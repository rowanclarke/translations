\id JHN - Okphela
\h iJọni
\toc1 Usomhi Onete oyi iJesu iKirisiti ni iJọni Ọ kẹkẹ
\toc2 iJọni
\toc3 iJọn
\mt2 Usomhi Onete oyi iJesu iKirisiti ni
\mt1 IJọni
\mt2 Ọ kẹkẹ
\c 1
\s1 Ungmemhi Ọni ọ khi agbọ
\p 
\v 1 Igbaekẹle, Ungmemhi Ọ she kpẹ la ọ. Ọni Ungmemhi ọ nu Ẹshinẹgba la. Ọni Ungmemhi Ọ khi Ẹshinẹgba.
\v 2 Igbaekẹle lọli ali Ẹshinẹgba e te ga la.
\v 3 Obọ oyọli a te ma emhikpa. Aa mẹ emhikhọghuo ni a ma ni aa rọte obọ oyọli ma.
\v 4 Lọli ọ mhọli agbọ na agbọagbọ. Oni agbọ oyọli, o ri ákpá na ẹgbọ na agbọ.
\p 
\v 5 Oni ákpá o gẹ nga alo ebili, ama alo ebili ọa dobẹ pfuse ọli a.
\p 
\v 6 Ẹshinẹgba ọ ghie ọmọse ọghuo ni a lu iJọni ghi ẹgbọ na agbọ.\f + \fr 1:6 \ft Li zẹ \fq iMat 3.1; iMak 1.4; iLuk 3.1-2\f*
\v 7 Lọli ọ bhale ya pfi ọtsẹlẹ shi ọni ọgbọ ni ọ khi oni ákpá, ni ẹgbọ nya e rọte oni ọtsẹlẹ miesuọ.
\v 8 Ọa khi ọni iJọni ọ khi oni ákpá; eri ọ li bhale ya pfi ọtsẹlẹ shi oni ákpá.
\v 9 Lọli ọ khi oni egbegbi ákpá, ni ọ ya bhale agbọ ni ọ ya ri imekẹ na ẹgbọ nya.
\p 
\v 10 Ọni Ungmemhi ọ la agbọ, ẹgbọ ẹa lẹsẹ ọli, abi o ri riẹ khia khi lọli a rọte obọ oyọli ma agbọ.
\v 11 Ọ bhale deba ẹgbọ eyọli, ẹa lama mie ọli.
\v 12 Ama, ebubu ni e da lama mie ọli, ni e lẹsẹ mie eva oyọli suọ, wẹwẹ ọ ri afu na e rọ̀ mele imi Ẹshinẹgba a.
\v 13 Ọa khi abi ita ali inyọ e liẹ bia ọgbọ alo-gbugbugbu a ri ona ngme, ama Ẹshinẹgba ọ khi ita wẹ.
\p 
\v 14 Ọni Ungmemhi ọ mele ọgbọ-a, ọ nu awa la agbọ ona, awa mẹ ufumhi oyọli, ikhi ufumhi oyi omi Ita ọtuọghuo kpe ni Ita ọ mhọli, ọni ọ rọte obọ oyi Ita bhale, ọni ọ mhọli isomhelemhi ali igẹsikia gbeku ọ.
\p 
\v 15 IJọni ọ́ kia tse abọ ingme oyọli yẹ ẹgbọ, ọ́ọ́ tsẹsẹ, ọ́ọ́ liẹ, “Ọna mhi gueyẹ ẹ khi ọ ya bhale odukhokho oyẹmhẹ, ama ọ fu dọsẹ mhẹ itobọ khi ọ kpẹ la agbọ neni a bia mhẹ.”
\p 
\v 16 Rọte isomhelemhi oyọli ni o gbeku ọ, awa te mhọli ikhivọsẹ ọdọda.
\v 17 Obọ oyi iMosisi Ẹshinẹgba ọ te ri ushi na awa, ama obọ oyi iJesu iKirisiti isomhelemhi ali igẹsikia e te bhale.
\v 18 Ọgbọkhọghuo ọa mẹ Ẹshinẹgba ghue. Ama, Omi Ẹshinẹgba ọtuọghuo kpe, ni lọli ali Ẹshinẹgba e khi ọghuo, ni lọli ali Ita e ga la, lọli o zẹ ni agbọ e rọ lẹsẹ Ita.
\s1 IJọni ọọ khi lọli ẹ khi Ọmiepfuese
\r (iMat 3.1-12; iMak 1.1-8; iLuk 3.1-18)
\p 
\v 19 Egbhali eyi iJu ni e la iJerusalẹmu e ghie eni ẹẹ ralo ugamhi oyi Ẹshinẹgba ali eni ẹ nu wẹ gbe ikanya owa-ugamhi, e ka mhila iJọni ọni ọ khi.
\p 
\v 20 IJọni ọa rọ sheli wẹ, ọ nyanya sọ wẹ ọ, ọ gueyẹ wẹ gboo khi ọa khi lọli khi ọni Ọmiepfuese.
\p 
\v 21 E mhila li, “Ọghuo u ke khi shọ? Elaja u khi?”\f + \fr 1:21 \ft Li zẹ \fq iDẹut 18.15,18; iMala 4.5\f*
\p IJọni ọọ, “Iiye.” E gbo mhila li.
\p “Ọmekẹguele ọyi Ẹshinẹgba u khi?”
\p Ọ ọ “Iiye.”
\p 
\v 22 E gbolo ẹ, “Gueyẹ anye ọni u khi shọ, ni anye mẹ emini anye ya gueyẹ eni e ghie anye, elọ yẹyẹ u khi shọ?”
\p 
\v 23 IJọni ọ rọte ungmemhi ni Azaya ọmekẹguele ọyi Ẹshinẹgba ọ ngme sọ wẹ ọ, ọọ, “Mhẹmhẹ mhi khi uruli oyi ọgbọ ni o la ọdagbe ẹ tsẹsẹ, ni ọọ liẹ, ‘A riẹlẹ udu oyẹ ẹ shi ekẹ khẹ Ọnọmhuẹ ni ọ́ ọ bhale.’ ”\f + \fr 1:23 \ft Li zẹ \fq Aza 40.3\f*
\p 
\v 24 Ẹgbọ ni ẹgbọ iFarisi e ghie ghi iJọni, e mhila li,
\v 25 “Abi u a rọ khi Ọmiepfuese, ni u a rọ khi Elaja, wẹkhi ọni ọmekẹguele ọyi Ẹshinẹgba u khi ena, elọ o zẹ ni u rọ ọ batazi ẹgbọ shọ?”
\p 
\v 26 IJọni ọ sọ wẹ ọ, ọọ, “Amẹ mhi rọ batazi ẹgbọ memena, ama ọgbọ ọghuo ọ la ẹ iteva memena ni aa lẹsẹ ne.
\v 27 Lọli ọ ke ya bhale odukhokho oyẹmhẹ, ni o khia khi mhia fu ramhi ọni ọ́ ọ̀ taghiẹ uli oyi ẹkuẹ ni ọ rọ sọ a.”
\p 
\v 28 Obini iBẹtani ni o la ukiẹkiẹ obini ovọ o te ẹ ngale shi okẹ iJọdani, ashini iJọni ọ la batazi ẹgbọ, a la mẹ eni ingme ena nya.
\s1 Omi osumha ọyi Ẹshinẹgba
\p 
\v 29 Ogbeakọlọ iJọni ọ mẹ khi iJesu ọọ bhale, iJọni ọ gueyẹ ẹgbọ, ọọ, “Omi Osumha ọyi Ẹshinẹgba ni ọ́ rue olamhẹ eyi agbọ vu na!
\v 30 Ọna mhi ngme abi mhi rọ liẹ, ‘Ọmọse ọghuo ọ ya bhale ni ọ́ fu dọsẹ mhẹ, itobọ khi ọ she kpẹ la ọ neni a bia mhẹ.’
\v 31 Egbegbi mhẹmhẹ mhia kpẹ lẹsẹ ọli ghue, ama eri mhi bhale ri amẹ ẹ batazi ẹgbọ ini mhi mẹ asha ri ọli khasẹ ẹgbọ iZirẹni.”
\p 
\v 32 Ighọ iJọni ọ pfi ọtsẹlẹ ona khi, “Mhi mẹ khi Ayẹmhẹ ọ li abi anekhukhu rọte idane tiemhie ya ma li egbe.
\v 33 Mhia kha kpẹ lẹsẹ ọli, ama ọni ọ ghie mhẹ mhi ri amẹ ke batazi ẹgbọ, ọọ mhẹ, ‘Ọni u da mẹ khi oni Ayẹmhẹ ọ tiemhie shi ọ khi ọ migha li egbe ne, lọli ọ khi ọni ọ ya ke ri Ayẹmhẹ-nọ-pfuasẹ batazi ẹgbọ.’
\v 34 Ighọ eni emini a gueyẹ mhẹ ena e li de shi ukpẹloe oyẹmhẹ, ni o rẹmhẹ gueyẹ ẹ khi Omi Ẹshinẹgba ọ khi.”
\s1 Eniyẹ odukhokho eni ododẹ ni iJesu ọ zẹ
\p 
\v 35 Ogbeakọlọ iJọni ali eniyẹ odukhokho eyọli etuava e gbo migha akaghọ.
\v 36 Abi iJọni ọ rọ mẹ khi iJesu ọọ dọsẹ, ọọ, “Bino Omi osumha ọyi Ẹshinẹgba.”
\p 
\v 37 Abi eniyẹ odukhokho etuava eghọ e rọ suọ ona te, e deba iJesu vu.
\v 38 IJesu ọ pfi alo ukhokho, ọ mẹ wẹ khi ẹẹ deba luẹ, ọ mhila wẹ, “Elọ a nono.”
\p Ẹẹ ọli, “Ọsẹsẹ, obo wa la?”
\p 
\v 39 Ọọ wẹ, “A bhale ya bino.” Ighọ e deba li, e mẹ obini ọ la. Aghọ e ke nu ọ la ẹlẹghọ nya rọte agogo ene ẹlẹ ọguota vu.
\p 
\v 40 Ọtuọghuo eniyẹ odukhokho etuava ni e suọ emini iJọni ọ ngme ni e deba iJesu vu ọ khi Aduru, inyọghuo iSamọ iPita.
\v 41 Ighọ Aduru ọ nyanya kpẹ te ododẹ nono iSamọ inyọghuo ọli gueyẹ, ọọ, “Anye she mẹ Ọmiepfuese.” (Emini a ri iKirisiti ngme khi, Ọmiepfuese.)
\v 42 Aduru ọ rue iSamọ bhale ghi iJesu.
\p IJesu ọ bino ọli, ọọ, “Yẹyẹ u khi ISamọ omi iJọni, iKefasi a kẹ ẹ ke lu ẹ. IPita ali iKefasi emhi oghuo a rẹwẹ ngme.”
\s1 IJesu ọ lu iFilipu ali iNataniẹ
\p 
\v 43 Ogbeakọlọ, iJesu ọ ke mu egbe khi lọli rọte aghọ vu ya ke je iGalili. Ọ mẹ iFilipu, ọọ li, “Deba mhẹ.”
\v 44 Ọnge iBẹtisaida ni Aduru ali iPita e khi iFilipu ọ li khi.
\v 45 IFilipu ọ ke nono iNataniẹli mẹ. Ọọ li, “Anye she mẹ ọni iMosisi ọ kẹkẹ ingme oyọli shi ebe ushi, ni emekẹguele e gbo kẹkẹ ingme oyọli shi Ebe-no-pfuasẹ, ikhi iJesu ọnge iNazarẹti Omi iJosẹfu.”
\p 
\v 46 INataniẹli ọọ, “INazarẹti wẹ, eminete o li rọte iNazarẹti ẹ lase?”
\p IFilipu ọọ, “Lẹsẹ bhale ya bino tsẹ.”
\p 
\v 47 Abi iJesu ọ rọ mẹ iNataniẹli khi ọọ bhale obini luẹ la, iJesu ọọ, “Egbegbi ọnge iZirẹni na, ọni ọa ya lo ẹgbhọli.”
\p 
\v 48 INataniẹli ọ mhila li, “Sẹ u ghọ lẹsẹ mhẹ?” IJesu ọọ, “Mhi she mẹ abi u rọ la udi ọkhua eni neni iFilipu ọ lu ẹ.”
\p 
\v 49 INataniẹli ọọ, “Ọsẹsẹ, Omi Ẹshinẹgba u khi, oghie oyi iZirẹni!”
\p 
\v 50 IJesu ọọ, “Itobọ khi mhiẹ khi mhi mẹ ẹ udi ọkhua eni u rọ tigbe miesuọ, u ya mẹ emini e dọsẹ ona.”
\v 51 Ọ gbo gueyẹ wẹ, “A ya mẹ khi idane o khueghie-a, a mẹ khi igẹni eyi Ẹshinẹgba e rọte idane ẹ tiemhile ya nga shi mhẹmhẹ Omi Ọgbọ ọ.”\f + \fr 1:51 \ft Li zẹ \fq Igbae 28.12\f*
\c 2
\s1 IJesu ọ ri amẹ mele onyọ a
\p 
\v 1 Ogbẹlẹ onuzi-esẹ, a la iKena na ekẹ iGalili ri ọmueshi ya ngeli. Inyọ iJesu ọ la aghọ,
\v 2 A li lu iJesu ali eniyẹ odukhokho eyọli shi oni ilegba ni a la ri ọmueshi ngeli.
\v 3 Abi onyọ ni a la aghọ da o rọ pfo, inyọ iJesu ọọ iJesu, “Onyọ e pfo wẹ rọ da.”
\p 
\v 4 IJesu ọọ, “Inyọ, khi ke gueyẹ mhẹ emini mhi ya li, itobọ khi ẹghẹghẹ oyẹmhẹ ọa ramhi ne.”
\p 
\v 5 Inyọ iJesu ọ gueyẹ eni e sọ onyọ, “A ri emini ọ da gueyẹ ẹ gbe akanya.”
\p 
\v 6 Ikpokpomhi idubọ echẹ esesa e la epfẹ aghọ na diẹ amẹ ẹ shi ni ẹgbọ iJu e rọ kpe egbe a abi ushi oyẹwẹ o ngme. Udubọ oghuo oghuo, ọọ mie italabi amẹ ene.
\v 7 IJesu ọ gueyẹ eni e sọ onyọ, “A ka diẹ amẹ vọ eni idubọ esesa.” Ighọ e diẹ amẹ vọ ẹwẹ nya tẹ unu tsuẹ.
\v 8 Ighọ ọọ, “A diẹ ọ ghi ọni ọ ri ukpẹloe ẹ khu oni ilegba.” Ighọ e diẹ ọ ghi ọ.
\v 9 Ọni ọ ri ukpẹloe ẹ khu ilegba ọ rọte eni amẹ ni a she rọ mele onyọ a da bino, ọa kpẹ lẹsẹ obini a mẹ wẹ, ama eni ẹ sọ onyọ e lẹsẹ obini a mẹ wẹ. Ighọ ọni ọmọse ọ lu ughuẹ-ọmueshi je epfẹ etẹ,
\v 10 ọọ li, “Ashini a la riẹlẹ emhi onana kpa, onyọ onete onana a kpẹ rọ lasele na ẹgbọ da khue neni a ri onyọ oni o kpọ-a lasele, Elọ o zẹ ni a rọ ri onyọ ona kpe shi aghọ?”
\p 
\v 11 Ona o khi akanya ọnyaloa oni ododẹ ni iJesu ọ gbe. Ẹoli iKena na ekẹ iGalili ọ la riẹlẹ ọ. Onana ọ rọ ri ufumhi oyọli khasẹ, ni eniyẹ odukhokho eyọli e rọ mie ọli suọ.
\p 
\v 12 Ona o dọsẹ se, iJesu ali inyọli, ghe inyọghuo ọli eni emọse ali eniyẹ odukhokho eyọli e tiemhi obini iKapanọmu. E la oobọ ukuku ogbẹlẹ.\f + \fr 2:12 \ft Li zẹ \fq iMat 4.13\f*
\s1 IJesu ọ lo elemhi Owa oyi Ẹshinẹgba le
\r (iMat 21.12-13; iMak 11.15-17; iLuk 19.45-46)
\p 
\v 13 Abi ẹghẹghẹ ukpe oyi ẹgbọ iJu ni a lu iPasova o rọ ti bhale, iJesu ọ nga obini iJerusalẹmu.\f + \fr 2:13 \ft Li zẹ \fq Okiali 12.1-27\f*
\v 14 Ọ́ bhale ya ẹ khi ẹgbọ e la elemhi apfẹ oyi Owa oyi Ẹshinẹgba ri ena ali isumha ali inekhukhu ẹ dẹ. Eghuo e shitọ pfa ikpaghọ na ẹgbọ.
\v 15 Ighọ iJesu ọ rue ili rọ lali utali ulumhekie rọ khu wẹ ya lase nya, ghe eni ena ali isumha; ọ miatsẹ wẹ ikpaghọ kua, ọ ghi wẹ abọ okphẹ kpha ku-a.
\v 16 Ọ́ọ́ eni e ri inekhukhu ẹ de, “A muno wẹ ana-a! Sẹ a li ri owa oyi Ita mhẹmhẹ ẹ mele oki a.”
\v 17 Eniyẹ odukhokho eyọli e ya yelele emini a kpẹ kẹkẹ shi Ebe-no-pfuasẹ khi, “Ingme owa oyẹ o mu mhẹ egbe gba.”\f + \fr 2:17 \ft Li zẹ \fq Iwolo 69.9\f*
\p 
\v 18 Ighọ enighie eyi iJu e mhila iJesu ini ọ mhọli ikanya ọnyaloa ni ọ ya gbe ni o ya rọkhasẹ ẹwẹ khi ọ mhọli afu ni ọ rọ riẹlẹ enana nya.
\p 
\v 19 IJesu ọọ wẹ, “A bighi oni Owa oyi Ẹshinẹgba ona nya gbe, mhi ya gbo riẹlẹ ọ tọ ogbẹlẹ esẹ.”\f + \fr 2:19 \ft Li zẹ \fq iMat 26.61; 27.40; iMak 14.58; 15.29\f*
\p 
\v 20 Enighie eyi iJu e ke mhila, “Owa ni a ri ikpe egbhuẹva ali esesa tọ wa liẹ khi u ri ogbẹlẹ esẹ tsẹ ya riẹlẹ tọ?”
\p 
\v 21 Ama egbe oyọli ọ ri oni Owa oyi Ẹshinẹgba ni ọ ngme khọkhọ.
\v 22 Abi ọ rọ ghu-a ni Ẹshinẹgba ọ rọ gbo guise ọ le, eniyẹ odukhokho eyọli e rọ tigbe sa ya to emini ọ ke ngme. Ona o rẹwẹ mie ungmemhi oni o la Ebe-no-pfuasẹ, ali ingme oyi iJesu lolo suọ.
\p 
\v 23 Ẹghẹghẹ ni iJesu ọ rọ la iJerusalẹmu, ikhi ẹghẹghẹ ukpe iPasova, ebubu ẹgbọ e rọ mie ọli suọ itobọ khi e mẹ ikanya ọnyaloa ni ọ gbe.
\v 24 Ama iJesu ọa ya regbenga wẹ obọ itobọ khi ọ lẹsẹ emini ẹgbọ e khi pfo nya.
\v 25 Ọa khi ọgbọ ọ ke gbo ya gue ingme oyi ẹgbọ yẹ ọli, itobọ khi ọ she lẹsẹ emini o la wẹ udu.
\c 3
\s1 IJesu ali iNikodemọsi
\p 
\v 1 Ọmọse ọghuo ọ la ọ ni ọ la otu iFarisi, ọ khi ọkhẹmhuẹ ni ọ mu ẹloe shi elemhi iJu, a lu ọli iNikodemọsi.
\v 2 Ọni ọmọse ọna ọ bhale deba iJesu ẹliyọsẹ ẹlẹghuo, ọọ li, “Ọsẹsẹ, anye lẹsẹ khi ọni ọọ sẹsẹ ni ọ rọte obọ oyi Ẹshinẹgba bhale u khi. Itobọ khi ọgbọkhọghuo ọa ya dobẹ ke gbe ikanya ọnyaloa enabi u wa gbe ena ini Ẹshinẹgba ọa nu ọli la.”
\p 
\v 3 IJesu ọọ li, “Mhi gue igẹsikia yẹ khi, ini aa li riẹlẹ ọgbọ bia, ọa ya mẹ Eghiele oyi Ẹshinẹgba.”
\p 
\v 4 INikodemọsi ọọ li, “Sẹ a li gbo riẹlẹ ọgbọ ni ọ womhẹ se bia? Eri ọ gbo ya lo inyọli elemhi ni ọ gbo riẹlẹ ọli bia?”
\p 
\v 5 IJesu ọ sọli ọ, ọọ li, “Mhi gue igẹsikia yẹ khi, aa mẹ ọgbọkhọghuo ni ọ ya lo Eghiele oyi Ẹshinẹgba ini aa bia li elemhi amẹ ali elemhi Ayẹmhẹ.
\v 6 Ọmọse ali ọkpotso ẹẹ bia ọgbọ alo gbugbugbu, ama Ayẹmhẹ oyi Ẹshinẹgba a rọ riẹlẹ ọgbọ ọ bia elemhi ayẹmhẹ.
\v 7 Khi zẹ ni ungmemhi ni mhiẹ khi, ‘A mema riẹlẹ ẹ ya bia,’ o lighọ ri abọ shẹ.
\v 8 Obini o ghọle akpekpeli o li ẹ je, eri awa liẹ suọ abi o liẹ li, ama awa aa ya mẹ ọli. Ighọ ingme oyi eni a riẹlẹ bia elemhi Ayẹmhẹ oyi Ẹshinẹgba e li.”
\p 
\v 9 INikodemọsi ọ mhila iJesu, “Sẹ a liẹ mẹ ghọ?”
\p 
\v 10 IJesu ọọ, “Yẹyẹ ukpokpo-ọgbọ ọguebe ni u liẹ sẹsẹ ẹgbọ ekẹ iZirẹni waa lẹsẹ ona?
\v 11 Abi o li mhi li gue ọli ẹ yẹ khi emini anye lẹsẹ, anye ẹ ngme. Emini anye mẹ, anye ẹ gueyẹ agbọ. Ama aa nono ni a mie usomhi oyi anye suọ.
\v 12 Ini waa mie mhẹ suọ ini mhi gue ingme ena agbọ ona yẹ, sẹ u liẹ mie mhẹ suọ ini mhi gue ingme iloghie yẹ?
\v 13 Ọgbọkhọghuo ọa kpẹ ye iloghie jele ghue, sẹ ni mhẹmhẹ Omi Ọgbọ ni mhi rọte iloghie tiemhie.
\v 14 Abi iMosisi ọ ke li gẹ ẹnyẹ ni a ri igolu lumhi shi ukpokpo, ni ọ tsua li idane obini ọdagbe ifufu, ighọ a mema li tsua Omi Ọgbọ idane.\f + \fr 3:14 \ft Li zẹ \fq iNọba 21.9\f*
\v 15 Ẹghẹghẹ aghọ, ọnini ọ da mie ọli suọ, ọ ya mhọli agbọ na agbọagbọ.
\p 
\v 16 “Irari khi Ẹshinẹgba ọ̀ ọ́ nono ingme oyi agbọ gba, lọli ọ rọ rue Omiọli ọni ọmọse ọtuọghuo kpe na agbọ, ẹghẹghẹ aghọ ọnini ọ da mie ọli suọ ne, ọa ya pfua, ama ọ ya mhọli agbọ na agbọagbọ.
\v 17 Ẹshinẹgba ọa ghie omi ọli bhale agbọ, ni ọ bhale ya pfa ẹzọ mu ẹgbọ na agbọ, eri ọ ghie ọli, ọ bhale ya mie agbọ pfuese.
\v 18 Aa ya pfa ẹzọ mu ọni ọ da mie Omi Ẹshinẹgba suọ, ama ọni ọa da mie ọli suọ, a she pfa ẹzọ mu ọli se, itobọ khi ọa mie Omi Ẹshinẹgba ọtuọghuo kpe suọ.
\v 19 Abi a liẹ sọ oni ẹzọ na. Ákpá o bhale agbọ, ama ẹgbọ e nono alo ebili nẹ, itobọ khi ikanya ebe ẹẹ gbe.
\v 20 Ọni ọ́ gbe ikanya ebe ọa ya nono ákpá, ọa tigbe ẹ bhale ákpá itobọ khi ikanya eyọli e ya ri udi lasele ini e bhale ákpá.
\v 21 Ama ọni ọ da ri ungmemhi oyi Ẹshinẹgba ni o khi igẹsikia a gbe akanya ne, ọ́ bhale ákpá ashini a te ẹ mẹ ekẹ, ni ikanya eyọli e rọkhasẹ khi odẹ oyi Ẹshinẹgba ọ rọte.”
\s1 Ọtsẹlẹ ni iJọni ọ pfi shi ingme oyi iJesu
\p 
\v 22 Ẹlẹ lese iJesu ali eniyẹ odukhokho eyọli e je ekẹ iJudia. Ọ nu wẹ la oobọ ukuku ẹghẹghẹ, ọọ batazi ẹgbọ.
\v 23 IJọni ọ la Ainoni ni ọa nuẹ shi iSalimu li batazi ẹgbọ, itobọ khi amẹ e lo bu shi aghọ. Ẹgbọ e je aghọ deba li ni ọ batazi wẹ.
\v 24 Ẹghẹghẹ aghọ aa mu IJọni shi owa ighumha ne.\f + \fr 3:24 \ft Li zẹ \fq iMat 14.3; iMak 6.17; iLuk 3.19-20\f*
\p 
\v 25 Eniyẹ odukhokho eyi iJọni eghuo e nu ọgbọ iJu ọghuo khakọ shi ingme ikpegbe a ona ugamhi.
\v 26 Ighọ e le deba iJọni, ẹẹ, “Ọsẹsẹ, u ke yelele ọmọse ọghuo ni u ke batazi, ọni u ngme ingme oyọli epfẹ okẹ iJọdani ẹlẹghọ, ọ li ẹ batazi ẹgbọ, lọli ẹgbọ nya e ke na deba memena.”
\p 
\v 27 IJọni ọọ wẹ, “Aa mẹ emhikhọghuo ni ọgbọ ọ mhọli ni ọa khi Ẹshinẹgba ọ rọli na.
\v 28 Ẹẹ ena a ga suọ abi mhi rọ liẹ khi ọa khi mhẹmhẹ mhi khi Ọmiepfuese, khi eri a li ghie mhẹ ralo na li.\f + \fr 3:28 \ft Li zẹ \fq iJọn 1.20\f*
\v 29 Ọmọse ọni ọ rue ọmueshi ọ́ khi ughuẹ ọmueshi. Eri ọmọle ọni ọmọse ọni ọ rue ọmueshi ọ́ ri esọ shi ekẹ migha ke khẹ ughuẹ ọmueshi. Ọ kha da suọ khi ọmọle ọ da ngme ne, egbe ẹẹ mu ọli. Ighọ egbe e liẹ mu mhẹ memena, ighọ oghẹlẹ oyẹmhẹ o gbo vọ.
\v 30 Ufumhi oyọli o mema ke nga shiọ, ufumhi oyẹmhẹ ọ̀ ọ ke tiemhi.
\p 
\v 31 “Ọni ọ rọte ilimhi tiemhie ọ́ fu dọsẹ ẹgbọ nya. Ọni ọ rọte agbọ ana lasele, ọna agbọ ona ọ khi. Irarighọ, ingmemhi eyi agbọ ana a ke ngme. Ama ọni ọ rọte ilimhi tiemhie ọ́ fu dọsẹ ẹgbọ nya.
\v 32 Emini ọ mẹ ali emini ọ suọ ilimhi, ọ gue ẹ yẹ ẹgbọ, ama ọgbọkhọghuo ọa mie ọli suọ.
\v 33 Ọni ọ da mie emini ọ gueyẹ agbọ suọ ne, eri ọ rọkhasẹ khi igẹsikia Ẹshinẹgba ọ́ ngme.
\v 34 Ọni Ẹshinẹgba ọ́ ghie, ọọ ngme ungmemhi oyi Ẹshinẹgba, itobọ khi eri Ẹshinẹgba ọ ri Ayẹmhẹ oyọli na li gbe ku ọ.
\v 35 Eri Ẹshinẹgba Ita ọ nono ingme oyi Omiọli ọni ọmọse, irarighọ ọ rọ ri emhikpa nga li obọ.\f + \fr 3:35 \ft Li zẹ \fq iMat 11.27; iLuk 10.22\f*
\v 36 Ọni ọ da mie Omiọli suọ ne, eri ọọ mhọli agbọ na agbọagbọ, ama ọni ọ da kie ọli ne, ọa ya mhọli agbọ, eri ibiselemhi oyi Ẹshinẹgba ọọ deba li agbọagbọ.”
\c 4
\s1 IJesu ọ nu ọkpotso ọnge iSameria ngme
\p 
\v 1 Ẹgbọ iFarisi e suọ khi ebubu ẹgbọ ẹ deba iJesu, ali khi ọ gbo batazi eniyẹ odukhokho bu dọsẹ iJọni.
\v 2 Ọa khi iJesu ọ ri obọ oyọli mema batazi ẹgbọ, ama eniyẹ odukhokho eyọli e batazi ẹgbọ.
\v 3 Ighọ abi iJesu ọ́ rọ̀ suọ ingme ni ẹgbọ e ngme, ọ rọte ekẹ iJudia vu, ọ mu egbe pfi je iGalili.
\v 4 Ọ ya rọte odẹ iSameria dọsẹ abi ọ rọ lẹ iGalili.
\p 
\v 5 Ighọ ọ́ bhale ẹoli na lu iSicha ni o la ekẹ iSameria, ni ọa nuẹ shi ekẹ ni iGiekọpu ọ rọ na iJosẹfu omiọli ọni ọmọse.\f + \fr 4:5 \ft Li zẹ \fq Igbae 33.19; iJosh 24.32\f*
\p 
\v 6 Aghọ ilijia oni a lu ilijia oyi iGiekọpu o la. O lọsẹ iJesu itobọ okiali ni ọ kia ramhi aghọ, ighọ ọ shitọ epfẹ oni ilijia. Ọguota o lẹsẹ mu ekẹ oni ẹghẹghẹ.
\p 
\v 7 Ọkpotso ọnge iSameria ọghuo ọ bhale ya a amẹ. IJesu ọọ li, “Diẹ amẹ na mhẹ da.”
\v 8 Ẹghẹghẹ aghọ eniyẹ odukhokho eyọli e she lo ifuapfẹ ya dẹ eminale. \fig IJesu ali ọkpotso ọnge iSameria |src="DN00433b.tif" size="col" loc="JHN 4.8" copy="Dunham" ref="4.8"\fig*
\p 
\v 9 Ọni ọkpotso ọnge iSameria ọọ iJesu, “Ọnge iJu u khi, mhẹmhẹ mhi khi ọnge iSameria, sẹ u ke li a liẹ mhi diẹ amẹ nẹ da?” Emini o zẹ ni ọ rọ ngme na khi, ẹgbọ iJu ali ẹgbọ iSameria ẹa ri egbe ẹ ti emhi egbe.\f + \fr 4:9 \ft Li zẹ \fq Ẹzira 4.1-5; iNee 4.1-2\f*
\p 
\v 10 IJesu ọ li, “Ini u lẹsẹ isomhopfa ni Ẹshinẹgba ọ́ rọ́ na ọgbọ lọ, ni u gbo rọ lẹsẹ emini ọgbọ ni ọọ mhila ẹ amẹ ọ khi lọ, u kha mhila li ọ ri amẹ nẹ da. Ẹghẹghẹ aghọ ni ọ ri amẹ ni e ri agbọ ọ na ọgbọ nẹ da.”
\p 
\v 11 Ọni ọkpotso ọ ke mhila iJesu, ọọ, “Ọga, waa mhọli emhi ni a rọ ọ a amẹ, oni ilijia o limhi. Obo u ke te ya mẹ eni amẹ ni e ri agbọ ọ na ọgbọ na a mhẹ da?
\v 12 Eri u kẹ liẹ khi yẹyẹ u fu dọsẹ iGiekọpu ita anye kpa?” Lọli ọ tọ oni ilijia ona, ni ọ ri ọli na anye, ni lọli ali imiọli ali elamhakọ eyọli e gbo te ọ da.
\p 
\v 13 IJesu ọ ya sọ li ọ, ọ li, “Onini ọ da da amẹ eyi ilijia ena, okiamẹ o gbo ya gbe ọli.
\v 14 Ama okiamẹ ọa tigbe kẹ ẹ gbe ọnini ọ da da amẹ ni mhi ya rọ na li da. Itobọ khi amẹ eyẹmhẹ e ya mele okẹ ni ọa ke ya khakha ghue shi ọli elemhi, ni o ya ke sha kule ri agbọ na agbọagbọ na li.”
\p 
\v 15 Ọni ọkpotso ọọ, “Ọga Kpẹkpẹ ri eni amẹ na mhẹ da ini okiamẹ o khi ke gbo gbe mhẹ, ini mhi khi ke gbo bhale akana ya a amẹ.”
\p 
\v 16 IJesu ọọ, “Ka lu ọmọse ni ọ rue ẹ shi bhale.”
\p 
\v 17 Ọni ọkpotso ọọ, “Mhia mhọli ọmọse.” IJesu ọọ li, “Igẹsikia lọ, ni u wẹ khi u a mhọli ọmọse,
\v 18 itobọ khi u she kpẹ mhọli emọse oshe ni u kpẹ ngeli na. Ọni u ga nu la memena, ọa khi lọli ọ rẹ shi.”
\p 
\v 19 Ọni ọkpotso ọọ, “Kie! Ọga, mhi she mẹ ọli khi ọmekẹguele ọyi Ẹshinẹgba u khi.
\v 20 Ukhomhi ute onana eni e bia anye ẹgbọ iSameria, e kpẹ la ga ugamhi, ama ẹẹ ẹgbọ iJu, ẹ khi iJerusalẹmu awa mema la ke ga ugamhi.”
\p 
\v 21 IJesu ọọ li, “Mie mhẹ suọ khi ẹghẹghẹ ọọ bhale ni u a ke rọ la ukhomhi ute ona, wẹ khi iJerusalẹmu ya ga Ita.
\v 22 Emini ẹẹ ẹgbọ iSameria aa lẹsẹ, a ga, ama anye lẹsẹ emini anye ẹ ga itobọ khi obọ oyi iJu imiepfuese o te bhale.
\v 23 Ama, ẹghẹghẹ ọọ bhale, oni ẹghẹghẹ o she ramhi ni ẹgbọ eni e ri igẹsikia ẹ ga Ẹshinẹgba e rọ ya ke ga li abi Ayẹmhẹ oyọli o li rọkhasẹ wẹ, e gbo te odẹ igẹsikia ga li, itobọ khi ẹgbọ eni e lighọ ọ ga li, ọọ nònō.
\v 24 Ayẹmhẹ oyi Ẹshinẹgba ọ khi, eni ẹẹ ga li e mema ya ke ga li abi Ayẹmhẹ o rọkhasẹ wẹ, ali rọte odẹ igẹsikia.”
\p 
\v 25 Ọni ọkpotso ọọ iJesu, “Mhi lẹsẹ khi Ọmiepfuese (ọni a lu iKirisiti) ọ̀ ọ bhale. Ọ kha bhale, ọ ya khueghie emhikpa gueyẹ anye.”
\p 
\v 26 IJesu ọ sọ ọni ọkpotso ọ, “Lọli mhi khi ni mhi nu ẹ ngme ena.”
\p 
\v 27 Abi e kie li ngme, eniyẹ odukhokho eyọli e bhale ya ẹ khi ọ nu ọkpotso o ngme, o ri abọ sha wẹ. Ọngẹwẹ ọa mhila li, “Elọ wa nono?” Wẹkhi e ri e mhila li, “Elọ o zẹ nu u rọ nu ọli ẹ ngme?”
\p 
\v 28 Ighọ ọni ọkpotso ọ zẹ akhe amẹ oyọli obọ shi aghọ, ọ je ifuapfẹ kia gueyẹ ẹgbọ, ọọ liẹ,
\v 29 “A bhale ka ghe ọmọse ọghuo ni ọ gue emini mhi ga riẹlẹ ghue nya yẹ mhẹ. Ọmiepfuese ọ fẹ ya khi?”
\v 30 Ẹgbọ e vẹ gbii te ifuapfẹ bhale ashini iJesu ọ la.
\p 
\v 31 Ẹghẹghẹ aghọ, eniyẹ odukhokho eyọli e ke lema li, “Ọsẹsẹ, waa ke le eminale.”
\p 
\v 32 IJesu ọọ wẹ, “Mhi mhọli eminale ni mhia le ni aa lẹsẹ.”
\v 33 Eniyẹ odukhokho eyọli e mhila egbe wẹ́, “Eri ọgbọkhọghuo ọ̀ kpẹ ri eminale ghi ọ le?”
\p 
\v 34 IJesu ọọ wẹ, “Eminale oyẹmhẹ khi, ni mhi riẹlẹ ọghuẹmhẹ oyi ọni ọ ghie mhẹ, ni mhi rọ gbo gbe akanya oyọli pfo.
\v 35 Aa she ngme ọ khi, ‘Iki ene e ke kpọle ni a rọ ke ya khiẹsẹ emhi ẹkọmhi’? Mhi gue ẹ yẹ ẹ memena, a bino khi emhi ẹkọmhi na ishemhi e she bie ni a khiẹsẹ.
\v 36 Memena a she ẹ fali eni ẹ khiẹsẹ ishemhi ota akanya, ni e ke khiẹsẹ ikhiẹsẹ ni o ri agbọ na agbọagbọ ọ bhale. Ẹghẹghẹ aghọ ni a bhale ya ẹ khi eni e rọ kọ ali eni ẹ khiẹsẹ e ga kugbe ke ghẹlẹ.
\v 37 Onana o rọkhasẹ khi emini ẹgbọ ẹ ngme khi igẹsikia o khi, ikhi ungmemhi ni ọọ, ‘Ọni ọ rọ kọ, ọ kiọda shi ọni ọ khiẹsẹ.’
\v 38 Eri mhi ghie ẹ a ka khiẹsẹ emini aa rọ kọ. Ẹgbọ elese e ya gbe ikanya ni e toto rẹwẹ kọ, ama ẹẹ a mẹ eleli ikanya eyẹwẹ.”
\s1 Ebubu ẹgbọ iSameria e miesuọ
\p 
\v 39 Ebubu ẹgbọ iSameria ni e la oni ẹoli e ri itobọ emini ọni ọkpotso ọghọ ọ́ gueyẹ wẹ mie iJesu suọ, ikhi emini ọ ngme ni ọọ, “A bhale ya ghe ọni ọ gue emini mhi ga riẹlẹ ghue nya yẹmhẹ.”
\v 40 Abi eni ẹgbọ iSameria e rọ bhale deba iJesu, e lema li ọ kpẹkpẹ ọ ku shi na ẹwẹ. Ighọ iJesu ọ ku shi na wẹ ogbẹlẹ eva.
\p 
\v 41 Ebubu ẹgbọ elese e gbo mie iJesu suọ itobọ ingmemhi ni ọ nu wẹ ngme.
\v 42 Eni ẹgbọ e kẹ ọni ọkpotso, “Anye she miesuọ memena. Ọa khi itobọ emini u gueyẹ anye tsẹ anye rọ miesuọ, ama itobọ khi anye she suọ emini ọ ngme, anye gbo lẹsẹ egbegbọ khi ọni ọmọse ọna ọ ga khi ọni Ọmiepfuese.”
\s1 IJesu ọ ri omi ọni ọ gbe akanya igọmẹti ni ọ fu ze
\r (iMat 8.5-13; iLuk 7.1-10)
\p 
\v 43 IJesu ọ la iSameria ramhi ogbẹlẹ eva. Ọ rọte aghọ vu je iGalili.
\v 44 Ọ she kpẹ liẹ khi ẹgbọ ẹa la ẹoli oyi ọmekẹguele ọyi Ẹshinẹgba a mu ekpẹ na li.\f + \fr 4:44 \ft Li zẹ \fq iMat 13.57; iMak 6.4; iLuk 4.24\f*
\v 45 Abi ọ rọ lo ekẹ iGalili le, ẹgbọ iGalili e mie ọli egbegbọ, itobọ khi ukpẹloe oyẹwẹ iJesu ọ la gbe ikanya ọnyaloa ni ọ la iJerusalẹmu gbe abi e rọ riẹlẹ ukpe iPasova.\f + \fr 4:45 \ft Li zẹ \fq iJọn 2.23\f*
\p 
\v 46 Ighọ iJesu ọ gbo nyenẹ egbe je iKena ni o la ekẹ iGalili, ashini ọ ke la ri amẹ mele onyọ a. Ọmọse ọghuo ni ọ gbe akanya igọmẹti ọ la akaghọ, ni omi ọli ọ la iKapanọmu ghua.\f + \fr 4:46 \ft Li zẹ \fq iJọn 2.1-11\f*
\v 47 Ọni ọmọse ọ suọ khi iJesu ọ rọte ekẹ iJudia ẹ bhale iGalili. Ighọ ọ bhale ya lema iJesu ọ kpẹkpẹ ọ deba luẹ ya nu lọli ri omi luẹ, ni ọa ze ni ọ la akọ eghuli ze.
\v 48 IJesu ọọ, “Ini aa li mẹ ọlẹlẹ ọnyaloa ali ọshabọ, aa ya miesuọ.”
\p 
\v 49 Ọni ọmọse ni ọ gbe akanya igọmẹti, ọọ, “Ọnọmhuẹ, kpẹkpẹ bhale neni omimhẹ ọọ ghua.”
\p 
\v 50 IJesu ọọ li, “Ke je khi omiẹ ọ ya ze, ọa ya ghu.” Ọni ọmọse ọ mie emini iJesu ọ gueyẹ ọ suọ, ọ́ọ̀ je.
\v 51 Abi ọ rọ je, eni ẹẹ ga li, e bhale ya lona li odẹ, e gueyẹ ọli, “Omiẹ ọ she ze.”
\p 
\v 52 Ọni ọmọse ọ mhila wẹ, “Ẹghẹghẹ onoghuo ọni ọmọ ọ la ze?” E gueyẹ oli khi, “Agogo oghuo ọguota oodẹ ọni ọmọ ọ la ze.”
\v 53 Ọni ita ọni ọmọ ọ sato khi ẹghẹghẹ aghọ tee iJesu ọ la gueyẹ luẹ, “Omiẹ ọ ya ze.” Lọli ali apfẹ ọli nya e mie iJesu suọ.
\p 
\v 54 Onana o khi akanya ọnyaloa onuzi-eva ni iJesu ọ gbe abi ọ rọ rọte ekẹ iJudia bhale iGalili.
\c 5
\s1 IJesu ọ ri ọmọse ọghuo ni ọọ ghua ze
\p 
\v 1 Abi a rọ mẹ ingme ena se, iJesu ọ nga obini iJerusalẹmu shi ukpe ni ẹgbọ iJu e riẹlẹ.
\v 2 Mena, odẹ unuẹkpẹ ni a lu Isumha o la iJerusalẹmu. Atekẹ ni okẹ o chọchọ shi o la aghọ. IBẹtisaida a ri ẹlẹmhi Iburu ẹẹ lu oni okẹ. Ikuku ikholo ishe ni a ghi e la gasẹ oni okẹ.
\v 3 Ebubu ẹgbọ ni ẹa ze, ikhi ezalo, ali eni ẹa dobẹ ẹ kia ali eni e ghu egbe-a, e yẹshi gasẹ oni okẹ. Eri e migha khẹ ẹghẹghẹ ni a rọ ọ wushe oni okẹ-a.
\v 4 [Irari khi o mhọli ẹghẹghẹ ni agẹni ọyi Ẹshinẹgba ọ rọọ tiemhi elemhi oni okẹ ya wushe ọli-a. Ẹghẹghẹ aghọ ọnini ọ da kpẹ te ododẹ ya tiemhi oni okẹ ini ọni agẹni ọ lẹsẹ wushe ọli-a se, a rọli ze, ughuamhi onini o tseku yẹsẹ ọli ẹ ngme]
\v 5 Ọmọse ọghuo ọ la aghọ ni o she gba ikpe uye-ali-igbẹlele abi ọ te ẹ ghua.
\v 6 IJesu ọ bhale ya ẹ ọni ọmọse shi aghọ, ọ lẹsẹ khi ọ she la aghọ tẹsẹ. IJesu ọ mhila li, ọọ li, “Wa nono ni u ze?”
\p 
\v 7 Ọni ọmọse ni ọ ghua ọ sọ li ọ, ọọ, “Ọga mhi aa mhọli ọgbọ ni ọ ya kpaghiẹ mhẹ obọ mu mhẹ tiemhi elemhi okẹ. A kha da lẹsẹ wushe okẹ-a se, ni mhi rọ da mu egbe ni mhi tiemhi ne, ọgbọ ọlese ọ kpẹ tiemhi khẹ mhẹ.”
\p 
\v 8 Ighọ iJesu ọọ li, “Vule! Rue iya oyẹ mhuẹ obọ ni u ke kia.”
\v 9 Ighọ ọni ọmọse ọ ze aghọ aghọ, ọ rue iya oyọli, ọọ kia. Ẹlẹghọ o khi Ogbẹlẹ iyẹmhẹa oyi ẹgbọ iJu.
\p 
\v 10 Enighie eyi iJu ẹẹ ọni ọmọse ni a rọ ze, “Kieee! Amo o khi Ogbẹlẹ iyẹmhẹa oyi ẹgbọ iJu. Eri u gbe ushi ni Ẹshinẹgba ọ rọ na iMosisi-a. Ighuighuẹ lọ ni u rọ tsua iya oyẹ ẹlẹ iyẹmhẹa.”\f + \fr 5:10 \ft Li zẹ \fq iNee 13.19; iJere 17.21\f*
\p 
\v 11 Ọni ọmọse ọọ, wẹ, “Ọmọse ni ọ rẹ mhẹ ze ọọ mhẹ, ‘Rue iya o yẹ, u ke kia.’ ”
\p 
\v 12 E mhila li, “Ọghuo ọ khi ọni ọgbọ ni ọ gueyẹ u rue ọli ekẹ u ke kia?”
\p 
\v 13 Ọni ọmọse ni a she rọ ze, ọa ke lẹsẹ ọgbọ ni ọ rọ li ze, itobọ khi iJesu ọ she lo ifuabọ ẹgbọ oni ẹghẹghẹ.
\p 
\v 14 Abi a rọ mẹ ena se, iJesu ọ bhale ya ẹ ọni ọmọse ni ọ rọ ze elemhi Owa oyi Ẹshinẹgba. IJesu ọọ li. “Ghekhẹ, abi u rọ da ze se ena, khi ke gbo lamhẹ, ini emhi obe olese ni o dọsẹ ana o khi ya li ẹ.”
\p 
\v 15 Ighọ ọni ọmọse ọ vu, ọ ya gueyẹ ẹgbọ iJu khi iJesu ọ rẹ luẹ ze.
\v 16 Itobọ khi iJesu ọ gbe ikanya enana Ogbẹlẹ iyẹmhẹa oyi ẹgbọ iJu, ẹgbọ iJu ee jili ọli.
\v 17 IJesu ọ gueyẹ wẹ, ọọ, “Ẹghẹghẹ kpa Itamhẹ ọ rọ gbe akanya, ighọ mhẹmhẹ mhi li liẹ gbe akanya.”
\p 
\v 18 Itobọ ungmemhi onana ẹgbọ iJu e rọ mema gba li abi e li ya gbe ọli-a. Ọa khi itobọ khi ọ gbe ushi oyi Ogbẹlẹ iyẹmhẹa oyi ẹgbọ iJu tsẹ e rọ ye ugbamhi oyọli, ama itobọ khi ọ̀ọ́ khi Ẹshinẹgba ọ khi Ita lọli. Ẹ liẹ khi e li ọ ri onana a liẹ khi otu lọli ali Ẹshinẹgba e khi.
\s1 Ẹshinẹgba ọ ri afu na Omi ọli
\p 
\v 19 IJesu ọ gueyẹ wẹ, ọọ, “Abi o li mhi li gue ọli ẹ yẹ ẹ, khi mhẹmhẹ Omi Ẹshinẹgba mhi aa dobẹ ya riẹlẹ emhikhọghuo ọọtsobọ oyẹmhẹ, ama emini mhi mẹ khi Ẹshinẹgba itamhẹ ọọ riẹlẹ, mhi ya ke riẹlẹ.
\v 20 Irari khi Ita ọ̀ nono ingme oyi omiọli ọ rọ ri emini ọ riẹlẹ nya khasẹ ọli. Ọ ya gbo ri emini e fu dọsẹ ena khasẹ mhẹ ni o ya sha ẹ abọ.
\v 21 Abi Ita ọ li guise eni e ghu-a le ni ọ gbo ri agbọ na wẹ, ighọ mhẹmhẹ omi ọli mhi li ya ri agbọ na ọni ọ ghọle mhẹ.
\v 22 Ita ọa ya ri ọgbọkhọghuo gue ẹzọ, ama omiọli ọ ri afu na, ni ọ rọ ri ẹgbọ gue ẹzọ.
\v 23 Ni a bhale ya ẹ khi ọgbọkpa ọ mu ekpẹ na ọni Ọmọ abi a li mu ekpẹ ẹ na Ita. Ọni ọa da mu ekpẹ na ọni Ọmọ ọa mu ekpẹ na ọni Ita ni o ghie oni Ọmọ.
\p 
\v 24 “Abi o li mhi li gue ọli ẹ yẹ ẹ khi, ọni ọ da suọ ungmemhi oyẹmhẹ ni ọ da gbo mie ọni ọ ghie mhẹ suọ, ọ she mhọli agbọ na agbọagbọ. Ọgbọ ọa ya pfa ẹzọ mu ọli, itobọ khi ọ she rọte odẹ eghuli lasele bhale odẹ agbọ.
\v 25 Abi o li mhi li gue ọli ẹ yẹ ẹ khi ẹghẹghẹ ọọ bhale, oni ẹghẹghẹ na, ni eni e ghu-a e rọ ya suọ ungmemhi oyi Omi Ẹshinẹgba, eni e da suọ ungmemhi oyọli, e ya la agbọ.
\v 26 Abi Ita ọ li khi ọni ọ ri agbọ ọ na ọgbọ, ighọ ọ ri oni agbọ na Omiọli, ni ọ li ke rọ na ẹgbọ.
\v 27 Ọ she gbo ri afu ni a rọ sọ ẹzọ na Omi ọli, itobọ khi lọli ọ khi Omi Ọgbọ.
\p 
\v 28 “Emini mhi gueyẹ ẹ, o khi sha ẹ abọ, itobọ khi ẹghẹghẹ ọọ bhale ni ilimhi nya ni a she rọ tọ e ya suọ uruli oyọli.
\v 29 E kha da suọ oni uruli ne, e ya guale, e te uji fiẹ lase, eni e da riẹlẹ onete, e ya mhọli agbọ, ama ẹgbọ ebe e ya guale shi epfua.\f + \fr 5:29 \ft Li zẹ \fq iDan 12.2\f*
\v 30 Emhikhọghuo ọa la ọ ni mhi dobẹ ya riẹlẹ ọọtsobọ oyẹmhẹ. Abi itamhẹ ọ gueyẹ mhẹ mhi li sọ ẹzọ mhi liẹ sọ ẹzọ. Isọ-ẹzọ oyẹmhẹ oni o migha lọ, itobọ ọa khi abi o ghọle mhẹ mhi liẹ gbe ikanya, ama emini o ghọle Itamhẹ ni ọ ghie mhẹ mhi rọ gbe akanya.
\s1 A pfi ọtsẹlẹ shi ọni iJesu ọ khi
\p 
\v 31 “Mhi aa ya pfi ọtsẹlẹ na egbe mhẹ. Mhi kha pfi ọtsẹlẹ na egbe mhẹ, ẹgbọ ẹa ya rue oni ọtsẹlẹ shi egbegbọ.
\v 32 Ọgbọẹse ọ la ọ ni ọ pfi ọtsẹlẹ na mhẹ. Mhi lẹsẹ ọtsẹlẹ oyọli ni ọ pfi ẹ na mhẹ khi egbegbọ lọ.
\p 
\v 33 “A she kpẹ ghie usomhi ghi iJọni, ọ pfi ọtsẹlẹ shi ọni ọ khi igẹsikia.\f + \fr 5:33 \ft Li zẹ \fq iJọn 1.19-27; 3.27-30\f*
\v 34 Ama ọa khi eri mhi mu ma ọtsẹlẹ oyi ọgbọ, eri mhi mema gue ọtsẹlẹ ni iJọni ọ pfi na mhẹ yẹ ẹ ini a mhọli imiepfuese.
\v 35 Eri iJọni ọ gẹ abi ákpá ni o rọ odẹ ẹ khasẹ ẹ. Ukuku ẹghẹghẹ a lama mie oni ákpá ni o ri egbe mu ẹ.
\p 
\v 36 “Mhi mhọli ọtsẹlẹ ni ọ fu dọsẹ ọtsẹlẹ ni iJọni ọ pfi na mhẹ. Ika ni Itamhẹ ọ rọ na mhẹ mhi gbe pfo ni mhi kiele ẹ gbe, e pfi ọtsẹlẹ khi Itamhẹ ọ ghie mhẹ.
\v 37 Itamhẹ ni ọ ghie mhẹ ọ she pfi ọtsẹlẹ shi ingme oyẹmhẹ. Aa tigbe kpẹ suọ uruli oyọli wẹkhi eri a tigbe kpẹ mẹ abi ọli.\f + \fr 5:37 \ft Li zẹ \fq iMat 3.17; iMak 1.11; iLuk 3.22\f*
\v 38 Ungmemhi oyọli ọa la elemhi oyẹ ẹ, itobọ khi aa mie ọni ọ ghie suọ.
\v 39 À rọshẹka wẹna Ebe-no-pfuasẹ, ni a dabi khi lọli o ya ri agbọ na agbọagbọ na ẹ. Oni ebe ona lọli o gbo pfi ọtsẹlẹ shi ingme oyẹmhẹ.
\v 40 Ama aa nono ni a bhale deba mhẹ, ini a mhọli agbọ.
\p 
\v 41 “Ọa khi ikuẹghiẹ oyi ẹgbọ mhia nono.
\v 42 Ama mhi lẹsẹ ẹ. Mhi lẹsẹ khi aa mhọli inono oyi Ẹshinẹgba shi udu o yẹ ẹ
\v 43 Eva oyi Itamhẹ mhi rọ bhale, ama aa mie mhẹ, ọgbọẹse ọ kha ri eva oyọli bhale deba ẹ, a ya mie ọli.
\v 44 Emini o zẹ khi aa miesuọ khi, ikuẹghiẹ ni o rọte obọ oyi ẹgbọ bhale á nono, ocho ni a kha rọ ke nono oni o rọte obọ oyi Ẹshinẹgba bhale.
\p 
\v 45 “A khi sa khi mhia ya pfa ẹzọ mu ẹ odalo oyi Itamhẹ. Ọni ọ pfa ẹzọ mu ẹ khi iMosisi ni a regbenga.
\v 46 Ini a mie iMosisi suọ lọ, a kha mie mhẹ suọ itobọ khi ọ kẹkẹ ingme oyẹmhẹ shi ebe.
\v 47 Ama abi aa rọ mie emini ọ kẹkẹ shi ebe suọ, sẹẹ a ke li ya mie emini mhi gueyẹ ẹ suọ?”
\c 6
\s1 IJesu ọ ri eminale na ebubu ẹgbọ le
\r (iMat 14.13-21; iMak 6.30-44; iLuk 9.10-17)
\p 
\v 1 Abi a rọ mẹ ingme enana se, iJesu ọ da okẹ oniẹmhi no khishi na lu iGalili lasele je egele ọ. (ITibẹriasi a gbolo ẹ lu oni okẹ.)
\v 2 Ighọ ebubu ẹgbọ e vẹ deba li gbii, itobọ khi e mẹ ikanya ọnyaloa ni ọ ri eni ẹ ghua ze.
\v 3 Ighọ iJesu ali eniyẹ odukhokho eyọli e nga ukhomhi ute ya shitọ.
\v 4 Ẹghẹghẹ aghọ ukpe iPasova oyi iJu o she ramhi.
\p 
\v 5 Abi iJesu ọ yasẹ alo, ọ mẹ ebubu ẹgbọ ni e bhale deba li, ighọ ọ mhila iFilipu, ọọ li. “Obo awa te ya dẹ eminale ni e ya lo ẹgbọ ena le?”
\v 6 Eri iJesu ọ mema mhila li ni ọ rọ mhẹsẹ ọli bino, itobọ khi ọ she kpẹ lẹsẹ emini lọli ya riẹlẹ shi udu.
\p 
\v 7 IFilipu ọ sọ iJesu ọ, ọọ li. “O kha tseku khi ifata iki elele, ẹa ya lo ni a rọ de eminale ni a mẹ ya kemhi pfiẹlẹ-pfiẹlẹ na wẹ tono unu!”
\p 
\v 8 Ọtuọghuo eniyẹ odukhokho eyọli ni a lu Aduru ni ọ khi inyọghuo iSamọ iPita, ọọ li,
\v 9 “Ukuku ọmọ ọ la akana ni ọ tsua irui ibulẹdi ishe ali ifẹlẹ aava. Ashi enana e kia ya ramhi, ni aa kemhi na ẹgbọ ena nya?”
\p 
\v 10 IJesu ọọ li, “A ri eni ẹgbọ shitọ.” Ebuli iyẹyẹ e vọ aghọ egbegbọ. Eni ẹgbọ nya e shitọ, emọse ni e laọ tsẹ, e khi ẹgbọ agbẹlẹ asha ishe.
\v 11 IJesu ọ rue eni ibulẹdi, ọ tsẹ Ẹshinẹgba uwegbe shi ọ, ọ kia kemhi na wẹ. Ọ gbo lighọ rue eni ifẹlẹ, ọ tsẹ Ẹshinẹgba uwegbe shi ọ, ọ kemhi na wẹ. Eni ẹgbọ e le, e khue.
\p 
\v 12 Abi e rọ le khue se, iJesu ọ gueyẹ eniyẹ odukhokho eyọli, ọọ, “A kia sanọ iku wẹ eni e le kpọle, a khi zẹ ni e li opfu-a.”
\v 13 Abi e ke rọ sanọ wẹ gbili, ighughu igbẹva e vọ iku ibulẹdi ni ẹgbọ e le kpọle.
\p 
\v 14 Abi eni ẹgbọ e rọ mẹ ikanya ọnyaloa ni iJesu ọ gbe, ẹẹ li, “Igẹsikia lọ khi ọmọse ọna ọ khi ọmekẹguele ni ẹ khi ọ ya bhale agbọ.”
\v 15 IJesu ọ lẹsẹ khi eni ẹgbọ e she gba abi e li ya ri itoto rọli khi oghie, ighọ, lọlighuo ọ te wẹ ifuabọ vu ya nga ukhomhi ute.
\s1 IJesu ọ kia ukhomhi okẹ
\r (iMat 14.22-33; iMak 6.45-52)
\p 
\v 16 Abi ogbọmhi o rọ mu ekẹ ẹlẹghọ, eniyẹ odukhokho eyọli e tiemhi okẹ ni o khishi.
\v 17 Aghọ e te lo ọkọ-okẹ oniẹmhi ni o tsua wẹ da lase je iKapanọmu. Oni ẹghẹghẹ obili o she bi, iJesu ọ́ a nu wẹ la akaghọ.
\v 18 Ighọ akpekpeli oniẹmhi o tsua rughu wẹ, okẹ o wushe kugbe.
\v 19 Abi e rọ kia ukhomhi okẹ ramhi abi imali esẹ ali ene ghọ, e mẹ khi iJesu ọ kia ukhomhi okẹ ẹ bhale. Ulishi oo mu wẹ.
\v 20 IJesu ọọ wẹ, “Mhẹmhẹ lọ, ulishi o khi ke mu ẹ.”
\v 21 Ighọ, o ghọle wẹ ni e tsua iJesu shi elemhi ọkọ-okẹ oniẹmhi. Aghọaghọ oni ọkọ-okẹ oniẹmhi o ramhi egele obini e je.
\s1 Ẹgbọ e nono iJesu u gasẹ
\p 
\v 22 Ogbeakọlọ eni ebubu ẹgbọ ni e kpẹ la olase egele okẹ ukiẹkiẹ obini o kpọle ni eniyẹ odukhokho e kpẹ te vu. E lẹsẹ khi ọkọ-okẹ oniẹmhi oghuo tsẹ o kpẹ la aghọ, eni ẹgbọ e lẹsẹ khi eniyẹ odukhokho eyọli tsẹ e la oni elemhi ọkọ-okẹ oniẹmhi, ali khi iJesu ọa nu wẹ lo oni ọkọ-okẹ oniẹmhi abi o rọte aghọ vu.
\v 23 Ikọ-okẹ elese e rọte obini iTibẹriasi bhale epfepfẹ ashini iJesu ọ la ri eminale ni ebubu ẹgbọ le, ni ọ la tsẹ Ẹshinẹgba uwegbe shi eni eminale.
\v 24 Abi eni ẹgbọ e mẹ khi iJesu ali eniyẹ odukhokho eyọli ẹa la akaghọ, e dọsẹ lo ikọ-okẹ, ni e tsua wẹ je iKapanọmu, ni e ya nono iJesu gasẹ.
\s1 IJesu ni ọ khi Eminale ni o ri agbọ ọ na ọgbọ
\p 
\v 25 Abi e ke rọ mẹ iJesu ukhomhi egele olase okẹ ukiẹkiẹ obini uzeva, ẹẹ ọli, “Ọsẹsẹ, ẹghẹghẹ onoghuo u rọ ramhi oola?”
\p 
\v 26 IJesu ọ sọ wẹ ọ, ọọ wẹ, “Egbegbi-ingme mhi gue ẹ yẹ ẹ, ọa khi itobọ khi a mẹ ikanya ọnyaloa ni mhi gbe a rọ nono mhẹ, ama itobọ eminale ni mhi rọ na ẹ le khue.
\v 27 A khi ke kuẹlẹa nono eminale oyi agbọ ona ni ọọ yese-a, ama a ke kuẹlẹa nono eminale ni ọọ la ọ agbọagbọ ni Omi Ọgbọ ọ rọ ya na ẹ le. Itobọ khi Ẹshinẹgba Ita ọ she ri obọ nga li ukhomhi ọ mie shi ọli ọ.”
\p 
\v 28 Ighọ, e ke mhila li, ẹ ọ li, “Elọ anye ya ke li ni anye rọ ya ke gbe akanya ni o ghọle Ẹshinẹgba?”
\p 
\v 29 IJesu ọọ wẹ, “Akanya oyi Ẹshinẹgba khi ni a rọ mie ọni ọ ghie suọ.”
\p 
\v 30 E gbo mhila li, ẹẹ ọli, “Ikanya ọnyaloa eneghuo u ya riẹlẹ khasẹ ni anye mẹ ni anye rọ ya mie ẹ suọ? Elọ u ya riẹlẹ?
\v 31 Eni e bia awa e le eminale ni e rọte idane de kule, Abi Ebe-no-pfuasẹ o ngme khi. ‘Ọ ri eminale ni e te idane de kule na wẹ le.’ ”\f + \fr 6:31 \ft Li zẹ \fq Okiali 16.4,15; Iwolo 78.24\f*
\p 
\v 32 IJesu ọ sọ wẹ ọ, ọọ. “Egbegbi-ingme mhi gue ẹ yẹ ẹ, a khi iMosisi ọ ri eminale te idane tiemhile na ẹ le, ama Itamhẹ lọlighuo ọ rọte idane ri egbegbi eminale tiemhile ni e le.
\v 33 Itobọ khi eminale ni Ẹshinẹgba ọ rọ na ọgbọ, lọli khi ọni ọ rọte iloghie bhale ya ri agbọ na ẹgbọ na agbọ.”
\v 34 Ẹẹ ọli, “Ọnọmhuẹ, kpẹkpẹ rọte ana vu, ke ri oni eminale ona na anye le.”
\p 
\v 35 IJesu ọ sọ wẹ ọ, ọọ wẹ. “Mhẹmhẹ mhi khi eminale ni o ri agbọ ọ na ọgbọ. Ọnini ọ da bhale deba mhẹ, okiamhi ọa kẹa gbe ọli ghue, ọni ọ da mie mhẹ suọ okiamẹ ọa tigbe ke ya gbe ọli.
\v 36 Ama mhi gueyẹ ẹ khi a she mẹ mhẹ, ama aa kie mie mhẹ suọ.
\v 37 Ẹgbọ ni Itamhẹ ọ rọ na mhẹ nya e ya bhale deba mhẹ, ọni ọ da bhale deba mhẹ ne mhia ya khu ọli vu.
\v 38 Itobọ khi eri mhi rọte iloghie ilimhi tiemhile ni mhi rọ riẹlẹ ọghuẹmhẹ oyi ọni ọ ghie mhẹ, a khi ni mhi riẹlẹ ọghuẹmhẹ oyẹmhẹ.
\v 39 Ọghuẹmhẹ oyi Ita ni ọ ghie mhẹ khi, ni a bhale ya ẹ khi ọkhọghuo eni ọ rọ na mhẹ ọa wa mhẹ-a, ali ni mhi rọ guise wẹ le ri agbọ na wẹ, ogbẹlẹ ni o kpukhokho.
\v 40 Ọghuẹmhẹ oyi Itamhẹ khi ni ọgbọkpa ni ọ da pfi alo bino omiọli, ni ọ gbo mie ọli suọ ọ ya mhọli agbọ na agbọagbọ. Mhi ya guise ọli le mhi gbo ri agbọ na li ogbẹlẹ ni o kpukhokho.”
\p 
\v 41 Itobọ khi iJesu ọọ wẹ, “Mhẹmhẹ mhi khi eminale ni o rọte iloghie ilimhi tiemhile,” ẹgbọ iJu e wọlọ shi ọ.
\v 42 Ighọ e liẹ, “Ọnana ọa she khi iJesu omi iJosẹfu, ni anye lẹsẹ itali ali inyọli? Sẹẹ ọ ke liẹ liẹ khi, ‘Mhẹmhẹ khi ibulẹdi ni o rọte iloghie ilimhi tiemhile.’ ”
\p 
\v 43 IJesu ọ sọ wẹ ọ, ọọ, “A khi ke wọlọ.
\v 44 Ọgbọkhọghuo ọa la ọ ni ọ ya bhale deba mhẹ ini ọa li khia khi Ita lọlighuo ni ọ ghie mhẹ ọ ti ọ bhale, mhi ya guise ọli le gbo ri agbọ na li ogbẹlẹ ni o kpukhokho.
\v 45 Ọmekẹguele ọyi Ẹshinẹgba ọghuo ọ kpẹ kẹkẹ ọli shi Ebe-no-pfuasẹ khi, ‘Ẹshinẹgba lọli oghuo ọ ya sẹsẹ ẹgbọ eyọli nya.’ Ọgbọkpa ni ọ da ku esọ-a na Ita, ni ọ rọte obọ oyọli wẹna, ọ ya bhale deba mhẹ.\f + \fr 6:45 \ft Li zẹ \fq Aza 54.13\f*
\v 46 Aa mẹ ọgbọ ni ọ mẹ Ẹshinẹgba Ita ghue, ini ọa li khi ọni ọ rọte obọ oyọli bhale. Lọlighuo tsẹ ọ mẹ ọli.
\v 47 Egbegbi ingme mhi gueyẹ ẹ, ọni ọ da mie mhẹ suọ, ọ she mhọli agbọ na agbọagbọ
\v 48 Mhẹmhẹ mhi khi eminale ni o ri agbọ ọ na ọgbọ.
\v 49 Eni e bia ẹ, e le eminale ni e rọte idane de kule obini ọdagbe-ifufu, e kie ghuloa.
\v 50 Ama ọna ọ khi eminale ni o rọte iloghie tiemhile, ọni ọ da le ọli, ọa ya ghu.
\v 51 Mhẹmhẹ mhi khi eminale ni o ri agbọ ọ na ọgbọ, ni o rọte iloghie tiemhile. Ọnini ọ da le eminale ona, ọ ya mhọli agbọ na agbọagbọ. Oni eminale ona, idiegbe oyẹmhẹ lọ, ni mhi ya rọ shi ekẹ na agbọ ni e rọ mhọli agbọ.”
\p 
\v 52 Abi iJesu ọ rọ ngme ona se, ẹgbọ iJu e nu egbe wẹ khakọ ekhakọ oniẹmhi, ikhi. “Sẹẹ ọmọse ọna ọ li ri idiegbe oyọli na awa ya le?”
\p 
\v 53 IJesu ọọ, “Egbegbi ingme mhi gueyẹ ẹ, ini u a li le idiegbe, ni u gbo da ọlia eyi Omi Ọgbọ, wa ya mhọli agbọ.
\v 54 Ọni ọ da le idiegbe oyẹmhẹ ni ọ gbo da ọlia eyẹmhẹ, ọ ya mhọli agbọ na agbọagbọ. Ọ ya mhọli agbọ itobọ khi mhi ya guise ọli le gbo ri agbọ na li ogbẹlẹ ni o kpukhokho.
\v 55 Idiegbe oyẹmhẹ khi egbegbi eminale, ọlia eyẹmhẹ e gbo khi egbegbi emini a da.
\v 56 Ọni ọ da le idiegbe ọyẹmhẹ ni ọ gbo da ọlia eyẹmhẹ, ọ la elemhi oyẹmhẹ, mhẹmhẹ mhi li la elemhi oyọli.
\v 57 Abi Ita ni ọ mhọli agbọ ọ́ ghie mhẹ, mhi li mhọli oni agbọ, Ighọ ọni ọ da le idiegbe oyẹmhẹ ọ li ya mhọli agbọ itobọ oyẹmhẹ.
\v 58 Onana lọli khi eminale ni o te iloghie tiemhile, ọa li abi eminale ni e rọte idane de kule ni eni e bia ẹ e kpẹ le, ni e rọ kie ghua. Ama ọni ọ da le idiegbe oyẹmhẹ ọ ya la agbọ agbọagbọ.”
\p 
\v 59 Eni ingmemhi ena iJesu ọ ngme abi ọ li la elemhi owa ugamhi ni o la iKapanọmu sẹsẹ.
\s1 Ingmemhi eyi iJesu ni e ri agbọ na agbọagbọ ọ na ọgbọ
\p 
\v 60 Abi e rọ suọ eni ingmemhi ni iJesu ọọ ngme, ebubu eniyẹ odukhokho eyi iJesu e kẹ, “Osẹsẹ, ena e ma ze dọsẹ e. Ọghuo ọ dobẹ ya mie shi ọ?”
\p 
\v 61 Abi iJesu ọ́ rọ́ lẹsẹ khi eniyẹ odukhokho eyọli ẹ wọlọ, ọọ, “Eri ingmemhi eyẹmhẹ e yese ẹ udu-a?
\v 62 Sẹẹ a kẹ ẹ ngme ini a mẹ Omi Ọgbọ khi ọ nga iloghie ya shitọ obini ọ kpẹ te tiemhile?
\v 63 Ayẹmhẹ oyi Ẹshinẹgba ọ ri agbọ ẹẹ na ọgbọ, ama ọgbọ ọa dobẹ ri agbọ ẹẹ na ọgbọ. Ingmemhi ni mhi nu ẹ ngme, obọ oyi Ayẹmhẹ e te ẹẹ bhale, wẹwẹ e ri agbọ ẹẹ na ọgbọ
\v 64 Abi o riẹ khi ighọ, eghuo elemhi ẹ, ẹa miesuọ.” Itobọ khi iJesu ọ she kpẹ te ekẹ lẹsẹ eni ẹa mie ọli suọ ali ọni ọ ya ri ọli dẹ.
\v 65 IJesu ọ gbo gueyẹ wẹ, ọọ wẹ, “Ona o zẹ khi mhi gueyẹ ẹ khi ọgbọ lọlighuo ọa dobẹ ya bhale deba mhẹ sẹẹ ini Ita ọ ri oni afu na li.”
\p 
\v 66 Rọ te ana vu eniyẹ odukhokho eyọli ebubu e mu egbe pfi ẹa ke lama deba li.
\v 67 IJesu ọ mhila eniyẹ odukhokho etuogbava eyọli, ọọ wẹ, “Eri a nono ni a li vu?”
\p 
\v 68 ISamọ iPita ọ sọ ọli ọ, ọọ li, “Ọnọmhuẹ, ọghuo anye ya lẹ deba? Yẹyẹghuo u mhọli ungmemhi ni e ri agbọ na agbọagbọ ọ na ọgbọ.
\v 69 Anye miesuọ, anye gbo lẹsẹ khi yẹyẹghuo u khi Ọni ọ pfuasẹ ọyi Ẹshinẹgba.”\f + \fr 6:69 \ft Li zẹ \fq iMat 16.16; iMak 8.29; iLuk 9.20\f*
\p 
\v 70 IJesu ọ sọ li ọ, ọọ, “Ọa khi ẹẹ ogbava mhi zẹ? Ama ọghuo elemhi ẹ, ọkphaghiẹ ọ khi!”
\v 71 IJudasi ni ọ khi omi iSamọ Isikarọti lọli iJesu ọ la ana ngme ingme oyọli. IJudasi ọ khi ọghuo eniyẹ odukhokho Ogbava ni ọ kie te ikpukhokho ri ọli dẹ.
\c 7
\s1 IJesu ali inyọghuo ọli
\p 
\v 1 Abi a rọ mẹ ona se, iJesu ọ kia gasẹ ekẹ iGalili. Ọa lama je ekẹ iJudia itobọ khi eni ẹ mhẹsẹ eyi ẹgbọ iJu e nono abi e li ya gbe ọli a.
\v 2 Oni ẹghẹghẹ ukpe okholo oyi iJu o ti bhale.\f + \fr 7:2 \ft Li zẹ \fq iLẹv 23.34; iDẹut 16.13\f*
\v 3 Ighọ Inyọghuo iJesu, ẹẹ ọli, “Wa ke rọte ana lase, ni u ke je obini ekẹ iJudia ni eniyẹ odukhokho eyẹ e mẹ ikanya ọnyaloa ni u wa gbe?
\v 4 Ọgbọ ni ọ nono ni agbọ e lẹsẹ luẹ ọa ya riẹlẹ ingme sheli. Abi u rọ gbe ikanya ọshabọ ena, ri egbe ẹ khasẹ agbọ gbo ni e lẹsẹ ọni u khi.”
\v 5 Egbegbọ inyọghuo ọli ẹa mie ọli suọ.
\p 
\v 6 IJesu ọọ, “Ẹghẹghẹ oyẹmhẹ ọa ramhi ne, Ẹghẹghẹ ni a mẹ kpa o ti ẹ ẹloe.
\v 7 Ẹgbọ na agbọ ẹa dobẹ ya biselemhi ẹ, ama ẹẹ biselemhi mhẹ itobọ khi mhia gueyẹ wẹ khi emini ẹẹ riẹlẹ khi ẹa ti.
\v 8 A ke je obini a la riẹlẹ ukpe, mhẹmhẹ mhia vu ne, itobọ khi ẹghẹghẹ oyẹmhẹ ọa ramhi ne.”
\v 9 Abi iJesu ọ ngme ghọ se, ọa ke te iGalili je ashikhọghuo.
\p 
\v 10 Abi inyọghuo ọli e rọ je obini oni ukpe okholo se, ọ li je oobọ, ama ọa zẹ ni ẹgbọ e mẹ luẹ.
\p 
\v 11 Eni e khi enighie eyi ẹgbọ iJu e la aghọ nono iJesu gasẹ, e mhila, “Ighe ọni ọmọse ọghọ?”
\p 
\v 12 Ebubu ẹgbọ e la oni igbaa khẹ akọ shi ingme oyi iJesu. Eghuo e liẹ khi iJesu khi ọgbọ ọnete lọ, eghuo ẹ khi eri ọ mema di ẹgbọ.
\v 13 Ama ọgbọkhọghuo ọa ngme ingme oyọli lase gboo, itobọ khi e na ulishi enighie eyi ẹgbọ iJu.
\s1 IJesu ọ la olele oyi oni ukpe sẹsẹ
\p 
\v 14 Abi a rọ li oni ukpe ramhi odẹ, iJesu ọ lo elemhi owa oniẹmhi oyi Ẹshinẹgba, ọ sẹsẹ ẹgbọ ungmemhi oyi Ẹshinẹgba.
\v 15 Enighie eyi iJu ni e suọ oni osẹsẹ, abọ e sha wẹ, ẹ liẹ, “Obo ọmọse ọna ni ọa ye owẹna okhọghuo ne ọ te mhọli ilẹsẹ enana?”
\p 
\v 16 IJesu ọ sọ wẹ ọ, ọ li, “Osẹsẹ ni mhia sẹsẹ, ẹa khi obọ oyẹmhẹ o te bhale, ama obọ oyi ọni ọ ghie mhẹ bhale.
\v 17 Ọni o ghọle ni ọ riẹlẹ ọghuẹmhẹ oyi Ẹshinẹgba ọ ya lẹsẹ khi osẹsẹ ni mhia sẹsẹ ini obọ oyi Ẹshinẹgba o te bhale, abi khi ungmemhi ni o ghọle mhẹ mhia ngme.
\v 18 Ọni ọ da ngme ungmemhi oyi egbọli, ekpẹ ọọ nono ni ẹgbọ e ke mu na lọli, eri-tsẹ khi ọni ọ da gbe akanya ni ọ rọ ti ọni ọ ghie ọ nga ne, lọli o khi ọgbọ ni ọ ti, ọa ga khi ọgbọ ẹgbhọli.
\v 19 IMosisi ọa ri ishi na ẹ? Ama ongẹ ẹ, ọa ri eni ishi gbe. Elọ o ke zẹ khi a nono ni a gbe mhi a?”
\p 
\v 20 Eni ẹgbọ e sọ ọli ọ, ẹẹ ọli, “Ayẹmhẹ ọkphaghiẹ o la ẹ egbe! Ọghuo ọ nono ni lọli gbe-a?”
\p 
\v 21 IJesu ọọ, “Mhi riẹlẹ ọnyaloa oghuo, o rọ abọ sha ẹ nya.
\v 22 Ama abi o riẹ khia khi iMosisi ọ ri ushi ishẹlẹ-a na ẹ (ọa mema khi obọ oyi iMosisi o te bhale, ama rọte obọ oyi eni e bia awa, o rọte bhale), eri a kiele ẹ shẹlẹ ọmọ a ogbẹlẹ iyẹmhẹa oyi ẹgbọ iJu.\f + \fr 7:22 \ft Li zẹ \fq Igbae 17.10; iLẹv 12.3\f*
\v 23 Ini a shẹlẹ ọmọ a ogbẹlẹ iyẹmhẹa oyi ẹgbọ iJu, ini a khi gbe Ushi oyi iMosisi a, elọ zẹ khi a wola khi mhi rọ ọni ọọ ghua ze ogbẹlẹ iyẹmhẹa?\f + \fr 7:23 \ft Li zẹ \fq iJọn 5.9\f*
\v 24 A khi ke bino ọgbọ alo gue ọgbọ ẹzọ, a ke sọ ẹzọ shi abi o li.”
\s1 Ẹgbọ e mhila ini iJesu ọ khi Ọni Ọmiepfuese?
\p 
\v 25 Ẹghẹghẹ aghọ ẹgbọ eghuo ni e la iJerusalẹmu e liẹ, “Ọa khi ọmọse ọna enighie eyi iJu ẹẹ dua abi e li ya gbe a?
\v 26 Ghe ọli shọ! Ọa khi lọli ọ la ana ngme gbo ena ni ọgbọkhọghuo ọa li ọli emhikhọghuo! Abi khi eri enighie e she lama egbegbọ khi lọli ọ khi iKirisiti?
\v 27 Awa aa lẹsẹ obini ọmọse ọna ọ te bhale. Ama ẹghẹghẹ ni iKirisiti ọ rọ ya bhale, ọgbọkhọghuo ọa ya lẹsẹ obini ọ te ya bhale.”
\p 
\v 28 Abi iJesu ọ rọ la elemhi Owa oyi Ẹshinẹgba sẹsẹ, ọ tsẹsẹ lasele, ọọ, “A lẹsẹ mhẹ, a gbo lẹsẹ udi-apfẹ ni mhi te lasele, ọa khi mhẹmhẹghuo mhi ghie egbemhẹ bhale akana, ama ọni ọ ghie mhẹ, ọna igẹsikia lọ. Aa lẹsẹ ọli.
\v 29 Ama mhi lẹsẹ ọli itobọ khi obọ oyọli mhi te bhale, lọlighuo ọ ghie mhẹ bhale.”
\v 30 Itobọ ona e nono abi e li ya mu ọli. Ama ọgbọ khọghuo ọa khu ọli, ẹa ri obọ ti ọli, itobọ khi ẹghẹghẹ oyọli ọa ramhi ne
\v 31 Ama ebubu ẹgbọ e kie mie ọli suọ, e kẹ, “Ini ọni iKirisiti ọ bhale, ọ ya gbe ikanya ọnyaloa ni e dọsẹ eni ọmọse ọna ọọ gbe ena?”
\s1 A ghie eni ẹ khẹ ekhẹ e ka mu iJesu bhale
\p 
\v 32 Ẹgbọ iFarisi e suọ ingme ni ẹgbọ e ngme shi iJesu egbe. Eni iFarisi ali ighie eyi ekpodalo-ugamhi e ghie eni e la Owa Oyi Ẹshinẹgba ẹ khẹ ekhẹ e ka mu ọli bhale.
\v 33 IJesu ọọ li, “Ukuku ẹghẹghẹ mhi mhọli ya nu ẹ la akana, mhi ya nyenẹ egbe je oyi Ita ni ọ ghie mhẹ.
\v 34 A ya nono mhẹ, ama aa ya mẹ mhẹ, ashini mhi ya la aa dobẹ ya ramhi aghọ.”
\p 
\v 35 Enighie eyi iJu e nu egbe wẹ ẹ ngme, e liẹ, “Obo ọmọse ọna ọọ lẹ ni ọ rọ liẹ khi awa aa ke ya mẹ luẹ? Eri ọ vu ẹ je ifui ẹoli oyi ẹgbọ iGiriki, obini ẹgbọ eyawa e kia miatsẹku, ni ọ la obọ ke sẹsẹ ẹgbọ iGiriki?
\v 36 Elọ iJesu ọ rọ li ngme, abi ọ rẹẹ, a ya nono mhẹ aa mẹ mhẹ, ali obini mhi ya la aa dobẹ ya ramhi aghọ?”
\p 
\v 37 Ogbẹlẹ ni o kpukhokho oni ukpe, ni khi khi ogbẹlẹ ni o mu ẹloe nẹ nya, iJesu ọ vule, ọ rue unu leghe, ọọ li, “Ọni okiamẹ ọọ gbe ọ bhale deba mhẹ ya mọ amẹ da.\f + \fr 7:37 \ft Li zẹ \fq iLẹv 23.36\f*
\v 38 Ebe-no-pfuasẹ o ngme ghọ khi ọni ọ mie mhẹ suọ khi okẹ ni o mhọli amẹ eni ri agbọ a na ọgbọ o ya rọte agbọ oyọli ke tu lasele.”\f + \fr 7:38 \ft Li zẹ \fq Ezik 47.1; iZaka 14.8\f*
\v 39 Ayẹmhẹ ni eni mie ọli suọ e ya mie ẹlẹlese, iJesu ọ ri oni amẹ agbọ o na a ngme. Ramhi oni ẹghẹghẹ, oni Ayẹmhẹ ọa bhale ne, itobọ khi aa yasẹ iJesu nga ufumhi oniẹmhi ne.
\s1 Eni ẹgbọ ẹa ke lama shi egbe ọ
\p 
\v 40 Abi eni ẹgbọ e rọ suọ ingmemhi eyọli, ẹgbọ eghuo e ke, “Ọmekẹguele ọmọse ọna ọ khi egbegbọ.”
\p 
\v 41 Ẹgbọ elese e kẹ, “Lọli ọ khi ọni Ọmiepfuese.” Elese ẹẹ, “Sẹẹ Ọmiepfuese ọ li rọte iGalili lasele?
\v 42 Ebe-no-pfuasẹ o guele khi ọni Ọmiepfuese, khi unuẹkpẹ oyi iDefidi ọ ya te lasele, iBẹtilẹẹmu a ya bia li shi, ẹoli oyi iDefidi.”\f + \fr 7:42 \ft Li zẹ \fq 2 iSam 7.12; iMika 5.2\f*
\v 43 Ighọ okemhi o ri itobọ iJesu lo wẹ iteva.
\v 44 Ẹgbọ eghuo e nono ni ẹwẹ e mu ọli, ama ọgbọkhọghuo ọa ri obọ ti ọli.
\s1 Umha mie iJesu suọ oyi Enighie eyi ẹgbọ iJu
\p 
\v 45 Abi eni e la Owa oyi Ẹshinẹgba oniẹmhi ẹẹ khẹ ekhẹ e rọ je deba iFarisi ali ighie eyi ekpodalo-ugamhi, e mhila wẹ, “Elọ e zẹ khi a mu iJesu bhale ghi anye?”
\p 
\v 46 Eni ẹgbọ ni ẹ khẹ ekhẹ, e sọ wẹ ọ, e li. “Ọgbọkhọghuo ọa tigbe ngme abi ọmọse ọna ọ liẹ ngme ghue.”
\p 
\v 47 IFarisi e mhila wẹ, ẹẹ, “Eri iJesu ọ she li di ẹ?”
\v 48 “Aa tigbe mẹ ọgbọ iFarisi ali enighie eyi ẹgbọ iJu ni e mie ọli suọ?
\v 49 Iiye! Ama eni ẹgbọ ebubu ena ẹa lẹsẹ Ishi eyi iMosisi. Itobọ ighọ ẹgbọ ni Ẹshinẹgba ọ pfi unu na e khi.”
\p 
\v 50 INikodemọsi ni ọ li khi ọtuọghuo eni ẹ mhẹsẹ elemhi ẹgbọ iJu ni ọ kpẹ ya mẹ iJesu ẹliyọsẹ, ọ mhila eni ẹgbọ, ọọ,\f + \fr 7:50 \ft Li zẹ \fq iJọn 3.1-2\f*
\v 51 “Ushi oyawa ọa fẹ ngme ghọ a khi pfa ẹzọ umha-guẹli mu ọgbọ ini aa li suọ ẹzọ ni ọ ya gue, ali a gbo guanọ emini ọọ riẹlẹ?”
\p 
\v 52 E kẹ ọ li, “Ọnge iGalili yẹyẹ u li khi? Ka riẹlẹ ebe zẹ egbegbọ khi u ya mẹ khi ọmekẹguele ọọ ya rọte iGalili bhale.”
\p 
\v 53 Ighọ ọgbọgbọ nya ni ọ la aghọ, ọ je apfẹ oyọli.
\c 8
\s1 Ọkpotso ni a gazu okia
\p 
\v 1 IJesu ọ je ukhomhi ute oyi ẹẹra olivu.
\v 2 Ẹluzogbe fiefie, iJesu ọ gbo bhale elemhi Owa oyi Ẹshinẹgba, ebubu ẹgbọ e bhale deba li, ọ shitọ ọ sẹsẹ wẹ.
\v 3 Esẹsẹ Ishi eyi iMosisi ali iFarisi e mu ọkpotso ni a gazu okia obọ-obọ bhale ghi iJesu, e rọ ọli migha odalo igbaa.
\v 4 Ẹẹ iJesu, “Ọsẹsẹ, eri a ga ọkpotso ọna zu okia.
\v 5 IMosisi ọ she kpẹ rọ oni ushi shi ekẹ na anye, khi, ọkpotso ni a da lighọ gazu okia, a ke tono ọli echẹ gbe-a. Elọ u mhuẹ ya ngme shi ona mena?”\f + \fr 8:5 \ft Li zẹ \fq iLẹv 20.10; iDẹut 22.22-24\f*
\v 6 Eri e ri ona kpẹ igha khẹ iJesu ini ọ ngme ungmemhi ni e ya rọ ri ingme de ọ. Ighọ iJesu ọ nyẹsẹ egbe, ọ ri umiesobọ ọ kẹkẹ emhi shi ekẹ.
\p 
\v 7 Abi e kie li mhila iJesu oni ogbọ ona, iJesu ọ vule, ọọ, “Ọni ọ lẹsẹ khi lọli ẹa kpẹ lamhẹ olamhẹ ghue ọ kpẹ to ọli ẹchẹ.”
\v 8 Ọ gbo nyẹsẹ egbe, ọ kẹkẹ emhi shi ekẹ.
\v 9 Abi e rọ suọ ingme ni iJesu ọ ngme, e gbhiaku-a ọtuọghuo-ọghuo rọte eni egbhali. O ke lẹsẹ kpe iJesu ali ọni ọkpotso le shi aghọ ni ọ kie migha.
\v 10 IJesu ọ vule, ọọ ọni ọkpotso, “Ighe eni ẹgbọ ni e pfa ẹzọ mu ẹ?”
\p 
\v 11 Ọni ọkpotso ọọ li, “Mhi aa mẹ ọgbọkhọghuo, Ọnọmhuẹ.” IJesu ọọ li, “Mhẹmhẹ mhi aa li pfa ẹzọ mu ẹ, ama ke lẹ, khi ke gbo lamhẹ.”
\p 
\v 12 IJesu ọ gbo nu iFarisi ngme, ọọ wẹ, “Mhẹmhẹ mhi khi ákpá oyi agbọ. Ọni ọ da deba mhẹ ne, ọa ya tigbe kia alo ebili, ọ ya mhọli ákpá ni o ri odẹ agbọ a khasẹ ọgbọ.”\f + \fr 8:12 \ft Li zẹ \fq iMat 5.14; iJọn 9.5\f*
\p 
\v 13 Eni iFarisi ẹẹ ọli, “Egbe ẹ u pfi ọtsẹlẹ na, ẹgbọ ẹa ya rue ọtsẹlẹ oyẹ shi igẹsikia.”\f + \fr 8:13 \ft Li zẹ \fq iJọn 5.31\f*
\p 
\v 14 IJesu ọọ, “Iiye, ini mhi tseku pfi ọtsẹlẹ na egbemhẹ, egbegbi ọtsẹlẹ lọ ni mhi pfi na egbemhẹ, itobọ khi mhi lẹsẹ obini mhi te bhale ali obini mhia je. Ẹẹ, aa lẹsẹ obini mhi te bhale wẹkhi obini mhia je.
\v 15 Abi ẹgbọ na agbọ e li ẹ sọ ẹzọ ẹẹ a liẹ sọ ẹzọ, ama mhẹmhẹ mhi aa pfa ẹzọ mu ọgbọkhọghuo.
\v 16 Ini mhi ya sọ ẹzọ, egbegbọ ẹzọ mhia sọ, itobọ khi ọa khi mhẹmhẹghuo mhi la. Ita ni ọ ghie mhẹ ọ nu mhẹ la.
\v 17 A kẹkẹ ọli shi ebe ushi oyẹẹ khi ọtsẹlẹ oyi ẹgbọ aava, o migha shi egbegbi ọtsẹlẹ.\f + \fr 8:17 \ft Li zẹ \fq iDẹut 19.15\f*
\v 18 Mhi pfi ọtsẹlẹ na egbe mhẹ, Ita ni ọ ghie mhẹ ọ́ gbo pfi ọtsẹlẹ na mhẹ.”
\p 
\v 19 Ẹghẹghẹ ana eni ẹgbọ e mhila li, “Ighe Itẹ?”
\p IJesu ọọ wẹ, “Aa lẹsẹ mhẹ wẹkhi Itamhẹ a lẹsẹ. Ini a lẹsẹ mhẹ lọ, a kha li lẹsẹ Itamhẹ.”
\p 
\v 20 Elemhi Owa oyi Ẹshinẹgba ọ la ngme eni ingmemhi ena abi ọ kie li sẹsẹ ẹgbọ, epfẹ ashini a ri ikpati ni a ri ikpaghọ isomhopfa a shi ọ migha. Ọgbọkhọghuo ọa kie mu ọli, itobọ khi ẹghẹghẹ oyọli ọa ramhi ne.
\p 
\v 21 IJesu ọ gbolo liẹ wẹ, “Mhi ya vu, a ya nono mhẹ, a ya ghu shi olamhẹ oyẹ ẹ. Aa ya dobẹ ramhi obini mhia je.”
\p 
\v 22 Ẹgbọ iJu ẹẹ, “Ọ́ khi awa aa dobẹ ya a ramhi obini lọli a je. Eri ọ fẹ ri ona a liẹ khi lọli ya gbe egbeọli-a?”
\p 
\v 23 IJesu ọọ, “Ẹgbọ ena ọọkẹ-ola a khi, mhẹmhẹ mhi rọte iloghie tiemhie. Ẹgbọ ena agbọ ona ẹẹ a khi, mhẹmhẹ mhia khi ọnge agbọ ona.
\v 24 Itobọ ighọ mhi rọ liẹ khi a ya ghu shi olamhẹ oyẹ ẹ ini a da miesuọ khi mhẹmhẹ mhi khi ọni mhiẹ khi mhi khi.”
\p 
\v 25 Ẹgbọ iJu e mhila li, “Ọghuo u khi?”
\p IJesu ọọ, Ọni mhi kie kpẹ rọte igbaekẹle liẹ khi mhi khi, mhi khi.
\v 26 Mhi mhọli ebubu ingme ali ebubu umha-guẹkia ni mhi kha gue shi ẹ egbe. Ọni ọ ghie mhẹ, ọna igẹsikia ọ khi, ingmemhi ni ọ gueyẹ mhẹ, mhi gue ẹ yẹ agbọ.
\p 
\v 27 Ẹa lẹsẹ khi ingme oyi Ita li iJesu ọ gueyẹ wẹ.
\v 28 IJesu ọọ, “Ini a da tsua Omi Ọgbọ idane shi ukhomhi ọọra apfida a ya lẹsẹ khi ọni mhiẹ khi mhi khi, mhi khi. Oni ẹghẹghẹ a ya lẹsẹ khi ọa khi itoto oyẹmhẹ mhi rọ riẹlẹ emini mhia riẹlẹ, ama emini Ita ọ sẹsẹ mhẹ, mhia gueyẹ agbọ.
\v 29 Ọni ọ ghie mhẹ ọ nu mhẹ la, ọa pfi mhẹ shi ekẹ tsẹ, itobọ khi ọghuẹmhẹ oyọli mhia riẹlẹ ẹghẹghẹ kpa.”
\p 
\v 30 Ebubu ẹgbọ ni e suọ khi iJesu ọ ngme eni ingmemhi ena e mie ọli suọ.
\s1 Igẹsikia o ya rue ẹ ọ le
\p 
\v 31 IJesu ọ gueyẹ ẹgbọ iJu ni e mie ọli suọ, ọọ wẹ, “Ini a ri emini mhia sẹsẹ ẹ gba akanya, egbegbi eniyẹ odukhokho eyẹmhẹ a khi.
\v 32 A ya lẹsẹ igẹsikia ni o la ingme oyi Ẹshinẹgba, oni igẹsikia o ya rue ẹ ọ le.”
\v 33 Eni ẹgbọ iJu ẹẹ ọli, “Imi Aburaamu anye khi, anye aa tigbe kpẹ lo ighumha oyi ọgbọkhọghuo ghue! Elọ u rọ li ẹ ngme, ini u wa liẹ khi anye ya khi eni a rue ighumha lasele?”\f + \fr 8:33 \ft Li zẹ \fq iMat 3.9; iLuk 3.8\f*
\p 
\v 34 IJesu ọ sọ wẹ ọ, ọọ, “Egbegbi-ingme mhi gue ẹ yẹ ẹ, khi ọgbọkpa ni ọ da lamhẹ olamhẹ, oghumha ọyi olamhẹ ọ khi
\v 35 Oghumha ọa ya la apfẹ oyi ọni ọ mhọli ọli agbọagbọ, ama, omi ọmhuẹ-apfẹ ọọ la apfẹ agbọagbọ.
\v 36 Ini Omi Ẹshinẹgba ọ da rue ẹ ighumha le, egbegbọ a rue ẹ ighumha le.
\v 37 Mhi lẹsẹ khi imi Aburaamu a khi, ama a nono odẹ ni a te ya gbe mhẹ a, itobọ khi aa nono ingme ni mhi gueyẹ ẹ.
\v 38 Emini Itamhẹ ọ rọkhasẹ mhẹ mhi gueyẹ ẹ, ama emini Ita ẹ ọ gueyẹ ẹ, a riẹlẹ.”
\p 
\v 39 Ẹ ọ li, “Aburaamu khi Ita anye.” IJesu ọ kẹ, “Ini imi Aburaamu a kha khi egbegbọ lọ, a kha ke riẹlẹ emhi enabi ọ riẹlẹ.
\v 40 Abi o ri riẹ khia khi egbegbọ ingmemhi ni Ẹshinẹgba ọ gueyẹ mhẹ mhi gueyẹ ẹ, ama a dua abi a li ya gbe mhẹ a. Aburaamu ọa riẹlẹ emhi eghọghọ!
\v 41 Abi a li ena, ighọ ita ẹ ọ kpẹ li.” Ẹẹ ọli, “Anye a khi eniyẹ ni a bia shi ukhomhi okia, Ẹshinẹgba ọ khi Ita ọghuo kpe ni anye mhọli.”
\p 
\v 42 IJesu ọọ wẹ, “Ini Ẹshinẹgba ọ khi Ita ẹ lọ, a kha nono ingme oyẹmhẹ, itobọ khi obọ oyi Ẹshinẹgba mhi te bhale, ni mhi rọ la akana, ọa khi omhẹsẹ oyẹmhẹ o rẹ mhẹ bhale, ama lọli ọ ghie mhẹ bhale.
\v 43 Elọ o zẹ khi ingmemhi ni mhi ngme khi ẹa lo ẹ esọ? Itobọ khi aa lama ri egbe mie ingme ni mhi gueyẹ lọ.
\v 44 Eniyẹ eyi Ọkphaghiẹ ni ọ khi ita ẹ a khi, ọghuẹmhẹ oyi ita ẹ a nono ni a ke riẹlẹ. Rọte igbaekẹle ọ te khi ọgbolo-ẹgbọ-a ali ọloẹgbhuẹ. Igẹsikia ọa la li unu. Ingmemhi eyi ọli, ẹgbhọli e khi nya, itobọ khi eri ọọ lo ẹgbhọli abi ọ li. Lọli ọ khi ita ẹgbhọli nya.
\v 45 Ama igẹsikia mhi gueyẹ ẹ khi, itobọ ighọ aa rọ lama mie mhẹ suọ
\v 46 Ọghuo elemhi ẹ ọ dobẹ ya guele khi mhi mhọli ipfidọ? Ini igẹsikia mhi gueyẹ ẹ, elọ e zẹ khi aa mie mhẹ suọ?
\v 47 Ọni ọ da khi ọyi Ẹshinẹgba ọ mema ya ri esọ shi ingmemhi eyi Ẹshinẹgba, ama ẹẹ aa khi eyi Ẹshinẹgba lọli o zẹ khi aa lama rọ shi ungmemhi oyi Ẹshinẹgba.”
\s1 Emini iJesu ọọ khi lọli khi
\p 
\v 48 Eni ẹgbọ iJu e sọ ọli ọ, “Anye a guẹ ngme ọli mena ni anye rọ yẹ khi ọnge iSameria u khi, ali khi ayẹmhẹ ọkphaghiẹ o la ẹ egbe?”
\p 
\v 49 IJesu ọ ke wẹ, “Mhi aa mhọli ayẹmhẹ ọkphaghiẹ. Ama mhi ri ekpẹ na Itamhẹ, ama ẹẹ a ri ẹloe gbe mhẹ.
\v 50 Aa khi eri mhia nono ni ẹgbọ e ri ufumhi na mhẹ; ama ọni ọọ nono ni a rọ ekpẹ na mhẹ, lọli ọ khi ọni ọ sọ ẹzọ ti ẹloe.
\v 51 Egbegbi-ingme mhi gue ẹ yẹ ẹ, ọni ọ da rọ shi osẹsẹ oyẹmhẹ ne, ọa tigbe ya ghu ghue.”
\p 
\v 52 Ẹgbọ iJu ẹẹ ọli, “Eena anye tigbe lẹsẹ khi ayẹmhẹ ọkphaghiẹ o la ẹ egbe. Aburaamu ọ she ghua, emekẹguele e she ghua, ama wa guele khi ọni ọ da rọ shi osẹsẹ eyẹ ọa tigbe ya ghu ghue.
\v 53 Ita awa Aburaamu ọ she ghua, eri u kẹ ẹ liẹ khi u fu dọsẹ Aburaamu? Emekẹguele e she li ghua. Ọghuo u fẹ sa khi u khi?”
\p 
\v 54 IJesu ọọ li, “Ini mhi ti egbe mhẹ nga, oni itinga o khi afuẹ. Itamhẹ ọni ẹẹ a lu Ẹshinẹgba ọyẹ ẹ, lọli ọ khi ọni ọ ti mhẹ nga.
\v 55 Ẹẹ a kpẹ tigbe lẹsẹ ọli, ama mhi lẹsẹ ọli. Ini mhiẹ khi mhia lẹsẹ ọli, ọloẹgbhuẹ ọni abi ẹẹ ena mhi kha khi. Ama mhi lẹsẹ ọli, mhi gbo ri ungmemhi oyọli gbe akanya.
\v 56 Eri o ri egbe mu Aburaamu ita ẹ, abi ọ rọ sa usamhi abi lọli ya li mẹ ogbẹlẹ ibhale oyẹmhẹ. Abi ọ rọ mẹ ibhale oyẹmhẹ, ọ ghẹlẹ.”
\p 
\v 57 Ẹgbọ iJu ẹẹ ọli, “Waa gbe ikpe egbhuẹva ali igbe ne, wẹkhi eri u mẹ Aburaamu!”
\p 
\v 58 IJesu ọ li, “Abi o li mhi li gue ọli yẹ ẹ, neni a bia Aburaamu, mhi she kpẹ laọ!”
\p 
\v 59 Ighọ e sanọ echẹ khi wẹwẹ ya tono ọli, ama, ọ ri egbọli sheli, ọ rọte wẹ ifuabọ wa, ọ ya fiẹ Owa oyi Ẹshinẹgba lase.
\c 9
\s1 IJesu ọ khueghie ọzalo alo a
\p 
\v 1 Abi iJesu ọ li kia odẹ lẹ, ọ mẹ ọmọse ọghuo ni a bia shi ọzalo.
\v 2 Eniyẹ odukhokho eyi iJesu e mhila li, “Ọsẹsẹ, ọghuo ọ lamhẹ ni o zẹ khi a bia ọmọse ọnana ọzalo? Olamhẹ oyọli lọ, abi eyi eni e bia li?”
\p 
\v 3 IJesu ọọ wẹ, “Ọa khi olamhẹ oyọli, wẹkhi eni e bia li, ama eri ọ zẹ alo ni Ẹshinẹgba ọ ri ekpabọ eyọli khasẹ elemhi agbọ oyi ọni ọzalo.
\v 4 Ogbe o kha da kie laọ ne, awa mema ya ke gbe ikanya eyi ọni ọ ghie mhẹ, ẹlẹ iyọsẹ ọ̀ọ́ bhale ni ọgbọkhọghuo ọa kẹ rọ dobẹ ya gbe akanya.
\v 5 Abi mhi li la agbọ ena, mhẹmhẹ mhi khi ọni ọ ri ákpá a na ẹgbọ ni e la agbọ.”\f + \fr 9:5 \ft Li zẹ \fq iMat 5.14; iJọn 8.12\f*
\p 
\v 6 IJesu ọ ngme ona se, ọ tono etẹ shi ekẹ fọsẹ igbọlọ rọ ma li alo.
\v 7 Ọ́ọ́ ọni ọmọse, “Ke je okẹ ni a lu iSiloamu ni u ya kpe alo a.” Usomhi ni a ghie, a ri iSiloamu ngme. Ighọ ọni ọmọse ọ li vu ya kpe alo-a. Ọọ jele apfẹ, ọọ mẹ ekẹ.
\p 
\v 8 Ẹgbọ eni e ga la kugbe ali ẹgbọ ni e kpẹ mẹ ọli khi ọọ ye omhila, ẹẹ. “Ọnana ọa she khi ọzalo ni ọ kpẹ ẹ shitọ akana mhila?”
\p 
\v 9 Ẹgbọ eghuo ẹẹ, “Lọli lọ,” ama eghuo ẹẹ, “Iiye o! Ọa khi lọli, eri ọna ọ li khọ li.” Ama ọni ọmọse ọọ, “Mhẹmhẹ o khi guẹguẹguẹ.”
\p 
\v 10 E mhila li, “Sẹ o li kia ni u rọ ke ẹ mẹ ekẹ?”
\p 
\v 11 Ọ wẹ, “Ọmọse ọghuo ni a lu iJesu ọ fọsẹ igbọlọ ma mhẹ alo, ọ mhẹ mhi je okẹ iSiloamu ya kpe alo a. Ighọ mhi lẹ ya kpe alo-a, lọli mhi rọ ọ mẹ ekẹ.”
\p 
\v 12 E ọli. “Ighe ọli?” Ọọ wẹ, “Mhi aa lẹsẹ.”
\s1 Ẹgbọ iFarisi e de udi irọze oyi ọni ọmọse
\p 
\v 13 E rue ọni ọmọse ni ọ kpẹ zẹ alo ghi ẹgbọ iFarisi.
\v 14 Ogbẹlẹ iyẹmhẹa oyi ẹgbọ iJu iJesu ọ rọ fọsẹ igbọlọ rọ khueghie ọni ọmọse alo-a.
\v 15 Eni iFarisi e mhila ọni ọmọse abi o li kia ni ọ rọ ke ẹ mẹ ekẹ. Ọọ wẹ, “IJesu ọ ri igbọlọ ma mhẹ alo, mhi kpe alo-a, mhi rọ ọ mẹ ekẹ memena.”
\p 
\v 16 Eghuo eni iFarisi ẹẹ, “Ọmọse ni ọ riẹlẹ ona ọa rọte obọ oyi Ẹshinẹgba bhale, itobọ khi ọa ri ushi oyi ogbẹlẹ iyẹmhẹa oyi ẹgbọ iJu gbe akanya.” Ẹgbọ iFarisi elese ẹẹ, “Sẹ ọgbọ olamhẹ ọ li dobẹ ya gbe akanya ọnyaloa onana?” Ingme ona o pfi umhalama shi egbe ọ na wẹ.
\p 
\v 17 Ighọ eni ẹgbọ iFarisi e mhila ọni ọmọse, “Yẹyẹ ni iJesu ọ khueghie alo-a, elọ u mẹ ya ngme shi ingme oyọli?”
\p Ọọ wẹ, “Ọmekẹguele lọ.”
\p 
\v 18 Eni ẹgbọ iJu ẹa kie miesuọ khi ọni ọmọse ọ kpẹ zẹ alo, ali khi eri a khueghie ọli alo-a. O ya ramhi ni e rọ ghie ya lu eni e bia ọni ọmọse,
\v 19 E mhila wẹ, “Omi ẹ na? Onana ẹ khi ọzalo a bia li? Sẹ o ke li kia ni ọ rọ ke ẹ mẹ ekẹ?”
\p 
\v 20 Eni e bia li ẹẹ wẹ, “Anye lẹsẹ khi omi anye lọ, anye gbo lẹsẹ khi ọzalo anye bia li.
\v 21 Ama anye aa lẹsẹ abi ọ li kia ni ọ rọ ke ẹ mẹ ekẹ, anye aa gbo lẹsẹ ọni ọ khueghie ọli alo-a. A mhila li, ọa ke khi ọmọ, ọ dobẹ ya ngme na egbọli.”
\v 22 Itobọ khi ulishi ẹgbọ iJu o mu eni e bia li e rọ ngme na. Irari khi eni ẹgbọ iJu e she kpẹ ngme ọli shi oghuo, khi ọgbọ ni ọ da mie shi ọ khi iJesu khi iKirisiti, khi eri a khu ọli owa ugamhi ya fiẹ.
\v 23 Itobọ ona eni e bia li e rọ liẹ, “Ọ fu tẹ ni ọ ngme ẹ na egbọli, a mhila li.”
\p 
\v 24 Utonuzeva, e gbo lu ọmọse ni ọ kpẹ zẹ alo, ẹẹ ọli, “Romhi Ẹshinẹgba khi u ya gue igẹsikia yẹ anye. Itobọ khi anye lẹsẹ khi ọmọse ni ọ rẹ ze khi ọgbọ olamhẹ lọ.”
\p 
\v 25 Ọọ wẹ, “Mhi aa lẹsẹ ini ọgbọ olamhẹ lọ, ama emhi oghuo ni mhi lẹsẹ khi, ọzalo mhi kpẹ khi, ama memena mhi she ẹ mẹ ekẹ.”
\p 
\v 26 E mhila li, “Sẹ ọ fẹ li ẹ? Sẹ ọ li khueghie-a ẹ alo a?”
\p 
\v 27 Ọ́ọ́ wẹ, “Mhi kpẹ gueyẹ ẹ, aa lama shi mhẹ ọ, elọ o ke zẹ ni a rọ ọ nono ni a gbo suọ oni ungmemhi? Eri a li ẹ nono ni a li khi eniyẹ odukhokho eyọli?”
\p 
\v 28 E tsue ọli, ẹẹ ọli, “Ọmọ odukhokho ọyi ọni ọmọse ọna yẹyẹ u khi, ini itse lọ, ama eniyẹ odukhokho eyi iMosisi anye khi.
\v 29 Anye lẹsẹ khi Ẹshinẹgba ọ nu iMosisi ngme, ama anye aa lẹsẹ obini ọmọse ọna ọ te bhale.”
\p 
\v 30 Ọni ọmọse ọọ wẹ, “Uza lọ e, ni aa rọ lẹsẹ obini ọ te bhale, ama lọli ọ khueghie mhẹ alo-a.
\v 31 Awa lẹsẹ khi Ẹshinẹgba ọa ya suọ iromhi oyi ẹgbọ olamhẹ, ama iromhi oyi eni e ri ekpẹ na li ọọ suọ, ali eni ẹ riẹlẹ emini ọọ nono e riẹlẹ.
\v 32 Rọte igbaekẹle agbọ, aa tigbe suọ ọgbọ ni ọ khueghie ọzalo ni o khia khi ighọ a bia li alo a ghue.
\v 33 Ini ọa khia khi ọmọse ọna khi obọ oyi Ẹshinẹgba ọ te bhale lọ, ọa kha dobẹ li emhikhọghuo.”
\p 
\v 34 E ọli, “Elemhi olamhẹ a bia ẹ shi, ni a la kuẹlẹ, sẹ u li a nono ni u ke sẹsẹ anye?” Ighọ e khu ọli elemhi owa ugamhi ya lase ọ khi ke gbo bhale ọ ghue.
\s1 Itasẹ-alo-a ona ayẹmhẹ
\p 
\v 35 Abi iJesu ọ rọ suọ khi a khu ọni ọmọse owa ugamhi ya lase, ọ nono ọli mẹ, ọ mhila li, ọọ li, “U mie Omi Ọgbọ suọ?”
\p 
\v 36 Ọni ọmọse ọ li, “Ọga, gueyẹ mhẹ ọni Omi Ọgbọ ọ khi, ni mhi mie ọli suọ!”
\p 
\v 37 IJesu ọọ li, “U she mẹ ọli, lọli ọ ga nu ẹ ngme ena.”
\p 
\v 38 Ọni ọmọse ọ li, “Ọnọmhuẹ mhi miesuọ.” Ọ wugha ọ kuẹghiẹ iJesu.
\p 
\v 39 IJesu ọli, “Eri mhi bhale agbọ ona ya gue ẹgbọ ẹzọ, isheghọ ni ẹgbọ ni e zalo e ke mẹ ekẹ, ni eni e kpẹ ẹ mẹ ekẹ ni e zẹ alo.”
\p 
\v 40 Ẹgbọ iFarisi eghuo ni e la akaghọ e suọ ingme ni ọ ngme, e mhila li, “Eri u wẹ khi ezalo anye li khi?”
\p 
\v 41 IJesu ọọ wẹ, “Ini ezalo a khi lọ, aa kha mhọli umha-guẹkia, ama abi ẹẹ a ke rọ yẹ khi a mẹ ekẹ na, onana o rọkhasẹ khi ena olamhẹ a khi.”
\c 10
\s1 Okhẹ oyi ọrisumhakia
\p 
\v 1 IJesu ọọ, “Abi o li mhi li gue ọli ẹ yẹ ẹ, khi, ọgbọ ni ọa da rọte odẹ unuẹkpẹ lo ogba ni a ri isumha shi, ni ọ rọte oboese nga fiala lo ne oghiatọ ali ọni ọ li iko ọ khi.
\v 2 Ọgbọ ni ọ rọte odẹ unuẹkpẹ lo, lọli ọ khi ọrisumhakia ọyi isumha.
\v 3 Eri ọni ọọ khẹ ekhẹ odẹ unuẹkpẹ ọ khueghie odẹ-a na li, eni isumha ẹ suọ uruli oyọli ini ọ lu isumha eyọli eva abi ọ ri eva na wẹ, ọ rẹ wẹ kia lase.
\v 4 Ọ kha da rẹ wẹwẹ nya fiẹ lase ne, eri ọọ ralo na wẹ, eni isumha ẹẹ deba li, itobọ khi e lẹsẹ uruli oyọli.
\v 5 Ẹ a ya deba ọgbọẹse, eri ẹ ri ochoghọ mẹ ọli ya ke na, itobọ khi ẹa lẹsẹ uruli oyọli.”
\p 
\v 6 Eri iJesu ọ zẹ okhẹ ona rọ nu wẹ ngme, ama ẹa lẹsẹ emini ọ ri ọli ngme.
\s1 IJesu ni ọ khi ọrisumhakia ọnete
\p 
\v 7 Ighọ iJesu ọ gbo lẹ, “Egbegbi-ingme mhi gue ẹ yẹ ẹ, mhẹmhẹ mhi khi odẹ unuẹkpẹ ni isumha e rọte ẹ lo, ni e gbo te ẹ dọsẹ fiẹ.
\v 8 Ẹgbọ ni e kpẹ bhale khẹ mhẹ, ighiatọ ali eni ẹ li iko e khi, ama eni isumha ẹa ri esọ shi wẹ ọ.
\v 9 Mhẹmhẹ mhi khi odẹ unuẹkpẹ, ọnini ọ da rọte mhẹmhẹ egbe ne, a ya mie ọli pfuese, ọ ya fiẹ, ọ lo le, ọ mẹ emhi le.
\v 10 Eri oghiatọ ọ lẹsẹ bhale ya do, ọ gbe-a, ọ pfuse-a tsẹ, ama mhi she bhale ni a mhọli agbọ, ni a mhọli ọli gba pfo.
\p 
\v 11 “Mhẹmhẹ mhi khi ọrisumhakia ọnete. Eri ọrisumhakia ọnete ọ ri agbọ oyọli shi ekẹ ni eni isumha eyọli.
\v 12 Ọni a mie shi akanya irisumhakia ọa khi lọli ọ mhọli eni isumha, ini ọ mẹ khi akpogene ọọ bhale, ọ na tsua isumha kua, ọni akpogene ọ tsua rughu eni isumha, ọ vẹsẹ wẹ kua.
\v 13 Ọni a mie shi oni akanya irisumhakia ọ na vu, itobọ khi eni isumha ẹa khi eyọli, ali khi ẹa mu ọli egbe.
\p 
\v 14 “Mhẹmhẹ mhi khi ọrisumhakia ọnete, mhi lẹsẹ isumha eyẹmhẹ, eni isumha e lẹsẹ.
\v 15 Abi Ita ọ li lẹsẹ mhẹ, ighọ mhẹmhẹ mhi lẹsẹ ọli, ighọ mhi rọ ri agbọ oyẹmhẹ shi ekẹ na eni isumha.\f + \fr 10:15 \ft Li zẹ \fq iMat 11.27; iLuk 10.22\f*
\v 16 Isumha elese e laọ ni ẹa la elemhi ogba oyi isumha ona memena. Mhi mema fiẹ ya wolọ wẹ ma ọ. E ya suọ uruli oyẹmhẹ. E ya kugbe khi ọghuo, e mhọli ọrisumhakia ọghuo.\fig IJesu ọrisumhakia ọnete|src="BK00004B.TIF" size="col" loc="JHN 10.16" copy="TIF" ref="10.16"\fig*
\v 17 Ita ọ nono ingme oyẹmhẹ, itobọ khi mhi lama ri agbọ oyẹmhẹ shi ekẹ, ni a rọ bhale ya ẹ khi mhi ya gbo mẹ ọli rue.
\v 18 Aa mẹ ọgbọkhọghuo ni ọ ya dobẹ mie mhẹ agbọ oyẹmhẹ. Mhẹmhẹ ọghuo mhi rọ li shi ekẹ. Mhi mhọli afu ni mhi rọ ọ zẹ ọli obọ, mhi gbo dobẹ ya rue ọli ini o ghọle mhẹ. Omhẹsẹ ona Itamhẹ ọ gueyẹ mhẹ mhi riẹlẹ.”
\p 
\v 19 Eni ingmemhi enana e gbo pfi umhalama shi egbe ọ na ẹgbọ iJu.
\v 20 Ebubu ẹgbọ e liẹ, “Ayẹmhẹ ọkphaghiẹ o la li egbe, ujili ọọ kpha li. Elọ e zẹ khi a ri esọ ọ shi ọli ọ?”
\p 
\v 21 Ama ẹgbọ elese, ẹẹ ọli, “Ingmemhi enana ẹa dobẹ ya rọte unu oyi ọgbọ ni ọ mhọli ayẹmhẹ ọkphaghiẹ lasele! Ayẹmhẹ ọkphaghiẹ o dobẹ ya khueghie ọzalo alo a?”
\p 
\v 22 Oni ẹghẹghẹ o khi ẹghẹghẹ oruamẹ ni a rọ li ukpe ni a rọ yelele abi a li ri Owa oyi Ẹshinẹgba riẹlẹ nga Ẹshinẹgba obọ. Ẹghẹghẹ ulili lọ.
\v 23 IJesu ọ la atukpapfẹ oyi Owa oyi Ẹshinẹgba kia, ashini a lu arakpha oyi iSolomoni.
\v 24 Ebubu ẹgbọ iJu e le gasẹ ọli, e mhila li, “Ẹlẹ u ri anye ya shi alo ebili ramhi? Khueghie igẹsikia ni o la ọ-a khasẹ anye ini yẹyẹ u khi iKirisiti!”
\p 
\v 25 IJesu ọọ wẹ, “Mhi she kpẹ gueyẹ ẹ, ama aa lama mie mhẹ suọ. Ikanya ọnyaloa ni mhi ri itoto oyi Ita a gbe, wẹwẹ e pfi ọtsẹlẹ na mhẹ.
\v 26 Ama aa lama miesuọ, itobọ khi aa la elemhi isumha eyẹmhẹ.
\v 27 Isumha eyẹmhẹ ẹẹ suọ uruli oyẹmhẹ, mhi lẹsẹ wẹ, ẹẹ deba mhẹ.
\v 28 Mhi ri agbọ na agbọagbọ na wẹ, ẹa tigbe ya pfua. Aa mẹ ọni ọ ya dobẹ mie mhẹ ẹwẹ obọ.
\v 29 Itamhẹ ni ọ ri eni isumha nga mhẹ obọ, ọ fu dọsẹ ọgbọkpa. Aa mẹ ọni ọ dobẹ ya mie Ita ẹwẹ obọ.
\v 30 Mhẹmhẹ ali Itamhẹ ọghuo anye khi.”
\p 
\v 31 Eni ẹgbọ iJu e gbo sanọ echẹ ekẹ ẹ tono ọli.
\v 32 IJesu ọọ wẹ, “Mhi she gbe ikanya ebubu ukpẹloe oyẹ ẹ, ni o khia khi Itamhẹ ọ́ ri itoto na mhẹ ni mhi rọ gbe wẹ, onoghuo a tono mhẹ echẹ ẹ shi ọ?”
\p 
\v 33 Eni ẹgbọ iJu ẹẹ ọli, “Ọa khi itobọ ikanya enete e zẹ ni anye rọ a tono ẹ echẹ, ama, itobọ khi u pfi unu-a! Sẹ yẹyẹ ọgbọ afuẹ-afuẹ u li ẹ ke liẹ khi Ẹshinẹgba u khi?”\f + \fr 10:33 \ft Li zẹ \fq iLẹv 24.16\f*
\p 
\v 34 IJesu ọọ wẹ, “A she kpẹ kẹkẹ ọli shi ebe Ishi eyi iMosisi khi Ẹshinẹgba ọọ liẹ khi, ishinẹgba ẹẹ a khi.\f + \fr 10:34 \ft Li zẹ \fq Iwolo 82.6\f*
\v 35 Anye she kpẹ lẹsẹ khi emini ebe onopfuasẹ o ngme khi igẹsikia o khi agbọagbọ, khi ẹgbọ ni a she kpẹ gue ingme oyi Ẹshinẹgba yẹ, Ẹshinẹgba ọ lu ishinẹgba.
\v 36 Ita ọ she zẹ mhẹ ọda kẹẹ neni ọ ghie mhẹ bhale agbọ, ini mhi ngme ghọ khi Omi Ẹshinẹgba mhi khi, sẹ a ke li a liẹ khi mhi a pfi unu-a?
\v 37 A khi mie mhẹ suọ, ini mhi aa ya riẹlẹ emini Itamhẹ ọ riẹlẹ.
\v 38 Ama ini mhia riẹlẹ wẹ, ini aa rọ tseku mie mhẹ suọ, a mie ikanya ọnyaloa ni mhia gbe suọ, ni a rọ lẹsẹ khi Ita ọ la elemhi oyẹmhẹ, mhẹmhẹ mhi li la elemhi oyi Ita.”
\p 
\v 39 Ighọ e ke gbo li dua ni wẹwẹ e mu iJesu, ama ọ pfue wẹ, ọa zẹ wẹ mu.
\p 
\v 40 IJesu ọ da okẹ iJọdani je ukiẹkiẹ ashini iJọni ọ ke la batazi ẹgbọ. Ighọ ọ bie ya la akaghọ.\f + \fr 10:40 \ft Li zẹ \fq iJọn 1.28\f*
\v 41 Ebubu ẹgbọ e bhale akaghọ deba li. Ẹẹ, “IJọni ọa gbe ikanya ọnyaloa okhọghuo, ama ingmemhi ni iJọni ọ ngme shi ingme eyi iJesu, e bhale ya tsẹ nya.”
\v 42 Ebubu ẹgbọ ni e la akaghọ e mie iJesu suọ.
\c 11
\s1 Eghuli oyi iLazarọsi
\p 
\v 1 Ọmọse ọghuo ni a lu iLazarọsi ni ọ la ẹoli iBẹtani, Ọ́ọ́ ghua. IBẹtani iMeli ali inyọghuo ọli ni ọkpotso ni a lu iMata e la.\f + \fr 11:1 \ft Li zẹ \fq iLuk 10.38-39\f*
\v 2 IMeli ọna ọ ke ku ituale ni ọ pfie ku Ọnọmhuẹ awẹ, ni ọ gbo ri itsu ni e la li ukhomhi shishi ọ ẹwẹ-a. Lọli ọ khi inyọghuo iLazarọsi ni ọ yẹshi i ghua.\f + \fr 11:2 \ft Li zẹ \fq iJọn 12.3\f*
\v 3 Inyọghuo ọli eni ikpotso e ghie usomhi ghi iJesu, ẹ ọ li, “Ọnọmhuẹ, ọmọle ẹ ọ̀ọ́ ghua.”
\p 
\v 4 Abi iJesu ọ rọ suọ ona, ọọ li, “Ughuamhi ona, ọa ya gbe ọli, ama, eri a mẹ onana ni a mẹ asha khi ufumhi na Ẹshinẹgba ali Omi Ẹshinẹgba.”
\p 
\v 5 IJesu ọọ nono ingme oyi iMata ali iMeli ali iLazarọsi.
\v 6 Abi ọ rọ tseku suọ khi iLazarọsi ọ ghua, ọ kie la ashini ọ la ramhi ogbẹlẹ eva.
\v 7 Ighọ ọ gueyẹ eniyẹ odukhokho eyọli, ọọ wẹ, “A zẹ ni awa mu egbe pfi je obini ekẹ iJudia.”
\p 
\v 8 Eniyẹ odukhokho eyọli ẹ ọ li, “Ọsẹsẹ, odẹ ọ́ a nuẹ ne ni ẹgbọ iJu e rọ ọ nono ni wẹwẹ tono ẹ echẹ. Oobọ wa nono ni u gbo nyenẹ egbe je?”
\p 
\v 9 IJesu ọọ wẹ, “Ọa khi te ẹlẹ uzogbe ramhi ẹlẹ ogbọmhi awa rọ ọ mẹ ekẹ? Ọni ọọ kia ini ogbe o la ọ, ọa ya khi owẹ, itobọ khi ákpá oyi agbọ ona ọ rọ ọ mẹ ekẹ.
\v 10 Ama ini ọ ri alo ebili ẹ kia, ọ ya khi owẹ, itobọ khi ọa mhọli ákpá ni ọ rọ ọ mẹ ekẹ.”
\p 
\v 11 Abi ọ ke rọ ngme onana se, ọ gueyẹ wẹ, ọọ wẹ, “ILazarọsi ọmọle awa ọ she lesẹa, ama mhia lẹ ni mhi ya guise ọli le.”
\p 
\v 12 Eniyẹ odukhokho eyọli ẹ ọ li, “Abi ọ rọ da lesẹ-a eghọ, ọ ya ze.”
\p 
\v 13 Eri IJesu ọ rọ li liẹ khi iLazarọsi ọ she ghua, ama e dabi khi egbegbi olesẹ ọ ngme.
\v 14 Ighọ iJesu ọ guele gboo khi iLazarọsi ọ she ghu-a.
\v 15 Ama itobọ oyẹ ẹ, egbe ẹ mu mhẹ shi ọ khi mhi aa nu ọli la akaghọ ni ọ rọ ghu-a, ni a rọ mie mhẹ suọ. A zẹ ni awa lẹ deba li.
\p 
\v 16 ITọmọsi ni a gbo li ẹ lu iDidimọsi, ọọ eniyẹ odukhokho enekpọle, “A zẹ ni awa li deba Ọsẹsẹ je oobọ ni awa nu ọli ghu-a.”
\p 
\v 17 Ẹghẹghẹ ni iJesu ọ ke rọ ramhi aghọ, ọ bhale ya ẹ khi o she ramhi ẹlẹ ene abi a te ri iLazarọsi tọ.
\v 18 Rọte iBẹtani je iJerusalẹmu ọa ramhi imali eva.
\v 19 Ighọ ebubu ẹgbọ iJu e she kpẹ bhale iBẹtani ya tsẹ iMeli ali iMata e mu opfu shi inyọghuo wẹ ni ọ ghu-a.
\p 
\v 20 Abi iMata ọ rọ suọ khi iJesu ọ̀ọ́ bhale, ọ fiẹ lase ya lona li odẹ, ama iMeli ọ la elemhi owa.
\v 21 IMata ọọ iJesu, “Ọnọmhuẹ, ini u la akana lọ, inyọghuo-mhẹ ọa kha ghu.
\v 22 Ama mhi lẹsẹ khi memena khi Ẹshinẹgba ọ ya ri emiemini u wa mhila li nẹ.”
\p 
\v 23 IJesu ọọ li, “Inyọghuo ẹ, ọ gbo ya guale bhale agbọ.”
\p 
\v 24 IMata ọ li, “Mhi lẹsẹ khi ọ ya te eghuli guale ogbẹlẹ iguale ni o khi ogbẹlẹ ni o kpukhokho.”
\p 
\v 25 IJesu ọọ ọli, “Mhẹmhẹ mhi rọte eghuli ya guise eni e ghu-a le, ni mhi ri agbọ ya na wẹ, ọni ọ da mie mhẹ suọ ọ ya mhọli agbọ, ini ọ tseku ghu-a.
\v 26 Ọni ọ la agbọ ni ọ da mie mhẹ suọ, ọa tigbe ya ghu-a. U fẹ mie ona suọ?”
\p 
\v 27 Ọọ li, “Ii Ọnọmhuẹ! Mhi miesuọ khi yẹyẹ u khi iKirisiti, Omi Ẹshinẹgba ni ọ ya bhale ekẹ agbọ ona.”
\p 
\v 28 Abi iMata ọ rọ ngme ghọ se ọ lẹ ya ri ọfiẹ gueyẹ iMeli, ọọ, “Ọsẹsẹ ọ she bhale, ọ̀ọ́ nono ẹ.”
\v 29 Abi iMeli ọ rọ suọ ona ọ ti vule, ọ nyanya fiẹ lase je ashini iJesu ọ la.
\v 30 IJesu ọa kie ramhi oni ẹoli ni ọ́ọ̀ je ne, ama ọ kie la ashini ọ kia ramhi ni iMata ọ rọ lona li odẹ.
\v 31 Ẹgbọ iJu ni e la elemhi owa yẹsẹ ọli, e vule deba li je olase abi e rọ mẹ khi ọ ti vule je olase. E dabi khi eri ọ je obini uji ya viẹ.
\p 
\v 32 Abi iMeli ọ rọ ramhi ashini iJesu ọ la ni ọ mẹ ọli, ọ de ya wugha li odalo, ọọ li, “Ọnọmhuẹ, ini u la akana lọ, inyọghuo-mhẹ ọa kha ghu!”
\p 
\v 33 Abi iJesu ọ mẹ khi lọli ali ẹgbọ iJu ni e kphase ọli khi ee viẹ, o rọ obọ ti iJesu udu, egbe e guọghọ ọli a.
\v 34 IJesu ọ mhila wẹ, ọọ, “Ashi a rọ li tọ?”
\p Ẹ ọ li, “Ọnọmhuẹ bhale ya ghe ọli.”
\p 
\v 35 IJesu ọ́ viẹ.
\v 36 Ẹgbọ iJu ni e la aghọ, ẹẹ, “A ghe abi ọli nono ingme oyi ọli khẹ.”
\p 
\v 37 Ama eghuo ọ e liẹ, “Lọli ni ọ khueghie ọzalo alo-a ọọ kha dobẹ tsumhi iLazarọsi ini ọ khi ghua?”
\s1 IJesu ọ guise iLazarọsi gbo bhale agbọ
\p 
\v 38 O gbo ri obọ ti iJesu udu. Ọ kia je obini uji ni o khi irui, ni a gheghele ẹchẹ zuse unu.
\v 39 IJesu ọọ, “A gheghele oni ẹchẹ unu oni uji-a.”
\p IMata inyọghuo ọni ọmọse ni ọ ghu-a ọọ, “Ọnọmhuẹ, ọ shẹ ya ke wẹ! Amo o li ẹlẹ onuzi-ene abi a te rọ li tọ!”
\p 
\v 40 IJesu ọ li, “Mhi a kpẹ gueyẹ khi u ya mẹ ufumhi oyi Ẹshinẹgba ini u miesuọ?”
\v 41 Ighọ e gheghele oni ẹchẹ unu uji lase. IJesu ọ yasẹ alo idane, ọ li, “Mhi kphẹmhi nẹ Ita, khi u suọ mhẹ.
\v 42 Mhi lẹsẹ khi u ma suọ oyẹmhẹ, itobọ oyi ẹgbọ ena mhi rọ ọ ngme ona ni e miesuọ khi yẹyẹ u ghie mhẹ.”
\p 
\v 43 Abi ọ rọ ngme ona se, ọ lu ọli leghe, “ILazarọsi e! Fiẹ lasele!”
\v 44 Ọni ọmọse ni ọ ghu-a ọ fiẹ lasele, a ri ide olimhi gẹnọ li abọ ali awẹ, ghe eni a rọ ku ọli alo. IJesu ọọ wẹ, “A taghiẹ ọli a ni a zẹ ọli vu.”
\s1 Ugbamhi abi a li ya gbe iJesu-a
\r (iMat 26.1-5; iMak 14.1-2; iLuk 22.1-2)
\p 
\v 45 Ebubu ẹgbọ iJu ni e bhale ya tsẹ iMeli ọ mu opfu e mẹ emini iJesu ọ riẹlẹ, e mie ọli suọ.
\v 46 Ama eghuo elemhi wẹ e vu ya gueyẹ ẹgbọ iFarisi emini iJesu ọ riẹlẹ.
\v 47 Ighie eyi ekpodalo-ugamhi ali iFarisi e ya lu eni ẹ mhẹsẹ ni a lu iSaẹdiri ya nu wẹ mhọli ilegba.
\p E mhila egbewẹ, “Elọ awa li ena? Aa mẹ ikanya ọnyaloa ni ọmọse onana ọ gbe?
\v 48 Ini awa lina zẹ ọli obọ, ọgbọkpa ọ ya mie ọli suọ. Ẹgbọ iRomu e ya shashe Owa oyi Ẹshinẹgba oyawa-a.”
\p 
\v 49 Ọmọse ọghuo elemhi wẹ ni a lu iKefasi, ni ọ ralo ugamhi oni ukpe oghọ, ọọ li, “Aa lẹsẹ ingme!
\v 50 A lẹsẹ khi ọgbọ ọtuọghuo ọ kha ghu-a na ẹgbọ kpa, khi o ti dọsẹ ni ẹgbọ nya e pfua?”
\p 
\v 51 Ọa khi ibe eyọli ọ rọ sa ngme oni ungmemhi ona, ama ungmemhi angme-shi-ekẹ ni o ya tsẹ ogbe na akọ, khi iJesu ọ ya ghu-a na ẹgbọ iJu o khi ni ọ ngme, itobọ khi lọli ọ ralo ugamhi oni ukpe.
\v 52 Ọa khi oyi iJu tsẹ, ama ni ọ sanọ ẹgbọ eyi Ẹshinẹgba ni e kia miatsẹ ku agbọ nya gbili rẹ wẹ khili oghuo.
\p 
\v 53 Rọte ẹlẹ ghọ vu, ẹgbọ iJu e te gba ugbamhi abi wẹwẹ e li ya gbe iJesu a.
\v 54 Itobọ ighọ, iJesu ọa ke kia lase gboo iteva oyi ẹgbọ iJu. Ọ ri ochoghọ vu je ẹoli ni a lu Efuremu, ni o ti mama ọdagbe ifufu. Aghọ lọli ali eniyẹ odukhokho eyọli e ke ga la.
\p 
\v 55 Abi ẹghẹghẹ ukpe iPasova oyi ẹgbọ iJu o rọ ti i bhale, ebubu ẹgbọ e te ẹoli ọdọda je iJerusalẹmu ya ri egbe wẹ khi eni e pfuasẹ, abi ushi oyẹwẹ ọọ e ke li neni oni ukpe o ramhi.
\v 56 Ee nono iJesu. Abi e rọ la elemhi Owa oyi Ẹshinẹgba, e mhila egbewẹ, e liẹ, “A li sa khi ọ ya bhale? Otsẹ ọa ya bhale shi oni ukpe ona.”
\v 57 Ama ighie eyi ekpodalo-ugamhi ali iFarisi e she kpẹ mhẹsẹ na eni ẹgbọ, ọni ọ da lẹsẹ obini iJesu ọ la, ọni ọgbọ ọ guele ni wẹwẹ e mẹ asha mu ọli.
\c 12
\s1 IMeli ọ la obini iBẹtani ku ituale ku iJesu
\r (iMat 26.6-13; iMak 14.1-9)
\p 
\v 1 Abi o rọ kpọ ogbẹlẹ esesa oni ukpe iPasova le, iJesu ọ nyenẹ egbe bhale obini iBẹtani, obini iLazarọsi ni iJesu ọ rọte eghuli guise le ọ la.
\v 2 E nye akhe na iJesu, iMata ọ kphanọ eni eminale ghi wẹ. ILazarọsi ọ li nu wẹ shitọ shi ilele oyi eni ekhe.
\v 3 Ighọ iMeli ọ rue egbegbi akanama ituale ni ọ pfie ni o lolo ghalẹ. Ọ́ ku ọli shi iJesu awẹ, ọ ri itsu ni e la li ukhomhi shishi ọ awẹ a. Upfiemhi oyi oni ituale o kphela vọ oni elemhi owa nya.\f + \fr 12:3 \ft Li zẹ \fq iLuk 7.37-38\f*
\p 
\v 4 IJudasi Isikarọti ni ọ khi ọtuọghuo eniyẹ odukhokho eyi iJesu, ni ọ rọte ikpukhokho ya ri iJesu dẹ, ọ mẹ emini iMeli ọ riẹlẹ, ọọ,
\v 5 “Elọ o zẹ ni aa rọ ri oni ituale dẹ ni a kemhi eni ikpaghọ na eni ẹa mhuẹ? Oni ituale o ghalẹ ramhi ifata ukpe oyi ọgbọ ọghuo.”
\v 6 Ọa khi itobọ khi ọ mhọli udu iamhẹ na eni ẹa mhuẹ, ọ rọ ngme ungmemhi ona. Ama itobọ khi oghiatọ ọ khi, ali khi lọli ọ tsua ikpaghọ ọ mhuẹ na wẹ, ni ọ rọte muno epfia.
\p 
\v 7 Ama iJesu ọọ li, “Zẹ ọli obọ riẹlẹ emini o la li udu, eri ọ mu mhẹ egbe ẹ khẹ irọtọ oyẹmhẹ.
\v 8 Ẹghẹghẹ kpa ẹgbọ ni ẹa mhuẹ e rọ nu ẹ a la, ama mhẹmhẹ mhia nu ẹ ya la ana ẹghẹghẹ kpa.”\f + \fr 12:8 \ft Li zẹ \fq iDẹut 15.11\f*
\p 
\v 9 Ebubu ẹgbọ iJu e suọ khi iJesu ọ la iBẹtani, ighọ e je oobọ. Ọa khi itobọ iJesu tsẹ e rọ je oobọ, ama ni e ba mẹ iLazarọsi ni iJesu ọ te eghuli guise le.
\v 10 Ighọ ighie eyi ekpodalo-ugamhi ee gba ugbamhi abi e li ya li gbe iLazarọsi a,
\v 11 itobọ khi ingme oyọli o zẹ khi ebubu ẹgbọ iJu e ku ma iJesu ọ, ni e rọ mie ọli suọ.
\s1 Ẹgbọ e ri ufumhi na iJesu abi ọ́ rọ́ lo elemhi iJerusalẹmu
\r (iMat 21.1-11; iMak 11.1-11; iLuk 19.28-40)
\p 
\v 12 Ogbeakọlọ ebubu ẹgbọ ni e bhale shi oni ukpe iPasova e suọ khi iJesu ọ̀ọ́ je iJerusalẹmu.
\v 13 Ighọ e yanọ eyamhi mhuẹ abọ fiẹ ya ẹẹ ọli. E kpe okeke gbii, e liẹ, “Tsumhi anye. Awa kuẹghiẹ Ẹshinẹgba. Ẹshinẹgba ọ khivọsẹ na ọni ọ ri eva oyi Ẹshinẹgba Ọnọmhuẹ ẹ bhale! Ẹshinẹgba ọ ka khivọsẹ na oghie iZirẹni!”\f + \fr 12:13 \ft Li zẹ \fq Iwolo 118.25,26\f*
\p 
\v 14 IJesu ọ mẹ ozele akphẹrẹ. Ọ nga li shitọ abi Ebe-no-pfuasẹ o ngme ọli, ni ọọ,
\q1 
\v 15 “Ẹgbọ iJerusalẹmu,
\q2 ulishi o khi mu ẹ!
\q1 Oghie ọyẹ ẹ ọọ bhale ena,
\q2 ọ nga ozele akphẹrẹ ẹẹ bhale.”\f + \fr 12:15 \ft Li zẹ \fq iZaka 9.9\f*
\p 
\v 16 Eniyẹ odukhokho eyi iJesu ẹa kpẹ rọte ekẹ lẹsẹ obini eni ingme ena e je. Ama abi Ẹshinẹgba ọ rọte eghuli guise iJesu le ni ọ ri ufumhi na li, e rọ tigbe sato khi a kpẹ kẹkẹ eni ingme eyọli ena shi Ebe-no-pfuasẹ, ali khi e ke riẹlẹ eni ingme ena deba li ghue.
\p 
\v 17 Olele ẹgbọ ni e nu ọli la aghọ abi ọ rọ rọte uji lu iLazarọsi lasele, ni ọ rọ rọte eghuli guise ọli le, e kie kia gueyẹ ẹgbọ abi a li mẹ oni ingme.
\v 18 Itobọ khi ebubu ẹgbọ e suọ khi iJesu ọ gbe akanya ọnyaloa ona e rọ vẹ lasele ya mẹ ọli.
\v 19 Ighọ ẹgbọ iFarisi e nu egbe wẹ ngme ọli, e liẹ, “Awa aa mhọli emini awa dobẹ ya li ona. Aa mẹ khi ẹgbọ nya e ke ẹ deba li!”
\s1 IJesu ọ ngme ingme eghuli oyọli shi ekẹ
\p 
\v 20 Ẹgbọ iGiriki e li la eni e je iJerusalẹmu ya ga ẹghẹghẹ oni ukpe iPasova.
\v 21 E ya mhila iFilipu (ni ọ khi ọnge iBẹtisaida ni o la iGalili) ẹ ọ li “Ọga, anye ẹ nono ni anye mẹ iJesu, ni anye nu ọli ngme.”
\p 
\v 22 IFilipu ọ vu ya gueyẹ Aduru, wẹwẹ aava e ya gueyẹ iJesu.
\p 
\v 23 IJesu ọọ, “Oni ẹghẹghẹ o she ramhi ni a rọ́ ri ufumhi oniẹmhi oyi Omi Ọgbọ ya khasẹ.
\v 24 Abi o li mhi li gue ọli ẹ yẹ ẹ khi, ini aa li ri ukpamhi ado kọ ekẹ ni o ghua, eri o kie ya li abi o kie kpẹ li. Ini a rọli kọ ekẹ ni o rọ zẹ, o ghua, o fu, o ri imọmhi ni e bu lasele.
\v 25 Ọnini ọ da nono ingme agbọ oyọli dọsẹ odẹ ne, o ya de ọli obọ a, ama ọni ọa da nono ingme agbọ oyọli elemhi agbọ ona ne, eri ọ kẹsẹ ọ shi ẹ khẹ agbọ na agbọagbọ.\f + \fr 12:25 \ft Li zẹ \fq iMat 10.39; 16.25; iMak 8.35; iLuk 9.24; 17.33\f*
\v 26 Ọni ọ nono khi lọli ya ga mhẹ, ọọ mema ya ke deba mhẹ. Ashini mhi da la kpa, ọ li la akaghọ. Itamhẹ ọ mu ekpẹ na li.
\p 
\v 27 “Memena udu oyẹmhẹ ọa ke sheshe. Elọ mhi kẹ ya ngme? ‘Eri mhi kẹ ya liẹ, Ita, khi zẹ ni ẹghẹghẹ ona o bhale deba mhẹ’? Iiye, oni ẹghẹghẹ ni o zẹ ni mhi rọ bhale agbọ na!
\v 28 Ita ri ufumhi ni o la eva oyẹ khasẹ.”
\p Ighọ Ẹshinẹgba ọ rọte idane ngme lase, ọọ, “Mhi she kpẹ ri ufumhi ni o la eva oyẹmhẹ khasẹ ẹgbọ na agbọ, mhi ya gbo lighọ riẹlẹ ọli.”
\p 
\v 29 Ebubu ẹgbọ ni e migha epfepfẹ aghọ e suọ khi uruli oyi Ẹshinẹgba o ngme. Ẹgbọ eghuo ẹẹ, “Akphala o de!” Ẹgbọ elese ẹẹ, “Agẹni ọ nu ọli ngme!”
\p 
\v 30 Ama iJesu ọọ, “Ọa khi itobọ oyẹmhẹ uruli oyi Ẹshinẹgba oghọ o rọ ngme ungmemhi oghọ, ama itobọ oyẹ ẹ lọ.
\v 31 Oni ẹghẹghẹ o she ramhi ni a rọ ri agbọ ẹ gue ẹzọ. Memena, a ya khu Ọkphaghiẹ ọni ọ kpẹ ẹ mhẹsẹ shi agbọ ona ukpẹkhomhi pfia.
\v 32 A kha da yasẹ mhẹ nga idane ọọra apfida ne, mhi ya ti ọgbọkpa bhale deba mhẹ.”
\v 33 Eri ọ ngme ona ni ọ rọ rọkhasẹ wẹ uwali eghuli ni ọ ya ghu.
\p 
\v 34 Eni ẹgbọ ẹẹ ọli, “Ushi ni Ẹshinẹgba ọ rọ na iMosisi na awa o gue ọli yẹ anye khi agbọagbọ Ọmiepfuese ọ ya la ọ. Sẹẹ u ke li a liẹ khi a mema ya yasẹ Omi Ọgbọ nga idane? Ọghuo ọ khi ọni Omi Ọgbọ ọna?”\f + \fr 12:34 \ft Li zẹ \fq Iwolo 110.4; Aza 9.7; Ezik 37.25; iDan 7.14\f*
\p 
\v 35 IJesu ọọ wẹ, “Ákpá o ya la ẹ iteva ukuku ẹghẹghẹ. A ke kia okiali abi oni ákpá o kie la ẹ iteva memena, ini obili o khi ya bi ẹ, itobọ khi ọni ọ la alo ebili ọa lẹsẹ obini ọọ je.
\v 36 A regbenga ọni ákpá ni ọ ri ákpá na ẹ abi ọ kie li la ẹ iteva, ni a li khi ẹgbọ ni e ri imekẹ ẹ na ẹgbọ.” Abi iJesu ọ li ngme ona se, ọ lase wẹ iteva le, je ashini ẹa ke te e mẹ ọli.
\s1 Umha-miesuọ oyi ẹgbọ iJu
\p 
\v 37 Abi iJesu ọ tseku gbe ikanya ọnyaloa ena ukpẹloe oyẹwẹ, ẹa kie lama mie ọli suọ.
\v 38 Onana o ri emini Azaya ni ọ khi Ọmekẹguele ọ kpẹ ngme shi ekẹ ya tsẹ, ni ọọ,
\q1 “Ọnọmhuẹ, ọghuo ọ lama
\q2 mie usomhi oyanye suọ?
\q1 Ọghuo Ọnọmhuẹ ọ mema
\q2 khueghie ekpabọ eyọli-a khasẹ?”\f + \fr 12:38 \ft Li zẹ \fq Aza 53.1\f*
\p 
\v 39 Onana o zẹ khi ẹa dobẹ miesuọ, itobọ khi Azaya ọ gbo ngme ọli shi ashese khi,
\v 40 “Ẹshinẹgba ọ she tasẹ wẹ alo a, ọ gbo zuse wẹ udu ini e khi mẹ ekẹ ali ini udu oyẹwẹ e khi lẹsẹ ingme. Ini e khi ya mu pfi, ni mhi mẹ asha rẹ wẹ ze.”\f + \fr 12:40 \ft Li zẹ \fq Aza 6.10\f*
\v 41 Eri Azaya ọ ngme ona itobọ khi ọ she kpẹ mẹ ufumhi oyi iJesu, ọ gbo kpẹ ngme ingme oyọli.
\p 
\v 42 Abi o tseku khia khi ebubu eni ẹẹ ralo eyi ẹgbọ iJu e mie iJesu suọ ẹghẹghẹ ni a ngme ena, ẹa ngme ọli lasele, itobọ khi e na ulishi oyi iFarisi ini e khi khu ẹwẹ owa ugamhi ya lase.
\v 43 Irari khi e nono ikuẹghiẹ ni o rọte obọ oyi ẹgbọ bhale dọsẹ oni o rọte obọ oyi Ẹshinẹgba bhale.
\s1 Ungmemhi oyi iJesu a rọ ya ri ẹgbọ na agbọ gue ẹzọ
\p 
\v 44 IJesu ọ tsẹsẹ leghe guele, ọọ, “Ọni ọ da mie mhẹ suọ, ọa khi mhẹmhẹ tsẹ ọ miesuọ, ama ọni ọ ghie mhẹ ọ li miesuọ.
\v 45 Ọnini ọ da mẹ mhẹ, ọ she li mẹ ọni ọ ghie mhẹ.
\v 46 Mhi she bhale agbọ ya ri ákpá gẹ na ẹgbọ na agbọ, ini eni e mie mhẹ suọ ọkhọghuo ọ khi la alo ebili.
\v 47 Ọni ọ suọ ungmemhi oyẹmhẹ ni ọa da rọ shi ọ, ọa khi mhẹmhẹ mhi ya pfa ẹzọ mu ọli. Ọa khi eri mhi bhale ya ri ẹgbọ na agbọ gue ẹzọ, ama eri mhi bhale ya mie agbọ pfuese.
\v 48 Ọni ọọ pfa ẹzọ mu ọni ọ da kie mhẹ ali ungmemhi oyẹmhẹ, ọ la aghọ. Eni ingmemhi ni mhia ngme e ya pfa ẹzọ mu ọli ogbẹlẹ ni o kpukhokho.
\v 49 Itobọ khi ọa khi ungmemhi ọọtsobọ oyẹmhẹ mhia ngme, ama ungmemhi ni Ita ni ọ ghie ọ mhẹsẹ na mhẹ mhi ngme mhia ngme.”
\v 50 Mhi lẹsẹ khi oni ushi oyi Ẹshinẹgba, o ri agbọ na agbọagbọ ọ na ọgbọ. Irarighọ, eri mhi ẹ ngme emini Ita ọ gueyẹ mhẹ mhi ngme.
\c 13
\s1 IJesu ọ kpe eniyẹ odukhokho eyọli awẹ-a
\p 
\v 1 Abi o rọ kpọ ẹlẹghuo ukpe iPasova le, iJesu ọ lẹsẹ khi oni ẹghẹghẹ o she ramhi ni ọ rọ ya te agbọ lasele je oyi Ita. Ọ ma kie kpẹ nono ingme oyi ẹgbọ eyọli ni e la agbọ, ọ rọli khasẹ wẹ khi eri lọli nono ingme oyẹwẹ pfo.
\p 
\v 2 IJesu ali eniyẹ odukhokho eyọli e la ashini e la le eminale ẹlẹ ogbọmhi. Ọkphaghiẹ ọ she rọli shi udu oyi iJudasi omi iSamọ Isikarọti ọ ka rọ iJesu dẹ.
\v 3 IJesu ọ lẹsẹ khi Ita ọ she rọ ekpabọ nga luẹ obọ, ọ lẹsẹ khi obọ oyi Ẹshinẹgba lọli kpẹ te bhale, ali khi obọ oyọli lọli gbo nyenẹ egbe ya je.
\v 4 Ighọ iJesu ọ rọte ashini ọ shitọ ti vule, ikhi ashini e la le eminale, ọ gueghie awulu ni ọ sọ kpeda, ọ ri ode ni a rọ ọ muno amẹ egbe-a mu oku.
\v 5 Ighọ ọ ku amẹ shi atalabi, ọ kpe eniyẹ odukhokho eyọli awẹ-a. Ọ rue ode ni a rọ ọ muno amẹ egbe a ni ọ rọ mu oku shishi wẹ amẹ awẹ-a.
\p 
\v 6 Abi ọ rọ kpe ramhi iSamọ iPita ọ, iPita ọọ, “Kie! Ọnọmhuẹ yẹyẹ u kha ke kpe mhẹ awẹ a?”
\p 
\v 7 IJesu ọọ li, “Wa lẹsẹ emini mhia riẹlẹ memena, ama u ya lẹsẹ okhẹse.”
\p 
\v 8 ISamọ iPita ọọ, “Ọnọmhuẹ, atsobọ oghọ! Wa ya tigbe kpe mhẹ awẹ-a.”
\p IJesu ọọ, “Ini mhia kpe ẹ awẹ-a, wa aa ke khi ọyẹmhẹ.”
\p 
\v 9 ISamọ iPita ọọ, “O kha khi ighọ, Ọnọmhuẹ, ọa khi awẹ tsẹ u ke lẹsẹ ya kpe mhẹ-a! Ama kpe mhẹ abọ ali ukhomhi-a ma ọ.”
\p 
\v 10 IJesu ọọ li, “Ọgbọ ni ọ da khuẹ se, ọ she pfuasẹ, ọa khi ọni ọ ke gbo ya khuẹ-a, ama awẹ ọ ke lẹsẹ ẹ yẹghẹ-a. Ẹẹ nya a she pfuasẹ, sẹ ni ọtuọghuo elemhi ẹ.”
\v 11 Irari khi iJesu ọ she kpẹ lẹsẹ ọni ọ ya rọ ọli dẹ, lọli o zẹ ni ọ rọ liẹ, “Ẹẹ nya a she pfuasẹ, sẹ ni ọtuọghuo elemhi ẹ.”
\p 
\v 12 Abi iJesu ọ rọ kpe wẹ awẹ a se, ọ riẹlẹ awulu ni ọ kpẹ gueghie rọ sọ, ọ ya shitọ ashini ọ kpẹ te vule. Ọọ mhila wẹ, “A li lẹsẹ akanya ni mhi gbe na ẹ lẹna?”
\v 13 “A lu mhẹ ‘Ọsẹsẹ’ ali ‘Ọnọmhuẹ.’ A ga guẹ ngme, itobọ khi emini mhi khi ghọ.
\v 14 Memena ni mhẹmhẹ ni mhi khi Ọnọmhuẹ ali Ọsẹsẹ ọyẹẹ mhi she kpe ẹ awẹ-a, ẹẹ a li ke kpe egbe ẹ awẹ-a.
\v 15 Mhi she ri irọkhọkhọ khasẹ ẹ, ni a li ke riẹlẹ emini mhi riẹlẹ na ẹ.\f + \fr 13:15 \ft Li zẹ \fq iLuk 22.27\f*
\v 16 Egbegbi ingme mhi gueyẹ ẹ, khi ọni ọ ga ọgbọ, ọa ya fu dọsẹ ọni ọọ ga, ọni a aghiusomhi ọa ya fu dọsẹ ọni ọ ghie ọli usomhi.\f + \fr 13:16 \ft Li zẹ \fq iMat 10.24; iLuk 6.40; iJọn 15.20\f*
\v 17 Abi a rọ lẹsẹ eni ingme ena eghọ, a ya khivọsẹ na ẹ, ini a rọ li gba akanya.
\s1 IJesu ọ guele shi ekẹ khi a ya rẹ luẹ dẹ
\r (iMat 26.20-25; iMak 14.17-21; iLuk 22.21-23)
\p 
\v 18 “Aa khi ẹẹ nya mhi nu ẹ ngme. Mhi lẹsẹ abi ingeli eyi eni mhi zẹ e li. Ama, emini Ebe-no-pfuasẹ o ngme, o mema bhale ya tsẹ, ikhi oni ọọ, ‘Ọgbọ ni ọ nu mhẹ ẹ le eminale ọ ya nyenẹ egbe mu okhọli vule shi mhẹ ọ.’\f + \fr 13:18 \ft Li zẹ \fq Iwolo 41.9\f*
\p 
\v 19 “Eri mhia gue ona yẹ ẹ shi ekẹ neni a lighọ mẹ ọli, isheghọ ini a lighọ mẹ ghọ, a ya miesuọ khi ‘Mhẹmhẹ mhi khi ọni mhi khi.’
\v 20 Abi o li mhi li gue ọli ẹ yẹ ẹ, khi ọni ọ da kpe abọ mie aghiusomhi ni mhi ghie, mhẹmhẹ ọ li mie, ọni ọ da mie mhẹ, ọni ọ ghie mhẹ ọ li mie.”\f + \fr 13:20 \ft Li zẹ \fq iMat 10.40; iMak 9.37; iLuk 9.48; 10.16\f*
\p 
\v 21 Abi iJesu ọ rọ ngme ona se, udu ọa ke sheshe ọli, ọ guele gboo, ọọ, “Egbegbi ingme mhi gueyẹ ẹ, khi ọtuọghuo elemhi ẹ, ọ ya rẹmhẹ dẹ.”
\p 
\v 22 Eniyẹ odukhokho eyọli e bino egbe alo gasẹ, o lolo sha wẹ abọ ọni iJesu ọ ngme.
\v 23 Ọghuo ọmọ odukhokho ni iJesu ọ mema nono ingme oyọli, ọ shitọ mama iJesu.
\v 24 ISamọ iPita ọ rọ ikpialo nu ọni ọmọ odukhokho ngme, ọọ li, “Mhila iJesu, ọghuo ọni ọgbọ ọ fẹ khi elemhi awa.”
\p 
\v 25 Ighọ ọni ọmọ odukhokho ni ọ shitọ mama iJesu ọ mhila li, ọọ, “Ọnọmhuẹ, ọghuo ọni ọgbọ ọ khi elemhi anye?”
\p 
\v 26 IJesu ọ sọ li ọ, ọọ, “Ọni mhi ya ri ibulẹdi ona sọmhi utasa oni awa te ẹ le emhi enana na ne, lọli lọ.” Ighọ ọ sọ oni ibulẹdi elemhi utasa, ọ rọ na iJudasi omi iSamọ Isikarọti.
\v 27 Abi iJudasi ọ lẹsẹ mie oni ibulẹdi se, Ọkphaghiẹ ọ lo ọli udu. IJesu ọ gueyẹ ọli, “Nyanya ya riẹlẹ emini wa nono ni u riẹlẹ.”
\v 28 Ọgbọkhọghuo abi e ga li shitọ ọ le eminale, ọa la ni ọ lẹsẹ emini o zẹ ni iJesu ọ rọ ngme ọli ghọ.
\v 29 Aborọkhia khi iJudasi ọ tsua ikpaghọ ọ mhuẹ na wẹ, eghuo e dabi khi eri iJesu ọ gueyẹ ọli ọ ka dẹ emini e rọ ọ li ukpe iPasova. Elese e dabi khi otsẹ eri ọọ ọ ka somhi eni ẹa mhuẹ opfa.
\v 30 Abi iJudasi ọ mie oni ibulẹdi se. Ọ fiẹ lase aghọaghọ. Ẹliyọsẹ o she ramhi.
\s1 IJesu ọ ri ushi onogbọ na wẹ
\p 
\v 31 Abi iJudasi ọ rọ vu se, iJesu ọọ, “Eena ẹgbọ e ya mẹ ufumhi oyi mhẹmhẹ Omi Ọgbọ, e ya te idiegbe oyi Omi Ọgbọ mẹ ufumhi oyi Ẹshinẹgba.
\v 32 Ini ẹgbọ e rọte idiegbe oyi Omi Ọgbọ mẹ ufumhi oyi Ẹshinẹgba, ẹghẹghẹ aghọ Ẹshinẹgba lọlighuo ọ ya nyanya ri ufumhi oyi Omi Ọgbọ khasẹ ẹgbọ.
\p 
\v 33 “Eniyẹ eyẹmhẹ, mhia ke nu ẹ ya la akana tẹsẹ. A ya nono mhẹ, aa ke mẹ mhẹ. Mhi gue ona yẹ ẹ memena, abi mhi kpẹ li gueyẹ eni ẹẹ mhẹsẹ eyi ẹgbọ iJu, ni mhiẹ, Aa dobẹ ya ramhi obini mhi-a je.”\f + \fr 13:33 \ft Li zẹ \fq iJọn 7.34\f*
\p 
\v 34 “Memena mhi rọ ushi onogbọ na ẹ: A nono ingme oyi egbe ẹ. Abi mhi li nono ingme oyẹ ẹ, a mema li ya nono ingme oyi egbe ẹ.\f + \fr 13:34 \ft Li zẹ \fq iJọn 15.12,17; 1 iJọn 3.23; 2 iJọn 5\f*
\v 35 A kha da mhọli inono na egbe ẹ ne, ẹgbọ kpa e ya lẹsẹ khi eniyẹ odukhokho eyẹmhẹ a khi.”
\s1 IJesu ọ ngme ọ shi ekẹ khi iPita ọ ya kie luẹ
\r (iMat 26.31-35; iMak 14.27-31; iLuk 22.31-34)
\p 
\v 36 ISamọ iPita ọ mhila li, ọọ, “Ọnọmhuẹ, obo wa lẹ?”
\p IJesu ọọ li, “Waa ya dobẹ deba mhẹ je obini mhia je, ama u ya deba mhẹ okhẹse.”
\p 
\v 37 IPita ọ mhila li, ọọ “Elọ e zẹ ni mhi aa rọ dobẹ ya deba ẹ? Mhi mu egbe ni agbọ oyẹmhẹ o li opfu-a!”
\p 
\v 38 IJesu ọ ke gbo sọ li ọ, “U ga mema mu egbe agbọ oyẹ o rọ liẹ opfu-a na mhẹ? Mhi gueyẹ khi, neni ọkpa ọ gbiẹghẹ, u ya liẹ khi u waa lẹsẹ mhẹ ramhi itesẹ!”
\c 14
\s1 IJesu khi odẹ ni a tẹ ẹ bhale deba Ẹshinẹgba
\p 
\v 1 IJesu ọ gueyẹ eniyẹ odukhokho eyọli, ọọ wẹ, “Aa khi zẹ ni udu o yese ẹ-a, a mie Ẹshinẹgba suọ, a gbo li mie mhẹ suọ.
\v 2 Elemhi owa ni a la e kpọku shi apfẹ oyi Itamhẹ. Ini ọa khi ighọ lọ, mhi kha gueyẹ ẹ. Mhia ya vu ni mhi ya mu egbe asha shi ekẹ khẹ ẹ.
\v 3 Mhi kha vu ya mu egbe shi ekẹ khẹ ẹ se, mhi ya gbo nyenẹ egbe bhale ya wolọ ẹ ma egbe vu, isheghọ ashini mhi ya la, ni a li nu mhẹ la akaghọ.
\v 4 A lẹsẹ odẹ ni a tẹ ẹ je ashini mhia je.”
\p 
\v 5 ITọmọsi ọọ li, “Ọnọmhuẹ, anye ẹa lẹsẹ obini u wa je. Sẹẹ anye li ya lẹsẹ odẹ je obini u wa je?”
\p 
\v 6 IJesu ọọ li, “Mhẹmhẹ mhi khi odẹ ni a te ẹ je obini oyi Ẹshinẹgba. Mhẹmhẹ mhi ri igẹsikia ni o la Ẹshinẹgba a khasẹ. Mhẹmhẹ mhi ri agbọ ọ na ọgbọ. Ọgbọ khọghuo ọa mẹ asha ya je obini oyi Ita ini ọa li rọte obọ oyẹmhẹ.
\v 7 Eri a kha lẹsẹ mhẹ lọ, a kha li lẹsẹ ọni Ita. Rọ te memena vu, a she lẹsẹ ọli, a gbo mẹ ọli.”
\p 
\v 8 IFilipu ọọ, “Ọnọmhuẹ, ri ọni Ita khasẹ anye, emini anye lẹsẹ nono ghọ.”
\p 
\v 9 IJesu ọ sọli ọ, ọ, “IFilipu, mhi she nu ẹ la tẹsẹ, waa kie lẹsẹ ọni mhi khi? Ọni ọ da mẹ mhẹ, ọ she mẹ ọni Ita. Sẹẹ u kiele ẹ liẹ ‘Ri ọni Ita khasẹ anye?’
\v 10 Filipu, waa miesuọ khi mhi la elemhi oyi Ita, ali khi Ita ọ la elemhi oyẹmhẹ? Ingmemhi ni mhi gueyẹ ẹ nya ẹa khi eyẹmhẹ. Ita ni ọ la mhẹ elemhi ọ ga gbe ikanya ena nya.
\v 11 A mie emini mhi ngme suọ ini mhiẹ khi mhi la elemhi oyi Ita ali khi Ita ọ li la elemhi oyẹmhẹ. Ini aa mie emini mhi ngme suọ, a ri itobọ ikanya ọnyaloa ni mhia gbe miesuọ.
\v 12 Egbegbi-ingme mhi gue ẹ yẹ ẹ, ọni ọ da mie mhẹ suọ, ọ ya gbe ikanya enabi mhia gbe. Ọ ya gbe ikanya eni e fu dọsẹ eni abi mhia gbe, itobọ khi mhia je oyi Ita.
\v 13 Emini a rọ eva oyẹmhẹ mhila nya mhi ya riẹlẹ ọ, ẹghẹghẹ aghọ ni ọmọ ri ufumhi oyi Ita khasẹ ẹgbọ.
\v 14 Emini a rọ eva oyẹmhẹ mhila nya, mhi ya riẹlẹ na ẹ.
\s1 IJesu ọ shobọ khi lọli ya ghi Ayẹmhẹ-nọ-pfuasẹ bhale agbọ
\p 
\v 15 “A kha nono ingme oyẹmhẹ, a ya ri omhẹsẹ oyẹmhẹ gba akanya.
\v 16 Ẹghẹghẹ aghọ, mhi ya lema Ita, ọ ri Ọkpaghiobọ ọlese na ẹ, ni ọ ya nu ẹ la agbọagbọ.
\v 17 Lọli ọ khi Ayẹmhẹ ni o ri igẹsikia ni o la Ẹshinẹgba a khasẹ agbọ. Ẹgbọ na agbọ ẹa dobẹ mie ọli itobọ khi ẹa mẹ ọli wẹkhi eri e lẹsẹ ọli. Ama, ẹẹ ena a lẹsẹ ọli, itobọ khi ọ nu ẹ la, ọ la elemhi oyẹ ẹ.
\p 
\v 18 “Mhia ya zẹ ẹ obọ shi ekẹ abi omi-olimhi, mhi ya gbo nyenẹ egbe bhale deba ẹ.
\v 19 O kha dẹnẹ, ẹgbọ na agbọ ẹa kẹ ẹ mẹ mhẹ, ama ẹẹ ena, a ya mẹ mhẹ. Itobọ khi mhi ya gbo la agbọ, a ya li la agbọ.
\v 20 Ini ogbe ni ẹlẹghọ o ramhi, a ya lẹsẹ khi mhi la elemhi oyi Itamhẹ, khi ẹẹ a la elemhi oyẹmhẹ, abi mhi li la elemhi oyẹ ẹ.
\p 
\v 21 “Ọni ọ mie ishi eyẹmhẹ ni ọ ri ẹwẹ gbe akanya, ọ nono ingme oyẹmhẹ. Itamhẹ ọ ya nono ingme oyi ọni ọda nono ingme oyẹmhẹ, mhi ya li nono ingme oyi ọni ọgbọ, mhi ri egbe mhẹ khasẹ ọli.”
\p 
\v 22 IJudasi (ọa khi ọni a lu Isikarọti) ọọ, “Ọnọmhuẹ, elọ o zẹ khi u fẹ ya ri egbe ẹ khasẹ anye tsẹ, ni u wa rọ ya ri egbe ẹ khasẹ agbọ kpa?”
\p 
\v 23 IJesu ọ sọ li ọ, ọọ, “Ọni ọ da nono ingme oyẹmhẹ, ọ ya ri osẹsẹ oyẹmhẹ gbe akanya. Itamhẹ ọ ya nono ingme oyi ọli, mhẹmhẹ ali Itamhẹ, anye bhale ya nu ọli la.
\v 24 Ọni ọa da nono ingme oyẹmhẹ, ọa rọ osẹsẹ oyẹmhẹ ya gbe akanya. Eni osẹsẹ ni mhia sẹsẹ ẹ, ẹa khi eyẹ mhẹ, ama obọ oyi Itamhẹ ni ọ ghie mhẹ e te bhale.
\p 
\v 25 “Mhi she gue ena yẹ ẹ, abi mhi kie li nu ẹ la.
\v 26 Ama oni, Ayẹmhẹ-nọ-pfuasẹ ikhi Ọkpaghiobọ, ni Ita ọ ya rọ eva oyẹmhẹ rọ ghi ẹ, ọ ya sẹsẹ ẹ emhikpa. Ọ ya gbo rẹ ẹ yelele emhikpa ni mhi gueyẹ ẹ.
\v 27 Mhi zẹ ẹ obọ shi agbọ ona shi opfọmhẹ, mhi ri opfọmhẹ oyẹmhẹ na ẹ. Ọa khi oni abi ẹgbọ na agbọ e rọ ọ na ọgbọ mhi rọ na ẹ. A khi zẹ udu yese ẹa, ali a khi zẹ ni ulishi o mu ẹ.
\p 
\v 28 “A suọ abi mhi rọ gueyẹ ẹ khi mhi ya rọte iteva oyẹẹ vu, khi mhi ya gbo bhale deba ẹ. Ini a nono ingme oyẹmhẹ lọ, a kha ke ghẹlẹ khi mhia je oyi Itamhẹ, irari khi lọli ọ fu dọsẹ mhẹ.
\v 29 Mhi she gue ingme ena yẹ ẹ shi ekẹ neni a mẹ wẹ, isheghọ ini a da kie lighọ mẹ wẹ, a mie mhẹ suọ.
\v 30 Mhia kẹ nu ẹ ngme tẹsẹ, itobọ khi ọkphaghiẹ ni ọ kpẹ mhẹsẹ shi agbọ ona, ọọ bhale. Ọa mhọli ekpabọ shi agbọ oyẹmhẹ,
\v 31 ama ẹgbọ na agbọ e mema ya lẹsẹ khi mhi ma nono ingme oyi Ita, ali khi emini Itamhẹ ọ mhẹsẹ na mhẹ mhi riẹlẹ, mhia riẹlẹ tee.
\p “A bhale ni awa vu ana le.
\c 15
\s1 IJesu ọ khi egbegbi ọọra upfonu
\p 
\v 1 “Mhẹmhẹ mhi li abi oni upfonu ni ọ mọ umọmhi onete, Itamhẹ ọ́ riẹlẹ ẹ shi ọ.
\v 2 Lọli ọọ kanọ uguabọ oyẹmhẹ ni ọa ya mọ umọmhi a. Ọọ riẹlẹ uguabọ oyẹmhẹ ni ọọ mọ umọmhi, ni o gbo mọ imọmhi eni e bu.
\v 3 Ungmemhi ni mhi she nu ẹ ngme o she riẹlẹ ẹ ti ni a rọ dobẹ mọ imọmhi enete.\fig ogba ipfonu|src="hk00108b.tif" size="col" loc="JHN 15.3" copy="TIF" ref="15.3"\fig*
\v 4 A toma mhẹ idiegbe, mhẹmhẹ mhi ya toma ẹ idiegbe. Uguabọ ọọra okhọghuo ọa dobẹ ya mọ umọmhi ọọtsobọ oyọli, o mema ya to ma idiegbe ọọra. U kẹ neta khi eri a dobẹ ya riẹlẹ eminete ini aa toma mhẹ egbe.
\p 
\v 5 “Mhẹmhẹ mhi khi ọọra upfonu, ẹẹ a li abi iguabọ. Ini u toma mhẹ egbe ni mhi rọ li toma ẹ egbe, u ya mọ imọmhi eni e bu. Ini a rọ obọ rue mhẹ ọ le, aa dobẹ ya riẹlẹ emhikhọghuo onete.
\v 6 Ini u waa da toma mhẹ egbe ne, eri a ya khi ẹ pfia. Eri u ya li abi iguabọ ekhakha ni, a ti ẹ ma ri erali tosẹ-a.
\v 7 Ini u toma mhẹ egbe, ni ingmemhi eyẹmhẹ e rọ la elemhi oyẹ, emiemini o ghọle ẹ kpa wa mhila, a ri ọli nẹ.
\v 8 Eminete ni a riẹlẹ o ri ufumhi ghi Itamhẹ. Ona o rọkhasẹ khi eniyẹ odukhokho eyẹmhẹ a khi.
\p 
\v 9 “Abi Ita ọ nono ingme oyẹmhẹ, ighọ mhi li nono ingme oyẹẹ. A la elemhi inono oyẹmhẹ.
\v 10 Ini a rọ ishi eyẹmhẹ gbe akanya, a ya la inono oyẹmhẹ, abi mhi li ri ishi eyi Itamhẹ gbe akanya ni mhi li la inono oyọli.
\v 11 Eri mhi gue ona yẹ ẹ ni oghẹlẹ oyẹmhẹ o vọ ẹ udu, ni oni oghẹlẹ oyẹ ẹ o gba pfo.
\v 12 Ushi ni mhi rọ na ẹ khi, a nono ingme oyi egbe ẹ, abi mhi nono ẹ.\f + \fr 15:12 \ft Li zẹ \fq iJọn 13.34; 15.17; 1 iJọn 3.23; 2 iJọn 5\f*
\v 13 Aa mẹ inono olese ni o fu dọsẹ oni ọgbọ ọ rọ ghu-a na emọle ọli.
\v 14 Emọle mhẹ a khi ini a da ri ishi eyẹmhẹ gbe akanya.
\v 15 Mhi aa kẹ lu ẹ eni ẹ ga mhẹ, itobọ khi ọni ọ ga ọgbọ ọa lẹsẹ akanya ni ọga ọyọli ọ gbe. Ochoghọ, emọle mhi ke ẹ lu ẹ, itobọ emini mhi rọte obọ oyi Itamhẹ wẹna nya mhi gueyẹ ẹ.
\v 16 Ọa khi ẹẹ a zẹ mhẹ, mhẹmhẹ mhi zẹ ẹ ni mhi ri akanya na ẹ, a ka gbe ikanya enete ni ikanya eyẹ ẹ e migha. Isheghọ Ita ọ ya rọ emini a rọ eva oyẹmhẹ mhila nya na ẹ.
\v 17 Ushi oyẹmhẹ ni mhi shi na ẹ khi, a nono ingme oyi egbe ẹ.
\s1 Ẹgbọ na agbọ ee biselemhi eniyẹ odukhokho eyi IJesu
\p 
\v 18 “Ini ẹgbọ na agbọ ẹ biselemhi ẹ, a sato khi ighọ e kpẹ li biselemhi mhẹ.
\v 19 Ini a khi eyi ẹgbọ na agbọ lọ, e kha nono ingme oyẹ ẹ abi enayẹwẹ. Abi o ke li memena khi, aa ke khi eyi ẹgbọ na agbọ itobọ khi mhi she rọte elemhi agbọ zẹ ẹ, lọli o zẹ khi ẹgbọ na agbọ e rọ́ biselemhi ẹ.
\v 20 A sato ingme ni mhi gueyẹ ẹ, ‘Ọni ọọ ga ọgbọ ọa fu ẹ dọsẹ ọga ọyọli.’ Ini e kpẹ mu okhọli vule shi mẹ ọ ghue, e ya mu okhọli vule shi ẹ ọ. Ama ini e rọ osẹsẹ ni mhi sẹsẹ gbe akanya, e ya rọ osẹsẹ oyẹ ẹ li gbe akanya.\f + \fr 15:20 \ft Li zẹ \fq iMat 10.24; iLuk 6.40; iJọn 13.16\f*
\v 21 E ya lina ngeli deba ẹ itobọ khi enayẹmhẹ a khi, ali itobọ khi ẹa lẹsẹ ọni ọ ghie mhẹ.
\v 22 Ini mhi aa bhale ya nu wẹ ngme lọ, ẹa kha mhọli umha-guẹkia oyi olamhẹ. Ama ẹa ke mhọli emini e gue ọli ya nga egbe khi o rẹwẹ a lamhẹ olamhẹ.
\v 23 Ọni ọ da biselemhi mhẹ, Itamhẹ ọ li liẹ biselemhi.
\v 24 Ini mhi aa la akpẹwẹ gbe ikanya ni ọgbọẹse ọa dobẹ gbe ghue lọ, ẹa kha mhọli umha-guẹkia oyi olamhẹ. Ama memena e she mẹ eni ikanya ọnyaloa, ama e kiele ẹ biselemhi mhẹ ali Itamhẹ.
\v 25 Ama ona o zẹ ni emini a kẹkẹ shi ebe ushi oyẹwẹ o rọ bhale ya tsẹ, oni ọ́ khi, ‘Afuẹ ẹ biselemhi mhẹ.’\f + \fr 15:25 \ft Li zẹ \fq Iwolo 35.19; 69.4\f*
\p 
\v 26 “Ini ọni Ọkpaghiobọ ọ bhale, ọni mhi rọte obọ oyi Itamhẹ ya ghie ghi ẹ, lọli ọ khi Ayẹmhẹ nọ ọ ri igẹsikia ni o la Ita a khasẹ, ọ ya pfi ọtsẹlẹ shi ingme oyẹmhẹ.
\v 27 Ẹẹ a ya li mema pfi ọtsẹlẹ na mhẹ, itobọ khi rọte igbaekẹle a te nu mhẹ la.
\c 16
\p 
\v 1 “Eri mhi gue ona a yẹ ẹ ini a khi tsua irudunga pfia.
\v 2 Ẹgbọ e ya khu ẹ owa ugamhi fiẹ lase, ẹghẹghẹ o ga ya ramhi ni ọgbọ ọ kha gbe ọngẹẹ a, ọ dabi khi eri lọli ẹ ga Ẹshinẹgba.
\v 3 E ya riẹlẹ eni emhi ena deba ẹ, itobọ khi ẹa lẹsẹ Ita, wẹkhi mhẹmhẹ.
\v 4 Ama, eri mhi gue ona yẹ ẹ, ini oni ẹghẹghẹ o ramhi, a ya sato khi mhi kpẹ tse agua yẹ ẹ. Itobọ khi mhi kie nu ẹ la mhi aa rọ kpẹ gue ingme ena yẹ ẹ.
\s1 Akanya ni Ayẹmhẹ-nọ-pfuasẹ ọọ gbe
\p 
\v 5 “Memena, mhia lẹ deba ọni ọ ghie mhẹ, ama ọngẹẹ ọa kie mhila mhẹ, ‘Obo wa je?’
\v 6 Itobọ khi mhi gue ingme ena yẹ ẹ, udu oyẹẹ o she yese-a.
\v 7 Ama igẹsikia mhi gueyẹ ẹ, ni o rọ ti ẹ egbe mhi rọ rọte ẹ iteva a vu. Itobọ khi ini mhi aa vu, ọni Ọkpaghiobọ ọa ya bhale. Ama ini mhi da vu mhi ya ghie ọli ghi ẹ.
\v 8 Ini Ọ da bhale, Ọ ya rẹwẹ lẹsẹ umha-guẹkia ni o la ingme olamhẹ, ọ gbo rẹwẹ li lẹsẹ ipfuasẹ oyi Ẹshinẹgba ali isọ-ẹzọ oyọli.
\v 9 Ọ ya rẹwẹ lẹsẹ khi umha-guẹkia ni o la olamhẹ o khi, umha mie mhẹ suọ.
\v 10 Ọ ya rẹwẹ lẹsẹ khi e ya mhọli ipfuasẹ oyi Ẹshinẹgba, itobọ khi mhi je oyi Ita ni aa ke te tigbe ya mẹ mhẹ
\v 11 Ọ ya rẹwẹ lẹsẹ emini isọ-ẹzọ oyi Ẹshinẹgba o khi. Itobọ khi a she pfa ẹzọ mu ọkphaghiẹ ọni ọ mhẹsẹ ẹ shi agbọ ona.
\p 
\v 12 “Mhi mhọli emini e bububu ni mhi kha gbo gueyẹ ẹ, ama e bu dọsẹ ni a dobẹ ya mie.
\v 13 Ama ini Ayẹmhẹ ni ọ ri igẹsikia a khasẹ ọ da bhale, ọ ya ri igẹsikia ni o la ingme oyi Ẹshinẹgba nya khasẹ ẹ. Ọa ya ngme ungmemhi ọọtsobọ oyọli, ama emini ọ suọ ọ ya ke ngme. Ọ gbo gueyẹ ẹ ingme ni a ya mẹ.
\v 14 Mhẹmhẹ ọ ya ke ti nga, itobọ khi ọ ya mie mhẹ ungmemhi ni mhi ngme gueyẹ ẹ.
\v 15 Emini Itamhẹ ọ mhuẹ nya, eyẹmhẹ lọ, lọli o zẹ khi mhi kpẹ gueyẹ ẹ khi emini mhi rọ na Ayẹmhẹ-nọ-pfuasẹ, ọ ya gueyẹ ẹ.
\s1 Oya oyẹẹ o ya mele oghẹlẹ a
\p 
\v 16 “O kha dẹnẹ, aa kẹ mẹ mhẹ, o kha ke gbo dẹnẹ a gbo mẹ mhẹ.”
\p 
\v 17 Eniyẹ odukhokho eghuo ee mhila egbewẹ, “Elọ ọ ri ona a ngme, ni ọọ liẹ awa khi, o kha dẹnẹ khi awa aa ke a mẹ luẹ, ali khi o kha ke gbo dẹnẹ khi awa gbo lo ya mẹ luẹ? Ọ gbolo ẹ, ‘Itobọ khi mhi ya je obini oyi Ita.’
\v 18 Elọ ọ ri ‘O kha dẹnẹ’ ngme? Awa aa lẹsẹ ingme ni ọ rọ ọli ngme!” E kie lina mhila egbewẹ.
\p 
\v 19 IJesu ọ́ she lẹsẹ khi ẹẹ nono ni e mhila luẹ oni ungmemhi ona, ọ mhila wẹ, “Eri a mhila egbe ẹ abi mhi ri oni ungmemhi ngme, ni mhi rọ liẹ, ‘O kha dẹnẹ aa ke ya mẹ mhẹ ali khi o kha gbo dẹnẹ a ya mẹ mhẹ?’
\v 20 Egbegbi ingme mhi gue ẹ yẹ ẹ, a ya viẹ, a viẹ oya. Ama ẹgbọ na agbọ e ya ke ghẹlẹ, ẹẹ a mhuẹ iyeseudu-a, oni iyeseudu-a o ya mele oghẹlẹ-a na ẹ.
\v 21 Ini ọkpotso ọ ya bia, udu o yese ọli a itobọ khi ẹghẹghẹ osue o she bhale, ama ini ọ bia ọni ọmọ se, ọọ ghẹlẹ, ọ yele osue ni ọ mẹ a. Irari khi ọọ ghẹlẹ khi lọli bia ọmọ shi agbọ.
\v 22 Ighọ o li li ẹ egbe, memena udu o yese ẹ a, ama mhi ya gbo mẹ ẹ. Ẹghẹghẹ aghọ oghẹlẹ o vọ ẹ udu, oghẹlẹ ni ọgbọ ọa dobẹ ya mie.
\v 23 Ini oni ogbẹlẹ o ramhi, aa kẹ ẹ mhila mhẹ emhikhọghuo. Mhi gue igẹsikia a yẹ ẹ khi Itamhẹ ọ ya rọ emini a ri eva oyẹmhẹ mhila kpa na ẹ.
\v 24 Ga ramhi memena, aa kie ri eva oyẹmhẹ mhila emhikhọghuo. A mhila khi a ya mẹ mie, isheghọ ni oghẹlẹ oyẹẹ o gba pfo.
\s1 IJesu ọ khọli okhọli agbọ mu ọ le
\p 
\v 25 “Mhi aa lolo kpẹ khueghie ingme-a gue ẹ yẹ e. Ama ẹghẹghẹ ọọ bhale ni mhi aa ke rọ lighọ nu ẹ ngme, ama mhi ya gue ingme oyi Ita yẹ ẹ gboo.
\v 26 Ini oni ogbẹlẹ o ramhi, a ya ri eva oyẹmhẹ mhila Ita emini o ghọle ẹ. Mhi aa liẹ khi mhẹmhẹ mhi ya mhila na ẹ.
\v 27 Ita ọọ nono ingme oyẹẹ, itobọ khi a nono ingme oyẹmhẹ, a gbo miesuọ khi obọ oyi Ẹshinẹgba mhi te bhale.
\v 28 Obọ oyi Ita mhi te bhale ya lo elemhi agbọ, memena mhi gbo te elemhi agbọ ya vu je deba Ita.”
\p 
\v 29 Eniyẹ odukhokho eyọli ẹẹ ọli, “Ena u tigbe ẹ khueghie ingmemhi eyẹ-a gueyẹ anye gboo, waa ke ẹ biẹbiẹ eni ingme-a gueyẹ anye.
\v 30 Eena anye lẹsẹ khi u lẹsẹ emhikpa, ọa ke khi ọgbọ ọ ke gbo ya ke mhila ẹ ogbọ. Onana o zẹ khi anye miesuọ khi obọ oyi Ẹshinẹgba u te bhale.”
\p 
\v 31 IJesu ọ sọ wẹ ọ, ọ, “A she miesuọ memena?
\v 32 Ẹghẹghẹ ọọ bhale, oni ẹghẹghẹ o she ramhi, ni ẹẹ nya a rọ ya miatsẹ ku, ọgbọgbọ ọ je apfẹ oyọli. Mhẹmhẹ-ghuo tsẹ mhi ke ya la. Ama ọa khi mhẹmhẹghuo tsẹ mhi la, itobọ khi Ita ọ nu mhẹ la.
\v 33 Eri mhi gue ingme ena yẹ ẹ, ni a ri itobọ khi a kugbe mhẹ ọ mhuẹ opfọmhẹ. Ẹgbọ na agbọ e ya ri osue na ẹ mẹ. Ama a mhọli udu, itobọ khi mhi she mu agbọ ọ le.”
\c 17
\s1 IJesu ọ sọ iromhi na eniyẹ odukhokho eyọli
\p 
\v 1 Abi iJesu ọ rọ nu eniyẹ odukhokho eyọli ngme se, ọ yasẹ alo bino idane, ọ sọ iromhi, ọọ, “Ita, oni ẹghẹghẹ o she ramhi. Ri ufumhi oyi Omiẹ khasẹ agbọ, ni Omiẹ ọ li ri ufumhi oyẹ khasẹ agbọ.
\v 2 Itobọ khi u she ri ekpabọ na li, shi ukhomhi oyi ẹgbọ na agbọ kpa, ni ọ ri agbọ na agbọagbọ na ẹgbọ ni u rọ na li.
\v 3 Agbọ na agbọagbọ khi, ni a rọ lẹsẹ ẹ, ikhi yẹyẹ ni u khi egbegbi Ẹshinẹgba ọghuo kpe. Ni a gbo rọ lẹsẹ mhẹ iJesu iKirisiti, ni u ghie.
\v 4 Mhi she ri ufumhi oyẹ khasẹ ẹgbọ na agbọ, abi mhi rọ ọ gbe akanya ni u rọ na mhẹ, ni mhi gbe ọli pfo.
\v 5 Ita, gbo ri ufumhi ni mhi kpẹ mhọli na mhẹ memena, ikhi ufumhi ni mhi rọte ekẹ mhọli neni a ma agbọ.
\p 
\v 6 “Mhi she ri ẹ khasẹ ẹgbọ ni u te elemhi agbọ rọ na mhẹ. Ẹgbọ eyẹ e khi ni u rọ na mhẹ. E she ri ungmemhi oyẹ gbe akanya.
\v 7 Memena e she lẹsẹ khi emhikpa ni u rọ na mhẹ khi obọ oyẹ e te bhale.
\v 8 Mhi she gueyẹ wẹ usomhi ni u rọ na mhẹ, wẹwẹ e she mie oni usomhi. E she lẹsẹ egbegbọ khi obọ oyẹ mhi te bhale, e gbo miesuọ khi yẹyẹ u ghie mhẹ.
\p 
\v 9 “Mhi sọ iromhi na wẹ, ọa khi ẹgbọ na agbọ nya mhi sọ iromhi na, ama eni u rọ na mhẹ irari khi ẹgbọ eyẹ e khi.
\v 10 Emhikpa ni mhi mhọli eyẹ e khi, emini u mhọli eyẹmhẹ e li khi. Wẹwẹ e ri ufumhi oyẹmhẹ khasẹ ẹgbọ na agbọ.
\v 11 Memena mhia bhale deba ẹ, mhia ke la elemhi agbọ, ama wẹwẹ e kie la elemhi agbọ. Ita ni ọ pfuasẹ, ri itoto ni o la eva oyẹ ni u rọ na mhẹ, khukhu wẹ, ni e khi ọghuo abi mhẹmhẹ ali yẹyẹ awa khi ọghuo.
\v 12 Ẹghẹghẹ ni mhi rọ nu wẹ la, mhi ri itoto ni o la eva oyẹ ni u rọ na mhẹ, khukhu wẹ, mhi khẹ wẹ ekhẹ. Ọkhọghuo ọ ọa pfua, sẹ ni ọghuo elemhi wẹ ni ọ khi ọni ọ ya pfua, ni emini a kẹkẹ shi Ebe-no-pfuasẹ o bhale ya tsẹ.\f + \fr 17:12 \ft Li zẹ \fq Iwolo 41.9\f*
\p 
\v 13 “Memena mhia bhale deba ẹ, mhia ngme ingmemhi ena, abi mhi kie li la elemhi agbọ, ini eniyẹ odukhokho eyẹmhẹ e mhọli oghẹlẹ ni o gba pfo, onabi oyẹmhẹ.
\v 14 Mhi she gue usomhi oyẹ yẹ wẹ, ama agbọ ẹ biselemhi wẹ, itobọ khi ẹa ke khi enayi agbọ abi mhia li khi ọnayi agbọ.
\v 15 Mhi aa liẹ u wolọ wẹ elemhi agbọ lasele, ama tsumhi wẹ obọ oyi Ọna ọkhọlọ.
\v 16 Ẹa khi enayi agbọ abi mhi aa li khi ọna agbọ.
\v 17 Ri igẹsikia oyẹ rẹwẹ pfuasẹ. Irari khi egbegbi ungmemhi ungmemhi oyẹ o khi.
\v 18 Abi u li ghie mhẹ je elemhi agbọ, ighọ mhi li ghie wẹ je elemhi agbọ.
\v 19 Itobọ ẹwẹ mhi rọ ri egbe mhẹ nẹ, ini wẹwẹ ee li lighọ ri egbe wẹ nẹ egbegbọ.
\s1 IJesu ọ lema na igbaa oyi eni e mie iJesu iKirisiti suọ nya
\p 
\v 20 “Ọa khi itobọ oyi eniyẹ odukhokho eyẹmhẹ tsẹ mhi rọ sọ iromhi ona. Mhi li sọ iromhi na ẹgbọ ni e li ya te ọtsẹlẹ oyẹwẹ mie mhẹ suọ.
\v 21 Mhi sọ iromhi e ga kugbe khi ọghuo. Ita! Mhi sọ iromhi e la elemhi oyi awa, ẹzẹzẹ abi u li la elemhi oyẹmhẹ ni mhẹmhẹ mhi li la elemhi oyẹ. Mhi sọ iromhi e khi ọghuo ini agbọ e mie wẹ suọ khi yẹyẹ u ghie mhẹ.
\v 22 Mhi ri ufumhi ni u rọ na mhẹ na wẹ ini e kugbe khi ọghuo abi mhẹmhẹ ali yẹyẹ awa khi ọghuo.
\v 23 Mhẹmhẹ mhi la elemhi oyẹwẹ, yẹyẹ u la elemhi oyẹmhẹ, ni e ga kugbe khi ọghuo, isheghọ ni agbọ e lẹsẹ khi yẹyẹ u ghie mhẹ, ali khi u nono ingme oyẹwẹ abi u nono ingme oyẹmhẹ.
\p 
\v 24 “Ita, yẹyẹ u ri wẹ na mhẹ. Mhia nono ni e nu mhẹ la ashini mhi ya la kpa, isheghọ ni e mẹ ufumhi ni u rọ na mhẹ itobọ khi u nono ingme oyẹmhẹ neni a ma agbọ.
\p 
\v 25 “Ita ni ọ pfuasẹ! Agbọ ẹa lẹsẹ ọni u khi, ama mhẹmhẹ mhi lẹsẹ ọni u khi, enana e lẹsẹ khi yẹyẹ u ghie mhẹ.
\v 26 Mhẹmhẹ mhi ri ọni u khi khasẹ, ighọ mhi kie li ya ke riẹlẹ ọli, isheghọ inono ni u mhọli na mhẹ, o la wẹ egbe, ni mhẹmhẹ mhi li la elemhi oyẹwẹ.”
\c 18
\s1 Abi a li ri iJesu dẹ
\r (iMat 26.47-56; iMak 14.43-50; iLuk 22.47-53)
\p 
\v 1 Abi iJesu ọ rọ sọ iromhi ona se, lọli ali eniyẹ odukhokho eyọli e da uchokẹ ni a lu iKidirọni lase. Ogba ni a kọ ẹẹra na lu olivu shi o la epfẹ aghọ, iJesu ali eniyẹ odukhokho eyọli e lo elemhi oni ogba oyi ẹẹra olivu.
\v 2 IJudasi ọni ọ ri ọli dẹ ọ lẹsẹ oni ogba, itobọ khi iJesu ali eniyẹ odukhokho eyọli e kẹlẹ lona akaghọ.
\v 3 Ighọ iJudasi ọ tsua ekhọli-okhuẹ eyi iRomu, ali ẹgbọ ni e la Owa oyi Ẹshinẹgba ẹ khẹ ekhẹ ali ighie eyi ekpodalo-ugamhi eyi iJu ali iFarisi ma egbe. E tsua itsua okhọli, ali igbili igọlọ ali ikpa. E lo ogba oyi ẹẹra olivu le.
\p 
\v 4 IJesu ọ she kpẹ lẹsẹ emini lọli ya mẹ, ọ mhila wẹ, ọọ. “Ọghuo a nono?”
\p 
\v 5 Ẹẹ ọli, “IJesu ọnge iNazarẹti!”
\p IJesu ọọ, “Mhẹmhẹ na.”
\p IJudasi ni ọ ri ọli dẹ ọ migha mama wẹ.
\v 6 Abi IJesu ọ rọ gueyẹ wẹ khi, “Mhẹmhẹ na,” ighọ e ti je ukhokho, e de ya gbe.
\p 
\v 7 IJesu ọ gbo mhila wẹ, ọọ, “Ọghuo ẹ khi a nono wẹ?”
\p E gbo liẹ ọ li, “IJesu ọnge iNazarẹti.”
\p 
\v 8 IJesu ọọ, “Mhi she kpẹ gueyẹ ẹ khi mhẹmhẹ na. O kha khia khi mhẹmhẹghuo a nono, a zẹ ni eni e kpọle e vu.”
\v 9 Eri iJesu ọ ngme ona ni emini ọ kpẹ ngme o bhale ya tsẹ, ni ọọ: “Ita! Mhi aa wasẹ ọkhọghuo elemhi ẹgbọ ni u rọ na mhẹ a.”
\p 
\v 10 Ighọ iSamọ iPita, ni ọ tsua itakobi shi emhi ọ ji ọli lasele rọ bẹ ọni ọ gbe akanya a deba ọga ọyi ekpodalo ugamhi esọ na obita ukhomhi pfi-a. IMakọsi a lu ọni ọmọse.
\v 11 IJesu ọọ iPita, “Rue itakobi oghọ shi ashini u kpẹ te ji ọli lasele. Eri u dabi khi mhia ya rọte uko osue ni Itamhẹ ọ mhẹsẹ na mhẹ ya da?”\f + \fr 18:11 \ft Li zẹ \fq iMat 26.39; iMak 14.36; iLuk 22.42\f*
\s1 A mu iJesu bhale odalo iguẹzọ oyi ẹgbọ iJu
\p 
\v 12 Ighọ ekhọli-okhuẹ eyi iRomu ali eni e kpeda na wẹ ali eni e khẹ ekhẹ owa ugamhi ni o funẹ eyi ẹgbọ iJu, e gba iJesu mu, e gẹ ọli abọ je ukhokho.
\v 13 E te ododẹ rue ọli bhale ayi Anasi, ni ọ khi ọgọ iKefasi. IKefasi ọ khi ọkpodalo-ugamhi ọyi Ẹshinẹgba ọni ọ kpeda ọyi ẹgbọ iJu oni ukpe oghọ.
\v 14 IKefasi ọ́ ke kpẹ ye ẹgbọ iJu ude, khi ini ọgbọ ọtuọghuo ọ ghu-a na ẹgbọ ni e bu, o ti dọsẹ ni ẹgbọ ni e la ẹoli nya e pfua.\f + \fr 18:14 \ft Li zẹ \fq iJọn 11.49-50\f*
\s1 IPita ọ kie iJesu
\r (iMat 26.69-70; iMak 14.66-68; iLuk 22.55-57)
\p 
\v 15 ISamọ iPita ali ọmọ odukhokho ọyi iJesu ọlese, e deba iJesu. Ọni ọmọ odukhokho ali oni ọ kpeda nya na ekpodalo-ugamhi eyi Ẹshinẹgba e kpẹ lẹsẹ egbe. Ighọ ọni ọmọ odukhokho ọ deba iJesu lo elemhi apfẹ oyi oni ọ kpeda nya na ekpodalo-ugamhi eyi Ẹshinẹgba.
\v 16 Abi iPita ọọ migha olase epfẹ odẹ unuẹkpẹ, ọni ọmọ odukhokho ọghọ ọ nyenẹ egbe je olase, ọ ya nu ọni ọmueshi ni ọ la aghọ ngme, ọ rue iPita lo elemhi apfẹ.
\v 17 Ọni ọmueshi ni ọ la odẹ unuẹkpẹ ọ̀ mẹ iPita, ọ́ ọ̀ li, “Ọa khi ọmọ odukhokho ọyi ọni ọmọse ọghọ u li khi?”
\p IPita ọọ, “Iiye, mhia khi lọli.”
\p 
\v 18 Ulili o gbe. Eni ẹ khẹ ekhẹ ali ighumha e migha gasẹ erali ingamhi ni e pfie, e khasẹ erali. IPita ọ li nu wẹ migha a khasẹ erali.
\s1 Ọga ọyi ekpodalo ugamhi ọ mhila iJesu ogbọ
\r (iMat 26.59-66; iMak 14.55-64; iLuk 22.66-71)
\p 
\v 19 Ọni ọga ọyi ekpodalo ugamhi eyi Ẹshinẹgba ọ mhila iJesu ogbọ osẹsẹ eyọli ali eniyẹ odukhokho eyọli.
\v 20 IJesu ọ́ sọli ọ, ọ, “Mhi aa tigbe na sheli sẹsẹ osẹsẹ elemhi Owa Oyi Ẹshinẹgba ali owa ugamhi ni mhi la a sẹsẹ gboo ẹghẹghẹ kpa, ikhi ashini ẹgbọ iJu ẹ legba.
\v 21 Elọ o zẹ khi áá mhila mhẹ ogbọ? A ka mhila ẹgbọ ni e suọ osẹsẹ oyẹmhẹ. E lẹsẹ emini mhi ngme.”
\p 
\v 22 Abi iJesu ọ ngme ona se, ọghuo eni ẹ khẹ ekhẹ ọ lase iJesu esọ, ọ li, “Elọ o zẹ ni u rọ lighọ nu Ọga ọyi ekpodalo ugamhi a ngme?”
\p 
\v 23 IJesu ọọ, “Ini u lẹsẹ khi mhi aa gue ngme, gue emini ọa ti ni mhi ngme le, ni ẹgbọ e suọ. Ama o kha khia khi mhi guẹ ngme, elọ o zẹ ni u rọ lase mhẹ esọ?”
\p 
\v 24 Ana Anasi ọ la liẹ e rue ọli ghi iKefasi ni ọ khi Ọga ọyi ekpodalo ugamhi, abi a kie li gẹ ọli abọ je ukhokho. Ẹghẹghẹ ona, iKefasi ali Anasi e ga khi ekpodalo-ugamhi eyi Ẹshinẹgba ni e kpeda.
\s1 IPita ọ gbo kie iJesu
\r (iMat 26.71-75; iMak 14.69-72; iLuk 22.58-62)
\p 
\v 25 IPita ọ kie migha akaghọ, ọọ khasẹ erali. Ẹgbọ elese e mhila li, “Wa she khi ọghuo eniyẹ odukhokho eyi ọmọse ọghọ?” IPita ọ sọ wẹ ọ, ọọ, “Iiye! Ọa khi mhẹmhẹ.”
\p 
\v 26 Ọghuo ọni ọ gbe akanya a deba oni ọ kpeda nya na ekpodalo-ugamhi eyi Ẹshinẹgba, ni ọ khi ọgbọ ọyi ọmọse ni iPita ọ bẹ esọ ukhomhi a, ọ gbo mhila iPita, “Ọa khi yẹyẹ mhi she mẹ khi u nu ọmọse ọghọ la elemhi ogba?”
\p 
\v 27 IPita ọ gbo lẹ, “Iiye!” Utoghuokpe, ọkpa ọ gbiẹghẹ.
\s1 A rue iJesu bhale odalo oyi iPaleti ya gue ẹzọ
\r (iMat 27.1-2,11-14; iMak 15.1-5; iLuk 23.1-5)
\p 
\v 28 Ẹlẹ uzogbe fiefie, e rue iJesu fiẹ owa oyi iKefasi je apfẹ oyi igọvunọ oyi ẹgbọ iRomu. Enighie eyi ẹgbọ iJu ẹa lama lo elemhi oni apfẹ, itobọ khi ẹa nono ni ichimhi umha-pfuasẹ ni o mu wẹ, ini ee dobẹ le eminale iPasova.
\v 29 Itobọ ighọ ọni igọvunọ na lu iPaleti ọ fiẹ je olase deba eni ẹgbọ iJu, ọọ wẹ, “Umha-guẹli onoghuo a gue shi ọmọse ọna egbe?”
\p 
\v 30 Ẹẹ ọli, “Ini ọa mhuẹ umha-guẹli lọ anye ẹa kha rue ọli bhale ghie.”
\p 
\v 31 IPaleti ọọ wẹ, “A rue ọli vu ya gue ẹzọ egbe-a abi ushi oyẹẹ o ngme shọ.”
\p Ẹgbọ iJu ẹẹ ọli, “Anye aa mhọli afu ni a rọ ọ liẹ a ka gbe ọgbọa.”
\v 32 Eri a lina mẹ onana ni emini iJesu ọ kpẹ ngme ni o bhale ya tsẹ, ikhi ungmemhi ni ọ la guele uwali eghuli ni lọli ya ghu.\f + \fr 18:32 \ft Li zẹ \fq iJọn 3.14; 12.32,33\f*
\p 
\v 33 IPaleti ọ nyenẹ egbe je elemhi apfẹ oyọli, ọ lu iJesu mhila, ọọ, “Yẹyẹ u khi oghie ọyi ẹgbọ iJu?”
\p 
\v 34 IJesu ọọ. “Udu oyẹ ogbọ ona ni u mhila mhẹ o te bhale abi khi ọgbọ ọ gue ingme oyẹmhẹ yẹ ẹ?”
\p 
\v 35 IPaleti ọọ li, “Ọnge iJu wẹ khi mhi khi? Ẹgbọ eyẹ ali ighie eyi ekpodalo-ugamhi e rue ẹ bhale ghi mhẹ, Elọ u li?”
\p 
\v 36 IJesu ọọ li, “Eghiele oyẹmhẹ ọa khi onayi agbọ ona. Ini ighọ o khi lọ, eni ẹ deba mhẹ e kha ye okhọli na mhẹ, ini a khi dobẹ mu mhẹ ghi eni ẹ mhẹsẹ eyi ẹgbọ iJu. Ama memena, eghiele oyẹmhẹ ọa khi onayi agbọ ona.”
\p 
\v 37 Ighọ iPaleti ọ mhila li, “Oghie u ti ẹ khi?”
\p IJesu ọọ, “U guẹ ga ngme ọli ni u rọ khi oghie mhi khi. Onana o zẹ khi a bia mhẹ bhale elemhi agbọ, ni mhi rọ ri emini o khi igẹsikia khasẹ ẹgbọ na agbọ. Ọni ọ da khi ọna igẹsikia ne, ọọ suọ oyẹmhẹ.”
\p 
\v 38 IPaleti ọ mhila li, “Elọ o khi igẹsikia?”
\s1 A pfa ẹzọ igbea mu iJesu
\r (iMat 27.15-31; iMak 15.6-20; iLuk 23.13-25)
\p Ighọ iPaleti ọ gbo fiẹ je olase, ọ gueyẹ ẹgbọ iJu, ọọ, “Mhi aa mẹ umha-guẹli shi ọli obọ ni o rẹmhẹ ya pfa ẹzọ mu ọli a gbe ọlia
\v 39 Ama, abi a li ini a da li ukpe iPasova khi, ukpe khi ukpe kpa, eri mhia rue ọgbọ ọghuo ẹgbọ eyẹ ẹ eni a mu shi owa ighumha abọ-a na ẹ. A nono ni mhi wolọ oghie iJu abọ a na ẹ?”
\p 
\v 40 Ighọ e tsẹsẹ gbii, ẹẹ ọli, “Iiye! Ri Ochoghọ rue iBarabasi obọ a na anye.” (IBarabasi iko ọ li, ọni ọ gbe ọgbọ a ọ khi ni a mu shi owa ighumha.)
\c 19
\s1 A pfa ẹzọ igbea mu iJesu
\r (iMat 27.15-31; iMak 15.6-20; iLuk 23.13-25)
\p 
\v 1 Ighọ iPaleti ọọ a gbe iJesu itali egbegbọ.
\v 2 Eni ekhọli-okhuẹ e nyanọ iguabọ ẹẹra igba riẹlẹ arula oghie rughu iJesu ukhomhi, e rue awulu ni o khi ẹgholi ni ọ li abi oyilẹ nabi a rọ ọ sọ oghie sọ ọli.
\v 3 E gbo bhale deba li, e rọ ọli li egia, e liẹ ọli, “A yasẹ obọ ekẹ na oghie ọyi iJu!” E lase ọli alo.
\p 
\v 4 IPaleti ọ ke gbo fiẹ je olase deba ẹgbọ iJu, ọọ, “A ghe ọli e, mhi rue ọli lasele na ẹ ni a rọ lẹsẹ khi mhi aa mẹ umha-guẹli shi ọli obọ ni o rẹ mhẹ ya liẹ a ka gbe ọli a.”
\v 5 Abi iJesu ọ rọ fiẹ lasele ni ọ rọ rughu arula igba, ọ gbo sọ awulu ẹgholi oyilẹ ni oghie ọ sọ, iPaleti ọọ, “A ghe ọni ọmọse!”
\p 
\v 6 Abi ighie eyi ekpodalo-ugamhi ali eni ẹ khẹ ekhẹ Owa oyi Ẹshinẹgba e rọ mẹ ọli, e tsẹsẹ, ẹẹ, “A ta li ma ọọra apfida! A ta li ma ọọra apfida!”
\p IPaleti ọọ, “Ẹẹ a rue ọli vu ya ta ma ọọra. Mhi aa mẹ umha-guẹli shi ọli obọ.”
\p 
\v 7 Ẹgbọ iJu ẹẹ ọli, “Anye mhuẹ ushi ni o guele a gbe ọlia, itobọ khi ọọ lu egbọli Omi Ẹshinẹgba.”
\p 
\v 8 Abi iPaleti ọ rọ suọ ona, ulishi o tigbe mema lolo mu ọli.
\v 9 Ọ nyenẹ egbe je elemhi apfẹ oyọli, ya mhila iJesu, “Ọnge obo u khi?”
\p Ama iJesu ọ tsaghiẹ ọli-a.
\v 10 IPaleti ọọ, “Wa ya mie mhẹ unu? Wa lẹsẹ khi mhi mhọli ekpabọ ni mhi rọ dobẹ ya pfa ẹ shi ekẹ, ali khi mhi gbo dobẹ ya liẹ a ka tẹ ma ọọra apfida gbe-a?”
\p 
\v 11 IJesu ọọ ọli, “Wa kha mhọli afu shi mhẹ idiegbe ini ọa khi Ẹshinẹgba o ri ọli nẹ lọ, ama ọgbọ ni ọ mu mhẹ bhale ghi ẹ, lọli ọ mhọli umha-guẹli oyi olamhẹ ni o fu nẹ.”
\p 
\v 12 Abi iPaleti ọ rọ suọ ona se, ọ nono odẹ ni ọ te ya wolọ iJesu abọ a, ama eni ẹgbọ iJu e kiele tsẹsẹ, e liẹ ọli, “Ini u zẹ ọli obọ, wa khi ọmọle iSiza oghie ọniẹmhi ọyi iRomu. Ọnini ọ da guele khi oghie lọli khi, ọbe iSiza ọ khi.”
\p 
\v 13 Abi iPaleti ọ rọ suọ ingmemhi ena, ọ rue iJesu je olase, iPaleti ọ ya shitọ ukpho ẹchẹ ni ọ shitọ la sọ ẹzọ, ni a lu Ẹtẹtẹ ẹchẹ (iGabata a ri ẹlẹmhi Iburu ẹẹ lu ọli)
\v 14 Ẹghẹghẹ aghọ ovọ o lẹsẹ ramhi iteteva ukhomhi ẹlẹghọ, ikhi ogbẹlẹ ni a mu egbe ẹ shi ukpe iPasova. IPaleti ọọ eni ẹgbọ iJu, “Oghie ọyẹẹ ghọ o!”
\p 
\v 15 Ama e tsẹsẹ, “A rue ọli ya gbe-a! A rue ọli ya gbe-a! A ta li ma ọọra apfida!”
\p IPaleti ọ mhila wẹ, ọọ, “A nono ni mhi ta oghie ọyẹ ẹ ma ọọra apfida?” Ighie eyi ekpodalo-ugamhi ẹẹ ọ li, “Anye aa mhọli oghie ọlese dọsẹ oghie iSiza.”
\p 
\v 16 Ighọ iPaleti ọ ri iJesu na ekhọli-okhuẹ e ka ta li ma ọọra apfida.
\s1 A ta iJesu ma ọọra apfida
\r (iMat 27.32-44; iMak 15.21-32; iLuk 23.26-43)
\p Rọ te aghọ vu ekhọli-okhuẹ e te rue iJesu vu.
\v 17 IJesu ọ fiẹ lasele, lọlighuo ọ tsua ọọra apfida oyọli, ọ je ashini a lu “Ukhomhi olimhi ni o ku igua-a.” (IGọgọta a ri ẹlẹmhi Iburu ẹ lu akaghọ.)
\v 18 Aghọ e tali ma ọọra apfida shi, e ta ẹgbọ aava ma ẹẹra mama li. Ọghuo epfẹ obita, ọnọkpọle epfẹ obọgobọ, iJesu ọ la wẹ iteva.
\v 19 IPaleti ọ kẹkẹ emhi rọ kphase oni ọọra-apfida. Emini ọ kẹkẹ shi ọ khi, “IJesu Ọnge iNazarẹti, Oghie ọyi Ẹgbọ IJu.”
\v 20 Ebubu eni ẹgbọ iJu e zẹ oni emhi, itobọ khi ashini a ta iJesu ma ọọra apfida shi ọa nuata shi apfẹ. Ẹlẹmhi Iburu, ghe iLatini ali iGiriki a rọ kẹkẹ oni emini a rọ kphase ọọra apfida ni a ta iJesu ma.
\v 21 Ighie eyi ekpodalo-ugamhi eyi ẹgbọ iJu ẹa lama shi emini iPaleti ọ kẹkẹ. E ya gueyẹ ọli, ẹẹ ọli, “Anye ẹa nono ni u kẹkẹ oghie ọyi iJu shi ọ, emini u kha kẹkẹ shi ọ khi, Oghie ọyi ẹgbọ iJu ọmọse ọna ọ khi lọli khi.”
\p 
\v 22 IPaleti ọọ wẹ, “Mhi she kẹkẹ emini mhi kẹkẹ.”
\p 
\v 23 Abi eni ekhọli-okhuẹ e rọ ta iJesu ma ọọra apfida se, e wolọ ide eyọli kemhi shi asha ene. Ọgbọgbọ ọ rue asha eghuo ọ, e gbo rue awulu oyọli ni a do ni aa rọte ashikhọghuo gbẹla toma.
\p 
\v 24 Eni ekhọli-okhuẹ e gueyẹ egbe wẹ, “Awa khi nyanọ li-a, awa ti ebe shi ọ, ni awa mẹ ọni o ya mu, ni ọ rue ọli.” Eri a mẹ onana ni emini a kẹkẹ shi Ebe-no-pfuasẹ o bhale ya tsẹ, ni ọọ, “E kemhi ide eyẹmhẹ, e gbo ti ebe shi awulu oyẹmhẹ.”
\p 
\v 25 Inyọ iJesu, ali inyọghuo inyọli nọkpotso, ali iMeli ughuẹ iKilopasi, ali iMeli ọnge iMagidaleni e migha mama oni ọọra apfida ni a ta iJesu ma.
\v 26 IJesu ọ mẹ inyọli ali ọmọ odukhokho ọyọli ni ọ nono ingme oyọli, khi ọ migha epfẹ aghọ, iJesu ọọ, “Inyọ! Omi-ẹ ghọ.”
\p 
\v 27 Ọ gueyẹ ọni ọmọ odukhokho, ọọ li, “Inyẹ ghọ.” Rọ te aghọ vu ọni ọmọ odukhokho ọ te rue ọni inyọ iJesu je apfẹ ni ọ te nu ọ la.
\s1 Eghuli ni iJesu ọ ghu
\r (iMat 27.45-56; iMak 15.33-41; iLuk 23.44-49)
\p 
\v 28 IJesu ọ lẹsẹ khi emhikpa e she zẹ ukhomhi, ọọ, “Okiamẹ ọa gbe mhẹ.” Onana o ri emini a kẹkẹ shi Ebe-no-pfuasẹ bhale ya tsẹ.\f + \fr 19:28 \ft Li zẹ \fq Iwolo 69.21; 22.15\f*
\v 29 Ubene ni o vọ onyọ ni o khẹ-a o la epfẹ aghọ, e sọ isoso\f + \fr 19:29 \fk isoso \ft ẹgbọ eghuo ẹ lu isoso ukodo.\f* elemhi oni onyọ e rọ oni isoso kphase ukpokpo oyi ọọra ni a lu isopu ni o nuẹ, e nise ọli je iJesu unu.
\v 30 Abi iJesu ọ rọ to unu oni onyọ, ọ, “O she pfo.”
\p Ọ dọ ukhomhi gbe, ọ ghua.
\p 
\v 31 Ekhẹmhuẹ eyi ẹgbọ iJu e vu ya mhila iPaleti ọ zẹ ni wẹwẹ e ya pfi emhi shi awẹ eyi emọse ni a ta ma ẹẹra apfida guọghọ-a. Ali ni wẹwẹ e taghiẹ wẹ te eni ẹẹra apfida tiemhile. Emini o zẹ ni e rọ lighọ mhila khi, ẹlẹghọ khi ogbẹlẹ ni ala mu egbe khẹ ogbẹlẹ iyẹmhẹa oyi ẹgbọ iJu. Eri ẹa nono ni e la ikhomhi ẹẹra apfida ramhi ogbẹlẹ iyẹmhẹa, itobọ khi oni ogbẹlẹ iyẹmhẹa oghọ, ogbẹlẹ ipfuasẹ na kẹ o khi.
\v 32 Eni ekhọli-okhuẹ e vu ya pfi emhi shi ọgbọ ọni ododẹ ni a ta ma ọọra apfida mama iJesu awẹ guọghọ a. E gbo lighọ ya guọghọ eyi ọni o kpọle a.
\v 33 Ama abi e rọ ramhi ayi iJesu, e bhale ya ẹ khi ọ she ghua, itobọ ighọ ẹa ke pfi emhi shi iJesu awẹ guọghọ a.
\v 34 Ọghuo eni ekhọli-okhuẹ ọ sọ iJesu ọgbhọrọ epfẹ, utoghuokpe, ọlia ali amẹ e te ọli egbe ku lasele.
\v 35 Ọgbọ ni ọ ri ẹloe mẹ ona ọ pfi ọtsẹlẹ shi ọ, ọtsẹlẹ ni ọ pfi o khi igẹsikia itobọ khi ọ lẹsẹ gboo khi igẹsikia ona o khi. Eri ọ pfi ọtsẹlẹ ona ni a khi eni e miesuọ.
\v 36 Onana o ri emini a kpẹ kẹkẹ shi Ebe-no-pfuasẹ bhale ya tsẹ, ni o guele khi, “Ọgbọkhọghuo ọa ya khi ugua shi ọli idiegbe.”\f + \fr 19:36 \ft Li zẹ \fq Okiali 12.46; iNọba 9.12; Iwolo 34.20\f*
\v 37 Ebe-no-pfuasẹ o gbo ngme ghọ shi asha olese khi, “E ya ke bino ọni e ya to ọgbhọrọ gbese a.”\f + \fr 19:37 \ft Li zẹ \fq iZaka 12.10\f*
\s1 Irọtọ oyi iJesu
\r (iMat 27.57-61; iMak 15.42-47; iLuk 23.50-56)
\p 
\v 38 Abi a rọ mẹ ona se, iJosẹfu ọnge Arimatia, ni ọ khili ọtuọghuo eniyẹ odukhokho ni e bẹna e deba iJesu itobọ khi ọ na ulishi oyi ekhẹmhuẹ eyi ẹgbọ iJu, ọ lẹ ya mhila iPaleti olimhi oyi iJesu. IPaleti ọ lama na li ọ rue olimhi oyi iJesu ya rọ tọ. Ighọ iJosẹfu ọ bhale ya rue ọli vu.
\v 39 INikodemọsi ni ọ ke ya mẹ iJesu ẹlẹ iyọsẹ ọ kphase iJosẹfu. Ọ tsua ikhumhi ni a rọ ọ to olimhi egbe ini ọ khi kẹlẹ kẹa. Eni ikhumhi e bu ramhi akpulu ikoko oghuo. Ọ gbo tsua ituale ni ẹ pfie mhuẹ.\f + \fr 19:39 \ft Li zẹ \fq iJọn 3.1-2\f*
\v 40 Eni emọse aava e tsua olimhi ọyi iJesu, e ri ide epfopfo gẹnọ ọli. Abi e li i gẹnọ ọni olimhi, ighọ e pfi ituale shi ọli egbe, ni e ri ikhumhi na rọ ọ shi olimhi egbe ma ọ, abi ẹgbọ iJu e liẹ mu olimhi egbe shi irọtọ, abi ushi oyẹwẹ o ngme.
\v 41 Ukuku ogba o la ashini a ta iJesu ma ọọra apfida shi, uji ona ufuegbhẹ onogbọ ni aa ri ọgbọ tọ ghue o li la aghọ.
\v 42 Itobọ khi ẹlẹghọ o khi ogbẹlẹ ni a rọ mu egbe ẹ shi ekẹ khẹ ogbẹlẹ iyẹmhẹa oyi ẹgbọ iJu, ali khi oni uji na ufuegbhẹ o ti mama wẹ, e ri olimhi oyi iJesu yẹshi aghọ.
\c 20
\s1 IJesu ọ rọte eghuli guale
\r (iMat 28.1-8; iMak 16.1-8; iLuk 24.1-12)
\p 
\v 1 Ẹlẹ uzogbe fiefie ẹlẹ ni ọọ deba ogbẹlẹ iyẹmhẹa oyi ẹgbọ iJu, obili o kie la ogbe. IMeli ọnge iMagidaleni ọ̀ je uji ashini a ri iJesu yẹshi, ọ bhale ya ẹ khi a she gheghele ẹchẹ unu oni uji-a.
\v 2 Ighọ ọ sọ awẹ unamhi na je ayi iSamọ iPita ali ọmọ odukhokho ọghọ ni iJesu ọ nono ingme oyọli, ọ gueyẹ wẹ, ọọ, “E tsua olimhi oyi Ọnọmhuẹ elemhi uji ufuegbhẹ a! Anye aa lẹsẹ obini e tsua li je.”
\p 
\v 3 Ighọ iPita ali ọni ọmọ odukhokho ọghọ e vu ya je oni uji ufuegbhẹ.
\v 4 Wẹwẹ aava ee na, ama ọni ọmọ odukhokho ọghọ ọ na dọsẹ iPita, ọ kpẹ ramhi oni uji ufuegbhẹ khẹ iPita.
\v 5 Ọ nyẹsẹ egbe bino elemhi oni uji ufuegbhẹ, ama ọa lo elemhi ọ. Ọ mẹ ide ni a kpẹ rọ khuli idiegbe oyi iJesu.
\v 6 Ighọ iSamọ iPita ni ọ kpukhokho ramhi aghọ ọ dọsẹ ya lo elemhi oni uji ufuegbhẹ. Ọ mẹ eni ide khi e la elemhi uji ufuegbhẹ.
\v 7 Ode olimhi ni a rọ gẹ iJesu ukhomhi o li la aghọ. Oni ode o khili shi ashaọda shi ide enekpọle ọ. O kie khili shi aghọ abi a kie kpẹ li rọli khili olimhi oyi iJesu, ọa taghiẹ a.
\v 8 Ighọ ọni ọmọ odukhokho ọghọ ni ọ kpẹ ramhi oni uji, ọ li lo elemhi ọli, ọ ri ẹloe mẹ, ọ miesuọ.
\v 9 Oni ẹghẹghẹ ẹa kie lẹsẹ emini a kẹkẹ shi ebe khi iJesu ọ ya te eghuli guale.
\v 10 Ighọ eni eniyẹ odukhokho e nyenẹ egbe je apfẹ.
\s1 IJesu ọ ri egbọli khasẹ iMeli ọnge iMagidaleni
\r (iMat 28.9-10; iMak 16.9-11)
\p 
\v 11 IMeli ọ migha olase oni uji ufuegbhẹ ọọ viẹ. Abi ọ li kie le viẹ, ọ nyẹsẹ egbe bino elemhi oni uji ufuegbhẹ.
\v 12 Ọ mẹ khi igẹni aava ni e sọ itsua epfopfo e shitọ elemhi oni uji ufuegbhẹ ni a ri olimhi oyi iJesu yẹshi. Ọghuo ọ shitọ obini iJesu ọ kpẹ ri ukhomhi shi, ọni ọ kpọle ọ shitọ obini ọ kpẹ ri awẹ shi.
\p 
\v 13 Ẹ mhila li, ẹẹ ọli, “Nọ kpotso, elọ u viẹ ẹ shi?” Ọọ wẹ, “E she tsua Ọnọmhuẹ ọyẹmhẹ vu, mhi aa lẹsẹ obini e rọli shi.”
\p 
\v 14 Ighọ ọ nyenẹ egbe ọ mẹ khi iJesu ọ migha aghọ, ama ọa lẹsẹ khi iJesu lọ.
\v 15 IJesu ọ mhila li, ọọ li, “Nọ kpotso elọ u viẹ ẹ shi, ọghuo wa nono?”
\p IMeli ọ dabi khi ọni ọ riẹlẹ shi oni ogba ni o la aghọ lọ, ọ, “Ọga ini yẹyẹ u tsua li vu kpẹkpẹ gueyẹ mhẹ obini u rọli shi ni mhi je aghọ ya tsua li.”
\p 
\v 16 IJesu ọ li, “Meli.” Ọ sọ alo ghue ọli, ọ tsẹsẹ leghe ri ẹlẹmhi oyi ẹgbọ iJu yemhẹ ọli, ọọ, “Raboni!” Ọsẹsẹ a ri ona ngme ẹlẹmhi Iburu.
\p 
\v 17 IJesu ọ gueyẹ ọli, “Khi mu mhẹ mhuẹ, itobọ khi mhi aa nyenẹ egbe je oyi Ita ne. Ama ka gueyẹ inyọghuo-mhẹ khi mhi ya nyenẹ egbe je oyi Itamhẹ ni ọ li khi Ita wẹ, ali Ẹshinẹgba ọyẹmhẹ ni ọ li khi Ẹshinẹgba ọyẹwẹ.”
\p 
\v 18 Ighọ iMeli ọnge iMagidaleni ọ vu ya gueyẹ eniyẹ odukhokho khi lọli mẹ iJesu Ọnọmhuẹ. Ọ gueyẹ wẹ ingme ni Ọnọmhuẹ ọ gueyẹ ọli.
\s1 IJesu ọ ri egbọli khasẹ eniyẹ odukhokho eyọli
\r (iMat 28.16-20; iMak 16.14-18; iLuk 24.36-49)
\p 
\v 19 Abi ogbọmhi o rọ mu ekẹ ẹlẹghọ ni o khi ogbeakọlọ oyi ẹlẹ iyẹmhẹa oyi ẹgbọ iJu, ni o khi ẹlẹ ni ododẹ elemhi ẹfo uka, eniyẹ odukhokho eyọli e le gba elemhi owa, e sọnọ okpẹ odẹ itobọ khi ee na ulishi oyi ẹgbọ iJu eni ẹẹ mhẹsẹ. Udemhija, iJesu ọ bhale ya migha wẹ iteva bia, ọọ, “Opfọmhẹ o ka nu ẹ la.”
\v 20 Abi ọ rọ ngme ona se, ọ ri abọ ali epfẹ khasẹ wẹ. Oghẹlẹ o vọ wẹ elemhi shi abi e li mẹ Ọnọmhuẹ.
\v 21 IJesu ọ gbo liẹ wẹ, “Opfọmhẹ o ka nu ẹ la. Abi Ita ọ li ghie mhẹ mhi li liẹ ghie ẹ.”
\v 22 Ighọ ọ yẹmhẹ ku wẹ, ọọ, “A mie Ayẹmhẹ-nọ-pfuasẹ,
\v 23 Ọgbọ ni a da gbe olamhẹ kua na, a she gbe kua na li, ama ini aa da gbe kua na wẹ ne, aa gbe kua na wẹ.”\f + \fr 20:23 \ft Li zẹ \fq iMat 16.19; 18.18\f*
\s1 IJesu ọ ri egbọli khasẹ iTọmọsi
\p 
\v 24 Otu ọghuo elemhi eni eniyẹ odukhokho ogbava ni a lu iTọmọsi ni a gbolo ẹẹ lu itsema, ọa nu wẹ la aghọ ni iJesu ọ rọ bhale wẹ iteva.
\v 25 Eniyẹ odukhokho eni e kpọle e gueyẹ ọli, ẹ ọ li, “Anye mẹ Ọnọmhuẹ!”
\p ITọmọsi ọọ, “Ini mhi aa li mẹ ẹmẹli ni o la ashini a te ta itse shi ọli abọ ni mhi ri umiesobọ oyẹmhẹ ti ọli, ni mhi aa rọ ri obọ shiọ oni o la li epfẹ, mhi aa ya miesuọ khi ọ she guale.”
\p 
\v 26 Abi o rọ gbe utui, eniyẹ odukhokho eyọli e gbo lona elemhi owa, iTọmọsi ọ nu wẹ la aghọ, e sọ okpẹ odẹ. Udemhija iJesu ọ gbo bhale ya migha wẹ iteva bia, ọọ wẹ, “Opfọmhẹ o ka nu ẹ la.”
\v 27 Ọ gueyẹ iTọmọsi, ọọ li, “Ri umiesobọ ti ana, bino mhẹ abọ, gbo nise obọ ti mhẹ epfẹ. Khi ke mhọli akhọkhọmhẹ, miesuọ!”
\p 
\v 28 ITọmọsi ọ li, “Ọnọmhuẹ ọyẹmhẹ, ali Ẹshinẹgba ọyẹ mhẹ!”
\p 
\v 29 IJesu ọọ li, “Itobọ khi u mẹ mhẹ u rọ miesuọ? Ikhivọsẹ o khi na eni ẹa mẹ mhẹ ne ni e miesuọ.”
\s1 Emini o zẹ ni a rọ kẹkẹ ebe ona
\p 
\v 30 IJesu ọ la ukpẹloe oyi eniyẹ odukhokho eyọli gbe ikanya ọnyaloa ni e bububu elese ni ọgbọ ọa kẹkẹ shi ebe ona.
\v 31 Ama eri a kẹkẹ ena shi ebe ini a miesuọ khi iJesu khi iKirisiti, ikhi Ọmiepfuese Omi Ẹshinẹgba, ali, ini a mhọli irudunga, a ya mhọli agbọ itobọ eva oyọli.
\c 21
\s1 IJesu ọ ri egbọli khasẹ eniyẹ odukhokho eyọli etuoshilua
\p 
\v 1 Abi a rọ mẹ ingme ena se, iJesu ọ gbo ri egbe ọli khasẹ eniyẹ odukhokho eyọli, epfẹ okẹ oniẹmhi ni a lu iGalili. Ina a li mẹ ọli.
\v 2 ISamọ iPita, ali iTọmọsi na lu itsema, ali iNataniẹli ọnge iKena na ekẹ iGalili, ghe IJọni ali iJemhisi imi iZebedi, ali eniyẹ odukhokho eyi iJesu aava elese e ga legba asheghuo nya.
\v 3 ISamọ iPita ọọ, “Mhia vu ya mu ifẹlẹ.”\f + \fr 21:3 \ft Li zẹ \fq iLuk 5.5\f*
\p Ẹẹ ọli, “Anye ya deba ẹ ye.” Ighọ e lo elemhi ọkọ-okẹ oniẹmhi oni ikeke. Ama ẹliyọsẹ ẹlẹghọ nya, ẹa mu emhikhọghuo.
\v 4 Ẹlẹ uzogbe fiefie, iJesu ọ migha egele oyi okẹ oniẹmhi, ama wẹwẹ ẹa lẹsẹ khi iJesu ọ nu wẹ ngme.
\v 5 IJesu ọ mhila wẹ, ọọ, “Emọle mhẹ, aa kie mẹ afẹlẹ ọkhọghuo mu?”
\p Ẹẹ ọli, “Anye ẹa mẹ emhikhọghuo mu.”
\p 
\v 6 Ọọ wẹ, “Pfi aga oyẹ je epfẹ obita oyi ọkọ-okẹ oniẹmhi khi a ya mẹ ifẹlẹ mu.” Ighọ e pfi aga je obini ọ ngme, ẹa ke dobẹ ti oni aga lọ elemhi oni ọkọ-okẹ oniẹmhi itobọ khi o she mu ifẹlẹ ni e bu.\f + \fr 21:6 \ft Li zẹ \fq iLuk 5.6\f*
\p 
\v 7 Ighọ ọni ọmọ odukhokho ni iJesu ọ nono ingme oyọli, ọ́ ọ̀ iPita, “Ọnọmhuẹ lọ!” Abi iSamọ iPita ọ suọ khi Ọnọmhuẹ lọ ni ọ nu wẹ ngme lẹna, ọ nyanya rọ itsua sọ (itobọ khi eri ọ kpẹ taghiẹ ide eghuo egbe-a), ọ ji pfilo elemhi amẹ.
\v 8 Eniyẹ odukhokho eni e kpọle e gua oni ọkọ-okẹ oniẹmhi bhale esọ okẹ, e e ti oni aga bhale epfẹ egele. Ekẹkhẹ ọa ke lolo nuẹ shi wẹ ọ, emhi nabi ẹtẹ-awẹ egbhuẹshe o ke rọte aghọ khi.
\v 9 Abi e rọ ramhi egele, e mẹ ingamhi erali aghọ, a ri afẹlẹ tọ ọ, ibulẹdi e li nga ọ.
\p 
\v 10 IJesu ọọ wẹ, “A rọte ifẹlẹ ni a mu lẹna rue bhale.”
\p 
\v 11 IPita ọ nga egele le, ọ ya tialọ oni aga ni o vọ ifẹlẹ enieniẹmhi ngale egele, eni ifẹlẹ e kugbe khi egbhuẹshilua ali igbẹsẹ. Abi eni ifẹlẹ e riẹ lighọ bu, oni aga ọa nyanọ a.
\v 12 IJesu ọọ wẹ, “A bhale ya le emhi.” Ọgbọkhọghuo eni eniyẹ odukhokho ọa mhila li, “Ọghuo u khi?” Itobọ khi e lẹsẹ khi Ọnọmhuẹ lọ.
\v 13 Ighọ iJesu ọ ya rue oni ibulẹdi kemhi na wẹ, ọ gbo kemhi oni afẹlẹ na wẹ.
\p 
\v 14 Onana o khi utonuzi-esẹ ni iJesu ọ ri egbọli yaa khasẹ eniyẹ odukhokho eyọli abi ọ te rọte eghuli guale.
\s1 IJesu ọ nu iPita ngme
\p 
\v 15 Abi e rọ le se, iJesu ọọ iSamọ iPita, “Samọ omi iJọni! U fẹ nono ingme oyẹmhẹ dọsẹ emhi enana nya?”
\p IPita ọ sọ li ọ, ọ Ii, “Ọnọmhuẹ, u lẹsẹ khi mhi nono ingme oyẹ.”
\p IJesu ọọ, “Ri eminale na imi isumha eyẹmhẹ le.”
\p 
\v 16 Utonuzeva, iJesu ọọ li, “Samọ omi iJọni, u fẹ nono ingme oyẹmhẹ?”
\p IPita ọọ Ii, “Guẹguẹguẹ Ọnọmhuẹ, U lẹsẹ khi mhi nono ingme oyẹ.”
\p IJesu ọọ, “Ri eminale na isumha eyẹmhẹ le.”
\p 
\v 17 Utonuzesẹ iJesu ọọ li, “Samọ omi iJọni, u fẹ nono ingme oyẹmhẹ?”
\p Oni ingme o to iPita egbe, itobọ khi iJesu ọ mhila li itesẹ, “U fẹ nono ingme oyẹmhẹ?” Ighọ iPita ọ sọ li ọ, ọ, “Ọnọmhuẹ, u lẹsẹ emhikpa, u lẹsẹ khi mhi nono ingme oyẹ.”
\p IJesu ọọ li, “Rọ ẹloe khu isumha eyẹmhẹ.”
\v 18 IJesu ọọ, “Igẹsikia mhi gue yẹ khi, abi u rọ khi ozele, eri u ri itsua sọ u fiẹ je obini o ghọle ẹ, ama ini u womhẹ, ọgbọẹse ọ ke ya ri itsua ke sọ ẹ, ọ mu ẹ obọ je obini ọa ghọle ẹ ni u je.”
\v 19 Eri iJesu ọ ngme ona ni ọ rọkhasẹ abi iPita ọ li ya ghua ni o ya rọ ufumhi ghi Ẹshinẹgba. Ighọ ọọ iPita, “Ke deba mhẹ.”
\p 
\v 20 IPita ọ nyenẹ egbe, ọ mẹ ọni ọmọ odukhokho ni iJesu ọ nono ingme oyọli, ọni ọ shitọ mama iJesu abi e rọ nu iJesu le eminale ni o kpukhokho khi ọọ deba wẹwẹ. Lọli ọọ ke mhila iJesu ogbọ ni ọọ, “Ọnọmhuẹ, ọghuo ọ ya rẹ dẹ?”
\v 21 Abi iPita ọ rọ mẹ ọli, ọ mhila iJesu, ọọ, “Sẹ ẹgbọ na agbọ e fẹ ya li ọni ọmọse ọna?”
\p 
\v 22 IJesu sọ li ọ, ọ, “Ini mhia nono ni ọ la agbọ ramhi ni mhi rọ ya gbo nyenẹ egbe bhale agbọ, onoghuo o khi oyẹ shi ọ? Ke deba mhẹ.”
\p 
\v 23 Ona o zẹ ni e rọ bẹna ngme ọli iteva oyi eniyẹ odukhokho eyi iJesu, khi ọni ọmọ odukhokho ọna ọa ya ghu ghue. Ama iJesu ọa liẹ khi ọa ya ghu ghue. Eri ọ́ lẹsẹ liẹ, “Ini mhia nono ni ọ la agbọ ramhi ni mhi rọ ya gbo mu egbe nyenẹ bhale, onoghuo o khi oyẹ shi ọ?”
\s1 Ungmemhi ni o kpukhokho
\p 
\v 24 Lọli khi ọmọ odukhokho ni ọ pfi ọtsẹlẹ shi eni ingmemhi ena, lọli ọ gbo kẹkẹ wẹ shi ebe. Awa gbo lẹsẹ khi emini ọ ngme khi igẹsikia lọ.
\p 
\v 25 Ikanya ebubu e laọ ni iJesu ọ gbe. Ini ẹẹ a kẹkẹ wẹ nya ukpamhi oghuo-oghuo lọ, mhi sa khi agbọ ona nya ọa kha luẹsẹ ebe ni a kha kẹkẹ wẹ shi.
