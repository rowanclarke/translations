\v 44 \w y|strong="H1571"\w* me conteste: \w Bebe|strong="H8354"\w* tú \w mismo|strong="H1931"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w sacaré|strong="H7579"\w* para tus \w camellos|strong="H1581"\w*, sea \w ésta|strong="H1931"\w* \w la|strong="H1931"\w* esposa \w que|strong="H1931"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w destinó|strong="H3198"\w* para \w el|strong="H1931"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* mi \tl ʼadón\tl*.   
\p
\v 45 \w Antes|strong="H2962"\w* \w que|strong="H4994"\w* \w yo|strong="H2009"\w* acabara \w de|strong="H5921"\w* \w hablar|strong="H1696"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w corazón|strong="H3820"\w*, ahí \w estaba|strong="H2009"\w* \w Rebeca|strong="H7259"\w* \w con|strong="H5921"\w* su \w cántaro|strong="H3537"\w* \w al|strong="H5921"\w* \w hombro|strong="H7926"\w* quien bajaba \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w fuente|strong="H5869"\w*. Cuando \w sacó|strong="H3318"\w* agua \w le|strong="H5921"\w* \w dije|strong="H1696"\w*: \w Te|strong="H5869"\w* \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* \w me|strong="H5921"\w* des \w de|strong="H5921"\w* \w beber|strong="H8248"\w*.   
\p
\v 46 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* apresuró, bajó su \w cántaro|strong="H3537"\w* \w de|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w ella|strong="H5921"\w* \w y|strong="H1571"\w* respondió: \w Bebe|strong="H8354"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* abrevaré tus \w camellos|strong="H1581"\w*. \w Y|strong="H3068"\w* \w bebí|strong="H8354"\w*, \w y|strong="H1571"\w* \w ella|strong="H5921"\w* abrevó \w los|strong="H5921"\w* \w camellos|strong="H1581"\w*.   
\p
\v 47 \w Le|strong="H5921"\w* \w pregunté|strong="H7592"\w*: ¿\w De|strong="H5921"\w* \w quién|strong="H4310"\w* eres \w hija|strong="H1323"\w*? \w Y|strong="H3068"\w* respondió: Soy \w hija|strong="H1323"\w* \w de|strong="H5921"\w* Betuel, \w el|strong="H5921"\w* \w hijo|strong="H1121"\w* \w que|strong="H4310"\w* \w Milca|strong="H4435"\w* \w le|strong="H5921"\w* \w dio|strong="H7760"\w* \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Nacor. Entonces \w le|strong="H5921"\w* \w puse|strong="H7760"\w* \w el|strong="H5921"\w* pendiente \w en|strong="H5921"\w* \w la|strong="H5921"\w* nariz \w y|strong="H5921"\w* \w los|strong="H1121"\w* \w brazaletes|strong="H6781"\w* \w en|strong="H5921"\w* sus \w manos|strong="H3027"\w*.   
\p
\v 48 \w E|strong="H3068"\w* hice reverencia, me postré ante \nd \+w Yavé|strong="H3068"\+w*\nd*. \w Bendije|strong="H1288"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*, ʼElohim\nd* \w de|strong="H1121"\w* mi \tl ʼadón\tl* Abraham, Quien me condujo \w por|strong="H1870"\w* \w camino|strong="H1870"\w* recto \w a|strong="H3068"\w* fin \w de|strong="H1121"\w* \w tomar|strong="H3947"\w* \w a|strong="H3068"\w* la \w hija|strong="H1323"\w* del hermano \w de|strong="H1121"\w* mi \tl ʼadón\tl* para su \w hijo|strong="H1121"\w*.  
\v 49 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w si|strong="H3808"\w* ustedes \w hacen|strong="H6213"\w* \w misericordia|strong="H2617"\w* \w y|strong="H5921"\w* verdad \w con|strong="H5921"\w* \w mi|strong="H5921"\w* \tl ʼadón\tl*, declárenmelo. \w Y|strong="H3068"\w* \w si|strong="H3808"\w* \w no|strong="H3808"\w*, declárenmelo también, \w y|strong="H5921"\w* \w me|strong="H5921"\w* encaminaré \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w derecha|strong="H3225"\w* \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w izquierda|strong="H8040"\w*.   
\p
\v 50 \w Y|strong="H3068"\w* al \w responder|strong="H6030"\w* \w Labán|strong="H3837"\w* y Betuel, \w dijeron|strong="H1697"\w*: \w De|strong="H1697"\w* parte \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w salió|strong="H3318"\w* \w esto|strong="H1697"\w*. \w No|strong="H3808"\w* \w podemos|strong="H3201"\w* decirte \w algo|strong="H1697"\w* \w malo|strong="H7451"\w* \w o|strong="H3068"\w* \w bueno|strong="H2896"\w*.  
\v 51 Ahí \w está|strong="H1961"\w* \w Rebeca|strong="H7259"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti. \w Tómala|strong="H3947"\w* y \w vete|strong="H3212"\w*, y \w sea|strong="H1961"\w* la esposa del \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* tu \tl ʼadón\tl*, \w como|strong="H1961"\w* lo \w dijo|strong="H1696"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 52 \w Cuando|strong="H1961"\w* el esclavo \w de|strong="H1697"\w* Abraham \w oyó|strong="H8085"\w* sus \w palabras|strong="H1697"\w*, \w se|strong="H1961"\w* postró en tierra delante \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 53 Después el esclavo \w sacó|strong="H3318"\w* \w alhajas|strong="H3627"\w* \w de|strong="H5414"\w* \w plata|strong="H3701"\w*, objetos \w de|strong="H5414"\w* \w oro|strong="H2091"\w* y ropa, y se los \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w*. \w También|strong="H3318"\w* \w dio|strong="H5414"\w* valiosos regalos \w a|strong="H3068"\w* su hermano y \w a|strong="H3068"\w* su madre.  
\v 54 Después comieron y \w bebieron|strong="H8354"\w*, \w él|strong="H1931"\w* y \w los|strong="H5973"\w* \w que|strong="H1931"\w* \w lo|strong="H1931"\w* acompañaban, y pasaron \w la|strong="H1931"\w* noche.  
\p Al \w levantarse|strong="H6965"\w* \w de|strong="H5973"\w* \w mañana|strong="H1242"\w*, dijo: Envíenme \w a|strong="H3068"\w* mi \tl ʼadón\tl*.   
\p
\v 55 \w Entonces|strong="H3117"\w* \w el|strong="H3427"\w* hermano de ella y su madre respondieron: Permanezca la doncella con nosotros algunos \w días|strong="H3117"\w*, por lo menos diez, y \w después|strong="H3427"\w* se \w irá|strong="H3212"\w*.   
\p
\v 56 Pero él les dijo: \w No|strong="H1870"\w* me retrasen ya que \nd \+w Yavé|strong="H3068"\+w*\nd* hizo \w prosperar|strong="H6743"\w* mi \w camino|strong="H1870"\w*. Despáchenme para que me \w vaya|strong="H3212"\w* \w a|strong="H3068"\w* mi \tl ʼadón\tl*.   
\p
\v 57 \w Y|strong="H3068"\w* ellos contestaron: \w Llamemos|strong="H7121"\w* \w a|strong="H3068"\w* la joven y preguntémosle cuál es su \w deseo|strong="H7592"\w*.  
\v 58 \w Llamaron|strong="H7121"\w* \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w* y \w le|strong="H5973"\w* dijeron: ¿\w Irás|strong="H3212"\w* tú \w con|strong="H5973"\w* \w este|strong="H2088"\w* varón?  
\p \w Y|strong="H3068"\w* ella respondió: \w Iré|strong="H3212"\w*.   
\p
\v 59 Entonces despidieron \w a|strong="H3068"\w* su hermana \w Rebeca|strong="H7259"\w*, \w a|strong="H3068"\w* su madre de crianza, al esclavo de Abraham y \w a|strong="H3068"\w* sus hombres.  
\v 60 \w Bendijeron|strong="H1288"\w* \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w* y le dijeron:  
\q1 ¡Hermana nuestra, \w sé|strong="H1961"\w* madre de miles de millares  
\q1 y \w que|strong="H1961"\w* tus descendientes \w posean|strong="H3423"\w* la \w puerta|strong="H8179"\w* de sus \w enemigos|strong="H8130"\w*!   
\p
\v 61 \w Rebeca|strong="H7259"\w* \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w con|strong="H5921"\w* sus \w doncellas|strong="H5291"\w*, montaron \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w camellos|strong="H1581"\w* \w y|strong="H5921"\w* siguieron \w al|strong="H5921"\w* hombre. \w Y|strong="H3068"\w* \w el|strong="H5921"\w* esclavo \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w* \w y|strong="H5921"\w* \w salió|strong="H3212"\w*.   
\p
\v 62 Mientras tanto, \w Isaac|strong="H3327"\w* regresaba del pozo del Viviente-que-me-ve, \w pues|strong="H1931"\w* \w él|strong="H1931"\w* \w habitaba|strong="H3427"\w* en \w la|strong="H1931"\w* región del Neguev.  
\v 63 \w Isaac|strong="H3327"\w* había \w salido|strong="H3318"\w* \w a|strong="H3068"\w* meditar al \w campo|strong="H7704"\w* al llegar la \w tarde|strong="H6153"\w*. Cuando \w levantó|strong="H5375"\w* sus \w ojos|strong="H5869"\w*, \w miró|strong="H7200"\w* y ahí llegaban unos \w camellos|strong="H1581"\w*.   
\p
\v 64 \w Rebeca|strong="H7259"\w* también \w levantó|strong="H5375"\w* sus \w ojos|strong="H5869"\w*, \w y|strong="H5921"\w* cuando \w vio|strong="H7200"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*, desmontó \w del|strong="H5921"\w* \w camello|strong="H1581"\w*,  
\v 65 porque había preguntado al esclavo: ¿\w Quién|strong="H4310"\w* \w es|strong="H1931"\w* \w ese|strong="H1931"\w* varón \w que|strong="H4310"\w* \w viene|strong="H1980"\w* por \w el|strong="H1931"\w* \w campo|strong="H7704"\w* \w a|strong="H3068"\w* nuestro encuentro?  
\p \w El|strong="H1931"\w* esclavo respondió: \w Es|strong="H1931"\w* mi \tl ʼadón\tl*.  
\p Entonces \w ella|strong="H1931"\w* \w tomó|strong="H3947"\w* \w el|strong="H1931"\w* velo y \w se|strong="H1931"\w* \w cubrió|strong="H3680"\w*.   
\p
\v 66 \w El|strong="H3605"\w* esclavo le \w contó|strong="H5608"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w* \w todas|strong="H3605"\w* las \w cosas|strong="H1697"\w* \w que|strong="H1697"\w* \w hizo|strong="H6213"\w*.  
\v 67 \w Isaac|strong="H3327"\w* la introdujo en la tienda de su madre \w Sara|strong="H8283"\w*, \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w* \w como|strong="H1961"\w* esposa y la amó. \w E|strong="H3068"\w* \w Isaac|strong="H3327"\w* \w se|strong="H1961"\w* consoló \w después|strong="H1961"\w* de \add la muerte de\add* su madre.   
\c 25  
\s1 Hijos de Abraham y Cetura  
\p
\v 1 Abraham \w tomó|strong="H3947"\w* otra esposa, cuyo \w nombre|strong="H8034"\w* era Cetura,  
\v 2 la cual le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Zimram, \w Jocsán|strong="H3370"\w*, \w Medán|strong="H4091"\w*, \w Madián|strong="H4080"\w*, \w Isbac|strong="H3435"\w* y Súa.  
\v 3 \w Jocsán|strong="H3370"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Seba|strong="H7614"\w* y \w a|strong="H3068"\w* \w Dedán|strong="H1719"\w*. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Dedán|strong="H1719"\w* \w fueron|strong="H1961"\w* \w los|strong="H1121"\w* asuritas, letusitas y leumitas,  
\v 4 y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Madián|strong="H4080"\w* fueron Efa, Efer, Hanoc, Abida y Elda. \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* fueron descendientes \w de|strong="H1121"\w* Cetura.  
\v 5 Abraham \w dio|strong="H5414"\w* \w todo|strong="H3605"\w* cuanto tenía \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*,  
\v 6 pero \w les|strong="H5921"\w* \w dio|strong="H5414"\w* regalos \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w concubinas|strong="H6370"\w* \w que|strong="H5921"\w* tuvo. \w Y|strong="H3068"\w* \w mientras|strong="H5750"\w* vivía, \w los|strong="H1121"\w* \w envió|strong="H7971"\w* \w al|strong="H5921"\w* \w oriente|strong="H6924"\w*, lejos \w de|strong="H5921"\w* su \w hijo|strong="H1121"\w* \w Isaac|strong="H3327"\w*, \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w oriental|strong="H6924"\w*.   
\s1 Muerte de Abraham  
\p
\v 7 Los \w días|strong="H3117"\w* \w de|strong="H2568"\w* los \w años|strong="H8141"\w* \w que|strong="H3117"\w* \w vivió|strong="H3117"\w* Abraham fueron 175 \w años|strong="H8141"\w*.  
\v 8 Abraham expiró y \w murió|strong="H4191"\w* en \w buena|strong="H2896"\w* \w vejez|strong="H7872"\w*, \w anciano|strong="H2205"\w* y satisfecho. \w Y|strong="H3068"\w* fue reunido \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*.  
\v 9 Sus \w hijos|strong="H1121"\w* \w Isaac|strong="H3327"\w* \w e|strong="H3068"\w* \w Ismael|strong="H3458"\w* \w lo|strong="H5921"\w* \w sepultaron|strong="H6912"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cueva|strong="H4631"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* Macpela, \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w campo|strong="H7704"\w* \w de|strong="H5921"\w* Efrón, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Zoar \w el|strong="H5921"\w* heteo, \w que|strong="H5921"\w* estaba \w enfrente|strong="H6440"\w* \w de|strong="H5921"\w* \w Mamre|strong="H4471"\w*,  
\v 10 \w el|strong="H1121"\w* \w campo|strong="H7704"\w* \w que|strong="H1121"\w* Abraham \w compró|strong="H7069"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het. \w Allí|strong="H8033"\w* fue \w sepultado|strong="H6912"\w* Abraham junto \w a|strong="H3068"\w* su esposa \w Sara|strong="H8283"\w*.  
\v 11 \w Sucedió|strong="H1961"\w* \w después|strong="H3427"\w* \w de|strong="H5973"\w* la \w muerte|strong="H4194"\w* \w de|strong="H5973"\w* Abraham, \w que|strong="H1121"\w* \nd ʼElohim\nd* \w bendijo|strong="H1288"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w* su \w hijo|strong="H1121"\w*. \w E|strong="H3068"\w* \w Isaac|strong="H3327"\w* vivió \w junto|strong="H5973"\w* al pozo \w del|strong="H5973"\w* Viviente-que-me-ve.   
\s1 Descendencia de Ismael  
\p
\v 12 Estos son \w los|strong="H1121"\w* descendientes \w de|strong="H1121"\w* \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Abraham, \w que|strong="H1121"\w* \w Agar|strong="H1904"\w* la \w egipcia|strong="H4713"\w*, esclava \w de|strong="H1121"\w* \w Sara|strong="H8283"\w*, le dio \w a|strong="H3068"\w* luz.  
\v 13 Estos son \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Ismael|strong="H3458"\w* según su nacimiento: \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Ismael|strong="H3458"\w*, Nebaiot, después, \w Cedar|strong="H6938"\w*, Adbeel, \w Mibsam|strong="H4017"\w*,  
\v 14 \w Misma|strong="H4927"\w*, \w Duma|strong="H1746"\w*, Massa,  
\v 15 Hadar, Tema, \w Jetur|strong="H3195"\w*, Nafis y Cedema.  
\v 16 \w Estos|strong="H1992"\w* son \w los|strong="H1992"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Ismael|strong="H3458"\w* según \w sus|strong="H1992"\w* poblados y \w sus|strong="H1992"\w* \w campamentos|strong="H2918"\w*: 12 \w príncipes|strong="H5387"\w* según \w sus|strong="H1992"\w* naciones.   
\p
\v 17 Los \w años|strong="H8141"\w* \w de|strong="H5971"\w* la \w vida|strong="H2416"\w* \w de|strong="H5971"\w* \w Ismael|strong="H3458"\w* fueron 137 \w años|strong="H8141"\w*. \w Ismael|strong="H3458"\w* \w murió|strong="H4191"\w* y fue reunido \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*.  
\v 18 \w Se|strong="H5921"\w* estableció \w desde|strong="H5704"\w* \w Havila|strong="H2341"\w* \w hasta|strong="H5704"\w* \w Shur|strong="H7793"\w*, \w que|strong="H5921"\w* \w está|strong="H7931"\w* \w enfrente|strong="H6440"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w en|strong="H5921"\w* dirección \w a|strong="H3068"\w* Asiria. \w Y|strong="H3068"\w* \w habitó|strong="H7931"\w* enfrentado \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus hermanos.   
\s1 Jacob y Esaú  
\p
\v 19 Estos son \w los|strong="H1121"\w* descendientes \w de|strong="H1121"\w* \w Isaac|strong="H3327"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Abraham. Abraham \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*.   
\p
\v 20 \w Isaac|strong="H3327"\w* \w tenía|strong="H1961"\w* 40 \w años|strong="H8141"\w* \w cuando|strong="H1961"\w* \w tomó|strong="H3947"\w* \w como|strong="H1961"\w* esposa \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w*, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Betuel, \w el|strong="H1121"\w* arameo \w de|strong="H1121"\w* \w Padan-aram|strong="H6307"\w*, hermana \w de|strong="H1121"\w* \w Labán|strong="H3837"\w* \w el|strong="H1121"\w* arameo.  
\v 21 \w Isaac|strong="H3327"\w* suplicó \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w por|strong="H3588"\w* \w su|strong="H1931"\w* esposa, \w que|strong="H3588"\w* \w era|strong="H1931"\w* estéril. \w Y|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* atendió \w la|strong="H1931"\w* súplica, \w y|strong="H3588"\w* \w Rebeca|strong="H7259"\w* \w su|strong="H1931"\w* esposa \w concibió|strong="H2029"\w*.   
\p
\v 22 Pero \w como|strong="H4100"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* luchaban \w dentro|strong="H7130"\w* \w de|strong="H1121"\w* ella, dijo: Si \w es|strong="H2088"\w* \w así|strong="H3651"\w*, ¿para \w qué|strong="H4100"\w* vivo? \w Y|strong="H3068"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* consultar \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 23 \w Y|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* le dijo:  
\q1 \wj \+w Dos|strong="H8147"\+w* \+w naciones|strong="H1471"\+w* hay en tu seno, \wj*  
\q1 \wj \+w Y|strong="H3068"\+w* \+w dos|strong="H8147"\+w* \+w pueblos|strong="H3816"\+w* se dividen aun desde tu vientre. \wj*  
\q1 \wj Un \+w pueblo|strong="H7227"\+w* será \+w más|strong="H7227"\+w* fuerte que el otro, \wj*  
\q1 \wj \+w Y|strong="H3068"\+w* el \+w mayor|strong="H7227"\+w* \+w servirá|strong="H5647"\+w* al \+w menor|strong="H6810"\+w*.\wj*   
\p
\v 24 \w Cuando|strong="H3117"\w* se cumplieron sus \w días|strong="H3117"\w* para dar \w a|strong="H3068"\w* luz, \w sí|strong="H2009"\w*, había gemelos en su vientre.  
\v 25 \w El|strong="H3605"\w* \w primero|strong="H7223"\w* \w salió|strong="H3318"\w* pelirrojo, \w todo|strong="H3605"\w* \w el|strong="H3605"\w* velludo como una pelliza, y \w llamaron|strong="H7121"\w* su \w nombre|strong="H8034"\w* \w Esaú|strong="H6215"\w*.  
\v 26 Después \w salió|strong="H3318"\w* su hermano con su \w mano|strong="H3027"\w* asida al talón \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*, y lo \w llamó|strong="H7121"\w* \w Jacob|strong="H3290"\w*.  
\p \w Isaac|strong="H3327"\w* tenía 60 \w años|strong="H8141"\w* cuando ella \w los|strong="H1121"\w* dio \w a|strong="H3068"\w* luz.   
\p
\v 27 \w Los|strong="H3427"\w* muchachos crecieron. \w Esaú|strong="H6215"\w* \w fue|strong="H1961"\w* hombre \w diestro|strong="H3045"\w* en la \w caza|strong="H6718"\w*, hombre del \w campo|strong="H7704"\w*, mientras \w Jacob|strong="H3290"\w* \w era|strong="H1961"\w* hombre tranquilo, \w que|strong="H3045"\w* \w vivía|strong="H3427"\w* en tiendas.  
\v 28 \w Isaac|strong="H3327"\w* prefería \w a|strong="H3068"\w* \w Esaú|strong="H6215"\w* \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w caza|strong="H6718"\w* \w de|strong="H3588"\w* éste era deleitosa \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w boca|strong="H6310"\w*, \w pero|strong="H3588"\w* \w Rebeca|strong="H7259"\w* amaba \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*.   
\s1 La primogenitura  
\p
\v 29 Un día \w Jacob|strong="H3290"\w* hizo un guiso, y cuando \w Esaú|strong="H6215"\w* llegó \w del|strong="H4480"\w* \w campo|strong="H7704"\w* y estaba \w cansado|strong="H5889"\w*,  
\v 30 dijo \w Esaú|strong="H6215"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: \w Te|strong="H5921"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* \w me|strong="H4480"\w* dejes comer \w de|strong="H4480"\w* \w eso|strong="H3651"\w* rojo, \w porque|strong="H3588"\w* estoy desfallecido. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w lo|strong="H2088"\w* \w llamaron|strong="H7121"\w* Edom.   
\p
\v 31 \w Jacob|strong="H3290"\w* respondió: \w Véndeme|strong="H4376"\w* \w hoy|strong="H3117"\w* tu primogenitura.   
\p
\v 32 Entonces \w Esaú|strong="H6215"\w* dijo: Igual me \w voy|strong="H1980"\w* \w a|strong="H3068"\w* \w morir|strong="H4191"\w*. ¿De \w qué|strong="H4100"\w* me sirve la primogenitura?   
\p
\v 33 \w Y|strong="H3068"\w* \w Jacob|strong="H3290"\w* contestó: ¡\w Júramelo|strong="H7650"\w* \w hoy|strong="H3117"\w*! Le \w juró|strong="H7650"\w* y \w vendió|strong="H4376"\w* su primogenitura \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*.   
\p
\v 34 Entonces \w Jacob|strong="H3290"\w* \w dio|strong="H5414"\w* \w pan|strong="H3899"\w* con guiso \w de|strong="H5414"\w* \w lentejas|strong="H5742"\w* \w a|strong="H3068"\w* \w Esaú|strong="H6215"\w*. Él comió y \w bebió|strong="H8354"\w*, se \w levantó|strong="H6965"\w* y \w salió|strong="H3212"\w*.  
\p Así despreció \w Esaú|strong="H6215"\w* la primogenitura.   
\c 26  
\s1 Isaac en Gerar  
\p
\v 1 \w Hubo|strong="H1961"\w* una hambruna \w en|strong="H3212"\w* aquella tierra, además de aquella \w primera|strong="H7223"\w* hambruna \w que|strong="H3117"\w* \w hubo|strong="H1961"\w* \w en|strong="H3212"\w* \w los|strong="H1961"\w* \w días|strong="H3117"\w* de Abraham. \w Isaac|strong="H3327"\w* \w fue|strong="H1961"\w* \w a|strong="H3068"\w* \w Gerar|strong="H1642"\w*, donde Abimelec \w era|strong="H1961"\w* \w rey|strong="H4428"\w* de \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w*.   
\p
\v 2 \nd \+w Yavé|strong="H3068"\+w*\nd* se le \w apareció|strong="H7200"\w* y le dijo: \wj No bajes \+w a|strong="H3068"\+w* \+w Egipto|strong="H4714"\+w*. Vive en la tierra que Yo te diré.\wj*  
\v 3 \wj \+w Habita|strong="H1481"\+w* temporalmente \+w en|strong="H5973"\+w* \+w esta|strong="H2063"\+w* tierra \+w y|strong="H3588"\+w* estaré \+w contigo|strong="H5973"\+w*. \+w Te|strong="H3588"\+w* \+w bendeciré|strong="H1288"\+w*, \+w porque|strong="H3588"\+w* \+w daré|strong="H5414"\+w* \+w todas|strong="H3605"\+w* \+w estas|strong="H2063"\+w* tierras \+w a|strong="H3068"\+w* \+w ti|strong="H5973"\+w* \+w y|strong="H3588"\+w* \+w a|strong="H3068"\+w* tu \+w descendencia|strong="H2233"\+w*, \+w y|strong="H3588"\+w* \+w confirmaré|strong="H6965"\+w* \+w el|strong="H5973"\+w* \+w juramento|strong="H7621"\+w* \+w que|strong="H3588"\+w* \+w hice|strong="H7650"\+w* \+w a|strong="H3068"\+w* tu padre Abraham.\wj*   
\p
\v 4 \wj \+w Multiplicaré|strong="H7235"\+w* tu \+w descendencia|strong="H2233"\+w* como las \+w estrellas|strong="H3556"\+w* del \+w cielo|strong="H8064"\+w*, y \+w daré|strong="H5414"\+w* \+w a|strong="H3068"\+w* tu \+w descendencia|strong="H2233"\+w* \+w todas|strong="H3605"\+w* estas tierras. \+w Todas|strong="H3605"\+w* las \+w naciones|strong="H1471"\+w* \+w de|strong="H5414"\+w* \+w la|strong="H3605"\+w* tierra serán bendecidas en tu \+w descendencia|strong="H2233"\+w*,\wj*  
\v 5 \wj \+w por|strong="H6118"\+w* cuanto Abraham \+w escuchó|strong="H8085"\+w* mi \+w voz|strong="H6963"\+w* y \+w guardó|strong="H8104"\+w* mis Preceptos, mis \+w Mandamientos|strong="H4687"\+w*, mis \+w Estatutos|strong="H2708"\+w* y mis \+w Leyes|strong="H8451"\+w*.\wj*  
\v 6 \w Isaac|strong="H3327"\w* \w habitó|strong="H3427"\w* en \w Gerar|strong="H1642"\w*.   
\p
\v 7 \w Los|strong="H5921"\w* hombres \w de|strong="H5921"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* \w le|strong="H1931"\w* \w preguntaron|strong="H7592"\w* \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w su|strong="H1931"\w* esposa, \w y|strong="H3588"\w* \w él|strong="H1931"\w* contestó: \w Ella|strong="H1931"\w* \w es|strong="H1931"\w* \w mi|strong="H5921"\w* hermana, \w porque|strong="H3588"\w* \w temió|strong="H3372"\w* decir: \w Es|strong="H1931"\w* \w mi|strong="H5921"\w* esposa, \w pues|strong="H3588"\w* pensó \w que|strong="H3588"\w* \w los|strong="H5921"\w* hombres \w del|strong="H5921"\w* \w lugar|strong="H4725"\w* \w lo|strong="H1931"\w* matarían \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w Rebeca|strong="H7259"\w*, ya \w que|strong="H3588"\w* \w ella|strong="H1931"\w* \w era|strong="H1931"\w* \w de|strong="H5921"\w* \w hermosa|strong="H2896"\w* \w apariencia|strong="H4758"\w*.   
\p
\v 8 \w Después|strong="H1961"\w* \w de|strong="H3588"\w* estar \w allí|strong="H8033"\w* bastante \w tiempo|strong="H3117"\w*, Abimelec, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w*, \w al|strong="H4428"\w* \w mirar|strong="H7200"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* ventana \w vio|strong="H7200"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*, quien acariciaba \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w* \w su|strong="H3588"\w* esposa.  
\v 9 Abimelec \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*, \w y|strong="H3588"\w* \w le|strong="H1931"\w* dijo: \w Mira|strong="H2009"\w*, \w ciertamente|strong="H3588"\w* \w ella|strong="H1931"\w* \w es|strong="H1931"\w* tu esposa. ¿\w Por|strong="H5921"\w* \w qué|strong="H3588"\w* dijiste: \w Es|strong="H1931"\w* \w mi|strong="H5921"\w* hermana?  
\p \w E|strong="H3068"\w* \w Isaac|strong="H3327"\w* \w le|strong="H1931"\w* respondió: \w Porque|strong="H3588"\w* \w me|strong="H5921"\w* dije: \w No|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w muera|strong="H4191"\w* \w por|strong="H5921"\w* causa \w de|strong="H5921"\w* \w ella|strong="H1931"\w*.   
\p
\v 10 Abimelec preguntó: ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w nos|strong="H5921"\w* \w hiciste|strong="H6213"\w* \w esto|strong="H2063"\w*? ¡\w Cuán|strong="H4100"\w* fácilmente hubiera podido unirse alguno \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w con|strong="H5921"\w* \w tu|strong="H6213"\w* esposa \w y|strong="H5921"\w* \w así|strong="H2063"\w* habrías traído culpabilidad \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*!   
\p
\v 11 \w Por|strong="H2088"\w* \w lo|strong="H2088"\w* cual Abimelec \w mandó|strong="H6680"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* su \w pueblo|strong="H5971"\w*: \w El|strong="H3605"\w* \w que|strong="H5971"\w* toque \w a|strong="H3068"\w* \w este|strong="H2088"\w* hombre \w o|strong="H3068"\w* \w a|strong="H3068"\w* su esposa, \w ciertamente|strong="H4191"\w* \w morirá|strong="H4191"\w*.   
\s1 Los pozos de Isaac  
\p
\v 12 \w Isaac|strong="H3327"\w* sembró en \w aquella|strong="H1931"\w* tierra. \w Aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w año|strong="H8141"\w* cosechó \w ciento|strong="H3967"\w* por uno, porque \nd \+w Yavé|strong="H3068"\+w*\nd* \w lo|strong="H1931"\w* \w bendijo|strong="H1288"\w*.  
\v 13 Aquel varón se \w engrandeció|strong="H1431"\w* \w y|strong="H3588"\w* continuó \w el|strong="H3588"\w* engrandecimiento \w hasta|strong="H5704"\w* hacerse \w muy|strong="H3966"\w* \w poderoso|strong="H1431"\w*.  
\v 14 \w Tuvo|strong="H1961"\w* \w rebaño|strong="H6629"\w* de \w ovejas|strong="H6629"\w*, \w hato|strong="H4735"\w* de \w ganado|strong="H4735"\w* \w vacuno|strong="H1241"\w* \w y|strong="H1241"\w* \w gran|strong="H7227"\w* servidumbre, tanto \w que|strong="H1961"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w* le \w tuvieron|strong="H1961"\w* \w envidia|strong="H7065"\w*,  
\v 15 de modo \w que|strong="H3117"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* pozos \w que|strong="H3117"\w* \w cavaron|strong="H2658"\w* \w los|strong="H3605"\w* esclavos en \w días|strong="H3117"\w* de su padre Abraham, \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w* \w los|strong="H3605"\w* \w cegaron|strong="H5640"\w*. \w Los|strong="H3605"\w* \w llenaron|strong="H4390"\w* de \w tierra|strong="H6083"\w*.   
\p
\v 16 \w Y|strong="H3068"\w* Abimelec dijo \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*: \w Apártate|strong="H3212"\w* \w de|strong="H4480"\w* \w nosotros|strong="H5973"\w* \w porque|strong="H3588"\w* eres \w mucho|strong="H3966"\w* \w más|strong="H3588"\w* poderoso \w que|strong="H3588"\w* \w nosotros|strong="H5973"\w*.   
\p
\v 17 \w Isaac|strong="H3327"\w* \w salió|strong="H3212"\w* de \w allí|strong="H8033"\w* y acampó \w en|strong="H3212"\w* \w el|strong="H3427"\w* valle de \w Gerar|strong="H1642"\w*, y vivió \w allí|strong="H8033"\w*.  
\v 18 \w Luego|strong="H7725"\w* \w Isaac|strong="H3327"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* abrir los pozos \w de|strong="H4325"\w* \w agua|strong="H4325"\w* \w que|strong="H3117"\w* \w cavaron|strong="H2658"\w* en los \w días|strong="H3117"\w* \w de|strong="H4325"\w* su padre Abraham, y \w que|strong="H3117"\w* los \w filisteos|strong="H6430"\w* \w cegaron|strong="H5640"\w* después \w de|strong="H4325"\w* la \w muerte|strong="H4194"\w* \w de|strong="H4325"\w* Abraham. Los \w llamó|strong="H7121"\w* con los mismos \w nombres|strong="H8034"\w* \w que|strong="H3117"\w* su padre les \w dio|strong="H7725"\w*.   
\p
\v 19 Los esclavos \w de|strong="H4325"\w* \w Isaac|strong="H3327"\w* \w cavaron|strong="H2658"\w* en el valle y encontraron \w allí|strong="H8033"\w* un pozo \w de|strong="H4325"\w* \w aguas|strong="H4325"\w* \w vivas|strong="H2416"\w*.  
\v 20 \w Pero|strong="H3588"\w* \w los|strong="H5973"\w* pastores \w de|strong="H3588"\w* \w Gerar|strong="H1642"\w* \w riñeron|strong="H7378"\w* \w con|strong="H5973"\w* \w los|strong="H5973"\w* pastores \w de|strong="H3588"\w* \w Isaac|strong="H3327"\w* \w y|strong="H3588"\w* dijeron: \w El|strong="H5973"\w* \w agua|strong="H4325"\w* \w es|strong="H3588"\w* nuestra. \w Por|strong="H3588"\w* eso lo \w llamó|strong="H7121"\w* \w del|strong="H5973"\w* pozo Eseq, \w porque|strong="H3588"\w* altercaron \w por|strong="H3588"\w* \w él|strong="H5973"\w*.  
\v 21 Abrieron otro pozo \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w riñeron|strong="H7378"\w* \w por|strong="H5921"\w* \w él|strong="H5921"\w*. \w Lo|strong="H5921"\w* \w llamó|strong="H7121"\w* Sitna.  
\v 22 \w Entonces|strong="H3588"\w* \w se|strong="H5921"\w* apartó \w de|strong="H5921"\w* \w allí|strong="H8033"\w* \w y|strong="H3588"\w* abrió otro pozo. \w Por|strong="H5921"\w* éste \w no|strong="H3808"\w* \w riñeron|strong="H7378"\w*. \w Lo|strong="H3808"\w* \w llamó|strong="H7121"\w* Rehobot \w porque|strong="H3588"\w* dijeron: \nd \+w Yavé|strong="H3068"\+w*\nd* \w nos|strong="H5921"\w* hizo ensanchar, \w y|strong="H3588"\w* fructificaremos \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra.   
\p
\v 23 De \w allí|strong="H8033"\w* \w subió|strong="H5927"\w* \w a|strong="H3068"\w* Beerseba.  
\v 24 \w Aquella|strong="H1931"\w* \w noche|strong="H3915"\w* \w se|strong="H1931"\w* \w le|strong="H1931"\w* \w apareció|strong="H7200"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w y|strong="H3588"\w* \w le|strong="H1931"\w* dijo: \wj \+w Yo|strong="H3588"\+w* \+w soy|strong="H1931"\+w* \+w el|strong="H1931"\+w* \+nd ʼElohim\+nd* \+w de|strong="H3588"\+w* tu padre Abraham. \+w No|strong="H3588"\+w* \+w temas|strong="H3372"\+w*, \+w porque|strong="H3588"\+w* estoy contigo. \+w Te|strong="H3588"\+w* \+w bendeciré|strong="H1288"\+w*, \+w y|strong="H3588"\+w* \+w multiplicaré|strong="H7235"\+w* tu \+w descendencia|strong="H2233"\+w* \+w por|strong="H3588"\+w* amor \+w a|strong="H3068"\+w* mi esclavo Abraham.\wj*   
\p
\v 25 Entonces \w edificó|strong="H1129"\w* \w allí|strong="H8033"\w* un \w altar|strong="H4196"\w* \w e|strong="H3068"\w* invocó el \w Nombre|strong="H8034"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*. Plantó \w allí|strong="H8033"\w* su tienda y los esclavos de \w Isaac|strong="H3327"\w* \w cavaron|strong="H3738"\w* \w allí|strong="H8033"\w* un pozo.   
\p
\v 26 Abimelec \w fue|strong="H1980"\w* \w a|strong="H3068"\w* él desde \w Gerar|strong="H1642"\w* con su allegado Ahuzat y Ficol, \w capitán|strong="H8269"\w* \w de|strong="H8269"\w* su \w ejército|strong="H6635"\w*.  
\v 27 \w Isaac|strong="H3327"\w* les dijo: ¿\w Por|strong="H4069"\w* qué vienen \w a|strong="H3068"\w* mí, si me \w aborrecieron|strong="H8130"\w* y me echaron de entre ustedes?   
\p
\v 28 \w Le|strong="H5973"\w* respondieron: \w Ciertamente|strong="H3588"\w* \w vimos|strong="H7200"\w* \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w está|strong="H1961"\w* \w contigo|strong="H5973"\w*. Pensamos interponer un juramento solemne \w entre|strong="H5973"\w* tú \w y|strong="H3588"\w* \w nosotros|strong="H5973"\w*, \w y|strong="H3588"\w* concertar un \w pacto|strong="H1285"\w* \w contigo|strong="H5973"\w*  
\v 29 \w de|strong="H5973"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* nos \w harás|strong="H6213"\w* daño, \w así|strong="H6258"\w* \w como|strong="H5973"\w* \w nosotros|strong="H5973"\w* \w no|strong="H3808"\w* \w te|strong="H5973"\w* tocamos. \w Solo|strong="H7535"\w* \w te|strong="H5973"\w* \w hicimos|strong="H6213"\w* \w bien|strong="H2896"\w* y \w te|strong="H5973"\w* despedimos \w en|strong="H5973"\w* \w paz|strong="H7965"\w*. \w Tú|strong="H6213"\w* eres \w ahora|strong="H6258"\w* \w el|strong="H5973"\w* bendecido por \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 30 Entonces \w él|strong="H6213"\w* les \w ofreció|strong="H6213"\w* un \w banquete|strong="H4960"\w*, y comieron y \w bebieron|strong="H8354"\w*.   
\p
\v 31 Por la \w mañana|strong="H1242"\w* se levantaron temprano y se juramentaron el uno al otro. Al despedirlos \w Isaac|strong="H3327"\w*, salieron de su lado \w en|strong="H3212"\w* \w paz|strong="H7965"\w*.   
\p
\v 32 \w Aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w* \w sucedió|strong="H1961"\w* \w que|strong="H1931"\w* llegaron \w los|strong="H5921"\w* esclavos \w de|strong="H5921"\w* \w Isaac|strong="H3327"\w* \w con|strong="H5921"\w* \w las|strong="H5921"\w* noticias \w del|strong="H5921"\w* pozo \w que|strong="H1931"\w* \w cavaron|strong="H2658"\w* \w y|strong="H5921"\w* \w le|strong="H1931"\w* dijeron: ¡Encontramos \w agua|strong="H4325"\w*!  
\v 33 \w Lo|strong="H2088"\w* \w llamó|strong="H7121"\w* \w Seba|strong="H7656"\w*, \w por|strong="H5921"\w* \w lo|strong="H2088"\w* cual \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* \w aquella|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w es|strong="H2088"\w* Beerseba \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
\p
\v 34 \w Esaú|strong="H6215"\w* \w tenía|strong="H1961"\w* 40 \w años|strong="H8141"\w* \w de|strong="H1121"\w* \w edad|strong="H8141"\w* \w cuando|strong="H1961"\w* \w tomó|strong="H3947"\w* \w como|strong="H1961"\w* esposa \w a|strong="H3068"\w* Judit, \w hija|strong="H1323"\w* del heteo Beeri, y \w a|strong="H3068"\w* Bosemat, \w hija|strong="H1323"\w* del heteo Elón.  
\v 35 Ellas \w fueron|strong="H1961"\w* causa de mucha amargura \w para|strong="H1961"\w* \w Isaac|strong="H3327"\w* y \w Rebeca|strong="H7259"\w*.   
\c 27  
\s1 La bendición de Isaac  
\p
\v 1 \w Aconteció|strong="H1961"\w* \w que|strong="H3588"\w* \w Isaac|strong="H3327"\w* \w envejeció|strong="H2204"\w* \w y|strong="H3588"\w* sus \w ojos|strong="H5869"\w* \w se|strong="H1961"\w* debilitaron hasta \w no|strong="H3588"\w* \w ver|strong="H7200"\w*. \w Entonces|strong="H3588"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Esaú|strong="H6215"\w*, \w su|strong="H3588"\w* \w hijo|strong="H1121"\w* \w mayor|strong="H1419"\w*, \w y|strong="H3588"\w* \w le|strong="H5869"\w* dijo: \w Hijo|strong="H1121"\w* mío.  
\p \w Y|strong="H3068"\w* \w él|strong="H3588"\w* respondió: \w Aquí|strong="H2009"\w* \w estoy|strong="H1961"\w*.   
\p
\v 2 Le dijo: \w Mira|strong="H2009"\w*, \w ahora|strong="H4994"\w* \w ya|strong="H4994"\w* soy \w viejo|strong="H2204"\w* y \w no|strong="H3808"\w* \w sé|strong="H3045"\w* el \w día|strong="H3117"\w* de \w mi|strong="H2009"\w* \w muerte|strong="H4194"\w*.  
\v 3 \w Toma|strong="H5375"\w* \w ahora|strong="H6258"\w* tus \w aparejos|strong="H3627"\w*, tu caja portátil de flechas y tu \w arco|strong="H7198"\w*. \w Sal|strong="H3318"\w* al \w campo|strong="H7704"\w* y cázame alguna presa.  
\v 4 Prepárame \w manjares|strong="H4303"\w* como \w a|strong="H3068"\w* \w mí|strong="H5315"\w* me gustan y tráemelos para que coma, \w a|strong="H3068"\w* fin de que \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* \w te|strong="H5315"\w* \w bendiga|strong="H1288"\w* \w antes|strong="H2962"\w* que \w muera|strong="H4191"\w*.   
\p
\v 5 Pero \w Rebeca|strong="H7259"\w* estaba \w escuchando|strong="H8085"\w* lo \w que|strong="H1121"\w* \w Isaac|strong="H3327"\w* decía \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w Esaú|strong="H6215"\w*. \w Y|strong="H3068"\w* cuando \w Esaú|strong="H6215"\w* \w fue|strong="H3212"\w* al \w campo|strong="H7704"\w* \w a|strong="H3068"\w* cazar la presa \w que|strong="H1121"\w* \w iba|strong="H3212"\w* \w a|strong="H3068"\w* traer,  
\v 6 \w Rebeca|strong="H7259"\w* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w Jacob|strong="H3290"\w*: \w Oye|strong="H8085"\w*, \w escuché|strong="H8085"\w* \w a|strong="H3068"\w* tu padre cuando \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* tu hermano \w Esaú|strong="H6215"\w*:  
\v 7 Tráeme una presa y prepárame \w manjares|strong="H4303"\w* para que \w yo|strong="H6213"\w* coma y te \w bendiga|strong="H1288"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w antes|strong="H6440"\w* que muera.  
\v 8 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, \w hijo|strong="H1121"\w* mío, obedéceme en lo \w que|strong="H6258"\w* te \w ordeno|strong="H6680"\w*:  
\v 9 \w Vé|strong="H3212"\w* \w ahora|strong="H4994"\w* al \w rebaño|strong="H6629"\w*, y tráeme de \w allí|strong="H8033"\w* \w dos|strong="H8147"\w* \w buenos|strong="H2896"\w* \w cabritos|strong="H1423"\w* para preparar con ellos \w manjares|strong="H4303"\w* para \w tu|strong="H6213"\w* padre, como \w a|strong="H3068"\w* \w él|strong="H6213"\w* le gustan.  
\v 10 Tú lo llevarás \w a|strong="H3068"\w* tu padre para que coma, y así te \w bendecirá|strong="H1288"\w* \w antes|strong="H6440"\w* \w de|strong="H6440"\w* su \w muerte|strong="H4194"\w*.   
\p
\v 11 Pero \w Jacob|strong="H3290"\w* dijo \w a|strong="H3068"\w* su madre \w Rebeca|strong="H7259"\w*: \w Mira|strong="H2005"\w*, mi hermano \w Esaú|strong="H6215"\w* es un hombre velludo, y yo \w lampiño|strong="H2509"\w*.  
\v 12 Quizás \w me|strong="H5921"\w* palpe \w mi|strong="H5921"\w* padre. Quedaré ante \w él|strong="H5921"\w* \w como|strong="H1961"\w* tramposo, \w y|strong="H5921"\w* traeré \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w* \w maldición|strong="H7045"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w bendición|strong="H1293"\w*.   
\p
\v 13 Pero su madre \w le|strong="H5921"\w* respondió: \w Hijo|strong="H1121"\w* \w mío|strong="H5921"\w*, tu \w maldición|strong="H7045"\w* caiga \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*. Solo \w obedece|strong="H8085"\w* \w mi|strong="H5921"\w* \w voz|strong="H6963"\w*. Así \w que|strong="H5921"\w* \w vé|strong="H3068"\w* \w y|strong="H5921"\w* tráemelos.   
\p
\v 14 Entonces \w él|strong="H6213"\w* \w fue|strong="H3212"\w*, los \w tomó|strong="H3947"\w* y los \w llevó|strong="H3947"\w* \w a|strong="H3068"\w* su madre, y su madre los guisó como le gustaban \w a|strong="H3068"\w* su padre.  
\v 15 Luego \w Rebeca|strong="H7259"\w* \w tomó|strong="H3947"\w* la mejor ropa \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w* su \w hijo|strong="H1121"\w* \w mayor|strong="H1419"\w* \w que|strong="H1121"\w* ella tenía consigo en la \w casa|strong="H1004"\w*, y \w vistió|strong="H3847"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* su \w hijo|strong="H1121"\w* \w menor|strong="H6996"\w*.  
\v 16 \w Con|strong="H5921"\w* \w las|strong="H5921"\w* pieles \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w cabritos|strong="H1423"\w* \w le|strong="H5921"\w* cubrió sus \w manos|strong="H3027"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w parte|strong="H2513"\w* \w de|strong="H5921"\w* su \w cuello|strong="H6677"\w* \w donde|strong="H5921"\w* \w no|strong="H5921"\w* tenía vello.  
\v 17 Luego colocó en las \w manos|strong="H3027"\w* \w de|strong="H1121"\w* su \w hijo|strong="H1121"\w* \w Jacob|strong="H3290"\w* \w los|strong="H1121"\w* \w manjares|strong="H4303"\w* y \w el|strong="H1121"\w* \w pan|strong="H3899"\w* \w que|strong="H1121"\w* preparó.   
\p
\v 18 \w Él|strong="H4310"\w* fue \w a|strong="H3068"\w* su padre y dijo: Padre mío.  
\p \w Él|strong="H4310"\w* respondió: \w Aquí|strong="H2009"\w* estoy. ¿\w Quién|strong="H4310"\w* eres, \w hijo|strong="H1121"\w* mío?   
\p
\v 19 \w Y|strong="H3068"\w* \w dijo|strong="H1696"\w* \w Jacob|strong="H3290"\w* \w a|strong="H3068"\w* su padre: \w Yo|strong="H5315"\w* soy \w Esaú|strong="H6215"\w*, \w tu|strong="H6213"\w* \w primogénito|strong="H1060"\w*. \w Hice|strong="H6213"\w* como me \w hablaste|strong="H1696"\w*. \w Levántate|strong="H6965"\w*, \w te|strong="H5315"\w* \w ruego|strong="H4994"\w*. \w Siéntate|strong="H3427"\w* y come de \w mi|strong="H4994"\w* \w caza|strong="H6718"\w* para \w que|strong="H4994"\w* \w tu|strong="H6213"\w* \w alma|strong="H5315"\w* me \w bendiga|strong="H1288"\w*.   
\p
\v 20 \w Entonces|strong="H3588"\w* \w Isaac|strong="H3327"\w* dijo \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w*: ¡\w Qué|strong="H3588"\w* \w pronto|strong="H4116"\w* \w la|strong="H3588"\w* \w hallaste|strong="H4672"\w*, \w hijo|strong="H1121"\w* mío! \w Y|strong="H3068"\w* \w él|strong="H3588"\w* contestó: \w Porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* tu \nd ʼElohim\nd* \w me|strong="H3588"\w* \w la|strong="H3588"\w* presentó al alcance.   
\p
\v 21 Pero \w Isaac|strong="H3327"\w* dijo \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: \w Acércate|strong="H5066"\w* \w ahora|strong="H4994"\w* para \w que|strong="H3808"\w* te palpe, \w hijo|strong="H1121"\w* mío, \w si|strong="H3808"\w* eres tú \w mi|strong="H4994"\w* \w hijo|strong="H1121"\w* \w Esaú|strong="H6215"\w*, \w o|strong="H3068"\w* \w no|strong="H3808"\w*.   
\p
\v 22 \w Jacob|strong="H3290"\w* se \w acercó|strong="H5066"\w* \w a|strong="H3068"\w* su padre \w Isaac|strong="H3327"\w*. \w Él|strong="H5066"\w* lo palpó y dijo: La \w voz|strong="H6963"\w* \w es|strong="H3027"\w* la \w voz|strong="H6963"\w* de \w Jacob|strong="H3290"\w*, pero las \w manos|strong="H3027"\w*, las \w manos|strong="H3027"\w* de \w Esaú|strong="H6215"\w*.  
\v 23 \w No|strong="H3808"\w* \w lo|strong="H3808"\w* reconoció, \w porque|strong="H3588"\w* sus \w manos|strong="H3027"\w* \w eran|strong="H1961"\w* velludas \w como|strong="H3588"\w* las \w de|strong="H3588"\w* \w Esaú|strong="H6215"\w*, \w y|strong="H3588"\w* \w se|strong="H1961"\w* dispuso \w a|strong="H3068"\w* bendecirlo.  
\v 24 Preguntó: ¿Eres tú realmente mi \w hijo|strong="H1121"\w* \w Esaú|strong="H6215"\w*?  
\p Contestó: Yo soy.   
\p
\v 25 Entonces dijo: \w Hijo|strong="H1121"\w* mío, acércame la \w caza|strong="H6718"\w* \w para|strong="H4616"\w* \w que|strong="H1121"\w* coma y \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* \w te|strong="H5315"\w* \w bendiga|strong="H1288"\w*.  
\p \w Y|strong="H3068"\w* \w él|strong="H1121"\w* se la \w acercó|strong="H5066"\w*, y comió. Luego le sirvió \w vino|strong="H3196"\w* y \w bebió|strong="H8354"\w*.  
\v 26 Entonces su padre \w Isaac|strong="H3327"\w* le dijo: \w Acércate|strong="H5066"\w* y bésame \w hijo|strong="H1121"\w* mío.   
\p
\v 27 \w Él|strong="H1121"\w* se \w acercó|strong="H5066"\w* y lo \w besó|strong="H5401"\w*, y al oler Isaac \w el|strong="H1121"\w* aroma \w de|strong="H1121"\w* sus ropas, lo \w bendijo|strong="H1288"\w*:  
\q1 Aquí está \w el|strong="H1121"\w* aroma \w de|strong="H1121"\w* mi \w hijo|strong="H1121"\w*,  
\q1 Como \w el|strong="H1121"\w* aroma del \w campo|strong="H7704"\w* \w que|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w bendijo|strong="H1288"\w*.   
\q1
\v 28 \nd ʼElohim\nd*, pues, te \w dé|strong="H5414"\w* del \w rocío|strong="H2919"\w* del \w cielo|strong="H8064"\w*,  
\q1 \w Y|strong="H3068"\w* \w de|strong="H5414"\w* las fertilidades \w de|strong="H5414"\w* la tierra,  
\q1 \w Y|strong="H3068"\w* \w abundancia|strong="H7230"\w* \w de|strong="H5414"\w* \w grano|strong="H1715"\w* y \w mosto|strong="H8492"\w*.   
\q1
\v 29 \w Pueblos|strong="H5971"\w* te sirvan,  
\q1 \w Y|strong="H3068"\w* naciones \w se|strong="H5971"\w* inclinen ante ti.  
\q1 \w Sé|strong="H5971"\w* \tl ʼadón\tl* \w de|strong="H1121"\w* tus hermanos,  
\q1 \w E|strong="H3068"\w* inclínense ante ti \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* tu madre.  
\q1 Malditos \w los|strong="H1121"\w* \w que|strong="H5971"\w* te maldigan,  
\q1 \w Y|strong="H3068"\w* \w benditos|strong="H1288"\w* \w los|strong="H1121"\w* \w que|strong="H5971"\w* te bendigan.   
\p
\v 30 \w Aconteció|strong="H1961"\w* \w que|strong="H1961"\w* apenas terminó \w Isaac|strong="H3327"\w* \w de|strong="H6440"\w* bendecir \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*, y \w Jacob|strong="H3290"\w* acababa \w de|strong="H6440"\w* \w salir|strong="H3318"\w* \w de|strong="H6440"\w* la \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* su padre \w Isaac|strong="H3327"\w*, su hermano \w Esaú|strong="H6215"\w* llegó \w de|strong="H6440"\w* su cacería.  
\v 31 \w También|strong="H1571"\w* \w él|strong="H1931"\w* preparó \w manjares|strong="H4303"\w* \w y|strong="H1571"\w* \w los|strong="H1121"\w* llevaba \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre. \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre: ¡\w Levántate|strong="H6965"\w*, padre mío, \w y|strong="H1571"\w* come \w de|strong="H1121"\w* \w la|strong="H1931"\w* \w caza|strong="H6718"\w* \w de|strong="H1121"\w* \w tu|strong="H6213"\w* \w hijo|strong="H1121"\w* para \w que|strong="H1931"\w* me \w bendiga|strong="H1288"\w* \w tu|strong="H6213"\w* \w alma|strong="H5315"\w*!   
\p
\v 32 \w Y|strong="H3068"\w* su padre \w Isaac|strong="H3327"\w* \w le|strong="H4310"\w* preguntó: ¿\w Quién|strong="H4310"\w* eres? \w Y|strong="H3068"\w* \w él|strong="H4310"\w* respondió: Yo soy tu \w hijo|strong="H1121"\w*, tu \w primogénito|strong="H1060"\w* \w Esaú|strong="H6215"\w*.   
\p
\v 33 \w Entonces|strong="H1571"\w* \w Isaac|strong="H3327"\w* \w se|strong="H1961"\w* estremeció \w grandemente|strong="H3966"\w* \w y|strong="H1571"\w* exclamó: ¿\w Quién|strong="H4310"\w*, \w pues|strong="H1931"\w*, \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w que|strong="H4310"\w* \w vino|strong="H1961"\w* aquí, \w que|strong="H4310"\w* cazó \w y|strong="H1571"\w* \w me|strong="H4310"\w* trajo \w de|strong="H5704"\w* comer, \w y|strong="H1571"\w* comí \w de|strong="H5704"\w* \w todo|strong="H3605"\w* \w antes|strong="H2962"\w* \w que|strong="H4310"\w* tú vinieras? ¡Yo \w lo|strong="H1931"\w* \w bendije|strong="H1288"\w* \w y|strong="H1571"\w* \w será|strong="H1961"\w* \w bendito|strong="H1288"\w*!   
\p
\v 34 \w Cuando|strong="H5704"\w* \w Esaú|strong="H6215"\w* \w oyó|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w de|strong="H5704"\w* su padre, dio un grito atroz lleno \w de|strong="H5704"\w* \w amargura|strong="H4751"\w* \w y|strong="H1571"\w* pidió \w a|strong="H3068"\w* su padre: ¡\w Bendíceme|strong="H1288"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* mí, padre mío!   
\p
\v 35 Pero él respondió: Vino tu hermano con astucia y \w tomó|strong="H3947"\w* tu \w bendición|strong="H1293"\w*.   
\p
\v 36 \w Y|strong="H3068"\w* dijo: \w Bien|strong="H3588"\w* \w llamaron|strong="H7121"\w* \w su|strong="H3588"\w* \w nombre|strong="H8034"\w* \w Jacob|strong="H3290"\w*, \w pues|strong="H3588"\w* \w me|strong="H3588"\w* suplantó \w dos|strong="H6471"\w* \w veces|strong="H6471"\w*: \w se|strong="H3808"\w* alzó \w con|strong="H3588"\w* \w mi|strong="H2009"\w* primogenitura, \w y|strong="H3588"\w* \w mira|strong="H2009"\w*, \w ahora|strong="H6258"\w* \w tomó|strong="H3947"\w* \w mi|strong="H2009"\w* \w bendición|strong="H1293"\w*. \w Y|strong="H3068"\w* añadió: ¿\w No|strong="H3808"\w* reservaste \w una|strong="H6471"\w* \w bendición|strong="H1293"\w* \w para|strong="H3588"\w* \w mí|strong="H2009"\w*?   
\p
\v 37 \w E|strong="H3068"\w* \w Isaac|strong="H3327"\w* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* \w Esaú|strong="H6215"\w*: \w Mira|strong="H2005"\w*, \w lo|strong="H4100"\w* declaré \w como|strong="H4100"\w* \tl ʼadón\tl* tuyo y le \w di|strong="H5414"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus hermanos \w como|strong="H4100"\w* esclavos. Le \w dí|strong="H5414"\w* provisión \w de|strong="H1121"\w* \w trigo|strong="H1715"\w* y \w de|strong="H1121"\w* \w vino|strong="H8492"\w*. Entonces, ¿\w qué|strong="H4100"\w* podré \w hacer|strong="H6213"\w* \w por|strong="H4100"\w* ti ahora, \w hijo|strong="H1121"\w* mío?   
\p
\v 38 \w Y|strong="H3068"\w* \w Esaú|strong="H6215"\w* preguntó \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre: Padre mío, ¿no tienes \w sino|strong="H1931"\w* una \w bendición|strong="H1293"\w*? ¡\w Bendíceme|strong="H1288"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* \w mí|strong="H5375"\w*, padre mío! \w Y|strong="H3068"\w* \w Esaú|strong="H6215"\w* \w alzó|strong="H5375"\w* \w su|strong="H1931"\w* \w voz|strong="H6963"\w* \w y|strong="H1571"\w* \w lloró|strong="H1058"\w*.   
\p
\v 39 \w E|strong="H3068"\w* \w Isaac|strong="H3327"\w* su padre \w respondió|strong="H6030"\w*:  
\q1 \w Mira|strong="H2009"\w*, sin \w la|strong="H5921"\w* fertilidad \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra  
\q1 \w Y|strong="H3068"\w* sin \w el|strong="H5921"\w* \w rocío|strong="H2919"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w de|strong="H5921"\w* arriba, \w será|strong="H1961"\w* tu habitación.   
\q1
\v 40 \w Por|strong="H5921"\w* tu \w espada|strong="H2719"\w* \w vivirás|strong="H2421"\w*,  
\q1 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* tu hermano \w servirás|strong="H5647"\w*.  
\q1 Pero \w sucederá|strong="H1961"\w* \w que|strong="H5921"\w* \w cuando|strong="H1961"\w* \w te|strong="H5921"\w* fortalezcas,  
\q1 Sacudirás su \w yugo|strong="H5923"\w* \w de|strong="H5921"\w* tus hombros.   
\s1 Huida de Jacob  
\p
\v 41 \w Esaú|strong="H6215"\w* aborreció \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w bendición|strong="H1293"\w* \w de|strong="H5921"\w* su padre \w y|strong="H5921"\w* dijo \w en|strong="H5921"\w* su \w corazón|strong="H3820"\w*: \w Se|strong="H5921"\w* acercan \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w del|strong="H5921"\w* duelo \w por|strong="H5921"\w* \w mi|strong="H5921"\w* padre, \w entonces|strong="H3117"\w* \w mataré|strong="H2026"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* hermano \w Jacob|strong="H3290"\w*.   
\p
\v 42 Cuando le anunciaron \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w* su \w hijo|strong="H1121"\w* \w mayor|strong="H1419"\w*, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w llamar|strong="H7121"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* su \w hijo|strong="H1121"\w* \w menor|strong="H6996"\w* y le \w dijo|strong="H5046"\w*: \w Mira|strong="H2009"\w*, tu hermano \w Esaú|strong="H6215"\w* se \w consuela|strong="H5162"\w* con la idea \w de|strong="H1121"\w* matarte.  
\v 43 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, \w hijo|strong="H1121"\w* mío, \w obedece|strong="H8085"\w* mi \w voz|strong="H6963"\w*. \w Levántate|strong="H6965"\w* y huye \w a|strong="H3068"\w* \w Harán|strong="H2771"\w*, adonde mi hermano \w Labán|strong="H3837"\w*.  
\v 44 Vive \w con|strong="H5973"\w* \w él|strong="H5973"\w* algunos \w días|strong="H3117"\w* \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* se calme la furia \w de|strong="H5973"\w* tu hermano,  
\v 45 \w hasta|strong="H5704"\w* \w que|strong="H4100"\w* \w se|strong="H4480"\w* aplaque \w la|strong="H1571"\w* ira \w contra|strong="H4480"\w* \w ti|strong="H4480"\w* \w y|strong="H1571"\w* olvide \w lo|strong="H4100"\w* \w que|strong="H4100"\w* le \w hiciste|strong="H6213"\w*. \w Entonces|strong="H3117"\w* \w te|strong="H4480"\w* \w enviaré|strong="H7971"\w* \w a|strong="H3068"\w* traer \w de|strong="H4480"\w* \w allá|strong="H8033"\w*. ¿\w Por|strong="H4480"\w* \w qué|strong="H4100"\w* debo ser privada \w de|strong="H4480"\w* ustedes \w dos|strong="H8147"\w* \w en|strong="H4480"\w* un solo \w día|strong="H3117"\w*?   
\p
\v 46 \w Rebeca|strong="H7259"\w* dijo \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*: Estoy hastiada \w de|strong="H6440"\w* mi \w vida|strong="H2416"\w* \w por|strong="H6440"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* las \w hijas|strong="H1323"\w* \w de|strong="H6440"\w* Het. \w Si|strong="H6440"\w* \w Jacob|strong="H3290"\w* llega \w a|strong="H3068"\w* \w tomar|strong="H3947"\w* esposa \w de|strong="H6440"\w* entre las \w hijas|strong="H1323"\w* \w de|strong="H6440"\w* Het, \w como|strong="H4100"\w* éstas, \w de|strong="H6440"\w* las \w hijas|strong="H1323"\w* \w de|strong="H6440"\w* esta tierra, ¿\w de|strong="H6440"\w* \w qué|strong="H4100"\w* me servirá la \w vida|strong="H2416"\w*?   
\c 28  
\s1 Bet-ʼEl  
\p
\v 1 Entonces \w Isaac|strong="H3327"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*, \w lo|strong="H3808"\w* \w bendijo|strong="H1288"\w* y le \w ordenó|strong="H6680"\w*: \w No|strong="H3808"\w* \w tomes|strong="H3947"\w* esposa de las \w hijas|strong="H1323"\w* de \w Canaán|strong="H3667"\w*.  
\v 2 \w Levántate|strong="H6965"\w*, \w vé|strong="H3068"\w* \w a|strong="H3068"\w* \w Padan-aram|strong="H6307"\w*, \w a|strong="H3068"\w* \w casa|strong="H1004"\w* de Betuel, padre de tu madre, y \w toma|strong="H3947"\w* \w allí|strong="H8033"\w* esposa de las \w hijas|strong="H1323"\w* de \w Labán|strong="H3837"\w*, hermano de tu madre.   
\p
\v 3 \nd ʼEL-Shadday\nd* te \w bendiga|strong="H1288"\w*, te haga fructificar, te multiplique hasta llegar \w a|strong="H3068"\w* ser \w multitud|strong="H6951"\w* \w de|strong="H5971"\w* \w pueblos|strong="H5971"\w*,  
\v 4 y te \w dé|strong="H5414"\w* la \w bendición|strong="H1293"\w* \w de|strong="H5414"\w* Abraham, \w a|strong="H3068"\w* ti y contigo \w a|strong="H3068"\w* tu \w descendencia|strong="H2233"\w*, \w para|strong="H5414"\w* hacer que tomes posesión \w de|strong="H5414"\w* la tierra \w de|strong="H5414"\w* tus peregrinaciones, la cual \nd ʼElohim\nd* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* Abraham.   
\p
\v 5 Así \w Isaac|strong="H3327"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*, \w el|strong="H1121"\w* cual \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w Padan-aram|strong="H6307"\w*, adonde \w Labán|strong="H3837"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Betuel \w el|strong="H1121"\w* arameo, hermano \w de|strong="H1121"\w* \w Rebeca|strong="H7259"\w*, madre \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w* y \w Esaú|strong="H6215"\w*.   
\p
\v 6 \w Esaú|strong="H6215"\w* \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w Isaac|strong="H3327"\w* \w bendijo|strong="H1288"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* \w y|strong="H3588"\w* \w lo|strong="H3808"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w Padan-aram|strong="H6307"\w* \w para|strong="H5921"\w* \w tomar|strong="H3947"\w* \w de|strong="H5921"\w* \w allí|strong="H8033"\w* esposa \w para|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w*, \w al|strong="H5921"\w* bendecirlo, \w le|strong="H5921"\w* \w ordenó|strong="H6680"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w tomara|strong="H3947"\w* esposa \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w las|strong="H5921"\w* \w hijas|strong="H1323"\w* \w de|strong="H5921"\w* \w Canaán|strong="H3667"\w*,  
\v 7 y que \w Jacob|strong="H3290"\w*, al \w obedecer|strong="H8085"\w* \w a|strong="H3068"\w* su padre y \w a|strong="H3068"\w* su madre, se dirigió \w a|strong="H3068"\w* \w Padan-aram|strong="H6307"\w*.   
\p
\v 8 \w Entonces|strong="H3588"\w* \w Esaú|strong="H6215"\w* comprendió \w que|strong="H3588"\w* las \w hijas|strong="H1323"\w* \w de|strong="H3588"\w* \w Canaán|strong="H3667"\w* eran desagradables \w a|strong="H3068"\w* \w su|strong="H3588"\w* padre \w Isaac|strong="H3327"\w*.  
\v 9 \w Esaú|strong="H6215"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w Ismael|strong="H3458"\w*, \w y|strong="H5921"\w* \w además|strong="H5921"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w que|strong="H5921"\w* tenía, \w tomó|strong="H3947"\w* \w para|strong="H5921"\w* \w él|strong="H5921"\w* \w como|strong="H5921"\w* esposa \w a|strong="H3068"\w* Mahalat, \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Abraham \w y|strong="H5921"\w* hermana \w de|strong="H5921"\w* Nebayot.   
\p
\v 10 \w Jacob|strong="H3290"\w* \w salió|strong="H3318"\w* de Beerseba y se dirigió \w a|strong="H3068"\w* \w Harán|strong="H2771"\w*.  
\v 11 \w Cuando|strong="H3588"\w* llegó \w a|strong="H3068"\w* \w cierto|strong="H3588"\w* \w lugar|strong="H4725"\w*, pasó \w allí|strong="H8033"\w* \w la|strong="H1931"\w* noche \w porque|strong="H3588"\w* ya \w el|strong="H1931"\w* \w sol|strong="H8121"\w* \w se|strong="H1931"\w* \w había|strong="H3588"\w* \w puesto|strong="H3588"\w*. \w Tomó|strong="H3947"\w* una piedra del \w lugar|strong="H4725"\w*, \w la|strong="H1931"\w* colocó \w como|strong="H3588"\w* \w su|strong="H1931"\w* \w cabecera|strong="H4763"\w* \w y|strong="H3588"\w* \w se|strong="H1931"\w* tendió \w en|strong="H3588"\w* \w aquel|strong="H1931"\w* \w sitio|strong="H4725"\w*.   
\p
\v 12 \w Tuvo|strong="H2492"\w* un sueño: Apareció una escalera apoyada en la tierra, cuya parte superior alcanzaba el \w cielo|strong="H8064"\w*. Miró que los \w ángeles|strong="H4397"\w* de \nd ʼElohim\nd* \w subían|strong="H5927"\w* y bajaban por ella.  
\v 13 \w Y|strong="H3068"\w* \w vio|strong="H2009"\w* \w que|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w estaba|strong="H5324"\w* \w en|strong="H5921"\w* pie \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w* \w y|strong="H5921"\w* dijo: \wj \+w Yo|strong="H2009"\+w* soy \+nd \+w Yavé|strong="H3068"\+w*, ʼElohim\+nd* \+w de|strong="H5921"\+w* tu padre Abraham \+w y|strong="H5921"\+w* \+nd ʼElohim\+nd* \+w de|strong="H5921"\+w* \+w Isaac|strong="H3327"\+w*. \+w La|strong="H5921"\+w* tierra \+w sobre|strong="H5921"\+w* \+w la|strong="H5921"\+w* cual estás tendido \+w te|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w daré|strong="H5414"\+w* \+w a|strong="H3068"\+w* \+w ti|strong="H5921"\+w* \+w y|strong="H5921"\+w* \+w a|strong="H3068"\+w* tus descendientes.\wj*  
\v 14 \wj Tu \+w descendencia|strong="H2233"\+w* \+w será|strong="H1961"\+w* \+w como|strong="H1961"\+w* \+w el|strong="H3605"\+w* \+w polvo|strong="H6083"\+w* de \+w la|strong="H3605"\+w* \+w tierra|strong="H6083"\+w*, y \+w te|strong="H3220"\+w* extenderás \+w hacia|strong="H5045"\+w* \+w el|strong="H3605"\+w* \+w mar|strong="H3220"\+w*, al \+w oriente|strong="H6924"\+w*, al \+w norte|strong="H6828"\+w* y \+w hacia|strong="H5045"\+w* Neguev. En ti y en tu \+w descendencia|strong="H2233"\+w* \+w serán|strong="H1961"\+w* bendecidas \+w todas|strong="H3605"\+w* las \+w familias|strong="H4940"\+w* de \+w la|strong="H3605"\+w* \+w tierra|strong="H6083"\+w*.\wj*   
\p
\v 15 \wj \+w Mira|strong="H2009"\+w*, \+w Yo|strong="H3588"\+w* estoy \+w contigo|strong="H5973"\+w*, \+w te|strong="H3588"\+w* \+w guardaré|strong="H8104"\+w* dondequiera \+w que|strong="H3588"\+w* \+w vayas|strong="H3212"\+w* \+w y|strong="H3588"\+w* \+w volveré|strong="H7725"\+w* \+w a|strong="H3068"\+w* traerte \+w a|strong="H3068"\+w* \+w esta|strong="H2063"\+w* tierra, \+w pues|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w te|strong="H3588"\+w* \+w dejaré|strong="H5800"\+w* \+w hasta|strong="H5704"\+w* \+w que|strong="H3588"\+w* \+add Yo\+add* \+w haga|strong="H6213"\+w* \+w lo|strong="H3808"\+w* \+w que|strong="H3588"\+w* \+w te|strong="H3588"\+w* prometí.\wj*   
\p
\v 16 \w Jacob|strong="H3290"\w* \w despertó|strong="H3364"\w* de su \w sueño|strong="H8142"\w* y dijo: ¡\w Ciertamente|strong="H3426"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w está|strong="H2088"\w* en \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* y yo \w no|strong="H3808"\w* \w lo|strong="H2088"\w* \w sabía|strong="H3045"\w*!  
\v 17 \w Tuvo|strong="H3372"\w* \w miedo|strong="H3372"\w*, \w y|strong="H3588"\w* dijo: ¡\w Cuán|strong="H4100"\w* asombroso \w es|strong="H2088"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*! ¡\w Esto|strong="H2088"\w* \w no|strong="H3588"\w* \w es|strong="H2088"\w* \w sino|strong="H3588"\w* \w Casa|strong="H1004"\w* \w de|strong="H3588"\w* \nd ʼElohim\nd* \w y|strong="H3588"\w* \w puerta|strong="H8179"\w* del \w cielo|strong="H8064"\w*!   
\p
\v 18 \w Jacob|strong="H3290"\w* \w madrugó|strong="H7925"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w mañana|strong="H1242"\w* \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w tomar|strong="H3947"\w* \w la|strong="H5921"\w* piedra \w que|strong="H5921"\w* \w puso|strong="H7760"\w* \w como|strong="H5921"\w* su \w cabecera|strong="H4763"\w*, \w la|strong="H5921"\w* erigió \w como|strong="H5921"\w* una estela \w y|strong="H5921"\w* \w derramó|strong="H3332"\w* \w aceite|strong="H8081"\w* \w sobre|strong="H5921"\w* su cúspide.  
\v 19 \w Llamó|strong="H7121"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* Bet-ʼEl. Sin embargo, al principio, \w el|strong="H1931"\w* \w nombre|strong="H8034"\w* de \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w era|strong="H1931"\w* \w Luz|strong="H3870"\w*.   
\p
\v 20 \w Jacob|strong="H3290"\w* \w hizo|strong="H5088"\w* un \w voto|strong="H5087"\w* solemne: \w Si|strong="H1961"\w* \nd ʼElohim\nd* \w está|strong="H2088"\w* \w conmigo|strong="H5978"\w*, me protege en \w este|strong="H2088"\w* \w camino|strong="H1870"\w* en el cual \w ando|strong="H1980"\w*, me \w da|strong="H5414"\w* \w pan|strong="H3899"\w* \w para|strong="H5414"\w* comer y ropa \w para|strong="H5414"\w* vestir  
\v 21 y yo vuelvo en \w paz|strong="H7965"\w* \w a|strong="H3068"\w* \w casa|strong="H1004"\w* de \w mi|strong="H1961"\w* padre, \nd \+w Yavé|strong="H3068"\+w*\nd* \w será|strong="H1961"\w* \w mi|strong="H1961"\w* \nd ʼElohim\nd*.  
\v 22 Entonces \w esta|strong="H2063"\w* piedra \w que|strong="H1961"\w* erigí \w como|strong="H1961"\w* estela \w será|strong="H1961"\w* \w Casa|strong="H1004"\w* \w de|strong="H5414"\w* \nd ʼElohim\nd*, y \w de|strong="H5414"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1961"\w* me \w des|strong="H5414"\w*, \w ciertamente|strong="H5414"\w* te \w daré|strong="H5414"\w* \w el|strong="H3605"\w* diezmo.   
\c 29  
\s1 Mesopotamia  
\p
\v 1 Entonces \w Jacob|strong="H3290"\w* prosiguió su viaje, y \w fue|strong="H3212"\w* \w a|strong="H3068"\w* tierra \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w oriente|strong="H6924"\w*.  
\v 2 \w Miró|strong="H7200"\w*, \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w campo|strong="H7704"\w* \w vio|strong="H7200"\w* un pozo \w y|strong="H3588"\w* \w tres|strong="H7969"\w* \w rebaños|strong="H5739"\w* \w de|strong="H4480"\w* \w ovejas|strong="H6629"\w* \w que|strong="H3588"\w* descansaban \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H1931"\w*, \w porque|strong="H3588"\w* \w de|strong="H4480"\w* \w aquel|strong="H1931"\w* pozo solían abrevar \w los|strong="H5921"\w* \w rebaños|strong="H5739"\w*. Una \w gran|strong="H1419"\w* piedra tapaba \w la|strong="H1931"\w* \w boca|strong="H6310"\w* \w del|strong="H4480"\w* pozo.  
\v 3 \w Allí|strong="H8033"\w* \w se|strong="H5921"\w* juntaban \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w rebaños|strong="H5739"\w*. \w Después|strong="H5921"\w* \w de|strong="H5921"\w* rodar \w la|strong="H5921"\w* piedra \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w del|strong="H5921"\w* pozo, \w abrevaban|strong="H8248"\w* \w las|strong="H5921"\w* \w ovejas|strong="H6629"\w*, \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w lo|strong="H5921"\w* cual devolvían \w la|strong="H5921"\w* piedra \w a|strong="H3068"\w* su \w lugar|strong="H4725"\w*, \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w del|strong="H5921"\w* pozo.   
\p
\v 4 \w Jacob|strong="H3290"\w* les dijo: Hermanos, ¿de dónde son? \w Y|strong="H3068"\w* respondieron: Somos de \w Harán|strong="H2771"\w*.   
\p
\v 5 Les preguntó: ¿\w Conocen|strong="H3045"\w* \w a|strong="H3068"\w* \w Labán|strong="H3837"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Nacor? Contestaron: Lo conocemos.   
\p
\v 6 \w Les|strong="H5973"\w* dijo: ¿Está \w en|strong="H5973"\w* \w paz|strong="H7965"\w*? \w Y|strong="H3068"\w* ellos dijeron: \w En|strong="H5973"\w* \w paz|strong="H7965"\w*, y \w mira|strong="H2009"\w*, su \w hija|strong="H1323"\w* Raquel viene \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w rebaño|strong="H6629"\w*.   
\p
\v 7 Él dijo: Miren, \w todavía|strong="H5750"\w* \w es|strong="H4735"\w* pleno \w día|strong="H3117"\w*. \w Aún|strong="H5750"\w* \w no|strong="H3808"\w* \w es|strong="H4735"\w* \w tiempo|strong="H6256"\w* \w de|strong="H5750"\w* recoger el \w ganado|strong="H4735"\w*. Abreven las \w ovejas|strong="H6629"\w* y déjenlas pastar.   
\p
\v 8 Pero \w ellos|strong="H5921"\w* respondieron: \w No|strong="H3808"\w* \w podemos|strong="H3201"\w* \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w rebaños|strong="H5739"\w* \w se|strong="H5921"\w* reúnan. Entonces rodamos \w la|strong="H5921"\w* piedra \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w del|strong="H5921"\w* pozo \w y|strong="H5921"\w* abrevamos \w las|strong="H5921"\w* \w ovejas|strong="H6629"\w*.   
\p
\v 9 \w Cuando|strong="H3588"\w* \w él|strong="H1931"\w* \w aun|strong="H5750"\w* \w hablaba|strong="H1696"\w* \w con|strong="H5973"\w* \w ellos|strong="H1931"\w*, Raquel llegó \w con|strong="H5973"\w* \w el|strong="H1931"\w* \w rebaño|strong="H6629"\w* \w de|strong="H3588"\w* \w su|strong="H1931"\w* padre, \w pues|strong="H3588"\w* \w ella|strong="H1931"\w* \w era|strong="H1931"\w* \w la|strong="H1931"\w* pastora.  
