\s1 We live by faith
\m 
\v 1 \w Now|strong="G1722"\w* \w then|strong="G1063"\w*, \w we|strong="G2249"\w* \w know|strong="G1492"\w* \w that|strong="G3754"\w* \w though|strong="G1437"\w* \w our|strong="G2316"\w* \w earthly|strong="G1919"\w*, tent-like ‘\w house|strong="G3614"\w*’ \w may|strong="G2316"\w* \w be|strong="G2316"\w* \w destroyed|strong="G2647"\w*, \w we|strong="G2249"\w* \w have|strong="G2192"\w* \w a|strong="G2192"\w* \w building|strong="G3619"\w* \w from|strong="G1537"\w* \w God|strong="G2316"\w* (\w not|strong="G2192"\w* \w a|strong="G2192"\w* handmade \w house|strong="G3614"\w*), eternal \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w heavens|strong="G3772"\w*.
