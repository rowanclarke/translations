\p
\v 32 \wj \+w Por|strong="H3588"\+w* \+w tanto|strong="H3651"\+w*, \+w ciertamente|strong="H3588"\+w* vienen \+w días|strong="H3117"\+w*, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \wj \+w cuando|strong="H3588"\+w* ya \+w no|strong="H3808"\+w* \+w será|strong="H3808"\+w* llamado Tófet \+w ni|strong="H3808"\+w* \+w Valle|strong="H1516"\+w* del \+w hijo|strong="H1121"\+w* \+w de|strong="H3588"\+w* Hinom, \+w sino|strong="H3588"\+w* \+w Valle|strong="H1516"\+w* \+w de|strong="H3588"\+w* \+w la|strong="H3588"\+w* Matanza, \+w porque|strong="H3588"\+w* sepultarán \+w en|strong="H3588"\+w* Tófet \+w hasta|strong="H3117"\+w* \+w que|strong="H3588"\+w* \+w no|strong="H3808"\+w* quede \+w lugar|strong="H4725"\+w*.\wj*  
\v 33 \wj \+w Los|strong="H1961"\+w* cadáveres \+w de|strong="H5971"\+w* \+w este|strong="H2088"\+w* \+w pueblo|strong="H5971"\+w* \+w servirán|strong="H1961"\+w* \+w de|strong="H5971"\+w* alimento \+w a|strong="H3068"\+w* las \+w aves|strong="H5775"\+w* del \+w cielo|strong="H8064"\+w* y \+w a|strong="H3068"\+w* las bestias \+w de|strong="H5971"\+w* la tierra. \+w No|strong="H1961"\+w* \+w habrá|strong="H1961"\+w* quien las espante.\wj*  
\v 34 \wj \+w En|strong="H3588"\+w* las \+w ciudades|strong="H5892"\+w* \+w de|strong="H3588"\+w* \+w Judá|strong="H3063"\+w* \+w y|strong="H3588"\+w* \+w en|strong="H3588"\+w* las \+w calles|strong="H2351"\+w* \+w de|strong="H3588"\+w* Jerusalén ordenaré cesar \+w la|strong="H3588"\+w* \+w voz|strong="H6963"\+w* \+w de|strong="H3588"\+w* \+w gozo|strong="H8057"\+w* \+w y|strong="H3588"\+w* \+w de|strong="H3588"\+w* \+w alegría|strong="H8057"\+w*, \+w la|strong="H3588"\+w* \+w voz|strong="H6963"\+w* del novio \+w y|strong="H3588"\+w* \+w de|strong="H3588"\+w* \+w la|strong="H3588"\+w* novia, \+w porque|strong="H3588"\+w* \+w esta|strong="H1961"\+w* tierra \+w será|strong="H1961"\+w* asolada.\wj*   
\c 8  
\p
\v 1 \wj \+w En|strong="H3318"\+w* \+w aquel|strong="H1931"\+w* \+w tiempo|strong="H6256"\+w*, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \wj \+w sacarán|strong="H3318"\+w* \+w de|strong="H8269"\+w* \+w los|strong="H3427"\+w* \+w sepulcros|strong="H6913"\+w* \+w los|strong="H3427"\+w* \+w huesos|strong="H6106"\+w* \+w de|strong="H8269"\+w* \+w los|strong="H3427"\+w* \+w reyes|strong="H4428"\+w* \+w de|strong="H8269"\+w* \+w Judá|strong="H3063"\+w*, \+w sus|strong="H1931"\+w* magistrados, \+w los|strong="H3427"\+w* \+w sacerdotes|strong="H3548"\+w*, \+w los|strong="H3427"\+w* \+w profetas|strong="H5030"\+w* y \+w los|strong="H3427"\+w* \+w habitantes|strong="H3427"\+w* \+w de|strong="H8269"\+w* Jerusalén.\wj*  
\v 2 \wj \+w Los|strong="H5921"\+w* esparcirán \+w ante|strong="H6440"\+w* \+w el|strong="H5921"\+w* \+w sol|strong="H8121"\+w*, \+w la|strong="H5921"\+w* \+w luna|strong="H3394"\+w* \+w y|strong="H5921"\+w* \+w toda|strong="H3605"\+w* \+w la|strong="H5921"\+w* hueste \+w del|strong="H5921"\+w* \+w cielo|strong="H8064"\+w*, \+w a|strong="H3068"\+w* quienes amaron \+w y|strong="H5921"\+w* rindieron culto, \+w siguieron|strong="H1980"\+w* \+w y|strong="H5921"\+w* consultaron, \+w y|strong="H5921"\+w* \+w se|strong="H1961"\+w* postraron. \+w No|strong="H3808"\+w* \+w serán|strong="H1961"\+w* recogidos \+w ni|strong="H3808"\+w* \+w sepultados|strong="H6912"\+w*. Quedarán \+w como|strong="H1961"\+w* abono \+w sobre|strong="H5921"\+w* \+w la|strong="H5921"\+w* superficie \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra.\wj*  
\v 3 \wj \+w El|strong="H3605"\+w* remanente \+w que|strong="H4480"\+w* \+w quede|strong="H7604"\+w* \+w de|strong="H4480"\+w* \+w toda|strong="H3605"\+w* \+w esta|strong="H2063"\+w* \+w perversa|strong="H7451"\+w* \+w familia|strong="H4940"\+w* preferirá \+w la|strong="H2063"\+w* \+w muerte|strong="H4194"\+w* y no \+w la|strong="H2063"\+w* \+w vida|strong="H2416"\+w* \+w en|strong="H4480"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H3605"\+w* \+w lugares|strong="H4725"\+w* \+w a|strong="H3068"\+w* \+w donde|strong="H8033"\+w* \+w Yo|strong="H4480"\+w* \+w los|strong="H3605"\+w* eche, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H4480"\w* las huestes.   
\p
\v 4 Les dirás: \wj \+nd \+w Yavé|strong="H3068"\+w*\+nd* dice: \+w El|strong="H5307"\+w* \+w que|strong="H3808"\+w* \+w cae|strong="H5307"\+w*, ¿\+w no|strong="H3808"\+w* \+w se|strong="H3808"\+w* \+w volverá|strong="H7725"\+w* \+w a|strong="H3068"\+w* \+w levantar|strong="H6965"\+w*? \+w El|strong="H5307"\+w* \+w que|strong="H3808"\+w* \+w se|strong="H3808"\+w* desvía, ¿\+w no|strong="H3808"\+w* \+w se|strong="H3808"\+w* devuelve?\wj*  
\v 5 ¿\w Por|strong="H4069"\w* \w qué|strong="H5971"\w* apostata \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, Jerusalén, con \w perpetua|strong="H5329"\w* apostasía? \w Se|strong="H5971"\w* aferran al engaño, rehúsan regresar.  
\v 6 \w Oí|strong="H8085"\w* \w atentamente|strong="H8085"\w* \w y|strong="H5921"\w* \w escuché|strong="H7181"\w*. \w No|strong="H3808"\w* \w hablan|strong="H1696"\w* \w rectamente|strong="H3651"\w*. \w No|strong="H3808"\w* hay \w quien|strong="H4100"\w* \w se|strong="H5921"\w* arrepienta \w de|strong="H5921"\w* su perversidad \w y|strong="H5921"\w* \w diga|strong="H1696"\w*: ¿\w Qué|strong="H4100"\w* \w hice|strong="H6213"\w*? \w Cada|strong="H3605"\w* \w cual|strong="H4100"\w* \w se|strong="H5921"\w* apartó \w por|strong="H5921"\w* su \w camino|strong="H7451"\w*, \w como|strong="H4100"\w* \w caballo|strong="H5483"\w* \w que|strong="H4100"\w* arremete \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w batalla|strong="H4421"\w*.  
\v 7 \w Aun|strong="H1571"\w* \w la|strong="H1571"\w* cigüeña en \w el|strong="H1571"\w* \w cielo|strong="H8064"\w* \w conoce|strong="H3045"\w* sus \w tiempos|strong="H4150"\w*. \w La|strong="H1571"\w* tórtola, \w la|strong="H1571"\w* golondrina \w y|strong="H1571"\w* \w la|strong="H1571"\w* grulla observan \w el|strong="H1571"\w* \w tiempo|strong="H6256"\w* \w de|strong="H5971"\w* su migración, pero mi \w pueblo|strong="H5971"\w* \w no|strong="H3808"\w* \w conoce|strong="H3045"\w* \w la|strong="H1571"\w* \w Ordenanza|strong="H4941"\w* \w de|strong="H5971"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 8 ¿Cómo dicen: Somos \w sabios|strong="H2450"\w*, la \w Ley|strong="H8451"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* está con nosotros? \w Ciertamente|strong="H2009"\w* la pluma \w engañosa|strong="H8267"\w* del \w escriba|strong="H5608"\w* la convirtió en \w mentira|strong="H8267"\w*.  
\v 9 \w Los|strong="H2450"\w* \w sabios|strong="H2450"\w* \w se|strong="H4100"\w* avergonzaron. \w Se|strong="H4100"\w* espantaron y fueron consternados. \w Ciertamente|strong="H2009"\w* aborrecieron \w la|strong="H2451"\w* \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. ¿\w Cuál|strong="H4100"\w* \w sabiduría|strong="H2451"\w* \w tienen|strong="H2451"\w*?  
\v 10 \wj \+w Por|strong="H3588"\+w* \+w tanto|strong="H3651"\+w*, \+w daré|strong="H5414"\+w* sus esposas \+w a|strong="H3068"\+w* otros, \+w y|strong="H3588"\+w* sus \+w campos|strong="H7704"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H3605"\+w* conquistadores, \+w porque|strong="H3588"\+w* \+w cada|strong="H3605"\+w* uno, \+w desde|strong="H5704"\+w* \+w el|strong="H3588"\+w* \+w más|strong="H3588"\+w* \+w pequeño|strong="H6996"\+w* \+w hasta|strong="H5704"\+w* \+w el|strong="H3588"\+w* \+w más|strong="H3588"\+w* \+w grande|strong="H1419"\+w*, persigue \+w la|strong="H3588"\+w* \+w avaricia|strong="H1215"\+w*. \+w Todos|strong="H3605"\+w* practican \+w el|strong="H3588"\+w* \+w engaño|strong="H8267"\+w* \+w desde|strong="H5704"\+w* \+w el|strong="H3588"\+w* \+w profeta|strong="H5030"\+w* \+w hasta|strong="H5704"\+w* \+w el|strong="H3588"\+w* \+w sacerdote|strong="H3548"\+w*.\wj*  
\v 11 \wj \+w Curan|strong="H7495"\+w* \+w con|strong="H5921"\+w* \+w liviandad|strong="H7043"\+w* \+w el|strong="H5921"\+w* \+w quebrantamiento|strong="H7667"\+w* \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w hija|strong="H1323"\+w* \+w de|strong="H5921"\+w* \+w mi|strong="H5921"\+w* \+w pueblo|strong="H5971"\+w*, pues dicen: ¡\+w Paz|strong="H7965"\+w*! ¡\+w Paz|strong="H7965"\+w*! \+w Y|strong="H3068"\+w* \+w no|strong="H5921"\+w* hay \+w paz|strong="H7965"\+w*.\wj*  
\v 12 \wj ¿\+w Se|strong="H3045"\+w* avergonzaron \+w cuando|strong="H3588"\+w* \+w cometieron|strong="H6213"\+w* repugnancia? \+w Ciertamente|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w se|strong="H3045"\+w* avergonzaron \+w ni|strong="H3808"\+w* \+w supieron|strong="H3045"\+w* ruborizarse. \+w Por|strong="H3588"\+w* \+w tanto|strong="H3651"\+w*, \+w caerán|strong="H5307"\+w* \+w con|strong="H3588"\+w* \+w los|strong="H3588"\+w* \+w que|strong="H3588"\+w* \+w caigan|strong="H5307"\+w*. \+w En|strong="H3588"\+w* \+w el|strong="H3588"\+w* \+w tiempo|strong="H6256"\+w* \+w de|strong="H3588"\+w* \+w su|strong="H3588"\+w* castigo \+w tropezarán|strong="H3782"\+w*, \wj*dice \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 13 \wj En verdad \+w los|strong="H1992"\+w* acabaré, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \wj No habrá racimos en la \+w vid|strong="H1612"\+w*, ni \+w higos|strong="H8384"\+w* en la higuera. Hasta \+w las|strong="H1992"\+w* \+w hojas|strong="H5929"\+w* \+w se|strong="H1992"\+w* marchitarán, y \+w lo|strong="H1992"\+w* \+w que|strong="H1992"\+w* \+w les|strong="H1992"\+w* \+w di|strong="H5414"\+w* \+w pasará|strong="H5674"\+w* \+w de|strong="H5414"\+w* \+w ellos|strong="H1992"\+w*.\wj*   
\p
\v 14 ¿\w Por|strong="H5921"\w* \w qué|strong="H3588"\w* \w nos|strong="H5921"\w* quedamos \w aquí|strong="H8033"\w* \w sentados|strong="H3427"\w*? Reúnanse \w y|strong="H3588"\w* entremos \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* fortificadas \w y|strong="H3588"\w* perezcamos \w allí|strong="H8033"\w*, \w porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd* \w nos|strong="H5921"\w* lleva \w a|strong="H3068"\w* perecer. \w Nos|strong="H5921"\w* dio \w a|strong="H3068"\w* \w beber|strong="H8248"\w* \w agua|strong="H4325"\w* envenenada, \w porque|strong="H3588"\w* \w pecamos|strong="H2398"\w* \w contra|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 15 \w Esperábamos|strong="H6960"\w* \w paz|strong="H7965"\w* y no hay tal \w bien|strong="H2896"\w*, \w día|strong="H6256"\w* \w de|strong="H6256"\w* sanidad, pero \w aquí|strong="H2009"\w* está el terror.  
\v 16 Desde \w Dan|strong="H1835"\w* se \w oye|strong="H8085"\w* \w el|strong="H3605"\w* relincho de \w los|strong="H3427"\w* \w caballos|strong="H5483"\w*. \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra se estremece ante \w el|strong="H3605"\w* \w estruendo|strong="H6963"\w* del relincho de sus corceles. Llegan y devoran \w la|strong="H3605"\w* tierra y \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* hay en \w ella|strong="H3605"\w*, \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* y sus \w habitantes|strong="H3427"\w*.  
\v 17 \wj \+w Porque|strong="H3588"\+w* \+w ciertamente|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* \+w envío|strong="H7971"\+w* contra ustedes \+w serpientes|strong="H5175"\+w*, víboras, contra las cuales \+w no|strong="H3588"\+w* hay encantamiento, \+w y|strong="H3588"\+w* \+w los|strong="H3588"\+w* morderán,\wj* \w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\s1 Lamento de Jeremías  
\p
\v 18 Aunque tenga consuelo \w en|strong="H5921"\w* \w la|strong="H5921"\w* aflicción, \w mi|strong="H5921"\w* \w corazón|strong="H3820"\w* \w desfallece|strong="H1742"\w* \w dentro|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*.  
\v 19 \w Ciertamente|strong="H2009"\w* escucho el lamento \w de|strong="H5971"\w* la \w hija|strong="H1323"\w* \w de|strong="H5971"\w* \w mi|strong="H2009"\w* \w pueblo|strong="H5971"\w* desde una tierra \w lejana|strong="H4801"\w*. ¿No está \nd \+w Yavé|strong="H3068"\+w*\nd* en \w Sion|strong="H6726"\w*? ¿Su \w Rey|strong="H4428"\w* no está en ella?  
\p \wj ¿\+w Por|strong="H4069"\+w* \+w qué|strong="H5971"\+w* me provocaron con imágenes \+w de|strong="H5971"\+w* talla, con \+w ídolos|strong="H6456"\+w* extraños?\wj*   
\p
\v 20 \w Pasó|strong="H5674"\w* la cosecha. \w Se|strong="H3808"\w* \w acabó|strong="H3615"\w* \w el|strong="H5674"\w* \w verano|strong="H7019"\w* y nosotros \w no|strong="H3808"\w* fuimos salvados.   
\p
\v 21 \w Por|strong="H5921"\w* \w el|strong="H5921"\w* \w quebrantamiento|strong="H7667"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* estoy \w quebrantado|strong="H7665"\w*. Estoy \w entenebrecido|strong="H6937"\w*. \w El|strong="H5921"\w* \w espanto|strong="H8047"\w* \w me|strong="H5921"\w* arrebató.  
\v 22 ¿\w No|strong="H3808"\w* hay \w bálsamo|strong="H6875"\w* \w en|strong="H3588"\w* \w Galaad|strong="H1568"\w*? ¿\w No|strong="H3808"\w* hay \w médico|strong="H7495"\w* \w allí|strong="H8033"\w*? ¿\w Entonces|strong="H3588"\w*, \w por|strong="H3588"\w* \w qué|strong="H3588"\w* \w no|strong="H3808"\w* hay sanidad \w para|strong="H3588"\w* \w la|strong="H3588"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* mi \w pueblo|strong="H5971"\w*?   
\c 9  
\p
\v 1 ¡\w Oh|strong="H4310"\w*, \w que|strong="H3588"\w* mi cabeza fuera agua \w y|strong="H3588"\w* \w mis|strong="H5414"\w* ojos fuentes \w de|strong="H3588"\w* lágrimas \w para|strong="H3588"\w* llorar \w de|strong="H3588"\w* día \w y|strong="H3588"\w* \w de|strong="H3588"\w* noche \w por|strong="H3588"\w* \w los|strong="H3605"\w* asesinados \w de|strong="H3588"\w* \w la|strong="H3588"\w* hija \w de|strong="H3588"\w* mi \w pueblo|strong="H5971"\w*!  
\v 2 ¡Quién \w me|strong="H3588"\w* diera una posada \w de|strong="H3588"\w* caminantes \w en|strong="H3588"\w* \w el|strong="H3588"\w* desierto \w para|strong="H3588"\w* abandonar \w a|strong="H3068"\w* mi pueblo \w y|strong="H3588"\w* apartarme \w de|strong="H3588"\w* ellos! \w Porque|strong="H3588"\w* todos ellos \w son|strong="H3588"\w* adúlteros, congregación \w de|strong="H3588"\w* traidores.  
\v 3 \wj Disponen \+w su|strong="H3588"\+w* lengua \+w como|strong="H3588"\+w* arco. Lanzan mentiras \+w y|strong="H3588"\+w* \+w no|strong="H3588"\+w* \+w se|strong="H5921"\+w* fortalecieron \+w para|strong="H5921"\+w* \+w la|strong="H5921"\+w* verdad \+w en|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra. \+w Porque|strong="H3588"\+w* proceden \+w de|strong="H5921"\+w* mal \+w en|strong="H5921"\+w* mal \+w y|strong="H3588"\+w* \+w no|strong="H3588"\+w* \+w me|strong="H5921"\+w* conocen,\wj* dice \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 4 ¡\wj Cuídese cada uno \+w de|strong="H3811"\+w* su \+w prójimo|strong="H7453"\+w*! \+w No|strong="H3808"\+w* tenga confianza en algún hermano, \+w porque|strong="H3808"\+w* todo hermano suplanta, y todo \+w prójimo|strong="H7453"\+w* anda con calumnias.\wj*  
\v 5 \wj Cada uno engaña \+w a|strong="H3068"\+w* su prójimo y \+w no|strong="H3985"\+w* habla verdad. Adiestraron su lengua para la mentira, y \+w se|strong="H3045"\+w* pervierten hasta \+w el|strong="H3427"\+w* cansancio.\wj*  
\v 6 \wj \+w Su|strong="H3588"\+w* morada \+w está|strong="H3651"\+w* \+w en|strong="H3588"\+w* medio del engaño, \+w y|strong="H3588"\+w* rehúsan conocerme \+w a|strong="H3068"\+w* \+w causa|strong="H6440"\+w* del engaño, \wj*dice \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 7 \wj Por tanto, Jerusalén es una pila de escombros y una guarida de chacales, y las ciudades de Judá, una desolación sin habitante. \wj*\nd \+w Yavé|strong="H3068"\+w*\nd* de las huestes \w dice|strong="H1696"\w*: \wj Ciertamente Yo los fundiré y los probaré. ¿De cuál otra manera procedo con la hija de mi pueblo?\wj*  
\v 8 \wj Su lengua \+w es|strong="H2088"\+w* flecha mortal \+w que|strong="H3808"\+w* habla engaño. \+w Con|strong="H5921"\+w* su boca hablan \+w de|strong="H5921"\+w* paz \+w con|strong="H5921"\+w* su prójimo, pero \+w dentro|strong="H5921"\+w* \+w de|strong="H5921"\+w* \+w él|strong="H5921"\+w* ponen emboscada.\wj*  
\v 9 \wj ¿\+w No|strong="H3808"\+w* debo castigar estas cosas? \wj*dice \nd \+w Yavé|strong="H3068"\+w*\nd*. \wj \+w De|strong="H5921"\+w* una nación \+w como|strong="H3588"\+w* \+w ésta|strong="H5921"\+w*, ¿\+w no|strong="H3808"\+w* \+w se|strong="H5921"\+w* vengará \+w mi|strong="H5921"\+w* alma?\wj*   
\p
\v 10 \wj \+w Por|strong="H5414"\+w* las montañas levantaré \+w mi|strong="H3389"\+w* lamento y \+w mi|strong="H3389"\+w* llanto \+w por|strong="H5414"\+w* \+w los|strong="H3427"\+w* pastizales del desierto porque \+w están|strong="H3427"\+w* desolados. \+w No|strong="H1097"\+w* hay quien pase, \+w ni|strong="H1097"\+w* se oye \+w el|strong="H3427"\+w* bramido del ganado. Desde las aves del cielo \+w hasta|strong="H1097"\+w* las bestias huyeron. Todos se fueron.\wj*  
\v 11 \wj Convertiré \+w a|strong="H3068"\+w* Jerusalén \+w en|strong="H5921"\+w* una pila \+w de|strong="H5921"\+w* escombros \+w y|strong="H5921"\+w* una guarida \+w de|strong="H5921"\+w* chacales, \+w y|strong="H5921"\+w* \+w a|strong="H3068"\+w* \+w las|strong="H5921"\+w* ciudades \+w de|strong="H5921"\+w* Judá \+w en|strong="H5921"\+w* una desolación \+w sin|strong="H1097"\+w* habitante.\wj*   
\s1 Profecía sobre la dispersión  
\p
\v 12 ¿Quién es un hombre sabio \w que|strong="H3808"\w* \w entienda|strong="H8085"\w* esto? ¿\w Y|strong="H3068"\w* \w a|strong="H3068"\w* quién habló \w la|strong="H5921"\w* boca \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w lo|strong="H3808"\w* declare? ¿\w Por|strong="H5921"\w* \w qué|strong="H3808"\w* pereció \w la|strong="H5921"\w* tierra? \w Fue|strong="H1980"\w* asolada \w como|strong="H5921"\w* un desierto, \w y|strong="H5921"\w* \w no|strong="H3808"\w* hay quien pase \w por|strong="H5921"\w* \w ella|strong="H5921"\w*.  
\v 13 \nd \+w Yavé|strong="H3068"\+w*\nd* dijo: \wj Porque abandonaron la Ley que puse delante de ellos. No escucharon mi voz, ni andan según ella,\wj*  
\v 14 \wj sino andan tras la dureza \+w de|strong="H5971"\+w* su corazón \+w y|strong="H3541"\+w* tras los baales, \+w lo|strong="H2088"\+w* cual les enseñaron sus antepasados.\wj*  
\v 15 \w Por|strong="H5704"\w* tanto, \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H5704"\w* \w las|strong="H1992"\w* huestes, \nd ʼElohim\nd* \w de|strong="H5704"\w* Israel, dice: \wj Ciertamente Yo daré \+w a|strong="H3068"\+w* comer ajenjo \+w a|strong="H3068"\+w* este \+w pueblo|strong="H1992"\+w* \+w y|strong="H5704"\+w* \+w les|strong="H1992"\+w* daré \+w a|strong="H3068"\+w* beber agua \+w con|strong="H5704"\+w* hiel.\wj*  
\v 16 \wj \+w Los|strong="H2450"\+w* dispersaré entre naciones \+w que|strong="H3541"\+w* ellos no conocieron ni sus antepasados. \+w Enviaré|strong="H7971"\+w* la espada tras ellos hasta exterminarlos.\wj*   
\p
\v 17 \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes dice: \wj Atiendan \+w y|strong="H5921"\+w* llamen \+w a|strong="H3068"\+w* \+w las|strong="H5921"\+w* plañideras \+w para|strong="H5921"\+w* \+w que|strong="H5921"\+w* vengan. Envíen \+w a|strong="H3068"\+w* llamar \+w a|strong="H3068"\+w* \+w las|strong="H5921"\+w* \+w que|strong="H5921"\+w* son expertas \+w para|strong="H5921"\+w* \+w que|strong="H5921"\+w* vengan.\wj*  
\v 18 \w Que|strong="H3588"\w* se apresuren \w y|strong="H3588"\w* prorrumpan \w en|strong="H3588"\w* lamento \w por|strong="H3588"\w* nosotros \w para|strong="H3588"\w* \w que|strong="H3588"\w* nuestros ojos se deshagan \w en|strong="H3588"\w* lágrimas \w y|strong="H3588"\w* nuestros párpados destilen agua.  
\v 19 \w Porque|strong="H3588"\w* \w en|strong="H3588"\w* Sion fue oída una voz \w de|strong="H3588"\w* lamento: ¡\w Cómo|strong="H3588"\w* somos arruinados! Somos sometidos \w a|strong="H3068"\w* gran vergüenza \w porque|strong="H3588"\w* abandonamos \w la|strong="H3588"\w* tierra, \w pues|strong="H3588"\w* nuestras residencias fueron destruidas.   
\p
\v 20 ¡Escuchen, oh mujeres, \w la|strong="H3588"\w* Palabra \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*! ¡Reciba \w su|strong="H3588"\w* oído \w la|strong="H3588"\w* Palabra \w de|strong="H3588"\w* \w su|strong="H3588"\w* boca! Enseñen lamentaciones \w a|strong="H3068"\w* sus hijas, cantos fúnebres, cada una \w a|strong="H3068"\w* \w su|strong="H3588"\w* vecina.  
\v 21 \w Porque|strong="H5921"\w* \w la|strong="H5921"\w* muerte subió \w por|strong="H5921"\w* nuestras ventanas. Entró \w en|strong="H5921"\w* nuestros palacios. Arrebató \w a|strong="H3068"\w* \w los|strong="H5921"\w* niños \w en|strong="H5921"\w* \w la|strong="H5921"\w* calle \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* jóvenes \w en|strong="H5921"\w* \w las|strong="H5921"\w* plazas.  
\v 22 \wj Dí: \wj*\nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj \+w Los|strong="H2450"\+w* cadáveres caerán como abono sobre \+w la|strong="H2451"\+w* superficie del campo, como manojo detrás del \+w que|strong="H3541"\+w* cosecha, pero nadie \+w los|strong="H2450"\+w* recogerá.\wj*  
\v 23 \nd \+w Yavé|strong="H3068"\+w*\nd* \w dice|strong="H5002"\w*: \wj \+w No|strong="H6213"\+w* \+w se|strong="H3045"\+w* \+w alabe|strong="H1984"\+w* \+w el|strong="H3588"\+w* sabio \+w en|strong="H3588"\+w* \+w su|strong="H3588"\+w* \+w sabiduría|strong="H3045"\+w*, ni \+w el|strong="H3588"\+w* valiente \+w en|strong="H3588"\+w* \+w su|strong="H3588"\+w* valentía, ni \+w el|strong="H3588"\+w* rico \+w en|strong="H3588"\+w* sus riquezas.\wj*  
\v 24 \wj Sino alábese \+w en|strong="H5921"\+w* esto \+w el|strong="H5921"\+w* \+w que|strong="H5921"\+w* \+w se|strong="H5921"\+w* alabe: \+w En|strong="H5921"\+w* entenderme \+w y|strong="H5921"\+w* conocerme, \+w que|strong="H5921"\+w* \+w Yo|strong="H2009"\+w* soy \+nd \+w Yavé|strong="H3068"\+w*\+nd*, \+w Quien|strong="H3605"\+w* practica misericordia, juicio \+w y|strong="H5921"\+w* justicia \+w en|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra, \+w porque|strong="H5921"\+w* quiero estas cosas, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 25 \wj \+w En|strong="H5921"\+w* verdad, vienen días,\wj* dice \nd \+w Yavé|strong="H3068"\+w*\nd*, \wj \+w cuando|strong="H3588"\+w* castigaré \+w a|strong="H3068"\+w* \+w todo|strong="H3605"\+w* circuncidado \+w y|strong="H3588"\+w* \+w a|strong="H3068"\+w* \+w todo|strong="H3605"\+w* \+w incircunciso|strong="H6189"\+w*: \wj*  
\v 26 \wj \+w A|strong="H3068"\+w* Egipto, \+w a|strong="H3068"\+w* Judá y \+w a|strong="H3068"\+w* Edom, \+w a|strong="H3068"\+w* los hijos de Amón y \+w a|strong="H3068"\+w* Moab, \+w a|strong="H3068"\+w* todos los que se rapan las sienes y \+w a|strong="H3068"\+w* los habitantes del desierto. Porque todas las naciones son incircuncisas, y toda la Casa de Israel es incircuncisa de corazón.\wj*   
\c 10  
\s1 Los \tl ʼelohim\tl* de las naciones  
\p
\v 1 \w Oigan|strong="H8085"\w* \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w que|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w les|strong="H5921"\w* \w dice|strong="H1696"\w*, oh \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 2 \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj \+w No|strong="H3588"\+w* aprendan \+w el|strong="H3588"\+w* \+w camino|strong="H1870"\+w* \+w de|strong="H3588"\+w* \+w las|strong="H1992"\+w* \+w naciones|strong="H1471"\+w*, ni tengan temor \+w a|strong="H3068"\+w* \+w las|strong="H1992"\+w* señales del \+w cielo|strong="H8064"\+w*, \+w aunque|strong="H3588"\+w* \+w las|strong="H1992"\+w* \+w naciones|strong="H1471"\+w* \+w las|strong="H1992"\+w* \+w teman|strong="H2865"\+w*.\wj*  
\v 3 \w Porque|strong="H3588"\w* las costumbres \w de|strong="H3588"\w* \w los|strong="H1931"\w* \w pueblos|strong="H5971"\w* \w son|strong="H3588"\w* \w vanidad|strong="H1892"\w*. Cortan un \w árbol|strong="H6086"\w* del \w bosque|strong="H3293"\w*, \w la|strong="H1931"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* un \w artífice|strong="H2796"\w* \w lo|strong="H1931"\w* labra \w con|strong="H3588"\w* azuela,  
\v 4 \w lo|strong="H3808"\w* adornan con \w plata|strong="H3701"\w* y \w oro|strong="H2091"\w*, y \w lo|strong="H3808"\w* sujetan con clavos y martillo para \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* caiga.  
\v 5 \w Son|strong="H3588"\w* \w como|strong="H3588"\w* un espantapájaros \w en|strong="H3588"\w* un huerto \w de|strong="H3588"\w* pepinos: \w no|strong="H3808"\w* \w hablan|strong="H1696"\w*. \w Son|strong="H3588"\w* llevados \w porque|strong="H3588"\w* \w no|strong="H3808"\w* pueden andar. \w No|strong="H3808"\w* tengan \w temor|strong="H3372"\w* \w a|strong="H3068"\w* \w ellos|strong="H1992"\w*, \w porque|strong="H3588"\w* \w ni|strong="H3808"\w* pueden hacer \w mal|strong="H7489"\w*. \w Ni|strong="H3808"\w* \w para|strong="H3588"\w* hacer \w bien|strong="H3190"\w* \w tienen|strong="H1992"\w* poder.   
\p
\v 6 ¡Oh \nd \+w Yavé|strong="H3068"\+w*\nd*, nadie hay \w como|strong="H3644"\w* Tú! ¡\w Grande|strong="H1419"\w* eres, \w grande|strong="H1419"\w* es tu \w Nombre|strong="H8034"\w* en poder!  
\v 7 ¿\w Quién|strong="H4310"\w* \w no|strong="H3808"\w* \w te|strong="H3588"\w* \w temerá|strong="H3372"\w*, \w oh|strong="H4310"\w* \w Rey|strong="H4428"\w* \w de|strong="H3588"\w* las \w naciones|strong="H1471"\w*? \w Porque|strong="H3588"\w* \w a|strong="H3068"\w* Ti \w se|strong="H3808"\w* debe \w temor|strong="H3372"\w*, \w pues|strong="H3588"\w* \w entre|strong="H3808"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w sabios|strong="H2450"\w* \w de|strong="H3588"\w* las \w naciones|strong="H1471"\w* \w y|strong="H3588"\w* \w entre|strong="H3808"\w* \w todos|strong="H3605"\w* sus \w reinos|strong="H4438"\w* \w no|strong="H3808"\w* \w hay|strong="H3372"\w* \w alguno|strong="H3605"\w* comparable \w a|strong="H3068"\w* Ti.  
\v 8 Todos son estúpidos \w y|strong="H1197"\w* necios con \w su|strong="H1931"\w* disciplina de engaño, \w su|strong="H1931"\w* ídolo de \w madera|strong="H6086"\w*.  
\v 9 Traen \w plata|strong="H3701"\w* batida de \w Tarsis|strong="H8659"\w* y \w oro|strong="H2091"\w* de Ufaz, \w obra|strong="H4639"\w* de orífice y de \w la|strong="H3605"\w* \w mano|strong="H3027"\w* del \w fundidor|strong="H6884"\w*. Su ropa \w es|strong="H3027"\w* de tela azul y púrpura, \w obra|strong="H4639"\w* de \w hábil|strong="H2450"\w* artesano.  
\v 10 Pero \nd \+w Yavé|strong="H3068"\+w*\nd* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \nd ʼElohim\nd* verdadero. ¡\w Él|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \nd ʼElohim\nd* \w viviente|strong="H2416"\w* y \w el|strong="H1931"\w* \w Rey|strong="H4428"\w* \w eterno|strong="H5769"\w*! Con \w su|strong="H1931"\w* \w ira|strong="H7110"\w* \w se|strong="H1931"\w* estremece \w la|strong="H1931"\w* tierra. Las \w naciones|strong="H1471"\w* \w no|strong="H3808"\w* pueden soportar \w su|strong="H1931"\w* \w furor|strong="H2195"\w*.   
\p
\v 11 Les dirán: Los \nd ʼela\nd* \w que|strong="H1768"\w* \w no|strong="H3809"\w* \w hicieron|strong="H5648"\w* el \w cielo|strong="H8065"\w* \w ni|strong="H3809"\w* la tierra desaparecerán \w de|strong="H4481"\w* la tierra \w y|strong="H3809"\w* \w de|strong="H4481"\w* \w debajo|strong="H8460"\w* \w del|strong="H4481"\w* \w cielo|strong="H8065"\w*.  
\v 12 \add Él\add* es \w Quien|strong="H6213"\w* \w hizo|strong="H6213"\w* \w la|strong="H2451"\w* tierra con su \w poder|strong="H3581"\w*, \w Quien|strong="H6213"\w* estableció \w el|strong="H6213"\w* \w mundo|strong="H8398"\w* con su \w sabiduría|strong="H2451"\w* y \w extendió|strong="H5186"\w* los \w cielos|strong="H8064"\w* con su \w inteligencia|strong="H8394"\w*.  
\v 13 Cuando \w Él|strong="H6213"\w* emite su \w voz|strong="H6963"\w*, hay una abundancia \w de|strong="H5414"\w* \w agua|strong="H4325"\w* \w en|strong="H3318"\w* \w el|strong="H6213"\w* \w cielo|strong="H8064"\w*. Eleva la neblina desde \w lo|strong="H6213"\w* \w último|strong="H7097"\w* \w de|strong="H5414"\w* la tierra. \w Hace|strong="H6213"\w* los \w relámpagos|strong="H1300"\w* \w para|strong="H5414"\w* la \w lluvia|strong="H4306"\w* y \w saca|strong="H3318"\w* \w el|strong="H6213"\w* \w viento|strong="H7307"\w* \w de|strong="H5414"\w* sus depósitos.  
\v 14 \w Todo|strong="H3605"\w* hombre \w es|strong="H3588"\w* estúpido, \w sin|strong="H3808"\w* \w conocimiento|strong="H1847"\w*. \w Todo|strong="H3605"\w* \w fundidor|strong="H6884"\w* \w es|strong="H3588"\w* avergonzado \w por|strong="H3588"\w* una \w imagen|strong="H6459"\w*, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w imagen|strong="H6459"\w* moldeada \w es|strong="H3588"\w* falsedad. \w No|strong="H3808"\w* hay aliento \w en|strong="H3588"\w* \w ella|strong="H3605"\w*.  
\v 15 \w Obras|strong="H4639"\w* vanas y ridículas, \w que|strong="H6256"\w* perecerán en \w el|strong="H1992"\w* \w tiempo|strong="H6256"\w* \w de|strong="H6256"\w* \w su|strong="H1992"\w* castigo.  
\v 16 \w La|strong="H1931"\w* Porción \w de|strong="H3588"\w* \w Jacob|strong="H3290"\w* \w no|strong="H3808"\w* \w es|strong="H1931"\w* parecida \w a|strong="H3068"\w* \w ellas|strong="H1931"\w*, \w porque|strong="H3588"\w* \w Él|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* Hacedor \w de|strong="H3588"\w* \w todo|strong="H3605"\w*, \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w tribu|strong="H7626"\w* \w de|strong="H3588"\w* \w su|strong="H1931"\w* \w heredad|strong="H5159"\w*. ¡\nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H3588"\w* las huestes \w es|strong="H1931"\w* \w su|strong="H1931"\w* \w Nombre|strong="H8034"\w*!   
\s1 Asolamiento de Judá  
\p
\v 17 Recoge del suelo tu equipaje, tú que vives bajo asedio.  
\v 18 \w Porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj \+w Ciertamente|strong="H3588"\+w* \+w esta|strong="H2063"\+w* \+w vez|strong="H6471"\+w* lanzaré \+w a|strong="H3068"\+w* \+w los|strong="H1992"\+w* \+w habitantes|strong="H3427"\+w* \+w de|strong="H3588"\+w* \+w la|strong="H3588"\+w* tierra \+w con|strong="H3588"\+w* honda, \+w y|strong="H3588"\+w* \+w los|strong="H1992"\+w* afligiré \+w para|strong="H4616"\+w* \+w que|strong="H3588"\+w* \+w lo|strong="H1992"\+w* sientan.\wj*   
\p
\v 19 ¡Ay \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w quebrantamiento|strong="H7667"\w*! \w Mi|strong="H5921"\w* herida \w es|strong="H2088"\w* incurable. Pero dije: Ciertamente \w ésta|strong="H2088"\w* \w es|strong="H2088"\w* \w mi|strong="H5921"\w* aflicción \w y|strong="H5921"\w* debo soportarla.  
\v 20 Mi tienda fue \w destruida|strong="H7703"\w* y \w todas|strong="H3605"\w* mis cuerdas están rotas. Se fueron mis \w hijos|strong="H1121"\w* y ya no están. \w Ya|strong="H3068"\w* no \w hay|strong="H5750"\w* \w quien|strong="H3605"\w* levante mi tienda, ni \w quien|strong="H3605"\w* extienda mis \w cortinas|strong="H3407"\w*.  
\v 21 \w Porque|strong="H3588"\w* \w los|strong="H5921"\w* \w pastores|strong="H7462"\w* \w se|strong="H5921"\w* embrutecieron \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w buscaron|strong="H1875"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w no|strong="H3808"\w* \w prosperaron|strong="H7919"\w* \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w su|strong="H3588"\w* rebaño \w se|strong="H5921"\w* dispersó.   
\p
\v 22 ¡Oigan un \w rumor|strong="H8052"\w*! ¡Viene un \w gran|strong="H1419"\w* tumulto de la tierra del \w norte|strong="H6828"\w* para convertir las \w ciudades|strong="H5892"\w* de \w Judá|strong="H3063"\w* en desolación y en guarida de chacales!  
\v 23 Oh \nd \+w Yavé|strong="H3068"\+w*\nd*, \w reconozco|strong="H3045"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* del hombre \w no|strong="H3808"\w* está \w en|strong="H3588"\w* \w él|strong="H3588"\w* mismo, \w ni|strong="H3808"\w* al hombre \w que|strong="H3588"\w* \w camina|strong="H1980"\w* corresponde dirigir sus propios \w pasos|strong="H6806"\w*.  
\v 24 Corrígeme, oh \nd \+w Yavé|strong="H3068"\+w*\nd*, pero con \w justicia|strong="H4941"\w*, \w no|strong="H6435"\w* con tu furor, pues me reducirás \w a|strong="H3068"\w* nada.  
\v 25 \w Derrama|strong="H8210"\w* tu \w furor|strong="H2534"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w pueblos|strong="H1471"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* \w conocen|strong="H3045"\w*, \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w invocan|strong="H7121"\w* tu \w Nombre|strong="H8034"\w*, \w porque|strong="H3588"\w* devoraron \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*. \w Lo|strong="H3808"\w* devoraron, \w lo|strong="H3808"\w* consumieron \w y|strong="H3588"\w* desolaron \w su|strong="H3588"\w* \w morada|strong="H5116"\w*.   
\c 11  
\s1 Violación del Pacto  
\p
\v 1 La \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*:  
\v 2 \wj \+w Oigan|strong="H8085"\+w* \+w las|strong="H5921"\+w* \+w Palabras|strong="H1697"\+w* \+w de|strong="H5921"\+w* \+w este|strong="H2063"\+w* \+w Pacto|strong="H1285"\+w*. \+w Hablen|strong="H1696"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H3427"\+w* hombres \+w de|strong="H5921"\+w* \+w Judá|strong="H3063"\+w* \+w y|strong="H5921"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H3427"\+w* \+w habitantes|strong="H3427"\+w* \+w de|strong="H5921"\+w* Jerusalén.\wj*  
