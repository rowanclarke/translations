\id MAN - Matupi Chin Standard Bible
\ide UTF-8
\h MANASSEH KAH THANGTHUINAH
\toc1 Manasseh kah Thangthuinah
\toc2 Manasseh
\toc3 Man
\mt1 MANASSEH
\mt4 Kah Thangthuinah
\im He thangthuinah he Judah manghai Manasseh kah hlohlai lung la ana pom uh. A ollung he bahoeng a then dongah hlangboel tlaivongnah tue (Reformation Age) vaengah tah Protestants rhoek long khaw laa la ana sak uh. Tedae hekah he Protestants, Roman Catholics neh Eastern Orthodox long khaw Bible dongah ana thum sak moenih.
\iot Sawt Yoeinah
\io1 Pathen olkhueh neh rhennah \ior (1-7)\ior*
\io1 Manasseh kah tholh phongnah \ior (8-15)\ior*
\c 1
\s1 Koehnah
\q1 
\v 1 Tlungthang Boeipa Aw
\q2 A pa rhoek kah Pathen
\q1 Abraham, Isaak neh Jakob neh
\q2 Amih a hlangdueng cadil rhoek kah Pathen aw,
\q1 
\v 2 Namah loh vaan neh diklai khaw
\q2 A pum la tlueptluep boeih na saii coeng.
\q1 
\v 3 Na olpaek ol neh tuitunli aka hinghoek tih,
\q2 tuidung aka khe tih te rhoek te
\q2 na rhim-om thangpom ming neh aka tlaeng,
\q1 
\v 4 Amah dongah a cungkuem he thuen tih,
\q2 Na sarhi dongah khaw let uh.
\q1 
\v 5 Na rhuepomnah khaw noeng uh pawt tih
\q2 na kosi dongah hlangtholh rhoek khaw ueh pawh.
\q1 
\v 6 Te vaengah na rhennah olkhueh tah
\q2 tae lek pawt tih khe lek pawh.
\q2 
\v 7 Namah tah Boeipa Khohni la na om,
\q1 thinphoei neh, uehnah neh, sitlohnah la na om.
\q2 Aw Boeipa na thennah a len dongah,
\q1 Na taengah aka tholh rhoek ham pataeng,
\q2 Yutnah neh khodawkngainah ol na khueh.
\q2 Na rhennah hlangping lakli ah hlangtholh rhoek ham
\q1 yutnah te na khueh pah coeng.
\q2 Boei paw aw te daengah ni,
\q2 amih khaw a daem uh pai eh.
\q1 
\v 8 Te dongah Boeipa aw, nang tah duengnah Pathen ni,
\q2 hlangdueng kah yutnah te na tuek het pawt nim?
\q1 Abraham, Isaak neh Jakob tah na taengah tholh pawt dae ta,
\q2 Kai hlang tholh ham he yutnah khaw nang khueh mai.
\s1 Tholh Phongnah
\q1 
\v 9 Tholnah ka saii he khaw tuitun \w laivin\w* lakah yet coeng,
\q2 Ka boekoek khaw pung tih, Boeipa aw, ping coeng.
\q1 Ka boethaenah khaw a pung khungdaeng dongah
\q2 Vaan hmuensang ke dang tih sawt ham ka koih moenih.
\q1 
\v 10 Thi pael loh kai muep n'nan coeng,
\q2 Ka tholhnah long khaw kai m'voeih coeng,
\q2 Ka loeihnah he om voel pawh.
\q1 Na kosi loh kai n'tluung he khaw,
\q2 na mikhmuh kah boethae ka saii dongah ni,
\q2 tueilaeh koi ka khueh tih boekoek khaw a yet dongah ni.
\s1 Tholhhlah Bihnah
\q1 
\v 11 Te dongah thinko khuklu ka sungkueng coeng,
\q2 na rhennah hamla nang kan phoe coeng.
\q1 
\v 12 Ka tholh coeng, Boeipa aw, ka tholh coeng.
\q2 Ka halangnah khaw ka ming coeng.
\q1 
\v 13 Lunghoih la nang kang khue,
\q2 Khodawk ngai mai, Boeipa aw, khodawk ngai mai,
\q2 Ka boekoeknah kongah he kai m'phae boel mai,
\q1 Kai taengah phat sai boel lamtah ka boethae khaw tung boel mai,
\q2 Diklai laedil hil ah tah kai m'boe sak aih boel mai,
\q1 Boeipa nang tah aka yut rhoek kah Pathen ni.
\q2 
\v 14 Ka khuiah na thennah te na phoe sak bitni,
\q1 Ka tingtawk pawt cakhaw na sitlonah loh kan nan khang bitni.
\q2 
\v 15 Ka hingnah tue khuiah tah nang phat kang koeh eh,
\q1 Vaan caem puei boeih kah miknoek khaw nang koehnah la om saeh,
\q2 Thangpomnah he namah kah yoeyah saeh. Amen. 
