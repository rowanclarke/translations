\q1  
\v 26 E tuvaila ivigaki yagila bomatu iuu, 
\q2 deli metoya ola peula ikatumwali yagila bolimila. 
\q1  
\v 27 E iwitali mauna baisa la tomota, 
\q2 e kala bidubadu makawala kanakenuva okawolawa. 
\q1  
\v 28 Ikapusisi olopola kabosikaiwa 
\q2 deli ikanuulaisi buliyoyova ikanupataisi. 
\q1  
\v 29 Mapaila baisa tomota ikamsi e ikomatasi. 
\q2 Yaubada isaiki matausina avaka magisi. 
\q1  
\v 30 Mitaga gala wala iukuwokuva kasi vikeiya, 
\q2 mapaila iyayosasi wala kamkwam, 
\q1  
