\id JER
\h  إِرْمِييَا 
\toc1  إِرْمِييَا 
\toc2  إِرْمِييَا 
\toc3 إِرْم. 
\mt1 إِرْمِييَا  
\c 1
\s1 ثَاڒَاغِيثْ ن أَربِّي خْ إِرْمِييَا  
\m
\v 1 أَوَاڒنْ ن إِرْمِييَا، مِّيسْ ن حِيلْقِييَا، زڭْ إِكهَّاننْ نِّي \add إِدْجَانْ\add* ذِي عَانَاثُوثْ، ذِي ثمُّورْثْ ن بِينْيَامِينْ،  
\v 2 ونِّي غَارْ د-يُوسَا وَاوَاڒْ ن سِيذِي ذڭْ وُوسَّانْ ن ؤُجدْجِيذْ يُوشِييَا، مِّيسْ ن أَمُونْ، أَجدْجِيذْ ن يَاهُوذَا، ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒطَّاشْ ن ڒحْكَامثْ نّسْ. \x ◘ \xo 1:‏2 \xt 2 إِج. 21‏:‏26؛ 22‏:‏1‏-‏23؛ 2 إِم. 34‏:‏1‏-‏30\x*  
\v 3 يُوسَا-د \add وَاوَاڒْ ن سِيذِي\add* غَارسْ ؤُڒَا ذڭْ وُوسَّانْ ن يَاهُويَاقِيمْ، مِّيسْ ن يُوشِييَا، أَجدْجِيذْ ن يَاهُوذَا، أَڒْ مَانِي إِكمّڒْ ؤُسڭّْوَاسْ وِيسّْ حِيطَاشْ ن صِيذْقِييَا، مِّيسْ ن يُوشِييَا، أَجدْجِيذْ ن يَاهُوذَا، أَڒَامِي د-إِوْينْ ؤُرْشَالِيمْ غَارْ لْمنْفَا ذڭْ ؤُيُورْ وِيسّْ خمْسَا. \x ◘ \xo 1:‏3 \xt 2 إِج. 23‏:‏34؛ 24‏:‏17؛ 25‏:‏8؛ 2 إِم. 36‏:‏4، 10‏-‏23؛ إِرْم. 52‏:‏1‏-‏30\x*   
\b  
\m
\v 4 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:  
\v 5 ”قْبڒْ مَا ڭِّيغْ شكْ ذ أَسيْمِي ذڭْ ؤُعذِّيسْ \add ن يمَّاشْ\add*، ثُوغَا سّْنغْ شكْ، ؤُ قْبڒْ مَا د-ثفّْغذْ زِي ڒمْڒَاوثْ، أَقَا سّْقدّْسغْ شكْ. نشّْ أَرشّْحغْ شكْ ذ أَنَابِي إِ ڒڭْنُوسْ.“ \x ◘ \xo 1:‏5 \xt ڭال. 1‏:‏15\x*  
\v 6 \add خنِّي\add* نِّيغْ: ”أَهْ، سِيذِي إِنُو، سِيذِي! خْزَارْ، نشّْ وَارْ زمَّارغْ أَذْ سِّيوْڒغْ، نشّْ \add عَاذْ\add* ذ أَحُوذْرِي.“ \x ◘ \xo 1:‏6 \xt ؤُف. 3؛ 4؛ 6‏:‏11، 29\x*  
\v 7 \add مَاشَا\add* سِيذِي يَارَّا-د خَافِي: ”وَارْ قَّارْ: ’نشّْ \add عَاذْ\add* ذ أَحُوذْرِي!‘، مَاغَارْ مَانِي مَا شكْ إِ غَا سّكّغْ أَذْ ذِينْ ثْرَاحذْ، ؤُ مَارَّا مِينْ ذ أَشْ غَا ؤُمُورغْ، أَذْ \add ث\add* ثِينِيذْ.  
\v 8 وَارْ زَّايْسنْ تّڭّْوذْ، مَاغَارْ نشّْ أَكِيذكْ، حِيمَا أَذْ شكْ فكّغْ!“، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. \x ◘ \xo 1:‏8 \xt أَعَوذ. 31‏:‏6، 8؛ ياش. 1‏:‏5؛ حِز. 3‏:‏9\x*  
\v 9 إِسّْوِيژّضْ سِيذِي أَفُوسْ نّسْ، إِحَاذَا أَقمُّومْ إِنُو ؤُشَا إِنَّا أَيِي سِيذِي: ”خْزَارْ، نشّْ ڭِّيغْ أَشْ أَوَاڒنْ إِنُو ذڭْ ؤُقمُّومْ نّشْ.\x ◘ \xo 1:‏9 \xt إِشا. 6‏:‏6، 7؛ إِرْم. 5‏:‏14\x*  
\v 10 خْزَارْ، ذڭْ وَاسّْ-أَ أَذْ شكْ أَرشّْحغْ خْ ڒڭْنُوسْ ؤُ خْ ثْڭلْذَاوِينْ، حِيمَا أَذْ ثْقڒْعذْ ؤُ أَذْ ثْهذْمذْ، حِيمَا أَذْ ثَاردّْدْجذْ ؤُ حِيمَا أَذْ ثْغضْڒذْ، حِيمَا أَذْ ثبْنِيذْ ؤُ أَذْ ثژُّوذْ.“ \x ◘ \xo 1:‏10 \xt إِرْم. 18‏:‏7؛ 2 كُور. 10‏:‏4، 5\x*   
\b  
\m
\v 11 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا: ”مِينْ ثتّْوَاڒِيذْ، إِرْمِييَا؟“ نشّْ أَرِّيغْ-د: ”نشّْ تّْوَاڒِيغْ إِشْثْ ن ثْسطَّا ن دْجوْزْ.“  
\v 12 إِنَّا أَيِي سِيذِي: ”شكْ ثژْرِيذْ نِيشَانْ، مَاغَارْ نشّْ تّْعسّغْ خْ وَاوَاڒْ إِنُو حِيمَا أَذْ ث ڭّغْ.“   
\b  
\m
\v 13 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي إِ ثْوَاڒَا وِيسّْ ثْنَاينْ، إِنَّا: ”مِينْ ثتّْوَاڒِيذْ؟“ نشّْ أَرِّيغْ-د: ”تّْوَاڒِيغْ ثَايْذَارْثْ إِتّْننَّانْ، أَبُوضْ نّسْ إِميّڒْ \add غَارْ ذَا\add* زِي شَّامَالْ.“  
\v 14 \add خنِّي\add* إِنَّا أَيِي سِيذِي: ”زِي شَّامَالْ إِ د غَا إِهْوَا ڒْغَارْ\add -أَ\add* خْ مَارَّا إِمزْذَاغْ ن ثمُّورْثْ. \x ◘ \xo 1:‏14 \xt إِرْم. 4‏:‏6\x*  
\v 15 مَاغَارْ، خْزَارْ، نشّْ أَذْ ڒَاغِيغْ خْ مَارَّا ڒَادْجَاثْ ن ثْڭلْذِيوِينْ ن شَامَالْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، ؤُشَا نِيثْنِي أَذْ د-أَسنْ ؤُشَا أَذْ سّْبدّنْ ڒكْرَاسِي نْسنْ غَارْ وَاذَافْ ن ثوُّورَا ن ؤُرْشَالِيمْ ؤُ ضِيدّْ إِ مَارَّا ڒحْيُوضْ نّسْ إِ ذ أَسْ د-إِنّْضنْ ؤُ ضِيدّْ إِ مَارَّا ثِيندَّامْ ن يَاهُوذَا. \x ◘ \xo 1:‏15 \xt إِرْم. 5‏:‏15؛ 6‏:‏22؛ 10‏:‏22؛ 52‏:‏4، 5\x*  
\v 16 نشّْ أَذْ خَاسنْ نطْقغْ مَارَّا ڒحْكَامَاثْ إِنُو، خْ مَارَّا ثُوعفّْنَا نْسنْ: أَقَا سمْحنْ ذَايِي ؤُشَا بخَّارنْ إِ إِربِّيثنْ نّغْنِي ؤُشَا سجْذنْ إِ مِينْ ڭِّينْ إِفَاسّنْ نْسنْ.  
\v 17 شكْ \add خنِّي\add*، حزّمْ ثِيجْعِينَّاثِينْ نّشْ ؤُشَا كَّارْ، بَارّحْ أَسنْ مَارَّا مِينْ ذ أَشْ غَا ؤُمُورغْ. وَارْ تّْنخْڒِيعْ زَّايْسنْ نِيغْ أَذْ شكْ سّْنخْڒْعغْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ.  
\v 18 خْزَارْ، نشّْ أَذْ شكْ ڭّغْ ذ ثَانْذِينْثْ إِفَارْينْ، ذ إِجّْ ن ؤُپِيلَارْ ن وُوزَّاڒْ ذ ڒحْيُوضْ ن نّْحَاسْ ضِيدّْ إِ مَارَّا ثَامُّورْثْ: ضِيدّْ إِ إِجدْجِيذنْ ن يَاهُوذَا، ضِيدّْ إِ ڒْحُوكَّامْ نّسْ، ضِيدّْ إِ إِكهَّاننْ نّسْ ؤُ ضِيدّْ إِ ڒْڭنْسْ ن ثمُّورْثْ. \x ◘ \xo 1:‏18 \xt إِرْم. 6‏:‏27؛ 15‏:‏20\x*  
\v 19 نِيثْنِي أَذْ كِيذكْ مّنْغنْ، \add مَاشَا\add* وَارْ شكْ أَرنّْينْ، مَاغَارْ نشّْ أَكِيذكْ، حِيمَا أَذْ شكْ فكّغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\b  
\b  
\m  
\c 2
\s1 ثَاسْڒِيثْ إِغْضَارنْ  
\m
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:  
\v 2 ”ؤُيُورْ، بَارّحْ ذڭْ ؤُمزُّوغْ ن ؤُرْشَالِيمْ، إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي: نشّْ تّْخَارَّاصغْ ذَايمْ، ذِي ثْمخْسِيوْثْ إِشوَّارنْ ن ثمْژِي نّمْ، خْ ثَايْرِي ن وُوسَّانْ ن ثْنخْضَابْثْ نّمْ، ؤُمِي د أَيِي د-ثضْفَارذْ ذِي ڒخْڒَا، ذِي ثمُّورْثْ ثَامسُّوشِيثْ.  
\v 3 إِسْرَائِيل ثُوغَا ذ أَمْقدّسْ إِ سِيذِي، ثَامزْوَارُوثْ ن صَّابثْ نّسْ. مَارَّا وِي زَّايسْ إِشّنْ، إِدَّاكّْوَاڒْ ذَايسْ ڒْعِيبْ،  إِوْضَا-د خَاسنْ ڒْغَارْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.‘ “   
\m
\v 4 ”سْڒمْ إِ وَاوَاڒْ ن سِيذِي، كنِّيوْ زِي ثَادَّارْثْ ن يَاعْقُوبْ، ذ مَارَّا ڒَادْجَاثْ ن ثَادَّارْثْ ن إِسْرَائِيل.  
\v 5 أَمُّو إِ إِقَّارْ سِيذِي: ’مَانْ ڒْغشّْ نِّي ذَايِي ؤُفِينْ ڒجْذُوذْ نْومْ أَڒَامِي خَافِي حيّْضنْ ؤُشَا ضْفَارنْ \add لْ-أَصْنَامْ\add* إِبطّْڒنْ ؤُشَا ذوْڒنْ \add سِيمَانْثْ نْسنْ\add* ذِي ڒْبَاطڒْ، \x ◘ \xo 2:‏5 \xt مِيخَا 6‏:‏3، 4\x*  
\v 6 وَارْ سّقْسِينْ: مَانِي إِدْجَا سِيذِي، ونِّي ذ أَنغْ د-إِسُّوفّْغنْ زِي مِيصْرَا، ونِّي ذ أَنغْ إِسّشْننْ أَبْرِيذْ ذِي ڒخْڒَا، خْ إِشْثْ ن ثمُّورْثْ ن ڒخْڒَا ذ إِخنْذْرَاقْ، خْ إِشْثْ ن ثمُّورْثْ ن ڒَاژَاغْ ذ ثِيڒِي ن ڒْموْثْ، خْ إِشْثْ ن ثمُّورْثْ وَارْ خَاسْ إِعْذُو ؤُڒَا ذ إِجّْ ؤُ وَارْ ذَايسْ إِزْذِيغْ ؤُڒَا ذ إِجّْ ن بْنَاذمْ؟  
\v 7 نشّْ إِوْيغْ كنِّيوْ غَارْ إِشْثْ ن ثمُّورْثْ إِسّغْمَاينْ حِيمَا أَذْ زَّايسْ ثشّمْ ڒْغِيدْجثْ ذ ڒْخَارْ. \add مَاشَا\add* ؤُمِي \add ذِينْ\add* ثِيوْضمْ، ثسّْخمْجمْ ثَامُّورْثْ إِنُو ؤُ ثَارِّيمْ ثَاسْغَارْثْ إِنُو ذ جّْعِيفشْثْ.  
\v 8 إِكهَّاننْ وَارْ سّقْسِينْ: مَانِي إِدْجَا سِيذِي؟، ؤُشَا إِنِّي ثُوغَا إِحطَّانْ شَّارِيعَا وَارْ ذ أَيِي سِّيننْ ؤُ إِمكْسَاونْعدُّونْ-د خَافِي ؤُ إِنَابِييّنْ تّْنَابّنْ س بَاعَالْ ؤُشَا ضْفَارنْ مِينْ وَارْ إِنفّْعنْ. \f ◼ \fr 2:‏8 \ft \+bd ’إِمكْسَاونْ‘\+bd* - نِيغْ ’إِنِيتْشَانْ‘.\f*  \x ◘ \xo 2:‏8 \xt رُوم. 2‏:‏20\x*  
\v 9 س ؤُيَا نشّْ أَذْ أَرْنِيغْ أَذْ مْشُوبّْشغْ أَكِيذْومْ، ؤُڒَا أَكْ-ذ إِحنْجِيرنْ ن إِحنْجِيرنْ نْومْ أَذْ مْشُوبّْشغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.‘ “   
\b  
\m
\v 10 ”ژْوَامْ غَارْ ثڭْزِيرِينْ ن أَيْثْ ن كِيتِّيمْ، أَقَا سكّمْ \add إِرقَّاسنْ\add* غَارْ قِيذَارْ، بيْثمْ ؤُشَا خْزَارمْ مْلِيحْ، مَا إِمْسَارْعمَّارْصْ أَمْ مَانْ أَيَا! \f ◼ \fr 2:‏10 \ft \+bd ’كِيتِّيمْ‘\+bd* - إِخْسْ أَذْ يِينِي ’قُوبْرُوسْ‘. \+bd ’قِيذَارْ‘\+bd* - إِشْثْ ن جِّيهثْ ن جّْوَايهْ ن ثمُّورْثْ ن وعْرَابنْ.\f*  
\v 11 مَاعمَّارْصْ إِبدّڒْ شَا ن ڒْڭنْسْ إِربِّيثنْ نّسْ، \add وَاخَّا\add* وَارْ دْجِينْ ذ إِربِّيثنْ؟ ڒْڭنْسْ إِنُو مَاشَا إِوْشَا ڒْعزّْ نّسْ ذڭْ ومْشَانْ ن مِينْ وَارْ إِنفّْعنْ. \x ◘ \xo 2:‏11 \xt إِزهد. 106‏:‏20\x*  
\v 12 إِڒِيمْ ذ إِڭْنَاونْ خْ مَانْ أَيَا، \add كنِّيوْ أَ\add* إِجنْوَانْ، ڭّْوذمْ، نْخڒْعمْ أَڒْ طَّارْفْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. \x ◘ \xo 2:‏12 \xt أَعَوذ. 32‏:‏1؛ إِشا. 1‏:‏2\x*  
\v 13 مَاغَارْ ڒْڭنْسْ إِنُو إِڭَّا ثْنَاينْ ن ڒعْيُوبْ: نشّْ، ڒْعُونْصَارْ ن وَامَانْ إِدَّارنْ، أَقَا سمْحنْ ذَايسْ مَاحنْذْ أَذْ غْزَانْ أَنُوثنْ إِ يِيخفْ نْسنْ، أَنُوثنْ س ثَازّشْثْ إِ إِخْوَانْ زڭْ وَامَانْ.\x ◘ \xo 2:‏13 \xt إِزْڒِي 4‏:‏15؛ إِرْم. 17‏:‏13\x*  
\v 14 مَا إِسْرَائِيل ذ إِسْمغْ نِيغْ ذ إِجّْ إِتّْوَارُو \add ذ إِسْمغْ\add* ذِي ثَادَّارْثْ؟ مَايمِّي إِذْوڒْ إِ زَّارْذثْ \add خنِّي\add*؟  
\v 15 سّْبُوعْرُوثنْ خَاسْ وَايْرَاذنْ إِمژْيَاننْ، ڭِّينْ أَذْ سْڒنْ إِ ثْمِيجَّا نْسنْ. نِيثْنِي أَرِّينْ ثَامُّورْثْ نّسْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ ثِيندَّامْ نّسْ تّْوَاسّْشمْضنْثْ أَڒَامِي وَارْ إِقِّيمْ إِزدّغْ ذَايْسنْثْ ؤُڒَا ذ إِجّْ. \x ◘ \xo 2:‏15 \xt إِشا. 5‏:‏29؛ إِرْم. 4‏:‏7\x*  
\v 16 عَاذْ حفّنْ أَيْثْ ن نُوفْ ذ ثَاحْفَانِيسْ أَشقُّوفْ ن ؤُزدْجِيفْ نّشْ.  
\v 17 مَا وَارْ ثڭِّيذْ شَا مَانَاوْيَا إِ يِيخفْ نّمْ، \add مِينْزِي\add* شمْ ثْسمْحذْ ذِي سِيذِي، أَربِّي نّمْ أَمْ نتَّا إِنْذحْ إِ شمْ ذڭْ وبْرِيذْ؟“   
\b  
\m
\v 18 ”ڒخُّو، مِينْ ذِينْ جَارْ أَمْ ذ جَارْ وبْرِيذْ ن مِيصْرَا مَاحنْذْ أَذْ ثسْوذْ \add ذِينْ\add* أَمَانْ زِي شِيخُورْ، \add زڭْ إِغْزَارْ ذ أَبَارْشَانْ\add*؟ مِينْ جَارْ أَمْ ذ جَارْ وبْرِيذْ ن أَشُّورْ أَڒَامِي \add ذِينْ\add* إِ غَا ثسْوذْ أَمَانْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*؟ \f ◼ \fr 2:‏18 \ft \+bd ’شِيخُورْ‘\+bd* - وَانِيثَا ذ إِسمْ نّغْنِي ذڭْ ومْشَانْ ن ’نِيلْ‘. شِيخُورْ إِخْسْ أَذْ يِينِي ’أَبَارْشَانْ‘، مِينْزِي إِغْزَارْ ن نِيلْ إِذْوڒْ ذ أَبَارْشَانْ زِي سِّيبّثْ ن ؤُبدْجَاعْ ذ ؤُبَارْيُوضْ إِ ذَايسْ إِدْجَانْ.\f*  \x ◘ \xo 2:‏18 \xt إِشا. 31‏:‏1\x*  
\v 19 ثُوعفّْنَا نّمْ أَذْ شكْ ثَاربَّا ؤُ إِبْرِيذنْ ن ؤُودَّارْ نّمْ أَذْ شمْ عَاقْبنْ. سّنْ ؤُ خْزَارْ، مَامّشْ وَارْ إِحْڒِي ؤُ مشْحَاڒْ يَارْزڭْ أَقَا ثْسمْحذْ ذِي سِيذِي، أَربِّي نّمْ، ؤُ وَارْ زَّايِي ثتّڭّْوذذْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ.“ \x ◘ \xo 2:‏19 \xt إِشا. 3‏:‏9؛ حُوش. 5‏:‏5\x*   
\b  
\m
\v 20 ”أَطَّاسْ زڭْ وَامِي ثَارْژِيذْ \add أَ\add*زَايْڒُو نّمْ، ثْشَارّْڭذْ إِشذِّييّنْ نّمْ. شمْ ثنِّيذْ: ’وَارْ خْسغْ أَذْ أَشْ سخَّارغْ!‘ مِينْزِي خْ كُوڒْ ڒْڭعّْذثْ يُوعْڒَانْ ؤُ سَاذُو كُوڒْ ثَاشجَّارْثْ ثَازِيزَاوْثْ ثُوضَارذْ أَمْ ثمْغَارْثْ ن فَارْقْ-شّْغڒْ. \f ◼ \fr 2:‏20 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  
\v 21 نشّْ مَاشَا ثُوغَا ژُّوغْ شمْ ذ ثَازَايَارْثْ ثَاحُورِّيثْ، ذ زَّارِيعثْ إِشْنَانْ أَطَّاسْ. مَامّشْ ثْذوْڒذْ غَارْ ثْسضْوِينْ ن ثْزَايَارْثْ ن ڒخْڒَا ثَابَارَّانشْثْ؟ \x ◘ \xo 2:‏21 \xt ؤُف. 15‏:‏17؛ إِزهد. 44‏:‏3؛ 80‏:‏9\x*  
\v 22 وَاخَّا ثسِّيرْذذْ إِخفْ نّمْ س لِّيخِييَّا ؤُشَا ثَارْنِيذْ أَسْرَايْ س صَّابُونْ، \add عَاذْ\add* أَذْ ثقِّيمْ ڒْمُوعْصِييّثْ نّمْ زَّاثْ إِ وُوذمْ إِنُو، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“ \x ◘ \xo 2:‏22 \xt أَيُوبْ 9‏:‏30\x*   
\m
\v 23 ”مَامّشْ ثْزمَّارذْ أَذْ ثِينِيذْ: ’نشّْ وَارْ تّْوَاسّْخمْجغْ شَا، نشّْ وَارْ ضْفَارغْ شَا ’إِبَاعْلنْ!‘ خْزَارْ غَارْ وبْرِيذْ نّمْ ذِي ثغْزُورْثْ، عْقڒْ مِينْ ثڭِّيذْ، شمْ ذ ثَاڒْغمْثْ ثفْسُوسْ ثتَّازّڒْ، ثنِّي إِتّمْخَارْوَاضنْ ذڭْ إِبْرِيذنْ نّسْ!  
\v 24 أَقَا-ت ذ ثَاغْيُوتْشْ ن ڒخْرَا، إِنُّومنْ ذِي ڒخْڒَا، ثنِّي إِتّْشمَّانْ أَرِّيحْ ذڭْ ونْژَارْ نّسْ ؤُمِي ثْحَاجْ. وِي ت إِ غَا إِسّْبدّنْ ذِي نّشْوثْ نّسْ؟ قَاعْ وِي ت يَارزُّونْ وَارْ إِحْذِيجْ أَذْ إِسِّيحڒْ إِخفْ نّسْ، أَذْ ت يَافْ ذڭْ ؤُيُورْ \add ن نّشْوثْ\add* نّسْ.  
\v 25 حْضَا وَارْ إِتِّيڒِي ؤُضَارْ نّمْ بْڒَا ثِيسِيڒَا ؤُڒَا ثْمِيجَّا نّمْ وَارْ ثتِّيژغْ س ؤُفَاذِي! شمْ مَاشَا ثقَّارذْ: ’وَارْ خَاسْ نسِّيوِيڒْ،عمَّارْصْ! مَاغَارْ نشّْعشْقغْ ذِي مِيدّنْ، خْسغْ أَذْ ؤُيُورغْ أَوَارْنِي أَسنْ!‘ “   
\m
\v 26 ”أَمْ ؤُخوَّانْ إِنّحْصڒْ إِسضْحَا، أَمُّو إِ غَا سضْحَانْ إِنِّي ن ثَادَّارْثْ ن إِسْرَائِيل، نِيثْنِي ذ إِجدْجِيذنْ نْسنْ ذ ڒْحُوكَّامْ نْسنْ ذ إِكهَّاننْ نْسنْ ذ إِنَابِييّنْ نْسنْ.  
\v 27 نِيثْنِي قَّارنْ إِ ؤُكشُّوضْ: ’شكْ ذ بَابَا!‘، ؤُ إِ وژْرُو: شكْ ثجِّيذْ أَيِي-د!، مَاغَارْ نِيثْنِي وْشِينْ أَيِي س وعْرُورْ، وَارْ إِدْجِي س ؤُغمْبُوبْ، \add مَاشَا\add* ذِي ڒحْصَارثْ نْسنْ قَّارنْ: ’كَّارْ، سنْجمْ أَنغْ!‘  
\v 28 مَانِي دْجَانْ ڒخُّو إِربِّيثنْ نّشْ، إِنِّي ثڭِّيذْ إِ يِيخفْ نّشْ؟ أجّْ إِ-ثنْ أَذْ د-كَّارنْ، مَاڒَا زمَّارنْ أَذْ شكْ فكّنْ غَارْ ڒْوقْثْ ن ڒحْصَارثْ نّشْ، مَاغَارْ إِربِّيثنْ نْومْ أَمْ لْعَاذَاذْ ن ثْندَّامْ نّشْ، \add أَ\add* يَاهُوذَا!“ \x ◘ \xo 2:‏28 \xt إِشا. 2‏:‏8؛ إِرْم. 11‏:‏13\x*   
\m
\v 29 ”مَايمِّي أَكِيذِي ثمْشُوبُّوشمْ كنِّيوْ؟ كنِّيوْ مَارَّا ثتّْعدَّامْ خَافِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 30 خْ بَاطڒْ إِ وْثِيغْ إِحنْجِيرنْ نْومْ، وَارْ جِّينْ إِخفْ نْسنْ أَذْ أَريّْضنْ. سِّيفْ نْومْ إِشَّا إِنَابِييّنْ نْومْ أَمْ وَايْرَاذْ إِغَارّْصنْ. \x ◘ \xo 2:‏30 \xt إِشا. 1‏:‏5؛ إِرْم. 5‏:‏3\x*  
\v 31 \add أَ\add* كنِّيوْ، \add أَ\add* جِّيڒْ \add ن يِيضَا\add*، حْضَامْ أَوَاڒْ ن سِيذِي. مَا ثُوغَا أَيِي ذ ڒخْڒَا إِ إِسْرَائِيل، نِيغْ ذ ثَامُّورْثْ ن ثَادْجسْثْ ذ ثَابَارْشَانْثْ؟ مَايمِّي \add خنِّي\add* إِقَّارْ ڒْڭنْسْ إِنُو: ’أَقَا نشِّينْ ننُّوفْصڒْ زَّايكْ، وَارْ إِ د غَاركْ نذِّيكّْوِيڒْ عَاذْ‘؟ \x ◘ \xo 2:‏31 \xt مت. 23‏:‏26‏-‏39\x*  
\v 32 مَا أَذْ ثتُّو ثعْزَارشْثْ ثَالْوِيزْثْ نّسْ نِيغْ \add أَذْ ثتُّو\add* ثسْڒِيثْ ثَاحزَّامْثْ نّسْ \add إِزوّْقنْ\add*؟ وَاخَّا أَمنِّي إِ ذ أَيِي إِتُّو ڒْڭنْسْ إِنُو أَطَّاسْ ن وُوسَّانْ بْڒَا ڒحْسَابْ. \x ◘ \xo 2:‏32 \xt إِرْم. 3‏:‏21\x*  
\v 33 مشْحَاڒْ ثسّْنذْ مْلِيحْ أَذْ ثَارْزُوذْ أَبْرِيذْ ن ثَايْرِي؟ س ؤُيَا إِ ثسّْڒمْذذْ ذِي إِبْرِيذنْ نّمْ ثِيمسْڒَايِينْ ثِيعفَّانِينْ إِ يِيخفْ نّمْ.  
\v 34 ؤُڒَا ذڭْ ؤُبحْرُورْ ن وَارُّوضْ نّمْ ؤُفِينْ إِذَامّنْ ن ڒعْمُورَاثْ إِضعْفنْ إِزْذِيڭنْ، إِنِّي وَارْ ثمْنِيعذْ ؤُمِي ؤُشَارنْ \add ثُوذْرِينْ\add*، \add وَاهْ،\add* زِي سِّيبّثْ ن مَارَّا مَانْ أَيَا \add أَقَا إِمْسَارْ\add*. \f ◼ \fr 2:‏34 \ft \+bd ’زِي سِّيبّثْ ن مَارَّا مَانْ أَيَا‘\+bd* - إِذَامّنْ وَارْ ؤُزِّيڒنْ شَا ؤُمِي طّْفنْ إِشفَّارنْ نِيغْ إِخوَّاننْ ذِي إِسْرَائِيل ؤُشَا نْغِينْ ثنْ، مَاشَا إِذَامّنْ ؤُزّْڒنْ ؤُمِي نْغِينْ إِنَابِييّنْ ن سِيذِي (خْزَارْ 2 إِج. 21‏:16 ؤُ 2 إِج. 24‏:4). ثُوغَا أَيْثْ ن إِسْرَائِيل ذ إِخوَّاننْ ذ إِذَارْغَاڒنْ ؤُمِي عبْذنْ لَاصْنَامْ إِفنَّانْ، وَارْ إِدْجِي أَربِّي إِ إِدْجَانْ إِ ڒبْذَا.\f*  \x ◘ \xo 2:‏34 \xt أَمب. 11‏:‏9\x*  
\v 35 ؤُشَا \add عَاذْ\add* ثقَّارذْ: ’س ثِيذتّْ، نشّْ ذ ثَامزْذَاڭْثْ، أَقَا أَغْضَابْ نّسْ إِحيّذْ خَافِي!‘ خْزَارْ، نشّْ أَذْ كِيمْ شَارّْعغْ، مِينْزِي ثقَّارذْ: ’نشّْ وَارْ ڭِّيغْ دّْنُوبْ!‘  
\v 36 مَايمِّي ثتّڭّْوْجذْ أَطَّاسْ ؤُشَا ثْبدّْڒذْ \add ڒبْذَا\add* أَبْرِيذْ نّمْ؟ ؤُڒَا \add ثَامُّورْثْ ن\add* مِيصْرَا أَذْ شمْ ثشْمثْ، أَمْ مَامّشْ إِ ذ أَمْ ثشْمثْ أَشُّورْ.  
\v 37 ؤُڒَا سّنِّي أَذْ ثڭّْوجذْ س إِفَاسّنْ نّمْ خْ ؤُزدْجِيفْ، مَاغَارْ سِيذِي إِنْضَارْ مَارَّا إِنِّي خْ ثتّشْڒذْ، أَڒَامِي وَارْ إِتِّيڒِي أَيَا ؤُڒَا أَكِيذْسنْ.“   
\b  
\b  
\m  
\c 3
\s1 ثَاڒَاغِيثْ إِ وعْقَابْ غَارْ سِيذِي أَربِّي  
\m
\v 1 ”قَّارنْ: ’خْزَارْ، إِجّْ ن ورْيَازْ إِدْجفْ إِ ثمْغَارْثْ نّسْ ؤُ نتَّاثْ ثُويُورْ خَاسْ، ثذْوڒْ ذ ثَامْغَارْثْ ن إِجّْ نّغْنِي، مَا إِعدّڒْ أَذْ غَارسْ د-إِعْقبْ \add خنِّي\add*؟ مَا وَارْ ثفْسذْ ثمُّورْثْ نِّي أَطَّاسْ؟‘ شمْ مَاشَا ثڭّذْ فَّارْقْ-شْغڒْ نّمْ أَكْ-ذ إِجّْ ن ؤُبَارُّو ن إِمدُّوكَّاڒْ، مَا \add خنِّي\add* ثْزمَّارذْ أَذْ غَارِي د-ثْعقْبذْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. \x ◘ \xo 3:‏1 \xt أَعَوذ. 24‏:‏1‏-‏4\x*  
\v 2 سْڭعّذْ ثَامُوغْڒِي نّمْ ذِي ڒڭْعُوذِي \add إِ خفْ وهّْبنْ ثِيغَارْصَا\add*، خْزَارْ، مَانِي وَارْ شمْ خَارْضنْ؟ أَقَا ثُويُورذْ أَذْ ثقِّيمذْ ذڭْ إِبْرِيذنْ مَارَّا أَمْ يِيجّْ ن وعْرَابْ ذِي ڒخْڒَا. \add أَمُّو\add* إِ ثسّْفسْذذْ ثَامُّورْثْ س فَارْقْ-شّْغڒْ نّمْ ذ ڒْغَارْ نّمْ.  
\v 3 س ؤُيَا إِتّْوَامْنعْ ونْژَارْ ؤُشَا وَارْ د-إِوْثِي ونْژَارْ أَجُورِي. \add مَاشَا\add* شمْ ثُوغَا غَارمْ ثَانْيَارْثْ ثقْجَارْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ، وَارْ ثخْسذْ أَذْ ثْسضْحِيذْ.  
\v 4 مَا وَارْ ثبْذِيذْ مْغِيرْ إِ شْوَايْثْ ن ڒْوقْثْ وَاهَا أَذْ أَيِي ثتّْڒَاغَاذْ ’بَابَا! شكْ ذ أَمدُّوكّڒْ إِنُو زِي ثمْژِي إِنُو!  
\v 5 مَا \add خنِّي\add* أَذْ إِقِّيمْ وغْضَابْ نّسْ إِتّْبدَّا إِ ڒبْذَا؟ مَا نتَّا أَذْ ث إِحْضَا إِ ڒبْذَا؟‘ خْزَارْ، \add أَمُّو إِ\add* ثقَّارذْ، \add أَمْ\add* ثتّڭّذْ مَاڒَا ثِيمسْڒَايِينْ نِّي ثِيعفَّانِينْ ؤُ \add ثتّْخَارّْصذْ\add* أَقَا أَيَا إِعدّڒْ \add أَذْ إِتّْوَاڭّْ.\add*“   
\m
\v 6 سِيذِي إِنَّا أَيِي ذڭْ وُوسَّانْ ن يُوشِييَا: ”مَا ثژْرِيذْ مِينْ ثڭَّا \add ثمْغَارْثْ\add* إِسْرَائِيل إِكْفَارنْ؟ نتَّاثْ ثْڭعّذْ كُوڒْ أَذْرَارْ يُوعْڒَانْ، ثزّڒْ سَاذُو كُوڒْ ثَاشجَّارْثْ ثَازِيزَاوْثْ ؤُشَا ثڭَّا ذِينْ أَمْ ثمْغَارْثْ ن فَارْقْ-شّْغڒْ! \f ◼ \fr 3:‏6 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  \x ◘ \xo 3:‏6 \xt إِرْم. 2‏:‏20\x*  
\v 7 أَوَارْنِي ڒَامِي ثڭَّا أَيَا، نِّيغْ: \bd ’أَذْ د-ثذْوڒْ غَارِي!‘\bd*، مَاشَا نتَّاثْ وَارْ د-ثذْوِيڒْ شَا. \add خنِّي\add* ثژْرِي أَيَا ؤُتْشْمَاسْ إِغدَّارنْ يَاهُوذَا.  
\v 8 ژْرِيغْ، ؤُمِي ذ أَسْ دْجْفغْ زِي سِّيبّثْ ن مَارَّا مِينْ زِي ثزْنَا \add ثمْغَارْثْ\add* إِسْرَائِيل إِكْفَارنْ ؤُ وْشِيغْ أَسْ ثَابْرَاثْ ن وَادْجَافْ، أَقَا أَيَا وَارْ إِسّْنخْڒِيعْ ؤُتْشْمَاسْ ثَاغدَّارْثْ يَاهُوذَا، \add مَاشَا\add* نتَّاثْ ثُويُورْ، ثسّفْسذْ إِخفْ نّسْ ؤُڒَا ذ نتَّاثْ س فَارْقْ-شّْغڒْ نّسْ.  
\v 9 س فَارْقْ-شّْغڒْ نّسْ إِهوْننْ، ثتّْوَاسّفْسذْ ثمُّورْثْ، \add مَاغَارْ\add* نتَّاثْ ثزْنَا س وژْرُو ذ ؤُكشُّوضْ.  
\v 10 ذِي مَارَّا أَيَا وَارْ د غَارِي ثعْقِيبْ ؤُتْشْمَاسْ يَاهُوذَا ثَاغدَّارْثْ س مَارَّا ؤُڒْ نّسْ، \add مَاشَا\add* ثسّْنِيعْمِيڒْ وَاهَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\m
\v 11 \add س ؤُيَا\add* إِنَّا أَيِي سِيذِي: ”\add ثَاوتْشْمَاثْ\add* إِسْرَائِيل إِكْفَارنْ، أَقَا ثَارَّا إِخفْ نّسْ ثْبَانْ-د ثْسڭّذْ كْثَارْ خْ \add ؤُتْشْمَاسْ\add* يَاهُوذَا ثَاغدَّارْثْ.  
\v 12 ؤُيُورْ، ڒَاغَا أَوَاڒنْ-أَ غَارْ شَّامَالْ، إِنِي: \bd ’ذْوڒْ-د، \+bdit أَ شمْ\+bdit* \+bdit ثمْغَارْثْ\+bdit* إِسْرَائِيل إِكْفَارنْ!‘\bd*، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. أَغمْبُوبْ إِنُو وَارْ إِتّْبَارْشِينْ، مَاغَارْ نشّْ شُّورغْ س ثْمخْسِيوْثْ إِشوَّارنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. نشّْ وَارْ تِّيڒِيغْ تّْفُوڭْمغْ ڒبْذَا. \x ◘ \xo 3:‏12 \xt إِزهد. 86‏:‏15؛ 103‏:‏8، 9؛ 145‏:‏17\x*  
\v 13 مَاشَا نْعمْ س ڒْمُوعْصِييّثْ نّمْ، أَقَا ثْعذِّيذْ خْ سِيذِي، أَربِّي نّمْ، ؤُشَا ثفّْغذْ زڭْ وبْرِيذْ غَارْ مَارَّا إِغزْذِيسنْ غَارْ إِبَارَّانِييّنْ، سَاذُو كُوڒْ ثَاشجَّارْثْ ثَازِيزَاوْثْ، \add مَاشَا\add* كنِّيوْ وَارْ ثسْڒِيمْ شَا غَارْ ثْمِيجَّا إِنُو، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\m
\v 14 \bd ”ذوْڒمْ-د، أَ ثَارَّاوْثْ إِكْفَارنْ!\bd*، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، مَاغَارْ نشّْ ذ أَرْيَازْ نْومْ، نشّْ أَذْ كنِّيوْ قبْڒغْ \add عَاوذْ\add*، إِجّْ زڭْ إِشْثْ ن ثنْذِينْثْ ؤُ ثْنَاينْ زڭْ إِجّْ ن ڒَادْجْ، ؤُ نشّْ أَذْ كنِّيوْ أَوْيغْ غَارْ صِيهْيُونْ.  
\v 15 نشّْ أَذْ أَومْ وْشغْ إِمكْسَاونْ إِ إِخْسْ وُوڒْ إِنُو، إِنِّي كنِّيوْ إِ غَا يَاروْسنْ س ثُوسّْنَا ذ ڒعْقڒْ. \x ◘ \xo 3:‏15 \xt إِرْم. 23‏:‏4؛ حِز. 34‏:‏23؛ أَفا. 4‏:‏11\x*  
\v 16 خْمِي غَا ثمَّارنْيمْ ذڭْ وُوسَّانْ نِّي، أَذْ د-ثَاوْيمْ ڒْغِيدْجثْ ذِي ثمُّورْثْ، إِقَّارْ سِيذِي، أَذْ ثَافذْ وَارْ قَّارنْ \add عَاذْ\add* ’تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي!‘ وَارْ د أَسنْ ثتَّاڒِي غَارْ ڒْبَاڒْ، وَارْ ت تِّيذَارنْ، وَارْ ت فقّْذنْ \add عَاذْ\add* ؤُشَا وَارْ ت تّْسنَّاعنْ.“   
\m
\v 17 ”ذِي ڒْوقْثْ نِّي أَذْ إِنِينْ إِ ؤُرْشَالِيمْ ’ڒْْكُورْسِي ن سِيذِي!‘، ؤُشَا مَارَّا ڒڭْنُوسْ أَذْ غَارسْ د-نّْيَارْونْ ذِي طّْوعْ ن يِيسمْ ن سِيذِي، غَارْ ؤُرْشَالِيمْ، ؤُشَا وَارْ تّْغِيمِينْ ڭُّورنْ شَا عْلَاحْسَابْ ڒقْسَاحثْ ن وُوڒْ نْسنْ أَعفَّانْ.  
\v 18 ذڭْ وُوسَّانْ نِّي أَذْ ثُويُورْ ثَادَّارْثْ ن يَاهُوذَا غَارْ ثَادَّارْثْ ن إِسْرَائِيل ؤُشَا نِيثنْثِي أَذْ فّْغنْثْ مُوننْثْ زِي ثمُّورْثْ ن شَّامَالْ غَارْ ثمُّورْثْ نِّي وْشِيغْ ذ ثَاسْغَارْثْ إِ ڒجْذُوذْ نْومْ.“   
\m
\v 19 ”نشّْ ثُوغَا نِّيغْ: ’مَامّشْ زمَّارغْ أَذْ كنِّيوْ أَرّغْ ذ إِحنْجِيرنْ إِنُو ؤُشَا أَذْ أَومْ وْشغْ ثَامُّورْثْ إِعِيزّنْ، ثَاسْغَارْثْ \add نِّي إِدْجَانْ ذ\add* ثَالْوِيزْثْ ن ڒْعسْكَارَاثْ ن ڒڭْنُوسْ؟‘ نشّْ نِّيغْ: ’كنِّيوْ أَذْ غَارِي ڒَاغَانْ: بَابَا! ؤُشَا وَارْ خَافِي ثتّْحيِّيذمْ \add عَاذْ\add*!‘  
\v 20 س ثِيذتّْ، أَمْ ثمْغَارْثْ ثغْذَارْ أَمدُّوكّڒْ نّسْ، أَمُّو ؤُڒَا ذ كنِّيوْ ثِيغْذَارمْ أَيِي، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\b  
\m
\v 21 إِتّْوَاسڒْ إِجّْ ن ڒْحسّْ خْ ثوْرِيرِينْ إِقشَّارنْ، أَنِيخْسسْ ذ ثُوثْرَا ن أَيْثْ ن إِسْرَائِيل، مِينْزِي نِيثْنِي ؤُيُورنْ إِبْرِيذنْ فَارْغنْ ؤُشَا سِيذِي، أَربِّي نْسنْ، تُّونْ ث.   
\b  
\m
\v 22 \bd ”ذوْڒمْ-د، أَ ثَارَّاوْثْ إِكْفَارنْ!\bd*، نشّْ خْسغْ أَذْ سّْڭنْفِيغْ أَكْفَارْ نْومْ.“  
\b  
\m ”خْزَارْ، أَقَا أَنغْ ذَا، نشِّينْ نُوسَا-د غَاركْ، مَاغَارْ شكْ ذ سِيذِي، أَربِّي نّغْ!  
\v 23 نِيشَانْ خْ وَالُو \add إِ إِتّْرَاجَا بْنَاذمْ\add* زِي ڒڭْعُوذِي ن \add ثوْهِيبِينْ\add* ذ دْجْغَارغْ خْ إِذُورَارْ. نِيشَانْ، ذِي سِيذِي، أَربِّي نّغْ، أَقَا إِدْجَا ؤُسنْجمْ ن إِسْرَائِيل. \x ◘ \xo 3:‏23 \xt إِزهد. 121‏:‏1\x*  
\v 24 ڒفْضِيحثْ ثشَّا ڒْخذْمثْ ن ڒجْذُوذْ نّغْ زِي ثمْژِي نّغْ: ؤُدْجِي نْسنْ ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ نْسنْ، إِحنْجِيرنْ نْسنْ ذ ثْحنْجِيرِينْ نْسنْ.  
\v 25 نشِّينْ نزّڒْ ذِي ڒفْضِيحثْ نّغْ ؤُشَا ڒحْيَا نّغْ ثذْڒَا أَنغْ، مَاغَارْ نشِّينْ نخْضَا أَكْ-ذ سِيذِي، أَربِّي نّغْ، نشِّينْ ذ ڒجْذُوذْ نّغْ، زِي ثمْژِي نّغْ أَڒْ إِضَا. نشِّينْ وَارْ نسْڒِي شَا غَارْ ثْمِيجَّا ن سِيذِي، أَربِّي نّغْ.“   
\b  
\b  
\m  
\c 4
\s1 بْڒَا تُّوبثْ وَارْ إِتِّيڒِي وعْقَابْ  
\m
\v 1 ”مَاڒَا ثخْسذْ أَذْ د-ثْعقْبذْ، \add أَ\add* إِسْرَائِيل، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، عْقبْ-د غَارِي، ؤُ مَاڒَا ثكّْسذْ مَارَّا نّْعَاوَاثْ ن لْ-أَصْنَامْ خْ وُوذمْ إِنُو، وَارْ تّْغِيمِي شَا ثدُّورِيذْ وَاهَا.  
\v 2 جَادْجْ س ثِيذتّْ، س ڒْحقّْ ؤُ س ثْسڭْذَا، \add إِنِي\add*: ’\add س ثِيذتّْ\add* أَمْ إِدَّارْ سِيذِي!‘، \add خنِّي\add* أَذْ زَّايسْ تّْوَابَارْكنْ ڒڭْنُوسْ ؤُشَا أَذْ ذَايسْ سّْعُودْجنْ إِخفْ نْسنْ. \x ◘ \xo 4:‏2 \xt أَمز. 22‏:‏18؛ إِشا. 48‏:‏1\x*  
\v 3 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي إِ يرْيَازنْ ن يَاهُوذَا ؤُ إِ ؤُرْشَالِيمْ: ’شَارْزمْ إِيَّارْ إِخْوَانْ إِ يِيخفْ نْومْ، \add مَاشَا\add* وَارْ زَارّْعمْ ذڭْ إِسنَّاننْ. \x ◘ \xo 4:‏3 \xt حُوش. 10‏:‏12\x*  
\v 4 خثْنمْ إِخفْ نْومْ إِ سِيذِي ؤُ سِّيڭّْوجمْ ڒعْذَاڒيَّاثْ ن وُوڒَاونْ نْومْ، كنِّيوْ إِرْيَازنْ ن يَاهُوذَا ذ كنِّيوْ إِمزْذَاغْ ن ؤُرْشَالِيمْ، حِيمَا أَسْعَارْ إِنُو وَارْ إِتَّارژِّي أَمْ ثْمسِّي، أَذْ إِشْمضْ بْڒَا مَا إِزمَّارْ ؤُڒَا ذ إِجّْ أَذْ إِسّخْسِي، زِي سِّيبّثْ ن ثْمڭَّا نْومْ ثِيعفَّانِينْ.‘ “ \x ◘ \xo 4:‏4 \xt أَعَوذ. 10‏:‏16؛ 30‏:‏6؛ إِشا. 65‏:‏5\x*   
\b  
\m  
\s1 أَهْجَامْ زِي ڒْڭنْسْ إِ د-يُوسِينْ زِي شَّامَالْ  
\m
\v 5 ”بَارّْحمْ \add ت\add* ذِي يَاهُوذَا ؤُ جّمْ أَذْ \add أَسْ\add* سْڒنْ ذِي ؤُرْشَالِيمْ، إِنِيمْ: ’سُوضمْ ذڭْ ؤُيِيشّْ ن إِشَارِّي ذِي ثمُّورْثْ!‘، سْغُويّمْ س ثْمِيجَّا إِجهْذنْ، إِنِيمْ: ’سْمُونمْ، أَسمْ-د غَارْ ثْندَّامْ إِفَارْينْ!‘  
\v 6 سْڭعّْذمْ ثَاعدْجَانْثْ إِ صِيهْيُونْ، وَارْ تّْغِيمِيمْ ثْبدّمْ، مَاغَارْ نشّْ أَذْ سِّيوْضغْ ڒْغَارْ زِي شَّامَالْ، لْمُوصِيبَا ثَامقّْرَانْثْ.  
\v 7 أَيْرَاذْ إِڭعّذْ-د زِي شْبَارْقْ \add ن ڒْمَارْڭحْ\add* نّسْ، أَمْثحَّايْ نْ ڒڭْنُوسْ إِرُوحْ ذڭْ وبْرِيذْ، إِفّغْ-د زڭْ ومْشَانْ نّسْ مَاحنْذْ أَذْ يَارّْ ثَامُّورْثْ نّمْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ. ثِيندَّامْ نّمْ أَذْ تّْوَاردّْدْجنْثْ أَڒَامِي وَارْ \add ذَايْسنْثْ\add* إِتّْغِيمِي ؤُڒَا ذ إِجّْ ن ؤُمزْذُوغْ. \x ◘ \xo 4:‏7 \xt إِشا. 5‏:‏29؛ إِرْم. 2‏:‏15؛ 5‏:‏6\x*  
\v 8 س ؤُينِّي، أَرْضمْ ثِيخُونْشَايْ \add ن وشْضَانْ\add*، شضْنمْ ؤُ وعّْضمْ، مَاغَارْ وَارْ خَانغْ إِحيّذْ ڒْحَاذُوقْ ن وغْضَابْ ن سِيذِي.“ \x ◘ \xo 4:‏8 \xt إِشا. 32‏:‏12\x*   
\m
\v 9 \add أَمُّو إِ\add* إِقَّارْ سِيذِي: ”ذڭْ وَاسّْ نِّي أَذْ إِمْسَارْ، أَقَا ؤُڒْ ن ؤُجدْجِيذْ ذ ؤُڒَاونْ ن ڒْحُوكَّامْ أَذْ أَسنْ ثْرَاحْ ثَارْيَاسْثْ، إِكهَّاننْ أَذْ نّْخڒْعنْ ؤُشَا إِنَابِييّنْ أَذْ ثْبهْثنْ.“   
\m
\v 10 \add خنِّي\add* نِّيغْ: ”أَخْ، سِيذِي إِنُو، سِيذِي، س ثِيذتّْ، أَقَا شكْ ثْشمْثذْ ڒْڭنْسْ-أَ ذ ؤُرْشَالِيمْ ؤُمِي ثنِّيذْ: ’أَذْ غَارْومْ يِيڒِي ڒهْنَا!‘ خْزَارْ، سِّيفْ يُوذفْ-د عَاذْ غَارْ ڒعْمَارْ \add نّغْ\add*!“   
\m
\v 11 ”ذڭْ وَاسّْ نِّي أَذْ إِنِينْ إِ ڒْڭنْسْ-أَ ؤُ إِ ؤُرْشَالِيمْ: ’أَسمِّيضْ إِسّشْمَاضْ زِي ثوْرِيرِينْ ثِيقشَّارِينْ ذِي ڒخْڒَا أَقَا-ث ذڭْ وبْرِيذْ غَارْ يدْجِيسْ ن ڒْڭنْسْ إِنُو، وَارْ إِتِّيڒِي إِ ؤُزُوزَّارْ نِيغْ إِ ؤُصفِّي.  
\v 12 أَذْ إِفّغْ زِي غَارِي إِجّْ ن ؤُسمِّيضْ إِجْهذْ خْ وَانِيثَا. ڒخُّو نشّْ \add سِيمَانْثْ إِنُو\add* أَذْ ثنْ حكْمغْ.  
\v 13 خْزَارْ، إِڭعّذْ أَمْ يِيسيْنُوثنْ ؤُشَا إِكَارُّوثنْ نّسْ ڭِّينْ أَمْ ثْحَارْيَاضْثْ، إِيْسَانْ نّسْ تِّيزْوَارنْ إِ إِڭِيذَارنْ. ؤُشْثْ نّغْ، نشِّينْ نتّْوَاردّدْجْ!‘ “   
\m
\v 14 ”سِيرْذْ ؤُڒْ نّمْ زِي ثُوعفّْنَا، \add أَ\add* ؤُرْشَالِيمْ، مَاحنْذْ أَذْ ثتّْوَاسّْنجْمذْ! مشْحَاڒْ عَاذْ إِ غَا كّنْ زدّْغنْ إِخَارِّيصنْ إِعفَّاننْ ذڭْ وُوڒْ نّمْ؟ \f ◼ \fr 4:‏14 \ft \+bd ’ذڭْ وُوڒْ نّمْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ذِي ذَاخڒْ نّمْ‘.\f*  \x ◘ \xo 4:‏14 \xt إِشا. 1‏:‏16\x*  
\v 15 مِينْزِي ثْمِيجَّا ثتّْبَارّحْ زِي ذَانْ ؤُشَا ثتّْوَاسڒْ ثشْثِي ثَامقّْرَانْثْ \add إِ-د-إِتّْقَارَّابنْ\add* زڭْ إِذُورَارْ ن إِفْرَايِيمْ.  
\v 16 بَارْحمْ \add زَّايسْ\add* ذِي يَاهُوذَا ؤُ جّمْ أَذْ أَسْ سْڒنْ ذِي ؤُرْشَالِيمْ، إِنِيمْ: ’إِنِّي إِ غَا إِحْصَارنْ أَقَا ؤُسِينْ-د زِي ثمُّورْثْ ثِيڭّْوجْ، نِيثْنِي سّْڭعَّاذنْ ثْمِيجَّا نْسنْ ضِيدّْ إِ ثْندَّامْ ن يَاهُوذَا.‘  
\v 17 نّْضنْ أَسْ-د أَمْ يِيعسَّاسنْ ذڭْ إِيَّارنْ، مَاغَارْ نتَّاثْ ثْغوّغْ خَافِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 18 ثَابْرِيذْثْ نّمْ ذ ثْمڭَّا نّمْ إِوْينْ أَمْ-د أَيَا. أَقَا-ث ذ أَشْثَابْ أَبَارْشَانْ نّمْ، يَارْزڭْ، إِڒقّفْ \add إِ شمْ ذڭْ\add* وُوڒْ نّمْ.“   
\b  
\m
\v 19 ”\add عَاونْ أَيِي،\add* أَعذِّيسْ إِنُو، أَعذِّيسْ إِنُو، نشّْ تّْفَارْفِيرغْ س ڒوْجعْ، \add أَ\add* إِغزْذِيسنْ ن وُوڒْ إِنُو، ؤُڒْ إِنُو إِنڭّزْ، نشّْ وَارْ زمَّارغْ أَذْ سغْذغْ، مَاغَارْ أَسُوضِي ن ؤُيِيشّْ ن إِشَارِّي يُوذفْ غَارْ ڒعْمَارْ إِنُو، \add ؤُشْثْ،\add* إِغُويَّانْ \add ن ؤُمنْغِي\add*. \x ◘ \xo 4:‏19 \xt إِشا. 21‏:‏4؛ إِرْم. 8‏:‏23\x*  
\v 20 ’ثِيشْثِي خْ ثشْثِي!‘، \add أَمُّو إِ\add* سْغُويُّونْ، مِينْزِي مَارَّا ثَامُّورْثْ ثْخَارّبْ. ذغْيَا تّْوَاهذْمنْ إِقِيضَانْ إِنُو، ذڭْ ورْمَاشْ ن وَابْڒِيونْ ثْجَارْثِيڒِينْ ن ؤُقِيضُونْ إِنُو! \f ◼ \fr 4:‏20 \ft \+bd ’ثِيشْثِي خْ ثِيشْثِي‘\+bd* - س ثْعِيبْرَانِيثْ ’ثَارژِّيثْ خْ ثَارژِّيثْ‘.\f*  
\v 21 أَڒْ مڒْمِي \add عَاذْ\add* أَذْ ثْوَاڒِيغْ ثَاعدْجَانْثْ \add ن ؤُمنْغِي\add* ؤُشَا أَذْ سْڒغْ إِ ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي؟  
\v 22 ڒْڭنْسْ إِنُو ذ أَبُوهَاڒِي، نِيثْنِي وَارْ ذ أَيِي سِّيننْ. نِيثْنِي ذ إِحنْجِيرنْ بْڒَا ڒعْقڒْ ؤُ وَارْ غَارْسنْ ثدْجِي ڒفْهَامثْ. نِيثْنِي ذ إِمِيغِيسنْ مَاحنْذْ أَذْ ڭّنْ ڒْغَارْ، \add مَاشَا\add* وَارْ سِّيننْ أَذْ ڭّنْ مِينْ إِصبْحنْ.“   
\b  
\m
\v 23 ”نشّْ ژْرِيغْ ثَامُّورْثْ، خْزَارْ، ثُوغَا-ت ذ ڒخْڒَا ذ ڒْخَاوِي ؤُ وَارْ \add ؤُفِيغْ\add* ثَافَاوْثْ ذڭْ ؤُجنَّا.  
\v 24 نشّْ ژْرِيغْ إِذُورَارْ، خْزَارْ، تَّارْجِيجِينْ ؤُشَا مَارَّا ثِيوْرِيرِينْ تّنْهزَّانْثْ \add تّْرَاحنْثْ ذ تَّاسنْثْ إِ-د\add*.  
\v 25 نشّْ ثْوَاڒِيغْ، خْزَارْ، وَارْ ذِينْ \add ؤُڒَا ذ إِجّْ ن\add* بْنَاذمْ، ؤُ مَارَّا إِجْضَاضْ ن ؤُجنَّا ثُوغَا ضْوِينْ.  
\v 26 نشّْ ژْرِيغْ، خْزَارْ، ثَامُّورْثْ إِسّغْمَاينْ ثُوغَا ذ ڒخْڒَا ؤُ مَارَّا ثِيندَّامْ نّسْ تّْوَاهذْمنْثْ ذِي سِّيبّثْ ن ڒْحَاذُوقْ ن وغْضَابْ ن سِيذِي.“   
\m
\v 27 ”مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: ’مَارَّا ثَامُّورْثْ-أَ أَذْ ثذْوڒْ ذ ثَامُّورْثْ ذ ڒخْڒَا، \add مَاشَا\add* نشّْ وَارْ \add ت\add* قطّْعغْ مَارَّا. \x ◘ \xo 4:‏27 \xt إِرْم. 5‏:‏10، 18؛ 30‏:‏11؛ 46‏:‏28\x*  
\v 28 س ؤُيَا إِ غَا ثشْضنْ ثمُّورْثْ، أَذْ بَّارْشْننْ إِجنْوَانْ سنّجْ، مَاغَارْ أَقَا نشّْ نِّيغْ ث، نشّْ ڭِّيغْ خَاسْ. نشّْ وَارْ نْذِيمغْ شَا ؤُ نشّْ وَارْ دِّيكّْوِيڒغْ ذڭْ وَاوَاڒْ.  
\v 29 زِي دّْرِيزْ ن إِمْنَاينْ \add ن ييْسَانْ\add* ذ إِمْجبَّاذنْ ن ڒْقوْسْ ثَارْوڒْ ثنْذِينْثْ مَارَّا. نِيثْنِي أَرزُّونْ أَذْ د-أَذْفنْ ذڭْ إِزغْرَانْ ؤُشَا أَذْ ڭعّْذنْ خْ ڒجْرُوفْ، ثَانْذِينْثْ مَارَّا ثتّْوَاجّْ، وَارْ ذَايسْ إِقِّيمْ ؤُڒَا ذ إِجّْ ن ؤُمزْذُوغْ.‘ “   
\m
\v 30 ”مِينْ غَا ثڭّذْ \add خنِّي\add*، \add أَ شمْ\add* ثَانْذِينْثْ ثتّْوَاردّدْجْ؟ وَاخَّا أَذْ ثْيَارْضذْ \add أَرُّوضْ ذ\add* أَزڭّْوَاغْ نِيغْ أَذْ ثقّْنذْ ڒهْزُوطْ ن وُورغْ نِيغْ أَذْ ثْكحّْڒذْ ثسّمْغَارِيذْ ثِيطَّاوِينْ نّمْ، أَقَا بَاطڒْ أَذْ ثْزوّْقذْ إِخفْ نّمْ. إِمعْشَاقنْ أَذْ شمْ سّْحقَّارنْ، أَذْ أَرْزُونْ أَذْ شمْ نْغنْ. \f ◼ \fr 4:‏30 \ft \+bd ’أَذْ أَرْزُونْ أَذْ شمْ نْغنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَذْ أَرْزُونْ ڒعْمَارْ نّمْ‘.\f*  
\v 31 مَاغَارْ نشّْ تّسْڒِيغْ ثْمِيجَّا، أَخْمِي زِي ثمْغَارْثْ إِتَّارْونْ، أَخْمِي زڭْ إِشْثنْ ثْحصَّارْ ذِي ثَارْوَا ثَامزْوَارُوثْ، ثْمِيجَّا ن يدْجِيسْ ن صِيهْيُونْ، ثْڒقّضْ-د نّفْسْ، ثسّْوَاژَّاضْ س إِفَاسّنْ نّسْ، \add ثسْغُويُّو\add*: ’ؤُشْثْ إِنُو، مَاغَارْ ڒعْمَارْ إِنُو إِفْنَا س يِينِّي إِخْسنْ أَذْ أَيِي نْغنْ!‘ “   
\b  
\b  
\m  
\c 5
\m
\v 1 ”ؤُيُورمْ ذِي ذْشُورَاثْ ن ؤُرْشَالِيمْ، ؤُشَا خْزَارمْ مْلِيحْ. إِڒِيمْ ثْفثْنمْ ؤُ أَرْزُومْ ذڭْ وَازَّاينْ نّسْ، مَا أَذْ ثَافمْ إِجّنْ، مَا ذِينْ إِجّْ إِتّڭّْ ثَاسڭْذَا، إِجّنْ ونِّي يَارزُّونْ ثِيذتّْ، \add خنِّي\add* نشّْ أَذْ أَسْ غْفَارغْ \add إِ ؤُرْشَالِيمْ\add*. \f ◼ \fr 5:‏1 \ft \+bd ’نشّْ أَذْ أَسْ غْفَارغْ‘\+bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي، أَقَا أَربِّي أَذْ إِغْفَارْ إِ ثنْذِينْثْ ن ؤُرْشَالِيمْ.\f*  
\v 2 نِيثْنِي قَّارنْ: ’س ثِيذتّْ أَمْ إِدَّارْ سِيذِي!‘، \add مَاشَا\add* وَاخَّا أَمنِّي تّْجَادْجَانْ ژُورْ.“   
\m
\v 3 ”\add أَ\add* سِيذِي، مَا وَارْ \add حطَّانْثْ\add* ثِيطَّاوِينْ نّشْ خْ ثِيذتّْ؟ شكْ ثوْثِيذْ ثنْ، مَاشَا وَارْ ؤُشِينْ أَكْ-ذ ڒحْرِيقْ، شكْ ثقْضِيذْ ثنْ، \add مَاشَا\add* وَارْ خْسنْ أَذْ تّْوَاربَّانْ. نِيثْنِي ڭِّينْ ثَانْيَارْثْ نْسنْ إِقسْحنْ خْ وژْرُو، نِيثْنِي ؤُڭِينْ أَذْ د-ذوْڒنْ. \x ◘ \xo 5:‏3 \xt إِشا. 1‏:‏5؛ 9‏:‏12؛ إِرْم. 2‏:‏30\x*  
\v 4 نشّْ نِّيغْ: ’أَهْ، نِيثْنِي ذ ڒْمُوسَاكِينْ، تّڭّنْ ثُوبُّوهڒْيَا، مِينْزِي نِيثْنِي وَارْ سِّيننْ أَبْرِيذْ ن سِيذِي، ثَاسڭْذَا ن أَربِّي نْسنْ.  
\v 5 نشّْ أَذْ ؤُيُورغْ غَارْ إِمقّْرَاننْ ؤُشَا أَذْ كِيذْسنْ سِّيوْڒغْ، مِينْزِي نِيثْنِي وَارْ سِّيننْ شَا أَبْرِيذْ ن سِيذِي، ثَاسڭْذَا ن أَربِّي نْسنْ.‘ نِيثْنِي جْمِيعْ \add مَاشَا\add* أَرْژِينْ زَّايْڒثْ، قطّْسنْ إِسغْوَانْ.  
\v 6 خْ ؤُيَا إِوّثْ إِ-ثنْ وَايْرَاذْ ن ثَاڭَانْثْ، إِمزّقْ إِ-ثنْ وُوشّنْ زِي ڒوْضَاثْ، إِتّْحَامَا ؤُغِيڒَاسْ ثِيندَّامْ نْسنْ. كُوڒْ إِجّْ ونِّي د غَا إِفّْغنْ \add زِي ثنْذِينْثْ\add*، أَذْ ث شَارّْڭنْ، مَاغَارْ إِعذِّيينْ نْسنْ ذ أَطَّاسْ ؤُ أَحيّذْ نْسنْ إِمْغَارْ أَطَّاسْ.“ \f ◼ \fr 5:‏6 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  \x ◘ \xo 5:‏6 \xt إِرْم. 4‏:‏7\x*   
\m
\v 7 ”مَامّشْ \add زمَّارغْ\add* أَذْ أَومْ غْفَارغْ مَانْ أَيَا؟ إِحنْجِيرنْ نّشْ سمْحنْ ذَايِي، تّْجَادْجَانْ غَارْ مِينْ وَارْ إِدْجِي ذ أَربِّي. \add ڒَْامِي\add* ثنْ سّْجِيوْنغْ، زنَّانْ نِيثْنِي، سّْمُوننْ س دّْحَاسْ غَارْ وخَّامْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ.  
\v 8 نِيثْنِي ذ إِكِيذَارنْ إِعڒْفنْ إِتّلِيعنْ. كُوڒْ إِجّْ إِسّْنحْنِيحْ غَارْ ثمْغَارْثْ ن ونّغْنِي. \x ◘ \xo 5:‏8 \xt حِز. 22‏:‏11\x*  
\v 9 مَا وَارْ تّْعِيقِيبغْ خْ مَانْ أَيَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، نِيغْ وَارْ إِتّنْثِيقِيمْ ڒعْمَارْ إِنُو زِي ڒْڭنْسْ أَمْ وَانِيثَا؟“ \x ◘ \xo 5:‏9 \xt إِرْم. 5‏:‏29؛ 9‏:‏9\x*   
\m
\v 10 ”ڭعّْذمْ خْ ڒحْيُوضْ نّسْ ؤُشَا هذْممْ ثنْ، \add مَاشَا\add* وَارْ ثنْ مسّْحمْ قَاعْ زِي ثمُّورْثْ. قڒْعمْ إِزْبِيرنْ نْسنْ، مَاغَارْ نِيثْنِي وَارْ \add دْجِينْ\add* شَا ن سِيذِي. \x ◘ \xo 5:‏10 \xt إِرْم. 4‏:‏27\x*  
\v 11 ثَادَّارْثْ ن إِسْرَائِيل ذ ثَادَّارْثْ ن يَاهُوذَا \add مَاشَا\add* غْذَارنْ أَيِي س وَاطَّاسْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. \x ◘ \xo 5:‏11 \xt إِرْم. 3‏:‏20\x*  
\v 12 نِيثْنِي نكَّارنْ سِيذِي، قَّارنْ: ’نتَّا وَارْ \add ذِينْ\add* إِدْجِي، وَارْ ذ أَنغْ إِڒقّفْ ڒْغَارْ، وَارْ نتّْوِيڒِي سِّيفْ ؤُڒَا ذ ڒَاژْ.  
\v 13 إِنَابِييّنْ أَذْ ذوْڒنْ أَمْ ؤُسمِّيضْ ؤُشَا وَارْ ذِينْ إِدْجِي ونِّي زَّايْسنْ إِسَّاوَاڒنْ. أَمُّو إِ ذ أَسنْ غَا إِمْسَارْ.‘ “   
\m
\v 14 ”س ؤُيَا إِقَّارْ سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ: ’مِينْزِي كنِّيوْ ثقَّارمْ أَوَاڒْ-أَ، خْزَارْ، نشّْ أَذْ ڭّغْ أَوَاڒنْ إِنُو ذڭْ ؤُقمُّومْ نّشْ ذ ثِيمسِّي، ڒْڭنْسْ-أَ \add أَذْ ث ڭّغْ\add* ذ أَكشُّوضْ، ؤُشَا أَذْ ثنْ ثشّْ \add ثْمسِّي\add*. \x ◘ \xo 5:‏14 \xt إِرْم. 1‏:‏9\x*  
\v 15 خْزَارْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل، نشّْ أَذْ خَاومْ سِّيوْضغْ إِجّْ ن ڒْڭنْسْ زِي ڒَاڭّْوَاجْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. أَقَا-ث ذ ڒْڭنْسْ إِوْعَارْ، ڒْڭنْسْ زڭْ وشْحَاڒْ ؤُيَا، ڒْڭنْسْ إِ زِي وَارْ ثسِّينذْ شكْ أَوَاڒْ نّسْ، ؤُ وَارْ ثْفهّْمذْ مِينْ قَّارنْ نِيثْنِي. \x ◘ \xo 5:‏15 \xt أَعَوذ. 28‏:‏49؛ إِرْم. 1‏:‏15؛ 6‏:‏22\x*  
\v 16 أَزعْبُوڒْ نّسْ \add ن فْڒِيثْشَاثْ\add* \add إِڭَّا\add* أَمْ يِيجّْ ن ونْضڒْ يَارزْمنْ، نِيثْنِي مَارَّا ذ أَيْثْ ن بُو-ثغْرُوضْثْ.  
\v 17 أَذْ إِشّْ \add ڒْْڭنْسْ نِّي\add* صَّابثْ نّمْ ذ وغْرُومْ نّمْ، أَذْ إِشّْ إِحنْجِيرنْ نّمْ ذ يسِّيمْ، أَذْ إِشّْ ؤُدْجِي نّمْ ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ نّمْ، أَذْ إِشّْ ثَازَايَارْثْ نّمْ ذ وَارْثُو نّمْ، \add ؤُشَا\add* س سِّيفْ أَذْ إِوّثْ ثِيندَّامْ نّمْ إِفَارْينْ مِينْ خفْ ثتّشْڒذْ.‘ “ \x ◘ \xo 5:‏17 \xt لَاوِي 26‏:‏16؛ أَعَوذ. 28‏:‏31، 33\x*   
\m
\v 18 ”\add مَاشَا\add* ؤُڒَا ذڭْ وُوسَّانْ نِّي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، نشّْ وَارْ كنِّيوْ قطِّيغْ مَارَّا. \x ◘ \xo 5:‏18 \xt إِرْم. 4‏:‏27\x*  
\v 19 مَاڒَا خنِّي كنِّيوْ ثقَّارمْ: ’مَايمِّي ذ أَنغْ إِڭَّا سِيذِي، أَربِّي نّغْ، مَارَّا أَيَا؟‘، \add خنِّي\add* أَذْ أَسنْ ثِينِيذْ: ’أَمْ مَامّشْ كنِّيوْ ذَايِي ثْسمْحمْ، ثتّْسخَّارمْ إِ إِربِّيثنْ \add إِغْرِيبنْ\add* ذِي ثمُّورْثْ نْومْ، أَمُّو إِ غَا ثْسخَّارمْ إِ إِبَارَّانِييّنْ ذِي ثمُّورْثْ وَارْ ثدْجِي نْومْ.‘ “ \x ◘ \xo 5:‏19 \xt إِرْم. 16‏:‏10\x*   
\m
\v 20 ”بَارّْحمْ أَيَا إِ ثَادَّارْثْ ن يَاعْقُوبْ، جّمْ أَذْ \add ث\add* سْڒنْ ذِي يَاهُوذَا، إِنِي:  
\v 21 ’سْڒمْ إِ وَايَا، \add أَ شكْ\add* ڒْڭنْسْ أَبُوهَاڒِي، نهْڒَا وُوڒْ! غَارْومْ ثِيطَّاوِينْ، \add مَاشَا\add* وَارْ تّْوِيڒِينْثْ، إِمزُّوغنْ، \add مَاشَا\add* وَارْ تّسْڒِينْ. \x ◘ \xo 5:‏21 \xt إِشا. 6‏:‏9، 10\x*  
\v 22 مَا وَارْ ذ أَيِي تّڭّْوذمْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. مَا وَارْ ثتّخْسمْ ثتَّارْجِيجِيمْ زَّاثْ إِ وُوذمْ إِنُو، \add إِ نشّْ\add* ونِّي إِڭِّينْ إِ ڒبْحَارْ إِجْذِي ذ ويْمِيرْ، ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا ثنِّي وَارْ زمَّارنْ أَذْ عْذُونْ \add ڒمْوَاجْ\add*. أَقَا تّنْهزَّانْ ڒمْوَاجْ، \add عَاذْ\add* وَارْ زمَّارنْ، تّْهَاجَانْ ڒمْوَاجْ، \add عَاذْ\add* وَارْ تعدُّونْ.‘\x ◘ \xo 5:‏22 \xt أَيُوبْ 38‏:‏10، 11؛ إِزهد. 33‏:‏7؛ 104‏:‏9\x*  
\v 23 \add مَاشَا\add* ڒْڭنْسْ-أَ غَارسْ ؤُڒْ إِحيّْذنْ ذ إِغوّْغنْ. نِيثْنِي حيّْذنْ \add خْ وبْرِيذْ\add* ؤُشَا فّْغنْ.  
\v 24 نِيثْنِي وَارْ قَّارنْ ذڭْ يِيخفْ نْسنْ: ’أجّْ أَنغْ أَذْ نڭّْوذْ سِيذِي، أَربِّي نّغْ نِّي إِتِّيشنْ أَنْژَارْ ذِي ڒْوقْثْ نّسْ، أَنْژَارْ ن زِيشْ ذ ونْژَارْ ن ڒخْمِيمْ، ونِّي إِحطَّانْ إِ نشِّينْ سِّيمَانَاثْ إِتّْوَاڭّنْ ن ثْميْرَا.‘ \x ◘ \xo 5:‏24 \xt أَعَوذ. 11‏:‏14\x*  
\v 25 ڒْمُوعْصِييَّاثْ نْومْ منْعنْثْ مَانْ أَيَا ؤُ دّْنُوبْ نْومْ طّْفنْ خَاومْ مِينْ إِشْنَانْ.  
\v 26 مَاغَارْ ؤُفِينْ إِعفَّاننْ ذِي ڒْڭنْسْ إِنُو. نِيثْنِي تّْحَامَانْ أَمْ يِييمَّارنْ ن يجْضَاضْ. سّْبدَّانْ إِجّْ ن ڒْفخْ إِنقّنْ، أَرزُّونْ أَذْ طّْفنْ إِوْذَانْ.  
\v 27 أَمْ ڒقْفزْ إِشُّورْ س إِجْضَاضْ، أَمُّو ثُوذْرِينْ نْسنْ شُّورنْثْ س ڒْغشّْ. خْ ؤُيَا ذوْڒنْ نِيثْنِي ذ إِمقّْرَاننْ ذ أَيْثْ ن بُو-وَاڭْڒَا.  
\v 28 أَقَا نِيثْنِي ؤُفّنْ س ثَاذُونْثْ، أَقَا أَثنْ ذ إِحْرَايْمِييّنْ، \add س ثْمڭَّا نْسنْ\add* سّْعدُّونْ نِيثْنِي ثِيمڭَّا ثِيعفَّانِينْ أَطَّاسْ. وَارْ حكّْمنْ س ڒْحقّْ ذِي دّعْوثْ، ؤُڒَا ذِي دّعْوثْ ن ؤُيُوجِيڒْ، وَاخَّا أَمنِّي فڒْحنْ نِيثْنِي. عَاوذْ وَارْ شِّيثنْ خْ ثسْغَارْثْ ن إِمزْڒَاضْ. \x ◘ \xo 5:‏28 \xt أَعَوذ. 32‏:‏15؛ إِشا. 1‏:‏23؛ زَاك. 7‏:‏10\x*  
\v 29 مَا وَارْ تّْعِيقِيبغْ خْ مَانْ أَيَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، مَا وَارْ خدْجْفغْ إِخفْ إِنُو زِي ڒْڭنْسْ أَمْ وَانِيثَا؟“ \x ◘ \xo 5:‏29 \xt إِرْم. 5‏:‏9؛ 9‏:‏9\x*   
\b  
\m
\v 30 ”مِينْ إِتّنخْڒَاعنْ ؤُ مِينْ إِدْجَانْ ذ نّْعِي أَقَا إِمْسَارْ ذِي ثمُّورْثْ.  
\v 31 إِنَابِييّنْ تّْنبَّانْ س إِخَارِّيقنْ ؤُشَا إِكهَّاننْ تّْصدْجْضنْ سَاذُو ؤُفُوسْ نْسنْ. ؤُشَا ڒْڭنْسْ إِنُو إِتّخْسْ إِ-ث أَمُّو. مِينْ غَا ثڭّمْ خْمِي د غَا يَاوضْ قطُّو؟“ \x ◘ \xo 5:‏31 \xt إِرْم. 14‏:‏18؛ 23‏:‏25، 26؛ حِز. 13‏:‏6\x*   
\b  
\b  
\m  
\c 6
\m
\v 1 ”سِيوْضمْ إِخفْ نْومْ ذِي ڒَامَانْ زِي ڒْوسْثْ ن ؤُرْشَالِيمْ، \add أَ\add* أَيْثْ ن بِينْيَامِينْ، ؤُشَا سُوضمْ ذڭْ ؤُيِيشّْ ن إِشَارِّي ذِي ثَاقُوعَا. سْڭعّْذمْ أَشنْيَالْ \add س دّخَّانْ\add* زِي بَايْثْ-هَا-كَارِيمْ، مِينْزِي إِسِّيڭْوَاذْ ڒْغَارْ زِي شَّامَالْ، لْمُوصِيبَا ثَامقّْرَانْثْ. \x ◘ \xo 6:‏1 \xt إِرْم. 1‏:‏13، 14\x*  
\v 2 ثَامْغَارْثْ إِشوَّارنْ ذ إِتّْوَاسُّوبُوضنْ، يدْجِيسْ ن صِيهْيُونْ، أَذْ ت سّْهلّْكغْ.  
\v 3 إِمكْسَاونْ أَذْ غَارسْ د-أَسنْ أَكْ-ذ ثْحِيمْرِيوِينْ نْسنْ، نِيثْنِي أَذْ أَسْ د-قوَّارنْ، أَذْ وْثنْ إِقِيضَانْ \add نْسنْ\add* خَاسْ، كُوڒْ إِجّْ أَذْ يَارْوسْ ذِي ثسْغَارْثْ نّسْ. \f ◼ \fr 6:‏3 \ft \+bd ’إِمكْسَاونْ‘\+bd* - نِيغْ: ’إِنِيتْشَانْ‘.\f*  
\v 4 \add أَذْ إِنِينْ\add* ’قدّْسمْ أَمنْغِي ضِيدّْ نّسْ، كَّارمْ، جّمْ أَنغْ أَذْ \add غَارسْ\add* نْڭعّذْ س ؤُزِيڒْ. ؤُشْثْ خَانغْ، مَاغَارْ أَسّْ عْڒَاينْ إِعْذُو، مِينْزِي ثِيڒِيوِينْ ن ثْمذِّيثْ تّْسَارّْحنْثْ-إِ-د.  
\v 5 كَّارمْ، جّمْ أَنغْ أَذْ نْڭعّذْ سْ دْجِيڒثْ، أَذْ نهْذمْ ڒقْصُورْ نّسْ!‘  
\v 6 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي نْ ڒسْكَارَاثْ: قسّمْ ثِيشجُّورَا، سْبدّمْ أَشْبَارْ إِ ڒحْصَارثْ ضِيدّْ إِ ؤُرْشَالِيمْ. ثَا ذ ثَانْذِينْثْ إِ غَا ثتّْوَاعَاقبْ، أَقَا دّدْجْ ذِي ڒْوسْثْ نّسْ مَارَّا.  
\v 7 أَمْ وَانُو إِتّجَّا أَمَانْ نّسْ تّْبقْبُوقنْ، أَمُّو إِ ثتّجَّا \add ؤُرْشَالِيمْ\add* أَذْ إِبقْبقْ مِينْ وَارْ إِحْڒِينْ. \add ڒْْحسّْ ن\add* لْعُونْفْ ذ وَاردّدْجْ إِتّْوَاسڒْ ذَايمْ، ڒحْڒَاشْ ذ ثيِّيثَا أَقَا-ثنْثْ ڒبْذَا زَّاثْ إِ ثِيطَّاوِينْ إِنُو.  
\v 8 أجّْ إِ شمْ أَذْ ثتّْوَاوبّْخذْ، \add أَ\add* ؤُرْشَالِيمْ، حِيمَا ڒعْمَارْ إِنُو وَارْ خَامْ ثتّمْسبْضِي، حِيمَا وَارْ شمْ تَّارِّيغْ ذْ ثَامُّورْثْ إِتّْوَاردّْدْجنْ ذ ثَامُّورْثْ إِخْڒَانْ زڭْ إِمزْذَاغْ.“   
\m
\v 9 ”أَمُّو إِ إِقَّارْ سِيذِي نْ ڒْعسْكَارَاثْ: ’أَمْ ثْزَايَارْثْ أَذْ ڒقْضنْ مِينْ إِقِّيمنْ ن إِسْرَائِيل س شْضَارثْ. أَرّْ أَفُوسْ نّشْ غَارْ ثْسضْوِينْ أَمْ ونِّي إِڒقّْضنْ أَضِيڒْ.‘\x ◘ \xo 6:‏9 \xt إِشا. 24‏:‏13\x*  
\v 10 وِي غَارْ إِ غَا سِّيوْڒغْ نِيغْ ؤُمِي غَاعڒْمغْ نشّْ، \add حِيمَا\add* أَذْ سْڒنْ؟ خْزَارْ، أَمزُّوغْ نْسنْ وَارْ إِتّْوَاخْثنْ، \add أَڒَامِي\add* وَارْ زمَّارنْ أَذْ سْڒنْ إِ وَالُو. أَقَا ذَا، أَوَاڒْ\add أنْ\add* ن سِيذِي تَّافنْ \add ثنْ\add* ذ أَحشِّي، وَارْ ثنْ حْذِيجنْ.“ \x ◘ \xo 6:‏10 \xt إِرْم. 7‏:‏26\x*   
\m
\v 11 ”س ؤُينِّي شُّورغْ س وسْعَارْ ن سِيذِي، أَقَا ؤُحْڒغْ أَذْ ث منْعغْ. ’زدْجعْ \add أَسْعَارْ نّشْ\add* \add خنِّي\add* خْ إِحنْجِيرنْ ذڭْ وبْرِيذْ ؤُڒَا خْ ؤُمُونِي ن إِحُوذْرِييّنْ، مَاغَارْ عَاذْ أَرْيَازْ ذ ثمْغَارْثْ أَذْ ثنْ حبّْسنْ، أَمُّو ؤُڒَا ذ أَمْغَارْ ذ ؤُوسَّارْ.  
\v 12 ثُوذْرِينْ نْسنْ أَذْ ذوْڒنْثْ إِ إِنّغْنِي، جْمِيعْ أَكْ-ذ إِحْوِيشنْ، ؤُڒَا ذ ثِيمْغَارِينْ، مَاغَارْ نشّْ أَذْ سْوِيژّْضغْ س ؤُفُوسْ إِنُو ضِيدّْ إِمزْذَاغْ ن ثمُّورْثْ\add -أَ\add*، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. \x ◘ \xo 6:‏12 \xt أَعَوذ. 28‏:‏30\x*  
\v 13 مَاغَارْ زڭْ ؤُمژْيَانْ أَڒْ أَمقّْرَانْ أَرزُّونْ مَارَّا نِيثْنِي ثِيزِي نْسنْ، ؤُ زڭْ ؤُنَابِي أَڒْ أَكهَّانْ مَارَّا ثْشمّثْ. \x ◘ \xo 6:‏13 \xt إِشا. 56‏:‏11؛ إِرْم. 8‏:‏10\x*  
\v 14 ثَارژِّيثْ ن ڒْڭنْسْ إِنُو خْسنْ أَذْ ت سّْڭنْفَانْ س ڒهْونْ، قَّارنْ: ’ڒهْنَا، ڒهْنَا!‘، مَاشَا وَارْ ذِينْ إِدْجِي ڒهْنَا. \f ◼ \fr 6:‏14 \ft \+bd ’قَّارنْ ’ڒهْنَا، ڒهْنَا!‘، مَاشَا وَارْ ذِينْ إِدْجِي ڒهْنَا.‘\+bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي ’قَّارنْ ’مْلِيحْ، مْلِيحْ!‘، مَاشَا وَارْ ذِينْ مِينْ إِدْجَانْ ذ لمْلِيحْ‘.\f*  \x ◘ \xo 6:‏14 \xt إِرْم. 8‏:‏11؛ حِز. 13‏:‏10\x*  
\v 15 مَا أَذْ سضْحَانْ مِينْزِي تّڭّنْ جّْعِيفشْثْ؟ نِيثْنِي وَارْ تّْسضْحِينْ شَا، ڒحْيَا وَارْ ث سِّيننْ. س ؤُيَا نِيثْنِي أَذْ وْضَانْ جَارْ إِنِّي إِوطَّانْ. غَارْ ڒْوقْثْ نِّي أَذْ زَّايْسنْ خڒْفغْ أَذْ نّْقَارْضنْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\m
\v 16 ”أَمُّو إِ إِقَّارْ سِيذِي: ’بدّمْ غَارْ إِبْرِيذنْ، ؤُشَا حْذَامْ، سقْسَامْ خْ إِبْرِيذنْ ن وشْحَاڒْ ؤُيَا، مَانِي إِدْجَا وبْرِيذْ نِيشَانْ ؤُشَا ؤُيُورمْ خَاسْ، \add خنِّي\add* أَذْ ثَافمْ أَرَّاحثْ إِ ڒعْمَارْ نْومْ!‘ نِيثْنِي \add مَاشَا\add* قَّارنْ: ’نشِّينْ وَارْ \add خَاسْ\add* نڭُّورْ!‘ \x ◘ \xo 6:‏16 \xt مت. 11‏:‏29\x*  
\v 17 نشّْ ڭِّيغْ أَومْ إِعسَّاسنْ، نِّيغْ: ’سْڒمْ إِ ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي!‘، \add مَاشَا\add* نِيثْنِي قَّارنْ: ’نشِّينْ وَارْ \add غَارسْ\add* نسْحسِّي شَا!‘  
\v 18 س ؤُيَا سْڒمْ، \add أَ كنِّيوْ\add* ڒڭْنُوسْ، ؤُ \add شمْ، أَ\add* ثَامسْمُونْثْ!، سّنْ مِينْ غَارْسنْ إِ غَا إِمْسَارنْ!  
\v 19 سڒْ، \add أَ\add* ثَامُّورْثْ، خْزَارْ، نشّْ أَذْ سِّيوْضغْ ڒْغَارْ \add ذ أَمقّْرَانْ\add* خْ ڒْڭنْسْ-أَ، ڒْغِيدْجثْ ن إِنْوَاينْ نْسنْ ثِيعفَّانِينْ، مَاغَارْ نِيثْنِي وَارْ خزَّارنْ شَا غَارْ وَاوَاڒنْ إِنُو ؤُ نْضَارنْ شَّارِيعَا إِنُو.  
\v 20 مَايمِّي ذ أَيِي د غَا يَاوْينْ جَّاوِي زِي شَابَا ذ ؤُغَانِيمْ ؤُحمُّومْ إِتّْفُوحنْ زِي ثمُّورْثْ يِيڭّْوجنْ؟ ثِيغَارْصَا ن وشْمَاضْ نْومْ وَارْ ذ أَيِي د-ؤُسِينْثْ إِ ڒْخَاضَارْ ؤُ ثِيغَارْصَا نْومْ وَارْ ذ أَيِي عْجِيبنْثْ. \x ◘ \xo 6:‏20 \xt إِشا. 1‏:‏11؛ 66‏:‏3؛ عَام. 5‏:‏21؛ مِيخَا 6‏:‏6‏-‏8\x*  
\v 21 س ؤُيَا \add أَمُّو إِ\add* إِقَّارْ سِيذِي: ’خْزَارْ، نشّْ أَذْ ڭّغْ ثِيعنْكْرِيفِينْ إِ ڒْڭنْسْ-أَ ؤُشَا نِيثْنِي أَذْ ذَايْسنْثْ نّْقَارْضنْ جْمِيعْ أَكْ-ذ إِبَابَاثنْ ذ إِحنْجِيرنْ، أَكْ-ذ وَاجَّارْ ذ ؤُمْعَاشَارْ نّسْ، \add أَمُّو\add* إِ غَا هلّْكنْ.‘ “   
\m
\v 22 ”أَمُّو إِ إِقَّارْ سِيذِي: ’خْزَارْ، أَذْ د-يَاسْ إِجّْ ن ڒْڭنْسْ زِي شَّامَالْ، إِجّْ ن ڒْڭنْسْ أَمقّْرَانْ أَذْ إِتّْوَاڒَاغَا زڭْ إِنڭُّورَا ن ثمُّورْثْ. \x ◘ \xo 6:‏22 \xt إِرْم. 50‏:‏41،42،43\x*  
\v 23 نِيثْنِي طّْفنْ ڒْقوْسْ ذ وحْرِيشْ، \add أَقَا-ث ذ إِجّْ ن ڒْڭنْسْ\add* إِوْعَارْ، وَارْ أَرّحْمنْ. دّْرِيزْ نْسنْ إِڭَّا أَمْ زّْهِيرْ ن ڒبْحَارْ ؤُشَا نِيثْنِي نْيِينْ خْ ييْسَانْ. أَمْ ورْيَازْ ن ؤُمنْغِي أَمُّو إِ إِسّْبدّْ نتَّا إِخفْ نّسْ ضِيدّْ نّمْ، \add أَ\add* يدْجِيسْ ن صِيهْيُونْ!“   
\m
\v 24 ”نشِّينْ نسْڒَا خَاسْ ڒخْبَارْ، أَرْخُونْ أَنغْ إِفَاسّنْ نّغْ،  إِڒْقفْ أَنغْ ؤُنذْقفْ، ڒحْرِيقْ أَمْ ن ثمْغَارْثْ إِتَّارْونْ. \x ◘ \xo 6:‏24 \xt إِرْم. 4‏:‏31؛ 49‏:‏24؛ 50‏:‏43\x*  
\v 25 وَارْ تّفّْغمْ غَارْ بَارَّا غَارْ ييَّارْ، وَارْ ڭُّورمْ ذڭْ وبْرِيذْ، مَاغَارْ \add أَقَا ذِينْ\add* سِّيفْ ن ڒعْذُو، ثِيڭّْوُوذِي أَقَا-ت مَانِي مَا!  
\v 26 \add أَ\add* يدْجِيسْ نْ ڒْڭنْسْ إِنُو، بيْسثْ إِخفْ نّمْ س ثْخَانْشثْ \add ن وشْضَانْ\add*، زُوزَّارْ خَامْ \add إِغّضْ\add*، شضْنثْ أَمْ خْ ؤُينِّي ن مِّيسْ نّمْ، سْغُويّْ س ثْغُويِّيثْ ثَامرْزَاڭْثْ، مَاغَارْ ذغْيَا أَذْ خَانغْ د-يَاسْ ؤُمْثحَّايْ.“ \x ◘ \xo 6:‏26 \xt إِرْم. 4‏:‏8\x*   
\b  
\m
\v 27 ”نشّْ ڭِّيغْ شكْ ذ صُّومْعثْ ن ثْعسَّاسْثْ ذِي ڒْڭنْسْ إِنُو، ذ إِشْثْ ن لْقلْعَا، حِيمَا أَذْ ثسّْنذْ أَبْرِيذْ نْسنْ، أَذْ ذَايسْ ثَارْزُوذْ.“   
\b  
\m
\v 28 ”نِيثْنِي مَارَّا ذ إِنِّي إِحيّْذنْ خْ وبْرِيذْ زِي مَارْكَاثْ إِوْعَارنْ قَاعْ، ڭُّورنْ تّنّْضنْ ذِي ثمُّورْثْ تّْشقَّافنْ، نِيثْنِي أَمْ نّْحَاسْ ذ وُوزَّاڒْ، مَارَّا إِذْسنْ ذ أَيْثْ ن بُو-إِمُورْضَاسْ. \x ◘ \xo 6:‏28 \xt حِز. 22‏:‏18\x*  
\v 29 أَرَّابُوزْ إِشْمضْ، ڒخْفِيفْ ثشَّا ث ثْمسِّي، \add مَاشَا\add* ذِي ڒْبَاطڒْ إِسّفْسِي ؤُفسَّايْ أَمُّو س وشْضَارْ، إِعفَّاننْ وَارْ زمَّارنْ أَذْ تّْوَافَارْزنْ.  
\v 30 قَّارنْ أَسْ: ’نُّوقَارْثْ إِمّنْضَارنْ!‘، مَاغَارْ إِنْضَارْ إِ-ثنْ سِيذِي.“ \x ◘ \xo 6:‏30 \xt إِشا. 1‏:‏22\x*   
\b  
\b  
\m  
\c 7
\s1 أَوَاڒْ ن إِرْمِييَا ذِي زَّاوشْثْ ثَامقّْرَانْثْ  
\m
\v 1 أَوَاڒْ نِّي د-إِفّْغنْ زِي سِيذِي غَارْ إِرْمِييَا، إِنَّا:  
\v 2 ”بدّْ ذِي ثوَّارْثْ ن ثَادَّارْثْ ن سِيذِي ؤُشَا ڒَاغَا ذِينِّي أَوَاڒْ-أَ، إِنِي: ’سْڒمْ أَوَاڒْ ن سِيذِي، \add أَ\add* يَاهُوذَا مَارَّا، كنِّيوْ إِنِّي إِتَّاذْفنْ زِي ثوُّورَا-يَا حِيمَا أَذْ ثْبنْذْقمْ زَّاثْ إِ سِيذِي.  
\v 3 أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل:عذْڒمْ إِبْرِيذنْ نّمْ ذ ثْمڭَّا نْومْ، \add خنِّي\add* نشّْ أَذْ كنِّيوْ سّْزذْغغْ ذڭْ ومْشَانْ-أَ. \x ◘ \xo 7:‏3 \xt إِرْم. 7‏:‏3؛ 18‏:‏11؛ 26‏:‏13\x*  
\v 4 وَارْ تّْشَاڒمْ خْ وَاوَاڒنْ ن إِخَارِّيقنْ أَمْ ثقَّارمْ: زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي، زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي، زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي، أَقَا-ت ذ ثَا زعْمَا!  
\v 5 مَاغَارْ \add مْغِيرْ\add* مَاڒَا ثْعذْڒمْ إِبْرِيذنْ نْومْ ذ ثْمڭَّا نْومْ نِيشَانْ، مَاڒَا س ثِيذتّْ ثتّڭّمْ س ڒْحقّْ جَارْ ورْيَازْ ذ ؤُمدُّوكّڒْ نّسْ، \x ◘ \xo 7:‏5 \xt إِرْم. 5‏:‏28\x*  
\v 6 وَارْ حصَّارمْ أَبَارَّانِي، أَيُوجِيڒْ ذ ثَاجَّاتْشْ، ؤُ وَارْ سِّيزِّيڒمْ إِذَامّنْ إِمزْذَاڭنْ ذڭْ ومْشَانْ-أَ ؤُ وَارْ ضفَّارمْ إِربِّيثنْ نّغْنِي إِ ؤُضيّعْ نْومْ، \x ◘ \xo 7:‏6 \xt إِشا. 10‏:‏1، 2؛ 59‏:‏7\x*  
\v 7 \add خنِّي\add* نشّْ أَذْ كنِّيوْ سّْزذْغغْ ذڭْ ومْشَانْ-أَ، ذِي ثمُّورْثْ إِ وْشِيغْ إِ ڒجْذُوذْ نْومْ، زِي ڒبْذَا أَڒْ ڒبْذَا.  
\v 8 خْزَارْ، كنِّيوْ ثتّْشَاڒَامْ خْ إِخَارِّيقنْ نِّي وَارْ إِنفّْعنْ ذِي وَالُو.  
\v 9 ثتَّاشَارمْ، ثْنقّمْ، ثْزنَّامْ، ثتّْجَادْجَامْ ژُورْ، ثتّْقدَّاممْ ثِيوْهِيبِينْ ن ڒبْخُورْ إِ بَاعْلْ ؤُ ثْضفَّارَامْ إِربِّيثنْ نّغْنِي نِّي وَارْ ثسِّينمْ،  
\v 10 ؤُشَا \add خنِّي\add* أَذْ د-ثَاسمْ ثْبدّمْ زَّاثْ إِ وُوذمْ إِنُو ذِي ثَادَّارْثْ-أَ مِينْ خفْ إِتّْوَابَارّحْ س يِيسمْ إِنُو، ؤُشَا \add خنِّي\add* ثْزعْممْ \add عَاذْ\add* أَذْ ثقَّارمْ: ’نشِّينْ نتّْوَاسّنْجمْ!‘، ؤُشَا \add خنِّي\add* ثتّْعَاوَاذمْ ثتّڭّمْ مَارَّا جّْعَايفْ-أَ!  
\v 11 مَا ثذْوڒْ ثَادَّارْثْ-أَ مِينْ خفْ إِتّْوَابَارّحْ إِسمْ إِنُو ذ إِفْرِي ن إِخوَّاننْ ذِي ثِيطَّاوِينْ نْومْ؟ خْزَارْ، \bd نشّْ\bd* ژْرِيغْ ث مْلِيحْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ \x ◘ \xo 7:‏11 \xt مت. 21‏:‏13؛ مك. 11‏:‏17؛ لك. 19‏:‏46\x*   
\b  
\m
\v 12 ”وَاخَّا، ؤُيُورمْ غَارْ ومْشَانْ ن ثْزذِّيغْثْ إِنُو ذِي شِيلُو مَانِي ثُوغَا سّْزذْغغْ إِسمْ إِنُو ذڭْ ؤُمزْوَارُو. خْزَارمْ مِينْ زَّايسْ ڭِّيغْ زِي سِّيبّثْ ن ڒْغَارْ ن ڒْڭنْسْ إِنُو إِسْرَائِيل. \x ◘ \xo 7:‏12 \xt 1 صم. 4‏:‏11؛ إِزهد. 78‏:‏60\x*  
\v 13 \add خنِّي\add* ڒخُّو، مِينْزِي كنِّيوْ ثڭِّيمْ مَارَّا ثِيمڭَّا-يَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، ؤُ نشّْ سِّيوْڒغْ أَكِيذْومْ زڭْ ؤُمزْوَارُو، \add مَاشَا\add* كنِّيوْ وَارْ ثسْڒِيمْ شَا، ؤُ نشّْ ڒَاغِيغْ-د خَاومْ، \add مَاشَا\add* كنِّيوْ وَارْ د-ثَارِّيمْ، \f ◼ \fr 7:‏13 \ft \+bd ’زڭْ ؤُمزْوَارُو‘\+bd* - س ثْعِيبْرَانِيثْ ’سِّيوْڒغْ أَكِيذْومْ ؤُمِي ثُوغَا-يِي تّْفَاقغْ زِيشْ‘.\f*  \x ◘ \xo 7:‏13 \xt 2 إِم. 36‏:‏15؛ أَوڒن. 1‏:‏24؛ إِشا. 65‏:‏12؛ 66‏:‏4؛ إِرْم. 7‏:‏21‏-‏28\x*  
\v 14 \add س ؤُينِّي\add* نشّْ أَذْ ڭّغْ أَكْ-ذ ثَادَّارْثْ-أَ مِينْ خفْ إِتّْوَابَارّحْ إِسمْ إِنُو، مِينْ خفْ ثتّْشَاڒَامْ، ؤُ أَكْ-ذ ومْشَانْ-أَ نِّي وْشِيغْ إِ كنِّيوْ ذ ڒجْذُوذْ نْومْ، أَمْ مَامّشْ ڭِّيغْ أَكْ-ذ شِيلُو.  
\v 15 نشّْ أَذْ كنِّيوْ نْضَارغْ زِي زَّاثْ ن وُوذمْ إِنُو، أَمْ مَامّشْ نْضَارغْ مَارَّا أَيْثْمَاثْومْ، مَارَّا زَّارِيعثْ ن إِفْرَايِيمْ.“   
\b  
\m
\v 16 ”أَ شكْ، وَارْ تّْژَادْجْ إِ ڒْڭنْسْ-أَ ؤُ وَارْ سْڭعّذْ \add ثْمِيجَّا نّشْ\add* حِيمَا أَذْ ثْرُوذْ نِيغْ أَذْ ثژَّادْجذْ ؤُ وَارْ تّْغِيمِي ثتّْرُوذْ-د غَارِي، مَاغَارْ نشّْ وَارْ غَاركْ د-تّسْڒِيغْ. \x ◘ \xo 7:‏16 \xt ؤُف. 32‏:‏10؛ إِرْم. 11‏:‏14؛ 14‏:‏11\x*  
\v 17 مَا وَارْ ثتّْوِيڒِيذْ مِينْ تّڭّنْ نِيثْنِي ذِي ثْندَّامْ ن يَاهُوذَا ؤُ ذڭْ إِبْرِيذنْ ن ؤُرْشَالِيمْ؟  
\v 18 إِحنْجِيرنْ سّْمُونَامْ أَكشُّوضْ، إِبَابَاثنْ \add نْسنْ\add* سّْرَاقَّانْ ثِيمسِّي، ؤُ ثِيمْغَارِينْ تّڭّْونْثْ أَرشْثِي حِيمَا أَذْ سّْوجْذنْثْ ثِيفْضِيڒِينْ إِ ثْجدْجِيذْثْ ن ؤُجنَّا ؤُ حِيمَا أَذْ فَارّْغنْثْ ثِيوْهِيبِينْ ن ؤُسيّبْ زَّاثْ إِ إِربِّيثنْ نّغْنِي مَاحنْذْ أَذْ أَيِي سْعَارنْ. \x ◘ \xo 7:‏18 \xt إِشا. 65‏:‏11؛ إِرْم. 8‏:‏2؛ 19‏:‏13؛ 44‏:‏19؛ إِرْم. 44‏:‏19\x*  
\v 19 مَا سْعَارنْ أَيِي، إِقَّارْ سِيذِي؟ مَا وَارْ ث تّڭّنْ إِ يِيخفْ نْسنْ إِ ڒفْضِيحثْ ن سِيمَانْثْ نْسنْ؟  
\v 20 س ؤُيَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي، خْزَارْ، أَذْ إِتّْوَافَارّغْ وغْضَابْ إِنُو ذ وسْعَارْ إِنُو خْ ومْشَانْ-أَ: خْ إِوْذَانْ، خْ إِمُودَّارنْ، خْ ثْشجُّورَا ذڭْ إِيَّارْ ؤُ خْ ڒْغِيدْجثْ ن وُوذمْ ن ثمُّورْثْ. أَذْ يَارقّْ \add وَاهْ،\add* ؤُ وَارْ \add إِزمَّارْ\add* أَذْ إِتّْوَاسّخْسِي.“   
\b  
\m
\v 21 ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’سْمُونمْ ثِيغَارْصَا ن وشْمَاضْ نْومْ أَكْ-ذ ثْغَارْصَا نْومْ ؤُشَا شّمْ أَيْسُومْ \add نْسنْثْ\add*. \x ◘ \xo 7:‏21 \xt إِشا. 1‏:‏11؛ إِرْم. 6‏:‏20؛ عَام. 5‏:‏21\x*  
\v 22 مَاغَارْ ذڭْ وَاسّْ نِّي ذِي ثنْ سُّوفّْغغْ زِي ثمُّورْثْ ن مِيصْرَا، وَارْ سِّيوْڒغْ أَكْ-ذ ڒجْذُوذْ نْومْ مَاحنْذْ أَذْ أَسنْ وصِّيغْ خْ ثْغَارْصَا ن وشْمَاضْ ذ ثْغَارْصِي.  
\v 23 مَاشَا نشّْ ؤُمُورغْ ثَامسْڒَاشْثْ-أَ ؤُمِي نِّيغْ: ’سْڒمْ-د غَارْ ثْمِيجَّا إِنُو، \add خنِّي\add* نشّْ أَذْ أَومْ إِڒِيغْ ذ أَربِّي ؤُ كنِّيوْ أَذْ أَيِي ثِيڒِيمْ ذ ڒْڭنْسْ ؤُ أَذْ ثُويُورمْ ذِي أَبْرِيذْ مَارَّا نِّي ذ أَومْ إِ غَا ؤُمُورغْ مَاحنْذْ أَذْ ثِيڒِيمْ مْلِيحْ!‘ \x ◘ \xo 7:‏23 \xt ؤُف. 19‏:‏5؛ لَاوِي 26‏:‏12؛ أَعَوذ. 6‏:‏3\x*  
\v 24 \add مَاشَا\add* نِيثْنِي وَارْ سْڒِينْ، وَارْ ذ أَيِي وْشِينْ ؤُمزُّوغْ، نِيثْنِي ضْفَارنْ إِخَارِّيصنْ ذ ڒقْسَاحثْ ن وُوڒْ أَعفَّانْ نْسنْ، ؤُ نِيثْنِي ذوْڒنْ غَارْ ضفَّارْ، وَارْ إِدْجِي غَارْ زَّاثْ. \x ◘ \xo 7:‏24 \xt إِرْم. 2‏:‏27؛ 3‏:‏17؛ 16‏:‏12؛ 32‏:‏33\x*  
\v 25 زڭْ وَاسّْ نِّي ذِي فّْغنْ ڒجْذُوذْ نْومْ زِي مِيصْرَا أَڒْ أَسّْ-أَ، سّكّغْ-د غَارْومْ مَارَّا إِمْسخَّارنْ إِنُو، إِنَابِييّنْ، زڭْ وُوسَّانْ ن وشْحَاڒْ ؤُيَا.  
\v 26 نِيثْنِي وَارْ غَارِي سْڒِينْ ؤُ وَارْ ذ أَيِي وْشِينْ أَمزُّوغْ. نِيثْنِي أَرْنِينْ ذِي ڒقْسَاحثْ مَاهُو ڒجْذُوذْ نْسنْ. \x ◘ \xo 7:‏26 \xt نَاح. 9‏:‏17، 29؛ إِرْم. 17‏:‏23؛ 19‏:‏15\x*  
\v 27 أَذْ كِيذْسنْ ثسَّاوَاڒذْ مَارَّا أَوَاڒنْ-أَ، \add مَاشَا\add* نِيثْنِي وَارْ ذ أَكْ تّسْڒِينْ شَا. شكْ أَذْ أَسنْ ثْڒَاغِيذْ، \add مَاشَا\add* وَارْ خَاكْ د-تَّارِّينْ.  
\v 28 س ؤُيَا إِنِي أَسنْ: ’وَا ذ ڒْڭنْسْ إِ وَارْ إِتّسْڒِينْ غَارْ ثْمِيجَّا ن سِيذِي، أَربِّي نّسْ، ؤُ وَارْ إِتّجِّينْ إِخفْ نّسْ أَذْ إِتّْوَاوبّخْ. أَقَا ثِيذتّْ ثتّْوَاردّدْجْ ؤُ ثتّْوَاقسّْ زڭْ ؤُقمُّومْ نْسنْ!‘ “ \x ◘ \xo 7:‏28 \xt إِرْم. 5‏:‏1، 3\x*   
\b  
\m
\v 29 ”حفّْ ثَاجّْ نّشْ \add ن وعْزَاڒْ\add* ؤُشَا نْضَارْ إِ-ث، وّثْ س إِڭجْذُورنْ خْ ڒڭْعُوذِي \add مَانِي تّْوهّْبنْثْ دّْبَايحْ\add*، مَاغَارْ سِيذِي إِنْضَارْ جِّيڒْ مِينْ خفْ إِدُّوقّزْ \add ؤُفُوڭمْ نّسْ\add*، ؤُشَا إِجَّا إِ-ث. \x ◘ \xo 7:‏29 \xt أَيُوبْ 1‏:‏20؛ إِشا. 15‏:‏2؛ إِرْم. 16‏:‏6\x*  
\v 30 مَاغَارْ إِحنْجِيرنْ ن يَاهُوذَا ڭِّينْ مِينْ \add إِدْجَانْ\add* ذ أَعفَّانْ ذِي ثِيطَّاوِينْ إِنُو، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. نِيثْنِي سّْبدّنْ نّْعَاوَاثْ نْسنْ ن لْ-أَصْنَامْ ذِي ثَادَّارْثْ مِينْ خفْ إِتّْوَاڒَاغَا س يِيسمْ إِنُو مَاحنْذْ أَذْ ت سّْخمّْجنْ.  
\v 31 نِيثْنِي سّْبدّنْ ڒڭْعُوذِي ن ثُوفَاثْ \add مَانِي تّْوهّْبنْثْ دّْبَايحْ،\add* \add ذ ثِينِّي إِدْجَانْ\add* ذِي ثغْزُورْثْ ن مِّيسْ ن هِينُّومْ، حِيمَا أَذْ سّْشمْضنْ إِحنْجِيرنْ ذ ثْحنْجِيرِينْ نْسنْ ذِي ثْمسِّي، مِينْعمَّارْصْ وَارْ ذ أَسنْ ؤُمُورغْ ذ مِينْعمَّارْصْ وَارْ ذ أَيِي د-إِدَّارنْ غَارْ ڒْبَاڒْ.“ \f ◼ \fr 7:‏31 \ft \+bd ’غَارْ ڒْبَاڒْ‘\+bd* - س ثْعِيبْرَانِيثْ ’غَارْ وُوڒْ‘.\f*  \x ◘ \xo 7:‏31 \xt 2 إِج. 23‏:‏10؛ إِرْم. 2‏:‏23؛ 19‏:‏5، 6\x*   
\m
\v 32 ”س ؤُيَا، خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، وَارْ ذ أَسْ تّْڒَاغَانْ عَاذْ ’ثُوفَاثْ‘ نِيغْ ’ثَاغْزُورْثْ ن مِّيسْ ن هِينُّومْ‘، مَاشَا ’ثَاغْزُورْثْ ن ونْغَايْ‘، ؤُشَا ذِي ثُوفَاثْ أَذْ نضْڒنْ \add إِمتَّانْ\add*، مِينْزِي مَانِي نّغْنِي وَارْ ذِينْ أَمْشَانْ.  
\v 33 ڒْخشْبَاثْ ن ڒْڭنْسْ-أَ أَذْ ذوْڒنْثْ ذ مَاشَّا إِ إِجْضَاضْ ن ؤُجنَّا ؤُ إِ ڒْمَاڒْ ن ييَّارْ ؤُشَا ؤُڒَا ذ إِجّْ وَارْ ثنْ إِسِّيڭّْوِيذْ. \x ◘ \xo 7:‏33 \xt أَعَوذ. 28‏:‏26؛ إِرْم. 34‏:‏20\x*  
\v 34 زِي ثْندَّامْ ن يَاهُوذَا ؤُ زڭْ إِبْرِيذنْ ن ؤُرْشَالِيمْ أَذْ سّْبدّغْ ثْمِيجَّا ن ؤُسْڒِيوْڒوْ ذ ثْمِيجَّا ن ڒفْرَاحثْ، ثْمِيجَّا ن مُوڒَايْ ذ ثْمِيجَّا ن ثسْڒِيثْ، مَاغَارْ ثَامُّورْثْ أَذْ ثذْوڒْ ذ ڒْخَارْبثْ.“\x ◘ \xo 7:‏34 \xt إِشا. 24‏:‏7؛ إِرْم. 16‏:‏9؛ 25‏:‏10؛ حِز. 26‏:‏13؛ حُوش. 2‏:‏13\x*   
\b  
\b  
\m  
\c 8
\m
\v 1 ”ذِي ڒْوقْثْ نِّي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَذْ سُّوفّْغنْ إِغْسَانْ ن إِجدْجِيذنْ ن يَاهُوذَا، إِغْسَانْ ن ڒْحُوكَّامْ نْسنْ، إِغْسَانْ ن إِكهَّاننْ نْسنْ، إِغْسَانْ ن إِنَابِييّنْ نْسنْ ذ يغْسَانْ ن إِمزْذَاغْ ن ؤُرْشَالِيمْ زڭْ إِمضْڒَانْ نْسنْ.  
\v 2 أَذْ بزّْعنْ \add إِخْسَانْ\add* إِ ثْفُوشْثْ ذ ثْزِيرِي ؤُ إِ مَارَّا إِثْرَانْ ن ؤُجنَّا، إِنِّي ثُوغَا تّخْسنْ، إِنِّي ؤُمِي ثُوغَاعبّْذنْ، إِنِّي ثُوغَا ضفَّارَانْ ذ يِينِّي ثُوغَا زَّايْسنْ أَرزُّونْ شّْوَارْ ذ يِينِّي ؤُمِي ثُوغَا سجَّاذنْ. وَارْ ثنْ د-يَارّْونْ، وَارْ ثنْ نطّْڒنْ، \add مَاشَا\add* أَذْ إِڒِينْ ذ ڒغْبَارْ خْ وُوذمْ ن ثمُّورْثْ. \x ◘ \xo 8:‏2 \xt إِرْم. 7‏:‏18؛ 19‏:‏13\x*  
\v 3 نِيثْنِي أَذْ خْسنْ ڒْموْثْ خْ ثُوذَارْثْ جَارْ مَارَّا إِنِّي إِقِّيمنْ زڭْ يِينِّي إِقِّيمنْ ن ثقْبِيتْشْ ن ڒْڭنْسْ-أَ ثَاعفَّانْثْ، ذِي مَارَّا إِمُوشَانْ مَانِي \add دْجَانْ\add* إِنِّي \add عَاذْ\add* إِقِّيمنْ، مَانِي خَاسنْ ؤُژّْڒغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي نْ ڒْعسْكَارَاثْ.“   
\b  
\m
\v 4 ”إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي: مَا أَذْ وْضَانْ أَڒْ غَا قِّيمنْ وَارْ تّكَّارَانْ \add عَاذْ\add*؟ مَا أَذْ \add خَافِي\add* حيّْذنْ ؤُ وَارْ د-تّْعِيقِّيبنْ؟  
\v 5 مَايمِّي إِحيّذْ ڒْڭنْسْ-أَ، ؤُرْشَالِيمْ \add ثَانِيثَا\add*، ڒبْذَا \add زَّايِي\add*؟ نِيثْنِي شبَّارنْ ذڭْ وشْمَاثْ، ؤُڭِينْ أَذْ غَارِي د-ذوْڒنْ.  
\v 6 نشّْ سّْحسّغْ، سْڒِيغْ: مِينْ سَّاوَاڒنْ، وَارْ ث تّڭّنْ، ؤُڒَا ذ إِجّنْ وَارْ إِنْذِيمْ خْ ڒْغَارْ نّسْ، أَذْ يِينِي: مِينْ ڭِّيغْ؟ كُوڒْ إِجّْ إِقِّيمْ إِتَّازّڒْ أَمْ ؤُيِيسْ إِتَّازّْڒنْ غَارْ ؤُمنْغِي.  
\v 7 ؤُڒَا ذ أَبلَّارْجْ ذڭْ ؤُجنَّا إِسّنْ ڒوْقَاثْ إِتّْوَاڭّنْ نّسْ. ثَاجْلِيلّحْثْ ذ ثْفَاڒْدْجسْثْ نِّي إِطَّاونْ ذڭْ ونّضْ، حْضَانْثْ ڒْوقْثْ ن وُوفُّوغْ نْسنْثْ، ڒْڭنْسْ إِنُو \add مَاشَا\add* وَارْ إِسِّينْ ڒْحقّْ ن سِيذِي. \x ◘ \xo 8:‏7 \xt إِرْم. 5‏:‏4، 5\x*  
\v 8 مَامّشْ ثقَّارمْ: نشِّينْ ذ إِمِيغِيسنْ ذ شَّارِيعَا ن سِيذِي أَقَا-ت أَكِيذْنغْ! س ثِيذتّْ، خْزَارْ، ڒقْڒمْ ن إِخَارِّيقنْ ن إِمَارِيرنْ إِڭَّا \add شَّارِيعَا\add* ذ أَخَارِّيقْ.  
\v 9 إِمِيغِيسنْ تّْسضْحَانْ، تّڭّْوذنْ ؤُشَا تّْوَاحبّْسنْ. خْزَارْ، نْضَارنْ أَوَاڒْ ن سِيذِي، \add خنِّي\add* مَامّشْ إِ ثدْجَا ثِيغِيثْ إِ غَارْسنْ؟“   
\m
\v 10 ”س ؤُيَا أَذْ وْشغْ ثِيمْغَارِينْ نْسنْ إِ إِنّغْنِي، إِيَّارنْ نْسنْ إِ يِينِّي إِ غَا إِحوّْسنْ \add ثَامُّورْثْ\add*، مَاغَارْ زڭْ ؤُمژْيَانْ أَڒْ أَمقّْرَانْ أَرزُّونْ مَارَّا نِيثْنِي ثِيزِي نْسنْ، زڭْ ؤُنَابِي أَڒْ أَكهَّانْ مَارَّا ثْشمّثْ. \x ◘ \xo 8:‏10 \xt إِشا. 56‏:‏11؛ إِرْم. 6‏:‏12، 13، 14، 15\x*  
\v 11 ثَارژِّيثْ ن ڒْڭنْسْ إِنُو خْسنْ أَذْ ت سّْڭنْفَانْ س ڒهْونْ أَمْ قَّارنْ: ’ڒهْنَا، ڒهْنَا!‘، مَاشَا وَارْ ذِينْ إِدْجِي ڒهْنَا.  
\v 12 مَا أَذْ سضْحَانْ نِيثْنِي، مِينْزِي تّڭّنْ جّْعِيفشْثْ؟ نِيثْنِي وَارْ تّْسضْحِينْ شَا، ڒحْيَا وَارْ ث سِّيننْ. س ؤُيَا أَذْ وْضَانْ جَارْ إِنِّي إِوطَّانْ. ذِي ڒْوقْثْ مڒْمِي زَّايْسنْ إِ غَا خڒْفغْ أَذْ نّْقَارْضنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“  
\v 13 ”نشّْ أَذْ ثنْ ڒقْضغْ قَاعْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. وَارْ إِقِّيمْ \add عَاذْ\add* ؤُضِيڒْ غَارْ ثْزَايَارْثْ ؤُ وَارْ ثقِّيمْ \add عَاذْ\add* ثَازَارْثْ غَارْ ثْشجَّارْثْ ن وَارْثُو، \add عَاذْ\add* ثِيفْرَايْ وْضَانْثْ. نشّْ أَذْ غَارْسنْ أَوْيغْ إِنِّي خَاسنْ إِ غَا إِعفْسنْ.“ \x ◘ \xo 8:‏13 \xt إِشا. 5‏:‏1‏-‏7؛ مت. 21‏:‏19؛ لك. 13‏:‏6‏-‏9\x*   
\m
\v 14 ”مَايمِّي ذَا نَارْنِي ذڭْ ؤُغِيمِي؟ إِتّْخصَّا أَنغْ أَذْ نْمُونْ، أَذْ نَاذفْ غَارْ ثْندَّامْ إِفَارْينْ، ؤُشَا أَذْ ذِينْ نسْقَارْ. أَقَا سِيذِي، أَربِّي نّغْ، يَارَّا أَنغْ أَذْ نسْقَارْ ؤُشَا إِوْشَا أَنغْ أَمَانْ إِسْمُومنْ، مَاغَارْ نخْضَا خْ سِيذِي. \x ◘ \xo 8:‏14 \xt إِرْم. 4‏:‏5؛ 9‏:‏15؛ 23‏:‏15\x*  
\v 15 نسِّيتِّيمْ ذِي ڒهْنَا، \add مَاشَا\add* وَارْ ذِينْ مِينْ إِصبْحنْ، ذِي ڒْوقْثْ ن ؤُسْڭنْفِي، \add مَاشَا\add* خْزَارْ، \add مْغِيرْ\add* أَسْنخْڒِيعْ. \x ◘ \xo 8:‏15 \xt إِرْم. 14‏:‏19\x*  
\v 16 زِي ذَانْ إِتّْوَاسڒْ ؤُسَاحَارْثْ ن ييْسَانْ نّسْ، زڭْ وسْنحْنحْ ن \add ييْسَانْ\add* إِجهْذنْ نّسْ ثنْهزَّا مَارَّا ثَامُّورْثْ. نِيثْنِي أَذْ د-أَسنْ أَذْ شّنْ ثَامُّورْثْ ذ ڒْغِيدْجثْ نّسْ، ثَانْذِينْثْ أَكْ-ذ إِمزْذَاغْ نّسْ. \x ◘ \xo 8:‏16 \xt إِرْم. 4‏:‏15\x*  
\v 17 مَاغَارْ خْزَارْ، نشّْ أَذْ سّكّغْ جَارْ أَومْ إِفِيغْرَانْ، إِفِيغْرَانْ ن أَرّْهَاجْ، أَكِيذْسنْ وَارْ إِنفّعْ ؤُعزّمْ. إِنَا أَذْ كنِّيوْ زعْفنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ \x ◘ \xo 8:‏17 \xt إِزهد. 58‏:‏5، 6\x*   
\b  
\m  
\s1 ڒحْڒِيقْ ذڭْ وُوڒْ ن إِرْمِييَا  
\m
\v 18 ”أَمْحَاذْ إِنُو أَقَا إِذْوڒْ ذ أَشْضَانْ، ؤُڒْ إِنُو يُوحڒْ أَطَّاسْ ذڭْ إِخفْ إِنُو.  
\v 19 خْزَارْ، ڒْحسّْ ن إِغُويَّانْ ن يدْجِيسْ ن ڒْڭنْسْ إِنُو زِي ثمُّورْثْ ثِيڭّْوجْ: ’مَا سِيذِي وَارْ إِدْجِي ذِي صِيهْيُونْ، مَا وَارْ ذَايسْ إِدْجِي ؤُجدْجِيذْ نّسْ؟‘ “  
\b  
\m ”مَايمِّي ذ أَيِي سْعَارنْ س ڒخْيَاڒَاثْ نْسنْ إِنقْشنْ، س \add لْ-أَصْنَامْ\add* إِبطّْڒنْ ن إِبَارَّانِييّنْ؟“   
\b  
\m
\v 20 ”ثعْذُو ثْميْرَا، إِفّغْ ؤُنبْذُو، \add ؤُ\add* نشِّينْ عَاذْ وَارْ ننْجِيمْ.  
\v 21 نشّْ تّْوَارْژِيغْ زِي سِّيبّثْ ن ثَارژِّيثْ ن يسِّيسْ ن ڒْڭنْسْ إِنُو. نشّْ أَرْضغْ أَرُّوضْ ذ أَبَارْشَانْ، إِشبَّارْ ذَايِي ؤُنخْڒِيعْ. \f ◼ \fr 8:‏21 \ft \+bd ’ثَارژِّيثْ‘\+bd* - إِخْسْ أَذْ يِينِي ’أَيزِّيمْ يَارزْمنْ‘ ونِّي د-يُوسِينْ أَكْ-ذ دّْنُوبْ ن ڒْڭنْسْ ن إِسْرَائِيل ذ يَاهُوذَا ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ مِينْزِي وَارْ خْسنْ أَذْ ذوْڒنْ غَارْ أَربِّي. خْزَارْ عَاوذْ إِشا. 1. س وَاوَاڒْ ’ثَارژِّيثْ‘ إِشيَّارْ ؤُنَابِي إِرْمِييَا عَاوذْ غَارْ ؤُوطُّو إِ د-يُوسِينْ غَارْ ؤُرْشَالِيمْ س ؤُفُوسْ ن ؤُجدْجِيذْ ن بَابِيلْ إِ خْ إِسَّاوَاڒْ إِرْمِييَا ذڭْ وُوذمْ-أَ ن ڒشْثَابْ ن إِرْمِييَا.\f*  
\v 22 مَا وَارْ ذِينْ إِدْجِي بَالْسَامْ ذِي جِيلْعَاذْ؟ مَا وَارْ ذِينِّي إِدْجِي ؤُمسْڭنْفُو؟ مَايمِّي وَارْ إِنِّيضْ ؤُيزِّيمْ ن يدْجِيسْ ن ڒْڭنْسْ إِنُو؟ \x ◘ \xo 8:‏22 \xt أَمز. 37‏:‏24؛ إِرْم. 46‏:‏11؛ 51‏:‏8\x*  
\v 23 أَخْ، مْڒِي أَزدْجِيفْ إِنُو ذ أَمَانْ، ثِيطّْ إِنُو ذ ڒْعُونْصَارْ ن إِمطَّاونْ، \add خنِّي\add* أَزِيڒْ ذ دْجِيڒثْ إِڒِي رُوغْ خْ يِينِّي إِتّْوَانْغنْ ن يدْجِيسْ ن ڒْڭنْسْ إِنُو.“ \x ◘ \xo 8:‏23 \xt إِشا. 22‏:‏4؛ إِرْم. 4‏:‏19\x*   
\b  
\b  
\m  
\c 9
\s1 أَشثْشِي ن سِيذِي أَربِّي  
\m
\v 1 ”أَخْ، مْڒِي غَارِي ثَازذِّيغْثْ ذِي ڒخْڒَا إِ إِمْسبْرِيذنْ، \add خنِّي\add* إِڒِي سمْحغْ ذِي ڒْڭنْسْ إِنُو، ؤُيُورغْ، مَاغَارْ نِيثْنِي مَارَّا ذ إِزنَّاينْ، أَمُونِي ن إِغدَّارنْ. \x ◘ \xo 9:‏1 \xt إِرْم. 5‏:‏7، 8\x*  
\v 2 نِيثْنِي سّْقضْعنْ إِڒسْ نْسنْ، ڒْقوْسْ \add إِشُّورْ س\add* إِخَارِّيقنْ. نِيثْنِي وَارْ ذْوِيڒنْ ذ أَيْثْ ن بُو-ثغْرُوضْثْ ذِي ثمُّورْثْ س ڒْمَانثْ، مَاغَارْ نِيثْنِي ؤُيُورنْ زِي ثْعفَّانْثْ غَارْ ؤُتْشْمَاسْ ؤُمِي وَارْ ذ أَيِي سِّيننْ شَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. \x ◘ \xo 9:‏2 \xt إِشا. 59‏:‏4، 13، 15؛ إِرْم. 6‏:‏7\x*  
\v 3 أجّْ كُوڒْ  إِجّْ أَذْ إِحْضَا إِخفْ نّسْ زڭْ ؤُمدُّوكّڒْ نّسْ، وَارْ تّْشِيڒمْ ؤُڒَا خْ ثَاوْمَاثْ، مَاغَارْ كُوڒْ ثَاوْمَاثْ ثتّڭّْ مْغِيرْ أَشْمَاثْ ؤُ كُوڒْ أَمدُّوكّڒْ إِتّنّضْ أَمْ إِتّْشقَّافْ س ڒْهَارْذْ نّسْ. \x ◘ \xo 9:‏3 \xt إِرْم. 6‏:‏28\x*  
\v 4 كُوڒْ إِجّْ إِتّْغَارَّا أَمدُّوكّڒْ نّسْ، وَارْ قَّارنْ شَا ثِيذتّْ. نِيثْنِي سّڒْمَاذنْ إِ يِيڒسْ نْسنْ أَذْ إِسّْخَارّقْ، نِيثْنِي سَّاحَاڒنْ إِخفْ نْسنْ س مِينْ وَارْ إِسڭّْذنْ.  
\v 5 ثَازذِّيغْثْ نّشْ ثْبدّْ ذِي ڒْوسْطْ ن وشْمَاثْ. س وشْمَاثْ \add نْسنْ\add*عوّْڒنْ أَذْ أَيِي سّْننْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\m
\v 6 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: ’خْزَارْ، نشّْ أَذْ ثنْ سّْفسْيغْ ؤُ أَذْ ثنْ جَارّْبغْ، مَاغَارْ مَامّشْ غَا ڭّغْ أَذْ كَّارغْ \add خنِّي\add* أَكْ-ذ يدْجِيسْ ن ڒْڭنْسْ إِنُو؟  
\v 7 إِڒسْ نْسنْ أَمْ فْڒِيثْشَا ن ڒْقوْسْ إِنقّنْ، أَقَا إِسَّاوَاڒْ س وشْمَاثْ. س ؤُقمُّومْ نّسْ كُوڒْ  إِجّْ إِسَّاوَاڒْ خْ ڒهْنَا أَكْ-ذ ؤُمدُّوكّڒْ نّسْ، \add مَاشَا\add* ذڭْ وُوڒْ نّسْ إِسّوْجَاذْ أَسْ إِجّْ ن ڒْفخْ. \x ◘ \xo 9:‏7 \xt إِزهد. 12‏:‏3؛ 28‏:‏3؛ 120‏:‏4؛ أَوڒن. 30‏:‏14\x*  
\v 8 مَا وَارْ زَّايْسنْ خدْجْفغْ زِي مَانْ أَيَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. مَا وَارْ إِخدْجفْ ڒعْمَارْ إِنُو زِي ڒْڭنْسْ أَمْ وَا؟“ \x ◘ \xo 9:‏8 \xt إِرْم. 5‏:‏9، 29\x*   
\b  
\m
\v 9 ”نشّْ أَذْ رُوغْ، أَذْ سّْڭعّْذغْ ثْغُويِّيثْ ن ؤُوحْوحْ خْ إِذُورَارْ ذ يزْڒِي ن وشْضَانْ خْ دّْمَانِي ن ثَاروْسَا، مَاغَارْ تّْوَاشمْضنْ أَڒَامِي ؤُڒَا ذ إِجّْ وَارْ سّنِّي د-إِتّكّْ ؤُ وَارْ تّسْڒِينْ ڒْحسّْ ن ثْحِيمْرِيوِينْ عَاذْ. زڭْ إِجْضَاضْ ن ؤُجنَّا أَڒْ ڒْمَاڒْ \add مَارَّا\add* أَروْڒنْ، كَّارنْ ؤُيُورنْ.“   
\b  
\m
\v 10 ”أَذْ أَرّغْ ؤُرْشَالِيمْ ذ إِزلِّيجنْ ن وژْرُو، ذ أَمْشَانْ ن ؤُذُورِّي إِ وُوشَّاننْ ن ڒخْڒَا، ؤُشَا ثِيندَّامْ ن يَاهُوذَا أَذْ ثنْثْ ڭّغْ ذ ثَامُّورْثْ إِتّْوَاردّْدْجنْ نِّي ذِي وَارْ إِزدّغْ ؤُڒَا ذ إِجّْ.“ \x ◘ \xo 9:‏10 \xt إِرْم. 10‏:‏22\x*   
\b  
\m
\v 11 ”وِي إِدْجَانْ ذ أَرْيَازْ أَمِيغِيسْ، أَقَا أَذْ إِحَاكَا ذڭْ ؤُيَا، ؤُ وِي غَارْ إِسِّيوڒْ ؤُقمُّومْ ن سِيذِي؟ أجّْ إِ-ث أَذْ \add زَّايسْ\add* إِبَارّحْ \add خنِّي\add*! مَايمِّي ثتّْوَاخَارّبْ ثَامُّورْثْ، ثتّْوَاسّشْمضْ أَمْ ڒخْڒَا أَڒَامِي ؤُڒَا ذ إِجّْ وَارْ ت إِتّْشُوقِي؟“   
\b  
\m
\v 12 ”سِيذِي إِنَّا: ’ڒَْامِي أَرْخُونْ نِيثْنِي زِي شَّارِيعَا إِنُو ثنِّي ذ أَسنْ وْشِيغْ زَّاثْ إِ ؤُغمْبُوبْ نْسنْ، ؤُ وَارْ سْڒِينْ غَارْ ثْمِيجَّا إِنُو ؤُ وَارْ ت ضْفَارنْ،  
\v 13 مَاشَا ضْفَارنْ ڒقْسَاحثْ ن وُوڒْ \add ن يِيخفْ\add* نْسنْ ؤُڒَا ذ ’إِبَاعْلنْ‘ أَمْ مَامّشْ إِ ذ أَسنْ سّڒْمَاذنْ ڒجْذُوذْ نْسنْ،  
\v 14 س ؤُيَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: خْزَارْ، نشّْ أَذْ وْشغْ شِّيحْ إِ ڒْڭنْسْ-أَ حِيمَا أَذْ ث شّنْ ؤُڒَا ذ أَمَانْ ن أَرّْهَاجْ حِيمَا أَذْ ثنْ سْونْ. \x ◘ \xo 9:‏14 \xt إِرْم. 8‏:‏14؛ 23‏:‏15\x*  
\v 15 نشّْ أَذْ ثنْ زُوزَّارغْ جَارْ ڒڭْنُوسْ نِّي وَارْ سِّيننْ، وَارْ إِدْجِي نِيثْنِي ؤُڒَا ذ ڒجْذُوذْ نْسنْ، ؤُ نشّْ أَذْ خَاسنْ سّكّغْ سِّيفْ أَڒْ ثنْ قْضِيغْ.‘ \x ◘ \xo 9:‏15 \xt لَاوِي 26‏:‏33\x*  
\v 16 أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: ’حْضَامْ، ڒَاغَامْ-د إِ ثمْغَارِينْ إِ وشْضَانْ مَاحنْذْ أَذْ د-أَسنْثْ، ؤُشَا جّمْ ؤُڒَا ذ ثِيمْغَارِينْ ثِيمِيغِيسِينْ أَذْ د-أَسنْثْ!‘ “   
\m
\v 17 ”\add نشّْ نِّيغْ، وَاهْ،\add* جّمْ ثنْثْ أَذْ ذغْيَانْثْ ؤُ أَذْ سّْڭعّْذنْثْ ثْغُويِّيثْ ن وشْضَانْ خَانغْ أَڒْ د-أَزّْڒنْثْ ثِيطَّاوِينْ نّغْ س إِمطَّاونْ ؤُ وَامَانْ أَذْ د-هْوَانْ خْ وَابْڒِيونْ.  
\v 18 مَاغَارْ ثْغُويِّيثْ ن وشْضَانْ سْڒِينْ أَسْ-د زِي صِيهْيُونْ: ’أَخْ، مَامّشْ نتّْوَاردّدْجْ، نشِّينْ نْسضْحَا أَطَّاسْ مَاغَارْ ثُوغَا خَانغْ أَذْ نكَّارْ أَذْ نسْمحْ ذِي ثمُّورْثْ نّغْ، مَاغَارْ ثِيزذِّيغِينْ نّغْ هذْمنْ ثنْثْ.‘  
\v 19 سْڒنْثْ خنِّي إِ وَاوَاڒْ ن سِيذِي، \add أَ\add* ثِيمْغَارِينْ، أجّْ أَمزُّوغْ نْكنْثْ أَذْ إِكْسِي أَوَاڒْ زڭْ ؤُقمُّومْ نّسْ. سْڒمْذنْثْ يسِّيثْكنْثْ أَذْ شضْننْثْ ؤُشَا أَذْ ثسّڒْمذْ كُوڒْ ثَامْغَارْثْ إِشْثْ ن وزْڒِي ن وشْضَانْ إِ ثْمدُّوكّتْشْثْ نّسْ.  
\v 20 مِينْزِي ڒْموْثْ ثْڭعّذْ-د زِي ڒكْوَازِي نّغْ، يُوذفْ-د غَارْ ڒقْصُورْ نّغْ مَاحنْذْ أَذْ إِقْضعْ إِحنْجِيرنْ إِمژْيَاننْ زِي زّْنَاقِي ذ إِحُوذْرِييّنْ زڭْ وَازَّاينْ.“   
\b  
\m
\v 21 ”سِيوڒْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي:  
\m \qt ’ڒْْخشْبثْ ن بْنَاذمْ أَذْ ثوْضَا\qt*  
\m \qt أَمْ ڒغْبَارْ خْ ييَّارْ،\qt*  
\m \qt ؤُ أَمْ ثْقبِّيضْثْ \+tl ن إِمنْذِي\+tl*\qt*  
\m \qt أَوَارْنِي إِ ونِّي إِمجَّارنْ\qt*  
\m \qt نِّي وَارْ ث إِ غَا إِجَارْونْ ؤُڒَا ذ إِجّْ.“\qt* \x ◘ \xo 9:‏21 \xt إِرْم. 7‏:‏33\x*   
\b  
\m
\v 22 ”أَمُّو إِ إِقَّارْ سِيذِي: ’وَارْ إِتّْفيِّيشْ ؤُمِيغِيسْ س ثِيغِيثْ \add ن يِيخفْ نّسْ\add* ؤُڒَا ذ بُو-ثغْرُوضْثْ وَارْ إِتّْفيِّيشْ س جّْهذْ نّسْ، بُو-وَاڭْڒَا وَارْ إِتّْفيِّيشْ س وَاڭْڒَا نّسْ. \x ◘ \xo 9:‏22 \xt 1 كُور. 1‏:‏31؛ 2 كُور. 10‏:‏17\x*  
\v 23 مَاشَا ونِّي إِتّْفيَّاشنْ، أجّْ إِ-ث أَذْ إِسّمْغَارْ، بلِّي نتَّا غَارسْ ڒفْهَامثْ ؤُ إِسّنْ أَيِي، بلِّي نشّْ ذ سِيذِي نِّي إِتّڭّنْ س ثْمخْسِيوْثْ إِشوَّارنْ ذ ڒْحقّْ ذ ثْسڭْذَا ذِي ثمُّورْثْ، مَاغَارْ ثِيمسْڒَايِينْ-أَ تّعْجِيبنْثْ أَيِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.‘ “   
\b  
\m
\v 24 ”خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَقَا نشّْ أَذْ خڒْفغْ زِي مَارَّا إِنِّي إِخثْننْ، \add مَاشَا وَاخَّا أَمنِّي\add* غَارْسنْ \add عَاذْ\add* ڒعْذَاڒْيثْ،  
\v 25 زِي مِيصْرَا ذ يَاهُوذَا ذ إِذُومْ ذ أَيْثْ ن عَامُّونْ ذ مُوآبَ ذ مَارَّا إِنِّي إِتّْحفَّانْ \add أَشُوَّافْ\add* غَارْ طّْرُوفَا، إِنِّي إِزدّْغنْ ذِي ڒخْڒَا، مَاغَارْ مَارَّا ڒڭْنُوسْ وَارْ تّْوَاخثْننْ، مَاشَا مَارَّا ثَادَّارْثْ ن إِسْرَائِيل أَقَا غَارْسنْ ڒعْذَاڒْيثْ خْ وُوڒْ.“ \x ◘ \xo 9:‏25 \xt لَاوِي 19‏:‏27؛ 21‏:‏5؛ 26‏:‏41؛ إِرْم. 9‏:‏25؛ 25‏:‏23؛ 49‏:‏32؛ رُوم. 2‏:‏28، 29 \x*   
\b  
\b  
\m  
\c 10
\m
\v 1 ”سْڒمْ أَوَاڒْ إِ زِي غَارْومْ د-إِسَّاوَاڒْ سِيذِي، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل!  
\v 2 أَمُّو إِ إِقَّارْ سِيذِي: ’وَارْ ڒمّْذمْ أَبْرِيذْ ن ڒڭْنُوسْ إِ يِيخفْ نّمْ ؤُ وَارْ تّْنخْڒِيعمْ زِي ڒعْڒَامَاثْ ن ؤُجنَّا، وَاخَّا ڒڭْنُوسْ تّْنخْڒَاعنْ زَّايْسنْثْ.  
\v 3 مَاغَارْ مِينْ حسّْبنْ ڒڭْنُوسْ ذ ڒْحقّْ أَقَا-ث ذِي ڒْبَاطڒْ، مِينْزِي أَقَا أَيَا ذ أَكشُّوضْ نِّي د-قسّنْ زڭْ وزْغَارْ، ذْ ڒْخذْمثْ ن إِفَاسّنْ ن بُو-صّنْعثْ نِّي إِڭَّا س إِميْذِي ن ومْزِيڒْ. \f ◼ \fr 10:‏3 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  \x ◘ \xo 10:‏3 \xt إِشا. 44‏:‏14‏-‏17\x*  
\v 4 زوّْقنْ ت س نُّوقَارْثْ ذ وُورغْ، س إِمسْمِيرنْ ذ إِفْضِيسنْ سّْمثْننْ ت \add أَڒَامِي\add* وَارْ ثقِّيمْ ثتّنْخُوخُوڒْ. \x ◘ \xo 10:‏4 \xt إِشا. 41‏:‏7\x*  
\v 5 أَقَا أَثنْثْ أَمْ يِيشْثْ ن ثْشجَّارْثْ إِسَّاوَاڒنْ إِ \add ذِينْ\add* إِبدّنْ، \add مَاشَا\add* وَارْ زمَّارنْ أَذْ سِّيوْڒنْ، \add إِتّْخصَّا\add* أَذْ ثنْثْ أَرْبُونْ، مِينْزِي وَارْ زمَّارنْثْ أَذْ ؤُيُورنْثْ. وَارْ زَّايْسنْثْ ثڭّْوذمْ شَا، مَاغَارْ نِيثنْثِي وَارْ زمَّارنْثْ أَذْ ڭّنْثْ مِينْ إِعفّْننْ، ؤُ \add وَارْ زمَّارنْثْ\add* أَذْ ڭّنْثْ مِينْ إِصبْحنْ.‘ “ \x ◘ \xo 10:‏5 \xt إِزهد. 115‏:‏5؛ إِشا. 41‏:‏23؛ 46‏:‏1، 7\x*   
\b  
\m
\v 6 ”ؤُڒَا ذ إِجّْ مَا أَمْ شكْ، \add أَ\add* سِيذِي! شكْ ذ أَمقّْرَانْ ؤُ إِسمْ نّشْ ذ أَمقّْرَانْ س جّهْذْ. \x ◘ \xo 10:‏6 \xt إِزهد. 86‏:‏8، 10\x*  
\v 7 مَانْ ونْ وَارْ شكْ إِتّڭّْوِيذنْ، \add شكْ\add*، \add أَ\add* أَجدْجِيذْ ن ڒڭْنُوسْ؟ مِينْزِي أَيَا يُوسَا-د خَاكْ، مَاغَارْ جَارْ مَارَّا إِمِيغِيسنْ ن ڒڭْنُوسْ ؤُ ذِي مَارَّا ثَاڭلْذِيثْ نْسنْ ؤُڒَا ذ إِجّْ أَمْ شكْ.“ \x ◘ \xo 10:‏7 \xt أَسَا. 15‏:‏4\x*   
\b  
\m
\v 8 ”أَقَا-ثنْ \add جْمِيعْ\add* ذ إِفْغَارْ ذ إِبُوهَاڒِييّنْ، \add مِينْزِي\add* تَّارْبِييّثْ ن \add لْ-أَصْنَامْ\add* إِبطّْڒنْ \add ثفّغْ-د\add* زڭْ ؤُكشُّوضْ \add وَاهَا\add*. \x ◘ \xo 10:‏8 \xt إِشا. 41‏:‏29؛ حَاب. 2‏:‏18؛ زَاك. 10‏:‏2\x*  
\v 9 إِوْينْ-د نُّوقَارْثْ إِتّْوَابزّْعنْ زِي ثَارْشِيشْ ذ وُورغْ زِي ؤُفَازْ، أَقَا-ت ذ ڒْخذْمثْ ن ؤُحْرَايْفِي ؤُڒَا ن إِفَاسّنْ ن ومْزِيڒْ ن وُورغْ. أَرُّوضْ نْسنْ \add ن إِفِيڒَانْ\add* إِذهْمَانِييّنْ ذ أَرْجُووَانِييّنْ، مَارَّا \add ڒخْيَاڒَاثْ\add* ڭِّينْ ثنْثْ يرْيَازنْ إِنِّي غَارْسنْ ثِيزمَّارْ.“   
\b  
\m
\v 10 ”سِيذِي أَربِّي ذ ثِيذتّْ، نتَّا ذ أَربِّي إِدَّارنْ، ذ أَجدْجِيذْ نْ ڒبْذَا. ثَامُّورْثْ ثتّنْهزَّا س ؤُذُوقّزْ ن وغْضَابْ نّسْ ؤُشَا ڒڭْنُوسْ وَارْ زمَّارنْ \add أَذْ كْسنْ\add* أَسْخضْ نّسْ.“   
\b  
\m
\v 11 ”ذ مَانْ أَيَا ذ أَسنْ إِ غَا ثِينِيمْ: ’إِربِّيثنْ نِّي وَارْ إِڭِّينْ أَجنَّا ؤُڒَا ذ ثَامُّورْثْ، نِيثْنِي أَذْ تّْوَاقْضَانْ زِي ثمُّورْثْ ذ سَاذُو أَجنَّا.‘ “   
\b  
\m
\v 12 ”\add مَاشَا\add* نتَّا إِڭَّا ثَامُّورْثْ س جّْهذْ نّسْ، إِڭَّا دُّونشْثْ زِي ثِيغِيثْ ؤُ س ڒفْهَامثْ نّسْ إِبزّعْ أَجنَّا. \x ◘ \xo 10:‏12 \xt أَمز. 1‏:‏1؛ أَيُوبْ 9‏:‏8؛ إِزهد. 104‏:‏2؛ إِشا. 40‏:‏22؛ 44‏:‏24؛ 51‏:‏13؛ إِرْم. 51‏:‏15\x*  
\v 13 ڒَامِي إِتّجَّا ثْمِيجَّا نّسْ أَذْ ت سْڒنْ، \add خنِّي ثڭَّا\add* أَمْ ؤُشَارْشُورْ ن وَامَانْ ذڭْ ؤُجنَّا. إِسيْنُوثنْ إِسّْڭعَّاذْ إِ-ثنْ زڭْ إِنڭُّورَا ن دُّونشْثْ، إِتّڭّْ أَسَّامنْ أَكْ-ذ ونْژَارْ ؤُ إِسّكَّا-د أَسمِّيضْ زڭْ إِخَّامنْ نّسْ ن ثْخُوبَايْ.“ \x ◘ \xo 10:‏13 \xt إِزهد. 135‏:‏7؛ إِرْم. 51‏:‏16؛ أَسَا. 14‏:‏3\x*   
\b  
\m
\v 14 ”كُوڒْ بْنَاذمْ ذ أَڭَارُّوضْ، بْڒَا ثُوسّْنَا، كُوڒْ أَمْزِيڒْ ن وُورغْ إِتّْسضْحَا زِي سِّيبّثْ ن ڒخْيَاڒْ إِنقْشنْ \add إِ إِڭَّا\add*، مَاغَارْ ڒخْيَاڒْ نّسْ إِفسْينْ ذ إِخَارِّيقنْ، وَارْ ذَايسْ \add إِدْجِي\add* بُوحْبڒْ. \x ◘ \xo 10:‏14 \xt إِرْم. 51‏:‏17، 18\x*  
\v 15 أَقَا ثنْثْ ذ \add لْ-أَصْنَامْ\add* إِبطّْڒنْ، أَقَا أَثنْثْ ذ ثِيمسْڒَايِينْ ن ثْسضْحَاشْثْ. ذِي ڒْوقْثْ مَانِي ثنْثْ إِ غَا عَاقْبنْ، أَذْ فْنَانْثْ.  
\v 16 ثَاسْغَارْثْ ن يَاعْقُوبْ وَارْ ثدْجِي أَمْ \add ثسْغَارْثْ\add* نْسنْثْ، مِينْزِي نتَّا ذ ونِّي إِڭِّينْ مَارَّا، ؤُشَا إِسْرَائِيل ذ ثَاقْبِيتْشْ ن ثسْغَارْثْ نّسْ، أَقَا سِيذِي ن ڒْعسْكَارَاثْ ذ إِسمْ نّسْ.“ \x ◘ \xo 10:‏16 \xt إِزهد. 74‏:‏2؛ إِرْم. 51‏:‏19\x*   
\b  
\m  
\s1 أَبَارّحْ س ثْمحْبَاسْثْ ن يَاهُوذَا  
\m
\v 17 ”سڭّْوجْ سّڒْعثْ زِي ثمُّورْثْ نّمْ، \add أَ شمْ\add* ثَامْغَارْثْ نِّي إِزدّْغنْ ذِي لْقلْعَا!  
\v 18 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: ’خْزَارْ، ثْوَاڒَا-يَا أَذْ نْضَارغْ إِمزْذَاغْ ن ثمُّورْثْ غَارْ ڒَاڭّْوَاجْ ؤُشَا أَذْ أَسنْ د-أَوْيغْ ذِي ڒحْصَارثْ، حِيمَا أَذْ تّْوَاطّْفنْ!‘ \x ◘ \xo 10:‏18 \xt إِرْم. 6‏:‏24\x*  
\v 19 ؤُشْثْ إِنُو زِي سِّيبّثْ ن ثْرژِّيثْ إِنُو، أَيزِّيمْ إِنُو إِتّقّسْ أَيِي أَطَّاسْ. وَاخَّا نشّْ نِّيغْ: أَيَا ذ إِجّْ ن ڒهْڒَاشْ ؤُ نشّْ أَذْ ث كْسِيغْ!  
\v 20 إِتّْوَاخَارّبْ ؤُقِيضُونْ إِنُو، مَارَّا إِمُورَارْ \add ن ؤُقِيضُونْ\add* قطّْسنْ، إِحنْجِيرنْ إِنُو ؤُيُورنْ خَافِي ؤُ وَارْ ذَا دْجِينْ عَاذْ. وَارْ ذِينْ وِي غَا إِسّْبدّنْ أَقِيذُونْ إِنُو ؤُشَا أَذْ خَاسْ يَايڒْ ثِيجَارْثِيڒِينْ نّسْ.  
\v 21 مَاغَارْ إِمكْسَاونْ ثُوغَا قجْحنْ، سِيذِي وَارْ خَاسْ أَرْزُونْ. خْ ؤُيَا وَارْ تّْڭعَّاذنْ ؤُ مَارَّا \add ثَاحِيمَارْثْ ن\add* دّْمَانِي نْسنْ ثتّْوَازُوزَّارْ. \f ◼ \fr 10:‏21 \ft \+bd ’إِمكْسَاونْ‘\+bd* - نِيغْ ’إِنِيتْشَانْ‘.\f*  
\v 22 ڒحْوڒْ ذ أَمقّْرَانْ، أَقَا ذَا، دّْرِيزْ زِي ثمُّورْثْ ذِي شَّامَالْ، حِيمَا أَذْ أَردّْدْجنْ ثِيندَّامْ ن يَاهُوذَا، \add مَاحنْذْ أَذْ ت أَرّنْ ذ ثَامُّورْثْ ن\add* ثْزذِّيغْثْ إِ وُوشَّاننْ ن ڒخْڒَا.“ \x ◘ \xo 10:‏22 \xt إِرْم. 1‏:‏14؛ 4‏:‏6؛ 9‏:‏11\x*   
\b  
\m
\v 23 ”نشّْ سّْنغْ، \add أَ\add* سِيذِي، أَقَا وَارْ د-ثقِّيمْ غَارْ بْنَاذمْ أَذْ إِخْضَارْ أَبْرِيذْ نّسْ، ؤُڒَا إِ ورْيَازْ إِڭُّورْ، مَاحنْذْ أَذْ إِنْذهْ إِصُورَافْ نّسْ. \x ◘ \xo 10:‏23 \xt أَوڒن. 16‏:‏1؛ 20‏:‏24\x*  
\v 24 سڭّمْ أَيِي، سِيذِي، مَاشَا س ڒْحقّْ، وَارْ إِدْجِي ذڭْ وغْضَابْ نّشْ، حِيمَا وَارْ ذ أَيِي ثَارِّيذْ ذ وَالُو. \x ◘ \xo 10:‏24 \xt إِزهد. 6‏:‏2؛ 38‏:‏2؛ إِرْم. 30‏:‏11؛ 46‏:‏28\x*  
\v 25 زدْجعْ أَسْعَارْ نّشْ خْ ڒڭْنُوسْ نِّي وَارْ شكْ إِسِّيننْ، ؤُ خْ ثْقبَّاڒْ نِّي وَارْ إِتّْڒِيغِينْ إِسمْ نّشْ، مِينْزِي نِيثْنِي صَارْضنْ يَاعْقُوبْ، صَارْضنْ ث ؤُشَا قْضَانْ خَاسْ، هذْمنْ أَمْشَانْ ن ثْزذِّيغْثْ نّسْ.“ \x ◘ \xo 10:‏25 \xt إِزهد. 79‏:‏6؛ إِرْم. 8‏:‏16؛ 9‏:‏16\x*   
\b  
\b  
\m  
\c 11
\s1 ڒْڭنْسْ يَارْژَا ڒْعَاهْذْ أَكْ-ذ سِيذِي  
\m
\v 1 أَوَاڒْ نِّي د-إِفّْغنْ زِي سِيذِي غَارْ إِرْمِييَا، إِنَّا:  
\v 2 ”سْڒمْ إِ وَاوَاڒنْ ن ڒْعَاهْذْ-أَ ؤُشَا سِيوڒْ أَكْ-ذ يرْيَازنْ ن يَاهُوذَا ؤُ أَكْ-ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ،  
\v 3 إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: إِتّْوَانْعڒْ ورْيَازْ نِّي وَارْ إِسْڒِينْ إِ وَاوَاڒنْ ن ڒْعَاهْذْ-أَ، \x ◘ \xo 11:‏3 \xt أَعَوذ. 27‏:‏26؛ ڭال. 3‏:‏10. \x*  
\v 4 ونِّي وصِّيغْ إِ ڒجْذُوذْ نْومْ ذڭْ وَاسّْ ؤُمِي ثنْ سُّوفّْغغْ زِي ثمُّورْثْ ن مِيصْرَا، زڭْ ؤُفَارَّانْ ن وُوزَّاڒْ، \add ڒَْامِي\add* نِّيغْ: سْڒمْ إِ ثْمِيجَّا إِنُو ؤُشَا ڭّمْ أَمْ مَامّشْ إِ كنِّيوْ وصِّيغْ مَارَّا، \add خنِّي\add* أَذْ أَيِي ثِيڒِيمْ ذ ڒْڭنْسْ إِنُو ؤُشَا نشّْ أَذْ أَومْ إِڒِيغْ ذ أَربِّي نْومْ، \x ◘ \xo 11:‏4 \xt لَاوِي 26‏:‏3، 12؛ أَعَوذ. 4‏:‏20\x*  
\v 5 حِيمَا أَذْ منْعغْ ذِي ثْجَادْجِيثْ نِّي جُّودْجغْ ذِي طّْوعْ ن ڒجْذُوذْ نْومْ، مَاحنْذْ أَذْ أَسنْ وْشغْ إِشْثْ ن ثمُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ، أَمْ \add ثدْجَا\add* أَسّْ-أَ.‘ “ \add خنِّي\add* نشّْ أَرِّيغْ-د، نِّيغْ: ”أَمِينْ، سِيذِي!“ \x ◘ \xo 11:‏5 \xt أَعَوذ. 7‏:‏12\x*   
\m
\v 6 إِنَّا أَيِي سِيذِي: ”بَارّحْ س مَارَّا أَوَاڒنْ-أَ ذِي ثْندَّامْ ن يَاهُوذَا ؤُ ذِي ذْشُورَاثْ ن ؤُرْشَالِيمْ، إِنِي: ’سْڒمْ إِ وَاوَاڒنْ ن ڒْعَاهْذْ-أَ، ڭّمْ زَّايْسنْ،  
\v 7 مَاغَارْ نشّْعڒْمغْ س جّهْذْ إِ ڒجْذُوذْ نْومْ ذڭْ وَاسّْ ؤُمِي ثنْ سُّوفّْغغْ زِي ثمُّورْثْ ن مِيصْرَا، زڭْ ؤُمزْوَارُو أَڒْ أَسّْ-أَ، \add وَاهْ،\add* شهْذغْ نِّيغْ: سْڒمْ غَارْ ثْمِيجَّا إِنُو‘ \x ◘ \xo 11:‏7 \xt إِرْم. 7‏:‏13، 25\x*  
\v 8 \add مَاشَا\add* نِيثْنِي وَارْ سْڒِينْ ؤُ وَارْ ذ أَيِي وْشِينْ أَمزُّوغْ نْسنْ، مَاشَا نِيثْنِي ضْفَارنْ مَارَّا إِذْسنْ ڒقْسَاحثْ ن وُوڒْ نْسنْ أَعفَّانْ. س ؤُينِّي سِّيوْضغْ خَاسنْ مَارَّا أَوَاڒنْ ن ڒْعَاهْذْ-أَ، إِنِّي خْ ثنْ وصِّيغْ مَاحنْذْ أَذْ زَّايْسنْ ڭّنْ، \add مَاشَا\add* وَارْ زَّايْسنْ ڭِّينْ.‘ “ \x ◘ \xo 11:‏8 \xt إِرْم. 3‏:‏17؛ 7‏:‏24، 26؛ 9‏:‏14\x*   
\m
\v 9 إِنَّا أَيِي سِيذِي: ”أَقَا ثتّْوَاعَارَّا إِشْثْ ن ثْمعْمُوتْشْ جَارْ إِرْيَازنْ ن يَاهُوذَا ؤُ جَارْ إِمزْذَاغْ ن ؤُرْشَالِيمْ.  
\v 10 نِيثْنِي ذوْڒنْ-د غَارْ ڒْمُوعْصِييّثْ ن ڒجْذُوذْ نْسنْ نِّي يُوڭِينْ أَذْ سْڒنْ غَارْ وَاوَاڒنْ إِنُو. نِيثْنِي رُوحنْ ضفَّارَانْ إِربِّيثنْ نّغْنِي مَاحنْذْ أَذْ أَسنْ سخَّارنْ. ثَادَّارْثْ ن إِسْرَائِيل ذ ثَادَّارْثْ ن يَاهُوذَا أَرْژِينْ ڒْعَاهْذْ إِنُو نِّي ڭِّيغْ أَكْ-ذ ڒجْذُوذْ نْسنْ.“   
\m
\v 11 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي: ’خْزَارْ، نشّْ أَذْ خَاسنْ نْضَارغْ إِجّْ ن ڒْغَارْ إِ زِي وَارْ زمَّارنْ أَذْ نجْمنْ. \add مَاڒَا\add* ڒَاغَانْ أَيِي-د \add خنِّي\add*، نشّْ وَارْ د غَارْسنْ تّسْڒِيغْ شَا. \x ◘ \xo 11:‏11 \xt أَوڒن. 1‏:‏28؛ إِشا. 1‏:‏15؛ إِرْم. 14‏:‏12؛ حِز. 8‏:‏18؛ مِيخَا 3‏:‏4\x*  
\v 12 \add خنِّي\add* أَذْ فّْغنْ ثِيندَّامْ ن يَاهُوذَا ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ، أَذْ ڒَاغَانْ غَارْ إِربِّيثنْ إِ يِينِّي ؤُمِي قدّْمنْ ثِيوْهِيبِينْ نْ ڒبْخُورْ، \add مَاشَا\add* يِينَا وَارْ زمَّارنْ أَذْ أَسنْ وْشنْ أَفُوسْ ذِي ڒْوقْثْ ؤُمِي ثنْ إِڒْقفْ ڒْغَارْ.  
\v 13 مَاغَارْ إِربِّيثنْ نّشْ ذڭْ وَاطَّاسْ أَنشْثْ ن ثْندَّامْ نّشْ، \add أَ\add* يَاهُوذَا، ؤُ إِعَالْثَارنْ إِ ثسّْبدّمْ إِ نّْعِي \add ن صَّانَامْ\add* نِّي ذڭْ وَاطَّاسْ أَنشْثْ ن إِبْرِيذنْ ن ؤُرْشَالِيمْ، إِعَالْطَارنْ مَاحنْذْ أَذْ خَاسنْ وهّْبنْ ثِيوْهِيبِينْ ن ڒبْخُورْ إِ بَاعْلْ.‘ “ \x ◘ \xo 11:‏13 \xt إِرْم. 2‏:‏28\x*   
\b  
\m
\v 14 ”شكْ \add خنِّي\add* وَارْ ثتَّارْ إِ ڒْڭنْسْ-أَ، وَارْ تّكَّارذْ أَذْ أَسنْ ثْرُوذْ نِيغْ أَذْ أَسنْ ثذْعِيذْ، مَاغَارْ نشّْ وَارْ تّسْڒِيغْ ذِي ڒْوقْثْ نِّي خَافِي د غَا ڒَاغَانْ زِي سِّيبّثْ ن ڒْغَارْ إِ ثنْ إِڒقْفنْ.“ \x ◘ \xo 11:‏14 \xt إِرْم. 7‏:‏16؛ 14‏:‏11\x*   
\b  
\m
\v 15 ”مِينْ إِ ثڭِّيذْ، \add أَ\add* ثَامْعِيزْثْ إِنُو، ذِي ثَادَّارْثْ إِنُو، ؤُمِي ثدْجَا ڒفْضِيحثْ نّسْ \add ذ ثَا\add*: أَقَا أَطَّاسْ تَّاڭّْوجنْ خَامْ أَكْ-ذ ويْسُومْ إِقدّْسنْ. مَاغَارْ س ثُوعفّْنَا إِ ثڭِّيذْ، مَا ثْزمَّارذْ أَذْ ثْنڭْزذْ س ڒفْرَاحثْ؟  
\v 16 ’ثَازِيثُونْثْ ثَازيْزَاوْثْ، \add أَ شمْ،\add* ڒمْڒَاحثْ، س ڒْغِيدْجثْ إِشْنَانْ ذِي ڒوْصِيفثْ!‘، \add أَمُّو إِ\add* ثُوغَا إِڭَّا سِيذِي إِسمْ نّمْ، \add مَاشَا\add* \add ڒخُّو\add* إِقّذْ أَسْ ثِيمسِّي أَمْ إِتّْوَاسڒْ ڒْحسّْ ن إِجّْ ن زّْهِيرْ ذ أَمقّْرَانْ ؤُشَا تّْوَارْژنْ ڒفْرُوعْ نّسْ.  
\v 17 سِيذِي ن ڒْعسْكَارَاثْ، ذ ونِّي شمْ إِژُّونْ، إِڭَّا خَامْ إِجّْ ن ڒْغَارْ زِي سِّيبّثْ ن ڒْغَارْ إِ ثڭَّا ثَادَّارْثْ ن إِسْرَائِيل ذ ثَادَّارْثْ ن يَاهُوذَا، \add ڒْغَارْ إِ\add* ڭِّينْثْ إِ يِيخفْ نْسنْثْ ؤُمِي ذ أَيِي سْعَارنْثْ س ثوْهِيبِينْ ن ڒبْخُورْ إِ بَاعْلْ.“ \x ◘ \xo 11:‏17 \xt إِرْم. 2‏:‏21\x*   
\b  
\m  
\s1 ثُوذَارْثْ ن ؤُنَابِي إِرْمِييَا ذِي لْخَاطَاڒْ  
\m
\v 18 ”سِيذِي إِسّْشنْ ث أَيِي ؤُشَا \add ڒخُّو\add* سّْنغْ، ڒَامِي ثسّشْنذْ أَيِي ثِيمڭَّا نْسنْ.  
\v 19 نشّْ سِيمَانْثْ إِنُو ثُوغَا أَيِي أَمْ يِيجّْ ن يزْمَارْ أَيْنَاوْ ن ثَادَّارْثْ، ندّْهنْ ث إِ ثْغَارْصْثْ، مَاغَارْ ثُوغَا وَارْ سِّينغْ أَقَا نِيثْنِي ڭِّينْ أَيِي إِجّْ ن ڒْفخْ \add ؤُمِي قَّارنْ\add*: ’أجّْ أَنغْ أَذْ نْضيّعْ ثَاشجَّارْثْ أَكْ-ذ ڒْغِيدْجثْ نّسْ ؤُ أَذْ ت نْثحَّا زِي ثمُّورْثْ ن يِينِّي إِدَّارنْ مَاحنْذْ إِسمْ نّسْ وَارْ ث تِّيذَارنْ عَاذْ.‘ “ \f ◼ \fr 11:‏19 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*   
\m
\v 20 ”سِيذِي ن ڒْعسْكَارَاثْ، \add أَ شكْ\add* ڒْقَاضِي إِسڭّْذنْ نِّي إِتّْجَارَّابنْ ثِيژَّاڒْ ذ وُوڒْ، سْشنْ أَيِي نّقْمثْ نّشْ، مَاغَارْ نشّْ سلّْمغْ دّعْوثْ إِنُو ذڭْ إِفَاسّنْ نّشْ.“ \f ◼ \fr 11:‏20 \ft \+bd ’ثِيژَّاڒْ‘\+bd* - نِيغْ ’ثِيڭژْڒِينْ‘.\f*  \x ◘ \xo 11:‏20 \xt 1 صم. 16‏:‏7؛ 1 إِم. 28‏:‏9؛ إِزهد. 7‏:‏10؛ 26‏:‏2؛ أَسَا. 2‏:‏23\x*   
\m
\v 21 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي خْ يرْيَازنْ ن عَانَاثُوثْ، إِنِّي يَارزُّونْ ڒعْمَارْ نّشْ، قَّارنْ: ’وَارْ تّْنَابْ س يِيسمْ ن سِيذِي أَڒَامِي وَارْ ثْمتِّيذْ س ؤُفُوسْ نّغْ.‘  
\v 22 س ؤُيَا، \add أَمُّو\add* إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: ’خْزَارْ، نشّْ أَذْ ثنْ خدْجْصغْ: إِحُوذْرِييّنْ أَذْ مّْثنْ س سِّيفْ، إِحنْجِيرنْ ذ يسِّيثْسنْ أَذْ مّْثنْ س ڒَاژْ.  
\v 23 وَارْ إِتّْغِيمِي مِينْ إِقِّيمنْ زَّايْسنْ، مَاغَارْ نشّْ أَذْ خَاسنْ د-سِّيوْضغْ إِجّْ ن ڒْغَارْ ذ أَعفَّانْ خْ يرْيَازنْ ن عَانَاثُوثْ ذڭْ ؤُسڭّْوَاسْ نِّي ذِي ثنْ إِ غَا خدْجْصغْ.‘ “   
\b  
\b  
\m  
\c 12
\s1 أَشثْشِي ن إِرْمِييَا  
\m
\v 1 ”مَاڒَا ڭِّيغْ أَذْ شَارّْعغْ أَكِيذكْ، \add أَ\add* سِيذِي، شكْ \add أَذْ ثْبَانذْ\add* ذ أَمْسڭّذْ. قَاعْ أَمنِّي تّخْسغْ أَذْ سِيوْڒغْ أَكِيذكْ خْ إِبْرِيذنْ ن ڒْحقّْ: مَايمِّي أَبْرِيذْ ن إِعفَّاننْ إِسڭّمْ، \add ؤُ\add* مَايمِّي إِغدَّارنْ ڒبْذَا ذِي أَرَّاحثْ؟ \x ◘ \xo 12:‏1 \xt أَيُوبْ 21‏:‏7؛ إِزهد. 73‏:‏11، 12؛ حَاب. 1‏:‏3\x*  
\v 2 شكْ ثژُّوذْ ثنْ ؤُ نِيثْنِي وْثِينْ إِژوْرَانْ، نِيثْنِيغمْينْ-د ؤُ إِوْينْ-د ڒْغِيدْجثْ. شكْ أَقَا ثُوذْسذْ أَقمُّومْ نْسنْ، مَاشَا ثِيڭّْوجذْ خْ ثِيژَّاڒْ نْسنْ.“ \f ◼ \fr 12:‏2 \ft \+bd ’ثِيژَّاڒْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ؤُڒْ‘.\f*  \x ◘ \xo 12:‏2 \xt إِشا. 29‏:‏13\x*   
\m
\v 3 ”شكْ، \add أَ\add* سِيذِي، ثسّْنذْ أَيِي، ثتّْوَارِيذْ أَيِي ؤُ ثْقدْجْبذْ ؤُڒْ إِنُو، \add مَا\add* أَقَا-ث أَكِيذكْ. جْبذْ إِ-ثنْ أَمْ وُودْجِي إِ ثْغَارْصْثْ ؤُ عْزڒْ إِ-ثنْ إِ وَاسّْ ن ونْغَايْ. \f ◼ \fr 12:‏3 \ft \+bd ’قدّسْ إِ-ثنْ‘\+bd* - إِخْسْ أَذْ يِينِي ’حَارّمْ إِ-ثنْ‘.\f*  \x ◘ \xo 12:‏3 \xt إِزهد. 17‏:‏3؛ 139‏:‏1؛ إِرْم. 11‏:‏20\x*  
\v 4 مشْحَاڒْ عَاذْ إِ غَا ثكّْ ثمُّورْثْ ثشْضنْ ؤُ أَفْسُو \add أَزِيزَا\add* أَذْ يَاژغْ ذڭْ إِيَّارْ مَارَّا؟ س ثُوعفّْنَا ن يِينِّي ذِينْ إِزدّْغنْ ضيّْعنْ ڒْمَاڒْ ذ يجْضَاضْ، مَاغَارْ نِيثْنِي قَّارنْ: ’نتَّا وَارْ إِتّْوِيڒِي أَنڭَّارْ نّغْ.“ \x ◘ \xo 12:‏4 \xt إِرْم. 4‏:‏25؛ 7‏:‏20؛ 9‏:‏10\x*   
\m
\v 5 ”مَاڒَا ثُوزّْڒذْ أَكْ-ذ إِنِّي إِتَّازّْڒنْ خْ إِضَارنْ، نِيثْنِي سَّاحَاڒنْ شكْ، مَامّشْ ثخْسذْ أَذْ ثڭّذْ \add خنِّي\add* حَامَاثْ أَكْ-ذ إِيْسَانْ؟ مَاڒَا ثتَّاشِيذْ أَقَا شكْ ذِي ڒَامَانْ مْغِيرْ ذِي ثمُّورْثْ ن ڒهْنَا، مَامّشْ غَا ثڭّذْ \add خنِّي\add* ذِي شْبَارْقْ إِقّْننْ ن \add يغْزَارْ ن\add* لْ-ؤُرْذُونْ؟  
\v 6 مَاغَارْ ؤُڒَا ذ أَيْثْمَاشْ ذ ثَادَّارْثْ ن بَابَاشْ، ؤُڒَا ذ نِيثْنِيغدَّارنْ شكْ، ؤُڒَا ذ نِيثْنِي سْغُويُّونْ س جّْهذْ أَوَارْنِي أَشْ. وَارْ ثنْ تِّيقّمْ، وَاخَّا سَّاوَاڒنْ أَكِيذكْ مْلِيحْ.“ \x ◘ \xo 12:‏6 \xt أَوڒن. 26‏:‏25\x*   
\b  
\m  
\s1 أَشثْشِي ن سِيذِي خْ يَاهُوذَا ؤُ خْ ڒڭْنُوسْ إِ ذ أَسْ د-إِنّْضنْ  
\m
\v 7 ”نشّْ سمْحغْ ذِي ثَادَّارْثْ إِنُو، نشّْ نْضَارغْ ثَاسْغَارْثْ إِنُو. ثنِّي إِسّْعِيزّْ ڒعْمَارْ إِنُو سلّْمغْ ت ذڭْ ؤُفُوسْ ن ڒْعذْيَانْ نّسْ.  
\v 8 ثَاسْغَارْثْ إِنُو ثذْوڒْ-د أَكِيذِي أَمْ يِيجّْ ن وَايْرَاذْ ذڭْ وزْغَارْ. ثسّْڭعّذْ-د أَكِيذِي ثْمِيجَّا نّسْ، خْ ؤُيَا نشّْ ذوْڒغْ شَارّْهغْ ت. \f ◼ \fr 12:‏8 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  
\v 9 ثَاسْغَارْثْ إِنُو إِ نشّْ \add أَمْ\add* ؤُجْضِيضْ إِبقّْضنْ إِتّْكشَّاضنْ. تّنّْضنْ أَسْ إِجْضَاضْ إِكشّْضنْ. كَّارمْ، سْمُونمْ-د مَارَّا ڒْمَاڒْ ن ييَّارْ، أجّْ إِ-ثنْ أَذْ د-أَسنْ حِيمَا أَذْ شّنْ!“ \x ◘ \xo 12:‏9 \xt إِرْم. 7‏:‏33\x*   
\m
\v 10 ”إِمكْسَاونْ أَطَّاسْ خَارّْبنْ أَمَارْجعْ إِنُو ن ؤُضِيڒْ،عفْسنْ خْ ييَّارْ إِنُو، أَقَا أَرِّينْ إِيَّارْ إِعِيزّنْ إِنُو ذ إِجّْ ن ڒخْڒَا إِخْوَا. \f ◼ \fr 12:‏10 \ft \+bd ’إِمكْسَاونْ‘\+bd* - نِيغْ: ’إِنِيتْشَانْ‘.\f*  \x ◘ \xo 12:‏10 \xt إِرْم. 6‏:‏3\x*  
\v 11 أَرِّينْ \add إِيَّارْ\add* ذ إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ، أَقَا إِتّْوَاخَارّبْ \add ييَّارْ\add*، إِزّڒْ زَّاثِي إِشْضنْ. مَارَّا ثَامُّورْثْ ثْخَارّبْ مِينْزِي ؤُڒَا ذ إِجّْ وَارْ ذ أَسْ يشْقِي.  
\v 12 خْ مَارَّا ثِيوْرِيرِينْ إِقشَّارنْ ذِي ڒخْڒَا ؤُسِينْ-د إِمْثحَّايّنْ، مَاغَارْ سِّيفْ إِسَارْضْ زِي طَّارْفْ ن ثمُّورْثْ أَڒْ طَّارْفْ \add نّغْنِي\add* ن ثمُّورْثْ. وَارْ ذِينْ إِقِّيمْ ڒهْنَا إِ مَارَّا دَّاثْ.  
\v 13 نِيثْنِي زَارْعنْ إِرْذنْ، \add مَاشَا\add* مْجَارنْ إِسنَّاننْ، نِيثْنِي ؤُحْڒنْ، مَاشَا بْڒَا نّْفَاعْ. نِيثْنِي أَذْ سضْحَانْ خْ صَّابثْ نْومْ زِي سِّيبّثْ ن ڒْحَاذُوقْ ن وغْضَابْ ن سِيذِي.“ \x ◘ \xo 12:‏13 \xt لَاوِي 26‏:‏16؛ أَعَوذ. 28‏:‏38\x*   
\m
\v 14 ”أَمُّو إِ إِقَّارْ سِيذِي: مَارَّا أَجَّارنْ إِنُو إِعفَّاننْ نِّي إِتّْحَاذَانْ ثَاسْغَارْثْ إِنُو إِ وْشِيغْ إِ ڒْڭنْسْ إِنُو إِسْرَائِيل ذ ثَاسْغَارْثْ، خْزَارْ، نشّْ أَذْ ثنْ قڒْعغْ زِي ثمُّورْثْ، \add مَاشَا\add* ثَادَّارْثْ ن يَاهُوذَا أَذْ ت قڒْعغْ زِي ڒْوسْطْ نْسنْ. \x ◘ \xo 12:‏14 \xt أَعَوذ. 30‏:‏3؛ إِرْم. 32‏:‏37\x*  
\v 15 أَوَارْنِي ڒَامِي ثنْ قڒْعغْ، أَذْ د-ذوْڒغْ ؤُ أَذْ خَاسنْ حِينّغْ ؤُشَا نشّْ أَذْ ثنْ أَرّغْ أَذْعقْبنْ، كُوڒْ إِجّْ غَارْ ثسْغَارْثْ نّسْ ؤُ كُوڒْ إِجّْ غَارْ ثمُّورْثْ نّسْ.  
\v 16 خْمِي غَا ڒمْذنْ س ثِيذتّْ إِبْرِيذنْ ن ڒْڭنْسْ إِنُو مَاحنْذْ أَذْ جَّادْجنْ غَارْ يِيسمْ إِنُو: ’س ثِيذتّْ أَمْ إِدَّارْ سِيذِي!‘، أَمْ مَامّشْ نِيثْنِي سّْڒمْذنْ ڒْڭنْسْ إِنُو مَاحنْذْ أَذْ جَّادْجنْ غَارْ بَاعْلْ، \add خنِّي\add* أَذْ تّْوَاسّْبدّنْ نِيثْنِي ذِي ڒْوسْطْ نْ ڒْڭنْسْ إِنُو.  
\v 17 \add مَاشَا\add* مَاڒَا نِيثْنِي وَارْ تّخْسنْ أَذْ سْڒنْ، \add خنِّي\add* نشّْ أَذْ قڒْعغْ ڒْڭنْسْ نِّي ؤُشَا أَذْ ثنْ أَردّْدْجغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ \x ◘ \xo 12:‏17 \xt إِشا. 60‏:‏12\x*   
\b  
\b  
\m  
\c 13
\s1 أَبْيَاسْ ن ڒقْطنْ  
\m
\v 1 ”أَمُّو إِ ذ أَيِي إِنَّا سِيذِي: ’ؤُيُورْ، سغْ إِ يِيخفْ نّشْ إِجّْ ن وبْيَاسْ ن ڒقْطنْ ؤُشَا بيْسْ إِ-ث خْ ثجْعِينَّاثِينْ نّشْ، \add مَاشَا\add* وَارْ ث ثجِّي أَذْ يَاذفْ ذڭْ وَامَانْ!‘  
\v 2 نشّْ سْغِيغْ إِجّْ ن وبْيَاسْ عْلَاحْسَابْ أَوَاڒْ ن سِيذِي ؤُشَا بيْسغْ ث خْ ثجْعِينَّاثِينْ إِنُو.  
\v 3 \add خنِّي\add* يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي إِ ثْوَاڒَا وِيسّْ ثْنَاينْ، إِنَّا:  
\v 4 ’كْسِي أَبْيَاسْ إِ ثسْغِيذْ، نِّي ثْبيْسذْ خْ ثجْعِينَّاثِينْ نّشْ ؤُشَا كَّارْ، ؤُيُورْ غَارْ \add يغْژَارْ ن\add* لْفُورَاطْ ؤُشَا فَّارْ إِ-ث ذِينِّي ذِي ثَازّشْثْ ن جَّارْفْ.‘  
\v 5 نشّْ ؤُيُورغْ ؤُشَا فَّارغْ ث غَارْ لْفُورَاطْ، أَمْ مَامّشْ ثُوغَا ذ أَيِي يُومُورْ سِيذِي.“   
\m
\v 6 ”أَوَارْنِي إِ وَاطَّاسْ ن وُوسَّانْ إِنَّا أَيِي سِيذِي: ’كَّارْ، ؤُيُورْ غَارْ لْفُورَاطْ ؤُشَا كْسِي سّنِّي أَبْيَاسْ نِّي ذ أَشْ ؤُمُورغْ مَاحنْذْ أَذْ ث ثفَّارذْ ذِينِّي.‘  
\v 7 \add خنِّي\add* ؤُيُورغْ غَارْ لْفُورَاطْ ؤُشَا غْزِيغْ ؤُ كّْسغْ-د أَبْيَاسْ زڭْ ومْشَانْ مَانِي ث ثُوغَا فَّارغْ. خْزَارْ، أَبْيَاسْ إِضيّعْ، وَارْ إِدْجِي مِينْ ؤُمِي غَا إِنْفِيعْ عَاذْ.   
\m
\v 8 \add خنِّي\add* يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:  
\v 9 ’أَمُّو إِ إِقَّارْ سِيذِي: ’أَمُّو إِ غَا سّْضيّْعغْ نّْفَاخثْ ن يَاهُوذَا ؤُڒَا ذ نّْفَاخثْ ثَامقّْرَانْثْ ن ؤُرْشَالِيمْ.  
\v 10 ڒْڭنْسْ-أَ أَعفَّانْ نِّي يُوڭِينْ أَذْ إِسڒْ غَارْ وَاوَاڒنْ إِنُو، نِّي إِضفَّارنْ ڒقْسَاحثْ ن وُوڒْ نّسْ ؤُشَا يَاردّفْ إِربِّيثنْ نّغْنِي مَاحنْذْ أَذْ ثنْ إِعْبذْ ؤُ أَذْ أَسنْ إِبنْذقْ، \add ڒْڭنْسْ-أَ\add* أَذْ إِذْوڒْ أَمْ وبْيَاسْ-أَ إِ وَارْ إِنفّْعنْ إِ وَالُو عَاذْ.  
\v 11 مَاغَارْ مَامّشْ إِقّنْ وبْيَاسْ إِ ثجْعِينَّاثِينْ ن ورْيَازْ، أَمُّو إِ أَرِّيغْ مَارَّا ثَادَّارْثْ ن إِسْرَائِيل ذ مَارَّا ثَادَّارْثْ ن يَاهُوذَا أَذْ غَارِي قّْننْثْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، مَاحنْذْ أَذْ إِڒِينْثْ ذ ڒْڭنْسْ إِنُو ذ يِيسمْ إِنُو ذ شَّانْ إِنُو ذ ؤُعُودْجِي إِنُو، \add مَاشَا\add* نِيثْنِي وَارْ سْڒِينْ شَا.‘ “   
\b  
\m  
\s1 إِقدُّوحنْ إِشُّورنْ س بِينُو  
\m
\v 12 ”شكْ أَذْ أَسنْ ثِينِيذْ أَوَاڒْ-أَ: ’أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: قَاعْ أَغَارَّافْ أَذْ إِتّْوَاشُّورْ س بِينُو.‘ \add خنِّي\add* أَذْ أَشْ إِنِينْ نِيثْنِي: ’مَا \add زعْمَا\add* نشِّينْ وَارْ نسِّينْ سِيمَانْثْ نّغْ نِيشَانْ، أَقَا قَاعْ أَغَارَّافْ أَذْ إِتّْوَاشُّورْ س بِينُو؟‘  
\v 13 \add خنِّي\add* أَذْ ذ أَسنْ ثِينِيذْ: ’أَمُّو إِ إِقَّارْ سِيذِي: خْزَارْ، نشّْ أَذْ أَرّغْ أَذْ سْشَارنْ مَارَّا إِمزْذَاغْ ن ثمُّورْثْ-أَ، إِجدْجِيذنْ نِّي إِقِّيمنْ خْ ڒْعَارْشْ ن ذَاوُوذْ، إِكهَّاننْ، إِنَابِييّنْ ذ مَارَّا إِمزْذَاغْ ن ؤُرْشَالِيمْ.  
\v 14 نشّْ أَذْ ثنْ وْثغْ ذ إِوثْوِيثنْ، إِجّْ أَكْ-ذ ونّغْنِي، إِبَابَاثنْ مُوننْ أَكْ-ذ إِحنْجِيرنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. نشّْ وَارْ تّْحِينِّيغْ، وَارْ سّْعِيزِّيغْ ؤُ وَارْ أَرحّْمغْ مَاحنْذْ وَارْ ثنْ تّْضيِّيعغْ.‘ “   
\b  
\m  
\s1 سِيذِي إِسَّاوَاڒْ س إِمذْيَا نّغْنِي  
\m
\v 15 ”سْڒمْ ؤُ وْشمْ أَمزُّوغْ، وَارْ تّْنفْخمْ، مَاغَارْ سِيذِي إِسِّيوڒْ.  
\v 16 وْشمْ شَّانْ إِ سِيذِي، أَربِّي نْومْ، قْبڒْ إِ د غَا ثَاسْ ثَادْجسْثْ ؤُ قْبڒْ إِ غَا نْقَارْضنْ إِضَارنْ نْومْ خْ إِذُورَارْ إِبُّوبْسنْ، \add أَمْ\add* ثتّْرَاجَامْ ثَافَاوْثْ، \add مَاشَا\add* نتَّا أَذْ ت يَارّْ ذ ثِيڒِي ن ؤُنُورِي ؤُڒَا ذ أَسيْنُو إِبُّومْبسْ. \x ◘ \xo 13:‏16 \xt إِزهد. 44‏:‏20\x*  
\v 17 \add مَاشَا\add* مَاڒَا كنِّيوْ وَارْ ثتّخْسمْ أَذْ ثسْڒمْ، \add خنِّي\add* أَذْ إِرُو ڒعْمَارْ إِنُو ذِي ثْنُوفّْرَا خْ نّْفَاخثْ \add نْومْ\add*، أَذْ إِكْسِي ذڭْ إِمطَّاونْ، ؤُشَا أَذْ د-سّهْوَانْ إِمطَّاونْ زِي ثِيطَّاوِينْ إِنُو، مَاغَارْ ثَاحِيمَارْثْ ن سِيذِي أَقَا ثتّْوَانْذهْ ذِي ثْمحْبَاسْثْ.“ \x ◘ \xo 13:‏17 \xt إِڭجذ. 1‏:‏2، 16\x*   
\m
\v 18 ”إِنِي إِ ؤُجدْجِيذْ ذ يمَّاسْ ن ؤُجدْجِيذْ: ’سْوَاضْعمْ إِخفْ نْومْ، قِّيممْ ذڭْ ومْشَانْ إِهْوَا، مَاغَارْ تَّاجْ نْومْ إِشُووَّارنْ ثوْضَا أَومْ-د خْ ؤُزدْجِيفْ.‘  
\v 19 تّْوَابلّْعنْثْ ثْندَّامْ ن \add ثمُّورْثْ ن\add* لْجَانُوبْ، ؤُشَا ؤُڒَا ذ إِجّْ وَارْ ثنْثْ يَارزّمْ. أَقَا إِتّْوَانْذهْ مَارَّا \add ڒْْڭنْسْ ن\add* يَاهُوذَا إِتّْوَانْذهْ إِمُونْ.  
\v 20 سْڭعّْذمْ ثِيطَّاوِينْ نْومْ، ؤُ خْزَارمْ، مَانْ ونْ إِ د-يُوسِينْ زِي شَّامَالْ! مَانِي ثدْجَا ثْحِيمَارْثْ إِ ذ أَمْ إِمّوْشنْ، ؤُدْجِي نّمْ إِشوَّارنْ؟ \f ◼ \fr 13:‏20 \ft \+bd ’إِ ذ أَمْ إِمّوْشنْ‘\+bd* - إِخْسْ أَذْ يِينِي ’إِ إِمّوْشنْ إِ يدْجِيسْ ن صِيهْيُونْ‘.\f*  
\v 21 مِينْ غَا ثِينِيذْ مَاڒَا نتَّا إِڭَّا ذ أَزدْجِيفْ خَامْ إِنِّي إِ ثسّْڒمْذذْ مَاحنْذْ أَذْ إِڒِينْ ذ إِمدُّوكَّاڒْ نّمْ إِعِيزّنْ؟ مَا وَارْ شمْ د-منّْعنْ ڒوْجعْ أَمْ يِيشْثْ ن ثمْغَارْثْ إِتَّارْونْ؟“   
\m
\v 22 ”خْمِي غَا ثِينِيذْ ذڭْ وُوڒْ نّمْ: ’مَايمِّي ذ أَيِي إِڒْقفْ \add مَارَّا\add* أَيَا؟‘، \add سّنْ أَقَا:\add* ’خْ ؤُبَارُّو ن ڒْمُوعْصِييّثْ نّمْ تّْوَاسّْڭعّْذنْثْ خَامْ ثِيمَّاوِينْ \add ن وَارُّوضْ\add*، تّْوَاذدْجنْ إِنِيرْزنْ نّمْ‘. \x ◘ \xo 13:‏22 \xt إِشا. 47‏:‏2، 3؛ إِرْم. 5‏:‏19؛ 16‏:‏10\x*  
\v 23 مَا إِزمَّارْ إِجّْ \add ن ورْيَازْ\add* زِي \add ثمُّورْثْ ن\add* كُوشْ أَذْ إِبدّڒْ سْمخْ ن ثڒْمشْثْ نّسْ؟ نِيغْ أَغِيڒَاسْ أَرقِّيعنْ نّسْ؟ مَا ثْزمَّارمْ ؤُڒَا ذ كنِّيوْ \add خنِّي\add* أَذْ ثْعذْڒمْ، \add كنِّيوْ\add* إِنِّي إِنُّومنْ ثُوعفّْنَا.  
\v 24 س ؤُينِّي نشّْ أَذْ ثنْ زُوزَّارغْ أَمْ ؤُڒُومْ نِّي إِطَّاونْ س ؤُسُوضِي ن ؤُسمِّيضْ ن ڒخْڒَا. \f ◼ \fr 13:‏24 \ft \+bd ’أَسمِّيضْ زِي ڒخْڒَا‘\+bd* - نِيغْ ’أَسمِّيضْ زِي ثْنَارِيوِينْ‘.\f*  
\v 25 وَا أَذْ يِيڒِي ذ زّْهَارْ نّمْ إِ ذ أَمْ د-إِكَّارنْ زَّايِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، مِينْزِي شمْ ثتُّوذْ أَيِي ؤُ ثتّشْڒذْ خْ إِخَارِّيقنْ.  
\v 26 \add خنِّي\add* ؤُڒَا ذ نشّْ أَذْ سّْڭعّْذغْ إِبحْرُورنْ \add ن وَارُّوضْ\add* نّمْ أَڒْ ثِيوَا أَغمْبُوبْ نّمْ ؤُشَا أَذْ ژَترنْ ڒفْضِيحثْ نّمْ:  
\v 27 زِّينَا نّمْ ذ ؤُسْنحْنحْ إِنزْرنْ نّمْ، فَارْقْ-شّْغڒْ نّمْ إِنْفضْحنْ. خْ ثوْرِيرِينْ ؤُ ذڭْ إِيَّارْ ژْرِيغْ نّْعَاوَاثْ نّمْ ن لْ-أَصْنَامْ. ؤُشْثْ خَامْ، \add أَ\add* ؤُرْشَالِيمْ، أَڒْ مڒْمِي وَارْ ثتّْوَاسِّيزْذِيڭذْ شَا عَاذْ \add زَّايْسنْثْ\add*؟“   
\b  
\b  
\m  
\c 14
\s1 أَوَاڒْ ن سِيذِي خْ ڒَاژَاغْ أَمقّْرَانْ  
\m
\v 1 أَوَاڒْ ن سِيذِي إِ د-يُوسِينْ غَارْ إِرْمِييَا خْ ڒَاژَاغْ أَمقّْرَانْ.   
\m
\v 2 ”\add ثَامُّورْثْ ن\add* يَاهُوذَا ثشْضنْ ؤُشَا ثِيوُّورَا نّسْ هيّْفنْثْ. قِّيمنْ نِيثْنِي خْ ثمُّورْثْ \add س ورُّوضْ\add* ذ أَبَارْشَانْ، ؤُشَا ثْغُويِّيثْ ن ؤُشثْشِي ن ؤُرْشَالِيمْ ثْڭعّذْ غَارْ ؤُجنَّا.  
\v 3 أَيْثْ ن جّهْذْ سكّنْ إِخمَّاسنْ نْسنْ إِمُوقْڒِيڒنْ مَاحنْذْ أَذْ أَيْمنْ أَمَانْ. ڒَامِي د-ؤُسِينْ نِيثْنِي غَارْ وَانُوثنْ ن ونْژَارْ، وَارْ ذَايْسنْ ؤُفِينْ أَمَانْ. نِيثْنِيعقْبنْ-د س إِبُوقَارنْ نْسنْ خْوَانْ، سضْحَانْ، ؤُشِينْ س ؤُبَارّقْ ؤُشَا ڒحّْفنْ إِ ؤُزدْجِيفْ نْسنْ،  
\v 4 مِينْزِي ثتّْوَاشَارّڭْ ثمُّورْثْ، مَاغَارْ وَارْ ذِينْ أَنْژَارْ ذِي ثمُّورْثْ. إِفدْجَاحنْ تّْسضْحَانْ، تّْڒحَّافنْ إِ ؤُزدْجِيفْ نْسنْ.  
\v 5 وَاهْ، ؤُڒَا ذ ثُوذَاذْثْ ذڭْ إِيَّارْ ثُورُووْ-د مِّيسْ، \add مَاشَا خنِّي\add* ثسْمحْ ذَايسْ، مِينْزِي وَارْ ذِينْ إِقِّيمْ أَرْبِيعْ عَاذْ.  
\v 6 إِغْيَاڒْ ن ڒخْڒَا بدّنْ خْ ثوْرِيرِينْ إِقُوشَّارنْ، سّْغَاثَانْ غَارْ ڒعْوِينْ أَمْ وُوشَّاننْ ن ڒخْڒَا. ثِيطَّاوِينْ نْسنْ خسْينْثْ مَاغَارْ وَارْ إِقِّيمْ وفْسُو \add أَزِيزَا\add* عَاذْ.“ \x ◘ \xo 14:‏6 \xt إِرْم. 12‏:‏4\x*   
\m
\v 7 ”وَاخَّا شهّْذنْثْ خَانغْ ڒْمُوعْصِييَّاثْ نّغْ، \add أَ\add* سِيذِي، أڭّْ إِ-ث ذِي طّْوعْ ن يِيسمْ نّشْ، مَاغَارْ أَودَّارْ نّغْ ذڭْ وَاطَّاسْ، أَقَا نخْضَا أَكِيذكْ.  
\v 8 \add شكْ\add* ذ ڒَايَاسْ ن إِسْرَائِيل، \add شكْ\add* ذ أَمْسنْجمْ نّسْ ذِي ڒْوقْثْ ن ڒحْصَارثْ، مَايمِّي غَا ثِيڒِيذْ أَمْ يِيجّْ ن ؤُبَارَّانِي ذِي ثمُّورْثْ، أَمْ يِيجّْ ن ؤُمْسبْرِيذْ إِتّْنُوسَانْ دْجِيڒثْ وَاهَا؟  
\v 9 مَايمِّي ثدْجِيذْ أَمْ يِيجّْ ن ورْيَازْ إِودَّارنْ، أَمْ يِيجّْ ن بُو-ثغْرُوضْثْ إِ وَارْ إِزمَّارنْ أَذْ إِفكّْ؟ أَقَا شكْ ذِي ڒْوسْطْ نّغْ، \add أَ\add* سِيذِي، إِسمْ نّشْ إِتّْوَابَارّحْ خَانغْ، وَارْ ذَايْنغْ سمّحْ!“   
\m
\v 10 ”أَمُّو إِ إِقَّارْ سِيذِي خْ ڒْڭنْسْ-أَ: ’ثُوغَا إِعْجبْ أَسنْ أَذْ ثلْعنْ، وَارْ سّْعِيزّنْ خْ إِضَارنْ نْسنْ. س ؤُينِّي سِيذِي وَارْ خَاسنْ يَارْضَا. ڒخُّو أَذْ يِيذَارْ نتَّا ڒْمُوعْصِييّثْ نْسنْ ؤُشَا أَذْ إِخدْجصْ دّْنُوبْ نْسنْ.‘ “   
\b  
\m
\v 11 إِنَّا أَيِي سِيذِي: ”وَارْ ثتَّارْ إِ ڒْڭنْسْ-أَ مَاحنْذْ أَذْ يِيڒِي مْلِيحْ! \x ◘ \xo 14:‏11 \xt ؤُف. 32‏:‏10؛ إِرْم. 7‏:‏16؛ 11‏:‏14\x*  
\v 12 وَاخَّا ژُومّنْ، نشّْ وَارْ تّسْڒِيغْ شَا غَارْ ثْغُويِّيثْ نْسنْ، \add وَاخَّا\add* نِيثْنِي إِوْينْ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ ذ إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*، نشّْ وَارْ خَاسنْ أَرْضِيغْ شَا، مَاغَارْ نشّْ أَذْ ثنْ قْضِيغْ س سِّيفْ ذ ڒَاژْ ذ طَّاعُونْ.“\x ◘ \xo 14:‏12 \xt أَوڒن. 1‏:‏28؛ إِشا. 1‏:‏15؛ إِرْم. 6‏:‏20؛ 7‏:‏21، 22؛ 11‏:‏11؛ حِز. 8‏:‏18؛ مِيخَا 3‏:‏4\x*   
\m
\v 13 \add خنِّي\add* نِّيغْ نشّْ: ”وَايَّاوْ، أَ سِيذِي إِنُو، سِيذِي، خْزَارْ، إِنَابِييّنْ قَّارنْ أَسنْ: ’كنِّيوْ وَارْ ثْژَارّمْ سِّيفْ، وَارْ إِتِّيڒِي ڒَاژْ، مَاغَارْ نشّْ أَذْ أَومْ وْشغْ ڒهْنَا ذ ثِيذتّْ ذڭْ ومْشَانْ-أَ‘ “  
\v 14 إِنَّا أَيِي سِيذِي: ”إِنَابِييّنْ تّْنبَّانْ س إِخَارِّيقنْ س يِيسمْ إِنُو. نشّْ وَارْ ثنْ د-سّكّغْ، وَارْ ثنْ ؤُمُورغْ ؤُ وَارْ كِيذْسنْ سِّيوْڒغْ. نِيثْنِي تّْنَابّنْ إِجّْ ن ڒوْحِييْ وَارْ إِدْجِينْ إِ كنِّيوْ، أَعزّمْ، مِينْ إِبضْڒنْ ذ وشْمَاثْ ن وُوڒْ \add ن يِيخفْ\add* نْسنْ.“ \x ◘ \xo 14:‏14 \xt إِرْم. 23‏:‏21؛ 27‏:‏15؛ 29‏:‏8، 9\x*   
\m
\v 15 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي: ”خْ إِنَابِييّنْ نِّي إِتّْنبَّانْ س يِيسمْ إِنُو، وَاخَّا نشّْ وَارْ ثنْ د-سّكّغْ شَا، ؤُشَا قَّارنْ: ’وَارْ إِتِّيڒِي سِّيفْ ؤُڒَا ذ ڒَاژْ ذِي ثمُّورْثْ-أَ!‘، أَقَا إِنَابِييّنْ نِّي أَذْ تّْوَاقْضَانْ س سِّيفْ ذ ڒَاژْ.  
\v 16 ڒْڭنْسْ ؤُمِي نبَّانْ، أَذْ إِمّنْضَارْ ذڭْ إِبْرِيذنْ ن ؤُرْشَالِيمْ زِي سِّيبّثْ ن ڒَاژْ ذ سِّيفْ، ؤُشَا وَارْ إِتِّيڒِي وِي ثنْ إِ غَا إِنضْڒنْ: نِيثْنِي، ثِيمْغَارِينْ نْسنْ، إِحنْجِيرنْ نْسنْ ذ ثْحنْجِيرِينْ نْسنْ. أَمُّو ذ خَاسنْ إِ غَا زدْجْعغْ ڒْغَارْ \add ن يِيخفْ\add* نْسنْ.“   
\b  
\m  
\s1 أَشْضَانْ ن ؤُنَابِي  
\m
\v 17 ”س ؤُينِّي أَذْ أَسنْ ثِينِيذْ أَوَاڒْ-أَ: ’إِمطَّاونْ أَذْ د-سّفْينْثْ زِي ثِيطَّاوِينْ إِنُو أَذْ د-هْوَانْثْ، دْجِيڒثْ ذ وَاسّْ، بْڒَا قطُّو!‘ مَاغَارْ ثتّْوَارْژْ ثعْزَارشْثْ، إِدْجِيسْ ن ڒْڭنْسْ إِنُو، س ثَارژِّيثْ ذ ثَامقّْرَانْثْ، س ؤُيزِّيمْ إِتّقّسْ أَطَّاسْ. \x ◘ \xo 14:‏17 \xt إِرْم. 13‏:‏17؛ إِڭجذ. 1‏:‏16؛ 2‏:‏18\x*  
\v 18 خْمِي غَا فّْغغْ، غَارْ ييَّارْ، أَقَا ذَا إِنِّي إِتّْوَاسّْنُوقّْبنْ س سِّيفْ، ؤُ خْمِي غَا أَذْفغْ غَارْ ثنْذِينْثْ، خْزَارْ، إِنِّي إِهڒْشنْ س ڒَاژْ! وَاهْ، إِنَابِييّنْ ذ إِكهَّاننْ ثتّْلِيعنْ ذڭْ إِشْثْ ن ثمُّورْثْ إِ وَارْ سِّيننْ.  
\v 19 مَا ثنْضَارذْ شكْ يَاهُوذَا مَارَّا؟ مَا إِشَارّهْ ڒعْمَارْ نّشْ صِيهْيُونْ؟ مَايمِّي ذ أَنغْ ثوْثِيذْ أَمُّو أَڒَامِي وَارْ ذ أَنغْ إِقِّيمْ بُو ؤُڭنْفُو؟ سِيتِّيمنْ أَذْ يِيڒِي ڒهْنَا، مَاشَا وَارْ ذِينْ أَمْشَانْ إِ ڒْخَارْ، سِيتِّيمنْ ذڭْ إِجّْ ن ڒْوقْثْ ن ؤُڭنْفِي، \add مَاشَا\add* خْزَارْ، \add مْغِيرْ\add* أَسْنخْڒِيعْ. \x ◘ \xo 14:‏19 \xt إِرْم. 8‏:‏15\x*  
\v 20 \add أَ\add* سِيذِي، نشِّينْ وَارْ نسِّينْ ڒْغَارْ نّغْ ذ ڒْمُوعْصِييّثْ ن ڒجْذُوذْ نّغْ، مَاغَارْ نشِّينْ نخْضَا أَكِيذكْ. \x ◘ \xo 14:‏20 \xt إِزهد. 106‏:‏6؛ دَان. 9‏:‏8\x*  
\v 21 وَارْ ذ أَنغْ سّحْقَارَا شَا ذِي طّْوعْ ن يِيسمْ نّشْ، وَارْ سّحْقَارَا ڒْعَارْشْ ن ؤُعُودْجِي نّشْ. إِذَارْ أَنغْ، وَارْ ثَارژَّا ڒْعَاهْذْ إِ كِيذْنغْ ثڭِّيذْ!  
\v 22 مَا أَقَا ذِينْ جَارْ \add لْ-أَصْنَامْ\add* إِبطّْڒنْ ن ڒڭْنُوسْ \add لْ-أَصْنَامْ\add* نِّي إِزمَّارنْ أَذْ وْشنْ أَنْژَارْ، نِيغْ شَّاثنْ إِجنْوَانْ س ونْژَارْ س سِيمَانْثْ نْسنْ؟ مَا وَارْ إِدْجِي ذ شكْ، \add أَ\add* سِيذِي، أَربِّي نّغْ؟ س ؤُينِّي أَذْ شكْ نْرَاجَا، مَاغَارْ شكْ إِ إِتّڭّنْ مَارَّا أَيَا.“ \x ◘ \xo 14:‏22 \xt إِزهد. 135‏:‏7؛ 147‏:‏8؛ إِشا. 30‏:‏23؛ إِرْم. 5‏:‏24؛ 10‏:‏13\x*   
\b  
\b  
\m  
\c 15
\s1 ثَامْوَارِّيثْ ن سِيذِي  
\m
\v 1 إِنَّا أَيِي سِيذِي: ”وَاخَّا مَاڒَا إِبدّْ مُوسَا ذ شَامْوِيلْ زَّاثْ إِ وُوذمْ إِنُو، عَاذْ وَارْ إِتِّيڒِي ڒعْمَارْ إِنُو أَكْ-ذ ڒْڭنْسْ-أَ. سِيڭّْوجْ إِ-ثنْ زِي زَّاثْ ن وُوذمْ إِنُو، أجّْ إِ-ثنْ أَذْ ؤُيُورنْ. \x ◘ \xo 15:‏1 \xt ؤُف. 32‏:‏14؛ 1 صم. 7‏:‏9؛ حِز. 14‏:‏14، 20\x*  
\v 2 خْمِي ذ أَشْ إِ غَا إِنِينْ: ’مَانِي غَا نُويُورْ؟‘، \add خنِّي\add* أَذْ أَسنْ ثِينِيذْ: ’أَمُّو إِ إِقَّارْ سِيذِي: وِي \add إِدْجَانْ\add* إِ ڒْموْثْ، غَارْ ڒْموْثْ، وِي \add إِدْجَانْ\add* إِ سِّيفْ، غَارْ سِّيفْ، وِي \add إِدْجَانْ\add* إِ ڒَاژْ، غَارْ ڒَاژْ ؤُ وِي \add إِدْجَانْ\add* إِ ڒحْبسْ، غَارْ ڒحْبسْ!‘\x ◘ \xo 15:‏2 \xt زَاك. 11‏:‏9؛ أَسَا. 13‏:‏10\x*  
\v 3 أَذْ ثنْ خدْجْصغْ س أَربْعَا ن وبْرِيذنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي: س سِّيفْ أَڒَامِي غَا تّْوَانْغنْ، س يِيطَانْ أَڒَامِي \add ثنْ\add* جَارّنْ زڭْ وبْرِيذْ، س إِجْضَاضْ ن ؤُجنَّا ذ ڒوْحُوشْ ن ثمُّورْثْ أَڒْ غَا تّْوَاصَارْضنْ ؤُ أَذْ تّْوَاردّْدْجنْ. \x ◘ \xo 15:‏3 \xt لَاوِي 26‏:‏16؛ إِرْم. 7‏:‏33\x*  
\v 4 نشّْ أَذْ ثنْ أَرّغْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ إِ مَارَّا ثِيڭلْذِيوِينْ ن دُّونشْثْ زِي سِّيبّثْ ن مَانَاسَّا، مِّيسْ ن حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ذ أَخْڒَافْ زِي مِينْ إِڭَّا ذِي ؤُرْشَالِيمْ.“ \x ◘ \xo 15:‏4 \xt أَعَوذ. 28‏:‏25\x*   
\m
\v 5 ”مَاغَارْ مَانْ ونْ ؤُمِي غَا ثزِّيدْجذْ، \add أَ\add* ؤُرْشَالِيمْ؟ وِي ذ أَمْ إِ غَا إِسّْحِيسّْفنْ نِيغْ وِي د غَا إِفّْغنْ زڭْ وبْرِيذْ مَاحنْذْ أَذْ خَامْ إِسّقْسَا خْ ؤُمدُّورْ نّمْ؟ \x ◘ \xo 15:‏5 \xt إِشا. 51‏:‏19\x*  
\v 6 شمْ ثْسمْحذْ ذَايِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، ثْذوْڒذْ غَارْ ضفَّارْ. س ؤُينِّي إِ غَا سّْوِيژّْضغْ أَفُوسْ إِنُو ضِيدّْ نّمْ ؤُشَا أَذْ شمْ أَردّْدْجغْ. نشّْ ؤُحْرغْ س ؤُحِينِّي خَاومْ.“ \x ◘ \xo 15:‏6 \xt إِرْم. 5‏:‏7\x*   
\m
\v 7 ”نشّْ أَذْ ثنْ زُوزَّارغْ س دْجُوحْ ذِي ثوُّورَا ن ثمُّورْثْ. نشّْ كشّْضغْ إِحنْجِيرنْ زِي ڒْڭنْسْ إِنُو ؤُشَا سّْهلّْكغْ \add ثنْ\add*. نِيثْنِي وَارْ د-ذْوِيڒنْ شَا زڭْ إِبْرِيذنْ نْسنْ \add إِعفَّاننْ\add*.\x ◘ \xo 15:‏7 \xt إِرْم. 4‏:‏11\x*  
\v 8 ثِيجَّاڒْ نْسنْ أَذْ إِڒِينْثْ وسْعنْثْ خْ يجْذِي ن ڒبْحُورَاثْ. ذِي طّْيَا ن وَاسّْ أَذْ خَاسنْ سِّيوْضغْ إِجّْ ن ؤُمْثحَّايْ، خْ يمَّاسْ ذ ؤُحُوذْرِي. ذغْيَا أَذْ خَاسْ وْضِيغْ نشّْ س ثِيڭّْوُوذِي ذ إِنخْڒِيعنْ. \f ◼ \fr 15:‏8 \ft \+bd ’خْ يمَّاسْ ن ؤُحُوضْرِي‘\+bd* - خْزَارْ عَاوذْ إِرْم. 15‏:9.\f*  
\v 9 ثنِّي إِ د-يُورْونْ سبْعَا ن إِحنْجِيرنْ، ثخْسِي. نتَّاثْ ثذْڒقْ إِ بُوحْبڒْ نّسْ، ثغْڒِي ثْفُوشْثْ نّسْ أَمْ إِدْجَا عَاذْ ذ وَاسّْ. نتَّاثْ ثتّْسضْحَا ؤُشَا ثتّطّفْ إِ-ت إِ-د ڒفْضِيحثْ. مِينْ إِقِّيمنْ زَّايْسنْ أَذْ ث وْشغْ إِ سِّيفْ زَّاثْ إِ وُوذمْ ن ڒْعذْيَانْ نْسنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ \x ◘ \xo 15:‏9 \xt عَام. 8‏:‏9\x*   
\b  
\m  
\s1 أَمنْغِي ذڭْ وُوڒْ ن إِرْمِييَا  
\m
\v 10 ”ؤُشْثْ خَافِي، يمَّا، أَقَا شمْ ثُورْوذْ أَيِي-د: إِجّْ ن ورْيَازْ ن ؤُمْشُوبّشْ، إِجّْ ن ورْيَازْ ن ؤُمنْغِي إِ مَارَّا ثَامُّورْثْ. نشّْ وَارْ ذ أَسنْثْ أَرْضْڒغْ ؤُشَا نِيثْنِي وَارْ ذ أَيِي تّتُّورْسنْ، وَاخَّا أَمنِّي مَارَّا نعّْڒنْ أَيِي.“ \f ◼ \fr 15:‏10 \ft \+bd أَفسَّارْ\+bd* - أَنَابِي إِرْمِييَا إِسَّاوَاڒْ.\f*  \x ◘ \xo 15:‏10 \xt أَيُوبْ 3؛ إِرْم. 20‏:‏14‏-‏18\x*  
\v 11 إِنَّا سِيذِي: ”\add أَهْ\add*، مَاڒَا نشّْ وَارْ ثڭّغْ س ثْشُونِي أَكِيذكْ، مَاڒَا نشّْ وَارْ ڭِّيغْ أَذْ شكْ إِحْشمْ ڒعْذُو ذِي ڒْوقْثْ ن ثشْثِي ثَاعفَّانْثْ ؤُ ذِي ڒْوقْثْ نْ ڒحْصَارثْ.“  
\v 12 مَا إِزمَّارْ بْنَاذمْ أَذْ يَارْژْ ؤُزَّاڒْ، ؤُزَّاڒْ إِ د-يُوسِينْ زِي شَّامَالْ، نِيغْ نّْحَاسْ؟ \x ◘ \xo 15:‏12 \xt إِرْم. 6‏:‏28\x*  
\v 13 أَڭْڒَا نّشْ ذ ڒكْنُوزْ نّشْ أَذْ ثنْ وْشغْ ذ ثَاكشَّاضْثْ إِ ڒڭْنُوسْ، بْڒَا تَّامَانْ، زِي سِّيبّثْ ن مَارَّا دّْنُوبْ نّشْ ؤُشَا \add أَيَا\add* ذِي مَارَّا ثَامُّورْثْ نّشْ. \x ◘ \xo 15:‏13 \xt إِرْم. 17‏:‏3\x*  
\v 14 نشّْ أَذْ \add شكْ\add* سّعْذُوغْ أَكْ-ذ ڒعْذُو نّشْ غَارْ إِشْثْ ن ثمُّورْثْ نِّي وَارْ ثسِّينذْ شَا، مَاغَارْ س وغْضَابْ إِنُو ثَارْغَا ثْمسِّي نِّي إِ غَا إِقِّيمنْ ثْشمّضْ ضِيدّْ نْومْ.“ \x ◘ \xo 15:‏14 \xt أَعَوذ. 32‏:‏22\x*   
\b  
\m
\v 15 ”\add أَ\add* سِيذِي، شكْ ثسّْنذْ ت، إِذَارْ أَيِي ؤُشَا ڒْهَا-د أَكِيذِي! نْثَاقمْ أَيِي زڭْ يِينِّي ذ أَيِي إِضفَّارنْ! وَارْ ذ أَيِي تّكّسْ، مِينْزِي غَاركْ تَّاسِيعْ ن ڒْخَاضَارْ أَطَّاسْ. سّنْ أَقَا نشّْ أَذْ خَاكْ كْسِيغْ ڒْعَارْ ذِي طّْوعْ نّشْ. \x ◘ \xo 15:‏15 \xt إِرْم. 11‏:‏20\x*  
\v 16 ؤُمِي تّْوَافنْ وَاوَاڒنْ نّشْ، شِّيغْ ثنْ ذغْيَا. أَوَاڒْ نّشْ ثُوغَا-ث إِ نشّْ ذ أَرْشُوقْ ذ ڒفْرَاحثْ إِ وُوڒْ إِنُو مَاغَارْ إِتّْوَابَارّحْ إِسمْ نّشْ ذِي ثِيوَا إِنُو، \add أَ\add* سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ.   
\m
\v 17 نشّْ وَارْ تّْغِيمِيغْ شَا ذڭْ وڭْرَاوْ ن يِينِّي إِسْثهْزَانْ، وَارْ نڭّْزغْ س ڒفْرَاحثْ. زِي سِّيبّثْ ن ؤُفُوسْ نّشْ تّْغِيمِيغْ وحّْذِي، مَاغَارْ ثشُّورذْ أَيِي س وسْخضْ نّشْ. \x ◘ \xo 15:‏17 \xt إِزهد. 1‏:‏1\x*  
\v 18 مَايمِّي ڒحْرِيقْ إِنُو إِدَّارْ ڒبْذَا ؤُ مَايمِّي وَارْ إِزمَّارْ ؤُيزِّيمْ إِنُوعمَّارْصْ أَذْ إِڭّنْفَا، مَا نتَّا يُوڭِي أَذْ إِڭّنْفَا؟ مَا س ثِيذتّْ أَقَا شكْ أَمْ وَامَانْ إِنْهوْڒنْ إِنِّي وَارْ ذِي إِدْجِي ڒَامَانْ؟“ \x ◘ \xo 15:‏18 \xt أَيُوبْ 6‏:‏15‏-‏30؛ إِرْم. 30‏:‏15\x*   
\m
\v 19 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي: ’مَاڒَا شكْ ثْذوْڒذْ-د، نشّْ أَذْ شكْ أَرّغْ أَذْ د-ثْذوْڒذْ ؤُ أَذْ ثْبدّذْ زَّاثْ إِ وُوذمْ إِنُو. مَاڒَا ثسِّيوْڒذْ مِينْ إِغْڒَانْ ذڭْ ومْشَانْ ن مِينْ وَارْ إِسكّْوِينْ وَالُو، \add خنِّي\add* أَذْ ثِيڒِيذْ أَمْ ؤُقمُّومْ إِنُو. أجّْ إِ-ثنْ أَذْ غَاركْ د-ذوْڒنْ، مَاشَا شكْ وَارْ ثْزمَّارذْ أَذْ غَارْسنْ د-ثْذوْڒذْ.  
\v 20 مَاغَارْ نشّْ أَذْ شكْ ڭّغْ إِ ڒْڭنْسْ-أَ ذ ڒْحِيضْ إِمثْننْ ن نّْحَاسْ. أَذْ كِيذكْ مّنْغنْ، \add مَاشَا\add* نِيثْنِي وَارْ زمَّارنْ أَذْ شكْ أَرنْينْ، مَاغَارْ نشّْ أَكِيذكْ حِيمَا أَذْ شكْ سّْنجْمغْ ؤُ حِيمَا أَذْ شكْ فكّغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.\x ◘ \xo 15:‏20 \xt إِرْم. 1‏:‏18\x*  
\v 21 نشّْ أَذْ شكْ فكّغْ زڭْ ؤُفُوسْ ن إِعفَّاننْ ؤُ نشّْ أَذْ شكْ فْذِيغْ زڭْ ومْنَاعْ ن أَيْثْ ن بُو-ڒخْشُونثْ.“   
\b  
\b  
\m  
\c 16
\s1 سِيذِي إِسَّاوَاڒْ أَكْ-ذ إِرْمِييَا  
\m
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:  
\v 2 ”وَارْ تَّاوِي ثَامْغَارْثْ إِ يِيخفْ نّشْ ؤُ وَارْ غَاركْ تِّيڒِينْ إِحنْجِيرنْ ذ ثْحنْجِيرِينْ ذڭْ ومْشَانْ-أَ،  
\v 3 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي خْ إِحنْجِيرنْ ذ ثْحنْجِيرِينْ إِ د غَا إِتّْوُورْونْ ذڭْ ومْشَانْ-أَ ؤُ خْ يمَّاثْسنْ إِ ثنْ د-يُورْونْ ؤُ خْ بَابَاثْسنْ إِ ثنْ د-إِجِّينْ ذِي ثمُّورْثْ-أَ:  
\v 4 ’نِيثْنِي أَذْ مّْثنْ سْ  إِبْرِيذنْ إِوْعَارنْ أَطَّاسْ، وَارْ خَاسنْ شطّنْ ؤُ وَارْ ثنْ نطّْڒنْ، نِيثْنِي أَذْ ذوْڒنْ ذ ڒغْبَارْ إِ وُوذمْ ن ثمُّورْثْ ؤُشَا أَذْ تّْوَاغزّنْ س سِّيفْ ذ ڒَاژْ، ؤُ ڒْخشْبَاثْ نْسنْ أَذْ ذوْڒنْثْ ذ مَاشَّا إِ إِجْضَاضْ ن ؤُجنَّا ؤُ إِ ڒوْحُوشْ ن ڒخْڒَا.‘ “ \x ◘ \xo 16:‏4 \xt إِرْم. 7‏:‏33؛ 9‏:‏22؛ 14‏:‏16؛ 15‏:‏2، 3؛ 25‏:‏33؛ 34‏:‏20\x*   
\m
\v 5 ”مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: ’وَارْ تَّاذفْ غَارْ إِشْثْ ن ثَادَّارْثْ ن وشْضَانْ ؤُ وَارْ شَّاثْ أَڭجْذُورْ، وَارْ أَرحّمْ، مَاغَارْ نشّْ كّْسغْ ڒهْنَا إِنُو خْ ڒْڭنْسْ-أَ، ثَامخْسِيوْثْ إِنُو إِشوَّارنْ ذ أَرّحْمثْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.‘  
\v 6 إِمقّْرَاننْ ذ إِمژْيَاننْ أَذْ مّْثنْ ذِي ثمُّورْثْ-أَ. وَارْ ثنْ نطّْڒنْ، وَارْ خَاسنْ شَّاثنْ أَڭجْذُورْ، وَارْ خبّْشنْ إِخفْ نْسنْ نِيغْ أَذْ سّْقُوشَّارنْ إِخفْ نْسنْ ذِي طّْوعْ نْسنْ. \x ◘ \xo 16:‏6 \xt لَاوِي 19‏:‏28؛ أَعَوذ. 14‏:‏1\x*  
\v 7 وَارْ ذ أَسنْ إِتّْوَارْژْ وغْرُومْ زِي سِّيبّثْ ن وشْضَانْ حِيمَا أَذْعزَّانْ شَا ن يِيجّنْ خْ إِجّْ ن ؤُمتِّي، ؤُ وَارْ ذ أَسنْ تِّيشنْ أَذْ سْونْ زڭْ ؤُغَارَّافْ ن ؤُعزِّي خْ بَابَاسْ نِيغْ يمَّاسْ. \x ◘ \xo 16:‏7 \xt مت. 26‏:‏26‏-‏28؛ مك. 14‏:‏22‏-‏24؛ لك. 22‏:‏19‏-‏20\x*  
\v 8 وَارْ تَّاذفْ غَارْ ثَادَّارْثْ مَانِي تّڭّنْ زَّارْذثْ مَاحنْذْ أَذْ ثقِّيمذْ غَارْسنْ إِ مَاشَّا ذ ثْسسِّيثْ.  
\v 9 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: خْزَارْ، نشّْ أَذْ سّْبدّغْ زَّاثْ إِ ثِيطَّاوِينْ نْومْ ذڭْ ومْشَانْ-أَ ثْمِيجَّا ن وَارْشَاقْ ذ ثْمِيجَّا ن ڒفْرَاحثْ، ثْمِيجَّا ن مُوڒَايْ ذ ثْمِيجَّا ن ثسْڒِيثْ.“ \x ◘ \xo 16:‏9 \xt إِشا. 24‏:‏7، 8؛ إِرْم. 7‏:‏34؛ 25‏:‏10؛ حِز. 26‏:‏13\x*   
\b  
\m
\v 10 ”خْمِي غَا ثْبَارّْحذْ مَارَّا أَوَاڒنْ-أَ إِ ڒْڭنْسْ-أَ ؤُشَا نِيثْنِي أَذْ سّقْسَانْ: ’مَايمِّي إِقَّارْ سِيذِي مَارَّا ڒْغَارْ-أَ أَمقّْرَانْ خَانغْ ؤُ مِينْ \add إِدْجَانْ\add* ذ لْجَارِيمَا نّغْ ؤُ مِينْ إِدْجَانْ ذ دّنْبْ نّغْ إِ نڭَّا نشِّينْ أَكْ-ذ سِيذِي، أَربِّي نّغْ؟‘، \x ◘ \xo 16:‏10 \xt إِرْم. 5‏:‏19\x*  
\v 11 \add خنِّي\add* أَذْ أَسنْ ثِينِيذْ: ’مَاغَارْ ڒجْذُوذْ نْومْ سمْحنْ ذَايِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، ؤُشَا ؤُيُورنْ أَوَارْنِي إِ إِربِّيثنْ نّغْنِي ؤُشَاعبْذنْ ؤُ سجْذنْ أَسنْ، \add مَاشَا\add* سمْحنْ ذَايِي ؤُ وَارْ حْضِينْ شَّارِيعَا إِنُو.  
\v 12 ؤُ كنِّيوْ سِيمَانْثْ نْومْ ثڭِّيمْ مَاهُو خْ ڒجْذُوذْ نْومْ، مِينْزِي خْزَارْ، كُوڒْ  إِجّْ زَّايْومْ إِضَافَّارْ ڒقْسَاحثْ ن وُوڒْ نّسْ أَعفَّانْ، أَڒَامِي كنِّيوْ وَارْ د غَارِي ثسْڒِيمْ \add قَاعْ\add*. \f ◼ \fr 16:‏12 \ft \+bd ’ؤُڒْ أَعفَّانْ نْومْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ؤُڒْ أَعفَّانْ نّسْ‘.\f*  \x ◘ \xo 16:‏12 \xt إِرْم. 3‏:‏17؛ 7‏:‏26؛ 9‏:‏14؛ 11‏:‏10؛ 13‏:‏10؛ 17‏:‏23\x*  
\v 13 س ؤُينِّي أَذْ كنِّيوْ حجَّارغْ غَارْ بَارَّا زِي ثمُّورْثْ-أَ غَارْ إِشْثْ ن ثمُّورْثْ إِ وَارْ ثسِّينمْ كنِّيوْ ؤُڒَا ذ ڒجْذُوذْ نْومْ، ؤُشَا ذِينِّي إِ غَا ثْعبْذمْ إِربِّيثنْ نّغْنِي، أَسّْ ذ دْجِيڒثْ، مِينْزِي نشّْ وَارْ غَارْومْ د-تَّارْزِيفغْ عَاذْ س شَا ن ڒْخَاضَارْ.‘ “ \x ◘ \xo 16:‏13 \xt أَعَوذ. 4‏:‏27؛ 28‏:‏64، 65\x*   
\m
\v 14 ”س ؤُيَا، خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، نِّي ذِي وَارْ قَّارنْ عَاذْ: ’س ثِيذتّْ أَمْ إِدَّارْ سِيذِي إِ د إِسُّوفّْغنْ أَيْثْ ن إِسْرَائِيل زِي مِيصْرَا!‘ \x ◘ \xo 16:‏14 \xt إِرْم. 23‏:‏7، 8\x*  
\v 15 مَاشَا: ’س ثِيذتّْ أَمْ إِدَّارْ سِيذِي ونِّي د-إِسُّوفّْغنْ أَيْثْ ن إِسْرَائِيل زِي ثمُّورْثْ ن شَّامَالْ ؤُ زِي مَارَّا ثِيمُّورَا مَانِي خَاسنْ يُوژّڒْ!‘ مِينْزِي نشّْ أَذْ ثنْ أَرّغْ غَارْ ثمُّورْثْ نِّي وْشِيغْ إِ ڒجْذُوذْ نْسنْ.  
\v 16 خْزَارْ، نشّْ أَذْ سّكّغْ أَطَّاسْ ن إِنيْمَارنْ ن إِسڒْمَانْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، إِنِّي ثنْ إِ غَا يْمَارنْ، ؤُ خنِّي أَذْ سّكّغْ أَطَّاسْ ن إِنيْمَارنْ نِّي خَاسنْ إِ غَا يَاژّْڒنْ زِي مْكُوڒْ أَذْرَارْ ؤُ زِي مْكُوڒْ ثَاوْرِيرْثْ ؤُ زڭْ إِفدْجِيقنْ جَارْ ڒجْرُوفْ.  
\v 17 مَاغَارْ ثِيطَّاوِينْ إِنُو تّْوَاڒَانْثْ مَارَّا إِبْرِيذنْ نْسنْ، نِيثْنِي وَارْ زمَّارنْ أَذْ زَّايِي نُّوفَّارنْ ؤُشَا ڒْمُوعْصِييّثْ نْسنْ وَارْ ثْزمَّارْ أَذْ ثنُّوفَّارْ زَّاثْ إِ ثِيطَّاوِينْ إِنُو. \x ◘ \xo 16:‏17 \xt أَيُوبْ 34‏:‏21؛ أَوڒن. 5‏:‏21؛ إِرْم. 32‏:‏19\x*  
\v 18 أَمزْوَارْ أَذْ خڒْفغْ س ؤُضفُّوسْ \add مَارَّا\add* ڒْمُوعْصِييّثْ نْسنْ ذ مَارَّا دّْنُوبْ نْسنْ، مِينْزِي نِيثْنِي سّْعِيدْجْثنْ ثَامُّورْثْ إِنُو. نِيثْنِي شُّورنْ ثَاسْغَارْثْ إِنُو س ڒْخشْبَاثْ ن نّْعَاوَاثْ ن لْ-أَصْنَامْ نْسنْ ؤُ س جّْعَايفْ نْسنْ.“ \x ◘ \xo 16:‏18 \xt إِرْم. 3‏:‏2؛ حِز. 43‏:‏7\x*   
\b  
\m
\v 19 ”\add أَ\add* سِيذِي، شكْ ذ جّهْذْ إِنُو ذ لْبُورْجْ إِنُو ذ أَمْشَانْ إِنُو ن ثَاروْڒَا ذڭْ وَاسّْ ن ڒحْصَارثْ. أَذْ غَاركْ د-أَسنْ ڒڭْنُوسْ زڭْ إِنڭُّورَا ن دُّونشْثْ، أَذْ إِنِينْ: ’ثَاسْغَارْثْ نِّي طّْفنْ ڒجْذُوذْ نّغْ، \add ذَايسْ مْغِيرْ\add* أَشْمَاثْ ذ \add أَعْبذْ ن لْ-أَصْنَامْ\add* إِبطِّيڒنْ، ثِيمسْڒَايِينْ إِ وَارْ إِنفّْعنْ.‘  
\v 20 مَا إِزمَّارْ بْنَاذمْ أَذْ إِڭّْ إِربِّيثنْ إِ يِيخفْ نّسْ؟ نِيثْنِي وَارْ دْجِينْ ذ إِربِّيثنْ.  
\v 21 س ؤُيَا، خْزَارْ، ثْوَاڒَا-يَا نشّْ أَذْ ثنْ أَرّغْ أَذْ شهْذنْ، أَذْ ثنْ أَرّغْ أَذْ سّْننْ أَفُوسْ إِنُو ذ جّهْذْ إِنُو، ؤُشَا \add خنِّي\add* أَذْ سّْننْ بلِّي إِسمْ إِنُو ’سِيذِي‘.“ \x ◘ \xo 16:‏21 \xt إِرْم. 33‏:‏2\x*   
\b  
\b  
\m  
\c 17
\s1 دّْنُوبْ ن يَاهُوذَا  
\m
\v 1 ”إِتّْوَاخْبشْ دّنْبْ ن يَاهُوذَا س بْلُومَا ن وُوزَّاڒْ، س ثْخفْثْ ن إِجّْ ن ؤُمسْمِيرْ ذِي ثڒْوِيحْثْ ن وُوڒْ نْسنْ ؤُ ذڭْ وَاشَّاونْ ن إِعَالْطَارنْ نّشْ. \x ◘ \xo 17:‏1 \xt إِرْم. 11‏:‏13\x*  
\v 2 أَمْ مَامّشْ تِّيذَارنْ ثَارْوَا نْسنْ، تِّيذَارنْ نِيثْنِي ؤُڒَا ذ إِعَالْطَارنْ نْسنْ ذ ثْربِّينْ نْسنْ ن شْوَارْثِي غَارْ ثْشجُّورَا ثِيزِيزَاوِينْ خْ ثوْرِيرِينْ يُوعْڒَانْ. \x ◘ \xo 17:‏2 \xt إِرْم. 2‏:‏20\x*  
\v 3 أَذْرَارْ إِنُو ذڭْ إِيَّارْ ذ وَاڭْڒَا نّشْ ذ مَارَّا ڒكْنُوزْ نّشْ أَذْ ثنْ وْشغْ ذ ثَاكشَّاضْثْ، ؤُڒَا ذ ڒڭْعُوذِي نّشْ \add مَانِي ثتّْوهّْبذْ دّْبَايحْ\add*، زِي سِّيبّثْ ن دّْنُوبْ ذِي مَارَّا ثَامُّورْثْ نّشْ. \x ◘ \xo 17:‏3 \xt إِرْم. 15‏:‏13\x*  
\v 4 \add خنِّي\add* أَذْ ثَارْخُوذْ زِي ثسْغَارْثْ نّشْ نِّي ذ أَشْ وْشِيغْ ؤُ مَانْ أَيَا زِي سِّيبّثْ ن \add دّْنُوبْ ن\add* يِيخفْ نّشْ. نشّْ أَذْ شكْ ڭّغْ ذ إِسْمغْ ن ڒْعذْيَانْ نّشْ ذڭْ إِشْثْ ن ثمُّورْثْ إِ وَارْ ثسِّينذْ شَا، مَاغَارْ كنِّيوْ ثَارِّيمْ إِشْثْ ن ثْمسِّي أَذْ ثْسَارغْ وغْضَابْ إِنُو نِّي إِ غَا إِقِّيمنْ إِشمّضْ إِ ڒبْذَا.“ \x ◘ \xo 17:‏4 \xt أَعَوذ. 28‏:‏68؛ إِرْم. 15‏:‏14؛ 16‏:‏13\x*   
\m
\v 5 ”أَمُّو إِ إِقَّارْ سِيذِي: ’أَذْ إِتّْوَانْعڒْ ورْيَازْ نِّي إِتّْشَاڒنْ خْ بْنَاذمْ ؤُشَا إِڭَّا دَّاثْ ذ ؤُغِيڒْ نّسْ \add إِ خفْ إِتّْعمّذْ\add*، ؤُ ونِّي ؤُڒْ نّسْ إِحيّذْ خْ سِيذِي. \f ◼ \fr 17:‏5 \ft \+bd ’إِتّْعمّذْ خْ ويْسُومْ‘\+bd* - إِخْسْ أَذْ يِينِي ’إِتّْعمّذْ خْ بْنَاذمْ نِيغْ خْ ڒْمَاڒْ‘.\f*  
\v 6 س مِينْزِي أَذْ يِيڒِي ذ ڒْعرْعَارْ ذِي ڒخْڒَا، ونِّي وَارْ إِتَّاشَانْ خْ مِينِّي د غَا يَاسْ مِينْ إِشْنَانْ، ذ ونِّي إِ غَا إِقِّيمنْ ذڭْ إِمُوشَانْ إِتّْوَاشمْضنْ س ڒحْمُو ذِي ڒخْڒَا، ذڭْ إِشْثْ ثمُّورْثْ ثَامدْجَاحْثْ وَارْ إِزْذِيغنْ.  
\v 7 أَذْ إِتّْوَابَاركْ ورْيَازْ نِّي إِتّْشَاڒنْ خْ سِيذِي ذ ونِّي إِڭِّينْ سِيذِي ذ ڒَامَانْ نّسْ. \x ◘ \xo 17:‏7 \xt إِزهد. 2‏:‏12؛ 34‏:‏9؛ أَوڒن. 16‏:‏20؛ إِشا. 30‏:‏18\x*  
\v 8 أَذْ يِيڒِي أَمْ ثْشجَّارْثْ إِ إِتّْوَاژُّونْ غَارْ ثِيغزْرَاثِينْ ن وَامَانْ، ثنِّي إِوْثِينْ إِژوْرَانْ نّسْ غَارْ ثغْزَارْثْ. وَارْ ثسِّينْ شَا مڒْمِي د غَا يَاسْ ڒهْمُو ؤُ ثِيفْرَايْ نّسْ أَذْ قِّيمنْثْ ذ ثِيزِييْزَاوِينْ. ذڭْ إِجّْ ن ؤُسڭّْوَاسْ ن ڒَاژَاغْ وَارْ ثتِّيسْڒِيوْ شَا ؤُشَا وَارْ ثتّْبذِّي أَذْ ثكْسِي ڒْغِيدْجثْ نّسْ.‘ “ \f ◼ \fr 17:‏8 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  \x ◘ \xo 17:‏8 \xt إِزهد. 1‏:‏3\x*   
\m
\v 9 ”ؤُڒْ ذ أَغدَّارْ سنّجْ خْ كُوڒْشِي، وَارْ إِزمَّارْ أَذْ إِڭّنْفَا، وِي إِزمَّارنْ أَذْ ث إِسّنْ؟  
\v 10 نشّْ، سِيذِي، أَرزُّوغْ ذڭْ وُوڒْ ؤُ تّْجَارَّابغْ ثِيژَّاڒْ، حِيمَا أَذْ خدْجْصغْ كُوڒْ إِجّْ عْلَاحْسَابْ ثِيبْرِيذِينْ نّسْ، عْلَاحْسَابْ ڒْغِيدْجثْ ن ثْمڭَّا نّسْ. \f ◼ \fr 17:‏10 \ft \+bd ’ثِيژَّاڒْ‘\+bd* - نِيغْ ’ثِيڭژْڒِينْ‘.\f*  \x ◘ \xo 17:‏10 \xt 1 صم. 16‏:‏7؛ إِزهد. 7‏:‏10\x*  
\v 11 أَمْ إِشْثْ ن ثْسكُّورْثْ إِ إِسّْڭُوطّْينْ خْ \add ثْمدْجَاڒِينْ\add* نِّي وَارْ د-ثُورُووْ، أَمُّو إِ إِدْجَا ونِّي إِڭِّينْ أَڭْڒَا، \add مَاشَا\add* وَارْ إِدْجِي س ڒْحقّْ. ذِي ڒْوسْطْ ن وُوسَّانْ نّسْ إِتّْخصَّا أَذْ ذَايْسنْ إِسْمحْ ؤُ غَارْ ؤُنڭَّارُو نّسْ أَذْ إِذْوڒْ ذ أَبُوهَاڒِي.“   
\b  
\m
\v 12 ”إِجّْ ن ڒْعَارْشْ إِڭْذَارنْ س ؤُعُودْجِي، يُوعْڒَانْ أَطَّاسْ زڭْ ؤُمزْوَارُو، \add أَمُّو إِ يدْجَا\add* أَمْشَانْ ن زَّاوشْثْ نّغْ إِقدّْسنْ.  
\v 13 \add شكْ\add* ذ ڒَايَاسْ ن إِسْرَائِيل، \add أَ\add* سِيذِي، مَارَّا إِنِّي خَاكْ إِحيّْذنْ، أَذْ نْفضْحنْ. إِنِّي خَافِي إِحيّْذنْ، أَذْ ثْوَارِينْ \add إِسْمَاونْ نْسنْ\add* ذڭْ ؤُشَاڒْ، مَاغَارْ نِيثْنِي سمْحنْ ذِي سِيذِي، ڒْعُونْصَارْ ن وَامَانْ إِدَّارنْ. \x ◘ \xo 17:‏13 \xt إِزهد. 73‏:‏27؛ إِشا. 1‏:‏28؛ إِرْم. 2‏:‏13؛ يُوح. 8‏:‏8\x*  
\v 14 سْڭنْفَا أَيِي، سِيذِي، \add خنِّي\add* أَذْ ڭّنْفِيغْ، سنْجمْ أَيِي، \add خنِّي\add* أَذْ تّْوَاسّْنجْمغْ، مَاغَارْ شكْ ذ إِزْڒِي ن ؤُصبّحْ إِنُو.  
\v 15 خْزَارْ، نِيثْنِي قَّارنْ أَيِي: ’مَانِي إِدْجَا وَاوَاڒْ ن سِيذِي؟ أجّْ إِ-ث أَذْ د-إِخشّْ!‘ \x ◘ \xo 17:‏15 \xt إِشا. 5‏:‏19؛ 2 بُط. 3‏:‏4\x*  
\v 16 نشّْعمَّارْصْ وَارْ حْصَارغْ إِخفْ إِنُو مَاحنْذْ أَذْ إِڒِيغْ ذ أَمكْسَاوْ أَوَارْنِي أَشْ، وَارْ مژْرِيغْ غَارْ وَاسّْ ن أَرْژِييّثْ. شكْ ثسّْنذْ ث: مِينْ إِ ذ أَيِي د-يُوسِينْ خْ إِينْشِيشنْ إِنُو، إِفّغْ-د زَّاثْ إِ ثِيطَّاوِينْ نّشْ.  
\v 17 وَارْ ذ أَيِي سْنخْڒِيعْ شَا، شكْ ذ أَذُورِّي إِنُو ذڭْ وَاسّْ ن ڒْغَارْ. \x ◘ \xo 17:‏17 \xt إِرْم. 16‏:‏19\x*  
\v 18 أجّْ إِنِّي ذ أَيِي إِضَافَّارنْ أَذْ نْفضْحنْ، مَاشَا وَارْ ذ أَيِي تّجِّي أَذْ نْفضْحغْ، أجّْ إِ-ثنْ أَذْ نْخڒْعنْ، مَاشَا وَارْ ذ أَيِي تّجِّي أَذْ نْخڒْعغْ. سِيوضْ-د خَاسنْ أَسّْ ن ڒْغَارْ ؤُشَا أَرْژْ إِ-ثنْ س إِشْثْ ن ثَارژِّيثْ س وضْفَاسْ.“ \x ◘ \xo 17:‏18 \xt إِزهد. 35‏:‏4؛ 40‏:‏15؛ إِرْم. 15‏:‏15\x*   
\b  
\m
\v 19 ”أَمُّو إِ غَارِي د-إِسِّيوڒْ سِيذِي: ’ؤُيُورْ ؤُشَا بدّْ ذِي ثوَّارْثْ ن إِحنْجِيرنْ ن ڒْڭنْسْ، \add ثَاوُّورْثْ\add* إِ زِي تَّاذْفنْ إِجدْجِيذنْ ن يَاهُوذَا ؤُ إِ زِي د-تّفّْغنْ نِيثْنُو، ؤُ \add أڭّْ أَمُّو ؤُڒَا\add* ذِي مَارَّا ثِيوُّورَا ن \add ثنْذِينْثْ\add* ؤُرْشَالِيمْ  
\v 20 ؤُشَا إِنِي أَسنْ: سْڒمْ إِ وَاوَاڒْ ن سِيذِي، كنِّيوْ إِجدْجِيذنْ ن يَاهُوذَا ذ مَارَّا يَاهُوذَا ذ مَارَّا إِمزْذَاغْ ن ؤُرْشَالِيمْ إِنِّي إِتَّاذْفنْ زِي ثوُّورَا-يَا.‘  
\v 21 أَمُّو إِ إِقَّارْ سِيذِي: ’حْضَامْ خْ إِخفْ نْومْ أَذْ ثَارْبُومْ ڒحْمڒْ ذڭْ وَاسّْ ن سّبْثْ ؤُ أَذْ ث ثسِّيذْفمْ زِي ثوُّورَا ن ؤُرْشَالِيمْ! \x ◘ \xo 17:‏21 \xt نَاح. 13‏:‏19\x*  
\v 22 ذڭْ وَاسّْ ن سّبْثْ وَارْ ثسُّوفُّوغمْ شَا ؤُڒَا ذ إِجّْ ن ڒحْمڒْ زِي ثُوذْرِينْ نْومْ ؤُ وَارْ ثتّڭّمْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ. كنِّيوْ أَذْ ثسّْقدّْسمْ أَسّْ ن سّبْثْ أَمْ مَامّشْ وصِّيغْ بَابَاثْومْ.‘ \x ◘ \xo 17:‏22 \xt ؤُف. 20‏:‏8؛ 23‏:‏12؛ 31‏:‏13؛ حِز. 20‏:‏12\x*  
\v 23 \add مَاشَا\add* نِيثْنِي وَارْ سْڒِينْ شَا ؤُ وَارْ ذ أَيِي وْشِينْ أَمزُّوغْ نْسنْ، نِيثْنِي \add مَاشَا\add*غنَّانْ أَيِي، مَاحنْذْ وَارْ سْڒِينْ ؤُ وَارْ كْسِينْ أَودّبْ.“ \x ◘ \xo 17:‏23 \xt إِرْم. 11‏:‏10؛ 13‏:‏10؛ 16‏:‏12\x*   
\b  
\m
\v 24 ”مَاڒَا ثسْڒِيمْ-د غَارِي مْلِيحْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَذْ يِيڒِي ڒَامِي وَارْ ثسِّيذْفمْ ڒحْمڒْ زِي ثوُّورَا ن ثنْذِينْثْ-أَ ؤُ ڒَامِي إِ غَا ثسّْقدّْسمْ أَسّْ ن سّبْثْ، وَارْ ذَايسْ ثتّڭّمْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ،  
\v 25 \add خنِّي\add* أَذْ أَذْفنْ إِجدْجِيذنْ ذ ڒْحُوكَّامْ نِّي إِقِّيمنْ خْ ڒْعَارْشْ ن ذَاوُوذْ زِي ثوُّورَا ن ثنْذِينْثْ-أَ، أَمْ ندّْهنْ إِكَارُّوثنْ ذ إِيْسَانْ، نِيثْنِي ذ ڒْحُوكَّامْ نْسنْ، إِرْيَازنْ ن يَاهُوذَا ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ. \add خنِّي\add* ثَانْذِينْثْ-أَ أَذْ ذَايسْ قِّيمنْ زدّْغنْ إِمزْذَاغْ نّسْ إِ ڒبْذَا. \x ◘ \xo 17:‏25 \xt إِرْم. 22‏:‏4\x*  
\v 26 نِيثْنِي أَذْ د-أَسنْ زِي ثْندَّامْ ن يَاهُوذَا ؤُ زِي جّْوَايهْ إِ د-إِنّْضنْ إِ ؤُرْشَالِيمْ، ؤُ زِي ثمُّورْثْ ن بِينْيَامِينْ، ؤُ زِي ثمُّورْثْ إِوَاطَانْ، زِي ثمُّورْثْ ن إِذُورَارْ ؤُ زِي لْجَانُوبْ، نِيثْنِي أَذْ أَوْينْ ثَاغَارْصْثْ ن وشْمَاضْ ذ صّذْقثْ ن ثْغَارْصْثْ ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذ جَّاوِي ؤُشَا أَذْ أَوْينْ ثَاوْهِيبْثْ ن ؤُقَاذِي ذِي ثَادَّارْثْ ن سِيذِي.  
\v 27 \add مَاشَا\add* مَاڒَا كنِّيوْ وَارْ غَارِي ثتّسْڒِيمْ حِيمَا أَذْ ثسّْقدّْسمْ أَسّْ ن سّبْثْ ؤُ حِيمَا أَذْ ثَاذْفمْ زِي ثوُّورَا ن ؤُرْشَالِيمْ س إِجّْ ن ڒحْمڒْ ذڭْ وَاسّْ ن سّبْثْ، \add خنِّي\add* نشّْ أَذْ سَّارْغغْ إِشْثْ ن ثْمسِّي ذِي ثوُّورَا نّسْ نِّي إِ غَا إِشّنْ ڒقْصُورْ ن ؤُرْشَالِيمْ ؤُ وَارْ ڭُّورْعمَّارْصْ أَذْ ثخْسِي.“   
\b  
\b  
\m  
\c 18
\s1 إِرْمِييَا ذِي ثَادَّارْثْ ن ؤُقدَّارْ  
\m
\v 1 أَوَاڒْ نِّي د-يُوسِينْ زِي سِيذِي غَارْ إِرْمِييَا، إِنَّا:   
\m
\v 2 ”كَّارْ، هْوَا غَارْ ثَادَّارْثْ ن بُو-ثْڒَاخْثْ. ذِينِّي إِ غَا جّغْ أَوَاڒنْ إِنُو أَذْ تّْوَاسْڒنْ.“ \f ◼ \fr 18:‏2 \ft \+bd ’أَقدَّارْ‘\+bd* - نِيغْ ’بُو-ثْڒَاخْثْ‘.\f*  
\v 3 \add خنِّي\add* هْوِيغْ غَارْ ثَادَّارْثْ ن بُو-ثْڒَاخْثْ، ؤُشَا خْزَارْ، ؤُفِيغْ ث إِخدّمْ إِشْثْ ن ڒْقشْعثْ خْ إِژْرَا \add إِتّنّْضنْ\add*.  
\v 4 مَاڒَا إِخْسَارْ ؤُغَارَّافْ نِّي ثُوغَا إِتّڭّْ زِي ثْڒَاخْثْ نِّي إِدْجَانْ ذڭْ ؤُفُوسْ ن بُو-ثْڒَاخْثْ، نتَّا إِڭَّا زَّايسْ عَاوذْ إِجّْ ن ؤُغَارَّافْ نّغْنِي، أَمْ مَامّشْ ذ أَسْ إِتّْغِيڒْ ذ لمْلِيحْ إِ بُو-ثْڒَاخْثْ مَاحنْذْ أَذْ ث إِڭّْ.  
\v 5 \add خنِّي\add* يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:  
\v 6 ”مَا وَارْ زمَّارغْ نشّْ أَذْ ڭّغْ أَكِيذْومْ أَمْ بُو-ثْڒَاخْثْ وَانِيثَا، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. خْزَارْ، أَمْ ثْڒَاخْثْ ذڭْ ؤُفُوسْ ن بُو-ثْڒَاخْثْ، أَمُّو إِ ثدْجَامْ ذڭْ ؤُفُوسْ إِنُو، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل!\x ◘ \xo 18:‏6 \xt إِشا. 45‏:‏9؛ 64‏:‏8؛ رُوم. 9‏:‏20\x*  
\v 7 إِشْثْ ن ثْوَاڒَا أَذْ سِّيوْڒغْ خْ إِجّْ نْ ڒْڭنْسْ ؤُ خْ إِشْثْ ن ثْڭلْذِيثْ أَقَا أَذْ \add ث\add* قڒْعغْ، أَذْ \add ث\add* هذْمغْ ؤُ أَذْ \add ث\add* ثحِّيغْ، \x ◘ \xo 18:‏7 \xt إِرْم. 1‏:‏10\x*  
\v 8 \add مَاشَا\add* مَاڒَا ڒْڭنْسْ نِّي أَذْ د-إِذْوڒْ زِي ثُوعفّْنَا نّسْ إِ خْ سِّيوْڒغْ \add أَكِيذْسنْ\add*، \add خنِّي\add* أَذْ نذْمغْ زِي ڒْغَارْ إِ ثُوغَا نْوِيغْ أَذْ أَسْ ث ڭّغْ.  
\v 9 إِشْثْ ن ثْوَاڒَا نّغْنِي أَذْ سِّيوْڒغْ خْ إِجّْ نْ ڒْڭنْسْ ؤُ خْ إِشْثْ ن ثْڭلْذِيثْ بلِّي أَذْ \add ث\add* سّْبدّغْ ؤُ أَذْ \add ث\add* ژُّوغْ،  
\v 10 \add مَاشَا\add* مَاڒَا أَذْ يڭّْ مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ إِنُو ؤُمِي وَارْ تّسْڒِينْ غَارْ ثْمِيجَّا إِنُو، \add خنِّي\add* أَذْ نذْمغْ خْ مِينْ إِشْنَانْ إِ نِّيغْ أَذْ كِيذْسنْ ث ڭّغْ.  
\v 11 خنِّي ڒخُّو، سِيوڒْ أَكْ-ذ إِرْيَازنْ ن يَاهُوذَا ؤُ أَكْ-ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ، إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي: خْزَارْ، نشّْ سّْوجْذغْ إِجّْ نْ ڒْغَارْ ضِيدّْ نْومْ ؤُ نشّْ تّْخَارَّاصغْ ذڭْ إِجّْ ن ونْوَايْ خَاومْ. ذوْڒمْ-د خنِّي، كُوڒْ إِجّْ زڭْ وبْرِيذْ نّسْ أَعفَّانْ، ؤُعذْڒمْ إِبْرِيذنْ نْومْ ذ ثْمڭَّا نْومْ.‘ \x ◘ \xo 18:‏11 \xt 2 إِج. 17‏:‏13؛ إِرْم. 7‏:‏3؛ 25‏:‏5؛ 26‏:‏13؛ 35‏:‏15\x*  
\v 12 مَاشَا نِيثْنِي قَّارنْ: ’ڒَْايَاسْ وَالُو! نشِّينْ أَذْ نضْفَارْ إِنْوَاينْ \add ن يِيخفْ\add* نّغْ ؤُشَا أَذْ نڭّْ كُوڒْ إِجّْ عْلَاحْسَابْ ڒقْسَاحثْ ن وُوڒْ نّسْ!‘ “ \x ◘ \xo 18:‏12 \xt إِرْم. 2‏:‏25\x*   
\m
\v 13 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي: ’سقْسَامْ ڒڭْنُوسْ، مَانْ ونْ إِسْڒِينْ \add عمَّارْصْ\add* أَمْ وَا؟ ثَاعْزَارشْثْ إِسْرَائِيل ثڭَّا إِجّْ ن نّْعِي ذ أَمقّْرَانْ. \x ◘ \xo 18:‏13 \xt إِرْم. 2‏:‏10\x*  
\v 14 مَا أَذْ إِحيّذْعمَّارْصْ وذْفڒْ ن لُوبْنَانْ زڭْ إِشْثْ ن ثصْضَارْثْ ذڭْ إِيَّارْ؟ مَا أَذْ أَژْغنْ \add عمَّارْصْ\add* وَامَانْ إِتّْبُوقْبُوقنْ، إِسمَّاضنْ إِتَّازّْڒنْ؟  
\v 15 مَاشَا وَاخَّا أَمنِّي إِتُّو أَيِي ڒْڭنْسْ إِنُو. نِيثْنِي تَّاوْينْ ثِيوْهِيبِينْ ن ڒبْخُورْ إِ \add لْ-أَصْنَامْ\add* إِبطّْڒنْ إِنِّي ثنْ إِجِّينْ أَذْ نّْقَارْضنْ ذڭْ إِبْرِيذنْ نْسنْ، ذِي جُّورَاثْ ن وشْحَاڒْ ؤُيَا، مَاحنْذْ أَذْ ؤُيُورنْ ذڭْ إِزُوبَاقْ ن إِجّْ ن وبْرِيذْ وَارْ إِوِيطِينْ، \x ◘ \xo 18:‏15 \xt إِرْم. 2‏:‏32؛ 3‏:‏21؛ 6‏:‏16؛ 13‏:‏25\x*  
\v 16 مَاحنْذْ أَذْ أَرّنْ ثَامُّورْثْ نْسنْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ ذ ثْسضْحَاشْثْ إِ ڒبْذَا. قَاعْ ونِّي سّنِّي إِ غَا إِكّنْ، أَذْ إِنّخْڒعْ، أَذْ إِهزّْ أَزدْجِيفْ نّسْ. \x ◘ \xo 18:‏16 \xt إِرْم. 12‏:‏11؛ 19‏:‏8؛ 49‏:‏13؛ 50‏:‏13\x*  
\v 17 أَمْ ؤُسمِّيضْ ن مَانِيسْ إِ د-ثْنقَّارْ ثْفُوشْثْ أَذْ ثنْ زُوزَّارغْ زَّاثْ إِ ڒعْذُو. نشّْ أَذْ أَسنْ سّشْنغْ أَعْرُورْ، وَارْ إِدْجِي ؤُذمْ \add إِنُو\add*، ذڭْ وَاسّْ ن ؤُهلّكْ نْسنْ.‘ “\x ◘ \xo 18:‏17 \xt إِشا. 27‏:‏8؛ 29‏:‏6؛ إِرْم. 4‏:‏11، 12، 13؛ 13‏:‏24\x*   
\b  
\m
\v 18 ”نِيثْنِي \add مَاشَا\add* نَّانْ: ’أَسمْ-د، جّمْ أَنغْ أَذْ نڭّْ ثَامعْمُوتْشْ خْ إِرْمِييَا، مَاغَارْ شَّارِيعَاعمَّارْصْ أَذْ إِقْضَا غَارْ ؤُكهَّانْ، شّْوَارْ غَارْ ؤُمِيغِيسْ ؤُ أَوَاڒْ غَارْ ؤُنَابِي. أَسمْ-د، أجّْ أَنغْ أَذْ ث نوّثْ س \add وَاوَاڒنْ ن\add* يِيڒسْ نّغْ ؤُشَا أجّْ أَنغْ وَارْ نتِّيشْ ثَايْنِيثْ إِ ؤُڒَا ذ إِجّْ زڭْ وَاوَاڒنْ إِ إِقَّارْ.‘ “ \x ◘ \xo 18:‏18 \xt إِرْم. 9‏:‏7؛ مـَال. 2‏:‏7\x*   
\b  
\m  
\s1 إِرْمِييَا ذِي ڒحْصَارثْ  
\m
\v 19 ”حْضَا أَيِي، \add أَ\add* سِيذِي، ؤُ سڒْ-د غَارْ ثْمِيجَّا ن يِينِّي أَكِيذِي إِتّْمنْغَانْ.  
\v 20 مَا \add خنِّي\add* أَذْ إِتّْوَاخْڒفْ مِينْ إِصبْحنْ س مِينْ وَارْ إِحْڒِينْ؟ مَاغَارْ نِيثْنِي غْزِينْ أَيِي إِشْثْ ن ثنْضتْشْ! إِذَارْ مَامّشْ بدّغْ زَّاثكْ حِيمَا أَذْ سِّيوْڒغْ ذِي ڒْخِيرْ نْسنْ، حِيمَا أَذْ خَاسنْ حيّْذغْ أَسْعَارْ نّشْ.  
\v 21 س ؤُيَا، أوْشْ إِحنْجِيرنْ نْسنْ إِ ڒَاژْ ؤُشَا سلّمْ إِ-ثنْ إِ ثْزمَّارْ ن سِّيفْ ؤُشَا أجّْ ثِيمْغَارِينْ نْسنْ أَذْ أَسنْثْ أَشَارنْ إِحنْجِيرنْ، أَذْ ذوْڒنْثْ ذ ثِيجَّاڒْ، أجّْ إِرْيَازنْ نْسنْثْ أَذْ تّْوَانْغنْ ؤُ إِحُوضْرِييّنْ نْسنْثْ أَذْ مّْثنْ س سِّيفْ ذڭْ ؤُمنْغِي. \x ◘ \xo 18:‏21 \xt إِزهد. 109‏:‏10\x*  
\v 22 أجّْ أَذْ ثتّْوَاسڒْ ثْغُويِّيثْ زِي ثُوذْرِينْ نْسنْ، مَاڒَا شكْ ذغْيَا ثْغضْرذْ-د خَاسنْ إِشْثْ ن بَانْذِييَّا ؤُمِي غْزِينْ إِشْثْ ن ثنْضتْشْ حِيمَا أَذْ أَيِي طّْفنْ، ؤُ سَّارْسنْ ڒفْخُوخْ إِنُّوفَّارنْ إِ إِضَارنْ إِنُو.  
\v 23 \add أَ\add* سِيذِي، شكْ ثسّْنذْ مَارَّا أَنْوَايْ نْسنْ مَاحنْذْ أَذْ أَيِي نْغنْ. وَارْ سْذُورِييْ ڒْمُوعْصِييّثْ نْسنْ ؤُ وَارْ محِّي دّْنُوبْ نْسنْ زَّاثْ إِ وُوذمْ نّشْ، \add مَاشَا\add* أجّْ إِ-ثنْ أَذْ وْضَانْ زَّاثكْ. أڭّْ أَسنْ \add أَمُّو\add* ذِي ڒْوقْثْ ن وغْضَابْ نّشْ.“   
\b  
\b  
\m  
\c 19
\s1 أَرژِّيثْ ن ؤُرْشَالِيمْ ذ يَاهُوذَا أَمْ إِشْثْ ن ثْقدُّوحْثْ ن ثْڒَاخْثْ  
\m
\v 1 أَمُّو إِ إِقَّارْ سِيذِي: ”ؤُيُورْ ؤُشَا سغْ إِجّْ ن ؤُغَارَّافْ ن ثْڒَاخْثْ ؤُشَا أَوِي \add شَا زڭْ\add* إِمْغَارنْ ن ڒْڭنْسْ ؤُ زڭْ إِمْغَارنْ ن إِكهَّاننْ \add أَكِيذكْ\add*.  
\v 2 فّغْ غَارْ بَارَّا غَارْ ثغْزُورْثْ ن مِّيسْ ن هِينُّومْ، ثنِّي غَارْ وَاذَافْ ن ثوَّارْثْ ن إِشقْفَانْ، ؤُشَا بَارّحْ ذِينِّي أَوَاڒنْ نِّي إِ ذ أَشْ غَا إِنِيغْ،  
\v 3 إِنِي: ’سْڒمْ إِ وَاوَاڒْ ن سِيذِي، \add أَ\add* إِجدْجِيذنْ ن يَاهُوذَا ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ! أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: خْزَارْ، نشّْ أَذْ سِّيوْضغْ إِشْثْ ن ثشْثِي \add ثَامقّْرَانْثْ\add* خْ ومْشَانْ-أَ، مَاحنْذْ ن مَارَّا نِّي ت غَا إِسْڒنْ، أَذْ طْنطْننْ إِمزُّوغنْ، \x ◘ \xo 19:‏3 \xt 1 صم. 3‏:‏11؛ 2 إِج. 21‏:‏12\x*  
\v 4 مَاغَارْ نِيثْنِي حيّْذنْ خَافِي، أَرِّينْ أَمْشَانْ-أَ \add ذ إِجّْ ن ومْشَانْ\add* إِ إِبَارَّانِييّنْ ؤُشَا قدّْمنْ ثِيوْهِيبِينْ ن ڒبْخُورْ إِ إِربِّيثنْ نّغْنِي نِّي وَارْ سِّيننْ، وَارْ إِدْجِي نِيثْنِي ؤُڒَا ذ إِبَابَاثنْ نْسنْ ذ إِجدْجِيذنْ ن يَاهُوذَا. نِيثْنِيعمَّارنْ أَمْشَانْ-أَ س إِذَامّنْ ن إِمزْذَاڭنْ. \x ◘ \xo 19:‏4 \xt إِشا. 65‏:‏11؛ إِرْم. 2‏:‏13، 17، 19؛ 5‏:‏7، 19؛ 7‏:‏6؛ 15‏:‏6؛ 17‏:‏13\x*  
\v 5 مِينْزِي نِيثْنِي سّْبدّنْ ڒڭْعُوذِي \add مَانِي تّْوهّْبنْثْ دّْبَايحْ نْسنْ\add* إِ بَاعْلْ، حِيمَا أَذْ سّْشمْضنْ إِحنْجِيرنْ نْسنْ س ثْمسِّي، أَمْ ثْغَارْصَا ن وشْمَاضْ إِ بَاعْلْ، مِينْ وَارْ \add ذ أَسنْ\add* ؤُمُورغْ ذ مِينْ وَارْ \add غَارْسنْ\add* سِّيوْڒغْ ذ مِينْعمَّارْصْ وَارْ \add ث\add* ڭِّيغْ ذڭْ وُوڒْ إِنُو.‘ “   
\m
\v 6 ”س ؤُيَا، خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، وَارْ ذَايْسنْ قَّارنْ عَاذْ إِ ومْشَانْ-أَ ’ثُوفَاثْ‘ نِيغْ ’ثَاغْزُورْثْ ن مِّيسْ ن هِينُّومْ‘، مَاشَا ’ثَاغْزُورْثْ ن ونْغَايْ‘. \x ◘ \xo 19:‏6 \xt إِرْم. 7‏:‏32\x*  
\v 7 مَاغَارْ أَذْ سّْبطّْڒغْ إِنْوَاينْ ن يَاهُوذَا ذ ؤُرْشَالِيمْ ذڭْ ومْشَانْ-أَ ؤُ أَذْ ثنْغضْڒغْ زَّاثْ إِ وُوذمْ ن ڒْعذْيَانْ نْسنْ س سِّيفْ ؤُ س ؤُفُوسْ ن يِينِّي يَارزُّونْ ثُوذَارْثْ نْسنْ. نشّْ أَذْ وْشغْ ڒْخشْبَاثْ نْسنْ ذ مَاشَّا إِ إِجْضَاضْ ن ؤُجنَّا ؤُ إِ ڒْمَاڒْ ن ثمُّورْثْ. \f ◼ \fr 19:‏7 \ft \+bd ’ثُوذَارْثْ نْسنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ نْسنْ‘.\f*  \x ◘ \xo 19:‏7 \xt إِرْم. 15‏:‏3؛ 16‏:‏4\x*  
\v 8 نشّْ أَذْ أَرّغْ ثَانْذِينْثْ-أَ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ ذ ثْسضْحَاشْ. كُوڒْ إِجّْ ونِّي خَاسْ د غَا إِكّنْ أَذْ إِنّخْڒعْ ؤُ أَذْ إِصفَّارْ \add س أَسْرُوبِي\add* خْ مَارَّا جّْعَايفْ نّسْ.  
\v 9 نشّْ أَذْ أَسنْ ڭّغْ أَذْ شّنْ أَيْسُومْ ن إِحنْجِيرنْ نْسنْ ذ ويْسُومْ ن يسِّيثْسنْ. نِيثْنِي أَذْ شّنْ، كُوڒْ إِجّْ أَيْسُومْ ن جَّارْ نّسْ، ذِي \add ڒْوقْثْ نِّي ذِي\add* غَا قُووَّارنْ إِ ثنْذِينْثْ، ذِي ڒحْصَارثْ إِ زِي ثنْ إِ غَا حْصَارنْ ڒْعذْيَانْ نْسنْ ذ يِينِّي يَارزُّونْ ثُوذَارْثْ نْسنْ.“\f ◼ \fr 19:‏9 \ft \+bd ’ثُوذَارْثْ نْسنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ نْسنْ‘.\f*  \x ◘ \xo 19:‏9 \xt لَاوِي 26‏:‏29؛ أَعَوذ. 28‏:‏53؛ إِڭجذ. 4‏:‏10\x*  
\v 10 \add خنِّي\add* إِتّْخصَّا أَشْ أَذْ ثَارْژذْ أَغَارَّافْ جَارْ ثِيطَّاوِينْ ن يرْيَازنْ نِّي أَكِيذكْ يُويُورنْ.  
\v 11 إِتّْخصَّا أَذْ أَسنْ ثِينِيذْ: ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: ’أَمُّو إِ غَا أَرْژغْ ڒْڭنْسْ-أَ ذ ثنْذِينْثْ-أَ، أَمْ مَامّشْ تَّارژَّانْ إِجّْ ن ؤُغَارَّافْ ن بُو-ثْڒَاخْثْ نِّي وَارْ إِزمَّارنْ أَذْ ثعذْڒنْ عَاذْ. نِيثْنِي أَذْ ثنْ نضْڒنْ ذِي ثُوفَاثْ ؤُمِي وَارْ ذِينْ إِقِّيمْ ومْشَانْ مَانِي غَا نضْڒنْ. \f ◼ \fr 19:‏11 \ft \+bd ’أَقدَّارْ‘\+bd* - نِيغْ ’بُو-ثْڒَاخْثْ‘.\f*  \x ◘ \xo 19:‏11 \xt إِرْم. 7‏:‏32\x*  
\v 12 أَمُّو إِ غَا ڭّغْ زڭْ ومْشَانْ-أَ ؤُ زڭْ إِمزْذَاغْ نّسْ، إِقَّارْ سِيذِي، حِيمَا أَذْ أَرّغْ ثَانْذِينْثْ-أَ أَمْ ثُوفَاثْ.  
\v 13 ثُوذْرِينْ ن ؤُرْشَالِيمْ ذ ثُوذْرِينْ ن إِجدْجِيذنْ ن يَاهُوذَا أَذْ ذوْڒنْثْ خمْجنْثْ أَمْ ومْشَانْ ن ثُوفَاثْ، زِي سِّيبّثْ ن مَارَّا ثُوذْرِينْ إِ زِي خْ ثْزغْوِينْ نْسنْثْ قدّْمنْ نِيثْنِي ڒبْخُورْ إِ مَارَّا ڒْعسْكَارْ ن ؤُجنَّا ذ ثوْهِيبِينْ ن ؤُسيّبْ إِ إِربِّيثنْ نّغْنِي.‘ “ \x ◘ \xo 19:‏13 \xt إِرْم. 7‏:‏18\x*   
\b  
\m
\v 14 ؤُمِي د-إِعْقبْ إِرْمِييَا زِي ثُوفَاثْ، مَانِي ثُوغَا ث إِسّكّْ سِيذِي مَاحنْذْ أَذْ إِنبَّا، يُويُورْ ذِي ڒمْرَاحْ ن زَّاثْ ن ثَادَّارْثْ ن سِيذِي ؤُشَا إِنَّا إِ ڒْڭنْسْ مَارَّا:  
\v 15 ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’خْزَارْ، نشّْ أَذْ سِّيوْضغْ خْ ثنْذِينْثْ-أَ ؤُ خْ مَارَّا ثِيندَّامْ نّسْ مَارَّا ڒْغَارْ نِّي خْ سِّيوْڒغْ، مِينْزِي نِيثْنِي منْعنْ ثَاغنَّانْثْ أَمْ ؤُڭِينْ أَذْ سْڒنْ غَارْ وَاوَاڒنْ إِنُو.‘ “ \x ◘ \xo 19:‏15 \xt إِرْم. 7‏:‏26؛ 17‏:‏23\x*   
\b  
\b  
\m  
\c 20
\s1 إِرْمِييَا ذ ڒْعذْيَانْ نّسْ  
\m
\v 1 \add ڒَْامِي\add* فَاشْحُورْ، مِّيسْ ن إِمِّيرْ، أَكهَّانْ نِّي إِتّْوَاڭّنْ ذ أَوقَّافْ أَمقّْرَانْ خْ ثَادَّارْثْ ن سِيذِي، إِسْڒَا إِ إِرْمِييَا إِتّْنبَّا أَوَاڒنْ-أَ،  
\v 2 إِوْثَا فَاشْحُورْ أَنَابِي إِرْمِييَا ؤُشَا إِحبّسْ إِ-ث ذڭْ ؤُكشُّوضْ نِّي إِدْجَانْ ذڭْ وخَّامْ ن سنّجْ ن ثوَّارْثْ يُوعْڒَانْ ن بِينْيَامِينْ نِّي \add إِدْجَانْ\add* ذِي ثَادَّارْثْ ن سِيذِي.   
\m
\v 3 ثِيوشَّا نّسْ إِجَّا فَاشْحُورْ أَذْ أَرْخُونْ إِ إِرْمِييَا زڭْ ؤُكشُّوضْ. \add خنِّي\add* إِنَّا أَسْ إِرْمِييَا: ”وَارْ ذ أَشْ إِقَّارْ سِيذِي فَاشْحُورْ، مَاشَا مَاجُورْ-مِيسَّابِيبْ. \f ◼ \fr 20:‏3 \ft \+bd ’فَاشْحُورْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’سْڒَامْ‘ نِيغْ ’ثِيڒلِّي‘. \+bd ’مَاجُورْ-مِيسَّابِيبْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَنخْڒِيعْ زِي مَارَّا إِغزْذِيسنْ‘.\f*  
\v 4 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: ’خْزَارْ، نشّْ أَذْ شكْ ڭّغْ ذ أَسْنخْڒِيعْ إِ يِيخفْ نّشْ ؤُ إِ مَارَّا إِنِّي شكْ إِتّخْسنْ. نِيثْنِي أَذْ وْضَانْ س سِّيفْ ن ڒْعذْيَانْ نْسنْ، أَمْ ث تّْوَاڒَانْثْ ثِيطَّاوِينْ نّشْ، ؤُ نشّْ أَذْ وْشغْ مَارَّا يَاهُوذَا ذڭْ إِفَاسّنْ ن ؤُجدْجِيذْ ن بَابِيلْ نِّي ثنْ إِ غَا إِنذْهنْ ذِي ثْمحْبَاسْثْ غَارْ بَابِيلْ ؤُ أَذْ ثنْ إِنغْ س سِّيفْ.  
\v 5 مَارَّا أَڭْڒَا ن ثنْذِينْثْ-أَ أَذْ ثنْ سلّْمغْ ؤُ مَارَّا مِينْ ذَايسْ إِغْڒَانْ ذ مَارَّا ثِيخُوبَا ن إِجدْجِيذنْ ن يَاهُوذَا أَذْ ڭّغْ أَيَا \add مَارَّا\add* ذڭْ ؤُفُوسْ ن ڒْعذْيَانْ نْسنْ. نِيثْنِي أَذْ ثنْ أَشَارنْ، أَذْ ثنْ كْسِينْ \add أَكِيذْسنْ\add* ؤُشَا أَذْ ثنْ إِ-د-أَوْينْ غَارْ بَابِيلْ. \x ◘ \xo 20:‏5 \xt إِرْم. 15‏:‏13؛ 17‏:‏3\x*  
\v 6 شكْ، فَاشْحُورْ، ذ مَارَّا أَيْثْ ن ثَادَّارْثْ نّشْ، كنِّيوْ أَذْ ثفّْغمْ ذ إِمحْبَاسْ. شكْ أَذْ د-ثَاوْضذْ غَارْ بَابِيلْ ؤُشَا أَذْ ثمّْثذْ ذِينِّي ؤُشَا أَذْ تّْوَانضْڒذْ ذِينِّي، شكْ ذ مَارَّا إِمدُّوكَّاڒْ نّشْ إِنِّي ؤُمِي ثْنبِّيذْ س إِخَارِّيقنْ.‘ “   
\b  
\m
\v 7 ”شكْ ثْجبْذذْ أَيِي، \add أَ\add* سِيذِي، ؤُشَا نشّْ تّْوَاسّْقنْعغْ. شكْ ثْجهْذذْ خَافِي أَطَّاسْ، ثْغڒْبذْ أَيِي. أَسّْ مَارَّا تّْغِيمَانْ ذحّْشنْ ذَايِي، مَارَّا إِذْسنْ سْثهْزَانْ زَّايِي.  
\v 8 مَاغَارْ مڒْمِي مَا سِّيوْڒغْ، سْغُويُّوغْ ’ڒخْشُونشْثْ!‘، ڒَاغِيغْ ’أَنخْڒِيعْ!‘، مَاغَارْ أَوَاڒْ ن سِيذِي إِتَّاوِي أَيِي-د أَسّْ إِمُونْ مْغِيرْ أَسحْقَارْ ذ ؤُسْثهْزِي. \x ◘ \xo 20:‏8 \xt إِشا. 57‏:‏4\x*  
\v 9 نِّيغْ: ’نشّْ وَارْ ث تِّيذَارغْ \add عَاذْ\add* ؤُ وَارْ سِّيوِيڒغْ \add عَاذْ\add* س يِيسمْ نّسْ!‘، \add خنِّي\add* إِذْوڒْ أَيَا ذڭْ وُوڒْ إِنُو أَمْ يِيشْثْ ن ثْمسِّي يَارقّنْ، ثتّْوَاحْبسْ ذڭْ إِغْسَانْ إِنُو. نشّْ سَّاحَاڒغْ إِخفْ إِنُو مَاحنْذْ أَذْ صْبَارغْ، مَاشَا وَارْ ذ أَسْ زمَّارغْ.  
\v 10 مَاغَارْ سْڒِيغْ أَشقّفْ س ڒْهَارْذْ ن وَاطَّاسْ: ’مَاجُورْ-مِيسَّاسِيبْ‘، \add ’أَسِيڭّْوذْ زِي مَارَّا إِغزْذِيسنْ!‘\add*، أَمُّو إِ قَّارنْ. ؤُشَا خنِّي قَّارنْ: ’سَارْڭبْ أَنغْ!، \add خنِّي\add* نشِّينْ أَذْ \add زَّايسْ\add* نْبَارّحْ!‘ كُوڒْ أَرْيَازْ أَكْ-ذ دَّارغْ ذِي ڒهْنَا، إِتّْرَاجَا أَڒْ غَا نْقَارْضغْ. \add قَّارنْ:\add* ’أَذْ ثَاغْ نْزمَّارْ أَذْ ث نغْوَا، خنِّي أَذْ ث نغْڒبْ ؤُشَا أَذْ زَّايسْ نخْڒفْ.‘ “   
\b  
\m
\v 11 ”سِيذِي إِبدّْ أَكِيذِي أَمْ يِيجّْ ن بُو-ثغْرُوضْثْ ذ أَمقّْرَانْ، خْ ؤُيَا إِ غَا نّْقَارْضنْ إِنِّي ذ أَيِي إِضَافَّارنْ، وَارْ زمَّارنْ أَذْ ڭّنْ وَالُو. نِيثْنِي أَذْ سضْحَانْ س يِيخفْ نْسنْ أَطَّاسْ، مِينْزِي وَارْ ڭِّينْ س ڒعْقڒْ. أَذْ ثِيڒِي ذ إِشْثْ ن ڒفْضِيحثْ إِ ڒبْذَا إِ وَارْ تّتُّونْ إِ ڒبْذَا. \x ◘ \xo 20:‏11 \xt إِرْم. 1‏:‏8، 19؛ 15‏:‏20؛ 17‏:‏18؛ 23‏:‏40\x*  
\v 12 \add شكْ\add*، \add أَ\add* سِيذِي ن ڒْعسْكَارَاثْ، ونِّي إِتّْقدْجَابنْ أَمْسڭّذْ، ونِّي إِتّْوَاڒَانْ ثِيژَّاڒْ ذ وُوڒْ، سْشنْ أَيِي نّقْمثْ نّشْ خَاسنْ، مَاغَارْ نشّْ ڭِّيغْ أَشْ ثَاغَاوْسَا إِنُو ذڭْ ؤُفُوسْ.“ \x ◘ \xo 20:‏12 \xt إِرْم. 11‏:‏20؛ 12‏:‏3؛ 15‏:‏15؛ 18‏:‏19‏-‏23\x*   
\b  
\m
\v 13 ”زهّْذمْ إِ سِيذِي، سمْغَارمْ سِيذِي، مَاغَارْ نتَّا إِفكّْ أَمزْڒُوضْ زڭْ ؤُفُوسْ ن إِعفَّاننْ.“   
\b  
\m
\v 14 ”أَقَا إِتّْوَانْعڒْ أَسّْ إِ ذِي د-تّْوَارْوغْ! أَسّْ إِ ذ أَيِي د-ثُورُو يمَّا وَارْ إِتِّيڒِي إِتّْوَابَاركْ. \x ◘ \xo 20:‏14 \xt إِرْم. 15‏:‏10\x*  
\v 15 إِتّْوَانْعڒْ ورْيَازْ نِّي د-يِيوْينْ ڒخْبَارْ أَصبْحَانْ إِ بَابَا، إِنَّا: ’أَقَا إِتّْوَارُووْ أَشْ-د ؤُحنْجِيرْ!‘ ؤُشَا إِسّْفَارْحْ إِ-ث \add أَمُّو\add* س وَاطَّاسْ. \x ◘ \xo 20:‏15 \xt أَيُوبْ 3‏:‏3\x*  
\v 16 أجّْ أَرْيَازْ نِّي أَذْ يِيڒِي أَمْ ثْندَّامْ نِّي إِسّْنقْڒبْ سِيذِي بْڒَا مَا إِنْذمْ زِي مَانْ أَيَا. أجّْ إِ-ث أَذْ إِسڒْ إِ إِغُويَّانْ \add ن ڒحْرِيقْ\add* غَارْ ثفُّوثْ ؤُ إِغُويَّانْ \add ن ؤُمنْغِي\add* غَارْ طّْيَا ن وَاسّْ، \x ◘ \xo 20:‏16 \xt أَمز. 19\x*  
\v 17 مِينْزِي نتَّا وَارْ ذ أَيِي إِنْغِي ذڭْ ؤُعذِّيسْ ن يمَّا. أَمُّو ثذْوڒْ يمَّا ذ أَنْضڒْ إِنُو ؤُشَا إِقِّيمْ ؤُعذِّيسْ نّسْ إِكْسِي س دّيْسثْ إِ ڒبْذَا!  
\v 18 مَايمِّي إِ د-فّْغغْ زڭْ ؤُعذِّيسْ؟ مَا حِيمَا أَذْ ژَترغْ ثَامَارَا ذ وشْضَانْ \add وَاهَا\add* ؤُ حِيمَا أَذْ قْضِيغْ ؤُسَّانْ إِنُو ذِي ڒفْضِيحثْ؟“ \x ◘ \xo 20:‏18 \xt أَيُوبْ 3‏:‏20\x*   
\b  
\b  
\m  
\c 21
\s1 أَسكِّي أَمزْوَارُو ن ؤُجدْجِيذْ صِيذْقِييَا غَارْ إِرْمِييَا  
\m
\v 1 أَوَاڒْ نِّي د-إِفّْغنْ زِي سِيذِي غَارْ إِرْمِييَا، ؤُمِي أَجدْجِيذْ صِيذْقِييَا إِسّكّْ غَارسْ فَاشْحُورْ، مِّيسْ ن ؤُكهَّانْ مَالْكِييَا، ذ صَافَانْيَا، مِّيسْ ن ؤُكهَّانْ مَاعَاسِييَا، إِنَّا: \f ◼ \fr 21:‏1 \ft \+bd ’صَافَانْيَا‘\+bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي ث إِسّْنُوفَّارنْ سِيذِي‘.\f*  
\v 2 ”سقْسَا مَاشَا سِيذِي خَانغْ، مَاغَارْ نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، إِتّْمنْغَا أَكِيذْنغْ. أَذْ ثَاغْ سِيذِي أَذْ ذَايْنغْ إِڭّْ إِشْثْ ن لْمُوعْجِيزَا أَمْ مَامّشْ مَارَّا لْمُوعْجِيزَاثْ نّسْ، مَاحنْذْ أَذْ خَانغْ إِحيّذْ \add نابُوخَاذْرَاصَّارْ\add*.“   
\m
\v 3 \add خنِّي\add* إِنَّا أَسنْ إِرْمِييَا: ”أَمُّو إِ غَا ثِينِيمْ إِ صِيذْقِييَا:  
\v 4 ’أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: خْزَارْ، نشّْ أَذْ سّنْقڒْبغْ ذڭْ إِفَاسّنْ نْومْ ڒسْنَاحْ إِ زِي تّْمنْغَامْ أَكْ-ذ ؤُجدْجِيذْ ن بَابِيلْ ذ إِكَالْذَانِييّنْ، إِنِّي ذ أَومْ د-إِنّْضنْ بَارَّا إِ ڒْحِيضْ، ؤُ نشّْ أَذْ ثنْ سّْمُونغْ ذِي ڒْوسْطْ ن ثنْذِينْثْ-أَ.  
\v 5 نشّْ سِيمَانْثْ إِنُو أَذْ كِيذْومْ منْغغْ س ؤُفُوسْ إِسّْوِيژّْضنْ ذ ؤُغِيڒْ إِجهْذنْ، س وغْضَابْ ذ وسْعَارْ ؤُ س ؤُذُوقّزْ أَمقّْرَانْ \add ن وغْضَابْ\add*.  
\v 6 نشّْ أَذْ وْثغْ إِمزْذَاغْ ن ثنْذِينْثْ-أَ، أَمْ إِوْذَانْ ؤُڒَا ذ ڒْمَارْ: نِيثْنِي أَذْ مّْثنْ س إِجّْ ن طَّاعُونْ أَمقّْرَانْ.  
\v 7 أَوَارْنِي أَسْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، نشّْ أَذْ سّعْذُوغْ صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ذ إِمْسخَّارنْ نّسْ ذ ڒْڭنْسْ نّسْ نِّي إِقِّيمنْ ذِي ثنْذِينْثْ-أَ زِي طَّاعُونْ، زِي سِّيفْ ؤُ زِي ڒَاژْ، ذڭْ ؤُفُوسْ ن نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ذڭْ ؤُفُوسْ ن ڒْعذْيَانْ نْسنْ ؤُ ذڭْ ؤُفُوسْ ن يِينِّي يَارزُّونْ ثُوذَارْثْ نْسنْ. نتَّا أَذْ ثنْ إِنغْ س ڒقْضعْ ن سِّيفْ ؤُ نتَّا وَارْ إِتّْحِينِّي، وَارْ إِسّْعِيزِّي ؤُ وَارْ يَارحّمْ.‘ “   
\b  
\m
\v 8 \bd ”إِ ڒْڭنْسْ-أَ أَذْ ثِينِيذْ\bd*: ’أَمُّو إِ إِقَّارْ سِيذِي: خْزَارْ، نشّْ ڭِّيغْ أَومْ أَبْرِيذْ ن ثُوذَارْثْ ذ وبْرِيذْ ن ڒْموْثْ.  
\v 9 ونِّي إِ غَا إِقِّيمنْ ذِي ثنْذِينْثْ-أَ، أَذْ إِتّْوَانغْ س سِّيفْ، س ڒَاژْ نِيغْ س طَّاعُونْ، \add مَاشَا\add* ونِّي زَّايسْ إِ غَا إِفّْغنْ ؤُشَا أَذْ إِعْذُو غَارْ إِكَالْذَانِييّنْ إِنِّي كنِّيوْ إِحصَّارنْ، أَذْ إِقِّيمْ إِدَّارْ ؤُشَا ڒعْمَارْ نّسْ أَذْ أَسْ يِيڒِي أَمْ ثْكشَّاضْثْ. \x ◘ \xo 21:‏9 \xt إِرْم. 38‏:‏2\x*  
\v 10 مَاغَارْ نشّْ أَرِّيغْ-د س وُوذمْ إِنُو ضِيدّْ إِ ومْشَانْ-أَ، وَارْ إِدْجِي إِ ڒْخَارْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. أَمْشَانْ-أَ أَذْ إِتّْوَاسّعْذُو ذڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن بَابِيلْ ؤُ نتَّا أَذْ أَسْ إِقّذْ ثِيمسِّي.‘ “   
\b  
\m
\v 11 \bd زِي جِّيهثْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ ن يَاهُوذَا\bd*، سْڒمْ إِ وَاوَاڒْ ن سِيذِي:  
\v 12 ”\add أَ\add* ثَادَّارْثْ ن ذَاوُوذْ، أَمُّو إِ إِقَّارْ سِيذِي: ’سڭّْذمْ نِيشَانْ ذِي ثفُّوثْ، فكّمْ ونِّي إِتّْوَاكشّْضنْ زڭْ ؤُفُوسْ ن ونِّي إِحصَّارنْ، نِيغْ أَذْ يَارّژْ وسْعَارْ إِنُو أَمْ ثْمسِّي أَڒَامِي وَارْ إِزمَّارْ ؤُڒَا ذ إِجّْ أَذْ ت إِسّخْسِي عَاذْ زِي سِّيبّثْ ن ثْمڭَّا نْومْ ثِيعفَّانِينْ. \x ◘ \xo 21:‏12 \xt إِرْم. 22‏:‏3\x*  
\v 13 خْزَارْ، أَذْ شمْ ڒقْفغْ، \add شمْ\add* ثنِّي إِزدّْغنْ ذِي ثيْسَارْثْ، \add شمْ\add*، \add أَ\add* ثَاصْضَارْثْ ن ڒْوَاطَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. كنِّيوْ ثقَّارمْ: مَانْ ونْ إِزمَّارنْ أَذْ غَارْنغْ د-إِهْوَا، مَانْ ونْ إِزمَّارنْ أَذْ د-يَاذفْ غَارْ ثْزذِّيغِينْ نّغْ؟  
\v 14 نشّْ أَذْ كنِّيوْ عَاقْبغْ عْلَاحْسَابْ ڒْغِيدْجثْ ن ثْمڭَّا نْومْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. نشّْ أَذْ ڭّغْ ثِيمسِّي ذڭْ وزْغَارْ نّسْ نِّي إِ غَا إِشّنْ مَارَّا مِينْ ذ أَسْ د-إِنّْضنْ.‘ “ \f ◼ \fr 21:‏14 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  \x ◘ \xo 21:‏14 \xt إِرْم. 17‏:‏27\x*   
\b  
\b  
\m  
\c 22
\m
\v 1 ”أَمُّو إِ إِقَّارْ سِيذِي: ’هْوَا غَارْ ثَادَّارْثْ ن ؤُجدْجِيذْ ن يَاهُوذَا، إِنِي ذِينْ أَوَاڒْ-أَ،  
\v 2 أَذْ ثِينِيذْ: \add أَ\add* أَجدْجِيذْ ن يَاهُوذَا، ونِّي إِقِّيمنْ خْ ڒْعَارْشْ ن ذَاوُوذْ، سڒْ إِ وَاوَاڒْ ن سِيذِي، شكْ ذ إِمْسخَّارنْ نّشْ ذ ڒْڭنْسْ نّشْ إِ إِتَّاذْفنْ زِي ثوُّورَا-يَا!  
\v 3 أَمُّو إِ إِقَّارْ سِيذِي: ڭّمْ ڒْحقّْ ذ ثْسڭْذَا ؤُ سّْنجْممْ مِينْ إِتّْوَاكشّْضنْ زڭْ ؤُفُوسْ ن ونِّي إِحصَّارنْ. وَارْ حصَّارمْ، وَارْ شَّاثمْ ڒْبَارَّانِي ذ ؤُيُوجِيڒْ ذ ثَاجَّاتْشْ. وَارْ سِّيزِّيڒمْ إِذَامّنْ إِمزْذَاڭنْ ذِي ثمُّورْثْ-أَ! \x ◘ \xo 22:‏3 \xt إِرْم. 7‏:‏6؛ 21‏:‏12\x*  
\v 4 مَاڒَا كنِّيوْ أَذْ ثڭّمْ أَوَاڒْ-أَ س ثِيذتّْ، \add خنِّي\add* أَذْ أَذْفنْ إِجدْجِيذنْ زِي ثوُّورَا ن ثنْذِينْثْ-أَ، إِنِّي إِ غَا إِقِّيمنْ غَارْ ذَاوُوذْ خْ ڒْعَارْشْ نّسْ، إِنِّي إِ غَا إِنذْهنْ إِكَارُّوثنْ ذ ييْسَانْ، \add وَاهْ،\add* نتَّا ذ إِمْسخَّارنْ نّسْ ذ ڒْڭنْسْ نّسْ. \x ◘ \xo 22:‏4 \xt إِرْم. 17‏:‏25؛ حِز. 37‏:‏25. \x*  
\v 5 مَاڒَا وَارْ ثسْڒِيمْ شَا غَارْ وَاوَاڒنْ-أَ، أَقَا جُّودْجغْ إِ يِيخفْ إِنُو، \add أَمُّو\add* إِقَّارْ سِيذِي، أَذْ ثذْوڒْ ثَادَّارْثْ-أَ ذ ڒْخِيرْبثْ.‘ “   
\m
\v 6 ”مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي خْ ثَادَّارْثْ ن ؤُجدْجِيذْ ن يَاهُوذَا: ’\add وَاخَّا\add* شكْ ثُوسِيذْ أَيِي خْ ڒْخَاضَارْ أَمْ جِيلْعَاذْ ؤُ أَمْ ثْقِيشّثْ ن لُوبْنَانْ، ذ ثِيذتّْ أَذْ شكْ تّڭّغْ ذ ڒخْڒَا، ثِيندَّامْ وَارْ إِزْذِيغنْ. \x ◘ \xo 22:‏6 \xt زَاك. 10‏:‏10\x*  
\v 7 نشّْ أَذْ حُوزغْ ضِيدّْ نّشْ إِمْثحَّايّنْ، كُوڒْ إِجّْ س ڒسْنَاحْ نّسْ \add إِ ونْغَايْ\add*. نِيثْنِي أَذْ قسّنْ ثِيشجُّورَا نّشْ ن ثنْڭلْثْ إِ إِشْنَانْ أَطَّاسْ \add س شّْوَاقَارْ نْسنْ\add* ؤُشَا أَذْ \add ثنْثْ\add* وْشنْ إِ ثْمسِّي. \x ◘ \xo 22:‏7 \xt إِرْم. 15‏:‏6\x*  
\v 8 \add خنِّي\add* أَذْ د-كّنْ أَطَّاسْ ن ڒڭْنُوسْ خْ ثنْذِينْثْ-أَ، أَذْ إِنِينْ، كُوڒْ إِجّْ إِ ؤُمْقَارَّابْ نّسْ: مَايمِّي سِيذِي إِڭَّا أَمُّو إِ ثنْذِينْثْ-أَ ثَامقّْرَانْثْ؟ \x ◘ \xo 22:‏8 \xt أَعَوذ. 29‏:‏23؛ 1 إِج. 9‏:‏8\x*  
\v 9 أَذْ إِنِينْ: مِينْزِي نِيثْنِي سمْحنْ ذِي ڒْعَاهْذْ ن سِيذِي، أَربِّي نْسنْ، ؤُشَا سجْذنْ إِ إِربِّيثنْ نّغْنِي ؤُشَا ذوْڒنْعبّْذنْ أَسنْ.‘ “   
\b  
\m  
\s1 خْ شَالُّومْ  
\m
\v 10 ”وَارْ تّْرُومْ خْ ؤُمتِّينْ ؤُ وَارْ خَاسْ شَّاثمْ أَڭجْذُورْ. رُومْ خْ ونِّي يُويُورنْ، مَاغَارْ نتَّاعمَّارْصْ أَذْ د-إِعْقبْ،عمَّارْصْ أَذْ إِژَارْ عَاذْ ثَامُّورْثْ نّسْ مَانِي إِخْڒقْ.  
\v 11 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي خْ شَالُّومْ، مِّيسْ ن يُوشِييَا، أَجدْجِيذْ ن يَاهُوذَا، ونِّي إِذوْڒنْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ ن بَابَاسْ يُوشِييَا، \add شَالُّومْ\add* ونِّي د-إِفّْغنْ زڭْ ومْشَانْ-أَ: ’نتَّاعمَّارْصْ أَذْ د-إِعْقبْ ذِينِّي عَاذْ.  
\v 12 مَاغَارْ ذڭْ ومْشَانْ مَانِي ث نذْهنْ ذِي ثْمحْبَاسْثْ، \add ذِينِّي\add* إِ غَا إِمّثْ،عمَّارْصْ أَذْ إِژَارْ ثَامُّورْثْ-أَ عَاوذْ.‘ “   
\b  
\m  
\s1 خْ يَاهُويَاقِيمْ  
\m
\v 13 ”أَخيّبْ إِ ونِّي إِ غَا إِسّْبدّنْ ثَازذِّيغْثْ نّسْ س ڒْمُوعْصِييّثْ، ثِيغُورْفِينْ نّسْ س ڒْغشّْ، ونِّي إِسّْخدَّامنْ ونِّي ث يُوذْسنْ نهْڒَا أَخدْجصْ ؤُ وَارْ ذ أَسْ إِتِّيشْ ڒْمُونثْ نّسْ، \x ◘ \xo 22:‏13 \xt لَاوِي 19‏:‏13؛ أَعَوذ. 24‏:‏14، 15؛ حَاب. 2‏:‏9\x*  
\v 14 ونِّي إِقَّارنْ: ’نشّْ أَذْ سّْبدّغْ إِ يِيخفْ إِنُو إِشْثْ ن ثْزذِّيغْثْ يُوعْڒَانْ أَطَّاسْ س ثْغُورْفِينْ إِوسْعنْ.‘ \add خنِّي\add* أَذْ ذَايسْ إِڭّْ ثِيبُورْجَاثِينْ ؤُشَا أَذْ ت إِسقّفْ س ؤُكشُّوضْ ن ثْشجُّورَا ن ثنْڭلْثْ ؤُشَا أَذْ ت إِزوّقْ س ثِينْثَاثْ ثِيزڭّْوَاغِينْ.  
\v 15 مَا ثْحكّْمذْ أَمْ ؤُجدْجِيذْ ؤُمِي ثتّمْحِيزْوَارذْ زِي سِّيبّثْ ن ثْنڭْلِينْ؟ بَابَاشْ مَا وَارْ إِشِّي، مَا وَارْ إِسْوِي ؤُ مَا وَارْ إِڭِّي ڒْحقّْ ذ ثْسڭْذَا؟ نتَّا ثُوغَا مْلِيحْ خَاسْ خنِّي!  
\v 16 نتَّا إِحْكمْ ثَامسْڒَاشْثْ ن ونِّي إِتّْوَاحْصَارنْ ذ ؤُمزْڒُوضْ. ثُوغَا مْلِيحْ خَاسْ خنِّي. مَا أَيَا وَارْ إِخْسْ أَذْ يِينِي أَقَا بْنَاذمْ إِسّنْ أَيِي؟، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 17 مَاشَا ثِيطَّاوِينْ نّشْ ذ وُوڒْ نّشْ أَقَا ثنْ مْغِيرْ خْ ثِيزِي نّشْ وَاهَا، خْ إِذَامّنْ إِمزْذَاڭنْ مَاحنْذْ أَذْ ثنْ ثسِّيزّْڒذْ، ؤُ خْ دّدْجْ ذ ؤُبعّجْ، مَاحنْذْ أَذْ ثنْ ثڭّذْ.“   
\m
\v 18 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي خْ يَاهُويَاقِيمْ، مِّيسْ ن يُوشِييَا، أَجدْجِيذْ ن يَاهُوذَا: ’نِيثْنِي وَارْ خَاسْ شطّْننْ: أَخْ، ؤُمَا! نِيغْ: أَخْ، ؤُتْشْمَا! نِيثْنِي وَارْ شطّْننْ: أَخْ، سِيذِي! نِيغْ: أَخْ، لْعَاضِيمْ! \x ◘ \xo 22:‏18 \xt إِرْم. 16‏:‏4، 5، 6\x*  
\v 19 أَذْ نضْڒنْ س ونْضَاڒْ ن إِجّْ ن وغْيُوڒْ. أَذْ ث جَارّنْ ؤُ أَذْ ث نْضَارنْ غَارْ ڒَاڭّْوَاجْ، بَارَّا إِ ثِيوُّورَا ن ؤُرْشَالِيمْ.‘ “ \x ◘ \xo 22:‏19 \xt إِرْم. 15‏:‏3؛ 36‏:‏30\x*   
\b  
\m  
\s1 خْ كُونْ-يَاهُو  
\m
\v 20 ”ڭعّذْ خْ \add إِذُورَارْ ن\add* لُوبْنَانْ، سْغُويّْ ؤُشَا أجّْ ثْمِيجَّا نّمْ أَذْ ثتّْوَاسڒْ ذِي بَاشَانْ. سْغُويّْ-د عَاوذْ زِي أَبَارِيمْ، مَاغَارْ مَارَّا إِنِّي شمْ إِتّخْسنْ تّْوَارْژَانْ.  
\v 21 نشّْ سِّيوْڒغْ أَكِيذمْ ڒَامِي شمْ ثُوغَا ذِي ڒَامَانْ، شمْ مَاشَا ثنِّيذْ: ’نشّْ وَارْ خْسغْ أَذْ سْڒغْ!‘ أَمُّو إِ ث ثڭِّيذْ زِي ثمْژِي نّمْ، مَاغَارْ شمْ ثُوغَا وَارْ ثتّخْسذْ أَذْ ثسْڒذْ إِ ثْمِيجَّا إِنُو. \x ◘ \xo 22:‏21 \xt إِرْم. 5‏:‏23؛ 7‏:‏23‏-‏28؛ 11‏:‏7، 8؛ 13‏:‏10، 11؛ 16‏:‏12؛ 17‏:‏23؛ 18‏:‏12؛ 19‏:‏15\x*  
\v 22 مَارَّا إِمكْسَاونْ أَذْ ثنْ يَارْوسْ ؤُسمِّيضْ ؤُشَا إِنِّي شمْ إِتّخْسنْ أَذْ ؤُيُورنْ ذِي ثْمحْبَاسْثْ. خنِّي أَذْ ثْسضْحِيذْ ؤُشَا أَذْ ثنْفضْحذْ زِي سِّيبّثْ ن مَارَّا ثُوعفّْنَا نّمْ. \f ◼ \fr 22:‏22 \ft \+bd ’إِمكْسَاونْ‘\+bd* - نِيغْ ’إِنِيتْشَانْ‘.\f*  
\v 23 شمْ، \add أَ\add* ثنِّي إِزدّْغنْ خْ \add إِذُورَارْ ن\add* لُوبْنَانْ، ثنِّي إِحبْضنْ ذِي ثْشجُّورَا ن ثْنڭْلِينْ، مَامّشْ إِ غَا ثْزهَّارذْ خْمِي ذ أَمْ د غَا يَاسنْ ڒوْجعْ، ڒحْرِيقْ أَمْ يِيشْثنْ ثتَّارُو!“   
\m
\v 24 ”\add س ثِيذتّْ أَمْ\add* دَّارغْ نشّْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي: ’وَاخَّا، مَاڒَا كُونْ-يَاهُو، مِّيسْ ن يَاهُويَاقِيمْ، أَجدْجِيذْ ن يَاهُوذَا، ثُوغَا ذ ثْخَاذنْثْ ن ؤُشمِّيعْ ذڭْ ؤُفُوسْ إِنُو، أَقَا أَذْ شكْ كّْسغْ سّنِّي.  
\v 25 نشّْ أَذْ شكْ وْشغْ ذڭْ ؤُفُوسْ ن يِينِّي يَارزُّونْ ثُوذَارْثْ نّشْ ؤُ ذڭْ ؤُفُوسْ ن ونِّي زِي ثتّڭّْوذذْ، ذڭْ ؤُفُوسْ ن نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ؤُ ذڭْ ؤُفُوسْ ن إِكَالْذَانِييّنْ. \f ◼ \fr 22:‏25 \ft \+bd ’ينِّي يَارزُّونْ ثُوذَارْثْ نّكْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ن ينِّي يَارزُّونْ ڒعْمَارْ نّكْ‘.\f*  
\v 26 شكْ ذ يمَّاشْ، أَذْ كنِّيوْ نْضَارغْ غَارْ إِشْثْ ن ثمُّورْثْ نّغْنِيثْ مَانِي وَارْ ثخْڒِيقمْ، ؤُشَا ذِينِّي أَذْ ثْمثْنمْ.  
\v 27 وَارْ تّْعِيقِّيبمْعمَّارْصْ غَارْ ثمُّورْثْ نِّي ذِي ثمّژْرمْ مَاحنْذْ أَذْ غَارسْ د-ثْعقْبمْ.‘ “   
\m
\v 28 ”مَا كُونْ-يَاهُو أَرْيَازْ-أَ ذ إِجّْ ن ؤُغَارَّافْ إِمّنْضَارْ، يَارّژْ؟ نِيغْ نتَّا ذ إِجّْ ن ؤُغَارَّافْ وَارْ ث إِتّخْسْ عَاذْ ؤُڒَا ذ إِجّْ؟ مَايمِّي ث حجَّارنْ، نتَّا ذ زَّارِيعثْ نّسْ، نْضَارنْ \add ثنْ\add* غَارْ إِشْثْ ن ثمُّورْثْ وَارْ ت سِّيننْ؟  
\v 29 \add أَ\add* ثَامُّورْثْ، ثَامُّورْثْ، ثَامُّورْثْ، سڒْ إِ وَاوَاڒْ ن سِيذِي!  
\v 30 أَمُّو إِ إِقَّارْ سِيذِي: ’زمّْ أَرْيَازْ-أَ نْهْڒَا إِحنْجِيرنْ، إِجّْ ن ورْيَازْ نِّي وَارْ غَارْ إِدْجِي زّْهِيرْ ذڭْ وُوسَّانْ نّسْ. مَاغَارْ ؤُڒَا ذ إِجّْ زڭْ وَارَّاوْ نّسْ أَذْ غَارسْ يِيڒِي زّْهِيرْ \add أَڒَامِي\add* إِ غَا إِقِّيمْ خْ ڒْعَارْشْ ن ذَاوُوذْ، أَذْ إِحْكمْ عَاوذْ ذِي \add ثمُّورْثْ ن\add* يَاهُوذَا.‘ “   
\b  
\b  
\m  
\c 23
\s1 أَغدُّو ن ثْسڭْذَا  
\m
\v 1 ”ؤُشْثْ خْ إِمكْسَاونْ إِ إِنقّنْ ؤُ زُوزَّارَانْ ؤُدْجِي ن دّْمَانِي إِنُو ن ثَاروْسَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. \f ◼ \fr 23:‏1 \ft \+bd ’إِمكْسَاونْ‘\+bd* - نِيغْ ’إِنِيتْشَانْ‘.\f*  \x ◘ \xo 23:‏1 \xt حِز. 34‏:‏2\x*  
\v 2 س ؤُيَا أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل، خْ إِمكْسَاونْ نِّي يَاركّْوْسنْ ڒْڭنْسْ إِنُو: ’كنِّيوْ ثْزُوزَّارمْ ؤُدْجِي إِنُو ؤُشَا ثُوژّْڒمْ خَاسنْ. كنِّيوْ وَارْ ثنْ ثحْضِيمْ. خْزَارْ، نشّْ أَذْ خڒْفغْ زِي ثُوعفّْنَا ذ ثْمڭَّا نْومْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 3 نشّْ أَذْ سّْمُونغْ مِينْ إِقِّيمنْ ن وُودْجِي إِنُو زِي مَارَّا ثِيمُّورَا مَانِي خَاسنْثْ ؤُژّْڒغْ. نشّْ أَذْ ثنْثْ أَرّغْ غَارْ ڒْكُورِيثْ نْسنْثْ، أَذْ أَرْونْثْ، أَذْ مَّارْنِينْثْ.  
\v 4 نشّْ أَذْ أَسنْثْ ڭّغْ إِمكْسَاونْ نِّي ثنْثْ إِ غَا يَاروْسنْ. نِيثْنِي وَارْ تّڭّْوْذنْثْ عَاذْ ؤُ وَارْ تّْنخْڒِيعنْثْ ؤُ وَارْ تّْوذِّيرِينْثْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ \x ◘ \xo 23:‏4 \xt حِز. 34‏:‏11، 12\x*   
\m
\v 5 ”خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَقَا نشّْ أَذْ سّكَّارغْ إِ ذَاوُوذْ أَغدُّو ن ثْسڭْذَا. نتَّا أَذْ إِحْكمْ أَمْ ؤُجدْجِيذْ، أَذْ إِفْڒحْ ؤُشَا أَذْ إِڭّْ ڒْحقّْ ذ ثْسڭْذَا ذِي ثمُّورْثْ. \x ◘ \xo 23:‏5 \xt إِشا. 4‏:‏2؛ 40‏:‏11؛ إِرْم. 33‏:‏14، 15؛ دَان. 9‏:‏24؛ لك. 1‏:‏32، 33\x*  
\v 6 ذڭْ وُوسَّانْ نّسْ أَذْ إِتّْوَاسّنْجمْ يَاهُوذَا ؤُشَا إِسْرَائِيل أَذْ إِزْذغْ ذِي ڒَامَانْ. وَا أَذْ يِيڒِي ذ إِسمْ إِ زِي ذ أَسْ إِ غَا ڒَاغَانْ: سِيذِي، ثَاسڭْذَا نّغْ.“ \x ◘ \xo 23:‏6 \xt أَعَوذ. 33‏:‏28\x*   
\m
\v 7 ”س ؤُيَا، خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، وَارْ قَّارنْ عَاذْ: ’س ثِيذتّْ أَمْ إِدَّارْ سِيذِي نِّي د-إِسُّوفّْغنْ أَيْثْ ن إِسْرَائِيل زِي مِيصْرَا!‘، \x ◘ \xo 23:‏7 \xt إِرْم. 16‏:‏14، 15\x*  
\v 8 مَاشَا: ’س ثِيذتّْ أَمْ إِدَّارْ سِيذِي نِّي د-إِسْڭعّْذنْ زَّارِيعثْ ن ثَادَّارْثْ ن إِسْرَائِيل، ونِّي ثنْ د-يَارِّينْ زِي ثمُّورْثْ ن شَّامَالْ ؤُ زِي مَارَّا ثِيمُّورَا مَانِيسْ خَاسنْ ؤُژّْڒغْ. نِيثْنِي أَذْ زذْغنْ ذِي ثمُّورْثْ نْسنْ.‘ “   
\b  
\m
\v 9 \bd خْ إِنَابِييّنْ.\bd*  
\m ”ؤُڒْ إِنُو إِتّْوَارْژْ ذِي ذَاخڒْ إِنُو، مَارَّا إِغْسَانْ إِنُو تَّارْجِيجِينْ. نشّْ ذوْڒغْ أَمْ يِيجّْ ن ؤُمسْشُورْ، أَمْ ورْيَازْ نِّي يَارْنِي بِينُو، زِي سِّيبّثْ ن سِيذِي ؤُ زِي سِّيبّثْ ن وَاوَاڒنْ نّسْ إِقدّْسنْ.  
\v 10 مَاغَارْ ثَامُّورْثْ ثشُّورْ س يِينِّي إِزنَّانْ، مَاغَارْ ثَامُّورْثْ ثشْضنْ زِي سِّيبّثْ ن نّعْڒثْ، دّْمَانِي ن ثَاروْسَا ذِي ڒخْڒَا ؤُژْغنْثْ. مَانِي خْسنْ أَذْ أَوْضنْ أَقَا-ث ذ أَعفَّانْ، ؤُڒَا ذ جّهْذْ نْسنْ وَارْ إِدْجِي شَا نِيشَانْ. \x ◘ \xo 23:‏10 \xt إِرْم. 5‏:‏7، 8؛ 9‏:‏2\x*  
\v 11 مَاغَارْ أَمْ ؤُنَابِي أَمْ ؤُكهَّانْ تّْوَافسْذنْ، عَاذْ ذِي ثَادَّارْثْ إِنُو تَّافغْ ثُوعفّْنَا نْسنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. \x ◘ \xo 23:‏11 \xt إِرْم. 6‏:‏13؛ 8‏:‏10؛ 14‏:‏18\x*  
\v 12 س ؤُيَا أَذْ د-أَسنْ إِذْوڒْ وبْرِيذْ نْسنْ أَمْ يِيجّْ نْ ڒوْضَا إِتّحْرُودْجُوضْ ذِي ثَادْجسْثْ. أَذْ تّْوَاعَارّْننْ ؤُ نِيثْنِي أَذْ زَّايسْ د-وْضَانْ، مَاغَارْ أَذْ خَاسنْ د-سّهْوِيغْ إِشْثْ ن ثشْثِي ثَاعفَّانْثْ ذڭْ ؤُسڭّْوَاسْ إِ زَّايْسنْ إِ غَا خڒْفغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ \x ◘ \xo 23:‏12 \xt إِزهد. 35‏:‏6؛ 73‏:‏18؛ إِرْم. 13‏:‏16\x*   
\m
\v 13 ”أَقَا نشّْ ژْرِيغْ ثِيمسْڒَايِينْ إِسّْثبْهَاثنْ غَارْ إِنَابِييّنْ ن سَامَارْيَا: نِيثْنِي ثُوغَا تّْنَابّنْ س بَاعْلْ ؤُشَا تّْغَارَّانْ ڒْڭنْسْ إِنُو.  
\v 14 \add مَاشَا\add* غَارْ إِنَابِييّنْ ن ؤُرْشَالِيمْ ژْرِيغْ إِجّْ ن نّْعِي ذ أَعفَّانْ قَاعْ: نِيثْنِي زنَّانْ، ؤُيُورنْ أَمْ سّْخَارِّيقنْ ؤُشَا سّْجهْذنْ إِفَاسّنْ ن إِعفَّاننْ أَڒَامِي ؤُڒَا ذ إِجّْ وَارْ د-إِعْقبْ زڭْ وبْرِيذْ نّسْ أَعفَّانْ. مَامّشْ تّْوَاڒِيغْ نشّْ، مَارَّا إِذْسنْ أَمْ سَاذُومْ، ؤُشَا إِمزْذَاغْ ن ؤُرْشَالِيمْ \add إِ نشّْ\add* أَمْ عَامُورَّا. \x ◘ \xo 23:‏14 \xt إِشا. 1‏:‏9\x*  
\v 15 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: خْزَارْ، نشّْ أَذْ وْشغْ شِّيحْ ذ مَاشَّا إِ ڒْڭنْسْ-أَ ؤُڒَا ذ أَمَانْ ن أَرّْهَاجْ مَاحنْذْ أَذْ ثنْ سْونْ، مِينْزِي زڭْ إِنَابِييّنْ ذِي ؤُرْشَالِيمْ إِفّغْ-د ؤُغسّبْ \add ن شَّارِيعَا\add* غَارْ مَارَّا ثَامُّورْثْ. \x ◘ \xo 23:‏15 \xt إِرْم. 8‏:‏14؛ 9‏:‏15\x*  
\v 16 أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: وَارْ تّسْڒِيمْ شَا إِ وَاوَاڒنْ ن إِنَابِييّنْ نِّي ذ أَومْ إِتّْنبَّانْ، \add أَمْ\add* سَّاوَاڒنْ أَكِيذْومْ بَاطڒْ. نِيثْنِي سَّاوَاڒنْ إِجّْ ن ڒوْحِييْ ن وُوڒْ \add ن يِيخفْ\add* نْسنْ، وَارْ \add سِّيوِيڒنْ\add* \add ڒوْحِييْ\add* زڭْ ؤُقمُّومْ ن سِيذِي.  
\v 17 ڒبْذَا قَّارنْ إِ يِينِّي ذ أَيِي إِسّحْقَارَانْ: سِيذِي إِنَّا إِ-ث، أَذْ غَارْومْ يِيڒِي ڒهْنَا! ؤُ إِ كُوڒْ إِجّْ ونِّي إِڭُّورنْ ذِي ڒقْسَاحثْ ن وُوڒْ نّسْ، قَّارنْ: وَارْ د خَاومْ إِتّمْسَارْ ؤُڒَا ذ إِجّْ ن ڒْغَارْ! \x ◘ \xo 23:‏17 \xt إِرْم. 6‏:‏14؛ 8‏:‏11؛ حِز. 13‏:‏10؛ زَاك. 10‏:‏2\x*  
\v 18 مَاغَارْ مَانْ ونْ ثُوغَا إِبدّْ ذِي ڒْحڒْقثْ ن إِمْشَاوَارنْ ن سِيذِي، إِژْرَا أَوَاڒْ نّسْ ؤُ إِسْڒَا أَسْ؟ وِي إِسّْحسّنْ إِ وَاوَاڒْ نّسْ ؤُشَا إِسْڒَا غَارسْ؟  
\v 19 خْزَارْ، ثَاحَارْيَاضْثْ ن سِيذِي، إِفّغْ-د \add زَّايسْ\add* وسْعَارْ، إِشْثْ ن ثْحَارْيَاضْثْ ثزّبْزِيبْ نِّي د غَا إِهْوَانْ خْ ؤُزدْجِيفْ ن إِعفَّاننْ. \x ◘ \xo 23:‏19 \xt إِرْم. 30‏:‏23، 24\x*  
\v 20 أَغْضَابْ ن سِيذِي وَارْ د-إِذِّيكّْوِيڒْ شَا أَڒْ غَا يِيڒِينْ إِخَارِّيصنْ ن وُوڒْ نّسْ. ذڭْ ؤُنڭَّارْ ن وُوسَّانْ أَذْ أَسْ ثْفهْممْ س ڒفْهَامثْ ثكْمڒْ.  
\v 21 نشّْ وَارْ د-سّكِّيغْ شَا إِنَابِييّنْ نِّي، \add وَاخَّا أَمنِّي\add* ڭُّورنْ تَّازّْڒنْ نِيثْنِي. نشّْ وَارْ غَارْسنْ سِّيوْڒغْ شَا، \add وَاخَّا أَمنِّي\add* بْذَانْ أَذْ نبَّانْ ذغْيَا \add زڭْ يِيخفْ نْسنْ\add*. \x ◘ \xo 23:‏21 \xt إِرْم. 14‏:‏14\x*  
\v 22 مْڒِي ثُوغَا نِيثْنِي بدّنْ ذِي ڒْهڒْقثْ ن إِمْشَاوَارنْ إِنُو، إِڒِي أَرِّينْ ڒْڭنْسْ إِنُو أَذْ إِسڒْ إِ وَاوَاڒنْ إِنُو ؤُ إِڒِي أَرِّينْ ثنْ أَذْ د-ذوْڒنْ زڭْ وبْرِيذْ نْسنْ أَعفَّانْ ؤُ زِي ڒْغَارْ ن ثْمڭَّا نْسنْ.“   
\m
\v 23 ”نشّْ ذ إِجّْ ن أَربِّي زِي ڒَاذَاسْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، وَارْ إِدْجِي إِجّْ ن أَربِّي زِي ڒَاڭّْوَاجْ؟  
\v 24 مَا إِزمَّارْ شَا ن يِيجّنْ أَذْ إِنُّوفَّارْ ذڭْ إِمُوشَانْ إِنُّوفَّارنْ، أَڒَامِي نشّْ وَارْ ث ژَترّغْ، إِقَّارْ سِيذِي. مَا وَارْ إِدْجِي ذ نشّْ ونِّي إِشُّورنْ أَجنَّا ذ ثمُّورْثْ؟، إِقَّارْ سِيذِي. \x ◘ \xo 23:‏24 \xt إِزهد. 139‏:‏7‏-‏12؛ عَام. 9‏:‏2، 3\x*  
\v 25 نشّْ سْڒِيغْ مِينْ قَّارنْ إِنَابِييّنْ نِّي إِتّْنبَّانْ أَمْ سّْخَارِّيقنْ ذڭْ يِيسمْ إِنُو، قَّارنْ: ’ثُوغَا غَارِي إِشْثْ ن ثِيرْجَا، إِشْثْ ن ثِيرْجَا!‘  
\v 26 أَڒْ مڒْمِي \add عَاذْ\add* أَذْ إِڒِينْثْ ثِيرْجَا ذڭْ وُوڒْ ن إِنَابِييّنْ نِّي إِتّْنبَّانْ أَمْ سّْخَارِّيقنْ؟ نِيثْنِي ذ إِنَابِييّنْ ن وشْمَاطْ ن وُوڒْ \add ن يِيخفْ\add* نْسنْ،  
\v 27 إِنِّي يَارزُّونْ أَذْ أَرّنْ ڒْڭنْسْ إِنُو أَذْ إِتُّو إِسمْ إِنُو س ثِيرْجَا نْسنْ نِّي تّْهَاجَانْ إِجّْ إِ ونّغْنِي، أَمْ مَامّشْ إِبَابَاثنْ نْسنْ تُّونْ إِسمْ إِنُو س بَاعْلْ. \x ◘ \xo 23:‏27 \xt ڒقض. 3‏:‏7؛ 8‏:‏33، 34\x*  
\v 28 أَنَابِي نِّي غَارسْ إِشْثْ ن ثِيرْجَا، أجّْ إِ-ث أَذْ ت إِحَاجَا، ؤُ \add أَنَابِي\add* نِّي غَارْ إِدْجَا وَاوَاڒْ إِنُو، أجّْ إِ-ث أَذْ إِسِّيوڒْ أَوَاڒْ إِنُو س ثِيذتّْ. مَاغَارْ مِينْ د-يِيوْينْ ڒُومْ غَارْ إِمنْذِي، إِقَّارْ سِيذِي.  
\v 29 مَا وَارْ إِدْجِي وَاوَاڒْ إِنُو أَمْ ثْمسِّي، إِقَّارْ سِيذِي، ؤُشَا أَمْ يِيجّْ ن وفْضِيسْ إِ إِڒبّْزنْ ثَاصْضَارْثْ؟  
\v 30 س ؤُيَا، خْزَارْ، نشّْ أَذْ ڒقْفغْ إِنَابِييّنْ نِّي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، إِنِّي إِتَّاشَارنْ أَوَاڒنْ إِنُو إِجّْ ن ونّغْنِي. \x ◘ \xo 23:‏30 \xt أَعَوذ. 18‏:‏20؛ إِرْم. 14‏:‏14، 15\x*  
\v 31 خْزَارْ، نشّْ أَذْ ڒقْفغْ إِنَابِييّنْ نِّي، إِقَّارْ سِيذِي، إِنِّي إِسّْخدَّامنْ إِڒسْ نْسنْ ؤُ سَّاوَاڒنْ \add زَّايسْ أَمُّو\add*: ’نتَّا إِقَّارْ!‘  
\v 32 خْزَارْ، نشّْ أَذْ ڒقْفغْ إِنِّي إِتّْنبَّانْ س ثِيرْجَا إِخَارِّيقنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. نِيثْنِي تّْحَاجَانْ ثِيرْجَا نِّي ؤُ \add أَمُّو إِ\add* تّْغَارَّانْ ڒْڭنْسْ إِنُو زڭْ إِخَارِّيقنْ نْسنْ ذ ڒْهَارْذْ نْسنْ إِبطّْڒنْ. نشّْ وَارْ ثنْ د-سّكّغْ ؤُ وَارْ ذ أَسنْ وْشِيغْ أَوَاڒْ. نِيثْنِي وَارْ دْجِينْ ذ نّْفعْ إِ ڒْڭنْسْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ \x ◘ \xo 23:‏32 \xt صَاف. 3‏:‏4\x*   
\m
\v 33 ”خْمِي شكْ إِ غَا إِسّقْسَا إِجّْ ن ڒْڭنْسْ نِيغْ إِجّْ ن ؤُنَابِي نِيغْ إِجّْ ن ؤُكهَّانْ، أَذْ يِينِي: ’مِينْ إِعْنَا \add خنِّي\add* ڒْحُوكْمْ إِسَّاڭّْوَاذنْ ن سِيذِي؟‘، خنِّي شكْ أَذْ أَسنْ ثِينِيذْ: ’مِينْ إِعْنَا \add خنِّي\add* ڒْحُوكْمْ إِسَّاڭّْوَاذنْ؟‘ ’أَذْ كنِّيوْ نْضَارغْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 34 أَنَابِي ذ ؤُكهَّانْ ذ ڒْڭنْسْ نِّي إِقَّارنْ \add أَمْ سْثهزَّانْ\add*: ’ڒْحُوكْمْ إِسَّاڭّْوَاذنْ ن سِيذِي؟‘، أَرْيَازْ نِّي ذ ثَادَّارْثْ نِّي أَذْ زَّايسْ خڒْفغْ.  
\v 35 أَمُّو إِتّْخصَّا أَذْ ثِينِيمْ، كُوڒْ  إِجّْ إِ جَّارْ نّسْ ؤُ كُوڒْ إِجّْ إِ ؤُمَاسْ: ’مَامّشْ خَاكْ د-يَارَّا سِيذِي؟‘، ؤُ: ’مِينْ إِنَّا سِيذِي؟‘  
\v 36 وَارْ ثِيذَارمْ عَاذْ ڒْحُوكْمْ إِسَّاڭّْوَاذنْ ن سِيذِي، مَاغَارْ ڒْحُوكْمْ إِسَّاڭّْوَاذنْ ن سِيذِي أَذْ يِيڒِي مِينْ غَا يِينِي كُوڒْ إِجّْ: أَقَا كنِّيوْ ثسّْفَارْغمْ أَوَاڒنْ ن أَربِّي إِدَّارنْ، سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي نّغْ.   
\m
\v 37 أَمُّو إِ غَا ثِينِيذْ إِ ؤُنَابِي: ’مَامّشْ خَاكْ د-يَارَّا سِيذِي؟‘، نِيغْ: ’مِينْ إِنَّا سِيذِي؟‘  
\v 38 \add مَاشَا\add* ؤُمِي ثقَّارمْ كنِّيوْ: ’ڒْحُوكْمْ إِسَّاڭّْوَاذنْ ن سِيذِي؟‘، س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي، ؤُمِي كنِّيوْ ثقَّارمْ أَوَاڒْ-أَ: ’ڒْحُوكْمْ إِسَّاڭّْوَاذنْ ن سِيذِي؟‘، وَاخَّا نشّْ سّكّغْ-د غَارْومْ \add إِجّنْ\add* حِيمَا أَذْ أَومْ يِينِي: ’كنِّيوْ وَارْ ثقَّارمْ شَا: ڒْحُوكْمْ إِسَّاڭّْوَاذنْ ن سِيذِي؟‘،  
\v 39 س ؤُيَا، خْزَارْ، نشّْ أَذْ كنِّيوْ تُّوغْ قَاعْ. نشّْ أَذْ كنِّيوْ نْضَارغْ زِي زَّاثْ إِ وُوذمْ إِنُو أَكْ-ذ ثنْذِينْثْ نْومْ نِّي ذ أَومْ وْشِيغْ إِ كنِّيوْ ؤُڒَا إِ ڒجْذُوذْ نْومْ.  
\v 40 نشّْ أَذْ خَاومْ د-سّهْوِيغْ ڒْحڭْرَا إِ ڒبْذَا ذ ڒفْضِيحثْ إِ ڒبْذَا نِّي وَارْ إِتّْوَاتُّونْعمَّارْصْ.“ \x ◘ \xo 23:‏40 \xt إِرْم. 20‏:‏11\x*   
\b  
\b  
\m  
\c 24
\s1 ثْنَاينْ ن ثْسُودْجَاثِينْ ن ثَازَارْثْ  
\m
\v 1 سِيذِي إِجَّا أَيِي أَذْ ژَترغْ مَانْ أَيَا. خْزَارْ، تّْوَاسَّارْسنْثْ ثْنَاينْ ن ثْسُودْجَاثِينْ ن ثَازَارْثْ قِيبَاتْشْ إِ زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي أَوَارْنِي إِ ؤُمِي ثُوغَا نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، إِنْذهْ يَاكُونْيَا، مِّيسْ ن يَاهُويَاقِيمْ، أَجدْجِيذْ ن يَاهُوذَا، ذ ڒْحُوكَّامْ ن يَاهُوذَا أَكْ-ذ إِحْرَايْفِييّنْ ذ يمْزِيڒنْ زِي ؤُرْشَالِيمْ ذِي لْمنْفَا غَارْ بَابِيلْ. \x ◘ \xo 24:‏1 \xt 2 إِج. 24‏:‏15؛ 2 إِم. 36‏:‏10\x*  
\v 2 ذڭْ إِشْثْ ن ثْسُودْجثْ ثُوغَا \add ذِينْ\add* ثَازَارْثْ إِصبْحنْ، أَمْ ڒْبَاشُورْ. ذِي ثْسُودْجثْ نّغْنِيثْ ثُوغَا ذِينْ ثَازَارْثْ وَارْ ثحْرِي أَطَّاسْ، زعْمَا وَارْ ثحْرِي أَڒَامِي وَارْ إِزمَّارْ أَذْ ثتّْوَاشّْ.  
\v 3 إِنَّا أَيِي سِيذِي: ”مِينْ ثتّْوَاڒِيذْ شكْ، إِرْمِييَا؟“ نشّْ نِّيغْ: ”ثَازَارْثْ. ثَازَارْثْ إِصبْحنْ ثصْبحْ أَطَّاسْ، ؤُشَا ثنِّي وَارْ إِحْڒِينْ أَطَّاسْ، وَارْ ثحْڒِي أَڒَامِي وَارْ ثتّْوِيشِّي.“   
\m
\v 4 \add خنِّي\add* يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:  
\v 5 ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’أَمْ ثَازَارْثْ إِصبْحنْ أَمُّو إِ غَا حسْبغْ صبْحنْ إِنِّي إِتّْوَانذْهنْ ذِي ثْمحْبَاسْثْ زِي يَاهُوذَا، إِنِّي خْ ؤُژّْڒغْ زڭْ ومْشَانْ-أَ غَارْ ثمُّورْثْ ن إِكَالْذَانِييّنْ.  
\v 6 نشّْ أَذْ خَاسنْ سَّارْسغْ ثِيطَّاوِينْ إِنُو س أَرْضَا ؤُشَا أَذْ ثنْ أَرّغْ أَذْعقْبنْ غَارْ ثمُّورْثْ-أَ. نشّْ أَذْ ثنْ سّْبدّغْ، وَارْ ثنْ هدّْمغْ، أَذْ ثنْ ژُّوغْ، وَارْ ثنْ قدْجْعغْ.  
\v 7 نشّْ أَذْ أَسنْ وْشغْ إِجّْ ن وُوڒْ مَاحنْذْ أَذْ أَيِي سّْننْ، بلِّي أَقَا نشّْ ذ سِيذِي. نِيثْنِي أَذْ إِڒِينْ ذ ڒْڭنْسْ إِنُو ؤُ نشّْ أَذْ إِڒِيغْ ذ أَربِّي نْسنْ، مَاغَارْ نِيثْنِي أَذْ غَارِي د-ذوْڒنْ س وُوڒْ نْسنْ إِمُونْ.‘ “ \x ◘ \xo 24:‏7 \xt أَعَوذ. 30‏:‏6؛ إِرْم. 30‏:‏22؛ 31‏:‏33؛ 32‏:‏38، 39؛ حِز. 11‏:‏19؛ 36‏:‏26، 27\x*   
\m
\v 8 ”أَمْ ثَازَارْثْ وَارْ إِحْڒِينْ، ثنِّي وَارْ ثحْڒِي أَطَّاسْ أَڒَامِي وَارْ ثتّْوِيشِّي، إِقَّارْ سِيذِي، أَمُّو إِ غَا أَرّغْ صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ذ ڒْحُوكَّامْ نّسْ ذ مِينْ إِقِّيمنْ زِي ؤُرْشَالِيمْ ذ يِينِّي إِزدّْغنْ ذِي ثمُّورْثْ ن مِيصْرَا. \x ◘ \xo 24:‏8 \xt إِرْم. 29‏:‏17\x*  
\v 9 نشّْ أَذْ ثنْ أَرّغْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ إِ مَارَّا ثِيڭلْذِيوِينْ ن دُّونشْثْ، ذ ڒْحڭْرَا ذ إِجّْ ن ؤُمذْيَا ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُسْثهْزِي ذ إِشْثْ ن نّعْڒثْ ذِي مَارَّا إِمُوشَانْ مَانِي خَاسنْ إِ غَا يَاژّْڒغْ. \x ◘ \xo 24:‏9 \xt أَعَوذ. 28‏:‏25، 37؛ 1 إِج. 9‏:‏7؛ 2 إِم. 7‏:‏20؛ إِرْم. 15‏:‏4؛ 29‏:‏18؛ 34‏:‏17؛ 42‏:‏18\x*  
\v 10 نشّْ أَذْ سّكّغْ جَارْ أَسنْ سِّيفْ ذ ڒَاژْ ذ طَّاعُونْ أَڒْ د-تّْوَاكّْسنْ مَارَّا زِي ثمُّورْثْ إِ أَسنْ وْشِيغْ، إِ نِيثْنِي ؤُ إِ ڒجْذُوذْ نْسنْ.“   
\b  
\b  
\m  
\c 25
\s1 أَبَارّحْ س لْمنْفَا ذِي بَابِيلْ  
\m
\v 1 أَوَاڒْ نِّي د-يُوسِينْ غَارْ إِرْمِييَا خْ مَارَّا ڒْڭنْسْ ن يَاهُوذَا، ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعَا ن يَاهُويَاقِيمْ، مِّيسْ ن يُوشِييَا، أَجدْجِيذْ ن يَاهُوذَا. ثُوغَا-ث ذ أَسڭّْوَاسْ أَمزْوَارُو ن نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ.  
\v 2 إِنَّا ؤُنَابِي إِرْمِييَا \add أَوَاڒْ-أَ\add* إِ مَارَّا ڒْڭنْسْ ن يَاهُوذَا ؤُ إِ مَارَّا إِمزْذَاغْ ن ؤُرْشَالِيمْ، إِنَّا:  
\v 3 ”زڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒطَّاشْ ن يُوشِييَا، مِّيسْ ن أَمُونْ، أَجدْجِيذْ ن يَاهُوذَا، أَڒْ أَسّْ-أَ، أَقَا إِ يِيجّْ ن ڒْمِيجَّاڒْ ن ثْڒَاثَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا، يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي ؤُ نشّْ ثُوغَا سَّاوَاڒغْ أَكِيذْومْ، \add وَاهْ،\add* زڭْ ؤُمزْوَارُو ثُوغَا نشّْ سَّاوَاڒغْ \add أَكِيذْومْ\add*، \add مَاشَا\add* كنِّيوْ وَارْ ثسْڒِيمْ شَا.  
\v 4 سِيذِي إِسّكّْ-د عَاوذْ مَارَّا إِمْسخَّارنْ نّسْ، إِنَابِييّنْ، زڭْ ؤُمزْوَارُو إِسّكّْ إِ-ثنْ-د، \add مَاشَا\add* كنِّيوْ وَارْ ثسْڒِيمْ ؤُ وَارْ ثوْشِيمْ شَا أَمزُّوغْ نْومْ حِيمَا أَذْ ثسْڒمْ. \x ◘ \xo 25:‏4 \xt إِرْم. 7‏:‏13، 25؛ 11‏:‏7، 8،10؛ 13‏:‏10، 11؛ 16‏:‏12؛ 17‏:‏23؛ 18‏:‏12؛ 19‏:‏15؛ 22‏:‏21\x*  
\v 5 نِيثْنِي نَّانْ: ’ذوْڒمْ-د، كُوڒْ  إِجّْ زڭْ وبْرِيذْ نّسْ أَعفَّانْ ؤُ زِي ثُوعفّْنَا ن ثْمڭَّا نْومْ ؤُشَا زذْغمْ ذِي ثمُّورْثْ نِّي ذ أَومْ إِوْشَا سِيذِي ؤُ إِ ڒجْذُوذْ نْومْ زِي ڒبْذَا إِ ڒبْذَا قَاعْ. \x ◘ \xo 25:‏5 \xt 2 إِج. 17‏:‏13؛ إِرْم. 18‏:‏11؛ 35‏:‏15؛ يُون. 3‏:‏8\x*  
\v 6 وَارْ تّْرَادَّافمْ إِربِّيثنْ نّغْنِي حِيمَا أَذْ أَسنْ ثْعبْذمْ ؤُ أَذْ أَسنْ ثْبنْذْقمْ. وَارْ ذ أَيِي سعَّارمْ س ثْمڭَّا ن إِفَاسّنْ نْومْ، مَاحنْذْ وَارْ ذ أَومْ تّڭّغْ ڒْغَارْ.‘  
\v 7 مَاشَا كنِّيوْ وَارْ غَارِي ثسْڒِيمْ شَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَڒَامِي ذ أَيِي ثسْعَارمْ س ثْمڭَّا ن إِفَاسّنْ نْومْ، إِ ثْخسَّارْثْ نْومْ.“   
\m
\v 8 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: ’مِينْزِي كنِّيوْ وَارْ ثسْڒِيمْ شَا غَارْ وَاوَاڒنْ إِنُو،  
\v 9 خْزَارْ، س ؤُيَا أَذْ ڭّغْ أَذْ أَوْيغْ مَارَّا ڒَادْجَاثْ زِي شَّامَالْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، ؤُڒَا ذ نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، أَمْسخَّارْ إِنُو. نشّْ أَذْ ثنْ سِّيوْضغْ خْ ثمُّورْثْ-أَ ؤُ خْ إِمزْذَاغْ نّسْ ؤُ خْ مَارَّا ڒڭْنُوسْ إِ ذ أَسْ د-إِنّْضنْ ؤُشَا أَذْ ثنْ حَارّْمغْ إِ ؤُثحِّي. نشّْ أَذْ ثنْ ڭّغْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ ذ ثْسضْحَاشْثْ ؤُڒَا ذ ڒْخِيرْبَاثْ إِ ڒبْذَا. \x ◘ \xo 25:‏9 \xt إِرْم. 19‏:‏8\x*  
\v 10 نشّْ أَذْ زَّايْسنْ كّْسغْ ڒْحسّْ ن ڒفْرَاحثْ ذ ڒْحسّْ ن وَارْشَاقْ، ثْمِيجَّا ن مُوڒَايْ ذ ثْمِيجَّا ن ثسْڒِيثْ، دّْرِيزْ ن يژْرَا ن ثْسِيرْثْ ؤُڒَا ذ ثْفَاوْثْ ن ڒفْنَارْ. \x ◘ \xo 25:‏10 \xt إِشا. 24‏:‏7؛ إِرْم. 7‏:‏34؛ 16‏:‏9؛ حِز. 26‏:‏13\x*  
\v 11 ثَامُّورْثْ-أَ مَارَّا أَذْ ثذْوڒْ ذ ڒْخِيرْبثْ ؤُڒَا ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ، ؤُ ڒڭْنُوسْ-أَ أَذْ سخَّارنْ أَجدْجِيذْ ن بَابِيلْ، \bd سبْعِينْ ن إِسڭّْوُوسَا\bd*.   
\m
\v 12 خْمِي غَا عْذُونْ سبْعِينْ ن إِسڭّْوُوسَا نِّي، خنِّي أَذْ خڒْفغْ زڭْ ؤُجدْجِيذْ ن بَابِيلْ ذ ڒْڭنْسْ نِّي خْ ڒْمُوعْصِييّثْ نْسنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، ؤُڒَا خْ ثمُّورْثْ ن إِكَالْذَانِييّنْ. نشّْ أَذْ ت أَرّغْ ذ إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ إِ ڒبْذَا. \x ◘ \xo 25:‏12 \xt 2 إِم. 36‏:‏22؛ عِز. 1‏:‏1؛ إِرْم. 29‏:‏10؛ دَان. 9‏:‏2\x*  
\v 13 نشّْ أَذْ د-سّهْوِيغْ خْ ثمُّورْثْ نِّي مَارَّا أَوَاڒنْ إِنُو نِّي خَاسْ نِّيغْ، مَارَّا مِينْ يُورِينْ ذڭْ وذْلِيسْ إِتّْوَانّْضنْ، مِينْ إِنبَّا إِرْمِييَا خْ مَارَّا ڒڭْنُوسْ.  
\v 14 مَاغَارْ ؤُڒَا ذ نِيثْنِي، \add وَاهْ،\add* نِيثْنِي، أَذْعبّْذنْ إِ وَاطَّاسْ ن ڒڭْنُوسْ ذ إِجدْجِيذنْ إِمقّْرَاننْ، ؤُشَا \add أَمُّو\add* نشّْ أَذْ زَّايْسنْ خڒْفغْ عْلَاحْسَابْ ثِيمڭَّا نْسنْ ؤُ عْلَاحْسَابْ ڒْخذْمثْ ن إِفَاسّنْ نْسنْ.‘ “ \x ◘ \xo 25:‏14 \xt إِرْم. 27‏:‏7\x*   
\b  
\m  
\s1 ڒْكَاسْ ن وغْضَابْ ن سِيذِي  
\m
\v 15 ”مَاغَارْ أَمُّو إِ ذ أَيِي إِنَّا سِيذِي، أَربِّي ن إِسْرَائِيل: ’كْسِي ڒْكَاسْ-أَ ن بِينُو ن وسْعَارْ زڭْ ؤُفُوسْ إِنُو ؤُ أوْشْ إِ-ث إِ مَارَّا ڒڭْنُوسْ مَانِي شكْ إِ غَا سّكّغْ، حِيمَا أَذْ سْونْ، \x ◘ \xo 25:‏15 \xt إِرْم. 13‏:‏12\x*  
\v 16 مَاحنْذْ أَذْ سْونْ، أَذْ ميّْڒنْ سَّا غَارْ ذَا، أَذْ ذوْڒنْ تّْبُوهْڒُوينْ زِي سِّيبّثْ ن سِّيفْ نِّي د غَا سّكّغْ جَارْ أَسنْ.‘ “   
\b  
\m
\v 17 \add أَوَارْنِي ؤُيَا\add* كْسِيغْ ڒْكَاسْ زڭْ ؤُفُوسْ ن سِيذِي، وْشِيغْ ث إِ مَارَّا ڒڭْنُوسْ، مَانِي إِ ذ أَيِي إِسّكّْ سِيذِي:   
\m
\v 18 ... \bd إِ ؤُرْشَالِيمْ ذ ثْندَّامْ ن يَاهُوذَا\bd*، إِ إِجدْجِيذنْ نّسْ ذ ڒْحُوكَّامْ نّسْ، حِيمَا أَذْ ثنْ أَرّغْ ذ ڒْخِيرْبثْ، ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ ذ ثْسضْحَاشْثْ ؤُڒَا ذ نّعْڒثْ، أَمْ \add ثدْجَا\add* أَسّْ-أَ،   
\m
\v 19 ... \bd إِ فِيڒْعُونْ، أَجدْجِيذْ ن مِيصْرَا\bd*، إِ ؤُمْسخَّارنْ نّسْ، ڒْحُوكَّامْ نّسْ ؤُ إِ مَارَّا ڒْڭنْسْ نّسْ، \x ◘ \xo 25:‏19 \xt إِرْم. 46\x*   
\m
\v 20 ... \bd إِ ؤُبَارُّو ن عْڒَامْ كُوڒْ  إِبَارَّانِييّنْ\bd*  
\m ... \bd إِ إِجدْجِيذنْ ن ثمُّورْثْ نْ عُوصْ\bd*  
\m ... \bd إِ مَارَّا إِجدْجِيذنْ ن ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ\bd*، إِ أَشْقَالُونْ، غَازَّا، عَاقْرُونْ ؤُ إِ مَارَّا مِينْ إِقِّيمنْ زِي أَشْذُوذْ، \x ◘ \xo 25:‏20 \xt إِرْم. 47‏:‏4‏-‏7\x*   
\m
\v 21 ... \bd إِ إِذُومْ، مُوآبَ ذ أَيْثْ ن عَامُّونْ،\bd* \x ◘ \xo 25:‏21 \xt إِرْم. 48؛ 49‏:‏1‏-‏22\x*   
\m
\v 22 ... \bd إِ مَارَّا إِجدْجِيذنْ ن صُورْ، إِ مَارَّا إِجدْجِيذنْ ن صِيذُونْ ؤُ إِ إِجدْجِيذنْ ن ثڭْزِيرِينْ\bd* خْ ؤُجمَّاضْ ن ڒبْحَارْ، \x ◘ \xo 25:‏22 \xt إِرْم. 47‏:‏4\x*   
\m
\v 23 ... \bd إِ ذَاذَانْ، ثَايْمَا، بُوزْ\bd* ذ مَارَّا إِنِّي إِتّْحفَّانْ \add أَشُوَّافْ\add* غَارْ طّْرُوفَا، \x ◘ \xo 25:‏23 \xt لَاوِي 19‏:‏27؛ 21‏:‏5؛ إِرْم. 9‏:‏25؛ إِرْم. 49‏:‏8، 32 \x*   
\m
\v 24 ... \bd إِ مَارَّا إِجدْجِيذنْ ن ثمُّورْثْ ن وعْرَابنْ ؤُ إِ مَارَّا إِجدْجِيذنْ ن عْڒَامْ كُوڒْ إِبَارَّانِييّنْ نِّي إِزدّْغنْ ذِي ڒخْڒَا،\bd* \x ◘ \xo 25:‏24 \xt إِرْم. 49‏:‏31\x*   
\m
\v 25 ... \bd إِ مَارَّا إِجدْجِيذنْ ن زِيمْرِي، ؤُ إِ مَارَّا إِجدْجِيذنْ ن عِيلَامْ ؤُ إِ مَارَّا إِجدْجِيذنْ ن مَاذَايْ،\bd* \x ◘ \xo 25:‏25 \xt إِرْم. 49‏:‏34\x*   
\m
\v 26 ... \bd إِ مَارَّا إِجدْجِيذنْ ن شَّامَالْ\bd*، إِنِّي يُوذْسنْ ذ يِينِّي إِڭّْوجنْ، إِجّنْ أَوَارْنِي إِ ونّغْنِي،  
\m ... \bd إِ مَارَّا ثِيڭلْذِيوِينْ ن دُّونشْثْ إِ إِدْجَانْ خْ وُوذمْ ن ثمُّورْثْ\bd*،  
\m \bd ؤُشَا أَوَارْنِي أَسنْ \+bdit مَارَّا\+bdit* أَذْ إِسُو ؤُجدْجِيذْ ن شِيشَاكْ، \+bdit إِخْسْ أَذْ يِينِي بَابِيلْ\+bdit*\bd*.   
\m
\v 27 ”أَذْ أَسنْ ثِينِيذْ: ’أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: سْومْ، سْشَارمْ، عُوقّمْ، وْضَامْ ؤُ وَارْ ثكَّارمْ عَاذْ زَّاثْ إِ سِّيفْ إِ د غَا سّكّغْ جَارْ أَومْ.‘  
\v 28 خْمِي غَا أَڭِينْ أَذْ كْسِينْ ڒْكَاسْ زڭْ ؤُفُوسْ نّشْ مَاحنْذْ أَذْ ث سْونْ، \add خنِّي\add* إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: أَذْ ثسْومْ س ؤُغِيڒْ!  
\v 29 مَاغَارْ خْزَارْ، ذِي ثنْذِينْثْ إِ خْ إِتّْوَابَارّحْ س يِيسمْ إِنُو، أَذْ بْذِيغْ س ڒْغَارْ. مَا أَذْ ذَايْومْ ڭّنْ أَمْ تّڭّنْ أَكْ-ذ إِمزْذَاڭنْ؟ كنِّيوْ وَارْ تّْوَاحسْبنْ ذ إِمزْذَاڭنْ، مَاغَارْ أَذْ ڒَاغِيغْ إِ سِّيفْ ضِيدّْ إِ مَارَّا إِمزْذَاغْ ن ثمُّورْثْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.‘ “ \x ◘ \xo 25:‏29 \xt 1 بُط. 4‏:‏17\x*   
\b  
\m
\v 30 ”أَذْ خَاسنْ ثْنبِّيذْ مَارَّا أَوَاڒنْ-أَ ؤُشَا أَذْ ذ أَسنْ ثِينِيذْ: ’سِيذِي أَذْ د-إِزهَّارْ زِي سنّجْ ؤُشَا نتَّا أَذْ إِسّْڭعّذْ ثْمِيجَّا نّسْ زِي ثْزذِّيغْثْ نّسْ إِقدّْسنْ. نتَّا أَذْ إِزهَّارْ خْ ثْزذِّيغْثْ نّسْ، أَذْ إِڒَاغَا أَمْ ث تّڭّنْ إِنِّي يَارفّْسنْ أَضِيڒْ، ضِيدّْ إِ مَارَّا إِمزْذَاغْ ن دُّونشْثْ.\x ◘ \xo 25:‏30 \xt يُووِ. 4‏:‏16؛ عَام. 1‏:‏2؛ أَسَا. 19‏:‏15، 16\x*  
\v 31 أَذْ د-يَاسْ إِجّْ ن ڒْحسّْ إِسّْنخْڒِيعنْ أَڒْ ثْمَا ن ثمُّورْثْ، مِينْزِي سِيذِي غَارسْ إِشْثْ ن دّعْوثْ أَكْ-ذ ڒڭْنُوسْ. نتَّا أَذْ إِحْكمْ خْ بْنَاذمْ أَمْ إِكْمڒْ، أَذْ إِعَارّنْ مَارَّا إِعفَّاننْ غَارْ سِّيفْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.‘  
\v 32 أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: ’خْزَارْ، إِجّْ ن ڒْغَارْ ثسُّورُوفْ زِي ڒْڭنْسْ غَارْ ڒْڭنْسْ نّغْنِي، إِشْثْ ن ثْهَارْيَاضْثْ ثوْعَارْ ثكَّارْ-د زِي ثْمُووَّا ن ثمُّورْثْ.  
\v 33 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِڒِينْ إِنِّي إِتّْوَاسّْنُوقّْبنْ \add س سِّيفْ\add* خْ إِشْثْ ن ثْمَا ن ثمُّورْثْ أَڒْ ثْمَا نّغْنِي. وَارْ خَاسنْ تّْرُونْ، وَارْ ثنْ جَارّْونْ ؤُ وَارْ ثنْ نطّْڒنْ. أَذْ ذوْڒنْ ذ ڒغْبَارْ خْ وُوذمْ ن ثمُّورْثْ.\x ◘ \xo 25:‏33 \xt إِرْم. 16‏:‏4\x*  
\v 34 رُومْ، \add كنِّيوْ\add* إِمكْسَاونْ، سْغُويمْ. زُوزَّارمْ \add أَشَاڒْ\add* خْ يِيخفْ نْومْ، \add كنِّيوْ\add* إِنِّي غَارْ إِدْجَا جّهْذْ خْ ثْحِيمْرِيوِينْ ن وُودْجِي، مَاغَارْ يِيوضْ-د ڒْحَاڒْ ن ثْغَارْصْثْ نْومْ، ؤُ نشّْ أَذْ كنِّيوْ زُوزَّارغْ ؤُ كنِّيوْ أَذْ ثفْرُورْيمْ أَمْ يِيجّْ ن ؤُغَارَّافْ إِغْڒَا. \x ◘ \xo 25:‏34 \xt إِشا. 65‏:‏12؛ إِرْم. 4‏:‏8؛ 6‏:‏26؛ 9‏:‏16؛ 12‏:‏3؛ 13‏:‏14، 24؛ 18‏:‏17\x*  
\v 35 وَارْ ثْنفّعْ ثَاروْڒَا إِ إِمكْسَاونْ ؤُڒَا ذ ونْجَامْ ن يِينِّي غَارْ إِدْجَا جّهْذْ خْ ثْحِيمْرِيوِينْ ن وُودْجِي.  
\v 36 سْحسّمْ مَامّشْ سْغُويُّونْ إِمكْسَاونْ س جّهْذْ، \add مَامّشْ\add* تّْرُونْ إِنِّي غَارْ إِدْجَا جّهْذْ خْ ثْحِيمْرِيوِينْ ن وُودْجِي، مِينْزِي سِيذِي إِتَّاردّدْجْ دّْمَانِي نْسنْ ن ثَاروْسَا.  
\v 37 مَاغَارْ دّْمَانِي ن ثَاروْسَا أَذْ ذوْڒنْ ؤُڭْنُونْ زِي سِّيبّثْ ن ڒْحَاذُوقْ ن وغْضَابْ ن سِيذِي.  
\v 38 أَمْ ويْرَاذْ أَمژْيَانْ إِجَّا نتَّا أَذُورِّي نّسْ، مَاغَارْ ثَامُّورْثْ نْسنْ ثذْوڒْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ س ڒْحَاذُوقْ \add ن سِّيفْ\add* ن ونِّي إِحصَّارنْ، س ڒْحَاذُوقْ ن وغْضَابْ نّسْ.‘ “   
\b  
\b  
\m  
\c 26
\s1 إِرْمِييَا ذِي زَّاوشْثْ ثَامقّْرَانْثْ - أَنقِّي ن ؤُنَابِي ؤُرِييَا  
\m
\v 1 ذڭْ ؤُمزْوَارُو ن ثْڭلْذَا ن يَاهُويَاقِيمْ، مِّيسْ ن يُوشِييَا، أَجدْجِيذْ ن يَاهُوذَا، يُوسَا-د وَاوَاڒْ-أَ زِي سِيذِي، إِنَّا:  
\v 2 ”أَمُّو إِ إِقَّارْ سِيذِي: ’بدّْ ذِي ڒمْرَاحْ ن زَّاثْ ن ثَادَّارْثْ ن سِيذِي ؤُشَا إِنِي مَارَّا أَوَاڒنْ-أَ نِّي زِي شكْ وصِّيغْ مَاحنْذْ أَذْ زَّايْسنْ ثسِّيوْڒذْ إِ \add إِمزْذَاغْ ن\add* مَارَّا ثِيندَّامْ ن يَاهُوذَا نِّي د-يُوسِينْ مَاحنْذْ أَذْ بنْذْقنْ ذِي ثَادَّارْثْ ن سِيذِي. وَارْ تّجِّي ؤُڒَا ذ إِجّْ ن وَاوَاڒْ وَارْ ث ثقَّارذْ.  
\v 3 أَذْ ثَاغْ أَذْ سْڒنْ، أَذْ د-ذوْڒنْ، كُوڒْ إِجّْ زڭْ وبْرِيذْ أَعفَّانْ نّسْ، ؤُشَا أَذْ نذْمغْ خْ ڒْغَارْ نِّي نْوِيغْ أَذْ ذَايْسنْ ث ڭّغْ زِي سِّيبّثْ ن ثُوعفّْنَا ن ثْمڭَّا نْسنْ. \x ◘ \xo 26:‏3 \xt إِرْم. 18‏:‏8\x*  
\v 4 إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي: مَاڒَا كنِّيوْ وَارْ ثتّخْسمْ أَذْ غَارِي ثسْڒمْ مَاحنْذْ أَذْ ثُويُورمْ عْلَاحْسَابْ شَّارِيعَا إِنُو نِّي ذ أَومْ ڭِّيغْ ذڭْ ؤُفُوسْ،  
\v 5 \add ؤُ مَاحنْذْ\add* أَذْ ثسْڒمْ غَارْ وَاوَاڒنْ ن إِمْسخَّارنْ إِنُو، إِنَابِييّنْ نِّي ذ أَومْ د-سّكّغْ زڭْ ؤُمزْوَارُو، وَاخَّا كنِّيوْ وَارْ \add ذ أَسنْ\add* ثسْڒِيمْ، \x ◘ \xo 26:‏5 \xt إِرْم. 7‏:‏13، 25؛ 11‏:‏7؛ 25‏:‏3\x*  
\v 6 خنِّي أَذْ ڭّغْ أَكْ-ذ ثَادَّارْثْ-أَ أَمْ ڭِّيغْ أَكْ-ذ شِيلُو، ؤُشَا أَذْ أَرّغْ ثَانْذِينْثْ ذ نّعْڒثْ إِ مَارَّا ڒڭْنُوسْ ذِي ثمُّورْثْ.‘ “ \x ◘ \xo 26:‏6 \xt 1 صم. 4‏:‏12؛ إِزهد. 78‏:‏60؛ إِرْم. 7‏:‏12، 14\x*   
\m
\v 7 إِكهَّاننْ ذ إِنَابِييّنْ ذ مَارَّا ڒْڭنْسْ سْڒِينْ مَامّشْ إِسِّيوڒْ إِرْمِييَا أَوَاڒنْ-أَ ذِي ثَادَّارْثْ ن سِيذِي.  
\v 8 ؤُمِي إِكمّڒْ إِرْمِييَا أَوَاڒْ خْ مَارَّا مِينْ ثُوغَا إِ ذ أَسْ إِوصَّا سِيذِي مَاحنْذْ أَذْ ث إِنَّا إِ مَارَّا ڒْڭنْسْ، طّْفنْ ث إِكهَّاننْ ذ إِنَابِييّنْ ذ مَارَّا ڒْڭنْسْ ؤُشَا نَّانْ: ”إِتّْخصَّا أَذْ ثمّْثذْ!  
\v 9 مَايمِّي ثْنبِّيذْ س يِيسمْ ن سِيذِي، ثنِّيذْ: ’ثَادَّارْثْ-أَ أَذْ ثذْوڒْ أَمْ شِيلُو ؤُ ثَانْذِينْثْ-أَ أَذْ ثتّْوَاردّدْجْ أَڒَامِي وَارْ ذَايسْ إِزدّغْ ؤُڒَا ذ إِجّنْ؟‘ “ مَارَّا ڒْڭنْسْ إِمُونْ خْ إِرْمِييَا ذِي ثَادَّارْثْ ن سِيذِي.   
\m
\v 10 ؤُمِي سْڒِينْ ڒْحُوكَّامْ ن يَاهُوذَا أَوَاڒنْ-أَ، فّْغنْ-د زِي ثَادَّارْثْ ن ؤُجدْجِيذْ ڭعّْذنْ غَارْ ثَادَّارْثْ ن سِيذِي، قِّيمنْ غَارْ وَاذَافْ ن ثوَّارْثْ ن جْذِيذْ ن ثَادَّارْثْ ن سِيذِي. \f ◼ \fr 26:‏10 \ft \+bd ’ثَامَايْنُوثْ‘\+bd* - نِيغْ: ’جْذِيذْ‘.\f*  
\v 11 \add خنِّي\add* سِّيوْڒنْ إِكهَّاننْ ذ إِنَابِييّنْ أَكْ-ذ ڒْحُوكَّامْ ؤُ أَكْ-ذ مَارَّا ڒْڭنْسْ، نَّانْ: ”أَرْيَازْ-أَ إِسْذَاهدْجْ ڒْموْثْ، أَمْ مَامّشْ ت ثسْڒَامْ س إِمزُّوغنْ نْومْ.“   
\m
\v 12 \add خنِّي\add* إِسِّيوڒْ  إِرْمِييَا أَكْ-ذ مَارَّا ڒْحُوكَّامْ ؤُ أَكْ-ذ مَارَّا ڒْڭنْسْ، إِنَّا: ”سِيذِي إِسّكّْ أَيِي-د حِيمَا أَذْ نبِّيغْ مَارَّا أَوَاڒنْ إِ ثسْڒِيمْ ضِيدّْ إِ ثَادَّارْثْ-أَ ؤُ ضِيدّْ إِ ثنْذِينْثْ-أَ.  
\v 13 \add خنِّي\add* ڒخُّو،عذْڒمْ إِبْرِيذنْ نْومْ ذ ثْمڭَّا نْومْ ؤُشَا صْڒمْ إِ ثْمِيجَّا ن سِيذِي، أَربِّي نْومْ، \add خنِّي\add* أَذْ إِنْذمْ سِيذِي زِي مَارَّا ڒْغَارْ إِ خَاومْ إِنَّا. \x ◘ \xo 26:‏13 \xt إِرْم. 7‏:‏3\x*  
\v 14 \add مَاشَا\add* نشّْ، خْزَارْ، أَقَا أَيِي ذڭْ ؤُفُوسْ نْومْ، ڭّمْ زَّايِي مَامّشْ إِ ذ أَومْ إِتّْغِيڒْ ذ لمْلِيحْ ذ نِيشَانْ ذِي ثِيطَّاوِينْ نْومْ.  
\v 15 سْنمْ \add مَاشَا\add* نِيشَانْ، مَاڒَا كنِّيوْ ثنْغِيمْ أَيِي، أَذْ د-ثَاوْيمْ إِذَامّنْ إِمزْذَاڭنْ خْ يِيخفْ نْومْ ؤُ خْ ثنْذِينْثْ-أَ ؤُ خْ إِمزْذَاغْ نّسْ، مِينْزِي س ثِيذتّْ، سِيذِي إِسّكّْ أَيِي-د غَارْومْ مَاحنْذْ أَذْ أَومْ إِنِيغْ مَارَّا أَوَاڒنْ-أَ ذڭْ إِمزُّوغنْ نْومْ.“   
\m
\v 16 ڒْحُوكَّامْ ذ مَارَّا ڒْڭنْسْ نَّانْ إِ إِكهَّاننْ ؤُ إِ إِنَابِييّنْ: ”أَرْيَازْ-أَ وَارْ إِسّْذِيحدْجْ ڒْموْثْ، مَاغَارْ نتَّا إِسَّاوَاڒْ أَكِيذْنغْ س يِيسمْ ن سِيذِي، أَربِّي نّغْ.“  
\v 17 شَا ن إِرْيَازنْ زڭْ إِمْغَارنْ ن ثمُّورْثْ كَّارنْ، بدّنْ. نِيثْنِي سِّيوْڒنْ غَارْ مَارَّا أَڭْرَاوْ ن ڒْڭنْسْ، نَّانْ:  
\v 18 ”مِيخَا زِي مُورَاشِيثْ ثُوغَا إِتّْنَابَّا ذڭْ وُوسَّانْ ن حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ؤُشَا إِسِّيوڒْ غَارْ مَارَّا ڒْڭنْسْ ن يَاهُوذَا، إِنَّا: ’أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: صِيهْيُونْ أَذْ ثتّْوَاشَارْزْ أَمْ يِيجّْ ن ييَّارْ ؤُ \add ثَانْذِينْثْ ن\add* ؤُرْشَالِيمْ أَذْ ثذْوڒْ ذ ڒْخَارْبثْ ؤُ أَذْرَارْ ن ثَادَّارْثْ-أَ \add أَذْ إِذْوڒْ\add* ذ ڒڭْعُوذِي \add مَانِي غَا وهّْبنْ ثِيوْهِيبِينْ\add* ذڭْ وزْغَارْ.‘ \f ◼ \fr 26:‏18 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  \x ◘ \xo 26:‏18 \xt مِيخَا 1‏:‏1؛ 3‏:‏12\x*  
\v 19 مَا إِنْغَا إِ-ث حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ذ مَارَّا يَاهُوذَا؟ مَا وَارْ إِڭّْوِيذْ نتَّا سِيذِي ؤُ إِكْسِي س ڒْمعْرُوفْ إِ سِيذِي أَڒَامِي إِنْذمْ خْ ڒْغَارْ إِ خَاسنْ إِقَّارْ؟ نشِّينْ أَذْ نڭّْ إِجّْ ن ڒْعِيبْ ذ أَمقّْرَانْ إِ يِيخفْ نّغْ.“ \f ◼ \fr 26:‏19 \ft \+bd ’إِ يِيخفْ نّغْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒعْمُورْ نّغْ‘.\f*   
\m
\v 20 ثُوغَا ذِينْ عَاذْ إِجّْ ن ورْيَازْ \add نّغْنِي\add* ونِّي ثُوغَا إِتّْنبَّانْ س يِيسمْ ن سِيذِي، ؤُرِييَا، مِّيسْ ن شَامْعِييَا، زِي قَارْيَاثْ-يَاعَارِيمْ. نتَّا إِنبَّا ضِيدّْ إِ ثنْذِينْثْ-أَ ؤُ ضِيدّْ إِ ثمُّورْثْ-أَ عْلَاحْسَابْ مَارَّا أَوَاڒنْ نِّي إِنَّا إِرْمِييَا.  
\v 21 \add خْمِي\add* إِسْڒَا ؤُجدْجِيذْ يَاهُويَاقِيمْ \add جْمِيعْ\add* أَكْ-ذ مَارَّا ڒْحُوكَّامْ أَوَاڒنْ نّسْ، إِخْسْ ؤُجدْجِيذْ أَذْ ث إِنغْ. إِسْڒَا ؤُرِييَا أَيَا، إِڭّْوذْ، يَارْوڒْ ؤُ يِيوضْ غَارْ مِيصْرَا.  
\v 22 أَجدْجِيذْ يَاهُويَاقِيمْ \add مَاشَا\add* إِسّكّْ إِرْيَازنْ غَارْ مِيصْرَا: إِلْ-نَاثَانْ، مِّيسْ ن عَاكْبُورْ أَكْ-ذ شَا ن إِرْيَازنْ. إِسّكّْ إِ-ثنْ غَارْ مِيصْرَا.  
\v 23 نِيثْنِي إِوْينْ-د ؤُرِييَا زِي مِيصْرَا ؤُشَا نذْهنْ ث غَارْ ؤُجدْجِيذْ يَاهُويَاقِيمْ ؤُ وَانِيثَا إِنْغَا إِ-ث س سِّيفْ. نتَّا إِنْضَارْ ڒْخشْبثْ نّسْ ذڭْ إِمضْڒَانْ ن ثَارْوَا ن ڒْڭنْسْ.   
\m
\v 24 \add مَاشَا\add* أَفُوسْ ن أَخِيقَامْ، مِّيسْ ن شَافَانْ، ثُوغَا-ث أَكْ-ذ إِرْمِييَا مَاحنْذْ وَارْ ث تِّيشنْ ذڭْ إِفَاسّنْ ن ڒْڭنْسْ مَاحنْذْ أَذْ ث نْغنْ.   
\b  
\b  
\m  
\c 27
\s1 أَخْضَاعْ إِ بَابِيلْ  
\m
\v 1 ذڭْ ؤُمزْوَارْ ن ثْڭلْذَا ن يَاهُويَاقِيمْ، مِّيسْ ن يُوشِييَا، أَجدْجِيذْ ن يَاهُوذَا، يُوسَا-د وَاوَاڒْ-أَ غَارْ إِرْمِييَا، إِنَّا:  
\v 2 ”أَمُّو إِ ذ أَيِي إِنَّا سِيذِي: ’أڭّْ إِ يِيخفْ نّشْ إِسغْوَانْ ذ إِزَايْڒُوثنْ، ؤُ سَّارْسْ إِ-ثنْ خْ يِيرِي نّشْ \x ◘ \xo 27:‏2 \xt إِرْم. 28‏:‏10\x*  
\v 3 ؤُشَا سكّْ إِ-ثنْ إِ ؤُجدْجِيذْ ن إِذُومْ، إِ ؤُجدْجِيذْ ن مُوآبَ، إِ ؤُجدْجِيذْ ن أَيْثْ ن عَامُّونْ، إِ ؤُجدْجِيذْ ن صُورْ ؤُ إِ ؤُجدْجِيذْ ن صِيذُونْ، س ؤُفُوسْ ن إِمْسخَّارنْ إِنِّي د-يُوسِينْ غَارْ ؤُرْشَالِيمْ غَارْ صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا.  
\v 4 ؤُمُورْ أَسنْ أَذْ إِنِينْ إِ إِسِيذِيثنْ نْسنْ: أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل، أَمُّو إِ إِتّْخصَّا أَذْ ثِينِيمْ إِ إِسِيذِيثنْ نْومْ:  
\v 5 س جّهْذْ إِنُو أَمقّْرَانْ ذ ؤُفُوسْ إِنُو إِسّْوِيژَّاذنْ ڭِّيغْ ثَامُّورْثْ ذ بْنَاذمْ ذ ڒبْهَايمْ نِّي إِدْجَانْ خْ وُوذمْ ن ثمُّورْثْ ؤُشَا نشّْ أَذْ ثنْ وْشغْ إِ ونِّي إِسْذَاهدْجنْ ذِي ثِيطَّاوِينْ إِنُو. \x ◘ \xo 27:‏5 \xt دَان. 4‏:‏14، 22\x*  
\v 6 \add خنِّي\add* ڒخُّو، نشّْ ڭِّيغْ مَارَّا ثِيمُّورَا-يَا ذڭْ ؤُفُوسْ ن نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، أَمْسخَّارْ إِنُو. وْشِيغْ أَسْ ؤُڒَا ذ ڒْمَاڒْ ن ييَّارْ، مَاحنْذْ أَذْ خَاسْ سخَّارنْ. \x ◘ \xo 27:‏6 \xt إِرْم. 25‏:‏9\x*  
\v 7 مَارَّا ڒڭْنُوسْ أَذْ أَسْ سخَّارنْ ؤُڒَا إِ مِّيسْ ذ مِّيسْ ن مِّيسْ أَڒَامِي إِ د غَا يَاسْ ڒْحَاڒْ إِ ثمُّورْثْ نّسْ. \add خنِّي\add* أَطَّاسْ ن ڒڭْنُوسْ ذ إِجدْجِيذنْ إِمقّْرَاننْ أَذْ ڭّنْ أَذْ زَّايسْ تّْوَاسخَّارنْ.  
\v 8 ڒْڭنْسْ ذ ثْڭلْذِيثْ إِ وَارْ إِخْسْ أَذْ أَسْ إِسخَّارْ إِ نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ؤُشَا وَارْ إِخْسْ أَذْ إِسّهْوَا إِڒِي نّسْ سْوَادَّايْ إِ ؤُزَايْڒُو ن ؤُجدْجِيذْ ن بَابِيلْ، أَقَا نشّْ أَذْ خڒْفغْ زِي ڒْڭنْسْ نِّي س سِّيفْ ذ ڒَاژْ ذ طَّاعُونْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَڒْ ثنْ إِ غَا قْضِيغْ س ؤُفُوسْ نّسْ.  
\v 9 كنِّيوْ \add خنِّي\add*، وَارْ تّسْڒِيمْ إِ إِنَابِييّنْ نْومْ ذ إِڭزَّاننْ نْومْ ذ أَيْثْ ن بُو-ثِيرْجَا نْومْ ذ إِبزْڭَاونْ نْومْ ذ إِسحَّارنْ نْومْ نِّي غَارْومْ إِسَّاوَاڒنْ، قَّارنْ: كنِّيوْ وَارْ ثْسخَّارَامْ شَا إِ ؤُجدْجِيذْ ن بَابِيلْ!،  
\v 10 مَاغَارْ نِيثْنِي تّْنبَّانْ س إِخَارِّيقنْ مَاحنْذْ أَذْ كنِّيوْ سِّيڭّْوجنْ خْ ثمُّورْثْ نْومْ، أَڒَامِي نشّْ أَذْ خَاونْ أَژّْڒغْ ؤُشَا كنِّيوْ أَذْ ثتّْوَاهلّْكمْ.  
\v 11 \add مَاشَا\add* ڒْڭنْسْ نِّي إِ غَا إِسَّاضَارنْ إِڒِي نّسْ سْوَادَّايْ إِ ؤُزَايْڒُو ن ؤُجدْجِيذْ ن بَابِيلْ ؤُشَا أَذْ أَسْ إِسّخَّارْ، أَقَا ڒْڭنْسْ نِّي أَذْ ث جّغْ أَذْ إِقِّيمْ ذِي ثمُّورْثْ نّسْ، ؤُشَا أَذْ ت إِشَارْزْ ؤُ أَذْ ذَايسْ إِزْذغْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\m
\v 12 \add خنِّي\add* سِّيوْڒغْ غَارْ صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، عْلَاحْسَابْ مَارَّا أَوَاڒنْ-أَ، نِّيغْ: ”ڭّمْ إِڒَاونْ نْومْ سْوَادَّايْ إِ ؤُزَايْڒُو ن ؤُجدْجِيذْ ن بَابِيلْ ؤُ سخَّارمْ أَسْ ؤُ إِ ڒْڭنْسْ نّسْ، \add خنِّي\add* أَذْ ثقِّيممْ ثدَّارمْ.  
\v 13 مَايمِّي غَا ثتّْوَانْغمْ، شكْ ذ ڒْڭنْسْ نّشْ، س سِّيفْ ذ ڒَاژْ ذ طَّاعُونْ، أَمْ مَامّشْ إِسِّيوڒْ سِيذِي خْ ڒْڭنْسْ إِ وَارْ إِخْسنْ أَذْ إِسخَّارْ إِ ؤُجدْجِيذْ ن بَابِيلْ.  
\v 14 وَارْ تّسْڒِيمْ إِ وَاوَاڒنْ ن إِنَابِييّنْ، إِنِّي غَارْومْ إِسَّاوَاڒنْ، قَّارنْ: ’كنِّيوْ وَارْ ثتّْسخَّارمْ شَا إِ ؤُجدْجِيذْ ن بَابِيلْ!‘، مَاغَارْ نِيثْنِي تّْنبَّانْ أَومْ س إِخَارِّيقنْ، \x ◘ \xo 27:‏14 \xt إِرْم. 14‏:‏14؛ 23‏:‏21؛ 29‏:‏8\x*  
\v 15 مِينْزِي نشّْ وَارْ ثنْ د-سّكّغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، ؤُ نِيثْنِي تّْنبَّانْ س إِخَارِّيقنْ س يِيسمْ إِنُو مَاحنْذْ أَذْ كنِّيوْ أَژّْڒغْ ؤُ كنِّيوْ أَذْ ثتّْوَاهلّْكمْ، كنِّيوْ ذ إِنَابِييّنْ نِّي ذ أَومْ إِتّْنَابّنْ،“   
\m
\v 16 سِّيوْڒغْ ؤُڒَا أَكْ-ذ إِكهَّاننْ ؤُ أَكْ-ذ مَارَّا ڒْڭنْسْ، نِّيغْ: ”أَمُّو إِ إِقَّارْ سِيذِي: ’وَارْ ثسْڒِيمْ غَارْ وَاوَاڒنْ ن إِنَابِييّنْ نْومْ إِ إِقَّارنْ: خْزَارْ، ڒقْشُوعْ زِي ثَادَّارْثْ ن سِيذِي أَذْ تّْوَارّنْ ذغْيَا زِي بَابِيلْ!، مَاغَارْ نِيثْنِي تّْنبَّانْ إِ كنِّيوْ س إِخَارِّيقنْ. \x ◘ \xo 27:‏16 \xt إِرْم. 28‏:‏3\x*  
\v 17 وَارْ غَارْسنْ تّسْڒِيمْ شَا، \add مَاشَا\add* سخَّارمْ إِ ؤُجدْجِيذْ ن بَابِيلْ، \add خنِّي\add* أَذْ ثقِّيممْ ثدَّارمْ. مَايمِّي غَا ثذْوڒْ ثنْذِينْثْ-أَ ذ إِشْثْ نْ ڒْخِيرْبثْ؟  
\v 18 مْڒِي نِيثْنِي ذ إِنَابِييّنْ، ؤُ أَوَاڒْ ن سِيذِي إِدْجَا \add س ثِيذتّْ\add* غَارْسنْ، أجّْ إِ-ثنْ أَذْ تَّارنْ إِ سِيذِي ن ڒْعسْكَارَاثْ، أَقَا ڒقْشُوعْ إِ إِقِّيمنْ عَاذْ ذِي ثَادَّارْثْ ن سِيذِي ؤُ ذِي ثَادَّارْثْ ن ؤُجدْجِيذْ ن يَاهُوذَا ذِي ؤُرْشَالِيمْ وَارْ تّْرِيحنْ غَارْ بَابِيلْ.  
\v 19 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ خْ إِپِيلَارنْ، خْ ڒبْحَارْ ن نّْحَاسْ، خْ ثْكَارُّوثِينْ ؤُ خْ مَارَّا ڒقْشُوعْ نّغْنِي إِ إِقِّيمنْ ذِي ثنْذِينْثْ-أَ،  
\v 20 إِنِّي وَارْ كِيذسْ إِكْسِي نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ؤُمِي إِنْذهْ يَاكُونْيَا، مِّيسْ ن يَاهُويَاقِيمْ، أَجدْجِيذْ ن يَاهُوذَا، زِي ؤُرْشَالِيمْ غَارْ بَابِيلْ أَكْ-ذ مَارَّا ثَارْوَا ن ثَاصِيڒثْ ن يَاهُوذَا ذ ؤُرْشَالِيمْ، \x ◘ \xo 27:‏20 \xt 2 إِج. 24‏:‏14، 15\x*  
\v 21 \add وَاهْ،\add* أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل، خْ ڒقْشُوعْ إِ إِقِّيمنْ ذِي ثَادَّارْثْ ن سِيذِي ؤُ ذِي ثَادَّارْثْ ن ؤُجدْجِيذْ ن يَاهُوذَا ؤُ ذِي ؤُرْشَالِيمْ:  
\v 22 غَارْ بَابِيلْ أَذْ مّكْسِينْ ؤُ أَذْ قِّيمنْ ذِينِّي أَڒْ أَسّْ إِ غَارْسنْ د غَا أَرْزْفغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. \add خنِّي\add* أَذْ ثنْ سُّوفّْغغْ ؤُ أَذْ ثنْ د-أَرّغْ غَارْ ومْشَانْ-أَ.‘ “ \x ◘ \xo 27:‏22 \xt 2 إِج. 25‏:‏13؛ 2 إِم. 36‏:‏18، 22؛ إِرْم. 29‏:‏10\x*   
\b  
\b  
\m  
\c 28
\s1 أَنَابِي حَانَانْيَا  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ نِّي، ذڭْ ؤُمزْوَارُو ن ثْڭلْذَا ن ؤُجدْجِيذْ صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعَا، ذڭْ ؤُيُورْ وِيسّْ خمْسَا، إِسِّيوڒْ أَكِيذِي حَانَانْيَا، مِّيسْ ن عَازُورْ، أَنَابِي زِي جِيبْعُونْ، ذِي ثَادَّارْثْ ن سِيذِي زَّاثْ إِ ثِيطَّاوِينْ ن إِكهَّاننْ ذ ڒْڭنْسْ إِمُونْ، إِنَّا:  
\v 2 ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل، إِقَّارْ: ’نشّْ أَذْ أَرْژغْ أَزَايْڒُو ن ؤُجدْجِيذْ ن بَابِيلْ.  
\v 3 عَاذْ ثْنَاينْ ن إِسڭّْوُوسَا \add خنِّي\add* نشّْ أَذْ د-أَرّغْ غَارْ ثمُّورْثْ-أَ مَارَّا ڒقْشُوعْ ن ثَادَّارْثْ ن سِيذِي، إِنِّي إِكْسِي نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، زڭْ ومْشَانْ-أَ ؤُشَا يِيوْيْ-إِ-ثنْ غَارْ بَابِيلْ. \x ◘ \xo 28:‏3 \xt إِرْم. 27‏:‏16\x*  
\v 4 نشّْ أَذْ سّْعقْبغْ يَاكُونْيَا، مِّيسْ ن يَاهُويَاقِيمْ، ذ مَارَّا إِمنْفِييّنْ زِي يَاهُوذَا إِ د-يِيوْضنْ غَارْ بَابِيلْ، غَارْ ومْشَانْ-أَ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، مِينْزِي نشّْ أَذْ أَرْژغْ أَزَايْڒُو ن ؤُجدْجِيذْ ن بَابِيلْ.‘ “   
\m
\v 5 \add خنِّي\add* إِنَّا ؤُنَابِي إِرْمِييَا إِ ؤُنَابِي حَانَانْيَا - زَّاثْ إِ ثِيطَّاوِينْ ن إِكهَّاننْ ؤُ زَّاثْ إِ ثِيطَّاوِينْ ن ڒْڭنْسْ إِمُونْ، إِنِّي إِبدّنْ ذِي ثَادَّارْثْ ن سِيذِي -  
\v 6 \add وَاهْ أَمُّو إِ\add* إِنَّا إِرْمِييَا: ”أَمِينْ، أَمُّو إِ غَا يڭّْ سِيذِي! إِڒِي أَذْ إِسّقْفڒْ سِيذِي أَوَاڒنْ نّشْ إِ ثْنبِّيذْ أَڒَامِي غَا يَارّْ ڒقْشُوعْ ن ثَادَّارْثْ ن سِيذِي ذ مَارَّا إِنِّي إِتّْوَانذْهنْ ذِي لْمنْفَا زِي بَابِيلْ غَارْ ومْشَانْ-أَ!  
\v 7 سڒْ \add مَاشَا\add* إِ وَاوَاڒْ-أَ إِ زِي سَّاوَاڒغْ ذڭْ إِمزُّوغنْ نْومْ ؤُ ذڭْ إِمزُّوغنْ ن ڒْڭنْسْ إِمُونْ:  
\v 8 ’إِنَابِييّنْ نِّي ثُوغَا \add ذِينْ\add* إِدْجَانْ قْبڒْ إِنُو ذ كنِّيوْ زڭْ وشْحَاڒْ ؤُيَا، نبَّانْ ضِيدّْ إِ وَاطَّاسْ ن ثمُّورَا ؤُ ضِيدّْ إِ وَاطَّاسْ ن ثْڭلْذِيثِينْ خْ ڭَارَّا، خْ إِشڒْوَاونْ ؤُ خْ طَّاعُونْ.  
\v 9 \add مَاشَا\add* أَنَابِي نِّي إِتّْنَابّنْ خْ سْڒَامْ، مَاڒَا أَوَاڒْ ن ؤُنَابِي نِّي أَذْ د-إِفّغْ، \add خنِّي\add* أَذْ يِيڒِي إِتّْوَاسّنْ \add س ثِيذتّْ\add* أَقَا سِيذِي إِسّكّْ-د أَنَابِي نِّي.‘ “   
\m
\v 10 \add خنِّي\add* إِكْسِي ؤُنَابِي حَانَانْيَا أَزَايْڒُو ن يِيرِي ن ؤُنَابِي إِرْمِييَا، يَارْژْ إِ-ث.  
\v 11 ؤُشَا إِسِّيوڒْ حَانَانْيَا زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا ڒْڭنْسْ، إِنَّا: ”أَمُّو إِ إِقَّارْ سِيذِي: ’قْبڒْ إِ غَا عْذُونْ ثْنَاينْ ن إِسڭّْوُوسَا كمّْڒنْ أَذْ أَرْژغْ أَزَايْڒُو ن نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، \add إِ  إِدْجَانْ\add* خْ يِيڒَاونْ ن مَارَّا ڒڭْنُوسْ.“ ؤُشَا إِرْمِييَا يُويُورْ أَبْرِيذْ نّسْ.   
\m
\v 12 \add خنِّي\add* يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِرْمِييَا أَوَارْنِي إِ ؤُمِي يَارْژَا ؤُنَابِي حَانَانْيَا أَزَايْڒُو خْ يِيڒَاونْ ن ؤُنَابِي إِرْمِييَا، إِنَّا:  
\v 13 ”ؤُيُورْ، سِيوڒْ أَكْ-ذ حَانَانْيَا، إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي: إِزَايْڒُوثنْ ن ؤُكشُّوضْ ثَارْژِيذْ ثنْ، \add مَاشَا\add* ثڭِّيذْ إِزَايْڒُوثنْ ن وُوزَّاڒْ ذڭْ ومْشَانْ نْسنْ.‘  
\v 14 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’إِجّْ ن ؤُزَايْڒُو ن وُوزَّاڒْ سَّارْسغْ ث خْ يِيڒَاونْ ن مَارَّا ڒڭْنُوسْ، مَاحنْذْ أَذْ سخَّارنْ إِ نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ. نِيثْنِي أَذْ أَسْ سخَّارنْ. ؤُڒَا ذ ڒْمَاڒْ وْشِيغْ ثنْ ذڭْ ؤُفُوسْ نّسْ.‘ “ \x ◘ \xo 28:‏14 \xt إِرْم. 27‏:‏6\x*   
\m
\v 15 \add خَاسْ ؤُشَا\add* إِنَّا ؤُنَابِي إِرْمِييَا إِ ؤُنَابِي حَانَانْيَا: ”سڒْ، حَانَانْيَا، سِيذِي وَارْ شكْ د إِسّكّْ شَا ؤُ شكْ ثْغَارّذْ ڒْڭنْسْ-أَ أَذْ إِتّْشڒْ خْ إِخَارِّيقنْ.  
\v 16 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي، خْزَارْ، نشّْ أَذْ شكْ نْضَارغْ. \add عَاذْ\add* ذڭْ ؤُسڭّْوَاسْ-أَ أَذْ ثمّْثذْ مِينْزِي ثسِّيوْڒذْ خْ ؤُحيّذْ ن سِيذِي.“ \x ◘ \xo 28:‏16 \xt أَعَوذ. 13‏:‏6؛ إِرْم. 29‏:‏32\x*  
\v 17 إِمُّوثْ ؤُنَابِي حَانَانْيَا ذڭْ ؤُسڭّْوَاسْ نِّي، ذڭْ ؤُيُورْ وِيسّْ سبْعَا.   
\b  
\b  
\m  
\c 29
\s1 ثَابْرَاثْ ن إِرْمِييَا إِ إِمحْبَاسْ ذِي بَابِيلْ  
\m
\v 1 إِنَا ذ أَوَاڒنْ ن ثبْرَاثْ إِ د-إِسّكّْ ؤُنَابِي إِرْمِييَا زِي ؤُرْشَالِيمْ إِ إِمْغَارنْ \add ن ڒْڭنْسْ\add* إِ إِقِّيمنْ جَارْ أَيْثْ ن لْمنْفَا إِ إِكهَّاننْ ذ إِنَابِييّنْ ؤُ إِ مَارَّا ڒْڭنْسْ نِّي ثُوغَا إِنْذهْ نابُوخَاذْنَاصَّارْ زِي ؤُرْشَالِيمْ ذِي لْمنْفَا غَارْ بَابِيلْ،  
\v 2 أَوَارْنِي إِ ؤُمِي إِفّغْ ؤُجدْجِيذْ يَاكُونْيَا ذ يمَّاسْ ن ؤُجدْجِيذْ، ڒَا إِمْسخَّارنْ إِشنّْعنْ، ڒَا ڒْحُوكَّامْ ن يَاهُوذَا ذ ؤُرْشَالِيمْ، ڒَا ڒمْعُودْجَامْ ؤُڒَا ذ إِمْزِيڒنْ زِي ؤُرْشَالِيمْ. \x ◘ \xo 29:‏2 \xt 2 إِج. 24‏:‏12 \x*  
\v 3 \add إِسّكّْ إِرْمِييَا ثَابْرَاثْ نِّي\add* س ؤُفُوسْ ن أَلْعَاسَا، مِّيسْ ن شَافَانْ، ذ جَامَارْيَا، مِّيسْ ن حِيلْقِييَا، إِنِّي إِسّكّْ صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، غَارْ بَابِيلْ غَارْ نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ. \add ثَابْرَاثْ\add* ثنَّا:   
\b  
\m
\v 4 ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل، إِ مَارَّا أَيْثْ ن لْمنْفَا نِّي د-إِوْيغْ زِي ؤُرْشَالِيمْ غَارْ بَابِيلْ:  
\v 5 ’سْڭعّْذمْ ثُوذْرِينْ ؤُشَا زذْغمْ ذَايْسنْثْ، ژُّومْ إِحْوِيشنْ ؤُشَا شّمْ ڒْغِيدْجثْ نْسنْ،  
\v 6 أَوْيمْ ثِيمْغَارِينْ ؤُشَا جّمْ-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ، أَوْيمْ إِ إِحنْجِيرنْ نْومْ ثِيمْغَارِينْ ؤُشَا وْشمْ ثْحنْجِيرِينْ نْومْ إِ يرْيَازنْ، مَاحنْذْ أَذْ ؤُرْونْثْ إِحنْجِيرنْ ذ ثْحنْجِيرِينْ. حْضَامْ أَذْ ذِينِّي ثمَّارْنِيمْ، وَارْ ثْنقّْصمْ،  
\v 7 أَرْزُومْ ڒهْنَا إِ ثنْذِينْثْ مَانِي كنِّيوْ إِ غَا نذْهغْ ؤُ تَّارمْ إِ مَانْ أَيَا إِ سِيذِي، مَاغَارْ ذِي ڒهْنَا نّسْ إِ إِدْجَا ڒهْنَا نْومْ.‘  
\v 8 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’وَارْ تّجِّيمْ أَذْ كنِّيوْ شمْثنْ إِنَابِييّنْ ذ إِڭزَّاننْ نِّي إِدْجَانْ ذِي ڒْوسْطْ نْومْ ؤُ وَارْ تّسْڒِيمْ شَا غَارْ أَيْثْ ن بُو-ثِيرْجَا إِ كنِّيوْ إِتّجَّانْ أَذْ ثَارْجَامْ، \x ◘ \xo 29:‏8 \xt إِرْم. 14‏:‏14؛ 23‏:‏31؛ 27‏:‏15\x*  
\v 9 مَاغَارْ نِيثْنِي تّْنبَّانْ إِخَارِّيقنْ س يِيسمْ إِنُو. نشّْ وَارْ ثنْ د-سكّغْ شَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.‘  
\v 10 مِينْزِي أَمُّو إِ إِقَّارْ سِيذِي: ’خْمِي غَا قفْڒنْ سبْعِينْ ن إِسڭّْوُوسَا ذِي بَابِيلْ، خنِّي أَذْ كنِّيوْ أَرْزْفغْ ؤُشَا أَذْ أَومْ كمّْڒغْ أَوَاڒْ إِنُو أَصبْحَانْ ؤُمِي كنِّيوْ غَا أَرّغْ غَارْ ثمُّورْثْ-أَ. \x ◘ \xo 29:‏10 \xt 2 إِم. 36‏:‏22؛ عِز. 1‏:‏1؛ إِرْم. 25‏:‏12؛ دَان. 9‏:‏2\x*  
\v 11 مَاغَارْ نشّْ سّْنغْ مَانْ إِخَارِّيصنْ إِ غَارِي خَاومْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، إِخَارِّيصنْ ن ڒهْنَا، وَارْ إِدْجِي ن ڒْغَارْ، حِيمَا أَذْ أَومْ وْشغْ إِمَارْ ذ ڒَايَاسْ.  
\v 12 \add مَاڒَا\add* كنِّيوْ أَذْ أَيِي ثْڒَاغَامْ، أَذْ غَارِي ثژَّادْجمْ، نشّْ أَذْ غَارْومْ سْڒغْ. \x ◘ \xo 29:‏12 \xt دَان. 9\x*  
\v 13 أَذْ خَافِي ثَارْزُومْ ؤُشَا أَذْ أَيِي ثَافمْ مَاڒَا كنِّيوْ ثَارْزُومْ خَافِي س مَارَّا وُوڒْ نْومْ.  
\v 14 أَذْ زَّايْومْ تّْوَافغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَذْ سّنْقڒْبغْ ثَامحْبَاسْثْ نْومْ ؤُشَا أَذْ كنِّيوْ سّْمُونغْ زِي مَارَّا ڒڭْنُوسْ ؤُ زِي مَارَّا إِمُوشَانْ مَانِي خَاومْ ؤُژّْڒغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، ؤُ نشّْ أَذْ كنِّيوْ أَرّغْ غَارْ ومْشَانْ إِ زِي كنِّيوْ نذْهغْ ذِي لْمنْفَا.‘ “\x ◘ \xo 29:‏14 \xt إِرْم. 23‏:‏3\x*   
\m
\v 15 ”\add مَاشَا\add* مِينْزِي ثنَّامْ: ’سِيذِي إِسّْنكَّارْ أَنغْ-د إِنَابِييّنْ ذِي بَابِيلْ!‘،  
\v 16 خْ ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي خْ ؤُجدْجِيذْ، ونِّي إِقِّيمنْ خْ ڒْعَارْشْ ن ذَاوُوذْ، ؤُ خْ مَارَّا ڒْڭنْسْ إِ إِزدّْغنْ ذِي ثنْذِينْثْ-أَ، أَيْثْمَاثْومْ إِنِّي وَارْ أَكِيذْومْ يُويُورنْ ذِي لْمنْفَا،  
\v 17 \add وَاهْ،\add* أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: ”خْزَارْ، نشّْ أَذْ سّكّغْ جَارْ أَسنْ سِّيفْ ذ ڒَاژْ ذ طَّاعُونْ ؤُشَا أَذْ ثنْ جّغْ أَمْ ثَازَارْثْ إِخْسَارنْ، ثنِّي وَارْ إِحْڒِينْ مَاحنْذْ أَذْ زَّايسْ شّنْ. \x ◘ \xo 29:‏17 \xt إِرْم. 24‏:‏8، 10\x*  
\v 18 نشّْ أَذْ ثنْ ضْفَارغْ س سِّيفْ ذ ڒَاژْ ذ طَّاعُونْ ؤُ نشّْ أَذْ ثنْ أَرّغْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ إِ مَارَّا ثِيڭلْذِيوِينْ ن دُّونشْثْ، أَذْ ثِيڒِيذْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* وخْزِي ذ ؤُسِيڭّْوذْ ذ ثْسضْحَاشْثْ ذ ڒْحڭْرَا جَارْ مَارَّا ڒڭْنُوسْ مَانِي ثنْ إِ غَا سُّوفّْغغْ. \x ◘ \xo 29:‏18 \xt أَعَوذ. 28‏:‏25، 37؛ إِرْم. 15‏:‏4؛ 24‏:‏9، 10\x*  
\v 19 مِينْزِي نِيثْنِي وَارْ سْڒِينْ غَارْ وَاوَاڒنْ إِنُو، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، ؤُمِي غَارْسنْ د-سّكّغْ إِمْسخَّارنْ إِنُو، إِنَابِييّنْ. عَاذْ زڭْ ؤُمزْوَارُو سّكّغْ ثنْ، مَاشَا كنِّيوْ وَارْ ثسْڒِيمْ شَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\m
\v 20 ”كنِّيوْ \add مَاشَا\add*، سْڒمْ إِ وَاوَاڒْ ن سِيذِي، مَارَّا كنِّيوْ إِنِّي إِتّْوَانذْهنْ ذِي لْمنْفَا، إِنِّي سّكّغْ زِي ؤُرْشَالِيمْ غَارْ بَابِيلْ.  
\v 21 أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل، خْ أَخَابْ، مِّيسْ ن قُولَايَا، ؤُ خْ صِيذْقِييَا، مِّيسْ ن مَاعَاسِييَا، إِنِّي ذ أَومْ إِتّْنبَّانْ ذڭْ يِيسمْ إِنُو س إِخَارِّيقنْ: ’خْزَارْ، نشّْ أَذْ ثنْ ڭّغْ ذڭْ ؤُفُوسْ ن نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ؤُ نتَّا أَذْ ثنْ إِنغْ زَّاثْ إِ ثِيطَّاوِينْ نْومْ.  
\v 22 مَارَّا أَيْثْ ن لْمنْفَا زِي يَاهُوذَا نِّي \add إِدْجَانْ\add* ذِي بَابِيلْ أَذْ زَّايْسنْ كّْسنْ إِشْثْ ن نّعْڒثْ، أَذْ إِنِينْ: سِيذِي أَذْ شكْ يڭّْ أَمْ صِيذْقِييَا ذ أَحَابْ نِّي إِشْنفْ ؤُجدْجِيذْ ن بَابِيلْ س ثْمسِّي!،  
\v 23 مِينْزِي نِيثْنِي ڭِّينْ إِشْثْ ن ثُوبُّوهڒْيَا ذِي إِسْرَائِيل: نِيثْنِي زْنَانْ أَكْ-ذ ثمْغَارِينْ ن وِي ثنْ يُوذْسنْ ؤُ بَارّْحنْ س يِيسمْ إِنُو أَوَاڒنْ ن إِخَارِّيقنْ إِ ثُوغَا وَارْ ذ أَسنْ نِّيغْ. نشّْ ذ ونِّي إِسّْننْ ذ ونِّي إِشهْذنْ \add خْ مَانْ أَيَا\add*!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\b  
\m
\v 24 \bd إِ شَامْعِييَا زِي نَاحْلَامْ\bd*، إِتّْخصَّا أَذْ كِيذسْ ثسِّيوْڒذْ أَذْ أَسْ ثِينِيذْ \add أَمُّو\add*:   
\m
\v 25 ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل، إِقَّارْ: ’مِينْزِي س إِسمْ نّشْ إِ-د-ثسّكّذْ ثِيبْرَاثِينْ إِ مَارَّا ڒْڭنْسْ ذِي ؤُرْشَالِيمْ ؤُ إِ ؤُكهَّانْ صَافَانْيَا، مِّيسْ ن مَاعَاسِييَا، ؤُ إِ مَارَّا إِكهَّاننْ، يُورَا ذَايْسنْ: \f ◼ \fr 29:‏25 \ft \+bd ’صَافَانْيَا‘\+bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي ث إِسّْنُوفَّارنْ سِيذِي‘.\f*   
\m
\v 26 سِيذِي إِڭَّا شكْ ذ أَكهَّانْ ذڭْ ومْشَانْ ن ؤُكهَّانْ يَاهُويَاذَاعْ، مَاحنْذْ أَذْ ذِينْ إِڒِينْ إِوقَّافنْ ذِي ثَادَّارْثْ ن سِيذِي خْ كُوڒْ إِجّْ ؤُبُوهَاڒِي نِّي إِتّڭّنْ إِخفْ نّسْ ذ أَنَابِي. أَذْ ث ثقّْنذْ خْ ؤُكشُّوضْ أَكْ-ذ ڒْڭِيذْ خْ يِيرِي \add نّسْ\add*. \x ◘ \xo 29:‏26 \xt إِرْم. 20‏:‏1، 2، 3\x*  
\v 27 خنِّي ڒخُّو، مَايمِّي وَارْ ثْعَاقْبذْ إِرْمِييَا زِي عَانَاثُوثْ، ونِّي خَاومْ إِتَّارَّانْ إِخفْ نّسْ ذ أَنَابِي؟  
\v 28 مَاغَارْ نتَّا إِسّكّْ-د \add إِشْثْ ن ثبْرَاثْ\add* إِ نشِّينْ ذِي بَابِيلْ مَانِي إِقَّارْ: أَطَّاسْ إِ غَا إِقِّيمنْ! سْبدّمْ ثُوذْرِينْ ؤُ زذْغمْ ذَايْسنْثْ، ژُّومْ إِحْوِيشنْ ؤُ أَذْ ثَاوْيمْ ڒِيقِّي إِ ڒْغِيدْجثْ نْسنْ!“   
\b  
\m
\v 29 ثُوغَا إِقَّارْ ؤُكهَّانْ صَافَانْيَا ثَابْرَاثْ-أَ ذڭْ إِمزُّوغنْ ن ؤُنَابِي إِرْمِييَا.  
\v 30 \add خنِّي\add* يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِرْمِييَا، إِنَّا:   
\m
\v 31 ”سْقَاذْ أَرقَّاسْ-أَ إِ مَارَّا أَيْثْ ن لْمنْفَا: ’أَمُّو إِ إِقَّارْ سِيذِي خْ شِيمْعِييَا زِي نَاحْلَامْ: مِينْزِي شَامْعِييَا ثُوغَا إِتّْنَابّْ أَومْ، وَاخَّا نشّْ وَارْ ث-إِ-د سّكّغْ، ؤُشَا يَارَّا كنِّيوْ أَذْ ثتِّيقّمْ ذڭْ إِخَارِّيقنْ!‘،\x ◘ \xo 29:‏31 \xt إِرْم. 28‏:‏15\x*  
\v 32 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي: ’خْزَارْ، نشّْ أَذْ خڒْفغْ إِ شَامْعِييَا زِي نَاحْلَامْ ؤُ زِي ثَارْوَا نّسْ. ؤُڒَا ذ إِجّنْ زڭْ إِنِّي نّسْ وَارْ إِتّْغِيمِي إِزْذغْ ذِي ڒْوسْطْ ن ڒْڭنْسْ-أَ ؤُ نتَّا وَارْ إِژَارّْ ڒْخِيرْ إِ غَا ڭّغْ إِ ڒْڭنْسْ إِنُو، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، مِينْزِي س ڒْهَارْذْ نّسْ إِڭَّا أَذْ حيّْذنْ خْ سِيذِي.‘ “ \x ◘ \xo 29:‏32 \xt إِرْم. 28‏:‏16\x*   
\b  
\b  
\m  
\c 30
\s1 أَڒقّحْ ن إِسْرَائِيل  
\m
\v 1 أَوَاڒْ نِّي د-يُوسِينْ زِي سِيذِي إِ إِرْمِييَا، إِنَّا:   
\m
\v 2 ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل، إِقَّارْ: ’أَرِي مَارَّا أَوَاڒنْ نِّي ذ أَشْ نِّيغْ ذڭْ إِجّْ ن وذْلِيسْ.  
\v 3 مَاغَارْ خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَذْ قڒْبغْ ثَامحْبَاسْثْ ن ڒْڭنْسْ إِنُو، إِسْرَائِيل ذ يَاهُوذَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. نشّْ أَذْ ثنْ أَرّغْ غَارْ ثمُّورْثْ إِ وْشِيغْ إِ ڒجْذُوذْ نْسنْ ؤُ نِيثْنِي أَذْ ت طّْفنْ ذ ثَاسْغَارْثْ.‘ “   
\b  
\m
\v 4 إِنَا ذ أَوَاڒنْ إِ زِي إِسِّيوڒْ سِيذِي خْ إِسْرَائِيل ذ يَاهُوذَا:   
\m
\v 5 ”مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: ’نسْڒَا ڒْحسّْ إِسِّيڭّْوَاذنْ، \add إِجّْ ن ڒْحسّْ\add* إِسّْنخْڒِيعنْ، وَارْ إِدْجِي \add ن\add* ڒهْنَا.  
\v 6 سقْسَامْ ؤُ خْزَارمْ، مَا إِزمَّارْ ورْيَازْ أَذْ يَارُووْ؟ مَايمِّي إِ تّْوَاڒِيغْ مَارَّا إِرْيَازنْ س إِفَاسّنْ خْ ثجْعِينَّا نْسنْ أَمْ يِيشْثْ ن ثمْغَارْثْ ثتَّارُو، ؤُ قَاعْ أَغمْبُوبْ إِذْوڒْ إِوَارْغْ أَمْ ڒْخشْبثْ؟ \x ◘ \xo 30:‏6 \xt إِرْم. 4‏:‏31؛ 6‏:‏24\x*  
\v 7 ؤُشْثْ، مَاغَارْ ذ أَمقّْرَانْ أَسّْ نِّي، وَارْ إِدْجِي ؤُڒَا ذ إِجّنْ أَمْ نتَّا. إِشْثْ ن ڒْوقْثْ ن ڒحْصَارثْ إِ يَاعْقُوبْ، \add مَاشَا\add* نتَّا أَذْ زَّايسْ إِتّْوَاسّنْجمْ. \x ◘ \xo 30:‏7 \xt يُووِ. 2‏:‏11؛ صَاف. 1‏:‏15\x*  
\v 8 ذڭْ وَاسّْ نِّي أَذْ إِمْسَارْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَذْ أَرْژغْ أَزَايْڒُو خْ يِيڒَاونْ نّشْ. إِبَارَّانِييّنْ وَارْ ث تّجِّينْ أَذْ خَاسنْ إِسخَّارْ \add عَاذْ أَمْ يِيسْمغْ\add*،  
\v 9 نِيثْنِي أَذْ سخَّارنْ إِ سِيذِي، أَربِّي نْسنْ، ؤُڒَا إِ ؤُجدْجِيذْ نْسنْ ذَاوُوذْ ونِّي د غَا سّكَّارغْ ذِي طّْوعْ نْسنْ.‘ “ \x ◘ \xo 30:‏9 \xt حِز. 34‏:‏23، 24؛ 37‏:‏24؛ حُوش. 3‏:‏5\x*   
\m
\v 10 ”وَارْ ثڭّْوذْ، \add أَ\add* شكْ أَمْسخَّارْ إِنُو يَاعْقُوبْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، وَارْ ثفْشِيڒْ شَا، \add أَ\add* إِسْرَائِيل، مَاغَارْ خْزَارْ، نشّْ أَذْ شكْ سّْنجْمغْ زِي ثِيمُّورَا إِڭّْوجنْ ؤُڒَا ذ زَّارِيعثْ نّشْ زِي ثْمحْبَاسْثْ نْسنْ. أَذْ يَارڭّْوحْ يَاعْقُوبْ، أَذْ غَارسْ ثِيڒِي ڒْهُوذْنثْ، أَذْ إِدَّارْ ذِي ڒَامَانْ ؤُشَا ؤُڒَا ذ إِجّْ وَارْ ث إِسّْنخْڒِيعْ. \x ◘ \xo 30:‏10 \xt إِشا. 41‏:‏13؛ 43‏:‏5؛ 44‏:‏1؛ إِرْم. 46‏:‏28\x*  
\v 11 مَاغَارْ نشّْ أَكِيذكْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، حِيمَا أَذْ شكْ سّْنجْمغْ، مَاغَارْ نشّْ أَذْ قْضِيغْ مَارَّا ڒڭْنُوسْ نِّي غَارْ شكْ زُوزَّارغْ، مَاشَاعمَّارْصْ وَارْ شكْ قطِّيغْ، \add مَاشَا\add* أَذْ شكْ أَربِّيغْ س ڒعْبَارْ إِسڭّْذنْ ؤُ وَارْ شكْ هضّْبغْ ذ أَمزْذَاڭْ.“ \x ◘ \xo 30:‏11 \xt إِشا. 27‏:‏8؛ إِرْم. 4‏:‏27؛ 5‏:‏10، 18؛ 10‏:‏24؛ 46‏:‏28\x*   
\m
\v 12 ”مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: ’ثَارژِّيثْ نّمْ وَارْ ثْزمَّارْ أَذْ ثڭّنْفَا، أَيزِّيمْ نّمْ إِتّقّسْ. \x ◘ \xo 30:‏12 \xt إِرْم. 10‏:‏19؛ 15‏:‏18\x*  
\v 13 ؤُڒَا ذ إِجّْ وَارْ خَامْ إِسّْعِيزّْ أَڒْ إِ شمْ إِ غَا إِشْفنْ، وَارْ غَارمْ شَا دَّاوَاثْ حِيمَا أَذْ ثنْثْ ثڭّذْ خْ ثْحبُّوشْثْ نّمْ.  
\v 14 مَارَّا إِنِّي ثُوغَا إِ شمْ إِتّخْسنْ تُّونْ شمْ، وَارْ خَامْ تّْسقْسِينْ، مَاغَارْ أَمْ مَامّشْ إِشَّاثْ ڒعْذُو أَمُّو إِ شمْ وْثِيغْ، أَمْ يِيجّنْ إِ يَاربَّانْ س ڒقْسَاحثْ، زِي سِّيبّثْ ن ڒْمُوعْصِييّثْ نّمْ إِمْغَارنْ، \add مَاغَارْ\add* دّْنُوبْ نّمْ وسْعنْ أَطَّاسْ. \x ◘ \xo 30:‏14 \xt إِرْم. 22‏:‏20\x*  
\v 15 مَايمِّي ثسْغُويُّوذْ \add أَمُّو\add* خْ ثْرژِّيثْ نّمْ، خْ ڒحْرِيقْ نّمْ إِ وَارْ إِزمَّارنْ أَذْ إِڭّنْفَا؟ زِي سِّيبّثْ ن ڒْمُوعْصِييّثْ نّمْ إِمْغَارنْ، \add مَاغَارْ\add* دّْنُوبْ نّمْ وسْعنْ أَطَّاسْ، نشّْ ڭِّيغْ ذَايمْ مَانْ أَيَا. \x ◘ \xo 30:‏15 \xt إِرْم. 5‏:‏6؛ 13‏:‏17\x*  
\v 16 س ؤُيَا، مَارَّا إِنِّي شمْ إِتّفّْزنْ، أَذْ تّْوَاشّنْ \add سِيمَانْثْ نْسنْ\add*، ؤُشَا مَارَّا إِغْرِيمنْ نّمْ أَذْ ؤُيُورنْ ذِي ثْمحْبَاسْثْ، ؤُ إِنِّي شمْ إِكشّْضنْ، أَذْ تّْوَاكشّْضنْ ؤُ مَارَّا إِنِّي شمْ يُوشَارنْ، أَذْ ثنْ وْشغْ ذ ثُوكَّارْضَا. \x ◘ \xo 30:‏16 \xt ؤُف. 23‏:‏22؛ إِشا. 41‏:‏11؛ إِرْم. 10‏:‏25\x*  
\v 17 مَاغَارْ نشّْ أَذْ شمْ شفْنغْ ؤُ أَذْ شمْ سّْڭنْفِيغْ زڭْ إِيزِّيمنْ نّمْ نِّي إِ ذَايمْ وْثِينْ نِيثْنِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، مِينْزِي نِيثْنِي ڒَاغَانْ أَمْ ’ثَامنْضَارْثْ!‘، قَّارنْ: أَقَا-ت ذ صِيهْيُونْ، وَارْ خَاسْ إِتّْسقْسِي ؤُڒَا ذ إِجّْ!‘ “   
\m
\v 18 ”أَمُّو إِ إِقَّارْ سِيذِي: ’خْزَارْ، أَذْ سّنْقڒْبغْ ثَامحْبَاسْثْ ن إِقِيضَانْ ن يَاعْقُوبْ ؤُشَا أَذْ أَرحْمغْ خْ ثْزذِّيغِينْ نْسنْ. أَذْ بْنَانْ ثَانْذِينْثْ عَاوذْ خْ ڒْخِيرْبَاثْ نّسْ ؤُشَا ڒقْصَارْ أَذْ د-إِذْوڒْ غَارْ ومْشَانْ نّسْ إِصحّْ.  
\v 19 أَذْ زَّايْسنْ إِفّغْ \add إِجّْ ن إِزْڒِي ن\add* ؤُقَاذِي ذ إِشْثْ ن ثْمِيجَّا ن يوْذَانْ إِفَارّْحنْ. نشّْ أَذْ ثنْ أَرّغْ ذڭْ وَاطَّاسْ، نِيثْنِي وَارْ ذِيكّْوِيڒنْ ذْرُوسْ، ؤُ نشّْ أَذْ أَسنْ ڭّغْ ڒْعزّْ ؤُ نِيثْنِي وَارْ تّْوَاسّحْقِيرِينْ \add عَاذْ\add*. \x ◘ \xo 30:‏19 \xt إِرْم. 31‏:‏4\x*  
\v 20 إِحنْجِيرنْ نّسْ أَذْ إِڒِينْ أَمْ يِينِّي زڭْ وشْحَاڒْ ؤُيَا ؤُشَا ثَامسْمُونْثْ نّسْ أَذْ ثِيڒِي زَّاثْ إِ وُوذمْ إِنُو ؤُ نشّْ أَذْ خڒْفغْ زڭْ إِنِّي إِ-ثنْ إِحْصَارنْ.  
\v 21 أَمْزمَّارْ نّسْ أَذْ زَّايسْ يِيڒِي ؤُ ڒْحَاكمْ نّسْ أَذْ زَّايسْ إِفّغْ ؤُ نشّْ أَذْ ث-إِ-د-سّْقَارّْبغْ ؤُ نتَّا أَذْ أَيِي د-يَاذسْ، مَاغَارْ مَانْ ونْ إِدْجَانْ ذ أَضْمَانْ س وُوڒْ نّسْ مَاحنْذْ أَذْ غَارِي د-يَاذسْ؟‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\b  
\m
\v 22 ”كنِّيوْ أَذْ أَيِي ثِيڒِيمْ ذ ڒْڭنْسْ إِنُو ذ نشّْ أَذْ إِڒِيغْ ذ أَربِّي نْومْ.“\x ◘ \xo 30:‏22 \xt إِرْم. 24‏:‏7؛ 31‏:‏1، 33؛ 32‏:‏38\x*   
\b  
\m
\v 23 ”خْزَارْ، ثَاحَارْيَاضْثْ ن سِيذِي، إِفّغْ-د \add زَّايسْ\add* وسْعَارْ، \add أَمْ\add* ثْحَارْيَاضْثْ ثزّبْزِيبْ نِّي إِ غَا إِهْوَانْ خْ ؤُزدْجِيفْ ن إِعفَّاننْ. \x ◘ \xo 30:‏23 \xt إِرْم. 23‏:‏19، 20؛ 25‏:‏32\x*  
\v 24 ڒْحَاذُوقْ ن وغْضَابْ ن سِيذِي وَارْ إِتّْبذِّي شَا أَڒْ ذ إِڭَّا إِخَارِّيصنْ ن وُوڒْ نّسْ ؤُشَا إِكمّڒْ إِ-ثنْ. ذڭْ ؤُنڭَّارْ ن وُوسَّانْ أَذْ أَسْ ثْفهْممْ.“   
\b  
\b  
\m  
\c 31
\m
\v 1 ”ذِي ڒْوقْثْ نِّي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَذْ إِڒِيغْ ذ أَربِّي إِ مَارَّا ڒَادْجَاثْ ن إِسْرَائِيل ؤُ نِيثْنِي أَذْ إِڒِينْ ذ ڒْڭنْسْ إِنُو.“   
\m
\v 2 ”أَمُّو إِ إِقَّارْ سِيذِي: ’ڒْْڭنْسْ ن يِينِّي إِنجْمنْ زِي سِّيفْ، يُوفَا أَرْضَا ذِي ڒخْڒَا، أجّْ أَيِي أَذْ رَاحغْ نشّْ مَاحنْذْ أَذْ ث سَّاريّْحغْ، \add وَاهْ، مَاحنْذْ أَذْ سَّاريّْحغْ\add* إِسْرَائِيل!‘ “   
\m
\v 3 ”زِي ڒَاڭّْوَاجْ إِبَانْ أَيِي-د سِيذِي!“ ...  
\b  
\m ”نشّْ ثُوغَا تّخْسغْ شمْ س ثَايْرِي ن ڒبْذَا، خْ ؤُيَا شمْ د-جبْذغْ س ثْمخْسِيوْثْ إِشوَّارنْ.  
\v 4 نشّْ أَذْ شمْ بْنِيغْ عَاوذْ، أَذْ ثتّْوَابْنِيذْ عَاوذْ، \add أَ شمْ\add* إِسْرَائِيل ثَاعْزَارشْثْ. شمْ أَذْ ثْزوّْقذْ إِخفْ نّمْ عَاوذْ س إِبنْذِيرنْ، أَذْ ثفّْغذْ س شّْضِيحْ س نُّوبْثَاثْ ن يِينِّي إِفَارّْحنْ. \x ◘ \xo 31:‏4 \xt إِرْم. 30‏:‏19\x*  
\v 5 أَذْ ثژُّوذْ ثِيزَايَارِينْ ذڭْ إِمَارْجَاعنْ خْ إِذُورَارْ ن سَامَارْيَا: إِنِّي إِتّژُّونْ أَذْ ثنْثْ ژُّونْ ؤُ ڒْغِيدْجثْ أَذْ زَّايسْ أَرّنْ مژْرِي. \x ◘ \xo 31:‏5 \xt إِشا. 65‏:‏21\x*  
\v 6 مَاغَارْ أَذْ د-يَاسْ وَاسّْ نِّي ذِي أَذْ ڒَاغَانْ إِعسَّاسنْ خْ إِذُورَارْ ن إِفْرَايِيمْ: ’كَّارمْ، أجّْ أَنغْ أَذْ نْڭعّذْ غَارْ صِيهْيُونْ، غَارْ سِيذِي، أَربِّي نّغْ!‘ “ \x ◘ \xo 31:‏6 \xt إِشا. 2‏:‏2، 3؛ مِيخَا 4‏:‏2\x*   
\m
\v 7 ”مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: ’غنّْجمْ س ڒفْرَاحثْ إِ يَاعْقُوبْ، سْڒِيوْڒِيومْ إِ ؤُزدْجِيفْ ن ڒڭْنُوسْ، بَارّْحمْ، سمْغَارمْ ث، إِنِيمْ: \add أَ\add* سِيذِي، سنْجمْ ڒْڭنْسْ نّشْ، مِينْ إِقِّيمنْ زِي إِسْرَائِيل.  
\v 8 خْزَارْ، نشّْ أَذْ ثنْ أَرّغْ أَذْ د-أَسنْ زِي ثمُّورْثْ ن شَّامَالْ ؤُ نشّْ أَذْ ثنْ سّْمُونغْ زڭْ إِنڭُّورَا ن ثمُّورْثْ. أَقَا ذِينْ جَارْ أَسنْ إِذَارْغَاڒنْ ذ إِنعْضَابنْ، ثِينِّي إِدْجَانْ س دّيْسثْ ذ ثِينِّي إِتَّارْونْ. أَذْعقْبنْ غَارْ ذَا س إِجّْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add* أَمقّْرَانْ. \x ◘ \xo 31:‏8 \xt إِرْم. 3‏:‏18\x*  
\v 9 أَذْ د-أَسنْ تّْرُونْ، أَذْ ثنْ ڭوّْذغْ أَمْ كسِّينْ س ڒْمعْرُوفْ. أَذْ ثنْ سّْنذْهغْ غَارْ ثغْزَارِينْ ن وَامَانْ، خْ إِجّْ ن وبْرِيذْ إِسڭّْمنْ مَانِي وَارْ تّْنقْرِيضنْ، مَاغَارْ نشّْ ذ بَابَاسْ إِ إِسْرَائِيل ؤُ إِفْرَايِيمْ ذ مِّي أَمنْزُو.‘ “ \x ◘ \xo 31:‏9 \xt ؤُف. 4‏:‏22\x*   
\m
\v 10 ”سْڒمْ إِ وَاوَاڒْ ن سِيذِي، \add أَ\add* كنِّيوْ ڒڭْنُوسْ، بَارّْحمْ ث خْ ثڭْزِيرِينْ نِّي إِڭّْوجنْ أَطَّاسْ، إِنِيمْ: ’ذ ونِّي ثُوغَا إِزُّوزَارنْ إِسْرَائِيل، أَذْ ث إِسّْمُونْ عَاوذْ ؤُ أَذْ ث يَارْوسْ أَمْ مَامّشْ يَاركّْوسْ ؤُمكْسَاوْ ثَاحِيمَارْثْ نّسْ.  
\v 11 مَاغَارْ سِيذِي أَقَا إِفْذِي يَاعْقُوبْ ؤُشَا إِفكّْ إِ-ث زڭْ ؤُفُوسْ ن ونِّي خَاسْ إِجهْذنْ.‘\f ◼ \fr 31:‏11 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78‏:35.\f*  \x ◘ \xo 31:‏11 \xt إِشا. 40‏:‏10؛ 49‏:‏24، 25\x*  
\v 12 نِيثْنِي أَذْ د-أَسنْ ؤُ أَذْ سْڒِيوْڒونْ خْ ڒْڭعّْذثْ ن صِيهْيُونْ ؤُشَا أَذْ أَزّْڒنْ غَارْ ڒْخَارْ ن سِيذِي، غَارْ إِمنْذِي، غَارْ بِينُو ن جْذِيذْ، غَارْ زّشْثْ، غَارْ إِزْمَارنْ ؤُ غَارْ إِفُونَاسنْ ذ ثْفُونَاسِينْ. ڒعْمَارْ نْسنْ أَذْ يِيڒِي أَمْ ڒعْرَاصِي إِتّْوَاسُّونْ ؤُشَاعمَّارْصْ \add عَاذْ\add* أَذْ إِڒِينْ شضْننْ. \x ◘ \xo 31:‏12 \xt إِشا. 61‏:‏11\x*  
\v 13 خنِّي أَذْ ثْفَارْحْ ثعْزَارشْثْ غَارْ شّْضِيحْ س نُّوبْثَاثْ، ؤُڒَا ذ إِحُوذْرِييّنْ ذ إِوسُّورَا، \add نِيثْنِي مَارَّا\add* مُوننْ، مِينْزِي نشّْ أَذْ أَرّغْ أَشْضَانْ نْسنْ ذ أَرْشُوقْ، أَذْ ثنْعزِّيغْ، أَذْ ثنْ سّْفَارْحغْ أَوَارْنِي وشْضَانْ نْسنْ.  
\v 14 نشّْ أَذْ سّْجِيوْنغْ ڒعْمَارْ ن إِكهَّاننْ س ثَاذُونْثْ \add ن ثْغَارْصَا\add* ؤُشَا أَذْ إِذْوڒْ ڒْڭنْسْ إِنُو إِجِّيونْ س ڒْخَارْ إِنُو، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\m
\v 15 ”أَمُّو إِ إِقَّارْ سِيذِي: ’ثتّْوَاسڒْ إِشْثْ ن ثْمِيجَّا ذِي رَامَا، أَوعّذْ ذ إِمطَّاونْ إِمَارْزَاڭنْ: رَاحِيلْ ثتّْرُو خْ ثَارْوَا نّسْ ؤُ وَارْ ثتّخْسْ أَذْ ثتّْوَاعزَّا خْ إِحنْجِيرنْ نّسْ، مَاغَارْ نِيثْنِي وَارْ دْجِينْ \add عَاذْ\add*.‘ \x ◘ \xo 31:‏15 \xt مت. 2‏:‏17، 18\x*  
\v 16 أَمُّو إِ إِقَّارْ سِيذِي: ’طّفْ ثْمِيجَّا نّمْ إِ ؤُنِيخْسسْ ؤُ ثِيطَّاوِينْ نّمْ إِ إِمطَّاونْ، مَاغَارْ أَقَا ثدْجَا ڒْمُونثْ إِ وَارْبرْ نّمْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، مَاغَارْ نِيثْنِي أَذْ د -عقْبنْ زِي ثمُّورْثْ ن ڒعْذُو.  
\v 17 أَقَا ذِينْ ڒَايَاسْ إِ ثَارْوَا نّمْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، مَاغَارْ إِحنْجِيرنْ \add نّمْ\add* أَذْ د-ذوْڒنْ غَارْ ثمُّورْثْ نْسنْ.‘ “   
\m
\v 18 ”نشّْ سْڒِيغْ مْلِيحْ مَامّشْ د-إِتّْشثْشَا إِفْرَايِيمْ، إِنَّا: ’شكْ ثَاربِّيذْ أَيِي ؤُ نشّْ تّْوَاربِّيغْ أَمْ يِيجّْ ن ؤُعجْمِي وَارْ إِتّْضَاوَاعنْ. أَرّْ أَيِي، \add ذغْيَا\add* نشّْ خْسغْ أَذْ د-ذوْڒغْ، مَاغَارْ شكْ ذ سِيذِي، أَربِّي إِنُو. \x ◘ \xo 31:‏18 \xt إِڭجذ. 5‏:‏21\x*  
\v 19 مَاغَارْ أَوَارْنِي ڒَامِي د-ذوْڒغْ، ثُوبغْ، ؤُ أَوَارْنِي ڒَامِي ذوْڒغْ سّْنغْ، وْثِيغْ إِخفْ إِنُو خْ ثْمصَّاضِينْ. نشّْ سضْحِيغْ، نْفضْحغْ، مَاغَارْ نشّْ أَرْبُوغْ ڒفْضِيحثْ ن ثمْژِي إِنُو.‘ \x ◘ \xo 31:‏19 \xt أَعَوذ. 30‏:‏2\x*  
\v 20 مَا وَارْ إِدْجِي إِفْرَايِيمْ ذ مِّي إِغْڒَانْ غَارِي ذ أَحنْجِيرْ إِنُو إِعِيزّنْ؟ مَاغَارْ كُوڒْ إِشْثْ ن ثْوَاڒَا سِّيوْڒغْ غَارسْ \add س ؤُفُوسْ ن إِنَابِييّنْ\add*، قِّيمغْ تِّيذَارغْ ث. خْ ؤُيَا إِشَّاثْ جُّوفْ إِنُو ذَايِي. نِيشَانْ نشّْ أَذْ خَاسْ أَرّحْمغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\m
\v 21 ”سْبدّْ إِقُودْجَايْ \add إِ وسْشَانْ ن وبْرِيذْ\add*، سَارْسْ إِژْرَا \add ن جُّورَّاثْ ن وبْرِيذْ\add*، أڭّْ ؤُڒْ نّمْ خْ وبْرِيذْ إِسڭّْمنْ، خْ وبْرِيذْ نِّي ذِي ثڭُّورذْ. ذْوڒْ، \add أَ\add* ثَاعْزَارشْثْ إِسْرَائِيل، ذْوڒْ غَارْ ثْندَّامْ نّمْ.  
\v 22 أَڒْ مڒْمِي عَاذْ ثخْسذْ أَذْ ثقِّيمذْ ثتّْلِيعذْ، \add أَ شمْ،\add* يدْجِيسْ إِ \add خَافِي\add* إِحيّْذنْ؟ مَاغَارْ سِيذِي إِڭَّا إِشْثْ ن ڒْحَاجّثْ ن جْذِيذْ ذِي ثمُّورْثْ: ثَامْغَارْثْ أَذْ ثتّْهِيلَّا \add مَارَّا\add* إِ ورْيَازْ.“   
\m
\v 23 ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’أَذْ سِّيوْڒنْ أَوَاڒْ-أَ عَاوذْ ذِي ثمُّورْثْ ن يَاهُوذَا ؤُ ذِي ثْندَّامْ نّسْ خْمِي غَا سّنْقڒْبغْ ثَامحْبَاسْثْ نْسنْ: أَذْ شمْ إِبَاركْ سِيذِي، \add أَ\add* ثَازذِّيغْثْ ن ثْسڭْذَا، \add أَ\add* أَذْرَارْ إِقدّْسنْ! \x ◘ \xo 31:‏23 \xt إِرْم. 50‏:‏7\x*  
\v 24 يَاهُوذَا ذ مَارَّا ثِيندَّامْ نّسْ أَذْ ذَايسْ زدّْغنْثْ جْمِيعْ، إِفدْجَاحنْ ذ يِينِّي إِتّثْلِيعنْ أَكْ-ذ ثْحِيمَارْثْ.  
\v 25 مَاغَارْ نشّْ سّسُّوغْ ڒعْمَارْ يُوحْڒنْ ؤُشَا سّْجِيوْنغْ كُوڒْ ڒعْمَارْ إِحْزنْ.‘ “   
\b  
\m
\v 26 أَوَارْنِي أَيَا فَاقغْ-د ؤُشَا ؤُشِيغْ مشْحَارْ يِيزِيضْ يِيضصْ إِنُو.   
\b  
\m
\v 27 ”خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَذْ زَارْعغْ ثَادَّارْثْ ن إِسْرَائِيل ذ ثَادَّارْثْ ن يَاهُوذَا س زَّارِّيعثْ ن إِوْذَانْ ذ ڒْمَاڒْ.  
\v 28 أَمْ مَامّشْ خَاسنْعسّغْ حِيمَا أَذْ قڒْعغْ، أَذْ هذْمغْ، أَذْ أَرْژغْ، أَذْ أَردّْدْجغْ ؤُ أَذْ ڭّغْ ڒْغَارْ، أَمُّو إِ خَاسنْ إِ غَاعسّغْ حِيمَا أَذْ سّْبدّغْ ؤُ حِيمَا أَذْ ژُّوغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 29 ذڭْ وُوسَّانْ نِّي وَارْ تّْغِيمِينْ أَذْ إِنِينْ عَاذْ: ’إِبَابَاثنْ شِّينْ أَضِيڒْ أَسمَّامْ ؤُشَا ذوْڒنْثْ ثغْمَاسْ ن إِحنْجِيرنْ حْفَانْثْ.‘ \x ◘ \xo 31:‏29 \xt حِز. 18‏:‏2، 3\x*  
\v 30 مَاشَا كُوڒْ إِجّْ أَذْ إِمّثْ زِي سِّيبّثْ ن ڒْمُوعْصِييّثْ \add ن يِيخفْ\add* نّسْ. زِي مْكُوڒْ بْنَاذمْ نِّي إِ غَا إِشّنْ أَضِيرْ أَسمَّامْ، أَذْ أَسْ ذوْڒنْثْ ثغْمَاسْ حْفَانْثْ.“   
\m
\v 31 ”خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، نِّي ذِي غَا ڭّغْ إِجّْ ن ڒْعَاهْذْ ن جْذِيذْ أَكْ-ذ ثَادَّارْثْ ن إِسْرَائِيل ؤُ أَكْ-ذ ثَادَّارْثْ ن يَاهُوذَا، \x ◘ \xo 31:‏31 \xt إِرْم. 31‏:‏31؛ مت. 26‏:‏28، مك. 14‏:‏24، لك. 22‏:‏20، 1 كُور. 11‏:‏25، 2 كُور. 3‏:‏6، عبر. 8‏:‏6، 8، 13؛ 9‏:‏15؛ 12‏:‏24\x*  
\v 32 وَارْ إِدْجِي أَمْ مَامّشْ ڒْعَاهْذْ إِ ڭِّيغْ أَكْ-ذ ڒجْذُوذْ نْسنْ ؤُمِي ثنْ طّْفغْ زڭْ ؤُفُوسْ، حِيمَا أَذْ ثنْ نذْهغْ زِي ثمُّورْثْ ن مِيصْرَا، ڒْعَاهْذْ إِنُو نِّي أَرْژِينْ، وَاخَّا زعْمَا نشّْ ذوْڒغْ ذ أَرْيَازْ نْسنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 33 مَاغَارْ وَا أَذْ يِيڒِي ذ ڒْعَاهْذْ نِّي إِ غَا ڭّغْ أَوَارْنِي إِ وُوسَّانْ نِّي أَكْ-ذ ثَادَّارْثْ ن إِسْرَائِيل، \add أَمُّو إِ\add* إِقَّارْ سِيذِي: نشّْ أَذْ ڭّغْ شَّارِيعَا إِنُو ذڭْ وُوڒْ نْسنْ ؤُشَا أَذْ ت أَرِيغْ ذڭْ وُوڒْ نْسنْ. نشّْ أَذْ إِڒِيغْ ذ سِيذِي إِ نِيثْنِي ؤُ نِيثْنِي أَذْ إِڒِينْ ذ ڒْڭنْسْ إِ نشّْ. \x ◘ \xo 31:‏33 \xt إِرْم. 24‏:‏7؛ 30‏:‏22؛ 31‏:‏33\x*  
\v 34 ؤُڒَا ذ إِجّنْ وَارْ إِسّڒْمِيذْ \add عَاذْ\add* جَّارْ نّسْ نِيغْ ؤُمَاسْ، أَمْ قَّارنْ: ’سّنْ سِيذِي!‘، مَاغَارْ نِيثْنِي مَارَّا أَذْ أَيِي سّْننْ، أَمْ ؤُمژْيَانْ أَمْ ؤُمقّْرَانْ جَارْ أَسنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، مَاغَارْ نشّْ أَذْ أَسنْ غْفَارغْ إِ ڒْمُوعْصِييّثْ نْسنْ ؤُ وَارْ تِّيذَارغْ \add عَاذْ\add* دّْنُوبْ نْسنْ.“ \x ◘ \xo 31:‏34 \xt إِشا. 54‏:‏13؛ إِرْم. 33‏:‏8؛ مِيخَا 7‏:‏18؛ يُوح. 6‏:‏45؛ ڒخ. 10‏:‏43\x*   
\m
\v 35 ”أَمُّو إِ إِقَّارْ سِيذِي، ونِّي إِڭِّينْ ثْفُوشْثْ إِ ثْفَاوْثْ ذڭْ وَاسّْ، \add ونِّي يُومُورنْ\add* ثَازِيرِي ذ إِثْرَانْ إِ ثْفَاوْثْ ذِي دْجِيڒثْ، ونِّي إِسّهْوَاڒنْ ڒبْحَارْ أَڒَامِي دّْ-ذُوقُّوزنْثْ ڒمْوَاجْ نّسْ، أَقَا سِيذِي ن ڒْعسْكَارَاثْ ذ إِسمْ نّسْ: \x ◘ \xo 31:‏35 \xt أَمز. 1‏:‏16؛ إِشا. 51‏:‏15\x*  
\v 36 ’مَاڒَا لْفَارَايِيضْ-أَ أَذْ د-وْضَانْثْ زڭْ وُوذمْ إِنُو، إِقَّارْ سِيذِي، \add خنِّي\add* أَذْ إِبدّْ ؤُڒَا ذ زَّارِيعثْ ن إِسْرَائِيل أَذْ ثِيڒِي ذ إِجّْ ن ڒْڭنْسْ زَّاثْ إِ وُوذمْ إِنُو، مَارَّا ؤُسَّانْ.‘  
\v 37 أَمُّو إِ إِقَّارْ سِيذِي: ’مَاڒَا تّْوَاعْبَارنْ إِجنْوَانْ سنّجْ ؤُ \add مَاڒَا\add* زمَّارنْ أَذْ أَرْزُونْ سَاذُو ذْسُوسَا ن ثمُّورْثْ، \add خنِّي\add* ؤُڒَا ذ نشّْ أَذْ نْضَارغْ زَّارِيعثْ ن إِسْرَائِيل زِي سِّيبّثْ ن مَارَّا مِينْ ڭِّينْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.‘ “   
\m
\v 38 ”خْزَارْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَذْ د-أَسنْ وُوسَّانْ نِّي ذِي غَا بْنَانْ ثَانْذِينْثْ \add عَاوذْ\add* إِ سِيذِي، زِي صُّومْعثْ ن حَانَانِييِيلْ أَڒْ ثوَّارْثْ ن ثغْمَارْثْ،  
\v 39 ؤُشَا أَذْ إِفّغْ ؤُفِيڒُو نْ ڒقْيَاسْ عَاذْ كْثَارْ، نِيشَانْ غَارْ زَّاثْ غَارْ ثوْرِيرْثْ ن جَارِيبْ ؤُشَا \add خنِّي\add* أَذْ إِميّڒْ غَارْ جُوعَا.  
\v 40 مَارَّا ثَايْسَارْثْ س ڒْخشْبَاثْ إِمُّوثنْ ؤُ س يِيغّضْ ذ مَارَّا إِيَّارنْ أَڒْ ثغْزَارْثْ ن قِيذْرُونْ أَڒْ ثغْمَارْثْ ن ثوَّارْثْ ن ييْسَانْ غَارْ شَّارْقْ، مَارَّا أَيَا أَذْ يِيڒِي ذ أَمْقدَّاسْ إِ سِيذِي.عمَّارْصْ أَذْ ثتّْوَاقْڒعْ ؤُ أَذْ ثتّْوَاهْذمْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ عَاذْ إِ ڒبْذَا.“   
\b  
\b  
\m  
\c 32
\s1 ثَامسْغِيوْثْ ن ييَّارْ  
\m
\v 1 أَوَاڒْ نِّي د-إِفّْغنْ زِي سِيذِي غَارْ إِرْمِييَا ذڭْ ؤُسڭّْوَاسْ وِيسّْعشْرَا ن صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا. أَسڭّْوَاسْ-أَ ثُوغَا ذ أَسڭّْوَاسْ وِيسّْ ثْمنْطَاشْ ن نابُوخَاذْرَاصَّارْ.  
\v 2 ذڭْ وُوسَّانْ نِّي ثُوغَا ڒْعسْكَارْ ن ؤُجدْجِيذْ ن بَابِيلْ إِحصَّارْ-د ؤُرْشَالِيمْ ؤُشَا أَنَابِي إِرْمِييَا ثُوغَا إِتّْوَاحبّسْ ذِي ڒمْرَاحْ ن ڒحْبسْ نِّي ثُوغَا ذِي ثَادَّارْثْ ن ؤُجدْجِيذْ ن يَاهُوذَا.  
\v 3 مَاغَارْ ثُوغَا إِحبّسْ إِ-ث صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، أَمْ ذ أَسْ إِنَّا: ”مَايمِّي ثتّْنَابّذْ، ثقَّارذْ: ’أَمُّو إِ إِقَّارْ سِيذِي: خْزَارْ، نشّْ أَذْ ڭّغْ ثَانْذِينْثْ-أَ ذڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن بَابِيلْ ؤُ نتَّا أَذْ ت ثطّفْ.  
\v 4 صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، وَارْ إِنجّمْ زڭْ ؤُفُوسْ ن إِكَالْذَانِييّنْ، مَاشَا أَذْ إِمّوْشْ ذڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن بَابِيلْ. نتَّا أَذْ كِيذسْ إِسِّيوڒْ زڭْ ؤُقمُّومْ غَارْ ؤُقمُّومْ ؤُ نتَّا أَذْ ث إِژَارْ ثِيطّْ ذِي ثِيطّْ. \x ◘ \xo 32:‏4 \xt إِرْم. 34‏:‏3\x*  
\v 5 نتَّا أَذْ يَاوِي صِيذْقِييَا غَارْ بَابِيلْ ؤُ نتَّا أَذْ ذِينِّي إِقِّيمْ، أَڒْ غَارسْ إِ غَا رَاحغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. وَاخَّا كنِّيوْ أَذْ ثمّنْغمْ أَكْ-ذ إِكَالْذَانِييّنْ، وَارْ تِّيكّْوِيضمْ شَا.‘ “   
\m
\v 6 إِرْمِييَا إِنَّا: ”يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:  
\v 7 ’خْزَارْ، حَانَامْ‘إِلْ، مِّيسْ نعمِّيشْ شَالُّومْ، أَذْ غَاركْ د-يَاسْ ؤُشَا أَذْ يِينِي: سغْ إِ يِيخفْ نّشْ إِيَّارْ إِنُو ذِي عَانَاثُوثْ، مَاغَارْ شكْ غَاركْ ڒْحقّْ نْ ڒفْذِييّثْ مَاحنْذْ أَذْ ث ثسْغِيذْ.‘ “  
\v 8 \add خنِّي\add* يُوسَا-د غَارِي حَانَامْ‘إِلْ، مِّيسْ نعمِّي، عْلَاحْسَابْ أَوَاڒْ ن سِيذِي، ذِي ڒمْرَاحْ ن ڒحْبسْ، إِنَّا أَيِي: ”سغْ خنِّي إِيَّارْ إِنُو ذِي عَانَاثُوثْ، ذِي ثمُّورْثْ ن بِينْيَامِينْ، مَاغَارْ شكْ غَاركْ ڒْحقّْ أَذْ ث ثْوَارْثذْ ؤُشَا غَاركْ \add ڒْحقّْ\add* ن ؤُسُوفغْ مَاحنْذْ أَذْ ث ثفْذِيذْ، أَذْ ث ثسْغذْ.“ ڒخْذنِّي سّْنغْ إِلَّا أَوَاڒْ-أَ يُوسَا-د زِي سِيذِي.  
\v 9 \add أَمُّو إِ\add* سْغِيغْ إِيَّارْ نِّي \add إِدْجَانْ\add* ذِي عَانَاثُوثْ خْ حَانَامْ‘إِلْ، مِّيسْ نعمِّي، ؤُشَا وزْنغْ أَسْ نُّوقَارْثْ: سْبعْطَاشْ شِيقْلُو ن نُّوقَارْثْ.  
\v 10 نشّْ وقّْعغْ خْ ثَابْرَاثْ، شمّْعغْ ت ؤُشَا جِّيغْ شّْهُوذْ أَذْ ت سّْمثْننْ ؤُشَا وزْنغْ نُّوقَارْثْ ذِي ڒْمِيزَانْ.  
\v 11 كْسِيغْ ثَابْرَاثْ إِتّْوَانّْضنْ ن ثْمسْغِيوْثْ، ثنِّي ثُوغَا إِتّْوَاشمّْعنْ، \add إِتّْوَارِي ذَايسْ\add* مَامّشْ إِتّْوَاڭّْ ڒْعَاهْذْ ؤُ \add مِينْ دْجَانْثْ\add* لْفَارَايِيضْ، ؤُڒَا ثَابْرَاثْ يَارزْمنْ  
\v 12 ؤُشَا وْشِيغْ ثَابْرَاثْ إِتّْوَانْضنْ ن ثْمسْغِيوْثْ إِ بَارُوخْ، مِّيسْ ن نِيرِي-يَاهْ، مِّيسْ ن مَاحْسِييَا، زَّاثْ إِ ثِيطَّاوِينْ ن حَانَامْ‘إِلْ، مِّيسْ نعمِّي، ؤُ زَّاثْ إِ ثِيطَّاوِينْ نْ ڒشْهُوذْ نِّي ثُوغَا إِوقّْعنْ ثَابْرَاثْ إِتّْوَانّْضنْ ن ثْمسْغِيوْثْ زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا وُوذَاينْ نِّي إِقِّيمنْ ذِي ڒمْرَاحْ ن ڒحْبسْ.  
\v 13 نشّْ ؤُمُورغْ بَارُوخْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ، نِّيغْ:  
\v 14 ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’كْسِي ثِيبْرَاثِينْ-أَ، ثَابْرَاثْ إِتّْوَانّْضنْ ن ثْمسْغِيوْثْ، أَمْ ثنِّي إِشمّْعنْ أَمْ ثَانِيثَا، ثنِّي يَارزْمنْ، ؤُشَا سَّارْسْ إِ-ثنْثْ ذڭْ إِشْثْ ن ڒْقشْعثْ ن ثْڒَاخْثْ، مَاحنْذْ أَذْ قِّيمنْثْ أَطَّاسْ ن وُوسَّانْ حْضَانْثْ!‘  
\v 15 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’أَذْ تّْوَاسْغنْ عَاوذْ ثُوذْرِينْ ذ إِيَّارنْ ذ إِمَارْجَاعنْ ن ؤُضِيڒْ ذِي ثمُّورْثْ-أَ.‘ “   
\m
\v 16 أَوَارْنِي ؤُمِي ثُوغَا وْشِيغْ ثَابْرَاثْ ن ثْمسْغِيوْثْ إِ بَارُوخْ، مِّيسْ ن نِيرِي-يَاهْ، ژُّودْجغْ س ڒَادْجَاغْ غَارْ سِيذِي، نِّيغْ:  
\v 17 ”أَخْ، سِيذِي إِنُو، سِيذِي، خْزَارْ، شكْ ثڭِّيذْ إِجنْوَانْ ذ ثَامُّورْثْ س جّْهذْ نّشْ أَمقّْرَانْ ؤُ س ؤُغِيڒْ نّشْ إِسّْوِيژّْضنْ. وَارْ خَاكْ إِوْعَارْ وَالُو.  
\v 18 \add شكْ\add* ذ ونِّي إِڭِّينْ ثَامخْسِيوْثْ إِشوَّارنْ إِ ڒُوڒُوفْ ؤُشَا ثْخدْجْصذْ ڒْمُوعْصِييّثْ ن إِبَابَاثنْ ذڭْ وحْسِينْ ن إِحنْجِيرنْ نْسنْ أَوَارْنِي أَسنْ، \add أَ\add* شكْ أَربِّي ذ أَمقّْرَانْ ذ أَجبَّارْ، ونِّي ؤُمِي قَّارنْ: سِيذِي ن ڒْعسْكَارَاثْ. \x ◘ \xo 32:‏18 \xt ؤُف. 34‏:‏7\x*  
\v 19 شكْ ذ أَمقّْرَانْ ن شّْوَارْ ؤُ ثجْهذْ ذِي ثْمڭَّا، مَاغَارْ ثِيطَّاوِينْ نّشْ تّْعسّنْثْ خْ مَارَّا إِبْرِيذنْ ن ثَارْوَا ن بْنَاذمْ، حِيمَا أَذْ ثْخدْجْصضْ كُوڒْ إِجّْ عْلَاحْسَابْ إِبْرِيذنْ نّسْ ؤُ عْلَاحْسَابْ ڒْغِيدْجثْ ن ثْمڭَّا نّسْ.\x ◘ \xo 32:‏19 \xt أَيُوبْ 34‏:‏21؛ أَوڒن. 5‏:‏21؛ إِشا. 28‏:‏29؛ إِرْم. 16‏:‏17؛ 17‏:‏10\x*  
\v 20 شكْ ثڭِّيذْ ڒعْڒَامَاثْ ذ لْمُوجِيزَاثْ ذِي مِيصْرَا، أَڒْ أَسّْ-أَ، أَمْ ذڭْ إِسْرَائِيل أَمْ ذڭْ إِوْذَانْ نّغْنِي. ثڭِّيذْ إِجّْ ن يِيسمْ إِ يِيخفْ نّشْ، أَمْ مَامّشْ \add إِ ثدْجَا\add* أَسّْ-أَ.  
\v 21 شكْ ثسُّوفّْغذْ-د ڒْڭنْسْ نّشْ إِسْرَائِيل زِي ثمُّورْثْ ن مِيصْرَا س ڒعْڒَامَاثْ ذ لْمُوعْجِيزَاثْ، س إِجّْ ن ؤُفُوسْ  إِجهْذنْ ذ إِجّْ ن ؤُغِيڒْ  إِسّْوِيژَّاضنْ، \add ؤُمِي ثسّكَّارذْ\add* إِشْثْ ن ثڭّْوُوذِي ثَامقّْرَانْثْ \add جَارْ ڒڭْنُوسْ\add*.\x ◘ \xo 32:‏21 \xt ؤُف. 6‏:‏7؛ 2 صم. 7‏:‏23؛ 1 إِم. 17‏:‏21\x*  
\v 22 شكْ ثوْشِيذْ أَسنْ ثَامُّورْثْ-أَ، ثنِّي ثجُّودْجذْ إِ ڒجْذُوذْ نْسنْ مَاحنْذْ أَذْ أَسنْ ت ثوْشذْ، إِشْثْ ن ثمُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ.  
\v 23 نِيثْنِي ؤُذْفنْ-د غَارسْ ؤُشَا طّْفنْ ت ذ ثَاسْغَارْثْ، \add مَاشَا\add* نِيثْنِي وَارْ سْڒِينْ إِ ثْمِيجَّا نّشْ ؤُ وَارْ ؤُيُورنْ ذڭْ \add وبْرِيذْ ن\add* شَّارِيعَا نّشْ ؤُ وَارْ ڭِّينْ عْلَاحْصَابْ مَارَّا مِينْزِي ثنْ ثْوصِّيذْ. \add س ؤُيَا\add* إِ ثنْ إِڒْقفْ مَارَّا ڒْغَارْ-أَ.  
\v 24 خْزَارْ، إِشْبَارنْ إِ ڒحْصَارثْ! نِيثْنِي إِوْضنْ-د أَڒْ ثَانْذِينْثْ مَاحنْذْ أَذْ ت طّْفنْ، ؤُشَا ثَانْذِينْثْ ثمّوْشْ ذڭْ ؤُفُوسْ ن إِكَالْذَانِييّنْ نِّي أَكِيذسْ إِتّْمنْغَانْ، زِي سِّيبّثْ ن سِّيفْ ذ ڒَاژْ ذ طَّاعُونْ. مِينْ ثسِّيوْڒذْ أَقَا يِيوضْ-د. خْزَارْ، ثتّْوَارِيذْ \add ث\add* سِيمَانْثْ نّشْ.  
\v 25 \add وَاخَّا أَمنِّي\add* ثنِّيذْ أَيِي، \add أَ\add* سِيذِي إِنُو، سِيذِي: سغْ إِ يِيخفْ نّشْ إِيَّارْ نِّي س نُّوقَارْثْ ؤُشَا أجّْ ڒشْهُوذْ أَذْ ت سّْمثْننْ، \add ڒَْامِي\add* ثمّوْشْ ثنْذِينْثْ ذڭْ ؤُفُوسْ ن إِكَالْذَانِييّنْ.“   
\m
\v 26 \add خنِّي\add* يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِرْمِييَا، إِنَّا:  
\v 27 ”خْزَارْ، نشّْ ذ سِيذِي، أَربِّي ن مَارَّا نِّي غَارْسنْ أَرِّيمثْ \add ن ويْسُومْ\add*. مَا إِوْعَارْ خَافِي شَا؟‘ \x ◘ \xo 32:‏27 \xt ڒخْڒ. 16‏:‏22\x*  
\v 28 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي: ’نشّْ أَذْ ڭّغْ ثَانْذِينْثْ-أَ ذڭْ ؤُفُوسْ ن إِكَالْذَانِييّنْ ؤُ ذڭْ ؤُفُوسْ ن نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ؤُ نتَّا أَذْ ت إِطّفْ.  
\v 29 إِكَالْذَانِييّنْ، إِنِّي إِتّْمنْغَانْ أَكْ-ذ ثنْذِينْثْ-أَ، أَذْ غَارسْ د-أَذْفنْ، أَذْ قدّنْ ثَانْذِينْثْ س ثْمسِّي ؤُشَا أَذْ ت سّْشمْضنْ أَكْ-ذ ثُوذْرِينْ نِّي خْ ثْزغْوِينْ نْسنْثْ إِ زِي قدّْمنْ ثِيوْهِيبِينْ ن ڒبْخُورْ إِ بَاعْلْ ؤُشَا سيّْبنْ ثِيوْهِيبِينْ ن ؤُسيّبْ إِ إِربِّيثنْ نّغْنِي حِيمَا أَذْ أَيِي سْعَارنْ. \x ◘ \xo 32:‏29 \xt إِرْم. 21‏:‏10\x*  
\v 30 مَاغَارْ أَيْثْ ن إِسْرَائِيل ذ أَيْثْ ن يَاهُوذَا زِي ثمْژِي نْسنْ تّڭّنْ مْغِيرْ مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ إِنُو. أَيْثْ ن إِسْرَائِيل سْعَارنْ أَيِي س ڒْخذْمثْ ن إِفَاسّنْ نْسنْ!‘، إِقَّارْ سِيذِي.  
\v 31 ’مَاغَارْ ثَانْذِينْثْ ثُوغَا ت إِ نشّْ \add ذ سِّيبّثْ\add* ن وغْضَابْ ذ وسْعَارْ زڭْ وَاسّْ نِّي ذِي ثتّْوَابْنَا أَڒْ أَسّْ-أَ، أَڒَامِي ت غَا نْضَارغْ خْ وُوذمْ إِنُو  
\v 32 زِي سِّيبّثْ ن مَارَّا ڒْغَارْ ن أَيْثْ ن إِسْرَائِيل ذ أَيْثْ ن يَاهُوذَا مَاحنْذْ أَذْ أَيِي سْعَارنْ، نِيثْنِي ذ إِجدْجِيذنْ نْسنْ ذ ڒْحُوكَّامْ نْسنْ ذ إِكهَّاننْ نْسنْ ذ إِنَابِييّنْ نْسنْ ذ إِرْيَازنْ ن يَاهُوذَا ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ.  
\v 33 نِيثْنِي وْشِينْ أَيِي-د س وعْرُورْ، وَارْ إِدْجِي س ؤُغمْبُوبْ، \add وَاخَّا\add* نشّْ سّْڒمْذغْ ثنْ، \add عَاذْ\add* زڭْ ؤُمزْوَارُو سّْغَارغْ ثنْ، \add مَاشَا\add* نِيثْنِي وَارْ خْسنْ أَذْ سْڒنْ مَاحنْذْ أَذْ طّْفنْ تَّارْبِييّثْ. \x ◘ \xo 32:‏33 \xt إِرْم. 2‏:‏27؛ 7‏:‏13، 24، 25؛ 25‏:‏3؛ 26‏:‏5؛ 29‏:‏19\x*  
\v 34 نِيثْنِي سّْبدّنْ نّْعَاوَاثْ نْسنْ ن لْ-أَصْنَامْ ذِي ثَادَّارْثْ إِ خفْ إِتّْوَابَارّحْ إِسمْ إِنُو مَاحنْذْ أَذْ ت سّْخمْجنْ.  
\v 35 نِيثْنِي سّْبدّنْ ڒڭْعُوذِي ن بَاعْلْ \add مَانِي إِ ذ أَسْ تّْوهّْبنْ دّْبَايحْ نْسنْ\add* ذِي ثغْزُورْثْ ن مِّيسْ ن هِينُّومْ مَاحنْذْ أَذْ سّعْذُونْ إِحنْجِيرنْ نْسنْ ذ ثْحنْجِيرِينْ نْسنْثْ إِ مُولَاكْ ذِي ثْمسِّي، مِينْ وَارْ ذ أَسنْ ؤُمُورغْعمَّارْصْ ؤُ مِينْ وَارْ ذ أَيِي د-إِدَّارنْ ذِي ڒْبَاڒْ إِنُو، أَقَا أَذْ ڭّنْ نّْعِي أَمْ وَا أَڒَامِي عَارْننْ يَاهُوذَا غَارْ دّْنُوبْ.‘ “ \x ◘ \xo 32:‏35 \xt إِرْم. 19‏:‏5\x*   
\m
\v 36 ”س ؤُيَا، ڒخُّو، أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل، خْ ثنْذِينْثْ-أَ إِ خْ ثقَّارمْ: ’أَقَا ثمّوْشْ ذڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن بَابِيلْ، س سِّيفْ، س ڒَاژْ ؤُ س طَّاعُونْ!‘:  
\v 37 خْزَارْ، نشّْ أَذْ ثنْ سّْمُونغْ زِي مَارَّا ثِيمُّورَا مَانِي خَاسنْ ؤُژّْڒغْ ذڭْ وغْضَابْ إِنُو ؤُ ذڭْ وسْعَارْ إِنُو ؤُ ذڭْ ؤُذُوقّزْ ن وغْضَابْ إِنُو، ؤُ نشّْ أَذْ ثنْ أَرّغْ غَارْ ومْشَانْ-أَ ؤُ أَذْ ثنْ سّْزذْغغْ ذِي ڒَامَانْ. \x ◘ \xo 32:‏37 \xt إِرْم. 23‏:‏3؛ 29‏:‏14؛ 31‏:‏10\x*  
\v 38 نِيثْنِي أَذْ إِڒِينْ ذ ڒْڭنْسْ إِنُو ؤُ نشّْ أَذْ إِڒِيغْ ذ أَربِّي نْسنْ. \x ◘ \xo 32:‏38 \xt إِرْم. 24‏:‏7؛ 30‏:‏22؛ 31‏:‏1، 33\x*  
\v 39 نشّْ أَذْ أَسنْ وْشغْ ؤُڒْ ذ إِجّْ ؤُڒَا ذ وبْرِيذْ ذ إِجّْ حِيمَا أَذْ أَيِي ڭّْوذنْ مَارَّا ؤُسَّانْ إِ ثِيزِي نْسنْ ؤُ إِ ثِيزِي ن إِحنْجِيرنْ نْسنْ أَوَارْنِي أَسنْ.  
\v 40 نشّْ أَكِيذْسنْ ڭّغْ إِجّْ ن ڒْعَاهْذْ إِتّْذُومَانْ، أَقَا وَارْ تّْحيِّيذغْ زِي أَوَارْنِي أَسنْ، حِيمَا أَذْ أَسنْ ڭّغْ مِينْ إِصبْحنْ، ؤُ نشّْ أَذْ أَسنْ سَّارْسغْ ثِيڭّْوُوذِي زَّايِي ذڭْ وُوڒْ نْسنْ، مَاحنْذْ وَارْ خَافِي تّْحيِّيذنْ \add عَاذْ\add*.  
\v 41 نشّْ أَذْ زَّايْسنْ فَارْحغْ مَاحنْذْ أَذْ ذَايْسنْ تّْهِيلِّيغْ ؤُ زِي ڒْمَانثْ إِنُو أَذْ ثنْ ژُّوغْ ذِي ثمُّورْثْ-أَ س مَارَّا ؤُڒْ إِنُو ؤُ س مَارَّا ڒعْمَارْ إِنُو.‘ “ \x ◘ \xo 32:‏41 \xt إِرْم. 24‏:‏6؛ عَام. 9‏:‏15\x*   
\m
\v 42 ”مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: ’أَمْ مَامّشْ إِ د إِوْيغْ خْ ڒْڭنْسْ-أَ ثُوعفّْنَا-يَا ثَامقّْرَانْثْ، أَمُّو إِ خَاسنْ إِ غَا سِّيوْضغْ مَارَّا ثَاصبْحَانْثْ إِ خَاسنْ نِّيغْ.  
\v 43 أَذْ سْغنْ \add عَاوذْ\add* إِيَّارنْ ذِي ثمُّورْثْ-أَ إِ خفْ ثقَّارمْ كنِّيوْ: ’أَقَا-ت ذ إِشْثْ ثمُّورْثْ إِتّْوَاردّْدْجنْ نْهْڒَا بْنَاذمْ ذ ڒْمَارْ، ثمّوْشْ ذڭْ ؤُفُوسْ ن إِكَالْذَانِييّنْ.‘  
\v 44 أَذْ سْغنْ \add عَاوذْ\add* إِيَّارنْ س \add تّْمنْيَاثْ ن\add* نُّوقَارْثْ، أَذْ وقّْعنْ ؤُ أَذْ شمّْعنْ ثِيبْرَاثِينْ ن ثْمسْغِيوْثْ، أَذْ أَوْينْ ڒشْهُوذْ حِيمَا أَذْ سّْمثْننْ \add ثَامسْغِيوْثْ\add* ذِي ثمُّورْثْ ن بِينْيَامِينْ، ذِي جّْوَايهْ ن ؤُرْشَالِيمْ، ذِي ثْندَّامْ ن يَاهُوذَا، ذِي ثْندَّامْ ن ثمُّورْثْ ن إِذُورَارْ، ذِي ثْندَّامْ ن ثمُّورْثْ إِوَاطَانْ ؤُ ذِي ثْندَّامْ ن \add ثمُّورْثْ ن\add* لْجَانُوبْ، مَاغَارْ نشّْ أَذْ سّنْقڒْبغْ ثَامحْبَاسْثْ نْسنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.‘ “   
\b  
\b  
\m  
\c 33
\s1 لْوَاعْذْ ن ؤُرقّعْ  
\m
\v 1 يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِرْمِييَا إِ ثْوَاڒَا وِيسّْ ثْنَاينْ، ؤُمِي ثُوغَا عَاذْ إِتّْوَابلّعْ خَاسْ ذِي ڒمْرَاحْ ن ڒحْبسْ، إِنَّا:  
\v 2 ”أَمُّو إِ إِقَّارْ سِيذِي، ونِّي ث إِڭِّينْ، سِيذِي، ونِّي ت يَارشْمنْ أَڒَامِي ت غَا إِبدّْ ذ ؤُبذِّي، أَقَا سِيذِي ذ إِسمْ نّسْ:  
\v 3 ’ڒَْاغَا أَيِي-د ؤُشَا أَذْ خَاكْ د-أَرّغْ ؤُ أَذْ أَشْ سّشْنغْ ثِيمسْڒَايِينْ ثِيمقّْرَانِينْ ذ إِنُّوفَارنْ، وَارْ ثنْثْ ثسِّينذْ.  
\v 4 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل، خْ ثُوذْرِينْ ن ثنْذِينْثْ-أَ ؤُ خْ ثُوذْرِينْ ن إِجدْجِيذنْ ن يَاهُوذَا نِّي إِتّْوَاهذْمنْ، \add مَاحنْذْ أَذْ إِڒِينْثْ إِ ؤُذُورِّي\add* ضِيدّْ ن وشْبَارنْ ن ڒحْصَارثْ ؤُ ضِيدّْ ن سِّيفْ:  
\v 5 إِنِّي د-يُوسِينْ حِيمَا أَذْ مّنْغنْ أَكْ-ذ إِكَالْذَانِييّنْ، \add أَقَا ؤُسِينْ-د\add* حِيمَا أَذْعمَّارنْ \add ثُوذْرِينْ نِّي\add* س ڒْخشْبَاثْ ن إِوْذَانْ نِّي نْغِيغْ ذڭْ وغْضَابْ إِنُو ؤُ ذڭْ وسْعَارْ إِنُو، مِينْزِي سّْذُورّْيغْ ؤُذمْ إِنُو خْ ثنْذِينْثْ-أَ زِي سِّيبّثْ ن مَارَّا ثُوعفّْنَا نْسنْ!  
\v 6 \add مَاشَا\add* خْزَارْ، نشّْ أَذْ أَسْ-ت-إِ-د-أَوْيغْ أَعْذَاڒْ ذ ؤُڭنْفُو، نشّْ أَذْ ثنْ سّْڭنْفِيغْ ؤُشَا أَذْ خَاسنْ عَارِّيغْ إِجّْ \add ن ڒْعُونْصَارْ\add* إِفيّْضنْ س ڒهْنَا ذ ثِيذتّْ.  
\v 7 نشّْ أَذْ سّنْقڒْبغْ ثَامحْبَاسْثْ ن يَاهُوذَا ذ ثْمحْبَاسْثْ ن إِسْرَائِيل، ؤُ أَذْ ثنْ بْنِيغْ أَمْ ذڭْ ؤُمزْوَارُو. \x ◘ \xo 33:‏7 \xt إِرْم. 24‏:‏6؛ 31‏:‏4؛ 32‏:‏44\x*  
\v 8 نشّْ أَذْ ثنْ سِّيزذْڭغْ زِي مَارَّا ڒْمُوعْصِييّثْ نْسنْ إِ زِي كِيذِي خْضَانْ. أَذْ غْفَارغْ مَارَّا ڒْمُوعْصِييَّاثْ نْسنْ إِ زِي خْضَانْ أَكِيذِي ؤُشَاعدَّانْ خَافِي. \x ◘ \xo 33:‏8 \xt إِرْم. 31‏:‏34\x*  
\v 9 أَذْ ثِيڒِي \add ثنْذِينْثْ ن ؤُرْشَالِيمْ\add* إِ نشّْ ذ إِسمْ إِسّفْرَاحنْ ذ ؤُسمْغَارْ ذ شَّانْ غَارْ مَارَّا ڒڭْنُوسْ ن دُّونشْثْ نِّي إِ غَا إِسْڒَانْ ڒْخَارْ نِّي ذ أَسنْ إِ غَا ڭّغْ. نِيثْنِي أَذْ ڭّْوذنْ ؤُ أَذْ أَرْجِيجنْ خْ مَارَّا ڒْخَارْ ؤُ خْ مَارَّا ڒهْنَا نِّي ذ أَسْ إِ غَا ڭّغْ.‘ “   
\m
\v 10 ”أَمُّو إِ إِقَّارْ سِيذِي: ذڭْ ومْشَانْ-أَ إِ خْ ثقَّارمْ كنِّيوْ: ’أَقَا-ث ذ ڒْخِيرْبثْ أَڒَامِي وَارْ إِقِّيمْ ؤُڒَا ذ إِجّْ ن بْنَاذمْ نِيغْ ذ ڒْمَاڒْ!‘، \add وَاهْ،\add* ذِي ثْندَّامْ ن يَاهُوذَا ؤُ ذڭْ إِبْرِيذنْ ن ؤُرْشَالِيمْ، ثِينِّي إِتّْوَاردّْدْجنْ أَڒَامِي وَارْ إِقِّيمْ ؤُڒَا ذ إِجّْ ن بْنَاذمْ نِيغْ ذ أَمزْذُوغْ نِيغْ ذ ڒْمَاڒْ، أَذْ إِتّْوَاسڒْ \add عَاذْ\add*  
\v 11 ثْمِيجَّا نْ وَارْشَاقْ ذ ثْمِيجَّا ن ڒفْرَاحثْ، ثْمِيجَّا ن مُوڒَايْ ذ ثْمِيجَّا ن ثسْڒِيثْ، ثْمِيجَّا ن يِينِّي إِقَّارنْ: قَاذَامْ سِيذِي ن ڒْعسْكَارَاثْ، مَاغَارْ سِيذِي إِصْبحْ، مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ ثتّْغِيمَا إِ ڒبْذَا!، ثْمِيجَّا ن يِينِّي إِ د-إِتَّاوْينْ أَقَاذِي ذِي ثَادَّارْثْ ن سِيذِي، مَاغَارْ نشّْ أَذْ سّنْقڒْبغْ ثَامحْبَاسْثْ ن ثمُّورْثْ، \add أَذْ ثِيڒِي\add* أَمْ ذڭْ ؤُمزْوَارُو، إِقَّارْ سِيذِي.‘ “ \x ◘ \xo 33:‏11 \xt إِرْم. 7‏:‏34؛ إِزهد. 136‏:‏6\x*   
\m
\v 12 ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: ’ذڭْ ومْشَانْ-أَ إِ إِتّْوَاردّْدْجنْ أَڒَامِي وَارْ إِقِّيمْ \add عَاذْ\add* ؤُڒَا ذ إِجّْ ن بْنَاذمْ نِيغْ ذ ڒْمَاڒْ، \add وَاهْ،\add* ذِي مَارَّا ثِيندَّامْ نّسْ أَذْ إِڒِينْثْ عَاوذْ دّْمَانِي ن ثَاروْسَا إِ إِمكْسَاونْ نِّي إِ غَا إِسَّاريّْحنْ ؤُدْجِي. \f ◼ \fr 33:‏12 \ft \+bd ’إِمكْسَاونْ‘\+bd* - نِيغْ ’إِنِيتْشَانْ‘.\f*  
\v 13 ذِي ثمُّورْثْ ن إِذُورَارْ، ذِي ثْندَّامْ ن ثمُّورْثْ إِوَاطَانْ، ذِي ثْندَّامْ ن ثمُّورْثْ ن لْجَانُوبْ، ذِي ثمُّورْثْ ن بِينْيَامِينْ، ذڭْ إِمُوشَانْ إِ ذ أَسْ د-إِنّْضنْ إِ ؤُرْشَالِيمْ ؤُ ذِي ثْندَّامْ ن يَاهُوذَا أَذْ عْذُونْ وُودْجِي عَاوذْ سَاذُو إِفَاسّنْ ن يِينِّي إِ ثنْ إِحسّْبنْ!‘، \add أَمُّو\add* إِ إِقَّارْ سِيذِي.“   
\m
\v 14 ”خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَذْ سّْقفْڒغْ أَوَاڒْ أَصبْحَانْ نِّي سِّيوْڒغْ إِ ثَادَّارْثْ ن إِسْرَائِيل ذ ثَادَّارْثْ ن يَاهُوذَا. \x ◘ \xo 33:‏14 \xt إِرْم. 29‏:‏10\x*  
\v 15 ذڭْ وُوسَّانْ نِّي ؤُ ذِي ڒْوقْثْ نِّي أَذْ سّْغمْيغْ إِ ذَاوُوذْ أَغدُّو ن ثْسڭْذَا. نتَّا أَذْ يڭّْ ڒْحقّْ ذ ثْسڭْذَا ذِي ثمُّورْثْ. \x ◘ \xo 33:‏15 \xt إِرْم. 23‏:‏5\x*  
\v 16 ذڭْ وُوسَّانْ نِّي أَذْ إِتّْوَاسّنْجمْ يَاهُوذَا ؤُشَا ؤُرْشَالِيمْ أَذْ ثزْذغْ ذِي ڒَامَانْ، أَذْ أَسْ ڭّنْ \add إِ ؤُرْشَالِيمْ\add* إِسمْ وَانِيثَا: ’سِيذِي ذ ثَاسڭْذَا نّغْ.‘ “   
\m
\v 17 ”مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: ’عمَّارْصْ أَذْ إِنْقصْ إِ ذَاوُوذْ إِجّْ ن ورْيَازْ نِّي إِقِّيمنْ خْ ڒْعَارْشْ ن ثَادَّارْثْ ن إِسْرَائِيل،  
\v 18 ؤُشَا ؤُڒَا ذ إِكهَّاننْ إِلَاوِييّنْ وَارْ ذ أَسنْ إِنقّصْعمَّارْصْ إِجّْ ن ورْيَازْ نِّي إِ غَا إِقدّْمنْ ثَاغَارْصْثْ ن وشْمَاضْ زَّاثْ إِ وُوذمْ إِنُو نِيغْ أَذْ إِسّْبخَّارْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* نِيغْ أَذْ إِسّوْجذْ إِشْثْ ن ثْغَارْصْثْ، مَارَّا ؤُسَّانْ.‘ “ \x ◘ \xo 33:‏18 \xt إِرْم. 17‏:‏26\x*   
\m
\v 19 يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِرْمِييَا، إِنَّا:  
\v 20 ”أَمُّو إِ إِقَّارْ سِيذِي: ’مَاڒَا إِزمَّارْ أَذْ ثَارْژْممْ ڒْعَاهْذْ إِنُو س وَاسّْ ذ ڒْعَاهْذْ إِنُو س دْجِيڒثْ أَڒْ أَسّْ ذ دْجِيڒثْ وَارْ تِّيڒِينْ عَاذْ ذِي ڒْوقْثْ نْسنْ إِتّْوَاڭّنْ،  
\v 21 \add خنِّي\add* إِڒِي أَذْ إِتّْوَارْژْ ؤُڒَا ذ ڒْعَاهْذْ إِنُو أَكْ-ذ ؤُمْسخَّارْ إِنُو ذَاوُوذْ، أَڒَامِي وَارْ غَارسْ إِتِّيڒِي عَاذْ مِّيسْ نِّي إِ غَا إِحكْمنْ خْ ڒْعَارْشْ نّسْ، ؤُ أَكْ-ذ إِكهَّاننْ زڭْ أَيْثْ ن لَاوِي، إِمْسخَّارنْ إِنُو.  
\v 22 أَمْ مَامّشْ وَارْ إِزمَّارْ أَذْ إِتّْوَاحْسبْ ڒْعسْكَارْ ن ؤُجنَّا ؤُ ؤُڒَا ذ إِجْذِي ن ڒبْحَارْ وَارْ إِزمَّارْ أَذْ إِتّْوَاعْبَارْ، أَمُّو س وَاطَّاسْ إِ غَا ڭّغْ ثَارْوَا ن ؤُمْسخَّارْ إِنُو ذَاوُوذْ ؤُ \add ن\add* إِلَاوِييّنْ نِّي ذ أَيِي إِتّْسخَّارنْ.‘ “   
\b  
\m
\v 23 يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِرْمِييَا، إِنَّا:  
\v 24 ”مَا وَارْ ثژْرِيذْ مَامّشْ إِسَّاوَاڒْ ڒْڭنْسْ-أَ، قَّارنْ: ’ثْنَاينْ ن ڒَادْجَاثْ نِّي إِفَارْزْ سِيذِي، أَقَا إِنْضَارْ إِ-ثنْثْ‘؟ أَقَا نِيثْنِي سْثهْزَانْ زِي ڒْڭنْسْ إِنُو أَڒَامِي وَارْ إِدْجِي عَاذْ ذ ڒْڭنْسْ إِ نِيثْنِي.“   
\m
\v 25 ”أَمُّو إِ إِقَّارْ سِيذِي: ’مَاڒَا ڒْعَاهْذْ إِنُو س وَاسّْ ذ دْجِيڒثْ وَارْ إِتِّيڒِي \add عَاذْ\add*، وَارْ تّْغِيمِيغْ تّڭّغْ لْفَارَايِيضْ ن إِجنْوَانْ ذ ثمُّورْثْ،  
\v 26 أَذْ نْضَارغْ ؤُڒَا ذ ثَارْوَا ن يَاعْقُوبْ ذ \add ثَارْوَا\add* ن ذَاوُوذْ أَڒَامِي وَارْ تّڭّغْ \add عَاذْ\add* زِي زَّارِيعثْ نّسْ إِنِّي غَا إِحكْمنْ خْ ثَارْوَا ن إِبْرَاهِيمْ ذ إِسْحَاقْ ذ يَاعْقُوبْ، مَاغَارْ نشّْ أَذْ سّنْقڒْبغْ ثَامحْبَاسْثْ نْسنْ ؤُ نشّْ أَذْ خَاسنْ حِينّغْ.‘ “ \x ◘ \xo 33:‏26 \xt إِرْم. 31‏:‏20\x*   
\b  
\b  
\m  
\c 34
\s1 أَعْڒَامْ غَارْ صِيذْقِييَا  
\m
\v 1 أَوَاڒْ إِ د-إِفّْغنْ زِي سِيذِي غَارْ إِرْمِييَا - ؤُمِي نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ذ مَارَّا ڒْعسْكَارْ نّسْ ذ مَارَّا ثِيڭلْذِيوِينْ ن دُّونشْثْ إِ إِدْجَانْ سَاذُو فُوسْ نّسْ ذ مَارَّا ڒڭْنُوسْ ثُوغَا تّْمنْغَانْ أَكْ-ذ ؤُرْشَالِيمْ ؤُ أَكْ-ذ مَارَّا ثِيندَّامْ نّسْ - إِ إِنَّانْ: \x ◘ \xo 34:‏1 \xt 2 إِج. 25؛ إِرْم. 52 \x*   
\m
\v 2 ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’ؤُيُورْ ؤُشَا سِيوڒْ أَكْ-ذ صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، إِنِي أَسْ: أَمُّو إِ إِقَّارْ سِيذِي، خْزَارْ، نشّْ أَذْ وْشغْ ثَانْذِينْثْ-أَ ذڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن بَابِيلْ ؤُ نتَّا أَذْ أَسْ إِقّذْ ثِيمسِّي. \x ◘ \xo 34:‏2 \xt إِرْم. 21‏:‏10؛ 32‏:‏29\x*  
\v 3 ؤُڒَا ذ شكْ س يِيخفْ نّشْ وَارْ ثْنجّْمذْ إِ ؤُفُوسْ نّسْ، مَاشَا أَذْ شكْ طّْفنْ ؤُ أَذْ شكْ وْشنْ ذڭْ ؤُفُوسْ نّسْ. ثِيطّْ ذِي ثِيطّْ أَذْ ثْژَارذْ أَجدْجِيذْ ن بَابِيلْ ؤُشَا أَذْ كِيذسْ ثسِّيوْڒذْ زڭْ ؤُقمُّومْ غَارْ ؤُقمُّومْ ؤُشَا أَذْ د-ثَاوْضذْ أَڒْ بَابِيلْ. \x ◘ \xo 34:‏3 \xt إِرْم. 32‏:‏4\x*  
\v 4 سڒْ مَاشَا إِ وَاوَاڒْ ن سِيذِي، صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا. أَمُّو إِ خَاكْ إِقَّارْ سِيذِي: ’شكْ وَارْ ثتّْوَانْغذْ شَا س سِّيفْ.  
\v 5 أَذْ ثمّْثذْ ذِي ڒهْنَا ؤُشَا أَمْ مَامّشْ سَّارْغنْ ثِيمسِّييَاثْ إِ ڒجْذُوذْ نّشْ، إِجدْجِيذنْ ن زِيشْ نِّي ثُوغَا إِدْجَانْ قْبڒْ إِ شكْ، أَذْ سَّارْغنْ عَاوذْ ذ ثِيمسِّييَاثْ إِ شكْ ؤُشَا أَذْ خَاكْ وْثنْ أَڭجْذُورْ، أَذْ إِنِينْ: أَخْ، سِيذِي!‘، مَاغَارْ نشّْ سِّيوْڒغْ أَوَاڒْ\add -أَ\add*، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.‘ “   
\m
\v 6 إِسِّيوڒْ ؤُنَابِي إِرْمِييَا مَارَّا أَوَاڒنْ-أَ إِ صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ذِي ؤُرْشَالِيمْ،  
\v 7 \add ؤُمِي\add* ثُوغَا ڒْعسْكَارْ ن ؤُجدْجِيذْ ن بَابِيلْ إِتّْمنْغَا أَكْ-ذ ؤُرْشَالِيمْ ؤُ أَكْ-ذ مَارَّا ثِيندَّامْ ن يَاهُوذَا نِّي إِقِّيمنْ، أَكْ-ذ لَاخِيشْ ذ عَازِيقَا، مَاغَارْ ثِينَا ثُوغَا عَاذْ قِّيمنْثْ جَارْ ثْندَّامْ ن يَاهُوذَا، مِينْزِي ثُوغَا أَثنْثْ ذ ثِيندَّامْ إِفَارْينْ.   
\b  
\m
\v 8 أَوَاڒْ نِّي د-إِفّْغنْ زِي سِيذِي غَارْ إِرْمِييَا، أَوَارْنِي مَا إِقّنْ ؤُجدْجِيذْ صِيذْقِييَا إِجّْ ن ڒْعَاهْذْ أَكْ-ذ مَارَّا ڒْڭنْسْ نِّي إِدْجَانْ ذِي ؤُرْشَالِيمْ، مَاحنْذْ أَذْ بَارّْحنْ س إِجّْ ن ؤُسَارّحْ جَارْ أَسنْ، \x ◘ \xo 34:‏8 \xt ؤُف. 21‏:‏2\x*  
\v 9 مَاحنْذْ كُوڒْ  إِجّنْ أَذْ يَارْخُو إِ إِسْمغْ نّسْ ؤُ إِ ثَايَّا نّسْ، إِ ؤُعِيبْرَانِي ؤُ إِ ثْعِيبْرَانشْثْ، أَڒَامِي وَارْ إِتّْغِيمِي جَارْ أَسنْ ؤُڒَا ذ إِجّنْ \add ونِّي إِدْجَانْ\add* ذ إِسْمغْ غَارْ إِجّْ ن ورْيَازْ زِي يَاهُوذَا، غَارْ ؤُمَاسْ.  
\v 10 مَارَّا ڒْحُوكَّامْ ذ مَارَّا ڒْڭنْسْ نِّي إِقّْننْ ڒْعَاهْذْ، سْڒِينْ أَقَا \add كُوڒْ\add* أَرْيَازْ أَذْ يَارْخُو إِ إِسْمغْ نّسْ ؤُ \add كُوڒْ\add* أَرْيَازْ أَذْ يَارْخُو إِ ثَايَّا نّسْ حِيمَا وَارْ إِتّْغِيمِي غَارْسنْ ؤُڒَا ذ إِجّْ ن إِسْمغْ. نِيثْنِي وْشِينْ أَمزُّوغْ \add إِ مَانْ أَيَا\add* ؤُشَا سّكّنْ ثنْ.  
\v 11 \add مَاشَا أَوَارْنِي أَسْ\add* بدّْڒنْ، أَرِّينْ-د إِسمْغَانْ ذ ثِييَّا إِنِّي ؤُمِي ثُوغَا أَرْخُونْ، حْصَارنْ ثنْ عَاوذْ مَاحنْذْ أَذْ إِڒِينْ \add عَاوذْ\add* ذ إِمْسمْغَانْ ذ ثِييَّا.   
\m
\v 12 \add خنِّي\add* يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِرْمِييَا، إِنَّا:  
\v 13 ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’نشّْ ڭِّيغْ إِجّْ ن ڒْعَاهْذْ أَكْ-ذ ڒجْذُوذْ نْومْ ذڭْ وَاسّْ نِّي ذِي ثنْ د-سُّوفّْغغْ زِي مِيصْرَا، زِي ثَادَّارْثْ ن ثسْمُوغِي، نِّيغْ:  
\v 14 أَوَارْنِي ڒَامِي عْذُونْ سبْعَا ن إِسڭّْوُوسَا إِتّْخصَّا كُوڒْ  إِجّْ أَذْ إِسّكّْ ؤُمَاسْ أَعِيبْرَانِي نِّي ذ أَشْ إِزّنْزنْ إِخفْ نّسْ ؤُشَا ثُوغَا إِخدّمْ إِ شكْ ستَّا ن إِسڭّْوُوسَا. إِتّْخصَّا أَذْ أَسْ ثَارْخُوذْ \add أَذْ يُويُورْ\add* ذِي ثْڒلِّي! \add مَاشَا\add* ڒجْذُوذْ نْومْ وَارْ غَارِي د-سْڒِينْ ؤُ وَارْ \add ذ أَيِي\add* وْشِينْ شَا أَمزُّوغْ. \x ◘ \xo 34:‏14 \xt ؤُف. 21‏:‏2؛ أَعَوذ. 15‏:‏12\x*  
\v 15 وَاخَّا كنِّيوْ ثْذوْڒمْ-د، ثڭِّيمْ مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ إِنُو أَمْ إِبَارّحْ كُوڒْ  إِجّْ س ؤُسَارْخُو إِ جَّارْ نّسْ ؤُشَا ثڭِّيمْ إِجّْ ن ڒْعَاهْذْ زَّاثْ إِ وُوذمْ إِنُو ذِي ثَادَّارْثْ مِينْ خفْ إِتّْوَابَارّحْ إِسمْ إِنُو،  
\v 16 كنِّيوْ \add مَاشَا\add* ثنّْقڒْبمْ عَاوذْ ؤُشَا ثسّْعِيدْجْثمْ إِسمْ إِنُو. كُوڒْ  إِجّْ يَارَّا-د إِسْمغْ نّسْ ؤُ كُوڒْ  إِجّْ يَارَّا-د ثَايَّا نّسْ نِّي ؤُمِي ثُوغَا ثَارْخُومْ مَاحنْذْ أَذْ ؤُيُورنْ نِيثْنِي مَانِي خْسنْ، ؤُشَا كنِّيوْ ثحْصَارمْ ثنْ عَاوذْ مَاحنْذْ أَذْ أَومْ إِڒِينْ ذ إِمْسمْغَانْ ذ ثِييَّا.‘ “   
\m
\v 17 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي: ’كنِّيوْ وَارْ غَارِي ثسْڒِيمْ مَاحنْذْ كُوڒْ إِجّْ أَذْ إِبَارّحْ س ؤُسَارْخُو إِ ؤُمَاسْ ؤُ كُوڒْ إِجّْ إِ جَّارْ نّسْ. خْزَارْ، أَمُّو نشّْ أَذْ أَومْ بَارّْحغْ س ؤُسَارْخُو، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، \add مَاحنْذْ أَذْ كنِّيوْ سلّْمغْ\add* إِ سِّيفْ، إِ طَّاعُونْ ؤُ إِ ڒَاژْ. نشّْ أَذْ كنِّيوْ ڭّغْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ إِ مَارَّا ثِيڭلْذِيوِينْ ن دُّونشْثْ. \x ◘ \xo 34:‏17 \xt أَعَوذ. 28‏:‏25؛ إِرْم. 15‏:‏4؛ 24‏:‏9، 10\x*  
\v 18 نشّْ أَذْ أَرّغْ إِرْيَازنْ نِّي إِعْذُونْ خْ ڒْعَاهْذْ إِنُو، إِنِّي وَارْ إِطِّيفنْ ذڭْ وَاوَاڒنْ ن ڒْعَاهْذْ نِّي ڭِّينْ زَّاثْ إِ وُوذمْ إِنُو، \add أَمْ\add* ؤُعجْمِي نِّي بْضَانْ خْ ثْنَاينْ ذ ونِّي جَارْ إِزيْنَاثْ نّسْ شُوقنْ نِيثْنِي: \x ◘ \xo 34:‏18 \xt أَمز. 15‏:‏10\x*  
\v 19 ڒْحُوكَّامْ ن يَاهُوذَا ذ ڒْحُوكَّامْ ن ؤُرْشَالِيمْ، إِمْسخَّارنْ إِشنّْعنْ، إِكهَّاننْ ذ مَارَّا ڒْڭنْسْ ن ثمُّورْثْ، إِنِّي إِشُوقنْ \add مَارَّا\add* جَارْ إِزِييْنَاثْ ن ؤُعجْمِي.  
\v 20 نشّْ أَذْ ثنْ وْشغْ ذڭْ ؤُفُوسْ ن ڒْعذْيَانْ نْسنْ ؤُ ذڭْ ؤُفُوسْ ن يِينِّي يَارزُّونْ أَذْ ثنْ نْغنْ ؤُشَا ڒْخشْبَاثْ نْسنْ أَذْ إِڒِينْثْ ذ مَاشَّا إِ إِجْضَاضْ ن ؤُجنَّا ؤُ إِ ڒْمَاڒْ ن ثمُّورْثْ. \f ◼ \fr 34:‏20 \ft \+bd ’إِنِّي يَارزُّونْ أَذْ ثنْ نْغنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’إِنِّي يَارزُّونْ ڒعْمَارْ نْسنْ‘.\f*  \x ◘ \xo 34:‏20 \xt إِرْم. 7‏:‏33؛ 16‏:‏4؛ 19‏:‏7\x*  
\v 21 ؤُڒَا ذ صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ذ ڒْحُوكَّامْ نّسْ أَذْ ثنْ ڭّغْ ذڭْ ؤُفُوسْ ن ڒْعذْيَانْ نْسنْ، ذڭْ ؤُفُوسْ ن يِينِّي يَارزُّونْ ثُوذَارْثْ نْسنْ، ذڭْ ؤُفُوسْ ن ڒْعسْكَارْ ن ؤُجدْجِيذْ ن بَابِيلْ نِّي خَاومْ إِفّْغنْ \add ڒخُّو\add*. \x ◘ \xo 34:‏21 \xt إِرْم. 37‏:‏11\x*  
\v 22 خْزَارْ، نشّْ أَذْ ؤُمُورغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، ؤُ نشّْ أَذْ ثنْ د-أَرّغْ غَارْ ثنْذِينْثْ-أَ ؤُ نِيثْنِي أَذْ كِيذسْ مّنْغنْ، أَذْ ت طّْفنْ ؤُشَا أَذْ أَسْ قّْذنْ ثِيمسِّي. نشّْ أَذْ أَرّغْ ثِيندَّامْ ن يَاهُوذَا ذ إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ، وَارْ ذَايسْ إِتّْغِيمِي ؤُڒَا ذ إِجّْ ن ؤُمزْذُوغْ \add عَاذْ\add*.‘ “   
\b  
\b  
\m  
\c 35
\s1 أَيْثْ ن رِيكَابْ  
\m
\v 1 أَوَاڒْ ن سِيذِي إِ د-يُوسِينْ غَارْ إِرْمِييَا ذڭْ وُوسَّانْ ن يَاهُويَاقِيمْ، مِّيسْ ن يُوشِييَا، أَجدْجِيذْ ن يَاهُوذَا، إِنَّا:  
\v 2 ”ؤُيُورْ غَارْ ثَادَّارْثْ ن أَيْثْ ن رِيكَابْ ؤُشَا سِيوڒْ أَكِيذْسنْ ؤُ أَوْيِي ثنْ غَارْ ثَادَّارْثْ ن سِيذِي، ذڭْ إِجّْ زڭْ إِخَّامنْ \add نّسْ\add*، ؤُ أوْشْ أَسنْ بِينُو حِيمَا أَذْ سْونْ.“   
\m
\v 3 \add خنِّي\add* إِوْيغْ-د يَازَانْيَا\add هُو\add*، مِّيسْ ن إِرْمِييَا، مِّيسْ ن حَابْصِينِييَا، \add جْمِيعْ\add* أَكْ-ذ مَارَّا أَيْثْمَاسْ ذ مَارَّا إِحنْجِيرنْ نّسْ ذ مَارَّا ثَادَّارْثْ ن أَيْثْ ن رِيكَابْ. \f ◼ \fr 35:‏3 \ft \+bd ’إِرَاكَابِييّنْ‘\+bd* - إِخْسْ أَذْ يِينِي ’أَيْثْ ن رَاكَابْ‘.\f*  
\v 4 إِوْيغْ ثنْ غَارْ ثَادَّارْثْ ن سِيذِي، ذڭْ وخَّامْ ن أَيْثْ ن حَانَانْ، مِّيسْ ن يَاجْذَالْيَا، أَرْيَازْ ن أَربِّي، \add أَخَّامْ\add* نِّي \add إِدْجَانْ\add* زَّاثْ إِ وخَّامْ ن ڒْحُوكَّامْ، ثِيوَا إِ وخَّامْ ن مَاعَاسِييَا، مِّيسْ ن شَالُّومْ، أَعسَّاسْ ن ثوَّارْثْ.  
\v 5 نشّْ سَّارْسغْ إِغَارَّافنْ شُّورنْ س بِينُو ذ ڒْكِيسَانْ زَّاثْ إِ وُوذمْ ن أَيْثْ ن رِيكَابْ ؤُشَا نِّيغْ أَسنْ: ’سْومْ بِينُو!‘  
\v 6 \add مَاشَا\add* نِيثْنِي نَّانْ: ’نشِّينْ وَارْ نْسسّْ شَا بِينُو، مَاغَارْ بَابَاثْنغْ يُونَاذَابْ، مِّيسْ ن رِيكَابْ، إِوصَّا أَنغْ، إِنَّا: كنِّيوْعمَّارْصْ وَارْ تّْسسّمْ بِينُو، كنِّيوْ ذ إِحنْجِيرنْ نْومْ، أَڒْ إِ ڒبْذَا.  
\v 7 وَارْ إِعدّڒْ أَذْ ثبْنَامْ ثَادَّارْثْ نِيغْ أَذْ ثْزَارْعمْ زَّارِيعثْ نِيغْ أَذْ ثژُّومْ ثَازَايَارْثْ ذڭْ ؤُمَارْجعْ نِيغْ أَذْ غَارْومْ يِيڒِي ؤُمَارْجعْ ن ؤُضِيڒْ، \add مَاشَا\add* مِينْ غَا ثكّمْ ثدَّارمْ أَذْ ثْزذْغمْ ذڭْ إِقِيضَانْ، مَاحنْذْ أَذْ ثدَّارمْ ؤُسَّانْ أَطَّاسْ ذِي ثمُّورْثْ مَانِي إِ غَا ثْزذْغمْ أَمْ يِيبَارَّانِييّنْ.  
\v 8 نشِّينْ نسْڒَا غَارْ بَابَاثْنغْ يُونَاذَابْ، مِّيسْ ن رِيكَابْ، ذِي مَارَّا مِينْ زِي إِ ذ أَنغْ إِوصَّا، مَاحنْذْ وَارْ نْسسّْ بِينُو مَارَّا ثُوذَارْثْ نّغْ، نشِّينْ ذ ثمْغَارِينْ نّغْ ذ إِحنْجِيرنْ نّغْ ذ يسِّيثْنغْ، \f ◼ \fr 35:‏8 \ft \+bd ’مَارَّا ثُوذَارْثْ نّغْ‘\+bd* - س ثْعِيبْرَانِيثْ ’مَارَّا ؤُسَّانْ نّغْ‘.\f*  
\v 9 ؤُ مَاحنْذْ وَارْ نْبنِّي ثُوذْرِينْ ذ ثَازذِّيغْثْ إِ يِيخفْ نّغْ. وَارْ غَارْنغْ بُو ؤُمَارْجعْ ن ؤُضِيڒْ نِيغْ إِيَّارْ نِيغْ زَّارِيعثْ،  
\v 10 ؤُشَا نشِّينْ ثُوغَا نْزدّغْ ذڭْ إِقِيضَانْ. \add أَمُّو\add* إِ نسْڒَا ؤُ نڭَّا عْلَاحْصَابْ مَارَّا مِينْ زِي إِ ذ أَنغْ إِوصَّا بَابَاثْنغْ يُونَاذَابْ.  
\v 11 ؤُمِي \add مَاشَا\add* نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، إِڭعّذْ خْ ثمُّورْثْ-أَ، إِمْسَارْ، أَقَا ننَّا: أَسمْ-د، أَذْ نْرَاحْ غَارْ ؤُرْشَالِيمْ زِي سِّيبّثْ ن ڒْعسْكَارْ ن إِكَالْذَانِييّنْ ؤُ زِي سِّيبّثْ ن ڒْعسْكَارْ ن أَرَامْ! \add س ؤُينِّي إِ\add* نْزدّغْ ذِي ؤُرْشَالِيمْ.‘ “   
\m
\v 12 \add خنِّي\add* يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِرْمِييَا، إِنَّا:  
\v 13 ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ؤُيُورْ، إِنِي إِ يرْيَازنْ ن يَاهُوذَا ؤُ إِ إِمزْذَاغْ ن ؤُرْشَالِيمْ: ’مَا وَارْ ثتّخْسمْ أَذْ ثكْسِيمْ تَّارْبِييّثْ س ؤُثسْڒِي إِ وَاوَاڒنْ إِنُو؟‘، إِقَّارْ سِيذِي.  
\v 14 أَوَاڒنْ ن يُونَاذَابْ، مِّيسْ ن رِيكَابْ، إِنِّي يُومُورْ إِ إِحنْجِيرنْ نْسنْ حِيمَا وَارْ سسّنْ بِينُو، أَقَا ضْفَارنْ ثنْ-د، مَاغَارْ أَڒْ أَسّْ-أَ وَارْ سْوِينْ شَا، مِينْزِي نِيثْنِي سْڒِينْ غَارْ ثوْصيّثْ ن بَابَاثْسنْ، \add مَاشَا\add* نشّْ سِّيوْڒغْ أَكِيذْومْ، \add وَاهْ عَاذْ\add* زڭْ ؤُمزْوَارُو سِّيوْڒغْ أَكِيذْومْ، \add مَاشَا\add* كنِّيوْ وَارْ غَارِي د-ثسْڒِيمْ شَا. \x ◘ \xo 35:‏14 \xt إِرْم. 11‏:‏7؛ 25‏:‏3؛ 26‏:‏5؛ 29‏:‏19؛ 32‏:‏33\x*  
\v 15 نشّْ سّكّغْ-د غَارْومْ مَارَّا إِمْسخَّارنْ إِنُو، إِنَابِييّنْ. عَاذْ زِيشْ سكّغْ ثنْ حِيمَا أَذْ إِنِينْ: ذوْڒمْ-د خنِّي، كُوڒْ إِجّْ زڭْ وبْرِيذْ نّسْ أَعفَّانْ ؤُ ڭّمْ ڒخْذَايمْ ثِيصبْحَانِينْ ؤُ وَارْ ثْرَادَّافمْ إِربِّيثنْ نّغْنِي مَاحنْذْ أَذْ أَسنْ ثْسخَّارمْ، خنِّي ثْزمَّارمْ أَذْ ثقِّيممْ \add ثْزذْغمْ\add* ذِي ثمُّورْثْ إِ ذ أَومْ وْشِيغْ ؤُ إِ ڒجْذُوذْ نْومْ. كنِّيوْ مَاشَا وَارْ ثوْشِيمْ أَمزُّوغْ ؤُ وَارْ غَارِي ثسْڒِيمْ. \x ◘ \xo 35:‏15 \xt إِرْم. 18‏:‏11؛ 25‏:‏5\x*  
\v 16 إِحنْجِيرنْ ن يُونَاذَابْ، مِّيسْ ن رِيكَابْ، سّْقفْڒنْ ثَاوْصيّثْ ن بَابَاثْسنْ نِّي ثنْ يُومُورْ، \add مَاشَا\add* ڒْڭنْسْ-أَ وَارْ غَارِي إِسْڒِي شَا.“   
\m
\v 17 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: خْزَارْ، نشّْ أَذْ أَوْيغْ خْ يَاهُوذَا ؤُ خْ مَارَّا إِمزْذَاغْ ن ؤُرْشَالِيمْ مَارَّا ڒْغَارْ نِّي ذ أَسنْ نِّيغْ، مِينْزِي سِّيوْڒغْ أَكِيذْسنْ مَاشَا نِيثْنِي وَارْ سْڒِينْ شَا، ؤُشَا ڒَاغِيغْ أَسنْ مَاشَا نِيثْنِي وَارْ د-أَرِّينْ شَا.“   
\m
\v 18 إِنَّا إِرْمِييَا إِ ثَادَّارْثْ ن أَيْثْ ن رِيكَابْ: ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’ؤُمِي ثسْڒِيمْ غَارْ ثوْصيّثْ ن بَابَاثْومْ يُونَاذَابْ ؤُشَا ثحْضَامْ مَارَّا ثِيوصَّا نّسْ ؤُ ثڭِّيمْ عْلَاحْسَابْ مَارَّا مِينْ ذ أَومْ يُومُورْ،  
\v 19 خْ ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: مَارَّا ؤُسَّانْ وَارْ إِتّْخصِّيعمَّارْصْ إِ يُونَاذَابْ، مِّيسْ ن رِيكَابْ، إِجّْ ن ورْيَازْ نِّي إِتّْبدَّانْ زَّاثْ إِ وُوذمْ إِنُو!‘ “   
\b  
\b  
\m  
\c 36
\s1 أَذْلِيسْ إِتّْوَانّْضنْ  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعَا ن يَاهُويَاقِيمْ، مِّيسْ ن يُوشِييَا، أَجدْجِيذْ ن يَاهُوذَا، إِمْسَارْ أَقَا يُوسَا-د وَاوَاڒْ ن سِيذِي وَانِيثَا غَارْ إِرْمِييَا، إِنَّا:  
\v 2 ”كْسِي إِجّْ ن وذْلِيسْ إِتّْوَانْضنْ ؤُشَا أَرِي خَاسْ مَارَّا أَوَاڒنْ إِ غَاركْ سِّيوْڒغْ خْ إِسْرَائِيل ؤُ خْ يَاهُوذَا ؤُ خْ مَارَّا ڒڭْنُوسْ، زڭْ وَاسّْ إِ د غَاركْ سِّيوْڒغْ، زڭْ وُوسَّانْ ن يُوشِييَا أَڒْ أَسّْ-أَ. \x ◘ \xo 36:‏2 \xt 2 إِم. 35‏:‏25؛ إِشا. 8‏:‏1؛ إِرْم. 30‏:‏2\x*  
\v 3 أَذْ ثَاغْ أَذْ سْڒنْ إِنِّي ن ثَادَّارْثْ ن يَاهُوذَا خْ مَارَّا ڒْغَارْ نِّي خْسغْ أَذْ أَسنْ ڭّغْ مَاحنْذْ أَذْ د-ذوْڒنْ أَذْ ثُوبنْ، كُوڒْ إِجّْ زڭْ وبْرِيذْ نّسْ أَعفَّانْ، ؤُ نشّْ أَذْ أَسنْ غْفَارغْ ڒْمُوعْصِييّثْ نْسنْ ذ دّْنُوبْ نْسنْ.“   
\m
\v 4 \add خنِّي\add* إِڒَاغَا-د إِرْمِييَا خْ بَارُوخْ، مِّيسْ ن نِيرِي-يَاهْ، ؤُشَا يُورَا بَارُوخْ زڭْ ؤُقمُّومْ ن إِرْمِييَا مَارَّا أَوَاڒنْ ن سِيذِي نِّي ذ أَسْ إِنَّا ذڭْ إِجّْ ن وذْلِيسْ إِتّْوَانّْضنْ.  
\v 5 يُومُورْ إِرْمِييَا إِ بَارُوخْ، إِنَّا: ”نشّْ تّْوَاسّْبدّغْ، وَارْ زمَّارغْ أَذْ د-أَذْفغْ غَارْ ثَادَّارْثْ ن سِيذِي.  
\v 6 أَذفْ-د شكْ غَارْ ذَاخڒْ ؤُشَا غَارْ أَوَاڒنْ ن سِيذِي زڭْ وذْلِيسْ إِتّْوَانْضنْ نِّي ثُورِيذْ زڭْ ؤُقمُّومْ إِنُو ذڭْ إِمزُّوغنْ ن ڒْڭنْسْ ذِي ثَادَّارْثْ ن سِيذِي ذڭْ وَاسّْ ن ؤُژُومِّي. إِتّْخصَّا أَذْ ثنْ ثْغَارذْ ذڭْ إِمزُّوغنْ ن مَارَّا \add أَيْثْ ن\add* يَاهُوذَا، إِنِّي د-يُوسِينْ زِي مَارَّا ثِيندَّامْ نْسنْ.  
\v 7 أَذْ ثَاغْ أَذْ يَافْ ثُوثْرَا نْسنْ أَرْضَا زَّاثْ إِ وُوذمْ ن سِيذِي ؤُ أَذْ د-ذوْڒنْ أَذْ ثُوبنْ نِيثْنِي، كُوڒْ إِجّْ زڭْ وبْرِيذْ نّسْ أَعفَّانْ، مَاغَارْ ذ أَمقّْرَانْ إِ يدْجَا وغْضَابْ ذ وسْعَارْ إِ خْ ثُوغَا إِسِّيوڒْ سِيذِي إِ ڒْڭنْسْ-أَ.“   
\m
\v 8 بَارُوخْ، مِّيسْ ن نِيرِي-يَاهْ، إِڭَّا مَارَّا أَمْ مَامّشْ ث يُومُورْ ؤُنَابِي إِرْمِييَا، ؤُشَا إِغْرَا-د أَوَاڒنْ ن سِيذِي \add إِ ڒْڭنْسْ\add* زڭْ وذْلِيسْ \add إِتّْوَانّْضنْ\add* ذِي ثَادَّارْثْ ن سِيذِي.  
\v 9 ذڭْ ؤُسڭّْوَاسْ وِيسّْ خمْسَا ن يَاهُويَاقِيمْ، مِّيسْ ن يُوشِييَا، أَجدْجِيذْ ن يَاهُوذَا، ذڭْ ؤُيُورْ وِيسّْ ثسْعَا بَارّْحنْ س إِجّْ ن ؤُژُومِّي زَّاثْ إِ وُوذمْ ن سِيذِي إِ مَارَّا ڒْڭنْسْ ذِي ؤُرْشَالِيمْ ؤُ إِ مَارَّا ڒْڭنْسْ نِّي د-يُوسِينْ ذِي ؤُرْشَالِيمْ زِي ثْندَّامْ ن يَاهُوذَا.  
\v 10 إِغْرَا-د بَارُوخْ أَوَاڒنْ ن إِرْمِييَا ذِي ثَادَّارْثْ ن سِيذِي خْ إِمزُّوغنْ ن مَارَّا ڒْڭنْسْ زڭْ وذْلِيسْ \add إِتّْوَانّْضنْ\add*، ذڭْ وخَّامْ ن جَامَارْيَا، مِّيسْ ن شَافَانْ، أَمَارِيرْ، ذِي ڒمْرَاحْ ن سنّجْ، غَارْ وَاذَافْ ن ثوَّارْثْ ن جْذِيذْ ن ثَادَّارْثْ ن سِيذِي.   
\m
\v 11 \add ؤُمِي\add* مِيخَا-يَاهُو، مِّيسْ ن جَامَارْيَا، مِّيسْ ن شَافَانْ، إِسْڒَا إِ مَارَّا أَوَاڒنْ ن سِيذِي زڭْ وذْلِيسْ \add إِتّْوَانّْضنْ\add*،  
\v 12 إِهْوَا-د نتَّا غَارْ ثَادَّارْثْ ن ؤُجدْجِيذْ، غَارْ وخَّامْ ن ؤُمَارِيرْ. خْزَارْ، قِّيمنْ ذِينْ مَارَّا ڒْحُوكَّامْ: أَلِيشَامَاعْ، أَمَارِيرْ، ذَالَايَا، مِّيسْ ن شَامْعِييَا، إِلْ-نَاثَانْ، مِّيسْ ن عَاكْبُورْ، جَامَارْيَا، مِّيسْ ن شَافَانْ، صِيذْقِييَا، مِّيسْ ن حَانَانْيَا، ؤُ مَارَّا ڒْحُوكَّامْ.  
\v 13 مِيخَا-يَاهُو إِعَاوذْ أَسنْ مَارَّا أَوَاڒنْ نِّي ثُوغَا إِسْڒَا ؤُمِي د-إِغْرَا بَارُوخْ زڭْ وذْلِيسْ \add إِتّْوَانْضنْ\add* ذڭْ إِمزُّوغنْ نْ ڒْڭنْسْ.  
\v 14 \add خنِّي\add* سّكّنْ-د مَارَّا ڒْحُوكَّامْ يَاهُوذِي، مِّيسْ ن نَاثَانْيَا، مِّيسْ ن شَالَامْيَا، مِّيسْ ن كُوشِي، غَارْ بَارُوخْ، نَّانْ: ”أَذْلِيسْ إِتّْوَانْضنْ مَانِيسْ د-ثغْرِيذْ خْ ڒْڭنْسْ، كْسِي ث ذڭْ ؤُفُوسْ نّشْ ؤُشَا أَسْ-د!“ \add ڒخْذنِّي\add* إِكْسِي بَارُوخْ، مِّيسْ ن نِيرِي-يَاهْ، أَذْلِيسْ إِتّْوَانّْضنْ نِّي ؤُشَا يُوذفْ-د غَارْسنْ.  
\v 15 نِيثْنِي نَّانْ أَسْ: ”قِّيمْ، ثْغَارذْ أَذْلِيسْ إِتّْوَانّْضنْ خَانغْ!“ \add خنِّي\add* إِغْرَا ث بَارُوخْ خَاسنْ.   
\m
\v 16 ؤُمِي سْڒِينْ نِيثْنِي مَارَّا أَوَاڒنْ \add نِّي\add*، خْزَارنْ ذڭْ وَايَاوْيَا ڭّْوذنْ ؤُشَا نَّانْ إِ بَارُوخْ: ”نِيشَانْ أَذْ نْعَاوذْ مَارَّا أَوَاڒنْ-أَ إِ ؤُجدْجِيذْ.“  
\v 17 نِيثْنِي سّقْسَانْ بَارُوخْ، نَّانْ: ”إِنِي أَنغْ مَاشَا، مَامّشْ ثُورِيذْ مَارَّا أَوَاڒنْ-أَ زڭْ ؤُقمُّومْ نّسْ؟“  
\v 18 يَارَّا-د خَاسنْ بَارُوخْ: ”س ؤُقمُّومْ نّسْ إِ خَافِي إِغْرَا مَارَّا أَوَاڒنْ-أَ ؤُ نشّْ ؤُرِيغْ ثنْ س سّْمخْ ذڭْ وذْلِيسْ\add -أَ\add* \add إِتّْوَانّْضنْ\add*.“  
\v 19 \add خَاسْ ؤُشَا\add* نَّانْ ڒْحُوكَّامْ إِ بَارُوخْ: ”ؤُيُورْ، فَّارْ إِخفْ نّشْ، شكْ ؤُڒَا ذ إِرْمِييَا! ؤُڒَا ذ إِجّْ وَارْ إِتّسّنْ مَانِي ثدْجَامْ.“  
\v 20 ؤُذْفنْ نِيثْنِي غَارْ ؤُجدْجِيذْ ذِي ڒمْرَاحْ، \add مَاشَا\add* نِيثْنِي ثُوغَا خمّْڒنْ أَذْلِيسْ إِتّْوَانّْضنْ ذڭْ وخَّامْ ن إِلِيشَامَاعْ، أَمَارِيرْ، ؤُ نِيثْنِي حَاجَانْ مَارَّا أَوَاڒنْ-أَ غَارْ إِمزُّوغنْ ن ؤُجدْجِيذْ.   
\m
\v 21 \add خنِّي\add* إِسّكّْ ؤُجدْجِيذْ يَاهُوذِي مَاحنْذْ أَذْ د-يَاوِي أَذْلِيسْ إِتّْوَانّْضنْ. وَانِيثَا يِيوِي ث إِ-د زڭْ وخَّامْ ن أَلِيشَامَاعْ، أَمَارِيرْ، ؤُشَا إِغْرَا إِ-ث-إِ-د يَاهُوذِي ذڭْ إِمجَّانْ ن ؤُجدْجِيذْ ؤُ ذڭْ إِمجَّانْ ن مَارَّا ڒْحُوكَّامْ نِّي د-إِبدّنْ غَارْ ؤُجدْجِيذْ.  
\v 22 ثُوغَا إِقِّيمْ ؤُجدْجِيذْ ذِي ثَادَّارْثْ ن ثَاڭَارْسْثْ، ثُوغَا ذ أَيُورْ وِيسّْ ثسْعَا. زَّاثسْ ثَارقّْ \add ذِينِّي\add* ثْمسِّي خْ ثْمجْمَارْثْ.  
\v 23 ڒَامِي إِغْرَا يَاهُوذِي ثْڒَاثَا نِيغْ أَربْعَا ن إِضوْضَانْ، إِقسّْ إِ-ثنْ ؤُجدْجِيذْ س ڒْمُوسّْ ن ؤُمَارِيرْ ؤُشَا إِنْضَارْ إِ-ثنْ ذِي ثْمسِّي خْ ڒْمجْمَارْ، أَڒَامِي ثُوغَا ثِيمسِّي خْ ڒْمجْمَارْ ثشَّا مَارَّا أَذْلِيسْ.  
\v 24 أَجدْجِيذْ ذ مَارَّا إِمْسخَّارنْ نّسْ إِنِّي إِسْڒِينْ إِ وَاوَاڒنْ-أَ مَارَّا، وَارْ نّْخڒْعنْ ؤُ وَارْ شَارّْڭنْ أَرُّوضْ نْسنْ.  
\v 25 تَّارنْ إِلْ-نَاثَانْ ذ ذَالَايَا ذ جَامَارْيَا إِ ؤُجدْجِيذْ أَطَّاسْ حِيمَا وَارْ إِسّشْمِيضْ \add أَذْلِيسْ\add* إِتّْوَانّْضنْ، \add مَاشَا\add* نتَّا وَارْ غَارْسنْ إِسْڒِي.  
\v 26 \add عَاذْ\add* يُومُورْ ؤُجدْجِيذْ إِ يَارْحَامِييِيلْ، مِّيسْ ن ؤُجدْجِيذْ، إِ سَارَايَا، مِّيسْ ن عَازْرَايِيلْ، ؤُ إِ شَالَامْيَا، مِّيسْ ن عَابْذِييِيلْ، حِيمَا أَذْ طّْفنْ أَمَارِيرْ بَارُوخْ ذ ؤُنَابِي إِرْمِييَا ذ إِمحْبَاسْ. \add مَاشَا\add* سِيذِي إِسّْنُوفَّارْ إِ-ثنْ.   
\m
\v 27 يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِرْمِييَا، أَوَارْنِي ڒَامِي إِسّشْمضْ ؤُجدْجِيذْ أَذْلِيسْ إِتّْوَانّْضنْ ذ وَاوَاڒنْ نِّي يُورَا بَارُوخْ، \add إِنِّي د-إِفّْغنْ\add* زڭْ ؤُقمُّومْ ن إِرْمِييَا، إِنَّا:  
\v 28 ”كْسِي عَاوذْ إِجّْ ن وذْلِيسْ إِتّْوَانّْضنْ نّغْنِي ؤُ أَرِي خَاسْ مَارَّا أَوَاڒنْ إِمزْوُورَا، إِنِّي ثُوغَا ذڭْ وذْلِيسْ أَمزْوَارُو إِ إِسّشْمضْ يَاهُويَاقِيمْ، أَجدْجِيذْ ن يَاهُوذَا،  
\v 29 ؤُشَا إِنِي إِ يَاهُويَاقِيمْ، أَجدْجِيذْ ن يَاهُوذَا: ’أَمُّو إِ إِقَّارْ سِيذِي: شكْ ثسّْشمْضذْ أَذْلِيسْ-أَ إِتّْوَانّْضنْ، ثنِّيذْ: مَايمِّي ذَايسْ ثُورِيذْ، ثنِّيذْ: أَجدْجِيذْ ن بَابِيلْ أَذْ د-يَاسْ، أَذْ إِخَارّبْ ثَامُّورْثْ ؤُشَا أَذْ زَّايسْ إِمْحَا بْنَاذمْ ذ ڒْمَاڒْ؟‘  
\v 30 ’س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي خْ يَاهُويَاقِيمْ، أَجدْجِيذْ ن يَاهُوذَا: وَارْ غَارسْ إِتِّيڒِي ونِّي إِ غَا إِقِّيمنْ خْ ڒْعَارْشْ ن ذَاوُوذْ ؤُشَا ڒْخشْبثْ نّسْ أَذْ ثمّنْضَارْ إِ ڒحْمُو ن ؤُزِيڒْ ؤُ إِ ثسْمضْ ن دْجِيڒثْ. \x ◘ \xo 36:‏30 \xt إِرْم. 22‏:‏19\x*  
\v 31 نشّْ أَذْ زَّايسْ خڒْفغْ ڒْمُوعْصِييّثْ نْسنْ، ؤُڒَا زِي ثَارْوَا نّسْ ؤُڒَا زڭْ إِمْسخَّارنْ نّسْ. نشّْ أَذْ سّْغضْڒغْ خَاسنْ، خْ إِمزْذَاغْ ن ؤُرْشَالِيمْ ؤُ خْ إِرْيَازنْ ن يَاهُوذَا، مَارَّا ڒْغَارْ إِ ذ أَسنْ نِّيغْ، \add وَاخَّا\add* نِيثْنِي وَارْ خْسنْ أَذْ سْڒنْ.‘ “ \f ◼ \fr 36:‏31 \ft \+bd ’ثَارْوَا نّسْ‘\+bd* - س ثْعِيبْرَانِيثْ ’زَّارِيعثْ نّسْ‘.\f*   
\m
\v 32 إِكْسِي إِرْمِييَا إِجّْ ن وذْلِيسْ نّغْنِي إِتّْوَانّْضنْ ؤُشَا إِوْشَا إِ-ث إِ ؤُمَارِيرْ بَارُوخْ، مِّيسْ ن نِيرِي-يَاه. وَانِيثَا يُورَا خَاسْ، زڭْ ؤُقمُّومْ ن إِرْمِييَا، مَارَّا أَوَاڒنْ ن وذْلِيسْ \add إِتّْوَانّْضنْ\add* نِّي ثُوغَا يَاهُويَاقِيمْ، أَجدْجِيذْ ن يَاهُوذَا، إِسّشْمضْ س ثْمسِّي ؤُشَا تّْوَارْنِينْ عَاذْ غَارْسنْ وَاطَّاسْ ن وَاوَاڒنْ نّغْنِي إِ ثنْ يُوذْسنْ.   
\b  
\b  
\m  
\c 37
\s1 أَجدْجِيذْ صِيذْقِييَا إِسّكّْ غَارْ إِرْمِييَا إِ ثْوَاڒَا وِيسّْ ثْنَاينْ  
\m
\v 1 إِذْوڒْ صِيذْقِييَا، مِّيسْ ن يُوشِييَا، ذ أَجدْجِيذْ ذڭْ ومْشَانْ ن كُونْ-يَاهُو، مِّيسْ ن يَاهُويَاقِيمْ، ونِّي ثُوغَا إِڭَّا نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ذ أَجدْجِيذْ خْ ثمُّورْثْ ن يَاهُوذَا.  
\v 2 وَانِيثَا وَارْ إِسْڒِي شَا غَارْ وَاوَاڒنْ ن سِيذِي نِّي إِسِّيوڒْ نتَّا س ؤُفُوسْ ن ؤُنَابِي إِرْمِييَا، وَارْ إِدْجِي وَانِيثَا ؤُڒَا ذ إِمْسخَّارنْ نّسْ ؤُڒَا ذ ڒْڭنْسْ ن ثمُّورْثْ.  
\v 3 \add وَاخَّا أَمنِّي\add* إِسّكّْ ؤُجدْجِيذْ صِيذْقِييَا يَاهُوخَالْ، مِّيسْ ن شَالَامْيَا، ذ صَافَانْيَا، مِّيسْ ن مَاعَاسِييَا، غَارْ ؤُنَابِي إِرْمِييَا مَاحنْذْ أَذْ أَسْ إِنِينْ: ”ژَتدْجْ خَانغْ غَارْ سِيذِي، أَربِّي نّغْ!“ \f ◼ \fr 37:‏3 \ft \+bd ’صَافَانْيَا‘\+bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي ث إِسّْنُوفَّارنْ سِيذِي‘.\f*   
\m
\v 4 إِرْمِييَا ثُوغَا عَاذْ إِزمَّارْ أَذْ يَاذفْ ؤُ أَذْ إِفّغْ ذِي ڒْوسْطْ نْ ڒْڭنْسْ ؤُ نِيثْنِي ثُوغَا عَاذْ وَارْ ث نْضَارنْ ذِي ڒْحبْسْ.  
\v 5 إِفّغْ-د ڒْعسْكَارْ ن فِيرْعُونْ زِي مِيصْرَا ؤُشَا ؤُمِي سْڒِينْ إِكَالْذَانِييّنْ نِّي ثُوغَا إِحصَّارنْ ؤُرْشَالِيمْ خْ مَانْ أَيَا، أَڭّْوجنْ خْ ؤُرْشَالِيمْ. \x ◘ \xo 37:‏5 \xt إِرْم. 34‏:‏21\x*   
\m
\v 6 خنِّي يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ ؤُنَابِي إِرْمِييَا، إِنَّا:  
\v 7 ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’أَمُّو إِ غَا ثِينِيمْ إِ ؤُجدْجِيذْ ن يَاهُوذَا، ونِّي كنِّيوْ غَارِي د-إِسّكّنْ حِيمَا أَذْ أَيِي ثسّقْسَامْ: خْزَارْ، ڒْعسْكَارْ ن فِيرْعُونْ نِّي د-إِفّْغنْ مَاحنْذْ أَذْ أَومْ إِوْشْ أَفُوسْ، أَذْ د-إِعْقبْ غَارْ ثمُّورْثْ نّسْ، غَارْ مِيصْرَا!  
\v 8 أَذْ د-ذوْڒنْ إِكَالْذَانِييّنْ، أَذْ مّنْغنْ أَكْ-ذ ثنْذِينْثْ-أَ ؤُشَا أَذْ ت طّْفنْ، أَذْ أَسْ قّْذنْ ثِيمسِّي.‘  
\v 9 أَمُّو إِ إِقَّارْ سِيذِي: ’وَارْ شمّْثمْ إِخفْ نْومْ خْمِي غَا ثِينِيمْ: إِكَالْذَانِييّنْ أَذْ خَانغْ أَڭّْوجنْ، أَذْ ؤُيُورنْ!، مِينْزِي نِيثْنِي وَارْ ڭُّورنْ.  
\v 10 عَاذْ مَاڒَا كنِّيوْ ثْغڒْبمْ مَارَّا ڒْعسْكَارْ ن إِكَالْذَانِييّنْ إِنِّي أَكِيذْومْ إِتّْمنْغَانْ، ؤُشَا أَذْ زَّايْسنْ قِّيمنْ مْغِيرْ إِرْيَازنْ إِيزْمنْ أَطَّاسْ، أَقَا نِيثْنِي أَذْ كَّارنْ، كُوڒْ  إِجّْ ذڭْ ؤُقِيضُونْ نّسْ، ؤُشَا أَذْ قّْذنْ ثِيمسِّي إِ ثنْذِينْثْ-أَ.‘ “   
\b  
\m  
\s1 إِرْمِييَا إِتّْوَاحبّسْ  
\m
\v 11 إِمْسَارْ ؤُمِي د-إِسّْڭعّذْ ڒْعسْكَارْ ن إِكَالْذَانِييّنْ زِي ؤُرْشَالِيمْ زِي سِّيبّثْ ن ڒْعسْكَارْ ن فِيرْعُونْ،  
\v 12 إِفّغْ إِرْمِييَا زِي ؤُرْشَالِيمْ مَاحنْذْ أَذْ إِرَاحْ غَارْ ثمُّورْثْ ن بِينْيَامِينْ حِيمَا أَذْ ذِينِّي إِطّفْ إِشْثْ ن ثسْغَارْثْ ذِي ڒْوسْطْ ن ڒْڭنْسْ نّسْ.  
\v 13 \add ڒَْامِي ث ثُوغَا\add* ذِي ثوَّارْثْ ن بِينْيَامِينْ، ثُوغَا ذِينْ أَكُومَانْذَارْ ن ثْعسَّاسْثْ، قَّارنْ أَسْ يَارِييَّا، مِّيسْ ن شَالَامْيَا، مِّيسْ ن حَانَانْيَا. نتَّا إِطّفْ أَنَابِي إِرْمِييَا، إِنَّا: ”شكْ ثخْسذْ أَذْ ثَاروْڒذْ غَارْ إِكَالْذَانِييّنْ!“  
\v 14 يَارَّا-د \add خَاسْ\add* إِرْمِييَا: ”مَانْ أَيَا مْغِيرْ ذ أَخَارِّيقْ! نشّْ وَارْ خْسغْ شَا أَذْ أَروْڒغْ غَارْ إِكَالْذَانِييّنْ!“ \add مَاشَا\add* نتَّا وَارْ غَارسْ إِسْڒِي شَا ؤُشَا إِطّفْ يَارِييَّا إِرْمِييَا ؤُشَا يِيوْيِي ث غَارْ ڒْحُوكَّامْ \add نْ ڒْڭنْسْ\add*.  
\v 15 فُّوڭْمنْ ڒْحُوكَّامْ أَطَّاسْ خْ إِرْمِييَا، وْثِينْ ث ؤُشَا ڭِّينْ ث ذِي ڒحْبسْ، ذِي ثَادَّارْثْ ن ؤُمَارِيرْ يُونَاثَانْ، مَاغَارْ ثَانِيثَا ثُوغَا أَرِّينْ ت ذ ثَادَّارْثْ ن ثْعسَّاسْثْ.  
\v 16 أَمُّو د-إِوْضَا إِرْمِييَا ذڭْ وحْفُورْ ن إِمحْبَاسْ ؤُ ذڭْ إِخَّامنْ ن ڒحْبسْ. ذِينِّي إِقِّيمْ إِرْمِييَا أَطَّاسْ ن وُوسَّانْ.   
\b  
\m  
\s1 ڒْهَارْدْ ن صِيذْقِييَا أَكْ-ذ إِرْمِييَا إِ ثْوَاڒَا ثَامزْوَارُوثْ  
\m
\v 17 إِسّكّْ ؤُجدْجِيذْ صِيذْقِييَا إِجّنْ مَاحنْذْ أَذْ ث-إِ-د-أَوْينْ ؤُشَا إِسّقْسَا ث ؤُجدْجِيذْ س ثْنُوفّْرَا ذِي ثْزذِّيغْثْ نّسْ، إِنَّا: ”مَا أَقَا ذِينْ \add زعْمَا\add* شَا ن وَاوَاڒْ ن سِيذِي؟“ إِنَّا \add أَسْ\add* إِرْمِييَا: ”أَقَا-ث ذِينْ!“ \add خنِّي\add* إِنَّا: ”شكْ أَذْ ثوْضِيذْ ذڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن بَابِيلْ.“  
\v 18 \add ڒخْذنِّي\add* إِنَّا إِرْمِييَا إِ ؤُجدْجِيذْ صِيذْقِييَا: ”مَانْ ڒْعِيبْ إِ ذَايكْ ڭِّيغْ نِيغْ ذڭْ إِمْسخَّارنْ نّشْ نِيغْ ذِي ڒْڭنْسْ-أَ أَڒَامِي كنِّيوْ ذ أَيِي ثنْضَارمْ ذِي ڒحْبسْ؟  
\v 19 مَانِي دْجَانْ \add ڒخُّو\add* إِنَابِييّنْ نْومْ نِّي ثُوغَا إِتّْنَابّنْ إِ كنِّيوْ، قَّارنْ: أَجدْجِيذْ ن بَابِيلْ وَارْ د-إِتِّيسْ ضِيدّْ نْومْ ؤُ ضِيدّْ إِ ثمُّورْثْ-أَ!  
\v 20 \add خنِّي\add* ڒخُّو، سڒْ مَاشَا، \add أَ\add* سِيذِي إِنُو أَجدْجِيذْ! إِڒِي أَذْ ثَافْ ثُوثْرَا إِنُو ذ أَرْضَا زَّاثْ إِ وُوذمْ نّشْ! وَارْ تّجِّي أَذْ أَيِي أَرّنْ غَارْ ثَادَّارْثْ ن ؤُمَارِيرْ يُونَاثَانْ حِيمَا وَارْ ذِينِّي تّْمتِّيغْ.“  
\v 21 \add خنِّي\add* يُومُورْ ؤُجدْجِيذْ صِيذْقِييَا أَذْ حْضَانْ خْ إِرْمِييَا ذِي ڒمْرَاحْ ن ڒحْبسْ ؤُشَا وْشِينْ أَسْ كُوڒْ أَسّْ إِجّْ ن ونْڭُورْ ن وغْرُومْ زِي زّنْقثْ ن إِخْبَايْزِييّنْ أَڒَامِي إِقْضَا وغْرُومْ زِي ثنْذِينْثْ. \add أَمُّو إِ\add* إِقِّيمْ إِرْمِييَا ذِي ڒمْرَاحْ ن ڒحْبسْ. \x ◘ \xo 37:‏21 \xt إِرْم. 32‏:‏2\x*   
\b  
\b  
\m  
\c 38
\s1 إِرْمِييَا ذڭْ وَانُو  
\m
\v 1 \add ڒَْامِي\add* شَافَاطْيَا، مِّيسْ ن مَاتَّانْ، ذ جَاذَالْيَا، مِّيسْ ن فَاشْحُورْ، ذ يُوخَالْ، مِّيسْ ن شَالَامْيَا، ذ فَاشْحُورْ، مِّيسْ ن مَالْكِييَا، سْڒِينْ إِ وَاوَاڒنْ نِّي إِسِّيوڒْ إِرْمِييَا غَارْ مَارَّا ڒْڭنْسْ، ؤُمِي وَانِيثَا إِنَّا:  
\v 2 ”أَمُّو إِ إِقَّارْ سِيذِي: ’ونِّي إِ غَا إِقِّيمنْ ذِي ثنْذِينْثْ-أَ، أَذْ إِتّْوَانغْ س سِّيفْ، س ڒَاژْ نِيغْ س طَّاعُونْ، \add مَاشَا\add* ونِّي إِ غَا إِفّْغنْ غَارْ إِكَالْذَانِييّنْ، أَذْ إِقِّيمْ إِدَّارْ. نتَّا أَذْ يَاوِي أَكِيذسْ بُوحْبڒْ نّسْ أَمْ ثْكشَّاضْثْ، أَذْ إِقِّيمْ إِدَّارْ!‘. \x ◘ \xo 38:‏2 \xt إِرْم. 21‏:‏9\x*  
\v 3 أَمُّو إِ إِقَّارْ سِيذِي: ’ثَانْذِينْثْ-أَ أَذْ ثمّوْشْ ذڭْ ؤُفُوسْ ن ڒْعسْكَارْ ن ؤُجدْجِيذْ ن بَابِيلْ ؤُ نتَّا أَذْ ت إِطّفْ!‘ “،  
\v 4 \add ڒخْذنِّي\add* نَّانْ ڒْحُوكَّامْ إِ ؤُجدْجِيذْ: ”إِتّْخصَّا أَذْ إِتّْوَانغْ ورْيَازْ-أَ، مِينْزِي أَمُّو إِ إِسّفْشَاڒْ إِفَاسّنْ ن إِعسْكَارِييّنْ نِّي \add عَاذْ\add* إِقِّيمنْ ذِي ثنْذِينْثْ-أَ ؤُڒَا ذ إِفَاسّنْ ن مَارَّا ڒْڭنْسْ ؤُمِي غَارْسنْ إِسَّاوَاڒْ أَوَاڒنْ-أَ، مَاغَارْ أَرْيَازْ-أَ وَارْ يَارزُّو شَا ڒهْنَا إِ ثنْذِينْثْ-أَ، مَاشَا يَارزُّو ڒْغَارْ.“  
\v 5 إِنَّا ؤُجدْجِيذْ صِيذْقِييَا: ”خْزَارْ، نتَّا أَقَا-ث ذڭْ ؤُفُوسْ نّمْ، مَاغَارْ أَجدْجِيذْ وَارْ إِزمَّارْ أَذْ أَومْ إِڭّْ وَالُو.“  
\v 6 طّْفنْ نِيثْنِي إِرْمِييَا ؤُشَا نْضَارنْ ث ذڭْ وَانُو ن مِّيسْ ن ؤُجدْجِيذْ مَالْكِييَا، ونِّي \add إِدْجَانْ\add* ذِي ڒمْرَاحْ نْ ڒحْبسْ. سيّْبنْ إِرْمِييَا س إِسغْوَانْ سْوَادَّايْ. ثُوغَا وَارْ ذِينْ بُو وَامَانْ ذڭْ وَانُو، مَاشَا مْغِيرْ أَبَارْيُوضْ ؤُشَا إِغْضسْ إِرْمِييَا ذڭْ ؤُبَارْيُوضْ.   
\m
\v 7 \add ؤُمِي\add* إِسْڒَا عَابْذْ-مَالِيكْ، أَكُوشِي، إِجّْ ن ؤُمْسخَّارْ أَمْشنّعْ ذِي ثَادَّارْثْ ن ؤُجدْجِيذْ، أَقَا نْضَارنْ إِرْمِييَا ذڭْ وَانُو، ؤُشَا إِقِّيمْ ؤُجدْجِيذْ غَارْ ثوَّارْثْ ن بِينْيَامِينْ، \f ◼ \fr 38:‏7 \ft \+bd ’أَكُوشِي‘\+bd* - إِجّْ ن ورْيَازْ زِي ثمُّورْثْ ن كُوشْ نِّي إِدْجَانْ ذ سُّوذَانْ ذ إِثِييُوبِييَّا ن يِيضَا.\f*  
\v 8 إِفّغْ عَابْذْ-مَالِيكْ زِي ثَادَّارْثْ ن ؤُجدْجِيذْ ؤُشَا إِسِّيوڒْ أَكْ-ذ ؤُجدْجِيذْ، إِنَّا:  
\v 9 ”\add أَ\add* سِيذِي إِنُو أَجدْجِيذْ، إِرْيَازنْ-أَ ڭِّينْ مِينْ وَارْ إِحْڒِينْ ذِي مَارَّا مِينْ ڭِّينْ إِ ؤُنَابِي إِرْمِييَا، ونِّي نْضَارنْ نِيثْنِي ذڭْ وَانُو. ثُوغَا إِزمَّارْ أَذْ ذِينِّي إِمّثْ س ڒَاژْ، مَاغَارْ \add عَاذْ\add* وَالُو أَغْرُومْ ذِي ثنْذِينْثْ.“  
\v 10 \add خنِّي\add* يُومُورْ ؤُجدْجِيذْ عَابْذْ-مَالِيكْ أَكُوشِي \add زِي ثمُّورْثْ ن كُوشْ\add*، إِنَّا: ”كْسِي سّنِّي ثْڒَاثِينْ ن يرْيَازنْ سَاذُو ؤُفُوسْ نّشْ ؤُشَا سْڭعّذْ أَنَابِي إِرْمِييَا زڭْ وَانُو قْبڒْ إِ غَا إِمّثْ.“  
\v 11 عَابْذْ-مَالِيكْ إِكْسِي إِرْيَازنْ \add نِّي\add* سَاذُو ؤُفُوسْ نّسْ ؤُشَا يُوذفْ غَارْ ثَادَّارْثْ ن ؤُجدْجِيذْ أَڒْ وَادَّايْ ن وخَّامْ ن ثْخُوبَايْ. سّنِّي إِكْسِي إِكتَّاننْ إِقْذِيمنْ ذ وَارُّوضْ إِقَّارْصنْ ؤُشَا إِسّهْوَا إِ-ثنْ-د س إِسغْوَانْ غَارْ إِرْمِييَا ذڭْ وَانُو.  
\v 12 \add خنِّي\add* إِنَّا عَابْذْ-مَالِيكْ أَكُوشِي إِ إِرْمِييَا: ”أڭّْ إِكتَّاننْ إِقْذِيمنْ ذ وَارُّوضْ إِقَّارْصنْ سَاذُو ثِيذِّيغِينْ ن إِغَادْجنْ نّشْ ؤُشَا أڭّْ إِسغْوَانْ سْوَادَّايْ!“ ؤُشَا أَمُّو إِ ت إِڭَّا إِرْمِييَا.  
\v 13 جبْذنْ-د نِيثْنِي إِرْمِييَا س إِسغْوَانْ ؤُشَا سّْڭعّْذنْ ث-إِ-د زڭْ وَانُو. \add مَاشَا\add* إِرْمِييَا إِقِّيمْ ذِي ڒمْرَاحْ نْ ڒحْبسْ.   
\b  
\m  
\s1 ڒْهَارْدْ ن صِيذْقِييَا أَكْ-ذ إِرْمِييَا إِ ثْوَاڒَا وِيسّْ ثْنَاينْ  
\m
\v 14 \add خنِّي\add* إِسّكّْ أَجدْجِيذْ صِيذْقِييَا \add شَا ن إِمْسخَّارنْ نّسْ\add*، إِجَّا أَذْ أَسْ د-أَوْينْ أَنَابِي إِرْمِييَا غَارْ وَاذَافْ وِيسّْ ثْڒَاثَا غَارْ ثَادَّارْثْ ن سِيذِي. إِنَّا ؤُجدْجِيذْ إِ إِرْمِييَا: ”نشّْ خْسغْ أَذْ شكْ سّقْسِيغْ خْ إِشْثْ نْ ڒْحَاجّثْ، وَارْ خَافِي ت تّفَّارْ وَالُو.“  
\v 15 يَارَّا-د إِرْمِييَا خْ صِيذْقِييَا: ”مَاڒَا نشّْ سَّارْڭْبغْ شكْ، مَا وَارْ ذ أَيِي ثْنقّذْ زعْمَا؟ ؤُ مَاڒَا وْشِيغْ أَشْ إِجّْ ن أَرَّايْ، شكْ وَارْ غَارِي ثتّسْڒِيذْ!“  
\v 16 \add خَاسْ ؤُشَا\add* إِجُّودْجْ ؤُجدْجِيذْ صِيذْقِييَا إِ إِرْمِييَا س ثْنُوفّْرَا إِنَّا: ”س ثِيذتّْ أَمْ إِدَّارْ سِيذِي ونِّي ذ أَنغْ إِوْشِينْ ثُوذَارْثْ-أَ: ’\add ؤُشْثْ خَافِي\add*، مَاڒَا نشّْ نْغِيغْ شكْ نِيغْ مَاڒَا وْشِيغْ شكْ ذڭْ إِفَاسّنْ ن يرْيَازنْ نِّي يَارزُّونْ ثُوذَارْثْ نّشْ!‘ “ \x ◘ \xo 38:‏16 \xt إِشا. 57‏:‏16\x*  
\v 17 إِنَّا إِرْمِييَا إِ صِيذْقِييَا: ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’مَاڒَا شكْ أَذْ ثفّْغذْ س ثِيذتّْ غَارْ ڒْحُوكَّامْ ن ؤُجدْجِيذْ ن بَابِيلْ، أَذْ ثقِّيمذْ أَذْ ثدَّارذْ، ؤُشَا ثَانْذِينْثْ-أَ وَارْ ثتّْوَاسّشْمَاضْ س ثْمسِّي، شكْ أَذْ ثقِّيمذْ أَذْ ثدَّارذْ، \add وَاهْ\add* شكْ ذ ثَادَّارْثْ نّشْ.  
\v 18 \add مَاشَا\add* مَاڒَا وَارْ ثفِّيغذْ شَا غَارْ ڒْحُوكَّامْ ن ؤُجدْجِيذْ ن بَابِيلْ، \add خنِّي\add* أَذْ ثمّوْشْ ثنْذِينْثْ-أَ ذڭْ ؤُفُوسْ ن إِكَالْذَانِييّنْ. نِيثْنِي أَذْ ت سّْشمْضنْ س ثْمسِّي ؤُ شكْ وَارْ ثْنجّْمذْ زڭْ إِفَاسّنْ نْسنْ.‘ “  
\v 19 أَجدْجِيذْ صِيذْقِييَا إِنَّا إِ إِرْمِييَا: ”نشّْ تّڭّْوذغْ زڭْ وُوذَاينْ نِّي يعْذُونْ غَارْ إِكَالْذَانِييّنْ، أَڒَامِي نِيثْنِي وَارْ ذ أَيِي سّْعدُّونْ غَارْ ؤُفُوسْ نْسنْ ؤُ وَارْ زَّايِي تّڭّنْ مِينْ خْسنْ.“  
\v 20 إِنَّا \add أَسْ\add* إِرْمِييَا: ”نِيثْنِي وَارْ شكْ سلّْمنْ شَا. سڒْ مَاشَا غَارْ ثْمِيجَّا ن سِيذِي، غَارْ ڒْحَاڒْضْ إِنُو، \add خنِّي\add* أَذْ ثِيڒِيذْ مْلِيحْ ؤُ أَذْ ثقِّيمذْ أَذْ ثدَّارذْ. \f ◼ \fr 38:‏20 \ft \+bd ’أَذْ ثقِّيمذْ أَذْ ثدَّارذْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَذْ إِدَّارْ ڒعْمَارْ نّكْ‘.\f*  
\v 21 \add مَاشَا\add* مَاڒَا ثُوڭِيذْ أَذْ ثفّْغذْ، \add خنِّي\add* ذ وَا ذ أَوَاڒْ نِّي ذ أَيِي إِسّْشنْ سِيذِي:  
\v 22 ’خْزَارْ، مَارَّا ثِيمْغَارِينْ نِّي ثُوغَا إِقِّيمنْ ذِي ثَادَّارْثْ ن ؤُجدْجِيذْ ن يَاهُوذَا، أَذْ تّْوَانذْهنْثْ غَارْ ڒْحُوكَّامْ ن ؤُجدْجِيذْ ن بَابِيلْ. خْزَارْ، نِيثنْثِي أَذْ إِنِينْثْ:  
\b  
\m إِرْيَازنْ نِّي أَكْ-ذ ثُوغَا ثدَّارذْ ذِي ڒهْنَا،  
\m أَقَا غْذَارنْ شكْ ؤُ زمَّارنْ خَاكْ،  
\m نُّوغنْ إِضَارنْ نّشْ ذڭْ ؤُبَارْيُوضْ،  
\m \add ؤُشَا نِيثْنِي س يِيخفْ نْسنْ\add* ذوْڒنْ غَارْ ضفَّارْ! \f ◼ \fr 38:‏22 \ft \+bd ’إِرْيَازنْ نِّي أَكْ-ذ ثُوغَا ثدَّارذْ ذِي ڒهْنَا‘\+bd* - إِرْيَازنْ-أَ ذ إِرْيَازنْ إِشنْعنْ ذ إِنَابِييّنْ نِّي ثُوغَا إِسّْمُونَا ؤُجدْجِيذْ غَارسْ.\f*   
\b  
\m
\v 23 مَارَّا ثِيمْغَارِينْ نّشْ ذ إِحنْجِيرنْ نّشْ أَذْ تّْوَانذْهنْ غَارْ إِكَالْذَانِييّنْ، ؤُشَا ؤُڒَا ذ شكْ سِيمَانْثْ نّشْ وَارْ ثْنجّْمذْ زڭْ ؤُفُوسْ نْسنْ، مِينْزِي أَذْ ثتّْوَاطّْفذْ زڭْ ؤُجدْجِيذْ ن بَابِيلْ ؤُ ثَانْذِينْثْ-أَ أَذْ ثتّْوَاسّشْمضْ س ثْمسِّي.‘ “   
\m
\v 24 \add خنِّي\add* صِيذْقِييَا إِنَّا إِ إِرْمِييَا: ”إِتّْخصَّا ؤُڒَا ذ إِجّْ وَارْ إِتّسّنْ أَوَاڒنْ-أَ، \add أَمُّو\add* وَارْ ثْمّثِيذْ.  
\v 25 مَاڒَا ڒْحُوكَّامْ سْڒِينْ أَقَا نشّْ سِّيوْڒغْ أَكِيذكْ، أَذْ غَاركْ د-أَسنْ، أَذْ أَشْ إِنِينْ: ’إِنِي أَنغْ مِينْ ثنِّيذْ إِ ؤُجدْجِيذْ! وَارْ خَانغْ ثفَّارْ \add وَالُو\add*، نِيغْ أَقَا أَذْ شكْ ننّغْ: مِينْ خَاسْ كِيذكْ إِسِّيوڒْ ؤُجدْجِيذْ؟‘  
\v 26 \add خنِّي\add* إِتّْخصَّا أَذْ أَسنْ ثِينِيذْ: ’نشّْ وْضِيغْ س ڒْقدّْ إِنُو زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ حِيمَا وَارْ إِتّجِّي أَذْ أَيِي أَرّنْ غَارْ ثَادَّارْثْ ن يُونَاثَانْ مَاحنْذْ أَذْ ذِينِّي مّْثغْ.‘ “   
\m
\v 27 \add ڒَْامِي\add* د-ؤُسِينْ مَارَّا ڒْحُوكَّامْ غَارْ إِرْمِييَا، إِحَاجَا ثنْ مَارَّا أَوَاڒنْ-أَ إِنِّي ثُوغَا يُومُورْ ؤُجدْجِيذْ. \add خَاسْ ؤُشَا\add* جِّينْ ث مَاغَارْ ؤُڒَا ذ إِجّْ وَارْ إِسْڒِي ثَامسْڒَاشْثْ سِيمَانْثْ نّسْ.  
\v 28 \add أَمُّو إِ\add* إِقِّيمْ إِرْمِييَا ذِي ڒمْرَاحْ ن ڒحْبسْ أَڒْ أَسّْ نِّي ذِي ثتّْوَاطّفْ ؤُرْشَالِيمْ، \add وَاهْ،\add* نتَّا ثُوغَا-ث عَاذْ ذِينْ ؤُمِي ثتّْوَاطّفْ ؤُرْشَالِيمْ.   
\b  
\b  
\m  
\c 39
\s1 ؤُضُوفْ ن ؤُرْشَالِيمْ  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثسْعَا نْ صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ذڭْ ؤُيُورْ وِيسّْعشْرَا، يُوسَا-د نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، أَكْ-ذ مَارَّا ڒْعسْكَارْ نّسْ غَارْ ؤُرْشَالِيمْ ؤُشَا نّْضنْ أَسْ-د. \x ◘ \xo 39:‏1 \xt 2 إِج. 25‏:‏1؛ إِرْم. 52‏:‏4\x*  
\v 2 ذڭْ ؤُسڭّْوَاسْ وِيسّْ حِيطَاشْ ن صِيذْقِييَا، ذڭْ ؤُيُورْ وِيسّْ أَربْعَا، ذڭْ وَاسّْ وِيسّْ ثسْعَا ن ؤُيُورْ، وْثِينْ إِبُوخَّاشْ ذِي \add ڒْْحِيضْ ن\add* ثنْذِينْثْ.  
\v 3 \add خَاسْ ؤُشَا\add* ؤُذْفنْ مَارَّا ڒْحُوكَّامْ ن ؤُجدْجِيذْ ن بَابِيلْ ؤُشَا قِّيمنْ ذِي ثوَّارْثْ ن وَامَّاسْ: نَارْجَالْ-شَارَاصَارْ، شَامْجَارْ-نابُو، سَارْسَاخِيمْ، أَزدْجِيفْ ن إِمْسخَّارنْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ، نَارْجَالْ-شَارْصَارْ، أَزدْجِيفْ ن أَيْثْ ن بُو-ثْسحَّارْثْ، ؤُڒَا ذ مَارَّا ڒْحُوكَّامْ إِنّغْنِي ن ؤُجدْجِيذْ ن بَابِيلْ.  
\v 4 ڒَامِي صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ذ مَارَّا إِعسْكَارِييّنْ نّسْ ژْرِينْ ثنْ، أَروْڒنْ نِيثْنِي، فّْغنْ زِي ثنْذِينْثْ سْ دْجِيڒثْ خْ وبْرِيذْ غَارْ وحْوِيشْ ن ؤُجدْجِيذْ. نِيثْنِي كِّينْ زِي ثوَّارْثْ جَارْ ثْنَاينْ ن ڒحْيُوضْ ؤُشَا نتَّا إِطّفْ أَبْرِيذْ غَارْ ڒوْضَا.   
\m
\v 5 ضْفَارنْ ثنْ ڒْعسْكَارْ ن إِكَالْذَانِييّنْ، حَارْثنْ خْ صِيذْقِييَا ذِي ڒوْضَاثْ ن أَرِيحَا. نِيثْنِي طّْفنْ ث ذ أَمحْبُوسْ ؤُشَا إِوْينْ ث غَارْ نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، غَارْ رِيبْلَا ذِي ثمُّورْثْ ن حَامَاثْ، ؤُ وَانِيثَا إِحْكمْ خَاسْ.  
\v 6 إِجَّا ؤُجدْجِيذْ ن بَابِيلْ أَذْ غَارْصنْ إِحنْجِيرنْ ن صِيذْقِييَا زَّاثْ إِ ثِيطَّاوِينْ نّسْ ذِي رِيبْلَا. ؤُڒَا ذ مَارَّا ثَارْوَا ن ثَاصِيڒثْ ن يَاهُوذَا إِغَارْصْ أَسنْ ؤُجدْجِيذْ ن بَابِيلْ.  
\v 7 إِسّْذَارْغڒْ نتَّا ثِيطَّاوِينْ ن صِيذْقِييَا ؤُشَا إِقّنْ إِ-ث س ثْنَاينْ ن سّْنَاسڒْ ن نّْحَاسْ مَاحنْذْ أَذْ ث يَاوِي غَارْ بَابِيلْ.  
\v 8 سّْشمْضنْ إِكَالْذَانِييّنْ ثَادَّارْثْ ن ؤُجدْجِيذْ ذ ثُوذْرِينْ ن ڒْڭنْسْ س ثْمسِّي ؤُشَا أَڒْژِينْ ڒحْيُوضْ ن ؤُرْشَالِيمْ.  
\v 9 مِينْ إِشطّنْ زِي ڒْڭنْسْ نِّي إِتّْوَاجّنْ ذِي ثنْذِينْثْ، \add إِخْسْ أَذْ يِينِي\add* \add مَارَّا\add* إِنِّي ثُوغَا إِعْذُونْ غَارْ ؤُجدْجِيذْ ن بَابِيلْ ذ مِينْ إِشطّنْ زِي ڒْڭنْسْ، إِنْذهْ إِ-ثنْ نابُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، ذِي لْمنْفَا.  
\v 10 زڭْ إِمزْڒَاضْ ن ڒْڭنْسْ نِّي وَارْ غَارْ إِدْجِي وَالُو، إِجَّا نبُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، إِجّْ ن وزْينْ ذِي ثمُّورْثْ ن يَاهُوذَا. إِوْشَا أَسنْ ذڭْ وَاسّْ نِّي إِمَارْجَاعنْ ن ؤُضِيڒْ ذ إِيَّارنْ.   
\m
\v 11 نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ثُوغَا يُومُورْ نبُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، خْ إِرْمِييَا، إِنَّا:  
\v 12 ”أَوْيِي ث-إِ-د، حْضَا خَاسْ. وَارْ ذَايسْ تّڭّْ ؤُڒَا ذ إِجّْ نْ ڒْغَارْ، \add مَاشَا\add* أڭّْ أَكِيذسْ أَمْ مَامّشْ إِ ذ أَشْ غَا يِينِي.“  
\v 13 \add خنِّي\add* إِسّكّْ نبُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، \add شَا ن إِرقَّاسنْ\add*، \add نتَّا جْمِيعْ\add* أَكْ-ذ نبُوشَازْبَانْ، أَمقّْرَانْ ن إِمْسخَّارنْ ن ؤُجدْجِيذْ، ذ نَارْجَالْ-شَارَاصَارْ، أَزدْجِيفْ ن أَيْثْ ن ثْسحَّارْثْ، ؤُ أَكْ-ذ مَارَّا إِكُومَانْذَارنْ ن ؤُجدْجِيذْ ن بَابِيلْ.  
\v 14 جِّينْ ثنْ أَذْ أَوْينْ إِرْمِييَا زِي ڒمْرَاحْ نْ ڒحْبسْ، سلّْمنْ ث ذڭْ ؤُفُوسْ ن جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ، مِّيسْ ن شَافَانْ، مَاحنْذْ أَذْ ث-إِ-د-أَوْينْ غَارْ ثَادَّارْثْ نّسْ. \add أَمُّو إِ\add* إِقِّيمْ إِزدّغْ جَارْ ڒْڭنْسْ. \f ◼ \fr 39:‏14 \ft \+bd ’جَارْ ڒْڭنْسْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ذِي ڒْوسْثْ ن ڒْڭنْسْ‘.\f*   
\b  
\m  
\s1 ڒْوَاعْذْ إِ عَابْذْ-مَالِيكْ  
\m
\v 15 يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِرْمِييَا ؤُمِي ثُوغَا إِتّْوَاحْصَارْ ذِي ڒمْرَاحْ نْ ڒحْبسْ، إِنَّا:  
\v 16 ”رُوحْ، سِيوڒْ أَكْ-ذ عَابْذْ-مَالِيكْ، أَكُوشِي، إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: خْزَارْ، نشّْ أَذْ سِّيوْضغْ أَوَاڒنْ إِنُو غَارْ ثنْذِينْثْ-أَ، إِ ڒْغَارْ وَارْ إِدْجِي إِ ڒْخَارْ، أَذْ د-فّْغنْ \add وَاوَاڒنْ إِنُو\add* \bd ذڭْ وَاسّْ نِّي\bd* زَّاثْ إِ ثِيطَّاوِينْ نّشْ.\f ◼ \fr 39:‏16 \ft \+bd ’أَكُوشِي‘\+bd* - نِيغْ ’أَرْيَازْ زِي كُوشْ‘.\f*  
\v 17 \add مَاشَا\add* أَذْ شكْ سّْنجْمغْ ذڭْ وَاسّْ نِّي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، ؤُ شكْ وَارْ ثتّْموْشِيذْ شَا ذڭْ إِفَاسّنْ ن يرْيَازنْ إِ زِي ثڭّْوذذْ.  
\v 18 مَاغَارْ نشّْ أَذْ شكْ سّْنجْمغْ. وَارْ شَّاثنْ س سِّيفْ. أَذْ ثِيڒِي ثُوذَارْثْ نّشْ ذ ثَاكشَّاضْثْ نّشْ، مَاغَارْ شكْ ثتّشْڒذْ خَافِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.‘ “   
\b  
\b  
\m  
\c 40
\s1 إِرْمِييَا أَكْ-ذ جَاذَالْيَا  
\m
\v 1 أَوَاڒْ إِ د-يُوسِينْ زِي سِيذِي غَارْ إِرْمِييَا أَوَارْنِي ڒَامِي ث-إِ-د-يِيوِي نبُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، زِي رَامَا. ؤُمِي ث-إِ-د-إِوْينْ، إِتّْوَاشَارْفْ نتَّا س سّْنَاسڒْ ذِي ڒْوسْطْ ن إِمنْفِييّنْ زِي ؤُرْشَالِيمْ ذ يَاهُوذَا، إِنِّي إِتّْوَاندّْهنْ ذ إِمنْفِييّنْ غَارْ بَابِيلْ.  
\v 2 ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ إِ د-يِيوِي إِرْمِييَا، إِنَّا أَسْ: ”سِيذِي، أَربِّي نّشْ، ثُوغَا إِتّْبَارّحْ س ڒْغَارْ-أَ خْ ومْشَانْ-أَ  
\v 3 ؤُشَا يَارَّا \add إِ-ث\add* سِيذِي أَذْ د-يَاسْ ؤُشَا نتَّا إِڭَّا س مِينْ ثُوغَا إِنَّا، مَاغَارْ كنِّيوْ ثخْضَامْ أَكْ-ذ سِيذِي ؤُ وَارْ ثسْڒِيمْ شَا غَارْ ثْمِيجَّا نّسْ. س ؤُينِّي كنِّيوْ إِڒْقفْ مَانْ أَيَا.  
\v 4 ڒخُّو \add مَاشَا\add*، خْزَارْ، أَذْ فسْيغْ أَسّْ-أَ سّْنَاسڒْ نِّي خْ إِفَاسّنْ نّشْ. مَاڒَا ذ لمْلِيحْ ذِي ثِيطَّاوِينْ نّشْ أَذْ كِيذِي د-ثَاسذْ غَارْ بَابِيلْ، \add خنِّي\add* أَسْ-د، ؤُ نشّْ أَذْ شكْ كْسِيغْ. مَاشَا مَاڒَا ذ أَعفَّانْ ذِي ثِيطَّاوِينْ نّشْ مَاحنْذْ أَذْ كِيذِي ثُويُورذْ غَارْ بَابِيلْ، أجّْ إِ-ث خنِّي. خْزَارْ، مَارَّا ثَامُّورْثْ زَّاثكْ. شكْ ثْزمَّارذْ أَذْ ثُويُورذْ غَارْ إِجّْ ن ومْشَانْ إِ ذ أَشْ إِتّْغِيڒْ ذ مْلِيحْ ذ نِيشَانْ ذِي ثِيطَّاوِينْ نّشْ!“  
\v 5 ؤُمِي ثُوغَا \add عَاذْ\add* وَارْ د-إِعْقِيبْ، \add يَارْنِي إِنَّا\add*: ”ذْوڒْ-د غَارْ جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ، مِّيسْ ن شَافَانْ، ونِّي إِڭَّا ؤُجدْجِيذْ ن بَابِيلْ خْ ثْندَّامْ ن يَاهُوذَا ؤُشَا قِّيمْ غَارسْ جَارْ ڒْڭنْسْ، نِيغْ ؤُيُورْ مَانِي ثتّْوَارِيذْ مْلِيحْ ذِي ثِيطَّاوِينْ نّشْ مَاحنْذْ أَذْ ثْرَاحذْ.“ \add خَاسْ ؤُشَا\add* إِوْشَا أَسْ ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ ڒعْوتْشْ \add إِ ؤُمُودُّو\add* ذ إِشْثْ ن ثَارْزفْثْ ؤُشَا إِجَّا إِ-ث أَذْ يُويُورْ.  
\v 6 يُويُورْ إِرْمِييَا غَارْ جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ، غَارْ مِيصْفَاثْ. إِقِّيمْ إِتّْنُوسَا غَارسْ ذِي ڒْوسْطْ ن ڒْڭنْسْ نِّي ثُوغَا إِقِّيمنْ \add عَاذْ\add* ذِي ثمُّورْثْ.   
\b  
\m  
\s1 أَنقِّي ن جَاذَالْيَا  
\m
\v 7 \add ڒَْامِي\add* مَارَّا إِكُومَانْذَارنْ ن ڒْعسْكَارَاثْ نِّي \add إِدْجَانْ\add* ذڭْ إِيَّارنْ، نِيثْنِي ذ إِرْيَازنْ نْسنْ، سْڒِينْ أَقَا أَجدْجِيذْ ن بَابِيلْ إِڭَّا جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ، خْ ثمُّورْثْ ؤُ إِڭَّا إِ-ث خْ يرْيَازنْ ذ ثمْغَارِينْ ذ إِحنْجِيرنْ، خْ إِمزْڒَاضْ قَاعْ ن ثمُّورْثْ ؤُ خْ \add مَارَّا\add* إِنِّي ثُوغَا وَارْ إِتّْوَانذْهنْ غَارْ بَابِيلْ،  
\v 8 ؤُسِينْ-د نِيثْنِي غَارْ جَاذَالْيَا ذِي مِيصْفَاثْ: إِسْمَاعِيلْ، مِّيسْ ن نَاثَانْيَا، يُوحَانَانْ ذ يُونَاثَانْ، إِحنْجِيرنْ ن قَارِيحَا، سَارَايَا، مِّيسْ ن ثَانْحُومَاثْ، \add أَرْنِي خَاسْ\add* إِحنْجِيرنْ ن عِيفَا، أَنْطُوفَاثِي، ذ يَازَانْيَا، مِّيسْ ن ؤُمَاعْكِي، \add مَارَّا\add* نِيثْنِي أَكْ-ذ يرْيَازنْ نْسنْ.  
\v 9 جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ، مِّيسْ ن شَافَانْ، إِجُّودْجْ أَسنْ ؤُ إِ يرْيَازنْ نْسنْ، إِنَّا: ”وَارْ تّڭّْوْذمْ مَاحنْذْ أَذْ ثْسخَّارمْ إِ إِكَالْذَانِييّنْ. قِّيممْ ذِي ثمُّورْثْ ؤُشَا سخَّارمْ إِ ؤُجدْجِيذْ ن بَابِيلْ، \add خنِّي\add* أَذْ ثِيڒِيمْ مْلِيحْ.  
\v 10 ؤُشَا نشّْ، خْزَارْ، نشّْ زدّْغغْ ذِي مِيصْفَاثْ مَاحنْذْ أَذْ بدّغْ \add ذ أَمنْذُوبْ ذِي طّْوعْ نْومْ\add* زَّاثْ إِ وُوذمْ ن إِكَالْذَانِييّنْ نِّي غَارْنغْ إِ د غَا يَاسنْ. إِتّْخصَّا كنِّيوْ أَذْ ثسّْمُونمْ بِينُو ذ ثِينِي ن ؤُنبْذُو ذ زّشْثْ، ؤُشَا ڭّمْ أَيَا ذڭْ إِقْذِيحنْ نْومْ ؤُشَا زذْغمْ ذِي ثْندَّامْ نِّي ثطّْفمْ.“   
\m
\v 11 ؤُڒَا ذ مَارَّا ؤُذَاينْ نِّي \add إِدْجَانْ\add* ذِي مُوآبَ ؤُ جَارْ أَيْثْ نْ عَامُّونْ ؤُ ذِي إِذُومْ ؤُ ذِي مَارَّا ثِيمُّورَا \add إِنّغْنِي\add*، سْڒِينْ أَقَا أَجدْجِيذْ ن بَابِيلْ \add إِجَّا\add* مِينْ إِقِّيمنْ \add ن إِمزْذَاغْ\add* ذِي يَاهُوذَا ؤُ إِڭَّا خَاسنْ جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ، مِّيسْ ن شَافَانْ. \f ◼ \fr 40:‏11 \ft \+bd ’إِجَّا أَذْ إِزْذغْ ذِي يَاهُوذَا‘\+bd* - س ثْعِيبْرَانِيثْ ’إِوْشَا مِينْ إِقِّيمنْ (ن إِمزْذَاغْ) ذِي يَاهُوذَا‘.\f*  
\v 12 \add س ؤُينِّي\add* د -عقْبنْ مَارَّا وُوذَاينْ زِي مَارَّا إِمُوشَانْ مَانِي خَاسنْ ؤُژّْڒنْ ؤُشَا إِوْضنْ غَارْ ثمُّورْثْ ن يَاهُوذَا غَارْ جَاذَالْيَا غَارْ مِيصْفَاثْ. نِيثْنِي سّْمُوننْ أَطَّاسْ ن بِينُو ذ ثِينِي ن ؤُنبْذُو.   
\m
\v 13 \add ؤُڒَا ذ\add* يُوحَانَانْ، مِّيسْ ن قَارِيحَا، ذ مَارَّا إِكُومَانْذَارنْ ن ڒْعسْكَارَاثْ نِّي ثُوغَا ذڭْ إِيَّارنْ ؤُسِينْ-د غَارْ جَاذَالْيَا غَارْ مِيصْفَاثْ.  
\v 14 نِيثْنِي نَّانْ أَسْ: ”مَا ثسّْنذْ شكْ، أَقَا بَاعْلِيسْ، أَجدْجِيذْ ن أَيْثْ ن عَامُّونْ، إِسّكّْ-د إِسْمَاعِيلْ، مِّيسْ ن نَاثَانْيَا، حِيمَا أَذْ شكْ إِنغْ؟“ جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ، \add مَاشَا\add* وَارْ ثنْ يُومِينْ.  
\v 15 يُوحَانَانْ، مِّيسْ ن قَارِيحَا، \add مَاشَا\add* إِسِّيوڒْ أَكْ-ذ جَاذَالْيَا س ثْنُوفّْرَا ذِي مِيصْفَاثْ، إِنَّا: ”أجّْ أَيِي أَذْ ذِينْ ڒَاحغْ ؤُ أَذْ نْغغْ إِسْمَايِيلْ، مِّيسْ ن نَاثَانْيَا. وَارْ ث إِسِّينْ ؤُڒَا ذ إِجّْ. مَايمِّي غَا إِنغْ حذْ ؤُ مَارَّا أَيْثْ ن يَاهُوذَا إِ د-خَاكْ إِمُوننْ أَذْ تّْوَاسّْزُوزَّارنْ ذ مِينْ إِقِّيمنْ زِي يَاهُوذَا أَذْ إِودَّارْ؟“  
\v 16 \add مَاشَا\add* جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ، إِنَّا إِ يُوحَانَانْ، مِّيسْ ن قَارِيحَا: ”وَارْ تّڭّْ أَيَا، مَاغَارْ مِينْ ثقَّارذْ شكْ خْ إِسْمَاعِيلْ ذ إِخَارِّيقنْ \add وَاهَا\add*.“   
\b  
\b  
\m  
\c 41
\m
\v 1 إِمْسَارْ ذڭْ ؤُيُورْ وِيسّْ سبْعَا أَقَا يُوسَا-د إِسْمَاعِيلْ، مِّيسْ ن نَاثَانْيَا، مِّيسْ ن إِلِيشَامَاعْ، ونِّي ذ إِجّْ زِي ڒْوَاشُونْ ن ؤُجدْجِيذْ، \add جْمِيعْ\add* أَكْ-ذ إِمقّْرَاننْ ن ؤُجدْجِيذْ ؤُ أَكِيذسْ \add عَاذْ\add*عشْرَا ن يرْيَازنْ، غَارْ جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ، غَارْ مِيصْفَاثْ. نِيثْنِي مُوننْ تّتّنْ ذِينْ ذِي مِيصْفَاثْ. \x ◘ \xo 41:‏1 \xt 2 إِج. 25‏:‏25\x*  
\v 2 \add خنِّي\add* إِكَّارْ إِسْمَاعِيلْ، مِّيسْ ن نَاثَانْيَا، \add جْمِيعْ أَكْ-ذ\add*عشْرَا ن يرْيَازنْ نِّي ثُوغَا غَارسْ إِدْجَانْ ؤُشَا وْثِينْ جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ، مِّيسْ ن شَافَانْ، س سِّيفْ، ؤُشَا أَمُّو إِ إِنْغَا \add إِسْمَاعِيلْ\add* ونِّي ثُوغَا إِڭَّا ؤُجدْجِيذْ ن بَابِيلْ خْ ثمُّورْثْ.  
\v 3 إِنْغَا إِسْمَاعِيلْ ؤُڒَا ذ مَارَّا ؤُذَاينْ إِ غَارسْ، إِخْسْ أَذْ يِينِي إِنِّي ثُوغَا غَارْ جَاذَالْيَا ذِي مِيصْفَاثْ، ؤُڒَا ذ إِكَالْذَانِييّنْ نِّي إِتّْوَافنْ ذِينْ، إِعسْكَارِييّنْ.   
\m
\v 4 ذڭْ وَاسّْ وِيسّْ ثْنَاينْ أَوَارْنِي ڒَامِي إِنْغَا جَاذَالْيَا، أَمْ ؤُڒَا ذ إِجّْ وَارْ يَارْڭِيبْ \add عَاذْ\add*،  
\v 5 ؤُسِينْ-د إِرْيَازنْ زِي شَاكِيمْ، شِيلُو ذ سَامَارْيَا، ثْمنْيِينْ ن يرْيَازنْ، س ثِيمِيرَا حفّنْثْ ذ ورُّوضْ إِشَارّڭْ ذ إِخبِّيشنْ. نِيثْنِي \add إِوْينْ-د\add* ذڭْ إِفَاسّنْ نْسنْ إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذ جَّاوِي مَاحنْذْ أَذْ ت أَوْينْ غَارْ ثَادَّارْثْ ن سِيذِي. \x ◘ \xo 41:‏5 \xt لَاوِي19‏:‏28؛ إِرْم. 16‏:‏6\x*  
\v 6 ؤُشَا إِفّغْ غَارْسنْ إِسْمَاعِيلْ، مِّيسْ ن نَاثَانْيَا، زِي مِيصْفَاثْ إِ ؤُمْسَاڭَارْ أَكِيذْسنْ، إِرُو أَمْ إِڭُّورْ. ؤُمِي ثنْ إِمّڒْقَا، إِنَّا: ”أَسمْ-د غَارْ جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ!“  
\v 7 ؤُمِي د-إِوْضنْ نِيثْنِي غَارْ ڒْوسْطْ ن ثنْذِينْثْ، إِغَارْصْ أَسنْ إِسْمَاعِيلْ، مِّيسْ ن نَاثَانْيَا. نتَّا ذ يرْيَازنْ إِ كِيذسْ \add إِدْجَانْ،\add* نْضَارنْ ثنْ ذِي ڒْوسْطْ ن وَانُو.  
\v 8 \add مَاشَا\add* تّْوَافنْعشْرَا ن يرْيَازنْ جَارْ أَسنْ إِنِّي إِنَّانْ إِ إِسْمَاعِيلْ: ”وَارْ ذ أَنغْ نقّْ شَا، مَاغَارْ ذڭْ إِيَّارْ نشِّينْ غَارْنغْ ڒعْوتْشْ إِخمّْڒنْ ن إِرْذنْ، إِمنْذِي، زّشْثْ ذ ثَامّنْثْ.“ \add خنِّي\add* إِحْثَا خَاسنْ، وَارْ ثنْ إِنْغِي ذِي ڒْوسْطْ ن أَيْثْمَاسْ.  
\v 9 أَنُو نِّي ذِي إِنْضَارْ إِسْمَاعِيلْ مَارَّا أَرِّيمَاثْ ن يرْيَازنْ نِّي إِنْغَا غَارْ ؤُغزْذِيسْ ن جَاذَالْيَا، ثُوغَا ذ ونِّي إِڭَّا ؤُجدْجِيذْ أَسَا زِي سِّيبّثْ ن بَاعْشَا، أَجدْجِيذْ ن إِسْرَائِيل. إِسْمَاعِيلْ، مِّيسْ ن نَاثَانْيَا، إِشُّورْ إِ-ث س يِينِّي إِتّْوَانْغنْ.   
\m
\v 10 إِنْذهْ إِسْمَاعِيلْ مَارَّا مِينْ إِقِّيمنْ \add عَاذْ\add* زِي ڒْڭنْسْ \add إِ إِدْجَانْ\add* ذِي مِيصْفَاثْ، ذ إِمحْبَاسْ، أَقَا يسِّيسْ ن ؤُجدْجِيذْ ذ مَارَّا ڒْڭنْسْ نِّي ثُوغَا إِقِّيمنْ \add عَاذْ\add* ذِي مِيصْفَاثْ، إِنِّي خْ ثُوغَا إِڭَّا نبُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ. إِسْمَاعِيلْ، مِّيسْ ن نَاثَانْيَا إِنْذهْ إِ-ثنْ ذ إِمحْبَاسْ ؤُشَا يُويُورْ حِيمَا أَذْ إِعْذُو \add خْ لْ-ؤُرْذُونْ\add* غَارْ \add ثمُّورْثْ ن\add* أَيْثْ ن عَامُّونْ.  
\v 11 \add ؤُمِي\add* يُوحَانَانْ، مِّيسْ ن قَارِيهَا، ذ مَارَّا إِكُومَانْذَارنْ ن ڒْعسْكَارَاثْ نِّي ثُوغَا غَارسْ إِدْجَانْ، سْڒِينْ س مَارَّا ڒْغَارْ إِ ثُوغَا إِڭَّا إِسْمَاعِيلْ، مِّيسْ ن نَاثَانْيَا،  
\v 12 إِوْينْ نِيثْنِي مَارَّا إِرْيَازنْ ؤُشَا طّْفنْ \add أَبْرِيذْ\add* حِيمَا أَذْ مّنْغنْ أَكْ-ذ إِسْمَاعِيلْ، مِّيسْ ن نَاثَانْيَا. نِيثْنِي ؤُفِينْ ث غَارْ ؤُيڒْمَامْ أَمقّْرَانْ غَارْ جِيبْعُونْ.  
\v 13 ڒَامِي مَارَّا ڒْڭنْسْ إِ ثُوغَا أَكْ-ذ إِسْمَاعِيلْ، إِنْطحْ يُوحَانَانْ، مِّيسْ ن قَارِيحَا، ذ مَارَّا إِكُومَانْذَارنْ ن ڒْعسْكَارْ نِّي غَارسْ، فَارْحنْ أَطَّاسْ.  
\v 14 مَارَّا ڒْڭنْسْ نِّي ثُوغَا إِنْذهْ إِسْمَاعِيلْ ذ أَمحْبُوسْ زِي مِيصْفَاثْ، قڒْبنْ، ذوْڒنْ-د ؤُشَا عْذُونْ غَارْ يُوحَانَانْ، مِّيسْ ن قَارِيحَا.  
\v 15 إِسْمَاعِيلْ \add مَاشَا\add*، مِّيسْ ن نَاثَانْيَا، يَارْوڒْ زِي زَّاثْ ن وُوذمْ ن يُوحَانَانْ أَكْ-ذ ثْمنْيَا ن يرْيَازنْ ؤُشَا يُويُورْ غَارْ أَيْثْ ن عَامُّونْ.   
\b  
\m  
\s1 ثَاروْڒَا غَارْ مِيصْرَا  
\m
\v 16 \add خنِّي\add* إِكْسِي يُوحَانَانْ، مِّيسْ ن قَارِييَاحْ، \add نتَّا جْمِيعْ\add* أَكْ-ذ مَارَّا إِكُومَانْذَارنْ ن ڒْعسْكَارَاثْ نِّي غَارسْ \add إِدْجَانْ\add*، مَارَّا مِينْ إِقِّيمنْ غَارْ ضفَّارْ ن ڒْڭنْسْ إِ يِيوِي نتَّا زِي إِسْمَاعِيلْ، مِّيسْ ن نَاثَانْيَا، زِي مِيصْفَاثْ، أَوَارْنِي ڒَامِي إِنْغَا وَانِيثَا جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ: \add أَقَا\add* إِرْيَازنْ إِجهْذنْ، إِعسْكَارِييّنْ، ثِيمْغَارِينْ، إِحنْجِيرنْ إِمژْيَاننْ ذ إِمْسخَّارنْ إِشنّْعنْ نِّي د-إِسّعْقبْ نتَّا زِي جِيبْعُونْ.  
\v 17 نِيثْنِي ؤُيُورنْ \add ذڭْ وبْرِيذْ\add* ؤُشَا قِّيمنْ ذڭْ ومْشَانْ ن أَرَّاحثْ ن كِيمْهَانْ نِّي غَارْ بَايْثْ-لَاحْمْ، مَاحنْذْ أَذْ سّنِّي عْذُونْ أَڒَامِي غَا ؤُذْفنْ نِيثْنِي غَارْ مِيصْرَا.  
\v 18 \add نِيثْنِي أَروْڒنْ\add* زِي زَّاثْ ن وُوذمْ ن إِكَالْذَانِييّنْ، مَاغَارْ ڭّْوذنْ زَّايْسنْ، مَاغَارْ إِسْمَاعِيلْ، مِّيسْ ن نَاثَانْيَا، إِنْغَا جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ، ونِّي إِڭَّا ؤُجدْجِيذْ ن بَابِيلْ \add ذ ڒْبَاشَا\add* خْ ثمُّورْثْ.   
\b  
\b  
\m  
\c 42
\m
\v 1 \add خنِّي\add* قَارّْبنْ-د مَارَّا إِكُومَانْذَارنْ ن ڒْعسْكَارْ، يُوحَانَانْ، مِّيسْ ن قَارِييَاحْ، ذ يَازَانْيَا، مِّيسْ ن هُوشَاعْيَا، ذ مَارَّا ڒْڭنْسْ، زڭْ ؤُمژْيَانْ أَڒْ أَمقّْرَانْ.  
\v 2 نِيثْنِي نَّانْ إِ ؤُنَابِي إِرْمْيَا: ”إِڒِي أَذْ يَافْ ثُوثْرَا نّغْ أَرْضَا زَّاثْ إِ وُوذمْ نّشْ. تَّارْ أَنغْ غَارْ سِيذِي، أَربِّي نّشْ، ذِي طّْوعْ ن مَارَّا مِينْ إِقِّيمنْ، مِينْزِي نشِّينْ نقِّيمْ \add عَاذْ\add* س ذْرُوسْ زڭْ وَاطَّاسْ، أَمْ مَامّشْ ثْزمَّارذْ أَذْ ثثْوَارِيذْ س ثِيطَّاوِينْ نّشْ ؤُمِي غَارْنغْ ثْخزَّارذْ.  
\v 3 إِڒِي سِيذِي، أَربِّي نّشْ، أَذْ أَنغْ إِسّْشنْ مَانْ أَبْرِيذْ إِ غَا نضْفَارْ ذ مِينْ غَا نڭّْ.“  
\v 4 إِنَّا أَسنْ ؤُنَابِي إِرْمِييَا: ”نشّْ سْڒِيغْ ث. خْزَارْ، نشّْ أَذْ تَّارغْ ذِي طّْوعْ نْومْ غَارْ سِيذِي، أَربِّي نْومْ، عْلَاحْسَابْ أَوَاڒنْ نْومْ. نشّْ أَذْ أَومْ إِنِيغْ مَارَّا أَوَاڒْ نِّي زِي د خَاومْ إِ غَا يَارّْ سِيذِي، وَارْ زَّايْومْ سّْنُوفَّارغْ ؤُڒَا ذ إِجّْ ن وَاوَاڒْ.“  
\v 5 نِيثْنِي نَّانْ إِ إِرْمِييَا: ”سِيذِي أَذْ يِيڒِي ذ شَّاهذْ ذ أَمْثِيقِّي ذ أَصْذِيقْ جَارْ أَنغْ، مَاڒَا وَارْ نتّڭّْ عْلَاحْسَابْ كُوڒْ أَوَاڒْ نِّي كِيذكْ غَارْنغْ د غَا إِسّكّْ سِيذِي، أَربِّي نّشْ!  
\v 6 ذ أَصبْحَانْ نِيغْ ذ أَعفَّانْ، أَذْ نْسڒْ غَارْ ثْمِيجَّا ن سِيذِي، أَربِّي نّغْ، إِ ؤُمِي شكْ إِ غَا نسّكّْ مَاحنْذْ أَذْ نِيڒِي مْلِيحْ خْمِي غَا نْسڒْ غَارْ ثْمِيجَّا ن سِيذِي، أَربِّي نّغْ.“ \x ◘ \xo 42:‏6 \xt إِرْم. 7‏:‏23\x*   
\m
\v 7 أَوَارْنِي ڒَامِي عْذُونْعشْرَا ن وُوسَّانْ، إِمْسَارْ أَقَا إِفّغْ وَاوَاڒْ ن سِيذِي غَارْ إِرْمِييَا.  
\v 8 \add خَاسْ ؤُشَا\add* إِڒَاغَا نتَّا خْ يُوحَانَانْ، مِّيسْ ن قَارِييَاحْ، ؤُ خْ مَارَّا إِكُومَانْذَارنْ ن ڒْعسْكَارْ نِّي ثُوغَا غَارسْ \add إِدْجَانْ\add*، ؤُڒَا خْ مَارَّا ڒْڭنْسْ، زڭْ ؤُمژْيَانْ أَڒْ أَمقّْرَانْ.  
\v 9 إِنَّا أَسنْ: ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل، غَارْ ونِّي ذ أَيِي ثسّكّمْ، حِيمَا أَذْ أَسْ سِّيوْضغْ ثُوثْرَا نْومْ زَّاثْ إِ وُوذمْ نّسْ:  
\v 10 ’مَاڒَا كنِّيوْ ثقِّيممْ ثْزدّْغمْ ذِي ثمُّورْثْ-أَ، أَمُّو كنِّيوْ إِ غَا سّْبدّغْ ؤُ وَارْ كنِّيوْ هدّْمغْ، أَذْ كنِّيوْ ژُّوغْ ؤُ وَارْ كنِّيوْ قڒْعغْ، مَاغَارْ نشّْ ندّْمغْ خْ ڒْغَارْ إِ ذَايْومْ ڭِّيغْ. \x ◘ \xo 42:‏10 \xt إِرْم. 24‏:‏6؛ 31‏:‏4؛ 33‏:‏7\x*  
\v 11 وَارْ تّڭّْوْذمْ شَا زڭْ ؤُجدْجِيذْ ن بَابِيلْ، ونِّي زِي ثتّڭّْوذمْ. وَارْ زَّايسْ تّڭّْوْذمْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. مَاغَارْ نشّْ أَكِيذْومْ حِيمَا أَذْ كنِّيوْ سّْنجْمغْ ؤُ أَذْ كنِّيوْ فكّغْ زڭْ ؤُفُوسْ نّسْ.  
\v 12 نشّْ أَذْ كنِّيوْ أَرحْمغْ مَاحنْذْ نتَّا أَذْ كنِّيوْ يَارْحمْ ؤُ أَذْ كنِّيوْ يَارّْ أَذْ ثْذوْڒمْ غَارْ ثمُّورْثْ نْومْ.   
\m
\v 13 \add مَاشَا\add* مَاڒَا كنِّيوْ ثقَّارمْ: نشِّينْ وَارْ نتّْغِيمِي شَا ذِي ثمُّورْثْ-أَ، ؤُ \add مَاڒَا كنِّيوْ\add* وَارْ ثتّسْڒِيمْ شَا غَارْ ثْمِيجَّا ن سِيذِي، أَربِّي نْومْ،  
\v 14 أَذْ ثِينِيمْ: لَّ، نخْسْ أَذْ نُويُورْ غَارْ مِيصْرَا مَانِي وَارْ نْژَارّْ أَمنْغِي ؤُ وَارْ نتّسْڒِي إِ ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي ؤُ وَارْ نتّْڒِيژِي أَغْرُومْ. أَقَا ذِينِّي إِ نخْسْ أَذْ نقِّيمْ!‘،  
\v 15 خنِّي سْڒمْ ڒخُّو غَارْ وَاوَاڒْ ن سِيذِي، كنِّيوْ مِينْ إِقِّيمنْ ن يَاهُوذَا. أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’مَاڒَا كنِّيوْ ثْعمّْذمْ أَذْ ثُويُورمْ غَارْ مِيصْرَا ؤُشَا أَذْ د-ثَاوْضمْ حِيمَا أَذْ ذِينْ ثْزذْغمْ أَمْ يِيبَارَّانِييّنْ،  
\v 16 \add خنِّي\add* سِّيفْ إِ زِي ثتّڭّْوذمْ أَذْ كنِّيوْ إِڒْقفْ ذِينِّي ذِي مِيصْرَا ؤُ ڒَاژْ إِ زِي ثتّڭّْوذمْ أَذْ كنِّيوْ د-إِضْفَارْ ذِينِّي ذِي مِيصْرَا ؤُ أَذْ ذِينِّي ثمّْثمْ.  
\v 17 خنِّي مَارَّا إِرْيَازنْ نِّي إِخْسنْ أَذْ ؤُيُورنْ غَارْ مِيصْرَا حِيمَا أَذْ ذِينْ زذْغنْ أَمْ يِيبَارَّانِييّنْ أَذْ مّْثنْ س سِّيفْ ذ ڒَاژْ ذ طَّاعُونْ. وَارْ زَّايْسنْ إِنجّمْ نِيغْ إِتَّاركّْوَاڒْ ؤُڒَا ذ إِجّنْ زِي ڒْغَارْ إِ خَاسنْ د غَاغضْڒغْ.‘  
\v 18 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’أَمْ مَامّشْ أَغْضَابْ إِنُو ذ وسْعَارْ إِنُو تّْوَازدْجْعنْ خْ إِمزْذَاغْ ن ؤُرْشَالِيمْ، أَمُّو إِ غَا إِتّْوَازدْجعْ ؤُڒَا ذ أَسْعَارْ إِنُو خَاومْ مَاڒَا ثِيوْضمْ غَارْ مِيصْرَا. كنِّيوْ أَذْ ثْذوْڒمْ ذ \add ڒْقشْعثْ ن\add* وخْزِي ذ ؤُنخْڒِيعْ ذ ثْسضْحَاشْثْ، ؤُڒَا ذ نّعْڒثْ ذ ڒْحڭْرَا. أَمْشَانْ-أَعمَّارْصْ أَذْ ت ثْژَارمْ عَاذْ.‘ \x ◘ \xo 42:‏18 \xt إِشا. 65‏:‏15؛ إِرْم. 7‏:‏20؛ 18‏:‏16؛ 19‏:‏8؛ 24‏:‏9؛ 25‏:‏9، 18؛ 26‏:‏6؛ 29‏:‏18\x*  
\v 19 سِيذِي إِسِّيوڒْ غَارْومْ، \add أَ\add* مِينْ إِقِّيمنْ ن يَاهُوذَا! وَارْ تِّيذْفمْ غَارْ مِيصْرَا. سْنمْ مْلِيحْ أَقَا نشّْعڒْمغْ أَومْ أَسّْ-أَ.  
\v 20 مَاغَارْ كنِّيوْ ثْغشّمْ خْ يِيخفْ نْومْ. كنِّيوْ سِيمَانْثْ نْومْ ثسّكّمْ أَيِي-د غَارْ سِيذِي، أَربِّي نْومْ، ثنَّامْ: ’ژَتدْجْ أَنغْ غَارْ سِيذِي، أَربِّي نّغْ. إِنِي أَنغْ مَارَّا مِينْ غَا يِيڒِي أَذْ يِينِي سِيذِي، أَربِّي نّغْ، ؤُشَا نشِّينْ أَذْ ث نڭّْ!‘  
\v 21 أَسّْ-أَ نِّيغْ أَومْ، \add مَاشَا\add* كنِّيوْ وَارْ ثسْڒِيمْ شَا غَارْ ثْمِيجَّا ن سِيذِي، أَربِّي نْومْ، غَارْ مَارَّا س مِينْ زِي إِ ذ أَيِي غَارْومْ د-إِسّكّْ.  
\v 22 \add خنِّي\add* ڒخُّو، سْنمْ مْلِيحْ أَقَا أَذْ ثمّْثمْ س سِّيفْ ذ ڒَاژْ ذ طَّاعُونْ ذڭْ ومْشَانْ مَانِي ثخْسمْ أَذْ ثُويُورمْ حِيمَا أَذْ ذِينِّي ثقِّيممْ أَمْ يِيبَارَّانِييّنْ.“   
\b  
\b  
\m  
\c 43
\m
\v 1 إِمْسَارْ ؤُمِي إِكمّڒْ إِرْمِييَا ڒْهَارْذْ نّسْ إِ مَارَّا ڒْڭنْسْ س مَارَّا أَوَاڒنْ ن سِيذِي، أَربِّي نْسنْ، س مِينْ زِي ثُوغَا سِيذِي، أَربِّي نْسنْ، إِسّكّْ إِ-ث-إِ-د غَارْسنْ،  
\v 2 أَقَا إِسِّيوڒْ عَازَارْيَا، مِّيسْ ن هُوشَاعْيَا، ؤُ نَّانْ \add عَاوذْ\add* يُوحَانَانْ، مِّيسْ ن قَارِييَاحْ، ذ مَارَّا يرْيَازنْ إِمْعفَّارنْ إِ إِرْمِييَا: ”شكْ ثسّْخَارِّيقذْ. سِيذِي، أَربِّي نّغْ، وَارْ شكْ د-إِسكّْ مَاحنْذْ أَذْ ثِينِيذْ: ’وَارْ إِعدّڒْ أَذْ ثْرَاحمْ غَارْ مِيصْرَا مَاحنْذْ أَذْ ذِينِّي ثقِّيممْ أَمْ يِيبَارَّانِييّنْ!‘  
\v 3 مَاشَا بَارُوخْ، مِّيسْ ن نِيرِي-يَاهْ، إِ شكْ إِ د-إِحَارّْشنْ خَانغْ، حِيمَا أَذْ أَنغْ ثْسلّْمذْ غَارْ إِفَاسّنْ ن إِكَالْذَانِييّنْ، مَاحنْذْ أَذْ أَنغْ نْغنْ ؤُ أَذْ أَنغْ نذْهنْ ذِي لْمنْفَا غَارْ بَابِيلْ.“   
\m
\v 4 \add أَمُّو\add* وَارْ إِسْڒِي يُوحَانَانْ، مِّيسْ ن قَارِييَاحْ، ذ مَارَّا إِكُومَانْذَارنْ ن ڒْعسْكَارْ ؤُڒَا ذ مَارَّا ڒْڭنْسْ غَارْ ثْمِيجَّا ن سِيذِي، مَاحنْذْ أَذْ قِّيمنْ ذِي ثمُّورْثْ ن يَاهُوذَا.  
\v 5 يُوحَانَانْ، مِّيسْ ن قَارِييَاحْ، ذ مَارَّا إِكُومَانْذَارنْ ن ڒْعسْكَارْ كْسِينْ مَارَّا مِينْ إِقِّيمنْ ن يَاهُوذَا، إِنِّي ثُوغَا د-إِذوْڒنْ زِي مَارَّا ڒڭْنُوسْ غَارْ مَانِي خَاسنْ ؤُژّْڒنْ، حِيمَا أَذْ قِّيمنْ ذِي ثمُّورْثْ ن يَاهُوذَا:  
\v 6 إِرْيَازنْ إِجهْذنْ ذ ثمْغَارِينْ ذ إِحنْجِيرنْ إِمژْيَاننْ ذ يسِّيسْ ن ؤُجدْجِيذْ ذ مَارَّا ڒعْمَارْ نِّي ثُوغَا إِجَّا نبُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، غَارْ جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ، مِّيسْ ن شَافَانْ، ؤُڒَا ذ أَنَابِي إِرْمِييَا ذ بَارُوخْ، مِّيسْ ن نِيرِي-يَاه.  
\v 7 نِيثْنِي ؤُسِينْ-د غَارْ ثمُّورْثْ ن مِيصْرَا، مِينْزِي نِيثْنِي وَارْ سْڒِينْ شَا غَارْ ثْمِيجَّا ن سِيذِي ؤُشَا ؤُسِينْ-د أَڒْ ثَاحْفَانِيسْ.   
\b  
\m  
\s1 إِرْمِييَا إِتّْنَابَّا ذِي ثَاحْفَانْحِيسْ  
\m
\v 8 \add خنِّي\add* يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِرْمِييَا ذِي ثَاحْفَانْحِيسْ، إِنَّا:  
\v 9 ”كْسِي إِژْرَا إِمقّْرَاننْ ذڭْ ؤُفُوسْ نّشْ ؤُشَا نُوفَّارْ إِ-ثنْ ذڭْ ؤُبدْجَاعْ ن ثِيسِي ن لُوصَا غَارْ وَاذَافْ ن ثَادَّارْثْ ن فِيرْعُونْ ذِي ثَاحْفَانِيسْ. \add أڭّْ إِ-ث\add* زَّاثْ إِ ثِيطَّاوِينْ ن يرْيَازنْ ن يَاهُوذَا،  
\v 10 إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: خْزَارْ، نشّْ أَذْ أَوْيغْ نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، أَمْسخَّارْ إِنُو، ؤُشَا أَذْ ڭّغْ ڒْعَارْشْ نّسْ خْ يژْرَا-يَا نِّي نُوفَّارغْ \add ذِينِّي\add*، ؤُشَا نتَّا أَذْ إِوّثْ أَقِيضُونْ نّسْ إِڭلّْذنْ ثِيوَا نْسنْ. \x ◘ \xo 43:‏10 \xt إِرْم. 25‏:‏9؛ 27‏:‏6\x*  
\v 11 نتَّا أَذْ د-يَاسْ ؤُشَا أَذْ إِوّثْ ثَامُّورْثْ ن مِيصْرَا: ونِّي \add إِدْجَانْ\add* إِ ڒْموْثْ، س ڒْموْثْ، ذ ونِّي \add إِدْجَانْ\add* إِ ثْمحْبَاسْثْ، إِ ؤُحبّسْ، ذ ونِّي \add إِدْجَانْ\add* إِ سِّيفْ، س سِّيفْ. \x ◘ \xo 43:‏11 \xt إِرْم. 15‏:‏2؛ زَاك. 11‏:‏9\x*  
\v 12 نتَّا أَذْ سَّارغْ إِشْثْ ن ثْمسِّي ذڭْ إِخَّامنْ ن لْ-أَصْنَامْ ن مِيصْرَا، أَذْ سّْشمْضغْ إِخَامّنْ نِّي ؤُ أَذْ أَوْيغْ لْ-أَصْنَامْ ذ إِمحْبَاسْ. نتَّا أَذْ يَارْضْ ثَامُّورْثْ ن مِيصْرَا أَمْ ؤُمكْسَاوْ يَارْضْ أَرُّوضْ نّسْ ؤُشَا نتَّا أَذْ زَّايسْ د-إِفّغْ ذِي ڒهْنَا.  
\v 13 نتَّا أَذْ يَارْژْ إِمَايْضُوثنْ نْسنْ \add إِقدّْسنْ\add*، نِّي \add إِدْجَانْ\add* ذِي ثمُّورْثْ ن مِيصْرَا، ؤُشَا أَذْ إِسّشْمضْ إِخَّامنْ ن لْ-أَصْنَامْ ن مِيصْرَا س ثْمسِّي.‘ “   
\b  
\b  
\m  
\c 44
\s1 ڒْڭنْسْ ن إِسْرَائِيل ذِي مِيصْرَا إِعبّذْ ثَاجدْجِيذْثْ ن ؤُجنَّا  
\m
\v 1 أَوَاڒْ نِّي د-إِفّْغنْ غَارْ إِرْمِييَا إِ مَارَّا ؤُذَاينْ نِّي ثُوغَا إِزدّْغنْ ذِي ثمُّورْثْ ن مِيصْرَا، إِنِّي ثُوغَا إِزدّْغنْ ذِي مَاجْذَالْ ذ ثَاحْفَانْحِيسْ ذ نُوفْ ؤُ ذِي ثمُّورْثْ ن فَاثْرُوسْ، إِ إِنَّانْ:  
\v 2 ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’كنِّيوْ سِيمَانْثْ نْومْ ثژْرِيمْ ڒْغَارْ إِ ڭِّيغْ خْ ؤُرْشَالِيمْ ؤُ خْ مَارَّا ثِيندَّامْ ن يَاهُوذَا، ؤُشَا خْزَارْ، ڒخُّو ذوْڒنْثْ نِيثنْثِي ذ ڒْخِيرْبثْ، وَارْ ذَايْسنْثْ إِزدّغْ عَاذْ ؤُڒَا ذ إِجّْ،  
\v 3 زِي سِّيبّثْ ن ڒْغَارْ إِ ڭِّينْ ؤُمِي ذ أَيِي سْعَارنْ أَڒَامِي وهّْبنْ ڒبْخُورْ مَاحنْذْ أَذْ \add زَّايسْ\add*عبْذنْ إِ إِربِّيثنْ نّغْنِي إِنِّي وَارْ سِّيننْ نِيثْنِي، ڒَا ذ كنِّيوْ ؤُڒَا ذ ڒجْذُوذْ نْومْ.  
\v 4 نشّْ سّكّغْ-د غَارْومْ مَارَّا إِمْسخَّارنْ إِنُو، إِنَابِييّنْ، عَاذْ زڭْ ؤُمزْوَارُو سّكّغْ ثنْ حِيمَا أَذْ إِنِينْ: وَارْ تّڭّمْ نّْعِي-يَا نِّي شَارّْهغْ نشّْ \add أَطَّاسْ\add*.  
\v 5 نِيثْنِي \add مَاشَا\add* وَارْ سْڒِينْ ؤُ وَارْ ذ أَيِي وْشِينْ أَمزُّوغْ نْسنْ ؤُمِي د-ذوْڒنْ نذْمنْ زِي ڒْغَارْ نْسنْ، ؤُمِي وَارْ وهّْبنْ \add عَاذْ كْثَارْ\add* ثِيوْهِيبِينْ نْسنْ ن ڒبْخُورْ إِ إِربِّيثنْ نّغْنِي.  
\v 6 \add س ؤُيَا\add* إِ فَارْغغْ أَسْعَارْ إِنُو ذ وغْضَابْ إِنُو خْ ثْندَّامْ ن يَاهُوذَا ؤُ خْ إِبْرِيذنْ ن ؤُرْشَالِيمْ، \add أَڒَامِي\add* ذوْڒنْثْ ذ ڒْخِيرْبثْ، تّْوَارذْدْجنْثْ أَمْ \add ثدْجَا\add* أَسّْ-أَ.‘ “ \x ◘ \xo 44:‏6 \xt إِرْم. 7‏:‏20؛ 42‏:‏18\x*   
\m
\v 7 ”\add خنِّي\add* ڒخُّو، أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’مَايمِّي ثتّڭّمْ ڒْغَارْ أَمْ وَانِيثَا خْ ثُوذَارْثْ نْومْ أَڒَامِي ثْقطَّامْ خْ ورْيَازْ ذ ثمْغَارْثْ، أَحنْجِيرْ ذ ؤُسيْمِي زِي ڒْوسْطْ ن يَاهُوذَا أَڒَامِي وَارْ خَاومْ إِشطّْ مِينْ إِقِّيمنْ؟  
\v 8 مَايمِّي إِ ذ أَيِي ثْسعَّارمْ س ڒْخذْمثْ ن إِفَاسّنْ نْومْ، ؤُمِي ثسّْبخَّارَامْ ڒبْخُورْ إِ إِربِّيثنْ نّغْنِي زِي ثمُّورْثْ ن مِيصْرَا مَانِي غَارْ د-ثِيوْضمْ ڒخُّو حِيمَا أَذْ ذِينِّي ثْزذْغمْ أَمْ يِيبَارَّانِييّنْ، أَڒَامِي غَا ثْقضْعمْ إِخفْ نْومْ \add أَمُّو\add* ؤُ حِيمَا أَذْ ثْذوْڒمْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* وخْزِي ذ ڒْحڭْرَا جَارْ مَارَّا ڒڭْنُوسْ ن ثمُّورْثْ؟  
\v 9 مَا ثتُّومْ كنِّيوْ قَاعْ ڒْغَارْ إِ ڭِّينْ ڒجْذُوذْ نْومْ ذ ڒْغَارْ إِ ڭِّينْ إِجدْجِيذنْ ن يَاهُوذَا ذْ ڒْغَارْ إِ ڭِّينْثْ ثمْغَارِينْ نْسنْ ؤُڒَا ذ ڒْغَارْ إِ ثڭِّيمْ كنِّيوْ سِيمَانْثْ نْومْ ذ ڒْغَارْ إِ ڭِّينْثْ ثمْغَارِينْ نْومْ ذِي ثمُّورْثْ ن يَاهُوذَا ؤُ ذڭْ إِبْرِيذنْ ن ؤُرْشَالِيمْ؟  
\v 10 أَڒْ أَسّْ-أَ إِ ذِي ندْجْ عَاذْ وَارْ تّْوَارّْژنْ \add ذڭْ وُوڒْ\add*، وَارْ زَّايِي تّڭّْوْذنْ ؤُ وَارْ ضفَّارَانْ شَّارِيعَا إِنُو ذ ثْوصَّا إِنُو نِّي كنِّيوْ وْشِيغْ زَّاثْ إِ وُوذمْ نْومْ ؤُ زَّاثْ إِ وُوذمْ ن ڒجْذُوذْ نْومْ.‘ “   
\m
\v 11 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’خْزَارْ، نشّْ أَذْ أَرّغْ ؤُذمْ إِنُو إِ ڒْغَارْ خَاومْ ؤُ حِيمَا أَذْ قْضِيغْ مَارَّا يَاهُوذَا. \x ◘ \xo 44:‏11 \xt إِرْم. 21‏:‏10؛ عَام. 9‏:‏4\x*  
\v 12 نشّْ أَذْ كّْسغْ مِينْ إِقِّيمنْ ن يَاهُوذَا، إِنِّي إِعمّْذنْ أَذْ ؤُيُورنْ غَارْ ثمُّورْثْ ن مِيصْرَا حِيمَا أَذْ ذِينِّي زذْغنْ أَمْ يِيبَارَّانِييّنْ. نِيثْنِي أَذْ تّْوَاهلّْكنْ مَارَّا، أَذْ وْضَانْ ذِي ثمُّورْثْ ن مِيصْرَا. نِيثْنِي أَذْ تّْوَاهلّْكنْ س سِّيفْ ذ ڒَاژْ، أَمْ ؤُمژْيَانْ أَمْ ؤُمقّْرَانْ. نِيثْنِي أَذْ مّْثنْ س سِّيفْ ذ ڒَاژْ ؤُشَا أَذْ ذوْڒنْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* وخْزِي ذ ؤُنخْڒِيعْ ذ نّعْڒثْ ذ ڒْحڭْرَا. \x ◘ \xo 44:‏12 \xt إِرْم. 42‏:‏15، 16، 17، 22\x*  
\v 13 نشّْ أَذْ خڒْفغْ زڭْ إِنِّي إِزدّْغنْ ذِي ثمُّورْثْ ن مِيصْرَا أَمْ مَامّشْ ثُوغَا خڒْفغْ زِي ؤُرْشَالِيمْ، س سِّيفْ، س ڒَاژْ ؤُ س طَّاعُونْ.  
\v 14 زِي مِينْ إِقِّيمنْ ن يَاهُوذَا، زڭْ إِنِّي إِوْضنْ غَارْ ثمُّورْثْ ن مِيصْرَا، حِيمَا أَذْ ذِينِّي زذْغنْ أَمْ يِيبَارَّانِييّنْ، وَارْ إِنجِّيمْ نِيغْ إِتَّاركّْوَاڒْ ؤُڒَا ذ إِجّْ، حِيمَا أَذْ د-إِعْقبْ غَارْ ثمُّورْثْ ن يَاهُوذَا مَانِي تّخْسنْ أَذْ د -عقْبنْ مَاحنْذْ أَذْ ذِينْ زذْغنْ. وَارْ د-تّعْقِيبنْ شَا، مْغِيرْ \add شَا\add* إِنِّي إِنجْمنْ.‘ “   
\m
\v 15 \add خنِّي\add* أَرِّينْ-د خْ إِرْمِييَا مَارَّا إِرْيَازنْ، إِنِّي إِسّْننْ أَقَا ثِيمْغَارِينْ نْسنْ وهّْبنْثْ ڒبْخُورْ إِ إِربِّيثنْ إِنّغْنِي، ؤُڒَا ذ مَارَّا ثِيمْغَارِينْ إِ ذِينْ إِبدّنْ، إِجّْ ن ؤُبَارُّو ذ أَمقّْرَانْ، مَارَّا ڒْڭنْسْ نِّي ثُوغَا إِزدّْغنْ ذِي ثمُّورْثْ ن مِيصْرَا، ذِي فَاثْرُوسْ، نَّانْ:  
\v 16 ”خْ وَاوَاڒْ إِ كِيذْنغْ ثسِّيوْڒذْ ذڭْ يِيسمْ ن سِيذِي، وَارْ غَاركْ نتّسْڒِي شَا.  
\v 17 مَاغَارْ كُوڒْ أَوَاڒْ إِ د-إِفّْغنْ زڭْ ؤُقمُّومْ نّغْ أَذْ ث نڭّْ ؤُمِي غَا نسّْبخَّارْ إِ ثْجدْجِيذْثْ ن ؤُجنَّا ؤُ ؤُمِي ذ أَسْ إِ غَا نْسيّبْ ثِيوْهِيبِينْ ن ؤُسيّبْ أَمْ مَامّشْ ثُوغَا نڭَّا، نشِّينْ ذ ڒجْذُوذْ نّغْ ؤُڒَا ذ إِجدْجِيذنْ نّغْ ذ ڒْحُوكَّامْ نّغْ، ذِي ثْندَّامْ ن يَاهُوذَا ؤُ ذڭْ إِبْرِيذنْ ن ؤُرْشَالِيمْ، \add ؤُمِي\add* ثُوغَا نجِّيونْ نشِّينْ س وغْرُومْ ؤُ ثُوغَا أَنغْ مْلِيحْ، ثُوغَا وَارْ ذِينْ ثَارْجِيجَاثْ زِي حذْ. \x ◘ \xo 44:‏17 \xt إِرْم. 7‏:‏18\x*  
\v 18 زڭْ وَامِي مَاشَا نسّْبدّْ نتّْوهّبْ ڒبْخُورْ إِ ثْجدْجِيذْثْ ن ؤُجنَّا ؤُ زڭْ ؤُسيّبْ ن ثوْهِيبِينْ إِ نتَّاثْ، أَقَا نحْوَاجْ ؤُ نفْنَا نشِّينْ س سِّيفْ ذ ڒَاژْ.  
\v 19 مَاڒَا نشِّينْ نسّْبخَّارْ إِ ثْجدْجِيذْثْ ن ؤُجنَّا، نْسيّبْ أَسْ ثِيوْهِيبِينْ ن ؤُسيّبْ، مَا نْهْڒَا \add أَرْڭَابْ ذ ڒْخَاضَارْ ن\add* يرْيَازنْ نّغْ نڭَّا أَسْ ثِيفْضِيرِينْ إِ صّذْقثْ نِّي ذَايسْ يَارْوسنْ ؤُ نْسيّبْ أَسْ ثِيوْهِيبِينْ ن ؤُسيّبْ؟“   
\m
\v 20 \add خنِّي\add* إِسِّيوڒْ إِرْمِييَا غَارْ مَارَّا ڒْڭنْسْ، غَارْ إِرْيَازنْ ذ ثمْغَارِينْ، غَارْ مَارَّا ڒْڭنْسْ نِّي ثُوغَا إِ د خَاسْ يَارِّينْ \add أَمُّو\add*، إِنَّا:  
\v 21 ”ثِيوْهِيبِينْ ن ڒبْخُورْ نِّي ثسّْبخَّارمْ ذِي ثْندَّامْ ن يَاهُوذَا ؤُ خْ إِبْرِيذنْ ن ؤُرْشَالِيمْ، كنِّيوْ ذ ڒجْذُوذْ نْومْ، إِجدْجِيذنْ نْومْ ذ ڒْحُوكَّامْ نْومْ ذ ڒْڭنْسْ ن ثمُّورْثْ، مَا وَارْ ثنْثْ إِذَارْ سِيذِي نِيغْ وَارْ د-ؤُسِينْثْ غَارْ ڒْبَاڒْ نّسْ؟  
\v 22 سِيذِي وَارْ إِقِّيمْ \add عَاذْ\add* إِصبَّارْ أَومْ خْ ثْمڭَّا نْومْ ثِيعفَّانِينْ، خْ جّْعَايفْ إِ ثڭِّيمْ. س ؤُينِّي ثذْوڒْ ثمُّورْثْ نْومْ ذ ڒْخَارْبثْ ذ إِشْثْ ن ثمُّورْثْ إِخْڒَانْ ؤُڒَا ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ ذ نّعْڒثْ أَڒَامِي وَارْ ذِينْ إِزدّغْ \add عَاذْ\add* ؤُڒَا ذ إِجّْ، أَمْ \add ثدْجَا\add* أَسّْ-أَ.  
\v 23 مِينْزِي كنِّيوْ ثِيوْيمْ-د ڒبْخُورْ ؤُ ثخْضَامْ أَكْ-ذ سِيذِي ؤُ وَارْ ثسْڒِيمْ شَا غَارْ ثْمِيجَّا ن سِيذِي ؤُ وَارْ ثُويُورمْ ذِي شَّارِيعَا نّسْ، ذِي ثْوصَّا نّسْ ؤُ ذِي شّْهَاذَاثْ نّسْ، خْ ؤُيَا إِ كنِّيوْ إِڒْقفْ ڒْغَارْ-أَ، أَمْ \add ثدْجَا\add* أَسّْ-أَ.“   
\m
\v 24 \add خنِّي\add* إِنَّا إِرْمِييَا إِ مَارَّا ڒْڭنْسْ ؤُ إِ مَارَّا ثِيمْغَارِينْ: ”سْڒمْ إِ وَاوَاڒْ ن سِيذِي، مَارَّا يَاهُوذَا نِّي إِدْجَانْ ذِي ثمُّورْثْ ن مِيصْرَا.  
\v 25 أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل، إِقَّارْ: ’خْ كنِّيوْ ؤُ خْ ثمْغَارِينْ نْومْ، أَقَا ثنَّامْ \add ث\add* س ؤُقمُّومْ نْومْ ؤُ س إِفَاسّنْ نْومْ ثڭِّيمْ \add ث\add*، ثنَّامْ: أَموْشِي ن وَاوَاڒْ إِ نڭَّا، أَذْ ث نْكمّڒْ نِيشَانْ حِيمَا أَذْ نْقدّمْ ثِيوْهِيبِينْ ن ڒبْخُورْ إِ ثْجدْجِيذْثْ ن ؤُجنَّا ؤُ حِيمَا أَذْ نْسيّبْ ثِيوْهِيبِينْ ن ؤُسيّبْ. \add خنِّي\add* كمّْڒمْ نِيشَانْ لْوُوعُوذْ إِ ثْوَاعْذمْ ؤُ ڭّمْ س ثِيذتّْ مِينْ ثُوغَا ثْوَاعْذمْ.‘ “   
\m
\v 26 ”س ؤُيَا سْڒمْ إِ وَاوَاڒْ ن سِيذِي، مَارَّا يَاهُوذَا إِ إِزدّْغنْ ذِي مِيصْرَا: ’خْزَارْ، نشّْ جُّودْجغْ س يِيسمْ إِنُو أَمقّْرَانْ، إِقَّارْ سِيذِي، وَارْ إِتّْوَاڒَاغَا س يِيسمْ إِنُو \add عَاذْ\add* زِي شَا ن ورْيَازْ مَامّشْ مَا إِڭَّا زِي يَاهُوذَا ذِي مَارَّا ثَامُّورْثْ ن مِيصْرَا، أَذْ يِينِي: س ثِيذتّْ أَمْ إِدَّارْ سِيذِي إِنُو، سِيذِي!  
\v 27 خْزَارْ، نشّْ أَذْ خَاسنْعسّغْ إِ ڒْغَارْ، وَارْ إِدْجِي إِ ڒْخَارْ. مَارَّا إِرْيَازنْ ن يَاهُوذَا نِّي إِدْجَانْ ذِي ثمُّورْثْ ن مِيصْرَا، أَذْ هلّْكنْ س سِّيفْ ذ ڒَاژْ أَڒْ غَا تّْوَاكّْسنْ. \x ◘ \xo 44:‏27 \xt إِرْم. 31‏:‏28\x*  
\v 28 \add مَاشَا\add* إِنِّي يَاروْڒنْ زِي سِّيفْ، أَذْ د-ذوْڒنْ زِي ثمُّورْثْ ن مِيصْرَا غَارْ ثمُّورْثْ ن يَاهُوذَا، \add مْغِيرْ\add* إِجّْ ن وُورُو ن يرْيَازنْ. مَارَّا مِينْ إِقِّيمنْ ن يَاهُوذَا إِ د-إِوْضنْ غَارْ ثمُّورْثْ ن مِيصْرَا حِيمَا أَذْ ذِينْ زذْغنْ أَمْ يِيبَارَّانِييّنْ، أَذْ سّْننْ أَوَاڒْ ن مَانْ ونْ إِ غَا إِقِّيمْ إِبدّْ، ونِّي إِنُو نِيغْ ونِّي نْسنْ.  
\v 29 مَانْ أَيَا أَذْ أَومْ ثِيڒِي ذ ڒعْڒَامثْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَقَا نشّْ أَذْ كنِّيوْ عَاقْبغْ ذڭْ ومْشَانْ-أَ حِيمَا أَذْ ثسّْنمْ أَقَا أَوَاڒنْ إِنُو خَاومْ أَذْ خَاومْ إِڒِينْ إِ ڒْغَارْ.  
\v 30 \add مَانْ أَيَا أَذْ يِيڒِي ذ ڒعْڒَامثْ\add*، أَمُّو إِ إِقَّارْ سِيذِي: خْزَارْ، نشّْ أَذْ سِّيوْضغْ فِيرْعُونْ حُوفْرَاعْ، أَجدْجِيذْ ن مِيصْرَا، غَارْ ؤُفُوسْ ن ڒْعذْيَانْ نّسْ ؤُ غَارْ ؤُفُوسْ ن يِينِّي يَارزُّونْ ثُوذَارْثْ نّسْ، أَمْ مَامّشْ سِّيوْضغْ صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، غَارْ ؤُفُوسْ ن نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ڒعْذُو نّسْ ونِّي ثُوغَا يَارزُّونْ ثُوذَارْثْ نّسْ.‘ “   
\b  
\b  
\m  
\c 45
\s1 أَوَاڒْ ن إِرْمِييَا إِ بَارُوخْ  
\m
\v 1 أَوَاڒْ نِّي إِسَّاوَاڒْ ؤُنَابِي إِرْمِييَا إِ بَارُوخْ، مِّيسْ ن نِيرِي-يَاهْ، ؤُمِي يُورَا وَانِيثَا أَوَاڒنْ زڭْ ؤُقمُّومْ ن إِرْمِييَا ذڭْ إِجّْ ن وذْلِيسْ إِتّْوَانّْضنْ، ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعَا ن يَاهُويَاقِيمْ، مِّيسْ ن يُوشِييَا، أَجدْجِيذْ ن يَاهُوذَا. إِنَّا:  
\v 2 ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل، خَاكْ، \add أَ\add* بَارُوخْ!  
\v 3 شكْ ثنِّيذْ: ’أَخيّبْ إِ نشّْ، مَاغَارْ سِيذِي يَارنِّي عَاذْ أَشْضَانْ خْ ڒحْرِيقْ إِنُو. نشّْ ؤُحْڒغْ س وزْهَارْ، وَارْ ؤُفِيغْ أَرَّاحثْ!‘  
\v 4 إِتّْخصَّا أَذْ أَسْ ثِينِيذْ: ’أَمُّو إِ إِقَّارْ سِيذِي: خْزَارْ، مِينْ سّْبدّغْ، أَذْ ثغضْڒغْ، ؤُ مِينْ ژُّوغْ، أَذْ ث قڒْعغْ، \add وَاهْ،\add* مَارَّا ثَامُّورْثْ-أَ.  
\v 5 مَا ثخْسذْ شكْ أَذْ ثَارْزُوذْ خْ ثْمسْڒَايِينْ ثِيمقّْرَانِينْ إِ يِيخفْ نّشْ؟ وَارْ ثنْثْ ثَارزُّوذْ شَا، مَاغَارْ خْزَارْ، نشّْ أَذْ سِّيوْضغْ إِجّْ نْ ڒْغَارْ خْ مَارَّا دَّاثْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، \add مَاشَا\add* أَذْ أَشْ وْشغْ ڒعْمَارْ نّشْ ذ ثَاكشَّاضْثْ ذِي مَارَّا إِمُوشَانْ مَانِي غَا ثْرَاحذْ.‘ “ \x ◘ \xo 45:‏5 \xt إِرْم. 21‏:‏9؛ 38‏:‏2؛ 39‏:‏18\x*   
\b  
\b  
\m  
\c 46
\s1 أَوَاڒنْ خْ ڒڭْنُوسْ  
\m
\v 1 أَوَاڒْ ن سِيذِي نِّي د-يُوسِينْ غَارْ ؤُنَابِي إِرْمِييَا خْ ڒڭْنُوسْ.   
\b  
\m
\v 2 \bd خْ مِيصْرَا\bd*  
\m ضِيدّْ ن ڒْعسْكَارْ ن فِيرْعُونْ نَاخُو، أَجدْجِيذْ ن مِيصْرَا، ونِّي ذِينْ غَارْ يغْزَارْ ن لْفُورَاطْ، غَارْ كَارْكَامِيشْ، ونِّي يَارْنَا نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعَا ن يَاهُويَاقِيمْ، مِّيسْ ن يُوشِييَا، أَجدْجِيذْ ن يَاهُوذَا.   
\m
\v 3 ”سْوجْذمْ ثَاسدَّارْثْ \add ن ؤُعسْكَارِي\add* ذ ثْسدَّارْثْ \add نّسْ\add* ثَامقّْرَانْثْ ؤُشَا سْڭعّْذمْ غَارْ ؤُمنْغِي!  
\v 4 حزّْمنْ إِ إِيْسَانْ، نْيمْ خَاسمْ، \add أَ\add* إِمْنَاينْ ن ييْسَانْ! سْبدّمْ إِخفْ نْومْ س لْكَاسْكَاثْ \add خْ إِزدْجِيفنْ نْومْ\add*. سْقضْعمْ فْڒِيثْشَاثْ ؤُشَا حزّْممْ س وَارُّوضْ ن وُوزَّاڒْ! \x ◘ \xo 46:‏4 \xt إِرْم. 51‏:‏11\x*  
\v 5 مَايمِّي تّْوَاڒِيغْ نشّْ أَقَا نِيثْنِي نّْخڒْعنْ أَڒَامِي ذوْڒنْ غَارْ ضفَّارْ؟ عَاذْ أَيْثْ ن بُو-ثغْرُوضْثْ نْسنْ تّْوَارْژنْ، منْعنْ ذِي ثَاروْڒَا ؤُشَا وَارْ إِ-د-نّْقڒْبنْ غَارْ ضفَّارْ. أَقَا ذِينْ أَسْنخْڒِيعْ ذِي مَارَّا إِغزْذِيسنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 6 أجّْ ونِّي إِفْسُوسنْ س إِضَارنْ وَارْ إِتَّاركّْوَاڒْ ؤُڒَا ذ بُو-ثغْرُوضْثْ وَارْ إِنجّمْ: نّْقَارْضنْ، وْضَانْ ذِي شَّامَالْ، غَارْ ثْمَا ن إِغْزَارْ ن لْفُورَاطْ.“   
\m
\v 7 ”مَانْ ونْ إِ ذِينْ د-إِڭعّْذنْ أَمْ وَامَانْ \add ن مِيصْرَا\add*، أَمَانْ نّسْ زهَّارنْ أَمْ يِيغزْرَانْ؟  
\v 8 مِيصْرَا ثْڭعّذْ-د أَمْ وَامَانْ، أَمَانْ نّسْ زهَّارنْ أَمْ يِيغزْرَانْ، ثقَّارْ: ’نشّْ أَذْ ڭعّْذغْ، أَذْ ذْڒغْ ثَامُّورْثْ، أَذْ قْضِيغْ خْ ثنْذِينْثْ ذ يِينِّي ذَايسْ إِزدّْغنْ.  
\v 9 ڭعّْذمْ، \add أَ\add* إِيْسَانْ، مُوزَّارمْ، \add كنِّيوْ، أَ\add* إِكَارُّوثنْ ن ؤُمنْغِي! جّمْ أَيْثْ ن بُو-ثغْرُوضْثْ أَذْ فّْغنْ: أَيْثْ ن كُوشْ، أَيْثْ ن فُوطْ إِنِّي يَاربُّونْ ثَاسدَّارْثْ \add ن ؤُعسْكَارِي\add* ذ أَيْثْ ن لُوذْ إِنِّي إِتّطّْفنْ ڒْقوْسْ ؤُشَا محّْضنْ ث. \x ◘ \xo 46:‏9 \xt إِشا. 66‏:‏19\x*  
\v 10 أَسّْ-أَ ذ إِجّْ ن وَاسّْ إِ سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ، إِجّْ ن وَاسّْ ن وخْڒَافْ مَاحنْذْ أَذْ إِخْڒفْ إِ يِيخفْ نّسْ زڭْ إِغْرِيمنْ نّسْ. أَذْ يشّْ سِّيفْ، أَذْ إِجَّاونْ ؤُشَا أَذْ إِسْشَارْ س إِذَامّنْ نْسنْ، مَاغَارْ أَقَا ذِينْ إِشْثْ ن ثْغَارْصْثْ إِ سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ، ذِي ثمُّورْثْ ن شَّامَالْ غَارْ يغْزَارْ ن لْفُورَاطْ.  
\v 11 ڭعّْذمْ غَارْ جِيلْعَاذْ، أَوْيمْ-ذ بَالْسَامْ، \add أَ شمْ\add* ثَاعْزَارشْثْ، إِدْجِيسْ ن مِيصْرَا!. بَاطڒْ ثَارنِّيذْ ذِي دّْوَاوَاثْ أَطَّاسْ، \add مَاغَارْ\add* وَارْ غَارمْ بُو دَّاوَاثْ حِيمَا أَذْ ثنْثْ ثڭّذْ \add خْ ؤُيزِّيمْ\add*.\x ◘ \xo 46:‏11 \xt إِرْم. 8‏:‏22\x*  
\v 12 سْڒِينْ ڒڭْنُوسْ خْ ڒفْضِيحثْ نّمْ ؤُشَا ثشُّورْ ثمُّورْثْ زڭْ إِغُويَّانْ \add ن ڒحْڒِيقْ\add* نّمْ، مَاغَارْ بُو-ثغْرُوضْثْ إِمْقَارْقبْ أَكْ-ذ بُو-ثغْرُوضْطْ نّغْنِي، مُوننْ وْضَانْ س ثْنَاينْ.“   
\b  
\m
\v 13 أَوَاڒْ نِّي إِسِّيوڒْ سِيذِي غَارْ ؤُنَابِي إِرْمِييَا خْ ثْوَاسِيثْ ن نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، حِيمَا أَذْ إِوّثْ ثَامُّورْثْ ن مِيصْرَا.   
\m
\v 14 ”بَارّْحمْ \add ث\add* ذِي مِيصْرَا ؤُ جّمْ أَذْ أَسْ سْڒنْ ذِي مَاجْذَالْ، جّمْ أَذْ أَسْ سْڒنْ ذِي نُوفْ ذ ثَاحْفَانْحِيسْ. إِنِيمْ: ’بدّْ أَبذِّي، وْجذْ!‘، مَاغَارْ سِّيفْ إِشَّا \add مَارَّا\add* إِغزْذِيسنْ إِ ذ أَشْ د-إِنّْضنْ.  
\v 15 مَايمِّي تّْوَامْحَانْ أَيْثْ ن بُو-صُّولْطَا نّشْ؟ وَارْ إِزمَّارْ نتَّا أَذْ إِقِّيمْ إِبدّْ، مِينْزِي سِيذِي إِعَارّنْ إِ-ث.  
\v 16 نتَّا يَارَّا أَطَّاسْ أَذْ نْقَارْضنْ، \add وَاهْ،\add* أَرْيَازْ إِوْضَا خْ ونّغْنِي، ؤُشَا نِيثْنِي نَّانْ: ’كَّارمْ، جّمْ أَنغْ أَذْ نذْوڒْ غَارْ ڒْڭنْسْ نّغْ ؤُ غَارْ ثمُّورْثْ مَانِي نخْڒقْ زِي سِّيبّثْ ن سِّيفْ إِوْعَارنْ.‘  
\v 17 ذِينْ إِ ڒَاغَانْ نِيثْنِي: ’أَقَا فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا، إِتّْوَاردّدْجْ، أَقَا إِجَّا ڒْوقْثْ إِتّْوَاڭّنْ أَذْ ثعْذُو.‘ “   
\m
\v 18 ”س ثِيذتّْ أَمْ دَّارغْ نشّْ، \add أَمُّو إِ\add* إِقَّارْ ؤُجدْجِيذْ، سِيذِي ن ڒْعسْكَارَاثْ ذ إِسمْ نّسْ: ’نتَّا أَذْ د-يَاسْ، أَمْ \add وذْرَارْ ن\add* ثابُورْ جَارْ إِذُورَارْ ؤُ أَمْ \add وذْرَارْ ن\add* كَارْمِيلْ غَارْ ڒبْحَارْ!  
\v 19 سْمُونْ ڒحْوَايجْ نّمْ إِ لْمنْفَا، \add أَ شمْ\add* ثَامزْذُوغْثْ، إِدْجِيسْ ن مِيصْرَا، مَاغَارْ \add ثَامُّورْثْ ن\add* نُوفْ أَذْ ثذْوڒْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ ؤُشَا أَذْ ثتّْوَاردّدْجْ، أَڒَامِي وَارْ ذِينْ إِقِّيمْ ؤُڒَا ذ إِجّْ إِزدّغْ.   
\m
\v 20 \add ثَامُّورْثْ ن\add* مِيصْرَا ذ إِشْثْ ن ثَاعجْمِيثْ ثشْنَا، \add مَاشَا\add* أَذْ غَارسْ د-يَاسْ إِجّْ ن يَارزِّي ذ أَذَارْغَاڒْ، أَذْ د-يَاسْ زِي شَّامَالْ.  
\v 21 ؤُڒَا ذ إِشوَّاڒنْ نّسْ ذِي ڒْوسْطْ نّسْ ڭِّينْ أَمْ يِيعجْمِييّنْ إِصحّنْ، \add مَاشَا\add* ؤُڒَا ذ نِيثْنِيعقْبنْ-د، نِيثْنِي أَروْڒنْ جْمِيعْ، وَارْ قِّيمنْ بدّنْ، مَاغَارْ أَسّْ ن ؤُضيّعْ نْسنْ أَذْ خَاسنْ د-يَاسْ، ثَاسَاعّثْ ن وخْڒَافْ نْسنْ.  
\v 22 ثْمِيجَّا نّسْ ثڭَّا أَمْ ڒْحسّْ ن ؤُفِيغَارْ إِحْرَارَّانْ، مَاغَارْ أَذْ ذِينْ ؤُيُورنْ أَكْ-ذ إِجّْ ن ڒْعسْكَارْ ؤُ أَذْ غَارسْ د-أَسنْ س شّْوَاقَارْ أَمْ يِينزْذَامنْ ن ؤُكشُّوضْ. \f ◼ \fr 46:‏22 \ft \+bd ’ثْمِيجَّا نّسْ‘\+bd* - إِخْسْ أَذْ يِينِي ’ثْمِيجَّا ن مِيصْرَا‘. نَاپُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، أَذْ إِهْجمْ خْ ثمُّورْثْ ن مِيسْڒَا س ڒْعسْكَارْ نّسْ أَمشْنَاوْ هجْمنْ س شّْوَاقرْ خْ إِجّْ ن ؤُفِيغَارْ ذڭْ إِيَّارْ.\f*  
\v 23 نِيثْنِي أَذْ قسّنْ أَزْغَارْ نّسْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، مَاغَارْ \add ڒْْعسْكَارْ\add* وَارْ إِزمَّارْ أَذْ إِتّْوَاحْسبْ، مِينْزِي نِيثْنِي أَقَا أَثنْ ذڭْ وَاطَّاسْ خْ إِبُورخْسنْ، وَارْ زمَّارنْ أَذْ تّْوَاحسْبنْ. \f ◼ \fr 46:‏23 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  
\v 24 ثْسضْحَا يدْجِيسْ ن مِيصْرَا، أَقَا ثتّْوَاڭّْ ذڭْ ؤُفُوسْ ن إِجّْ ن ڒْڭنْسْ زِي شَّامَالْ.‘ “   
\m
\v 25 ”سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل، إِنَّا: ’خْزَارْ، نشّْ أَذْ عَاقْبغْ أَمُونْ زِي \add ثمُّورْثْ ن\add* نُو، ذ فِيرْعُونْ ذ مِيصْرَا، إِربِّيثنْ نّسْ ذ إِجدْجِيذنْ نّسْ، \add وَاهْ،\add* فِيرْعُونْ ذ يِينِّي خَاسْ إِتّْشَاڒنْ.  
\v 26 نشّْ أَذْ ثنْ وْشغْ ذڭْ ؤُفُوسْ ن يِينِّي يَارزُّونْ ثُوذَارْثْ نْسنْ ڒَا ذڭْ ؤُفُوسْ ن نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ؤُڒَا ذڭْ ؤُفُوسْ ن إِمْسخَّارنْ نّسْ. \add أَوَارْنِي إِ ؤُيَا\add* أَذْ ثذْوڒْ ثمُّورْثْ س إِمزْذَاغْ عَاوذْ أَمْ ذڭْ وُوسَّانْ ن زِيشْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.‘ “   
\m
\v 27 ”وَارْ ثڭّْوذْ، \add أَ\add* شكْ أَمْسخَّارْ إِنُو يَاعْقُوبْ، وَارْ ثفْشِيڒْ شَا، \add أَ\add* إِسْرَائِيل، مَاغَارْ خْزَارْ، نشّْ أَذْ شكْ سّْنجْمغْ زِي ثِيمُّورَا إِڭّْوجنْ ؤُڒَا ذ زَّارِيعثْ نّشْ زِي ثْمحْبَاسْثْ نْسنْ. أَذْ يَارڭّْوحْ يَاعْقُوبْ، أَذْ غَارسْ ثِيڒِي ڒْهُوذْنثْ، أَذْ إِدَّارْ ذِي ڒَامَانْ ؤُشَا ؤُڒَا ذ إِجّْ وَارْ ث إِسّْنخْڒِيعْ. \x ◘ \xo 46:‏27 \xt إِشا. 41‏:‏13؛ 43‏:‏5؛ 44‏:‏1؛ إِرْم. 30‏:‏10\x*  
\v 28 وَارْ تّڭّْوذْ، \add أَ\add* شكْ أَمْسخَّارْ إِنُو يَاعْقُوبْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، مَاغَارْ نشّْ أَكِيذكْ، مِينْزِي نشّْ أَذْ قْضِيغْ خْ مَارَّا ڒڭْنُوسْ نِّي مَانِي كنِّيوْ سِّيڭّْوجغْ، \add مَاشَا\add*عمَّارْصْ وَارْ خَاكْ قطِّيغْ، \add مَاشَا\add* أَذْ شكْ وبّْخغْ س ڒعْبَارْ إِسڭّْذنْ ؤُ وَارْ شكْ هضّْبغْ ذ أَمزْذَاڭْ.‘ “ \x ◘ \xo 46:‏28 \xt إِرْم. 10‏:‏24؛ 30‏:‏11\x*   
\b  
\b  
\m  
\c 47
\s1 خْ إِفِيلِيسْطِينِييّنْ  
\m
\v 1 أَوَاڒْ ن سِيذِي نِّي د-يُوسِينْ غَارْ ؤُنَابِي إِرْمِييَا، \add أَوَاڒْ إِ إِوجّْهنْ\add* \bd ضِيدّْ إِ إِفِيلِيسْطِينِييّنْ\bd* قْبڒْ مَا إِوْثَا فِيرْعُونْ غَازَّا.   
\m
\v 2 ”أَمُّو إِ إِقَّارْ سِيذِي: ’خْزَارْ، أَمَانْ ڭعّْذنْ زِي شَّامَالْ، أَذْ ذوْڒنْ ذ إِشْثْ ن ثغْزَارْثْ ثسّْفَايْ. أَذْ حمْڒنْ خْ ثمُّورْثْ ؤُ خْ مَارَّا مِينْ ذَايسْ إِدْجَانْ، ثَانْذِينْثْ ذ إِمزْذَاغْ نّسْ. أَذْ سْغُوينْ إِوْذَانْ ؤُ مَارَّا إِمزْذَاغْ ن ثمُّورْثْ أَذْ شضْننْ أَطَّاسْ  
\v 3 زِي سِّيبّثْ ن وزْبَارْ ن ثشْثِي ن ثْشضْيِينْ ن \add ييْسَانْ\add* إِجهْذنْ، زِي سِّيبّثْ ن دّْرِيزْ ن إِكَارُّوثنْ \add ن ؤُمنْغِي\add* ذ ؤُقَارْقبْ ن ثْجَارَّارِينْ. \add عَاذْ\add* إِبَابَاثنْ وَارْ حكَّارنْ شَا إِ إِحنْجِيرنْ \add نْسنْ\add* مَاغَارْ إِفَاسّنْ نْسنْ ذوْڒنْ أَرهْفنْ \x ◘ \xo 47:‏3 \xt إِشا. 5‏:‏28؛ إِرْم. 4‏:‏13؛ 6‏:‏23\x*  
\v 4 زِي سِّيبّثْ ن وَاسّْ إِ د غَا يَاسنْ حِيمَا أَذْ تّْوَاثحَّانْ مَارَّا أَيْثْ ن إِفِيلِيسْطِينِييّنْ، حِيمَا أَذْ إِتّْوَاكّسْ زِي صُورْ ذ صِيذُونْ كُوڒْ بُو-ثْوِيزَا إِ يَاروْڒنْ، مَاغَارْ سِيذِي أَذْ إِثحَّا إِفِيلِيسْطِينِييّنْ، مِينْ إِقِّيمنْ ن ثڭْزِيرْثْ ن كَافْثُورْ. \x ◘ \xo 47:‏4 \xt إِرْم. 25‏:‏22\x*  
\v 5 ثُوسَا-د ثْقشَّارْثْ خْ غَازَّا، ثسّغْذْ \add ثمُّورْثْ ن\add* أَشْقَالُونْ \add جْمِيعْ\add* أَكْ-ذ مِينْ إِقِّيمنْ ن ڒوْضَا ن ثغْزُورْثْ نْسنْ. أَڒْ مڒْمِي غَا ثقِّيمذْ عَاذْ ثْخبّْشذْ إِخفْ نّمْ؟ \x ◘ \xo 47:‏5 \xt أَعَوذ. 14‏:‏1؛ إِرْم. 16‏:‏6؛ 25‏:‏20\x*  
\v 6 ؤُشْثْ \add خَاكْ، أَ\add* سِّيفْ ن سِيذِي، أَڒْ مڒْمِي إِ غَا ثقِّيمذْ عَاذْ نهْڒَا أَرَّاحثْ؟ ذْوڒْ-د غَارْ فُورُّو ن وغْڒَافْ نّشْ، قِّيمْ وَارْ ثنْهزَّا!  
\v 7 مَامّشْ إِ غَا ثقِّيمذْ ثَارْسِيذْ؟ أَقَا سِيذِي يُومُورْ سِّيفْ ضِيدّْ إِ أَشْقَالُونْ ؤُ ضِيدّْ إِ ثْمَا ن ڒبْحَارْ، إِ مَانَاينِّي إِ إِتّْوَاڭّْ.‘ “   
\b  
\b  
\m  
\c 48
\m
\v 1 \bd خْ مُوآبَ\bd*  
\m ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’ؤُشْثْ خْ نابُو، مَاغَارْ أَقَا \add ثَانْذِينْثْ\add* ثتّْوَاخَارّبْ، \add ثَانْذِينْثْ ن\add* قَارْيَاثَايِيمْ ثطّفْ إِ-ت ڒحْيَا، أَقَا ثتّْوَاطّفْ. لْبُورْجْ يُوعْڒَانْ ثطّفْ إِ-ت ڒهْيَا ؤُ ثتّنْهزَّا. \x ◘ \xo 48:‏1 \xt إِرْم. 25‏:‏21؛ 27‏:‏3\x*  
\v 2 ڒْعزّْ ن \add ثمُّورْثْ ن\add* مُوآبَ وَارْ إِدْجِي \add عَاذْ\add*. ذِي حَاشْبُونْ خَارّْصنْ ذِي ڒْغَارْ ضِيدّْ نّسْ، نَّانْ: أجّْ أَنغْ أَذْ ت نكّسْ زِي جَارْ ڒڭْنُوسْ. ؤُڒَا ذ شكْ، مَاذْمِينْ، أَذْ شكْ سّْبكْمنْ، سِّيفْ ڭُّورْ أَذْ شكْ إِضْفَارْ.  
\v 3 \add ثفّغْ\add* إِشْثْ ن ثْغُويِّيثْ \add ن ڒحْرِيقْ\add* زِي حُورُونَايِيمْ: أَخَارّبْ ذ لْمُوصِيبَا ذ ثَامقّْرَانْثْ!  
\v 4 \add ثَامُّورْثْ ن\add* مُوآبَ ثتّْوَارْژْ، إِحنْجِيرنْ نّسْ إِمژْيَاننْ ڭِّينْ أَذْ ثتّْوَاسڒْ ثْغُويِّيثْ ثجْهذْ.  
\v 5 وَاهْ، أَمْ إِتّْرُو إِتّْڭعَّاذْ نتَّا ثْسَاونْثْ ن لُوحِيثْ، مَاغَارْ غَارْ ؤُهكّْوُو غَارْ حُورُونَايِيمْ سْڒِينْ أَذُوقّزْ ن إِغُويَّانْ ن ثْخسَّارْثْ. \x ◘ \xo 48:‏5 \xt إِشا. 15‏:‏5\x*  
\v 6 أَروْڒمْ، سْنجْممْ ثُوذَارْثْ نْومْ، ذوْڒمْ أَمْ يِيجّْ ن ؤُخشَّابْ ذِي ثْنزْرُوفْثْ. \x ◘ \xo 48:‏6 \xt إِرْم. 17‏:‏6\x*  
\v 7 مِينْزِي شمْ ثتّشْڒذْ خْ ثْمڭَّا نّمْ ذ ڒكْنُوزْ نّمْ، ؤُڒَا ذ شمْ أَذْ ثتّْوَاطّْفذْ. كَامُوشْ أَذْ يُويُورْ ذِي لْمنْفَا، إِكهَّاننْ نّسْ \add جْمِيعْ\add* أَكْ-ذ ڒْحُوكَّامْ نّسْ. \x ◘ \xo 48:‏7 \xt إِرْم. 49‏:‏3\x*  
\v 8 أَمْثحَّايْ أَذْ د-يَاسْ غَارْ كُوڒْ ثَانْذِينْثْ ؤُشَا ؤُڒَا ذ إِشْثْ ن ثنْذِينْثْ وَارْ ثْزمَّارْ أَذْ ثنْجمْ. أَذْ ثتّْوَابْضڒْ ڒوْضَا ن ثغْزُورْثْ ؤُشَا ڒْوَاطَا أَذْ ثتّْوَاخَارّبْ، أَمْ مَامّشْ ث إِنَّا سِيذِي.‘ “   
\m
\v 9 ”وْشمْ أَفْرِيونْ إِ مُوآبَ، مَاغَارْ نِيثْنِي أَذْ فّْغنْ س ثَازْڒَا ؤُشَا ثِيندَّامْ نّسْ أَذْ ذوْڒنْثْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ، مَانِي وَارْ إِتّْغِيمِي إِزدّغْ \add عَاذْ\add* ؤُڒَا ذ إِجّْ.  
\v 10 إِتّْوَانْعڒْ ونِّي يَارْخُونْ ذِي ثْسخَّارْثْ ن سِيذِي، إِتّْوَانْعڒْ ونِّي إِسّْبدّنْ سِّيفْ نّسْ خْ \add ؤُسِيزّڒْ ن\add* إِذَامّنْ.  
\v 11 ثُوغَا مُوآبَ ذِي ڒَامَانْ زِي ثمْژِي نّسْ، يَارْسَا \add أَمْ بِينُو\add* خْ ڒخْمِيرَا نّسْ، وَارْ ث فَارّْغنْ زڭْ ؤُقْذِيحْ غَارْ ؤُقْذِيحْ \add نّغْنِي\add* ؤُعمَّارْصْ وَارْ إِفِّيغْ غَارْ لْمنْفَا. خْ ؤُيَا إِقِّيمْ أَسْ ؤُڒذِّي نّسْ ذ ڒفْوَاحْ نّسْ وَارْ إِبدّڒْ. \x ◘ \xo 48:‏11 \xt صَاف. 1‏:‏12\x*  
\v 12 س ؤُيَا، خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ، إِقَّارْ سِيذِي، أَذْ غَارسْ د-سّكّغْ إِنِّي إِ غَا إِفَارّْغنْ إِقْذِيحنْ ؤُشَا نِيثْنِي أَذْ ث فَارّْغنْ. نِيثْنِي أَذْ سّخْوَانْ ڒقْشُوعْ نّسْ ؤُ أَذْ أَرْژنْ إِغَارَّافنْ نّسْ.  
\v 13 مُوآبَ أَذْ إِنّفْضحْ زِي سِّيبّثْ ن كَامُوشْ، أَمْ مَامّشْ ثنّفْضحْ ثَادَّارْثْ ن إِسْرَائِيل زِي سِّيبّثْ ن بَايْثْ-إِلْ، إِ خفْ ثُوغَا تّثْشْڒنْ نِيثْنِي. \x ◘ \xo 48:‏13 \xt 1 إِج. 12‏:‏29\x*  
\v 14 مَامّشْ ثْزمَّارمْ أَذْ ثِينِيمْ: ’نشِّينْ ذ أَيْثْ ن بُو-ثغْرُوضْثْ، إِرْيَازنْ إِمحْضنْ، \add إِوجْذنْ\add* إِ ؤُمنْغِي؟‘  
\v 15 مُوآبَ إِتّْوَاخَارّبْ ؤُشَا إِڭعّذْ \add ڒعْذُو\add* غَارْ ثْندَّامْ نّسْ. أَشوَّارْ ن إِحُوذْرِييّنْ نّسْ هْوَانْ-د غَارْ ثْغَارْصْثْ، \add أَمُّو إِ\add* إِقَّارْ ؤُجدْجِيذْ، إِسمْ نّسْ سِيذِي ن ڒْعسْكَارَاثْ.“   
\m
\v 16 ”أَضيّعْ ن مُوآبَ يُوذسْ-د أَطَّاسْ ؤُ ڒْغَارْ نّسْ يِيوضْ-د ذغْيَا.  
\v 17 شثْشَامْ خَاسْ، مَارَّا كنِّيوْ إِ ذ أَسْ د-إِنّْضنْ ؤُ مَارَّا إِنِّي إِسّْننْ إِسمْ نّسْ. إِنِيمْ: ’مَامّشْ إِڭَّا يَارّژْ ؤُزدْجَاضْ \add ن صُّولْطَا\add* إِجهْذنْ، ثَاسطَّا نِّي إِصبْحنْ أَطَّاسْ؟‘  
\v 18 هْوَا-د زڭْ ومْشَانْ نّمْ يُوعْڒَانْ، قِّيمْ ذڭْ \add إِشْثْ ن جِّيهثْ ن\add* ؤُفَاذِي، شمْ ثنِّي \add ذِينْ\add* إِزدّْغنْ، يدْجِيسْ ن ذِيبُونْ، مَاغَارْ أَمْثحَّايْ ن مُوآبَ إِهجّمْ-د خَامْ، أَقَا يَاردّدْجْ لْقلْعَاثْ نّمْ.  
\v 19 بدّثْ غَارْ وبْرِيذْ ؤُشَا خْزَارثْ، شمْ ثنِّي إِزدّْغنْ ذِي عَارُوعِيرْ! سقْسَاثْ أَرْيَازْ نِّي يَاروْڒنْ، ثَامْغَارْثْ نِّي إِنجْمنْ، إِنِي: ’مِينْ إِمْسَارنْ؟‘  
\v 20 إِنّفْضحْ مُوآبَ، مِينْزِي إِتّْوَاڒْبزْ. شثْشَا، سْغُويّْ، أجّْ أَذْ سّْننْ ذِي أَرْنُونْ أَقَا مُوآبَ إِتّْوَاخَارّبْ. \x ◘ \xo 48:‏20 \xt إِشا. 16‏:‏7\x*  
\v 21 يِيوضْ-د ڒْحُوكْمْ خْ ڒْوَاطَا، خْ حُولُونْ، خْ يَاحْصَا، خْ مَايْفَاعَاثْ،  
\v 22 خْ ذِيبُونْ، خْ نابُو، خْ بَايْثْ-ذَابْلَاثَايِيمْ،  
\v 23 خْ قَارْيَاثَايِيمْ، خْ بَايْثْ-جَامُولْ، خْ بَايْثْ-مَاعُونْ،  
\v 24 خْ قَارْيُوثْ ؤُ خْ بُوصْرَا، ؤُ خْ مَارَّا ثِيندَّامْ ن ثمُّورْثْ ن مُوآبَ، ثِينِّي إِڭّْوجنْ ذ ثِينِّي يُوذْسنْ.  
\v 25 إِتّْوَاقْضعْ يِيشّْ ن مُوآبَ، يَارژْ ؤُغِيڒْ نّسْ، إِقَّارْ سِيذِي.“   
\m
\v 26 ”سْشَارمْ ث مَاغَارْ نتَّا ثُوغَا إِتّْعفَّارْ ضِيدّْ إِ سِيذِي س وَاوَاڒنْ ن ؤُكبَّارْ. أَذْ إِوْضَا مُوآبَ ذڭْ إِعُوقَّانْ ن يِيخفْ نّسْ ؤُشَا أَذْ إِذْوڒْ سِيمَانْثْ نّسْ إِ ثْسضْحَاشْثْ.  
\v 27 نِيغْ مَا وَارْ ثُوغِي إِسْرَائِيل إِ ثْسضْحَاشْثْ إِ شكْ؟ مَا طّْفنْ ث زعْمَا جَارْ إِشفَّارنْ أَقَا شكْ ثتّْعيَّابذْ ث أَمْ ثسّنْهزِّيذْ أَزدْجِيفْ مڒْمِي مَا إِوْضَا أَشْ-د خْ يِيڒسْ؟  
\v 28 فّْغمْ زِي ثْندَّامْ، زذْغمْ ذِي ڒجْرُوفْ، \add كنِّيوْ\add* إِمزْذَاغْ ن مُوآبَ! ڭّمْ أَمْ ثذْبِيرْثْ إِ إِڭِّينْ ڒْعُوشّْ خْ ؤُجمَّاضْ ن ؤُقمُّومْ ن يفْرِي إِتّْفَانْ.  
\v 29 نشِّينْ نسْڒَا خْ نّْفَاخثْ ن مُوآبَ، ذَايسْ نّْفَاخثْ أَطَّاسْ: نّْفَاخثْ نّسْ، أَعفَّارْ نّسْ ذ وُوڒْ نّسْ إِتُّوعْڒَانْ.“ \x ◘ \xo 48:‏29 \xt إِشا. 16‏:‏6\x*   
\m
\v 30 ”نشّْ سّْنغْ زّْعَامثْ نّسْ، إِقَّارْ سِيذِي، ؤُڒَا ذ ڒْغشّْ ن ڒْهَارْذْ نّسْ. نِيثْنِي وَارْ تّڭّنْ مِينْ قَّارنْ.  
\v 31 خْ ؤُيَا إِ غَا وْثغْ أَڭجْذُورْ خْ مُوآبَ، خْ مَارَّا مُوآبَ أَذْ سْغُويغْ، أَذْ زهَّارنْ خْ إِرْيَازنْ ن قِيرْ-حَارِيسْ.  
\v 32 س إِمطَّاونْ أَطَّاسْ خْ إِمطَّاونْ ن يَاعْزِيرْ أَذْ خَامْ رُوغْ، \add أَ\add* شمْ ثْزَايَارْثْ ن سِيبْمَا. ڒفْرُوعْ نّمْ عْذُونْ ڒبْحَارْ، إِوْضنْ-د أَڒْ ڒبْحَارْ ن جَاعْزِيرْ. يُوسَا-د \add مَاشَا\add* ؤُمْثحَّايْ إِهْجمْ خْ ثِينِي نّمْ ن ؤُنبْذُو ؤُڒَا خْ ڒْغِيدْجثْ نّمْ ن ؤُضِيڒْ.  
\v 33 ثْرُوحْ ڒفْرَاحثْ ذ ورْشَاقْ زِي ثمُّورْثْ إِسّɣ̮مَاينْ، زِي ثمُّورْثْ ن مُوآبَ، مِينْزِي سّْبدّغْ بِينُو زِي ثيْسِيرِينْ ن ؤُضِيڒْ. وَارْ تّْغِيمِينْ أَذْ دّْزنْ عَاذْ أَضِيڒْ س ؤُسْڒِيوْڒوْ. أَسْڒِيوْڒوْ؟ شْفَا ؤُسْڒِيوْڒوْ. \x ◘ \xo 48:‏33 \xt إِشا. 16‏:‏10\x*  
\v 34 زِي سِّيبّثْ ن ثْغُويِّيثْ ن حَاشْبُونْ أَڒْ أَلِيعَالَا، أَڒْ يَاهَاصْ، \add وَاهْ، نِيثْنِي\add* تّڭّنْ أَذْ سْڒنْ ثْمِيجَّا نْسنْ زِي صُوعَارْ أَڒْ حُورُونَايِيمْ، ثَاعجْمِيثْ \add نِّي\add* ن ثْڒَاثَا ن إِسڭّْوُوسَا. مَاغَارْ عَاذْ أَمَانْ ن نِيمْرِيمْ أَذْ ذوْڒنْ ذ إِيرْمَامنْ إِتّْوَاخَارّْبنْ. \x ◘ \xo 48:‏34 \xt إِشا. 15‏:‏5، 6\x*  
\v 35 ونِّي إِقدّْمنْ ثَاغَارْصْثْ ذِي ڒڭْعُوذِي ذ ونِّي إِتَّاوْينْ ثِيوْهِيبِينْ ن ڒبْخُورْ إِ إِربِّيثنْ نّسْ، أَذْ ث أَرّغْ أَذْ إِبدّْ \add زِي مَانْ أَيَا\add* ذِي مُوآبَ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\m
\v 36 ”خْ ؤُيَا إِتّْعفَّارْ وُوڒْ إِنُو خْ مُوآبَ أَمْ ثمْجَا، ؤُڒْ إِنُو إِتّْعفَّارْ خْ يرْيَازنْ ن قِيرْ-حَارِيسْ أَمْ يِيشْثْ ن ثمْجَا، مِينْزِي أَفيّضْ نِّي إِكْسبْ، أَقَا إِودَّارْ.  
\v 37 قَاعْ إِزدْجِيفنْ ذ إِقشُّورَا ؤُ قَاعْ ثِيمِيرَا تّْوَاقضْعنْثْ، ذِي مَارَّا إِفَاسّنْ نْسنْ \add أَقَا\add* إِقسِّيثنْ \add ن وشْضَانْ\add* ؤُ إِ ثجْعِينَّا نْسنْ \add أَقَا\add* ثَاخَانْشثْ \add ن وشْضَانْ\add*. \x ◘ \xo 48:‏37 \xt إِشا. 15‏:‏2، 3؛ إِرْم. 47‏:‏5\x*  
\v 38 خْ مَارَّا ثِيزغْوِينْ ن مُوآبَ ؤُ خْ مَارَّا وَازَّاينْ نّسْ، \add وَاهْ،\add* مَانِي مَا \add أَقَا ذِينْ\add* ثْغُويِّيثْ ن وشْضَانْ، مَاغَارْ نشّْ أَرْژِيغْ مُوآبَ أَمْ يِيشْثْ ن ڒْقشْعثْ وَارْ ذَايسْ بُو أَرْضَا \add عَاذْ\add*، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 39 مَامّشْ إِتّْوَاوّثْ مُوآبَ، مَامّشْ سّْغُويُّونْ نِيثْنِي. مَامّشْ \add إِ ذ أَسنْ ذ\add* يَارَّا مُوآبَ س وعْرُورْ س ؤُسضْحِي! مُوآبَ إِذْوڒْ ذ إِشْثْ نْ ڒْقشْعثْ ن ؤُسْثهْزِي ذ إِجّْ ن ؤُمذْيَا ن ؤُسْنخْڒِيعْ إِ مَارَّا إِنِّي ذ أَسْ د-إِنّْضنْ.“   
\m
\v 40 ”مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: ’خْزَارْ، أَمْ يِيجّْ ن ؤُڭِيذرْ أَذْ إِحوّمْ نتَّا ؤُشَا أَذْ إِبزّعْ أَفْرِيونْ نّسْ ثِيوَا ن مُوآبَ.\x ◘ \xo 48:‏40 \xt إِرْم. 4‏:‏13\x*  
\v 41 قَارْيُوثْ طّْفنْ ث ؤُشَاغڒْبنْ خْ لْقلْعَاثْ \add ذڭْ إِذُورَارْ\add*. \bd ذڭْ وَاسّْ نِّي\bd* أَذْ يِيڒِي وُوڒْ ن أَيْثْ ن بُو-ثغْرُوضْثْ ن مُوآبَ أَمْ وُوڒْ ن إِشْثْ ن ثمْغَارْثْ إِتَّارُونْ.  
\v 42 مُوآبَ أَذْ إِتّْوَاردّدْجْ أَڒَامِي وَارْ إِتِّيڒِي \add عَاذْ\add* ذ ڒْڭنْسْ مَاغَارْ إِسّمْغَارْ إِخفْ نّسْ خْ سِيذِي.  
\v 43 ثِيڭّْوُوذِي ذ ونْذَايْ ذ ڒْفخْ أَذْ خَاكْ إِڒِينْ، \add أَ\add* شكْ ونِّي إِزدّْغنْ ذِي مُوآبَ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 44 ونِّي إِ غَا يَاروْڒنْ زِي ثِيڭّْوُوذِي، أَذْ إِوْضَا ذِي ثسْرَافْثْ، ؤُ ونِّي د غَا إِڭعّْذنْ زِي ثسْرَافْثْ، أَذْ إِنَّاغْ ذِي ڒْفخْ، مَاغَارْ نشّْ أَذْ أَوْيغْ خْ مُوآبَ أَسڭّْوَاسْ ن وخْڒَافْ نّسْ، إِقَّارْ سِيذِي.‘ “   
\m
\v 45 ”ذِي ثِيڒِي ن حَاشْبُونْ قِّيمنْ إِمَارْوَاڒْ تّْبدَّانْ بْڒَا جّهْذْ، مَاغَارْ ثِيمسِّي ثفّغْ-د زِي حَاشْبُونْ، إِجّْ ن ؤُهَاذُوقْ زِي سِيحُونْ، ؤُشَا وَانِيثَا إِشَّا لْحنْكَاثْ ن \add ؤُزدْجِيفْ\add* مُوآبَ ذ أَشقُّوفْ ن مَارَّا أَيْثْ ن بُو-ڒخْشُونثْ.\x ◘ \xo 48:‏45 \xt ڒخْڒ. 21‏:‏28\x*  
\v 46 ؤُشْثْ خَاكْ، مُوآبَ، أَقَا إِخْسَارْ ڒْڭنْسْ ن كَامُوشْ، مَاغَارْ إِحنْجِيرنْ نّشْ تّْوَانذْهنْ ذِي ثْمحْبَاسْثْ ؤُشَا ؤُڒَا ذ يسِّيشْ تّْوَاحبّْسنْ.  
\v 47 ذڭْ ؤُنڭَّارْ ن وُوسَّانْ أَذْ سّنْقڒْبغْ ثَامحْبَاسْثْ ن مُوآبَ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ أَڒْ ذَانِيثَا \add إِدْجَا وَاوَاڒْ إِ يُورِينْ خْ\add* ڒْحُوكْمْ خْ مُوآبَ.   
\b  
\b  
\m  
\c 49
\m
\v 1 \bd خْ أَيْثْ ن عَامُّونْ\bd*  
\m ”أَمُّو إِ إِقَّارْ سِيذِي: ’مَا إِسْرَائِيل وَارْ غَارسْ بُو إِحنْجِيرنْ؟ مَا وَارْ غَارسْ بُو أَوْرِيثْ؟ مَايمِّي \add خنِّي\add* إِطّفْ ؤُجدْجِيذْ نْومْ \add ثَامُّورْثْ ن\add* جَاذْ ذ ڒْوَارْثْ إِ يِيخفْ نّسْ ؤُ مَايمِّي إِزدّغْ ڒْڭنْسْ نّسْ ذِي ثْندَّامْ \add ن جَاذْ\add*؟ \x ◘ \xo 49:‏1 \xt عَام. 1‏:‏13\x*  
\v 2 س ؤُيَا، خْزَارْ، ؤُسَّانْ أَذْ د-أَسنْ، أَمُّو إِ إِقَّارْ سِيذِي، أَذْ جّغْ أَذْ تّْوَاسْڒنْ إِغُويَّانْ \add ن ؤُمنْغِي\add* خْ \add ثنْذِينْثْ ن\add* رَابَّا ن أَيْثْ ن عَامُّونْ. أَذْ ثذْوڒْ \add ثنْذِينْثْ\add* ذ إِشْثْ ن ڒْڭعّْذثْ ن ڒْخَارْبثْ ؤُ ثِيندَّامْ إِ غَارسْ د-إِقّْننْ أَذْ ثنْثْ قّْذنْ س ثْمسِّي. إِسْرَائِيل أَذْ إِوَارْثْ \add عَاوذْ\add* مِينْ زَّايسْ كّْسنْ ذ ڒْوَارْثْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.\x ◘ \xo 49:‏2 \xt عَام. 1‏:‏14\x*  
\v 3 رُو، \add أَ\add* حَاشْبُونْ، مَاغَارْ \add ثَانْذِينْثْ ن\add* عَايْ ثتّْوَاردّدْجْ، سْغُويّنْثْ، \add أَ كنِّينْثْ\add* يسِّيسْ ن رَابَّا، حزّْمنْثْ س ثْخُونْشَايْ \add ن وشْضَانْ\add*، شضْننْثْ ؤُشَا ؤُيُورنْثْ غَارْ ذَا ذ ذِيهَا غَارْ ؤُغزْذِيسْ ن إِشْبَارنْ، مَاغَارْ أَجدْجِيذْ نْومْ، \add مِيلْكُومْ\add*، أَذْ إِتّْوَانْذهْ ذِي لْمنْفَا، إِكهَّاننْ نّسْ أَكْ-ذ ڒْحُوكَّامْ نّسْ.‘ “ \x ◘ \xo 49:‏3 \xt إِشا. 32‏:‏12؛ إِرْم. 4‏:‏8؛ 6‏:‏26؛ 48‏:‏7 \x*   
\m
\v 4 ”مشْحَاڒْ ثتّْفيّْشذْ س ڒوْضَاثْ ن ثغْزُورِينْ نّمْ، س ؤُفيّضْ ن ڒوْضَا نّمْ ن ثغْزُورْثْ، \add أَ شمْ\add* يدْجِيسْ إِكْفَارنْ، ثنِّي إِتّْشَاڒَانْ خْ وَاڭْڒَا نّسْ، \add ثقَّارْ:\add* ’وِي د غَارِي إِ غَا إِقَارّْبنْ؟‘ \x ◘ \xo 49:‏4 \xt إِرْم. 21‏:‏13؛ 48‏:‏7\x*  
\v 5 خْزَارْ، أَذْ خَامْ د -غضْرغْ ثِيڭّْوُوذِي زِي مَارَّا إِغزْذِيسنْ نّمْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ. كنِّيوْ أَذْ ثتّْوَاعَارّْنمْ، كُوڒْ إِجّْ نِيشَانْ غَارْ زَّاثْ، ؤُشَا وَارْ ذِينْ ؤُڒَا ذ إِجّنْ ونِّي إِ غَا إِسّْمُوننْ إِنِّي يَاروْڒنْ.  
\v 6 \add مَاشَا\add* أَوَارْنِي أَسْ أَذْ سّنْقڒْبغْ ثَامحْبَاسْثْ ن أَيْثْ ن عَامُّونْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\b  
\m
\v 7 \bd خْ إِذُومْ\bd*  
\m ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: ’مَا وَارْ ثدْجِي عَاذْ ثِيغِيثْ ذِي ثِييْمَانْ؟ مَا إِبْضڒْ شّْوَارْ ن إِمِيغِيسنْ؟ مَا ثْضيّعْ ثِيغِيثْ نْسنْ؟ \x ◘ \xo 49:‏7 \xt عُوب. 8\x*  
\v 8 أَروْڒمْ، ذوْڒمْ، فَّارمْ ذڭْ إِمُوشَانْ يُودْجْغنْ، \add كنِّيوْ\add* إِمزْذَاغْ ن ذَاذَانْ، مَاغَارْ نشّْ أَذْ خَاسْ أَوْيغْ أَضيّعْ ن عِيسُو، ڒْوقْثْ نِّي ذِي أَذْ ث عَاقْبغْ. \x ◘ \xo 49:‏8 \xt إِرْم. 25‏:‏23\x*  
\v 9 مَاڒَا ؤُسِينْ-د غَاركْ إِمڒْقَاضْ ن ؤُضِيڒْ، مَا \add خنِّي\add* وَارْ تّجِّينْ شَا أَوَارْنِي أَسنْ؟ مَاڒَا \add ؤُسِينْ-د\add* إِخوَّاننْ س دْجِيڒثْ، مَا خنِّي وَارْ تّْضيِّيعنْ أَڒْ غَا جِّيوْننْ؟ \x ◘ \xo 49:‏9 \xt عُوب. 5\x*  
\v 10 نشّْ مَاشَا قشَّارغْ \add ثَامُّورْثْ ن\add* عِيسُو، عَارِّيغْ خْ إِمُوشَانْ نّسْ إِنُّوفَّارنْ أَڒَامِي وَارْ إِزمَّارْ \add عَاذْ\add* أَذْ إِنُّوفَّارْ. ثَارْوَا نّسْ تّْوَاردّْدْجنْ، ؤُڒَا ذ أَيْثْمَاسْ ذ جِّيرَانْ نّسْ، أَقَا نتَّا وَارْ إِدْجِي عَاذْ.  
\v 11 أجّْ إِيُوجِيڒنْ نّشْ، نشّْ أَذْ ثنْ حْضِيغْ أَذْ قِّيمنْ دَّارنْ، ثِيجَّاڒْ نّشْ أجّْ إِ-ثنْثْ أَذْ خَافِي تّشْڒنْثْ.‘  
\v 12 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: ’خْزَارْ، إِنِّي وَارْ ث إِسّْذِيهدْجنْ أَذْ سْونْ زِي ڒْكَاسْ، أَذْ زَّايسْ سْونْ. ؤُ شكْ \add ونِّي ث إِسّْذَاهدْجنْ\add*، مَا أَذْ ثتّْوَابَارِّيذْ؟ وَارْ ثتّْوَابَارِّيذْ شَاعمَّارْصْ، أَذْ زَّايسْ ثسْوذْ س ؤُغِيڒْ!  
\v 13 مَاغَارْ نشّْ جُّودْجغْ غَارْ إِخفْ إِنُو، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَقَا بُوصْرَا أَذْ إِذْوڒْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ ذ ڒْحڭْرَا، ؤُڒَا ذ إِشْثْ ن ڒْخِيرْبثْ ذ نّعْڒثْ، ؤُشَا مَارَّا ثِيندَّامْ نّسْ أَذْ ذوْڒنْثْ ذ ڒْخِيرْبَاثْ إِ ڒبْذَا.‘ “   
\m
\v 14 ”نشّْ سْڒِيغْ إِجّْ ن ڒخْبَارْ زِي سِيذِي، أَقَا إِتّْوَاسّكّْ-د إِجّْ ن ؤُرقَّاسْ جَارْ ڒڭْنُوسْ حِيمَا أَذْ يِينِي: ’سْمُونمْ، سْڭعّْذمْ خَاسْ، كَّارمْ غَارْ ؤُمنْغِي!‘ \x ◘ \xo 49:‏14 \xt عُوب. 1\x*  
\v 15 مِينْزِي خْزَارْ، نشّْ سّمْژِييغْ شكْ جَارْ ڒڭْنُوسْ، ثتّْوَاسّحْقَارذْ جَارْ إِوْذَانْ.  
\v 16 ڒحْكَامثْ نّشْ إِسَّاڭّْوَاذنْ ثْغَارّْ إِ شكْ ؤُڒَا ذ زّْعَامثْ ن وُوڒْ نّشْ، \add أَ شكْ\add* ونِّي إِزدّْغنْ ذڭْ إِفدْجِيقنْ ن ڒجْرُوفْ، ونِّي إِتّْشبَّارنْ ذِي ثْقِيشّثْ ن ثوْرِيرِينْ! وَاخَّا ثڭِّيذْ ڒْعُوشّْ نّشْ سنّجْ قَاعْ أَمْ ث إِتّڭّْ ؤُڭِيذرْ، نشّْ أَذْ شكْ د -غضْڒغْ سّنِّي، إِقَّارْ سِيذِي. \x ◘ \xo 49:‏16 \xt إِرْم. 48‏:‏29\x*  
\v 17 إِذُومْ أَذْ إِذْوڒْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ. كُوڒْ إِجّْ ونِّي د أَسْ إِ غَا إِكّنْ، أَذْ إِنّخْڒعْ ؤُ أَذْ إِصفَّارْ \add س وسْرُوبِي\add* خْ مَارَّا جّْعَايفْ نّسْ. \x ◘ \xo 49:‏17 \xt إِرْم. 50‏:‏13\x*  
\v 18 أَمْ غَارْ ؤُنقْڒبْ ن سَاذُومْ ذ عَامُورَّا ذ ذْشُورَاثْ نّسْ يُوذْسنْ، إِقَّارْ سِيذِي، وَارْ ذِينِّي إِزدّغْ \add عَاذْ\add* ؤُڒَا ذ إِجّْ ؤُ وَارْ ذَايسْ إِتّْغِيمِي \add عَاذْ\add* ؤُڒَا ذ إِجّْ ن مِّيسْ ن بْنَاذمْ \add ذ أَبَارَّانِي\add*. \x ◘ \xo 49:‏18 \xt أَمز. 19‏:‏25؛ إِرْم. 50‏:‏40؛ عَام. 4‏:‏11\x*  
\v 19 خْزَارْ، أَمْ يِيجّْ ن وَايْرَاذْ أَذْ د-إِڭعّذْ زِي شْبَارْقْ إِقّْننْ ن لْ-ؤُرْذُونْ ضِيدّْ إِ ثْزذِّيغْثْ إِجهْذنْ، خنِّي ذڭْ ورْمَاشْ ن وَابْڒِيونْ أَذْ ث أَرّغْ أَذْ أَزّڒْ سّنِّي، ؤُ ونِّي ؤُمِي فَارْزغْ، أَذْ خَاسْ ث أَرشّْحغْ. مَاغَارْ مَانْ ونْ إِدْجَانْ أَمْ نشّْ، مَانْ ونْ خَافِي إِ غَا إِڒَاغَانْ إِ دّعْوثْ؟ مَانْ ونْ ذ أَمكْسَاوْ ونِّي إِ غَا إِقِّيمنْ زَّاثِي إِبدّْ؟ \x ◘ \xo 49:‏19 \xt أَيُوبْ 41‏:‏2؛ إِرْم. 12‏:‏5؛ 50‏:‏44\x*  
\v 20 س ؤُيَا، سْڒمْ إِ ؤُشَاوَارْ ن سِيذِي نِّي إِقْضعْ خْ إِذُومْ، ؤُ \add سْڒمْ\add* إِ إِنْوَاينْ نِّي إِخَارّصْ خْ إِمزْذَاغْ ن ثَايْمَانْ: ’س ثِيذتّْ، إِنِّي إِمژْيَاننْ أَطَّاسْ زڭْ وُودْجِي أَذْ ثنْ جَارّنْ، س ثِيذتّْ، ثَازذِّيغْثْ نْسنْ أَذْ ثتّْوَاسّْنخْڒعْ!‘ \x ◘ \xo 49:‏20 \xt إِرْم. 50‏:‏45\x*  
\v 21 ثَامُّورْثْ ثتّنْهزَّا س ڒْحسّْ ن ؤُوطُّو نْسنْ، س ثْغُويِّيثْ إِ زِي غَا إِتّْوَاسڒْ ڒْحسّْ نّسْ أَڒْ ڒبْحَارْ ن ثلْڭَا.  
\v 22 خْزَارْ، إِتّْڭعَّاذْ أَمْ يِيجّْ ن ؤُڭِيذرْ \add غَارْ ؤُجنَّا\add*، إِتّحْرَارَا، إِتّْبزَّاعْ أَفْرِيونْ نّسْ ثِيوَا ن بُوصْرَا. \bd ذڭْ وَاسّْ نِّي\bd* أَذْ يِيڒِي وُوڒْ ن أَيْثْ ن بُو-ثغْرُوضْثْ ن إِذُومْ أَمْ وُوڒْ ن إِشْثْ ن ثمْغَارْثْ س ڒحْرِيقْ ن ثَارْوَا.“ \x ◘ \xo 49:‏22 \xt إِرْم. 48‏:‏40،41\x*   
\b  
\m
\v 23 \bd خْ ذِيمَاشْقْ\bd*  
\m ”حَامَاثْ ذ أَرْفَاذْ سضْحَانْ، مَاغَارْ نِيثْنِي سْڒِينْ إِ وَارقَّاسْ ذ أَعفَّانْ، فشْڒنْ. غَارْ ڒبْحَارْ ثتّْوَافْ ڒحْصَارثْ، بْنَاذمْ وَارْ إِزمَّارْ أَذْ يَارْسَا \add ذِينْ\add*.\x ◘ \xo 49:‏23 \xt إِشا. 17‏:‏1\x*  
\v 24 ثَارْخُو \add ثنْذِينْثْ\add* ن ذِيمَاشْقْ، ثنّقْڒبْ، مَاحنْذْ أَذْ ثطّفْ ذِي ثَاروْڒَا. إِمْنعْ إِ-ت ؤُقْذِيدّسْ. ڒحْصَارثْ ذ ڒوْجعْ أَمْ ن إِشْثْ ثمْغَارْثْ إِتَّارْونْ طّْفنْ ت. \x ◘ \xo 49:‏24 \xt إِرْم. 4‏:‏31؛ 6‏:‏24؛ 30‏:‏6\x*  
\v 25 ثَانْذِينْثْ إِشنّْعنْ، مَا وَارْ ثڭِّي أَمْ ثنِّي إِتّْوَاجّنْ، ثَانْذِينْثْ ن ڒفْرَاحثْ إِنُو؟  
\v 26 س ؤُيَا أَذْ وْضَانْ إِحُوذْرِييّنْ نّسْ ذڭْ وَازَّاينْ ؤُ مَارَّا إِعسْكَارِييّنْ أَذْ تّْوَاسغْذنْ \bd ذڭْ وَاسّْ نِّي\bd*، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.  
\v 27 نشّْ أَذْ سَّارْغغْ ثِيمسِّي ذِي ڒْحِيضْ ن ذِيمَاشْقْ، أَذْ ثشّْ ڒقْصُورْ ن بِينْهَاذَاذْ.“ \x ◘ \xo 49:‏27 \xt عَام. 1‏:‏4، 14\x*   
\b  
\m
\v 28 \bd خْ وعْرَابنْ\bd*  
\m \bd خْ قِيذَارْ ذ ثْڭلْذِيثِينْ ن حَاصُورْ\bd* نِّي إِغْڒبْ نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ.  
\m ”أَمُّو إِ إِقَّارْ سِيذِي: ’كَّارمْ ؤُشَا هجْممْ خْ قِيذَارْ ؤُشَا أَردّْدْجمْ أَيْثْ ن شَّارْقْ.  
\v 29 نِيثْنِي أَذْ أَسنْ كّْسنْ إِقِيضَانْ نْسنْ ذ وُودْجِي نْسنْ، ثِيجَارْثِيڒِينْ ن ؤُقِيضَانْ نْسنْ ذ مَارَّا ڒْقشّْ نْسنْ. ؤُشَا ؤُڒَا ذ إِڒغْمَانْ نْسنْ أَذْ ثنْ أَوْينْ أَكِيذْسنْ. أَذْ خَاسنْ سْغُوينْ: أَسِيڭّْوذْ مَانِي مَا!  
\v 30 أَروْڒمْ، بعّْذمْ، فَّارمْ ذڭْ إِمُوشَانْ يُودْجْغنْ، \add كنِّيوْ\add* إِمزْذَاغْ ن حَاصُورْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، مَاغَارْ نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، إِقْضعْ خَاومْ أَشَاوَارْ ؤُشَا إِخَارّصْ ذڭْ إِجّْ ن ونْوَايْ خَاومْ.  
\v 31 كَّارمْ، ڭعّْذمْ خْ إِجّْ ن ڒْڭنْسْ نِّي إِزدّْغنْ ذِي ڒْهُوذْنثْ ؤُ ذِي ڒَامَانْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، \add إِجّْ ن ڒْڭنْسْ\add* وَارْ غَارسْ بُو ثوُّورَا ؤُڒَا ذ زّنْكْرُونْ، ونِّي إِزدّْغنْ وحّْذسْ.  
\v 32 إِڒغْمَانْ نْسنْ أَذْ تّْوَاحوّْسنْ ؤُشَا أَبَارُّو ن ثْحِيمْرِيوِينْ نْسنْ نْ ڒْمَاڒْ أَذْ تّْوَاشَارنْثْ ؤُ نشّْ أَذْ ثنْ زُوزَّارغْ غَارْ مَارَّا إِغزْذِيسنْ ن ؤُسمِّيضْ، \add مَارَّا\add* إِنِّي إِتّْحفَّانْ \add أَشُوَّافْ\add* غَارْ طّْرُوفَا، . نشّْ أَذْ خَاسنْ د-أَوْيغْ أَضيّعْ زِي مَارَّا إِغزْذِيسنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. \x ◘ \xo 49:‏32 \xt لَاوِي 19‏:‏27؛ 21‏:‏5؛ إِرْم. 9‏:‏25؛ 25‏:‏23. \x*  
\v 33 هَاصُورْ أَذْ إِذْوڒْ ذ ثَازذِّيغْثْ إِ وُوشَّاننْ ن ڒخْڒَا، إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ إِ ڒبْذَا. وَارْ ذَايسْ إِزدّغْ \add عَاذْ\add* ؤُڒَا ذ إِجّنْ ؤُشَا ؤُڒَا ذ إِجّْ ن مِّيسْ ن بْنَاذمْ أَذْ ذِينْ إِقِّيمْ \add عَاذْ\add* أَمْ ؤُبَارَّانِي.‘ “ \x ◘ \xo 49:‏33 \xt إِرْم. 9‏:‏10؛ 10‏:‏22\x*   
\b  
\m
\v 34 \bd خْ عِيلَامْ\bd*  
\m أَوَاڒْ ن سِيذِي إِ ؤُنَابِي إِرْمِييَا خْ عِيلَامْ، ذڭْ ؤُمزْوَارُو ن ثْڭلْذَا ن صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، إِنَّا:  
\v 35 ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: ’خْزَارْ، نشّْ أَذْ أَرْژغْ ڒْقوْسْ ن عِيلَامْ، أَمزْوَارُو ن ثْزمَّارْ نْسنْ ن أَيْثْ ن بُو-ثغْرُوضْثْ.  
\v 36 نشّْ أَذْ د-سّهْوِيغْ خْ عِيلَامْ أَربْعَا ن إِسمِّيضنْ زِي أَربْعَا ن ثْغمُّورَا ن ؤُجنَّا ؤُ غَارْ مَارَّا ثِيغمُّورَا ن إِسمِّيضنْ أَذْ ثنْ زُوزَّارغْ. وَارْ إِتِّيڒِي بُو ڒْڭنْسْ مَانِي وَارْ د-تِّيسنْ إِنِّي خْ ؤُژّْڒنْ زِي عِيلَامْ.  
\v 37 نشّْ أَذْ سّْنخْڒْعغْ \add أَيْثْ ن\add* عِيلَامْ زَّاثْ إِ ڒْعذْيَانْ نْسنْ ؤُ زَّاثْ إِ يِينِّي يَارزُّونْ ثُوذَارْثْ نْسنْ. نشّْ أَذْ د -غضْڒغْ ڒْغَارْ خَاسنْ، ڒْحَاذُوقْ ن وغْضَابْ إِنُو، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. نشّْ أَذْ أَسنْ سّضْفَارغْ سِّيفْ أَڒْ ثنْ ثحِّيغْ.  
\v 38 نشّْ أَذْ سّْبدّغْ ڒْعَارْشْ إِنُو ذِي عِيلَامْ ؤُشَا أَذْ ثحِّيغْ أَجدْجِيذْ ذ ڒْحُوكَّامْ سّنِّي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 39 ذڭْ ؤُنڭَّارْ ن وُوسَّانْ أَذْ سّنْقڒْبغْ ثَامحْبَاسْثْ ن عِيلَامْ \add أَمُّو إِ\add* إِقَّارْ سِيذِي.‘ “ \x ◘ \xo 49:‏39 \xt إِرْم. 48‏:‏47\x*   
\b  
\b  
\m  
\c 50
\s1 خْ بَابِيلْ  
\m
\v 1 أَوَاڒْ نِّي إِسِّيوڒْ سِيذِي \bd خْ بَابِيلْ، خْ ثمُّورْثْ ن إِكَالْذَانِييّنْ\bd*، س ؤُفُوسْ ن ؤُنَابِي إِرْمِييَا.   
\m
\v 2 ”بَارّْحمْ جَارْ ڒڭْنُوسْ، جّمْ أَذْ أَسْ سْڒنْ، سْڭعّْذمْ ثَاعدْجَانْثْ، جّمْ أَذْ أَسْ سْڒمْ، وَارْ \add ت\add* سْنُوفَّارَامْ. إِنِيمْ: ’\add ثَانْذِينْثْ ن\add* بَابِيلْ ثتّْوَاطّفْ، بِيلْ إِسضْحَا، مَارُوذَاخْ أَقَا يَارْژَا، ڒخْيَاڒَاثْ نّسْ ن لْ-أَصْنَامْ تّْوَابَارْقنْ، إِميْضَا ن \add لْ-أَصْنَامْ نّسْ\add* تّْوَاڒبْزنْ!‘ \x ◘ \xo 50:‏2 \xt إِشا. 46‏:‏1؛ إِرْم. 51‏:‏44\x*  
\v 3 مَاغَارْ إِهْجمْ-د خَاسْ إِجّْ ن ڒْڭنْسْ زِي شَّامَالْ، أَذْ يَارّْ ثَامُّورْثْ نّسْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ، وَارْ ذَايسْ إِزدّغْ عَاذْ ؤُڒَا ذ إِجّْ، زِي بْنَاذمْ أَڒْ ڒْمَاڒْ أَروْڒنْ، فّْغنْ.“   
\b  
\m
\v 4 ”ذڭْ وُوسَّانْ نِّي ؤُ ذِي ڒْوقْثْ نِّي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَذْ د-أَسنْ أَيْثْ ن إِسْرَائِيل مُوننْ أَكْ-ذ أَيْثْ ن يَاهُوذَا. أَذْ ؤُيُورنْ أَمْ تّْرُونْ، أَذْ أَرْزُونْ خْ سِيذِي، أَربِّي نْسنْ.  
\v 5 خْ صِيهْيُونْ أَذْ سّقْسَانْ، أَقَا غَارْ ذِينِّي إِ نْضَارنْ ثِيطَّاوِينْ نْسنْ. نِيثْنِي أَذْ د-أَسنْ ؤُشَا أَذْ د-مَّارنْينْ غَارْ سِيذِي س إِجّْ ن ڒْعَاهْذْ إِتّْذُومَانْ نِّي وَارْ إِتّْوَاتُّونْ.  
\v 6 ثُوغَا ڒْڭنْسْ إِنُو ذ ؤُدْجِي إِودَّارنْ، إِمكْسَاونْ نْسنْ سُّوفّْغنْ ثنْثْ خْ وبْرِيذْ خْ إِذُورَارْ إِكْفَارنْ. نِيثْنِي ؤُيُورنْثْ زڭْ وذْرَارْ أَڒْ ثوْرِيرْثْ، تُّونْثْ أَمْشَانْ ن أَرَّاحثْ نْسنْثْ.  
\v 7 مَارَّا وِي ثنْثْ يُوفِينْ، شِّينْ ثنْثْ ؤُشَا إِغْرِيمنْ نْسنْثْ نَّانْ: ’نشِّينْ وَارْ ذ أَنغْ إِتَّارْسْ حذْ، مَاغَارْ نِيثنْثِي خْضَانْثْ أَكْ-ذ سِيذِي، أَكْ-ذ ثْزذِّيغْثْ ن ثْسڭْذَا، أَكْ-ذ ڒَايَاسْ ن ڒجْذُوذْ نْسنْثْ \add ضِيدّْ إِ\add* سِيذِي.‘ \x ◘ \xo 50:‏7 \xt إِرْم. 31‏:‏23\x*  
\v 8 أَرْوْڒمْ زِي بَابِيلْ، فّْغمْ زِي ثمُّورْثْ ن إِكَالْذَانِييّنْ، إِڒِيمْ أَمْ يِيغَايْضنْ إِتِّيزْوَارنْ إِ وُودْجِي!“ \x ◘ \xo 50:‏8 \xt إِشا. 48‏:‏20؛ إِرْم. 51‏:‏6؛ أَسَا. 18‏:‏4\x*   
\b  
\m
\v 9 ”مَاغَارْ خْزَارْ، نشّْ سِيمَانْثْ إِنُو أَذْ د-سّْحَارّْشغْ خْ بَابِيلْ إِجّْ ن ؤُبَارُّو ن ڒڭْنُوسْ إِمقّْرَاننْ زِي ثمُّورْثْ ن شَّامَالْ. نِيثْنِي أَذْ سّْبدّنْ إِخفْ نْسنْ ضِيدّْ نّسْ. سّنِّي أَذْ ثتّْوَاطّفْ \add ثَانْذِينْثْ ن بَابِيلْ\add*. فْڒِيثْشَاثْ نْسنْ أَمْ أَيْثْ ن بُو-ثغْڒُوضْثْ إِمحْضنْ، ؤُڒَا ذ إِشْثْ زَّايْسنْثْعمَّارْصْ وَارْ د-ثْعِيقِّيبْ ثخْوَا.  
\v 10 \add ثَامُّورْثْ ن\add* إِكَالْذَانِييّنْ أَذْ ثذْوڒْ ذ ثَاكشَّاضْثْ، مَارَّا إِنِّي ت إِ غَا إِكشّْضنْ، أَذْ جِّيوْننْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 11 مِينْزِي كنِّيوْ ثْفَارْحمْ، أَقَا ثْنڭّْزمْ س ڒفْرَاحثْ، \add أَ كنِّيوْ\add* إِنِّي إِكشّْضنْ ثَاسْغَارْثْ إِنُو. كنِّيوْ ثْنذْومْ أَمْ ثْعجْمِييِّينْ ذِي دّمْنثْ ؤُ ثسّْنحْنِيحمْ أَمْ \add ييْسَانْ\add* إِجهْذنْ.  
\v 12 ثْسضْحَا يمَّاثْومْ، ثنِّي كنِّيوْ إِ د-يُورْونْ، أَقَا إِڒْقفْ إِ-ت ؤُسحْشمْ. خْزَارْ، نتَّاثْ ذ ثَانڭَّارُوثْ نْ ڒڭْنُوسْ: \add مْغِيرْ\add* ذ ڒخْڒَا ذ ڒكْحضْ ذ ثَانزْرُوفْثْ.  
\v 13 زِي سِّيبّثْ ن ؤُذُوقّزْ ن وغْضَابْ ن سِيذِي أَذْ ثقِّيمْ \add ثنْذِينْثْ ن بَابِيلْ\add* وَارْ ثتّْوَازدّغْ \add عَاذْ\add*، أَذْ ثذْوڒْ ذ إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ. مَارَّا وِي غَا إِعْذُونْ خْ بَابِيلْ أَذْ إِنّخْڒعْ، أَذْ إِصفَّارْ \add س ؤُعيّبْ\add* خْ مَارَّا جّْعَايفْ نّسْ.“ \x ◘ \xo 50:‏13 \xt إِرْم. 49‏:‏17\x*   
\b  
\m
\v 14 ”سدّمْ إِخفْ نْومْ إِ ؤُمنْغِي أَكْ-ذ بَابِيلْ غَارْ مَارَّا إِغزْذِيسنْ نّسْ، مَارَّا إِنِّي إِمحْضنْ ڒْقوْسْ، مَاغَارْ نتَّاثْ ثخْضَا أَكْ-ذ سِيذِي.  
\v 15 سْغُويّمْ خَاسْ زِي مَارَّا إِغزْذِيسنْ. أَقَا نتَّاثْ ثْسلّمْ إِخفْ نّسْ. وْضَانْ لْبُورْجَاثْ نّسْ، هذْمنْ ڒحْيُوضْ نّسْ، مَاغَارْ وَا ذ نّقْمثْ ن سِيذِي. خڒْفمْ زَّايسْ، ڭّمْ زَّايسْ أَمْ مَامّشْ إِ ثڭَّا نتَّاثْ. \x ◘ \xo 50:‏15 \xt أَسَا. 18‏:‏6\x*  
\v 16 كّْسمْ أَزَارَّاعْ زِي بَابِيلْ ذ ونِّي إِطّْفنْ أَمْجَارْ ذِي ڒْوقْثْ ن ثْمجْرَا! زِي سِّيبّثْ ن سِّيفْ إِقسْحنْ أَذْعقْبنْ نِيثْنِي، كُوڒْ إِجّْ غَارْ ڒْڭنْسْ نّسْ، ؤُشَا أَذْ أَروْڒنْ، كُوڒْ  إِجّْ غَارْ ثمُّورْثْ نّسْ.“   
\b  
\m
\v 17 ”إِسْرَائِيل \add أَمْ\add* إِجّنْ زڭْ وُودْجِي إِ خفْ ؤُژّْڒنْ، ثنِّي خْعرْفنْ وَايْرَاذنْ. غَارْ ؤُمزْوَارْ إِسَارْضْ إِ-ت ؤُجدْجِيذْ ن أَشُّورْ، غَارْ ؤُنڭَّارْ إِدّزْ أَسْ نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، إِغْسَانْ نّسْ.  
\v 18 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: ’خْزَارْ، نشّْ أَذْ خڒْفغْ زڭْ ؤُجدْجِيذْ ن بَابِيلْ ذ ثمُّورْثْ نّسْ، أَمْ مَامّشْ خڒْفغْ زڭْ ؤُجدْجِيذْ ن أَشُّورْ. \x ◘ \xo 50:‏18 \xt 2 إِج. 19‏:‏35، 37؛ إِشا. 37‏:‏36، 38\x*  
\v 19 إِسْرَائِيل \add مَاشَا\add* أَذْ ث-إِ-د-أَرّغْ غَارْ ثْزذِّيغْثْ نّسْ ؤُ نتَّا أَذْ يَارْوسْ خْ كَارْمَالْ ذ بَاشَانْ، أَذْ ثجَّاونْ ڒعْمَارْ نّسْ ذِي ثمُّورْثْ ن إِذُورَارْ ن إِفْرَايِيمْ ذ جِيلْعَاذْ.‘ “   
\m
\v 20 ”ذڭْ وُوسَّانْ نِّي ؤُ ذِي ڒْوقْثْ نِّي، إِقَّارْ سِيذِي، أَذْ أَرْزُونْ خْ ڒْعِيبْ ن إِسْرَائِيل، \add مَاشَا\add* وَارْ إِتِّيڒِي، ؤُ خْ دّْنُوبْ ن يَاهُوذَا، \add مَاشَا\add* وَارْ ثنْ تِّيفنْ، مِينْزِي إِنِّي إِ د غَا أَرّغْ أَذْ قِّيمنْ، نشّْ أَذْ أَسنْ غْفَارغْ.   
\m
\v 21 ڭعّذْ ضِيدّْ إِ ثمُّورْثْ ن مَارَاثَايِيمْ، \add ’ثَامُّورْثْ ن ؤُغوّغْ ثْنَاينْ ن ثْسقَّارْ‘\add*، ؤُ ضِيدّْ إِ إِمزْذَاغْ ن فَاقُوذْ، \add ’ثَانْذِينْثْ ن وخْڒفْ‘\add*. أَردّدْجْ ؤُ حَارّمْ أَوَارْنِي أَسنْ مَارَّا \add إِ ؤُثحِّي\add*، \add أَمُّو\add* إِ إِقَّارْ سِيذِي، ؤُ أڭّْ عْلَاحْسَابْ مَارَّا مِينْزِي شكْ ؤُمُورغْ.“   
\m
\v 22 ”\add أَقَا ذَا، إِتّْوَاسڒْ\add* لْهَارَاجْ ن ؤُمنْغِي ذِي ثمُّورْثْ، إِشْثْ ن لْمُوصِيبَا ثَامقّْرَانْثْ.  
\v 23 مَامّشْ إِتّْوَاقسّْ ؤُ إِتّْوَارْژْ وفْضِيسْ ن مَارَّا دُّونشْثْ! مَامّشْ إِذْوڒْ بَابِيلْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ جَارْ ڒڭْنُوسْ!  
\v 24 نشّْ ڭِّيغْ أَمْ، \add أَ، ثَانْذِينْثْ ن\add* بَابِيلْ، إِجّْ ن ڒْفخْ ؤُشَا ثجِّيذْ إِخفْ نّمْ أَذْ شمْ ڭّنْ ذِي ڒحْبسْ، وَاخَّا وَارْ ثُوشِيذْ. ؤُفِينْ ذ طّْفنْ ؤُڒَا ذ شمْ، مَاغَارْ شمْ ثُوغَا ثتّمْعَارِّيذْ أَكْ-ذ سِيذِي.  
\v 25 سِيذِي يَارْزمْ أَخَّامْ نّسْ ن ثْخُوبَايْ ؤُشَا إِسُّوفّغْ-د دُّوزَانْ ن وسْخضْ نّسْ، مَاغَارْ ثَا ذ إِشْثْ ن ڒْخذْمثْ إِ سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ، ذِي ثمُّورْثْ ن إِكَالْذَانِييّنْ.  
\v 26 أَزّْڒمْ غَارسْ زِي طَّارْفْ \add ن ثمُّورْثْ\add*، أَرْزْممْ ڒخْزَاينْ نّسْ، نْضَارمْ مَارَّا خْ إِعُورِّيشنْ يُوعْڒَانْ ؤُشَا حَارّْممْ ثنْ \add إِ ؤُثحِّي\add*، حْضَامْ مْلِيحْ مَاحنْذْ وَارْ زَّايسْ إِتّْغِيمِي وَالُو.  
\v 27 نْغمْ مَارَّا إِفُونَاسنْ نّسْ إِمژْيَاننْ س سِّيفْ، سهْوَامْ ثنْ-د غَارْ ثْغَارْصْثْ. ؤُشْثْ خَاسنْ، مَاغَارْ أَسّْ نْسنْ يِيوضْ-د، ثَاسَاعّثْ ن ؤُعَاقبْ نْسنْ!  
\v 28 \add أَقَا ذَا\add* إِجّْ ن ڒْحسّْ ن إِمَارْوَاڒنْ ؤُ ن يِينِّي إِنجْمنْ زِي ثمُّورْثْ ن بَابِيلْ مَاحنْذْ أَذْ بَارّْحنْ أَخْڒَافْ ن سِيذِي، أَربِّي نّغْ، ذِي صِيهْيُونْ، أَخْڒَافْ ذِي طّْوعْ ن زَّاوشْثْ نّسْ ثَامقّْرَانْثْ.“   
\m
\v 29 ”ڒَْاغَامْ إِ أَيْثْ ن ڒْقوْسْ غَارْ بَابِيلْ، مَارَّا إِنِّي إِجبّْذنْ ڒْقوْسْ! حْصَارمْ ثَانْذِينْثْ زِي مَارَّا إِغزْذِيسنْ، حْضَامْ مَاحنْذْ ؤُڒَا ذ إِجّنْ أَذْ إِنْجمْ. خڒْفمْ ت عْلَاحْسَابْ ثِيمڭَّا نّسْ، ڭّمْ زَّايسْ عْلَاحْسَابْ مَارَّا مِينْ ثڭَّا، مَاغَارْ نتَّاثْ ثُوغَا ثفُّوشّحْ أَكْ-ذ سِيذِي، أَكْ-ذ ؤُمْقدّسْ ن إِسْرَائِيل. \x ◘ \xo 50:‏29 \xt أَسَا. 18‏:‏6، 7\x*  
\v 30 س ؤُيَا أَذْ وْضَانْ إِحُوذْرِييّنْ نّسْ ذڭْ وَازَّاينْ ذ مَارَّا إِعسْكَارِييّنْ نّسْ أَذْ تّْوَاسُّوسْمنْ \bd ذڭْ وَاسّْ نِّي\bd*، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ. \x ◘ \xo 50:‏30 \xt إِرْم. 49‏:‏26\x*  
\v 31 خْزَارْ، نشّْ أَذْ غَارمْ كَّارغْ، \add أَ شمْ\add* ثنِّي إِفُّوشّْحنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ، مِينْزِي أَسّْ نّمْ يِيوضْ-د، ثْسَاعّثْ نِّي ذِي شمْ إِ غَا خدْجْصغْ.  
\v 32 خنِّي ونِّي إِفُّوشّْحنْ أَذْ إِنْقَارْضْ، أَذْ إِوْضَا، ؤُشَا ؤُڒَا ذ إِجّْ وَارْ ث إِسّْبذِّي. نشّْ أَذْ قّْذغْ ثِيمسِّي ذِي ثْندَّامْ نّسْ نِّي إِ غَا إِشّنْ مَارَّا مِينْ ذ أَسنْثْ-إِ-د إِنّْضنْ.“   
\m
\v 33 ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: ’تّْوَاحْصَارنْ أَيْثْ ن إِسْرَائِيل \add جْمِيعْ\add* أَكْ-ذ أَيْثْ ن يَاهُوذَا. مَارَّا إِنِّي ثنْ إِحبّْسنْ، طّْفنْ ثنْ، ؤُڭِينْ أَذْ جّنْ أَذْ أَسنْ أَرْخُونْ.  
\v 34 \add مَاشَا\add* أَمفْذِي نْسنْ إِجْهذْ، سِيذِي ن ڒْعسْكَارَاثْ ذ إِسمْ نّسْ. نتَّا ڭُّورْ أَذْ إِوّثْ خْ دّعْوثْ نْسنْ حِيمَا أَذْ إِڭّْ ڒْهُوذْنثْ إِ ثمُّورْثْ ؤُ حِيمَا أَذْ إِسَّارْجِيجْ إِمزْذَاغْ ن بَابِيلْ.‘ “   
\m
\v 35 ”سِّيفْ خْ إِكَالْذَانِييّنْ، إِقَّارْ سِيذِي، ؤُ خْ إِمزْذَاغْ ن بَابِيلْ، خْ ڒْحُوكَّامْ نّسْ ؤُ خْ إِمِيغِيسنْ نّسْ.  
\v 36 سِّيفْ خْ أَيْثْ ن بُو-إِخَارِّيقنْ مَاحنْذْ أَذْ ذوْڒنْ ذ إِبُوهَاڒِييّنْ، سِّيفْ خْ أَيْثْ ن بُو-ثغْرُوضْثْ نّسْ مَاحنْذْ أَذْ تّْوَارْژنْ.  
\v 37 سِّيفْ خْ ييْسَانْ نّسْ ؤُ خْ إِكَارُّوثنْ نّسْ ؤُ خْ ؤُبَارُّو ن عْڒَامْ كُوڒْ  إِبَارَّانِييّنْ \add نِّي إِدْجَانْ\add* ذِي ڒْوسْطْ نّسْ، مَاحنْذْ أَذْ ذوْڒنْ أَمْ ثمْغَارِينْ. سِّيفْ خْ ڒكْنُوزْ نّسْ مَاحنْذْ أَذْ تّْوَاشَارنْ.  
\v 38 ڒكْحضْ خْ وَامَانْ نّسْ مَاحنْذْ أَذْ أَژْغنْ، مَاغَارْ ذ إِشْثْ ن ثمُّورْثْ ثشُّورْ س ڒخْيَاڒَاثْ إِنقْشنْ ؤُشَا نِيثْنِي ذوْڒنْ ذ إِبُوهَاڒِييّنْ زِي نّْعَاوَاثْ ن لْ-أَصْنَامْ.  
\v 39 س ؤُيَا أَذْ \add ذِينْ\add* زذْغنْ ڒوْحُوشْ ن ڒخْڒَا أَكْ-ذ يِيفِيسنْ ؤُشَا ؤُڒَا ذ يسِّيسْ ن نّْعَامثْ أَذْ زذْغنْثْ ذِينْ. إِ ڒبْذَا وَارْ إِتّْغِيمِي ذِينْ ؤُڒَا ذ إِجّْ ؤُ وَارْ \add ذَايسْ\add* زدّْغنْ عَاذْ زِي جِّيڒْ أَڒْ جِّيڒْ. \x ◘ \xo 50:‏39 \xt [إِشا. 13‏:‏20]\x*  
\v 40 أَمْ مَامّشْ ثُوغَا إِسّْنقْڒبْ أَربِّي سَاذُومْ ذ عَامُورَّا ذ ذْشُورَاثْ نّسْ يُوذْسنْ، \add أَمُّو\add* وَارْ ذِينِّي إِزدّغْ \add عَاذْ\add* ؤُڒَا ذ إِجّْ ؤُ وَارْ ذَايسْ إِتّْغِيمِي \add عَاذْ\add* ؤُڒَا ذ إِجّْ ن مِّيسْ ن بْنَاذمْ \add ذ أَبَارَّانِي\add*، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ \x ◘ \xo 50:‏40 \xt أَمز. 19‏:‏25؛ إِرْم. 49‏:‏18\x*   
\m
\v 41 ”خْزَارْ، إِجّْ ن ڒْڭنْسْ أَذْ د-يَاسْ زِي شَّامَالْ، إِجّْ ن ڒْڭنْسْ ذ أَمقّْرَانْ، ؤُشَا أَطَّاسْ ن إِجدْجِيذنْ أَذْ تّْوَاعَارّنْ أَذْ فَاقنْ زِي ثْغمُّورَا ن ثمُّورْثْ. \x ◘ \xo 50:‏41 \xt إِرْم. 6‏:‏22، 30\x*  
\v 42 نِيثْنِي منّْعنْ ذِي ڒْقوْسْ ذ فْڒِيثْشَا. نِيثْنِي تّوْعَارنْ، وَارْ أَرّحمنْ. ثْمِيجَّا نْسنْ أَمْ زّْهِيرْ ن ڒبْحَارْ، نِيثْنِي نَّاينْ خْ ييْسَانْ. أَقَا تّْحزَّامنْ غَارْ ؤُمنْغِي أَكِيذمْ، \add أَ\add* يدْجِيسْ ن بَابِيلْ!  
\v 43 إِسْڒَا ؤُجدْجِيذْ ن بَابِيلْ ڒخْبَارْ خَاسنْ ؤُشَا ذوْڒنْ أَسْ إِفَاسّنْ طّْسنْ. ثطّفْ إِ-ث إِ-د ثِيڭّْوُوذِي، \add ؤُڒَا ذ\add* ڒحْرِيقْ أَمْ ن إِشْثْ ن ثمْغَارْثْ إِتَّارْونْ. \x ◘ \xo 50:‏43 \xt إِرْم. 49‏:‏24\x*  
\v 44 خْزَارْ، أَمْ يِيجّْ ن وَايْرَاذْ أَذْ د-إِڭعّذْ زِي شْبَارْقْ إِقّْننْ ن لْ-ؤُرْذُونْ، \add أَمُّو إِ غَا إِڭعّذْ\add* ضِيدّْ إِ ثْزذِّيغْثْ إِجهْذنْ، مَاغَارْ ذڭْ ورْمَاشْ ن وَابْڒِيونْ أَذْ ثنْ أَرّغْ أَذْ أَزّْڒنْ سّنِّي، ؤُ ونِّي ؤُمِي فَارْزغْ، أَذْ خَاسْ ث أَرشّْحغْ. مَاغَارْ مَانْ ونْ إِدْجَانْ أَمْ نشّْ، مَانْ ونْ خَافِي إِ د غَا إِڒَاغَانْ إِ دّعْوثْ؟ مَانْ ونْ ذ أَمكْسَاوْ ونِّي إِ غَا إِقِّيمنْ زَّاثِي إِبدّْ؟ \x ◘ \xo 50:‏44 \xt أَيُوبْ 41‏:‏2؛ إِرْم. 49‏:‏19، 22\x*  
\v 45 س ؤُيَا، سْڒمْ إِ ؤُشَاوَارْ ن سِيذِي نِّي إِقْضعْ خْ بَابِيلْ ؤُ \add سْڒمْ\add* إِ إِنْوَاينْ نّسْ نِّي إِخَارّصْ خْ ثمُّورْثْ ن إِكَالْذَانِييّنْ: ’س ثِيذتّْ، إِنِّي إِمژْيَاننْ أَطَّاسْ زڭْ وُودْجِي أَذْ ثنْ جَارّنْ، س ثِيذتّْ، ثَازذِّيغْثْ نْسنْ أَذْ ثتّْوَاسّْنخْڒعْ!‘ \x ◘ \xo 50:‏45 \xt إِرْم. 49‏:‏20\x*  
\v 46 ثَامُّورْثْ ثتّنْهزَّا زِي ڒْحسّْ ن ؤُطفُّو ن بَابِيلْ ؤُشَا أَغُويِّي نّسْ إِتّْوَاسڒْ غَارْ ڒڭْنُوسْ.“ \x ◘ \xo 50:‏46 \xt إِرْم. 49‏:‏21\x*   
\b  
\b  
\m  
\c 51
\m
\v 1 ”أَمُّو إِ إِقَّارْ سِيذِي: ’خْزَارْ، نشّْ أَذْ د-سّكَّارغْ إِجّْ ن بُوحْبڒْ ن وَاردّدْجْ خْ بَابِيلْ ؤُ خْ يِينِّي ذِينْ إِزدّْغنْ ذڭْ وُوڒْ ن إِغْرِيمنْ إِنُو. \x ◘ \xo 51:‏1 \xt إِرْم. 4‏:‏11\x*  
\v 2 نشّْ أَذْ سّكّغْ إِبَارَّانِييّنْ غَارْ بَابِيلْ، أَذْ ت زُوزَّارنْ ؤُشَا أَذْ فَارْضنْ ثَامُّورْثْ نّسْ، مِينْزِي ذڭْ وَاسّْ نْ ڒْغَارْ أَذْ بدّنْ أَرنْذَاذْ نّسْ غَارْ مَارَّا إِغزْذِيسنْ. \x ◘ \xo 51:‏2 \xt إِرْم. 4‏:‏11؛ 15‏:‏7\x*  
\v 3 أجّْ أَمْجبَّاذْ ن ڒْقوْسْ أَذْ إِمْحضْ ڒْقوْسْ نّسْ ضِيدّْ ن ونِّي إِمحْضنْ \add ڒْقوْسْ\add* ؤُ ضِيدّْ ن ونِّي إِسّْڭعَّاذنْ إِخفْ نّسْ ذڭْ ورُّوضْ نّسْ ن وُوزَّاڒْ. وَارْ تّْحِيوِيڒمْ خْ إِحُوذْرِييّنْ نّسْ، حَارّْممْ مَارَّا ڒْعسْكَارْ نّسْ \add إِ ؤُثحِّي\add*.  
\v 4 إِنِّي إِتّْوَانْغنْ وْضَانْ ذِي ثمُّورْثْ ن إِكَالْذَانِييّنْ، ؤُ إِنِّي إِتّْوَاسّْخَارّْقنْ أَقَا أَثنْ خْ إِبْرِيذنْ نّسْ.‘ “ \x ◘ \xo 51:‏4 \xt إِرْم. 49‏:‏26\x*  
\v 5 ”مَاغَارْ إِسْرَائِيل ذ يَاهُوذَا وَارْ تّْوَاجّنْ ذ ثَاجَّاتْشْ زِي أَربِّي نْسنْ، زِي سِيذِي ن ڒْعسْكَارَاثْ، مِينْزِي ثَامُّورْثْ ن \add إِكَالْذَانِييّنْ\add* ثشُّورْ س ؤُمَارْوَاسْ غَارْ ؤُمْقدَّاسْ ن إِسْرَائِيل.“   
\b  
\m
\v 6 ”أَروْڒمْ زِي بَابِيلْ، أجّْ أَذْ إِسّنْجمْ كُوڒْ إِجّْ ثُوذَارْثْ نّسْ، وَارْ تّجِّيمْ أَذْ تّْوَاسّْبكّْممْ \add إِ ڒبْذَا\add* س ڒْمُوعْصِييّثْ نّسْ، مَاغَارْ ثَا ذ ڒْوقْثْ ن وخْڒَافْ ن سِيذِي، نتَّا أَذْ زَّايسْ إِخْڒفْ مِينْ ثسْذَاهدْجْ.“ \x ◘ \xo 51:‏6 \xt إِرْم. 50‏:‏8، 15، 28؛ أَسَا. 18‏:‏4\x*   
\b  
\m
\v 7 ”بَابِيلْ ثُوغَا-ت ذ إِجّْ ن ڒْكَاسْ ن وُورغْ ذڭْ ؤُفُوسْ ن سِيذِي، إِسْشَارْ مَارَّا ثَامُّورْثْ. زِي بِينُو نّسْ سْوِينْ مَارَّا ڒڭْنُوسْ، خْ ؤُيَا إِفّغْ ڒعْقڒْ إِ ڒڭْنُوسْ. \x ◘ \xo 51:‏7 \xt أَسَا. 18\x*  
\v 8 ذغْيَا ثوْضَا \add ثنْذِينْثْ ن\add* بَابِيلْ ؤُ ثتّْوَاهْذمْ. وْثمْ خَاسْ أَڭجْذُورْ، أَوْيمْ أَسْ-د بَالْسَامْ إِ ڒحْرِيقْ نّسْ، أَذْ ثَاغْ أَذْ ثتّْوَاسّْڭنْفَا.“ \x ◘ \xo 51:‏8 \xt إِشا. 21‏:‏9؛ إِرْم. 8‏:‏22؛ أَسَا. 14‏:‏8؛ 18‏:‏2\x*   
\b  
\m
\v 9 ”نشِّينْ نخْسْ أَذْ نَاوِي أَڭنْفُو إِ بَابِيلْ، مَاشَا وَارْ غَارسْ أَڭنْفُو. جّمْ \add ثَانْذِينْثْ نِّي\add*، ؤُ أجّْ كُوڒْ  إِجّْ زَّايْنغْ أَذْ إِرَاحْ غَارْ ثمُّورْثْ نّسْ، مَاغَارْ ڒْحُوكْمْ خَاسْ يِيوضْ أَڒْ أَجنَّا، إِڭعّذْ أَڒْ إِسيْنُوثنْ.“\x ◘ \xo 51:‏9 \xt إِرْم. 46‏:‏11\x*   
\b  
\m
\v 10 ”سِيذِي إِسِّيوضْ-د ڒْمُوعْصِييّثْ نّغْ \add غَارْ ثْفَاوْثْ\add*. أَسمْ-د، أجّْ أَنغْ أَذْ نْعَاوذْ ذِي صِيهْيُونْ مِينْ إِڭَّا سِيذِي، أَربِّي نّغْ.“   
\b  
\m
\v 11 ”سْقضْعمْ فْڒِيثْشَاثْ، طّْفمْ ثِيسدَّارِييِينْ \add ن ؤُعسْكَارِي\add*. سِيذِي إِسّكَّارْ-د بُوحْبڒْ ن إِجدْجِيذنْ ن مَاذَايْ، مِينْزِي نتَّا إِعوّڒْ أَذْ إِهْذمْ بَابِيلْ، مَاغَارْ وَا ذ أَخْڒَافْ ن سِيذِي، أَخْڒَافْ إِ زَّاوشْثْ نّسْ ثَامقّْرَانْثْ. \x ◘ \xo 51:‏11 \xt إِرْم. 46‏:‏4؛ 50‏:‏28\x*  
\v 12 سْڭعّْذمْ ثَاعدْجَانْثْ خْ ڒحْيُوضْ ن بَابِيلْ، زيَّارمْ ثَاعسَّاسْثْ، سْبدّمْ إِعسَّاسنْ، ڭّمْ ڒفْخُوخْ، مَاغَارْ عْلَاحْسَابْ أَعوّڒْ ن سِيذِي، أَمُّو إِ غَا يڭّْ \add مَارَّا\add* مِينْ إِنَّا خْ إِمزْذَاغْ ن بَابِيلْ.  
\v 13 شمْ، أَ ثنِّي إِزدّْغنْ غَارْ مَانِي وسْعنْ وَامَانْ، ثنِّي غَارْ إِدْجَا وَاطَّاسْ ن وَاڭْڒَا، قطُّو نّمْ يِيوضْ-د، أَقَا إِشُّورْ ڒْقدّْ ن طّْمعْ نّمْ.  
\v 14 إِجُّودْجْ سِيذِي ن ڒْعسْكَارَاثْ غَارْ يِيخفْ نّسْ: وَاخَّا نشّْ شُّورغْ شمْ س إِوْذَانْ أَمْ ثْمُورْغِي، عَاذْ أَذْ خَامْ د-ڒَْاغَانْ س إِشْثْ ن ثْغُويِّيثْ ن ؤُسْڒِيوْڒوْ!“ \x ◘ \xo 51:‏14 \xt عَام. 6‏:‏8\x*   
\b  
\m
\v 15 ”نتَّا إِڭَّا ثَامُّورْثْ س جّْهذْ نّسْ، إِڭَّا دُّونشْثْ زِي ثِيغِيثْ نّسْ ؤُ إِبزّعْ أَجنَّا س ڒفْهَامثْ نّسْ. \x ◘ \xo 51:‏15 \xt أَمز. 1‏:‏1؛ أَيُوبْ 9‏:‏8؛ إِزهد. 104‏:‏2؛ إِشا. 40‏:‏22؛ 44‏:‏24؛ 51‏:‏13؛ إِرْم. 10‏:‏12\x*  
\v 16 ڒَامِي إِتّجَّا ثْمِيجَّا نّسْ أَذْ ت سْڒنْ، \add خنِّي ثڭَّا\add* أَمْ ؤُشَارْشُورْ ن وَامَانْ ذڭْ ؤُجنَّا. إِسيْنُوثنْ إِسّْڭعَّاذْ إِ-ثنْ زڭْ إِنڭُّورَا ن دُّونشْثْ، إِتّڭّْ أَسَّامنْ أَكْ-ذ ونْژَارْ ؤُشَا إِسّكَّا-د أَسمِّيضْ زڭْ إِخَّامنْ نّسْ ن ثْخُوبَايْ. \x ◘ \xo 51:‏16 \xt إِرْم. 10‏:‏13\x*  
\v 17 كُوڒْ بْنَاذمْ ذ أَڭَارُّوضْ، بْڒَا ثُوسّْنَا، كُوڒْ أَمْزِيڒْ ن وُورغْ إِتّْسضْحَا زِي سِّيبّثْ ن ڒخْيَاڒْ \add إِ إِڭَّا\add*، مَاغَارْ ڒخْيَاڒْ نّسْ إِفسْينْ ذ إِخَارِّيقنْ، وَارْ ذَايسْ \add إِدْجِي\add* بُوحْبڒْ.  
\v 18 أَقَا-ثنْثْ ذ \add لْ-أَصْنَامْ\add* إِبطّْڒنْ، أَقَا أَثنْثْ ذ ڒقْشُوعْ ن ثْسضْحَاشْثْ! ذِي ڒْوقْثْ ن وخْڒَافْ نْسنْثْ، أَذْ فْنَانْثْ.“   
\b  
\m
\v 19 ”ثَاسْغَارْثْ ن يَاعْقُوبْ وَارْ ثدْجِي أَمْ \add ثسْغَارْثْ\add* نْسنْثْ، مِينْزِي نتَّا ذ ونِّي إِڭِّينْ مَارَّا، ؤُشَا إِسْرَائِيل ذ ثَاقْبِيتْشْ ن ثسْغَارْثْ نّسْ، أَقَا سِيذِي ن ڒْعسْكَارَاثْ ذ إِسمْ نّسْ.“\x ◘ \xo 51:‏19 \xt إِرْم. 10‏:‏16\x*   
\b  
\m
\v 20 ”شكْ ثڭِّيذْ أَيِي أَمْ يِيجّْ ن شَّاقُورْ، ڒسْنَاحْ إِنُو إِ ؤُمنْغِي. زَّايكْ إِ غَا ڒبْزغْ ڒڭْنُوسْ، زَّايكْ إِ غَاغضْڒغْ ثِيڭلْذِيوِينْ. \x ◘ \xo 51:‏20 \xt إِرْم. 50‏:‏23\x*  
\v 21 زَّايكْ إِ غَا ڒبْزغْ أَيِيسْ ذ ونِّي خَاسْ إِنْيِينْ ؤُ زَّايكْ إِ غَا ڒبْزغْ أَكَارُّو ن ؤُمنْغِي ذ ونِّي ث إِندّْهنْ،  
\v 22 زَّايكْ إِ غَا ڒبْزغْ أَرْيَازْ ذ ثمْغَارْثْ، زَّايكْ إِ غَا ڒبْزغْ أَوسَّارْ ذ ؤُحُوضْرِي ؤُ زَّايكْ إِ غَا ڒبْزغْ أَبْڒِيغْ ذ ثبْڒِيغْثْ،  
\v 23 زَّايكْ إِ غَا ڒبْزغْ أَمكْسَاوْ ذ ثْحِيمَارْثْ نّسْ، زَّايكْ إِ غَا ڒبْزغْ أَفدْجَاحْ ذ زَّايْڒثْ نّسْ \add أَكْ-ذ إِينْذُوزنْ\add*، ؤُ زَّايكْ إِ غَا ڒبْزغْ لْوُولَاثْ ذ إِمْسيَّارنْ \add ن ثمُّورْثْ\add*،  
\v 24 \add مَاشَا\add* زَّاثْ إِ ثِيطَّاوِينْ نْومْ أَذْ خڒْفغْ نشّْ زِي بَابِيلْ ؤُ زِي مَارَّا إِمزْذَاغْ ن \add ثمُّورْثْ ن\add* إِكَالْذَانِييّنْ خْ مَارَّا ڒْغَارْ إِ ڭِّينْ ذِي صِيهْيُونْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ \f ◼ \fr 51:‏24 \ft \+bd ’إِمزْذَاغْ ن كَالْذِييَا‘\+bd* - نِيغْ ’إِكَالْذَانِييّنْ‘.\f*   
\m
\v 25 ”خْزَارْ، نشّْ أَذْ كِيذكْ د-ڒْْهِيغْ، \add شكْ\add* أَذْرَارْ ن وَاردّدْجْ، إِقَّارْ سِيذِي، شكْ ذ ونِّي يَاردّْدْجنْ مَارَّا ثَامُّورْثْ. نشّْ أَذْ خَاكْ د-سْوِيژّْضغْ أَفُوسْ إِنُو ؤُ أَذْ شكْ سّقْنُونّْيغْ زِي ڒجْرُوفْ ؤُ أَذْ شكْ ڭّغْ ذ أَذْرَارْ إِشمّْضنْ. \x ◘ \xo 51:‏25 \xt 2 إِج. 23‏:‏13\x*  
\v 26 عمَّارْصْ وَارْ زَّايكْ تَّاوْينْ \add عَاذْ\add* أَژْرُو إِ وژْرُو ن ثغْمَارْثْ ؤُڒَا ذ أَژْرُو إِ ذْسُوسَا، مَاغَارْ أَذْ ثْذوْڒذْ إِ ڒْخِيرْبَاثْ إِ ڒبْذَا، إِقَّارْ سِيذِي.“   
\m
\v 27 ”سْڭعّْذمْ ثَاعدْجَانْثْ ذِي ثمُّورْثْ، سُوضمْ ذڭْ ؤُيِيشّْ ن إِشَارِّي جَارْ ڒڭْنُوسْ، فَارْزمْ ڒڭْنُوسْ ضِيدّْ نّسْ، ڒَاغَامْ ضِيدّْ نّسْ إِ ثْڭلْذِيوِينْ ن أَرَارَاطْ، مِينِّي ذ أَشْكَانَازْ، ڭّمْ إِجّْ ن ڒْعسْكَارْ ضِيدّْ نّسْ، جّمْ إِيْسَانْ أَذْ فّْغنْ أَمْ \add إِجّْ ن ويْڒَافْ ن ثْمُوغْرِي\add* إِصَارّْضنْ إِقسْحنْ.  
\v 28 فَارْزمْ ڒڭْنُوسْ ضِيدّْ نّسْ، إِجدْجِيذنْ ن مَاذَايْ أَكْ-ذ لْوُولَاثْ نّسْ ذ مَارَّا إِمْسيَّارنْ نّسْ، مَارَّا ثَامُّورْثْ \add إِ خْ ثدْجَا\add* صُّولْطَا نّسْ.  
\v 29 \add خنِّي\add* أَذْ ثنْهزّْ ثمُّورْثْ ؤُشَا أَذْ ثْفَارْغْ سْ ڒحْرِيقْ، مِينْزِي إِنْوَاينْ ن سِيذِي بدّنْ نِيشَانْ مَاحنْذْ أَذْ أَرّنْ ثَامُّورْثْ ن بَابِيلْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ، وَارْ ذَايسْ إِزدّغْ \add عَاذْ\add* ؤُڒَا ذ إِجّْ.  
\v 30 أَيْثْ ن بُو-ثغْرُوضْثْ ن بَابِيلْ سمْحنْ ذڭْ ؤُمنْغِي، قِّيمنْ ذِي لْقلْعَاثْ نْسنْ. ثفْشڒْ ثْزمَّارْ نْسنْ، نِيثْنِي ذوْڒنْ ذ ثِيمْغَارِينْ. نِيثْنِي قّْذنْ إِ ثْزذِّيغِينْ نْسنْ ؤُشَا إِعُومَاذْ نْسنْ إِ ؤُبلّعْ تّْوَارْژنْ. \x ◘ \xo 51:‏30 \xt إِرْم. 50‏:‏37\x*  
\v 31 أَمْسَازَّاڒْ \add نِّي\add* خْ ؤُمْسَازَّاڒْ \add نّغْنِي\add* إِتَّازّڒْ-د، أَرقَّاسْ \add نِّي\add* خْ ؤُرقَّاسْ \add نّغْنِي\add*، حِيمَا أَذْ حَاجَانْ إِ ؤُجدْجِيذْ ن بَابِيلْ، أَقَا ثَانْذِينْثْ نّسْ ثتّْوَاطّفْ زِي مَارَّا إِغزْذِيسنْ،  
\v 32 أَقَا إِمُوشَانْ ن ؤُژكّْوُو تّْوَامنْعنْ، إِيَّارنْ ن ؤُغَانِيمْ تّْوَاشمْضنْ س ثْمسِّي ؤُشَا إِعسْكَارِييّنْ تّْوَانْهزّنْ.  
\v 33 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل: يدْجِيسْ ن بَابِيلْ ثڭَّا أَمْ ؤُنذْرَارْ، أَقَا ثِيوضْ-د ڒْوقْثْ حِيمَا أَذْ خَاسْعفْسنْ. عَاذْ ذْرُوسْ \add إِ إِقِّيمنْ\add*، \add خنِّي\add* ثِيوضْ-د ڒْوقْثْ ن ثْمجْرَا إِ نتَّاثْ.“   
\m
\v 34 ”نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، إِشَّا أَيِي، إِڒْبزْ أَيِي، إِڭَّا أَيِي ذ إِجّْ نْ وقْذِيحْ إِخْوَانْ، إِسَارْضْ أَيِي أَمْ ڒْهَايْشثْ، إِعمَّارْ أَعذِّيسْ نّسْ س ڒحْزُوثْ إِنُو ؤُشَا يُوژّڒْ خَافِي.  
\v 35 \add أجّْ أَذْ د-يَاسْ\add* خْ بَابِيلْ لْعُونْفْ إِ ذ أَيِي إِڭِّينْ ؤُ ذڭْ يِينِّي \add إِ إِدْجَانْ ذ\add* دَّاثْ إِنُو، \add أَمُّو إِ\add* ثقَّارْ ثنِّي إِزدّْغنْ ذِي صِيهْيُونْ. ’\add أجّْ أَذْ د-أَسنْ\add* إِذَامّنْ إِنُو خْ إِمزْذَاغْ ن \add ثمُّورْثْ ن\add* إِكَالْذَانِييّنْ \add أَمُّو إِ\add* ثقَّارْ ؤُرْشَالِيمْ.“   
\m
\v 36 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي: ’نشّْ سِيمَانْثْ إِنُو تّذْعِيغْ دّْعَاوِي نّمْ ؤُ أَذْ زَّايمْ خڒْفغْ. نشّْ أَذْ سِّيژْغغْ ڒبْحَارْ نّسْ ؤُ أَذْ جّغْ ثَاڒَا نّسْ أَذْ ثَاژغْ. \x ◘ \xo 51:‏36 \xt إِرْم. 50‏:‏38\x*  
\v 37 بَابِيلْ أَذْ ثذْوڒْ \add مْغِيرْ\add* ذ ڒْخِيرْبَاثْ، إِشْثْ ن ثْزذِّيغْثْ ن وُوشَّاننْ ن ڒخْڒَا، \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ ذ ؤُسمْژِي مَاحنْذْ وَارْ \add ذَايسْ إِتّْغِيمِي\add* إِزدّغْ \add عَاذْ\add* ؤُڒَا ذ إِجّنْ.‘ “   
\m
\v 38 ”مَارَّا إِذْسنْ أَذْ زهَّارنْ أَمْ وَايْرَاذنْ، أَذْ سّْمِيعّْرِيونْ أَمْ وَايْرَاذنْ إِمژْيَاننْ.  
\v 39 خْمِي غَا يِيڒِينْ حْمَانْ، أَذْ سَّارْسغْ زَّاثْسنْ ثَاسسِّيثْ نْسنْ. نشّْ أَذْ ثنْ سّسْشَارغْ أَڒْ غَا ذوّْخنْ ؤُشَا أَذْ طّْصنْ إِضصْ ن ڒبْذَا،عمَّارْصْ أَذْ فَاقنْ \add عَاذْ\add*، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 40 نشّْ أَذْ ثنْ د-سّهْوِيغْ أَمْ يِيزمْرَاونْ غَارْ ثْغَارْصْثْ، أَمْ يِيشَارِّييّنْ أَكْ-ذ إِغَايْضنْ.  
\v 41 مَامّشْ إِتّْوَاطّفْ شِيشَاكْ ؤُ \add مَامّشْ\add* إِتّْوَاطّفْ ڒْعزّْ ن مَارَّا ثَامُّورْثْ! مَامّشْ ثذْوڒْ \add ثنْذِينْثْ ن\add* بَابِيلْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ جَارْ ڒڭْنُوسْ! \x ◘ \xo 51:‏41 \xt إِشا. 13‏:‏19؛ إِرْم. 25‏:‏26\x*  
\v 42 إِڭعّذْ-د ڒبْحَارْ خْ \add ثنْذِينْثْ ن\add* بَابِيلْ، س ؤُبَارُّو ن ڒمْوَاجْ نّسْ ثتّْوَاذڒْ نتَّاثْ.  
\v 43 ثِيندَّامْ نّسْ ذوْڒنْثْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ، \add ثَامُّورْثْ ثذْوڒْ ذ\add* ثَامُّورْثْ يُوژْغنْ ذ ثْنزْرُوفْثْ ذ إِشْثْ ن ثمُّورْثْ مَانِي وَارْ إِزدّغْ \add عَاذْ\add* ؤُڒَا ذ إِجّْ ؤُ مَانِي وَارْ إِتّْشُوقِي ؤُڒَا ذ إِجّْ ن مِّيسْ ن بْنَاذمْ.  
\v 44 نشّْ أَذْ خڒْفغْ زِي بِيلْ ذِي بَابِيلْ، أَذْ كّْسغْ زِي ثْمِيجَّا نّسْ مِينْ ثُوغَا إِسَارْضْ. ڒڭْنُوسْ وَارْ غَارسْ تَّازّْڒنْ عَاذْ. عَاذْ ڒْحِيضْ ن بَابِيلْ أَذْ إِوْضَا.“   
\m
\v 45 ”فّغْ زَّايسْ، \add أَ\add* ڒْڭنْسْ إِنُو، أجّْ كُوڒْ إِجّْ أَذْ إِسّنْجمْ ثُوذَارْثْ نّسْ زِي ڒْحَاذُوقْ ن وغْضَابْ ن سِيذِي.  
\v 46 مَاڒَا لَّا خنِّي أَذْ ضعْفنْ وُوڒَاونْ نْومْ ؤُشَا أَذْ ڭّْوذنْ زِي ڒخْبَارْ نِّي إِ غَا سْڒنْ ذِي ثمُّورْثْ، مَاغَارْ إِجّْ ن ڒخْبَارْ أَذْ إِتّْوَاسڒْ ذڭْ إِجّْ ن ؤُسڭّْوَاسْ ؤُشَا أَوَارْنِي إِ يِيجّْ ن ؤُسڭّْوَاسْ \add نّغْنِي\add* أَذْ د-يَاسْ إِجّْ ن ڒخْبَارْ \add نّغْنِي\add*. أَذْ ذِينْ يِيڒِي لْعُونْفْ ذِي ثمُّورْثْ، \add إِجّْ ن\add* ڒْحَاكمْ أَذْ د-إِكَّارْ خْ إِجّْ ن ڒْحَاكمْ \add نّغْنِي\add*.“   
\m
\v 47 ”س ؤُينِّي خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ نِّي ذِي غَا خڒْفغْ زِي بَابِيلْ زِي سِّيبّثْ ن ڒخْيَاڒَاثْ إِنقْشنْ ؤُشَا مَارَّا ثَامُّورْثْ نّسْ أَذْ ثنّفْضحْ ؤُ مَارَّا إِنِّي إِتّْوَانْغنْ أَذْ وْضَانْ ذِي ڒْوسْطْ نّسْ.  
\v 48 أَجنَّا ذ ثمُّورْثْ ذ مَارَّا مِينْ ذَايْسنْ أَذْ سْڒِيوڒْونْ خْ بَابِيلْ. مَاغَارْ أَذْ غَارسْ د-أَسنْ إِمْثحَّايّنْ زِي شَّامَالْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 49 أَمْ مَامّشْ ثُوغَا بَابِيلْ ذ سِّيبّثْ ن ؤُوطُّو ن يِينِّي إِتّْوَانْغنْ ن إِسْرَائِيل، \add أَمُّو\add* إِ غَا وْضَانْ مَارَّا إِنِّي إِتّْوَانْغنْ زِي مَارَّا ثَامُّورْثْ غَارْ \add ثنْذِينْثْ ن\add* بَابِيلْ.“   
\b  
\m
\v 50 ”\add كنِّيوْ\add*، إِنِّي إِنجْمنْ إِ سِّيفْ، فّْغمْ، وَارْ سْبدَّامْ إِخفْ نْومْ! خمّمْ-د زِي ڒَاڭّْوَاجْ ذِي سِيذِي ؤُ جّمْ ؤُرْشَالِيمْ أَذْ د-ثَاسْ غَارْ ڒْبَاڒْ نْومْ. \f ◼ \fr 51:‏50 \ft \+bd ’غَارْ ڒْبَاڒْ نْومْ‘\+bd* - س ثْعِيبْرَانِيثْ ’غَارْ وُوڒَاونْ نْومْ‘.\f*  
\v 51 نشِّينْ نْسضْحَا، مَاغَارْ نسْڒَا خْ ؤُسحْقَارْ، ثزْوغْ ن ڒحْيَا ثذْڒَا أَغمْبُوبْ نّغْ، مَاغَارْ إِبَارَّانِييّنْ ڭعّْذنْ خْ ثْزَاوِييِّينْ إِقدّْسنْ ن ثَادَّارْثْ ن سِيذِي.“   
\b  
\m
\v 52 ”س ؤُيَا خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، نشّْ أَذْ خڒْفغْ زِي ڒخْيَاڒَاثْ نّسْ إِنقْشنْ ؤُشَا ذِي مَارَّا ثَامُّورْثْ نّسْ أَذْ تّْوَازْبَارنْ إِنِّي إِتّْوَانْغنْ.  
\v 53 وَاخَّا مَاڒَا \add ثَانْذِينْثْ ن\add* بَابِيلْ ثْڭعّذْ أَڒْ أَجنَّا، وَاخَّا ثڭَّا لْبَارَاجْ نّسْ إِجهْذنْ يُوعْڒَانْ أَڒْ مَانِي وَارْ يِيوِيضْ ؤُڒَا ذ إِجّْ، وَاخَّا أَمنِّي أَذْ غَارسْ د-أَسنْ إِمْثحَّاينْ زَّايِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\b  
\m
\v 54 ”\add إِفّغْ-د\add* ڒْحسّْ ن ثْغُويِّيثْ ثَامقّْرَانْثْ زِي بَابِيلْ، \add أَمشْنَاوْ\add* ن إِشْثْ ن لْمُوصِيبَا ذ ثَامقّْرَانْثْ زِي ثمُّورْثْ ن إِكَالْذَانِييّنْ.  
\v 55 مَاغَارْ سِيذِي إِڭَّا أَذْ إِخَارّبْ بَابِيلْ ؤُ أَذْ إِقْضَا خْ دّْرِيزْ نّسْ أَمقّْرَانْ، مِينْزِي ڒمْوَاجْ نْسنْ أَذْ زهَّارنْ أَمْ وَامَانْ إِمقّْرَاننْ، دّْرِيزْ ن ؤُزهَّارْ نْسنْ أَذْ إِتّْوَاسڒْ.  
\v 56 مِينْزِي أَذْ خَاسْ د-أَسنْ إِمْثحَّاينْ، خْ بَابِيلْ، ؤُشَا تّْوَاحبّْسنْ أَيْثْ ن بُو-ثغْرُوضْثْ نّسْ، ڒقْوَاسْ نْسنْ أَذْ تّْوَارْژنْ، مَاغَارْ سِيذِي أَقَا-ث ذ أَربِّي ن وخْڒَافْ، أَذْ \add زَّايسْ\add* إِخْڒفْ نِيشَانْ.“   
\m
\v 57 ”أَذْ سّسْشَارغْ ڒْحُوكَّامْ نّسْ ذ إِمِيغِيسنْ نّسْ ذ لْوُولَاثْ نّسْ ذ إِمْسيَّارنْ نّسْ ذ أَيْثْ ن بُو-ثغْرُوضْثْ نّسْ ؤُشَا نِيثْنِي أَذْغضْصنْ ذڭْ يِيضصْ ن ڒبْذَا ؤُعمَّارْصْ أَذْ فَاقنْ، \add أَمُّو إِ\add* إِقَّارْ ؤُجدْجِيذْ، سِيذِي ن ڒْعسْكَارَاثْ ذ إِسمْ نّسْ.“  
\v 58 أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: ”أَذْ أَرّنْ ڒحْيُوضْ إِمِيرِيونْ ن بَابِيلْ أَذْ سضْحَانْ أَطَّاسْ ؤُشَا ثِيوُّورَا نّسْ يُوعْڒَانْ أَذْ \add ثنْثْ\add* قدّنْ س ثْمسِّي. ڒڭْنُوسْ أَذْ أَحْڒنْ بَاطڒْ ؤُ شُّوعُوبْ سِّيحْڒنْ إِخفْ نْسنْ ذِي طّْوعْ ن ثْمسِّي.“   
\b  
\m
\v 59 أَوَاڒْ نِّي يُومُورْ ؤُنَابِي إِرْمِييَا إِ سَارَايَا، مِّيسْ ن نِيرِي-يَاهْ، مِّيسْ ن مَاحْسِييَّا، ؤُمِي وَانِيثَا يُويُورْ زِي صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، غَارْ بَابِيلْ، ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعَا ن ڒحْكَامثْ نّسْ. ثُوغَا سَارَايَا ذ ڒْحَاكمْ خْ ڒْمَارْڭحْ ن ڒْعسْكَارْ.   
\m
\v 60 إِرْمِييَا يُورَا مَارَّا ڒْغَارْ إِ د غَا يَاسنْ خْ بَابِيلْ ذڭْ إِجّْ ن وذْلِيسْ إِتّْوَانّْضنْ، مَارَّا أَوَاڒنْ نِّي إِتّْوَارِينْ خْ بَابِيلْ.  
\v 61 \add خنِّي\add* إِنَّا إِرْمِييَا إِ سَارَايَا: ”خْمِي د غَا ثَاسذْ غَارْ بَابِيلْ، خْزَارْ مَامّشْ غَا ثڭّذْ أَذْ ثْبَارّْحذْ س مَارَّا أَوَاڒنْ-أَ،  
\v 62 أَذْ ثِينِيذْ: ’\add أَ\add* سِيذِي، شكْ سِيمَانْثْ نّشْ ثقَّارذْ خْ ومْشَانْ-أَ بلِّي أَذْ \add زَّايسْ\add* ثكّْسذْ إِمزْذَاغْ، مَاحنْذْ وَارْ ذَايسْ إِزدّغْ \add عَاذْ\add* ؤُڒَا ذ إِجّْ، ڒَا بْنَاذمْ ؤُڒَا ذ ڒْمَاڒْ، ؤُ بلِّي \add أَمْشَانْ-أَ\add* أَذْ يِيڒِي ذ إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ!‘  
\v 63 خْمِي إِ غَا ثْكمّْڒذْ زڭْ ؤُغَارِي ن وذْلِيسْ إِتّْوَانّْضنْ، أَذْ غَارسْ ثقّْنذْ إِجّْ ن وژْرُو، أَذْ ث ثنْضَارذْ ذِي ڒْوسْطْ ن \add يغْزَارْ ن\add* لْفُورَاطْ.  
\v 64 أَذْ ثِينِيذْ: ’أَمُّو إِ غَا ثْغبَّا \add ثنْذِينْثْ ن\add* بَابِيلْ ؤُ وَارْ ثْڭِيعِّيذْ \add عَاذْ\add* زِي سِّيبّثْ نْ ڒْغَارْ إِ خَاسْ د-سّهْوِيغْ. نِيثْنِي أَذْ سْڒَاونْ.‘ “ أَڒْ ذَا إِ يِيوْضنْ وَاوَاڒنْ ن إِرْمِييَا. \x ◘ \xo 51:‏64 \xt أَسَا. 18‏:‏21\x*   
\b  
\b  
\m  
\c 52
\s1 أَشْثَابْ ن ؤُرْشَالِيمْ  
\m
\v 1 صِيذْقِييَا \add ثُوغَا\add* غَارسْ وَاحِيثْ ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ حِيطَاشْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ حَامُوثَالْ، يدْجِيسْ ن إِرْمِييَا زِي لِيبْنَا. \x ◘ \xo 52:‏1 \xt 2 إِج. 24‏:‏18\x*  
\v 2 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، نِيشَانْ أَمْ مَامّشْ ث إِڭَّا يَاهُويَاقِيمْ.  
\v 3 مَاغَارْ أَخيّقْ ن سِيذِي ثُوغَا يَارْسَا خْ ؤُرْشَالِيمْ ذ يَاهُوذَا، أَڒَامِي ثنْ إِنْضَارْ زِي زَّاثْ ن وُوذمْ نّسْ. \add خنِّي\add* ثُوغَا صِيذْقِييَا إِغوّغْ خْ ؤُجدْجِيذْ ن بَابِيلْ.   
\m
\v 4 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثسْعَا ن ڒحْكَامثْ نّسْ، ذڭْ وَاسّْ وِيسّْعشْرَا ن ؤُيُورْ وِيسّْعشْرَا، إِفّغْ-د نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، س مَارَّا ڒْعسْكَارْ نّسْ غَارْ ؤُرْشَالِيمْ، نِيثْنِي نّْضنْ أَسْ-د ؤُشَا قوَّارنْ أَسْ س جّهْذْ غَارْ مَارَّا إِغزْذِيسنْ نّسْ. \x ◘ \xo 52:‏4 \xt 2 إِج. 25‏:‏1؛ إِرْم. 39‏:‏1\x*  
\v 5 أَمُّو إِ ثتّْوَاحْسَارْ ثنْذِينْثْ أَڒْ أَسڭّْوَاسْ وِيسّْ حِيطَاشْ ن ؤُجدْجِيذْ صِيذْقِييَا.  
\v 6 ذڭْ ؤُيُورْ وِيسّْ أَربْعَا، ذڭْ وَاسّْ وِيسّْ ثسْعَا ن ؤُيُورْ، ڒَامِي إِذْوڒْ ڒَاژْ إِمقَّارْ ذِي ثنْذِينْثْ ؤُشَا ڒْڭنْسْ ن ثمُّورْثْ وَارْ غَارسْ إِقِّيمْ بُو وغْرُومْ \add عَاذْ\add*،  
\v 7 أَقَا ثتّْوَارْژْ ثنْذِينْثْ ؤُ مَارَّا إِعسْكَارِييّنْ أَروْڒنْ، فّْغنْ س دْجِيڒثْ خْ وبْرِيذْ ن ثوَّارْثْ \add إِ إِدْجَانْ\add* جَارْ ثْنَاينْ ن ڒحْيُوضْ نِّي \add إِدْجَانْ\add* غَارْ وحْوِيشْ ن ؤُجدْجِيذْ، \add ؤُمِي\add* إِكَالْذَانِييّنْ ثُوغَا قُووَّارنْ إِ ثنْذِينْثْ. ؤُشَا أَجدْجِيذْ يُويُورْ خْ وبْرِيذْ ن ڒوْضَا.  
\v 8 ڒْعسْكَارْ ن إِكَالْذَانِييّنْ إِضْفَارْ أَجدْجِيذْ ؤُشَا نِيثْنِي حَارْثنْ خْ صِيذْقِييَا ذِي ڒْوَاطَاثْ ن أَرِيحَا. مَارَّا ڒْعسْكَارْ نّسْ تّْوَاسّبْضَانْ خَاسْ.  
\v 9 نِيثْنِي طّْفنْ أَجدْجِيذْ ؤُشَا إِوْينْ ث غَارْ نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، غَارْ رِيبْلَا ذِي ثمُّورْثْ ن حَامَاثْ ؤُشَا وَانِيثَا إِحْكمْ خَاسْ.  
\v 10 أَجدْجِيذْ ن بَابِيلْ إِنْغَا إِحنْجِيرنْ ن صِيذْقِييَا زَّاثْ إِ طِّيثَاوِينْ نّسْ. ؤُڒَا ذ مَارَّا ڒْحُوكَّامْ ن يَاهُوذَا إِنْغَا إِ-ثنْ ذِي رِيبْلَا.  
\v 11 إِسّْذَارْغڒْ ثِيطَّاوِينْ ن صِيذْقِييَا ؤُشَا إِقّنْ إِ-ث س ثْنَاينْ ن سّْنَاسڒْ ن نّْحَاسْ. \add أَمُّو\add* إِ ث يِيوِي ؤُجدْجِيذْ ن بَابِيلْ غَارْ بَابِيلْ ؤُشَا إِڭَّا إِ-ث ذِي ڒحْبسْ أَڒْ أَسّْ ؤُمِي إِمُّوثْ.   
\m
\v 12 ذڭْ ؤُيُورْ وِيسّْ خمْسَا، ذڭْ وَاسّْ وِيسّْعشْرَا ن ؤُيُورْ - ثُوغَا أَسڭّْوَاسْ ذ أَسڭّْوَاسْ وِيسّْ ثْسعْطَاشْ ن ؤُجدْجِيذْ نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ - خْمِي د-يُوسَا نابُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ ونِّي ثُوغَا إِسخَّارْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ن بَابِيلْ، غَارْ ؤُرْشَالِيمْ، \f ◼ \fr 52:‏12 \ft \+bd ’إِسخَّارْ‘\+bd* - س ثْعِيبْرَانِيثْ ’إِبدّْ‘.\f*  
\v 13 إِسَّارْغْ نتَّا ثَادَّارْثْ ن سِيذِي ذ ثَادَّارْثْ ن ؤُجدْجِيذْ ذ مَارَّا ثُوذْرِينْ ن ؤُرْشَالِيمْ ذ مَارَّا ثُوذْرِينْ ن إِمْشنّْعنْ إِسَّارْغْ إِ-ثنْثْ \add عَاوذْ\add* س ثْمسِّي.  
\v 14 مَارَّا ڒْعسْكَارْ ن إِكَالْذَانِييّنْ، إِنِّي د-يُوسِينْ أَكْ-ذ ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، أَقَا أَرْژِينْ مَارَّا ڒحْيُوضْ ن ؤُرْشَالِيمْ إِ ذ أَسْ د-إِنّْضنْ.  
\v 15 إِمزْڒَاضْ قَاعْ ن ڒْڭنْسْ ذ مِينْ إِشطّنْ ن ڒْڭنْسْ نِّي إِتّْوَاجّنْ ذِي ثنْذِينْثْ ذ إِنِّي إِفّْغنْ غَارْ ؤُجدْجِيذْ ن بَابِيلْ ؤُشَا ذوْڒنْ غَارسْ ؤُڒَا ذ مِينْ إِشطّنْ ن ڒْغَاشِي، إِنْذهْ إِ-ثنْ نبُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، ذِي لْمنْفَا.  
\v 16 \add مَاشَا\add* زڭْ إِمزْڒَاضْ ن ثمُّورْثْ إِجَّا نبُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، إِجّْ ن ذْرُوسْ أَمْ يِيمڒْقَاضْ ن ثْزَايَارْثْ ؤُ أَمْ يِيفدْجَاحنْ.   
\m
\v 17 \add ؤُشَا\add* أَرْژِينْ إِكَالْذَانِييّنْ إِپِيلَارنْ ن نّْحَاسْ ذِي ثَادَّارْثْ ن سِيذِي، ثِيكَارُّوثِينْ ذ ثْرِيمَانْثْ ن نّْحَاسْ \add إِ ثُوغَا إِدْجَانْ\add* ذِي ثَادَّارْثْ ن سِيذِي ؤُشَا كْسِينْ مَارَّا نّْحَاسْ أَكِيذْسنْ غَارْ بَابِيلْ. \f ◼ \fr 52:‏17 \ft \+bd ’ثَارِيمَانْثْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒبْحَارْ‘ نِيغْ ’إِلْ‘.\f*  \x ◘ \xo 52:‏17 \xt إِرْم. 27‏:‏19\x*  
\v 18 ؤُڒَا ذ ثِييْذُورِينْ ذ إِغنْجَاينْ ذ ثْجقَّاضِينْ ذ طَّاوْيَاثْ إِ ؤُرُوشِّي ذ ثْغنْجَايِينْ ذ مَارَّا ڒقْشُوعْ ن نّْحَاسْ إِ زِي تّْسخَّارنْ، كْسِينْ ثنْ.  
\v 19 أَمُّو إِ إِكْسِي ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ طّْبَاصَا ذ طَّاوْيَاثْ إِ ؤُرُوشِّي ذ ثيْذُورِينْ ذ ڒقْنَاذڒْ ذ ثْغنْجَايِينْ ذ ڒْكِيسَانْ، \add مَارَّا\add* مِينْ ثُوغَا إِدْجَانْ ن وُورغْ قَاعْ نِيغْ ن نُّوقَارْثْ قَاعْ.  
\v 20 \add خْ\add* ثْنَاينْ ن إِپِيلَارنْ ذ ثْرِيمَانْثْ ذ ثنْعَاشْ ن إِفُونَاسنْ ن نّْحَاسْ نِّي ثُوغَا \add إِدْجَانْ\add* سَاذُو نّسْ ؤُڒَا خْ ثْكَارُّوثِينْ نِّي إِڭَّا ؤُجدْجِيذْ إِ ثَادَّارْثْ ن سِيذِي: أَقَا نّْحَاسْ ن مَارَّا ڒقْشُوعْ-أَ وَارْ زمَّارنْ أَذْ وزْننْ \add مَارَّا أَيَا\add*.  
\v 21 \add خْ\add* إِپِيلَارنْ: ثُوغَا ڒُوعْڒَا ن إِجّْ ن ؤُپِيلَارْ ذَايسْ ثْمنْطَاشْ ن إِغَادْجنْ ؤُشَا إِجّْ ن ؤُفِيڒُو ن \add ڒعْبَارْ\add* ن ثنْعَاشْ ن إِغَادْجنْ إِزمَّارْ أَذْ أَسْ إِنّضْ. ثُوغَا ڒْڭذْرَانْ نّسْ ذَايسْ أَربْعَا ن إِضوْضَانْ ؤُشَا \add غَارْ ذَاخڒْ\add* ثُوغَا-ث إِخْوَا.\x ◘ \xo 52:‏21 \xt 1 إِج. 7‏:‏15؛ 2 إِج. 25‏:‏17؛ 2 إِم. 3‏:‏15\x*  
\v 22 تَّاجْ سنّجْ نّسْ \add ثُوغَا-ث\add* ن نّْحَاسْ. ڒُْوعْڒَا ن إِجّْ ن تَّاجْ ثُوغَا خمْسَا ن إِغَادْجنْ ؤُ خْ تَّاجْ \add ثُوغَا خَاسْ\add* ثْرَاشَّا ذ ثْرمَّامِينْ إِ ذ أَسْ د-إِنّْضنْ. ثُوغَا مَارَّا ن نّْحَاسْ. أَمْ ثُوغَا وَانِيثَا، أَمُّو ثُوغَا ؤُڒَا ذ أَپِيلَارْ نّغْنِي ذ ثْرمَّانِينْ نّسْ.  
\v 23 ثِيرمَّانِينْ ثُوغَا أَثنْثْ ذِي ستَّا ؤُ-ثسْعِينْ غَارْ مَارَّا إِغزْذِيسنْ ن ؤُسمِّيضْ. مَارَّا ثِيرمَّانِينْ ثُوغَا أَثنْثْ ذِي مْيَا خْ ثْرَاشَّا إِ ذ أَسْ د-إِنّْضنْ.   
\m
\v 24 ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ يِيوِي-د أَكِيذسْ ؤُڒَا ذ أَكهَّانْ أَمقّْرَانْ سَارَايَا، أَكهَّانْ وِيسّْ ثْنَاينْ صَافَانْيَا ذ ثْڒَاثَا ن إِعسَّاسنْ ن ثوَّارْثْ. \f ◼ \fr 52:‏24 \ft \+bd ’صَافَانْيَا‘\+bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي ث إِسّْنُوفَّارنْ سِيذِي‘.\f*  
\v 25 زِي ثنْذِينْثْ إِكْسِي نتَّا إِجّْ ن ؤُمْسخَّارْ أَمْشنّعْ ونِّي ثُوغَا خْ إِعسْكَارِييّنْ، ڒَا ذ سبْعَا ن يرْيَازنْ نِّي إِزمَّارنْ أَذْ ژَترنْ ؤُذمْ ن ؤُجدْجِيذْ ذ يِينِّي إِتّْوَافنْ ذِي ثنْذِينْثْ، ڒَا ذ أَمَارِيرْ ن ؤُكُومَانْذَارْ ن ڒْعسْكَارْ نِّي ثُوغَا إِزمّنْ ڒْڭنْسْ ن ثمُّورْثْ إِ ؤُمنْغِي، ؤُڒَا ذ ستِّينْ ن يرْيَازنْ زِي ڒْڭنْسْ ن ثمُّورْثْ نِّي إِتّْوَافنْ ذِي ڒْوسْثْ ن ثنْذِينْثْ.  
\v 26 نبُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، إِطّفْ إِ-ثنْ ؤُشَا يِيوِي ثنْ غَارْ ؤُجدْجِيذْ ن بَابِيلْ، غَارْ رِيبْلَا.  
\v 27 أَجدْجِيذْ ن بَابِيلْ إِوْثَا إِ-ثنْ ؤُشَا إِنْغَا إِ-ثنْ ذِي رِيبْلَا، ذِي ثمُّورْثْ ن حَامَاثْ. \add أَمُّو إِ\add* إِتّْوَانْذهْ يَاهُوذَا زِي ثمُّورْثْ نّسْ غَارْ لْمنْفَا.   
\b  
\m
\v 28 وَا ذ ڒْڭنْسْ نِّي إِنْذهْ نابُوخَاذْرَاصَّارْ ذِي لْمنْفَا:  
\m ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا \add إِنْذهْ\add* ثڒْثْ-أَڒَافْ ؤُ-ثْڒَاثَا ؤُ-عِيشْرِينْ ن أَيْثْ ن يَاهُوذَا.   
\m
\v 29 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْمنْطَاشْ ن نابُوخَاذْرَاصَّارْ، يِيوِي ثمْنمْ-مْيَا ؤُ-ثْنَاينْ ؤُ-ثْڒَاثِينْ ن إِوْذَانْ زِي ؤُرْشَالِيمْ.   
\m
\v 30 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا ؤُ-عِيشْرِينْ ن نابُوخَاذْرَاصَّارْ إِنْذهْ نبُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، سبْعَا-مْيَا ؤُ-خمْسَا ؤُ-ربْعِينْ ن أَيْثْ ن يَاهُوذَا غَارْ لْمنْفَا.  
\m مَارَّا \add جْمِيعْ\add* ثُوغَا أَثنْ ذِي أَربْعَا-أَڒَافْ ؤُ-ستَّا-مْيَا ن إِوْذَانْ. \f ◼ \fr 52:‏30 \ft \+bd ’إِوْذَانْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒعْمُورْ‘.\f*   
\b  
\m  
\s1 أَجدْجِيذْ يَاهُويَاكِينْ إِتَّافْ ڒْخَاضَارْ ذِي ثِيطَّاوِينْ ن ؤُجدْجِيذْ ن بَابِيلْ  
\m
\v 31 ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا ؤُ-ثْڒَاثِينْ ن ثْمحْبَاسْثْ ن يَاهُويَاكِينْ، أَجدْجِيذْ ن يَاهُوذَا، ذڭْ ؤُيُورْ وِيسّْ ثنْعَاشْ، ذڭْ وَاسّْ وِيسّْ خمْسَا ؤُ-عِيشْرِينْ ن ؤُيُورْ، إِسّْڭعّذْ أَوِيلْ-مَارُوذَاخْ، أَجدْجِيذْ ن بَابِيلْ، ذڭْ ؤُسڭّْوَاسْ أَمزْوَارُو ن ثْڭلْذَا نّسْ، أَزدْجِيفْ ن يَاهُويَاكِينْ، أَجدْجِيذْ ن يَاهُوذَا، ؤُشَا إِسُّوفّغْ إِ-ث-إِ-د زِي ڒحْبسْ. \x ◘ \xo 52:‏31 \xt 2 إِج. 25‏:‏27‏-‏30\x*  
\v 32 نتَّا إِعْذڒْ أَكِيذسْ، إِوْشَا أَسْ ڒْكُورْسِي نّسْ ثِيوَا إِ ڒكْرَاسِي ن إِجدْجِيذنْ نّغْنِي إِنِّي ثُوغَا غَارسْ ذِي بَابِيلْ.  
\v 33 إِسَّارْسْ يَاهُويَاكِينْ أَرُّوضْ نّسْ ن ڒحْبسْ ؤُشَا إِذْوڒْ إِتّتّْ غَارسْ، مِينْ إِكَّا إِدَّارْ.  
\v 34 خْ ڒْمعْثقْ نّسْ: ڒبْذَا إِمّوْشْ أَسْ ڒْمعْثقْ نّسْ س ؤُفُوسْ ن ؤُجدْجِيذْ ن بَابِيلْ، كُوڒْ أَسّْ مِينْ د-إِكَّارنْ ن وَاسّْ نِّي أَڒْ أَسّْ ن ڒْموْثْ نّسْ، مِينْ إِكَّا إِدَّارْ. \f ◼ \fr 52:‏34 \ft \+bd ’مِينْ إِكَّا إِدَّارْ‘\+bd* - س ثْعِيبْرَانِيثْ ’مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّسْ‘.\f*   