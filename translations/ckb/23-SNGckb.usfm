\id SNG - Biblica® Open Kurdi Sorani Standard Version 
\h گۆرانی گۆرانییەکان 
\toc1 گۆرانی گۆرانییەکان 
\toc2 گۆرانی گۆرانییەکان 
\toc3 گۆرانی گۆرانییەکان 
\mt1 گۆرانی گۆرانییەکان 
\c 1  
\p  
\v 1 گۆرانی گۆرانییەکانی سلێمان. 
\sp ئەویندار\f + \fr 1:1 \ft وشەی ئەویندار بۆ کچ بەکارهاتووە.‏\f* 
\q1  
\v 2 با بە ماچەکانی دەمی ماچم بکات، 
\q2 چونکە ئەوینی تۆ لە شەراب خۆشترە. 
\q1  
\v 3 بۆنی عەترەکەت خۆشە؛ 
\q2 ناوت عەتری پرژاوە، 
\q2 مایەی سەرسوڕمانی نییە کە پاکیزەکان تۆیان خۆشدەوێ. 
\q1  
\v 4 پەلم بگرە و با پێکەوە بڕۆین! 
\q2 با پاشا بمهێنێتە ناو ژوورەکەی خۆی. 
\sp دەستەخوشکەکان 
\q1 شاد و دڵخۆش دەبین پێت، 
\q2 لە شەراب زیاتر یادی ئەوینی تۆ دەکەینەوە. 
\sp ئەویندار 
\q1 بەڕاستی تۆیان خۆشدەوێ. 
\b  
\q1  
\v 5 ئەی کچانی ئۆرشەلیم، 
\q2 من ئەسمەرێکی جوانم، 
\q2 وەک ڕەشماڵەکانی قێدار، 
\q2 وەک نێوبەندی ڕەشماڵەکانی سلێمان. 
\q1  
\v 6 تەماشام مەکەن کە من ئەسمەرم، 
\q2 ئەوە خۆر لێیداوم. 
\q1 کوڕانی دایکم لە من تووڕە بوون، 
\q2 منیان کردە چاودێری ڕەزەمێو، 
\q2 لەبەر ئەوەی ناچار کرام، چاودێری ڕەزەمێوەکەم نەکرد. 
\q1  
\v 7 ئەی خۆشەویستی گیانم، پێم بڵێ، 
\q2 لەکوێ مێگەلی خۆت دەڵەوەڕێنیت، 
\q2 کاتی نیوەڕۆش پشتیری مەڕەکانت لەکوێیە؟ 
\q1 بۆچی وەک پەچەکراوێک بم، 
\q2 لەلای مێگەلی هاوڕێیەکانت؟ 
\sp دەستەخوشکەکان 
\q1  
\v 8 ئەی جوانترینی نێو ئافرەتان، ئەگەر نازانیت 
\q2 بە شوێن پێی مەڕاندا بڕۆ و 
\q1 کارەبزنەکانت بلەوەڕێنە 
\q2 لەلای نشینگەی شوانەکان. 
\sp دڵدار\f + \fr 1:8 \ft وشەی دڵدار بۆ کوڕ بەکارهاتووە.‏\f* 
\q1  
\v 9 یارەکەم، بە ئەسپێک لە گالیسکەکانی فیرعەون 
\q2 لێکم چوواندی، 
\q1  
\v 10 گۆنات بە خشڵەوە جوانە، 
\q2 گەردنت بە گەردانەوە. 
\q1  
\v 11 خشڵی زێڕت بۆ دەکەین، 
\q2 لەگەڵ نقێمی زیو. 
\sp ئەویندار 
\q1  
\v 12 هەتا پاشا لە کۆڕی خۆیەتی، 
\q2 ناردینی من بۆنی خۆی بڵاو دەکاتەوە. 
\q1  
\v 13 دڵدارەکەم چەپکێک موڕە 
\q2 کە لەنێو مەمکەکانم شەو بەسەردەبات. 
\q1  
\v 14 دڵدارەکەم هێشووی خەنەیە 
\q2 لەناو ڕەزەمێوەکانی کانی گەدی. 
\sp دڵدار 
\q1  
\v 15 ئەی یارەکەم، تۆ چەند جوانیت، 
\q2 چەند جوانیت! 
\q2 چاوەکانت کۆترن. 
\sp ئەویندار 
\q1  
\v 16 ئەی دڵدارەکەم، تۆش چەند قۆزیت، 
\q2 چەند شیرینیت! 
\q2 جێگاکەمان سەوزە. 
\sp دڵدار 
\q1  
\v 17 کاریتەی خانووەکەمان لە داری ئورزە، 
\q2 تەختەدارەکانی سەروون. 
\c 2  
\sp ئەویندار 
\q1  
\v 1 من گوڵاڵە سوورەی شارۆن و 
\q2 سەوسەنی دۆڵانم. 
\sp دڵدار 
\q1  
\v 2 وەک گوڵی سەوسەن لەناو دڕکوداڵ 
\q2 یارەکەم ئاوایە لەناو کچان. 
\sp ئەویندار 
\q1  
\v 3 وەک دار سێو لەنێو دارەکانی دارستان 
\q2 دڵدارەکەم ئاوایە لەناو کوڕان. 
\q1 حەزم لە دانیشتنە لە سێبەرەکەی 
\q2 مێوەکەشی بۆ دەمم شیرینە. 
\q1  
\v 4 با بمباتە هۆڵی خوانەکە، 
\q2 خۆشەویستییەکەی وەک ئاڵا لەسەر سەرم بشەکێتەوە. 
\q1  
\v 5 بە کشمیش گڕوتینم پێ ببەخشن، 
\q2 بە سێو بمگەشێننەوە، 
\q2 چونکە من بە شەیدای خۆشەویستی ئەوم. 
\q1  
\v 6 دەستی چەپی لەژێر سەرمە و 
\q2 دەستی ڕاستی لە ئامێزم دەگرێت. 
\q1  
\v 7 ئەی کچانی ئۆرشەلیم، سوێندتان دەدەم، 
\q2 بە مامز یان مێینەی ئاسکی دەشتودەر، 
\q1 کە خۆشەویستی هەڵنەستێنن و بە ئاگای نەهێنن 
\q2 هەتا خۆی حەز دەکات. 
\b  
\q1  
\v 8 گوێ بگرە! ئەوە دەنگی دڵدارەکەمە! 
\q2 تەماشا بکە! وا دێت، 
\q1 لەسەر چیاکان هەڵدەبەزێتەوە، 
\q2 بەسەر گردەکاندا باز دەدات. 
\q1  
\v 9 دڵدارەکەم وەک ئاسک یان وەک کارمامزە، 
\q2 وا لە پشت دیوارەکەمان ڕاوەستاوە، 
\q1 لە دەلاقەوە سەیر دەکات، 
\q2 لە کڵاوڕۆژنەوە\f + \fr 2:9 \ft وەک پەنجەرەیە، دەلاقەیەکە بۆ هاتوچۆی هەوا و گەڕانەوەی تیشکی خۆر.‏\f* تەماشا دەکات. 
\q1  
\v 10 دڵدارەکەم قسەی کرد، پێی گوتم: 
\q2 «یارەکەم، هەستە، 
\q2 شیرینەکەم، وەرە. 
\q1  
\v 11 تەماشا بکە، زستان تێپەڕی، 
\q2 باران بەسەرچوو و نەما. 
\q1  
\v 12 گوڵ لەسەر زەوی دەرکەوت، 
\q2 ئێستا کاتی گۆرانییە؛ 
\q1 خوێندنی کوکوختی 
\q2 لە خاکی ئێمە دەبیسترێت. 
\q1  
\v 13 هەنجیر بەری گرتووە، 
\q2 بۆنی بەرسیلەی مێو بڵاو بووەتەوە. 
\q1 یارەکەم، هەستە، 
\q2 شیرینەکەم، وەرە.» 
\sp دڵدار 
\q1  
\v 14 ئەی کۆترەکەم لەناو کەلەبەری هەڵدێرەکان، 
\q2 لە پەناگای بنارەکان، 
\q1 با ڕوخسارت ببینم، 
\q2 با دەنگت ببیستم، 
\q1 چونکە دەنگت ناسکە و 
\q2 ڕوخسارت شیرینە! 
\q1  
\v 15 ڕێوییەکانمان بۆ ڕاو بکەن، 
\q2 ئەو توولە ڕێوییانەی 
\q1 ڕەزەکانمان تێکدەدەن، 
\q2 چونکە ڕەزەکانمان پەسیرەیان گرتووە. 
\sp ئەویندار 
\q1  
\v 16 دڵدارەکەم بۆ منە و منیش بۆ ئەوم، 
\q2 لەناو گوڵە سەوسەنەکان دەلەوەڕێت. 
\q1  
\v 17 بەر لەوەی ڕۆژ هەڵبێت و 
\q2 تاریکی بڕەوێتەوە، 
\q1 ئەی دڵدارەکەم، بگەڕێوە، 
\q2 وەک ئاسک بە، 
\q1 یان کارمامز 
\q2 لەسەر چیا فرە لووتکەکان. 
\b  
\c 3  
\q1  
\v 1 بە درێژایی شەو لەسەر نوێنەکەم 
\q2 بەدوای ئەو کەسەدا گەڕام کە گیانم خۆشی دەوێت؛ 
\q2 بەدوایدا گەڕام، بەڵام نەمدۆزییەوە. 
\q1  
\v 2 ئێستا هەڵدەستم و بەناو شاردا دەسووڕێمەوە، 
\q2 بەناو شەقام و گۆڕەپانەکاندا 
\q1 بەدوای ئەو کەسەدا دەگەڕێم کە گیانم خۆشی دەوێت. 
\q2 ئیتر بەدوایدا گەڕام، بەڵام نەمدۆزییەوە. 
\q1  
\v 3 تووشی ئێشکگرەکان بووم، 
\q2 کاتێک بەناو شاردا دەگەڕان. 
\q2 «ئایا ئەوەی گیانم خۆشی دەوێت ئێوە نەتانبینیوە؟» 
\q1  
\v 4 ئەوەندەی نەمابوو لێیان تێپەڕم 
\q2 کاتێک ئەوەم بینییەوە کە گیانم خۆشی دەوێت. 
\q1 گرتم و بەرمنەدا، 
\q2 هەتا بردمە ماڵی دایکم، 
\q2 بۆ ژووری ئەو کەسەی کە بە من سکپڕ ببوو. 
\q1  
\v 5 ئەی کچانی ئۆرشەلیم، سوێندتان دەدەم 
\q2 بە مامز یان مێینەی ئاسکی دەشتودەر، 
\q1 کە خۆشەویستی هەڵنەستێنن و بە ئاگای نەهێنن 
\q2 هەتا خۆی حەز دەکات. 
\b  
\q1  
\v 6 ئەوە کێیە لە چۆڵەوانییەوە بەدەرکەوت، 
\q2 وەک ستوونی دووکەڵ، 
\q1 بە موڕ و بخوور بۆنخۆش کراوە، 
\q2 بە هەموو بۆنوبەرامێکی بازرگانان؟ 
\q1  
\v 7 ببینن! گالیسکەکەی سلێمانە، 
\q2 شەست پاڵەوان دەوریان داوە 
\q2 لە پاڵەوانەکانی ئیسرائیل، 
\q1  
\v 8 هەموو شمشێر بەدەستن، 
\q2 شارەزای جەنگن، 
\q1 هەریەکە و شمشێرەکەی بە لاڕانیەوەیە، 
\q2 لەبەر مەترسییەکانی شەو. 
\q1  
\v 9 سلێمانی پاشا گالیسکەیەکی بۆ خۆی دروستکرد 
\q2 لە داری لوبنان. 
\q1  
\v 10 ستوونەکانی لە زیو دروستکرد، 
\q2 کاریتەکانی لە زێڕ. 
\q1 بەرگی دۆشەکەکان ئەرخەوانییە، 
\q2 ناوەوەی بە ئەوین ڕازێنراوەتەوە. 
\q1 ئەی کچانی ئۆرشەلیم،  
\v 11 وەرنە دەرەوە، 
\q2 ئەی کچانی سییۆن، ببینن. 
\q1 سلێمانی پاشا بەو تاجەوە ببینن کە لەسەریەتی، 
\q2 کە دایکی لەسەری نا 
\q1 لە ڕۆژی زەماوەندی ژنهێنانی، 
\q2 لە ڕۆژی شادی دڵی. 
\c 4  
\sp دڵدار 
\q1  
\v 1 ئەی یارەکەم، تۆ چەند جوانیت، 
\q2 چەند جوانیت! 
\q2 چاوەکانت دوو کۆترن لە پشت پەچەکەتەوە. 
\q1 قژت وەک مێگەلە بزنە 
\q2 کە لە کێوی گلعادەوە دێتە خوارەوە. 
\q1  
\v 2 ددانەکانت وەک ڕانە مەڕن، 
\q2 کە تازە بڕاونەتەوە و لە شوشتن گەڕاونەتەوە، 
\q1 هەموویان جووتن، 
\q2 هیچیان بە تەنها نین. 
\q1  
\v 3 لێوەکانت وەک ڕیسی ئاڵە، 
\q2 دەمت شیرینە، 
\q1 گۆنات وەک لەتە هەنارە 
\q2 لە پشت پەچەکەتەوە. 
\q1  
\v 4 گەردنت وەک قوللەی داودە 
\q2 بە ڕیزە بەرد بنیاد نراوە، 
\q1 هەزار قەڵغانی پێوە هەڵواسراوە، 
\q2 هەمووی قەڵغانی پاڵەوانانە. 
\q1  
\v 5 جووتە مەمکەکەت وەک دوو کارمامزن، 
\q2 وەک جووتێک مامزن، 
\q2 کە لەنێو گوڵە سەوسەندا دەلەوەڕێن. 
\q1  
\v 6 بەر لەوەی ڕۆژ هەڵبێت و 
\q2 تاریکی بڕەوێتەوە، 
\q1 دەچمە چیای موڕ و 
\q2 گردی بخوور. 
\q1  
\v 7 ئەی یارەکەم، سەرتاپات جوانییە، 
\q2 هیچ کەموکوڕیت تێدا نییە. 
\b  
\q1  
\v 8 بووکێ، لەگەڵ من لە لوبنانەوە وەرە، 
\q2 لەگەڵ من لە لوبنانەوە وەرە. 
\q1 لە لووتکەی چیای ئەماناوە وەرە خوارەوە، 
\q2 لە سەری سنیرەوە کە لووتکەی حەرمۆنە، 
\q1 لە لانەی شێرانەوە، 
\q2 لە چیای پڵنگانەوە. 
\q1  
\v 9 ئازیزەکەم، بووکێ، دڵی منت ڕفاندووە، 
\q2 بە تیلەی چاوت دڵت ڕفاندووم، 
\q2 بە موورووێکی ملوانکەکەت. 
\q1  
\v 10 ئەوینت چەند جوانە، بووکی ئازیزم، 
\q2 ئەوینت چەند لە شەراب خۆشترە، 
\q2 بۆنی عەترەکەشت لە هەموو بۆنوبەرامێک. 
\q1  
\v 11 لێوەکانت شانەی هەنگوینیان لێ دەتکێت، بووکێ، 
\q2 شیر و هەنگوین لەژێر زمانتە! 
\q2 بۆنی جلوبەرگت وەک بۆنی لوبنانە. 
\q1  
\v 12 باخچەیەکی داخراوە! بووکی ئازیزم، 
\q2 سەرچاوەیەکی داخراوە، کانییەکی مۆرکراوە! 
\q1  
\v 13 نەمامەکانت باخی هەنارن 
\q2 لەگەڵ بەروبوومی هەڵبژاردە، 
\q2 خەنە و ناردین، 
\q2  
\v 14 ناردین و کارکۆم\f + \fr 4:14 \ft ئەو گوڵەیە کە ڕەگەکەی زەردەچەوەی لێ دروستدەکرێت.‏\f*، 
\q2 قامیشی بۆنخۆش و دارچین، 
\q2 لەگەڵ هەموو جۆرە دار بخوورێک، 
\q2 موڕ و ئەلوا\f + \fr 4:14 \ft ڕووەکێکی دڕکاوییە وەک سەباڕ، شلەیەکی تێدایە بۆ پێست باشە.‏\f* 
\q2 لەگەڵ هەموو بۆنوبەرامەکان. 
\q1  
\v 15 تۆ سەرچاوەی باخچەکانیت، 
\q2 بیری ئاوی لەبەر ڕۆیشتووی، 
\q2 لێشاوە لە لوبنان دێتە خوارێ. 
\sp ئەویندار 
\q1  
\v 16 هەستە، ئەی بای باکوور، 
\q2 وەرە، ئەی بای باشوور! 
\q1 بەسەر باخچەکەم هەڵبکەن، 
\q2 با بۆنوبەرامی بڵاوبێتەوە، 
\q1 بۆ ئەوەی دڵدارەکەم بێتە ناو باخچەکەی خۆی، 
\q2 با بەروبوومە هەڵبژاردەکەی تام بکات. 
\c 5  
\sp دڵدار 
\q1  
\v 1 هاتمە ناو باخچەکەم، ئازیزم، بووکێ، 
\q2 موڕ و بۆنوبەرامی خۆمم کۆکردەوە، 
\q1 شانەی هەنگوین و هەنگوینی خۆمم خوارد، 
\q2 شەراب و شیری خۆمم خواردەوە. 
\sp هاوڕێیەکان 
\q1 ئەی هاوڕێیان، بخۆن و بخۆنەوە؛ 
\q2 یاران، بە ئەوین مەست بن. 
\sp ئەویندار 
\q1  
\v 2 من خەوتووم، بەڵام دڵم بێدارە! 
\q2 دەنگی دڵدارەکەمە لە دەرگا دەدات: 
\q1 «دەرگام بۆ بکەرەوە، دڵداری ئازیزم، 
\q2 ئەی کۆترەکەم، ئەی بێ کەموکوڕییەکەم، 
\q1 سەرم پڕ ئاونگ بووە، 
\q2 ئەگریجەم پڕ شەونم.» 
\q1  
\v 3 جلەکانم داکەندووە، 
\q2 ئایا دەبێ دیسان لەبەری بکەمەوە؟ 
\q1 پێیەکانم شوشتووە، 
\q2 ئایا دەبێ دیسان پیسیان بکەمەوە؟ 
\q1  
\v 4 دڵدارەکەم لە کونی دەرگاوە دەستی درێژکرد، 
\q2 هەناوم بۆی ڕاچەنی. 
\q1  
\v 5 هەستام هەتا دەرگا لە دڵدارەکەم بکەمەوە، 
\q2 دەستەکانم موڕیان لێ دەچۆڕا، 
\q1 پەنجەکانم موڕی شل 
\q2 لەسەر دەسکی سورگییەکە. 
\q1  
\v 6 دەرگام بۆ دڵدارەکەم کردەوە، 
\q2 بەڵام دڵدارەکەم بایدابووەوە و ڕۆیشتبوو. 
\q2 گیانم بەدوای ئەودا دەرچوو، 
\q1 بەدوایدا گەڕام، بەڵام نەمدۆزییەوە. 
\q2 بانگم کرد، وەڵامی نەدامەوە. 
\q1  
\v 7 تووشی ئێشکگرەکان بووم 
\q2 کاتێک بەناو شاردا دەسووڕانەوە. 
\q1 لێیان دام و برینداریان کردم، 
\q2 چارۆکەکەیان لەبەر داکەندم، 
\q2 ئێشکگری شووراکان 
\q1  
\v 8 ئەی کچانی ئۆرشەلیم، سوێندتان دەدەم، 
\q2 ئەگەر تووشی دڵدارەکەم بوون، 
\q1 ئەمەی پێ بڵێن، 
\q2 من بە شەیدای خۆشەویستی ئەوم. 
\sp دەستەخوشکەکان 
\q1  
\v 9 دڵدارەکەی تۆ چی زیاترە لە دڵداران، 
\q2 ئەی جوانی نێو ئافرەتان؟ 
\q1 دڵدارەکەی تۆ چی زیاترە لە دڵداران، 
\q2 کە ئاوا سوێندت داین؟ 
\sp ئەویندار 
\q1  
\v 10 دڵدارەکەم سوور و گەشاوەیە، 
\q2 لەناو دە هەزار کەسدا دیارە. 
\q1  
\v 11 سەری زێڕی بێگەردە، 
\q2 زولفی بەرداوەتەوە، 
\q2 ڕەشە وەک قەلەڕەش. 
\q1  
\v 12 چاوەکانی وەک کۆترن 
\q2 چاوەکانی وەک کۆترن لەسەر کانییەک، 
\q1 کۆترەکان هێندە سپین وەکو شیر، 
\q2 لە کەناری حەوزێک هەڵنیشتوون. 
\q1  
\v 13 گۆناکانی وەک باخچەی بۆندارن، 
\q2 بۆنیان خۆشە. 
\q1 لێوەکانی سەوسەنن، 
\q2 موڕی شلیان لێ دەتکێت. 
\q1  
\v 14 دەستەکانی لوولەی زێڕن، 
\q2 بە زەبەرجەد ڕازاونەتەوە، 
\q1 لەشی عاجی تاشراوە 
\q2 بە بەردی یاقووتی شین\f + \fr 5:14 \ft یاقووتی شین: دەشێت لاجیوەرد بێت.‏\f* پێچراوەتەوە. 
\q1  
\v 15 قاچەکانی ستوونی مەڕمەڕن، 
\q2 لەسەر دوو بنکەی زێڕی بێگەرد دامەزراون. 
\q1 ڕوخساری وەک لوبنانە، 
\q2 هەڵبژاردە وەک ئورز. 
\q1  
\v 16 دەمی شیرینە، 
\q2 سەراپای خۆشەویستە. 
\q1 ئەمە دڵدارەکەمە، ئەو ئازیزی منە، 
\q2 ئەی کچانی ئۆرشەلیم! 
\c 6  
\sp دەستەخوشکەکان 
\q1  
\v 1 دڵدارەکەت چووە کوێ، 
\q2 ئەی جوانی نێو ئافرەتان؟ 
\q1 دڵدارەکەت ڕووی لەکوێ کرد، 
\q2 هەتا لەگەڵت بەدوایدا بگەڕێین؟ 
\sp ئەویندار 
\q1  
\v 2 دڵدارەکەم دابەزییە ناو باخچەکەی، 
\q2 بۆ ناو باخچەی بۆندار، 
\q1 هەتا مێگەلی خۆی لەناو باخچەکاندا بلەوەڕێنێت و 
\q2 سەوسەن کۆبکاتەوە. 
\q1  
\v 3 من بۆ دڵدارەکەمم و دڵدارەکەم بۆ منە، 
\q2 لەناو گوڵە سەوسەنەکان دەلەوەڕێت. 
\sp دڵدار 
\q1  
\v 4 یارەکەم تۆ وەک شانشینی تیرزە جوانی، 
\q2 وەک ئۆرشەلیم شیرینی، 
\q2 وەک لەشکرە ئاڵادارەکان شکۆداری. 
\q1  
\v 5 چاوەکانت لەسەر من لابدە، 
\q2 چونکە بەرگەی ناگرم. 
\q1 قژت وەک ڕانە بزنە 
\q2 کە لە کێوی گلعادەوە دێتە خوارەوە. 
\q1  
\v 6 ددانەکانت وەک ڕانە مەڕن 
\q2 کە لە شوشتن گەڕاونەتەوە، 
\q1 هەموویان جووتن، 
\q2 هیچیان بە تەنها نین. 
\q1  
\v 7 گۆنات وەک لەتە هەنارە 
\q2 لە پشت پەچەکەتەوە. 
\q1  
\v 8 شەست شاژنن و 
\q2 هەشتا کەنیزەن، 
\q2 پاکیزەکانیش لە ژمارە نایەن، 
\q1  
\v 9 بەڵام کۆترەکەم، بێگەردەکەم، بێ وێنەیە، 
\q2 کچە تاقانەی دایکییەتی، 
\q2 نازدارەکەی ئەوەی بوویەتی. 
\q1 کچ بینییان خۆزگەیان پێ خواست 
\q2 شاژنەکان و کەنیزەکان ستایشیان کرد. 
\sp دەستەخوشکەکان 
\q1  
\v 10 ئەوە کێیە سەری هەڵهێنا وەک بەرەبەیان، 
\q2 جوانە وەک مانگ، بێگەردە وەک ڕۆژ، 
\q2 وەک کەژاوەی ئەستێرەکان شکۆدارە؟ 
\sp ئەویندار 
\q1  
\v 11 بۆ ناو باخی دار گوێز دابەزیم 
\q2 بۆ بینینی دەرکەوتنی گیای دۆڵ، 
\q1 بۆ ئەوەی ببینم ئاخۆ دار مێو چەکەرەی کردووە، 
\q2 هەناریش پشکوتووە؟ 
\q1  
\v 12 پێش ئەوەی بزانم، 
\q2 گیانم لەناو گالیسکەکانی پاشایەتی گەلەکەم داینام. 
\sp دەستەخوشکەکان 
\q1  
\v 13 ئەی شولەمیتی\f + \fr 6:13 \ft ناوی ناوچەیە.‏\f*، بگەڕێوە، بگەڕێوە! 
\q1 بگەڕێوە، بگەڕێوە، بۆ ئەوەی تەماشات بکەین! 
\sp دڵدار 
\q1 بۆچی تەماشای شولەمیت دەکەن 
\q2 وەک سەمای مەحەنەیم\f + \fr 6:13 \ft مەحەنەیم: ناوی شارێک بوو لە ڕۆژهەڵاتی ڕووباری ئوردون. بڕوانە \xt پەیدابوون 32‏:2‏\ft ‏.‏\f*؟ 
\b  
\c 7  
\q1  
\v 1 ئەی کچە میر، 
\q2 پێیەکانت لەناو پێڵاو چەندە جوانن! 
\q1 کەوانی ڕانت وەک خشڵە 
\q2 دەستکردی دەستی وەستای کارامەیە. 
\q1  
\v 2 ناوکت جامێکی خڕە 
\q2 شەرابی تێکەڵاوی لێ کەم ناکات، 
\q1 ناوقەدت خەرمانی گەنمە 
\q2 بە سەوسەن پەرژین کراوە. 
\q1  
\v 3 جووتە مەمکەکەت وەک دوو کارمامزن، 
\q2 وەک جووتێک مامزن. 
\q1  
\v 4 گەردنت قوللەیەکی عاجە. 
\q1 چاوەکانت وەک گۆمن لە حەشبۆن 
\q2 لەبەردەم دەروازەی بەت ڕەبیم. 
\q1 لووتت وەک قوللەی لوبنانە 
\q2 ڕووەو دیمەشق دەڕوانێت. 
\q1  
\v 5 سەرت وەک کێوی کارمەلە بەسەرتەوە و 
\q2 پرچی سەرت ئەرخەوانییە، 
\q2 پاشا بەندی ئەگریجەکانە. 
\q1  
\v 6 چەند جوان و چەند شیرینیت، 
\q2 ئەی ئەویندارەکەم، من بە تۆ دڵشادم! 
\q1  
\v 7 ئەم بەژنەت لە دار خورما دەچێت، 
\q2 مەمکەکانت لە هێشوو. 
\q1  
\v 8 گوتم: «بەسەر دار خورما دەکەوم، 
\q2 خۆم بە بەرهەمەکەی دەگرم.» 
\q1 با مەمکەکانت وەک هێشووە ترێ بن، 
\q2 بۆنی هەناسەت وەک سێو بێت، 
\q2  
\v 9 دەمت وەک باشترین جۆری شەراب بێت. 
\sp ئەویندار 
\q1 با شەرابەکە بە ئاسانی بۆ دڵدارەکەم بڕژێت، 
\q2 بە نەرمی بەسەر لێو و دداندا بڕوات. 
\q1  
\v 10 من بۆ دڵدارەکەمم و 
\q2 ئەو پەرۆشی منە. 
\q1  
\v 11 دڵدارەکەم، وەرە با بچینە کێڵگە، 
\q2 لە گوندەکان شەو بەسەرببەین. 
\q1  
\v 12 با بەیانی زوو بگەینە سەر ڕەزەمێوەکان، 
\q2 ببینین ئاخۆ دار مێو چەکەرەی کردووە، 
\q1 پەسیرەکان کراونەتەوە، 
\q2 هەناریش پشکوتووە؟ 
\q2 لەوێ ئەوینەکەمت پێ دەبەخشم. 
\q1  
\v 13 گیائادەمە\f + \fr 7:13 \ft بڕوانە \xt پەیدابوون 30‏:14‏-16.‏\ft ‏\f* بۆن بڵاو دەکاتەوە، 
\q2 لە بەردەرگاکەشمان هەموو میوەیەکی بەتام هەیە، 
\q1 کۆن و نوێ 
\q2 کە بۆ تۆم هەڵگرتووە، ئەی دڵدارەکەم. 
\b  
\c 8  
\q1  
\v 1 بریا برای من بووای، 
\q2 شیرەخۆری مەمکی دایکم! 
\q1 ئەوا لە دەرەوە تووشت دەهاتم و ماچم دەکردیت، 
\q2 بەبێ ئەوەی ڕیسوا بم. 
\q1  
\v 2 دەمبردیت، 
\q2 دەمبردیتە ماڵی دایکم، 
\q2 ئەوەی منی پەروەردە کردووە. 
\q1 شەرابی تێکەڵاوم دەرخوارد دەدای، 
\q2 لە خۆشاوی هەنارەکەم. 
\q1  
\v 3 دەستی چەپی لەژێر سەرمە و 
\q2 دەستی ڕاستی لە ئامێزم دەگرێت. 
\q1  
\v 4 ئەی کچانی ئۆرشەلیم، سوێندتان دەدەم 
\q2 کە خۆشەویستی هەڵنەستێنن و بە ئاگای نەهێنن 
\q2 هەتا خۆی حەز دەکات. 
\sp دەستەخوشکەکان 
\q1  
\v 5 ئەو کچە کێیە لە چۆڵەوانییەوە دێت و 
\q2 پاڵی بە دڵدارەکەیەوە داوە؟ 
\sp ئەویندار 
\q1 لەژێر دار سێوەکە بەئاگام هێنای، 
\q2 لەوێ دایکت بە تۆ سک پڕ بوو، 
\q2 لەوێ ئەوەی تۆی بوو سکی پێت پڕ بوو. 
\q1  
\v 6 بمکە مۆر لەسەر دڵت، 
\q2 مۆر لەسەر بازووت، 
\q1 چونکە خۆشەویستی وەک مردن بەهێزە، 
\q2 ئیرەیی وەک گۆڕ سەختە، 
\q1 خۆشەویستی سووتێنەرە، گڕی ئاگرە، 
\q2 وەک ئاگرێکی بەهێزە. 
\q1  
\v 7 ئاوە زۆرەکان ناتوانن خۆشەویستی بکوژێننەوە، 
\q2 ڕووبارەکان نوقومی ناکەن. 
\q1 ئەگەر مرۆڤ هەموو سامانی ماڵەکەی 
\q2 لە پێناوی خۆشەویستی ببەخشێت، 
\q2 بە بێبەها دادەنرێت. 
\sp دەستەخوشکەکان 
\q1  
\v 8 خوشکێکی بچووکمان هەیە، 
\q2 هێشتا مەمکی نەهاتووە. 
\q1 چی بکەین بۆ خوشکمان، 
\q2 ئەو ڕۆژەی داخوازیکەری بێت؟ 
\q1  
\v 9 ئەگەر شوورا بێت، 
\q2 قوللەی زیوین لەسەری بنیاد دەنێین. 
\q1 ئەگەر دەرگا بێت، 
\q2 بە تەختەداری ئورز دەوری دەدەین. 
\sp ئەویندار 
\q1  
\v 10 من شوورام و 
\q2 مەمکەکانم وەک قوللەن، 
\q1 بەم جۆرە لە چاوەکانی 
\q2 پەسەندی بەدی دەکەم. 
\q1  
\v 11 سلێمان ڕەزەمێوێکی هەبوو لە بەعل‌هامۆن، 
\q2 ئەم ڕەزەمێوی دایە ڕەزەوانان، 
\q1 هەریەکە و لەبری بەرهەمەکەی 
\q2 هەزار شاقل\f + \fr 8:11 \ft نزیکەی 11,5 کیلۆگرام.‏\f* زیوی دەدا. 
\q1  
\v 12 بەڵام ڕەزەمێوەکەی خۆم بە ویستی خۆمە بیبەخشم؛ 
\q2 ئەی سلێمان، هەزار شاقل بۆ تۆ بێت، 
\q2 دوو سەد شاقلیش\f + \fr 8:12 \ft دوو سەد شاقل نزیکەی 2,3 کیلۆگرام.‏\f* بۆ ڕەزەوانەکان. 
\sp دڵدار 
\q1  
\v 13 ئەی دانیشتووی ناو باخچەکان! 
\q2 هاوڕێیان گوێیان لە دەنگت گرتووە، 
\q2 با گوێم لێت بێت. 
\sp ئەویندار 
\q1  
\v 14 ڕابکە، دڵدارەکەم، 
\q2 وەک ئاسک بە 
\q1 یان وەک کارمامز 
\q2 لەسەر ئەو چیایانەی پڕ بۆنوبەرامن.