\v 16 \w God|strong="G2532"\w* wanted \w me|strong="G1473"\w* \w to|strong="G2443"\w* \w go|strong="G2532"\w* \w and|strong="G2532"\w* tell \w the|strong="G1722"\w* message \w about|strong="G1722"\w* \w Jesus|strong="G2532"\w* \w to|strong="G2443"\w* \w the|strong="G1722"\w* \w people|strong="G1484"\w* \w that|strong="G2443"\w* \w are|strong="G3588"\w* \w not|strong="G3756"\w* Jews. \w So|strong="G2443"\w* \w he|strong="G2532"\w* showed \w Jesus|strong="G2532"\w* \w to|strong="G2443"\w* \w me|strong="G1473"\w*, \w and|strong="G2532"\w* \w he|strong="G2532"\w* told \w me|strong="G1473"\w* \w all|strong="G2532"\w* \w about|strong="G1722"\w* \w him|strong="G3588"\w*. \w Then|strong="G2532"\w* \w I|strong="G1473"\w* \w believed|strong="G3588"\w* \w in|strong="G1722"\w* \w Jesus|strong="G2532"\w*. \w God|strong="G2532"\w* told \w me|strong="G1473"\w* \w that|strong="G2443"\w* message, \w so|strong="G2443"\w* \w I|strong="G1473"\w* didn’\w t|strong="G3588"\w* ask anybody \w else|strong="G2532"\w* \w about|strong="G1722"\w* \w it|strong="G2532"\w*.\x * \xo 1:16 \xt Acts 9:3-6; 22:6-10; 26:13-18\x*  
\v 17 \w I|strong="G1473"\w* didn’\w t|strong="G3588"\w* \w go|strong="G1519"\w* \w to|strong="G1519"\w* \w Jerusalem|strong="G2414"\w* \w to|strong="G1519"\w* talk \w to|strong="G1519"\w* \w the|strong="G2532"\w* \w men|strong="G3588"\w* \w that|strong="G3588"\w* \w were|strong="G3588"\w* \w Jesus|strong="G2532"\w*’s special workers \w before|strong="G4253"\w* \w I|strong="G1473"\w* \w was|strong="G3588"\w*. Instead \w of|strong="G2532"\w* \w that|strong="G3588"\w*, \w I|strong="G1473"\w* \w went|strong="G2532"\w* straight \w away|strong="G5290"\w* \w to|strong="G1519"\w* \w the|strong="G2532"\w* country \w called|strong="G3588"\w* Arabia. \w Then|strong="G2532"\w* later \w I|strong="G1473"\w* \w went|strong="G2532"\w* \w back|strong="G3825"\w* \w to|strong="G1519"\w* \w the|strong="G2532"\w* city \w called|strong="G3588"\w* \w Damascus|strong="G1154"\w*.   
\p
