\p \w Now|strong="H3212"\w* \w the|strong="H7200"\w* \w famine|strong="H7458"\w* \w was|strong="H7458"\w* \w severe|strong="H2389"\w* \w in|strong="H3212"\w* \w Samaria|strong="H8111"\w*.  
