\id MRK - SYN- Siyin Bible 
\h MARK 
\toc1 MARK 
\toc2 Mark 
\toc3 Mk 
\mt1 MARK  
\mt2 MARK  
\c 1  
\s1 Jesus Lamsialsak John  
\r Matt. 3:1-12; Lk. 3:1-18; Jn. 1:19-28  
\p
\v 1 Pathian Tapa Jesus Christ lungdamna thu a kipatna in;   
\p
\v 2 Kamsang te in a sonkholsa bangma in, en vun, na pai natu lampi a pua tu in, ka kamtaipa na mai ah sawl khi hi.   
\p
\v 3 Senneal ngam sungah a au aw khat in, Topa lampi puakhol vun a, tangsak vun, ci hi.   
\p
\v 4 John in senneal ngam ah tuiphumna pia a, mawmaisakna tu in ki sikkik na tuiphumna thu tangko hi.   
\p
\v 5 Jerusalem le Judah ngam theampo pan in mi tampi te John kungah hongpai uh a, amate mawna te pualak in Jordan ngun ah tui ki phum tek uh hi.   
\p
\v 6 John sia kala-uk mul taw a ki tak puan sil a, a kawng sia savun kawngkhau taw kil hi; khaumaw le khuaitui te ne hi;   
\p
\v 7 Ka nung pan hongpai pa sia kei sang in thahat zaw a, kei ka hile kun in a peangdap khau sutsak tu in zong ka kiphu bua hi:   
\p
\v 8 Keima in tui taw tuiphumna kong pia hi: ahizong Ama in Tha Thiangtho taw tuiphumna hong pia tu hi, ci in pualak hi.   
\s1 John in Jesus Tuiphum  
\r Matt. 3:13-17; Lk. 3:21, 22  
\p
\v 9 Tuazawkciang in, Jesus sia Galilee ngam Nazareth pan hongpai in, John in Jordan ngun ah tuiphumna pia hi.   
\p
\v 10 Jesus tuisung pan a thawto pociang, van hong ki hong in, Thaa sia vakhu bang in a tungah hong tuaksuk John in mu hi:   
\p
\v 11 Van pan in aw khat hong nging a, Nangma sia ka it ka Tapa na hihi, Na tungah ka lungkim mama hi, ci hi.   
\s1 Jesus Ze-et na  
\r Matt. 4:1-11; Lk. 4:1-13  
\p
\v 12 Tuazawk pociang in, Thaa in Jesus sia senneal ngam ah paisak hi.   
\p
\v 13 Tua senneal ngam ah ni sawm li om a, Satan in ze-et hi; senneal ngam sung ngamsa te taw omkhawm a; vantung mite in khoi hi.   
\s1 Jesus Nasep Kipan  
\r Matt. 4:12-17; Lk. 5:14, 15  
\p
\v 14 John thong a tak zawkciang in Jesus Galilee ah pai a, Pathian kumpingam lungdamna thuhil hi.   
\p
\v 15 \wj A hun hong cing zo a, Pathian kumpingam hong nai zo hi, na mawna uh kisik vun a, lungdamna thu um vun, \wj* ci hi.   
\s1 Nungzui Masa Te A Sapna  
\r Matt. 4:18-22; Lk. 5:1-11  
\p
\v 16 Jesus Galilee tuili hui ah a pai laitak in Simon le a suapuipa Andrew sia tuili sungah ngenpai in a om laitak mu hi:   
\p
\v 17 Jesus in amate tung ah, \wj Ka nung hong zui tavun, mihing man te kong suaksak tu hi, \wj* ci hi.   
\p
\v 18 Taciang amate in thakhatthu in a ngen te nusia in, a nungzui uh hi.   
\p
\v 19 A khuala hiat na mun a thet uh ciang in Zebedee tapa James le John te u nau ngunkuang sungah ngen a phaw uh laitak mu hi.   
\p
\v 20 Jesus in a mu pociang in sam a; amate zong ngunkuang sungah a pa Zebedee le a naseam te nusia in a nung zui uh hi.   
\s1 Jesus in Doai Ngilo Hawlkhia  
\r Lk. 4:31-37  
\p
\v 21 Amate Capernaum khua ah pai uh a; sabbath ni hong thet pociang synagogue sungah tum in, thuhil hi.   
\p
\v 22 Amate in a hil na lamdangsa tek uh hi: banghangziam cile thukhamhil te bang in hil ngawl in, thunei te khat bang in hil hi.   
\p
\v 23 Amate synagogue sungah doai ngilo vei pasal khat om a,   
\p
\v 24 Nang Nazareth mi Jesus, hong om nginge sak po tan; nang taw bang sep tu nei khu ziam? hong susia tu in hongpai hi ngawl ni ziam? Nangma in Pathian mithiangtho ni hi, ci hong he khi hi, ci au hi.   
\p
\v 25 Tasiaciang Jesus in ama tei a, \wj Om nginge po in a, hisia pa sung pan pusuak in, \wj* ci hi.   
\p
\v 26 Doai ngilo in tuapa huangsak vadil a, a nging tatak a au zawkciang, a sung pan pusuak hi.   
\p
\v 27 Amate theampo in lamdangsa mama uh a, hisia in bangbang hithong ziam? hibang te koibang hil na thak ziam? banghangziam cile thuneina taw thupia in, doai ngilo te nangawn in a thuni hi, ci in amate sungah ki dong tek uh hi.   
\p
\v 28 Taciang a min sia Galilee ngam kimkot teng theampo ah manlangtak in thang hi.   
\s1 Jesus in Mi Tampi Damsak  
\r Matt. 8:14-17; Lk. 4:38-41  
\p
\v 29 Amate synagogue sung pan a pusua zawk uh ciang in, James le John te taw Simon le Andrew te innsung ah tumsuak pai uh hi.   
\p
\v 30 Ahihang Simon zi i a nu sia a cisa in lum hi, ci manlang tak in son uh hi.   
\p
\v 31 Taciang Jesus hongpai a, a ban pan len in kaito hi; tasia pociang in a cisa thai a, amate leangna do hi.   
\p
\v 32 Nitak sang ni tum ciang in, cina te le doai te a kungah puak uh hi.   
\p
\v 33 Tua khuapi sung mihing theampo a kongbiang ah hong ki kaikhawm siat uh hi.   
\p
\v 34 Jesus in natna namcin a thuak te damsak a, doai tam mama hawlkhia hi; Jesus in doai te pausak ngawl hi, banghangziam cile amate in Jesus he uh hi.   
\s1 Jesus Zingtung Tho in Thungen  
\r Lk. 4:42-44  
\p
\v 35 A zingciang khuavak ma in Jesus tho a, khuapua sangah pusuak in kuama om ngawl na mun ah thungen hi.   
\p
\v 36 Simon le a lawmte in ama zui tek uh hi.   
\p
\v 37 Amate in a mu uh ciang in, a kungah, mi theampo in hong zong uh hi, ci uh hi.   
\p
\v 38 Jesus in, \wj Khuapi dang te ah zong pai tawng, tuak sungah thuhil tu khi hi: banghangziam cile thuhil tu in hongpai ka hihi, \wj* ci hi.   
\p
\v 39 Galilee ngam mun tatuam synagogue te ah thuhil a, doai te zong hawlkhia hi.   
\s1 Jesus in Miphak Khat Damsak  
\r Matt. 8:1-4; Lk. 5:12-16  
\p
\v 40 Miphak khat ama kungah hongpai a, khupdin in, Topa uk hi po le te keima hong thiangsak thei ni hi, ci in thum hi.   
\p
\v 41 Jesus in tuapa tungah hesuakna nei in, a khut tham a, \wj Uk khi hi; thiang tan, \wj* ci hi.   
\p
\v 42 Jesus in a ci zawkpociang in, a phak natna bo vingveng a, ama thiang hi.   
\p
\v 43 Jesus in ama phatak in thu a vaithak zawkciang, paisak hi;   
\p
\v 44 Ama kungah, \wj Kuama son heak in: ahizong thiampi te kungah pai tan a, nangma le nangma ki lak in, amate tungah tetti na lak natu in Moses thupiak biakpiakna pia in, \wj* ci hi.   
\p
\v 45 Ahihang tua pa pai in, mun theampo ah a pualak kakoai hu in, Jesus khuapi sungah a kilang in tum thei ngawl a, khua pua sang duisung ah om hi: taciang mun theampo pan in a kungah hongpai tek uh hi.   
\c 2  
\s1 Jesus in Pumzawpa Damsak  
\r Matt. 9:1-8; Lk. 5:17-26  
\p
\v 1 Tuazawk ni tam ki hal ngawl in Jesus Capernaum khua ah hong theng kik a; inn ah om hi, ci thu hong kison hi.   
\p
\v 2 Tasia pociang in mihing tam mama hong theng tek uh a, innsung ah a awng na munkhat mama zong om ngawl in, kongkha hui a puasang dong in dimteak uh hi: tua mun ah Jesus in amate thuhil hi.   
\p
\v 3 Tualaitak in mihing li in pumzawpa khat zawng khawm uh a, hong paipui uh hi.   
\p
\v 4 Mihing tamlei ahikom in Jesus kung dong pai thei ngawl hi, tua ahikom Jesus om na tungsan pan inn khuvum sulet uh a: pumzawpa a lupna taw khiasuk uh hi.   
\p
\v 5 Jesus in amate upna uh a mu ciang, pumzawpa kungah, \wj Ka tapa awng, na mawna te hong ki maisak zo hi, \wj* ci hi.   
\p
\v 6 Ahihang tua mun ah thukhamhil te pawlkhat tokhawm uh a, amate thinsung uh ah,   
\p
\v 7 Banghang in hisia pa in Pathian mindaisak in pau ziam? Pathian bek in mawna maisak thei hi ngawl ziam? ci in ngaisun uh hi.   
\p
\v 8 Thakhatthu in Jesus in amate ngaisutna a thaa taw he a, \wj Banghang in na thinsung uh ah hi thu te ngaisun nu ziam?\wj*   
\p
\v 9 \wj Hi pumzawpa kungah, na mawna te hong ki maisak zo hi; ci le, tho in a, na lupna zial in, pai in, ci tu koisia ol zaw ziam?\wj*   
\p
\v 10 \wj Ahihang, mihing Tapa in leitung ah mawna te maisak thei na vangletna nei hi, ci na tel thei natu uh in, \wj* (pumzawpa kungah),   
\p
\v 11 \wj Nangma tungah kong ci hi, tho in a, na lupna zial in, pai in a, cia in, hong ci khi hi, \wj* ci hi.   
\p
\v 12 Tasia pociang thakhatthu in tho a, a lupna la in mi theampo i mai ah pai hi; amate theampo in lamdangsa mama uh a, hibang thu i mu ngei bua hi, ci in Pathian minthang pok uh hi.   
\s1 Levi A Sapna  
\r Matt. 9:9-13; Lk. 5:27-32  
\p
\v 13 Jesus tuili hui ah pai kik hi; taciang mihonpi te a kungah hongpai uh a, amate thuhil hi.   
\p
\v 14 Lampi ah a pai uh laitak in Alphaeus i tapa Levi sia shia ki dong na mun innsung ah a to mu a, \wj Hong zui tan, \wj* ci hi. Tasia ciang ama zong ding in, Jesus nungzui hi.   
\p
\v 15 Tuazawkciang in, Jesus Levi innsung anneakna mun ah to hi, siadong te le mawnei tampi te zong Jesus le a nungzui te taw to khawmtek uh hi: banghangziam cile mitampi in a nung pan zui hi.   
\p
\v 16 Taciang siadong te le mawnei te taw an a neak khop uh, thukhamhil te le Pharisee te in a mu uh ciang in, a nungzui te kungah, bangbang in siadong te le mawnei te taw annekhawm ziam? ci uh hi.   
\p
\v 17 Tua thu Jesus in a zakciang in amate tung ah, \wj A cidam te in syavuan kul ngawl hi, ahihang cina te in kul hi: mipha te sam tu in hongpai ngawl khi hi, mawnei te ki sikkiksak tu in hongpai khi hi, \wj* ci hi.   
\s1 John Nungzuite in Antan Thu Dong  
\r Matt. 9:14-17; Lk. 5:33-39  
\p
\v 18 John le Pharisee te zungzui te antang tawntung uh hi: amate Jesus kungah hongpai uh a, John le Pharisee te i nungzui te antang uh hi, banghang in na nungzui te tang ngawl ziam? ci uh hi.   
\p
\v 19 Jesus in amate kungah, \wj Zineipa sia a lawmte taw a om laitak in amate antang thei tu ziam? zineipa om sung theampo antang thei ngawl hi.\wj*   
\p
\v 20 \wj Ahihang amate kung pan zineipa a ki lak ni hong theng tu a, tasiaciang antang kik lai tu hi.\wj*   
\p
\v 21 \wj Puan lui sia puan thak taw kuama in phaw ngei ngawl hi: tabang in phaw le tua a phawna puan thak in puan lui sia kaikin tu a, a ek zai seseam tu hi.\wj*   
\p
\v 22 \wj Tasia bangma in savun um lui sungah kuama in sapittui thak thun ngei ngawl hi: a thun le savun um tamtham tu a, sapittui bua siat in, savun um zong laltham tu hi: ahihang sapittui thak sia savun um thak sungah a thun hamtang tu uh a hihi, \wj* ci hi.   
\s1 Jesus Sabbath i Topa Hi  
\r Matt. 12:1-8; Lk. 6:1-5  
\p
\v 23 Tuazawkciang in, Jesus sabbath ni khat lo sung kantan in pai a; a nungzui te a ngilkial ahikom, zungtang hui te hiat in ne uh hi.   
\p
\v 24 Ahihang Pharisee te in a mu uh ciang, Jesus kungah, en in, na nungzui te in sabbath ngeina a hi ngawl te banghang seam uh ziam? ci uh hi.   
\p
\v 25 Jesus in amate tung ah, \wj David le a lawmte a ngilkial uh a, kisap na a nei ciang in, bang vawt ci thu simngei ngawl nu ziam?\wj*   
\p
\v 26 \wj Thiampi sangbel Abiathar hun lai in Pathian innsung ah bangbang tum in, thiampi te bek i a neak thei, Pathian mai ah a ki lui anluum te ne in, a lawmte zong pia hi ngawl ziam? amate neak tu a kilawm ngawl, thiampi te bek i a neak thei tu in Pathian mai ah a ki lui anluum te ne uh hi, \wj* ci hi.   
\p
\v 27 Tasiaciang Jesus in amate tung ah, \wj Sabbath sia mihing te atu a kivawt hi a, mihing sia sabbath atu in a ki vawt hi ngawl hi:\wj*   
\p
\v 28 \wj Tua ahikom mihing Tapa sia sabbath i tungah Topa a hihi, \wj* ci hi.   
\c 3  
\s1 Sabbath Ni in Khutzaw Pa Damsak  
\r Matt. 12:9-14; Lk. 6:6-11  
\p
\v 1 Jesus synagogue sungah tumkik a; tuaksung ah khut langzaw khat om hi.   
\p
\v 2 Ama maw zong nuam te in sabbath ni in damsak maw, damsak ngawl; ci encik uh hi.   
\p
\v 3 Jesus in tua khut langzaw pa tung ah, \wj A maisang ah hong ding tan, \wj* ci hi.   
\p
\v 4 Taciang Jesus in amate tung ah, \wj Sabbath ni in a pha sep tu kilawm ziam maw, a hibale a phangawl sep tu kilawm ziam? ngual nuntakna ngum tu maw, that tuh?, \wj* ci hi. Ahihang amate a huthe bua uh hi.   
\p
\v 5 Jesus in a kimkot teng thin-uk kawm in en a, amate thinpui uh hu in khuangai a, tua pa kungah, \wj Na khut phal in, \wj* ci hi. Tasiaciang ama in a khut phal a: tua a khut sia a langkhat bangma in dam kik hi.   
\p
\v 6 Tasia pociang, Pharisee te pai in Herod mihing te taw Jesus suksiat thei natu thu kikum pai uh hi.   
\s1 Mi Tampi Te in Jesus Zui  
\p
\v 7 Ahihang Jesus a nungzui te taw tuili sangah pai uh a: a zui mihon tampi te sia, Galilee le Judah,   
\p
\v 8 Jerusalem, Idumea le Jordan ngunngal; Tyre le Sidon kim teng pan hongpai te a hi uh hi. Tua mihon tampi te sia Jesus i na lianpi a vawt te a zak uh ciang in, a kungah hongpai tek uh hi.   
\p
\v 9 Mihonpi te in phulcip tha tu a hi ciang in ngunkuang no khat taw ngak khol tu in a nungzui te sawl hi.   
\p
\v 10 Banghangziam cile mi tam mama damsak zo a; natna a thuak te theampo in ama tham tu in kitu ngawp uh hi.   
\p
\v 11 Doai ngilo te in Ama a mu uh ciang in, a mai ah bok uh a, nang sia Pathian Tapa ni hi, ci in au uh hi.   
\p
\v 12 Jesus in amate tung ah, Ama thu kuama hesak ngawl tu in nasiatak in vaitha hi.   
\s1 Jesus In Nungzui Sawm Li Ni te Teal  
\r Matt. 10:1-4; Lk. 6:12-16  
\p
\v 13 Jesus mualtung ah kato hi, taciang Ama i dei te teal a: tua te a kungah hongpai hi.   
\p
\v 14 Mihing sawmleni te sia ama kungah om tu in ahizong, thuhil tu in paisak tu ahizong, nasep pia in,   
\p
\v 15 Natna te damsak tu in ahizong, doai te hawlkhiat zawk na vangletna nei tu in ahizong:   
\p
\v 16 Peter kici Simon;   
\p
\v 17 Zebedee tapa James le John; amate sia Boanerges ci in min kivaw a, a khiakna sia vanto tate, cinopna a hihi:   
\p
\v 18 Andrew, Philip, Bartholomew, Matthew, Thomas, Alphaeus tapa James, Thaddaeus, Canaan mi Simon,   
\p
\v 19 Jesus leheakpa Judas Iscariot te a hi uh hi: Taciang amate innsung ah tum tek uh hi.   
\s1 Jesus le Beelzabub  
\r Matt. 12:22-32; Lk. 11:14-23  
\p
\v 20 Taciang mihonpi te hongpai kik uh hi, tua ahikom amate anneak hun zong a nei bua hi.   
\p
\v 21 Tua thu a mealheak te in a zak uh ciang in, Jesus sia a thin-am zo hi, a ci uh hu in Ama pui tu in pai tek uh hi.   
\p
\v 22 Jerusalem pan hongpai thukhamhil te in, Jesus sungah Beelzabub om hi, doai ngilo le topa vang taw in doai te hawlkhia hi, ci uh hi.   
\p
\v 23 Taciang Jesus in amate a kungah sam in, sontena te taw thu son a, \wj Bangbang in Satan in Satan hawlkhia thei tu ziam?\wj*   
\p
\v 24 \wj Kumpingam khat kikhen in kido a hile, tua kumpingam sia kho ngawl tu hi.\wj*   
\p
\v 25 \wj Inn khat sia kikhen in kido a hile, tua inn kho ngawl tu hi.\wj*   
\p
\v 26 \wj Tasia bangma in Satan zong ama le ama kikhen in a kido le, kho ngawl tu a, bo in mangthang tu hi.\wj*   
\p
\v 27 “\wj Kuama in mihing thahatpa hencip masa ngawl in, a innsung ah tum in a neisa te sut thei ngawl tu hi, mihing thahatpa a hencip zawkciang bek in; a innsung van te sut thei tu hi.\wj*   
\p
\v 28 \wj A tatak ka ci ciang, mihing te mawna namcin le sonsiatna te kimaisak tu hi:\wj*   
\p
\v 29 \wj Ahihang Tha Thiangtho a sonsiate, bangmahun in ki maisak ngei ngawl tu hi, banghangziam cile tawntung thukhenna dan thuak tu kilawm hi:\wj* ci hi.   
\p
\v 30 Amate in Jesus sungah tha-nin om hi, a ci uh hu in Jesus in hibang in a pau a hihi.   
\s1 Jesus Nu le A Suapuite  
\r Matt. 12:46-50; Lk. 8:19-21  
\p
\v 31 Tuazawkciang Jesus nu le a nau te hongpai a, a puasang ah ding in, mikhat Jesus kungah sawl in sam hi.   
\p
\v 32 A kim a mihonpi te to a, a kungah, en in, na nu le na nau te nangma zong in a puasang ah om hi, ci hi.   
\p
\v 33 Jesus in, \wj Ka nu, a hibale, ka suapui te kua te ziam?\wj* ci in zo kik hi.   
\p
\v 34 Taciang a kim a pam a to te en in, \wj En vun, ka nu le ka suapui te!\wj*   
\p
\v 35 \wj Banghangziam cile a kuamapo Pathian deina a seam peuma sia, ka suapui le ka nu a hihi, \wj* ci hi.   
\c 4  
\s1 Thaici Poai Sontena  
\r Matt. 13:1-9; Lk. 8:4-8  
\p
\v 1 Jesus tuili hui ah thuhil kipan kik hi: a kungah mihon tampi te hong ki kaikhop ciang in tuili sung ngunkuang sungah tuak in to a; mihonpi te sia tuili hui ah om uh hi.   
\p
\v 2 Tasiaciang sontena te zang in thuhil a,   
\p
\v 3 \wj Ngai vun a; en vun, thaici poaipa khat thaici poai tu in pai hi:\wj*   
\p
\v 4 \wj Tabang a poai ciang in, thaici pawlkhat te lampi ah tak a, tungleang te hongpai in ne siat hi.\wj*   
\p
\v 5 \wj Pawlkhat te suang tam na mun ah tak a, lei tawm a hi man in thaici te hong po pai hi, banghangziam cile lei thuk ngawl hi:\wj*   
\p
\v 6 \wj Ni hong sua ciang in, nisa in kang a; zung tha ngawl ahikom ngawtak hi.\wj*   
\p
\v 7 \wj Pawlkhat te lingphung sungah tak a, lingkung te a khan ciang in deapcip in, nga zo ngawl hi.\wj*   
\p
\v 8 \wj A dang te lei pha na tungah tak hi, taciang po in hong khang a, a nga hong nga hi; pawlkhat te a se sawmthum, pawlkhat te a se sawmluk, pawlkhat te a se zakhat dong in khang hi, \wj* ci hi.   
\p
\v 9 Taciang Jesus in amate tung ah, \wj Zak natu bil a nei peuma in za tahen, \wj* ci hi.   
\p
\v 10 Ama nguak a om laitak in, a nungzui sawmleni te taw a omte in sontena thu dong uh hi.   
\p
\v 11 Jesus in amate tung ah, \wj Pathian kumpingam thuku heak theina hong pia zo hi: ahihang a puasang a omte tung ah, tua thu te theampo sia sontena te taw son hi:\wj*   
\p
\v 12 \wj Amate in mu tu hi napi, a he bua tu uh hi; ngai tu hi napi, a tel thei bua tu uh hi; tabang hi bua le hun khatpo ah amate ki kheal in, amate i mawna ki maisak tu hi, \wj* ci hi.   
\p
\v 13 Jesus in amate tung ah, \wj Hi sontena te he ngawl nu ziam? taciang sontena theampo bangbang in tel thei tu nu ziam?\wj*   
\p
\v 14 \wj Thaici poaipa in Pathian kammal poai hi.\wj*   
\p
\v 15 \wj Lampi ah a tak thaici te thu sia hibang te a hihi, amate in Pathian kammal a zak uh ciang in Satan manlang tak in hongpai a, amate thinsung pan Pathian kammal te laksak hi.\wj*   
\p
\v 16 \wj Suang tam na mun ah a tak thaici te sia hibang te a hihi; amate sia Pathian kammal a zak uh ciang in thakhatthu in lungdamna taw sang hi napi;\wj*   
\p
\v 17 \wj Amate sungah zungtha ngawl ahikom, tawmvei sung bek khom hi: Pathian thu hang in haksatna le vawtsiatna a thet ciang in, thakhathu in pukkik hi.\wj*   
\p
\v 18 \wj Lingsung a tak thaici te thu sia hibang te a hihi, Pathian kammal za napi, \wj*   
\p
\v 19 \wj Hi leitung thinngimna, hauna i theamna, nadang tampi te lungngul nate tum in Pathian thu sia deapcip ahikom, a nga toai ngawl hi.\wj*   
\p
\v 20 \wj Lei pha na a tak thaici te thu sia hibang a hihi; Pathian thu za in sang a, pawlkhat te a se sawmthum, pawlkhat te a se sawmluk, pawlkhat te a se zakhat in a nga hong toai hi, \wj* ci hi.   
\s1 Khum taw a ki Khup Khuaimei  
\r Matt. 5:14-16; Lk. 8:16-18  
\p
\v 21 Jesus in amate tung ah, \wj Khuaimei sia khum nuai ah, a hibale, lupna nuai ah koi tu in ki keng ngei ziam? meivak na tungah a ki koi tu hi ngawl ziam?\wj*   
\p
\v 22 \wj Banghangziam cile a ki lang ngawl tu in phualcip thei bangma a om ngawl bangma; pualak ngawl tu thuku zong om ngawl hi.\wj*   
\p
\v 23 \wj Zak natu bil nei theampo in za tahen, \wj* ci hi.   
\p
\v 24 Jesus in amate tung ah, \wj Na zak thu uh kidawm vun: ngualdang na te uh bangma in noma zong hong ki tekik tu hi: taciang a za te a tamzaw hong ki piakik tu hi.\wj*   
\p
\v 25 \wj Banghangziam cile a nei te ki pia thua tu a: a nei ngawl te a neisun ki laksak tu hi, \wj* ci hi.   
\s1 Thaici Sontena  
\p
\v 26 Jesus in, \wj Pathian kumpingam sia, mikhat in a lo ah thaici poai tu hi;\wj*   
\p
\v 27 \wj Taciang mu in, le tho in, sun le zan in thaici bangbang in po tu le bangbang in khang tu ci a he ngawl thaici poaipa taw kibang hi.\wj*   
\p
\v 28 \wj Banghangziam cile leitang in ama thu in ngasak a; a masabel in a te meangsak hi, tua zawkciang vui a, a vui zawkciang a tang hong suak hi.\wj*   
\p
\v 29 \wj Ahihang anlak hun hong thet ciang in, ama in phiau taw manlangtak in at hi, banghangziam cile anlak hun cing zo hi, \wj*   
\s1 Ankam Cii Sontena  
\r Matt. 13:31, 32, 34; Lk. 13:18, 19  
\p
\v 30 Jesus in, \wj Kumpingam sia bangtaw sonte tu khi ziam? a hibale bangtaw tekak tu khi ziam?\wj*   
\p
\v 31 \wj Hisia in ankam cii taw kibang hi, lei ah a poai ciang in thaici dang theampo sang in no zaw hi:\wj*   
\p
\v 32 \wj Ahihang a poai zawkciang in hong khang a, an te theampo sung pan a lianbel hong suak hi, van a vacim te a lim ah tawlnga thei zadong in a bak te nei hi, \wj* ci hi.   
\p
\v 33 Amate i zak thei tuh in sontena tampi taw thuhil hi.   
\p
\v 34 Sontena kihel ngawl in amate tungah thuhil ngawl hi: taciang amate bek a om uh ciang in a nungzui te kungah tua thu te son thiang hi.   
\s1 Jesus in Huipi Suangval Thimsak  
\r Matt. 8:23-27; Lk. 8:22-25  
\p
\v 35 Tua ni nitak sang in, Jesus in a nungzui te kungah, \wj Ngalkhat ah pai tawng, \wj* ci hi.   
\p
\v 36 Amate in mihonpi te a paisak zawk uh ciang in, Ama sia nungzui te in ngunkuang taw paipui hi. Tua mun ah a dang ngunkuang no te zong om hi.   
\p
\v 37 Tasiaciang huipi suangval nasiatak in hong tho a, tuihual te in ngunkuang sia nuaicip ahikom, ngunkuang sungah tui hong dim hi.   
\p
\v 38 Jesus sia ngunkuang nungsang kham in mu hi: amate in phong uh a, Syapa awng, ka thisiat tu uh phamaw hong sa ngawl ni ziam? ci uh hi.   
\p
\v 39 Jesus hong tho in, huipi tei hi, taciang tuipi tung ah, \wj Thim in, \wj* ci hi. Taciang hui thim in, dai dide hi.   
\p
\v 40 Jesus in nungzui te kungah, \wj Banghang in hibang lalawm in lau nu ziam? bangbang lalawm in upna nei ngawl nu ziam?\wj* ci hi.   
\p
\v 41 Amate lau mama uh a, hisia pa sia bangbang mihing ziam, hui le tuipi in a thuni hi? ci in khat le khat kici uh hi.   
\c 5  
\s1 Jesus in Thin-am Khat Damsak  
\r Matt. 8:28-34; Lk. 8:26-39  
\p
\v 1 Amate tuili ngalkhat Gadarenes ngam theng uh hi.   
\p
\v 2 Jesus ngunkuang sung pan a pusua pociang, than pan in hongpai doai vei khat taw kisi hi,   
\p
\v 3 Ama than ah om a; kuama in hen thei ngawl hi, thikkol taw nangawn in khit thei ngawl hi:   
\p
\v 4 Banghangziam cile thikkol le saikhau taw tu le tu khit uh hi kale, saikhau te bot tan in, thikkol te santham hi: kuama in zualsak zo ngawl hi.   
\p
\v 5 Sun le zan in, mual tung tatuam le than ah om a, au tawntung in, ama le ama suang taw ki kui hi.   
\p
\v 6 Ahihang a khuala mama na pan Jesus a mu ciang, hong tai in bia hi,   
\p
\v 7 Taciang a nging tak in au a, Jesus awng, nang, a sangbel Pathian Tapa, nang taw bang kisai na nei khi ziam? Nong vawtsiat ngawl natu in Pathian min taw hong ngen khi hi, ci hi.   
\p
\v 8 Banghangziam cile Jesus in ama tung ah, \wj Nang doai ngilo, hisia pa sung pan in pusuak in, \wj* ci hi.   
\p
\v 9 Jesus in, \wj Na min kua ziam?\wj* ci in dong hi. Tua pa in, ka min sia Legion hi, banghangziam cile ka tam mama uh hi, ci in zo kik hi.   
\p
\v 10 Ama in tua ngam pan hawlkhia ngawl tu in thum hi.   
\p
\v 11 Mual te taw a ki nai na mun ah vokhon tampi anne keukho hi.   
\p
\v 12 Doai ngilo te theampo in, vok sungah tum tu in hong sawl tan, ci ngen uh hi.   
\p
\v 13 Tasia pociang Jesus in paisak hi. Doai ngilo te pusuak a, vokhon sungah tum uh hi: taciang vokhon te liang pan in manlang tak in tai uh a, tuili sungah tuita in thi siat hi. Tua vok te tul ni kiim pha uh hi.   
\p
\v 14 Vokcing te tai in, khuapi le ngam sungah son hi. Mipi te tabang thu piang te en tu in hongpai tek uh hi.   
\p
\v 15 Amate Jesus kungah hongpai uh a, legion a kici doai ngilo vei pa sia puansil in, a thin ciim in a to mu uh hi: amate lau mama uh hi.   
\p
\v 16 Tua thu a mu te in doai ngilo vei pa le vokhon tungah thu piang te ngualdang tungah son uh hi.   
\p
\v 17 Tasiaciang amate in Jesus sia amate ngam pan pusuak tu in ngen uh hi.   
\p
\v 18 Jesus ngunkuang sung a tum ciang in, doai ngilo vei ngei pa in, Ama taw kikop tu in ngen hi.   
\p
\v 19 Ahihang Jesus in zuisak ngawl a, ama kungah, \wj Na inn ah cia tan a, na lawmte kungah, Topa in nangma atu hong vawtsak te bangza in lian ci le, na tungah hesuakna a nei nate son in, \wj*ci hi.   
\p
\v 20 Tua pa zong pai in, Decapolis ngam sung theampo ah Jesus in ama atu a vawtsak nate bangza in lian ziam, ci thu te tangko hi: a za theampo in lamdangsa uh hi.   
\s1 Kum Sawm le Kum Ni Thisuak Nu Damsak  
\r Matt. 9:18-26; Lk. 8:40-56  
\p
\v 21 Jesus sia ngunkuang taw ngalkhat ah paikik a, mi tampi te a kungah hong ki kaikhawm hi: Ama sia tuili nai na ah om hi.   
\p
\v 22 Taciang, en vun, Jairus a kici synagogue lampui khat Jesus kungah hongpai a; a mu ciang in a peang ah bok in,   
\p
\v 23 Ka tanu a thi dektak in lum hi: hongpai tan a tungah na khut nga tu in hong ngen khi hi, tasiaciang ama dam tu a; nungta tu hi, ci in nasiatak in thum hi.   
\p
\v 24 Taciang Jesus ama taw pai hi; mi tampi in zui uh a, a kiim a pam pan phul ngawp uh hi.   
\p
\v 25 Taciang kum sawm le kum ni sung thisuak numei khat,   
\p
\v 26 Syavuan tam mama kungah ki lak zo a, a neisa theampo zang siat zo hi kale, dam tuan ngawl bekdom ngawl in lawmawk seseam hi,   
\p
\v 27 Jesus thu a zak ciang in, mihon sungah a nung pan pai in, a puan tham hi.   
\p
\v 28 Banghangziam cile, a puan thamtha po leng dam tu khi hi, ci hi.   
\p
\v 29 Thakhatthu in a thi suak kang a; tua natna pan dam khi hi, ci phawk hi.   
\p
\v 30 Jesus in, a sung pan vangletna pusuak hi, ci he lian ahikom, mihonpi sangah kiheak in, \wj A kua in ka puan hong tham nu ziam?\wj* ci hi.   
\p
\v 31 A nungzui te in, mihonpi in hong phul ngawp mu nginge napi, banghang in, kua na tham nu ziam ci ni ziam? ci uh hi.   
\p
\v 32 Jesus in a puan tham sia nu mu nuam in a kiim teng en hi.   
\p
\v 33 Ahihang numei nu in a sungah thu piang he ahikom, lau le ling kawm in, Jesus mai ah pai in bok a, thu piang theampo a man in son hi.   
\p
\v 34 Jesus in a kungah, \wj Ka ta nu awng, na upna in hong damsak zo hi; thinnuam in pai tan a, vawtsiat na pan in suakta ta in, \wj* ci hi.   
\p
\v 35 Jesus a pau laitak in, synagogue lampui pa inn pan in hongpai te in, na tanu thi zo hi: banghang in syapa nawngkaisak lai ni ziam? ci uh hi.   
\p
\v 36 Tua thu Jesus in a zak pociang, synagogue lampui pa kungah, \wj Lau heak in, um bek po in, \wj* ci hi.   
\p
\v 37 Jesus in, Peter, James le a suapui pa John simngawl kuama zuisak ngawl hi.   
\p
\v 38 Jesus synagogue lampui pa inn a thet ciang in, nasiatak in kap le tau in ngamlum lialua mu hi.   
\p
\v 39 Amate kungah hong sungtan ciang in, \wj Banghang in ngamlum lialua in kap nu ziam? numeino sia a thi hi ngawl hi, a mu hi, \wj* ci hi.   
\p
\v 40 Amate in Jesus selno in nuisan uh hi. Ahihang amate a vekpi a puasang ah pusuaksak siat a, numeino i a nu le pa le a paipui teng bek sam in, numeino nu lupna mun inndoi sungah tum tek uh hi.   
\p
\v 41 Taciang Jesus in numeino a khut pan len a, \wj Talitha kumi, \wj* ci hi; a khiakna sia, numeino, tho in kong ci hi, a cinopna hi.   
\p
\v 42 Taciang numeino sia thakhatthu in hong tho a, lampai hi; ama sia kum sawmleni kiim hi. Amate in lamdangsa mama uh hi.   
\p
\v 43 Jesus in, hi thu te kuama hesak heak vun, ci in nasiatak in vaitha hi; tua nu i neak tu khatpo a piak natu in thu pia hi.   
\c 6  
\s1 Nazareth Khua ah Jesus Ki Nial  
\r Matt. 13:53-58; Lk. 4:16-30  
\p
\v 1 Jesus tua mun pan in pai a, Ama khua ah theng hi; a nungzui te in zui uh hi.   
\p
\v 2 Sabbath ni a thet ciang in, synagogue sungah thuhil kipan hi: a za mi tampi te in lamdangsa in, hi thu te koisung pan in nga ziam? ama tungah a ki pia pilna sia bang pilna ziam, bangbang in vanglian nasep te a khut taw seam thei ziam? ci uh hi.   
\p
\v 3 Ama sia Mary tapa, James, Joses, Judah le Simon te suapuipa, lettama pa hi ngawl ziam? a suapui numei te zong ziak ma ah om hi ngawl ziam? ci in, a sang thei bua uh hi.   
\p
\v 4 Ahihang Jesus in amate tung ah, \wj Kamsang khat sia ama khua, mealheak suapui le, ama inn simngawl mundang ah ki upat hi, \wj* ci hi.   
\p
\v 5 Tua mun ah cina tawm te tungah a khut nga in a damsak simngawl, a vanglian nasep dang bangma seam thei ngawl hi.   
\p
\v 6 Amate up ngawl na hang in Jesus in lamdangsa hi. Taciang ama a kiim a pam khuapi te ah pai in thuhil hi.   
\s1 Nungzuite tung A Vaithak Thu  
\r Matt. 10:5-42; Lk. 9:1-6  
\p
\v 7 A nungzui sawmleni te a kungah sam a, ni tek in sawl hi; doai ngilo te zo tu in vangletna pia hi;   
\p
\v 8 A khualhaw na mun uh ah ciangkhut bek keng tu a; thung, anluum le sumbawm sungah sum te keng ngawl in:   
\p
\v 9 Peangdap te bul tu le; laktong sil ni keng ngawl tu in thupia hi.   
\p
\v 10 Ama te kungah, \wj Na tum na uh inn ah tua mun pan na paikik uh dong, tam vun.\wj*   
\p
\v 11 \wj A kuapo a hi zong note hong sang nuam ngawl le na thu uh a ngai nuam ngawl peuma tua mun pan na pusua kik uh ciang in, amate langpan tu tetti tu in na peang leihui thin vun. A tatak kong ci ciang, thukhenna ni ciang in tua khuapi sang in Sodom le Gomorah te thuakna thuak nop zaw lai tu hi, \wj* ci hi.   
\p
\v 12 Amate pai uh a, mihing te ki sikkik tu in thuhil uh hi.   
\p
\v 13 Amate in doai ngilo tampi hawlkhia uh a, cina tampi te zong sathau zut in damsak uh hi.   
\s1 Tuiphumpa John Thina  
\r Matt. 14:1-12; Lk. 9:7-9  
\p
\v 14 Jesus sia muntheampo ah a minthang a, Herod kumpipa in a thu a zakciang in; tuiphumpa John thina pan thokik hi, tua hang in a vanglian nasep te lak thei hi, ci hi.   
\p
\v 15 A dangte in Elijah hi, ci uh hi. A dang te in kamsang khat hi, a hibale kamsang sung pan khat papo hi, ci uh hi.   
\p
\v 16 Ahihang Herod in a zakciang in, hi thu sia a ngawng ka tan John thina pan thokik hi, ci hi.   
\p
\v 17 Herod in a nau Philip i zi Herodias sia tenpui a, tua Herodias thu hang in, ama vateak in mi sawl a, John man in thong ah khum hi.   
\p
\v 18 John in Herod kungah, na naupa zi na tenpui sia ngeina om ngawl hi, a ci hang a hihi.   
\p
\v 19 Tua ahikom Herodias in John ngaimaw in that nuam napi; that thei ngawl hi:   
\p
\v 20 Banghangziam cile Herod in John sia mi thutang le mithiangtho hi, ci a heak hang in lau hi, ama in keamcing in, a sep sa tampi te lungdamtak in ngai hi.   
\p
\v 21 Hunpha a thet ciang in, Herod in a suani ah, ama i to te, ngalkapmang te le Galilee ngam uk ulian te atu in nitak an vak hi;   
\p
\v 22 Herodias i ta nu tum in, a lap ciang, Herod le a kiim a to te a lungkimsak mama hi, tua ahikom kumpipa in ngaknu nu kungah, na dei theampo hong ngen tan, kong pia tu hi, ci hi.   
\p
\v 23 Nong nget theampo, ka kumpingam a lang a hi zong kong pia tu hi, ci in kamciam hi.   
\p
\v 24 Tasiaciang ngaknu nu a nu kungah pai a, bang ka ngen tu ziam? ci hi. A nu in, tuiphumpa John lu ngen in, ci hi.   
\p
\v 25 Ngaknu nu hongpai kik pai in, kumpipa kungah tuiphumpa John i lu sia pakandal sungah a manlang in nong piak tu ka dei hi, ci in ngen hi.   
\p
\v 26 Kumpipa sia khuangai mama hi kale; a kamciam na sa le a kiim a to te hang in, ngaknu nu nget na nial ngam ngawl hi.   
\p
\v 27 Taciang kumpipa in mihing that te khat sawl in paisak pai a, John lu puak tu in thupia hi: taciang mihing that pa pai a, thonginn sungah John ngawng tan hi,   
\p
\v 28 Taciang pakandal taw a lu puak a, ngaknu nu pia hi: taciang ngaknu nu in a nu pia hi.   
\p
\v 29 Tua thu John nungzui te in a zak ciang in, amate hongpai uh a, a luanghawm la in than ah vui uh hi.   
\s1 Jesus in Mi Tul Nga Vak  
\r Matt. 14:13-21; Lk. 9:10-17; Jn. 6:1-14  
\p
\v 30 Sawltakte Jesus kungah hong ki kaikhawm uh a, amate i vawt te le a thuhilna uh theampo son uh hi.   
\p
\v 31 Jesus in amate tungah hibang in ci hi, \wj Hongpai tavun, senneal sungah a tuam in tawmvei tawlnga tawng, \wj* ci hi: banghangziam cile a pai le a cia mihing tam mama a, amate anneak hun zong nei ngawl hi.   
\p
\v 32 Taciang amate ngunkuang taw a tuam in senneal sangah pai uh hi.   
\p
\v 33 Mipi te in amate pai a mu uh ciang in, mi tampi in Ama he uh ahikom, khuapi theampo sung pan in peang taw hongpai tek uh a, amate kantan in, a kungah hongpai uh hi.   
\p
\v 34 Jesus hong pusua ciang in, mitampi a mu ciang, a cing nei ngawl tuuhon taw kibang uh ahikom khuangaihuai sa hi: taciang amate thu tampi hil kipan hi.   
\p
\v 35 Nitak sang ciang in a nungzui te a kungah hongpai a, hi mun sia senneal ngam hi, khua zong niam zo hi:   
\p
\v 36 Amate paisak in a, kiim le pam khua tatuam ah pai in, amate neak tu anluum lei tahen: banghangziam cile amate neak tu bangma nei ngawl hi, ci hi.   
\p
\v 37 Jesus in, \wj Note in amate neak tu pia vun, \wj* ci in zo kik hi. Taciang amate in, koma pai in dangka za ni man an lei in, amate neak tu pia tu hong sawl ni ziam? ci uh hi.   
\p
\v 38 Jesus in, \wj Anluum bangza nei nu ziam? pai vun a en vun, \wj* ci hi. Amate in a heak uh ciang, lum nga le ngasa ni, ci uh hi.   
\p
\v 39 Jesus in a vekpi in lopa hing tungah a hon a hon in to tu in thupia hi.   
\p
\v 40 Taciang amate, pawlkhat zakhat, pawlkhat sawm nga ci bang in a hon a hon in to tek uh hi.   
\p
\v 41 Jesus in anluum nga le ngasa ni te a lak zawkciang in, vandak to a, thupha a piak zawkciang, anluum te bal in, a nungzui te mai ah lui hi; ngasa ni te zong amate theampo hawmsak hi.   
\p
\v 42 Amate theampo in ngilva tak in ne tek uh hi.   
\p
\v 43 Amate in anluum le ngasa a val te tawm uh a, bawm sawm le bawm ni dim hi.   
\p
\v 44 Anlum a ne teng pasal tul nga kiim pha uh hi.   
\s1 Jesus Tui Tung Lampai  
\r Matt. 14:22-33; Jn. 6:15-21  
\p
\v 45 Mipite a ciasak uh laitak in, a nungzui te ngunkuang sungah tumsak pai in, ngalkhat Bethsaida ah paikholsak hi.   
\p
\v 46 Amate a paisak zawkciang in, mualtung ah thungen tu in pai hi.   
\p
\v 47 Nitak sang ciang in, ngunkuang sia tuili laizang ah om a, Jesus ama nguak mualtung ah om hi.   
\p
\v 48 Amate sangah hui hongpai ahikom a nungzui te in ngunkuang sia haksa tak in hot uh hi: zingsang nai thum le nai luk ki laklaw kiim in, Jesus amate sang tuili tungah lampai in, amate kantan tu bang in kithoai hi.   
\p
\v 49 Ahihang amate in tui tungah a lampai a mu uh ciang in, thitha sa in, au ngawp uh hi.   
\p
\v 50 Banghangziam cile a vekpi in mu uh a, amate lungmang mama uh hi. Tasia pociang Jesus in amate paupui a, \wj Thinnuam in om vun: Keima khi hi; lau heak vun, \wj* ci hi.   
\p
\v 51 Jesus amate kung ngunkuang tungah ka to a, a sung a thet ciang in; hui zong thim hi: taciang amate in sonzawk ngawl zadong in lamdangsa uh hi.   
\p
\v 52 Amate in anluum taw kisai nalamdang thu phawk ngawl uh hi, banghangziam cile amate a thinpui lei uh hang a hihi.   
\p
\v 53 Ngalkhat a thet uh ciang in, Gennesaret ah hongpai uh a, tuihui ah ngunkuang khit uh hi.   
\p
\v 54 Amate ngunkuang sung pan a pusua pociang, mipi te in Jesus a hi hunlam tel pai uh hi.   
\p
\v 55 Tasiaciang tua ngam kimkot theampo ah tai uh a, Jesus om hi, ci a zak na mun uh ah, cina te a lupna uh taw hong pua tek uh hi.   
\p
\v 56 Jesus a tum na mun khua theampo, khuapi te le lo lam theampo ah, amate in cina te lampi tungah sial uh a, a puanmong tham tu in ngen tek uh hi: a tham tha theampo in damna nga uh hi.   
\c 7  
\s1 Sungsang Thianthona  
\r Matt. 15:1-20  
\p
\v 1 Tuazawkciang in Pharisee te le thukhamhil te honkhat Jerusalem pan hongpai uh hi.   
\p
\v 2 Amate in Jesus nungzui pawlkhat te khut silngawl a ninpui taw anne a mu uh ciang in, mawsiat uh hi.   
\p
\v 3 Banghangziam cile amate ngeina a zui Pharisee te le Judah minam theampo, khut sil ngawl in anne ngei ngawl uh hi.   
\p
\v 4 Amate sumbuk pan a cia uh ciang zong, khut a sil bua uh le anne ngawl uh hi. Thu dang tampi a zui uh te, hai, beal, danbeal le sabuai ci bang te zong sil tawntung uh hi.   
\p
\v 5 Tasiaciang Pharisee te le thukhamhil te in ngeina te zui ngawl in, banghang khut sil ngawl in anne ziam? ci in dong uh hi.   
\p
\v 6 Jesus in amate tung ah, \wj Isaiah in phatak in noma a kihitheamsak te thu a sonkholna a atsa bangma in, hi mite in a muk uh bek taw hong upat uh hi, ahihang a thinsung uh sia kei kung pan khuala uh hi.\wj*   
\p
\v 7 \wj Ahihang amate in mihing thupiak te sia ki hil na phabel atu in zang uh a, a lui thathong in kei hong bia uh hi.\wj*   
\p
\v 8 \wj Banghangziam cile, Pathian thupiak te vawk in, mihing te i ngeina beal le hai te sil ngeina zui zaw nu hi, tabang thudang tampi te zong vawt nu hi, \wj* ci in zo kik hi.   
\p
\v 9 Jesus in amate tung ah, \wj Na ngeina uh na zui thei natu uh in, Pathian thupiak te nial thal nu hi.\wj*   
\p
\v 10 \wj Banghangziam cile Moses in, na nu le na pa zakta in; a pa a hibale a nu a hamsiat peuma, thina thuak tahen, ci hi:\wj*   
\p
\v 11 \wj Ahihang note in, khatpo in a nu, a hibale a pa kungah zatakna tu in van a nei te, hisia Corban hi, hisia letsong hi cinopna hi, Pathian kungah piaksa hi: ci po le ama peng tu hi.\wj*   
\p
\v 12 \wj Tabang in a pa, a hibale a nu atu in a vawtsak tu te vawt nuam nawn ngawl nu hi;\wj*   
\p
\v 13 \wj Na ki hil sawn uh na ngeina uh te zang in Pathian thu sia vang nei ngawl suaksak nu hi: tabang in na vawt uh dang tam mama lai hi, \wj* ci hi.   
\p
\v 14 Jesus in mihonpi te a vekpi in a kungah sam a, \wj Note sung pan khatsim in hong ngai tavun a, tel thei tavun:\wj*   
\p
\v 15 \wj Mihing sia a puasang pan in a sungah a tumsuk te taw a nin om ngawl hi: ahihang a sungsang pan a pusuak thu te in ninsak hi.\wj*   
\p
\v 16 \wj Khat po in zak thei na bil a nei le, za tahen, \wj* ci hi.   
\p
\v 17 Jesus sia mihonpi te kung pan in innsung ah a tum ciang in, a nungzui te in sontena taw kisai in thu dong hi.   
\p
\v 18 Jesus in amate tung ah, \wj Note zong tel thei tuan ngawl nu ziam? Bangpo a hi zong a puasang pan mihing sung a tum sia in ama ninsak ngawl hi, ci sia tel thei ngawl nu ziam;\wj*   
\p
\v 19 \wj Banghangziam cile a thinsung ah tum ngawl in a ngilpi sungah tum a, taciang awng dum sungah an theampo ki thiangsak hi ngawl ziam? \wj* ci hi.   
\p
\v 20 Tasiaciang Ama in, \wj Mihing sung pan a pusuak sia in, tua mihing ninsak hi.\wj*   
\p
\v 21 \wj Banghangziam cile mihing thinsung pan in, ngaisutna phangawl, palngul mawna, paktatna, tual that, \wj*   
\p
\v 22 \wj Nguta, duhop na, ngitlona, theam na, maizum heak ngawl na, el na, sonsiat na, kiphatsakna, mawmawt na:\wj*   
\p
\v 23 \wj Hibang a phangawl theampo sia a sung pan a pusuak te hi a, mihing ninsak hi, \wj* ci hi.   
\s1 Canaan Numei nu Upna  
\r Matt. 15:21-28  
\p
\v 24 Tuazawkciang Jesus tua mun pan in ding a, Tyre le Sidon ngamngi sangah pai in, innkhat sungah tum hi, kuama heak tu zong dei ngawl hi: ahihang bucip thei ngawl hi.   
\p
\v 25 Banghangziam cile, doai ngilo vei numeino khat i nu in Jesus thu a zak cing, hongpai in a peang ah bok hi:   
\p
\v 26 Taciang a tanu sung pan doai hawlkhiatsak tu in ngen hi; tua nupi nu sia Greek minam hi a, Syrophenicia ngammi a hihi.   
\p
\v 27 Ahihang Jesus in, \wj Tate ngilva phot tahen: banghangziam cile tate i anluum laksak in, ui piaksak tu ngeina om ngawl hi, \wj* ci hi.   
\p
\v 28 Tua nupi nu in, hi hi, Topa awng: hima kale, tate sabuai pan anneng tak sabuai nuai pan ui in ne thei hi, ci in zo kik hi.   
\p
\v 29 Tasiaciang Jesus in a kungah, \wj Hi thu hang in, pai tan a; na tanu sung pan in doai ngilo pusuak zo hi, \wj* ci hi.   
\p
\v 30 A inn a thet ciang in, a tanu sung pan doai ngilo pusuak zo a, lupna tungah a lum mu hi.   
\s1 Nangong le A Pau Thei Ngawl Khat Damsak  
\p
\v 31 Jesus Tyre le Sidon ngam kiim kot pan pai kik a, Decapolis ngam huam sung teng kantan in Galilee tuili theng hi.   
\p
\v 32 Taciang amate in Jesus kungah nangong le a pau thei ngawl pa khat hong paipui uh a, a tungah khut nga tu in ngen uh hi.   
\p
\v 33 Jesus in tua pa sia mihonpi te kung pan in mundang ah paipui a, a khutzung te a bil lang le lang sungah thun in, cilphi a, a lei zong thamsak hi;   
\p
\v 34 Taciang Jesus vandak to in, a tau zawkciang tua pa kungah, \wj Ephphatha, \wj* ci hi, a khiakna sia, ki hong tahen, a cinopna a hihi.   
\p
\v 35 Tasia pociang in a bil te ki hong in, a lei thangui zong ki phel a, a thiang vaset in pau hi.   
\p
\v 36 Jesus in tua thu kuama tungah son ngawl tu in vaitha hi: ahihang a vaithak tam seseam le nasia va-ial in pualak hi;   
\p
\v 37 Tasiaciang amate in lamdangsa mama uh a, Ama in na theampo a pha in vawt hi: nangong te khua zasak zo a, a pau thei ngawl te zong pausak hi, ci uh hi.   
\c 8  
\s1 Mihing Tul Li Anvak  
\r Matt. 15:32-39  
\p
\v 1 Tuazawkciang a tam mama mihonpi te neak tu nei ngawl hi, taciang Jesus in a nungzui te a kungah sam a,   
\p
\v 2 \wj Mihonpi te hesuakhuai sa khi hi, banghangziam cile amate ka kungah nithum hong om zo a, neak tu bangma nei ngawl hi:\wj*   
\p
\v 3 \wj An ne ngawl in amate innlam zuan in ciasak hileng, amate lamkal ah puk-hong tu hi: banghangziam cile pawlkhat te a khuala mama na pan in hongpai uh hi, \wj* ci hi.   
\p
\v 4 A nungzui te in, hi duisung ah a kua in mihing hi za ngilva tu in vak tu anluum kong pan nga thei tu ziam? ci in zo kik uh hi.   
\p
\v 5 Taciang Jesus in, \wj Anluum bangza nei nu ziam?\wj* ci in dong hi. Amate in sali, ci uh hi.   
\p
\v 6 Jesus in mipi te lei ah to tu in thupia hi: taciang anluum sali la a, lungdam a ko zawkciang phel in, mipi te lui tu in a nungzui te mai ah koi a; a nungzui te in mipi te lui hi.   
\p
\v 7 Amate in ngasa tawm nei hi: Jesus in thupha a piak zawkciang in, mipi te lui tu in thupia hi.   
\p
\v 8 Amate ngilvatak in a neak zawk uh ciang in: anluum neng teng tawm uh a bawm sali dim hi.   
\p
\v 9 A ne te sia tul li kiim pha uh hi: taciang Jesus in amate ciasak hi.   
\p
\v 10 Tuazawk pociang ngunkuang sungah a nungzui te taw tum a, Dalmanutha ngam huam sungah pai uh hi.   
\s1 Musakna Ngen  
\r Matt. 16:1-4  
\p
\v 11 Pharisee te hongpai in, Jesus thu dok kipan uh hi, Ama ze-et tu in vanlam musakna ngen uh hi.   
\p
\v 12 Jesus in a thinsung tawng pan tau vahum in, \wj Banghang in hi minam te in musakna ngen ziam? a tatak in kong ci ciang, hi minam te kungah musakna bangma pia ngawl tu khi hi, \wj* ci hi.   
\p
\v 13 Taciang Jesus in amate nusia in, ngunkuang sungah to kik a ngalkhat ah pai hi.   
\s1 Pharisee le Herod te Tol  
\r Matt. 16:5-12  
\p
\v 14 Nungzuite in anluum ken tu mangil uh a, ngunkuang sungah anluum khat simngawl a dang bangma nei ngawl uh hi.   
\p
\v 15 Jesus in amate tung ah, \wj Pharisee te le Herod i tol pan kidawm vun, \wj* ci in vaitha hi.   
\p
\v 16 Hi thu sia anluum i ken ngawl hang hi, ci in amate kikum uh hi.   
\p
\v 17 Taciang Jesus in a heak ciang in amate tung ah, \wj Anluum na nei ngawl uh hang hi, ci in banghang kikum nu ziam? he ngawl lai in tel thei ngawl lai nu ziam? na thin uh puisak top lai nu ziam?\wj*   
\p
\v 18 \wj Mit nei napi, mu ngawl nu ziam? bil nei napi, za ngawl nu ziam? bangma ciamte ngawl nu ziam?\wj*   
\p
\v 19 \wj Tul nga te sungah anluum nga ka phel lai, a val bawm bangza tawm nu ziam?\wj* ci hi. Amate in, sawmleni, ci uh hi.   
\p
\v 20 \wj Tul li sungah sali ka phel lai in, a val bawm bangza tawm nu ziam?\wj* ci hi. Amate in, sali, ci uh hi.   
\p
\v 21 Jesus in amate tung ah, \wj Bangbang in hi thu he thei ngawl nu ziam? \wj* ci hi.   
\s1 Bethsaida ah Mittaw Pa Khuamusak  
\p
\v 22 Jesus Bethsaida ah hongpai a; amate in mittaw khat a kungah hong paipui uh hi, taciang tua pa a thamsak tu in ngen uh hi.   
\p
\v 23 Jesus in mittaw pa a khut pan in len a, khuapi puasang ah paipui hi; taciang a mitte tungah cilphi in, a khut nga a, khatpo mu na nei ziam, ci in dong hi.   
\p
\v 24 Mittaw pa in en a, mihing te thingkung bang in a vak mu khi hi, ci hi.   
\p
\v 25 Tuazawkciang Jesus in, mittaw pa mit tungah a khut nga kik a, ensak hi: a mit vak in, mihing te thiangtak in mu hi.   
\p
\v 26 Jesus in a inn ah ciasak a, \wj Khuapi sungah tum heak in a, kuama zong son heak in, \wj* ci hi.   
\s1 Peter in Jesus sia Christ Ci Pualak  
\r Matt. 16:13-20; Lk. 9:18-21  
\p
\v 27 Jesus le a nungzui te pai uh a, Caesarea Philippi khuapi kiim khua te ah pai hi: lamkal ah a nungzui te kungah, \wj Ngual in keima sia akua hong ci uh ziam?\wj* ci in dong hi.   
\p
\v 28 Taciang amate in, tuiphumpa John: pawlkhat te in Elijah; a dang te in kamsang khat papo hong ci hi, ci in zo kik uh hi.   
\p
\v 29 Taciang Jesus in amate tung ah, \wj Hi kale, note in, Keima sia kua hi nong ci uh ziam?\wj* ci hi. Taciang Peter in, Nangma sia, Christ na hihi, ci in zo hi.   
\p
\v 30 Tasiaciang in, Ama thu kuama tungah son ngawl tu in nungzui te vaitha hi.   
\s1 Jesus in A Thi Natu Thu Son  
\r Matt. 16:21-23; Lk. 9:21, 22  
\p
\v 31 Jesus in amate thuhil kipan a, mihing Tapa in tam mama thuak tu hi, upa te, thiampi lian te le thukhamhil te in nial tu uh hi, that tu uh a, nithum zawkciang thokik tu hi.   
\p
\v 32 Tua thu Jesus in a kilangtak in son hi. Taciang Peter in Jesus samtuam in tei hi.   
\p
\v 33 Ahihang Jesus in a nungzui te kihei in a le-et kawm in, \wj Satan: nang ka nung ah kiheam in, banghangziam cile Pathian thu sang in, mihing thu kinzaw ni hi, \wj* ci in Peter tei hi.   
\p
\v 34 Taciang Jesus in mihon te le a nungzui te Ama kungah a sap zawkciang in, \wj A kuamapo ka nung hong zui nuam peuma, ama le ama ki nial hen a, ama thinglamte pua in, hong zui tahen.\wj*   
\p
\v 35 \wj Banghangziam cile a kuamapo in, ama nuntakna a hung nuam sia in sum tu hi; ahihang a kuamapo in keima le lungdamna thu hang in a nuntakna a sum peuma in, a nuntakna hu zo tu hi.\wj*   
\p
\v 36 \wj Banghangziam cile mi khat in hileitung buppi a nei hial zong, a thaa nuntakna a sum le bang phatuam ziam?\wj*   
\p
\v 37 \wj Mihing in a thaa nuntakna bang taw theak thei tu ziam?\wj*   
\p
\v 38 \wj Tua ahikom a kuamapo in hi seksol suan te mai ah keima le ka thu a maizumpui peuma; a Pa vangletna sungah a thiangtho vantungmi te taw hongpai ciang in, mihing Tapa in maizumpui kik tu hi, \wj* ci hi.   
\c 9  
\p
\v 1 Jesus in amate tung ah, \wj A tatak in kong ci ciang, hi mun ah a om pawlkhat te in, Pathian kumpingam vangletna taw hongpai a mu dong thina tep tha ngawl tu uh hi.\wj* ci hi.   
\s1 Jesus Meal Kikheal  
\r Matt. 17:1-13; Lk. 9:28-36  
\p
\v 2 Ni luk zawkciang Jesus in, Peter, James le John te mualsang tungah a tuam in sam a, amate mai ah a meal kikheal hi.   
\p
\v 3 A puan taang a, leitung ah koibang puansawp peuma in zong a thiansak thei ngawl tu za dong in; vuk bang in pak hi.   
\p
\v 4 Elijah le Moses te hong ki lang a: Jesus taw ki paupui uh hi.   
\p
\v 5 Peter in Jesus kungah, Syapa awng, eite atu in hi mun ah om tu pha hi: buk thum sa tawng; Nangma atu khat, Moses atu khat le Elijah atu khat, ci hi.   
\p
\v 6 Banghangziam cile amate a laulei uh hu in, bang son tu ci zong a he bua uh hi.   
\p
\v 7 Taciang amate meingo in lia a: meingo sung pan in, hisia ka it ka Tapa a hihi, ama thu ni vun, ci aw khat hong nging hi.   
\p
\v 8 Tasia pociang, amate in a kiim a pam a et uh ciang in, Jesus le amate simngawl kuama a mu bua uh hi.   
\p
\v 9 Amate mualtung pan a tuaksuk uh ciang in, Jesus in, mihing Tapa thina pan in a thawkik dong, a mu uh thu te kuama a son ngawl natu in vaitha hi.   
\p
\v 10 Amate in tua a son thu te ciamte uh a, thina pan thokik, ci kammal sia bang a cinopna hi tu ziam, ci in khat le khat ki dong uh hi.   
\p
\v 11 Taciang a nungzui te in, banghang in thukhamhil te in Elijah hongpai masa tu hi, ci ziam? ci in dong uh hi.   
\p
\v 12 Jesus in, \wj Elijah hongpai masa takpi tu a, na theampo ama in puakhol tu hi; taciang mihing Tapa thu bangbang in atkhol ziam ci le, ama in tam mama thuak tu a, bangma thusimngawl in koi tu hi.\wj*   
\p
\v 13 \wj Ahihang keima in hibang in kong ci hi, Elijah hong theng takpi a, ama thu a ki atkholsa ombang in, amate uk bang in vawt uh hi, \wj* ci hi.   
\s1 Jesus in Patangno Damsak  
\r Matt. 17:14-21; Lk. 9:37-43  
\p
\v 14 A nungzui te kungah hongpai ciang in, thukhamhil te le mihonpi te a kiim ah thu kidong mu hi.   
\p
\v 15 Thakhatthu in, mi theampo in Jesus a mu uh ciang in, lamdangsa uh a, ama sangah hong tai in, paupui uh hi.   
\p
\v 16 Jesus in thukhamhil te kungah, \wj Amate taw bang ki dong nu ziam?\wj* ci in dong hi.   
\p
\v 17 Mihonpi sung pan khat in, Syapa awng, ka tapa sungah a pau thei ngawl doai lut a, na kung hong puak khi hi;   
\p
\v 18 Tua a pau thei ngawl doai in a paipui na mun theampo ah, lei ah puksak in, a kam pan cilphuan te pusuak hi, a ha ngoai in, ngawm law liang hi: na nungzui te hawlkhiasak tu in ka son hang; amate in hawlkhia zo ngawl hi, ci hi.   
\p
\v 19 Jesus in ama zokik a, \wj Maw upna nei ngawl suan te, note taw bang hun dong hong om tu khi ziam? banghun dong hong khual lai tu khi ziam? ama ka kungah hong paipui tavun, \wj* ci hi.   
\p
\v 20 Amate in Jesus kungah paipui uh hi: Jesus a mu ciang in, thaa in patang pa sia thakhatthu in lei ah puksak a; cilphuan te thasak hi.   
\p
\v 21 Jesus in, \wj Hi bang a hi zawk ngei zo ziam?\wj* ci in a pa dong hi. A pa in a no lai pan ma hi zo hi, ci hi.   
\p
\v 22 Taciang ama siatsua tu in, tu le tu mei sungah ahizong, tui sungah ahizong, sep tawntung hi: ahihang khatpo na vawt thei le, kote tungah hesuakna nei in hong hu tan, ci hi.   
\p
\v 23 Jesus in ama kungah, \wj Na um ngam ziam, a umte atu in na theampo suakthei hi, \wj* ci hi.   
\p
\v 24 Tua patang i pa in thakhatthu in, Topa, um khi hi; ka up ngawl na hong hu tan, ci in thitui taw au hi.   
\p
\v 25 Jesus in mihon te tai kawm in hongpai a mu ciang, doai ngilo tung ah, \wj Nang pau thei ngawl le nangong doai, hi sia pa sung pan pusuak tu le tumkik nawn ngawl tu in thu hong pia khi hi, \wj* ci in tei hi.   
\p
\v 26 Tua thaa ngilo au a, patangno kawngkaw cip bang in a omsak zawkciang, a sung pan pusuak hi: taciang ama sia a thi bang in om a; mi tampi in, thi zo hi, ci uh hi.   
\p
\v 27 Ahihang Jesus in a khut pan len in kaito hi; taciang ama ding to hi.   
\p
\v 28 Jesus innsung ah a tum ciang in, a nungzui te in a, banghang in ko te in hawlkhia thei ngawl khu ziam? ci in a tuam in dong uh hi.   
\p
\v 29 Jesus in amate tung ah, \wj Hi bang te sia thungetna le antan na simngawl, thudang taw pusuak thei ngawl hi, \wj* ci hi.   
\s1 Jesus in a Thi natu Thu Sonkik  
\r Matt. 17: 22, 23; Lk. 9:43b-45  
\p
\v 30 Amate tua mun pan Galilee ngam kantan in pai uh a; kuama i heak tu dei ngawl hi.   
\p
\v 31 Banghangziam cile a nungzui te hil a, \wj Mihing Tapa sia ngual khut ah ap tu hi, taciang amate in that tu uh a; a ma a ki thalup zawk nithum ni ciang in thokik tu hi, \wj* ci hi.   
\p
\v 32 Ahihang amate in a son thu telthiam ngawl uh hi napi, dong ngam tuan ngawl uh hi.   
\s1 A Kua Lianbel  
\r Matt. 18:1-6; Lk. 9:46-48  
\p
\v 33 Capernaum khua theng uh a: innsung a tum uh ciang in Jesus in a nungzui te kungah, \wj Lamkal ah bang thu ki nial nu ziam?\wj* ci in dong hi.   
\p
\v 34 Ahihang amate huthe ngawl in om uh hi: banghangziam cile lamkal ah a ki nial uh thu sia, a kua lianbel tu, ci thu ki nial uh hi.   
\p
\v 35 Jesus to suk a, a nungzui sawmleni te sam in, amate tung ah, \wj A kuamapo a masabel nuam le, tua pa sia, a khakbel le mi theampo te naseam hi tu hi, \wj* ci hi.   
\p
\v 36 Taciang Jesus in patangno khat la in, amate lai ah koi hi: a toai zawkciang in, amate tung ah,   
\p
\v 37 \wj A kuama po in keima min taw hibang patang te a sang peuma keima hong sang a hihi, taciang a kuamapo keima hong sang peuma in, keima hong sang hi ngawl in, keima hong sawl pa a sang a hihi, \wj* ci hi.   
\s1 Ei Hong Langpan Ngawl Te  
\r Lk. 9:49, 50  
\p
\v 38 John in, Syapa awng, na min taw doai te a hawlkhia khat ka mu uh a, hong zui ngawl hu in: tho khu hi, ci uh hi.   
\p
\v 39 Ahihang Jesus in, \wj Khak heak vun; banghangziam cile keima min taw na lamdang a vawt khat in, kei hong sonsia mameang ngawl tu hi.\wj*   
\p
\v 40 \wj Banghangziam cile ei hong langpan ngawl peuma ei sangah om hi.\wj*   
\p
\v 41 \wj A tatak in kong ci ciang, a kuapo a hi zong keima mihing na hi uh hang in, ka min taw tui dawn tu hai khat hong pia peuma, a thaman tan ngawl tu hi.\wj*   
\s1 Patang Lamkhialsak Te  
\r Matt. 18:7-9; Lk. 17:1-4  
\p
\v 42 \wj Khat po in keima hong um patangno te sung pan khat lam a khialsak peuma, a ngawng ah an ngoai na suangtum khit in, tuipi thuk na mun ah khiasuk leang ama atu phazaw lai hi.\wj*   
\p
\v 43 \wj Na khut in hong khialsak le, at tan in: bangmahun in a mit ngei ngawl tu hell meisung ah khut lang ni taw pai sang in, pumpi kim ngawl in nuntakna sungah tum tu phazaw hi:\wj*   
\p
\v 44 \wj Tua mei sungah than zong thi ngawl a, mei zong mit ngawl hi.\wj*   
\p
\v 45 \wj Taciang na peang in hong khialsak le, at tan in: bangmahun in a mit ngei ngawl tu hell meisung ah peang lang ni taw pai sang in, pumpi kim ngawl in nuntakna sungah tum tu phazaw hi:\wj*   
\p
\v 46 \wj Tua mei sungah than zong thi ngawl a, mei zong mit ngawl hi.\wj*   
\p
\v 47 \wj Taciang na mit in hong khialsak le, khel keak in: bangmahun in a mit ngei ngawl tu hell meisung ah mit lang ni taw pai sang in, pumpi kim ngawl in nuntakna sungah tum tu phazaw hi:\wj*   
\p
\v 48 \wj Tua mei sungah than zong thi ngawl a, mei zong mit ngawl hi.\wj*   
\p
\v 49 \wj Banghangziam cile khatsim khatsim mei taw hong ki alsak tu hi, taciang biakpiakna theampo zong ci taw ki alsak tu hi.\wj*   
\s1 Ci  
\r Matt. 5:13; Lk. 14:34, 35  
\p
\v 50 \wj Cii sia pha hi: ahihang a al na bo a hile, bangbang in al kiksak thei tu nu ziam? Cii bang in al vun a, khat le khat kilem vadiam in om tavun, \wj* ci hi.   
\c 10  
\s1 Zi Khul Thu  
\r Matt. 19:1-12; Lk. 16:18  
\p
\v 1 Jesus tua mun pan ding in, Jordan ngun ngal khat Judah ngam kimkot teng ah pai hi: mipi te a kungah hong ki kaikhawm kik leleau a; a hil ngei bang in thuhil kik hi.   
\p
\v 2 Pharisee te a kungah hongpai a, pasal khat in a zi khul tu ngeina a om ziam? ci ze-et in dong uh hi.   
\p
\v 3 Jesus in amate tung ah, \wj Moses in note bang thu hong pia ziam?\wj* ci in zo hi.   
\p
\v 4 Taciang amate in, Moses in khul na lai at in, zi khul tu oai hi, ci uh hi.   
\p
\v 5 Jesus in amate tung ah, \wj Moses in na thinpui lei uh hang in hi ngeina a at a hihi.\wj*   
\p
\v 6 \wj Ahihang Pathian in a kipatcil bitphuana hun lai in pa le numei vawt hi.\wj*   
\p
\v 7 \wj Tua ahikom pasal in a pa le a nu nusia tu a, a zi beal tu hi;\wj*   
\p
\v 8 \wj Taciang amate ni sia taksa pumkhat hi tu hi: tua ahikom amate sia ni hi nawn ngawl tu a taksa pumkhat a hi uh hi.\wj*   
\p
\v 9 \wj Tua ahikom Pathian in a ngawm sa te mihing in khen heak tahen, \wj* ci in zo hi.   
\p
\v 10 Innsung ah a nungzui te in tua thu ma dong kik uh hi.   
\p
\v 11 Jesus in amate tung ah, \wj A kuamapo in a zi khul in, ngualdang a tenpui le palngul mawna vawt a hihi.\wj*   
\p
\v 12 \wj Zi in a pasal nusia in, pasal dang a nei kik le, palngul mawna vawt a hihi, \wj* ci hi.   
\s1 Jesus in Patang te Thupha Pia  
\r Mat. 19:13-15; Luk. 18:15-17  
\p
\v 13 Amate in a tate uh a thamsak tu dei in Jesus kungah paipui uh a: a nungzui te in amate tei hi.   
\p
\v 14 Ahihang Jesus in a mu ciang in, a thin-uk a, amate tung ah, \wj Patangno te ka kung hong paisak tavun, khak heak vun: banghangziam cile Pathian kumpingam sia hibang patang te atu a hihi.\wj*   
\p
\v 15 \wj A tatak in kong ci ciang, a kuamapo hibang patangno bang in Pathian kumpingam a sang ngawl peuma, Pathian kumpingam sungah tum ngawl tu hi, \wj* ci hi.   
\p
\v 16 Taciang Jesus in patang te toai a, amate tungah a khut nga in, thupha pia hi.   
\s1 Mihau Tangvalpa  
\r Matt. 19:16-30; Lk. 18:18-30  
\p
\v 17 Jesus lamkal ah a pai laitak in, mi khat hong tai a, khupdin in, Sya pha awng, tawntung nuntakna ka nga thei natu in bang vawt tu khi ziam? ci in dong hi.   
\p
\v 18 Taciang Jesus in ama kungah, \wj Banghang in, pha, hong ci ni ziam? Pathian khatbek simngawl kuama a pha om ngawl hi.\wj*   
\p
\v 19 \wj Thupiak te he ni hi, palngul mawna vawt heak in, tual that heak in, nguta heak in, a man ngawl tettipang heak in, ngual neisa sut heak in, na nu le na pa zakta in, \wj* ci hi.   
\p
\v 20 Taciang tua pa in Jesus kungah, Syapa awng, hite theampo ka no lai pan in zuisiat zo khi hi, ci in zo hi.   
\p
\v 21 Tasiaciang Jesus in ama itna taw en a, \wj Khat bek kisam lai ni hi: pai tan a, na neisa theampo zuak siat in, taciang mizawng te pia in, tua hile vantung ah neisa na nei tu hi: taciang hongpai tan a, thinglamte pua in hong zui tan, \wj* ci hi.   
\p
\v 22 Tua thu hang in ama khuangai mama a, thinna in paisan hi: banghangziam cile a neisa tam mama hi.   
\p
\v 23 Jesus in a kimkot teng en a, a nungzui te kungah, \wj Mihau te Pathian kumpingam sung a tum tu uh bangza in haksa ziam!\wj* ci hi.   
\p
\v 24 Taciang a nungzui te in Jesus i son thu hang in lungmang mamatek uh hi. Ahihang Jesus in amate tung ah, \wj Ka tate awng, hauna a muang te atu in Pathian kumpingam sungah tum tu sia bangza in haksa ziam!\wj*   
\p
\v 25 \wj Mihau pa Pathian kumpingam sungah a tum tu sang in, phin bilvang sungah kala-uk tum tu ol zaw hi, \wj* ci in zo kik hi.   
\p
\v 26 Amate in lamdangsa mamatek uh a, tabang hithong le, a kua peuma ngupna nga thei tu ziam? ci in amate kikum uh hi.   
\p
\v 27 Taciang Jesus in amate en a, \wj Hi thu sia mihing te atu in suak thei ngawl hi, ahihang Pathian atu in hi ngawl hi: banghangziam cile Pathian atu in na theampo suak thei hi, \wj* ci hi.   
\p
\v 28 Tuazawkciang in Peter in, Jesus kungah, en in, kote ka hi uh le na theampo nusia in kong zui uh hi, ci hi.   
\p
\v 29 Jesus in, \wj A tatak in kong son hi, a kuamapo keima le lungdamna thu hang in a inn le lo a hi zong, a u le a nau a hi zong, a nu le a pa a hi zong, a zi le a ta te a hi zong, a nusia a hile, \wj*   
\p
\v 30 \wj Tu hun in inn le lo hi kale, nu te hi kale, u le nau hi kale, tate hi kale, vawtsiatna tatuam taw a se za in sang tu a; hongpai lai tu hun ah tawntung nuntakna sang tu hi.\wj*   
\p
\v 31 \wj Ahihang a masabel te nungkhakbel tu a; a nungkhakbel te masabel hi tu hi, \wj* ci hi.   
\s1 Jesus in a Thi tu Thumvei na Son  
\r Matt. 20:17-19; Lk. 18:31-34  
\p
\v 32 Amate Jerusalem pai na lamkal ah hi uh a; Jesus amate mai ah pai hi: taciang amate in lamdangsa in, a nung pan zui kawm in lau tek mama uh hi. A nungzui sawmleni te sam a, a tungah thupiang tu te son kipan hi,   
\p
\v 33 \wj En vun, Jerusalem sangah i pai hi; mihing Tapa sia thiampi lian te le thukhamhil te kungah ap tu hi; amate in thi tu in thukhen tu uh a, Gentile te kungah ap tu uh hi:\wj*   
\p
\v 34 \wj Amate in selno tu a, vel in cilphi tu uh hi, taciang that tu uh a: nithum ni ciang in thokik tu hi, \wj* ci hi.   
\s1 Zebedee Zi in a Tate atu Jesus Kung ah Ngetsak  
\r Matt. 20:20-28  
\p
\v 35 Zebedee tapa James le John te Jesus kungah hongpai uh a, Syapa awng, kong nget tu uh sia nong vawtsak tu ka uk uh hi, ci uh hi.   
\p
\v 36 Jesus in amate tung ah, \wj No atu in bang hong vawtsak tu khi ziam?\wj* ci hi.   
\p
\v 37 Amate in, na minthanna sungah khat na ziatsang ah, a dang khat na veisang ah hong tosak tan, ci uh hi.   
\p
\v 38 Hi kamale, Jesus in, \wj Bang ngen nu ziam ci zong he ngawl nu hi: ka dawn tu hai dawn zo tu nu ziam, ka san tu baptisma sang zo tu nu ziam?\wj* ci hi.   
\p
\v 39 Amate in, zo tu khu hi, ci uh hi. Jesus in, \wj Ka dawn tu hai dawn takpi tu nu hi, ka san tu baptisma zong sang takpi tu nu hi:\wj*   
\p
\v 40 \wj Ahihang ka ziatsang le ka veisang a to tute sia kei i piak tu hi ngawl a; ka Pa in a ngealkholsa te pia tu hi, \wj* ci hi.   
\p
\v 41 Tua thu a dang sawm te in a zak uh ciang in, James le John tungah a lung uh kim ngawl hi.   
\p
\v 42 Ahihang Jesus in amate tung ah, \wj Na heak uh bang ma in Gentile kumpi te in a mihing te sia zawthawk thu taw uk uh a, ulian te in mipi te tungah thuneina zang tawntung uh hi.\wj*   
\p
\v 43 \wj Ahihang no sungah hibang hi ngawl tu hi: note sungah khatpo a lian nuam le, note i naseam hi tahen:\wj*   
\p
\v 44 \wj Note sung pan khatpo in a lu bel a hi nuam le, note i sila hi tahen.\wj*   
\p
\v 45 \wj Mihing Tapa sia ngual a sawl tu in hongpai ngawl hi, ngual atu seam tu in le mi tampi tatkhiat natu a nuntakna pia tu in hongpai hi, \wj* ci hi.   
\s1 Jesus in Mittaw Bartimaeus Khuamusak  
\r Matt. 20:29-34; Lk. 18:35-43  
\p
\v 46 Jesus le a nungzui te Jericho ah hongpai uh a: amate mihon tampi taw Jericho pan a pusua uh ciang in, Timaeus i tapa, Bartimaeus a kici mittaw pa sia lamhui ah to in khutdaw ngen hi.   
\p
\v 47 Ama in Nazareth khua mi Jesus hi, ci a zak ciang in, David Tapa Jesus awng, hong hesuak kapo in, ci in au hi.   
\p
\v 48 Mi tampi te in ama a om khikhep natu in tei uh hi kale: Nang David Tapa awng, hong hesuak kapo in, ci in au seseam hi.   
\p
\v 49 Jesus ding a, ama sam tu in thupia hi. Amate in mittaw pa kungah, thinnuam in a, ding in; Ama in hong sam hi, ci uh hi.   
\p
\v 50 A puantual sil sia khia in, ding a, Jesus kungah pai hi.   
\p
\v 51 Jesus in ama zo a, \wj Nang tungah bang ka vawt tu uk ni ziam?\wj* ci hi. Mittaw pa in, Topa awng, ka mit khua mu tu uk khi hi, ci hi.   
\p
\v 52 \wj Jesus in ama kungah, pai in; na upna in hong damsak zo hi, \wj* ci hi. Tasia pociang in khuamu a, lampi ah Jesus nungzui hi.   
\c 11  
\s1 Jerusalem ah Minthanna taw Tum  
\r Matt. 21:1-11; Lk. 19:28-40; Jn. 12:12-19  
\p
\v 1 Amate Jerusalem hong nai ciang, Olive mual a om Bethphage le Bethany a thet uh ciang in, Jesus in nungzui te ni sawl in,   
\p
\v 2 \wj Na mai uh ah pai tavun a: khuasung na tum uh pociang kuama to ngei ngawl lai laano a ki khitsa in mu tu nu hi; a khau sut vun a, ka kungah paipui tavun.\wj*   
\p
\v 3 \wj Khat po in banghang hibang ngamta nu ziam? hong ci le, Topa in tulmaw hi; ci vun, tasia pociang hong paisak pai tu hi, \wj* ci hi.   
\p
\v 4 Amate pai uh a, lampi kisiktua na mun kongkha hui a puasang ah laano a ki khit mu uh hi; taciang sut uh hi.   
\p
\v 5 Tua mun ah a ding te in, banghang in laano sut nu ziam? ci uh hi.   
\p
\v 6 A nungzui te in Jesus thupiak sa bang in a son uh ciang: amate in paisak uh hi.   
\p
\v 7 Amate in laano sia Jesus kungah hong paipui uh a, a tungah puan te pha hi; taciang Jesus a tungah to hi.   
\p
\v 8 Mi tampi te in lampi ah a puan uh te pha uh a: midang te in zong thingbak te sat in lampi tungah pha uh hi.   
\p
\v 9 A mai ah a pai te le a nung pan a zuite in, Hosanna; Topa min taw hongpai pa thuphatoai a hihi:   
\p
\v 10 I pa David kumpingam in thupha nga tahen, Topa min taw hongpaipa: a sangbelna ah Hosanna, ci in au uh hi.   
\p
\v 11 Taciang Jerusalem biakinn sungah tum uh a: na theampo a et zawk, nitaksang ciang in, nungzui sawmleni te taw Bethany khua ah pai tek uh hi.   
\s1 Theikung Hamsiatna  
\r Matt. 21:18, 19  
\p
\v 12 A zingciang Bethany khua pan amate a paikik uh ciang in, Jesus a ngilkial hi:   
\p
\v 13 A ngalkhat pan in a te puitung mama theikung khat mu a, a nga a om tha le, ci in pai hi: a bul a thet ciang in, a te simngawl bangma mu ngawl hi; banghangziam cile a nga hun hi ngawl hi.   
\p
\v 14 Jesus in tua theikung sia, \wj Kuama in bangmahun in na nga ne nawn heak tahen, \wj* ci hi. A nungzui te in zong za uh hi.   
\s1 Biakinn Thiangthosak  
\r Matt. 21:12-17; Lk. 19:45-48; Jn. 2:13-22  
\p
\v 15 Amate Jerusalem ah hongpai uh a: Jesus biakinn sungah tum hi, biakinn sungah vanzuak te le a lei te nawtkeak in, sum theak te sabuai te le vakhu zuak te i tokhum te lawnthal siat hi;   
\p
\v 16 Biakinn hui pan zong kuama vanpua kawm in tawnsak nawn ngawl hi.   
\p
\v 17 Jesus in, \wj Ka inn sia minam theampo in thungetna inn, ci tu uh hi, ci atkhol hi ngawl ziam? ahihang note in nguta te kua in na vawt uh hi, \wj* ci hil hi.   
\p
\v 18 Tua thu thukhamhil te le thiampi lian te in a zak uh ciang in, Jesus bangbang in that thei tu, ci in zong tek uh hi: banghang in amate in Jesus lau ziam cile, mi theampo in a hilna lamdang asak uh hang a hihi.   
\p
\v 19 Nitak sang ciang in Jesus khuapi sung pan in pusuak hi.   
\s1 Theikung Ko  
\r Matt. 21:18-22  
\p
\v 20 A zingsang ciang lampi ah a pai uh kawm in, amate in theikung sia a sungpan kipan a ko siat mu hi.   
\p
\v 21 Peter in phawkkik a, Jesus kungah, Syapa awng, en in, na hamsiat theikung sia ko siat zo hi, ci hi.   
\p
\v 22 Taciang Jesus in amate tung ah, \wj Pathian sungah upna nei vun.\wj*   
\p
\v 23 \wj Banghangziam cile, a mantak in kong ci hi, a kuamapo in, a thinsung ah uplakna nei ngawl in, a pau bang in a vekpi piang tu hi; ci upna taw hi mual tung ah, ki khin in a, tuipi sungah ki khiasuk in; a ci le a ci bang in piang tu hi.\wj*   
\p
\v 24 \wj Tua ahikom kong ci hi, thu na nget uh ciang in, na dei uh theampo sia nga khi hi, ci na um uh le na nga tu uh hi.\wj*   
\p
\v 25 \wj Thu na nget tu uh ciang in, khatpo i tungah diksak ngawl na na nei uh le, maisak vun: tabang in vantung a om na Pa uh zong in na vawtkhial uh te hong maisak tu hi.\wj*   
\p
\v 26 \wj Ahihang note in ngual khialna te na maisak bua uh le, vantung a om na Pa uh in note khial na zong hong maisak ngawl tu hi, \wj* ci hi.   
\s1 Jesus Thuneina Ki Dong  
\r Matt. 21:23-27; Lk. 20:1-8  
\p
\v 27 Amate Jerusalem ah hongpaikik uh a: biakinn sungah Jesus a pai laitak in, thiampi lian te, thukhamhil te le upa te a kungah hongpai uh a,   
\p
\v 28 Ama tung ah, bang thuneina taw hibang nate vawt ni ziam? hibang nate vawt tu in a kua in hibang thuneina hong pia ziam? ci uh hi.   
\p
\v 29 Tasiaciang in Jesus in amate tung ah, \wj Kei zong thu khat hong dong tu khi hi, hong zo tavun, hibang te bang thuneina taw vawt khi ziam, ci kong son tu hi, \wj* ci zo hi.   
\p
\v 30 \wj John i tuiphumna a piak sia, vantung pan ziam, mihing tung pan ziam? hong zo tavun, \wj* ci hi.   
\p
\v 31 Amate kikum uh a, vantung pan ci leang; ama in banghang ama um ngawl nu ziam? hong ci tu hi.   
\p
\v 32 Ahihang, mihing tung pan hi, ci tu hile; amate in mipi te lau hi: banghangziam cile mi theampo in John sia kamsang tatak hi, ci ngaisun tek uh hi.   
\p
\v 33 Taciang amate in Jesus kungah, hong son thei ngawl khu hi, ci uh hi. Tasiaciang Jesus in amate tung ah, \wj Hibang te bang thuneina taw vawt khi ziam ci keizong kong son bua tu hi, \wj* ci in zo hi.   
\c 12  
\s1 Sapit Huan Naseam te Sontena  
\r Matt. 21:33-46; Lk. 20:9-19  
\p
\v 1 Jesus in thu sontena te zang in amate thuhil pan hi. \wj Mi khat in sapit huan sungah sapit cing a, a huang um in sapit sukna tu dum zong to hi, taciang teitan zong sa a, huan naseam tu te zawn in ama a khuala mama na ah khualhaw hi.\wj*   
\p
\v 2 \wj A hun a cin ciang in, huan naseam te kung pan a nga te la tu in a naseam te khat sawl hi.\wj*   
\p
\v 3 \wj Amate in man in vel uh a, khut nguak in tha kik uh hi.\wj*   
\p
\v 4 \wj A dang naseam khat sawl kik leleau hi; tua pa sia suangtum taw sep in a lu zong liam hi, taciang maizum huaitak in tha kik uh hi.\wj*   
\p
\v 5 \wj Taciang a dang khat sawl kik leleau a; amate in tua pa that uh hi, a dang tampi te zong vel in that uh hi.\wj*   
\p
\v 6 \wj Tua ahikom a it mama a tapa khat a neisun sia, amate in ka tapa sia zakta tu uh hi, ci in, a khakbel ciang in paisak hi.\wj*   
\p
\v 7 \wj Ahihang lo naseam te in, hisia pa a ngamhlua tu pa hi; pai tavun, ama that tawng, a ngamh teng eima a hi tu hi, ci in kikum uh hi.\wj*   
\p
\v 8 \wj Taciang amate in a tapa man in, that uh a, sapit huan puasang ah vawk hi.\wj*   
\p
\v 9 \wj Tua ahikom sapit huan nei topa in bangbang vawt tu ziam? ama hongpai tu a huan naseam te siatsua tu hi, taciang sapit huan sia ngualdang te kungah pia tu hi.\wj*   
\p
\v 10 \wj Innsa te in a nil uh suangtum sia innbul thupibel suak hi:\wj*   
\p
\v 11 \wj Hi thu in Topa i vawt hi a, i mu na ah, lamdang mama hi, ci in Lai Thiangtho sungah simngei ngawl lai nu ziam?\wj* ci hi.   
\p
\v 12 Amate in, sontena a son te amate a cinopna hi, ci he ahikom in, Jesus sia mat sawm napi: mipi te lau a hi uhkom in Jesus paisan uh a, a kung pan in kiheam siat uh hi.   
\s1 Caesar Shia Piak Tu Thu  
\r Matt. 22:15-22; Lk. 20:20-26  
\p
\v 13 Amate in Jesus a kampauna pan man tu in, Pharisee te pawlkhat le Herod pawl te sawl uh hi.   
\p
\v 14 Amate hongpai uh ciang in Jesus kungah, Syapa awng nangma sia thutang ni hi, kuama zong lau ngawl le mihing te maitang zong en ngawl in Pathian thutak lampi hil ni hi, ci kong he uh hi: Caesar kungah shia piak tu sia ngeina a hi ziam, hi ngawl ziam?   
\p
\v 15 Pia tu khu ziam maw, a hibale pia ngawl tu khu ziam? ci hi. Ahihang Jesus in amate ki hitheamsak he ahikom, \wj Banghang in hong ze-et nu ziam? dangka khat paipui tavun, en tu khi hi, \wj* ci hi.   
\p
\v 16 Taciang amate in paipui uh hi. Jesus in, \wj Hi lim le ceptena sia a kua ziam?\wj* ci hi. Amate in, Caesar le ceptena hi, ci uh hi.   
\p
\v 17 Taciang Jesus in amate tung ah, \wj Caesar neisa te Caesar pia vun a, Pathian neisa te Pathian pia vun, \wj* ci in zo hi. Taciang amate in Jesus lamdangsa mama uh hi.   
\s1 Thawkikna Thu  
\r Matt. 22:23-33; Lk. 20:27-40  
\p
\v 18 Thawkikna om ngawl hi; a ci Sadducee te Jesus kungah pai in, thu dong uh a,   
\p
\v 19 Syapa awng, mi khat a suapuipa a thi ciang in, a zi ta nei ngawl in a nusia le, a thi pa i cimit ngawl natu in a nau in a mo tenpui hen, ci Moses in hong ci hi.   
\p
\v 20 U nau sali om uh a: a lianbel sia in zi nei napi, ta nei ngawl in thi hi.   
\p
\v 21 A nina pa in tua nu tenpui a, ta nei ngawl ma in thi hi: a thumna zong tabangma hi.   
\p
\v 22 A sali bup in tua nu tenpui uh a, kuama in ta a nei bua uh hi: a khakbel ciang in tua nu zong thi hi.   
\p
\v 23 Tua ahikom thawkikna ni, amate a thawkik uh ciang in, tua nu sia a kua zi hi tu ziam? banghangziam cile a sali bup in tenpui hi, ci uh hi.   
\p
\v 24 Jesus in amate tung ah, \wj Lai thiangtho le Pathian vangletna na heak ngawl uh hang in, khial hi ngawl nu ziam?\wj*   
\p
\v 25 \wj Banghangziam cile, amate thina pan a thawkik ciang in, kipui na le nupa tu in ki piak ci bang om nawn ngawl tu a; vantungngam ah vantung mite bang i hi tu hi.\wj*   
\p
\v 26 \wj Mithi te thawkik na thu taw kisai in: Moses laibu sungah, Pathian in lopa phung sung pan Moses a son na ah, Keima sia Abraham Pathian, Isaac Pathian le Jacob Pathian ka hihi, a ci na simngei ngawl nu ziam?\wj*   
\p
\v 27 \wj Pathian sia mithi te Pathian hi ngawl a, a nungta te Pathian a hihi: tua ahikom note nasiatak in khial nu hi, \wj* ci in zo hi.   
\s1 A Lianbel Thupiak  
\r Matt. 22:34-40; Lk. 10:25-28  
\p
\v 28 Amate in tua thu a kikup uh thukhamhil te sung pan khat in a zak ciang in, Jesus in phatak in zo hi, ci a heak ciang, a kungah pai a, thupiak theampo sung pan a masabel bang ziam? ci in dong hi.   
\p
\v 29 Jesus in ama kungah, \wj Thupiak theampo sung pan a masabel sia, ngai vun, Maw Israel; Topa i Pathian bek Topa hi:\wj*   
\p
\v 30 \wj Topa na Pathian sia na thinsung theampo, na nuntakna theampo, na ngaisutna theampo le na hatna theampo taw it in: hi sia in a masabel thupiak a hihi.\wj*   
\p
\v 31 \wj Taciang a ni na sia, a khatna taw a kibang hi a, nangma le nangma na ki it bang in na innpam it tu ni hi. Hi te sang in a lianzaw thupiak om nawn ngawl hi, \wj* ci in zo hi.   
\p
\v 32 Thukhamhil pa in Jesus kungah, pha hi, Syapa awng, nang thutak son ni hi: banghangziam cile Pathian khatbek om a; Ama simngawl a dang om ngawl hi:   
\p
\v 33 Taciang Ama sia, thinsung theampo le heakna theampo, nuntakna theampo le hatna theampo taw it tu a hihi, taciang ama le ama a ki it bang in a innpam zong a it tu hi, tua thu sia meihal biakpiakna le sangaw biakpiakna theampo sang in thupi zaw hi, ci hi.   
\p
\v 34 Tua pa in pilvangtak in a zo kik Jesus in a mu ciang in, ama tung ah, \wj Nangma sia Pathian kumpingam taw na ki khuala bua hi, \wj* ci hi. Tuazawkciang kuama in Jesus thu a dong ngam nawn bua uh hi.   
\s1 Christ Kua Tapa Ziam?  
\r Matt. 22:41-45; Lk. 20:41-44  
\p
\v 35 Jesus in, biakinn sungah thu a hil laitak in, \wj Bangbang in thukhamhil te in Christ sia David Tapa ci thei ziam?\wj*   
\p
\v 36 \wj Banghangziam cile David in Tha Thiangtho taw in ama le ama a kici na ah, Topa in ka Topa kungah, na ngal te na peang ngakna in ka vawt mateng ka ziatsang ah to in, ci hi.\wj*   
\p
\v 37 \wj Tua ahikom David in ama le ama sia Topa kici a hile; bangbang in a tapa hi thei tu ziam?\wj* ci in zo hi. Mihonpi in lawptak in ngai tek uh hi.   
\p
\v 38 Jesus in a hil na ah, \wj Thukhamhil te kidawm vun, amate sia puantualpui taw vak nuam sap uh a, sumbuk te ah paupui na te, \wj*   
\p
\v 39 \wj Syngogues sungah tokhum tungnung te le poai mun theampo ah a sangbel inn doi te dei uh hi:\wj*   
\p
\v 40 \wj Amate in meingong te inn zawthawk thu taw sut uh a, a sau mama thu ki ngensak hi: tua ahikom hi te in a lian zaw dan thuak tu uh hi, \wj* ci hi.   
\s1 Meingong nu Sumpi  
\r Lk. 21:1-4  
\p
\v 41 Jesus sumpi kuang mai ah to a, ngual in sumpi kuang sungah bangbang in sumpi khia ziam, ci in en hi: mihau tampi te in tampitak khia uh hi.   
\p
\v 42 Taciang a zawng meingongnu khat hongpai a, a son thamman ngawl dangka tang ni khia hi.   
\p
\v 43 Taciang Jesus in a nungzui te a kungah sam a, \wj A mantak in kong son hi, hi a zawng meingong nu in sumpi kuang sungah a khia theampo sang in a tamzaw khia hi:\wj*   
\p
\v 44 \wj Banghangziam cile, amate sia a dimlet a nei uh sung pan in khia uh hi; ahihang meingong nu a hile, a kivak natu kisam kawm pan in a nei theampo khia hi, \wj*   
\c 13  
\s1 Biakinn Suksiat Natu Thu  
\r Matt. 24:1, 2; Lk. 21:5, 6  
\p
\v 1 Jesus biakinn sung pan a pusua ciang in, a nungzui te sung pan khat in, Syapa awng, en in, hi suangtum te bangbang in kiphut le bangbang a kisa innpi te ziam? ci hi.   
\p
\v 2 Jesus in ama kungah, \wj Hi inn lianpui te na mu ziam? suangtum kithuap khat zong om nawn ngawl in ki lawnthal siat lai tu hi, \wj* ci hi.   
\s1 Hunbo natu Musakna Te  
\r Matt. 24:3-14; Lk. 21:7-19  
\p
\v 3 Jesus biakinn ngalkhat Olive mualtung ah a to laitak in, Peter, James, John le Andrew te in,   
\p
\v 4 Hi thu te banghun ciang in piang tu ziam, hong son tan? ci in a tuam in dong uh hi.   
\p
\v 5 Jesus in amate tung ah, \wj Kuama i hong theam ngawl natu in kidawm vun:\wj*   
\p
\v 6 \wj Banghangziam cile ka min taw mi tampi hongpai tu uh a, keima in Christ ka hihi; ci in mi tampi theam tu hi.\wj*   
\p
\v 7 \wj Taciang ngal ki do le ngal kisim natu thu te na zak uh ciang in thinngim heak vun: banghangziam cile tabang theampo sia a piang kul hamtang hi a; a tawpna tu hi ngawl lai hi.\wj*   
\p
\v 8 \wj Banghangziam cile minam khat le khat kido tu uh a, kumpingam khat le khat ki sim tu hi: mun tatuam ah zinling tu a, kial le haksatna te om tu hi: hi te sia ngimna te i kipatna a hihi.\wj*   
\p
\v 9 \wj Hi kamale noma le noma kidawm vun: banghangziam cile amate in hausa zum ah hong ap tu uh hi; taciang synagogue sungah zong hong vel tu uh a: keima hang in le amate atu tetti hitu in, ngam uk te le kumpi te mai ah hong paipui tu uh hi.\wj*   
\p
\v 10 \wj Lungdamna thu sia minam theampo sungah ki son masa tu hi.\wj*   
\p
\v 11 \wj Ahihang amate paipui in hong ap uh ciang, na pau tu uh ngaisun khol heak vun, ngeal zong ngealkhol heak vun: ahizong a hun ciang in hongpiak babang in pau vun: banghangziam cile tua te sia no i pau hi ngawl in, Tha Thiangtho hi.\wj*   
\p
\v 12 \wj Unau zong thi tu in ki zuak tu hi, a pa zong in a tapa zuak tu a; tate in a nu le a pa ding in langpan tu uh a, thina ciangdong ki then tu uh hi.\wj*   
\p
\v 13 \wj Mi theampo in Keima min hang in hong ensan tu uh hi: hi kamale a tawp dong in a thuakzo sia, ki ngum tu hi. \wj*   
\s1 Kum Sali Ngimna  
\r Matt. 24:15-28; Lk. 21:20-24  
\p
\v 14 \wj Ahihang kamsang Daniel sonkholna bang in a lipkhaphuai sia a kilawm ngawl na mun ah na mu uh ciang in, (a sim te in tel ta uh hen) Judah ngam sungah a omte mual tung pan in tai tahen:\wj*   
\p
\v 15 \wj Innkhum tung a omte inn sungah van la tu in tuaksuk nawn heak hen:\wj*   
\p
\v 16 \wj Lo sung a omte in a puan la tu in cia nawnheak hen.\wj*   
\p
\v 17 \wj Ahihang tua ni ciang naupai te le nau noailuai te haksa mama tu uh hi!\wj*   
\p
\v 18 \wj Na tai tu uh hun sia phalbi sung a hi ngawl natu in thungen vun.\wj*   
\p
\v 19 \wj Banghangziam cile tua hun ciang hong theng tu ngimna sia, Pathian in a kipatcil bitphuana pan kipan tuning dong om ngei ngawl lai a, maisang ah zong om kik nawn ngawl tu hi.\wj*   
\p
\v 20 \wj Tua hun le ni te Topa in tomsak ngawl hile, kuama suakta ngawl tu hi: ahihang a tealsa te atu in, tua ni te tomsak hi.\wj*   
\p
\v 21 \wj Taciang khatpo in, en vun, Christ ziak ah om hi; a hibale, zesung ah om hi; hong ci le um heak vun:\wj*   
\p
\v 22 \wj Banghangziam cile Christ phaw sil te le leilot kamsang te hong theng tu uh a; a hi thei le a tealsa te zong theam tu in musakna le nalamdang tampi lak tu uh hi.\wj*   
\p
\v 23 \wj Ahihang kidawm vun: en vun, hi thu te hong sonkhol zo khi hi.\wj*   
\s1 Mihing Tapa Hong Paikik Natu Thu  
\r Matt. 24:29-31; Lk. 21:25-28  
\p
\v 24 \wj Ahihang haksatna teng zawk, tua hun le ni te sungah, ni hong mial tu a, tha zong tang ngawl tu hi, \wj*   
\p
\v 25 \wj Van ah aksi te zong tak tu a, vantung vangletna te zong ki thing tu hi.\wj*   
\p
\v 26 \wj Tuazawkciang in mihing Tapa sia minthang vanglian taw meingo pan hong tuak amate in mu tu uh hi.\wj*   
\p
\v 27 \wj Taciang leitung mongkhat pan in van mongkhat dong, leitung kingli pan a tealsa te kaikhawm tu in, Ama vantungmi te sawl tu hi.\wj*   
\s1 Theikung Sontena  
\r Mat. 24:32-35; Luk. 21:29-33  
\p
\v 28 \wj Theikung pan in sontena khat sin vun; a bak te pan in a dawnmoi te hong sua ciang khal hong nai zo hi, cina he uh hi:\wj*   
\p
\v 29 \wj Tasia bangma in hibang te na mu uh ciang in, a hun hong nai mama zo a, kongbiang kung tatak ma hong theng zo hi, ci he tavun.\wj*   
\p
\v 30 \wj A tatak kong ci ciang, hibang te theampo a piansiat mateng, hi suan le pal te bo siat ngawl tu hi.\wj*   
\p
\v 31 \wj Van le lei bo tu hi: ahihang ka kammal te a bo bua tu hi.\wj*   
\s1 Kuama in A Hun He Ngawl Hi  
\r Matt. 24:36-44; Lk. 17:26-30, 34-36  
\p
\v 32 \wj Ahizong tua ni le hun sia kuama in he ngawl hi, vantungmi te in zong he ngawl hi, Ka Pa bek in he hi.\wj*   
\p
\v 33 \wj Kinging khol vun a, ngak in thungen vun: banghangziam cile a hun na he bua uh hi.\wj*   
\p
\v 34 \wj Banghangziam cile, mihing Tapa sia, khual khuala mama a haw khat, a inn a om naseam te thuneina pia in, mi theampo amate nasep tek seam tu le kongcing te zong cingsak in a nusia pa taw kibang hi.\wj*   
\p
\v 35 \wj Tua ahikom, note ngak nginge vun, banghangziam cile, innteakpa sia nitak sang, a hibale zan laitak, a hibale akkhuan hun, a hibale zingsangkuan, banghun theng tu ci na he bua uh hi:\wj*   
\p
\v 36 \wj A hibale thakhatthu hong theng le na mut laitak hong si tu hi.\wj*   
\p
\v 37 \wj Ngak nginge vun, ci note kong son bang ma in, mi theampo son khi hi.\wj*   
\c 14  
\s1 Jesus That tu in Kikum Ku  
\r Matt. 26:1-5; Lk. 22:1, 2l; Jn. 11:45-53  
\p
\v 1 Paisanpoai le tolsaw ngawl anluum poai tu, ni ni a kisap ciang in: thiampi lian te le thukhamhil te in Jesus sia bangbang man in that thei tu ci thimtheltak in kikum uh hi.   
\p
\v 2 Ahihang amate in mipi te buaisak ngawl in poai ni ci bua tawng, ci uh hi.   
\s1 A Manham Sathau Namtui  
\r Matt. 26:6-16; Jn. 12:1-8  
\p
\v 3 Jesus sia Bethany khua miphak Simon inn ah anne in a om laitak, numei khat a manham mama alabaster sathau namtui thawl khat keng in hongpai a, a palang sutham in, Jesus lutung ah buak hi.   
\p
\v 4 Tua mun ah a om pawlkhat te a thin-uk uh a, banghang in hi sathau namtui sia pakvawt ziam?   
\p
\v 5 Banghangziam cile ta sia dangka zathum sang in a tamzaw taw zuak in, mizawng te pia leang pha hi, ci uh hi. Taciang amate in numei nu langpan in phun uh hi.   
\p
\v 6 Jesus in, \wj Ama thu in omsak po vun; banghang in nawngkaisak nu ziam? ama in ka tungah na pha vawt hi.\wj*   
\p
\v 7 \wj Banghangziam cile mizawng te sia noma taw om tawntung hi, taciang na ukhun uh po in amate tungah napha vawt thei nu hi: ahihang kei ka hile no kungah hong om tawntung ngawl khi hi.\wj*   
\p
\v 8 \wj Ama in a vawt thei za vawt hi: ka luanghawm vui natu ama in sathau namtui buakkhol hi.\wj*   
\p
\v 9 \wj A tatak in ka ci ciang, leitung mun tatuam lungdamna thu ki son na theampo ah hi numei nu i vawt thu zong ama phaw tawntung natu in kison tu hi, \wj* ci hi.   
\s1 Judah Iscariot in Jesus Leheak  
\r Matt. 26:14-16; Lk. 22:3-6  
\p
\v 10 Taciang, nungzui sawmleni sung pan khat, Judah Iscariot sia, thiampi lian te kungah Jesus ap tu in pai hi.   
\p
\v 11 Amate in a zak uh ciang in, lungdam mama uh a, dangka piak tu in kamciam pia hi. Taciang ama in bangbang ap thei tu, ci hunpha zong tawntung hi.   
\s1 Paisanpoai  
\r Matt. 26:17-25; Lk. 22:7-14, 21-23; Jn. 13:21-30  
\p
\v 12 Paisanpoai tuuno ki ngaw ni, tol saw ngawl anluum poai ni masabel ni in, a nungzui te in Jesus kungah, paisanpoai na anneak natu mun koisung ah pai in vawtkhol tu dei ni ziam? ci uh hi.   
\p
\v 13 Tasiaciang a nungzui te ni sawl a, \wj Khuapi sungah pai tavun a, tuibeal taw tui pua khat mu tu nu hi: ama zui vun.\wj*   
\p
\v 14 \wj Ama tum na innteakpa kungah, Syapa in, ka nungzui te taw paisanpoai an ka neak natu mun leangna inndoi koisung ziam? ci vun.\wj*   
\p
\v 15 \wj Tua hile ama in inntung doituam zai mama eite atu in, a ki puakholsa in a om hong lak tu hi, \wj* ci hi.   
\p
\v 16 A nungzui te pai uh a, khuapi sung a thet uh ciang in, Jesus sonkhol bang in mu uh hi: amate in paisanpoai atu in vawtkholsiat uh hi.   
\p
\v 17 Taciang nitak sang ciang in Jesus a nungzui sawmleni te taw hongpai hi.   
\p
\v 18 Amate to uh a an a neak tek uh laitak in, Jesus in, \wj A tatak kong ci ciang, note sung pan khat, keima taw anne sia in hong leheak tu hi, \wj* ci hi.   
\p
\v 19 Tasiaciang amate khuangai mama uh a, khat zawkciang khat in Jesus kungah, kei ka hi ziam? a dang khat in, kei ka hi ziam? ci tek uh hi.   
\p
\v 20 Jesus in amate tung ah, \wj Sawmleni sung pan khat, keima taw kuangsung ah a sawkkhawm sia hi.\wj*   
\p
\v 21 \wj Ama thu a ki atkholsa bang in: mihing Tapa sia pai hamtang tu hi, ahihang mihing Tapa a leheak sia, a mailam bing hi! piang bua zaw le ama atu phazaw hi, \wj* ci zo kik hi.   
\s1 Topa Nitak An  
\r Matt. 26:26-30; Lk. 22:14-20; I Cor. 11:23-25  
\p
\v 22 Amate a neak tek uh laitak, Jesus in anluum la a thupha a piak zawkciang in, phel hi, taciang amate pia a, \wj La vun a, ne vun: hisia in ka pumpi hi, \wj* ci hi.   
\p
\v 23 Taciang hai zong la a, lungdam a ko zawkciang in, amate pia hi: taciang a vekpi in dawn tek uh hi.   
\p
\v 24 Taciang amate tung ah, \wj Hisia in thuciamthak taw kisai in mi tampi atu a luang ka thisan a hihi.\wj*   
\p
\v 25 \wj A mantak ka ci ciang, hibang sapittui thak sia, ka Pa kumpingam sungah note taw ka dawn kik mateng bangmahun in ka dawn nawn batu hi, \wj* ci hi.   
\p
\v 26 Taciang amate la asak zawk uh ciang in, Olive mualtung sangah paito uh hi.   
\s1 Peter in Jesus a Nial na Thu  
\r Matt. 26:31-35; Lk. 22:31-34; Jn. 13:36-38  
\p
\v 27 Taciang Jesus in amate tung ah, \wj Tuucingpa ka that tu a, tuu te peakkeak siat tu hi, ci a ki atkhol bangma in, tu zan in note theampo in keima hang in na thin uh no mama tu hi.\wj*   
\p
\v 28 \wj Ahihang ka thawkik zawkciang in, Galilee ah note mai ah pai tu khi hi, \wj* ci hi.   
\p
\v 29 Ahihang Peter in, mi theampo nangma hang in thinkiam siat kale, kei thinkiam ngawl het tu khi hi, ci hi.   
\p
\v 30 Jesus in, \wj A mantak kong ci ciang, tuni, tuzan mama in, ak nivei a khuan ma, thumvei hong nial tu ni hi, \wj* ci hi.   
\p
\v 31 Peter in nangma taw thi tu ahizong hong nial ngawl tu khi hi, ci in khotak in ci hi. Tasia bangma in a dangte theampo in zong ci tek uh hi.   
\s1 Jesus le a Nungzuite Gethsemane Huansung ah Thungen  
\r Matt. 26:36-46; Lk. 22:39-46  
\p
\v 32 Amate Gethsemane a kici huan ah theng uh hi: taciang a nungzui te kungah, \wj Ka thunget lan ziak ah to hi vun, \wj* ci hi.   
\p
\v 33 Jesus in, Peter, James le John te paipui a, lungmann ale nasiatak in thinngimna hong kipan hi.   
\p
\v 34 Taciang amate tung ah, \wj Ka thin sia thi tu za dong in nasiatak in khuangai hi: hi mun ah om in ngak nginge vun, \wj* ci hi.   
\p
\v 35 Taciang a maisang tawm pai lai a, lei ah bok in, a suak thei a hile, hi hun taw a ki peal thei natu in thungen hi.   
\p
\v 36 Taciang, \wj Abba, Pa awng, nang atu in na theampo hi thei hi; hi hai ka kung pan hong laksak tan: ahihang keima deina bang hi ngawl in nangma deina bang hi zaw tahen, \wj* ci hi.   
\p
\v 37 Taciang Jesus hongpai a, amate mut laitak mu hi, taciang Peter kungah, \wj Simon, mu na hi ziam? nai khat sungbeak zong ngak zo ngawl na hi ziam?\wj*   
\p
\v 38 \wj Ze-etna sungah na tum ngawl natu in thungen in ngak vun. Thaa sia uk mama hi kale cilesa sia a thaneam hi, \wj* ci hi.   
\p
\v 39 Taciang Jesus paikik a, a nget sa bangma in ngen leleau hi.   
\p
\v 40 Jesus a heakkik ciang in, amate mutthip leleau mu hi, banghangziam cile amate mitte ngit mama hi, amate in bangba zo kik tu ci zong a he bua uh hi.   
\p
\v 41 Thumvei na hongpaikik ciang in, amate tung ah, \wj Tu in mu vun a, tawlnga vun: hisia in pha zo hi, a huncing hi zo hi; en vun, mihing Tapa sia mawnei te khut ah leheak hun theng zo hi.\wj*   
\p
\v 42 \wj Tho vun a, pai tawng; en vun, Keima hong leheak pa hong theng zo hi, \wj* ci hi.   
\s1 Jesus Kimatna Thu  
\r Matt. 26:47-56; Lk. 22:47-53; Jn. 18:3-12  
\p
\v 43 Tabang a pau laitak, thakhatthu in, nungzui sawmleni sung pan khat, Judas Iscariot sia, thiampi lian te, thukhamhil te le upa te taw hongpai hi.   
\p
\v 44 Jesus a leheak pa in, ka nap sia Ama hi, man vun a; paipui vahiat vun, ci in heaksakna piakhol hi.   
\p
\v 45 Judas hong thet pociang, Jesus kungah hongpai suak a, Syapa, syapa awng; ci in nam hi.   
\p
\v 46 Taciang amate in Jesus man uh a, paipui uh hi.   
\p
\v 47 Taciang a kiim a ding te khat in namsau dawk in, thiampi sangbel pa naseam pa sat ahikom a bil tawng hi.   
\p
\v 48 Jesus in amate tung ah, \wj Banghang in nguta man tu bang in namsau le moltum taw keima man tu in hongpai nu ziam?\wj*   
\p
\v 49 \wj Biakinn sungah thuhil in nisim note taw om hi napi, hong man ngawl nu hi: ahihang laithiangtho sia tangtung hamtang tu hi, \wj* ci in zo kik hi.   
\p
\v 50 Tasiaciang amate a vekpi in Jesus nusia uh a, tai siat uh hi.   
\p
\v 51 Tua mun ah tangval khat, puanneal khat bek sil in Jesus nung zui a, tangval te in ama man ahikom:   
\p
\v 52 A puanneal sia nusia in, amate kung pan a pumnguak in tai keak hi.   
\s1 Jesus Caiaphas Mai ah  
\r Matt. 26:57-68; Lk. 22:54, 55, 63, 71; Jn. 18:13, 14, 19-24  
\p
\v 53 Amate in Jesus sia thiampi sangbel pa kungah paipui uh a: ama taw thiampi lian te, upa te le thukhamhil te kaikhawm tek hi.   
\p
\v 54 Taciang Peter in thiampi sangbel pa leitual dong a khuala na pan zui a: naseam te taw mei oai in to khawm hi.   
\p
\v 55 Thiampi lian te le tangpi upa te theampo in Jesus thalup thei natu in a man ngawl tetti te zong napi; a mu bua uh hi.   
\p
\v 56 A man ngawl tetti tu tam mama hongpai napi, amate tetti pan nate a thu uh ki si ngawl hi.   
\p
\v 57 Pawlkhat te ding in a man ngawl tettipang uh a,   
\p
\v 58 Khut taw a kisa hi biakinn ka pheltham tu a, khuttawsak ngawl a dang biakinn nithum sung sa tu khi hi, a ci za khu hi, ci uh hi.   
\p
\v 59 Ahihang amate tetti pan nate sia a thu uh kisi thei ngawl hi.   
\p
\v 60 Thiampi sangbel pa a lai ah ding a, Jesus kungah, bangma zo kik ngawl tu ni ziam? hi te in bangbang in nang hong langpan in tettipang ziam? ci hi.   
\p
\v 61 Ahihang Jesus huthe ngawl in om a, bangma zong zo kik ngawl hi. Thiampi sangbel pa in, nangma sia Christ a kici, thupha taw a dim Pathian Tapa na hi ziam? ci in dong kik hi.   
\p
\v 62 Jesus in, \wj Hi khi hi: mihing Tapa vangletna ziatsang ah to in meingo sung pan hongpai na mu tu uh hi, \wj*   
\p
\v 63 Tasiaciang thiampi sangbel pa in a puan eaukeak a, tetti dang bang kul nawn ziam?   
\p
\v 64 Pathian a sonsiat na za zo nu hi: bangbang ngaisun nu ziam? ci hi. Amate theampo in, thi tu kilawm mawna nei hi, ci in mawsiat tek uh hi.   
\p
\v 65 Pawlkhat te in Jesus sia cilphi hi, a mai humsak uh a vel in, a vel sia kamsang bang in pualak in, ci uh hi: naseam te in a khutpheak taw beang uh hi.   
\s1 Peter in Jesus Nial  
\r Matt. 26:69-75; Lk. 22:56-62; Jn. 18:15-18, 25-27  
\p
\v 66 Peter sia a nuai sang leitual ah a om laitak in, thiampi sangbel pa naseam te sung pan khat hongpai a:   
\p
\v 67 Tua nu in Peter mei oai a mu ciang in, en a, nangma zong Nazareth mi Jesus taw om nu hi, ci hi.   
\p
\v 68 Ahihang ama in, he ngawl khi hi, bang son ni ziam ci zong he ngawl khi hi, ci in nial hi. Taciang ama a puasang ah pusuak a, akkhuang hi.   
\p
\v 69 Naseam numei nu in mu leleau a, a kung a ding te kungah, hisia pa zong amate sungah ki hel hi, ci hi.   
\p
\v 70 Taciang Peter in nial leleau hi. Tuazawk a ngei ngawl in, a kung a ding te in Peter kungah, nangma sia amate sungah kihel lalawm ni hi: banghangziam cile nangma sia Galilee mi ni hi, na kampau pan ki he hi, ci leleau hi.   
\p
\v 71 Ahihang Peter in, kiciam in, na son uh sia pa he ngei ngawl khi hi, ci in kiciam hi.   
\p
\v 72 Taciang ak a ni veina khuang hi. Taciang Peter in Jesus i sonkhol, ak nivei a khuan ma thumvei hong nial tu ni hi, a ci thu phawkkik hi. Taciang tua thu a ngaisut ciang in kap hi.   
\c 15  
\s1 Jesus Pilate Mai ah  
\r Matt. 27:1, 2; Lk. 23:1, 2; Jn. 18:28-32  
\p
\v 1 Zingsang ciang in thiampi lian te in upa te, thukhamhil te le thunei te teng taw manlangtak in thu kikupna nei uh hi, taciang Jesus lehhen in paipui uh a, Pilate kungah ap uh hi.   
\p
\v 2 Pilate in, nangma in Judah mite Kumpipa na hi ziam? ci in dong hi. Ama in, \wj Na ci bang in ka hihi, \wj* ci in zo hi.   
\p
\v 3 Thiampi lian te in thu tatuam taw Ama mawsiat uh ahihang: bangma zo kik ngawl hi.   
\p
\v 4 Taciang Pilate in, bangma zo kik ngawl tu ni ziam? en in, amate in nangma mawsiat na bangzata tettipang uh ziam, ci dong hi.   
\p
\v 5 Ahihang Jesus in bangma zo kikngawl ahikom; Pilate in lamdangsa mama hi.   
\s1 Jesus le Barabbas  
\r Matt. 27:15-26; Lk. 23:13-25; Jn. 18:39-19:16  
\p
\v 6 Tua poai sungah amate in thongtak te sung pan, mipi te i dei khat papo suatak uh hi.   
\p
\v 7 Taciang ngaltho a, tualthat pa Barabbas a kici khat om hi, ama sia ngaltho dang te taw thongtak hi.   
\p
\v 8 Mihonpi te in a vawt ngei uh bangma in vawtsak tu dei in, a nging tatak in au kipan uh hi.   
\p
\v 9 Ahihang Pilate in, Judah te Kumpipa ka suatak tu na dei uh ziam? ci in dong hi.   
\p
\v 10 Banghangziam cile ama in Jesus sia thiampi lian te in a el uh man in hong ap hi, ci he nginge hi.   
\p
\v 11 Ahihang thiampi lian te in mihonpi te, Barabbas suatak zaw tu in holku uh hi.   
\p
\v 12 Taciang Pilate in amate tung ah, Judah te Kumpipa a kici pa bang law tu khi ziam? ci in dong hi.   
\p
\v 13 Taciang amate in, thinglamte tungah khai in, ci in au kik uh hi.   
\p
\v 14 Taciang Pilate in amate tung ah, banghang ziam, bang mawna vawt ziam? ci hi. Amate in thinglamte tungah khai in, ci in au seseam uh hi.   
\p
\v 15 Pilate in mipi te lungkimsak nuam ahikom, Barabbas suatak a, Jesus a vel zawkciang in, thinglamte tungah khai tu in ap hi.   
\s1 Ngalkap te in Jesus Nunau  
\r Matt. 27:27-31; Lk. 22:63-65; Jn. 19:2, 3  
\p
\v 16 Ngalkap te in Jesus Pilate inn ah tumpui uh a; ngalkap theampo munkhat ah sam hi.   
\p
\v 17 Taciang amate in Jesus puan sannum silsak uh a, ling kipheak lukhu a lu ah khusak uh hi.   
\p
\v 18 Tuazawkciang, Judah te Kumpipa! thuphatoai ta in, ci in zatakna pia uh hi.   
\p
\v 19 Amate in phaikung taw a lu pan vel uh hi, cilphi uh a, khupdin in bia uh hi.   
\p
\v 20 Amate in a selno zawk uh ciang in, puan sannum a silsak uh sia sutsak kik uh a, Ama puansil te silsak kik uh hi, taciang thinglamte tungah khai tu in paipui uh hi.   
\s1 Jesus Thinglamte Tung ah  
\r Matt. 27:32-44; Lk. 23:26-43; Jn. 19:17-27  
\p
\v 21 Alexander le Rufus te i pa, Cyrene ngam mi Simon sia, khuano pan hongpai a, lamkal ah ama a mu uh ciang zawthawk thu taw thinglamte puasak uh hi.   
\p
\v 22 Amate in Jesus sia Golgotha a kici, lu ngu mun ah paipui uh hi.   
\p
\v 23 Amate in myrrh taw a ki hel sapittui pia uh ahihang: Jesus in sang nuam ngawl hi.   
\p
\v 24 Amate in thinglamte tungah a khai zawk uh ciang in, a puan te khen uh a, mi khatsim in a nga tu uh tek aisan in hawm uh hi.   
\p
\v 25 Tabang in thinglamte tungah a khai uh sia zingsang nai kua a hihi.   
\p
\v 26 Ama mawsiatna lai tak uh a, \sc judah te kumpipa, \sc* ci in a tungah at uh hi.   
\p
\v 27 Taciang Ama taw nguta ni te sia; a ziatsang ah khat le a veisang ah khat, thinglamte tungah khai uh hi.   
\p
\v 28 Taciang Ama sia mawnei te taw ki sim khawm hi, ci laithiangtho tangtun na a hihi.   
\p
\v 29 Lampi a tawn peuma in nu nau uh a, lupei in, biakinn phel in, nithum sung a sa kik tu pa,   
\p
\v 30 Nangma le nangma ki hun in a, thinglamte tung pan hong tuaksuk tan, ci uh hi.   
\p
\v 31 Tabangma in thiampi lian te le thukhamhil te in zong, hisia pa sia ngualdang ngum thei a; ama le ama ki ngum thei ngawl hi.   
\p
\v 32 Israel te Kumpipa, Christ sia thinglamte tung pan tu mama in tuaksuk hen a, tabang in ka mu le um tu khu hi, ci in selno uh hi. Taciang Ama taw thinglamte tung a ki khai te in zong selno uh hi.   
\s1 Jesus Thina  
\r Matt. 27:45-56; Lk. 23:44-49; Jn. 19:28-30  
\p
\v 33 Sun nai sawmleni pan nitak sang nai thum dong leitung theampo khuazing hi.   
\p
\v 34 Nitak sang nai thum ciang in Jesus a nging tak in, \wj ELOI, ELOI, LAMASABAKTANI?\wj* ci in au hi. A khiakna sia, Ka Pathian, Ka Pathian awng, banghang hong taisan ni ziam? a cinopna a hihi.   
\p
\v 35 Tua mun ah a ding pawlkhat te in a zak uh ciang in, En vun, ama in Elijah sam hi, ci uh hi.   
\p
\v 36 Amate sung pan khat hong tai a, tuihup puan la in sapittui hau sungah pap suk a, phaikung dawn ah a sawm zawkciang, Jesus dawn tu in pia hi, Koi hi po in; Elijah hongpai in a khiasuk ziam, en hi tawng, ci uh hi.   
\p
\v 37 Jesus a ngingtak in a au zawkciang thi hi.   
\p
\v 38 Taciang biakinn sungah kidoi na puan sia a lu pan a taw dong ki zensuk a, khen ni ki sua hi.   
\p
\v 39 Taciang, Jesus au in, thi ci amai a ding ngalkap mangpa in a mu ciang in, hisia pa sia Pathian Tapa tatak hi, ci hi.   
\p
\v 40 Numei te in a khuala na pan in ngal-et uh a: amate sungah Mary Magdalene, James a no le Joses te nu Mary le Salome;   
\p
\v 41 Amate Jesus Galilee ngam a om lai in a nungzui te le a khoi te a hi uh hi; Jesus taw Jerusalem ah a pai khawm numei dang tampi te zong om hi.   
\s1 Jesus Than Ah Ki Vui  
\r Matt. 27:57-61; Lk. 23:5—56; Jn. 19:38-42  
\p
\v 42 Tua ni sia sabbath ni a thet ma, ki ngin ni hi a, nitak sang ciang in,   
\p
\v 43 A zatak huai ngaisutna pia le Pathian kumpingam a ngak Arimathaea khua mi Joseph hongpai a, hangsantak in Pilate kungah pai hi, taciang Jesus luanghawm ngen hi.   
\p
\v 44 Pilate in Jesus thi zo hi, a ci uh ciang lamdangsa mama hi: ngalkap mangpa sam a, Jesus a thi zawk ngei zom ziam? ci in dong hi.   
\p
\v 45 Ngalkap mangpa kung pan a heak ciang in Jesus luanghawm Pilate in Joseph pia hi.   
\p
\v 46 Taciang Joseph in puanneal lei a, Jesus khiasuk in, puanneal taw tuam hi, taciang a ki to tawm suang hawng sungah vui a, than kongkha ah suangtum lik hi.   
\p
\v 47 Mary Magdalene le Joses nu Mary te in Jesus a vui na mun en uh hi.   
\c 16  
\s1 Jesus Thawkikna  
\r Matt. 28:1-10; Lk. 24:1-12; Jn. 20:1-10  
\p
\v 1 Sabbath ni a bo ciang in, Mary Magdalene, James nu Mary le Salome te hongpai uh a, Jesus luanghawm zut tu sathau namtui te keng uh hi.   
\p
\v 2 Nipikal khat sung ni masabel ni zingtung, ni sua ciang in, amate than ah pai uh hi.   
\p
\v 3 Taciang amate in than kongkha a suangtum sia kua in hong liksak tu ziam? ci in kikum kawm uh hi.   
\p
\v 4 Amate in a et uh ciang in, suangtum a ki lik sa in mu uh hi: banghangziam cile tua suangtum sia lian mama hi.   
\p
\v 5 Than sung a tum uh ciang in, tangval khat puanpak tualpui sil in ziatsang ah a to, amate in mu uh a; lau mama uh hi.   
\p
\v 6 Ama in numei te kungah, lau heak vun: thinglamte tung a ki khai Nazareth khua mi Jesus zong nu hi; Ama thokik zo hi; hi mun ah om nawn ngawl hi: Ama ki vui na hong en tavun.   
\p
\v 7 Ahihang pai tavun a, a nungzui te le Peter kungah, na mai uh Galilee ah pai hi, ci in son vun: note hong sonkholsa bangma in, tua mun ah mu tu nu hi, ci in son hi.   
\p
\v 8 Taciang amate than pan in manlangtak in pai uh a, tai kawm uh hi; banghangziam cile amate huang liang in lamdangsa mama uh hi: kuama kungah zong bangma son ngawl hi; banghangziam cile amate a lau uh hang a hihi.   
\s1 Jesus Mary Magdalene Kung ah Kilang  
\r Jn. 20:11-18  
\p
\v 9 Jesus sia nipikal khat sung ni masabel ni zingtung a thawkik ciang in, a sung pan doai ngilo sali a hawlkhiatsak Mary Magdalene kungah kilang masabel hi.   
\p
\v 10 Taciang ama pai a, Jesus taw kithawl ngei in, a kap a tau te son hi.   
\p
\v 11 Amate in, Jesus nungta hi, ci le Mary in mu hi, ci a zak uh ciang in, a um bua uh hi.   
\s1 Jesus Nungzui Ni te Kung Kilang  
\r Lk. 24:13-35  
\p
\v 12 Tuazawkciang in amate sung pan mi ni, khuano sang a pai te kungah, Jesus meal lamdang in kilaak hi.   
\p
\v 13 Taciang amate pai in a dang te son a hi uh hang: amate in a um bua uh hi.   
\s1 Nasep Lianbel Apna  
\r Matt. 28:16-20; Lk. 24:36-49; Jn. 20:19-23; Sawl;. 1:6-8  
\p
\v 14 Tuazawkciang in, nungzui sawm le khat te anneakna mun ah a to uh laitak, Jesus hong kilang a, amate tei hi, banghangziam cile amate in a thawkik zawk a mu te i son te um ngawl in a thinpui uh hang a hihi.   
\p
\v 15 Jesus in amate tung ah, \wj Note leitung theampo ah pai tavun a, piansakna theampo tungah lungdamna thu son tavun.\wj*   
\p
\v 16 \wj Um in tuiphumna a sang peuma ngupna nga tu hi; ahihang a um ngawl te sia thukhenna thuak tu hi.\wj*   
\p
\v 17 \wj A umte sia hibang musakna te in zui tu hi; ka min taw doai te hawlkhia tu uh a; kam thak taw pau tu uh hi;\wj*   
\p
\v 18 \wj Ngul te zong man tu uh a; ngu a ne hial uh zong, bangma tat ngawl tu hi; cina te tungah a khut uh te nga tu uh a, dam tu hi, \wj*   
\s1 Jesus Van ah Kato  
\r Lk. 24:50-53; Sawl. 1:9-11  
\p
\v 19 Topa in amate thu a son zawkciang in, Ama sia van ah ki la to a, Pathian ziatsang ah to hi.   
\p
\v 20 Amate pai uh a, mun theampo ah thuhil uh hi, Topa amate taw naseam a, a thuhilna uh te nalamdang te in zui in kipsak hi. Amen.   