\q1 I̱na Pilidialiru balu wayali howa  
\q2 turu halu ga̱ lalu harogoni, laya.   
\b  
\q1
\v 9 Ngode Datagaliwabe-o ege pabe hongohe bu mabubi tano ngagoha  
\q2 i̱ aiwa haru anda polobadabe.  
\q1 Idomo dindiha i̱ aiwa haru polobadabe.   
\q1
\v 10 Ngode Datagaliwabe í̠na ina erembira ngiribe.  
\q1 Í̠na inanaga ami agali karu biamogo nabuleorebe.   
\q1
\v 11 Agalinaga hongome ina biamogo bulene nakarulapego\x + \xo 60.11 \xt Iba 118.8, 146.3\x*  
\q2 iname waitigi bu karu baba wai buluma̱ya  
\q2 í̠nioreme ina biamogo bibe.   
