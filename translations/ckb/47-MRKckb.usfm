\id MRK - Biblica® Open Kurdi Sorani Standard Version
\h مەرقۆس
\toc1 مزگێنی بەپێی نووسینی مەرقۆس
\toc2 مەرقۆس
\toc3 مەرقۆس
\mt1 مزگێنی بەپێی نووسینی مەرقۆس
\c 1
\s1 دەرکەوتنی یەحیای کوڕی زەکەریا
\p 
\v 1 سەرەتای مزگێنی عیسای مەسیحی کوڕی خودا.
\p 
\v 2 لە پەڕتووکی ئیشایای پێغەمبەردا نووسراوە:
\q1 ﴿من نێردراوی خۆم لەپێشتەوە دەنێرم،
\q2 ئەوەی ڕێگات بۆ ئامادە دەکات،﴾\f + \fr 1:2 \ft \xt مەلاخی 3‏:1.‏\xt*\ft ‏\f*
\q1 
\v 3 ﴿کەسێک لە چۆڵەوانی هاوار دەکات و دەڵێت:
\q1 «ڕێگا بۆ هاتنی یەزدان ئامادە بکەن،
\q2 ڕێچکەکانی بۆ ڕێکبخەن.»﴾\f + \fr 1:3 \ft \xt ئیشایا 40‏:3.‏\xt*\ft ‏\f*
\m 
\v 4 یەحیا هات، لە چۆڵەوانیدا خەڵکی لە ئاو هەڵدەکێشا و جاڕی لەئاوهەڵکێشانی\f + \fr 1:4 \ft یۆنانی: \tl باپتسمە‏\tl*، بە واتای شوشتن دێت بۆ پاکبوونەوە لە گوناه، وەک (بسمیلکردن).‏\f* تۆبەکردنی دەدا بۆ گوناه بەخشین.
\v 5 خەڵکی هەموو گوندەکانی یەهودیا و هەموو ئۆرشەلیم دەهاتنە لای، دانیان بە گوناهەکانیاندا دەنا و لەسەر دەستی ئەو لە ڕووباری ئوردون لە ئاو هەڵدەکێشران.
\v 6 جلوبەرگی یەحیا لە مووی وشتر بوو، پشتێنێکی چەرمیشی لە ناوقەدی دەبەست، کوللە و هەنگوینی کێویی دەخوارد.
\v 7 ئەمە پەیامەکەی ئەو بوو: «لەدوای من کەسێک دێت کە زۆر لە من بەتواناترە، تەنانەت شایانی ئەوە نیم دابنەوێمەوە و قەیتانی پێڵاوەکانی بۆ بکەمەوە.
\v 8 من لە ئاوتان هەڵدەکێشم، بەڵام ئەو لە ڕۆحی پیرۆزتان هەڵدەکێشێت\f + \fr 1:8 \ft هەڵکێشان لە ڕۆحی پیرۆز بە واتای شوشتنی ڕۆحی دێت. واتا، عیسای مەسیح ڕۆحی پیرۆز دەنێرێت تاکو لە هەموو باوەڕدارێکدا نیشتەجێ ببێت و لە گوناه بیانپارێزێت و ڕێنماییان بکات.‏\f*.»
\s1 لەئاوهەڵکێشانی عیسا
\p 
\v 9 لەو ڕۆژانەدا عیسا لە ناسیرەوە هات، کە سەر بە ناوچەی جەلیلە و لەسەر دەستی یەحیا لە ڕووباری ئوردون لە ئاو هەڵکێشرا.
\v 10 هەرکە عیسا لە ئاوەکە هاتە دەرەوە، بینی ئاسمان شەق بوو، ڕۆحی پیرۆزیش وەک کۆترێک لەسەری نیشتەوە.
\v 11 دەنگێکیش لە ئاسمانەوە هات: «تۆ کوڕی خۆشەویستمی، بە تۆ زۆر دڵشادم.»
\p 
\v 12 دەستبەجێ ڕۆحی پیرۆز عیسای بەرەو چۆڵەوانی برد.
\v 13 چل ڕۆژ لە چۆڵەوانیدا لەنێوان ئاژەڵانی کێویدا بوو، شەیتان تاقی دەکردەوە، فریشتەکانیش خزمەتیان دەکرد.
\s1 عیسا مزگێنی ڕادەگەیەنێت
\p 
\v 14 دوای دەستگیرکردنی یەحیا، عیسا هاتە جەلیل و مزگێنی خودای ڕادەگەیاند و
\v 15 دەیفەرموو: «کاتەکە هاتووەتە دی و پاشایەتی خودا نزیک بووەتەوە. تۆبە بکەن، باوەڕ بەم مزگێنییە بهێنن.»
\s1 هەڵبژاردنی قوتابییەکان
\p 
\v 16 کاتێک عیسا بە کەناری دەریاچەی جەلیلدا دەڕۆیشت، شیمۆن و ئەندراوسی برای بینی، تۆڕیان فڕێدەدایە دەریاچەکە، چونکە ماسیگر بوون.
\v 17 عیسا پێی فەرموون: «وەرن دوام بکەون، دەتانکەم بە ڕاوکەری مرۆڤ\f + \fr 1:17 \ft بەدەستهێنانی خەڵک تاکو ببنە قوتابی مەسیح.‏\f*.»
\v 18 دەستبەجێ تۆڕەکانیان بەجێهێشت و دوای کەوتن.
\p 
\v 19 ئینجا کەمێک دوور کەوتەوە، یاقوبی کوڕی زەبدی و یۆحەنای برای بینی، لەناو بەلەمێکدا تۆڕەکەی خۆیان چاک دەکردەوە.
\v 20 یەکسەر بانگی کردن، ئەوانیش زەبدی باوکیان لەگەڵ کرێکاران لەناو بەلەمەکە بەجێهێشت و دوای کەوتن.
\s1 دەرکردنی ڕۆحی پیس
\p 
\v 21 ئینجا عیسا و شوێنکەوتووانی چوونە شاری کەفەرناحوم. لە ڕۆژی شەممەدا عیسا چووە کەنیشت و دەستی کرد بە فێرکردنی خەڵک.
\v 22 خەڵکی لە فێرکردنەکەی سەرسام بوون، چونکە وەک دەسەڵاتدارێک فێری دەکردن، نەک وەکو مامۆستایانی تەورات\f + \fr 1:22 \ft مالم.‏\f*.
\v 23 لە کەنیشتەکەیاندا یەکێکی لێبوو ڕۆحی پیسی تێدابوو، لەپڕ هاواری کرد،
\v 24 گوتی: «عیسای ناسیرەیی، چیت لێمان دەوێت؟ هاتووی لەناومان ببەیت؟ دەزانم تۆ کێیت، پیرۆزەکەی خودایت!»
\p 
\v 25 عیسا لێی ڕاخوڕی و فەرمووی: «بێدەنگ بە! لێی وەرە دەرەوە!»
\v 26 ڕۆحە پیسەکەش فێی لە پیاوەکە هێنا و بە دەنگی بەرز هاواری کرد و لێی هاتە دەرەوە.
\p 
\v 27 هەموو سەرسام بوون و کەوتنە پرسیار لە یەکتری: «ئەمە چییە؟ فێرکردنێکی نوێیە بە دەسەڵاتەوە! فەرمان بە ڕۆحە پیسەکانیش دەدات و گوێڕایەڵی دەبن.»
\v 28 یەکسەر ناوبانگی عیسا بە هەموو ناوچەی دەوروبەری جەلیلدا بڵاو بووەوە.
\s1 چاککردنەوەی خەسووی پەترۆس
\p 
\v 29 کاتێک عیسا لەگەڵ یاقوب و یۆحەنا کەنیشتەکەیان بەجێهێشت، چوونە ماڵی شیمۆن و ئەندراوس.
\v 30 خەسووی شیمۆن لەناو جێگادا کەوتبوو، تای هەبوو، خێرا باسی ئەویان بۆ عیسا کرد.
\v 31 ئەویش هات، دەستی گرت و هەڵیستاندەوە. تایەکە بەریدا و دەستی کرد بە خزمەتکردنیان.
\p 
\v 32 ئەو ئێوارەیە لەپاش ڕۆژئاوابوون، هەموو نەخۆش و ئەو کەسانەیان بۆ دەهێنا کە ڕۆحی پیسیان تێدابوو.
\v 33 هەموو دانیشتووانی شارەکە لەبەر دەرگا کۆبوونەوە،
\v 34 عیسا ژمارەیەکی زۆر نەخۆشی بە جۆرەها دەردەوە چاککردەوە و زۆر ڕۆحی پیسیشی دەرکرد و نەیهێشت ڕۆحە پیسەکان بدوێن، چونکە دەیانزانی کێیە.
\s1 مزگێنیدان لە ناوچەی جەلیل
\p 
\v 35 بەرەبەیانی ڕۆژی دواتر کە هێشتا تاریک بوو، عیسا هەستا و چووە شوێنێکی چۆڵ و لەوێ دەستی کرد بە نوێژکردن.
\v 36 شیمۆن و هاوڕێکانی بە شوێنیدا گەڕان،
\v 37 کە دۆزییانەوە پێیان گوت: «هەموو خەڵکەکە بەدواتدا دەگەڕێن.»
\p 
\v 38 عیسا پێی فەرموون: «وەرن، با بڕۆین بۆ دێیەکانی دەوروپشت، تاکو لەوێش پەیامەکەم ڕابگەیەنم، چونکە من بۆ ئەمە هاتووم.»
\v 39 ئینجا ڕۆیشت و لە هەموو جەلیلدا لە کەنیشتەکانیان پەیامی خودای ڕادەگەیاند و ڕۆحی پیسی دەردەکرد.
\s1 پاکبوونەوە لە گولی
\p 
\v 40 پیاوێک هاتە لای عیسا کە نەخۆشی گولی هەبوو، لێی پاڕایەوە و چۆکی دادا و پێی گوت: «ئەگەر بتەوێت، دەتوانیت پاکم بکەیتەوە.»
\p 
\v 41 عیسا دڵی پێی سووتا و دەستی بۆ درێژکرد و دەستی لێدا و پێی فەرموو: «دەمەوێت، پاک بەرەوە!»
\v 42 دەستبەجێ گولییەکەی لێبووەوە و پاک بووەوە.
\p 
\v 43 دوای ئەوەی کە عیسا پیاوەکەی بە توندی ئاگادار کردەوە، دەستبەجێ بەڕێی کرد،
\v 44 پێی فەرموو: «ئاگاداربە، هیچ شتێک بە کەس مەڵێ، بەڵام بڕۆ خۆت پیشانی کاهین\f + \fr 1:44 \ft کاهین: پیاوێکی ئایینی جولەکەیە کە هەڵدەستێ بە ئەرکی قوربانی کردن لەناو پەرستگا و فێرکردنی خەڵک.‏\f* بدە و بۆ پاکبوونەوەکەت ئەو قوربانییەی موسا فەرمانی کردووە بیکە، وەک شایەتییەک بۆیان.»
\v 45 بەڵام ئەو ڕۆیشت و دەستی بە جاڕدان و بڵاوکردنەوەی ئەم هەواڵە کرد، لەبەر ئەوە عیسا نەیتوانی بە ئاشکرا بچێتە ناو شار، بەڵکو لە دەرەوە لە شوێنە چۆڵەکاندا بوو و خەڵکیش لە هەموو لایەکەوە دەهاتنە لای.
\c 2
\s1 چاککردنەوەی ئیفلیجێک
\p 
\v 1 پاش چەند ڕۆژێک عیسا هاتەوە بۆ کەفەرناحوم، جا بیسترا کە لە ماڵەوەیە.
\v 2 خەڵکێکی زۆر کۆبوونەوە، بە شێوەیەک لە بەردەرگاش شوێن نەمابوو، ئەویش دەستی کرد بە باسکردنی پەیامی خودای بۆیان.
\v 3 لەو کاتەدا کابرایەکی ئیفلیجیان هێنایە لای، بە چوار کەس هەڵیانگرتبوو.
\v 4 بەڵام بەهۆی زۆری خەڵکەکەوە نەیانتوانی لێی نزیک ببنەوە. جا کونێکی گەورەیان کردە سەربانی ئەو شوێنەی کە عیسای لێبوو و نوێنەکەیان شۆڕکردەوە کە پیاوە ئیفلیجەکەی لەسەر بوو.
\v 5 کاتێک عیسا باوەڕی ئەوانی بینی، بە ئیفلیجەکەی فەرموو: «کوڕم، گوناهەکانت بەخشران.»
\p 
\v 6 هەندێک لە مامۆستایانی تەورات کە لەوێ دانیشتبوون، لە دڵی خۆیاندا گوتیان:
\v 7 «بۆچی ئەمە بەم شێوەیە دەدوێت؟ کفر دەکات! بێجگە لە خودا کێ دەتوانێت گوناه ببەخشێت؟»
\p 
\v 8 دەستبەجێ عیسا لە ڕۆحییەوە زانی کە ئەوان لە دڵی خۆیاندا بەو جۆرە بیر دەکەنەوە، پێی فەرموون: «بۆچی لە دڵتاندا بیر لەم شتانە دەکەنەوە؟
\v 9 کامیان ئاسانترە، بە ئیفلیجەکە بگوترێت: ”گوناهەکانت بەخشران،“ یان بگوترێت: ”هەستە، نوێنەکەت هەڵگرە و بڕۆ“؟
\v 10 بەڵام بۆ ئەوەی بزانن کوڕی مرۆڤ\f + \fr 2:10 \ft کوڕی مرۆڤ: مەسیح بەم نازناوە خۆی دەناسێنێت. بڕوانە \xt دانیال 7‏:13‏-14.‏\xt*\ft ‏\f* لەسەر زەوی دەسەڵاتی گوناهبەخشینی هەیە،…» بە ئیفلیجەکەی فەرموو:
\v 11 «پێت دەڵێم: هەستە، نوێنەکەت هەڵگرە و بڕۆرەوە ماڵەوە.»
\v 12 ئەویش یەکسەر هەستا و نوێنەکەی هەڵگرت و لەبەرچاوی هەموویان چووە دەرەوە. بە شێوەیەک هەموو سەرسام بوون و ستایشی خودایان کرد و گوتیان: «هەرگیز شتی وامان نەبینیوە!»
\s1 عیسا لێڤی بانگهێشت دەکات
\p 
\v 13 دیسان عیسا چووە سەر کەناری دەریاچەکە، خەڵکەکە هەموو لێی کۆبوونەوە و ئەویش دەستی کرد بە فێرکردنیان.
\v 14 لە کاتی ڕۆیشتنیدا، لێڤی کوڕی حەلفی بینی لە شوێنی باجگری دانیشتبوو، پێی فەرموو: «دوام بکەوە.» ئەویش هەستا و دوای کەوت.
\p 
\v 15 لە کاتێکدا عیسا لە ماڵی لێڤی دانیشتبوو، زۆر لە باجگران و گوناهباران لەگەڵ عیسا و قوتابییەکانی لەسەر خوان بوون، چونکە ژمارەی ئەوانە زۆر بوو کە دوای کەوتبوون.
\v 16 مامۆستایانی تەورات کە فەریسی بوون، کاتێک بینییان عیسا وا لەگەڵ گوناهبار و باجگران نان دەخوات، بە قوتابییەکانی ئەویان گوت: «بۆچی لەگەڵ باجگر و گوناهباران نان دەخوات؟»
\p 
\v 17 کە عیسا گوێی لەمە بوو، پێی فەرموون: «لەشساغ پێویستی بە پزیشک نییە، بەڵکو نەخۆش. نەهاتووم ڕاستودروستان بانگهێشت بکەم، بەڵکو گوناهباران.»
\s1 لەبارەی ڕۆژووەوە
\p 
\v 18 کاتێک قوتابییەکانی یەحیا و فەریسییەکان بەڕۆژوو بوون، چەند کەسێک هاتنە لای عیسا و لێیان پرسی: «بۆچی قوتابییەکانی یەحیا و قوتابی فەریسییەکان بەڕۆژوو دەبن، بەڵام قوتابییەکانی تۆ بەڕۆژوو نابن؟»
\p 
\v 19 عیساش پێی فەرموون: «ئایا بانگهێشتکراوانی زەماوەند دەتوانن بەڕۆژوو بن کاتێک زاوا لەگەڵیاندایە؟ هەتا زاوا لەگەڵیاندا بێت ناتوانن بەڕۆژوو بن.
\v 20 بەڵام ڕۆژێک دێت کە زاوایان لێ دوور دەخرێتەوە، ئەوسا لەو ڕۆژەدا بەڕۆژوو دەبن.
\p 
\v 21 «کەس کراسی کۆن بە پەڕۆیەک کە نەچووبێتە ئاو پینە ناکات، چونکە پینە نوێیەکە لە کراسە کۆنەکە ڕادەکێشێت و دڕاوییەکە خراپتر دەبێت.
\v 22 کەسیش شەرابی نوێ ناکاتە ناو مەشکەی کۆنەوە، ئەگینا شەرابەکە مەشکەکە دەدڕێنێت، شەرابەکە دەڕژێت و مەشکەکەش لەناودەچێت. بەڵکو شەرابی نوێ دەکرێتە ناو مەشکەی نوێوە.»
\s1 گەورەی ڕۆژی شەممە
\p 
\v 23 لە ڕۆژێکی شەممەدا عیسا بەناو دەغڵدا تێدەپەڕی، قوتابییەکانی بە ڕێگاوە دەستیان کرد بە گوڵەگەنم لێکردنەوە.
\v 24 فەریسییەکان پێیان گوت: «بڕوانە، بۆچی شتێک دەکەن کە لە شەممەدا دروست نییە؟»
\p 
\v 25 عیساش وەڵامی دانەوە: «ئایا نەتانخوێندووەتەوە داود چی کرد کاتێک خۆی و ئەوانەی لەگەڵی بوون کەوتنە تەنگانە و برسییان بوو؟
\v 26 لە سەردەمی ئەبیاتاری سەرۆکی کاهینان، داود چووە ناو ماڵی خودا و نانی تەرخانکراوی\f + \fr 2:26 \ft بڕوانە پەراوێزی \xt مەتا 12‏:4‏\xt*\ft ‏\f* خوارد، دایە ئەوانەش کە لەگەڵی بوون، ئەو نانەی کە دروست نییە بخورێت بۆ کاهینان نەبێت.»
\p 
\v 27 ئینجا پێی فەرموون: «شەممە بۆ مرۆڤ بەدیهێنراوە، نەک مرۆڤ بۆ شەممە.
\v 28 کەواتە کوڕی مرۆڤ گەورەی ڕۆژی شەممەیە.»
\c 3
\s1 چاککردنەوەی نەخۆش لە شەممە
\p 
\v 1 دیسان عیسا چووەوە ناو کەنیشتێک، لەوێ پیاوێکی لێبوو دەستی وشک ببوو،
\v 2 ئیتر هەندێک لەوانەی لەوێ بوون چاودێرییان دەکرد بۆ ئەوەی بزانن لە شەممەدا چاکی دەکاتەوە، تاکو سکاڵای لێ بکەن.
\v 3 عیسا بە پیاوە دەست وشکبووەکەی فەرموو: «لەبەردەم هەمووان ڕابوەستە.»
\p 
\v 4 ئینجا پێی فەرموون: «ئایا لە شەممەدا کاری چاکە دروستە یان کاری خراپە؟ ڕزگارکردنی ژیان یان کوشتن؟» کەچی بێدەنگ بوون.
\p 
\v 5 بە تووڕەییەوە ئاوڕی لێیان دایەوە، لەبەر دڵڕەقییان خەمبار بوو، بە پیاوەکەی فەرموو: «دەستت درێژ بکە.» ئەویش درێژی کرد و دەستی چاک بووەوە.
\v 6 فەریسییەکان هاتنە دەرەوە و یەکسەر لەگەڵ هێرۆدسییەکان تەگبیریان کرد چۆن بیکوژن.
\s1 خەڵکێکی زۆر دوای عیسا دەکەون
\p 
\v 7 عیسا و قوتابییەکانی بەرەو دەریاچەکە کشانەوە و خەڵکێکی زۆر لە جەلیل دوای کەوتن.
\v 8 کاتێک هەموو ئەو شتانەیان بیست کە دەیکرد، خەڵکێکی زۆر لە یەهودیا، ئۆرشەلیم، ئادومیا، ئەوبەری ڕووباری ئوردون و دەوروبەری سور و سەیداوە هاتنە لای.
\v 9 ئەویش بە قوتابییەکانی فەرموو کە بەلەمێکی بۆ ئامادە بکەن، بۆ ئەوەی خەڵکەکە پاڵەپەستۆی نەخەنە سەر.
\v 10 لەبەر ئەوەی خەڵکێکی زۆری چاککردەوە، وای لێهات هەموو دەردەدارەکان بەرەو ڕووی دەهاتن تاکو دەستی لێبدەن.
\v 11 ئەو کەسانەی کە ڕۆحی پیسیان تێدابوو، کاتێک دەیانبینی کڕنۆشیان بۆ دەبرد و هاواریان دەکرد: «تۆ کوڕی خودای!»
\v 12 ئەویش بە توندی فەرمانی پێدەدان لەلای کەس باسی نەکەن.
\s1 هەڵبژاردنی دوازدە نێردراوەکە
\p 
\v 13 عیسا چووە سەر شاخێک و ئەوانەی بانگکرد کە خۆی ویستنی، ئەوانیش چوونە لای.
\v 14 دوازدەی دیاری کرد و ناوی لێنان نێردراوان، تاکو لەگەڵی بن و بۆ جاڕدان بیاننێرێت و
\v 15 دەسەڵاتیان هەبێت بۆ دەرکردنی ڕۆحی پیس.
\b
\li4 
\v 16 ئەم دوازدە کەسەی دیاری کرد:
\b
\li1 شیمۆن کە ناوی لێنا پەترۆس،
\li1 
\v 17 یاقوبی کوڕی زەبدی و یۆحەنای برای کە ناوی لێنان بوانەرگس، واتا کوڕانی هەورەتریشقە،
\li1 
\v 18 هەروەها ئەندراوس،
\li1 فیلیپۆس،
\li1 بەرتۆلماوس،
\li1 مەتا، تۆماس،
\li1 یاقوبی کوڕی حەلفی،
\li1 تەداوس،
\li1 شیمۆنی کانەوی\f + \fr 3:18 \ft کانەوی پارتێکی نەتەوەیی ڕادیکالی جولەکە بوو، شیمۆنیش سەر بەو پارتە بوو. بڕوانە \xt لۆقا 6‏:15‏\xt*\ft ‏.‏\f* و
\li1 
\v 19 یەهوزای ئەسخەریوتی کە عیسای بە گرتن دا.
\s1 عیسا و سەرۆکی ڕۆحە پیسەکان
\p 
\v 20 عیسا چووە ماڵێک و دیسان خەڵکێکی زۆریان لێ کۆبووەوە، بە شێوەیەک کە نەیانتوانی نان بخۆن.
\v 21 کاتێک کەسوکاری بیستیان، هاتن بیگرن، چونکە دەیانگوت: «مێشکی تێکچووە.»
\p 
\v 22 مامۆستایانی تەوراتیش کە لە ئۆرشەلیمەوە هاتبوون، گوتیان: «بەعل‌زەبول\f + \fr 3:22 \ft بەعل‌زەبول: بڕوانە \xt مەتا 10‏:25‏\xt*\ft ‏\f* دەستی بەسەردا گرتووە، بە شای ڕۆحە پیسەکان، ڕۆحی پیس دەردەکات.»
\p 
\v 23 عیسا بانگی کردن و بە نموونە قسەی بۆ کردن: «شەیتان چۆن دەبێت شەیتان دەربکات؟
\v 24 ئەگەر شانشینێک دووبەرەکی تێدابێت، ئەو شانشینە خۆی ڕاناگرێت.
\v 25 ئەگەر ماڵێکیش دووبەرەکی تێدابێت، ئەو ماڵە خۆی ڕاناگرێت.
\v 26 ئەگەر شەیتان لە خۆی هەڵگەڕایەوە و دووبەرەکی تێکەوت، خۆی ڕاناگرێت، بەڵکو کۆتایی پێ دێت.
\v 27 کەسیش ناتوانێت بچێتە ماڵی پیاوێکی بەهێز و شتەکانی تاڵان بکات، ئەگەر یەکەم جار نەیبەستێتەوە، ئینجا ماڵەکەی تاڵان بکات.
\v 28 ڕاستیتان پێ دەڵێم: هەموو گوناه و کفرکردنێکی مرۆڤ دەبەخشرێت،
\v 29 بەڵام ئەوەی سەبارەت بە ڕۆحی پیرۆز کفر بکات، هەرگیز نابەخشرێت، بەڵکو بە گوناهێکی هەتاهەتاییەوە تاوانبارە.»
\p 
\v 30 ئەمەی فەرموو، چونکە دەیانگوت: «ڕۆحی پیسی هەیە.»
\s1 دایک و براکانی عیسا
\p 
\v 31 دایک و براکانی عیسا هاتن، لە دەرەوە ڕاوەستان و ناردیان بەدوایدا.
\v 32 خەڵکیش لە دەوروبەری دانیشتبوون، پێیان گوت: «وا دایک و براکانت لە دەرەوە بەدواتدا دەگەڕێن.»
\p 
\v 33 وەڵامی دانەوە و فەرمووی: «دایک و براکانم کێن؟»
\p 
\v 34 چاوی گێڕا بەسەر ئەوانەی لە دەوروپشتی دانیشتبوون و فەرمووی: «دایک و برای من ئەمانەن.
\v 35 ئەوەی بە خواستی خودا بکات، خوشک و برا و دایکمە.»
\c 4
\s1 نموونەی چوار جۆری خاک
\p 
\v 1 دیسان عیسا لە کەناری دەریاچەی جەلیل دەستی کرد بە فێرکردنی خەڵک، خەڵکێکی ئێجگار زۆر لێی کۆبووەوە، تاکو وای لێهات چووە ناو بەلەمێکی ناو ئاوەکە دانیشێت، هەموو خەڵکەکەش لە نزیک ئاوەکە لەسەر وشکانی بوون.
\v 2 بە نموونە زۆر شتی فێرکردن، لە فێرکردنەکەیدا پێیانی فەرموو:
\v 3 «گوێ بگرن، جوتیارێک چووە دەرەوە تۆو بکات.
\v 4 کە تۆوی دەوەشاند، هەندێکی کەوتنە سەر ڕێگا، باڵندەش هاتن و خواردیانن.
\v 5 هەندێکیش کەوتنە سەر زەوییەکی بەردەڵان کە خۆڵی کەم بوو، خێرا سەریان دەرکرد، چونکە زەوییەکەی قووڵ نەبوو.
\v 6 بەڵام کە ڕۆژ هەڵهات سووتان و وشک بوون، چونکە ڕەگیان نەبوو.
\v 7 هەندێکیشیان کەوتنە نێو دڕکان، دڕکەکان گەورە بوون و خنکاندیانن و بەرهەمیان نەدا.
\v 8 هەندێکیش کەوتنە سەر زەوییەکی باش، ڕوان و گەشەیان کرد و بەرهەمیان دا، یەک بە سی و یەک بە شەست و یەک بە سەد.»
\p 
\v 9 ئینجا فەرمووی: «ئەوەی گوێی هەیە بۆ بیستن، با ببیستێت!»
\p 
\v 10 کاتێک عیسا بە تەنها بوو، ئەوانەی لە دەوروپشتی بوون لەگەڵ دوازدە قوتابییەکە، دەربارەی نموونەکە لێیان پرسی.
\v 11 ئەویش پێی فەرموون: «نهێنی شانشینی خودا بە ئێوە دراوە، بەڵام ئەوانەی لە دەرەوەن هەموو شتێکیان بە نموونە پێ دەگوترێت،
\v 12 بۆ ئەوەی
\q1 «﴿بە سەیرکردن سەیر بکەن، بەڵام نەبینن،
\q2 بە بیستن ببیستن، بەڵام تێنەگەن،
\q1 نەوەک بگەڕێنەوە و ببەخشرێن!﴾\f + \fr 4:12 \ft \xt ئیشایا 6‏:9‏-10‏\xt*\ft ‏‏\f*»
\p 
\v 13 ئینجا پێی فەرموون: «ئایا لەم نموونەیە تێنەگەیشتن؟ باشە چۆن لە نموونەکانی دیکە تێدەگەن؟
\v 14 جوتیارەکە پەیامی خودا تۆو دەکات.
\v 15 هەندێک کەس وەکو ئەو تۆوانەن کە دەکەونە سەر ڕێگاکە، کە پەیامەکەیان لێ تۆو دەکرێت، کاتێک دەیبیستن دەستبەجێ شەیتان دێت و ئەو پەیامە دەبات کە تێیاندا تۆوکراوە.
\v 16 ئەوانەی دیکە کە لەسەر بەردەڵانەکە تۆوکران، ئەوانەن کە پەیامەکە دەبیستن و دەستبەجێ بە خۆشییەوە وەریدەگرن،
\v 17 بەڵام بۆ ماوەیەکی کەم دەمێنن، چونکە ڕەگیان نییە. دواتر لەبەر پەیامەکە تووشی تەنگانە و چەوسانەوە دەبن، یەکسەر دەکەون.
\v 18 ئەوانەی دیکە کە لەنێو دڕکەکاندا تۆوکران، ئەمانە ئەوەن کە پەیامەکە دەبیستن،
\v 19 بەڵام خەمی ژیان و فریوخواردنی دەوڵەمەندی و ئارەزووی شتەکانی دیکە دێنە ناوەوە و پەیامەکە دەخنکێنن، ئیتر بێ بەرهەم دەبن.
\v 20 ئەوانەی دیکە کە لەسەر زەوییەکی باش تۆوکران، ئەوانەن کە پەیامەکە دەبیستن و وەریدەگرن و بەرهەم دەدەن، یەک بە سی و یەک بە شەست و یەک بە سەد.»
\s1 نموونەی چرا
\p 
\v 21 ئینجا پێی فەرموون: «ئایا خەڵکی چرا هەڵدەکەن تاکو بیخەنە ژێر تەشت یان نوێنەوە؟ باشە لەسەر چرادان داینانێن؟
\v 22 چونکە هیچ شتێکی شاردراوە نییە ئاشکرا نەبێت و نهێنی نییە دەرنەکەوێت.
\v 23 ئەگەر یەکێک گوێی هەیە بۆ بیستن، با ببیستێت.»
\s1 نموونەی پێوانە
\p 
\v 24 هەروەها پێی فەرموون: «وردببنەوە لەوەی دەیبیستن. بەو پێوانەیەی ئێوە بۆ خەڵک دەیپێون، خودا بۆتان دەپێوێتەوە و زیاتریشتان دەداتێ،
\v 25 چونکە ئەوەی هەیەتی، پێی دەدرێت، ئەوەش کە نییەتی، تەنانەت ئەوەی هەشیەتی لێی دەسەنرێتەوە.»
\s1 نموونەی گەشەکردنی تۆوێک
\p 
\v 26 هەروەها فەرمووی: «شانشینی خودا لە مرۆڤێک دەچێت تۆو بوەشێنێتە سەر زەوی.
\v 27 شەو دەخەوێت و ڕۆژ هەڵدەستێت، تۆوەکە سەر دەردەکات و گەشە دەکات، ئەویش نازانێت چۆن دەبێت.
\v 28 زەوی لە خۆیەوە بەرهەم دەدات، یەکەم جار گیا، ئینجا گوڵەگەنم، پاشان لە گوڵەگەنمەکەدا گەنمی تەواو.
\v 29 بەڵام کاتێک بەرەکە پێدەگات، دەستبەجێ داسی لێ گیر دەکات، چونکە دروێنەی هاتووە.»
\s1 نموونەی دەنکە خەرتەلە
\p 
\v 30 هەروەها فەرمووی: «شانشینی خودا لە چی دەچێت؟ بە چ نموونەیەک ڕوونی بکەینەوە؟
\v 31 شانشینی خودا وەک دەنکە خەرتەلەیەکە\f + \fr 4:31 \ft گیایەکی یەک ساڵەیە و چەندین جۆری هەیە. جۆرێکی لە وڵاتی ئیسرائیل هەیە کە بەرزییەکەی دەگاتە نزیکەی 3 بۆ 4 مەتر.‏\f*، کاتێک لەسەر زەوی تۆو دەکرێت، لە هەموو تۆوەکانی سەر زەوی بچووکترە.
\v 32 کاتێک تۆو دەکرێت، گەشە دەکات و لە هەموو ڕووەکەکان گەورەتر دەبێت و لقی گەورە دەردەکات، بە شێوەیەک باڵندەی ئاسمان دەتوانن لەژێر سێبەریدا هێلانە بکەن.»
\p 
\v 33 هەتا ئەو ئاستەی دەیانتوانی لێی تێبگەن، عیسا بە زۆر نموونەی لەو شێوەیە خەڵکی فێر دەکرد.
\v 34 بەبێ نموونە قسەی بۆ نەدەکردن، بەڵام کاتێک بە تەنها دەبوو لەگەڵ قوتابییەکانی خۆی هەموو واتاکانی بۆ ڕوون دەکردنەوە.
\s1 هێمنکردنەوەی ڕەشەبا
\p 
\v 35 هەر ئەو ڕۆژە، کاتێک ئێوارە داهات، بە قوتابییەکانی فەرموو: «با بپەڕینەوە ئەوبەر.»
\v 36 ئەوانیش خەڵکەکەیان بەجێهێشت و بە هەمان بەلەم عیسایان برد؛ بەلەمی دیکەشی لەگەڵ بوو.
\v 37 ئینجا ڕەشەبایەکی توند هەڵیکرد، شەپۆلەکان بە توندی لە بەلەمەکەیان دەدا، کە خەریک بوو پڕبێت لە ئاو.
\v 38 عیسا لە دواوە سەری خستبووە سەر سەرینێک و خەوتبوو. هەڵیانساند و پێیان گوت: «مامۆستا، بەلاتەوە گرنگ نییە ئەگەر لەناوبچین؟»
\p 
\v 39 ئەویش هەستا و لە ڕەشەباکەی ڕاخوڕی و بە دەریاچەکەی فەرموو: «بێدەنگ بە! هێمن بە!» ڕەشەباکە وەستا و بووە هێمنییەکی تەواو.
\p 
\v 40 ئینجا پێی فەرموون: «بۆچی ئەوەندە دەترسن؟ هێشتا باوەڕتان نییە؟»
\p 
\v 41 ئەوانیش تۆقین و بە یەکترییان دەگوت: «ئەمە کێیە؟ تەنانەت با و دەریاش گوێڕایەڵی دەبن!»
\c 5
\s1 دەرکردنی ڕۆحی پیس
\p 
\v 1 ئینجا گەیشتنە ئەوبەری دەریاچەکە، بۆ هەرێمی گەراسین.
\v 2 کاتێک عیسا لە بەلەمەکە دابەزی، یەکسەر لەناو گۆڕستان پیاوێکی تووش بوو ڕۆحی پیسی تێدابوو،
\v 3 لەناو گۆڕستاندا دەژیا، کەس نەیدەتوانی چیتر بیبەستێتەوە، تەنانەت بە زنجیریش.
\v 4 زۆر جار بە کۆت و زنجیر دەبەسترایەوە، بەڵام زنجیرەکانی دەپچڕاند و کۆتەکانیشی دەشکاند، کەس نەیدەتوانی بەسەریدا زاڵ بێت.
\v 5 شەو و ڕۆژ بەردەوام لەناو گۆڕستان و لە چیاکاندا بوو، هاواری دەکرد و بە بەرد لەشی خۆی بریندار دەکرد.
\p 
\v 6 کاتێک لە دوورەوە عیسای بینی، ڕایکرد و کڕنۆشی بۆ برد.
\v 7 بە دەنگێکی بەرز هاواری کرد: «چیت لە من دەوێت، ئەی عیسای کوڕی خودای هەرەبەرز؟ سوێندت دەدەم بە خودا، ئەشکەنجەم مەدە!»
\v 8 چونکە عیسا پێی فەرمووبوو: «ئەی ڕۆحی پیس، لە پیاوەکە وەرە دەرەوە!»
\p 
\v 9 ئینجا لێی پرسی: «ناوت چییە؟»
\p پێی گوت: «ناوم لێگیۆنە\f + \fr 5:9 \ft لێگیۆن: لاتینی، واتا لەشکری 6000 سەربازی.‏\f*، چونکە ئێمە زۆرین.»
\v 10 زۆریش لە عیسا پاڕایەوە نەیاننێرێتە دەرەوەی ناوچەکە.
\p 
\v 11 لەوێ ڕانە بەرازێکی گەورە لە قەد شاخەکە دەلەوەڕان،
\v 12 ڕۆحە پیسەکان لە عیسا پاڕانەوە: «بماننێرە ناو بەرازەکان، با بچینە ناویان.»
\v 13 ئەویش ڕێی پێدان. ڕۆحە پیسەکان هاتنە دەرەوە و چوونە ناو بەرازەکان، ئینجا ڕانەکە کە نزیکەی دوو هەزار سەر دەبوون، بە خێرایی لە قەدپاڵەکەوە بۆ ناو دەریاچەکە هەڵدێران و خنکان.
\p 
\v 14 بەرازەوانەکان ڕایانکرد و هەواڵیان دا بە شار و گوندەکان. خەڵکەکەش هاتن تاکو ببینن چی ڕوویداوە.
\v 15 کاتێک هاتنە لای عیسا، بینییان ئەوەی لەشکرێک ڕۆحی پیسی تێدابوو، دانیشتووە و پۆشتەیە و ئاقڵە، ئیتر ترسان.
\v 16 ئەوانەش کە بینیبوویان چی بەسەر بەرازەکان و ئەو کەسەدا هات کە ڕۆحی پیسی تێدابوو، ڕووداوەکەیان بۆ خەڵکەکە گێڕایەوە.
\v 17 ئیتر دەستیان بە پاڕانەوە کرد لە عیسا تاکو لە ناوچەکەیان بڕوات.
\p 
\v 18 کاتێک عیسا سواری بەلەمەکە دەبوو، ئەو کەسەی ڕۆحی پیسی تێدابوو، لێی پاڕایەوە کە لەگەڵی بڕوات.
\v 19 ڕێگای نەدا، بەڵکو پێی فەرموو: «بگەڕێوە ناو ماڵ و کەسوکارەکەت، بۆیان بگێڕەوە پەروەردگار چی بۆت کردووە و چۆن بەزەیی پێتدا هاتەوە.»
\v 20 جا ڕۆیشت و لە دە شارەکە\f + \fr 5:20 \ft دە شارەکە: دیکاپۆلیس، دەکەوێتە ڕۆژهەڵاتی ڕووباری ئوردون.‏\f* دەستی بە جاڕدانی هەموو ئەوە کرد کە عیسا بۆی کردبوو. هەموو سەرسام بوون.
\s1 زیندووکردنەوەی کچێک و چاککردنەوەی ژنێک
\p 
\v 21 دیسان عیسا بە بەلەمەکە پەڕییەوە ئەوبەر، هەر لە کەناری دەریاچەکە بوو خەڵکێکی زۆر لێی کۆبوونەوە.
\v 22 یەکێک لە پێشەوایانی کەنیشت هات، ناوی یایرۆس بوو، کاتێک عیسای بینی، لەبەرپێی کەوت و
\v 23 زۆر لێی پاڕایەوە: «کچە بچووکەکەم لە سەرەمەرگدایە، وەرە دەستی لەسەر دابنێ تاکو چاک بێتەوە و بژیێت.»
\v 24 عیسا لەگەڵی چوو، خەڵکێکی زۆر دوای کەوت و پاڵەپەستۆیان لێ دەکرد.
\p 
\v 25 ژنێک لەوێ بوو کە دوازدە ساڵ خوێنبەربوونی هەبوو.
\v 26 بە دەستی چەندین پزیشک ئازاری زۆری چێژتبوو، ئەوەی هەیبوو خەرجی خۆی کردبوو، بەڵام هیچ سوودێکی نەبوو، بەڵکو خراپتر ببوو.
\v 27 باسی عیسای بیستبوو، بۆیە هاتە ناو خەڵکەکە و لە دواوە دەستی لە کراسەکەی دا،
\v 28 چونکە لە دڵی خۆیدا گوتی: «ئەگەر تەنها دەست لە کراسەکەی بدەم، چاکدەبمەوە.»
\v 29 دەستبەجێ خوێن لەبەرڕۆیشتنەکەی ڕاوەستا و لە لەشیدا هەستی بە چاکبوونەوە کرد لە نەخۆشییەکەی.
\p 
\v 30 یەکسەر عیساش زانی هێزێک لێی هاتە دەرەوە، ئاوڕی لە خەڵکەکە دایەوە و فەرمووی: «کێ دەستی لە کراسەکەم دا؟»
\p 
\v 31 قوتابییەکانی وەڵامیان دایەوە: «دەبینیت خەڵکەکە پاڵەپەستۆت لێدەکەن، کەچی دەفەرمووی کێ دەستی لێدام؟»
\p 
\v 32 بەڵام عیسا چاوی دەگێڕا، تاکو بزانێت کێ بوو وای کرد.
\v 33 ژنەکەش کە بە ڕووداوەکەی خۆی دەزانی، بە ترس و لەرزەوە هات، لەبەردەمی کەوت و هەموو شتێکی بە ڕاستی پێ گوت.
\v 34 ئەویش پێی فەرموو: «کچم، باوەڕەکەت تۆی چاککردەوە، بڕۆ بە سەلامەت و لە نەخۆشییەکەت چاکببەوە.»
\p 
\v 35 کاتێک عیسا قسەی دەکرد، چەند کەسێک لە ماڵی پێشەوای کەنیشتەوە هاتن و گوتیان: «کچەکەت مرد، ئیتر ئەزیەت مەخەرە بەر مامۆستا.»
\p 
\v 36 عیسا قسەکانی ئەوانی بەرگوێ کەوت، بە پێشەواکەی کەنیشتی فەرموو: «مەترسە، تەنها باوەڕت هەبێت.»
\p 
\v 37 نەیهێشت کەس لەگەڵی بچێت، پەترۆس و یاقوب و یۆحەنای برای یاقوب نەبێت.
\v 38 هاتنە ماڵی پێشەواکەی کەنیشت، بینی هەرا و گریان و شیوەنێکی زۆرە.
\v 39 چووە ژوورەوە، پێی فەرموون: «بۆچی هەراتانە و دەگریێن؟ کچەکە نەمردووە، بەڵکو نوستووە.»
\v 40 بەمە خەڵکەکە پێی پێکەنین.
\p بەڵام عیسا هەموویانی دەرکردە دەرەوە، دایک و باوکی منداڵەکەی برد لەگەڵ ئەوانەی لەگەڵی بوون و چووە ژوورەوە بۆ ئەو شوێنەی منداڵەکەی لێبوو.
\v 41 دەستی منداڵەکەی گرت و پێی فەرموو: «تالیسا، قوم!» کە بە واتای «کیژۆڵە، پێت دەڵێم هەستە!» دێت.
\v 42 کچەکە کە تەمەنی دوازدە ساڵ بوو، دەستبەجێ هەستا و دەستی بە ڕۆیشتن کرد، جا هەموویان زۆر سەرسام بوون.
\v 43 بە توندیش ڕایسپاردن کەس بەمە نەزانێت و فەرمووی شتێکی بدەنێ با بیخوات.
\c 6
\s1 ڕەتکردنەوەی عیسا
\p 
\v 1 عیسا ئەوێی بەجێهێشت و گەڕایەوە شارەکەی خۆی، قوتابییەکانیشی دوای کەوتن.
\v 2 کە بووە شەممە، لە کەنیشتدا دەستی کرد بە فێرکردنی خەڵک، زۆر لەوانەی گوێیان لێی گرتبوو سەرسام بوون.
\p گوتیان: «ئەمە ئەمانەی لەکوێ بوو؟ ئەی ئەم داناییەی پێی دراوە و ئەم پەرجووانەی\f + \fr 6:2 \ft پەرجوو: موعجیزە.‏\f* لەسەر دەستی دەکرێن!
\v 3 ئەرێ ئەمە دارتاشەکەی کوڕی مریەم و براکەی یاقوب و یوسی و یەهوزا و شیمۆن نییە؟ خوشکەکانی لێرە لەلامان نین؟» ئیتر ڕەتیان کردەوە.
\p 
\v 4 بەڵام عیسا پێی فەرموون: «پێغەمبەر بێ ڕێز نییە، لە شاری خۆی و لەنێوان خزم و کەسوکار و ماڵی خۆی نەبێت.»
\v 5 ئیتر لەوێدا نەیتوانی هیچ پەرجووێک بکات، تەنها چەند نەخۆشێک نەبێت کە دەستی لەسەر دانان و چاکیکردنەوە.
\v 6 لە بێباوەڕیی ئەوان سەری سوڕما.
\s1 عیسا نێردراوەکانی دەنێرێت
\p ئینجا بە گوندەکانی دەوروبەردا دەگەڕا و خەڵکی فێر دەکرد.
\v 7 دوازدە قوتابییەکەی بانگکرد، دوو دوو دەستی بە ناردنیان کرد و دەسەڵاتی بەسەر ڕۆحە پیسەکاندا پێدان.
\p 
\v 8 ڕایسپاردن کە بۆ ڕێگا هیچ نەبەن جگە لە گۆچانێک، نە نان و نە توورەکە و نە پارە بۆ بەر پشتێن،
\v 9 پێڵاو لە پێ بکەن بەڵام کراسی زیادە لەبەر مەکەن.
\v 10 پێی فەرموون: «لە هەر شوێنێک چوونە ماڵێک، لەوێ بمێننەوە هەتا ئەوێ بەجێدەهێڵن.
\v 11 ئەگەر لە هەر شوێنێکیش پێشوازییان لێ نەکردن و گوێیان لێ نەگرتن، لەوێ بڕۆنە دەرەوە و تۆزی پێتان بتەکێنن، بۆ شایەتی لەسەریان.»
\p 
\v 12 ئەوانیش چوونە دەرەوە و جاڕی تۆبەکردنیان دا.
\v 13 ڕۆحی پیسی زۆریان دەرکرد و زۆر نەخۆشیان بە ڕۆن چەورکرد و چاکیان کردنەوە.
\s1 کوشتنی حەزرەتی یەحیا
\p 
\v 14 هێرۆدسی پاشا لەم بارەیەوە بیستی، چونکە ناوی عیسا دەنگیدابووەوە و دەیانگوت: «یەحیای لەئاوهەڵکێش لەناو مردووان هەستاوەتەوە، لەبەر ئەوە کاری پەرجوو لەسەر دەستی ئەو دەکرێت.»
\p 
\v 15 خەڵکی دیکە دەیانگوت: «ئەلیاسە.»
\p هەندێکیش دەیانگوت: «پێغەمبەرێکە، وەک پێغەمبەرانی سەردەمی کۆن.»
\p 
\v 16 بەڵام هێرۆدس کاتێک بیستی، گوتی: «یەحیایە، ئەوەی سەرم بڕی، ئەوە هەستاوەتەوە!»
\p 
\v 17 هێرۆدس لەبەر هێرۆدیای ژنی فیلیپۆسی برای، ئەوەی کە خۆی خواستبووی، ناردبووی و یەحیای گرتبوو، پەلبەستی کردبوو و خستبوویە زیندانەوە،
\v 18 لەبەر ئەوەی یەحیا بە هێرۆدسی دەگوت: «دروست نییە براژنەکەت بخوازیت.»
\v 19 ئیتر هێرۆدیا زۆر ڕقی لێی دەبووەوە و حەزی دەکرد بیکوژێت، بەڵام نەیدەتوانی،
\v 20 چونکە هێرۆدس لە یەحیا دەترسا، دەیزانی پیاوێکی ڕاستودروست و پیرۆزە، دەیپاراست. کاتێک گوێی لێ دەگرت زۆر دەشێوا، حەزیشی دەکرد گوێی لێ بگرێت.
\p 
\v 21 لە کۆتاییدا دەرفەتێک ڕێککەوت. هێرۆدس لە جەژنی لەدایکبوونیدا خوانێکی بۆ گەورە پیاوان و فەرماندەکانی و پیاو ماقوڵانی جەلیل سازکرد.
\v 22 کچی هێرۆدیا هاتە ژوورەوە و سەمای کرد. جا هێرۆدس و ئەوانەی دڵخۆش کرد کە لەگەڵی پاڵیاندابووەوە.
\p پاشا بە کچەکەی گوت: «ئەوەی دەتەوێت لە منی داوا بکە، دەتدەمێ.»
\v 23 سوێندیشی بۆ خوارد: «هەرچیم لێ داوا بکەیت دەتدەمێ، ئەگەر نیوەی شانشینەکەشم بێت.»
\p 
\v 24 ئەویش چووە دەرەوە و بە دایکی گوت: «داوای چی بکەم؟»
\p گوتی: «سەری یەحیای لەئاوهەڵکێش.»
\p 
\v 25 دەستبەجێ و بە پەلە هاتە ژوورەوە بۆ لای پاشا، داوای کرد و گوتی: «دەمەوێت ئێستا سەری یەحیای لەئاوهەڵکێشم لەسەر سینییەک بدەیتێ.»
\p 
\v 26 پاشا زۆر دڵگران بوو. بەڵام لەبەر سوێندەکەی و ئەوانەی لەگەڵی لەسەر خوان بوون، نەیویست ڕەتی بکاتەوە.
\v 27 پاشا یەکسەر جەلادی نارد و فەرمانی دا سەری بهێنێت. ئەویش چوو و لە زیندان سەری پەڕاند،
\v 28 لەسەر سینییەک سەری ئەوی هێنا و دایە کچەکە، کچەش دای بە دایکی.
\v 29 قوتابییەکانی یەحیا بیستیان، هاتن تەرمەکەیان هەڵگرت و لە گۆڕێکدا ناشتیان.
\s1 تێرکردنی پێنج هەزار کەس
\p 
\v 30 نێردراوان لە عیسا کۆبوونەوە و هەموو ئەو کارە و فێرکردنانەیان بۆ گێڕایەوە کە کردبوویان.
\v 31 ئەویش پێی فەرموون: «هەر خۆتان وەرنە شوێنێکی چۆڵ کەمێک پشوو بدەن.» لەبەر ئەوەی ئەوانەی دەهاتن و دەچوون زۆر بوون، دەرفەتی نان خواردنیان نەبوو.
\p 
\v 32 ئیتر هەر خۆیان بە بەلەم چوونە شوێنێکی چۆڵ.
\v 33 بەڵام خەڵکێکی زۆر ئەوانیان لە کاتی ڕۆیشتندا بینی و ناسیاننەوە، لە هەموو شارەکانەوە پێکەوە بە پێ بەرەو ئەوێ ڕایاندەکرد و پێشیان کەوتن.
\v 34 کاتێک عیسا لە بەلەمەکە دابەزی، خەڵکێکی بێشوماری بینی و دڵی پێیان سووتا، چونکە وەک مەڕی بێ شوان وابوون، هەر بۆیە دەستی کرد بە فێرکردنیان بە زۆر شت.
\p 
\v 35 کاتێک درەنگ داهات، قوتابییەکانی هاتنە لای و گوتیان: «ئەم شوێنە چۆڵە و ئێستا کاتیش درەنگە.
\v 36 بەڕێیان بکە، تاکو بچنە ئەم کێڵگە و گوندانەی دەوروبەر خواردن بۆ خۆیان بکڕن.»
\p 
\v 37 بەڵام وەڵامی دانەوە: «ئێوە شتێکیان بدەنێ با بیخۆن.»
\p پێیان گوت: «ئایا بچین بایی دوو سەد دینار\f + \fr 6:37 \ft یەک دینار کرێی ڕۆژانەی کرێکارێک بووە.‏\f* نانیان بۆ بکڕین و بیاندەینێ، تاکو بیخۆن؟»
\p 
\v 38 ئەویش پێی فەرموون: «بڕۆن بزانن چەند نانتان هەیە.»
\p کە زانییان گوتیان: «پێنج نان و دوو ماسی.»
\p 
\v 39 ئینجا فەرمانی پێدان خەڵکەکە کۆمەڵ کۆمەڵ لەسەر سەوزە گیا دابنیشێنن.
\v 40 بە کۆمەڵ دانیشتن، سەد سەد و پەنجا پەنجا.
\v 41 ئینجا پێنج نانەکە و دوو ماسییەکەی هەڵگرت و تەماشای ئاسمانی کرد، سوپاسی خودای کرد و نانەکانی لەتکرد و دایە قوتابییەکانی تاکو لەبەردەمیان دایبنێن، دوو ماسییەکەشی بەسەر هەموویان دابەش کرد.
\v 42 هەموو خواردیان و تێر بوون.
\v 43 پاشان دوازدە سەبەتەی پڕ لە پەلکەنان و ماسییان هەڵگرتەوە.
\v 44 ئەوانەی لە نانەکەیان خوارد پێنج هەزار پیاو بوون.
\s1 عیسا بەسەر ئاودا دەڕوات
\p 
\v 45 دەستبەجێ عیسا قوتابییەکانی ناچار کرد سواری بەلەمەکە بن و پێشی بکەون بۆ ئەوبەری دەریاچەکە، بۆ شارۆچکەی بێت‌سەیدا، هەتا خۆی خەڵکەکە بەڕێ دەکات.
\v 46 دوای بەڕێکردنیان، بۆ نوێژکردن چووە سەر شاخ.
\p 
\v 47 کە ئێوارە داهات، بەلەمەکە لە ناوەڕاستی دەریاچەکە بوو، عیساش بە تەنها لەسەر وشکانی بوو.
\v 48 کە بینی قوتابییەکانی بەهۆی سەوڵ لێدانەوە ماندوو بوون، چونکە ئاراستەی ڕەشەباکە پێچەوانە بوو، لە بەرەبەیان هاتە لایان، بەسەر دەریاچەکەدا ڕۆیشت و ویستی لێیان تێبپەڕێت.
\v 49 بەڵام کاتێک بینییان بەسەر دەریاچەکەدا دەڕوات، وایانزانی دێوەزمەیە، جا هاواریان کرد،
\v 50 چونکە هەموو بینییان و پەشۆکان.
\p ئەو دەستبەجێ قسەی لەگەڵ کردن: «ورەتان بەرز بێ! ئەوە منم. مەترسن.»
\v 51 ئینجا بۆ لایان سەرکەوتە ناو بەلەمەکە و ڕەشەباکە وەستا. جا بە تەواوی سەرسام بوون،
\v 52 لەبەر ئەوەی لە پەرجووی نانەکان تێنەگەیشتن؛ دڵیان هەر ڕەق بوو.
\s1 عیسا نەخۆشی دیکە چاک دەکاتەوە
\p 
\v 53 کاتێک عیسا و قوتابییەکانی پەڕینەوە ئەوبەر، هاتنە خاکی جەنیسارەت و لەنگەریان گرت.
\v 54 کاتێک لە بەلەمەکە دابەزین، خەڵک عیسایان ناسییەوە.
\v 55 بە پەلە ڕۆیشتن و دەستیان کرد بە هێنانی نەخۆشەکانیان بەسەر نوێنەکانیانەوە بۆ هەر شوێنێک کە دەیانبیست عیسای لێیە.
\v 56 بۆ هەر شوێنێک دەچوون، گوند، شار، کێڵگە، خەڵک نەخۆشەکانیان لە بازاڕ دادەنا و لێی دەپاڕانەوە کە تەنها دەست لە چمکی کراسەکەی بدەن. جا هەموو ئەوانەی دەستیان لێی دەدا چاکدەبوونەوە.
\c 7
\s1 سەرپێچیکردنی ڕاسپاردەی خودا
\p 
\v 1 فەریسی و هەندێک لە مامۆستایانی تەورات کە لە ئۆرشەلیمەوە هاتبوون لەلای عیسا کۆبوونەوە.
\v 2 بینییان هەندێک لە قوتابییەکانی بە دەستی پیس نان دەخۆن، واتا بێ دەست شوشتن،
\v 3 چونکە فەریسی و هەموو جولەکەکان نان ناخۆن ئەگەر بە باشی دەستیان نەشۆن، لەبەر ئەوەی پەیوەست بوون بە نەریتی پیرانەوە،
\v 4 هەروەها کاتێک لە بازاڕ دێنەوە نان ناخۆن هەتا خۆیان نەشۆن. زۆر دابونەریتی دیکەش هەیە کە جێبەجێی دەکەن، وەکو شوشتنی کاسە و چاپەست و دۆلکەی مس.
\p 
\v 5 فەریسی و مامۆستایانی تەوراتیش لە عیسایان پرسی: «بۆچی قوتابییەکانت لەسەر نەریتی پیران ناڕۆن و بە دەستی پیس نان دەخۆن؟»
\p 
\v 6 ئەویش پێی فەرموون: «ئیشایای پێغەمبەر سەبارەت بە ئێوەی دووڕوو پێشبینی باشی کردووە، وەک نووسراوە:
\q1 «﴿ئەم گەلە هەر بە دەم ڕێزم لێ دەگرن،
\q2 بەڵام دڵیان لێم دوورە.
\q1 
\v 7 بەخۆڕایی دەمپەرستن،
\q2 تەنها ڕاسپاردەی مرۆڤانە فێری خەڵک دەکەن.﴾\f + \fr 7:7 \ft \xt ئیشایا 29‏:13.‏\xt*\ft ‏\f*
\m 
\v 8 ئێوە ڕاسپاردەی خوداتان پشتگوێ خستووە و دەستتان بە نەریتی مرۆڤەوە گرتووە.»
\p 
\v 9 دیسان پێی فەرموون: «باش ڕاسپاردەی خودا ڕەت دەکەنەوە، بۆ ئەوەی پارێزگاری لە نەریتی خۆتان بکەن.
\v 10 ئەوەتا موسا گوتوویەتی: ﴿ڕێزی دایک و باوکتان بگرن﴾\f + \fr 7:10 \ft \xt دەرچوون 30‏:12 و دواوتار 5‏:16.‏\xt*\ft ‏\f*، ﴿ئەوەی نەفرەت لە دایکی یان باوکی بکات، دەبێت بکوژرێت.﴾\f + \fr 7:10 \ft \xt دەرچوون 21‏:17 و لێڤییەکان 20‏:9.‏\xt*\ft ‏\f*
\v 11 بەڵام ئێوە دەڵێن: ”ئەگەر یەکێک بە دایک یان باوکی بڵێت: ئەوەی لە منەوە سوودت لێی وەردەگرت، دەیکەمە قوربانی،“ کە دیارییە بۆ خودا،
\v 12 ئیتر نایەڵن هیچ شتێک بۆ دایک یان باوکی بکات.
\v 13 بەو نەریتەتان کە لە یەکتری وەردەگرن، دەسەڵاتی ڕاسپاردەی خودا ڕەت دەکەنەوە. زۆر شتی دیکەی وەک ئەمە دەکەن.»
\s1 ئەوەی مرۆڤ گڵاو دەکات
\p 
\v 14 دیسان عیسا خەڵکەکەی بانگکرد و پێی فەرموون: «هەموو گوێم لێ بگرن و تێبگەن.
\v 15 شت نییە لە دەرەوەی مرۆڤەوە بێتە ناوی و گڵاوی بکات. بەڵام ئەوەی لە مرۆڤەوە دێتە دەرەوە، ئەوە مرۆڤ گڵاو دەکات.
\v 16 [ئەوەی گوێی هەیە بۆ بیستن با گوێ بگرێت.]»
\p 
\v 17 کاتێک خەڵکەکەی بەجێهێشت و هاتە ماڵەوە، قوتابییەکانی بۆ نموونەکە پرسیاریان لێکرد.
\v 18 پێی فەرموون: «ئایا ئێوەش تێنەگەیشتوون؟ ئایا تێناگەن کە هەرچی لە دەرەوەی مرۆڤەوە دێتە ناویەوە ناتوانێت گڵاوی بکات؟
\v 19 چونکە ناچێتە دڵییەوە، بەڵکو سکی، پاشان دەچێتە دەرەوەی جەستەی.» بەمەش ڕایگەیاند کە هەموو خواردنێک پاکە.
\p 
\v 20 ئینجا فەرمووی: «ئەوەی لە مرۆڤ دەردەچێت، ئەوەیە مرۆڤ گڵاو دەکات،
\v 21 چونکە لە ناوەوە، لە دڵی مرۆڤەوە، بیری خراپ دەردەچێت: بەدڕەوشتی، دزی، کوشتن،
\v 22 داوێنپیسی، چاوچنۆکی، خراپەکاری، هەڵخەڵەتاندن، بەڕەڵایی، چاوپیسی، کفر، لووتبەرزی، گێلی.
\v 23 هەموو ئەم خراپانە لە ناخی مرۆڤەوە دەردەچن و گڵاوی دەکەن.»
\s1 باوەڕی ژنێکی کەنعانی
\p 
\v 24 عیسا ئەوێی بەجێهێشت و چوو بۆ هەرێمی سور. چووە ماڵێک و نەیویست کەس بزانێت، بەڵام نەیتوانی خۆی بشارێتەوە.
\v 25 لەبەر ئەوەی ژنێک کچەکەی ڕۆحی پیسی تێدابوو، کاتێک هەواڵی ئەوی بیست یەکسەر هات و لەبەرپێی کەوت.
\v 26 ژنەکەش یۆنانی بوو، لە ڕەگەزی فینیکیای سوریا بوو، داوای لێکرد ڕۆحە پیسەکە لە کچەکەی دەربکات.
\p 
\v 27 ئەویش پێی فەرموو: «جارێ با منداڵان تێر بن، چونکە ناشێت نانی منداڵان ببڕدرێت و فڕێبدرێت بۆ سەگ.»
\p 
\v 28 بەڵام ژنەکە وەڵامی دایەوە: «گەورەم! سەگیش لەژێر خواندا لە پاشماوەی منداڵان دەخوات.»
\p 
\v 29 پێی فەرموو: «لەبەر ئەم قسەیە، بڕۆ، ڕۆحە پیسەکە لە کچەکەت دەرچوو.»
\p 
\v 30 کاتێک ژنەکە گەڕایەوە ماڵەوە، بینی منداڵەکە لەسەر جێگاکەی پاڵکەوتووە و ڕۆحە پیسەکەی لێ دەرچووبوو.
\s1 چاکبوونەوەی کەڕولاڵێک
\p 
\v 31 ئینجا عیسا هەرێمی سوری بەجێهێشت و بە سەیدادا بەرەو دەریاچەی جەلیل هات، بە هەرێمی دە شارەکەدا.
\v 32 کەڕێکی لاڵەپەتەیان بۆ هێنا و لێی پاڕانەوە دەستی لەسەر دابنێت.
\p 
\v 33 عیسا بردییە لایەکەوە، دوور لە خەڵکەکە، پەنجەکانی خستە ناو گوێی کابراوە و تفی دا بە دەستی خۆی و پاشان دەستی لە زمانی دا.
\v 34 چاوی بەرەو ئاسمان هەڵبڕی و لە ناخەوە ئاهێکی هەڵکێشا و پێی فەرموو: «ئێففەسا!» واتا بکرێوە.
\v 35 دەستبەجێ گوێیەکانی کرانەوە و گرێی زمانی شلبووەوە و بە ڕەوانی قسەی کرد.
\p 
\v 36 ئینجا ڕایسپاردن بە کەس نەڵێن، بەڵام چەند ڕایدەسپاردن ئەوان زیاتر بڵاویان دەکردەوە.
\v 37 زۆر سەرسام بوون و دەیانگوت: «هەموو شتێکی بە باشی کردووە! وا دەکات کەڕ ببیستێت و لاڵ قسە بکات.»
\c 8
\s1 تێرکردنی چوار هەزار کەس
\p 
\v 1 لەو ڕۆژانەدا کۆمەڵە خەڵکێکی زۆری دیکە کۆبوونەوە. لەبەر ئەوەی هیچیان نەبوو بیخۆن، عیسا قوتابییەکانی بانگکرد و پێی فەرموون:
\v 2 «دڵم بەو خەڵکە دەسووتێت، ئەوە سێ ڕۆژە لەگەڵمدان و هیچیان نییە بیخۆن.
\v 3 ئەگەر بە برسیێتی بیاننێرمەوە ماڵ، لە ڕێگا بڕ ناکەن، هەندێکیشیان لە دوورەوە هاتوون.»
\p 
\v 4 قوتابییەکانی وەڵامیان دایەوە: «کێ دەتوانێت لەم چۆڵەوانییە نانی ئەمانە بدات؟»
\p 
\v 5 لێی پرسین: «چەند نانتان پێیە؟»
\p گوتیان: «حەوت.»
\p 
\v 6 ئیتر فەرمانی دا خەڵکەکە لەسەر زەوی دانیشن. حەوت نانەکەی وەرگرت و سوپاسی خودای کرد و لەتی کردن و دایە قوتابییەکان تاکو دابەشی بکەن، ئەوانیش بەسەر خەڵکەکەدا دابەشیان کرد.
\v 7 چەند ماسییەکی بچووکیشیان پێبوو، سوپاسی خودای کرد و فەرمووی با ئەمەش دابەش بکرێت.
\v 8 ئیتر خواردیان و تێربوون، دوایی حەوت سەبەتەی پڕ پەلکەنانیان کۆکردەوە.
\v 9 ژمارەی ئەوانەی ئامادەبوون نزیکەی چوار هەزار کەس دەبوون. دوای ئەوەی کە عیسا خەڵکەکەی بەڕێکرد،
\v 10 یەکسەر لەگەڵ قوتابییەکانی سواری بەلەم بوو و هاتە ناوچەی دەلمانووسە.
\s1 داواکردنی نیشانەی ئاسمانی
\p 
\v 11 فەریسییەکان هاتن و لەگەڵ عیسا دەستیان بە مشتومڕ کرد، هەروەها بۆ ئەوەی تاقی بکەنەوە، داوای نیشانەیەکی ئاسمانییان لێی کرد.
\v 12 عیسا لە ناخەوە ئاهێکی هەڵکێشا و فەرمووی: «بۆچی ئەم نەوەیە داوای نیشانە دەکات؟ ڕاستیتان پێ دەڵێم: نیشانە نادرێتە ئەم نەوەیە.»
\v 13 ئینجا بەجێی هێشتن. دووبارە سواری بەلەمەکە بوو و پەڕییەوە ئەوبەر.
\s1 هەویرترشی فەریسی و هێرۆدس
\p 
\v 14 قوتابییەکان لەبیریان چووبوو لەگەڵ خۆیان نان بهێنن، لە بەلەمەکەدا تەنها یەک نانیان پێبوو.
\v 15 عیسا ڕایسپاردن: «وریابن، ئاگاداری هەویرترشی فەریسییەکان و هەویرترشی هێرۆدس بن.»
\p 
\v 16 لەناو خۆیاندا بە یەکتریان گوت: «لەبەر ئەوەی نانمان پێ نییە.»
\p 
\v 17 عیسا کە بەمەی دەزانی، پێی فەرموون: «بۆ باسی ئەوە دەکەن کە نانتان پێ نییە؟ ئایا هێشتا نابینن و تێناگەن؟ ئایا هەتا ئێستا دڵتان هەر ڕەقە؟
\v 18 خۆ چاوتان هەیە، نابینن، گوێتان هەیە، نابیستن؟ هەروەها بیرتان نایەتەوە؟
\v 19 کاتێک پێنج نانەکەم بۆ پێنج هەزارەکە لەتکرد، چەند سەبەتەی پڕ لە پەلکەنانتان هەڵگرتەوە؟»
\p وەڵامیان دایەوە: «دوازدە.»
\p 
\v 20 «ئەی کاتی حەوت نانەکە بۆ چوار هەزار کەسەکە، چەند سەبەتەی پڕ لە پەلکەنانتان هەڵگرتەوە؟»
\p وەڵامیان دایەوە: «حەوت.»
\p 
\v 21 ئینجا پێی فەرموون: «هێشتا تێناگەن؟»
\s1 چاکبوونەوەی کەسێکی نابینا
\p 
\v 22 کاتێک عیسا و قوتابییەکانی هاتنە بێت‌سەیدا، کەسێکی نابینایان هێنایە لای عیسا و لێی پاڕانەوە دەستی لێ بدات.
\v 23 ئەویش دەستی نابیناکەی گرت، بردییە دەرەوەی دێیەکە و تفی لەسەر چاوی دا و دەستی لەسەر دانا و لێی پرسی: «هیچ دەبینیت؟»
\p 
\v 24 پیاوەکە سەیری دەوروبەری کرد و گوتی: «خەڵک دەبینم وەک درەخت دەڕۆن.»
\p 
\v 25 دیسان عیسا دەستی خستەوە سەر چاوی، چاوی تێبڕی و چاک بووەوە و هەموو شتێکی بە ڕوونی بینی.
\v 26 ئینجا بۆ ماڵی خۆی ڕەوانەی کردەوە و فەرمووی: «جارێ مەڕۆ بۆ ناو دێ.»
\s1 پەترۆس دان بەوەدا دەنێت کە عیسا مەسیحەکەیە
\p 
\v 27 عیسا و قوتابییەکانی بەرەو گوندەکانی قەیسەرییەی فیلیپۆس بەڕێکەوتن، لە ڕێگا لە قوتابییەکانی پرسی: «خەڵکی دەڵێن من کێم؟»
\p 
\v 28 وەڵامیان دایەوە: «هەندێک دەڵێن یەحیای لەئاوهەڵکێش، هەندێکیش دەڵێن ئەلیاس، هەندێکی دیکەش دەڵێن یەکێک لە پێغەمبەران.»
\p 
\v 29 لێی پرسین: «ئەی ئێوە دەڵێن من کێم؟»
\p پەترۆس وەڵامی دایەوە: «تۆ مەسیحەکەیت\f + \fr 8:29 \ft بە زمانی عیبری پێی دەگوترێ \tl مەشیخ‏\tl* یان \tl مەشیح‏\tl*. بە زمانی یۆنانی دەبێتە \tl کریستۆس‏\tl*، کە بە واتای (دەستنیشانکراو) لەلای خودا دێت کە ڕزگارکەری گەلەکەیەتی. بڕوانە یەکەم ساموئێل 16.‏\f*.»
\p 
\v 30 جا ئاگاداری کردنەوە لەلای کەس باسی نەکەن.
\s1 یەکەم باسی مردنی عیسا
\p 
\v 31 ئینجا دەستی کرد بە فێرکردنیان کە کوڕی مرۆڤ دەبێت زۆر ئازار بچێژێت، پیران و کاهینانی باڵا و مامۆستایانی تەورات ڕەتی بکەنەوە، بکوژرێت و دوای سێ ڕۆژ هەستێتەوە.
\v 32 عیسا قسەکەی ئەوەندە بە ئاشکرا کرد کە پەترۆس هێنایە ئەم لاوە و دەستی کرد بە سەرزەنشتکردنی.
\p 
\v 33 بەڵام عیسا ئاوڕی دایەوە و سەیری قوتابییەکانی کرد، سەرزەنشتی پەترۆسی کرد و فەرمووی: «لەبەرچاوم لاچۆ، ئەی شەیتان! تۆ بیر لە شتە خوداییەکان ناکەیتەوە، بەڵکو شتی مرۆڤانە.»
\s1 خۆ ئامادە کردن بۆ مردن
\p 
\v 34 ئینجا خەڵکەکە و قوتابییەکانی بانگکرد و پێی فەرموون: «ئەگەر کەسێک دەیەوێت ببێتە قوتابی من، با نکۆڵی لە خۆی بکات و خاچەکەی هەڵبگرێت و دوام بکەوێت.
\v 35 ئەوەی بیەوێت ژیانی خۆی ڕزگار بکات، دەیدۆڕێنێت، بەڵام ئەوەی لە پێناوی من و مزگێنییەکەم ژیانی خۆی بدۆڕێنێت، ڕزگاری دەکات.
\v 36 چی بەکەڵکی مرۆڤ دێت ئەگەر هەموو جیهان بباتەوە و خۆی بدۆڕێنێت؟
\v 37 یان کەسێک لە بەرامبەر ژیانیدا چ بەهایەک دەدات؟
\v 38 ئەوەی لەلای ئەم نەوە داوێنپیس و گوناهبارە شەرمی بە من و بە وتەکانم بێت، کوڕی مرۆڤیش شەرمی پێی دەبێت، کاتێک بە شکۆمەندی باوکیەوە لەگەڵ فریشتە پیرۆزەکاندا دێتەوە.»
\c 9
\s1 شێوە گۆڕانی عیسا
\p 
\v 1 ئینجا پێی فەرموون: «ڕاستیتان پێ دەڵێم: هەندێک لەوانەی لێرە ڕاوەستاون، مردن ناچێژن هەتا شانشینی خودا نەبینن بە هێزەوە دێت.»
\p 
\v 2 دوای شەش ڕۆژ، عیسا بە تەنها پەترۆس و یاقوب و یۆحەنای لەگەڵ خۆی برد و بۆ سەر چیایەکی بەرز ڕێبەریی کردن. پاشان لەپێشیان شێوەی گۆڕا.
\v 3 جلەکانی بووە سپییەکی بریسکەدار، سپیتر لەوەی کە هەرکەسێک لە جیهاندا بتوانێت بیکات.
\v 4 ئینجا ئەلیاس و موسایان بۆ دەرکەوت، لەگەڵ عیسادا کەوتنە گفتوگۆ.
\p 
\v 5 پەترۆسیش بە عیسای گوت: «ڕابی، پێمان باشە لێرە بین، با سێ کەپر دروستبکەین، یەکێک بۆ تۆ و یەکێک بۆ موسا و یەکێکیش بۆ ئەلیاس.»
\v 6 نەیدەزانی چی دەڵێت، چونکە تۆقیبوون.
\p 
\v 7 هەورێکیش هات و باڵی بەسەریاندا کێشا، دەنگێک لە هەورەکەوە هات: «ئەمە کوڕی خۆشەویستمە، گوێی لێ بگرن!»
\p 
\v 8 کاتێک لەناکاو سەیری دەوروپشتیان کرد، لە عیسا زیاتر کەسیان لەگەڵ خۆیان نەبینی.
\p 
\v 9 کاتێک لە چیاکە دەهاتنە خوارەوە، عیسا فەرمانی پێدان ئەوەی بینییان بە کەسی نەڵێن، هەتا کوڕی مرۆڤ لەناو مردووان هەڵدەستێتەوە.
\v 10 ئەوانیش بابەتەکەیان لەنێو خۆیاندا هێشتەوە و لەبارەی هەستانەوەی نێو مردووانەوە دەستیان بە گفتوگۆ کرد.
\p 
\v 11 جا پرسیاریان لێکرد: «بۆچی مامۆستایانی تەورات دەڵێن: ”دەبێت یەکەم جار ئەلیاس بێت“؟»
\p 
\v 12 عیسا وەڵامی دانەوە: «ڕاستە، ئەلیاس دێت و هەموو شتێک ڕێک دەخاتەوە. کەواتە بۆچی دەربارەی کوڕی مرۆڤ نووسراوە کە دەبێت زۆر ئازار بچێژێت و سووکایەتیی پێ بکرێت؟
\v 13 بەڵام پێتان دەڵێم، ئەلیاس هات و چییان ویست پێیان کرد، هەروەک ئەوەی لەبارەی ئەوەوە نووسراوە.»
\s1 دەرکردنی ڕۆحی پیس لە کوڕێکدا
\p 
\v 14 کاتێک هاتنەوە لای قوتابییەکانی دیکە، خەڵکێکی زۆریان لە دەوروپشتیان بینی و مامۆستایانی تەوراتیش دەمەقاڵێیان لەگەڵ دەکردن.
\v 15 کە هەموو خەڵکەکە عیسایان بینی یەکسەر سەرسام بوون، ڕایانکرد بەرەوپیری و سڵاویان لێکرد.
\p 
\v 16 عیسا لێی پرسین: «لەسەر چی دەمەقاڵێیان لەگەڵ دەکەن؟»
\p 
\v 17 یەکێک لە خەڵکەکە وەڵامی دایەوە: «مامۆستا، کوڕەکەم هێناوەتە لات، ڕۆحێکی لاڵی هەیە.
\v 18 لەکوێ بیگرێت، بە زەویدا دەدات، دەمی کەف دەکات و ددانەکانی جیڕدەکاتەوە و ڕەق دەبێت. داوام لە قوتابییەکانت کرد دەریبکەن، بەڵام نەیانتوانی.»
\p 
\v 19 عیسا وەڵامی دانەوە: «ئەی نەوەی بێباوەڕ، هەتا کەی لەگەڵتان بم؟ هەتا کەی بەرگەتان بگرم؟ منداڵەکە بهێننە لام.»
\p 
\v 20 ئەوانیش هێنایانە لای. کە ڕۆحە پیسەکە عیسای بینی، دەستبەجێ منداڵەکە فێی لێهات و کەوتە سەر زەوی، دەگەوزی و کەف لە دەمیەوە دەهات.
\p 
\v 21 عیسا لە باوکی منداڵەکەی پرسی: «لە کەیەوە وای لێهاتووە؟»
\p گوتی: «لە منداڵییەوە.
\v 22 زۆر جاریش خستوویەتییە ناو ئاگر یان ئاوەوە تاکو لەناوی ببات. ئەگەر دەتوانیت شتێک بکەیت، بەزەییت پێمان بێتەوە و یارمەتیمان بدە.»
\p 
\v 23 عیسا پێی فەرموو: «”ئەگەر دەتوانیت“؟ ئەوەی باوەڕ بهێنێت هەموو شتێکی بۆ دەبێت.»
\p 
\v 24 یەکسەر باوکی منداڵەکە هاواری کرد: «باوەڕم هەیە، یارمەتی بێباوەڕیم بدە!»
\p 
\v 25 عیسا کە بینی خەریکە قەرەباڵغ دەبێت، لە ڕۆحە پیسەکەی ڕاخوڕی: «ئەی ڕۆحی کەڕولاڵ، فەرمانت پێ دەکەم، لێی وەرە دەرەوە و نەچیتەوە ناوی!»
\p 
\v 26 ئینجا ڕۆحە پیسەکە هاواری کرد و بە توندی فێی لێهێنا و لێی هاتە دەرەوە. کوڕەکە وەک مردووی لێ هات، تەنانەت زۆر کەس گوتیان: «مرد.»
\v 27 بەڵام عیسا دەستی گرت و هەڵیستاندەوە، ئەویش ڕاوەستا.
\p 
\v 28 عیسا چووەوە ماڵ، قوتابییەکانی بە تەنها لێیان پرسی: «بۆچی ئێمە نەمانتوانی دەریبکەین؟»
\p 
\v 29 پێی فەرموون: «ئەم جۆرە بە نوێژ نەبێت دەرناکرێت.»
\s1 دووەم باسی مردنی عیسا
\p 
\v 30 لەوێ ڕۆیشتن و بە جەلیلدا تێپەڕین، عیساش نەیویست کەس بزانێت،
\v 31 چونکە قوتابییەکانی فێردەکرد و پێی دەفەرموون: «کوڕی مرۆڤ دەدرێتە دەست خەڵک و دەیکوژن، دوای کوشتنی بە سێ ڕۆژ هەڵدەستێتەوە.»
\v 32 بەڵام ئەوان لە قسەکە تێنەگەیشتن و ترسان لێی بپرسن.
\s1 کێ پایەبەرزترە؟
\p 
\v 33 ئینجا هاتنە کەفەرناحوم. کە گەیشتە ماڵەوە، عیسا لێی پرسین: «لە ڕێگا گفتوگۆی چیتان دەکرد؟»
\v 34 بەڵام ئەوان بێدەنگ بوون، چونکە لە ڕێگا مشتومڕیان لەگەڵ یەکتر کرد کە کامیان پایەبەرزترە.
\p 
\v 35 عیسا دانیشت و دوازدە قوتابییەکەی بانگکرد، پێی فەرموون: «ئەگەر یەکێک ویستی یەکەم بێت، با لەدوای هەمووان و خزمەتکاری هەمووان بێت.»
\p 
\v 36 ئینجا منداڵێکی هێنا و لە ناوەڕاستیاندا ڕایگرت، گرتییە باوەشی و پێی فەرموون:
\v 37 «ئەوەی بە ناوی منەوە پێشوازی لە یەکێک لەم منداڵانە بکات، پێشوازی لە من دەکات، ئەوەی پێشوازیم لێ بکات، پێشوازی لە من ناکات، بەڵکو لەوەی ناردوومی.»
\s1 ئەوەی دژمان نییە لەگەڵمانە
\p 
\v 38 یۆحەنا پێی گوت: «مامۆستا، یەکێکمان بینی بە ناوی تۆوە ڕۆحی پیسی دەردەکرد، ئێمەش ڕێمان لێ گرت، چونکە دوامان ناکەوێت.»
\p 
\v 39 عیسا فەرمووی: «ڕێی لێ مەگرن، کەس نییە بە ناوی منەوە پەرجوو بکات و بتوانێت لەدوای ماوەیەکی کورت بە خراپە باسم بکات،
\v 40 چونکە ئەوەی دژمان نییە لەگەڵمانە.
\v 41 ئەوەی بە ناوی منەوە جامێک ئاوی پێدان، لەبەر ئەوەی هی مەسیحن، ڕاستیتان پێ دەڵێم پاداشتی ون نابێت.
\s1 ئاگادارکردنەوە لەبارەی گوناه
\p 
\v 42 «ئەوەی یەکێک لەم بچووکانەی کە باوەڕیان بە من هەیە تووشی گوناه بکات، باشترە بۆی بەرداشێکی گەورە بە ملیەوە هەڵبواسرێت و فڕێبدرێتە دەریاوە.
\v 43 ئەگەر دەستت تووشی گوناهی کردیت، بیبڕەوە. بۆ تۆ باشترە بە دەستێکەوە بچیتە ناو ژیانەوە لەوەی دوو دەستت هەبێت و بچیتە دۆزەخەوە، ناو ئاگرێک کە کوژانەوەی بۆ نییە.
\v 44 [لەوێ کرمەکانیان نامرێت و ئاگرەکە ناکوژێتەوە.]
\v 45 ئەگەر پێت تووشی گوناهی کردیت، بیبڕەوە. بۆ تۆ باشترە بە پێیەکەوە بچیتە ناو ژیانەوە لەوەی کە بە دوو پێوە فڕێبدرێیتە ناو دۆزەخ.
\v 46 [لەوێ کرمەکانیان نامرێت و ئاگرەکە ناکوژێتەوە.]
\v 47 ئەگەر چاوت تووشی گوناهی کردیت، دەریبهێنە. بۆ تۆ باشترە بە یەک چاوەوە بچیتە ناو شانشینی خوداوە لەوەی بە دوو چاوەوە فڕێبدرێیتە ناو دۆزەخ.
\q1 
\v 48 «﴿لەوێ کرمەکانیان نامرێت و
\q2 ئاگرەکە ناکوژێتەوە.﴾\f + \fr 9:48 \ft \xt ئیشایا 66‏:24‏\xt*\ft ‏\f*
\m 
\v 49 هەموو کەسێک بە ئاگر سوێر دەکرێت.
\p 
\v 50 «خوێ باشە، بەڵام ئەگەر خوێ سوێرییەکەی نەما، بە چی سوێری دەکەنەوە؟ با خوێتان تێدابێت و لەگەڵ یەکتری لە ئاشتیدا بن.»
\c 10
\s1 ژنهێنان و تەڵاقدان
\p 
\v 1 ئینجا عیسا ئەوێی بەجێهێشت و هاتە هەرێمی یەهودیا و ئەوبەری ڕووباری ئوردون. دیسان خەڵک لێی کۆبوونەوە، وەک نەریتی خۆی فێری دەکردن.
\p 
\v 2 هەندێک فەریسی هاتن و بۆ تاقیکردنەوە پرسیاریان لێی کرد: «ئایا دروستە مێرد ژنەکەی تەڵاق بدات؟»
\p 
\v 3 وەڵامی دایەوە: «موسا فەرمانی چی پێ کردوون؟»
\p 
\v 4 گوتیان: «موسا ڕێی داوە پیاو تەڵاقنامە بنووسێت و لە ژنەکەی جودا ببێتەوە.»
\p 
\v 5 بەڵام عیسا پێی فەرموون: «لەبەر دڵڕەقیتان ئەم ڕاسپاردەیەی بۆ نووسین.
\v 6 بەڵام لە سەرەتای بەدیهێنانەوە، خودا ﴿بە نێر و مێ بەدیهێنان.﴾\f + \fr 10:6 \ft \xt پەیدابوون 1‏:27.‏\xt*\ft ‏\f*
\v 7 ﴿لەبەر ئەوە پیاو دایک و باوکی خۆی بەجێدەهێڵێت و بە ژنەکەیەوە دەنووسێت،
\v 8 ئیتر هەردووکیان دەبنە یەک جەستە.﴾\f + \fr 10:8 \ft \xt پەیدابوون 2‏:24.‏\xt*\ft ‏\f* کەواتە چیتر دوو نین، بەڵکو یەک جەستەن.
\v 9 لەبەر ئەوە ئەوەی خودا بە یەکتری گەیاندووە، با مرۆڤ جیای نەکاتەوە.»
\p 
\v 10 لە ماڵەوەش، قوتابییەکان دیسان لەم بارەیەوە لێیان پرسی.
\v 11 پێی فەرموون: «ئەوەی ژنەکەی تەڵاق بدات و یەکێکی دیکە بهێنێت، ئەوا داوێنپیسی بەرامبەر دەکات.
\v 12 ئەگەر ژن مێردەکەی تەڵاق بدات و مێرد بە یەکێکی دیکە بکات، ئەوا داوێنپیسی دەکات.»
\s1 عیسا منداڵان بەرەکەتدار دەکات
\p 
\v 13 خەڵکی منداڵیان هێنایە لای عیسا تاوەکو دەستیان لەسەر دابنێت\f + \fr 10:13 \ft مەبەست لە دەست لەسەر دانان، بەرەکەتدارکردنە.‏\f*، بەڵام قوتابییەکان سەرزەنشتیان کردن.
\v 14 کە عیسا ئەمەی بینی، تووڕە بوو، پێی فەرموون: «لێگەڕێن منداڵان بێنە لام، ڕێیان لێ مەگرن، چونکە شانشینی خودا هی وەک ئەمانەیە.
\v 15 ڕاستیتان پێ دەڵێم: ئەوەی وەک منداڵێک شانشینی خودا قبوڵ نەکات، هەرگیز ناچێتە ناویەوە.»
\v 16 منداڵەکانیشی لە باوەش کرد، دەستی لەسەر دانان و بەرەکەتی پێدان.
\s1 گەنجە دەوڵەمەندەکە
\p 
\v 17 کاتێک عیسا خەریک بوو دەڕۆیشت، پیاوێک بە پەلە بەرەو ڕووی هات، کڕنۆشی بۆ برد و لێی پرسی: «مامۆستای باش، چی بکەم تاکو ژیانی هەتاهەتایی بە میرات وەربگرم؟»
\p 
\v 18 عیسا پێی فەرموو: «بۆچی بە باش ناوم دەبەیت؟ بێجگە لە خودا کەس باش نییە.
\v 19 ڕاسپاردەکان دەزانیت: ﴿مەکوژە، داوێنپیسی مەکە، مەدزە، شایەتی درۆ مەدە، فێڵ مەکە، ڕێزی دایک و باوکت بگرە.﴾\f + \fr 10:19 \ft \xt دەرچوون 20‏:12 و دواوتار 5‏:16‏،20‏\xt*\ft ‏.‏\f*»
\p 
\v 20 ئەویش پێی گوت: «مامۆستا، لە منداڵییەوە هەموو ئەم ڕاسپاردانەم بەجێگەیاندووە.»
\p 
\v 21 عیسا سەیری کرد و خۆشیویست، پێی فەرموو: «شتێکت کەمە، بڕۆ هەرچیت هەیە هەمووی بفرۆشە و بیدە بە هەژاران، بەمە گەنجینەیەکت لە ئاسماندا دەبێت، ئینجا وەرە دوام بکەوە.»
\p 
\v 22 بەم قسەیە دڵی خورپەی کرد، بە دڵتەنگییەوە ڕۆیشت، چونکە سامانێکی زۆری هەبوو.
\p 
\v 23 عیسا سەیری دەوروپشتی کرد و بە قوتابییەکانی فەرموو: «چوونە ناو شانشینی خودا بۆ دەوڵەمەند چەند زەحمەتە!»
\p 
\v 24 قوتابییەکان لە قسەکانی سەرسام بوون، بەڵام عیسا دیسان پێی فەرموون: «کوڕینە، چوونە ناو شانشینی خودا چەند زەحمەتە!
\v 25 ئاسانترە وشترێک بە کونی دەرزییەکەوە بچێت لەوەی دەوڵەمەندێک بچێتە ناو شانشینی خوداوە.»
\p 
\v 26 جا زیاتر سەرسام بوون و بە یەکتریان گوت: «کەواتە کێ دەتوانێت ڕزگاری بێت؟»
\p 
\v 27 عیساش سەیری کردن و فەرمووی: «لەلای مرۆڤ مەحاڵە، بەڵام لەلای خودا نا، چونکە لەلای خودا هەموو شتێک دەبێت.»
\p 
\v 28 پەترۆس دەستی بە قسە کرد و گوتی: «ئەوەتا ئێمە وازمان لە هەموو شتێک هێناوە و دوات کەوتووین.»
\p 
\v 29 عیسا فەرمووی: «ڕاستیتان پێ دەڵێم: کەس نییە ماڵ، برا، خوشک، دایک، باوک، منداڵ یان کێڵگەی لە پێناوی من و مزگێنییەکەم بەجێهێشتبێت،
\v 30 ئێستا لەم دنیایە سەد ئەوەندە وەرنەگرێتەوە لە ماڵ، برا، خوشک، دایک، منداڵ و کێڵگە لەگەڵ چەوسانەوە، لەو دنیاش ژیانی هەتاهەتایی.
\v 31 بەڵام زۆر لە یەکەمینەکان دەبنە دواهەمین و دواهەمینەکانیش دەبنە یەکەمین.»
\s1 سێیەم باسی مردنی عیسا
\p 
\v 32 بە ڕێگاوە بەرەو ئۆرشەلیم سەردەکەوتن، عیسا پێشیان کەوتبوو، قوتابییەکانیش سەرسام ببوون، ئەوانەی دوای دەکەوتن دەترسان. دیسان دوازدە قوتابییەکەی جیا کردەوە و دەستی کرد بە باسکردنی ئەو شتانەی کە بەسەری دێت.
\v 33 فەرمووی: «ئەوا بۆ ئۆرشەلیم سەردەکەوین، کوڕی مرۆڤ دەدرێتە دەست کاهینانی باڵا و مامۆستایانی تەورات، بڕیاری مردنی دەدەن، دەیدەنە دەست ناجولەکەکان،
\v 34 گاڵتەی پێ دەکەن و تفی لێدەکەن و بە قامچی لێی دەدەن و دەیکوژن. دوای سێ ڕۆژ هەڵدەستێتەوە.»
\s1 خزمەتکار پایەبەرزترە
\p 
\v 35 یاقوب و یۆحەنای کوڕەکانی زەبدی هاتنە لای و پێیان گوت: «مامۆستا، دەمانەوێت هەرچی داوای دەکەین بۆمان بکەیت.»
\p 
\v 36 ئەویش پێی فەرموون: «چیتان دەوێت بۆتان بکەم؟»
\p 
\v 37 وەڵامیان دایەوە: «کاتێک لەسەر تەختی شکۆمەندییەکەت دانیشتیت، پێمان ڕەوا ببینە یەکێکمان لەلای ڕاستت و یەکێکمان لەلای چەپت دابنیشین.»
\p 
\v 38 بەڵام عیسا پێی فەرموون: «نازانن داوای چی دەکەن. ئایا دەتوانن ئەو جامە بخۆنەوە کە من دەیخۆمەوە؟ ئایا دەتوانن بەو ئازارەدا تێبپەڕن کە من پێیدا تێدەپەڕم\f + \fr 10:38 \ft مەبەستی لە لەخاچدانە.‏\f*؟»
\p 
\v 39 وەڵامیان دایەوە: «دەتوانین.»
\p عیساش پێی فەرموون: «ئەو جامەی من دەیخۆمەوە، ئێوەش دەیخۆنەوە، بەو شێوەیەی من بە ئازاردا تێدەپەڕم، ئێوەش پێیدا تێدەپەڕن.
\v 40 بەڵام دانیشتن لەلای ڕاست و چەپمەوە، هی من نییە تاکو بیبەخشم. ئەو شوێنانە هی ئەو کەسانەیە کە بۆیان ئامادە کراون.»
\p 
\v 41 کاتێک دە قوتابییەکەی دیکە قسەکانی یاقوب و یۆحەنایان بیستەوە، لێیان تووڕە بوون،
\v 42 بەڵام عیسا بانگی کردن و پێی فەرموون: «دەزانن ئەوانەی بە سەرۆکی نەتەوەکانی دیکە دادەنرێن وەک میر فەرمانڕەواییان بەسەردا دەکەن و گەورەکانیان دەسەڵاتیان بەسەردا دەسەپێنن.
\v 43 بەڵام لەنێو ئێوەدا ئاوا نابێت، بەڵکو ئەوەی دەیەوێت لەنێوتاندا پایەی بەرز بێت، با ببێتە خزمەتکارتان.
\v 44 ئەوەش کە دەیەوێ لەنێوتاندا ببێتە یەکەم، با ببێتە بەندەی هەمووتان،
\v 45 چونکە تەنانەت کوڕی مرۆڤیش نەهاتووە تاکو خزمەت بکرێت، بەڵکو خزمەت بکات و ژیانی خۆی بەخت بکات بۆ کڕینەوەی خەڵکێکی زۆر.»
\s1 عیسا کەسێکی نابینا چاک دەکاتەوە
\p 
\v 46 ئینجا گەیشتنە شاری ئەریحا. لەو کاتەی خۆی و قوتابییەکانی و خەڵکێکی زۆر لە شارەکە هاتنە دەرەوە، سواڵکەرێکی نابینا بە ناوی بارتیماوس کە بە واتای کوڕی تیماوس دێت، لەسەر ڕێگا دانیشتبوو.
\v 47 کە بیستی ئەوە عیسای ناسیرەییە، هاواری کرد: «عیسای کوڕی داود، بەزەییت پێمدا بێتەوە!»
\p 
\v 48 زۆر کەس ئەویان سەرزەنشت کرد تاکو بێدەنگ بێت. بەڵام زۆر بەرزتر هاواری دەکرد: «کوڕی داود، بەزەییت پێمدا بێتەوە!»
\p 
\v 49 عیسا ڕاوەستا و فەرمووی: «بانگی بکەن.»
\p ئەوانیش نابیناکەیان بانگکرد و پێیان گوت: «ورەت بەرز بێت! هەستە، بانگت دەکات.»
\v 50 ئیتر کەواکەی فڕێدا و هەستا و هاتە لای عیسا.
\p 
\v 51 عیسا لێی پرسی: «چیت دەوێ بۆت بکەم؟»
\p نابیناکە پێی گوت: «ڕابی، دەمەوێ ببینم.»
\p 
\v 52 عیساش پێی فەرموو: «بڕۆ! باوەڕەکەت تۆی چاککردەوە.» دەستبەجێ بینایی بۆ گەڕایەوە و بە ڕێگادا دوای عیسا کەوت.
\c 11
\s1 کەژاوەی پاشایانە
\p 
\v 1 کاتێک لە ئۆرشەلیم نزیک بوونەوە، لە بێت‌فاجی و بێت‌عەنیا لەلای کێوی زەیتوون، عیسا دووان لە قوتابییەکانی نارد،
\v 2 پێی فەرموون: «بڕۆنە ئەو گوندەی بەرامبەرتان، کاتێک دەچنە ناوی، دەبینن جاشکێک بەستراوەتەوە هەتا ئێستا کەس سواری نەبووە، بیکەنەوە و بیهێنن.
\v 3 ئەگەر یەکێک لێی پرسین: ”بۆ ئەمە دەکەن؟“ بڵێن: ”گەورەمان پێویستی پێیەتی، ئینجا زوو دەینێرێتەوە بۆ ئێرە.“»
\p 
\v 4 چوون و بینییان وا جاشکێک لەسەر ڕێگاکە، لەبەر دەرگای ماڵێک بەستراوەتەوە، ئەوانیش کردیانەوە.
\v 5 هەندێک کەس لەوێ ڕاوەستابوون، لێیان پرسین: «چی دەکەن، جاشکەکە دەکەنەوە؟»
\v 6 وەک ئەوەی عیسا پێی فەرمووبوون وەڵامیان دایەوە، ئیتر ڕێگایان دان.
\v 7 جاشکەکەیان بۆ عیسا هێنا و کەواکانیان خستە سەری، ئەویش سواری بوو.
\v 8 زۆر کەسیش کەواکانیان لەسەر ڕێگاکە ڕاخست، هەندێکیش لە باخەکان لقەداریان بڕیبووەوە.
\v 9 ئەوانەی لەپێشییەوە و ئەوانەش کە لەدوایەوە دەڕۆیشتن، هاواریان دەکرد:
\q1 «﴿هۆسانا!\f + \fr 11:9 \ft لە زمانی عیبری دەربڕینێکە بە واتای ڕزگارمان بکە، بووە هاواری ستایش‏.‏\f* پیرۆزە ئەوەی بە ناوی یەزدانەوە دێت!﴾\f + \fr 11:9 \ft \xt زەبوورەکان 118‏:25‏،26.‏\xt*\ft ‏\f*»
\b
\q1 
\v 10 «پیرۆزە ئەو شانشینەی داودی باوکمان کە دێت!»
\b
\q1 «هۆسانا بۆ خودا!»
\p 
\v 11 عیسا چووە ناو ئۆرشەلیم بۆ ناو حەوشەکانی پەرستگا، تەماشای هەموو شتێکی دەوروبەری کرد، بەڵام لەبەر ئەوەی کات درەنگ بوو، لەگەڵ دوازدە قوتابییەکە چوونە دەرەوەی شار بۆ گوندی بێت‌عەنیا.
\s1 دار هەنجیری بێ بەر
\p 
\v 12 بۆ بەیانی کە بێت‌عەنیایان بەجێهێشت، عیسا برسی بوو.
\v 13 لە دوورەوە دار هەنجیرێکی بینی گەڵای کردبوو، بەرەو لای چوو بە ئومێدی ئەوەی شتێکی پێوە ببینێ. گەیشتە لای و لە گەڵا زیاتر هیچی پێوە نەبینی، چونکە وەرزی هەنجیر نەبوو.
\v 14 ئینجا پێی فەرموو: «ئیتر هەرگیز کەس لە بەرت ناخوات.» قوتابییەکانیشی گوێیان لێبوو.
\s1 پاککردنەوەی پەرستگا
\p 
\v 15 هاتنە ئۆرشەلیم و عیسا چووە ناو حەوشەکانی پەرستگا و دەستی کرد بە دەرکردنی ئەوانەی لەوێ خەریکی کڕین و فرۆشتن بوون، مێزی پارەگۆڕەوان و کورسی کۆترفرۆشانی سەرەوژێر کرد.
\v 16 نەیدەهێشت کەس بە شتومەکەوە بە ناو حەوشەکانی پەرستگادا تێبپەڕێت.
\v 17 فێری دەکردن و دەیفەرموو: «ئایا نەنووسراوە: ﴿ماڵەکەم بە ماڵی نوێژ ناودەبردرێت بۆ هەموو گەلان﴾\f + \fr 11:17 \ft \xt ئیشایا 56‏:7‏\xt*\ft ‏.‏\f*؟ بەڵام ئێوە کردووتانە بە ﴿ئەشکەوتی دزان!﴾\f + \fr 11:17 \ft \xt یەرمیا 7‏:11‏\xt*\ft ‏.‏\f*»
\p 
\v 18 کاهینانی باڵا و مامۆستایانی تەورات گوێیان لێبوو، بیریان دەکردەوە چۆن لەناوی ببەن، چونکە لێی دەترسان لەبەر ئەوەی هەموو خەڵکەکە لە فێرکردنەکانی سەرسام ببوون.
\p 
\v 19 کاتێک ئێوارە داهات، عیسا و قوتابییەکانی چوونە دەرەوەی شار.
\s1 دەربارەی هێزی باوەڕ
\p 
\v 20 بەیانی کە بەوێدا تێپەڕینەوە، دار هەنجیرەکەیان بینی لە ڕەگەوە وشک بووە.
\v 21 پەترۆس بیری کەوتەوە و گوتی: «ڕابی، سەیر بکە! دار هەنجیرەکەی نەفرەتت لێکرد، وشک بووە!»
\p 
\v 22 عیسا وەڵامی دایەوە: «باوەڕتان بە خودا هەبێت.
\v 23 ڕاستیتان پێ دەڵێم: ئەوەی بەم کێوە بڵێت ”هەڵبکەنرێ و بکەوە ناو دەریاوە،“ لە دڵدا گومان نەکات، بەڵکو باوەڕ بکات ئەوەی دەیڵێت دەبێت، ئەوا بۆی دەبێت.
\v 24 لەبەر ئەوە پێتان دەڵێم: هەموو ئەوەی داوای دەکەن و نوێژی بۆ دەکەن، باوەڕ بکەن کە وەرتانگرتووە، بۆتان دەبێت.
\v 25 کاتێک دەوەستن نوێژ بکەن، ئەگەر شتێکتان بەسەر یەکێکەوە هەبێت لێی خۆشبن، تاکو باوکیشتان ئەوەی کە لە ئاسمانە لە گوناهەکانتان خۆشبێت.
\v 26 [بەڵام ئەگەر ئێوە لێ خۆش نەبن، باوکی ئاسمانیشتان لە گوناهەکانتان خۆش نابێت.]»
\s1 دەسەڵاتی عیسا
\p 
\v 27 دیسان هاتنەوە ئۆرشەلیم، عیسا لە حەوشەکانی پەرستگا دەگەڕا، کاهینانی باڵا و مامۆستایانی تەورات و پیران هاتنە لای و
\v 28 لێیان پرسی: «ئەمانە بە چ دەسەڵاتێک دەکەیت؟ کێ ئەم دەسەڵاتەی بە تۆ داوە ئەم شتانە بکەیت؟»
\p 
\v 29 عیسا پێی فەرموون: «پرسیارێکتان لێ دەکەم، وەڵامم بدەنەوە، منیش پێتان دەڵێم بە چ دەسەڵاتێک ئەمانە دەکەم:
\v 30 لەئاوهەڵکێشانی یەحیا لە ئاسمانەوە بوو یان لە مرۆڤەوە؟ وەڵامم بدەنەوە!»
\p 
\v 31 لەنێو خۆیاندا کەوتنە ڕاوێژکردن و گوتیان: «ئەگەر بڵێین، ”لە ئاسمانەوە بوو،“ دەڵێت، ”باشە بۆچی باوەڕتان پێی نەکرد؟“
\v 32 ئەگەریش بڵێین، ”لە مرۆڤەوە بوو“…» لە خەڵک دەترسان، چونکە یەحیا لەلای هەمووان بەڕاستی بە پێغەمبەر دادەنرا.
\p 
\v 33 ئینجا وەڵامی عیسایان دایەوە: «نازانین.»
\p عیساش پێی فەرموون: «منیش پێتان ناڵێم بە چ دەسەڵاتێک ئەمانە دەکەم.»
\c 12
\s1 نموونەی ڕەزەوانە کرێگرتەکان
\p 
\v 1 عیسا بە نموونە دەستی کرد بە قسەکردن بۆیان: «کابرایەک ڕەزێکی چاند، پەرژینێکی بە دەوریدا کرد، چاڵێکی بۆ ترێ گوشین تێدا هەڵکەند و قوللەیەکی چاودێری بنیاد نا. بە ڕەزەوانانی سپارد و گەشتی کرد.
\v 2 لە وەرزی خۆیدا خزمەتکارێکی بۆ لای ڕەزەوانەکان نارد، تاکو بەرهەمی ڕەزەکە لە ڕەزەوانەکان وەربگرێت.
\v 3 بەڵام گرتییان و لێیاندا و بە دەستی بەتاڵ ناردییانەوە.
\v 4 دیسان خزمەتکارێکی دیکەی بۆ لایان نارد، سەری ئەمیشیان شکاند و سووکایەتییان پێ کرد.
\v 5 یەکێکی دیکەشی نارد، ئەویشیان کوشت. زۆر خزمەتکاری دیکەشی نارد، لە هەندێکیان دا و هەندێکیان کوشت.
\p 
\v 6 «تەنها کوڕە خۆشەویستەکەی مابوو، لە کۆتاییدا ئەویشی بۆ لایان نارد و گوتی: ”ڕێزی کوڕەکەم دەگرن.“
\p 
\v 7 «بەڵام ئەو ڕەزەوانانە بە یەکتریان گوت: ”ئەوەتا میراتگر، با بیکوژین، تاکو ببینە میراتگر.“
\v 8 ئینجا گرتیان و کوشتیان و فڕێیان دایە دەرەوەی ڕەزەکە.
\p 
\v 9 «خاوەنی ڕەزەکە چی دەکات؟ دێت و ئەم ڕەزەوانانە لەناودەبات و ڕەزەکە دەداتە خەڵکی دیکە.
\v 10 ئەم نووسراوە پیرۆزەتان نەخوێندووەتەوە:
\q1 «﴿ئەو بەردەی وەستاکان ڕەتیان کردەوە،
\q2 بوو بە گرنگترین بەردی بناغە\f + \fr 12:10 \ft بەردێکی گەورەیە کە لە گۆشەی دیوار دادەنرێت، لەو بەردانە بەهێزترە کە لە دیوارەکە بەکاردێت و دەبێتە هۆی بەهێزکردنی دیوارەکە.‏\f*.
\q1 
\v 11 ئەمە لەلایەن یەزدانەوە بوو،
\q2 لەبەرچاومان سەیرە﴾\f + \fr 12:11 \ft \xt زەبوورەکان 118‏:22‏،23‏\xt*\ft ‏.‏\f*؟»
\p 
\v 12 کاهینانی باڵا دەیانویست بیگرن، چونکە زانییان نموونەکەی لەسەر ئەوان فەرموو، بەڵام لە خەڵکەکە ترسان، ئیتر وازیان لێ هێنا و ڕۆیشتن.
\s1 سەرانەدان بە قەیسەر
\p 
\v 13 کاهینانی باڵا هەندێک لە فەریسییەکان و هێرۆدسییەکانیان ناردە لای عیسا، تاکو بە وشەیەکی تووشی بکەن.
\v 14 هاتن و پێیان گوت: «مامۆستا، دەزانین تۆ ڕاستگۆیت و لە کەس سڵ ناکەیتەوە، چونکە تەماشای ڕواڵەتی خەڵک ناکەیت، بەڵکو بە ڕاستی ڕێگای خودا فێر دەکەیت. دروستە سەرانە بدرێتە قەیسەر یان نا؟ بیدەین یان نا؟»
\p 
\v 15 بەڵام عیسا بە دووڕوویی ئەوانی زانی و پێی فەرموون: «بۆچی تاقیم دەکەنەوە؟ دینارێکم بۆ بهێنن با بیبینم.»
\v 16 هێنایان و پێی فەرموون: «ئەم وێنە و نووسینە هی کێیە؟»
\p وەڵامیان دایەوە: «هی قەیسەر.»
\p 
\v 17 عیساش پێی فەرموون: «هی قەیسەر بدەنە قەیسەر، هی خوداش بدەنە خودا.»
\p ئیتر زۆر پێی سەرسام بوون.
\s1 زیندووبوونەوەی مردووان
\p 
\v 18 سەدوقییەکان\f + \fr 12:18 \ft چینێکی جولەکە بوون کە زۆربەیان کاهین بوون، باوەڕیان بە فریشتە و هەستانەوە نەبوو.‏\f*، ئەوانەی کە دەڵێن هەستانەوە نییە، هاتنە لای و پرسیاریان لێکرد:
\v 19 «مامۆستا، موسا بۆی نووسیوین\f + \fr 12:19 \ft بڕوانە دواوتار 25‏:5‏-10.‏\f*، ئەگەر یەکێک براکەی بە وەجاخکوێری مرد و ژنەکەی لەپاش خۆی بەجێهێشت، ئەوا براژنەکەی دەخوازێتەوە و وەچە بۆ براکەی دەخاتەوە.
\v 20 حەوت برا هەبوون، یەکەمیان ژنی هێنا و بە وەجاخکوێری مرد.
\v 21 دووەم خواستییەوە و بە وەجاخکوێری مرد، سێیەمیش ئاوا.
\v 22 هەر حەوتەکە وەجاخکوێر بوون، لەدوای هەموویان ژنەکەش مرد.
\v 23 ئایا لە ڕۆژی زیندووبوونەوەدا دەبێتە ژنی کامیان؟ چونکە ژنی هەر حەوتیان بووە.»
\p 
\v 24 عیساش پێی فەرموون: «ئایا ئێوە هەڵە نین، چونکە نە لە نووسراوە پیرۆزەکان دەزانن و نە لە هێزی خودا؟
\v 25 کاتێک لە مردن هەڵدەستێنرێنەوە، نە ژن دەهێنن و نە مێرد دەکەن، بەڵکو وەک فریشتە لە ئاسمان دەبن.
\v 26 بەڵام دەربارەی مردووان کە هەڵدەستنەوە، ئایا لە پەڕتووکی موسادا نەتانخوێندووەتەوە، چۆن لە دەوەنەکەدا خودا پێی فەرموو: ﴿من خودای ئیبراهیم و خودای ئیسحاق و خودای یاقوبم﴾؟\f + \fr 12:26 \ft \xt دەرچوون 3‏:6.‏\xt*\ft ‏\f*
\v 27 ئەو خودای مردووان نییە، بەڵکو هی زیندووانە. زۆر بە هەڵەدا چوونە!»
\s1 گەورەترین ڕاسپاردە
\p 
\v 28 یەکێک لە مامۆستایانی تەورات هات، گوێی لە گفتوگۆکەیان بوو، بینی عیسا وەڵامێکی باشی دانەوە، لێی پرسی: «چ ڕاسپاردەیەک لە هەموویان گرنگترە؟»
\p 
\v 29 عیسا وەڵامی دایەوە: «لە هەموویان گرنگتر ئەمەیە: ﴿ئەی ئیسرائیل گوێ بگرن، یەزدانی پەروەردگارمان یەک یەزدانە،
\v 30 جا بە هەموو دڵ و بە هەموو گیان و بە هەموو بیر و بە هەموو تواناتانەوە یەزدانی پەروەردگارتان خۆشبوێ.﴾\f + \fr 12:30 \ft دواوتار 6‏:4، 5.‏\f*
\v 31 لەدوای ئەویش ئەمەیە، ﴿نزیکەکەت وەک خۆت خۆشبوێت،﴾\f + \fr 12:31 \ft \xt لێڤییەکان 19‏:18.‏\xt*\ft ‏\f* هیچ ڕاسپاردەیەک لەم دوو ڕاسپاردەیە گرنگتر نییە.»
\p 
\v 32 مامۆستاکەی تەوراتیش پێی گوت: «ڕاستە مامۆستا، ڕاستت فەرموو کە یەک خودا هەیە و بێجگە لە ئەو هیچ خودایەکی دیکە نییە.
\v 33 خۆشویستنی ئەویش بە هەموو دڵ و بە هەموو تێگەیشتن و بە هەموو تواناوە، هەروەها خۆشویستنی نزیکەکەت وەک خۆت، لە هەموو جۆرە قوربانی سووتاندن و پێشکەشکراوێک باشترە.»
\p 
\v 34 عیسا بینی بە داناییەوە وەڵامی دایەوە، پێی فەرموو: «لە پاشایەتی خوداوە دوور نیت.» ئیتر کەس نەیوێرا هیچ پرسیارێکی دیکەی لێ بکات.
\s1 مەسیح و داود
\p 
\v 35 کاتێک عیسا لە حەوشەکانی پەرستگا خەڵکی فێر دەکرد فەرمووی: «مامۆستایانی تەورات چۆن دەڵێن: ”مەسیح کوڕی داودە“؟
\v 36 داود خۆی بە سروشی ڕۆحی پیرۆز گوتی:
\q1 «﴿یەزدان بە خاوەن شکۆی منی فەرموو:
\q2 ”لە دەستەڕاستم دابنیشە
\q2 هەتا دوژمنانت دەخەمە ژێر پێت.“﴾\f + \fr 12:36 \ft \xt زەبوورەکان 110‏:1.‏\xt*\ft ‏\f*
\m 
\v 37 داود خۆی پێی دەڵێ ”خاوەن شکۆ“، ئیتر چۆن دەبێتە کوڕی؟»
\p خەڵکەکە زۆر بە خۆشییەوە گوێیان لێی دەگرت.
\s1 ئاگادارکردنەوە لە مامۆستایانی تەورات
\p 
\v 38 لە فێرکردنەکەیدا دەیفەرموو: «ئاگاداری مامۆستایانی تەورات بن، حەز دەکەن بە جلی شۆڕەوە بگەڕێن و پێیان خۆشە لە بازاڕدا سڵاویان لێ بکرێت،
\v 39 لە کەنیشتەکان ڕیزی پێشەوە بگرن و لە میوانیشدا لای سەرەوە.
\v 40 ماڵی بێوەژن هەڵدەلووشن و بۆ خۆدەرخستن نوێژەکانیان درێژ دەکەنەوە. ئەمانە سزایان گەورەترە.»
\s1 بەخشینی بێوەژن
\p 
\v 41 عیسا بەرامبەر گەنجینەی پەرستگا دانیشت و سەیری کرد چۆن خەڵکی پارەیان دەخەنە ناو گەنجینەکەوە، زۆرێک لە دەوڵەمەندەکان پارەی زۆریان دادەنا.
\v 42 بێوەژنێکی هەژار هات و دوو فلسی دانا کە نیو عانەیە\f + \fr 12:42 \ft یۆنانی: کودرانتیس. یەک لە 64 بەشی دینارێک.‏\f*.
\p 
\v 43 قوتابییەکانی بانگکرد و پێی فەرموون: «ڕاستیتان پێ دەڵێم، ئەم بێوەژنە هەژارە، لە هەموو ئەوانەی دیکە پارەی زیاتر خستە ناو گەنجینەکە،
\v 44 چونکە هەمووان لە زیادەی خۆیان بەخشییان، بەڵام ئەم بێوەژنە، سەرەڕای هەژارییەکەی هەموو بژێوییەکەی بەخشی.»
\c 13
\s1 نیشانەکانی کۆتایی زەمان
\p 
\v 1 کاتێک عیسا لە پەرستگا دەهاتە دەرەوە، یەکێک لە قوتابییەکانی پێی گوت: «مامۆستا تەماشا بکە! چ جۆرە بەرد و چ جۆرە تەلارێکن!»
\p 
\v 2 عیساش پێی فەرموو: «ئەم تەلارە مەزنانە دەبینیت؟ لێرەدا بەردی بەسەر بەردیەوە نامێنێت و هەمووی دەڕووخێت.»
\p 
\v 3 کاتێک عیسا لەسەر کێوی زەیتوون بەرامبەر پەرستگاکە دانیشتبوو، پەترۆس و یاقوب و یۆحەنا و ئەندراوس بە تەنها لێیان پرسی:
\v 4 «پێمان بڵێ کەی ئەمانە ڕوودەدەن؟ هەروەها ئەو نیشانەیە چییە کە ئاماژە بە نزیکبوونەوەی ڕوودانی ئامانە دەکات؟»
\p 
\v 5 عیسا وەڵامی دانەوە: «ئاگاداربن، کەس چەواشەتان نەکات.
\v 6 زۆر کەس بە ناوی منەوە دێن و دەڵێن، ”من ئەوم.“ زۆر کەسیش چەواشە دەکەن.
\v 7 کاتێک جەنگ و هەواڵی جەنگیش دەبیستن مەتۆقن. دەبێت ئەمە ڕووبدات، بەڵام هێشتا کۆتایی نییە.
\v 8 نەتەوە لە نەتەوە ڕاست دەبێتەوە و شانشین لە شانشین. قاتوقڕی و بوومەلەرزەش لە شوێنی جیاجیا دەبێت. بەڵام ئەمانە سەرەتای ژانەکانن.
\p 
\v 9 «ئاگاداری خۆتان بن، چونکە دەدرێنە دادگا و لە کەنیشتەکان بە قامچی لێتان دەدرێت. لە پێناوی مندا لەبەردەم فەرمانڕەوا و پاشایان ڕادەوەستێنرێن، وەک شایەتی بۆ ئەوان.
\v 10 هەروەها دەبێ یەکەم جار مزگێنییەکەم بە هەموو نەتەوەکان ڕابگەیەنرێت.
\v 11 کاتێکیش دەتانگرن و ڕادەستتان دەکەن، پێشوەخت نیگەران مەبن لەوەی چی بڵێن، بەڵکو لەو کاتەدا چیتان پێ دەدرێت بەوە بدوێن، چونکە ئێوە نین دەدوێن، بەڵکو ڕۆحی پیرۆزە.
\p 
\v 12 «برا برای خۆی بۆ مردن بە دەستەوە دەدات، باوکیش منداڵی خۆی. منداڵان لە دایک و باوکیان هەڵدەگەڕێنەوە و بە کوشتنیان دەدەن.
\v 13 لەبەر ناوی من هەمووان ڕقیان لێتان دەبێتەوە، بەڵام ئەوەی هەتا کۆتایی دانبەخۆیدا بگرێت، ڕزگاری دەبێت.
\s1 گەورەترین تەنگانە
\p 
\v 14 «کاتێک ﴿قێزەونی وێرانکەر﴾\f + \fr 13:14 \ft \xt دانیال 9‏:27؛ 11‏:31؛ 12‏:11‏\xt*\ft ‏\f* دەبینن لەو جێگایە ڕاوەستاوە کە نابێت لێی بێ (با خوێنەر تێبگات)، ئینجا با ئەوانەی لە یەهودیان بەرەو چیاکان ڕابکەن،
\v 15 ئەوەی لە سەربانە، با نەیەتە خوارەوە و نەچێتە ژوورەوە تاکو شتێک لە ماڵەوە ببات،
\v 16 هەروەها ئەوەی لە کێڵگەیە با نەگەڕێتەوە تاکو جلەکەی ببات.
\v 17 لەو ڕۆژانەدا قوڕبەسەر دووگیان و شیردەر!
\v 18 نوێژ بکەن تاکو ئەوە لە زستاندا نەبێت،
\v 19 چونکە لەو ڕۆژانەدا تەنگانەیەک ڕوودەدات کە هەر لە سەرەتای دروستکردنی بەدیهێنراوانەوە لە لایەن خودا هەتا ئێستا ئاوا نەبووە و نابێت.
\p 
\v 20 «ئەگەر پەروەردگار ئەو ڕۆژانەی کەم نەکردایەوە، کەس ڕزگاری نەدەبوو. بەڵام لە پێناوی ئەو هەڵبژێردراوانەی\f + \fr 13:20 \ft بڕوانە نامەی ڕۆما بەشی 9 تاکو 11.‏\f* کە ئەو هەڵیبژاردوون، ئەو ڕۆژانەی کەم کردووەتەوە.
\v 21 ئەگەر ئەو کاتە یەکێک پێی گوتن: ”ئەوەتا مەسیح لێرەیە!“ یان: ”ئەوەتا لەوێیە!“ باوەڕ مەکەن،
\v 22 چونکە چەند مەسیحێکی درۆزن و پێغەمبەرانی درۆزن\f + \fr 13:22 \ft کەسانێک بانگەشەی ئەوە دەکەن کە مەسیحن یان پێغەمبەرن.‏\f* دەردەکەون، نیشانە و پەرجوو دەکەن، تاکو ئەگەر بکرێ تەنانەت ئەوانەی هەڵبژێردراون هەڵبخەڵەتێنن.
\v 23 بەڵام ئاگاداربن، ئەوا پێشوەخت هەموو شتێکم پێ گوتن.
\s1 هاتنەوەی عیسا
\p 
\v 24 «بەڵام لەو ڕۆژانەدا، دوای ئەو تەنگانەیە،
\q1 «﴿خۆر تاریک دەبێت و
\q2 مانگ ڕووناکییەکەی نادات،
\q1 
\v 25 ئەستێرەکان لە ئاسمان دەکەون،
\q2 تەنی ئاسمانی دەهەژێن.﴾\f + \fr 13:25 \ft \xt ئیشایا 13‏:10؛ 34‏:4‏\xt*\ft ‏\f*
\p 
\v 26 «ئەوسا کوڕی مرۆڤ دەبینن بە هێزێکی گەورە و شکۆوە لەناو هەورەوە دێت.\f + \fr 13:26 \ft بڕوانە \xt دانیال 7‏:13‏\xt*\ft ‏\f*
\v 27 ئینجا فریشتەکان دەنێرێت و ئەوانەی هەڵبژێردراون لە چوار بایەکە\f + \fr 13:27 \ft بڕوانە \xt مەتا 24‏:31‏\xt*\ft ‏\f* کۆدەکاتەوە، لەم سەری زەوییەوە هەتا ئەو سەری ئاسمان.
\p 
\v 28 «پەند لە دار هەنجیر وەربگرن، کاتێک لقەکانی نەرم بوون و گەڵایان کرد، دەزانن هاوین نزیکە.
\v 29 بە هەمان شێوە، کاتێک ئێوەش دەبینن ئەم شتانە ڕوودەدات، بزانن کە نزیکە و لە بەردەرگایە.
\v 30 ڕاستیتان پێ دەڵێم: ئەم نەوەیە بەسەرناچێت هەتا هەموو ئەمانە نەیەنە دی.
\v 31 ئاسمان و زەوی بەسەردەچن، بەڵام وشەکانم هەرگیز بەسەرناچن.
\s1 کەس ئەو کاتە نازانێت
\p 
\v 32 «سەبارەت بەو ڕۆژ و کاتە کەس نایزانێت، نە فریشتەکان کە لە ئاسمانن و نە کوڕەکە، باوک نەبێت.
\v 33 کەواتە ئاگاداربن و ئێشک بگرن، چونکە نازانن کەی ئەو کاتە دێت.
\v 34 وەک پیاوێکە گەشتی کردبێت، ماڵەکەی بەجێهێشتبێت و دەسەڵاتی دابێتە کۆیلەکانی، هەریەکە و بە ئیشی خۆی، دەرگاوانیشی ڕاسپاردبێت ئێشک بگرێت.
\p 
\v 35 «لەبەر ئەوە ئێشک بگرن، چونکە نازانن کەی گەورەی ماڵ دەگەڕێتەوە، ئێوارە یان نیوەی شەو، یان لەگەڵ خوێندنی کەڵەشێر، یان بەیانی.
\v 36 نەوەک لەناکاو بگەڕێتەوە و بتانبینێت خەوتوون.
\v 37 جا ئەوەی بە ئێوەی دەڵێم، بە هەمووانی دەڵێم: ئێشک بگرن!»
\c 14
\s1 پیلانگێڕی بۆ کوشتنی عیسا
\p 
\v 1 جەژنی پەسخە و فەتیرە دوو ڕۆژی مابوو، کاهینانی باڵا و مامۆستایانی تەورات دەگەڕان بە فێڵێک عیسا بگرن و بیکوژن،
\v 2 گوتیان: «با لە جەژندا نەبێت، نەوەک ئاژاوە بکەوێتە ناو خەڵک.»
\s1 ئامادەکردنی عیسا بۆ ناشتنی
\p 
\v 3 کاتێک عیسا لە گوندی بێت‌عەنیا بوو، لە ماڵی شیمۆنە گول لەسەر خوان بوو، ژنێک هات بوتڵێکی ئەلەباستەریی\f + \fr 14:3 \ft لە بەردی ئەلەباستەر دروستکرابوو، ئەم جۆرە بەردە لە میسر هەیە بۆ تاشین ئاسانە و ڕەنگەکەی قاوەییە.‏\f* بۆنی ناردینی بێگەردی گرانبەهای پێبوو، بوتڵەکەی شکاند و بەسەریدا ڕژاند.
\p 
\v 4 بەڵام هەندێک تووڕە بوون و بە یەکتریان گوت: «بۆچی بۆنەکە ئاوا بەفیڕۆ درا؟
\v 5 دەکرا ئەم بۆنە بە زیاتر لە سێ سەد دینار بفرۆشرایە و بدرایە بە هەژاران.» جا سەرزەنشتی ژنەکەیان کرد.
\p 
\v 6 بەڵام عیسا فەرمووی: «وازی لێ بهێنن. بۆچی بێزاری دەکەن؟ شتێکی چاکی بۆ من کرد.
\v 7 هەژاران هەمیشە لەگەڵتانن، کەی ویستتان دەتوانن چاکەیان لەگەڵ بکەن، بەڵام من هەمیشە لەلاتان نیم.
\v 8 ئەوەی لە دەستی هات کردی، زوو جەستەی منی بۆ ناشتن چەورکرد.
\v 9 ڕاستیتان پێ دەڵێم: لە هەر شوێنێکی جیهاندا ئەم مزگێنییە ڕابگەیەنرێت، وەک یادکردنەوەیەک باسی ئەوەش دەکرێت کە ئەم ژنە کردوویەتی.»
\s1 ناپاکی یەهوزا
\p 
\v 10 یەهوزای ئەسخەریوتی کە یەکێک بوو لە دوازدە قوتابییەکە، چوو بۆ لای کاهینانی باڵا تاکو عیسا بە گرتن بدات.
\v 11 کاتێک گوێیان لێبوو، دڵخۆش بوون و بەڵێنیان پێیدا زیوی بدەنێ. جا لە هەلێک دەگەڕا تاکو عیسا بە گرتن بدات.
\s1 جەژنی پەسخە
\p 
\v 12 لە یەکەم ڕۆژی جەژنی فەتیرەدا، کە بەرخی پەسخەیان\f + \fr 14:12 \ft سەربڕینی بەرخ لە یادی ئەو قوربانییەی لە سەردەمی موسا لە میسردا سەربڕدراوە، بڕوانە \xt دەرچوون 12‏:1‏-28.‏\xt*\ft ‏\f* سەردەبڕی، قوتابییەکانی لە عیسایان پرسی: «دەتەوێ بچینە کوێ ئامادەکاری بکەین، تاکو نانی پەسخە بخۆیت؟»
\p 
\v 13 ئەویش دووان لە قوتابییەکانی نارد و پێی فەرموون: «بڕۆنە ناو شار، پیاوێک تووشتان دەبێت گۆزەیەک ئاوی هەڵگرتووە، دوای بکەون.
\v 14 لەکوێ چووە ژوورەوە، بە خاوەن ماڵەکە بڵێن: ”مامۆستا دەفەرموێ: کوا دیوەخانەکەم تاکو لەگەڵ قوتابییەکانم نانی پەسخەی تێدا بخۆم؟“
\v 15 ئەویش لە نهۆمی سەرەوە ژوورێکی گەورەتان پیشان دەدات، ڕاخراوە و ئامادە کراوە، لەوێ بۆمانی ئامادە بکەن.»
\p 
\v 16 قوتابییەکان ڕۆیشتن و هاتنە شار، هەموو شتێکیان دۆزییەوە، هەروەک عیسا پێی فەرمووبوون. ئینجا نانی پەسخەیان ئامادە کرد.
\p 
\v 17 کە ئێوارە داهات، عیسا لەگەڵ دوازدە قوتابییەکە هات.
\v 18 پاڵیاندابووەوە نانیان دەخوارد، عیسا فەرمووی: «ڕاستیتان پێ دەڵێم، یەکێکتان وا لەگەڵم دەخوات، بە گرتنم دەدات.»
\p 
\v 19 خەم دایگرتن و یەک لەدوای یەک گوتیان: «خۆ ئەو کەسە من نیم؟»
\p 
\v 20 پێی فەرموون: «یەکێکە لەم دوازدەیە، ئەوەی لەگەڵم دەستی لەناو قاپەکەیە.
\v 21 کوڕی مرۆڤ دەبێت وەک ئەوەی لەبارەیەوە نووسراوە بڕوات، بەڵام قوڕبەسەر ئەوەی کوڕی مرۆڤ بە گرتن دەدات! باشتر بوو بۆ ئەو کەسە هەر لەدایک نەبووایە.»
\s1 دوایین شێوی مەسیح
\p 
\v 22 کاتێک نانیان دەخوارد، عیسا نانێکی هەڵگرت، سوپاسی خودای کرد و لەتی کرد، پێیدان و فەرمووی: «وەریبگرن، ئەمە جەستەی منە.»
\p 
\v 23 ئینجا جامێکی هەڵگرت و سوپاسی خودای کرد، پێیدان و هەموو لێیان خواردەوە.
\p 
\v 24 پێی فەرموون: «ئەمە خوێنی منە، خوێنی پەیمانەکەیە کە لە پێناوی خەڵکێکی زۆر دەڕژێت.
\v 25 ڕاستیتان پێ دەڵێم: ئیتر لە بەرهەمی مێو ناخۆمەوە، هەتا ئەو ڕۆژە دێت کە سەر لە نوێ لە شانشینی خودا دەیخۆمەوە.»
\p 
\v 26 ئینجا گۆرانیی ڕۆحییان\f + \fr 14:26 \ft خوێندنەوەی زەبوور لە شێوەی گۆرانی.‏\f* گوت و چوون بۆ دەرەوەی شار بۆ کێوی زەیتوون.
\s1 پێشبینی نکۆڵیکردنی پەترۆس
\p 
\v 27 عیسا پێی فەرموون: «هەمووتان پشتم تێ دەکەن، چونکە نووسراوە:
\q1 «﴿لە شوانەکە دەدەم،
\q2 مەڕەکان پەرت دەبن.﴾\f + \fr 14:27 \ft \xt زەکەریا 13‏:7‏\xt*\ft ‏\f*
\m 
\v 28 بەڵام دوای هەستانەوەم، پێشتان دەکەوم بۆ جەلیل.»
\p 
\v 29 پەترۆس پێی گوت: «ئەگەر هەموو پشتت لێ بکەن، من پشتت لێ ناکەم.»
\p 
\v 30 عیسا پێی فەرموو: «ڕاستیت پێ دەڵێم: تۆ ئەمڕۆ، هەر ئەمشەو، پێش ئەوەی دوو جار کەڵەشێر بخوێنێت، سێ جار نکۆڵی لە ناسینی من دەکەیت.»
\p 
\v 31 بەڵام پەترۆس زیاتر پێداگری کرد و گوتی: «ئەگەر لەگەڵیشت بمرم، نکۆڵیت لێ ناکەم.» هەموو وایان گوت.
\s1 نوێژی عیسا لە باخی گەتسیمانی
\p 
\v 32 پاشان چوونە شوێنێک پێی دەگوترا گەتسیمانی، بە قوتابییەکانی فەرموو: «لێرە دانیشن تاکو نوێژ دەکەم.»
\v 33 ئەوسا پەترۆس و یاقوب و یۆحەنای لەگەڵ خۆی برد، هەستی بە دڵگرانی و دڵتەنگی دەکرد.
\v 34 پێی فەرموون: «زۆر دڵتەنگم، خەریکە بمرم، لێرە بمێننەوە و ئێشک بگرن.»
\p 
\v 35 کەمێک دوور کەوتەوە و خۆی خستە سەر زەوی، نوێژی کرد تاکو ئەگەر بکرێت کاتەکەی بەسەردا تێبپەڕێت.
\v 36 فەرمووی: «بابە!\f + \fr 14:36 \ft یۆنانی: ئابە.‏\f* باوکە، هەموو شتێک بۆ تۆ دەبێت، ئەم جامەم لەسەر لاببە، بەڵام نەک بە خواستی من، بەڵکو بە خواستی تۆ.»
\p 
\v 37 گەڕایەوە بینی نوستوون، بە پەترۆسی فەرموو: «شیمۆن نوستوویت؟ نەتتوانی کاتژمێرێک ئێشک بگریت؟
\v 38 ئێشک بگرن و نوێژ بکەن، تاکو نەکەونە ناو تاقیکردنەوەوە. ڕۆح چالاکە بەڵام جەستە لاوازە.»
\p 
\v 39 دیسان ڕۆیشتەوە و نوێژی کرد، هەمان وتەی دووبارە کردەوە.
\v 40 کاتێک کە دووبارە گەڕایەوە، بینی نوستوون، چونکە چاویان قورس ببوو، نەیانزانی چۆن وەڵامی بدەنەوە.
\p 
\v 41 سێیەم جار گەڕایەوە، پێی فەرموون: «هێشتا نوستوون و پشوو دەدەن؟ بەسە! کاتەکە هاتووە. ئەوەتا کوڕی مرۆڤ دەدرێتە دەست گوناهباران.
\v 42 هەستن با بڕۆین، ئەوەتا ئەوەی بە گرتنم دەدات نزیک بووەوە.»
\s1 گرتنی عیسا
\p 
\v 43 کاتێک هێشتا عیسا قسەی دەکرد، لەناکاو یەهوزا گەیشت کە یەکێک بوو لە دوازدە قوتابییەکە. کۆمەڵە خەڵکێکی لەگەڵ بوو لەلایەن کاهینانی باڵا و مامۆستایانی تەورات و پیرانەوە نێردرابوون، شمشێر و داریان پێبوو.
\p 
\v 44 ئەوەی بە گرتنی دەدا نیشانەیەکی پێدابوون، گوتبووی: «ئەوەی ماچی دەکەم، ئەوە خۆیەتی، بیگرن و بە پاسەوانییەوە بیبەن.»
\v 45 هەرکە یەهوزا گەیشت، چوو بۆ لای عیسا و گوتی: «ڕابی!»\f + \fr 14:45 \ft ڕابی: وشەیەکی عیبرییە بە واتای مامۆستا دێت.‏\f* و ماچی کرد.
\v 46 ئیتر دەستبەسەریان کرد و گرتییان.
\v 47 بەڵام یەکێک لە ئامادەبووان، شمشێرەکەی هەڵکێشا، لە خزمەتکاری سەرۆکی کاهینانی دا و گوێی بڕی.
\p 
\v 48 عیساش پێی فەرموون: «ئایا من کەسێکی یاخیبووم کە بە کوتەک و شمشێرەوە هاتوون بمگرن؟
\v 49 ڕۆژانە لە حەوشەکانی پەرستگا لەگەڵتان بووم خەریکی فێرکردن بووم، نەتانگرتم، بەڵام دەبێت نووسراوە پیرۆزەکان بێنە دی.»
\v 50 ئینجا هەموو بەجێیان هێشت و ڕایانکرد.
\p 
\v 51 گەنجێک دوای عیسا کەوت کە تەنها بە پارچە کەتانێک ڕووتییەکەی داپۆشیبوو. کاتێک گرتیان،
\v 52 کەتانەکەی بەجێهێشت و بە ڕووتی ڕایکرد.
\s1 دادگاییکردنی عیسا
\p 
\v 53 عیسایان بردە لای سەرۆکی کاهینان، هەموو کاهینانی باڵا و پیران و مامۆستایانی تەورات کۆبوونەوە.
\v 54 پەترۆسیش دووربەدوور تاکو ناو حەوشەی ماڵی سەرۆکی کاهینان دوای کەوت، لەگەڵ خزمەتکاران لەبەردەم ئاگر دانیشتبوو خۆی گەرم دەکردەوە.
\p 
\v 55 کاهینانی باڵا و هەموو ئەندامانی ئەنجومەنی باڵای جولەکە\f + \fr 14:55 \ft ئەنجومەنی باڵای جولەکە کە لە یۆنانی پێی گوتراوە \tl سەنهەدرین‏\tl*، باڵاترین دەسەڵاتی جولەکە بووە کە دەسەڵاتی دەرکردنی بڕیاری ئایینی و شارستانی و تاوانبارکردنی هەبووە.‏\f* بەدوای شایەتییەک دەگەڕان لەسەر عیسا تاکو سزای کوشتنی بەسەردا بدەن، بەڵام دەستیان نەکەوت.
\v 56 کەسانێکی زۆر بە درۆ شایەتییان لەسەری دا، بەڵام شایەتییەکانیان یەکیان نەدەگرتەوە.
\p 
\v 57 هەندێک هەستان و بە درۆ شایەتییان لەسەری دا و گوتیان:
\v 58 «گوێمان لێی بوو دەیگوت: ”ئەم پەرستگایەی دەستکردی مرۆڤە دەیڕووخێنم، بە سێ ڕۆژ یەکێکی دیکە بنیاد دەنێم کە دەستکردی مرۆڤ نەبێت.“»
\v 59 لەمەشدا شایەتییەکەیان کۆک نەبوو.
\p 
\v 60 سەرۆکی کاهینانیش لە ناوەڕاست ڕاوەستا و لە عیسای پرسی: «هیچ وەڵام نادەیتەوە؟ ئەم پیاوانە چ شایەتییەکت لەسەر دەدەن؟»
\p 
\v 61 بەڵام عیسا بێدەنگ مایەوە و هیچ وەڵامی نەدایەوە. دیسان سەرۆکی کاهینان لێی پرسی و پێی گوت: «ئایا تۆ مەسیحەکەی، کوڕی خودای پیرۆز؟»
\p 
\v 62 عیسا فەرمووی: «من ئەوم. لە داهاتووش دەبینن کوڕی مرۆڤ لە دەستەڕاستی خودای توانادار دادەنیشێت و بەسەر هەوری ئاسمانەوە دێتەوە.\f + \fr 14:62 \ft \xt دانیال 7‏:13‏\xt*\ft ‏.‏\f*»
\p 
\v 63 سەرۆکی کاهینان جلەکانی خۆی دادڕی و گوتی: «ئیتر چ پێویستیمان بە شایەت هەیە؟
\v 64 خۆ گوێتان لە کفرەکە بوو، ڕاتان چییە؟»
\p هەموو بڕیاریان دا کە شایانی مردنە.
\v 65 هەندێک کەوتنە تف لێکردنی، دەم و چاویان داپۆشی و لێیان دەدا، پێیان دەگوت: «ئەگەر پێغەمبەریت، بزانە کێ بوو لێیدایت؟» پاسەوانەکانیش گرتییان و دایانە بەر زللە.
\s1 پەترۆس نکۆڵی لە عیسا دەکات
\p 
\v 66 پەترۆس لە خوارەوە لە حەوشەکە بوو، یەکێک لە کارەکەرانی سەرۆکی کاهینان هات.
\v 67 پەترۆسی بینی خۆی گەرم دەکاتەوە، تێیڕوانی و گوتی: «تۆش لەگەڵ عیسای ناسیرەیی بوویت.»
\p 
\v 68 بەڵام پەترۆس نکۆڵیی کرد و گوتی: «نازانم، تێناگەم چی دەڵێی.» چووە داڵانەکە. [ئینجا کەڵەشێر خوێندی.]
\p 
\v 69 کارەکەرەکە بینییەوە، بەوانەی گوتەوە کە لەوێدا ڕاوەستابوون: «ئەمەش لەوانە.»
\v 70 دیسان نکۆڵیی کرد.
\p پاش کەمێک ئەوانەی لەوێدا ڕاوەستابوون، بە پەترۆسیان گوت: «بە ڕاستی تۆ لەوانیت، چونکە تۆش جەلیلیت.»
\p 
\v 71 دەستی کرد بە نەفرەتکردن و سوێندخواردن و گوتی: «ئەم کابرایەی باسی دەکەن نایناسم.»
\p 
\v 72 دەستبەجێ کەڵەشێر بۆ دووەم جار خوێندی، پەترۆسیش قسەکەی عیسای بیرکەوتەوە کە پێی فەرمووبوو: «پێش ئەوەی دوو جار کەڵەشێر بخوێنێت، سێ جار نکۆڵیم لێ دەکەیت.» خۆی پێ نەگیرا و گریا.
\c 15
\s1 عیسا دەدرێتە دەست پیلاتۆس
\p 
\v 1 هەر بەیانی زوو، کاهینانی باڵا و پیران و مامۆستایانی تەورات و هەموو ئەندامانی ئەنجومەنی باڵای جولەکە ڕاوێژیان کرد. عیسایان قۆڵبەست کرد و بردیان و دایانە دەست پیلاتۆس.
\p 
\v 2 پیلاتۆس لێی پرسی: «تۆ پاشای جولەکەی؟»
\p عیسا وەڵامی دایەوە: «خۆت گوتت.»
\p 
\v 3 کاهینانی باڵا سکاڵای زۆریان لێ دەکرد.
\v 4 پیلاتۆس لێی پرسییەوە: «ئایا هیچ وەڵام نادەیتەوە؟ بزانە چەند سکاڵات لێدەکەن.»
\p 
\v 5 بەڵام عیسا هیچ وەڵامێکی نەدایەوە و پیلاتۆسیش بەمە سەرسام بوو.
\s1 بڕیاری لەخاچدانی عیسا
\p 
\v 6 لە هەر جەژنێکدا فەرمانڕەوا بەگوێرەی داواکاری خەڵکەکە بەندکراوێکی ئازاد دەکرد.
\v 7 پیاوێک بە ناوی باراباس لەگەڵ یاخیبووان گیرابوو کە لە ڕاپەڕینەکەدا کوشتاریان کردبوو\f + \fr 15:7 \ft لەو سەردەمە یاخیبووان لە دژی ئیمپراتۆریەتی ڕۆمانی ڕاپەڕینێکیان ئەنجام دابوو.‏\f*.
\v 8 ئینجا خەڵکەکە هاتن و داوایان کرد ئەوەیان بۆ بکات کە هەمیشە دەیکرد بۆیان.
\p 
\v 9 پیلاتۆسیش لێی پرسین: «دەتانەوێ پاشای جولەکەتان بۆ ئازاد بکەم؟»
\v 10 چونکە دەیزانی کاهینانی باڵا لە ئیرەییدا عیسایان بە گرتن دابوو.
\v 11 بەڵام کاهینانی باڵا خەڵکەکەیان جۆشدا کە باراباسیان بۆ ئازاد بکات.
\p 
\v 12 پیلاتۆس دیسان لێی پرسین: «ئەی باشە چی لەوە بکەم کە پێی دەڵێن، ”پاشای جولەکە“؟»
\p 
\v 13 هاواریان کرد: «لە خاچی بدە!»
\p 
\v 14 پیلاتۆس لێی پرسین: «بۆ؟ چ خراپەیەکی کردووە؟»
\p بەڵام ئەوان زیاتر هاواریان دەکرد: «لە خاچی بدە!»
\p 
\v 15 پیلاتۆسیش دەیویست خەڵکەکە ڕازی بکات، لەبەر ئەوە باراباسی بۆ ئازاد کردن، بەڵام فەرمانی دا کە عیسا بدرێتە بەر قامچی و پاشان لە خاچ بدرێت.
\s1 سەربازەکان گاڵتە بە عیسا دەکەن
\p 
\v 16 سەربازەکان عیسایان بردە کۆشکی فەرمانڕەوا و تەواوی سەربازەکانیان کۆکردەوە.
\v 17 کەوایەکی ئەرخەوانییان لەبەرکرد، تاجێکیان لە دڕک هۆنییەوە و لەسەریان نا.
\v 18 دەستیان کرد بە سڵاو لێکردنی و دەیانگوت: «سڵاو، ئەی پاشای جولەکە!»
\v 19 بە قامیش لەسەریان دەدا و تفیان لێی دەکرد، چۆکیان دادەدا و لەبەردەمی کڕنۆشیان دەبرد.
\v 20 کاتێک گاڵتەیان پێ کرد، کراسە ئەرخەوانییەکەیان لەبەر داکەند و جلەکەی خۆیان لەبەرکردەوە و بۆ لەخاچدان بردیانە دەرەوە.
\s1 لەخاچدانی عیسا
\p 
\v 21 ڕێبوارێک لە کێڵگە دەهاتەوە، ناوی شیمۆنی کورێنی\f + \fr 15:21 \ft گەورەترین شار لە وڵاتی لیبیا لەم سەردەمەدا.‏\f* بوو، باوکی ئەسکەندەر و ڕوفوس، ناچاریان کرد خاچەکەی ئەو هەڵبگرێت.
\v 22 ئینجا عیسایان بردە شوێنێک کە پێی دەگوترا گولگۆسا، واتا «شوێنی کاسەسەر».
\v 23 شەرابی تێکەڵ بە موڕیان\f + \fr 15:23 \ft موڕ: بۆنێک بووە بۆ کەمکردنەوەی ئازار تێکەڵ بە شەراب کراوە.‏\f* پێدا، بەڵام نەیخواردەوە.
\v 24 لە خاچیان دا و جلەکانیان دابەش کرد، تیروپشکیان لەسەر کرد، بۆ ئەوەی بزانن هەریەکەیان چی بەردەکەوێت.
\p 
\v 25 کاتێک لە خاچیان دا کاتژمێر نۆی\f + \fr 15:25 \ft یۆنانی: کاتژمێری سێیەم.‏\f* بەیانی بوو،
\v 26 ناونیشانی تاوانەکەشی نووسرابوو:
\pc پاشای جولەکە.
\p 
\v 27 دوو دزیشیان لەگەڵی لە خاچ دا، یەکێک لەلای ڕاستی و ئەوەی دیکەش لەلای چەپی. [
\v 28 نووسراوە پیرۆزەکە هاتە دی کە دەڵێت: ﴿لەگەڵ یاخیبووان ژمێردرا.﴾\f + \fr 15:28 \ft \xt ئیشایا 53‏:12‏\xt*\ft ‏.‏\f*]
\v 29 ئەوانەی بەوێدا تێدەپەڕین، جنێویان پێی دەدا و سەریان بادەدا و دەیانگوت: «ها! ئەی ڕووخێنەری پەرستگا و بنیادنەرەوەی لە سێ ڕۆژدا،
\v 30 خۆت ڕزگار بکە و لە خاچەکە دابەزە.»
\v 31 بە هەمان شێوە کاهینانی باڵا و مامۆستایانی تەورات گاڵتەیان دەکرد و بە یەکتریان دەگوت: «خەڵکی دیکەی ڕزگار کرد، بەڵام ناتوانێ خۆی ڕزگار بکات!
\v 32 با ئێستا مەسیحی پاشای ئیسرائیل لە خاچەکە دابەزێت، تاکو ببینین و باوەڕ بهێنین.» ئەوانەش کە لەگەڵی لە خاچ دەدران قسەیان پێ دەگوت.
\s1 مردنی عیسا
\p 
\v 33 کە بووە کاتژمێر دوازدە\f + \fr 15:33 \ft یۆنانی: کاتژمێری شەشەم.‏\f* تاریکی باڵی بەسەر هەموو زەویدا کێشا هەتا کاتژمێر سێ\f + \fr 15:33 \ft یۆنانی: کاتژمێری نۆیەم.‏\f*.
\v 34 لە کاتژمێر سێ، عیسا بە دەنگێکی بەرز هاواری کرد: «﴿ئێلی، ئێلی، لەما شەبەقتانی؟﴾» کە بە واتای ﴿خودای من، خودای من، بۆ وازت لێ هێنام؟﴾\f + \fr 15:34 \ft \xt زەبوورەکان 22‏:1‏\xt*\ft ‏\f* دێت.
\p 
\v 35 کاتێک هەندێک لەوانەی لەوێ ڕاوەستابوون گوێیان لێی بوو، گوتیان: «ئەوە بانگی ئەلیاس دەکات.»
\p 
\v 36 یەکێک ڕایکرد و ئیسفەنجێکی لە سرکە هەڵکێشا و بەسەر قامیشێکەوە پێیدا تاکو بیخواتەوە و گوتی: «لێگەڕێن، با بزانین ئەلیاس دێت دایبگرێت؟»
\p 
\v 37 عیساش بە دەنگێکی بەرز هاواری کرد و گیانی سپارد.
\p 
\v 38 پەردەی پەرستگاش لە سەرەوە هەتا خوارەوە شەق بوو و بوو بە دوو پارچەوە.
\v 39 ئەو سەرپەلەی\f + \fr 15:39 \ft وشە یۆنانییەکە مەبەست لە سەرکردەی سەد سەربازە لە سوپای ڕۆم.‏\f* بەرامبەر عیسا ڕاوەستابوو، گوێی لە هاواری بوو و بینی چۆن گیانی سپارد، گوتی: «بەڕاستی ئەم کەسە کوڕی خودا بوو!»
\p 
\v 40 چەند ژنێک لە دوورەوە تەماشایان دەکرد، لەنێوانیاندا مریەمی مەجدەلی و مریەمی دایکی یاقوبی بچووک و یوسی و سالومە دەبینران.
\v 41 ئەمانە لە جەلیلەوە دوای عیسا کەوتبوون و خزمەتیان دەکرد، زۆری دیکەش لەگەڵی هاتبوونە ئۆرشەلیم.
\s1 ناشتنی عیسا
\p 
\v 42 ئێوارە داهات، ڕۆژی خۆ ئامادەکردن بوو، واتا ڕۆژی پێش شەممە،
\v 43 یوسفی خەڵکی ڕامە ئەندامێکی بەرزی ئەنجومەن بوو، ئەویش چاوەڕێی شانشینی خودای دەکرد، وێرای و چوو بۆ لای پیلاتۆس و داوای تەرمەکەی عیسای کرد.
\v 44 پیلاتۆس سەرسام بوو ئاوا بە زوویی عیسا مردووە، سەرپەلەکەی بانگکرد و لێی پرسی ئاخۆ دەمێکە مردووە.
\v 45 کاتێک لە سەرپەلەکەوە زانی، تەرمەکەی دایە یوسف.
\v 46 ئەویش کەتانی کڕی، دایگرت و بە کەتان کفنی کرد، لە گۆڕێکدا ناشتی کە لە تاشەبەرد هەڵکەنرابوو. ئینجا بەردێکی گلۆر کردەوە سەر دەرگای گۆڕەکە.
\v 47 مریەمی مەجدەلی و مریەمی دایکی یاقوب، بینییان لەکوێ نێژرا.
\c 16
\s1 زیندووبوونەوەی عیسا
\p 
\v 1 کە ڕۆژی شەممە تەواو بوو، مریەمی مەجدەلی و سالومە و مریەمی دایکی یاقوب بۆنوبەرامیان کڕی، تاکو بچن و تەرمی عیسا چەور بکەن.
\v 2 لە یەکەم ڕۆژی هەفتەدا، بەیانی زوو لەگەڵ خۆر هەڵاتن، هاتنە سەر گۆڕەکە.
\v 3 بە یەکتریان دەگوت: «باشە کێ بەردی سەر دەرگای گۆڕەکەمان بۆ گلۆر دەکاتەوە؟»
\p 
\v 4 بەڵام کە سەیریان کرد، بینییان بەردەکە گلۆر کراوەتەوە، هەرچەندە زۆر گەورە بوو.
\v 5 جا چوونە ناو گۆڕەکە و لەلای ڕاستەوە گەنجێکیان بینی دانیشتبوو، کەوایەکی سپی لەبەر بوو، ئیتر تاسان.
\p 
\v 6 پێی گوتن: «مەتاسێن، بە شوێن عیسای ناسیرەیی لەخاچدراودا دەگەڕێن. ئەو هەستایەوە! لێرە نییە. ئەوەتا ئەو شوێنەی لێیان دانا.
\v 7 بەڵام بڕۆن و بە قوتابییەکانی و بە پەترۆس بڵێن، ”ئەو پێشتان دەکەوێت بۆ جەلیل، وەک چۆن پێی فەرموون لەوێ دەیبینن.“»
\p 
\v 8 ژنەکان لە گۆڕەکە هاتنە دەرەوە و هەڵاتن. لەرز و سەرسامی دایگرتبوون، هیچیان بە کەس نەگوت، چونکە دەترسان.
\p [
\v 9 دوای ئەوەی عیسا بەیانی زوو لە یەکەم ڕۆژی هەفتەدا هەستایەوە، یەکەم جار بۆ مریەمی مەجدەلی دەرکەوت، ئەوەی حەوت ڕۆحی پیسی لێی دەرکردبوو.
\v 10 ئەویش چوو و بەوانەی گوت کە لەگەڵ عیسادا بوون و شیوەنیان دەگێڕا و دەگریان.
\v 11 کاتێک بیستیان عیسا زیندوو بووەتەوە و ئەم بینیویەتی، باوەڕیان نەکرد.
\p 
\v 12 لە دوای ئەمانە عیسا بە شێوەیەکی دیکە بۆ دووان لە قوتابییەکان دەرکەوت، کاتێک بۆ گوندەکان بەڕێوە بوون.
\v 13 جا چوون و بەوانی دیکەیان ڕاگەیاند، بەڵام باوەڕیان پێ نەکردن.
\p 
\v 14 پاشان عیسا بۆ یازدە قوتابییەکە دەرکەوت، کاتێک لەسەر خوان بوون، لەبەر بێباوەڕی و کەللەڕەقییان سەرزەنشتی کردن، چونکە باوەڕیان بەوانە نەکرد کە دوای هەستانەوەکەی بینیبوویان.
\p 
\v 15 پێی فەرموون: «بڕۆن بۆ هەموو جیهان و ئەم مزگێنییە بە هەموو بەدیهێنراوان ڕابگەیەنن.
\v 16 ئەوەی باوەڕ دەهێنێت و لە ئاو هەڵدەکێشرێ ڕزگاری دەبێت، ئەوەش کە باوەڕ ناهێنێ، تاوانبار دەکرێت.
\v 17 ئەوانەی باوەڕ دەهێنن ئەم نیشانانەیان لەگەڵ دەبێت، بە ناوی من ڕۆحی پیس دەردەکەن و بە زمانی نوێ دەدوێن،
\v 18 بە دەستیان مار دەگرن، ئەگەر ژەهرێکی کوشندەش بخۆنەوە زیانیان پێ ناگات، دەست لەسەر نەخۆش دادەنێن و چاکدەبنەوە.»
\p 
\v 19 لەدوای ئەوەی عیسای خاوەن شکۆ ئەمانەی پێ فەرموون، بۆ ئاسمان بەرزکرایەوە و لە دەستەڕاستی خودا دانیشت.
\v 20 ئەوانیش چوون و لە هەموو لایەک جاڕیان دا، عیسای خاوەن شکۆش لەگەڵیان کاری دەکرد و بە پەرجووەکانی پشتگیری پەیامەکەی دەکرد.]
