\id JAS - Okphela 
\h iJemhisi 
\toc1 iJemhisi 
\toc2 iJemhisi 
\toc3 iJem 
\mt2 Ebe ni 
\mt1 IJemhisi 
\mt2 Ọ kẹkẹ 
\c 1  
\p  
\v 1 Mhẹmhẹ iJemhisi ni mhi khi ọni ọọ ga ọyi Ẹshinẹgba ali ọyi iJesu iKirisiti Ọnọmhuẹ mhia kẹkẹ ebe ona ghi ẹgbọ eni e miesuọ, ni ẹ la ẹdẹli igbẹva eyi ẹgbọ iZirẹni, ni e gbhiaku elemhi ekẹ agbọ nya.\f + \fr 1:1 \ft Li zẹ \fq iMat 13.55; iMak 6.3; Ika 15.13; iGal 1.19\f* 
\p Mhi tsẹ ẹ. 
\s1 Ke ghẹlẹ elemhi imufẹ 
\p  
\v 2 Inyọghuo-mhẹ, leli ọli shi emhi oghẹlẹ ini imufẹ ọdọda e bhale debẹ.  
\v 3 Irari khi u lẹsẹ khi ini a da mu irudunga oyẹ fẹ bino ne, iregbemie oyẹ o ya mẹ asha fu-a shi ọ.  
\v 4 Zobẹ ni iregbemie oyẹẹ o gbe akanya oyọli pfo, ni a mhọli iwomhẹloe, ni o gba pfo, ni a khi eni ingeli enete ẹa baku.  
\v 5 Ama ini ọngẹẹ ọọ nono ẹgbhali, ọ mhila Ẹshinẹgba ni ọ pfo elemhi rọ ọ na ọgbọkpa, ni ọa ya mẹ umha-guẹkia oyi ọgbọ. Ọ ya rọli na li.  
\v 6 Ama ini ọọ mhila, ọ mhọli irudunga ni ọa mhuẹ akhọkhọmhẹ, irari khi ọni mhọli akhọkhọmhẹ, eri ọ li abi izughuse oyi okẹ oniẹmhi ni akpekpeli o pfi ẹ kia.  
\v 7 Ọgbọ ọghọghọ ọ khi sa khi lọli mẹ emhikhọghuo ya mie obọ oyi Ọnọmhuẹ.  
\v 8 Ọgbọ ọzidu eva ọ khi, ọa ya riẹlẹ emini o mu amẹ. 
\s1 Ẹpfue ali umhamẹ 
\p  
\v 9 Eni e mie iJesu iKirisiti suọ ena umhamẹ e ke ghẹlẹ irari khi e ma ghalẹ ukpẹloe oyi Ẹshinẹgba.  
\v 10 Igbaa oyi eni e mie iJesu iKirisiti suọ ni e pfue, e ke ghẹlẹ ini agbọ o ke ti wẹ tiemhile. Irari khi eri ẹpfue e ta a kua abi udodo.  
\v 11 Irari khi ini ovọ o ngale khi ọọ to, eri ọọ tosẹ ebuli a, e khakha-a, idodo eyẹwẹ e de kua, isomhotse eyẹwẹ o yese a. Ighọ, ọni ọ pfue ọ li ya ta kua, abi ọ li na ya nga na ya tiemhi shi akanya oyọli.\f + \fr 1:11 \ft Li zẹ \fq Aza 40.6-7\f* 
\s1 Imhẹsẹ-bino ali imufẹ 
\p  
\v 12 Ikhivọsẹ o khi na ọgbọ ni ọ kie migha ini ọ mhọli imufẹ, irari khi ini ọ dobẹ ri egbe mie, ọ ya mie arula oghie oyi agbọ na agbọagbọ, ni Ẹshinẹgba ọ she shobọ khi lọli ya rọ na eni e nono ingme oyẹluẹ. 
\p  
\v 13 Ini a mu ọgbọ lighọ fẹ bino, ọ khi liẹ khi, “Ẹshinẹgba ọ mu mhẹ ẹ fẹ.” Irari khi ọgbọ ọa ri onobe ya dobẹ mu Ẹshinẹgba fẹ, wẹkhi eri lọli ọ mu ọgbọkhọghuo ẹ fẹ bino.  
\v 14 Ama ọghuẹmhẹ eyawa ni e di awa mu, e ri awa mhọli imufẹ.  
\v 15 Ẹghẹghẹ aghọ oni ọghuẹmhẹ o kha mẹ, o bia olamhẹ, ini olamhẹ o fu, khi o tẹ, o bia eghuli. 
\p  
\v 16 Inyọghuo-mhẹ a khi zẹ ni a di ẹ.  
\v 17 Isomhi-opfa onete kpa ni o gba pfo, idane o te bhale, obini oyi Ita ni ọ ma ikpa na idane, o rọte ẹ tiemhile. Ọni ọa ya mu pfi abi aroro ni ọọ je oola je oobọ.  
\v 18 Ọghuẹmhẹ oyọli ọ rọ ri ungmemhi igẹsikia oyọli ri awa bhale agbọ, ini ọ mẹ asha ri awa khi imọmhi eni ododẹ elemhi emini o ma nya. 
\s1 Isuọ-ungmemhi oyi Ẹshinẹgba ali irọli-gbe akanya 
\p  
\v 19 A sato ona inyọghuo-mhẹ, ọgbọkpa ọ kẹlẹ ke suọ ungmemhi, ama ọ khi kẹlẹ ke ngme unu, ọ khi gbo kẹlẹ ke mhuẹ elemhi ibibi.  
\v 20 Irari khi elemhi ibibi oyi ọgbọ ọa ri ọgbọ ọ mhọli iguẹ-ngeli oyi Ẹshinẹgba  
\v 21 Irarighọ, a ti egbe ingeli ichimhi-a ali ingeli ingmobe ni e sha ẹ ma-a. A ri egbe ẹ tiemhile na Ẹshinẹgba, a ri ẹloe shi ungmemhi oyọli, ikhi oni a rọ kọ ẹ udu, ni o dobẹ ya mie ẹ pfuese.  
\v 22 A khi khi eni e lẹsẹ ri esọ suọ tsẹ ni ẹẹ di egbe wẹ, a ri ochoghọ ke ri emini a suọ gbe akanya.  
\v 23 Ọni ọ ri esọ suọ oni ungmemhi ni ọa riẹlẹ emini o ngme, eri ọ li abi ọni ọ lẹ ya bino egbọli ughegbe abi lọli li.  
\v 24 Ọ kha bino egbọli se, ọ vu aghọ le, aghọaghọ ọ yele abi ọ li-a.  
\v 25 Ama ọgbọ ni ọ bino elemhi ushi ni o gba pfo ni ọọ rue ọgbọ ọ le, ni ọ kiele ẹ riẹlẹ emini o ngme, ni ọa yele-a abi oni ushi o ngme, a ya khivọsẹ na li emiemini ọọ riẹlẹ kpa. 
\p  
\v 26 Ini ọngẹ ẹ ọ rue egbọli khi ọna ugamhi lọli khi, ni ọa rọ lolo mu ẹlẹmhi oyọli mhuẹ kpẹ̀, egbọli ọọ di. Ugamhi afuẹ ọọ ga.  
\v 27 Ugamhi ni o pfuasẹ ni ọa mhọli ifue ni Ẹshinẹgba Ita awa ọọ mie lọli o khi, ni u rọ ri ukpẹloe khu imi-olimhi ali esamhi-olimhi ini ẹẹ mẹ osoli. Ali ni ọgbọ ọ mu egbọli ini agbọ o khi ri ichimhi mu ọli. 
\c 2  
\s1 A khi zọlọ egbe ẹ 
\p  
\v 1 Inyọghuo-mhẹ, ini u mie iJesu iKirisiti Ọnọmhuẹ ọyawa ni ọ mhọli ufumhi oniẹmhi suọ, a khi riẹlẹ khi ọnana ọ kpe mhẹ nẹ.  
\v 2 Ini a fẹ bhale ya ẹ khi ọgbọ ni ọ pfue ni ọ sọ ukpẹkhuli oyi igolu ali ide eni e somhotse, ọ lo ilegba oyẹẹ le, ali ni a rọ gbo mẹ khi ọna umhamẹ ọ sọ ijẹjẹ ide li lole.  
\v 3 Ini u ri ekpẹ na ọni ọ sọ itsua ni e somhotse nẹ, ni u rọ liẹ ọli, “Bhale ya shitọ ashini o ti nẹ,” ni u rọ liẹ ọna umhamẹ, “Migha oobọ,” okekhia khi eri u wẹ ọli, “Shitọ ekẹkhẹ epfẹ awẹ eyẹmhẹ.” O fẹ ti ghọ?  
\v 4 Aa she riẹlẹ azọlọmhẹ deba egbe ẹ eghọ? Aa gbolo ri isamhi ebe ẹ gue egbe ẹ ẹzọ eghọ? 
\p  
\v 5 A ri esọ shi mhẹ ekẹ inyọghuo-mhẹ, ọa khi eri Ẹshinẹgba ọ she zẹ ena umhamẹ ukpẹloe agbọ, ni e mhọli ẹpfue oyi irudunga, ali ni e mhọli okemhi shi ugu eghiele ni ọ rọ shobọ na eni e nono ingme oyọli?  
\v 6 Ama u she mẹ ena umhamẹ bie. Ọa khi eri eni ẹpfue e li ẹ le? Ọa khi wẹwẹ e rẹ ẹ ye ikọtu?  
\v 7 Ọa khi wẹwẹ ẹ ri unu ẹ yese eva onete oyi iJesu iKirisiti-a ọni a kugbe ọ? 
\p  
\v 8 Onete wa riẹlẹ ini u ri ushi ni o mu egbe nẹ nya, ni o la Ebe-no-pfuasẹ gbe akanya, ni ọọ, “Nono ingme oyi ọnuzava oyẹ abi u li nono ingme egbe ẹ.”\f + \fr 2:8 \ft Li zẹ \fq iLẹv 19.18\f* 
\v 9 Ama ini u riẹlẹ azọlọmhẹ, u she lamhẹ, ushi o gbo pfa ẹzọ mu ẹ khi ọni ọ gbe ushi-a u khi.  
\v 10 Irari khi ọnini ọ da ri ishi nya ghuẹ ni ọ pfi dọ elemhi ushi oghuo tsẹ, ishi enekpọle nya ọ gbe-a.  
\v 11 Irari khi ọni ọọ, “Khi kia okia.” Lọli ọ gbolo ẹ, “Khi gbe ugbeli.” Ini u wa ririẹ kia okia, ni u rọ da gbe ugbeli ne, ọgbushia u khi.\f + \fr 2:11 \ft Li zẹ \fq Okiali 20.13,14; iDẹut 5.17,18\f* 
\p  
\v 12 A ke ngme ungmemhi, àá ngeli abi ẹgbọ eni a ri ushi inono ya gue wẹ ẹzọ, ikhi ushi oni o ri ẹpfua a na ọgbọ.  
\v 13 Irari khi Ẹshinẹgba ọa ya mhọli ilẹlemhi na ọgbọ ni ọa ya mhọli ilẹlemhi, ẹlẹ ni Ẹshinẹgba ọ rọli ya gue ẹzọ. Irari khi ini u mhọli ilẹlemhi, eri u ya ke ghẹlẹ ini a rẹ ẹ gue ẹzọ. 
\s1 Irudunga ali irọ-gbe akanya 
\p  
\v 14 Inyọghuo-mhẹ ini ọgbọ guele khi lọli mhọli irudunga, ni ọa rọ mhọli irọ-gbe akanya, onete onoghuo o ya li nali? Imiesuọ oghọghọ ọa ya dobẹ tsumhi ọli?  
\v 15 Ini a fẹ bhale ya ẹ khi inyọghuo awa ọni ọmọse okekhi ọkpotso ọa mhọli itsua ni a sọ ali eminale ni ọ ya le ogbẹlẹ.  
\v 16 Ni ọngẹ ọ rọ gueyẹ ọli, “Ke vu, o ya ti nẹ, Ẹshinẹgba ọ khi zẹ ni ulili ali okiamhi o nẹ osoli”, ni ọa rọ mhọli emhi khọghuo ni ọ riẹlẹ na, ighe onete ni o riẹlẹ?  
\v 17 Eri o li abinẹ khi ọgbọ mhọli irudunga ni ọa rọli gbe akanya. Irudunga luẹghuo tsẹ ni a ri akanya ma, irudunga oni o ghu-a o khi. 
\p  
\v 18 Ama a dobẹ ya mẹ khi ọgbọ ọọ li, “U mhọli irudunga, mhẹmhẹ mhi gueyẹ ọli khi irọgbe-akanya mhi mhọli.” Ri irudunga oyẹ khasẹ mhẹ ni ọa mhọli akanya igbegbe, mhẹmhẹ mhi ya ri emini mhi riẹlẹ rọ ri irudunga oyẹmhẹ khasẹ ẹ.  
\v 19 U miesuọ khi Ẹshinẹgba ọghuo ọ khi, oo ti gba. Egbegbi ayẹmhẹ eyi ọkphaghiẹ e mie ona suọ, ẹẹ na ulishi, ẹẹ guọ.  
\v 20 Yẹyẹ ọmọse ọọyẹghẹ, eri u wa nono ni a gbo gue ọli ke yẹ, khi irudunga ni ọa mhọli akanya igbegbe, khi afuẹ o khi?  
\v 21 Ọa khi emini ititawa Aburaamu ọ riẹlẹ a rọ rọli liẹ khi ọni ọ pfuasẹ ọ khi, abi ọ rọ ri omi ọli Aziki luasẹ obo ukhomhi atẹtẹ?\f + \fr 2:21 \ft Li zẹ \fq Igbae 22.1-14\f* 
\v 22 U mẹ ọli khi irudunga ali irọgbe-akanya oyọli e ga gbe akanya kugbe, emini ọ riẹlẹ o ri irudunga oyọli gba pfo.  
\v 23 Lọli o zẹ khi emini Ebe-no-pfuasẹ o ngme o rọ bhale ya tse ni ọọ, “Aburaamu ọ mie Ẹshinẹgba suọ, a leli ọli nali shi ipfuasẹ”, A lu ọli ọmọle Ẹshinẹgba.\f + \fr 2:23 \ft Li zẹ \fq Igbae 15.6; 2 Okhẹ 20.7; Aza 41.8\f* 
\p  
\v 24 U mẹ ọli eghọ khi emhi ni ọgbọ ọ riẹlẹ a rọ liẹ khi ọgbọ ọna ipfuasẹ ọ khi, ọa khi irudunga tse ọgbọ ọ rọ khuẹ pfuasẹ.  
\v 25 Ighọ o gbo li egbe oyi iRé-àbu ni ọ khi adegbe. Emini ọ riẹlẹ o rọli khuẹ pfuasẹ odalo oyi Ẹshinẹgba. Abi ọ li mu ẹgbọ iZirẹni ni e bhale ya tọkpẹ ekẹ bino epfẹse. Ni ọ gbo kpaghiẹ wẹ obọ ni e rọ mẹ asha na rọte odẹ oboese vu.\f + \fr 2:25 \ft Li zẹ \fq iJosh 2.1-21\f* 
\p  
\v 26 Irarighọ, abi idiegbe ni ọa mhọli ayẹmhẹ o li khi oni ghua, ighọ irudunga ni ọa mhọli akanya o li khi oni ghua. 
\c 3  
\s1 Ekpabọ oyi ẹlẹmhi 
\p  
\v 1 Emọle mhẹ, ẹẹ nya a khi ya khi eni ẹẹ sẹsẹ, irari khi a lẹsẹ khi anye ni anye khi eni ẹẹ sẹsẹ ẹgbọ, a ri ẹzọ oni o ze nẹ nya na ya gue.  
\v 2 Awa nya awa mhọli ashini awa te pfi dọ. Ama ini ọgbọ ọa pfi dọ elemhi ungmemhi oyọli ghuẹ, ọgbọ ọni ọ gba pfo ọ khi, ni ọ dobẹ ẹ mhẹsẹ ni idiegbe oyọli nya. 
\p  
\v 3 Eri a sọ achi aghẹkpẹ unu ni ọ ke suọ esọ na awa, lọli o zẹ khi awa dobẹ nga li ẹ je obini o ghọle awa.  
\v 4 Gbo li sa ingme ọkọ okẹ oniẹmhi bino, ashini o gbẹdi ramhi eghọ, ni o khia khi akpekpeli oniẹmhi o kha riẹ ẹ li, ukuku akhuli, ọni ọọ gua li ọ rọ mu ọli ukhomhi ẹ pfi je obiobini o ghọle ọli.  
\v 5 Ighọ ẹlẹmhi o li li. Ashini o shẹ ramhi elemhi idiegbe oyi ọgbọ, o ma pfi okhorobo. 
\p Sa ọ ghue, abi ukuku akhuerẹ o liẹ ma erẹ osha.  
\v 6 Eri ẹlẹmhi o li abi erali. Emhi obe o khi ni o la elemhi idiegbe ọgbọ. Eri ọọ yese ọgbọ-a nya odẹ khi odẹ. Ilimhi iriẹriẹ oni erali oghọ o te bhale ẹlẹmhi. 
\p  
\v 7 Elamhakọ nya e zẹ ẹ mu abọ, ghe ipfeli o, ghe eni ẹ tialọ akpidi ekẹ o, ghe elamhakọ ena okẹ o, ọgbọ ọ dobẹ ẹ mu wẹ abọ.  
\v 8 Ama ọgbọ khọghuo ọa dobẹ ya mu ẹlẹmhi abọ. Eri o li abi osuẹ ẹnyẹ ọbe ni ọọ gbe. 
\p  
\v 9 Oni ẹlẹmhi awa rọ ọ kuẹghiẹ Ita awa Ọnọmhuẹ. Lọli awa gbo rọ ọ ku itsẹ na ẹgbọ ni a rọ khọkhọ Ẹshinẹgba ma.\f + \fr 3:9 \ft Li zẹ \fq Igbae 1.26\f* 
\v 10 Ikuẹghiẹ ali itsẹ ikuku e rọte unu oghuo ẹ lasele. Ọa kha khi ighọ inyọghuo-mhẹ.  
\v 11 Amẹ eni e ti unu ali amẹ ni ẹa ti unu ẹa dobẹ ya rọte unupfie oyi okẹ oghuo ke chọchọ lasele.  
\v 12 Inyọghuo-mhẹ, ọkhua-eni o fẹ dobẹ ya mọ udumhi olivu? Wẹkhi eri olomu iba o dobẹ ya mọ udumhi ọkhua-eni? Ighọ okẹ oni ọọ chọchọ amẹ ugbheli, ọa dobẹ ri amẹ eni e ti unu ya lasele. 
\s1 Iku ilẹsingme eva 
\p  
\v 13 Ọghuo ọ elemhi ẹ ọ khi ọtsẹgbhẹ ni ọ mhọli ilẹsẹ? Ọni ọgbọ ọ ri angeli onete oyọli rọli khasẹ, ikhi onete ni ọ ri iregbe-tiemhile ni o rọte ilẹsingme bhale riẹlẹ.  
\v 14 Ama ini u mhọli ayẹmhẹ ubọgbọ ali emhi-itoegbe shi udu oyẹ, khi vuse ipfua shi ọ, ni u rọli kie oni igẹsikia.  
\v 15 Ilẹsingme oghọghọ ọa khi iloghie o te bhale, ama onayi agbọ ona o khi, ni ọa rọte Ayẹmhẹ-nọ-pfuasẹ bhale, elemhi ayẹmhẹ oyi ọkphaghiẹ o te lasele.  
\v 16 Ashini ubọgbọ ali emhi ituegbe o da la ne, ozughu ali emhi ebe ọdọda, e ma la akaghọ.  
\v 17 Ama ẹgbhẹ ali ilẹsẹ ni o te idane bhale, eri o kpẹ te ekẹ pfuasẹ, o nono opfọmhẹ. Eri ọọ kuegbe-a, o ri egbe ọli ẹ tiemhile na ọgbọkpa pfo, o mhọli elemhi-iamhẹ, o ri umọmhi angeli onete ẹ khasẹ. Ọa ya gbe azẹba, o mhọli igẹsikia.  
\v 18 Eni ẹ nono opfọmhẹ ni e ri ayẹmhẹ opfọmhẹ ri onete kọ, ikhiẹsẹ oyi ipfuasẹ ẹẹ mẹ. 
\c 4  
\s1 A ri egbe ẹ na Ẹshinẹgba pfo 
\p  
\v 1 Elọ ọọ pfi okhọli ali uwola a na ẹ? Ọa khi itobọ ọghuẹmhẹ, ni e la ẹ udu nu ẹ a khọli o zẹ ni a rọ nu egbe ẹ khọli?  
\v 2 Emhi ọọ ghọle ẹ, ama aa mhọli ọli. A gbe ugbeli, a mhọli ẹloe-iamhẹ ama a dobẹ mhọli emini ẹẹ ghọle ẹ. A kha wola, a khọli. Aa ya mhọli emini a nono, irari khi aa mhila Ẹshinẹgba.  
\v 3 A kha mhila, aa ya mẹ mie, irari khi usamhi obe a rọ shi udu ke mhila, ini a ba mẹ asha ri emini a mhila rọ li agbọ shi egbe. 
\p  
\v 4 Ẹẹ ni a khi ẹgbọ ni e li abi ọkpotso ni ọọ kia okia, eri aa lẹsẹ khi ini emhi agbọ o ghọle ẹ dọsẹ, khi ọbe Ẹshinẹgba a khi? Ọnini ọ da zẹ agbọ ona ọmọle ne, ọbe Ẹshinẹgba ọ khi.  
\v 5 Eri u dabi khi afuẹ Ebe-no-pfuasẹ o ngme ọli khi, eri ayẹmhẹ ni Ẹshinẹgba ọ rọ shi awa egbe ọọ kpe ofuma egbegbọ, ni o khia khi eri ọọ nono ni awa khi ọyi Ẹshinẹgba pfo nya.  
\v 6 Ama eri Ẹshinẹgba ọ khi ma okhale na awa. Onana o zẹ ni Ebe-no-pfuasẹ o rọ liẹ, 
\q1 “Eri Ẹshinẹgba 
\q2 ọ mu okhọli ẹ vule shi 
\q2 ọni ọ ti egbe ọli ẹ nga ọ. 
\q1 Ọọ somhi elemhi 
\q2 ọni ọ ti egbọli ẹ tiemhile.”\f + \fr 4:6 \ft Li zẹ \fq Ekpi 3.34\f* 
\p  
\v 7 Ri egbe ẹ tiemhile na Ẹshinẹgba pfo nya. Tsẹsẹ ku ọkphaghiẹ ọ ti kia nẹ, khi ọ ya na nẹ.  
\v 8 Ti bhale deba Ẹshinẹgba, khi ọ ya ti bhale debẹ. A kpe abọ eyẹ ẹ-a, ẹẹ ena olamhẹ, a ri udu oyẹ ẹ shi eni e pfuasẹ, ẹẹ ezidu-eva.  
\v 9 Viẹ osoli, viẹ oya, mu egia oyẹ mele eviẹ-a, u gbo mu oghẹlẹ oyẹ pfi bhale iyese udu-a.  
\v 10 Ti egbe ẹ tiemhile odalo oyi Ọnọmhuẹ, khi ọ ya ti ẹ nga. 
\p  
\v 11 A khi ke yese egbe eva inyọghuo-mhẹ. Ini u da yese ọnuzava oyẹ ni a ga mie iKirisiti suọ eva-a ne, ni u rọ da gue ọli ẹzọ, ushi wa zẹ ifue, ni u wa gue ẹzọ. Ini u gue ushi ẹzọ, wa ke khi ọni ọ ri ushi ẹ gbe akanya! Ama ọni ọ gue ọli ẹzọ u ke khi.  
\v 12 Ẹshinẹgba lọlighuo tsẹ ọ khi ọni ọ rue ushi na agbọ ni ọọ gue ọgbọ ẹzọ egbe-a. Lọlighuo tsẹ ọ dobẹ a tsumhi, ni ọ dobẹ a gbe-a. Ọghuo u sa khi u khi ni u wa gue ọgbọẹse ẹzọ? 
\s1 Awa khi ke tono obọ udu 
\p  
\v 13 A suọ mhẹ, yẹyẹ ni u wẹ, “Amo okekhi akọ awa ya ye ẹoli ona okekhi oghọ, awa ya la oobọ elemhi ukpe oghuo, awa la oobọ gbe akanya ona ali oghọ, awa gbe ukpaghọ tima.”  
\v 14 Waa lẹsẹ emini ogbe na akọ o ngme ne, wẹkhi emini a ya mẹ akọ. Sẹ u lẹsẹ abi agbọ oyẹ o ya li? Eri u li abi otughunu ẹlẹ uzogbe ni ọọ lasele ukuku ẹghẹghẹ, o gbo kala-a.\f + \fr 4:14 \ft Li zẹ \fq Ekpi 27.1\f* 
\v 15 Eri u kha ri ochoghọ liẹ, “Ini o ghọle Ọnọmhuẹ, awa ya la agbọ, awa li ona ali oghọ.”  
\v 16 Mena eri u wa tono obọ udu, waa ti ipfuabọ nga. Itonobọ-udu eghọghọ nya ẹa gbe akanya. 
\p  
\v 17 Irarighọ, ọnini ọ da lẹsẹ onete ni ọ kha riẹlẹ ni ọa rọ da riẹlẹ ọli ne, olamhẹ o khi na li. 
\c 5  
\s1 A tsẹ agua yẹ eni e pfue, ni ẹẹ nasẹ eni ẹa pfue. 
\p  
\v 1 Ghe ii, ẹẹ eni a pfue, a viẹ, a viẹ oya irari osoli ni ọọ bhale na ẹ.  
\v 2 Ẹpfue eyẹ ẹ, e she kẹ a, ali khi esele e she rẹ ẹ ide le.  
\v 3 Igolu ali ẹlomho eyẹ ẹ, e she mu ọghuọghuọ-a. Ọghuọghuọ ni e mu, e ya pfi ọtsẹlẹ mu ẹ, a ya na ẹ osoli to ọ irari khi u ti ikpaghọ ma leghe na egbe ẹ ya ramhi memena.\f + \fr 5:3 \ft Li zẹ \fq iMat 6.19\f* 
\v 4 Waa fali ẹgbọ eni e gbe ikanya ishemhi oyẹ nẹ ifata ne. Ẹẹ viẹ, ẹẹ wọlọ. Eviẹ oyi eni e nu ẹ khiẹsẹ itsua ishemhi, o she ramhi esọ eyi Ẹshinẹgba ni ọ funẹ nya ni ọ mhuẹ ekhọli-okhuẹ na iloghie.\f + \fr 5:4 \ft Li zẹ \fq iDẹut 24.14-15\f* 
\v 5 Eri u la agbọ ẹ li agbọ nyafunyafu, u li agbọ ọ tsua kua. Wa le ọkpọ, ali ọfọlọ, u gbẹdi-a lọọghọ abi ẹlamhi ni a mu ya gbe-a.  
\v 6 U she pfa ẹzọ ugbeli mu ẹgbọ eni ẹa mhuẹ abi e li, u gbolo wẹ-a. Wẹwẹ na, ẹa dobẹ liẹ khi wẹwẹ a lama shi ẹ ọ. 
\s1 Irabọmudu elemhi osoli 
\p  
\v 7 Irarighọ, inyọghuo, ri abọ mudu ramhi ibhale oyi Ọnọmhuẹ. Bino ghue abi ọghiale ọ liẹ migha khẹ ẹghẹghẹ ni ishemhi e la bie. Abi ọ li ri abọ mudu ni otsukpe o de, ni oruamẹ o rọ le.  
\v 8 Yẹyẹ li lighọ ri abọ mu udu abi ọghiale. Lolo ri ukpẹloe shi ekẹ, u migha gbagbagba irari khi ibhale oyi Ọnọmhuẹ o ti bhale. 
\p  
\v 9 A khi ke mẹ umha-guẹli oyegbe inyọghuo-mhẹ, ini a khi gue ẹ ẹzọ. Ọsọẹzọ ọ ga ti mama awa memena. 
\p  
\v 10 Inyọghuo-mhẹ, a ke khọnya emekẹguele ni ẹẹ ngme na Ọnọmhuẹ. Eri e ri abọ mudu ini o riẹ khi e ya mẹ osoli.  
\v 11 A she kpẹ lẹsẹ khi eni a khivọsẹ na, anye ẹ lu ẹgbọ eni e ri egbe ẹ mie. A she kpe suọ eko iJobu abi ọọ ri egbe mie tẹsẹ. A mẹ emini Ẹshinẹgba ọ riẹlẹ na li ikpukhokho. Ọnọmhuẹ, ona ilẹlemhi ọ khi.\f + \fr 5:11 \ft Li zẹ \fq iJobu 1.21-22; 2.10; Iwolo 103.8\f* 
\p  
\v 12 Inyọghuo-mhẹ, oni o mu egbe nẹ nya khi, khi romhi iloghie ali ekẹ agbọ ali emhese. Zẹ ni, “Ii oyẹ o khi ii, u zẹ ni iiye oyẹ, o khi iiye.” Ini a khi mẹ asha pfa ẹzọ mu ẹ.\f + \fr 5:12 \ft Li zẹ \fq iMat 5.34-37\f* 
\s1 Iromhi ni a ri irudunga sọ 
\p  
\v 13 Ini ọngẹẹ ọ la elemhi ọmunu, ọ lema Ẹshinẹgba. Ini ọngẹẹ ọọ ghẹlẹ, ọ to uwolo ikuẹghiẹ.  
\v 14 Ini ọngẹẹ ọọ ghua, ọ ka lu egbhali ni e la igbaa oyi eni e mie iJesu iKirisiti suọ, ni e sọ iromhi na li, e ri eva ọyi Ọnọmhuẹ ri oili to ọli egbe.\f + \fr 5:14 \ft Li zẹ \fq iMak 6.13\f* 
\v 15 Ẹghẹghẹ aghọ, ni iromhi ni e ri irudunga sọ, ni o ri ọli zẹ. Ni Ọnọmhuẹ ọ rọte ughuamhi mu ọli vule. Ini ọ lamhẹ olamhẹ, Ọnọmhuẹ ọ ya rọ topfa li.  
\v 16 Irarighọ, a zọnọ olamhẹ eyẹẹ ye egbe ẹ, a lema na egbe, ni a rẹ ẹ ze. Eri iromhi oyi ọgbọ ni ọ la ipfuasẹ o migha a gbe akanya egbegbọ. 
\p  
\v 17 Ọgbọ onabi awa, Elaja ọ khi. Eri ọ te ekelemhi udu lema egbegbọ. Ọọ amẹ o khi ruẹ, amẹ o mu oni ekẹ elemhi ikpe esẹ ali ukhukhui.\f + \fr 5:17 \ft Li zẹ \fq 1 Ighie 17.1; 18.1\f* 
\v 18 Ọ gbo lema, ọọ amẹ o ruẹ, amẹ o ruẹ, ekẹ o ri emhi ẹkọmhi zẹ lasele.\f + \fr 5:18 \ft Li zẹ \fq 1 Ighie 18.42-45\f* 
\p  
\v 19 Ini ọngẹ ẹ ọ pfi egbegbi odẹ oyi Ẹshinẹgba shi ekẹ, no ọgbọẹse ọ rọ mu ọli nyenẹ bhale ukhokho,  
\v 20 sato ọ khi, ọnini ọ mu ọna olamhẹ rọte odẹ ẹgbhọli oyọli pfi, ọ ya tsumhi ayẹmhẹ oyọli obọ eghuli, ọ guese olamhẹ ebubu na li.\f + \fr 5:20 \ft Li zẹ \fq Ekpi 10.12; 1 iPit 4.8\f*