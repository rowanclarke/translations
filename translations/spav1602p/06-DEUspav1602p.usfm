\v 68 \w Y|strong="H3068"\w* el \w SEÑOR|strong="H3068"\w* te hará \w tornar|strong="H7725"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* \w en|strong="H5750"\w* navíos \w por|strong="H1870"\w* el \w camino|strong="H1870"\w* del cual te \w ha|strong="H3808"\w* dicho: \w Nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w volveréis|strong="H7725"\w*: y \w allí|strong="H8033"\w* seréis \w vendidos|strong="H4376"\w* \w a|strong="H3068"\w* vuestros enemigos \w por|strong="H1870"\w* esclavos y \w por|strong="H1870"\w* esclavas, y \w no|strong="H3808"\w* habrá quien os compre.
\c 29
\m 
\v 1 \w ÉSTAS|strong="H6213"\w* \add son\add* las palabras del pacto \w que|strong="H3605"\w* \w el|strong="H3605"\w* \w SEÑOR|strong="H3068"\w* mandó \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w que|strong="H3605"\w* concertara con \w los|strong="H3605"\w* hijos \w de|strong="H5869"\w* \w Israel|strong="H3478"\w* en \w la|strong="H3605"\w* tierra \w de|strong="H5869"\w* Moab, además del acto \w que|strong="H3605"\w* con­certó con \w ellos|strong="H3605"\w* en Horeb.
\m 
\v 2 Moisés \w pues|strong="H7200"\w* llamó \w a|strong="H3068"\w* todo Israel, y díjoles: Vosotros habéis \w visto|strong="H7200"\w* todo \w lo|strong="H1992"\w* \w que|strong="H1992"\w* \w el|strong="H1992"\w* SEÑOR ha hecho \w delante|strong="H5869"\w* \w de|strong="H5869"\w* vuestros \w ojos|strong="H5869"\w* en la tierra \w de|strong="H5869"\w* Egipto \w a|strong="H3068"\w* Faraón y \w a|strong="H3068"\w* todos \w sus|strong="H1992"\w* siervos, y \w a|strong="H3068"\w* toda \w su|strong="H1992"\w* tierra:
\m 
\v 3 Las pruebas grandes \w que|strong="H3808"\w* vie­ron tus \w ojos|strong="H5869"\w*, las señales, \w y|strong="H5704"\w* las grandes maravillas.
\m 
\v 4 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* SEÑOR \w no|strong="H3808"\w* \w os|strong="H5921"\w* dio corazón \w para|strong="H5921"\w* entender, \w ni|strong="H3808"\w* ojos \w para|strong="H5921"\w* ver, \w ni|strong="H3808"\w* oídos \w para|strong="H5921"\w* oír, \w hasta|strong="H5921"\w* \w el|strong="H5921"\w* día \w de|strong="H5921"\w* hoy.
\m 
\v 5 \w Y|strong="H3068"\w* \w yo|strong="H3588"\w* os he traído cuarenta años \w por|strong="H3588"\w* \w el|strong="H3588"\w* desierto: vuestras vestiduras \w no|strong="H3808"\w* \w se|strong="H3045"\w* han envejecido sobre voso­tros, \w ni|strong="H3808"\w* tu zapato \w se|strong="H3045"\w* \w ha|strong="H3808"\w* envejeci­do sobre tu pie.
\m 
\v 6 No habéis comido pan, ni bebisteis vino ni bebida fuerte: para \w que|strong="H2088"\w* supieseis \w que|strong="H2088"\w* yo soy el SEÑOR vuestro Dios.
\m 
\v 7 \w Y|strong="H3068"\w* llegasteis \w a|strong="H3068"\w* este lugar, y salió Sehón rey \w de|strong="H5414"\w* Hesbón, y Og rey \w de|strong="H5414"\w* Basán, delante \w de|strong="H5414"\w* nosotros \w para|strong="H5414"\w* pelear, y herímoslos;
\m 
\v 8 \w Y|strong="H3068"\w* tomamos su tierra, y dímos­\w la|strong="H2063"\w* \w por|strong="H4616"\w* heredad \w a|strong="H3068"\w* Rubén y \w a|strong="H3068"\w* Gad, y \w a|strong="H3068"\w* \w la|strong="H2063"\w* media tribu \w de|strong="H1697"\w* Manasés.
\m 
\v 9 Guardaréis, pues, las palabras \w de|strong="H6440"\w* este pacto, y las pondréis \w por|strong="H6440"\w* obra, para \w que|strong="H3117"\w* prosperéis en \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3117"\w* hiciereis.
\m 
\v 10 Vosotros todos estáis hoy \w delante|strong="H5704"\w* del SEÑOR vuestro Dios; vuestros príncipes \w de|strong="H5704"\w* vues­tras tribus, vuestros ancianos, \w y|strong="H5704"\w* vuestros oficiales, todos los varo­nes \w de|strong="H5704"\w* Israel,
\m 
\v 11 Vuestros niños, vuestras esposas, y tus extranjeros \w que|strong="H3117"\w* habitan \w en|strong="H5973"\w* medio \w de|strong="H5973"\w* tu campo, desde \w el|strong="H5973"\w* \w que|strong="H3117"\w* corta tu leña \w hasta|strong="H3117"\w* \w el|strong="H5973"\w* \w que|strong="H3117"\w* saca tus aguas:
\m 
\v 12 \w Para|strong="H4616"\w* \w que|strong="H1931"\w* entres en \w el|strong="H1931"\w* pacto del SEÑOR tu Dios, y en \w su|strong="H1931"\w* \w jura|strong="H7650"\w*­mento, \w que|strong="H1931"\w* \w el|strong="H1931"\w* SEÑOR tu Dios acuerda \w hoy|strong="H3117"\w* \w contigo|strong="H5971"\w*:
\m 
\v 13 Para confirmarte hoy por su pueblo, y \w que|strong="H3808"\w* él te sea \w a|strong="H3068"\w* ti por Dios, de \w la|strong="H2063"\w* manera \w que|strong="H3808"\w* él te \w ha|strong="H3808"\w* dicho, y como él juró \w a|strong="H3068"\w* tus padres Abraham, Isaac, y Jacob.
\m 
\v 14 \w Y|strong="H3068"\w* \w no|strong="H3588"\w* \w con|strong="H5973"\w* \w vosotros|strong="H3426"\w* solos acuerdo \w yo|strong="H3588"\w* \w este|strong="H5975"\w* pacto \w y|strong="H3588"\w* \w este|strong="H5975"\w* jura­mento,
\m 
\v 15 \w Sino|strong="H3588"\w* \w con|strong="H3588"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w están|strong="H3427"\w* aquí presentes hoy \w con|strong="H3588"\w* nosotros delante del SEÑOR nuestro Dios, \w y|strong="H3588"\w* \w con|strong="H3588"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w están|strong="H3427"\w* aquí hoy \w con|strong="H3588"\w* nosotros.
\m 
\v 16 Porque \w vosotros|strong="H5973"\w* sabéis \w cómo|strong="H5973"\w* habitamos \w en|strong="H5973"\w* la tierra \w de|strong="H5973"\w* Egipto, y \w cómo|strong="H5973"\w* hemos pasado por medio \w de|strong="H5973"\w* las naciones que habéis pasado;
\m 
\v 17 \w Y|strong="H3068"\w* habéis visto \w sus|strong="H1992"\w* abomina­ciones, y \w sus|strong="H1992"\w* ídolos, madera y piedra, plata y oro, \w que|strong="H6435"\w* \add tienen\add* \w consigo|strong="H5973"\w*.
\m 
\v 18 \w Quizá|strong="H3588"\w* \w habrá|strong="H1961"\w* \w entre|strong="H3588"\w* \w vosotros|strong="H8085"\w* varón, \w o|strong="H3068"\w* mujer, \w o|strong="H3068"\w* familia, \w o|strong="H3068"\w* tribu, cuyo \w corazón|strong="H3820"\w* \w se|strong="H1961"\w* vuelva hoy \w de|strong="H3588"\w* \w con|strong="H3588"\w* \w el|strong="H3588"\w* SEÑOR nuestro Dios, \w por|strong="H3588"\w* \w andar|strong="H3212"\w* \w a|strong="H3068"\w* servir \w a|strong="H3068"\w* \w los|strong="H1961"\w* dioses \w de|strong="H3588"\w* aquellas naciones; \w quizá|strong="H3588"\w* \w habrá|strong="H1961"\w* \w en|strong="H3588"\w* \w vosotros|strong="H8085"\w* raíz \w que|strong="H3588"\w* eche veneno \w y|strong="H3588"\w* ajenjo;
\m 
\v 19 \w Y|strong="H3068"\w* sea \w que|strong="H3588"\w*, \w cuando|strong="H3588"\w* \w el|strong="H1931"\w* \w tal|strong="H2088"\w* oyere las palabras \w de|strong="H3588"\w* \w esta|strong="H2088"\w* maldición, \w él|strong="H1931"\w* \w se|strong="H1931"\w* bendiga \w en|strong="H3588"\w* \w su|strong="H1931"\w* corazón, dicien­do: Tendré paz, \w aunque|strong="H3588"\w* ande según \w la|strong="H1931"\w* imaginación \w de|strong="H3588"\w* mi cora­zón, \w para|strong="H3588"\w* añadir \w la|strong="H1931"\w* embriaguez \w a|strong="H3068"\w* \w la|strong="H1931"\w* sed:
\m 
\v 20 \w El|strong="H3605"\w* \w SEÑOR|strong="H3068"\w* no querrá perdo­narle; \w antes|strong="H2088"\w* humeará \w luego|strong="H2088"\w* \w el|strong="H3605"\w* furor del \w SEÑOR|strong="H3068"\w* y su celo sobre \w el|strong="H3605"\w* \w tal|strong="H2088"\w* hombre, y asentaráse sobre \w él|strong="H3605"\w* \w toda|strong="H3605"\w* maldición \w escrita|strong="H3789"\w* en \w este|strong="H2088"\w* \w libro|strong="H5612"\w*, y \w el|strong="H3605"\w* \w SEÑOR|strong="H3068"\w* raerá su nom­bre \w de|strong="H7451"\w* debajo del cielo:
\m 
\v 21 \w Y|strong="H3068"\w* apartarálo \w el|strong="H1931"\w* \w SEÑOR|strong="H3068"\w* \w de|strong="H1121"\w* \w todas|strong="H1755"\w* las tribus \w de|strong="H1121"\w* Israel para mal, \w conforme|strong="H1931"\w* \w a|strong="H3068"\w* \w todas|strong="H1755"\w* las maldi­ciones del pacto escrito en \w este|strong="H1931"\w* libro \w de|strong="H1121"\w* \w la|strong="H1931"\w* ley.
