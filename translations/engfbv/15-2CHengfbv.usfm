\p
\v 17 Solomon \w had|strong="H5971"\w* \w a|strong="H3068"\w* census \w taken|strong="H6213"\w* \w of|strong="H2022"\w* \w all|strong="H6213"\w* \w the|strong="H6213"\w* foreigners \w in|strong="H6213"\w* \w the|strong="H6213"\w* land \w of|strong="H2022"\w* \w Israel|strong="H5971"\w*, \w like|strong="H6213"\w* \w the|strong="H6213"\w* census \w his|strong="H6213"\w* father David \w had|strong="H5971"\w* conducted, \w and|strong="H3967"\w* found \w there|strong="H1992"\w* \w were|strong="H5971"\w* 153,600.  
\v 18 He allocated 70,000 as laborers, 80,000 as stonecutters in the mountains, and 3,600 as foremen.   
\b  
\c 3  
\p
\v 1 \w Then|strong="H7200"\w* \w Solomon|strong="H8010"\w* \w began|strong="H2490"\w* \w building|strong="H1129"\w* \w the|strong="H7200"\w* \w Temple|strong="H1004"\w* \w of|strong="H1004"\w* \w the|strong="H7200"\w* \w Lord|strong="H3068"\w* \w in|strong="H3068"\w* \w Jerusalem|strong="H3389"\w* \w on|strong="H7200"\w* \w Mount|strong="H2022"\w* \w Moriah|strong="H4179"\w*, \w where|strong="H4725"\w* \w the|strong="H7200"\w* \w Lord|strong="H3068"\w* \w appeared|strong="H7200"\w* \w to|strong="H3068"\w* \w his|strong="H3068"\w* father \w David|strong="H1732"\w*. \w This|strong="H7200"\w* \w was|strong="H3068"\w* \w the|strong="H7200"\w* \w place|strong="H4725"\w* \w that|strong="H7200"\w* \w David|strong="H1732"\w* \w had|strong="H3068"\w* \w provided|strong="H3559"\w*—\w the|strong="H7200"\w* former \w threshing|strong="H1637"\w* \w floor|strong="H1637"\w* \w of|strong="H1004"\w* Ornan \w the|strong="H7200"\w* \w Jebusite|strong="H2983"\w*.  
