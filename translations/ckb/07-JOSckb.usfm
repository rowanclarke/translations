\id JOS - Biblica® Open Kurdi Sorani Standard Version
\h یەشوع
\toc1 یەشوع
\toc2 یەشوع
\toc3 یەشوع
\mt1 یەشوع
\c 1
\s1 فەرمانی یەزدان بۆ یەشوع
\p 
\v 1 ئەوە بوو پاش مردنی موسای بەندەی یەزدان، یەزدان بە یەشوعی کوڕی نونی خزمەتکاری موسای فەرموو:
\v 2 «موسای بەندەم مرد، ئێستا هەستە، خۆت و هەموو ئەم گەلە لە ڕووباری ئوردونەوە بپەڕنەوە بۆ ئەو خاکەی پێیان دەدەم، واتا بە نەوەی ئیسرائیل.
\v 3 هەر شوێنێک پێی لێ بنێن، بە ئێوەی دەدەم، هەروەک بە موسام فەرموو،
\v 4 لە چۆڵەوانییەوە هەتا لوبنان و لە ڕووباری گەورە، ڕووباری فورات، واتا هەموو خاکی حیتییەکان هەتا دەریای سپی ناوەڕاست\f + \fr 1:4 \ft دەریای سپی ناوەڕاست: عیبری دەریای مەزن.‏\f* بەرەو ڕۆژئاوا دەبێت بە سنوورتان.
\v 5 لە هەموو ڕۆژانی ژیانت کەس بەرەو ڕووت ناوەستێت. هەروەک لەگەڵ موسادا بووم، لەگەڵ تۆش دەبم و فەرامۆشت ناکەم و بەجێت ناهێڵم.
\v 6 بەهێزبە و ئازابە، چونکە ئەو خاکە بۆ ئەم گەلە دەکەیت بە میرات کە سوێندم بۆ باوباپیرانیان خواردووە کە پێیانی بدەم.
\p 
\v 7 «تەنها بەهێزبە و زۆر ئازابە، بۆ ئەوەی هۆشیار بیت بۆ کارکردن بەپێی هەموو ئەو فێرکردنەی کە موسای بەندەم فەرمانی پێ کردوویت. نە بەلای ڕاست و نە بەلای چەپ لێی لامەدە، بۆ ئەوەی بۆ هەرکوێیەک بچیت سەرکەوتوو بیت.
\v 8 پەڕتووکی ئەم فێرکردنە لە دەمت جیا نەبێتەوە، بەڵکو بە شەو و بە ڕۆژ لێی وردبەرەوە، بۆ ئەوەی وریابیت بۆ کارکردن بەپێی هەموو ئەو شتانەی تێیدا نووسراوە، ئەو کاتە ژیانت ڕاستەڕێ دەبێت و سەردەکەویت.
\v 9 ئایا من فەرمانم بە تۆ نەکرد؟ جا بەهێزبە و ئازابە، مەتۆقە و ورە بەرمەدە، چونکە یەزدانی پەروەردگارت لەگەڵتە بۆ هەرکوێ بچیت.»
\p 
\v 10 ئیتر یەشوع فەرمانی بە کوێخاکانی گەل کرد و پێی گوتن:
\v 11 «بەناو ئۆردوگاکەدا تێبپەڕن و فەرمان بە گەل بکەن و بڵێن: ”ئازووقە بۆ خۆتان ئامادە بکەن، چونکە پاش سێ ڕۆژی دیکە لە ڕووباری ئوردونەوە دەپەڕنەوە هەتا بچنە ناوەوە و دەست بەسەر ئەو خاکەدا بگرن کە یەزدانی پەروەردگارتان دەتانداتێ هەتا ببنە خاوەنی.“»
\p 
\v 12 پاشان یەشوع بە ڕەئوبێنی و گادییەکان و نیوەی هۆزی مەنەشەی\f + \fr 1:12 \ft هۆزی مەنەشە دابەش ببوون بۆ سەر دوو بەش، هەریەکەیان کەوتبووە لایەکی ڕووباری ئوردون.‏\f* گوت:
\v 13 «ئەو وشەیەی موسای بەندەی یەزدان فەرمانی پێ کردن، بەبیری خۆتانی بهێننەوە، کە پێی ڕاگەیاندن یەزدانی پەروەردگارتان، ئێوەی حەساندەوە و ئەم خاکەی پێدان.
\v 14 ژن و منداڵ و ئاژەڵی ماڵیتان لەم خاکەدا دەمێننەوە کە موسا پێیدان، لەم بەری ڕووباری ئوردون بەرەو ڕۆژهەڵات، بەڵام هەموو جەنگاوەرە قارەمانەکان بە چەکەوە لەپێش براکانتانەوە دەپەڕنەوە. یارمەتی براکانتان دەدەن
\v 15 هەتا یەزدان وەک ئێوە براکانتان دەحەسێنێتەوە و ئەوانیش دەست بەسەر ئەو خاکەدا دەگرن کە یەزدانی پەروەردگارتان دەیانداتێ. دوای ئەوە دەگەڕێنەوە بۆ خاکەکەی میراتیتان و داگیری دەکەن، ئەوەی موسای بەندەی یەزدان لەم بەری ڕووباری ئوردون بەرەو ڕۆژهەڵات پێیدان.»
\p 
\v 16 ئەوانیش وەڵامی یەشوعیان دایەوە و گوتیان: «هەموو ئەو شتانەی فەرمانت پێ کردین جێبەجێی دەکەین و بۆ هەر شوێنێکمان بنێریت دەچین،
\v 17 بەپێی هەموو ئەوەی گوێڕایەڵی موسا بووین ئاوا گوێڕایەڵی تۆش دەبین. با یەزدانی پەروەردگارت لەگەڵت بێت وەک چۆن لەگەڵ موسا بوو.
\v 18 هەرکەسێک یاخی بێت لە فەرمانەکانت و گوێڕایەڵی وشەکانت نەبێت لە هەموو ئەوەی فەرمانی پێ دەکەیت، دەکوژرێت، بەڵام تەنها بەهێز و ئازابە!»
\c 2
\s1 ڕاحاب و دوو سیخوڕ
\p 
\v 1 ئینجا یەشوعی کوڕی نون لە شەتیمەوە دوو سیخوڕی بە نهێنی نارد و گوتی: «بڕۆن تەماشای خاکەکە بکەن، بە تایبەتی ئەریحا.» ئەوانیش ڕۆیشتن و چوونە ماڵی ژنێکی لەشفرۆش کە ناوی ڕاحاب بوو، لەوێ مانەوە.
\p 
\v 2 بە پاشای ئەریحا گوترا: «بزانە، ئەمشەو دوو پیاوی نەوەی ئیسرائیل هاتوونەتە ئێرە هەتا سیخوڕی دەربارەی خاکەکە بکەن.»
\v 3 لەبەر ئەوە پاشای ئەریحا بەدوای ڕاحابدا ناردی و پێی گوت: «ئەو دوو پیاوەی کە هاتن بۆ لات و هاتنە ناو ماڵەکەت بیانهێنە دەرەوە، چونکە ئەوانە هاتوون بۆ ئەوەی سیخوڕی لەبارەی هەموو خاکەکەوە بکەن.»
\p 
\v 4 بەڵام ڕاحاب دوو پیاوەکەی بردبوو و شاردبوونییەوە و گوتی: «ڕاستە ئەو دوو پیاوە هاتنە لای من، بەڵام نەمزانی خەڵکی کوێن.
\v 5 کاتێک تاریکی داهات، کاتی داخستنی دەروازەی شار، دوو پیاوەکە ڕۆیشتن. نازانم دوو پیاوەکە بۆ کوێ چوون. بە پەلە شوێنیان بکەون، بەڵکو پێیان بگەن.»
\v 6 بەڵام ئەو هەردووکیانی بردبوو بۆ سەربان و لەناو کۆمەڵێک چیلکە داری کەتاندا شاردبوونییەوە کە لە سەربان هەڵیچنیبوون.
\v 7 پیاوەکانی پاشاش بەو ڕێگایەی کە بەرەو تەنکاییەکانی ڕووباری ئوردون دەچوو بەدوای سیخوڕەکاندا چوون. کە ئەوانەی بە شوێنیاندا دەگەڕان چوونە دەرەوە، دەروازەکان داخران.
\p 
\v 8 پێش ئەوەی سیخوڕەکان خەویان لێ بکەوێت، ڕاحاب بۆ لایان سەرکەوتە سەربان و
\v 9 بە پیاوەکانی گوت: «زانیومە کە یەزدان ئەم خاکەی بە ئێوە داوە و ترسی ئێوە باڵی بەسەرماندا کێشاوە و سەرجەم دانیشتووانی خاکەکەش لەبەر ئێوە ڕەنگیان پەڕیوە،
\v 10 چونکە بیستمان یەزدان چۆن ئاوی دەریای سووری\f + \fr 2:10 \ft عیبری \tl سوف‏\tl* واتا (زەل). دەشێت مەبەست لە دەریای سوف بێت، ئەو دەریایە بێت کە دەکەوێتە سەرووی باکووری کەنداوی سوێسی ئەمڕۆ، بەڵام لە دەقی یۆنانی پەیمانی نوێ هەر بە دەریای سوور نووسراوە. بڕوانە \xt عیبرانییەکان 11‏:29‏\xt*\ft ‏.‏\f* لەپێشتان وشک کرد، کاتێک لە میسر هاتنە دەرەوە، هەروەها لەوبەری ڕووباری ئوردون بەلای ڕۆژهەڵات چیتان بە هەردوو پاشای ئەمۆرییەکان سیحۆن و عۆگ کرد، ئەوانەی کە بە تەواوی قڕتان کردن\f + \fr 2:10 \ft لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f*.
\v 11 کاتێک ئەوەمان بیست، دڵمان تۆقی و بەهۆی ئێوەوە کەس ورەی\f + \fr 2:11 \ft ورە: عیبری \tl نەفەش‏\tl* واتا ڕۆح.‏\f* نەما، چونکە یەزدانی پەروەردگارتان ئەو خودایە لە ئاسمان لە سەرەوە و لەسەر زەوی لە خوارەوە.
\p 
\v 12 «ئێستاش بە یەزدان سوێندم بۆ بخۆن کە چۆن من چاکەم لەگەڵ ئێوەدا کرد، ئێوەش لەگەڵ ماڵی باوکم چاکە بکەن. نیشانەیەکی دڵنیابوونم بدەنێ کە
\v 13 دایک و باوک و خوشک و براکانم و هەموو ئەوەی هەیانە بە زیندوویی بیانهێڵنەوە و فریای گیانمان بکەون لە مردن.»
\p 
\v 14 پیاوەکانیش پێیان گوت: «خودا بمانکات بە قوربانتان! ئەگەر ئەم کارەمان نەدرکێنن، هەروەها ئەگەر یەزدان خاکەکەی پێداین، ئەوا چاکە و دڵسۆزیت لەگەڵدا دەکەین.»
\p 
\v 15 ئینجا ڕاحاب هەردووکیانی لە پەنجەرەی ماڵەکەیەوە بە گوریس شۆڕکردەوە، چونکە ماڵەکەی کە تێیدا دەژیا لە شوورای شارەکە بوو.
\v 16 هەروەها پێی گوتن: «بڕۆن بۆ چیا نەوەک ئەوانەی بە شوێنتاندا دەگەڕێن تووشتان بن، لەوێ بۆ ماوەی سێ ڕۆژ خۆتان بشارنەوە، هەتا ئەوان دەگەڕێنەوە، ئینجا بە ڕێگای خۆتاندا بڕۆن.»
\p 
\v 17 پیاوەکانیش پێیان گوت: «ئێمە بێتاوان دەبین لەو سوێندەی کە بۆ تۆمان خوارد
\v 18 ئەگەر هاتوو لە کاتی هاتنمان بۆ ناو خاکەکە، ئەم گوریسە سوورە بەو پەنجەرەیەوە گرێ نەدەیت کە ئێمەت لێوەی شۆڕکردەوە و ئەگەر دایک و باوک و خوشک و براکانت و سەرجەم ئەندامانی ماڵی باوکت لە ماڵەکەی خۆتدا کۆنەکەیتەوە.
\v 19 ئەگەر هەرکەسێک لە دەرگاکانی ماڵەکەی تۆوە بچێتە دەرەوە خوێنی خۆی لەسەر خۆی دەبێت و ئێمە بێتاوان دەبین، بەڵام هەر یەکێک لەگەڵ تۆ لە ماڵەکەتدا بێت، ئەگەر دەستدرێژییەکی کرایە سەر ئەوا خوێنی لەسەر ئێمە دەبێت.
\v 20 هەروەها ئەگەر ئەم کارەی ئێمە بدرکێنیت، ئێمە بێتاوان دەبین لەو سوێندەی کە بۆ تۆمان خوارد.»
\p 
\v 21 ڕاحابیش گوتی: «چۆنتان گوت، ئاوا دەبێت.»
\p ئیتر بەڕێی کردن و ڕۆیشتن، ئەویش گوریسە سوورەکەی بە پەنجەرەکەوە گرێ دا.
\p 
\v 22 پیاوەکان ڕۆیشتن و چوونە چیا و ماوەی سێ ڕۆژ لەوێ مانەوە، هەتا ئەوانەی بە شوێنیاندا دەگەڕان گەڕانەوە، لە دوای ئەوەی کە لە هەموو ڕێگاکاندا بەدوایاندا گەڕان و نەیاندۆزینەوە.
\v 23 ئینجا دوو پیاوەکە گەڕانەوە، لە چیاکە هاتنە خوارەوە و لە ڕووبارەکە پەڕینەوە، هاتنە لای یەشوعی کوڕی نون و هەموو بەسەرهاتەکەیان بۆ گێڕایەوە،
\v 24 بە یەشوعیان گوت: «بەڕاستی یەزدان هەموو خاکەکەی داوەتە دەستمانەوە و سەرجەم دانیشتووانی خاکەکەش بەهۆی ئێمەوە ڕەنگیان سپی بووە.»
\c 3
\s1 پەڕینەوە لە ڕووباری ئوردون
\p 
\v 1 بەیانی زوو یەشوع لەگەڵ هەموو نەوەی ئیسرائیل لە شەتیمەوە کۆچیان کرد و هاتنە لای ڕووباری ئوردون، بەر لەوەی بپەڕنەوە لەوێ مانەوە.
\v 2 پاش سێ ڕۆژ کوێخاکان بەناو ئۆردوگاکەدا گەڕان و
\v 3 فەرمانیان بە گەل کرد و گوتیان: «کاتێک کە سندوقی پەیمانی یەزدانی پەروەردگارتان دەبینن، کاهینە لێڤییەکان هەڵیانگرتووە، لە شوێنەکانی خۆتان کۆچ بکەن و لەدوایەوە بڕۆن.
\v 4 بەڵام با ماوەی نێوان ئێوە و سندوقەکە بە پێوانە دوو هەزار باڵ\f + \fr 3:4 \ft دوو هەزار باڵ: نزیکەی 900 مەتر.‏\f* بێت و لێی نزیک مەبنەوە بۆ ئەوەی ئەو ڕێگایە بزانن کە پێیدا دەڕۆن، چونکە ئێوە پێشتر بەم ڕێگایەدا نەڕۆیشتوون.»
\p 
\v 5 یەشوع بە گەلی گوت: «خۆتان تەرخان بکەن، چونکە یەزدان بەیانی لەنێوتاندا کاری سەرسوڕهێنەر دەکات.»
\p 
\v 6 هەروەها یەشوع بە کاهینەکانی گوت: «سندوقی پەیمان هەڵبگرن و بە بەردەم گەلدا تێپەڕ بن.» ئەوانیش سندوقی پەیمانیان هەڵگرت و لەپێش گەل ڕۆیشتن.
\p 
\v 7 ئینجا یەزدان بە یەشوعی فەرموو: «لە ئەمڕۆوە دەست دەکەم بە پایەبەرزکردنەوەت لەلای هەموو نەوەی ئیسرائیل، بۆ ئەوەی بزانن چۆن لەگەڵ موسادا بووم ئاواش لەگەڵ تۆدا دەبم.
\v 8 بەڵام تۆ فەرمان بە کاهینەکانی هەڵگری سندوقی پەیمان بکە و پێیان بڵێ: ”کاتێک دەگەنە کەنار ئاوی ڕووباری ئوردون، لەناو ڕووباری ئوردوندا بوەستن.“»
\p 
\v 9 هەروەها یەشوع بە نەوەی ئیسرائیلی گوت: «وەرنە پێشەوە بۆ ئێرە و گوێ لە فەرمایشتی یەزدانی پەروەردگارتان بگرن.»
\v 10 ئینجا یەشوع گوتی: «بەمە دەزانن کە خودای زیندوو لەنێوتاندایە، کەنعانی، حیتی، حیڤی، پریزی، گرگاشی، ئەمۆری و یەبوسییەکان لەبەردەمتاندا بە تەواوی دەردەکات.
\v 11 ئەوەتا سندوقی پەیمانی پەروەردگاری هەموو زەوی لەپێشتانەوە بۆ ناو ڕووباری ئوردون دەپەڕێتەوە.
\v 12 ئێستاش دوازدە پیاو لە هەموو هۆزەکانی ئیسرائیل بۆ خۆتان هەڵبژێرن، لە هەر هۆزە و پیاوێک.
\v 13 ئینجا کاتێک پێی کاهینەکانی هەڵگری سندوقی یەزدان، پەروەردگاری هەموو زەوی، لەناو ئاوی ڕووباری ئوردون جێگیر دەبێت، ئاوی ڕووباری ئوردون، ئەو ئاوەی کە لە سەرەوە دێت شەق دەبێت و لە یەک بەربەستدا پەنگدەخواتەوە.»\f + \fr 3:13 \ft ڕادەوەستێت: بڕوانە \xt دەرچوون 15‏:8‏\xt*\ft ‏.‏\f*
\p 
\v 14 جا کاتێک گەل لە چادرەکانیانەوە کۆچیان کرد، تاکو لە ڕووباری ئوردون بپەڕنەوە، کاهینەکانی هەڵگری سندوقی پەیمانیش لەپێشیانەوە بوون.
\v 15 بە درێژایی ڕۆژانی دروێنە ڕووباری ئوردونیش دەبووە لافاو، بەڵام لە کاتی هاتنی هەڵگرانی سندوقەکە بۆ ناو ڕووباری ئوردون و نوقومبوونی پێی کاهینەکانی هەڵگری سندوقەکە لەناو ئاوی کەنارەکە،
\v 16 ئەو ئاوەی لە سەرەوە دەهاتە خوارەوە لە ڕۆیشتن وەستا. لە دوورییەکی زۆرەوە لە شارۆچکەی ئادام لە بەربەستێک پەنگی خواردەوە، ئەو شارۆچکەیەی کە لەتەنیشت چەرەتانە، هەروەها ئەو ئاوەی کە دەڕژایە ناو دەریای عەراڤا واتا دەریای مردوو\f + \fr 3:16 \ft دەریای مردوو: عیبری: دەریای خوێ.‏\f* بە تەواوی بڕا و گەل بەرەو ئەریحا پەڕینەوە.
\v 17 کاهینەکانی هەڵگرانی سندوقی پەیمانی یەزدان لەسەر وشکانی لە ناوەڕاستی ڕووباری ئوردون بە جێگیری وەستان و هەموو ئیسرائیلیش بەسەر وشکانیدا پەڕینەوە، هەتا هەموو نەتەوەکە لە ڕووباری ئوردون تەواو پەڕینەوە.
\c 4
\p 
\v 1 کاتێک هەموو نەتەوەکە لە ڕووباری ئوردون تەواو پەڕینەوە، یەزدان بە یەشوعی فەرموو:
\v 2 «لەناو خەڵکەکەدا دوازدە پیاو هەڵبژێرە، لە هەر هۆزە و پیاوێک،
\v 3 فەرمانیان پێ بکە و پێیان بڵێ: ”لێرە لە ناوەڕاستی ڕووباری ئوردونەوە، لە شوێن پێی کاهینەکان کە تێیدا جێگیر بوون، دوازدە بەرد هەڵبگرن و لەگەڵ خۆتان بیانپەڕێننەوە و لەو شوێنەدا دایانبنێن کە ئەمشەو تێیدا دەمێننەوە.“»
\p 
\v 4 ئینجا یەشوع ئەو دوازدە پیاوەی بانگکرد کە لە نەوەی ئیسرائیل هەڵیبژاردبوون، لە هەر هۆزە و پیاوێک،
\v 5 یەشوع پێی گوتن: «لەبەردەم سندوقی یەزدانی پەروەردگارتانەوە تێپەڕ بن بۆ ناوەڕاستی ڕووباری ئوردون و بەگوێرەی ژمارەی هۆزەکانی نەوەی ئیسرائیل هەریەک لە ئێوە بەردێک بەرز بکاتەوە بۆ سەر شانی،
\v 6 بۆ ئەوەی ئەمە ببێتە نیشانەیەک لەنێوتان. ئەگەر سبەینێ منداڵەکانتان لێتان بپرسن: ”ئەم بەردانە چ واتایەکی هەیە؟“
\v 7 ئێوەش پێیان دەڵێن: ”ئاوی ڕووباری ئوردون لەبەردەم سندوقی پەیمانی یەزدان وەستا. کاتێک لە ڕووباری ئوردون پەڕینەوە، ئاوی ئوردون ڕاوەستا، جا ئەم بەردانە دەبنە یادگاری بۆ نەوەی ئیسرائیل بۆ هەتاهەتایە.“»
\p 
\v 8 نەوەی ئیسرائیلیش ئاوایان کرد، هەروەک یەشوع فەرمانی پێ کردن، دوازدە بەردیان لە ناوەڕاستی ڕووباری ئوردونەوە هەڵگرت، هەروەک یەزدان بە یەشوعی فەرموو، بەپێی ژمارەی هۆزەکانی نەوەی ئیسرائیل و لەگەڵ خۆیاندا پەڕاندیانەوە بۆ ئەو شوێنەی چادریان تێیدا هەڵدا و لەوێ دایاننان.
\v 9 یەشوعیش دوازدە بەردەکەی ڕاگیر کرد کە لە ناوەڕاستی ڕووباری ئوردوندا بوون لەو شوێنەی کە کاهینەکانی هەڵگری سندوقی پەیمان ڕاوەستابوون و هەتا ئەمڕۆش لەو شوێنەدان.
\p 
\v 10 کاهینەکانی هەڵگرانی سندوقەکە لە ناوەڕاستی ڕووباری ئوردوندا وەستان هەتا هەموو ئەو شتانەی یەزدان فەرمانی بە یەشوع کردبوو بە گەلی بڵێت بەگوێرەی هەموو ئەوەی موسا فەرمانی بە یەشوع کردبوو تەواو بوو. گەل پەلەیان کرد و پەڕینەوە.
\v 11 کاتێک هەموو گەل تەواو پەڕینەوە، سندوقی یەزدان و کاهینەکانیش بە بەردەم گەلدا پەڕینەوە.
\v 12 نەوەی ڕەئوبێن و نەوەی گاد و نیوەی هۆزی مەنەشەش بە چەکەوە لەبەردەم نەوەی ئیسرائیل پەڕینەوە، هەروەک موسا پێی گوتبوون\f + \fr 4:12 \ft هەروەک موسا پێی گوتبوون: بڕوانە 1‏:12‏-15 و دواوتار 3‏:18‏-20.‏\f*.
\v 13 نزیکەی چل هەزار چەکدار بۆ شەڕکردن لەبەردەم یەزدان پەڕینەوە بۆ جەنگ بەرەو دەشتەکانی ئەریحا.
\p 
\v 14 لەو ڕۆژە یەزدان لەبەرچاوی هەموو ئیسرائیل یەشوعی بەرز ڕاگرت، ئەوانیش بە درێژایی ژیانی یەشوع ڕێزێکی تایبەتیان بۆی هەبوو، هەروەک چۆن ڕێزیان لە موسا گرتبوو.
\p 
\v 15 هەروەها یەزدان بە یەشوعی فەرموو:
\v 16 «فەرمان بە کاهینەکانی هەڵگرانی سندوقی پەیمانی بکە با لە ڕووباری ئوردونەوە سەربکەون.»
\p 
\v 17 یەشوعیش فەرمانی بە کاهینەکان کرد و گوتی: «لە ڕووباری ئوردونەوە سەربکەون.»
\p 
\v 18 ئەوە بوو لەگەڵ سەرکەوتنی کاهینەکانی هەڵگری سندوقی پەیمانی یەزدان لە ناوەڕاستی ڕووباری ئوردونەوە، بن پێی کاهینەکان کەوتە سەر وشکانی، ئاوی ڕووباری ئوردون گەڕایەوە شوێنی خۆی و وەک پێشتر بووەوە بە لافاو.
\p 
\v 19 گەلیش لە دەیەم ڕۆژی مانگی یەکدا لە ڕووباری ئوردونەوە سەرکەوتن و لە گلگال لە سنووری ڕۆژهەڵاتی ئەریحا چادریان هەڵدا.
\v 20 ئەو دوازدە بەردەش کە لە ڕووباری ئوردونەوە هێنابوویان، یەشوع لە گلگال کەڵەکەی کردن و
\v 21 بە نەوەی ئیسرائیلی گوت: «ئەگەر سبەینێ نەوەکانتان لە باوباپیرانی خۆیانیان پرسی: ”ئەم بەردانە چین؟“
\v 22 پێیان بناسێنن و پێیان بڵێن: ”نەوەی ئیسرائیل بەسەر وشکانی لەم ڕووباری ئوردونە پەڕینەوە.“
\v 23 لەبەر ئەوەی یەزدانی پەروەردگارتان ئاوی ڕووباری ئوردونی لەبەردەمیاندا وشک کرد هەتا پەڕینەوە، هەروەک ئەوەی بە دەریای سووری کرد کە لەبەردەمماندا وشکی کرد هەتا ئێمە پەڕینەوە.
\v 24 ئەمەی کرد هەتا هەموو گەلانی خاکەکە بزانن کە دەستی یەزدان بەهێزە، تاوەکو هەتاهەتایە لە یەزدانی پەروەردگارتان بترسن.»
\c 5
\s1 خەتەنەکردن لە گلگال
\p 
\v 1 کاتێک هەموو پاشاکانی ئەمۆرییەکان، ئەوانەی لەبەری ڕۆژئاوای ڕووباری ئوردون بوون و هەموو پاشاکانی کەنعانییەکان، ئەوانەی لەسەر کەناری دەریا بوون، بیستیان کە یەزدان ئاوی ڕووباری ئوردونی لەبەردەم نەوەی ئیسرائیل وشک کردووە هەتا دوای پەڕیونەتەوە، ئیتر دڵیان تۆقی و ورەیان تێدا نەما بۆ ڕووبەڕووبوونەوەی نەوەی ئیسرائیل.
\p 
\v 2 لەو کاتەدا یەزدان بە یەشوعی فەرموو: «چەند چەقۆیەک لە بەردەئەستێ بۆ خۆت دروستبکە و جارێکی دیکە نەوەی ئیسرائیل خەتەنە\f + \fr 5:2 \ft خەتەنەکردن: بڕوانە \xt پەیدابوون 17‏:9‏-14‏\xt*\ft ‏\f* بکەرەوە.»
\v 3 جا یەشوع چەند چەقۆیەکی لە بەردەئەستێ دروستکرد و نەوەی ئیسرائیلی لە گردی هاعەرالۆت\f + \fr 5:3 \ft هاعراڵۆت: واتا پێستی سەری کێر، کە لە کاتی خەتەنەکردندا دەبڕدرێت.‏\f* خەتەنە کرد.
\p 
\v 4 ئەمەش هۆی خەتەنەکردنەکەیان بوو لەلایەن یەشوعەوە، هەموو ئەو گەلەی کە لە میسر هاتبوونە دەرەوە، ئەو نێرینانەی کە پیاوی جەنگ بوون، ماوەیەک لەدوای ڕۆیشتنیان لە میسر لە ڕێگا لە چۆڵەوانی مردن.
\v 5 هەموو ئەو گەلەی کە لە میسرەوە کۆچیان کرد خەتەنە کرابوون، بەڵام هەموو ئەو گەلەی لە کاتی کۆچیان لە میسرەوە لە ڕێگا لە چۆڵەوانیدا لەدایک بوون خەتەنە نەکرابوون.
\v 6 نەوەی ئیسرائیل چل ساڵ بە چۆڵەوانیدا ڕۆیشتن، هەتا هەموو ئەو گەلە، هەموو پیاوانی جەنگ، ئەوانەی لە میسر هاتبوونە دەرەوە کۆتاییان پێهات، چونکە گوێڕایەڵی یەزدان نەبوون. یەزدان سوێندی بۆ خواردن کە ئەو خاکەیان پیشان نەدات کە سوێندی بۆ باوباپیرانیان خوارد کە دەیداتە ئێمە، ئەو خاکەی شیر و هەنگوینی لێ دەڕژێت.
\v 7 بۆیە کوڕەکانیانی لە جێی ئەوان پێگەیاند، هەروەها یەشوع ئەوانی خەتەنە کرد، چونکە خەتەنە نەکرابوون، لەبەر ئەوەی لە ڕێگادا خەتەنەیان نەکردبوون.
\v 8 پاش ئەوەی هەموو گەل لە خەتەنەکردن بوونەوە، لە جێی خۆیان لە ئۆردوگاکە مانەوە هەتا برینەکەیان ساڕێژ بوو.
\p 
\v 9 ئینجا یەزدان بە یەشوعی فەرموو: «ئەمڕۆ ڕیسوایی میسرم لێتان گلۆرکردەوە.» بۆیە ئەو شوێنە هەتا ئەمڕۆش بە گلگال\f + \fr 5:9 \ft لە زمانی عیبری \tl گلگال‏\tl* لە چاووگی (گلۆرکردنەوە) وەرگیراوە.‏\f* ناودەبردرێت.
\p 
\v 10 نەوەی ئیسرائیل لە گلگال چادریان هەڵدا و لە ئێوارەی ڕۆژی چواردەی مانگ لە دەشتی ئەریحا جەژنی پەسخەیان گێڕا.
\v 11 بۆ ڕۆژی پاش جەژنی پەسخە، هەر هەمان ڕۆژ، لە بەروبوومی خاک نانی فەتیرە و دانەوێڵەی برژاویان خوارد.
\v 12 هەروەها لەو ڕۆژەدا مەن بڕایەوە کاتێک لە بەری خاکەکەیان خوارد، ئیتر لەدوای ئەوە مەن بۆ نەوەی ئیسرائیل نەبوو، بەڵام ئەو ساڵە لە بەری زەوی کەنعانیان خوارد.
\s1 کەوتنی شاری ئەریحا
\p 
\v 13 ئەوە بوو کاتێک یەشوع لە نزیک ئەریحا بوو، سەری هەڵبڕی و بینی وا پیاوێک بەرامبەری ڕاوەستاوە و شمشێرەکەشی هەڵکێشاوە. یەشوعیش چووە لای و پێی گوت: «ئایا تۆ لەگەڵ ئێمە دایت یان لەگەڵ دوژمنەکانمان؟»
\p 
\v 14 ئەویش گوتی: «هیچیان، چونکە ئێستا من وەک فەرماندەی گشتی سوپای یەزدان هاتووم.» جا یەشوع بە ڕوودا بەسەر زەوی کەوت و کڕنۆشی برد و گوتی: «پەیامی گەورەکەم چییە بۆ خزمەتکاری خۆی؟»
\p 
\v 15 فەرماندەی گشتی سوپای یەزدانیش بە یەشوعی فەرموو: «پێڵاوەکانت لە پێت دابکەنە، چونکە ئەو شوێنەی تۆ لەسەری وەستاویت پیرۆزە.» یەشوعیش بەم جۆرەی کرد.
\c 6
\p 
\v 1 ئەریحاش بەهۆی نەوەی ئیسرائیلەوە بە تەواوی داخرابوو، نە کەس دەچووە دەرەوە و نە کەسیش دەهاتە ژوورەوە.
\p 
\v 2 جا یەزدان بە یەشوعی فەرموو: «بڕوانە من ئەریحا و پاشاکەی و پاڵەوانە شەڕکەرەکانی ئەوم داوەتە دەست تۆ.
\v 3 ئێوەش هەموو جەنگاوەرەکان بۆ ماوەی شەش ڕۆژ، ڕۆژی جارێک بە چواردەوری شارەکەدا دەسووڕێنەوە.
\v 4 حەوت کاهین حەوت کەڕەنای قۆچە بەران لەبەردەم سندوقەکەدا هەڵدەگرن و لە ڕۆژی حەوتەم حەوت جار بە چواردەوری شارەکەدا دەسووڕێنەوە و کاهینەکان کەڕەناکان لێدەدەن.
\v 5 کاتێک گوێتان لە دەنگی کەڕەناکان دەبێت، لەگەڵ درێژبوونەوەی فووکردن بە قۆچە بەرانەکاندا، هەموو گەل بە یەک دەنگ هاوارێکی بەرز دەکەن؛ ئیتر شوورای شارەکە دەڕمێت و هەموو گەل هەریەکە و لەلای خۆیەوە بەسەریدا دەدەن.»
\p 
\v 6 جا یەشوعی کوڕی نون کاهینەکانی بانگکرد و پێی گوتن: «سندوقی پەیمان هەڵبگرن و با حەوت کاهینیش حەوت کەڕەنای قۆچە بەران لەپێش سندوقی یەزدان هەڵبگرن.»
\v 7 ئینجا بە گەلی گوت: «پێش بکەون و بە چواردەوری شارەکەدا بسووڕێنەوە، با ئەوەی چەک بە دەستە لەپێش سندوقی یەزدانەوە بڕوات.»
\p 
\v 8 هەروەک چۆن یەشوع فەرمانی بە گەل کرد، حەوت کاهینەکەی هەڵگرانی حەوت کەڕەنا قۆچە بەرانەکان، لەبەردەم یەزدانەوە بە کەڕەنا لێدانەوە بەرەو پێش چوون و سندوقی پەیمانیش لە دوایانەوە دەڕۆیشت.
\v 9 هەموو چەک بەدەستەکانیش لەپێش کاهینە کەڕەنا لێدەرەکان دەڕۆیشتن، لەپاشەوە پاسەوانەکانیش لەدوای سندوقەکەوە دەڕۆیشتن. بەردەوام کەڕەنا دەنگی دەهات.
\v 10 بەڵام یەشوع فەرمانی بە گەل کردبوو و پێی گوتبوون: «هاوار مەکەن و دەنگتان نەبیسترێت و یەک وشە لە دەمتان نەیەتە دەرەوە، هەتا ئەو ڕۆژەی پێتان دەڵێم هاوار بکەن، جا هاوار دەکەن!»
\v 11 لەبەر ئەمە سندوقی یەزدان یەک جار بە چواردەوری شارەکەدا سووڕایەوە و پاشان هاتنەوە بۆ ناو ئۆردوگاکە و لە ئۆردوگاکە مانەوە.
\p 
\v 12 بەیانی زوو یەشوع لە خەو هەستا و کاهینەکانیش سندوقی یەزدانیان هەڵگرت و
\v 13 حەوت کاهینەکەی هەڵگرانی حەوت کەڕەناکەش لەپێش سندوقی یەزدانەوە دەڕۆیشتن و کەڕەنایان لێدەدا و چەک بەدەستەکانیش لەپێشیانەوە دەڕۆیشتن و لەپاشەوە پاسەوانەکانیش لەدوای سندوقی یەزدانەوە دەڕۆیشتن، کاتێک کەڕەنا دەنگی دەهات.
\v 14 ئینجا لە ڕۆژی دووەم یەک جار بەدەوری شارەکەدا سووڕانەوە و پاشان هاتنەوە بۆ ناو ئۆردوگاکە. شەش ڕۆژ ئاوایان کرد.
\p 
\v 15 ئەوە بوو لە ڕۆژی حەوتەم بەرەبەیان زوو لە خەو هەستان و حەوت جار بەو شێوەیە بە چواردەوری شارەکەدا سووڕانەوە. تەنها لەو ڕۆژەدا حەوت جار بە چواردەوری شارەکەدا سووڕانەوە،
\v 16 ئەوە بوو لە جاری حەوتەم کاتێک کاهینەکان کەڕەناکانیان لێدا، یەشوع بە گەلی گوت: «هاوار بکەن! چونکە یەزدان شارەکەی داوەتە دەست ئێوە!
\v 17 دەبێت شارەکە و هەرچی تێیدایە بۆ یەزدان تەرخان بکرێت تاکو قڕ بکرێت\f + \fr 6:17 \ft لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان. لە کاتی شەڕدا دەستکەوتەکە دابەش ناکرێت و بەخشینەکە دەرئەنجامەکەی لەناوبردنی تەواوە.‏\f*، تەنها ڕاحابی لەشفرۆش و هەموو ئەوانەی لە ماڵەکە لەگەڵین دەیانهێڵنەوە، چونکە ئەو دوو نێردراوەی شاردەوە، کە ناردمانن.
\v 18 بەڵام ئێوە خۆتان بە دوور بگرن لە شتە تەرخانکراوەکان نەوەک قڕ بکرێن و ئۆردوگای ئیسرائیل تووشی قڕبوون و تێکدان بکەن.
\v 19 هەموو ئەو زێڕ و زیو و قاپە بڕۆنز و ئاسنانە بۆ یەزدان تەرخانکراون و دەچنە ناو گەنجینەی یەزدانەوە.»
\p 
\v 20 کاتێک گەل هاواری کرد و کەڕەنایان لێدا، گەل گوێیان لە دەنگی کەڕەنا بوو، هاوارێکی بەرزیان کرد و شووراکە داڕما و گەل چوونە ناو شارەکەوە، هەریەکە و لەلای خۆیەوە و بەسەریاندا دا و شارەکەیان گرت.
\v 21 شارەکەیان بۆ یەزدان تەرخان کرد و هەرچی تێیدابوو لە پیاو و ژن و منداڵ و پیر، هەتا گا و مەڕ و گوێدرێژەکانیشیان بە زەبری شمشێر قڕ کرد.
\p 
\v 22 یەشوعیش بەو دوو پیاوەی گوت کە سیخوڕی خاکەکەیان کردبوو: «بچنە ناو ماڵی ژنە لەشفرۆشەکەوە، هەروەک سوێندتان بۆی خوارد، خۆی و هەموو ئەوەی هی ئەوە بیانهێننە دەرەوە.»
\v 23 جا دوو گەنجە سیخوڕەکە چوونە ژوورەوە و ڕاحاب و دایک و باوک و براکانی و هەرچی هەیبوو و هەموو کەسوکارەکەیان هێنایە دەرەوە و لە دەرەوەی ئۆردوگای ئیسرائیل دایاننان.
\p 
\v 24 شارەکەشیان سووتاند و لەگەڵ هەموو ئەو شتانەی تێیدا بوو، بەڵام زێڕ و زیو و قاپە بڕۆنز و ئاسنەکانیان خستە ناو گەنجینەی ماڵی یەزدانەوە.
\v 25 بەڵام یەشوع ڕاحابی لەشفرۆش و ماڵی باوکی و هەرچی هەیبوو بە زیندووێتی هێشتنییەوە، ئەویش هەتا ئەمڕۆش لەنێو ئیسرائیلدا نیشتەجێیە، چونکە ئەو دوو نێردراوەی شاردەوە کە یەشوع بۆ سیخوڕی ئەریحا ناردبوونی.
\p 
\v 26 لەو کاتەدا یەشوع سوێندی خوارد و گوتی: «لەبەردەم یەزدان نەفرەت لێکراوە ئەو کەسەی هەڵدەستێت و ئەم شاری ئەریحایە بنیاد دەنێتەوە:
\q1 «بە مەرگی کوڕە نۆبەرەکەی
\q2 بناغەکانی دادەنێت و
\q1 بە مەرگی بچووکەکەی
\q2 دەرگاکانی دادەمەزرێنێت.»
\p 
\v 27 یەزدانیش لەگەڵ یەشوع بوو و ناوبانگی بە هەموو خاکەکەدا بڵاو بووەوە.
\c 7
\s1 گوناهی عاخان
\p 
\v 1 بەڵام نەوەی ئیسرائیل سەبارەت بە شتە تەرخانکراوەکان بۆ یەزدان\f + \fr 7:1 \ft لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان. لە کاتی شەڕدا دەستکەوتەکە دابەش ناکرێت و بەخشینەکە دەرئەنجامەکەی لەناوبردنی تەواوە.‏\f* ناپاکییان کرد، عاخانی کوڕی کەرمی کوڕی زیمری کوڕی زەرەح لە هۆزی یەهودا لە شتە تەرخانکراوەکانی برد، ئیتر تووڕەیی یەزدان بەسەر نەوەی ئیسرائیلدا جۆشا.
\p 
\v 2 یەشوعیش چەند پیاوێکی لە ئەریحاوە بۆ عای نارد کە لەلای بێت‌ئاڤنە لە ڕۆژهەڵاتی بێت‌ئێل و پێی گوتن: «سەربکەون و سیخوڕی لەبارەی خاکەکەوە بکەن.» پیاوەکانیش سەرکەوتن و سیخوڕی عاییان کرد.
\p 
\v 3 کاتێک گەڕانەوە لای یەشوع و پێیان گوت: «با هەموو گەل سەرنەکەون، بەڵکو تەنها نزیکەی دوو هەزار یان سێ هەزار پیاو بەسەر عایدا بدەن، هەموو گەل شەکەت مەکە، چونکە ئەوان کەمن.»
\v 4 جا نزیکەی سێ هەزار کەس لە گەل بۆ ئەوێ سەرکەوتن، بەڵام لەبەردەم پیاوەکانی عای هەڵاتن،
\v 5 خەڵکی عای لێیاندان و نزیکەی سی و شەش پیاویان کوشتن و دوایان کەوتن. لەبەردەم دەروازەکەوە هەتا کانە بەردەکان، لە لێژاییەکە لێیان دان، گەل ڕەنگیان پەڕی.
\p 
\v 6 یەشوعیش جلەکانی دادڕی و لەبەردەم سندوقی یەزدان بە ڕوودا کەوتە سەر زەوی و هەتا ئێوارە لەوێ مایەوە. هەروەها پیرانی نەوەی ئیسرائیل هەمان شتیان کرد و خۆڵیان بەسەر سەری خۆیاندا کرد.
\v 7 هەروەها یەشوع گوتی: «ئای یەزدانی باڵادەست، بۆچی ئەم گەلەت بە تەواوی لە ڕووباری ئوردون پەڕاندەوە، بۆ ئەوەی بماندەیتە دەست ئەمۆرییەکان و لەناومان ببەن؟ خۆزگە بەوەندە ڕازی دەبووین و لەوبەری ڕووباری ئوردون دەماینەوە.
\v 8 ئەی پەروەردگار، من چی بڵێم پاش ئەوەی نەوەی ئیسرائیل لەبەردەم دوژمنەکانیاندا بەزین؟
\v 9 جا کەنعانییەکان و سەرجەم دانیشتووانی خاکەکە ئەمە دەبیستن و گەمارۆمان دەدەن و ناومان لەسەر ڕووی زەوی دەسڕنەوە، ئەی چی بۆ ناوی گەورەی خۆت دەکەیت؟»
\p 
\v 10 یەزدان بە یەشوعی فەرموو: «هەستە، بۆچی ئاوا بەسەر ڕووتدا کەوتوویت؟
\v 11 نەوەی ئیسرائیل گوناهیان کرد و هەروەها پەیمانەکەی منیان شکاند کە فەرمانم پێکردبوون، هەندێک لە شتە تەرخانکراوەکانیان برد، دزییان کرد و درۆیان کرد و لەناو کەلوپەلەکانی خۆیاندا دایاننا.
\v 12 بۆیە نەوەی ئیسرائیل ناتوانن بەرامبەر بە دوژمنەکانیان ڕابوەستن، پشتیان تێ دەکەن و هەڵدێن، چونکە بەرپرسیار بوون لە قڕبوونی خۆیان. ئەگەر بێتو ئەو تەرخانکراوە لەنێو خۆتاندا بنبڕ نەکەن، ئەوا لەمەودوا لەگەڵتاندا نابم.
\p 
\v 13 «هەستە، گەل تەرخان بکە و پێیان بڵێ: ”خۆتان بۆ بەیانی تەرخان بکەن، چونکە یەزدانی پەروەردگاری ئیسرائیل ئەمە دەفەرموێت: ئەی ئیسرائیل، لەنێوتان کەسانێک هەن کە شتی تەرخانکراویان بردووە. لەبەر ئەوە ناتوانن بەرامبەر بە دوژمنەکانتان ڕابوەستن، هەتا ئەو شتانە لەنێو خۆتان دانەماڵن.
\p 
\v 14 «”بەیانی بە هۆزەکانتانەوە وەرنە پێش و ئەو هۆزەی یەزدان هەڵیدەبژێرێت، با بە خێڵەکانییەوە بێتە پێش؛ ئەو خێڵەی یەزدان هەڵیدەبژێرێت، با بە بنەماڵەکانییەوە بێتە پێش؛ ئەو بنەماڵەیەی یەزدان هەڵیدەبژێرێت، با بە پیاوەکانییەوە یەک لەدوای یەک بێنە پێشەوە.
\v 15 ئەوەی بە شتە تەرخانکراوەکانەوە بگیردرێت، خۆی و هەرچی هەیەتی بە ئاگر دەسووتێنرێ، چونکە ئەو پەیمانی یەزدانی شکاندووە و کارێکی دزێوی لەناو ئیسرائیلدا ئەنجام داوە.“»
\p 
\v 16 بۆ بەیانی یەشوع زوو لە خەو هەستا و هۆزەکانی نەوەی ئیسرائیلی یەک یەک هێنایە پێش و هۆزی یەهودا هەڵبژێردرا\f + \fr 7:16 \ft هەڵبژێردرا: بە خواستی خودا بە تیروپشک هەڵبژێردرا.‏\f*.
\v 17 خێڵەکانی یەهودای هێنایە پێش و خێڵی زەرەحییەکان هەڵبژێردرا. ئینجا خێڵی زەرەحییەکانی هێنایە پێش بە خێزانەکانیانەوە و زیمری هەڵبژێردرا.
\v 18 بەرەبابەکەی ئەویشی بە پیاوەکانییەوە هێنایە پێش و عاخانی کوڕی کەرمی کوڕی زیمری کوڕی زەرەح هەڵبژێردرا کە سەر بە هۆزی یەهودایە.
\p 
\v 19 ئینجا یەشوع بە عاخانی گوت: «تکایە کوڕی خۆم، یەزدانی پەروەردگاری ئیسرائیل شکۆدار بکە و دانی پێدا بنێ. پێم بڵێ، چیت کردووە؟ لێمی مەشارەوە.»
\p 
\v 20 عاخانیش وەڵامی یەشوعی دایەوە و گوتی: «بەڕاستی من بەرامبەر بە یەزدانی پەروەردگاری ئیسرائیل گوناهم کردووە و ئاوام کردووە،
\v 21 لەنێو تاڵانکردنەکەدا کەوایەکی بابلی گرانبەها و دوو سەد شاقل زیو\f + \fr 7:21 \ft دوو سەد شاقل زیو: نزیکەی 2,3 کیلۆگرام.‏\f* و قاڵبە زێڕێکم بینی کە کێشەکەی پەنجا شاقل دەبوو، ئارەزووم کرد و بردم. ئەوەتا لەژێر زەوی لە ناوەڕاستی چادرەکەمدا شاردومەتەوە و زیوەکەش لە ژێرەوەیە.»
\p 
\v 22 جا یەشوع چەند کەسێکی نارد و ڕایانکرد بۆ چادرەکە و بینییان ئەوەتا لەناو چادرەکەدا شاردراونەتەوە و زیوەکەش لە ژێریانەوەیە.
\v 23 ئەوانیش شتەکانیان لە ناوەڕاست چادرەکە هەڵگرت و بۆ یەشوع و هەموو نەوەی ئیسرائیلیان هێنا و لەبەردەم یەزدان دایاننا.
\p 
\v 24 ئینجا یەشوع عاخانی کوڕی زەرەحی لەگەڵ زیوەکە و کەواکە و قاڵبە زێڕەکە و کوڕەکانی و کچەکانی و گا و گوێدرێژ و مەڕەکانی و چادرەکەی و هەموو ئەو شتانەی هی ئەو بوون، هەموو نەوەی ئیسرائیلیشی لەگەڵ بوو، بردیانن و سەریان خستن بۆ دۆڵی عاخۆر.
\v 25 ئینجا یەشوع گوتی: «چۆن لێت تێکداین، یەزدانیش ئەمڕۆ ئاوا لێت تێکبدات.»
\p ئینجا هەموو نەوەی ئیسرائیل ئەویان بەردباران کرد و ئەوانەی دیکەیان بەردباران کرد و سووتاندیانن،
\v 26 کۆمەڵە بەردێکی گەورەیان لەسەر عاخان کەڵەکە کرد کە هەتا ئەمڕۆش لەوێیە. ئینجا جۆشی تووڕەییەکەی یەزدان دامرکایەوە، بۆیە ئەو شوێنەش هەتا ئەمڕۆ بە دۆڵی عاخۆر\f + \fr 7:26 \ft \tl عاخۆر‏\tl* وشەیەکی عیبرییە بە واتای تێکدان.‏\f* ناودەبردرێت.
\c 8
\s1 وێرانکردنی شاری عای
\p 
\v 1 ئینجا یەزدان بە یەشوعی فەرموو: «مەترسە و ورە بەرمەدە. هەموو جەنگاوەرەکان لەگەڵ خۆت ببە و هەستە سەربکەوە بۆ عای، ببینە من پاشاکەی و گەلەکەی و شارەکەی و خاکەکەیم داوەتە دەست تۆ.
\v 2 ئەوەی بە ئەریحا و پاشاکەیتان کرد، بە عای و پاشاکەی بکەن، بەڵام دەستکەوتەکان و ئاژەڵە ماڵییەکانی بۆ خۆتان تاڵان بکەن. لە پشتییەوە بۆسەیەک بۆ شارەکە بنێوە.»
\p 
\v 3 جا یەشوع و هەموو جەنگاوەرەکانی سوپا هەستان بۆ ئەوەی بەسەر عایدا بدەن، یەشوع سی هەزار جەنگاوەری قارەمانی هەڵبژارد و بە شەو ناردنی،
\v 4 فەرمانی پێ کردن و گوتی: «وریابن، ئێوە لە پشتەوە بۆسە بۆ شارەکە دەنێنەوە و زۆر لە شارەکە دوور مەکەونەوە و هەمووتان لە ئامادەباشیدا بن.
\v 5 منیش لەگەڵ هەموو ئەم گەلە لە شارەکە نزیک دەبینەوە و ئیتر کە ئەوان دێنە دەرەوە بۆمان، ئێمە وەک یەکەم جار لەبەردەمیاندا هەڵدێین و
\v 6 ئەوان بەدوامان دەکەون هەتا لە شارەکە دووریان دەخەینەوە، چونکە دەڵێن: ”ئەوەتا وەک یەکەم جار لەبەردەممان هەڵدێن،“ جا کاتێک لەبەردەمیان هەڵدێین،
\v 7 ئێوەش لە بۆسەکەوە دێنە دەرەوە و دەست بەسەر شارەکەدا دەگرن و یەزدانی پەروەردگارتان دەیدات بە دەستتانەوە.
\v 8 کاتێک شارەکە دەگرن، ئاگری تێبەر دەدەن. ئەوە بکەن کە یەزدان فەرمانی پێ کردوون. سەیر بکەن ئەوە فەرمانی منە بۆ ئێوە.»
\p 
\v 9 ئینجا یەشوع ناردنی و ئەوانیش بۆ شوێنی بۆسەکە ڕۆیشتن و لەنێوان بێت‌ئێل و عای، لە ڕۆژئاوای عای مانەوە. ئەو شەوە یەشوع لە ناوەڕاستی گەل مایەوە.
\p 
\v 10 بۆ بەیانی یەشوع زوو لە خەو هەستا و گەلەکەی کۆکردەوە و خۆی و پیرانی ئیسرائیل لەپێش گەلەوە سەرکەوتن بۆ عای.
\v 11 هەروەها هەموو ئەو لەشکرەی لەگەڵیدا بوون سەرکەوتن و چوونە پێشەوە و هاتنە بەرامبەر شارەکە، لە باکووری عای چادریان هەڵدا و دۆڵەکە لەنێوان ئەوان و عای بوو.
\v 12 یەشوع نزیکەی پێنج هەزار پیاوی نارد و لەنێوان بێت‌ئێل و عای، لە ڕۆژئاوای عای لە بۆسەدا داینان.
\v 13 ئیتر گەل، واتا هەموو لەشکرەکە کە لە باکووری شارەکە بوو لەگەڵ ئەوانەی کە لە بۆسەکەی ڕۆژئاوای شارەکە بوون، جێگیر بوون، یەشوعیش ئەو شەوە چووە ناوەڕاستی دۆڵەکە.
\p 
\v 14 کاتێک پاشای عای ئەمەی بینی، خۆی و پیاوانی شارەکە بەیانی زوو بە پەلە هاتنە دەرەوە بۆ بەرەنگاربوونەوەی ئیسرائیل لە بەرزاییەک کە دەیڕوانییە عەراڤا\f + \fr 8:14 \ft عەراڤا شیوێک بوو لە دەریاچەی جەلیلەوە هەتا دەریای مردوو.‏\f*، بەڵام پاشا نەیدەزانی کە لە پشت شارەکەوە بۆسەیەکی بۆ نراوەتەوە.
\v 15 یەشوع لەگەڵ هەموو ئیسرائیل وایان پیشان دا کە شکستیان خواردوو و بە ڕێگای چۆڵەوانیدا هەڵاتن.
\v 16 لەنێو هەموو خەڵکی شاری عای بانگەواز بڵاو بووەوە کە دوایان بکەون، ئەوانیش دوای یەشوع کەوتن و لە شارەکە دوور کەوتنەوە.
\v 17 یەک پیاو لە عای یان لە بێت‌ئێل نەما کە بەدوای ئیسرائیل نەکەوتبێت. شارەکەیان بە کراوەیی بەجێهێشت و بەدوای ئیسرائیل کەوتن.
\p 
\v 18 ئینجا یەزدان بە یەشوعی فەرموو: «ڕمەکەی دەستت ڕووەو عای بگرە، چونکە من دەیدەمە دەستتەوە.» یەشوعیش ئەو ڕمەی بە دەستیەوە بوو ڕووەو شارەکەی کرد.
\v 19 کاتێک دەستی درێژکرد ئەوانەی لە بۆسەکە بوون بە پەلە لە جێی خۆیان هەستان و ڕایانکرد و چوونە ناو شارەکەوە و گرتیان و بە پەلە سووتاندیان.
\p 
\v 20 پیاوەکانی عای ئاوڕیان دایەوە و تەماشایان کرد وا دووکەڵی شارەکە بۆ ئاسمان بەرز بووەتەوە و هیچ جێیەکیش نییە بۆی هەڵبێن، نە بەملا و نە بەولا، ئیسرائیلییەکانیش کە بۆ چۆڵەوانی ڕایاندەکرد بەسەر ڕاونەرەکاندا هەڵگەڕانەوە.
\v 21 جا کە یەشوع و هەموو ئیسرائیل بینییان بۆسەکە شارەکەی گرتووە و دووکەڵی شارەکە بەرز بووەتەوە، گەڕانەوە و لە پیاوەکانی عاییان دا.
\v 22 جەنگاوەران لەناو بۆسەکەش لە شارەکەوە بۆ پەلاماردانیان هاتنە دەرەوە و پیاوەکانی عای کەوتنە نێوان ئیسرائیلییەکان. ئەمان لەم لاوە و ئەوان لەولاوە، ئینجا لێیان دان تاکو کەسیان لێ نەما هەڵبێت و دەرباز بێت.
\v 23 بەڵام پاشای عاییان بە زیندوویی دەستگیر کرد و بردیانە بەردەم یەشوع.
\p 
\v 24 پاش ئەوەی ئیسرائیل لە کوشتنی هەموو پیاوەکانی عای بوونەوە کە لە کێڵگە و چۆڵەوانیدا دوایان کەوتبوون هەتا قڕیان بکەن، هەموو ئیسرائیلییەکان گەڕانەوە ناو شار و هەموو ئەو دانیشتووانانەیان بە شمشێر کوشت کە لەوێ مابوونەوە.
\v 25 سەرجەم دانیشتووانی عای، هەموو ئەوانەی لەو ڕۆژەدا کەوتن لە پیاو و لە ژن، دوازدە هەزار کەس بوون.
\v 26 یەشوعیش ئەو دەستەی کە ڕمەکەی پێ درێژکردبوو نەیگەڕاندەوە دواوە هەتا سەرجەم دانیشتووانی عای قڕ بوون\f + \fr 8:26 \ft قڕ بوون: لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f*.
\v 27 بەڵام نەوەی ئیسرائیل ئاژەڵی ماڵی و دەستکەوتی ئەو شارەیان بۆ خۆیان تاڵان کرد، بەگوێرەی فەرمایشتی یەزدان کە فەرمانی بە یەشوع کردبوو.
\p 
\v 28 ئینجا یەشوع عایی سووتاند\f + \fr 8:28 \ft یەشوع عایی سووتاند: واتا یەشوع و پیاوەکانی شاری عاییان سووتاند.‏\f* و کردییە گردێکی وێرانی هەتاهەتایی، هەتا ئەمڕۆش هەروا ماوەتەوە.
\v 29 هەروەها لاشەی پاشای عایی هەتا ئێوارە لەسەر دار هەڵواسی، لە کاتی ئاوابوونی خۆر یەشوع فەرمانی دا و لاشەکەیان هێنا خوارەوە و لەبەردەم دەروازەی شارەکە فڕێیان دا و کۆمەڵە بەردێکی گەورەیان لەسەر کەڵەکە کرد کە هەتا ئەمڕۆ ماوەتەوە.
\s1 تازەکردنەوەی پەیمانەکە لە کێوی عێبال
\p 
\v 30 ئینجا یەشوع قوربانگایەکی بۆ یەزدانی پەروەردگاری ئیسرائیل لە کێوی عێبال بنیاد نا.
\v 31 هەروەک موسای بەندەی یەزدان فەرمانی بە نەوەی ئیسرائیل کردبوو، بەپێی ئەوەی لە پەڕتووکی تەوراتی موسادا نووسراوە، قوربانگایەک لە بەردی نەتاشراو، کە ئامێری ئاسنی بەسەردا بەرز نەکرابووەوە، قوربانی سووتاندنیان بۆ یەزدان سەرخستە سەری و قوربانی هاوبەشییان\f + \fr 8:31 \ft قوربانی هاوبەشی: ئەم قوربانییە هاودەمی قوربانی سووتاندن بوو. تەنها یەک کەس هەڵدەستا بە دابینکردنی ئەم قوربانییە، بەڵام لەگەڵ خەڵکی دیکە بەشی زۆری ئەم قوربانییەیان لەبەردەم خودا دەخوارد وەک هێمایەک بۆ پێکەوە ژیان. بڕوانە \xt لێڤییەکان 7‏:11‏-15.‏\xt*\ft ‏\f* سەربڕی.
\v 32 لەوێ یەشوع لەبەرچاوی نەوەی ئیسرائیل وێنەیەکی لەو فێرکردنە نووسییەوە کە موسا نووسیبووی.
\v 33 هەموو ئیسرائیلیش نامۆ و هاوڵاتی وەک یەک، لەگەڵ پیر و کوێخا و دادوەریان لەتەنیشت سندوقەکەوە، لەم لا و ئەو لاوە بەرامبەر بە کاهینە لێڤییەکان هەڵگرانی سندوقی پەیمانی یەزدان وەستان، نیوەیان بەلای کێوی گەریزیم و نیوەکەی دیکەیان بەلای کێوی عێبال، وەک چۆن لەوەو پێش موسای بەندەی یەزدان فەرمانی دابوو، کاتێک فەرمانی دا بۆ داواکردنی بەرەکەت بۆ گەلی ئیسرائیل.
\p 
\v 34 پاشان هەموو وشەکانی ئەو فێرکردنەی خوێندەوە، بەرەکەت و نەفرەت، بەگوێرەی هەموو ئەوەی لە پەڕتووکی تەوراتدا نووسرابوو.
\v 35 وشەیەک نەبوو لە هەموو ئەو شتانەی کە موسا فەرمانی پێ کردبوو، کە یەشوع نەیخوێنێتەوە، لەبەردەم هەموو کۆمەڵی ئیسرائیلدا بە ئافرەت و منداڵ و ئەو نامۆیانەش کە لەنێویاندا بوو.
\c 9
\s1 گبعۆنییەکان یەشوع فریودەدەن
\p 
\v 1 ئینجا کاتێک هەموو ئەو پاشایانەی لە بەری ڕۆژئاوای ڕووباری ئوردونن، لە ناوچە شاخاوییەکان و زوورگەکانی\f + \fr 9:1 \ft زوورگ: لە تەپۆڵکە بەرزترە، هەروەک بەرزاییەکانی زوورگەزراو لە کوردستان.‏\f* ڕۆژئاوای و لە هەموو کەنارەکانی دەریای سپی ناوەڕاست\f + \fr 9:1 \ft دەریای سپی ناوەڕاست: عیبری دەریای مەزن.‏\f* تاکو لوبنان، حیتی و ئەمۆری و کەنعانی و پریزی و حیڤی و یەبوسییەکان ئەوەیان بیستەوە،
\v 2 بە یەک دەنگ پێکەوە کۆبوونەوە بۆ جەنگ لە دژی یەشوع و ئیسرائیل.
\p 
\v 3 بەڵام دانیشتووانی گبعۆن کە بیستیانەوە یەشوع چی بە ئەریحا و عای کردووە،
\v 4 بە زۆرزانییەوە کاریان کرد و چوون وەک شاندێک\f + \fr 9:4 \ft شاند: وەفد.‏\f* خۆیان پیشان دا، گوێدرێژەکانیان لە جەواڵە کۆن و مەشکە شەرابی کۆن و دڕاو و بەستراو بارکرد،
\v 5 پێڵاوی دڕاو و پینەکراویان لەپێکرد و جلی شڕیان لەبەرکرد، هەموو نانی ئازووقەکەیان وشک و کەڕووی هەڵهێنابوو.
\v 6 ئینجا بەرەو لای یەشوع چوون بۆ ئۆردوگاکە کە لە گلگال بوو، بە یەشوع و پیاوانی ئیسرائیلیان گوت: «لە وڵاتێکی دوورەوە هاتووین و ئێستا پەیمانمان لەگەڵدا ببەستن.»
\p 
\v 7 پیاوانی ئیسرائیلیش بە حیڤییەکانیان گوت: «لەوانەیە ئێوە دانیشتووانی ئەم ناوچەیە بن، ئیتر چۆن پەیمانتان لەگەڵدا ببەستین؟»
\p 
\v 8 ئەوانیش بە یەشوعیان گوت: «ئێمە خزمەتکاری تۆین.»
\p یەشوعیش لێی پرسین: «ئێوە کێن و لەکوێوە هاتوون؟»
\p 
\v 9 ئەوانیش وەڵامیان دایەوە: «خزمەتکارەکانت لە وڵاتێکی زۆر دوورەوە هاتوون، لەبەر ناوی یەزدانی پەروەردگارت، چونکە ئێمە گوێمان لە هەواڵی یەزدانی پەروەردگارت بوو و لەبارەی هەموو ئەو کارانەی کە بەسەر میسری هێنا،
\v 10 هەموو ئەوەی بە دوو پاشای ئەمۆرییەکانی کرد، ئەوانەی لەوبەری ڕووباری ئوردون لەلای ڕۆژهەڵات بوون، سیحۆنی پاشای حەشبۆن و عۆگی پاشای باشان ئەوەی لە عەشتارۆت بوو.
\v 11 جا پیرانمان و هەموو دانیشتووانی خاکەکەمان قسەیان لەگەڵ کردین و گوتیان: ”ئازووقەی ڕێگا لەگەڵ خۆتان ببەن و بڕۆن بۆ بینینیان، پێیان بڵێن: ئێمە خزمەتکاری ئێوەین و ئێستاش پەیمانمان لەگەڵدا ببەستن.“
\v 12 ئەو ڕۆژەی کە بەڕێکەوتین بۆ ئەوەی بێین بۆ لای ئێوە، لە ماڵەوە نانەکەمان بە گەرمی هێنا، بەڵام تەماشا بکە، ئێستا وشکە و کەڕووی هەڵهێناوە.
\v 13 ئەمەش مەشکەی شەرابەکانمانە کە بە نوێتی پڕمان کردن و وا دڕاون، ئەمەش جلوبەرگ و پێڵاوەکانمانە کە لەبەر دووری ڕێگاکە کۆن بوون.»
\p 
\v 14 جا پیاوانی ئیسرائیل لە ئازووقەکەیان وەرگرت\f + \fr 9:14 \ft مەبەست ئەوەیە نانەکەیان وەک بەڵگە وەرگرت و بڕوایان پێیان کرد.‏\f*، بەڵام پرسیان بە یەزدان نەکرد.
\v 15 یەشوعیش پەیمانی ئاشتی لەگەڵیاندا بەست کە بە زیندوویی بیانهێڵێتەوە، ڕابەرەکانی گەلیش سوێندیان بۆ خواردن.
\p 
\v 16 پاش تێپەڕبوونی سێ ڕۆژ بەسەر پەیمانەکەدا، بیستیانەوە کە گبعۆنییەکان لێیان نزیکن و دانیشتووی ئەو ناوچەیەن.
\v 17 جا نەوەی ئیسرائیل بەڕێکەوتن و لە ڕۆژی سێیەمدا هاتنە شارەکانیان، ئەمانە شارەکانیان بوون: گبعۆن، کەفیرا، بئێرۆت و قیریەت یەعاریم.
\v 18 نەوەی ئیسرائیلیش لێیان نەدان، چونکە ڕابەرەکانی گەل سوێندیان بە یەزدانی پەروەردگاری ئیسرائیل بۆ خواردبوون.
\p لەبەر ئەوە هەموو گەل بۆڵەبۆڵیان لە دژی ڕابەرەکان کرد،
\v 19 جا هەموو ڕابەرەکان بە هەموو گەلیان گوت: «ئێمە بە یەزدانی پەروەردگاری ئیسرائیل سوێندمان بۆ خواردن و ئێستاش ناتوانین دەستیان لێ بدەین،
\v 20 ئەمەیان بۆ دەکەین و بە زیندوویی دەیانهێڵینەوە، بۆ ئەوەی تووڕەیی بەسەرماندا نەبارێت، بەهۆی ئەو سوێندەی کە بۆمان خواردوون.»
\v 21 هەروەها ڕابەرەکان پێیان گوتن: «بە زیندوویی دەمێننەوە و بۆ هەموو گەل دەبن بە داربڕ و ئاوکێش.» بەم شێوەیە ڕابەرەکان بەڵێنیان پێدابوون.
\p 
\v 22 ئینجا یەشوع گبعۆنییەکانی بانگکرد و پێی گوتن: «بۆچی فریوتان داین و گوتتان: ”ئێمە زۆر لە ئێوەوە دوورین،“ ئێوە وا دانیشتووانی ئەم ناوەن؟
\v 23 ئێستا ئێوە نەفرەت لێکراون، کۆیلە و داربڕ و ئاوکێشتان لێ نابڕێت بۆ ماڵی خودام.»
\p 
\v 24 ئەوانیش وەڵامی یەشوعیان دایەوە گوتیان: «خزمەتکارەکانت هەموو ئەو هەواڵەیان بیستووەتەوە کە یەزدانی پەروەردگارت فەرمانی بە موسای بەندەی کردبوو کە هەموو خاکەکەتان بداتێ و هەموو دانیشتووانی خاکەکەش لەبەردەمتان لەناو ببات. ئێمەش لەبەر گیانی خۆمان زۆر لە ئێوە ترساین و ئەم کارەمان کرد،
\v 25 ئێستاش ئەوەتا لەبەردەستی ئێوەداین و چی بە باش و ڕاست دەزانن ئەوەمان لەگەڵدا بکەن.»
\p 
\v 26 یەشوعیش ئاوای لێکردن و لە دەست نەوەی ئیسرائیل ڕزگاری کردن و نەیانکوشتن.
\v 27 لەو ڕۆژەشدا یەشوع گبعۆنییەکانی کردە داربڕ و ئاوکێش بۆ کۆمەڵ و بۆ قوربانگای یەزدان، هەتا ئەمڕۆش ئەوە کاریانە لەو شوێنەی یەزدان هەڵیدەبژێرێت.
\c 10
\s1 خۆر بەسەر گبعۆنەوە بەردەوامە
\p 
\v 1 کاتێک ئەدۆنی سەدەقی پاشای ئۆرشەلیم بیستییەوە کە یەشوع شاری عایی گرتووە و بە تەواوی قڕی کردووە\f + \fr 10:1 \ft قڕی کردووە: لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت، لێرە و لە ئایەتەکانی 28، 35، 37، 39، 40.‏\f*، ئەوەی بە ئەریحا و پاشاکەی کرد، هەمان شتی بە عای و پاشاکەی کردووە، هەروەها دانیشتووانی گبعۆن پەیمانی ئاشتییان لەگەڵ ئیسرائیلدا بەستووە و لە نزیکیان دەژین،
\v 2 زۆر ترسا، چونکە گبعۆن شارێکی گەورە بوو، وەک یەکێک لە شارە پاشانشینەکان و لە عای گەورەتر بوو، هەموو پیاوەکانیشی پاڵەوان بوون.
\v 3 ئینجا ئەدۆنی سەدەقی پاشای ئۆرشەلیم بەدوای هۆهامی پاشای حەبرۆن و پیرامی پاشای یەرموت و یافیعی پاشای لاخیش و دەڤیری پاشای عەگلۆنیدا نارد و گوتی:
\v 4 «سەربکەون بۆ لام و یارمەتیم بدەن، لە گبعۆن دەدەین، چونکە پەیمانی ئاشتی لەگەڵ یەشوع و نەوەی ئیسرائیلدا بەستووە.»
\p 
\v 5 ئینجا هەر پێنج پاشای ئەمۆرییەکان کۆبوونەوە، پاشای ئۆرشەلیم و حەبرۆن و یەرموت و لاخیش و عەگلۆن، خۆیان و هەموو سوپاکانیان سەرکەوتن و چادریان هەڵدا لە دژی گبعۆن و جەنگیان لە دژی بەرپا کرد.
\p 
\v 6 جا دانیشتووانی گبعۆن بەدوای یەشوعدا ناردیان بۆ ئۆردوگاکە لە گلگال، پێیان گوت: «دەست لە خزمەتکارەکانت بەرمەدە. بە پەلە سەربکەوە بۆ لامان، ڕزگارمان بکە و یارمەتیمان بدە، چونکە هەموو پاشاکانی ئەمۆرییەکان ئەوانەی لە ناوچەی شاخاویدا نیشتەجێن لە دژمان گەلەکۆمەیان لێکردووین.»
\p 
\v 7 بۆیە یەشوع لە گلگالەوە لەگەڵ هەموو سوپاکە و جەنگاوەرە قارەمانەکان سەرکەوتن.
\v 8 یەزدانیش بە یەشوعی فەرموو: «لێیان مەترسە، چونکە ئەوانەم داوەتە دەست تۆ، کەسیان ناتوانێت لەبەردەمت ڕابوەستێت.»
\p 
\v 9 یەشوع بە درێژایی ئەو شەوە لە گلگالەوە سەرکەوت و لەناکاو بۆیان هات.
\v 10 یەزدانیش لەبەردەم ئیسرائیلدا سەری لێ شێواندن، لە گبعۆن بە تەواوی شکستی دان و بە ڕێگای هەورازی بێت‌حۆرۆندا ڕاوی نان، هەتا عەزێقا و مەقێدا لێیدان.
\v 11 هەروەها کاتێک لەبەردەم ئیسرائیلدا هەڵدەهاتن و لە نشێوەکەی بێت‌حۆرۆن بوون، یەزدان لە ئاسمانەوە بە تەرزەی گەورە لێیدان هەتا گەیشتنە عەزێقا و مردن. ئەوانەی کە بە تەرزە مردن زیاتر بوون لەوانەی کە نەوەی ئیسرائیل بە شمشێر کوشتیانن.
\p 
\v 12 لەو ڕۆژەدا کە یەزدان ئەمۆرییەکانی دایە دەست نەوەی ئیسرائیل، یەشوع لەگەڵ یەزداندا دوا، لەبەرچاوی ئیسرائیلدا گوتی:
\q1 «ئەی خۆر بەسەر گبعۆنەوە ڕابوەستە و
\q2 ئەی مانگ بەسەر دۆڵی ئەیالۆنەوە.
\q1 
\v 13 جا خۆر ڕاوەستا و
\q2 مانگیش وەستا
\q2 هەتا گەل تۆڵەیان لە دوژمنەکانیان سەندەوە.»
\m ئایا ئەمە لە پەڕتووکی یاشاردا\f + \fr 10:13 \ft پەڕتووکی یاشار: دەشێت کۆکراوەی هەڵبەستە جەنگییەکان بووبێت، هەروەها لە \xt دووەم ساموئێل 1‏:18‏\xt*\ft ‏ دەقێکی دیکە لەم پەڕتووکە وەرگێڕاوە.‏\f* نەنووسراوە؟
\p جا خۆر لەناو جەرگەی ئاسماندا ڕاوەستا و بۆ ماوەی یەک ڕۆژی تەواو لە ئاوابوون پەلەی نەکرد.
\v 14 وەک ئەو ڕۆژە قەت نەبووە، نە لەپێشی و نە لەپاشی کە یەزدان ئاوا گوێ لە دەنگی کەسێک بگرێت، چونکە یەزدان بۆ پاڵپشتی ئیسرائیل دەجەنگا!
\p 
\v 15 ئینجا یەشوع و هەموو ئیسرائیل گەڕانەوە بۆ ئۆردوگاکە لە گلگال.
\s1 پێنج پاشاکە کوژران
\p 
\v 16 پێنج پاشاکەش هەڵاتن و لە ئەشکەوتێکدا لە مەقێدا خۆیان شاردەوە.
\v 17 جا بە یەشوع ڕاگەیەنرا و گوترا کە پێنج پاشاکە لە ئەشکەوتێکدا لە مەقێدا خۆیان شاردووەتەوە،
\v 18 یەشوعیش گوتی: «بەردی گەورە بۆ سەر دەمی ئەشکەوتەکە تل بکەنەوە و چەند پیاوێکی بەدیارەوە دابنێن بۆ چاودێرییان.
\v 19 ئێوەش مەوەستن، بەڵکو دوای دوژمنەکانتان بکەون و لە پشتەوە لێیان بدەن، مەهێڵن بچنە ناو شارەکانیانەوە، چونکە یەزدانی پەروەردگارتان ئەوانی داوەتە دەستتان.»
\p 
\v 20 ئینجا کە یەشوع و نەوەی ئیسرائیل تەواو بوون لە لێدانیان بە گورزێکی جەرگبڕ هەتا لەناوچوون و ئەوانەی لێیان هەڵاتن چوونە ناو شارە قەڵابەندەکانەوە،
\v 21 هەموو سوپا بە سەلامەتی گەڕانەوە بۆ لای یەشوع بۆ ئۆردوگاکە لە مەقێدا. کەس نەبوو لە دژی نەوەی ئیسرائیل زمان درێژ بکات.
\p 
\v 22 ئینجا یەشوع گوتی: «دەمی ئەشکەوتەکە بکەنەوە و ئەو پێنج پاشایەم لە ئەشکەوتەکەوە بۆ بهێنە دەرەوە.»
\v 23 ئەوانیش بەم جۆرەیان کرد و ئەو پێنج پاشایەیان لە ئەشکەوتەکەوە بۆ هێنایە دەرەوە، پاشای ئۆرشەلیم و حەبرۆن و یەرموت و لاخیش و عەگلۆن.
\v 24 جا کە پاشاکانیان بۆ یەشوع هێنایە دەرەوە، یەشوع هەموو پیاوانی ئیسرائیلی بانگکرد و بە فەرماندەکانی سوپای گوت، ئەوانەی کە لەگەڵیدا ڕۆیشتبوون، «وەرنە پێشەوە و قاچتان لەسەر ملی ئەم پاشایانە دابنێن.» ئەوانیش چوونە پێش و قاچیان لەسەر ملیان دانا.
\p 
\v 25 ئینجا یەشوع پێی گوتن: «مەترسن و ورە بەرمەدەن، بەهێز و ئازابن، چونکە یەزدان ئاوا لە هەموو دوژمنەکانتان دەکات، کە ئێوە لە دژیان دەجەنگن.»
\v 26 ئینجا یەشوع لێیدان و کوشتنی، هەر پێنجیانی لەسەر پێنج دار هەڵواسی، هەتا ئێوارە بە هەڵواسراوی لەسەر دارەکان مانەوە.
\p 
\v 27 پاشان لە کاتی ئاوابوونی خۆر یەشوع فەرمانی دا، ئینجا لە دارەکان دایانگرتن و فڕێیان دانە ئەو ئەشکەوتەی خۆیان تێیدا شاردبووەوە، چەند بەردێکی گەورەشیان خستە سەر دەمی ئەشکەوتەکە، هەتا ئەمڕۆش لەوێن.
\p 
\v 28 هەر لەو ڕۆژەدا یەشوع\f + \fr 10:28 \ft یەشوع: واتا یەشوع لەگەڵ هەموو جەنگاوەرەکانی ئیسرائیل.‏\f* مەقێدای گرت و دایە بەر زەبری شمشێر، پاشاکەی و هەموو گیانێکی تێدا بە تەواوی قڕکرد. کەسی لێیان نەهێشت، ئەوەی بە پاشای مەقێدا کرد کە بە پاشای ئەریحای کردبوو.
\s1 گرتنی شارەکانی باشوور
\p 
\v 29 ئینجا یەشوع لەگەڵ هەموو ئیسرائیل لە مەقێداوە تێپەڕین بۆ لیڤنا، لە دژی لیڤنا جەنگان.
\v 30 یەزدان شارەکەی لەگەڵ پاشاکەی دایە دەست ئیسرائیل و بە شمشێر لێیدا، لە خۆی و هەموو گیانێک کە تێیدا بوو. کەسی لێیان نەهێشت، ئەوەی بە پاشاکەی کرد کە بە پاشای ئەریحای کردبوو.
\p 
\v 31 پاشان یەشوع لەگەڵ هەموو ئیسرائیلدا لە لیڤنایەوە تێپەڕین بۆ لاخیش، گەمارۆیان دا و لە دژی جەنگان.
\v 32 یەزدان لاخیشی دایە دەست ئیسرائیل، لە ڕۆژی دووەمدا یەشوع گرتی و دایە بەر زەبری شمشێر، لەگەڵ هەر گیانێکی زیندوو کە تێیدا بوو، هەروەک چۆن یەشوع بە لیڤنای کردبوو.
\v 33 لەو کاتەدا هۆرامی پاشای گەزەر بۆ پاڵپشتیکردنی لاخیش سەرکەوتبوو، بەڵام یەشوع لە خۆی و لەشکرەکەی دا و کەسی لێیان نەهێشت.
\p 
\v 34 ئینجا یەشوع و هەموو ئیسرائیل لە لاخیشەوە تێپەڕین بۆ عەگلۆن، گەمارۆیان دا و لە دژی جەنگان.
\v 35 هەر لەو ڕۆژەدا گرتیان و دایانە بەر زەبری شمشێر، هەر لەو ڕۆژەدا هەموو گیانێکی زیندوویان تێدا بە تەواوی قڕکرد، بە دەردی لاخیشیان برد.
\p 
\v 36 ئینجا یەشوع و هەموو ئیسرائیل لە عەگلۆنەوە سەرکەوتن بۆ حەبرۆن و لە دژی جەنگان،
\v 37 گرتیان و دایانە بەر زەبری شمشێر، لەگەڵ پاشاکەی و هەموو شارۆچکەکانی و هەموو گیانێکی زیندوو کە تێیدا بوو، کەسی لێیان نەهێشت، بە دەردی عەگلۆنیان برد، جا خۆی و هەموو گیانێکی زیندووی بە تەواوی قڕکرد کە تێیدا بوو.
\p 
\v 38 ئینجا یەشوع و هەموو ئیسرائیل گەڕانەوە بۆ دەڤیر و لە دژی جەنگان و
\v 39 گرتیان، خۆی و پاشاکەی و هەموو شارۆچکەکانی و دایانە بەر زەبری شمشێر و هەرچی گیانی زیندووی تێدابوو بە تەواوی قڕیان کرد، کەسی لێیان نەهێشت، دەڤیر و پاشاکەی بە دەردی حەبرۆن و پاشاکەی برد، هەروەک چی بە لیڤنا و پاشاکەی کردبوو.
\p 
\v 40 جا یەشوع هەموو خاکی ناوچە شاخاوییەکە و نەقەب و زوورگەکانی خۆرئاوا و قەدپاڵەکانی لەگەڵ هەموو پاشاکانیانی خستە ژێر ڕکێفی خۆی و کەسی لێیان نەهێشت، بەڵکو بە تەواوی هەموو هەناسەدانێکی لێ بڕی، هەروەک یەزدانی پەروەردگاری ئیسرائیل فەرمانی دابوو.
\v 41 یەشوع هەر لە قادێش بەرنێعەوە هەتا غەزە لێیدان، لە هەموو ناوچەی گۆشەن هەتا گبعۆن.
\v 42 یەشوع هەموو ئەو پاشایانە و خاکەکەیانی بە یەک جار گرت، چونکە یەزدانی پەروەردگاری ئیسرائیل بۆ پاڵپشتی ئیسرائیل جەنگا.
\p 
\v 43 ئینجا یەشوع لەگەڵ هەموو ئیسرائیلدا گەڕایەوە بۆ ئۆردوگاکە لە گلگال.
\c 11
\s1 بەزاندنی پاشاکانی باکوور
\p 
\v 1 ئینجا کاتێک یاڤینی پاشای حاچۆر ئەمەی بیستەوە، نێردراوی نارد بۆ لای یۆڤاڤی پاشای مادۆن و پاشای شیمرۆن و پاشای ئەکشاف و
\v 2 ئەو پاشایانەی لە باکوور لە چیان و لە دەشتایی عەراڤا خوارووی کینەرەت و لە زوورگەکانی خۆرئاوا و لە بەرزاییەکانی دۆرە لە ڕۆژئاوا،
\v 3 کەنعانییەکان لە ڕۆژهەڵات و ڕۆژئاوا، ئەمۆری و حیتی و پریزی و یەبوسییەکان لە ناوچە شاخاوییەکان و حیڤییەکانی بناری حەرمۆن لە خاکی میچپا.
\v 4 جا خۆیان و هەموو لەشکرەکانیان لەگەڵیان هاتنە دەرەوە، سوپایەکی گەورە وەک لمی کەناری دەریا، بە ئەسپ و گالیسکەیەکی زۆر زۆرەوە.
\v 5 ئینجا هەموو ئەو پاشایانە لە کاتی دیاریکراودا کۆبوونەوە و هاتن، لەلای جۆگەی مێرۆم چادریان هەڵدا بۆ ئەوەی لە دژی ئیسرائیل بجەنگن.
\p 
\v 6 یەزدانیش بە یەشوعی فەرموو: «لێیان مەترسە، چونکە سبەینێ لەم کاتەدا هەموویان بە کوژراوی فڕێدەدەمە بەردەم ئیسرائیل، جا دەماری پێی ئەسپەکانیان ببڕەوە و گالیسکەکانیان بە ئاگر بسووتێنە.»
\p 
\v 7 ئینجا یەشوع و هەموو جەنگاوەرەکان لەگەڵیدا لەناکاو لە نزیک جۆگەی مێرۆم هاتنە سەریان.
\v 8 یەزدانیش ئەوانی دایە دەست ئیسرائیل، ئەوانیش لێیان دان و دەریانپەڕاندن هەتا سەیدائی مەزن و میسرەفۆت مەیم و دۆڵی میچپا لە ڕۆژهەڵات، جا لێیان دان هەتا کەسیان لێیان نەهێشت.
\v 9 یەشوع ئەوەی پێکردن کە یەزدان پێی فەرموو، دەماری پێی ئەسپەکانی ئەوانی بڕی و گالیسکەکانی سووتاندن.
\p 
\v 10 ئینجا لەو کاتەدا یەشوع گەڕایەوە و شاری حاچۆری گرت و بە شمشێر لە پاشاکەی دا. پێشتر حاچۆر پایتەختی هەموو ئەو پاشایەتییانە بوو.
\v 11 هەموو گیانێک کە تێیدابوو دایانە بەر زەبری شمشێر، بە تەواوی قڕیان کردن\f + \fr 11:11 \ft لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f* و هەناسەیەکی تێدا نەما، حاچۆریشیان سووتاند.
\p 
\v 12 ئینجا یەشوع هەموو ئەو شارانەی کە پاشایان هەبوو بە پاشاکانیانەوە گرتی و دایە بەر زەبری شمشێر، بە تەواوی قڕی کردن، هەروەک موسای بەندەی یەزدان فەرمانی دابوو.
\v 13 بەڵام ئیسرائیل ئەو شارانەی نەسووتاند کە لەسەر گردەکان بوون، تەنها حاچۆر، یەشوع بە تەنها ئەوی سووتاند.
\v 14 نەوەی ئیسرائیل هەموو دەستکەوتەکانی ئەو شارانە و ئاژەڵە ماڵییەکانیان بۆ خۆیان تاڵان کرد. بەڵام هەموو دانیشتووانەکانیان دایە بەر شمشێر هەتا بە تەواوی لەناویانبردن، هیچ زیندووێکیان تێدا نەهێشتەوە.
\v 15 هەروەک یەزدان فەرمانی بە موسای بەندەی کردبوو، موساش ئاوا فەرمانی بە یەشوع کرد و یەشوعیش ئاوای کرد، هیچ شتێکی پشتگوێ نەخست، لە هەموو ئەوەی یەزدان فەرمانی بە موسا کردبوو.
\p 
\v 16 جا یەشوع هەموو ئەو خاکانەی گرت: ناوچە شاخاوییەکە و هەموو نەقەب و هەموو خاکی گۆشەن و زوورگەکانی خۆرئاوا و دەشتایی عەراڤا و چیاکانی ئیسرائیل و زوورگەکانی،
\v 17 لە کێوی حالاقەوە کە بەرەو سێعیر سەردەکەوێت هەتا بەعل‌گاد لە دۆڵی لوبنان لە بناری چیای حەرمۆن، هەموو پاشاکانیشی گرتن و لێیدان و کوشتنی.
\v 18 یەشوع ماوەیەکی زۆر لەگەڵ ئەو پاشایانەدا جەنگا،
\v 19 هیچ شارێک پەیمانی ئاشتیی لەگەڵ ئیسرائیلدا نەبەست، تەنها حیڤییەکانی دانیشتووی گبعۆن نەبێت، بەڵکو هەموویانی بە جەنگ گرت،
\v 20 چونکە یەزدان خۆی دڵیانی ڕەقکردبوو، هەتا لە جەنگدا بەرەنگاری ئیسرائیل ببنەوە، جا قڕ بکرێن و بەزەییان بەسەرەوە نەبێت، بەڵکو بە تەواوی لەناویان ببات، هەروەک یەزدان فەرمانی بە موسا کردبوو.
\p 
\v 21 لەو کاتەدا یەشوع چوو و عەناقییەکانی لە کێوی حەبرۆن و دەڤیر و عەناڤ و هەموو ناوچە شاخاوییەکانی یەهودا و هەموو ناوچە شاخاوییەکانی ئیسرائیل بنبڕ کرد. یەشوع لەگەڵ شارۆچکەکانیاندا بە تەواوی قڕی کردن.
\v 22 جا لە خاکی نەوەی ئیسرائیلدا عەناقییەکان نەمان، بەڵام هەندێکیان لە غەزە و گەت و ئەشدۆد مانەوە.
\v 23 ئینجا یەشوع هەموو خاکەکەی گرت، بەپێی هەموو ئەوەی یەزدان بە موسای فەرمووبوو، یەشوع بەگوێرەی بەش و هۆزەکانیان بە میرات بە ئیسرائیلی دا.
\p ئینجا خاکەکە لە جەنگ پشووی دا.
\c 12
\s1 لیستی ئەو پاشایانەی کە بەزین
\li4 
\v 1 ئەمانەش ئەو پاشایانەن کە نەوەی ئیسرائیل لێیان دان و دەستیان بەسەر خاکەکەیاندا گرت، لە بەری ڕۆژهەڵاتی ڕووباری ئوردون، لە دەربەندی ئەرنۆنەوە هەتا چیای حەرمۆن و هەموو دەشتایی عەراڤا بەرەو ڕۆژهەڵات:
\b
\li1 
\v 2 سیحۆنی پاشای ئەمۆرییەکان، کە لە حەشبۆن نیشتەجێ بوو،
\li2 حوکمڕان بوو لەسەر عەرۆعێر کە کەناری دەربەندی ئەرنۆنە، ناوەڕاستی دۆڵەکە، نیوەی گلعاد هەتا دۆڵی یەبۆق کە سنووری عەمۆنییەکانە،
\li2 
\v 3 دەشتایی عەراڤا هەتا دەریاچەی جەلیل\f + \fr 12:3 \ft دەریاچەی جەلیل: عیبری: دەریای کینەرەت. بڕوانە \xt مەتا 4‏:18‏\xt*\ft ‏.‏\f* ڕووەو ڕۆژهەڵات، هەتا دەریای عەراڤا واتا دەریای مردوو\f + \fr 12:3 \ft دەریای مردوو: عیبری: دەریای خوێ.‏\f* بەرەو ڕۆژهەڵات، ڕێگای بێت‌یەشیمۆت، ئینجا بەرەو باشووری بناری پسگە.
\li1 
\v 4 سنوورەکانی عۆگی پاشای باشان، کە لە پاشماوەی ڕفائییەکانە\f + \fr 12:4 \ft ڕفائییەکان: خەڵکێکی زەبەلاح بوون.‏\f* و نیشتەجێی عەشتارۆت و ئەدرەعییە،
\li2 
\v 5 حوکمڕان بوو بەسەر چیای حەرمۆن و سەلخە و هەموو باشانەوە هەتا سنووری گەشووری و مەعکائییەکان و نیوەی گلعاد هەتا سنوورەکانی سیحۆنی پاشای حەشبۆن.
\b
\li4 
\v 6 موسای بەندەی یەزدان و نەوەی ئیسرائیل ئەوانیان شکاند. موسای بەندەی یەزدان بە میرات\f + \fr 12:6 \ft میرات: واتا موسا خاکەکەیانی بە میرات دایە ڕەئوبێنی و گادییەکان و نیوەی هۆزی مەنەشە.‏\f* دایە ڕەئوبێنی و گادییەکان و نیوەی هۆزی مەنەشە.
\b
\p 
\v 7 ئەمانەش ئەو پاشایانەی خاکەکەن کە یەشوع و نەوەی ئیسرائیل شکاندیانن، لە بەری ڕۆژئاوای ڕووباری ئوردون لە بەعل‌گاد لە دۆڵی لوبنانەوە هەتا کێوی حالاق کە بەرەو سێعیر سەردەکەوێت، یەشوعیش بەگوێرەی بەشەکانیان بە میرات دایە هۆزەکانی ئیسرائیل.
\v 8 ئەو خاکەی لە ناوچە شاخاوییەکان، زوورگەکانی خۆرئاوا، دەشتایی عەراڤا، بنارەکان، چۆڵەوانی و نەقەبدا بوو. ئەمەش خاکی حیتی، ئەمۆری، کەنعانی، پریزی، حیڤی و یەبوسییەکانە.
\b
\li4 ئەمانە ئەو پاشایانەن:
\b
\li1 
\v 9 پاشای ئەریحا
\li1 پاشای عای کە لەلای بێت‌ئێلە
\li1 
\v 10 پاشای ئۆرشەلیم
\li1 پاشای حەبرۆن
\li1 
\v 11 پاشای یەرموت
\li1 پاشای لاخیش
\li1 
\v 12 پاشای عەگلۆن
\li1 پاشای گەزەر
\li1 
\v 13 پاشای دەڤیر
\li1 پاشای گەدەر
\li1 
\v 14 پاشای حۆرما
\li1 پاشای عەراد
\li1 
\v 15 پاشای لیڤنا
\li1 پاشای عەدولام
\li1 
\v 16 پاشای مەقێدا
\li1 پاشای بێت‌ئێل
\li1 
\v 17 پاشای تەپووەح
\li1 پاشای حێفەر
\li1 
\v 18 پاشای ئەفێق
\li1 پاشای لەشارۆن
\li1 
\v 19 پاشای مادۆن
\li1 پاشای حاچۆر
\li1 
\v 20 پاشای شیمرۆن‌مەرۆن
\li1 پاشای ئەکشاف
\li1 
\v 21 پاشای تەعنەک
\li1 پاشای مەگیدۆ
\li1 
\v 22 پاشای قەدەش
\li1 پاشای یۆقنەعام لە کارمەل
\li1 
\v 23 پاشای دۆر لە بەرزاییەکانی دۆر
\li1 پاشای گۆییم لە گلگال
\li1 
\v 24 پاشای تیرزە.
\b
\li4 هەموو پاشاکان سی و یەک پاشا بوون.
\c 13
\s1 خاکی دەستبەسەردانەگیراو
\p 
\v 1 کاتێک یەشوع پیر بوو و چووە ساڵەوە، یەزدانیش پێی فەرموو: «تۆ پیر بوویت و چوویتە ساڵەوە، هێشتا چەند خاکێکی زۆریش ماوە دەستی بەسەردا بگیردرێت.
\b
\li4 
\v 2 «ئەمە ئەو خاکەیە کە ماوەتەوە:
\b
\li1 «هەموو ناوچەکانی فەلەستی و گەشوورییەکان،
\v 3 لە ڕووباری شیحۆرەوە کە لە ڕۆژهەڵاتی میسرە هەتا سنووری عەقرۆن لە باکوور کە سەر بە کەنعانییەکانە، سنووری پێنج ڕابەرە\f + \fr 13:3 \ft لێرەدا بە وشەی زمانی کۆنی فەلەستی (سێرێن) هاتووە، واتا هەر یەکێک لەو پێنج شارەی فەلەستییەکان ڕابەری خۆی هەبوو، کە لە هەمان کاتدا سەرکردەی لەشکری شارەکەش بووە.‏\f* فەلەستییەکان، لە غەزە، ئەشدۆد، ئەسقەلان،
\li1 گەت و عەقرۆن، عەقرۆنی خاکی عەڤییەکان.
\v 4 لە باشوورەوە:
\li1 هەموو خاکی کەنعانییەکان و عارا کە هی سەیدائییەکانە هەتا ئەفێق و سنووری ئەمۆرییەکان،
\li1 
\v 5 خاکی جوبەیلییەکان\f + \fr 13:5 \ft شاری جوبەیل شارێکی کۆنە کە مێژووەکەی دەگەڕێتەوە بۆ 7000 لەمەوپێش، ئەمرۆ بە دووری 38 کیلۆمەتر دەکەوێتە باکووری بەیروت.‏\f*
\li1 و هەموو ناوچەکانی لوبنان بەرەو ڕۆژهەڵات، لە بەعل‌گاد بناری چیای حەرمۆنەوە هەتا دەروازەی حەمات.
\b
\p 
\v 6 «من خۆم هەموو دانیشتووانی چیا لە لوبنانەوە هەتا میسرەفۆت مەیم، هەموو سەیدائییەکان لەبەردەم نەوەی ئیسرائیلدا دەردەکەم. دەبێت تۆش ئەم خاکانە بە تیروپشک بە میرات بۆ ئیسرائیل دابەش بکەیت، بەو شێوەیەی فەرمانم پێ کردیت،
\v 7 ئێستاش بەسەر نۆ هۆز و نیوەی هۆزی مەنەشەدا بە میرات دابەشی بکە.»
\s1 دابەشکردنی خاکی ڕۆژهەڵاتی ڕووباری ئوردون
\li4 
\v 8 ڕەئوبێنی و گادییەکان بەشی خۆیان لەگەڵ نیوەکەی دیکەی مەنەشە وەرگرت کە موسای بەندەی یەزدان بەری ڕۆژهەڵاتی ڕووباری ئوردونی پێدابوون.
\li1 
\v 9 لە عەرۆعێرەوە کە لە کەناری دەربەندی ئەرنۆنە و لە شارۆچکەکەی ناوەڕاستی دەربەندەکەوە، هەموو دەشتە بەرزەکەی مادەبا هەتا دیڤۆن،
\v 10 هەموو شارۆچکەکانی سیحۆنی پاشای ئەمۆرییەکان کە لە حەشبۆنەوە هەتا سنووری عەمۆنییەکان فەرمانڕەوایەتی دەکرد.
\li1 
\v 11 هەروەها گلعاد و سنوورەکانی گەشووری و مەعکائییەکان، هەموو چیای حەرمۆن، هەموو باشان هەتا سەلخە لەخۆ دەگرت،
\v 12 واتا هەموو شانشینی عۆگ لە باشان کە لە عەشتارۆت و ئەدرەعی پاشایەتی دەکرد، ئەویش لە پاشماوەی ڕفائییەکان مابووەوە کە موسا کاتی خۆی لێیدان و دەریکردن.
\v 13 نەوەی ئیسرائیل گەشوورییەکان و مەعکائییەکانیان دەرنەکرد، ئیتر هەتا ئەمڕۆش گەشووری و مەعکائی لەنێو ئیسرائیلدا نیشتەجێن.
\b
\li1 
\v 14 بەڵام موسا میراتی بە هۆزی لێڤی نەدا، لەبەر ئەوەی قوربانییە بە ئاگرەکانی یەزدانی پەروەردگاری ئیسرائیل میراتی ئەوانە، هەروەک یەزدان بە موسای فەرموو.
\b
\li4 
\v 15 ئەو خاکانەی موسا بە هۆزی نەوەی ڕەئوبێنی دابوو، بەگوێرەی خێڵەکانیان، ئەمانە بوون:
\li1 
\v 16 سنووریان لە عەرۆعێرەوە کە لەسەر کەناری دەربەندی ئەرنۆنە و لە شارۆچکەکەی ناوەڕاستی دەربەندەکەوە، هەموو دەشتە بەرزەکە لە مادەبایەوە
\v 17 هەتا شاری حەشبۆن و هەموو شارۆچکەکانی کە لە دەشتە بەرزەکەیە، کە دیڤۆن، بامۆت‌بەعل، بێت‌بەعل‌مەعۆن،
\v 18 یەهەچ، قەدێمۆت، مێفەعەت،
\v 19 قیریاتەیم، سیڤما، چەرەت شەحەر لەسەر کێوەکەی نێو دۆڵەکە،
\v 20 بێت‌پەعۆر، بنارەکانی پسگە، بێت‌یەشیمۆت لەخۆ دەگرێت،
\v 21 هەموو شارۆچکەکانی دەشتە بەرزەکە و هەموو شانشینی سیحۆنی پاشای ئەمۆرییەکان کە لە حەشبۆن فەرمانڕەوایەتی دەکرد. موسا کاتی خۆی سیحۆنی لەگەڵ سەرۆکەکانی میدیاندا شکاندبوو، واتا ئاڤی، ڕاقەم، چوور، حوور و ڕێڤەع، میرە هاوپەیمانەکانی سیحۆن کە لەو خاکەدا دەژیان.
\v 22 نەوەی ئیسرائیل بەلعامی کوڕی بەعۆری فاڵگرەوەشیان بە شمشێر لەگەڵ کوژراوەکانیان کوشت.
\li4 
\v 23 جا سنووری نەوەی ڕەئوبێن کەناری ڕووباری ئوردون بوو. ئەمە میراتی نەوەی ڕەئوبێنە بەگوێرەی خێڵەکانیان، شارۆچکە و گوندەکانیان.
\b
\li4 
\v 24 ئەو خاکانەی موسا بە هۆزی نەوەی گادی دابوو، بەگوێرەی خێڵەکانیان، ئەمانە بوون:
\li1 
\v 25 سنوورەکانیان یەعزێر و هەموو شارۆچکەکانی گلعاد و نیوەی خاکی عەمۆنییەکان هەتا عەرۆعێر کە لە نزیک ڕەبەیە،
\v 26 لە شاری حەشبۆنەوە هەتا ڕامای میچپا و بەتۆنیم، لە مەحەنەیمەوە هەتا سنووری دەڤیر،
\v 27 لە دۆڵەکەش بێت‌هارام، بێت‌نیمرا، سوکۆت و چافۆن، پاشماوەکەی شانشینی سیحۆنی پاشای حەشبۆن، بەری ڕۆژهەڵاتی ڕووباری ئوردون کە سنوورەکانی هەتا قەراغی دەریاچەی جەلیلە.
\li4 
\v 28 ئەمە میراتی نەوەی گادە بەگوێرەی خێڵەکانیان، شارۆچکە و گوندەکانیان.
\b
\li4 
\v 29 ئەو خاکانەی موسا دابوویە نیوەی هۆزی مەنەشە، واتا بۆ نیوەی نەوەی مەنەشە، بەگوێرەی خێڵەکانیان، ئەمانە بوون:
\li1 
\v 30 سنوورەکەیان لە مەحەنەیمەوە هەموو باشان، هەموو شانشینی عۆگی پاشای باشان، هەموو ئاوەدانییەکانی یائیر کە لە باشانە، شەست شارۆچکە و
\v 31 نیوەی گلعاد و عەشتارۆت و ئەدرەعی،
\li4 شارەکانی شانشینی عۆگ لە باشان بۆ نەوەی ماکیری کوڕی مەنەشە بوون، بۆ نیوەی نەوەی ماکیر بەگوێرەی خێڵەکانیان.
\b
\li4 
\v 32 ئەمە ئەوە بوو کە موسا لە دەشتەکانی مۆئاب لە بەری ڕۆژهەڵاتی ڕووباری ئوردون بەرامبەر ئەریحا کردی بە میرات.
\v 33 بەڵام موسا میراتی نەدا بە هۆزی لێڤی، چونکە یەزدانی پەروەردگاری ئیسرائیل میراتی ئەوان بوو، هەروەک بەڵێنی پێدابوون.
\c 14
\s1 دابەشکردنی خاکی ڕۆژئاوای ڕووباری ئوردون
\p 
\v 1 لە خاکی کەنعان، نەوەی ئیسرائیل ئەمەیان بۆ بوو بە میرات، ئەوەی ئەلعازاری کاهین و یەشوعی کوڕی نون و سەرۆکەکانی باوکانی هۆزەکانی نەوەی ئیسرائیل بەسەریاندا دابەشکردن وەک میرات.
\v 2 میراتەکەیان بە تیروپشک بوو بۆ نۆ هۆزەکە و نیو هۆزەکە، هەروەک یەزدان لە ڕێگەی موساوە فەرمانی دا.
\v 3 موسا میراتی دوو هۆزەکە و نیو هۆزەکەی لەوبەری ڕووباری ئوردوندا بەلای ڕۆژهەڵاتدا دابوو، بەڵام لەناو ئەواندا هیچ میراتی بە لێڤییەکان نەدا،
\v 4 چونکە نەوەی یوسف دوو هۆز بوون، مەنەشە و ئەفرایم. لە خاکەکەدا هیچ بەشێکیان بە لێڤییەکان نەدا، تەنها چەند شارۆچکەیەک نەبێت بۆ نیشتەجێبوون و دەوروبەری شارۆچکەکان، بۆ لەوەڕگای ڕەشەوڵاخ و مەڕوماڵاتیان.
\v 5 هەروەک یەزدان فەرمانی بە موسا کردبوو، نەوەی ئیسرائیل ئاوایان کرد و خاکەکەیان دابەش کرد.
\s1 حەبرۆن بە کالێب دەدرێت
\p 
\v 6 ئینجا نەوەی یەهودا لە گلگالدا چوونە پێش بۆ لای یەشوع، کالێبی کوڕی یەفونەی قەنیزی بە یەشوعی گوت: «تۆ ئەو قسەیە دەزانیت کە یەزدان لە قادێش بەرنێعدا لەبارەی من و تۆوە بە موسای پیاوی خودای فەرموو.
\v 7 لەو کاتەدا کە موسای بەندەی یەزدان منی لە قادێش بەرنێعەوە نارد بۆ ئەوەی سیخوڕیێتیی خاکەکە بکەم، تەمەنم چل ساڵ بوو، منیش گەڕامەوە و ئەو هەواڵەی لە دڵمدا بوو پێم ڕاگەیاند.
\v 8 هەرچەندە براکانم ئەوانەی لەگەڵ من بوون گەلیان ترساند، بەڵام من بە هەموو دڵمەوە بەدوای یەزدانی پەروەردگارم کەوتم.
\v 9 جا موسا لەو ڕۆژە سوێندی خوارد: ”ئەو خاکەی تۆ پێت نایە سەری هەتاهەتایە دەبێتە میراتی خۆت و کوڕەکانت، چونکە بە هەموو دڵتەوە بەدوای یەزدانی پەروەردگارم کەوتیت.“\f + \fr 14:9 \ft بڕوانە \xt دواوتار 1‏:36‏\xt*\ft .‏\f*
\p 
\v 10 «ئێستا تەماشا بکە، یەزدان هەروەک فەرمووی، ئەم چل و پێنج ساڵە منی بە زیندوویی هێشتووەتەوە، لەو کاتەوە کە یەزدان بەم قسانە لەگەڵ موسادا دوا، کاتێک ئیسرائیل بە چۆڵەوانیدا ڕۆیشت. ئێستاش ئەوەتا تەمەنم هەشتا و پێنج ساڵە!
\v 11 هێشتا هەتا ئەمڕۆش هێزم لەبەردا ماوە، هەروەک ئەو ڕۆژەی کە موسا منی نارد، ئەو کاتە هێزم چۆن بوو، ئێستاش هەمان هێزی چوونە ناو جەنگم هەیە.
\v 12 ئێستاش ئەم ناوچە شاخاوییانەم بدەرێ کە یەزدان لەو ڕۆژەدا بەڵێنی پێدام، چونکە تۆ لەو ڕۆژەدا بیستت کە عەناقییەکان لەوێن و شارەکانیان گەورە و قەڵابەند بوون. بەڵکو یەزدان یارمەتیم بدات، جا دەریاندەکەم، هەروەک یەزدان فەرمووی.»
\p 
\v 13 یەشوعیش داوای بەرەکەتی بۆ کالێبی کوڕی یەفونە کرد و حەبرۆنی بە میرات پێدا.
\v 14 لەبەر ئەوە حەبرۆن بووە میراتی کالێبی کوڕی یەفونەی قەنیزی هەتا ئەمڕۆش، چونکە بە هەموو دڵییەوە بەدوای یەزدانی پەروەردگاری ئیسرائیل کەوت.
\v 15 حەبرۆنیش پێشتر ناوی قیریەت ئەربەع بوو، ئەربەعیش گەورەترین پیاو بوو لەناو عەناقییەکان.
\p ئینجا خاکەکە لە جەنگ پشووی دا.
\c 15
\s1 بەشی یەهودا
\li4 
\v 1 بەشی هۆزی نەوەی یەهودا بە تیروپشک بەگوێرەی خێڵەکانیان لە سنووری ئەدۆمەوە بۆ چۆڵەوانی چن بەرەو باشوور درێژ بووەوە، هەتا ئەوپەڕی باشوور.
\b
\li1 
\v 2 سنووری باشووریان لە کەنداوەوە دەستپێدەکات، لە کۆتایی باشووری دەریای مردووە\f + \fr 15:2 \ft دەریای مردوو: عیبری دەریای خوێ، لێرە و لە ئایەتی 5دا.‏\f* و
\v 3 لەوێشەوە بۆ باشووری هەورازی دووپشک دەچوو و پەڕییەوە بۆ چن لە باشووری قادێش بەرنێعەوە سەرکەوت. ئینجا بەردەوام بوو بۆ حەسرۆن و سەرکەوت بۆ ئەدار لەوێشەوە بۆ قەرقەع و
\v 4 بەردەوام بوو بۆ عەچمۆن و لەگەڵ دۆڵی میسر یەکیگرت و کۆتایی سنوورەکەش لەلای دەریای سپی ناوەڕاست\f + \fr 15:4 \ft لەلای دەریای سپی ناوەڕاست: عیبری: لەلای دەریاوە، لێرە و لە ئایەتی 11.‏\f* بوو. ئەمە دەبێتە سنووری باشووریان.
\li1 
\v 5 سنووری ڕۆژهەڵاتیش لە دەریای مردووەوە هەتا کۆتایی ڕووباری ئوردون بوو.
\li1 سنووری لای باکوور دەستپێدەکات لە کەنداوی دەریاکە لەلای کۆتایی ڕووباری ئوردون و
\v 6 سنوورەکە سەرکەوت بۆ بێت‌حۆگلە و لە باکووری بێت‌عەراڤا پەڕییەوە و سنوورەکە سەرکەوت بۆ بەردی بۆهەنی کوڕی ڕەئوبێن و
\v 7 سنوورەکە لە دۆڵی عاخۆرەوە سەرکەوت بۆ دەڤیر و بەرەو باکوور بووەوە بۆ گەلیلۆت کە بەرامبەر بە ڕێگای هەورازی ئەدومیمە کە لە باشووری دەربەندەکەیە و ئینجا سنوورەکە بەردەوام بوو بۆ ئاوەکانی کانی شەمەش و چوو بۆ کانی ڕۆگێل.
\v 8 ئینجا سنوورەکە بە دۆڵی بەن‌هینۆمدا بەلای باشووری بناری شاری یەبوسیدا سەرکەوت کە ئۆرشەلیمە، سنوورەکە بۆ سەر لووتکەی کێوەکە سەرکەوت کە بەرامبەر دۆڵی بەن‌هینۆمە بەلای ڕۆژئاوادا کە لە کەنار دۆڵی ڕفایمە لە باکوور.
\v 9 سنوورەکە لەسەر لووتکەی کێوەکەوە درێژ بووەوە بۆ سەرچاوەی ئاوەکانی نەفتۆوەح و چوو بۆ شارۆچکەکانی کێوی عەفرۆن. لەوێشەوە سنوورەکە درێژ بووەوە بۆ بەعلە کە قیریەت یەعاریمە.
\v 10 ئینجا سنوورەکە لە بەعلەیەوە بەرەو ڕۆژئاوا درێژ بووەوە بۆ کێوی سێعیر\f + \fr 15:10 \ft ئەم کێوە پەیوەندی بەو ناوچە شاخاوییە نییە کە عیسۆ لێی دەژیا.‏\f* و بەردەوام بوو بۆ لای بناری کێوی یەعاریم لە باکوور کە کەسالۆنە و دابەزییە بێت‌شەمەش و پەڕییەوە بۆ تیمنا.
\v 11 ئینجا سنوورەکە چوو بۆ لای بناری باکووری عەقرۆن و سنوورەکە درێژ بووەوە بۆ شیکارۆن و لە کێوی بەعلە پەڕییەوە و گەیشتە یەڤنئێل و کۆتایی سنوورەکەش لەلای دەریای سپی ناوەڕاست بوو.
\li1 
\v 12 سنووری ڕۆژئاواشیان دەریای سپی ناوەڕاست\f + \fr 15:12 \ft دەریای سپی ناوەڕاست: عیبری: دەریای مەزن، لێرە و لە ئایەتی 47.‏\f* بوو بە کەنارەکانییەوە.
\b
\li4 ئەمە سنووری نەوەی یەهودا بوو بە چواردەوریدا بەگوێرەی خێڵەکانیان.
\b
\p 
\v 13 بەپێی فەرمانی یەزدان، یەشوع لە خاکی نەوەی یەهودا بەشێکی دا بە کالێبی کوڕی یەفونە، ئەویش قیریەت ئەربەع بوو کە حەبرۆنە و ئەربەع باپیرە گەورەی عەناق بوو.
\v 14 کالێبیش هەر سێ خێڵی نەوەی عەناقی لە حەبرۆن دەرکرد، شێشەی و ئەحیمەن و تەلمەی کە کوڕەکانی عەناق بوون.
\v 15 لەوێشەوە بۆ هێرشکردنە سەر دانیشتووانی دەڤیر پێشڕەوی کرد، دەڤیر پێشتر ناوی قیریەت سێفەر بوو.
\v 16 ئینجا کالێب گوتی: «ئەوەی پەلاماری قیریەت سێفەر بدات و بیگرێت، عەکسای کچمی دەدەمێ ببێتە ژنی.»
\v 17 ئیتر عۆسنیێلی کوڕی قەنەزی برای کالێب قیریەت سێفەری گرت، کالێبیش عەکسای کچی دایێ بۆ ئەوەی ببێتە ژنی.
\p 
\v 18 ئینجا لە کاتی هاتنی بۆ لای عۆسنیێل، عەکسا هانی دا بۆ ئەوەی داوای کێڵگەیەک لە باوکی بکات. کاتێک عەکسا لە گوێدرێژەکە دابەزی، کالێب لێی پرسی: «چیت بۆ بکەم؟»
\p 
\v 19 ئەویش پێی گوت: «بەرەکەتێکم بدەرێ، لەبەر ئەوەی لە نەقەب زەویت پێداوم، سەرچاوەکانی ئاوم بدەرێ.» کالێبیش کانیاوەکانی سەروو و خوارووی پێدا.
\b
\li4 
\v 20 ئەمە میراتی هۆزی یەهودایە بەگوێرەی خێڵەکانیان:
\b
\li1 
\v 21 شارۆچکەکانی هۆزی نەوەی یەهودا کە لە کۆتایی باشووردا بوون لە نەقەب لەلای سنووری ئەدۆم ئەمانە بوون:
\li2 قەڤچەئێل، عێدەر، یاگور،
\v 22 قینا، دیمۆنا، عەدعادە،
\v 23 قەدەش، حاچۆر، یەتنان،
\v 24 زیف، تەلەم، بەعالۆت،
\v 25 حاچۆر حەدەتا، قەریۆت حەسرۆن کە حاچۆرە،
\v 26 ئەمام، شەمەع، مۆلادا،
\v 27 حەچەر گەدا، حەشمۆن و بێت‌پەلەت،
\v 28 حەچەر شوعال، بیری شابەع، بزیۆتیە،
\v 29 بەعلە، عییم، عەچەم،
\v 30 ئەلتۆلەد، کەسیل، حۆرما،
\v 31 چیقلەگ، مەدمەنا، سەنسەنا،
\v 32 لەڤائۆت، شیلحیم، عەین و ڕیمۆن. هەموو شارۆچکەکان بیست و نۆ شارۆچکە بوون بە گوندەکانیشیانەوە.
\li1 
\v 33 لە زوورگەکانی خۆرئاوا:
\li2 ئەشتائۆل، چۆرعا، ئەشنا،
\v 34 زانۆوەح، کانی گەنیم، تەپووەح، عێینام،
\v 35 یەرموت، عەدولام، سۆکۆ، عەزێقا،
\v 36 شەعەرایم، عەدیتەیم، گەدێرا یان گەدێرۆتەیم بوون، واتا چواردە شارۆچکە بە گوندەکانیانەوە.
\li2 
\v 37 چەنان، حەداشا، میگدەل گاد،
\v 38 دیلعان، میچپا، یۆقتئێل،
\v 39 لاخیش، بۆچقەت، عەگلۆن،
\v 40 کەبۆن، لەحماس، کیتلیش،
\v 41 گەدێرۆت، بێت‌داگۆن، نەعما و مەقێدا، واتا شازدە شارۆچکە بە گوندەکانیانەوە.
\li2 
\v 42 لیڤنا، عەتەر، عاشان،
\v 43 یەفتاح، ئەشنا، نەچیڤ،
\v 44 قەعیلا، ئەکزیڤ و مارێشا، واتا نۆ شارۆچکە بە گوندەکانیانەوە.
\li2 
\v 45 عەقرۆن لەگەڵ دانیشتووانی دەوروبەری و گوندەکانی،
\v 46 لە عەقرۆنەوە بەرەو ڕۆژئاوا، هەموو ئەوەی نزیک ئەشدۆد و گوندەکانیەتی،
\v 47 ئەشدۆد لەگەڵ دانیشتووانی دەوروبەری و گوندەکانی و غەزە و دانیشتووانی دەوروبەری و گوندەکانی هەتا دۆڵی میسر و دەریای سپی ناوەڕاست و کەنارەکانی.
\li1 
\v 48 لە ناوچە شاخاوییەکەش:
\li2 شامیر، یەتیر، سۆکۆ،
\v 49 دەنا، قیریەت سەنا کە دەڤیرە،
\v 50 عەناڤ، ئەشتەمۆ، عانیم،
\v 51 گۆشەن، حۆلۆن و گیلۆ، واتا یازدە شارۆچکە بە گوندەکانیانەوە.
\li2 
\v 52 ئەرەڤ، دوما، ئەشعان،
\v 53 یانیم، بێت‌تەپووەح، ئەفێقا،
\v 54 حومتا، قیریەت ئەربەع کە حەبرۆنە و چیعۆر، واتا نۆ شارۆچکە بە گوندەکانیانەوە.
\li2 
\v 55 ماعۆن، کارمەل، زیف، یوتا،
\v 56 یەزرەعیل، یۆقدەعام، زانۆوەح،
\v 57 قەین، گیڤعا و تیمنا، واتا دە شارۆچکە بە گوندەکانیانەوە.
\li2 
\v 58 حەلحول، بێت‌چوور، گەدۆر،
\v 59 مەعەرات، بێت‌عەنۆت و ئەلتەقۆن، واتا شەش شارۆچکە بە گوندەکانیانەوە.
\li2 
\v 60 قیریەت بەعل ئەوەی قیریەت یەعاریمە و ڕەبە، واتا دوو شارۆچکە بە گوندەکانیانەوە.
\li1 
\v 61 لە چۆڵەوانیش:
\li2 بێت‌عەراڤا، میددین، سیکاکا،
\v 62 نیڤشان، شاری خوێ و کانی گەدی، واتا شەش شارۆچکە بە گوندەکانیانەوە.
\b
\p 
\v 63 بەڵام نەوەی یەهودا نەیتوانی یەبوسییەکانی دانیشتووی ئۆرشەلیم دەربکەن، جا هەتا ئەمڕۆش یەبوسییەکان لە ئۆرشەلیمدا لەگەڵ نەوەی یەهودا نیشتەجێن.
\c 16
\s1 بەشەکانی مەنەشە و ئەفرایم
\li1 
\v 1 تیروپشک بۆ بەشی نەوەی یوسف دەرچوو، لە ڕووباری ئوردون لەلای ئەریحا هەتا ئاوی ئەریحا بوو، بەرەو ڕۆژهەڵات هەتا ئەو چۆڵەوانییەی لە ئەریحاوە سەردەکەوێت بۆ ناوچە شاخاوییەکانی بێت‌ئێل،
\v 2 لە بێت‌ئێلیشەوە کە پێی دەگوترێ لوز، بەردەوام بوو بۆ سنووری ئەرکییەکان لە عەتەرۆت و
\v 3 لەوێشەوە ڕووەو ڕۆژئاوا دابەزی بۆ سنووری یەفلێتییەکان و بۆ سنووری بێت‌حۆرۆنی خواروو و بۆ گەزەر و کۆتاییەکەشی لەلای دەریای سپی ناوەڕاست\f + \fr 16:3 \ft لەلای دەریای سپی ناوەڕاست: عیبری: لەلای دەریاوە، لێرە و لە ئایەتی 8.‏\f* بوو.
\li4 
\v 4 جا نەوەکانی یوسف مەنەشە و ئەفرایم میراتی خۆیان وەرگرت.
\b
\li4 
\v 5 ئەمانەش سنووری نەوەی ئەفرایم بوو بەگوێرەی خێڵەکانیان:
\li1 سنووری میراتەکەیان لە ڕۆژهەڵات، عەتەرۆت ئەدار بوو، هەتا بێت‌حۆرۆنی ژووروو،
\v 6 ئینجا سنوورەکە بەرەو دەریا چوو، لە میخمەتات ڕووەو باکوور، بەلای ڕۆژهەڵاتدا سووڕایەوە بۆ تانەس شیلۆ و پەڕییەوە بۆ یانۆوەح لەلای ڕۆژهەڵات.
\v 7 سنوورەکە لە یانۆوەحەوە دابەزی بۆ عەتەرۆت و نەعەرا و چوو بۆ ئەریحا و گەیشتە ڕووباری ئوردون.
\v 8 ئینجا سنوورەکە لە تەپووەح درێژبووەوە بەرەو ڕۆژئاوا بۆ شیوی قانا و کۆتاییەکەشی لەلای دەریای سپی ناوەڕاست بوو. ئەمە میراتی هۆزی نەوەی ئەفرایم بوو بەگوێرەی خێڵەکانیان،
\li1 
\v 9 لەگەڵ ئەو شارۆچکانەی لەناو میراتی نەوەی مەنەشەدا بۆ نەوەی ئەفرایم جیا کرابوونەوە، هەموو شارۆچکە و گوندەکانیان.
\b
\p 
\v 10 کەنعانییەکانی دانیشتووانی گەزەریان دەرنەکرد، ئیتر کەنعانییەکان هەتا ئەمڕۆش لەگەڵ ئەفرایمدا نیشتەجێن و وەک کۆیلە بێگارییان پێدەکەن.
\c 17
\p 
\v 1 ئینجا تیروپشک بۆ هۆزی مەنەشە بوو، چونکە ئەو نۆبەرەی یوسف بوو، بۆ ماکیری نۆبەرەی مەنەشە و باپیرە گەورەی گلعاد، چونکە ماکیرییەکان پیاوی جەنگ بوون، گلعاد و باشان بۆ ئەو بوون.
\v 2 تیروپشک بۆ نەوەکانی دیکەی مەنەشەش بەگوێرەی خێڵەکانیان بوو، بۆ نەوەی ئەبیعەزەر، حێلەق، ئەسریێل، شەخەم، حێفەر و شەمیداع بەگوێرەی خێڵەکانیان بوو. ئەمانە نەوە نێرینەکانی کوڕانی مەنەشەی کوڕی یوسفن.
\p 
\v 3 بەڵام سەلۆفحادی کوڕی حێفەری کوڕی گلعادی کوڕی ماکیری کوڕی مەنەشە هیچ کوڕی نەبوو، بەڵکو کچی هەبوو، ئەمەش ناوی کچەکانییەتی، مەحلە، نۆعا، حۆگلە، میلکە و تیرزە.
\v 4 جا چوونە پێش بۆ لای ئەلعازاری کاهین و یەشوعی کوڕی نون و سەرۆکەکان و گوتیان: «یەزدان فەرمانی بە موسا کرد کە لەناو براکانمان میراتمان بدرێتێ.» ئیتر یەشوع بەپێی فەرمانی یەزدان لەنێو براکانی باوکیان میراتی پێدان.
\v 5 مەنەشە دە بەشی بەرکەوت، بێجگە لە زەوی گلعاد و باشان کە لەوبەری ڕووباری ئوردونەوە بوو بەلای ڕۆژهەڵاتەوە،
\v 6 چونکە کچانی هۆزی مەنەشە لەگەڵ کوڕەکانی میراتیان وەرگرت. زەوی گلعادیش بۆ ئەوانی دیکە بوو لە نەوەی مەنەشە.
\b
\li1 
\v 7 سنووری مەنەشەش لە ئاشێرەوە بۆ میخمەتات بوو کە ڕۆژهەڵاتی شەخەمە. سنوورەکە بەلای باشووردا درێژ بووەوە بۆ لای دانیشتووانی کانی تەپووەح.
\v 8 شاری تەپووەح لەسەر سنووری مەنەشە تایبەت بوو بە نەوەی ئەفرایم، بەڵام ناوچەکانی دەوروبەری شاری تەپووەح تایبەت بوون بە مەنەشە.
\v 9 ئینجا سنوورەکە بەرەو باشوور دابەزی بۆ شیوی قانا. ئەمانە شارۆچکەکانی ئەفرایم بوون لەنێو شارۆچکەکانی مەنەشە، سنووری مەنەشەش لە باکووری شیوەکە بوو، کۆتاییەکەشی لەلای دەریای سپی ناوەڕاست\f + \fr 17:9 \ft لەلای دەریای سپی ناوەڕاست: عیبری: لەلای دەریاوە.‏\f* بوو.
\v 10 لەلای باشوورەوە خاکەکە بۆ ئەفرایم بوو، لەلای باکووریشەوە بۆ مەنەشە بوو. دەریاش سنووری بوو، لەلای باکوورەوە گەیشتە ئاشێر و لەلای ڕۆژهەڵاتیشەوە گەیشتە یەساخار.
\li1 
\v 11 جا لەناو یەساخار و ئاشێر ئەم شارۆچکانە و دەوروبەریان بۆ مەنەشە بوون: بێت‌شان، یەڤلەعام، دانیشتووانی دۆر، سێ بەرزاییەکانی کانی دۆر، تەعنەک و مەگیدۆ.
\b
\p 
\v 12 بەڵام نەوەی مەنەشە نەیانتوانی دەست بەسەر ئەو شارۆچکانەدا بگرن، چونکە کەنعانییەکان سوور بوون لەسەر نیشتەجێبوون لەو خاکەدا.
\v 13 کاتێک نەوەی ئیسرائیل بەهێزتر بوون بێگارییان بە کەنعانییەکان کرد، بەڵام بە تەواوی دەریاننەکردن.
\p 
\v 14 ئینجا نەوەی یوسف لەگەڵ یەشوعدا دوان و گوتیان: «بۆچی یەک تیروپشک و یەک بەشت وەک میرات پێداوین، لەگەڵ ئەوەی ئێمە گەلێکی زۆرین، چونکە هەتا ئێستاش یەزدان هەر بەرەکەتداری کردووین؟»
\p 
\v 15 یەشوعیش وەڵامی دانەوە: «ئەگەر ئێوە گەلێکی زۆرن، سەربکەون بۆ دارستان لەوێ بۆ خۆتان زەوی پریزی و ڕفائییەکان پاک بکەنەوە، ئەگەر ناوچە شاخاوییەکانی ئەفرایم تەنگە بۆتان.»
\p 
\v 16 نەوەی یوسفیش گوتیان: «ناوچە شاخاوییەکە بەشمان ناکات و هەموو کەنعانییەکانی دانیشتووی دۆڵەکەش گالیسکەی ئاسنینیان هەیە، ئەوانەی لە بێت‌شان و دەوروبەری و ئەوانەی لە دۆڵی یەزرەعیلن.»
\p 
\v 17 ئینجا یەشوع بە بنەماڵەی یوسف، بە نەوەی ئەفرایم و مەنەشەی گوت: «ئێوە گەلێکی زۆرن و توانایەکی مەزنتان هەیە، لەبەر ئەوە تەنها یەک تیروپشکتان نابێت،
\v 18 بەڵکو ناوچە شاخاوییەکەش بۆ ئێوە دەبێت، چونکە دارستانیشی هەیە، جا بیبڕنەوە و هەتا کۆتایی سنوورەکەی دەستی بەسەردا بگرن، ئینجا کەنعانییەکان دەردەکەن، هەرچەندە گالیسکەی ئاسنینیان هەبێت و بەهێزیش بن.»
\c 18
\s1 دابەشکردنی ئەو زەوییانەی کە ماوەتەوە
\p 
\v 1 ئینجا هەموو کۆمەڵی نەوەی ئیسرائیل لە شیلۆ کۆبوونەوە و لەوێدا چادری چاوپێکەوتنیان هەڵدا، خاکەکەش خرایە ژێر ڕکێفیانەوە.
\v 2 بەڵام حەوت هۆز لە نەوەی ئیسرائیل مابوونەوە کە هێشتا میراتەکەی خۆیان وەرنەگرتبوو.
\p 
\v 3 جا یەشوع بە نەوەی ئیسرائیلی گوت: «هەتا کەی خاو دەبن لە چوونە ژوورەوە بۆ دەست بەسەرداگرتنی ئەو خاکەی کە یەزدانی پەروەردگاری باوباپیرانتان پێیداون؟
\v 4 لە هەر هۆزێک سێ کەس بۆ خۆتان هەڵبژێرن، بۆ ئەوەی بیاننێرم و بچن و بە خاکەکەدا بگەڕێن، بەگوێرەی میراتەکەیان ڕووپێو بکەن، پاشان بگەڕێنەوە بۆ لام.
\v 5 بۆ حەوت بەش دابەشی بکەن. جا یەهودا لەسەر سنوورەکەی خۆی لە باشوور دەمێنێتەوە و بنەماڵەی یوسفیش لەسەر سنوورەکەیان لە باکوور دەمێننەوە.
\v 6 ئێوەش خاکەکە بۆ حەوت بەش ڕووپێو بکەن و پاشان بیهێننەوە ئێرە، لێرە لەبەردەم یەزدانی پەروەردگارمان تیروپشکتان بۆ دەکەم.
\v 7 بەڵام لێڤییەکان لەنێو ئێوەدا بەشیان نییە، چونکە کاهینیێتی یەزدان میراتی ئەوانە. گاد و ڕەئوبێن و نیوەی هۆزی مەنەشەش میراتی خۆیان لە بەری ڕۆژهەڵاتی ڕووباری ئوردون وەرگرت، ئەوەی کە موسای بەندەی یەزدان پێیدان.»
\p 
\v 8 کاتێک پیاوەکان بۆ ڕووپێوی خاکەکە بەڕێکەوتن، یەشوع فەرمانی پێکردن و گوتی: «بڕۆن و بە خاکەکەدا بگەڕێن و وردەکارییەکانی بنووسن. پاشان وەرنەوە بۆ لام و منیش لێرە لەبەردەم یەزدان لە شیلۆ تیروپشکتان بۆ دەکەم.»
\v 9 ئینجا پیاوەکان ڕۆیشتن و بەناو خاکەکەدا گەڕان، بەگوێرەی شارۆچکەکان کردیان بە حەوت بەش، وردەکارییەکەیان تۆمار کرد، پاشان هاتنەوە بۆ لای یەشوع بۆ ئۆردوگاکە لە شیلۆ.
\b
\li4 
\v 10 یەشوعیش لە شیلۆ لەبەردەم یەزدان تیروپشکی بۆ کردن، لەوێ خاکەکەی بۆ نەوەی ئیسرائیل بەگوێرەی بەشەکانیان دابەش کرد.
\s1 بەشی بنیامین
\li4 
\v 11 ئینجا تیروپشک بۆ هۆزی نەوەی بنیامین بەگوێرەی خێڵەکانیان کرا. سنووری تیروپشکەکەیان لەنێوان نەوەی یەهودا و نەوەی یوسفدا بوو.
\li1 
\v 12 سنوورەکەیان لەلای باکوورەوە لە ڕووباری ئوردونەوە دەستی پێکرد و لە بناری ئەریحا لەلای باکوورەوە تێدەپەڕی، پاشان بە ناوچە شاخاوییەکەدا بەرەو ڕۆژئاوا دەچوو، هەتا نزیک چۆڵەوانی بێت‌ئاڤن.
\v 13 ئینجا سنوورەکە لەوێوە بەردەوام بوو بۆ باشووری بناری لوز کە بێت‌ئێلە و لەوێوە هاتە خوارەوە بۆ عەتەرۆت ئەدار لەسەر چیاکەی باشووری بێت‌حۆرۆنی خواروو.
\li1 
\v 14 ئینجا سنوورەکە درێژ بووەوە و سووڕایەوە بەلای ڕۆژئاوای باشوور، لەو کێوەی کە بەرامبەر بێت‌حۆرۆنە لە باشوور و گەیشتە قیریەت بەعل کە قیریەت یەعاریمە، شارۆچکەیەکی نەوەی یەهودا بوو. ئەمە لای ڕۆژئاوا بوو.
\li1 
\v 15 لای باشووریش لەوپەڕی قیریەت یەعاریمەوە دەستی پێکرد و سنوورەکە بەرەو ڕۆژئاوا چوو بۆ سەرچاوەی ئاوەکانی نەفتۆوەح.
\v 16 سنوورەکە بۆ دامێنی کێوەکەی بەرامبەر بە دۆڵی بەن‌هینۆم کە لە دۆڵی ڕفایمە لەلای باکوور دابەزی، لەوێشەوە دابەزی بۆ دۆڵی هینۆم بەلای لێژاییەکەی باشووری شاری یەبوسییەکاندا، ئینجا دابەزی بۆ کانی ڕۆگێل.
\v 17 ئینجا لە باکوورەوە ڕووەو کانی شەمەش درێژ بووەوە و بەردەوام بوو هەتا گەلیلۆت کە بەرامبەر بە ڕێگای هەورازی ئەدومیمە و ئینجا دابەزی بۆ بەردی بۆهەنی کوڕی ڕەئوبێن.
\v 18 بەردەوام بوو بۆ بنارەکەی بەرامبەر بە بێت‌عەراڤا بەلای باکووردا، ئینجا دابەزی بۆ دەشتایی عەراڤا.
\v 19 سنوورەکە بەردەوام بوو بۆ لای بناری باکووری بێت‌حۆگلە، لە کەنداوی باکووری دەریای مردوو\f + \fr 18:19 \ft دەریای مردوو: عیبری: دەریای خوێ.‏\f* کۆتایی هات، لە کۆتایی ڕووباری ئوردون لە باشوور. ئەمەش سنووری باشوورە.
\li1 
\v 20 سنووری لای ڕۆژهەڵاتیش ڕووباری ئوردون بوو.
\li4 ئەمە میراتی نەوەی بنیامین بوو لەگەڵ سنوورەکەی بە چواردەوریدا بەگوێرەی خێڵەکانیان.
\b
\li4 
\v 21 شارەکانی هۆزی نەوەی بنیامینیش بەگوێرەی خێڵەکانیان ئەمانە بوون:
\li1 ئەریحا، بێت‌حۆگلە، عێمەق قەچیچ،
\v 22 بێت‌عەراڤا، چەمارایم، بێت‌ئێل،
\v 23 عەڤیم، پارا، عۆفرا،
\v 24 کەفەر عەمۆنی، عۆفنی و گەڤەع، واتا دوازدە شارۆچکە بە گوندەکانیانەوە.
\li1 
\v 25 گبعۆن، ڕامە، بئێرۆت،
\v 26 میچپا، کەفیرا، مۆچە،
\v 27 ڕاقەم، یەرپەئێل، تەرەلا،
\v 28 چێلەع، هائەلەف، شاری یەبوسی کە ئۆرشەلیمە، گیڤعا و قیریەت، واتا چواردە شارۆچکە بە گوندەکانیانەوە.
\li4 ئەمە میراتی نەوەی بنیامین بوو بەگوێرەی خێڵەکانیان.
\c 19
\s1 بەشی هۆزی شیمۆن
\li4 
\v 1 تیروپشکی دووەمیش بۆ هۆزی شیمۆن بەگوێرەی خێڵەکانیان کرا، میراتەکەشیان کەوتە ناو میراتەکەی نەوەی یەهوداوە.
\v 2 جا لە میراتەکەیان ئەمانە بۆ ئەوان بوو:
\li1 بیری شابەع کە شابەعە، مۆلادا،
\v 3 حەچەر شوعال، بالا، عەچەم،
\v 4 ئەلتۆلەد، بەتول، حۆرما،
\v 5 چیقلەگ، بێت‌مەرکاڤۆت، حەچەر سوسا،
\v 6 بێت‌لەڤائۆت، شاروحەن، واتا سێزدە شارۆچکە بە گوندەکانیانەوە؛
\li1 
\v 7 عەین و ڕیمۆن و عەتەر و عاشان، واتا چوار شارۆچکە بە گوندەکانیانەوە؛
\v 8 هەروەها هەموو ئەو گوندانەی بە چواردەوری ئەم شارۆچکانەدا بوون تاکو بەعەلەت بئێر کە ناسراوە بە ڕامەی نەقەب.
\li4 ئەمە میراتی هۆزی نەوەی شیمۆن بوو بەگوێرەی خێڵەکانیان.
\v 9 میراتەکەی نەوەی شیمۆن لە بەشەکەی نەوەی یەهودا بوو، چونکە بەشەکەی نەوەی یەهودا زۆر بوو بۆیان، لەبەر ئەوە نەوەی شیمۆن لەناو میراتەکەی یەهودا میراتیان بەرکەوت.
\s1 بەشی هۆزی زەبولون
\li4 
\v 10 تیروپشکی سێیەمیش بەگوێرەی خێڵەکانیان بۆ نەوەی زەبولون کرا:
\li1 سنووری میراتەکەیان هەتا سارید بوو.
\v 11 سنوورەکەیان بەرەو ڕۆژئاوا سەرکەوت بۆ مەرعەلا و گەیشتە دەباشەت و گەیشتە شیوەکەی نزیک بە یۆقنەعام.
\v 12 ئینجا لە ساریدەوە بەلای ڕۆژهەڵات سووڕایەوە، ڕووەو خۆر هەڵاتن بەسەر سنووری کیسلۆت تاڤۆر و بەردەوام بوو بۆ داڤەرەت و سەرکەوت بۆ یافیع.
\v 13 لەوێشەوە بەرەو ڕۆژهەڵات پەڕییەوە، ڕووەو ڕۆژهەڵات بۆ گەت حێفەر، عیتا قاچین و چوو بۆ ڕیمۆن و درێژ بووەوە بۆ نێعا.
\v 14 لەوێشەوە سنوورەکە بەلای باکووردا سووڕایەوە بۆ حەناتۆن و کۆتاییەکەشی لەلای دۆڵی یەفتەح ئێل بوو.
\li1 
\v 15 دوازدە شارۆچکە بوون بە گوندەکانیانەوە، لەوانە قەتات و نەهەلال و شیمرۆن و یەدەلا و بێت‌لەحم\f + \fr 19:15 \ft ئەم شوێنە جیاوازە لەگەڵ بێت‌لەحمی یەهودا کە دواتر داود و عیسا تێیدا لەدایک بوون.‏\f*.
\li4 
\v 16 ئەم شارۆچکانە لەگەڵ گوندەکانیان میراتی نەوەی زەبولون بوو بەگوێرەی خێڵەکانیان.
\s1 بەشی هۆزی یەساخار
\li4 
\v 17 تیروپشکی چوارەمیش بۆ یەساخار بوو، بۆ نەوەی یەساخار بەگوێرەی خێڵەکانیان.
\v 18 سنوورەکەشیان ئەمانە بوو:
\li1 یەزرەعیل، کەسولۆت، شونێم،
\v 19 حەفارەیم، شیئۆن، ئەناحەرەت،
\v 20 ڕەبیت، قیشیۆن، ئەڤەچ،
\v 21 ڕەمەت، کانی گەنیم، کانی حەدا و بێت‌پەچێچ بوو،
\li1 
\v 22 هەروەها سنوورەکە گەیشتە تاڤۆر و شەحەچوما و بێت‌شەمەش و کۆتایی سنوورەکەیان لەلای ڕووباری ئوردون بوو،
\li1 شازدە شارۆچکە بوون بە گوندەکانیانەوە.
\li4 
\v 23 ئەمە میراتی هۆزی نەوەی یەساخارە بەگوێرەی خێڵەکانیان، ئەم شارۆچکانە لەگەڵ گوندەکانیان.
\s1 بەشی هۆزی ئاشێر
\li4 
\v 24 تیروپشکی پێنجەمیش بۆ هۆزی نەوەی ئاشێر بوو بەگوێرەی خێڵەکانیان،
\v 25 سنوورەکەشیان ئەمانە بوو:
\li1 حەلقەت، حەلی، بەتەن، ئەکشاف،
\v 26 ئەلەمەلەخ، عەمعاد و میشال، لەلای ڕۆژئاواشەوە گەیشتە کارمەل و شیحۆر لیڤنات.
\v 27 ئینجا بەلای ڕۆژهەڵات گەڕایەوە بۆ بێت‌داگۆن و گەیشتە زەبولون و دۆڵی ییفتەح ئێل لە باکووری بێت‌عێمەق و نەعیێل و ئینجا بەلای چەپی کاڤولدا تێپەڕی
\v 28 بۆ عەبدۆن، ڕەحۆڤ، حەمۆن، قانا و هەتا سەیدائی مەزن.
\v 29 ئینجا سنوورەکە گەڕایەوە بەرەو ڕامە و بۆ شاری سوری قەڵابەند، لەوێشەوە سنوورەکە گەڕایەوە بۆ حۆسا و کۆتاییەکەشی لەلای دەریای سپی ناوەڕاست\f + \fr 19:29 \ft لەلای دەریای سپی ناوەڕاست: عیبری: لەلای دەریاوە، لێرە و لە ئایەتی 8.‏\f* بوو لە ناوچەی ئەکزیڤ،
\v 30 عوما و ئەفێق و ڕەحۆڤ،
\li1 بیست و دوو شارۆچکە بوون بە گوندەکانیانەوە.
\li4 
\v 31 ئەم شارۆچکانە لەگەڵ گوندەکانیان میراتی هۆزی نەوەی ئاشێر بوو بەگوێرەی خێڵەکانیان.
\s1 بەشی هۆزی نەفتالی
\li4 
\v 32 تیروپشکی شەشەمیش بۆ نەوەی نەفتالی بوو بەگوێرەی خێڵەکانیان.
\li1 
\v 33 سنوورەکەشیان لە حێلەفەوە لە دار بەڕووەکەوە بوو لەلای چەعەنەنیم و ئەدامی نەقەڤ و یەڤنئێل و تاکو لەقووم و کۆتاییەکەشی لەلای ڕووباری ئوردون بوو.
\v 34 ئینجا سنوورەکە بەرەو خۆرئاوا گەڕایەوە بۆ ئەزنۆت تاڤۆر و لەوێشەوە چوو بۆ حوقۆق و گەیشتە زەبولون لەلای باشوورەوە و گەیشتە ئاشێر لەلای ڕۆژئاواوە و لە ڕۆژهەڵاتیشەوە بۆ ڕووباری ئوردون\f + \fr 19:34 \ft بەپێی دەقی عیبری: یەهودای ئوردون.‏\f*.
\li1 
\v 35 شارە قەڵابەندەکانیش، چیدیم، چێر، حەممەت، ڕەقەت، کینارێت،
\v 36 ئەدامە، ڕامە، حاچۆر،
\v 37 قەدەش، ئەدرەعی، کانی حاچۆر،
\v 38 یەرئۆن، میگدەل ئێل، حۆرێم، بێت‌عەنات و بێت‌شەمەش،
\li1 نۆزدە شارۆچکە بوون بە گوندەکانیانەوە.
\li4 
\v 39 ئەم شارۆچکانە لەگەڵ گوندەکانیان میراتی هۆزی نەوەی نەفتالی بوو بەگوێرەی خێڵەکانیان.
\s1 بەشی هۆزی دان
\li4 
\v 40 تیروپشکی حەوتەمیش بۆ هۆزی نەوەی دان بەگوێرەی خێڵەکانیان کرا،
\v 41 جا هەرێمەکانی میراتیان ئەمە بوو:
\li1 چۆرعا، ئەشتائۆل، عیر شەمەش،
\v 42 شەعەلەبین، ئەیالۆن، یەتلا،
\v 43 ئێلۆن، تیمنا، عەقرۆن،
\v 44 ئەلتەقێ، گیبەتۆن، بەعەلات،
\v 45 یەهودییە، بەنێ‌ڤەرەق، گەت ڕیمۆن،
\v 46 ئاوەکانی یەرقۆن و ڕەقۆن لەگەڵ ئەو سنوورانەی بەرامبەر بە یافا بوو.
\li4 
\v 47 پاش ئەوەی نەوەی دان سنوورەکەیان لە دەست چوو، جا نەوەی دان سەرکەوتن و لە دژی لەشەم جەنگان و گرتیان و دایانە بەر زەبری شمشێر و داگیریان کرد و تێیدا نیشتەجێ بوون، ئینجا لەشەمیان ناو نا دان، لەسەر ناوی دانی باوباپیرانیان.
\li4 
\v 48 ئەم شارۆچکانە لەگەڵ گوندەکانیان میراتی هۆزی نەوەی دان بوو بەگوێرەی خێڵەکانیان.
\s1 بەشی یەشوع
\li1 
\v 49 پاش ئەوەی لە دابەشکردنی خاکەکە بوونەوە بەپێی سنوورەکانی، نەوەی ئیسرائیل لەنێو خۆیاندا میراتێکیان بە یەشوعی کوڕی نون دا.
\v 50 بەپێی فەرمایشتی یەزدان، ئەو شارۆچکەیەیان پێیدا کە داوای کرد، تیمنەت سەرەح\f + \fr 19:50 \ft تیمنەت سەرەح: هەروەها بە (تیمنەت حەرەس) ناسراوە. بڕوانە \xt ڕابەران 2‏:9‏\xt*\ft ‏.‏\f* لە ناوچە شاخاوییەکانی ئەفرایم، جا شارۆچکەکەی بنیاد نایەوە و تێیدا نیشتەجێ بوو.
\b
\li4 
\v 51 ئەمە میراتەکانە کە ئەلعازاری کاهین و یەشوعی کوڕی نون و سەرۆکەکانی باوکانی هۆزەکانی نەوەی ئیسرائیل لە شیلۆدا لەبەردەم یەزدان لەلای دەروازەی چادری چاوپێکەوتندا بە تیروپشک دابەشیان کرد و ئینجا لە دابەشکردنی خاکەکە بوونەوە.
\c 20
\s1 شارەکانی پەناگا
\p 
\v 1 ئینجا یەزدان بە یەشوعی فەرموو:
\v 2 «بە نەوەی ئیسرائیل بڵێ: ”شاری پەناگا بۆ خۆتان دابنێن، هەروەک لە ڕێگەی موساوە پێم فەرموون،
\v 3 هەتا ئەو کەسەی بەبێ ئەنقەست و بە ڕێککەوت کەسێکی دیکە دەکوژێت بۆ ئەوێ هەڵبێت، جا دەبێتە پەناگاتان لە دەست خوێنگری\f + \fr 20:3 \ft خوێنگر: خوێنخوا، نزیکترین پلەی کۆمەڵایەتی کە مافی هەیە داوای تۆڵەی خوێنی بکات. بڕوانە پێشەکی پەڕتووکی ڕائووس.‏\f* تۆڵەسێنەر.
\v 4 با بۆ یەکێک لەو شارانە هەڵبێت و لە دەروازەی شارەکەدا بوەستێت و کێشەکەی بۆ پیرانی ئەو شارە بگێڕێتەوە و ئەوانیش لە شارەکەدا دەیگرنە خۆیان و شوێنێکی دەدەنێ، جا لەنێویاندا نیشتەجێ دەبێت.
\v 5 ئەگەر هاتوو خوێنگرەکەش دوای کەوت، ئەوان تۆمەتبارکراوەکە نادەنە دەستیەوە، چونکە بە ڕێککەوت نزیکەکەی خۆی کوشتووە و پێشتر ڕقی لێی نەبووەتەوە.
\v 6 ئیتر لەو شارە نیشتەجێ دەبێت، هەتا ئەو کاتەی بۆ بڕیاردان لەبەردەم ئەنجومەن ڕادەوەستێت و هەتا مردنی سەرۆکی کاهینی ئەو سەردەمە، ئینجا ئەو کەسە دەتوانێت بگەڕێتەوە ماڵەکەی خۆی، بۆ ئەو شارۆچکەیەی لێی هەڵاتبوو.“»
\p 
\v 7 جا قەدەشیان لە جەلیل لە ناوچە شاخاوییەکانی نەفتالی تەرخان کرد و شەخەمیش لە ناوچە شاخاوییەکانی ئەفرایم و قیریەت ئەربەع کە حەبرۆنە لە ناوچە شاخاوییەکانی یەهودا.
\v 8 هەروەها لە بەری ڕۆژهەڵاتی ڕووباری ئوردونیش لەلای ئەریحا، بەچەریان لە چۆڵەوانی لە دەشتە بەرزەکەی هۆزی ڕەئوبێن نیشان کرد و ڕامۆت لە گلعاد لە هۆزی گاد و گۆلان لە باشان لە هۆزی مەنەشە.
\v 9 ئەمانە شارەکانی پەناگان بۆ هەموو نەوەی ئیسرائیل و ئەو نامۆیەی لەنێویاندا دەژیێت، هەتا ئەوەی بەبێ ئەنقەست کەسێکی دیکەی کوشت بۆ ئەوێ هەڵبێت، جا بە دەستی خوێنگرە تۆڵەسێنەرەکە ناکوژرێت هەتا لەبەردەم ئەنجومەن نەوەستێت بۆ دادگاییکردنی.
\c 21
\s1 پێدانی چەند شارۆچکەیەک بە لێڤییەکان
\p 
\v 1 ئەوە بوو گەورەی بنەماڵەکانی لێڤییەکان هاتنە لای ئەلعازاری کاهین و یەشوعی کوڕی نون و گەورەی بنەماڵەکانی هۆزەکانی دیکەی نەوەی ئیسرائیل،
\v 2 لە شیلۆ لە خاکی کەنعان لەگەڵیاندا دوان و گوتیان: «یەزدان لە ڕێگەی موساوە فەرمانی داوە کە چەند شارۆچکەیەکمان پێبدرێت بۆ نیشتەجێبوون لەگەڵ لەوەڕگاکانیان بۆ ئاژەڵی ماڵیمان.»
\b
\li4 
\v 3 بەپێی فەرمانی یەزدان نەوەی ئیسرائیلیش لە میراتەکەی خۆیان ئەم شارۆچکانە و لەوەڕگایانەیان دایە لێڤییەکان:
\b
\li1 
\v 4 جا تیروپشک بۆ خێڵەکانی قەهاتییەکان کرا، لێڤییەکان کە لە نەوەی هارونی کاهین بوون بە تیروپشک سێزدە شارۆچکەیان بەرکەوت لە هۆزی یەهودا و هۆزی شیمۆن و هۆزی بنیامین.
\li1 
\v 5 بۆ پاشماوەی نەوەی قەهاتیش دە شارۆچکە بە تیروپشک لە خێڵەکانی هۆزی ئەفرایم و هۆزی دان و نیوەی هۆزی مەنەشەیان بەرکەوت.
\li1 
\v 6 بۆ نەوەی گێرشۆنیش سێزدە شارۆچکەیان بە تیروپشک بەرکەوت، لە خێڵەکانی هۆزی یەساخار و هۆزی ئاشێر و هۆزی نەفتالی و نیوەی هۆزی مەنەشە لە باشان.
\li1 
\v 7 بۆ نەوەی مەراریش بەگوێرەی خێڵەکانیان دوازدە شارۆچکەیان بەرکەوت، لە هۆزی ڕەئوبێن و گاد و زەبولون.
\b
\li4 
\v 8 جا نەوەی ئیسرائیل بە تیروپشک ئەم شارۆچکە و لەوەڕگایانەیان بە لێڤییەکان دا، هەروەک یەزدان لە ڕێگەی موساوە فەرمانی دابوو.
\b
\li1 
\v 9 لە هۆزی نەوەی یەهودا و هۆزی نەوەی شیمۆن ئەم شارۆچکانەیان دا کە ئەمانە ناوەکانیان بوون،
\v 10 جا ئەم شارۆچکانە بۆ نەوەی هارون دیاری کرا لە خێڵەکانی قەهاتییەکان لە نەوەی لێڤی، چونکە تیروپشکی یەکەم بۆ ئەوان بوو:
\li2 
\v 11 قیریەت ئەربەع باپیرە گەورەی عەناق کە حەبرۆنە لە ناوچە شاخاوییەکانی یەهودا لەگەڵ لەوەڕگاکانی دەوروبەری،
\v 12 بەڵام کێڵگەکان و گوندەکانی دەوروبەری شارەکەیان بە کالێبی کوڕی یەفونە دا وەک موڵکی خۆی.
\v 13 ئەم شارۆچکانە بە لەوەڕگاکانیانەوە درانە نەوەی هارونی کاهین: حەبرۆن، کە شارێکی پەناگای تۆمەتبارکراوان بوو بە کوشتن، لەگەڵ لیڤنا،
\v 14 یەتیر، ئەشتەمۆع،
\v 15 حۆلۆن، دەڤیر،
\v 16 عەین، یوتا و بێت‌شەمەش، واتا نۆ شارۆچکە لەم دوو هۆزە\f + \fr 21:16 \ft لەم دوو هۆزە: واتا یەهودا و شیمۆن، بڕوانە ئایەتی 9.‏\f*.
\li1 
\v 17 لە هۆزی بنیامینیش
\li2 گبعۆن، گەڤەع،
\v 18 عەناتۆت و عەلمۆن بە لەوەڕگاکانیانەوە، واتا چوار شارۆچکە.
\li4 
\v 19 هەموو شارۆچکەکانی نەوەی هارون کە کاهینەکانن، سێزدە شارۆچکە بوون بە لەوەڕگاکانیانەوە.
\b
\li4 
\v 20 پاشماوەی خێڵەکانی قەهات لە لێڤییەکان، بە تیروپشک ئەم شارۆچکانەیان لە هۆزی ئەفرایم بەرکەوت:
\li1 
\v 21 لە ناوچە شاخاوییەکانی ئەفرایم شارۆچکەی شەخەمیان پێدرا،
\li2 کە شارێکی پەناگای تۆمەتبارکراوان بوو بە کوشتن، لەگەڵ گەزەر،
\v 22 قیڤچەیم و بێت‌حۆرۆن بە لەوەڕگاکانیانەوە، واتا چوار شارۆچکە.
\li1 
\v 23 لە هۆزی دانیش ئەمانەیان وەرگرت:
\li2 ئەلتەقێ و گیبەتۆن و
\v 24 ئەیالۆن و گەت ڕیمۆن بە لەوەڕگاکانیانەوە، واتا چوار شارۆچکە.
\li1 
\v 25 لە نیوەی هۆزی مەنەشەش ئەمانەیان وەرگرت:
\li2 تەعنەک و گەت ڕیمۆن بە لەوەڕگاکانیانەوە، واتا دوو شارۆچکە.
\li4 
\v 26 هەموو شارۆچکەکان دە بوون بە لەوەڕگاکانیانەوە بۆ پاشماوەی خێڵەکانی نەوەی قەهات بوو.
\b
\li4 
\v 27 بۆ نەوەی گێرشۆنیش لە خێڵەکانی لێڤییەکان:
\li1 لە نیوەی هۆزی مەنەشەوە:
\li2 گۆلان و لەوەڕگاکانی پێدرا لە باشان، کە شارێکی پەناگای تۆمەتبارکراوان بوو بە کوشتن، لەگەڵ بەعەشتەرا و لەوەڕگاکانی، واتا دوو شارۆچکە.
\li1 
\v 28 لە هۆزی نەوەی یەساخاریش ئەمانەیان وەرگرت:
\li2 قیشیۆن و داڤەرەت و
\v 29 یەرموت و کانی گەنیم، بە لەوەڕگاکانیانەوە، واتا چوار شارۆچکە.
\li1 
\v 30 لە هۆزی نەوەی ئاشێریش ئەمانەیان وەرگرت:
\li2 میشال و عەبدۆن و
\v 31 حەلقەت و ڕەحۆڤ، بە لەوەڕگاکانیانەوە، واتا چوار شارۆچکە.
\li1 
\v 32 لە هۆزی نەفتالیش ئەمانەیان وەرگرت:
\li2 قەدەش لە جەلیل، کە شارێکی پەناگای تۆمەتبارکراوان بوو بە کوشتن، لەگەڵ حەمۆت دۆر و قەرتان بە لەوەڕگاکانیانەوە، واتا سێ شارۆچکە.
\li4 
\v 33 هەموو شارۆچکەکانی گێرشۆنییەکان بەگوێرەی خێڵەکانیان، سێزدە شارۆچکە بوون بە لەوەڕگاکانیانەوە.
\b
\li4 
\v 34 بۆ خێڵەکانی نەوەی مەراریش کە پاشماوەی لێڤییەکانن:
\li1 لە هۆزی زەبولون ئەمانەیان پێدان:
\li2 یۆقنەعام و قەرتا و
\v 35 دیمنا و نەهەلال، بە لەوەڕگاکانیانەوە، واتا چوار شارۆچکە.
\li1 
\v 36 لە هۆزی ڕەئوبێنیش ئەمانەیان پێدان:
\li2 بەچەر و یەهەچ و
\v 37 قەدێمۆت و مێفەعەت بە لەوەڕگاکانیانەوە، واتا چوار شارۆچکە.
\li1 
\v 38 لە هۆزی گادیش ئەمانەیان وەرگرت:
\li2 ڕامۆت لە گلعاد، کە شارێکی پەناگای تۆمەتبارکراوان بوو بە کوشتن، لەگەڵ مەحەنەیم و
\v 39 حەشبۆن و یەعزێر، بە لەوەڕگاکانیانەوە، واتا چوار شارۆچکە.
\li4 
\v 40 جا هەموو ئەو شارۆچکانەی بۆ نەوەی مەراری بوون بەگوێرەی خێڵەکانیان، ئەوانەی لە خێڵەکانی لێڤییەکان مابوونەوە، تیروپشکەکەشیان دوازدە شارۆچکە بوو.
\b
\li4 
\v 41 هەموو شارۆچکەکانی لێڤییەکان لەناو ئەو موڵکەی نەوەی ئیسرائیل خاوەنی بوون، چل و هەشت شارۆچکە بوون بە لەوەڕگاکانیانەوە.
\v 42 ئەم شارۆچکانەش شار بە شار بوون و لەوەڕگاکانیشیان بە چواردەوریاندا بوو، هەموو ئەم شارۆچکانە وابوون.
\b
\p 
\v 43 جا یەزدان هەموو ئەو زەوییەی دایە نەوەی ئیسرائیل کە سوێندی خواردبوو بیداتە باوباپیرانیان، ئەوانیش دەستیان بەسەردا گرت و تێیدا نیشتەجێ بوون.
\v 44 هەروەها یەزدان لە دەوروبەرەکەیان ئاسوودەی کردن بەپێی ئەو سوێندەی بۆ باوباپیرانی ئەوانی خوارد، تەنها پیاوێکیش لە هەموو دوژمنەکانیان بەرامبەریان نەوەستا، بەڵکو یەزدان هەموو دوژمنەکانی ئەوانی دایە دەستیان.
\v 45 هیچ بەڵێنێک لە هەموو ئەو بەڵێنە چاکانەی یەزدان بە بنەماڵەی ئیسرائیلی فەرمووبوو نەشکاوە، بەڵکو هەمووی هاتە دی.
\c 22
\s1 گەڕانەوەی هۆزەکانی ڕۆژهەڵات
\p 
\v 1 ئینجا یەشوع ڕەئوبێنییەکان و گادییەکان و نیوە هۆزەکەی مەنەشەی بانگکرد و
\v 2 پێی گوتن: «ئێوە هەموو ئەو شتانەتان جێبەجێ کرد کە موسای بەندەی یەزدان فەرمانی پێ کردبوون و لە هەموو ئەو شتانەش کە فەرمانم پێکردن گوێڕایەڵم بوون و
\v 3 بە درێژایی ئەو ڕۆژانە و هەتا ئەمڕۆش براکانی خۆتان بەجێ نەهێشت و بە وریاییەوە فەرمانی یەزدانی پەروەردگاری خۆتان بەجێهێنا.
\v 4 ئێستاش کە یەزدانی پەروەردگارتان براکانی ئێوەی ئاسوودە کرد، هەروەک بەڵێنی پێدابوون، ئێستا بگەڕێنەوە ماڵەکانتان لەو خاکەی موڵکتانە، ئەوەی کە موسای بەندەی یەزدان لەوبەری ڕووباری ئوردون پێیدان.
\v 5 بەڵام زۆر ئاگاداربن بۆ کارکردن بەو ڕاسپاردە و فێرکردنەی کە موسای بەندەی یەزدان فەرمانی پێ کردن، کە یەزدانی پەروەردگارتان خۆشبوێت و هەموو ڕێگاکانی بگرنەبەر و فەرمانەکانی جێبەجێ بکەن و دەستی پێوە بگرن، پڕ بە دڵ و لە ناختانەوە بیپەرستن.»
\p 
\v 6 ئینجا یەشوع داوای بەرەکەتی بۆ کردن و ئەوانی ناردەوە، ئەوانیش بەرەو نشینگەکانی خۆیان چوون.
\v 7 (پێشتر موسا لە باشان خاکی دابووە نیوە هۆزەکەی مەنەشە. یەشوعیش خاکی دابووە نیوەکەی دیکەی هۆزەکە لەگەڵ براکانیان لە بەری ڕۆژئاوای ڕووباری ئوردون.\f + \fr 22:7 \ft بڕوانە \xt سەرژمێری 32‏:20‏-33.‏\xt*\ft ‏\f*) هەروەها کە یەشوع ئەوانی ناردەوە بۆ لای نشینگەکانیان، داوای بەرەکەتی بۆ کردن و
\v 8 پێی گوتن: «بە سامانێکی زۆرەوە بگەڕێنەوە بۆ ماڵەکانتان و بە گاوگۆتاڵێکی زۆر و بە زێڕ و زیو و بڕۆنز و ئاسن و جلوبەرگێکی زۆرەوە، دەستکەوتی دوژمنەکانتان لەگەڵ براکانتان بەش بکەن.»
\p 
\v 9 ئینجا نەوەی ڕەئوبێن و نەوەی گاد و نیوەی هۆزی مەنەشە گەڕانەوە، نەوەی ئیسرائیلیان لە شیلۆ لە خاکی کەنعان بەجێهێشت، بۆ ئەوەی بچنە خاکی گلعاد بۆ ئەو خاکەی موڵکی خۆیانە، ئەوەی دەستیان بەسەردا گرتبوو بەپێی فەرمانی یەزدان لە ڕێگەی موساوە.
\p 
\v 10 کاتێک هاتنە گەلیلۆت کە نزیک ڕووباری ئوردونە لەناو خاکی کەنعان، نەوەی ڕەئوبێن و نەوەی گاد و نیوەی هۆزی مەنەشە لەوێ لەسەر ڕووباری ئوردون قوربانگایەکی گەورە و بەرچاویان بنیاد نا.
\v 11 جا نەوەی ئیسرائیل بیستیان، ئەوەتا نەوەی ڕەئوبێن و نەوەی گاد و نیوە هۆزەکەی مەنەشە قوربانگایەکیان بەرامبەر خاکی کەنعان لە گەلیلۆتدا نزیک ڕووباری ئوردون بەرامبەر بە نەوەی ئیسرائیل بنیاد ناوە.
\v 12 جا کە نەوەی ئیسرائیل ئەمەی بیستەوە، هەموو کۆمەڵی نەوەی ئیسرائیل لە شیلۆ کۆبوونەوە بۆ ئەوەی بۆ جەنگ لە دژی هۆزەکانی ئەوبەری ڕووباری ئوردون بڕۆن.
\p 
\v 13 ئینجا نەوەی ئیسرائیل فینەحاسی کوڕی ئەلعازاری کاهینیان نارد بۆ لای نەوەی ڕەئوبێن و نەوەی گاد و نیوەی هۆزی مەنەشە لە خاکی گلعاد.
\v 14 دە سەرۆکی لەگەڵ نارد، لە هەر هۆزێکی ئیسرائیل یەکێک، هەموویان گەورەی بنەماڵەکان بوون لەنێو تیرەکانی ئیسرائیل.
\p 
\v 15 ئینجا هاتنە لای نەوەی ڕەئوبێن و نەوەی گاد و نیوەی هۆزی مەنەشە بۆ خاکی گلعاد و پێیان گوتن:
\v 16 «هەموو کۆمەڵی یەزدان وا دەڵێن: ”ئەم ناپاکییە چییە کە دەرهەق بە خودای ئیسرائیل کردتان، بەوەی کە ئەمڕۆ لە یەزدان هەڵگەڕاونەتەوە بە بنیادنانی قوربانگایەک بۆ خۆتان هەتا لە دژی یەزدان یاخی بن؟
\v 17 ئایا گوناهەکەی پەعۆر کەمە بۆمان؟ ئەوەی هەتا ئەمڕۆش لێی پاک نەبووینەتەوە و بووە هۆی دەرد لەناو کۆمەڵی یەزدان!
\v 18 ئایا ئەمڕۆ ئێوەش لە یەزدان هەڵدەگەڕێنەوە؟
\p «”ئەگەر ئێوە ئەمڕۆ لە یەزدان یاخی بن، ئەویش سبەینێ لە هەموو کۆمەڵی ئیسرائیل تووڕە دەبێت.
\v 19 بەڵام ئەگەر خاکەکەی موڵکتان گڵاوە، بۆ خاکەکەی موڵکی یەزدان بپەڕنەوە کە چادری پەرستنی یەزدانی تێدایە و لەناو ئێمەدا میرات وەربگرن و لە یەزدان یاخی مەبن و لە دژی ئێمەش مەبن بە بنیادنانی قوربانگایەک بۆ خۆتان جیا لە قوربانگاکەی یەزدانی پەروەردگارمان.
\v 20 کاتێک عاخانی کوڕی زەرەح ناپاکی کرد لە شتە تەرخانکراوەکاندا\f + \fr 22:20 \ft لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان. لە کاتی شەڕدا دەستکەوتەکە دابەش ناکرێت و بەخشینەکە دەرئەنجامەکەی لەناوبردنی تەواوە.‏\f*، ئایا تووڕەیی یەزدان بەسەر هەموو کۆمەڵی ئیسرائیلدا نەباری؟ بەهۆی گوناهەکەیەوە تەنها خۆی لەناو نەچوو!“»\f + \fr 22:20 \ft بڕوانە بەشی 7.‏\f*
\p 
\v 21 ئینجا نەوەی ڕەئوبێن و نەوەی گاد و نیوەی هۆزی مەنەشە وەڵامیان دایەوە و بە سەرۆک خێڵەکانی ئیسرائیلیان گوت:
\v 22 «خودای توانادار، یەزدانە! خودای توانادار، یەزدانە! ئەو دەزانێت و با ئیسرائیلیش بزانێت، ئەگەر ئەمە بە یاخیبوون و بە ناپاکی دەرهەق بە یەزدان کرابێت، ئەوا ئەمڕۆ ڕزگارمان مەکەن!
\v 23 ئەگەر ئێمە ئەو قوربانگایەی خۆمانمان بە مەبەستی هەڵگەڕانەوە لە یەزدان و سەرخستنی قوربانی سووتاندن و پێشکەشکراوی دانەوێڵە بنیاد ناوە، یاخود بۆ ئەنجامدانی قوربانی هاوبەشی لەسەری، ئەوا با یەزدان خۆی سزامان بدات.
\p 
\v 24 «نەخێر! بەڵکو ئەم کارەمان بەهۆی ئەم ترسەوە کردووە کە گوتمان، لەوانەیە سبەینێ نەوەکانتان بە نەوەکانمان بڵێن: ”ئێوە چ پەیوەندییەکتان بە یەزدانی پەروەردگاری ئیسرائیلەوە هەیە؟
\v 25 ئەی نەوەی ڕەئوبێن و نەوەی گاد، یەزدان ڕووباری ئوردونی کردووەتە سنووری نێوان ئێمە و ئێوە! ئێوە هیچ بەشێکتان لە یەزداندا نییە.“ جا لەوانەیە نەوەکانتان ڕێگا نەدەن نەوەکانمان یەزدان بپەرستن.
\p 
\v 26 «لەبەر ئەوە گوتمان: ”با ئێمە بۆ خۆمان قوربانگایەک بنیاد بنێین، بەڵام بۆ قوربانی سووتاندن و قوربانی سەربڕاو نا.“
\v 27 بەڵکو لەپاش خۆمان ئەوە ببێتە شایەت لەنێوان ئێمە و ئێوە و نەوەکانمان، بۆ ئەوەی یەزدان لە پیرۆزگاکەی خۆی بپەرستین بە قوربانی سووتاندنەکانمان و سەربڕدراوەکانمان و قوربانییەکانی هاوبەشیمان و لە داهاتوودا نەوەکانتان بە نەوەکانمان نەڵێن: ”ئێوە بەشتان لە یەزداندا نییە.“
\p 
\v 28 «هەروەها گوتمان: ”کە لە داهاتوودا ئەمە بە خۆمان و نەوەکانمان دەڵێن، ئێمەش دەڵێین، بڕوانن هاوشێوەی قوربانگای یەزدان کە باوباپیرانمان کردوویانە، بەڵام بۆ قوربانی سووتاندن و سەربڕدراوەکان نییە، بەڵکو وەک شایەتە لەنێوان ئێمە و ئێوە.“
\p 
\v 29 «ئەوە لە ئێمە بەدوور بێت، کە لە یەزدان یاخی بین و ئەمڕۆ لە یەزدان هەڵگەڕێینەوە بە بنیادنانی قوربانگایەک بۆ قوربانی سووتاندن یان پێشکەشکراوی دانەوێڵە یان سەربڕاو، بێجگە لە قوربانگای یەزدانی پەروەردگارمان ئەوەی لەبەردەم چادرەکەی پەرستنیەتی.»
\p 
\v 30 جا کاتێک فینەحاسی کاهین و ڕابەرەکانی کۆمەڵ، سەرۆک خێڵەکانی ئیسرائیل، ئەوانەی لەگەڵیدا بوون، گوێیان لە قسەکانی نەوەی ڕەئوبێن و گاد و مەنەشە بوو، قسەکانیان قبوڵ کردن.
\v 31 ئینجا فینەحاسی کوڕی ئەلعازاری کاهین بە نەوەی ڕەئوبێن و نەوەی گاد و نەوەی مەنەشەی گوت: «ئەمڕۆ زانیمان کە یەزدان لەگەڵماندایە، چونکە ئەم ناپاکییەتان دەرهەق بە یەزدان نەکردووە، ئێستا ئێوە نەوەی ئیسرائیلتان لە دەست یەزدان دەرباز کردووە.»
\p 
\v 32 ئینجا فینەحاسی کوڕی ئەلعازاری کاهین و سەرۆکەکان لەلای نەوەی ڕەئوبێن و نەوەی گادەوە لە خاکی گلعادەوە بۆ لای نەوەی ئیسرائیل لە خاکی کەنعاندا گەڕانەوە و هەواڵیان پێدان.
\v 33 جا نەوەی ئیسرائیلیش دڵخۆش بوون بەم هەواڵە و ستایشی خودایان کرد و بیریان لەوە نەکردەوە کە سەربکەون بۆیان بۆ جەنگ و بۆ وێرانکردنی ئەو خاکەی کە نەوەی ڕەئوبێن و نەوەی گاد تێیدا نیشتەجێن.
\p 
\v 34 ئینجا نەوەی ڕەئوبێن و نەوەی گاد ناویان لە قوربانگاکە نا: «شایەتە لەنێوانمان کە یەزدان خودایە.»
\c 23
\s1 یەشوع ڕابەرەکان بە خودا دەسپێرێت
\p 
\v 1 پاش بەسەرچوونی ماوەیەکی زۆر، لەدوای ئەوەی یەزدان ئیسرائیلی لە دوژمنەکانی دەوروبەریان حەساندەوە، یەشوع پیر بوو و بەساڵدا چوو،
\v 2 هەموو ئیسرائیلی بە پیر و ڕابەر و دادوەر و کوێخاکانیەوە بانگکرد و پێی گوتن: «ئەوا من پیر بووم، بەساڵدا چووم و
\v 3 ئێوەش هەموو ئەوەتان بینیوە کە یەزدانی پەروەردگارتان لەبەر ئێوە بە هەموو ئەو نەتەوانەی کرد، چونکە یەزدانی پەروەردگارتان لە جیاتی ئێوە جەنگا.
\v 4 ببینن، من خاکی ئەو نەتەوانەی کە ماونەتەوە بە تیروپشک بۆم دابەش کردوون بە میرات بەپێی هۆزەکانتان، هەموو ئەو نەتەوانەم بەزاندووە، لە ڕووباری ئوردونەوە هەتا دەریای سپی ناوەڕاست\f + \fr 23:4 \ft دەریای سپی ناوەڕاست: عیبری دەریای مەزن.‏\f* بەرەو ڕۆژئاوا.
\v 5 یەزدانی پەروەردگارتان خۆی لەبەردەمتان ڕایاندەماڵێت و لەپێشتان دەریاندەکات، ئێوەش دەست بەسەر خاکەکەیاندا دەگرن هەروەک یەزدانی پەروەردگارتان بەڵێنی پێدان.
\p 
\v 6 «جا زۆر بەهێز بن بۆ پاراستن و کارکردن بە هەموو ئەوەی لە پەڕتووکی تەوراتی موسادا نووسراوە، بەبێ ئەوەی کە بەلای ڕاست یان چەپدا لێی لابدەن.
\v 7 تێکەڵی ئەم نەتەوانە مەبن، ئەوانەی لەگەڵتان ماونەتەوە ناوی خوداوەندەکانیان مەهێنن، سوێندیان پێ مەخۆن، مەیانپەرستن و کڕنۆشیان بۆ مەبەن.
\v 8 بەڵکو دەست بە یەزدانی پەروەردگارتانەوە بگرن هەروەک هەتا ئەمڕۆ کردووتانە.
\p 
\v 9 «یەزدان نەتەوە مەزن و بەهێزەکانی لەبەردەمتان دەرکردووە و هەتا ئەمڕۆش کەس لەبەردەمتاندا خۆی ڕانەگرتووە.
\v 10 یەک پیاو لە ئێوە هەزار دەردەپەڕێنێت، چونکە یەزدانی پەروەردگارتان لە جیاتی ئێوە دەجەنگێت هەروەک بەڵێنی پێدان.
\v 11 جا زۆر ئاگاداری خۆتان بن کە یەزدانی پەروەردگاری خۆتان خۆشبوێت.
\p 
\v 12 «بەڵام ئەگەر گەڕانەوە و هاوپەیمانیێتی بەجێماوەکانی ئەو نەتەوانەوەتان کرد، ئەوانەی کە لەگەڵتان ماونەتەوە، ژن و ژنخوازیتان لەگەڵدا کردن و هەڵسوکەوتتان لەگەڵیان کرد،
\v 13 ئەوا باش بزانن کە ئیتر یەزدانی پەروەردگارتان ئەو نەتەوانە لەبەردەمتان دەرناکات، بەڵکو دەبنە داو و تەڵە، قامچی لەسەر پشتتان و دڕک لەناو چاوتان، هەتا لەسەر ئەو خاکە چاکە لەناودەچن کە یەزدانی پەروەردگارتان پێیداون.
\p 
\v 14 «ئەوەتا خەریکە منیش ئەمڕۆ وەک هەموو دانیشتووانی زەوی کۆچی دوایی دەکەم، ئێوەش بە هەموو دڵ و بە هەموو دەروونتانەوە دەزانن کە تەنها یەک بەڵێن نەشکاوە لە هەموو ئەو بەڵێنە چاکانەی یەزدان دەربارەی ئێوە فەرمووبووی، هەمووی بۆتان هاتە دی، یەک بەڵێنی لێ نەشکاوە.
\v 15 ئاواش دەبێت، هەروەک چۆن هەموو ئەو بەڵێنە چاکانەی یەزدانی پەروەردگارتان دەربارەی ئێوە بەڵێنی دابوو هاتە دی، بە هەمان شێوە یەزدان هەموو شتە خراپەکانتان بەسەردا دەهێنێت، هەتا لەسەر ئەم خاکە چاکەی یەزدانی پەروەردگارتان پێیداون لەناوتان دەبات.
\v 16 ئەگەر پەیمانەکەی یەزدانی پەروەردگارتان بشکێنن کە فەرمانی پێ کردن، بڕۆن و خوداوەندی دیکە بپەرستن و کڕنۆشی بۆ ببەن، تووڕەیی یەزدان بەسەرتاندا دەجۆشێت و بە زوویی لەسەر ئەو خاکە چاکە لەناودەچن کە پێیداون.»
\c 24
\s1 تازەکردنەوەی پەیمانەکە لە شاری شەخەم
\p 
\v 1 ئینجا یەشوع هەموو هۆزەکانی ئیسرائیلی لە شەخەم کۆکردەوە و پیرانی ئیسرائیل و ڕابەر و دادوەر و کوێخاکانی بانگکرد و ئەوانیش لەبەردەم خودا وەستان.
\p 
\v 2 یەشوع بە هەموو گەلی گوت: «یەزدانی پەروەردگاری ئیسرائیل وای فەرمووە: ”لە کۆنەوە باوباپیرانتان لەوبەری ڕووباری فوراتەوە نیشتەجێ بوون، تارەحی باوکی ئیبراهیم و باوکی ناحۆر خوداوەندی دیکەیان دەپەرست.
\v 3 بەڵام من ئیبراهیمی باوکتانم لەوبەری ڕووباری فورات برد و بەناو هەموو زەوی کەنعاندا گێڕام، نەوەکانی ئەوم زۆر کرد و ئیسحاقم دایێ،
\v 4 یاقوب و عیسۆشم دایە ئیسحاق، بەشە میراتی ناوچە شاخاوییەکانی سێعیرم دایە عیسۆ، بەڵام یاقوب و کوڕەکانی دابەزین بۆ میسر.
\p 
\v 5 «”لەدوای ئەوە موسا و هارونم نارد و خەڵکی میسرم تووشی بەڵا کرد بەگوێرەی هەموو ئەوەی لەناویدا کردم، ئینجا ئێوەم دەرهێنا،
\v 6 جا باوباپیرانتانم لە میسر دەرهێنا و چوونە ناو دەریاوە و میسرییەکانیش بە گالیسکە و ئەسپەوە بۆ دەریای سوور دوای باوباپیرانتان کەوتن.
\v 7 جا کە هاواریان بۆ یەزدان کرد، ئەویش تاریکاییەکی خستە نێوان ئێوە و میسرییەکانەوە و دەریاکەی بەسەریاندا هێنایەوە و دایپۆشین. ئێوە بە چاوی خۆتان بینیتان من لە میسر چیم کرد. پاشان ئێوە لە چۆڵەوانیدا ڕۆژانێکی زۆر مانەوە.
\p 
\v 8 «”ئینجا ئێوەم هێنایە ناو خاکی ئەمۆرییەکان، ئەوانەی لەوبەری ڕووباری ئوردوندا بەلای ڕۆژهەڵاتدا نیشتەجێ بوون و لە دژتان جەنگان و منیش ئەوانم دا بەدەستتانەوە و دەستتان بەسەر خاکەکەیاندا گرت و لەبەردەمتان لەناوم بردن.
\v 9 ئینجا بالاقی کوڕی چیپوری پاشای مۆئاب هەستا و لە دژی ئیسرائیل جەنگا و بەلعامی کوڕی بەعۆری بانگکرد بۆ ئەوەی نەفرەتتان لێ بکات،
\v 10 بەڵام من ئامادە نەبووم گوێ لە بەلعام بگرم، بۆیە ئەویش چەند جارێک داوای بەرەکەتی بۆ کردن\f + \fr 24:10 \ft بڕوانە سەرژمێری بەشی 23 و 24.‏\f* و بەو شێوەیە لە دەستی دەربازم کردن.
\p 
\v 11 «”ئینجا لە ڕووباری ئوردون پەڕینەوە و هاتن بۆ ئەریحا و خەڵکی ئەریحاش، ئەمۆری و پریزی و کەنعانی و حیتی و گرگاشی و حیڤی و یەبوسییەکان لە دژتان جەنگان و منیش ئەوانم دایە دەستتان و
\v 12 زەردەواڵەشم\f + \fr 24:12 \ft دەکرێت هێمایەک بێت بۆ ئەو ترس و لەرزەی خودا خستییە دڵیانەوە. بڕوانە \xt دەرچوون 23‏:28 و دواوتار 7‏:20.‏\xt*\ft ‏\f* لەپێشتانەوە نارد و هەردوو پاشای ئەمۆرییەکانم لەبەردەمتان دەرکرد، نە بە شمشێرەکەت و نە بە کەوانەکەت.
\v 13 ئینجا زەوییەکم پێدان کە پێوەی ماندوو نەبوون و چەند شارێک کە بنیادتان نەناوە و تێیدا نیشتەجێن و ڕەزەمێو و زەیتوونێکیش کە نەتانچاندووە و دەیخۆن.“
\p 
\v 14 «ئێستاش لە یەزدان بترسن و بە تەواوی و دڵسۆزییەوە بیپەرستن. ئەو خودایانەش لە خۆتان دابماڵن کە باوباپیرانتان لەوبەری ڕووباری فورات و لە میسر دەیانپەرست و یەزدان بپەرستن.
\v 15 بەڵام ئەگەر بەلاتانەوە خراپە یەزدان بپەرستن، ئەوا ئەمڕۆ بۆ خۆتان هەڵبژێرن کێ دەپەرستن، ئەگەر ئەو خوداوەندانە بن کە باوباپیرانتان لەوبەری ڕووباری فورات دەیانپەرستن یان خوداوەندەکانی ئەمۆرییەکان ئەوانەی ئێوە لەناو خاکەکەیاندا نیشتەجێن. بەڵام من و بنەماڵەکەم یەزدان دەپەرستین.»
\p 
\v 16 جا گەل وەڵامیان دایەوە و گوتیان: «لە ئێمە بەدوور بێت واز لە یەزدان بهێنین و خوداوەندانی دیکە بپەرستین،
\v 17 چونکە یەزدانی پەروەردگارمان ئێمە و باوباپیرانمانی لە خاکی میسر، لە خاکی کۆیلایەتییەوە هێنایە دەرەوە و ئەو هەموو نیشانە گەورانەی لەبەرچاوماندا کرد. لە هەموو ئەو ڕێگایەی پێیدا ڕۆیشتین و لە کاتی تێپەڕینمان بەناو ئەو هەموو گەلانەدا پارێزگاری لێکردین.
\v 18 هەروەها یەزدان هەموو ئەو گەلانە و لەنێویشیاندا ئەمۆرییەکانی نیشتەجێی خاکەکەی لەبەردەممان دەرکرد، لەبەر ئەوە ئێمە یەزدان دەپەرستین، چونکە ئەو خودامانە.»
\p 
\v 19 یەشوعیش بە گەلی گوت: «ئێوە ناتوانن یەزدان بپەرستن، چونکە ئەو خودایەکی پیرۆز و خودایەکی ئیرەدارە\f + \fr 24:19 \ft ئیرەدار: لێرەدا واتایەکی ئەرێنی لەخۆ دەگرێت، چونکە خودا مرۆڤی خۆشدەوێت و نایەوێت کەسێک پەیوەندی نێوانیان تێک بدات.\f*، لە یاخیبوون و گوناهەکانتان خۆش نابێت.
\v 20 ئەگەر واز لە یەزدان بهێنن و خوداوەندی بێگانە بپەرستن، ئەوا دەگەڕێتەوە و خراپتان بەسەردەهێنێت و کۆتاییتان پێ دەهێنێت، پاش ئەوەی چاکەی لەگەڵتاندا کرد.»
\p 
\v 21 گەلیش بە یەشوعیان گوت: «نەخێر! بەڵکو یەزدان دەپەرستین.»
\p 
\v 22 یەشوعیش پێی گوتن: «ئێوە شایەتن لەسەر خۆتان، کە ئێوە یەزدانتان بۆ خۆتان هەڵبژاردووە بۆ ئەوەی بیپەرستن.»
\p ئەوانیش گوتیان: «ئێمە شایەتین.»
\p 
\v 23 «ئینجا ئێستا ئەو خوداوەندە بێگانانەی لەنێوتاندان دابماڵن و دڵتان بە یەزدانی پەروەردگاری ئیسرائیل بسپێرن.»
\p 
\v 24 گەلیش بە یەشوعیان گوت: «یەزدانی پەروەردگارمان دەپەرستین و گوێڕایەڵی ئەو دەبین.»
\p 
\v 25 ئینجا یەشوع لەو ڕۆژەدا پەیمانێکی لەگەڵ گەلدا بەست و لە شەخەمدا فەرز و یاسای بۆ دانان.
\v 26 یەشوع ئەم وشانەی لە پەڕتووکی تەوراتی خودا نووسی و بەردێکی گەورەی هێنا و لەژێر دار بەڕووەکەی لای پیرۆزگاکەی یەزدان چەقاندی.
\p 
\v 27 یەشوع بە هەموو گەلی گوت: «سەیر بکەن! ئەم بەردە دەبێتە شایەت بەسەرمانەوە، چونکە گوێی لە هەموو وشەکانی یەزدان بوو کە پێی فەرمووین، جا دەبێتە شایەت بەسەرتانەوە نەوەک نکۆڵی لە خودای خۆتان بکەن.»
\p 
\v 28 ئینجا یەشوع گەلی ڕەوانە کردەوە، هەرکەسە و بەرەو میراتەکەی خۆی.
\s1 ناشتنی یەشوع
\p 
\v 29 پاش ئەم شتانە یەشوعی کوڕی نونی بەندەی یەزدان لە تەمەنی سەد و دە ساڵی مرد.
\v 30 لە سنووری میراتەکەی خۆی لە تیمنەت سەرەح کە لە ناوچە شاخاوییەکانی ئەفرایمە لە باکووری کێوی گاعەش ناشتیان.
\p 
\v 31 نەوەی ئیسرائیلیش بە درێژایی سەردەمی یەشوع یەزدانیان دەپەرست، هەروەها بە درێژایی سەردەمی پیران کە لەدوای یەشوع تەمەنیان درێژەی کێشا و هەموو ئەو کارانەیان بینی کە یەزدانی مەزن بۆ ئیسرائیلی ئەنجام دا.
\p 
\v 32 ئێسکەکانی یوسفیش کە نەوەی ئیسرائیل لە میسرەوە هێنایانەوە، لە شەخەمدا ناشتیان لەناو ئەو پارچە کێڵگەیەی کە یاقوب لە نەوەی حەمۆری باوکی شەخەم بە سەد پارچە زیو کڕیبووی و بوو بە میرات بۆ نەوەی یوسف.
\p 
\v 33 ئینجا ئەلعازاری کوڕی هارون مرد و لە گیڤعا ناشتیان، لە ناوچە شاخاوییەکانی ئەفرایم بوو کە درابووە فینەحاسی کوڕی.
