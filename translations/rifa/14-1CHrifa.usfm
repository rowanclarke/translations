\id 1CH
\h 1 إِمزْرُوينْ
\toc1 1 إِمزْرُوينْ
\toc2 1 إِمزْرُوينْ
\toc3 1 إِم.
\mt1 1 إِمزْرُوينْ
\c 1
\s1 جِّيڒَاثْ ن أَذَامْ أَڒْ إِبْرَاهِيمْ ذ إِسْحَاقْ ذ يَاعْقُوبْ
\m 
\v 1 \bd أَذَامْ\bd*، شِيثْ، أَنُوشْ، \x ◘ \xo 1:‏1 \xt [أَمز. 5‏:‏1‏-‏32؛ 10‏:‏1‏-‏32؛ 11‏:‏10‏-‏26؛ 25‏:‏1‏-‏6]\x*
\v 2 قِينَانْ، مَاهَالَالْ-إِلْ، يَارَاذْ،
\v 3 حَانُوخْ، مَاثُوشَالَاحْ، لَامَاكْ،
\m 
\v 4 \bd نُوحْ\bd*، شَامْ، حَامْ، يَافَاثْ.
\b
\m 
\v 5 \bd أَرَّاونْ ن يَافَاثْ\bd* \add ثُوغَا أَثنْ ذ\add* جُومَارْ، مَاجُوجْ، مَاذَايْ، يَاوَانْ، ثُوبَالْ، مَاشِيكْ ذ ثِيرَاسْ. \f ◼ \fr 1:‏5 \ft \bd ’مَاجُوجْ‘\bd* - نِيغْ ’مَاخُوخْ‘، نِيغْ ’مَاڭُوڭْ‘.\f*
\m 
\v 6 أَرَّاونْ ن جُومَارْ \add ثُوغَا أَثنْ ذ\add* أَشْكَانَازْ، ذِيفَاثْ ذ ثُوجَارْمَا. \f ◼ \fr 1:‏6 \ft \bd ’ذِيفَاثْ‘\bd* - ذڭْ وذْلِيسْ أَمز. 10‏:3 نُوفَا ’رِيفَاثْ‘.\f*
\m 
\v 7 أَرَّاونْ ن يَاوَانْ \add ثُوغَا أَثنْ ذ\add* إِلِيشَا، ثَارْشِيشَا، إِكِيتِّييّنْ ذ إِذُوذَانِييّنْ. \f ◼ \fr 1:‏7 \ft \bd ’ثَارْشِيشَا‘\bd* - ذڭْ وذْلِيسْ أَمز. 10‏:4 نُوفَا ’ثَارْشِيشْ‘.\f*
\b
\m 
\v 8 \bd أَرَّاونْ ن حَامْ\bd* \add ثُوغَا أَثنْ ذ\add* كُوشْ، مِيصْرَايِيمْ، فُوطْ ذ كنْعَانْ.
\m 
\v 9 أَرَّاونْ ن كُوشْ \add ثُوغَا أَثنْ ذ\add* سبَا، حَاوِيلَا، سَابْثَا، رَاعَامَا ذ سَابْثَاكَا.
\m أَرَّاونْ ن رَاعَامَا \add ثُوغَا أَثنْ ذ\add* شَابَا ذ ذَاذَانْ.
\m 
\v 10 كُوشْ إِجَّا-د نِيمْرُوذْ. وَانِيثَا إِبْذَا أَذْ يِيڒِي ذ إِجّْ ن جِّيهڒْ خْ ثمُّورْثْ.
\m 
\v 11 مِيصْرَايِيمْ إِجَّا-د إِلُوذِييّنْ، إِعَانَامِييّنْ، إِلَاهَابِييّنْ، إِنَافْثُوحِييّنْ،
\m 
\v 12 إِفَاثْرُوسِييّنْ، إِكَاسْلُوحِييّنْ، إِنِّي زِي إِ د-إِقَّارْصنْ إِفِيلِيسْطِينِييّنْ، ؤُڒَا ذ إِكَافْثُورِييّنْ.
\m 
\v 13 كنْعَانْ إِجَّا-د صِيذُونْ، أَمنْزُو نّسْ، ذ حِيثْ،
\v 14 أَيابُوسِي، أَمُورِي، أَجِيرْجَاشِي،
\v 15 أَحِيوِي، أَعَارْقِي، أَسِينِييْ،
\v 16 أَرْوَاذِي، أَصَامَارِي ذ ؤُحَامَاثِي.
\b
\m 
\v 17 \bd أَرَّاونْ ن شَامْ\bd* \add ثُوغَا أَثنْ ذ\add* عِيلَامْ أَشُّورْ، أَرْفَاكْشَاذْ، لُوذْ، أَرَامْ، عُوزْ، حُولْ، جَاثَارْ ذ مَاشِيكْ.
\m 
\v 18 أَرْفَاكْشَاذْ إِجَّا-د شَالَاحْ ؤُ شَالَاحْ إِجَّا-د عَابِيرْ.
\m 
\v 19 تّْوَارْونْ-د إِ عَابِيرْ ثْنَاينْ ن وَارَّاونْ. إِجّنْ قَّارنْ أَسْ فَالَاجْ، مِينْزِي ذڭْ وُوسَّانْ نّسْ ثتّْوَابْضَا ثمُّورْثْ، ؤُشَا قَّارنْ أَسْ إِ ؤُمَاسْ يُوقْطَانْ.
\m 
\v 20 يُوقْطَانْ إِجَّا-د أَلْمُوذَاذْ، شَالَافْ، هَاضَارْمَاوْثْ، يَارَاحْ،
\v 21 هَاذُورَامْ، ؤُزَالْ، ذِيقْلَا،
\v 22 عِيبَالْ، أَبِيمَايِيلْ، شَابَا، \f ◼ \fr 1:‏22 \ft \bd ’عِيبَالْ‘\bd* - ذڭْ وذْلِيسْ أَمز. 10‏:28 نُوفَا ’عُوبَالْ‘.\f*
\v 23 ؤُفِيرْ، حَاوِيلَا ذ يُوبَابْ. مَارَّا إِنَا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن يُوقْطَانْ.
\b
\m 
\v 24 \bd شَامْ\bd*، أَرْفَاكْشَاذْ، شَالَاحْ،
\v 25 عَابِيرْ، فَالَاحْ، رَاعُووْ،
\v 26 سَارُوجْ، نَاحُورْ، ثَارَاحْ،
\v 27 أَبْرَامْ، وَا ذ \bd إِبْرَاهِيمْ\bd*.
\m 
\v 28 أَرَّاونْ ن إِبْرَاهِيمْ \add ثُوغَا أَثنْ ذ\add* \bd إِسْحَاقْ\bd* ذ \bd إِسْمَاعِيلْ\bd*.
\b
\m 
\v 29 إِنَا ذ إِنِّي زَّايْسنْ د-إِتّْوَارْونْ:
\m أَمنْزُو \bd ن إِسْمَاعِيلْ\bd* \add ثُوغَا-ث ذ\add* نَابَايُوثْ، \add خنِّي\add* قِيذَارْ، أَذَابِيلْ، مِيبْسَامْ، \x ◘ \xo 1:‏29 \xt أَمز. 25‏:‏12‏-‏18\x*
\v 30 مِيشْمَاعْ، ذُومَا، مَاسَّا، حَاذَاذْ ذ ثَايْمَا،
\v 31 يَاطُورْ، نَافِيشْ ذ قِيذْمَا. إِنَا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن إِسْمَاعِيلْ.
\b
\m 
\v 32 \bd أَرَّاونْ ن قَاطُورَا\bd*، ثَايَّا ن إِبْرَاهِيمْ: نتَّاثْ ثُورُووْ-د زِيمْرَانْ، يُوقْشَانْ، مَاذَانْ، مِيذْيَانْ، يِيشْبَاقْ ذ شُوحَا. أَرَّاونْ ن يُوقْشَانْ \add ثُوغَا أَثنْ ذ\add* شَابَا ذ ذَاذَانْ. \x ◘ \xo 1:‏32 \xt أَمز. 25‏:‏1‏-‏6\x*
\m 
\v 33 أَرَّاونْ ن مِيذْيَانْ \add ثُوغَا أَثنْ ذ\add* عِييْفَا، عِيفَارْ، حَانُوخْ، أَبِيذَاعْ ذ أَلْذَاعَا.
\m نِيثْنِي مَارَّا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن قَاطُورَا.
\b
\m 
\v 34 إِبْرَاهِيمْ إِجَّا-د \bd إِسْحَاقْ\bd*. أَرَّاونْ ن إِسْحَاقْ \add ثُوغَا أَثنْ ذ\add* \bd عِيسُو\bd* ذ \bd إِسْرَائِيل\bd*. \x ◘ \xo 1:‏34 \xt أَمز. 25‏:‏1‏-‏6\x*
\b
\m 
\v 35 \bd أَرَّاونْ ن عِيسُو\bd* \add ثُوغَا أَثنْ ذ\add* إِلِيفَازْ، رَاعُووِيلْ، يَاعُوشْ، يَاعْلَامْ ذ قُورَاحْ.
\m 
\v 36 أَرَّاونْ ن إِلِيفَازْ \add ثُوغَا أَثنْ ذ\add* ثَايْمَانْ، ؤُمَارْ، صَافِي، جَاعْثَامْ، قِينَازْ، ثِيمْنَاعْ ذ عَامَالِيقْ. \f ◼ \fr 1:‏36 \ft \bd ’قِينَازْ‘\bd* - ذڭْ وذْلِيسْ أَمز. 36‏:11 نُوفَا ’زِيفُو‘. \bd ’ثِيمْنَاعْ‘\bd* - إِسمْ وَانِيثَا وَارْ ث نُوفَا ذڭْ وذْلِيسْ أَمزْوَارُو، ؤُذمْ 36. أَذْ ثَاغْ إِشيَّارْ إِسمْ وَانِيثَا غَارْ إِشْثْ ن ثمْغَارْثْ ثنِّي ثَارُو عَامَالِيقْ إِ إِلِيفَازْ.\f*
\m 
\v 37 أَرَّاونْ ن رَاعُويِيلْ \add ثُوغَا أَثنْ ذ\add* نَاحَاثْ، زَارَاحْ، شَامَّا ذ مِيزَّا.
\m 
\v 38 \bd أَرَّاونْ ن سَاعِيرْ\bd* \add ثُوغَا أَثنْ ذ\add* لُوطَانْ، شُوبَالْ، صِيبْعُونْ، عَانَا، ذِيشُونْ، إِصَارْ ذ ذِيشَانْ. \x ◘ \xo 1:‏38 \xt أَمز. 36‏:‏20‏-‏30\x*
\m 
\v 39 أَرَّاونْ ن لُوطَانْ \add ثُوغَا أَثنْ ذ\add* أَخُورِي ذ هُومَامْ ؤُشَا \add ثُوغَا\add* ثِيمْنَاعْ ذ ؤُتْشْمَاسْ ن لُوطَانْ. \f ◼ \fr 1:‏39 \ft \bd ’هُومَامْ‘\bd* - ذڭْ وذْلِيسْ أَمز. 1‏:39 نُوفَا ’هَايْمَامْ‘.\f*
\m 
\v 40 أَرَّاونْ ن شُوبَالْ \add ثُوغَا أَثنْ ذ\add* عَالْيَانْ، مَانَاحَاثْ، عِيبَالْ، شَافِي ذ ؤُنَامْ.
\m أَرَّاونْ ن صِيبْعُونْ \add ثُوغَا أَثنْ ذ\add* أَيَا ذ عَانَا.\f ◼ \fr 1:‏40 \ft \bd ’عَالْيَانْ‘\bd* - ذڭْ وذْلِيسْ أَمز. 36‏:23 نُوفَا ’عَالْوَانْ‘. \bd ’شَافِي‘\bd* - ذڭْ وذْلِيسْ أَمز. 36‏:23 نُوفَا ’شَافُو‘. \bd ’صِيبْعُونْ‘\bd* - ذڭْ وذْلِيسْ أَمز. 36‏:24 نُوفَا ’صَابْعُونْ‘.\f*
\m 
\v 41 أَرَّاونْ ن عَانَا \add مْغِيرْ\add*: ذِيشُونْ.
\m أَرَّاونْ ن ذِيشُونْ \add ثُوغَا أَثنْ ذ\add* حَامْرَانْ، إِشْبَانْ، يِيثْرَانْ ذ كَارَانْ.
\m 
\v 42 أَرَّاونْ ن إِصَارْ \add ثُوغَا أَثنْ ذ\add* بِيلْهَانْ ذ زَاعْوَانْ ذ يَاعْكَانْ.
\m أَرَّاونْ ن ذِيشُونْ \add ثُوغَا أَثنْ ذ\add* عُوصْ ذ أَرَانْ. \f ◼ \fr 1:‏42 \ft \bd ’يَاعْكَانْ‘\bd* - ذڭْ وذْلِيسْ أَمز. 36‏:27 نُوفَا ’عَاقَانْ‘.\f*
\m 
\v 43 إِنَا ذ \bd إِجدْجِيذنْ إِ ثُوغَا إِدْجَانْ خْ إِذُومْ\bd*، قْبڒْ مَا ثُوغَا إِحكّمْ إِجّْ ن ؤُجدْجِيذْ خْ أَيْثْ ن إِسْرَائِيل:
\m بِيلَاعْ، مِّيسْ ن بَاعُورْ. ثَانْذِينْثْ نّسْ قَّارنْ أَسْ ذِينْهَابَا. \x ◘ \xo 1:‏43 \xt أَمز. 36‏:‏31‏-‏43\x*
\m 
\v 44 إِمُّوثْ بِيلَاعْ ؤُشَا يُووَابْ، مِّيسْ ن زَارَاحْ، زِي بُوصْرَا، إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\m 
\v 45 إِمُّوثْ يُووَابْ ؤُشَا حُوشَامْ زِي ثمُّورْثْ ن إِثَايْمَانِييّنْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\m 
\v 46 إِمُّوثْ حُوشَامْ ؤُشَا هَاذَاذْ مِّيسْ ن بَاذَاذْ ونِّي إِغڒْبنْ مِيذْيَانْ ذڭْ إِيَّارْ ن مُوآبَ، إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. إِسمْ ن ثنْذِينْثْ نّسْ قَّارنْ أَسْ عَاوِيثْ.
\m 
\v 47 إِمُّوثْ هَاذَاذْ ؤُشَا سَامْلَا زِي مَاسْرِيقَا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\m 
\v 48 إِمُّوثْ سَامْلَا ؤُشَا شَاوُولْ، زِي رَاحُوبُوثْ غَارْ يغْزَارْ \add ن لْفُورَاطْ\add*، إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\m 
\v 49 إِمُّوثْ شَاوُولْ ؤُشَا بَاعْلْ-حَانَانْ، مِّيسْ ن عَاكْبُورْ، إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\m 
\v 50 إِمُّوثْ بَاعْلْ-حَانَانْ ؤُشَا هَاذَاذْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. ثَانْذِينْثْ نّسْ قَّارنْ أَسْ فَاعِي ؤُ ثَامْغَارْثْ نّسْ قَّارنْ أَسْ مَاهِيطَابْ‘إِلْ، يدْجِيسْ ن مَاطْرِيذْ، يدْجِيسْ ن مَا-ذَاهَابْ. \f ◼ \fr 1:‏50 \ft \bd ’هَاذَاذْ‘\bd* - ذڭْ وذْلِيسْ أَمز. 36‏:39 نُوفَا ’هَاذَارْ‘. \bd ’بَاهِي‘\bd* - ذڭْ وذْلِيسْ أَمز. 36‏:39 نُوفَا ’بَاهُو‘.\f*
\b
\m 
\v 51 إِمُّوثْ هَاذَاذْ ؤُشَا \add خنِّي\add* ذوْڒنْ \add يِينَا\add* ذ \bd إِمْغَارنْ ن إِذُومْ\bd*:
\m أَمْغَارْ ثِيمْنَاعْ، ذ ؤُمْغَارْ عَالْوَا، ذ ؤُمْغَارْ يَاثِيثْ،
\m 
\v 52 ذ ؤُمْغَارْ أَهُولِيبَامَا، ذ ؤُمْغَارْ إِلَا، ذ ؤُمْغَارْ فِينُونْ،
\m 
\v 53 ذ ؤُمْغَارْ قَانَازْ، ذ ؤُمْغَارْ ثَايْمَانْ، ذ ؤُمْغَارْ مِيبْصَارْ،
\m 
\v 54 ذ ؤُمْغَارْ مَاجْذِييِيلْ، ذ ؤُمْغَارْ عِيرَامْ.
\m إِنَا \add ثُوغَا أَثنْ ذ\add* إِمْغَارنْ ن ثْقبَّاڒْ ن إِذُومْ.
\b
\b
\c 2
\s1 ثنْعَاشْ ن إِحنْجِيرنْ ن إِسْرَائِيل
\m 
\v 1 إِنَا \add ثُوغَا أَثنْ ذ\add* \bd أَيْثْ ن إِسْرَائِيل\bd*: رُوبِينْ، شِيمْعُونْ، لَاوِي ذ يَاهُوذَا، إِسَّاكَارْ ذ زابُولُونْ،
\v 2 ذَانْ، يُوسُوفْ ذ بِينْيَامِينْ، نَافْثَالِي، جَاذْ ذ أَشِيرْ.
\b
\m 
\v 3 \bd أَرَّاونْ ن يَاهُوذَا\bd* \add ثُوغَا أَثنْ ذ\add* عِيرْ ذ ؤُنَانْ ذ شَايْلَا. أَقَا ثْڒَاثَا\add -يَا\add* تّْوَارْونْ أَسْ-د زڭْ يدْجِيسْ ن شُوعَا، ثَاكنْعَانِيثْ. عِيرْ، أَمنْزُو ن يَاهُوذَا، ثُوغَا ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي. س ؤُينِّي إِنْغَا إِ-ث.
\m 
\v 4 ثَامَارْ، ثَاسْڒِيثْ نّسْ، ثُورُووْ أَسْ-د فَارِيصْ ذ زَارَاحْ. يَاهُوذَا \add ثُوغَا غَارسْ\add* س مَارَّا خمْسَا ن وَارَّاونْ.
\b
\m 
\v 5 \bd أَرَّاونْ ن فَارِيصْ\bd* \add ثُوغَا أَثنْ ذ\add* حَاصْرُونْ ذ حَامُولْ.
\m 
\v 6 أَرَّاونْ ن زَارَاحْ \add ثُوغَا أَثنْ ذ\add* زِيمْرِي، إِثَانْ، هَايْمَانْ، كَالْكُولْ ذ ذَارَاعْ. س مَارَّا خمْسَا.
\m 
\v 7 أَرَّاونْ ن كَارْمِي \add ثُوغَا أَثنْ ذ\add* عَاخَارْ، ونِّي إِغضْڒنْ إِسْرَائِيل ذِي ڒغْبنْ، مِينْزِي إِڭَّا س ڒغْذَارْ أَكْ-ذ مِينْ ثُوغَا إِتّْوَاحَارّْمنْ \add إِ ؤُثحِّي\add*.
\m 
\v 8 أَرَّاونْ ن إِثَانْ: \add مْغِيرْ\add* عَازَارْيَا.
\b
\m 
\v 9 \bd أَرَّاونْ ن حَاصْرُونْ\bd* إِنِّي ذ أَسْ د-إِتّْوَارْونْ \add ثُوغَا أَثنْ ذ\add* يَارْحَامْ‘إِلْ ذ رَامْ ذ كَالُوبَايْ.
\b
\m 
\v 10 \bd رَامْ\bd* إِجَّا-د عَامِّينَاذَابْ.
\m عَامِّينَاذَابْ إِجَّا-د نَاحْشُونْ، ڒْحَاكمْ ن أَيْثْ ن يَاهُوذَا.
\m 
\v 11 نَاحْشُونْ إِجَّا-د سَالْمُو.
\m سَالْمُو إِجَّا-د بُوعَازْ.
\m 
\v 12 بُوعَازْ إِجَّا-د عُوبِيذْ.
\m عُوبِيذْ إِجَّا-د يَاسَّا.
\m 
\v 13 \bd يَاسَّا\bd* إِجَّا-د إِلِييَابْ، أَمنْزُو نّسْ، وِيسّْ ثْنَاينْ أَبِينَاذَابْ، وِيسّْ ثْڒَاثَا شِيمْعَا،
\v 14 وِيسّْ أَربْعَا نَاثَانَايِيلْ، وِيسّْ خمْسَا رَادَّايْ،
\v 15 وِيسّْ ستَّا ؤُصَامْ ذ وِيسّْ سبْعَا \bd ذَاوُوذْ\bd*.
\m 
\v 16 سُويثْمَاثْسنْ \add ثُوغَا أَثنْ ذ\add* صَارُويَا ذ أَبِيجَايِيلْ.
\m أَرَّاونْ ن صَارُويَا \add ثُوغَا أَثنْ ذ\add* أَبِيشَايْ ذ يُووَابْ ذ عَسَائِيلْ، ثْڒَاثَا \add ن وَارَّاونْ\add*.
\m 
\v 17 أَبِيجَايِيلْ ثُورُووْ-د عَامَاسَا ؤُ بَابَاسْ ن عَامَاسَا \add ثُوغَا-ث\add* ذ يَاثْرُو، ونِّي ذ أَسْمَاعِيلِي.
\b
\m 
\v 18 \bd كَالِيبْ\bd*، مِّيسْ ن حَاصْرُونْ، إِجَّا-د أَكْ-ذ عَازُوبَا، ثَامْغَارْثْ \add نّسْ\add*، \add يدْجِيسْ\add* يَارِيعُوثْ.
\m ذ إِنَا \add ثُوغَا أَثنْ\add* ذ أَرَّاونْ نّسْ: يَاشَارْ، شُوبَابْ ذ أَرْذُونْ.
\m 
\v 19 \add ؤُمِي\add* إِمُّوثْ عَازُوبَا، يِيوِي كَالِيبْ إِفْرَاثْ\add أَ\add* \add ذ ثَامْغَارْثْ\add* إِ يِيخفْ نّسْ ؤُ نتَّاثْ ثُورُووْ أَسْ-د حُورْ.
\m 
\v 20 حُورْ إِجَّا-د ؤُرِي ؤُ ؤُرِي إِجَّا-د بَاصَالْيِيلْ.
\b
\m 
\v 21 أَوَارْنِي أَسْ يُوذفْ حَاصْرُونْ خْ يدْجِيسْ ن مَاخِيرْ، بَابَاسْ ن جِيلْعَاذْ، ؤُ نتَّا يِيوْيِي ت \add ذ ثَامْغَارْثْ\add* ؤُمِي غَارسْ ثُوغَا ستِّينْ ن إِسڭّْوُوسَا ؤُ نتَّاثْ ثُورُووْ أَسْ-د \bd سَاجُوبْ\bd*.
\m 
\v 22 سَاجُوبْ إِجَّا-د يَا‘إِرْ. نتَّا \add ثُوغَا\add* غَارسْ ثْڒَاثَا ؤُ-عِيشْرِينْ ن ثْندَّامْ ذِي ثمُّورْثْ ن جِيلْعَاذْ.
\m 
\v 23 جَاشُورْ أَكْ-ذ أَرَامْ إِكّسْ زَّايْسنْ ذْشُورَاثْ ن يَا‘إِرْ، ؤُڒَا ذ قَانَاثْ ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ، س مَارَّا ستِّينْ ن ثْندَّامْ.
\m إِنَا مَارَّا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن مَاخِيرْ، بَابَاسْ ن جِيلْعَاذْ. \x ◘ \xo 2:‏23 \xt ڒخْڒ. 32‏:‏41، 42؛ أَعَوذ. 3‏:‏4، 14\x*
\m 
\v 24 أَوَارْنِي ڒْموْثْ ن حَاصْرُونْ ذِي كَالِيبْ-إِفْرَاثَا، ثُورُووْ أَسْ-د أَبِييَا، ثَامْغَارْثْ ن حَاصْرُونْ، \bd أَشْحُورْ\bd*، بَابَاسْ ن ثَاقُوعَا.
\b
\m 
\v 25 \bd أَرَّاونْ ن يَارْحَامْ‘إِلْ\bd*، أَمنْزُو ن حَاصْرُونْ، \add ثُوغَا أَثنْ ذ\add* رَامْ، أَمنْزُو، \add خنِّي\add* بُونَا، أَوْرَانْ، ؤُصَامْ ذ أَخِييَا.
\m 
\v 26 يَارْحَامْ‘إِلْ ثُوغَا غَارسْ عَاذْ إِشْثْ ن ثمْغَارْثْ نّغْنِيثْ، قَّارنْ أَسْ أَطَارَا. نتَّاثْ \add ثُوغَا\add* ذ يمَّاسْ ن ؤُنَامْ.
\b
\m 
\v 27 أَرَّاونْ ن رَامْ، أَمنْزُو ن يَارْحَامْ‘إِلْ، \add ثُوغَا أَثنْ ذ\add* مَاعَاصْ ذ يَامِينْ ذ عَاقَارْ.
\m 
\v 28 أَرَّاونْ ن ؤُنَامْ \add ثُوغَا أَثنْ ذ\add* شَامَّايْ ذ يَاذَاعْ.
\m أَرَّاونْ ن شَامَّايْ \add ثُوغَا أَثنْ ذ\add* نَاذَابْ ذ أَبِيشُورْ.
\m 
\v 29 ثَامْغَارْثْ ن أَبِيشُورْ قَّارنْ أَسْ أَبِيحَايِيلْ. نتَّاثْ ثُورُووْ أَسْ-د أَحْبَانْ ذ مُولِيذْ.
\m 
\v 30 أَرَّاونْ ن نَاذَابْ \add ثُوغَا أَثنْ ذ\add* سَالَاذْ ذ أَفَّايِيمْ.
\m سَالَاذْ إِمُّوثْ بْڒَا أَرَّاونْ.
\m 
\v 31 أَرَّاونْ ن أَفَّايِيمْ: \add مْغِيرْ\add* يِيشْعِي.
\m أَرَّاونْ ن يِيشْعِي: \add مْغِيرْ\add* شِيشَانْ.
\m أَرَّاونْ ن شِيشَانْ: \add مْغِيرْ إِشْثْ ن يدْجِيسْ\add*، أَحْلَايْ.
\m 
\v 32 أَرَّاونْ ن يَاذَاعْ، ؤُمَاسْ ن شَامَّايْ، \add ثُوغَا أَثنْ ذ\add* يَاثْرُو ذ يُونَاثَانْ.
\m يَاثْرُو إِمُّوثْ بْڒَا أَرَّاونْ.
\m 
\v 33 أَرَّاونْ ن يُونَاثَانْ \add ثُوغَا أَثنْ ذ\add* فَالَاثْ ذ زَازَا.
\m إِنَا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن يَارْحَامْ‘إِلْ.
\b
\m 
\v 34 شِيشَانْ ثُوغَا وَارْ غَارسْ بُو وَارَّاونْ مَاشَا يسِّيسْ \add وَاهْ\add*. شِيشَانْ ثُوغَا غَارسْ إِجّْ ن ؤُمْسخَّارْ ذ أَمِيصْرِي، قَّارنْ أَسْ يَارْحَاعْ.
\v 35 شِيشَانْ إِوْشَا يدْجِيسْ ذ ثَامْغَارْثْ إِ ؤُمْسخَّارْ نّسْ يَارْحَاعْ ؤُ نتَّاثْ ثُورُووْ أَسْ-د عَاتَّايْ.
\m 
\v 36 عَاتَّايْ إِجَّا-د نَاثَانْ،
\m نَاثَانْ إِجَّا-د زَابَاذْ،
\m 
\v 37 زَابَاذْ إِجَّا-د إِفْلَالْ،
\m إِفْلَالْ إِجَّا-د عُوبِيذْ،
\m 
\v 38 عُوبِيذْ إِجَّا-د يَاهُو،
\m يَاهُو إِجَّا-د عَازَارْيَا،
\m 
\v 39 عَازَارْيَا إِجَّا-د حَالَاصْ،
\m حَالَاصْ إِجَّا-د إِلْعَاسَا،
\m 
\v 40 إِلْعَاسَا إِجَّا-د سِيسْمَايْ،
\m سِيسْمَايْ إِجَّا-د شَالُّومْ،
\m 
\v 41 شَالُّومْ إِجَّا-د يَاقَامْيَا
\m ؤُ يَاقَامْيَا إِجَّا-د إِلِيشَامَاعْ.
\b
\m 
\v 42 \bd أَرَّاونْ ن كَالِيبْ\bd*، ؤُمَاسْ ن يَارْحَامْ‘إِلْ: \add مْغِيرْ\add* مِيشَاعْ، أَمنْزُو نّسْ ونِّي ذ بَابَاسْ ن زِيفْ، ؤُڒَا ذ أَرَّاونْ ن مَارِيشَا، بَابَاسْ ن حَابْرُونْ.
\m 
\v 43 أَرَّاونْ ن حَابْرُونْ \add ثُوغَا أَثنْ ذ\add* قُورَاحْ، ثَافُّوعْ، رَاقَامْ ذ شَامَاعْ.
\m 
\v 44 شَامَاعْ إِجَّا-د رَاحَامْ، بَابَاسْ ن جَارَاقْعَامْ،
\m ؤُ رَاقَامْ إِجَّا-د شَامَّايْ.
\m 
\v 45 مِّيسْ ن شَامَّا إِ \add ثُوغَا-ث ذ\add* مَاعُونْ.
\m مَاعُونْ ثُوغَا ذ بَابَاسْ ن بَايْثْ-صُورْ.
\m 
\v 46 عِييْفَا، ثَايَّا ن كَالِيبْ، ثُورُووْ-د حَارَانْ، مُوصَا ذ جَازِيزْ.
\m حَارَانْ إِجَّا-د جَازِيزْ.
\m 
\v 47 أَرَّاونْ ن جَاهْ-ذَايْ \add ثُوغَا أَثنْ ذ\add* رَاجَامْ، يُوثَامْ، جِيشَانْ، فَالَاطْ، عِييْفَا ذ شَاعَافْ.
\m 
\v 48 \add أَكْ-ذ\add* ثَايَّا ن كَالِيبْ، مَاعْكَا، إِجَّا-د نتَّا شَابَارْ ذ ثَارْحَانَا.
\m 
\v 49 نتَّاثْ ثُورُووْ-د شَاعَافْ، بَابَاسْ ن مَاذْمَانَّا، ذ شَاوَا، بَابَاسْ ن مَاكْبِينَا ذ بَابَاسْ ن جِيبْعَا. يدْجِيسْ ن كَالِيبْ ثُوغَا عَاكْسَا.
\m 
\v 50 إِنَا ذ أَرَّاونْ ن كَالِيبْ: مِّيسْ ن حُورْ، أَمنْزُو ن إِفْرَاثَا، \add ثُوغَا\add* شُوبَالْ، بَابَاسْ ن قَارْيَاثْ-يَاعَارِيمْ،
\v 51 سَالْمَا، بَابَاسْ ن بَايْثْ-لَاحْمْ، \add ذ\add* حَارِيفْ، بَابَاسْ ن بَايْثْ-جَاذِيرْ.
\m 
\v 52 أَرَّاونْ ن شُوبَالْ، بَابَاسْ ن قَارْيَاثْ-يَاعَارِيمْ، \add ثُوغَا أَثنْ ذ\add* هَارُووَا ذ حَاصِي-هَا-مَانُوحُوثْ.
\m 
\v 53 ثِيوَاشُونِينْ ن قَارْيَاثْ-يَاعَارِيمْ \add ثُوغَا أَثنْ ذ\add* إِيِيثْرِييّنْ، إِفُّوثِييّنْ، إِشَامَاثِييّنْ ذ إِمَاشْرَاعِييّنْ. زَّايْسنْ إِ د-إِقَّارْصنْ إِصَارْعِييّنْ ذ إِشْثَاوُولِييّنْ.
\m 
\v 54 أَرَّاونْ ن سَالْمَا: \add مْغِيرْ\add* بَايْثْ-لَاحْمْ، ؤُشَا إِنَاطُوفَاثِييّنْ \add ثُوغَا أَثنْ\add*: عَاطَارُوثْ-بَايْثْ-يُو‘أَبْ ذ حَاصِي-هَا-مَانَاحْثِي ذ إِصُورْعِييّنْ.
\m 
\v 55 ثِيوَاشُونِينْ ن إِمَارِيرنْ نِّي إِزدّْغنْ ذِي يَاعْبِيصْ، \add ثُوغَا أَثنْ ذ\add* إِثِيرْعَاثِييّنْ ذ إِشَامْعَايّنْ ذ إِسُوكَانِييّنْ. نِيثْنِي ذ إِقِينِييّنْ إِنِّي د-إِقَّارْصنْ زِي حَامَّاثْ، بَابَاسْ ن ثَادَّارْثْ ن رَاكَابْ.
\b
\b
\c 3
\m 
\v 1 إِنَا \add ثُوغَا\add* ذ \bd أَرَّاونْ ن ذَاوُوذْ إِنِّي ذ أَسْ د-إِتّْوَارْونْ ذِي حَابْرُونْ\bd*: أَمنْزُو \add ثُوغَا\add* ذ أَمْنُونْ ن أَخِينُوعَامْ، ثَايَازْرَاعِيلِيثْ؛ وِيسّْ ثْنَاينْ ذَانِييَالْ ن أَبِيجَايِيلْ، ثَاكَارْمَالِيثْ؛ \f ◼ \fr 3:‏1 \ft \bd ’ثَايَازْرَاعِيلِيثْ‘\bd* - إِشْثْ ن ثمْغَارْثْ زِي يَازْرَاعِيلْ. \bd ’ثَاكَارْمَالِيثْ‘\bd* - إِشْثْ ن ثمْغَارْثْ زِي كَارْمِيلْ.\f*
\v 2 وِيسّْ ثْڒَاثَا أَبْشَالُومْ، مِّيسْ ن مَاعْكَا، يدْجِيسْ ن ثَالْمَايْ، أَجدْجِيذْ ن جَاشُورْ؛ وِيسّْ أَربْعَا أَذُونِييَا، مِّيسْ ن هَاجِّيثْ؛
\v 3 وِيسّْ خمْسَا شَافَاطْيَا ن أَبِيطَالْ، وِيسّْ ستَّا يِيثَارْعَامْ، ن ثمْغَارْثْ نّسْ عَاجْلَا.
\v 4 تّْوَارْونْ أَسْ-د ستَّا ذِي حَابْرُونْ، مِينْزِي إِحْكمْ ذِينِّي سبْعَا ن إِسڭّْوُوسَا ذ ستَّا ن إِيُورنْ ؤُ ذِي ؤُرْشَالِيمْ إِحْكمْ ثْڒَاثَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا.
\b
\m 
\v 5 \bd إِنَا تّْوَارْونْ أَسْ-د ذِي ؤُرْشَالِيمْ:\bd* شِيمْعَا، شُوبَابْ، نَاثَانْ، سُولِيمَانْ. أَربْعَا-يَا ثُوغَا أَثنْ ذ أَرَّاونْ ن بَاثْ-شُوعْ، يدْجِيسْ ن عَامِّييِيلْ. \f ◼ \fr 3:‏5 \ft \bd ’بَاثْ-شُوعْ‘\bd* - إِسمْ-أَ وَانِيثَا ؤُرِينْ ث ’بَاثْشَابَاعْ‘ مَانِي نّغْنِي.\f*
\m 
\v 6 \add خنِّي\add* يِيبْحَارْ، إِلِيشَامْعَا، إِلِيفَالَاطْ،
\v 7 نُوجَاهْ، نَافَاجْ، يَافِيعْ،
\v 8 إِلِيشَامَاعْ، إِلِييَاذَاعْ، إِلِيفَالَاطْ، ثسْعَا \add ن وَارَّاونْ\add*.
\m 
\v 9 إِنَا مَارَّا ذ أَرَّاونْ ن ذَاوُوذْ، نْهْڒَا أَرَّاونْ ن ثِييَّا، ؤُ ثَامَارْ \add ثُوغَا\add* ذ ؤُتْشْمَاثْسنْ.
\b
\m 
\v 10 \bd مِّيسْ ن سُولِيمَانْ \bdit ثُوغَا-ث ذ\bdit* رَاحَابْعَامْ\bd*، مِّيسْ أَبِييَا، مِّيسْ أَسَا، مِّيسْ يَاهُوشَافَاطْ،
\v 11 مِّيسْ يَاهُورَامْ، مِّيسْ أَخَازْيَا، مِّيسْ يُووَاشْ،
\v 12 مِّيسْ أَمَاصْيَا، مِّيسْ عَازَارْيَا، مِّيسْ يُوثَامْ،
\v 13 مِّيسْ أَحَازْ، مِّيسْ حِيزْقِييَا، مِّيسْ مَانَاسَّا،
\v 14 مِّيسْ أَمُونْ \add ذ\add* مِّيسْ يُوشِييَا.
\m 
\v 15 أَرَّاونْ ن يُوشِييَا \add ثُوغَا أَثنْ ذ\add* أَمنْزُو يُوحَانَانْ، وِيسّْ ثْنَاينْ يَاهُويَاقِيمْ، وِيسّْ ثْڒَاثَا صِيذْقِييَا، وِيسّْ أَربْعَا شَالُّومْ.
\m 
\v 16 أَرَّاونْ ن يَاهُويَاقِيمْ: مِّيسْ يَاكُونْيَا \add ذ\add* مِّيسْ صِيذْقِييَا.
\m 
\v 17 أَرَّاونْ ن يَاكُونْيَا: أَسِّيرْ، شَاعَالْثِييِيلْ \add ثُوغَا\add* ذ مِّيسْ،
\v 18 ؤُ \add خنِّي\add* مَالْكِيرَامْ ذ فَاذَايَا ذ شِينَاصَّارْ ذ يَاقَامْيَا ذ هُوشَامْعَا ذ نَاذَابْيَا.
\m 
\v 19 أَرَّاونْ ن فَاذَايَا \add ثُوغَا أَثنْ ذ\add* زَارُوبَّابِيلْ ذ شِيمْعِي.
\m أَرَّاونْ ن زَارُوبَّابِيلْ \add ثُوغَا أَثنْ ذ\add* مَاشُولَّامْ ذ حَانَانْيَا، ؤُ ؤُتْشْمَاثْسنْ \add ثُوغَا-ت ذ\add* شَالُومِيثْ،
\v 20 ؤُ \add خنِّي\add* حَاشُوبَا ذ ؤُوْهِيلْ ذ بَارَاخْيَا ذ حَاسَاذْيَا ذ يُوشَابْ-حَاسَاذْ، خمْسَا \add ن وَارَّاونْ\add*.
\m 
\v 21 أَرَّاونْ ن حَانَانْ-يَاهْ \add ثُوغَا أَثنْ\add* فَالَاطْ-يَاهْ، ذ إِشَاعْيَا. أَرَّاونْ ن رَافَايَا، أَرَّاونْ ن أَرْنَانْ، أَرَّاونْ نْ عُوبَاذْيَا، أَرَّاونْ ن شَاكَانْيَا.
\m 
\v 22 أَرَّاونْ ن شَاخَانْيَا، \add مْغِيرْ\add* شَامْعِييَا.
\m أَرَّاونْ ن شِيمْعِييَا \add ثُوغَا أَثنْ ذ\add* حَاتُّوشْ، يِيجْعَالْ، بَارِيحْ، نَاعَارْيَا ذ شَافَاثْ، ستَّا \add ن وَارَّاونْ\add*.
\m 
\v 23 أَرَّاونْ ن نَاعَارْيَا \add ثُوغَا أَثنْ ذ\add* إِلْيُوعِينَايْ، حِيزْقِييَا ذ عَازْرِيقَامْ، ثْڒَاثَا \add ن وَارَّاونْ\add*.
\m 
\v 24 أَرَّاونْ ن إِلْيُوعِينَايْ \add ثُوغَا أَثنْ ذ\add* هُوذَاوْيَاهُو، إِلْيَاشِيبْ، فَالَايَا، عَاقُّوبْ، يُوحَانَانْ، ذَالَايَا ذ عَانَانِي، سبْعَا \add ن وَارَّاونْ\add*.
\b
\b
\c 4
\m 
\v 1 \bd أَرَّاونْ ن يَاهُوذَا\bd* \add ثُوغَا أَثنْ ذ\add* فَارِيصْ، حَاصْرُونْ ذ كَارْمِي ذ حُورْ ذ شُوبَالْ.
\b
\m 
\v 2 \bd رَآيَا، مِّيسْ ن شُوبَالْ\bd*، إِجَّا-د يَاحَاثْ ؤُ يَاحَاثْ إِجَّا-د أَخُومَايْ ذ لَاهَاذْ. ثِينَا \add ثُوغَا أَثنْثْ\add* ذ ڒَادْجَاثْ ن إِصَارْعِييّنْ.
\m 
\v 3 \bd إِنَا \bdit ثُوغَا أَثنْ ذ أَرَّاونْ\bdit* ن أَبِي-عِيطَامْ\bd*: يَازْرَاعِيلْ، يَاشْمَا ذ يَاذْبَاشْ. إِسمْ ن ؤُتْشْمَاثْسنْ \add ثُوغَا-ث ذ\add* هَاصَّالَالْفُونِي.
\m 
\v 4 \bd فَانُووِيلْ\bd* \add ثُوغَا-ث ذ\add* بَابَاسْ ن جَاذُورْ، ؤُ عَازَارْ \add ثُوغَا-ث ذ\add* بَابَاسْ ن حُوشَا. إِنَا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن حُورْ، أَمنْزُو ن إِفْرَاثَا، بَابَاسْ ن بَايْثْ-لَاحْمْ.
\m 
\v 5 \bd أَشْحُورْ، بَابَاسْ ن ثَاقُوعَا\bd*، ثُوغَا غَارسْ ثْنَاينْ ن ثمْغَارِينْ، حَالَا ذ نَاعَارَا.
\v 6 نَاعَارَا ثُورُووْ أَسْ-د أَخُوزَّامْ، حَافَارْ، ثَايْمَانِي ذ إِخَاشْثَارِييّنْ. إِنَا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن نَاعَارَا.
\v 7 أَرَّاونْ ن حَالَا \add ثُوغَا أَثنْ ذ\add* صَارَاثْ، صُوحَارْ ذ إِثْنَانْ.
\m 
\v 8 \bd قُوصْ\bd* إِجَّا-د عَانُوبْ ذ هَاصُوبِيبَا، ذ ڒَادْجَاثْ ن أَخَارْحِيلْ، مِّيسْ ن هَارُومْ.
\m 
\v 9 \bd يَاعْبِيصْ\bd* ثُوغَا غَارسْ شَّانْ خْ يَايْثْمَاسْ. يمَّاسْ ثُوغَا ثڭَّا أَسْ يَاعْبِيصْ، مَاغَارْ نتَّاثْ ثنَّا: ”نشّْ ؤُرْوغْ ث-إِ-د س ڒحْرِيقْ.“
\v 10 إِڒَاغَا يَاعْبِيصْ خْ أَربِّي ن إِسْرَائِيل، إِنَّا: ”مَاڒَا شكْ ثْبَارْكذْ أَيِي ؤُ أَذْ ثْوسّْعذْ أَيْمِيرْ \add ن ثمُّورْثْ\add* إِنُو ؤُشَا أَذْ كِيذِي يِيڒِي ؤُفُوسْ نّشْ، أَذْ خَافِي ثسِّيڭّْوجذْ ڒْغَارْ حِيمَا وَارْ ذ أَيِي ثْڒقّفْ ثَامَارَا ...!“ ؤُشَا أَربِّي إِسِّيوضْ \add أَسْ\add* مِينْ إِتَّارْ.
\m 
\v 11 \bd كَالُوبْ\bd*، ؤُمَاسْ ن شُوحَا، إِجَّا-د مَاحِيرْ. وَانِيثَا ذ بَابَاسْ ن إِشْثُونْ.
\v 12 إِشْثُونْ إِجَّا-د بَايْثْ-رَافَا ذ فَاسِيحْ ذ ثَاحِينَّا، بَابَاسْ \add ن ثنْذِينْثْ\add* ن عِيرْ-نَاحَاشْ. إِنَا ذ إِرْيَازنْ ن رَايْكَا. \f ◼ \fr 4:‏12 \ft \bd ’عِيرْ-نَاحَاشْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثَانْذِينْثْ ن ؤُفِيغْرَارْ‘\f*
\m 
\v 13 \bd أَرَّاونْ ن قَانَازْ\bd* \add ثُوغَا أَثنْ ذ\add* عُوثْنِييِيلْ ذ سَارَايَا. أَرَّاونْ ن عُوثْنِييِيلْ، \add مْغِيرْ\add* حَاثَاثْ.
\m 
\v 14 \bd مَاعُونَاثَايْ\bd* إِجَّا-د عَافْرَا، ؤُ سَارَايَا إِجَّا-د يُووَابْ، بَابَاسْ ن ثغْزُورْثْ ن إِحْرَايْفِييّنْ، مَاغَارْ نِيثْنِي ذ إِحْرَايْفِييّنْ، \add أَيْثْ ن بُو-صّنْعثْ\add*.
\m 
\v 15 \bd أَرَّاونْ ن كَالِيبْ\bd*، مِّيسْ ن يَافُونِّي، \add ثُوغَا أَثنْ ذ\add* عِيرُو، إِيْلَا ذ نَاعَامْ. أَرَّاونْ ن إِلَا، \add مْغِيرْ\add* قِينَازْ.
\m 
\v 16 \bd أَرَّاونْ ن يَاهْلَالِييِيلْ\bd* \add ثُوغَا أَثنْ ذ\add* زِيفْ ذ زِيفَا ذ ثِيرِييَا ذ أَسَارَايِيلْ.
\m 
\v 17 \bd أَرَّاونْ ن عِيزْرَا\bd* \add ثُوغَا أَثنْ ذ\add* يَاثَارْ ذ مَارَاذْ ذ عِيفَارْ ذ يَالُونْ. نتَّاثْ، \add بِيثْيَا\add*، ثُورُووْ-د مَارْيَامْ ذ شَامَّايْ ذ يِيشْبَاحْ، بَابَاسْ ن إِشْثَامُوعْ،
\v 18 ؤُ ثَامْغَارْثْ نّسْ ثَايَاهُوذشْثْ ثُورُووْ-د يَارَاذْ، بَابَاسْ ن جَاذُورْ، ذ حَابِيرْ، بَابَاسْ ن سُوكُو، ذ يَاقُوثِييِيلْ، بَابَاسْ ن زَانُوحْ، \add مَاشَا\add* \add إِنّغْنِي\add* نِيثْنِي \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن بِيثْيَا، يدْجِيسْ ن فِيرْعُونْ، ثنِّي يِيوِي مَارَاذْ \add ذ ثَامْغَارْثْ\add*. \f ◼ \fr 4:‏18 \ft \bd ’ثَايَاهُوذِيثْ‘\bd* - إِشْثْ ن ثمْغَارْثْ زِي يَاهُوذَا.\f*
\m 
\v 19 \bd أَرَّاونْ ن ثمْغَارْثْ ن هُوذِييَا\bd*، ؤُتْشْمَاسْ ن نَاحَامْ، \add ثُوغَا أَثنْ ذ\add* بَابَاسْ \add ن ثنْذِينْثْ\add* ن قَاعِيلَا، أَجَارْمِي، ذ إِشْثَامُوعَا، أَمَاعْكِي.
\m 
\v 20 \bd أَرَّاونْ ن شِيمُونْ\bd* \add ثُوغَا أَثنْ ذ\add* أَمْنُونْ ذ رِينَّا، بِينْ-حَانَانْ ذ ثِيلُونْ. أَرَّاونْ ن يِيعْشِي \add ثُوغَا أَثنْ ذ\add* زُوحَايْثْ ذ بَانْ-زُوحَايْثْ.
\m 
\v 21 \bd أَرَّاونْ ن شَايْلَا\bd*، مِّيسْ ن يَاهُوذَا، \add ثُوغَا أَثنْ ذ\add* عِيرْ، بَابَاسْ ن لِيكَا، لَاعْذَا، بَابَاسْ ن مَارِيشَا، ذ ڒَادْجَاثْ ن ثَادَّارْثْ ن يِينِّي إِخدّْمنْ س ثِيفّسْثْ ن ثَادَّارْثْ ن أَشْبِيعَا.
\m 
\v 22 ؤُ \add خنِّي\add* يُوقِيمْ ذ يرْيَازنْ ن كُوزِيبَا، ذ يُووَاشْ ذ سَارَافْ، إِنِّي إِصدْجْضنْ خْ مُوآبَ، ذ يَاشُوبِي-لَاحْمْ. ذ مَانْ أَيَا ذ ڒخْبَارَاثْ ثِيقْذِيمِينْ.
\v 23 نِيثْنِي \add ثُوغَا أَثنْ\add* ذ أَيْثْ ن بُو-ثْڒَاخْثْ ؤُ زدّْغنْ ذِي نَاثَاعِيمْ ذ جَاذِيرَا. نِيثْنِي قِّيمنْ زدّْغنْ ذِينْ حِيمَا أَذْ سخَّارنْ إِ ؤُجدْجِيذْ.
\b
\m 
\v 24 \bd أَرَّاونْ ن شِيمْعُونْ\bd* \add ثُوغَا أَثنْ ذ\add* نَامُويِيلْ ذ يَامِينْ، يَارِيبْ، زَارَاحْ، شَاوُولْ.
\m 
\v 25 شَالُّومْ ذ مِّيسْ، مِّيسْ مِيبْسَامْ، مِّيسْ مِيشْمَاعْ.
\m 
\v 26 أَرَّاونْ ن مِيشْمَاعْ: مِّيسْ حَامُّويِيلْ، مِّيسْ زَاكُّورْ \add ذ\add* مِّيسْ شِيمْعِي.
\m 
\v 27 شِيمْعِي ثُوغَا غَارسْ سطَّاشْ ن وَارَّاونْ ذ ستَّا ن ثْحنْجِيرِينْ. \add مَاشَا\add* أَيْثْمَاسْ وَارْ غَارْسنْ ثُوغِي بُو وَارَّاونْ أَطَّاسْ ؤُ مَارَّا ڒَادْجَاثْ نْسنْ وَارْ مَّارْنِينْثْ شَا أَمْ ثِينِّي ن وَارَّاونْ ن يَاهُوذَا.
\v 28 نِيثْنِي ثُوغَا زدّْغنْ ذِي بِئرْ-سبْعَا، ذِي مُولَاذَا، ذِي حَاصَارْ-شُوعَالْ،
\v 29 ذِي بِيلْهَا ذِي عَاصِيمْ، ذِي ثُولَاذْ،
\v 30 ذِي بِيثُووِيلْ، ذِي حُورْمَا، ذِي صِيقْلَاغْ،
\v 31 ذِي بَايْثْ-مَارْكابُوثْ، ذِي حَاصَارْ-سُوسِيمْ، ذِي بَايْثْ-بِيرِي ؤُ ذِي شَاعَارَايِيمْ. أَڒْ إِذْوڒْ ذَاوُوذْ ذ أَجدْجِيذْ \add ثُوغَا\add* إِنَا ذ ثِيندَّامْ نْسنْ،
\v 32 ذ ذْشُورَاثْ نْسنْ: عِيطَامْ، عَايْنْ، رِيمُّونْ، ثُوكَانْ ذ عَاشَانْ، خمْسَا ن ثْندَّامْ
\v 33 أَكْ-ذ مَارَّا ذْشُورَاثْ إِ ذ أَسنْثْ-إِ-د إِنّْضنْ إِ ثْندَّامْ-أَ، أَڒْ بَاعْلْ. ثِينَا ذ جّْوَايهْ مَانِي زذْغنْ ؤُ نِيثْنِي حْضَانْ س يِيخفْ نْسنْ لِيسْثَا ن جَّاذِيرَا.
\m 
\v 34 مَاشُوبَابْ ذ يَامْلِيكْ ذ يُوشَا، مِّيسْ ن أَمَاصْيَا،
\v 35 ذ يُووِيلْ ذ يَاهُو، مِّيسْ ن يُوشِيبَا، مِّيسْ ن سَارَايَا، مِّيسْ ن عَاسِييِيلْ،
\v 36 ذ إِلْيُوعِينَايْ ذ يَاعْقُوبَا ذ يَاشُوحَايَا ذ عَاسَايَا ذ عَاذِييِيلْ ذ يَاسِيمِييِيلْ ذ بَانَايَا
\v 37 ذ زِيزَا، مِّيسْ ن شِيفْعِي، مِّيسْ ن أَلُّونْ، مِّيسْ ن يَاذَايَا، مِّيسْ ن شِيمْرِي، مِّيسْ ن شَامْعِييَا.
\v 38 إِنَا، \add إِنِّي إِ ذَا\add* إِتّْوَاڒَاغَانْ س يِيسمْ \add نْسنْ\add*، \add ثُوغَا أَثنْ ذ\add* ڒْحُوكَّامْ ذِي ڒَادْجَاثْ نْسنْ، ؤُشَا ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ ثُوغَا مَّارْنِينْثْ أَطَّاسْ.
\v 39 نِيثْنِي ؤُيُورنْ، كِّينْ خْ ؤُغزْذِيسْ ن ڒْغَارْبْ ن جَاذُورْ أَڒْ شَّارْقْ ن ثغْزُورْثْ، حِيمَا أَذْ ؤُفِينْ مَانِي غَا هدّنْ وُودْجِي نْسنْ.
\v 40 نِيثْنِي ؤُفِينْ \add ذِينْ\add* دّْمَانِي ن ثَاروْسَا شُّورنْ مْلِيحْ، شْنَانْ. ثُوغَا ثَامُّورْثْ ثوْسعْ غَارْ مَارَّا إِغزْذِيسنْ، ثَارْسَا ؤُ ذَايسْ ڒْهُوذْنثْ، مَاغَارْ إِنِّي ن حَامْ ثُوغَا زدّْغنْ ذِينْ زِيشْ.
\v 41 إِنَا، إِنِّي إِتّْوَازمّمنْ س إِسْمَاونْ \add نْسنْ\add*، ؤُسِينْ-د ذڭْ وُوسَّانْ ن ؤُجدْجِيذْ حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ؤُ نِيثْنِي هذْمنْ إِقِيضَانْ نْسنْ، ؤُڒَا ذ إِمَاعُونِييّنْ إِنِّي ذِينْ ؤُفِينْ، ثحَّانْ ثنْ أَڒْ أَسّْ-أَ. نِيثْنِي ڭِّينْ أَذْ زذْغنْ ذڭْ ومْشَانْ نْسنْ، مَاغَارْ ثُوغَا ذِينِّي \add ثَامُّورْثْ ن\add* ثَاروْسَا إِ وُودْجِي نْسنْ. \f ◼ \fr 4:‏41 \ft \bd ’حَازَاقِييَا‘\bd* - س ثْعِيبْرَانِيثْ ’يحَازْقِييَاهُو‘.\f*
\m 
\v 42 زڭْ إِنَا، زڭْ وَارَّاونْ ن شِيمْعُونْ، فّْغنْ \add عَاوذْ\add* خمْسَا مْيَا ن يرْيَازنْ غَارْ إِذُورَارْ ن سَاعِيرْ. فَالَاطْيَا ذ نَاعْرِييَا ذ رَافَايَا ذ عُوزِّييِيلْ، أَرَّاونْ ن يِيشْعِي، \add بدّنْ\add* غَارْ ؤُزدْجِيفْ نْسنْ.
\v 43 نِيثْنِي نْغِينْ مِينْ إِقِّيمنْ ن أَيْثْ ن عَامَالِيقْ إِنِّي د إِنّجْمنْ ؤُ نِيثْنِي زدّْغنْ ذِينِّي أَڒْ أَسّْ-أَ.
\b
\b
\c 5
\m 
\v 1 \bd أَرَّاونْ ن رُوبِينْ\bd*، أَمنْزُو ن إِسْرَائِيل - مِينْزِي نتَّا ثُوغَا-ث ذ أَمنْزُو، مَاشَا ؤُمِي نتَّا إِسّخْسَارْ ثَاسُّوثْ ن بَابَاسْ، ثمّوْشْ ثَاسْغَارْثْ ن ثْمنْزُوثْ نّسْ إِ وَارَّاونْ ن يُوسُوفْ، مِّيسْ ن إِسْرَائِيل، مَاشَا وَارْ إِدْجِي أَمنِّي أَڒَامِي \add يُوسُوفْ\add* إِتّْوَازمّمْ ذِي لِيسْثَا ن جَّاذِيرَا عْلَاحْسَابْ ثَاسْغَارْثْ ن ثْمنْزُوثْ نّسْ، \f ◼ \fr 5:‏1 \ft \bd ’ثَامنْزُوثْ‘\bd* - نِيغْ ’أَخڒْقضْ أَمزْوَارُو‘ نِيغْ ’ثَاڒَاڒِيثْ ثَامزْوَارُوثْ‘ نِيغْ ’ثَاوَاڒُوثْ ثَامزْوَارُوثْ‘.\f*
\v 2 مَاغَارْ يَاهُوذَا إِذْوڒْ ذ بُو-ثغْرُوضْثْ جَارْ أَيْثْمَاسْ ؤُ زَّايسْ إِفّغْ ڒْحَاكمْ \add وَاخَّا\add* ثَاسْغَارْثْ ن ثْمنْزُوثْ ثُوغَا-ت غَارْ يُوسُوفْ -
\v 3 أَرَّاونْ ن رُوبِينْ، أَمنْزُو ن إِسْرَائِيل، \add ثُوغَا أَثنْ ذ\add* حَانُوكْ ذ فَالُّو، حَاصْرُونْ ذ كَارْمِي.
\m 
\v 4 أَرَّاونْ ن يُووِيلْ: مِّيسْ شَامْعِييَا، مِّيسْ \add هَا\add*جُوجْ مِّيسْ شِيمْعِي،
\v 5 مِّيسْ مِيخَا، مِّيسْ رَآيَا، مِّيسْ بَاعْلْ
\v 6 \add ذ\add* مِّيسْ بَائِيرَا، ونِّي يِيوْيِي ثِيغْلَاثْ-فِيلَاسِيرْ، أَجدْجِيذْ ن أَشُّورْ، ذِي لْمنْفَا. نتَّا ثُوغَا ذ ڒْحَاكمْ ن إِرُوبِينِييّنْ.
\m 
\v 7 أَيْثْمَاسْ، \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، ؤُمِي نِيثْنِي تّْوَازمّمنْ ذِي لِيسْثَا ن جَّاذِيرَا عْلَاحْسَابْ أَخْڒَاقْ نْسنْ، \add ثُوغَا أَثنْ ذ\add* أَزدْجِيفْ يَاعِييِيلْ ذ زَاكَارِييَّا \f ◼ \fr 5:‏7 \ft \bd ’ثَاڒَاڒِيثْ‘\bd* - نِيغْ ’أَخْڒَاقْ‘.\f*
\m 
\v 8 ذ بِيلَاعْ، مِّيسْ ن أَسَا، مِّيسْ ن شَامْعِي، مِّيسْ ن يُووِيلْ. نتَّا ثُوغَا إِزدّغْ ذِي عَارُوعِيرْ أَڒْ نابُو ذ بَاعْلْ-مَاعُونْ.
\v 9 إِزْذغْ ذِي شَّارْقْ أَڒْ وَاذَافْ غَارْ ڒخْڒَا إِ إِسّْوِيژّْضنْ إِخفْ نّسْ زڭْ إِغْزَارْ ن لْفُورَاطْ، مَاغَارْ ڒبْهَايمْ نْسنْ ذوْڒنْ س وَاطَّاسْ ذِي ثمُّورْثْ ن جِيلْعَاذْ.
\v 10 ذڭْ وُوسَّانْ ن شَاوُولْ ڭِّينْ نِيثْنِي أَمنْغِي أَكْ-ذ إِهَاجْرِييّنْ، إِنِّي إِوْضَانْ س ؤُفُوسْ نْسنْ. نِيثْنِي ڭِّينْ أَذْ زذْغنْ ذڭْ إِقِيضَانْ نْسنْ خْ مَارَّا أَغزْذِيسْ غَارْ شَّارْقْ ن جِيلْعَاذْ.
\b
\m 
\v 11 \bd أَرَّاونْ ن جَاذْ\bd* ثُوغَا زدّْغنْ أَجمَّاضِينْ نْسنْ ذِي ثمُّورْثْ ن بَاشَانْ أَڒْ سَالْخَا.
\v 12 يُووِيلْ \add ثُوغَا-ث ذ\add* أَزدْجِيفْ نْسنْ ؤُ شَافَامْ \add ثُوغَا-ث ذ\add* وِيسّْ ثْنَاينْ، ذ يَاعْنَايْ ذ شَافَاثْ. \add نِيثْنِي ثُوغَا زدّْغنْ\add* ذِي بَاشَانْ.
\m 
\v 13 أَيْثْمَاثْسنْ، \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، \add ثُوغَا أَثنْ ذ\add* مِيخَايِيلْ ذ مَاشُولَّامْ ذ شَابْعَا ذ يُورَايْ ذ يَاعْكَانْ ذ زِيعَا ذ عَابِيرْ، سبْعَا \add ن وَاوْمَاثنْ\add*.
\m 
\v 14 إِنَا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن أَبِيحَايِيلْ، مِّيسْ ن حُورِي، مِّيسْ ن يَارُوحْ، مِّيسْ ن جِيلْعَاذْ، مِّيسْ ن مِيخَايِيلْ، مِّيسْ ن يَاشِيشَايْ، مِّيسْ ن يَاهْذُو، مِّيسْ ن بُوزْ.
\m 
\v 15 أَخِي، مِّيسْ ن عَابْذِييِيلْ، مِّيسْ ن جُونِي، \add ثُوغَا-ث ذ\add* أَزدْجِيفْ ن ثَادَّارْثْ ن إِبَابَاثنْ نْسنْ.
\m 
\v 16 نِيثْنِي ثُوغَا زدّْغنْ ذِي جِيلْعَاذْ، ذِي بَاشَانْ ؤُ ذِي ثْندَّامْ إِ غَارسْ د-إِقّْننْ ؤُ ذِي مَارَّا دّْمَانِي ن ثَاروْسَا ن شَارُونْ أَڒْ ثِيمَاوِّينْ نْسنْ.
\v 17 مَارَّا إِنَا تّْوَازمّمنْ ذِي لِيسْثَاثْ ن جَّاذِيرَا ذڭْ وُوسَّانْ ن يُوثَامْ، أَجدْجِيذْ ن يَاهُوذَا، ؤُ ذڭْ وُوسَّانْ ن يَارُوبْعَامْ، أَجدْجِيذْ ن إِسْرَائِيل.
\b
\m 
\v 18 زڭْ وَارَّاونْ ن رُوبِينْ ذ وَارَّاونْ ن جَاذْ ذ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا، زڭْ أَيْثْ ن ؤُمنْغِي، \add زڭْ\add* إِرْيَازنْ إِنِّي يَاربُّونْ ثَاسدَّارْثْ \add ن ؤُعسْكَارِي\add* ذ سِّيفْ ذ يِينِّي إِمحْضنْ ڒْقوْسْ ؤُ ثُوغَا ذَارّْبنْ ذڭْ ؤُمنْغِي، أَقَا \add ذِينْ\add* أَربْعَا ؤُ-ربْعِينْ-أَڒفْ ؤُ-سبْعَا-مْيَا ؤُ-ستِّينْ إِنِّي د-إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ.
\v 19 نِيثْنِي مّنْغنْ أَكْ-ذ إِهَاجْرِييّنْ ؤُ \add أَكْ-ذ\add* يَاطُورْ ذ نَافِيشْ ذ نُوذَابْ.
\v 20 نِيثْنِي تّْوَاعَاوْننْ \add ذڭْ ؤُمنْغِي\add* أَكِيذْسنْ ؤُشَا إِهَاجْرِييّنْ ذ مَارَّا إِنِّي أَكِيذْسنْ \add إِدْجَانْ\add*، مّوْشنْ ذڭْ ؤُفُوسْ نْسنْ، مَاغَارْ نِيثْنِي سْغُوينْ ذڭْ ؤُمنْغِي غَارْ أَربِّي ؤُ وَانِيثَا إِجَّا أَذْ إِسَّارْضَا إِخفْ نّسْ س ثْژَادْجِيثْ يُودْجْغنْ نْسنْ، مِينْزِي نِيثْنِي ثشْڒنْ خَاسْ.
\v 21 نِيثْنِي حوّْسنْ ڒْمَاڒْ نْسنْ: خمْسِينْ-أَڒفْ ن إِڒغْمَانْ نْسنْ، مِيثَاينْ ؤُ-خمْسِينْ-أَڒفْ ن وُودْجِي ؤُ أَڒْفَاينْ ن يغْيَاڒْ ؤُ مْيَاثْ-أَڒفْ ن إِوْذَانْ. \f ◼ \fr 5:‏21 \ft \bd ’إِوْذَانْ‘\bd* - س ثْعِيبْرَانِيثْ ’ڒعْمُوڒْ‘.\f*
\v 22 مِينْزِي ثُوغَا \add ذِينْ\add* أَطَّاسْ ن يِينِّي إِتّْوَانْغنْ، مَاغَارْ ثُوغَا-ث ذ إِجّْ ن ؤُمنْغِي ن أَربِّي. نِيثْنِي ڭِّينْ أَذْ \add ذِينْ\add* زذْغنْ ذڭْ ومْشَانْ نْسنْ أَڒْ لْمنْفَا.
\b
\m 
\v 23 \bd أَرَّاونْ ن وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا\bd* زذْغنْ ذِي ثمُّورْثْ \add نِّي\add*. نِيثْنِي مَّارْنِينْ زِي بَاشَانْ أَڒْ بَاعْلْ-حِيرْمُونْ ذ سَانِيرْ ذ وذْرَارْ ن حَارْمُونْ.
\v 24 إِنَا \add ثُوغَا أَثنْ ذ\add* إِزدْجِيفنْ ن ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ: عِيفَارْ ذ يِيشْعِي ذ إِلِييِيلْ ذ عَازْرِييِيلْ ذ إِرْمِييَا ذ هُوذَايَا ذ يَاحْذِييِيلْ. \add نِيثْنِي ثُوغَا أَثنْ ذ\add* أَيْثْ ن بُو-ثغْرُوضْثْ، إِرْيَازنْ إِمحْضنْ، إِرْيَازنْ ن يِيسمْ، إِزدْجِيفنْ ن ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ.
\v 25 نِيثْنِي غْذَارنْ أَربِّي ن ڒجْذُوذْ نْسنْ ؤُ سّْفسْذنْ إِخفْ نْسنْ س إِربِّيثنْ ن ڒڭْنُوسْ ن ثمُّورْثْ، إِنِّي ثُوغَا إِثحَّا أَربِّي زَّاثْ إِ وُوذمْ نْسنْ.
\v 26 \add خنِّي\add* إِسّكَّارْ أَربِّي ن إِسْرَائِيل بُوحْبڒْ ن فُولْ، أَجدْجِيذْ ن أَشُّورْ، ذ بُوحْبڒْ ن ثِيغْلَاثْ-فِيلْنَاسِيرْ، أَجدْجِيذْ ن أَشُّورْ، ؤُ وَانِيثَا إِنْذهْ إِ-ثنْ غَارْ لْمنْفَا: أَيْثْ ن رُوبِينْ ذ أَيْثْ ن جَاذْ ذ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا. نتَّا يِيوْيِي ثنْ غَارْ حَالَاحْ ذ خابُورْ ذ هَارَا\add ن\add* ؤُ غَارْ إِغْزَارْ ن جُوزَانْ، \add ؤُ نِيثْنِي قِّيمنْ ذِينِّي\add* أَڒْ أَسّْ-أَ. \x ◘ \xo 5:‏26 \xt 2 إِج. 18‏:‏11\x*
\b
\s1 زِي لَاوِي أَڒْ أَكهَّانْ أَمقّْرَانْ هَارُونْ ذ ثَارْوَا نّسْ
\m 
\v 27 \bd أَرَّاونْ ن لَاوِي\bd* \add ثُوغَا أَثنْ ذ\add* جَارْشُونْ، قَاهَاثْ ذ مَارَارِي.
\m 
\v 28 \bd أَرَّاونْ ن قَاهَاثْ\bd* \add ثُوغَا أَثنْ ذ\add* عَامْرَامْ، يِيصْهَارْ ذ حَابْرُونْ ذ عُوزِّييِيلْ.
\m 
\v 29 \bd أَرَّاونْ ن عَامْرَامْ\bd* \add ثُوغَا أَثنْ ذ\add* هَارُونْ ذ مُوسَا، ؤُ مَارْيَامْ \add ؤُتْشْمَاثْسنْ\add*.
\m \bd أَرَّاونْ ن هَارُونْ\bd* \add ثُوغَا أَثنْ ذ\add* نَاذَابْ ذ أَبِيهُو، أَلِيعَازَارْ ذ إِثَامَارْ.
\m 
\v 30 أَلِيعَازَارْ إِجَّا-د فِينَاحَاسْ، فِينَاحَاسْ إِجَّا-د أَبِيشُوعَا،
\m 
\v 31 أَبِيشُوغَا إِجَّا-د بُوقِّي، بُوقِّي إِجَّا-د عُوزِّي،
\m 
\v 32 عُوزِّي إِجَّا-د زَارَاحْ-يَاهْ، زَارَاحْ-يَاهْ إِجَّا-د مَارَايُوثْ،
\m 
\v 33 مَارَايُوثْ إِجَّا-د أَمَارْيَا، أَمَارْيَا إِجَّا-د أَخِيطُوبْ،
\m 
\v 34 أَخِيطُوبْ إِجَّا-د صَاذُوقْ، صَاذُوقْ إِجَّا-د أَخِيمَاعَاصْ،
\m 
\v 35 أَخِيمَاعَاصْ إِجَّا-د عَازَارْيَا، عَازَارْيَا إِجَّا-د يُوحَانَانْ
\m 
\v 36 ؤُ يُوحَانَانْ إِجَّا-د عَازَارْيَا. وَانِيثَا ثُوغَا ذ ونِّي إِتّْسخَّارنْ أَمْ ؤُكهَّانْ ذِي ثَادَّارْثْ إِ إِبْنَا سُولِيمَانْ ذِي ؤُرْشَالِيمْ.
\m 
\v 37 عَازَارْيَا إِجَّا-د أَمَارْيَا، أَمَارْيَا إِجَّا-د أَخِيطُوبْ،
\m 
\v 38 أَخِيطُوبْ إِجَّا-د صَاذُوقْ، صَاذُوقْ إِجَّا-د شَالُّومْ،
\m 
\v 39 شَالُّومْ إِجَّا-د حِيلْقِييَا، حِيلْقِييَا إِجَّا-د عَازَارْيَا،
\m 
\v 40 عَازَارْيَا إِجَّا-د سَارَايَا ؤُ سَارَايَا إِجَّا-د يَاهُوصَاذَاقْ.
\m 
\v 41 يَاهُوصَاذَاقْ يُويُورْ \add أَكِيذْسنْ\add* ؤُمِي سِيذِي إِنْذهْ يَاهُوذَا ذ ؤُرْشَالِيمْ غَارْ لْمنْفَا س ؤُفُوسْ ن نابُوخَاذْنَاصَّارْ.
\b
\b
\c 6
\s1 أَيْثْ ن لَاوِي - إِلَاوِييّنْ
\m 
\v 1 \bd أَرَّاونْ ن لَاوِي\bd* \add ثُوغَا أَثنْ ذ\add* جَارْشُونْ، قَاهَاثْ ذ مَارَارِي.
\m 
\v 2 إِنَا ذ إِسْمَاونْ ن \bd وَارَّاونْ ن جَارْشُونْ:\bd* لِيبْنِي ذ شِيمْعِي.
\m 
\v 3 \bd أَرَّاونْ ن قَاهَاثْ\bd* \add ثُوغَا أَثنْ ذ\add* عَامْرَامْ، يِيصْحَارْ، حَابْرُونْ ذ عُوزِّييِيلْ.
\m 
\v 4 \bd أَرَّاونْ ن مَارَارِي\bd* \add ثُوغَا أَثنْ ذ\add* مَاحْلِي ذ مُوشِي. ثِينَا ذ ڒَادْجَاثْ ن إِلَاوِييّنْ، عْلَاحْسَابْ ڒجْذُوذْ نْسنْ.
\b
\m 
\v 5 \bd ن جَارْشُونْ:\bd* مِّيسْ لِيبْنِي، مِّيسْ يَاحَاثْ، مِّيسْ زِيمَّا،
\v 6 مِّيسْ يُووَاخْ، مِّيسْ عِيدُّو، مِّيسْ زَارَاحْ \add ذ\add* مِّيسْ يَاثْرَايْ.
\b
\m 
\v 7 \bd أَرَّاونْ ن قَاحَاثْ:\bd* مِّيسْ عَامِّينَاذَابْ، مِّيسْ قُورَاحْ، مِّيسْ أَسِّيرْ،
\v 8 مِّيسْ إِلْقَانَا، مِّيسْ أَبِييَاسَافْ، مِّيسْ أَسِّيرْ،
\v 9 مِّيسْ ثَاحَاثْ، مِّيسْ ؤُرِييِيلْ، مِّيسْ عُوزِّييَا \add ذ\add* مِّيسْ شَاوُولْ.
\m 
\v 10 أَرَّاونْ ن إِلْقَانَا \add ثُوغَا أَثنْ ذ\add* عَامَاسَايْ ذ أَخِيمُوثْ.
\v 11 إِلْقَانَا: مِّيسْ \add ثُوغَا-ث\add* إِلْقَانَا، مِّيسْ صُوفَايْ، مِّيسْ نَاحَاثْ،
\v 12 مِّيسْ إِلِييَابْ، مِّيسْ يَارُوحَامْ \add ذ\add* مِّيسْ إِلْقَانَا.
\m 
\v 13 أَرَّاونْ ن شَامْوِيلْ \add ثُوغَا أَثنْ ذ\add* \add يُووِيلْ\add*، أَمنْزُو نّسْ، ؤُ \add ونِّي ذ\add* وِيسّْ ثْنَاينْ \add ثُوغَا-ث\add* أَبِييَا.
\b
\m 
\v 14 \bd أَرَّاونْ ن مَارَارِي:\bd* مَاحْلِي، مِّيسْ لِيبْنِي، مِّيسْ شِيمْعِي، مِّيسْ عُوزَّا،
\v 15 مِّيسْ شِيمْعَا، مِّيسْ حَاجِييَا \add ذ\add* مِّيسْ عَاسَايَا.
\b
\m 
\v 16 إِنَا ذ إِنِّي إِڭَّا ذَاوُوذْ حِيمَا أَذْ إِڒِينْ \bd خْ ؤُغنّجْ ن يِيزْڒَانْ ذِي ثَادَّارْثْ ن سِيذِي\bd*، أَوَارْنِي ڒَامِي ثُوغَا ثِيوضْ تَّابُوثْ غَارْ ومْشَانْ ن أَرَّاحثْ نّسْ.
\v 17 نِيثْنِي ثُوغَا تّْسخَّارنْ س إِزْڒَانْ زَّاثْ إِ ثْزذِّيغْثْ، زَّاثْ إِ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، أَڒْ إِكمّڒْ سُولِيمَانْ ڒبْنِي ن ثَادَّارْثْ ن سِيذِي ذِي ؤُرْشَالِيمْ. نِيثْنِي بدّنْ ذِي ثْسخَّارْثْ نْسنْ عْلَاحْسَابْ لْفَارِيضَا نْسنْ.
\v 18 إِنَا ذ إِنِّي إِ \add ذِينْ\add* إِبدّنْ أَكْ-ذ وَارَّاونْ نْسنْ:
\m زڭْ وَارَّاونْ \bd ن إِقَاحَاثِييّنْ\bd*: \bd هَايْمَانْ\bd*، أَمذْيَازْ، مِّيسْ ن يُووِيلْ، مِّيسْ ن شَامْوِيلْ،
\v 19 مِّيسْ ن إِلْقَانَا، مِّيسْ ن يَارُوحَامْ، مِّيسْ ن إِلِييِيلْ، مِّيسْ ن ثُووَاحْ،
\v 20 مِّيسْ ن صُوفْ، مِّيسْ ن إِلْقَانَا، مِّيسْ ن مَاحَاثْ، مِّيسْ ن عَامَاسَايْ،
\v 21 مِّيسْ ن إِلْقَانَا، مِّيسْ ن يُووِيلْ، مِّيسْ ن عَازَارْيَا، مِّيسْ ن صَافَانْيَا، \f ◼ \fr 6:‏21 \ft \bd ’صَافَانْيَا‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي ث إِسّْنُوفَّارنْ سِيذِي‘.\f*
\v 22 مِّيسْ ن ثَاحَاثْ، مِّيسْ ن أَسِّيرْ، مِّيسْ ن أَبِييَاسَافْ، مِّيسْ ن قُورَاحْ،
\v 23 مِّيسْ ن يِيصْهَارْ، مِّيسْ ن قَاهَاثْ، مِّيسْ ن لَاوِي، مِّيسْ ن إِسْرَائِيل.
\m 
\v 24 ؤُمَاسْ \bd أَسَافْ\bd* ثُوغَا إِتّْبدَّا \bd غَارْ ؤُفُوسِي نّسْ\bd*. ثُوغَا أَسَافْ ذ مِّيسْ ن بَارَاخْيَا، مِّيسْ ن شِيمْعِي،
\v 25 مِّيسْ ن مِيخَايِيلْ، مِّيسْ ن بَاعَاسِييَا، مِّيسْ ن مَالْكِييَا،
\v 26 مِّيسْ ن إِثْنِي، مِّيسْ ن زَارَاحْ، مِّيسْ ن عَاذَايَا،
\v 27 مِّيسْ ن إِثَانْ، مِّيسْ ن زِيمَّا، مِّيسْ ن شِيمْعِي،
\v 28 مِّيسْ ن يَاحَاثْ، \bd مِّيسْ ن جَارْشُومْ\bd*، مِّيسْ ن لَاوِي.
\m 
\v 29 أَيْثْمَاثْسنْ، \bd أَرَّاونْ ن مَارَارِي\bd*، بدّنْ غَارْ ؤُزڒْمَاضْ: \bd إِثَانْ\bd*، مِّيسْ ن قِيشِي، مِّيسْ ن عَابْذِي، مِّيسْ ن مَالُّوخْ،
\v 30 مِّيسْ ن حَاشَابْيَا، مِّيسْ ن أَمَاصْيَا، مِّيسْ ن حِيلْقِييَا،
\v 31 مِّيسْ ن أَمْصِي، مِّيسْ ن بَانِي، مِّيسْ ن شَامَارْ،
\v 32 مِّيسْ ن مَاحْلِي، مِّيسْ ن مُوشِي، مِّيسْ ن مَارَارِي، مِّيسْ ن لَاوِي.
\b
\m 
\v 33 أَيْثْمَاثْسنْ، \bd إِلَاوِييّنْ\bd*، \add ثُوغَا\add* تّْوَاڭّنْ إِ قَاعْ ثْسخَّارْثْ ذِي ثْزذِّيغْثْ ن ثَادَّارْثْ ن أَربِّي.
\v 34 \add مَاشَا\add* \bd هَارُونْ ذ وَارَّاونْ نّسْ\bd*، إِنِّي إِسّْبخَّارنْ ثِيغَارْصَا خْ ؤُعَالْطَارْ ن وشْمَاضْ ؤُ خْ ؤُعَالْطَارْ ن ڒبْخُورْ، أَقَا أَثنْ حِيمَا أَذْ بدّنْ أَكْ-ذ قَاعْ ڒْخذْمثْ ذڭْ وقْذَاسْ خْ ؤُقدَّاسْ ؤُ حِيمَا أَذْ ڭّنْ أَصْڒَاحْ إِ إِسْرَائِيل أَمْ مَامّشْ مَارَّا مِينْ ثُوغَا يُومُورْ مُوسَا، أَمْسخَّارْ ن أَربِّي.
\m 
\v 35 إِنَا ذ \bd أَرَّاونْ ن هَارُونْ\bd*: مِّيسْ أَلِيعَازَارْ، مِّيسْ فِينَاحَاسْ، مِّيسْ أَبِيشُوعَا،
\v 36 مِّيسْ بُوقِّي، مِّيسْ عُوزِّي، مِّيسْ زَارَاحْ-يَاهْ
\v 37 مِّيسْ مَارَايُوثْ، مِّيسْ أَمَارْيَا، مِّيسْ أَخِيطُوبْ،
\v 38 مِّيسْ صَاذُوقْ \add ذ\add* مِّيسْ أَخِيمَاعَاصْ.
\b
\m 
\v 39 إِنَا ذ \bd إِمُوشَانْ مَانِي ثُوغَا زدّْغنْ\bd*، عْلَاحْسَابْ ڒمْرَاڭحْ نْسنْ خْ ثمُّورْثْ نْسنْ:
\m إِ وَارَّاونْ ن هَارُونْ، \bd إِ ڒَادْجْ ن إِقَاهَاثِييّنْ\bd*، مِينْزِي ثُوغَا-ت ثقْذُوحْثْ إِ نِيثْنِي.
\m 
\v 40 وْشِينْ أَسنْ حَابْرُونْ ذِي ثمُّورْثْ ن يَاهُوذَا أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ إِ ذ أَسْ د-إِنّْضنْ.
\v 41 إِيَّارْ ن ثنْذِينْثْ ذ ذْشُورَاثْ نّسْ وْشِينْ ث إِ كَالِيبْ، مِّيسْ ن يَافُونِّي.
\m 
\v 42 إِ وَارَّاونْ ن هَارُونْ وْشِينْ أَسنْ ثِيندَّامْ ن ثَاروْڒَا حَابْرُونْ ذ لِيبْنَا أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، يَاتِّيرْ ذ إِشْثَامُوعَا أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ،
\v 43 حِيلَايْنْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذ ذَابِيرْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ،
\v 44 ذ عَاشَانْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذ بَايْثْ-شَامْسْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ.
\m 
\v 45 زِي ثقْبِيتْشْ ن بِينْيَامِينْ \add كْسِينْ نِيثْنِي\add* جَابْعَا أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذ عَالِّيمَاثْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذ عَانَاثُوثْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ. مَارَّا ثِيندَّامْ نْسنْ \add ثُوغَا أَثنْثْ ذ\add* ثْڒطَّاشْ ن ثْندَّامْ أَكْ-ذ ڒَادْجَاثْ نْسنْ.
\m 
\v 46 إِ وَارَّاونْ ن قَاهَاثْ إِ إِقِّيمنْ زِي ڒَادْجْ ن ثقْبِيتْشْ، \add تّْوَاعيّْننْثْ\add* س ثْقدُّوحْثْعشْرَا ن ثْندَّامْ زڭْ وزْينْ ن ثقْبِيتْشْ، زڭْ وزْينْ ن مَانَاسَّا.
\m 
\v 47 \bd إِ وَارَّاونْ ن جَارْشُونْ\bd* \add تّْوَاعيّْننْثْ\add* عْلَاحْصَابْ ڒَادْجَاثْ نْسنْ زِي ثقْبِيتْشْ ن إِسَّاكَارْ، ؤُ زِي ثقْبِيتْشْ ن أَشِيرْ، ؤُ زِي ثقْبِيتْشْ ن نَافْثَالِي، ؤُ زِي ثقْبِيتْشْ ن مَانَاسَّا ذِي بَاشَانْ ثْڒطَّاشْ ن ثْندَّامْ.
\m 
\v 48 \bd إِ وَارَّاونْ ن مَارَارِي\bd* عْلَاهْسَابْ ڒَادْجَاثْ نْسنْ \add تّْوَاعيّْننْثْ\add* س ثْقدُّوحْثْ ثنْعَاشْ ن ثْندَّامْ زِي ثقْبِيتْشْ ن رُوبِينْ، ؤُ زِي ثقْبِيتْشْ ن جَاذْ ؤُ زِي ثقْبِيتْشْ ن زابُولُونْ.
\m 
\v 49 أَيْثْ ن إِسْرَائِيل وْشِينْ إِ إِلَاوِييّنْ ثِيندَّامْ-أَ أَكْ-ذ دّْمَانِي نْسنْثْ ن ثَاروْسَا.
\v 50 س ثْقدُّوحْثْ وْشِينْ نِيثْنِي ثِيندَّامْ-أَ إِ إِتّْوَاڒَاغَانْ س يِيسمْ نْسنْثْ زِي ثقْبِيتْشْ ن وَارَّاونْ ن يَاهُوذَا ؤُ زِي ثقْبِيتْشْ ن وَارَّاونْ ن شِيمْعُونْ ؤُ زِي ثقْبِيتْشْ ن وَارَّاونْ بِينْيَامِينْ.
\b
\m 
\v 51 ؤُشَا زِي ڒَادْجَاثْ ن \bd وَارَّاونْ ن قَاهَاثْ\bd* طّْفنْ نِيثْنِي \add عَاوذْ\add* ثِيندَّامْ زِي ثقْبِيتْشْ ن إِفْرَايِيمْ ذِي ثمُّورْثْ نْسنْ.
\v 52 مِينْزِي وْشِينْ أَسنْ زِي ثْندَّامْ ن ثَاروْڒَا شَاكِيمْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ خْ إِذُورَارْ ن إِفْرَايِيمْ، ذ جَازَارْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ،
\v 53 ذ يَاقْمَاعَامْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذ بَايْثْ-حُورُونْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ،
\v 54 ذ أَيَالُونْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ ذ جَاثْ-رِيمُّونْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ.
\m 
\v 55 زڭْ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا \add كْسِينْ نِيثْنِي\add* أَنِيرْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذ بِيلْعَامْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ إِ مِينْ إِقِّيمنْ زِي ڒَادْجْ ن وَارَّاونْ ن قَاهَاثْ.
\m 
\v 56 \bd أَرَّاونْ ن جَارْشُومْ\bd* \add كْسِينْ عَاوذْ\add* زِي ڒَادْجْ ن وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا: جُولَانْ ذِي بَاشَانْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ ذ عَاشْثَارُوثْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ.
\m 
\v 57 ؤُ زِي ثقْبِيتْشْ ن إِسَّاكَارْ \add كْسِينْ نِيثْنِي\add* قَاذَاشْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذُوبْرَا أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ،
\v 58 رَامُوثْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ ؤُ عَانِيمْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ.
\m 
\v 59 زِي ثقْبِيتْشْ ن أَشِيرْ \add كْسِينْ نِيثْنِي\add* مَاشَالْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذ عَابْذُونْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ،
\v 60 ذ حُوقُوقْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذ رَاحُوبْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ.
\m 
\v 61 زِي ثقْبِيتْشْ ن نَافْثَالِي \add كْسِينْ نِيثْنِي\add* قَاذَاشْ ذِي لْجَالِيلْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذ حَامُّونْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ ذ قَارْيَاثَايِيمْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ.
\m 
\v 62 \bd إِنِّي إِقِّيمنْ ن وَارَّاونْ ن مَارَارِي\bd* \add كْسِينْ عَاوذْ\add* زِي ثقْبِيتْشْ ن زابُولُونْ رِيمُّونُو أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذ ثابُورْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ
\m 
\v 63 ؤُ خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ غَارْ أَرِيحَا، شَّارْقْ ن لْ-ؤُرْذُونْ، \add كْسِينْ نِيثْنِي\add* زِي ثقْبِيتْشْ ن رُوبِينْ بَاصَارْ ذِي ڒخْڒَا أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذ يَاهْصَا أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ،
\v 64 ذ قَاذِيمُوثْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذ مَايْفَاعَا أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ،
\m 
\v 65 ؤُ زِي ثقْبِيتْشْ ن جَاذْ \add كْسِينْ نِيثْنِي\add* رَامُوثْ ذِي جِيلْعَاذْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذ مَاحَانَايِيمْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ،
\v 66 ذ حَاشْبُونْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ، ذ يَاعْزِيرْ أَكْ-ذ دّْمَانِي ن ثَاروْسَا نّسْ.
\b
\b
\c 7
\m 
\v 1 \bd أَرَّاونْ ن إِسَّاكَارْ\bd* \add ثُوغَا أَثنْ ذ\add* ثُولَاعْ ذ فُووَّا ذ يَاشُوبْ ذ شِيمْرُونْ، أَربْعَا \add ن وَارَّاونْ\add*.
\m 
\v 2 أَرَّاونْ ن ثُولَاعْ \add ثُوغَا أَثنْ ذ\add* عُوزِّي، رَافَايَا، يَارِييِيلْ، يَاحْمَايْ، يِيبْشَامْ ذ شِيمُووِيلْ، إِزدْجِيفنْ ن ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ ن ثُولَاعْ، أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، \add نِيثْنِي تّْوَازمّمنْ\add* عْلَاحْسَابْ أَخْڒَاقْ نْسنْ. ذڭْ وُوسَّانْ ن ذَاوُوذْ ثُوغَا ڒْقدّْ نْسنْ ثْنَاينْ ؤُ-عِيشْرِينْ-أَڒفْ ؤُ-ستَّا-مْيَا \add ن يرْيَازنْ\add*.
\m 
\v 3 أَرَّاونْ ن عُوزِّي، \add مْغِيرْ\add* يَازْرَاحْيَا، ؤُ أَرَّاونْ ن يَازْرَاحْيَا \add ثُوغَا أَثنْ ذ\add* مِيخَايِيلْ، عُوبَاذْيَا، يُووِيلْ ذ يَاشِّي-يَاهْ، نِيثْنِي مَارَّا \add ثُوغَا أَثنْ\add* خمْسَا ن إِزدْجِيفنْ.
\v 4 \add ثُوغَا\add* خَاسنْ \add ڒُْومُورْ خْ\add* ثرْبِيعِينْ ن ڒْعسْكَارْ، \add ؤُ نِيثْنِي ثُوغَا تّْوَاستّْفنْ\add* عْلَاحْسَابْ جَّاذِيرَا نْسنْ، عْلَاحْسَابْ ثَادَّارْثْ ن إِبَابَاثنْ نْسنْ. \add أَقَا-ثنْ\add* ذِي ستَّا ؤُ-ثْڒَاثِينْ-أَڒفْ \add ن يرْيَازنْ\add*، مَاغَارْ نِيثْنِي ثُوغَا غَارْسنْ أَطَّاسْ ن ثمْغَارِينْ ذ وَارَّاونْ. \f ◼ \fr 7:‏4 \ft \bd ’ثرْبِيعِينْ‘\bd* - س ثْعِيبْرَانِيثْ ’بَانْذِييَّاثْ‘. ؤُڒَا ذِي 12‏:19.\f*
\v 5 ؤُشَا \add خنِّي\add* أَيْثْمَاثْسنْ زِي مَارَّا ڒَادْجَاثْ ن إِسَّاكَارْ، سبْعَا ؤُ-ثْمَانْيِينْ-أَڒفْ ن أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، \add إِنِّي\add* إِتّْوَازمّمنْ مَارَّا ذِي لِيسْثَاثْ ن جَّاذِيرَا.
\b
\m 
\v 6 \bd \bdit أَرَّاونْ ن\bdit* بِينْيَامِينْ\bd* \add ثُوغَا أَثنْ ذ\add* بِيلَاعْ، بَاكَارْ ذ يَاذِيعَايِيلْ، ثْڒَاثَا \add ن وَارَّاونْ\add*.
\m 
\v 7 أَرَّاونْ ن بِيلَاعْ \add ثُوغَا أَثنْ ذ\add* إِصْبُونْ، عُوزِّي، عُوزِّييِيلْ، يَارِيمُوثْ ذ عَايْرِي، خمْسَا ن إِزدْجِيفنْ ن ڒَادْجَاثْ ن إِبَابَاثنْ، أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ. تّْوَازمّمنْ زَّايْسنْ ثْنَاينْ ؤُ-عِيشْرِينْ-أَڒفْ ؤُ-أَربْعَا ؤُ-ثْڒَاثِينْ \add ن يرْيَازنْ\add* ذِي لِيسْثَاثْ ن جَّاذِيرَا.
\m 
\v 8 أَرَّاونْ ن بَاكَارْ \add ثُوغَا أَثنْ ذ\add* زَامِيرَا، يُوعَاشْ، إِلِيعَازَارْ، إِلْيُوعِينَايْ، عُومْرِي، يَارِيمُوثْ، أَبِييَا، عَانَاثُوثْ ذ عَالَامَاثْ. نِيثْنِي مَارَّا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن بَاكَارْ.
\v 9 تّْوَازمّمنْ زَّايْسنْ عِيشْرِينْ-أَڒفْ ؤُ-مِيثَايْنْ ن أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ ذِي لِيسْثَاثْ ن ڒَادْجَاثْ، عْلَاحْسَابْ جَّاذِيرَا نْسنْ \add ؤُ نِيثْنِي ثُوغَا تّْوَاستّْفنْ عْلَاحْسَابْ\add* إِزدْجِيفنْ ن ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ.
\m 
\v 10 أَرَّاونْ ن يَاذِيعِيلْ، \add مْغِيرْ\add* بِيلْهَانْ. ؤُ أَرَّاونْ ن بِيلْهَانْ \add ثُوغَا أَثنْ ذ\add* يَاعِيشْ، بِينْيَامِينْ، إِهُوذْ، كَانْعَانَا، زَايْثَانْ، ثَارْشِيشْ ذ أَخِيشَاحَارْ.
\v 11 نِيثْنِي مَارَّا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن يَاذِيعِيلْ. سْبعْطَاشْ-أَڒفْ ؤُ-مِيثَايْنْ ن أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ فّْغنْ غَارْ ؤُمنْغِي أَكْ-ذ ڒْعسْكَارْ، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ إِزدْجِيفنْ ن ڒَادْجَاثْ نْسنْ.
\m 
\v 12 شُوفِّيمْ ذ هُوفِّيمْ \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن عِيرْ، هُوشِيمْ، أَرَّاونْ ن أَحِيرْ.
\b
\m 
\v 13 \bd أَرَّاونْ ن نَافْثَالِي\bd* \add ثُوغَا أَثنْ ذ\add* جَاحْصِييِيلْ، جُونِي، يَاصَارْ ذ شَالُّومْ، أَرَّاونْ ن بِيلْهَا.
\b
\m 
\v 14 \bd أَرَّاونْ ن مَانَاسَّا:\bd* أَشْرِييِيلْ، ونِّي إِ ذ أَسْ د-ثُورُووْ \add ثمْغَارْثْ نّسْ\add*. ثَايَّا نّسْ، \add إِشْثْ ن ثمْغَارْثْ\add* ثَارَامِيثْ، ثُورُووْ-د مَاخِيرْ، بَابَاسْ ن جِيلْعَاذْ. \f ◼ \fr 7:‏14 \ft \bd ’ثَارَامِيثْ‘\bd* - إِشْثْ ن ثمْغَارْثْ زِي ثمُّورْثْ ن أَرَامْ.\f*  \x ◘ \xo 7:‏14 \xt ڒخْڒ. 26‏:‏28‏-‏34\x*
\m 
\v 15 مَاخِيرْ إِكْسِي إِشْثْ ن ثمْغَارْثْ إِ حُوفِّيمْ ذ شُوفِّيمْ. إِسمْ ن ؤُتْشْمَاسْ \add ثُوغَا-ت ذ\add* مَاعْكَا. إِسمْ ن ونِّي وِيسّْ ثْنَاينْ \add ثُوغَا-ث ذ\add* صَالُوفْحَاذْ. صَالُوفْحَاذْ غَارسْ يسِّيسْ \add وَاهَا\add*.
\m 
\v 16 مَاعْكَا، ثَامْغَارْثْ ن مَاخِيرْ، ثُورُووْ-د إِجّْ ن مِّيسْ ؤُشَا ثڭَّا أَسْ فَارَاشْ ؤُ ؤُمَاسْ قَّارنْ أَسْ شَارَاشْ ؤُ أَرَّاونْ نّسْ \add ثُوغَا أَثنْ ذ\add* ؤُلَامْ ذ رَاقَامْ.
\m 
\v 17 أَرَّاونْ ن ؤُلَامْ: \add مْغِيرْ\add* بَاذَانْ. إِنَا ذ أَرَّاونْ ن جِيلْعَاذْ، مِّيسْ ن مَاخِيرْ، مِّيسْ ن مَانَاسَّا.
\m 
\v 18 خْ ؤُتْشْمَاسْ هَامُولَاكَاثْ، نتَّاثْ ثُورُووْ-د إِشْهُوذْ، أَبِيعَازَارْ ذ مَاحْلَا.
\m 
\v 19 أَرَّاونْ ن شَامِيذَاعْ \add ثُوغَا أَثنْ ذ\add* إِخْيَانْ، شَاكِيمْ ذ لَاقْحِي ذ أَنِيعَامْ.
\b
\m 
\v 20 \bd أَرَّاونْ ن إِفْرَايِيمْ\bd*، \add مْغِيرْ\add* شُوثَالَاحْ. مِّيسْ ثُوغَا بَارَاذْ، مِّيسْ ثَاحَاثْ، مِّيسْ إِلْعَاذَا، مِّيسْ ثَاحَاثْ، \x ◘ \xo 7:‏20 \xt ڒخْڒ. 26‏:‏35‏-‏37\x*
\v 21 مِّيسْ زَابَاذْ، مِّيسْ شُوثَالَاحْ ؤُ \add خنِّي\add* عَازَارْ ذ إِلْعَاذْ. إِرْيَازنْ ن جَاثْ، إِنِّي د-إِتّْوَاخڒْقنْ ذِي ثمُّورْثْ، نْغِينْ ثنْ، مِينْزِي نِيثْنِي ثُوغَا هْوَانْ، حِيمَا أَذْ كّْسنْ ڒْمَاڒْ نْسنْ.
\m 
\v 22 إِفْرَايِيمْ، بَابَاثْسنْ، إِشْضنْ أَطَّاسْ ن وُوسَّانْ ؤُشَا أَيْثْمَاسْ ؤُسِينْ-د حِيمَا أَذْ ثعزَّانْ.
\v 23 خنِّي يُوذفْ نتَّا خْ ثمْغَارْثْ نّسْ ؤُشَا ثكْسِي دّيْسثْ ؤُشَا ثُورُووْ-د إِجّْ ن ؤُحنْجِيرْ. نتَّا إِڭَّا أَسْ بَارِيعَا، مِينْزِي \add ذڭْ وُوسَّانْ نِّي\add* ثُوغَا ذ أَرْژِييّثْ ذِي ثَادَّارْثْ نّسْ.
\m 
\v 24 يدْجِيسْ \add ثُوغَا\add* شِيرَا. نتَّاثْ ثسّْبدّْ بَايْثْ-حُورُونْ ن وَادَّايْ ذ \add بَايْثْ-حُورُونْ\add* ن نّجْ ذ ؤُزِّينْ-شِيرَا.
\m 
\v 25 رَافَاعْ \add ثُوغَا\add* ذ مِّيسْ ؤُڒَا ذ رَاشَافْ. ؤُشَا مِّيسْ ثُوغَا ذ ثَالَاحْ، مِّيسْ ثَاحَانْ،
\v 26 مِّيسْ لَاعْذَانْ، مِّيسْ عَامِّيهُوذْ، مِّيسْ إِلِيشَامَاعْ،
\v 27 مِّيسْ نُونْ \add ذ\add* مِّيسْ يَاشُووَا. \f ◼ \fr 7:‏27 \ft \bd ’يَاشُووَا‘\bd* - إِسمْ إِكّمْڒنْ نّسْ ’يَاهُو-شُووَا‘.\f*
\m 
\v 28 أَڭْڒَا نْسنْ ذ إِمُوشَانْ مَانِي زدّْغنْ \add ثُوغَا\add* بَايْثْ-إِلْ أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ، ذ نَاعْرَانْ غَارْ شَّارْقْ ؤُ جَازَارْ غَارْ ڒْغَارْبْ أَكْ-ذ ثْندَّامْ إِ غَارْسنْثْ د-إِقّْننْ، ؤُڒَا ذ شَاكِيمْ أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ أَڒْ غَازَّا أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ.
\v 29 ثُوغَا بَايْثْ-شَانْ أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ، ثَاعْنَاكْ أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ، مَاجِيدُّو أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ \add ؤُ\add* ذُورْ أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ ذڭْ إِفَاسّنْ ن أَيْثْ ن مَانَاسَّا. أَيْثْ ن يُوسُوفْ، مِّيسْ ن إِسْرَائِيل، ثُوغَا زدّْغنْ ذَايْسنْثْ.
\b
\m 
\v 30 \bd أَرَّاونْ ن أَشِيرْ\bd* \add ثُوغَا أَثنْ ذ\add* يِيمْنَا، يِيشْوَا، يِيشْوِي، بَارِيعَا ذ سَارَاحْ \add ثنِّي ذ\add* ؤُتْشْمَاثْسنْ.
\m 
\v 31 أَرَّاونْ ن بَارِيعَا \add ثُوغَا أَثنْ ذ\add* حَابِيرْ ذ مَالْكِييِيلْ. نتَّا ذ بَابَا ن بِيرْزَاوَاثْ.
\m 
\v 32 حَابِيرْ إِجَّا-د يَافْلِيطْ، شُومِيرْ، حُوثَامْ ذ شُوعَا، ؤُتْشْمَاثْسنْ
\v 33 أَرَّاونْ ن يَافْلِيطْ \add ثُوغَا أَثنْ ذ\add* فَاسَاكْ، بِيمْهَالْ ذ عَاشْوَاثْ. إِنَا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن يَافْلِيطْ.
\m 
\v 34 أَرَّاونْ ن شَامَارْ \add ثُوغَا أَثنْ ذ\add* أَخِي، رُوهْجَا، يَاهُوبَّا ذ أَرَامْ.
\m 
\v 35 أَرَّاونْ ن ؤُمَاسْ هِيلَامْ \add ثُوغَا أَثنْ ذ\add* صُوفَاحْ، يِيمْنَاحْ، شَالَاشْ ذ عَامَالْ.
\m 
\v 36 أَرَّاونْ ن صُوفَاحْ \add ثُوغَا أَثنْ ذ\add* سُووَاحْ، حَارَانْفَارْ، شُوعَالْ، بِيرِي، يَامْرَا،
\v 37 بَاصَارْ، هُوذْ، شَامَّا، شِيلْشَا، يِيثْرَانْ ذ بَائِيرَا.
\m 
\v 38 أَرَّاونْ ن يِيثْرَامْ \add ثُوغَا أَثنْ ذ\add* يَافُونِّي، فِيشْفَا ذ أَرَا.
\m 
\v 39 أَرَّاونْ ن عُولَّا \add ثُوغَا أَثنْ ذ\add* أَرَاحْ، حَانِييِيلْ ذ رِيصْيَا.
\m 
\v 40 مَارَّا إِنَا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن أَشِيرْ، إِزدْجِيفنْ ن ڒَادْجَاثْ ن إِبَابَاثنْ، أَيْثْ ن بُو-ثغْرُوضْثْ إِفَارْزنْ إِمحْضنْ، إِزدْجِيفنْ ن ڒْحُوكَّامْ. نِيثْنِي تّْوَازمّمنْ ذِي لِيسْثَاثْ ن جَّاذِيرَا ن ڒْعسْكَارْ إِ ؤُمنْغِي. \add ثُوغَا\add* ڒْقدّْ نْسنْ ستَّا ؤُ-عِيشْرِينْ-أَڒفْ ن يرْيَازنْ.
\b
\b
\c 8
\s1 ثَارْوَا ن بِينْيَامِينْ
\m 
\v 1 بِينْيَامِينْ إِجَّا-د بِيلَاعْ، أَمنْزُو نّسْ، أَشْبِيلْ ذ وِيسّْ ثْنَاينْ، أَخْرَاخْ ذ وِيسّْ ثْڒَاثَا،
\v 2 نَاحُو ذ وِيسّْ أَربْعَا ؤُ رَافَا ذ وِيسّْ خمْسَا.
\m 
\v 3 بِيلَاعْ ثُوغَا غَارسْ أَرَّاونْ-أَ: أَدَّارْ، جِيرَا ذ أَبِيهُوذْ،
\v 4 أَبِيشُوعَا، نُوعْمَانْ، أَخُوخَا،
\v 5 جِيرَا، شَافُوفَانْ ذ حُورَامْ.
\m 
\v 6 إِنَا ذ أَرَّاونْ ن أَحُوذْ. نِيثْنِي \add ثُوغَا أَثنْ ذ\add* إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ن إِمزْذَاغْ ن جِيبْعَا. نذْهنْ إِ-ثنْ غَارْ مَانَاحَاثْ،
\v 7 أَقَا ذ نَاعْمَانْ، أَخِييَا ذ جِيرَا. نتَّا إِنْذهْ إِ-ثنْ. ؤُ نتَّا إِجَّا-د عُوزَّا ذ أَخِيحُوذْ.
\m 
\v 8 شَاحَارَايِيمْ إِجَّا-د \add إِحنْجِيرنْ\add* ذِي ثمُّورْثْ ن مُوآبَ، أَوَارْنِي إِ ؤُمِي ثُوغَا إِسُّوفّغْ ثِيمْغَارِينْ نّسْ حُوشِيمْ ذ بَاعْرَا.
\v 9 أَكْ-ذ ثمْغَارْثْ نّسْ خُوذَاشْ إِجَّا-د يُوبَابْ، ضِيبْيَا، مِيشَا، مَالْكَامْ،
\v 10 يَاعُوصْ، شَابِييَا ذ مِيرْمَا. إِنَا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ نّسْ، إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add*.
\v 11 أَكْ-ذ حُوشِيمْ إِجَّا-د نتَّا أَبِيطُوبْ ذ إِلْفَاعَالْ.
\m 
\v 12 أَرَّاونْ ن إِلْفَاعَالْ \add ثُوغَا أَثنْ ذ\add* عَابِيرْ، مِيشْعَامْ، شَامِيذْ نِّي إِبْنَانْ ؤُنُو ذ لُوذْ أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ،
\v 13 بَارِيعَا ذ شَامَاعْ. إِنَا \add ثُوغَا أَثنْ ذ\add* إِزدْجِيفنْ ن إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ن إِمزْذَاغْ ن أَيَالُونْ. نِيثْنِي ؤُژّْڒنْ خْ إِمزْذَاغْ ن جَاثْ.
\m 
\v 14 أَخِييُو، شَاشَاقْ، يَارِيمُوثْ،
\v 15 زَابَاذْيَا، عَارَاذْ، عَاذَارْ،
\v 16 مِيخَايِيلْ، جِيشْفَا ذ يُوخَا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن بَارِيعَا.
\m 
\v 17 زَابَاذْيَا، مَاشُولَّامْ، حَازْكِي، حَابِيرْ،
\v 18 يِيشْمَارَايْ، يَازْلِييَا ذ يُوبَابْ \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن إِلْفَاعَالْ.
\m 
\v 19 يَاقِيمْ، زِيكْرِي، زَابْذِي،
\v 20 إِلِيعِينَايْ، صِيلَّاثَايْ، إِلِييِيلْ،
\v 21 عَاذَايَا، بَارَايَا ذ شِيمْرَا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن شِيمِي.
\m 
\v 22 يِيشْفَانْ، عَابِيرْ، إِلِييِيلْ،
\v 23 عَابْذُونْ، زِيخْرِي، حَانَانْ،
\v 24 حَانَانْيَا، عِيلَامْ، عْنْثُوثِييَا،
\v 25 يَافْذِييَا ذ فَانُووِيلْ \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن شَاشَاقْ.
\m 
\v 26 شَامْشَارَايْ، شَاحَارْيَا، عَاثَالْيَا،
\v 27 يَاعْرَاشْيَا، إِلِييَا ذ زِيكْرِي \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن يَارُوحَامْ.
\m 
\v 28 إِنَا \add ثُوغَا أَثنْ ذ\add* إِزدْجِيفنْ خْ إِبَابَاثنْ، \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ جَّاذِيرَا نْسنْ، إِزدْجِيفنْ \add إِ إِدْجَانْ\add*. نِيثْنِي ثُوغَا زدّْغنْ ذِي ؤُرْشَالِيمْ.
\b
\s1 فَامِيلْيَا ن شَاوُولْ
\m 
\v 29 ذِي جِيبْعُونْ إِزْذغْ بَابَاسْ ن جِيبْعُونْ ؤُ ثَامْغَارْثْ نّسْ قَّارنْ أَسْ مَاعْكَا.
\v 30 أَمنْزُو نّسْ \add ثُوغَا\add* عَابْذُونْ، \add خنِّي\add* صُورْ، قِيسْ، بَاعَالْ، نَاذَابْ،
\v 31 جَاذُورْ، أَخِّييُو ذ زَاكِيرْ.
\m 
\v 32 مِيقْلُوثْ إِجَّا-د شَامَا. ؤُڒَا ذ نِيثْنِي زذْغنْ ذِي ؤُرْشَالِيمْ أَجمَّاضْ ن أَيْثْمَاثْسنْ، \add جْمِيعْ\add* أَكْ-ذ يَايْثْمَاثْسنْ.
\m 
\v 33 نِيرْ إِجَّا-د قِيسْ ؤُ قِيسْ إِجَّا-د شَاوُولْ ؤُ شَاوُولْ إِجَّا-د يُونَاثَانْ، مَالْكِيشُوعَا، أَبِينَاذَابْ ذ إِشْبَاعَالْ.
\m 
\v 34 مِّيسْ ن يُونَاثَانْ \add ثُوغَا\add* مَارِيبْ-بَاعَالْ. مَارِيبْ-بَاعَالْ إِجَّا-د مِيخَا.
\m 
\v 35 أَرَّاونْ ن مِيخَا \add ثُوغَا أَثنْ ذ\add* فِيثُونْ، مَالِيكْ، ثَارِيعْ ذ أَحَازْ.
\m 
\v 36 أَحَازْ إِجَّا-د يَاهُوعَادَّا ؤُ يَاهُوعَادَّا إِجَّا-د عَالْمَاثْ، عَازْمَاوثْ ذ زِيمْرِي. زِيمْرِي إِجَّا-د مُوصَا،
\m 
\v 37 ؤُ مُوصَا إِجَّا-د بِينْعَا. مِّيسْ \add ثُوغَا\add* رَافَاعْ، مِّيسْ إِلْعَاسَا \add ذ\add* مِّيسْ أَصِييَالْ.
\m 
\v 38 أَصِييَالْ ثُوغَا غَارسْ ستَّا ن وَارَّاونْ ؤُ إِنَا ذ إِسْمَاونْ نْسنْ: عَازْرِيقَامْ، بُوكْرَا، إِسْمَاعِيلْ، شَاعَارْيَا، عُوبَاذْيَا ذ حَانَانْ. نِيثْنِي مَارَّا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن أَصِييَالْ.
\m 
\v 39 أَرَّاونْ ن ؤُمَاسْ عَاشِيقْ \add ثُوغَا أَثنْ ذ\add* ؤُلَامْ، أَمزْوَارُو نّسْ، \add ؤُ\add* وِيسّْ ثْنَاينْ \add ثُوغَا-ث ذ\add* يَاعُوشْ ذ وِيسّْ ثْڒَاثَا إِلِيفَالَاطْ.
\m 
\v 40 أَرَّاونْ ن ؤُلَامْ \add ثُوغَا أَثنْ ذ\add* إِرْيَازنْ، أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ نِّي إِمحْضنْ ڒْقوْسْ. نِيثْنِي ثُوغَا غَارْسنْ أَطَّاسْ ن وَارَّاونْ ذ وَايَّاونْ، \add س مَارَّا\add* مْيَا ؤُ-خمْسِينْ. مَارَّا إِنَا زڭْ وَارَّاونْ ن بِينْيَامِينْ.
\b
\b
\c 9
\s1 إِمزْذَاغْ ن ؤُرْشَالِيمْ
\m 
\v 1 مَارَّا إِسْرَائِيل إِتّْوَازمّمْ \add ذِي لِيسْثَاثْ ن جَّاذِيرَا\add* ؤُ خْزَارْ، نِيثْنِي تّْوَازمّمنْ ذڭْ وذْلِيسْ ن إِجدْجِيذنْ ن إِسْرَائِيل ذ يَاهُوذَا. إِتّْوَانْذهْ يَاهُوذَا غَارْ لْمنْفَا غَارْ بَابِيلْ ذِي سِّيبّثْ ن ڒغْذَارْ نْسنْ.
\b
\m 
\v 2 إِمزْذَاغْ إِمزْوُورَا \add إِ إِڭِّينْ أَذْ زذْغنْ\add* خْ وَاڭْڒَا نْسنْ ذِي ثْندَّامْ نْسنْ، \add ثُوغَا أَثنْ\add* \add أَيْثْ ن\add* إِسْرَائِيل، \add ؤُشَا ؤُڒَا\add* ذ إِكهَّاننْ ذ إِلَاوِييّنْ ذ إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ.
\b
\m 
\v 3 زڭْ وَارَّاونْ ن \bd يَاهُوذَا\bd* ؤُ زڭْ وَارَّاونْ ن \bd بِينْيَامِينْ\bd* ؤُ زڭْ وَارَّاونْ ن \bd إِفْرَايِيمْ\bd* ؤُ زڭْ وَارَّاونْ ن \bd مَانَاسَّا\bd* زذْغنْ \add إِنَا\add* ذِي ؤُرْشَالِيمْ:
\m 
\v 4 عُوثَايْ، مِّيسْ ن عَامِّيهُوذْ، مِّيسْ ن عُومْرِي، مِّيسْ ن إِمْرِي، مِّيسْ ن بَانِي. \add نتَّا ثُوغَا\add* زڭْ وَارَّاونْ ن فَارِيصْ، مِّيسْ ن يَاهُوذَا.
\m 
\v 5 زڭْ أَشِيلُونِي\add يّنْ\add*: عَاسَايَا، أَمنْزُو أَكْ-ذ وَارَّاونْ نّسْ،
\m 
\v 6 ؤُ زڭْ وَارَّاونْ ن زَارَاحْ: يَاعُويِيلْ \add وَاهَا\add*.
\m أَيْثْمَاثْسنْ \add ثُوغَا أَثنْ\add* ذِي ستَّا مْيَا ؤُ-ثسْعِينْ.
\b
\m 
\v 7 زڭْ وَارَّاونْ ن بِينْيَامِينْ: سَالُّو، مِّيسْ ن مَاشُولَّامْ، مِّيسْ ن هُوذُويَا، مِّيسْ ن هَاسْنُووَا،
\v 8 ذ يِيبْنِييَا، مِّيسْ ن يَارُوحَامْ؛ ؤُ إِلَا، مِّيسْ ن عُوزِّي، مِّيسْ ن مِيكْرِي؛ ؤُ مَاشُولَّامْ، مِّيسْ ن شَافَاطْيَا، مِّيسْ ن رَاعُويِيلْ، مِّيسْ ن يِيبْنِييَا.
\m 
\v 9 أَيْثْمَاثْسنْ، \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ جَّاذِيرَا نْسنْ، \add ثُوغَا أَثنْ ذِي\add* ثسْعَا-مْيَا ؤُ-ستَّا ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*. مَارَّا إِرْيَازنْ-أَ \add ثُوغَا أَثنْ\add* ذ إِزدْجِيفنْ خْ إِبَابَاثنْ ن ڒَادْجَاثْ نْسنْ.
\b
\m 
\v 10 زڭْ \bd إِكهَّاننْ\bd*: يَاذَاعْيَا، يَاهُويَارِيبْ ذ يَاكِينْ؛
\v 11 ذ عَازَارْيَا، مِّيسْ ن حِيلْقِييَا، مِّيسْ ن مَاشُولَّامْ، مِّيسْ ن صَاذُوقْ، مِّيسْ ن مَارَايُوثْ، مِّيسْ ن أَخِيطُوبْ، ڒْحَاكمْ ن ثَادَّارْثْ ن أَربِّي؛
\v 12 ذ عَاذَايَا، مِّيسْ ن يَارُوحَامْ، مِّيسْ ن فَاشْحُورْ، مِّيسْ ن مَالْكِييَا؛ ؤُ مَاعْسَايْ، مِّيسْ ن عَاذِييِيلْ، مِّيسْ ن يَاحْزِيرَا، مِّيسْ ن مَاشُولَّامْ، مِّيسْ ن مَاشِيلِّيمِيثْ، مِّيسْ ن إِمِّيرْ.
\m 
\v 13 أَيْثْمَاثْسنْ \add إِنِّي ثُوغَا إِقّْننْ غَارْ\add* إِزدْجِيفنْ ن ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، \add ثُوغَا أَثنْ ذڭْ\add* أَڒفْ ؤُ-سبْعَا-مْيَا ؤُ-ستِّينْ ن أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، \add إِنِّي إِڭِّينْ\add* ڒْخذْمثْ ن ثْسخَّارْثْ ذِي ثَادَّارْثْ ن أَربِّي.
\b
\m 
\v 14 زڭْ \bd إِلَاوِييّنْ\bd*: شَامْعِييَا، مِّيسْ ن حَاشُوبْ، مِّيسْ ن عَازْرِيقَامْ، مِّيسْ ن حَاشَابْيَا، زڭْ وَارَّاونْ ن مَارَارِي،
\v 15 ذ بَاقْبَاقَارْ ذ حَارَاشْ ذ جَالَالْ ذ مَاثَانْيَا، مِّيسْ ن مِيخَا، مِّيسْ ن زِيكْرِي، مِّيسْ ن أَسَافْ؛
\v 16 ذ عُوبَايَا، مِّيسْ ن شَامْعِييَا، مِّيسْ ن جَالَالْ، مِّيسْ ن يَاذُوثُونْ؛ ذ بَارَاخْيَا، مِّيسْ ن أَسَا، مِّيسْ ن إِلْقَانَا، ونِّي إِزدّْغنْ ذِي ڒذْشُورْ ن إِنَاطُوفَاثِييّنْ.
\b
\m 
\v 17 \bd إِعسَّاسنْ ن ثوَّارْثْ\bd* \add ثُوغَا أَثنْ ذ\add* شَالُّومْ، عَاقُّوبْ، طَالْمُونْ ذ أَخِيمَانْ ذ ثَاوْمَاثْ نْسنْ. شَالُّومْ \add ثُوغَا-ث ذ\add* أَزدْجِيفْ.
\v 18 أَڒْ ڒخُّو \add بدّنْ نِيثْنِي\add* غَارْ ثوَّارْثْ ن ؤُجدْجِيذْ ذِي مَانِيسْ إِ د-ثْنقَّارْ ثْفُوشْثْ. نِيثْنِي ذ إِعسَّاسنْ ن ثوَّارْثْ غَارْ ڒمْرَاڭحْ ن ڒْعسْكَارْ ن أَيْثْ ن لَاوِي. \x ◘ \xo 9:‏18 \xt 1 Ki. 10‏:‏5؛ 2 إِج. 16‏:‏18\x*
\v 19 شَالُّومْ، مِّيسْ ن قُورِي، مِّيسْ ن أَبِييَاسَافْ، مِّيسْ ن قُورَاحْ، ذ أَيْثْمَاسْ، \add إِنِّي ثُوغَا إِقّْننْ\add* غَارْ ثَادَّارْثْ ن بَابَاسْ، إِخْسْ أَذْ يِينِي إِقُورَاحِييّنْ، \add ثُوغَا أَثنْ\add* خْ ڒْخذْمثْ ن ثْسخَّارْثْ. نِيثْنِي ثُوغَا-ثنْ ذ إِعسَّاسنْ غَارْ ثْنبْذَاثِينْ ن ؤُقِيضُونْ، أَمْ مَامّشْ ثُوغَا ڒجْذُوذْ نْسنْ ذ إِعسَّاسنْ ن وَاذَافْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ن سِيذِي.
\v 20 فِينَاحَاسْ، مِّيسْ ن أَلِيعَازَارْ، \add ثُوغَا-ث\add* زِيشْ ذ ڒْحَاكمْ نْسنْ. سِيذِي \add ثُوغَا\add* أَكِيذسْ.
\v 21 زَاكَارِييَّا، مِّيسْ ن مَاشَالْمِييَا، \add ثُوغَا-ث ذ\add* أَعسَّاسْ ن ثوَّارْثْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.
\m 
\v 22 مَارَّا إِنِّي إِتّْوَافَارْزنْ أَمْ يِيعسَّاسنْ ن ثوَّارْثْ غَارْ وَاذَافنْ، \add ثُوغَا أَثنْ ذِي\add* مِيثَاينْ ؤُ-ثنْعَاشْ \add ن يرْيَازنْ\add*. نِيثْنِي تّْوَازمّمنْ \add ذِي لِيسْثَا ن جَّاذِيرَا\add* ذِي ڒذْشُورْ نْسنْ. ذَاوُوذْ ذ شَامْوِيلْ، أَمْوَاڒَاوْ، سّْمثْننْ ثنْ ذِي ڒْفُوسِينَا إِ ذ أَسنْ د-إِتّْوَاوكّْڒنْ.
\v 23 نِيثْنِي ثُوغَا تّْعسَّانْ أَكْ-ذ وَارَّاونْ نْسنْ غَارْ ثوُّورَا ن ثَادَّارْثْ ن سِيذِي، غَارْ ثَادَّارْثْ ن ؤُقِيضُونْ.
\v 24 إِعسَّاسنْ ن ثوُّورَا \add ثُوغَا بدّنْ\add* غَارْ أَربْعَا \add ن إِغزْذِيسنْ\add* ن ؤُسمِّيضْ: غَارْ شَّارْقْ، غَارْ ڒْغَارْبْ، غَارْ شَّامَالْ، غَارْ لْجَانُوبْ.
\v 25 ثُوغَا خْ أَيْثْمَاثْسنْ، \add إِنِّي ثُوغَا إِزدّْغنْ\add* ذِي ڒذْشُورْ نْسنْ، أَذْ د-أَسنْ ذڭْ وَاسّْ وِيسّْ سبْعَا، حِيمَا \add أَذْ سخَّارنْ ڒْمِيجَاڒْ ن إِشْثْ ن سِّيمَانَا\add* ذِي ڒْوَاوْقَاثْ إِتّْوَاڭّنْ، \add جْمِيعْ\add* أَكِيذْسنْ،
\v 26 مَاغَارْ ذِي ڒْخذْمثْ إِ ذ أَسنْ-د إِتّْوَاوكّْڒنْ ثُوغَا نِيثْنِي ذ أَربْعَا ن إِعسَّاسنْ إِمزْوُورَا خْ ثوُّورَا. نِيثْنِي، إِخْسْ أَذْ يِينِي إِلَاوِييّنْ، تّْوَاڒقّْمنْ خْ إِخَّامنْ ؤُ خْ ثْخُوبَايْ ن ثَادَّارْثْ ن أَربِّي.
\v 27 ذِي دْجِيڒثْ سّنْسنْ ذڭْ ونّضْ ن ثَادَّارْثْ ن أَربِّي، مَاغَارْ ثُوغَا تّْوَاكلّْفنْ س ثْعسَّاسْثْ ذ وَارْزَامْ \add ن ثوُّورَا\add* كُوڒْ صّْبحْ.
\v 28 \add شَا\add* زَّايْسنْ \add تّْوَاڭّنْ\add* خْ دُّوزَانَاثْ ن ثْسخَّارْثْ، مَاغَارْ نِيثْنِي حسّْبنْ \add ثنْ\add* ؤُمِي ثنْ سِّيذْفنْ ؤُ ؤُمِي ثنْ سُّوفّْغنْ.
\v 29 \add شَا نّغْنِي\add* زَّايْسنْ تّْوَاڭّنْ خْ دُّوزَانَاثْ ؤُ خْ مَارَّا ڒقْشُوعْ إِقدّْسنْ ؤُ خْ وَارنْ أَزْذَاذْ ذ بِينُو ذ زّشْثْ ذ جَّاوِي ذ ڒعْطُورْ.
\m 
\v 30 إِمْسوْجَّاذنْ ن ثْخدْجضْثْ إِتّْفُوحنْ أَكْ-ذ ڒعْطُورْ \add ثُوغَا أَثنْ\add* زڭْ وَارَّاونْ ن إِكهَّاننْ.
\m 
\v 31 مَاتِّيثْيَا، \add إِجّنْ\add* زڭْ أَيْثْ ن لَاوِي، \add ثُوغَا\add* ذ أَمنْزُو ن شَالُّومْ، أَقُورَاحِي. إِتّْوَاوكّڒْ أَسْ مَاحنْذْ أَذْ إِسّوْجذْ مِينْ إِتّْخصَّا أَذْ سّنْڭْونْ.
\v 32 زڭْ وَارَّاونْ ن إِقَاهَاثِييّنْ، زڭْ أَيْثْمَاثْسنْ، \add ثُوغَا شَا\add* تّْوَاڒقّْمنْ خْ وغْرُومْ ن وسْشَانْ، حِيمَا أَذْ ث سَّارْسنْ \add ذِي طَّابْڒَا\add* كُوڒْ أَسّْ ن سّبْثْ.
\m 
\v 33 نِيثْنِي \add ثُوغَا أَثنْ\add* ؤُڒَا ذ إِمذْيَازنْ، إِزدْجِيفنْ ن إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ن إِلَاوِييّنْ، إِنِّي إِتّْوَانْفكّنْ \add زِي ڒخْذَايمْ نّغْنِي\add* مِينْزِي ثُوغَا خَاسنْ حِيمَا أَذْ شغْڒنْ أَكْ-ذ ڒْخذْمثْ-أَ أَسّْ ذ دْجِيڒثْ.
\m 
\v 34 إِنَا \add ثُوغَا أَثنْ ذ\add* إِزدْجِيفنْ ن إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ن إِلَاوِييّنْ، \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ جَّاذِيرَا نْسنْ، إِزدْجِيفنْ \add إِ إِدْجَانْ\add*. نِيثْنِي ثُوغَا زدّْغنْ ذِي ؤُرْشَالِيمْ.
\b
\s1 ثَارْوَا ن جِيبْعُونْ
\m 
\v 35 ذِي جِيبْعُونْ زذْغنْ يَاعِييِيلْ، بَابَاسْ ن جِيبْعُونْ، ؤُ إِسمْ ن ثمْغَارْثْ نّسْ ثُوغَا-ث مَاعْكَا.
\v 36 مِّيسْ أَمنْزُو \add ثُوغَا\add* عَابْذُونْ. \add ثُوغَا زدّْغنْ ذِينْ عَاوذْ\add* صُورْ، قِيسْ، نِيرْ، نَاذَابْ،
\v 37 جَاذُورْ، أَخِييُو، زَاكَارِييَّا ذ مِيقْلُوثْ.
\v 38 مِيقْلُوثْ إِجَّا-د شِيمْعَا. نِيثْنِي ثُوغَا زدّْغنْ أَجمَّاضْ ن أَيْثْمَاثْسنْ ذِي ؤُرْشَالِيمْ، \add جْمِيعْ\add* أَكْ-ذ أَيْثْمَاثْسنْ \add إِنّغْنِي\add*.
\m 
\v 39 نِيرْ إِجَّا-د قِيسْ، قِيسْ إِجَّا-د شَاوُولْ ؤُ شَاوُولْ إِجَّا-د يُونَاثَانْ، مَالْكِيشُوعَا، أَبِينَاذَابْ ذ إِشْبَاعَالْ.
\m 
\v 40 مِّيسْ ن يُونَاثَانْ \add ثُوغَا\add* مَارِيبْ-بَاعَالْ، ؤُ مَارِيبْ-بَاعَالْ إِجَّا-د مِيخَا.
\m 
\v 41 أَرَّاونْ ن مِيخَا \add ثُوغَا أَثنْ ذ\add* فِيثُونْ، مَالَاكْ ذ ثَاحْرِيعَا.
\m 
\v 42 أَحَازْ إِجَّا-د يَاعْرَا، ؤُ يَاعْرَا إِجَّا-د عَالْمَاثْ، عَازْمَاوثْ ذ زِيمْرِي، ؤُ زِيمْرِي إِجَّا-د مُوصَا،
\m 
\v 43 ؤُ مُوصَا إِجَّا-د بِينْعَا. مِّيسْ \add ثُوغَا\add* رَافَايَا، مِّيسْ إِلْعَاسَا \add ذ\add* مِّيسْ نّسْ أَصِيلْ.
\m 
\v 44 أَصِيلْ ثُوغَا غَارسْ ستَّا ن وَارَّاونْ ؤُ إِنَا ذ إِسْمَاونْ نْسنْ: عَازْرِيقَامْ ذ بُوكْرَا ذ إِسْمَاعِيلْ ذ شَاعَارْيَا ذ عُوبَاذْيَا ذ حَانَانْ. إِنَا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن أَصِيلْ.
\b
\b
\c 10
\s1 ڒْموْثْ ن شَاوُولْ
\m 
\v 1 مّنْغنْ إِفِيلِيسْطِينِييّنْ أَكْ-ذ إِسْرَائِيل. إِرْيَازْ\add أنْ\add* ن إِسْرَائِيل أَروْڒنْ زَّاثْ إِ وُوذمْ ن إِفِيلِيسْطِينِييّنْ ؤُشَا وْضَانْ ذ إِمتَّانْ خْ ثمُّورْثْ ن إِذُورَارْ ن جِيلْبُوعَا. \x ◘ \xo 10:‏1 \xt [1 صم. 31‏:‏1‏-‏13]\x*
\v 2 إِفِيلِيسْطِينِييّنْ ضْفَارنْ شَاوُولْ ذ أَرَّاونْ نّسْ بْڒَا قطُّو. إِفِيلِيسْطِينِييّنْ نْغِينْ يُونَاثَانْ، أَبِينَاذَابْ ذ مَالْكِيشُوعَا، أَرَّاونْ ن شَاوُولْ.
\v 3 ثُوغَا أَمنْغِي أَكْ-ذ شَاوُولْ إِوْعَارْ. إِمْجبَّاذنْ نْ ڒْقوْسْ ؤُفِينْ ث ؤُ نتَّا ثُوغَا إِڭّْوذْ أَطَّاسْ زڭْ إِمْجبَّاذنْ نْ ڒْقوْسْ.
\v 4 إِنَّا شَاوُولْ إِ ؤُحمَّاڒْ ن ڒسْنَاحْ نّسْ: ”سُوفّغْ-د سِّيفْ نّشْ، سْنُوقّبْ أَيِي زَّايسْ! نِيغْ أَذْ د-أَسنْ إِنِّي وَارْ إِتّْوَاخثْننْ، أَذْ زَّايِي سْثهْزَانْ.“ \add مَاشَا\add* أَحمَّاڒْ نّسْ ن ڒسْنَاحْ وَارْ إِخْسْ \add أَذْ ت إِڭّْ\add*، مَاغَارْ ثُوغَا إِڭّْوذْ أَطَّاسْ. \add خنِّي\add* إِكْسِي شَاوُولْ سِّيفْ ؤُشَا إِسّغْضڒْ إِخفْ نّسْ خَاسْ.
\v 5 \add ؤُمِي\add* إِژْرَا ؤُحمَّاڒْ ن ڒسْنَاحْ، أَقَا شَاوُولْ إِمُّوثْ، إِوْضَا ڒَا ذ نتَّا خْ سِّيفْ نّسْ ؤُشَا إِمُّوثْ.
\v 6 إِمُّوثْ شَاوُولْ أَكْ-ذ ثْڒَاثَا ن وَارَّاونْ نّسْ ؤُشَا \add أَمُّو\add* ثمُّوثْ قَاعْ ثَادَّارْثْ نّسْ.
\v 7 \add ؤُمِي\add* ژْرِينْ مَارَّا يرْيَازنْ ن إِسْرَائِيل، إِنِّي ثُوغَا ذِي ڒوْضَا ن ثغْزُورْثْ، بلِّي إِرْيَازنْ ن إِسْرَائِيل أَروْڒنْ ؤُ شَاوُولْ ذ وَارَّاونْ نّسْ تّْوَانْغنْ، سمْحنْ نِيثْنِي ذِي ثْندَّامْ نْسنْ ؤُشَا أَروْڒنْ. \add ڒخْذنِّي\add* ؤُسِينْ-د إِفِيلِيسْطِينِييّنْ ؤُشَا ذوْڒنْ زدّْغنْ ذِينْ.
\m 
\v 8 ثِيوشَّا نّسْ ؤُمِي د-ؤُسِينْ إِفِيلِيسْطِينِييّنْ حِيمَا أَذْ كشّْضنْ إِنِّي إِتّْوَانْغنْ، إِمْسَارْ، أَقَا ؤُفِينْ شَاوُولْ ذ وَارَّاونْ نّسْ، إِنِّي ثُوغَا إِوْضَانْ خْ وذْرَارْ ن جِيلْبُوعَا.
\v 9 نِيثْنِي كشّْضنْ ث ؤُشَا إِوْينْ أَزدْجِيفْ نّسْ ذ ڒسْنَاحْ نّسْ ؤُشَا سّكّنْ ثنْ ذِي ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ، حِيمَا أَذْ سِّيوْضنْ ڒخْبَارْ أَصبْحَانْ غَارْ ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ نْسنْ ؤُ غَارْ ڒْڭنْسْ.
\v 10 نِيثْنِي سَّارْسنْ ڒسْنَاحْ ن شَاوُولْ ذِي ثَادَّارْثْ ن أَربِّي نْسنْ ؤُ أَشقُّوفْ ن ؤُزدْجِيفْ نّسْ سمَّارنْ ث غَارْ ڒْحِيضْ ن بَايْثْ-شَانْ.
\m 
\v 11 ؤُمِي سْڒَانْ مَارَّا \add إِمزْذَاغْ ن\add* يَابِيشْ مِينْ ڭِّينْ إِفِيلِيسْطِينِييّنْ أَكْ-ذ شَاوُولْ،
\v 12 كَّارنْ مَارَّا إِرْيَازنْ إِمحْضنْ، كْسِينْ ڒْخشْبثْ ن شَاوُولْ ذ ڒْخشْبَاثْ ن وَارَّاونْ نّسْ ؤُشَا إِوْينْ ثنْثْ غَارْ يَابِيشْ. نِيثْنِي نضْڒنْ إِغْسَانْ نْسنْ سَاذُو إِ ثْشجَّارْثْ ن يِيڭّْ ذِي يَابِيشْ ؤُشَا ژُومّنْ سبْعَا ن وُوسَّانْ.
\m 
\v 13 شَاوُولْ إِمُّوثْ ذِي سِّيبّثْ ن ڒغْذَارْ نّسْ إِ زِي ثُوغَا إِغدَّارْ سِيذِي، ذِي سِّيبّثْ ن وَاوَاڒْ ن سِيذِي إِ وَارْ ذَايسْ إِطِّيفْ نتَّا، ؤُ ؤُمِي يَارْزُو شّْوَارْ غَارْ ونِّي إِسَّاوَاڒنْ أَكْ-ذ إِمتَّانْ،
\v 14 وَارْ إِسّقْسِي سِيذِي. س ؤُينِّي إِنْغَا إِ-ث \add سِيذِي\add* ؤُشَا إِسّْمُوطِّييْ ثَاڭلْذَا إِ ذَاوُوذْ، مِّيسْ ن يَاسَّا.
\b
\b
\c 11
\s1 ذَاوُوذْ إِذْوڒْ ذ أَجدْجِيذْ ؤُشَا إِطّفْ ؤُرْشَالِيمْ
\m 
\v 1 مَارَّا إِسْرَائِيل يُوسَا-د غَارْ ذَاوُوذْ غَارْ حَابْرُونْ، نَّانْ: ”خْزَارْ، نشِّينْ ذ إِغْسَانْ ذ ويْسُومْ نّشْ. \x ◘ \xo 11:‏1 \xt [2 صم. 5‏:‏1‏-‏10]\x*
\v 2 عَاذْ ؤُمِي ثُوغَا شَاوُولْ ذ أَجدْجِيذْ خَانغْ، أَقَا ذ شكْ إِ د-إِسُّوفّْغنْ إِسْرَائِيل \add غَارْ ؤُمنْغِي\add* ؤُشَا ثْجبْذذْ ث-إِ-د أَذْ د-إِذْوڒْ. عَاوذْ إِنَّا أَشْ سِيذِي، أَربِّي نّشْ: ’شكْ أَذْ ثَاروْسذْ ڒْڭنْسْ إِنُو إِسْرَائِيل ؤُ شكْ أَذْ ثِيڒِيذْ ذ ڒْحَاكمْ خْ إِسْرَائِيل.‘ “
\v 3 \add خنِّي\add* ؤُسِينْ-د مَارَّا إِمْغَارنْ ن إِسْرَائِيل غَارْ ؤُجدْجِيذْ ذِي حَابْرُونْ ؤُشَا إِڭَّا ؤُجدْجِيذْ ذَاوُوذْ إِجّْ ن ڒْعَاهْذْ أَكِيذْسنْ ذِي حَابْرُونْ زَّاثْ إِ وُوذمْ ن سِيذِي. نِيثْنِي ذهْننْ ذَاوُوذْ ذ أَجدْجِيذْ خْ إِسْرَائِيل عْلَاحْسَابْ أَوَاڒْ ن سِيذِي س ؤُقمُّومْ ن شَامْوِيلْ. \f ◼ \fr 11:‏3 \ft \bd ’س ؤُقمُّومْ‘\bd* - س ثْعِيبْرَانِيثْ ’س ؤُفُوسْ‘.\f*  \x ◘ \xo 11:‏3 \xt 1 صم. 16\x*
\m 
\v 4 ذَاوُوذْ إِفّغْ أَكْ-ذ مَارَّا إِسْرَائِيل غَارْ ؤُرْشَالِيمْ، أَقَا-ث ذ يابُوسْ. ذِينِّي \add ثُوغَا زدّْغنْ\add* أَيْثْ ن يابُوسْ، إِمزْذَاغْ ن ثمُّورْثْ.
\v 5 إِمزْذَاغْ ن يابُوسْ نَّانْ إِ ذَاوُوذْ: ”شكْ وَارْ ذَا ثتِّيذْفذْ شَا.“ \add مَاشَا\add* ذَاوُوذْ إِطّفْ لْبُورْجْ ن صِيهْيُونْ، أَقَا-ث ذ ثَانْذِينْثْ ن ذَاوُوذْ.
\v 6 \add مَاغَارْ\add* ذَاوُوذْ إِنَّا: ”كُوڒْ إِجّْ ونِّي إِ غَا إِوْثنْ أَيْثْ ن يابُوسْ ذ أَمزْوَارُو، أَذْ إِذْوڒْ ذ أَزدْجِيفْ ن إِكُومَانْذَارنْ. ؤُشَا يُووَابْ، مِّيسْ ن سَارَايَا، إِڭعّذْ ذ أَمزْوَارُو، \add س ؤُينِّي\add* إِذْوڒْ نتَّا ذ أَزدْجِيفْ.
\v 7 ثُوغَا ذَاوُوذْ إِزدّغْ ذِي لْقلْعَا. خْ ؤُيَا قَّارنْ أَسْ \add إِ لْقلْعَا\add* ثَانْذِينْثْ ن ذَاوُوذْ.
\v 8 نتَّا إِبْنَا ثَانْذِينْثْ إِ ذ أَسْ د-إِنّْضنْ، زِي لْقلْعَا ؤُ سّنِّي إِقُووَّارْ أَسْ-د. إِعْذڒْ يُوعَابْ مِينْ إِقِّيمنْ ن ثنْذِينْثْ.
\v 9 إِذْوڒْ ذَاوُوذْ يَارنِّي ذِي ڒمْغَارثْ، مَاغَارْ سِيذِي ن ڒْعسْكَارَاثْ ثُوغَا-ث أَكِيذسْ.
\b
\s1 أَيْثْ ن بُو-ثغْرُوضْثْ ن ذَاوُوذْ
\m 
\v 10 \bd إِنَا ذ إِزدْجِيفنْ ن أَيْثْ ن بُو-ثغْرُوضْثْ ن ذَاوُوذْ\bd* إِنِّي إِسّْجّهْذنْ أَكِيذسْ ثَاڭلْذَا نّسْ ذِي مَارَّا إِسْرَائِيل، حِيمَا أَذْ ث ڭّنْ ذ أَجدْجِيذْ خْ إِسْرَائِيل عْلَاحْسَابْ أَوَاڒْ ن سِيذِي. \x ◘ \xo 11:‏10 \xt [2 صم. 23‏:‏8‏-‏39]\x*
\v 11 ثَا ذ لِيسْثَا ن لْعَاذَاذْ ن أَيْثْ ن بُو-ثغْرُوضْثْ ن ذَاوُوذْ: \bd يَاشُوبْعَامْ، مِّيسْ ن هَاكْمُونِي، أَزدْجِيفْ ن ثْڒَاثِينْ\bd*. نتَّا إِحنّضْ س لَانْسَا نّسْ خْ ثڒْثْ-مْيَا \add ن يرْيَازنْ\add* نِّي إِسّْنُوقّبْ ذڭْ إِجّْ ن ؤُمُورْ.
\v 12 أَوَارْنِي أَسْ \add يُوسَا-د\add* \bd أَلِيعَازَارْ، مِّيسْ ن ذُوذُو، أَخُوخِي. نتَّا ثُوغَا ذ إِجّْ زِي ثْڒَاثَا ن أَيْثْ ن بُو-ثغْرُوضْثْ\bd*.
\v 13 نتَّا ثُوغَا-ث أَكْ-ذ ذَاوُوذْ ذِي فَاسْ-ذَامِّيمْ. إِفِيلِيسْطِينِييّنْ نّْيَارْونْ ذِينْ إِ ؤُمنْغِي. إِجّْ ن وزْينْ ن ييَّارْ ثُوغَا إِشُّورْ س إِمنْذِي ؤُمِي يَارْوڒْ ڒْڭنْسْ زڭْ إِفِيلِيسْطِينِييّنْ.
\v 14 نِيثْنِي بدّنْ ذِي ڒْوسْثْ ن وزْينْ ن ييَّارْ نِّي، فكّنْ ث، ؤُشَاغڒْبنْ خْ إِفِيلِيسْطِينِييّنْ. \add أَمُّو\add* إِ يَارَّا سِيذِي ذ أَسنْجمْ ذ أَمقّْرَانْ.
\m 
\v 15 ثْڒَاثَا زِي ثْڒَاثِينْ ن إِزدْجِيفنْ هْوَانْ أَڒْ ثَاصْضَارْثْ، \add ؤُسِينْ-د\add* غَارْ ذَاوُوذْ ذڭْ إِفْرِي ن أَبْذُولَّامْ. ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ ثُوغَا إِوْثَا إِقِيضَانْ نّسْ ذِي ثغْزُورْثْ ن إِرَافَاوِييّنْ.
\v 16 ذَاوُوذْ \add ثُوغَا-ث\add* ذِي لْقلْعَا ؤُ \add ثُوغَا\add* ذِينْ إِجّْ ن ڒْعسْكَارْ ن ؤُحوّسْ ن إِفِيلِيسْطِينِييّنْ ذِي بَايْثْ-لَاحْمْ.
\v 17 ذَاوُوذْ إِڒْقفْ إِ-ث ؤُفَاذِي، إِنَّا: ”وِي إِ ذ أَيِي د غَا يَاوْينْ أَمَانْ زِي ثَاڒَا ن بَايْثْ-لَاحْمْ نِّي \add إِدْجَانْ\add* غَارْ ثوَّارْثْ \add ن ثنْذِينْثْ\add*؟“
\v 18 \add خنِّي\add* شُوقنْ ثْڒَاثَا نِّي ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ، ؤُيْمنْ-د أَمَانْ زِي ثَاڒَا ن بَايْثْ-لَاحْمْ، ثنِّي \add إِدْجَانْ\add* غَارْ ثوَّارْثْ \add ن ثنْذِينْثْ\add*. كْسِينْ ثنْ أَكِيذْسنْ ؤُشَا إِوْضنْ غَارْ ذَاوُوذْ. نتَّا يُوڭِي أَذْ ثنْ إِسُو، مَاشَا إِزدْجعْ إِ-ثنْ زَّاثْ إِ سِيذِي.
\v 19 نتَّا إِنَّا: ”أَيَا إِڭّْوجْ خَافِي، \add أَ\add* أَربِّي إِنُو، أَقَا نشّْ أَذْ ڭّغْ مَانْ أَيَا. مَا أَذْ سْوغْ إِذَامّنْ ن يرْيَازنْ س ڒعْمَارْ نْسنْ \add ذَايْسنْ\add*، مَاغَارْ نِيثْنِي سبّْڒنْ ثُوذَارْثْ نْسنْ سِيمَانْثْ نْسنْ؟“ ؤُ نتَّا وَارْ إِخْسْ أَذْ ثنْ إِسُو. ذ مَانْ أَيَا إِ ڭِّينْ ثْڒَاثَا ن أَيْثْ ن بُو-ثغْرُوضْثْ \add نِّي\add*.
\v 20 \bd أَبِيشَايْ، مِّيسْ ن يُووَابْ\bd*، ثُوغَا ذ أَزدْجِيفْ ن ثْڒَاثَا \add نِّي\add*. نتَّا إِحنّضْ لَانْسَا نّسْ خْ ثڒْثْ-مْيَا \add ن يرْيَازنْ\add*، إِسّْنُوقّبْ \add إِ-ثنْ\add*. نتَّا غَارسْ إِجّْ ن يِيسمْ \add إِتّْوَاشنّْعنْ\add* جَارْ ثْڒَاثَا \add نِّي\add*.
\v 21 جَارْ ثْڒَاثَا\add -يَا\add* ثُوغَا \add أَبِيشَايْ\add* ذ ونِّي إِتّْوَاشنّْعنْ ثْنَاينْ ن إِمُورنْ، ؤُ نتَّا ثُوغَا ذ ڒْقبْطَانْ إِ نِيثْنِي. \add مَاشَا\add* نتَّا وَارْ يِيوِيضْ ؤُڒَا أَمْ ثْڒَاثَا إِمزْوُورَا.
\m 
\v 22 \add خنِّي\add* \bd بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ\bd*، مِّيسْ ن إِجّْ ن ورْيَازْ إِمحْضنْ، ثِيمڭَّا نّسْ مْغَارنْثْ. نتَّا زِي قَابْضِييِيلْ. إِغْڒبْ خْ ثْنَاينْ ن إِيْرَاذنْ جهْذنْ زِي مُوآبَ. عَاوذْ ثُوغَا إِهْوَا \add إِشْثْ ن ثْوَاڒَا\add*، إِغْڒبْ خْ إِجّْ ن ويْرَاذْ ذِي ڒْوسْطْ ن إِجّْ ن وَانُو ذڭْ إِجّْ ن وَاسّْ ؤُمِي إِوْثَا وذْفڒْ.
\v 23 \bd نتَّا\bd* إِغْڒبْ ؤُڒَا خْ يِيجّْ ن ورْيَازْ ذ أَمِيصْرِي، س يِيجّْ ثِيذِّي ن خمْسَا ن إِغَادْجنْ. أَمِيصْرِي ثُوغَا غَارسْ لَانْسَا ذڭْ ؤُفُوسْ \add نّسْ\add* \add ثڭَّا\add* أَمْ يِيجّْ ن وعْمُوذْ ن ؤُكشُّوضْ ن ؤُخيّضْ. إِهْوَا غَارسْ س وعْمُوذْ، إِكّسْ أَسْ لَانْسَا زڭْ ؤُفُوسْ ن ؤُمِيصْرِي ؤُشَا إِنْغَا إِ-ث س لَانْسَا نّسْ.
\v 24 ذ مَانْ أَيَا إِ إِڭَّا بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ. س ؤُيَا غَارسْ إِدْجَا إِسمْ \add إِشْنعْ\add* جَارْ ثْڒَاثَا ن أَيْثْ ن بُو-ثغْرُوضْثْ.
\v 25 نتَّا ثُوغَا ذ ونِّي إِتّْوَاشنّْعنْ أَطَّاسْ زِي ثْڒَاثِينْ، مَاشَا وَارْ يِيوضْ أَڒْ ثْڒَاثَا \add إِمزْوُورَا\add*. ذَاوُوذْ إِڭَّا إِ-ث جَارْ إِمْثِيقَّانْ نّسْ.
\b
\m 
\v 26 أَيْثْ بُو-ثغْرُوضْثْ إِمحْضنْ \add إِ إِقِّيمنْ\add* \add ثُوغَا أَثنْ\add*:
\m عَسَائِيلْ، ؤُمَاسْ ن يُووَابْ،
\m إِلْحَانَانْ، مِّيسْ ن ذُوذُو، زِي بَايْثْ-لَاحْمْ،
\m 
\v 27 شَامُّوثْ، أَهَارُوذِي،
\m حَالِيصْ، أَلْفَالُونِي،
\m 
\v 28 عِيرَا، مِّيسْ ن عِيقِّيشْ، أَثِيقُّوعِي،
\m أَبِيعَازَارْ، أَعَانَاثُوثِي،
\m 
\v 29 سِيبِّيكَايْ، أَحُوشَاثِي،
\m عِيلَايْ، أَخُوخِي،
\m 
\v 30 مَاهَارَايْ، أَنَاطُوفَاثِي،
\m خَالِيذْ، مِّيسْ ن بَاعْنَا، أَنَاطُوفَاثِي،
\m 
\v 31 إِتَّايْ، مِّيسْ ن رِيبَايْ، زِي جِيبْعَا زڭْ وَارَّاونْ ن بِينْيَامِينْ،
\m بَانَايَا، زِي فِيرْعَاثُونْ،
\m 
\v 32 هُورَايْ زِي ثغْزَارِينْ ن جَاعَاشْ،
\m أَبِييِيلْ، أَعَارَابَاثِي،
\m 
\v 33 عَازْمَاوثْ، أَبَاحْرُومِي،
\m إِلْيَاحْبَا، أَشَاعَالْبُونِي،
\m 
\v 34 أَرَّاونْ ن هَاشِيمْ، أَجَازُونِي،
\m يُونَاثَانْ، مِّيسْ ن شَاجَايْ، أَهَارَارِي،
\m 
\v 35 أَخِييَامْ، مِّيسْ ن سَاكَارْ، أَهَارَارِي،
\m إِلِيفَالْ، مِّيسْ ن ؤُرْ،
\m 
\v 36 حَافِيرْ، أَمَاكِيرَاثِي،
\m أَخِييَا، أَفَالُونِي،
\m 
\v 37 حَاصْرُو، أَكَارْمَالِي،
\m نَاعْرَايْ، مِّيسْ ن إِزْبَايْ،
\m 
\v 38 يُووِيلْ، ؤُمَاسْ ن نَاثَانْ،
\m مِيبْحَارْ، مِّيسْ ن هَاجْرِي،
\m 
\v 39 صَالِيقْ، أَعَامُّونِي،
\m نَاحْرَايْ، أَبَائِيرُوثِي، أَحمَّاڒْ ن ڒسْنَاحْ ن يُووَابْ، مِّيسْ ن صَارُويَا،
\m 
\v 40 عِيرَا، أَيِيثْرِي،
\m جَارِيبْ، أَيِيثْرِي،
\m 
\v 41 ؤُرِييَا، أَحِيتِّي،
\m زَابَاذْ، مِّيسْ ن أَحْلَايْ،
\m 
\v 42 أَذِينَا، مِّيسْ ن شِيزَا، زِي ثقْبِيتْشْ ن رُوبِينْ، \add ونِّي\add* ذ أَزدْجِيفْ ن أَيْثْ ن رُوبِينْ، ؤُ سنّجْ نّسْ \add عَاذْ\add* ثْڒَاثِينْ \add ن يرْيَازنْ\add*،
\m 
\v 43 حَانَانْ، مِّيسْ ن مَاعْكَا،
\m ذ يُوشَافَاطْ، أَمَاثْنِي،
\m 
\v 44 عُوزِّييَا أَعَاشْثَارُوثِي،
\m شَامَاعْ ذ يَاعِييِيلْ، أَرَّاونْ ن حُوثَامْ، أَعَارُوعِيرِي،
\m 
\v 45 يَاذِيعِيلْ، مِّيسْ ن شِيمْرِي،
\m يُوحَا، ؤُمَاسْ، أَثِيصِي،
\m 
\v 46 إِلِييِيلْ أَمَاحْوِيمْ،
\m يَارِيبَايْ ذ يُوشُووْيَا، أَرَّاونْ ن إِلْنَاعَامْ،
\m ذ يِيثْمَا أَمُو‘أَبِي،
\m 
\v 47 إِلِييِيلْ، عُوبِيذْ ذ يَاعْسِييِيلْ زِي مَاصُوبَايَا.
\b
\b
\c 12
\s1 إِمضْفَارنْ ن ذَاوُوذْ ذِي صِيقْلَاغْ
\m 
\v 1 إِنَا إِ د-يُوسِينْ غَارْ ذَاوُوذْ غَارْ صِيقْلَاغْ، ؤُمِي ثُوغَا إِتّْخصَّا عَاذْ أَذْ إِقِّيمْ \add ذَاوُوذْ\add* إِتّڭّْوجْ خْ وُوذمْ ن شَاوُولْ، مِّيسْ ن قِيشْ. نِيثْنِي \add ثُوغَا تّقّنْ إِ\add* أَيْثْ ن بُو-ثغْرُوضْثْ إِنِّي إِوْشِينْ أَفُوسْ \add إِ ذَاوُوذْ\add* ذڭْ ؤُمنْغِي.
\v 2 نِيثْنِي ثُوغَا حزْمنْ س ڒقْوَاسْ ؤُ زمَّارنْ \add أَذْ حجَّارنْ\add* س يژْرَا ؤُ أَذْ وْثنْ فْڒِيثْشَاثْ س ڒْقوْسْ س ؤُفُوسْ أَفُوسِي ؤُ س ؤُفُوسْ أَزڒْمَاضْ. نِيثْنِي ثُوغَا أَثنْ \bd زڭْ أَيْثْمَاسْ ن شَاوُولْ، زِي بِينْيَامِينْ\bd*.
\m 
\v 3 أَخِيعَازَارْ \add ثُوغَا\add* ذ أَزدْجِيفْ نْسنْ، \add خنِّي\add* يُووَاشْ، \add نِيثْنِي س ثْنَاينْ إِذْسنْ\add* ذ أَرَّاونْ ن شَامَاعَا، زِي جِيبْعَا،
\m \add خنِّي\add* يَازُو‘إِلْ ذ فَالَاطْ، \add نِيثْنِي س ثْنَاينْ إِذْسنْ ذ\add* أَرَّاونْ ن عَازْمَاوثْ،
\m ؤُ بَارَاخْيَا ذ يَاهُو، زِي عَانَاثُوثْ،
\m 
\v 4 ؤُ يَاشْمَاعْيَا، زِي جِيبْعُونْ، \add ونِّي ثُوغَا\add* ذ إِجّْ ن بُو-ثغْرُوضْثْ جَارْ ثْڒَاثِينْ ؤُ \add ثُوغَا\add* خْ ثْڒَاثِينْ،
\m 
\v 5 ؤُڒَا ذ إِرْمِييَا، يَاحْزِييِيلْ، يُوحَانَانْ ذ يُوزَابَاذْ، أَجَاذِيرِي،
\m 
\v 6 إِلْعُوزَايْ، يَارِيمُوثْ، بَاعْلِييَا، شَامَارْيَا، شَافَاطْيَا، أَحَارُوفِي،
\m 
\v 7 إِلْقَانَا، يَاشِّي-يَاهْ، عَازْرِييِيلْ، يُوعَازَارْ ذ يَاشُوبْعَامْ، \add نِيثْنِي ذ\add* إِقُورَاحِييّنْ،
\m 
\v 8 ؤُ \add غَارْ ؤُنڭَّارْ\add* يُوعِيلَا ذ زَابَاذْيَا، \add نِيثْنِي س ثْنَاينْ إِذْسنْ ذ\add* أَرَّاونْ ن يَارُوحَامْ زِي جَاذُورْ.
\b
\m 
\v 9 \bd زڭْ \bdit أَيْثْ\bdit* ن جَاذْ\bd* أَقَا ذِينْ إِنِّي إِمّْسبْضَانْ إِخفْ نْسنْ \add حِيمَا أَذْ ژْوَانْ\add* غَارْ ذَاوُوذْ، ذِي لْقلْعَا ذِي ڒخْڒَا. أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، إِعسْكَارِييّنْ \add وجْذنْ\add* إِ ؤُمنْغِي، تّْوَاحزْمنْ س ثْسدَّارِييِينْ \add ن ؤُعسْكَارِي\add* ثِيمقّْرَانِينْ ؤُ س إِحْرِيشنْ. ؤُذْمَاونْ نْسنْ أَمْ وُوذْمَاونْ ن ويْرَاذنْ ؤُ نِيثْنِي ؤُيُورنْ س ثَازْڒَا أَمشْنَاوْ إِغَايْضنْ ن وزْغَارْ خْ إِذُورَارْ.
\m 
\v 10 عَازَارْ ثُوغَا-ث ذ أَزدْجِيفْ،
\m عُوبَاذْيَا ذ وِيسّْ ثْنَاينْ، إِلِييَابْ ذ وِيسّْ ثْڒَاثَا،
\m 
\v 11 مِيشْمَانَّا ذ وِيسّْ أَربْعَا، إِرْمِييَا ذ وِيسّْ خمْسَا،
\m 
\v 12 عَاتَّايْ ذ وِيسّْ ستَّا، إِلِييِيلْ ذ وِيسّْ سبْعَا،
\m 
\v 13 يُوحَانَانْ ذ وِيسّْ ثْمنْيَا، إِلْزَابَاذْ ذ وِيسّْ ثسْعَا،
\m 
\v 14 إِرْمِييَا ذ وِيسّْعشْرَا، مَاخْبَانَايْ ذ وِيسّْ حِيطَاشْ.
\m 
\v 15 إِنَا ثُوغَا أَثنْ زڭْ وَارَّاونْ ن جَاذْ، إِمقّْرَاننْ ن ڒْعسْكَارْ. أَمژْيَانْ حسْبنْ ث أَمْ مْيَا \add ن يرْيَازنْ\add* ؤُ أَمقّْرَانْ أَمْ أَڒفْ.
\v 16 إِنَا ذ إِنِّي إِژْوَانْ لْ-ؤُرْذُونْ ذڭْ ؤُيُورْ أَمزْوَارُو، ؤُمِي إِسْفِي \add لْ-ؤُرْذُونْ\add* بَارَّا مَارَّا ثِيمُووَّا نّسْ ؤُ نِيثْنِي ؤُژّْڒنْ خْ مَارَّا إِمزْذَاغْ ن ڒوْضَاثْ ن ثغْزُورْثْ \add إِ إِدْجَانْ\add* غَارْ شَّارْقْ ذ ڒْغَارْبْ.
\b
\m 
\v 17 ؤُڒَا \bd زڭْ وَارَّاونْ ن بِينْيَامِينْ ؤُ زڭْ وَارَّاونْ ن يَاهُوذَا\bd* ؤُسِينْ-د \add يرْيَازنْ\add* غَارْ ذَاوُوذْ غَارْ لْقلْعَا ن وذْرَارْ.
\v 18 ذَاوُوذْ إِفّغْ-د غَارْسنْ حِيمَا أَذْ ثنْ إِڒْقَا، ؤُشَا إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا أَسنْ: ”مَاڒَا كنِّيوْ ثُوسِيمْ-د غَارِي حِيمَا أَذْ أَيِي ثوْشمْ أَفُوسْ، خنِّي نشّْ أَذْ إِڒِيغْ س وُوڒْ ذ إِجّْ أَكِيذْومْ، \add مَاشَا\add* مَاڒَا \add كنِّيوْ ثُوسِيمْ-د\add* حِيمَا أَذْ أَيِي ثْسلّْممْ إِ إِغْرِيمنْ إِنُو، وَاخَّا وَارْ \add ذِينْ ثدْجِي\add* ڒخْشُونثْ غَارْ إِفَاسّنْ إِنُو، \add خنِّي\add* إِڒِي أَذْ ث إِژَارْ أَربِّي ن ڒجْذُوذْ نّغْ ؤُ أَذْ كنِّيوْ إِخدْجسْ!“
\v 19 إِوْضَا-د أَرُّوحْ أَمْ وَارُّوضْ خْ عَامَاسَايْ، أَزدْجِيفْ ن ثْڒَاثِينْ، نتَّا إِنَّا: ”نشِّينْ أَكِيذكْ، ذَاوُوذْ، ؤُ نشِّينْ أَكِيذكْ، مِّيسْ ن يَاسَّا. ڒهْنَا، ڒهْنَا \add أَذْ\add* كِيذكْ \add يِيڒِي\add* ؤُ ڒهْنَا \add أَذْ يِيڒِي\add* أَكْ-ذ يِينِّي ذ أَشْ إِوْشِينْ أَفُوسْ، مَاغَارْ أَربِّي نّشْ إِوْشَا أَشْ أَفُوسْ.“ \add خنِّي\add* إِسِّيذفْ إِ-ثنْ ذَاوُوذْ ؤُ إِڭَّا إِ-ثنْ ذ إِزدْجِيفنْ خْ ثرْبِيعْثْ ن ڒْعسْكَارْ.
\b
\m 
\v 20 ؤُڒَا \bd زِي مَانَاسَّا\bd* \add ثُوغَا ذِينْ\add* إِنِّي إِعْذُونْ غَارْ ذَاوُوذْ، ؤُمِي د-إِفّغْ أَكْ-ذ إِفِيلِيسْطِينِييّنْ غَارْ ؤُمنْغِي أَكْ-ذ شَاوُولْ. \add إِفِيلِيسْطِينِييّنْ مَاشَا\add* وَارْ ذ أَسنْ جِّينْ أَذْ وْشنْ أَفُوسْ، مِينْزِي ڒْبَاشَاثْ \add ن ثْندَّامْ\add* ن إِفِيلِيسْطِينِييّنْ سّكّنْ ث، نَّانْ: ”\add زعْمَا\add* نتَّا إِزمَّارْ أَذْ إِعْذُو س إِزدْجِيفنْ نّغْ \add ذڭْ ؤُفُوسْ نّسْ\add* غَارْ شَاوُولْ، سِيذسْ.“
\v 21 ؤُمِي د-إِعْقبْ غَارْ صِيقْلَاغْ، عْذُونْ \add إِنَا\add* غَارسْ زڭْ \add أَيْثْ ن\add* مَانَاسَّا: عَاذْنَاحْ، يُوزَابَاذْ، يَاذِيعِيلْ، مِيخَايِيلْ، يُوزَابَاذْ، إِلِيهُو ذ صِيلّْثَايْ، ڒْقبْطَانَاثْ خْ ڒُورُوفْ ن مَانَاسَّا.
\v 22 نِيثْنِي وْشِينْ أَفُوسْ إِ ذَاوُوذْ حِيمَا أَذْ إِڭوّذْ ثِيرْبِيعِينْ \add ن ڒْعسْكَارْ\add*، مَاغَارْ نِيثْنِي مَارَّا ثُوغَا أَثنْ ذ أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ ؤُ نِيثْنِي ثُوغَا أَثنْ ذ إِكُومَانْذَارنْ ن ڒْعسْكَارْ.
\v 23 مَاغَارْ ذِي ڒْوقْثْ نِّي ؤُسِينْ-د \add يرْيَازنْ\add* غَارْ ذَاوُوذْ زڭْ وَاسّْ أَڒْ أَسّْ حِيمَا أَذْ أَسْ وْشنْ أَفُوسْ، أَڒَامِي \add ذوْڒنْ\add* ذ ڒْعسْكَارْ ذ أَمقّْرَانْ، أَمْ ڒْعسْكَارْ ن أَربِّي.
\b
\s1 خْ ڒْعسْكَارْ ن ذَاوُوذْ ذِي حَابْرُونْ
\m 
\v 24 وَا ذ ڒْقدّْ ن إِزدْجِيفنْ نِّي إِتّْوَاحسْبنْ ن يِينِّي إِ ثُوغَا إِسّْوجْذنْ إِ ؤُمنْغِي، إِنِّي د-يُوسِينْ غَارْ ذَاوُوذْ ذِي حَابْرُونْ مَاحنْذْ أَذْ غَارسْ سّعْذُونْ ثَاڭلْذَا ن شَاوُولْ، أَمْ مَامّشْ ث يُومُورْ سِيذِي:
\m 
\v 25 \bd زڭْ وَارَّاونْ ن يَاهُوذَا\bd* \add ثُوغَا ڒْقدّْ\add* ن يِينِّي يَارْبُونْ ثِيسدَّارِييِينْ \add ن ؤُعسْكَارِي\add* ثِيمقّْرَانِينْ ذ إِحْرِيشنْ ستَّا-أَڒَافْ ؤُ-ثمْنْ-مْيَا \add ن يرْيَازنْ\add*. نِيثْنِي ثُوغَا وجْذنْ إِ ؤُمنْغِي.
\m 
\v 26 \bd زڭْ وَارَّاونْ ن شِيمْعُونْ\bd* \add ثُوغَا ڒْقدّْ\add* ن أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ إِ ڒْعسْكَارْ سبْعَا-أَڒَافْ ؤُ-مْيَا \add ن يرْيَازنْ\add*.
\m 
\v 27 \bd زڭْ وَارَّاونْ ن لَاوِي\bd* أَربْعَا-أَڒَافْ ؤُ-ستَّا-مْيَا \add ن يرْيَازنْ\add*.
\m 
\v 28 يَاهُويَاذَاعْ ثُوغَا ذ ڒْحَاكمْ إِ \add وَارَّاونْ ن\add* هَارُونْ. نتَّا يِيوِي أَكِيذسْ ثڒْثْ-أَڒَافْ ؤُ-سبْعَا-مْيَا \add ن يرْيَازنْ\add*.
\m 
\v 29 صَاذُوقْ \add ثُوغَا\add* ذ أَحُوذْرِي، بُو-ثغْرُوضْثْ إِمحْضنْ. \add زِي\add* ثَادَّارْثْ ن بَابَاسْ \add ثُوغَا ذِينْ\add* ثْنَاينْ ؤُ-عِيشْرِينْ ن ڒْقبْطَانَاثْ.
\m 
\v 30 \bd زڭْ وَارَّاونْ ن بِينْيَامِينْ\bd*، أَيْثْمَاسْ ن شَاوُولْ، \add ثُوغَا ذِينْ\add* ثڒْثْ-أَڒَافْ \add ن يرْيَازنْ\add*، مِينْزِي أَزْينْ أَمقّْرَانْ زَّايْسنْ ثُوغَا حطَّانْ ثَادَّارْثْ ن شَاوُولْ.
\m 
\v 31 \bd زڭْ وَارَّاونْ ن إِفْرَايِيمْ\bd* \add ثُوغَا ذِينْ\add* عِيشْرِينْ-أَڒفْ ؤُ-ثْمنْيَا-مْيَا \add ن يرْيَازنْ\add*، أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، إِرْيَازنْ س يِيسمْ ذِي ثَادَّارْثْ ن إِبَابَاثنْ نْسنْ.
\m 
\v 32 \bd زڭْ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا\bd* \add ثُوغَا ذِينْ\add* ثْمنْطَاشْ-أَڒفْ \add ن يرْيَازنْ\add*، إِنِّي ثُوغَا تّْوَاڒَاغَانْ س يِيسْمَاونْ نْسنْ مَاحنْذْ أَذْ د-أَسنْ أَذْ ڭّنْ ذَاوُوذْ ذ أَجدْجِيذْ.
\m 
\v 33 \bd زڭْ وَارَّاونْ ن إِسَّاكَارْ\bd*، إِنِّي غَارْسنْ ڒفَاهْمثْ ن ڒْمِيجَاڒَاثْ ن ڒْوقْثْ حِيمَا أَذْ سّْننْ مِينْ ثُوغَا خْ إِسْرَائِيل أَذْ إِڭّْ، \add ثُوغَا\add* ڒْقبْطَانَاثْ نْسنْ مِيثَاينْ \add ن يرْيَازنْ\add*، ؤُ مَارَّا أَيْثْمَاثْسنْ \add ثُوغَا أَثنْ\add* سَاذُو أَفُوسْ نْسنْ. \f ◼ \fr 12:‏33 \ft \bd ’سَاذُو أَفُوسْ نْسنْ‘\bd* - س ثْعِيبْرَانِيثْ ’سَاذُو أَقمُّومْ نْسنْ‘.\f*
\m 
\v 34 \bd زڭْ \bdit وَارَّاونْ ن\bdit* زابُولُونْ\bd*، \add زڭْ يِينِّي\add* د-إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ س مَارَّا ڒسْنَاحْ نْسنْ، \add ثُوغَا ذِينْ\add* خمْسِينْ-أَڒفْ \add ن يرْيَازنْ\add*. \add نِيثْنِي ثُوغَا سّْوجْذنْ\add* حِيمَا أَذْ ستّْفنْ إِخفْ نْسنْ ذڭْ ؤُسذِّي س وُوڒْ إِمُونْ نِيشَانْ.
\m 
\v 35 \bd زڭْ \bdit وَارَّاونْ ن\bdit* نَافْثَالِي\bd* \add ثُوغَا ذِينْ\add* أَڒفْ ن ڒْقبْطَانَاثْ. ثُوغَا-ثنْ ذِي سبْعَا ؤُ-ثْڒَاثِينْ-أَڒفْ \add ن يرْيَازنْ\add* إِنِّي يَارْبُونْ ثَاسدَّارْثْ \add ن ؤُعسْكَارِي\add* ثَامقّْرَانْثْ ذ لَانْسَا،
\m 
\v 36 \bd زڭْ \bdit وَارَّاونْ ن\bdit* ذَانْ\bd* \add ثُوغَا ذِينْ\add* ثْمنْيَا ؤُ-عِيشْرِينْ أَڒفْ ؤُ-ستَّا-مْيَا \add ن يرْيَازنْ\add*، وجْذنْ إِ ؤُمنْغِي.
\m 
\v 37 \bd زڭْ \bdit وَارَّاونْ ن\bdit* أَشِيرْ\bd* فّْغنْ-د أَربْعَا-أَڒَافْ \add ن يرْيَازنْ\add* أَكْ-ذ ڒْعسْكَارْ حِيمَا أَذْ سّْبدّنْ إِخفْ نْسنْ ذڭْ ؤُسذِّي.
\m 
\v 38 \bd زڭْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، زڭْ وَارَّاونْ ن رُوبِينْ ؤُ زڭْ وَارَّاونْ ن جَاذْ ؤُ زڭْ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا\bd* \add ثُوغَا ذِينْ\add* مْيَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add* أَكْ-ذ مَارَّا ڒسْنَاحْ إِ ؤُمنْغِي.
\m 
\v 39 مَارَّا إِعسْكَارِييّنْ-أَ ؤُسِينْ-د غَارْ حَابْرُونْ، تّْوَاستّْفنْ ذڭْ إِسذِّييّنْ س وُوڒْ إِمُونْ، حِيمَا أَذْ ڭّنْ ذَاوُوذْ ذ أَجدْجِيذْ خْ مَارَّا إِسْرَائِيل. ؤُڒَا ذ مِينْ إِقِّيمنْ ن \add أَيْثْ ن\add* إِسْرَائِيل ثُوغَا أَثنْ س وُوڒْ ذ إِجّْ حِيمَا أَذْ ڭّنْ ذَاوُوذْ ذ أَجدْجِيذْ.
\v 40 نِيثْنِي قِّيمنْ ثْڒَاثَا ن وُوسَّانْ ذِينِّي غَارْ ذَاوُوذْ، شِّينْ سْوِينْ، مَاغَارْ أَيْثْمَاثْسنْ ثُوغَا بدّنْ أَكِيذْسنْ.
\v 41 ؤُڒَا ذ يِينِّي يُوذْسنْ أَڒْ إِسَّاكَارْ ذ زابُولُونْ ذ نَافْثَالِي ؤُسِينْ-د، إِوْينْ-د وغْرُومْ خْ إِغْيَاڒْ، خْ إِڒغْمَانْ، خْ إِسَارْضَانْ ؤُ خْ إِفُونَاسنْ، \add س\add* ڒعْوتْشْ \add أَمْ\add* فَارِينَا ذ إِغْرُومنْ ن ثَازَارْثْ ذ إِغْرُومنْ ن زّْبِيبْ ذ بِينُو ذ زّشْثْ ذ إِفُونَاسنْ ذ وُودْجِي س ؤُفيّضْ، مَاغَارْ \add ثُوغَا ذِينْ\add* ڒفْرَاحثْ ذِي إِسْرَائِيل.
\b
\b
\c 13
\s1 أَسْمُوطِّي ن تَّاپُوثْ غَارْ ثَادَّارْثْ ن عُوبِيذْ-إِذُومْ
\m 
\v 1 ذَاوُوذْ إِمْشَاوَارْ أَكْ-ذ إِمقّْرَاننْ خْ وَاڒفْ ذ خْ مْيَا ؤُ أَكْ-ذ مْكُوڒْ ڒْحَاكمْ. \x ◘ \xo 13:‏1 \xt [2 صم. 6‏:‏1‏-‏11]\x*
\v 2 ذَاوُوذْ إِنَّا إِ مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ن إِسْرَائِيل: ”مَاڒَا يَارْضَا إِ كنِّيوْ ؤُڒَا إِ سِيذِي، أَربِّي نّغْ، أجّْ أَنغْ أَذْ نسّكّْ ذغْيَا \add إِرقَّاسنْ\add* غَارْ أَيْثْمَاثْنغْ نِّي إِقِّيمنْ ذِي مَارَّا ثِيمُّورَا ن إِسْرَائِيل ؤُ غَارْ إِكهَّاننْ ذ إِلَاوِييّنْ نِّي إِزدّْغنْ أَكِيذْسنْ ذِي ثْندَّامْ أَكْ-ذ دّْمَانِي نْسنْثْ ن ثَاروْسَا، حِيمَا نِيثْنِي أَذْ غَارْنغْ نّْيَارْونْ.
\v 3 ؤُشَا أجّْ أَنغْ أَذْ غَارْنغْ د-نَارّْ تَّابُوثْ ن أَربِّي، مَاغَارْ ذڭْ وُوسَّانْ ن شَاوُولْ وَارْ كِيذسْ نڒْهِي.
\v 4 مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* إِنَّا بلِّي أَذْ ڭّنْ أَمُّو، مَاغَارْ ذ مَانْ أَيَا ذ إِشْثْ ن ثْمسْڒَاشْثْ ذ ثَاصبْحَانْثْ ذِي ثِيطَّاوِينْ ن مَارَّا ڒْڭنْسْ.
\m 
\v 5 ذَاوُوذْ إِسّْمُونْ مَارَّا إِسْرَائِيل، زڭْ \add يغْزَارْ ن\add* شِيحُورْ غَارْ مِيصْرَا أَڒْ مَانِي غَا ثِيوْضذْ غَارْ حَامَاثْ، حِيمَا أَذْ سّْڭعّْذنْ تَّابُوثْ ن أَربِّي زِي قَارْيَاثْ-يَاعَارِيمْ.
\v 6 \add خنِّي\add* إِفّغْ ذَاوُوذْ أَكْ-ذ مَارَّا إِسْرَائِيل غَارْ بَاعْلَا، غَارْ قَارْيَاثْ-يَاعَارِيمْ ونِّي \add إِدْجَانْ\add* ذِي يَاهُوذَا حِيمَا أَذْ سّْڭعّْذنْ تَّابُوثْ ن أَربِّي سّنِّي. \add تَّابُوثْ\add* ن سِيذِي ونِّي إِتّْغِيمَانْ \add جَارْ\add* إِكِيرُوبنْ مَانِي إِتّْوَاڒَاغَا خْ يِيسمْ \add نّسْ\add*. \f ◼ \fr 13:‏6 \ft \bd ’إِكِيرُوبنْ‘\bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*
\v 7 نِيثْنِي إِوْينْ-د تَّابُوثْ ن أَربِّي خْ إِجّْ ن ؤُكَارُّو ن جْذِيذْ زِي ثَادَّارْثْ ن أَبِينَاذَابْ. عُوزَّا ذ أَخِييُو نذْهنْ أَكَارُّو.
\v 8 ذَاوُوذْ ذ مَارَّا إِسْرَائِيل تِّيرَارنْ لْمُوسِيقَا س مَارَّا جّهْذْ نْسنْ زَّاثْ إِ وُوذمْ ن أَربِّي س يزْڒَانْ ذ ڒْڭَامْبْرِييَاثْ ذ لهَارْپَاثْ ذ إِبنْذِيرنْ ذ ثدْجُونِينْ ن وُوزَّاڒْ ذ ڒبْوَاقْ.
\m 
\v 9 \add ؤُمِي\add* د-إِوْضنْ نِيثْنِي غَارْ ؤُنذْرَارْ ن كِيذُونْ، إِسّْوِيژّضْ عُوزَّا أَفُوسْ نّسْ، حِيمَا أَذْ إِطّفْ تَّابُوثْ مِينْزِي نْذرْفنْ إِفُونَاسنْ.
\v 10 \add خَاسْ ؤُشَا\add* يَارْغَا وغْضَابْ ن سِيذِي خْ عُوزَّا ؤُشَا إِوْثَا إِ-ث مَاغَارْ وَانِيثَا إِسّْوِيژّضْ أَفُوسْ نّسْ غَارْ تَّابُوثْ ؤُشَا إِمُّوثْ ذِينْ زَّاثْ إِ وُوذمْ ن أَربِّي.
\m 
\v 11 يِيوضْ سّمْ غَارْ وُوڒْ ن ذَاوُوذْ، أَقَا سِيذِي إِسْعَارْ أَمُّو خْ عُوزَّا ؤُ إِڭَّا أَسْ إِ ومْشَانْ نِّي فَارِيصْ-عُوزَّا أَڒْ أَسّْ-أَ.
\v 12 ذڭْ وَاسّْ نِّي ثڒْقفْ ذَاوُوذْ ثِيڭّْوُوذِي زِي أَربِّي، إِنَّا: ”مَامّشْ إِ غَا ڭّغْ أَذْ غَارِي د-أَوْيغْ تَّابُوثْ ن أَربِّي؟“
\v 13 \add خْ ؤُيَا\add* ذَاوُوذْ وَارْ إِجِّي أَذْ غَارسْ د-أَوْينْ تَّابُوثْ ذِي ثنْذِينْثْ ن ذَاوُوذْ، \add مَاشَا\add* إِجَّا إِ-ت أَذْ ثَاڭّْوجْ غَارْ ثَادَّارْثْ ن عُوبِيذْ-إِذُومْ، أَجِيتِّي.
\v 14 ثكَّا تَّابُوثْ ن أَربِّي ثْڒَاثَا ن إِيُورنْ ذِي ثَادَّارْثْ نّسْ غَارْ \add أَيْثْبَابْ ن\add* ثَادَّارْثْ ن عُوبِيذْ-إِذُومْ، ؤُ إِبَاركْ سِيذِي ثَادَّارْثْ ن عُوبِيذْ-إِذُومْ ذ مَارَّا مِينْ غَارسْ إِدْجَانْ.
\b
\b
\c 14
\s1 شَّانْ ن ذَاوُوذْ
\m 
\v 1 حِيرَامْ، أَجدْجِيذْ ن صُورْ، إِسّكّْ إِرقَّاسنْ غَارْ ذَاوُوذْ \add أَكْ-ذ\add* ثْشجُّورَا ن ثنْڭلْثْ، ذ إِنقَّاشنْ ن وژْرُو ن ڒْحِيضْ ذ إِنقَّاشنْ ن ؤُكشُّوضْ. نِيثْنِي سّْبدّنْ أَسْ إِشْثْ ن ثَادَّارْثْ. \x ◘ \xo 14:‏1 \xt [1 صم. 5‏:‏11‏-‏25]\x*
\v 2 ذَاوُوذْ إِسّنْ، أَقَا سِيذِي ثُوغَا إِڭَّا إِ-ث ذ أَجدْجِيذْ خْ إِسْرَائِيل، مَاغَارْ إِسّْڭعّذْ \add سِيذِي\add* ثَاڭلْذَا نّسْ أَطَّاسْ ذِي طّْوعْ ن ڒْڭنْسْ نّسْ إِسْرَائِيل.
\m 
\v 3 ذَاوُوذْ إِكْسِي عَاذْ ثِيمْغَارِينْ نّغْنِيثْ ذِي ؤُرْشَالِيمْ ؤُ ذَاوُوذْ يَارْنِي إِجَّا-د عَاذْ أَرَّاونْ ذ ثْحنْجِيرِينْ نّغْنِي.
\v 4 إِنَا ذ إِسْمَاونْ ن وَارَّاونْ إِ غَارسْ-د \add إِتّْوَارْونْ\add* ذِي ؤُرْشَالِيمْ: شَامُّوعْ، شُوبَابْ، نَاثَانْ، سُولِيمَانْ،
\v 5 إِبْحَارْ، إِلِيشُوعْ، إِلْفَالَاطْ،
\v 6 نُوجَاهْ، نَافَاجْ، يَافِيعْ،
\v 7 إِلِيشَامَاعْ، بَاعَالْيَاذَاعْ ذ إِلِيفَالَاطْ.
\m 
\v 8 \add ؤُمِي\add* سْڒِينْ إِفِيلِيسْطِينِييّنْ، أَقَا ذهْننْ ذَاوُوذْ ذ أَجدْجِيذْ خْ إِسْرَائِيل، ڭعّْذنْ مَارَّا إِفِيلِيسْطِينِييّنْ حِيمَا أَذْ أَرْزُونْ خْ ذَاوُوذْ. ذَاوُوذْ إِسْڒَا \add إِ مَانْ أَيَا\add* ؤُشَا إِفّغْ مَاحنْذْ أَذْ كِيذْسنْ إِمْسَاڭَارْ.
\v 9 ؤُسِينْ-د إِفِيلِيسْطِينِييّنْ ؤُشَا بزّْعنْ إِخفْ نْسنْ ذِي ثغْزُورْثْ ن إِرَافَاوِييّنْ.
\v 10 \add خنِّي\add* إِسّقْسَا ذَاوُوذْ أَربِّي، إِنَّا: ”مَا أَذْ ڭعّْذغْ ضِيدّْ إِ إِفِيلِيسْطِينِييّنْ؟ مَا أَذْ ثنْ ثڭّذْ ذڭْ ؤُفُوسْ إِنُو؟“ إِنَّا أَسْ سِيذِي: ”ڭعّذْ، نشّْ أَذْ ثنْ ڭّغْ ذڭْ ؤُفُوسْ نّشْ!“
\v 11 نِيثْنِي ڭعّْذنْ غَارْ بَاعْلْ-فَارَاصِيمْ. ذِينِّي إِوْثَا ذَاوُوذْ إِفِيلِيسْطِينِييّنْ، إِنَّا: ”س ؤُفُوسْ إِنُو إِشُوقْ أَربِّي ذِي ڒْعذْيَانْ إِنُو أَمْ وَامَانْ أَرْژِينْ \add إِجّْ ن ڒْحِيضْ\add*.“ خْ ؤُيَا ڭِّينْ أَسْ إِ ومْشَانْ نِّي بَاعْلْ-فَارَاصِيمْ.
\v 12 إِفِيلِيسْطِينِييّنْ جِّينْ إِربِّيثنْ نْسنْ ذِينِّي، ؤُشَا يُومُورْ ذَاوُوذْ مَاحنْذْ أَذْ ثنْ سّْشمْضنْ س ثْمسِّي.
\m 
\v 13 إِفِيلِيسْطِينِييّنْ ڭعّْذنْ عَاوذْ ؤُشَا بزّْعنْ إِخفْ نْسنْ ذِي ڒوْضَا ن ثغْزُورْثْ.
\v 14 ذَاوُوذْ إِسّقْسَا أَربِّي ؤُ أَربِّي إِنَّا أَسْ: ”وَارْ تّْڭِيعِّيذْ شَا أَوَارْنِي أَسنْ، مَاشَا نّضْ أَسنْ-د، أَذْ غَارْسنْ د-ثَاسذْ زڭْ ؤُغزْذِيسْ ن ثْشجُّورَا ن ؤُمتِّي.
\v 15 خْمِي غَا ثسْڒذْ إِ ثشْڒِي ن إِصُورَافْ ذِي ثْقِيشَّاثْ ن ثْشجُّورَا ن ؤُمتِّي، خنِّي أَذْ ثفّْغذْ غَارْ ؤُمنْغِي، مَاغَارْ \add خنِّي\add* أَذْ أَشْ يِيزْوَارْ أَربِّي زَّاثْ إِ وُوذمْ نّشْ، حِيمَا أَذْ إِوّثْ ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ.“
\v 16 ذَاوُوذْ إِڭَّا أَمْ مَامّشْ ذ أَسْ يُومُورْ أَربِّي، ؤُ نِيثْنِي وْثِينْ ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ زِي جِيبْعُونْ أَڒْ جَازَارْ.
\v 17 أَمُّو إِ إِفّغْ إِسمْ ن ذَاوُوذْ ذِي مَارَّا ثِيمُّورَا، ؤُشَا سِيذِي إِسِّيوضْ ثِيڭّْوُوذِي زَّايسْ خْ مَارَّا ڒڭْنُوسْ.
\b
\b
\c 15
\s1 أَسْمُوطِّي ن تَّاپُوثْ زِي ثَادَّارْثْ ن عُوبِيذْ-إِذُومْ غَارْ ؤُرْشَالِيمْ
\m 
\v 1 ذَاوُوذْ إِڭَّا إِ يِيخفْ نّسْ ثُوذْرِينْ ذِي ثنْذِينْثْ ن ذَاوُوذْ ؤُ نتَّا إِڭَّا \add عَاوذْ\add* إِجّْ ن ومْشَانْ إِ تَّابُوثْ ن أَربِّي ؤُشَا إِسّْبدّْ أَسْ إِجّْ ن ؤُقِيضُونْ.
\v 2 \add خنِّي\add* إِنَّا ذَاوُوذْ: ”وَارْ إِعدّڒْ أَقَا ؤُڒَا ذ إِجّنْ أَذْ يَارْبُو تَّابُوثْ ن أَربِّي، مْغِيرْ إِلَاوِييّنْ وَاهَا، مَاغَارْ سِيذِي إِفَارْزْ إِ-ثنْ حِيمَا أَذْ أَرْبُونْ تَّابُوثْ ن أَربِّي ؤُ حِيمَا أَذْ أَسْ سخَّارنْ إِ ڒبْذَا.“
\v 3 ذَاوُوذْ إِسّْمُونْ-د مَارَّا إِسْرَائِيل غَارْ ؤُرْشَالِيمْ حِيمَا أَذْ سّْڭعّْذنْ تَّابُوثْ ن سِيذِي غَارْ ومْشَانْ نّسْ نِّي ثُوغَا ذ أَسْ إِڭَّا.
\m 
\v 4 ذَاوُوذْ إِسّْمُونْ أَرَّاونْ ن هَارُونْ ذ إِلَاوِييّنْ.
\m 
\v 5 زڭْ وَارَّاونْ ن قَاهَاثْ \add ثُوغَا\add* ؤُرِييِيلْ ذ أَمقّْرَانْ \add نْسنْ\add*. أَيْثْمَاسْ \add ثُوغَا أَثنْ ذِي\add* مْيَا ؤُ-عِيشْرِينْ.
\m 
\v 6 زڭْ وَارَّاونْ ن مَارَارِي \add ثُوغَا\add* عَاسَايَا ذ أَمقّْرَانْ \add نْسنْ\add*. أَيْثْمَاسْ \add ثُوغَا أَثنْ ذِي\add* مِيثَاينْ ؤُ-عِيشْرِينْ.
\m 
\v 7 زڭْ وَارَّاونْ ن جَارْشُومْ \add ثُوغَا\add* يُووِيلْ ذ أَمقّْرَانْ \add نْسنْ\add*. أَيْثْمَاسْ \add ثُوغَا أَثنْ ذِي\add* مْيَا ؤُ-ثْڒَاثِينْ.
\m 
\v 8 زڭْ وَارَّاونْ ن إِلِيصَافَانْ \add ثُوغَا\add* شَامْعِييَا ذ أَمقّْرَانْ \add نْسنْ\add*. أَيْثْمَاسْ \add ثُوغَا أَثنْ ذِي\add* مِيثَاينْ.
\m 
\v 9 زڭْ وَارَّاونْ ن حَابْرُونْ \add ثُوغَا\add* إِلِييِيلْ ذ أَمقّْرَانْ \add نْسنْ\add*. أَيْثْمَاسْ \add ثُوغَا أَثنْ ذِي\add* ثْمنْيِينْ.
\m 
\v 10 زڭْ وَارَّاونْ ن عُوزِّييِيلْ \add ثُوغَا\add* عَامِّينَاذَابْ ذ أَمقّْرَانْ \add نْسنْ\add*. أَيْثْمَاسْ \add ثُوغَا أَثنْ ذِي\add* مْيَا ؤُ-ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 11 ذَاوُوذْ إِڒَاغَا إِ إِكهَّاننْ صَاذُوقْ ذ أَبْيَاثَارْ، ؤُڒَا إِ إِلَاوِييّنْ ؤُرِييِيلْ، عَاسَايَا، يُووِيلْ، شَامْعِييَا، إِلِييِيلْ ذ عَامِّينَابْ.
\v 12 نتَّا إِنَّا أَسنْ: ”كنِّيوْ ذ إِزدْجِيفنْ ن إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ن إِلَاوِييّنْ. سْقدّْسمْ إِخفْ نْومْ، كنِّيوْ ذ أَيْثْمَاثْومْ، حِيمَا أَذْ ثسّْڭعّْذمْ تَّابُوثْ ن سِيذِي، أَربِّي ن إِسْرَائِيل \add غَارْ ومْشَانْ\add* نِّي ذ أَسْ سّْوجْذغْ.
\v 13 مِينْزِي كنِّيوْ وَارْ ثڭِّيمْ أَيَا ثْوَاڒَا ثَامزْوَارُوثْ، أَقَا سِيذِي، أَربِّي نّغْ، إِسْعَارْ خَانغْ، مِينْزِي وَارْ خَاسْ نَارْزُو عْلَاحْسَابْ لْفَارِيضَا.
\v 14 إِكهَّاننْ ذ إِلَاوِييّنْ سّْقدّْسنْ إِخفْ نْسنْ حِيمَا أَذْ سّْڭعّْذنْ تَّابُوثْ ن سِيذِي، أَربِّي ن إِسْرَائِيل.
\v 15 أَيْثْ ن لَاوِي أَرْبُونْ تَّابُوثْ ن أَربِّي أَكْ-ذ إِعُومَاذْ ن ثْربُّوثْ خْ ثْغَارْضِينْ نْسنْ، أَمْ مَامّشْ \add ث\add* يُومُورْ مُوسَا عْلَاحْسَابْ أَوَاڒْ ن سِيذِي.
\m 
\v 16 ذَاوُوذْ إِنَّا إِ إِمقّْرَاننْ ن إِلَاوِييّنْ، أَقَا أَذْ سّْبدّنْ أَيْثْمَاثْسنْ، إِمذْيَازنْ أَكْ-ذ دُّوزَانْ ن دْجْغَا، أَكْ-ذ لهَارْپَاثْ، أَكْ-ذ ڒْڭَامْبْرِييَاثْ ؤُ أَكْ-ذ ثَادْجُونِينْ ن وُوزَّاڒْ، مَاحنْذْ أَذْ إِتّْوَاسڒْ ڒْحسّْ إِسّفْرَاحنْ إِجْهذْ.
\v 17 نِيثْنِي سّْبدّنْ هَايْمَانْ، مِّيسْ ن يُووِيلْ، ؤُ زڭْ أَيْثْمَاسْ: أَسَافْ، مِّيسْ ن بَارَاخْيَا، ؤُ زڭْ أَيْثْ ن مَارَارِي، ؤُمَاثْسنْ، إِثَانْ، مِّيسْ ن قُوشَايَا،
\v 18 ؤُ أَكِيذْسنْ أَيْثْمَاثْسنْ ذِي دُّوقْ \add ن ثْعسَّاسْثْ\add* وِيسّْ ثْنَاينْ: زَاكَارِييَّا، بِينْ، يَاعْزِييِيلْ، شَامِيرَامُوثْ، يَاحِييِيلْ، عُونِّي، إِلِييَابْ، بَانَايَا، مَاعَاسْيَا، مَاتِّيثْيَا، إِلِيفَالْيَا، مَاقْنِييَا، عُوبِيذْ-إِذُومْ ذ يَاعِييِيلْ، \add نِيثْنِي ثُوغَا أَثنْ\add* ذ إِعسَّاسنْ ن ثوَّارْثْ.
\m 
\v 19 إِمذْيَازنْ ثُوغَا أَثنْ ذ هَايْمَانْ ذ أَسَافْ ذ إِثَانْ أَكْ-ذ ثدْجُونِينْ ن نّْحَاسْ، حِيمَا أَذْ \add ثنْثْ\add* جّنْ أَذْ دّنْذُوننْ،
\v 20 ؤُ زَاكَارِييَّا، عُوزِّييِيلْ، شَامِيرَامُوثْ، يَاحِييِيلْ، عُونِّي، إِلِييَابْ، مَاعَاسْيَا ذ بَانَايَا أَكْ-ذ لهَارْپَاثْ إِتّْوَارِّيڭْلَانْ غَارْ سنّجْ،
\v 21 ذ مَاتِّيثْيَا، إِلِيفَالْيَا، مَاقْنِييَا، عُوبِيذْ-إِذُومْ، يَاعِييِيلْ ذ عَازَازْيَا أَكْ-ذ ڒْڭَامْبْرِييَاثْ ذِي ڒْمفْثَاحْ وِيسّْ ثْمنْيَا، حِيمَا أَذْ سُّويُورنْ \add إِزْڒَانْ\add*.
\v 22 كَانَانْيَا، أَمقّْرَانْ ن إِلَاوِييّنْ، ثُوغَا-ث خْ ثَاربُّوثْ \add ن تَّابُوثْ\add*. نتَّا إِسّڒْمذْ أَسنْ مَامّشْ ثُوغَا إِتّْخصَّا أَذْ أَرْبُونْ، مَاغَارْ نتَّا إِسّنْ \add أَسْ\add*.
\v 23 بَارَاخْيَا ذ إِلْقَانَا ثُوغَا أَثنْ ذ إِعسَّاسنْ ن ثوَّارْثْ غَارْ تَّابُوثْ.
\v 24 إِكهَّاننْ شَابَانْيَا، يَاهُوشَافَاطْ، نَاثَانَايِيلْ، عَامَاسَايْ، زَاكَارِييَّا، بَانَاجَا ذ إِلِيعَازَارْ سُوضنْ ذِي ڒبْوَاقْ زَّاثْ إِ تَّابُوثْ ن أَربِّي ؤُ عُوبِيذْ-إِذُومْ ذ يَاحِييَا ثُوغَا أَثنْ ذ إِعسَّاسنْ ن ثوَّارْثْ غَارْ تَّابُوثْ.
\b
\s1 أَسْمُوطِّي ن تَّاپُوثْ غَارْ ثنْذِينْثْ ن ذَاوُوذْ
\m 
\v 25 \add أَمُّو\add* إِ إِمْسَارْ، أَقَا ذَاوُوذْ ذ إِمْغَارنْ ن إِسْرَائِيل ذ إِمقّْرَاننْ خْ وَاڒفْ طّْفنْ أَبْرِيذْ حِيمَا أَذْ سّْڭعّْذنْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي س ڒفْرَاحثْ زِي ثَادَّارْثْ ن عُوبِيذْ-إِذُومْ. \x ◘ \xo 15:‏25 \xt [1 صم. 6‏:‏16‏-‏23]\x*
\v 26 \add ڒَْامِي\add* أَرْبُونْ إِلَاوِييّنْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي أَمْ ذ أَسنْ إِوْشَا أَربِّي \add أَ\add*فُوسْ، إِمْسَارْ أَقَا نِيثْنِي قدّْمنْ سبْعَا ن إِفُونَاسنْ إِمژْيَاننْ ذ سبْعَا ن إِشَارِّييّنْ ذ ثَاغَارْصْثْ.
\v 27 ذَاوُوذْ ثُوغَا يَارْضْ إِجّْ ن ؤُسڒْهَامْ ن ڒقْطنْ أَزْذَاذْ، ؤُڒَا مَارَّا إِلَاوِييّنْ، إِنِّي يَارْبُونْ تَّابُوثْ ذ يِينِّي ثُوغَا إِتّْغنَّاجنْ، ذ كَانَانْيَا، أَمحْضَايِي خْ يِينِّي إِتّْغنَّاجنْ. ذَاوُوذْ يَارْضْ إِجّْ ن ؤُپَالْطُو \add ن ؤُكهَّانْ\add* ن ڒقْطنْ.
\v 28 أَمُّو إِ إِسّْڭعّذْ مَارَّا إِسْرَائِيل تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي س إِغُويَّانْ ن ڒفْرَاحثْ ؤُ س ڒْحسّْ ن ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي ؤُ ذِي ڒبْوَاقْ ؤُ س ڒْحسّْ ن ثَادْجُونِينْ ن وُوزَّاڒْ، ؤُ نِيثْنِي ثُوغَا تِّيرَارنْ س لهَارْپَاثْ ذ ڒْڭَامْبْرِييَاثْ.
\v 29 ڒَامِي د-ثِيوضْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي غَارْ ثنْذِينْثْ ن ذَاوُوذْ، إِمْسَارْ، أَقَا مِيخَالْ، يدْجِيسْ ن شَاوُولْ، ثخْزَارْ زِي ڒْكَازِي، ثژْرَا مَامّشْ إِنڭّزْ ؤُ مَامّشْ إِشطّحْ ؤُجدْجِيذْ ذَاوُوذْ، ؤُشَا ثسّحْقَارْ إِ-ث ذڭْ وُوڒْ نّسْ.
\b
\b
\c 16
\s1 ذَاوُوذْ إِذبَّارْ أَعْبذْ ن سِيذِي س ثْغَارْصَا ذ إِزْڒَانْ ذ ثْژَادْجِيثْ
\m 
\v 1 نِيثْنِي سِّيذْفنْ تَّابُوثْ ن أَربِّي غَارْ ذَاخڒْ ؤُشَا سَّارْسنْ ت ذِي ڒْوسْطْ ن ؤُقِيضُونْ نِّي ثُوغَا ذ أَسْ د-إِشدّْ ذَاوُوذْ، ؤُشَا قدّْمنْ نِيثْنِي ثِيغَارْصَا ن وشْمَاضْ ذ ثِيغَارْصَا ن ڒهْنَا زَّاثْ إِ وُوذمْ ن أَربِّي.
\v 2 \add ؤُمِي\add* إِكمّڒْ ذَاوُوذْ أَسْڭعّذْ ن ثْغَارْصْثْ ن وشْمَاضْ ذ ثْغَارْصَا ن ڒهْنَا، إِبَاركْ نتَّا ڒْڭنْسْ ذڭْ يِيسمْ ن سِيذِي.
\v 3 نتَّا إِبْضَا إِ مَارَّا ذِي إِسْرَائِيل، إِ يرْيَازنْ ذ ثمْغَارِينْ، إِ كُوڒْ إِجّْ، إِجّْ ن ونْڭُورْ ن وغْرُومْ، إِجّْ ن ؤُشدْجِيقْ ن ويْسُومْ ن ؤُفُونَاسْ ذ إِجّْ ن وَارقِّيعْ ن زّْبِيبْ.
\v 4 نتَّا إِڭَّا شَا ن إِلَاوِييّنْ ذ إِمْسخَّارنْ إِ تَّابُوثْ ن سِيذِي، حِيمَا أَذْ سّْعقْڒنْ ؤُ أَذْ قَاذَانْ ؤُ أَذْ سّمْغَارنْ سِيذِي، أَربِّي ن إِسْرَائِيل.
\v 5 أَسَافْ \add ثُوغَا-ث ذ\add* أَزدْجِيفْ ذ زَاكَارِييَّا \add ثُوغَا-ث ذ\add* وِيسّْ ثْنَاينْ أَوَارْنِي أَسْ \add ؤُ خنِّي\add* يَاعِييِيلْ، شَامِيرَامُوثْ، يَاحِييِيلْ، مَاتِّيثْيَا، إِلِييَابْ، بَانَايَا، عُوبِيذْ-إِذُومْ ذ يَاعِييِيلْ أَكْ-دُّوزَانَاثْ أَمْ لهَارْپَاثْ ذ ڒْڭَامْبْرِييَاثْ، ؤُشَا أَسَافْ إِڭَّا أَذْ أَسْ سْڒنْ س ثدْجُونِينْ ن وُوزَّاڒْ.
\v 6 إِكهَّاننْ بَانَايَا ذ يَاحْزِييِيلْ \add ؤُيُورنْ\add* س ڒبْوَاقْ زَّاثْ إِ تَّابُوثْ ن ڒْعَاهْذْ ن أَربِّي.
\m 
\v 7 ذڭْ وَاسّْ نِّي إِڭَّا ذَاوُوذْ إِ ثْوَاڒَا ثَامزْوَارُوثْ خْ أَسَافْ ذ أَيْثْمَاسْ مَاحنْذْ أَذْ سّمْغَارنْ سِيذِي.
\b
\s1 إِژْڒِي ن ؤُصبّحْ ن ذَاوُوذْ
\m 
\v 8 \qt ”قَاذَامْ سِيذِي، ڒَاغَامْ خْ يِيسمْ نّسْ،\qt*
\m \qt بَارّْحمْ س ثْمڭَّا نّسْ جَارْ ڒڭْنُوسْ.\qt*\x ◘ \xo 16:‏8 \xt [إِزهد. 105‏:‏1‏-‏15؛ 96‏:‏1‏-‏13؛ 106‏:‏1، 47‏-‏48]\x*
\m 
\v 9 \qt غنّْجمْ أَسْ، زهّْذمْ إِ نتَّا،\qt*
\m \qt سِيوْڒمْ خْ مَارَّا لْمُوعْجِيزَاثْ نّسْ.\qt*
\m 
\v 10 \qt شنّْعمْ س يِيسمْ نّسْ أَمْقدّسْ،\qt*
\m \qt حِيمَا ؤُڒْ ن يِينِّي يَارزُّونْ سِيذِي،\qt*
\m \qt أَذْ إِفَارْحْ.\qt*
\m 
\v 11 \qt سقْسَامْ خْ سِيذِي ذ جّهْذْ نّسْ،\qt*
\m \qt أَرْزُومْ ؤُذمْ نّسْ ڒبْذَا.\qt*
\m 
\v 12 \qt عقْڒمْ خْ ڒعْجَايبْ نّسْ إِ إِڭَّا،\qt*
\m \qt خْ ڒعْڒَامثْ نّسْ\qt*
\m \qt ؤُ خْ ڒحْكَامَاثْ ن ؤُقمُّومْ نّسْ.\qt*
\m 
\v 13 \qt زَّارِيعثْ ن إِسْرَائِيل، أَمْسخَّارْ نّسْ،\qt*
\m \qt إِحنْجِيرنْ ن يَاعْقُوبْ،\qt*
\m \qt إِنِّي زَّايسْ إِتّْوَافَارْزنْ!\qt*
\m 
\v 14 \qt نتَّا ذ سِيذِي، أَربِّي نّغْ.\qt*
\m \qt ڒحْكَامَاثْ نّسْ \tl إِ د-إِتَّاسنْ\tl*\qt*
\m \qt خْ مَارَّا ثَامُّورْثْ.\qt*
\m 
\v 15 \qt عقْڒمْ خْ ڒْعَاهْذْ نّسْ إِ ڒبْذَا،\qt*
\m \qt أَوَاڒْ نِّي إِوصَّا إِ أَڒفْ ن جِّيڒَاثْ،\qt*
\m 
\v 16 \qt \tl ڒْْعَاهْذْ\tl* إِ إِڭَّا أَكْ-ذ إِبْرَاهِيمْ،\qt*
\m \qt \tl إِسّمْثنْ إِ-ث س\tl* ثْجَادْجِيثْ نّسْ إِ إِسْحَاقْ.\qt*
\m 
\v 17 \qt نتَّا إِڭَّا إِ-ث ذ إِشْثْ ن ثوْصيّثْ إِ يَاعْقُوبْ،\qt*
\m \qt إِ إِسْرَائِيل \add إِڭَّا إِ-ث\add* ذ إِجّْ ن ڒْعَاهْذْ إِ ڒبْذَا،\qt*
\m 
\v 18 \qt ؤُمِي إِنَّا:\qt*
\m \qt ’أَذْ أَشْ وْشغْ ثَامُّورْثْ ن كنْعَانْ،\qt*
\m \qt ثَاسْغَارْثْ إِ ذ أَومْ د-إِكَّارنْ!‘،\qt*
\m 
\v 19 \qt ؤُمِي كنِّيوْ ثُوغَا ذ إِجّْ ن وُورُو ن يرْيَازنْ،\qt*
\m \qt س ذْرُوسْثْ \tl وَاهَا\tl*،\qt*
\m \qt ذ إِبَارَّانِييّنْ ذِي \tl ثمُّورْثْ\tl*.\qt*
\m 
\v 20 \qt ثلْعنْ زِي ڒْڭنْسْ غَارْ ڒْڭنْسْ \tl نّغْنِي\tl*،\qt*
\m \qt زڭْ إِشْثْ ن ثْڭلْذِيثْ غَارْ إِجّْ ن ڒْڭنْسْ نّغْنِي.\qt*
\m 
\v 21 \qt نتَّا وَارْ إِجِّي ؤُڒَا ذ إِجّْ أَذْ ثنْ إِحْصَارْ،\qt*
\m \qt ؤُ نتَّا إِعَاقبْ إِجدْجِيذنْ ذِي طّْوعْ نْسنْ.\qt*
\m 
\v 22 \qt ’وَارْ تّْحَاذَامْ شَا إِمذْهَانْ إِنُو،\qt*
\m \qt وَارْ تّڭّمْ ڒْغَارْ ذڭْ إِنَابِييّنْ إِنُو!‘\qt*
\m 
\v 23 \qt غنّْجمْ إِ سِيذِي، مَارَّا ثَامُّورْثْ،\qt*
\m \qt بَارّْحمْ إِ ؤُسنْجمْ نّسْ أَسّْ خْ وَاسّْ.\qt*
\m 
\v 24 \qt حَاجَامْ أَعُودْجِي نّسْ جَارْ ڒڭْنُوسْ،\qt*
\m \qt ڒعْجَايبْ نّسْ جَارْ مَارَّا ڒڭْنُوسْ.\qt*
\m 
\v 25 \qt مَاغَارْ سِيذِي ذ أَمقّْرَانْ،\qt*
\m \qt إِسّْذَاحدْجْ أَسمْغَارْ أَطَّاسْ،\qt*
\m \qt نتَّا ذ أَمَاڭّْوذْ مَاهُو مَارَّا إِربِّيثنْ.\qt*
\m 
\v 26 \qt مِينْزِي مَارَّا إِربِّيثنْ ن ڒڭْنُوسْ\qt*
\m \qt أَقَا أَثنْ ذ لْ-أَصْنَامْ،\qt*
\m \qt \tl مَاشَا\tl* سِيذِي إِڭَّا إِجنْوَانْ.\qt*
\m 
\v 27 \qt ثِيسِّيقْثْ ذ ڒْعزّْ \tl أَقَا أَثنْ\tl*\qt*
\m \qt زَّاثْ إِ وُوذمْ نّسْ،\qt*
\m \qt جّهْذْ ذ ڒفْرَاحثْ ذڭْ ومْشَانْ نّسْ.\qt*
\m 
\v 28 \qt وْشمْ إِ سِيذِي، \tl أَ\tl* ثِيقبَّاڒْ ن ڒڭْنُوسْ،\qt*
\m \qt وْشمْ إِ سِيذِي أَعُودْجِي ذ جّهْذْ.\qt*
\m 
\v 29 \qt وْشمْ إِ سِيذِي أَعُودْجِي ن يِيسمْ نّسْ،\qt*
\m \qt أَوْيمْ ثَاوْهِيبْثْ ؤُشَا أَسمْ-د\qt*
\m \qt زَّاثْ إِ وُوذمْ نّسْ،\qt*
\m \qt بنْذْقمْ إِ سِيذِي\qt*
\m \qt ذڭْ ؤُشُووَّاضْ ن زَّاوشْثْ إِقدّْسنْ.\qt*
\m 
\v 30 \qt أَرْجِيجمْ زَّاثْ إِ وُوذمْ نّسْ،\qt*
\m \qt \tl أَ\tl* مَارَّا ثَامُّورْثْ!\qt*
\m \qt نِيشَانْ، \tl ڒخُّو\tl* دُّونشْثْ ثْبدّْ ثمْثنْ،\qt*
\m \qt وَارْ تّنْهزِّي \tl عَاذْ\tl*.\qt*
\m 
\v 31 \qt أجّْ أَجنَّا أَذْ إِفَارْحْ\qt*
\m \qt ؤُ ثَامُّورْثْ أَذْ ثْفَارْحْ،\qt*
\m \qt أَذْ إِنِينْ جَارْ ڒڭْنُوسْ:\qt*
\m \qt سِيذِي إِحكّمْ.\qt*
\m 
\v 32 \qt أجّْ أَذْ إِزْهَارْ ڒبْحَارْ ذ ؤُعمَّارْ نّسْ، \qt*
\m \qt أجّْ أَذْ إِسْڒِيوْڒوْ ييَّارْ س ڒفْرَاحثْ،\qt*
\m \qt س مَارَّا مِينْ ذَايسْ.\qt*
\m 
\v 33 \qt خنِّي أَذْ سْڒِيوْڒِيونْثْ\qt*
\m \qt مَارَّا ثِيشجُّورَا ن وزْغَارْ\qt*
\m \qt زَّاثْ إِ وُوذمْ ن سِيذِي،\qt*
\m \qt مَاغَارْ نتَّا أَذْ د-يَاسْ،\qt*
\m \qt حِيمَا أَذْ إِسڭّذْ ثَامُّورْثْ.\qt* \f ◼ \fr 16:‏33 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\m 
\v 34 \qt قَاذَامْ سِيذِي، مَاغَارْ نتَّا إِصْبحْ،\qt*
\m \qt مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ\qt*
\m \qt \tl ثتّْغِيمَا\tl* إِ ڒبْذَا.\qt*
\m 
\v 35 \qt إِنِيمْ: سنْجمْ أَنغْ،\qt*
\m \qt \tl أَ\tl* أَربِّي ن ؤُسنْجمْ نّغْ،\qt*
\m \qt نْذهْ أَنغْ نْمُونْ، فكّْ أَنغْ زِي ڒڭْنُوسْ،\qt*
\m \qt حِيمَا أَذْ نْقَاذَا إِسمْ إِقدّْسنْ نّكْ\qt*
\m \qt ؤُ أَذْ شكْ نْصبّحْ س إِزْڒَانْ ن ؤُصبّحْ.\qt*
\b
\m 
\v 36 \qt أَذْ إِتّْوَابَاركْ سِيذِي، أَربِّي ن إِسْرَائِيل،\qt*
\m \qt زِي ڒبْذَا أَڒْ ڒبْذَا!“\qt*
\b
\m ؤُ مَارَّا ڒْڭنْسْ إِنَّا: ”أَمِينْ!“ ؤُشَا إِمْذحْ سِيذِي.
\b
\m 
\v 37 نتَّا إِڭَّا ذِينْ زَّاثْ إِ وُوذمْ ن تَّابُوثْ ن سِيذِي، إِ أَسَافْ ذ يَايْثْمَاسْ، حِيمَا أَذْ سخَّارنْ ڒبْذَا زَّاثْ إِ وُوذمْ ن تَّابُوثْ، \add حِيمَا أَذْ ڭّنْ\add* كُوڒْ أَسّْ مِينْ يُورِينْ إِ وَاسّْ نِّي.
\v 38 عُوبِيذْ-إِذُومْ أَكْ-ذ أَيْثْمَاثْسنْ، \add ثُوغَا أَثنْ جْمِيعْ\add* ثْمنْيَا ؤُ-ستِّينْ \add ن يرْيَازنْ\add*. عُوبِيذْ-إِذُومْ، مِّيسْ ن يَاذِيثُونْ، ذ حُوسَا \add ثُوغَا أَثنْ ذ\add* إِعسَّاسنْ ن ثِيوُّورَا،
\v 39 ؤُشَا أَكهَّانْ صَاذُوقْ ذ يَايْثْمَاسْ، إِكهَّاننْ، \add ثُوغَا تّْسخَّارنْ\add* زَّاثْ إِ ثْزذِّيغْثْ ن سِيذِي خْ ڒْڭعّْذثْ نِّي \add إِدْجَانْ\add* غَارْ جِيبْعُونْ،
\v 40 حِيمَا أَذْ أَوْينْ ثِيغَارْصَا ن وشْمَاضْ بْڒَا \add أَ\add*قطُّو إِ سِيذِي خْ ؤُعَالْطَارْ ن وشْمَاضْ، غَارْ ثُوفُّوثْ ؤُ غَارْ ثْمذِّيثْ، أَمْ مَامّشْ مَارَّا مِينْ يُورَانْ ذِي شَّارِيعَا ن سِيذِي، ثنِّي إِڭَّا خْ إِسْرَائِيل.
\v 41 غَارْسنْ \add ثُوغَا\add* هَايْمَانْ ذ يَاذُوثُونْ أَكْ-ذ إِنّغْنِي إِنِّي إِتّْوَافَارْزنْ ؤُ إِتّْوَاڭّنْ س يِيسْمَاونْ \add نْسنْ\add*، حِيمَا أَذْ قَاذَانْ سِيذِي: ’مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ \add ثتّْغِيمَا\add* إِ ڒبْذَا!‘
\v 42 ثُوغَا غَارْ هَايْمَانْ ذ يَاذُوثُونْ \add ذ ونّغْنِي\add* ڒبْوَاقْ ذ ثَادْجُونِينْ ن وُوزَّاڒْ، مَاحنْذْ أَذْ ڭّنْ أَذْ أَسنْ سْڒنْ \add يوْذَانْ\add*، ؤُڒَا ذ دُّوزَانَاثْ ن لْمُوسِيقَا \add إِنّغْنِي\add* \add إِ ؤُسمْغَارْ\add* ن أَربِّي. أَرَّاونْ ن يَاذُوثُونْ \add ثُوغَا بدّنْ\add* غَارْ ثوَّارْثْ \add ن وَاذَافْ\add*.
\v 43 \add خنِّي\add* يُويُورْ مَارَّا ڒْڭنْسْ، كُوڒْ إِجّْ غَارْ ثَادَّارْثْ نّسْ. ؤُڒَا ذ ذَاوُوذْ إِعْقبْ غَارْ ثَادَّارْثْ نّسْ حِيمَا أَذْ إِبَاركْ ثَادَّارْثْ نّسْ.
\b
\b
\c 17
\s1 أَوَاڒْ ن أَربِّي خْ زَّاوشْثْ ثَامقّْرَانْثْ ذ ڒْكُورْسِي إِڭلّْذنْ
\m 
\v 1 ؤُمِي إِزْذغْ ذَاوُوذْ ذِي ثَادَّارْثْ نّسْ، إِنَّا ذَاوُوذْ إِ ؤُنَابِي نَاثَانْ: ”خْزَارْ، نشّْ زدّْغغْ ذڭْ إِشْثْ ن ثَادَّارْثْ ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ، \add مَاشَا\add* تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي أَقَا-ت سَاذُو ڒْكتَّانْ \add ن ؤُقِيضُونْ\add*.“ \x ◘ \xo 17:‏1 \xt [2 صم. 7‏:‏1‏-‏15]\x*
\v 2 نَاثَانْ يَارَّا-د خْ ذَاوُوذْ: ”أڭّْ مَارَّا مِينْ غَاركْ ذڭْ وُوڒْ نّشْ، مَاغَارْ أَربِّي أَكِيذكْ.“
\m 
\v 3 ذِي دْجِيڒثْ نِّي إِمْسَارْ أَقَا يُوسَا-د وَاوَاڒْ ن أَربِّي غَارْ نَاثَانْ، إِنَّا:
\v 4 ”ؤُيُورْ، إِنِي إِ ؤُمْسخَّارْ إِنُو ذَاوُوذْ: ’أَمُّو إِ إِقَّارْ سِيذِي: وَارْ ذ أَيِي ثْبنِّيذْ ثَادَّارْثْ إِ نشّْ، حِيمَا أَذْ ذَايسْ زذْغغْ،
\v 5 مَاغَارْ زڭْ وَاسّْ ؤُمِي د-سّْڭعّْذغْ إِسْرَائِيل زِي مِيصْرَا، نشّْ وَارْ زْذِيغغْ \add عمَّارْصْ\add* ذڭْ إِشْثْ ن ثَادَّارْثْ. مَاشَا نشّْ ثُوغَا ڭُّورغْ زڭْ ؤُقِيضُونْ غَارْ ؤُقِيضُونْ، زِي ثْزذِّيغْثْ غَارْ ثْزذِّيغْثْ.
\v 6 مَانِي مَا ؤُيُورغْ أَكْ-ذ مَارَّا إِسْرَائِيل، مَا نشّْ سِّيوْڒغْ \add عمَّارْصْ ؤُڒَا س\add* إِجّْ ن وَاوَاڒْ أَكْ-ذ إِجّنْ زِي ڒْقُوضَاثْ ن إِسْرَائِيل، إِنِّي ثُوغَا ڭِّيغْ أَذْ أَروْسنْ ڒْڭنْسْ إِنُو إِسْرَائِيل، نِّيغْ: مَايمِّي كنِّيوْ وَارْ ذ أَيِي ثْبنِّيمْ شَا ثَادَّارْثْ س ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ؟‘ \x ◘ \xo 17:‏6 \xt 2 صم. 7‏:‏7\x*
\v 7 خنِّي ڒخُّو، أَمُّو إِ غَا ثِينِيذْ إِ ؤُمْسخَّارْ إِنُو، إِ ذَاوُوذْ: ’أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ إِجهْذنْ: نشّْ إِوْيغْ-د شكْ زِي ڒْكُورِي، زِي ضفَّارْ ن وُودْجِي، مَاحنْذْ أَذْ ثْذوْڒذْ ذ ڒْحَاكمْ خْ ڒْڭنْسْ إِنُو إِسْرَائِيل.
\v 8 مَانِي مَا ثُويُورذْ، ثُوغَا أَيِي أَكِيذكْ ؤُ نشّْ ثحِّيغْ مَارَّا ڒْعذْيَانْ زَّاثْ إِ ثِيطَّاوِينْ نّشْ ؤُ نشّْ ڭِّيغْ أَشْ إِجّْ ن يِيسمْ أَمْ يِيسمْ ن إِمقّْرَاننْ خْ ثمُّورْثْ.
\v 9 نشّْ نيّْشغْ إِجّْ ن ومْشَانْ إِ ڒْڭنْسْ إِنُو ؤُشَا ژُّوغْ ث \add ذِينْ\add*، مَاحنْذْ أَذْ إِزْذغْ ذڭْ ومْشَانْ \add نّسْ\add*، وَارْ إِتّْوَاسّْنخْڒِيعْ عَاذْ ؤُ وَارْ ث حصَّارنْ عَاذْ أَيْثْ ن ڒْمُوعْصِييّثْ أَمْ زِيشْ،
\v 10 زڭْ وُوسَّانْ ؤُمِي نشّْ ڭِّيغْ ڒْقُوضَاثْ خْ ڒْڭنْسْ إِنُو إِسْرَائِيل. نشّْ سّْوَاضْعغْ مَارَّا ڒْعذْيَانْ نّشْ ؤُ سَّارْڭْبغْ شكْ بلِّي سِيذِي أَذْ أَشْ إِبْنَا إِشْثْ ن ثَادَّارْثْ.
\v 11 خْ مِينِّي إِ غَا قفْڒنْ وُوسَّانْ نّشْ ؤُ أَذْ ثڭّذْ أَذْ ثَاريّْحذْ جَارْ ڒجْذُوذْ نّشْ، أَذْ إِمْسَارْ، نشّْ أَذْ سّكَّارغْ مِّيشْ أَوَارْنِي أَشْ، ونِّي إِ غَا إِفّْغنْ زڭْ وَارَّاونْ نّشْ، ؤُ نشّْ أَذْ سّْمثْنغْ ثَاڭلْذِيثْ نّسْ. \f ◼ \fr 17:‏11 \ft \bd ’مِّيشْ‘\bd* - س ثْعِيبْرَانِيثْ ’زَّارِيعثْ نّكْ‘.\f*
\v 12 نتَّا أَذْ أَيِي إِبْنَا إِشْثْ ن ثَادَّارْثْ ؤُ نشّْ أَذْ سّْبدّغْ ڒْعَارْشْ نّسْ إِ ڒبْذَا.
\v 13 نشّْ أَذْ إِڒِيغْ ذ بَابَاسْ إِ نتَّا ؤُ نتَّا أَذْ أَيِي يِيڒِي ذ مِّي ؤُ نشّْ وَارْ خَاسْ سّْحيِّيذغْ شَا ثَامخْسِيوْثْ إِنُو إِشوَّارنْ أَمْ مَامّشْ ت سْحيّْذغْ خْ ونِّي ثُوغَا ذ أَشْ إِزْوَارنْ.
\v 14 نشّْ أَذْ ث سّْمثْنغْ ذِي ثَادَّارْثْ إِنُو ؤُ ذِي ثْڭلْذِيثْ إِنُو إِ ڒبْذَا ؤُ ڒْعَارْشْ نّسْ أَذْ إِبدّْ إِمْثنْ إِ ڒبْذَا.‘ “
\v 15 إِسِّيوڒْ نَاثَانْ أَكْ-ذ ذَاوُوذْ نِيشَانْ أَمْ مَامّشْ مَارَّا أَوَاڒنْ-أَ ؤُ أَمْ مَامّشْ مَارَّا ڒوْحِييْ-أَ.
\b
\s1 ثَاژَادْجِيثْ ن ؤُقَاذِي ن ذَاوُوذْ
\m 
\v 16 \add خنِّي\add* يُوذفْ ؤُجدْجِيذْ ذَاوُوذْ ؤُشَا إِقِّيمْ زَّاثْ إِ وُوذمْ ن سِيذِي، إِنَّا: ”مِينْ عْنِيغْ نشّْ، سِيذِي أَربِّي، ؤُ مِينْ ثعْنَا ثَادَّارْثْ إِنُو أَقَا شكْ ثْنذْهذْ أَيِي-د أَڒْ ذَانِيثَا؟ \x ◘ \xo 17:‏16 \xt [2 صم. 7‏:‏18‏-‏29]\x*
\v 17 ذِي ثِيطَّاوِينْ نّشْ ثُوغَا مَانْ أَيَا ذْرُوسْ \add وَاهَا\add*، \add أَ\add* أَربِّي، ؤُ \add ڒخُّو\add* ثسِّيوْڒذْ \add عَاذْ\add* خْ ثَادَّارْثْ ن ؤُمْسخَّارْ نّشْ ذڭْ إِجّْ ن يِيمَارْ إِڭّْوجْ ؤُ ثْخزَّارذْ ذَايِي أَمْ يِيجّْ ن ؤُفِيڒُو \add ن وَارَّاونْ\add* ن بْنَاذمْ إِ د-إِتَّاوْينْ غَارْ سنّجْ، \add أَ\add* سِيذِي أَربِّي!
\v 18 مِينْ ذ أَشْ إِ غَا يِينِي ذَاوُوذْ عَاذْ كْثَارْ خْ شّنْعثْ إِ ثسّشْنذْ إِ ؤُمْسخَّارْ نّشْ؟ أَقَا شكْ ثسّْنذْ أَمْسخَّارْ نّشْ!
\v 19 \add أَ\add* سِيذِي، أَقَا ثڭِّيذْ مَارَّا ڒمْغَارثْ-أَ ذِي طّْوعْ ن ؤُمْسخَّارْ نّشْ ؤُ عْلَاحْسَابْ ؤُڒْ نّشْ، حِيمَا أَذْ ثسَّارْڭْبذْ \add أَمُّو\add* مَارَّا ثِيمسْڒَايِينْ-أَ ثِيمقّْرَانِينْ.
\v 20 \add أَ\add* سِيذِي، ؤُڒَا ذ إِجّْ وَارْ إِدْجِي أَمْ شكْ. وَارْ ذِينْ أَربِّي مْغِيرْ شكْ س مَارَّا مِينْ نسْڒَا س إِمزُّوغنْ نّغْ.
\v 21 مَانْ ونْ \add إِ إِدْجَانْ\add* أَمْ ڒْڭنْسْ نّشْ إِسْرَائِيل، أَينِّي ن ڒْڭنْسْ إِ إِدْجَانْ خْ ثمُّورْثْ إِ غَارْ إِرَاحْ أَربِّي حِيمَا أَذْ ث إِفْذِي إِ يِيخفْ نّسْ ذ ڒْڭنْسْ، حِيمَا أَذْ إِڭّْ إِ يِيخفْ نّسْ إِجّْ ن يِيسمْ س ثْمڭَّا ثِيمقّْرَانِينْ ذ إِسِّيڭّْوْذنْ، ؤُ حِيمَا أَذْ يَاژّڒْ خْ ڒڭْنُوسْ زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ نّشْ، ونِّي ثفْذِيذْ زِي مِيصْرَا؟ \f ◼ \fr 17:‏21 \ft \bd ’إِفْذِي‘\bd* - خْزَارْ إِزهد. 78‏:35.\f*
\v 22 شكْ ثڭِّيذْ ڒْڭنْسْ نّشْ إِسْرَائِيل ذ إِجّْ ن ڒْڭنْسْ إِ يِيخفْ نّشْ إِ ڒبْذَا. شكْ، \add أَ\add* سِيذِي، أَقَا شكْ ثْذوْڒذْ ذ أَربِّي إِ نِيثْنِي.
\v 23 خنِّي ڒخُّو، \add أَ\add* سِيذِي أَربِّي، أجّْ أَوَاڒْ نِّي ثسِّيوْڒذْ خْ ؤُمْسخَّارْ نّشْ ؤُ خْ ثَادَّارْثْ نّسْ أَذْ إِبدّْ إِ ڒبْذَا ؤُ أڭّْ أَمْ مَامّشْ ثسِّيوْڒذْ.
\v 24 أجّْ إِسمْ نّشْ أَذْ إِتّْوَاسّمْغَارْ إِ ڒبْذَا ؤُمِي غَا إِنِينْ: سِيذِي ن ڒْعسْكَارَاثْ إِجهْذنْ، أَربِّي ن إِسْرَائِيل، أَقَا-ث ذ أَربِّي خْ إِسْرَائِيل، ؤُشَا إِڒِي أَذْ ثتّْوَاسّمْثنْ ثَادَّارْثْ ن ؤُمْسخَّارْ نّشْ ذَاوُوذْ زَّاثْ إِ وُوذمْ نّشْ.
\v 25 مَاغَارْ شكْ، أَربِّي إِنُو، ثسَّارْڭْبذْ ذڭْ إِمزُّوغنْ ن ؤُمْسخَّارْ نّشْ أَقَا شكْ أَذْ أَسْ ثبْنِيذْ إِشْثْ ن ثَادَّارْثْ. خْ ؤُيَا ثُوسَا-د إِ ؤُمْسخَّارْ نّشْ ذڭْ وُوڒْ، حِيمَا أَذْ إِژَّادْجْ زَّاثْ إِ وُوذمْ نّشْ.
\v 26 خنِّي ڒخُّو، \add أَ\add* سِيذِي، شكْ ذ أَربِّي نِّي ؤُ شكْ ثسِّيوْڒذْ س \add مَارَّا\add* ثْشُونِي-يَا خْ ؤُمْسخَّارْ نّشْ.
\v 27 خنِّي ڒخُّو، أَقَا يَارْضَا إِ شكْ أَذْ ثْبَارْكذْ ثَادَّارْثْ ن ؤُمْسخَّارْ نّشْ، حِيمَا أَذْ ثِيڒِي زَّاثْ إِ وُوذمْ نّشْ إِ ڒبْذَا. مِينْزِي شكْ، \add أَ\add* سِيذِي، ثْبَارْكذْ ت ؤُشَا أَذْ ثتّْوَابَاركْ إِ ڒبْذَا.“
\b
\b
\c 18
\s1 إِغلَّابنْ ن ذَاوُوذْ
\m 
\v 1 أَوَارْنِي أَيَا إِمْسَارْ، أَقَا ذَاوُوذْ إِغْڒبْ خْ إِفِيلِيسْطِينِييّنْ ؤُشَا يَارَّا إِ-ثنْ سَاذُو نّسْ. نتَّا إِكّسْ جَاثْ ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ زڭْ ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ. \x ◘ \xo 18:‏1 \xt [2 صم. 8‏:‏1‏-‏15]\x*
\v 2 إِغْڒبْ ؤُڒَا خْ \add أَيْثْ ن\add* مُوآبَ أَڒَامِي \add أَيْثْ ن\add* مُوآبَ ذوْڒنْ ذ إِمْسخَّارنْ إِ ذَاوُوذْ، إِنِّي إِتّْخصَّانْ أَذْ وْشنْ ثَارْزِيفِينْ.
\m 
\v 3 ذَاوُوذْ إِغْڒبْ \add عَاوذْ\add* خْ هَاذَاذْ-عَازَارْ، أَجدْجِيذْ ن صُوبَا، أَڒْ حَامَاثْ، ؤُمِي ثُوغَا د-إِفّغْ وَانِيثَا حِيمَا أَذْ إِسّمْثمْ ڒحْكَامثْ نّسْ غَارْ يغْزَارْ ن لْفُورَاطْ. \f ◼ \fr 18:‏3 \ft \bd ’ڒحْكَامثْ نّسْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَفُوسْ نّسْ‘.\f*
\v 4 ذَاوُوذْ إِكّسْ زَّايسْ أَڒفْ ن إِكَارُّوثنْ ذ سبْعَا-أَڒَافْ ن إِمْنَاينْ ذ عِيشْرِينْ-أَڒفْ ن يرْيَازنْ خْ إِضَارنْ ؤُ ذَاوُوذْ إِقسّْ إِژوْرَانْ ن إِضَارنْ ن مَارَّا \add إِيْسَانْ ن\add* إِكَارُّوثنْ ؤُشَا إِجَّا زَّايْسنْ مْيَا ن \add إِيْسَانْ ن\add* إِكَارُّوثنْ \add وَاهَا\add*.
\m 
\v 5 يُوسَا-د أَرَامْ زِي ذِيمَاشْقْ، حِيمَا أَذْ إِوْشْ أَفُوسْ إِ هَاذَارْ-عَازَارْ، أَجدْجِيذْ ن صُوبَا، \add مَاشَا\add* ذَاوُوذْ إِغْڒبْ خْ ثْنَاينْ ؤُ-عِيشْرِينْ-أَڒَافْ ن يرْيَازنْ ن أَرَامْ.
\v 6 ذَاوُوذْ إِڭَّا ڒْعسْكَارَاثْ ن ؤُحوّسْ جَارْ أَيْثْ ن أَرَامْ ن ذِيمَاشْقْ، ؤُ أَيْثْ ن أَرَامْ ذوْڒنْ ذ إِمْسخَّارنْ ن ذَاوُوذْ إِنِّي إِتّْخصَّانْ أَذْ \add أَسْ\add* وْشنْ ثَارْزِيفِينْ \add ذ لْجِيزْيَا\add*. سِيذِي إِڭَّا تَّاسِيعْ إِ ذَاوُوذْ مَانِي مَا إِرُوحْ وَانِيثَا.
\v 7 ذَاوُوذْ يِيوِي ثِيسدَّارِييِينْ \add ن ؤُعسْكَارِي\add* إِقسْحنْ إِ تّْوَاڭّنْثْ س وُورغْ، ثِينِّي ثُوغَا \add إِدْجَانْ\add* ن إِمْسخَّارنْ ن هَاذَاذْ-عَازَارْ ؤُ يِيوْيِي ثنْثْ غَارْ ؤُرْشَالِيمْ.
\v 8 ذَاوُوذْ إِكْسِي أَطَّاسْ ن نّْحَاسْ زِي طَابْحَاثْ ذ خُونْ، ثِيندَّامْ ن هَاذَاذْ-عَازَارْ. زَّايسْ إِڭَّا سُولِيمَانْ ثَارِيمَانْثْ ثَامقّْرَانْثْ ن نّْحَاسْ ذ إِپِيلَارنْ ذ ڒقْشُوعْ ن نّْحَاسْ. \f ◼ \fr 18:‏8 \ft \bd ’ثَارِيمَانْثْ‘\bd* - س ثْعِيبْرَانِيثْ ’ڒبْحَارْ‘ نِيغْ ’إِلْ‘.\f*
\m 
\v 9 \add ؤُمِي\add* ثُوعِي، أَجدْجِيذْ ن حَامَاثْ، إِسْڒَا أَقَا ذَاوُوذْ إِغْڒبْ خْ مَارَّا ڒْعسْكَارْ ن هَاذَاذْ-عَازَارْ، أَجدْجِيذْ ن صُوبَا،
\v 10 إِسّكّْ نتَّا مِّيسْ هَاذُورَامْ غَارْ ؤُجدْجِيذْ ذَاوُوذْ حِيمَا أَذْ إِسّقْسَا خْ ؤُمدُّورْ نّسْ ؤُ حِيمَا أَذْ أَسْ إِبَاركْ، مِينْزِي \add ذَاوُوذْ\add* إِمّْنغْ أَكْ-ذ هَاذَاذْ-عَازَارْ ؤُشَا إِغْڒبْ خَاسْ - مَاغَارْ هَاذَاذْ-عَازَارْ ثُوغَا إِ ثُوعِي ذ إِجّْ ن ورْيَازْ يَارزُّو أَمنْغِي \add ڒبْذَا\add* - ؤُ \add نتَّا يِيوِي أَكِيذسْ\add* عْڒَامْ كُوڒْ ڒقْشُوعْ ن وُورغْ ذ نُّوقَارْثْ ذ نّْحَاسْ.
\v 11 أَجدْجِيذْ ذَاوُوذْ إِسّْقدّسْ إِ-ثنْ إِ سِيذِي، \add جْمِيعْ\add* أَكْ-ذ نُّوقَارْثْ ذ وُورغْ إِ ذ يِيوِي زِي مَارَّا ڒڭْنُوسْ، زِي إِذُومْ، زِي مُوآبَ، ن أَيْثْ ن عَامُّونْ، ن إِفِيلِيسْطِينِييّنْ ؤُ ن \add أَيْثْ ن\add* عَامَالِيقْ.
\m 
\v 12 أَبِيشَايْ، مِّيسْ ن صَارَاوْيَا، إِغْڒبْ خْ إِذُومْ ذِي ثغْزُورْثْ ن ثَامدْجَاحْثْ، ثْمنْطَاشْ-أَڒفْ \add ن يرْيَازنْ\add*.
\v 13 نتَّا إِڭَّا ڒْعسْكَارَاثْ ن ؤُحوّسْ ذِي إِذُومْ أَڒَامِي مَارَّا إِذُومِييّنْ ذوْڒنْ ذ إِمْسخَّارنْ إِ ذَاوُوذْ، ؤُ سِيذِي إِڭَّا تَّاسِيعْ إِ ذَاوُوذْ مَانِي مَا إِفّغْ نتَّا.
\b
\s1 إِمْذبَّارنْ أَكْ-ذ ؤُجدْجِيذْ ذَاوُوذْ
\m 
\v 14 ذَاوُوذْ إِحْكمْ خْ مَارَّا إِسْرَائِيل ؤُ إِڭَّا س ڒْحقّْ ذ ثْسڭْذَا إِ مَارَّا ڒْڭنْسْ نّسْ. \x ◘ \xo 18:‏14 \xt [2 صم. 8‏:‏16‏-‏18؛ 20‏:‏23‏-‏26]\x*
\v 15 يُووَابْ، مِّيسْ ن صَارُويَا، \add ثُوغَا-ث\add* خْ ڒْعسْكَارْ ؤُ يَاهُوشَافَاطْ، مِّيسْ ن أَخِيلُوذْ، \add ثُوغَا-ث ذ\add* أَمَارِيرْ ن ؤُمزْرُويْ.
\m 
\v 16 صَاذُوقْ، مِّيسْ ن أَخِيطُوبْ، ذ أَبِيمَالِيكْ، مِّيسْ ن أَبْيَاثَارْ، ثُوغَا أَثنْ ذ إِكهَّاننْ، ؤُ شَاوْشَا ثُوغَا-ث ذ أَمَارِيرْ.
\m 
\v 17 بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ، \add ثُوغَا-ث خْ\add* إِعسَّاسنْ ن أَرِّيمثْ ؤُ خْ إِرقَّاسنْ ن ثَازْڒَا. أَرَّاونْ ن ذَاوُوذْ \add ثُوغَا أَثنْ\add* ذ إِمزْوُورَا غَارْ ؤُفُوسْ ن ؤُجدْجِيذْ.
\b
\b
\c 19
\s1 أَمنْغِي أَكْ-ذ أَمُونْ ذ أَرَامْ
\m 
\v 1 أَوَارْنِي أَيَا إِمْسَارْ، أَقَا نَاحَاشْ، أَجدْجِيذْ ن أَيْثْ ن عَامُّونْ، إِمُّوثْ. مِّيسْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. \x ◘ \xo 19:‏1 \xt [2 صم. 10‏:‏1‏-‏19]\x*
\v 2 \add خنِّي\add* إِنَّا ذَاوُوذْ: ”نشّْ خْسغْ أَذْ سّشْنغْ ثَامخْسِيوْثْ إِشوَّارنْ إِ حَانُونْ، مِّيسْ ن نَاحَاشْ، أَمْ مَامّشْ ذ أَيِي إِسّْشنْ بَابَاسْ ثَامخْسِيوْثْ إِشوَّارنْ.“ ذَاوُوذْ إِسّكّْ إِرقَّاسنْ، حِيمَا أَذْ ث إِعزَّا خْ \add ڒْْموْثْ ن\add* بَابَاسْ، ؤُشَا إِوْضنْ إِمْسخَّارنْ ن ذَاوُوذْ غَارْ ثمُّورْثْ ن أَيْثْ ن عَامُّونْ.
\v 3 \add خنِّي\add* نَّانْ ڒْحُوكَّامْ ن أَيْثْ ن عَامُّونْ إِ سِيذِي نْسنْ حَانُونْ: ”مَا \add إِخْسْ\add* ذَاوُوذْ أَذْ إِوقَّارْ بَابَاشْ \add س ثِيذتّْ\add* ذِي ثِيطَّاوِينْ نّشْ، مِينْزِي إِسّكّْ-د إِنِّي شكْ إِ غَا إِعزَّانْ؟ مَا وَارْ د-إِسّكّْ ذَاوُوذْ إِمْسخَّارنْ نّسْ غَاركْ، حِيمَا أَذْ أَرْزُونْ ذِي ثمُّورْثْ مَاحنْذْ أَذْ \add ت\add* سّنْقڒْبنْ ؤُ أَذْ \add ت\add* برْڭَاڭنْ؟“
\v 4 \add خنِّي\add* إِطّفْ حَانُونْ إِمْسخَّارنْ ن ذَاوُوذْ، إِحفّْ أَسنْ أَزْينْ زِي ثْمَارْثْ، إِقسّْ أَسنْ أَزْينْ ن وَارُّوضْ أَڒْ ضفَّارْ ؤُشَا إِسّكّْ إِ-ثنْ.
\v 5 نِيثْنِي طّْفنْ \add أَبْرِيذْ\add* ؤُشَا حَاجَانْ \add إِرقَّاسنْ\add* خْ يرْيَازنْ-أَ إِ ذَاوُوذْ. س ؤُينِّي ذ أَسنْ إِسّكّْ، مِينْزِي نِيثْنِي ثُوغَا تّْسضْحَانْ أَطَّاسْ. إِنَّا ؤُجدْجِيذْ: ”قِّيممْ ذِي أَرِيحَا أَڒْ ذ إِ غَا ثمْغَارْ ثْمَارْثْ نْومْ، خنِّي أَذْ د-ثْذوْڒمْ.“
\m 
\v 6 \add ؤُمِي\add* ژْرِينْ أَيْثْ نْ عَامُّونْ بلِّي نِيثْنِي ثُوغَا سَّارْزْڭنْ إِخفْ نْسنْ غَارْ ذَاوُوذْ، إِسّكّْ هَانُونْ ذ أَيْثْ ن عَامُّونْ أَڒفْ ثَالِينْثْ ن نُّوقَارْثْ، حِيمَا أَذْ شْرَانْ إِ يِيخفْ نْسنْ إِكَارُّوثنْ ذ إِمْنَاينْ زِي أَرَامْ-نَاهْرَايْنْ، \add أَقَا-ت ذ مِيسُوپُوثَامْيَا\add*، زِي أَرَامْ-مَاعْكَا ؤُ زِي صُوبَا.
\v 7 نِيثْنِي شْرَانْ إِ يِيخفْ نْسنْ ثْنَاينْ ؤُ-ثْڒَاثِينْ-أَڒفْ ن إِكَارُّوثنْ \add ن ؤُمنْغِي\add* ؤُ \add شْرَانْ عَاوذْ\add* أَجدْجِيذْ ن مَاعْكَا ذ ڒْڭنْسْ نّسْ. نِيثْنِي ؤُسِينْ-د ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ زَّاثْ إِ وُوذمْ ن \add ثنْذِينْثْ ن\add* مَايْذَابَا. \add ؤُڒَا ذ\add* أَيْثْ ن عَامُّونْ نّْيَارْونْ زِي ثْندَّامْ نْسنْ ؤُشَا فّْغنْ غَارْ ؤُمنْغِي.
\v 8 \add ؤُمِي\add* إِسْڒَا ذَاوُوذْ أَيَا، إِسّكّْ يُووَابْ س مَارَّا ڒْعسْكَارْ نّسْ، أَيْثْ ن بُو-ثغْرُوضْثْ.
\v 9 فّْغنْ-د أَيْثْ ن عَامُّونْ ؤُشَا سدّنْ إِخفْ نْسنْ إِ ؤُمنْغِي غَارْ وَاذَافْ ن ثنْذِينْثْ، أَمْ إِجدْجِيذنْ نِّي د-ؤُسِينْ، \add ثُوغَا أَثنْ\add* س وحّذْسنْ ذڭْ إِيَّارْ.
\v 10 \add ؤُمِي\add* إِژْرَا يُووَابْ، أَقَا أَمنْغِي ڒَا زڭْ ؤُرنْذَاذْ ؤُڒَا زِي ضفَّارْ ن ؤُغمْبُوبْ نّسْ، إِخْضَارْ زِي مَارَّا إِنِّي إِتّْوَافَارْزنْ \add ذِي ڒْعسْكَارْ\add* ن إِسْرَائِيل ؤُشَا إِسّْبدّْ إِ-ثنْ \add إِ ؤُمنْغِي\add* أَجمَّاضْ ن أَيْثْ ن أَرَامْ.
\v 11 مِينْ إِقِّيمنْ ن ڒْڭنْسْ إِڭَّا إِ-ثنْ سَاذُو إِ ؤُفُوسْ ن ؤُمَاسْ أَبِيشَايْ ؤُ نِيثْنِي سّْبدّنْ إِخفْ نْسنْ أَجمَّاضْ ن أَيْثْ ن عَامُّونْ.
\v 12 إِنَّا نتَّا: ”مَاڒَا أَرَامْ إِجْهذْ خَافِي، خنِّي أَسْ-د، أوْشْ أَيِي أَفُوسْ! مَاڒَا أَيْثْ ن عَامُّونْ جهْذنْ خَاكْ، خنِّي أَذْ د-أَسغْ أَذْ شكْ فكّغْ.
\v 13 إِڒِي ذ أَرْيَازْ ؤُ أجّْ أَنغْ أَذْ نِيڒِي نمْحضْ ذِي طّْوعْ ن ڒْڭنْسْ نّغْ ؤُ ذِي طّْوعْ ن ثْندَّامْ ن أَربِّي. أَذْ إِڭّْ سِيذِي مِينْ إِدْجَانْ مْلِيحْ ذِي ثِيطَّاوِينْ نّسْ.“
\v 14 \add خنِّي\add* إِبْذَا يُووَابْ ذ ڒْڭنْسْ إِ غَارسْ إِدْجَانْ أَذْ إِمّْنغْ أَكْ-ذ أَيْثْ ن أَرَامْ ؤُشَا إِنَا طّْفنْ ذِي ثَاروْڒَا زَّاثْ إِ وُوذمْ نْسنْ.
\v 15 \add ؤُمِي\add* ژْرِينْ أَيْثْ ن عَامُّونْ، أَقَا أَيْثْ ن أَرَامْ أَروْڒنْ، طّْفنْ ؤُڒَا ذ نِيثْنِي ذِي ثَاروْڒَا زَّاثْ إِ وُوذمْ ن ؤُمَاسْ أَبِيشَايْ ؤُشَاعقْبنْ غَارْ ثنْذِينْثْ. \add خنِّي\add* يِيوضْ يُووَابْ \add غَارْ\add* ؤُرْشَالِيمْ.
\m 
\v 16 \add ؤُمِي\add* إِژْرَا أَرَامْ أَقَا نِيثْنِي تّْوَاوْثنْ زَّاثْ إِ وُوذمْ ن إِسْرَائِيل، سّكّنْ نِيثْنِي إِرقَّاسنْ ؤُشَا ڭِّينْ أَذْ فّْغنْ أَيْثْ ن أَرَامْ إِنِّي \add ثُوغَا إِزدّْغنْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*، ؤُ شُوبَاكْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ ن هَاذَاذْ-عَازَارْ يُويُورْ زَّاثْ إِ ؤُغمْبُوبْ نْسنْ.
\v 17 \add ؤُمِي\add* نَّانْ أَيَا إِ ذَاوُوذْ، إِسّْمُونْ نتَّا مَارَّا إِسْرَائِيل، إِژْوَا لْ-ؤُرْذُونْ، يُوسَا-د غَارْسنْ ؤُشَا إِسدّْ إِخفْ نّسْ إِ ؤُمنْغِي. \add ؤُمِي\add* إِسدّْ ذَاوُوذْ إِخفْ نّسْ إِ ؤُمنْغِي أَكْ-ذ أَيْثْ ن أَرَامْ، مّنْغنْ نِيثْنِي أَكِيذسْ.
\v 18 أَيْثْ ن أَرَامْ أَروْڒنْ زَّاثْ إِ وُوذمْ ن إِسْرَائِيل ؤُشَا إِقْضَا ذَاوُوذْ خْ سبْعَا-أَڒَافْ ن \add ينِّي إِندّْهنْ\add* إِكَارُّوثنْ \add ن ؤُمنْغِي\add* ؤُ خْ أَربْعِينْ-أَڒفْ ن يرَازْ\add أنْ\add* خْ إِضَارنْ زڭْ أَيْثْ ن أَرَامْ. \add عَاوذْ\add* إِنْغَا نتَّا شُوبَاكْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ.
\v 19 \add ؤُمِي\add* ژْرِينْ مَارَّا إِمْسخَّارنْ ن هَاذَاذْ-عَازَارْ، أَقَا تّْوَارْنَانْ زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل، ڭِّينْ نِيثْنِي ڒهْنَا أَكْ-ذ إِسْرَائِيل ؤُشَا سخَّارنْ أَسْ. وَارْ د-يُوسِي ذِي ڒعْقڒْ غَارْ أَيْثْ ن أَرَامْ عَاذْ أَذْ فكّنْ أَيْثْ نْ عَامُّونْ إِشْثْ ن ثْوَاڒَا نّغْنِيثْ.
\b
\b
\c 20
\s1 أَغلّبْ خْ ثنْذِينْثْ ن رَابَّا ن عَامُّونْ
\m 
\v 1 غَارْ ؤُقطُّو ن ؤُسڭّْوَاسْ \add ن جْذِيذْ\add*، ذِي ڒْوقْثْ إِ د إِتّفّْغنْ إِجدْجِيذنْ \add غَارْ ؤُمنْغِي\add*، إِمْسَارْ أَقَا يُووَابْ إِڭوّذْ جّهْذْ ن ڒْعسْكَارْ. يَاردّدْجْ ثَامُّورْثْ ن أَيْثْ ن عَامُّونْ ؤُشَا إِنّضْ إِ رَابَّا، إِحْصَارْ إِ-ت، \add ؤُمِي\add* إِقِّيمْ ذَاوُوذْ ذِي ؤُرْشَالِيمْ. يُووَابْ إِغْڒبْ خْ رَابَّا ؤُشَا إِثحَّا إِ-ت. \x ◘ \xo 20:‏1 \xt [2 صم. 12‏:‏26‏-‏31]\x*
\v 2 ذَاوُوذْ إِكّسْ تَّاجْ ن ؤُجدْجِيذْ خْ ؤُزدْجِيفْ نّسْ، ؤُ نتَّا يُوفَا ڒوْزنْ نّسْ ذ إِشْثْ ن ثَالِينْثْ ن وُورغْ. ثُوغَا خَاسْ ثَايَاقُوثِينْ إِغْڒَانْ. سَّارْسنْ تَّاجْ نِّي خْ ؤُزدْجِيفْ ن ذَاوُوذْ. نتَّا يِيوِي-د \add عَاوذْ\add* ثَاكشَّاضْثْ ذ ثَامقّْرَانْثْ أَطَّاسْ زِي ثنْذِينْثْ. \x ◘ \xo 20:‏2 \xt 2 صم. 12‏:‏30\x*
\v 3 ڒْڭنْسْ نِّي \add إِدْجَانْ\add* ذِي \add ثنْذِينْثْ\add* إِسُّوفّغْ إِ-ث ؤُشَا إِهْجمْ خَاسنْ س ڒْمنْشَارَاثْ ذ إِيَاڒْزِيمنْ ن وُوزَّاڒْ ذ شّْوَاقَارْ ن وُوزَّاڒْ. أَمُّو إِ إِڭَّا ذَاوُوذْ أَكْ-ذ مَارَّا ثِيندَّامْ ن أَيْثْ ن عَامُّونْ. \add خنِّي\add* إِعْقبْ ذَاوُوذْ ذ مَارَّا ڒْڭنْسْ غَارْ ؤُرْشَالِيمْ. \x ◘ \xo 20:‏3 \xt 2 صم. 12‏:‏31\x*
\b
\s1 أَمنْغِي أَكْ-ذ إِفِيلِيسْطِينِييّنْ
\m 
\v 4 أَوَارْنِي أَسْ إِمْسَارْ، أَقَا إِكَّارْ عَاوذْ ؤُمنْغِي أَكْ-ذ إِفِيلِيسْطِينِييّنْ ذِي جَازَارْ. ڒخْذنِّي إِغْڒبْ سَابْكَايْ، أَحُوشَايِي، خْ سَافَّايْ، ونِّي ذ إِجّْ زڭْ وَارَّاونْ ن رَافَا، ؤُشَا تّْوَاسّْوَاضْعنْ نِيثْنِي. \x ◘ \xo 20:‏4 \xt [2 صم. 21‏:‏18‏-‏22]\x*
\m 
\v 5 ثُوغَا ذِينْ عَاوذْ أَمنْغِي أَكْ-ذ إِفِيلِيسْطِينِييّنْ. إِلْحَانَانْ، مِّيسْ ن يَاعِيرْ، إِغْڒبْ خْ لَاحْمِي، ؤُمَاسْ ن جُولِييَاثْ، زِي جَاثْ. أَكشُّوضْ ن لَانْسَا نّسْ إِڭَّا أَمْ يِيجّْ ن وعْمُوذْ ن ؤُكشُّوضْ ن ؤُخيّضْ.
\v 6 ؤُشَا إِكَّارْ عَاوذْ ؤُمنْغِي ذِي جَاثْ. ثُوغَا ذِينْ إِجّْ ن ورْيَازْ ذ أَزِيرَارْ س ستَّا ن إِضوْضَانْ \add ذڭْ إِفَاسّنْ نّسْ\add* ؤُ ستَّا \add ن ثْفذْنِينْ ذڭْ إِضَارنْ نّسْ\add*، \add مَارَّا\add* ڒْقدّْ نْسنْ أَربْعَا ؤُ-عِيشْرِينْ. ؤُڒَا ذ نتَّا إِتّْوَاخْڒقْ-د إِ رَافَا.
\v 7 نتَّا إِسْثهْزَا زِي إِسْرَائِيل، مَاشَا يُونَاثَانْ، مِّيسْ ن شِيمْعَا، ؤُمَاسْ ن ذَاوُوذْ، إِغْڒبْ خَاسْ.
\v 8 إِنَا ذ إِنِّي إِتّْوَاخڒْقنْ-د إِ رَافَا ذِي جَاثْ ؤُ نِيثْنِي وْضَانْ س ؤُفُوسْ ن ذَاوُوذْ ؤُ س ؤُفُوسْ ن إِمْسخَّارنْ نّسْ.
\b
\b
\c 21
\s1 أَحسّبْ ن ڒْڭنْسْ ذ ڒْعِيقَابْ
\m 
\v 1 \add خنِّي\add* إِكَّارْ-د إِجّْ ن وغْرِيمْ خْ إِسْرَائِيل ؤُشَا إِغَارّْ ذَاوُوذْ حِيمَا أَذْ إِحْسبْ إِسْرَائِيل. \x ◘ \xo 21:‏1 \xt [2 صم. 24‏:‏1‏-‏25]\x*
\v 2 ذَاوُوذْ إِنَّا إِ يُووَابْ ؤُ إِ ڒْحُوكَّامْ ن ڒْڭنْسْ: ”ؤُيُورمْ، حسّْبمْ إِسْرَائِيل زِي بِئرْ-سبْعَا أَڒْ ذَانْ ؤُشَا أَوْيمْ أَيِي-د \add مشْحَاڒْ\add*، مَاحنْذْ أَذْ سّْنغْ مشْحَاڒْ إِذْسنْ.“
\v 3 \add خنِّي\add* إِنَّا يُووَابْ: ”إِڒِي أَذْ يَارْنِي سِيذِي ذِي ڒْڭنْسْ نّسْ أَمْ إِدْجَا ڒخُّو عَاذْ مْيَا ن ثْسقَّارْ. مَا وَارْ دْجِينْ مَارَّا، \add أَ\add* سِيذِي إِنُو أَجدْجِيذْ، ذ إِمْسخَّارنْ ن سِيذِي إِنُو؟ مَايمِّي \add إِ زَّايِي\add* إِتّْمژْرِي سِيذِي إِنُو مَانْ أَيَا؟ مَايمِّي غَا إِسَّارْبُو إِسْرَائِيل أَمَارْوَاسْ خْ يِيخفْ نّسْ؟“
\v 4 \add مَاشَا\add* أَوَاڒْ ن ؤُجدْجِيذْ إِجْهذْ خْ يُووَابْ ؤُ يُووَابْ إِفّغْ. إِكَّا مَارَّا إِسْرَائِيل ؤُشَا إِعْقبْ-د غَارْ ؤُرْشَالِيمْ.
\v 5 يُووَابْ إِوْشَا إِ ذَاوُوذْ ڒْقدّْ ن ڒحْسَابْ ن ڒْڭنْسْ أَمْ إِكْمڒْ. مَارَّا إِسْرَائِيل \add ذَايسْ\add* مِيلْيُونْ ؤُ-مْيَا-أَڒفْ ن يرْيَازنْ إِنِّي إِزمَّارنْ خْ سِّيفْ ؤُ يَاهُوذَا \add ذَايسْ\add* أَربْعَا-مْيَا ؤُ-سبْعِينْ-أَڒفْ ن يرْيَازنْ نِّي إِزمَّارنْ خْ سِّيفْ.
\v 6 \add مَاشَا أَيْثْ ن\add* لَاوِي ذ بِينْيَامِينْ وَارْ ثنْ إِحْسِيبْ شَا، مَاغَارْ أَوَاڒْ ن ؤُجدْجِيذْ ثُوغَا ذ أَعِيفِّي إِ يُووَابْ.
\m 
\v 7 ثَامسْڒَاشْثْ-أَ ثُوغَا ذ ثَاعفَّانْثْ ذِي ثِيطَّاوِينْ ن أَربِّي ؤُشَا نتَّا إِڒْقفْ إِسْرَائِيل س إِشْثْ ن جّْرِيحشْثْ.
\v 8 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ أَربِّي: ”نشّْ خْضِيغْ \add خَاكْ\add* أَطَّاسْ، س مِينْزِي نشّْ ڭِّيغْ أَيَا. خنِّي ڒخُّو، كّسْ ڒْمُوعْصِييّثْ خْ ؤُمْسخَّارْ نّشْ، مِينْزِي نشّْ ڭِّيغْ س ثُوبُّوهڒْيَا أَطَّاسْ.“
\v 9 إِسِّيوڒْ سِيذِي غَارْ جَاذْ، أَمْوَاڒَاوْ ن ذَاوُوذْ، إِنَّا:
\v 10 ”ؤُيُورْ، سِيوڒْ غَارْ ذَاوُوذْ، إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي: أَذْ أَشْ سَّارْسغْ ثْڒَاثَا ن ثْمسْڒَايِينْ. إِخْضَارْ إِشْثْ \add زَّايْسنْثْ\add* إِ شكْ. أَذْ أَشْ ت ڭّغْ.‘ “
\v 11 جَاذْ يُوسَا-د غَارْ ذَاوُوذْ، إِنَّا أَسْ: ’أَمُّو إِ إِقَّارْ سِيذِي: ’إِخْضَارْ شكْ:
\v 12 ثْڒَاثَا ن إِسڭّْوُوسَا ن ڒَاژْ، نِيغْ ثْڒَاثَا ن إِيُورنْ إِ ذِي إِ غَا ثتّْوَاهلّْكذْ زَّاثْ إِ وُوذمْ ن يِينِّي شكْ إِحْصَارنْ ؤُ سِّيفْ ن ڒْعذْيَانْ نّشْ أَذْ شكْ إِضْفَارْ، نِيغْ ثْڒَاثَا ن وُوسَّانْ ن سِّيفْ ن سِيذِي، أَقَا-ث ذ طَّاعُونْ ذِي ثمُّورْثْ ؤُ لْمَالَاكْ ن سِيذِي أَذْ إِضيّعْ مَارَّا ثَامُّورْثْ ن إِسْرَائِيل. خنِّي ڒخُّو، خْزَارْ، مَامّشْ غَا يَارّغْ خْ ونِّي ذ أَيِي د-إِسّكّنْ.‘ “
\v 13 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ جَاذْ: ”نشّْ تّْوَاحْصَارغْ أَطَّاسْ، \add مَاشَا\add* أجّْ أَيِي أَذْ وْضِيغْ ذڭْ ؤُفُوسْ ن سِيذِي، مَاغَارْ أَرّحْمثْ نّسْ ذ ثَامقّْرَانْثْ أَطَّاسْ، وَارْ تّڭّْ أَذْ وْضِيغْ ذڭْ ؤُفُوسْ ن بْنَاذمْ.“
\m 
\v 14 ؤُشَا إِسِّيوضْ سِيذِي طَّاعُونْ خْ إِسْرَائِيل ؤُشَا وْضَانْ سبْعِينْ-أَڒفْ ن يرْيَازنْ زِي إِسْرَائِيل.
\v 15 إِسّكّْ أَربِّي لْمَالَاكْ غَارْ ؤُرْشَالِيمْ حِيمَا أَذْ ث إِضيّعْ. ؤُمِي إِبْذَا نتَّا أَذْ ت إِضيّعْ، إِژْرَا إِ-ت سِيذِي ؤُشَا إِنْذمْ خْ ثُوعفّْنَا، إِنَّا إِ لْمَالَاكْ ن ؤُضيّعْ: ”شْفَا، سهْوَا ڒخُّو أَفُوسْ نّشْ!“ ثُوغَا لْمَالَاكْ ن سِيذِي إِبدّْ غَارْ ؤُنذْرَارْ ن ؤُيابُوسِي ؤُرْنَانْ.
\m 
\v 16 \add ؤُمِي\add* إِسّْڭعّذْ ذَاوُوذْ ثِيطَّاوِينْ نّسْ، إِژْرَا لْمَالَاكْ ن سِيذِي إِبدّْ جَارْ ثمُّورْثْ ذ ؤُجنَّا أَمْ إِطّفْ ؤُفُوسْ نّسْ سِّيفْ، إِسّْوِيژّضْ إِ-ث خْ ؤُرْشَالِيمْ. \add خنِّي\add* إِوْضَا ذَاوُوذْ ذ إِمقّْرَاننْ نْ ڒْڭنْسْ س ؤُغمْبُوبْ نْسنْ \add غَارْ ثمُّورْثْ\add* أَمْ ثُوغَا ڒحّْفنْ س ثْخُونْشَايْ \add ن وشْضَانْ\add*.
\v 17 ؤُشَا إِنَّا ذَاوُوذْ إِ أَربِّي: ”مَا وَارْ إِدْجِي ذ نشّْ إِ إِنَّانْ أَقَا إِتّْخصَّا أَذْ حسْبنْ ڒْڭنْسْ؟ وَاهْ، ذ نشّْ إِ ثُوغَا إِخْضَانْ ذ نشّْ إِ إِڭِّينْ ڒْمُوعْصِييّثْ أَطَّاسْ، مَاشَا ؤُدْجِي-يَا، مِينْ ڭِّينْثْ؟ \add أَ\add* سِيذِي، أَربِّي إِنُو، أجّْ أَذْ يِيڒِي ؤُفُوسْ نّشْ إِ ثشْثِي غَارِي ؤُ غَارْ ثَادَّارْثْ ن بَابَا، وَارْ إِدْجِي مَاشَا غَارْ ڒْڭنْسْ نّشْ.“
\b
\s1 أَمْشَانْ ن ثَادَّارْثْ ن سِيذِي أَربِّي
\m 
\v 18 \add خنِّي\add* إِنَّا لْمَالَاكْ ن سِيذِي إِ جَاذْ، أَذْ يِينِي إِ ذَاوُوذْ بلِّي إِتّْخصَّا إِ ذَاوُوذْ أَذْ إِڭعّذْ حِيمَا أَذْ إِسّْبدّْ إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي خْ ؤُنذْرَارْ ن ؤُيابُوسِي أَرْنَانْ.
\v 19 ؤُشَا ذَاوُوذْ إِڭعّذْ عْلَاحْسَابْ أَوَاڒْ ن جَاذْ نِّي إِسِّيوڒْ س يِيسمْ ن سِيذِي.
\m 
\v 20 ؤُشَا إِنّقْڒبْ-د أَرْنَانْ، إِژْرَا لْمَالَاكْ. أَربْعَا ن وَارَّاونْ نّسْ إِ ثُوغَا غَارسْ \add إِدْجَانْ\add*، نُّوفَّارنْ. ؤُرْنَانْ ثُوغَا إِسَّارْوَاثْ إِرْذنْ.
\m 
\v 21 يِيوضْ ذَاوُوذْ غَارْ أَرْنَانْ ؤُشَا إِسّْڭعّذْ أَرْنَانْ ثِيطَّاوِينْ، إِژْرَا ذَاوُوذْ. \add خنِّي\add* إِفّغْ-د زڭْ ؤُنذْرَارْ ؤُشَا إِبنْذقْ زَّاثْ إِ ذَاوُوذْ س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ.
\v 22 إِنَّا ذَاوُوذْ إِ أَرْنَانْ: ”أوْشْ أَيِي أَنْذْرَارْ، حِيمَا أَذْ خَاسْ بْنِيغْ إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي. أوْشْ أَيِي \add أَمْشَانْ\add* س تَّامَانْ نّسْ إِمُونْ، حِيمَا أَذْ ثْبدّْ ثِيشْثِي-يَا ذِي ڒْڭنْسْ.“
\v 23 أَرْنَانْ إِنَّا إِ ذَاوُوذْ: ”كْسِي ث إِ شكْ ؤُشَا أَذْ يڭّْ سِيذِي إِنُو أَجدْجِيذْ مِينْ إِدْجَانْ ذ لمْلِيحْ ذِي ثِيطَّاوِينْ نّسْ. خْزَارْ، أَذْ وْشغْ إِفُونَاسنْ-أَ أَمْ ثْغَارْصَا ن وشْمَاضْ، ؤُ ثِيڒْوِيحِينْ إِتّحْڒُودْجُوضنْ إِ ؤُسَارْوثْ ذ ؤُكشُّوضْ \add إِ ثْمسِّي\add* ذ إِرْذنْ، أَذْ ثنْ وْشغْ إِ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*. نشّْ أَذْ وْشغْ أَيَا مَارَّا.“
\v 24 \add مَاشَا\add* إِنَّا ؤُجدْجِيذْ ذَاوُوذْ إِ أَرْنَانْ: ”لَّ، نشّْ خْسغْ نِيشَانْ أَذْ ث سْغغْ س تَّامَانْ نّسْ إِكْمڒْ، مِينْزِي مِينْ إِدْجَانْ نّشْ وَارْ ث كسِّيغْ إِ سِيذِي، \add حِيمَا\add* \add أَمُّو إِ\add* غَا وهّْبغْ ثَاغَارْصْثْ ن وشْمَاضْ إِ سِيذِي بْڒَا أَذْ ت خدْجْصغْ.“
\v 25 أَمُّو إِ إِوْشَا ذَاوُوذْ إِ أَرْنَانْ إِ ومْشَانْ نِّي إِجّْ ن ڒوْزنْ ن ستَّا-مْيَا شِيقْلُو ن وُورغْ.
\v 26 ذَاوُوذْ إِسّْبدّْ ذِينِّي إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي ؤُشَا يِيوِي خَاسْ ثِيغَارْصَا ن وشْمَاضْ ذ ثوْهِيبِينْ \add ن ڒْغِيدْجثْ\add*. نتَّا إِڒَاغَا إِ سِيذِي ؤُ وَانِيثَا يَارَّا-د خَاسْ س ثْمسِّي زڭْ ؤُجنَّا خْ ؤُعَالْطَارْ ن وشْمَاضْ.
\v 27 إِنَّا سِيذِي إِ لْمَالَاكْ مَاحنْذْ ذ يَارّْ سِّيفْ ذڭْ ؤُفُورُّو ن وغْڒَافْ نّسْ.
\m 
\v 28 ذِي ڒْوقْثْ نِّي، ؤُمِي إِژْرَا ذَاوُوذْ أَقَا سِيذِي يَارَّا-د خَاسْ خْ ؤُنذْرَارْ ن ؤُيابُوسِي أَرْنَانْ، يِيوِي \add ذِينْ\add* ثِيغَارْصَا.
\v 29 ذِي ڒْوقْثْ نِّي ثُوغَا ثَازذِّيغْثْ ن سِيذِي، ثنِّي ثُوغَا إِڭَّا مُوسَا ذِي ڒخْڒَا، ذ ؤُعَالْطَارْ إِ ثْغَارْصَا ن وشْمَاضْ خْ ڒْڭعّْذثْ ن جِيبْعُونْ.
\v 30 ذَاوُوذْ \add مَاشَا\add* وَارْ إِزمَّارْ أَذْ ذِينْ يُويُورْ حِيمَا أَذْ يَارْزُو خْ أَربِّي، مَاغَارْ ثُوغَا ثڒْقفْ إِ-ث ثِيڭّْوُوذِي زِي سِّيفْ ن لْمَالَاكْ ن سِيذِي.
\b
\b
\c 22
\s1 أَسوْجذْ إِ ڒبْنِي ن زَّاوشْثْ ثَامقّْرَانْثْ
\m 
\v 1 إِنَّا ذَاوُوذْ: ”ذَا \add إِ غَا ثْبدّْ\add* ثَادَّارْثْ ن سِيذِي أَربِّي، ؤُ ذَا \add إِ غَا يِيڒِي\add* ؤُعَالْطَارْ ن ثْغَارْصَا ن وشْمَاضْ إِ إِسْرَائِيل.“
\v 2 يُومُورْ ذَاوُوذْ أَذْ سّْمُوننْ إِبَارَّانِييّنْ نِّي إِدْجَانْ ذِي ثمُّورْثْ ن إِسْرَائِيل، ؤُ نتَّا إِڭَّا إِسُويْذَاينْ حِيمَا أَذْ سُّويْذَانْ إِژْرَا إِ ڒبْنِي ن ثَادَّارْثْ ن أَربِّي. \f ◼ \fr 22:‏2 \ft \bd ’يُومُورْ‘\bd* - س ثْعِيبْرَانِيثْ ’إِنَّا‘.\f*
\v 3 ذَاوُوذْ إِسّوْجذْ أَطَّاسْ ن وُوزَّاڒْ إِ ڒوْثَاذَاثْ إِ ثوُّورَا ن وَاذَافْ ؤُ إِ ثْحنْيَا ن ؤُعَارّضْ ؤُڒَا ذ وَاطَّاسْ ن نّْحَاسْ، \add أَڒَامِي\add* وَارْ إِزمَّارْ أَذْ إِتّْوَاوْزنْ ڒْقدّْ نّسْ،
\v 4 ؤُڒَا ذ أَكشُّوضْ نْ ثنْڭلْثْ، س إِجّْ ن ڒْقدّْ وَارْ إِزمَّارْ أَذْ إِتّْوَاحْسبْ، مِينْزِي أَيْثْ ن صِيذُونْ ذ أَيْثْ ن صُورْ سِّيوْضنْ أَطَّاسْ ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ غَارْ ذَاوُوذْ.
\v 5 ذَاوُوذْ إِنَّا: ”مِّي سُولِيمَانْ \add عَاذْ\add* ذ أَحُوذْرِي أَرْهفْ. ثَادَّارْثْ إِ غَا بْنَانْ إِ سِيذِي أَذْ ثِيڒِي ذ ثَامقّْرَانْثْ ذ إِسّْعُودْجنْ حِيمَا إِسمْ \add نّسْ\add* ذ ڒْعزّْ نّسْ أَذْ إِذْوڒْ غَارْ مَارَّا ثِيمُّورَا. نشّْ أَذْ أَسْ سّْوجْذغْ.“ أَمُّو إِ إِسّوْجذْ ذَاوُوذْ أَطَّاسْ قْبڒْ إِ ڒْموْثْ نّسْ.
\m 
\v 6 \add خنِّي\add* إِڒَاغَا نتَّا إِ مِّيسْ سُولِيمَانْ ؤُشَا يُومُورْ إِ-ث حِيمَا أَذْ إِبْنَا إِشْثْ ن ثَادَّارْثْ إِ سِيذِي، أَربِّي ن إِسْرَائِيل.
\v 7 إِنَّا ذَاوُوذْ إِ سُولِيمَانْ: ”مِّي، نشّْ سِيمَانْثْ إِنُو ثُوغَا-ث ذڭْ وُوڒْ إِنُو، حِيمَا أَذْ بْنِيغْ إِشْثْ ن ثَادَّارْثْ إِ يِيسمْ ن سِيذِي، أَربِّي إِنُو.
\v 8 \add مَاشَا\add* يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا: ’شكْ ثسِّيزّْڒذْ أَطَّاسْ ن إِذَامّنْ ؤُ ثڭِّيذْ إِمنْغَانْ إِقسْحنْ. شكْ وَارْ ثْبنِّيذْ إِ يِيسمْ إِنُو ثَادَّارْثْ، مَاغَارْ شكْ ثسِّيزّْڒذْ زَّاثْ إِ وُوذمْ إِنُو أَطَّاسْ ن إِذَامّنْ خْ ثمُّورْثْ.
\v 9 خْزَارْ، مِّيشْ ونِّي إِ ذ أَشْ غَا د-إِتّْوَارْونْ، أَذْ يِيڒِي ذ إِجّْ ن ورْيَازْ ن ڒْحُوذْنثْ، مَاغَارْ نشّْ أَذْ أَسْ وْشغْ ڒْهُوذْنثْ زِي مَارَّا ڒْعذْيَانْ نّسْ إِ ذ أَسْ د-إِنّْضنْ، مَاغَارْ إِسمْ نّسْ أَذْ يِيڒِي سُولِيمَانْ ؤُ ذڭْ وُوسَّانْ نّسْ أَذْ وْشغْ ڒهْنَا ذ ڒْهُوذْنثْ إِ إِسْرَائِيل.
\v 10 نتَّا أَذْ إِبْنَا إِشْثْ ن ثَادَّارْثْ إِ يِيسمْ إِنُو ؤُ نتَّا أَذْ يِيڒِي إِ نشّْ ذ مِّيسْ ؤُ نشّْ أَذْ أَسْ إِڒِيغْ ذ بَابَاسْ ؤُ نشّْ أَذْ سّْمثْنغْ ڒْعَارْشْ ن ثْڭلْذَا نّسْ خْ إِسْرَائِيل إِ ڒبْذَا.‘
\v 11 خنِّي ڒخُّو، \add أَ\add* مِّي، سِيذِي أَذْ يِيڒِي أَكِيذكْ ؤُ شكْ أَذْ ثْفڒْحذْ ؤُ أَذْ ثبْنِيذْ ثَادَّارْثْ ن سِيذِي، أَربِّي نّشْ، أَمْ مَامّشْ ثُوغَا خَاكْ إِسِّيوڒْ.
\v 12 إِڒِي أَذْ أَشْ إِوْشْ سِيذِي ڒعْقڒْ ذ ڒفْهَامثْ ؤُڒَا ذ ؤُسُويَارْ خْ إِسْرَائِيل حِيمَا أَذْ ثحْضِيذْ شَّارِيعَا ن سِيذِي، أَربِّي نّشْ.
\v 13 خنِّي أَذْ ثِيڒِيذْ ثْفڒْحذْ، خْمِي غَا ثحْضِيذْ حِيمَا أَذْ ڭّنْ ثِيوصَّا ذ لْفَارَايِيضْ، ثِينِّي يُومُورْ سِيذِي س مُوسَا إِ إِسْرَائِيل. إِڒِي ذ أَرْيَازْ ؤُ إِڒِي ثْمحْضذْ، وَارْ تّڭّْوذْ شَا ؤُ وَارْ ثفْشِيڒْ!
\m 
\v 14 خْزَارْ-د، ذِي ڒحْصَارثْ إِنُو سّْوجْذغْ غَارْ ؤُفُوسْ إِ ثَادَّارْثْ ن سِيذِي مْيَاثْ-أَڒفْ ثَالِينْثْ ن وُورغْ ذ وَاڒفْ خْ وَاڒفْ ثَالِينْثْ ن نُّوقَارْثْ ؤُڒَا ذ نّْحَاسْ ذ وُوزَّاڒْ، أَڒَامِي وَارْ زمَّارنْ أَذْ وزْننْ. إِوْيغْ ؤُڒَا ذ أَكشُّوضْ ذ يژْرَا. ؤُ شكْ أَذْ خَاسْ ثَارنْيذْ عَاذْ.
\v 15 شكْ غَاركْ \add عَاوذْ\add* أَطَّاسْ \add ن يرْيَازنْ\add* حِيمَا أَذْ ڭّنْ ڒْخذْمثْ، إِسُويْذَاينْ ذ ڒمْعُودْجَامْ إِ \add ؤُنقَّاشْ ن\add* وژْرُو ذ ؤُكشُّوضْ ذ عْڒَامْ كُوڒْ \add إِوْذَانْ\add* نِّي غَارْ ثدْجَا ڒفْهَامثْ ذِي عْڒَامْ كُوڒْ ڒْخذْمثْ.
\v 16 ؤُرغْ ذ نُّوقَارْثْ ذ نّْحَاسْ ذ وُوزَّاڒْ أَنشْثْ وَارْ إِزمَّارْ أَذْ ث حسْبنْ. كَّارْ، أڭّْ إِ-ث ؤُشَا سِيذِي أَذْ كِيذكْ يِيڒِي.“
\m 
\v 17 ذَاوُوذْ يُومُورْ \add عَاوذْ\add* إِ مَارَّا ڒْحُوكَّامْ ن إِسْرَائِيل، مَاحنْذْ أَذْ وْشنْ أَفُوسْ إِ مِّيسْ سُولِيمَانْ، إِنَّا:
\v 18 ”مَا وَارْ إِدْجِي سِيذِي، أَربِّي نْومْ، أَكِيذْومْ ؤُ \add مَا وَارْ\add* ذ أَومْ إِوْشِي ڒْهُوذْنثْ غَارْ مَارَّا إِغزْذِيسنْ نْومْ؟ مَاغَارْ نتَّا إِڭَّا مَارَّا إِمزْذَاغْ ن ثمُّورْثْ ذڭْ ؤُفُوسْ إِنُو ؤُشَا ثتّْوَاڭّْ ثمُّورْثْ سَاذُو ؤُفُوسْ \add إِنُو\add* زَّاثْ إِ وُوذمْ ن سِيذِي ؤُ زَّاثْ إِ وُوذمْ ن مَارَّا ڒْڭنْسْ.
\v 19 \add خنِّي\add* ڒخُّو، وْشمْ ؤُڒْ ذ ڒعْمَارْ \add نْومْ\add* حِيمَا أَذْ ثَارْزُومْ خْ سِيذِي، أَربِّي نْومْ، ؤُشَا كَّارمْ، أَذْ ثبْنَامْ زَّاوشْثْ إِقدّْسنْ ن سِيذِي أَربِّي حِيمَا تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي ذ مَارَّا ڒقْشُوعْ إِقدّْسنْ ن أَربِّي زمَّارنْ أَذْ تّْوَاسِّيذْفنْ ذِي ثَادَّارْثْ إِ غَا إِتّْوَابْنَانْ إِ يِيسمْ ن سِيذِي.“
\b
\b
\c 23
\s1 ذَاوُوذْ إِذبَّارْ ڒْخذْمثْ ن إِلَاوِييّنْ
\m 
\v 1 \add ؤُمِي\add* ثُوغَا ذَاوُوذْ إِوْسَارْ ؤُ إِجِّيونْ ؤُسَّانْ، إِڭَّا نتَّا مِّيسْ سُولِيمَانْ ذ أَجدْجِيذْ خْ إِسْرَائِيل.
\v 2 نتَّا إِسّْمُونْ-د مَارَّا ڒْحُوكَّامْ ن إِسْرَائِيل ؤُڒَا ذ إِكهَّاننْ ذ إِلَاوِييّنْ.
\v 3 تّْوَاحسْبنْ إِلَاوِييّنْ زِي ثْڒَاثِينْ ن إِسڭّْوُوسَا ذ سنّجْ. \add ثُوغَا\add* ڒْقدّْ نْسنْ أَزدْجِيفْ أَزدْجِيفْ ثْمنْيَا ؤُ-ثْڒَاثِينْ-أَڒفْ ن يرْيَازنْ.
\v 4 زَّايْسنْ \add ثُوغَا ذِينْ\add* أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ ن يِينِّي إِتّْوَاڭّنْ ذ إِمْسيَّارنْ خْ ڒْخذْمثْ ذِي ثَادَّارْثْ ن سِيذِي ؤُشَا \add أَقَا ذِينْ عَاذْ\add* ستَّا-أَڒَافْ ن إِمحْضَاينْ ذ ڒْقُوضَاثْ،
\v 5 أَربْعَا-أَڒَافْ ن إِعسَّاسنْ ن ثوَّارْثْ ذ أَربْعَا-أَڒَافْ ن إِمذْيَازنْ إِ إِژْرَانْ ن ؤُصبَّاحْ إِ سِيذِي، أَكْ-ذ دُّوزَانَاثْ \add ن لْمُوسِيقَا\add* نِّي ڭِّيغْ نشّْ، \add إِنَّا ذَاوُوذْ\add*، حِيمَا أَذْ سّمْغَارنْ \add سِيذِي\add* س يزْڒَانْ ن ؤُصبَّاحْ.
\b
\m 
\v 6 ذَاوُوذْ إِبْضَا ثنْ ذِي ثرْبِيعِينْ، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ أَرَّاونْ ن لَاوِي: جَارْشُونْ، قَاهَاثْ ذ مَارَارِي.
\b
\m 
\v 7 زڭْ \bd إِجَارْشُونِييّنْ\bd* \add ثُوغَا أَثنْ ذ\add* لَاعْذَانْ ذ شِيمْعِي.
\m 
\v 8 أَرَّاونْ ن لَاعْذَانْ \add ثُوغَا أَثنْ ذ\add* أَزدْجِيفْ يَاحِييِيلْ، زِيثَامْ ذ يُووِيلْ، ثْڒَاثَا \add ن يرْيَازنْ\add*.
\m 
\v 9 أَرَّاونْ ن شِيمْعِي \add ثُوغَا أَثنْ ذ\add* شَالُومِيثْ، حَازِييِيلْ ذ هَارَانْ، ثْڒَاثَا \add ن يرْيَازنْ\add*. إِنَا \add ثُوغَا أَثنْ ذ\add* إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ن لَاعْذَانْ.
\m 
\v 10 أَرَّاونْ ن شِيمْعِي \add ثُوغَا أَثنْ ذ\add* يَاحَاثْ، زَايْنَا، يَاعُوشْ ذ بَارِيعَا. إِنَا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن شِيمْعِي.
\m 
\v 11 يَاحَاثْ ثُوغَا-ث ذ أَزدْجِيفْ ؤُ زِيزَا ذ وِيسّْ ثْنَاينْ، \add مَاشَا\add* يَاعُوشْ ذ بَارِيعَا وَارْ ثُوغِي غَارْسنْ أَرَّاونْ أَطَّاسْ. غَارْ ڒحْسَابْ تّْوَاحسْبنْ نِيثْنِي ذ إِشْثنْ ثَادَّارْثْ ن إِبَابَاثنْ.
\b
\m 
\v 12 \bd أَرَّاونْ ن قَاهَاثْ\bd* \add ثُوغَا أَثنْ ذ\add* عَامْرَامْ، يِيصْهَارْ، حَابْرُونْ ذ عُوزِّييِيلْ، أَربْعَا \add ن يرْيَازنْ\add*.
\m 
\v 13 أَرَّاونْ ن عَامْرَامْ \add ثُوغَا أَثنْ ذ\add* هَارُونْ ذ مُوسَا.
\m إِتّْوَاعْزڒْ هَارُونْ حِيمَا أَذْ إِتّْوَاقدّسْ ذ أَمْقدّسْ قَاعْ، نتَّا ذ أَرَّاونْ نّسْ، إِ ڒبْذَا، حِيمَا أَذْ إِسّْبخَّارْ زَّاثْ إِ وُوذمْ ن سِيذِي، حِيمَا أَذْ أَسْ إِسخَّارْ ؤُ حِيمَا أَذْ إِبَاركْ س يِيسمْ نّسْ إِ ڒبْذَا.
\m 
\v 14 أَرَّاونْ ن مُوسَا، أَرْيَازْ ن أَربِّي، تّْوَاڒَاغَانْ جَارْ ثقْبِيتْشْ ن لَاوِي.
\v 15 أَرَّاونْ ن مُوسَا \add ثُوغَا أَثنْ ذ\add* جَارْشُومْ ذ إِلِيعَازَارْ.
\m 
\v 16 \add زڭْ\add* وَارَّاونْ ن جَارْشُونْ \add ثُوغَا\add* شابُووِيلْ ذ أَزدْجِيفْ.
\m 
\v 17 مِّيسْ ن إِلِيعَازَارْ \add ثُوغَا\add* ذ أَزدْجِيفْ رَاحَابْيَا. وَارْ ثُوغِي غَارسْ غَارْ إِلِيعَازَارْ أَرَّاونْ نّغْنِي. أَرَّاونْ ن رَاحَابْيَا \add مَاشَا\add* \add ثُوغَا أَثنْ\add* ذڭْ وَاطَّاسْ.
\m 
\v 18 \add زڭْ\add* وَارَّاونْ ن يِيصْهَارْ \add ثُوغَا\add* شَالُومِيثْ ذ أَزدْجِيفْ.
\m 
\v 19 \add زڭْ\add* وَارَّاونْ ن حَابْرُونْ \add ثُوغَا\add* يَارِييَا ذ أَزدْجِيفْ، أَمَارْيَا وِيسّْ ثْنَاينْ، يَاحْزِييِيلْ وِيسّْ طْرَاثَا ذ يَاقْمَاعَامْ وِيسّْ أَربْعَا.
\m 
\v 20 \add زڭْ\add* وَارَّاونْ ن عُوزِّييِيلْ \add ثُوغَا\add* مِيخَا ذ أَزدْجِيفْ، ؤُ يَاشِّي-يَاهْ وِيسّْ ثْنَاينْ.
\b
\m 
\v 21 \bd أَرَّاونْ ن مَارَارِي\bd* \add ثُوغَا أَثنْ ذ\add* مَاحْلِي ذ مُوشِي.
\m ثَارْوَا ن مَاحْلِي \add ثُوغَا أَثنْ ذ\add* أَلِيعَازَارْ ذ قِيسْ.
\v 22 أَلِيعَازَارْ إِمُّوثْ ؤُ نتَّا وَارْ غَارسْ ثُوغِي بُو وَارَّاونْ مَاشَا يسِّيسْ \add وَاهْ\add*. أَرَّاونْ ن قِيسْ، أَيْثْمَاثْسنْ، إِوْينْ ثنْثْ \add ذ ثَامْغَارْثْ\add*.
\m 
\v 23 أَرَّاونْ ن مُوشِي \add ثُوغَا أَثنْ ذ\add* مَاحْلِي ذ عَاذِيرْ ذ يَارِيمُوثْ، ثْڒَاثَا \add ن يرْيَازنْ\add*.
\b
\m 
\v 24 إِنَا \add ثُوغَا أَثنْ\add* ذ أَرَّاونْ ن لَاوِي، \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، عْلَاحْسَابْ إِزدْجِيفنْ ن ڒَادْجَاثْ، إِنِّي \add إِتّْوَازمّنْ\add* غَارْ ڒحْسَابْ نْسنْ س ڒْقدّْ ن إِسْمَاونْ نْسنْ أَزدْجِيفْ أَزدْجِيفْ، إِنِّي إِڭِّينْ ثَاسخَّارْثْ إِ ثَادَّارْثْ ن سِيذِي، زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ.
\v 25 مَاغَارْ ذَاوُوذْ ثُوغَا إِنَّا: ”سِيذِي، أَربِّي ن إِسْرَائِيل، إِوْشَا ڒْهُوذْنثْ إِ ڒْڭنْسْ نّسْ ؤُ نتَّا أَذْ إِزْذغْ ذِي ؤُرْشَالِيمْ إِ ڒبْذَا.“
\v 26 \add نتَّا إِنَّا\add* عَاوذْ خْ إِلَاوِييّنْ: ”نِيثْنِي وَارْ حْذِيجنْ عَاذْ أَذْ أَرْبُونْ ثَازذِّيغْثْ ذ مَارَّا ڒقْشُوعْ نِّي د إِتَّاسنْ أَكْ-ذ ثْسخَّارْثْ.“
\v 27 مِينْزِي عْلَاحْسَابْ أَوَاڒنْ إِنڭُّورَا ن ذَاوُوذْ، \add ثُوغَا\add* ڒْقدّْ ن وَارَّاونْ ن لَاوِي ذ إِنِّي \add إِدْجَانْ\add* زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ.
\v 28 نِيثْنِي بدّنْ أَكْ-ذ وَارَّاونْ ن هَارُونْ ذِي ثْسخَّارْثْ ذِي ثَادَّارْثْ ن سِيذِي، \add غَارْ ؤُحطُّو\add* خْ ڒمْرَاحَاثْ، خْ إِخَّامنْ ن ڒخْزنْ، خْ ؤُسِيزْذڭْ ن مَارَّا ڒقْشُوعْ إِقدّْسنْ، خْ ڒْخذْمثْ ن ثْسخَّارْثْ ذِي ثَادَّارْثْ ن أَربِّي،
\v 29 خْ \add ؤُسوْجذْ ن\add* أَغْرُومْ ن وسْشَانْ، خْ وَارنْ أَزْذَاذْ إِ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*، خْ ثڒْفَافْ بْڒَا أَنْثُونْ، خْ وخْذِيمْ ؤُ خْ \add مَامّشْ ڭّْوِينْ\add* أَرشْثِي ؤُ خْ مَارَّا ڒْقدّْ ذ ڒقْيَاسْ.
\v 30 ثُوغَا إِتّْخصَّا أَذْ بدّنْ \add وجْذنْ\add* ذِي كُوڒْ ثُوفُّوثْ حِيمَا أَذْ صبّْحنْ ؤُ أَذْ سّمْغَارنْ سِيذِي، ؤُڒَا غَارْ ثْمذِّيثْ،
\v 31 ؤُڒَا ڒَامِي د-يِيوْينْ مَارَّا ثِيغَارْصَا ن وشْمَاضْ إِ سِيذِي، ذڭْ وُوسَّانْ ن سّبْثْ، ذڭْ وُوسَّانْ ن ؤُيُورْ ن جْذِيذْ ؤُ ذِي ڒعْيُوذَاثْ إِتّْوَاڭّنْ، عْلَاحْسَابْ ڒْقدّْ إِ يدْجَا ذِي لْفَارِيضَا إِ ذ أَسْ إِتّْڒِيقَانْ، بْڒَا \add أَ\add*قطُّو زَّاثْ إِ وُوذمْ ن سِيذِي.
\v 32 إِتّْخصَّا أَسنْ أَذْ حْضَانْ ثَاوقَّافْثْ نْسنْ إِ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ذ ثْوقَّافْثْ نْسنْ إِ زَّاوشْثْ إِقدّْسنْ ذ ثْوقَّافْثْ \add نْسنْ\add* غَارْ ؤُغزْذِيسْ ن وَارَّاونْ ن هَارُونْ، أَيْثْمَاثْسنْ، غَارْ ثْسخَّارْثْ ن ثَادَّارْثْ ن سِيذِي.
\b
\b
\c 24
\s1 ثِيرْبِيعِينْ ن إِكهَّاننْ
\m 
\v 1 ثِيرْبِيعِينْ ن وَارَّاونْ ن هَارُونْ. أَرَّاونْ ن هَارُونْ \add ثُوغَا أَثنْ ذ\add* نَاذَابْ، أَبِيهُو، أَلِيعَازَارْ ذ إِثَامَارْ.
\v 2 نَاذَابْ ذ أَبِيهُو مُّوثنْ زَّاثْ إِ وُوذمْ ن بَابَاثْسنْ. وَارْ غَارْسنْ بُو وَارَّاونْ. أَلِيعَازَارْ ذ إِثَامَارْ ثُوغَا تّْسخَّارنْ أَمْ يِيكهَّاننْ.
\m 
\v 3 \add جْمِيعْ\add* أَكْ-ذ صَاذُوقْ زڭْ وَارَّاونْ ن أَلِيعَازَارْ ؤُ أَكْ-ذ أَخِيمَالِيكْ زڭْ وَارَّاونْ ن إِثَامَارْ إِبْضَا إِ-ثنْ ذَاوُوذْ عْلَاحْسَابْ ثَاوقَّافْثْ نْسنْ إِ ثْسخَّارْثْ نْسنْ.
\v 4 ؤُفِينْ أَقَا غَارْ وَارَّاونْ ن أَلِيعَازَارْ أَطَّاسْ ن إِزدْجِيفنْ خْ \add إِزدْجِيفنْ\add* \add نِّي إِدْجَانْ\add* غَارْ وَارَّاونْ ن إِثَامَارْ. بْضَانْ ثنْ \add أَمنِّي\add*: جَارْ وَارَّاونْ ن إِلِيعَازَارْ \add ثُوغَا ذِينْ\add* سطَّاشْ ن إِزدْجِيفنْ إِ ثُوذْرِينْ ن إِبَابَاثنْ \add نْسنْ\add* ؤُ جَارْ وَارَّاونْ ن إِثَامَارْ \add ثُوغَا ذِينْ\add* ثْمنْيَا \add ن إِزدْجِيفنْ\add* إِ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ.
\v 5 نِيثْنِي بْضَانْ ثنْ س ثْقدُّوحْثْ، أَمْ يِينَا أَمْ يِينِّي، مَاغَارْ إِمقّْرَاننْ ن زَّاوشْثْ إِقدّْسنْ، إِمقّْرَاننْ ن أَربِّي، \add ثُوغَا أَثنْ\add* زڭْ وَارَّاونْ ن أَلِيعَازَارْ ؤُ زڭْ وَارَّاونْ ن إِثَامَارْ.
\m 
\v 6 شَامْعِييَا، مِّيسْ ن نَاثَانْيِيلْ، \add ونِّي ثُوغَا\add* ذ أَمَارِيرْ زِي \add ثقْبِيتْشْ\add* ن لَاوِي، إِزمّنْ إِ-ثنْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ذ ڒْحُوكَّامْ ذ ؤُكهَّانْ صَاذُوقْ، ذ أَخِيمَالِيكْ، مِّيسْ ن أَبْيَاثَارْ، ؤُ زَّاثْ إِ وُوذمْ ن إِزدْجِيفنْ ن ڒَادْجَاثْ جَارْ إِكهَّاننْ ؤُ جَارْ إِلَاوِييّنْ. ڭِّينْ \add ثَاقدُّوحْثْ\add* إِ يِيجّْ ن ڒَادْجْ ن أَلِيعَازَارْ، \add خنِّي\add* إِ \add يِيجّْ ن ڒَادْجْ\add* ن إِثَامَارْ.
\b
\m 
\v 7 ثَاقدُّوحْثْ ثَامزْوَارُوثْ ثكَّارْ أَسْ-د
\m إِ يَاهُويَارِيبْ،
\m وِيسّْ ثْنَاينْ إِ يَاذَاعْيَا،
\m 
\v 8 وِيسّْ ثْڒَاثَا إِ حَارِيمْ،
\m وِيسّْ أَربْعَا إِ سَاعُورِيمْ،
\m 
\v 9 وِيسّْ خمْسَا إِ مَالْكِييَا،
\m وِيسّْ ستَّا إِ مِييَامِينْ،
\m 
\v 10 وِيسّْ سبْعَا إِ هَاقُّوصْ،
\m وِيسّْ ثْمنْيَا إِ أَبِييَا،
\m 
\v 11 وِيسّْ ثسْعَا إِ يشُوعَا،
\m وِيسّْعشْرَا إِ شَاكَانْيَا،
\m 
\v 12 وِيسّْ حِيثَاشْ إِ إِلْيَاشِيبْ،
\m وِيسّْ ثنْعَاشْ إِ يَاقِيمْ،
\m 
\v 13 وِيسّْ ثْڒطَّاشْ إِ حُوفَّا،
\m وِيسّْ أَرْبعْطَاشْ إِ يَاشَابَاذْ،
\m 
\v 14 وِيسّْ خمّسْطَاشْ إِ بِيلْجَا،
\m وِيسّْ سطَّاشْ إِ إِمِّيرْ،
\m 
\v 15 وِيسّْ سْبعْطَاشْ إِ حِيزِيرْ،
\m وِيسّْ ثْمنْطَاشْ إِ حَافْصِيصْ،
\m 
\v 16 وِيسّْ ثْسعْطَاشْ إِ فَاقَاحْيَا،
\m وِيسّْ عِيشْرِينْ إِ يَاحَازْقِييِيلْ،
\m 
\v 17 وِيسّْ وَاحِيثْ ؤُ-عِيشْرِينْ إِ يَاخِينْ،
\m وِيسّْ ثْنَاينْ ؤُ-عِيشْرِينْ إِ جَامُولْ،
\m 
\v 18 وِيسّْ ثْڒَاثَا ؤُ-عِيشْرِينْ إِ ذَالَايَا،
\m وِيسّْ أَربْعَا ؤُ-عِيشْرِينْ إِ مَاعَازْيَا.
\b
\m 
\v 19 إِنَا ثُوغَا خَاسنْ ثَاوقَّافْثْ مَاحنْذْ أَذْ أَذْفنْ غَارْ ثَادَّارْثْ ن سِيذِي عْلَاحْسَابْ \add أَستّفْ ن\add* ثْسخَّارْثْ نْسنْ أَمْ مَامّشْ لْفَارِيضَا \add إِ د-يُوسِينْ\add* س ؤُفُوسْ ن بَابَاثْسنْ هَارُونْ أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي، أَربِّي ن إِسْرَائِيل.
\b
\s1 ڒَادْجْ ن إِلَاوِييّنْ
\m 
\v 20 زِي جِّيهثْ \add ن ؤُستّفْ\add* ن مِينْ إِقِّيمنْ ن وَارَّاونْ ن لَاوِي:
\m شُوبَايِيلْ \add ثُوغَا ذ أَزدْجِيفْ\add* إِ وَارَّاونْ ن عَامْرَامْ،
\m يَاحَاذْيَا \add ثُوغَا ذ أَزدْجِيفْ\add* إِ وَارَّاونْ ن شُوبَايِيلْ.
\m 
\v 21 خْ رَاحَابْيَا: خْ وَارَّاونْ ن رَاحَابْيَا \add ثُوغَا\add* يَاشِّي-يَاهْ ذ أَزدْجِيفْ.
\m 
\v 22 خْ \add وَارَّاونْ\add* ن يِيصْهَارْ \add ثُوغَا\add* شَالُومِيثْ \add ذ أَزدْجِيفْ\add*.
\m خْ وَارَّاونْ ن شَالُومِيثْ \add ثُوغَا\add* يَاهَاثْ \add ذ أَزدْجِيفْ\add*.
\m 
\v 23 ؤُ \add خْ\add* وَارَّاونْ \add ن حَابْرُونْ\add* \add ثُوغَا\add* يَارِييَا \add ذ أَزدْجِيفْ\add*، أَمَارْيَا \add ثُوغَا-ث\add* ذ وِيسّْ ثْنَاينْ، يَاحْزِييِيلْ ذ وِيسّْ ثْڒَاثَا، يَاقْمَاعَامْ د وِيسّْ أَربْعَا.
\m 
\v 24 \add خْ\add* وَارَّاونْ ن عُوزِّييِيلْ \add ثُوغَا\add* مِيخَا \add ذ أَزدْجِيفْ\add*.
\m خْ وَارَّاونْ ن مِيخَا \add ثُوغَا\add* شَامِيرْ \add ذ أَزدْجِيفْ\add*.
\m 
\v 25 ؤُمَاسْ ن مِيخَا \add ثُوغَا\add* ذ يَاشِّي-يَاه. خْ وَارَّاونْ ن يَاشِّي-يَاهْ \add ثُوغَا\add* زَاكَارِييَّا \add ذ أَزدْجِيفْ\add*.
\m 
\v 26 أَرَّاونْ ن مَارَارِي \add ثُوغَا أَثنْ ذ\add* مَاحْلِي ذ مُوشِي. خْ وَارَّاونْ ن يَاعَازْيَا \add ثُوغَا\add* بَانُو \add ذ أَزدْجِيفْ\add*.
\m 
\v 27 أَرَّاونْ ن مَارَارِي س يَاعَازْيَا \add ثُوغَا أَثنْ ذ\add* بَانُو ذ شُوهَامْ ذ زَاكُّورْ ذ عِيبْرِي.
\m 
\v 28 إِ مَاحْلِي \add ثُوغَا\add* أَلِيعَازَارْ \add ذ مِّيسْ\add*. وَانِيثَا ثُوغَا وَارْ غَارسْ بُو وَارَّاونْ.
\m 
\v 29 خْ قِيسْ: أَرَّاونْ ن قِيسْ: \add مْغِيرْ\add* يَارْحَامْيِيلْ.
\m 
\v 30 أَرَّاونْ ن مُوشِي \add ثُوغَا أَثنْ ذ\add* مَاحْلِي، عَاذِيرْ ذ يَارِيمُوثْ.
\b
\m إِنَا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن لَاوِي، \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ ن إِبَابَاثنْ نْسنْ.
\m 
\v 31 ؤُڒَا ذ نِيثْنِي نْضَارنْ ثِيقدُّوحِينْ أَمْ يَايْثْمَاثْسنْ، أَرَّاونْ ن هَارُونْ، زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ذَاوُوذْ ذ صَاذُوقْ ذ أَخِيمَالِيكْ ذ إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ن إِكهَّاننْ ؤُ خْ إِلَاوِييّنْ، أَمْ يِيبَابَاثنْ \add نِّي إِدْجَانْ\add* ذ أَزدْجِيفْ أَمْ ؤُمَاثْسنْ ذ أَمَاژُوژْ.
\b
\b
\c 25
\s1 إِمذْيَازنْ
\m 
\v 1 زڭْ وَارَّاونْ ن أَسَافْ ذ هَايْمَانْ ذ يَاذُوثُونْ إِعْزڒْ ذَاوُوذْ أَكْ-ذ إِكُومَانْذَارنْ ن ڒْعسْكَارْ \add إِرْيَازنْ\add* إِ ثْسخَّارْثْ نِّي إِتّْنبَّانْ س ڒْڭَامْبْرِييَاثْ ذ لهَارْپَاثْ ذ ثَادْجُونِينْ ن وُوزَّاڒْ. ڒْقدّْ ن يرْيَازنْ إِ إِڭِّينْ ڒْخذْمثْ ن ثْسخَّارْثْ نْسنْ \add ثُوغَا-ث ذ وَا\add*:
\b
\m 
\v 2 \bd إِ وَارَّاونْ ن أَسَافْ\bd*: زَاكُّورْ، يُوسُوفْ، نَاثَانْيَا ذ أَشْرِييِيلْ، \add نِيثْنِي ذ\add* أَرَّاونْ ن أَسَافْ. ثُوغَا-ثنْ سَاذُو ؤُفُوسْ ن أَسَافْ. نتَّا ثُوغَا إِتّْنبَّا خْ إِشيَّارنْ ن ؤُجدْجِيذْ.
\m 
\v 3 إِ يَاذُوثُونْ: \bd أَرَّاونْ ن يَاذُوثُونْ\bd* \add ثُوغَا أَثنْ ذ\add* جَاذَالْيَا، صَارِي، إِشَاعْيَا، حَاشَابْيَا ذ مَاتِّيثْيَا، ستَّا \add ن وَارَّاونْ\add*. ثُوغَا-ثنْ سَاذُو ؤُفُوسْ ن بَابَاثْسنْ يَاذُوثُونْ، ونِّي ثُوغَا إِتّْنبَّانْ \add أَمْ إِتِّيرَارْ\add* خْ ڒْڭَامْبْرِي، أَمْ إِتّْقَاذَا ذ إِسّمْغَارَا سِيذِي.
\m 
\v 4 إِ هِيمَانْ: \bd أَرَّاونْ ن هَايْمَانْ\bd* \add ثُوغَا أَثنْ ذ\add* بُوقِّييَا، مَاتَّانْيَا، عُوزِّييِيلْ، شابُووِيلْ، يَارِيمُوثْ، حَانَانْيَا، حَانَانِي، إِلِييَاثَا، جِيدَّالْثِي، رُومَامْثِي-عَازَارْ، يُوشْبَاقَاشَا، مَالُّوثِي، هُوثِيرْ \add ذ\add* مَاحْزِييُوثْ.
\v 5 نِيثْنِي مَارَّا \add ثُوغَا أَثنْ ذ\add* أَرَّاونْ ن هَايْمَانْ، أَمْوَاڒَاوْ ن ؤُجدْجِيذْ س ڒفْهَامثْ ن وَاوَاڒنْ ن أَربِّي، حِيمَا أَذْ سّْڭعّْذنْ إِشّْ \add نّسْ\add*، \add مِينْزِي إِ ؤُيَا\add* يَارْزفْ أَربِّي إِ هَايْمَانْ أَرْبعْطَاشْ ن وَارَّاونْ ذ ثْڒَاثَا ن ثْحنْجِيرِينْ.
\m 
\v 6 مَارَّا إِنَا \add ثُوغَا أَثنْ\add* سَاذُو ؤُفُوسْ ن بَابَاثْسنْ، \add ن\add* أَسَافْ، يَاذُوثُونْ ذ هَايْمَانْ، مَاحنْذْ أَذْغنّْجنْ إِزْڒَانْ ذِي ثَادَّارْثْ ن سِيذِي س ثَادْجُونِينْ ن وُوزَّاڒْ ذ لهَارْپَاثْ ذ ڒْڭَامْبْرِييَاثْ إِ ثْسخَّارْثْ ذِي ثَادَّارْثْ ن أَربِّي سَاذُو ؤُفُوسْ ن ؤُجدْجِيذْ.
\v 7 ڒْقدّْ نْسنْ، \add جْمِيعْ\add* أَكْ-ذ أَيْثْمَاثْسنْ، إِنِّي ثُوغَا إِتّْوَاسّْڒمْذنْ ذڭْ إِزْڒَانْ إِ سِيذِي، \add ڒْقدّْ ن\add* مَارَّا إِنِّي غَارْسنْ ثِيزمَّارْ \add ذِي مَانْ أَيَا\add*، ثُوغَا-ث مِيثَاينْ ؤُ-ثْمنْيَا ؤُ-ثْمَانْيِينْ.
\m 
\v 8 نِيثْنِي نْضَارنْ ثِيقدُّوحِينْ إِ ثْعسَّاسْثْ، أَمْ ؤُمژْيَانْ أَمْ ؤُمقّْرَانْ، أَمْ ؤُمْسڒْمَاذْ أَمْ ؤُمحْضَارْ.
\b
\m 
\v 9 ثَاقدُّوحْثْ ثَامزْوَارُوثْ ثكَّارْ أَسْ-د إِ يُوسُوفْ.
\m وِيسّْ ثْنَاينْ إِ جَاذَالْيَا. نتَّا ذ أَيْثْمَاسْ ذ وَارَّاونْ نّسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 10 وِيسّْ ثْڒَاثَا \add ثكَّارْ أَسْ-د\add* إِ زَاكُّورْ، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 11 وِيسّْ أَربْعَا \add ثكَّارْ أَسْ-د\add* إِ يَاصْرِي، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 12 وِيسّْ خمْسَا \add ثكَّارْ أَسْ-د\add* إِ نَاثَانْيَا، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 13 وِيسّْ ستَّا \add ثكَّارْ أَسْ-د\add* إِ بُوقِّييَا، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 14 وِيسّْ سبْعَا \add ثكَّارْ أَسْ-د\add* إِ يَاشَارْيِيلَا، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 15 وِيسّْ ثْمنْيَا \add ثكَّارْ أَسْ-د\add* إِ إِشَاعْيَا، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 16 وِيسّْ ثسْعَا \add ثكَّارْ أَسْ-د\add* إِ مَاتَّانْيَا، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 17 وِيسّْعشْرَا \add ثكَّارْ أَسْ-د\add* إِ شِيمْعِي، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 18 وِيسّْ حِيطَاشْ \add ثكَّارْ أَسْ-د\add* إِ عَازَارْيِيلْ، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 19 وِيسّْ ثنْعَاشْ \add ثكَّارْ أَسْ-د\add* إِ هَاشَابْيَا، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 20 وِيسّْ ثْڒطَّاشْ \add ثكَّارْ أَسْ-د\add* إِ شُوبَايِيلْ، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 21 وِيسّْ أَرْبعْطَاشْ \add ثكَّارْ أَسْ-د\add* إِ مَاتِّيثْيَا. \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 22 وِيسّْ خمّسْطَاشْ \add ثكَّارْ أَسْ-د\add* إِ يَارِيمُوثْ، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 23 وِيسّْ سطَّاشْ \add ثكَّارْ أَسْ-د\add* إِ حَانَانْ-يَاهْ، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 24 وِيسّْ سْبعْطَاشْ \add ثكَّارْ أَسْ-د\add* إِ يَاشْبَاقَاشَا، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 25 وِيسْ ثْمنْطَاشْ \add ثكَّارْ أَسْ-د\add* إِ حَانَانِي، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 26 وِيسّْ ثْسعْطَاشْ \add ثكَّارْ أَسْ-د\add* إِ مَالُّوثِي، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 27 وِيسّْ عِيشْرِينْ \add ثكَّارْ أَسْ-د\add* إِ إِلِييَاثَا، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 28 وِيسّْ وَاحِيثْ ؤُ-عِيشْرِينْ \add ثكَّارْ أَسْ-د\add* إِ هُوثِيرْ، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 29 وِيسّْ ثْنَاينْ ؤُ-عِيشْرِينْ \add ثكَّارْ أَسْ-د\add* إِ جِيدَّالْثِي، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 30 وِيسّْ ثْڒَاثَا ؤُ-عِيشْرِينْ \add ثكَّارْ أَسْ-د\add* إِ مَاحْزِييُوثْ، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\m 
\v 31 وِيسّْ أَربْعَا ؤُ-عِيشْرِينْ \add ثكَّارْ أَسْ-د\add* إِ رُومَامْثِي-عَازَارْ، \add نتَّا أَكْ-ذ\add* وَارَّاونْ نّسْ ذ أَيْثْمَاسْ، ثنْعَاشْ \add ن يرْيَازنْ\add*.
\b
\b
\c 26
\s1 إِعسَّاسنْ ن ثوَّارْثْ، إِوقَّافنْ نْ ڒكْنُوزْ، إِمحْضَاينْ ذ ڒْقُوضَاثْ
\m 
\v 1 ثِيرْبِيعِينْ ن \bd إِعسَّاسنْ ن ثوُّورَا:\bd*
\b
\m \bd ن إِقُورَاحِييّنْ:\bd* مَاشَالَامْيَا، مِّيسْ ن قُورِي، زڭْ وَارَّاونْ ن أَ\add بِييَا\add*سَافْ.
\b
\m 
\v 2 مَاشَالَامْيَا ثُوغَا غَارسْ وَارَّاونْ:
\m زَاكَارِييَّا \add ثُوغَا-ث ذ\add* أَمنْزُو،
\m يَاذِيعِيلْ وِيسّْ ثْنَاينْ،
\m زَابَاذْيَا وِيسّْ ثْڒَاثَا،
\m يَاثْنِييِيلْ وِيسّْ أَربْعَا،
\m 
\v 3 عِيلَامْ وِيسّْ خمْسَا،
\m يُوحَانَانْ وِيسّْ ستَّا،
\m إِلْيُوعِينَايْ وِيسّْ سبْعَا.
\b
\m 
\v 4 ؤُڒَا \bd عُوبِيذْ-إِذُومْ\bd* ثُوغَا غَارسْ وَارَّاونْ:
\m شَامْعِييَا \add ثُوغَا-ث ذ\add* أَمنْزُو،
\m يَاهُوزَابَاذْ وِيسّْ ثْنَاينْ،
\m يُووَاخْ وِيسّْ ثْڒَاثَا،
\m سَاكَارْ وِيسّْ أَربْعَا،
\m نَاثَانَايِيلْ وِيسّْ خمْسَا،
\m 
\v 5 عَامِييِيلْ وِيسّْ ستَّا،
\m إِسَّاكَارْ وِيسّْ سبْعَا،
\m فَاعَالْثَايْ وِيسّْ ثْمنْيَا،
\m مَاغَارْ إِبَاركْ إِ-ث أَربِّي.
\b
\m 
\v 6 ؤُڒَا إِ مِّيسْ شَامْعِييَا تّْوَاخڒْقنْ أَسْ-د وَارَّاونْ. \add نِيثْنِي ثُوغَا أَثنْ ذ\add* ڒْحُوكَّامْ ذِي ثَادَّارْثْ ن بَابَاثْسنْ، مِينْزِي نِيثْنِي \add ثُوغَا أَثنْ ذ\add* أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ.
\v 7 أَرَّاونْ ن شَامْعِييَا \add ثُوغَا أَثنْ\add*: عُوثْنِي، رَافَايِيلْ، عُوبِيذْ، إِلْزَابَاذْ \add أَكْ-ذ\add* أَيْثْمَاسْ، إِرْيَازنْ إِمحْضنْ: إِلِيهُو ذ شَامَاكْيَا.
\b
\m 
\v 8 إِنَا مَارَّا \add ثُوغَا أَثنْ\add* زڭْ وَارَّاونْ ن عُوبِيذْ-إِذُومْ، نِيثْنِي ذ وَارَّاونْ نْسنْ ذ وَاوْمَاثنْ نْسنْ، إِرْيَازنْ إِمحْضنْ، \add شُّورنْ\add* س جّهْذْ إِ ثْسخَّارْثْ نْسنْ، ثْنَاينْ ؤُ-ستِّينْ \add ن يرْيَازنْ\add* ن عُوبِيذْ-إِذُومْ.
\b
\m 
\v 9 مَاشَالَامْيَا \add ثُوغَا\add* غَارسْ وَارَّاونْ ذ وَاوْمَاثنْ، إِرْيَازنْ إِمحْضنْ، ثْمنْطَاشْ \add ن يرْيَازنْ\add*.
\b
\m 
\v 10 حُوسَا، \bd زڭْ وَارَّاونْ ن مَارَارِي\bd*، \add ثُوغَا\add* غَارسْ وَارَّاونْ-أَ:
\m شِيمْرِي \add ثُوغَا\add* ذ أَزدْجِيفْ، وَاخَّا نتَّا وَارْ إِدْجِي ذ أَمنْزُو، \add مَاشَا\add* بَابَاسْ إِڭَّا إِ-ث ذ أَزدْجِيفْ.
\m 
\v 11 حِيلْقِييَا \add ثُوغَا-ث ذ\add* وِيسّْ ثْنَاينْ،
\m ثَابَالْيَا وِيسّْ ثْڒَاثَا،
\m زَاكَارِييَّا وِيسّْ أَربْعَا.
\m مَارَّا أَرَّاونْ ذ وَاوْمَاثنْ ن حُوسَا \add ثُوغَا أَثنْ ذِي\add* ثْڒطَّاشْ \add ن يرْيَازنْ\add*.
\b
\m 
\v 12 خْ ثرْبِيعِينْ-أَ ن إِعسَّاسنْ ن ثوُّورَا، خْ إِزدْجِيفنْ ن أَيْثْ ن بُو-ثغْرُوضْثْ، ثُوغَا شّْغڒْ ن ثْسخَّارْثْ ذِي ثَادَّارْثْ ن سِيذِي، جْمِيعْ أَكْ-ذ أَيْثْمَاثْسنْ.
\m 
\v 13 نِيثْنِي نْضَارنْ ثَاقدُّوحْثْ، أَمْ ؤُمژْيَانْ أَمْ ؤُمقّْرَانْ، إِ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، إِ ثوَّارْثْ ؤُ إِ ثوَّارْثْ \add نّغْنِي\add*.
\m 
\v 14 ثَاقدُّوحْثْ إِ \add ثْعسَّاسْثْ ن\add* شَّارْقْ ثكَّارْ أَسْ-د إِ شَالَامْيَا.
\m ؤُڒَا إِ مِّيسْ زَاكَارِييَّا، ونِّي ذ أَمْشَاوَارْ س ڒعْقڒْ، ثوْضَا \add أَسْ-د\add* ثَاقدُّوحْثْ ؤُ ثَاقدُّوحْثْ نّسْ ثكَّارْ \add أَسْ-د\add* إِ شَّامَالْ.
\m 
\v 15 إِ عُوبِيذْ-إِذُومْ \add ثكَّارْ أَسْ-د ثْقدُّوحْثْ\add* إِ لْجَانُوبْ ؤُ إِ وَارَّاونْ نّسْ إِ ثَادَّارْثْ ن إِخَّامنْ ن ڒخْزنْ. \f ◼ \fr 26:‏15 \ft \bd ’ڒهْرِيثْ‘\bd* - نِيغْ ’إِخَّامنْ ن ؤُخمّڒْ‘.\f*
\m 
\v 16 إِ شُوفِّيمْ ذ حُوسَا \add ثكَّارْ أَسنْ-د ثْقدُّوحْثْ\add* إِ لْغَارْبْ، أَكْ-ذ ثوَّارْثْ ن شَالَاكَاثْ غَارْ وبْرِيذْ أَمقّْرَانْ إِڭعّْذنْ \add غَارْ زَّاوشْثْ ثَامقّْرَانْثْ\add*. إِجّْ ن ؤُعسَّاسْ \add ثُوغَا إِبدّْ\add* غَارْ \add إِجّْ ن\add* ؤُعسَّاسْ \add نّغْنِي\add*.
\m 
\v 17 غَارْ مَانِيسْ إِ د-ثْنقَّارْ ثْفُوشْثْ \add بدّنْ\add* ستَّا ن إِلَاوِييّنْ ؤُ غَارْ شَّامَالْ \add بدّنْ ذِينْ\add* كُوڒْ أَسّْ أَربْعَا. غَارْ لْجَانُوبْ \add عَاوذْ\add* كُوڒْ أَسّْ أَربْعَا ؤُ غَارْ إِخَّامنْ ن ڒخْزنْ ثْنَاينْ \add ؤُ عَاوذْ\add* ثْنَاينْ.
\v 18 غَارْ ڒبْنِي ن ؤُغزْذِيسْ ن لْغَارْبْ \add ن زَّاوشْثْ ثَامقّْرَانْثْ\add* أَربْعَا غَارْ وبْرِيذْ أَمقّْرَانْ ؤُ ثْنَاينْ غَارْ ڒبْنِي ن ؤُغزْذِيسْ.
\m 
\v 19 ثِينَا \add ثُوغَا\add* ذ ثِيرْبِيعِينْ ن إِعسَّاسنْ ن ثوُّورَا زڭْ وَارَّاونْ ن قُورَاحْ ؤُ زڭْ وَارَّاونْ ن مَارَارِي.
\b
\m 
\v 20 \bd أَيْثْمَاثْسنْ إِلَاوِييّنْ \bdit ثُوغَا أَثنْ\bdit* خْ إِخَّامنْ ن ثْخُوبَايْ\bd* ن ثَادَّارْثْ ن أَربِّي ؤُ خْ إِخَّامنْ ن ثْخُوبَايْ ن ثوْهِيبِينْ إِتّْوَاقدّْسنْ.
\m 
\v 21 أَرَّاونْ ن لَاعْذَانْ، أَرَّاونْ ن ؤُجَارْشُونِي \add نِّي ثُوغَا\add* غَارْ لَاعْذَانْ، \add إِخْسْ أَذْ يِينِي\add* إِزدْجِيفنْ ن إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ن لَاعْذَانْ، أَجَارْشُونِي: جَاحِييِيلِي \add وَاهَا\add*.
\m 
\v 22 إِحنْجِيرنْ ن يَاحْيِيلِي \add ثُوغَا أَثنْ ذ\add* زِيثَامْ ذ يُووِيلْ، ؤُمَاسْ. نِيثْنِي \add ثُوغَا أَثنْ\add* خْ إِخَّامنْ ن ثْخُوبَايْ ن ثَادَّارْثْ ن سِيذِي.
\m 
\v 23 ن عَامْرَامِييّنْ، ذ إِيِيصْهَارِييّنْ، ذ إِحَابْرُونِييّنْ، ذ إِعَازِييِيلِييّنْ
\v 24 \add ثُوغَا\add* شابُووِيلْ، مِّيسْ ن جَارْشُومْ، مِّيسْ ن مُوسَا، ذ أَمحْضَايِي خْ إِخَّامنْ ن ثْخُوبَايْ.
\m 
\v 25 أَيْثْمَاسْ \add زِي جَّاذِيرَا\add* ن إِلِيعَازَارْ \add ثُوغَا أَثنْ ذ\add* مِّيسْ رَاحَابْيَا، مِّيسْ إِشَاعْيَا، مِّيسْ يُورَامْ، مِّيسْ زِيكْرِي \add ذ\add* مِّيسْ شَالُومِيثْ.
\v 26 شَالُومِيثْ وَانِيثَا ذ أَيْثْمَاسْ \add ثُوغَا أَثنْ\add* خْ إِخَّامنْ ن ثْخُوبَايْ ن ثوْهِيبِينْ إِتّْوَاقدّْسنْ، ثِينِّي إِسّْقدّسْ إِ-ثنْثْ ؤُجدْجِيذْ ذَاوُوذْ أَكْ-ذ إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ؤُ أَكْ-ذ إِمقّْرَاننْ خْ وَاڒفْ ذ خْ مْيَا، ؤُ أَكْ-ذ إِكُومَانْذَارنْ ن ڒْعسْكَارْ.
\v 27 نِيثْنِي ثُوغَا سّْقدّْسنْ \add ثِيوْهِيبِينْ نِّي\add* زِي ڭَارَّاثْ ؤُ زِي ثْكشَّاضْثْ، حِيمَا أَذْ زَّايْسنْثْعذْڒنْ ثَادَّارْثْ ن سِيذِي.
\v 28 \add عَاوذْ\add* مَارَّا مِينْ ثُوغَا إِسّْقدّسْ إِ-ث ؤُمْوَاڒَاوْ شَامْوِيلْ، ذ شَاوُولْ، مِّيسْ ن قِيسْ، ذ أَبْنِيرْ، مِّيسْ ن نِيرْ، ذ يُووَابْ، مِّيسْ ن صَارَايَا. مَارَّا مِينْ ثُوغَا إِتّْوَاقدّْسنْ \add ثُوغَا\add* سَاذُو أَفُوسْ ن شَالُومِيثْ ذ أَيْثْمَاسْ.
\b
\m 
\v 29 زڭْ إِيِيصْهَارِييّنْ \add ثُوغَا\add* كَانَانْيَا ذ وَارَّاونْ نّسْ خدّْمنْ أَمْ \bd إِمحْضَاينْ ذ ڒْقُوضَاثْ\bd* بَارَّا ذِي \add ثمُّورْثْ ن\add* إِسْرَائِيل.
\m 
\v 30 زڭْ إِحَابْرُونِييّنْ \add ثُوغَا\add* ثَاوقَّافْثْ خْ إِسْرَائِيل غَارْ حَاشَابْيَا ذ أَيْثْمَاسْ، إِرْيَازنْ إِمحْضنْ، أَڒفْ ؤُ-سبْعَا-مْيَا \add ن يرْيَازنْ\add*، خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ غَارْ لْغَارْبْ، \add ثُوغَا أَثنْ\add* خْ مَارَّا ڒْخذْمثْ إِ سِيذِي ؤُ خْ ثْسخَّارْثْ إِ ؤُجدْجِيذْ.
\v 31 إِ إِحَابْرُونِييّنْ \add ثُوغَا\add* يَارِييَا ذ أَزدْجِيفْ، إِ إِحَابْرُونِييّنْ، إِ جِّيڒَاثْ نّسْ، جَارْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add*. ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعِينْ ن ثْڭلْذَا ن ذَاوُوذْ تّْوَارْزُونْ ؤُ تّْوَافنْ أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ ذِي يَاعْزِيرْ ذِي جِيلْعَاذْ.
\v 32 أَيْثْمَاسْ \add ثُوغَا أَثنْ ذ\add* إِرْيَازنْ إِمحْضنْ، أَڒْفَاينْ ؤُ-سبْعَا-مْيَا ن إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add*. أَجدْجِيذْ ذَاوُوذْ إِڭَّا ثنْ خْ أَيْثْ ن رُوبِينْ، خْ أَيْثْ ن جَاذْ ؤُ خْ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا، خْ مَارَّا ثِيمسْڒَايِينْ ن أَربِّي ؤُ \add خْ مَارَّا\add* ثِيمسْڒَايِينْ ن ؤُجدْجِيذْ.
\b
\b
\c 27
\s1 إِكُومَانْذَارنْ ن ڒْعسْكَارْ
\m 
\v 1 إِنَا ذ أَيْثْ ن إِسْرَائِيل أَكْ-ذ ڒْقدّْ نْسنْ، إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add*، ؤُڒَا ذ إِمقّْرَاننْ خْ وَاڒفْ ؤُ خْ مْيَا أَكْ-ذ إِمحْضَاينْ نْسنْ، إِنِّي ثُوغَا إِتّْسخَّارنْ إِ ؤُجدْجِيذْ ذِي مَارَّا ثِيمسْڒَايِينْ ن ثرْبِيعِينْ، \add أَمْ\add* زِي جِّيهثْ ن مَانْ ونْ إِ د-إِتَّاسنْ، \add أَمْ\add* زِي جِّيهثْ ن مَانْ ونْ إِتّْرَاحنْ، ؤُ \add مَانْ أَيَا\add* زڭْ ؤُيُورْ أَڒْ ؤُيُورْ \add نّغْنِي\add* ذِي مَارَّا إِيُورنْ ن ؤُسڭّْوَاسْ. إِشْثْ ن ثرْبِيعْثْ \add ذَايسْ\add* أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add*.
\m 
\v 2 يَاسُوبْعَامْ، مِّيسْ ن زَابْذِييِيلْ، \add ثُوغَا\add* خْ ثرْبِيعْثْ ثَامزْوَارُوثْ \bd إِ ؤُيُورْ وِيسّْ أَمزْوَارُو\bd*. ثَارْبِيعْثْ نّسْ \add ذَايسْ\add* أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add*.
\m 
\v 3 \add نتَّا ثُوغَا\add* زڭْ وَارَّاونْ ن فَارِيصْ. \add نتَّا\add* ذ أَكُومَانْذَارْ أَمقّْرَانْ خْ مَارَّا إِكُومَانْذَارنْ ن ڒْعسْكَارَاثْ ذڭْ ؤُيُورْ أَمزْوَارُو.
\m 
\v 4 ذُوذَايْ، أَخُوخِي، \add ثُوغَا\add* خْ ثرْبِيعْثْ \bd ن ؤُيُورْ وِيسّْ ثْنَاينْ\bd*. مِيقْلُوثْ ذ أَمحْضَايْ ن ثرْبِيعْثْ نّسْ. ثَارْبِيعْثْ نّسْ \add ذَايسْ\add* أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add*.
\m 
\v 5 بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ، أَكهَّانْ أَمقّْرَانْ ثُوغَا ذ أَكُومَانْذَارْ وِيسّْ ثْڒَاثَا ن ڒْعسْكَارْ \bd إِ ؤُيُورْ وِيسّْ ثْڒَاثَا\bd*. ثَارْبِيعْثْ نّسْ \add ذَايسْ\add* أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add*.
\m 
\v 6 بَانَايَا وَا \add ثُوغَا\add* ذ بُو-ثغْرُوضْثْ ن ثْڒَاثِينْ ؤُ نتَّا \add ثُوغَا\add* خْ ثْڒَاثِينْ. مِّيسْ عَامِّيزَابَاذْ \add ثُوغَا\add* خْ ثرْبِيعْثْ نّسْ.
\m 
\v 7 عَسَائِيلْ، مِّيسْ ن يُووَابْ، ذ وِيسّْ أَربْعَا \bd إِ ؤُيُورْ وِيسّْ أَربْعَا\bd* ؤُ مِّيسْ زَابَاذْيَا \add ثُوغَا\add* أَوَارْنِي أَسْ. ثَارْبِيعْثْ نّسْ \add ذَايسْ\add* أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add*.
\m 
\v 8 شَامْحُوثْ، أَيَازْرَاحِي، أَكُومَانْذَارْ، \add ثُوغَا\add* خْ \add ثرْبِيعْثْ\add* وِيسّْ خمْسَا \bd إِ ؤُيُورْ وِيسّْ خمْسَا\bd*. ثَارْبِيعْثْ نّسْ \add ذَايسْ\add* أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add*.
\m 
\v 9 عِيرَا، مِّيسْ ن عِيقِّيسْ، أَثِيقُّوعِي، \add ثُوغَا\add* ذ وِيسّْ ستَّا \bd إِ ؤُيُورْ وِيسّْ ستَّا\bd*. ثَارْبِيعْثْ نّسْ \add ذَايسْ\add* أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add*.
\m 
\v 10 حَالِيصْ، أَفَالِيثُونِي، زڭْ وَارَّاونْ ن إِفْرَايِيمْ، \add ثُوغَا\add* ذ وِيسّْ سبْعَا \bd إِ ؤُيُورْ وِيسّْ سبْعَا\bd*. ثَارْبِيعْثْ نّسْ \add ذَايسْ\add* أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add*.
\m 
\v 11 سِيبْكَايْ، أَحُوشَاثِي، ن إِزَارَاحِييّنْ، \add ثُوغَا\add* ذ وِيسّْ ثْمنْيَا \bd إِ ؤُيُورْ وِيسّْ ثْمنْيَا\bd*. ثَارْبِيعْثْ نّسْ \add ذَايسْ\add* أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add*.
\m 
\v 12 أَبِيعَازَارْ، أَعَانَاثُوثِي، ن أَيْثْ ن بِينْيَامِينْ، \add ثُوغَا\add* ذ وِيسّْ ثسْعَا \bd إِ ؤُيُورْ وِيسّْ ثسْعَا\bd*. ثَارْبِيعْثْ نّسْ \add ذَايسْ\add* أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add*.
\m 
\v 13 مَاهَارَايْ، أَنَاطُوفَاثِي، إِ إِزَارَاحِييّنْ، \add ثُوغَا\add* ذ وِيسّْعشْرَا \bd إِ ؤُيُورْ وِيسّْعشْرَا\bd*. ثَارْبِيعْثْ نّسْ \add ذَايسْ\add* أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add*.
\m 
\v 14 بَانَايَا، أَفَارْعَاثُونِي، زڭْ وَارَّاونْ ن إِفْرَايِيمْ، \add ثُوغَا\add* ذ وِيسّْ حِيطَاشْ \bd إِ ؤُيُورْ وِيسّْ حِيطَاشْ\bd*. ثَارْبِيعْثْ نّسْ \add ذَايسْ\add* أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add*.
\m 
\v 15 خَالْذَايْ، أَنَاطُوفَاثِي، \add إِ د-إِقَّارْصنْ\add* زِي عُوثْنِييِيلْ، \add ثُوغَا\add* ذ وِيسّْ ثنْعَاشْ \bd إِ ؤُيُورْ ثنْعَاشْ\bd*. ثَارْبِيعْثْ نّسْ \add ذَايسْ\add* أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add*.
\b
\s1 إِمقّْرَاننْ ن ثْقبَّاڒْ
\m 
\v 16 \add إِنَا بدّنْ\add* خْ ثْقبَّاڒْ ن إِسْرَائِيل:
\m \bd إِ إِرُوبِينِييّنْ\bd* \add ثُوغَا\add* إِلِيعَازَارْ، مِّيسْ ن زِيكْرِي، ذ ڒْحَاكمْ.
\m \bd إِ إِشَامْعُونِييّنْ:\bd* شَافَاطْيَا، مِّيسْ ن مَاعْكَا.
\m 
\v 17 \bd إِ لَاوِي:\bd* حَاشَابْيَا، مِّيسْ ن قَامُووِيلْ.
\m \bd إِ هَارُونْ:\bd* صَاذُوقْ.
\m 
\v 18 \bd إِ يَاهُوذَا:\bd* إِلِيهُو، زڭْ أَيْثْمَاسْ ن ذَاوُوذْ.
\m \bd إِ إِسَّاكَارْ:\bd* عُومْرِي، مِّيسْ ن مِيخَايِيلْ.
\m 
\v 19 \bd إِ زابُولُونْ:\bd* يِيشْمَاعْيَا، مِّيسْ ن عُوبَاذْيَا.
\m \bd إِ نَافْثَالِي:\bd* يَارِيمُوثْ، مِّيسْ ن عَازَارْيِيلْ.
\m 
\v 20 \bd إِ وَارَّاونْ ن إِفْرَايِيمْ:\bd* حُوشِيعَا، مِّيسْ ن عَازَارْيَا.
\m \bd إِ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا:\bd* يُووِيلْ، مِّيسْ ن فَاذَايَا.
\m 
\v 21 \bd إِ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا ذِي جِيلْعَاذْ:\bd* جَادُّو، مِّيسْ ن زَاكَارِييَّا.
\m \bd إِ بِينْيَامِينْ:\bd* يَاعِيسِييِيلْ، مِّيسْ ن أَبْنِيرْ.
\m 
\v 22 \bd إِ ذَانْ:\bd* عَازَارْيِيلْ، مِّيسْ ن يَارُوحَامْ.
\b
\m إِنَا ثُوغَا ذ ڒْحُوكَّامْ ن ثْقبَّاڒْ ن إِسْرَائِيل.
\m 
\v 23 ذَاوُوذْ وَارْ إِكْسِي شَا ڒْقدّْ ن يِينِّي غَارْ إِدْجَا عِيشْرِينْ ن إِسڭّْوُوسَا ذ سْوَادَّايْ، مَاغَارْ سِيذِي ثُوغَا إِنَّا أَقَا نتَّا أَذْ يَارّْ إِسْرَائِيل ذڭْ وَاطَّاسْ أَمْ يِيثْرَانْ ن ؤُجنَّا.
\v 24 يُووَابْ، مِّيسْ ن صَارُويَا، ثُوغَا إِبْذَا أَذْ إِحْسبْ \add ڒْڭنْسْ\add*، مَاشَا وَارْ ث إِكمّڒْ ؤُمِي د-يُوسَا ؤُذُوقّزْ ذ أَمقّْرَانْ ن وغْضَابْ خْ إِسْرَائِيل. س ؤُينِّي وَارْ إِتّْوَاڭّْ ڒْقدّْ ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن ؤُجدْجِيذْ ذَاوُوذْ.
\b
\s1 إِوْكِيڒنْ ن ؤُجدْجِيذْ
\m 
\v 25 \bd عَازْمَاوثْ، مِّيسْ ن عَاذِييِيلْ\bd*، \add ثُوغَا\add* خْ إِخَّامنْ ن ثْخُوبَايْ ن ؤُجدْجِيذْ.
\m \bd يُونَاثَانْ، مِّيسْ ن عُوزِّييَا\bd*، \add ثُوغَا\add* خْ إِخَّامنْ ن ثْخُوبَايْ ن ثمُّورْثْ، ذِي ثْندَّامْ، ذِي ذْشُورَاثْ ؤُ ذِي لْبُورْجَاثْ.
\m 
\v 26 \bd عَازْرِي، مِّيسْ ن كَالُوبْ\bd*، \add ثُوغَا إِطّفْ أَشْبَارْ\add* خْ مَامّشْ ڭِّينْ ڒْخذْمثْ ذڭْ إِيَّارْ حِيمَا أَذْ شَارْزنْ أَشَاڒْ.
\m 
\v 27 \bd شِيمْعِي، أَرَامَاثِي\bd*، \add ثُوغَا إِطّفْ أَشْبَارْ\add* خْ إِمَارْجَاعنْ ن ؤُضِيڒْ.
\m \bd زَابْذِي، أَشِيفْمِي\bd*، \add ثُوغَا\add* خْ زَّاذْ ن بِينُو \add نِّي إِدْجَانْ\add* ذڭْ إِمَارْجَاعنْ ن ؤُضِيڒْ.
\m 
\v 28 \bd بَاعْلْ-حَانَانْ، أَجَاذِيرِي\bd*، \add ثُوغَا إِطّفْ أَشْبَارْ\add* خْ إِحْوِيشنْ ن زِّيثُونْ ؤُ خْ إِزمُّورنْ نِّي \add إِدْجَانْ\add* ذِي ثمُّورْثْ إِوَاطَانْ.
\m \bd يُووَاشْ\bd* \add ثُوغَا\add* خْ زَّاذْ ن زّشْثْ.
\m 
\v 29 \bd شِيطْرَايْ، أَشَارُونِي\bd*، \add ثُوغَا إِطّفْ أَشْبَارْ\add* خْ إِفُونَاسنْ ذ ثْفُونَاسِينْ، إِنِّي إِهدَّا ذِي ڒوْضَا ن شَارُونْ.
\m \bd شَافَاثْ، مِّيسْ ن عَالَايْ\bd*، \add ثُوغَا\add* خْ إِفُونَاسنْ ذ ثْفُونَاسِينْ ذِي ڒوْضَاثْ ن ثغْزُورْثْ.
\m 
\v 30 \bd ؤُبِيلْ، أَسْمَاعِيلِي\bd*، \add ثُوغَا إِطّفْ أَشْبَارْ\add* خْ إِڒغْمَانْ.
\m \bd يَاحَاذْيَا، أَمِيرُونُوثِي\bd*، \add ثُوغَا\add* خْ ثِيغْيَاڒْ.
\m 
\v 31 \bd يَازِيزْ، أَهَاجْرِي\bd*، \add ثُوغَا إِطّفْ أَشْبَارْ\add* خْ وُودْجِي.
\m نِيثْنِي مَارَّا ثُوغَا أَثنْ ذ إِمحْضَاينْ خْ وَاڭْڒَا نِّي \add إِدْجَانْ\add* ن ؤُجدْجِيذْ ذَاوُوذْ.
\m 
\v 32 \bd يُونَاثَانْ،عمِّيسْ ن ذَاوُوذْ\bd*، \add ثُوغَا\add* ذ أَمْشَاوَارْ، إِجّْ ن بْنَاذمْ ذ أَمِيغِيسْ. نتَّا ثُوغَا عَاوذْ ذ أَمَارِيرْ.
\m \bd يَاحِييِيلْ، مِّيسْ ن حَاكْمُونِي\bd*، \add ثُوغَا\add* غَارْ وَارَّاونْ ن ؤُجدْجِيذْ، \add يَاربَّا إِ-ثنْ\add*.
\m 
\v 33 \bd أَخِيثُوفِيلْ\bd* \add ثُوغَا\add* ذ أَمْشَاوَارْ ن ؤُجدْجِيذْ،
\m ؤُ \bd حُوشَايْ، أَيَارْكِي\bd*، \add ثُوغَا\add* ذ أَمدُّوكّڒْ ن ؤُجدْجِيذْ.
\m 
\v 34 \bd يَاهُويَاذَاعْ، مِّيسْ ن بَانَايَا، ذ أَبْيَاثَارْ\bd* \add ثُوغَا أَثنْ\add* أَوَارْنِي إِ أَخِيثُوفِيلْ.
\m \bd يُو‘أَبْ\bd* \add ثُوغَا-ث ذ\add* أَكُومَانْذَارْ ن ڒْعسْكَارْ ن ؤُجدْجِيذْ.
\b
\b
\c 28
\s1 ذَاوُوذْ إِڭَّا خْ سُولِيمَانْ مَاحنْذْ أَذْ إِبْنَا زَّاوشْثْ ثَامقّْرَانْثْ
\m 
\v 1 ذَاوُوذْ إِسّْمُونْ ذِي ؤُرْشَالِيمْ مَارَّا إِمقّْرَاننْ ن إِسْرَائِيل: إِمقّْرَاننْ ن ثْقبَّاڒْ ذ إِمقّْرَاننْ ن ثرْبِيعِينْ ذ إِمْسخَّارنْ ن ؤُجدْجِيذْ ذ إِمقّْرَاننْ خْ وَاڒفْ ذ إِمقّْرَاننْ خْ مْيَا ذ إِمقّْرَاننْ \add إِ إِدْجَانْ\add* خْ مَارَّا أَڭْڒَا ذ ڒْكسْبثْ ن ڒْمَاڒْ ن ؤُجدْجِيذْ ذ وَارَّاونْ نّسْ، \add جْمِيعْ\add* أَكْ-ذ إِمْسخَّارنْ إِشنّْعنْ ذ أَيْثْ ن بُو-ثغْرُوضْثْ، \add وَاهْ،\add* كُوڒْ بُو-ثغْرُوضْثْ إِمحْضنْ.
\m 
\v 2 إِكَّارْ ؤُجدْجِيذْ ذَاوُوذْ، إِنَّا: ”سْڒمْ-د غَارِي، أَيْثْمَا ذ ڒْڭنْسْ إِنُو! نشّْ سِيمَانْثْ إِنُو ثُوغَا-ث غَارِي ذڭْ وُوڒْ إِنُو حِيمَا أَذْ بْنِيغْ إِشْثْ ن ثَادَّارْثْ ن أَرَّاحثْ إِ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي ؤُ إِ ثْنبْذَاثْ ن إِضَارنْ ن أَربِّي نّغْ. \add خْ ؤُينِّي\add* سّْوجْذغْ إِ ڒبْنِي.
\v 3 مَاشَا أَربِّي إِنَّا أَيِي: ’شكْ وَارْ ثْبنِّيذْ إِ يِيسمْ إِنُو ثَادَّارْثْ، مَاغَارْ شكْ ذ إِجّْ ن ورْيَازْ ن إِمنْغَانْ ؤُ ثسِّيزْڒذْ أَطَّاسْ ن إِذَامّنْ.‘
\v 4 سِيذِي، أَربِّي ن إِسْرَائِيل، إِفَارْزْ أَيِي زِي مَارَّا ثَادَّارْثْ ن بَابَا، حِيمَا أَذْ ذوْڒغْ ذ أَجدْجِيذْ خْ إِسْرَائِيل إِ ڒبْذَا، مِينْزِي نتَّا إِفَارْزْ يَاهُوذَا حِيمَا أَذْ يِيڒِي ذ ڒْحَاكمْ، ؤُشَا \add خنِّي\add* ثَادَّارْثْ ن بَابَا زِي ثَادَّارْثْ ن يَاهُوذَا، ؤُشَا جَارْ وَارَّاونْ ن بَابَا يَارْضَا ذَايِي أَڒَامِي إِڭَّا أَيِي ذ أَجدْجِيذْ خْ مَارَّا إِسْرَائِيل.
\v 5 زِي جَارْ مَارَّا أَرَّاونْ إِنُو - مَاغَارْ سِيذِي إِوْشَا أَيِي أَطَّاسْ ن وَارَّاونْ - إِفَارْزْ نتَّا مِّي سُولِيمَانْ، حِيمَا أَذْ إِقِّيمْ خْ ڒْعَارْشْ ن ثْڭلْذَا ن سِيذِي خْ إِسْرَائِيل.
\v 6 نتَّا إِنَّا أَيِي: ’مِّيشْ سُولِيمَانْ أَذْ إِبْنَا ثَادَّارْثْ إِنُو ذ ڒمْرَاحَاثْ إِنُو، مَاغَارْ نتَّا إِ فَارْزغْ ذ مِّي ؤُ نشّْ أَذْ أَسْ إِڒِيغْ ذ بَابَاسْ.
\v 7 نشّْ أَذْ سّْمثْنغْ ثَاڭلْذِيثْ نّسْ إِ ڒبْذَا مَاڒَا نتَّا أَذْ إِضْفَارْ ثِيوصَّا ذ لْفَارَايِيضْ إِنُو س جّهْذْ، أَمْ مَامّشْ ثدْجَا أَسّْ-أَ.‘
\v 8 خنِّي ڒخُّو، \add أَذْ أَومْعڒْمغْ\add* زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا إِسْرَائِيل، أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ن سِيذِي، ؤُ ذڭْ إِمزُّوغنْ ن أَربِّي نّغْ، حِيمَا أَذْ ثحْضَامْ ؤُ أَذْ ثَارْزُومْ مَارَّا ثِيوصَّا ن سِيذِي، أَربِّي نْومْ، مَاحنْذْ أَذْ ثقِّيممْ ثتّطّْفمْ ثَامُّورْثْ ثَاصبْحَانْثْ ثَانِيثَا ذ ڒْوَارْثْ، ؤُشَا أَذْ ت ثجّمْ ذ ڒْوَارْثْ إِ ڒبْذَا إِ وَارَّاونْ نْومْ أَوَارْنِي أَومْ.
\v 9 ؤُ شكْ، مِّي سُولِيمَانْ، سّنْ أَربِّي ن بَابَاشْ ؤُ سخَّارْ أَسْ س وُوڒْ إِمُونْ ذ س ڒعْمَارْ إِوجْذنْ مِينْزِي سِيذِي إِتّْبقّشْ مَارَّا ؤُڒَاونْ ؤُشَا إِفهّمْ مَارَّا مِينْ د-إِتَّاسنْ غَارْ إِخَارِّيصنْ \add ن ؤُزدْجِيفْ نّغْ\add*. مَاڒَا شكْ ثَارْزُوذْ خَاسْ، نتَّا أَذْ زَّايكْ إِتّْوَافْ، مَاشَا مَاڒَا ثْسمْحذْ ذَايسْ، أَذْ شكْ إِنْضَارْ إِ ڒبْذَا.
\v 10 خْزَارْ ڒخُّو، مِينْزِي سِيذِي إِفَارْزْ إِ شكْ حِيمَا أَذْ أَسْ ثبْنِيذْ إِشْثْ ن ثَادَّارْثْ ذ زَّاوشْثْ إِقدّْسنْ. إِڒِي ذ أَرْيَازْ ؤُشَا أڭّْ إِ-ث!“
\m 
\v 11 ذَاوُوذْ إِوْشَا إِ مِّيسْ سُولِيمَانْ أَمذْيَا ن وسْقِيفْ ن وَاذَافْ، ن ڒبْنِييَاثْ نّسْ، ذ إِخَّامنْ ن ثْخُوبَايْ ذ ثْغُورْفَاثِينْ نّسْ، ذ إِخَّامنْ نّسْ ن ذَاخڒْ، ذ وخَّامْ إِ ثْقبَّارْثْ ن وصْڒَاحْ،
\v 12 ؤُڒَا ذ إِجّْ ن ؤُمذْيَا ن مَارَّا مِينْ غَارسْ-د يُوسَا س أَرُّوحْ خْ ڒمْرَاحَاثْ ن ثَادَّارْثْ ن سِيذِي، خْ مَارَّا إِخَّامنْ إِ ذ أَسْ د-إِنّْضنْ، خْ مَارَّا إِخَّامنْ ن ثْخُوبَايْ ن ثَادَّارْثْ ن أَربِّي ؤُ خْ إِخَّامنْ ن ثْخُوبَايْ ن ثوْهِيبِينْ إِتّْوَاقدّْسنْ،
\v 13 خْ ثرْبِيعِينْ ن إِكهَّاننْ ذ إِلَاوِييّنْ، خْ مَارَّا ڒْخذْمثْ إِ ثْسخَّارْثْ ذِي ثَادَّارْثْ ن سِيذِي ؤُ خْ مَارَّا ڒقْشُوعْ إِ ثْسخَّارْثْ ذِي ثَادَّارْثْ ن سِيذِي.
\v 14 خْ وُورغْ، أَقَا إِوْشَا ڒوْزنْ ن وُورغْ إِ مَارَّا ڒقْشُوعْ ن ثْسخَّارْثْ، ؤُڒَا إِ ڒقْشُوعْ ن نُّوقَارْثْ \add إِوْشَا\add* ڒوْزنْ \add نْسنْ\add*، إِ مَارَّا ڒقْشُوعْ إِ كُوڒْ ثَاسخَّارْثْ.
\v 15 \add إِوْشَا ؤُڒَا\add* ڒوْزنْ إِ ڒقْنَاذڒْ ن وُورغْ ذ ڒفْنَارَاثْ نْسنْ ن وُورغْ، ڒوْزنْ ن كُوڒْ ڒْقنْذِيڒْ أَكْ-ذ ڒفْنَارَاثْ نّسْ \add وحّْذسْ\add*، ؤُڒَا \add ڒوْزنْ\add* إِ ڒقْنَاذڒْ ن نُّوقَارْثْ، ڒوْزنْ إِ يِيجّْ ن ڒْقنْذِيڒْ أَكْ-ذ ڒفْنَارَاثْ نّسْ \add وحّْذسْ\add*، أَمْ مَامّشْ د-يُوسَا أَكْ-ذ ثْسخَّارْثْ ن كُوڒْ ڒْقنْذِيڒْ.
\v 16 \add عَاوذْ\add* ڒوْزنْ ن وُورغْ إِ طَّابْڒَاثْ إِ خْ بزّْعنْ أَغْرُومْ، إِ كُوڒْ طَّابْڒَا \add ڒوْزنْ نّسْ وحّْذسْ\add*، ؤُڒَا ذ \add ڒوْزنْ ن\add* نُّوقَارْثْ إِ طَّابْڒَاثْ ن نُّوقَارْثْ،
\v 17 ؤُڒَا ذ ؤُرغْ إِصْفَانْ إِ فُورْشَايَاثْ، إِ طَّاوْيَاثْ إِ ؤُرُوشِّي، إِ إِفنْجَاڒنْ ن وُورغْ أَكْ-ذ ڒوْزنْ ن كُوڒْ أَفنْجَاڒْ \add وحّْذسْ\add*، إِ إِفنْجَاڒنْ ن نُّوقَارْثْ أَكْ-ذ ڒوْزنْ إِ كُوڒْ أَفنْجَاڒْ \add وحّْذسْ\add*،
\v 18 إِ ؤُعَالْطَارْ ن ڒبْخُورْ أَكْ-ذ ڒوْزنْ \add نّسْ\add* س وُورغْ إِقُّورْ، ؤُڒَا \add أَمُّو عَاوذْ ڒوْزنْ ن\add* وُورغْ إِ ؤُمذْيَا ن ؤُكَارُّو \add ن إِجنْوَانْ\add* ن إِكِيرُوبنْ إِنِّي إِبزّْعنْ \add وَافْرِيونْ نْسنْ\add* ؤُشَا ذْڒِينْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي. \f ◼ \fr 28:‏18 \ft \bd ’إِكِيرُوبنْ‘\bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*
\m 
\v 19 مَانْ أَيَا مَارَّا، \add إِنَّا ذَاوُوذْ\add*، إِتّْوَاسّفْهمْ أَيِي س ثِيرَا زڭْ ؤُفُوسْ ن سِيذِي، مَارَّا ڒخْذَايمْ \add إِ د إِتَّاسنْ أَكْ-ذ\add* ؤُمذْيَا ن ڒبْنِي، أَقَا يُورَانْثْ ذِي ثِيرَا-يَا.
\m 
\v 20 خنِّي إِنَّا ذَاوُوذْ إِ مِّيسْ سُولِيمَانْ: ”إِڒِي ذ أَرْيَازْ، إِڒِي ثْمحْضذْ ؤُ أڭّْ إِ-ث! وَارْ تّڭّْوذْ شَا ؤُ وَارْ أَرخُّو، مَاغَارْ سِيذِي أَربِّي، أَربِّي إِنُو، أَذْ يِيڒِي أَكِيذكْ. نتَّا وَارْ ذَايكْ إِسمّحْ نِيغْ شكْ إِتّجِّي أَڒْ أَكمّڒْ ن مَارَّا ڒْخذْمثْ إِ ثْسخَّارْثْ ذِي ثَادَّارْثْ ن سِيذِي.
\v 21 خْزَارْ، أَقَا ذِينْ ثِيرْبِيعِينْ ن إِكهَّاننْ ذ إِلَاوِييّنْ إِ مَارَّا ثَاسخَّارْثْ ذِي ثَادَّارْثْ ن أَربِّي ؤُ إِ مَارَّا ڒْخذْمثْ \add أَقَا ذِينْ\add* غَاركْ مَارَّا إِنِّي إِ غَارْ ثدْجَا ذِي ڒْخَاذَارْ نْسنْ \add حِيمَا أَذْ ت ڭّنْ\add* س ثِيغِيثْ إِ كُوڒْ ڒْخذْمثْ. ؤُڒَا ذ ڒْحُوكَّامْ ذ مَارَّا ڒْڭنْسْ \add بدّنْ أَكِيذكْ،\add* حِيمَا \add أَذْ ڭّنْ\add* مَارَّا أَوَاڒنْ نّشْ.“
\b
\b
\c 29
\s1 ذَاوُوذْ إِسلّمْ ڒبْنِي ن زَّاوشْثْ ثَامقّْرَانْثْ ذ ڒْعَارْشْ إِ مِّيسْ سُولِيمَانْ
\m 
\v 1 ؤُشَا إِنَّا ؤُجدْجِيذْ ذَاوُوذْ إِ مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add*: ”مِّي سُولِيمَانْ ذ أَينِّي ونِّي إِفَارْزْ إِ-ث أَربِّي. نتَّا \add عَاذْ\add* ذ أَحُوذْرِي ذ أَرخْفنْ ؤُشَا ڒْخذْمثْ ذ ثَامقّْرَانْثْ، مَاغَارْ وَارْ إِدْجِي ڒقْصَارْ إِ يِيجّْ ن بْنَاذمْ، مَاشَا إِ سِيذِي أَربِّي.
\v 2 س مَارَّا ثِيزمَّارْ إِنُو سّْوجْذغْ إِ ثَادَّارْثْ ن أَربِّي إِنُو ؤُرغْ إِ \add ڒقْشُوعْ\add* ن وُورغْ، نُّوقَارْثْ إِ \add ڒقْشُوعْ\add* ن نُّوقَارْثْ، نّْحَاسْ إِ \add ڒقْشُوعْ\add* ن نّْحَاسْ، ؤُزَّاڒْ إِ \add ڒقْشُوعْ\add* ن وُوزَّاڒْ، أَكشُّوضْ إِ \add ڒقْشُوعْ\add* ن ؤُكشُّوضْ، ذ إِژْرَا ن ؤُنِيكْسْ ذ إِژْرَا إِبَارْشَاننْ يَارقّنْ ؤُڒَا ذ إِژْرَا إِتّْوَاسّْقَارقْشنْ مَاحنْذْ أَذْ تّْوَاڭّنْ ذِي ثْشُويَارْ، ؤُڒَا \add عَاذْ\add* عْڒَامْ كُوڒْ إِژْرَا إِغْڒَانْ \add نّغْنِي\add*، ؤُشَا \add خنِّي\add* أَطَّاسْ ن إِژْرَا ن ڒْمَارْمُورْ ذ أَشمْڒَاڒْ.
\v 3 زِي ثَايْرِي إِنُو إِ ثَادَّارْثْ ن أَربِّي إِنُو، أَذْ أَرْزْفغْ زڭْ وَاڭْڒَا إِنُو عَاذْ ؤُرغْ ذ نُّوقَارْثْ ثِيوَا إِ مِينْ سّْوجْذغْ إِ ثَادَّارْثْ ن زَّاوشْثْ إِقدّْسنْ،
\v 4 \add عَاذْ\add* ثڒْثْ-أَڒَافْ ثَالِينْثْ ن وُورغْ زڭْ وُورغْ ن ؤُفِيرْ ذ سبْعَا-أَڒَافْ ثَالِينْثْ ن نُّوقَارْثْ إِصْفَانْ مَاحنْذْ أَذْ زَّايْسنْ حنّْشنْ ڒحْيُوضْ ن إِخَّامنْ.
\v 5 ؤُرغْ إِ \add ڒقْشُوعْ ن\add* وُورغْ، نُّوقَارْثْ إِ \add ڒقْشُوعْ ن\add* نُّوقَارْثْ، إِ مَارَّا ڒْخذْمثْ \add إِ غَا ثتّْوَاڭّْ\add* س ؤُفُوسْ ن إِحْرَايْفِييّنْ. مَانْ ونْ \add خنِّي\add* إِطّوّْعنْ أَسّْ-أَ مَاحنْذْ أَذْ إِوْشْ إِ سِيذِي؟“
\m 
\v 6 \add خَاسْ ؤُشَا\add* إِوْينْ إِمقّْرَاننْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ذ إِمقّْرَاننْ ن ثْقبَّاڒْ ن إِسْرَائِيل ذ إِمقّْرَاننْ خْ وَاڒفْ ؤُ خْ مْيَا ثِيوْهِيبِينْ نْسنْ س ڒْخَاضَارْ، \add جْمِيعْ\add* أَكْ-ذ إِمقّْرَاننْ خْ ڒْخذْمثْ ن ؤُجدْجِيذْ.
\v 7 نِيثْنِي أَرْزْفنْ إِ ثْسخَّارْثْ ن ثَادَّارْثْ ن أَربِّي خمْسَا-أَڒَافْ ثَالِينْثْ ن وُورغْ ذعشْرَا-أَڒَافْ ن ذْرَاخْمَاثْ ذعشْرَا-أَڒَافْ ثَالِينْثْ ن نُّوقَارْثْ ذ ثْمنْطَاشْ-أَڒفْ ثَالِينْثْ ن نّْحَاسْ ذ مْيَاثْ-أَڒفْ ثَالِينْثْ ن وُوزَّاڒْ.
\v 8 ونِّي غَارْ ؤُفِينْ إِژْرَا \add إِغْڒَانْ\add*، إِوْشَا إِ-ثنْ إِ وخَّامْ ن ثْخُوبَايْ ن ثَادَّارْثْ ن سِيذِي ونِّي ثُوغَا سَاذُو ؤُفُوسْ ن يَاحِييِيلْ، أَجَارْشُونِي.
\v 9 إِفَارْحْ ڒْڭنْسْ س ثوْهِيبِينْ نْسنْ \add إِ إِمّوْشنْ\add* س ڒْخَاضَارْ، مَاغَارْ نِيثْنِي وْشِينْ زڭْ وُوڒْ إِمُونْ قَاعْ س ڒْخَاضَارْ إِ سِيذِي، ؤُشَا إِفَارْحْ ؤُجدْجِيذْ ذَاوُوذْ ڒفْرَاحثْ ذ ثَامقّْرَانْثْ أَطَّاسْ.
\v 10 ذَاوُوذْ إِبَاركْ سِيذِي زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add*، إِنَّا:
\b
\m ”أَذْ ثتّْوَابَارْكذْ شكْ، \add أَ\add* سِيذِي، أَربِّي ن بَابَاثْنغْ إِسْرَائِيل، زِي ڒبْذَا أَڒْ ڒبْذَا!
\m 
\v 11 إِ شكْ، \add أَ\add* سِيذِي، ڒمْغَارثْ ذ صُّولْطَا ذ ڒْعزّْ ذ مِينْ إِتّْذُومَانْ إِ ڒبْذَا ذ لْعَاضَامَا، مِينْزِي مَارَّا مِينْ إِدْجَانْ ذڭْ ؤُجنَّا ؤُ خْ ثمُّورْثْ أَقَا-ث نّشْ. زَّايكْ، \add أَ\add* سِيذِي، \add إِ ثدْجَا\add* ثَاڭلْذِيثْ، \add زَّايكْ شكْ،\add* ونِّي إِسّْڭعّْذنْ إِخفْ نّشْ ذ أَزدْجِيفْ ثِيوَا مَارَّا.
\v 12 أَڭْڒَا ذ شَّانْ زَّاثْ إِ وُوذمْ نّشْ ؤُ شكْ ثْصدْجْضذْ خْ مَارَّا \add مِينْ إِدْجَانْ\add*. أَقَا-ث جّهْذْ ذ صُّولْطَا ذڭْ ؤُفُوسْ نّشْ، أَقَا-ث ذڭْ ؤُفُوسْ نّشْ \add حِيمَا أَذْ ثوْشذْ\add* ڒمْغَارثْ ذ جّهْذْ إِ مَارَّا.
\m 
\v 13 خنِّي ڒخُّو، أَربِّي نّغْ، نشِّينْ نتّْقَاذَا شكْ ؤُ نتّْصبّحْ ذڭْ يِيسمْ ن ڒْعزّْ نّشْ.
\v 14 مَاغَارْ مِينْ عْنِيغْ نشّْ ذ مِينْ إِعْنَا ڒْڭنْسْ إِنُو، أَقَا نشِّينْ غَارْنغْ ثِيزمَّارْ أَذْ نوْشْ أَمُّو س ڒْخَاضَارْ؟ مَاغَارْ زَّايكْ د-إِتَّاسْ مَارَّا ؤُ مِينْ إِ ذ أَشْ نوْشَا، \add نوْشَا إِ-ث\add* زڭْ ؤُفُوسْ نّشْ.
\v 15 مَاغَارْ نشِّينْ مْغِيرْ ذ إِبَارَّانِييّنْ ذ إِمعْزَابْ زَّاثْ إِ وُوذمْ نّشْ، أَمْ ڒجْذُوذْ نّغْ. ؤُسَّانْ نّغْ خْ ثمُّورْثْ أَمْ ثِيڒِي ؤُ ڒَايَاسْ وَارْ ذِينْ إِدْجِي.
\m 
\v 16 \add أَ\add* سِيذِي، أَربِّي نّغْ، زڭْ ؤُفُوسْ نّشْ \add يُوسَا-د\add* مَارَّا أَفيّضْ-أَ إِ نسّوْجذْ، حِيمَا أَذْ نبْنَا إِشْثْ ن ثَادَّارْثْ إِ شكْ، إِ يِيسمْ نّشْ إِقدّْسنْ. مَارَّا أَيَا ذ نّشْ.
\v 17 نشّْ سّْنغْ، \add أَ\add* أَربِّي إِنُو، أَقَا شكْ ثْقدْجْبذْ ؤُڒْ ؤُ أَقَا إِتّعْجِيبْ أَشْ ؤُسڭّمْ. نشّْ، ذِي ڒصْفَايثْ ن وُوڒْ إِنُو، وْشِيغْ مَارَّا أَيَا س ڒْخَاضَارْ، ؤُ ڒخُّو أَقَا ؤُڒَا ذ ڒْڭنْسْ نّشْ إِ ذَا إِدْجَانْ - إِوَا ژْرِيغْ ث س ڒفْرَاحثْ - إِوْشَا أَشْ \add ثِيوْهِيبِينْ\add* س ڒْخَاضَارْ.
\m 
\v 18 \add أَ\add* سِيذِي، أَربِّي ن ڒجْذُوذْ نّغْ، \add ن\add* إِبْرَاهِيمْ ذ إِسْحَاقْ ذ إِسْرَائِيل، حْضَا \add خنِّي\add* إِ ڒبْذَا أَقَا أَيَا أَذْ يجّْ طَّابعْ خْ إِخَارِيصّنْ ذڭْ وُوڒْ ن ڒْڭنْسْ نّشْ ؤُ نْذهْ ؤُڒْ نْسنْ غَاركْ!
\v 19 أوْشْ ؤُڒَا إِ مِّي سُولِيمَانْ إِجّْ ن وُوڒْ إِمُونْ قَاعْ، مَاحنْذْ أَذْ إِحْضَا ڒُومُورَاثْ نّشْ ذ شّْهَاذثْ نّشْ ذ ثِيوصَّا نّشْ، مَاحنْذْ أَذْ يڭّْ مَارَّا ؤُ مَاحنْذْ أَذْ إِبْنَا ڒقْصَارْ-أَ \add ن زَّاوشْثْ ثَامقّْرَانْثْ\add* إِ خْ سّْوجْذغْ نشّْ.“
\b
\m 
\v 20 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add*: ”بَارْكمْ، سِيذِي، أَربِّي نْومْ!“ \add خنِّي\add* إِبَاركْ مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ. نِيثْنِي ؤُضَارنْ، بنْذْقنْ إِ سِيذِي ؤُ إِ ؤُجدْجِيذْ.
\v 21 ثِيوشَّا نّسْ إِوْينْ نِيثْنِي ثِيغَارْصَا إِ سِيذِي. نِيثْنِي إِوْينْ أَڒفْ ن إِفُونَاسنْ إِمژْيَاننْ ذ أَڒفْ ن إِشَارِّييّنْ ذ أَڒفْ ن إِزْمَارنْ أَكْ-ذ مَارَّا ثِيوْهِيبِينْ نْسنْ ن ؤُسيّبْ ذ ثْغَارْصَا ن وشْمَاضْ إِ سِيذِي ؤُ \add خنِّي\add* أَطَّاسْ ن ثْغَارْصَا إِ مَارَّا إِسْرَائِيل.
\v 22 ذڭْ وَاسّْ نِّي شِّينْ ؤُ سْوِينْ نِيثْنِي س ڒفْرَاحثْ ثَامقّْرَانْثْ زَّاثْ إِ وُوذمْ ن سِيذِي ؤُ ڭِّينْ سُولِيمَانْ، مِّيسْ ن ذَاوُوذْ، ذ أَجدْجِيذْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ ؤُ ذهْننْ \add ث\add* ذ ڒْحَاكمْ زَّاثْ إِ سِيذِي، ؤُ صَاذُوقْ \add ذهْننْ ث\add* ذ أَكهَّانْ.
\v 23 سُولِيمَانْ إِقِّيمْ خْ ڒْعَارْشْ ن سِيذِي أَمْ ؤُجدْجِيذْ ذڭْ ومْشَانْ ن بَابَاسْ ذَاوُوذْ. نتَّا إِفْڒحْ ؤُ مَارَّا إِسْرَائِيل إِسْڒَا أَسْ.
\v 24 مَارَّا ڒْحُوكَّامْ ذ أَيْثْ ن بُو-ثغْرُوضْثْ ؤُڒَا ذ مَارَّا أَرَّاونْ ن ؤُجدْجِيذْ ذَاوُوذْ، وْثِينْ ذڭْ ؤُفُوسْ أَذْ قِّيمنْ سَاذُو \add أَفُوسْ ن\add* ؤُجدْجِيذْ سُولِيمَانْ.
\v 25 يَارَّا سِيذِي سُولِيمَانْ أَذْ إِذْوڒْ ذ أَمقّْرَانْ أَڒْ طَّارْفْ زَّاثْ إِ ثِيطَّاوِينْ ن إِسْرَائِيل. نتَّا إِوْشَا أَسْ أَوقَّارْ إِڭلّْذنْ إِ ثُوغَا وَارْ إِدْجِي ؤُڒَا غَارْ إِجّْ ن ؤُجدْجِيذْ خْ إِسْرَائِيل قْبڒْ نّسْ.
\b
\m 
\v 26 \add أَمُّو\add* إِ إِحْكمْ ذَاوُوذْ، مِّيسْ ن يَاسَّا، خْ مَارَّا إِسْرَائِيل.
\v 27 ؤُسَّانْ نِّي ثُوغَا إِحْكمْ خْ إِسْرَائِيل، أَقَا أَثنْ أَربْعِينْ ن إِسڭّْوُوسَا. نتَّا إِحْكمْ ذِي حَابْرُونْ سبْعَا ن إِسڭّْوُوسَا ؤُ ذِي ؤُرْشَالِيمْ ثْڒَاثَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا.
\m 
\v 28 نتَّا إِمُّوثْ ؤُمِي إِشَابْ مْلِيحْ، إِجِّيونْ ؤُسَّانْ، أَڭْڒَا ذ ؤُعُودْجِي. مِّيسْ سُولِيمَانْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\b
\m 
\v 29 إِمزْرُوينْ ن ؤُجدْجِيذْ ذَاوُوذْ، إِمزْوُورَا ذ إِنڭُّورَا، أَقَا تّْوَازمّمنْ ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن ؤُمْوَاڒَاوْ شَامْوِيلْ ؤُ ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن ؤُنَابِي نَاثَانْ ؤُ ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن ؤُمْوَاڒَاوْ جَاذْ،
\v 30 س مَارَّا \add مِينْ يُورَانْ\add* خْ ثْڭلْذِيثْ نّسْ ؤُ خْ صُّولْطَا نّسْ ؤُ خْ ڒْمِيجَاڒَاثْ ن ڒْوقْثْ إِ خَاسْ د-إِكِّينْ ؤُڒَا خْ إِسْرَائِيل ؤُ خْ مَارَّا ثِيڭلْذِيوِينْ ن ثمُّورَا. 
