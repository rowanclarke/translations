\id LAM  
\h TangilńĀulau 
\toc1 Ko E Ngaahi TangilńĀulau  Ľa Selemaia 
\toc2 TangilńĀulau 
\toc3 TngL 
\mt2 KO E TOHI  
\mt3  ĽOE NGAAHI TANGILńÄULAU  ĽA  
\mt1 SELEMAIA  
\cl KO E VAHE  
\c 1  
\cd \it 1  ĽAe kovi  Ľo SelŇęsalema ko e me Ľa  Ľi he Ľene angahala. 12  ĽOku ne tangi koe Ľuhi ko  Ľene mamahi, 18 Pea  Ľoku fakahńĀ  Ľoku mńĀ Ľoni Ľoni  Ľae ngaahi fakamaau  Ľae  ĽOtua.\it*  
\p
\v 1 ‚ÄĆ ĽOiau!  ĽAe nofo lala pe  Ľae kolo  
\q2  Ľaia na Ľe pito  Ľi he kakai!  
\q1 Kuo ne hoko  Ľo hangńď ko e fefine kuo mate hono  Ľunoho!  
\q1 Ko ia,  Ľaia na Ľe lahi  Ľi he ngaahi pule Ľanga,  
\q1 pea hangńď ko e  Ľeiki fefine ki he ngaahi potu pule Ľanga,  
\q2 kuo hoko ia ko e fai tukuhau!   
\b  
\q1
\v 2 ‚ÄĆ ĽOku ne tangi mamahi  Ľi he pŇć,  
\q2 pea  Ľoku  Ľi hono kou Ľahe  Ľa hono lo Ľimata;  
\q1  Ľi he Ľene ngaahi kaume Ľa kotoa pńď,  
\q2  Ľoku  Ľikai ha taha ke fakafiemńĀlie ia:  
\q1 kuo fai kńĀkńĀ  Ľa  Ľene ngaahi kaume Ľa kotoa pńď kiate ia,  
\q2 kuo nau hoko ko hono ngaahi fili.   
\b  
\q1
\v 3 Kuo  Ľalu  Ľa Siuta ki he pŇćpula, koe Ľuhi ko e mamahi pea koe Ľuhi ko e ngńĀue lahi:  
\q1  Ľoku ne nofo mo e hiteni,  
\q2  Ľoku  Ľikai te ne  Ľilo ha fiemńĀlie:  
\q2 na Ľe ma Ľu ia  Ľe he kau fakatanga kotoa pńď  Ľi he ngaahi potu lausi Ľi.   
\b  
\q1
\v 4 ‚ÄĆ ĽOku tangi  Ľae ngaahi hala  Ľo Saione,  
\q2 koe Ľuhi  Ľoku  Ľikai ha ni Ľihi ke ha Ľu ki he ngaahi kńĀtoanga mamafa:  
\q1  Ľoku lala hono ngaahi matapńĀ kotoa pńď:  
\q2  Ľoku mafulu  Ľene kau taula Ľeiki,  
\q1  Ľoku mamahi Ľia  Ľene kau tńĀupo Ľou,  
\q2 pea  Ľoku ne  Ľi he kona.   
\b  
\q1
\v 5 ‚ÄĆ ĽOku mńĀ Ľolunga  Ľa hono ngaahi fili,  
\q2  Ľoku tupu lelei hono ngaahi fili;  
\q1 he kuo fakamamahi Ľi ia  Ľe Sihova koe Ľuhi ko e lahi  Ľo  Ľene ngaahi angahala:  
\q2 kuo  Ľalu  Ľene fńĀnau ki he pŇćpula  Ľi he  Ľao  Ľoe fili.   
\b  
\q1
\v 6 Pea kuo mole  Ľae hoihoifua kotoa pńď mei he  Ľofefine  Ľo Saione:  
\q2 kuo hoko  Ľa  Ľene ngaahi hou Ľeiki  Ľo hangńď ko e fanga ha Ľate  Ľoku  Ľikai ke  Ľilo ha potu ke kai,  
\q2 pea kuo nau hola ta ĽehamńĀlohi  Ľi he  Ľao  Ľo ia  Ľoku tuli.   
\b  
\q1
\v 7 Na Ľe manatu  Ľe SelŇęsalema  Ľi he ngaahi  Ľaho  Ľo  Ľene mahaki mo  Ľene ngaahi mamahi,  
\q2  Ľa  Ľene me Ľa mńĀlie kotoa pńď  Ľaia na Ľa ne ma Ľu  Ľi he ngaahi  Ľaho  Ľi mu Ľa,  
\q1  Ľaia na Ľe tŇć  Ľa  Ľene kakai ki he nima  Ľoe fili,  
\q2 pea na Ľe  Ľikai ha tokoni kiate ia:  
\q2 na Ľe mamata  Ľae kau fili kiate ia pea nau taukae ki hono ngaahi  Ľaho tapu.   
\q1
\v 8 Kuo fai kovi lahi  Ľe SelŇęsalema ko ia kuo fetukutuku ai ia:  
\q2 ko kinautolu kotoa pńď na Ľe faka Ľapa Ľapa kiate ia  Ľoku nau manuki ki ai,  
\q1 koe Ľuhi kuo nau mamata ki he Ľene telefua:  
\q2  Ľio,  Ľoku ne mafulu pea foki ki mui.   
\q1
\v 9 ‚ÄĆ ĽOku  Ľi hono kapa Ľi kofu  ĽńĀ  Ľene  Ľuli;  
\q2  Ľoku  Ľikai ha manatu  Ľiate ia ki hono ngata Ľanga;  
\q1 ko ia na Ľa ne tŇć hifo fakamanavahńď:  
\q1 na Ľe  Ľikai  Ľiate ia ha taha ke fakafiemńĀlie.  
\q2  ĽE Sihova ke ke  Ľafio ki he Ľeku mamahi:  
\q2 he kuo fakahikihiki  Ľe ia ia,  Ľe he fili.   
\q1
\v 10 Kuo mafao  Ľae fili  Ľa hono nima ki he Ľene ngaahi me Ľa lelei kotoa pńď:  
\q2 he kuo ne mamata na Ľe hŇę  Ľae hiteni ki hono potu tapu,  
\q2  Ľaia na Ľa ke fekau, ke  Ľoua na Ľa nau hoko atu ki ho Ľo kakai.   
\q1
\v 11 ‚ÄĆ ĽOku mafulu  Ľa  Ľene kakai kotoa pńď,  Ľoku nau kumi mńĀ,  
\q2 kuo nau foaki  Ľenau ngaahi me Ľa lelei ko e me Ľakai, ke tokoni  Ľae laumńĀlie:  
\q1 ‚Äú ĽE Sihova ke ke  Ľafio pea vakai;  
\q2 he kuo u hoko  Ľo fakalielia.‚ÄĚ   
\q1
\v 12 ‚ÄúKo ha me Ľa noa pe eni kiate kimoutolu,  Ľakimoutolu kotoa pńď  Ľoku  Ľalu ange?  
\q2 Vakai, pea mamata, pe  Ľoku ai ha mamahi  Ľo hangńď ko  Ľeku mamahi,  
\q2  Ľaia  Ľoku fai kiate au,  
\q2  Ľaia kuo fakamamahi  Ľaki au  Ľe Sihova  Ľi he  Ľaho  Ľo hono houhau lahi.   
\q1
\v 13 ‚ÄúKuo ne fakahifo mei  Ľolunga  Ľae afi ki hoku ngaahi hui,  
\q2 pea  Ľoku ne mńĀlohi ki ai:  
\q1 kuo ne fola ha kupenga ki hoku va Ľe; kuo ne fakatafoki Ľi au ki mui:  
\q2 kuo ne ngaohi au ko e li Ľaki mo e vaivai  Ľi he  Ľaho kotoa pńď.   
\q1
\v 14 ‚ÄúKo e no Ľo  Ľo  Ľeku ngaahi angahala, kuo ha Ľi  Ľaki hono nima:  
\q2  Ľoku nau fihi,  
\q2 pea  Ľoku a Ľu hake ki hoku kia: kuo ne pule ke hinga  Ľa  Ľeku mńĀlohi,  
\q1 kuo tukuange au  Ľe Sihova ki honau nima,  
\q2 pea  Ľoku  Ľikai te u mafai ke tu Ľu hake.   
\b  
\q1
\v 15 ‚ÄúKuo malaki hifo  Ľe Sihova  Ľa  Ľeku kau tangata mńĀlohi kotoa pńď,  
\q2  Ľi hoku hao Ľanga: kuo ne ui ha fakataha kiate au ke ta Ľomia  Ľeku kau talavou:  
\q2 kuo molomoloki  Ľe Sihova  Ľae tńĀupo Ľou, ko e  Ľofefine  Ľo Siuta,  Ľo hangńď  Ľi ha tata Ľo Ľanga uaine.   
\b  
\q1
\v 16 ‚ÄúKoe Ľuhi ko e ngaahi me Ľa ni  Ľoku ou tangi;  
\q2 ko hoku mata, ko hoku mata  Ľoku tafe hifo  Ľi he vai,  
\q1 koe Ľuhi  Ľoku mama Ľo meiate au  Ľae fakafiemńĀlie na Ľe totonu ke tokoni hoku laumńĀlie:  
\q1  Ľoku li Ľaki pe  Ľeku fńĀnau,  
\q2 koe Ľuhi na Ľe mńĀlohi mai  Ľae fili.‚ÄĚ   
\b  
\q1
\v 17 ‚Äú ĽOku mafao atu  Ľe Saione  Ľa hono nima,  
\q2 pea  Ľoku  Ľikai ha ni Ľihi ke fakafiemńĀlie kiate ia:  
\q1 kuo fekau  Ľe Sihova kia Sńďkope,  
\q2 ke takatakai ia  Ľe hono ngaahi fili:  
\q2  Ľoku hangńď ha fefine mahaki  Ľa SelŇęsalema  Ľiate kinautolu.   
\b  
\q1
\v 18 ‚Äú ĽOku mńĀ Ľoni Ľoni  Ľa Sihova;  
\q2 he kuo u fai talangata Ľa ki he Ľene fekau;  
\q1  Ľoku ou kole kiate kimoutolu  Ľae kakai kotoa pńď fanongo,  
\q2 pea mou vakai ki he Ľeku mamahi:  
\q1 kuo  Ľalu  Ľeku kau tńĀupo Ľou mo  Ľeku kau talavou ki he pŇćpula.   
\b  
\q1
\v 19 ‚ÄúNe u ui ki he Ľeku kau mamana,  
\q2 ka na Ľa nau kńĀkaa Ľi au:  
\q1 ko  Ľeku kau taula Ľeiki mo  Ľeku kau mńĀtu Ľa na Ľa nau tukuange  Ľa honau laumńĀlie  Ľi he kolo,  
\q2  Ľi he Ľenau kei kumi me Ľakai ke fakafiemńĀlie honau laumńĀlie.   
\q1
\v 20 ‚Äú ĽAfio mai  Ľe Sihova, he  Ľoku ou mamahi:  
\q2  Ľoku ngaue mamahi hoku fatu;  
\q1 kuo liliu hoku loto  Ľiate au;  
\q2 he kuo u fai talangata Ľa  Ľaupito;  
\q1  Ľitu Ľa a  Ľoku fakamasiva  Ľe he heletńĀ,  
\q2 pea  Ľoku  Ľi he loto fale  Ľae mate.   
\b  
\q1
\v 21 ‚ÄúKuo nau fanongo  Ľoku ou mafulu:  
\q2  Ľoku  Ľikai ha taha ke fakafiemńĀlie kiate au,  
\q1 kuo fanongo  Ľa hoku ngaahi fili kotoa pńď ki he Ľeku mamahi;  
\q2  Ľoku nau fiefia koe Ľuhi kuo ke fai ia:  
\q1 he te ke fakahokosia  Ľae  Ľaho kuo ke tu Ľutu Ľuni,  
\q2 pea te nau hoko pe  Ľo hangńď ko au.   
\b  
\q1
\v 22 ‚ÄúTuku ke hoko ki ho  Ľao  Ľa  Ľenau ngaahi angahala kotoa pńď;  
\q2 pea ke fai kiate kinautolu,  Ľo hangńď ko ia kuo ke fai kiate au,  
\q1 koe Ľuhi ko  Ľeku ngaahi angahala kotoa pńď:  
\q1 he  Ľoku lahi  Ľeku mafulu,  
\q2 pea  Ľoku vaivai hoku loto.‚ÄĚ   
\c 2  
\cd \it 1  ĽOku tangi  Ľa Selemaia  Ľi he mamahi  Ľo SelŇęsalema. 20  ĽOku ne fakahńĀ ia ki he  ĽOtua.\it*  
\p
\v 1 Hono  Ľikai  Ľufi Ľufi  Ľe Sihova  Ľae  Ľofefine  Ľo Saione  Ľaki  Ľae  Ľao  Ľi hono houhau!  
\q2 Pea fakahifo mei he langi ki mńĀmani  Ľae nńĀunau  Ľo  ĽIsileli,  
\q2 pea ta Ľemanatu ki hono tu Ľunga va Ľe  Ľi he  Ľaho  Ľo hono houhau!   
\b  
\q1
\v 2 Kuo folo hifo  Ľe Sihova  Ľae ngaahi nofo Ľanga  Ľo Sńďkope,  
\q2 pea na Ľe  Ľikai te ne manava Ľofa;  
\q1 kuo ne holoki hifo  Ľi hono houhau  Ľae ngaahi potu mńĀlohi  Ľoe  Ľofefine  Ľo Siuta;  
\q2 kuo ne hifo  Ľakinautolu ki he kelekele:  
\q2 kuo ne faka Ľuli Ľi  Ľae pule Ľanga mo e ngaahi hou Ľeiki  Ľo ia.   
\b  
\q1
\v 3 Kuo ne tutu Ľu  Ľi hono houhau lahi  Ľae nifo kotoa pńď  Ľo  ĽIsileli:  
\q2 kuo ne to Ľo  Ľa hono nima to Ľomata Ľu mei he  Ľao  Ľoe fili,  
\q1 pea ne vela kia Sńďkope  Ľo hangńď ko e afi kakaha,  
\q2  Ľaia  Ľoku faka Ľauha takatakai.   
\q1
\v 4 Kuo ne teke  Ľa  Ľene kaufana  Ľo hangńď ha fili:  
\q2 na Ľa ne tu Ľu mai mo hono nima to Ľomata Ľu  Ľo hangńď ha fili,  
\q1 pea ne tńĀmate Ľi  Ľakinautolu kotoa pńď na Ľe hoihoifua  
\q2  Ľi he fale fehikitaki  Ľoe  Ľofefine  Ľo Saione: na Ľa ne lilingi hono houhau  Ľo hangńď ko e afi.   
\b  
\q1
\v 5 Na Ľe hoko  Ľa Sihova ke tatau mo e fili:  
\q2 kuo ne folo hifo  Ľa  ĽIsileli,  
\q1 kuo ne folo hifo  Ľa hono ngaahi fale lelei kotoa pńď:  
\q2 kuo ne maumau Ľi  Ľa hono ngaahi potu mńĀlohi,  
\q2 pea kuo ne fakatupu ki he  Ľofefine  Ľo Saione  Ľae mamahi mo e tangi.   
\b  
\q1
\v 6 Pea kuo ne  Ľave fakamńĀlohi  Ľa hono fale fehikitaki,  
\q2  Ľo hangńď ko ha me Ľa  Ľoe ngoue:  
\q1 kuo ne faka Ľauha  Ľae ngaahi potu  Ľoe fakataha:  
\q2 kuo ngaohi  Ľe Sihova ke ngalo  Ľae ngaahi kńĀtoanga mamafa mo e ngaahi  Ľaho tapu  Ľi Saione,  
\q2 pea kuo ne manuki  Ľi hono houhau lahi  Ľae tu Ľi mo e taula Ľeiki.   
\b  
\q1
\v 7 Kuo li Ľaki  Ľe Sihova  Ľa hono feilaulau Ľanga,  
\q2 kuo ne fehi Ľa ki hono potu tapu,  
\q1 kuo ne tukuange ki he nima  Ľoe fili  Ľae ngaahi holisi  Ľo hono ngaahi fale lelei;  
\q2 kuo nau mavava  Ľi he fale  Ľo Sihova,  
\q2  Ľo hangńď  Ľi he  Ľaho  Ľoe kńĀtoanga mamafa.   
\b  
\q1
\v 8 Kuo finangalo  Ľa Sihova ke maumau  Ľae  ĽńĀ  Ľoe  Ľofefine  Ľo Saione:  
\q2 kuo ne falŇć ha afo,  
\q2 na Ľe  Ľikai te ne ta Ľofi hono nima mei he faka Ľauha:  
\q1 ko ia na Ľa ne ngaohi  Ľae tanu mo e  ĽńĀ ke tangi;  
\q2 na Ľa nau faka Ľa Ľau ki mui fakataha.   
\b  
\q1
\v 9 Kuo ngalo hifo  Ľi he kelekele  Ľa hono ngaahi matapńĀ:  
\q2 kuo ne fesi Ľi mo maumau Ľi hono ngaahi  Ľakau songo;  
\q1  Ľoku  Ľi he kakai Senitaile  Ľa hono tu Ľi mo hono hou Ľeiki:  Ľoku  Ľikai ha fono:  
\q1 ko  Ľene kau palŇćfita foki  Ľoku  Ľikai ke kei  Ľilo ha me Ľa hńĀ mai meia Sihova.   
\b  
\q1
\v 10 ‚ÄĆ ĽOku nofo hifo  Ľi he kelekele  
\q2 pea  Ľoku longo pe  Ľae kau mńĀtu Ľa  Ľoe  Ľofefine  Ľo Saione:  
\q1 kuo nau pani efu  Ľa honau  Ľulu;  
\q2 kuo nau fakavala  Ľaki  Ľakinautolu  Ľae tauanga Ľa:  
\q2 ko e kau tńĀupo Ľou  Ľo SelŇęsalema  Ľoku nau fakatŇćmape Ľe honau  Ľulu  Ľo a Ľu ki he kelekele.   
\b  
\q1
\v 11 ‚ÄĆ ĽOku vaivai  Ľi he lo Ľimata  Ľa hoku mata,  
\q2  Ľoku ngaue hoku fatu,  
\q1  Ľoku lilingi hoku  Ľate ki he kelekele,  
\q2 ko e me Ľa  Ľi he faka Ľauha  Ľae  Ľofefine  Ľo hoku kakai;  
\q2 koe Ľuhi  Ľoku pongia  Ľae tamaiki mo e kau valevale  Ľi he ngaahi hala  Ľoe kolo.   
\q1
\v 12 ‚ÄĆ ĽOku nau pehńď ki he Ľenau ngaahi fa Ľńď,  
\q2 ‚ÄúKofa ĽńĀ  Ľae koane mo e uaine?‚ÄĚ  
\q2  ĽI he Ľenau pongia  Ľo hangńď ko e kau kafo  Ľi he hala  Ľoe kolo,  
\q2  Ľi he  Ľaho ko ia,  Ľaia na Ľe lilingi ai  Ľa honau laumńĀlie ki he fatafata  Ľo  Ľenau ngaahi fa Ľńď.   
\b  
\q1
\v 13 Ko e hńĀ te u  Ľatu ke fakamo Ľoni kiate koe?  
\q2 Ko e hńĀ te u fakatńĀtńĀ  Ľaki kiate koe  Ľe  Ľofefine  Ľo SelŇęsalema?  
\q1 Ko e hńĀ te u fakatatau mo koe,  
\q2 koe Ľuhi ke u fakafiemńĀlie Ľi koe  Ľe  Ľofefine  Ľo Saione?  
\q1 He ko ho Ľo maumau  Ľoku lahi  Ľo hangńď ko e lahi:  
\q2 ko hai  Ľe fakamo Ľui koe?   
\b  
\q1
\v 14 Kuo  Ľilo  Ľe ho Ľo kau palŇćfita  Ľae ngaahi me Ľa va Ľinga mo vale koe Ľuhi ko koe:  
\q2 pea na Ľe  Ľikai te nau fakahńĀ ho Ľo kovi  
\q2 koe Ľuhi ke faka Ľafe Ľi ho Ľo pŇćpula;  
\q2 ka kuo nau  Ľilo koe Ľuhi ko koe  Ľae ngaahi kikite loi, mo ngaahi me Ľa fakahńď.   
\b  
\q1
\v 15 ‚ÄĆ ĽOku pasi kiate koe  Ľakinautolu kotoa pńď  Ľoku  Ľalu ange;  
\q2  Ľoku nau  Ľisa mo kalokalo honau  Ľulu ki he  Ľofefine  Ľo Selusalema,  
\q1  Ľo nau pehńď, ‚ÄúKo eni końĀ  Ľae kolo  Ľaia  Ľoku ui  Ľe he kakai ko e toulekeleka haohaoa,  
\q2 ko e fiefia Ľanga  Ľo mńĀmani kotoa pńď?‚ÄĚ   
\q1
\v 16 Kuo fakamanga honau ngutu kiate koe  Ľe ho kau fili kotoa pńď:  
\q2  Ľoku nau  Ľisa pea fengai Ľitaki  Ľae nifo:  
\q2  Ľonau pehńď, ‚ÄúKuo tau folo hifo ia:  
\q1 ko e mo Ľoni ko eni  Ľae  Ľaho na Ľa tau  Ľamanaki ki ai kuo tau  Ľilo,  
\q2 kuo tau mamata ai.‚ÄĚ   
\b  
\q1
\v 17 Kuo fai  Ľe Sihova  Ľaia na Ľa ne filio Ľi;  
\q2 kuo ne fakamo Ľoni ki he Ľene folofola  Ľaia na Ľa ne fekau  Ľi he ngaahi  Ľaho  Ľi mu Ľa:  
\q1 kuo ne holoki hifo,  
\q2 pea na Ľe  Ľikai te ne manava Ľofa;  
\q1 pea kuo ne pule ke fiefia ho fili kiate koe,  
\q2 kuo ne fokotu Ľu ki  Ľolunga  Ľae nifo  Ľo ho kau fili.   
\b  
\q1
\v 18 Na Ľe tangi honau loto kia Sihova,  
\q1  ĽE  ĽńĀ  Ľoe  Ľofefine  Ľo Saione,  
\q2 tuku ke tafe hifo  Ľae ngaahi lo Ľimata  Ľi he  Ľaho mo e pŇć,  Ľo hangńď ha vaitafe:  
\q1  Ľoua na Ľa ke malolŇć; ke  Ľoua na Ľa tuku  Ľe ho kano Ľi mata.   
\b  
\q1
\v 19 Tu Ľu hake, pea ke kalanga  Ľi he pŇć,  
\q2  Ľi he kamata Ľanga  Ľoe ngaahi le Ľo,  
\q1 hua Ľi ho loto  Ľo hangńď ko e vai  Ľi he  Ľao  Ľoe fofonga  Ľoe  ĽEiki:  
\q2 hiki hake ho nima kiate ia koe Ľuhi ke mo Ľui  Ľa ho Ľo tamaiki iiki,  
\q2  Ľaia  Ľoku mate fiekaia,  Ľi he mu Ľa hala kotoa pńď.   
\b  
\q1
\v 20 ‚Äú ĽE  ĽEiki ke ke vakai pea tokanga kiate kinautolu kuo ke fai pehńď ki ai.  
\q2  ĽE kai  Ľe he kau fefine  Ľa honau fua,  
\q2 mo e tamaiki,  Ľoku hanga pe taha  Ľa honau lŇćloa?  
\q2  ĽE mate tńĀmate Ľi,  Ľae taula Ľeiki mo e palŇćfita  Ľi he fale tapu  Ľo Sihova?   
\b  
\q1
\v 21 ‚Äú ĽAe kakai talavou mo e mńĀtu Ľa  Ľoku nau tokoto  Ľi he kelekele  Ľi he ngaahi hala:  
\q2 kuo tŇć  Ľi he heletńĀ  Ľeku kau tńĀupo Ľou mo  Ľeku kau talavou:  
\q1 kuo ke tńĀmate Ľi  Ľakinautolu  Ľi he  Ľaho  Ľo ho houhau;  
\q2 kuo ke tńĀmate Ľi pea  Ľikai manava Ľofa.   
\b  
\q1
\v 22 Kuo ke uiui Ľi  Ľae ngaahi fakamanavahńď ke kńĀpui au,  Ľo hangńď  Ľi ha  Ľaho mamafa,  
\q2 ko ia na Ľe  Ľikai si Ľi ke hao pe toe ha ni Ľihi  Ľi he  Ľaho  Ľoe houhau  Ľo Sihova:  
\q2  Ľakinautolu na Ľe fakakofu Ľi mo tauhi Ľi  Ľeau kuo faka Ľauha  Ľe he fili.   
\c 3  
\cd \it 1  ĽOku tangi  Ľae kau fai totonu koe Ľuhi ko  Ľenau ngaahi mamahi. 22 Ko e me Ľa  Ľi he  Ľalo Ľofa  Ľae  ĽEiki  Ľoku tu Ľuma Ľu  Ľenau  Ľamanaki. 37  ĽOku nau fakahńĀ  Ľae angatonu  Ľae  ĽOtua. 55  ĽOku nau kole  Ľae fakahaofi, 64 Mo e tautea ki honau kau fili.\it*  
\q1
\v 1 Ko au ko e tangata kuo mamata ki he mamahi  
\q2  Ľi he me Ľa tńĀ  Ľa hono houhau.   
\q1
\v 2 Kuo ne tataki au mo  Ľomi au ki he po Ľuli,  
\q2 kae  Ľikai ki he maama.   
\q1
\v 3 Ko e mo Ľoni kuo ne liliu kiate au,  
\q2  Ľoku ne liliu hono nima kiate au  Ľi he  Ľaho kotoa.   
\q1
\v 4 Ko hoku kili mo hoku kakano kuo ne ngaohi ke motu Ľa;  
\q2 kuo ne fesi Ľi hoku ngaahi hui.   
\q1
\v 5 Kuo ne langa Ľi me Ľa kiate au,  
\q2 pea kuo ne takatakai au  Ľaki  Ľae kona mo e mamahi.   
\q1
\v 6 Kuo ne fokotu Ľu au  Ľi he ngaahi potu fakapo Ľuli,  
\q2  Ľo hangńď ko kinautolu na Ľe pekia  Ľi mu Ľa.   
\b  
\q1
\v 7 Kuo ne  ĽńĀ Ľi takatakai au pea  Ľoku  Ľikai te u fa Ľa hao kitu Ľa:  
\q2 kuo ne fakamamafa  Ľa  Ľeku ha Ľi ukamea.   
\q1
\v 8 ‚ÄĆ ĽO kau ka tangi foki mo kalanga,  
\q2  Ľoku ne ta Ľetokanga Ľi  Ľeku kole.   
\q1
\v 9 Kuo ne  ĽńĀ Ľi hoku ngaahi hala  Ľaki  Ľae ngaahi maka kuo tńĀ,  
\q2 kuo ne fakapiko Ľi hoku ngaahi hala.   
\q1
\v 10 Na Ľa ne hangńď ha pea  Ľoku toitoi kiate au,  
\q2 pea hangńď ha laione  Ľi he ngaahi potu lilo.   
\q1
\v 11 Kuo ne mimio Ľi hoku ngaahi  Ľalu Ľanga,  
\q2 pea kuo ne haehae au fakaikiiki:  
\q2 kuo ne ngaohi au ke lala pe.   
\q1
\v 12 Kuo ne teke  Ľa  Ľene kaufana,  
\q2 pea kuo ne fokotu Ľu au ko e faka Ľilonga ki he ngahau.   
\b  
\q1
\v 13 Kuo ne pule ki he ngaahi ngahau  Ľo  Ľene tangai ke  Ľasi ki hoku ngaahi kongaloto.   
\q1
\v 14 Ko e manuki Ľanga au ki hoku kakai;  
\q2 pea ko  Ľenau tńĀ Ľanga  Ľi he  Ľaho kotoa pńď.   
\q1
\v 15 Kuo ne fakafonu au  Ľaki  Ľae kona,  
\q2 kuo ne fakakona Ľi au  Ľaki  Ľae kona Ľi Ľńę.   
\b  
\q1
\v 16 Kuo ne fesi Ľi foki hoku kau nifo  Ľaki  Ľae kilikili,  
\q2 kuo ne pani au  Ľaki  Ľae efu.   
\q1
\v 17 Pea kuo ke hiki hoku laumńĀlie ke mama Ľo mei he melino:  
\q2 na Ľe ngalo  Ľiate au  Ľae monŇę Ľia.   
\q1
\v 18 Pea ne u pehńď, ‚ÄúKo  Ľeku mńĀlohi  
\q2 mo  Ľeku  Ľamanaki kuo  Ľauha meia Sihova;‚ÄĚ   
\b  
\q1
\v 19 ‚ÄĆ ĽI he Ľeku manatu ki hoku mahaki pea mo  Ľeku mamahi,  Ľae kona pea mo e  Ľahu.   
\q1
\v 20 ‚ÄĆ ĽOku kei manatu ki ai hoku laumńĀlie, pea  Ľoku angavaivai ia  Ľiate au.   
\b  
\q1
\v 21 Ko ia  Ľoku ou fakamanatu ki hoku loto,  
\q2 pea ko ia  Ľoku ou kei ma Ľu ai  Ľae  Ľamanaki.   
\q1
\v 22 Ko e me Ľa  Ľi he  Ľalo Ľofa  Ľa Sihova  Ľoku  Ľikai te tau  Ľauha,  
\q2 koe Ľuhi  Ľoku  Ľikai ke ngata  Ľene manava Ľofa.   
\q1
\v 23 ‚ÄĆ ĽOku fo Ľou ia  Ľi he pongipongi kotoa pńď,  
\q2  Ľoku lahi ho Ľo angatonu.   
\q1
\v 24 ‚ÄĆ ĽOku pehńď  Ľe hoku laumńĀlie, ‚ÄúKo hoku tofi Ľa  Ľa Sihova:  
\q2 ko ia te u  Ľamanaki lelei  Ľiate ia.‚ÄĚ   
\q1
\v 25 ‚ÄĆ ĽOku lelei  Ľa Sihova kiate kinautolu  Ľoku tatali kiate ia,  
\q2 ki he laumńĀlie  Ľoku kumi kiate ia.   
\q1
\v 26 ‚ÄĆ ĽOku lelei ki he tangata ke ne  Ľamanaki,  
\q2 pea ne tatali fakatatoka foki ki he fakamo Ľui meia Sihova.   
\q1
\v 27 ‚ÄĆ ĽOku lelei ki he tangata ke ne fua  Ľae ha Ľamo  Ľi he Ľene kei talavou.   
\b  
\q1
\v 28 ‚ÄĆ ĽOku ne nofo tokotaha pe, pea  Ľoku longo pe,  
\q2 koe Ľuhi kuo ne fua ia  Ľe ia pe.   
\q1
\v 29 ‚ÄĆ ĽOku ne  Ľai hono ngutu  Ľi he efu,  
\q2 ko e me Ľa na Ľa  Ľoku kei ai ha  Ľamanaki.   
\q1
\v 30 ‚ÄĆ ĽOku ne tuku hono kou Ľahe kiate ia  Ľoku ne taa Ľi ia:  
\q2  Ľoku ne pito  Ľaupito  Ľi he lau Ľi kovi.   
\b  
\q1
\v 31 He koe Ľuhi  Ľe  Ľikai li Ľaki ke lauikuonga  Ľe Sihova:   
\q2
\v 32 He kapau te ne fakamamahi,  
\q2 ka te ne manava Ľofa foki  Ľo fakatatau ki hono lahi  Ľo  Ľene ngaahi  Ľalo Ľofa.   
\q1
\v 33 He  Ľoku  Ľikai te ne fie tautea,  
\q2 pe fakamamahi  Ľae fńĀnau  Ľae tangata.   
\b  
\q1
\v 34 Ke laiki  Ľi hono lalo va Ľe  Ľae ngaahi pŇćpula kotoa pńď  Ľo mńĀmani,   
\q2
\v 35 Ke fakatafe  Ľae totonu  Ľoe tangata  Ľi he  Ľao  Ľoe fofonga  Ľoe Fungani MńĀ Ľoni Ľoni,   
\q2
\v 36 Ke kńĀkaa Ľi  Ľae tangata  Ľi hono fakamaau Ľi  Ľoku  Ľikai lelei ai  Ľa Sihova.   
\b  
\q1
\v 37 Ko hai ia  Ľoku fakahńĀ, pea  Ľoku hoko ia,  
\q2  Ľo kapau  Ľoku  Ľikai ke fekau  Ľe Sihova?   
\q1
\v 38 ‚ÄĆ ĽOku  Ľikai ke  Ľalu mei he fofonga  Ľoe Fungani MńĀ Ľolunga  Ľae lelei mo e kovi.   
\q2
\v 39 Ko e hńĀ  Ľoku lńĀunga ai  Ľae tangata mo Ľui,  
\q2  Ľae tangata koe Ľuhi ko e tautea  Ľo  Ľene ngaahi angahala?   
\b  
\q1
\v 40 Ke tau kumi mo  Ľahi Ľahi Ľi hotau ngaahi  Ľalu Ľanga,  
\q2 pea toe tafoki kia Sihova.   
\q1
\v 41 Ke tau hiki hake hotau loto mo hotau nima ki he  ĽOtua  Ľi he ngaahi langi.   
\q2
\v 42 ‚ÄúKuo mau fai talangata Ľa, pea kuo mau angatu Ľu:  
\q2  Ľoku te Ľeki ai te ke fakamolemole.   
\b  
\q1
\v 43 ‚ÄúKuo ke  Ľu Ľufi  Ľaki  Ľae houhau,  
\q2 pea fakatanga Ľi  Ľakimautolu:  
\q2 kuo ke tńĀmate Ľi pea na Ľe  Ľikai te ke manava Ľofa.   
\q1
\v 44 Kuo ke  Ľufi Ľufi koe  Ľaki  Ľae  Ľao,  
\q2 ke  Ľoua na Ľa  Ľasi atu  Ľa  Ľemau kole.   
\q1
\v 45 Kuo ke ngaohi  Ľakimautolu ko e efe mo e  Ľoto Ľota  Ľi he lotolotonga  Ľoe kakai.   
\b  
\q1
\v 46 ‚ÄúKuo mafa Ľa  Ľae ngutu  Ľa homau kau fili kotoa pńď kiate kimautolu.   
\q2
\v 47 Kuo hoko mai  Ľae manavahńď mo e tauhele kiate kimautolu,  
\q2  Ľae lala mo e  Ľauha.‚ÄĚ   
\b  
\q1
\v 48 ‚ÄĆ ĽOku tafe hifo hoku mata, hangńď ko e ngaahi vaitafe,  
\q2 koe Ľuhi ko e  Ľauha  Ľae  Ľofefine  Ľo hoku kakai.   
\q1
\v 49 ‚Äú ĽOku tafe hifo  Ľa hoku mata,  
\q2 pea  Ľikai  Ľosi,  
\q2  Ľoku  Ľikai si Ľi ke tuku.   
\q1
\v 50 Ke  Ľoua ke  Ľafio mai  Ľa Sihova,  
\q2 pea vakai mei he langi.   
\q1
\v 51 Ko hoku mata  Ľoku ne ue Ľi hoku loto,  
\q2 koe Ľuhi ko e ngaahi  Ľofefine kotoa pńď  Ľo  Ľeku kolo.   
\b  
\q1
\v 52 ‚ÄúNa Ľe tuli fakamamahi au  Ľe hoku kau fili hangńď ha manupuna,  
\q2 ta Ľehano Ľuhinga.   
\q1
\v 53 Kuo nau motuhi  Ľeku mo Ľui  Ľi he fale fakapŇćpula,  
\q2 pea kuo lńę ha maka kiate au.   
\q1
\v 54 na Ľe melemo hoku  Ľulu  Ľi he ngaahi vai;  
\q2 pea ne u toki pehńď, ‚ÄėKuo motuhi au.‚Äô   
\b  
\q1
\v 55 ‚Äú ĽE Sihova ne u ui ki ho huafa  
\q2 mei he fale fakapŇćpula taumama Ľo.   
\q1
\v 56 Kuo ke fanongo ki hoku le Ľo;  
\q2  Ľoua na Ľa ke fufŇę ho fofonga ki he Ľeku mńĀnava,  
\q2 ki he Ľeku tangi.   
\b  
\q1
\v 57 Na Ľa ke  Ľunu Ľunu mai  Ľo ofi  Ľi he  Ľaho ko ia ne u ui kiate koe:  
\q2 na Ľa ke pehńď, ‚Äú ĽOua na Ľa manavahńď.‚ÄĚ   
\b  
\q1
\v 58 ‚Äú ĽE Sihova kuo ke langomaki Ľi hoku laumńĀlie;  
\q2 kuo ke huhu Ľi  Ľeku mo Ľui.   
\q1
\v 59 ‚ÄĆ ĽE Sihova kuo ke  Ľafio Ľi ki he kovi kuo fai kiate au,  
\q2 fakamaau  Ľe koe  Ľeku me Ľa.   
\q1
\v 60 Kuo ke  Ľafio ki he Ľenau lili kotoa pńď,  
\q2 mo  Ľenau ngaahi filio Ľi kiate au.   
\q1
\v 61 ‚Äú ĽE  ĽEiki kuo ke fanongo ki he Ľenau taukae,  
\q2 pea mo  Ľenau ngaahi filio Ľi kiate au;   
\q1
\v 62 ‚ÄĆ Ľae loungutu  Ľonautolu na Ľe tu Ľu hake kiate au,  
\q2 pea mo  Ľenau fakatupu me Ľa kiate au  Ľi he  Ľaho kotoa pńď.   
\q1
\v 63 Vakai ki he Ľenau nofo hifo mo  Ľenau tu Ľu hake;  
\q2 ko au ko  Ľenau ta Ľanga.   
\b  
\q1
\v 64 ‚Äú ĽE  ĽEiki ke ke tuku kiate kinautolu ha totongi,  
\q2  Ľo fakatatau ki he ngńĀue  Ľa honau nima.   
\q1
\v 65 Tuku kiate kinautolu  Ľae mamahi  Ľoe loto,  
\q2  Ľa ho Ľo mala Ľia kiate kinautolu.   
\q1
\v 66 Fakatanga mo faka Ľauha  Ľakinautolu  Ľi he houhau  
\q2 mei he lalo langi  Ľa Sihova.   
\c 4  
\cd \it 1  ĽOku tangilńĀulau  Ľa Saione koe Ľuhi ko hono tofi Ľa kovi. 12  ĽOku ne fakahńĀ  Ľene ngaahi angahala. 21  ĽOku fakamana  Ľa  ĽItomi. 22  ĽOku fakafiemńĀlie  Ľa Saione.\it*  
\p
\v 1 Hono  Ľikai kuo hoko  Ľo nenefu  Ľae koula!  
\q2 Hono  Ľikai liliu  Ľae fungani koula!  
\q1  ĽAe ngaahi maka  Ľoe potu tapu kuo lilingi  
\q2  Ľi he mu Ľa hala kotoa pńď.   
\b  
\q1
\v 2 ‚ÄĆ ĽAe ngaahi foha mahu Ľinga  Ľo Saione,  
\q2  Ľaia  Ľoku tatau mo e fungani koula,  
\q1  Ľoku fńďfńď  Ľae lau  Ľakinautolu  Ľo hangńď ko e ngaahi ipu kelekele,  
\q2  Ľae ngńĀue  Ľae tufunga ngaohi ipu!   
\b  
\q1
\v 3 ‚ÄĆ ĽIo, na Ľa mo e ngaahi ika lalahi  Ľoe tahi  
\q2  Ľoku nau  Ľatu  Ľae huhu  Ľonau fakahuhu honau  Ľuhiki:  
\q1 ka kuo hoko  Ľo ta Ľe Ľofa  Ľae  Ľofefine  Ľo hoku kakai,  
\q2  Ľo hangńď ko e fanga  Ľositalesi  Ľi he toafa.   
\b  
\q1
\v 4 Ko e  Ľelelo  Ľoe tamasi Ľi huhu  Ľoku piki ki hono  Ľao Ľingutu  Ľi he fieinu;  
\q2  Ľoku kole mńĀ  Ľe he tamaiki iiki,  
\q2 pea  Ľoku  Ľikai ke tofi  Ľe ha tangata kiate kinautolu.   
\b  
\q1
\v 5 ‚ÄĆ ĽAkinautolu na Ľe fa Ľa kai lelei  Ľoku nau paea  Ľi he ngaahi hala:  
\q2  Ľakinautolu na Ľe kofu kulokula  Ľi he Ľenau tupu hake,  Ľoku fńĀ Ľufua  Ľae tu Ľunga  Ľoto Ľota.   
\b  
\q1
\v 6 He  Ľoku lahi  Ľae tautea ki he angahala  Ľae  Ľofefine  Ľo hoku kakai  Ľi he tautea  Ľoe angahala  Ľa Sotoma,  
\q2  Ľaia na Ľe fulihi  Ľo hangńď  Ľi ha kemo pe taha  
\q2 pea na Ľe  Ľikai fa Ľa ala  Ľae nima ki ai.   
\b  
\q1
\v 7 Na Ľe ma Ľa lahi hake  Ľa hono hou Ľeiki  Ľi he  Ľuha hinehina,  
\q2 nau nau hinehina lahi  Ľi he hu Ľahuhu,  
\q1 ko honau sino na Ľe kula lahi  Ľi he ngaahi lupi,  
\q2 ko honau ngingila na Ľe hangńď ko e safaia.   
\b  
\q1
\v 8 ‚ÄĆ ĽOku  Ľuli Ľuli honau mata  Ľi he maka fefie;  
\q2  Ľoku  Ľikai ke kei  Ľilo Ľi  Ľakinautolu  Ľi he ngaahi hala:  
\q1  Ľoku piki  Ľa honau kili ki honau ngaahi hui,  
\q2  Ľoku fe Ľufe Ľu ia,  
\q2 kuo hoko ia  Ľo hangńď ha va Ľa  Ľakau.   
\b  
\q1
\v 9 ‚ÄĆ ĽOku lelei  Ľakinautolu  Ľoku mate  Ľo tńĀmate Ľi  Ľaki  Ľae heletńĀ,  Ľiate kinautolu  Ľoku mate  Ľi he honge;  
\q2 he  Ľoku faka Ľau Ľausino  Ľakinautolu ni,  
\q2 kuo tńĀmate Ľi  Ľi he Ľenau masiva  Ľi he ngaahi fua  Ľoe ngoue.   
\b  
\q1
\v 10 Kuo ta Ľo  Ľe he nima  Ľoe kau fefine anga Ľofa  Ľenau fńĀnau  Ľanautolu:  
\q2 ko  Ľenau me Ľakai  Ľakinautolu  Ľi he faka Ľauha  Ľoe  Ľofefine  Ľo hoku kakai.   
\q1
\v 11 Kuo fai  Ľe he  ĽEiki  Ľa hono houhau;  
\q2 kuo ne hua Ľi hono houhau vela,  
\q1 pea kuo ne tutu ha afi  Ľi Saione,  
\q2 pea kuo faka Ľauha ai  Ľa hono ngaahi tu Ľunga.   
\q1
\v 12 Na Ľe  Ľikai ke meimei tui  Ľae ngaahi tu Ľi,  
\q2 mo e ngaahi kakai  Ľo mńĀmani,  
\q2  Ľe fa Ľa hŇę  Ľae kau fili  Ľi he ngaahi matapńĀ  Ľo SelŇęsalema.   
\q1
\v 13 Ko e me Ľa  Ľi he angahala  Ľo  Ľene kau palŇćfita,  
\q2 pea mo e ngaahi hia  Ľo  Ľene kau taula Ľeiki,  
\q2  Ľaia kuo lilingi  Ľae toto  Ľoe kau mńĀ Ľoni Ľoni  Ľi hono lotolotonga,   
\b  
\q1
\v 14 Ko ia kuo nau he  Ľo hangńď ko e kau tangata kui  Ľi he ngaahi hala,  
\q2 kuo nau faka Ľuli Ľi  Ľakinautolu  Ľaki  Ľae toto,  
\q1 ko ia na Ľe  Ľikai fa Ľa ala  Ľae kakai ki honau ngaahi kofu.   
\b  
\q1
\v 15 Na Ľa nau kalanga kiate kinautolu,  
\q2 ‚ÄúMou Ňć!;  Ľoku  Ľuli ia!;  ĽAlu pe,  ĽAlu pe,  Ľoua na Ľa ala!:‚ÄĚ  
\q1  Ľi he Ľenau hola, mo  Ľenau  Ľalu hńďhńď, na Ľa nau pehńď  Ľi he kakai hiteni,  
\q2 ‚Äú ĽE  Ľikai te nau kei nofo ai.‚ÄĚ   
\b  
\q1
\v 16 Kuo fakamavahevahe  Ľakinautolu  Ľe he houhau  Ľa Sihova;  
\q2  Ľe  Ľikai te ne kei tokanga Ľi  Ľakinautolu:  
\q1 na Ľe  Ľikai te nau faka Ľapa Ľapa Ľi  Ľae kau taula Ľeiki,  
\q2 na Ľe  Ľikai te nau tokoni ki he kau mńĀtu Ľa.   
\b  
\q1
\v 17 Ka koe Ľuhi ko kitautolu, na Ľe vaivai hotau mata  
\q2 ko e me Ľa  Ľi he Ľetau tokoni va Ľinga:  
\q1  Ľi he Ľetau le Ľo kuo tau le Ľo ki ha pule Ľanga,  Ľaia na Ľe  Ľikai ke fa Ľa lava ke fakamo Ľui  Ľakitautolu.   
\b  
\q1
\v 18 ‚ÄĆ ĽOku nau tuli  Ľi he Ľetau laka Ľanga,  
\q2 pea  Ľoku  Ľikai te tau fa Ľa  Ľalu  Ľi he ngaahi hala:  
\q1  Ľoku ofi hotau ngata Ľanga,  
\q2 kuo kakato hotau ngaahi  Ľaho;  
\q2 he kuo hoko hotau ngata Ľanga.   
\q1
\v 19 ‚ÄĆ ĽOku ve Ľe vave hotau kau fakatanga  Ľi he fanga  Ľikale  Ľoe langi:  
\q2 na Ľa nau tuli kitautolu  Ľi he ngaahi mo Ľunga;  
\q2 na Ľa nau malumu kiate kitautolu  Ľi he toafa.   
\b  
\q1
\v 20 Ko e mńĀnava  Ľa hotau ava Ľi ihu,  
\q2 ko e pani  Ľo Sihova,  
\q2 na Ľe mo Ľua  Ľi he Ľenau ngaahi luo,  
\q1  Ľaia na Ľa tau pehńď ki ai,  
\q2 ‚Äú ĽI he Ľene malu Ľi te tau mo Ľui  Ľi he lotolotonga  Ľoe hiteni.‚ÄĚ   
\b  
\q1
\v 21 Ke ke fiefia mo nekeneka,  
\q2  Ľi he fonua ko Usa;  
\q1  Ľe a Ľu atu kiate koe foki  Ľae ipu:  
\q2 he te ke konńĀ koe,  
\q2 pea te ke fakatelefua koe.   
\b  
\q1
\v 22 Kuo kakato  Ľae tautea  Ľa ho Ľo hia,  Ľe  Ľofefine  Ľo Saione;  
\q2  Ľe  Ľikai te ne toe  Ľave koe ki he pŇćpula:  
\q1 ka te ne  Ľa Ľahi  Ľa ho Ľo hia,  Ľe  Ľofefine  Ľo  ĽItomi,  
\q2 pea te ne faka Ľilo ho Ľo ngaahi angahala.   
\c 5  
\cd \it 1‚Äď22 Ko e tangi mamahi  Ľa Saione,  Ľi he lotu ki he  ĽOtua.\it*  
\q1
\v 1 ‚ÄĆ ĽE Sihova, ke ke manatu ki he me Ľa kuo hoko kiate kimautolu:  
\q2 tokanga pea ke  Ľafio ki homau taukae.   
\q1
\v 2 Kuo liliu homau tofi Ľa ki he kau muli,  
\q2  Ľa homau ngaahi fale ki he  ĽńĀuhńď.   
\q1
\v 3 Ko e kau fa Ľńď mate mo tamai mate  Ľakimautolu,  
\q2 ko  Ľemau ngaahi fa Ľńď kuo hangńď kuo mate  Ľa honau ngaahi husepńĀniti.   
\q1
\v 4 Kuo mau inu vai  Ľi he totongi pa Ľanga,  
\q2 ko  Ľemau fefie  Ľoku fakatau kiate kimautolu.   
\q1
\v 5 ‚ÄĆ ĽOku mńĀ Ľulalo  Ľa homau kia ki he fakatanga:  
\q2  Ľoku mau ngńĀue pea  Ľoku  Ľikai ha mńĀlŇćlŇć.   
\q1
\v 6 Kuo mau fekuku nima mo e kau  ĽIsipite,  
\q2 pea mo e kau  ĽAsilia, ke mau mńĀkona  Ľi he mńĀ.   
\q1
\v 7 Na Ľe fai angahala  Ľa  Ľemau ngaahi tamai, pea  Ľoku  Ľikai,  
\q2 pea kuo mau fua  Ľenau ngaahi hia.   
\q1
\v 8 Kuo pule  Ľae kau tamaio Ľeiki kiate kimautolu,  
\q2  Ľoku  Ľikai ha ni Ľihi  Ľoku fakahaofi  Ľakimautolu mei honau nima.   
\q1
\v 9 Na Ľa mau ma Ľu me Ľakai  Ľi he tu ĽutńĀmaki  Ľo  Ľemau mo Ľui,  
\q2 koe Ľuhi ko e heletńĀ  Ľi he toafa.   
\q1
\v 10 Na Ľe  Ľuli Ľuli  Ľa homau kili  Ľo hangńď ko e ngoto Ľumu,  
\q2 ko e me Ľa  Ľi he honge fakamanavahńď.   
\q1
\v 11 Na Ľa nau tohotoho  Ľae kau fefine  Ľi Saione,  
\q2  Ľae kau tńĀupo Ľou  Ľi he ngaahi kolo  Ľo Siuta.   
\q1
\v 12 ‚ÄĆ ĽOku tautau  Ľae ngaahi hou Ľeiki mei honau nima,  
\q2 na Ľe  Ľikai ke faka Ľapa Ľapa Ľi  Ľae mata  Ľoe kau mńĀtu Ľa.   
\q1
\v 13 Na Ľa nau  Ľave  Ľae kau talavou ke momosi,  
\q2 pea na Ľe tŇć hifo  Ľae tamaiki  Ľi he lalo  Ľakau.   
\q1
\v 14 Kuo  Ľosi  Ľae kau mńĀtu Ľa mei he matapńĀ,  
\q2  Ľae kau talavou mei he fasi hiva.   
\q1
\v 15 Kuo  Ľosi  Ľae fiefia  Ľa homau loto;  
\q2 kuo liliu  Ľa  Ľemau me Ľe ko e mamahi.   
\q1
\v 16 Kuo tŇć  Ľae tatńĀ fakatu Ľi mei homau  Ľulu.  
\q2  ĽOiauńď  Ľakimautolu! He kuo mau fai angahala.   
\q1
\v 17 Koe Ľuhi ko e me Ľa ni  Ľoku vaivai homau loto;  
\q2 koe Ľuhi ko e ngaahi me Ľa ni  Ľoku nenefu homau mata.   
\q1
\v 18 Koe Ľuhi ko e mo Ľunga  Ľo Saione,  Ľaia  Ľoku lala pńď,  
\q2  Ľoku  Ľa Ľeva ai  Ľae fanga fokisi.   
\b  
\q1
\v 19 ‚ÄĆ ĽE Sihova,  Ľoku ke  Ľafio Ľi  Ľo ta Ľengata,  
\q2 ko ho  Ľafio Ľanga  Ľoku mei he to Ľutangata ki he to Ľutangata.   
\q1
\v 20 Ko e hńĀ  Ľoku ke fakangalo Ľi  Ľakimautolu  Ľo ta Ľengata,  
\q2 pea mahu Ľi meiate kimautolu  Ľo fuoloa?   
\q1
\v 21 Fakatafoki Ľi  Ľakimautolu kiate koe,  ĽE Sihova, pea te mau liliu mo Ľoni;  
\q2 fakafo Ľou homau ngaahi  Ľaho  Ľo hangńď ko ia  Ľi mu Ľa.   
\q1
\v 22 Ka kuo ke mńĀtu Ľaki li Ľaki  Ľakimautolu;  
\q2  Ľoku ke houhau  Ľaupito kiate kimautolu.   