\q1
\v 151 Anduane Homogo-o í̠naga bi mana bibahende henene wiaabo haga ngelowa  
\q2 í̠ni i̱ kogoha kaware haabo kegoni.   
\q1
\v 152 Bambaore howa í̠naga bi mana lowiriru mandabi harugoni ndobe.  
\q2 Í̠na bi uruni lo wialu wiaabo helo nge.   
\s1 Anduane Homogohondo, I̱ biamogo bia, lalu bi lenego ogo  
\q1
\v 153 I̱na í̠naga bi mana lo ngeru embeda nahe kogo  
\q2 í̠na i̱ha genda timbuni ngaru de hondowa i̱ biamogo bibe.   
\q1
\v 154 Í̠nime pele nguleore lalu lo wiridagua i̱ pele ngibe.  
\q2 Godi lalu koria i̱ bo waholene nga loligo í̠na i̱naga lahabe.   
\q1
\v 155 Ko biaga karu tigua í̠naga bi mana lo ngeru talialu nabiagaore kago  
\q2 í̠na ti pele mialu haru dai nabule kegoni.   
\q1
\v 156 Anduane Homogo-o í̠naga dara holene timbuniore ngegome  
\q2 í̠na dara howa biamogo bulebero lalu bi lo wiridagua  
\q2 áyu ogoni i̱ biamogo bibelo hameledo.   
\q1
\v 157 Waitigi dewaoreme i̱ baba waitigi ho halu mo ko haga bidagoyu  
\q2 ainde i̱na í̠naga bi mana galoneore lo ngeru yu wahalu nape kogoni.   
\q1
\v 158 Agali ko biaga biarume í̠na mana bayale bulene nga lo wiriruni nabiaga karu hondowa  
\q2 i̱na tihondo turu nahe handabe manga timbuni ho haruli.   
\q1
\v 159 Anduane Homogo-o í̠naga bi mana bulene nga larigo  
\q2 i̱na gubaliniore howa bua haabo kogoni manda bibe.  
\q2 Í̠naga gubalini holene ho haabo haga kegonigo  
\q2 ainde i̱ dara halu pele ngibe.   
\q1
\v 160 Í̠naga bi mana ngerunaga irane henene lolene dege lo nge.\x + \xo 119.160 \xt Iba 119.89, 119.142, 119.152\x*  
\q2 Í̠naga bi mana lo ngeruni tigabiore wiaabobo bu wiaga nga.   
\s1 Anduane Homogonaga bi mana lo ngaru hame lalu gubaliniore ho henego ogo  
\q1
\v 161 Irane nawini agali haguane bu karume i̱ mo ko halu kagoyu  
\q2 i̱na í̠naga bi mana lo ngeru mitangiore bu haga kogoni.   
\q1
\v 162 Mbiralime ngolo dewa handa walia howa turu hagadagua  
\q2 í̠na buleore lalu lo wigi birirunaga mitangi bialu  
\q2 i̱ turu timbuniore ho kogoni.   
\q1
\v 163 Ke̱ hagane mana koorene ko ngago i̱ mangaore ho kogoyu  
\q2 i̱na í̠naga bi mana lo ngeru hangu gubalini timbuniore ho kogoni.   
\q1
\v 164 Í̠na mana tigabini howa bi lolene ngadagua laga kegonaga  
\q2 i̱na horo bibahendengi í̠hondo kahalu ka̱i̱ laruli.   
\q1
\v 165 Wali agali í̠naga bi mana gubalini ho haga karu ti bayale halu\x + \xo 119.165 \xt Ais 32.17\x*  
\q2 mbirale mbirame ti mo pila holene nawulebira.   
\q1
\v 166 Anduane Homogo-o í̠na i̱ pele ngialu haru dai bibelo maliaho howa  
\q2 mana í̠nime bibe lalu lo wirigo i̱na bialu kogoni.   
\q1
\v 167 Í̠naga bi mana lo ngeru i̱na taluwa bialu hagaore kogoni.  
\q2 Bi mana uruni gubaliniore howa bua timbuni ho kogoni ndobe.   
\q1
\v 168 I̱na í̠naga mana lo ngerubi bulene nga lalu bi lederubi  
\q2 bibahendeore talialu biai halu kogoni.  
\q2 I̱na mana ogoni bialu koria í̠ de handai ho kegoni.   
\s1 Anduane Homogohanda biamogo bilo ibuhondo bi lenego ogo  
\q1
\v 169 Anduane Homogo-o i̱ biamogo bia lalu olalu kogo hale habe.  
\q2 Abale howa í̠na i̱hondo manda bulene nguleore lalu bi lo wiridagua  
\q2 i̱ manda bulene timbuni mo ngibe.   
\q1
\v 170 Ainde i̱na í̠hondo bi larogo baya hangu hale halu  
\q2 í̠na pele ngialu haru dai bule laridagua áyu i̱ pele ngibe.   
\q1
\v 171 Í̠na í̠naga mana lo ngeru i̱ lawai haabo haga kegonaga  
\q2 i̱na í̠naga mini yaraga haabo halu holebero.   
\q1
\v 172 Í̠naga bi mana damenego bayale tigabi dege ngegonaga\x + \xo 119.172 \xt Iba 51.14, 119.138\x*  
\q2 i̱na mana ogoni lalu iba gana la halu holebero.   
\q1
\v 173 Í̠naga bi mana damenego bibahende talialu bialu kogonigo  
\q2 ai nde í̠na i̱ biamogo bule manda bu haabo habe.   
\q1
\v 174 Anduane Homogo-o i̱ pele ngialu haru dai bibelonaga ha dege biwane  
\q2 i̱naga bu miniha tandaga bialu i̱ hongo ereba haragoni.  
\q2 Í̠naga bi mana lo ngegome i̱ mo turu haga biaga ngagoni.   
\q1
\v 175 Í̠naga mini yaraga halu holiya í̠na i̱ha holene bayaleore ngibe.  
\q2 Í̠naga bi lo ngegome i̱ biamogo bia helo hameledo.   
\q1
\v 176 I̱ hariga bayale yu wahalu pu tara howa\x + \xo 119.176 \xt Ais 53.6, Yar 50.6, Md 18.12, Lg 15.4\x*  
\q2 i̱ nogo sibi pu ereba hene ale ko.  
\q2 I̱na í̠naga bi mana lowini ngeru yu wanahagaore kogo manda buwa  
\q1 í̠na í̠naga biabe biahaga i̱ kogonigo i̱ taya bibe.   
\c 120  
\s1 Anduane Homogohondo, Biamogo bia, lalu bi lenego ogo  
\q1
\v 1 I̱ha genda timbuni anda ibiyangi i̱na Anduane Homogo olarugola\x + \xo 120.1 \xt Iba 118.5, Yna 2.2\x*  
\q2 ibugua i̱ biamogo biya.   
\q1
\v 2 I̱na Anduane Homogohondo bi lalu,  
\q1 Anduane Homogo-o agali ke̱ haga karume  
\q2 i̱ mo hondo holigo i̱ biamogo bibe, larugoni.   
\b  
\q1
\v 3 Ke̱ haga bu kamiru tíhondo Anduane Homogohanda agua bulubadabe.  
\q2 Tí pani nalimulo aguaore ngulubadabe.   
\q1
\v 4 Ibugua tí aminaga yandarerume nogoba halu  
\q2 ira hedope halu tí delolebira.   
\b  
\q1
\v 5 I̱ tí dege dombeneha kogoni Mesege dindibi Keda dindibi  
\q2 wali agali ko biaga karu baba haradagua bidogoni.   
\q1
\v 6 Agali maru wali agali bu karu baba mandagi habe manga haga karu  
\q2 i̱ ti heba mandagi luore haabo haruda.   
\q1
\v 7 I̱na mo palia holenenaga bi lalu koria  
\q2 tigua wai bule dege manda biaga kagoni ndobe.   
\c 121  
\s1 Anduane Homogo ibu inanaga mamage hagane kago ogo  
\q1
\v 1 I̱na hari wedaruha de handadaga berogoni.\x + \xo 121.1 \xt Iba 87.1, 123.1\x*  
\q2 I̱ ani bia berogonigoyu  
\q2 mbirali i̱ biamogo bule ibulubadago agohayagi howa ibulubadabe.   
\q1
\v 2 Anduane Homogo ibugua hari daligabi dindi timbuni o kamagobi wabinigo\x + \xo 121.2 \xt Iba 115.15, 124.8\x*  
\q2 ibunime dege i̱ biamogo biaga kagoni.   
\q1
\v 3 Ibugua í̠ pilope nahabelo handayaho holebira.\x + \xo 121.3 \xt Iba 41.2, 66.9, 127.1\x*  
\q2 Ibu u napaliaga howa í̠ mamage kaore dege halu egabi laga biaga kagoni.   
\b  
\q1
\v 4 O larogo bayuwa hale habe.  
\q1 Anduane Homogo ibu Isaraele wali agalinaga mamage haga kago howa  
\q2 ibu u emene mbira napaliagaore ka.  
\q2 Ibu umubi heba nalagaore kagoni.   
\q1
\v 5 Anduane Homogo ibugua í̠ kegoha kaware haparaho howa  
\q2 í̠ mamage haabo haga kagoni.  
\q2 Ibu ani kagola í̠ ibu gumbaha howa bayaleore dungulo holebere.   
\q1
\v 6 Horombe ni tandagabi daragome í̠ daba halu mo ko naholebira.\x + \xo 121.6 \xt Ais 49.10, Mo 7.16\x*  
\q2 Mbiraga ege daragomebi í̠ mo ko naholebira dege.   
\b  
\q1
\v 7 Mbirale ko hiriribi tara tara ngarume í̠ mo ko mbira holilono\x + \xo 121.7 \xt Iba 91.10-12\x*  
\q2 Anduane Homogo ibugua í̠ handayaho mamage holebira.   
\q1
\v 8 Í̠ í̠ni andagani palialu tagira pu haregoriani\x + \xo 121.8 \xt Iba 113.2, 115.18\x*  
\q2 ibugua mamage hama ibagabu holebira.  
\q2 Í̠ andagani daibu paleregolabi  
\q2 ibugua dege mamage holebira.  
\q1 Áyubi awebi ibugua ani biaabo holebira.   
\c 122  
\s1 Yarusaleme tano mitangi bialu ka̱i̱ lenego ogo  
\q1
\v 1 Tigua i̱hondo, Anduane Homogonaga anda mali̱ya ma íbu, layagola i̱ turuore haru.\x + \xo 122.1 \xt Ais 2.3, Seg 8.21\x*   
\q1
\v 2 Ani layagola ina pialu  
\q2 ai áyu Yarusaleme anda puwa pabe tamuha o kamagoni handadaba.   
\q1
\v 3 Yarusaleme tano biagoni lone bu aribia hene  
\q2 baya gibiore de hondoabi kagoni.   
\q1
\v 4 Isaraele hameigini tara tara palu ngaru  
\q2 ti bibahendeme Anduane Homogo ibuhondo ka̱i̱ lole ogoriani íbu ngoai halimu lenedagua  
\q2 ka̱i̱ lole ibugu biaga kagoni.   
\q1
\v 5 Dindi ogoriani godi anda kago ogoniha Isaraele wali agalinaga kinirume biruwa  
\q2 godi hale halu mo tiga biaga kagoni.   
\b  
\q1
\v 6 Yarusaleme dindini gendabi mbira nawi mo paliaho wilo  
\q2 Anduane Homogohondo bi ogodagua lalu halimu.  
\q1 Wali agali Yarusaleme tano mitangi timbuni ho karu  
\q2 ti bayaleore helo biamogo bibe.   
\q1
\v 7 Wali agali Yarusaleme tanonaga pabe tamuhayagi bu kamiru  
\q2 tí tíni dege dege ngeke̱ nale gungu nabi bayuwaore mo paliaho helo biamogo bibe.  
\q1 Kinibi ibunaga agali haguane karubi uruni andagahayagi haga karu  
\q2 tibi turuho mo paliaho dege helo biamogo bibe, lalu ani laga bilimu.   
\q1
\v 8 I̱ damenebi i̱ ariabi igiri yangobi Yarusalemeni íbu karu mitangi bialu  
\q2 bi ogo Yarusalemeni kamiru tíhondo larogoni,  
\q1 Tí ngeke̱ nale gungu nabi bayuwaore mo paliaho halimu, laro.   
\q1
\v 9 I̱na Anduane Homogo inanaga Ngode Datagaliwabe kago  
\q2 ibunaga anda kagoore i̱na mitangi timbuni ho kogoni.  
\q2 Ngode Datagaliwabehanda Yarusaleme wali agaliore biamogo bialu  
\q2 mo bayale helonaga ibuhondo bi lahalu kogoni.   
\c 123  
\s1 Anduane Homogohanda dara howa biamogo bilonaga bi lenego ogo  
\q1
\v 1 Anduane Homogo-o í̠ni dahuliya andaga haru kegoha\x + \xo 123.1 \xt Iba 121.1\x*  
\q2 i̱na handa daga halu í̠hondo bi lalu kogoni.   
\q1
\v 2 Biabe biahaga agali kagome ibunaga anduane kagoha mini hana ho hagadaguabi\x + \xo 123.2 \xt Iba 25.15, Mal 1.6\x*  
\q2 biabe biahaga wali bedagome ibunaga anduane bedagoha mini hanaho biragadaguabi  
\q2 Anduane Homogo inanaga Ngode Datagaliwabe-o  
\q2 í̠na dara howa biamogo bibelo ina í̠ha hanaho holeberema.   
\b  
\q1
\v 3 Anduane Homogo-o ina de hondowa dara habe.  
\q1 Wali agali bu karume ina mo ko hayago  
\q2 ai í̠na daraore howa biamogo bibe.   
\q1
\v 4 Agali homogo mbirale dewawi hearume  
\q2 ina mege bialu haabo haya.  
\q1 Agali mine haga hearume  
\q2 ina bope halu haabo haga kagoni.   
\c 124  
\s1 Anduane Homogo ibugua ibunaga wali agali biamogo biaga kago ogo  
\q1
\v 1 Anduane Homogohanda ina biamogo nabinidale ina nde abiore kamaledabe.  
\q1 Bi o larogoniore Isaraele wali agali tígua bi ogodagua ladai bidaba-o.   
\b  
\q1
\v 2 Inanaga waitigi hearume ina bo anda ibiyangi  
\q2 Anduane Homogo ibugua ina mo wialu biamogo nabinidale   
\q1
\v 3 inanaga waitigi biarume tinaga keba holeneme ina bibahende mo ko howaore bo wahai kale.   
\q1
\v 4 Iba li ibalu mbirale ibame hilu dambiho yalu puabo hagadagua  
\q2 inanaga waitigirume ina bamba bo mburi lalu erebaho wa heledale ndobe.   
\q1
\v 5 Iba li hongoheore ibiyagome ina bibahende mbelelo yalu pialu  
\q2 yu ereba kagola homai kamale ndobe.  
\q1 Homabehego nahome yopene harimago kamagoni, lalu ladai bilimu.   
\b  
\q1
\v 6 Inanaga waitigi bu hearume ina bibahende bo mburi laihe nale  
\q2 Anduane Homogo ibunime ina bibahende hatali wu haabo hayagonaga  
\q2 iname ibuhondo ka̱i̱ laaboore hami̱ya.   
\q1
\v 7 Agalime ega gono wedaria ega mbira gono dagoha da puda halu kundulo mialu  
\q2 ibida porayadagua ina pirimagoni kamagoni.  
\q1 Ina gono wearuha do ngamalego Anduane Homogo ibugua gono kundulupe helaga biyagome  
\q2 ina yo pialu pene kamagoni.   
\q1
\v 8 Anduane Homogo ibugua hari daligabi dindi timbuni o kamagobi wabinigo  
\q2 ibunime dege ina biamogo biaga kagoni.   
\c 125  
\s1 Anduane Homogohanda ibunaga wali agali handayaho haga kago ogo  
\q1
\v 1 Wali agali Anduane Homogoha mini mbiraore wu karu\x + \xo 125.1 \xt Iba 121.8, Seg 2.5\x*  
\q2 ti Hari Saiono ale imiema nabi durubi nalaga hongo haabo haga ka.   
\q1
\v 2 Hari wedarume Yarusaleme ho hagira bu kadagua  
\q1 Anduane Homogohanda ibunaga wali agali handayaho howa  
\q2 ho mabu bu haabo holebira.   
\b  
\q1
\v 3 Wali agali ko biaga karume wali agali mana tigabi biaga karu  
\q2 handayaho haabo naholebira.  
\q1 Tigua handayaho haabo hayagua nde wali agali tigabi karume  
\q2 tibi nde mana ko biaga holobada.   
\q1
\v 4 Anduane Homogo-o wali agali bayale í̠naga mana ngeru taluwa bialu haga karu  
\q2 tihondo í̠na mana bayale biadai bibe.   
\q1
\v 5 Í̠na wali agali ko biaga karunaga pani nelo mialu howa  
\q2 wali agali maru í̠naga mana ngeru mo wahalu piaga karubi  
\q2 ti bibahende pani nelo miai habe laro.  
\b  
\q1 Isaraele wali agaliru tiha mo palia holene wia helo hameledo.   
\c 126  
\s1 Isaraele wali agalime Anduane Homogohanda ti biamogo bilonaga ibuhondo bi lenego ogo  
\q1
\v 1 Anduane Homogohanda ina dindi taraha garabaya hemaria haru dai bialu  
\q2 Yarusalemeni lone helayagoni\x + \xo 126.1 \xt Ab 12.9\x*  
\q1 Ibugua ani biyagonaga  
\q2 iname ogoni henene ndo emaga handarimabe toba harimaya.   
\q1
\v 2 Ina Yarusalemeni daibu howa turuore gibi halu  
\q2 oba hangu haho wiaabo halu  
\q2 turu howa iba ganaru podaga podaga bialu gibiore laho wiaabo harimagoni.  
\q1 Ina ani birimago hondowa wali agali hameigini tara tara paluyu pearume  
\q2 tini dege dege lade̱le̱ bialu au laya.  
\q1 Anduane Homogohanda ibunaga Isaraele wali agali biamogo bule  
\q2 gibiore nabibehe wiagoni biya hendedemini, laya.   
\q1
\v 3 Ogoni heneneore ndobe.  
\q1 Anduane Homogohanda ina biamogo bulenaga biabe gibiore biyagoni.  
\q2 Ibugua ani biyagonaga ina turuore gibi halu  
\q2 ina miniha dunguore lo harimagoni.   
\b  
\q1
\v 4 Anduane Homogo-o ina ala turuho dunguore lo haramalidagua holoma̱ya hela dai bibe.  
\q1 Iba hundiragola gana iba piagagoha yobu ngaria dalu lone ibiragola iba piaga wiyadagua lone piaga.  
\q2 Ogonidagua Anduane Homogo í̠na ina áyu kamaru lone mo gumbilo dai bibe.   
\q1
\v 5 Wali agali deiba ibalu howa tomo hangalu karume\x + \xo 126.5 \xt Yar 31.9\x*  
\q2 mani tomo hangaragoni bu ngaria turuore halu bu hanaga bilo hameledo.   
\b  
\q1
\v 6 Wali agali dugu bialu tomo egene hongole yalu pialu hangayarume  
\q2 mani tomo uruni bu ngaria bu hombedo hanalu  
\q2 turu hama iba gana lamalama andaga dai bulebira.   
\c 127  
\s1 Anduane Homogo ibu baya gibiore biaga kagonaga ka̱i̱ lenego ogo  
\q1
\v 1 Anda biaga gabendame anda bialu karuni\x + \xo 127.1 \xt Iba 121.4\x*  
\q2 Anduane Homogo ibunime bialu kaha ndo tini hangu hongome bialu kayagua  
\q2 ti bame biabe bu wahole bialu kagoni.  
\q1 Mamage haga agalime tano handayaho karuni  
\q2 Anduane Homogo ibugua mamage kaha ndo  
\q2 tini hangunaga hongome kayagua ti bame irane nawini mamage halu egabi lo kagoni.   
\q1
\v 2 Egabiore lara handala heyalu  
\q2 munibi tomobi mitangi bialu biabe bule tagira poramali.  
\q2 Biabe bialu ne lo wákaha mbiraga andaga dai bialu u palia puda haramali.  
\q1 Urunidagua bialu kamaruni nde irane nawini dege  
\q2 bame hongo bibaho bialu kamagoni.  
\q1 Irane Anduane Homogo ibugua wali agali ibuni gubalini ho karu ti mbiraga u padaha  
\q2 ibunime ti tomo nolenebi mbirale wu holenebi  
\q2 manda mandabu wia haga kagoni.   
\b  
\q1
\v 3 Anduane Homogo ibugua inahondo baya turubini bialu waneigini ngidaruni  
\q2 turu halu mbirale bame ngiradagua bidagoni.  
\q2 Waneigini bu karuni ibugua ina mo gumbila halu inahondo ngidagoni.   
\q1
\v 4 Agali daliaheme ibu igini igiri hono wu haga bidago  
\q2 ogoni wai biagane agalime ibu giha timu ayagu yu hagadagua yu ka.   
\q1
\v 5 Timu ayagu ogoniale dewaore wu kago ibu baya turubiore ka.  
\q2 Ibunaga waitigi karu baba bi godi laga birangi  
\q2 ibu igini dewa urunime lamogo biragola  
\q2 ibunaga waitigidarume ibu godi lo wini labe naheore holebira.   
\c 128  
\s1 Anduane Homogohanda ibunaga bi mana hale haga karu mo bayale holebero lenego ogo  
\q1
\v 1 Wali agali Anduane Homogohanda hame ledadagua bialu karu  
\q2 ibunaga bi mana lo ngadagua bialu hagabi karu  
\q2 ti turuore ho ka.   
\b  
\q1
\v 2 Í̠ ogonibi keyagua í̠naga biabe bereruha howa karulape mo ngialu  
\q2 mbirale burupale keru yu holebere.  
\q1 Mbirale í̠na bereru damene bibahende bayale hai haragola  
\q2 í̠ni turubiore holebere.   
\q1
\v 3 Í̠ one ibu nde \w gerebi\w* lini dewaore daga kaligobi birulebira.  
\q2 Ira olibe hongone dewa ira teneha anda ho mabu biralidagua  
\q2 í̠naga waneiginiru ti í̠naga andagani ira dedagoria biru mabu bulebira.   
\q1
\v 4 Heneneore mbirali Anduane Homogonaga bi ledago taluwa biaga kago  
\q2 ibuha mo turu holene ogonibi migi bulebira.   
\b  
\q1
\v 5 Anduane Homogo ibugua Saionoha howa í̠ mo bayale helo.  
\q2 Í̠ dindini homa nabi wene keore Yarusalemeni mbirale uruni heneneore biaabo halu kane handabelo hameledo.   
\q1
\v 6 Í̠ dindi ogoria luore haabo howa  
\q2 í̠naga waneigini aguaneru de handabelo hameledo.  
\b  
\q1 Isaraele wali agaliru tiha mo palia holene wia helo hameledo.   
\c 129  
\s1 Isaraelealirume waitigi bu hearu mo ko helonaga Anduane Homogohondo bi lenego ogo  
\q1
\v 1 Isaraelealiru-o bambaore howa tí waitigirume pigane hemingi howa  
\q2 mo ko hama ibalu haabo henego te langibe.   
\b  
\q1
\v 2 I̱na í̠hondo langialu lalu,  
\q1 I̱ daliahe dege hewangi  
\q2 waitigime mo ko hama ibalu haabo henego áyu kogoni.  
\q2 Tigua ani binigoyu i̱ bope nahe kogoni.   
\q1
\v 3 Tigua i̱ pu payini tibume minu bayagola  
\q2 i̱naga tingini erembiraha poda gaibu baga biya.  
\q2 I̱naga tingini bayago dere tibu bene wiadagua luni biagimbu bigi bialu  
\q2 iba ganarua ale pupe haga biya.   
\q1
\v 4 Tigua ani biyagoyu Anduane Homogo ibu tigabiore kagome  
\q2 i̱ biamogo bialu waitigi biarunaga garabaya biabe ale bialu haga ndo  
\q2 i̱ golope hene ko, lalu langerogoni.   
\b  
\q1
\v 5 Waitigirume Saiono handabe manga haga bu karu  
\q2 tini daluha bo taliadai bimi̱ya hamelo ko.   
\q1
\v 6 Tiore anda dangini gondo anda ho hagadagua hayagua bayaleda.  
\q2 Mbiralime gondo ogoni dugu wanahe kaore minalu abale gau laga.   
\q1
\v 7 Gondo anda dangini anda hene ogoni  
\q2 mbiralime gandu lowa mo kabubu yalu napiaga ndobe.   
\q1
\v 8 Wali agali kaware bolangua halu porarume tihondo ogodagua lalu,  
\q1 Anduane Homogohanda tí mo bayale helo.  
\q1 Iname nde Anduane Homogonaga minini howa tí mo bayale helo hameledama, lalu nalolebira ndobe.   
\c 130  
\s1 Mbirali ibu Anduane Homogohondo biamogo bia lalu lenego ogo  
\q1
\v 1 Anduane Homogo-o i̱naga bu miniha gendaore gibi ho howa í̠hondo bi larogoni.\x + \xo 130.1 \xt Dug 3.55, Yna 2.2\x*   
\q1
\v 2 Anduane-o i̱na í̠hondo duguore bialu bi larogoni hale habe.  
\q2 Í̠na i̱ biamogo bia lalu olarogoni hale habe.   
\q1
\v 3 Í̠na iname ko birimaruni damenego bibahendeore mo ilu wiai ho kele\x + \xo 130.3 \xt Iba 143.2, Lm 3.20, 3.23-24\x*  
\q2 ina kamaruni mbira pani nane yo pialu ai pedalebe.   
\q1
\v 4 Ina mbiraorebi yo napobeheore kamalegoyu\x + \xo 130.4 \xt Yar 33.8-9\x*  
\q2 í̠na iname ko beramaru domo wahaga kegoni.  
\q2 Iname í̠ hondowa giho holoma̱yanaga  
\q2 ko beremaru í̠na domo wahaga bialu kegoni.   
\b  
\q1
\v 5 I̱ore Anduane Homogohanda biamogo bilo lowa ibuha hana howa miniha didiho haruli.\x + \xo 130.5 \xt Iba 33.20, 40.1, Ais 8.17, 30.18\x*  
\q2 Ibugua biamogo bulebero lalu ibunaga bi lo wiyagoria yaniho haabo haruli.   
\q1
\v 6 I̱ore Anduane Homogohanda biamogo bulebira lowa miniha didiore howa haruli.\x + \xo 130.6 \xt Iba 63.6, 119.147\x*  
\q2 Mbiraga mamageali mbira egabi ala la lowa hale gogabu haradagua ndo  
\q2 i̱ miniha didi gibiore biyagola dugudaga howa yangayangabu haruli.   
\b  
\q1
\v 7 Isaraele wali agaliru-o Anduane Homogo ibugua ina gubalini gibiore haho wiaabo haga kago manda bialu  
\q2 iname ibuhondo mini mbiraore wialu ibuha hanaho holene nga.  
\q2 Ina mbira mo ko holani handalu ibugua biamogo biaga kagoni.   
\q1
\v 8 Ibugua Isaraele wali agali ibuninaga ka lalu\x + \xo 130.8 \xt Md 1.21, Ta 2.14\x*  
\q2 tigua ko binidaru domo wahai halu  
\q2 ti gi mialu haru dai biai haga kagoni.   
\c 131  
\s1 Mbiralime mini mbiraore wu howa Anduane Homogohondo bi lenego ogo  
\q1
\v 1 Anduane Homogo-o i̱na mine halu haruligo wahalu  
\q2 i̱ni bayale kogo mitangi bialu balagala haruligobi waharu.  
\q1 I̱na mana timbuni i̱ manda bibe nahe ngarubi  
\q2 mbirale nahendene ale bulene taibiore ngarubi  
\q2 uruni i̱ mitangi nabi holebero.   
\q1
\v 2 I̱na ani nabi howa ai i̱ karulape í̠naga mo palia holeneha bedogoni.  
\q2 Waneigini gali ti ai̱ya bani bayale paliagadagua  
\q2 i̱naga miniha nde hadape howa dungulo kogoni.   
\q1
\v 3 Isaraele wali agaliru-o tígua Anduane Homogohondo mini mbiraore hongohe  
\q2 áyu ogoni howa wu haabo ho halimu.   
\c 132  
\s1 Anduane Homogonaga anda mitangi bialu ka̱i̱ lenego ogo  
\q1
\v 1 Anduane Homogo-o Debidihanda erekui biabe ndelaheore bialu hayagoni mitangi bialu  
\q2 í̠na ibuore embeda holeni.   
\q1
\v 2 Anduane Homogo-o Debidi ibugua ogo ale buleore lalu  
\q2 Isaraele wali agalinaga Ngode Datagaliwabe Hongo Gibihe kego í̠hondo bi lo wigi biyagoni  
\q2 í̠na mitangi budai bibe.   
\q1
\v 3 Ibugua bi ogodagua lo wigi biyagoni.  
\q1 I̱na i̱ andaga napolebero dagianibi u napaluebero.   
\q1
\v 4 Ha̱lo birabi mbirale mbirani malia howa paliabi nabulebero.   
\q1
\v 5 Isaraele wali agalinaga Ngode Datagaliwabe Hongo Gibihe kagonaga andaore mbira bu heore lolego buwa  
\q2 Anduane Homogo ibu anda ogoniha kagola i̱ i̱ni andaga u palue polebero, lalu  
\q1 Debidihanda bi uruni leanego mitangi bibe.   
\b  
\q1
\v 6 Anduane Homogonaga Habo Nalolene bi lo winigonaga Mbogoyi biagoni dindi ogoha nga lalu\x + \xo 132.6 \xt 1 Sml 7.1-2, 1 Bit 13.5\x*\x + \xo 132.6 \xt 2 Bit 6.41-42\x*  
\q2 ina Bedelehemeni hemaria langiyane hale harima.  
\q1 Mbogoyi biagoni Yarimu dindini wiaria handa walia harima.   
\q1
\v 7 Handa walia howa iname lalu, Ai Mbogoyi ogo mo yalu Anduane Homogonaga andani ma nalarami, larima.  
\q1 Anduane Homogonaga biragane dagia ngagoria kaware hapara howa  
\q2 ina bulu palialu ibunaga mini mo yaraga halu lotu lami̱ya ma, lalu larima.   
\b  
\q1
\v 8 Anduane Homogo-o í̠naga Mbogoyi biagoni heba í̠ninaga andani haabo hole íbu habe.  
\q2 Mbogoyi ogonime Anduane Homogo í̠ hongo gibihe kego walia halu manane ogoni ngagoni.   
\q1
\v 9 Í̠naga \w loma\w* binigo mo miaga agali karu tiguabi mana tigabi hangu bilo hameledo.  
\q2 Í̠naga wali agali bu karume turuore gibi howa bi ladagadaga bilo hamelo kogoni.   
\b  
\q1
\v 10 Anduane Homogo-o í̠naga biabe bia haga Debidiore mitangi bibe.  
\q2 Kini í̠nime dabene ogonihondo handa tara halu erembira muleni.   
\q1
\v 11 Anduane Homogo-o ala í̠na bi hongoheore mbira Debidihondo lo wiriyagoni pugua nabuleore kegoni.\x + \xo 132.11 \xt 2 Sml 7.12-16, 1 Bit 17.11-14, Iba 89.4-5, Ab 2.30\x*  
\q1 Ala í̠na Debidihondo ogodagua lariyagoni,  
\q2 Debidi í̠ni halu homedeha mani í̠ igini hararu aria mbirago kini í̠ pani ho aribia helo dabo helolebero, lariyagoni.   
\q1
\v 12 Í̠na Debidihondo laabo halu lalu,  
\q1 Í̠naga igini hararume i̱na habo nalolene bi pongo bo wirudagua bialu  
\q2 ogoale bilimu ogo ale nabilimu lalu lamerodagua biyagua nde  
\q2 mani í̠naga aguane hararu ti iginime kini dege halu  
\q2 í̠naga dagia í̠niha tagira pene degeme mia aribia haga bulebira, lalu lo wiriyagoni.   
\b  
\q1
\v 13 Anduane Homogohanda Saiono tano ibuninagaore helo ibunime dabene.  
\q2 Ibu Saionooreni ho teneho hole hameleda.   
\q1
\v 14 Ibugua lalu, I̱ tano ogoriani haho wiaaboore holebero.  
\q2 I̱na dindi ogoriani howa i̱ni kini howa haru holenaga dindi ogoni dabedo.   
\q1
\v 15 I̱na Saiono tanoni wali agali bu karu buru pada ale dewaore bu hombedo mulebero.  
\q2 Ogoniha wali agali yagibano tomo noanoalo bu karu tibi tomo karulapeore nelo mulebero.   
\q1
\v 16 Saiononi loma binigo mo miaga karume  
\q2 i̱naga wali agali gi mialu haru dai bulene biabe bayale bilo biamogo bulebero.  
\q2 Saiononi wali agali bu karu ti turu halu iba gana lalu bi ladagadaga bu holebira.   
\q1
\v 17 I̱na dindi ogoriani howa Debidi ibuha howa tagira pene mbira kago  
\q2 kini gibiorene gibi helo dabo helolebero.\x + \xo 132.17 \xt 1 Kin 11.36\x*  
\q1 Kini ogoni lamu hale daabo hagadagua  
\q2 ibugua wali agali handame holene ereba nahe wiaaboboore holebira.   
\q1
\v 18 Kini ogoninaga waitigi karu i̱na ti mo taga halu  
\q2 taga pani timbuniore nelolebero.  
\q1 Ai wali agali kini ogoni ibugua handayaho hene karu  
\q2 i̱na ho timbu hama baya hama puabo helolebero, lalu  
\q1 Anduane Homogohanda ani lene.   
\c 133  
\s1 Ngode Datagaliwabenaga wali agali mo palia howa mandagi holene turubiore ngago ogo  
\q1
\v 1 Ngode Datagaliwabenaga wali agali ti baya hangu mini mo mbiraore howa mandagi hayagua nde\x + \xo 133.1 \xt Pig 13.8\x*  
\q2 mana ogoni bayaleore halu ti miniha dungulo holebira.   
\q1
\v 2 Tigua mana ogonidagua bulenego bayaore  
\q2 olibe lini ibaneme weli baya tara wabini mbira  
\q2 Arononaga haguaneni odo wiyagola pugulalu ibunaga angarini pora bialu  
\q2 aga lu biagoria pugulope hayagobi holebira.   
\q1
\v 3 Mini mo mbiraore holene mana ogoni Hari Hemononi dadimba mbiraga ibira haraligobi halu  
\q2 Saiononaga hari bu karuha ibira hagagobi holebira.  
\q1 Dindi ogoniha Anduane Homogohanda wali agali mini mo mbiraore ho karu  
\q2 tihondo bayale dege bialu holebero lo winigo nga.  
\q1 Bi lowinigo ogo, Tí haabo holene yu halimulonaga ngulebero, lene.   
\c 134  
\s1 Anduane Homogonaga mini yaraga hama lenego ogo  
\q1
\v 1 Anduane Homogonaga andaha mbiraga biabe biahaga kamiru  
\q2 ibunaga mini yaraga hole ibidaba.   
\q1
\v 2 Tígua ibunaga andaha howa gi yaraga halu  
\q2 Anduane Homogohondo bi lalu ibunaga mini yaraga hadaba.   
\b  
\q1
\v 3 Anduane Homogo ibu hari daligabi dindi o kamagonibi wabini kago  
\q2 ibugua Saionoha howa tí mo bayaleore helo laro.   
\c 135  
\s1 Anduane Homogonaga mini yaraga halu iba gana lenego ogo  
\q1
\v 1 Anduane Homogonaga mini yaraga hami̱ya.  
\q1 Anduane Homogonaga biabe biahaga kamiru  
\q2 tígua ibunaga mini yaraga hadaba.   
\q1
\v 2 Tí Anduane Homogo inanaga Ngode Datagaliwabenaga anda pabe timbuni kago tamuha haga kamiru  
\q2 tígua ibunaga mini yaraga hadaba.   
\q1
\v 3 Ibu bayaleore kagonaga iname ibunaga mini yaraga hami̱ya.  
\q2 Ibugua inahondo dara howa bayale biaabo haga kagonaga  
\q2 iname ibunaga mini yaraga halu iba ganaru lami̱ya.   
\q1
\v 4 Anduane Homogohanda Yagaba ibunaga helo dabenedagua  
\q2 ibugua Isaraele wali agali ibuninagaore helo dabo helene ka.   
\b  
\q1
\v 5 Anduane Homogo ibu mini leneore howa  
\q2 dama mitangi bialu bi pupu wulenaga gime wabini ngaruni  
\q2 ibugua bolangua haiheore kago i̱ manda bidogoni.   
\q1
\v 6 Anduane Homogohanda mbirale ibunime bule hame ledadagua  
\q2 hari daligahabi dindinibi biaga ka.  
\q1 Iba solowarahabi iba andanehabi bibahendeoreni  
\q2 ibugua bua biradagua biai haga ka.   
\q1
\v 7 Ibugua harini ginu dindi bibahendeha wiame helalu  
\q2 hari daba bilaragola howa iba dalu ibilalu  
\q2 puyabu tara tara ibuni andagaha wia do ho winiru mo heya halu  
\q2 dindi bibahendeha pulame helo pelaga ka.   
\b  
\q1
\v 8 Iyibi dindini Iyibialinaga igini wahene bibahende bo wahai halu  
\q2 tinaga nogo igini pigane wini hearubi bibahende bo wahai hene.\x + \xo 135.8 \xt Har 12.29\x*   
\q1
\v 9 Iyibi dindiha dege ibugua kinibi ibunaga agali haguane hearubi bibahende pani nelo mialu  
\q2 agalime nabiagane alebi nahendene ale dewaorebi bialu hene.\x + \xo 135.9 \xt Har 7.14–10.29\x*   
\q1
\v 10 Anduane Homogohanda hameigini tara tara dindi dewaoreni hearu bo wahaga bialu  
\q2 kini hongohe bu hearunibi bo wahai haga bini.   
\q1
\v 11 Ibugua Amoro wali agalinaga Kini Sihono bo wahalu\x + \xo 135.11 \xt Dag 21.21-35, Yos 12.7-24\x*  
\q2 Basana wali agalinaga Kini Oga bo wahalu  
\q2 Kenana dindiha kini dewa bu hearubi bo wahai halu bini.   
\q1
\v 12 Ibugua dindi uruni ibunaga wali agaliruhondo mini.  
\q2 Isaraele wali agali hearu tihondo dindi uruni bibahende miai hene.   
\b  
\q1
\v 13 Anduane Homogo-o wali agali bibahendeme í̠ Ngode Datagaliwabeore kagonida lalu latagi haabo holebira.  
\q2 Wali agali mani holebirarubi ti bibahendeme í̠ ogonibiore ke lalu manda bulebira.   
\q1
\v 14 Anduane Homogohanda ibunaga wali agali handayaho haabo holebira.  
\q2 Ibugua dara holene nawi howa ibunaga biabe biahaga karu dara haabo holebira.   
\b  
\q1
\v 15 Hameigini dindi tara taraha bu hearume dama mitangi bialu\x + \xo 135.15 \xt Iba 115.4-8, Mo 9.20\x*  
\q2 mbirale bi pupu wulenaga ngolo silibarume wabu helaga biaga.  
\q2 Mbirale uruni tininaga gi degeme wabigi bini.   
\q1
\v 16 Mbirale uruni wabu helayaru tinaga ne hariga ngagoyu bi nalaga nga.  
\q2 Tinaga de heledagoyu mbirale deme nahandaga nga.   
\q1
\v 17 Tinaga hale wabu heledagoyu bi hale nahagabi  
\q2 tiha bu he̱bi nalagabi nga.   
\q1
\v 18 Mbirale uruni ale wabu helayarubi  
\q2 uruni yu tiga biaga agali karubi  
\q2 tini nde mbirale urunibi dege helo hamelo kogoni.   
\b  
\q1
\v 19 Isaraele wali agaliru-o Anduane Homogonaga mini yaraga hadaba.  
\q2 Anduane Homogonaga \w loma\w* binigo mo miaga kamiru tíguabi ibunaga mini yaraga hadaba.   
\q1
\v 20 \w Libai\w* agali kamiru tíguabi Anduane Homogonaga mini yaraga hadaba.  
\q2 Wali agali Anduane Homogo mitangi bialu lotu laga kamiru tí bibahendeme  
\q2 ibunaga mini yaraga hadaba.   
\q1
\v 21 Anduane Homogo ibunaga dalu Saiono Yarusalemeha howa wali agali bu kamiru  
\q2 tígua ibunaga mini yaraga hai hadaba.   
\c 136  
\s1 Anduane Homogohondo ka̱i̱ lalu iba gana lenego ogo  
\q1
\v 1 Anduane Homogohanda inahondo bayale bialu haga kagonaga\x + \xo 136.1 \xt 1 Bit 16.34, 2 Bit 5.13, 7.3, Esr 3.11, Iba 100.5, 106.1, 107.1, 118.1, Yar 33.11\x*  
\q2 iname ibuhondo ka̱i̱ timbuni lolene nga.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 2 Anduane Homogo ibu mbirale bi pupu wulenaga gime wabini ngaru bolangua haihe kago  
\q2 iname ibuhondo ka̱i̱ lama.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 3 Anduane Homogo ibu dindini haguane hene karu bolangua haihe kago  
\q2 iname ibuhondo ka̱i̱ lama.  
\q1 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\b  
\q1
\v 4 Agalime nabiagane aleru ibugua dege biaga ka.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 5 Hari daliga li karuni ibunaga mini bayale gigabi wiagome wabini.\x + \xo 136.5 \xt Pig 1.1\x*  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 6 Ibugua iba andaneha berelowa dindi daliga wabu ngeleda.\x + \xo 136.6 \xt Pig 1.2\x*  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 7 Ibugua ni egebi wabini.\x + \xo 136.7 \xt Pig 1.16\x*  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 8 Ibugua nime horombe wá halu hondo helo heleda.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 9 Ibugua egebi yakundirubi urunime mbiraga dalu hondo helo heledagoni.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\b  
\q1
\v 10 Ibugua Iyibi wali agalinaga igini wahene bo wahai hene.\x + \xo 136.10 \xt Har 12.29\x*  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 11 Ibugua Isaraele wali agali Iyibi wahalu haru tagira pene.\x + \xo 136.11 \xt Har 12.51\x*  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 12 Ibunaga hongo timbuniore heagome ti ani haru tagira pene.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 13 Ibugua iba solowara Daramabi laga bereago bira migimigi bilene.\x + \xo 136.13 \xt Har 14.21-29\x*  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 14 Ibuni bamba halu ibunaga wali agali haru halu iba solowara Daramabi domaede hene.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 15 Ibugua ani biyagoyu Iyibinaga kinibi ibunaga ami agali hearubi iba ogoniha iba nalu homai helene.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\b  
\q1
\v 16 Ibugua dindi ko wali agali nahaga wiagoria ibuni bamba halu ibunaga wali agali haru halu pene.\x + \xo 136.16 \xt Har 13.18, 15.22\x*  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 17 Ibugua kini hongohe hearu bo wahai hene.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 18 Ibugua kini mini lene hearubi bo wahai hene.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 19 Ibugua Amoro wali agalinaga Kini Sihono bo wahene.\x + \xo 136.19 \xt Dag 21.21-30\x*  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 20 Basana wali agalinaga Kini Ogabi bo wahene.\x + \xo 136.20 \xt Dag 21.31-35\x*  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 21 Kini uruninaga dindi wiaru ibunaga wali agaliruhondo mini.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 22 Ibugua dindi uruni ibunaga biabe biahaga Isaraelealiruhondo mini.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\b  
\q1
\v 23 Waitigime ina bopeore hayagola ibugua ina embeda nahene.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 24 Ina waitiginaga giha hemaria ibugua ina mo wialu haru dai biya.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\q1
\v 25 Ibugua wali agalibi ema bialu piaga damene bibahendebi tomo karulape nelo miaga ka.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\b  
\q1
\v 26 Ngode Datagaliwabe dahuliya andaga kagohondo iname ka̱i̱ lami̱ya.  
\q2 Ibugua ina gubalini ha ho wiaaboore haga kagoni.   
\c 137  
\s1 Isaraele wali agali dindi taraha garabaya pu howa tininaga dindi mitangi bialu iba gana darabi lenego ogo  
\q1
\v 1 Babilono dindini iba piyarunaga angeni ina bira bigi bu harima.\x + \xo 137.1 \xt Neh 1.4\x*  
\q2 Ogoriani biruwa nde inanenaga dindi Saionoore mitangi harima.  
\q1 Iname dindi biago mitangiore harimadagua nde  
\q2 daraore howa inane dindinaga duguore bu wia harima.   
\q1
\v 2 Iname inanaga ngida ga̱wa̱ hiliyularu iba angeni ira hiribi ale hearunaga maganeni derela ho ngelowa  
\q2 ina labe manga biyagola nale bame biru wirima.   
\q1
\v 3 Agali ina garabaya biaga biarume inahondo lalu,  
\q2 Tígua iba gana maru ina mo turu holenaga laga bidaba.  
\q2 Tíninaga dindi Saionoore lalu ka̱i̱ laga bialu mbira ina hale holoma̱ya la handadaba, laga biya.   
\b  
\q1
\v 4 Ti ani laga biyagoyu ina dindi taraha garabaya pu howa  
\q2 ina Anduane Homogonaga iba ganago bame laholo au bulebe.  
\q1 Ani nabuleore ndobe.   
\q1
\v 5 Yarusaleme-o i̱na í̠ embeda haruyagua  
\q2 o ngidaru lone aginaga bole ndodago nabolebero.   
\q1
\v 6 Yarusaleme-o i̱na í̠ embeda halu  
\q2 i̱naga turu holene tene  
\q1 Yarusaleme mitangi harogome tagira ibaga manda bidogobi heba embeda dege haruyagua  
\q2 o i̱ iba gana lone mani nalolego i̱naga bi mo pu helabe laro.   
\b  
\q1
\v 7 Anduane Homogo-o Babilonoalime Yarusaleme bo gialo paya bialu bayangi  
\q2 Edomoali ti wai Babilonoha anda puwa tigua bi laga biyagoore bayuwa mitangi bibe.  
\q1 Tigua ogodagua laga biyagoni.  
\q1 Weagua tira dindi hangu ibira helo bibahende bo gialo bagabu wahadaba, lalu  
\q2 laga biyagoni í̠ hale harigoni.   
\b  
\q1
\v 8 Babilono-o bi o larogo hale habe.\x + \xo 137.8 \xt Mo 18.6\x*  
\q1 Í̠ nde bo mburi lolebirago lelo ani habe.  
\q2 Í̠na inahondo koore birigonaga paipai mbirali ibugua í̠hondo bulebirago handabe.  
\q2 Mbirali inanaga paipai bia haga kago ibu turu holene nga.   
\q1
\v 9 Agali inanaga wai puhaga haruago ibugua ibalu Babilono í̠naga waneigini emene hono yu hama pederuni yamuwa  
\q2 ege to̱le̱ni embone tuguduki haga bulebirago ani bilo hono yu habe.   
\c 138  
\s1 Anduane Homogohondo ka̱i̱ lenego ogo  
\q1
\v 1 Anduane Homogo-o i̱ninaga miniha hongo timbuniore howa  
\q2 í̠hondo ka̱i̱ larogoni.  
\q1 I̱na mbirale dama mitangi bialu gime wabini ngagoria howa  
\q2 í̠naga mini yaraga halu iba gana lalu kogoni.   
\q1
\v 2 Í̠naga anda loma bia hene kago handade halu i̱na ge duli hanga ho biruwa  
\q2 í̠naga mini yaraga halu kogoni.  
\q2 Í̠naga gubalini holene wiaabo kegonagabi  
\q2 í̠ mini bilinahe kegonagabi i̱na ani lalu kogoni.  
\q1 Í̠naga minibi í̠na mana ogo bulene nga lenerubi duniniore nga lalu  
\q2 inahondo mo walia harigonaga i̱na iba gana ogo lalu kogoni.   
\q1
\v 3 I̱na í̠ olarugola í̠na i̱naga bi hale howa  
\q2 í̠ninaga hongo timbuniore kegome i̱ mo hongo haabo harigola kogoni.   
\b  
\q1
\v 4 Kini dindini bu karu bibahendeme í̠na bi lowiriru hale howa  
\q2 tigua í̠naga mini yaraga holebira.   
\q1
\v 5 Tigua í̠na bibahende birirunaga iba ganabi  
\q2 í̠ mini timbuni lene kegonaga iba ganabi lalu holebira.   
\q1
\v 6 Anduane Homogo-o í̠ daliga duniniore kegoni howa\x + \xo 138.6 \xt Ais 57.15, Ya 4.6, 1 Pi 5.5\x*  
\q2 wali agali mini mo dindiha haga karu mitangi bu haga ke.  
\q2 Wali agali mine haga karu ti nde í̠naga deni ha do habe nahe ka.   
\b  
\q1
\v 7 I̱ha genda íbu mabu biragola\x + \xo 138.7 \xt Iba 23.3-4\x*  
\q2 í̠nime i̱ handayaho halu pele ngiaga kegoni.  
\q2 Waitigi bu karume i̱hondo keba haragola  
\q2 í̠na i̱ pele ngialu í̠ninaga hongome i̱ bayuwa mo wiaga kegoni.   
\b  
\q1
\v 8 Anduane Homogo-o mbirale i̱hondo bulebero lalu lo wiriruni  
\q2 biaiore holebere lo manda bido.  
\q2 Í̠naga gubalini holene wiaabo haga kegoni.  
\q2 Í̠na biabe bule biriruni bibahende bu maro bibelo hameledo.   
\c 139  
\s1 Ngode Datagaliwabe ibugua ina manda biai halu de hondo kago ogo  
\q1
\v 1 Anduane Homogo-o í̠na i̱ ba handalu ai ogobiore kalo manda biaiore kegoni.\x + \xo 139.1 \xt Iba 17.3, Yar 12.3\x*   
\q1
\v 2 I̱na mbirale bigi berogo bibahendeore í̠ manda biaiore ke.\x + \xo 139.2 \xt 2 Kin 19.27, Md 9.4, Yo 2.24-25\x*  
\q2 Í̠ kaundiaore uyura howabi i̱naga miniha mitangi berogo damene bibahendeore manda biai kegoni.   
\q1
\v 3 I̱ biabe bialu koyaguabi o ha̱lo bedoyaguabi\x + \xo 139.3 \xt Iba 17.3, Yar 12.3\x*  
\q2 í̠na i̱ handaya kegola dege bialu kogoni.  
\q2 I̱na bigi berogo damene bibahendeore manda biai ho kegoni.   
\q1
\v 4 Bi mbira naledoore ogo ale lolebira lowa\x + \xo 139.4 \xt Hi 4.13\x*  
\q2 í̠ abale manda bu bolangua kegoni.   
\q1
\v 5 Í̠na i̱ homabu bupe halu  
\q2 í̠naga hongome i̱ pabe tigila haradagua bidegola kogoni.   
\q1
\v 6 Í̠na i̱ ogobiore kagoni lowa baya hanguore bilibele lo manda biai ho kegoni.  
\q2 Manda bulene daligaore ogonibi i̱na mandabu mibe naheoreda.   
\b  
\q1
\v 7 Í̠ ke handala i̱ ibida pole pialu ha do hole ani pobehe kobe.\x + \xo 139.7 \xt Yar 23.24, Yna 1.3\x*  
\q2 Í̠ nahego mbira dindi agohayagi ngabe.   
\q1
\v 8 Dahuliya anda iraga halu ibiruyagua í̠ ebere ke.  
\q2 Humbirini andaga dalipe halu  
\q2 ni bu karu baba bia tagoho hole yupe haruyaguabi  
\q2 í̠ niguniha ha dege bulebere.   
\q1
\v 9 Yagalo yalu pialu ni tagira ibagahayagi ha do hole piruyaguabi  
\q2 o ndo ni paliagahayagi pu haruyaguabi   
\q1
\v 10 dindi gibuni gibuni urunihabi í̠ ha dege bulebere.  
\q2 Í̠na i̱ biamogo bulebi haru holebi ha dege bulebere.   
\q1
\v 11 Aruma holeneme i̱ budambi heladaba lalu  
\q2 wá emeneore mbira nahe aruma dumbilinioreha ha do hole lalu manda biruyaguabi  
\q2 í̠ ha dege bulebere.   
\q1
\v 12 Í̠na i̱ arumaha ndo koria hondolebere.\x + \xo 139.12 \xt Yob 34.22, Dan 2.22, Hi 4.13\x*  
\q2 Mbiraga dumbilini mbauleyaguabi  
\q2 í̠na i̱ horombe hau hanunini koria handaradagua hendede.  
\q2 Handalu keria wá arumala tu nangaria hendede.  
\q2 Mbiragabi horombeni handaradagua dege hendede.   
\b  
\q1
\v 13 I̱naga tingini gi gebi embone minibi tara tara hama pedaruni  
\q2 í̠na wabu helene kogoni.  
\q2 Í̠na i̱ ai̱ya tombeha i̱ mo gimbu bialu berelariyagoni.   
\q1
\v 14 Í̠na mbirale bigi berego taraore bigi biagayagonagabi  
\q2 í̠ timbuni gibi baya buruguleore howa i̱ manda biai ho kegonagabi  
\q2 i̱na í̠naga mini mo yaraga haro.  
\q1 Ina wali agalime í̠ hondowa mo yo handabe nahe kamagoni.   
\q1
\v 15 I̱ ai̱ya tombeha biruwa i̱naga kuni dameneru wene hole mo gimbu gimbu bigi bialu heagola\x + \xo 139.15 \xt Yob 10.8-9, Aga 11.5\x*  
\q2 i̱ tombeha bira do howa anda haga bialu hewago  
\q2 í̠ manda bu harigo kegoni.   
\q1
\v 16 I̱ ai̱yahanda i̱ taba nahene tombeha berewago í̠ handarigoni.  
\q2 Í̠na ani bialu nde i̱ dindini howa mali ogodagua holebira ogoangi homolebira lalu manda buwa  
\q2 í̠naga mbugani gilibu wu kegoni.  
\q1 I̱ ai̱yahanda i̱ taba naheneha abogo ibu lu ogodagua helo lalu  
\q2 mali podo manda bu winigo í̠naga mbugani gilibu wiai kegoni.   
\q1
\v 17 Anigo Ngode Datagaliwabe-o í̠naga mitangi bulene daligaore tara  
\q2 i̱ aleme manda bibe nahedagolabi daga labe nahedagolabi  
\q2 i̱ mogolo kogoni.   
\q1
\v 18 Daga laruyagua iba angeni iba mu ngaru emene karulape lowa  
\q2 í̠naga mitangi bulene daga nalabeheore la dege bialu  
\q2 lo umulowa paliahondo howabi dengala howabi í̠ heba dege halu  
\q2 i̱na í̠ manda biai habe naheore kogoni.   
\b  
\q1
\v 19 Ngode Datagaliwabe-o wali agali mini kowi bu karuore homelo bowaore ha nabira lalu kogoni.  
\q2 Wali agali bame irane nawini bo wahama ibaga biaga karu  
\q2 ti baba i̱ mandagi habe mangabago  
\q2 tiore erebaha nabira lalu kogoni.   
\q1
\v 20 Ko biaga uruni tigua í̠ lalu bi ko laga bialu  
\q2 í̠naga mini mo ko hole lalu lo guraga bialu ka.   
\q1
\v 21 Anduane Homogo-o í̠ handabe manga haga karu  
\q2 i̱na uruniore handabe manga ho ko.  
\q2 Í̠hondo waitigi ho karu  
\q2 i̱na ti mo yo hondowa de handape ho kogoni.   
\q1
\v 22 I̱na ti handabe manga timbuniore ho ko.  
\q2 Ti i̱ waitigi ka lo kogoni.   
\b  
\q1
\v 23 Ngode Datagaliwabe-o í̠na i̱naga bu habanehabi minihabi hai bialu\x + \xo 139.23 \xt Yob 31.6, Iba 26.2\x*  
\q2 ko mbira ngabe hondole mitangihabi tayabume halu manda bibe.   
\q1
\v 24 Í̠na ani taya bialu mana ko mbira i̱ha au ngabe handalu\x + \xo 139.24 \xt Iba 5.8, 143.10\x*  
\q2 í̠naga haabo holene harigani puabo holiya i̱ haru habe.   
\c 140  
\s1 Anduane Homogohanda handayaho helo bi lenego ogo  
\q1
\v 1 Anduane Homogo-o wali agali ko biaga karume i̱ mo ko holigo pele ngibe.  
\q2 Agali bo wahaga karume i̱ baba waitigi nahelo biamogo bibe.   
\q1
\v 2 Tigua mana ko bulenaga ndindi laabo halu  
\q2 wali agali bu karu tini keba haga haga bilo mo keba haga ka.   
\q1
\v 3 Tinaga hége ne gadele puyanaga ne ale howa\x + \xo 140.3 \xt Lm 3.13\x*  
\q2 tigua bi lararume nogombi ko tomia pale ngagonaga tomia ale  
\q2 tinaga ne hambuni ngagoni.   
\b  
\q1
\v 4 Anduane Homogo-o agali ko karunaga hongome i̱ bope nahelo  
\q2 í̠na i̱ handayaho habe.  
\q2 Agali bo wahaga karume i̱ mo ko holenaga bi ndindi lalu kago  
\q2 i̱ ba nabilo hapai habe.   
\q1
\v 5 Mine haga bu karume i̱ gonoha doliya gono wu kagoni.  
\q2 Tigua gono ogoni pu payini timbuni mbirame i̱naga geni do ngelonaga  
\q2 i̱ hariga poleberogoha gono wia do ka.   
\b  
\q1
\v 6 I̱na Anduane Homogohondo lamialu lalu,  
\q2 I̱naga Ngode Datagaliwabeore í̠ni kegoni.  
\q2 Anduane Homogo-o i̱na biamogo bia lalu olalu kogo hale habe.   
\q1
\v 7 Anduane Homogo Bibahende Haru Haame Ho Haga-o  
\q2 i̱ haru dai biaga hongoheore í̠ kegoni.  
\q2 I̱na waitigiru baba wai bialu hewangi  
\q2 í̠na i̱ handayaho harigoni.   
\q1
\v 8 Anduane Homogo-o agali mini kowi karume bule hameledaru buligo nabilabe.  
\q2 Tigua ko bulenaga bi pongo balu karuni biatagi nahelabe.   
\b  
\q1
\v 9 Waitigi bu karume i̱ bope halu balagala howa ibaga bu nahelabe.  
\q2 Tigua i̱ bo waholenaga mo gi halu karuni tiniha biadai bilabe.   
\q1
\v 10 Ira dedaore tinaga haguaneni ibira helolene karulapeda.  
\q2 Ti gundu uli ngagoha uli pu wiaabo helo minu bape habe.   
\q1
\v 11 Agali ko urunime ke̱ howa wali agali maru karu bame godi deni heledago  
\q2 tigua godi lalu bolangua nahelabe.  
\q1 Agali bo wahaga bu karu tiha mo ko holene mbira ibilalu  
\q2 ti bo ereba hai helabelo hamelo kogoni.   
\b  
\q1
\v 12 Anduane Homogo-o wali agali ko urunibi karume  
\q2 wali agali yagibano karu mo ko holebiragola  
\q2 í̠na yagibano karu biamogo biaga kegoni.  
\q2 Wali agali burupale karu tihondobi bayale bulene ngadagua biriligo  
\q2 i̱ manda bu kogoni.   
\q1
\v 13 Wali agali mana tigabi biaga karume í̠naga mini yaraga halu  
\q2 í̠ni kegoha haabo holebira.   
\c 141  
\s1 Mbiraga Anduane Homogohondo bi lenego ogo  
\q1
\v 1 Anduane Homogo-o i̱na í̠ olarogo áyu ogoniore i̱ biamogo bibe.  
\q2 I̱na í̠ olalu kogola í̠na i̱naga bi haleore habe.   
\q1
\v 2 I̱naga bi í̠hondo larogoni ira hagua ngabi mini \w inisenesinaga\w* hagua irigi haragola\x + \xo 141.2 \xt Mo 5.8\x*  
\q2 nga halu turu harilidagua turu halu hale habe.  
\q2 Mbiraga í̠hondo mbirale lomabu delene yamirilidagua  
\q2 i̱naga gi yaraga halu í̠hondo bi larogo yamibe.   
\b  
\q1
\v 3 Anduane Homogo-o i̱naga ne hariga howa bi latagi haroru mamage habe.\x + \xo 141.3 \xt Iba 34.13, Ya 1.26, 3.8\x*  
\q2 I̱naga ne hambuni bi loleberoru damene handayaho habe.   
\q1
\v 4 Mana ko ngago bulenaga i̱naga bu miniha heyuligo mamage habe.  
\q1 Wali agali ko biaga karume mana ko biradagua  
\q2 i̱ ti heba howa ko biamaga halu holigo i̱ nahelabe.  
\q2 Ti dawe halu tomo nalu bedagoha  
\q2 i̱ ti heba mandagi naberelabe.\x + \xo 141.4 \xt Min 23.6\x*   
\b  
\q1
\v 5 Wali agali mini tigabi kagome i̱ dara howa mo tiga bialu  
\q2 pani ngiyagua nde ogoni karulape.  
\q2 Wali agali ko karume i̱naga mini yaraga holene manda biyagua i̱ mangaba lolebero.  
\q2 Irane i̱na í̠hondo lalu wali agali ko karume ko biyagonaga pani mibe laabo haruligonaga i̱ manga holebero.   
\q1
\v 6 Agali marume wali agali ko uruni mo ko howa minu baragola  
\q2 tigua Anduane Homogonaga bi layago heneneoreda lo manda bulebira.   
\q1
\v 7 Agalime ira kambulalu dangialabaga biagadagua bialu  
\q2 agali uruninaga kuni gingirulobaga buwa homali ngagoha waholebira.   
\b  
\q1
\v 8 Anduane Homogo Bibahende Haru Haame Ho Haga-o\x + \xo 141.8 \xt 2 Bit 20.12, Iba 25.15, 123.1-2\x*  
\q2 i̱na í̠hondo mini mbiraore wu haabo kogoni ndobe.  
\q2 I̱na í̠ha ha do kogonigo i̱ nahome helabe.   
\q1
\v 9 Agali ko karume gono ngagoha i̱ do wuligo handayaho halu  
\q2 í̠nime i̱ baya hangu pabe bu habe.   
\q1
\v 10 Agali ko uruni tininaga gono ngagoha tini do nga handala  
\q2 i̱ poleberogoha mo pila holene mbira nawi howa  
\q2 bayale yo pialu poliya helabe.   
\c 142  
\s1 Anduane Homogohanda biamogo bilo bi lenego ogo  
\q1
\v 1 Anduane Homogohanda i̱ biamogo bilonaga i̱na ibu olalu kogoni.\x + \xo 142.1 \xt 1 Sml 22.1, 24.3\x*  
\q1 I̱na i̱ biamogo bia lalu haya howa bi lalu kogoni.   
\q1
\v 2 I̱ha genda ngangi i̱na ibu karia genda ogoni yalu piruli.  
\q2 I̱ mini burugulo koru bibahende ibuhondo lamiai haruli.   
\q1
\v 3 I̱ mini dege dindi halu homolene kawareda lo manda bu kongi\x + \xo 142.3 \xt Iba 77.3, 140.5, 143.4\x*  
\q2 Anduane Homogo ibugua i̱ ogoale bulene ngalo mandabu kagoni.  
\q1 Waitigi karume i̱ gonoha do wuliya hariga poleberogoha gono wia ho ka.   
\q1
\v 4 I̱ni kogoria kaware handa ai nai bialu koria\x + \xo 142.4 \xt Yob 11.20, Iba 88.8, 88.18\x*  
\q2 mbirali i̱ biamogo bulene mbira naheda.  
\q2 Agali ko karume i̱ bo waholilono  
\q2 mbirali i̱ handayaho howa mamage holenebi naheoreda.  
\q2 I̱ dara howa biamogo bulenebi mbira naheoredane hendedo.   
\b  
\q1
\v 5 Anduane Homogo-o í̠na i̱ biamogo bibelo olalu kogoni.  
\q2 Í̠ni hanguore i̱ handayaho haga kegoni.  
\q2 I̱ homa nabi kongi í̠nila habiya hamelo kogoni.   
\q1
\v 6 I̱na biamogo bia lowa í̠ olalu kogonigo hale habe.  
\q2 I̱naga bu miniha mini dege dindi ho howa lalu kogoni.  
\q1 Agali i̱ mo ko hagadaruni ti hongo timbuniorehe kago  
\q2 i̱na ti bope habe naheore kogoni ndobe.  
\q1 I̱ tinaga giha koria í̠na gi mialu yamibe.   
\q1
\v 7 Gendaru íbu ngagoha kogo bayaleore holiya í̠na i̱ biamogo bia laro.\x + \xo 142.7 \xt Iba 13.6, 143.11, 146.7\x*  
\q2 Í̠naga wali agali ngoai ho kagoria  
\q2 i̱na tinaga deni í̠naga mini yaraga halu holebero.  
\q1 Í̠na i̱hondo bayale birigonaga i̱na ani bulebero.   
\c 143  
\s1 Anduane Homogohondo biamogo bia lalu bi lenego ogo  
\q1
\v 1 Anduane Homogo-o i̱na í̠hondo bi larogo hale habe.  
\q1 Í̠ mini tigabiorebi mini bilinahebi kegome  
\q2 i̱na biamogo bia lalu koru hale habe.   
\q1
\v 2 Í̠na godi larengi í̠naga biabe biahaga i̱ kogo godini heloleni nahelabe.\x + \xo 143.2 \xt Lm 3.20, Ga 2.16\x*  
\q2 Í̠naga deni mbirali ibuha ko nawi mbira naheore ndobe.   
\b  
\q1
\v 3 Waitigi bu karume i̱ talima ibaga bialu i̱ bopeore henego ko.  
\q2 Tigua i̱ arumaha minu dariba ho wiradagua bidagola  
\q2 i̱ wali agali bamba homo gialo wahene ngaligobi kogoni ndobe.   
\q1
\v 4 I̱ ani bidagome i̱ mini tumutumu bialu  
\q2 mini dege dindi ho kogoni.   
\b  
\q1
\v 5 Bambaore biniru i̱na lone mitangibu dai bero.\x + \xo 143.5 \xt Iba 77.5, 77.10-11\x*  
\q2 Mbirale bayale damene bibahende í̠na biriruni mitangi bialu  
\q2 biabe bayale birirubi mitangibu dai berogoni.   
\q1
\v 6 I̱na i̱naga gi yaraga halu í̠hondo bi lalu kogoni.  
\q2 Wali agalime iba noa howa kembobe lebola haradagua  
\q2 i̱naga dininime í̠naga bi mana lo ngeru noa halu hame timbuniore lo kogoni.   
\b  
\q1
\v 7 Anduane Homogo-o i̱na mini dunubia ho harugo ereba harago  
\q2 ainde i̱na bi larogo áyu ogoni abale hale habe.  
\q1 I̱ abale homalu homene dininiru piagane ngagoha poligo  
\q2 í̠ ha do nahabe.   
\q1
\v 8 I̱na í̠hondo mini mbiraore wu kogonigo\x + \xo 143.8 \xt Iba 5.8, 25.1, 46.5\x*  
\q2 egerebagi bibahendengi í̠naga gubalini holene ngegoni i̱ mo mitangi biaabo helabe.  
\q1 I̱na í̠hondoore bi lalu haga kogonigo  
\q2 ai hariga i̱na pialu holiyago í̠nime mo walia habe.   
\b  
\q1
\v 9 Anduane Homogo-o í̠na i̱ handayaho habelo í̠ni keria eberogoni.  
\q2 Waitigi bu karunaga giha koria i̱ mo wialu haru dai bibe.   
\q1
\v 10 I̱naga Ngode Datagaliwabe í̠niore kego\x + \xo 143.10 \xt Iba 31.14, 119.12, 139.24\x*  
\q2 i̱na í̠naga hame ngego hangu taluwa bialu holiya i̱ lawai habe.  
\q1 Í̠na i̱hondo bayale bialu  
\q2 i̱ tigabi holene ngagoria ibagabu holiya haru habelo hamelo kogoni.   
\b  
\q1
\v 11 Anduane Homogo-o í̠nime bule lalu abale lo wiridagua  
\q2 i̱ mo wialu bayuwa haru dai bibe.  
\q2 Í̠ bayaleore biaga kegome i̱ha genda bibahende íbu ngagoria kogola  
\q2 í̠nime i̱ pele ngibe.   
\q1
\v 12 I̱ í̠ninaga biabe biahaga kogo manda buwa  
\q2 í̠na i̱hondo gubaliniore ho haga kegonigo i̱ waitigi bu karu homelo babe.  
\q2 I̱ bope haga karu bibahendeorebi bo wahai habe.   
\c 144  
\s1 Kini mbirame ibu wayali henegonaga Anduane Homogohondo ka̱i̱ lenego ogo  
\q1
\v 1 I̱na Anduane Homogonaga mini yaraga harogoni.  
\q1 I̱ biamogo biaga hongo timbunihe ibu kagoni.  
\q1 Ibugua i̱ wai buliya baya hangu biawai halu  
\q2 i̱ mo manda mandabu helaga kagoni.   
\q1
\v 2 Ibugua i̱ handayaho haga howa ibunime i̱ ho hagira bu haga ka.  
\q2 I̱naga humbi alebi pele ngiagabi ibu hanguore kagonigo  
\q2 i̱na ibuha mini mbiraore wu kogome  
\q2 ibugua i̱ mo wialu haru dai biaga kagoni.  
\q1 Ibugua hameigini tara tara dindi bibahendeha karu i̱ andaneha hai helaga kagoni.   
\b  
\q1
\v 3 Anduane Homogo-o ina wali agali agi ale kamagola\x + \xo 144.3 \xt Yob 7.17-18, Iba 8.4\x*  
\q2 í̠na mitangi ho haga kebe.  
\q2 Ina bame nahabane mbira kamagonidago  
\q2 ainde í̠na irane aginaga ina mo galone harilibe.   
\q1
\v 4 Ina wali agali bameore ne harigaha buhe̱ halu  
\q2 mbira hangu tagira pialu ereba hagagobi kamagoni ndobe.  
\q1 Inanaga dindini holene tubagiore  
\q2 bame ni daragola munini emene howa abale ereba haraligobi kamagoni.   
\b  
\q1
\v 5 Anduane Homogo-o hari li kagoni kambulaki bialu abale dalia.  
\q2 Í̠naga gime dindi hari wedaru ela hariyagua ira hagua timbuni tagira ibulebira.   
\q1
\v 6 Hari daba mo bia halu waitigi bu karuni bo purogo lela.  
\q2 Ti gerai lalu ibida purogo lelo í̠naga timume bo pelabe.   
\q1
\v 7 Í̠na hari daligaha howa gi dogolape halu  
\q2 i̱ iba andaneha bedogo wahalu tagira ibuliya gini yamia.  
\q2 Agali dindi tarani howa ibini bu karunaga andaneha koria  
\q2 í̠na i̱ abale mo wialu golope habe.   
\q1
\v 8 Agali uruni tiha henene lolene mbira nawiore howa  
\q2 tigua gi doladaga halu henene larama lowa ke̱ dege hagane ka.   
\b  
\q1
\v 9 Ngode Datagaliwabe-o i̱na iba gana gahenge wabialu í̠hondo lolebero.  
\q2 I̱na ngida ale balu í̠hondo iba gana lolebero.   
\q1
\v 10 Í̠na kinirume wai bialu wayali helo biamogo biaga howa  
\q2 í̠naga biabe biahaga Debidi i̱nibi nde biamogo bialu haru dai biaga kegoni.   
\b  
\q1
\v 11 Waitigi i̱ bope haga bu karunaga giha koria haru dai bibe.  
\q2 Agali dindi taraha howa ibini bu karunaga andaneha koria  
\q2 í̠na i̱ abale mo wialu golope habe.  
\q1 Agali uruni tiha henene lolene mbira nawiore howa  
\q2 tigua gi doladaga halu henene larama lowa ke̱ dege hagane ka.   
\b  
\q1
\v 12 Ina igini igiri daliahe kaore  
\q2 ira hongone karu hongohe anda hagagobi helo hamelo kamagoni.  
\q1 Ina wane bedarubi baya dege halu kini andaga kagoha  
\q2 mo yári bia hene ngagobi berelo hamelo kamagoni.   
\q1
\v 13 Inanaga tomo wiaga andaha tomo bayale dewaore wu to̱latagi helo hamelo kama.  
\q1 Inanaga dindini nogo sibi karume igini daosini dewaore honoyu helo hamelo kama.   
\q1
\v 14 Nogo bulumaga bu karumebi igini dewa honoyu kagola  
\q2 mo ko nahelobi maru homa nabilobi hamelo kamagoni.  
\q1 Inanaga hariga polene ngagoria  
\q2 wali agaliyaguabi waneiginiyaguabi mbiragome  
\q2 ibuha genda tandagaru tagira ibiragola  
\q2 dugu bima pelo hame naledema.   
\b  
\q1
\v 15 Dindi mbiraha wali agali bayale urunibi bu karu ti turu ho ka.\x + \xo 144.15 \xt Iba 33.12\x*  
\q2 Wali agali Ngode Datagaliwabe ibuni tinaga Anduane Homogo ka lalu haga karu  
\q2 tibi turuore ho kagoni.   
\c 145  
\s1 Anduane Homogonaga mini mo yaraga halu iba gana lenego ogo  
\q1
\v 1 I̱naga Ngode Datagaliwabebi i̱naga kinibi í̠ kegonigo  
\q2 i̱na wali agali bibahendehondo í̠ daliga gibiore ka lalu lamulebero.  
\q1 I̱na í̠hondo ka̱i̱ lalu laaboore holebero.   
\q1
\v 2 Horo bibahendengi i̱na í̠hondo turu halu ka̱i̱ laabo halu holebero.  
\q2 I̱na í̠naga mini mo yadagadaga haabo haluore holebero.   
\q1
\v 3 Anduane Homogo ibu mini lene daliga gibiore kago  
\q2 bibahendeme ibunaga mini mo yaraga holene nga.  
\q1 Ibu daliga gibiore haruagoni  
\q2 iname ogobiore ka lowa manda biai habe nahe kama.  
\q2 Inanaga manda bulenego emene ko tubagi kamagoni.   
\b  
\q1
\v 4 Í̠naore mbirale bigi biriruni wali agali áyu karume agua bigi biya lalu í̠naga mini mo yaraga halu ka.  
\q1 Wali agali dabane mani hararu tiguabi nde  
\q2 tinaga waneigini lamiragola uruni tiguabi nde  
\q2 í̠naga mini mo yaraga halu dege holebira.  
\q1 Tigua í̠na biabe hongoheore gibi bigi biriruni agua bigi biya lalu  
\q2 bi te lalili bima puabo holebira.   
\q1
\v 5 Wali agalime í̠naga hongo baya gibi holenenaga lalubi  
\q2 í̠ kini gibi kego lalubi bite laabo holebira.  
\q2 Í̠na biabe hongohe gibiorebi agalime nabibeheru bigi birigonaga  
\q2 i̱na miniha mitangidangi bialu haabo holebero.   
\q1
\v 6 Í̠naga hongo gibioreme biabe bigi birigonaga wali agali tigua bite laga bulebira.  
\q2 I̱nabi nde í̠ daligaore gibi kagoni lalu maru karu lamulebero.   
\q1
\v 7 Tigua í̠naga mana baya gibiore biaga kegonaga maru lamialubi  
\q2 í̠naga dara holene ngegonaga garea lalubi iba ganaru lalu holebira.   
\q1
\v 8 Anduane Homogo ibugua ina gubalini timbuniore hagabi dara howa biamogo biagabi ka.  
\q2 Ibu keba abale tungulope nahaga howa  
\q2 ibugua ibunaga gubalini haho wiaabo holeneme ina yaniho wiaabo helowa haga kagoni.\x + \xo 145.8 \xt Dag 14.18, Iba 103.8\x*   
\q1
\v 9 Ibugua wali agali bibahendehondo mana bayale ogobi degedege bialu mbirago bume hembome nalagaore kagoni.  
\q1 Mbirale tara tara ibunime wabiniru bibahendeore dara howa ibuni handayaho haga kagoni.   
\b  
\q1
\v 10 Anduane Homogo-o mbirale mbirale ema bialu piaga í̠ni wabini karu  
\q2 bibahendeoreme í̠ninaga mini mo yaraga haiore holebira.  
\q1 Í̠naga wali agali bibahendeoreme í̠nihondo turu halu ka̱i̱ lalu lai holebira.   
\q1
\v 11 Í̠na dindi bibahende de handame howa baya buruguleore haru kegonaga tigua maru hale helo lamialu  
\q2 í̠naga hongo holene gibiore ngegonagabi lalu lamulebira.   
\q1
\v 12 Wali agali karu bibahendeme Anduane Homogo í̠na biabe hongohe gibi bigi biriruni manda biai helo ani lamulebira.  
\q1 Í̠ kini baya buruguleore hongohe howa  
\q2 í̠naga mini daliga gibiore ngegoni manda biai helobi ani loyogo lalu holebira.   
\q1
\v 13 Í̠naga handame holene wiaaboore howa  
\q2 wali agali bibahende haru haho wiaaboboore haga kini holebere.  
\b  
\q1 Anduane Homogo ibugua mbirale mbira bulebero laga bialu lo wigi binigo  
\q2 mbira pugua nabi lo beregedabi nabi  
\q2 ibu mini bilinahe howa bulebero lenedagua biaiore haga kagoni.  
\q1 Ibugua ina dara gibi haga howa mbirale bigi biraru ina biamogo bulenaga dege bigi biaga kagoni.   
\q1
\v 14 Wali agali genda yu howa mini burugulo karu bibahende biamogo bialu  
\q2 wali agali yangoneme hengedope haragola dindiha haga karubi  
\q2 ibunime ti mo yaragaho helolebira.   
\b  
\q1
\v 15 Mbirale dindini emabu bedaru damene bibahendeme í̠naga gi hangu hondole hanaho beda.  
\q1 Ti tomo noa harangi í̠na ti karulape nelo miaga kegoni.   
\q1
\v 16 Í̠na ti bibahende tomo karulapeore nelo mialu  
\q2 ti mbirale maru buru pada alebi mulene ngadagua miaga kegoni.   
\b  
\q1
\v 17 Anduane Homogo ibu mini tigabiore howa ibugua mbirale bigi biraru damene tigabi bialu  
\q2 ina daraore howa biamogo bigi biaga kagoni.   
\q1
\v 18 Wali agalime ti miniha tigabi howa heneneorenaga Anduane Homogo olalu karu  
\q2 ibuni ti kagoria kawareore íbu haga kagoni.   
\q1
\v 19 Wali agali Anduane Homogohondo giho haga karu  
\q2 ti burupale ngaru ibunime tiga handaga haga.  
\q1 Ti genda yu howa ibuhondo bi laragola ibunime hale halu gi miaga ka.   
\q1
\v 20 Wali agali Anduane Homogo ibuore gubalini haga karu  
\q2 ibunime ti baya hanguore handayaho halu mamage haga ka.  
\q2 Wali agali mana ko biaga karu ibugua ti bibahende bo mburi lai holebira.   
\b  
\q1
\v 21 I̱na Anduane Homogonaga mini mo yaraga haabo holebero.  
\q1 Ibugua mbirale ema bialu piaga ibuni wabini karu bibahendeoreme  
\q2 ibunaga mini baya buruguleore kago mo yaraga haaboore holene nga.   
\c 146  
\s1 Anduane Homogo ibu Pele Ngiaga ka lalu mini yaraga halu bi lenego ogo  
\q1
\v 1 Anduane Homogonaga mini yaraga hama.  
\q1 I̱ni bu miniha howa ibunaga mini yaraga harogoni.   
\q1
\v 2 I̱ dindini kogoni howa ibunaga mini yaraga haabo holebero.  
\q2 I̱na i̱naga Ngode Datagaliwabe mini yaraga halu  
\q2 iba gana laabo halu kone dege i̱ni homalu waholebero.   
\b  
\q1
\v 3 Dindini agali haguane karuha mini hanaho nahabe.  
\q2 Agali dindini hene bu karu  
\q2 tigua í̠ pele ngialu haru dai nabibehe kagoni.   
\q1
\v 4 Agali uruni ti homarangi lone dindi dege hodai bulebira.  
\q2 Ti homarangi mbirale ogoale bule lalu lo wiyaruni budai nabulebiraore.   
\b  
\q1
\v 5 Wali agali ti Yagabanaga Ngode Datagaliwabe kagome ti biamogo bilonaga ibuhondo mini mbiraore wu karume  
\q2 ti turu ho haga ka.  
\q1 Uruni tigua Anduane Homogo tinaga Ngode Datagaliwabehondo mini dunubia ho kagome  
\q2 ti turuore ho kagoni.   
\q1
\v 6 Ngode Datagaliwabe ogoni ibugua hari daligabi dindibi iba solowarabi wabialu uruniha karubi ngarubi wabiai henego\x + \xo 146.6 \xt Iba 115.15, 117.2, Ab 4.24, 14.15\x*  
\q2 ibugua mbirale ibuni buleore lalu bi lowiniru bibahende biaiore haga ka.   
\q1
\v 7 Wali agali maru ti waitigi andaneha bope ho karu  
\q2 Anduane Homogo ibunime ti biamogo biaga ka.  
\q2 Maru tomo nane garibilo karuhondo ibugua ti tomo nelo miaga.  
\q1 Anduane Homogo ibugua maru garabayaha karu ti golope haga biaga.   
\q1
\v 8 Ibugua wali agali de kohe karu de hendelo mo ngala halu  
\q2 wali agali gendame bo dambi karu genda mo wahai halu mo hongo haga ka.  
\q1 Anduane Homogohanda ibunaga wali agali bayale tigabi karu gubalini ho haga ka.   
\q1
\v 9 Wali agali dindi taraha howa ina dindini íbu hene karubi ibugua handayaho haga ka.  
\q2 Wali dalo bedarubi waneigini ai̱ya abala homene karubi ibugua ti baya hanguore handayaho haga ka.  
\q1 Ibugua ani biagagoyu agali ko biaga karume mana ko bule manda bialu karu mo libilabala halu mo luluya haga ka.   
\b  
\q1
\v 10 Anduane Homogo ibu kini haluhe haabo kagoni.  
\q2 Saiono wali agaliru-o tínaga Ngode Datagaliwabe ibu kiniore haabobo bu ka.  
\q1 Iname Anduane Homogonaga mini yaraga hami̱ya.   
\c 147  
\s1 Anduane Homogo Hongo Haiheore kagonaga mini yaraga halu iba gana lenego ogo  
\q1
\v 1 Anduane Homogonaga mini yaraga hami̱ya.  
\q1 Iname inanaga Ngode Datagaliwabe mini yaraga halu  
\q2 ibuhondo iba ganaru lolene bayaleore ogoni.  
\q2 Iname ibunaga mini yaraga holene bayale tigabiore nga.   
\q1
\v 2 Anduane Homogohanda Yarusaleme lone mo heya ho helowa  
\q2 ibunaga wali agali dindi taraha garabaya pu haga bini hearu haru dai biragoni.   
\q1
\v 3 Wali agali tini bu miniha genda timbuni yu haga bidaru\x + \xo 147.3 \xt Iba 51.17, Ais 57.15, 61.1, Lg 4.18\x*  
\q2 ibugua mo karulape helaga ka.  
\q2 Ibugua tinaga dere bidaru dabi helo kabu bia haga kagoni.   
\b  
\q1
\v 4 Ibugua yakundi hari daligani bu karuni bibahende daga lai howa\x + \xo 147.4 \xt Pig 15.5, Ais 40.26\x*  
\q2 ti mbira mbiranaga mini lai haga ka.   
\q1
\v 5 Inanaga Anduane Homogo ibu mini leneore howa hongo haiheore ka.  
\q2 Ibunaga mini gigabi ngago iname manda biai habe nahe kama.   
\q1
\v 6 Ibugua wali agali tini mo dindiha haga karu mo yaraga hagago  
\q2 nde wali agali ko biaga karu ti dindiha hengedape haga ka.   
\b  
\q1
\v 7 Anduane Homogonaga mini yaraga halu ibuhondo iba ganaru lolene nga.  
\q1 Inanaga Ngode Datagaliwabehondo ngida ale balu  
\q2 bi bayale mo bila howa bayale bolene nga.   
\q1
\v 8 Ibugua hari daligaha beraliba helame haga.  
\q2 Iba dalu dindini ibilaragola  
\q2 hari bare bare ngaruha datani bayale anda helaga biaga ka.   
\q1
\v 9 Ibugua ema bialu piaga karubi bedarubi tomo nelo mialu  
\q2 ega igini bedarume tomo noa halu bi laragola hale howa  
\q2 ibugua ti tomo nelo mia dege biaga ka.   
\b  
\q1
\v 10 Anduane Homogohanda nogo hosinaga hongobi\x + \xo 147.10 \xt Iba 33.16-18, Hos 1.7\x*  
\q2 ami agalinaga hongobi hondowa turu haga ndo ka.   
\q1
\v 11 Wali agali ibu mitangi bialu mo dunini howa  
\q2 ibunaga gubalini holene wiaabo ka manda bialu  
\q2 ibuhondo mini mbiraore wiaga karu ti hondowa ibugua turuho haga ka.   
\b  
\q1
\v 12 Yarusaleme wali agaliru-o Anduane Homogonaga mini yaraga hadaba.  
\q2 Saiono wali agaliru-o tínaga Ngode Datagaliwabenaga mini yaraga holene nga.   
\q1
\v 13 Ibugua Yarusalemenaga pabe panga kago mo hongo howa  
\q2 wali agali bu karu bayaleore biamogo bialu haga ka.   
\q1
\v 14 Ibugua tínaga dindi tubari handayaho halu  
\q2 widi bayaleru tí mabuha anda haga biledagola  
\q2 tígua widi lini dewaore nalu tombeho haga kamigoni.   
\b  
\q1
\v 15 Ibugua bi mbira dindihondo laragola  
\q2 bi ogoni hale halu abaleore biai haga.   
\q1
\v 16 Ibugua dindiguni timbunirume dindini dungume helalu  
\q2 puyabume abalu pulo yalu piagadagua pibiya pulo yu purogo lelaga ka.   
\q1
\v 17 Iba angeni iba mu wiame kadagua  
\q2 ibugua dalu ibilaragola dindiguni wiame helaga biaga.  
\q2 Ibugua dindini dagare ogonibi ibilaragola  
\q2 mbiralime dagare bidago bilowa dagare nahe tingi halu donge ho habe naheore ka.   
\q1
\v 18 Mani howa ibugua bi laragola dindiguni ngaru mo iba bu hinilaga.  
\q2 Ibugua puyabu ibilaragome iba bedago mo ema bia halu pelaga ka.   
\b  
\q1
\v 19 Ibugua ibunaga bi lowiniru Yagabahondo lamini.  
\q2 Ibunaga bi mana Isaraele wali agaliruhondo mini.   
\q1
\v 20 Ogonidagua ibugua hameigini tara tara dindi bibahendeha karuhondo nalami.  
\q2 Tigua ibunaga bi mana lo ngago manda nabi ka.  
\b  
\q1 Iname Anduane Homogonaga mini yaraga hami̱ya.   
\c 148  
\s1 Hari daligahabi dindihabi karu bibahendeoreme Anduane Homogonaga mini mo yaraga hai holene ngago ogo  
\q1
\v 1 Anduane Homogonaga mini mo yaraga hadaba-o.  
\q2 Tí hari daligaha kamiru bibahendeme Anduane Homogonaga miniore mo yaraga hadaba.   
\q1
\v 2 Ibunaga dahuliyali kamiru tí bibahendeme ibunaga miniore mo yaraga hadaba.  
\q2 Dahuliya andaganaga ami kamiru bibahendeme ibunaga mini mo yaraga hai hadaba.   
\b  
\q1
\v 3 Ni egela li kabigo libugua ibunaga mini mo yaraga hadaba.  
\q2 Yakundi harini li ngiringaralo bu kamiru tíguabi ibunaga mini mo yaraga hadaba.   
\q1
\v 4 Dahuliya andaga da habaneoreha kamiru tínime ibunaga mini mo yaraga hadaba.  
\q2 Hari daliga yarali howa iba uyura bedamirumebi ibunaga mini mo yaraga hadaba.   
\b  
\q1
\v 5 Mbirale uruni bibahendeore Anduane Homogo ibunaga bime tagira íbu hadaba laga biyagola  
\q2 tagira íbu haga binigo ka.  
\q1 Ibugua ani binigo uruni bibahendeoreme ibunaga mini mo yaraga hai holene nga.   
\q1
\v 6 Ibunaga bime ti hangu hangu abogo ogoria ha laga biyadagua haabo henego ka.\x + \xo 148.6 \xt Yob 38.33, Yar 33.20, 33.25\x*  
\q2 Ti mbiragome ibunaga bi mo wahabe nahe kagoni.   
\b  
\q1
\v 7 Dindini kamirumebi iba solowara guru kuyama unura bedarumebi  
\q2 wena gibiore wialuwiore unura bedamirumebi   
\q1
\v 8 hari dabamebi dalu dindigunimebi pibiyamebi hari beralibamebi  
\q2 puyabu hongoheore Anduane Homogonaga bi larago hale haga kamirumebi  
\q2 tí bibahendeoreme ibunaga mini mo yaraga haiore hadaba.   
\b  
\q1
\v 9 Dindi hari timbuni wedamirumebi dindi hari emene wedamirumebi  
\q2 ira lini nagane ale daga kamirumebi irabu ira kamirumebi   
\q1
\v 10 nogo hinini dambole kamirumebi nogo gabua tagira hope hene kamirumebi  
\q2 mbirale tombeme piaga ngamirumebi ega bibahende bedamirumebi  
\q2 ti bibahendeoreme Anduane Homogonaga mini mo yaraga haiore hadaba.   
\b  
\q1
\v 11 Kini kamirumebi wali agali bibahende bu kamirumebi gabumane kamirumebi agali haguane kamirumebi   
\q1
\v 12 igiri daliahe bu kamirumebi wandari daliahe bedamirumebi  
\q2 wali agali wahe kamirumebi wandari igiri emene kamirumebi  
\q2 tí bibahendeoreme Anduane Homogonaga mini mo yaraga haiore hadaba.   
\b  
\q1
\v 13 Ti bibahendeme Anduane Homogonaga mini mo yaraga haiore holene nga.  
\q1 Wali agali marunaga mini ngagobi ndo ibunaga mini daligaore ngagoni.  
\q2 Ibunaga mini baya burugule daliga gibiore ibu ale mende naheorego  
\q2 dahuliya andaga angua hai halu dindi bibahendebi angua hai kago  
\q2 ibu hangunaga mini mo yaraga haiore holene nga.   
\q1
\v 14 Anduane Homogo ibugua ibunaga Isaraele hameigini gubaliniore halu yabu howa mo hongo hayagola  
\q2 tigua ibunaga mini mo yaraga haga kagoni.  
\b  
\q1 Anduane Homogonaga miniore mo yaraga hai hadaba-o.   
\c 149  
\s1 Anduane Homogonaga mini yaraga halu iba gana lenego ogo  
\q1
\v 1 Anduane Homogonaga mini yaraga hama.  
\q2 Ibuhondo iba gana gahengeru lami̱ya.  
\q1 Wali agali ibuhondo mini bilinahe haga kamiru  
\q2 tígua ibu mitangi bialu lotu lole ngoai ho kamigoria ibunaga mini yaraga hadaba.   
\q1
\v 2 Isaraele wali agaliru-o ibugua tínaga Wabiaga ka mitangi bialu turuho hadaba.  
\q2 Saiono wali agaliru-o tínaga kini ibu kagonaga turu timbuni ho hadaba.   
\q1
\v 3 Tígua mali lialu ibunaga mini yaraga hadaba.  
\q2 Tabageru balubi ngida ale balubi ibunaga mini yaraga hadaba.   
\b  
\q1
\v 4 Anduane Homogohanda ibunaga wali agaliruhondo gubalini ho kagoni.  
\q2 Ibugua wali agali tini mo dindiha haga karunaga mini yaraga halu  
\q2 wai bialu wayali helo biamogo biaga ka.   
\q1
\v 5 Ngode Datagaliwabenaga wali agali tí wayali harimigonaga turuho holene nga.\x + \xo 149.5 \xt Yob 35.10\x*  
\q2 Mbiraga tíninaga dagiani biruwa tígua turu halu iba ganaru laabo holene nga.   
\q1
\v 6 Tigua Ngode Datagaliwabenaga mini yaraga halu bi dalimu lalu  
\q2 wai biagane ayu tibu ne gadeleru tíni gime yu howa ga̱ ladagadaga bialu turu ho holene nga.   
\q1
\v 7 Tígua ayu tibu yu howa hameigini tara tara dindi bibahendeha karu baba wai bialu  
\q2 wali agali Anduane Homogo manda nabi karu ti ko biyarunaga pani mialu  
\q2 bo wahai holene nga.   
\q1
\v 8 Waitiginaga kinibi agali haguane bu karubi  
\q2 pu seni aeaneme wabini ngagome tinaga gi geru minu dabaho helolene nga.   
\q1
\v 9 Ngode Datagaliwabehanda hameigini tara tara dindi bibahendeha bu karu  
\q2 pani mulene nga layadagua tígua milimu.  
\q1 Ngode Datagaliwabenaga wali agali kagome wayali ogonibi holebira.  
\b  
\q1 Anduane Homogonaga mini yaraga hami̱ya.   
\c 150  
\s1 Anduane Homogonaga mini mo yaragaore holene ngago ogo  
\q1
\v 1 Anduane Homogonaga miniore mo yaraga hai hami̱ya.  
\q2 Ngode Datagaliwabe ibu ibunaga andaha kago  
\q2 ibu mini mo yaraga hami̱ya.  
\q1 Dahuliya andagani ibu hongo gibiore ho kago  
\q2 ibunaga miniore mo yaraga hami̱ya. \fig Biguliru tabageru irabitele aleru ngi̱li̱nge̱le̱ lagane haeagobi ngaru ... tilitola lalu balu howa Anduane Homogonaga mini mo yaraga hami̱ya.|src="HK 62c, HK62d, HK 61d, HK 62f (as in Pisin Bible p 837).tif" size="2" ref="(150.3-5)" \fig*   
\q1
\v 2 Ibugua biabe hongohe gibiore bigi biyarunaga  
\q2 iname ibunaga mini mo yaragaore hami̱ya.  
\q2 Dunini gibi daligaorego ibuni hangu kago manda bialu  
\q2 ibu hangunaga mini mo yaraga hami̱ya.   
\q1
\v 3 Mbelo biguli pu lalu  
\q2 ibunaga mini mo yaraga hami̱ya.  
\q2 Ngida aleru balu mbirale kelengele laga irabitele aleru balu  
\q2 ibunaga mini mo yaraga hami̱ya.   
\q1
\v 4 Tabageru balu gi geru ema bialu mali lialu  
\q2 Anduane Homogonaga miniore mo yaraga hami̱ya.  
\q2 Ngida aleru balu pilipe aleru lalu howa  
\q2 ibunaga mini mo yaraga hami̱ya.   
\q1
\v 5 Mbirale ngi̱li̱nge̱le̱ lagane haeagobi ngaru hongo howa tilitola lalu balu howa  
\q2 Anduane Homogonaga mini mo yaraga hami̱ya.   
\q1
\v 6 Mbirale dindini emabu bu kamiru damenego bibahendeoreme  
\q2 Anduane Homogonaga mini mo yaraga hai halimu.  
\b  
\q1 Anduane Homogonaga mini mo yaraga haaboore hami̱ya.   