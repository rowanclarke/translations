\id HOS - Biblica® Open Kikuyu Holy Word of God
\h Hosea
\toc1 Hosea
\toc2 Hosea
\toc3 Hos
\mt1 HOSEA
\c 1
\p 
\v 1 Ĩno nĩyo ndũmĩrĩri ya Jehova ĩrĩa yakinyĩrĩire Hosea mũrũ wa Beeri hĩndĩ ya wathani wa Uzia, na wa Jothamu, na wa Ahazu, na wa Hezekia athamaki a Juda, na hĩndĩ ya wathani wa Jeroboamu mũrũ wa Joashu mũthamaki wa Isiraeli:
\s1 Mũtumia wa Hosea na Ciana Ciao
\p 
\v 2 Rĩrĩa Jehova aambĩrĩirie kwaria na kanua ka Hosea, Jehova aamwĩrire atĩrĩ, “Thiĩ, ũkahikie mũtumia mũmaraya na ũgĩe na ciana cia ũmaraya, tondũ andũ a bũrũri nĩmehĩtie, na ũndũ wa ũtharia mũũru mũno wa gũtirika Jehova.”
\v 3 Nĩ ũndũ ũcio Hosea akĩhikia Gomeri mwarĩ wa Dibilaimu, nake akĩgĩa nda na akĩmũciarĩra mwana wa kahĩĩ.
\p 
\v 4 Nake Jehova akĩĩra Hosea atĩrĩ, “Gatue Jezireeli, tondũ nĩngũherithia nyũmba ya Jehu o narua nĩ ũndũ wa ũragani mũnene ooraganire kũu Jezireeli,\f + \fr 1:4 \ft Jezireeli nĩ kuuga “Ngai nĩaharaganagia”.\f* na niine ũthamaki wa Isiraeli.
\v 5 Mũthenya ũcio-rĩ, nĩngoinanga ũta wa Isiraeli Gĩtuamba-inĩ kĩa Jezireeli.”
\p 
\v 6 Gomeri akĩgĩa nda rĩngĩ na agĩciara mwana wa kairĩtu. Nake Jehova akĩĩra Hosea atĩrĩ, “Gatue Lo-Ruhama, nĩgũkorwo ndigacooka kuonania wendo rĩngĩ kũrĩ nyũmba ya Isiraeli, atĩ ndĩmarekere o na atĩa.\f + \fr 1:6 \ft Lo-Ruhama nĩ kuuga “arĩa mataiguĩrĩirwo tha” kana “andũ matarĩ ende”.\f*
\v 7 No nĩngonania wendo kũrĩ nyũmba ya Juda; na nĩngamahonokia, na ti na ũndũ wa ũta, kana rũhiũ rwa njora kana mbaara, kana na mbarathi na ahaici acio, no nĩ ũndũ wa Jehova Ngai wao.”
\p 
\v 8 Thuutha wa gũtigithia Lo-Ruhama kuonga-rĩ, Gomeri agĩciara kahĩĩ kangĩ.
\v 9 Nake Jehova akĩmwĩra atĩrĩ, “Gatue Lo-Ammi, nĩ ũndũ inyuĩ mũtirĩ andũ akwa, na niĩ ndirĩ Ngai wanyu.\f + \fr 1:9 \ft Lo-Ammi nĩ kuuga “arĩa matarĩ andũ akwa”.\f*
\p 
\v 10 “No rĩrĩ, andũ a Isiraeli magaatuĩka ta mũthanga wa hũgũrũrũ-inĩ cia iria, ũrĩa ũtangĩthimĩka kana ũtarĩke. O handũ harĩa merĩirwo atĩrĩ, ‘Inyuĩ mũtirĩ andũ akwa’, no ho mageetwo ‘ariũ a Ngai ũrĩa ũrĩ muoyo’.
\v 11 Nao andũ a Juda na andũ a Isiraeli nĩmagacookanĩrĩra rĩngĩ, na nĩmagathuura mũndũ ũmwe amatongorie, nao nĩmakoima bũrũri ũcio, nĩgũkorwo mũthenya wa Jezireeli nĩũgaatuĩka mũthenya mũnene.
\c 2
\p 
\v 1 “Ha ũhoro wa ariũ a thoguo, meere atĩrĩ, ‘Inyuĩ mũrĩ andũ akwa’, na ha ũhoro wa aarĩ a thoguo, ũmeere atĩrĩ, ‘Inyuĩ mũrĩ endwa akwa’.\f + \fr 2:1 \ft Ruhama nĩ kuuga “arĩa maiguĩrĩirwo tha”, naguo Ammi nĩ kuuga “andũ akwa”.\f*
\s1 Isiraeli Kũherithio na Gũcookererio
\q1 
\v 2 “Thaithai nyina wanyu, mũthaithei,
\q2 nĩgũkorwo we ti mũtumia wakwa,
\q2 na niĩ ndirĩ mũthuuriwe.
\q1 Nĩeherie maũndũ ma ũtharia ũthiũ-inĩ wake,
\q2 na athengie ũmaraya gatagatĩ-inĩ ka nyondo ciake.
\q1 
\v 3 Akorwo ti ũguo ndĩmũrute nguo aikare arĩ njaga,
\q2 na ndũme aikare njaga o ta mũthenya ũrĩa aaciarirwo;
\q1 ngaamũtua ta werũ,
\q2 na ndĩmũgarũre atuĩke bũrũri mũngʼaru,
\q2 na ndĩmũũrage na nyoota.
\q1 
\v 4 Ndikaiguĩra ciana ciake tha,
\q2 tondũ nĩ ciana cia ũtharia.
\q1 
\v 5 Nyina wao akoretwo akĩhũũra ũmaraya,
\q2 na aagĩire nda ciao na njĩra cia ũũra-thoni.
\q1 Nĩ ũndũ oigĩte atĩrĩ, ‘Nĩngũrũmĩrĩra endwa akwa,
\q2 arĩa maaheaga irio ciakwa na maaĩ makwa,
\q1 na guoya wakwa wa ngʼondu o na gatani yakwa,
\q2 maguta makwa o na kĩrĩa nyuuaga.’
\q1 
\v 6 Nĩ ũndũ wa ũguo nĩngũhinga njĩra yake na mĩigua,
\q2 ndĩmũirigĩre thĩinĩ, aage njĩra ya kuumĩra.
\q1 
\v 7 Nĩagatengʼeria endwa ake na ndakamakinyĩra.
\q2 Akaamacaria na ndakamona.
\q1 Hĩndĩ ĩyo nĩagacooka oige atĩrĩ,
\q2 ‘Nĩngũcooka kũrĩ mũthuuri wakwa wa mbere,
\q2 nĩgũkorwo hĩndĩ ĩyo nĩndaikarĩte wega gũkĩra rĩu.’
\q1 
\v 8 Mũtumia ũcio nĩagire kũmenya atĩ nĩ niĩ
\q2 ndaamũheaga ngano, na ndibei ya mũhihano, o na maguta,
\q1 na ngamũingĩhĩria betha na thahabu,
\q2 iria maahũthagĩra gũthondeka ngai ĩrĩa ĩĩtagwo Baali.\f + \fr 2:8 \ft Andũ a Kaanani meetĩkĩtie atĩ Baali nĩyo yamaheaga ngano, na ndibei, na maguta.\f*
\b
\q1 
\v 9 “Tondũ ũcio nĩngoya ngano yakwa yakũra,
\q2 na ndibei yakwa ya mũhihano yagĩrĩra,
\q1 na ndĩmũtunye guoya wakwa wa ngʼondu na gatani yakwa,
\q2 o iria ciarĩ cia kũmũhumbĩra njaga yake.
\q1 
\v 10 Nĩ ũndũ ũcio, nĩngaguũria maũndũ make ma waganu
\q2 endwa ake mamwĩroreire;
\q2 gũtirĩ mũndũ ũkaamũteithũra moko-inĩ makwa.
\q1 
\v 11 Nĩnganiina ikeno ciake ciothe, arĩ cio:
\q2 ciathĩ ciake cia mwaka o mwaka, na Tũrũgamo twake twa mweri,
\q2 na mĩthenya yake ya Thabatũ, na ciathĩ ciake ciothe iria nyamũre.
\q1 
\v 12 Nĩngathũkangia mĩthabibũ yake na mĩkũyũ yake,
\q2 ĩrĩa oigire nĩ irĩhi rĩake kuuma kũrĩ endwa ake;
\q1 nĩngamĩtua ihinga,
\q2 na nyamũ cia gĩthaka nĩikamĩrĩa.”
\q1 
\v 13 Jehova ekuuga atĩrĩ,
\q1 “Nĩngamũherithia nĩ ũndũ wa mĩthenya ĩrĩa acinĩire Baali ũbumba;
\q2 rĩrĩa eegemagia na icũhĩ, na mathaga ma goro,
\q2 na akĩrũmĩrĩra endwa ake, no akĩriganĩrwo nĩ niĩ.
\b
\q1 
\v 14 “Nĩ ũndũ wa ũguo nĩngũmũguucĩrĩria na waara;
\q2 ngũmũtongoria nginya werũ-inĩ,
\q2 na ndĩmwarĩrie na ciugo cia wendo.
\q1 
\v 15 Kũu nĩkuo ngaamũcookeria mĩgũnda yake ya mĩthabibũ,
\q2 na ndue Kĩanda kĩa Akori mũrango wa mwĩhoko.\f + \fr 2:15 \ft Kĩanda kĩa Akori nĩ kuuga “thĩĩna” kana “gũthĩĩnio”.\f*
\q1 Kũu nĩkuo akaina o ta ũrĩa ainaga matukũ-inĩ ma ũnini wake,
\q2 aine ta ũrĩa ainire mũthenya ũrĩa aambatire kuuma bũrũri wa Misiri.”
\b
\q1 
\v 16 Jehova ekuuga atĩrĩ, “Mũthenya ũcio-rĩ,
\q2 nĩũkanjĩta ‘Mũthuuri wakwa’;
\q2 ndũkanjĩta rĩngĩ ‘Mwathi wakwa’.
\q1 
\v 17 Nĩngeheria marĩĩtwa ma Baali kuuma mĩromo-inĩ yake;
\q2 marĩĩtwa macio matikagwetwo rĩngĩ.
\q1 
\v 18 Mũthenya ũcio nĩngathondeka kĩrĩkanĩro
\q2 na nyamũ cia gĩthaka, o na nyoni cia rĩera-inĩ,
\q2 na ciũmbe iria ithiiagĩra gũkũ thĩ nĩ ũndũ wao.
\q1 Ũta, na rũhiũ rwa njora, na mbaara nĩngaciniina bũrũri-inĩ,
\q2 nĩgeetha othe makomage marĩ na thayũ.
\q1 
\v 19 Nĩngakũũria ũtuĩke mũtumia wakwa nginya tene;
\q2 ngaakũũria ũtuĩke wakwa ũhoro-inĩ wa ũthingu na wa kĩhooto,
\q2 ngũũrie ndĩ na wendo na tha.
\q1 
\v 20 Nĩngakũũria ũtuĩke wakwa na wĩhokeku,
\q2 nawe nĩũgetĩkĩra Jehova.”
\b
\q1 
\v 21 Jehova ekuuga atĩrĩ,
\q2 “Mũthenya ũcio-rĩ, nĩngacookia ũhoro;
\q1 nĩngacookeria matu ũhoro,
\q2 namo matu macookerie thĩ ũhoro;
\q1 
\v 22 nayo thĩ ĩcookerie ngano,
\q2 na ndibei ya mũhihano, na maguta ũhoro,
\q2 nacio nĩigacookeria Jezireeli ũhoro.
\q1 
\v 23 Nĩngamũhaanda bũrũri-inĩ nĩ ũndũ wakwa mwene;
\q2 nĩngonania wendo wakwa harĩ ũrĩa nderĩte atĩrĩ,
\qc ‘Niĩ ndikwendete’.
\q1 Arĩa nderĩte atĩrĩ, ‘Inyuĩ mũtirĩ andũ akwa’,
\q2 nĩngameera atĩrĩ,
\qc ‘Inyuĩ mũrĩ andũ akwa’;
\q2 na mũndũ o mũndũ oige atĩrĩ, ‘Wee nĩwe Ngai wakwa.’ ”
\c 3
\s1 Hosea na Mũtumia Wake Kũiguana Rĩngĩ
\p 
\v 1 Ningĩ Jehova akĩnjĩĩra atĩrĩ, “Thiĩ, wonie mũtumia waku wendo rĩngĩ, o na gũtuĩka nĩendetwo nĩ mũndũ ũngĩ na nĩ mũtharia. Mwende o ta ũrĩa Jehova endete andũ a Isiraeli, o na gũtuĩka nĩmagarũrũkagĩra ngai ingĩ na makenda keki iria nyamũre cia thabibũ nyũmũ.”
\p 
\v 2 Nĩ ũndũ ũcio ngĩmũgũra na thogora wa cekeri ikũmi na ithano\f + \fr 3:2 \ft nĩ ta giramu 170\f* cia betha, na ta homeri na letheku ĩmwe\f + \fr 3:2 \ft nĩ ta kilo 330\f* ya cairi.
\v 3 Ngĩcooka ngĩmwĩra atĩrĩ, “Nĩũgũtũũrania na niĩ matukũ maingĩ, na no nginya ũtige ũmaraya na ndũkendane na mũndũ ũngĩ, na niĩ nĩngũtũũrania nawe.”
\p 
\v 4 Nĩgũkorwo andũ a Isiraeli nĩmegũtũũra matukũ maingĩ matarĩ na mũthamaki kana mũnene, na matarĩ na igongona kana mahiga maamũre, na matarĩ na ebodi kana mũhianano.
\v 5 Thuutha ũcio andũ a Isiraeli nĩmagacooka na marongorie Jehova Ngai wao na Daudi mũthamaki wao. Nĩmagooka makĩinainaga kũrĩ Jehova na kũrĩ irathimo ciake matukũ-inĩ ma mũthia.
\c 4
\s1 Thitango ya Gũũkĩrĩra Isiraeli
\q1 
\v 1 Iguai ũhoro wa Jehova, inyuĩ andũ a Isiraeli,
\q2 tondũ Jehova nĩekũmũthitanga,
\q2 inyuĩ mũtũũraga thĩinĩ wa bũrũri ũyũ:
\q1 “Nĩ ũndũ-rĩ, gũtirĩ na wĩhokeku kana wendo,
\q2 kana kũmenya Ngai thĩinĩ wa bũrũri ũyũ.
\q1 
\v 2 Kĩrĩa kũrĩ no kũrumana, na kũheenania, na ũragani,
\q2 na ũici, na ũtharia;
\q1 maũndũ macio makaingĩha mũno,
\q2 na ũiti wa thakame ũkarũmĩrĩra ũiti wa thakame.
\q1 
\v 3 Nĩ ũndũ wa gĩtũmi kĩu bũrũri nĩũracakaya,
\q2 na arĩa othe matũũraga thĩinĩ waguo makahinyara;
\q1 nyamũ cia gĩthaka, na nyoni cia rĩera-inĩ,
\q2 na thamaki cia iria-inĩ nĩgũkua irakua.
\b
\q1 
\v 4 “No rĩrĩ, ndũkareke mũndũ arehe thitango,
\q2 mũndũ ndagathitange ũrĩa ũngĩ,
\q1 nĩgũkorwo andũ anyu mahaana andũ arĩa
\q2 mathitangaga mũthĩnjĩri-Ngai.
\q1 
\v 5 Mũhĩngagwo mũthenya na ũtukũ,
\q2 na anabii makahĩngwo hamwe na inyuĩ.
\q1 Nĩ ũndũ ũcio nĩnganiina maitũguo.
\q2 
\v 6 Andũ akwa maniinagwo nĩ ũndũ wa kwaga ũmenyo.
\b
\q1 “Tondũ nĩmũregete ũmenyo,
\q2 o na niĩ nĩndĩmũregete mũtuĩke athĩnjĩri-Ngai akwa;
\q1 tondũ nĩmũtiganĩirie watho wa Ngai wanyu,
\q2 o na niĩ nĩngatiganĩria ciana cianyu.
\q1 
\v 7 O ũrĩa athĩnjĩri-Ngai maingĩhaga,
\q2 noguo maakĩragĩrĩria kũnjĩhĩria;
\q2 nao magĩkũũrania riiri wao na kĩndũ gĩa thoni.
\q1 
\v 8 Mehũũnagia na mehia ma andũ akwa,
\q2 na magakenera waganu wao.
\q1 
\v 9 Na nĩgũgatuĩka atĩrĩ: O ta ũrĩa andũ makaahaana,
\q2 no taguo athĩnjĩri-Ngai makaahaana.
\q1 Nĩngamaherithia othe nĩ ũndũ wa mĩthiĩre yao,
\q2 na ndĩmarĩhe kũringana na ciĩko ciao.
\b
\q1 
\v 10 “Makaarĩĩaga no matikahũũna,
\q2 makaahũũraga ũmaraya no matikaingĩha,
\q1 tondũ nĩmatiganĩirie Jehova
\q2 nĩguo meheane
\v 11 kũrĩ ũmaraya,
\q1 na kũnyua ndibei ĩrĩa ngũrũ na ya mũhihano,
\q2 iria cieheragia ũmenyo
\v 12 wa andũ akwa.
\q1 Mahooyaga kĩrĩra kuuma kũrĩ mũhianano mũicũhie,
\q2 naruo rũthanju rwa ũragũri rũkamacookeria ũhoro.
\q1 Roho wa ũmaraya nĩũmahĩtithagia njĩra;
\q2 makaaga kwĩhokeka kũrĩ Ngai wao.
\q1 
\v 13 Marutagĩra igongona irĩma igũrũ,
\q2 na magacinĩra maruta ma njino tũrĩma-inĩ,
\q1 na rungu rwa mũtĩ wa mũgandi, na wa mũribina, o na mũceceni,
\q2 tondũ kĩĩruru kĩayo nĩ kĩega.
\q1 Nĩkĩo airĩtu anyu mahũũraga ũmaraya,
\q2 na atumia a ariũ anyu magatharia.
\b
\q1 
\v 14 “Ndikaherithia airĩtu anyu maahũũra ũmaraya,
\q2 kana herithie atumia a ariũ anyu maatharia,
\q1 tondũ arũme o ene mathiiaga thiritũ na maraya,
\q2 na makarutaga igongona hamwe na maraya ma mahooero-inĩ:
\q2 nĩ ũndũ ũcio andũ matarĩ ũmenyo nĩmakanangĩka!
\b
\q1 
\v 15 “Atĩrĩ wee Isiraeli, o na gũtuĩka nĩũtharagia-rĩ,
\q2 Juda nĩagĩtige kwĩhia.
\b
\q1 “Ndũgathiĩ Giligali;
\q2 o na ndũkambate Bethi-Aveni.\f + \fr 4:15 \ft Bethi-Aveni rĩarĩ rĩĩtwa rĩa kũnyũrũria Betheli, tondũ Bethi-Aveni nĩ kuuga “Nyũmba ya waganu”, naguo Betheli nĩ kuuga “Nyũmba ya Ngai”.\f*
\q2 Na ndũkehĩte uuge atĩrĩ, ‘Ti-itherũ o ta ũrĩa Jehova atũũraga muoyo!’
\q1 
\v 16 Andũ a Isiraeli mangʼathĩtie
\q2 o ta moori ngʼathia.
\q1 Kũngĩhoteka atĩa Jehova amarĩithie
\q2 ta tũgondu tũrĩ nyeki-inĩ nduru?
\q1 
\v 17 Efiraimu nĩegwatanĩtie na mĩhianano;
\q2 tiganai nake!
\q1 
\v 18 O na rĩrĩa kĩndũ kĩao gĩa kũnyua gĩthirĩte-rĩ,
\q2 no mathiiaga na mbere na ũmaraya wao;
\q2 aathani ao nĩmendete mũno njĩra cia thoni.
\q1 
\v 19 Kĩhuhũkanio kĩnene gĩkaamahaata kĩmombũkie,
\q2 na magongona mao nĩmakamaconorithia.
\c 5
\s1 Isiraeli Gũtuĩrwo Ciira
\q1 
\v 1 “Iguai ũhoro ũyũ, inyuĩ athĩnjĩri-Ngai!
\q2 Tegai matũ, inyuĩ andũ a Isiraeli!
\q1 Thikĩrĩria, wee nyũmba ya ũthamaki!
\q2 Nĩ inyuĩ mũgũtuĩrwo ciira ũyũ:
\q1 Mũkoretwo mũrĩ mũtego kũu Mizipa,
\q2 na mũrĩ wabu ya gũtegana yarĩtwo kũu Taboru.
\q1 
\v 2 Aregi a watho nĩmarikĩire ũragani-inĩ.
\q2 Niĩ nĩngamaherithia othe.
\q1 
\v 3 Niĩ nĩnjũũĩ maũndũ mothe ma Efiraimu;
\q2 Isiraeli ndahithĩtwo kuuma kũrĩ niĩ.
\q1 Wee Efiraimu, rĩu nĩũhũrĩte ũmaraya;
\q2 Isiraeli nake nĩathũkĩte.
\b
\q1 
\v 4 “Ciĩko ciao itingĩmetĩkĩria
\q2 gũcookerera Ngai wao.
\q1 Roho wa ũmaraya ũrĩ ngoro-inĩ ciao,
\q2 nao makaaga kũmenya Jehova.
\q1 
\v 5 Mwĩtĩĩo wa Isiraeli nĩũrutaga ũira wa kũmookĩrĩra;
\q2 andũ a Isiraeli na Efiraimu mahĩngagwo nĩ mehia mao;
\q2 Juda o nake akahĩngwo hamwe nao.
\q1 
\v 6 Hĩndĩ ĩrĩa magaathiĩ na ndũũru ciao cia mbũri na cia ngʼombe
\q2 kũrongooria Jehova-rĩ,
\q2 matikamuona; we nĩamehereire.
\q1 
\v 7 Nĩmagĩte kwĩhokeka harĩ Jehova;
\q2 nao magaciara ciana itarĩ na ũngai.
\q1 Na rĩrĩ, ciathĩ ciao cia Karũgamo ka Mweri
\q2 nĩikaamameria, o hamwe na mĩgũnda yao.
\b
\q1 
\v 8 “Huhai karumbeta kũu Gibea,
\q2 na mũhuhe coro kũu Rama.
\q1 Muuge mbu ya gwĩtana mbaara kũu Bethi-Aveni;
\q2 wee Benjamini, wĩhũũge.
\q1 
\v 9 Efiraimu nĩgũgakira ihooru
\q2 mũthenya ũcio wa ituĩro.
\q1 Gatagatĩ-inĩ ka mĩhĩrĩga ya Isiraeli-rĩ,
\q2 niĩ ngwanĩrĩra ũrĩa kũrĩ.
\q1 
\v 10 Atongoria a Juda mahaana
\q2 andũ arĩa meheragia mahiga ma mĩhaka.
\q1 Nĩngamaitĩrĩria mangʼũrĩ makwa,
\q2 taarĩ kĩguũ kĩa maaĩ.
\q1 
\v 11 Efiraimu nĩmũhinyĩrĩrie,
\q2 akarangĩrĩrio ituĩro-inĩ rĩa ciira,
\q2 nĩ ũndũ wa kwenda kũrũmĩrĩra mĩhianano.
\q1 
\v 12 Niĩ haana memenyi kũrĩ Efiraimu,
\q2 na ngahaana ta ũbuthu kũrĩ andũ a Juda.
\b
\q1 
\v 13 “Rĩrĩa Efiraimu oonire ndwari yake,
\q2 nake Juda akĩona ironda ciake-rĩ,
\q1 hĩndĩ ĩyo Efiraimu agĩthiĩ kũrĩ Ashuri,
\q2 na agĩtũmana kũrĩ mũthamaki ũcio mũnene nĩguo amũteithie.
\q1 Nowe ndangĩhota gũkũhonia,
\q2 o na kana ahonie ironda ciaku.
\q1 
\v 14 Niĩ ngaatuĩka ta mũrũũthi kũrĩ Efiraimu,
\q2 nduĩke ta mũrũũthi ũrĩ hinya kũrĩ Juda.
\q1 Ngaamatambuuranga, njooke ndĩthiĩre;
\q2 ngaamataha, na gũtirĩ mũndũ ũkaamahonokia.
\q1 
\v 15 Ningĩ niĩ nĩngacooka gwakwa,
\q2 nginya rĩrĩa magetĩkĩra mahĩtia mao.
\q1 Nao nĩmakarongooria ũthiũ wakwa;
\q2 nao mona mathĩĩna nĩmakanongoria na kĩo.”
\c 6
\s1 Isiraeli Kwaga Kwĩrira
\q1 
\v 1 “Ũkai, rekei tũcookerere Jehova.
\q1 Nĩatũtambuurangĩte,
\q2 no nĩegũtũhonia;
\q1 nĩatũtihangĩtie,
\q2 no nĩegũtuoha ironda ciitũ.
\q1 
\v 2 Thuutha wa matukũ meerĩ, nĩagatwarahũra;
\q2 mũthenya wa ĩtatũ nĩagatũcookereria
\q2 nĩguo tũtũũre muoyo mbere yake.
\q1 
\v 3 Nĩtũmenyei Jehova,
\q2 na tũkĩrĩrĩrie kũmũmenya.
\q1 Ti-itherũ o ta ũrĩa riũa rĩrathaga-rĩ,
\q2 noguo o nake akooneka;
\q1 agooka kũrĩ ithuĩ ta mbura ya hĩndĩ ya heho,
\q2 kana ta mbura ya gũkũria irio ĩrĩa yuraga thĩ.”
\b
\q1 
\v 4 “Wee Efiraimu-rĩ, ingĩgwĩka atĩa?
\q2 Na wee Juda-rĩ, ngũgwĩka atĩa?
\q1 Wendo waku ũhaana ta kĩbii kĩa rũciinĩ,
\q2 ũkahaana ta ime rĩa rũciinĩ rĩrĩa rĩcookaga rĩgathira.
\q1 
\v 5 Nĩkĩo ndaagũtinangirie icunjĩ na tũnua twa anabii akwa,
\q2 ngĩkũũraga na ciugo cia kanua gakwa;
\q2 matuĩro makwa magĩkĩhenũka ta rũheni igũrũ rĩaku.
\q1 
\v 6 Nĩgũkorwo nyendaga tha no ti igongona,
\q2 na kũmenya Ngai gũkĩra maruta ma njino.
\q1 
\v 7 O ta ũrĩa Adamu aathũkirie kĩrĩkanĩro gĩakwa,
\q2 noguo maagire kwĩhokeka ũndũ-inĩ ũcio.
\q1 
\v 8 Gileadi nĩ itũũra inene rĩa andũ aaganu,
\q2 rĩhakĩtwo imeni nĩ makinya marĩ na thakame.
\q1 
\v 9 O ta ũrĩa ikundi cia atunyani ciĩhithagĩra mũndũ,
\q2 no taguo ikundi cia athĩnjĩri-Ngai ciĩkaga;
\q1 moraganagĩra njĩra-inĩ ya gũthiĩ Shekemu,
\q2 makagera ngero cia thoni.
\q1 
\v 10 Niĩ nĩnyonete ũndũ mũũru mũno
\q2 nyũmba-inĩ ya Isiraeli.
\q1 Kũu nĩkuo Efiraimu eheanĩte ahũũre ũmaraya,
\q2 nake Isiraeli nĩakanyiitwo nĩ thaahu.
\b
\q1 
\v 11 “O na kũrĩ we, wee Juda,
\q2 nĩwathĩrĩirio ihinda rĩa magetha.
\b
\q1 “O hĩndĩ ĩrĩa ndaacookeria andũ akwa maũndũ ma kũmaguna,
\c 7
\q1 
\v 1 o rĩrĩa ndenda kũhonia Isiraeli-rĩ,
\q1 mehia ma Efiraimu makonanio,
\q2 nacio ngero cia Samaria ikaguũrio.
\q1 Maaragia maũndũ ma maheeni,
\q2 na aici magatua nyũmba, magatoonya,
\q2 nacio njangiri igatunyana indo njĩra-inĩ;
\q1 
\v 2 no rĩrĩ, matimenyaga
\q2 atĩ nĩndirikanaga ciĩko icio ciao njũru ciothe.
\q1 Mehia mao nĩmamarigiicĩirie;
\q2 makoragwo mbere yakwa hĩndĩ ciothe.
\b
\q1 
\v 3 “Makenagia mũthamaki na waganu wao,
\q2 magakenia anene na maheeni mao.
\q1 
\v 4 Othe nĩ itharia,
\q2 maakanaga ta riiko rĩa kũrugĩra mĩgate,
\q1 rĩrĩa mũrugi wa mĩgate atabataragio nĩ gwakĩrĩria
\q2 kuuma gũkanda mũtu nginya ũimbe.
\q1 
\v 5 Mũthenya wa gĩathĩ kĩa mũthamaki witũ-rĩ,
\q2 we na anene ake manyuuaga ndibei makarĩĩo,
\q2 nake akanyiitana moko na arĩa manyũrũranagia.
\q1 
\v 6 Ngoro ciao nĩ ta riiko rĩa kũrugĩra mĩgate;
\q2 mathiiaga harĩ we marĩ na waara.
\q1 Thuti ciao ciakanaga kahora ũtukũ wothe;
\q2 nakuo gwakĩa rũciinĩ igaakana ta mwaki wa rũrĩrĩmbĩ.
\q1 
\v 7 Othe mahiũhĩte ta riiko rĩa kũrugĩra mĩgate;
\q2 moragaga aathani ao.
\q1 Athamaki ao othe maniinagwo,
\q2 na gũtirĩ o na ũmwe wao ũngayagĩra.
\b
\q1 
\v 8 “Efiraimu nĩetukanĩtie na ndũrĩrĩ;
\q2 Efiraimu nĩ mũgate ũtarĩ mũgarũre.
\q1 
\v 9 Andũ a kũngĩ marĩĩaga hinya wake,
\q2 nowe ndamenyaga ũguo.
\q1 Njuĩrĩ ciake irĩ na mbuĩ,
\q2 nowe ndoonaga ũguo.
\q1 
\v 10 Mwĩtĩĩo wa Isiraeli nĩũrutaga ũira wa kũmũũkĩrĩra,
\q2 no o na kũrĩ ũguo-rĩ,
\q1 we ndacookagĩrĩra Jehova Ngai wake,
\q2 kana akamũrongooria.
\b
\q1 
\v 11 “Efiraimu ahaana ta ndutura,
\q2 ĩrĩa ĩheenekaga narua, ĩtarĩ ũmenyo;
\q1 rĩmwe akayagĩra bũrũri wa Misiri
\q2 na rĩrĩa rĩngĩ agathiĩ Ashuri.
\q1 
\v 12 Rĩrĩa magaathiĩ-rĩ, nĩngaikia wabu yakwa igũrũ rĩao;
\q2 nĩngamaharũrũkia ta nyoni cia rĩera-inĩ.
\q1 Rĩrĩa ngaigua nĩmaracookanĩrĩra-rĩ,
\q2 nĩngamanyiita.
\q1 
\v 13 Kaĩ marĩ na haaro-ĩ,
\q2 tondũ nĩmandiganĩirie!
\q1 Maroniinwo,
\q2 tondũ nĩmanemeire!
\q1 Niĩ nĩnyendaga kũmahonokia,
\q2 no-o no igenyo manjigagĩrĩra.
\q1 
\v 14 Matingayagĩra kuuma ngoro-inĩ ciao,
\q2 no kũgirĩka magirĩkaga marĩ marĩrĩ-inĩ mao.
\q1 Monganaga hamwe nĩ ũndũ wa ngano, na ndibei ya mũhihano,
\q2 no niĩ makaahutatĩra.
\q1 
\v 15 Ndaamathomithirie na ngĩmekĩra hinya,
\q2 no-o mathugundaga kũnjĩka ũũru.
\q1 
\v 16 Maticookagĩrĩra Ũrĩa-ũrĩ-Igũrũ-Mũno;
\q2 mahaana ta ũta ũrĩa ũhĩtagia wathi.
\q1 Atongoria ao makooragwo na rũhiũ rwa njora,
\q2 nĩ ũndũ wa ciugo ciao cia rũtũrĩko.
\q1 Nĩ ũndũ wa ũguo nĩmakanyũrũrio
\q2 kũu bũrũri wa Misiri.
\c 8
\s1 Isiraeli Kũgetha Kĩhuhũkanio
\q1 
\v 1 “Huhai karumbeta mwĩhũge!
\q2 Thũ ĩrerete igũrũ rĩa nyũmba ya Jehova ta nderi,
\q1 tondũ andũ nĩmathũkĩtie kĩrĩkanĩro gĩakwa,
\q2 na makarega watho wakwa.
\q1 
\v 2 Isiraeli nĩarangaĩra, akoiga atĩrĩ,
\q2 ‘Wee Ngai witũ, nĩtũkũmenyete!’
\q1 
\v 3 No Isiraeli nĩaregete ũndũ ũrĩa mwega;
\q2 nĩ ũndũ ũcio thũ nĩĩkamũingatithia.
\q1 
\v 4 Marũgamagia athamaki matarĩ na rũtha rwakwa,
\q2 magathuura anene itametĩkĩrĩtie.
\q1 Methondekagĩra mĩhianano
\q2 na betha na thahabu ciao,
\q2 nayo ĩgatuĩka ya kũmaniina.
\q1 
\v 5 Wee Samaria-rĩ, te mũhianano wa ngai ĩyo ya njaũ!
\q2 Marakara makwa nĩmakanĩte harĩ yo.
\q1 Nĩ nginya-rĩ megũtũũra maremetwo nĩgũikara marĩ atheru?
\q2 
\v 6 Acio moimĩte Isiraeli!
\q1 Njaũ ĩno nĩ mũturi ũmĩthondekete;
\q2 yo ti Ngai.
\q1 Njaũ ĩyo ya Samaria-rĩ,
\q2 nĩĩkoinangwo icunjĩ.
\b
\q1 
\v 7 “Mahaandaga rũhuho,
\q2 makagetha kĩhuhũkanio;
\q1 ngano ndĩrĩ na magira,
\q2 ndĩngiumia mũtu;
\q1 korwo no ĩciare ngano,
\q2 andũ a kũngĩ nĩo mangĩmĩrĩa.
\q1 
\v 8 Isiraeli nĩameretio;
\q2 rĩu arĩ gatagatĩ ka ndũrĩrĩ
\q2 ahaana ta kĩndũ gĩtarĩ bata.
\q1 
\v 9 Nĩgũkorwo nĩmambatĩte, magathiĩ Ashuri,
\q2 ta ndigiri ya gĩthaka ĩkĩũrũra ĩrĩ iiki.
\q2 Efiraimu nĩeyendetie kũrĩ endwa ake.
\q1 
\v 10 O na gũtuĩka nĩmeyendetie gatagatĩ-inĩ ka ndũrĩrĩ,
\q2 rĩu nĩngũmacookanĩrĩria hamwe.
\q1 Mekwambĩrĩria kũhinyara,
\q2 mahinyĩrĩirio nĩ mũthamaki ũrĩa ũrĩ hinya.
\b
\q1 
\v 11 “O na gũtuĩka Efiraimu nĩakĩte igongona nyingĩ
\q2 cia kũrutagĩrwo maruta ma kũhoroherio mehia,
\q2 icio ituĩkĩte igongona cia kwĩhagĩria.
\q1 
\v 12 Ndaamandĩkĩire maũndũ maingĩ watho-inĩ wakwa,
\q2 no makĩmatua taarĩ maũndũ mageni.
\q1 
\v 13 Marutaga magongona marĩa ndeheirwo,
\q2 magacooka makarĩa nyama icio,
\q2 no Jehova ndakenagio nĩmo.
\q1 Na rĩrĩ, nĩekũririkana waganu wao,
\q2 na aherithie mehia mao.
\q2 Nao nĩmagacooka bũrũri wa Misiri.
\q1 
\v 14 Isiraeli nĩariganĩirwo nĩ ũrĩa wamũmbire,
\q2 na agaaka nyũmba cia ũnene;
\q2 Juda nĩairigĩire matũũra maingĩ na thingo cia hinya.
\q1 No nĩngarehere matũũra mao manene mwaki
\q2 ũrĩa ũgaacina ciikaro ciao iria ciirigĩtwo na hinya.”
\c 9
\s1 Kũherithio kwa Isiraeli
\q1 
\v 1 Wee Isiraeli-rĩ, tiga gũkena;
\q2 tiga gũkũngũĩra ta ndũrĩrĩ iria ingĩ.
\q1 Nĩgũkorwo ũkoretwo ũtarĩ mwĩhokeku harĩ Ngai waku;
\q2 wee nĩwendete mũcaara wa maraya,
\q2 ũkaũcaragia kũrĩa guothe kũhuhagĩrwo ngano.
\q1 
\v 2 Ihuhĩro cia ngano na ihihĩro cia ndibei itikahũũnia andũ,
\q2 o na gũtigakorwo na ndibei ya mũhihano.
\q1 
\v 3 Matigaatũũra bũrũri wa Jehova;
\q2 Efiraimu agaacooka bũrũri wa Misiri,
\q2 na arĩe irio irĩ thaahu kũu Ashuri.
\q1 
\v 4 Matigaitĩra Jehova maruta ma ndibei,
\q2 kana magongona mao mamũkenie.
\q1 Kũrĩo magongona ta macio makaahaana ta mũgate wa andũ megũcakaya;
\q2 arĩa othe makaamarĩa nĩmakanyiitwo nĩ thaahu.
\q1 Irio icio igaakorwo irĩ ciao o ene;
\q2 itikareehwo hekarũ-inĩ ya Jehova.
\b
\q1 
\v 5 Mũgeeka atĩa mũthenya ũrĩa mwamũre wa ciathĩ cianyu,
\q2 mĩthenya ĩyo ya gĩathĩ kĩa Jehova?
\q1 
\v 6 O na mangĩkaahonoka kwanangwo,
\q2 andũ a bũrũri wa Misiri nĩmakamacookereria,
\q2 nao andũ a Memufisi mamathike.
\q1 Congʼe nĩguo ũgaacooka handũ ha igĩĩna ciao cia betha,
\q2 nayo mĩigua ĩhumbĩre hema ciao.
\q1 
\v 7 Matukũ ma kũherithio nĩmakinyu,
\q2 ĩĩ, matukũ ma kũrĩhania nĩmakinyĩte.
\q2 Isiraeli nĩamenye ũguo.
\q1 Tondũ mehia manyu nĩ maingĩ mũno,
\q2 na rũmena rwanyu rũkaneneha mũno,
\q1 mũnabii akoonagwo arĩ mũndũ mũkĩĩgu,
\q2 na mũndũ ũrĩa ũrĩ na ũrathi akonwo arĩ mũgũrũki.
\q1 
\v 8 Mũnabii nĩwe ũtuĩtwo mũrangĩri\f + \fr 9:8 \ft Arangĩri maarĩ anabii arĩa a ma, na nĩo matendetwo nĩ andũ a Isiraeli.\f* wa Efiraimu nĩ Ngai wakwa;
\q1 no rĩrĩ, mĩtego ĩmwetereire njĩra-inĩ ciake ciothe,
\q2 na rũmena rũkamweterera nyũmba-inĩ ya Ngai wake.
\q1 
\v 9 Nĩmatoonyereire, makarikĩra mũno ũũru-inĩ,
\q2 o ta ũrĩa meekire matukũ-inĩ ma Gibea.
\q1 Nake Ngai nĩakaririkana waganu wao,
\q2 na amaherithie nĩ ũndũ wa mehia mao.
\b
\q1 
\v 10 “Rĩrĩa ndaamenyire Isiraeli,
\q2 kwarĩ ta mũndũ onete thabibũ werũ-inĩ;
\q1 rĩrĩa ndonire maithe manyu-rĩ,
\q2 kwarĩ ta mũndũ onete matunda ma mũtĩ wa mũkũyũ marĩa maambaga kwĩrua.
\q1 No rĩrĩa Isiraeli mookire Baali-Peoru,
\q2 nĩmeyamũrĩire mũhianano ũcio wa gĩconoko,
\q2 na magĩthũka, magĩtuĩka o ta kĩndũ kĩu mendete.
\q1 
\v 11 Riiri wa Efiraimu ũkoombũka ta nyoni ũũre:
\q2 gũtigakorwo ũhoro wa gũciara, kana gũkuua nda, o na kana kũgĩa nda.
\q1 
\v 12 O na mangĩkaarera ciana-rĩ,
\q2 nĩngaciũraga ciothe.
\q1 Rĩrĩa ngaagarũrũka ndĩmatige,
\q2 kaĩ nĩmagakorwo na haaro-ĩ!
\q1 
\v 13 Nĩnyonete Efiraimu,
\q2 ahaandĩtwo handũ hega, o ta Turo.
\q1 No rĩrĩ, Efiraimu akaaruta ciana ciake,
\q2 acineane kũrĩ mũũragani.”
\b
\q1 
\v 14 Mahe, Wee Jehova;
\q2 no nĩ kĩĩ ũkũmahe?
\q1 Mahe nda iria ihunaga,
\q2 na ũmahe nyondo iria itarĩ iria.
\b
\q1 
\v 15 “Nĩ ũndũ wa waganu wao wothe marĩ kũu Giligali,
\q2 nĩkĩo ndamamenire marĩ o kũu.
\q1 Nĩ ũndũ wa ciĩko ciao cia mehia-rĩ,
\q2 nĩngamarutũrũra moime nyũmba yakwa,
\q1 na ndigacooka kũmenda rĩngĩ;
\q2 atongoria ao othe nĩ aremi.
\q1 
\v 16 Andũ a Efiraimu nĩacine nĩ mbaa,
\q2 naguo mũri wao nĩũhoohete,
\q2 maticiaraga maciaro.
\q1 O na mangĩciara ciana-rĩ,
\q2 nĩngooraga ciana icio ciao mendete.”
\b
\q1 
\v 17 Ngai wakwa nĩakamarega,
\q2 nĩgũkorwo matiamwathĩkĩire;
\q2 magaatuĩka andũ a kũũrũũraga ndũrĩrĩ-inĩ.
\c 10
\q1 
\v 1 Isiraeli aarĩ ta mũthabibũ watheeremaga,
\q2 nake agĩĩciarĩra maciaro.
\q1 O ũrĩa maciaro make maingĩhaga-rĩ,
\q2 noguo nake aakaga igongona nyingĩ;
\q1 o ũrĩa bũrũri wake wagaacagĩra-rĩ,
\q2 noguo aagemagia mahiga make marĩa maamũre ma kũhooyagwo.
\q1 
\v 2 Ngoro ciao nĩ cia maheeni,
\q2 na rĩu no nginya marĩhio wĩhia wao.
\q1 Jehova nĩakamomora igongona ciao,
\q2 na athũkangie mahiga macio mao maamũre ma kũhooyagwo.
\b
\q1 
\v 3 Ningĩ nĩmakoiga atĩrĩ, “Tũtirĩ na mũthamaki,
\q2 tondũ tũtiigana gũtĩĩa Jehova.
\q1 No o na korwo twarĩ na mũthamaki-rĩ,
\q2 nĩ atĩa angĩahotire gũtwĩkĩra?”
\q1 
\v 4 Meranagĩra ciĩranĩro nyingĩ,
\q2 na makehĩta mĩĩhĩtwa ya maheeni,
\q2 na magathondeka irĩkanĩro;
\q1 nĩ ũndũ ũcio maciira makunũkaga
\q2 ta mahuti marĩ ũrogi marĩa mameraga hianyũ-inĩ.
\q1 
\v 5 Andũ arĩa matũũraga Samaria metangaga
\q2 nĩ ũndũ wa mũhianano wa njaũ ĩrĩa ya Bethi-Aveni.
\q1 Amu andũ akuo nĩmakamĩcakaĩra,
\q2 na noguo athĩnjĩri-ngai a mĩhianano ĩyo mageeka
\q1 arĩa makenagĩra riiri wayo,
\q2 tondũ nĩyeheretio kuuma kũrĩ o, ĩgathaamĩrio kũndũ kũngĩ.
\q1 
\v 6 Nayo ĩgaatwarwo Ashuri,
\q2 ĩtuĩke kĩheo kũrĩ mũthamaki ũcio mũnene.
\q1 Efiraimu nĩagaconorithio;
\q2 Isiraeli nake nĩagaconoka nĩ ũndũ wa mĩhianano ĩyo yake ya mĩtĩ.
\q1 
\v 7 Samaria na mũthamaki wakuo magaathererio
\q2 ta karũhonge karĩ igũrũ wa maaĩ, maniinwo.
\q1 
\v 8 Kũndũ kũrĩa gũtũũgĩru gwĩkagĩrwo waganu nĩgũkanangwo,
\q2 na nĩkuo kwene wĩhia wa Isiraeli.
\q1 Mĩigua na mahiũ ma nyeki-inĩ nĩcio igaakũra kuo,
\q2 nacio ihumbĩre igongona ciao.
\q1 Nao andũ nĩmakeera irĩma atĩrĩ, “Tũhumbĩrei!”
\q2 na macooke meere tũrĩma atĩrĩ, “Tũgwĩrei!”
\b
\q1 
\v 9 “Wee Isiraeli-rĩ, kuuma o matukũ-inĩ ma Gibea
\q2 ũtũũrĩte wĩhagia, na ũguo noguo ũtũũraga.
\q1 Githĩ mbaara ndĩakinyĩire eeki ũũru kũu Gibea?
\q1 
\v 10 Rĩrĩa niĩ ngenda, nĩngamaherithia;
\q2 ndũrĩrĩ nĩigacookanĩrĩra,
\q1 imokĩrĩre nĩguo imoohe imatahe
\q2 nĩ ũndũ wa mehia mao kũingĩha.
\q1 
\v 11 Efiraimu nĩ moori menyerie wĩra
\q2 ĩrĩa yendete gũkonyora ngano;
\q1 nĩ ũndũ ũcio nĩngamĩoha icooki
\q2 ngingo-inĩ yayo thaka.
\q1 Nĩngatwarithia Efiraimu,
\q2 Juda no nginya agaacimba na mũraũ,
\q2 nake Jakubu no nginya agaacimba gĩtira.
\q1 
\v 12 Rĩu-rĩ, mwĩhaandĩrei ũhoro wa ũthingu,
\q2 nĩguo mwĩgethere maciaro ma wendo ũtathiraga,
\q1 na mũciimbe mĩgũnda yanyu ya ngamba;
\q2 nĩgũkorwo ihinda nĩ ikinyu rĩa kũrongooria Jehova,
\q1 nginya rĩrĩa agooka,
\q2 oirie mbura ya ũthingu igũrũ rĩanyu.
\q1 
\v 13 No rĩrĩ, inyuĩ mũhaandĩte waganu,
\q2 mũkagetha ũũru;
\q2 inyuĩ mũrĩĩte maciaro ma maheeni.
\q1 Tondũ mwĩhokaga hinya wanyu inyuĩ ene,
\q2 o na wa njamba cianyu nyingĩ cia ita-rĩ,
\q1 
\v 14 mũrurumo wa mbaara nĩũgokĩrĩra andũ aku.
\q2 Nĩ ũndũ ũcio ciikaro ciaku iria nũmu nĩikaanangwo,
\q1 o ta ũrĩa Shalimani aanangire Bethi-Arabeli mũthenya ũrĩa wa mbaara,
\q2 rĩrĩa manyina ma twana maatungumanirio thĩ hamwe na twana twao.
\q1 
\v 15 Ũguo noguo ũgeekwo wee Betheli,
\q2 nĩ ũndũ wa waganu waku mũnene.
\q1 Rĩrĩa mũthenya ũcio ũgaakĩa-rĩ,
\q2 mũthamaki wa Isiraeli nĩakaniinwo biũ.
\b
\c 11
\q1 
\v 1 “Rĩrĩa Isiraeli aarĩ kaana-rĩ, nĩndamwendete,
\q2 ngĩgĩĩta mũrũ ũcio wakwa oime bũrũri wa Misiri.
\q1 
\v 2 No o ũrĩa ndaakĩragĩrĩria gwĩta Isiraeli,
\q2 noguo maakĩragĩrĩria kũnjũrĩra.
\q1 Nao makĩrutĩra Baali magongona,
\q2 na magĩcinĩra mĩhianano ũbumba.
\q1 
\v 3 Niĩ nĩ niĩ ndaarutire andũ a Efiraimu gwĩtwara na magũrũ,
\q2 ndĩmanyiitĩte moko;
\q1 no matiigana kũmenya
\q2 atĩ nĩ niĩ ndamahonagia.
\q1 
\v 4 Nĩndamatongoragia na mĩkanda ya ũtugi wa ũmũndũ,
\q2 ngamaguucĩrĩria na mĩhĩndo ya wendo;
\q1 ngĩmaruta icooki ngingo,
\q2 na ngĩinamĩrĩra kũmahe irio.
\b
\q1 
\v 5 “Githĩ matigagĩcooka o kũu bũrũri wa Misiri,
\q2 o na githĩ matigaathwo nĩ Ashuri,
\q2 tondũ nĩmaregete kwĩrira, manjookerere?
\q1 
\v 6 Hiũ cia njora ikaahenũkaga matũũra-inĩ mao manene,
\q2 ikaananga mĩgĩĩko ya ihingo ciao,
\q2 na ikinyie mĩbango yao mũthia.
\q1 
\v 7 Andũ akwa nĩmatuĩte itua maahuutatĩre.
\q2 O na mangĩgaakaĩra Ũrĩa-ũrĩ-Igũrũ-Mũno-rĩ,
\q2 ndakamatũgĩria o na atĩa.
\b
\q1 
\v 8 “Ndahota atĩa gũgũtirika, wee Efiraimu?
\q2 Ndahota atĩa gũkũrekereria, wee Isiraeli?
\q1 Ndahota atĩa gũtũma ũtuĩke ta Adima?
\q1 Ndahota atĩa gũgũtua ta Zeboimu?
\q1 Ngoro yakwa nĩĩreganĩte na ũhoro ũcio,
\q2 nacio tha ciakwa ciothe nĩciarahũkĩte.
\q1 
\v 9 Ndikamũkinyĩria marakara makwa mahiũ,
\q2 o na kana hũgũkĩre Efiraimu ndĩmũniine.
\q1 Nĩgũkorwo niĩ nĩ niĩ Ngai, ndirĩ mũndũ,
\q2 Ngai Ũrĩa Mũtheru gatagatĩ-inĩ kanyu.
\q2 Ndigooka kũrĩ we ndĩ na mangʼũrĩ.
\q1 
\v 10 Nĩmakarũmĩrĩra Jehova;
\q2 nake nĩakararama ta mũrũũthi.
\q1 Hĩndĩ ĩrĩa akaararama-rĩ,
\q2 ciana ciake nĩigooka ikĩinainaga ciumĩte mwena wa ithũĩro.
\q1 
\v 11 Igooka ikĩinainaga
\q2 ta nyoni ikiuma bũrũri wa Misiri,
\q2 na ta ndutura ikiuma bũrũri wa Ashuri.
\q1 Nĩngatũma matũũre mĩciĩ-inĩ yao ene,”
\q4 ũguo nĩguo Jehova ekuuga.
\s1 Mehia ma Isiraeli
\q1 
\v 12 Efiraimu andigiicĩirie na maheeni,
\q2 nyũmba ya Isiraeli ĩkandigiicĩria na kũheenania.
\q1 Nake Juda akaremera Ngai,
\q2 o na agookĩrĩra Ũrĩa Mũtheru mwĩhokeku.
\c 12
\q1 
\v 1 Efiraimu arĩĩaga rũhuho;
\q2 ahanyũkagia rũhuho rwa mwena wa irathĩro mũthenya wothe,
\q2 na akaingĩhia maheeni na haaro.
\q1 Agĩĩaga na kĩrĩkanĩro na Ashuri,
\q2 na agatũmana maguta ma mĩtamaiyũ matwarwo bũrũri wa Misiri.
\q1 
\v 2 Jehova arĩ na thitango ekũrehe ya gũũkĩrĩra Juda;
\q2 nĩakaherithia Jakubu kũringana na njĩra ciake,
\q2 na amũrĩhe kũringana na ciĩko ciake.
\q1 
\v 3 Arĩ nda ya nyina nĩanyiitire ndiira ya mũrũ wa nyina;
\q2 aatuĩka mũndũ mũgima-rĩ, nĩagianire na Ngai.
\q1 
\v 4 Nĩagianire na mũraika, na akĩmũtooria;
\q2 akĩrĩra na akĩmũthaitha amũrathime.
\q1 Aamũkorire Betheli na makĩaranĩria nake kũu:
\q1 
\v 5 Jehova Ngai Mwene-Hinya-Wothe,
\q2 Jehova nĩrĩo rĩĩtwa rĩake rĩrĩa rĩrĩ ngumo.
\q1 
\v 6 No rĩrĩ, wee no nginya ũcookerere Ngai waku,
\q2 na ũtũũrie wendo na kĩhooto,
\q2 na wetagĩrĩre Ngai waku hĩndĩ ciothe.
\b
\q1 
\v 7 Mwonjorithia ahũthagĩra gĩthimi gĩtarĩ kĩa ma;
\q2 endaga kũiya na wara.
\q1 
\v 8 Efiraimu eganaga, akoiga atĩrĩ,
\q2 “Niĩ ndĩ mũtongu mũno; niĩ nĩnduĩkĩte gĩtonga.
\q1 No o na ndĩ na ũtonga ũcio wothe,
\q2 matingĩona waganu kana wĩhia o na ũrĩkũ thĩinĩ wakwa.”
\b
\q1 
\v 9 “Nĩ niĩ Jehova Ngai wanyu,
\q2 ũrĩa wamũrutire bũrũri wa Misiri;
\q1 nĩngatũma mũtũũre hema-inĩ rĩngĩ,
\q2 o ta ũrĩa mwatũũraga matukũ-inĩ ma ciathĩ cianyu iria nyamũre.
\q1 
\v 10 Nĩndarĩirie anabii,
\q2 ngĩmahe cioneki nyingĩ,
\q2 na ngĩheana ngerekano na tũnua twao.”
\b
\q1 
\v 11 Gileadi-rĩ, nĩ kũrĩ waganu?
\q2 Andũ akuo nĩ a tũhũ!
\q1 Nĩmarutagĩra igongona rĩa ndegwa kũu Giligali?
\q2 Igongona ciao igaatuĩka ta hĩba cia mahiga
\q2 irĩ mũgũnda-inĩ mũciimbe.
\q1 
\v 12 Jakubu nĩorĩire bũrũri wa Aramu;
\q2 Isiraeli aatungatire nĩguo egĩĩre na mũtumia,
\q2 na nĩgeetha amũgũre-rĩ, aarĩithirie ngʼondu.
\q1 
\v 13 Jehova aahũthĩrire mũnabii kũruta Isiraeli kuuma bũrũri wa Misiri,
\q2 na akĩmũmenyerera na guoko kwa mũnabii.
\q1 
\v 14 No Efiraimu nĩatũmĩte Jehova arakare mũno.
\q2 Mwathani wake nĩagatũma acookererwo nĩ ihĩtia rĩake rĩa ũiti wa thakame,
\q2 na amũrĩhe nĩ ũndũ wa rũmena rwake.
\c 13
\s1 Marakara ma Jehova ma Gũũkĩrĩra Isiraeli
\q1 
\v 1 Efiraimu-rĩ, aaragia andũ makainaina;
\q2 aarĩ mũtũgĩrie thĩinĩ wa Isiraeli.
\q1 No rĩrĩ, nĩehirie nĩ ũndũ wa kũhooya Baali, nake agĩkua.
\q1 
\v 2 Na rĩrĩ, rĩu no gũkĩrĩrĩria makĩragĩrĩria kwĩhia;
\q1 methondekagĩra mĩhianano yao ene na betha ciao,
\q2 mĩhianano ĩthondeketwo na ũũgĩ mũingĩ,
\q2 yothe ĩrĩ wĩra wa mabundi.
\q1 Kwĩragwo atĩrĩ, ũhoro wa andũ aya,
\q2 “Marutaga andũ magongona,
\q2 na makamumunya mĩhianano ya njaũ.”
\q1 
\v 3 Nĩ ũndũ ũcio makahaana ta kĩbii kĩa rũciinĩ,
\q2 na ta ime rĩa kĩrooko rĩrĩa rĩcookaga gũthira,
\q2 na ta mũũngũ ũrĩa ũmbũragwo kuuma kĩhuhĩro-inĩ kĩa ngano,
\q2 o na ta ndogo ĩgĩtoga yumĩire ndirica-inĩ.
\b
\q1 
\v 4 “No rĩrĩ, niĩ nĩ niĩ Jehova Ngai wanyu,
\q2 ũrĩa wamũrutire bũrũri wa Misiri.
\q1 Ndũkanetĩkie atĩ nĩ kũrĩ Ngai ũngĩ tiga niĩ,
\q2 na gũtirĩ Mũhonokia ũngĩ tiga niĩ.
\q1 
\v 5 Nĩ niĩ ndaakũmenyagĩrĩra werũ-inĩ,
\q2 kũu bũrũri-inĩ ũrĩ ũrugarĩ mũingĩ.
\q1 
\v 6 Rĩrĩa ndamaheire irio, nĩmahũũnire;
\q2 na rĩrĩa maahũũnire, magĩtĩĩa;
\q2 magĩcooka makĩriganĩrwo nĩ niĩ.
\q1 
\v 7 Nĩ ũndũ ũcio ngaamahithũkĩra ta mũrũũthi,
\q2 na ndĩmehithĩre njĩra-inĩ ta ngarĩ.
\q1 
\v 8 O ta ũrĩa nduba ĩĩkaga rĩrĩa ĩtunyĩtwo twana twayo-rĩ,
\q2 ngaamatharĩkĩra na ndĩmatarũrange.
\q1 Ngaamarĩa ta mũrũũthi,
\q2 ndĩmatambuure o ta ũrĩa nyamũ ya gĩthaka ĩĩkaga.
\b
\q1 
\v 9 “Wee Isiraeli-rĩ, ũrĩ mwanange,
\q2 nĩ ũndũ nĩũnjũkĩrĩire, ũgookĩrĩra mũteithia waku.
\q1 
\v 10 Mũthamaki waku akĩrĩ ha, atĩ nĩguo akũhonokie?
\q2 Aathani aku a matũũra maku mothe marĩ ha,
\q1 o arĩa woigire atĩrĩ,
\q2 ‘He mũthamaki, na ũhe anene’?
\q1 
\v 11 Nĩ ũndũ ũcio, ndaakũheire mũthamaki ndakarĩte,
\q2 na ngĩcooka ngĩmweheria ndĩ na mangʼũrĩ.
\q1 
\v 12 Wĩhia wa Efiraimu nĩmũige,
\q2 mehia make nĩmandĩkĩtwo makaigwo.
\q1 
\v 13 Ruo ta rwa mũtumia ũkũrũmwo nĩrũramũnyiita,
\q2 nowe nĩ mwana ũtarĩ na ũũgĩ;
\q1 ihinda rĩakinya-rĩ,
\q2 akarega gũikũrũka nĩguo aciarwo.
\b
\q1 
\v 14 “Nĩngamahonokia kuuma kũrĩ hinya wa mbĩrĩra;
\q2 nĩngamakũũra kuuma kũrĩ gĩkuũ.
\q1 Wee gĩkuũ-rĩ, mĩthiro yaku ĩrĩ ha?
\q1 Wee mbĩrĩra-rĩ, kũniinana gwaku gũkĩrĩ ha?
\b
\q1 “Ndikaiguanĩra tha,
\q1 
\v 15 o na angĩkaagaacĩra arĩ gatagatĩ-inĩ ka ariũ a ithe.
\q1 Rũhuho rwa mwena wa irathĩro ruumĩte harĩ Jehova nĩrũgooka,
\q2 rũhurutanĩte kuuma werũ-inĩ;
\q1 narĩo itherũkĩro rĩake rĩa maaĩ rĩkooma,
\q2 nakĩo gĩthima gĩake kĩhũe.
\q1 Nyũmba yake ya mũthiithũ
\q2 nĩĩgatahwo indo ciayo ciothe cia goro.
\q1 
\v 16 Andũ a Samaria no nginya marĩhio wĩhia wao,
\q2 nĩ tondũ nĩmaremeire Ngai wao.
\q1 Nao nĩmakooragwo na rũhiũ rwa njora;
\q2 natuo tũkenge twao tũgaatungumanio thĩ,
\q2 na atumia ao arĩa marĩ na nda itarũrwo.”
\c 14
\s1 Kwĩrira kũrĩa Kũrehaga Kĩrathimo
\q1 
\v 1 Wee Isiraeli-rĩ, cookerera Jehova Ngai waku.
\q1 Mehia maku nĩmo makũgũithĩtie!
\q1 
\v 2 Thiĩ na ciugo ũcookerere Jehova,
\q1 ũmwĩre atĩrĩ,
\q2 “Tũrekere mehia maitũ mothe,
\q1 na ũtwamũkĩre na wega waku,
\q2 nĩguo tũhote gũkũrutĩra igongona rĩa gũkũgooca na mĩromo iitũ.
\q1 
\v 3 Ashuri ndangĩhota gũtũhonokia;
\q2 tũtikũhaica mbarathi cia ita.
\q1 Tũtirĩ hĩndĩ ĩngĩ tũgaacooka
\q2 gwĩta kĩrĩa tũthondekete na moko maitũ ‘ngai ciitũ,’
\q2 nĩgũkorwo thĩinĩ waku ciana cia ngoriai nĩciiguagĩrwo tha.”
\b
\q1 
\v 4 “Nĩngamahonia kũrĩa maanoora njĩra,
\q2 na ndĩmende ndĩyendeire;
\q2 nĩgũkorwo marakara makwa nĩmamehereire.
\q1 
\v 5 Ngaatuĩka ta ime harĩ Isiraeli;
\q2 nake akaarirũka ta gĩtoka.
\q1 Agaikũrũkia mĩri yake
\q2 ehaande o ta mĩtarakwa ya Lebanoni.
\q2 
\v 6 Thuuna ciake nĩigakũra.
\q1 Ũthaka wake ũgaatuĩka ta wa mũtĩ wa mũtamaiyũ,
\q2 naguo mũtararĩko wake ũtuĩke ta mũtarakwa wa Lebanoni.
\q1 
\v 7 Andũ nĩmagatũũra rĩngĩ kĩĩruru-inĩ gĩake.
\q2 Nake akaarura ta ngano.
\q1 Akaarirũka ta mũthabibũ,
\q2 nayo ngumo yake ĩtuĩke ta ya ndibei ya kuuma Lebanoni.
\q1 
\v 8 Wee Efiraimu, ndĩ na ũhoro ũngĩ ũrĩkũ na mĩhianano ya kũhooywo?
\q2 Nĩngamũcookeria ũhoro na ndĩmũmenyerere.
\q1 Haana ta mũkarakaba mũruru;
\q2 gũciara gwaku kuumaga harĩ niĩ.”
\b
\q1 
\v 9 Nũũ mũũgĩ? Ũcio nĩakamenya maũndũ macio.
\q2 Nũũ ũkũũranaga maũndũ? Ũcio nĩakamamenya.
\q1 Njĩra cia Jehova nĩ njagĩrĩru;
\q2 arĩa athingu nĩcio mathiiagĩra,
\q2 no arĩa aremi mahĩngagwo marĩ o njĩra-inĩ icio.
