\id 2JN  
\h 2 Juan 
\toc1 2 Juan 
\mt1 Nihánj me síj vi̱j yanj cartá quiꞌyaj síí cuꞌna̱j Juan caꞌnéé soꞌ rihaan nij yuvii̱ noco̱ꞌ man Diose̱ a 
\c 1  
\p  
\v 1 Síí chii nga̱ mej, ne̱ achrón ꞌu̱nj yanj nihánj naya̱a̱ taranꞌ nij soj si̱j narii Diose̱ man si̱j nuu chre̱ꞌ rej achíín niꞌya̱j soj rihaan Diose̱ a. Dan me se ꞌe̱e̱ raj man soj, cheꞌé rej si̱j noco̱ꞌ nana̱ ya̱ me taranꞌ níꞌ a. Ne̱ nuveé o̱rúnꞌ ꞌu̱nj me síí ꞌe̱e̱ rá man soj maꞌ. ꞌO̱ se taranꞌ nij síí neꞌen nana̱ ya̱ ꞌe̱e̱ rá man soj ado̱nj.  
\v 2 ꞌE̱e̱ rá núj man soj cheꞌé se nu̱u̱ nana̱ ya̱ nimán níꞌ, ne̱ yoꞌo̱ cu̱nuû nana̱ ya̱ yoꞌ nimán níꞌ nu̱ꞌ cavii nu̱ꞌ caꞌanj rugua̱nj.  
\v 3 Ne̱ me rá ꞌu̱nj quiꞌya̱j Rej níꞌ Diose̱ do̱ꞌ, taꞌníí soꞌ Jesucristó do̱ꞌ, se lu̱j cheꞌé nij soj, ne̱ me rá ꞌu̱nj cunu̱u ꞌe̱e̱ rá ro̱j soꞌ ni̱ꞌyaj ro̱j soꞌ man soj, ne̱ me rá ꞌu̱nj ga̱a̱ xe̱j nimán soj quiꞌya̱j ro̱j soꞌ, ne̱ yoꞌo̱ canoco̱ꞌ soj nana̱ ya̱ ne̱ ga̱a̱ ꞌe̱e̱ rá soj man tuviꞌ soj ei. 
\s1 Nana̱ nihánj taj xnaꞌanj se vaa yoꞌo̱ quiꞌya̱j níꞌ nana̱ cataj xnaꞌanj Diose̱ rihaan níꞌ, ne̱ ga̱a̱ ꞌe̱e̱ rá níꞌ man tuviꞌ níꞌ a 
\p  
\v 4 Guun niha̱ꞌ uxrá raj, cheꞌé se xcaj ꞌu̱nj cuentá se vaa taꞌa̱j nij soj me síí yoꞌo̱ nocoꞌ tucuáán ya̱, nda̱a vaa cataj xnaꞌanj Rej níꞌ Diose̱ rihaan níꞌ chugua̱nj.  
\v 5 Ne̱ nihánj me se achíín ni̱ꞌyáá ꞌu̱nj rihaan soj se vaa quiꞌya̱j nij soj nda̱a vaa cataj xnaꞌanj Diose̱ rihaan níꞌ a. Ne̱ nuveé na̱na̱ caꞌnaꞌ naca̱ rihaan níꞌ me nana̱ nihánj maꞌ. Ma̱a̱n se nana̱ cataj xnaꞌanj Diose̱ rihaan níꞌ asi̱j guun cheꞌe̱ níꞌ canocoꞌ níꞌ man soꞌ me nana̱ nihánj ado̱nj. Ne̱ nana̱ nihánj taj se vaa cunu̱u ꞌe̱e̱ rá níꞌ man tuviꞌ níꞌ a.  
\v 6 Sese ga̱a̱ ꞌe̱e̱ rá níꞌ man tuviꞌ níꞌ, ne̱ síí ꞌyaj nda̱a vaa cataj xnaꞌanj Diose̱ rihaan níꞌ me níꞌ ei. Ne̱ yoꞌ me nana̱ cataj xnaꞌanj soꞌ rihaan níꞌ asi̱j guun cheꞌe̱ níꞌ canocoꞌ níꞌ man soꞌ, ne̱ me rá soꞌ yoꞌo̱ quiꞌya̱j níꞌ nana̱ yoꞌ ado̱nj.  
\v 7 ꞌO̱ se ya̱j me se curiha̱nj ndoꞌo nij síí tihaꞌ yuꞌunj rihaan chumii̱ nihánj, ne̱ cataj nij soꞌ se vaa nuveé si̱j guun yuvii̱ me Jesucristó a. Cheꞌé dan me nij soꞌ síí tihaꞌ yuꞌunj aꞌmii nana̱ ne̱, ne̱ taj nij soꞌ se vaa maꞌa̱n nij soꞌ me síí caꞌnéé Diose̱ ti̱nanii man yuvii̱ rihaan sayuun a.  
\v 8 Cu̱tumé ndoꞌo soj man soj se̱ gaa na̱nj caꞌa̱nj niꞌya̱ nu̱ꞌ nij rasu̱u̱n sa̱ꞌ quiꞌyaj canaán soj maꞌ. Tza̱j ne̱ yoꞌo̱ canoco̱ꞌ soj nana̱ ya̱, ga̱a ne̱ veꞌé na̱ruꞌvee Diose̱ rihaan soj ei.  
\v 9 Ne̱ me maꞌa̱n síí tanáj se‑tucua̱nj Jesucristó roꞌ, nuviꞌ Diose̱ yáán ga̱ soꞌ maꞌ. Tza̱j ne̱ síí noco̱ꞌ raan se‑tucua̱nj Jesucristó me se soꞌ me síí yoꞌo̱ yáán ro̱j taꞌni̱j Diose̱ ga̱ soꞌ ado̱nj.  
\v 10 Ne̱ sese caꞌna̱ꞌ ꞌo̱ síí aꞌmii yoꞌó nana̱ rej ya̱nj soj, ne̱ se̱ caꞌvej rá soj catu̱u̱ soꞌ rihaan soj, ne̱ se̱ caꞌmii sa̱ꞌ soj ga̱ soꞌ maꞌ.  
\v 11 ꞌO̱ se síí aꞌmii sa̱ꞌ ga̱ soꞌ me síí racuíj man soꞌ quiꞌya̱j soꞌ se chiꞌi̱i̱ ado̱nj. 
\s1 Nana̱ nihánj taj xnaꞌanj se vaa cuchi̱ꞌ Juan rej ya̱nj nij soꞌ a 
\p  
\v 12 Vaa ndoꞌo nana̱ me rá ꞌu̱nj cata̱j xnaꞌanj ꞌu̱nj rihaan soj, tza̱j ne̱ naꞌvej rá ꞌu̱nj cachro̱n ꞌu̱nj cunuda̱nj nij nana̱ rihaan yanj nihánj, cheꞌé se queꞌe̱e̱ ndoꞌo nana̱ me yoꞌ ei. Tza̱j ne̱ cuchi̱j rihaan soj, raj, ga̱a ne̱ caꞌve̱e caꞌmi̱i̱ rihaan maꞌa̱n tuviꞌ ya̱ níꞌ, ga̱a ne̱ gu̱un niha̱ꞌ uxrá rá níꞌ ga̱a nariꞌ tuviꞌ níꞌ chugua̱nj.  
\v 13 Ne̱ nij síí narii Diose̱ ya̱nj chumanꞌ nihánj roꞌ, me rá taranꞌ nij soꞌ se vaa veꞌé ca̱yáán taranꞌ soj ei.