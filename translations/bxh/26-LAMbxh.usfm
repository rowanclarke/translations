\id LAM - Buhutu Bible Translation 
\h Lau Kapole 
\toc1 Lau Kapole Bukana 
\toc2 Kapole 
\toc3 Kapole 
\mt1 Lau Kapole  
\mt2 Diuda, Guyau sa Lau Kapoleꞌen  
\ip Buka ite Isalaela edi nuwa heyaya laꞌilaꞌi Yelusalem lisina yai, dedena. Boliman 586 B.C. yai (B.C. aniyona mate Boliman fisa hola Yesu hige i tubu) mate adi waiyunu sa lau be edi taon laꞌilaꞌi Yelusalem sa anfaheyayai be Isalaela dodogadi sa lawedi ganamuli nuꞌudi yai. Edi ginauli loholohodi hinaga sa abidi. Bukana tau ulina hige ti sibai in moho dodoga haisa edi nuwatuhu mate Delamaiya ya uli.  
\ie  
\c 1
\s1 Yelusalem edi Nuwa Heyaya  
\sr Lau Kapole 1:1-7  
\p
\v 1 Beyabeyana Yelusalem yai, doga ya ouli wananaha,  
\q2 na aho ite, afaꞌafana!  
\q1 Hesana beyabeyana ya laꞌi nuꞌu hahaisa ganahewadi yai,  
\q2 na aho ite doha hwabuhwabu.  
\q1 Beyabeyana in doha hatafele,  
\q2 na aho ite ya famala tau lau fayofayo.   
\q1
\v 2 Diuda dodogadi maihonadi sa tan eloꞌelolosi.  
\q1 Tau gadogadosisiyedi mahudoꞌidi sa lau afuledi,  
\q2 hige tau abi famatanodi.  
\q1 Afa haidadi mahudoꞌidi sa sana mulimuliyedi,  
\q2 sa famala adi waiyunu.   
\q1
\v 3 Be sa lawedi sa famala edi tau lau fayofayo  
\q2 yo mwahu sa fabaheidi.  
\q1 Mulimuli dodogadi ganahewadi yai sa miya  
\q2 na hige aba anyawasi loholohona ti lobahi.  
\q1 Waiyunu mate, Diuda dodogadi sa weꞌa dudu lidi bee–,  
\q2 sa fasai bulubuluhidi.  
\q2 Hige edi aba gela hesa.   
\q1
\v 4 Iti kapole–, Saiyon edaꞌedadi mate afaꞌafadi.  
\q1 Itaꞌitadi doha ti tantan,  
\q2 paꞌana hige sai laꞌi i lau watanidi  
\q2 i lau be Yaubada i fadebasae.  
\q1 Yelusalem Taonna aba luhuluhu launa afaꞌafana.  
\q1 Tau antalasam sa tan nuwa heyaya,  
\q2 yo wawahin hasahasaladi sa tan eloꞌelolosi.   
\q1
\v 5 Ana waiyunu sa famala ena baꞌisa,  
\q2 habahim sa miya gwaugwau.  
\q1 Ena heyaya debadi yai, \nd Guyau\nd* ya fakamkamna  
\q1 na nanatuna sa tohaidi be sa lawedi nuꞌu eda lofalofa.   
\q1
\v 6 Beyabeyana Yelusalem itaꞌitana olina,  
\q2 na aho ite higeꞌe.  
\q1 Ena babaꞌisa doha suisui guliguliyamna,  
\q2 tauna sa belubelu paꞌana hige kalahe,  
\q1 ma belubeluna ya gela tau faꞌoyowa matadi yai.   
\q1
\v 7 Edi kamkamna lahaidi yai,  
\q2 yo fuyana sa leuleu yo sa saisai mate,  
\q1 ginauli loholohodi mahudoꞌidi beyabeyana  
\q2 iti enehedi sa nuwatuhuidi.  
\q1 Isalaela dodogadi hige tau saguhidi  
\q2 fuyanna waiyunu sa fasai bulubuluhidi.  
\q1 Yelusalem ena heyaheyaya yai  
\q2 adi waiyunu sa itadi mate sa ala liuliuhwaꞌedi.   
\c 3
\s1 Panisi, Nuwa Bui yo Sunuma  
\sr Lau Kapole 3:19-33  
\q1
\v 19 Egu kamkamna yo egu lau gaibu E nuwatuhuidi  
\q1 mate nuwagu ya kalapi doha kapasiya.   
\q1
\v 20 E nuwanuwatuhuidi be  
\q2 nuwagu ya belubelu.   
\q1
\v 21 In moho ginauli esega yena E nuwatuhui,  
\q2 haba nuwagu ya adidili fuyo mate:   
\q1
\v 22 \nd Guyau\nd* ena gadosisi otaꞌota fahina yai, hola te mwahumwahuli,  
\q1 yo ena nuwatohatoha ibege i ofi.   
\q1
\v 23 Hwalahwalala ouꞌouli ena gadosisi yo ena nuwatohatoha falifalihudi.  
\q1 Yo ena sunuma ya laꞌi wananaha.   
\q1
\v 24 \nd Guyau\nd* E sunumaꞌen  
\q2 paꞌana In egu gogo mahudoꞌina.   
\q1
\v 25 Safalumadi \nd Guyau\nd* sa sunusunumaꞌen,  
\q2 yo sa yoꞌoyoꞌoi,  
\q2 mate ya loholoho lebedi yai.   
\q1
\v 26 Ya loholoho, ma nuwa taluda,  
\q2 \nd Guyau\nd* ena abi famwahuli te bagiyen.   
\q1
\v 27 Ya loholoho hinaga,  
\q2 doga ma hewalina e ma hasalana  
\q2 ena mwahu ya baheidi.   
\q1
\v 28 \nd Guyau\nd* lebena yai mwahudi ya tole.  
\q2 Debana yai iyabona ya taꞌai be ya fafamakano.   
\q1
\v 29 Bena ya hoba lidi,  
\q2 ma nuwa lidilidina \nd Guyau\nd* lisina,  
\q2 nuwana, sunuma hola otana.   
\q1
\v 30 Yena sai ya fanuha bena ya talai,  
\q1 bena papalina ya felen be ya lau papaliꞌi.  
\q2 Haba ya taumayamayaꞌen. \rq (Isaiya 50:6)\rq*   
\q1
\v 31 Paꞌana \nd Guyau\nd* ibege i ꞌwaiyoꞌoꞌen be hige anadan.   
\q1
\v 32 \nd Guyau\nd* nuwa heyaya, nuwana haba ya leyama lisina.  
\q2 In moho ena nuwatohatoha yo ena gadosisi  
\q2 lebena yai ya ota esegahi.   
\q1
\v 33 Yo hige i fanuha,  
\q2 bena nuwa heyaya yo kamkamna i felen.   