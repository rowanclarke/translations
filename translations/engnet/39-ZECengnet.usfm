\v 6 \w Then|strong="H3068"\w* \w the|strong="H3068"\w* \w angel|strong="H4397"\w* \w of|strong="H3068"\w* \w the|strong="H3068"\w* \nd \w Lord|strong="H3068"\w*\nd* exhorted \w Joshua|strong="H3091"\w* \w solemnly|strong="H5749"\w*:
\v 7 “\w The|strong="H5414"\w* \nd \w Lord|strong="H3068"\w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H5414"\w* \w all|strong="H5414"\w* \w says|strong="H3541"\w*, ‘If \w you|strong="H5414"\w* \w live|strong="H1870"\w* \w and|strong="H3068"\w* \w work|strong="H5414"\w* according \w to|strong="H3212"\w* \w my|strong="H8104"\w* requirements, \w you|strong="H5414"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* able \w to|strong="H3212"\w* \w preside|strong="H1777"\w* \w over|strong="H5414"\w* \w my|strong="H8104"\w* \w temple|strong="H1004"\w* \w and|strong="H3068"\w* \w attend|strong="H8104"\w* \w to|strong="H3212"\w* \w my|strong="H8104"\w* \w courtyards|strong="H2691"\w*, \w and|strong="H3068"\w* \w I|strong="H5414"\w* \w will|strong="H3068"\w* \w allow|strong="H5414"\w* \w you|strong="H5414"\w* \w to|strong="H3212"\w* \w come|strong="H3212"\w* \w and|strong="H3068"\w* \w go|strong="H3212"\w* among \w these|strong="H1004"\w* others \w who|strong="H3068"\w* \w are|strong="H3068"\w* \w standing|strong="H5975"\w* \w by|strong="H3068"\w* \w you|strong="H5414"\w*.
