\v 31 \w Now|strong="H1571"\w* Barzillai \w the|strong="H3605"\w* Gileadite \w had|strong="H4428"\w* come down \w from|strong="H3947"\w* Rogelim \w to|strong="H1004"\w* cross \w the|strong="H3605"\w* Jordan \w with|strong="H1004"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w and|strong="H4428"\w* send \w him|strong="H3947"\w* \w on|strong="H1004"\w* \w his|strong="H3605"\w* \w way|strong="H3605"\w* \w from|strong="H3947"\w* \w there|strong="H7965"\w*.
\v 32 \w Barzillai|strong="H1271"\w* \w was|strong="H4428"\w* quite old, eighty years \w of|strong="H4428"\w* age, \w and|strong="H7971"\w* since \w he|strong="H7971"\w* \w was|strong="H4428"\w* \w a|strong="H3068"\w* very wealthy \w man|strong="H5674"\w*, \w he|strong="H7971"\w* \w had|strong="H4428"\w* provided \w for|strong="H7971"\w* \w the|strong="H5674"\w* \w king|strong="H4428"\w* \w while|strong="H3383"\w* \w he|strong="H7971"\w* stayed \w in|strong="H4428"\w* Mahanaim.
