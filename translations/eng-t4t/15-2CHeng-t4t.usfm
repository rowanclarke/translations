\p
\v 12 \w Then|strong="H5375"\w* \w Yahweh|strong="H3068"\w* enabled Asa \w and|strong="H3068"\w* \w the|strong="H6440"\w* \w army|strong="H4264"\w* \w of|strong="H3068"\w* Judah \w to|strong="H5704"\w* defeat \w the|strong="H6440"\w* \w army|strong="H4264"\w* \w from|strong="H6440"\w* \w Ethiopia|strong="H3569"\w*. \w They|strong="H1992"\w* fled,  
\v 13 \w and|strong="H3068"\w* Asa \w and|strong="H3068"\w* \w his|strong="H3605"\w* army pursued \w them|strong="H5921"\w* \add to the southwest\add* \w as|strong="H1961"\w* \w far|strong="H5921"\w* \w as|strong="H1961"\w* \w Gerar|strong="H1642"\w*. \w A|strong="H3068"\w* \w huge|strong="H7227"\w* number \w of|strong="H3068"\w* \w the|strong="H3605"\w* soldiers \w from|strong="H5921"\w* Ethiopia \w were|strong="H1961"\w* \w killed|strong="H5221"\w*, \w with|strong="H3068"\w* \w the|strong="H3605"\w* result \w that|strong="H3588"\w* \w those|strong="H3605"\w* \add who were not killed\add* \w were|strong="H1961"\w* unable \w to|strong="H3068"\w* fight \w any|strong="H3605"\w* \w more|strong="H7227"\w*. \w They|strong="H3588"\w* \w were|strong="H1961"\w* \w greatly|strong="H7227"\w* \w defeated|strong="H5221"\w* \w by|strong="H5921"\w* \w Yahweh|strong="H3068"\w* \w and|strong="H3068"\w* \w his|strong="H3605"\w* army, \w and|strong="H3068"\w* \w the|strong="H3605"\w* \w men|strong="H3605"\w* \w of|strong="H3068"\w* Judah \w carried|strong="H3068"\w* \w away|strong="H3605"\w* \w a|strong="H3068"\w* \w great|strong="H7227"\w* amount \w of|strong="H3068"\w* \w their|strong="H3605"\w* possessions.  
