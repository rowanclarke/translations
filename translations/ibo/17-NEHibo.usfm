\li1 
\v 30 ndị Rema na Geba, narị isii na iri abụọ na otu (621),
\li1 
\v 31 ndị Mikmash, otu narị na iri abụọ na abụọ (122),
\li1 
\v 32 ndị Betel na Ai, otu narị na iri abụọ na atọ (123),
\li1 
\v 33 ndị Nebo nke ọzọ, iri ise na abụọ (52),
\li1 
\v 34 ndị agbụrụ Elam nke ọzọ, otu puku, narị abụọ na iri ise na anọ (1,254),
\li1 
\v 35 ndị Harim, narị atọ na iri abụọ (320),
\li1 
\v 36 ndị Jeriko, narị atọ na iri anọ na ise (345),
\li1 
\v 37 ndị Lod, Hadid, na Ono, narị asaa na iri abụọ na otu (721),
\li1 
\v 38 ndị Senaa, puku atọ, na narị itoolu na iri atọ (3,930).
\b
\li4 
\v 39 Ndị nchụaja:
\li1 ndị agbụrụ Jedaya site nʼezinaụlọ Jeshua, narị itoolu na iri asaa na atọ (973),
\li1 
\v 40 ndị Imea, otu puku, na iri ise na abụọ (1,052),
\li1 
\v 41 ndị Pashua, otu puku, na narị abụọ na iri anọ na asaa (1,247),
\li1 
\v 42 ndị Harim, otu puku, na iri na asaa (1,017).
\b
\li1 
\v 43 Ndị Livayị:
\li2 ndị agbụrụ Jeshua site na Kadmiel nke ụmụ Hodavaya, iri asaa na anọ (74).
\b
\li1 
\v 44 Ndị ọbụ abụ:
\li2 ndị agbụrụ Asaf, otu narị, na iri anọ na asatọ (148).
\b
\li1 
\v 45 Ndị nche ọnụ ụzọ ụlọnsọ ukwu:
\li2 ndị agbụrụ Shalum, Atea, Talmon, Akub, Hatita na Shobai otu narị, na iri atọ na asatọ (138).
\b
\li1 
\v 46 Ndị na-eje ozi nʼụlọnsọ:
\li2 ndị agbụrụ Ziha, Hasufa na ndị Tabaot,
\li2 
\v 47 Keros, Sia, Padon,
\li2 
\v 48 Lebana, Hagaba, Shalmai,
\li2 
\v 49 Hanan, Gidel, Gaha,
\li2 
\v 50 Reaya, Rezin, Nekoda,
\li2 
\v 51 Gazam, Ụza, Pasea,
\li2 
\v 52 Besai, Meunim, Nefusim,
\li2 
\v 53 Bakbuk, Hakufa, Hahua,
\li2 
\v 54 Bazlut, Mehida, Hasha,
\li2 
\v 55 Bakos, Sisera, Tema,
\li2 
\v 56 Nezaya na Hatifa.
\li1 
\v 57 Agbụrụ ndị na-ejere eze Solomọn ozi,
\li2 ya bụ ndị agbụrụ Sotai, Soferat, Perida,
\li2 
\v 58 Jaala, Dakon, Gidel,
\li2 
\v 59 Shefataya, Hatil,
\li2 Pokeret-Hazebaim na Amọn.
\li4 
\v 60 Ndị na-eje ozi nʼụlọnsọ na ụmụ ndị na-ejere eze Solomọn ozi, dị narị atọ na iri itoolu na abụọ (392).
\b
\li4 
\v 61 Ndị a bụ ndị ọzọ sitere nʼobodo Tel Mela, Tel Hasha, Kerub, Adọn na Imea, nke dị nʼala Peshịa lọta. Ma ha enweghị ike igosi ezinaụlọ ebe agbụrụ ha si nʼIzrel.
\li1 
\v 62 Ndị agbụrụ:
\li2 Delaya, ndị Tobaya na ndị Nekoda, narị isii na iri anọ na abụọ (642).
\b
\li4 
\v 63 Sitekwa nʼetiti ndị nchụaja:
\li1 Ndị agbụrụ:
\li2 Hobaya, Hakoz na Bazilai (nwoke lụrụ ada Bazilai onye Gilead a kpọọ ya aha nʼaha ha).
\li4 
\v 64 Ndị a chọrọ ebe e depụtara usoro ọmụmụ ha nʼakwụkwọ, ma ha achọtaghị ha nʼihi ya e wepụrụ ha nʼọrụ nchụaja dịka ndị na-adịghị ọcha.
\v 65 Nʼihi nke a, onyeisi ọchịchị nyere iwu ka ha ghara iri ihe aja dịkarịsịrị nsọ, tutu ruo mgbe a ga-enwe onye nchụaja na-eji Urim na Tumim ajụta ase.
\b
\li4 
\v 66 Nkpọkọta ọnụọgụgụ ndị niile lọtara dị iri puku anọ na abụọ, na narị atọ na iri isii (42,360),
\v 67 nke a agụnyeghị ndị ohu ndị ikom na ndị inyom dị puku asaa, na narị atọ na iri atọ na asaa (7,337), ndị ikom na ndị inyom, ndị ọbụ abụ\f + \fr 7:67 \ft Tinyere ndị Livayị na-abụ abụ, e nwere ọtụtụ ndị ọzọ na-abụ abụ nʼoge mmemme dị iche iche, dịka nʼoge ọlụlụ nwanyị, na nʼoge olili na ọnwụ \xt Ezr 2:65\xt*\f* dị narị abụọ, na iri anọ na ise (245).
\v 68 Ịnyịnya dị narị asaa na iri atọ na isii (736), ịnyịnya muul narị abụọ na iri anọ na ise (245),
\v 69 ịnyịnya kamel dị narị anọ na iri atọ na ise (435), ebe ịnyịnya ibu dị puku isii, na narị asaa na iri abụọ (6,720).
\b
\pm 
\v 70 Ma ụfọdụ nʼime ndịisi ezinaụlọ nyere onyinye maka ọrụ ahụ. Onyeisi ọchịchị tinyere nʼụlọakụ otu puku darik ọlaedo (1,000),\f + \fr 7:70 \ft Ya bụ kilogram asatọ na ụma anọ\f* iri efere ọlaedo ise (50) na uwe ndị nchụaja narị ise na iri atọ (530).
\v 71 Ụfọdụ ndịisi ezinaụlọ tinyere nʼụlọakụ maka ije ozi ahụ, darik ọlaedo puku iri abụọ (20,000),\f + \fr 7:71 \ft Darik ịdị arọ ya ruru narị kilogram na iri kilogram asaa\f* na ọtụtụ minas ọlaọcha puku abụọ na narị abụọ (2,200).\f + \fr 7:71 \ft Ịdị arọ ya ruru otu tọọnu na ụma abụọ\f*
\v 72 Nkpọkọta ọnụọgụgụ nke ndị mmadụ fọdụrụ nyere bụ, darik ọlaedo puku iri abụọ (20,000), na minas ọlaọcha puku abụọ (2,000), na uwe ndị nchụaja iri isii na asaa (67).
\pm 
\v 73 Ndị nchụaja, na ndị Livayị, na ndị nche ọnụ ụzọ, ndị ọbụ abụ na ndị na-eje ozi nʼụlọnsọ, tinyere ụfọdụ ndị mmadụ na ndị Izrel niile fọdụrụ, gara birikwa nʼobodo nke ha.
\s1 Ezra agụọ site nʼakwụkwọ iwu
\p Mgbe ọnwa asaa ruru, nʼoge a ndị Izrel niile e birila nʼobodo nke aka ha,
\c 8
\nb 
\v 1 Ndị mmadụ niile zukọrọ dịka otu onye na mbara ala dị nʼỌnụ Ụzọ Ama Mmiri. Ha gwara Ezra onye nkuzi ka ọ weta akwụkwọ Mosis, nke \nd Onyenwe anyị\nd* nyere ndị Izrel nʼiwu.
\p 
\v 2 Ya mere, Ezra, onye nchụaja wepụtara akwụkwọ Iwu ahụ nʼụbọchị mbụ nke ọnwa asaa nʼihu mkpọkọta ahụ bụ nke ndị ikom na ndị inyom na onye ọbụla ga-aghọta ihe mejupụtara.
\v 3 O chere ihu nʼỌnụ Ụzọ Ama Mmiri were oke olu gụọ ya site nʼụtụtụ ruokwa ehihie nʼihu ndị nwoke, ndị nwanyị na ndị ọzọ nwere ike ịghọta ihe o na-agụ. Mmadụ niile gekwara ntị na ngụpụta nke akwụkwọ iwu ahụ.
\p 
\v 4 Ezra onye ode akwụkwọ, rigoro nʼelu ihe mgbakwasị ụkwụ ha mere maka nke a. Ndị guzo nʼaka nri ya bụ, Matitaia, Shema, Anaia, Ụraya, Hilkaya na Maaseia. Ndị guzo nʼaka ekpe ya bụkwa ndị a: Pedaia, Mishael, Malkija, Hashum, Hashbadana, Zekaraya na Meshulam.
\p 
\v 5 Ezra meghere akwụkwọ ahụ mgbe mmadụ niile na-ahụzu ya nʼihi na o guzoro nʼebe dị elu mgbe ọ na-agụ ya. Mmadụ niile guzoro ọtọ mgbe ọ na-agụ ya.
\v 6 Mgbe ahụ, Ezra gọziri \nd Onyenwe anyị\nd* Chineke ukwu ahụ, mmadụ niile zakwara sị; “Amen! Amen!” Ha chịlịri aka ha abụọ elu, kpọọ isiala nye \nd Onyenwe anyị\nd*.
\p 
\v 7 Ndị Livayị aha ha bụ Jeshua, Bani, Sherebaya, Jamin, Akub, Shabetai, Hodia, Maaseia, Kelita, Azaraya, Jozabad, Hanan na Pelia, kuziri ndị mmadụ ihe dị nʼIwu mee ka ha ghọta ya dịka ha guzo nʼebe ahụ.
\v 8 Ha gụpụtara site nʼakwụkwọ iwu Chineke ahụ, sụgharịa ya, kọwazie ọkpụrụkpụ okwu niile dị nʼihe a gụpụtara, mee ka ndị mmadụ ghọta ihe a na-agụpụta nke ọma.
\p 
\v 9 Mgbe ahụ, Nehemaya, onyeisi ọchịchị, na Ezra, ode akwụkwọ na onye nchụaja, na ndị Livayị ahụ na-atụziri ndị mmadụ ihe, gwara ndị ahụ niile sị: “Taa bụ ụbọchị dị nsọ nye \nd Onyenwe anyị\nd*, Chineke unu. Unu erula ụjụ maọbụ bee akwa.” Nʼihi na ha niile na-akwa akwa mgbe ha na-ege ntị nʼokwu niile nke iwu ahụ.
\p 
\v 10 Nehemaya gwakwara ha sị; “Laanụ nʼụlọ unu gaa mee mmemme oriri na ọṅụṅụ nyekwanụ ndị na-enweghị nke ha ga-eri. Ụbọchị taa dị nsọ nye Chineke anyị. Unu erukwala ụjụ, nʼihi na ọṅụ \nd Onyenwe anyị\nd* bụ ike unu.”
\p 
\v 11 Ndị Livayị mere ka ndị mmadụ ahụ nọrọ nwayọọ, na-asị, “Nọrọnụ nwayọọ, nʼihi na taa bụ ụbọchị dị nsọ, ọ bụghị ụbọchị iru ụjụ na anya mmiri.”
\p 
\v 12 Ya mere, ha niile lawara ị ga rie ma ṅụọ, na ikenye ndị ọzọ site nʼihe ha nwere. Ha gakwara ime mmemme nke oke ọṅụ, nʼihi na ha ghọtara okwu agwara ha.
\p 
\v 13 Nʼụbọchị nke abụọ nke ọnwa ahụ, ndịisi ezinaụlọ niile na ndị nchụaja, na ndị Livayị, zukọrọ nʼebe Ezra, bụ onye nkuzi nọ, maka itinye uche nʼakwụkwọ iwu ahụ.
\v 14 Mgbe ha na-agụ ya, ha chọpụtara ebe \nd Onyenwe anyị\nd* gwara Mosis sị ya na ụmụ Izrel kwesiri ibi nʼụlọ ikwu mgbe ọbụla a na-eme mmemme ụlọ ikwu nke a ga-eme nʼọnwa ahụ.
\v 15 O kwukwara na ha ga-ekwusa okwu a nʼobodo niile nke Juda na Jerusalem sị; “Gaanụ nʼala ugwu ugwu gbute alaka osisi oliv ụlọ, na alaka oliv ọhịa, na alaka osisi mietul,\f + \fr 8:15 \ft Mietul bụ ahịhịa na-esi isi ụtọ. \xt Aịz 41:19; 55:13\xt*\f* na alaka nkwụ, na alaka osisi ndị ọzọ na-enye ndo nke a ga-eji wuo ebe unu ga-ebi tutu ruo mgbe mmemme ahụ ga-agwụsị, dịka e dere ya nʼakwụkwọ iwu.”
\p 
\v 16 Ya mere, ndị ahụ pụrụ gaa weta alaka osisi, jiri ha wuore onwe ha ụlọ ahịhịa ha ga-ebi nwa mgbe nta nʼelu ụlọ ha, na nʼogige ụlọ nke aka ha, nakwa nʼogige ụlọ Chineke, na mbara ala Ọnụ Ụzọ Ama Mmiri, na nʼakụkụ Ọnụ Ụzọ Ama Ifrem.
\v 17 Ndị ahụ niile si na ndọta nʼagha lọta wuuru onwe ha ụlọ ikwu biri nʼime ya ụbọchị asaa ahụ niile e mere mmemme ahụ. Oke ọṅụ jupụtara obi mmadụ niile, nʼihi na site nʼoge Joshua nwa Nun ruo nʼoge a, o nwebeghị mgbe ụmụ Izrel mere mmemme a nʼụzọ dị otu a.
\p 
\v 18 Ezra na-agụpụta site nʼakwụkwọ iwu Chineke kwa ụbọchị, site nʼụbọchị mbụ ruo nʼụbọchị ikpeazụ. Ha mere mmemme ahụ ụbọchị asaa ma nʼụbọchị nke asatọ ha nwere ọgbakọ ofufe mmechi dịka e dere ya nʼiwu.
\c 9
\s1 Nkwupụta mmehie
\p 
\v 1 Nʼụbọchị nke iri abụọ na anọ nke otu ọnwa ahụ, ndị Izrel niile zukọkwara na obubu ọnụ, yiri uwe iru ụjụ, kpokwasịkwa onwe ha ntụ nʼisi.
\v 2 Ndị si nʼagbụrụ Izrel wezugakwara onwe ha site nʼebe ndị mba ọzọ niile nọ. Ha guzoro nʼọnọdụ ha kwupụta mmehie ha na ajọ omume nke nna nna ha.
\v 3 Ha guzokwara nʼebe ahụ ha nọ gụọ site nʼakwụkwọ iwu nke \nd Onyenwe anyị\nd*, bụ Chineke ha ruo awa atọ. Ha jikwa awa atọ nke ọzọ kwupụta mmehie ha, na ife \nd Onyenwe anyị\nd* Chineke ha ofufe.
\v 4 Mgbe ahụ Jeshua, Bani, Kadmiel, Shebanaya, Buni, Sherebaya, Bani na Kenani rigoro guzo nʼelu ihe nguzo ndị Livayị. Ha jiri oke olu kpọkuo \nd Onyenwe anyị\nd* bụ Chineke ha.
\v 5 Ndị Livayị ndị a, Jeshua, Kadmiel, Bani, Hashabneia, Sherebaya, Hodia, Shebanaya na Petahaya sịrị, “Bilienụ ọtọ, too \nd Onyenwe anyị\nd* Chineke unu, onye na-adị site nʼebighị ebi ruo ebighị ebi.”
\pm “Ka aha gị dị ebube bụrụ ihe a gọziri agọzi, ka ọ bụrụ ihe e buliri elu karịa ngọzị niile na otuto niile.
\v 6 Gị onwe gị, naanị gị bụ \nd Onyenwe anyị\nd*. Gị kere eluigwe, ọ bụladị eluigwe kachasị elu, na kpakpando niile nke mbara eluigwe, ụwa na ihe niile dị nʼime ya, oke osimiri niile na ihe niile dị nʼime ha. Ọ bụ gị na-enye ihe niile ndụ, usuu niile nke eluigwe na-akpọkwa isiala nye gị.
\pm 
\v 7 “Gị, onwe gị bụ \nd Onyenwe anyị\nd* Chineke ahụ, onye họpụtara Ebram site nʼobodo Ụọ nke ndị Kaldịa, kpọpụta ya, gụgharịa aha ya ka ọ bụrụ Ebraham.
\v 8 Ị hụkwara nʼobi ya kwesiri ntụkwasị obi nye gị, gị na ya gbakwara ndụ na ị ga-enye ụmụ ya ala ndị Kenan, nke ndị Het, nke ndị Amọrait, nke ndị Periz, nke ndị Jebus na nke ndị Gigash. I mezuola nkwa gị nʼihi na ị bụ onye ezi omume.
\pm 
\v 9 “Ị hụrụ nsogbu na iru ụjụ niile nke nna nna anyị ha nʼala Ijipt; ị nụkwara akwa ha nʼakụkụ Osimiri Uhie.
\v 10 I gosiri Fero na ndịisi ọchịchị ya na ndị ya niile ọtụtụ ihe ịrịbama na ọrụ ebube nʼihi na ị hụrụ otu ha siri site na nganga juru ha obi mesoo ndị gị mmeso ọjọọ. Ụwa niile maara aha gị taa nʼihi ọrụ ebube ndị a niile ị rụrụ.
\v 11 I kewara Osimiri Uhie abụọ mee ka ndị gị site nʼala akọrọ gafee. Ma i mere ka ndị iro ha na-achụ ha ọsọ nwụọ nʼime oke osimiri ahụ. Ha mikpuru dịka nkume danyere nʼime mmiri, nke oke osimiri.
\v 12 I ji ogidi igwe ojii duo nna nna anyị ha nʼehihie, ma were ogidi ọkụ duo ha nʼabalị, inye ha ìhè ka ha ghara ijehie ụzọ.
\pm 
\v 13 “I sitere nʼeluigwe gwa ha okwu, ị rịdatara nʼugwu Saịnaị, ị nyere ha iwu na ntụziaka niile ziri ezi, nyekwa ha ụkpụrụ na ihe niile dị mma nke enyere nʼiwu.
\v 14 I mere ka ha mata ụbọchị izuike gị dị nsọ, nyekwa ha iwu site nʼọnụ ohu gị Mosis, ka ha debe iwu gị na ụkpụrụ gị niile.
\v 15 I sitere nʼeluigwe nye ha achịcha mgbe agụụ gụrụ ha, sitekwa na nkume nye ha mmiri mgbe akpịrị kpọrọ ha nkụ. I sịkwara ha baa nʼime ala ahụ inweta ala ahụ bụ nke i weliri aka gị ṅụọ iyi inye ha.
\pm 
\v 16 “Ma nna nna anyị ha erubeghị isi nʼokwu gị, nʼihi isiike ha na nganga ha.
\v 17 Ha egeghị ntị ọbụla, ha echetakwaghị ihe ịrịbama niile i meere ha. Kama ha nupuru isi họpụtara onwe ha onyeisi ga-eduru ha ịlaghachi Ijipt. Ma ị bụ Chineke onye na-eme ebere, onye na-agbaghara mmehie ndị gị mgbe ọbụla. Ị bụ onye obiọma, onye iwe na-adịghị ewe ọsịịsọ. I jupụtara nʼịhụnanya na amara mgbe niile. Nʼihi ya, ị gbakụtaghị ha azụ,
\v 18 ọ bụladị mgbe ha meere onwe ha nwa ehi ha kpụrụ akpụ kwuo sị, ‘Nke a bụ chi unu. Ọ bụ ya si nʼala Ijipt dupụta anyị,’ maọbụ mgbe ha mehiere megide gị nʼụzọ niile.
\pm 
\v 19 “Ma nʼihi obi ebere gị nke dị ukwuu, ị hapụghị ha ka ha nwụọ nʼọzara. Ogidi igwe ojii ahụ duuru ha ụbọchị niile, ma ogidi ọkụ ahụ dukwara ha abalị niile.
\v 20 I zitere ezi Mmụọ nke gị ime ka ha nwee uche. Ị gbochikwaghị mánà gị iru ha ọnụ, ị nyekwara ha mmiri nʼihi akpịrị ịkpọ nkụ ha.
\v 21 Iri afọ anọ ka i debere ha ndụ nʼọzara. Ọ dịghị ihe kọrọ ha nʼoge ahụ. Uwe ha akaghị nka, ukwu ha azaghị.
\pm 
\v 22 “I nyere ha alaeze na mba dị iche iche, kenye ha ọbụladị ebe ndị dịkarịsịrị anya. Ha nwetara ala Saịhọn bụ eze Heshbọn, na ala Ọg bụ eze Bashan.
\v 23 I mere ka ụmụ Izrel mụbaa dịka kpakpando nke eluigwe, ị kpọbatara ha nʼala ahụ i gwara ndị bụ nna ha ka ha baa nweta.
\v 24 Ụmụ ha banyere nweta ala ahụ. I meriri ndị Kenan nʼihu ha, bụ ndị bi nʼala ahụ. I weere ndị Kenan ahụ nyefee nʼaka ha, ha na ndị eze ha, na ndị niile bi nʼala ahụ ka ndị gị jiri ha mee ihe ọbụla ha kpebiri nʼobi ha.
\v 25 Ndị gị nwetara ala mara mma, na ọtụtụ obodo e wusiri ike; ha nwetakwara ọtụtụ ụlọ nke ihe ọma juru nʼime ha, na olulu mmiri e gwuru nke ọma, na ubi vaịnị mkpụrụ dị, na ubi oliv, na ọtụtụ osisi ọma ndị ọzọ na-amị mkpụrụ. Ha rijuru afọ, ahụ ha mara mma ile anya, ha ṅụrikwara ọṅụ nʼihi ngọzị ị gọziri ha.
\pm 
\v 26 “Ma ha nupuru isi nʼokwu gị, jụ iwu gị, gbuo ndị amụma tụrụ ha mmehie ha nʼihu, meekwa ọtụtụ ihe ọjọọ ndị ọzọ dị iche iche.
\v 27 Nʼihi nke a, i nyefere ha nʼaka ndị iro ha, ndị kpagburu ha. Ma nʼime mkpagbu ha, ha kpọkuru gị, ị nọkwa nʼeluigwe nụ ekpere ha, sitekwa nʼobi ebere gị zigara ha ndị bịara zọpụta ha, na ndị napụtara ha site nʼaka ndị iro ha.
\pm 
\v 28 “Ma mgbe ihe bidoro ịgara ha nke ọma, ha mekwara ihe jọrọ njọ nʼihu gị. Ọzọkwa, i nyefere ha nʼaka ndị iro ha ka ndị iro ha merie ha. Ma mgbe ọbụla ndị gị chegharịkwutere gị, kpọkuo gị ka i nyere ha aka, ị na-anụ arịrịọ ha, sitekwa nʼobi ebere gị gbapụta ha.
\pm 
\v 29 “Ị dọrọ ha aka na ntị sị ha lọghachi debe ihe i nyere nʼiwu. Ma ha sitere na nganga juru ha obi jụ idebe iwu gị. Ha mehiere megide ihe niile i nyere nʼiwu, ọ bụ ezie na ha maara na idebe ya ga-ewetara ha ndụ. Ma site nʼisiike ha, ha gbakụtara gị azụ, bụrụ ndị isiike na ndị jụrụ ige ntị.
\v 30 Ma i sitere na ntachiobi gị nye ha ogologo oge ichegharị; ị dọrọ ha aka na ntị site nʼọnụ ndị amụma gị, ma ha egeghị ntị. Ya mere, i kwenyekwara ka ndị iro ha merie ha ọzọ.
\v 31 Ma nʼihi obi ebere gị i bibighị ha kpamkpam; ị gbakụtakwaghị ha azụ nʼihi na ị bụ Chineke onye dị ebere na onye amara.
\pm 
\v 32 “Ugbu a, Chineke anyị, Chineke dị ukwuu, onye dị ike dịkwa ebube, onye na-edebe ọgbụgba ndụ ịhụnanya ya, ka ọnọdụ ihe isi ike a ghara ịbụ ihe nta nʼanya gị. Ntaramahụhụ nke dakwasịrị anyị, ndị eze anyị na ndị ndu anyị, ndị nchụaja anyị, ndị amụma anyị, nna nna anyị ha na ndị gị niile, site nʼoge ndị eze Asịrịa buru ụzọ lụgbuo anyị nʼagha tutu ruo taa.
\v 33 Ma gị onwe gị bụ onye ezi omume, nʼihe niile bịakwasịrị anyị; Ị mere ihe kwesiri, ebe anyị onwe anyị mere ajọ omume.
\v 34 Ndị eze anyị, ndị ndụ anyị na ndị nchụaja na nna nna anyị edebeghị iwu gị; ha aṅaghịkwa ntị nʼihe niile i nyere nʼiwu maọbụ ihe ama gị nke ị dọrọ ha aka na ntị idebe.
\v 35 Ọ bụladị mgbe ha nọ nʼalaeze nke aka ha na-ekpori ndụ, nke oke ịdị mma gị nke ị mere ka o rute ha aka, nʼala ọma ahụ sara mbara nwere ume i nyere ha, ha efeghị gị ofufe, ha esitekwaghị nʼụzọ ọjọọ ha chigharịa.
\pm 
\v 36 “Ma lee, anyị bụ ndị ohu taa, e, anyị bụ ndị ohu nʼala ahụ i nyere nna nna anyị ha, ka ọ bụrụ ebe ha ga-esi rie mkpụrụ ọ mịpụtara na ihe ọma ọ na-amịpụta.
\v 37 Nʼihi mmehie anyị, mkpụrụ ọma niile a na-esi na ya wepụta ka ndị eze ahụ niile i mere ka ha na-achị anyị na-ewere. Ha nwere ike nʼahụ anyị, na nʼebe anụ ụlọ anyị dị ka o si dị ha mma. Anyị na-ahụjukwa anya.
\s1 Nkwekọrịta nke mmadụ niile
\p 
\v 38 “Nʼihi ihe ndị a niile, anyị na-ekwe gị nkwa ugbu a na anyị ga-efe gị. Anyị, ndịisi anyị, ndị Livayị na ndị nchụaja, na-etinye aha anyị nʼọgbụgba ndụ a.”
\b
\c 10
\li4 
\v 1 Ndị tinyere aka, nʼakwụkwọ ahụ bụ:
\b
\li1 Onyeisi ọchịchị:
\li2 Nehemaya nwa Hakalaya.
\b
\li2 Zedekaya,
\v 2 Ndị ọzọ bụ Seraya, Azaraya, Jeremaya,
\li2 
\v 3 Pashua, Amaraya, Malkija,
\li2 
\v 4 Hatush, Shebanaya, Maluk,
\li2 
\v 5 Harim, Meremot, Ọbadaya,
\li2 
\v 6 Daniel, Gineton, Baruk,
\li2 
\v 7 Meshulam, Abija, Mijamin,
\li2 
\v 8 Maazaya, Bilgai na Shemaya.
\li1 Ndị a bụ ndị nchụaja.
\b
\li1 
\v 9 Ndị Livayị so tinye aka ha nʼakwụkwọ bụ,
\li2 Jeshua nwa Azanaya, Binui otu nʼime ụmụ Henadad, Kadmiel,
\li2 
\v 10 ndị so ha na-arụ ọrụ: Shebanaya,
\li2 Hodia, Kelita, Pelaia, Hanan,
\li2 
\v 11 Mika, Rehob, Hashabaya
\li2 
\v 12 Zakua, Sherebaya, Shebanaya,
\li2 
\v 13 Hodia, Bani na Beninu.
\b
\li1 
\v 14 Ndịisi ọchịchị tinyere aka ha bụ,
\li2 Parosh, Pahat-Moab, Elam, Zatu, Bani,
\li2 
\v 15 Buni, Azgad, Bebai,
\li2 
\v 16 Adonaịja, Bigvai, Adin,
\li2 
\v 17 Atea, Hezekaya, Azoa,
\li2 
\v 18 Hodia, Hashum, Bezai,
\li2 
\v 19 Harif, Anatot, Nebai,
\li2 
\v 20 Magpịash, Meshulam, Hezia,
\li2 
\v 21 Meshezabel, Zadọk, Jadua,
\li2 
\v 22 Pelataya, Hanan, Anaia,
\li2 
\v 23 Hoshea, Hananaya, Hashub,
\li2 
\v 24 Halohesh, Pilha, Shobek,
\li2 
\v 25 Rehum, Hashabna, Maaseia,
\li2 
\v 26 Ahaya, Hanan, Anan,
\li2 
\v 27 Maluk, Harim na Baana.
\b
\pm 
\v 28 “Ndị ọzọ fọdụrụ bụ ndị nchụaja, ndị Livayị, ndị nche, ndị ọbụ abụ, ndị na-eje ozi nʼụlọnsọ na ndị ahụ niile sitere nʼirube isi nʼiwu Chineke wezuga onwe ha site nʼebe ndị mba ọzọ ahụ bi ha gburugburu nọ, ha na ndị nwunye ha na ụmụ ha ndị ikom na ndị inyom, bụ ndị niile tozuru ịghọta ihe.
\v 29 Ndị a niile sooro ụmụnne ha ndị Izrel a na-asọpụrụ, jikọtaa onwe ha nʼọbụbụ ọnụ na ịṅụ iyi ịgbaso iwu Chineke, nke o nyere site nʼaka Mosis, bụ ohu Chineke; na ilezi anya rube isi nʼihe niile enyere nʼiwu, ntụziaka niile na ụkpụrụ niile nke \nd Onyenwe anyị\nd* bụ Onyenwe anyị.
\pm 
\v 30 “Anyị kpebikwara na ụmụ anyị ndị ikom na ndị inyom agaghị alụ di maọbụ nwunye site na mba ọzọ.
\pm 
\v 31 “Anyị kpebikwara na ọ bụrụ na ndị mba ọzọ eburu ngwa ahịa ha maọbụ mkpụrụ ubi ha bịa ire ya nʼụbọchị izuike, maọbụ nʼụbọchị ọzọ dị nsọ, anyị agaghị azụ ihe ọbụla. Anyị na-ekpebikwa na anyị agaghị arụ ọrụ ọbụla nʼafọ nke asaa niile, kwekọọkwa na anyị ga-agbaghara ụmụnna anyị niile ji anyị ụgwọ nʼafọ ahụ.
\pm 
\v 32 “Anyị kwekọrịtakwara na anyị ga-atụ ụtụ otu ụzọ nʼime ụzọ atọ nke otu shekel afọ niile maka iji kwadoo ọrụ ụlọnsọ ukwu Chineke,
\v 33 maka ime ka ihe ndị a dịrị nʼụlọnsọ ukwu ahụ: achịcha nsọ, onyinye ọka nke ụbọchị niile, aja nsure ọkụ na onyinye nke ụbọchị izuike, mmemme ọnwa ọhụrụ niile, ha na mmemme ndị ọzọ niile a kara aka, maka aja dị nsọ niile na aja ikpuchi mmehie ndị Izrel, maka ozi niile a na-aga nʼụlọnsọ Chineke anyị.
\pm 
\v 34 “Anyị bụ ndị nchụaja, ndị Livayị na ndị ọzọ, ejirila ife nza chọpụta mgbe ezinaụlọ ọbụla nʼetiti anyị ga-eji bubata nku nʼụlọ Chineke anyị nʼoge ya kwa afọ, maka ebe ịchụ aja nke \nd Onyenwe anyị\nd* Chineke anyị dịka e dere ya nʼiwu.
\pm 
\v 35 “Anyị kpebikwara na mmadụ niile nʼotu nʼotu ga na-ewebata mkpụrụ mbụ nke ihe ubi ya nʼụlọnsọ \nd Onyenwe anyị\nd*, na mkpụrụ osisi ọbụla, maọbụ ihe ubi ndị ọzọ.
\pm 
\v 36 “Dịka e dere ya nʼIwu, anyị ga-ewebata ụmụ ndị ikom mbụ anyị, na nwa mbụ nke igwe ehi, na igwe ewu na atụrụ anyị niile, nʼụlọ Chineke anyị. A ga-enye ha ndị nchụaja na-eje ozi nʼebe ahụ.
\pm 
\v 37 “Karịsịa, anyị ga-ewebata nʼụlọ ịchịkọba ihe nke ụlọnsọ Chineke anyị, nyekwa ha ndị nchụaja, ụtụ ọka mbụ anyị kwọrọ, ya na onyinye ndị ọzọ nke mkpụrụ ubi mbụ anyị, dịka mmanya vaịnị mbụ, mmanụ oliv mbụ na mkpụrụ osisi ndị ọzọ. Anyị kpebikwara inye ndị Livayị otu ụzọ nʼime ụzọ iri nke ihe niile anyị nwetara nʼubi anyị, nʼihi na ọ bụ ọrụ ndị Livayị ịnakọta otu ụzọ nʼụzọ iri site nʼobodo niile ebe anyị na-arụ ọrụ.
\v 38 Ndị nchụaja bụ ụmụ ụmụ Erọn ga-eso ndị Livayị mgbe ha na-anakọta onyinye otu ụzọ nʼime ụzọ iri ndị a. Ha ga-ewekọta ihe ndị a niile webaa ha nʼụlọ Chineke anyị, ruo nʼime ọnụụlọ ịchịkọba ihe,\f + \fr 10:38 \ft Ọtụtụ ọnụụlọ nchịkọba ihe dị nʼogige ụlọnsọ ukwu ahụ. Ọ bụ nʼebe a ka a na-edebe ngwongwo niile dị nsọ. Gụọ ebe ndị a; \xt 1Ih 9:26; 2Ih 31:11; Neh 13:7; Mal 3:10.\xt*\f* nke ụlọakụ.
\v 39 Ndị Izrel na ndị Livayị, kwesiri iweta onyinye ọka ha, na mmanya vaịnị ọhụrụ, na mmanụ oliv nʼime ụlọ ịchịkọba ihe, nʼebe a na-edebe ngwongwo niile e ji eje ozi nʼụlọ ukwu ahụ, nke ndị nchụaja na-eje ozi, ndị nche na nke ndị ọbụ abụ.
\pm “Anyị agaghị agbakụtakwa ụlọ Chineke anyị azụ.”
\c 11
\s1 Ndị ọhụrụ ga-ebi na Jerusalem
\p 
\v 1 Ugbu a, ndịisi Izrel bi nʼobodo nsọ Jerusalem nʼoge a, ma e sitere nʼife nza họpụta otu ụzọ nʼime ụzọ iri nke ndị bi nʼobodo ndị ọzọ niile ka ha bịa biri na Jerusalem, bụ obodo nsọ ahụ, ebe ụzọ itoolu fọdụrụ bikwa nʼobodo nke aka ha.
\v 2 Ndị mmadụ toro ndị niile jiri afọ ofufu họrọ ịbịa soro biri na Jerusalem.
\b
\li4 
\v 3 Ndị a bụ ndịisi ala ahụ a na-achị achị ndị bịara biri na Jerusalem (ma ọtụtụ ndị Izrel, ndị nchụaja, ndị Livayị, ndị na-eje ozi nʼụlọnsọ na ụmụ ndị na-ejere Solomọn ozi biiri nʼobodo Juda, onye ọbụla nʼihe onwunwe ya nʼobodo ha dị iche iche.
\v 4 Ebe ndị ọzọkwa bụ ndị sitere na Juda na Benjamin, biiri na Jerusalem).
\b
\li1 Ndị sitere nʼagbụrụ Juda bụ ndị a:
\li2 Ataia nwa Uzaya, nwa Zekaraya, nwa Amaraya, nwa Shefataya, nwa Mahalalel, nwa Perez;
\li2 
\v 5 na Maaseia nwa Baruk, nwa Kol-Hoze, nwa Hazaia, nwa Adaya, nwa Joiarib, nwa Zekaraya, nwa onye Shilo.\f + \fr 11:5 \ft Maọbụ, \fqa Shela\f*
\li2 
\v 6 Ọnụọgụgụ ụmụ Perez niile bi na Jerusalem dị narị anọ, na iri isii na asatọ (468). Ha bụ ndị ikom gbara dimkpa.
\li1 
\v 7 Ndị sitere nʼagbụrụ Benjamin bụ,
\li2 Salu nwa Meshulam, nwa Joed, nwa Pedaia, nwa Kolaya, nwa Maaseia, nwa Itiel, nwa Jeshaya,
\v 8 ya na ndị na-eso ya bụ ụmụ Gabai na Salai. Ọnụọgụgụ ha dị narị itoolu na iri abụọ na asatọ (928).
\li2 
\v 9 Juel nwa Zikri bụ onyeisi ha. Juda nwa Hasenua bụ onye na-eso ya, na onye na-achị akụkụ ọhụrụ nke obodo ahụ.
\li1 
\v 10 Ndị sitere nʼetiti ndị nchụaja bụ,
\li2 Jedaya nwa Joiarib, na Jakin,
\li2 
\v 11 na Seraya nwa Hilkaya, nwa Meshulam, nwa Zadọk, nwa Meraiot, nwa Ahitub onye na-elekọta ụlọ ukwuu Chineke.
\v 12 Ọnụọgụgụ ndị ikom ha na ha na-arụkọ ọrụ nʼụlọ ukwu ahụ bụ narị asatọ na iri abụọ na abụọ (822).
\li2 Adaya, nwa Jeroham, nwa Pelalaya, nwa Amzi, nwa Zekaraya, nwa Pashua nwa Malkija,
\v 13 na ndị ikom bụ ndịisi ezinaụlọ ndị so ya rụọ ọrụ dị narị abụọ na iri anọ na abụọ (242) nʼọnụọgụgụ,
\li2 Amashaị nwa Azarel, nwa Ahazai, nwa Meshilemot, nwa Imea,
\v 14 na ndị otu ya nʼọrụ ndị bụkwa dimkpa, dị otu narị na iri abụọ na asatọ (128) nʼọnụọgụgụ.
\li2 Onyeisi ha bụ Zabdiel nwa Hagedolin.
\li1 
\v 15 Site na ndị Livayị:
\li2 Shemaya nwa Hashub, nwa Azrikam, nwa Hashabaya, nwa Buni,
\li2 
\v 16 na Shabetai, na Jozabad, mmadụ abụọ na ndị ndu ndị Livayị, ndị ọ bụ ha na-arụ ọrụ dị nʼezi nke ụlọ Chineke;
\li2 
\v 17 Matanaya nwa Mika, nwa Zabdi, nwa Asaf, bụ onyendu nke duru nʼekpere na ofufe ekele.
\li2 Bakbukaya onye nke abụọ nʼetiti ndị otu ya,
\li2 na Abda nwa Shamua, nwa Galal, nwa Jedutun, bụ ndị na-enyere ya aka.
\li2 
\v 18 Ọnụọgụgụ ndị Livayị niile nọ na obodo nsọ ahụ dị narị abụọ na iri asatọ na anọ (284).
\li1 
\v 19 Ndị nche ọnụ ụzọ ama,
\li2 Akub, Talmon na ndị otu ha dị otu narị na iri asaa na abụọ (172) nʼọnụọgụgụ, ha bụ ndị na-eche nche nʼọnụ ụzọ ama niile.
\b
\p 
\v 20 Ndị fọdụrụ nʼIzrel, ha na ndị nchụaja, na ndị Livayị, nọ nʼobodo Juda niile, onye ọbụla nʼihe nketa ya.
\p 
\v 21 Ndị ahụ niile na-eje ozi nʼụlọnsọ bi nʼugwu Ofel. Ndịisi ha bụ Ziha na Gishpa.
\p 
\v 22 Onye na-elekọta ndị Livayị bi na Jerusalem bụ Uzi, nwa Bani, nwa Hashabaya, nwa Matanaya, nwa Matanaia, nwa Mika. Uzi bụ otu onye si nʼikwu Asaf, ndị ọbụ abụ maka ije ozi nke ụlọ Chineke.
\v 23 Eze họpụtara ndị ọbụ abụ nyekwa ha ọrụ ha kwesiri ịrụ ụbọchị niile.
\p 
\v 24 Petahaya nwa Meshezabel, onye bụ otu nʼagbụrụ Zera, nwa Juda, bụ onyeozi eze banyere ihe niile gbasara ndị mmadụ ahụ.
\p 
\v 25 Obodo ụfọdụ ebe ndị Juda bi bụ ndị a: Kiriat Aba, Dibọn, Jekabzeel na obodo nta ndị dị ha gburugburu,
\v 26 Jeshua, Molada, Bet-Pelet,
\v 27 Haza Shual, Bịasheba na obodo ya niile,
\v 28 Ziklag, Mekona na obodo ya niile,
\v 29 En-Rimọn, Zora, Jamut,
\v 30 Zanoa, Adulam na obodo nta dị ha gburugburu, Lakish, ala dị ya gburugburu, Azeka na obodo ya niile. Nke a pụtara na ndị mmadụ bi site na Bịasheba ruo na Ndagwurugwu Hinom.
\p 
\v 31 Ndị agbụrụ Benjamin biri na Geba, Mikmash, Aija, Betel na obodo dị ya gburugburu,
\v 32 Anatot, Nob, Ananaya,
\v 33 Hazọ, Rema, Gitaim,
\v 34 Hadid, Zeboim, Nebalat,
\v 35 Lod, Ono na Ge Harashim.\f + \fr 11:35 \ft Maọbụ, \fqa Ndagwurugwu ndị na-akwa ǹka\f*
\p 
\v 36 Ụfọdụ nʼotu ndị Livayị, ndị ebe obibi ha dị na Juda ka e zigara isoro biri nʼebo Benjamin.
\c 12
\s1 Ndị nchụaja na ndị Livayị
\li4 
\v 1 Ndị a bụ ndị nchụaja na ndị Livayị ndị so Zerubabel nwa Shealtiel na Jeshua lọta.
\b
\li1 Seraya, Jeremaya, Ezra,\f + \fr 12:1 \ft Ezra nke a, abụghị Ezra onye nchụaja. Onye bụ ọka nʼihe gbasara iwu Onyenwe anyị, nke si nʼezinaụlọ Seraya. Gụọ akwụkwọ \xt Ezr 7:1-5\xt*\f*
\li1 
\v 2 Amaraya, Maluk, Hatush,
\li1 
\v 3 Shekanaya, Rehum, Meremot,
\li1 
\v 4 Ido, Gineton, Abija
\li1 
\v 5 Mijamin, Maadaya, Bilga,
\li1 
\v 6 Shemaya, Joiarib, Jedaya,
\li1 
\v 7 Salu, Amok, Hilkaya na Jedaya.
\b
\li4 Ndị a niile bụ ndị ndu ndị nchụaja na ndị na-enyere ndị ndụ aka nʼụbọchị Jeshua.
\b
\p 
\v 8 Ndị Livayị so ha bụ ndị a: Jeshua, Binui, Kadmiel, Sherebaya, Juda nakwa Matanaya, onye ya na ndị otu ya na-elekọta ofufe ekele.
\v 9 Bakbukaya, na Unni, ndị otu ha nọ na ncherita ihu nʼofufe ahụ.
\b
\li1 
\v 10 Jeshua mụrụ Joiakim,
\li1 Joiakim mụrụ Eliashib,
\li1 Eliashib mụrụ Joiada,
\li1 
\v 11 Joiada mụrụ Jonatan,
\li1 ebe Jonatan mụrụ Jadua.
\b
\b
\li4 
\v 12 Ndị a bụ ndịisi ikwu ndị nchụaja nʼoge ndụ Joiakim.
\b
\li1 Meraia bụ onyeisi ụmụ Seraya,
\li1 Hananaya bụ onyeisi ụmụ Jeremaya,
\li1 
\v 13 Meshulam bụ onyeisi ụmụ Ezra,
\li1 Jehohanan, onyeisi ụmụ Amaraya;
\li1 
\v 14 Jonatan, onyeisi ụmụ Maluk;
\li1 Josef bụ onyeisi ụmụ Shekanaya\f + \fr 12:14 \fq Shekanaya \ft ọtụtụ akwụkwọ ndị Hibru na-ede \fqa Shebayana\f*;
\li1 
\v 15 nke Harim, Adna,
\li1 nke Meremot, Helkai;
\li1 
\v 16 Zekaraya, onyeisi ụmụ Ido;
\li1 Meshulam, onyeisi ụmụ Gineton
\li1 
\v 17 Zikri, onyeisi ụmụ Abija;
\li1 Piltai, onyeisi ụmụ Modaya na Miniamin
\li1 
\v 18 Shamua, onyeisi ụmụ Bilga,
\li1 Jehonatan, onyeisi ụmụ Shemaya;
\li1 
\v 19 Matenai, onyeisi ụmụ Joiarib;
\li1 Uzi, onyeisi ụmụ Jedaya;
\li1 
\v 20 Kalai, onyeisi ụmụ Salu;
\li1 Eba, onyeisi ụmụ Amok,
\li1 
\v 21 Hashabaya, onyeisi ụmụ Hilkaya;
\li1 Netanel, onyeisi ndị Jedaya.
\b
\p 
\v 22 E dekọtara aha ndịisi ezinaụlọ ndị Livayị niile nʼụbọchị Eliashib, Joiada, Johanan na Jadua, nakwa nke ndị nchụaja nʼakwụkwọ nʼoge ọchịchị Daraiọs bụ eze Peshịa.
\v 23 E dekwara aha ndịisi ndị Livayị niile nʼakwụkwọ tutu ruo nʼoge Johanan nwa Eliashib dị ndụ.
\v 24 Ndị a bụ ndịisi ndị Livayị nʼoge ahụ: Hashabaya, Sherebaya, Jeshua, nwa Kadmiel na ndị otu ha. Ha kere onwe ha ụzọ abụọ. Ụzọ abụọ ndị a na-eguzokwa na-eche ibe ha ihu mgbe ọbụla ha na-abụku Chineke abụ otuto na ekele. Otu ụzọ na-amalite nke ọzọ azaghachi, dịka Devid onye nke Chineke si nye ya nʼiwu.
\p 
\v 25 Ndị nche na-eche ọnụ ụzọ ụlọ ịchịkọba ihe nke ụlọnsọ bụ ndị a: Matanaya, Bakbukaya, Ọbadaya, Meshulam, Talmon na Akub.
\v 26 Ha jere ozi ha nʼoge Joiakim nwa Jeshua, nwa Jozadak, dị ndụ, na nʼoge Nehemaya bụ onyeisi ọchịchị, na nʼoge Ezra bụkwa onye nchụaja, na onye nkuzi okwu Chineke.
\s1 Ido mgbidi Jerusalem nsọ
\p 
\v 27 Mgbe a na-edo mgbidi Jerusalem ọhụrụ ahụ nsọ, e sitere nʼobodo niile ndị Livayị bi kpọọ ha ka ha bịa nye aka iji ọṅụ mee mmemme ido nsọ ahụ. Ha bịakwara jiri abụ ekele na ihe egwu dị iche iche dịka ụbọ akwara, ịgba na une kelee Chineke.
\v 28 Ndị ọbụ abụ sitekwara nʼobodo niile dị gburugburu Jerusalem bịa, ọ bụladị site nʼobodo niile ndị Netofa,
\v 29 na Bet-Gilgal, na akụkụ Geba na Azmavet, nʼihi na ha ewuorola onwe ha obodo nta dị iche iche gburugburu Jerusalem.
\v 30 Mgbe ndị nchụaja na ndị Livayị dochara onwe ha ọcha, ha dokwara ndị Izrel niile, na ọnụ ụzọ ama niile, na mgbidi ahụ ọcha.
\p 
\v 31 E mere m ka ndị ndu Juda niile rigoro nʼelu mgbidi ahụ. Nʼebe ahụ ka m kenyere otu ndị ọbụ abụ abụọ inye ekele. Otu ụzọ gara akụkụ aka nri nke elu mgbidi ahụ ruo nʼỌnụ Ụzọ Ama Ikpofu Ahịhịa.
\v 32 Hoshaya na ọkara ndị ndu Juda na-eso ha nʼazụ,
\v 33 ha na Azaraya, Ezra, Meshulam,
\v 34 Juda, Benjamin, Shemaya, Jeremaya
\v 35 na ndị nchụaja ndị a ndị na-afụ opi, tinyere Zekaraya nwa Jonatan, nwa Shemaya. Ndị bụ nna nna Zekaraya bụ Matanaya, Mikaya na Zakua, ndị ikwu Asaf.
\v 36 Ndị otu ya, bụ Shemaya, Azarel, Milalai, Gilalai, Maai, Netanel, Juda na Hanani. Ha niile ji ngwa egwu ha, ụdị ngwa egwu ndị ahụ Devid onye nke Chineke nyere nʼiwu na ndị ọbụ abụ ga-eji. Ezra, bụ ode akwụkwọ nọ nʼihu na-edu ha.
\v 37 Mgbe ha rutere nʼỌnụ Ụzọ ama Isi Iyi, ha rigooro nʼelu nkwasa nrigo ụlọ elu e si abata nʼobodo Devid, si ebe ahụ gafee ụlọeze Devid, gaakwa lọghachi nʼỌnụ Ụzọ Ama Mmiri, nke dị nʼakụkụ ọwụwa anyanwụ obodo ahụ.
\p 
\v 38 Ndị ọbụ abụ nke ọzọ bụ ndị na-enye ekele gara ụzọ aka ekpe. Mụ onwe m sooro ha nʼelu mgbidi ahụ, tinyere ọkara ndị mmadụ ahụ, gafee Ụlọ elu Ite Ọkụ jeruo Mgbidi Sara Mbara.
\v 39 Anyị sitekwara nʼebe ahụ gafee Ọnụ Ụzọ Ama Ifrem, Ọnụ Ụzọ ama Jeshana, Ọnụ Ụzọ Ama Azụ, Ọnụ Ụzọ Ama Ụlọ Elu Hananel, ruokwa nʼỌnụ Ụzọ Ama Ụlọ Elu Narị na ruo nʼỌnụ Ụzọ Ama Atụrụ, kwụsị nʼỌnụ Ụzọ Ama Ndị Nche.
\p 
\v 40 Ya mere, ụzọ ndị mmadụ abụọ na-abụ abụ ekele nye Chineke zukọtara bata nʼụlọnsọ ukwu. Esokwa m ha bata, mụ na ọkara ndị ndu,
\v 41 tinyere ndị nchụaja ndị a: Eliakịm, Maaseia, Miniamin, Mikaya, Elioenai, Zekaraya na Hananaya. Ndị a niile ji opi ha.
\v 42 Ndị ọzọ sokwa bata bụ ndị a: Maaseia, Shemaya, Elieza, Uzi, Jehohanan, Malkija, Elam na Eza. Onyendu ndị ọbụ abụ ahụ niile bụ Jezrahaya.
\v 43 Ha chụrụ ọtụtụ aja nʼụbọchị ahụ nʼihi na Chineke nyere ha oke ọṅụ. Ụmụnta na ndị inyom sokwa ṅụrịa ọṅụ. Ha nụkwara ụda ọṅụ ndị Jerusalem site nʼebe dị anya.
\p 
\v 44 Nʼoge ahụ ka a họpụtara ndị ikom na-elekọta ụlọ ịchịkọba ihe, ebe a na-achịkọba onyinye mkpụrụ mbụ, na onyinye otu ụzọ nʼụzọ iri. A na-esite nʼobodo gbara Jerusalem gburugburu na-ewebata nʼụlọ ịchịkọba ihe onyinye niile e nyere nʼiwu maka ọdịmma ndị nchụaja na ndị Livayị. E si otu a na-ewebata ya nʼihi na ọrụ ndị nchụaja na ndị Livayị na-arụ na-atọ ndị Juda ụtọ nke ukwuu.
\v 45 Nʼihi na ha na-arụ ọrụ Chineke ahụ ha ketara ịrụ, ya na ọrụ ido ndị mmadụ na ihe ọbụla nsọ. Otu a kwa ka ndị ọbụ abụ, na ndị na-eche nche sị arụkwa ọrụ a dịka iwu Devid na Solomọn nwa ya nyere si dị.
\v 46 Ọ bụ nʼoge Devid na Asaf ka e bidoro inwe ndị ndu abụ ito na ikele Chineke.
\v 47 Ya mere, nʼoge Zerubabel na Nehemaya, ndị Izrel niile na-ewebata onyinye e ji akwagide ọrụ ndị ọbụ abụ, na ndị nche, na ndị Livayị. Ha kewapụtakwara oke ruru ndị Livayị ndị ọzọ iche, ndị Livayị nʼonwe ha kwa, kewapụtara oke ruru ụmụ Erọn nʼime ihe e nyere ha dịka e si nye ya nʼiwu.
\c 13
\s1 Mgbanwe ikpeazụ Nehemaya wetara
\p 
\v 1 Nʼụbọchị ahụ, a gụpụtara okwu Chineke na ntị ndị Izrel site nʼakwụkwọ iwu Mosis. Mgbe a na-agụpụta ya, a chọpụtara na o megidere iwu na onye Amọn, maọbụ onye Moab, ga-eso nʼofufe ụlọnsọ ukwu Chineke.
\v 2 Nʼihi na ha bụ ndị iro ụmụ Izrel. Ha enyeghị ha ihe oriri na ihe ọṅụṅụ kama ha zụrụ Belam ka ọ bụọ ụmụ Izrel ọnụ. (Ma Chineke anyị gbanwere ịbụ ọnụ ahụ mee ka ọ ghọọ ngọzị.)
\v 3 Mgbe a gụpụtara iwu a, ndị Izrel chụpụrụ ndị mba ọzọ niile nọ nʼọgbakọ ha.
\p 
\v 4 Ma tupu ihe ndị a niile emee, Eliashib onye bụ onye nchụaja, onye e doro nʼisi ilekọta ime ụlọ a na-achịkọba ihe nʼụlọ Chineke anyị, ya na Tobaya nwee ezi mmekọrịta,
\v 5 o weere otu ọnụụlọ buru ibu a na-achịkọba ihe nye ya. Na mbụ, ọ bụ ọnụụlọ ebe a na-achịkọta onyinye ọka na ụda na-esi isi ụtọ, na ngwongwo ụlọnsọ, na efere mmanya ọhụrụ, na mmanụ oliv. Mosis enyelarị ya nʼiwu na ọ bụ ndị Livayị na ndị ọbụ abụ na ndị nche nwe onyinye ndị ahụ. Ndị nchụaja nwekwa oke nʼihe ndị a.
\p 
\v 6 Mgbe ihe ndị a na-eme, anọghị m na Jerusalem, nʼihi na nʼiri afọ atọ na abụọ nke ọchịchị Ataksekses, eze Babilọn,\f + \fr 13:6 \ft Sairọs nyere onwe ya aha a, bụ Eze Babilọn, mgbe o meriri ndị Babilọn nʼagha.\f* a lọghachikwutere m eze. Ma e mesịrị m nata ya ike
\v 7 laghachikwa na Jerusalem. Nʼebe a ka m nọ mata banyere ihe ọjọọ ahụ Eliashib mere, inye Tobaya otu ọnụụlọ nke dị nʼogige ụlọ Chineke ka ọ bụrụ ebe izuike ya.
\v 8 Iwe were m nke ukwuu, nke mere na m sitere nʼọnụụlọ ahụ tụpụsịa ngwongwo Tobaya niile nʼezi.
\v 9 Enyere m iwu ka e doo ọnụụlọ ndị ahụ niile ọcha, a chighachikwara m ngwongwo ụlọ Chineke niile nʼime ha, ha na onyinye mkpụrụ ọka, na ụda na-esi isi ụtọ ndị ahụ.
\p 
\v 10 A chọpụtakwara m na-enyebeghị ndị Livayị oke ihe ruru ha, nke mere na ndị ọbụ abụ, na ndị nche ndị ọ bụ ọrụ ha i doo ofufe, alaghachila nʼubi ha dị iche iche.
\v 11 Nʼihi ya, abaara m ha mba jụọ ha si: “Gịnị mere unu jiri gbakụta ụlọnsọ ukwu Chineke azụ?” Mgbe ahụ akpọghachiri m ndị Livayị nyekwa ha ọrụ ha nʼụlọnsọ.
\p 
\v 12 Ndị Juda niile bidokwara iweta ụtụ ha, na onyinye ọka, na mmanya vaịnị na mmanụ oliv ha nʼụlọ ịchịkọba ihe dị nʼụlọnsọ.
\v 13 E tinyere m Shelemaya onye nchụaja, na Zadọk ode akwụkwọ, na Pedaia onye Livayị, ka ha bụrụ ndị na-elekọta ụlọ ịchịkọba ihe niile ahụ. Emekwara m Hanan nwa Zakua, nwa Matanaya, onye ga na-enyere ha aka, nʼihi na a gụrụ ha dịka ndị kwesiri ntụkwasị obi. Ọrụ ha bụ ikere ndị Livayị ibe ha niile oke.
\b
\p 
\v 14 Chineke m, biko cheta m nʼihi nke a, ehichapụkwala ihe niile m ji obi m niile rụọ nʼụlọnsọ gị na ije ozi niile ya.
\b
\p 
\v 15 Nʼụbọchị ndị ahụ, ka m hụrụ na Juda ndị na-azọcha mmanya vaịnị nʼụbọchị izuike, ndị ji ịnyịnya ibu na-ebubata ogbe ọka, na-ebokwasị ha nʼelu ịnyịnya ibu, tinyekwara mmanya, na mkpụrụ vaịnị na fiig, na ibu niile ọbụla. Ha na-ebubatakwa ha nʼime Jerusalem nʼụbọchị izuike. Nke a mere m ji dọọ ha aka na ntị megide ire nri nʼụbọchị ahụ.
\v 16 Ndị si obodo Taịa, bụ ndị birila na Jerusalem nọ na-ebubata azụ na ngwa ahịa ndị ọzọ dị iche iche, na-ere ha na Juda, nakwa na Jerusalem nʼụbọchị izuike.
\v 17 A baara m ndị a na-asọpụrụ na Juda mba, si ha, “Gịnị bụ ihe ọjọọ nke a unu na-eme, na-emerụ ụbọchị izuike?
\v 18 Ọ bụghị otu ihe a ka nna nna unu ha mere, nke mere na Chineke wetara ọdachi a tụkwasị anyị nakwa obodo a? Ugbu a, unu na-akpali ọnụma tụkwasị na nke dị megide Izrel site nʼimerụ ụbọchị izuike?”
\p 
\v 19 Nʼihi nke a, enyere m iwu na a ga-emechi ọnụ ụzọ ama Jerusalem nʼuhuruchi tupu ụbọchị izuike, ruo mgbe ụbọchị izuike gafesịrị. Emere m ka ụfọdụ ndị ohu m na-anọ na nche nʼebe ahụ, ịhụ na ọ dịghị onye ahịa ọbụla ga-abata nʼime obodo Jerusalem nʼụbọchị izuike.
\v 20 Ya mere, ndị na-azụ ahịa na ndị na-ere ụdị ngwa ahịa dị iche iche, na-anọ ọnọdụ abalị nʼazụ Jerusalem, otu gboro maọbụ ugboro abụọ.
\v 21 Ma a dọrọ ha aka na ntị, sị, “Gịnị ka unu ji na-anọ ọnọdụ abalị nʼakụkụ mgbidi a? Ọ bụrụ na unu eme ya ọzọ, aga m enye iwu ka e jide unu.” Site nʼụbọchị ahụ gaa nʼihu, ha abịakwaghị ọzọ nʼụbọchị izuike.
\v 22 Mgbe ahụ, enyere m ndị Livayị iwu ka ha doo onwe ha ọcha, nọọkwa na nche nʼọnụ ụzọ ama, ịhụ na onye ọbụla doro ụbọchị izuike nsọ.
\b
\p Chineke m, biko, cheta m nʼihi ihe ọma ndị a niile, nwee amara nʼebe m nọ, dịka ịba ụba nke obi ebere gị si dị.
\b
\p 
\v 23 Ọzọ, nʼụbọchị ndị ahụ a hụrụ m ndị ikom Juda ndị lụtara ndị inyom site nʼetiti ndị Ashdọd, na ndị Amọn, na ndị Moab,
\v 24 chọpụtakwa na ọkara nʼetiti ụmụ ha na-asụ naanị asụsụ ndị Ashdọd, maọbụ otu asụsụ nke ndị mba ọzọ, ma ha amaghị asụsụ Juda ma ọlị.
\v 25 Ya mere, abaara m ha mba, bụkwaa ha ọnụ. Ụfọdụ ha ka m tiri ihe, dọọkwa ha nʼagịrị isi. Emesịa, emere m ka ha ṅụọ iyi nʼaha Chineke si: “Unu agaghị ekwekwa ka ụmụ ndị ikom na ndị inyom unu lụọ ndị mba ọzọ ma unu onwe unu agakwaghị alụtara ụmụ unu, maọbụ onwe unu, ndị inyom ndị mba ọzọ.
\v 26 Ọ bụghị ọlụlụ di na nwunye dị otu a wetara ọdịda Solomọn? O nweghị eze ọzọ dị na mba ọbụla a pụrụ iji tụnyere Solomọn, nʼihi na Chineke ya hụrụ ya nʼanya mee ya eze ndị Izrel niile. Ma ọ bụ ndị nwunye mba ọzọ ọ lụrụ dubara ya na mmehie ikpere arụsị.
\v 27 Ugbu a, ọ bụ ka anyị gere na ntị na unu onwe unu na-emekwa ajọ ihe dị otu a, na unu ekwesighị ntụkwasị obi nye Chineke anyị, site nʼịlụ ndị inyom ndị mba ọzọ?”
\p 
\v 28 Ya mere, esitere m nʼebe m nọ chụpụ otu nʼime ụmụ ndị ikom Joiada, nwa Eliashib, onyeisi nchụaja, onye bụ ọgọ Sanbalat onye Hor.
\b
\p 
\v 29 Cheta ha, Chineke m, nʼihi na ha merụrụ ọrụ nchụaja, na ọgbụgba ndụ ọrụ nchụaja, na nke ndị Livayị.
\b
\p 
\v 30 Ya mere, e doro m ndị nchụaja, na ndị Livayị ọcha, wezugakwa ihe ọbụla nke na-ekwesighị nʼebe ha nọ. E kenyere m ha ọrụ, onye ọbụla nʼije ozi ya.
\v 31 Emekwara m ka a na-ebubata nkụ nke ebe ịchụ aja nʼoge kwesiri, meekwa ka a na-ewebata onyinye mkpụrụ mbụ niile nʼoge ha.
\b
\p Cheta m Chineke, gosi m ihuọma gị.
