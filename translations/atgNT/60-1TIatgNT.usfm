\id 1TI - Okphela 
\h 1 iTimoti 
\toc1 1 iTimoti 
\toc2 1 iTimoti 
\toc3 1 iTimo 
\mt2 Ebe onododẹ ni iPọlu ọ kẹkẹ ghi 
\mt1 ITimoti 
\c 1  
\p  
\v 1 Mhẹmhẹ iPọlu aghiusomhi na kẹẹ ọyi iJesu iKirisiti, rọte omhẹsẹ oyi Ẹshinẹgba ni ọ mie awa pfuese ali iJesu iKirisiti ni ọ khi irudushi ọyawa. 
\p  
\v 2 Mhẹmhẹ mhi kẹkẹ ebe ona ghi iTimoti, ni ọ khi egbegbi omimhẹ elemhi imiesuọ, okhale ali ilẹlemhi ali opfọmhẹ enayi Ẹshinẹgba e ka khi eyẹ.\f + \fr 1:2 \ft Li zẹ \fq Ika 16.1\f* 
\s1 Mhuẹ ẹgbhẹ shi ena osẹsẹ ẹgbhọli egbe 
\p  
\v 3 Mhia nono ni u la ẹoli Efesọsi abi mhi kie kpẹ gueyẹ abi mhi rọ lẹẹ iMasidonia, ni u mẹ asha gueyẹ ẹgbọ eghuo ni e la oobọ ọ sẹsẹ osẹsẹ ẹgbhọli e mu migha.  
\v 4 Gueyẹ wẹ, e tsua okhẹ igbaekẹle oyi ẹgbọ enẹdẹ ali ida-ẹchẹ ku-a ni o khia khi ekhakọ o lẹsẹ rọọ bhale, ẹa ya kpaghiẹ akanya oyi Ẹshinẹgba ni o rọte irudunga bhale obọ.  
\v 5 Emini o zẹ ni a rọ mhẹsẹ omhẹsẹ ona khi, ni a rọ guise inono, ni o rọte udu no pfuasẹ bhale le, ali oni o rọte udu-onete ni ọ gue ọgbọ ẹzọ ali egbegbi irudunga bhale.  
\v 6 Ẹgbọ eghuo e she rọte enana lasele, nyenẹ egbe je ingmemhi afuẹ.  
\v 7 Ẹẹ nono ni wẹwẹ e khi esẹsẹ Ishi eyi iMosisi eyi Ẹshinẹgba, ama ẹa lẹsẹ emini ẹ ngme wẹkhi eri e lẹsẹ emini e ri itoto gẹ ma gue gagaga. 
\p  
\v 8 Awa lẹsẹ khi ushi o ti ini awa guẹ deba li abi awa kha li.  
\v 9 Awa lẹsẹ khi ọa khi itobọ ẹgbọ enete a rọ shi ushi, ama itobọ ẹgbọ ni ẹẹ gbe ushi-a ali ighiatọ ali eni ẹa mhuẹ ulishi Ẹshinẹgba ali ena olamhẹ, ali ẹgbọ ni ẹa lesẹ ugamhi, ni ẹa mu ekpẹ ẹ na emhi eyi Ẹshinẹgba, ali ẹgbọ ni ẹẹ gbe itawẹ ali inyẹwẹ-a, ali ẹgbọ ni ẹẹ gbe ugbeli.  
\v 10 A shi ushi na ẹgbọ okia ali eni nu emọse nabi wẹwẹ ali ikpotso nabi wẹwẹ ẹẹ gbhẹ, ali ẹgbọ ni e muno ẹgbọ ọ dẹ, ali ẹgbọ ni ẹ lo ẹgbhuẹ ali eni ẹẹ pfi ọtsẹlẹ ẹgbhuẹ, ali emhi elese ni ẹa de shi egbegbi osẹsẹ,  
\v 11 ni o khi osẹsẹ ni o de shi usomhi onete oni o mhọli ufumhi oyi Ẹshinẹgba, ni ọ mhọli ikhivọsẹ ni a rọ nga mhẹ obọ. 
\s1 Ikphẹmhi shi ilẹlemhi oyi Ẹshinẹgba 
\p  
\v 12 Mhi kphẹmhi na iJesu iKirisiti Ọnọmhuẹ ọyawa ni ọ ri itoto na mhẹ, ni ọ mẹ khi mhi tẹ ọ ni ọ rọ zẹ mhẹ shi akanya oyọli.  
\v 13 Abi o tseku khia khi ẹghẹghẹ ni o dọsẹ khi mhi pfi unu-a deba Ẹshinẹgba, ali ni mhi i jili ẹgbọ ni e miesuọ, ni mhi nu wẹ khọli, ọọ mhọli ilẹlemhi na mhẹ irari khi umhalẹsẹ ali umha miesuọ o rẹmhẹ li ghọ.\f + \fr 1:13 \ft Li zẹ \fq Ika 8.3; 9.4-5\f* 
\v 14 Ọnọmhuẹ ọyawa ọ ya tutu okhale ku mhẹ. Ọ ri irudunga ali inono na mhẹ ni e khi eyawa irari ikugbe ni awa ali iJesu iKirisiti awa kugbe. 
\p  
\v 15 Egbegbi ungmemhi na, ni awa kha mie shi nya, khi eri iJesu iKirisiti ọ bhale agbọ ya tsumhi ena olamhẹ, ni o khia khi mhẹmhẹ mhi ga khọlọ nẹ nya.  
\v 16 Ama eri Ẹshinẹgba ọ mhuẹ ilẹlemhi na mhẹmhẹ ni ọ khọlọ nẹ ena olamhẹ nya, ni a rọ bhale ya ẹ khi irabọmudu oniẹmhi ni iJesu ọ mhuẹ na mhẹ o khi irọkhọkhọ shi ẹgbọ ni e ke ya mie ọli suọ ọ, ali eni e ya mhuẹ agbọ na agbọagbọ.  
\v 17 Ekpẹ ali ufumhi o khi oyi Oghie na agbọagbọ, ni ọa ya ghu, ni aa ya mẹ, Ẹshinẹgba ni ọ khi ọghuo kpẹ, rọte agbọagbọ ya je agbọagbọ! Atsẹ. 
\p  
\v 18 Yẹyẹ iTimoti omimhẹ, ena e khi omhẹsẹ ni mhi rọ nẹ, ni e de shi abi a li mẹ ekẹ shi ẹ egbe ẹghẹghẹ ni o dọsẹ. Ke ri omhẹsẹ ena gbe akanya, irari khi itsua-okhuẹ e khi nẹ, ni u rọ dobẹ ya khọli okhọli onete,  
\v 19 kie mu irudunga oyẹ ali udu onete ni ọ gue ọgbọ ẹzọ oyẹ mhuẹ. Ẹgbọ eghuo ni ẹa kẹ riẹlẹ emini udu onete ni ọ gue ọgbọ ẹzọ oyẹwẹ o gueyẹ wẹ e riẹlẹ, eri irudunga oyẹwẹ o de guọghọ-a abi ọkọ-okẹ oniẹmhi.  
\v 20 Ẹgbọ enabi eghọghọ iManiusi ali Alẹzada e khi, ni mhi wolọ abọ na ọkphaghiẹ ni ọ sẹsẹ wẹ ingme, ini e khi ke ngme ungmemhi ipfiunu-a deba Ẹshinẹgba. 
\c 2  
\s1 Ugamhi igbaa oyi eni e mie iJesu iKirisiti suọ 
\p  
\v 1 Mhi gueyẹ ẹ, a kpẹ te ododẹ sọ iromhi na ẹgbọ kpa. Abi u liẹ gue emini e to ẹ le, lema Ẹshinẹgba shi ilẹlemhi na wẹ, u kphẹmhi na Ẹshinẹgba na wẹ.  
\v 2 U li sọ iromhi na enighie ali eni ẹẹ mhẹsẹ ni awa, ni e rọ dobẹ ke la agbọ na tsukẹ ali opfọmhẹ, elemhi ekpẹ oyi Ẹshinẹgba rọte iguẹ-ngeli.  
\v 3 Ona oo ti, o ma ri egbe a mu Ẹshinẹgba ọtsumhi ọyawa.  
\v 4 Ni ọọ nono ni ọgbọkpa ọ mhọli imiepfuese, ni ọ gbo lẹsẹ igẹsikia.  
\v 5 Irari khi Ẹshinẹgba ọghuo ọ laọ, ali ọmigha iteva ọgbọ ali Ẹshinẹgba ọghuo, ọmọse ni a lu iJesu iKirisiti.  
\v 6 Ni ọ ri egbọli bhale shi ọtoẹloli, ni ọ rọ mie ẹgbọ nya pfuese. Ona o khi usomhi ni Ẹshinẹgba ọọ nono ni lọli gueyẹ ọgbọkpa ni o guẹ de shi ẹghẹghẹ oyọli.  
\v 7 Ona o zẹ ni a rọ ghie mhẹ abi aghiusomhi na kẹẹ ni iKirisiti ọ zẹ ali ọsẹsẹ oyi iJẹta ni mhi rọ gue usomhi irudunga ali igẹsikia le. A khi ẹgbhuẹ mhia lo, igẹsikia mhia guele.\f + \fr 2:7 \ft Li zẹ \fq 2 iTimo 1.11\f* 
\p  
\v 8 Ini a ye ugamhi, mhia nono ni emọse e tsua abọ ekẹ shi iromhi isọsọ ni ọa mhuẹ elemhi ibibi wẹkhi ekhakọ.  
\v 9 Mhi lili ẹ nono ni eni ikpotso e guẹ ke sọ itsua ni e gbe akanya, a khi khuẹ akhuẹ abamẹmhẹ, wẹkhi iẹ-itsu dọlọdọlọ shi ukhomhi, wẹkhi iri-igolu khuẹ akhuẹ ali ifẹfẹ isọsọ wẹkhi itsua ni e lolo ghalẹ isọsọ.\f + \fr 2:9 \ft Li zẹ \fq 1 iPit 3.3\f* 
\v 10 Ama e ke gbe ikanya enete, ni o ye ni ikpotso ni ẹẹ khi wẹwẹ a ga Ẹshinẹgba ẹ gbe. 
\p  
\v 11 Ikpotso e ke ri iregbe-tiemhile ke ku esọ-a wẹna.  
\v 12 Mhi aa zẹ ọkpotso ni ọ sẹsẹ, wẹ khi eri ọ ya mhuẹ omhẹsẹ shi emọse ukhomhi. Ọ ke tsaghiẹ-a.  
\v 13 Itobọ khi Adamu a kpẹ ma neni a ma Ivu.\f + \fr 2:13 \ft Li zẹ \fq Igbae 2.7,21-22\f* 
\v 14 Ọa khi Adamu ọkphaghiẹ ọ di, ama ọkpotso a di ni ọ gbe ushi oyi Ẹshinẹgba-a.\f + \fr 2:14 \ft Li zẹ \fq Igbae 3.1-6\f* 
\v 15 Ama a ya tsumhi ọkpotso rọte eniyẹ ibiabia, ini ọ kiele ẹ deba irudunga ali inono ali ipfuasẹ, ni ọ rọ mu ekpẹ shi egbọli egbe. 
\c 3  
\s1 Eni ẹ mhẹsẹ elemhi igbaa oyi eni e mie iJesu iKirisiti suọ. 
\p  
\v 1 Oni ungmemhi ona oo gbe akanya gba. Ini ọgbọ ọọ nono ni lọli khi ọni ọ ri ẹloe ẹ khu ẹgbọ eyi Ẹshinẹgba, eminete lọ ni o ghọle ọli.  
\v 2 Ọni ọ ri ẹloe a khu eni e miesuọ ọ mema ya khi ọgbọ ni ọ fu dọsẹ umhaguẹli, ọ khi ọdọ ọkpotso ọghuo, ọ mhuẹ ikuegbe-a, ọ mu ekpẹ shi egbọli egbe, ọ khi ọni a mu ekpẹ a na, ọ mema ya ke kpe abọ mie epfẹse lo apfẹ oyọli le, ọ mema ya dobẹ ke sẹsẹ osẹsẹ.  
\v 3 Ọ khi khi ọdonyọ, wẹ ọgbọ okhọli, ama ọ pfọmhẹ, ọ khi khi ọgbọ uwola, ọ khi nono ingme ukpaghọ dọsẹ.  
\v 4 Ọ mema khi ọni ọ guẹ ri ẹloe ẹ khu ọmhuẹ-apfẹ oyọli. Ọ khi ọni imiọli e mu ekpẹ ẹ na, ẹẹ suọ esọ na li egbegbọ.  
\v 5 Itobọ khi ini ọgbọ ọa guẹ ri ẹloe ẹ khu ọmhuẹ-apfẹ oyọli, se ọli ya dobẹ ri ẹloe khu igbaa oyi eni e mie iJesu iKirisiti suọ?  
\v 6 Ọ khi khi ọni ọ lẹsẹ miesuọ ni odẹ ọa nuẹ ne ini ititiegbe e khi vọ li egbe ni ọ tigbe ya de pfilo epfua nabi ọkphaghiẹ ọ de pfilo.  
\v 7 Ọ mema khi ọgbọ ni ọ mhọli eva onete iteva oyi ena edato, ini ọ khi yẹghẹ-a ni ọ de ya pfilo igha ọkphaghiẹ.\f + \fr 3:7 \ft Li zẹ \fq iTatọ 1.6-9\f* 
\p  
\v 8 Eni ẹẹ kpaghiẹ elemhi owa ugamhi, e khi ẹgbọ ni a mu ekpẹ ẹ na, e khi ẹgbọ ni a ri egbe ẹ nga. E khi khi eni e da onyọ ọ dọsẹ wẹkhi eni ẹẹ li oyamhi ukpaghọ.  
\v 9 E ri udu-onete ni ọọ gue ọgbọ ẹzọ mu igẹsikia ni a rọkhasẹ ni e la irudunga mhuẹ.  
\v 10 A kpẹ mu wẹ fẹ bino, ini o khia khi e gue gbe, a tigbe zẹ wẹ obọ ọ gbe akanya ọni ọọ ga.  
\v 11 Ighuẹwẹ e mema ya mhuẹ ingeli enete. E khi khi eni ẹẹ le ẹgbọ itsa uruli kiakia, e mhọli ayẹmhẹ ni o pfọmhẹ, e khi eni a ri egbe ẹ nga shi emhikpa.  
\v 12 Ọmọse ọkpaghiobọ ọ mema ya khi ọni ọ rue ọkpotso ọghuo shi, ọ khi ọni ọ guẹ ẹ sẹsẹ eniyẹ eyọli odẹ, ọ gue ri ukpẹloe a khu ọmhuẹ-apfẹ oyọli.  
\v 13 Ekpaghiẹ-obọ eni e gue ga, e she rọli mie ashini o mu ẹloe, ali e dobẹ ri igbedu ẹ ngme ingme oyi irudunga oyi iJesu iKirisiti ni e mhuẹ. 
\s1 Osheli ni o la irudunga oyawa 
\p  
\v 14 Aboriẹkhia khi mhi ririẹ mhọli ọli shi udu khi mhi ya kẹlẹ bhale ya binẹ, mhi rọ kie kẹkẹ eni omhẹsẹ ena ghi ẹ. Ẹghẹghẹ aghọ ni a bhale ya ẹ khi,  
\v 15 ini o khia khi mhi tẹsẹ dẹnẹ, ebe ona o ya sẹsẹ ẹ abi o ti ni ẹgbọ e li ke ngeli elemhi ọmhuẹ-apfẹ oyi Ẹshinẹgba, ni o khi igbaa oyi eni e mie iJesu iKirisiti suọ oyi Ẹshinẹgba ni ọ la agbọ. Ikhi igbaa oyi eni e mie iJesu iKirisiti suọ ni o khi ọchẹ ali irọgbekẹ ni a ma igẹsikia nga.  
\v 16 Igẹsikia ni o la osheli oniẹmhi ni o la irudunga oyawa o fu dọsẹ oni ọgbọkhọghuo ọ mhuẹ ekhakọ ẹ shi. 
\q1 IJesu ọ bhale agbọ abi ọgbọ, 
\q2 Ayẹmhẹ ọ rọli khasẹ 
\q2 khi ọ ghọle Ẹshinẹgba, 
\q1 igẹni e mẹ ọli 
\q2 A rọli tsẹ abọ gasẹ 
\q2 ushishi nya, 
\q1 ẹgbọ e mie ọli suọ 
\q2 elemhi agbọ nya 
\q2 a rue ọli nga iloghie. 
\c 4  
\s1 Ena Osẹsẹ ẹgbhọli 
\p  
\v 1 Ayẹmhẹ ọ guele gboo khi, ikpukhokho agbọ, ẹgbọ eghuo e ya tsua irudunga pfi-a. Ẹ deba iyẹmhẹ ni ẹẹ di agbọ, ẹẹ deba osẹsẹ ni ayẹmhẹ ọkphaghiẹ e tsua lasele.  
\v 2 Osẹsẹ eghọghọ, obọ oyi elo-ẹgbhuẹ ena ikokoalo e te ẹ bhale, eni udu-onete ni ọ gue ọgbọ ẹzọ oyẹwẹ o she ghua dishi.  
\v 3 Ẹgbọ eghọghọ ẹ sẹsẹ ẹgbọ e khi rue ọkpotso, eni ikpotso e khi ye ughuẹ, e gueyẹ wẹ e khi ke le eminale eghuo. Ama eri Ẹshinẹgba ọ ma eminale eghọghọ, eni e miesuọ ni e lẹsẹ igẹsikia e ke ri ikphẹmhi mie wẹ le.  
\v 4 Emhikpa ni Ẹshinẹgba ọ ma o ti, a khi mẹ emini a kie, ama a ke ri ikphẹmhi mie emhikpa.  
\v 5 Irari khi ungmemhi oyi Ẹshinẹgba ali iromhi isọsọ a rọ rẹwẹ ẹ shi eni e pfuasẹ. 
\p  
\v 6 Ini u ri oni omhẹsẹ ona na eni e miesuọ, u ya khi ọni ọ guẹ gbe akanya ugamhi ọyi iJesu iKirisiti, ni a kuẹlẹ vule rọte igẹsikia na irudunga ali osẹsẹ enete ni u wa deba.  
\v 7 Khi mhọli emini u ri okhẹ oyi ẹgbọ nẹdẹ, ali okhẹ ikpotso egbhali ẹ riẹlẹ. Ke ngeli riẹlẹ ọghuẹmhẹ oyi Ẹshinẹgba.  
\v 8 Inisegbe-a o mhọli ukuku eminete ni o riẹlẹ a na ọgbọ, ama ni a rọ suọ esọ na Ẹshinẹgba, eri o ti odẹkhodẹ, itobọ khi o mhọli ishobọ na awa memena ali agbọ ni o ke ẹ bhale. 
\p  
\v 9 Ungmemhi igẹsikia na ni o ti ni a mieshi, ni a gbo lama shi ọ.  
\v 10 Onana o ri anye rọshẹka a gbe akanya egbegbọ, irari khi awa she ri irudushi oyawa shi Ẹshinẹgba obọ, ọni ọ laọ ni ọ khi Ọmiepfuese ọyi ọgbọkpa, eni e miesuọ kpaashi. 
\p  
\v 11 Mhẹsẹ, u gbo sẹsẹ ena nya.  
\v 12 Khi zẹ ni ọgbọkhọghuo ọ ri ẹloe gbe ẹ irari khi ozele u khi, ama rọte ungmemhi oyẹ, ali agbọ oyẹ, ali inono oyẹ, elemhi irudunga ali ipfuasẹ oyẹ khili irọkhasẹ na eni e miesuọ.  
\v 13 Ya ramhi ẹghẹghẹ ni mhi rọ ya bhale, ri ẹloe shi ọ kie ke zẹ Ebe-no-pfuasẹ khasẹ igbaa, u kie le ẹ tse-abọ oni ungmemhi, wa sẹsẹ wẹ.  
\v 14 Khi ri obọ gbe isomhopfa ni Ẹshinẹgba ọ rọ nẹ nyẹ. Oni a rọ nẹ abi a rọ mekẹguele shi ẹ egbe ali abi eni egbhali e rọ ri abọ ngẹ egbe. 
\p  
\v 15 Ke ri ẹloe shi eni emhi ena egbegbọ, u ri egbe ẹ na wẹ pfo ni ẹgbọ nya e ke mẹ ije-odalo oyẹ.  
\v 16 Ri ẹloe shi egbe ẹ egbe ali osẹsẹ oyẹ. Kie ke riẹlẹ emhi ena, irari khi ini u wa lighọ u ya tsumhi egbe ẹ ali eni ẹ suọ ẹ. 
\c 5  
\s1 Abi ẹẹ a ke li esamhi-olimhi, ali egbhali ali ighumha 
\p  
\v 1 Khi dese ọgbhali, ri ipfọmhẹ uruli nu ọli ngme abinẹ khi itẹ ọ khi. Ke riẹlẹ deba ozele abinẹ khi inyọghuo ẹ u ngeli ẹ deba.  
\v 2 U riẹlẹ deba ikpotso eni egbhali abinẹ khi inyẹ e khi. Ke ngeli deba ozele ikpotso abi inyọghuẹ ni ikpotso. 
\p  
\v 3 Khi ri ẹloe gbe esamhi-olimhi ni e khi esamhi-olimhi egbegbọ, ni e mhọli ọtomhẹ.  
\v 4 Ini ọni ọsamhi-olimhi ọ bia eniyẹ, o ke khia khi ọ mhuẹ imimi, eni eniyẹ e kpẹ ke ri emini e wẹna imiesuọ gbe akanya, abi e li ri ẹloe ẹ khu ọmhuẹ-apfẹ oyẹwẹ. Ini e lina, eri ẹ fẹli eni e bia wẹ ali itita wẹ eghọ, irari khi onana o ma ri egbe a mu Ẹshinẹgba.  
\v 5 Ọni ọ khi ọsamhi-olimhi igẹsikia ni ọa ke ye ughuẹ, ni lọlighuo ọ la, ọ she regbenga Ẹshinẹgba, ọ sọ iromhi ẹ mhila li ikpaghiobọ obọ, ẹlẹọguota ali ẹlẹ iyọsẹ.  
\v 6 Ama ọsamhi-olimhi ni ọ ri egbọli shi aruele agbọ, ọ she ghu-a ini ayẹmhẹ oyọli o kie tseku laọ.  
\v 7 Mhẹsẹ enana na wẹ ini a khi mẹ gue shi wẹ egbe.  
\v 8 Irari khi ini ọgbọ ọa ri ukpẹloe khu ena ọmhuẹ-apfẹ oyọli, tete imi ọli ali ughuẹ ọli, ọ she kie oni irudunga. Ọ khọlọ dọsẹ ọni ọa miesuọ. 
\p  
\v 9 Khi kẹkẹ eva oyi ọsamhi olimhi kuma eva eyi esamhi-olimhi sẹ ni ọ she dọsẹ ikpe egbhuẹsẹ, ọni o khia khi utoghuo-kpe ọ kpẹ lẹsẹ ye ughuẹ.  
\v 10 Ọ khi ọni a suọ eko shi ikanya enete, ọkpotso ni ọ guẹ kuẹlẹ imiọli. Ni ọ mie epfẹse ẹ shi owa. Ọ guẹ a gbe ikanya deba eni e miesuọ, ni ọọ kpaghiẹ ẹgbọ ni e la ọmunu obọ ni o ri egbọli shi onete ọdọda iriẹlẹ. 
\p  
\v 11 Ama khi ri eva oyi ozele esamhi-olimhi shi ebe. Irari khi ini ọghuẹmhẹ idiegbe oyẹwẹ o nga wẹ ukhomhi le dọsẹ ugamhi ni ẹ ga iKirisiti, e vu ya ngeli.  
\v 12 Eri e rọte aghọ lue, irari khi e she gbe irọnga ni e kpẹ te ekẹ rọ nga ni iKirisiti-a.  
\v 13 Ẹgbọ ọwaza e khi ni ẹẹ kia ifui owa. Oni o khọlọ nẹ nya khi ẹẹ le ẹgbọ itsa uruli kia kia, ẹẹ sọnọ unu ingme ni aa fẹ lu wẹ shi, ẹẹ ngme ungmemhi ni ẹa kha ngme.  
\v 14 Itobọ ighọ, ọ ghọle mhẹ ni ozele isamhi olimhi e ye ughuẹ, e bia eniyẹ, e ri ẹloe ẹ khu ọmhuẹ-apfẹ oyẹwẹ. Ini awa khi ri ẹghẹghẹ na ebe awa mẹ asha yese awa eva-a.  
\v 15 Eni esamhi-olimhi eghuo e she lase odẹ oyi iKirisiti le deba ọkphaghiẹ.  
\v 16 Ama ini ọkpotso ọkhọghuo ni ọ miesuọ ọ mhuẹ ọsamhi-olimhi she unuẹkpẹ oyọli, ọ mema ya ke ri ẹloe khu ọli, ọ khi rue ọli ghi igbaa oyi eni e mie iJesu iKirisiti suọ ke tsua, ni e dobẹ ri ẹloe ke khu eni e khi egbegbi esamhi-olimhi ni e mhọli ọtomhẹ. 
\p  
\v 17 A ke fali eni egbhali ni e ri igbaa oyi eni e mie iJesu iKirisiti suọ ẹ kia ni e guẹ gbe akanya egbegbọ ifata agbhagbhamhi eva, tete eni e mema lolo toto obọ itse-abọ ali osẹsẹ ungmemhi oyi Ẹshinẹgba.  
\v 18 Irari khi ebe ọ ngme ọli, u khi gẹ ena unu ini u rọli ẹ kpishi ikpamhi emhi. A ke fali egbakanya ifata eyẹwẹ.\f + \fr 5:18 \ft Li zẹ \fq iDẹut 25.4; iMat 10.10; iLuk 10.7\f* 
\v 19 Khi rọli shi egbegbi ingme ini ọgbọghuo a bhale ya ngme ingme shi ọgbhali egbe, se ini e gbe aava okekhi aasẹ.\f + \fr 5:19 \ft Li zẹ \fq iDẹut 17.6; 19.15\f* 
\v 20 La odalo ẹgbọ kpa ke dese eni e lamhẹ ni o tse agua ye enekpọle. 
\p  
\v 21 Mhi la ukpẹloe onayi Ẹshinẹgba ali iJesu iKirisiti ali oyi igẹni ni e pfuasẹ mhẹsẹ nẹ, u ri omhẹsẹ ena gbe akanya, khi rọte ode oshili wẹẹ azẹba riẹlẹ emhikhọghuo. 
\p  
\v 22 Khi tigbe kẹlẹ ri obọ nga ọgbọ egbe rọli nga akanya ugamhi oyi Ọnọmhuẹ, u khi ya nu ọli mhuẹ okemhi shi olamhẹ oyi ọli. Ri egbe ẹ shi ipfuasẹ. 
\p  
\v 23 Khi ke da amẹ tsẹẹ, ama ke da ukuku onyọ ni eminale e kẹlẹ ke daghiẹ-a shi ẹ elemhi, abi ọ rọ khia khi u ma kẹlẹ ẹ ghua eghọ. 
\p  
\v 24 Eri a ga ẹgbọ eghuo zu olamhẹ eyẹwẹ, neni a rẹ ramhi iguẹzọ, ama olamhẹ oyẹ ẹgbọẹse ẹlẹlese e ya lasele.  
\v 25 Ighọ a liẹ mẹ ikanya enete gboo. Shi eghuo ni aa ya mẹ memena, ẹa ya sheli okhẹse. 
\c 6  
\p  
\v 1 Eni e khi ighumha e ke ri ekpẹ na ega eyẹwẹ ẹghẹghẹkpa ini ọgbọkhọghuo ọ khi zẹ ẹmuẹbe na eva oyi Ẹshinẹgba ali osẹsẹ oyawa.  
\v 2 Ighumha e khi ri ẹloe gbe ega eyẹwẹ ni e miesuọ, ni e mhọli wẹ, irari khi inyọghuo egbe e ga khi ni ẹẹ deba iKirisiti, ọni iKirisiti ọ nono ingme oyẹwẹ. Ochoghọ e ke ga wẹ dọsẹ abi e kpẹ li a ga wẹ, Eni ingme ena e khi eni u ya ke sẹsẹ wẹ, u gbo rẹwẹ ẹ ye wẹ ude. 
\p  
\v 3 Ọgbọ ni ọ da sẹsẹ osẹsẹ olese ne, ọa lama shi egbegbi osẹsẹ oyi iJesu iKirisiti Ọnọmhuẹ oyawa ali ugamhi oyawa,  
\v 4 eri itipfuabọ-nga o she vọ li egbe ni ọa ke lẹsẹ emhikhọghuo. Ọ mhuẹ ọghuẹmhẹ obe na ekhakọ ali uwola shi ingmemhi ni ẹẹ pfi ofuma ali uwola ali itsue ali irẹloeviọba.  
\v 5 E gbolo ẹ pfi ekhakọ shi iteva ẹgbọ ni isamhi udu oyẹwẹ ọa ya gbe akanya te odẹ, ni igẹsikia o she wa wẹ-a. Eri ẹ dabi khi ugamhi khi ẹpfue a rọli ẹ nono. 
\p  
\v 6 Egbegbọ lọ khi ugamhi o ri ọgbọ ọ mhuẹ ẹpfue egbegbọ, o ri emini u mhuẹ khuese ẹ.  
\v 7 Irari khi awa a kpẹ tsua emhikhọghuo bhale agbọ ona. Ighọ awa a li rọte agbọ ya tsua emhikhọghuo vu.  
\v 8 Irari onana, ini awa da mhuẹ eminale ali itsua na sọ ne, o khuese awa.  
\v 9 Ama eni ẹ nono ni wẹwẹ e pfue eri ẹẹ de pfilo imufẹ ali igha ali ọghuẹmhẹ eyi ọyẹghẹ ni ẹ kuale ọgbọ utse, ni o pfi ẹgbọ pfilo epfua ali oyese.  
\v 10 Irari khi rọte oyamhi ukpaghọ iwali onobe nya e te ẹ zẹ lasele. Ẹgbọ eghuo e she kphakpha egbe ini e mhuẹ ikpaghọ, ni o she rẹwẹ kia lase odẹ irudunga le. E she ri ebubu oya yese egbe wẹ udu-a. 
\s1 Agbọ ni o ti ni ọni ọ miesuọ ọ la 
\p  
\v 11 Ama yẹyẹ Ọmọse ọyi Ẹshinẹgba, ti egbe emhi enana nya le, na ke khu ipfuasẹ, ali iriẹlẹ emini o ti Ẹshinẹgba ẹloe, ali irudunga, ali inono, iregbemie ali angeli ipfọmhẹ.  
\v 12 Ga ri itoto eyẹ nya na unamhi oni irudunga oyẹ, ni u mie eleli agbọ na agbọagbọ. Itobọ khi oni agbọ onana Ẹshinẹgba ọ lu ẹ shi abi u rọ pfi ọtsẹlẹ shi irudunga oyẹ odalo ebubu ẹgbọ.  
\v 13 Odalo oyi Ẹshinẹgba ni ọ ri agbọ na emhi nya ali odalo oyi iJesu iKirisiti, ni ọ pfi ọtsẹlẹ odalo iPọtiusi iPaleti, mhi la mhẹsẹ nẹ ena,\f + \fr 6:13 \ft Li zẹ \fq iJọn 18.37\f* 
\v 14 u ri omhẹsẹ enana gbe akanya, ri igẹsikia mu wẹ mhuẹ gbaa ya ramhi ẹlẹ ni iJesu iKirisiti Ọnọmhuẹ oyawa ọ rọ ya bhale.  
\v 15 Ọni ibhale oyọli o ya tsẹ shi ẹghẹghẹ ni Ẹshinẹgba ọ mhẹsẹ ọli shi te, lọli ọ khi Oghie ọghuo kpele ni a khivọsẹ na, Oghie ọyi ighie nya, ali Ọnọmhuẹ ọyi ekhẹmhuẹ nya.  
\v 16 Lọlighuo kpele ọ lẹsẹ la ọ lẹ agbọagbọ. Eri ọ la ákpá ni ọgbọkhọghuo ọa gbudu a ti mama. Ọni ọgbọkhọghuo ọa mẹ ghuẹ wẹkhi eri ọgbọ tigbe dobẹ ya mẹ ọli ghue. A ri ufumhi ali ekpabọ oniẹmhi nali. Atsẹ. 
\p  
\v 17 Mhẹsẹ na ẹgbọ ni e pfue shi elemhi agbọ ona, e khi ke ti-ipfuabọ nga, a e khi ri udu shi ẹpfue ni ẹa zẹ ri egbe ẹ da, ama e mhuẹ irudushi na Ẹshinẹgba ni ọ ri emhikpa somhi awa opfa tuọ, awa rọ ke li agbọ.  
\v 18 Mhẹsẹ na wẹ e ke riẹlẹ onete, e khili eni e pfue shi elemhi onete iriẹlẹ, e ke somhi ẹgbọ opfa, e ke rọte emini e mhuẹ rue obọ-a.  
\v 19 Ini e da li na ne, e ya ti ẹpfue ma na egbewẹ abi irọgbekẹ ni o migha, elemhi agbọ ni ọọ bhale, ni e la agbọ ni Ẹshinẹgba ọ nono ni e la. 
\p  
\v 20 ITimoti, ri ẹloe khu emini a rọ shi e obọ. Khi kuma ingmemhi ni ẹa khi eyi Ẹshinẹgba ali ekhakọ eyẹghẹ ni ẹgbọ eghuo e ri ẹgbhọli ẹ lu ilẹsẹ,  
\v 21 ni ẹgbọ eghuo e deba ni o rẹwẹ lase odẹ irudunga oyẹwẹ le. 
\p Okhale oyi Ẹshinẹgba o ka nu ẹẹ nya la.