\li1 
\v 22 namoonni Netoofaa 56,
\li1 
\v 23 namoonni Anaatoot 128,
\li1 
\v 24 namoonni Azmaawet 42,
\li1 
\v 25 namoonni Kiriyaati Yeʼaariim, kan Kefiiraatii fi Biʼeeroot 743,
\li1 
\v 26 namoonni Raamaa fi Gebaa 621,
\li1 
\v 27 namoonni Mikmaas 122,
\li1 
\v 28 Namoonni Beetʼeelii fi Aayi 223,
\li1 
