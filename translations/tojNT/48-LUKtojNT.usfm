\id LUK
\h SAN LUCAS
\toc1 Ja Loil It Jel Tzamali Ja Jastal Stz'ijba Can Ja San Lucasi
\toc2 SAN LUCAS
\toc3 Lc.
\mt1 El Santo Evangelio Según San Lucas
\mt2 Ja Loil It Jel Tzamali Ja Jastal Stz'ijba Can Ja San Lucasi
\c 1
\s1 Ja Lucasi stz'ijba ja Teófilo
\p 
\v 1 Lec ay Teófilo, ay jitzan ja ma' yaunej xa sbaje ba xchojlal oj stz'ijbaye ja jastal ec' cujticoni.
\v 2 Oj ni ch'ac ya ochuque juun ja jastal ni yala cabticon ja ma' mero yilahue ja Cajualtiqui desde ora jau q'ue ja yateli. Ja yenlei cho sloiltaye ec' ja yabal ja Diosi.
\v 3 Jach ni ja quen chomajquili. Como jc'ana ta yi lec sc'ujol ja ma' huas snaa, jach ni ja huen Teófilo, xchojlal oj tz'ijba hui,
\v 4 Ti oja huil que oj slaj sbaj soc ja jas jeubal ni ahuii.
\s1 Jun ángel jac yal que oj manxuc ja Juan it yaa bautismo
\p 
\v 5 Ja loil iti ja' to q'ue ja tiempo yora ay yatel ja rey Herodesi, ja ma' ay yatel ja ba Judea. Jaxa tihui cho ay jun pagre sbiil Zacarías. Ja yeni, ja' cuenta ay soc ja scuagriya ja Abiasi. Jaxa xcheumi sbiil Elisabet, ja' ni ja yintil ja Aaroni.
\v 6 Jun xta yabale jel toj aye ja ba sti sat ja Diosi. Mi ni modo huax taji smulea. Huas sc'uane spetzanil ja smandar ja Cajualtiqui. Yib c'abal ni aye soc ja Diosi.
\v 7 Pero mey yuntiquile yuj ja mi ni nunca yila unticanel ja Elisabeti. Soc meum tatame xa.
\v 8 Pero jun c'ac'u, como ja' ni xchol ja scuagriya, ja Zacarías aaji och pagreil ja ba sti sat ja Diosi.
\v 9 Como jach ni culan yujile ja spagre ja judio jumasa, huas staahue ja ma' oj och stzic ja pom ja ba yoj stemplo ja Cajualtiqui. Jaxa Zacariasi yen co xchol.
\v 10 Jun c'ac'u spetzanil ja cristiano ti aye ba fuera. Huane sc'umajel ja Diosi cuando huan tzicxel ja pomi ja ba yojol ja templo.
\v 11 Ja Zacariasi, huaj to yile, tey jun yangel ja Cajualtiqui. Jaxa ángel jahui ti tec'an ec' ba lado stojol sc'ab ja ba mero bay ja tzicupomi.
\v 12 Jaxa Zacariasi, huego huego c'umbi yoc sc'ab ja yajni yila. Jel och juntiro ja spensari.
\v 13 ―Zacarías, mi la xihui. Ja huaxa c'uman ja Diosi, abunubal. Jachuc ja Elisabet ja hua cheumi, oj to sman jun yal jaxa yal alatz jahui, Juan oja huaa yi ja sbiili.
\v 14 Jaxa hueni oj chaanan yuj ja hua gusto. Jaxa cristiano jumasa, jel oj gustoaxuque juntiro cuando huax yilahue ja yal alatzi.
\v 15 Ja alatz jahui jel nihuan oj huajuc ja ba sti sat ja Diosi. Mi oj yu ja yaalel tz'usubi ja ba paj xa soc mi ni ja jas huax yaa yacbeli. Desde ora oj jul xchonjeli, ti ni oj ajyuc ja ba sc'ab ja Espíritu Santo.
\v 16 Soc mi quechanuc ja iti. Yuj ja yeni, jitzan ja israeleño jumasa oj cumxuque soc ja Cajualtic Diosi.
\v 17 Jaxa yal ahuunin oj ni manxuqui, yen bajtan oj ya q'ueuc ja ateli, ti xa oj q'ue stul ja yatel ja Cajualtiqui. Pero ja hua Juani, ja' ni oj stul ja smodo ja aluman‑Dios Eliasi. Ja jastal jel tzatz ec' ja Eliasi, jach oj huajuc ja yeni. Oj ya culan yi sc'ujol ja tatal soc ja yuntiquili. Jachuc ja ma' mix c'ocxi, oj ni ya c'ocxuca. Oj ya stul ja smodo ja ma' toji. Jaxa cuando huax jac ja Cajualtiqui, yaa ta ni chapxuc lec ja sc'ujol ja cristiano jumasa, xchi ja angeli.
\v 18 ―Pero mix naa ta meran ja jastal iti, xchi ja Zacariasi. ¡Pe tatamon xa ni taca! Soc jach ni ja jcheumi, meum xa, xchi.
\v 19 ―¿Huan ama xa huala ta mi Gabrielucon ja queni? Ti ni ayon ja ba sti sat ja Diosi, pero jecubalon ahui ba oja huab ja abal it jel tzamali.
\v 20 Pero ja yaani, mudo oj canan. Mi oj bob c'umanan masan to oj c'otuc ja iti yuj ja mi ac'uan ja jas cala huabi, x'utji. Pero ja jas cala huabi, ti oja huil ta mi oj ni c'ot smeranila, xchi ja angeli.
\v 21 Jaxa cristiano jumasa huane xta smajlajel ja Zacariasi pero jel och ja spensare yuj ja jel xa albi ta jan ja ba yoj templo.
\v 22 Jaxa Zacariasi, cuando el jani, mi xax bob c'umanuc. Ti jac sc'ujole ja cristiano que ay jas snajsatin ja ba yojol ja templo. Quechan seña huas sea yuj ja mi ni modo huax bob eluc ja sc'umali.
\v 23 Yajni tz'icui ja sc'ac'u ja yatel ba yoj templo, ti xa huaj ja ba snaj ja Zacariasi.
\v 24 Ja ec' ja c'ac'u jumasa jahui, jaxa xcheum Elisabeti ti xa tucbia. Joe ixau mi ni jun parte el ja ba snaji.
\v 25 Ti yala ja Elisabeti: ―Ja yaani c'ot ni ja c'ac'u oj ya ec' qui ja jq'uixol ja ba sti sat ja cristiano ja Cajualtiqui. Como yena ni yaunej qui ja jastal ayoni, xchi ja Elisabeti.
\s1 Jun ángel jac yal que oj manxuc ja Jesusi
\p 
\v 26 Jaxa ba suaquil ixahui ja ángel Gabrieli cho jecji otro vuelta yuj ja Diosi ba jun yal chonab, Nazaret sbiil, ja' ni sbaj ja lugar Galilea.
\v 27 Jaxa ba chonab jahui, ti och ba jun naitz, jaxa ba naitz jahui, ti ni ay ja soltera jau ja smacben ixuc jun huinic sbiil José. Jaxa José ja' yintil ja rey David sbaj najatei. Jaxa soltera jahui, María sbiil.
\v 28 Huaj to yil ja María, huaj aajuc yi Dios yuj ja ángel ja bayi. Ti yalaa: ―María ja hueni mero tzaubala yuj ja Cajualtiqui. Ti ni ay amoc ja yeni. Ja ba spetzanil ja hua moj ixuquili, quechan ja huen tzaajiya. ¡Jel lec xa huila! x'utji.
\v 29 Pero ja María jel juntiro och ja spensar ja cuando ch'ac yab jastal alji yabi. ―¿Jastal ay ja it ba? xchi.
\v 30 ―Mi la xiu María. Jel lec huala ilji yuj ja Diosi
\v 31 Jayuj ja yaani oj xa tucban. Oj ni aman jun yal aquerem. Oja huaa yi sbiiluc Jesús,
\v 32 Jaxa yeni jel nihuan oj huajuc. Oj ni aljuc que ja' ni yunin ja Dios ja ma' jel nihuani, jaxa Cajualtic Diosi oj aajuc yi ba oj sc'ul mandar ja jastal sc'ulan mandar ja rey Davidi ja yen ja ma' ec' pax ta huujilexi.
\v 33 Oj cho sc'ul mandar ja israeleño jumasa spetzanil ja tiempo. Mi ni nunca oj eluc ja yateli, xchi ja angeli.
\v 34 Jaxa María ti yalaa: ―¿Jastal ay ba? ¡Pero mey jtatam ja quen tac! xchi.
\v 35 Ti yala ja angeli: ―Meyuc pero ja Espíritu Santo oj jac amoc ja huen. Quechan yuj ja yip ja Dios jel nihuani, jayuj oja man ja hua huali. Jaxa alatz oj manxuqui, mi ni jun smul ay pero oj ni aljuc que yunin Dios nia.
\v 36 Jach ni ja hua huatz Elisabeti, ja yeni tucbi ta, iday, ay xa sc'ujol. Ja' xa sbaj suaquil ixau ja huego, iday, spetzanil ja cristiano huas snaa que mi xa ni oj yil unticanela.
\v 37 Porque ja Diosi mi jas mi oj bob sc'uluc, xchi ja angeli.
\v 38 ―Pues lec ba, como ti ni ayon ja ba sc'ab ja Cajualtiqui. A sc'ul qui ja jas huaxa huala, xchi ja María. Jaxa angeli ti huaja.
\s1 Ja María huaj yulata ja Elisabeti
\p 
\v 39 Ja mismo c'ac'u jumasa jahui ja María ti huaj ja ba jun hacienda, ja' ni sbaj Judá, jaxa hacienda jahui, ti ni ay ba huitz.
\v 40 Ti och c'ot ja ba snaj ja Zacariasi. Ti yaa yi Dios ja Elisabeti.
\v 41 Ja Elisabeti, cuando yab aaji yi Dios yuj ja María, jaxa alatz ti to ni cuchan yujili snica sbaj juntiro. Ja Elisabeti ti iiji majan ja sti yuj ja Espíritu Santo, ti yalaa:
\v 42 ―Ja ba spetzanil ja hua moj ixuquili, quechan ni ja huena tzaubala ni leca, jaxa alatz oj to amani, t'ujpinubal ni ahuiaj.
\v 43 Iday, ¿janec'on to ni ja queni? Ja huena ni snana ja Cajual tac, iday, quen huax jac ahuilon.
\v 44 Quechan pavor cab ach'ac ahuaa qui Diosi, jaxa jastal ayoni, tzatz juntiro snica sbaj yuj ja sgusto.
\v 45 Jel lec oj ec' ahuuj yuj ja hua c'uani porque ja jastal alji ahuabi yuj ja Cajualtiqui, oj ni c'ot smeranila, xchi ja Elisabeti.
\v 46 Jaxa María ti yalaa:
\q1 Ja ba jc'ujoli jel juntiro huax toyo ja Cajualtiqui,
\q1 
\v 47 Jaxa caltzili jel alegre ay yuj ja Dios ja jColtanumtiqui.
\q1 
\v 48 Ja queni ja' ni jmoj ja tz'iileli. Jel ajul ja jbaj, pero stalna ni ja jyaujulali. Ja yaani lamlamil oj toyjucon
\q1 
\v 49 Yuj ja jel nihuan ja jas sc'ulan qui ja ma' jel ja yipi. Ja sbiili mi cualquierauc.
\q1 
\v 50 Lamlamil huas stalna ja syaujulale ja matic huax xiu yuji.
\q1 
\v 51 Seunej jastal ja yipi. Ch'ac ya huaj sactantan ja ma' huas stoyo sbaj ja ba sc'ujolei
\q1 
\v 52 Soc huax ch'ac sap yi ja yatel ja ma' jel tzatz ayi, jaxa ma' jel ch'in ayi, huax ya nihuanbuc.
\q1 
\v 53 Ja ma' jel huain xyabyei, ya but'uc soc ja jas jel lequi, jaxa rico jumasa, telan sc'ab ch'ac sec ele.
\q1 
\v 54 Ja yatjum jumasa ba Israeli cho scolta ja jastal ni yala que oj bi stalna syaujulalei.
\q1 
\v 55 Mi ch'ay sc'ujol ja Abrahami soc spetzanil ja yintil ja janec' oj to manxuqui. Sc'ulan ta ni ja jastal yalunej yab ja ma' ec' pax ta cujtiqui,
\m xchi ja María.
\v 56 Ja María ti can soc ja Elisabet mojan oxe ixau, ti xa cumxi ja ba snaj ja el ja oxe ixau jahui.
\s1 Manxi ja Juan ja ma' yaa bautismo
\p 
\v 57 Ja Elisabeti cuando tz'icui ja balune ixau ja xchameli, ti smana jun yal querema.
\v 58 Jel gustoaxi yajni yila sat ja yal squeremi. Jach ni ja svecino jumasa soc ja yermano jumasa, cuando yabye yabalil jastal jel talnaji syaujulal yuj ja Diosi, jel gusto yabye juntiro.
\v 59 Ja ay xa yioj huaxaque c'ac'u ja yal alatz jahui, ti jacye ba oj sc'uluque circuncidar ja jastal culan yujilei. Jaxa mismo ora jahui, ti sleahue ja sbiili. Ti yalahue que oj bi yaahue yi sbiiluc Zacarías, como jach ni sbiil ja stata.
\v 60 Jaxa snani ti yalaa: ―Miyuc, oj sbiiluc Juan, xchi.
\v 61 ―¿Jasyujil? Pero mi ni june ja hua huermano ay sbiil ja jastal iti, xchiye.
\v 62 Ti sobohue yi ja stati jastal huas sc'ana yaa yi ja sbiili pero soc seña sobohue.
\v 63 Jaxa yen ja Zacariasi ti sc'ana jun yal aq'uintea. Ti och stz'ijbaa, jaxa cuando yilahuei, Juan oj yii ja sbiili, xchi ja ba stz'ijbai. Jaxa smoj jumasa jel juntiro och ja spensarei.
\v 64 Ja mero ora jahui ti jamxi ja sti ja Zacariasi. Juntiro claro el ja sc'umali. Jel stoyo ja Diosi.
\v 65 Juntiro och xihuele spetzanil ja svecino jumasa. Jaxa spetzanil ja matic tey ba huitz ba Judea, huego huego ch'ac yabye jastal huaji.
\v 66 Jaxa matic ch'ac yabi, huan xta tz'iptz'unuc ja sc'ujolei: ―¡Saber jastal oj huajuc ja alatz it ja mas tzaani! xchiye. Jaxa yal querem jahui ti ni ay ba sc'ab ja Cajualtiqui.
\s1 Ja Zacariasi jel yaa yi stz'acatal ja Diosi
\p 
\v 67 Jaxa Zacarías ja stat ja alatzi, ti iiji majan ja sti yuj ja Espíritu Santo, ti yalaa:
\q1 
\v 68 Stz'acatal lec ja Cajualtic Dios sbaj Israeli. Yaunej sc'ujol ja yuntiquili. Jac yaa sbaj ba oj ya el libre ja matic yaunej sbaj ja ba sc'abi
\q1 
\v 69 Soc cho seca quitic jun jColtanumtic jel ja yipi, ja' ni yintil ja rey David ja yatjum ja Diosi.
\q1 
\v 70 Seca ni ja jastal huan yaljel desde najate lec cuando yora yiaj majan ja sti ja yalumani, ja it mi cualquierauqui.
\q1 
\v 71 Yala jastal oj coltajucotic ja ba sc'ab ja jcondratiqui soc spetzanil ja matic coraja xta huax yilahuotiqui.
\q1 
\v 72 Oj ni bi stalna syaujulal ja matic ec' pax ta cujtiqui soc oj ni snaa ja trato jau mi cualquierauqui.
\q1 
\v 73 Jach ni alji yab ja Abraham ja ma' ec' pax ta cujtiqui. Jach ni bi oj sc'ul quitic ja Diosi.
\q1 
\v 74 Oj ni sc'ulucotic librar ja ba sc'ab ja jcondratiqui cosaque jachuc mey xihuel oj cateltatic ja Diosi.
\q1 
\v 75 Mi xa bi sbejuc oj lee ja jmultiqui. Toj bi oj ajyucotic ja ba sti sat ja Diosi spetzanil ja tiempo oj ajyuc ja jsac'aniltiqui.
\q1 
\v 76 Jaxa huen alatz, oja biiluc Yalumanil ja ma' jel nihuani. Ja huen bajtan oja hua q'ue ja ateli, ti xa oj cho stul ja Cajualtica. Ja jastal huax jamxi ja bej cuando oj jac ja ma' ay yateli, jach oja huaa puesto ja sc'ujol ja cristiano ja cuando huax jac ja Cajualtiqui.
\q1 
\v 77 Oja jee yi ja yuntiquili jastal oj coltajuque soc jastal oj c'ulajuque librar soc ja smulei.
\q1 
\v 78 Ja jDiostiqui jel juntiro huas stalna ja jyaujulaltiqui. Yaunejotic sc'ujol. Seca con quitic ja yunin ja ba satq'uinali ba oj yaa quitic jun yajc'achil jvidatic.
\q1 
\v 79 Jach sc'ulan quitic yuj ja ti ni ayotic ba yoj q'uiq'uinali, como paan jac'anotic xta ni yuj ja chamel ch'aquela. Ja jDiostiqui oj ni ya quiitic ic'a soc oj ya elcotic ja ba q'uiq'uinali. Oj ni yaa quijlabtica.
\m Spetzanil ja jastal jahui, jach ni ch'ac yal ja viejito Zacariasa.
\v 80 Jaxa yal querem Juani q'uii. Jel tzatz ay soc ja Diosi. Cuando nihuan xa, ti ajyi ja ba jun lugar ba mi aayuc ja suinquili, jaxa mas tzaani, ti xa q'ue stul ja yatela. Ch'ac sloilta yab ja israeleño jumasa ja yabal ja Diosi.
\s1 Manxi ja Jesusi
\r (Mt. 1:18‑25)
\c 2
\p 
\v 1 Ja c'ac'u jumasa jahui ti yaa jun orden ja ma' ay yatel, Augusto César sbiil. Spetzanil ja cristiano oj bi ch'ac ochuque juun.
\v 2 Ja censo iti ja' ni ja sbajtanil censo sc'ulan cuando och yatel ja huinic Cirenio sbiil, ja ba lugar jau Siria.
\v 3 Jaxa cristiano ti huajye spetzanilea. Cada cristiano pilan pilan ja smunicipioei, chican bay ja xchonabile ja ma' ec' pax ta yujilei. Ti ni huajye ba oj ochuque juuni.
\v 4 Ja José ti culan ba Nazaret, ja' ni sbaj lugar Galilea. Ti huaj ja ba xchonabil ja rey Davidi, Belén sbiil, ja' ni sbaj Judea. Ti huaj ja tihui yuj ja ja' ni yintil ja José ja rey Davidi.
\v 5 Huaj ba oj ochuque juun soc ja María ja smacben ixuqui. Jaxa yeni mi xa lecuc ay.
\v 6 Cuando ti aye c'ot ja tihui, ja' xa ni ti tz'icui ja c'ac'u oj tojbuqui.
\v 7 Ti smana ja sbajtanil yali. Sbech'a soc jun c'uutz, ti yaa baan ba jun pesebre ja ba huax maconi ja huax huaa ja chantei. Ti yaa ja tihui yuj ja mi xa ni staahue majan ja sijlubei.
\s1 Ja ángel jumasa ti jac ba stz'eel ja talna chej jumasa
\p 
\v 8 Jaxa mojan ja tihui ay talnachej. Ti aye ba yoj job. Acual ni huas stalnaye ja xchejea.
\v 9 Iday, huaj to yile, jun yangel ja Cajualtiqui huaj ja ba stz'eelei. Jaxa yijlab ja Cajualtiqui lijpi juntiro ja bay ja yenlei. Ti jel och xihuelea.
\v 10 Ti yala ja angeli: ―Mi la xiuyex. Ata huabyex. Ay jas ajc'ach oj cala huabyex jel tzamal juntiro. Jel gusto juntiro oja huabyex. Jach ni spetzanil ja cristiano.
\v 11 Ja huaaxa manxi ta jun aColtanumex ja ba xchonabil ja rey Davidi, ja' ni ja Cajualtic Cristo ja ma' tzaubal yuj ja Diosi.
\v 12 Ja huaxa taahuex jun yal alatz bech'ubal soc jun c'uutz ti baan ec' ja ba jun pesebre, ti oja naex que ja' nia, xchi ja angeli.
\v 13 Huaj to cho yile, cho tey jun nole ángel, ja' ni ja ma' tey ba satq'uinali. Huane xta stoyjel ja Diosi. Ti huax yalahuea:
\q1 
\v 14 Ja ba satq'uinali ti huax aaji yi stz'acatal ja Diosi, jaxa ba luumi, laman a ajyuc ja suinquili soc jel lec a yil sbaje,
\m xchi ja ángel jumasa jahui.
\v 15 Yajni ch'ac yale jastal jahui, ti xa huajyea. Ti q'ueye q'ue ja ba satq'uinali, jaxa talnachej jumasa ti yala sbaj yenle itaa: ―La huaj quiltic ja ba Belén ba, xchiye. La huaj quiltic jastal ay ja jastal cabtic yala ja Cajualtiqui, xchiye.
\v 16 Ti huajye huegoa. Ti ni staahue ja María soc ja José soc ja yal alatzi ti baan ec' ba jun pesebre.
\v 17 Yajni yilahuei, ti yalahue ja jastal yabye yabalil ja yal alatz jahui.
\v 18 Jaxa matic ch'ac yabye ja jas yala ja talnachej jumasa, jel juntiro och ja spensarei.
\v 19 Pero ja María buc'an yuj ja jastic yabuneji. Quechan huan xta tz'iptz'unuc ja sc'ujoli.
\v 20 Ti xa cumxiye ja talnachej jumasa. Huane xta sc'anjel yi stz'acatal ja Diosi soc huane xta stoyjel ja Diosi yuj ja jastic ch'ac yabyei soc ja jas yilahuei. C'ot ta ni smeranil spetzanil ja jas ch'ac aljuc yabyei.
\s1 Ja alatz Jesusi iiji och ba templo
\p 
\v 21 Ja ay xa yioj huaxaque c'ac'u ja yal alatz Jesusi, ti xa c'ulaji circuncidar ja jastal ni culan yujile ja judio jumasa, soc aaji sbiiluc Jesús. Jach ni yala can ja ángel ja yora mi tox tucbi ja snani que Jesús bi oj yii ja sbiili.
\v 22 Ja tz'icui ja sc'ac'u huas stalna sbaje ja ixuquei, ja jastal ni ja smandar ja Moisesi, ti xa yiaje jan ja ba Jerusalena. Huaj yaahue yi ba sti sat ja Cajualtiqui.
\v 23 Ja jastal ni tz'ijbanubal ja smandar ja Cajualtiqui: Spetzanil ja yal querem bajtan alatzi, tzaubal bi oj ajyuc ba sti sat ja Cajualtic Diosi.
\v 24 Jayuj ja snan stat ja yal alatzi ti yiaje och ba oj yae yi ja smajtan ja Diosi ja jastal ni huax yala ja smandar ja Cajualtiqui: Jun bi pares paloma ma chab pichón oj aajuc yi ja Cajualtiqui.
\v 25 Jaxa ti ba Jerusaleni ay jun huinic sbiil Simeón. Ja huinic jahui jel toj soc meran huas sc'uan ja Diosi. Huan smajlajel ja ma' oj jac yaa snihuan sc'ujol ja israeleño jumasa. Jaxa Espíritu Santo tey soc ja yeni.
\v 26 Aaji jac sc'ujol yuj ja Espíritu Santo mi bi oj chamuc ta mi c'a huax yila ja Cristo ja ma' tzaubal yuj ja Cajualtiqui.
\v 27 Ja viejito Simeoni, julbesnubal yuj ja Espíritu ti huaj ja ba templo ja mero ora jahui, jaxa snan stat ja yal querem Jesusi yioje jan ja ba templo ba oj sc'uluque yi ja jastal culan yujile soc ja smandar ja Moisesi.
\v 28 Jaxa Simeoni ti sc'atantela ja yal alatz Jesusi. Ti och sc'an yi stz'acatal ja Diosi:
\q1 
\v 29 Cajual, ja huatjumon nia. Ja yaani, anima la chamyon xa. Jecahuon xa jun jc'ujol ja jastal ni huaxa hualai,
\q1 
\v 30 Porque soc ja mismo ja jsati quila ta ja ma' oj coltanuqui.
\q1 
\v 31 Oj ni scolta spetzanil ja cristiano jumasa.
\q1 
\v 32 Anima mi judiouc ja cristiano, ja jeca ta con ba oj yaa yijlab ja sbej ja yenle chomajquili, jaxa hua huuntiquil ja ba Israeli, oj ni ijlabanuc ja tihua,
\m xchi ja viejito Simeoni.
\v 33 Jaxa José soc ja María jel och ja spensare ja jastal huax alji sbaj ja yal queremi.
\v 34 Ja Simeoni sc'ulan bendiciar, ti yal yab ja María ja snani: ―Ja querem iti, t'ujpinubal ba oj ya moc' jitzan ja israeleño jumasa soc jitzan lec ja israeleño jumasa oj cho ya stul sbaj. Jaxa yal alatz iti, coraja xta oj iljuc pero ja' ni ja seña yuj ja yena ni ja ma' tzaubal ni, xchi ja Simeoni.
\v 35 Ti cho yalaa: ―Jachuc ja huen María. Lajan soc jun cuchilu oj ec' ja ba hua hualtzili. Yuj ja yeni oj ya chicnajuc ja jastal ay ja sc'ujol ja cristiano jumasa, xchi ja Simeoni.
\v 36 Ja tihui cho ti ni ay ja viejita Ana. Ja yeni aluman‑Dios, ja' yunin ja Fanueli, ja' ni yintil ja Aseri. Ja Ana, cuando soltera to, nupani pero quechan juque jabil ec' soc ja statami
\v 37 Ti can vigudaila. Jaxa tiempo ja yora c'otye ja María soc ja José, ay xa yioj ochenta cuatro jabil ja ora jahui. Pero mi ni huas sipa can ja temploa. Tola vida huas scomo ja suaeli. Ja' huajel sc'ujol sc'umajel ja Diosi.
\v 38 Ja yora jul ja snan stat ja yal alatzi, ja' ni ora jau ti jac ja Anai. Ti och sc'an yi stz'acatal ja Diosi. Ja mas tzaani ti huaj soc ja matic q'uelan sate que oj aajuc eluque libre ja ma' tey ba Jerusaleni. Ja' mero huan staajel ti' ja yal querem Jesusi.
\s1 Ti cumxiye ja ba Nazareti
\p 
\v 39 Ja María soc ja José, ja yajni ch'ac ta sc'uluc spetzanil ja jas huax yala ja smandar ja Cajualtiqui, ti xa cumxiye ba Galilea ja ba Nazareti.
\v 40 Ja yal querem Jesusi q'uii. Staa yip. Vivoaxi lec. Ac'ubal ni satal yuj ja Diosi.
\s1 Ja yal querem Jesusi ti taaji ba yoj templo
\p 
\v 41 Cada jabil ja ba stiempo ja syalq'uinal ja judio jumasa, ja snan stat ja yal queremi ti huax huajye ja ba Jerusaleni.
\v 42 Cuando ay xa yioj lajchahue jabil ja Jesusi, ti xa huaj soc ja snan stati ja jastal ni culan yujilei huax huaj yile ja q'uin jau ja ba Jerusaleni.
\v 43 Yajni ch'ac ja q'uini, ti xa huane cumxel ja ba snajei. Jaxa yal querem Jesusi ti can ja ba Jerusaleni, pero mi snaa ja snan stati.
\v 44 Huax yalahue que tey soc ja smojei, jayuj ti bejyiye jun c'ac'ua. Sleahue ja ba yermano jumasa soc ja ba sconocido jumasa.
\v 45 Pero como mi staahue, ti cho cumxiye ja ba Jerusaleni. Huaj slee jani.
\v 46 Yajni ec' oxe c'ac'u ti staahue ja ba yoj templo. Ja Jesusi ti culan ec' ba snalan ja ma' huas sea ja smandar ja Moisesi. Ti huan smaclajela, ti huax och soba.
\v 47 Spetzanil ja ma' huan yabjeli jex och ja spensarei ja jastal ja svivoili soc ja jastal huax cho sutu jan ja loili.
\v 48 Ja snan stati, yajni yilahuei, cham yabye. Ti yala ja snani: ―A cal, xchi, ¿jasyuj ja jach huaxa c'ulan quiticon ba? Huax leahuaticon soc ja hua tati pero jel xa huanticon pensar juntiro.
\v 49 Ti yala ja Jesusi: ―¿Jas lom huaxa leahuonex ba? ¿Mi ma t'un huax jac ja hua c'ujolex que ja yatel ja jTati, t'ilan ni oj c'uluca? xchi.
\v 50 Pero ja nanal tatali mi yab slugaril ja jas yalai.
\v 51 Ti huajye lajana. Cumxiye jan ja ba Nazareti. Jaxa Jesusi yib c'abal ni ac'ubal yuj ja snan stati. Jaxa snani naca buc'an yuj ba sc'ujol spetzanil ja jastaltic yabuneji.
\v 52 Ja Jesusi mas to huan vivoaxel. Jach ni ja scuerpo, huan q'uiel. Huan xa tzatzbel ja ba sti sat ja Diosi. Huan xax aaji cuenta yuj ja cristiano.
\s1 Ja Juani sloilta ja yabal ja Diosi ja ba ch'ayan lugari
\r (Mt. 3:1‑12; Mr. 1:1‑8; Jn. 1:19‑28)
\c 3
\p 
\v 1 Ja tiempo jahui ay xa yioj quince jabil ochel yatel ja Tiberio César, jaxa ti ba Judea, gobierno ay ja Poncio Pilato. Jaxa ba Galilea ja Herodesi, ay yatel. Jaxa Herodesi ay jun yermano Felipe sbiil, ay yatel ja ba Iturea soc jach ni ja ba Traconite. Jaxa ba Abilinia ay ochel yatel ja Lisaniasi.
\v 2 Jaxa Anasi soc ja Caifasi, yenle ja pagre mas nihuan yujile ja judio jumasa ja tiempo jahui. Jaxa Juan ja yunin ja Zacariasi, ti xa c'umaji yuj ja Diosi ba jun ch'ayan lugar. Ja tiempo jahui, tey ec' ja ba ch'ayan lugar jahui.
\v 3 Ja yen ja Juani ti huaj ec' ja ba sutanal ja nihuanja Jordani. Huan sloiltajel ec' jastal huax aaxi yi ja' ja cristiano cuando huas suchi ja sc'ujolei ba jachuc oj bi ch'ay snaajel ja smulei.
\v 4 Jach ni huan sc'ulajel ja jastal tz'ijbanubal ja ba slibro ja aluman‑Dios Isaiasi:
\q1 Oj to ajyuc jun ma' tzatz lec oj c'umanuc ja ba lugar jau mey lec ja suinquili, ti oj yal yab ja cristiano ja jastal iti: Ja jastal huaxa jamahuex ja bej ja cuando oj jac ja ma' ay yateli, jach oja huaex puesto ja hua c'ujolexi porque oj xa jacuc ja Cajualtiqui.
\q1 
\v 5 Jun rey, ta huax jamxi ja sbeji, spetzanil ja cañada jumasa oj ch'ac but'xuc. Anima nihuan huitzuc ma yal huitzuc, oj ch'ac jemxuc, jaxa bej ba jel lochani, oj ni tojxuc leca, soc ja bej jel lopan jotz'ani, oj cho lajxuc lec.
\q1 
\v 6 Ta jach c'a huaxa huaa puesto ja hua c'ujolexi, oja huilex oj ni coltajananic ja cuando huax jac ja jColtanumtiqui.
\m Jach ni yala ja Isaiasi cuando staa ti' ja Juani.
\v 7 Y meran nia, ti jac jun nole cristiano ja bay ja Juani. Huax jacye ba oj aajuc yile ja' yuj ja Juani, pero como huas snaa ja Juan jastal ay ja sc'ujolei, ti huax alji yabyea: ―Ja huenlexi ja' amojex ja chan it huax elye ajnel ja cuando huax jac ja tziq'uinali. ¿Huan ama xa hualahuex que ta oj elanic libre yuj ja huaxa pacahuex ajneli? ¡Majlayic! ti oja huilex ta loil tajnel ja scastigo ja Diosi, xchi ja Juani.
\v 8 A ilxuc ja hua modoex que suchi ta meran ja hua c'ujolexi. Mi jauc ja huen ita oja hualex, ja' quintilticon ja Abrahami, oj chianiqui. Huaxa cala huabyex, ja Diosi ta huan c'a sc'ana, oj ya pax yintilil ja Abraham ja ton jumasa iti.
\v 9 Ja yaani, lajan soc jastal jun huinic puesto xta ay ja yecheji ba oj sc'utz con todo yech ja tei. Jach ni ay ja Dios chomajquili. Puesto xta ay ba oj yaa castigo. Ja ma' mi lecuc ja smodo, lajan soc ja te' it mi lecuc ja sati. Oj c'uchuc ele. Oj jipxuc ja ba yoj c'ac', xchi ja Juani.
\v 10 ―Entonces ¿jasunc'a oj c'ulticon ba? xchi ja cristiano jumasa jahui.
\v 11 ―Pues ta ay c'a ma' ay chab lame ja sc'ui, a yaa yi ja ma' mey yioji. Jach ni a sc'uluc ja ma' ay suaeli, xchi ja Juani.
\v 12 Ti jacye chaboxe ja ma' huas stzomo ja taq'uini. Huas sc'ana oj aajuc yile ja'. Ti yalahuea: ―Maestro, jaxa quenticoni, ¿jasunc'a lec oj c'ulticon ba? xchiye.
\v 13 Ti yala ja Juani: ―Moc lom ec'anic mas ja jastal huax yala ja hua leyexi, xchi.
\v 14 Jach ni chaboxe soldado, ti yalahuea: ―Jaxa quenticoni, ¿jasunc'a lec oj c'ulticoni? xchiye. ―Pues mi lom xa yamahuex ja cristiano ba oj hua eluquex fuerza ja jas yiojei. Mi lom xa locohuex abal q'uiq'uinal ja cristiano, jaxa hua tz'acolexi, gusto cananic ja janec' huax aaji ahuilexi, xchi ja Juani.
\v 15 Jaxa cristiano jumasa, cuando yabye ja jas huan yaljel ja Juani, yaa jun snihuanil sc'ujole. Huan xta tz'iptz'unuc ja sc'ujolei: ―Ja Juan iti, ¿ja' ma yen ja Cristo ja ma' tzaubal yuj ja Diosi? xchiye.
\v 16 Ti yala ja Juani: ―Pues ja queni huax ca huiex ja' pero ay ma' oj to jacuqui. Ja yeni oj to yaa huilex ja Espíritu Santo pero con todo yip. Ja matic mix c'ocxiyei, oj ni aajuc cajan c'ac'a. Jaxa yen ja ma' oj to jacuqui, mas nihuan juntiro yuj ja queni. Mi ni oj maconucon oj sop yi ja xanabi.
\v 17 Ja yeni huax jac ba oj ch'ac spil ja ba lec ja sat iximi soc ja ba somelali. Oj smes el ja stz'iilelali, ti xa oj snol can ja ixim ja ba snajtzili, jaxa spolvoili ti oj ya och ba yoj c'ac' ja ba mi ni nunca huax tupi, xchi ja Juani.
\v 18 Soc ja jastal iti soc otro jitzan modo ti huax och sloilta yab ja cristiano ja abal it jel tzamali.
\v 19 Ja Herodes it ja ma' ay yateli, ti alji yab ja smul yuj ja Juani. Mi bi sbejuc ja jastal huan sc'ulajel soc ja ixuc Herodíasi, ja xcheum ja yijtz'in Felipe, soc cho yala spetzanil ja smodo jel malo huan sc'ulajeli.
\v 20 Iday, mas to somelal huaj ja rey Herodesi, hasta slutu preso ja Juani.
\s1 Aaji yii ja' ja Jesusi
\r (Mt. 3:13‑17; Mr. 1:9‑11)
\p 
\v 21 Ja tiempo yora huan to yiijel ja' spetzanil ja cristiano, jach ni ja Jesusi. Cho yiaj ja' ja yen chomajquili. Ti och sc'umuc ja Diosi, jaxa satq'uinali jamxi.
\v 22 Ti co t'ucan sbaj ja Espíritu Santo, pero entero splanta jastal jun paloma. Ti c'umani ja Dios ja ba satq'uinali: ―Ja huen mero cunina. Jel yaj huax cabya soc jel huaxa huaa qui gusto, xchi.
\s1 Ja ma' ec' pax yujil ja Jesucristo
\r (Mt. 1:1‑17)
\p 
\v 23 Ja Jesusi ja yora q'ue stul ja yateli, ay xa yioj mojan treinta jabil. Huax alji que ja' bi yunin ja José. Jaxa José, ja' stat ja Elí,
\v 24 Jaxa Elii, ja' stat ja Matat, jaxa Matati, ja' stat ja Leví, jaxa Levii, ja' stat ja Melqui, jaxa Melquii, ja' stat ja Jana, jaxa Janai, ja' stat ja José,
\v 25 Jaxa Josei, ja' stat ja Matatías, jaxa Matatiasi, ja' stat ja Amós, jaxa Amosi, ja' stat ja Nahum, jaxa Nahumi, ja' stat ja Esli, jaxa Eslii, ja' stat ja Nagay,
\v 26 Jaxa Nagayi, ja' stat ja Maat, jaxa Maati, ja' stat ja Matatías, jaxa Matatiasi, ja' stat ja Semey, jaxa Semeyi, ja' stat ja José, jaxa Josei, ja' stat ja Judá,
\v 27 Jaxa Judai, ja' stat ja Joana, jaxa Joanai, ja' stat ja Resa, jaxa Resai, ja' stat ja Zorobabel, jaxa Zorobabeli, ja' stat ja Salatiel, jaxa Salatieli, ja' stat ja Neri,
\v 28 Jaxa Nerii, ja' stat ja Melqui, jaxa Melquii, ja' stat ja Adi, jaxa Adii, ja' stat ja Cosam, jaxa Cosami, ja' stat ja Elmodam, jaxa Elmodami, ja' stat ja Er,
\v 29 Jaxa Eri, ja' stat ja Josué, jaxa Josuei, ja' stat ja Eliezer, jaxa Eliezeri, ja' stat ja Jorim, jaxa Jorimi, ja' stat ja Matat,
\v 30 Jaxa Matati, ja' stat ja Leví, jaxa Levii, ja' stat ja Simeón, jaxa Simeoni, ja' stat ja Judá, jaxa Judai, ja' stat ja José, jaxa Josei, ja' stat ja Jonán, jaxa Jonani, ja' stat ja Eliaquim,
\v 31 Jaxa Eliaquimi, ja' stat ja Melea, jaxa Meleai, ja' stat ja Mainán, jaxa Mainani, ja' stat ja Matata, jaxa Matatai, ja' stat ja Natán,
\v 32 Jaxa Natani, ja' stat ja David, jaxa Davidi, ja' stat ja Isaí, jaxa Isaí, ja' stat ja Obed, jaxa Obedi, ja' stat ja Booz, jaxa Boozi, ja' stat ja Salmón, jaxa Salmoni, ja' stat ja Naasón,
\v 33 Jaxa Naasoni, ja' stat ja Aminadab, jaxa Aminadabi, ja' stat ja Aram, jaxa Arami, ja' stat ja Esrom, jaxa Esromi, ja' stat ja Fares, jaxa Faresi, ja' stat ja Judá,
\v 34 Jaxa Judai, ja' stat ja Jacob, jaxa Jacobi, ja' stat ja Isaac, jaxa Isaqui, ja' stat ja Abraham, jaxa Abrahami, ja' stat ja Taré, jaxa Tarei, ja' stat ja Nacor,
\v 35 Jaxa Nacori, ja' stat ja Serug, jaxa Serugui, ja' stat ja Ragau, jaxa Ragahui, ja' stat ja Peleg, jaxa Pelegui, ja' stat ja Heber, jaxa Heberi, ja' stat ja Sala,
\v 36 Jaxa Salai, ja' stat ja Cainán, jaxa Cainani, ja' stat ja Arfaxad, jaxa Arfaxadi, ja' stat ja Sem, jaxa Semi, ja' stat ja Noé, jaxa Noeji, ja' stat ja Lamec,
\v 37 Jaxa Lamequi, ja' stat ja Matusalén, jaxa Matusaleni, ja' stat ja Enoc, jaxa Enoqui, ja' stat ja Jared, jaxa Jaredi, ja' stat ja Mahalaleel, jaxa Mahalaleeli, ja' stat ja Cainán,
\v 38 Jaxa Cainani, ja' stat ja Enós, jaxa Enosi, ja' stat ja Set, jaxa Seti, ja' stat ja Adán, jaxa Adani, ja' sc'ulan ja Diosi.
\s1 C'ulaji probar ja Jesusi
\r (Mt. 4:1‑11; Mr. 1:12‑13)
\c 4
\p 
\v 1 Ja Jesusi tey soc juntiro ja Espíritu Santo, jayuj ti xa el ja ba nihuanja Jordani. Julbesnubal huaj yuj ja Espíritu ja ba jun ch'ayan lugar.
\v 2 Cuarenta c'ac'u tejc'aji ja tihui, jaxa cuarenta c'ac'u jahui, c'ulaji lec probar yuj ja diablo. Ja c'ac'u jumasa jahui mi jas yab altiro. Cuando ch'ac ta ec'uc ja c'ac'u jumasa jahui, ti xa och huain xyaba.
\v 3 Ti alji yab yuj ja diablo: ―Ja huena ni yunin Diosaa. A pax huego panil ja ton iti, xyutaj ja Jesusi.
\v 4 Ti yala ja Jesusi: ―Pero jach ni tz'ijbanubal taca, que mi quechanuc yuj ja pan huax ajyi sac'anil ja cristiano pero ja' ni yuj spetzanil ja spalabra ja Diosi, xchi ja Jesusi.
\v 5 Ja Jesusi ti iiji yuj ja diablo ba jun chaanil huitz. Ti ch'ac jeejuc yi huego huego spetzanil ja lugar ja ba spetzanil ja mundo.
\v 6 Ti alji yab yuj ja diablo: ―Ja hueni oj caa hui ba hua c'ab spetzanil ja lugar jumasa. Jel nihuan oj iljan yuj ja cristiano. Ja queni ac'ubal qui ba jc'ab spetzanil ja lugari. Chican ja ma' huax c'ana ja queni, oj ni caa yia.
\v 7 Ja huen quechan oj coan mec'an ja ba sti jsati, oj ni ch'ac caa hui ba hua c'ab ja lugar jumasa, xchi ja diablo.
\v 8 Pero ja Jesusi ti yalaa: ―Elan ja ba jtz'eel Satanás, yuj ja jach ni tz'ijbanubali:
\q1 Ja ba sti sat ja hua Huajual Diosi oj coan mec'an. Quechan ja yen ja ma' oja huatelta,
\m xchi ja ba yabal ja Dios tac, xchi ja Jesusi.
\v 9 Ti cho iiji och ja ba Jerusalén ja Jesusi. Aaji q'ueuc ja ba s'olom ja templo ja tihui. Ti alji yaba: ―Huena ni yunin Diosaa. Jipa quit co abaj, xyutaj.
\v 10 ¿Mi ma jach huax yala ja ba yabal ja Dios ba?
\q1 Oj seca hui ja yangel ba oj stalnaya,
\m ¿mi ma xchi ba?
\q1 
\v 11 Ja yenlei soc sc'abe oj sbecha eq'ue cosaque jachuc mi oja c'ochuc ahuoc soc ja toni.
\m Ala quitic ta mi jach huax yala, xchi ja diablo.
\v 12 Ti cho yala ja Jesusi: ―Es jach nia, pero huax cho yala que mi lom xa c'ulan probar ja hua Huajual Diosi, xchi.
\v 13 Ja diablo, yajni ch'ac ja jun lame prueba iti, ti xa spila sbaj chaboxe tiempoa.
\s1 Ja Jesusi q'ue stul ja yatel ba Galilea
\r (Mt. 4:12‑17; Mr. 1:14‑15)
\p 
\v 14 Ja Jesusi ti cumxi ba Galilea. Jel tzatz ay soc ja Espíritu Santo, jayuj ti el yabalil ja ba yibanal ja lugari.
\v 15 Ti huan seejel ec' ja ba yiglesia ja judio jumasa. Jel nihuan huax ilji yuj spetzanil ja cristiano.
\s1 Ja Jesusi ti cumxi ja ba Nazareti
\r (Mt. 13;53‑58; Mr. 6;1‑6)
\p 
\v 16 Ti cho huaj ja ba Nazaret ja ba q'uii. Ja c'ac'u huax jijliye ja judio jumasa, ti och ja ba yiglesiaei ja jastal ni smodo. Ti q'ue tec'ana. Och sq'uel ja yabal ja Diosi
\v 17 Ti aaji yi ja slibro ja Isaías ja aluman‑Diosi. Ja cuando sama ja libro, ti staa ja ba parte huax yala jachuqui:
\q1 
\v 18 Ja Yespíritu ja Cajual Diosi ti ni ay ec' jmoca. Yuj ja stzaunejon ba oj loilta yab ja matic mi jas yiojei. Ay jas yajc'achil oj cal yabye, jaxa matic jel triste ayi, oj ca ec'uc ja stristeilei, jaxa matic naca mochan tei, jac cal yabye que libre xa aye, jaxa matic tupel ja satei, jac ca jamxuc ja satei. Jaxa matic jel coel huax iljiyei, jac ca ec'uc ja suocolei.
\q1 
\v 19 Seconejon ba oj cal yab ja mulanum jumasa que ja' xa ni tiempo huax talnaji syaujulale yuj ja Diosi.
\m 
\v 20 Ja cuando ch'ac ta sbal ja juun ja Jesusi, ti cho yaa yi ja ma' ay yatel ja ba iglesia. Ti och culana. Och see yi ja cristiano. Jaxa spetzanil ja ma' tey ba yoj iglesia, ti huax tojtoq'uelji lec ja Jesusi.
\v 21 Ti och yal yabyea: ―Ja yaani ja ba sti ja hua satexi ja jas tz'ijbanubal ja ba slibro ja Diosi huan xa c'otel, xchi ja Jesusi.
\v 22 Jaxa cristiano jel tzamal huas staahue ti' ja Jesusi. Juntiro ch'abajiye yuj ja jel tzamal juntiro ja jas huan yaljeli. ―¿Jastal ay ba? ¿Mi ma jauc ja yunin ja José ba? xchiye.
\v 23 Ti yala ja Jesusi: ―Huax naatic jastal ja yaljel ita ni huax calatiqui: Ta doctor c'a aya, ajnanan ja il ba. Jach ni mero huan c'umal ja hua c'ujolexi. Ja huabyex ni ja jastal ca tojbuc ja cristiano jumasa ba Capernaum. Jaxa ba slugar ja ba q'uii, mi jas huas sc'ulan, la chiyex.
\v 24 Huax cala huabyex pero meran, que mi ni jun aluman‑Dios c'ulaji caso ja ba q'uii, xchi.
\v 25 Pero oj cala huabyex ja smeranili. Ja tiempo jau ja tey ja aluman‑Dios Eliasi, ja' ni ja tiempo jau albel lec mi ni co ja jai ‑ oxe jabil soc huaque ixau mi yaa jai ‑ ti ajyi jun nihuan huain ja ba sutanal ja satq'uinali. Jaxa tiempo jahui jel ni jitzan ja viguda jumasa ja ba Israeli.
\v 26 Pero mi ni june ja viguda jumasa jahui huaj iljuc yuj ja Eliasi. Es huaj nia, pero jun viguda ba otro raza soc tuc lugar ay. Ti culan ba Sarepta ja ba lugar Sidoni.
\v 27 Jaxa stiempo ja aluman‑Dios Eliseo, ja ba Israeli jel ni ja ma' yioj ja chamel it huax c'a ja sbactelei. Pero mi ni june tojbiye ja israeleño jumasa. Eso sí, tojbi ni ja Naamani pero otro raza ja yeni soc tuc lugar ay. Ja yen ti culan ba Siria, xchi ja Jesusi.
\v 28 Yajni ch'ac yabye ja jastal iti, ja ma' tey ba yoj iglesia, juntiro q'ue ja scorajaei.
\v 29 Xachalji xta ch'ac q'ueuque, ti yiaje el ja ba sti ja hacienda jahui. Yiaje man ba scajanal ja huitz ja bay ja xchonabilei. Ti huas sc'ana oj sipe co ja tihui.
\v 30 Pero ja yen ja Jesusi ti ec' sc'utz och ja ba snalan ja yenlei. Ti huaja.
\s1 Ja huinic ixtalanubal yuj ja pucuji
\r (Mr. 1:21‑28)
\p 
\v 31 Ti xa huaj och ja ba Capernaum, jun chonab ba Galilea. Jaxa c'ac'u huax jijliye ja judio jumasa, ja Jesusi ti huax huaj see yi ja cristiano jumasa.
\v 32 Jel huax och spensare yuj ja jas huan seejeli. Ja sloili lajan soc yabal june ma' ay yatel.
\v 33 Ja ba yiglesia ja judio jumasa tey jun huinic ja tihui ixtalanubal yuj ja pucuji. Ti ahuani tzatz leca:
\v 34 ―Actayoticon. Iday, ¿jastal aya jmocticon ja huen ba Jesús nazareño? ¿Jaquela ma ba oja ch'ayoticon? Ja queni huax naa mach ayaa. ¡Ja hueni mi ni huaxa lea tan amul tac! Ti ni aya soc ja Diosa, xchi
\v 35 Ja Jesusi ti scomo c'ac' leca: ―¡Ch'abanan ja hueni! Acta can huego ja huinic iti, xyutaj. Jaxa pucuji ti sbantzun sbaj luuma ja ba sti sat ja yenlei. Ti yaa can ja huinic jahui. Mi ni jun spaltail cana.
\v 36 Spetzanil ja cristiano jel och juntiro ja spensarei. Ti huax yala sbaje yenle itaa: ―¿Ba jac ja loil iti? xchiye. Lajan soc jun ma' ay lec yateli. Jel ja yip huas sc'ulan mandar ja pucuj tac. Iday, ¡huan nix c'uaji taca! xchiye xta.
\v 37 Jaxa ba spetzanil ja lugar mojani, ch'ac yabye yabalil ja Jesusi.
\s1 Ja Jesusi ya tojbuc ja snial ja Simón Pedro
\r (Mt. 8:14‑15; Mr. 1:29‑31)
\p 
\v 38 Ja Jesusi ti xa el ja ba yiglesia ja judio jumasa. Ti huaj ja ba snaj ja Simoni. Jaxa snial ixuc ja Simoni jel juntiro ja sc'ajc'ali. Ja Simoni ti sc'ana yi pavora que oj huaj yile.
\v 39 Jaxa Jesusi ti och c'uban sq'uelaa. Ya lamxuc ja sc'ajc'ali. Huego eq'ui. Ti xa q'ue huegoa. Yen xa sc'ulan ja suael ja huiniquei.
\s1 Aaji tojbuc jitzan ja ma' malo ayi
\r (Mt. 8:16‑17; Mr. 1:32‑34)
\p 
\v 40 Ja cuando huan xa mucxel ja c'ac'u, spetzanil ja matic ay xchamumi, chican jas tiq'ue chamelil yiojei, ti huax iiji och yi ja Jesusi. Jaxa yeni ti huax ya cajan ja sc'ab ja ba cada jujune ja yenlei. Huan nix ch'ac ya tojbuquea.
\v 41 Jach ni ja tuc chomajquili. Jel jitzan ja matic actaji can yuj ja pucuji. Huax ahuaniye, ti huax cho yalahuea: ―Ja hueni, huena ni ja yunin Diosa, xchiye xta. Pero ja Jesusi ti huas scomo c'ac' leca. Mi aaji c'umanuque yuj ja huas snaahue que ja yeni, yena ni ja Cristoa.
\s1 Ja Jesusi sloilta ja yabal ja Diosi ja ba Galilea
\r (Mr. 1:35‑39)
\p 
\v 42 Jaxa el ja c'ac'u, ti huaja. Ti huaj ba jun lugar ja ba mey lec ja suinquili, jaxa cristiano huane sleejel eq'ue. Ti staahue ja tihui. T'ilan yalahue yabi que mi bi oj jipjuque can ja yenlei.
\v 43 Pero ja Jesusi ti yalaa: ―Pero jach ni ja tuc lugar chomajquili. T'ilan oj huaj cal yab jastal ay ja ba huas sc'ulan mandar ja Diosi. Jayuj jecubalon ja il tac, xchi.
\v 44 Jaxa ba tuctuquil yiglesia ja judio jumasa ja ba Galilea, ti huan sloiltajel ec' ja yabal ja Diosi.
\s1 C'ulaji yi milagro ja yamachay jumasa
\r (Mt. 4:18‑22; Mr. 1:16‑20)
\c 5
\p 
\v 1 Ja yora ti ajyi ja Jesús ja ba sti ja ja' ja ba Genesareti, ja cristiano huan xta xac botz'an sbaj ja yen ba oj yabye ja yabal ja Diosi.
\v 2 Ja Jesusi ti yila chab barco ti lac'an ja ba sti ja jai. Jaxa yamachay jumasa coye ja ba sbarcoei. Ti huane siijel ja yenubei.
\v 3 Jaxa Jesusi ti q'ue june ja barco jahui, ja' sbarco ja Simoni. Ti sc'ana yi pavor ja Simón Pedro ba oj ya och och t'un mas ja ba yoj jai. Jaxa Jesusi ti och culan ja ba yoj barco. Ti och see yi ja cristiano jumasa ja tihui.
\v 4 Yajni ch'ac see yi ja cristiano, ti yal yab ja Simoni: ―Ochanic och mas ja ba yoj jai. Tix hua ochuquex ja hua huenubexi ba oja yamex ja chayi, x'utjiye.
\v 5 Jaxa Simoni ti yalaa: ―Pero q'uelahuil Maestro, snajtil ja acuali huanticon atel pero mi ni jas jyamaticona. Pero como huen huaxa huala, oj ni cho jipticon co ja quenubticona, xchi.
\v 6 Jach ni sc'ulanea. Jaxa yenubei but' juntiro ja chayi, pero ch'ac c'utzuc yuj ja yalali.
\v 7 Ti seahue yi seña ja smojei, ja ma' tey ba otro barco ba oj jac coltajuque. Ti jacyea. Y jach ni ja sbarco ja yenlei. Ch'ac but' ja chayi. Ibjaaxi yuj ja yalali.
\v 8 Cuando ch'ac yil ja jastal it ja Simón Pedro, ti co mec'an ja ba sti sat ja Jesusi: ―Mi lom xa mojanon, Cajual, porque ja queni mulanumon, xchi.
\v 9 Jach yala yuj ja xihuel ja sbaj ja janec' syamahue ja chayi. Jach ni ja smoj jumasa chomajquili.
\v 10 Soc jach ni ja Jacobo soc ja Juani, ja yuntiquil ja Zebedeo, smoj sbaje yamachayil soc ja Simón Pedroi. Jel och ja spensare juntiro. Pero ja Jesusi ti yal yab ja Simoni: ―Mi xa c'ulan pensar. Meran, ja' huajel ac'ujolex syamjel ja chayi pero ja yaani, ja' oja huaa ac'ujolex oja leex jan qui ja cristiano.
\v 11 Yajni yaahue eluque jan ja chab barco jau ja ba sti jai, ti xa yaahue can spetzanila. Ti huajye soc ja Jesusi.
\s1 Ja Jesusi ya tojbuc jun ma' huan c'ael ja sbacteli
\r (Mt. 8:1‑4; Mr. 1:40‑45)
\p 
\v 12 Jun c'ac'u ja Jesusi tey ba june ja hacienda jumasa ja ba lugar jahui. Huaj to yile, ti jac jun huinic ay yioj jun chamel huan c'ael ja sbacteli. Jel xa yioj juntiro. Ja huinic jahui cuando yila ja sat ja Jesusi, ti co mec'ana. Och sc'an yi pavor: ―Cajual, ta jach c'a huaxa c'ana, oj bob hua tojbucon, xchi.
\v 13 Jaxa Jesusi ti xija ja sc'abi. Syama, ti yalaa: ―Huan nix c'ana oj tojbana, xchi. Jaxa sc'aelali, huego huego eq'ui.
\v 14 Ti alji yab que moc lom ma' oj yal yabi: ―Pero caax, utji, cax jea baj yi ja pagre. Yuj ja lec xa aya, jayuj aa yi ja smajtan ja Dios ja jastal ni yala can ja Moisesi. Soc ja jahui ti oj snaa ja cristiano que tojbiya ta, xchi ja Jesusi.
\v 15 Pero ja yabalil ja Jesusi mas to pucxi juntiro. Jaxa cristiano, partida huax jacye ba oj smaclaye soc ba oj aaji tojbuque soc ja xchamelei.
\v 16 Jaxa Jesusi ti huaj ba jun lugar ba mey lec ja suinquili ba oj bob sc'umuc ja Diosi.
\s1 Ja Jesusi ya tojbuc jun huinic tulido ayi
\r (Mt. 9:1‑8; Mr. 2:1‑12)
\p 
\v 17 Jun c'ac'u ti huan seejel ja Jesusi. Ti aye jun nole judio, fariseo sbiil. Ja fariseo jumasa soc ja ma' huas sea ja smandar ja Moisesi ti culane ec'a. Ti ch'ac jacuque ja ba spetzanil ja ch'in lugar sbaj Galilea soc ja sbaj Judea soc jach ni ja ba Jerusaleni. Jaxa c'ac'u jahui jel tzatz juntiro huaj ja yip ja Jesusi. Ch'ac ni tojbuc yuj ja cristiano jumasa, ja' ni yuj ja yip ja Cajualtic Diosi.
\v 18 Huaj to cho yile, ti jac chaboxe huinica. Lican yujile jun huinic tulido ay. Huane fuerza oj yii och man yoj naitz ba oj see yi ja Jesusi,
\v 19 Pero mi ni staahue modo jas oj sc'uluquea yuj ja jel but'el ja cristiano. Jayuj ti xa q'ueye ba s'olom ja naitzi. Ti sotohue ja tihui, ti ya couque ja xch'ajtilteili. Ti ya couque ba snalan ja cristiano ja ba mero spunto bay ja Jesusi.
\v 20 Ja Jesusi, ja yila jastal huax c'uaji, ti yalaa: ―Hijo, ja hua muli perdonado xa ay, xchi.
\v 21 Jaxa fariseo jumasa soc ja matic huas sea ja smandar ja Moisesi ti och sc'uluque pensara: ―¿Janec' to ni ja iti ja huan stoyjel sbaji? ¿Yuj ama yen ja Dios ba? ¿Aya ma' oj bob sc'ul perdonar ja mulal ba? ¿Mi ma quechanuc ja Dios ba? xchi ja ba sc'ujolei.
\v 22 Jaxa Jesusi snaa jastal ay ja spensar ja yenlei, ti yalaa: ―Iday, ¿jasyuj ja jach huan huaatzhuunuc ja hua c'ujolex ja huenlex ba?
\v 23 ¿Jasunc'a huaxa c'anahuex oj cal ba? ¿Q'uean, bejyan, oj ma cut ba? ¿Ja' ma gustoex jach oj cal ba, soc ja huax cala, ja hua muli, perdonado xa ay?
\v 24 Ja queni ti coelon jan ja ba satq'uinali. Ja' catel ayon ja ba luumi que oj ni jc'ul perdonar ja mulali. Pero ba oja c'uuc ja huenlexi, oj ni ca tojbuc ja huinic ita. Ti yal yab ja huinic ja ma' tulido ayi que oj q'ueuc.
\v 25 Jaxa huinic jahui ti ba satalajel abal q'ue huego. Yiaj ja suaynubi ja jas huas suaynuban ajyi. Ti xa huaj ba snaji. Huan sc'anjel yi stz'acatal ja Diosi.
\v 26 Spetzanil ja cristiano jahui jel och ja spensarei. Ti yalahuea: ―¡Stz'acatal ja Diosi! ¡Xihuel ja sbaj ja jas huan sc'ulajeli! Quilatic ta ja jas jel tzamal huan sc'ulajel ja Diosi, xchiye.
\s1 Tzaaji ja Levii
\r (Mt. 9:9‑13; Mr. 2:13‑17)
\p 
\v 27 Yajni ch'ac sc'uluc ja jastal it ja Jesusi, ti xa huaja. Ti yila jun colector sbiil Leví ti culan ec' ja ba huax och ja contribucioni: ―¿Mi ma xa c'ana huajan jmoc ba? xchi ja Jesusi.
\v 28 Ja Levii ti yaa can spetzanil ja atel jahui, ti huaj soc ja Jesusi.
\v 29 Ja mas tzaani ja Leví ti sc'ulan jun nihuan huaelal ja ba snaji ba oj sloc ja Jesusi. Jitzan ja ma' jaqui soc ja smoj colectorili. Naca ti xa aye ba mesa.
\v 30 Jaxa matic huas sea ja smandar ja Moisesi soc ja fariseo jumasa ti och huooljuque sbaj ja snebuman jumasa: ―¿Mi ma la q'uixuiyex lajan huanex huael soc ja tantic colector jumasa? ¡Jun ita aseq'uex huanex huael soc ja tantic mulanum jumasa tac!
\v 31 Ti yala ja Jesusi: ―¡Lec xta huujilex ja huenlexi, meyuc anesesidaex soc doctor como naca jel lec ayex! Pero ja yenlei huas sc'ulan necesitar jun sdoctore.
\v 32 Ja' ni yuj jaquelona ba oj colta soc ja smulei ba oj suchuc ja sc'ujolei pero ja ma' lec ayi, mi t'ilan huax yab oj colta, xchi ja Jesusi.
\s1 Ja Jesusi yala jas sbej ja mi scomo ja suaeli
\r (Mt. 9:14‑17; Mr. 2:18‑22)
\p 
\v 33 Ja cristiano ja ma' huane smaclajel ja loili ti yalahuea: ―Q'uelahuilex, ja snebuman ja Juani tola vida huas scomo ja suaelei soc huas sc'umane ja Diosi. Jach ni culan yujile ja snebuman jumasa ja fariseo. Jaxa hua nebuman jumasa ja hueni mi ni t'usan huas scomo ja suaelea, xchiye.
\v 34 Ti yala ja Jesusi: ―Ilahuil jun ch'ac abalanum. Ja sloc ja nupanumi mi ni sbejuc mi oj huauquea, como tzomane to soc ja nupanumi.
\v 35 Pero oj ni jacuc ja c'ac'u cuando oj ni ch'ay yujile ja nupanumi. Eso sí, ja c'ac'u jumasa jahui, oj ni scom ja suaelea yuj ja oj ni but'uque yuj ja stristeilei.
\v 36 Ti cho och yal otro loila: ―Mi ni modo oja ch'iex jun yajc'achil ac'uex ba oj hua ochuquex smactonil ja ba poco xa. Ta jach c'a huaxa c'ulanex, oj sujbuc juntiro ja macton jau ba yajc'achili, soc toj coleto oj huajuc.
\v 37 Jach ni jun poco oxom ba ay syaj. Mix bob hua och ja taan ba yajc'achil to. Jach c'a huaxa c'ulan, huaj to ahuile, leutz'uji ta snalan ja oxomi, jaxa hua taani, mi xa lecuca.
\v 38 Mas lec, aa ba jun yajc'achil oxom ba mey syaj. Jachuc, mi ni jas oj sc'uluca, mi ni ja oxomi soc mi ni ja taani.
\v 39 Jach yala jastal it ja Jesusi porque jel huocol huax yab ja ma' c'ajyel soc ja poco modo. Cuando huax yabye jun cosa yajc'achil, mi ni modo huas sc'anahuea. ―Mas lec juntiro ja jpoco modotiqui, huax xchiye. Porque ja yajc'achili, ja' ni sbaj ja Jesusi.
\s1 Ja snebumani stuch'uhue ja trigo ja sc'ac'uil ja jijleli
\r (Mt. 12:1‑8; Mr. 2:23‑28)
\c 6
\p 
\v 1 Jun sc'ac'uil ja sijlele ja judio jumasa ja Jesusi soc ja snebuman jumasa ti ecye ba jun yalajil trigo. Jaxa snebuman jumasa ti stuch'uhue ja sati. Ti sbuyuhue ja ba yoj sc'abei, ti sc'uxuhuea.
\v 2 Jaxa chaboxe fariseo jumasa ti yalahuea: ―¿Jasyuj jach huaxa c'ulanex ba? ¿Yuj ama mi xa naahuex que mi jach culanuc ja sc'ac'uil ja jijleltic ba? Ja jas huanex sc'ulajeli, atel nia, xchiye xta.
\v 3 Ti yala ja Jesusi: ―Entonces mi ni huaxa q'uelahuex ja yabal ja Diosi. ¿Mi ma xa naahuex ja jas sc'ulan ja rey David cuando och huain xyabi soc ja smoj jumasa?
\v 4 Ja yeni, cuando och ja ba templo it c'ulubal soc c'uutzi, sloo ni ja pan ti jian ec' ja ba sti sat ja Diosi. Jach ni ja smoj jumasa, cho yaa yile, iday, ja pan jahui mi sbejuc oj sloo ja rey Davidi soc mi ni ja smoj jumasa. Quechan huax bob sloo ja pagre jumasa. Iday, jaxa rey Davidi mi malouc ilji yuj ja Diosi.
\v 5 Ja queni coelon jan ja ba satq'uinali. Quena ni oj cal jasunc'a lec sc'ulajel ja ba c'ac'u jijleli, xchi ja Jesusi.
\s1 Tojbi ja huinic ja ma' jiman ec' ja sc'abi
\r (Mt. 12:9‑14; Mr. 3:1‑6)
\p 
\v 6 Otro vuelta ja sc'ac'uil ja sijlele ja judio jumasa, ja Jesusi ti och ja ba yiglesiaei. Ti och see yi ja cristiano. Huaj to yile, tey jun huinica. Ja stojol sc'abi lom xta ti jiman ec'a. Mi xa ni modo huax bob ya q'ueuca.
\v 7 Pero como ja' ni ja sc'ac'uil ja jijleli, ja matic huas sea ja smandar ja Moisesi quechan ta huas stz'elsatine ba oj yile ta oj ya tojbuc ja huinic jahui. Ta jach c'a huas sc'ulan, oj ni stae yi ja smula.
\v 8 Pero ja Jesusi huas snaa jastal ay ja sc'ujol ja yenlei. Ti yal yab ja huinic jau ja ma' jiman xa ni ec' ja sc'abi: ―Q'uean, ti la jac ja ba jnalanticoni, xyutaj. Jaxa yeni ti q'ue tec'ana.
\v 9 Jaxa Jesusi ti yiaj yabalea: ―Huax c'ana job ahuilex. Judiootic ja quentiqui. Jaxa sc'ac'uil ja jijleltiqui, ¿sbej ama oj c'ultic ja ba lequi ma ja' sbej oj c'ultic ja malo? ¿Lec ama oj coltatic ja cristiano ma oj ch'aytic snaajele?
\v 10 Ti och sq'ueltalauc spetzanil ja janec' joyan ec' ja cristiano. Ti yal yab ja huiniqui: ―A q'ueuc ja hua c'abi, xyutaj. Jaxa huiniqui ti ya q'ueuc ja sc'aba. Huego huego staa slugar ja jastal ay ja otro jun sc'abi.
\v 11 Jaxa fariseo jumasa soc ja matic huas sea ja smandar ja Moisesi xuaatzhuoni xta huaj ja scorajei. Ti yiaj yabal sbaje jas lec oj sc'uluque yi ja Jesusi.
\s1 Ja Jesusi stzaa ja lajchahuane secabanumi
\r (Mt. 10:1‑4; Mr. 3:13‑19)
\p 
\v 12 Ja c'ac'u jumasa jahui ja Jesusi ti huaj ba jun huitz. Huaj sc'umuc ja Diosi. Snajtil ja acual huan sc'umajel ja Diosi.
\v 13 Cuando el ja c'ac'u ti spaya jan ja snebuman jumasa. Ti tzaajiye lajchahuane ja yenlei, jaxa lajchahuane jahui ochye jecabanumil.
\v 14 Stzaa ja Simoni, ti slea yi otro sbiila. Yaa yi Pedroil. Cho tzaaji ja yijtz'in Andresi, soc ja Jacobo, soc ja Juani, soc ja Felipe, soc ja Bartolomé,
\v 15 Soc ja Mateo, soc ja Tomasi, soc ja Jacobo ja yunin ja Alfeo. Cho stzaa ja Simón ja ma' huax alji sbaj Zelote,
\v 16 Jach ni ja Judas, yermano sbaje soc ja Jacobo, soc ja Judas Iscariote, ja' ni ja ma' yiaj spatic ja Jesús ja mas tzaani.
\s1 Ja Jesusi sea yi jitzan ja cristiano
\r (Mt. 4:23‑25)
\p 
\v 17 Ja Jesusi ti xa coye jan soc ja snebuman jumasa. Yajni elye jul ja ba yoj jobi, ti tejc'aji t'usana. Ti smoj ja snebuman jumasa soc jun nole cristiano ja sbaj sutanal ja Judea. Soc ay ni ja ba Jerusaleni soc jach ni ja ma' tey ba sti ja' ja ba Tiro soc ja ba Sidoni. Jacye ba oj smaclaye ja yabal ja Diosi soc ba oj cho aaji tojbuc ja xchamelei.
\v 18 Jaxa matic huan ixtalajel yuj ja pucuj jumasa, ja yenlei ch'ac tojbuque.
\v 19 Spetzanil ja cristiano huas sc'ulane fuerza ba oj syame porque huas snaahue que jel ja yipi. Oj ni bi tojbuquea, siquiera huas syamahuei. Y meran nia, spetzanile ch'ac ni tojbuquea.
\s1 Ja Jesusi yala jastal mas lec oj ec' yuj ja cristiano
\r (Mt. 5:1‑12)
\p 
\v 20 Ja Jesusi ti stojtoq'uela lec ja snebuman jumasa ti yal yabyea: ―Ja huenlex ja janec' huaxa naahuex jel ajul abajex ja ba sti sat ja Diosi, ¡jel lec huaxa huilahuex! Ti xa ni ayex ja ba sc'ab ja Diosi.
\v 21 Ja huenlex ja janec' jex c'anc'oni toj oj ajyaniqui, jel lec huaxa huilex. Oj ni coltajananic yuj ja Diosa. Jel lec oj ec' ahuujilex ja huenlex ja huanex oq'uel ja huego, jaxa mas tzaani, jel gusto oj ajyanic.
\v 22 Jel lec oj ec' ahuujilex ta coraja xta huax yilahuex ja cristiano jumasa, mi c'ax bob smojuquexi, quechan c'a sloile ja' huax yutajex eq'ue. Ta mix bob abjuc ja hua biilexi, ta ja c'a ja hua mulex yuj ja huaxa c'uanonexi yuj ja ti ni coelon jan ja ba satq'uinali,
\v 23 Cuando jach huan c'ulajel ahuilexi, mas to ajyanic gusto. Chaananic yuj ja hua gustoexi. A jac ac'ujolex ja hua majtanex nolobal ahuilex ja ba satq'uinali, jel nihuan juntiro. Ja jastal oj yixtalauquex ja huenlexi, jach ni ixtalajiye ja aluman‑Dios jumasa ja najatei.
\v 24 Pobre ja huenlex ja matic rico ayex huaxa huabyexi. ¡Jel ajul abajex juntiro! Ja jastal ayexi, jacha ni oj ajyanica.
\v 25 Jaxa huenlex ja janec' mi jas huas sc'ulan ahuilex palta, ¡jel ajul abajex! Oj ni c'otuc ja c'ac'u cuando mi jas oja taexi. Jaxa huenlex ja ma' ja huan xta xa jautz'un abajex tzee ja huegoi, jaxa mas tzaani ti oja huilex ta mi oj meba oc'anic leca. Oj ni oc' xchabil ja hua satexa.
\v 26 ¡Jel ajul abaj ja huenlexi ta jel c'a huas stoyohuex ja cristiano! Eso sí, jach ni toyjiye ja ma' huas stoyo sbaj ja najate que aluman‑Dios bi.
\s1 Yaj xa huab ja hua condra
\r (Mt. 5:38‑48; 7:12)
\p 
\v 27 Pero ja huenlexi ja janec' huaxa huabyex slugaril ja jas huax cala, yaj xa huab ja hua condraexi. C'ulanic yi lec ja ma' coraja huax yilahuexi. Huax cala huabyex, pero meran.
\v 28 C'anahuic yi ja Diosi que oj sc'ul bendiciar ja hua condraexi. C'umanic ja Dios sbaj ja ma' miicben sbej ja jas huax yala bajexi.
\v 29 Ta ay c'a ma' huax yaa hui vuelta ba hua choji, cho sutu yi ja jun lado. Ta ay c'a ma' huas sapa hui ja hua c'ui, cho aa yi ja hua camisola.
\v 30 Chican ma' ay jas huas sc'ana hui, aa yi. Ta ay c'a ma' huas sbajan ja hua jas abaji, mi lom xa c'ana yi ba oj ya paxuc ahui.
\v 31 Ja jastal huaxa c'anahuex lec oj sc'uluc ahuilex ja cristiano, jach c'ulanic yi ja huenlex chomajquili.
\v 32 Ta quechan c'a yaj huaxa huabyex ja ma' yaj huax yabyexi, pues ja jahui lom ni altiroa. Como jach ni ja mulanumi, yaj ni huax yab ja ma' yaj huax abji yuji.
\v 33 Quechan c'a huaxa c'ulanex yi lec ja ma' lec huas sc'ulan ahuilexi, mi ni ay sbeja. Jach ni ja mulanum jumasa tac. Jach ni huax cho sc'ulan sbajea.
\v 34 Ta ay c'a jas ahuioj, oj jac majuc ahui, oja huaa yi yuj ja huaxa naa que oj c'otuc ja c'ac'u ay jas oj yaa hui ja yeni, ja jahui mi jas yioj. Como jach ni ja mulanum jumasa chomajquili. Huas smaja sbaje soc ja smoj mulanumili.
\v 35 Pero ja huenlexi yaj xa huabyex ja ma' condra huax yilahuexi. C'ulanic yi lec. Aahuic yi majan, mi jauc ja q'uelan asatex que ay jas oj yaa huilex ja huenlexi. Ta jach c'a huaxa c'ulanex, jel nihuan juntiro ja hua majtanex oj yaa huilex ja Diosi. Oj iljuc que yuninex ja Dios jel nihuani. Como jach ni ja yeni, jel yaj huax yab ja ma' mi ni stz'acatal huas sc'anahuei soc ja ma' jel timasani.
\v 36 Talnayic syaujulal ja yenle ja ma' jel ajul ja sbajei ja jastal ni ja hua Tatex jel huas stalna ja hua yaujulalex ja huenlexi.
\s1 Mi lom xa huaa huochel ja otro cristiano
\r (Mt. 7:1‑5)
\p 
\v 37 Mi lom xa huaa huochel ja otro cristiano. Ta mi c'a huaxa huaa huochel ja huen, jach ni ja huen, mi oj aajan ochelal. Mi lom xa tzujba ja hua moji. Mi c'a huaxa tzujba ja hua moji, jach ni ja hueni, mi oj cho tzujbajanan. C'ulanic perdonar. Huan c'a xa c'ulanex perdonar ja hua mojexi, jach ni ja hueni, oj c'ulajanan perdonar.
\v 38 Ay c'a jas ahuiojex, aahuic yi ja hua mojexi. Oj ni cho aajuc ahuilex mas ja huenlexa. Ja jastal huaxa huaa yi ja hua mojexi, jach ni oj cho ya cumxuc ahuilexa. Ja sbisol oj aajuc ahuilexi, tzaubal ni ja bis jahua. Mi jaxanuc oj aajuc ahuilex. T'enubal lec soc huosan lec.
\v 39 Ja Jesusi ti cho yala otro jun loila: ―Ay jitzan maestro lajan soc ja ma' tupel ja satei. Ilahuil ja ma' tupel ja sati. Mi ni modo oj bob see yi ja sbej ja smoj tupel satili. Ti c'a huane bejyel ba yoj huitzi, ta ay c'a jun q'ueen, ti oj moc'uque lajan ba yoj q'ueeni.
\v 40 Q'uelahuil jun cristiano huan jeejel yi yuj ja smaestro. Cuando huan tox och jeejuc yi, mas jel huas snaa juntiro ja smaestro. Pero cuando huax ch'ac sneb spetzanil ja jas oj jeejuc yii, entonces ja ma' sea, ja' ni oj iijuc ja smodo, sea lec ma sea malo.
\v 41 ¿Jas lom huaxa q'uela ja stz'iilelal ja sat ja hua huermano pero mas to jel nihuan tey ba hua baj ja hueni, iday, mi ni huaxa huaa yi casoa?
\v 42 Majla quijtz'in, la chi. Oj ca eluc ahui ja stz'iilelal ja hua sati, pero hua baj ja hueni, ¡mi ni icben sbej jastal aya! ¡Jastal modo oja hual yab jachuc ja hua huermano! ¡Toj chab cara aya! A el bajtan ja jas ay tey ba yoj ja hua sati. Jachuc, ti oj bob ahuil q'uinal oj hua el yi ja stz'iilelal ja sat ja hua huermano, xchi.
\s1 Ja tei huax naaxi yuj ja sati
\r (Mt. 7:17‑20; 12:34‑35)
\p 
\v 43 Jun sate' ba jel piero, mi oja hual que lec ja steili. Jaxa jun sate' ba tzamal, mi oja hual que ti jac ba jun mal te'.
\v 44 Yuj ja sat ja tei, ti huax naaxi jas tiq'ue teila. Q'uelahuil ja q'uehuexi. Mi ni modo oja hual que steil q'uiix. Soc mi ni oja tul pelul ja ba steil jun morax.
\v 45 Jayuj jachuc ja cristiano. Ja ma' toj ayi, yuj ni toj ay ja ba sc'ujola. Jaxa cristiano ja ma' toj malo, yuj ni jach ay ja ba sc'ujola. Ja jas ay ja ba sc'ujoli, jach ni huax el ja ba stia.
\s1 Ja naitz cajan ta ec' ja ba sat luumi
\r (Mt. 7:24‑27)
\p 
\v 46 Eso sí, ja huenlexi huaxa hualahuex ja huajualonex pero lom nia. Mi ni huaxa c'ulanex ja jas huax calai, xchi ja Jesusi.
\v 47 Spetzanil ja ma' huax jac smacla ja jas huax cala, huan ni sc'uanea, oj cala huabyex machunc'a oj slaji.
\v 48 Lajan soc jun huinic ja ma' huas sc'ulan ja snaji. Tz'unan lec huax yaa cani. Jel tzatz huax cani. Jaxa mas tzaani jac ja butjai. Spuctzin sbaj ja ba sat ja naitz jahui, pero mi ni huax nijquia yuj ja tz'unan ni lec ja syojyali.
\v 49 Jaxa ma' huas smacla ja jas huax cala pero lom nia, mi ni huas sc'uana, ja yeni lajan soc ja ma' huas sc'ulan ja snaji pero huan ita xyaa cajan ja ba sat luumi. Mi huas stz'apa lec ja yipi. Yajni jac ja butjai, huas spuctzin sbaj ja ba sat ja naitz jahui. Soc ja jahui, uchpiji ja naitzi. Ti huaj cayan ja ba sat ja jai, xchi ja Jesusi.
\s1 Aaji tojbuc ja smozo ja sepe ja soldado jumasa
\r (Mt. 8:5‑13)
\c 7
\p 
\v 1 Jaxa Jesusi cuando ch'ac yal yab ja cristiano ja jastal jahui, ti xa huaj ja ba Capernaum.
\v 2 Jaxa tihui tey jun scapitan ja soldado jumasa. Ja yeni ay jun smozo jel yajtanubal yuj, jaxa mozo jahui, jel xa yioj. Lajan soc oj xa chamuc.
\v 3 Ja capitani cuando yab yabalil ja jas huan sc'ulajel ec' ja Jesusi, ti seca chaboxe judio jumasa, ja ma' banquilal yujilei. Huajye ba oj sc'an yi stz'acatal ta ay modo oj jacuc ba oj ya tojbuc ja smozo.
\v 4 Jaxa banquilal jumasa jahui ti huajye ja bay ja Jesusi. Ti och sc'ane yi pavor leca: ―¿Mi ma oja talna syaujulal ba? Pero ¡lequil cristiano tac!
\v 5 Eso sí, ja yeni tuc raza nia pero huan ni sc'anahuotica. Yuj ja yeni, ya c'ulajuc ja iglesia ja ba jchonabilticoni, xchiye.
\v 6 Jaxa Jesusi ti huaj soc ja yenlei. Cuando mojan xa yioje ja snaj ja capitani, jaxa capitani ti seca chaboxe yamigoa ba oj yal yab ja Jesusi: ―Cajual, mi xa bi t'ilanuc oj huajan och masan. Jel bi oj q'uixhuuc ahuuj
\v 7 Jayuj mi ni huax jac staaa. Malan bi soc oja hual que oj tojbuc ja smozo, soc ja jahui, oj ni bi tojbuca.
\v 8 Porque q'uelahuile, ja yeni mandar bi ay, iday, huax cho sc'ulan mandar ja soldado jumasa. Ta huan c'a bix yal yab ja jun iti, caax, ta huax yutaj, oj bi huajuc. Soc ta huan c'a bi spaya jan ja otro juni, la, ta huax yutaj, huan ni bix jaca. Jaxa smozo, c'ulan ja iti, ta huan c'a bix yutaj, huan ni bi sc'ulana, ¡jauc to ma bi ja hueni mi oj ni bob ac'uluc ja jas huaxa c'ana oja c'uluqui!
\v 9 Ja ch'ac yab ja jastal it ja Jesusi, juntiro och ja spensari. Ti sutu sbaja. Yal yab ja cristiano ja matic smoji: ―Meran huax cala huabyex, mi ni june ja israeleño jumasa quila huas sc'uan ja jastal ja huinic iti, iday, ja yeni tzeil cristiano ni juntiroa, xchi.
\v 10 Jaxa jecabanum jahui, huaj to c'otuque ja ba snaj ja capitani, lec xa ni c'ot stae ja mozo jahua.
\s1 Aaji sac‑huuc ja yal ja viguda
\p 
\v 11 Ja mas tzaani ja Jesusi ti huaj ja ba jun chonab sbiil Naín. Ti smoj ja snebumani soc jun nole cristiano.
\v 12 Oj xa stae altiro ja spuertail ja chonabi, huaj to yile, ti q'uechubal jan jun chamhuinic. Viguda ay ja snani, jaxa viguda jahui quechan altiro yal yioj ajyi ja iti, iday chami. Soc jel jitzan ja cristiano suinquil ja chonab jahui ti smojonej ja viguda jahui.
\v 13 Cuando yila ja Cajualtiqui, ti stalna syaujulal ja nanal jahui. Ti yal yaba: ―Mi la oq'ui, xyutaj.
\v 14 Ti och c'ubana. Ti syama ja scajonil ja chamhuiniqui, jaxa matic q'uechan yuji ti c'otye tec'ana. Ti yala ja Jesusi: ―Hijo, c'uan ja jas huax cala huabi, q'uean xa, x'utji.
\v 15 Jaxa yen ja ma' cham ta ajyi, ti q'ue culana. Ti och c'umanuca. Jaxa Jesusi ti yal yab ja snani: ―Ja huego ti xa ay ja hua huali, xchi.
\v 16 Spetzanile och xihuele. Och yae yi stz'acatal ja Diosi: ―Ja aluman‑Dios iti jel nihuan juntiro. Sea ta ni sbaj quitica. Dios ni jac ta scoltayotica porque sbajotic nia, xchiye xta.
\v 17 Ja yabalil ja Jesusi juntiro pucxi ec' ja ba spetzanil ja Judea soc ja ba sutanal ja lugar jahui.
\s1 Ja Juani seca ja secabanum jumasa ja bay ja Jesusi
\r (Mt. 11:2‑19)
\p 
\v 18 Jaxa snebuman jumasa ja Juani ti huaj yale yab ja Juani spetzanil ja jas ajc'ach huan sc'ulajel ec' ja Jesusi. Jaxa Juani ti spaya jan chabe ja snebumani.
\v 19 Ti yala que oj huaj sobe yi ta yena ni ja ma' secunej jan ja Diosi ma ay to ma' otro oj to majlaticon: ―Jach oja hualex yabi, xchi ja Juani. Jaxa snebuman ja Juani ti huajye ja bay ja Jesusi.
\v 20 Cuando c'otye ja huinique jumasa jahui, ti yalahuea: ―Ja yen ja Juan ja ma' huax yaa bautismo, yen secahuoticon. Oj bi jobticon ahui ta huena ni ja ma' secunej ja Diosi ma t'ilan oj to jmajlaticon, xchiye.
\v 21 Iday, ti to tec'an ec' ja yenlei, huaj to yile, ja Jesusi ya tojbuc jitzan ja ma' mi lec ayuqui soc ja ma' ixtalanubal yuj ja pucuji. Jitzan ja ma' tupel ja sati ch'ac ya yil q'uinal ja ora jahui.
\v 22 Ja Jesusi ti xa yalaa: ―Caaxic, cax alahuic yab ja Juani ja jastal ahuilahuexi soc jastal ahuabyexi. Ja ma' tupel ja sati huan xax yila q'uinal, jaxa ma' renco ayi, toj xa huax bejyiye, jaxa ma' huan c'ael ja sbacteli, naca lec xa aye. Jachuc ja ma' mix yab q'uinali, huan xax yabye, soc ja ma' cham ta ajyi, ch'ac ni sac‑huuquea. Ja ma' mi jas yioji huan aljel yabye ja abal it jel tzamali.
\v 23 Jel lec oj ec' yujil ja ma' mix ec' sc'ujol ta mi quenuc ni ja jecubalon yuj ja Diosi, xchi ja Jesusi.
\v 24 Yajni huaj ja chahuane secabanum ja Juani, jaxa Jesusi ti och sta ti' ja Juani, como ti to ni canye jun nole ja cristiano: ―Jaxa cuando huajyex ja ba ch'ayan lugari, ¿jasunc'a huaj ahuilexi? ¿Yuj ama huaj ahuilex jun huinic lajan soc ja aj huan cumtz'ijel yuj ja iq'ui?
\v 25 Entonces ¿jasunc'a ja huilahuexi? ¿Yuj ama huaj ahuilex jun huinic ba jel tzamal juntiro ja sc'ui? Jach c'a, yuj ti huajyex ja ba snaj ja reyi porque ja tihui, ti ni aye ja ma' jel tzamal ja sc'uei.
\v 26 ¿Jastal lec huajyex ja ba ch'ayan lugar jahui? ¿Yuj ama huaj ahuilex junuc ja yaluman‑Diosi? Meran nia, ja Juani aluman‑Dios nia. Pero mi quechanuca. Ay otro atel sc'ulan.
\v 27 Ja huinic jahui, yena ni ja ma' taubal ti' ja ba slibro ja Diosi. Yala que oj jecjuc ba oj sloilta ec' ja cabali. Ja yeni bajtan bi oj ya q'ueuc ja ateli, ti xa oj q'ue atul ja hua huatel ja hueni, jach ni xchi tac. Yuj ja jas huas sea ja yeni jayuj puesto oj ajyuc ja cristiano ba oj sc'uuc ja jas oja loilta ja hueni, xchi ja yabal ja Diosi.
\v 28 Mi ni june ma' ac'ubal yi yatel como jastal ajyi yi ja aluman‑Dios Juani. Jel nihuan ja yateli pero iday, ay to mas jel nihuan que yuj ja yatel ac'ubal yi. Q'uelahuile ja jastal ja smandar ja Diosi. Huas staa jun cristiano ba jel ch'in juntiro huax ilji, ti huax yila jastal yuntiquil. ¡Pero mas to jel nihuan juntiro ja jas huas sc'ulan ja Dios tac!
\v 29 Jitzan lec ja cristiano, hasta ja ma' huas stzomohue ja taq'uini, ja cuando ch'ac yabye ja jas yala ja Jesusi, ti jac sc'ujole que jel ni tzamal ja jas huas sc'ulan ja Diosi, como aaji ni yie ja' yuj ja Juana.
\v 30 Jaxa fariseo jumasa soc ja ma' huas seahue ja smandar ja Moisesi, eso sí, ja Diosi huas sc'ana oj scolta ajyi pero mi ni modo sc'anahuea. Mi ni jotye ba oj bob aajuc yile ja' yuj ja Juani.
\v 31 Ti yala ja Jesusi: ―Oj cala huabyex machunc'a oj slaj ja cristiano ja tiempo iti.
\v 32 Lajane soc chab c'ole yal untic huax yiaj sbaje tajnel ja ba nalan patio. Yen ta huax yautalaan sbaje: Ja hualahuex oj c'ultic q'uin. Ja quenticoni juuticon ta ja ajmayi, jaxa huenlexi mi ni huala chaaniyexa. Cham ja yal cali, xchi june ja yenlei. Ja quenticoni huanoticon oq'uel, jaxa huenlexi, mi ni modo la ocyexa. ¿Jasyuj jach huaxa c'ulanex ba? Jach huax yala sbaje ja yal untiqui.
\v 33 Ja cristiano, ja' ni smoj ja yal untic jahui porque ja jastal ja smodo ja Juani, jel huas scomo ja suaeli soc mix yuaj ja yaalel tz'usubi, jaxa huenlexi huaxa hualahuex que pucuj.
\v 34 Jaxa queni ti ni coelon jan ja ba satq'uinali, iday, huala huaayon. Huax cuaj ja yaalel tz'usubi y huaxa huutajonex chitamil. Huax hua ochconex yacbumil. Huaxa hualahuex que ja' jmoj ja ma' huas syama lom ja taq'uini, ja' jmoj ja mulanum jumasa.
\v 35 Pero ja ma' huax yaa sbaj soc ja Diosi, ja yenlei mi jauc huas sc'ulan pensar ja jastal huaxa c'ulan pensar ja huenlexi. Gusto ni huax yilahue ja jas huan sc'ulajel ja Diosi.
\s1 Ja fariseo Simoni sloco huael ja Jesusi
\p 
\v 36 June ja fariseo ti sloco huael ja Jesusi. Ja och c'ot ja ba snaj ja fariseo, ti aaji yi ja suaeli. Ti och huauca.
\v 37 Huaj to yile, ti jac jun ixuc suinquil ja chonab jahui. Jaxa ixuqui jel juntiro huas staa smul soc ja huiniqui. Como yab yabalil que ti locobal huael ja Jesús ja ba snaj ja fariseo jahui, ti yiaj jan jun perpume, jaxa yetal ja perpume jahui, c'ulubal soc jun ton alabastro sbiil.
\v 38 Ja ixuc jahui ti och ba stz'eel ja Jesusi ja ba lado xijan ja yoqui. Ti och oc'uca. Ti co ja yaalel sat ja ba yoc ja Jesusi. Ti och scus soc ja s'olomi. Ti och yujtz'uc ja yoqui. Saxa can yi ja perpume ja ba yoc ja Jesusi.
\v 39 Ja fariseo ja ma' sloconej huael ja Jesusi, cuando yila jastal iti, ti och tz'iptz'unuc ja sc'ujoli: ―Ja iti, ta meran c'a aluman‑Diosi, oj jac sc'ujol ma' huan syamjel ja yoqui. Oj snaa jas tiq'ueil ja ixuc iti. ¡Xihuel ja sbaj ja smul tac! Jach huan c'umal ja sc'ujol ja fariseo.
\v 40 ―Simón, ay jas oj cala huabi, xchi ja Jesusi. ―Pues ala cab ba, Maestro, xchi ja Simoni.
\v 41 ―Ay jun huinic yaa yi majan taq'uin chahuane huinique. Ja juni yaa yi jel quinientos pesos, jaxa otro juni, cincuenta pesos.
\v 42 Pero ja yenlei mi jas yioje ba oj stupe, jayuj c'ulajiye perdonar xchahuanile. Ala cab ba, ja chahuane huinique jahui, ¿machunc'a mas yaj yab ja ma' yaa jel ja taq'uini?
\v 43 Ti yala ja Simoni: ―Ja quen lajan soc ja' huax cab ja ma' mas jitzan ja sel ch'ayji yii, xchi. ―Pues ja' nia, xchi ja Jesusi.
\v 44 Ti sutu sbaj ja ba lado bay ja ixuqui. Ti yal yab ja Simoni: ―Q'uelahuil ja ixuc iti. Ja huen, ochyon ja ba hua naji, iday, mi ahuaa qui ja' ja sbaj coqui. Pero ja yeni ja' spec'a ja yaalel sati ja sac'a qui ja coqui. Ja' soc ja s'olomi scusu qui, xchi.
\v 45 Ja hueni mi ni ahuaa qui Dios ja ochyon juli, mi ni ahuujtz'an qui ja jc'abi pero ja yeni quechan pavor och jule, mix yaa can yujtz'ajel ja coqui.
\v 46 Mi ajaxa yi aceite ja j'olomi pero ja yeni jac sax qui perpume ja ba coqui.
\v 47 Jayuj huax cala huabi, ja ixuc iti jel huas syajtayon juntiro porque ja smul jel jitzani, c'ulaji ta perdonar. Pero ja ma' quechan t'usan ja smul huax c'ulaji perdonari, jach ni, quechan t'usan huax yajtani.
\v 48 Ja Jesusi ti yal yab ja ixuqui: ―Ja hua muli tupel xa nia, x'utji ja ixuc jahui.
\v 49 Jaxa matic lajan huane huaeli ti och yal sbaje yenle itaa: ―¡Janec' to ni ja it ja huax yala huas sc'ulan perdonar ja mulali! xchiye xta.
\v 50 Pero ja Jesusi ti yal yab ja ixuc jahui: ―Yuj ja hua c'uani, jayuj coltajiya. Ja yaani cax gusto, xyutaj.
\s1 Ja ixuque ja ma' scolta ja Jesusi
\c 8
\p 
\v 1 Jaxa mas tzaan t'usani, ja Jesusi ti xa huaja. Huaj sloilta ec' ja yabal ja Diosi. Huan yaljel ec' ja jastal huas sc'ulan mandar ja Diosi. Ti huaj ba jitzan ja chonabi soc ja yal hacienda jumasa. Ja lajchahuane snebumani ja' ni smoj ec'a.
\v 2 Soc tey chaboxe ixuquea. Ja ixuque jahui c'ulajiye ta librar soc ja pucuji soc aaji tojbuque ja xchamelei. June ja yenlei, ja' ni ja María ja ma' sbiilan magdaleña. Yena ni ja ma' ixtalanubal yuj juque pucuj ajyi.
\v 3 Soc tey ja Juana, ja' statam ja Chuza. Jaxa Chuza, ac'ubal yi jun yatel yuj ja rey Herodesi. Soc tey jun ixuc Susana sbiil soc ay jitzan ixuque huax coltaniye eq'ue. Huane yaajel ja jas yioje t'usani.
\s1 Ja loil sbaj ja tica‑inati
\r (Mt. 13:1‑9; Mr. 4:1‑9)
\p 
\v 4 Jel aaye elye ja ba xchonabilei soc ja yal yaciendaei ba oj huaj yile ja Jesusi. Cuando ch'ac stzom sbaj jitzan lec ja cristiano, jaxa Jesusi ti och see yile soc puro loil:
\v 5 ―Q'uelahuilex, jun huinic huaj stic inat. Cuando huan sticjel eq'ue, iday, ay ba huax co ba yoj bej, ti huax batji cana. Huax jac ja yalchani, ti huas stulu ela.
\v 6 Soc ay ba co yoj ton ba mey lec ja luumi. Yajni el q'uen ja ba sat luumi, huego tacji porque taquin lugar. Mi yaaxuc ja luumi.
\v 7 Soc ay ba co ba yoj q'uiix. Ja inat jahui ti el q'uen lajan soc ja q'uiixi, jaxa mas tzaani, c'utzji sq'uiel ja inati.
\v 8 Soc ay ba co ba lequil luumi. Q'uii. Ajyi sat. Ay ba yaa cien ja sati. Yajni ch'ac yal ja jastal iti, ti c'umani tzatz leca: ―Ja ma' ay xchiquini, a yabi, xchi.
\s1 Ja jastal ja sbej ja loil it yala ja Jesusi
\r (Mt. 13:10‑17; Mr. 4:10‑12)
\p 
\v 9 Ti och sob ja snebuman jumasa: ―¿Jas bej ja loil it ahuala cabticoni? xchiye.
\v 10 Ti yala ja Jesusi: ―Meran nia, soc ni loil huax jea yi ja cristiano. Eso sí, ja yenlei ay sate pero mix yilahue q'uinal. Ay xchiquine pero mix yabye q'uinal. Ja jastal huas sc'ulan mandar ja Diosi mi mero huax abxi claro pero ja huenlexi, sbej ni oja huabyex claroa.
\s1 Ja Jesusi yala jas sbej ja tica‑inati
\r (Mt. 13:18‑23; Mr. 4:13‑20)
\p 
\v 11 Oj cala huabyex jas sbej ja loil iti. Ja inat jahui, ja' ni smoj ja yabal ja Diosi.
\v 12 Ja inat jau co ba yoj beji lajan soc ja ma' huax yab ja yabal ja Diosi pero huax jac ja diablo. Huax aaji ch'ay sc'ujole ja jas yabyei ba mi oj sc'uuque soc mi ni oj cho coltajuquea.
\v 13 Jaxa inat jau co ba yoj toni lajan soc ja ma' jel gusto huax yab ja yabal ja Diosi. Huego huax yala oj sc'uuque pero lom. Mi ni ay yipea. Huas sc'uane chaboxe tiempo pero cuando huax jac jun suocole, ti huax ch'ay ja sc'ujole ja jas huas sc'uanei.
\v 14 Jaxa inat jau co ba yoj q'uiixi lajan soc ja matic huax yabi, ti huax huaja. Jel ja yateli. Ja' huajel sc'ujol ba oj stul sbajei. Quechan huane sc'ulajel pensar ba jel gusto oj ajyuque, jaxa yabal ja Diosi huax yaahue can jun lado. Mi ni t'un huax bob yujilea.
\v 15 Pero ja inat jau co ba lequil luumi lajan soc ja ma' huas sc'uan soc spetzanil ja sc'ujoli. Tola vida puesto aye. Huas sc'uane ja jas huax alji yabyei. Jun xta aye tola vida. Meran huax ilxi que tucbi ja smodoea.
\s1 Ja loil sbaj ja yajlel ja candela
\r (Mr. 4:21‑25)
\p 
\v 16 Ja Jesusi ti cho och yal otro vuelta jun loil: ―Ja jas huax jea lajan soc jastal jun candela. Mi ni jun ma' oj ya ajluc jun candela ba quechan oj snuj soc jun cajón. Mi ni oj yaa ba yib ch'at. Ti oj ya ochuc ba jun candelerio, jaxa ma' huax och ja tihui, oj ni bob yil q'uinala.
\v 17 Porque mi ni modo oj can musan ja jas huax jea. Sbaj ni t'ilan oj chicnajuca. Eso sí, ja huego nac'an musan to t'usan, pero oj ni abxuc sbeja. Claro lec oj abxuc.
\v 18 Aa cuidadoex ja jas huax cala huabyexi. Ja ma' huas sc'uan ja cabali, oj ni ca snaa masa. Pero ja ma' mi huas sc'uan ja cabali, ja janec' t'usan huas snaa, oj ni ch'ay sc'ujola, xchi ja Jesusi.
\s1 C'ot ja snan soc ja yermano jumasa ja Jesusi
\r (Mt. 12:46‑50; Mr. 3:31‑35)
\p 
\v 19 Ti jac ja snan ja Jesusi soc ja yermano jumasa. Pero mi bob ochuque yuj ja jel but'el ja cristiano.
\v 20 Ti alji yab ja Jesusi: ―Ja hua nani soc ja hua huermano jumasa ti aye ba fuera. Huas sc'ana oj sc'umuca, xchiye.
\v 21 Jaxa yeni ti yalaa: ―Ja jnani soc ja quermano jumasa ja' ni ja ma' huax yab ja yabal ja Diosi soc ja ma' huas sc'uanei, xchi ja Jesusi.
\s1 Aaji ch'abajuc ja iq'ui soc ja jai
\r (Mt. 8:23‑27; Mr. 4:35‑41)
\p 
\v 22 Ja Jesusi jun c'ac'u ti q'ue ba jun barcoa. Ti smoj ja snebuman jumasa. ―La xa huajtic ja ba otro lado ja jai, xchi. ―Lec, xchiye. Ti huajyea.
\v 23 Cuando ti xa huan bejyel ja barco ja ba yoj jai, jaxa Jesusi ti och suayela. Ti jac jun tzatzal ic' ja ba yojol ja jai. But' ja' ja yoj sbarcoei. Lajan soc oj xa ibjaaxuc ja barco.
\v 24 Jaxa snebuman jumasa ti huaj syujquese ja Jesusi: ―Maestro, Maestro, xyutaje. Ja huego huantic xa huajel ja'. Ti xa q'ue ja Jesusi. Scomo ja ic' jahui. Ya lamxuc ja yip ja jai. Lamxi juntiro. Xch'ababi xta huaji.
\v 25 Ti yala ja Jesusi: ―¿Baya huaxa c'uanex ba? xchi. Porque huane xta q'uitc'onuc yuj ja xihueli. Juntiro ch'ac och spensare. Ti yala sbaj yenle itaa: ―¿Jas huiniquil ja yen ba? Hasta ja iq'ui soc ja jai huas sc'ulan mandar, ¡pero huax c'uaji yi tac! xchiye.
\s1 Ja gadareño ixtalanubal yuj ja pucuj jumasa
\r (Mt. 8:28‑34; Mr. 5:1‑20)
\p 
\v 26 Ti c'otye ja ba slugar ja gadareño jumasa ja ba mero spunto ja Galilea.
\v 27 Ja Jesusi cuando el c'ot ja ba sti ja jai, ti jac tajuc yuj jun huinic suinquil ja chonabi. Ay xa jitzan tiempo ixtalanubal yuj ja pucuji. Mi xa huan to slapa ja sc'u soc mi xa teyuc ba snaj pero ti xa ni culan ba campo santoa.
\v 28-29 Culan xa yuj ja pucuji jun ta repente huas syama ja huinic jahui, jayuj huax mochji yi soc cadena ja xchanil ja yoc sc'ab ja huiniqui. Pero ja yeni huas sc'utzu ja cadena. Ti huax iiji och fuerza ja ba lugar ch'ayani, pero ja' yujil ja pucuji. Ja huinic jahui cuando yila ja Jesusi, ti sipa sbaj luum ba sti sati. Ja Jesusi ti sc'ulan mandar ja pucuji que oj yacta can ja huinic jahui. Jaxa pucuji ti q'ue ahuanuc tzatz leca: ―¿Jastal aya jmoc ja huen ba Jesús? Ja hueni yunina ni ja Dios jel nihuani. Huax c'ana hui tz'acatal mi lom xa huixtalaanon, xchi ja pucuji pero ti ni ba sti ja huiniqui.
\v 30 ―¿Jas abiil ja hueni? xchi ja Jesusi. ―Como jel ni ayoticon ja quenticona, xchi ja pucuji. Como meran nia. Jel ni aayea huax yixtalaane ja huinic jahui.
\v 31 Ti och c'anjuc yi pavor ja Jesusi que mi bi oj jecjuque ja ba yoj q'uiq'uinali.
\v 32 Ja ba lugar jahui tey jun trozo chitama. Ti huane huael ja ba jun huitz mojani. Jaxa pucuj jumasa ti sc'anahue yi pavor ja Jesusi ba oj jecjuque soc ja chitam jumasa jahui siquiera ba oj ochuque ja ba scuerpoei. ―Pues lec, caaxic, xchi ja Jesusi.
\v 33 Jaxa pucuj jumasa it yaahue can ja huinic jahui. Ti huajye soc ja chitam jumasa, jaxa jun trozo chitam jahui ti sipa sbaje co ja ba snexanal ja huitzi. Ti baltzujiye co man ba yoj ja'. Ti ch'ac siq'ue jaa.
\v 34 Jaxa matic huan stalnajel ja chitam jumasa, yajni yilahue jastal ch'ac huajuqui, ti spacahue ajnela. Ti huaj yae razón ja ba yoj chonabi soc ja ba sti chonabi.
\v 35 Jaxa cristiano jumasa lom xta xnololji ch'ac huaj yile. Ti huajye ja bay ja Jesusi. Ti staahue ja huinic it ma' aaji ta can yuj ja pucuj jumasa. Ti culan ec' ba stz'eel ja Jesusi. Ay xa sc'u soc toj xa ay ja spensari. Jel xiuye juntiro ja cristiano.
\v 36 Jaxa matic ch'ac yil jastal tojbi ja huiniqui ti och yale jastal c'ulaji librar ja ma' ixtalanubal yuj ja pucuj ajyi.
\v 37 Pero ja cristiano ja ba sutanal ja slugar ja gadareño jumasa ti och sc'an yi stz'acatal ja Jesusi que oj bi yacta can ja slugarei. Jel bi huax xiuye juntiro, jayuj ja Jesusi ti cho q'ue ja ba barco. Ti cumxia.
\v 38 Pero cuando mi tox huaj ja Jesusi, jaxa huinic jau ja ma' ixtalanubal ajyi yuj ja pucuji, ti och sc'an yi jitzan stz'acatal ta ay modo oj huaj soc. Pero ja Jesusi ti yalaa:
\v 39 ―Miyuc. Cax ja ba hua naji. Loilta ec' ja jas jel tzamal sc'ulan ahui ja Diosi, x'utji ja huiniqui. Ti huaj ja huiniqui. Ch'ac sloilta ec' ja ba spetzanil ja chonabi ja jastal jel tzamal c'ulaji yi yuj ja Jesusi.
\s1 Ja yunin ja Jairo soc ja ixuc ja ma' syama ja sc'u ja Jesusi
\r (Mt. 9:18‑26; Mr. 5:21‑43)
\p 
\v 40 Yajni cho cumxi jan ja Jesusi, ti xa huan majlajel yuj jun nole cristiano. Mix yilahue ora oj c'otuc.
\v 41 Huaj to yile, ti jac jun huinic sbiil Jairo. Ti huaj tajuc yi sc'aba. Ja yeni ay yatel ja ba yiglesia ja judio jumasa. Ti och sc'an yi pavora ta mey modo oj huajuc ja ba snaji.
\v 42 Porque ay bi jun aq'uix yunin. Quechan bi altiro yena. Ay xa bi yioj mojan lajchahue jabil, iday, jaxa aq'uix jahui, huan xa chamel. Jaxa Jesusi ti yala que oj huaj yila. Cuando ti xa huajumi, jaxa cristiano jumasa ti smoji. Huan xta sbatalaan sbaje.
\v 43 Jaxa ba yojol ja cristiano jahui, tey jun ixuca. Jaxa ixuc jahui ay xa lajchahue jabil mix ec' ja scuenta. Ch'ac ta xch'ac el ja janec' yioji pero mi ni june ja doctor huas snaa jastal oj ya tojbuc ja ixuc jahui.
\v 44 Jaxa huego tey soc ja cristiano jumasa, ja ma' ti nochan ba spatic ja Jesusi. Ti och c'ubana. Huaj syam yi ja snich ja sc'ui, iday, jaxa scuenta, huego huego c'ot tec'an.
\v 45 Jaxa Jesusi ti yalaa: ―¿Machunc'a syamahuoni? xchi. ―Pero mi ni mach'a tac, xchiye spetzanile. Ti yala ja Pedro soc ja smoj jumasa: ―Como ti ni aya ba yoj cristiano tac, Maestro, jayuj huas slatzahua. Huas st'enahua iday, jaxa hueni huana sobjel machunc'a syamahuoni, la chi.
\v 46 ―Pero meran, ay ma' syamahuon porque yab jchiq'uel que ay ma' tojbi cuj porque c'ot man ba jcuerpo, xchi ja Jesusi.
\v 47 Jaxa ixuc jahui yajni yab ja jas yala ja Jesusi, ti jac ja ba stz'eeli. Huan q'uitc'onel. Ti co mec'an ja ba sti sat ja Jesusi. Ti yala satalajel abal jas sbej ja syamai, cho yala jastal huego huego tojbi.
\v 48 Ti yala ja Jesusi: ―Hija, yuj ja hua c'uani, tojbiya ta. Ja yaani, cax gusto, xyutaj.
\v 49 Cuando jach to huan yaljel ja Jesusi, huaj to yile, ti jac june ja suinquil ja snaj ja Jairo. Ti alji yabi: ―Q'uelahuil, ja hua huunini cham ta. Moc xa lomuc ahual yab que oj huajuc ja Maestro.
\v 50 Ja ch'ac yab ja it ja Jesusi, ti yal yab ja Jairo: ―Mix cham ac'ujol, como c'uan. Ja hua huunini oj ni sac‑huuca, xchi.
\v 51 Yajni c'otye ja ba snaj ja Jairo, ti yala que quechan oj och soc ja Pedro soc ja Jacobo soc ja Juani soc ja snan stat ja chamhuiniqui.
\v 52 Jaxa mucuanum jumasa huane xta meba oq'uel. Huane xta staajel ti' ja ma' chameli. Pero ja Jesusi ti yalaa: ―Mi lom la ocyex. Ja aq'uix iti mi chameluc, quechan huan huayel, xchi.
\v 53 Pero ja mucuanum jumasa quechan huas spechtiane. Huan ni snaahue que cham ta nia.
\v 54 Ja Jesusi ti huaj syam yi ja sc'ab ja aq'uixi. Ti sc'uman tzatz leca: ―Nina, q'uean, xyutaj.
\v 55 Jaxa aq'uixi huego huego sacui. Q'uei. Ti yala ja Jesusa: ―Aahuic xa yi ja suaeli, xchi.
\v 56 Jaxa snan stat ja aq'uixi juntiro boboaxiye pero ja Jesusi ti yala que mi ni june ma' oj yale yabye ja jastal sc'ulani.
\s1 Ja Jesusi seca lajchahuane ja snebumani
\r (Mt. 10:5‑15; Mr. 6:7‑13)
\c 9
\p 
\v 1 Ja Jesusi ti seca spayjel ja lajchahuane snebumani. Cuando ti xa tzomanei, ti yalaa: ―Ja yaani huax caa huatelex ba oj hua eluquex ja pucuji, chican jas tiq'ueil soc oj hua tojbuquex ja matic malo ayi, como huan nix caa hui ja hua huipexi.
\v 2 Oj huaj aloiltayex ec' jastal oj ajyuque ja cristiano jumasa cuando huax yaa sbaje ja ba sc'ab ja Diosi. Cax a tojbuquex ja ma' malo ayi.
\v 3 Moc lom jas oja huiex ja ba beji, mi ni hua najbanteexi soc mi ni hua morralexi soc mi ni hua huoot apichiexi soc mi ni hua taq'uinexi, soc moc cho ahuiex otro ac'uex. Quechan oja huiex ja jas lapan ahuujilexi.
\v 4 Ja naitz ja ba huala ochyexi, ti la ajiyexa. Ti oj cho elanica.
\v 5 Pero ta huan c'a la c'otyex ba jun chonab y mi huas sc'ulanex recibir, pues actayic cani. Tzijun can ja spolvoil ja hua huoquexi. A yil can sbaje.
\v 6 Ja ch'ac yal ja jachuqui, ti huajye ja snebuman jumasa. Chol yiaje ja yal hacienda jumasa. Huane sloiltajel ec' ja abal it jel tzamali. Huax cho yaahue tojbuc ja ma' ay xchameli ja ba spetzanil ja lugar jumasa.
\s1 Ja Juani ja ma' yaa bautismo, milji
\r (Mt. 14:1‑12; Mr. 6:14‑29)
\p 
\v 7 Ja Herodes ja ma' jel nihuan ja yateli, ti yab yabalil spetzanil ja jas huan sc'ulajel ec' ja Jesusi. Jel boboaxi juntiro ja spensari como ay ma' huax yala que sacui ta Juan it ma' huax yaa bautismo ajyi, ja' ni ja Juan ja it ma' yaa ni miljuqui.
\v 8 Jaxa tuqui huax yalahue que ja' ni ja aluman‑Dios Elías ba najatei. Soc ay ma' huax yala que ja' ni june ja yaluman‑Dios ba najatei sacui ta bi.
\v 9 Ti yala ja Herodesi: ―Ja Juan jahui, eso sí, quen ca c'utzuc el ja snuq'ui, pero ja jastal huax cab jitzan cosa que ay jas huan c'ulajel eq'ue, ¿machunc'a jau ba? xchi. Huas slea modo jastal oj bob yil ja Jesusi.
\s1 Joe mil huinic aaji huauque
\r (Mt. 14:13‑21; Mr. 6:30‑44; Jn. 6:1‑14)
\p 
\v 10 Cuando cumxiye ja jecabanum jumasa jahui, ti ch'ac xchole ja jastaltic sc'ulanei. Ja Jesusi ti yala que oj huajuque ja ba jun ch'ayan lugara, ja ba meyuc ja cristiano, mojan ba jun yal hacienda sbiil Betsaida.
\v 11 Pero ja cristiano, yajni yabyei, lom xta xnololi ch'ac huajuque. Jaxa Jesusi yajni yila ti xa ay c'ot ja cristiano, ti och see yi jastal oj ajyuque ta huan c'ax yaa sbaje ja ba sc'ab ja Diosi. Soc ch'ac ya tojbuc ja ma' jel ja snesesida soc ja xchamelei.
\v 12 Cuando huan xa tz'elpujel ja c'ac'u, ti jac ja lajchahuanei. Ti yalahuea: ―Jeca xa ja cristiano. Malan oj c'otuque ja ba yal hacienda jumasa ma ja ba yal lugar mojani cosaque oj bob stae majan ja sposadaei. Ja tihui oj staa ja suaelei, pero ja ili, ti aytic ja ba mey cristiano, xchiye.
\v 13 Ti yala ja Jesusi: ―¿Jaxa mi xa huaahuex yi ja suaele ja huenlex ba? Ti yala ja yenlei: ―Ja quentiqui quechan xta joe ala pan quiojtic soc chab chay. Entonces ¿quen oj huaj manticon ja jas oj yabye ja jun montón cristiano iti? xchiye.
\v 14 Porque ja janec' cristiano jahui, ja quechan ja huiniquei, ay mojan joe mil. Ja Jesusi ti yal yab ja snebuman jumasa: ―Cax alahuic yab oj ochuque culan, a yi sbaje cincuenta cada c'ole, xchi ja Jesusi.
\v 15 Jach ni sc'ulanea. Yalahue yab oj ochuque culan spetzanile.
\v 16 Ja Jesusi ti yiaj ja joe pani soc ja chab chayi. Ti sq'uela q'ue ja satq'uinali. Ti sc'ana yi stz'acatal ja Diosi. Ti och xet' ja pani. Yaa yi ja snebuman jumasa, jaxa snebumani ya ec' yi ja cristiano jumasa.
\v 17 Ti och huaa spetzanil ja cristiano. Butye lec. Jaxa jas can sobrai, ti stzomohuea, iday, lajchahue mooch but'i.
\s1 Ja Pedro yala que ja Jesusi, yena ni ja Cristo
\r (Mt. 16:13‑19; Mr. 8:27‑29)
\p 
\v 18 Jun c'ac'u ja Jesusi soc ja snebumani ti huajye ba jun ch'ayan lugar. Ti huaj sc'umuc ja Dios ja Jesusi. Jaxa mas tzaani ti och sob ja Jesusi: ―Jaxa cristiano ba, ¿mach ayon huax yalahue ba? xchi.
\v 19 Ti sac'a jan ja snebuman jumasa: ―Ay ma' huax yalahue que huena ni bi ja Juan it huax yaa bautismo ajyi. Jaxa tuqui huax yalahue que aluman‑Dios Eliasa, jaxa tuqui huax yalahue que huena ni bi june ja aluman‑Dios ba najatei sacuiya ta bi, xchiye.
\v 20 ―Jaxa huenlexi, ¿machunquilon huaxa hualahuex ba? xchi ja Jesusi. ―Huena ni ja Cristo tzaubala ni yuj ja Dios tac, xchi ja Pedro.
\s1 Ja Jesús yala que oj ni chamuca
\r (Mt. 16:20‑28; Mr. 8:30‑9:1)
\p 
\v 21 Pero ja yeni ti scomo ja snebuman jumasa ba mi ma' jas oj yal yab ja iti, pero sc'ana lec pavor.
\v 22 Ti yalaa: ―Ja queni ti coyon jan ja ba satq'uinali pero anima, oj ni quii jitzan huocola. Ja banquilal jumasa mi oj sc'ulucon recibir soc jach ni ja nihuac pagre jumasa. Mi ni ja matic huas sea ja smandar ja Moisesi, mi oj sc'ulucone recibir. T'ilan ni oj chamcona pero ba yoxil c'ac'u oj ni sac‑huucona.
\v 23 Ja Jesusi ti spaya jan ja cristiano jumasa. Ti och yal yabyea: ―Ta ay c'a ma' huas sc'ana ajyuc jmoqui, mi yen mismo oj syajta sbaj. A yaa sbaj juntiro cada c'ac'u, anima huax aaji locan ja ba cruzi. A sneb ja jmodo ja queni.
\v 24 Spetzanil ja ma' huajel sc'ujol que oj ajyuc tzamali, huan nix ch'aya sbaja. Pero ja ma' huax yala, ta huala chamyon yuj ja huax c'uan ja hueni, ti la chamyona, pero siquiera oj ajyuc lec ja caltzili ‑ ja ma' jach huax yala, pues ja yeni oj ni staa ja svida ba jel leca.
\v 25 Ja ma' tey ba sc'ab spetzanil ja jas ay ja ba mundo, pero ta huan c'ax ch'ay ja yaltzili, ¿ja' ma ba slequil ja jau ba?
\v 26 Ja queni ti ni coelon jan ja ba satq'uinali pero oj xa cumxucon ja tihui. Pero oj cho jacuc ja c'ac'u ja oj cocon jani, jaxa c'ac'u jahui oj lijpuc juntiro ja yijlab ja jTati. Jel ni tzamal oj jacon soc ja yangel ja Diosi. Pero ja ma' q'uixhui yuj ja cabali, jach ni ja queni, oj q'uixhuucon yujile ja ba sti sat ja jTat ja ora jahui.
\v 27 Huax cala, pero meran, ja janec' ayex ja ili, ay chaboxe ja ma' oj xa yil jastal ay ja ba huas sc'ulan mandar ja Diosi pero oj xa yile mas ligero, pero mi jauc ba oj xa chamuque.
\s1 Ja Jesusi stucbes sbaj
\r (Mt. 17:1‑8; Mr. 9:2‑8)
\p 
\v 28 Ja ch'ac yal ja jastal jau ja Jesusi, ti ec' mojan huaxaque c'ac'ua, entonces jaxa ora jahui, ja Jesusi ti huaj ba huitz. Ja' smoj ja Pedro soc ja Juan soc ja Jacobo. Ti huaj sc'umuc ja Dios ja Jesusi.
\v 29 Cuando huan sc'umajel ja Dios ja Jesusi, huaj to yile, tucbi juntiro ja sati, jaxa sc'ui, sact'ost'os xta ch'ac huajuc. Lijpi juntiro.
\v 30 Huaj to cho yile, tey chab huinica. Ti huane loil soc ja Jesusi, jaxa huinique jahui, ja' ni ja Moisesi soc ja Eliasi.
\v 31 Jaxa bayei, joybanubale yuj ja luzi, pero huax lijpi juntiro. Ja' huane yaljel ja jastal oj to yii huocol ja ba Jerusalén ja Jesusi. Ja' ni mero sloile ja jastal ni oj chamuqui.
\v 32 Jaxa Pedro soc ja chahuane smoji jel juntiro ja suayelei pero huas sc'ulane fuerza oj ec'uc ja suayelei siquiera ba oj yile ja jastal huan lijpel ja Jesusi soc ja chahuane huinic ti smoji.
\v 33 Jaxa chahuane jahui ti spila sbaj soc ja Jesusi. Cuando huajume xa, ti yala ja Pedro: ―Maestro, ¡pe jel lec ja ti aytic ja il tac! Oj c'ulticon huego oxe yal naitz, june ja hua baji soc june sbaj ja Moisesi soc june sbaj ja Eliasi. Pero lom huan bulbunuc ja Pedro. Mi huas snaa jasunc'a huan yaljeli.
\v 34 Cuando huan yaljel jachuc ja Pedro, huaj to yile, cho jac jun ason, ti ta musjiyea. Jel xiuye yajni yilahue ja ason jahui.
\v 35 Jaxa ba yojol ja asoni ti yabye jun c'umala: ―Ja iti, ja' ni mero cunin jel yaj huax cabi. Maclayic ja jas huax yala, xchi ja c'umali.
\v 36 Cuando ch'ac ja c'umal jahui, huaj to yile, stuch'il xa ja Jesusi. Jaxa yenlei mi ni june ma' c'umani yujilea. Ja c'ac'u jumasa jahui, mi ni june ma' jas yalahue yab ja jas yilahuei.
\s1 Tojbi jun querem ixtalanubal yuj ja pucuji
\r (Mt. 17:14‑21; Mr. 9:14‑29)
\p 
\v 37 Jaxa ba xchabil c'ac'u ti xa coye ba huitz jahui, jaxa cristiano jumasa, jitzan lec jac stae ja Jesusi.
\v 38 Tey jun huinic ja ba yojol ja cristiano, jaxa huinic jahui ti och c'umanuc tzatz leca: ―Maestro, tz'acatalucaa. La ila qui ja cunini. Quechan ni altiro quioj tac.
\v 39 Huax jac yamjuc yuj ja tan pucuji. Huax ya ahuanuc. Huax ya tup yic! Huax ya puuxanuc ja stii. Jel huax yixtalaan juntiro. Jel huocol huax ya jijluc can t'usan.
\v 40 Jc'ana ta yi stz'acatal ja hua nebuman jumasa ba oj sc'ul mandar ja pucuj ba oj yacta cani pero mi bob yujile, xchi ja huiniqui.
\v 41 Ti yala ja Jesusi: ―A, ja cristiano iti mi ni t'un huas sc'uane. ¡Jel ch'uuy ja sc'ujolei! Ay xa tiempo ti ayex jmoca pero lom nia. ¿Jaye to tiempo oj caa jpasensia amoquex? Ti yal yab ja huiniqui: ―Cax iaj jan qui ja hua huunini, xyutaj.
\v 42 Ja querem jahui cuando mojan xa ay ja ba stz'eel ja Jesusi, jaxa tan pucuji ti cho sipa man luuma. Ya tup yic'. Jaxa Jesusi ti yal yab oj eluc ja tan pucuj jahui. Ti tojbi huego ja queremi. Ti xa yaa ba sc'ab ja stati.
\v 43 Spetzanil ja cristiano jel och ja spensare ja yilahue ja jas jel tzamal huan sc'ulajel ja Diosi.
\s1 Ja Jesusi yala otro vuelta que oj ni chamuca
\r (Mt. 17:22‑23; Mr. 9:30‑32)
\p Cuando huane to lec pensar ja cristiano, jaxa Jesusi ti yal yab ja snebuman jumasa:
\v 44 ―Pero ja huenlexi, abyic lec ja jas oj cala huabyexi. Ja queni ti ni coelon jan ja ba satq'uinali pero oj xa c'ulajucon endregal ja ba sc'ab ja cristiano jumasa, xchi.
\v 45 Pero ja snebuman jumasa mi yabye sbej ja jas alji yabyei. Lajan soc macji ja xchiquinei. Huas sc'ana oj sobe yi jas sbej pero jel huane xihuel.
\s1 ¿Machunc'a mas nihuan ba?
\r (Mt. 18:1‑5; Mr. 9:33‑37)
\p 
\v 46 Ti q'ue ja sloile ja snebuman jumasa: ―¿Mach'a ma junuca ja ma' mas nihuan oj huajuc cujtic ja quentiqui? Jach ni huane yaljela.
\v 47 Jaxa Jesusi como huas snaa jastal ay ja spensarei, ti yiaj jan jun yal querema. Ti ya tec'an ja ba stz'eeli.
\v 48 Ti yalaa: ―Q'uelahuilex ja yal querem iti. Ta ay c'a ma' huas squitz'a yuj ja queni, quena ni huas squitz'ahuona. Jaxa ma' huas squitz'ahuon ja queni, ja' ni huas squitz'a ja jTat ja ma' seconejon coni. Ja huenlex ja ma' jun ac'ujol ayexi, yena ni mas nihuan oj ajyuca, xchi ja Jesusi.
\s1 Ja ma' mi jcondrauctiqui, camigo ni jbajtic soca
\r (Mr. 9:38‑40)
\p 
\v 49 Yajni ch'ac yal jachuc ja Jesusi, jaxa Juani ti sac'a jana: ―Maestro, quilaticon jun huinic: Yuj ja sbiil ja Jesusi acta can ja huinic jahui, pe xchi tac. Pe ja quenticon jcomoticon porque mi ni jmojuctica, xchi ja Juani.
\v 50 Ti yala ja Jesusi: ―Pero mi sbejuc huaxa comohuexi porque ja ma' mi jcondrauctiqui, camigo ni jbajtic soca, xchi.
\s1 Ja Jesusi scomo ja Jacobo soc ja Juani
\p 
\v 51 Ja Jesusi cuando jel xa mojan ja tiempo oj iijuc q'ue ja ba satq'uinali, ti xa sutan ja sc'ujol que oj xa huajuc ja ba Jerusaleni.
\v 52 Ti seca och chaboxe jecabanuma. Ti huajye ba jun yal hacienda sbaj ja samariteño jumasa. Huaj slee posada ba oj huayuquei.
\v 53 Pero ja samariteño ja ba yal hacienda jahui mi sc'ana oj yae yi majan ja sposada ja Jesusi. Ti huaj yale yab ja Jesusi que mi bi huas sc'anahue porque ti bi huajume ja ba Jerusaleni.
\v 54 Ja yab jastal alji yab ja Jesús ja Jacobo soc ja Juani, ti yalahuea: ―Cajual, ¿mi ma lec oj c'antic ja c'ac' ja ba satq'uinali ba oj ch'acuc ja it jumasa? Jach ni sc'ulan ja Elías tac, xchiye.
\v 55 Ti sutu sbaj ja Jesusi. Ti yalaa: ―Ja huenlexi lajan soc ja spensar ja pucuj ja hua pensarexi.
\v 56 Iday, jaxa queni, ti ni coelon jan ja ba satq'uinali pero mi jaquelucon ba oj ch'ay ja yaltzil ja cristiano. Jacyon ba oj colta ja yaltzilei, xchi ja Jesusi. Ti cho huajye ba otro yal haciendaa.
\s1 Ja ma' huas sc'ana yaa sbaj soc ja Jesusi
\r (Mt. 8:19‑22)
\p 
\v 57 Cuando ti xa huajumei, ti jac jun huinica. Ti yal yab ja Jesusi: ―Cajual, chican ba huala huaja, oj ni nocha ec'a, xchi.
\v 58 Ti yala ja Jesusi: ―Pero ja queni, mas lec ja jalahui. Ay sq'ueen. Soc ja yalchan, ay soj. Ja queni coelon ni jan ja ba satq'uinali pero mi ni ba oj ochcon baani, mey quioj, xchi.
\v 59 Ti yal yab ja otro juni: ―Jachuc ja hueni, nochohuon. Ti yala ja huiniqui: ―Cajual, cuando huax cham ja jtati, ti oj jacon amoca.
\v 60 Ti yala ja Jesusi: ―Ja hua tati oj ni mucjuc yuj ja ma' mi ni cuenta ayuqui, jaxa hueni, caax. Cax loilta ec' ja jastal oj ajyuc ja cristiano cuando huax yaa sbaj ja ba sc'ab ja Diosi.
\v 61 Ti cho yala otro juni: ―Oj jacon amoc, Cajual, pero c'ulan qui ja pavori, jecahuon ba oj huaj c'um can bajtan ja suinquil ja jnaji.
\v 62 Ti yala ja Jesusi: ―Ja hueni ja' amoj ja ma' huas syama arado, ti huas sq'uela spatica, iday, ja xchojlal ja alaji, c'atan mechan xta huax huaji. Mi ni tojuc ja yatela. Huaxa huala oj jacan jmoc, iday, huax cho ahuala oj cumxan ba hua naji. Ja ma' q'uelq'uelpatic ayi, quechan ita huas somo ja ateli, xchi ja Jesusi.
\s1 Ja Jesusi seca ja setenta huiniqui
\c 10
\p 
\v 1 Jaxa mas tzaan t'usani ja Cajualtiqui ti cho stzaa otro setenta huinica. Jaxa setenta huinic jahui ti yala que oj yii sbaje chaticuane ba oj huajuque ba spetzanil ja yal hacienda jumasa soc ja yal lugar jumasa, jaxa yeni ti bi oj huaj tzaana.
\v 2 Ti yal yabyea: ―Ja cristiano, jel xa chapan juntiro ja sc'ujolei. Lajane soc jun alaj ja ba huan xa smajlajel ja sachjeli. Pero ja atjumi, jel t'usan, jayuj c'anahuic yi ja suinquil ja alaji ba oj sec mas ja atjumi ba oj scuche jan ja iximi.
\v 3 Jayuj ja yaani caxic xa. Meran, ja cristiano jel c'aq'ue, lajane soc ja choji. Jaxa huenlexi lajan soc ja' amojex jun yal cheji, iday, ti huax jecahuex ba snalan ja yenle tac.
\v 4 Mi lom xa huiajex ja hua nutiexi soc mi ni ja hua taq'uinexi soc mi ni ja hua xanabexi, soc mi jauc ja oj ochanic loil ja ba beji.
\v 5 Chican ba naitz huala ochyexi, bajtan oja c'anex yi ja Diosi que oj ajyuc laman ja suinquil ja naitz jahui.
\v 6 Ta ay c'a mach ay ja tihui, ta huan c'a sc'ana oj smacla ja jas huaxa hualahuexi, entonces oj ni lamxuc ja yaltzila. Ta mi c'a sc'ana, pues como laman ajyanic ja huenlexi.
\v 7 Ja ba mismo naitz jahui ti la ajyiyexa. Chican jas huax aaji ahuilex, iajic. Abyic porque jun atjum sbej ni oj yii ja stz'acoli. Mi sbejuc ja chol oj yii ec' ja naitzaltiqui.
\v 8 Chican ba yal haciendail huala huajyexi, ta huan c'ax aaji ochanic, ay c'a jas huax yaa huilex, abyic, xchi ja Jesusi.
\v 9 Jaxa ba yal hacienda jahui, ta ay c'a ma' malo ay, aahuic tojbuc, ti xa hualahuex yaba: Ja yaani c'ot ta ni ja ora ba oj sc'ulucotic mandar ja Diosi, utajic.
\v 10 Pero ta huan c'a la huajyex ba jun yal hacienda, mi c'a huas sc'anahue ja jas oja hualexi, ti la elyexa. Pero ti xa hualahuex can yaba:
\v 11 Ja cocticoni cux ta pero ja' yujil ja spolvoil ja hua lugarexi. Pero ti oj tzijucticon can ja ba sti ja hua satexi. Pero ¡pobre ja huenlexi! Ja Diosi, eso sí, jac ta nique ba oj sc'uluquex mandar pero mi ni modo huaxa huaa bajexa!
\v 12 ¡Pero majlayic! Ja c'ac'u jau oj jac ja castigo, mas to lec ja scastigo ja suinqil ja Sodoma que soc ja hua castigo ja huenlex ja ba hacienda iti, iday, ja suinquil ja Sodoma mero mal cristianoe, utajic cani, xchi ja Jesusi.
\s1 Jel utji ja cristiano yuj ja Jesusi
\r (Mt. 11:20‑24)
\p 
\v 13 ¡Ay pobre ja huenlex ja matic suinquilex ja Corazini! Soc jach ni ja huenlex ja matic ti culanex ba Betsaida, ¡jel ajul abajex! Jach c'a c'ulaji ja milagro ja ba suinquil ja Tiro soc ja suinquil ja Sidoni, najate suchi ja sc'ujolea, iday, ja yenlei mi ni t'un huas snaahue sbaj ja Diosi. Jach c'a, ja' xa ni sc'ue ja coxtala soc huan xa ni saxa sbaje taana. Yatz'an xta ni tola vida ja yaltzile yuj ja smulei.
\v 14 Mas yoc'an oj yii ja scastigo ja suinquil ja Tiro soc ja suinquil ja Sidoni ja c'ac'u oja huaex yi cuenta ja Diosi. Pero ja huenlexi, tzatz juntiro oja huiex ja castigo.
\v 15 Jaxa huenlex ja matic ti culanex ja ba Capernaumi, jel lom juntiro huaxa toyo bajex. ¿Yuj ama huaxa hualahuex ta oj q'ueanic ja ba satq'uinali? ¡Ay pobre ja huenlexi! Ti ni oj jipjanic co ja ba yoj inpierno.
\v 16 Ja Jesusi ti cho yal yab ja setenta huinic jahui: ―Ja matic huas smacla ja jas huaxa hualahuex ja huenlexi, lajan soc quen huas smaclayone. Jaxa ma' mi smaclayexi, quena ni mi huas sc'ulanone casoa. Jaxa ma' mi huas sc'ulanon caso ja quen, yena ni ja ma' seconejoni mi sc'ulane caso, xchi ja Jesusi. Jaxa setenta jahui ti huaj sloiltaye ja yabal ja Diosi.
\s1 Cumxi ja setenta huiniquei
\p 
\v 17 Yajni cumxiyei, jel gusto aye juntiro. Ti yalahuea: ―Cajual, hasta ja pucuji, quechan huax taaticon ti' ja hua biili, huas sc'uan ja cabalticoni, xchiye.
\v 18 Ti yala ja Jesusi: ―Huan nix naa. Can ta ni baan ja Satanasa. Huan nix quila jasunc'a hua c'ulanexa. Quila sacbanban ch'ac canuc ja pucuj jumasa.
\v 19 Pero quen caa ja hua huipexi. Anima huaxa batahuex ja mal chani soc ja tzequi, mi ni jas oj bob sc'uluc ahuilexa. Anima jel tzatz ja hua condraexi, mi ni oj bob sc'uluquex ganara. Mi ni jas oj bob sc'uluc ahuilexa.
\v 20 Jel lec ja sc'uanex ja pucuj jumasa. Jel juntiro agustoex pero ay to jun cosa mas jel nihuan. Ja hua biilexi ti xa ni tz'ijbanubal ja ba libro ja ba satq'uinal tac, jayuj sbej que mas to jel gusto oj ajyanic yuj ja jahui.
\s1 Jel gustoaxi ja Jesusi
\r (Mt. 11:25‑27; 13:16‑17)
\p 
\v 21 Ja Jesusi cuando ch'ac yal ja jachuqui, jel gustoaxi juntiro yuj ja Espíritu Santo. Ti yalaa: ―Ja huen Tatey, Ajualal aya ba satq'uinali soc jach ni ja ba luumi. Ja ma' vivo soc ja ma' jel huas snaahuei mi jauc huaxa jea yi ja jastal iti. Tz'acatal ja' huaxa jea yi ja matic ch'in huax yaa sbaj ahuii. Lec, Tatey, como jach ni huaxa c'anaa.
\v 22 Ja yaani quena ni huax c'ulan mandara pero huena ni ahuaunej qui, Tatey. Mi ni ma' huas snaa ta quena ni ahuuninon. Quechan huen huaxa naa. Soc mi ni ma' huas snaa ta huena ni ja jTatai. Quechan ja quen huax naa baj, como ahuuninon nia. Eso sí, ay tuc ma' huas snaa baj pero quen huax ca snae abaj.
\v 23 Ja Jesusi ti sutu sbaj ja ba lado bay ja snebumani. Ti och yal yab yenle itaa: ―¡Lec xta huujilex ja jas huanex yiljeli!
\v 24 Porque jitzan ja aluman‑Dios soc ja rey jumasa huas sc'ana oj yile ja jas huanex yiljeli pero mi yilahue. Huas sc'ana oj yabye ja jastal huanex yabjeli pero mi yabye, xchi ja Jesusi.
\s1 Ja samariteño ba jel lec ja sc'ujoli
\p 
\v 25 Ja Jesusi, huaj to yile, ti jac ba stz'eel jun huinic ja ma' huas sea ja smandar ja Moisesi. Ti yiaj loila pero quechan huas sc'ana oj yab jas oj el sti ja Jesusi: ―Maestro, ¿jasunc'a mero lec oj c'uluc ba oj ajyuc ja jsac'anil tola vida? xchi.
\v 26 Ti yala ja Jesusi: ―¿Jasunc'a huax yala ja smandar ja Moisés ba? ¿Jastal huax yala ja juun huaxa q'uela ba?
\v 27 Ti yala ja ma' huas sea ja smandar ja Moisesi: ―Huax yala que yaj oja huab ja hua Huajual Diosi soc spetzanil ja hua c'ujoli soc spetzanil ja hua hualtzili soc spetzanil ja hua huipi soc spetzanil ja hua pensari. Jachuc ja hua moji, yaj oja huab jastal huaxa yajta baj ja huen mismo, xchi ja huiniqui.
\v 28 ―Meran ni ja jas huaxa hualaa, xchi ja Jesusi. Huan c'a xa c'ulan jachuc, oj ni ajyuc ja hua sac'anil tola vida, xchi.
\v 29 Pero ja huiniqui huan ni slea modo jastal oj scolta sbaja. Ti yal yab ja Jesusi: ―Eso sí, huan nix yala oj yajtatic ja jmojtica, pero ¿machunc'a ja jmojtic ba?
\v 30 Jaxa Jesusi ti yalaa: ―Jun huinic, ti el ja ba Jerusaleni, ti huajum ja ba Jericó. Cuando ti xa ay ja ba beji, ti staa chaboxe lagrona. Jaxa huinic jahui yamji. Ch'ac japjuc yi ja sastic sbaji. Ajyi yajbuc lec. Cham sac'an aaji cani. Ti huaj ja lagrona.
\v 31 Jaxa bay ja huiniqui, ti ec' jun pagrea. Ec' toj c'an ta yila, mi yila can ja huinic jahui.
\v 32 Otro jutz'in ti cho ec' jun huinic levita ay yatel ja ba yoj templo. Mojan juntiro eq'ui pero quechan sq'uela can lec.
\v 33 Ti cho ec' jun samariteñoa, jaxa yeni toj tuc cristiano nia. Ti huaj sta och c'uban ja bay ja huinic jahui. Yajni yila jastal ayi, ti stalna syaujulala.
\v 34 Yajni ti xa ay ja ba stz'eeli, ti spotzo yi ja syajbeli. Ya och yi aceite soc yaalel ja tz'usubi. Ti ya q'ueuc ja ba spatic ja scahuu. Ti yiaj och ba jun chonaba. Slea yi ja sposada soc stalna.
\v 35 Jaxa otro c'ac'u cuando oj xa huajuc ja samariteño jahui, ti ya el chab sat taq'uin, denario sbiil yujile. Yaa yi ja suinquil ja naitzi. Ti yal yaba: ―Aa hua pavori. Talna qui ja huinic iti. Ta mi c'ax yaa ja taq'uin huax caa cani, ta ay c'a jas huaxa huaa ja hueni, oj tup ahui cuando huala cumxiyoni, xchi ja samariteño.
\v 36 Ja Jesusi ti sobo yi ja ma' huas sea ja smandar ja Moisesi: ―¿Jas la chi ja huen ba? Ja ma' yajbesji cani, jaxa oxhuane ja ma' ec' ba, ¿machunc'a june ja yenle coltani ba?
\v 37 Ti yala ja ma' huas sea ja smandar ja Moisesi: ―Pues ¿mi ma jauc ja' ma' stalna syaujulal ba? Ti yala ja Jesusi: ―Ja' nia conser ja samariteño jahui toj tuc cristiano ja ma' scolta. Pero sbej ni ja jas sc'ulana porque puro ni jmoj jbajtica. Jach ni ja huen chomajquili, cax c'ulan ja jastal jahui, x'utji.
\s1 Ja Jesusi huaj ba snaj ja Marta soc ja María
\p 
\v 38 Jun c'ac'u ja Jesusi tey ba bej. Ti c'ot ja ba jun yal chonab, jaxa tihui ay jun ixuc sbiil Marta. Jaxa ixuc jahui sloco ja Jesús ja ba snaji.
\v 39 Jaxa Marta, ay jun yermana María sbiil. Ja María ti och culan ja ba stz'eel ja Jesusi. Ti huan smaclajel ja jas huan yaljeli.
\v 40 Pero ja Marta jel juntiro t'ilan huax yab ja yateli, jayuj ti och parte soc ja Jesusi: ―Cajual, ¿sbej ama huaxa huab ja jtuch'il huanon atel ba? ¡Jaxa quijtz'ini lom culan ec' ba hua tz'eel tac! Aa hua pavori al yabi que a scoltayon, xchi ja Marta.
\v 41 Ti yala ja Jesusi: ―Marta, ja' huajel ac'ujol soc ja hua huateli. Quechan huana snutzjel abaj soc ja jahui.
\v 42 Pero ay jas mas jel t'ilan. Ja María stzaa ta ni ja ba mas leca y mi ni ma' oj sap yia, xchi ja Jesusi.
\s1 Ja Jesusi sea jastal oj c'umtic ja Diosi
\r (Mt. 6:9‑15; 7:7‑11)
\c 11
\p 
\v 1 Jun c'ac'u ja Jesusi ti huaj sc'umuc ja Dios ba jun lugar. Cuando ch'ac sc'umuc ja Diosi, june ja snebumani ti yalaa: ―Cajual, jea quiticon jastal oj c'umticon ja Dios ja quenticon ba. Pe jach ni ja Juan tac, sea ni yi ja snebuman jumasa jastal oj sc'umuque ja Diosi, xchi.
\v 2 Ti yala ja Jesusi: ―Lec oj cala huabyex jastal oja c'umuquex ja Diosi:
\q1 JTaticon Dios ti aya ba satq'uinali, ja hua biili, mi cualquierauc. A jacuc ja tiempo oj ni ac'ul mandari. A c'ulajuc ja jastal huaxa c'anai. Ja jastal huaxa c'ulan ja ba satq'uinali, jach ni a c'ulajuc ja ba luum chomajquili.
\q1 
\v 3 Ja yaan c'ac'u aa quiticon ja juaelticoni.
\q1 
\v 4 C'ulan quiticon perdonar ja jmulticoni porque jach ni ja quenticoni, jc'ulanticon ta perdonar ja ma' huas sc'ulan quiticon ja malo. Moc hua c'ulajucoticon ganar soc ja jmulticoni. Pilahuoticon ja ba yoj maloili.
\m Jach ni c'anahuic yi ja Dios jastal ita, xchi ja Jesusi.
\v 5 Ti cho yala ja Jesusi: Q'uelahuile, cuando ay jun ahuamigo, jaxa hueni nalan acual oj huajan ja ba snaj ja huamigo jahui. Ti oja hual yaba: Camigo, a jel t'an siquiera chanjouc ja hua huooti.
\v 6 Ay jun camigo huan tox jul ja ba jnaji pero mi jas quioj ba oj ca yabi, oj chian c'ote.
\v 7 Jaxa hua huamigo tey yoj naitzi ti oj yal jana: Jachuc ja quen, mi xa jas can sobra ja cooti, cho lutan xa ja jnaji. Soc huan xa huayel ja cuntiquil ja ba jch'ati jayuj mi xa oj bob jas oj caa hui, oj chiuc.
\v 8 Iday, ja huamigo nia pero mi ni modo oj q'ue yaa hui jel ja yooti. Pero yajni huax yila mi ni la huaji, ti oj q'ue yaa hui spetzanil ja jas huaxa c'ana.
\v 9 Jayuj huax cala huabyex, cuando huaxa c'umanex ja Diosi, c'anahuic yi ja jas huaxa c'anahuexi. Ja yeni oj ni yaa huilexa. Mi lom xa huaahuex can ja sc'anjel yii. T'ilan oj aajuc ahuilex. Jaman c'a ja hua tiexi, oj ni ataex ja jas huaxa c'anahuexi.
\v 10 Porque spetzanil ni ja ma' huas sc'ana yi ja Diosi, huan nix aaji yia, jaxa ma' mix yaa can ja sc'anjeli, huan ni sc'ulan recibira, jaxa ma' jaman ni ja stii, huan ni staaa.
\v 11 Ja huenlexi tatalex, jaxa huuntiquilexi ta huan c'ax jac sc'an ahuilex jun pan, ¿oj ma huaex yi jun ton ba? Ma ta huan c'ax jac sc'an ahuilex jun chay, ¿oj ma huaex yi jun mal chan ba?
\v 12 Ma ta huan c'ax jac sc'an ahuilex jun nolob, ¿oj ma huaex yi jun tzec ba?
\v 13 Ja huenlexi, eso sí, maloex nia pero iday, huan ni xa huaahuex yi ba lec ja smajtan ja hua huuntiquilexi, ¡jauc to ma ja hua Tatex tey ba satq'uinali! Ja yeni oj yaa yi ja Espíritu Santo ja ma' huan sc'anjeli, xchi ja Jesusi.
\s1 Ja Jesusi locji abal que lajti abal bi ay soc ja pucuji
\r (Mt. 12:22‑30; Mr. 3:19‑27)
\p 
\v 14 Jaxa mas tzaani ja Jesusi ti iiji jan yi jun huinic ixtalanubal yuj ja pucuji. Aaji ta pax mudoil. Jaxa Jesusi ti yal yab ja pucuj jau que oj yacta can ja huinic jahui. Yajni el ja pucuji, jaxa ma' mudo ajyi, c'umani. Jaxa cristiano jumasa jel och juntiro ja spensarei.
\v 15 Pero ay chaboxe ja yenlei ti yalahuea: ―Es, huan ni sc'ulan mandar ja pucuja pero ja' ac'ubal yip yuj ja sepeil ja pucuji, pero ja' ni ja tan Satanasi, xchiye.
\v 16 Jaxa tuqui ti cho yalahue yaba: ―Siquiera oja jee jun nihuan seña sbaj ja Diosi. Jach yalahue porque quechan huas sc'ana oj sc'uluque probar ja Jesusi
\v 17 Pero ja Jesusi huas snaa jastal huan xta huaatzhuunuc ja sc'ujolei. Ti yalaa: ―Ja ba jun lugar, ta huan c'ax yila sbaje condra ja suinquili, mi ni lec oj ajyuca. Y jach ay ba jun naitz, ta puro pleito aye, oj ni jomuca.
\v 18 Ja pucuj jumasa, ta pilan pilan c'a aye, ¿mi ma oj cho jomuque ba? Ja queni huaxa hualahuex que ja' quioj ja yip ja diablo jayuj huax bob jc'ul mandar ja pucuji.
\v 19 Ta meran c'a ja' quioj ja yip ja diablo, iday, ¿jaxa hua mojex ba? ¿Ba huax yiaj ja yip ja yenle ba? ¡Majlayic! Ja yenle ja hua mojex jahui mi oj sc'ul gusto oja hualex jastal iti.
\v 20 Pero ta ja' c'a yuj ja Dios huax bob jc'ul mandar ja pucuji, entonces ja' xa ni ja Dios huan xa sc'ulajel mandar ja ila.
\v 21 Q'uelahuil jun huinic jel ja yipi. Chapan lec. Ta huan c'ax jac ja scondra, mi jas oj sc'ul yi palta. Oj ni bob scolta sbaja. Jel huas stalna ja snaji, jaxa jastic sbaji, mi huanuc pensar ta oj elc'ajuc yi como jel ni seguro aya.
\v 22 Pero ta huan c'ax jac ja ma' mas jel ja yipi, eso sí, oj ni c'ulajuc ganara. Oj japjuc yi spetzanil ja jas huas scolta sbaj soc ajyi, jaxa jastic sbaji oj ni ch'ac iijuc yia.
\v 23 Ja ma' mix bob smojuconi, condra ni huax yilahuona, jaxa ma' mi sc'ana oj scoltayon soc ja cateli, ja' ni sgusto ja mi oj bejyuc ja catela.
\s1 Ja pucuji cumxi ja ba snaji
\r (Mt. 12:43‑45)
\p 
\v 24 Q'uelahuil jun pucuj. Huax yaa can jun huinic, ti huax huaj ba jun taquin lugar, jaxa tihui c'atan xta ay eq'ue. Mix yila ora ba oj staa ja sijlubi, pero meyuc. Ti huax yalaa: ―Oj ma cumxucon ja ba jnaji ja ba elyon jani.
\v 25 Ti xa cumxia. Jaxa c'oti, mesubal lec ja naitzi. Tojbel lec.
\v 26 Ti huaja. Huaj yii jan otro juque ja smoj pucujili, pero mas to pegor ja jucuane jahui que soc ja yeni. Ti ochye culan ja ba naitz jahui. Ja huinic jahui mas lec ja jastal ay ajyi, xchi ja Jesusi.
\s1 Jel lec huax yila ja ma' huax yab ja yabal ja Diosi soc ja ma' huas sc'uani
\p 
\v 27 Ja Jesusi cuando jach to huan yaljel jachuqui, jun ixuc ja ba yojol ja cristiano ti c'umani tzatz leca: ―¡Jel lec huax yila ja ma' yalintaya soc ja ma' ya chuunani! xchi.
\v 28 Pero ja Jesusi ti yalaa: ―Eso sí, pero mas to jel lec huax yila ja ma' huax yab ja yabal ja Diosi soc ja ma' huas sc'uani, xchi.
\s1 Ja cristiano t'ilan sc'anahue oj yile jun milagro
\r (Mt. 12:38‑42; Mr. 8:12)
\p 
\v 29 Ja cristiano mas to huan stzomjel sbaje ja bay ja Jesusi, jaxa Jesusi ti yalaa: ―Ja cristiano iti, jel maloe juntiro. Quechan huane sc'anjel ba oj yile jun seña pero mi ni oj yilea. Eso sí, ay ni jas oj yilea pero ja' ni jastal ec' ja Jonasi.
\v 30 Ja jastal jeeji yile ja yip ja Dios ja suinquil ja Ninivé yuj ja jas c'ulaji yi ja Jonasi, jach ni oj cho jeejuc yile ja yip ja Dios ja cristiano iti. Oj ch'ac yile ja jastal oj ec' cujili, iday, ja queni ti ni coelon jan ja ba satq'uinala.
\v 31 Jaxa c'ac'u oja huaex yi cuenta ja Diosi, ti ni oj ajyuc ja reina jau ja ma' el jan ja ba najtil lugar. Huaj sc'an yi sc'ujol ja rey Salomoni porque ja reyi jel juntiro huas snaa. Iday, ja reina jahui ti jac ja ba jun najtil lugar lec. Ja yeni oj ni yaex endregala. Iday, ja ili ay jun ma' mas nihuan que yuj ja Salomoni pero mi xa huaahuonex caso.
\v 32 Jachuc ja suinquil ja Ninivé chomajquili. Oj ni yaex endregala. Ja yenlei suchi ja sc'ujole ja yora loiltaji yabye yuj ja Jonasi. Iday, ti ayon amoquex ja queni. Mas nihuanon ja quen que yuj ja Jonasi pero mi ni modo huas suchi ja hua c'ujolexi.
\s1 Ja jas huax jea, lajan soc jun candela, xchi ja Jesusi
\r (Mt. 5:15; 6:22‑23)
\p 
\v 33 Ja jas huax jea lajan soc jastal jun candela. Q'uelahuil jun candela. Ta huan c'ax aaji ajluc, yuj oj ni maconuca. Mi ni modo oj nujxuc soc jun cajón soc mi ni modo oj aajuc ajluc ba jun naitz ba mey suinquil. Ti oj aaji ochuc ba jun candelerio, jaxa ma' huax och ja tihui, oj ni bob yil q'uinala.
\v 34 Jaxa ma' huax yab slugaril ja jas huax jea, lajan soc ja ma' lec ay lec ja sati. Toj ni huax bejyia porque ja jsatiqui, ja' ni huax ya yil q'uinal ja jcuerpotica. Pero ja ma' mi lecuc ay ja sati, ti ni ay ja ba q'uiq'uinala.
\v 35 Ta ti xa c'a aya ja ba yoj luzi, pero aa lec acuidadoex porque ay modo jastal oj cho ochanic ja ba yoj q'uiq'uinali.
\v 36 Ta meran c'a ti xa aya ja ba luzi, najat xa ni ahuioj ja q'uiq'uinala. Lajan soc ti aya ja ba huax lijpi juntiro, como jastal ja ti aya ba stz'eel jun luz ba jel tzatz ja yijlabi.
\s1 Jel bi ja smul ja fariseo soc ja ma' huas sea ja smandar ja Moisesi
\r (Mt. 23:1‑36; Mr. 12:38‑40; Lc. 20:45‑47)
\p 
\v 37 Cuando ch'ac yal ja jastal it ja Jesusi, ti locji huael yuj june ja fariseo. Yajni och c'ot ja ba snaj ja fariseo jahui, ti och culan ja ba mesa.
\v 38 Ja fariseo jahui cuando yila mi sac'a ja sc'ab ja Jesusi ja jastal culan yujile cuando mi tox och huauquei, jel tuc juntiro yila.
\v 39 Jaxa Cajualtiqui ti yalaa: ―Ja huenlexi, fariseoex, ja hua vasoexi soc ja hua platoexi sac'ubal lec huaxa huaahuex ja spatiqui pero ja yojoli, cux ta ni aya. Jach ni mero amodoexa. Jel tzamal huaxa jea bajex ja ba fuera pero ja hua c'ujolexi mi icben sbej jastal ay. Puro elc'al but'el.
\v 40 ¡Tontos! Ja ma' sc'ulanex, eso sí, huax yila jastal huaxa jea bajexi, ¡jauc to ma hua c'ujolex mi oj bob yil jastal ay!
\v 41 Mas lec, mi xa mutz'u ja hua c'ab soc ja hua moj jumasa. Jaman c'a ja hua c'abi, ti oja huil que tzamal oj ajyuc ja hualtzili, mi quechanuc sac'ubal ja spatic ja hua vasoexa.
\v 42 ¡Ay pobre ja huenlex fariseo! Hasta arabueno, hasta ruda, spetzanil ja yal c'uli huaxa huaahuex lec cuenta. Ja ba cada lajunei, ti huax hua eluquex jujune ja ba smajtan ja Diosi. Lajan soc jel toj ayex pero iday, mi ni t'un toj ayuquex soc ja Diosi. Mi ni t'un huaxa naahuex ja syajtajel ja Diosi. Jel lec huaxa huaahuex yi ja Dios ja hua c'ulexi, pero ja ba mas t'ilani, huaxa huaahuex can jun lado.
\v 43 ¡Ay pobre ja huenlex fariseo! Jex oc' ac'ujolex ja lugar ba mas tzamal ja ba yoj ahuiglesiaexi. Jaxa ba plaza jel ja hua gustoex huax jac tajuc ja hua c'abexi.
\v 44 ¡Ay pobre ja huenlex ja huanex seejel ja smandar ja Moisesi soc ja huenlex fariseo jumasa! ¡Toj chab cara ayex! Ja' ni amojex ja sq'uejnal ja chamhuinic ba mi xa ay seña pero iday, ja yojol ja q'ueen jahui, jel ni quistala. Ja ba hua c'ujolexi, mi icben sbej jastal ay ja mulali. Ja cristiano huax hua snebex ja hua modoexi. Jaxa pobre cristiano ja ma' huaxa jeahuex yii, jun sc'ujol huas smaclayex.
\v 45 Ti sac'a jan june ja ma' huas sea ja smandar ja Moisesi: ―Maestro, entonces quen huax hua jmacchiquinucticon, xchi.
\v 46 Ti yala ja Jesusi: ―¡Ja huenlex nia! ¡Jel ajul abajex ja huanex seejel ja smandar ja Moisesi! Ja huaahuex ta och mas. Lajan soc huaxa tz'alahuex yi jun nihuan scarga ja cristiano jaxa huenlexi jach la bachbuniyex eq'ue.
\v 47 ¡Ay pobre ja huenlexi! Ja ba can mucan ja aluman‑Dios jumasa, jaxa huenlexi ti huaxa c'ulanex ja snajtzil ja sq'uejnalei pero ja mero smeranili, ja' ni amojex ja tantic mulanum ja ma' ec' pax ta huujilexi porque yenle ni ch'ac smilea.
\v 48 Moc ahualex ta mi huaxa naahuex lec ja iti. Lajan soc lajti abal ch'ac huajanic ja jastal ch'ac smile ja aluman‑Dios. Ch'ac smile ja yenlei, jaxa huego ja huenlexi, huen huax hua q'ueuquex ja snajtzil ja sq'uejnalei.
\v 49 Ja Diosi, como huan ni snaaa, yala ni que oj ni sec yi ja cristiano ja yaluman jumasa soc ja secabanum jumasa pero yala ni que ay ni ma' oj miljuca, jaxa tuqui oj aajuc yi jitzan huocol.
\v 50 Jaxa huenlex ja jun lame iti, huen oja cuchex can ja xchiq'uel ja aluman‑Dios jumasa ja janec' pec' desde cujlaji ja satq'uinali.
\v 51 Desde yora milji ja Abeli, jach ni lamlamil ch'ac chamuquea hasta cham ja Zacarías it milji ja ba scol ja templo soc ja ba huas tzicxi ja smajtan ja Diosi. Spetzanil ja jau jumasa, huenlex ni oj ch'ac acuchex can spetzanila.
\v 52 ¡Ay pobre ja huenlex ja matic huas sea ja smandar ja Moisesi! Lajan soc alutunejex ja puerta ja bay ja Diosi. Mi la ochyex ja huenlexi soc huax cho amacahuex sbej ja ma' huas sc'ana oj ochuqui.
\v 53 Ja Jesusi cuando ch'ac yal ja jastal jahui, jaxa matic huas sea ja smandar ja Moisesi soc ja fariseo jumasa mi snaa jas oj sc'uluque yi. Ti och sc'ane yi sc'ujol jitzan cosaa
\v 54 Ba mi oj sc'ul palta jas mas piero oj el sti ja Jesusi ba oj bob slee ja smuli.
\s1 Mi bi lecuc ja chab cara ay ja cristiano
\c 12
\p 
\v 1 Malan jach to huan yaljel ja Jesusi, jaxa cristiano jumasa huan xta stzomjel sbaje, mi naben jaye mil. Huan xta sbatalaan sbaje. Ja Jesusi ti och yal yab bajtan ja snebuman jumasa: ―Aa cuidadoex porque ja fariseo jumasa toj chab cara aye, jaxa smodo yiojei, lajan soc levadura. Huax pojxi.
\v 2 Pero mi jas nac'an ay ba mi oj chicnajuc. Mi ni jas cosa ba ch'aban ti' abal oj ajyuca.
\v 3 Spetzanil ja jas nac'ul abal huaxa hualahuexi, satalajel abal oj chicnajuc, jaxa jastal huala ochyex loil ba yoj ja najexi, lajan soc ic' huax yiaj.
\s1 ¿Machunc'a sbej oj xihuanic yujili?
\r (Mt. 10:28‑31)
\p 
\v 4 Camigo jumasa, ay jas oj cho cala huabyex. Moc lom xihuanic yuj ja matic huax bob smil ja jcuerpotiqui, jaxa mas tzaani, mi ni jas oj bob sc'ul quitica.
\v 5 Pero oj cala huabyex ja ma' oj xihuanic yuji. Xihuanic yuj ja Diosi. Huan c'ax yala oj chamanic, oj ni chamanica. Ay ni yip oj sipex yoj inpierno ta ja c'a sbajex inpierno. Jayuj huax cala huabyex, xihuanic yuj ja Diosi.
\v 6 Q'uelahuil ja yalchan huax chonji ba yoj mercado. Jel barato juntiro. Quechan chab centavo stz'acol ja joe yalchani. Pero anima, cuenta ni ay yuj ja Dios ja yalchan jumasa jahui.
\v 7 Q'uelahuil ja stzotzil ja hua olomexi. Cuenta ay yuj ja Diosi. Cuenta to ay jitzan ja yalchani, ¡jauc to ma ahualtzilex mi cuentauc oj ajyuca! Jayuj moc lom xihuanic.
\s1 Ja ma' huas staa ti' ja sbiil ja Jesucristo ja ba sti sat ja cristiano
\r (Mt. 10:32‑33; 12:32; 10:19‑20)
\p 
\v 8 Huax cala, pero meran, spetzanil ja ma' mix q'uixhui huas staa ti' ja jbiili ja ba sti sat ja cristiano, como ti ni coelon jan ja ba satq'uinali, jach ni ja quen chomajquili, mi oj q'uixhuucon ja oj taa ti' ja sbiilei ja ba sti sat ja yangel ja Diosi.
\v 9 Pero ja ma' huas snac'ahuon ja ba sti sat ja cristiano, jach ni oj cho jnac' ja yenle ja ba sti sat ja yangel ja Diosi.
\v 10 Ja queni meran ni ti coelon jan ja ba satq'uinali pero ta ay c'a ma' huas staahuon ti' malo, oj ni c'ulajuc perdonara. Pero ta ay c'a ma' huas staa ti' malo ja Espíritu Santo, mi ni nunca oj bob c'ulajuc perdonara.
\v 11 Cuando huala iijiyex ja ba quiglesiatiqui ma ba sti sat ja comandante jumasa, ma ba sti sat ja ma' ay yateli, mix cham ac'ujolex ja jas oja hualexi. Mix cham ac'ujolex jastal oj c'umananic.
\v 12 Ja Espíritu Santo ja mero ora jahui oj ya jac ac'ujolex jasunc'a lec oja hualexi, xchi ja Jesusi.
\s1 Ja ma' huas stzomo jitzan ja sriquesaili
\p 
\v 13 Ti yala jan june ja jun nole cristiano jahui: ―Maestro, al yab ja quermano que oj yaa qui ja jdote ja queni, xchi.
\v 14 Ti yala ja Jesusi: ―Quere, ¿pe jas cochel ja queni? ¿Yuj ama juezon ma pilaluumon?
\v 15 Ti och yal yabye ja cristiano: ―Ata huabyex. Aa t'un acuidadoex ja japan tuch'an ja jastic cosa jumasa. Mi jauc oj ajyuc ja hua sac'anilex yuj ja jel ja hua jastic abajexi.
\v 16 Ti och yal jun loila: ―Q'uelahuil, ta ay c'a jun rico huinic, jaxa sluumi jel xbaalani juntiro,
\v 17 Ti huax yala sbaj yen itaa: ¿Jas oj cut ja jas jbaji? oj chiuc. Mix taa ba oj nol ja sbaal ja jluumi.
\v 18 Oj ma jc'ul jachuc. Oj jom el ja snojlayub ja jastic jbaji, entonces ti oj c'ul mas nihuaca. Ti oj bob jnol spetzanil ja sbaal ja jluumi soc chican ja jastic quioji.
\v 19 Mi xa t'ilanuc oj atjucon, como ay ba jitzan jabil ja jas nolan cuji. Ja yaani oj xa jijlucon. Oj huaacon lec. Oj ajyucon gusto. Jach oj yal sbaj ja huinic jahui.
\v 20 Pero ja Diosi ti oj yala: ¡Ja hueni lajan soc pumpu ja hua olomi! Ja yaan acuali oj chaman, jaxa jastic nolan ahuuji, ¿ma' oja huaa can yi ba? oj utjuc.
\v 21 Jachuc ja ma' mutz'an yuj ja sricoili, jaxa soc ja Diosi, mi ni t'un ricouca, xchi ja Jesusi.
\v 22 Ja Jesusi ti yal yab ja snebuman jumasa: ―Jayuj huax cala huabyex, mi lom xa c'ulanex pensar jastal oj ajyanic, jastal oj huaanic. Jach ni ja hua c'uexi, mi xa c'ulanex pensar.
\v 23 Ja jas huaxa huabyexi soc ja jastal huaxa c'utes abajexi, pero ay to mas t'ilan que yuj ja jahui.
\v 24 Q'uelahuil ja joji. Mi jas huas stz'unuhue soc mi ni huax jach'ulaniye, mi ni ba huas snolo ja suaelei soc mi ni ay sranchoea pero anima, ja Diosi huan nix yaa yi ja suaelea. Iday, ja yenlei, yalchane, ¡jauc to ma huenlexi!
\v 25 ¿Huan ama xa hualahuex que oj ajyan jitzan tiempo ja ba luumi yuj ja chamc'ujol xta ayexi?
\v 26 ¡Mi ni ay sbej ja chamc'ujola! Mi oj alban mas ja ba luumi soc mi ni oja taa ja jas huaxa c'ulan necesitar yuj ja chamc'ujol xta ayexi.
\v 27 Q'uelahuil ja yal nichim huax ajyi ja ba huitzi. Mix atjiye. Mix ch'alniye. Pero mi ni ja sc'u ja rey Salomoni mi slaja ja jastal ja yelahuil ja yal nichim jahui conser ja Salomoni jel tzamal juntiro ja sc'u huas slapa ajyi.
\v 28 Jaxa nichim ba huitzi, ja huego yaax, jaxa jecheli huax ch'ac c'ac', pero anima, jel tzamal ja yelahuil huas sc'ulan ja Diosi, ¡jauc to ma huenlex mi oj ni sc'utesexa! ¡Pero ja huenlexi mi mero huaxa c'uanex!
\v 29 Mi lom xcham ac'ujolex ja jas oja huabyexi soc ja ja' oja huuexi. Mi jauc ja chamc'ujol xta oj ajyaniqui.
\v 30 Spetzanil ja jastal iti, ja' huajel sc'ujol ja ma' mi sc'uan ja Diosi pero ja huenlexi ay jun aTatex huas snaa jasunc'a huaxa c'ulanex nesesitari.
\v 31 Jayujil, aa bajex ja ba sc'ab ja Diosi. Jach c'a huaxa c'ulanex, oj ni ataex ja jastic abajexi.
\s1 Ja majtanal tey ba satq'uinali
\r (Mt. 6:19‑21)
\p 
\v 32 Mi ni sbejuc oj xihuanica. Ja huenlexi lajan soc yal jchejex nia. Meran, ja huenlexi jel t'usanex pero ja hua Tatexi jel sgusto que ti xa ayex ja ba sc'abi.
\v 33 Chonohuic ja jastic abajexi. Q'uebahuic yi ja ma' mi jas yioji. Ja jas ahuiojexi a atjuquex soc ja yatel ja Diosi cosaque mi oj ch'ayuc ahuujilexa. Jach c'a huaxa c'ulanex, lajan soc ti xa huanex snoljel ja ba satq'uinali. Ja tihui mi oj bob elc'ajuc soc mi ni ja huorhuojo, mi oj sote.
\v 34 Chican ja ba huaxa yajtayexi, ti ni huajel ja hua c'ujolexa.
\s1 T'ilan chapan oj ajyanic
\p 
\v 35 Ja Jesusi ti och see jastal chapan oj ajyucotic cuando huax co jan otro vuelta ja yeni. Ti yalaa: ―Chapan xta la ajiyex. A xta ajluc ja hua tajexi.
\v 36 Jach la ajyiyex jastal jun mozo huan smajlajel oj jacuc ja yajuali. Ja ajualali huajel to ba jun ch'ac abal. Pero ja huax cumxi jan ja ajualal ja ba snaji, ti huax c'umania. Jaxa smozoi, como huan xta ni smajlajela, jayuj huego huas sama ja puerta.
\v 37 Jel lec oj ec' yujil ja mozo jahui yuj ja cuando huax cumxi ja yajuali, huan xta ni smajlajela. Huax cala, pero meran, ja ajualal jahui ti oj xchap sbaja ba oj ya ec'uc ja huaelal ja ba mesa, jaxa mozo jahui ti xa culan ec' ba mesa ba oj huauc.
\v 38 Anima ba xchabil gallo ma ba yoxil gallo huax jul ja ajualali pero ta sac'an c'a huax c'ot tajuc ja mozo jahui, pues jel lec oj yile.
\v 39 C'ulanic t'un pensar. Ta ay c'a jun huinic huas snaa jas ora oj c'otuc ja lagron ja ba snaji, mi ni oj och suayela. Mi ni oj yaa ja snaj ba oj elc'ajuc yia.
\v 40 Jach ni ja huenlexi. Puesto xta ni ajyanica porque cuando mi huanuquex sc'ulajel pensar oj jaconi, ja' ni mero ora oj jacona. Oj ni cho cocon jan ja ba satq'uinala.
\s1 Ja lequil mozo soc ja mal mozo
\r (Mt. 24:45‑51)
\p 
\v 41 Ja Pedro ti yalaa: ―Cajual, ja loil it ahualai ¿quechan ama quenticon huax hua macchiquinucticon ba, ma spetzanil ja cristiano?
\v 42 Ti yala ja Cajualtiqui: ―Jun ajualal, mi cualquierauc ja smayordomo oj yaa yi ba sc'ab ja snaji. Ja mero yorail ja huaeli, ja' xchol oj yil ta huax ch'ac yii ja suaele spetzanil ja matic tey ba yoj naitzi. Ja mayordomo jahui jel huax c'uaji soc jel toj ja spensari.
\v 43 Ta jach c'a huan sc'ulajel tola vida, cuando xul ja yajuali, jel lec oj iljuc juntiro.
\v 44 Seguro oj ni aajuc ba sc'ab ja jas yioj ja ajualali.
\v 45 Pero ta ay c'a jun mozo huan c'ax yala: Ja cajuali mi baq'uin oj cumxuc, ta xchi c'a ba sc'ujoli, ti c'a huax och smac' ja smoj mozoili soc ja criada jumasa, huas smojan ja yacbum jumasa, huas smojan huael, huas smojan yuujel trago,
\v 46 Mi ni c'a t'un huas sc'ulan pensar jas ora oj jac ja yajuali, pero huaj to yile, ti xa ay ja yajuali, jel tzatz oj yii ja castigo. Ti oj nutzjuc soc ja smoj caprichudoili.
\v 47 Jaxa mozo jau ja ma' huas snaa jasunc'a huas sc'ana ja yajuali pero mi snutzu sbaj soc mi ni huas sc'uana, jel oj mac'juc juntiro.
\v 48 Pero ta ay c'a jun mozo mi snaa jasunc'a huas sc'ana ja yajuali, eso sí, huas sc'ulan ja jas mi lecuqui, oj ni aajuc yi castigo, pero punto. Chican ja ma' ac'ubal ba sc'ab jitzan ja ateli, yuj ni huax c'uaji que toj oj ajyuc soca. Y mi quechanuc ja janec' alubal yabi. Huan ni sc'ulan mas ja atel ta huax yila ay to sc'ana. Jach ni mero huas sc'ana ja ajualali. Ja ma' huax yab lec ja jas huax yala ja ajualali y huan ni sc'ulana, huan nix naaxi que mi quechanuc oj sc'uluc ja janec' huax alji yabi. Oj to sc'ul mas.
\s1 Yuj ja Jesusi, jayuj coraja huax yila sbaje ja cristiano
\r (Mt. 10:34‑36)
\p 
\v 49 Ja Jesusi ti yalaa: ―Yuj ja jacyon ja quen ja ba mundo, jayuj oj ch'ac q'ue ja suocol ja cristiano. Pero ja huocol jahui, mi pierouc anima cajan xta c'ac' oj ajyanic.
\v 50 Pero jach ni ja quen chomajquili. T'ilan oj q'ue lec ja juocoli. Cuando huax jac jc'ujoli, huax syatz'a sbaj ja caltzili, lajan soc ec' ta cuj.
\v 51 ¿Huan ama xa hualahuex ta jacyon ja ba mundo ba laman oj ajyuc ja cristiano? Meran huax cala huabyex, miyuc. Yuj ja jacyoni, jayuj oj yil sbaje condra ja cristiano.
\v 52 Ja huego ba jun naitz, ta ay c'a joe suinquil, coraja oj yil sbaje. Ja jun c'olei, oxhuane, jaxa otro jun c'olei, chahuane.
\v 53 Ja tatali condra oj yil ja yunini, jaxa uninali oj yil condra ja stati. Jachuc jun nanal, condra oj yil ja yali, jaxa aq'uix jahui, condra oj yil ja snani. Jachuc ja alibali, condra oj yil ja yalibi, jaxa ma' ochel alibajeli, condra oj cho yil ja yalibi.
\s1 Ja seña ja tiempo jastal oj to ec'uqui
\r (Mt. 16:1‑4; Mr. 8:11‑13)
\p 
\v 54 Yajni ch'ac yal jachuc ja Jesusi, ti och see yi ja cristiano jumasa: ―Cuando mi stiempo jauqui, huaxa huilahuex lechechi xta huax q'ue ja asoni: Es, ja yaani oj jac ja jai, la chiyex, y huan nix yaa merana.
\v 55 Cuando huax jac ja iq'ui: Ja yaani mi xa oj to yaa ja jai. Jamxi ta can ja satq'uinal, la chiyex. Jach ni meran huas sc'ulan ja ic'a.
\v 56 ¡Toj chab lado ayex! Eso sí, vivoex soc ja seña ja satq'uinali soc ja ba luumi, pero jastal oj to ec'uc ja tiempo oj jaconi, jel tontoex juntiro. Iday, ay lec seña pero mi huax jac ac'ujolex.
\s1 C'ulan fuerza oja tojbes abaj soc ja hua condra
\r (Mt. 5:25‑26)
\p 
\v 57 ¿Pero jas mi xa c'ulanex lec pensar ja ba toji?
\v 58 Cuando ay jun acondraex, jaxa yeni oj squichex och ja ba sti sat ja ma' ay yatel, mas lec cuando ti to ayex ja ba beji, lea modo jastal oja c'umuquex. Mi c'a xa lea modo jastal oja c'umuc, oj ni yia och ja ba sti sat ja jueza, jaxa juezi oj yaa ba sc'ab ja comandante, jaxa comandante oj sluta preso.
\v 59 Huax cala, pero meran, ja tihui mi ni oj elana masan to xch'ac atup spetzanil ja hua muli.
\s1 Ta mi c'a xa tucbes ja hua pensarexi, oj ni chamanica
\c 13
\p 
\v 1 Ja mismo tiempo jau huan to seejel ja Jesusi, ti jac chaboxe huinica. Jac yale yab ja Jesusi ja jastal huajye chaboxe huinic sbaj Galilea. Huane bi smiljel chante ba oj yaahue yi ja smajtan ja Diosi jaxa mismo ora jahui, ja yenle chomajquili, cho miljiye, pero ja' yaa orden ja Pilato ba oj miljuque.
\v 2 Ti yala ja Jesusi: ―¿Yuj ama huaxa hualahuex que jel ja smulei, jayuj chamye? ¿Yuj ama mi ni june ja galileño oj slaj ja smul ja yenle ba?
\v 3 Pero huax cala que miyuc. Jach ni ja huenlex chomajquili. Oj ni chamanic ta mi c'a xa tucbes ja hua pensarexi.
\v 4 Jaxa dieciocho huinic jau chamye ba Siloé cuando t'enjiye yuj ja chaanil naitz jahui, ¿yuj ama jel ja smule ba? Ja ba spetzanil ja suinquil ja Jerusaleni, ¿yuj ama quechan ja yenle ay smule ba?
\v 5 Pero huax cala que miyuc. Jach ni ja huenlex chomajquili. Oj ni chamanic ta mi c'a xa tucbes ja hua pensarexi.
\s1 Ja steil higo ba mey sati
\p 
\v 6 Ti cho yala otro jun loila: ―Ay jun huinic ay stz'ununej jun ibe higo ja ba yalaji. Huaj yil ta ay xa sat pero mi jas staa.
\v 7 Entonces ti yal yab ja huinic ja ma' huas stalna ja alaj jahui: Q'uelahuile, ay xa oxe jabil huax jac quil ta ay sat ja higo iti pero mi ni jun jabil huax taa ja sati. Mas lec, c'utzu xa ele. Lom huan smacjel luum ja ili, xchi.
\v 8 Ti yala ja ma' huas stalna ja alaji: Cajual, aa can siquiera ja jabil iti. Oj boy ja luum ja yibeli soc oj cho jc'ul abonar.
\v 9 Ta huan c'ax yaa sati, lec, pero ta mi c'a, ti xa xa c'utzu ela, xchi ja talna‑alaji. Jach yala jastal it ja Jesusi.
\s1 Aaji tojbuc jun ixuc c'ochan huax bejyi ajyi
\p 
\v 10 Jun sc'ac'uil sijlele ja judio jumasa, ja Jesusi ti huan seejel ja ba yiglesiaei.
\v 11 Ja tihui tey jun ixuca. Ay xa dieciocho jabil malo ay. Ja chamel yioji ac'ubal yi yuj ja pucuji. C'ochan xa juntiro huax bejyi. Mi xa ni modo huax bob xijpuc sbaja.
\v 12 Cuando yila ja Jesusi, ti spaya jana. Ti yalaa: ―Nana, ja yaani oj xa tojban soc ja chamel ahuioji.
\v 13 Ti ya cajan ja sc'ab ja Jesús ja ba scuerpo ja ixuc jahui, jaxa mismo ora jahui, huego huego xijpun sbaj. Ti och sc'an yi stz'acatal ja Diosa.
\v 14 Pero ja sepeil ja iglesia jahui q'ue juntiro ja scoraja yuj ja ja' ni ja sc'ac'uil jijlel aaji tojbuc ja ixuc jahui. Ja jepe ba iglesia ti yal yab ja cristiano: ―Huaque c'ac'u ay ja ba oj atjucotiqui. Ja' la jacyex ja c'ac'u jumasa jahui ba oj aaji tojbaniqui, mi jauc ja ba sc'ac'uil ja jijleltiqui, xchi.
\v 15 Ti sac'a jan ja Cajualtiqui: ―¡Toj chab cara ayex! Q'uelahuil ja huenlexi. Ta mochan c'a te' ja hua huacaxex ma ja hua burroexi, anima jauc ja sc'ac'uil ja jijleli, ¿mi ma oja sijpuquex ba oj huaj yu ja' ba?
\v 16 ¡Jauc to ma ja ixuc iti, ja' ni ja yintil ja Abraham tac! Ja yeni ay xa dieciocho jabil mochante yuj ja Satanasi. ¿Mi ma sbejuc ni oj c'ulaxuc librar ba, anima jauc ja sc'ac'uil ja jijleli?
\v 17 Cuando ch'ac yal jachuc ja Jesusi, spetzanil ja scondra jumasa jel q'uixhuiye juntiro. Pero ja otro cristiano jumasa, jel gusto yabye ja jas yilahue jel tzamal huan sc'ulajel ja Jesusi.
\s1 Ja loil sbaj ja sbac mostaza
\r (Mt. 13:31‑32; Mr. 4:30‑32)
\p 
\v 18 Ti cho yala ja Jesusi: ―Oj cala huabyex jastal huax pojxiye ja ma' ac'ubal mandar yuj ja Diosi.
\v 19 Lajan soc jun yal sbac' mostaza. Ja mostaza jahui tey ba yalaj jun huinic. Jaxa huiniqui, huaj to yile, pojxi ta lec ja jun yal sbac' jahui. Hasta ja yalchani bob sc'uluc ja soj ja ba pimi.
\s1 Ja loil sbaj ja slevadurail ja pani
\r (Mt. 13:33)
\p 
\v 20 Ja matic ac'ubal mandar yuj ja Diosi lajan soc ja levadura.
\v 21 Lajan soc ja slevadurail ja pani. Q'uelahuil jun ixuc. Huax yiaj ja levadura jahui, ti huas soco soc oxe medida harina. Huan tox huaj yile, q'ui ta lec ja pani.
\s1 Ochanic ja puerta ba ch'ini
\r (Mt. 7:13‑14, 21‑23)
\p 
\v 22 Ja Jesusi cuando huan huajel ja ba Jerusaleni, ti huax ec' ja ba chonab jumasa soc ja ba yal hacienda jumasa. Ti huax ec' see yi ja cristiano.
\v 23 Pero jun c'ac'u ti jobji yi ja Jesusi: ―Cajual, ¿t'usan it ama ja ma' oj aaji el libre soc ja smule yuj ja Dios ba? Ti yala ja Jesusi:
\v 24 ―C'ulanic fuerza ba oj ochanic ja puerta ba ch'ini. Huax cala huabyex, jitzan ja ma' oj sc'an oj ochuquei pero mi oj bob yujile,
\v 25 Porque ja suinquil ja naitzi oj q'ueuc. Oj q'ue slut ja puerta. Jaxa huenlex ti ayex ba fuera: Cajual, jama quiticon ja puerta ba, oj chianic. Jaxa suinquil ja naitzi ti oj yala huabyexa: Mix naa ba jaquelex ja huenlexi.
\v 26 Jaxa huenlexi ti oja hualexa: ¿Mi ma xa naa ba? Pe huaelotic ni lajan tac. Ja huana seejel ja ba yoj plaza, ti ni ayticon ja quenticon tac.
\v 27 Jaxa yeni ti oj yala huabyexa: Huax cala huabyex, mix naa ba jaquelex ja huenlexi, oj yutex. ¡Elanic ja ba jtz'eel ja huenlexi porque puro malo jas ac'ulanexi! oj yutex.
\v 28 Ja tihui oj oc'anic lec. Cuando huaxa huilahuex sat ja Abrahami soc ja Isaqui soc ja Jacobi soc spetzanil ja aluman‑Dios jumasa, como ja yenlei ti aye ja ba huas sc'ulan mandar ja Diosi, jaxa huenlexi, ti ayex ba fuera, ti oja c'uxex lec ja hua huejexi.
\v 29 Ja cristiano tey ba huas sc'ulan mandar ja Diosi oj ch'ac stzom sbaje ja ba xchanil xchiquin ja satq'uinali ba oj huauque ja ba mesa ja ba huas sc'ulan mandar ja Diosi.
\v 30 Jaxa c'ac'u jahui ja ma' lajan soc mi cristianouc ilji yuj ja smoj cristianoili, pero ja' xa soc ja Diosi jel nihuan oj iljuc. Jaxa ma' jel nihuan huax ilji ja ili, pero ja ora jahui jel ch'in oj iljuc, xchi ja Jesusi.
\s1 Ja Jesusi oc' yuj ja suinquil ja Jerusaleni
\r (Mt. 23:37‑39)
\p 
\v 31 Ja mismo ora jahui ti huaj chaboxe fariseo. Huaj yale yab ja Jesusi: ―Mas lec elan ja ili porque ja tan rey Herodesi huax yala oj bi smila.
\v 32 Ti yala ja Jesusi: ―A, ja huinic jahui quechan jel vivo soc ja smaloili. Cax alahuic yabi que ja yaan c'ac'ui soc ja jecheli oj ca el libre ja cristiano ja ma' huan ixtalajel yuj ja pucuji. Oj ni ca tojbuc ja ma' malo ayi. Man to chabej oj ch'acuc ja cateli, utajic.
\v 33 Ti ni huajumon ja ba Jerusalena. Oj to bejyucon ja yaani soc ja jecheli soc ja chabeji. T'ilan ni oj huajcona porque mi ni jun aluman‑Dios chamel ja ba otro lugari, quechan ti ba Jerusaleni. Cax alahuic yab jastal it ja Herodesi, xchi ja Jesusi.
\v 34 Yajni ch'ac yal jachuc ja Jesusi, ti och yala: ―A jerusaleño, suinquil ja Jerusaleni, huaxa milahuex ja aluman‑Diosi. Soc ton huaxa milahuex ja matic huax jecji ahuilex. Mi naben jaye vuelta huax c'ana oj tzomex can jastal ja gallina huas stzomo ja yuntiquili ti huax yaa ba yibel ja suech'i, pero mi ni modo huaxa c'anahuexa.
\v 35 ¡Ay pobre ja huenlexi! Oj xa can lutan ja hua najexi. Huax cala huabyex quechan xta huaxa huilahuonex ja huego. Eso sí, oj to ahuilonex pero ja ora jahui, stz'acatal ja ma' huax jac yuj ja sbiil ja Cajualtiqui, oj chianic.
\s1 Aaji tojbuc jun huinic sitz'el ja yoc sc'abi
\c 14
\p 
\v 1 Jun sc'ac'uil ja sijlel ja judio jumasa ja Jesusi ti locji huael yuj june ja fariseo ja ma' ay yatel. Ti huaj ja ba snaji. Tey chaboxe ja smoj fariseoil ja ma' locuanel huaeli, jaxa yenlei huane smajlajel ta ay jas oj el sti ja Jesusi.
\v 2 Cho tey jun huinic ba mojan ja stz'eel ja Jesusi jaxa huinic jahui, sitz'el sni sat.
\v 3 Ja Jesusi ti sobo yi ja ma' huas sea ja smandar ja Moisesi soc ja fariseo jumasa: ―¿Lec ama ta huax caatic tojbuc ja ma' ay xchamel ja sc'ac'uil ja jijleli? xchi.
\v 4 Jaxa yenlei mi ni jun palabra ma' c'umani yujilea. Jaxa Jesusi ti syama ja ma' malo ayi, ti ya tojbuca, ti yal yaba: ―Cax xa, x'utji ja ma' malo ay ajyi.
\v 5 Ti yal yab ja fariseo jumasa soc ja matic huas sea ja smandar ja Moisesi: ―Q'uelahuil ja huenlexi, ta huan c'ax moc' q'ueen ja hua burroexi ma ja huacaxexi, ¿mi ma oj ni hua eluquex huego ba, anima jauc ja sc'ac'uil ja jijleli? xchi ja Jesusi.
\v 6 Jaxa yenlei mi ni jun palabra ma' sama stii.
\s1 Ja matic locji ba jun ch'ac abali
\p 
\v 7 Jaxa tuc jumasa, ja ma' locobal ni, yajni huax ochye c'ote, huan ita sq'uelahue ja silla ba mojan stz'eel ja suinquil ja naitzi. Ja Jesusi cuando yila jastal ja smodoei, ti och yal jun loila:
\v 8 ―Ta ay c'a ma' huas slocohuex ba jun ch'ac abal, mas lec mi la ochyex culan ja ba lugar tzaubali porque mi xa naa ta ay ma' oj jacuc jaxa yenlei mas t'ilan ti oj ochuque culan ja tihui que soc ja hueni.
\v 9 Entonces oj jacuc ja suinquil ja naitzi, oj yala huabi: ¿Mi ma oj bob huajan culan ja ti c'ote porque ay ma' oj och culan ja ili? oj yuta. Jaxa hueni, ti oj elana pero jel oj q'uixhuan, ti oj huajan ja ba jun xchiquin naitz.
\v 10 Mas lec, cuando huala locjiyexi, culananic ja ba stz'eel ja ma' mey xcholi. Ti oj jacuc ja suinquil ja naitzi: Jaxa huen tatjun, ¿jas huaxa lea c'ot ja tihui? Ja hueni sbej ni ti oj jacan il ja huena, oj yuta. Ti oj yila ja cristiano que tzaubal ja hua lugari.
\v 11 Porque ja ma' jel huas stoyo sbaje oj aaji q'uixhuuc, jaxa ma' mi huanuc sleejel ba oj toyjuqui, mas toyobal oj huajuc.
\v 12 Cuando ch'ac yal jachuc ja Jesusi, ti yal yab ja ma' locuani: ―Ja hueni, cuando huaxa c'ulan jun q'uin y huaxa huaa huaelal, mi lom xa loco ja hua huamigo jumasa, mi ni ja hua huermano jumasa, mi ni ja hua najtil hermano, mi ni ja hua vecino jumasa ja ma' jel ja staq'uini. Porque ja yenlei ay modo oj cho sloca. Ta jach c'a, lajan soc huan nix ya paxuc ahui sloc'ola.
\v 13 Mas lec, cuando huaxa c'ulan jun huaelali, loco ja pobre jumasa soc ja impedido jumasa soc ja renco jumasa soc ja ma' tupel ja sati.
\v 14 Ti oja huil que jel gusto oj canuc ahualtzili, porque mi oj bob cho yaa hui ja yenlei. Jaxa ora oj ya sac‑huuc ja Dios ja ma' jel toj ayi, ti oj aajuc ahui ja stz'acol ja jas huaxa huaa.
\s1 Jun huinic sc'ulan jun nihuan huaelal
\p 
\v 15 Ja ch'ac yal ja jastal it ja Jesusi, ti yala june ja ma' ti culan ja ba mesa: ―¡Lec xta yuj ja ma' oj locjuc huael ja ba huas sc'ulan mandar ja Diosi!
\v 16 Ja Jesusi ti yalaa: ―Ay jun huinic sc'ulan jun nihuan huaelal y jel jitzan ja matic slocoi.
\v 17 Jaxa cuando lec xa ay ja huaelali, ti seca ja smozo ba oj ch'ac spay jan ja ma' sloconeji: Laic xa. Ja huaelali lec xa ay, xchi ja mozoi.
\v 18 Iday, spetzanile ch'ac yale que mi oj bob jacuque. Ja ba mero bajtan huaji: Huan tox ch'ac jman jun pedazo jluum. Ja' t'ilan oj huaj quile, jayuj c'ulanon perdonar, xchi.
\v 19 Jaxa otro juni ti cho yalaa: Q'uelahuile, jmanunej to joe teele juacax. Huax c'ana oj c'ul probar. C'ulanon perdonar, xchi.
\v 20 Ti cho yala ja otro juni: Ajc'ach to ch'ac nupanucon, jayuj mi oj bob huajcon, xchi.
\v 21 Jaxa mozo ti cumxia. Huaj yal yab ja yajuali. Ti jel q'ue ja scoraja ja suinquil ja naitzi. Ti alji yab ja mozo: Cax ja ba plazai soc ja ba calle jumasa ja ba yoj chonabi. Iaj jan ja pobre jumasa soc ja impedido jumasa soc ja renco jumasa soc ja matic tupel ja sati, xyutaj ja smozo. Jaxa mozo ti huaja.
\v 22 Cuando cumxi jani, ti yalaa: Cajual, jc'ulan ja jas ahualai pero ay to ni lugara, xchi.
\v 23 Ti yala ja ajualali: Pues cho cax ja ba beji. Ta ay c'a ma' huaxa taa tec'an ja ba sti ja beji, chican ma' huaxa taa, iaj jan t'ilan ba oj but'uc ja jnaji.
\v 24 Huax cala, pero meran, ja ma' mero jloconeji mi ni oj yabye yajbal ja huaela, xchi ja ajualali. Jach ni sbej ja loil it ja jastal yala ja Jesusi.
\s1 Jel huocol oj bob caa jbajtic ja ba sc'ab ja Cristo
\p 
\v 25 Ja Jesusi ti huan huajel soc jun nole lec ja cristiano ja ba Jerusaleni. Ti sutu sbaja. Ti yalaa:
\v 26 ―Ta ay c'a ma' huas sc'ana jac jmoc ja queni pero ta mas c'a jel yaj huax yab ja snan stati, ma ja xcheumi, ma ja yuntiquili, ma ja yermano, ma ja yermana yuj ja queni, entonces mi sbejuc huax och jnebumanil. Jachuc ja ma' huajel sc'ujol huas syajta sbaj ja yen mismo, mi ni sbejuc huax och jnebumanila.
\v 27 Ta ay c'a ma' huas sc'ana oj jac jmoc, pero ta mi c'a huas sc'ulan ahuantar ja huocoli, mi lom xa huala ta jnebuman ja yeni. Ja ma' jnebuman ni ja queni, oj sc'ul ahuantar ja huocoli, anima huax aaji locan ja ba cruzi.
\v 28 Q'uelahuil ja huenlexi, ta huaxa c'ana oja c'uluquex jun nihuan naitz, bajtan oja c'uluquex pensar ta oja taex ja taq'uini ba oj ch'ac ac'uluquexi.
\v 29 Mi c'a, c'ot ora quechan huax hua chotanex cani, jaxa s'olomi mi oja taex. Jaxa ma' huax yila ti oj och stzeuquexa:
\v 30 Ja huinic iti och suas sbaj soc ja snaji pero mi bob yuj, oj chiuque.
\v 31 Q'uelahuil, ta ay chab rey jel coraja huax yila sbaje, nechan xta aye, oj q'ueuc ja guerra. Pero ja juni, quechan diez mil soldado yioj, jaxa juni, ay yioj veinte mil. Ja ma' quechan diez mil yioji, mi sc'ana ya q'ueuc ja pleito. Bajtan oj sc'ul pensar que mi oj bob yuj.
\v 32 Cuando najat to ay ja otro reyi, oj sec ja secabanumi. Oj huaj slee modo jastal oj canuque gusto.
\v 33 Jachuc ja huenlexi. Ta mi c'a pensado ayuquex lec ba oja huaex can spetzanil ja jas ahuiojexi, mi ni oj bob oj ochanic jnebumanila.
\s1 Ja atz'am huax jomi
\r (Mt. 5:13; Mr. 9:50)
\p 
\v 34 Ja ma' huas sc'ana oj och jnebumanil, jel ni leca. Porque q'uelahuil ja atz'ami, mi ni oja hual que mi lecuca. Pero oj cho cala huabyex, moca lajex ja atz'am it huax pooxi, mi xa nix maconi ja mas tzaani,
\v 35 Mi ni ba abono. Sbaj xa ni xch'ayela. Ja' ni mero smoj ja ma' yaahuon ta cani. Mi xa ni jun yatel cujila.
\s1 Ja ch'ayel cheji
\r (Mt. 18:10‑14)
\c 15
\p 
\v 1 Spetzanil ja colector jau ja ma' huas stzomo ja taq'uini soc ja otro mulanum jumasa ti jacye ja ba stz'eel ja Jesusi ba oj smaclaye ja jas huax yala.
\v 2 Ja yajni yilahue ja fariseo jumasa soc ja matic huas sea ja smandar ja Moisesi ti och bulbunuquea: ―Ja tan huinic iti lajan huas staa sbaj soc ja mulanum jumasa. ¡Jun ta sec' huax huaaye tac! xchiye xta.
\v 3 Jaxa Jesusi ti och yal jun loila:
\v 4 ―Q'uelahuil junuc ja huenlexi. Ta ay c'a ma' yioj cien chej, ta huan c'ax ch'ay junuc ja cien jahui, entonces ti oj yaa can ba huitz ja noventa nueve, ti oj cumxuc ba oj slee ja jun yal chej jau ch'ay cani man oj stae.
\v 5 Cuando huas staai, ti oj ya cajan ja ba stejlubi. Jel xa gusto oj cumxuc ja ba snaji.
\v 6 Jaxa cuando huax c'ot ja ba snaji, ti oj stzom ja yamigo jumasa soc ja svecino jumasa. Ti oj yal yabyea: La xa jc'ultic jun q'uin porque jtaa ja yal chej ch'ayeli.
\v 7 Meran huax cala huabyex, ta huan c'a suchi ja sc'ujol ja june ja ma' ay smuli, jel oj yaa gusto ja ba satq'uinali. Pero ja noventa nueve jau huas stoyo sbaj que jel toji, mi sc'ana suchuc ja sc'ujolei, mi ni t'usan huax yaahue gusto ja ba satq'uinali.
\s1 Ja taq'uin ch'ayi
\p 
\v 8 Jach ni jun ixuc ta ay c'a yioj lajune peso taq'uin, ta huan c'ax ch'ay yuj jun peso ja staq'uin jahui, oj ni xch'ix ec' ja staj ja ba yoj snaji. Ti oj och smes ja snaji. Oj slee lec masan oj stae.
\v 9 Yajni huas staai, ti oj sloc jan ja yamiga jumasa soc ja svecina jumasa. Ti oj yala: La xa c'ultic jun q'uin porque jtaa ja cala taq'uin ch'ayeli.
\v 10 Jayuj huax cala huabyex, jel gusto huax yab ja yangel ja Diosi ta ay c'a jun mulanum huas suchi ja sc'ujoli.
\s1 Ja uninal ja ma' xch'aya sbaji
\p 
\v 11 Ja Jesusi ti cho yala otro jun loila: ―Jun huinic ay yioj chab yunin.
\v 12 Ja ijtz'inali ti yal yab ja stati: Tatey, aa qui ja jdote it oj ni ahuaa quii, xchi. Ti pilji yile ja sdoteei.
\v 13 Jaxa ec' t'usan ja c'ac'u, ja ijtz'inal jahui ti ch'ac stzom spetzanil ja sastic sbaji. Ti huaja. Ti huaj ba jun lugar najat lec, jaxa tihui, ti ch'ac xch'ac el lom q'uiq'uinal ja staq'uini. Xch'ayelal ni huaj juntiroa.
\v 14 Yajni ch'ac ta yixtalauc el spetzanil ja staq'uini, ti co jun nihuan huain ja ba lugar jahui. Iday, jaxa yeni mi xa ni jun centavo yioja.
\v 15 Ti huaj sc'ap sbaj yi jun huinic ja ba lugar jahui. Ti jecji ba jun srancho ba oj stalna chitam.
\v 16 Pero mi ni huax aaji huauca. Ja huax yaa yi ja suael ja chitami, lajan soc oj cho sc'ux ja yeni.
\v 17 Ti och sc'ul pensara: Ja ba srancho ja jtati mi naben jaye atjum huan ateli pero ay lec suaele. Huax can sobra ja suaele ja huax huaayei, jaxa queni huanon chamel huain ja ili, xchi.
\v 18 ¡Oj xa ma cumxucon soc ja jtati! Oj cal yab jachuc: Tatey, jlea ta jmul soc ja ma' tey ba satq'uinali soc ja huen chomajquili, oj ma cute.
\v 19 Anima mi xa xa huilahuon jastal ahuunin, siquiera oja huilon jastal junuc ja hua huatjumi, oj ma chicon c'ote.
\v 20 Ja ijtz'inal jahui ti xa huaj ja ba snaj ja stati. Cuando najat to ayi, ti ilji yuj ja stati, jaxa stati jel lástima yila ja jastal xa ayi. Ti huaj staa ajnela. Ti stela leca. Yujtz'an.
\v 21 Ti yal yab ja stati: Tatey, jlea ta jmul soc ja ma' tey ba satq'uinali soc jachuc ja hueni. Ja yaani mi xa ni sbejuc oja huilon ja jastal huaxa huilahuon ajyi. Lajan soc mi xa ni ahuuninucona.
\v 22 Pero ja tatali ti yal yab ja smozo: Iajic jan ja jc'u ja ba mas tzamali. Aahuic slap ja cunini. Aahuic yi jun anillo ba oj ya och ja ba sc'abi, cho aahuic yi jun xanab.
\v 23 Cax yamahuic ja becerro jau ba mas cojleli, ti xa milahuexa. Oj c'uxtic. Oj c'ultic jun q'uin.
\v 24 Porque ja cunin iti lajan soc cham ta ajyi pero ja huego, lajan soc sacui ta. Ch'ayel xa ni ay ajyia pero ja huego, jac ta yaa sbaj quitic, xchi ja tatali. Ti och ya q'ueuque ja q'uina.
\v 25 Jaxa banquilali ti huajel ba huitz ja ora jahui. Yajni cumxi, ja mojan xa yioj ja snaji, ti yab que jel ja q'uin ja ba snaji soc ay chaanel.
\v 26 Ti spaya jan june ja mozo. Ti sobo yi jasyuj jel ja q'uini.
\v 27 Ti yala ja mozo: Ja' jul ta hua huijtz'ini. Jel lec ay ja juli. Mi ni ay spaltaila jayuj ja yila ja hua tati, yala que oj milticon ja becerro it jel cojleli, xchi ja mozo.
\v 28 Jaxa banquilali jel q'ue juntiro ja scoraja. Mi ni t'un yala oj ochuca. Yajni yila ja stat que mix yala oj ochuc, ti huaj yal yab que oj ochuc ja ba yoj q'uini.
\v 29 Ti yala ja banquilali: Tatey, naa t'unuc jaye jabil huanon atel amoc. Mi ni jun vuelta ba mix c'uan ja hua huabali. Pero iday, mi ni siquiera jun yal chibo huaxa huaa qui ba oj c'ul q'uin soc ja camigo jumasa.
\v 30 Iday, jaxa huego yuj ja jul ta tan ahuunin it ja ma' quechan ixuc huajel sc'ujoli ‑ soc ni ixuc ch'ac xch'ac el lom ja hua taq'uin it ja huaa yii, iday, ¡jaxa huen huana smiljel ja becerro mas cojleli!
\v 31 Ti yala ja stati: Q'uelahuil cunin, ja hueni tola vida ti ni aya jmoca. Spetzanil ja jas quioji naca baj ni ja huenaa.
\v 32 Pero ja huego sbej ni oj caatic sq'uinil ja hua huijtz'ina. Oj ni ajyucotic soc gustoa porque ja hua huijtz'ini lajan soc cham ta ajyi pero ja huego lajan soc sacui ta. Ch'ayel xa ni ay ajyia, pero ja huego jac ta yaa sbaj quitic, xchi ja tatali. Spetzanil ja loil iti, jach yala ja Jesusi.
\s1 Ja mayordomo ja ma' slola ja yajuali
\c 16
\p 
\v 1 Ja Jesusi ti cho yal yab ja snebuman jumasa: ―Ay jun ajualal jel rico soc ay jun smayordomo. Jaxa mayordomo jahui ti huaj chonjuc yabalil ja jastal lom q'uiq'uinal huan xch'acjel ja staq'uin ja yajuali.
\v 2 Jaxa ajualali ti seca spayjela: Ay jas huanon yabjel ja huabalil, jayuj ja huego mi xa oj to caa ja hua huateli pero c'ulan qui entregar spetzanil ja juun jas tey ba hua c'abi, x'utji.
\v 3 Jaxa mayordomo jahui ti och juntiro ja spensari: ¿Jasunc'a oj c'uluc ja yaani? Ja cajuali oj xa ya el qui ja catel tac, y mey quip oj atjucon soc ja luumi. Oj cho q'uixhuucon ja oj c'an ec' limosna.
\v 4 Pero jnaa ta jas modo oj c'uluc. Oj lee ja camigo jumasa, ja ma' oj snolon ja ba snaj cuando x'aaji elcon ja mayordomoili.
\v 5 Ti ch'ac sec spayjel spetzanil ja ma' ay sel yuj ja yajuali. Jaxa ma' bajtan jaqui, ti sobo yia: ¿Janec' ja hua jel soc ja cajuali? xchi.
\v 6 Jaxa yeni ti yalaa: Pues ay jel soc cien barril aceite. Ti yala ja mayordomo jahui: Iaj ja juun iti. Quechan xta cincuenta a och juun huego, xyutaj.
\v 7 Ti cho jul ja otro juni: Jaxa hueni, ¿janec' ja hua jeli? Ti yala ja yeni: Pues ay quioj cien medida trigo, xchi. Ti yala ja mayordomoa: Iaj ja juun iti. Quechan xta ochenta a och juun, xyutaj.
\v 8 Jaxa ajualali cuando yab jas huan sc'ulajel ja mayordomo jahui, ti yalaa: ¡A, ja tan huinic jahui jel vivo soc ja smaloil ja jas huan sc'ulajeli, xchi. Ti yala ja Jesusi: Meran nia. Jach ni ja ma' tey ba mundo tac. Jel snaa huas sc'ulan ja trato soc ja smoj jumasa. Mas jel vivoe ja yenle soc ja ma' spila ta sbaj ja ba q'uiq'uinali.
\v 9 Oj cala huabyex jasunc'a mas lec oja c'uluquexi. Ja huego ti ayex ja ba yoj maloili jaxa taq'uin tey ba hua c'abexi, mas lec, lean ja hua huamigoex soc ja jahui. Porque oj c'otuc ja c'ac'u ja mi jas ahuiojexi pero ta jach c'a ac'ulanex, ay ma' oj sc'uluquex recibir ja ba snaji, ja' ni ja snaj ja ma' ti culan ja ba satq'uinali, jaxa naitz jahui mi ni nunca oj ch'acuc.
\v 10 Ja ma' toj ay soc ja t'usan yioji, toj ni oj cho ajyuc soc ja ta jitzan c'a yioji. Jaxa ma' mi tojuc ay soc ja t'usan yioji, ¡jauc to ma ta aay c'a yioji, mi ni t'usan oj ajyuc soc toja!
\v 11 Ja jas ay ba mundo, chican ja jas tey ba hua c'abexi, ta mi c'a toj ayuquex soc ja jahui, ¡jauc to ma oj aajuc ahuilex ja ricoil ba mi ni nunca huax ch'aqui!
\v 12 Ta huan c'a xa huixtalaan yi ja scosa ja hua moji, jaxa mero ja hua baj ja huen, mi ni nunca jas oja huil sata.
\v 13 Mi ni jun mozo oj bob yatelta chab ajualal. Ta jach c'a huas sc'ulan, coraja oj yil ja jun yajuali, jaxa juni, yaj oj yabi. Ja' oj yaa sc'ujol ja juni, jaxa otro juni mi ni t'un oj squitz'a. Ja Diosi, ma ja taq'uini, jayuj tzaa ba oja huaa c'ujoli, xchi ja Jesusi.
\v 14 Jaxa jas huan yaljel ja Jesusi, ti huan yabjel ja fariseo jumasa. Ja yenlei, como ja' huajel sc'ujole ja taq'uini, ti huas spechtianea.
\v 15 Ti yala ja Jesusi: ―Ja huenlexi quechan huaxa jea bajex que jel lequex ja ba sat ja cristiano pero ja Diosi huas snaa jastal ay ja hua c'ujolexi. Ja cristiano ja jas jel nihuan huax yilahue ja ili pero ja Diosi jel tuu huax yabi.
\s1 Ja smandar ja Moisesi soc ja jastal huas sc'ulan mandar ja Diosi
\p 
\v 16 Cuando mi tox q'ue stul oj yaa bautismo ja Juani, ti xa ni ay ja smandar ja Moisesi soc ja jas stz'ijbaye can ja aluman‑Dios jumasa. Jayuj yajni q'ue yaa bautismo ja Juani, ti xa och loiltaxuc ec' ja jastal huas sc'ulan mandar ja Diosi. Jaxa spetzanil ja mulanum jumasa huan xta sbatalaan sbaje siquiera ba oj ochuque ja ba huas sc'ulan mandar ja Diosi.
\v 17 Anima huax ch'ac ja satq'uinali soc ja luumi pero ja smandar ja Diosi, t'ilan ni oj c'ot smeranila.
\s1 Ja ma' huas sipa can ja xcheumi
\r (Mt. 19:1‑12; Mr. 10:1‑12)
\p 
\v 18 Ta ay c'a jun huinic huas sipa can ja xcheumi, huax nupani soc otro ixuc, huan ni staa smula. Jaxa ma' cho nupani soc ja ixuc ma' jipji cani, jach ni ja yeni, huan ni staa smula.
\s1 Ja huinic rico soc ja Lázaro
\p 
\v 19 Ja Jesusi ti cho ya q'ue otro loila: ―Ay jun huinic rico. Ja sc'u huas slapa puro pino. Jel tzamal juntiro. Cada c'ac'u huax yaa jun nihuan huaelal, jaxa ba huax huaa ja cristiano, tojbel lec.
\v 20 Cho ay jun huinic limosnero, Lázaro sbiil. Ja yeni ti moch'an ec' ja ba spuerta ja rico jahui, jaxa scuerpo puro xta llaga.
\v 21 Ti huax jac ja tz'ii. Huax jac lecjuc yi ja llaga yioji. Huas sc'ana oj huaj stul ja stz'ubil ja suael huax moc' ja ba yib smesa ja rico.
\v 22 Jun c'ac'u cham ja pobre huinic jahui. Jaxa angeli ti jac yiea ba ti oj ajyuc soc ja Abrahami ja ba lugar jau jel tzamali. Jaxa rico jau chomajquili, mi ec' mas c'ac'u, ti xta cho chama. Ti huaj mucjuc cana.
\v 23 Jaxa ti xa ay ba slugaril ja chamhuinic jumasa, huan lec huocol. Ti sq'uela q'uea. Ti yila ja Abrahami soc ja Lázaro pero najat aye lec.
\v 24 Ti ahuani tzatz leca: Tat Abraham, talna jyaujulal. Jeca qui ja Lázaro siquiera oj yaa qui jun bechuc ja jai. ¡Taquin xa juntiro yoj jnuc' tac! Jel huanon yiijel huocol ja ba yoj tan c'ac' iti, xchi ja rico huiniqui.
\v 25 Jaxa Abrahami ti yalaa: Hijo, a jac ja hua c'ujoli. Jel lec ec' ahuuj ja yora ti aya ba luumi pero ja Lázaro, jel ajul ja sbaj soc ja xchamel eq'ui. Pero ja huego sc'ulan ta recibir ja svida ba jel tzamali, jaxa hueni huana lec huocol.
\v 26 Jach huaxa huala pero mey modo porque ay jun nihuan uc'um ja ba jnalantiqui. Ta ay c'a ma' huas sc'ana huajuc ja tihui, mix bobi soc mi ni ja huenlexi, mix bob oj jacanic, xchi ja Abrahami.
\v 27 Entonces ti yala ja ricoa: Oj c'an ahui pavor ta jach tat Abraham, jeca qui ja Lázaro ja ba snaj ja jtati.
\v 28 Ja tihui ay to ni joe quermanoa. A huaj yal yabi siquiera moc jacuque ja ba lugar ili porque jel tzatz juntiro ja huocoli. A yal yab que a suchuc ja sc'ujolei.
\v 29 Ti yala ja Abrahami: Ja yenlei tey ba sc'abe ja jas stz'ijbunej can ja Moisesi soc ja aluman‑Dios jumasa pero mix yaahue caso.
\v 30 Ti yala ja rico: Meran, tat Abraham, pero ta huan c'ax huaj junuc ja ma' cham ta, bob ta oj suchuc ja sc'ujolei, xchi ja rico jahui.
\v 31 Ti yala ja Abrahami: Mi tox yaahue caso ja Moisesi soc ja aluman‑Dios jumasa, ¡jauc to ma oj squitz'e ja ma' cham ta, anima xeeji yile entero cristiano! xchi ni ja Jesusa.
\s1 Mi loiltajneluc ja ma' huas slea smuli
\r (Mt. 18:6‑7, 21‑22; Mr. 9:42)
\c 17
\p 
\v 1 Ja Jesusi ti yal yab ja secabanum jumasa: ―Mi oj sc'ul palta jastal oj slee ja smul ja cristiano pero ¡pobre ja yen ja ma' gana huax ya slee ja smul ja smoji!
\v 2 Mas lec, a cajan jun sc'ab cha' ja ba spat s'olomi, tix jipji co ja ba yoj mari porque quechan huax ya slee ja smul ja ma' jel to yaau ay ja ba sti sat ja Diosi.
\v 3 Aa cuidadoex. Ja hua moj creyenteili, ta ay c'a jas huas sc'ulan ahui malo, ti la huaja. Lea modo jastal oja hual yabi. Ta huan c'a sc'ana hui perdón con todo sc'ujol, pues c'ulan perdonar.
\v 4 Anima jach huas sc'ulan ahui juque vuelta ba c'ac'u: Pero mi xa oj to jc'uluc ahui otro vuelta, ta xchi c'a, pues sbej ni oja c'ul perdonara, anima cada vuelta huax yala huab que mi xa oj to sc'uluc.
\s1 Huan c'ax c'uantic ja Diosi, jel ja jas oj bobuqui
\p 
\v 5 Jaxa jecabanum jumasa cuando yabye ja iti, ti yalahuea: ―Aa quiticon mas ja quipticon ba.
\v 6 Ti yala ja Jesusi: ―Q'uelahuilex ja sbac' mostaza. Jel ch'in juntiro pero ta huan c'a xa c'uanex ja jastal ja xch'inil ja sbac' mostaza, oj bob ahualex yab ja moraxte iti: Elan ja ili, tix huaj atz'ap ja hua huech ja ba yoj mari, jaxa te' jahui ti oja huil que oj sc'uuquex.
\s1 Jun mozo, sbej ni oj sc'uluc ja jas oj aljuc yaba
\p 
\v 7 June ja huenlexi, ta ay c'a huiojex jun mozo, jaxa mozo jahui snajtil ja c'ac'u huan atel. Huan jutuj luum. Huan stalnajel huacax, jaxa huax jul ja och c'ac'u ba hua naji, mi ni modo oja hual yabi: La xa culanan. Oj xa huaan, mi oja huute.
\v 8 Miyuc, oja hual yabi: Chapa baj. Oja tojbes qui ja juaeli porque jel huain xcabi. A ec' qui ja jcajpei. Cuando huax ch'ac huaacon ja queni, ti oj huaan ja huena, oja huutex ja hua mozoexi.
\v 9 Ja mozo jahui sbej ni oj sc'uluc ja jas oja hualex yabi y mi sbejuc huaxa huaa yi stz'acatal.
\v 10 Jachuc ja huenlex soc ja Diosi. Smozoex nia. Cuando huax ch'ac ac'uluquex spetzanil ja jas huax yala huabyexi, ti oja hualexa: Como smozootic nia. Sbej ni jach jc'ulantica. Jach oj chianic.
\s1 Aaji tojbuque lajunhuane ja ma' huan c'ael ja sbactelei
\p 
\v 11 Ja Jesusi cuando ti xa ay ba bej cuando huan huajel ja ba Jerusaleni, ti ec' ja ba scol ja lugar Samaria soc ja lugar Galilea.
\v 12 Cuando oj xa c'otuc ja ba jun yal hacienda, ti huaj tajuc yuj lajune huinic ja ma' ay yioj ja chamel jau huax c'a ja sbactelei pero como mix bob mojhuanuque, jayuj
\v 13 Ti ahuaniyea: ―Maestro Jesús, talna jyaujulalticon ja quenticoni, xchiye.
\v 14 Ja Jesusi cuando yabi, ti sq'uela ocha: ―Cax jea bajex yi ja pagre jumasa, x'utjiye yuj ja Jesusi. Ti huajyea. Cuando ti xa aye ba beji, huaj to snaa sbaje, ch'ac ta tojbuque spetzanile.
\v 15 Entonces june ja yenlei, yajni yila que tojbi ta, ti cumxia. Huan yaajel yi stz'acatal ja Diosi, pero ahuanel.
\v 16 Ti co mec'an ja ba sti sat ja Jesusi pero huan oq'uel yuj ja sgusto. Iday, ja huinic jahui mi judiouc. Samariteño nia.
\v 17 Ti yala ja Jesusi: ―¿Mi ma lajunhuaneuquex huiniquex tojbiyex ba? Jaxa balune huinique jau ja hua moji, ¿bay baa?
\v 18 Ja huinic iti, mi quintiluctic. Tuc raza ni ay ja yena pero cumxi ba oj yaa yi stz'acatal ja Diosi.
\v 19 Ti yal yab ja huinic jahui: ―Q'uean xa. Cax xa. Tojbiya ta yuj ja hua c'uani, x'utji.
\s1 Ja jastal oj ec'uc cuando huax co jan ja Jesucristo
\r (Mt. 24:23‑28, 36‑41)
\p 
\v 20 Ja fariseo jumasa ti och sobe yi ja Jesusi jas ora oj jac sc'ul mandar ja Diosi. Ti yala ja Jesusi: ―Cuando huax jac sc'ul mandar ja Diosi, mi xa hualahuex ta oja huilex.
\v 21 Mi ni ma' oj bob yal ta ti huan sc'ulajel mandar ja ili ma ti huan sc'ulajel mandar ja tihui porque ja ma' oj sc'ul mandari, ti xa ni ay amoquex ja huenlexa.
\v 22 Ti yal yab ja snebumani: ―Q'uelahuilex, ja queni ti coelon jan ja ba satq'uinali pero oj jac ja c'ac'u cuando oja hualex: Siquiera juneuc xta nique c'ac'u oj quiltic ja jastal huax quilatic ajyi pero mi xa ni oj to ahuilexa.
\v 23 Pero ay ma' oj yala huabyex: Ja Cristo ti xa ay ba lugar iti, oj chiuc, ma oj cho yala huabyex: Ja Cristo ti xa ay ba lugar jahui. Pero moc lom huajanic ja ba huax yalahuei. Moc lom ac'uuquex ja cristiano jumasa jahui.
\v 24 Porque ja c'ac'u oj cocon ja ba satq'uinal ja queni, oj lijpucon juntiro ja jastal huax lijpi ja chamtzelahui.
\v 25 Pero ja tiempo jumasa ja iti oj ni qui lec ja huocola. Ja cristiano jel coraja oj yilone. Mi ni ma' oj yion leca.
\v 26 Jaxa cuando mojan xa oj cho cocon jan ja ba satq'uinali, jach ni oj cho ajyuc ja cristiano jumasa ja jastal ja jun lame cristiano ec' ja ba stiempo ja Noeji.
\v 27 Ja yenlei, como siempre smodo jastal culan yujilei, huax nupaniye, huax ya nupanuque ja yuntiquilei, huax huaaye, huax yuaje ja'.
\v 28 Jach ni chomajquil ja jun lame cristiano jau ja stiempo ja Loti. Huax huaaye, huax yuaje ja', huas smana ja sastic sbajei, huax cho xchonohue, huas stz'unu ja yalajei, huas sc'ulan ja snajei.
\v 29 Pero cuando el ja Lot ja ba chonab jau ja ba Sodoma, ti co jan ja c'ac'al taan ja ba satq'uinali, socan soc azufre. Jaxa ora jahui, ch'ac ni cham spetzanil ja suinquil ja chonab jahui.
\v 30 Jach oj ajyuc ja c'ac'u oj cho cocon jan ja ba satq'uinali.
\v 31 Ja c'ac'u jahui, ta ay c'a ma' ti t'ucan ja ba s'olom ja naitzi, jaxa sastic sbaji tey ba yoj naitzi, moc xa lom co ya eluc. Jaxa ma' tey ba huitzi, moc xa lom cumxuc ja ba snaji.
\v 32 Naahuic t'unuc ja jastal huaj ja xcheum ja Loti.
\v 33 Ja ma' huajel sc'ujol quechan yen huas syajta sbaj yen mismo pero ja mas tzaani oj ni ch'ayuc ja yaltzila. Pero ja ma' huas syajta ja smoj jastal huas syajta sbaj ja yen mismo, ja mas tzaani, mi ni ni oj ch'ayuc ja yaltzila.
\v 34 Huax cala huabyex, ja acual jau oj jaconi, chab cristiano huane huayel jun ta ch'at. Ja juni oj ni iijuca, jaxa juni, oj aajuc cani.
\v 35 Chahuane ixuque huane chenel jun ta aq'uinte. Ja juni oj ni iijuca, jaxa juni, oj aajuc cani.
\v 36 Chahuane huinique tey ba huitz. Ja juni oj ni iijuca, jaxa juni oj aajuc cani.
\v 37 Cuando yabye ja jastal iti, ti yalahuea: ―Pero ¿jas bej jach oj ec'uc ba Cajual? xchiye. Ti yala ja Jesusi: ―Ja' ni yuj ja ti sacbanban oj ajyuc ec' ja scuerpo ja cristiano. Quechan ni ti huan poc'oljuc ec' ja useja.
\s1 Ja viguda soc ja juezi
\c 18
\p 
\v 1 Ja Jesusi ti yala jun loila. Jach yala ba mi oj yae can ja sc'umajel ja Diosi soc ba mi oj el sganae:
\v 2 ―Q'uelahuil ba jun chonab tey ja juezi. Ja yeni mi ni t'un huax xiu yuj ja Diosi soc mi huas soyba ja cristiano.
\v 3 Ja ba mismo chonab jahui ay jun ixuc viguda ay. Ja yeni tola vida huax huaj parte soc ja juez jahui. Huas sc'ana oj tojbesjuc soc ja scondra.
\v 4 Pero ja juezi jitzan vuelta mi yaa yi caso pero ja mas tzaani ti sc'ulan pensara: Eso sí, ja queni mix caa yi caso ja Diosi, ¡jauc to ma cristianoa!
\v 5 Pero jaxa men viguda iti tola vida huan tox huaj quile, ti xa ay jul ja ba jnaji. Mas ma lec oj colta ba mi huahuanto oj jacuc ja ba jnaji. Mi c'a, repente oj q'ue jcoraja soc, xchi ja juezi.
\v 6 Ti yala ja Cajualtiqui: ―Ata huabil ja jas yala ja juezi iday, jel malo pero scolta ni ja viguda jahua.
\v 7 ¡Jauc to ma Dios que mi oj ni scolta ja ma' tzaubal ni yujili! Ta huane c'a parte c'ac'u acual, mi xa huala mi baq'uin oj stojbes.
\v 8 Huax cala huabyex, huego oj stojbes. Pero yajni huala coyon jan otro vuelta ja ba satq'uinali, mi naben ta ay to cristiano ja ma' huas sc'uan ja Diosi, xchi ja Jesusi.
\s1 Ja fariseo soc ja colectori huaj sc'umuque ja Diosi
\p 
\v 9 Ja Jesusi ti cho yala otro jun loila. Jayuj yala jachuc ba oj ya smacchiquinuc ja ma' jel huas stoyo sbaje, jaxa smoj jumasa, lajan soc mi smojuc cristianoil huax yilahue:
\v 10 ―Q'uelahuil, chahuane huinique huaj sc'umuque ja Dios ja ba templo. Ja juni fariseo, jaxa juni colector, ja' ni june ja ma' huas stzomo ja taq'uini.
\v 11 Ja fariseo ti och tec'ana. Och sc'umuc ja Diosi pero yen ta huan sc'umajel sbaj. Ti yalaa: Dios, huax c'ana hui tz'acatal porque ja queni mi lajanucon soc ja tuqui. Mi la elc'aniyon. Mi maloucon. Mi huax lea jmul soc ixuc soc mi ni t'usita jmojuc ja tan colector jau lom huax ya eluc ja taq'uini.
\v 12 Cada semana huax como chab vuelta ja juaeli, jaxa jas huax c'ulan ganari huax pila hui lajune cada cosa tac, xchi ja huas sc'uman ja Dios ja fariseo jahui.
\v 13 Jaxa colector jahui can najat. Ti och tz'inana. Ti stela ja sc'abi. Och sc'umuc ja Diosi: A Dios, talna jyaujulal porque ja queni jel ja jmuli. Jach yala ja colector jahui cuando huan sc'umajel ja Diosi.
\v 14 Ti yala ja Jesusi: ―Huax cala huabyex, ja colector jahui, cuando cumxi ja ba snaji, c'ulaji ta ni perdonara, jaxa fariseo, mi ni c'ulaji perdonara. Como jach nia. Ja ma' jel nihuan huax yaa sbaji, jel ch'in oj aaji huajuc, jaxa ma' jel ch'in huax yaa sbaji, jel nihuan oj aaji huajuc.
\s1 Ja Jesusi sc'ulan bendiciar ja yal untiqui
\r (Mt. 19:13‑15; Mr. 10:13‑16)
\p 
\v 15 Ja Jesusi ti iiji jan yi ja yal untiqui ba oj syam ja s'olomei pero cuando yila ja snebuman jumasa, ti scomohuea.
\v 16 Pero ja Jesusi ti spaya jan ja snebumani. Ti yalaa: ―Lec ja huax jacye ja yal untiqui. Mi lom xa comohuex porque ja jastal ja sc'ujol ja yal untic iti, jach ni ay ja sc'ujole ja matic yaunej sbaj ja ba sc'ab ja Diosi.
\v 17 Huax cala huabyex, pero meran, mi c'a la ch'inbiyex jastal jun yal untic cuando huaxa huaa bajex ja ba sc'ab ja Diosi, mi ni modo oj bob ochanic soc ja yeni.
\s1 Ja soltero jel rico och loil soc ja Jesusi
\r (Mt. 19:16‑30; Mr. 10:17‑31)
\p 
\v 18 June ja huinic ja ma' ay yateli ti soboa: ―Maestro, jel leca juntiro. Ala cab jasunc'a lec oj c'uluc oj quil ja vida jau ba jel lequi ba mi ni nunca huax ch'aqui.
\v 19 ―¿Jasyuj huaxa huala cab que jel leconi? Mi ni june ma' lec, quechan ja Diosi.
\v 20 Ja hueni huaxa naa ja mandar jumasa, que mi oja lee amul soc ja ixuqui, mi oj milhuanan, mi oj elc'anan, mi lom q'uiq'uinal oja lee ja smul ja hua moji. Yaj oja huab ja hua nan atati, xchi ja Jesusi.
\v 21 Ti yala ja huiniqui: ―Pero jach ni huax c'ulan man jch'inila, xchi
\v 22 Yajni yab ja Jesús ja jastal iti, ti yalaa: ―Pero ay to jas huas sc'ulan ahui palta. Cax chono can spetzanil ja jastic ahuioji. Aa yi ja pobre jumasa. Jach c'a huaxa c'ulan, jel ja jas oj aajuc ahui ja ba satq'uinali. Cax c'ulan jachuc, ti la jac jmoca, xchi ja Jesusi.
\v 23 Pero ja huiniqui, cuando yab ja jas ch'ac aljuc yabi, tristeaxi juntiro porque jel ja jastic sbaji.
\v 24 Ja Jesusi cuando yila tucbi ja smodo, ti yalaa: ―Ja ma' jel ja jastic sbaji, jel huocol juntiro oj yaa sbaj ja ba sc'ab ja Diosi.
\v 25 Mas mi huocoluc oj ec' jun camello ja ba sotol ja tz'istaq'uini que soc oj yaa sbaj ba sc'ab ja Dios jun rico, xchi ja Jesusi.
\v 26 Jaxa matic ch'ac yab ja jas yala ja Jesusi, ti yalahuea: ―Entonces ¿machunc'a oj bob el libre soc ja smul ba?
\v 27 ―Ja cristiano mi ni oj bob yujila pero ja Diosi oj ni bob yujila, xchi ja Jesusi.
\v 28 Ti yala ja Pedro: ―Entonces ¿jaxa quenticon ba? Caunejticon can spetzanil ja jastic quiojticoni ba oj ajyucoticon amoc Cajual.
\v 29 Ti yala ja Jesusi: ―Pues oj cala huabyex ja smeranili. Spetzanil ja ma' yaunej can ja snaji, ma ja snan stati, ma ja yermano jumasa, ma ja xcheumi, ma ja yuntiquili, ta ja' c'a huax yaa can yuj ja huas sc'ana yaa sbaj soc ja Diosi, ja jahui, mi ni lomuca.
\v 30 Ja ba mundo iti oj ni sc'ul recibir mas de snalan que soc ja janec' yaa cani, jaxa ba otro mundo oj sc'ul recibir ja vida jau ba jel lequi soc ba mi ni nunca huax ch'aqui, xchi.
\s1 Otro vuelta yala ja Jesús que oj chamuc
\r (Mt. 20:17‑19; Mr. 10:32‑34)
\p 
\v 31 Ja Jesusi ti ch'ac spay ja ba stz'eel ja snebuman jumasa. Ti yalaa: ―Q'uelahuilex, ti xa huajumotic ja ba Jerusaleni. Ja tihui oj c'ot smeranil spetzanil ja jas stz'ijbaye can ja aluman‑Dios jumasa ja jastal oj ni ec' cujili. Ja queni ti ni coelon jan ja ba satq'uinali.
\v 32 Pero oj c'ulajucon endregal ja ba sc'ab ja tzeil cristiano. Oj aajuc qui jitzan burla. Oj yixtalaucone. Oj stzujbaye ja jsati.
\v 33 Oj smac'one. Man oj smilone pero ja ba yoxil c'ac'u oj sac‑huucon.
\v 34 Pero ja snebuman jumasa mi ni t'un yabye sbej ja jas yala. Mi snaahue jasunc'a huax alji yabyei. Lajan soc juntiro macji ja spensarei.
\s1 Aaji yil q'uinal jun tupel sat sbaj Jericó
\r (Mt. 20:29‑34; Mr. 10:46‑52)
\p 
\v 35 Mojan xa yioj ja Jesús ja ba chonab Jericó. Huaj to yile, ti culan ec' jun huinic tupel sat ba sti bej. Huan sc'anjel limosna.
\v 36 Cuando yab huan xta cululuc huan eq'uel ja cristiano jahui, ti sobo jasyuj ja jel ja cristiano.
\v 37 Ti alji yab que ja' huan eq'uel ja Jesús nazareño.
\v 38 Ti och ahuanuc tzatz leca: ―¡Jesús yintila rey Davidi, talna jyaujulal ba! xchi xta.
\v 39 Jaxa cristiano ja ma' bajtan ayi ti huas scomohuea pero lajan soc alji yab ba oj ahuanuc mas tzatz: ―¡Yintila rey Davidi, talna jyaujulal ba! xchi.
\v 40 Ti c'ot tec'an ja Jesusi. Ti seca spayjela. Cuando ti xa ay ba stz'eeli, ti sobo yia:
\v 41 ―¿Jasunc'a huaxa c'ana oj c'uluc ahui ba? xchi. ―Cajual, huax c'ana oj quil q'uinal.
\v 42 Ti yala ja Jesusi: ―Lec, yuj ja hua c'uani, oj xa ni tojbana.
\v 43 Iday, huego huego yila q'uinal. Ti huaj nochan soc ja Jesusi. Huan xta sc'anjel yi stz'acatal ja Diosi. Jaxa spetzanil ja cristiano, cuando yilahue jastal tojbi ja huinic jahui, jel huax cho stoyohue ja Dios ja yenle chomajquili.
\s1 Ja Jesusi soc ja Zaqueo
\c 19
\p 
\v 1 Ja Jesusi ti c'ot ja ba chonab Jericó. Ti huan bejyel ec' ja ba yoj chonabi.
\v 2 Ay jun suinquil ja chonab jahui, Zaqueo sbiil. Ja huinic jahui jel rico, como yen huas sc'ulan mandar ja ba colecturía ja ba huax tzomxi ja taq'uini.
\v 3 Jaxa yajni yab que tey ba yoj chonab ja Jesusi, jel sgusto huas sc'ana oj yil ja sati pero mix bob yujil porque jel ja cristiano, jaxa yeni, jel yal tzapito.
\v 4 Jayuj ti ec' ajnel bajtana. Ti q'ue huego jun steil moraxtea ba oj bob yile, yuj ja ti ni bi oj ec'uc ja Jesús ja tihui.
\v 5 Jaxa Jesusi cuando ec' ja tihui, ti sq'uela q'ue ja ba tei. Ti yila ti t'ucan ec' ja Zaqueo. Ti yalaa: ―Zaqueo, coan jan huego porque ja huego ti oj jijlucon ja ba hua naji, xyutaj.
\v 6 Jaxa Zaqueo ti co jan huegoa. Jel sgusto yiaj och ja ba snaji.
\v 7 Jaxa cristiano jumasa, cuando yilahue ba oj huaj jijluc ja Jesusi, ti yochele xta c'umal ja ba ja' mi jauqui: ―Q'uelahuile, ti huax huaj ja ba snaj ja tan mulanum jahui, xchiye xta.
\v 8 Jaxa Jesusi soc ja smoji cuando c'otye ja ba snaj ja Zaqueo, ti ochye culana. Jaxa Zaqueo ti q'ue tec'ana, ti yalaa: ―Q'uelahuil Cajual, ja jastic jbaji oj caa yi snalan ja pobre jumasa. Ta ay c'a ma' jlolonej satalajel abal, oj ni ca cumxuc yile chane vuelta mas, xchi ja Zaqueo.
\v 9 Jaxa yajni yab ja Jesusi, ti och yal yab ja ma' tey ba yoj naitzi: ―Ja yaani jac ta c'ulajuc librar ja suinquil ja naitz iti. Ja huinic iti lajan soc ja' to ni yintil chomajquil ja Abrahami.
\v 10 Jayuj coyon ni jan ja ba satq'uinal tac. Jac jlee ja ma' ch'ayeli ba oj colta, xchi ja Jesusi.
\s1 Ja lajune mozo aaji yile jujune taq'uin
\p 
\v 11 Jaxa cristiano ti huane smaclajel ja jas huan yaljel ja Jesusi. Huax yalahue que jel xa mojan ja c'ac'u oj aajuc och yatel ja Jesusi. Jaxa Jesusi, como mojan xa ay ja Jerusaleni soc huas snaa jastal huan c'umal ja sc'ujol ja cristiano, jayuj ti och yal jun loila:
\v 12 ―Q'uelahuil jun huinic, Ja yeni spetzanil ja ma' ec' pax ta yujili, xchojlal ch'ac och yatele. Jachuc ja yeni ti huaj ba jun najtil lugar lec ba oj aaji och reyil, ti xa bi oj cumxuc ja ba mero slugari.
\v 13 Pero ja mi tox huaji, ti spaya jan lajune ja smozo ba oj yaa can yile ja staq'uini y jel aay yaa can yi cada jujune. Ti yal yabyea: Q'uelahuilex, oj xa huajcon pero ja taq'uin it huax caa huilexi, atjananic soc, xyutaj ja smozo jumasa. Ti xa huaj ja huinic jahua.
\v 14 Pero ja suinquil ja slugar ja ajualal jahui, jel coraja yilahue. Ti secahue jun comisión ba oj huaj yale yab que mi huas sc'anahue oj och sreyil.
\v 15 Pero ja huinic jahui aaji ni och reyila. Ja mas tzaani, ti cumxi ja ba slugari. Cuando c'oti, ti seca spayjel ja smozo jumasa, ja ma' yaa can yi ja taq'uini. Huas sc'ana oj snaa janec' sc'ulane ta ganar cada jujune.
\v 16 Ja ma' bajtan jaqui ti yalaa: Cajual, ja hua taq'uini alini ta cuj otro lajune tanto ja minai, como jach ni sbiil ja staq'uinei.
\v 17 ―Pues jel lec. Mero lequil mozoa. Ja janec' t'usan caa huii, jel lec ja jas hua c'ulan soqui, jayuj ja huego oja c'ul mandar lajune chonab, xchi ja reyi.
\v 18 Ti cho jac ja otro juni, ti yalaa: Cajual, ja hua taq'uin ahuaa can quii alini ta cuj otro joe tanto, xchi.
\v 19 ―Jachuc ja huen, oj cho ac'ul mandar joe chonab, xchi ja reyi.
\v 20 Ti cho jac ja otro juni: Cajual, oj xa caa hui endregal ja hua taq'uin it ahuaa quii. Jpotzo can ba jun mojchilal
\v 21 Porque huala xiuyon ahuujil. Huax naa que c'ac'al huinica. Ja hua modo ni toj jotzuanel ja hua gustoi. Pavor huaxa huiaj sbaal ja hua hualaji. Mi ahuateluc ja huena, xchi ja mozo jahui.
\v 22 ―¡Ay mozo, jel malo juntiro ja hua c'ujoli! Yuj ja jas el ja ba hua tii, jayuj oj ch'ac jap ahui ja janec' ahuioji. ¡Entonces huax quiaj ja ba mi jbajuqui! ¡Pavor huala huaayon ta jachuqui! Mi quenuc huax catelta.
\v 23 Entonces ta jachuc, ¿jasyuj mi hua och qui ba banco ja jtaq'uini ba oj c'ul recibir ja yal cuando la cumxiyon ja ba jnaji? x'utji ja mozo jahui.
\v 24 Ja reyi ti yal yab ja ma' tey tihui: Japahuic yi ja taq'uin jahui. Aahuic yi ja ma' ya alinuc diez tanto ja minai.
\v 25 Ti yalahuea: Pero Cajual, ¡ja yeni ay xa yioj diez mina tac!
\v 26 Ti yala ja reyi: Pero huax cala huabyex, jach nia. Ja ma' ay ni jas yioji, oj ni aajuc yi masa. Jaxa ma' quechan t'usan yiojei, ja t'usan jahui oj ni japjuc yilea.
\v 27 Jaxa jcondra jumasa ja ma' mi sc'ana oj ochcon reyili, iajic jan qui, ti xa milahuex ja ba sti jsati, xchi ja reyi.
\s1 Ja Jesusi och c'ot ja ba Jerusaleni
\r (Mt. 21:1‑11; Mr. 11:1‑11; Jn. 12:12‑19)
\p 
\v 28 Yajni ch'ac ja loil jahui, ja Jesusi ti stulu ja sbeji, como ti ni huan huajel ja ba Jerusaleni.
\v 29 Mojan xa yioje ja hacienda Betfagé soc ja Betania, soc mojan xa yioje ja huitz jau sbiil Olivos. Ja Jesusi ti spaya jan chahuane ja snebumani, ti yalaa:
\v 30 ―Caxic ja ba yal hacienda ja ba mojan xa quiojtiqui. Cuando la c'otyex ja tihui, ti oja taex jun yal burro ti mochantea. Mi to ni ma' huax q'uea. Tucuhuic, ti xa huiajex jan quia.
\v 31 Ta ay c'a ma' huas sobo huilex jasyuj huaxa tucuhuexi, ti xa hualahuex yaba: Ja' huas sc'ana ja Cajualtiqui, xa huutajex, xchi ja Jesusi.
\v 32 Ti huajye ja chahuane snebuman jahui. Ti ni staahue ja jastal yala ja Jesusi.
\v 33 Cuando huane stucjel ja yal burro jahui, ti jac ja suinquil jumasa: ―¿Jas sbej ja huanex stucjel ja yal jburroticoni? xchiye.
\v 34 ―Pero oj bi maconuc yuj ja Cajualtiqui, xchi ja yenlei.
\v 35 Ti yiaje och yi ja Jesusa. Yaahue bacan ja sc'ue ja ba spatic ja yal burro. Ti xa q'ue ja Jesusa.
\v 36 Jaxa ba bej ja ba huajum ja Jesusi, ja cristiano ti huane slibjel ja sc'uei como jach ni culan yujile cuando huax yilahue ja ma' jel nihuani.
\v 37 Cuando mojan xa yioje ja ba yib huitz sbaj Olivosi, jaxa jun nole ja ma' yaunej xa sbaj soc ja Jesusi ti och ahuanuque yuj ja sgustoei. Huane sc'anjel yi stz'acatal ja Diosi soc ja spetzanil ja milagro yilunejei.
\v 38 ―¡Viva ja jreytiqui! ¡Ja yeni jecji jan yuj ja Cajualtic Diosi! ¡Jel tzamal laman ay ja satq'uinali! ¡Ja tihui xlijpi xta juntiro! xchiye xta.
\v 39 Pero ja ba jun nole cristiano jahui ay chaboxe fariseo. Ti yalahuea: ―Maestro, como t'unuc ja hua nebuman ba.
\v 40 ―Huax cala huabyex, ta huan c'ax ch'abajiye ja yenlei, ay ni jas mas oj cho ilxuca. Hasta ja toni oj ahuanuque, xchi ja Jesusi.
\v 41 Ja Jesusi yila mojan xa ay ja Jerusaleni, ti bojti yoq'uela.
\v 42 Ti yalaa: ―¡Ay jerusaleño jumasa! Ja tiempo jumasa iti, ay modo jastal nique oj bob aajanic nique laman ajyi. Jel lec ja lec ahuabyex to nique slugarili. Ja yaani mi xax bobi porque ec' ta.
\v 43 Pero oja huilex oj jacuc ja c'ac'u ja hua condraexi oj soybayex. Lot'obal oj ajyanic. Oj ni snolc'abuquexa.
\v 44 Sacbanban oj cananic ja ba luumi, jerusaleño jumasa. Oj ni ch'ac miljanica. Ja ba yoj achonabilexi mi ni jun ton oj can latzan pero ja' yujil ja mi ni aquitz'ahuex ta Dios ni ja ma' jac yulatayex ja ba hua chonabilexi.
\s1 Ja Jesusi snutzu el ja matic huan negocio ja ba yoj templo
\r (Mt. 21:12‑17; Mr. 11:15‑19; Jn. 2:13‑22)
\p 
\v 45 Ja Jesusi ti c'ot ja ba Jerusaleni. Ti och ja ba templo. Huaj to yile, tey ja ma' huan xchonjel ja cosa soc ja ma' huan smanjeli. Ti ch'ac snutz el ba fueraa. Ti yalaa:
\v 46 ―Ja yabal ja Diosi huax yala ja ba snaji quechan ba huax c'umaxi ja Diosi. Pero ja huenlexi huaahuex ta pax snaj lagronil, xchi ja Jesusi.
\v 47 Spetzanil ja chaboxe c'ac'u jumasa jahui, ja Jesusi ti huan seejel ja ba yoj templo pero ja nihuac pagre jumasa soc ja ma' huas sea ja smandar ja Moisesi soc ja ma' ay yatel ja ba chonab jahui ti och xchape yabalila.
\v 48 Pero mi ni staahue modo jas oj sc'uluquea porque spetzanil ja cristiano jel ja sgustoei. Huane smaclajel ja jas huan seejel ja Jesusi.
\s1 Jel tzatz ja yatel ja Jesusi
\r (Mt. 21:23‑27; Mr. 11:27‑33)
\c 20
\p 
\v 1 Jun c'ac'u ja Jesusi ti huan seejel yi ja cristiano ja ba yoj templo. Ja' huan sloiltajel ja abal it jel tzamali. Ti c'ot ja nihuac pagre jumasa soc ja matic huas sea ja smandar ja Moisesi soc ja banquilal jumasa.
\v 2 Ti yalahuea: ―¿Yuj ama ay ahuatel ja huen huaxa c'ulan ja cosa jumasa iti? Entonces ¿ma' yaa hui ja hua huatel ba? x'utji.
\v 3 ―Jachuc ja queni, ay jas huax c'ana job ahuilex, alahuic cabi.
\v 4 Ja Juani, ¿machunc'a yala oj sc'ul bautizar ja cristiano? ¿Ja' ma alji yab yuj ja ma' tey ba satq'uinali ma ja' alji yab yuj ja cristiano? xchi ja Jesusi.
\v 5 Jaxa yenlei ti ochye loil yenle itaa: ―Huan c'ax calatic ja ma' tey ba satq'uinali, entonces oj yal cabtic, entonces ¿jaxa yuj ja mi xa c'uanex ba? oj yutotic.
\v 6 Iday, ta huan c'ax cho calatic que ja' ba cristiano, spetzanil ja cristiano oj xch'ojotic ton porque ja yenlei mero aluman‑Dios yujile ja tan Juan jahui.
\v 7 Ti yalahue yab ja Jesusi: ―Mix naaticon.
\v 8 ―Entonces jachuc ja queni, mi oj cala huabyex ma' yaunej qui ja jas huanon sc'ulajel eq'ui, xchi.
\s1 Ja ma' aaji can ba sc'ab ja yalajil tz'usubi
\r (Mt. 21:33‑44; Mr. 12:1‑11)
\p 
\v 9 Ja Jesusi ti och yal yab ja cristiano jun loila: ―Q'uelahuil, jun huinic stz'unu jun yalajil tz'usub. Ti sc'ulan trato soc chaboxe ja ma' oj yatelta ja yalaji, jaxa yeni ti el ja tihui, pero jitzan tiempo huaji.
\v 10 Ti sc'ulan tantear ja tiempo. Ti seca jun mozo ba oj yii jan ja sbaal ja yalaji pero ja talna‑alaji smac'ahue. Telan sc'ab yaahue huajuc ja mozo jahui.
\v 11 Jaxa suinquil ja yalajil tz'usubi ti cho seca otro ja smozo, pero jachuc ja yeni mac'ji. Xihuel ja sbaj ja jas c'ulaji yii, cho telan sc'ab aaji huajuc.
\v 12 Jaxa suinquil ja alaji ti cho seca otro smozoa, pero ja' xa ba yoxili. Jachuc ja yeni, cho aaji yajbuc. Ti cho nutzjia.
\v 13 Ti yala ja suinquil ja yalajil tz'usubi: ¿Jas oj c'ul ba? Oj ma jec ja cunin jel yaj huax cabi. Bob ta oj sc'uluque respectar ja yajni xyilahuei.
\v 14 Pero malaya, yajni ilji sat ja yunini, ti yalahue yenle itaa: Ja iti, yen oj yii can spetzanil ja dote. ¿Jaxa mix milatiqui? Ta cham c'a, quen oj bajuctic ja sdotea, xchiye.
\v 15 Ti syamahuea. Ti yiaje ba spat alaj. Ti smilahuea. Cuando huax cumxi ja suinquil ja alaj jahui, ¿jas huala chiyex? ¿Jas oj yut ja huinique jau ba? xchi ja Jesusi.
\v 16 Oj cala huabyex jasunc'a oj sc'uluqui. Cuando huax cumxi oj ni ch'ayjuc snaajelea. Tuc ja ma' oj yaa ba sc'ab ja alaj jahui. Cuando yala jachuc ja Jesusi, ti yalahue ja ma' huan smaclajel ja loil iti: ―¡Moc ama sc'an Dios!
\v 17 Ti tojtoq'ueljiye lec yuj ja Jesusi: ―¿Jasunc'a huax yala ja yabal ja Dios ba?
\q1 Ay jun oy ba jel tzamali pero ja c'ulanaitzi mi squitz'ahue, iday, jaxa oy jau mi quitzji, ja' mero oj yaa mas yip ja naitzi.
\m ¿Mi ma jach ni huax yala ba?
\v 18 Jaxa ma' huas sloco yoc soc ja oy jahui, jel ni tzatz oj yii ja yeni, pero ta ja' c'a oy huax moq'ui, polvo ni oj huajuc ja ma' oj co sbaji, xchi ja Jesusi.
\s1 ¿Lec ama oj caatic yi contribución ja gobierno, ma miyuc?
\r (Mt. 21:45‑46; 22:15‑22; Mr. 12:12‑17)
\p 
\v 19 Ja nihuac pagre jumasa soc ja matic huas sea ja smandar ja Moisesi ja mero ora jahui, ja' huas sc'ana oj syame ja Jesusi porque jac sc'ujole que yenle ni huax tajiye ti' soc ja loil it yala ja Jesusi pero xiuye yuj ja cristiano jumasa.
\v 20 Jayuj ti secahue chaboxe huinique, jaxa huinique jahui oj bi huaj see sbaje que jel leque, ti oj yie loila, entonces jaxa Jesusi mi sc'ulan palta jas oj el sti t'usan. Malan bi soc ja jahui, ti oj sc'uluque endregal ja ba sc'ab ja gobierno ja ma' ay yateli.
\v 21 Cuando c'otye ja ba stz'eel ja Jesusi ti yalahuea: ―Maestro, huax naaticon que jel toj ja jas huaxa huala soc ja jas huaxa jea. Mi tzaubaluc ita ja cristiano ja ma' huaxa jea ja sbej ja Diosi. Puro ni smeranil ja jas huaxa huala,
\v 22 Jayuj jac jobticon ahui, ¿lec ama oj caatic yi contribución ja gobierno César ma miyuc? xchiye.
\v 23 Jaxa Jesusi huego snaa que xchabil lado aye. ―¿Yuj ama jac ac'uluconex probar ba?
\v 24 Jeahuic qui ja taq'uin ba. Jaxa olomal iti, ¿ma' sbaj? jaxa jas tz'ijbanubal jahui, ¿ma' sbiil? ―Ja' sbaj gobierno Cesari, xchiye.
\v 25 ―Entonces ta ja c'a sbaj Cesari, aahuic yi ja César ja sbaji, jaxa jas sbaj ja Diosi, aahuic yi, x'utjiye yuj ja Jesusi.
\v 26 Mi ni t'un bob yujile que ay jas oj el sti ja ba sti sat ja cristiano. Mas lec, yen smaca juntiro ja stiei. Huas snaahue que jel toj ja jas yala ja Jesusi.
\s1 Oj ni sac‑huuc ja scuerpo ja ma' ch'ac ta chamuqui
\r (Mt. 22:23‑33; Mr. 12:18‑27)
\p 
\v 27 Ti c'otye ba stz'eel ja Jesús chaboxe saduceo. Judioe nia pero mi huas sc'uane ta oj to sac‑huuc ja scuerpo ja ma' huax chami. Ti yalahue ja saduceo jumasa jahui:
\v 28 ―Maestro, ja Moisesi yala can ta huan c'ax cham jun banquilal y huax yaa can ja xcheumi pero mey yuntiquile, entonces oj bi iijuc ja xcheum ja chamhuiniqui. Ja' bi oj yii can ja ma' nochan soc ja chamhuinic ajyi, jaxa yuntiquil ja yenlei, que oj bi och cuenta que ja' bi yuntiquil ja chamhuinic banquilali.
\v 29 Ta ay c'a jucuane yermano sbaje, jaxa banquilali nupani pero chami. Mi ni jun yuntiquil cani.
\v 30 Jaxa xcheum ja banquilali, ta huan c'ax iiji yuj ja ma' nochan soc ja statam ajyi, pero cho cham ja yeni. Mi ni ja yeni, mi yaa can yuntiquil.
\v 31 Ta jach cho sc'ulan ja ba yoxil ijtz'inali, ta jach c'a ch'ac ec'uque sucuanile, mi ni jun yuntiquil can spetzanilea,
\v 32 Ja lec ti xax cham ja ixuc jahui,
\v 33 Jaxa ba otro lado cuando oj sac‑huuc ja scuerpoei, ¿machunc'a mero oj yii ja ixuc jau ba? Porque spetzanil xcheumane ja ba luumi, xchi ja saduceo jumasa.
\v 34 Ti yala ja Jesusi: ―Meran nia. Ja cristiano ja ba mundo iti huax nupaniye. Huax aaji nupanuque.
\v 35 Pero ta jel c'a lec ja sportuna oj c'otuque ja ba otro mundo, ta huan c'ax chamye, jaxa mas tzaan oj sac‑huuque, ja ba mundo tihui mi ni oj nupanuquea soc mi oj aajuc nupanuque,
\v 36 Porque ja tihui, mi xa ni ma' oj chamuca. Ja ángel jumasa mix chamye, jachuc oj ajyuc ja yenlei. Ta huan c'a sacuiye, yuj ni yuntiquile xa ni ja Diosa.
\v 37 Jaxa ma' huax chamyei, oj ni sac‑huuquea. Jach ni huas sea ja Moisés ja ba yabal ja Diosi ja ba huax taji ti' ja q'uiixi. Ja ba juun jahui yalunej claro ja Moisesi que ja Abrahami, sDios ni ja Diosa. Jach ni ja Isaqui, sDios ni ja Diosa, soc jach ni ja Jacobi, sDios ni ja Diosa.
\v 38 Jach yala ja Diosi porque mi chameluc ja oxhuane huinique jahui. Ja ba sti sat ja Diosi mi ni ma' huax cham juntiro, xchi ja Jesusi.
\v 39 Ti yala chaboxe ja matic huas sea ja smandar ja Moisesi: ―Maestro, meran ni ja jas huaxa hualaa.
\v 40 Ti c'otye tec'ana. Mi xa ni jas yalahue masa.
\s1 Ja Cristo, ¿machunc'a ja sTati?
\r (Mt. 22:41‑46; Mr. 12:35‑37)
\p 
\v 41 Jaxa Jesusi ti cho yalaa: ―Pues ja yenlei huax yalahue que yintil bi ja David ja Cristo.
\v 42 Pero ja yen mismo ja Davidi huax yala ba libro ba Salmosi:
\q1 Ja Dios Tatali ti yal yab ja Cajual Cristoi: Quechan ja huen oj ajyuc ja huatel mas tzatz.
\q1 
\v 43 Oj ni caa ba yib ac'ab ja hua condra jumasa, x'utji.
\m 
\v 44 Ja huabyex que yajualan ja Cristo ja Davidi. ¿Jastal ay ja jahui? ¡Pero mi ni huax cajualan jbajtic ja quermano jbajtic tac! xchi ja Jesusi.
\s1 Ja Jesusi yala ja smul ja ma' huas sea ja smandar ja Moisesi
\r (Mt. 23:1‑36; Mr. 12:38‑40; Lc. 11:37‑54)
\p 
\v 45 Ti ch'ac yab spetzanil ja cristiano ja jas yalai. Ti cho och yal yab ja snebuman jumasa:
\v 46 ―Aa lec acuidadoex soc ja matic huas sea ja smandar ja Moisesi. Ja yenlei ja' sgustoe ja xuecheljiye xta ec' soc ja sc'uei. Soc ja' mero sgustoe oj jac tajuc sc'abe ja ba plaza, jaxa ba yoj yiglesiaei ja' huax huaj slee ja lugar ja ba huax och culan ja ma' ay yateli. Jach ni ja huax huajye ba jun huaelal, ja' mero huas sleahue ja lugar ba mas tzamali.
\v 47 Jachuc ja viguda jumasa, huas sapahue yi ja snajei pero ba mi oj naajuc ja jas huane sc'ulajeli, ti huax och sc'an yi stz'acatal ja Dios yuj ja viguda jahui pero albel lec huas sc'umane ja Diosi. Ja jau jumasa oj ni yii ja castigo ba mas tzatzi, xchi ja Jesusi.
\s1 Ja viguda jel pobre yaa slimosna
\r (Mr. 12:41‑44)
\c 21
\p 
\v 1 Ja Jesusi ti yila huane yaajel limosna ja rico jumasa. Ti huax ya ochuque ja ba cajón ja ba yoj templo.
\v 2 Ti jac jun vigudaa. Ja yeni jel pobre pero ya och chab sat taq'uin blanca sbiil yujile.
\v 3 Ti yala ja Jesusi: ―Ja mero smeranili, huax cala huabyexi, ja viguda iti jel pobre pero mas yaa can ja yen que soc ja tantic rico jumasa.
\v 4 Ja yenlei, quechan ja ba sobrae huax yaahue ja slimosnaei pero ja viguda iti, pobre juntiro pero yaa can spetzanil ja janec' yioji. Mi ni ba stz'acol ja suaeli, mi ni yiaj cana, xchi ja Jesusi.
\s1 Ja Jesusi yala oj jemuc ja templo
\r (Mt. 24:1‑2; Mr. 13:1‑2)
\p 
\v 5 Como ti ni ay ja snebuman jumasa, ti och yale jastal jel tzamal ja templo. Jel bi tzamal ja stojnali. Jel bi lec ja smajtan ja Dios huan yaajel ja cristiano ja ba oj maconuc ja ba sc'ulajel ja templo. Jayuj ti yala ja Jesusi:
\v 6 ―Eso sí, jel tzamal huaxa huilahuex pero oj jacuc ja c'ac'u mi ni jun ton oj can latzana. Polvo oj ch'ac can spetzanil.
\s1 Ja seña jastal oj to jacuc cuando oj xa ch'acuc ja mundo
\r (Mt. 24:3‑28; Mr. 13:3‑23)
\p 
\v 7 ―Maestro, ala cabticon jas ora oj ec'uc ja jau ba. ¿Oj ma jnaaticon jas ora oj ec'uc ja it ba? ¿Oj ma ajyuc seña?
\v 8 Ti yala ja Jesusi: ―Moc ahuaa bajex ba oj lolajananic porque ja ora jahui jel ja ma' oj yii ja jbiili: Quen ja Cristooni, oj chique. Jaxa tuqui: Ja yaani oj xa ni ch'acotica, oj chiuque. Pero moc lomuc ahuaex caso.
\v 9 Cuando huaxa huabyex huan loiltajel ja guerra, pleito, moc lom xihuanic yuj porque t'ilan ni oj c'ot smeranil ja jastal iti. Pero ja jahui, mi to jauc oj c'ot tic'an ja tiempo.
\v 10 Ja lugar jumasa puro coraja oj yil sbaje. Ja gobierno jumasa oj ochuque pleito.
\v 11 Xihuel ja sbaj oj ajyuc ja templori. Jel oj ajyuc ja huaini. Oj ajyuc jitzan chamel ja ba tuctuquil lugari, jaxa ba satq'uinali, oj iljuc ja jas jel oj yaa ja xihueli. Nihuan seña lec.
\v 12 Pero ja mi tox ahuilahuex ja seña jumasa jastal jahui, ja huenlexi oj mochjanic, ti oj iijanic ja ba iglesia jumasa. Oj cho aaji ochanic preso ma oj aaji ochanic ja ba sti sat ja ma' ay yateli soc ja ba sti sat ja gobierno jumasa. Pero ja' yuj ja huaxa c'uanonex ja queni.
\v 13 Pero mi jas oj sc'uluc. Soc ja jas huas sc'ulanei, oj yabye claro lec ja jas huaxa c'uanexi.
\v 14 Naahuic t'usan. Moc lom oja c'uluquex pensar jastal oj c'umananic. Mi jauc oja c'uluquex pensar jastal oja colta bajex ja ora jahui
\v 15 Porque ja quen oj cala huabyex jastal oj c'umananic. Oj ca vivoaxanic, jaxa hua condraexi juntiro oj smac ja sti ja jas oja hualexi. Mi ni oj bob jas oj sc'uluc ahuilexa.
\v 16 Pero ja huenlexi, anima jauc ja hua nan atatexi, soc ja hua huermanoexi, soc ja hua najtil ahuermanoexi, soc ja hua huamigoexi, oj ni yii apatiquexa. Ay ni ma' oj chamuc ahuujilex ja huenlexa.
\v 17 Lajan soc tz'i oj yilex spetzanil ja cristiano pero ja' yujil huaxa c'uanonex ja queni.
\v 18 Pero anima, porque q'uelahuilex ja stzotzil ja hua olomexi, cuenta ni aya, ¡jauc to ma hualtzilexi!
\v 19 Ta huan c'ax ec' ahuujilex spetzanil ja huocol jahui, oj ni ataex ja hua vidaex ba jel lequi.
\v 20 Cuando huaxa huilahuex ja Jerusaleni lot'obal xa yuj ja soldado jumasa, yuj ni oj xa ch'acjuque con todo xchonabilea.
\v 21 Jaxa matic tey ba Judea, mas lec aa xa huajuque ajnel ba huitz. Jaxa matic tey ba yoj chonab ba Jerusaleni, mas lec a eluque ja tihui. Jaxa matic tey ba huitzi, moc xa lom cumxuque ba yoj chonabi.
\v 22 Ja c'ac'u jumasa iti ja' oj stup ja smul ja cristiano. Oj ni c'ot smeranil ja jastal ni tz'ijbanubal ja ba slibro ja Diosi.
\v 23 Jel ajul ja sbaj ja ixuque ja ma' cuchan yuj ja nihuac chameli soc ja ma' ay yioj yal alatz huan chuunel yujili porque ja tiempo jahui jel ni yaj oj jacuc ja huocola. Jun castigo ba jel tzatz juntiro oj yii ja cristiano jumasa jahui.
\v 24 Jel ni ja ma' oj chamuc ja ba guerra, jaxa tuqui oj mochjuque. Oj iijuque ja ba spetzanil ja lugari, ti oj aaji ochuque presoa. Jaxa ma' huax can ja ba Jerusaleni oj ni batjuque yuj ja polestero. Ja jmojtic judioili ti oj ajyuque ba sc'ab ja polestero jumasa masan to oj c'ot tic'an ja tiempo oj sc'uluque mandar ja yenlei.
\s1 Ja jastal oj cho co jan ba satq'uinal ja Jesucristo
\r (Mt. 24:29‑35, 42‑44; Mr. 13:24‑37)
\p 
\v 25 Ja tiempo jahui ja ba satq'uinali, oj tucbuc juntiro ja c'ac'u, jach ni ja luna, jach ni ja c'anali pero ja' ni ja seña lec ja jahua. Jaxa ba luumi, ja ba spetzanil ja lugar jumasa oj jom juntiro. Mi oj snaa jas oj sc'uluque ja cristiano. Ja ma' mojan yioj ja mari oj xihuuque yuj juntiro yuj ja sruidoili. Jel tzatz juntiro oj spuctzuc sbaj.
\v 26 Ja cristiano jumasa oj bobaxuc juntiro yuj ja jel xihuel ja sbaj ja jastal oj to c'otuqui. Ja yip ja Dios ja jel tzatz ay ja ba satq'uinali, oj ni ch'ac syopes spetzanil. Oj ch'ac lospujuc con ja jas tey ba satq'uinali.
\v 27 Entonces spetzanil ja cristiano oj yilone oj cocon jan ja ba satq'uinali. Jel tzatz juntiro oj cocon jan ja ba yoj asoni. Jel tzamal oj lijpuc juntiro ja quijlabi.
\v 28 Cuando huaxa huilahuex huax q'ue ja huocol jumasa jahui, tzatz lec la ajiyex. A jachan ja hua pis'olomexi porque jel xa mojan ja ora oj c'ulajananic librari.
\v 29 Ja Jesusi ti och yal jun loila: ―Q'uelahuilex ja steil ja higo ma chican jas teil.
\v 30 Cuando yaau xa ja spoohuili, huan ni xa naahuex que q'ue ta ni ja stiempo jaa.
\v 31 Jachuc cuando huaxa huilahuex ja cosa jumasa iti, naahuic t'usan que oj xa jacuc ja Dios ja ma' huas sc'ulan mandari.
\v 32 Huax cala, pero meran, ja jun lame cristiano jahui mi oj chamuque masan to huax c'ot smeranil spetzanil ja jastal jahui.
\v 33 Anima huax ch'ac ja satq'uinali soc ja luumi, pero ja jas huax cala t'ilan ni oj c'ot smeranila.
\v 34 Aa cuidadoex mi xa huaahuex yi lugar oj c'anc'onuc ac'ujol soc ja jas ay ja ba mundo iti. Aa cuidado soc ja yuujel trago. Mi lom ja' oj huaj ac'ujolex ja hua vidaex ba mundo. Ta mi xa huaa cuidadoex soc ja jahui, oj ch'uybuc ja hua c'ujolexi porque cuando mi jauc huaxa c'ulanex pensari, huan tox huaj ahuilex, ti xa ay jul ja Diosi.
\v 35 Lajan soc jun pojhuic' jun ta ch'ayc'ujol huax co trampa. Jach oj co spetzanil ja ma' ay ba xchanil xchiquin ja satq'uinali ja c'ac'u oj couc ja castigo.
\v 36 Jayuj q'uelan jacan ajyanic ja huenlexi. C'umanic ja Dios tola vida. C'anahuic yi pavor ba oj scoltayex soc spetzanil ja jas oj to jacuqui soc ba oj bob ochanic ja ba sti jsati como oj to ni cocon jan ja ba satq'uinali, xchi ja Jesusi.
\v 37 Ja Jesusi ti huan seejel ja ba templo ja sat c'ac'u, jaxa acuali, ti huax huaj ja ba huitz Olivosi.
\v 38 Jaxa huax el ja c'ac'u ti huax jac spetzanil ja cristiano. Huax jac smaclaye ja yabal ja jas huan seejel ja ba yoj templo.
\s1 Yiaj yabal sbaje jastal oj syame ja Jesusi
\r (Mt. 26:1‑5, 14‑16; Mr. 14:1‑2, 10‑11; Jn. 11:45‑53)
\c 22
\p 
\v 1 Jel xa mojan ay ja syalq'uinal ja judio jumasa. Culan ni yujile ja q'uin jahui huas sueahue ja pan mey slevaduraili.
\v 2 Ja nihuac pagre jumasa soc ja matic huas sea ja smandar ja Moisesi huas sleahue modo jastal oj bob smile ja Jesusi pero mi nix bob yujilea, como huane xihuel yuj ja cristiano jumasa.
\v 3 Entonces ja Satanasi ti jac ja ba stz'eel ja Judas ja ma' huax aaji sbiiluc Iscariote. Ja yeni ja' ni june ja lajchahuane snebuman ja Jesusi.
\v 4 Ja Judas jahui ti huaj sc'umuc ja nihuac pagre jumasa soc ja matic huas sc'ulane mandar ja ba yoj templo. Ti och xchape yabalil jastal oj bob syame ja Jesusi.
\v 5 Jaxa yenle ja matic tey ba templo, jel gusto yabye juntiro. Ti yalahue que oj bi yae yi taq'uin ja Judasi.
\v 6 Ti sc'ulane tratoa. Jaxa Judasi ti och slee modo jastal oj bob sc'ul entregar ja Jesusi pero nac'ul abal.
\s1 Ja último cena ja Cajualtiqui
\r (Mt. 26:17‑29; Mr. 14:12‑25; Jn. 13:21‑30; 1 Cor. 11:23‑26)
\p 
\v 7 Ti c'ot ja sc'ac'uil ja q'uin it huas sueahue ja pan it mey slevaduraili. Ja c'ac'u jahui culan yujile huas smilahue jun chej cada syalq'uinal ja ba smajtan ja Diosi.
\v 8 Ja Jesusi ti seca ja Pedro soc ja Juani. Ti yal yabyea: ―Caaxic. Cax tojbesic ja ba oj huaacotiqui porque ja' xa mero syalq'uinal ja yaan c'ac'u.
\v 9 ―¿Ba huaxa c'ana oj chapticon ba? xchiye.
\v 10 Jaxa Jesusi ti yalaa: ―Cuando ti xa ayex ja ba sti ja chonabi, ti oja taex bej jun huinic q'uechan xch'ub. Nochohuic man oj och c'ot ja ba naitzi.
\v 11 Jaxa suinquil ja naitz jahui oja jobex yi bay ja cuarto jau ba nalan chaani. ¿Ba bi oj sc'ux ja xchejil ja syalq'uinal ja Maestro soc ja snebuman jumasa? utajic.
\v 12 Jaxa yeni oj sea huilex jun nihuan cuarto ba nalan chaani, chapan xa. Ti oja tojbesex leca, xchi ja Jesusi.
\v 13 Ti huajyea. Ti ni staahue ja jastal ni alji yabye yuj ja Jesusi. Stojbese ja ba oj ec' yujile ja syalq'uinali.
\v 14 Cuando ja' xa ni yorail ja suaelei, ja Jesusi soc ja snebuman jumasa ti ochye ba mesa.
\v 15 Ti yala ja Jesusi: ―Jel gusto juntiro huax cab ja lajan huantic huael ja syalq'uinal iti porque oj xa ni chamcona.
\v 16 Huax cala huabyex quechan xta último vuelta lajan huantic huael ja huego. Oj to cho huaacotic lajan pero cuando ti xa ayotic ja ba huas sc'ulan mandar ja Diosi, xchi.
\v 17 Ja Jesusi ti syama ja vaso but'el yalel tz'usub. Sc'ana yi stz'acatal ja Diosi, ti yalaa: ―Iajic ja iti. Uc'anic apetzanilex.
\v 18 Porque huax cala huabyex mi xa oj to cu otro vuelta ja yalel ja tz'usubi masan to cuando oj sc'ul mandar ja Dios oj stzom spetzanil ja yuntiquili.
\v 19 Ti syama ja pani. Ti cho sc'ana yi stz'acatal ja Diosi. Ti xet'aa. Ti yaa yi ja snebuman jumasa. Ti yalaa: ―Ja iti, ja' ni ja jcuerpo oj caa yuj ja huenlexi. Cuando huaxa hueahuex otro vuelta, a jac ac'ujolex jastal caa jbaj con todo jcuerpo yuj ja huenlexi.
\v 20 Jach ni cho sc'ulan soc ja jun vaso yalel tz'usub. Yajni ch'ac huauquei, ja Jesusi ti syama ja vaso jahui, ti yalaa: ―Ja jun vaso yalel tz'usub iti, ja' xa ni ja jchiq'uela. Ja Diosi sc'ulunej jun yajc'achil trato soc ja huenlexi, ja' cuando xpec' ja jchiq'ueli oj bi huajanic libre soc ja hua mulexi.
\v 21 Porque ja ma' oj ni sc'ulucon endregali ti ni culan ec' jmoc lajan ja ba mesa iti.
\v 22 Meran, ti ni coelon jan ja ba satq'uinali pero oj ni chamcona como t'ujpinubalon ni ba oj chamcona pero ¡pobre ja huinic jau ja ma' oj sc'ulucon endregali! xchi ja Jesusi.
\v 23 Jaxa snebuman jumasa ti och sob sbaje yenle itaa: ―¿Mach ama junuc ja oj sc'uluc ja jahui? xchiye.
\s1 ¿Machunc'a ja mas nihuani?
\p 
\v 24 Ja snebuman jumasa ja Jesusi ti q'ue sloilea: ―¿Ay ama junuc ja quentic ja ma' mas nihuan huax ilji? ¿Jas la chiyex ba? xchiye.
\v 25 Ti yala ja Jesusi: ―Q'uelahuilex, ja matic mi judiouqui, ja ma' ay yatel yujilei, lajan soc huax och ajualalil. Jaxa cristiano jumasa tey ba sc'abei, anima mi tzamaluc ja jas huas sc'ulane ja ma' ay yateli, pero huan nix c'anji yile stz'acatala.
\v 26 Pero ja huenlexi moc lom jach ajyanic ja jastal jahui. Ja ma' mas jel huas snaa ahuujilexi, oj see sbaj que mi jas huas snaa, jaxa ma' mas nihuan ja yateli, eso sí, ay yatel pero jach oj see sbaj jastal ja ma' huan c'ulajel mandari.
\v 27 ¿Machunc'a ja mas nihuani? ¿Ja' ama ma' huax aaji ec' jan yi ja suaeli ma ja' huan slechjel jan ja huaelali? ¿Mi ma jauc ni ja ma' huan smajlajel ja suael huax aaji ec' jan yi ba? Iday, ja queni lajanon soc ja ma' huas slecha jan ja huaelali.
\v 28 Spetzanil ja huocol eq'uel cuji, ja huilunejex nia.
\v 29 Jayuj oj caa ja hua huatelex como jastal ja jTat yaa qui ja catel ja queni.
\v 30 Jaxa ba oj to jc'ul mandar ja queni, ti oj huaacotic lajana. Ja tihui oj aajanic ochanic juezil. Oja tojbesex ja lajchau c'ole ja jmojtic israeleño jumasa, x'utjiye yuj ja Jesusi.
\s1 Ja Jesusi yala que oj nacjuc yuj ja Pedro
\r (Mt. 26:31‑35; Mr. 14:27‑31; Jn. 13:36‑38)
\p 
\v 31 Ti cho yala ja Cajualtiqui: ―Simón, q'uelahuile. Ja Satanasi sc'anunej licencia ba oj yaa huilex jun huocol, pero tzatz lec. Mi oja naex ba oja huiex ic'a.
\v 32 Pero jc'ana ta yi ja Diosi ba mi oj ch'ay ac'ujol ja jas huaxa c'uani. Pero cuando huala cumxi jmoc otro vuelta, ti xa colta ja hua huermano jumasa.
\v 33 Ti yala ja Simoni: ―Pero Cajual, puesto ayon oj ni huajcon amoca, anima huax aaji ochcon preso. Puesto ayon oj chamcon amoc lajan.
\v 34 ―Pedro, huax cala huabi ja yaan acuali, ja mi tox oc' ja gallo, oxe vuelta oja hual que mi xa naa jbaj, xchi ja Jesusi.
\s1 Mojxi ja yora ja suocoli
\p 
\v 35 Ti cho yala ja Jesusi: ―Cuando jecahuex sin morrali, ja it yora mi ni jun centavo ahuiojexi soc mi ni ja hua xanabexi, ¿ay ama jas sc'ulan ahuilex palta ba? ―Pues, mi ni jas sc'ulan quiticon palta yena, xchiye.
\v 36 Ti yala ja Jesusi: ―Pero ja yaani chapa bajex lec porque oj xa ni ahuilex ja jas oj ni ec'uqui. Ja ma' ay smorrali, a yie soc a yii ja staq'uini. Jaxa ma' mey smachiti, anima jauc ja xchompa oj xchoni, a sman ja smachiti.
\v 37 Porque huax cala huabyex t'ilan ni oj c'ot smeranil ja jastal ni tz'ijbanubal ja ba yabal ja Diosi. Huan nix yala que oj ni aaji jmojuc ja ma' jel malo. Como jach ni tz'ijbanubalona, jayuj t'ilan ni oj c'ot smeranila.
\v 38 Ti yala ja yenlei: ―Cajual, ay ni quiojticon chab machita. Ti yala ja Jesusi: ―Pues lec, malan soc.
\s1 Ja Jesusi sc'uman ja Dios ja ba Getsemaní
\r (Mt. 26:36‑46; Mr. 14:32‑42)
\p 
\v 39 Ja Jesusi cuando el ja tihui, ti huaj ja ba huitz Olivos, como jach ni culan yujila. Ti ch'ac huaj nochan ja snebuman jumasa.
\v 40 Ja c'otye ja ba huitz jahui, ti yala ja Jesusi: ―C'umanic ja Diosi ba mi oja lee ja hua mulexi.
\v 41 Jaxa Jesusi ti spila sbaj jun maq'uea. Ti co mec'ana. Och sc'umuc ja Diosi:
\v 42 ―Tatey, ta jach huaxa c'ana, a ec' qui ja huocol iti, pero mi jauc ja jas huax c'ana ja queni pero ja' ni ja jas huaxa c'ana ja hueni, xchi.
\v 43 Huaj to yile, ti co jan jun ángel ja ba satq'uinali. Jac aajuc yi mas ja yipi.
\v 44 Pero juntiro syatz'a sbaj ja yaltzili. Ti och sc'an yi mas stz'acatal ja Diosi. Jaxa sticahui huego huego el yoc. Lajan soc chic' huax t'ujpiji man luum.
\v 45 Yajni ch'ac sc'umuc ja Diosi, ti q'uea. Huaj ja bay ja snebuman jumasa. Chamele huayel yuj ja stristeilei.
\v 46 Ti yalaa: ―¿Jasyuj ja huanex xta huayel ja huenlexi? Q'ueanic. C'umanic ja Diosi ba mi oja lee ja hua mulexi.
\s1 Yamji ja Jesusi
\r (Mt. 26:47‑56; Mr. 14:43‑50; Jn. 18:2‑11)
\p 
\v 47 Cuando jach huan yaljel ja Jesusi, huaj to yile, ti c'ot jitzan ja cristiano. Ja ma' mero bajtan yujilei, yena ni ja ma' Judas sbiil, ja' ni june ja lajchahuane ja snebumani. Ti huaj c'uban ja ba stz'eel ja Jesusi ba oj yujtz'uc, como jach ni ja scostumbreei.
\v 48 ―Judas, jel lec huax jac ahuujtz'ucon yena pero ahuionej ni lec jpatica. Pero naa t'unuc, ti ni coelon jan ja ba satq'uinali, xchi ja Jesusi.
\v 49 Ja smoj jumasa ja Jesusi, cuando yilahue jastal oj xa ec'uc ja cosa jumasa iti, ti yalahuea: ―Cajual ¿jas la chi? ¿Mi ma lec oj jaxticon machit? xchiye.
\v 50 Iday, june ja yenlei huaj yaa yi ja smozo ja pagre mas nihuani. Sc'utzu el yi ja stojol xchiquini.
\v 51 ―Jaxa huenlexi, ¿jasyuj jach huanex sc'ulajeli? Acta cani, xchi ja Jesusi. Ti syama ja xchiquini. Ya staa sbaj huego.
\v 52 Ja Jesusi ti yal yab ja nihuac pagre jumasa soc ja matic sepeil ja soldado jumasa ba templo soc ja banquilal jumasa, spetzanil ja ma' oj xa nolc'abijuc ja yeni: ―¿Jasyujil ja soc machit soc garrote huax jac ayamonexi? ¿Yuj ama lagronon ja quen ba?
\v 53 Ja chaboxe c'ac'u ec' ta jani ti ni ajyiyon amoquex cada c'ac'u ba templo, iday, mi ni t'usan jas ahualahuex caba. Pero ja huego oj ni ac'uluquex ganar ja huenlexa porque ja' ni ora it tzatz lec huan huajel ja ma' suinquil ja q'uiq'uinali.
\s1 Ja Pedro yala que mi snaa sbaj ja Jesusi
\r (Mt. 26:57‑58, 69‑75; Mr. 14:53‑54, 66‑72; Jn. 18:12‑18, 25‑27)
\p 
\v 54 Ti smochohue ja Jesusi. Ti yiaje ja ba snaj ja pagre mas nihuani. Jaxa Pedro ti nochan och najtic najtica.
\v 55 Jaxa ba snaj ja pagre mas nihuani, ti stzomo sbaje jun montón cristiano. Ti ochye culan ba sti ja c'aq'ui. Ti cho och culan ja Pedro soc ja yenlei.
\v 56 Entonces jun criada, yajni yila ti culan ec' lajan ja ba sti ja c'aq'ui, ti stojtoq'uela leca. Ti yalaa: ―¡Pero ja tan huinic iti ja' ni smoj ja tan Jesús jahui! xchi.
\v 57 Pero ja Pedro: ―Nana, ¡pero mi ni t'un huax naa sbaj ja huinic jahui! xchi.
\v 58 Ja mas tzaani ti cho ilji ja Pedro: ―Jach ni ja hueni, amoj ni abajex soc ja yena, x'utji. ―Miyuc, mi quenuc, xchi ja Pedro.
\v 59 Jaxa ec' ta mojan jun ora, ti cho alji yaba: ―Meran, ja tan huinic iti smoj ni sbaje soca. Sbaj ni Galilea ja yen chomajquil tac, xchi, pero jel tzatz juntiro ja stii.
\v 60 Ti yala ja Pedro: ―Tata, mix naa jasunc'a huana yaljeli. Cuando jach to huan yaljeli, ti oc' ja galloa.
\v 61 Jaxa Cajualtiqui ti sutu sbaja. Ti sq'uela lec ja Pedroa. Ti jac sc'ujol ja Pedro ja jas alji yab yuj ja Cajualtiqui, ja cuando mi to bix oc' ja gallo, oxe bi vuelta oj yal que mi snaa sbaj.
\v 62 Ti xa el ja Pedroa. Ti och smil sbaj oq'uela.
\s1 C'ulaji yi burla ja Jesusi
\r (Mt. 26:67‑68; Mr. 14:65)
\p 
\v 63 Ja huinique jumasa jau ja ma' ti xa ni ay ba sc'abe ja Jesusi ti och yaahue yi burlaa. Ti cho och smaq'uea.
\v 64 Ti smacahue yi ja sati. Ti och yaahue yi vuelta ja ba xchoji. Ti yalahuea: ―Ala machunc'a huas smac'ahua ba.
\v 65 Jaxa tuqui ba sbiil ba mi sbiiluc huax yutaje.
\s1 Ja Jesusi iiji och ba yoj juntai
\r (Mt. 26:59‑66; Mr. 14:55‑64; Jn. 18:19‑24)
\p 
\v 66 Cuando el ja c'ac'u ti stzomo sbaje ja banquilal jumasa soc ja nihuac pagre jumasa soc ja matic huas sea ja smandar ja Moisesi. Ti yiaje och ja Jesusi ja ba junta ja ba tzoman spetzanil ja cristiano. Ti sobohue yia:
\v 67 ―Ala cabticon ba, ¿huen ama Cristoa? xchiye. Ti yala ja Jesusi: ―Anima huax cala huabyex ta quena, mi ni oja c'uuconexa.
\v 68 Ta huan c'ax c'an ac'ujolex machunc'a ja Cristoi, mi ni oja hualex caba, soc mi ni oja sijpuconexa.
\v 69 Ja queni coelon jan ja ba satq'uinali pero ja huego oj xa huajcon ja ba mero stz'eel ja Dios ba jel juntiro ja yipi.
\v 70 Ti och yalea: ―¡Ja huena ni ja yunin ja Dios ta jachuqui! ―Pues quena. ¿Jasyuj huaxa jobohuexi? xchi ja Jesusi.
\v 71 Ti yalahue ja yenlei: ―Pues, ¿jas yatel cujtic mas testigo? ¡Mismo quentic cabtic ta ja jas el ta ba sti tac! xchiye xta.
\s1 Ja Jesusi c'ulaji endregal ja ba sti sat ja Pilato
\r (Mt. 27:1‑2, 11‑14; Mr. 15:1‑5; Jn. 18:28‑38)
\c 23
\p 
\v 1 Spetzanil ja cristiano ja janec' stzomonej sbajei, ti yiaje och ja Jesús ja ba sti sat ja Pilato.
\v 2 Ti och slee yi ja smula: ―Ja huinic iti co ta cujticon ja jas huan sc'ulajel ec' ja ba jlugartiqui. Huan somjel yi ja s'olom ja cristiano. Mi bi oj caaticon yi contribución ja gobierno Cesari. Huax cho stoyo sbaj que yen bi ja Cristo tzaubal bi yuj ja Diosi. Rey ni bia, xchiye xta.
\v 3 Entonces ja Pilato ti yalaa: ―Entonces, ¡ja huena ni ja sreya ja judio jumasa ta jachuqui! ―Como huen ita ni huaxa hualaa, xchi ja Jesusi.
\v 4 Ja Pilato ti yal yabye ja nihuac pagre jumasa soc ja cristiano jumasa: ―Ja huinic iti mi ni jun smul huax taa ja queni, xchi.
\v 5 Pero ja yenlei mas to jel tzatz huaj ja stiei: ―Huan somjel juntiro ja cristiano jumasa sbaj Judea soc ja jas huan seejeli. Q'ue stul ba Galilea. El ta jul man ili, xchiye xta.
\s1 Ja Jesusi cho c'ulaji endregal ja ba sti sat ja Herodesi
\p 
\v 6 Ja Pilato yajni yab ja jastal iti, ti sobo ta galileño ja Jesusi.
\v 7 Yajni alji yab que galileño nia, ti seca ja ba sti sat ja Herodesa, como yena ni gobierno ay ja ba Galilea pero ja c'ac'u jumasa jahui, ti ni ay c'ot ja ba Jerusalena.
\v 8 Jaxa Herodesi yajni yila ja sat ja Jesusi, jel gustoaxi juntiro. Ay xa tiempo huas sc'ana oj snaa sbaj. Yabunej lec yabalil ja Jesusi. Jel ja sgusto oj yil oj sc'ul jun milagro.
\v 9 Ti och sc'an yi sc'ujol jitzan cosaa. Pero ja Jesusi mi ni jun palabra c'umania.
\v 10 Jaxa tihui tey ja nihuac pagre jumasa soc ja matic huas sea ja smandar ja Moisesi. Mas to jel tzatz huane sleejel yi ja smuli.
\v 11 Ja Herodesi soc ja soldado jumasa ti och yixtalauquea. Ti ya slape jun sc'u ba jel tzamal ja jastal huas slapa ja reyi, pero puro burla huane. Ja el ja sganae ja jastal huan sc'ulajel yii, ja Herodesi ti cho seca och ja ba sc'ab ja Pilato.
\v 12 Ja Pilato soc ja Herodesi mero scondra sbaje ajyi pero ja c'ac'u jahui, yamigoan sbaje.
\s1 Yalahue que t'ilan oj chamuc ja Jesusi
\r (Mt. 27:15‑26; Mr. 15:6‑15; Jn. 18:39‑19:16)
\p 
\v 13 Ja Pilato ti spaya jan ja nihuac pagre jumasa soc ja matic ay yatel yujilei, spetzanil ja cristiano jumasa.
\v 14 Ti och yala: ―Q'uelahuilex, ja huenlexi ja huiajex jan ja huinic iti. Huaxa hualahuex que huas somo ja s'olom ja cristiano. Ti ba sti asatex jitzan ja jas jobo ta yii, pero ja queni mi ni jun smul huax taa yi ja jastal huanex yaljeli.
\v 15 Jach ni ja Herodes chomajquili, cho seca jan qui otro vuelta. Ti huaxa huabyexa, mi ni jun sbej que oj chamuca.
\v 16 Eso sí, oj yii castigo pero oj ni jsijpuca, xchi ja gobierno Pilato.
\v 17 Ja ba q'uin jahui, culan ni yujile huax ya el libre jun presoanum ja Pilato
\v 18 Jayuj ja cristiano jumasa ti och yalea: ―¡A chamuc! ¡Mix c'anaticon! ¡Ja' huax c'anaticon oj el libre ja Barrabasi! pero xch'eljiye xta ahuanel.
\v 19 Ja Barrabás jahui aaji och preso yuj ja ya q'ue jun nihuan pleito ja ba yojol ja chonab jahui, cho milhuani.
\v 20 Ti cho c'umani otro vuelta ja Pilato porque ay ni sgana oj sijpuc ja Jesusi.
\v 21 Pero ja cristiano ti cho och ahuanuquea: ―¡A cham ba cruz, a cham ba cruz! xchiye xta.
\v 22 Ti cho yala ba yoxil vuelta ja Pilato: ―¡Pe mi jas malo huan sc'ulajel tac! ¡Mi ni jun sbej ba oj chamuca! Oj caa yi castigo, ti oj sijpuca, xchi ja Pilato.
\v 23 Pero ja cristiano mas jel tzatz q'ue ahuanuque. Huane xta ni yaljel que oj ni chamuc ja ba cruza. Yuj ja jel ni tzatz ja stie ja yenlei soc ja nihuac pagre jumasa, jayuj sc'ulane ni ganara.
\v 24 Jaxa Pilato ti xa yaa orden ba oj sc'uluque yi ja jastal huas sc'ana ja yenlei.
\v 25 Ti ya el libre ja huinic jau huan ni sc'anahuei, ja huinic jau ma' aaji och preso yuj ja milhuani, cho ya q'ue jun nihuan pleito. Ti xa c'ulaji endregal ja Jesús ja ba sc'ab ja soldado ja jastal ni yalahue ja cristiano jumasa.
\s1 Aaji locan ba cruz ja Jesusi
\r (Mt. 27:32‑44; Mr. 15:21‑32; Jn. 19:17‑27)
\p 
\v 26 Jaxa soldado jumasa ti yiaje ja Jesusi. Cuando ti xa aye ba beji, ti yilahue tey jun huinic suinquil ja Cirene, Simón sbiil. Huan tox ch'ac juluc ja ba huitzi. Ti spayahue ba oj sq'uech ja cruzi. Ti huaj nochan ja ba spatic ja Jesusi.
\v 27 Ti cho nochane jun nole lec ja cristiano soc jitzan ja ixuque huane oq'ueli. Huane mebaoq'uel yuj ja stristeilei.
\v 28 Ti sutu sbaj ja Jesusi. Ti yalaa: ―Ixuque ba Jerusalén, mi la ocyex yuj ja queni. Mas lec, a oc' xchabil ja hua satexi yuj ja hua huocolexi soc ja suocol ja hua huuntiquilexi,
\v 29 Porque oj ni c'otuc ja c'ac'u mas lec oj yil ja ma' mi ni nunca yila unticaneli. Ti oja hualexa: Mas lec juntiro ja ixuque ma' mi yila unticaneli, ja ma' mi ni nunca ya chunuc ja yal alatzi. Jach ni oja hualex ja c'ac'u jumasa jahui.
\v 30 Jaxa cristiano jumasa ti oj och yala: Mas lec huan xa sama sbaj ja lumq'uinali que no que lom jel huantic yiijel ja castigo iti. Tuu xa huax cabtic ja satq'uinali, oj chiuque.
\v 31 Ja cristiano, q'uelahuil jas huane sc'ulajel ja huego y ti to ayona pero ¡majlayic! Cuando huax jac ja scastigoei, ¡pegor oj huajuque juntiro! xchi ja Jesusi.
\v 32 Soc ti yioje chahuane huinique ja ma' co soc ja smulei. Lajan bi oj chamuque soc ja Jesusi.
\v 33 Cuando c'otye ja ba huitz jau huax aaji sbiiluc s'olom chamhuiniquili, jaxa tihui ti yaahue q'ue locan ba cruza. Jaxa chahuane huinic jau ma' co soc ja smulei, ja juni ti aaji q'ue ba lado stojol sc'ab ja Jesús ja ba stz'eel ja scruzi, jaxa otro juni ba lado surdero.
\v 34 Ti yala ja Jesusi: ―Tatey, c'ulan perdonar ja cristiano jumasa. Mi snaahue jasunc'a huane sc'ulajeli. Ja soldado jumasa ti sc'ulane ripar ja sc'u ja Jesusi ba oj spil sbaje ja janec' aye ja yenlei.
\v 35 Jaxa cristiano, q'uelan jacane xta c'ote, jaxa ma' ay yateli huane xta burla sbaj ja Jesusi: ―Jel scolta ja cristiano jumasa tac. Ja huego, ta Cristo c'a meran, ¡a scolta sbaj ja yen mismo ba, como tzaubal ni bi yuj ja Diosi! xchiye xta.
\v 36 Jach ni ja soldado jumasa, cho och yaahue yi burla. Ochye c'uban, ti yaahue yi vinagre ba oj yue.
\v 37 Ti yalahuea: ―¡Ta huen c'a sreya ja judio jumasa, colta baj ja huen mismo ba!
\v 38 Jaxa ba lado bay ja s'olom ja Jesusi ti yaahue pac'an jun juuna. Tz'ijbanubal oxe abal ja ba juun jahui, ja' ni ja abal griego soc latina soc hebrea: Ja huinic iti, ja' ni ja srey ja judio jumasa. Jach ni xchi ja ba tz'ijbanubali.
\v 39 Jaxa june ja ma' locan ec' ja ma' ay ni smul merani, ti och bulbunuca: ―Ta huen c'a ja Cristoa merani, colta baj ja huen mismo ba, cho coltayoticon ja quenticoni, xyutaj.
\v 40 Jaxa smoj mulanumili ti yalaa: ―Ch'abanan ja hueni. ¡Mi ni t'un huala xiu yuj ja Diosi, iday, ti aya ba yojol ja castigo! Jaxa yeni huan yiijel ja castigo jastal huantic yiijel ja quentiqui,
\v 41 Pero ja huinic iti mi ni jas malo sc'ulana. Ja quentiqui ay ni lec sbej huax quiajtic ja huocola. Sbej ni huantic stupel ja jastic ch'ac jc'ultiqui.
\v 42 Ja huinic jahui ti yal yab ja Jesusi: ―Cuando huala c'ot ja ba oja c'ul mandari, xa naahuon t'usan ja queni, xchi.
\v 43 Ti yala ja Jesusi: ―Huax cala huabi, pero meran, ja yaan c'ac'u ti ni oj c'um jbajtic ja ba lugar jau jel tzamali.
\s1 Cham ja Jesusi
\r (Mt. 27:45‑56; Mr. 15:33‑41; Jn. 19:28‑30)
\p 
\v 44 Cuando oj xa sta ja nalan c'ac'u, ti q'uicbi juntiro ja q'uinali. Ti to cho lijpi ja mojan nalan tz'elan c'ac'u.
\v 45 Ja c'ac'u tupi, jaxa nihuan scortinail ja templo ti xch'ia con sbaj snalan.
\v 46 Ja Jesusi ti ahuani tzatz leca: ―Tatey, iaj xa ja caltzili. Quechan ch'ac yal ja jachuqui, ti chama.
\v 47 Jaxa scapitanil ja soldado jumasa jahui, cuando yila jastal huaji, ti och sc'an yi stz'acatal ja Diosi: ―Meran ja huinic iti lequil huinic nia.
\v 48 Spetzanil ja cristiano ja matic teyi, yajni yilahue jastal huaji, ti xa elye ja tihua. Mi snaa jas oj sc'uluque soc ja spensarei.
\v 49 Jaxa spetzanil ja yamigo jumasa ja Jesusi soc ja ixuque jau ja ma' ti nochane jan man ba Galilea, ti huane sq'ueljel najat spetzanil ja jastal ch'ac ec'uqui.
\s1 Ti aaji och ba jun q'ueen ja Jesusi
\r (Mt. 27:57‑61; Mr. 15:42‑47; Jn. 19:38‑42)
\p 
\v 50 Ay jun huinic ja tihui, José sbiil. Ti culan ba Arimatea ajyi, ja' ni jun hacienda sbaj Judea. Ja yeni ay yatel soc ja smoj judioili. Lequil huinic nia soc jel toj.
\v 51 Ja yeni huan ni smajlajel jas ora oj sc'ul mandar ja Diosi. Como mi ni xch'ica sbaj ja jas ch'ac sc'uluc ja smoj jumasa, mi ni lajanuc staa sbajea.
\v 52 Ja José jahui ti huaj sc'an yi ja Pilato ja scuerpo ja Jesusi,
\v 53 Entonces ti huaja. Ti ya couc ja ba cruzi. Sbech'a soc jun sábana. Ti yaa ba jun q'ueen pero ja q'ueen jahui jotobal ba jun patac'. Mi to ni ma' huax mucji ba q'ueen jahua.
\v 54 Ja c'ac'u jau mucxi ja Jesusi, ja' ni ja c'ac'u huax q'ue xchap sbaj ja judio jumasa ba oj stalnaye ja sc'ac'uil ja sijlelei. Oj xa mucxuc altiro ja c'ac'u.
\v 55 Jaxa ixuque jumasa ja ma' nochane jan masan ba Galilea, ti huaj yile ja sq'uejnal ja Jesusi. Yilahue ja jastal aaji can ja scuerpo.
\v 56 Ti cumxiye ja ba sposadaei. Ti xchapahue yi jun yajnal ba jex ajbani ja yiq'uili soc ja yajnal ja ba oj saxe yi ja scuerpo ja Jesusi. Ti jijliye ja sc'ac'uil ja sijlelei, ja jastal ni huas sc'uane ja smandar ja judio jumasa.
\s1 Sacui ja Jesusi
\r (Mt. 28:1‑10; Mr. 16:1‑8; Jn. 20:1‑10)
\c 24
\p 
\v 1 Jaxa sbajtanil c'ac'u ja semana, ja' ni ja c'ac'u domingo, ja ixuque jahui saj to lec huajye ja ba q'ueeni. Yiaje ja yajnal it xchapahuei, como jel nix ajbani ja yiq'uila. Soc ay otro ixuque huaj mojtajuque yuj.
\v 2 Cuando c'otye ja tihui, jaxa ton ja macji can soc ja sti ja q'ueeni, tz'elan xa ec' staahue.
\v 3 Ti ochye ba yoj q'ueeni pero mi ni staahue ja scuerpo ja Cajualtic Jesusi.
\v 4 Jel huane xihuel juntiro. Mi snaa jas oj sc'uluque. Huaj to yile, ti tec'an ec' ba stz'eele chahuane huinique, jaxa sc'uei, jex lijpi juntiro.
\v 5 Como jel huane xihuel, ti ch'ac snujbuc ja sate ja ba luumi. Ti yala ja huiniquei: ―¿Jas huanex ec' ja il ba? Ja ili, ja' sbaj ja chamhuiniqui, mi jauc sbaj ja ma' sac'an xa.
\v 6 Ja ma' huaxa leahuexi mi xa teyuc ja ili. Sacui ta nia. ¿Mi ma huax jac ac'ujolex ja jas yala cuando ti to ay ba Galilea ba?
\v 7 Ti ni bi coel jan ja ba satq'uinali pero anima, oj ni bi c'ulajuc endregal ja ba sc'ab ja mulanum jumasa. Oj ni bi aajuc q'ue locan ja ba cruza pero ba yoxil c'ac'u oj ni bi sac‑huuca, ¿mi ma xa naahuex ba? xchi ja angeli.
\v 8 Jaxa yenlei ti xa jac sc'ujole ja jas yala meran ja Jesusi.
\v 9 Ti xa cumxiye ja bay ja juluchuane secabanum ja Jesusi soc ja tuc ja ma' ti ni ayei. Ti ch'ac yale spetzanil ja jastaltic yilahuei.
\v 10 Jaxa ma' yiaj och ja razoni, ja' ni ja María sbaj Magdala, soc ja Juana, soc ja María snan ja Jacobo, soc ay otro ixuquei.
\v 11 Pero ja juluchuane secabanum ja Jesusi ti yalahuea: ―Ja' ama mojex ja loco ja huenlexi. ¡Jastal oj c'uucticon ja jahui!
\v 12 Pero ja Pedro ti ela, pero ajnel huaj yil ja ba q'ueeni. Huaj to yil ja ba yoj q'ueeni, quechan ti pacan ec' ja sábana. Cuando cumxi ja ba naitz ja baye ja smoj jumasa, jel juntiro huan pensar ja jastal eq'ui.
\s1 Ja Jesusi sea sbaj yi chab huinic ja ba yal hacienda Emausi
\r (Mr. 16:12‑13)
\p 
\v 13 Ja mismo c'ac'u jahui chahuane ja snebuman ja Jesusi ti huajume ba jun yal hacienda, Emaús sbiil. Mojan oxe lehua yioj ba Jerusaleni.
\v 14 Ja' ni mero sloile ja jastal yabye ch'ac ec'uqui.
\v 15 Cuando huane lec loili, ja' ni huane yaljela. Huaj to yile, tey ba stz'eele ja Jesusi. Ja bej yioje ja yenlei ja mismo bej cho yiaj ja Jesusi.
\v 16 Iday, ja yenlei mi ni t'un bob snae sbaj machunc'aa.
\v 17 Ti yala ja Jesusi: ―¿Jasunc'a huanex yaljel ja ba bej ba? ¿Jasyuj jel triste ayex ba?
\v 18 Ti yala jan ja ma' Cleofas sbiili, ja' ni june ja chahuane huinique jahui: ―Pero spetzanil ja cristiano ja sbaj Jerusaleni, mi ni june ma' mi yabunejuc ja jastal ch'ac ec'uc ja c'ac'u jumasa iti. ¿Quechan ma huen mi to xa huab ba?
\v 19 ―Pero ¿jasunc'a ec' ba? xchi ja Jesusi. ―¿Mi ma xa huab yabalil ja Jesús nazareño ba? Jun huinic pero mero aluman‑Dios. Jel tzatz ja yateli soc jel nihuan juntiro ja jas huax yala. Jel tzatz ay ja ba sti sat ja Diosi, jaxa ba yojol ja cristiano, jel nihuan ja jas sc'ulani.
\v 20 Pero ja nihuac pagre jumasa soc ja ma' ay yatel cujtiqui xchapahue yabalil que oj bi chamuc. Yaahue q'ue locan ba cruz.
\v 21 Pero ja quenticoni nihuan jc'ujolticon ba oj sc'ulucotic librar ja janec' israeleñootic ja ba sc'ab ja jcondratiqui. Jel ja jas sc'ulani pero iday, ja huego ay xa oxe c'ac'u aaji q'ue locan ja ba cruzi.
\v 22 Jaxa huaaxa saj to lequi, huaj chaboxe ixuc ja jmojticoni. Huajye ba sq'uejnali pero iday, jel xiuye juntiro
\v 23 Porque mi staahue ja scuerpo. Ti jac yale cabticon que snajsatine bi chaboxe ángel. Ti bi alji yabye que ja Jesús sacui ta bi.
\v 24 Ti cho huajye chaboxe ja jmojticon huiniquil ja ba q'ueeni. Pero jach ni staahue ja jastal ni yalahue ja ixuquei. Pero ja scuerpo ja Jesusi mi ni bi yilahuea.
\v 25 Ti yala ja Jesusi: ―Ja huenlexi, ¡jel huocol juntiro huaxa c'uanex! ¿Mi ni ma t'un huax jac ac'ujolex ta mi meranuc ja jas yala ja aluman‑Dios jumasa?
\v 26 ¿Mi ma bajtanuc ni t'ilan jel oj yii huocol ja Cristo ba? ¿Jaxa mas tzaani oj ni huajuc ja ba huax lijpia?
\v 27 Ti och yal ja jastal huax taji ti' ja Cristo ja ba spetzanil ja slibro ja Diosi. Och stul ja jas stz'ijba can ja Moisesi masan ch'ac ec'uc ja libro stz'ijba can spetzanil ja aluman‑Dios jumasa.
\v 28 Yajni c'otye ja ba yal hacienda ja ba huajumei, jaxa Jesusi sea sbaj que mas najat oj huajuc.
\v 29 Pero ja yenlei ti sc'ulane fuerza que oj can soquea: ―¿Mi ma mas lec oj xa canan jmocticon porque och ta c'ac'u? Lajan soc acual xa nia. Entonces yajni yab ja Jesusi, ti xa och och ja ba yoj naitza. Can soc ja yenlei.
\v 30 Yajni ti xa culane ja ba mesa, ti syama ja pani. Ti sc'ana yi stz'acatal ja Diosi. Ti xet'a yi xen yamana. Ti yaa yi ja yenlei.
\v 31 Ti to jac lec sc'ujole machunc'aa. Quechan pavor snaahue machunc'a, huaj to yile, ch'ay huego.
\v 32 Ti och yal sbaje yenle itaa: ―¿Mi ma jel alegre huaj ja hua hualtzili cuando huan loil jan jmoctic ja ba beji, como ja' ni huan seejel quitic ja jas tz'ijbanubal ja ba slibro ja Diosi? huax yutaj sbaje.
\v 33 Y mi smajlaye mas. Cho yiaj ja sbejei. Cho cumxiye ja mismo ora ja acual jahui ja ba Jerusaleni. Ti ni staahue tzoman ja juluchuane jecabanumi soc ja smoje jumasa.
\v 34 Ja' ni huane xta ni yaljela: ―Meran nia, sacui ta ni ja Cajualtica. Meran ni yila ja Simona, xchiye xta.
\v 35 Jaxa chahuane jau cumxiye jan yilahue ja Cajualtiqui, ti och xchole ja jastal yilahue ja ba beji. Pero ti to bi snaahue sbaj ja cuando spila ja pani.
\s1 Ja Jesusi sea sbaj yi ja snebuman jumasa
\r (Mt. 28:16‑20; Mr. 16:14‑18; Jn. 20:19‑23)
\p 
\v 36 Cuando jach to huane yaljeli, huaj to yile, ti tec'an ec' ba snalane ja Jesusi. Ti aaji yile Diosa.
\v 37 Pero ja yenlei xlasasi ch'ac huajuc ja xchiq'uelei. Juntiro jel och ja xihuelei. Huax yalahue que altzilal bi huax yilahue.
\v 38 Pero ja Jesusi ti yalaa: ―¿Jasyuj jel huanex xihuel ja huenlex ba? ¿Jas sbej huan xta tz'iptz'unuc ja hua c'ujolexi?
\v 39 Q'uelahuilex ja coc jc'abi. Quena ni merana. Yamahuonic. Q'uelahuonic. Jun altzilal mey scuerpo ja jastal huaxa huilahuonex ja queni, xchi ja Jesusi.
\v 40 Ch'ac yal ja jastal iti, ti sea ja yoc sc'abi.
\v 41 Jaxa yenlei jel sgustoe juntiro pero jel jomel ja s'olomei, jayuj mi mero huas sc'uane. Yajni yila ja Jesusi, ti yalaa: ―¿Ay ama jas ahuiojex ba oj cabtic?
\v 42 Ti yaahue yi jun pedazo bacbel chaya soc jun penca chab.
\v 43 Jaxa Jesusi ti yiaja. Och sc'ux ja ba sti sat ja yenlei, cho sloo ja chabi.
\v 44 Ti yalaa: ―Ja jastal ch'ac ec' cujili, como jach cala huabyex cuando ti to ni ayon amoquex ajyi. Spetzanil ja jas tz'ijbanubal ja ba smandar ja Moisesi soc ja ba slibro ja aluman‑Dios jumasa soc ja libro ja Salmo jumasa t'ilan ch'ac c'ot smeranila.
\v 45 Soc ja jas yala ja Jesús ja ora jahui, ti to jac sc'ujole jas sbej ja jas tz'ijbanubal ja ba slibro ja Diosi.
\v 46 Ti cho yala ja Jesusi: ―Ja Cristo t'ilan ni bi oj chamuca, jaxa ba yoxil c'ac'u oj ni sac‑huuca. ¡Pero quena ni ja Cristoon tac!
\v 47 Jaxa ba spetzanil ja lugar jumasa oj xa ch'ac loiltaxuc ja jas yajc'achil ch'ac ta ec'uqui ba oj suchuc ja sc'ujol ja cristiano soc ba oj c'ulajuc perdonar ja smulei, pero ja' ni yuj ja jastal ch'ac ta ec' cujili. Ti oj q'ue tulxuc ja sloiltajel ja ba Jerusaleni.
\v 48 Pero ja huenlexi testigoex nia porque ahuilunejex ja jas ch'ac ta ec' cujili.
\v 49 Pero q'uelahuilex. Oj ni jec ahuilex ja Espíritu Santo ja jastal ni yalunej ja jTati. Pero cananic ja il ba Jerusaleni masan to oj yaa hui ja hua huipex ja Diosi, x'utjiye yuj ja Jesusi.
\s1 Iiji q'ue ba satq'uinal ja Jesusi
\r (Mr. 16:19‑20)
\p 
\v 50 Ja Jesusi soc spetzanil ja snebumani ti huajye ba Betania. Ja Jesusi ti ya q'ueuc ja sc'abi. Sc'ulan bendiciar ja yenlei.
\v 51 Cuando ch'ac sc'ul bendiciari, ti spila sbaj soc ja yenlei. Ti xa iiji q'ue ja ba satq'uinali.
\v 52 Jaxa snebuman jumasa ti coye mec'ana. Yaahue yi stz'acatal ja Diosi. Entonces ti xa cumxiye ja ba Jerusaleni pero jel gusto aye juntiro.
\v 53 Tola vida huax huajye ba templo. Huas sc'anahue yi stz'acatal ja Diosi. Ti ch'aca. Amén.
