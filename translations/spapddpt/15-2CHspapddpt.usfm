\v 12 Entonces algunos \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Efraín: \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Hohanam, Berequías \w y|strong="H5921"\w* Ezequías, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Meshillemoth, Jehizhiah, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Salum \w y|strong="H5921"\w* \w Amasa|strong="H6021"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Hadlai|strong="H2311"\w*, \w se|strong="H5921"\w* \w levantaron|strong="H6965"\w* \w contra|strong="H5921"\w* \w los|strong="H1121"\w* \w que|strong="H4480"\w* llegaban \w de|strong="H4480"\w* \w la|strong="H5921"\w* batalla  
\v 13 \w y|strong="H3588"\w* \w les|strong="H5921"\w* dijeron: \w No|strong="H3808"\w* traigan \w acá|strong="H2008"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* cautivos, \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w* \w contra|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* caerá \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*. Ustedes tratan \w de|strong="H5921"\w* añadir \w a|strong="H3068"\w* nuestros \w pecados|strong="H2403"\w* \w y|strong="H3588"\w* culpas, \w pues|strong="H3588"\w* \w es|strong="H3588"\w* muy \w grande|strong="H7227"\w* nuestro delito. \w El|strong="H5921"\w* ardor \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w ira|strong="H2740"\w* \w está|strong="H5921"\w* \w contra|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
