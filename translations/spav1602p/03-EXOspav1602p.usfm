\v 24 \w Y|strong="H3068"\w* \w en|strong="H3588"\w* \w todo|strong="H3605"\w* Egipto \w hicieron|strong="H2658"\w* pozos \w alrededor|strong="H5439"\w* \w del|strong="H8354"\w* \w río|strong="H2975"\w* \w para|strong="H3588"\w* \w beber|strong="H8354"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w podían|strong="H3201"\w* \w beber|strong="H8354"\w* \w de|strong="H3588"\w* las \w aguas|strong="H4325"\w* \w del|strong="H8354"\w* \w río|strong="H2975"\w*.   
