\id JOL Azeri-N: Azerbaijani Bible 2008 
\h YOEL 
\toc1 Yoel Peyğəmbərin Kitabi 
\toc2 Yoel 
\toc3 Yoel 
\mt1 YOEL  
\mt2 PEYĞƏMBƏRİN KİTABI  
\imt1 GİRİŞ  
\ip Yoel peyğəmbər İsrailin üzərinə gələn çəyirtkələrin dəhşətli hücumundan və böyük quraqlıqdan danışır. Bu hadisələrdə o, Rəbbin gününü, Onun ədalətli hökmünə qarşı çıxanların cəzalandırılacağı vaxtın əlamətlərini görür. Peyğəmbər Allahın xalqını tövbəyə çağırır və Onun xalqına verdiyi xeyir-dualı vədləri yadına salır. Burada vacib fikir odur ki, Rəbb Öz Ruhunu bütün xalqın, o cümlədən qadın və kişilərin, gənc və qocaların üzərinə tökməyi vəd edir.  
\iot Kitabın məzmunu:  
\io2 1:1–2:17 Çəyirtkə bəlası və tövbə çağırışı  
\io2 2:18-27 Rəbbin cavabı və bərəkət vədi  
\io2 2:28–3:21 Rəbbin günü  
\c 1  
\s1 Məhv olmuş məhsul üçün yas  
\p
\v 1 Petuelin oğlu Yoelə nazil olan Rəbbin sözü budur:   
\q1
\v 2 Ey ağsaqqallar, bunu dinləyin.  
\q1 Ey bütün ölkə əhalisi, buna qulaq asın,  
\q1 Sizin və atalarınızın dövründə  
\q1 Belə bir şey olubmu?   
\q1
\v 3 Siz bunu övladlarınıza danışın.  
\q1 Övladlarınız da öz övladlarına,  
\q1 Onların övladları isə gələcək nəslə danışsın.   
\b  
\q1
\v 4 Kəsici çəyirtkələrdən qalanı qaynaşan çəyirtkə yedi,  
\q1 Qaynaşan çəyirtkədən qalanı tullanan çəyirtkə yedi,  
\q1 Tullanan çəyirtkədən qalanı dağıdıcı çəyirtkə yeyib-qurtardı.   
\b  
\q1
\v 5 Ayılın, ey sərxoşlar və ağlayın.  
\q1 Ey şirin şərab içənlər, hamınız nalə çəkin,  
\q1 Ona görə ki, şirin şərab ağzınızdan alındı.   
\q1
\v 6 \x * \xo 1:6 \xt Vəhy 9:8 \x* Çünki mənim torpağımın üzərinə  
\q1 Qüvvətli və saysız-hesabsız bir millət gəldi.  
\q1 Onların dişləri aslan dişləri kimidir,  
\q1 Onlarda dişi aslanın köpək dişləri var.   
\q1
\v 7 Tənəyimi məhv etdi,  
\q1 Əncir ağacımı gəmirdi,  
\q1 Qabıqlarını tamamilə soyub yerə atdı,  
\q1 Budaqları ağ qaldı.   
\b  
\q1
\v 8 Cavanlıqda nişanlısını itirən,  
\q1 Büsbütün çul geyinən  
\q1 Bir qız kimi yas tutun.   
\q1
\v 9 Rəbbin evindən  
\q1 Taxıl təqdimi və içmə təqdimi kəsildi,  
\q1 Rəbbə xidmət edən kahinlər yas tutur.   
\q1
\v 10 Zəmi viran qalıb, torpaq ağlayır,  
\q1 Çünki taxıl zay oldu, təzə şərab qurudu,  
\q1 Zeytun yağı qurtardı.   
\b  
\q1
\v 11 Buğda və arpaya görə  
\q1 Ey əkinçilər, utanın!  
\q1 Ey bağbanlar, nalə çəkin!  
\q1 Çünki torpağın məhsulları yoxa çıxdı,   
\q1
\v 12 Tənək qurudu,  
\q1 Əncir ağacı soldu,  
\q1 Nar, xurma, alma,  
\q1 Çölün bütün ağacları qurudu.  
\q1 Görün ki, bəşər övladları arasından sevinc yox oldu.   
\s1 Tövbəyə çağırın  
\q1
\v 13 Ey kahinlər, çul geyinərək yas tutun!  
\q1 Ey qurbangah xidmətçiləri, nalə çəkin!  
\q1 Ey Allahıma xidmət edənlər,  
\q1 Gəlin çulda gecələyin,  
\q1 Çünki Allahınızın evindən  
\q1 Taxıl təqdimi və içmə təqdimi yox oldu.   
\q1
\v 14 Oruc üçün vaxt təyin edin,  
\q1 Təntənəli toplantı çağırın.  
\q1 Ağsaqqalları, ölkənin bütün əhalisini  
\q1 Allahınız Rəbbin evinə yığın,  
\q1 Rəbbə fəryad qoparın.   
\b  
\q1
\v 15 \x * \xo 1:15 \xt Yeş. 13:6 \x* Vay o günə!  
\q1 Budur, Rəbbin o günü yaxındır,  
\q1 O gün Külli-İxtiyar fəlakət gətirəcək.   
\q1
\v 16 O yemək gözlərimizin önündən,  
\q1 Sevinc və şadlıq Allahımızın evindən yox olmadımı?   
\b  
\q1
\v 17 Torpaq kəsəkləri altında toxumlar çürüdü,  
\q1 Zirzəmilər boş qaldı,  
\q1 Anbarlar dağıldı,  
\q1 Çünki taxıllar məhv oldu.   
\q1
\v 18 Heyvanlar necə də inildəyir,  
\q1 Naxırlar çaşbaş qalıb,  
\q1 Çünki onlar otlaqsız qalıb,  
\q1 Sürülər də susuzluqdan əldən düşür.   
\b  
\q1
\v 19 Ya Rəbb, Sənə fəryad edirəm,  
\q1 Çünki çölün otlaqlarını alov yandırıb-yaxdı,  
\q1 Bütün düzəngahın ağacları odda qovruldu.   
\q1
\v 20 Çöl heyvanları da Səni çağırır,  
\q1 Axı axar sular quruyub,  
\q1 Çölün otlaqlarını alov yandırıb-yaxdı.   
\c 2  
\s1 Rəbbin günü – qaranlıq və zülmət günü  
\q1
\v 1 Sionda şeypur çalın,  
\q1 Müqəddəs dağımda bərkdən çalın.  
\q1 Qoy ölkənin bütün əhalisi titrəsin,  
\q1 Çünki Rəbbin günü gəlir,  
\q1 Həmin gün yaxındadır.   
\q1
\v 2  \x * \xo 2:2 \xt Sef. 1:15 \x* \x * \xo 2:2 \xt Çıx. 10:14 \x* Qaranlıq zülmətli bir gün!  
\q1 Buludlu və qatı qaranlıq bir gün!  
\q1 Bir qoşun gəlir  
\q1 Dağlar üzərində yayılan dan kimi  
\q1 Çoxsaylı və qüvvətli bir qoşun.  
\q1 Elə bir qoşun ki,  
\q1 Əzəldən bəri bunun kimisi olmamışdır,  
\q1 Bundan sonra da nəsillər boyu olmayacaqdır.   
\b  
\q1
\v 3 Önlərindəki hər şeyi od yandırıb-yaxır,  
\q1 Arxada qalanları alov qovurur.  
\q1 Önlərindəki Eden bağına bənzər yerdir,  
\q1 Arxalarında olansa izsiz bir səhradır,  
\q1 Heç nə onlardan qaçıb qurtara bilmir.   
\b  
\q1
\v 4  \x * \xo 2:4 \xt Vəhy 9:7-9 \x* Onlar görkəmcə ata bənzəyir.  
\q1 Atlar necə çapırlarsa,  
\q1 Onlar da eləcə çapırlar.   
\q1
\v 5 Döyüş arabalarına bənzəyən səslə,  
\q1 Küləşi yandırıb-yaxan od-alovun səsi ilə,  
\q1 Dağların zirvələri üzərindən tullanırlar.  
\q1 Onlar hücum üçün düzülən güclü bir qoşuna bənzəyirlər.   
\q1
\v 6  \x * \xo 2:6 \xt Nah. 2:10 \x* Onların qarşısında xalqlar sanki ağrı çəkir,  
\q1 Bütün üzlər solur.   
\q1
\v 7 Qaçırlar igidlər kimi,  
\q1 Divara dırmaşırlar cəngavərlər kimi.  
\q1 Hamı nizamla gedir sırasını pozmadan.   
\q1
\v 8 Heç kim yoldaşını tapdalamadan  
\q1 Yolundan çıxmır.  
\q1 Silahlar sırasını yarıb-keçirlər,  
\q1 Lakin salamat qalırlar.   
\q1
\v 9 Şəhərə doğru qaçışır,  
\q1 Divarlardan atlanıb evlərə soxulurlar,  
\q1 Quldur kimi pəncərələrdən girirlər.   
\b  
\q1
\v 10  \x * \xo 2:10 \xt Vəhy 8:12 \x* Qarşılarında yer sarsılır,  
\q1 Göylər lərzəyə gəlir,  
\q1 Günəş və ay qaralır,  
\q1 Ulduzlar işıqlarını gizlədir.   
\q1
\v 11  \x * \xo 2:11 \xt Vəhy 6:17 \x* Rəbb Öz ordusu önündə səs salır:  
\q1 Ordularının sayı-hesabı yoxdur.  
\q1 Onun sözünü yerinə yetirənlər güclüdür.  
\q1 Rəbbin günü möhtəşəm və çox dəhşətlidir.  
\q1 Buna kim dözə bilər?   
\s1 Rəbbə dönün  
\q1
\v 12 Rəbb belə bəyan edir:  
\q1 «İndi isə orucla, ağlamaqla, yas tutmaqla  
\q1 Bütün qəlbinizlə Mənə dönün.   
\q1
\v 13  \x * \xo 2:13 \xt Çıx. 34:6; Say. 14:18; Neh. 9:17; Zəb. 86:15; 103:8; 145:8; Yun. 4:2 \x* Paltarlarınızı deyil, ürəyinizi yırtın,  
\q1 Allahınız Rəbbə tərəf qayıdın».  
\q1 Çünki O, lütfkar və rəhmlidir,  
\q1 Hədsiz səbirlidir, bol məhəbbətlidir,  
\q1 Bəla göndərməz, rəhm edər.   
\q1
\v 14 Kim bilir, bəlkə rəhm edib dönər?  
\q1 Sonra Allahınız Rəbbə  
\q1 Taxıl və içmə təqdimlərini verəsiniz deyə  
\q1 Sizə bərəkət verər.   
\b  
\q1
\v 15 Sionda şeypur çalın,  
\q1 Oruc üçün vaxt təyin edin,  
\q1 Təntənəli toplantı çağırın.   
\q1
\v 16 Xalqı bir yerə yığın,  
\q1 Camaatı təqdis edin,  
\q1 Ağsaqqalları yığın,  
\q1 Uşaqları və südəmər çağaları toplayın.  
\q1 Bəy öz otağından,  
\q1 Gəlin də öz gərdəyindən çıxsın.   
\q1
\v 17 Rəbbə xidmət edən kahinlər  
\q1 Məbədin eyvanı ilə qurbangah arasında ağlayıb desin:  
\q1 «Ya Rəbb, xalqına qıyma,  
\q1 Öz irsini rüsvay olmağa qoyma!  
\q1 Qoyma onlar millətlərin dilinə düşsün.  
\q1 Axı nə üçün xalqlar arasında belə deyilsin:  
\q1 “Bəs hanı onların Allahı?”»   
\s1 Rəbbin cavabı və bərəkət vədi  
\q1
\v 18 O zaman Rəbb Öz torpağına qıymayacaq,  
\q1 Öz xalqına rəhm edəcək.   
\q1
\v 19 Rəbb xalqına belə cavab verəcək:  
\q1 «Budur, sizə taxıl,  
\q1 Təzə şərab və zeytun yağı göndərəcəyəm,  
\q1 Bunlarla doyacaqsınız,  
\q1 Artıq sizi millətlər arasında rüsvay etməyəcəyəm.   
\q1
\v 20 Şimal tərəfdən gələn ordunu sizdən uzaqlaşdıracağam.  
\q1 Onu quraq, izsiz bir yerə,  
\q1 Qarşıdakı ordunu Şərq dənizinə, \f + \fr 2:20 \fq Şərq dənizi \ft – Ölü dəniz.\f*  
\q1 Arxadan gələnləri isə Qərb dənizinə aparacağam. \f + \fr 2:20 \fq Qərb dənizi \ft – Aralıq dənizi.\f*  
\q1 Onların cəsədlərinin pis iyləri ətrafa yayılacaq».  
\q1 Həqiqətən, Rəbb böyük işlər gördü.   
\b  
\q1
\v 21 Qorxma, ey torpaq, sevin, fərəhlən.  
\q1 Bu böyük işləri görən Rəbdir.   
\q1
\v 22 Qorxmayın, ey çöl heyvanları,  
\q1 Çünki çölün otlaqları göyərir.  
\q1 Ağac meyvəsi ilə yüklənir,  
\q1 Əncir ağacı, tənək bəhrələrini verir.   
\b  
\q1
\v 23 Ey Sion xalqı,  
\q1 Allahınız Rəbdə sevinin və şadlanın,  
\q1 Çünki payız yağışını sizə kifayət qədər verir. \f + \fr 2:23 \fq Payız yağışını sizə kifayət qədər verir \ft – yaxud \fq sizə salehliyi öyrədən müəllimi verir.\f*  
\q1 Əvvəlki kimi payız yağışı ilə  
\q1 Yaz yağışını yağdırır.   
\q1
\v 24 Xırmanlar taxılla dolu olacaq,  
\q1 Təknələr təzə şərab və zeytun yağı ilə daşacaq.   
\b  
\q1
\v 25 «Aranıza göndərdiyim böyük qoşunumun –  
\q1 Kəsici çəyirtkənin, qaynaşan çəyirtkənin,  
\q1 Tullanan çəyirtkənin və dağıdıcı çəyirtkənin  
\q1 Yeyib-qurtardığı illərin əvəzini verəcəyəm.   
\q1
\v 26 Bol-bol, doyunca yeyəcəksiniz,  
\q1 Sizin üçün möcüzəli şeylər edən  
\q1 Allahınız Rəbbin adına şükürlər edəcəksiniz.  
\q1 Xalqım əbədi olaraq rüsvay olmayacaq.   
\q1
\v 27 Onda biləcəksiniz ki,  
\q1 Mən İsrailin arasındayam,  
\q1 Allahınız Rəbb Mənəm,  
\q1 Başqası yoxdur.  
\q1 Xalqım əbədi olaraq rüsvay olmayacaq.   
\s1 Rəbbin günü  
\q1
\v 28  \x * \xo 2:28 \xt Həv. 2:16-21 \x* Ondan sonra isə  
\q1 Bütün bəşər üzərinə Ruhumu tökəcəyəm.  
\q1 Oğullarınız və qızlarınız peyğəmbərlik edəcək,  
\q1 Ağsaqqallarınız röyalar,  
\q1 Cavanlarınızsa görüntülər görəcək.   
\q1
\v 29 O günlərdə qul və qarabaşların üzərinə də  
\q1 Ruhumu tökəcəyəm.   
\b  
\q1
\v 30 Göylərdə və yerdə əlamətlər göstərəcəyəm:  
\q1 Qan, alov və tüstü dirəkləri görünəcək.   
\q1
\v 31  \x * \xo 2:31 \xt Mat. 24:29; Mark 13:24-25; Luka 21:25; Vəhy 6:12-13 \x* Rəbbin möhtəşəm və dəhşətli günü gəlməzdən əvvəl  
\q1 Günəş qaranlığa və ay qan rənginə dönəcək.   
\q1
\v 32  \x * \xo 2:32 \xt Rom. 10:13 \x* Amma Rəbbin adını çağıran hər kəs xilas olacaq,  
\q1 Çünki Rəbbin dediyi kimi  
\q1 Sion dağında və Yerusəlimdə qurtuluş olacaq,  
\q1 Rəbbin çağırdığı sağ qalanlar arasında olacaq.   
\c 3  
\s1 Rəbb millətləri mühakimə edir  
\p
\v 1 O günlərdə Yəhuda və Yerusəlimin  
\q1 Sərvətlərini geri qaytardığım zaman   
\q1
\v 2 Bütün millətləri yığıb  
\q1 Yehoşafat \f + \fr 3:2 \fq Yehoşafat \ft – ibrani dilində \fq Rəbb mühakimə edir.\f* vadisinə endirəcəyəm.  
\q1 İrsim və xalqım İsraildən ötrü  
\q1 Orada millətləri mühakimə edəcəyəm,  
\q1 Çünki xalqımı millətlər arasında dağıtdılar,  
\q1 Torpağımı da böldülər.   
\q1
\v 3 Xalqım üçün püşk atdılar,  
\q1 Oğlan uşaqlarını fahişə əvəzinə verdilər,  
\q1 İçki içsinlər deyə  
\q1 Qızları şəraba satdılar».   
\p
\v 4 \x * \xo 3:4 \xt Yeş. 23:1-18; Yez. 26:1–28:26; Amos 1:9-10; Zək. 9:2-4; Mat. 11:20-22; Luka 10:13-14 \x* \x * \xo 3:4 \xt Yeş. 14:29-31; Yer. 47:1-7; Yez. 25:15-17; Amos 1:6-8; Sef. 2:4-7; Zək. 9:5-7 \x* «Ey Surlular, Sidonlular və bütün Filişt vilayətlərinin əhalisi, siz kimsiniz ki, Məndən qisas alasınız. Əgər siz Məndən qisas alsanız, çox tezliklə Mən sizin etdiyinizin əvəzini öz başınıza döndərəcəyəm.  
\v 5 Siz qızılımı və gümüşümü aldınız və qiymətli şeylərimi məbədlərinizə apardınız,  
\v 6 Yəhuda və Yerusəlim xalqını öz vətənlərindən uzaqlaşdırmaq üçün Yunan xalqına satdınız.  
\v 7 Amma Mən onları satdığınız yerdən götürəcəyəm, etdiyinizin əvəzini öz başınıza döndərəcəyəm.  
\v 8 Oğul-qızlarınızı Yəhuda xalqına satacağam və Yəhuda xalqı isə onları ucqar bir millətə – Səbalılara satacaq». Rəbb belə söylədi.   
\q1
\v 9 «Millətlər arasında bunu elan edin:  
\q1 Döyüşə hazırlaşın,  
\q1 İgidləri qızışdırın,  
\q1 Bütün döyüşçülər yaxınlaşıb yuxarı çıxsın.   
\q1
\v 10 \x * \xo 3:10 \xt Yeş. 2:4; Mik. 4:3 \x* Kotanlarınızdan qılınc,  
\q1 Dəryazlarınızdan nizə düzəldin.  
\q1 Qoy zəif olan “güclüyəm” desin.   
\q1
\v 11 Tələsin, ey hər tərəfdəki millətlər,  
\q1 Gəlin və toplaşın.  
\q1 Ya Rəbb, igidlərini oraya endir.   
\q1
\v 12 Millətlər hərəkətə gələrək  
\q1 Yehoşafat vadisinə çıxsın,  
\q1 Çünki hər tərəfdəki bütün millətləri  
\q1 Mühakimə etmək üçün orada oturacağam.   
\q1
\v 13 \x * \xo 3:13 \xt Vəhy 14:15 \x* \x * \xo 3:13 \xt Vəhy 14:19-20; 19:15 \x* Oraq çalın,  
\q1 Çünki məhsul yetişib.  
\q1 Gəlin ayağınızla əzin,  
\q1 Çünki üzümsıxanlar doludur,  
\q1 Təknələr daşır.  
\q1 Çünki onların pisliyi böyükdür».   
\b  
\q1
\v 14 Kütlələr, mühakimə vadisində olan kütlələr,  
\q1 Çünki mühakimə vadisində Rəbbin günü yaxındır!   
\q1
\v 15 Günəş və ay qaralır,  
\q1 Ulduzlar işıqlarını gizlədir.   
\b  
\q1
\v 16 \x * \xo 3:16 \xt Yer. 25:30; Amos 1:2 \x* Rəbb Siondan nərə çəkəcək,  
\q1 Yerusəlimdən guruldayacaq,  
\q1 Göy və yer sarsılacaq.  
\q1 Lakin Rəbb Öz xalqı üçün sığınacaq yer,  
\q1 İsrail övladları üçün qala olacaq.   
\s1 Allahın Öz xalqına xeyir-duası  
\q1
\v 17 «O zaman biləcəksiniz ki,  
\q1 Müqəddəs dağım Sionda məskən salan  
\q1 Allahınız Rəbb Mənəm!  
\q1 Yerusəlim müqəddəs olacaq,  
\q1 Artıq yadellilər oradan keçməyəcək.   
\b  
\q1
\v 18 O gün belə olacaq:  
\q1 Dağlardan şirin şərab damacaq,  
\q1 Təpələrdən süd axacaq,  
\q1 Yəhudanın bütün dərələrində sular axacaq.  
\q1 Rəbbin evindən bir qaynaq çıxacaq,  
\q1 Əbrişimlər \f + \fr 3:18 \fq Əbrişimlər \ft – ibrani mətnində \+tl Şittim\+tl*.\f* vadisini sulayacaq.   
\q1
\v 19 Yəhuda xalqına qəddarlıq etdiyinə,  
\q1 Torpaqlarında günahsız qan tökdüyünə görə  
\q1 Misir viran qalacaq,  
\q1 Edom izsiz bir səhra olacaq.   
\q1
\v 20 Lakin Yəhuda əbədi qalacaq,  
\q1 Yerusəlim nəsildən-nəslə keçəcək.   
\q1
\v 21 Onların tökdüyü qanları  
\q1 İndiyə qədər bağışlamamışam,  
\q1 Lakin bundan sonra bağışlayacağam.  
\q1 Rəbb Sionda məskən salır».   