\v 9 \wj \+w y|strong="H3588"\+w* \+w así|strong="H3588"\+w* \+w no|strong="H3808"\+w* pasará \+w la|strong="H3588"\+w* \+w heredad|strong="H5159"\+w* \+w de|strong="H3588"\+w* una \+w tribu|strong="H4294"\+w* \+w a|strong="H3068"\+w* otra, \+w sino|strong="H3588"\+w* las \+w tribus|strong="H4294"\+w* \+w de|strong="H3588"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H3588"\+w* \+w Israel|strong="H3478"\+w* conservarán \+w su|strong="H3588"\+w* propia \+w herencia|strong="H5159"\+w*.\wj*   
