\v 8 \w Manghai|strong="H4428"\w* \w te|strong="H9998"\w* \w thoo|strong="H6965"\w* \w tih|strong="H9999"\w* \w vongka|strong="H8179"\w* \w ah|strong="H9996"\w* \w ngol|strong="H3427"\w*. Te \w vaengah|strong="H9999"\w* \w pilnam|strong="H5971"\w* \w boeih|strong="H3605"\w* \w taengla|strong="H9997"\w* \w puen|strong="H5046"\w* uh tih, “\w Vongka|strong="H8179"\w* \w ah|strong="H9996"\w* \w manghai|strong="H4428"\w* \w om|strong="H3427"\w* \w ke|strong="H2009"\w*,” a \w ti|strong="H0559"\w* uh. Te \w daengah|strong="H9999"\w* \w pilnam|strong="H5971"\w* \w boeih|strong="H3605"\w* te \w manghai|strong="H4428"\w* \w kah|strong="H9998"\w* \w mikhmuh|strong="H6440"\w* \w ah|strong="H9997"\w* ha \w pawk|strong="H0935"\w* \w tih|strong="H9999"\w* \w Israel|strong="H3478"\w* \w amah|strong="H9909"\w* kah \w dap|strong="H0168"\w* \w la|strong="H9997"\w* \w boeih|strong="H0376"\w* \w rhaelrham|strong="H5127"\w* van.
