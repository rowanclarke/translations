\v 1 ÉSTAS \add son\add* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* \w habló|strong="H1696"\w* \w Moisés|strong="H4872"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w de|strong="H1697"\w* esta parte del \w Jordán|strong="H3383"\w* en \w el|strong="H3605"\w* \w desierto|strong="H4057"\w*, en \w el|strong="H3605"\w* llano \w delante|strong="H4136"\w* del mar \w Bermejo|strong="H5489"\w*, entre \w Parán|strong="H6290"\w*, y Tofel, y \w Labán|strong="H3837"\w*, y Haserot, y Dizahab.
\m 
\v 2 Once \w jornadas|strong="H3117"\w* hay \w desde|strong="H5704"\w* \w Horeb|strong="H2722"\w*, \w camino|strong="H1870"\w* del \w monte|strong="H2022"\w* \w de|strong="H5704"\w* \w Seir|strong="H8165"\w*, \w hasta|strong="H5704"\w* \w Cades-barnea|strong="H6947"\w*.
\m 
\v 3 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w*, \w que|strong="H1121"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* cuarenta \w años|strong="H8141"\w*, en \w el|strong="H3605"\w* \w mes|strong="H2320"\w* \w undécimo|strong="H6249"\w*, al primero del \w mes|strong="H2320"\w*, \w Moisés|strong="H4872"\w* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* conforme \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las cosas \w que|strong="H1121"\w* \w el|strong="H3605"\w* \w SEÑOR|strong="H3068"\w* le \w había|strong="H1961"\w* \w mandado|strong="H6680"\w* \w acerca|strong="H1696"\w* \w de|strong="H1121"\w* \w ellos|strong="H3605"\w*;
\m 
\v 4 \w Después|strong="H3427"\w* que \w hirió|strong="H5221"\w* \w a|strong="H3068"\w* \w Sehón|strong="H5511"\w* \w rey|strong="H4428"\w* de \w los|strong="H3427"\w* amorreos, que \w habitaba|strong="H3427"\w* \w en|strong="H5221"\w* \w Hesbón|strong="H2809"\w*, y \w a|strong="H3068"\w* \w Og|strong="H5747"\w* \w rey|strong="H4428"\w* de \w Basán|strong="H1316"\w*, que \w habitaba|strong="H3427"\w* \w en|strong="H5221"\w* Astarot \w en|strong="H5221"\w* Edrei:
\m 
\v 5 De \w esta|strong="H2063"\w* parte del \w Jordán|strong="H3383"\w*, en tie­rra de \w Moab|strong="H4124"\w*, \w resolvió|strong="H2974"\w* \w Moisés|strong="H4872"\w* declarar \w esta|strong="H2063"\w* \w ley|strong="H8451"\w*, diciendo:
\m 
\v 6 \w El|strong="H3427"\w* \w SEÑOR|strong="H3068"\w* nuestro \w Dios|strong="H3068"\w* nos \w habló|strong="H1696"\w* en \w Horeb|strong="H2722"\w*, \w diciendo|strong="H1696"\w*: Bastante tiempo habéis estado en \w este|strong="H2088"\w* \w monte|strong="H2022"\w*;
\m 
\v 7 \w Volveos|strong="H6437"\w*, \w partíos|strong="H5265"\w* \w e|strong="H3068"\w* id \w al|strong="H5704"\w* \w monte|strong="H2022"\w* del amorreo, \w y|strong="H5704"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* sus comarcas, \w en|strong="H5704"\w* \w el|strong="H3605"\w* llano, \w en|strong="H5704"\w* \w el|strong="H3605"\w* \w monte|strong="H2022"\w*, \w y|strong="H5704"\w* \w en|strong="H5704"\w* \w los|strong="H3605"\w* valles, \w y|strong="H5704"\w* \w en|strong="H5704"\w* \w el|strong="H3605"\w* sur, \w y|strong="H5704"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* costa del \w mar|strong="H3220"\w*, \w a|strong="H3068"\w* \w la|strong="H3605"\w* tierra del \w cananeo|strong="H3669"\w*, \w y|strong="H5704"\w* \w el|strong="H3605"\w* \w Líbano|strong="H3844"\w*, \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w gran|strong="H1419"\w* \w río|strong="H5104"\w*, \w el|strong="H3605"\w* \w río|strong="H5104"\w* \w Éufrates|strong="H6578"\w*.
\m 
\v 8 \w Mirad|strong="H7200"\w*, yo he \w dado|strong="H5414"\w* la tierra en vuestra \w presencia|strong="H6440"\w*; entrad y pose­ed la tierra que el \w SEÑOR|strong="H3068"\w* \w juró|strong="H7650"\w* \w a|strong="H3068"\w* vuestros padres Abraham, \w Isaac|strong="H3327"\w*, y \w Jacob|strong="H3290"\w*, que les \w daría|strong="H5414"\w* \w a|strong="H3068"\w* ellos y \w a|strong="H3068"\w* su \w simiente|strong="H2233"\w* después \w de|strong="H6440"\w* ellos.
\m 
\v 9 \w Y|strong="H3068"\w* yo os hablé \w entonces|strong="H6256"\w*, dicien­do: Yo \w no|strong="H3808"\w* \w puedo|strong="H3201"\w* \w llevaros|strong="H5375"\w* \w solo|strong="H1931"\w*:
\m 
\v 10 El \w SEÑOR|strong="H3068"\w* vuestro \w Dios|strong="H3068"\w* os ha multiplicado, y he \w aquí|strong="H2009"\w* sois \w hoy|strong="H3117"\w* vosotros como las \w estrellas|strong="H3556"\w* del \w cielo|strong="H8064"\w* en \w multitud|strong="H7230"\w*.
\m 
\v 11 ¡\w El|strong="H5921"\w* \w SEÑOR|strong="H3068"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* vuestros padres \w añada|strong="H3254"\w* \w sobre|strong="H5921"\w* vosotros \w como|strong="H5921"\w* sois mil \w veces|strong="H6471"\w*, \w y|strong="H5921"\w* \w os|strong="H5921"\w* bendi­ga, \w como|strong="H5921"\w* \w os|strong="H5921"\w* ha prometido!
\m 
\v 12 ¿Cómo \w llevaré|strong="H5375"\w* yo solo vues­tras molestias, vuestras cargas, y vuestros pleitos?
\m 
\v 13 \w Dad|strong="H3051"\w*\add me\add* de entre vosotros, de vuestras \w tribus|strong="H7626"\w*, varones \w sabios|strong="H2450"\w* y \w entendidos|strong="H3045"\w* y expertos, para \w que|strong="H3045"\w* yo \w los|strong="H2450"\w* \w ponga|strong="H7760"\w* por vuestros \w jefes|strong="H7218"\w*.
\m 
\v 14 \w Y|strong="H3068"\w* me \w respondisteis|strong="H6030"\w*, y dijis­teis: \w Bueno|strong="H2896"\w* \w es|strong="H1697"\w* \w hacer|strong="H6213"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* has \w dicho|strong="H1696"\w*.
\m 
\v 15 \w Y|strong="H3068"\w* \w tomé|strong="H3947"\w* \w los|strong="H5921"\w* \w principales|strong="H7218"\w* \w de|strong="H5921"\w* vuestras \w tribus|strong="H7626"\w*, varones \w sabios|strong="H2450"\w* \w y|strong="H5921"\w* expertos, \w y|strong="H5921"\w* púselos \w por|strong="H5921"\w* \w jefes|strong="H8269"\w* \w sobre|strong="H5921"\w* vosotros, \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* millares, \w y|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* cientos, \w y|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* cin­cuenta, \w y|strong="H5921"\w* cabos \w de|strong="H5921"\w* \w diez|strong="H6235"\w*, \w y|strong="H5921"\w* gober­nadores \w a|strong="H3068"\w* vuestras \w tribus|strong="H7626"\w*.
\m 
\v 16 \w Y|strong="H3068"\w* \w entonces|strong="H6256"\w* \w mandé|strong="H6680"\w* \w a|strong="H3068"\w* vuestros \w jueces|strong="H8199"\w*, diciendo: \w Oíd|strong="H8085"\w* entre vues­tros hermanos, y \w juzgad|strong="H8199"\w* justa­mente entre \w el|strong="H1931"\w* hombre y \w su|strong="H1931"\w* her­\w mano|strong="H1931"\w*, y \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w le|strong="H1931"\w* \w es|strong="H1931"\w* \w extranjero|strong="H1616"\w*.
\m 
\v 17 \w No|strong="H3808"\w* tengáis respeto \w de|strong="H4480"\w* perso­nas \w en|strong="H4480"\w* \w el|strong="H1931"\w* \w juicio|strong="H4941"\w*: \w así|strong="H3588"\w* \w al|strong="H4480"\w* \w pequeño|strong="H6996"\w* \w como|strong="H3588"\w* \w al|strong="H4480"\w* \w grande|strong="H1419"\w* \w oiréis|strong="H8085"\w*: \w no|strong="H3808"\w* ten­dréis temor \w de|strong="H4480"\w* \w ninguno|strong="H3808"\w*, \w porque|strong="H3588"\w* \w el|strong="H1931"\w* \w juicio|strong="H4941"\w* \w es|strong="H1931"\w* \w de|strong="H4480"\w* Dios: \w y|strong="H3588"\w* \w la|strong="H1931"\w* \w causa|strong="H1697"\w* \w que|strong="H3588"\w* \w os|strong="H4480"\w* fuere difícil, \w la|strong="H1931"\w* traeréis \w a|strong="H3068"\w* mí, \w y|strong="H3588"\w* \w yo|strong="H4480"\w* \w la|strong="H1931"\w* \w oiré|strong="H8085"\w*.
\m 
\v 18 Os \w mandé|strong="H6680"\w*, \w pues|strong="H1931"\w*, en \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* habíais \w de|strong="H1697"\w* \w hacer|strong="H6213"\w*.
