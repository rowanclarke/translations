\id MRK - Biblica® Open Yoruba Contemporary Bible 2017
\h Marku
\toc1 Ìwé Ìyìnrere Marku
\toc2 Marku
\toc3 Mk
\mt1 Ìwé Ìyìnrere Marku
\c 1
\s1 Johanu onítẹ̀bọmi tún ọ̀nà ṣe sílẹ̀
\p 
\v 1 Ìbẹ̀rẹ̀ ìyìnrere nípa Jesu Kristi, Ọmọ Ọlọ́run.
\p 
\v 2 Gẹ́gẹ́ bí a ti kọ ọ́ nínú ìwé wòlíì Isaiah pé,
\q1 “Èmi yóò ran oníṣẹ́ mi síwájú rẹ,
\q2 Ẹni tí yóò tún ọ̀nà rẹ ṣe.”
\q1 
\v 3 “Ohùn ẹni tí ń kígbe ní ijù,
\q2 ‘Ẹ tún ọ̀nà Olúwa ṣe,
\q2 ẹ ṣe ojú ọ̀nà rẹ̀ kí ó tọ́.’ ”
\m 
\v 4 Johanu dé, ẹni tí ó ń tẹnibọmi ní aginjù, tí ó sì ń wàásù ìtẹ̀bọmi ìrònúpìwàdà fún ìdáríjì ẹ̀ṣẹ̀.
\v 5 Gbogbo àwọn tí ń gbé ní agbègbè Judea, àti gbogbo ènìyàn Jerusalẹmu jáde tọ̀ ọ́ lọ, a sì ti ọwọ́ rẹ̀ tẹ gbogbo wọn bọ omi ni odò Jordani, wọ́n ń jẹ́wọ́ ẹ̀ṣẹ̀ wọn.
\v 6 Johanu sì wọ aṣọ irun ìbákasẹ. Ó sì di àmùrè awọ mọ́ ẹ̀gbẹ́ rẹ̀. Eṣú àti oyin ìgàn sì ni oúnjẹ rẹ̀.
\v 7 Ó sì bẹ̀rẹ̀ sí í wàásù wí pé, “Ẹnìkan tí ó tóbi jù mí lọ ń bọ̀ lẹ́yìn mi, okùn bàtà ẹsẹ̀ ẹni tí èmi kò tó ẹni tí ń tú.
\v 8 Èmi ń fi omi ṣe ìtẹ̀bọmi yín, ṣùgbọ́n Òun yóò fi Ẹ̀mí Mímọ́ ṣe ìtẹ̀bọmi yín.”
\s1 Ìtẹ̀bọmi àti ìdánwò Jesu
\p 
\v 9 Ó sì ṣe ní ọjọ́ kan Jesu ti Nasareti ti Galili jáde wá, a sì ti ọwọ́ Johanu ṣe ìtẹ̀bọmi fún ní odò Jordani.
\v 10 Lẹ́sẹ̀kẹsẹ̀ tí Jesu ń ti inú omi jáde wá, ó rí ọ̀run tí ó ṣí sílẹ̀, Ẹ̀mí Mímọ́ bí àdàbà sọ̀kalẹ̀ lé e lórí.
\v 11 Ohùn kan sì ti ọ̀run wá wí pé, “Ìwọ ni àyànfẹ́ Ọmọ mi, ẹni tí inú mi dùn sí gidigidi.”
\p 
\v 12 Lẹ́sẹ̀kan náà, Ẹ̀mí Mímọ́ sì darí Jesu sí ijù,
\v 13 Ó sì wà ní ogójì ọjọ́ ní aginjù. A sì ti ọwọ́ Satani dán an wò, ó sì wà pẹ̀lú àwọn ẹranko ìgbẹ́. Àwọn angẹli sì ń ṣe ìránṣẹ́ fún un.
\s1 Pípe àwọn ọmọ-ẹ̀yìn àkọ́kọ́
\p 
\v 14 Lẹ́yìn ìgbà tí ọba Herodu ti fi Johanu sínú ẹ̀wọ̀n tan, Jesu lọ sí Galili, ó ń wàásù ìyìnrere ti ìjọba Ọlọ́run.
\v 15 Ó sì kéde wí pé, \wj “Àkókò náà dé wàyí, ìjọba Ọlọ́run kù sí dẹ̀dẹ̀. Ẹ yípadà kúrò nínú ẹ̀ṣẹ̀ yín, kí ẹ sì gba ìyìnrere yìí gbọ́.”\wj*
\p 
\v 16 Ní ọjọ́ kan, bí Jesu ti ń rìn létí Òkun Galili, Ó rí Simoni àti Anderu arákùnrin rẹ̀, wọ́n ń fi àwọ̀n wọn pẹja torí pé apẹja ni wọ́n.
\v 17 Jesu sì ké sí wọn wí pé, \wj “Ẹ máa tọ̀ mí lẹ́yìn. Èmi yóò sì sọ yín di apẹja ènìyàn.”\wj*
\v 18 Ní kánkán wọ́n fi àwọ̀n wọn sílẹ̀, wọ́n sì tọ̀ Ọ́ lẹ́yìn.
\p 
\v 19 Bí Ó sì ti rìn síwájú díẹ̀, ní etí Òkun, Ó rí Jakọbu ọmọ Sebede àti Johanu arákùnrin rẹ̀ nínú ọkọ̀, wọ́n ń tún àwọ̀n wọn ṣe.
\v 20 Ó sì ké sí àwọn náà lẹ́sẹ̀kẹsẹ̀, wọ́n fi Sebede baba wọn sílẹ̀ nínú ọkọ̀ pẹ̀lú àwọn alágbàṣe, wọ́n sì tọ̀ ọ́ lẹ́yìn.
\s1 Jesu lé ẹ̀mí àìmọ́ jáde
\p 
\v 21 Lẹ́yìn náà, Jesu àti àwọn ọmọ-ẹ̀yìn rẹ̀ wọ ìlú Kapernaumu, nígbà tí ó di òwúrọ̀ ọjọ́ ìsinmi, ó lọ sínú Sinagọgu, ó sì ń kọ́ni.
\v 22 Ẹnu sì ya ìjọ ènìyàn nítorí ìkọ́ni rẹ̀, nítorí pé ó ń kọ́ni bí ẹni tí ó ní àṣẹ, kì í ṣe bí àwọn olùkọ́ òfin ṣe ń kọ́ àwọn ènìyàn.
\v 23 Ní àsìkò náà gan an ni ọkùnrin kan tí ó wà nínú Sinagọgu wọn, tí ó ní ẹ̀mí àìmọ́, bẹ̀rẹ̀ sí í kígbe wí pé,
\v 24 “Kí ni ìwọ ń wá lọ́dọ̀ wa, Jesu ti Nasareti? Ṣé ìwọ wá láti pa wá run ni? Èmí mọ ẹni tí ìwọ í ṣe; Ìwọ ní ẹni Mímọ́ Ọlọ́run!”
\p 
\v 25 Jesu si bá a wí, ó wí pé, \wj “Pa ẹnu rẹ mọ́, kí ó sì jáde kúrò lára rẹ̀.”\wj*
\v 26 Ẹ̀mí àìmọ́ náà sì gbé e ṣánlẹ̀ lógèdèǹgbé, ó ké ní ohùn rara, ó sì jáde kúrò lára ọkùnrin náà.
\p 
\v 27 Ẹnu sì ya àwọn ènìyàn, tó bẹ́ẹ̀ tí wọ́n fi ń sọ láàrín ara wọn ohun tí ó ti ṣẹlẹ̀. Wọ́n béèrè pẹ̀lú ìgbóná ara, pé, “Kí ni èyí? Irú ẹ̀kọ́ tuntun wo ni èyí? Ó ń fi agbára pàṣẹ fún àwọn ẹ̀mí àìmọ́ pàápàá wọ́n sì gbọ́ tirẹ̀.”
\v 28 Ìròyìn nípa rẹ̀ tàn ká gbogbo agbègbè Galili.
\s1 Jesu mú ọ̀pọ̀ ènìyàn láradá
\p 
\v 29 Nígbà tí wọn sì jáde kúrò nínú Sinagọgu, wọ́n lọ pẹ̀lú Jakọbu àti Johanu sí ilé Simoni àti Anderu.
\v 30 Ìyá ìyàwó Simoni tí ó dùbúlẹ̀ àìsàn ibà, wọ́n sì sọ fún Jesu nípa rẹ̀.
\v 31 Ó sì tọ̀ ọ́ lọ, ó fà á lọ́wọ́, ó sì gbé e dìde; lójúkan náà ibà náà fi sílẹ̀, ó sì ń ṣe ìránṣẹ́ fún wọn.
\p 
\v 32 Nígbà tí ó di àṣálẹ́, tí oòrùn wọ̀, wọ́n gbé gbogbo àwọn aláìsàn àti àwọn tó ni ẹ̀mí àìmọ́ tọ̀ ọ́ wá.
\v 33 Gbogbo ìlú si péjọ ni ẹnu-ọ̀nà.
\v 34 Jesu sì wo ọ̀pọ̀ tí wọ́n ní onírúurú ààrùn sàn. Bákan náà ni ó lé ọ̀pọ̀ ẹ̀mí àìmọ́ jáde. Ṣùgbọ́n kò sì jẹ́ kí àwọn ẹ̀mí àìmọ́ náà kí ó sọ̀rọ̀, nítorí tí wọ́n mọ ẹni tí òun í ṣe.
\s1 Jesu ya ara rẹ̀ sọ́tọ̀ láti gbàdúrà
\p 
\v 35 Ní kùtùkùtù òwúrọ̀ ọjọ́ kejì, kí ilẹ̀ tó mọ́, Jesu nìkan jáde lọ sí aginjù kan, láti lọ gbàdúrà.
\v 36 Simoni àti àwọn ènìyàn rẹ̀ yòókù lọ láti wá a.
\v 37 Nígbà tí wọ́n sì rí I, wọ́n sọ fún wí pé, “Gbogbo ènìyàn ń wá ọ!”
\p 
\v 38 Jesu sì dáhùn wí pé, \wj “Ẹ jẹ́ kí a lọ sí àwọn ìlú mìíràn, kí ń lè wàásù níbẹ̀ pẹ̀lú. Nítorí èyí ni èmi sá à ṣe wá.”\wj*
\v 39 Nítorí náà, ó ń kiri gbogbo agbègbè Galili, ó ń wàásù nínú Sinagọgu. Ó sì ń lé àwọn ẹ̀mí àìmọ́ jáde.
\s1 Ọkùnrin tí o ní ààrùn ẹ̀tẹ̀
\p 
\v 40 Ọkùnrin adẹ́tẹ̀ kan tọ̀ ọ́ wá, ó sì kúnlẹ̀ níwájú rẹ̀. Ó sì bẹ̀bẹ̀ fún ìmúláradá. Ó wí pé, “Bí ìwọ bá fẹ́, ìwọ lè mú mi láradá.”
\p 
\v 41 Jesu kún fún àánú, ó na ọwọ́ rẹ̀, ó fi ọwọ́ rẹ̀ bà a, ó wí pé, \wj “Èmí fẹ́. Di mímọ́.”\wj*
\v 42 Lójúkan náà ẹ̀tẹ̀ náà fi sílẹ̀ lọ, ọkùnrin náà sì rí ìwòsàn.
\p 
\v 43 Jesu sì kìlọ̀ fún un gidigidi
\v 44 Ó wí pé, \wj “Lọ fi ara rẹ̀ hàn àlùfáà Júù fún àyẹ̀wò. Ṣùgbọ́n má ṣe dúró sọ ohunkóhun fún ẹnikẹ́ni ní ọ̀nà. Mú ẹ̀bùn lọ́wọ́, èyí tí Mose pàṣẹ fún adẹ́tẹ̀ tí a mú láradá. Èyí tí í ṣe ẹ̀rí pé, ó ti rí ìwòsàn.”\wj*
\v 45 Ṣùgbọ́n ó jáde lọ, ó bẹ̀rẹ̀ sí í pòkìkí, ó ń tan ìròyìn kálẹ̀. Nítorí èyí, Jesu kò sì le wọ ìlú ní gbangba mọ́, ṣùgbọ́n ó wà lẹ́yìn odi ìlú ní aginjù. Síbẹ̀, àwọn ènìyàn tọ̀ ọ́ wá láti ibi gbogbo.
\c 2
\s1 Jesu wo aláàrùn ẹ̀gbà sàn
\p 
\v 1 Lẹ́yìn ọjọ́ mélòó kan, nígbà tí Jesu tún padà wọ Kapernaumu, òkìkí kàn pé ó ti wà nínú ilé.
\v 2 Láìpẹ́, ogunlọ́gọ̀ ènìyàn ti kún ilé tí ó dé sí tó bẹ́ẹ̀ tí inú ilé àti ẹ̀yìn ìlẹ̀kùn ní ìta kò gba ẹyọ ẹnìkan mọ́, ó sì wàásù ọ̀rọ̀ náà sí wọn.
\v 3 Àwọn ọkùnrin kan wá, wọ́n gbé arọ tọ̀ ọ́ wá, ẹni tí ọkùnrin mẹ́rin gbé.
\v 4 Nígbà tí wọn kò sì le dé ọ̀dọ̀ Jesu, nítorí ọ̀pọ̀ ènìyàn, wọ́n dá òrùlé ilé lu ní ọ̀gangan ibi tí Jesu wà. Wọ́n sì sọ ọkùnrin arọ náà kalẹ̀ ti òun ti àkéte rẹ̀ níwájú Jesu.
\v 5 Nígbà tí Jesu sì rí ìgbàgbọ́ wọn, ó sọ fún arọ náà pé, \wj “Ọmọ, a dárí gbogbo ẹ̀ṣẹ̀ rẹ jì ọ́.”\wj*
\p 
\v 6 Ṣùgbọ́n díẹ̀ nínú àwọn olùkọ́ òfin tó jókòó níbẹ̀ sọ fún ara wọn pé,
\v 7 “Èéṣe ti ọkùnrin yìí fi sọ̀rọ̀ báyìí? Ó ń sọ̀rọ̀-òdì. Ta ni ó lè darí ẹ̀ṣẹ̀ ji ni bí ko ṣe Ọlọ́run nìkan?”
\p 
\v 8 Lójúkan náà bí Jesu tí wòye nínú ọkàn rẹ̀ pé wọn ń gbèrò bẹ́ẹ̀ ní àárín ara wọn, ó wí fún wọn pé, \wj “Èéṣe tí ẹ̀yìn fi ń ro nǹkan wọ̀nyí nínú ọkàn yín?\wj*
\v 9 \wj Èwo ni ó rọrùn jù láti wí fún arọ náà pé, ‘A dárí ẹ̀ṣẹ̀ rẹ̀ jì ọ,’ tàbí wí pé, ‘Dìde sì gbé àkéte rẹ, kí o sì máa rìn?’\wj*
\v 10 \wj Ṣùgbọ́n kí ẹ lè mọ̀ pé Ọmọ Ènìyàn ní agbára ní ayé láti dárí ẹ̀ṣẹ̀ rẹ̀ ji ni.”\wj* Ó wí fún ọkùnrin arọ náà pé,
\v 11 \wj “Mo wí fún ọ, dìde, gbé àkéte rẹ kí ó sì máa lọ ilé rẹ.”\wj*
\v 12 Lójúkan náà, ọkùnrin náà fò sókè fún ayọ̀. Ó gbé àkéte rẹ̀. Ó sì jáde lọ lójú gbogbo wọn. Èyí sì ya gbogbo wọn lẹ́nu tó bẹ́ẹ̀ tí wọ́n sì yin Ọlọ́run lógo wí pé, “Àwa kò rí irú èyí rí!”
\s1 Ìpè Lefi
\p 
\v 13 Nígbà náà, Jesu tún jáde lọ sí etí Òkun. Ọ̀pọ̀ ènìyàn sì tọ̀ ọ́ wá, ó sì bẹ̀rẹ̀ sí ní kọ́ wọn.
\v 14 Bí ó ti ń rin etí Òkun lọ sókè, ó rí Lefi ọmọ Alfeu tí ó jókòó nínú àgọ́ níbi tí ó ti ń gba owó orí, Jesu sì wí fún un pé, \wj “Tẹ̀lé mi,”\wj* Lefi dìde, ó sì ń tẹ̀lé e.
\p 
\v 15 Ó sì ṣe, bí ó sì ti jókòó ti oúnjẹ ni ilé Lefi, ọ̀pọ̀ àwọn agbowó òde àti ẹlẹ́ṣẹ̀ wá bá Jesu jókòó pẹ̀lú àwọn ọmọ-ẹ̀yìn rẹ̀, nítorí tiwọn pọ̀ tiwọn tẹ̀lé e.
\v 16 Nígbà tí àwọn olùkọ́ òfin àti àwọn Farisi rí ì tí ó ń bá àwọn agbowó òde àti àwọn ẹlẹ́ṣẹ̀ jẹun, wọn wí fún àwọn ọmọ-ẹ̀yìn rẹ̀ pé, “Èétirí tí ó fi ń bá àwọn agbowó òde àti ẹlẹ́ṣẹ̀ jẹun?”
\p 
\v 17 Nígbà tí Jesu gbọ́, ó sọ fún wọn wí pé, \wj “Àwọn tí ara wọ́n dá kò wa oníṣègùn, bí ko ṣe àwọn tí ara wọn kò dá. Èmi kò wá láti sọ fún àwọn ènìyàn rere láti ronúpìwàdà, bí kò ṣe àwọn ènìyàn ẹlẹ́ṣẹ̀.”\wj*
\s1 Ìbéèrè nípa àwẹ̀ lọ́wọ́ Jesu
\p 
\v 18 Àwọn ọmọ-ẹ̀yìn Johanu àti àwọn Farisi a máa gbààwẹ̀. Àwọn ènìyàn kan sì wá, wọ́n sì bi í pé, “Èéṣe tí àwọn ọmọ-ẹ̀yìn Johanu àti àwọn ọmọ-ẹ̀yìn Farisi fi ń gbààwẹ̀, ṣùgbọ́n àwọn ọmọ-ẹ̀yìn rẹ kò gbààwẹ̀?”
\p 
\v 19 Jesu dáhùn wí pé, \wj “Báwo ni àwọn àlejò ọkọ ìyàwó yóò ṣe máa gbààwẹ̀ nígbà tí ọkọ ìyàwó ṣì wà lọ́dọ̀ wọn?\wj*
\v 20 \wj Ṣùgbọ́n láìpẹ́ ọjọ́, a ó gba ọkọ ìyàwó kúrò lọ́dọ̀ wọn. Nígbà náà wọn yóò gbààwẹ̀ ni ọjọ́ wọ̀nyí.”\wj*
\p 
\v 21 \wj “Kò sí ẹni tí ń fi ìrépé aṣọ tuntun lẹ ògbólógbòó ẹ̀wù, bí ó ba ṣe bẹ́ẹ̀, èyí tuntun tí a fi lẹ̀ ẹ́ yóò fàya kúrò lára ògbólógbòó, yíya rẹ̀ yóò sí burú púpọ̀ jù.\wj*
\v 22 \wj Kò sì sí ẹni tí ń fi ọtí wáìnì tuntun sínú ìgò wáìnì ògbólógbòó. Bí a bá ṣe bẹ́ẹ̀, ọtí wáìnì náà yóò fa ìgò náà ya, ọtí wáìnì a sì dàànù, bákan náà ni ìgò náà, ṣùgbọ́n ọtí wáìnì tuntun ni a n fi sínú ìgò wáìnì tuntun.”\wj*
\s1 Olúwa ọjọ́ ìsinmi
\p 
\v 23 Ó sì ṣe ni ọjọ́ ìsinmi, bí Jesu àti àwọn ọmọ-ẹ̀yìn rẹ̀ ti ń kọjá lọ láàrín oko ọkà, àwọn ọmọ-ẹ̀yìn rẹ̀ bẹ̀rẹ̀ sí í ya ìpẹ́ ọkà.
\v 24 Díẹ̀ nínú àwọn Farisi wí fún Jesu pé, “Wò ó, èéṣe tiwọn fi ń ṣe èyí ti kò yẹ ni ọjọ́ ìsinmi.”
\p 
\v 25 Ó dá wọn lóhùn pé, \wj “Ẹ̀yin kò ti ka ohun tí Dafidi ṣe, nígbà tí ó ṣe aláìní, tí ebi sì ń pa á, òun àti àwọn tí ó wà lọ́dọ̀ rẹ̀?\wj*
\v 26 \wj Bí ó tí wọ ilé Ọlọ́run lọ ni ọjọ́ Abiatari olórí àlùfáà, tí ó sì jẹ àkàrà ìfihàn ti kò tọ́ fún un láti jẹ bí kò ṣe fún àwọn àlùfáà, ó sì tún fi fún àwọn tí ń bẹ lọ́dọ̀ rẹ̀.”\wj*
\p 
\v 27 Ó sì wí fún wọ́n pé, a dá ọjọ́ ìsinmi fún ènìyàn, \wj “Ṣùgbọ́n a kò dá ènìyàn fún ọjọ́ ìsinmi.\wj*
\v 28 \wj Nítorí náà Ọmọ Ènìyàn ni Olúwa ọjọ́ ìsinmi pẹ̀lú.”\wj*
\c 3
\p 
\v 1 Nígbà tí Jesu wá sí Sinagọgu. Sì kíyèsi i ọkùnrin kan wà níbẹ̀, tí ọwọ́ rẹ̀ kan rọ.
\v 2 Àwọn kan nínú wọn sì ń wa ọ̀nà láti fi ẹ̀sùn kan Jesu. Nítorí náà, wọ́n ń ṣọ́ Ọ bí yóò mú un láradá ní ọjọ́ ìsinmi.
\v 3 Jesu wí fún ọkùnrin tí ọwọ́ rẹ̀ rọ náà pé, \wj “Dìde dúró ní iwájú ìjọ ènìyàn.”\wj*
\p 
\v 4 Nígbà náà ni Jesu béèrè lọ́wọ́ wọn pé, \wj “Ǹjẹ́ ó bá òfin mu ní ọjọ́ ìsinmi bóyá láti ṣe rere, tàbí láti ṣe búburú! Láti gbà ẹ̀mí là, tàbí pa á run?”\wj* Ṣùgbọ́n wọ́n dákẹ́ láìfèsì.
\p 
\v 5 Nígbà tí ó sì wo gbogbo wọn yíká pẹ̀lú ìbínú, ọkàn rẹ̀ sì bàjẹ́ nítorí líle àyà wọn, ó sọ fún ọkùnrin náà pé, \wj “Na ọwọ́ rẹ jáde.”\wj* Ó nà án jáde, ọwọ́ náà sì bọ̀ sípò padà pátápátá.
\v 6 Lójúkan náà, àwọn Farisi jáde lọ, láti bá àwọn ọmọ-ẹ̀yìn Herodu gbìmọ̀ pọ̀, bí wọn yóò ṣe pa Jesu.
\s1 Ọ̀pọ̀ ènìyàn tẹ̀lé Jesu
\p 
\v 7 Jesu pẹ̀lú àwọn ọmọ-ẹ̀yìn rẹ̀ yẹra kúrò níbẹ̀ lọ sí etí Òkun. Ọ̀pọ̀lọpọ̀ ènìyàn láti Galili àti Judea sì tọ̀ ọ́ lẹ́yìn.
\v 8 Nígbà tí wọ́n gbọ́ ìròyìn iṣẹ́ ìyanu tí ó ṣe, ọ̀pọ̀ ènìyàn sì tọ̀ ọ́ wá láti Judea, Jerusalẹmu àti Idumea, àti láti apá kejì odò Jordani àti láti ìhà Tire àti Sidoni.
\v 9 Nítorí ọ̀pọ̀ ènìyàn, Jesu sọ fún àwọn ọmọ-ẹ̀yìn rẹ̀ láti ṣètò ọkọ̀ ojú omi kékeré kan sílẹ̀ fún un láti lọ, láti lé àwọn èrò sẹ́yìn.
\v 10 Nítorí tí ó mú ọ̀pọ̀ ènìyàn láradá, ọ̀pọ̀lọpọ̀ àwọn aláìsàn ló bí ara wọn lù ú láti fi ọwọ́ kàn án.
\v 11 Ìgbàkúgbà tí àwọn tí ó ni ẹ̀mí àìmọ́ bá ti fojú ri, wọ́n á wólẹ̀ níwájú rẹ̀. Wọn a sì kígbe lóhùn rara wí pé, “Ìwọ ni Ọmọ Ọlọ́run.”
\v 12 Ṣùgbọ́n ó kìlọ̀ fún wọn gidigidi, kí wọn má ṣe fi òun hàn.
\s1 Jesu yan àwọn aposteli méjìlá
\p 
\v 13 Jesu gun orí òkè lọ, ó sì pe àwọn kan tí ó yàn láti wà pẹ̀lú rẹ̀, wọ́n sì tọ̀ ọ́ wá.
\v 14 Ó yan àwọn méjìlá, kí wọn kí ó lè wà pẹ̀lú rẹ̀, àti kí ó lè rán wọn lọ láti wàásù
\v 15 àti láti lágbára láti lé àwọn ẹ̀mí Èṣù jáde.
\b
\li4 
\v 16 Wọ̀nyí ni àwọn méjìlá náà tí ó yàn:
\b
\li1 Simoni (ẹni ti ó sọ àpèlé rẹ̀ ní Peteru),
\li1 
\v 17 Jakọbu ọmọ Sebede àti Johanu arákùnrin rẹ̀ (àwọn ẹni tí Jesu sọ àpèlé wọ́n ní Boanaji, èyí tí ó túmọ̀ sí “àwọn ọmọ àrá”).
\li1 
\v 18 Àti Anderu,
\li1 Filipi,
\li1 Bartolomeu,
\li1 Matiu,
\li1 Tomasi,
\li1 Jakọbu ọmọ Alfeu,
\li1 Taddeu,
\li1 Simoni tí ń jẹ́ Sealoti \f + \fr 3:18 \ft Ọ̀kan nínú àwọn ẹgbẹ́ tí o ń ja fun òmìnira àwọn Júù, \f*
\li1 
\v 19 àti Judasi Iskariotu, ẹni tí ó fi í hàn níkẹyìn.
\s1 Jesu àti Beelsebulu
\p 
\v 20 Nígbà náà ni Jesu sì wọ inú ilé kan, àwọn èrò sì tún kórajọ, tó bẹ́ẹ̀ tí Òun àti àwọn ọmọ-ẹ̀yìn rẹ̀ kò rí ààyè láti jẹun.
\v 21 Nígbà tí àwọn ẹbí rẹ̀ gbọ́ èyí, wọ́n wá láti mú un lọ ilé, nítorí tí wọn wí pé, “Orí rẹ̀ ti dàrú.”
\p 
\v 22 Àwọn olùkọ́ni ní òfin sọ̀kalẹ̀ wá láti Jerusalẹmu, wọ́n sì wí pé, “Ó ni Beelsebulu, olórí àwọn ẹ̀mí èṣù, ni ó sì fi ń lé àwọn ẹ̀mí èṣù jáde!”
\p 
\v 23 Jesu pè wọ́n, ó sì fi òwe bá wọn sọ̀rọ̀: \wj “Báwo ni Èṣù ṣe lè lé èṣù jáde?\wj*
\v 24 \wj Bí ìjọba kan bá yapa sí ara rẹ̀, ìjọba náà yóò wó lulẹ̀.\wj*
\v 25 \wj Bákan náà, bí ilé kan bá sì yapa sí ara rẹ, ilé náà kí yóò le è dúró.\wj*
\v 26 \wj Bí Èṣù bá sì dìde sí ara rẹ̀, tí ó sì yapa, òun kí yóò le è dúró ṣùgbọ́n òpin rẹ̀ yóò dé.\wj*
\v 27 \wj Kò sí ẹni tí ó le wọ ilé ọkùnrin alágbára kan lọ, kí ó sì kó o ní ẹrù lọ, bí kò ṣe pé ó kọ́kọ́ de ọkùnrin alágbára náà ní okùn, nígbà náà ni yóò lè kó ẹrù ní ilé rẹ̀.\wj*
\v 28 \wj Lóòótọ́ ní mo wí fún yín, gbogbo ẹ̀ṣẹ̀ ni a ó dáríjì àwọn ọmọ ènìyàn, àti gbogbo ọ̀rọ̀-òdì.\wj*
\v 29 \wj Ṣùgbọ́n ẹni tí ó bá sọ̀rọ̀-òdì sí Ẹ̀mí Mímọ́, kì yóò rí ìdáríjì títí ayé, ṣùgbọ́n ó wà nínú ewu ẹ̀bi àìnípẹ̀kun.”\wj*
\p 
\v 30 Òun sọ eléyìí fún wọn, nítorí tí wọ́n sọ pé, “Nípa agbára ẹ̀mí àìmọ́ ló ń ṣe àwọn iṣẹ́ ìyanu rẹ̀.”
\s1 Ìyá àti àwọn Arákùnrin Jesu
\p 
\v 31 Nígbà náà ni àwọn arákùnrin rẹ̀ àti ìyá wá, wọ́n dúró lóde, wọ́n sì ránṣẹ́ sí i, wọ́n ń pè é.
\v 32 Àwọn ènìyàn tí wọ́n jókòó lọ́dọ̀ rẹ̀ sì wí fún un pé, “Ìyá àti àwọn arákùnrin rẹ wà lóde.”
\p 
\v 33 Ṣùgbọ́n ó dá wọn lóhùn wí pé, \wj “Ta ni í ṣe ìyá mi tàbí àwọn arákùnrin mi?”\wj*
\p 
\v 34 Ó sì wò gbogbo àwọn tí ó jókòó lọ́dọ̀ rẹ̀ yíká, ó sì wí pé, \wj “Àwọn wọ̀nyí ni ìyá mi àti àwọn arákùnrin mi.\wj*
\v 35 \wj Nítorí ẹnikẹ́ni tí ó bá ń ṣe ìfẹ́ Ọlọ́run, òun ni arákùnrin mi àti arábìnrin mi àti ìyá mi.”\wj*
\c 4
\s1 Òwe afúnrúgbìn
\p 
\v 1 Jesu sì tún bẹ̀rẹ̀ sí ń kọ́ni létí Òkun, àwọn ìjọ ènìyàn tí ó yí i ká pọ̀ jọjọ tó bẹ́ẹ̀ tí ó fi bọ́ sínú ọkọ̀ ojú omi, tí ó sì jókòó nínú rẹ̀ lẹ́gbẹ̀ẹ́ Òkun, nígbà tí àwọn ènìyàn sì wà ní ilẹ̀ létí Òkun.
\v 2 Ó bẹ̀rẹ̀ sí í fi òwe bá wọn sọ̀rọ̀ nínú ẹ̀kọ́ rẹ̀ pé,
\v 3 \wj “Ẹ fi etí sílẹ̀! Ní ọjọ́ kan, afúnrúgbìn kan jáde lọ láti lọ fúnrúgbìn rẹ̀.\wj*
\v 4 \wj Bí ó ti ń fúnrúgbìn, díẹ̀ bọ́ sí ẹ̀bá ọ̀nà, àwọn ẹyẹ sì wá, wọ́n sì ṣà á jẹ.\wj*
\v 5 \wj Díẹ̀ bọ́ sórí ilẹ̀ àpáta, níbi tí erùpẹ̀ ko sí púpọ̀. Láìpẹ́ ọjọ́, ó hu jáde.\wj*
\v 6 \wj Ṣùgbọ́n nígbà tí oòrùn mú gangan, ó jóná, nítorí tí kò ní gbòǹgbò, ó gbẹ.\wj*
\v 7 \wj Àwọn irúgbìn mìíràn sì bọ́ sáàrín ẹ̀gún, nígbà tí ẹ̀gún sì dàgbàsókè, ó fún wọn pa, tó bẹ́ẹ̀ tí àwọn irúgbìn náà kò le so èso.\wj*
\v 8 \wj Ṣùgbọ́n òmíràn bọ́ sí ilẹ̀ ọlọ́ràá, o sì so èso lọ́pọ̀lọ́pọ̀, òmíràn ọgbọọgbọ̀n, òmíràn ọgọọgọ́ta, àti òmíràn ọgọọgọ́rùn-ún.”\wj*
\p 
\v 9 Jesu sì wí pé, \wj “Ẹni tí ó bá ní etí láti fi gbọ́, kí ó gbọ́.”\wj*
\p 
\v 10 Nígbà tí ó ku òun nìkan pẹ̀lú àwọn ọmọ-ẹ̀yìn méjìlá àti àwọn mìíràn, wọ́n bi í léèrè wí pé, “Kí ni ìtumọ̀ òwe rẹ̀?”
\v 11 Ó sì dá wọn lóhùn pé, \wj “Ẹ̀yin ni a gbà láààyè láti mọ ohun ìjìnlẹ̀ nípa ìjọba Ọlọ́run. Èyí tí ó pamọ́ sí àwọn tí ó wà lẹ́yìn agbo ìjọba náà.\wj*
\v 12 \wj Bí ó tilẹ̀ jẹ́ wí pé,\wj*
\q1 \wj “ ‘wọn yóò rí i, wọn yóò sì gbọ́, kì yóò yé wọn,\wj*
\q2 \wj bẹ́ẹ̀ ni wọn kì yóò sì yípadà sí Ọlọ́run.\wj*
\q1 \wj Tàbí kí a dárí ẹ̀ṣẹ̀ jì wọ́n!’ ”\wj*
\p 
\v 13 Ṣùgbọ́n Jesu wí fún wọn pé, \wj “Bí òwe tí ó rọrùn yìí kò bá yé e yín? Báwo ni ẹ̀yin yóò ṣe mọ ìtumọ̀ àwọn mìíràn tí mo ń sọ fún un yín?\wj*
\v 14 \wj Afúnrúgbìn ń fúnrúgbìn ọ̀rọ̀ náà.\wj*
\v 15 \wj Àwọn èso tó bọ́ sí ojú ọ̀nà, ni àwọn ọlọ́kàn líle tí wọ́n gbọ́ ọ̀rọ̀ Ọlọ́run, lójúkan náà èṣù wá ó sì mú kí wọn gbàgbé ohun tí wọ́n ti gbọ́.\wj*
\v 16 \wj Bákan náà, àwọn tí ó bọ́ sórí àpáta, ni àwọn ènìyàn tí wọ́n fi ayọ̀ gbọ́ ọ̀rọ̀ Ọlọ́run.\wj*
\v 17 \wj Ṣùgbọ́n kò ni gbòǹgbò tí ó jinlẹ̀ ní ọkàn wọn. Ṣùgbọ́n wọ́n á wà fún ìgbà díẹ̀, lẹ́yìn náà nígbà ti wàhálà tàbí inúnibíni bá dìde nítorí ọ̀rọ̀ náà, lójúkan náà, wọ́n á kọsẹ̀.\wj*
\v 18 \wj Àwọn tí ó bọ́ sáàrín ẹ̀gún ni àwọn tí ó gbọ́ ọ̀rọ̀ náà, tí wọn sì gbà á.\wj*
\v 19 \wj Ṣùgbọ́n láìpẹ́ jọjọ, àwọn adùn ayé àti inú dídùn, ọrọ̀ àti ìjàkadì fún àṣeyọrí àti ìfẹ́ àwọn ohun mèremère ayé, gba ọkàn wọn, wọ́n sì fún ọ̀rọ̀ náà pa ní ọkàn wọn. Ọ̀rọ̀ náà sì jẹ́ aláìléso.\wj*
\v 20 \wj Ṣùgbọ́n àwọn tí ó bọ́ sí ilẹ̀ ọlọ́ràá, ní àwọn tí ó gbọ́ ọ̀rọ̀ Ọlọ́run tí wọ́n sì gbà á lóòtítọ́, wọ́n sì mú èso púpọ̀ jáde fún Ọlọ́run ní ọgbọọgbọ̀n, ọgọọgọ́ta, àti òmíràn ọgọọgọ́rùn-ún, gẹ́gẹ́ bí a ti gbìn ín sí ọkàn wọn.”\wj*
\s1 Àtùpà lórí ọ̀pá fìtílà
\p 
\v 21 Ó sì wí fún wọn pé, \wj “A ha lè gbé fìtílà wá láti fi sábẹ́ òsùwọ̀n tàbí sábẹ́ àkéte? Rárá o, ki a ṣe pe a o gbé e ka orí ọ̀pá fìtílà?\wj*
\v 22 \wj Gbogbo ohun tí ó pamọ́ nísinsin yìí yóò hàn ní gbangba ní ọjọ́ kan, bẹ́ẹ̀ ni kò sí ohun tí ó wà ní ìkọ̀kọ̀, bí kò ṣe pé kí ó le yọ sí gbangba.\wj*
\v 23 \wj Bí ẹnikẹ́ni bá ní etí láti fi gbọ́, kí ó gbọ́.”\wj*
\p 
\v 24 Ó sì tún tẹ̀síwájú pé, \wj “Ẹ máa kíyèsi ohun tí ẹ bà gbọ́ dáradára, nítorí òsùwọ̀n tí ẹ̀yin bá fi wọ́n náà ni a ó fi wọ́n fún un yín àti jù bẹ́ẹ̀ lọ.\wj*
\v 25 \wj Nítorí ẹni tí ó bá ní, òun ni a ó tún fi fún sí i àti lọ́wọ́ ẹni tí kò bá ní, ni a ó ti gba èyí náà tí ó ní.”\wj*
\s1 Òwe irúgbìn tó ń dàgbà
\p 
\v 26 Ó sì tún sọ èyí pé, \wj “Èyí ni a lè fi ìjọba Ọlọ́run wé. Ọkùnrin kan ń fúnrúgbìn sí ilẹ̀.\wj*
\v 27 \wj Lóru àti ní ọ̀sán, bóyá ó sùn tàbí ó dìde, irúgbìn náà hu jáde, ó sì dàgbà, òun kò sì mọ̀ bí ó ti ṣẹlẹ̀.\wj*
\v 28 \wj Nítorí tí ilẹ̀ kọ́kọ́ hù èso jáde fún ara rẹ̀, ó mú èéhù ewé jáde, èyí tí ó tẹ̀lé e ní orí ọkà, ní ìparí, ọkà náà gbó.\wj*
\v 29 \wj Nígbà tí èso bá gbó tán, lẹ́sẹ̀kẹsẹ̀, òun a tẹ dòjé bọ inú ọkà náà, ó sì kórè rẹ̀.”\wj*
\s1 Òwe musitadi
\p 
\v 30 Jesu sì tún wí pé, \wj “Kí ni kí èmi fi ìjọba Ọlọ́run wé? Òwe wo ni kí èmi fi ṣe àkàwé rẹ̀?\wj*
\v 31 \wj Ó dàbí èso hóró musitadi kan, lóòótọ́, ó jọ ọ̀kan nínú àwọn èso tí ó kéré jùlọ ti a gbìn sínú ilẹ̀.\wj*
\v 32 \wj Síbẹ̀, nígbà tí a gbìn ín, ó dàgbàsókè, ó gbilẹ̀, ó sì di títóbi ju gbogbo ewéko inú ọgbà yòókù lọ. Ó sì yọ ẹ̀ka ńlá níbi tí àwọn ẹyẹ ọ̀run lè kọ́ ìtẹ́ wọn sí, kí wọn sì rí ìdáàbòbò.”\wj*
\p 
\v 33 Òun lo ọ̀pọ̀ irú òwe wọ̀nyí láti fi kọ́ àwọn ènìyàn, gẹ́gẹ́ bí wọ́n bá ti ń fẹ́ láti ní òye tó.
\v 34 Kìkì òwe ni Jesu fi ń kọ́ àwọn ènìyàn ní ẹ̀kọ́ ìta gbangba rẹ̀. Ṣùgbọ́n lẹ́yìn èyí, nígbà tí ó bá sì wà pẹ̀lú àwọn ọmọ-ẹ̀yìn rẹ̀, òun a sì sọ ìtumọ̀ ohun gbogbo.
\s1 Jesu mú afẹ́fẹ́ okun dákẹ́ jẹ́ẹ́
\p 
\v 35 Nígbà tí alẹ́ lẹ́, Jesu wí fún àwọn ọmọ-ẹ̀yìn rẹ̀ pé, \wj “Ẹ jẹ́ kí a rékọjá sí apá kejì.”\wj*
\v 36 Nígbà tí wọn ti tú ìjọ ká, wọ́n sì gbà á sínú ọkọ̀ ojú omi gẹ́gẹ́ bí ó ti wà. Àwọn ọkọ̀ ojú omi kékeré mìíràn sì wà lọ́dọ̀ rẹ̀.
\v 37 Ìjì líle ńlá kan sì dìde, omi sì ń bù sínú ọkọ̀, tó bẹ́ẹ̀ tí ọkọ̀ fi bẹ̀rẹ̀ sí í kún fún omi, ó sì fẹ́rẹ rì.
\v 38 Jesu ti sùn lọ lẹ́yìn ọkọ̀, ó gbé orí lé ìrọ̀rí. Wọ́n sì jí i lóhùn rara wí pé, “Olùkọ́ni, tàbí ìwọ kò tilẹ̀ bìkítà pé gbogbo wa fẹ́ rì?”
\p 
\v 39 Ó dìde, ó bá ìjì líle náà wí, ó sì wí fún òkun pé, \wj “Dákẹ́! Jẹ́ẹ́!”\wj* Ìjì náà sì dá, ìparọ́rọ́ ńlá sì wà.
\p 
\v 40 Lẹ́yìn náà, ó béèrè lọ́wọ́ àwọn ọmọ-ẹ̀yìn rẹ̀ pé, \wj “Èéṣe tí ẹ̀yin fi ń ṣojo bẹ́ẹ̀? Tàbí ẹ̀yin kò ì tí ì ní ìgbàgbọ́ síbẹ̀síbẹ̀?”\wj*
\p 
\v 41 Ẹ̀rù bà wọ́n gidigidi, wọ́n sì wí fún ara wọn pé, “Irú ọkùnrin wo ni èyí, tí ìjì àti Òkun ń gbọ́ tirẹ̀!”
\c 5
\s1 Ìwòsàn ọkùnrin ẹlẹ́mìí èṣù
\p 
\v 1 Wọ́n lọ sí apá kejì adágún ní ẹ̀bá ilẹ̀ àwọn ará Gadara.
\v 2 Bí Jesu sì ti ń ti inú ọkọ̀ ojú omi jáde. Ọkùnrin kan tí ó ní ẹ̀mí àìmọ́ jáde ti ibojì wá pàdé rẹ̀.
\v 3 Ọkùnrin yìí ń gbé nínú ibojì, kò sí ẹni tí ó lè dè é mọ́, kódà ẹ̀wọ̀n kò le dè é.
\v 4 Nítorí pé nígbà púpọ̀ ni wọ́n ti ń fi ṣẹ́kẹ́ṣẹkẹ̀ dè é lọ́wọ́ àti ẹsẹ̀, tí ó sì ń já a dànù kúrò ni ẹsẹ̀ rẹ̀. Kò sí ẹnìkan tí ó ní agbára láti káwọ́ rẹ̀.
\v 5 Tọ̀sán tòru láàrín àwọn ibojì àti ní àwọn òkè ni ó máa ń kígbe rara tí ó sì ń fi òkúta ya ara rẹ̀.
\p 
\v 6 Nígbà tí ó sì rí Jesu látòkèrè, ó sì sáré lọ láti pàdé rẹ̀. Ó sì wólẹ̀ níwájú rẹ̀.
\v 7 Ó sì kígbe ní ohùn rara wí pé, “Kí ní ṣe tèmi tìrẹ, Jesu Ọmọ Ọlọ́run Ọ̀gá-ògo? Mo fi Ọlọ́run bẹ̀ ọ́ má ṣe dá mi lóró.”
\v 8 Nítorí tí Ó wí fún un pé, \wj “Jáde kúrò lára ọkùnrin náà, ìwọ ẹ̀mí àìmọ́!”\wj*
\p 
\v 9 Jesu sì bi í léèrè pé, \wj “Kí ni orúkọ rẹ?”\wj*
\p Ẹ̀mí àìmọ́ náà sì dáhùn wí pé, “Ligioni, nítorí àwa pọ̀.”
\v 10 Nígbà náà ni ẹ̀mí àìmọ́ náà bẹ̀rẹ̀ sí í bẹ Jesu gidigidi, kí ó má ṣe rán àwọn jáde kúrò ní agbègbè náà.
\p 
\v 11 Agbo ẹlẹ́dẹ̀ ńlá kan sì ń jẹ lẹ́bàá òkè.
\v 12 Àwọn ẹ̀mí àìmọ́ náà bẹ Jesu pé, “Rán wa lọ sínú àwọn ẹlẹ́dẹ̀ wọ̀n-ọn-nì kí àwa le è wọ inú wọn lọ.”
\v 13 Jesu fún wọn láààyè, àwọn ẹ̀mí àìmọ́ náà sì jáde kúrò lára ọkùnrin náà, wọ́n sì wọ inú àwọn ẹlẹ́dẹ̀ náà lọ. Agbo ẹlẹ́dẹ̀ náà tí ó tó ìwọ̀n ẹgbẹ̀rún méjì (2,000) sì túká lọ́gán, wọ́n sì sáré lọ ní gẹ̀rẹ́gẹ̀rẹ́ òkè rọ́ sínú Òkun, wọ́n sì ṣègbé.
\p 
\v 14 Àwọn olùtọ́jú ẹran wọ̀nyí sì sálọ sí àwọn ìlú ńlá àti ìlú kéékèèké, wọ́n sì ń tan ìròyìn náà ká bí wọ́n ti ń sáré. Àwọn ènìyàn sì tú jáde láti fojú gán-án-ní ohun náà tí ó ṣẹlẹ̀.
\v 15 Nígbà tí wọ́n péjọ sọ́dọ̀ Jesu, wọ́n rí ọkùnrin náà, ẹni tí ó ní ẹ̀mí èṣù, tí ó jókòó níbẹ̀, ó wọ aṣọ ìyè rẹ sì bọ̀ sípò, ẹ̀rù sì bà wọ́n.
\v 16 Àwọn tí ìṣẹ̀lẹ̀ yìí ṣojú wọn sì ń ròyìn rẹ̀ fún àwọn ènìyàn ohun tí ó ṣẹlẹ̀ sí ọkùnrin ẹlẹ́mìí àìmọ́, wọ́n si sọ nípa agbo ẹlẹ́dẹ̀ náà pẹ̀lú.
\v 17 Nígbà náà, àwọn èrò bẹ̀rẹ̀ sí ní bẹ Jesu pé kí ó fi agbègbè àwọn sílẹ̀.
\p 
\v 18 Bí Jesu ti ń wọ inú ọkọ̀ ojú omi lọ, ọkùnrin náà tí ó ti ní ẹ̀mí àìmọ́ tẹ́lẹ̀ bẹ̀ Ẹ́ pé kí òun lè bá a lọ.
\v 19 Jesu kò gbà fún un, ṣùgbọ́n ó wí fún un pé, \wj “Lọ sí ilé sí ọ̀dọ̀ àwọn ẹbí rẹ, kí o sì sọ fún wọn bí Ọlọ́run ti ṣe ohun ńlá fún ọ, àti bí ó sì ti ṣàánú fún ọ.”\wj*
\v 20 Nítorí náà, ọkùnrin yìí padà lọ, ó bẹ̀rẹ̀ sí ròyìn ní Dekapoli nípa ohun ńlá tí Jesu ṣe fún un. Ẹnu sì ya gbogbo ènìyàn.
\s1 Òkú ọmọbìnrin kan àti obìnrin aláìsàn
\p 
\v 21 Nígbà tí Jesu sì ti inú ọkọ̀ rékọjá sí apá kejì Òkun, ọ̀pọ̀ ìjọ ènìyàn péjọ yí i ká ní etí Òkun.
\v 22 Ọ̀kan nínú àwọn olórí Sinagọgu tí à ń pè ni Jairu wá sọ́dọ̀ Jesu, nígbà tí ó sì rí i, ó wólẹ̀ níwájú rẹ̀.
\v 23 Ó sì bẹ̀ ẹ́ gidigidi pé, “Ọmọbìnrin mi wà lójú ikú, mo bẹ̀ ọ́, wá fi ọwọ́ rẹ lé e, kí ara rẹ̀ lè dá, kí ó sì yè.”
\v 24 Jesu sì ń bá a lọ.
\p Ọ̀pọ̀ ìjọ ènìyàn sì ń tọ̀ Ọ́ lẹ́yìn.
\v 25 Obìnrin kan sì wà láàrín ọ̀pọ̀ ènìyàn náà, tí ó ti ní ìsun ẹ̀jẹ̀ fún odidi ọdún méjìlá.
\v 26 Ẹni tí ojú rẹ̀ sì ti rí ọ̀pọ̀lọpọ̀ ìpọ́njú lọ́dọ̀ ọ̀pọ̀ àwọn oníṣègùn, tí ó sì ti ná gbogbo ohun tí ó ní, síbẹ̀ kàkà kí ó san, ó ń burú sí i.
\v 27 Nígbà tí ó sì gbúròó iṣẹ́ ìyanu tí Jesu ṣe, ìdí nìyìí tí ó fi wá sẹ́yìn rẹ̀, láàrín ọ̀pọ̀ ènìyàn, ó sì fọwọ́ kan aṣọ rẹ̀.
\v 28 Nítorí ti ó rò ní ọkàn rẹ̀ pé, “Bí mo bá sá à lè fi ọwọ́ kan aṣọ rẹ̀, ara mi yóò dá.”
\v 29 Ìsun ẹ̀jẹ̀ rẹ̀ sì gbẹ lẹ́sẹ̀kẹsẹ̀, òun sì mọ̀ lára rẹ̀ pé, a mú òun láradá kúrò nínú ààrùn náà.
\p 
\v 30 Lọ́gán, Jesu sì mọ̀ nínú ara rẹ̀ pé agbára jáde lára òun. Ó yípadà láàrín ọ̀pọ̀ ènìyàn, ó sì béèrè, \wj “Ta ni ó fi ọwọ́ kan aṣọ mi?”\wj*
\p 
\v 31 Àwọn ọmọ-ẹ̀yìn rẹ̀ wí fún un pé, “Ìwọ rí ọ̀pọ̀ ènìyàn tí ó rọ̀gbà yí ọ ká, ìwọ sì tún ń béèrè ẹni tí ó fi ọwọ́ kàn ọ́?”
\p 
\v 32 Síbẹ̀, Jesu bẹ̀rẹ̀ sí wò yíká láti rí ẹni náà, tí ó fi ọwọ́ kan òun.
\v 33 Nígbà náà, obìnrin náà kún fún ìbẹ̀rù àti ìwárìrì nítorí ó ti mọ ohun tí ó ṣẹlẹ̀ lára òun. Ó sì kúnlẹ̀ níwájú rẹ̀, ó sì sọ gbogbo òtítọ́ fún un.
\v 34 Jesu sì wí fún un pé, \wj “Ọmọbìnrin, ìgbàgbọ́ rẹ mú ọ láradá. Máa lọ ní àlàáfíà, ìwọ sì ti sàn nínú ààrùn rẹ.”\wj*
\p 
\v 35 Bí Jesu sì ti ń ba obìnrin náà sọ̀rọ̀, àwọn ìránṣẹ́ dé láti ilé Jairu olórí Sinagọgu wá, wọ́n wí fún un pé, ọmọbìnrin rẹ ti kú, àti pé kí wọn má ṣe yọ Jesu lẹ́nu láti wá, nítorí ó ti pẹ́ jù.
\p 
\v 36 Ṣùgbọ́n bi Jesu ti gbọ́ ọ̀rọ̀ náà, ó wí fún Jairu pé, \wj “Má bẹ̀rù, sá à gbàgbọ́ nìkan.”\wj*
\p 
\v 37 Nígbà náà, Jesu dá ọ̀pọ̀ ènìyàn náà dúró. Kò sì jẹ́ kí ẹnikẹ́ni tẹ̀lé òun lẹ́yìn lọ ilé Jairu, bí kò ṣe Peteru, Jakọbu àti Johanu arákùnrin Jakọbu.
\v 38 Nígbà tí wọ́n dé ibẹ̀, Jesu rí i pé gbogbo nǹkan ti dàrú. Ilé kún fún àwọn tí ń sọkún, àti àwọn tí ń pohùnréré ẹkún.
\v 39 Ó wọ inú ilé lọ, o sì bá àwọn ènìyàn sọ̀rọ̀, ó béèrè pé, \wj “Èéṣe tí ẹ̀yin fi ń sọkún tí ẹ sì ń pohùnréré ẹkún? Ọmọbìnrin náà kò kú, ó sùn lásán ni.”\wj*
\v 40 Wọ́n sì fi í rẹ́rìn-ín.
\p Ṣùgbọ́n ó sọ fún gbogbo wọn láti bọ́ síta, ó mú baba àti ìyá ọmọ náà, àti àwọn ọmọ-ẹ̀yìn rẹ̀ mẹ́ta. Ó sì wọ inú yàrá tí ọmọbìnrin náà gbé dùbúlẹ̀ sí.
\v 41 Ó gbá a ní ọwọ́ mú, ó sì wí pé, \wj “Talita kuumi”\wj* (tí ó túmọ̀ sí \wj “Ọmọdébìnrin, dìde dúró!”\wj*).
\v 42 Lẹ́sẹ̀kan náà, ọmọbìnrin náà sì dìde. Ó sì ń rìn, ẹ̀rù sì bà wọ́n, ẹnu sì ya àwọn òbí rẹ̀ gidigidi.
\v 43 Jesu sì kìlọ̀ fún wọn gidigidi pé kí wọn má ṣe sọ ohun tí ó ti ṣẹlẹ̀. Ó sì wí fún wọn kí wọn fún ọmọbìnrin náà ní oúnjẹ.
\c 6
\s1 Wòlíì tí kò ní ọlá
\p 
\v 1 Jesu fi ibẹ̀ sílẹ̀ lọ sí ìlú rẹ̀ pẹ̀lú àwọn ọmọ-ẹ̀yìn rẹ̀.
\v 2 Nígbà tí ó di ọjọ́ ìsinmi, ó lọ sí Sinagọgu láti kọ́ àwọn ènìyàn, ẹnu sì ya àwọn ènìyàn púpọ̀ tí ó gbọ́.
\p Wọ́n wí pé, “Níbo ni ọkùnrin yìí gbé ti rí nǹkan wọ̀nyí? Irú ọgbọ́n kí ni èyí tí a fi fún un, tí irú iṣẹ́ ìyanu báyìí ń ti ọwọ́ rẹ̀ ṣe?
\v 3 Gbẹ́nàgbẹ́nà náà kọ́ yìí? Ọmọ Maria àti arákùnrin Jakọbu àti Josẹfu, Judasi àti Simoni? Àwọn arábìnrin rẹ̀ gbogbo ha kọ́ ni ó ń bá wa gbé níhìn-ín yìí?” Wọ́n sì kọsẹ̀ lára rẹ̀.
\p 
\v 4 Nígbà náà, Jesu wí fún wọn pé, \wj “A máa ń bu ọlá fún wòlíì níbi gbogbo àfi ní ìlú ara rẹ̀ àti láàrín àwọn ìdílé àti àwọn ẹbí òun pàápàá.”\wj*
\v 5 Nítorí àìgbàgbọ́ wọn, òun kò lè ṣe iṣẹ́ ìyanu ńlá láàrín wọn, àfi àwọn aláìsàn díẹ̀ tí ó gbé ọwọ́ lé lórí, tí wọ́n sì rí ìwòsàn.
\s1 Jesu rán ọmọ-ẹ̀yìn méjìlá jáde
\p 
\v 6 Ẹnu si yà á nítorí àìgbàgbọ́ wọn. Lẹ́yìn náà, Jesu lọ sí àárín àwọn ìletò kéékèèké, ó sì ń kọ́ wọn.
\v 7 Ó sì pe àwọn méjìlá náà sọ́dọ̀ rẹ̀, ó bẹ̀rẹ̀ sí rán wọn lọ ní méjì méjì, Ó sì fi àṣẹ fún wọn lórí ẹ̀mí àìmọ́.
\p 
\v 8 O sọ fún wọn pé, wọn kò gbọdọ̀ mú ohunkóhun lọ́wọ́, àfi ọ̀pá ìtìlẹ̀ wọn. Wọn kò gbọdọ̀ mú oúnjẹ, àpò ìgbànú, tàbí owó lọ́wọ́.
\v 9 Wọn kò tilẹ̀ gbọdọ̀ mú ìpààrọ̀ bàtà tàbí aṣọ lọ́wọ́.
\v 10 Jesu wí pé, \wj “Ẹ dúró sí ilé kan ní ìletò kan. Ẹ má ṣe sípò padà láti ilé dé ilé, nígbà tí ẹ bá wà ní ìlú náà.\wj*
\v 11 \wj Ẹnikẹ́ni tí kò bá sì gbà yín, tí kò sì gbọ́rọ̀ yín, nígbà tí ẹ̀yin bá jáde kúrò níbẹ̀, ẹ gbọn eruku ẹsẹ̀ yín síbẹ̀ fún ẹ̀rí fún wọn.”\wj*
\p 
\v 12 Wọ́n jáde lọ láti wàásù ìrònúpìwàdà fún àwọn ènìyàn.
\v 13 Wọ́n lé ọ̀pọ̀lọpọ̀ àwọn ẹ̀mí àìmọ́ jáde. Wọ́n sì ń fi òróró kun orí àwọn tí ara wọn kò dá, wọ́n sì mú wọn láradá.
\s1 A bẹ́ Johanu onítẹ̀bọmi lórí
\p 
\v 14 Láìpẹ́, ọba Herodu gbọ́ nípa Jesu, nítorí níbi gbogbo ni a ti ń sọ̀rọ̀ iṣẹ́ ìyanu rẹ̀. Ọba náà rò pé, “Johanu Onítẹ̀bọmi jíǹde kúrò nínú òkú, nítorí náà ni iṣẹ́ ìyanu ṣe ń ṣe láti ọwọ́ rẹ.”
\p 
\v 15 Àwọn mìíràn wí pé, “Elijah ní.”
\p Àwọn mìíràn wí pé, “Wòlíì bí ọ̀kan lára àwọn àtijọ́ tó ti kú ló tún padà sáyé.”
\p 
\v 16 Ṣùgbọ́n nígbà tí Herodu gbọ́ èyí, ó wí pé “Johanu tí mo tí bẹ́ lórí ni ó ti jíǹde kúrò nínú òkú.”
\p 
\v 17 Herodu fúnra rẹ̀ sá ti ránṣẹ́ mú Johanu, tìkára rẹ̀ sínú túbú nítorí Herodia aya Filipi arákùnrin rẹ̀ nítorí tí ó fi ṣe aya.
\v 18 Johanu sì ti wí fún Herodu pé, “Kò tọ́ sí ọ láti fi ìyàwó arákùnrin rẹ ṣe aya.”
\v 19 Nítorí náà ni Herodia ṣe ní sínú, òun sì fẹ́ pa á, ṣùgbọ́n kò le ṣe é.
\v 20 Nítorí Herodu bẹ̀rù Johanu, ó sì mọ̀ ọ́n ni olóòtítọ́ ènìyàn àti ẹni mímọ́, ó sì ń tọ́jú rẹ̀. Nígbà tí Herodu ba gbọ́rọ̀ Johanu, ó máa ń dààmú síbẹ̀, ó sì fi ayọ̀ gbọ́rọ̀ rẹ̀.
\p 
\v 21 Níkẹyìn Herodia rí ààyè. Àkókò yìí ni ọjọ́ ìbí Herodu, òun sì pèsè àsè ní ààfin ọba fún àwọn olùrànlọ́wọ́ rẹ̀: àwọn balógun àti àwọn ènìyàn pàtàkì ní Galili.
\v 22 Nígbà náà, ni ọmọbìnrin Herodia wọlé láti jó. Inú Herodu àti àwọn àlejò rẹ̀ dùn tó bẹ́ẹ̀.
\p Ọba sọ fún ọmọbìnrin náà pé, “Béèrè ohunkóhun tí ìwọ bá fẹ́ lọ́wọ́ mi, èmi ó sì fi fún ọ.”
\v 23 Ó sì búra fún un wí pé, “Ohunkóhun tí ìwọ bá fẹ́, ìbá à ṣe ìdajì ìjọba mi ni, èmi yóò fi fún ọ.”
\p 
\v 24 Ó jáde lọ sọ fún ìyá rẹ̀ pé, “Kí ní kí ń béèrè?”
\p Ó dáhùn pé, “Orí Johanu Onítẹ̀bọmi.”
\p 
\v 25 Ọmọbìnrin yìí sáré padà wá sọ́dọ̀ Herodu ọba. Ó sì wí fún un pé, “Mo ń fẹ́ orí Johanu Onítẹ̀bọmi nísinsin yìí nínú àwopọ̀kọ́.”
\p 
\v 26 Inú ọba sì bàjẹ́ gidigidi, ṣùgbọ́n nítorí àwọn ìbúra rẹ, àti nítorí àwọn tí ó bá a jókòó pọ̀, kò sì fẹ́ kọ̀ fún un.
\v 27 Nítorí èyí, ọba rán ẹ̀ṣọ́ kan, ó fi àṣẹ fún un pé, kí ó gbé orí Johanu wá. Ọkùnrin náà sì lọ, ó bẹ́ Johanu lórí nínú túbú.
\v 28 Ó sì gbé orí Johanu wa nínú àwopọ̀kọ́. Ó sì gbé e fún ọmọbìnrin náà. Òun sì gbé e tọ ìyá rẹ̀ lọ.
\v 29 Nígbà tí àwọn ọmọ-ẹ̀yìn Johanu gbọ́, wọ́n wá gbé òkú rẹ̀, wọ́n sì lọ tẹ́ ẹ sínú ibojì.
\s1 Jesu bọ́ ẹgbẹ̀rún márùn-ún (5,000) ènìyàn
\p 
\v 30 Àwọn aposteli kó ara wọn jọ sí ọ̀dọ̀ Jesu, wọ́n sí ròyìn ohun gbogbo tí wọ́n ti ṣe àti ohun gbogbo tí wọ́n ti kọ́ni.
\v 31 Nígbà tí Jesu rí i pé ọ̀pọ̀ ènìyàn ń lọ tí wọ́n sì ń bọ̀ tó bẹ́ẹ̀ tí kò sí ààyè fún wọn láti jẹun, ó sì wí fún wọn pé, \wj “Ẹ jẹ́ kí a kúrò láàrín ọ̀pọ̀ ènìyàn wọ̀nyí fún ìgbà díẹ̀, kí a sì sinmi.”\wj*
\p 
\v 32 Nítorí náà, wọ́n wọ ọkọ̀ ojú omi kúrò níbẹ̀ lọ sí ibi tí ó parọ́rọ́.
\v 33 Ṣùgbọ́n ọ̀pọ̀ ènìyàn ni o rí wọn nígbà tí wọ́n ń lọ. Àwọn wọ̀nyí sì tún wá láti ìlú ńlá gbogbo wọn sáré gba etí Òkun, wọ́n ṣáájú wọn gúnlẹ̀ ní èbúté.
\v 34 Bí Jesu ti ń sọ̀kalẹ̀ láti inú ọkọ̀ náà, ó bá ọ̀pọ̀ ènìyàn bí i tí àtẹ̀yìnwá, tí wọ́n ti ń dúró dè e. Ó káàánú fún wọn, nítorí wọ́n dàbí àgùntàn tí kò ní olùtọ́jú. Ó sì kọ́ wọn ni ọ̀pọ̀ nǹkan tí ó yẹ kí wọ́n mọ̀.
\p 
\v 35 Nígbà tí ọjọ́ sì ti bù lọ tán, àwọn ọmọ-ẹ̀yìn rẹ̀ tọ̀ ọ́ wá, wọ́n wí fún un pé, ibi aṣálẹ̀ ni ìbí yìí, ọjọ́ sì bù lọ tán.
\v 36 “Rán àwọn ènìyàn wọ̀nyí láti lọ sí àwọn abúlé àti ìlú láti ra oúnjẹ fún ara wọn.”
\p 
\v 37 Ṣùgbọ́n Jesu sọ fún àwọn ọmọ-ẹ̀yìn rẹ̀ pé, \wj “Ẹ fún wọn ní oúnjẹ.”\wj*
\p Àwọn ọmọ-ẹ̀yìn wí fún pé, “Èyí yóò ná wa tó owó iṣẹ́ ọ̀yà oṣù mẹ́jọ, ṣe kí a lọ fi èyí ra àkàrà fún àwọn ọ̀pọ̀ ènìyàn yìí láti jẹ.”
\p 
\v 38 Jesu tún béèrè pé, \wj “Ìṣù àkàrà mélòó ni ẹ̀yin ni lọ́wọ́? Ẹ lọ wò ó.”\wj*
\p Wọ́n padà wá jíṣẹ́ pé, “Ìṣù àkàrà márùn-ún àti ẹja méjì.”
\p 
\v 39 Nígbà náà ni Jesu sọ fún ọ̀pọ̀ ènìyàn náà kí a mú wọn jókòó lẹ́gbẹ̀ẹ̀gbẹ́ lórí koríko.
\v 40 Lẹ́sẹ̀kan náà, wọ́n bẹ̀rẹ̀ sí í jókòó, ní àádọ́ta tàbí ọgọọgọ́rùn-ún.
\v 41 Nígbà tí ó sì mú ìṣù àkàrà márùn-ún àti ẹja méjì náà, ó gbé ojú rẹ̀ sókè ọ̀run. Ó dúpẹ́ fún oúnjẹ náà, ó bù wọ́n sí wẹ́wẹ́, ó fún àwọn ọmọ-ẹ̀yìn rẹ̀ láti gbé e kalẹ̀ síwájú àwọn ènìyàn náà àti àwọn ẹja méjì náà ni ó pín fún gbogbo wọn.
\v 42 Gbogbo wọn sì jẹ àjẹyó.
\v 43 Àwọn ọmọ-ẹ̀yìn sì kó agbọ̀n méjìlá tí ó kún fún àjẹkù àkàrà àti ti ẹja pẹ̀lú.
\v 44 Àwọn tí ó sì jẹ́ àkàrà náà tó ìwọ̀n ẹgbẹ̀rún márùn-ún (5,000) ọkùnrin.
\s1 Jesu rìn lórí omi
\p 
\v 45 Lẹ́sẹ̀kẹsẹ̀ lẹ́yìn èyí, Jesu pàṣẹ fún àwọn ọmọ-ẹ̀yìn rẹ̀ láti padà sínú ọkọ̀ kí wọn sì ṣáájú rékọjá sí Betisaida. Níbẹ̀ ni òun yóò ti wà pẹ̀lú wọn láìpẹ́. Nítorí òun fúnra a rẹ̀ yóò dúró sẹ́yìn láti rí i pé àwọn ènìyàn túká lọ ilé wọn.
\v 46 Lẹ́yìn náà, ó lọ sórí òkè láti lọ gbàdúrà.
\p 
\v 47 Nígbà tí ó di alẹ́, ọkọ̀ wà láàrín Òkun, òun nìkan sì wà lórí ilẹ̀.
\v 48 Ó rí i wí pé àwọn ọmọ-ẹ̀yìn wà nínú wàhálà púpọ̀ ní wíwa ọkọ̀ náà nítorí ti ìjì líle ṣe ọwọ́ òdì sí wọn, nígbà tí ó sì dì ìwọ̀n ìṣọ́ kẹrin òru, ó tọ̀ wọ́n wá, ó ń rìn lórí omi Òkun, òun sì fẹ́ ré wọn kọjá,
\v 49 ṣùgbọ́n nígbà tí wọ́n rí i tí ó ń rìn, wọ́n rò pé iwin ni. Wọ́n sì kígbe sókè lóhùn rara,
\v 50 nítorí gbogbo wọn ni ó rí i, tí ẹ̀rù sì bà wọ́n.
\p Ṣùgbọ́n òun sọ̀rọ̀ sí wọn lẹ́sẹ̀kẹsẹ̀ pé, \wj “Ẹ mú ọkàn le! Èmi ni. Ẹ má bẹ̀rù.”\wj*
\v 51 Nígbà náà ni ó gòkè sínú ọkọ̀ pẹ̀lú wọn, ìjì líle náà sì dáwọ́ dúró. Ẹ̀rù sì bà wọ́n rékọjá gidigidi, ẹnu sì yà wọ́n.
\v 52 Wọn kò sá tó ni òye iṣẹ́ ìyanu ti ìṣù àkàrà, nítorí ti ọkàn wọn yigbì.
\p 
\v 53 Lẹ́yìn tí wọ́n la Òkun náà kọjá, wọ́n gúnlẹ̀ sí Genesareti. Wọ́n sì so ọkọ̀ sí èbúté.
\v 54 Wọ́n jáde kúrò nínú ọkọ̀. Àwọn ènìyàn tó wà níbẹ̀ rí Jesu, wọ́n sì dá a mọ̀ ọ́n.
\v 55 Wéré, wọ́n ròyìn dídé rẹ̀, gbogbo àwọn ènìyàn sáré gbé gbogbo àwọn aláìsàn lórí àkéte wọn wá pàdé rẹ̀.
\v 56 Ní ibi gbogbo tí ó sì dé, yálà ní abúlé, ìlú ńlá tàbí àrọ́ko, ń ṣe ni wọ́n ń kó àwọn aláìsàn pàdé rẹ̀ ní àárín ọjà. Wọ́n sì ń bẹ̀ ẹ́ kí ó jẹ́ kí wọn fi ọwọ́ kan etí aṣọ rẹ̀, gbogbo àwọn tí wọ́n sì fi ọwọ́ kàn án ni a mú láradá.
\c 7
\s1 Mímọ́ àti àìmọ́
\p 
\v 1 Àwọn Farisi sì péjọ sí ọ̀dọ̀ rẹ̀, àti àwọn kan nínú àwọn akọ̀wé, tí ó wá láti Jerusalẹmu,
\v 2 wọ́n sì ṣe àkíyèsí wí pé díẹ̀ nínú àwọn ọmọ-ẹ̀yìn Jesu ń fi ọwọ́ àìmọ́ jẹun, èyí yìí ni wẹ ọwọ́.
\v 3 (Àwọn Farisi, àti gbogbo àwọn Júù, bí wọ́n kò bá wẹ ọwọ́ wọn gidigidi, wọn kì í jẹun nítorí wọ́n ti pa òfin àtọwọ́dọ́wọ́ àwọn àgbà mọ́.
\v 4 Nígbà tí wọ́n bá sì ti ọjà dé sílé, wọn kò gbọdọ̀ fi ọwọ́ kan oúnjẹ àfi tí wọ́n bá bu omi wẹ ara wọn. Èyí sì jẹ́ ọ̀kan nínú ogunlọ́gọ̀ àpẹẹrẹ òfin àti ìlànà tí wọ́n ti dì mú fún ọ̀pọ̀lọpọ̀ ọdún sẹ́yìn, bí i fífọ kọ́ọ̀bù, àwọn ìkòkò, àti kẹ́tù.)
\p 
\v 5 Nítorí èyí àwọn Farisi àti àwọn olùkọ́ òfin béèrè lọ́wọ́ rẹ̀ pé, “Èéṣe tí àwọn ọmọ-ẹ̀yìn rẹ̀ kò tẹ̀lé àwọn òfin àtọwọ́dọ́wọ́ àwọn àgbà nítorí wọ́n fi ọwọ́ àìmọ́ jẹun?”
\p 
\v 6 Jesu dá wọn lóhùn wí pé, \wj “Ẹyin àgàbàgebè yìí, òtítọ́ ni wòlíì Isaiah ń sọtẹ́lẹ̀ nípa tí ẹ̀yin àgàbàgebè, bí a ti kọ ọ́ pé:\wj*
\q1 \wj “ ‘Àwọn ènìyàn wọ̀nyí fi ẹnu wọn bu ọlá fún mi\wj*
\q2 \wj ṣùgbọ́n ọkàn wọn jìnà sí mi.\wj*
\q1 
\v 7 \wj Ìsìn wọn jẹ́ lásán,\wj*
\q2 \wj ìkọ́ni wọ́n jẹ́ kìkìdá òfin tí àwọn ènìyàn fi ń kọ́ni.’\wj*
\m 
\v 8 \wj Nítorí tí ẹ̀yin fi òfin Ọlọ́run sí apá kan, ẹ̀yin ń tẹ̀lé àṣà àwọn ènìyàn.”\wj*
\p 
\v 9 Ó si wí fún wọn: \wj “Ẹ̀yin sá à mọ̀ bí ẹ ti ń gbé òfin Ọlọ́run jù sẹ́yìn kí ẹ lè mú òfin tiyín ṣẹ.\wj*
\v 10 \wj Mose fún un yín ní òfin yìí láti ọ̀dọ̀ Ọlọ́run pé, ‘Bọ̀wọ̀ fún baba òun ìyá rẹ.’ Ó tún sọ pé, ‘Ẹnikẹ́ni tí ó bá sọ̀rọ̀ aburú sí baba tàbí ìyá rẹ̀ ní láti kú ni.’\wj*
\v 11 \wj Ṣùgbọ́n ẹ̀yin wá sọ pé ó dára bákan náà fún ọkùnrin kan bí kò bá tilẹ̀ pèsè fún àìní àwọn òbí rẹ̀, ṣùgbọ́n kí o sọ fún wọn pé, ‘Ẹ má ṣe bínú baba tàbí ìyá mi, n kò lè ràn yín lọ́wọ́ nísinsin yìí,’ nítorí tí mo ti fi ẹ̀bùn tí ǹ bá fi fún un yín fún Ọlọ́run.\wj*
\v 12 \wj Bẹ́ẹ̀ ni ẹ̀yin kò si jẹ́ kí ó ṣe ohunkóhun fún baba tàbí ìyá rẹ̀ mọ́.\wj*
\v 13 \wj Ẹ̀yin ń fi òfin àtọwọ́dọ́wọ́ tiyín tí ẹ fi lélẹ̀, sọ ọ̀rọ̀ Ọlọ́run di asán àti ọ̀pọ̀ irú nǹkan bẹ́ẹ̀ ni ẹ̀yin ń ṣe.”\wj*
\p 
\v 14 Lẹ́yìn náà, Jesu pe ọ̀pọ̀ ènìyàn láti wá gbọ́ ọ̀rọ̀ rẹ̀. Ó sì wí fún wọn pé, \wj “Gbogbo yín ẹ tẹ́tí sílẹ̀ kí ẹ sì jẹ́ kí èyí ó yé e yín.\wj*
\v 15 \wj Kò sí ohunkóhun láti òde ènìyàn, tí ó wọ inú rẹ̀ lọ, tí ó lè sọ ọ́ di aláìmọ́, ṣùgbọ́n àwọn nǹkan tí ó ti inú rẹ jáde, àwọn wọ̀nyí ní ń sọ ènìyàn di aláìmọ́.”\wj*\f + \fr 7:15 \ft Àwọn àkọsílẹ̀ àtijọ́ ìwé Marku kan se àfikún ọ̀rọ̀ yìí \fqa aláìmọ́. \fv 16 \fqa Ẹni tí ó bá ní etí láti fi gbọ́ kí ó gbọ́\ft .\f*
\p 
\v 17 Nígbà tí Jesu sì wọ inú ilé kan lọ, àwọn ọmọ-ẹ̀yìn tẹ̀lé é, wọ́n sì béèrè ìtumọ̀ àwọn òwe tí ó pa.
\v 18 Jesu béèrè wí pé, \wj “Àbí kò sí èyí tí ó yé yín nínú ọ̀rọ̀ náà? Ẹ̀yin kò rí i wí pé ohunkóhun tí ó wọ inú ènìyàn láti òde kò lè sọ ènìyàn di aláìmọ́?\wj*
\v 19 \wj Nítorí tí kò lọ sínú ọkàn rẹ̀, ṣùgbọ́n sínú ara, a sì yà á jáde, a sì gbá gbogbo oúnjẹ dànù.”\wj* (Nípa sísọ èyí, Jesu fihàn pé gbogbo oúnjẹ jẹ́ “mímọ́.”)
\p 
\v 20 Nígbà náà, ó fi kún un pé, \wj “Èyí ti ó ti ọkàn ènìyàn jáde ni ń sọ ni di aláìmọ́.\wj*
\v 21 \wj Nítorí pé láti inú ọkàn ènìyàn ni àwọn èrò búburú wọ̀nyí ti ń jáde wá: àgbèrè, olè, ìpànìyàn, panṣágà,\wj*
\v 22 \wj ọ̀kánjúwà, odì yíyàn, ìtànjẹ, ìmọ-tara-ẹni, ìlara, ọ̀rọ̀ ẹ̀yìn, ìgbéraga, òmùgọ̀.\wj*
\v 23 \wj Gbogbo àwọn nǹkan búburú wọ̀nyí ń tí inú wá, àwọn ló sì ń sọ yín di aláìmọ́.”\wj*
\s1 Ìgbàgbọ́ obìnrin ará Kenaani
\p 
\v 24 Nígbà náà ni Jesu kúrò ní Galili, ó sí lọ sí agbègbè Tire àti Sidoni, ó sì gbìyànjú láti nìkan wà pẹ̀lú àwọn ọmọ-ẹ̀yìn rẹ̀ fún àkókò díẹ̀, ṣùgbọ́n eléyìí kò ṣe é ṣe, nítorí pé kò pẹ́ púpọ̀ tí ó wọ ìlú nígbà tí ìròyìn dídé rẹ̀ tàn káàkiri.
\v 25 Láìpẹ́, obìnrin kan tí ọmọbìnrin rẹ̀ ní ẹ̀mí àìmọ́ tọ̀ ọ́ wá, ó ti gbọ́ nípa Jesu, ó wá, ó sì wólẹ̀ lẹ́sẹ̀ Jesu.
\v 26 Giriki ní obìnrin náà, Siro-Fonisia ní orílẹ̀-èdè rẹ̀. Ó bẹ Jesu kí ó bá òun lé ẹ̀mí èṣù náà jáde lára ọmọbìnrin òun.
\p 
\v 27 Jesu sọ fún obìnrin yìí pé, \wj “Ní àkọ́kọ́, ó yẹ kí a fi oúnjẹ tẹ́ àwọn ọmọ lọ́rùn ná. Nítorí kò tọ́ kí a mú oúnjẹ àwọn ọmọ fún àwọn ajá.”\wj*
\p 
\v 28 Obìnrin náà dáhùn wí pé, “Òótọ́ ni ọ̀rọ̀ yín Olúwa, ṣùgbọ́n àwọn ọmọ ajá pàápàá a máa ní àǹfààní láti jẹ èérún oúnjẹ tí ó bá bọ́ sílẹ̀ láti orí tábìlì.”
\p 
\v 29 \wj “Ó sì wí fún un pé, nítorí ọ̀rọ̀ yìí, máa lọ, ẹ̀mí àìmọ́ náà ti jáde kúrò lára ọmọbìnrin rẹ.”\wj*
\p 
\v 30 Nígbà tí ó padà dé ilé, ó bá ọmọbìnrin rẹ̀ ní ìdùbúlẹ̀ jẹ́jẹ́ lórí ibùsùn, ẹ̀mí àìmọ́ náà ti fi í sílẹ̀.
\s1 Ìwòsàn ọkùnrin odi àti afọ́jú
\p 
\v 31 Nígbà náà ni Jesu fi agbègbè Tire àti Sidoni sílẹ̀, ó wá si Òkun Galili láàrín agbègbè Dekapoli.
\v 32 Níbẹ̀ ọkùnrin kan tí kò lè sọ̀rọ̀ wá sí ọ̀dọ̀ Jesu, àwọn ènìyàn sì bẹ Jesu pé kí ó gbé ọwọ́ rẹ̀ lé e.
\p 
\v 33 Jesu sì mú ọkùnrin náà kúrò láàrín ọ̀pọ̀ ènìyàn. Ó sì fi àwọn ìka rẹ̀ sí etí ọkùnrin náà, ó tu itọ́ ṣọ́wọ́. Ó sì fi kan ahọ́n rẹ̀.
\v 34 Nígbà náà ni Jesu wòkè ọ̀run, ó sì mí kanlẹ̀, ó sì pàṣẹ wí pé, “Efata!” (èyí ni, \wj “Ìwọ ṣí!”\wj*).
\v 35 Lójúkan náà, etí rẹ̀ sì ṣí, okùn ahọ́n rẹ̀ sì tú, ó sì ń sọ̀rọ̀ ketekete.
\p 
\v 36 Jesu pàṣẹ fún ọ̀pọ̀ ènìyàn tó wà níbẹ̀ pé kí wọn má ṣe tan ìròyìn náà ká. Ṣùgbọ́n bí ó ti ń pa wọ́n lẹ́nu mọ́ tó, náà ni wọ́n ń tan ìròyìn náà káàkiri tó.
\v 37 Àwọn ènìyàn sì kún fún ìyanu, wọ́n wí pé, “Ó ṣe ohun gbogbo dáradára, Ó mú kí adití gbọ́rọ̀, odi sì sọ̀rọ̀.”
\c 8
\s1 Jesu bọ́ ẹgbàajì (4,000) ènìyàn
\p 
\v 1 Ní ọjọ́ kan, bí ọ̀pọ̀ ènìyàn ti péjọ, kò sí oúnjẹ fún wọn mọ́ láti jẹ. Jesu pe àwọn ọmọ-ẹ̀yìn rẹ̀.
\v 2 Ó wí fún wọn pé, \wj “Àánú ọ̀pọ̀ ènìyàn wọ̀nyí ṣe mí nítorí pé ó tó ọjọ́ mẹ́ta tí wọ́n ti wà níhìn-ín, kò sì sí ohun kan tí ó kù sílẹ̀ fún wọn láti jẹ.\wj*
\v 3 \wj Bí mo bá sọ fún wọn láti máa lọ sí ilé wọn bẹ́ẹ̀ pẹ̀lú ebi, wọn yóò dákú lójú ọ̀nà, nítorí pé àwọn mìíràn nínú wọn ti ọ̀nà jíjìn wá.”\wj*
\p 
\v 4 Àwọn ọmọ-ẹ̀yìn rẹ̀ béèrè pé, “Níbo ni a ó ti rí àkàrà tí ó tó láti fi bọ́ wọn nínú aṣálẹ̀ yìí?”
\p 
\v 5 Jesu béèrè lọ́wọ́ wọn pé, \wj “Ìṣù àkàrà mélòó lẹ ní lọ́wọ́?”\wj*
\p Wọ́n fèsì pé, “Ìṣù àkàrà méje.”
\p 
\v 6 Nítorí náà, ó pàṣẹ fún àwọn ènìyàn náà láti jókòó lórí ilẹ̀. Ó sì mú odindi àkàrà méje náà, ó dúpẹ́ lọ́wọ́ Ọlọ́run, ó sì bù wọ́n sí wẹ́wẹ́, ó pín wọn fún àwọn ọmọ-ẹ̀yìn rẹ̀ láti gbé ka iwájú àwọn ènìyàn, wọ́n sì ṣe bẹ́ẹ̀.
\v 7 Wọ́n rí àwọn ẹja wẹ́wẹ́ díẹ̀ pẹ̀lú. Jesu tún dúpẹ́ lọ́wọ́ Ọlọ́run fún ìpèsè náà, ó sì pàṣẹ fún àwọn ọmọ-ẹ̀yìn rẹ̀ láti pín wọn fún àwọn ènìyàn náà.
\v 8 Gbogbo ọ̀pọ̀ ènìyàn náà ló jẹ àjẹyó àti àjẹtẹ́rùn. Lẹ́yìn èyí wọ́n kó àjẹkù ti ó kù jọ, agbọ̀n méje sì kún.
\v 9 Àwọn tí ó jẹ ẹ́ tó ìwọ̀n ẹgbàajì (4,000) ènìyàn, ó sì rán wọn lọ.
\v 10 Lẹ́sẹ̀kẹsẹ̀, lẹ́yìn èyí, Jesu wọ inú ọkọ̀ ojú omi pẹ̀lú àwọn ọmọ-ẹ̀yìn rẹ̀, wọ́n sì gúnlẹ̀ sí agbègbè Dalmanuta.
\p 
\v 11 Àwọn Farisi tọ Jesu wá, wọ́n sì bẹ̀rẹ̀ sí béèrè ìbéèrè lọ́wọ́ rẹ̀. Láti dán an wò, wọ́n béèrè fún àmì láti ọ̀run.
\v 12 Jesu mí kanlẹ̀, nígbà tí ó gbọ́ ìbéèrè wọn. Ó sì dáhùn wí pé, \wj “Èéṣe tí ìran yìí fi ń wá àmì? Lóòótọ́ ni mo sọ fún un yín kò si àmì tí a ó fi fún ìran yín.”\wj*
\v 13 Nígbà náà ni ó padà sínú ọkọ̀ ojú omi ó fi àwọn ènìyàn sílẹ̀, ó sì rékọjá sí apá kejì Òkun náà.
\s1 Ìwúkàrà àwọn Farisi àti Herodu
\p 
\v 14 Ṣùgbọ́n àwọn ọmọ-ẹ̀yìn ti gbàgbé láti mú àkàrà tí yóò tó wọn ọ́n jẹ lọ́wọ́. Ẹyọ ìṣù àkàrà kan ṣoṣo ni ó wà nínú ọkọ̀ wọn.
\v 15 Bí wọ́n sì ti ń rékọjá, Jesu kìlọ̀ fún wọn pé, \wj “Ẹ máa ṣọ́ra nítorí ìwúkàrà àwọn Farisi àti ìwúkàrà Herodu.”\wj*
\p 
\v 16 Wọ́n bẹ̀rẹ̀ sí ronú èyí láàrín ara wọn wí pé, “Torí pé a kò mú àkàrà lọ́wọ́ ni?”
\p 
\v 17 Jesu mọ ohun tí wọ́n sọ láàrín ara wọn, ó sì dá wọn lóhùn pé, \wj “Èéṣe ti ẹ̀yin fi ń ṣe àròyé pé ẹ̀yin kò mú àkàrà lọ́wọ́? Ẹ̀yin kò kíyèsi i títí di ìsinsin yìí, ẹ kò sì ti mòye, àbí ọkàn yín le ni.\wj*
\v 18 \wj Ẹ̀yin ní ojú, ẹ kò fi ríran? Ẹ̀yin ni etí ẹ kò sí gbọ́ran? Ẹ̀yin kò sì rántí?\wj*
\v 19 \wj Nígbà ti mo bu ìṣù àkàrà márùn-ún fún ẹgbẹ̀rún márùn-ún (5,000) ènìyàn, agbọ̀n mélòó ni ó kún fún àjẹkù tí ẹ ṣàjọ?”\wj*
\p Wọ́n wí pé, “Méjìlá.”
\p 
\v 20 \wj “Bákan náà, nígbà tí mo bọ́ ẹgbàajì (4,000) pẹ̀lú ìṣù àkàrà méje, agbọ̀n mélòó ló kù sílẹ̀ lẹ́yìn àjẹyó àti àjẹtẹ́rùn wọn?”\wj*
\p Wọ́n dáhùn pé, “Ó ku ẹ̀kún agbọ̀n méje.”
\p 
\v 21 Ó sì wí fún wọn pé, \wj “Èéha ti ṣe tí kò fi yé yin?”\wj*
\s1 Ìwòsàn ọkùnrin afọ́jú ní Betisaida
\p 
\v 22 Nígbà tí wọ́n dé Betisaida, àwọn ènìyàn kan mú afọ́jú kan wá sọ́dọ̀ rẹ̀. Wọ́n bẹ̀ ẹ́ kí ó fi ọwọ́ kàn án, kí ó sì wò ó sàn.
\v 23 Jesu fa ọkùnrin náà lọ́wọ́, ó sì mú un jáde lọ sí ẹ̀yìn ìlú. Ó tu itọ́ sí i lójú. Ó sì gbé ọwọ́ rẹ̀ lé ojú náà. Ó sì bi í léèrè pé, \wj “Ǹjẹ́ ìwọ lè rí ohunkóhun nísinsin yìí?”\wj*
\p 
\v 24 Ọkùnrin náà wo àyíká rẹ̀, ó sì dáhùn pé, “Bẹ́ẹ̀ ni Olúwa, mo rí àwọn ènìyàn, ṣùgbọ́n n kò rí wọn kedere, wọ́n n rìn kiri bí àgékù igi.”
\p 
\v 25 Nígbà náà, Jesu tún gbé ọwọ́ rẹ̀ méjèèjì lé àwọn ojú ọkùnrin náà, bí ọkùnrin náà sì ti ranjú mọ́ ọn, a dá ìran rẹ̀ padà, ó sì rí gbogbo nǹkan kedere.
\v 26 Jesu sì rán an sí àwọn ẹbí rẹ̀. Ó kìlọ̀ fún un pé, \wj “Má ṣe lọ sí ìlú, kí o má sì sọ fún ẹnikẹ́ni ní ìlú.”\wj*
\s1 Peteru jẹ́wọ́ ẹni tí Kristi jẹ́
\p 
\v 27 Nísinsin yìí, Jesu àti àwọn ọmọ-ẹ̀yìn rẹ̀ kúrò ní Galili. Wọ́n sì jáde lọ sí àwọn abúlé ní agbègbè Kesarea-Filipi. Bí wọ́n ti ń lọ lọ́nà, ó béèrè lọ́wọ́ wọn pé, \wj “Ta ni àwọn ènìyàn ń fi mí pè?”\wj*
\p 
\v 28 Àwọn ọmọ-ẹ̀yìn náà dáhùn pé, “Àwọn kan rò pé ìwọ ni Johanu Onítẹ̀bọmi, àwọn mìíràn sọ pé, ìwọ ni Elijah tàbí àwọn wòlíì mìíràn ni ó tún padà wá sáyé.”
\p 
\v 29 Ó sì bi wọ́n pé, \wj “Ta ni ẹ̀yin ń fi mí pè?”\wj*
\p Peteru dáhùn pé, “Ìwọ ni Kristi náà.”
\p 
\v 30 Ṣùgbọ́n Jesu kìlọ̀ fún wọn, kí wọn má sọ èyí fún ẹnikẹ́ni.
\s1 Jesu sọ àsọtẹ́lẹ̀ nípa ikú ara rẹ̀
\p 
\v 31 Ó sì bẹ̀rẹ̀ sí kọ́ wọn, pé, Ọmọ Ènìyàn kò le ṣàìmá jìyà ohun púpọ̀, a ó sì kọ̀ ọ́ sílẹ̀ láti ọwọ́ àwọn àgbàgbà, àwọn olórí àlùfáà àti àwọn olùkọ́ òfin, a ó sì pa á, lẹ́yìn ọjọ́ mẹ́ta yóò sì jíǹde.
\v 32 Jesu bá wọn sọ̀rọ̀ yìí, láìfi ohunkóhun pamọ́ fún wọn, ṣùgbọ́n Peteru pe Jesu sẹ́yìn, ó sì bẹ̀rẹ̀ si bá a wí.
\p 
\v 33 Jesu yípadà, ó wo àwọn ọmọ-ẹ̀yìn rẹ̀. Ó sì wí fún Peteru pẹ̀lú ìtara pé, \wj “Kúrò lẹ́yìn mi Satani, nítorí ìwọ kò ro ohun tí Ọlọ́run bí kò ṣe ohun tí ènìyàn.”\wj*
\s1 Ọ̀nà sí àgbélébùú
\p 
\v 34 Nígbà náà ni Jesu pe àwọn ọmọ-ẹ̀yìn rẹ̀ àti ọ̀pọ̀ ènìyàn láti bá wọn sọ̀rọ̀, ó wí fún wọn pé, \wj “Bí ẹnikẹ́ni bá fẹ́ tọ̀ mí lẹ́yìn, kí ó sẹ́ ara rẹ̀, kí ó si gbé àgbélébùú rẹ̀, kí ó si máa tọ̀ mi lẹ́yìn.\wj*
\v 35 \wj Nítorí ẹni tó bá gbìyànjú láti gba ẹ̀mí ara rẹ̀ là, yóò sọ ọ́ nù. Iye àwọn tí ó sọ ẹ̀mí wọn nù nìkan nítorí í tèmi àti nítorí ìyìnrere, òun náà ni yóò gbà á là.\wj*
\v 36 \wj Nítorí èrè kí ni ó jẹ́ fún ẹni tí ó jèrè gbogbo ayé, tí ó sọ ẹ̀mí rẹ̀ nù?\wj*
\v 37 \wj Tàbí kí ni ènìyàn yóò fi ṣe pàṣípàrọ̀ ẹ̀mí rẹ̀?\wj*
\v 38 \wj Nítorí náà, bí ẹnikẹ́ni bá tijú àti gbà mí tàbí ọ̀rọ̀ mi nínú ìran panṣágà àti ẹlẹ́ṣẹ̀ yìí, tí ó kún fún àìgbàgbọ́ àti ẹ̀ṣẹ̀ báyìí, Ọmọ Ènìyàn yóò tijú rẹ̀ nígbà tí ó bá padà dé nínú ògo Baba rẹ̀, pẹ̀lú àwọn angẹli mímọ́.”\wj*
\c 9
\p 
\v 1 Ó sì wí fún wọn pé, \wj “Lóòótọ́ ni mo wí fún un yín àwọn mìíràn wa nínú àwọn tó dúró níhìn-ín yìí, tí kì yóò tọ́ ikú wò, títí yóò fi rí ìjọba Ọlọ́run tí yóò fi dé pẹ̀lú agbára.”\wj*
\s1 Ìparadà
\p 
\v 2 Lẹ́yìn ọjọ́ mẹ́fà tí Jesu sọ̀rọ̀ yìí, Jesu mú Peteru, Jakọbu àti Johanu lọ sí orí òkè gíga ní apá kan. Kò sí ẹlòmíràn pẹ̀lú wọn, ara rẹ̀ sì yípadà níwájú wọn.
\v 3 Aṣọ rẹ̀ sì di dídán, ó sì funfun gbòò, tí alágbàfọ̀ kan ní ayé kò lè sọ di funfun bẹ́ẹ̀.
\v 4 Nígbà náà ni Elijah àti Mose farahàn fún wọn, wọ́n sì bẹ̀rẹ̀ sí sọ̀rọ̀ pẹ̀lú Jesu.
\p 
\v 5 Peteru sì wí fún Jesu pé, “Rabbi, ó dára fún wa láti máa gbé níhìn-ín, si jẹ́ kí a pa àgọ́ mẹ́ta, ọ̀kan fun ọ, ọ̀kan fún Mose, àti ọ̀kan fún Elijah.”
\v 6 Nítorí òun kò mọ ohun tí òun ìbá sọ, nítorí ẹ̀rù bà wọ́n gidigidi.
\p 
\v 7 Ìkùùkuu kan sì bò wọ́n, ohùn kan sì ti inú ìkùùkuu náà wá wí pé, “Èyí ni àyànfẹ́ ọmọ mi. Ẹ máa gbọ́ ti rẹ̀!”
\p 
\v 8 Lójijì, wọ́n wo àyíká wọn, wọn kò sì rí ẹnìkankan mọ́, bí kò ṣe Jesu nìkan ṣoṣo ni ó sì wà pẹ̀lú wọn.
\p 
\v 9 Bí wọ́n ti ń sọ̀kalẹ̀ láti orí òkè, Jesu kìlọ̀ fún wọn kí wọ́n má ṣe sọ ohun tí wọ́n ti rí fún ẹnikẹ́ni títí Ọmọ Ènìyàn yóò fi jíǹde kúrò nínú òkú.
\v 10 Nítorí náà, wọ́n pa nǹkan náà mọ́ ní ọkàn wọn. Ṣùgbọ́n wọ́n ń béèrè lọ́wọ́ ara wọn ohun tí àjíǹde kúrò nínú òkú túmọ̀ sí.
\p 
\v 11 Nísinsin yìí, wọ́n bẹ̀rẹ̀ sí í béèrè lọ́wọ́ rẹ̀, èéṣe tí àwọn olùkọ́ òfin ń sọ wí pé, “Elijah ní yóò kọ́kọ́ dé.”
\p 
\v 12 Ó sì dáhùn ó sì wí fún wọn pé, \wj “Lóòótọ́ ni Elijah yóò kọ́kọ́ dé yóò sì mú nǹkan gbogbo padà bọ̀ sípò. Àní gẹ́gẹ́ bí a ti kọ̀wé rẹ nípa ti Ọmọ Ènìyàn pé kò le ṣàìmá jìyà ohun púpọ̀ àti pé a ó sì kọ̀ ọ́ sílẹ̀.\wj*
\v 13 \wj Ṣùgbọ́n mo wí fún yín pé, Elijah ti wa ná, wọ́n sì ti ṣe ohunkóhun tí ó wù wọ́n sí i, gẹ́gẹ́ bí a ti kọ̀wé nípa rẹ̀.”\wj*
\s1 Ìwòsàn ọmọkùnrin ẹlẹ́mìí èṣù
\p 
\v 14 Nígbà tí wọ́n sọ̀kalẹ̀ pátápátá sí ẹsẹ̀ òkè náà, wọ́n bá ọ̀pọ̀lọpọ̀ ènìyàn tí wọ́n yí àwọn ọmọ-ẹ̀yìn mẹ́sàn-án ìyókù ká. Àwọn olùkọ́ òfin díẹ̀ sì ń bá wọn jiyàn.
\v 15 Bí Jesu ti ń súnmọ́ ọ̀pọ̀ ènìyàn wọ̀nyí ni wọ́n ti bẹ̀rẹ̀ sí í wò ó pẹ̀lú ìbẹ̀rù, nígbà náà ni wọ́n sáré lọ kí i.
\p 
\v 16 Jesu béèrè lọ́wọ́ wọn pé, \wj “Kí ló fa àríyànjiyàn?”\wj*
\p 
\v 17 Ọkùnrin kan láàrín ọ̀pọ̀ ènìyàn dáhùn pé, “Olùkọ́, èmi ni mo mú ọmọ yìí wá fún ọ láti wò ó sàn. Kò lè sọ̀rọ̀ rárá, nítorí tí ó ní ẹ̀mí àìmọ́.
\v 18 Àti pé, nígbàkígbà tí ó bá mú un, á gbé e ṣánlẹ̀, a sì máa hó itọ́ lẹ́nu, a sì máa lọ́ eyín rẹ̀. Òun pàápàá a wá le gbagidi. Mo sì bẹ àwọn ọmọ-ẹ̀yìn rẹ kí wọn lé ẹ̀mí àìmọ́ náà jáde, ṣùgbọ́n wọ́n kò lè ṣe é.”
\p 
\v 19 Ó sì dá wọn lóhùn, ó wí pé, \wj “Ẹ̀yin ìran aláìgbàgbọ́ yìí, èmi yóò ti bá a yín gbé pẹ́ tó? Èmi yóò sì ti mú sùúrù fún un yín pẹ́ tó? Ẹ mú ọmọ náà wá sọ́dọ̀ mi.”\wj*
\p 
\v 20 Wọ́n sì mú un wá sọ́dọ̀ rẹ̀: nígbà tí ó sì rí i, lójúkan náà ẹ̀mí náà nà án tàntàn ó sì ṣubú lu ilẹ̀, ó sì ń fi ara yílẹ̀, ó sì ń yọ ìfófó lẹ́nu.
\p 
\v 21 Jesu béèrè lọ́wọ́ baba ọmọ náà pé, \wj “Ó tó ìgbà wo tí ọmọ rẹ̀ ti wà nínú irú ipò báyìí?”\wj*
\p Baba ọmọ náà dáhùn pé, “Láti kékeré ni.”
\v 22 Nígbàkígbà ni ó sì máa ń gbé e sínú iná àti sínú omi, láti pa á run, ṣùgbọ́n bí ìwọ bá lè ṣe ohunkóhun, ṣàánú fún wa, kí o sì ràn wá lọ́wọ́.
\p 
\v 23 \wj “Jesu sì wí fún un pé, ‘Bí ìwọ bá le gbàgbọ́: ohun gbogbo ni ó ṣe é ṣe fún ẹni tí ó bá gbàgbọ́.’ ”\wj*
\p 
\v 24 Lójúkan náà baba ọmọ náà kígbe ní ohùn rara, ó sì wí pé, “Olúwa, mo gbàgbọ́, ran àìgbàgbọ́ mi lọ́wọ́.”
\p 
\v 25 Nígbà tí Jesu rí i pé ọ̀pọ̀ ènìyàn ń péjọ sọ́dọ̀ wọn, ó bá ẹ̀mí àìmọ́ náà wí pé, \wj “Ìwọ ẹ̀mí àìmọ́, adití àti odi, mo pàṣẹ fún ọ, kí ó jáde kúrò lára ọmọ yìí, kí ó má ṣe padà sí ibẹ̀ mọ́.”\wj*
\p 
\v 26 Òun sì kígbe ńlá, ó sì nà án tàntàn, ó sì jáde kúrò lára rẹ̀, ọmọ náà sì dàbí ẹni tí ó kú tó bẹ́ẹ̀ tí ọ̀pọ̀ ènìyàn ké wí pé, “Hé è, ọmọ náà ti kú.”
\v 27 Ṣùgbọ́n Jesu fà á lọ́wọ́, ó sì ràn án lọ́wọ́ láti dúró lórí ẹsẹ̀ rẹ̀. Ó dìde dúró.
\p 
\v 28 Nígbà tí ó sì wọ ilé, àwọn ọmọ-ẹ̀yìn rẹ̀ bi í léèrè níkọ̀kọ̀ wí pé, “Èéṣe tí àwa kò fi lè lé e jáde?”
\p 
\v 29 Ó sì wí fún wọn pé, \wj “Irú èyí kò le ti ipa ohun kan jáde, bí kò ṣe nípa àdúrà.”\wj*\f + \fr 9:29 \ft Àwọn àkọsílẹ̀ kan sọ pé, nípa ààwẹ̀ àti àdúrà\f*
\p 
\v 30 Wọ́n sì kúrò níbẹ̀, wọ́n gba Galili kọjá. Níbẹ̀ ni Jesu ti gbìyànjú láti yẹra kí ó bá à lè wà pẹ̀lú àwọn ọmọ-ẹ̀yìn rẹ̀, kí ó lè ráàyè kọ́ wọn lẹ́kọ̀ọ́ sí i.
\v 31 Nítorí ó kọ́ àwọn ọmọ-ẹ̀yìn rẹ̀, ó sì wí fun wọn pe, \wj “A ó fi Ọmọ Ènìyàn lé àwọn ènìyàn lọ́wọ́, wọn ó sì pa á, lẹ́yìn ìgbà tí a bá sì pa á tan yóò jíǹde ní ọjọ́ kẹta.”\wj*
\v 32 Ṣùgbọ́n ọ̀rọ̀ náà kò yé wọn, ẹ̀rù sì bà wọ́n láti béèrè lọ́wọ́ rẹ̀, ìtumọ̀ ohun tí ó sọ náà.
\s1 Ta ni o ga jùlọ?
\p 
\v 33 Wọ́n dé sí Kapernaumu. Lẹ́yìn tí wọ́n sinmi tán nínú ilé tí wọ́n wọ̀, Jesu béèrè lọ́wọ́ wọn pé, \wj “Kí ni ohun tí ẹ́ ń bá ara yín jiyàn lé lórí?”\wj*
\v 34 Ṣùgbọ́n wọ́n dákẹ́; nítorí wọn ti ń bá ara wọn jiyàn pé, ta ni ẹni tí ó pọ̀jù?
\p 
\v 35 Ó jókòó, ó sì pè àwọn méjìlá náà, ó sọ fún wọn pé, \wj “Bí ẹnikẹ́ni bá fẹ́ ṣe ẹni ìṣáájú, òun ni yóò ṣe ẹni ìkẹyìn gbogbo wọn. Ó ní láti jẹ́ ìránṣẹ́ gbogbo ènìyàn.”\wj*
\p 
\v 36 Ó sì mú ọmọ kékeré kan, ó fi sáàárín wọn, nígbà tí ó sì gbé e sí apá rẹ̀, ó wí fún wọn pé,
\v 37 \wj “Ẹnikẹ́ni tí ó bá tẹ́wọ́gbà ọmọ kékeré bí èyí ní orúkọ mi, òun gbà mí. Ẹnikẹ́ni tí ó bá sì gbà mi, ó gba Baba mi, tí ó rán mi.”\wj*
\p 
\v 38 Ọ̀kan nínú àwọn ọmọ-ẹ̀yìn rẹ̀, Johanu sọ fún un ní ọjọ́ kan pé, “Olùkọ́, àwa rí ọkùnrin kan, tí ń fi orúkọ rẹ̀ lé àwọn ẹ̀mí àìmọ́ jáde, ṣùgbọ́n a sọ fún un pé kò gbọdọ̀ ṣe bẹ́ẹ̀ mọ́, nítorí kì í ṣe ọ̀kan nínú wa.”
\p 
\v 39 Jesu sì sọ fún un pé, \wj “Má ṣe dá irú ènìyàn bẹ́ẹ̀ dúró, nítorí kò sí ẹnìkan ti ó fi orúkọ mi ṣe iṣẹ́ ìyanu tí yóò tún lè máa sọ ohun búburú nípa mi.\wj*
\v 40 \wj Nítorí ẹni tí kò bá kọ ojú ìjà sí wa, ó wà ní ìhà tiwa.\wj*
\v 41 \wj Lóòótọ́ ni mo sọ fún ún yín bí ẹnikẹ́ni bá fún un yín ní ife omi kan nítorí pé ẹ jẹ́ ti Kristi, dájúdájú ẹni náà kì yóò sọ èrè rẹ̀ nù bí ó ti wù kí ó rí.\wj*
\s1 Okùnfà ẹ̀ṣẹ̀
\p 
\v 42 \wj “Ṣùgbọ́n ti ẹnikẹ́ni bá mú ọ̀kan nínú àwọn ọmọ kékeré wọ̀nyí tí ó gbà mí gbọ́ ṣìnà nínú ìgbàgbọ́ rẹ́, ó sàn fún un kí a so òkúta ńlá mọ́ ọn ni ọ̀run, kí a sì sọ ọ́ sínú òkun.\wj*
\v 43 \wj Bí ọwọ́ rẹ bá sì mú ọ kọsẹ̀, gé e sọnù, ó sàn fún ọ kí o ṣe akéwọ́ lọ sí ibi ìyè, ju kí o ní ọwọ́ méjèèjì, kí o lọ sí ọ̀run àpáàdì, sínú iná àjóòkú.\wj*\f + \fr 9:43 \ft Àwọn àkọsílẹ̀ àtijọ́ ìwé Marku kan se àfikún ọ̀rọ̀ yìí \fqa àjóòkú. \fv 44\fqa Níbi ti ‘kòkòrò wọn kì í kú, tí iná kì í sì í kú.’ \f*
\v 45 \wj Bí ẹsẹ̀ rẹ bá sì mú ọ kọsẹ̀, gé é sọnù, ó sàn kí ó di akesẹ̀, kí o sì gbé títí ayé àìnípẹ̀kun ju kí o ní ẹsẹ̀ méjì tí ó gbé ọ lọ sí ọ̀run àpáàdì.\wj*\f + \fr 9:45 \ft Àwọn àkọsílẹ̀ àtijọ́ ìwé Marku kan se àfikún ọ̀rọ̀ yìí \fqa àpáàdì. \fv 46\fqa Níbi ti ‘kòkòrò wọn kì í kú, tí iná kì í sì í kú.’ \f*
\v 47 \wj Bí ojú rẹ bá sì mú ọ kọsẹ̀, yọ ọ́ sọnù, ó sàn kí o wọ ìjọba Ọlọ́run pẹ̀lú ojú kan ju kí ó ní ojú méjì kí ó sì lọ sínú iná ọ̀run àpáàdì.\wj*
\v 48 \wj Níbi ti\wj*
\q1 \wj “ ‘kòkòrò wọn kì í kú,\wj*
\q2 \wj tí iná kì í sì í kú.’\wj*
\m 
\v 49 \wj Níbẹ̀ ni a ó ti fi iná dán ẹnìkọ̀ọ̀kan wò.\wj*
\p 
\v 50 \wj “Iyọ̀ dára, ṣùgbọ́n tí ó bá sọ adùn rẹ̀ nù, báwo ni ẹ ṣè lè padà mú un dùn? Ẹ ni iyọ̀ nínú ara yín, ki ẹ sì máa gbé ní àlàáfíà pẹ̀lú ara yín.”\wj*
\c 10
\s1 Ìkọ̀sílẹ̀
\p 
\v 1 Nígbà náà, Jesu kúrò níbẹ̀, ó sì wá sí ẹkùn Judea níhà òkè odò Jordani. Àwọn ènìyàn sì tún tọ̀ ọ́ wá, bí i ìṣe rẹ̀, ó sì kọ́ wọn.
\p 
\v 2 Àwọn Farisi kan tọ̀ ọ́ wá, láti dán an wò. Wọ́n béèrè lọ́wọ́ rẹ̀ pé, “Ǹjẹ́ ó ha tọ̀nà fún ènìyàn láti kọ ìyàwó rẹ̀ sílẹ̀?”
\p 
\v 3 Jesu béèrè lọ́wọ́ wọn pé, \wj “Kí ni Mose pàṣẹ fún un yín?”\wj*
\p 
\v 4 Wọ́n dáhùn pé, “Mose yọ̀ǹda fún wa láti kọ ìwé ìkọ̀sílẹ̀ fún un, kí a sì fi sílẹ̀.”
\p 
\v 5 Ṣùgbọ́n Jesu dá wọn lóhùn, ó sì wí pé, \wj “Nítorí líle àyà yín ni Mose fi kọ òfin yìí fun un yín.\wj*
\v 6 \wj Ṣùgbọ́n láti ìgbà tí ayé ti ṣẹ̀, Ọlọ́run dá wọn ní akọ àti abo.\wj*
\v 7 \wj Nítorí ìdí èyí, ọkùnrin yóò fi baba àti ìyá rẹ̀ sílẹ̀ yóò sì fi ara mọ́ aya rẹ̀.\wj*
\v 8 \wj Òun àti ìyàwó rẹ̀ yóò di ara kan náà. Nítorí náà, wọn kì í túnṣe méjì mọ́ bí kò ṣe ẹyọ ọ̀kan ṣoṣo.\wj*
\v 9 \wj Nítorí náà ohun ti Ọlọ́run bá sọ dọ̀kan, ki ẹnikẹ́ni máa ṣe yà wọ́n.”\wj*
\p 
\v 10 Lẹ́yìn náà, nígbà tí Jesu nìkan wà nínú ilé pẹ̀lú àwọn ọmọ-ẹ̀yìn rẹ̀, wọ́n tún béèrè lọ́wọ́ rẹ̀ nípa ohun kan náà.
\v 11 Jesu túbọ̀ ṣe àlàyé fún wọn pé, \wj “Ẹnikẹ́ni tí ó bá kọ aya rẹ̀ sílẹ̀ tí ó bá sì fẹ́ ẹlòmíràn, irú ọkùnrin bẹ́ẹ̀ ṣe panṣágà sí obìnrin tí ó ṣẹ̀ṣẹ̀ gbé níyàwó.\wj*
\v 12 \wj Bẹ́ẹ̀ gẹ́gẹ́, bí obìnrin kan bá kọ ọkọ rẹ̀ sílẹ̀ tí ó sì fẹ́ ọkùnrin mìíràn, irú obìnrin bẹ́ẹ̀ ṣe panṣágà.”\wj*
\s1 Jesu àti àwọn ọmọdé
\p 
\v 13 Lẹ́yìn èyí, àwọn ènìyàn bẹ̀rẹ̀ sí í gbé àwọn ọmọ wẹ́wẹ́ tọ Jesu wá kí ó lè súre fún wọn. Ṣùgbọ́n àwọn ọmọ-ẹ̀yìn rẹ̀ kígbe mọ́ àwọn tí ń gbé àwọn ọmọdé wọ̀nyí bọ̀ pé wọn kò gbọdọ̀ yọ Jesu lẹ́nu rárá.
\v 14 Ṣùgbọ́n nígbà tí Jesu rí ohun tí ó ń ṣẹlẹ̀, inú rẹ̀ kò dùn sí àwọn ọmọ-ẹ̀yìn rẹ̀. Nítorí náà, ó sọ fún wọn pé, \wj “Ẹ jẹ́ kí àwọn ọmọdé kékeré wá sọ́dọ̀ mi. Ẹ má ṣe dá wọn lẹ́kun nítorí pé irú wọn ni ìjọba Ọlọ́run.\wj*
\v 15 \wj Lóòótọ́ ni mo wí fún yín, ẹnikẹ́ni tí kò bá gba ìjọba Ọlọ́run bí ọmọ kékeré, kì yóò le è wọ inú rẹ̀.”\wj*
\v 16 Nígbà náà, Jesu gbé àwọn ọmọ náà lé ọwọ́ rẹ̀, ó gbé ọwọ́ lé orí wọn. Ó sì súre fún wọn.
\s1 Ọ̀dọ́mọkùnrin ọlọ́rọ̀
\p 
\v 17 Bí Jesu ti bẹ̀rẹ̀ ìrìnàjò rẹ, ọkùnrin kan sáré wá sọ́dọ̀ rẹ̀. Ó sì kúnlẹ̀, ó béèrè pé, “Olùkọ́ rere, kí ni èmi yóò ṣe láti jogún ìyè àìnípẹ̀kun?”
\p 
\v 18 Jesu béèrè pé, arákùnrin, \wj “Èéṣe tí o fi ń pè mí ní ẹni rere? Ẹni rere kan kò sí Ọlọ́run nìkan ni ẹni rere.\wj*
\v 19 \wj Ìwọ mọ àwọn òfin bí: ‘Ìwọ kò gbọdọ̀ pànìyàn, ìwọ kò gbọdọ̀ ṣe panṣágà, ìwọ kò gbọdọ̀ jalè, ìwọ kò gbọdọ̀ purọ́, ìwọ kò gbọdọ̀ rẹ́ ọmọnìkejì jẹ, bọ̀wọ̀ fún baba àti ìyá rẹ.’ ”\wj*
\p 
\v 20 Ọkùnrin náà dáhùn pé, “Olùkọ́, gbogbo nǹkan wọ̀nyí ni èmi ń ṣe láti ìgbà èwe mi wá.”
\p 
\v 21 Jesu wò ó tìfẹ́tìfẹ́. Ó wí fún un pé, \wj “Bí ó bá rí bẹ́ẹ̀, ohun kan ló kù fún ọ láti ṣe, lọ nísinsin yìí, ta gbogbo nǹkan tí o ní, kí o sì pín owó náà fún àwọn aláìní ìwọ yóò sì ní ìṣúra ní ọ̀run, sì wá, kí ó sì máa tọ̀ mí lẹ́yìn.”\wj*
\p 
\v 22 Nígbà tí ọkùnrin yìí gbọ́ èyí, ojú rẹ̀ korò, ó sì lọ pẹ̀lú ìbànújẹ́, nítorí pé ó ní ọrọ̀ púpọ̀.
\p 
\v 23 Jesu wò ó bí ọkùnrin náà ti ń lọ. Ó yípadà, ó sì sọ fún àwọn ọmọ-ẹ̀yìn rẹ̀ pé, \wj “Àní, ohun ìṣòro ni fún ọlọ́rọ̀ láti wọ ìjọba Ọlọ́run!”\wj*
\p 
\v 24 Ọ̀rọ̀ yìí ya àwọn ọmọ-ẹ̀yìn rẹ̀ lẹ́nu. Jesu tún sọ fún wọn pé, \wj “Ẹyin ọmọ yóò tí ṣòro tó fún àwọn tí ó ní ìgbẹ́kẹ̀lé nínú ọrọ̀ láti wọ ìjọba Ọlọ́run.\wj*
\v 25 \wj Ó rọrùn fún ìbákasẹ láti gba ojú abẹ́rẹ́ wọlé jù fún ọlọ́rọ̀ kan láti wọ ìjọba ọ̀run.”\wj*
\p 
\v 26 Ẹnu túbọ̀ ya àwọn ọmọ-ẹ̀yìn sí i. Wọ́n béèrè wí pé, “Tí ó bá rí bẹ́ẹ̀, ta ni nínú ayé ni ó lè ní ìgbàlà?”
\p 
\v 27 Jesu wò wọ́n, ó sì wí fún wọn pé, \wj “Ènìyàn ní èyí kò ṣe é ṣe fún ṣùgbọ́n kì í ṣe fún Ọlọ́run, nítorí ohun gbogbo ni ṣíṣe fún Ọlọ́run.”\wj*
\p 
\v 28 Nígbà náà ni Peteru kọjú sí Jesu, ó wí pé, “Àwa ti fi ohun gbogbo sílẹ̀, a sì ń tọ̀ ọ́ lẹ́yìn.”
\p 
\v 29 Jesu dáhùn pé, \wj “Lóòótọ́ ni mo wí fún un yín pé, kò sí ẹnikẹ́ni tí ó fi ohunkóhun sílẹ̀ bí: ilé, tàbí àwọn arákùnrin, tàbí àwọn arábìnrin, tàbí ìyá, tàbí baba, tàbí àwọn ọmọ tàbí ohun ìní nítorí mi àti nítorí ìyìnrere,\wj*
\v 30 \wj tí a kì yóò fún padà ní ọgọọgọ́rùn-ún àwọn ilé, tàbí arákùnrin, tàbí arábìnrin, tàbí ìyá, tàbí ọmọ, tàbí ilẹ̀, àti inúnibíni pẹ̀lú. Gbogbo nǹkan wọ̀nyí yóò jẹ́ tirẹ̀ ní ayé yìí àti pé ní ayé tó ń bọ̀ yóò ní ìyè àìnípẹ̀kun.\wj*
\v 31 \wj Ṣùgbọ́n ọ̀pọ̀ àwọn tí ó síwájú ni yóò di ẹni ìkẹyìn, àwọn tí ó sì kẹ́yìn yóò síwájú.”\wj*
\s1 Jesu tún sọ àsọtẹ́lẹ̀ nípa ikú ara rẹ̀
\p 
\v 32 Nísinsin yìí, wọ́n wà lójú ọ̀nà sí Jerusalẹmu. Jesu sì ń lọ níwájú wọn, bí àwọn ọmọ-ẹ̀yìn ti ń tẹ̀lé e, ìbẹ̀rù kún ọkàn wọn. Ó sì tún mú àwọn méjìlá sí apá kan, ó sì bẹ̀rẹ̀ sí ṣàlàyé ohun gbogbo tí a ó ṣe sí i fún wọn.
\v 33 Ó sọ fún wọn pé, \wj “Àwa ń gòkè lọ Jerusalẹmu, a ó sì fi Ọmọ Ènìyàn lé àwọn olórí àlùfáà àti àwọn olùkọ́ òfin lọ́wọ́. Wọn ni yóò dá lẹ́bi ikú. Wọn yóò sì fà á lé ọwọ́ àwọn aláìkọlà.\wj*
\v 34 \wj Wọn yóò fi ṣe ẹlẹ́yà, wọn yóò tutọ́ sí ní ara, wọn yóò nà pẹ̀lú pàṣán wọn. Wọn yóò sì pa, ṣùgbọ́n lẹ́yìn ọjọ́ mẹ́ta yóò tún jíǹde.”\wj*
\s1 Ìbéèrè Johanu àti Jakọbu
\p 
\v 35 Lẹ́yìn èyí, Jakọbu àti Johanu, àwọn ọmọ Sebede wá sọ́dọ̀ Jesu. Wọ́n sì bá a sọ̀rọ̀ kẹ́lẹ́kẹ́lẹ́, wọ́n wí pé, “Olùkọ́, inú wa yóò dùn bí ìwọ bá lè ṣe ohunkóhun tí a bá béèrè fún wa.”
\p 
\v 36 Jesu béèrè pé, \wj “Kí ni Ẹ̀yin ń fẹ́ kí èmi ó ṣe fún un yín?”\wj*
\p 
\v 37 Wọ́n bẹ̀bẹ̀ pé, “Jẹ́ kí ọ̀kan nínú wa jókòó ní ọwọ́ ọ̀tún rẹ àti ẹnìkejì ní ọwọ́ òsì nínú ògo rẹ!”
\p 
\v 38 Ṣùgbọ́n Jesu dá wọn lóhùn pé, \wj “Ẹ kò mọ ohun tí ẹ̀ ń béèrè! Ṣe ẹ lè mu nínú ago kíkorò tí èmi ó mú tàbí a lè bamitiisi yín pẹ̀lú irú ì bamitiisi ìjìyà tí a ó fi bamitiisi mi?”\wj*
\p 
\v 39 Àwọn méjèèjì dáhùn pé, “Àwa pẹ̀lú lè ṣe bẹ́ẹ̀.”
\p Jesu wí fún wọn pé, \wj “Lóòótọ́ ni ẹ̀yin ó mu ago ti èmi yóò mu, àti bamitiisi tí a sí bamitiisi mi ni a ó fi bamitiisi yín,\wj*
\v 40 \wj ṣùgbọ́n láti jókòó ní ọwọ́ ọ̀tún mi àti ní ọwọ́ òsì mi kì ì ṣe ti èmi láti fi fún ni: bí kò ṣe fún àwọn ẹni tí a ti pèsè rẹ̀ sílẹ̀ fún.”\wj*
\p 
\v 41 Nígbà tí àwọn ọmọ-ẹ̀yìn mẹ́wàá ìyókù gbọ́ ohun tí Jakọbu àti Johanu béèrè, wọ́n bínú.
\v 42 Nítorí ìdí èyí, Jesu pè wọ́n sọ́dọ̀, ó sì wí fún wọn pé, \wj “Gẹ́gẹ́ bí ẹ̀yin ti mọ̀ pé, àwọn ọba àti àwọn kèfèrí ń lo agbára lórí àwọn ènìyàn.\wj*
\v 43 \wj Ṣùgbọ́n láàrín yín ko gbọdọ̀ ri bẹ. Ẹnikẹ́ni tí ó bá fẹ́ di olórí nínú yín gbọdọ̀ ṣe ìránṣẹ́.\wj*
\v 44 \wj Ẹnikẹ́ni tí ó fẹ́ di aṣáájú nínú yín gbọdọ̀ ṣe ìránṣẹ́ gbogbo yín.\wj*
\v 45 \wj Nítorí, Èmi, Ọmọ Ènìyàn kò wá sí ayé kí ẹ lè ṣe ìránṣẹ́ fún mi, ṣùgbọ́n láti lè ṣe ìránṣẹ́ fun àwọn ẹlòmíràn, àti láti fi ẹ̀mí rẹ̀ ṣe ìràpadà ọ̀pọ̀ ènìyàn.”\wj*
\v 46 Wọ́n dé Jeriko, bí Jesu àti àwọn ọmọ-ẹ̀yìn rẹ̀ àti ọ̀pọ̀ ènìyàn ti fẹ́ kúrò ní ìlú Jeriko, ọkùnrin afọ́jú kan, Bartimeu, ọmọ Timeu jókòó lẹ́gbẹ̀ẹ́ ọ̀nà ó ń ṣagbe.
\s1 Bartimeu afọ́jú gba ìwòsàn
\p 
\v 47 Nígbà tí Bartimeu gbọ́ pé Jesu ti Nasareti wà nítòsí, o bẹ̀rẹ̀ sí kígbe lóhùn rara pé, “Jesu ọmọ Dafidi, ṣàánú fún mi.”
\p 
\v 48 Àwọn tó wà níbẹ̀ kígbe mọ́ ọn pé, “Pa ẹnu rẹ mọ́.” Ṣùgbọ́n dípò kí ó pa ẹnu mọ́, ṣe ló ń kígbe lóhùn rara pé, “Jesu ọmọ Dafidi ṣàánú fún mi.”
\p 
\v 49 Nígbà tí Jesu gbọ́ igbe rẹ̀, ó dẹ́sẹ̀ dúró lójú ọ̀nà, ó sì wí pé, \wj “Ẹ pè é kí ó wá sọ́dọ̀ mi.”\wj*
\p Nítorí náà wọ́n pe ọkùnrin afọ́jú náà, wọ́n wí pé, “Tújúká! Dìde lórí ẹsẹ̀ rẹ! Ó ń pè ọ́.”
\v 50 Lẹ́sẹ̀kan náà, Bartimeu bọ́ agbádá rẹ̀ sọnù, ó fò sókè, ó sì wá sọ́dọ̀ Jesu.
\p 
\v 51 Jesu béèrè lọ́wọ́ rẹ̀ pé, \wj “Kí ni ìwọ fẹ́ kí èmi kí ó ṣe fún ọ?”\wj*
\p Afọ́jú náà dáhùn pé, “Rabbi, jẹ́ kí èmi kí ó ríran.”
\p 
\v 52 Jesu wí fún un pé, \wj “Máa lọ, ìgbàgbọ́ rẹ ti mú ọ láradá.”\wj* Lẹ́sẹ̀kẹsẹ̀, ọkùnrin afọ́jú náà ríran ó sì ń tẹ̀lé Jesu lọ ní ọ̀nà.
\c 11
\s1 Jesu fi ẹ̀yẹ wọ Jerusalẹmu bi ọba
\p 
\v 1 Bí wọ́n ti súnmọ́ Betfage àti Betani ní ẹ̀yìn odi ìlú Jerusalẹmu, wọ́n dé orí òkè olifi. Jesu rán méjì nínú àwọn ọmọ-ẹ̀yìn rẹ̀ síwájú.
\v 2 Ó pàṣẹ fún wọn pé, \wj “Ẹ lọ sí abúlé tó wà lọ́hùn ún nì. Nígbà tí ẹ bá sì wọlé, ẹ̀yin yóò rí ọmọ kẹ́tẹ́kẹ́tẹ́ tí a so mọ́lẹ̀ tí ẹnikẹ́ni kò ì tí i gùn rí. Ẹ tú u, kí ẹ sì mú wá sí ibi yìí.\wj*
\v 3 \wj Bí ẹnikẹ́ni bá bi yín pé, ‘Kí ló dé tí ẹ fi ń ṣe èyí?’ Ẹ sọ fún un pé, ‘Olúwa ní í fi ṣe, yóò sì dá a padà síbí láìpẹ́.’ ”\wj*
\p 
\v 4 Àwọn ọmọ-ẹ̀yìn méjì náà lọ bí ó ti rán wọn. Wọ́n rí ọmọ kẹ́tẹ́kẹ́tẹ́ náà tí a so ní ẹnu-ọ̀nà lóde ní ìta gbangba, wọ́n sì tú u.
\v 5 Bí wọ́n ti ń tú u, díẹ̀ nínú àwọn tí ó dúró níbẹ̀ bi wọ́n léèrè pé, “Ki ni ẹyin n ṣe, tí ẹ̀yin fi ń tú ọmọ kẹ́tẹ́kẹ́tẹ́ n nì?”
\v 6 Wọ́n sì wí fún wọn gẹ́gẹ́ bí Jesu ti ní kí wọ́n sọ, wọ́n sì jọ̀wọ́ wọn lọ́wọ́ lọ.
\v 7 Wọ́n fa ọmọ kẹ́tẹ́kẹ́tẹ́ náà tọ Jesu wá. Wọ́n tẹ́ aṣọ wọn sí ẹ̀yìn rẹ̀, òun sì jókòó lórí rẹ̀.
\v 8 Àwọn púpọ̀ tẹ́ aṣọ wọn sí ọ̀nà. Àwọn mìíràn ṣẹ́ ẹ̀ka igi, wọ́n sì fọ́n wọn sí ọ̀nà.
\v 9 Àti àwọn tí ń lọ níwájú, àti àwọn tí ń bọ̀ lẹ́yìn, gbogbo wọn sì ń kígbe wí pé,
\q1 “Hosana!”
\b
\q1 “Olùbùkún ni ẹni náà tí ó ń bọ̀ wà ní orúkọ Olúwa!”
\b
\q1 
\v 10 “Olùbùkún ni fún ìjọba tí ń bọ̀ wá, ìjọba Dafidi, baba wa!”
\b
\q1 “Hosana lókè ọ̀run!”
\p 
\v 11 Jesu wọ Jerusalẹmu ó sì lọ sí inú tẹmpili. Ó wo ohun gbogbo yíká fínní fínní. Ó sì kúrò níbẹ̀, nítorí pé ilẹ̀ ti ṣú. Ó padà lọ sí Betani pẹ̀lú àwọn ọmọ-ẹ̀yìn rẹ̀ méjìlá.
\s1 Jesu palẹ̀ tẹmpili mọ́
\p 
\v 12 Ní òwúrọ̀ ọjọ́ kejì, bí wọ́n ti kúrò ní Betani, ebi ń pa Jesu.
\v 13 Ó rí igi ọ̀pọ̀tọ́ kan lọ́ọ̀ọ́kán tí ewé kún orí rẹ̀. Nígbà náà, ó lọ sí ìdí rẹ̀ láti wò ó bóyá ó léso tàbí kò léso. Nígbà tí ó dé ibẹ̀, ewé lásán ni ó rí, kò rí èso lórí rẹ̀. Nítorí pé àkókò náà kì í ṣe àkókò tí igi ọ̀pọ̀tọ́ máa ń so.
\v 14 Lẹ́yìn náà, Jesu pàṣẹ fún igi náà pé, \wj “Kí ẹnikẹ́ni má ṣe jẹ èso lórí rẹ mọ́ títí láé.”\wj* Àwọn ọmọ-ẹ̀yìn rẹ̀ gbọ́ nígbà tí ó wí bẹ́ẹ̀.
\p 
\v 15 Nígbà ti wọ́n padà sí Jerusalẹmu, ó wọ inú tẹmpili. Ó bẹ̀rẹ̀ sí nílé àwọn oníṣòwò àti àwọn oníbàárà wọn síta. Ó ti tábìlì àwọn tí ń pààrọ̀ owó nínú tẹmpili ṣubú. Bákan náà ni ó ti ìjókòó àwọn tí ń ta ẹyẹlé lulẹ̀.
\v 16 Kò sì gba ẹnikẹ́ni láààyè láti gbé ẹrù ọjà títà gba inú tẹmpili wọlé.
\v 17 Gẹ́gẹ́ bí ó ti kọ́ wọn, ó wí pé, \wj “Ṣé a kò ti kọ ọ́ pé: ‘Ilé àdúrà ni a o máa pe ilé mi, ní gbogbo orílẹ̀-èdè?’ Ṣùgbọ́n ẹ̀yin ti sọ ọ́ di ibùgbé àwọn ọlọ́ṣà.”\wj*
\p 
\v 18 Nígbà tí àwọn olórí àlùfáà àti àwọn olùkọ́ òfin gbọ́ ohun tí ó ti ṣe, wọ́n bẹ̀rẹ̀ sí ń gbà èrò bí wọn yóò ti ṣe pa á. Wọ́n bẹ̀rù rògbòdìyàn tí yóò bẹ́ sílẹ̀, nítorí tí àwọn ènìyàn ní ìgbóná ọkàn sí ẹ̀kọ́ rẹ̀.
\p 
\v 19 Ní ìrọ̀lẹ́ ọjọ́ náà, bí ìṣe wọn, Jesu àti àwọn ọmọ-ẹ̀yìn rẹ̀ jáde kúrò ní ìlú Jerusalẹmu.
\s1 Igi ọ̀pọ̀tọ́ tí kò ní eṣo
\p 
\v 20 Ní òwúrọ̀ ọjọ́ kejì, bí wọ́n ti ń kọjá lọ, wọ́n rí igi ọ̀pọ̀tọ́ tí Jesu fi bú. Wọ́n rí i pé ó ti gbẹ tigbòǹgbò tigbòǹgbò.
\v 21 Peteru rántí pé Jesu ti bá igi náà wí. Nígbà náà ni ó sọ fún Jesu pé, “Rabbi, wò ó! Igi ọ̀pọ̀tọ́ tí ìwọ fi bú ti gbẹ!”
\p 
\v 22 Jesu sì dáhùn pé, \wj “Ẹ ní ìgbàgbọ́ nínú Ọlọ́run.\wj*
\v 23 \wj Lóòótọ́ ni mò wí fún un yín, bí ẹnikẹ́ni bá wí fún òkè ‘Ṣídìí, gbé ara rẹ sọ sínú Òkun,’ ti kò sì ṣe iyèméjì nínú ọkàn rẹ̀ ṣùgbọ́n tí ó gbàgbọ́ pé ohun tí òun wí yóò ṣẹ, yóò rí bẹ́ẹ̀ fún un.\wj*
\v 24 \wj Torí náà, mo wí fún yín ohunkóhun tí ẹ bá béèrè fún nínú àdúrà, ẹ ní ìgbàgbọ́ pé, ó tí tẹ̀ yín lọ́wọ́, yóò sì jẹ́ tiyín.\wj*
\v 25 \wj Nígbà tí ẹ bá ń gbàdúrà, ẹ kọ́kọ́ dáríjì, bí ẹ̀yin bá ní ohunkóhun sí ẹnikẹ́ni, kí baba yín tí ń bẹ ní ọ̀run bá à le dárí àwọn ẹ̀ṣẹ̀ tiyín náà jì yín.”\wj*\f + \fr 11:25 \ft Àwọn àkọsílẹ̀ àtijọ́ ìwé Marku kan se àfikún ọ̀rọ̀ yìí \fqa yín. \fv 26 \fqa Ṣùgbọ́n bí ẹ̀yin bá kọ̀ láti dárí ẹ̀ṣẹ̀ àwọn ènìyàn jì wọ́n, baba yín kò ní í dárí ẹ̀ṣẹ̀ yín jì yín\ft .\f*
\p 
\v 27 Lẹ́yìn èyí, wọ́n tún padà sí Jerusalẹmu.
\s1 Ìbéèrè àṣẹ tí Jesu ní
\p Bí Jesu ti ń rìn kiri ni tẹmpili, àwọn olórí àlùfáà àti àwọn olùkọ́ òfin pẹ̀lú àwọn àgbàgbà Júù wá sọ́dọ̀ rẹ̀.
\v 28 Wọ́n béèrè lọ́wọ́ rẹ̀ pé, “Àṣẹ wo ni ó fi ń ṣe nǹkan yìí? Ta ni ó sì fún ọ ni àṣẹ yìí láti máa ṣe nǹkan wọ̀nyí?”
\p 
\v 29 Jesu dá wọn lóhùn pé, \wj “Èmi yóò bi yín léèrè ọ̀rọ̀ kan, kí ẹ sì dá mi lóhùn, èmi yóò sọ fún yín àṣẹ tí èmi fi ń ṣe nǹkan wọ̀nyí.”\wj*
\v 30 \wj Ìtẹ̀bọmi Johanu láti ọ̀run wa ni, tàbí láti ọ̀dọ̀ ènìyàn? “Ẹ dá mi lóhùn!”\wj*
\p 
\v 31 Wọ́n bá ara wọn jíròrò pé, “Bí a bá wí pé, ‘Láti ọ̀run wá ni,’ òun ó wí pé, ‘Nígbà tí ẹ mọ̀ bẹ́ẹ̀, èéṣe tí ẹ kò fi gbà à gbọ́?’
\v 32 Ṣùgbọ́n bí a bá wí pé, àti ọ̀dọ̀ ènìyàn, wọ́n bẹ̀rù àwọn ènìyàn, nítorí pé gbogbo ènìyàn ló gbàgbọ́ pé wòlíì gidi ni Johanu.”
\p 
\v 33 Nítorí náà, wọ́n kọjú sí Jesu wọn sì dáhùn pé, “Àwa kò mọ̀.”
\p Nígbà náà ni Jesu wí pé, \wj “Níwọ́n ìgbà tí ẹ kò lè dáhùn ìbéèrè mi, Èmi náà kì yóò sọ fún yín àṣẹ tí mo fi ń ṣe nǹkan wọ̀nyí.”\wj*
\c 12
\s1 Òwe àwọn ayálégbé
\p 
\v 1 Lẹ́yìn ìgbà tí Jesu pa àwọn olórí ẹ̀sìn lẹ́nu mọ́, ó bẹ̀rẹ̀ sí í fi òwe bá wọn sọ̀rọ̀ pé, \wj “Ọkùnrin kan gbin ọgbà àjàrà kan. Ó ṣe ọgbà yìí ká, ó sì wá ibi ìfúntí wáìnì, ó sì kọ́ ilé ìṣọ́ sí i ó sì fi ṣe àgbàtọ́jú fún àwọn olùṣọ́gbà, ó sì lọ sí ìrìnàjò tí ó jìnnà.\wj*
\v 2 \wj Lákokò ìkórè, ọkùnrin náà rán ọ̀kan nínú àwọn ọmọ ọ̀dọ̀ rẹ̀ sí àwọn olùṣọ́gbà náà, kí ó gbà nínú èso ọgbà àjàrà náà lọ́wọ́ àwọn olùṣọ́gbà.\wj*
\v 3 \wj Ṣùgbọ́n àwọn àgbẹ̀ wọ̀n-ọn-nì lu ìránṣẹ́ ọkùnrin náà, wọ́n sì rán an padà lọ́wọ́ òfo.\wj*
\v 4 \wj Ó sì tún rán ọmọ ọ̀dọ̀ mìíràn sí wọn. Bí àwọn àgbẹ̀ ti tún rí ọmọ ọ̀dọ̀ tí ó rán sí wọn; wọ́n lù ú. Àní, wọ́n tilẹ̀ dá ọgbẹ́ sí i lórí, wọn rán an lọ ni ìtìjú.\wj*
\v 5 \wj Ó sì tún rán òmíràn, èyí n nì wọ́n sì pa, àti ọ̀pọ̀ mìíràn, wọ́n lu òmíràn wọ́n sì pa òmíràn.\wj*
\p 
\v 6 \wj “Ìránṣẹ́ kan ṣoṣo ló kù tí Baba olóko kò ì tí ì rán níṣẹ́, èyí ni ọmọ òun tìkára rẹ̀. Níkẹyìn ó ran an sí àwọn olùṣọ́gbà náà, pẹ̀lú èrò pé, ‘Wọn yóò bu ọlá fún ọmọ òun.’\wj*
\p 
\v 7 \wj “Ṣùgbọ́n àwọn olùṣọ́gbà wọ̀n-ọn-nì wí fún ara wọn pé, ‘Èyí yìí ni àrólé. Ẹ wá, ẹ jẹ́ kí a pa á, ogún rẹ̀ yóò sì jẹ́ tiwa.’\wj*
\v 8 \wj Báyìí ni wọ́n mú ọmọ náà tí wọ́n pa á. Wọ́n sì wọ́ òkú rẹ̀ jáde kúrò nínú ọgbà àjàrà náà.\wj*
\p 
\v 9 \wj “Kí ni olúwa ọgbà àjàrà yóò ṣe nígbà tí ó bá gbọ́ ohun tí ó ṣẹlẹ̀. Dájúdájú yóò pa àwọn ẹni ibi wọ̀nyí. Yóò sì gba àwọn olùtọ́jú mìíràn sínú oko rẹ̀.\wj*
\v 10 \wj Tàbí ẹ̀yin kò ì tí ka ẹsẹ yìí nínú ìwé mímọ́:\wj*
\q1 \wj “ ‘Òkúta tí àwọn ọ̀mọ̀lé kọ̀sílẹ̀\wj*
\q2 \wj òun náà ni ó di pàtàkì igun ilé.\wj*
\q1 
\v 11 \wj Èyí ni iṣẹ́ Olúwa\wj*
\q2 \wj ó sì jẹ́ ìyàlẹ́nu lójú tiwa’?”\wj*
\p 
\v 12 Àwọn olórí àlùfáà àti àwọn olùkọ́ òfin pẹ̀lú àwọn àgbàgbà fẹ́ mú Jesu lákokò náà. Nítorí tí wọ́n mọ̀ pé àwọn ló ń pòwe mọ́ nínú ọ̀rọ̀ rẹ̀. Àwọn ni alágbàtọ́jú búburú nínú ìtàn rẹ̀. Ṣùgbọ́n ẹ̀rù ń bà wọ́n láti fọwọ́ kàn án nítorí pé wọ́n bẹ̀rù ìhùwàsí ọ̀pọ̀ ènìyàn tó wà lọ́dọ̀ rẹ̀. Nítorí náà wọ́n fi í sílẹ̀ lọ.
\s1 Sísan owó orí fún Kesari
\p 
\v 13 Ṣùgbọ́n wọ́n rán àwọn Farisi pẹ̀lú àwọn kan tí í ṣe ọmọ-ẹ̀yìn Herodu wá sọ́dọ̀ Jesu, láti fi ọ̀rọ̀ wá a lẹ́nu wò, títí yóò fi sọ ohun kan kí wọn lè rí fi mú.
\v 14 Bí wọn ti dé ọ̀dọ̀ rẹ̀, wọ́n wí pé, “Olùkọ́, àwa mọ̀ pé ìwọ máa ń sọ òtítọ́ láìsí ìbẹ̀rù ẹnikẹ́ni. Ṣùgbọ́n òtítọ́ ọ̀rọ̀ Ọlọ́run ni ìwọ máa ń kọ́ni. Nísinsin yìí, sọ fún wa, ó tọ́ tàbí kò tọ́ láti máa san owó orí fún Kesari?”
\v 15 Kí àwa kí ó fi fún un, tàbí kí a máa fi fún un?
\p Ṣùgbọ́n Jesu mọ ìwà àgàbàgebè wọn. Ó sì wí pé, \wj “Èéṣe tí ẹ̀yin fi n fi èyí dán mi wo? Ẹ mú owó idẹ kan wá kí n wò ó.”\wj*
\v 16 Nígbà tí wọ́n mú owó idẹ náà fún un, ó bi wọ́n léèrè pé, \wj “Ẹ wò ó! Àwòrán àti orúkọ ta ni ó wà níbẹ̀?”\wj*
\p Wọ́n dáhùn pé, “Àwòrán àti orúkọ Kesari ni.”
\p 
\v 17 Nígbà náà ni Jesu wí fún wọn pé, \wj “Bí ó bá rí bẹ́ẹ̀, ẹ fi ohun tí ó bá jẹ́ ti Kesari fún Kesari. Ṣùgbọ́n ẹ fi ohun gbogbo tí í ṣe ti Ọlọ́run fún Ọlọ́run.”\wj*
\p Ẹnu sì yà wọ́n gidigidi sí èsì rẹ̀.
\s1 Ìgbéyàwó ní àjíǹde
\p 
\v 18 Àwọn Sadusi tún wá sọ́dọ̀ rẹ̀, àwọn wọ̀nyí kò gbàgbọ́ pé àjíǹde ń bẹ. Ìbéèrè wọn ni pé,
\v 19 “Olùkọ́, Mose fún wa ní òfin pé, nígbà tí ọkùnrin kan bá kú láìbí ọmọ, arákùnrin rẹ̀ gbọdọ̀ ṣú ìyàwó náà lópó kí wọn sì bímọ ní orúkọ ọkọ tí ó kú náà.
\v 20 Ǹjẹ́ àwọn arákùnrin méje kan wà, èyí tí ó dàgbà jùlọ gbéyàwó, ó sì kú ní àìlọ́mọ.
\v 21 Arákùnrin rẹ̀ kejì ṣú obìnrin tí ó fi sílẹ̀ lópó, láìpẹ́, òun pẹ̀lú tún kú láìbímọ. Arákùnrin kẹta tó ṣú obìnrin yìí lópó tún kú bákan náà láìbímọ.
\v 22 Àwọn méjèèje sì ṣú u lópó, wọn kò sì fi ọmọ sílẹ̀. Ní ìkẹyìn gbogbo wọn, obìnrin náà kú pẹ̀lú.
\v 23 Ǹjẹ́ ní àjíǹde, nígbà tí wọ́n bá jíǹde, aya ta ni yóò ha ṣe nínú wọn? Àwọn méjèèje ni ó sá ni ní aya?”
\p 
\v 24 Jesu dáhùn ó wí fún wọn pé, \wj “Kì í há ṣe nítorí èyí ni ẹ ṣe ṣìnà, pé ẹ̀yin kò mọ ìwé Mímọ́, tàbí agbára Ọlọ́run.\wj*
\v 25 \wj Nítorí pé, nígbà tí àwọn arákùnrin méje yìí àti obìnrin náà bá jí dìde nínú òkú, a kò ní ṣe ìgbéyàwó fún wọn. Wọn yóò dàbí àwọn angẹli tí ń bẹ ní ọ̀run.\wj*
\v 26 \wj Ṣùgbọ́n nísinsin yìí, nípa bóyá àjíǹde yóò wà. Àbí ẹ̀yin kò ì tí ka ìwé Eksodu, nípa Mose àti pápá tí ń jó? Ọlọ́run sọ fún Mose pé, ‘Èmi ni Ọlọ́run Abrahamu, Ọlọ́run Isaaki àti Ọlọ́run Jakọbu.’\wj*
\v 27 \wj Òun kì í ṣe Ọlọ́run àwọn òkú bí kò ṣe Ọlọ́run àwọn alààyè: nítorí ẹ̀yin ṣe àṣìṣe gidigidi.”\wj*
\s1 Òfin tí ó ga jùlọ
\p 
\v 28 Ọ̀kan nínú àwọn olùkọ́ òfin ti ó dúró níbẹ̀ tí ó sì fetísílẹ̀ dáradára sí àròyé yìí ṣàkíyèsí pé, Jesu ti dáhùn dáradára. Òun pẹ̀lú sì béèrè lọ́wọ́ Jesu pé, “Nínú gbogbo òfin, èwo ló ṣe pàtàkì jùlọ?”
\p 
\v 29 Jesu dá ọkùnrin yìí lóhùn pé, \wj “Èyí tó ṣe pàtàkì jùlọ nínú àwọn òfin ni èyí tí ó kà báyìí pé, ‘Gbọ́ Israẹli; Olúwa Ọlọ́run wa Olúwa kan ni.\wj*
\v 30 \wj Kí ìwọ kí ó fi gbogbo àyà rẹ, àti gbogbo ọkàn rẹ, àti gbogbo ẹ̀mí rẹ, àti gbogbo agbára rẹ fẹ́ Olúwa Ọlọ́run rẹ, èyí ní òfin kìn-ín-ní.’\wj*
\v 31 \wj Èkejì ni pé: ‘Fẹ́ ọmọnìkejì rẹ.’ Kò sí òfin mìíràn tó ga ju méjèèjì yìí lọ.”\wj*
\p 
\v 32 Olùkọ́ òfin náà dáhùn pé, “Olùkọ́, ìwọ sọ òtítọ́ nípa pé Ọlọ́run kan ni ó ń bẹ, àti pé kò sí òmíràn àfi òun nìkan.
\v 33 Àti kí a fi gbogbo àyà, àti gbogbo òye, àti gbogbo ọkàn àti gbogbo agbára fẹ́ ẹ, àti fẹ́ ọmọnìkejì ẹni bí ara ẹni, ó ju gbogbo ẹbọ sísun, àti ẹbọ lọ.”
\p 
\v 34 Jesu rí i dájú pé òye ọkùnrin yìí ga, nítorí náà, Jesu sọ fún un pé, \wj “Arákùnrin, ìwọ kò jìnà sí à ti dé ìjọba Ọ̀run.”\wj* Láti ìgbà náà lọ, ẹnikẹ́ni kò tún béèrè ohun kan lọ́wọ́ Jesu.
\s1 Ọmọ ta ni Kristi ń ṣe?
\p 
\v 35 Lẹ́yìn náà, nígbà tí Jesu ń kọ́ àwọn ènìyàn nínú tẹmpili, ó béèrè lọ́wọ́ wọn pé, \wj “Èéṣe tí àwọn olùkọ́ òfin fi gbà wí pé Kristi náà ní láti jẹ́ ọmọ Dafidi?\wj*
\v 36 \wj Nítorí tí Dafidi tìkára rẹ̀, ti ń ti ipa Ẹ̀mí Mímọ́ sọ̀rọ̀ wí pé:\wj*
\q1 \wj “ ‘Olúwa sọ fún Olúwa mi pé:\wj*
\q2 \wj “Jókòó ní ọwọ́ ọ̀tún mi,\wj*
\q1 \wj títí èmi yóò fi sọ àwọn ọ̀tá rẹ\wj*
\q2 \wj di àpótí ìtìsẹ̀ rẹ.” ’\wj*
\m 
\v 37 \wj Níwọ́n ìgbà tí Dafidi tìkára rẹ̀ pè é ní ‘Olúwa,’ báwo ni ó túnṣe lè jẹ́ ọmọ rẹ̀?”\wj*
\p Ọ̀pọ̀ ènìyàn sì fi ayọ̀ gbọ́ ọ̀rọ̀ rẹ̀.
\p 
\v 38 Ó sì wí fún wọn nínú ẹ̀kọ́ rẹ̀ pé, \wj “Ẹ ṣọ́ra fun àwọn olùkọ́ òfin tí wọ́n fẹ́ láti máa wọ aṣọ gígùn káàkiri, tí wọ́n sì fẹ́ ìkíni ní ọjà,\wj*
\v 39 \wj àti ibùjókòó ọlá nínú Sinagọgu àti ipò ọlá níbi àsè.\wj*
\v 40 \wj Àwọn tí wọ́n jẹ ilé àwọn opó rún, tí wọ́n sì ń gbàdúrà gígùn fún àṣehàn, nítorí èyí, ìjìyà wọn yóò pọ̀ púpọ̀.”\wj*
\s1 Ọ̀rẹ́ opó
\p 
\v 41 Jesu jókòó ní òdìkejì kọjú sí àpótí ìṣúra: ó ń wo ìjọ ènìyàn ti ń sọ owó sínú àpótí ìṣúra, ọ̀pọ̀ àwọn ọlọ́rọ̀ sì sọ púpọ̀ sí i.
\v 42 Ṣùgbọ́n obìnrin opó kan wà, ó sì fi ààbọ̀ owó idẹ méjì síbẹ̀, tí ì ṣe ìdá méjì owó-babà kan sínú rẹ̀.
\p 
\v 43 Jesu pe àwọn ọmọ-ẹ̀yìn rẹ̀, ó sọ fún wọn wí pé, \wj “Lóòótọ́ ni mo wí fún yin pé, tálákà opó yìí sọ sínú àpótí ìṣúra ju gbogbo àwọn ìyókù to sọ sínú rẹ lọ.\wj*
\v 44 \wj Nítorí pé, àwọn ìyókù mú nínú ọ̀pọ̀ ìní wọ́n, ṣùgbọ́n ní tirẹ̀, nínú àìní rẹ̀, ó sọ gbogbo ohun tí ó ní náà sílẹ̀ àní gbogbo ìní rẹ̀.”\wj*
\c 13
\s1 Àwọn àmì òpin ayé
\p 
\v 1 Bí Jesu ti ń jáde láti inú tẹmpili ní ọjọ́ náà, ọ̀kan nínú ọmọ-ẹ̀yìn rẹ̀ sọ fún un pé, “Olùkọ́, wo ilé ńlá tí ó dára wọ̀nyí. Sì wo òkúta tí a ṣe lọ́ṣọ̀ọ́ lára àwọn ògiri ilé náà.”
\p 
\v 2 Jesu dáhùn pé, \wj “Ìwọ rí ilé ńlá wọ̀nyí? Kì yóò sí òkúta kan tí a ó fi sílẹ̀ lórí èkejì tí a kì yóò wó lulẹ̀.”\wj*
\p 
\v 3 Bí Jesu si ti jókòó lórí òkè olifi tí ó kọjú sí tẹmpili, Peteru, Jakọbu, Johanu àti Anderu wà pẹ̀lú rẹ̀ níbẹ̀, wọ́n bi í léèrè ni ìkọ̀kọ̀ pé,
\v 4 “Sọ fún wa, nígbà wo ni nǹkan wọ̀nyí yóò ṣẹlẹ̀ sí tẹmpili náà? Kí ni yóò sì jẹ́ àmì nígbà tí gbogbo nǹkan wọ̀nyí yóò ṣẹ?”
\p 
\v 5 Jesu kìlọ̀ fún wọn pé, \wj “Ẹ má ṣe jẹ́ kí ẹnikẹ́ni tàn yín.\wj*
\v 6 \wj Nítorí pé ọ̀pọ̀lọpọ̀ yóò wá ní orúkọ mi, wọn yóò wí pé, ‘Èmi ni Kristi,’ wọn yóò tan ọ̀pọ̀ ènìyàn jẹ.\wj*
\v 7 \wj Nígbà tí ẹ̀yin bá ń gbọ́ ìró ogun àti ìdágìrì ogun, kí ẹ̀yin má ṣe jáyà, nítorí irú nǹkan wọ̀nyí kò le ṣe kí ó má ṣẹlẹ̀, ṣùgbọ́n òpin náà kì í ṣe ìgbà yìí.\wj*
\v 8 \wj Orílẹ̀-èdè yóò dìde sí orílẹ̀-èdè, àti ìjọba sí ìjọba ilẹ̀ yóò máa jì ní ibi púpọ̀. Ìyàn yóò sì wà níbi gbogbo. Gbogbo nǹkan wọ̀nyí ni ìbẹ̀rẹ̀ ìpọ́njú tí ń bọ̀ níwájú.\wj*
\p 
\v 9 \wj “Ṣùgbọ́n nígbà tí àwọn nǹkan wọ̀nyí bá bẹ̀rẹ̀ sí i ṣẹlẹ̀, ẹ kíyèsára! Nítorí ẹ̀yin yóò wà nínú ewu. Wọn yóò fà yín lọ ilé ẹjọ́ gbogbo. Wọn yóò fi ìyà jẹ yín nínú Sinagọgu wọn. Àwọn ènìyàn yóò fẹ̀sùn kàn yín níwájú àwọn baálẹ̀ àti níwájú àwọn ọba nítorí orúkọ mi, fún ẹ̀rí fún wọn.\wj*
\v 10 \wj Nítorí pé ẹ gbọdọ̀ kọ́kọ́ wàásù ìyìnrere náà fún gbogbo orílẹ̀-èdè kí òpin tó dé.\wj*
\v 11 \wj Ṣùgbọ́n nígbà tí wọ́n bá ń fà yín lọ, tí wọ́n bá sì ń fi yín lé wọn lọ́wọ́, ẹ má ṣe ṣàníyàn ṣáájú ohun tí ẹ ó sọ. Ṣùgbọ́n ohun tí bá fi fún yín ní wákàtí náà, òun ni kí ẹ̀yin kí ó wí. Nítorí kì í ṣe ẹ̀yin ni ó ń wí, bí kò ṣe Ẹ̀mí Mímọ́.\wj*
\p 
\v 12 \wj “Arákùnrin yóò máa fi ẹ̀sùn kan arákùnrin rẹ̀, tí yóò sì yọrí sí ikú. Baba yóò máa ṣe ikú pa ọmọ rẹ̀. Àwọn ọmọ yóò máa dìtẹ̀ sí òbí wọn. Àní, àwọn ọmọ pẹ̀lú yóò máa ṣe ikú pa òbí wọn.\wj*
\v 13 \wj Àwọn ènìyàn yóò kórìíra yín nítorí tí ẹ jẹ́ tèmi. Ṣùgbọ́n ẹni tó bá fi ara da ìyà títí dé òpin tí kò sì kọ̀ mí sílẹ̀ òun ni yóò rí ìgbàlà.\wj*
\p 
\v 14 “\wj Ṣùgbọ́n nígbà tí ẹ̀yin bá rí ìríra ìsọdahoro, tí ó dúró níbí tí kò yẹ (ẹnikẹ́ni tí ó bá kà á kí ó yé e), nígbà náà ni kí àwọn tí ń bẹ ni Judea sálọ sí orí òkè.\wj*
\v 15 \wj Kí ẹni ti ń bẹ lórí ilé má ṣe sọ̀kalẹ̀ lọ sínú ilé, bẹ́ẹ̀ ni kí ó má sì ṣe wọ inú rẹ̀, láti mú ohunkóhun jáde nínú ilé rẹ̀.\wj*
\v 16 \wj Kí ẹni tí ó wà lóko má ṣe padà sẹ́yìn láti wá mú aṣọ rẹ̀.\wj*
\v 17 \wj Ègbé ní fún àwọn tí ó lóyún, àti fún obìnrin tí ń fún ọ́mọ lọ́mú ní ọjọ́ wọ̀nyí.\wj*
\v 18 \wj Kí ẹ sì máa gbàdúrà pé èyí ṣẹlẹ̀ ní àkókò òtútù.\wj*
\v 19 \wj Nítorí ọjọ́ wọ̀n-ọn-nì yóò jẹ́ àkókò ìpọ́njú, irú èyí tí kò ì ṣẹlẹ̀ láti ìbẹ̀rẹ̀ ẹ̀dá Ọlọ́run. Irú rẹ̀ kò sì ni ṣẹlẹ̀ mọ́.\wj*
\p 
\v 20 \wj “Àfi tí Olúwa bá gé àkókò ìjìyà náà kúrú, ẹyọ ẹ̀mí kan ní ayé kì yóò là. Ṣùgbọ́n nítorí àwọn tí Ọlọ́run yàn, ni yóò ṣe dín àwọn ọjọ́ náà kù.\wj*
\v 21 \wj Nígbà náà, bí ẹnikẹ́ni bá sọ fún un yín pé, ‘Ẹ wò ó, Kristi wa níbi yìí!’ tàbí, sọ fún un yín pé, ‘Ẹ wò ó, ó wà lọ́hùn ún nì!’ Ẹ má ṣe gbà wọ́n gbọ́.\wj*
\v 22 \wj Nítorí àwọn èké Kristi àti àwọn wòlíì èké ni yóò wá, wọn yóò sì fi iṣẹ́ ìyanu tí yóò tan ènìyàn jẹ hàn. Bí ó bá ṣe é ṣe, wọn yóò tan àwọn àyànfẹ́ pàápàá jẹ.\wj*
\v 23 \wj Nítorí náà, ẹ ṣọ́ra. Mo ti kìlọ̀ fún un yín ṣáájú tó!\wj*
\p 
\v 24 \wj “Ṣùgbọ́n ni ọjọ́ wọ̀nyí lẹ́yìn ìpọ́njú tí mo sọ yìí,\wj*
\q1 \wj “ ‘oòrùn yóò ṣókùnkùn,\wj*
\q2 \wj òṣùpá kò ní tan ìmọ́lẹ̀ rẹ̀.\wj*
\q1 
\v 25 \wj Àwọn ìràwọ̀ pẹ̀lú yóò já lulẹ̀ láti ojú ọ̀run,\wj*
\q2 \wj àti agbára tí ń bẹ ní ọ̀run ni a ó sì mì tìtì.’\wj*
\p 
\v 26 \wj “Nígbà náà ni gbogbo ayé yóò sì rí i tí èmi Ọmọ Ènìyàn yóò máa bọ̀ wá láti inú àwọsánmọ̀ pẹ̀lú agbára àti ògo ńlá.\wj*
\v 27 \wj Nígbà náà ni yóò sì rán àwọn angẹli rẹ̀ láti kó àwọn àyànfẹ́ ní gbogbo ayé jọ láti orígun mẹ́rẹ̀ẹ̀rin ayé láti ìkangun ayé títí dé ìkangun ọ̀run.\wj*
\p 
\v 28 \wj “Nísinsin yìí, ẹ kọ́ òwe lára igi ọ̀pọ̀tọ́, nígbà tí ẹ̀ka rẹ bá ń yọ tuntun, tí ó bá sì ń rú ewé, èyí fihàn pé àkókò ẹ̀rùn ti dé.\wj*
\v 29 \wj Bẹ́ẹ̀ gẹ́gẹ́, nígbà tí ẹ ba ri àwọn ohun wọ̀nyí ti n ṣẹlẹ̀, kí ẹ mọ̀ pé ó súnmọ́ etílé tán, bi ìgbà tí ó wà lẹ́yìn ìlẹ̀kùn.\wj*
\v 30 \wj Lóòótọ́ ni mo wí fún un yín, ìran yìí kì yóò rékọjá títí a ó fi mú gbogbo nǹkan wọ̀nyí ṣẹ.\wj*
\v 31 \wj Ọ̀run àti ayé yóò kọjá lọ, ṣùgbọ́n àwọn ọ̀rọ̀ mi dúró dájú títí ayé àìnípẹ̀kun.\wj*
\s1 Ọjọ́ àti wákàtí tí a kò mọ̀
\p 
\v 32 \wj “Ṣùgbọ́n kò sí ẹni tí ó mọ ọjọ́ tàbí wákàtí tí nǹkan wọ̀nyí yóò ṣẹlẹ̀. Àwọn angẹli ọ̀run pàápàá kò mọ̀. Àní, èmi pẹ̀lú kò mọ̀ ọ́n, bí kò ṣe baba nìkan.\wj*
\v 33 \wj Ẹ máa ṣọ́ra, ẹ dúró wámú, kí ẹ sì máa gbàdúrà, nítorí ẹ̀yin kò mọ ìgbà tí àkókò ná yóò dé.\wj*
\v 34 \wj Ó dà bí ọkùnrin kan tí ó lọ sí ìrìnàjò tí ó jìnnà rere, ẹni tí ó fi ilé rẹ̀ sílẹ̀, tí ó sì fi àṣẹ fún àwọn ọmọ ọ̀dọ̀ rẹ̀, àti iṣẹ́ tí ẹnìkọ̀ọ̀kan yóò ṣe, ó sì fi àṣẹ fún ẹni tó dúró lẹ́nu-ọ̀nà láti máa ṣọ́nà.\wj*
\p 
\v 35 \wj “Bẹ́ẹ̀ gẹ́gẹ́, ẹ̀yin pẹ̀lú ní láti máa fi ìrètí ṣọ́nà, nítorí pé ẹ kò mọ àkókò tí baálé ilé yóò dé. Bóyá ní ìrọ̀lẹ́ ni o, tàbí ní ọ̀gànjọ́ òru, tàbí nígbà tí àkùkọ máa ń kọ, tàbí ní òwúrọ̀.\wj*
\v 36 \wj Àti wí pé nígbà tí ó bá dé lójijì, kó má ṣe bá yín lójú oorun.\wj*
\v 37 \wj Ohun tí mo wí fún un yín, mo wí fun gbogbo ènìyàn: ‘Ẹ máa ṣọ́nà!’ ”\wj*
\c 14
\s1 A da tùràrí sí ara Jesu
\p 
\v 1 Lẹ́yìn ọjọ́ méjì ni àjọ ìrékọjá àti tí àìwúkàrà, àti àwọn olórí àlùfáà àti àwọn olùkọ́ òfin sì ń wá ọ̀nà láti mú Jesu ní ìkọ̀kọ̀, kí wọn sì pa á.
\v 2 Ṣùgbọ́n wọ́n wí pé, “A kò ní mú un ní ọjọ́ àjọ, kí àwọn ènìyàn má bá á fa ìjàngbọ̀n.”
\p 
\v 3 Nígbà tí ó sì wà ní Betani ni ilé Simoni adẹ́tẹ̀ bí ó ti jókòó ti oúnjẹ, obìnrin kan wọlé, ti òun ti alabasita òróró ìkunra olówó iyebíye, ó ṣí ìgò náà, ó sì da òróró náà lé Jesu lórí.
\p 
\v 4 Àwọn kan nínú àwọn tí ó jókòó ti tábìlì kún fún ìbànújẹ́. Wọ́n sì ń bi ara wọn pé, “Nítorí kí ni a ṣe fi òróró yìí ṣòfò?
\v 5 Òun ìbá ta òróró ìkunra yìí ju owó iṣẹ́ ọdún kan lọ, kí ó sì fi owó rẹ̀ ta àwọn tálákà lọ́rẹ.” Báyìí ni wọ́n ń fi ọ̀rọ̀ gún obìnrin náà lára.
\p 
\v 6 Ṣùgbọ́n Jesu wí fún pé, \wj “Ẹ fi í sílẹ̀, kí ni ẹ ń yọ ọ́ lẹ́nu fún ṣé nítorí tí ó ṣe ohun rere sí mi?\wj*
\v 7 \wj Nígbà gbogbo ni àwọn tálákà wà ní àárín yín, wọ́n sì ń fẹ́ ìrànlọ́wọ́ yín. Ẹ sì lè ṣe oore fún wọn nígbàkígbà tí ẹ bá fẹ́.\wj*
\v 8 \wj Ó ti ṣe èyí tí ó lè ṣe, o ti fi òróró kùn mí ni ara ní ìmúrasílẹ̀ de ìgbà tí wọn yóò sin òkú mi.\wj*
\v 9 \wj Lóòótọ́ ni mo wí fún un yín, níbikíbi tí wọ́n bá ti wàásù mi, ní gbogbo ayé, wọn kò ní ṣe aláìsọ ohun tí obìnrin yìí ṣe pẹ̀lú ní ìrántí rẹ̀.”\wj*
\p 
\v 10 Nígbà náà ni Judasi Iskariotu, ọ̀kan nínú àwọn ọmọ-ẹ̀yìn rẹ̀ méjìlá lọ sí ọ̀dọ̀ àwọn olórí àlùfáà, láti ṣètò bí yóò ti fi Jesu lé wọn lọ́wọ́.
\v 11 Inú wọn dùn láti gbọ́ èyí, wọ́n sì yọ̀, wọ́n sì ṣe ìlérí láti fún un ní owó. Nítorí náà ó bẹ̀rẹ̀ sí í ṣọ àkókò tí ó rọrùn tí òun yóò fi Jesu lé wọn lọ́wọ́.
\s1 Oúnjẹ alẹ́ Olúwa
\p 
\v 12 Ní ọjọ́ kìn-ín-ní àjọ̀dún ìrékọjá tí í ṣe ọjọ́ tí wọ́n máa ń pa ẹran àgùntàn fún ìrúbọ, àwọn ọmọ-ẹ̀yìn Jesu bi í léèrè pé, “Níbo ni ìwọ fẹ́ kí a lọ pèsè sílẹ̀ tí ìwọ yóò ti jẹ àsè ìrékọjá?”
\p 
\v 13 Ó rán méjì nínú àwọn ọmọ-ẹ̀yìn rẹ̀, lọ, ó sì wí fún wọn pé, \wj “Ẹ lọ sínú ìlú, ọkùnrin kan tó ru ìkòkò omi yóò pàdé yín, ẹ máa tọ̀ ọ́ lẹ́yìn.\wj*
\v 14 \wj Ilé tí ọkùnrin náà bá wọ̀, kí ẹ wí fún baálé náà pé, ‘Olùkọ́ rán wa pé, níbo ni gbàngàn àpèjẹ náà gbé wa, níbi tí èmi yóò gbé jẹ àsè ìrékọjá pẹ̀lú àwọn ọmọ-ẹ̀yìn mi?’\wj*
\v 15 \wj Òun yóò sì mú un yín lọ sí gbàngàn ńlá kan lókè ilé náà, tí a ti ṣe lọ́sọ́. Níbẹ̀ ni kí ẹ pèsè sílẹ̀ dè wá.”\wj*
\p 
\v 16 Àwọn ọmọ-ẹ̀yìn méjì náà sì jáde lọ àárín ìlú. Wọ́n bá gbogbo nǹkan gẹ́gẹ́ bí Jesu tí sọ fún wọn. Wọ́n sì pèsè àsè ìrékọjá.
\p 
\v 17 Nígbà tí ó di alẹ́, Jesu àti àwọn ọmọ-ẹ̀yìn rẹ̀ dé síbẹ̀.
\v 18 Bí wọ́n sì ti jókòó yí tábìlì ká, tí wọ́n ń jẹun, Jesu wí pé, \wj “Lóòótọ́ ni mo wí fún un yín, ọ̀kan nínú ẹ̀yin tí ẹ ń bá mi jẹun yìí ni yóò fi mí hàn.”\wj*
\p 
\v 19 Ọkàn wọn sì bẹ̀rẹ̀ sí í dàrú. Olúkúlùkù sì ń bi í ní ọ̀kọ̀ọ̀kan wí pé, “Dájúdájú, kì í ṣe èmi?”
\p 
\v 20 Ó sì dáhùn wí pé, \wj “Ọ̀kan nínú ẹ̀yin méjìlá tí ó ń bá mi tọwọ́ bọ àwo jẹun nísinsin yìí ni.\wj*
\v 21 \wj Nítòótọ́ Ọmọ Ènìyàn ń lọ bí a ti kọ̀wé nípa rẹ̀, ṣùgbọ́n ègbé ní fún ọkùnrin náà, láti ọwọ́ ẹni tí a ti fi Ọmọ Ènìyàn hàn. Ìbá sàn fún un bí a kò bá bí i rárá.”\wj*
\p 
\v 22 Bí wọ́n ti ń jẹun lọ́wọ́, Jesu mú ìṣù àkàrà kan, ó gbàdúrà sí i. Lẹ́yìn náà ó bù ú sí wẹ́wẹ́, ó sì fi fún wọn. Ó wí pé, \wj “Ẹ gbà jẹ, èyí yìí ni ara mi.”\wj*
\p 
\v 23 Bákan náà, ó sì mú ago wáìnì, ó dúpẹ́ fún un, ó sì gbé e fún wọn. Gbogbo wọn sì mu nínú rẹ̀.
\p 
\v 24 Ó sì wí fún wọn pé, \wj “Èyí ni ẹ̀jẹ̀ mi tí májẹ̀mú tuntun, tí a ta sílẹ̀ fún ọ̀pọ̀lọpọ̀ ènìyàn.\wj*
\v 25 \wj Lóòótọ́ ni mo wí fún un yín, èmi kò tún ní mu ọtí wáìnì mọ́ títí yóò fi di ọjọ́ náà tí Èmi yóò mu ún ní tuntun nínú ìjọba Ọlọ́run.”\wj*
\p 
\v 26 Lẹ́yìn náà wọ́n kọ orin, wọ́n sì gun orí òkè olifi lọ.
\s1 Jesu sọ àsọtẹ́lẹ̀ pé Peteru yóò sẹ́ òun
\p 
\v 27 Jesu sì wí fún wọn pé, \wj “Gbogbo yín ni ẹ ó sa kúrò lọ́dọ̀ mi, a ti kọ̀wé rẹ pé,\wj*
\q1 \wj “ ‘Èmi yóò lu olùṣọ́-àgùntàn\wj*
\q2 \wj àwọn agbo àgùntàn yóò sì fọ́nká.’\wj*
\m 
\v 28 \wj Ṣùgbọ́n lẹ́yìn ìgbà ti mo ba jíǹde tan, èmi yóò síwájú yin lọ sí Galili.”\wj*
\p 
\v 29 Ṣùgbọ́n Peteru dá a lóhùn, ó wí pé, “Bí gbogbo ènìyàn tilẹ̀ sá kúrò lẹ́yìn rẹ, èmi kò ní sá.”
\p 
\v 30 Jesu si wí fún un pé, \wj “Jẹ́ kí ń sọ òótọ́ fún ọ. Kí àkùkọ tó ó kọ lẹ́ẹ̀kejì ní òwúrọ̀ ọ̀la, ìwọ, pàápàá yóò ti sọ lẹ́ẹ̀mẹ́ta wí pe ìwọ kò mọ̀ mí rí.”\wj*
\p 
\v 31 Ṣùgbọ́n Peteru fa ara ya, ó wí pé, “Bí mo tilẹ̀ ní láti kú pẹ̀lú rẹ̀, èmi kò jẹ́ sọ pé n kò mọ̀ ọ́n rí.” Ìlérí yìí kan náà ni àwọn ọmọ-ẹ̀yìn ìyókù bẹ̀rẹ̀ sí í ṣe.
\s1 Ọgbà Getsemane
\p 
\v 32 Nígbà tí wọ́n dé ibi kan tí wọ́n ń pè ní ọgbà Getsemane. Jesu wí fún àwọn ọmọ-ẹ̀yìn rẹ̀ pé, \wj “Ẹ jókòó dè mí níhìn-ín títí n ó fi lọ gbàdúrà.”\wj*
\v 33 Ó sì mú Peteru àti Jakọbu àti Johanu lọ pẹ̀lú rẹ̀. Òun sì kún fún ìrẹ̀wẹ̀sì àti ìbànújẹ́ gidigidi.
\v 34 Ó sì wí fún wọn pé, \wj “Ọkàn mi ń káàánú gidigidi títí dé ojú ikú. Ẹ dúró níhìn-ín kí ẹ sì máa bá mi ṣọ́nà.”\wj*
\p 
\v 35 Ó sì lọ síwájú díẹ̀, ó dojúbo ilẹ̀, ó sì bẹ̀rẹ̀ sí i gbàdúrà pé, bí ó bá ṣe e ṣe kí wákàtí tí ó bọ̀ náà ré òun kọjá.
\v 36 Ó sì wí pé, \wj “Ábbà, Baba, ìwọ lè ṣe ohun gbogbo, mú ago yìí kúrò lórí mi, ṣùgbọ́n kì í ṣe èyí tí èmi fẹ́, bí kò ṣe èyí tí ìwọ fẹ́.”\wj*
\p 
\v 37 Nígbà tí ó sì padà dé ọ̀dọ̀ àwọn ọmọ-ẹ̀yìn mẹ́ta, ó bá wọn lójú oorun. Ó sì wí fún Peteru pé, \wj “Simoni, o ń sùn ni? Ìwọ kò lè bá mi ṣọ́nà fún wákàtí kan?\wj*
\v 38 \wj Ẹ máa ṣọ́nà, kí ẹ sì máa gbàdúrà, ki ẹ má ba à bọ́ sínú ìdánwò. Bí ó tilẹ̀ jẹ́ pé, ‘Ẹ̀mí ń fẹ́ ṣùgbọ́n ó ṣe àìlera fún ara.’ ”\wj*
\p 
\v 39 Ó sì tún lọ lẹ́ẹ̀kan sí i. Ó sì gbàdúrà gẹ́gẹ́ bí ó ti gbà á ti ìṣáájú.
\v 40 Nígbà tí ó sì tún padà dé, ó bá wọn wọ́n ń sùn, nítorí pé ojú wọn kún fún oorun. Wọn kò sì mọ irú èsì tí wọn ìbá fún un.
\p 
\v 41 Ó sì wá nígbà kẹta, ó sì wí fún wọn pé, \wj “Ẹ máa sùn kí ẹ sì máa sinmi ó tó bẹ́ẹ̀, wákàtí náà ti dé, wò ó, a fi Ọmọ Ènìyàn lé àwọn ẹlẹ́ṣẹ̀ lọ́wọ́.\wj*
\v 42 \wj Ẹ dìde, ẹ jẹ́ kí a máa lọ. Ẹ wò ó, ẹni tí yóò fi mí hàn wà ní tòsí!”\wj*
\s1 A mú Jesu
\p 
\v 43 Bí ó sì ti ń sọ̀rọ̀ lọ́wọ́, lójú ẹsẹ̀ náà ni Judasi ọ̀kan nínú àwọn ọmọ-ẹ̀yìn méjìlá dé pẹ̀lú. Ọ̀pọ̀lọpọ̀ ènìyàn ti idà àti kùmọ̀ lọ́wọ́, àwọn olórí àlùfáà, àwọn olùkọ́ òfin àti àwọn àgbàgbà Júù ni ó rán wọn wá.
\p 
\v 44 Judasi tí fi àmì fún wọn wí pe, “Ẹni tí mo bá fi ẹnu kò lẹ́nu nínú wọn, òun ní Jesu, ẹ mú un.”
\v 45 Nígbà tí wọ́n dé ọ̀dọ̀ Jesu, Judasi lọ sì ọ̀dọ̀ rẹ̀ tààrà, ó wí pé, “Rabbi!” Ó sì fi ẹnu kò Jesu lẹ́nu.
\v 46 Wọ́n sì mú Jesu.
\v 47 Ṣùgbọ́n ọ̀kan nínú àwọn tí ó dúró fa idà rẹ̀ yọ, ó fi ṣá ọmọ ọ̀dọ̀ olórí àlùfáà, ó sì gé etí rẹ̀ bọ́ sílẹ̀.
\p 
\v 48 Nígbà náà Jesu dáhùn, ó bi wọ́n léèrè pé, \wj “Ṣé Èmi ni ẹ̀yin jáde tọ̀ wá bi olè, ti ẹ̀yin ti idà àti kùmọ̀ láti mú?\wj*
\v 49 \wj Ojoojúmọ́ ni èmi wà pẹ̀lú yín ní tẹmpili, tí mo ń kọ́ni; ẹ kò mú mi. Ṣùgbọ́n eléyìí ṣẹlẹ̀, kí ohun tí ìwé Mímọ́ wí lè ṣẹ.”\wj*
\v 50 Ní àkókò yìí, gbogbo àwọn ọmọ-ẹ̀yìn rẹ̀ ti fi í sílẹ̀, wọ́n sálọ.
\p 
\v 51 Ọ̀dọ́mọkùnrin kan sì ń tọ̀ ọ́ lẹ́yìn tí ó fi aṣọ ọ̀gbọ̀ bo ìhòhò rẹ̀ àwọn ọmọ-ogun gbìyànjú láti mú òun náà.
\v 52 Ó sì fi aṣọ funfun náà sílẹ̀ fún wọn, ó sì sálọ ní ìhòhò.
\s1 Jesu níwájú ìgbìmọ̀ Sahẹndiri
\p 
\v 53 Wọ́n mú Jesu lọ sí ilé olórí àlùfáà, gbogbo àwọn olórí àlùfáà àti àwọn àgbàgbà Júù àti àwọn olùkọ́ òfin péjọ síbẹ̀.
\v 54 Peteru tẹ̀lé Jesu lókèèrè, ó sì yọ́ wọ inú àgbàlá olórí àlùfáà, ó sì jókòó pẹ̀lú àwọn ọmọ ọ̀dọ̀, ó ń yáná.
\p 
\v 55 Bí ó ti ń ṣe èyí lọ́wọ́, àwọn olórí àlùfáà àti gbogbo ìgbìmọ̀ ilé ẹjọ́ tí ó ga jùlọ ń wá ẹni tí yóò jẹ́rìí èké sí Jesu, èyí tí ó jọjú dáradára láti lè dájọ́ ikú fún un. Ṣùgbọ́n wọn kò rí.
\v 56 Nítorí pé ọ̀pọ̀lọpọ̀ ẹ̀rí wọ́n ní kò bá ara wọn mu.
\p 
\v 57 Níkẹyìn àwọn kan dìde, wọ́n bẹ̀rẹ̀ sí í jẹ́rìí èké sí i, wọ́n ní,
\v 58 “A gbọ́ tí ó wí pé, ‘Èmi yóò wó tẹmpili tí ẹ fi ọwọ́ kọ́ yìí, nígbà tí yóò bá sì fi di ọjọ́ kẹta, èmi yóò kọ́ òmíràn ti a kò fi ọwọ́ ènìyàn kọ́.’ ”
\v 59 Síbẹ̀, ẹ̀rí i wọn kò dọ́gba.
\p 
\v 60 Nígbà náà ni àlùfáà àgbà dìde, ó bọ́ síwájú. Ó sì bẹ̀rẹ̀ sí í bi Jesu léèrè, ó ní, “Ṣé o kò ní fèsì sí ẹ̀sùn tí wọ́n fi sùn ọ? Kí ni ìwọ gan an ní sọ fúnra rẹ̀?”
\v 61 Ṣùgbọ́n Jesu dákẹ́.
\p Olórí àlùfáà tún bi í, lẹ́ẹ̀kan sí i, ó ní, “Ṣé ìwọ ni Kristi náà, Ọmọ Olùbùkún un nì?”
\p 
\v 62 Jesu wá dáhùn, ó ni, “\wj Èmi ni, ẹ̀yin yóò sì rí Ọmọ Ènìyàn tí yóò jókòó lọ́wọ́ ọ̀tún agbára. Ẹ̀yin yóò sì tún rí Ọmọ Ènìyàn tí ó ń bọ̀ láti inú àwọsánmọ̀ ojú ọ̀run.”\wj*
\p 
\v 63 Nígbà náà ni Olórí àlùfáà fa aṣọ rẹ̀ ya, ó ní, “Kí ló kù tì a ń wá? Kí ni a tún ń wá ẹlẹ́rìí fún?
\v 64 Ẹ̀yin fúnra yín ti gbọ́ ọ̀rọ̀-òdì tí ó sọ. Kí ni ẹ rò pé ó tọ́ kí a ṣe?”
\p Gbogbo wọ́n sì dáhùn wí pé, “Ó jẹ̀bi ikú.”
\v 65 Àwọn kan sì bẹ̀rẹ̀ sí í tu itọ́ sí i lára. Wọ́n dì í lójú. Wọ́n ń kàn án lẹ́ṣẹ̀ẹ́ lójú. Wọ́n fi ṣe ẹlẹ́yà pé, “Sọtẹ́lẹ̀!” Àwọn olùṣọ́ sì ń fi àtẹ́lẹwọ́ wọn gbá a lójú.
\s1 Peteru sẹ́ Jesu
\p 
\v 66 Ní àkókò yìí Peteru wà ní ìsàlẹ̀ inú àgbàlá ilé ìgbẹ́jọ́. Nínú àgbàlá yìí, ọ̀kan nínú àwọn ìránṣẹ́bìnrin àlùfáà àgbà kíyèsi í tí Peteru ń yáná.
\v 67 Nígbà tí ó rí Peteru tí ó ti yáná, Ó tẹjúmọ́ ọn.
\p Ó sì sọ gbangba pé, “Ìwọ pàápàá wà pẹ̀lú Jesu ara Nasareti.”
\p 
\v 68 Ṣùgbọ́n Peteru sẹ́, ó ni, “N kò mọ Jesu náà rí; ohun tí ó ń sọ yìí kò tilẹ̀ yé mi.” Peteru sì jáde lọ sí ẹnu-ọ̀nà àgbàlá ilé ìgbẹ́jọ́. Àkùkọ sì kọ.
\p 
\v 69 Ọmọbìnrin náà sì tún rí Peteru. Ó sì tún bẹ̀rẹ̀ sí wí fún àwọn tí wọ́n dúró níbẹ̀. Ó ní, “Ọkùnrin yìí gan an jẹ́ ọ̀kan nínú àwọn ọmọ-ẹ̀yìn Jesu.”
\v 70 Ṣùgbọ́n Peteru tún sẹ́.
\p Nígbà tí ó sí túnṣe díẹ̀ sí i, àwọn tí wọ́n dúró lẹ́gbẹ́ Peteru wá wí fún un pé, “Lóòótọ́ ni, ọ̀kan ní ara wọn ni ìwọ í ṣe. Nítorí ará Galili ni ìwọ, èdè rẹ sì jọ bẹ́ẹ̀.”
\p 
\v 71 Nígbà náà ni Peteru bẹ̀rẹ̀ sí í sẹ́ ó sì ń búra, ó ni, “N kò mọ ẹni ti ẹ ń sọ̀rọ̀ rẹ̀ yí rí!”
\p 
\v 72 Lójúkan náà tí àkùkọ yìí kọ lẹ́ẹ̀kejì Peteru rántí ọ̀rọ̀ Jesu fún un pé, \wj “Kí àkùkọ tó kọ lẹ́ẹ̀méjì, ìwọ yóò sẹ́ mí nígbà mẹ́ta.”\wj* Ó sì rẹ̀ ẹ́ láti inú ọkàn wá, ó sì sọkún.
\c 15
\s1 Jesu jẹ́jọ́ níwájú Pilatu
\p 
\v 1 Ní kùtùkùtù òwúrọ̀, àwọn olórí àlùfáà, àwọn àgbàgbà, àwọn olùkọ́ òfin àti gbogbo àjọ ìgbìmọ̀ fi ẹnu kò lórí ohun tí wọn yóò ṣe. Wọ́n sì de Jesu, wọ́n mú un lọ, wọ́n sì fi lé Pilatu lọ́wọ́.
\p 
\v 2 Pilatu sì bi í léèrè, ó ni, “Ṣe ìwọ ni ọba àwọn Júù?”
\p Jesu sì dáhùn pé, \wj “Gẹ́gẹ́ bi ìwọ ti wí náà ni.”\wj*
\p 
\v 3 Àwọn olórí àlùfáà fi ẹ̀sùn ohun púpọ̀ kàn án.
\v 4 Pilatu sì tún bi í léèrè pé, “Ṣe ìwọ kò dáhùn ni? Wo gbogbo ẹ̀sùn tí wọ́n fi kàn ọ.”
\p 
\v 5 Ṣùgbọ́n Jesu kò dalóhùn síbẹ̀, tó bẹ́ẹ̀ ti ẹnu fi ya Pilatu.
\p 
\v 6 Ní báyìí, nígbà àjọ, gẹ́gẹ́ bí àṣà, òun a máa dá òǹdè kan sílẹ̀ fún wọn, ẹnikẹ́ni tí wọ́n bá béèrè fún.
\v 7 Ọkùnrin kan wà tí orúkọ rẹ̀ ń jẹ́ Baraba. Wọ́n ti ju òun àti àwọn ọlọ̀tẹ̀ ẹgbẹ́ rẹ̀ sí ọgbà ẹ̀wọ̀n, nítorí wọ́n ṣọ̀tẹ̀ sí ìjọba, wọ́n sì pa ènìyàn nínú ìdìtẹ̀ wọn.
\v 8 Ọ̀pọ̀ ènìyàn sì lọ bá Pilatu, wọ́n ní kí ó ṣe bí ó ti máa ń ṣe fún wọn ní ọdọọdún.
\p 
\v 9 Pilatu béèrè lọ́wọ́ wọn wí pé, “Ṣe ẹ̀yin ń fẹ́ kí èmi dá ọba àwọn Júù sílẹ̀ fún yin?”
\v 10 Òun mọ̀ pé nítorí ìlara ni àwọn olórí àlùfáà ṣe fà Jesu lé òun lọ́wọ́.
\v 11 Nígbà náà ni àwọn olórí àlùfáà ru ọ̀pọ̀ ènìyàn sókè pé, kí ó kúkú dá Baraba sílẹ̀ fún wọn.
\p 
\v 12 Pilatu sì tún béèrè lọ́wọ́ wọn pé, “Kí ni ẹ̀yin ń fẹ́ kí èmi kí ó ṣe pẹ̀lú ẹni ti ẹ̀yin n pè ní ọba àwọn Júù?”
\p 
\v 13 Wọ́n sì tún kígbe sókè pé, “Kàn án mọ àgbélébùú!”
\p 
\v 14 Nígbà náà ni Pilatu bi wọn léèrè pé, “Èéṣe? Búburú kí ni ó ṣe?”
\p Wọ́n sì kígbe sókè gidigidi wí pé, “Kàn án mọ́ àgbélébùú!”
\p 
\v 15 Pilatu sì ń fẹ́ ṣe èyí tí ó wu àwọn ènìyàn, ó dá Baraba sílẹ̀ fún wọn. Nígbà tí ó sì na Jesu tan o fà á lé wọn lọ́wọ́ láti kàn an mọ́ àgbélébùú.
\s1 Àwọn ọmọ-ogun fi Jesu ṣe ẹlẹ́yà
\p 
\v 16 Àwọn ọmọ-ogun sì fà á jáde lọ sínú ààfin (tí a ń pè ní Pretoriomu), wọ́n sì pe gbogbo ẹgbẹ́ àwọn ọmọ-ogun jọ.
\v 17 Wọn sì fi aṣọ aláwọ̀ àlùkò wọ̀ ọ́, wọ́n hun adé ẹ̀gún, wọ́n sì fi dé e ní orí.
\v 18 Wọ́n sì bẹ̀rẹ̀ sí i kí ì wí pé, Kábíyèsí, ọba àwọn Júù.
\v 19 Wọ́n sì fi ọ̀pá lù ú lórí, wọ́n sì tutọ́ sí i lára, wọ́n sì kúnlẹ̀ níwájú rẹ̀, wọ́n sì foríbalẹ̀ fún un.
\v 20 Nígbà tí wọ́n sì fi ṣẹ̀sín tan, wọ́n sì bọ aṣọ elése àlùkò náà kúrò lára rẹ̀, wọ́n sì fi aṣọ rẹ̀ wọ̀ ọ́, wọ́n sì mú un jáde lọ láti kàn án mọ́ àgbélébùú.
\s1 Wọ́n kan Jesu mọ́ àgbélébùú
\p 
\v 21 Wọ́n rí ọkùnrin kan tí ń kọjá lọ. Simoni ará Kirene. Òun ni baba Aleksanderu àti Rufusi. Wọ́n sì mú un ní tipátipá pé, kí ó rú àgbélébùú Jesu.
\v 22 Wọ́n sì mú Jesu wá sí Gọlgọta (èyí tí ìtumọ̀ rẹ̀ ń jẹ́ Ibi Agbárí)
\v 23 Wọ́n sì fi myrri wáìnì tí a dàpọ̀ mọ́ òjìá fún un mu, ṣùgbọ́n òun kò gbà á.
\v 24 Wọ́n sì kàn án mọ́ àgbélébùú. Wọ́n sì pín aṣọ rẹ̀ láàrín ara wọn, wọ́n dìbò lórí àwọn aṣọ náà ni kí wọn bá à lè mọ èyí tí yóò jẹ́ ti olúkúlùkù.
\p 
\v 25 Ní wákàtí kẹta ọjọ́ ni wọ́n kàn án mọ́ àgbélébùú.
\v 26 Àkọlé ìfisùn tí wọ́n kọ sókè orí rẹ̀ ni:
\pc Ọba àwọn Júù.
\p 
\v 27 Wọ́n sì kan àwọn olè méjì mọ́ àgbélébùú pẹ̀lú rẹ̀, ọ̀kan lọ́wọ́ ọ̀tún rẹ̀, èkejì lọ́wọ́ òsì rẹ̀.\f + \fr 15:27 \ft Àwọn àkọsílẹ̀ àtijọ́ ìwé Marku kan se àfikún ọ̀rọ̀ yìí \fqa rẹ̀, \fv 28 \fqa èyí tí a ti kọ̀wé rẹ̀ kò lè ṣe kí ó má ṣẹ lára mi, a sì kà á mọ́ àwọn arúfin\ft (Isaiah 53.12)\f*
\v 29 Àwọn tí ń kọjá lọ sì ń fi ṣe ẹlẹ́yà, wọ́n ń mi orí wọn pẹ̀lú, wọ́n sì ké pé, “Háà! Ìwọ tí yóò wó tẹmpili tí yóò sì tún un kọ́ láàrín ọjọ́ mẹ́ta,
\v 30 sọ̀kalẹ̀ láti orí àgbélébùú wá, kí o sì gba ara rẹ là!”
\v 31 Bákan náà ni àwọn olórí àlùfáà àti àwọn olùkọ́ òfin fi í ṣẹ̀sín láàrín ara wọn, wọ́n wí pé, “Ó gba àwọn ẹlòmíràn là ṣùgbọ́n, ara rẹ̀ ni kò lè gbàlà.
\v 32 Jẹ́ kí Kristi, ọba Israẹli, sọ̀kalẹ̀ láti orí igi àgbélébùú wá nísinsin yìí kí àwa kí ó lè rí i, kí àwa kí ó sì lè gbàgbọ́.” Bákan náà, àwọn ti a kàn mọ́ àgbélébùú pẹ̀lú rẹ̀ sì ń kẹ́gàn rẹ̀.
\s1 Ikú Jesu
\p 
\v 33 Nígbà tí ó di wákàtí kẹfà, òkùnkùn bo gbogbo ilẹ̀ títí di wákàtí kẹsànán.
\v 34 Ní wákàtí kẹsànán ni Jesu kígbe sókè ní ohùn rara, ó ní, \tl \wj “Eli, Eli, lama sabakitani?”\wj*\tl* (ìtumọ̀ èyí tí í ṣe, \wj “Ọlọ́run mi, Ọlọ́run mi, èéṣe tí ìwọ fi kọ̀ mí sílẹ̀?”\wj*).
\p 
\v 35 Nígbà tí àwọn kan nínú àwọn tí wọ́n dúró níbẹ̀ gbọ́, wọ́n sì wí pé, “Wò ó ó ń pe Elijah.”
\p 
\v 36 Nígbà náà ni ẹnìkan sáré lọ ki kànìnkànìn bọ inú ọtí kíkan, ó fi lé orí ọ̀pá, ó sì nà án sí Jesu kí ó lè mu ún. Ó wí pé, “Ẹ jẹ́ kí a máa wò ó, bóyá Elijah yóò wá sọ̀ ọ́ kalẹ̀ wa.”
\p 
\v 37 Jesu sì tún kígbe sókè ni ohùn rara, ó jọ̀wọ́ ẹ̀mí rẹ̀ lọ́wọ́.
\p 
\v 38 Aṣọ ìkélé tẹmpili sì fàya sí méjì láti òkè dé ìsàlẹ̀.
\v 39 Nígbà tí balógun ọ̀rún tí ó dúró lẹ́gbẹ̀ ọ̀dọ̀ Jesu rí i tí ó kígbe sókè báyìí, tí ó sì jọ̀wọ́ èmí rẹ̀ lọ́wọ́, ó wí pé, “Lóòótọ́ Ọmọ Ọlọ́run ni ọkùnrin yìí í ṣe.”
\p 
\v 40 Àwọn obìnrin kan wà níbẹ̀ pẹ̀lú, tí wọ́n ń wò ó láti òkèèrè. Maria Magdalene wà lára àwọn obìnrin náà, àti Maria ìyá Jakọbu kékeré àti ti Jose, àti Salome.
\v 41 Àwọn wọ̀nyí, nígbà tí ó wà ní Galili máa ń tọ̀ ọ́ lẹ́yìn, wọ́n a sì máa ṣe ìránṣẹ́ fún un àti ọ̀pọ̀ obìnrin mìíràn tí wọ́n sì bá a gòkè wá sí Jerusalẹmu.
\s1 Ìsìnkú Jesu
\p 
\v 42 Ọjọ́ yìí jẹ́ ọjọ́ ìpalẹ̀mọ́ (èyí tí i ṣe, ọjọ́ tó ṣáájú ọjọ́ ìsinmi). Nígbà tí ilẹ̀ ọjọ́ náà sì ṣú,
\v 43 Josẹfu ará Arimatea wá, ọ̀kan pàtàkì nínú àwọn ọmọ ìgbìmọ̀, ẹni tí ń retí ìjọba Ọlọ́run, ó fi ìgboyà lọ sí iwájú Pilatu láti tọrọ òkú Jesu.
\v 44 Ẹnu ya Pilatu láti gbọ́ pé Jesu ti kú. Nítorí náà ó pe balógun ọ̀rún, ó sì bí i léèrè bóyá Jesu ti kú nítòótọ́.
\v 45 Nígbà tí balógun ọ̀rún náà sì fún Pilatu ni ìdánilójú pé Jesu ti kú, Pilatu jọ̀wọ́ òkú rẹ̀ fún Josẹfu.
\v 46 Josẹfu sì ti ra aṣọ ọ̀gbọ̀ wá. Ó sọ òkú Jesu kalẹ̀: ó sì fi aṣọ ọ̀gbọ̀ náà dì í. Ó sì tẹ́ ẹ sí inú ibojì, tí wọ́n gbẹ́ sí ara àpáta. Ó wá yí òkúta dí ẹnu ibojì náà.
\v 47 Maria Magdalene àti Maria ìyá Jose ń wò ó bi Josẹfu ti n tẹ́ Jesu sí ibojì.
\c 16
\s1 Àjíǹde
\p 
\v 1 Nígbà tí ọjọ́ ìsinmi sì kọjá, Maria Magdalene, Maria ìyá Jakọbu, àti Salome mú òróró olóòórùn dídùn wá kí wọn bá à le fi kun Jesu lára.
\v 2 Ní kùtùkùtù ọjọ́ kìn-ín-ní ọ̀sẹ̀, wọ́n wá sí ibi ibojì nígbà tí oòrùn bẹ̀rẹ̀ sí yọ,
\v 3 wọn sì ń bi ara wọn léèrè pé, “Ta ni yóò yí òkúta náà kúrò ní ẹnu ibojì fún wa?”
\p 
\v 4 Ṣùgbọ́n nígbà tí wọn sì wò ó, wọ́n rí i pé a ti yí òkúta tí ó tóbi gidigidi náà kúrò.
\v 5 Nígbà tí wọ́n sì wo inú ibojì náà, wọ́n rí ọ̀dọ́mọkùnrin kàn tí ó wọ aṣọ funfun, ó jókòó ní apá ọ̀tún, ẹnu sì yà wọn.
\p 
\v 6 Ó sì wí fún wọn pé, “Ẹ má bẹ̀rù: ẹ̀yin ń wá Jesu tí Nasareti, tí a kàn mọ́ àgbélébùú. Ó jíǹde! Kò sí níhìn-ín yìí mọ́, ẹ wo ibi tí wọ́n gbé tẹ́ ẹ sí.
\v 7 Ṣùgbọ́n ẹ lọ sọ fún àwọn ọmọ-ẹ̀yìn rẹ̀ títí kan Peteru wí pé, ‘Òun ti ń lọ síwájú yín sí Galili. Ibẹ̀ ni ẹ̀yin yóò ti rí i, gẹ́gẹ́ bí ó ti sọ fún yín.’ ”
\p 
\v 8 Wọ́n sáré jáde lọ kánkán, kúrò ní ibi ibojì náà, nítorí tí wọ́n wárìrì; ẹ̀rù sì bà wọn gidigidi; wọn kò wí ohunkóhun fún ẹnikẹ́ni, nítorí ẹ̀rù bá wọ́n.
\iex [Àwọn àkọsílẹ̀ àtijọ́ àti àwọn ẹlẹ́rìí àtijọ́ kò ní ẹsẹ 9-20.]
\p 
\v 9 \it Nígbà tí Jesu jíǹde ní kùtùkùtù òwúrọ̀ ní ọjọ́ kìn-ín-ní ọ̀sẹ̀, ó kọ́ fi ara hàn fun Maria Magdalene, ni ara ẹni tí ó ti lé ẹ̀mí Èṣù méje jáde.\it*
\v 10 \it Òun sì lọ sọ fún àwọn tí ó ti ń bá a gbé, bí wọn ti ń gbààwẹ̀, tí wọ́n sì ń sọkún.\it*
\v 11 \it Àti àwọn, nígbà tí wọ́n sì gbọ́ pé Jesu wa láààyè, àti pé, òun ti rí i, wọn kò gbàgbọ́.\it*
\p 
\v 12 \it Lẹ́yìn èyí, ó sì fi ara hàn fún àwọn méjì ní ọ̀nà mìíràn, bí wọ́n ti ń rìn ní ọ̀nà, tí wọ́n sì ń lọ sí ìgbèríko.\it*
\v 13 \it Nígbà tí wọ́n sì mọ ẹni tí i ṣe, wọ́n sì lọ ròyìn fún àwọn ìyókù, síbẹ̀, àwọn ìyókù kò gbà wọ́n gbọ́.\it*
\p 
\v 14 \it Lẹ́yìn náà, Jesu fi ara rẹ̀ hàn fún àwọn mọ́kànlá níbi tí wọ́n ti ń jẹun papọ̀; Ó sì bá wọn wí fún àìgbàgbọ́ àti ọkàn líle wọn, nítorí wọn kò gba ẹ̀rí àwọn tí ó ti rí i lẹ́yìn àjíǹde rẹ̀ gbọ́.\it*
\p 
\v 15 \it Ó sì wí fún wọn pé, \wj “Ẹ lọ sí gbogbo ayé, kí ẹ sì máa wàásù ìyìnrere mi fún gbogbo ẹ̀dá.\wj*\it*
\v 16 \it \wj Ẹni tí ó bá gbàgbọ́, tí a sì tẹ̀bọmi yóò là. Ṣùgbọ́n ẹni tí ó bá kọ̀ tí kò gbàgbọ́ yóò jẹ̀bi.\wj*\it*
\v 17 \it \wj Àmì wọ̀nyí yóò sì máa bá àwọn tí ó gbàgbọ́ lọ. Ní orúkọ mi ni wọ́n yóò máa lé ẹ̀mí èṣù jáde. Wọn yóò máa fi èdè tuntun sọ̀rọ̀.\wj*\it*
\v 18 \it \wj Wọn yóò sì gbé ejò lọ́wọ́, bí wọ́n bá sì jẹ májèlé kò nípa wọ́n lára rárá. Wọ́n yóò gbé ọwọ́ lé àwọn aláìsàn, ara wọn yóò sì dá.”\wj*\it*
\p 
\v 19 \it Nígbà tí Jesu Olúwa sì ti bá wọn sọ̀rọ̀ báyìí tan, á gbé e lọ sí ọ̀run, ó sì jókòó lọ́wọ́ ọ̀tún Ọlọ́run.\it*
\v 20 \it Àwọn ọmọ-ẹ̀yìn rẹ̀ sì jáde lọ. Wọ́n ń wàásù káàkiri. Ọlọ́run sì wà pẹ̀lú wọn, ó sì ń fi ìdí ọ̀rọ̀ rẹ̀ múlẹ̀ nípa àwọn àmì tí ó tẹ̀lé e.\it*
