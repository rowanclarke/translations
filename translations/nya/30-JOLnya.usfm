\id JOL - Biblica® Open God’s Word in Contemporary Chichewa 2016 
\h Yoweli 
\toc1 Yoweli 
\toc2 Yoweli 
\toc3 Yow 
\mt1 Yoweli 
\c 1  
\p  
\v 1 Yehova anayankhula ndi Yoweli mwana wa Petueli. 
\s1 Kubwera kwa Dzombe 
\q1  
\v 2 Inu akuluakulu, imvani izi; 
\q2 mvetserani, nonse amene mumakhala mʼdziko. 
\q1 Kodi zinthu zokhala ngati izi zinayamba zaonekapo mʼnthawi yanu, 
\q2 kapena mʼnthawi ya makolo anu? 
\q1  
\v 3 Muwafotokozere ana anu, 
\q2 ndipo ana anuwo afotokozere ana awo, 
\q2 ndipo ana awo adzafotokozere mʼbado winawo. 
\q1  
\v 4 Chimene dzombe losamera mapiko lasiya 
\q2 dzombe lowuluka ladya; 
\q1 chimene dzombe lowuluka lasiya 
\q2 dzombe lalingʼono ladya; 
\q1 chimene dzombe lalingʼono lasiya 
\q2 chilimamine wadya. 
\b  
\q1  
\v 5 Dzukani, inu zidakwa ndipo mulire! 
\q2 Lirani mofuwula, inu nonse amene mumamwa vinyo; 
\q1 lirani mofuwula chifukwa cha vinyo watsopano, 
\q2 pakuti wachotsedwa pakamwa panu. 
\q1  
\v 6 Mtundu wa anthu wathira nkhondo dziko langa, 
\q2 wamphamvu ndi wosawerengeka; 
\q1 uli ndi mano a mkango, 
\q2 zibwano za mkango waukazi. 
\q1  
\v 7 Wawononga mphesa zanga 
\q2 ndipo wathyola mitengo yanga ya mkuyu. 
\q1 Wakungunula makungwa ake 
\q2 ndi kuwataya, 
\q2 kusiya nthambi zake zili mbee. 
\b  
\q1  
\v 8 Lirani ngati namwali wovala chiguduli, 
\q2 chifukwa cha mwamuna wa utsikana wake. 
\q1  
\v 9 Chopereka cha chakudya ndi cha chakumwa 
\q2 sizikuperekedwa ku nyumba ya Yehova. 
\q1 Ansembe akulira, 
\q2 amene amatumikira pamaso pa Yehova. 
\q1  
\v 10 Minda yaguga, 
\q2 nthaka yauma; 
\q1 tirigu wawonongeka, 
\q2 vinyo watsopano watha, 
\q2 mitengo ya mafuta yauma. 
\q1  
\v 11 Khalani ndi nkhawa, inu alimi, 
\q2 lirani mofuwula inu alimi a mphesa; 
\q1 imvani chisoni chifukwa cha tirigu ndi barele, 
\q2 pakuti zokolola za mʼmunda zawonongeka. 
\q1  
\v 12 Mpesa wauma 
\q2 ndipo mtengo wamkuyu wafota; 
\q1 makangadza, kanjedza ndi mitengo ya apulosi, 
\q2 mitengo yonse ya mʼmunda yauma. 
\q1 Ndithudi chimwemwe cha anthu 
\q2 chatheratu. 
\s1 Mulungu Ayitana Anthu kuti Atembenuke 
\q1  
\v 13 Inu ansembe, valani ziguduli ndipo lirani; 
\q2 lirani mofuwula, inu amene mumatumikira pa guwa lansembe. 
\q1 Bwerani, fundani ziguduli usiku wonse, 
\q2 inu amene mumatumikira pamaso pa Mulungu wanga; 
\q1 pakuti chopereka cha chakudya ndi cha chakumwa 
\q2 sizikupezekanso mʼnyumba ya Mulungu wanu. 
\q1  
\v 14 Lengezani tsiku lopatulika losala zakudya, 
\q2 itanani msonkhano wopatulika. 
\q1 Sonkhanitsani akuluakulu 
\q2 ndi anthu onse okhala mʼdziko 
\q1 ku nyumba ya Yehova Mulungu wanu 
\q2 ndipo alirire Yehova. 
\b  
\q1  
\v 15 Kalanga ine tsikulo! 
\q2 Pakuti tsiku la Yehova layandikira; 
\q2 lidzabwera ngati chiwonongeko chochokera kwa Wamphamvuzonse. 
\b  
\q1  
\v 16 Kodi chakudya chathu sichachotsedwa 
\q2 ife tikuona? 
\q1 Kodi mʼnyumba ya Mulungu wathu 
\q2 simulibe chimwemwe ndi chisangalalo? 
\q1  
\v 17 Mbewu zikunyala 
\q2 poti pansi ndi powuma. 
\q1 Nyumba zosungiramo zinthu zawonongeka; 
\q2 nkhokwe zapasuka 
\q2 popeza tirigu wauma. 
\q1  
\v 18 Taonani mmene zikulirira ziweto; 
\q2 ngʼombe zikungoyenda uku ndi uku 
\q1 chifukwa zilibe msipu; 
\q2 ngakhalenso nkhosa zikusauka. 
\b  
\q1  
\v 19 Kwa Inu Yehova ndilirira, 
\q2 pakuti moto wapsereza msipu wakuthengo, 
\q2 malawi amoto apsereza mitengo yonse ya mʼtchire. 
\q1  
\v 20 Ngakhale nyama zakuthengo zikulirira Inu; 
\q2 timitsinje tonse taphwa 
\q2 ndipo moto wapsereza msipu wa kuthengo. 
\c 2  
\s1 Chilango cha Mulungu 
\q1  
\v 1 Lizani lipenga mu Ziyoni. 
\q2 Chenjezani pa phiri langa loyera. 
\q1 Onse okhala mʼdziko anjenjemere, 
\q2 pakuti tsiku la Yehova likubwera, 
\q1 layandikira; 
\q2  
\v 2 tsiku la mdima ndi chisoni, 
\q2 tsiku la mitambo ndi la mdima wandiweyani. 
\q1 Ngati mʼbandakucha umene wakuta mapiri, 
\q2 gulu lalikulu ndi la ankhondo amphamvu likubwera, 
\q1 gulu limene nʼkale lomwe silinaonekepo 
\q2 ngakhale kutsogolo kuno silidzaonekanso. 
\q1  
\v 3 Patsogolo pawo moto ukupsereza, 
\q2 kumbuyo kwawo malawi amoto akutentha zinthu. 
\q1 Patsogolo pawo dziko lili ngati munda wa Edeni, 
\q2 kumbuyo kwawo kuli ngati chipululu, 
\q2 kulibe kanthu kotsalapo. 
\q1  
\v 4 Maonekedwe awo ali ngati akavalo; 
\q2 akuthamanga ngati akavalo ankhondo. 
\q1  
\v 5 Akulumpha pamwamba pa mapiri 
\q2 ndi phokoso ngati la magaleta, 
\q1 ngati moto wothetheka wonyeketsa ziputu, 
\q2 ngati gulu lalikulu la ankhondo lokonzekera nkhondo. 
\b  
\q1  
\v 6 Akangowaona, anthu a mitundu ina amazunzika mu mtima; 
\q2 nkhope iliyonse imagwa. 
\q1  
\v 7 Amathamanga ngati ankhondo; 
\q2 amakwera makoma ngati asilikali. 
\q1 Onse amayenda pa mizere, 
\q2 osaphonya njira yawo. 
\q1  
\v 8 Iwo sakankhanakankhana, 
\q2 aliyense amayenda molunjika. 
\q1 Amadutsa malo otchingidwa 
\q2 popanda kumwazikana. 
\q1  
\v 9 Amakhamukira mu mzinda, 
\q2 amathamanga mʼmbali mwa khoma. 
\q1 Amakwera nyumba ndi kulowamo; 
\q2 amalowera pa zenera ngati mbala. 
\b  
\q1  
\v 10 Patsogolo pawo dziko limagwedezeka, 
\q2 thambo limanjenjemera, 
\q1 dzuwa ndi mwezi zimachita mdima, 
\q2 ndipo nyenyezi zimaleka kuwala. 
\q1  
\v 11 Yehova amabangula 
\q2 patsogolo pawo, 
\q1 gulu lake lankhondo ndi losawerengeka, 
\q2 ndipo amphamvu ndi amene amamvera kulamula kwake. 
\q1 Tsiku la Yehova ndi lalikulu; 
\q2 ndi loopsa. 
\q2 Ndani adzapirira pa tsikulo? 
\s1 Ngʼambani Mtima Wanu 
\q1  
\v 12 “Ngakhale tsopano, 
\q2 bwererani kwa Ine ndi mtima wanu wonse 
\q2 posala zakudya ndi kukhetsa misozi,” akutero Yehova. 
\b  
\q1  
\v 13 Ngʼambani mtima wanu 
\q2 osati zovala zanu. 
\q1 Bwererani kwa Yehova Mulungu wanu, 
\q2 pakuti Iye ndi wokoma mtima ndi wachifundo, 
\q1 wosakwiya msanga ndi wachikondi chochuluka, 
\q2 ndipo amaleka kubweretsa mavuto. 
\q1  
\v 14 Akudziwa ndani? Mwina adzasintha maganizo nʼkutimvera chisoni, 
\q2 nʼkutisiyira madalitso, 
\q1 a chopereka cha chakudya ndi cha chakumwa 
\q2 kwa Yehova Mulungu wanu. 
\b  
\q1  
\v 15 Lizani lipenga mu Ziyoni, 
\q2 lengezani tsiku losala zakudya, 
\q2 itanitsani msonkhano wopatulika. 
\q1  
\v 16 Sonkhanitsani anthu pamodzi, 
\q2 muwawuze kuti adziyeretse; 
\q1 sonkhanitsani akuluakulu, 
\q2 sonkhanitsani ana, 
\q2 sonkhanitsani ndi oyamwa omwe. 
\q1 Mkwati atuluke mʼchipinda chake, 
\q2 mkwatibwi atuluke mokhala mwake. 
\q1  
\v 17 Ansembe amene amatumikira pamaso pa Yehova, 
\q2 alire pakati pa guwa lansembe ndi khonde la Nyumba ya Yehova. 
\q1 Azinena kuti, “Inu Yehova, achitireni chifundo anthu anu. 
\q2 Musalole kuti cholowa chanu chikhale chinthu chonyozeka, 
\q2 kuti anthu a mitundu ina awalamulire. 
\q1 Kodi nʼchifukwa chiyani anthu a mitundu ina amanena kuti, 
\q2 ‘Ali kuti Mulungu wawo?’ ” 
\s1 Yankho la Yehova 
\q1  
\v 18 Pamenepo Yehova adzachitira nsanje dziko lake 
\q2 ndi kuchitira chisoni anthu ake. 
\p  
\v 19 Yehova adzawayankha kuti, 
\q1 “Ine ndikukutumizirani tirigu, vinyo watsopano ndi mafuta 
\q2 ndipo mudzakhuta ndithu; 
\q1 sindidzakuperekaninso kuti mukhale chitonzo 
\q2 kwa anthu a mitundu ina. 
\b  
\q1  
\v 20 “Ine ndidzachotsa ankhondo akumpoto kuti apite kutali ndi inu, 
\q2 kuwapirikitsira ku dziko lowuma ndi lachipululu, 
\q1 gulu lawo lakutsogolo ndidzalipirikitsira ku nyanja ya kummawa 
\q2 ndi gulu lawo lakumbuyo, ku nyanja ya kumadzulo. 
\q1 Ndipo mitembo yawo idzawola, 
\q2 fungo lake lidzamveka.” 
\b  
\q1 Zoonadi Yehova wachita zinthu zazikulu. 
\q2  
\v 21 Iwe dziko usachite mantha; 
\q2 sangalala ndipo kondwera. 
\q1 Zoonadi Yehova wachita zinthu zazikulu. 
\q2  
\v 22 Inu nyama zakuthengo, musachite mantha, 
\q2 pakuti msipu wa ku chipululu ukuphukira. 
\q1 Mitengo ikubala zipatso zake; 
\q2 mitengo ya mkuyu ndi mpesa ikubereka kwambiri. 
\q1  
\v 23 Inu anthu a ku Ziyoni sangalalani, 
\q2 kondwerani mwa Yehova Mulungu wanu, 
\q1 pakuti wakupatsani 
\q2 mvula yoyambirira mwachilungamo chake. 
\q1 Iye wakutumizirani mivumbi yochuluka, 
\q2 mvula yoyambirira ndi mvula ya nthawi ya mphukira, monga poyamba paja. 
\q1  
\v 24 Pa malo opunthira padzaza tirigu; 
\q2 mʼmitsuko mudzasefukira vinyo watsopano ndi mafuta. 
\b  
\q1  
\v 25 “Ine ndidzakubwezerani zonse zimene zinawonongedwa ndi dzombe, 
\q2 dzombe lalikulu ndi dzombe lalingʼono, 
\q2 dzombe lopanda mapiko ndi dzombe lowuluka; 
\q1 gulu langa lalikulu la nkhondo limene ndinalitumiza pakati panu. 
\q1  
\v 26 Mudzakhala ndi chakudya chambiri, mpaka mudzakhuta, 
\q2 ndipo mudzatamanda dzina la Yehova Mulungu wanu, 
\q2 amene wakuchitirani zodabwitsa; 
\q1 ndipo anthu anga sadzachitanso manyazi. 
\q1  
\v 27 Pamenepo inu mudzadziwa kuti Ine ndili mu Israeli, 
\q2 kuti Ine ndine Yehova Mulungu wanu, 
\q2 ndi kuti palibenso wina; 
\q1 ndipo anthu anga sadzachitanso manyazi. 
\s1 Tsiku la Yehova 
\q1  
\v 28 “Ndipo patapita nthawi, 
\q2 ndidzakhuthulira Mzimu wanga pa anthu onse. 
\q1 Ana anu aamuna ndi ana anu aakazi adzanenera, 
\q2 nkhalamba zanu zidzalota maloto, 
\q2 anyamata anu adzaona masomphenya. 
\q1  
\v 29 Ngakhalenso pa antchito anga aamuna ndi aakazi 
\q2 ndidzakhuthulira Mzimu wanga masiku amenewo. 
\q1  
\v 30 Ndidzaonetsa zodabwitsa mlengalenga 
\q2 ndi pa dziko lapansi, 
\q2 ndizo magazi, moto ndi utsi watolotolo. 
\q1  
\v 31 Dzuwa lidzadetsedwa 
\q2 ndipo mwezi udzaoneka ngati magazi 
\q2 lisanafike tsiku lalikulu ndi loopsa la Ambuye. 
\q1  
\v 32 Ndipo aliyense amene adzayitana 
\q2 pa dzina la Ambuye adzapulumuka; 
\q1 pakuti chipulumutso chidzakhala pa Phiri la Ziyoni 
\q2 ndi mu Yerusalemu, 
\q2 monga Yehova wanenera, 
\q1 pakati pa otsala 
\q2 amene Yehova wawayitana. 
\c 3  
\s1 Kuweruzidwa kwa Mitundu ya Anthu 
\q1  
\v 1 “Masiku amenewo ndiponso nthawi imeneyo, 
\q2 nditadzabwezeretsanso Yerusalemu ndi Yuda mʼchimake, 
\q1  
\v 2 ndidzasonkhanitsa anthu a mitundu yonse 
\q2 ndipo ndidzawabweretsa ku Chigwa cha Yehosafati. 
\q1 Kumeneko ndidzawaweruza 
\q2 chifukwa cha cholowa changa, anthu anga Aisraeli, 
\q1 pakuti anabalalitsa anthu anga pakati pa mitundu ya anthu 
\q2 ndikugawa dziko langa. 
\q1  
\v 3 Anagawana anthu anga pochita maere 
\q2 ndipo anyamata anawasinthanitsa ndi akazi achiwerewere; 
\q1 anagulitsa atsikana chifukwa cha vinyo 
\q2 kuti iwo amwe. 
\p  
\v 4 “Kodi tsopano inu a ku Turo ndi Sidoni ndi madera onse a Filisitiya, muli ndi chiyani chotsutsana nane? Kodi mukundibwezera pa zinthu zimene ndakuchitirani? Ngati inu mukundibwezera, Ine ndidzabwezera zochita zanu mofulumira ndi mwachangu pa mitu yanu.  
\v 5 Pakuti munatenga siliva ndi golide wanga ndi kupita nacho chuma changa chamtengowapatali ku nyumba zanu zopembedzera mafano.  
\v 6 Inu munagulitsa anthu a ku Yuda ndi Yerusalemu kwa Agriki, kuti apite kutali ndi malire a dziko lawo. 
\p  
\v 7 “Taonani, Ine ndidzawachotsa kumalo kumene munawagulitsako, ndipo ndidzabwezera zimene mwachita pa mitu yanu.  
\v 8 Ndidzagulitsa ana anu aamuna ndi ana anu aakazi kwa anthu a ku Yuda, ndipo iwo adzawagulitsa kwa Aseba, mtundu wa anthu okhala kutali.” Yehova wayankhula. 
\q1  
\v 9 Lengezani izi pakati pa anthu a mitundu ina: 
\q2 Konzekerani nkhondo! 
\q1 Dzutsani ankhondo amphamvu! 
\q2 Asilikali onse afike pafupi ndipo ayambe nkhondo. 
\q1  
\v 10 Sulani makasu anu kuti akhale malupanga 
\q2 ndipo zikwanje zanu zikhale mikondo. 
\q1 Munthu wofowoka anene kuti, 
\q2 “Ndine wamphamvu!” 
\q1  
\v 11 Bwerani msanga, inu anthu a mitundu yonse kuchokera ku mbali zonse, 
\q2 ndipo musonkhane kumeneko. 
\b  
\q1 Tumizani ankhondo anu Yehova! 
\b  
\q1  
\v 12 “Mitundu ya anthu idzuke; 
\q2 ipite ku Chigwa cha Yehosafati, 
\q1 pakuti kumeneko Ine ndidzakhala 
\q2 ndikuweruza anthu a mitundu yonse yozungulira. 
\q1  
\v 13 Tengani chikwakwa chodulira tirigu, 
\q2 pakuti mbewu zakhwima. 
\q1 Bwerani dzapondeni mphesa, 
\q2 pakuti mopsinyira mphesa mwadzaza 
\q2 ndipo mitsuko ikusefukira; 
\q1 kuyipa kwa anthuwa nʼkwakukulu kwambiri!” 
\b  
\q1  
\v 14 Chigulu cha anthu, chigulu cha anthu, 
\q2 mʼchigwa cha chiweruzo! 
\q1 Pakuti tsiku la Yehova layandikira 
\q2 mʼchigwa cha chiweruzo. 
\q1  
\v 15 Dzuwa ndi mwezi zidzadetsedwa, 
\q2 ndipo nyenyezi sizidzawalanso. 
\q1  
\v 16 Yehova adzabangula kuchokera mu Ziyoni 
\q2 ndipo mawu ake adzamveka ngati bingu kuchokera mu Yerusalemu; 
\q2 dziko lapansi ndi thambo zidzagwedezeka. 
\q1 Koma Yehova adzakhala pothawira pa anthu ake, 
\q2 linga la anthu a ku Israeli. 
\s1 Madalitso a Anthu a Mulungu 
\q1  
\v 17 “Pamenepo inu mudzadziwa kuti Ine Yehova Mulungu wanu, 
\q2 ndimakhala mu Ziyoni, phiri langa lopatulika. 
\q1 Yerusalemu adzakhala wopatulika; 
\q2 alendo sadzamuthiranso nkhondo. 
\b  
\q1  
\v 18 “Tsiku limenelo mapiri adzachucha vinyo watsopano, 
\q2 ndipo zitunda zidzayenderera mkaka; 
\q2 mitsinje yonse ya ku Yuda idzadzaza ndi madzi. 
\q1 Kasupe adzatumphuka mʼnyumba ya Yehova 
\q2 ndipo adzathirira Chigwa cha Sitimu. 
\q1  
\v 19 Koma Igupto adzasanduka bwinja, 
\q2 Edomu adzasanduka chipululu, 
\q1 chifukwa cha nkhondo imene anathira anthu a ku Yuda 
\q2 mʼdziko limene anakhetsa magazi a anthu osalakwa. 
\q1  
\v 20 Koma Yuda adzakhala ndi anthu mpaka muyaya 
\q2 ndi Yerusalemu ku mibadomibado. 
\q1  
\v 21 Kukhetsa magazi kwawo kumene Ine sindinakhululuke 
\q2 ndidzakhululuka.” 
\b  
\qc Yehova amakhala mu Ziyoni!