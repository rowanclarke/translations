\c 10  
\s1 Worthless idols  
\p
\v 1 \w You|strong="H5921"\w* \w people|strong="H8085"\w* \w of|strong="H1004"\w* \w Israel|strong="H3478"\w*, \w listen|strong="H8085"\w* \w to|strong="H1696"\w* \w what|strong="H1697"\w* \w Yahweh|strong="H3068"\w* \w says|strong="H1696"\w*:   
\q1
