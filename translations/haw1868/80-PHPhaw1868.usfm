\id PHP
\h Pilipi
\toc1 Pilipi
\toc2 Pilipi
\toc3 Pilipi
\mt1 Pilipi
\c 1
\s1 O KA EPISETOLE
\q1 
\v 1 O PAULO a me Timoteo na kauwa a Iesu Kristo, na ka poe haipule a pau iloko o Kristo Iesu o noho ana i Pilipi, me na lunakiai a me na diakono:
\q1 
\v 2 He aloha ia oukou, a me ka malu mai ke Akua mai o ko kakou Makua, a me ka Haku Iesu Kristo.
\b
\q1 
\v 3 Ke hoomaikai aku nei au i ko'u Akua i na manawa a pau a'u i hoomanao ai ia oukou;
\q1 
\v 4 I na pule a pau a'u no oukou a pau, ua pule no au me ka olioli,
\q1 
\v 5 No ko oukou hoolauna ana i ka euanelio, mai ka la mua mai a i neia wa.
\q1 
\v 6 Ua maopopo ko'u manao i keia mea, o ka mea nanai hoomakai ka hana maikai iloko o oukou, nana no ia e hoomau a hiki i ka la o Iesu Kristo.
\q1 
\v 7 He mea pono ia no'u e manao aku ai pela no oukou a pau, no ka mea, eia no oukou iloko o kuu naau, i kuu wa o paa ana, a me kuu hoakaka ana, a me ka hookupaa ana i ka euaoelio; ua loaa pu la oukou a pau kuu lokomaikaiia mai.
\q1 
\v 8 No ka mea, o ke Akua no ko'u hoike maka, he nui kuu makemake aku ia oukou a pau, e like me ke aloha o Iesu Kristo.
\q1 
\v 9 O keia hoi ka'u e pule aku nei, i mahuahua loa aku ko oukou aloha ma ka naauao a me ka akamai
\q1 
\v 10 I hoomaopopo hoi oukou i na mea maikai loa; oiaio oukou, i hihia ole hoi, a hiki i ka la o Kristo;
\q1 
\v 11 I hoopihaia hoi oukou i na hua o ka pono, i mea e hoonani ai a e hoomaikaiia aku ai ke Akua mao Iesu Kristo la.
\b
\q1 
\v 12 E na hoahanau, ke ake nei au e ike oukou, o na mea i loaa ia'u, ua lilo ia i mea e palahalaha'i ka eoanelio.
\q1 
\v 13 No ka mea, o kuu paa ana no Kristo, na ike pono ia ma ka halealii, a ma na wahi e ae a pau.
\q1 
\v 14 A he nui na hoahanau iloko o ka Haku i hooikaikaia i kuu pahao ana, ua ikaika nui ae lakou e hai aku i ka olelo me ka makau ole.
\q1 
\v 15 Ua hai aku nae kekahi poo ia Kristo me ka huahuwa a me ka hakaka; a o kekahi poe me ka manao aloha.
\q1 
\v 16 Ua hai aku kela poe ia Kriato me ka hakaka, aole me ka manao pono; ke manao la lakou e hoonui mai i ka ino o ko'u paahao ana.
\q1 
\v 17 A o keia poo me ke aloha, ke ike nei lakou, ua hoonohoia au no ka hoakaka ana'ku i ka euanelio.
\q1 
\v 18 Heaha la hoi! a ina ma ka hookamani, ina hoi paha ma ka oiaio i haiia'ku ai o Kristo; ke olioli nei au ilaila, oia, e olioli mau ana hoi au.
\q1 
\v 19 No ka mea, ke ike nei au, e lilo ana keia i mea ola no'u ma ka oukou pule, a me ke kokuaia mai e ka Uhane o Iesu Kristo;
\q1 
\v 20 E like me ke kuko nui a me ka manaolana o'u, i ole au e hilahila kekahi mea; aka, ma ka ikaika nui me ia e mau ana, pela hoi i neia manawa, e hoonaniia i o Kristo ma ko'u kino, ke ola ia, a ke make paha.
\q1 
\v 21 No ka mea, a i ola no au, no Kristo ia, a i make hoi, o ko'u pomaikai ia.
\q1 
\v 22 Ina hoi au e ola ma ke kino nei, oia ka pono o ka'u hana ana: aka, o ka'u mea pono e koho aku ai, aole au e ike ia.
\q1 
\v 23 No ka mea, he pilikia ko'u iwaena o na mea elua, o ke ake e hele a e noho me Kristo; oia ka maikai loa;
\q1 
\v 24 Aka, o ka noho ma ke kino, ka mea ia e pono io ai oukou.
\q1 
\v 25 A ua maopopo kuu manao i keia, ua ike au e ola ana au a o noho ana me oukou a pau, i mea e mahuahua'i ko oukou olioli ma ka manaoio;
\q1 
\v 26 I nui ae hoi ko oukou hauoli no'u ma o Kristo Iesu la, i kuu hiki hou ana'ku io oukou la.
\b
\q1 
\v 27 E hana wale oukou ma ka pono o ka euanelio a Kristo; a ina paha e hele aku au e ike ia oukou, ma paha hoi ma kahi e e lohe auanei au i ka oukou mau mea, e ike no na kupaa oukou ma ka nhane hookahi, me ka manao hookahi, a me ka hooikaika pu ana i ka manaoio o ka euanelio;
\q1 
\v 28 Aole hoi i hooweliweli iki ia mai oukou e ka poe enemi; he hoailona ia ia lakou no ka make, aka, ia oukou, he hoailona ia no ke ola, a oia hoi mai ke Akua mai.
\q1 
\v 29 No ka mea, ua haawi lokomaikai ia mai ia ia oukou no Kristo, aole ka manaoio wale aku no ia ia, aka, o ka hoopiiikiaia mai hoi nona.
\q1 
\v 30 Uookahi o oukou paio ana me ka oukou i ike mai ai iloko o'u, a me ka oukou e lohe nei iloko o'u.
\c 2
\b
\q1 
\v 1 NOLAILA, ina he mea e malu ai iloko o Kristo, ina paha he oluolu i ke aloha, ina hoi he hoolauna pu ma ka Uhane, ina hoi he aloha o ka naau a me ka lokomaikai,
\q1 
\v 2 E hooko mai oukou i kuu olioli, i like pu ai hoi ko oukou manao, hookahi hoi ke aloha, hookahi no hoi naau, e manao hookahi ana.
\q1 
\v 3 Mai hana oukou i kekahi mea me ka hakaka a me ka hookiekie wale; aka, me ka naau akahai e hooi aku i ka manao maikai ia hai, aole ia oukou iho.
\q1 
\v 4 Aole hoi e nana ana kela mea keia mea i kana iho: aka, e nana hoi kela mea keia mea i ka hai.
\q1 
\v 5 I hookahi ka manao ana iloko o oukou, me ia iloko o Kristo Iesu;
\q1 
\v 6 Oia no ko ke Akua mea Hke, aole hoi ia imanao i kona iike ana me ke Akua he mea lawe wale:
\q1 
\v 7 Aka, waiho iho la ia i kona, e lawe ana i ke ano o ke kanwa, a ua lilo iho la oia ma ke ano kanaka.
\q1 
\v 8 A loaa iho la ke ano o ke kanaka, hoohaahaa iho la oia ia ia iho, me ka ae maoli aku i ka make, i ka make hoi ma ke kea.
\q1 
\v 9 No ia mea, ua hookiekie loa ae la ke Akua ia ia, a haawi aku la nona i ka inoa maluna o na inoa a pau;
\q1 
\v 10 I kukuli iho na kuli a pau i ka inoa o Iesu, o na mea o ka lani, a me na mea ma ka honua, a me na mea malalo ae o ka honua;
\q1 
\v 11 I hooia aku hoi na elelo a pau, o Iesu Kristo ka Haku, ka mea e nani ai ke Akua ka Makua.
\b
\q1 
\v 12 No ia mea, e o'u poo aloha, me oukou i hoolohe mau ai, aole wale no ia'u i noho ai me oukou, aka hoi, na nui aku i neia wa e noho nei au i kahi e, e hooikaika aku oukou i ke ola no oukou iho, me ka makau a me ka haalulu:
\q1 
\v 13 No ka mea, o ke Akua ka mea e hooikaika ana iloko o oukou, i ka makemake a me ka hana, no kona manao aloha.
\q1 
\v 14 E hana oukou i na mea a pau me ka ohumu ole, a me ka hoopaapaa ole:
\q1 
\v 15 I hala ole oukou a me ke kolohe ole, he poe keiki na ke Akua, i hoohewa olo ia iwaena o ka hanauna kekee a me ke kolohe, e alohi hoi oukou iwaena o lakou e like me na malamalama i ke ao nei;
\q1 
\v 16 E hoike aku ana i ka olelo e ola'i, i olioli ai au i ka la o Kristo, no kuu holo hewa oie, a me ka luhi hewa ole.
\b
\q1 
\v 17 Ina e nininiia aku au maluna o ka mohai a me ka alana o ko oukou manaoio, e olioli no wau, a e hauoli pu hoi me oukou a pau.
\q1 
\v 18 No keia mea hoi, e olioli oukou, a e hanoli pu mai me au.
\b
\q1 
\v 19 A ke manao nei au ma ka Haku ma o Iesu la, e hoouna koke aku ia Timoteo io oukou la, i olioli ai hoi au i ka wa a'u e ike ai i ka oukou mau mea.
\q1 
\v 20 Aole o'u kanaka manao like, nana e malama io i ka oukou mau mea.
\q1 
\v 21 No ka mea, ke imi nei na mea a pau i ka lakou iho, aole i ka Iesu Kristo.
\q1 
\v 22 Ua ike hoi oukou i kona hoaoia'na, no ka mea, ua hooikaika pu ia me au ma ka euanelio, me he keiki la me ka makua.
\q1 
\v 23 No ia mea, ke manao nei au e hoouna koke aku ia ia, aia ike au i ka hope o ka'u mau mea.
\q1 
\v 24 Ua maopopo hoi kuu manao ma ka Haku, e hiki koke aku hoi au io oukou la.
\q1 
\v 25 Aka, manao iho la au, he pono ke hoouna aku ia Epaperodito io oukou la, oia he hoahanau, he hoalawehana, a me ka hoa koa o'u, a o ko oukou elele no hoi, a me ka mea lawelawe na kuu hemahema.
\q1 
\v 26 No ka mea, he nui kona makemake ia oukou a pau, ua kaumaha loa kona naau, i ko oukou lohe ana he mai kona.
\q1 
\v 27 A he mai no kona, ua kokoke e make: aka, ua aloha mai ke Akua ia ia; aole ia ia wale no, ia'u no hoi, o loaa ia'u ke kaumaha maluna o ke kaumaha.
\q1 
\v 28 Nolaila, ua hoouna wikiwiki aku la au ia ia, i olioli ai oukou ke ike hou aku ia ia, i uuku iho hoi kuu eha.
\q1 
\v 29 E hookipa aku hoi oukou ia ia no ka Haku, me ka olioli nui; e manao maikai aku hoi oukou i ka poe like.
\q1 
\v 30 No ka mea, ma ka hana a Kristo, ua hookokoke aku la ia i ka make, aole no i malama i kona ola, i hoopau ai oia i ka mea i koe o ko oukou malama mai ia'u.
\c 3
\b
\q1 
\v 1 NO na mea i koe, e na hoahanau o'u, e olioli oukou i ka Haku. Aole o'u luhi ke palapala aku ia oukou i na mea like, a he mea pono hoi ia no oukou.
\q1 
\v 2 E makaala oukou i na ilio, e makaala i ka poe hana ino, e makaala hoi i ka poe i okiokiia.
\q1 
\v 3 No ka mea, o kakou ka poe i okipoepoeia, ka poe hoomana i ke Akua me ka naau, me ka hauoli ia Kristo Iesu, aole no e paulele i ko ke kino:
\q1 
\v 4 Aka, owau paha ka mea hiki ke paulele ma ko ke kino. Ina paha e manao kekahi he mea ia ia e paulele ai ma ko ke kino, he nui aku hoi ka'u.
\q1 
\v 5 Ua okipoepoeia au i ka po awalu, no ka lahuikanaka o Iseraela, no ka ohana o Beniamina, he Hebera hoi no na Hebera, a he Parisaio ma ke kanawai.
\q1 
\v 6 No ka manao ikaika, hoomaau aku la au i ka ekalesia; a ma ka pono o ke kanawai, aole o'u hala.
\q1 
\v 7 Aka, o na mea a'u i pemaikai ai, lilo ae la ia i kuu manao i mea poho no Kristo.
\q1 
\v 8 Oiaio hoi, ke manao nei au i na mea a pau, he mea poho ia i loaa mai ai ka maikai o ka ike ia Kristo Iesu i kuu Haku; nona au i hoolei ai i na mea a pau, a ke manao nei au, he opala wale no ia i loaa'i ia'u o Kristo,
\q1 
\v 9 I loaa hoi au iloko ona, aole e paa ana i ka'u pono ma ke kanawai, aka, i ka pono ma ka manaoio ia Kristo, oia ka pono mai ke Akua mai ma ka manaoio:
\q1 
\v 10 I ike hoi au ia ia, me ka mana o kona alahouana mai, a me ka hookahi ana o kona hoinoia, i hoohalikeia aku me kona make ana;
\q1 
\v 11 Malia paha e hiki aku auanei au i ke alahouana o ka poe i make.
\q1 
\v 12 No ka mea, aole i loaa ia'u i neia manawa, aole hoi au i hemolele: aka, ke hahai aku nei au, i lalau aku ai au i ka mea i lalauia mai ai au e Kristo Iesu.
\q1 
\v 13 E na hoahanau, ma kuu manao iho, aole au i lalau aku: aka, o keia hookahi ka'u e hana nei, e hoopoina ana au i na mea i hala mahope, a e kikoo aku ana au i na mea mamua,
\q1 
\v 14 Ke holo ikaika aku nei au ma ka hoailona, i loaa ia'u ka lei o ka poe a ke Akua i hea mai ai noluna mai ma o Kristo Iesu la.
\b
\q1 
\v 15 O na mea a pau e ake e hemolele, e manao kakou ia mea; a ina he manao okoa ko oukou i kekahi mea, na ke Akua hoi ia e hoike mai ia oukou.
\q1 
\v 16 Aka, o ka mea i loaa ia kakou, e haele kakou ma ke kanawai hookahi nei, e manao hoi kakou i ka mea hookahi.
\b
\q1 
\v 17 E na hoahanau, e hoohalike pu oukou me au, e nana pono hoi oukou i ka poe hele like me makou i kumu hoohalike na oukou.
\q1 
\v 18 (No ka mea, he nui no ka poe e hele ana, a'u i hai pinepine aku ai ia oukou, a ano hoi ke hai aku nei au me ka uwe ana, he poe enemi lakou i ke kea o Kristo:
\q1 
\v 19 O ka make ko lakou nope, o ka opu hoi ko lakou akua, a ma ka mea hilahila ko lakou nani, ke manao nei hoi lakou i na mea o ka honua.)
\q1 
\v 20 Aka, o ko kakou noho ana, aia no ia ma ka lani; ke kali nei hoi kakou i ka Mea hoola, oia ka Haku Iesu Kristo nolaila mai:
\q1 
\v 21 Nana e hoololi ae ko kakou kino haahaa, i lilo ia i ano like me kona kino nani, ma ka mana e hiki ai ia ia ke hoolilo i na mea a pau nona.
\c 4
\b
\q1 
\v 1 NOLAILA hoi, e na hoahanau o'u i alohaia, a i makemake nui ia, o kuu olioli a me kuu leialii; pela e kupaa ai oukou iloko o ka Haku, e na mea i alohaia.
\b
\q1 
\v 2 Ke noi aku nei au ia Euodia, ke noi aku nei hoi au ia Sunetuke, i hookahi ko laua manao iloko o ka Haku.
\q1 
\v 3 Ke noi aku nei hoi au ia oe kekahi, e ka hoalawehana io, e kokua aku oe ia mau wahine, i hooikaika pu me au ma ka euanelio, a me Kelemeneto hoi, a me o'u mau hoalawehana e ae, aia no maloko o ka buke ola ko lakou mau inoa.
\b
\q1 
\v 4 E hauoli mau oukou i ka Haku; ke olelo hou aku nei hoi au, e hauoli oukou.
\q1 
\v 5 I hoikeia hoi ko oukou akahai i na kanaka a pau. Ua kokoke mai ka Haku.
\q1 
\v 6 Mai manao nui oukou i kekahi mea; aka, i na mea a pau e hoike aku i ko oukou makemake i ke Akua ma ka pule, a me ka noi aku, a me ka hoomaikai aku.
\q1 
\v 7 A o ka maluhia o ke Akua, ka mea i oi aku i ko ke kanaka manao a pau, e hoomalu mai i ko oukou naau a me ko oukou manao ma o Kristo Iesu la.
\b
\q1 
\v 8 Eia hoi e na hoahanau, o na mea oiaio, na mea maikai, na mea pono, na mea hala ole, na mea lokomaikai, na mea lono maikai ia; ina he mea kupono, ina hoi he mea e hoomaikaiia'i, e noonoo iho oukou ia mau mea.
\q1 
\v 9 O na mea a oukou i aoia'i, i loaa hoi, i lohe a i ike hoi ia'u, o keia ka oukou e hana'i; a me oukou hoi ke Akua ka mea e malu ai.
\b
\q1 
\v 10 Ua olioli nui au i ka Haku, no ka mea, ua kupu hou mai ko oukou manao e kokua ia'u; malaila no oukou i manao ai, aka, aole a oukou mea e hiki ai.
\q1 
\v 11 Aole au i olelo pela no ka nele; no ka mea, ua aoia hoi au e oluolu iho i na mea a pau i loaa ia'u.
\q1 
\v 12 Ua ike hoi au i ka noho ilihune, a me ka noho lako: i na wahi a pau, a i na mea a pau, ua aoia mai la au e noho maona a e noho pololi, e noho lako a e noho nele.
\q1 
\v 13 E hiki no ia'u na mea a pau, ke kokua mai o Kristo ia'u.
\q1 
\v 14 Aka hoi, ua hana pono mai oukou, i ko oukou manawalea ana mai ia'u i ko'u popilikia.
\q1 
\v 15 E ko Pilipi, ua ike no oukou, i ka wa kinohou o ka euanelio, ia'u i haalele ai ia Makedonia, aole kekahi ekalesia e ae i launa mai ia'u i ka haawi ana a i ka lawe ana, o oukou wale no.
\q1 
\v 16 No ka mea, a i Tesalouike hookahi a elua hoi o ko oukou hoouka ana mai i ka mea e pono ai kuu nele.
\q1 
\v 17 Aole ka makana ka'u e imi nei; aka, ke imi nei au i ka hua e nui ai ko oukou pono.
\q1 
\v 18 A ia'u na mea he nui, a ua lako hoi: ua piha au i ka oukou mau mea i loaa mai ma o Epaperodito la, he mea ala oluolu, he mohai hooluolu, i maliuia mai hoi e ke Akua.
\q1 
\v 19 Aka, e haawi mai ana ko'u Akua i na mea a pau e pono ai oukou, no kona waiwai i kahi nani ma o Kristo Iesu la.
\q1 
\v 20 A i ke Akua ko kakou Makua ka hoonani mau loa ia i ke ao pau ole. Amene.
\b
\q1 
\v 21 E uwe aku i na haipule a pau iloko o Kristo Iesu. Ke uwe aku nei na hoahanau me au ia oukou.
\q1 
\v 22 Ke uwe aku nei na haipule a pau ia oukou, o lakou hoi no na ohua o Kaisara.
\b
\q1 
\v 23 O ke aloha o ko kakou Haku o Iesu Kristo me oukou a pau. Amene. 
