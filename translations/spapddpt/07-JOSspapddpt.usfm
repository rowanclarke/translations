\p \w Se|strong="H5921"\w* fueron elevando \w como|strong="H5921"\w* \w en|strong="H5921"\w* un embalse \add que llegó\add* \w a|strong="H3068"\w* \w gran|strong="H3966"\w* distancia, \w junto|strong="H5921"\w* \w a|strong="H3068"\w* Adán, \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w que|strong="H5921"\w* \w está|strong="H5975"\w* \w al|strong="H5921"\w* \w lado|strong="H6654"\w* \w de|strong="H5921"\w* Saretán, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w que|strong="H5921"\w* \w descendían|strong="H3381"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w del|strong="H5921"\w* Arabá, \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Sal|strong="H4417"\w*, fueron \w cortadas|strong="H3772"\w* completamente. \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* cruzó \w frente|strong="H5048"\w* \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w*.   
\p
\v 17 \w Los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w que|strong="H5704"\w* cargaban \w el|strong="H3605"\w* Arca del \w Pacto|strong="H1285"\w* \w de|strong="H5704"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* se pararon \w en|strong="H5704"\w* \w lo|strong="H5704"\w* seco, \w firmes|strong="H3559"\w* \w en|strong="H5704"\w* \w medio|strong="H8432"\w* del \w Jordán|strong="H3383"\w*, \w mientras|strong="H3605"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* cruzaba \w en|strong="H5704"\w* seco, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* pueblo terminó \w de|strong="H5704"\w* cruzar \w el|strong="H3605"\w* \w Jordán|strong="H3383"\w*.   
\c 4  
\s1 12 piedras  
\p
\v 1 \w Cuando|strong="H1961"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* pueblo \w acabó|strong="H8552"\w* de \w pasar|strong="H5674"\w* \w el|strong="H3605"\w* \w Jordán|strong="H3383"\w*, \nd \+w Yavé|strong="H3068"\+w*\nd* habló \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*:  
