\v 2  \w One|strong="H2896"\w* \w evening|strong="H6153"\w* \w David|strong="H1732"\w* \w got|strong="H6965"\w* \w up|strong="H6965"\w* \w from|strong="H5921"\w* \w his|strong="H1732"\w* \w bed|strong="H4904"\w* \w and|strong="H1980"\w* \w walked|strong="H1980"\w* \w around|strong="H5921"\w* \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w roof|strong="H1406"\w* \w of|strong="H4428"\w* \w his|strong="H1732"\w* \w palace|strong="H1004"\w*. \w From|strong="H5921"\w* \w the|strong="H5921"\w* \w roof|strong="H1406"\w* \w he|strong="H1004"\w* \w saw|strong="H7200"\w* \w a|strong="H3068"\w* \w woman|strong="H1004"\w* \w bathing|strong="H7364"\w*. \w Now|strong="H1961"\w* \w this|strong="H7200"\w* \w woman|strong="H1004"\w* \w was|strong="H1961"\w* \w very|strong="H3966"\w* \w attractive|strong="H4758"\w*.  
