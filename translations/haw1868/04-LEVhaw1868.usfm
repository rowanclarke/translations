\id LEV  
\h Oihanakahuna 
\toc1 Oihanakahuna 
\toc2 Oihanakahuna 
\toc3 Oihanakahuna 
\mt1 Oihanakahuna  
\c 1  
\s1 KA BUKE AKOLU A MOSE, I KAPAIA  
\q1
\v 1 KAHEA mai la o Iehova ia Mose, olelo mai la hoi ia ia mai loko mai o ka halelewa o ke anaina, i mai la,   
\q1
\v 2 E olelo aku oe i na mamo a Iseraela, e i aku hoi ia lakou, Ina e lawe kekahi kanaka o oukou i ka mohai ia Iehova, no na holoholona e lawe ai oukou i ka oukou mohai, no ka ohana bipi, a no ka ohana hipa,   
\q1
\v 3 Ina o kana mohai he mohaikuni noloko o ka ohana bipi, e mohai oia i ke kane kina ole: e mohai aku hoi oia ia no kona makemake iho ma ka puka o ka halelewa o ke anaina, ma ke alo o Iehova.   
\q1
\v 4 A e kau ae oia i kona lima maluna o ke poo o ka mohaikuni; a e maliuia nona e hooliloia i kalahala nona.   
\q1
\v 5 A e pepehi oia i ka bipi kane ma ke alo o Iehova; a o lawe mai na kahuna, ka Aarona mau keiki, i ke koko, a e pipi i ke koko a puni maluna iho o ke Kuahu, ka mea ma ka puka o ka halelewa o ke anaina.   
\q1
\v 6 A e lole oia i ka ili o ka mohaikuni, a e okioki i ka mohai i mau apana.   
\q1
\v 7 A e kau ae na keiki a Aarona ke kahuna i ke ahi maluna o ke kuahu, a e kau pono i ka wahie maluna o ke ahi.   
\q1
\v 8 A e kau na kahuna, ka Aarona mau keiki i na apana, i ke poo, a me ke kaikea, a pono maluna o ka wahie ka mea maluna o ke ahi, ka mea maluna o ke kuahu.   
\q1
\v 9 Aka e holoi oia i kona naau, a me kona mau wawae, me ka wai; a e kuni ke kahuna i na mea a pau maluna o ke kuahu, i mohaikuni, he inohai i kaumahaia ma ke ahi, he mea ala ono ia Iehova.   
\b  
\q1
\v 10 A ina no loko o ka ohana o na hipa, a o na kao kona mohai i mohaikuni, e lawe mai oia ia he kane kina ole,   
\q1
\v 11 A e pepehi oia ia ia ma ka aoao kukulu akau ma ke alo o Iehova; a e pipi na kahuna ka Aarona mau keiki i kona koko a puni maluna o ke kuahu.   
\q1
\v 12 A e okioki iho oia i mau apana una me kona poo a me kona konahua: a e kau ke kahuna ia mau mea a pono, maluna o ka wahie, ka mea maluna o ke ahi, ka mea maluna o ke kuahu.   
\q1
\v 13 Aka e holoi oia i ka naau, a me kona mau wawae me ka wai; a e lawe pu mai ke kahuna a e kuni maluna iho o ke kuahu: he mohaikuni ia, he mohai i kaumahaia ma ke ahi, he mea ala ono ia Iehova.   
\b  
\q1
\v 14 A ina no na manu ka mohaikuni kona mohai ia Iehova, alaila e lawe mai oia i kana mohai no na kuhukuku, a i ole ia, no na nunu opiopio.   
\q1
\v 15 A e lawe mai ke kahuna ia i ke kuahu, a e niki i kona poo, a e kuni aku ia ma ke kuahu, a e uwiia kona koko ma ka aoao o ke kuahu.   
\q1
\v 16 A e unuhi ae oia i kona opu a me kona haumia, a e holoi ae ia ma ka aoao o ke kuahu, ma ka hikina, ma kahi o ka lehu.   
\q1
\v 17 A e mahele oia ia ia me kona mau eheu, aole hoi e hookaawale loa; a e kuni ke kahuna ia ma ke kuahu maluna o ka wahie ka mea iluna o ke ahi; he mohaikuni ia, he mohai kaumahaia ma ke ahi, he mea ala ono ia Iehova.   
\c 2  
\b  
\q1
\v 1 A INA e lawe mai kekahi i ka mohaiai, ia Iehova, o kana mohai auanei he palaoa wali; a e ninini iho oia i ka aila maluna iho, a e kau hoi i ka libano maluna iho.   
\q1
\v 2 A e lawe mai oia ia i ka Aarona mau keiki, i na kahuna; a e lawe ae noloko, a piha kona lima i kona palaoa, a me kona aila me kona libano a pau, a e kuni ke kahuna i kona mea hoomanao, maluna o ke kuahu, i mohai i kaumahaia ma ke ahi, he mea ala ono ia Iehova.   
\q1
\v 3 A e lilo ke koena na Aarona, a me kana mau keiki, he mea hoano loa no na mohaipuhi o Iehova.   
\b  
\q1
\v 4 A ina e lawe mai oe i ka alana o ka mohaiai i kahuia ma ka umu, he mau popo palaoa hu ole i hui pu me ka aila, a i ole ia he mau papa palaoa i hamoia me ka aila.   
\b  
\q1
\v 5 A ina o kau alana he mohaiai moa ma ke pa, ka palaoa hu ole no ia i hui me ka aila.   
\q1
\v 6 E wawahi hoi oe i mau apana, a e ninini i ka aila maluna; he mohaiai ia.   
\b  
\q1
\v 7 A ina o kau alana he mohaiai moa ma ke paparai, e hanaia ia no ka palaoa a me ka aila.   
\q1
\v 8 A e lawe mai oe i ka mohaiai i hanaia no ia mau mea ia Iehova; a haawiia'e i ke kahuna, e lawe oia ia i ke kuahu.   
\q1
\v 9 A e lawe ke kahuna i ka mea hoomanao mai loko mai o ka mohaiai, a e kuni aku ia mea ma ke kuahu: he mohai ia i alanaia ma ke ahi, he mea ala ono ia Iehova.   
\q1
\v 10 A o ke koena o ka mohaiai, e lilo ia no Aarona, a me kana mau keiki; he mea hoano loa no na mohai i kaumahaia ma ke ahi no Iehova.   
\b  
\q1
\v 11 Aole e hanaia me ka hu ka mohaiai a oukou e lawe ai ia Iehova; no ka mea, aole oukou e kuni i ka hu, aole hoi i ka meli, iloko o na mohaipuhi na Iehova.   
\b  
\q1
\v 12 A o ka alana o na hua mua, e mohai aku no oukou ia mau mea ia Iehova; aole hoi lakou e kuniia ma ke kuahu i mea ala ono.   
\q1
\v 13 A o na alana a pau o kau mau mohaiai, oia kau e hoomiko ai me ka paakai; aole oe e hoonele i kau mau mohaiai i ka paakai o ka berita o kou Akua: me kau mau mohai a pau, e mohai pu oe i ka paakai.   
\b  
\q1
\v 14 A ina e mohai aku oe na Iehova i ka mohaiai no kau mau hua mua, o na opuu maka moa ma ke ahi, na hua hohoaia, oia kau e alana ai i mohaiai no kau mau hua mua.   
\q1
\v 15 A e ninini oe i ka aila maluna a me ka libano; he mohaiai no ia.   
\q1
\v 16 A e kuni ke kahuna i ka mea hoomanao ona, o kona hua hohoaia, a o kona aila, a me kona libano a pau, he mohai puhi no Iehova.   
\c 3  
\b  
\q1
\v 1 A INA o kona alana, he mohaihoomalu, a no na holoholona i kaumaha ai oia ia, ina he kane paha, he wahine paha, e mohai no hoi oia ia mea me ke kina ole imua o Iehova.   
\q1
\v 2 A e kau no oia i kona lima maluna o ke poo o kona mohai, a e pepehi iho ia ma ka puka o ka halelewa o ke anaina; a e pipi na kahuna, na keiki a Aarona i ke koko maluna o ke kuahu a puni.   
\q1
\v 3 A e kanmaha aku oia i ka mohaihoomalu, he mohai i kaumahaia ma ke ahi ia Iehova, ka makaupena e uhi ana i ka naau, a me ka nikiniki a pau ma ka naau;   
\q1
\v 4 A o na puupaa elua, a me ke konahua maluna iho o laua, ka mea ma na puhaka, a me ka aa o ke au ma ke akepaa a me na puupaa, oia kana e lawe aku ai.   
\q1
\v 5 A e kuni na keiki a Aarona ia mea ma ke kuahu maluna o ka mohaikuni ma ka wahie, ka mea maluna o ke ahi; he mohai puhi ala ono ia Iehova.   
\b  
\q1
\v 6 A ina hoi no na ohana kana mohai, he mohaihoomalu ia Iehova, he kane paha, he wahine paha, he mea kina ole hoi kana e kaumaha ai.   
\q1
\v 7 A ina e kanmaha oia i keikihipa he mohai ana, e kaumaha aku hoi oia ia mea ma ke alo o Iehova.   
\q1
\v 8 A e kau ae hoi oia i kona lima ma ke poo o kana mohai, a e pepehi hoi oia ia ma ke alo o ka halelewa o ke anaina; a e pipi ae o ka Aarona mau keiki i kona koko ma ke kuahu a puni.   
\q1
\v 9 A e kaumaha aku oia i ka mohaihoomalu, he alana puhi ia Iehova; o kona kaikea a me ka huelo, e lawe ae oia ma ka iwi kuamoo: o ka makaupena e uhi ana i ka naau, a me ka nikiniki a pau ma ka naau,   
\q1
\v 10 A o na puupaa elua, a me ke konahua maluna iho o laua, ka mea ma na puhaka, a me ka aa o ke au ma ke akepaa, a me na puupaa, oia kana e lawe aku ai.   
\q1
\v 11 A e kuni iho ke kahuna ia ma ke kuahu; he ai o ka mohai i kaumahaia ma ke ahi ia Iehova.   
\b  
\q1
\v 12 A ina he kao kana mohai, alaila e mohai aku oia ia ma ke alo o Iehova.   
\q1
\v 13 A e kau ae hoi oia i kona lima ma kona poo, a e pepehi hoi oia ia ma ke alo o ka halelewa o ke anaina; a e pipi ae o ka Aarona mau keiki i kona koko ma ke kuahu a puni.   
\q1
\v 14 No ia mea e alana ai oia i kana mohai, he alana puhi no Iehova; o ka makaupena e uhi ana i ka naau, a me ka nikiniki a pau ma ka naau,   
\q1
\v 15 A o na puupaa elua, a me ke konahua maluna iho o laua, ka mea ma na puhaka, a me ka aa o ke au ma ke akepaa, a me na puupaa, oia kana e lawe aku ai.   
\q1
\v 16 A e kuni iho ke kahuna ia mau mea ma ke kuahu; he ai ia o ka alana puhi no Iehova he mea ala ono. O ke kaikea a pau, no Iehova no ia.   
\q1
\v 17 He kanawai mau keia no ko oukou mau hanauna ma ko oukou mau hale a pau, aole loa oukou e ai i ke kaikea a me ke koko.   
\c 4  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 2 E olelo aku oe i na mamo a Iseraela, penei, Ina no ka ike ole e hana hewa kekahi uhane i kekahi kauoha a Iehova, i ka mea pono ole ke hana, a e hana hewa aku i kekahi o ia mau mea:   
\q1
\v 3 Ina e hana hewa ke kahuna i poniia i hewa ai na kanaka: alaila e lawe mai oia no ka hewa ana i hana'i, i ka bipikane opiopio kina ole ia Iehova i mohailawehala.   
\q1
\v 4 A e lawe mai ia i ka bipikane i ka puka o ka halelewa o ke anaina imua o Iehova; a e kau i kona lima ma ke poo o ka bipikane, a e pepehi iho i ka bipikane ma ke alo o Iehova.   
\q1
\v 5 A e lalau iho ke kahuna i poniia i ke koko o ka bipikane, a e lawe mai ia i ka puka o ka halelewa.   
\q1
\v 6 A e hoo ke kahuna i kona manamana lima iloko e ke koko, a e pipi i kauwahi o ke koko, i ehiku ka pipi ana ma ke alo o Iehova, mamua o ka paku o ke keenakapu.   
\q1
\v 7 A e kau ke kahuna i kauwahi o ke koko ma na pepeiaohao o ke kuahu mea ala ono, ma ke alo o Iehova, ka mea maloko o ka halelewa o ke anaina; a e ninini iho i ke koko a pau o ka bipikane, malalo o ke kuahu mohaikuni, ka mea ma ka puka o ka halelewa o ke anaina.   
\q1
\v 8 A e lawe nolaila mai i ke kaikea a pau o ka bipikane, i mohailawehala; o ka makaupena e uhi ana i ka naau a me ka nikiniki a pau ma ka naau,   
\q1
\v 9 O na puupaa hoi elua a me ke konahua maluna iho o laua, ka mea ma na puhaka, a me ka aa o ke au ma ke akepaa, me na puupaa, oia kana e lawe aku ai;   
\q1
\v 10 Me ia i laweia'e mai luna ae o ka alana o na mohaihoomalu; a e kuni iho ke kahuna ia mau mea ma ke kuahu mohaikuni.   
\q1
\v 11 A o ka ili o ka bipikane, a me kona io a pau, me kona poo, a me kona mau wawae, a me kona naau, a me kona lepo;   
\q1
\v 12 O ka bipikane hoi a pau, oia kana e lawe aku ai iwaho o kahi e hoomoana'i, i kahi maemae, kahi i nininiia'i ka lehu, a e hoopau iho ia ia maluna o ka wahie me ke ahi; ma kahi i nininiia'i ka lehu e kuniia'i ia.   
\b  
\q1
\v 13 A ina e hana hewa ke anaina a pau o Iseraela, no ka ike ole, a i hunaia ia i na maka o ka ahakanaka, a ua hana i kekahi o na kauoha a Iehova, i ka mea pono ole ke hana, a ua hewa;   
\q1
\v 14 A i ka wa e ikeia'i ka hewa a lakou i hana aku ai ia ia, alaila e mohai iho ke anaina i ka bipikane opiopio, no ia hewa, a e lawe mai ia ia i ke alo o ke anaina.   
\q1
\v 15 A e kau na lunakahiko o ke anaina i ko lakou mau lima maluna o ke poo o ka bipikane, imua i ke alo o Iehova; a e pepehi i na bipikane la imua i ke alo o Iehova.   
\q1
\v 16 A e lawe mai ke kahuna i poniia i ke koko o ka bipikane i ka halelewa o ke anaina.   
\q1
\v 17 A e hoo iho ke kahuna i kona manamana lima i kauwahi o ke koko, a e pipi aku ia, i ehiku ka pipi ana, ma ke alo o Iehova, imua o ka paku.   
\q1
\v 18 A e kau aku oia i kauwahi o ke koko ma na pepeiaohao o ke kuahu, ka mea ma ke alo o Iehova, ka mea iloko o ka halelewa o ke anaina, a e ninini aku i ke koko a pau malalo o ke kuahu mohaikuni, ka mea ma ka puka o ka halelewa o ke anaina.   
\q1
\v 19 A e lawe oia i ke kaikea a pau mai ona aku, a e kuni iho ma ke kuahu.   
\q1
\v 20 A e hana hoi oia i ka bipikane, me ia i hana aku ai i ka bipikane i mohailawehala, pela no ia e hana'i i keia; a e hana ke kahuna i kala hala no lakou, a e kalaia mai ko lakou hewa.   
\q1
\v 21 A e lawe aku oia i ka bipikane mawaho o kahi e hoomoana'i, a e puhi ia ia, me ia i puhi aku ai i ka bipikane mua; he mohailawehala ia no ke anaina.   
\b  
\q1
\v 22 Aia hana hewa ke'lii, a no ka ike ole i hana aku ai i kekahi o na kauoha a Iehova kona Akua, i ka mea pono ole ke hana, a na hewa ia;   
\q1
\v 23 A ina i loaa ia ia kona hewa ana i hana'i; e lawe mai no oia i kana mohai he keikikao, he kane kina ole.   
\q1
\v 24 A e kau ae i kona lima maluna o ke poo o ke kao, a e pepehi ia ia ma kahi i pepehi ai lakou i ka mohaikuni imua o Iehova; he mohailawehala ia.   
\q1
\v 25 A e lawe ke kahuna i kauwahi o ke koko o ka mohailawehala me kona manamana lima, a e kau aku hoi ia ma na pepeiaohao o ke kuahu mohaikuni, a e ninini aku i kona koko malalo o ke kuahu mohaikuni.   
\q1
\v 26 A e kuni iho oia i kona kaikea a pau maiuna o ke kuahu, e like me ke kaikea o ka alana o na mohaihoomalu; a e hana ke kahuna i ke kalahala no kona hewa, a e kalaia kona hewa.   
\b  
\q1
\v 27 A ina e hana hewa no ka ike ole kekahi o na kanaka i kana hana ana i kekahi o na kauoha a Iehova, i ka mea pono ole ke hana, a ua hewa ia:   
\q1
\v 28 A ina e loaa ia ia kona hewa ana i hana'i; alaila e lawe mai no oia i kana mohai, he keikikao, he wahine kina ole, no kona hewa ana i hana'i.   
\q1
\v 29 A e kau ae oia i kona lima maluna o ke poo o ka mohailawehala, a e pepeni i ka mohailawehala ma kahi o ka mohaikuni.   
\q1
\v 30 A e lawe ke kahuna i kauwahi o kona koko me kona manamana lima, a e kau ae ma na pepeiaohao o ke kuahu mohaikuni, a e ninini aku i kona koko a pau malalo o ke kuahu.   
\q1
\v 31 A e lawe aku oia i kona kaikea a pau, e like me ke kaikea i laweia ku ai mai ka alana o na mohaihoomalu; a e kuni iho ke kahuna ia mea ma ke kuahu i mea ala ono ia Iehova; a e hana ke kahuna i ke kalahala nona, a e kalaia kona hewa.   
\b  
\q1
\v 32 A ina i lawe mai oia i ke keikihipa i mohailawehala, e lawe mai hoi oia ia ia he wahine kina ole.   
\q1
\v 33 A e kau oia i kona lima ma ke poo o ka mohailawehala, a e pepehi ia ia i mohailawehala ma kahi i pepehi ai lakou i ka mohaikuni.   
\q1
\v 34 A e lawe ke kahuna i kauwahi o ke koko o ka mohailawehala me kona manamana lima, a e kau ae ma na pepeiaohao o ke kuahu mohaikuni, a e ninini aku i kona koko a pau malalo o ke kuahu.   
\q1
\v 35 A e lawe aku oia i kena kaikea a pau, me ke kaikea o ke keikihipa i laweta'ku ai mai ka alana aku o na mohaihoomalu; a e kuni iho ke kahuna ia ma ke kuahu, e like me na mohai i kaumahaia ma ke ahi ia Iehova: a e hana ke kahuna i ke kalahala nona, no kona hewa ana i hana'i, a e kalaia mai ia.   
\c 5  
\b  
\q1
\v 1 A INA e lawehala kekahi uhane, a lohe oia i leo o ka hoohiki ana, a he mea hoike ia, a ua ike paha, ua lohe paha, aole ia e hai, alaila, maluna ona kona hewa.   
\q1
\v 2 A ina e hoopa aku kekahi i ka mea haumia, ina he kupapau o ka holoholona hihiu haumia, a ina he kupapau o na holoholona laka haumia, a ina he kinomake o na mea kolo, a i nalo ia ia; e haumia no hoi ia, a hewa.   
\q1
\v 3 A ina e hoopa aku oia i ka haumia o ke kanaka, i kela haumia a i keia i haumia ai ia, a i nalo ia ia; aia ike oia, alaila hewa ia.   
\q1
\v 4 A ina e hoohiki kekahi e olelo walewale ana me kona lehelehe e hana hewa paha, a e hana pono paha, o ka mea a ke kanaka i olelo ai me ka hoohiki i ke Akua, a nalo ia ia ia; a loaa ia ia, a ua hewa ia i kekahi o ia mau mea.   
\q1
\v 5 A penei keia, i ka wa e hewa ai ia i kekahi o ia mau mea, alaila e hai mai ia, ua hana hewa oia ia mea.   
\q1
\v 6 A e lawe mai oia i kana mohaihala ia Iehova no kona hewa ana i hana'i, he wahine no ka ohana, he keikihipa, a i ole ia, he keikikao, i mohaihala; a e hana ke kahuna i ke kalahala nona no kona hewa.   
\b  
\q1
\v 7 A ina aole e hiki i kona lima ke lawe mai i ke keiki holoholona, alaila e lawe mai oia no kona hewa ana i hana'i, i elua mau kuhukuku, a i ole ia, elua manu nunu opiopio ia Iehova, i kekahi i mohailawehala, a i kekahi hoi i mohaikuni.   
\q1
\v 8 A e lawe mai oia ia mau mea i ke kahuna, a e alana mua oia i ka mea mohailawehala, a e niki oia i kona poo mai kona a-i, aole hoi e mahele a kaawale.   
\q1
\v 9 A e pipi ae oia i kauwahi o ke koko o ka mohailawehala ma ka aoao o ke kuahu; a e uwiia'e ke koena o ke koko malalo o ke kuahu: he mohailawehala ia.   
\q1
\v 10 A e alana sku oia i ka Iua i mohaikuni mamuli o ke kanawai; ae hana ke kahuna i kalahala nona, no ka hewa ana i hana'i, a e kalaia uanei oia.   
\b  
\q1
\v 11 A i ole e hiki i kona lima ke lawe mai i eloa manu kuhukuku, a i elua manu nunu opiopio paha, alaila, e lawe mai ka mea i hana hewa i mohai nons i ka hapaumi o ka epa palaoa wali i mohailawehala; aole e kau oia i ka aila maluna iho o ia mea, aole hoi ia e kau i ka libano ma ia mea, no ka mea, he mohailawehala ia.   
\q1
\v 12 A e lawe mai oia ia mea i ke kahuna, a e lalau iho ke kahuna a piha kona lima ia mea i mea hoomanao nona, a e kuni iho ma ke kuahu, e like me na mohaipuhi ia Iehova; he mohailawehala ia.   
\q1
\v 13 A e hana ke kahuna nona i kalahala no kona hewa ana i hana'i, ma kekahi o na mau mea la, a e kalaia nona; a e lilo ia na ke kahuna he mohaiai.   
\b  
\q1
\v 14 Olelo mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 15 Ina e hana kekahi i ka hewa, a lawehala no ka ike ole, ma na mea hoano o Iehova, alaila e lawe mai oia ia Iehova no kona hewa, i ka hipakane kina ole noloko mai o na ohana, me ka mea au i manao ai ma na sekela kala, mamuli o ke sekela o ke keenakapu, i mohaihala.   
\q1
\v 16 A e hooponopono oia no ka hewa ana i hana'i ma ka mea hoano, a e hui hou i ka hapa lima ona ilaila, a e haawi aku oia ia mea i ke kahuna; a e hoolilo ke kahuna i ka hipakane mohaihala i kalahala nona, a e kalaia no ia.   
\b  
\q1
\v 17 A ina e lawehala kekahi, a e hana i kekahi o ia mau mea i papaia ma na kauoha a Iehova, aole hoi i ike, e hihia no ia, a e kau no ia ia kona hewa.   
\q1
\v 18 A e lawe mai oia i ka hipakane kina ole noloko mai o ka ohana, me ka mea au i manao ai, i ke kahuna i mohaihala; a e hana ke kahuna i kalahala nona, no kona ike ole i hewa ai a ike ole hoi, a e kalaia no ia.   
\q1
\v 19 He mohaihala no ia: ua lawehala io no ia i ka Iehova.   
\c 6  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose i mai la,   
\q1
\v 2 Ina e lawehala kekahi uhane a e hana hewa ia Iehova, a e hoopunipuni i kona hoalauna i ka mea i haawiia ia ia e malama, a i ka hoolimalima paha, a i ka mea kaili wale ia paha, a na hoopunipuni oia i kona hoalauna;   
\q1
\v 3 A ina i loaa ia ia kekahi mea haule, a hoopunipuni oia no ia mea, a hoohiki wahahee hoi; i kahi o neia mau mea a pau a ke kanaka i hana'i, a hewa ilaila:   
\q1
\v 4 Penei hoi ia, no ka mea ua lawehala ia, a ua hewa, e hoihoi aku no ia i ka mea ana e kaili wale ai, a i ka mea i loaa ia ia ma ka wahahee, a i ka mea i haawiia ia ia e malama, a i ka mea haute paha i loaa ia ia;   
\q1
\v 5 A i kela mea keia mea ana i hoohiki wahahee ai, e hoihoi okoa aku no oia ia i kona kino, a e hui i ka hapa lima hou me ia, a e haawi aku i ka mea nana ia, i ka la o kona mohaihala.   
\q1
\v 6 A e lawe mai oia i kona mohaihala ia Iehova, he hipakane kina ole noloko mai o ka ohana, me kau mea i manao ai, i mohaihala, i ke kahuna.   
\q1
\v 7 A e hana ke kahuna i kalahala nona, ma ke alo o Iehova, a e kalaia no ia, no ka mea ana i hana'i, i ka mea i hewa'i.   
\b  
\q1
\v 8 Olelo mai la o Iehova ia Mose, i mai la,   
\q1
\v 9 E kauoha ia Aarona a me kana mau keiki, e i aku, Eia ke kanawai o ka mohaikuni; he mohaikuni no ia no ka aa ana o ke ahi ma ke kuahu a pau ka po, a kakahiaka, e aa ana hoi ke ahi kuahu ilaila.   
\q1
\v 10 E komo hoi ke kahuna i kona kapa olona, a komo no kona lole wawae olona i kona io, a e hao ia i ka lehu i pau i ke ahi me ka mohai, maluna o ke kuahu, a e waiho iho ma ka aoao o ke kuahu.   
\q1
\v 11 A e hemo ia ia koua mau kapa, a e komo hou i kekahi mau kapa okoa, a e lawe aku i ka lehu mawaho o kahi hoomoana'i a kahi maemae.   
\q1
\v 12 A o ke ahi maluna o ke kuahu e aa mau no ia malaila, aole e kinaiia ia; a e puhi ke kahuna i ka wahie maluna, i kela kakahiaka i keia kakahiaka, a e kau pono i ka mohaikuni maluna ona; a e kuni hoi oia maluna iho i ka momona o na mohaihoomalu.   
\q1
\v 13 E aa mau no ke ahi ma ke kuahu, aole loa e pio.   
\b  
\q1
\v 14 Eia hoi ke kanawai o ka mohaiai; e mohai aku no na keiki a Aarona ia ma ke alo o Iehova imua o ke kuahu.   
\q1
\v 15 A e lalau oia a piha kona lima i ka palaoa o ka mohaiai a i kona aila, a i kona libano a pau e kau ana maluna o ka mohaiai, a e kuni aku hoi ia he mea ala ono, o kona mea hoomanao ia Iehova.   
\q1
\v 16 A o ke koena o ia mea, na Aarona ia a me kana mau keiki e ai: me ka berena hu ole e aiia'i ia ma kahi hoano; ma ka pa o ka halelewa o ke anaina e ai ai lakou ia mea.   
\q1
\v 17 Aole ia e moa me ka hu: ua haawi aku wau ia he kuleana no lakou noloko o kuu mau mahaipuhi; he mea hoano loa, e like me ka mohailawehala a me ka mohaihala.   
\q1
\v 18 E ai na kane o ka Aarona mau keiki a pau ia mea: he kanawai mau ia i ko oukou hanauna, no na mohaipuhi ia Iehova; o ka mea e hoopa ia mau mea, e hoano ia.   
\b  
\q1
\v 19 Olelo mai la hoi o Iehova ia Mose, i mai la;   
\q1
\v 20 Eia ka mohai a Aarona a me kana mau keiki, a lakou e mohai aku ai ia Iehova i ka la i poniia'i oia, o ka hapaumi o ka epa palaoa wali, e mohai mau ai, o ka hapalua ona i ke kakahiaka, a o ka hapalua ona i ke ahiahi.   
\q1
\v 21 Ma ke pa e hanaia'i ia me ka aila; a moa, e lawe mai oe ia, a o na apana moa, o ka mohaiai kau e mohai ai i mea ala ono ia Iehova.   
\q1
\v 22 A o ke kahuna no na keiki mai ana i poniia no kona wahi, oia ka mea nana ia e mohai aku: ke kanawai mau ia no Iehova, e pau loa ia i ke ahi.   
\q1
\v 23 O na mohaiai a pau no ke kahuna e pau no ia i ke ahi; aole e aiia.   
\b  
\q1
\v 24 A ua olelo mai la o Iehova ia Mose, i mai la,   
\q1
\v 25 E olelo aku oe ia Aarona a me kana mau keiki, penei, Eia ke kanawai o ka mohailawehala; ma kahi i pepehiia'i ka mohaikuni, malaila e pepehiia'i ka mohailawehala, ma ke alo o Iehova; he mea hoano loa ia.   
\q1
\v 26 O ke kahuna nana ia i mohai aku, oia ke ai ia mea; ma kahi hoano no ia e aiia'i, maloko o ka pa o ka halelewa o ke anaina.   
\q1
\v 27 O ka mea nana e hoopa aku i ka io ona, e hoano no ia: a ina e pipiia ke koko ona ma ke kapakomo, e holoi ae oe i ka mem i pipiia'i ia, ma kahi hoano.   
\q1
\v 28 Aka o ka ipu lepo i hoolapalapaia'i ia, e wawahiia ia; a ina he ipu keleawe i hoolapalapaia'i ia, alaila e anaiia ia a e holoiia me ka wai.   
\q1
\v 29 E ai na kane a pau iwaena o na kahuna ia mea; he mea hoano loa no ia.   
\q1
\v 30 A o ka mohailawehala, i laweia kona koko iloko o ka halelewa o ke anaina, e hoolaulea ma kahi hoano, aole ia e aiia, e hoopauia ia i ke ahi.   
\c 7  
\b  
\q1
\v 1 EIA hoi ke kanawai o ka mohaihala: he hoano loa ia.   
\q1
\v 2 Ma kahi e pepehi ai lakou i ka mohaikuni, malaila no e pepehi ai lakou i ka mohaihala, a e pipi i ke koko ona maluna o ke kuahu a puni.   
\q1
\v 3 A e mohai aku oia i kona kaikea a pau; o ka huelo, a me ka nikiniki maluna o ka naau,   
\q1
\v 4 A o na puupaa elua, a me ke konahua maluna o laua, ka mea ma ka puhaka, a me ka aa o ke au ma ke akepaa, me na puupaa, oia kana e lawe ai:   
\q1
\v 5 A e kuni aku ke kahuna ia mau mea, maluna o ke kuahu, he mohai kanmahaia ma ke ahi ia Iehova; he mohaihala ia.   
\q1
\v 6 A e ai na kane a pau iwaena o na kahuna ia mea; e aiia ma kahi hoano; he mea hoano loa ia.   
\q1
\v 7 E like me ka mohailawehala, pela no ka mohaihala, he kanawai hookahi no ia mau mea; e lilo no ia i ke kahuna, nana ia e hoolilo i kalahala.   
\q1
\v 8 A o ke kahuna nana i mohai aku i ka mohaikuni o kekahi kanaka, e lilo nona ka ili o ka mohaikuni ana i mohai ai.   
\q1
\v 9 A o kamohaiai apau i moa i ka umu, a i moa i ko paparai, a me ke pa, e lilo no ia na ke kahuna nana ia i mohai aku.   
\q1
\v 10 A o na mohaiai a pau i huiia me ka aila, a maloo, e lilo na na keiki a pau a Aarona e like ka kekahi me ka kekahi.   
\b  
\q1
\v 11 Eia hoi ke kanawai o ka alaila o na mohaihoomalu ana e mohai aku ai ia Iehova.   
\q1
\v 12 A ma e mohai oia ia i mea e hoomaikai ai, alaila, e mohai aku oia me ka alana hoomaikai i na popopalaoa hn ole i huiia me ka aila, a me na papapalaoa hu ole i hamoia me ka aila, a me na popopalaoa i huiia me ka aila, no ka palaoa wali i paraiia.   
\q1
\v 13 A he mea e ae kana e mohaiai he mohai nana, o ka berena hu me ka alana hoomaikai no kana mau mohaihoomalu.   
\q1
\v 14 A noloko o ia mea e mohai aku ai ia i hookahi no ka mohai okoa, i mohai hoali ia Iehova; a e lilo ia na ke kahuna nana i pipi i ke koko o na mohaihoomalu.   
\b  
\q1
\v 15 A o ka io o ka alana, o kana mau mohaihoomalu no ka hoomaikai, e aiia ia i ka la i mohaiia'i ia; aole oia e hookoe i kauwahi a kakahiaka.   
\q1
\v 16 Aka, ina he mea hoohiki paha, a he mohai haawi wale, ka alana o kona mohai, e aiia ia i ka la i mohai aku ai oia i kana mohai; a ia la ae, aiia'i kolaila koena.   
\q1
\v 17 Aka o ke koena o ka io o ka alana, i ke kolu o ka la, e hoopauia ia i ke ahi.   
\q1
\v 18 A ina e aiia kauwahi o ka io o ka alana o kana mau mohaihoomalu, i ke kolu o ka la, aole ia e maliuia mai, aole hoi e heluia ia na ka mea nana ia e mohai aku; e lilo ia i mea e hoowahawahaia, a o ka mea nana e ai ia mea, o kau maluna ona kona hewa.   
\b  
\q1
\v 19 A o ka io i pili i ka mea maemae ole, aole ia e aiia, e hoopauia oia i ke ahi. A o ka io hoi, e ai ka poe maemae a pau i ka io.   
\q1
\v 20 Aka o ka mea nana e ai i ka io o ka alana o na mohaihoomalu, na mea o Iehova, e kau ana kona haumia maluna ona, e okiia'ku ia mai kona poe kanaka aku.   
\q1
\v 21 A o ke kanaka nana e hoopa aku i ka mea haumia, i ka haumia paha o ke kanaka, a i ka holoholona haumia, a i kekahi mea haumia e hoowahawahaia, a e ai hoi i ka io o ka alana o na mohaihoomalu, na mea o Iehova, e okiia'ku oia mai kona poe kanaka aku.   
\b  
\q1
\v 22 Olelo mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 23 E olelo aku oe i na mamo a Iseraela, penei, Mai ai oukou i ke kaikea o ka bipi kauo, a o ka hipa, a o ke kao.   
\q1
\v 24 A o ke kaikea o ka holoholona make wale, a o ke kaikea o ka mea i haehaeia e na holoholona, e pono ia i ka kela mea keia mea e ae, aole loa hoi oukou e ai ia mea.   
\q1
\v 25 A o ka mea nana e ai i ko kaikea o ka holoholona a na kanaka i kaumaha ai i ka mohai ma ke ahi ia Iehova, o ka mea i ai ia mea, oia ke okiia'ku mai kona poo kanaka aku.   
\q1
\v 26 Aole hoi oukou e ai i ko koko, o ke koko o ka manu, a o ka holoholona, iloko o kahi o ko oukou mau hale.   
\q1
\v 27 O ke kanaka i ai i ke koko, oia ke okiia'ku mai kona poe kanaka aku.   
\b  
\q1
\v 28 Olelo mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 29 E olelo aku oe i na mamo a Iseraela, penei, O ka mea mohai i ka alana o kana mau mohaihoomalu ia Iehova, e lawe mai oia i kana mohai ia Iehova noloko o ka alana o kana mau mohaihoomalu.   
\q1
\v 30 Na kona mau lima no e lawe mai i na mohai o Iehova i kaumahaia ma ke ahi, o ke kaikea me ka umauma, oia kana e lawe mai ai, i hooluliia ka umauma i mohaihoali ma ke alo o Iehova.   
\q1
\v 31 A e kuni ke kahuna i ke kai kea maluna o ke kuahu; a e lilo ka umauma na Aaroua a me kana mau keiki.   
\q1
\v 32 A o ka uha mua akau, oia ka oukou e haawi aku ai i ke kahuna i mohaihoali, noloko o na alana o na mohaihoomalu a oukou.   
\q1
\v 33 O kekahi o ka Aarona mau keiki nana e mohai aku i ke koko o na mohaihoomalu a me ke kaikea, e lilo nana ka nha mua akau i kuleana nona.   
\q1
\v 34 No ka mea, o ka umauma luli, a me ka uha hoali, oia ka'u i lawe ai mai na mamo a Iseraela, noluna mai hoi o na alana o ka lakou mau mohaihoomalu, a na haawi hoi aa ia mau mea ia Aarona ke kahuna, a i kana mau keiki; he kanawai mau iwaena o na mamo a Iseraela,   
\b  
\q1
\v 35 Oia hoi ko ka poni ana o Aarona, a me ko ka pom ana o kana mau keiki noloko mai o na mohai o Iehova i kanmahaia ma ke ahi, i ka la i haawi ai oia ia lakou e lawelawe imua o Iehova ma ka oihanakahuna;   
\q1
\v 36 O ka mea a Iehova i kanoha mai ai e haawiia na lakou ko na mamo a Iseraela, i ka la i poni ai oia ia lakou, he kanawai mau no ko lakou mau hanauna.   
\b  
\q1
\v 37 Oia ka kanawai o ka mohaikuni, o ka mohaiai, a o ka mohailawehala, a me ka mohaihala, a o na mohai poni, a me ka alana o na mohaihoomalu;   
\q1
\v 38 Ka mea a Iehova i kanoha mai ai ia Mose ma ka mauna Sinai, i ka la i kanoha mai ai oia i na mamo a Iseraela e kanmaha lakou i ko lakou mau mohai ia Iehova, ma ka waonahele o Sinai.   
\c 8  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 2 E lawe oe ia Aarona a me kana mau keiki pu, a me na kapa komo, a me ka aila poni, a me ka bipikane i mohailawehala, a me na hipakane elua, a me ka hinai berena hu ole.   
\q1
\v 3 A e hoakoakoa oe i ke anaina a pau ma ka puka o ka halelewa o ke anaina.   
\q1
\v 4 Hana iho la o Mose e like me ka Iehova i kanoha mai ai ia ia; a ua hoakoakoaia ka ahakaoaka i ka puka o ka halelewa o ke anaina.   
\q1
\v 5 I aku la o Mose i ke anaina, Eia ka mea a Iehova i kauoha mai.   
\b  
\q1
\v 6 A lawe mai la o Mose ia Aarona a me kana mau keiki, a holoi ae la ia lakou i ka wai.   
\q1
\v 7 A hookomo aku la oia i ke kapa komo ia ia, a kaei ae la ia ia i ke Kaei, a hoaahu ia ia i ka aahu, a kau hoi i ka epoda maluna ona, a kaei ae la ia ia i ke kaei onionio o ka epoda, a hoopili aku la ia mea ia ia.   
\q1
\v 8 A kau iho la hoi oia maluna ona i ka palenmanma; a kau hoi i ka Urima a me ke Tumima ma ka paleumanma.   
\q1
\v 9 A kau aku la hoi i papale kahuna ma kona poo; a ma ka papale kahuna, ma ke alo pono i kau ai oia i ka papa gula, ka lei hoano, e like me ka mea a Iehova i kanoha mai ai ia Mose.   
\b  
\q1
\v 10 Lawe iho la hoi o Mose i ka ai la poni, a poni aku la i ka halelewa, a me na mea a pau oloko, a hoolaa ae la ia mau mea.   
\q1
\v 11 A pipi iho la oia i kanwahi o ia mea ma ke kuahu, ehiku ka pipi ana, a poni hoi ia i ke kuahn a me kana mau ipn a pau, ka ipu holoi a me kona wawae, a hoolaa ae la ia mau mea.   
\q1
\v 12 Niumi iho la hoi oia i kanwahi o ka aila pom ma ke poo o Aarona, a poni iho la ia ia e hoano ia ia.   
\q1
\v 13 A lawe mai la hoi o Mose i na keiki a Aarona, a hookomo i na kapa komo ia lakou, a kaei ae la hoi ia lakou i na kaei, a kau aku la hoi i na papale maluna o lakou, e like me ke kanoha a Iehova ia Mose,   
\b  
\q1
\v 14 Lawe mai la hoi oia i ka bipikane i mohailawehala; a kau aku la o Aarona a me kana mau keiki i ko lakou mau lima maluna o ke poo o ka hipikane i mohaihala.   
\q1
\v 15 A pepehi ae la oia, a lawe hoi o Mose i ke koko, a kau aku hoi ma na pepeiaohao o ke knahn puni, me kona manamanalima, a hoomaemae ae la ke kuahu; a ninini iho la i ke koko malalo o ke kuahu, e hana i kalahala malun a ona.   
\q1
\v 16 Lawe iho la oia i ke kaikea a pau maluna o ka nsau, a me ka aa o ke au ma ke akepaa, a me na puupaa elua, a me ko laua mau konahua, a kuni iho la o Mose ma ke kuahn.   
\q1
\v 17 Aka o ka bipikane, a me kona ili, a me kona io, a me kona lepo, oia kana i hoopau ai i ke ahi mawaho o kahi e hooraoana'i, e like me ke kanoha a Iehova ia Mose.   
\b  
\q1
\v 18 Lawe mai la hoi oia i ka hipakano i mohaikuni; a kau ae la o Aarona, a me kana mau keiki i ko lakou mau lima maluna o ke poo o ka hipakano.   
\q1
\v 19 Pepehi iho la oia, a pipi ae la hoi o Mose i ke koko maluna o ke kuahu a puni.   
\q1
\v 20 Okioki ae la hoi oia i ka hipakano i mau apana; a puhi ae la hoi o Mose i ko poo, a mo na apana, a mo ko kaikea.   
\q1
\v 21 Holoi ae la hoi oia i ka naau a me na wawae i ka wai; a puhi ae la o Mose i ka hipakane okoa ma ke kuahu; he mohaikuni ia, he mea ala ono, he mohai i kaumahaia ma ke ahi ia Iehova, e like me ka Iehova kauoha ia Mose.   
\b  
\q1
\v 22 Lawe mai la hoi oia i ka lua o ka hipakane, ka hipakane no ka hoolaa ana; a kau aku la o Aarona a me kana mau keiki i ko lakou mau lima maluna o ke poo o ka hipakane.   
\q1
\v 23 Pepehi ae la hoi oia, a lawe hoi o Mose i kauwahi o kona koko, a kau aku la ma ke kihi o ko Aarona pepeiao akau, a ma ka manamananui o kona lima akau, a ma ka manamananui o kona kapuwakakau.   
\q1
\v 24 Lawe mai la hoi oia i ka Aarona mau keiki, a kau aku la o Mose i ko koko ma ke kihi o ko lakou pepeiao akau, a ma na manamananui o ko lakou mau lima akau, a ma na manamananui o ko lakou mau kapuwai akau; a pipi ae la o Mose i ke koko ma ke kuahu a puni.   
\q1
\v 25 Lawe ae la hoi oia i ke kaikea, a mo ka huelo, a me ka nikiniki ma ka naau, a me ka aa o ke au ma ke akepaa, a me na pnupaa elua, a me ko laua konahua, a me ka uha mua akau.   
\q1
\v 26 A mailoko mai o ka hinai berena hu ole, imua o Iehova, lawe ae la oia i hookahi poponalaoa hu ole a me ka popoberena i hamoia i ka aila, a me ka papaberena hookahi, a kau ae la hoi maluna o ko kaikea a me ka uha mua akau.   
\q1
\v 27 A kau okoa ae la oia ia maluna o ko Aarona mau lima, a ma na lima o kana mau keiki, a hooluli ae ia mau mea i mohaihoali imua o Iehova.   
\q1
\v 28 Lawe ae la hoi o Mose ia mau mea mai luna ae o ko lakou mau lima, a kuni ae la maluna o ke kuahu maluna o ka mohaikuni; he mau mea hoolaaia i mea ala ono, he mohai i kaumahaia ma ke ahi ia Iehova.   
\q1
\v 29 Lawe ae la hoi o Mose i ka umauma, a hooluli ae i mohaihoali ma ke alo o Iehova; o ko Mose kuleana ia o ka hipakane no ka hoolaa ana, e like me ka Iehova kauoha ia Mose.   
\b  
\q1
\v 30 Lawe ae la hoi o Mose i kau wahi o ka aila poni, a o ke koko ka mea maluna o ke kuahu, a pipi ae la maluna o Aarona, a ma kona mau kapa, a me kana mau keiki, a ma na kapa o kana mau keiki pu me ia; a ua hoolaa aku ia Aarona, a me kona mau kapa, a me kana mau keiki a mo na kapa o kana mau keiki me ia.   
\b  
\q1
\v 31 I aku la o Mose ia Aarona a i kana mau keiki, E hoolapalapa i ka io ma ka puka o ka halelewa o ke anaina; a malaila hoi e ai ai ia me ka berena oloko o ka hinai o na mea hoolaaia, me au hoi i kauoha ai e olelo ana, E ai o Aarona a me kana mau keiki ia mea.   
\q1
\v 32 A o ke koena o ka io, a me ka berena, oia ka oukou e hoopau ai i ke ahi.   
\q1
\v 33 Aole oukou e pnka ae ma ka puka o ka halelewa o ke anaina i na la ehiku, a pau na la o ko oukou hoolaa ana; no ka mea, e hoolaa oia ia oukou i na la ehiku.   
\q1
\v 34 Me ia i hana'i i keia la, pela no Iehova i kauoha mai ai o hana, e hana i kalahala no oukou.   
\q1
\v 35 Nolaila e noho ai oukou ma ka puka o ka halelewa o ke anaina i ke ao, i ka po, i na la ehiku, a e malama ke kauoha a Iehova, i ole ai oukou o make; no ka mea, pela no wau i kauohaia mai ai.   
\q1
\v 36 Pela i hana'i o Aarona a me kana mau keiki i na mea a pau a Iehova i kauoha mai ai ma ka lima o Mose.   
\c 9  
\b  
\q1
\v 1 EIA hoi kekahi, i ka walu o ka la, hea ae la o Mose ia Aarona a me kana mau keiki a me na luna kahiko o ka Iseraela;   
\q1
\v 2 Olelo ae la oia la Aarona, E lawe oe i ke keikibipi opiopio i mohailawehala, a me ka hipakane i mohaikuni, he kina ole, a e mohai aka ma ke alo o Iehova.   
\q1
\v 3 A e olelo aka oe i na mamo a Iseraela, penei, E lawe oukou i ke keikikao i mohailawehala; a me ke keikibipi a me ke keikihipa, na mea o ka makahiki hookahi, me ke kina ole, i mohaikuni;   
\q1
\v 4 A me ka bipikane a me ka hipakane i mau mohaihoomalu, e mohai aku ma ke alo o Iehova, a me ka mohaiai i huiia me ka aila; no ka mea, i keia la e ikeia'i o Iehova e oukou.   
\b  
\q1
\v 5 A lawe mai la lakou i ka mea a Mose i kauoha ai, ma ke alo o ka halelewa o ke anaina; a hookokoke mai la ke anaina a pau, a kukulu ae la imua o Iehova.   
\q1
\v 6 I ae la o Mose, Eia ka mea a Iehova i kauoha mai ai e hana oukou; a e ikeia ka nani o Iehova e oukou.   
\q1
\v 7 Olelo aku la hoi o Mose ia Aarona, E hele oe i ke kuahu, a e kanmaha aku i kau mohailawehala, a me kau mohaikuni, a e hana i kalahala nou iho, a no na kanaka; a e alana aku i ka mohai a na kanaka, a e hana i kalahala no lakou, e like me ka Iehova kauoha,   
\b  
\q1
\v 8 Nolaila, hele ae la o Aarona i ke kuahu, a pepehi iho la i ke keikibipi mohailawehala, ka mea nona iho.   
\q1
\v 9 Lawe mai la hoi ka Aarona mau keiki i ke koko io na la; a hoo iho oia i kona manamanalima iloko o ke koko, a kau aku la ma na pepeiaohao o ke kuahu, a ninini iho la i ke koko malalo o ke kuahu.   
\q1
\v 10 Aka o ke kaikea a me na puupaa, a me ka aa o ke au ma ke akepaa, o ka mohailawehala, oia kana i kuni ai ma ke kuahu, e like me ka Iehova kaaoha ia Mose.   
\q1
\v 11 A ua puhi oia i ka io a me ka ili me ke am mawaho o kahi e hoomoana'i.   
\b  
\q1
\v 12 Pepehi ae la ia i ka mohaikuni, a haawi ka Aarona mau keiki i ke koko ia ia, a pipi oia ia ma ke kuahu a puni.   
\q1
\v 13 Haawi ae la hoi lakou i ka mohaikuni ia ia, me na apana a me ke poo; a puhi ae la hoi oia ma ke kuahu.   
\q1
\v 14 Holoi ae la oia i ka naau a me na wawae, a puhi ae la hoi maluna o ka mohaikuni ma ke kuahu.   
\b  
\q1
\v 15 Lawe mai la hoi oia i ka mohai a na kanaka, a lalau ae la i ke kao, i ka mohailawehala no na kanaka, a pepehi ae la ia mea, a kaumaha aku la hoi ia no ka hewa, e like me ka mua.   
\q1
\v 16 Lawe mai la hoi oia i ka mohaikuni, a kanmaha aku la ia e like me ke kanawai.   
\q1
\v 17 Lawe mai la hoi oia i ka mohaiai, e hoopiha i kona lima ia mea, a puhi ae la ma ke kuahu, okoa ka mohaikuni o ke kakahiaka.   
\b  
\q1
\v 18 Pepehi ae la hoi oia i ka bipikane, a me ka hipakane, i alana no na mohaihoomalu, ka mea no na kanaka; a haawi ae la ka Aarona mau keiki i ke koko ia ia, a pipi ae ia oia ia mea ma ke kuahu a puni,   
\q1
\v 19 A i ke kaikea o ka bipikane a me ka hipakane, a me ka huelo, a me ka makaupena, a me na puupaa, a me ka aa o ke au ma ke akepaa:   
\q1
\v 20 Kau aku la hoi lakou i ke kaikea maluna o na umauma, a kuni ae la oia i ke kaikea ma ke kuahu;   
\q1
\v 21 A hooluli ae la hoi o Aarona i ka umauma a me ka uha mua akau i mohaihoali ma ke alo o Iehova, e like me ka Mose kauoha.   
\b  
\q1
\v 22 Hohola ae la hoi o Aarona i kona mau lima i na kanaka, a hoomaikai aku la ia lakou; a iho mai la hoi mai ke kaumaha ana i ka mohailawehala; a me ka mohaikuni, a me na mohaihoomalu.   
\q1
\v 23 Komo aku la hoi o Mose me Aarona i ka halelewa o ke anaina, a puka mai la hoi laua, a hoomaikai aku la i na kanaka; a ikeia aku la ka nani o Iehova e ka poe kanaka a pau.   
\q1
\v 24 Puka mai la hoi ke ahi mai ke alo mai o Iehova, a hoopau iho la i ka mohaikuni a me ke kaikea maluna o ke kuahu; a ike ka poe kanaka a pau ia, hooho ae la lakou a moe iho la ilalo ke alo.   
\c 10  
\b  
\q1
\v 1 LALAU iho la hoi, ka Aarona mau keiki o Nadaha a me Abihu, i ko laua mau ipuahi, a hahao ae la i ke ahi maloko, a kau hoi i ka mea ala maluna iho, a mohai aku la i ke ahi o ma ke alo o Iehova ka mea ana i kauoha ole ai ia laua.   
\q1
\v 2 Puka mai la hoi ke ahi mai ke alo mai o Iehova, a ai iho la ia laua, a make iho la laua imua o Iehova.   
\q1
\v 3 Alaila olelo ae la o Mose ia Aarona, O ka mea keia a Iehova i olelo mai ai, i ka i ana, E hoanoia mai no wau e ka poe e hookokoke mai io'u nei, a e hoonaniia mai hoi au ma ke alo o na kanaka a pau. A hakanu iho la o Aarona.   
\q1
\v 4 Kahea ae la hoi o Mose ia Misaela, a me Elezapana, na keiki a Uziela, ka hoahanau o ko Aarona makua, i aku la hoi ia laua, E hookokoke mai, o lawe aku i ko olua mau hoahanau mai ke alo aku o ke keenakapu, mawaho o kahi e hoomoana ai.   
\q1
\v 5 Hookokoke ae la hoi laua, a halihali ae la ia laua iloko o ko laua mau kapa mawaho o kahi e hoomoana'i, e like me ka Mose olelo.   
\q1
\v 6 Olelo aku la hoi o Mose ia Aarona, a me Eleazara, a me Itamara, kana mau keiki, Mai wehe ae i ko oukou mau poo, aole hoi e uhae i ko oukou mau kapa, o make oukou, a kau mai ka inaina maluna o ka poe kanaka a pau; aka e uwe ko oukou poe hoahanau, ka ohana a pau o Iseraela, i ka aa ana a Iehova i kuni iho ai.   
\q1
\v 7 Aole hoi oukou e hele mawaho o ka puka o ka halelewa o ke anaina, o make oukou; no ka mea, maluna o oukou ka aila poni o Iehova. A hana iho la lakou e like me ka olelo a Mose.   
\b  
\q1
\v 8 A olelo mai la o Iehova ia Aarona, i mai la,   
\q1
\v 9 Mai inu i ka waina a me ka mea ona, o oe a me kau mau keiki me oe, i ka wa e hele ai oukou iloko o ka halelewa o ke anaina, o make oukou: he kanawai mau no ia i na hanauna o oukou;   
\q1
\v 10 I hiki hoi ia oukou ke hookaawale iwaena o ka hoano, a me ka hoano ole, a iwaena o ka haumia a me ka maemae;   
\q1
\v 11 A e ao aku hoi oukou i na mamo a Iseraela, i na kanawai a pau a Iehova i olelo mai ai ia lakou, ma ka lima o Mose.   
\b  
\q1
\v 12 Olelo ae la hoi o Mose ia Aarona, a ia Eleazara, a ia Itamara, i kana mau keiki i koe mai, E lawe i ka mohaiai i koe mai o na mohai o Iehova i kamnahaia'ku ai ma ke ahi, a e ai ia mea me ka hu ole kokoke i ke kuahu; no ka mea, he mea hoano loa ia.   
\q1
\v 13 E ai hoi oukou ia mea ma kahi hoano; no ka mea, nau no ia, a na kau mau keiki noloko o na mohai o Iehova i kanmahaia ma ke ahi; no ka mea, pela wau i kauohaia mai ai.   
\q1
\v 14 E ai hoi oukou i ka umauma luli, a me ka uha mua hoali ma kahi maemae, o oe, a me kau mau keiki, a me kau mau kaikamahine me oe; no ka mea, o kou kuleana ia, a me ko na keiki au, o na mea i haawiia noloko o na alana o na mohaihoomalu a na mamo a Iseraela.   
\q1
\v 15 E lawe mai lakou i ka uha hoali a me ka umauma luli me na mohai kaikea kuniia, e hooluli i mohaihoali ma ke alo o Iehova; a e lilo ia nau a na kau mau keiki me oe, ma ke kanawai mau loa, e like me ka Iehova kauoha.   
\b  
\q1
\v 16 Imi ikaika ae la o Mose i ke kao mohailawehala, aia hoi, ua puhiia; a na huhu oia ia Eleazara a ia Itamara na keiki a Aarona i koe mai, i ae la,   
\q1
\v 17 No ke aha la i ai ole ai olua i ka mohailawehala ma kahi hoano, no ka mea, he mea hoano loa, a ua haawiia ia oukou, o hali i ka hewa o ke anaina, e hana hoi i kalahala uo lakou ma ko alo o Iehova!   
\q1
\v 18 Eia hoi, aole i laweia mai ke koko maloko o kahi hoano, he pono no i ai io oukou ia mea ma kahi hoano, me a'u i kauoha aku ai.   
\q1
\v 19 A olelo ae la o Aarona ia Mose, Eia hoi, i keia la ua mohai aku laua i ka laua mohailawehala a me ka laua mohaikuni ma ke alo o Iehova; a ua loaa ia'u na mea e like me nei: a ina i ai au i ka mohailawehala, i keia la, ua pono anei ia i na maka o Iehova!   
\q1
\v 20 A lohe o Mose, he pono ia i kona manao.   
\c 11  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose a me Aarona, i mai la ia laua,   
\q1
\v 2 E olelo olua i na mamo a Iseraela, penei, Eia na holoholona a oukou e ai ai, o ko na holoholona a pau maluna o ka honua.   
\q1
\v 3 O ka mea mahele i ka maiuu, a ua kapuwai maheleia, a ua nau i ka mea hoolualuaiia, iwaena o na holoholona, oia ka oukou e ai ai.   
\q1
\v 4 Aka, aole oukou e ai i keia mau mea o na mea nau i ka mea hoolualuaiia, a o na mea mahele maiuu, o ke kamelo, no ka mea, ua nau ia i ka mea hoolualuaiia, aole nae i mahele i ka maiuu, he haumia ia ia oukou.   
\q1
\v 5 A o ke kone hoi, no ka mea, ua nau no ia i ka mea hoolualuaiia, aole mahele i ka maiuu, he haumia ia ia oukou.   
\q1
\v 6 A o ka hare hoi, no ka mea, ua nau no ia i ka mea hoolualuaiia, aole hoi i mahele i ka maiuu, he haumia ia ia oukou.   
\q1
\v 7 A o ka puaa hoi, no ka mea, ua mahele no ia i ka maiuu, ua kapuwai maheleia, aole hoi ia i nau i ka mea hoolualuaiia, he haumia ia ia oukou.   
\q1
\v 8 Aole oukou e ai i ko lakou io, aole e hoopa i ko lakou kupapau, he haumia lakou ia oukou.   
\b  
\q1
\v 9 Eia na mea e ai ai oukou, o na mea maloko o na wai, o ka mea halo, a me ka unahi, iloko o na wai a me na kai, a me na muliwai, o lakou ka oukou e ai ai.   
\q1
\v 10 A o ka mea halo ole, a me ka unahi ole, iloko o na kai, a me na muliwai, o na mea a pau e oni ana iloko o na wai, a o na mea ola iloko o na wai, he mea hoowahawahaia ia oukou.   
\q1
\v 11 He mau mea e hoowahawahaia ia oukou; aole oukou e ai i ko lakou io, a e hoopailua oukou i ko lakou mau kupapau.   
\q1
\v 12 O ka mea halo ole, a unahi ole maloko o na wai, oia ke hoowahawahaia e oukou.   
\b  
\q1
\v 13 Eia hoi na mea a oukou e hoowahawaha ai iwaena o na manu, aole e aiia lakou, he mea e hoowahawahaia no; o ka aeto, a me ka oseferaga, a me ka osepera;   
\q1
\v 14 A o ka vuletura, a me ka falekona me kona like;   
\q1
\v 15 A o ke koraka me kona like;   
\q1
\v 16 A o ka iana, a me ke tama, a me ke kuku, a me ka nisu me kona like;   
\q1
\v 17 A o ka pueo pepeiao, a me ka lawaia, a me ka pueo;   
\q1
\v 18 A o ka noketura, a me ka pelikana a me ka vuletura keokeo;   
\q1
\v 19 A o ke kikonia, a me ka aredea me kona like, a me ka upupa, a me ka opeapea.   
\b  
\q1
\v 20 O na manu kolo e hele ana ma na ha, he mea ia e hoowahawahaia e oukou.   
\q1
\v 21 Eia nae na mea e pono ke ai oukou, o na mea lele e kolo ana, na mea hele ma na ha, he mau wawae hoi ko lakou maluna o na kapuwai, e mahiki ai ma ka honua;   
\q1
\v 22 O neia poe o lakou e pono ke ai oukou; o ka uhini me kona like, a me ka uhini wawae ha me kona like, a me ka uhini lele me kona like, a me ka uhini akerida me kona like.   
\q1
\v 23 Aka o na mea lele e ae a pau e kolo ana, me na wawae ha, he mea ia e hoopailuaia e oukou.   
\b  
\q1
\v 24 A no ia mau mea e haumia ai oukou; o ka mea i pa aku i ko lakou kupapau e haumia ia a hiki i ke ahiahi.   
\q1
\v 25 A o ka mea e hali i kauwahi o ke kupapau o lakou, e holoi oia i kona mau kapa, a e haumia hoi ia a hiki i ke ahiahi.   
\q1
\v 26 O ke kupapau o ka holoholona i mahele i ka maiuu, aole mahele lea ia ke kapuwai, aole nau i ka mea i hoolualuaiia, oia ke haumia ia oukou, o ka mea e pa ia lakou e haumia no ia.   
\q1
\v 27 O ka mea hele ma kona mau kapuwai manamana, o ko na holoholona a pau e hele ana ma na ha, he haumia ia ia oukou; a o ka mea i pa i ko lakou kupapau e haumia ia a hiki i ke ahiahi.   
\q1
\v 28 A o ka mea nana e hali i ko lakou kupapau, e holoi oia i kona kapa, a e haumia a hiki i ke ahiahi, he mau mea haumia ia oukou.   
\b  
\q1
\v 29 Eia hoi na mea haumia ia oukou iwaena o na mea kolo e kolo ana ma ka lepo, o ka mole, o ka iole, a me ka honu me kona like,   
\q1
\v 30 A me ke anaka, a me ke koa, a me ka moo, a me ka hometa, a me ke kameleona.   
\q1
\v 31 He mau mea haumia ia ia oukou iwaena o na mea a pau e kolo ana; o ka mea e pa ia mau mea mahope o ko lakou make ana, e haumia no ia a hiki i ke ahiahi.   
\q1
\v 32 A o ka mea i hauleia iho e kekahi mea i make o lakou, e haumia no ia; ina he ipu laau, a he kapa paha, a he ili, he eke, o kela ipu keia ipu, kahi e hanaia'i ka hana, e hookomoia iloko o ka wai, a e haumia ia a hiki i ke ahiahi, alaila e hoomaemaeia ia.   
\q1
\v 33 A o ka ipu lepo, i hauleia iloko e kekahi o lakou, e haumia ka mea oloko, a e wawahi oukou ia.   
\q1
\v 34 A o ka ai e aiia, ke hiki ia wai maluna iho, e haumia ia; a o ka mea inu e inuia oloko o ia ipu, e haumia ia.   
\q1
\v 35 A o ka mea i hauleia'i e kauwahi o ko lakou kupapau, e haumia ia, o ka umu paha, kahi e kau ai na ipuhao, e wawahiia no ia mau mea; ua haumia, a e haumia hoi ia mau mea ia oukou.   
\q1
\v 36 Aka he kumuwai, a he lua paha, kahi wai nui, e maemae ia; aka o ka mea pa i ko lakou kupapau e haumia oia.   
\q1
\v 37 A ina e haule iho kauwahi o ko lakou kupapau maluna o ka hua lulu e luluia'na, e maemae hoi ia.   
\q1
\v 38 A ina i kau ka wai maluna o ka hua, a haule kauwahi o ko lakou kupapau maluna iho ona, e haumia ia ia oukou.   
\b  
\q1
\v 39 A ina e make ka holoholona he pono ke aiia e oukou, o ka mea i pa i kona kupapau, e haumia ia a hiki i ke ahiahi.   
\q1
\v 40 A o ka mea i ai i kona kupapau, e holoi oia i kona kapa, a haumia hoi ia a hiki i ke ahiahi: a o ka mea hali i kona kupapau, e holoi oia i kona kapa, a haumia hoi a hiki i ke ahiahi.   
\b  
\q1
\v 41 A o ka mea kolo e kolo ana ma ka lepo, he mea hoowahawahaia, aole ia e aiia.   
\q1
\v 42 A o ka mea kolo ma ka opu, a o ka mea hele ma na ha, a o ka mea he nui kona mau kapuwai, iwaena o na mea kolo a pau e kolo ana ma ka lepo, aole oukou e ai ia lakou; no ka mea, he mau mea hoowahawahaia.   
\q1
\v 43 Mai hoolilo ia oukou iho i mea hoowahawahaia, i kekahi mea kolo e kolo ana; aole hoi e hoohaumia ia oukou me lakou i haumia oukou ilaila.   
\q1
\v 44 No ka mea, owau, no Iehova ko oukou Akua; nolaila, e hoomaemae oukou ia oukou iho i maemae oukou, no ka mea, he maemae wau; aole hoi oukou e hoohaumia ia oukou iho me kekahi mea kolo e kolo ana ma ka lepo.   
\q1
\v 45 No ka mea, owau no Iehova, e lawe ana ia oukou mailoko mai o ka aina o Aigupita, i Akua no oukou: nolaila e hoano oukou, no ka mea, he hoano no wau.   
\b  
\q1
\v 46 Oia ke kanawai no na holoholona, a no na manu, a no na mea ola e oni ana iloko o ka wai, a no na mea kolo e kolo ana ma ka lepo:   
\q1
\v 47 E hookaawale iwaena o ka mea haumia a me ka mea maemae, a iwaena hoi o na holoholona e pono ke aiia a me na holoholona pono ole ke aiia.   
\c 12  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 2 E olelo aku oe i na mamo a Iseraela, penei, Ina i hapai ka wahine a hanau he keikikane, e haumia ka wahine i na la ehiku, e like me na la o kona kaawale ana no kona mai, e haumia ana no ia.   
\q1
\v 3 A i ka walu o ka la e okipoepoeia'i kona iliomaka.   
\q1
\v 4 Alaila noho ka wahine iloko o kona koko o kona hoomaemaeia, i na la he kanakolukumamakolu; aole e pa aku oia i ka mea hoano, aole hoi e komo i ke keenakapu, a pau ae na la o kona hoomaemae ana.   
\q1
\v 5 Aka ina i hanau oia he kaikamahine, alaila e haumia ia i na hebedoma elua, me ia i kona kaawale ana; a e noho no oia iloko o ke koko o kona hoomaemaeia i na la he kanaonokumamaono.   
\b  
\q1
\v 6 Aia pau na la o kona hoomaemae ana, no ke keikikane, a no ke kaikamahine paha, e lawe mai no oia i ke keikihipa o ka makahiki hookahi, i mohaikuni, a i ka manu nunu opiopio, a i ke kuhukuku paha i mohailawehala, i ka puka o ka halelewa o ke anaina, i ke kahuna;   
\q1
\v 7 Nana no ia e kaumaha aku ma ke alo o Iehova, a e hana i kalahala nona, a e hoomaemaeia oia mai ke kahe ana o kona koko. Oia ke kanawai no ka wahine i hanau he kane, he wahine paha.   
\q1
\v 8 A ina e hiki ole ia ia ke lawe mai i ke keikihipa, alaila e lawe mai oia i na kuhukuku elua, a i na manu nunu opiopio paha, i kekahi i mohaikuni, a i kekahi i mohailawehala: a e hana ke kahuna i kalahala nona, a maemae no ia.   
\c 13  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose a me Aarona, i mai la,   
\q1
\v 2 A loaa i ke kanaka ka pehu ana ma ka ili o kona io, a o ka pehupala paha, a o kahi lilelile paha, a iloko no o ka ili o kona io e like me ka mai lepera; alaila e laweia mai oia io Aarona la ke kahuna, a i kekahi paha o na keiki ana, na kahuna pule;   
\q1
\v 3 A e nana iho ke kahuna pule i ka mai iloko o ka ili o kona io, a i lilo ka huluhulu iloko o ka mai i keokeo, a ina malalo iho o ka ili o kona io ka mai i ikeia, he mai lepera ia; a e nana ae ke kahuna ia ia a e olelo aku, he haumia ia.   
\q1
\v 4 A ina he keokeo kahi lilelile iloko o ka ili o kona io, a ina aole malalo ia o ka ili i ka ikeia, aole hoi i lilo kolaila huluhulu i keokeo; alaila e papani i ka mea mai, i na la ehiku.   
\q1
\v 5 A i ka hiku o ka la e nana hou aku ke kahuna ia ia; aia hoi, ina aole ai ka mai, aole hoi i nui ae maloko o ka ili; alaila e papani hou ke kahuna ia ia i na la hou ehiku.   
\q1
\v 6 A i ka hiku o ka la, e nana hou aku ke kahuna ia ia; aia hoi, ina i eleele iki mai ka mai, aole hoi i nui ae ka mai iloko o ka ili, alaila e olelo ke kahuna he maemae oia; he pehupala ia, e holoi oia i kona kapa, a e maemae ia.   
\b  
\q1
\v 7 Aka ina i nunui ae ka pehupala iloko o ka ili, mahope iho o kona ikeia ana e ke kahuna, e ike hou ia oia e ke kahuna pule.   
\q1
\v 8 A ina i ike ke kahuna pule, aia hoi, ua nunui ae ka pehupala iloko o ka ili, alaila e olelo aku ke kahuna, ua haumia ia, he lepera ia mai.   
\b  
\q1
\v 9 A ina he mai lepera iloko o ke kanaka, e laweia mai oia i ke kahuna pule;   
\q1
\v 10 A e nana aku ke kahuna ia ia; aia hoi, ina he keokeo ka pehu ana iloko o ka ili, a ua hoolilo ae i ka huluhulu i keokeo, a he io kupu maloko o ka pehu ana,   
\q1
\v 11 He mai lepera kahiko ia iloko o ka ili o kona io, a e olelo ke kahuna he haumia oia, aole e papani ae ia ia, no ka mea he haumia ia.   
\q1
\v 12 Ina i poha ka mai lepera iloko o ka ili, a paapu i ka lepera ka ili o ka mea mai lepera mai kona poo a hiki i kona kapuwai, ma kela wahi keia wahi a puni a ke kahuna i nana ai:   
\q1
\v 13 Alaila, e noonoo ae ke kahuna; aia hoi, ina ua paapu kona io a pau i ka mai lepera, e olelo ae no ia he maemae ka mea mai; ua pau ae i ke keokeo, he maemae oia.   
\q1
\v 14 Aka i na la i ikeia ka io kupu iloko ona, e haumia no ia.   
\q1
\v 15 A e nana hoi ke kahuna i ka io, a e olelo aku hoi he haumia ia; he haumia ka io, he mai lepera ia.   
\q1
\v 16 A ina i ano hou ka io, a lilo ia i keokeo, e hele hou mai no ia i ke kahuna pule;   
\q1
\v 17 A e nana ke kahuna ia ia; aia hoi, ina ua lilo ka mai i keokeo, alaila e olelo ke kahuna, he maemae ka mea mai; he maemae no ia.   
\b  
\q1
\v 18 A o ka io hoi maloko ona, a maloko o kolaila ili, he mai hehee, a ua ola ia;   
\q1
\v 19 A ina ma kahi o ka mai hehee, he pehu keokeo, he wahi lilelile paha, he keokeo, he ula iki nae, a i hoikeia'e i ke kahuna pule;   
\q1
\v 20 A ike ke kahuna, aia hoi, malalo o ka ili ia i ka ikeia, a ua lilo kolaila huluhulu i keokeo, alaila e olelo ke kahuna he haumia ia: he mai lepera ia i poha mai, mailoko mai o ka mai hehee.   
\q1
\v 21 A ina i nana ke kahuna ia mea, aia hoi, aole huluhulu keokeo malaila, aole hoi ia maloko o ka ili, aka he eleele iki; alaila e papani aku ke kahuna ia ia i na la ehiku;   
\q1
\v 22 A ina e palahalaha nui ae ia ma ka ili, alaila e olelo ke kahuna he haumia ia, he mai ino ia.   
\q1
\v 23 Aka ina e mau kahi lilelile ma kona wahi no, aole palahalaha ae, he wewela ia; a e olelo ke kahuna he maemae ia.   
\b  
\q1
\v 24 A ina he io iloko o ka ili kahi i wewela ai a he wahi lilelile keokeo ko ka mea e wewela ana, he ulaula iki paha, he keokeo paha;   
\q1
\v 25 Alaila e nana ke kahuna ia mea; aia hoi, ina ua lilo ka huluhulu maloko o kahi lilelile, i keokeo, a malalo o ka ili ia i ke ikeia, he mai lepera ia i pahu mai mai loko mai o ka wela: nolaila e olelo ai ke kahuna he haumia ia; he mai lepera ia.   
\q1
\v 26 A ina e nana ke kahuna ia mea, aia hoi, aole huluhulu keokeo ma kahi lilelile, aole hoi ia malalo o kekahi ili, aka he eleele iki; alaila e papani aku ke kahuna ia ia i na la ehiku.   
\q1
\v 27 A i ka hiku o ka la, e nana hou ke kahuna ia ia; a ina ua palahalaha nui ae ia ma ka ili, alaila e olelo ke kahuna he haumia ia; he mai lepera ia.   
\q1
\v 28 A ina e mau kahi lilelile i kona wahi iho, aole palahalaha ae ma ka ili, aka he eleele iki nae ia, he pehu ia o ka wela, a e olelo ke kahuna he maemae ia; he hoailona ia o ka wela.   
\b  
\q1
\v 29 Ina he mai ko ke kanaka paha, ko ka wahine paha ma ke poo paha, ma ka umiumi paha:   
\q1
\v 30 Alaila e nana ke kahuna i ka mai ino, aia hoi, ina malalo ia o ka ili i ka ikeia, a malaila ke oho melemele lahilahi; alaila e olelo ke kahuna he haumia ia, he mai lepera ia, he mai lepera ma ke poo paha, a ma ka umiumi paha.   
\q1
\v 31 A ina e nana ke kahuna i ka mai lepera, aia hoi, aole malalo iho ia o ka ili i ka ikeia, aole hoi oho eleele iloko ona; alaila e papani aku ke kahuna i ka mea mai lepera i na la ehiku:   
\q1
\v 32 A i ka hiku o ka la, e nana hou ke kahuna i ka mai; aia hoi, i palahalaha ole ae ka mai lepera, aole hoi oho melemele malaila, aole hoi ka mai lepera malalo o ka ili;   
\q1
\v 33 E kahiia oia, aka aole e kahi i ka mai lepera; a e papani aku ke kahuna i ka mea mai lepera i na la hou ehiku.   
\q1
\v 34 A i ka hiku o ka la, e nana hou ke kahuna i ka mai lepera; aia hoi, ina aole palahalaha ae ka mai lepera ma ka ili, aole hoi ia malalo o ka ili i ka ikeia; alaila e olelo ke kahuna he maemae ia, a e holoi oia i kona kapa, a e maemae no hoi.   
\q1
\v 35 Aka ina i palahalaha nui ae ka mai lepera ma ka ili mahope o kona maemae ana,   
\q1
\v 36 Alaila e nana ko kahuna ia ia; aia hoi, ina ua palahalaha ae ka mai lepera ma ka ili, aole e imi ke kahuna i ke oho melemele, he haumia no ia.   
\q1
\v 37 Aka ina he mau ko ka mai lepera i ka ikeia, a ua kupu ke oho eleele iloko, ua ola ia mai lepera, he maemae no oia: a e olelo ke kahuna he maemae ia.   
\b  
\q1
\v 38 A ina he mau wahi lilelile, he lilelile keokeo ko ke kanaka paha, ko ka wahine paha, iloko o ko laua ili;   
\q1
\v 39 Alaila e nana ke kahuna, aia hoi, ina he keokeo eleele iki, he wahi ahinahina ia e ulu ana iloko o ka ili; he maemae no ia.   
\b  
\q1
\v 40 A o ke kanaka ua haule iho kona lauoho mai kona poo iho, he ohule ia, he maemae nae.   
\q1
\v 41 A o ke kanaka ua haule ka lauoho mai kahi e kokoke ana i kona maka, he lae ohule ia, he maemae nae.   
\q1
\v 42 A ina ma kahi ohule o ke poo, a o ka lae paha he mai keokeo ulaula iki; he mai lepera ia i kupu ma kona poo ohule, a ma kona lae ohule paha.   
\q1
\v 43 Alaila e nana ke kahuna pule ia mea; aia hoi, ina o ka pehu ana o ka mai he ulaula keokeo, ma kona poo ohule paha, a ma kona lae ohule paha, e like me ka mai lepera i ka nanaia ma ka ili o ka io;   
\q1
\v 44 He kanaka lepera ia, he haumia; e olelo ke kahuna, he haumia loa ia, ma kona poo kona mai.   
\b  
\q1
\v 45 A o ka lepera iloko ona ka mai, e uhaeia kona kapa, a e papale ole kona poo, a e uhi i kona lehelehe luna, a e kahea aku, He haumia, he haumia.   
\q1
\v 46 I na la a pau e noho ai ka mai iloko ona, e maemae ole no ia; he haumia no, e noho kaawale ia, mawaho o kahi hoomoana kona wahi e noho ai.   
\b  
\q1
\v 47 O ke kapa hoi koloko ona ka mai lepera, ina he kapa hula hipa, ina he kapa olona;   
\q1
\v 48 Ina ma ka maaweloloa, a ina ma ka maawepokopoko, o ke olona paha, o ka huluhipa; a ina ma ka ili, a ina ma kekahi mea i hanaia o ka ili;   
\q1
\v 49 A ina he omaomao iki, a he ulaula iki ka lepera iloko o ke kapa paha, a iloko paha o ka ili, a iloko paha o ka maaweloloa, a ma ka maawepokopoko paha, a iloko paha o ka mea i hanaia no ka ili; he mai lepera ia, a e hoikeia ia i ke kahuna pule.   
\q1
\v 50 A e nana ke kahuna i ka lepera, a e papani aku i ka mea lepera i na la ehiku.   
\q1
\v 51 A i ka hiku o ka la, e nana aku oia i ka lepera; a ina i palahalaha ae ka lepera iloko o ke kapa, ina maloko o ka maaweloloa, o ina ma ha maawepokopoko, a ina ma ka ili, a ina ma ka mea i hanaia no ka ili; he lepera aai ia, he haumia no ia.   
\q1
\v 52 E puhi hoi oia ia kapa, ina he maaweloloa, ina he maawepokopoko, a ina ma ka huluhipa, ina ma ke olona, a ina ma ko ka ili, kahi e noho ai ka lepera; no ka mea he lepera aai ia, a hoopauia ia i ke ahi.   
\b  
\q1
\v 53 A ina e nana ke kahuna, aia hoi, aole i palahalaha ae ka lepera iloko o ke kapa, ma ka maaweloloa, ka maawepokopoko, a ma ka mea paha i hanaia no ka ili;   
\q1
\v 54 Alaila e kauoha ke kahuna e holoi lakou i ka mea lepera, a e papani hou oia i na la hou ehiku;   
\q1
\v 55 A e nana ke kahuna i ka lepera mahope o ka holoi ana; aia hoi, ina aole ano hou, aole i palahalaha ae ka lepera, he haumia no ia; e puhi oe ia mea i ke ahi, ua aai no ia, ua kuakea ma ke kua a ma ke alo paha.   
\b  
\q1
\v 56 A ina e nana ke kahuna, aia hoi, ua eleele iki ka lepera mahope iho o ka holoi ana ia mea; alaila e uhae oia ia mea mailoko ae o ke kapa paha, a o ka ili paha, a o ka maaweloloa paha, a o ka maawepokopoko paha:   
\q1
\v 57 A i ike mau ia ia iloko o ke kapa, ina ma ka maaweloloa, a ina ma ka maawepokopoko, a ina ma ka mea ili, he mea e palahalaha ana; e puhi oe i ka mea lepera i ke ahi.   
\q1
\v 58 A o ke kapa, o ka maaweloloa, a o ka maawepokopoko, a o ka mea ili, au e holoi ai, ina ua haalele aku ka lepera mailaila aku, alaila e holoi hou ia'e ia mea, a e maemae no.   
\b  
\q1
\v 59 Oia ke kanawai o ka lepera iloko o ke kapa huluhipa, a he olona, ma ka maaweloloa paha, ka maawepokopoko paha, a he mea ili paha, a e olelo ai he maemae, a e olelo ai hoi he haumia.   
\c 14  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 2 Eia ke kanawai o ka lepero i kona la e hoomaemaeia'i; e laweia mai ia i ke kahuna pule;   
\q1
\v 3 A e hele aku ke kahuna mailoko aku o kahi hoomoana, a e nana ke kahuna, aia hoi, ina ua ola ka mai lepera iloko o ka lepero;   
\q1
\v 4 Alaila e kauoha ke kahuna e lawe iho no ka mea e hoomaemaeia ana, elua manu ola, maemae, a me ka laau kedera, a me ka lole ula, a me ka husopa;   
\q1
\v 5 A e kauoha ke kahuna e pepehi ia kekahi o na manu maloko o ka ipu lepo, maluna o ka wai e kahe ana:   
\q1
\v 6 A o ka manu ola, e lalau oia ia, a me ka laau kedera, a me ka lole ula, a me ka husopa, a e hou iho ia mau mea me ka manu ola, iloko o ke koko o ka manu i pepehiia maluna o ka wai e kahe ana:   
\q1
\v 7 A e pipi aku oia maluna o ka mea e hoomaemaeia'na i ka lepera, i ehiku ka pipi ana, a e olelo aku he maemae ia, a e hookuu aku oia i ka manu ola mawaho ma ke kula.   
\q1
\v 8 A o ka mea e hoomaemaeia'na e holoi oia i kona kapa, a e koli i kona lauoho a pau, a e auau ia i ka wai, i maemae ia; a mahope iho, e hele mai ia i kahi hoomoana, a e noho mawaho o kona halelewa i na la ehiku.   
\q1
\v 9 A i ka hiku o ka la, e koli oia i kona lauoho a pau ma kona poe, a me kona umiumi, a me kona hulu kuemaka, o kona lauoho a pau kana e koli ai; a e holoi i kona kapa, a e holoi hoi oia i kona kino iho i ka wai, a a maemae ia.   
\b  
\q1
\v 10 A i ka walu o ka la, e lawe oia i elua keikihipa kane kina ole, a i hookahi keikihipa wahine kina ole o ka makahiki hookahi, a i ekolu paha umi epa o ka palaoa wali, i mohaiai i huiia me ka aila, a i hookahi loga aila.   
\q1
\v 11 A o ke kahuna e hoomaemae ana ia ia, e hoike oia i ke kanaka e hoomaemaeia'na a me kela mau mea, ma ke alo o Iehova ma ka puka o ka halelewa o ke anaina.   
\q1
\v 12 A e lawe ke kahuna i kekahi o ua mau keikihipa kane la, a e kaumaha aku i mohaihala, a me ka loga aila, a e hooluli ae ia mau mea i mohaihoali imua o ke alo o Iehova.   
\q1
\v 13 A e pepehi ai oia i ke keikihipa ma kahi e pepehi ai oia i ka mohailawehala, a me ka mohaikuni, ma kahi hoano; no ka mea, no ke kahuna pule ka mohailawehala, pela ka mohaihala, he laa loa ia.   
\q1
\v 14 A e lawe ke kahuna i kauwahi o ke koko o ka mohaihala, a e kau aku ke kahuna ia ma ke kihi o ka pepeiao akau o ka mea e hoomaemaeia'na, a ma ka manamananui o kona lima akau, a ma ka manamananui hoi o kona kapuwai akau.   
\q1
\v 15 A e lawe ke kahuna i kauwahi o ka loga aila, a e ninini iho maloko o ka poho o kona lima hema:   
\q1
\v 16 A e hoo iho ke kahuna i kona manamanalima akau iloko o ka aila ka mea iloko o kona lima hema, a e pipi i ka aila me kona manamanalima, ehiku ka pipi ana imua o Iehova.   
\q1
\v 17 A o ko ke koena o ka aila iloko o kona lima hema, o ka ke kahuna ia e kau ai ma ke kihi o ka pepeiao akau o ke kanaka e hoomaemaeia'na, a ma ka manamananui o kona lima akau, a ma ka manamananui o kona kapuwai akau maluna iho o ke koko o ka mohailawehala.   
\q1
\v 18 A o ke koena o ka aila iloko o ka lima o ke kahuna, oia kana e ninini ai maluna iho o ke poo o ka mea e hoomaemaeia'na; a e hana ke kahuna i kalahala nona imua o Iehova.   
\q1
\v 19 A e kaumaha aku ke kahuna i ka mohailawehala, a e hana hoi i kalahala no ka mea e hoomaemaeia na mai kona haumia ana; a mahope iho e pepehi ai oia i ka mohaikuni.   
\q1
\v 20 A e kaumaha aku ke kahuna i ka mohaikuni, a me ka mohaiai, maluna o ke kuahu, a e hana ke kahuna i kalahala nona; a e maemae oia.   
\b  
\q1
\v 21 A ina he ilihune ia, aole hoi hiki keia mau mea ia ia; alaila e lawe oia i hookahi keikihipa i mohaihala e hooluliia i kalahala nona, a i hookahi hapaumi o ka epa palaoa wali i huiia me ka aila i mohaiai, a me ka loga aila:   
\q1
\v 22 A i elua kuhukuku, a i ole ia, i elua manu nunu opiopio, na mea e loaa ia ia; a e lilo kekahi i mohailawehala, a o kekahi i mohaikuni.   
\q1
\v 23 A e lawe mai oia ia mau mea i ka walu o ka la, e hoomaemaeia'i oia, i ke kahuna ma ka puka o ka halelewa o ke anaina imua o Iehova.   
\q1
\v 24 A e lawe ke kahuna i ke keikihipa mohaihala a me ka loga aila, a hooluli ke kahuna ia mau mea i mohaihoali imua o Iehova.   
\q1
\v 25 A e pepehi oia i ke keikihipa i mohaihala, a e lawe ke kahuna i kauwahi o ke koko o ka mohaihala, a e kau ae ma ke kihi o ka pepeiao akau o ka mea e hoomaemaeia'na, a ma ka manamananui o kona lima akau, a ma ka manamananui o kona kapuwai akau.   
\q1
\v 26 A e ninini ke kahuna i kauwahi o ka aila ma ka poho o kona lima hema iho:   
\q1
\v 27 A e pipi ke kahuna me kona manamanalima akau i kauwahi o ka aila iloko o kona lima hema, ehiku ka pipi ana imua o Iehova.   
\q1
\v 28 A e kau ke kahuna i kauwahi o ka aila ka mea iloko o kona lima, ma ke kihi o ka pepeiao akau o ka mea e hoomaemaeia'na, a ma ka manamananui o kona lima akau, a ma ka manamananui o kona kapuwai akau, ma kahi o ke koko o ka mohaihala.   
\q1
\v 29 A o ke koena o ka aila maloko o ka lima o ke kahuna, oia kana e kau ai ma ke poo o ka mea e hoomaemaeia'na, a e hana hoi i kalahala nona ma ke alo o Iehova.   
\q1
\v 30 A e kaumaha hoi oia i kekahi o na kuhukuku, a o na manu nunu paha, ka mea e hiki ke loaa ia ia;   
\q1
\v 31 Ka mea e hiki i kona lima, i kekahi i mohailawehala, a i kekahi i mohaikuni, me ka mohaiai; a e hana ke kahuna i kalahala no ka mea e hoomaemaeia'na imua o Iehova.   
\q1
\v 32 Oia ke kanawai no ka mea mai lepera, aole hiki ke loaa i kona lima na mea no kona hoomaemae ana.   
\b  
\q1
\v 33 Olelo mai la hoi o Iehova ia Mose a me Aarona, i mai la,   
\q1
\v 34 Aia komo oukou i ka aina o Kanaana a'u e haawi ai ia oukou i hooilina, a hookomo au i ka ino lepera iloko o ka hale o ka aina o oukou;   
\q1
\v 35 A hele mai ka mea nona ka hale e hai i ke kahuna pule, e i mai ana, I kuu manao, ea, me he ino lepera la iloko o ka hale:   
\q1
\v 36 Alaila e kauoha ke kahuna e hookaawale i ka hale mamua o ke komo ana o ke kahuna e ike i ka ino, i ole ai e pau i ka haumia koloko o ka hale; a mahope iho e hele ae ke kahuna iloko e nana i ka hale.   
\q1
\v 37 A e nana aku oia i ka mai ino, aia hoi, ina ma na paia ka mai ino, he mau alualu, he omaomao iki, a he ulaula iki paha, ua poopoo iloko o ka paia i ka nana aku;   
\q1
\v 38 Alaila e puka aku ke kahuna mawaho o ka hale a i ka puka o ka hale, a e papani i ka hale i na la hiku.   
\q1
\v 39 A e hoi mai ke kahuna i ka hiku o ka la, a e nana; aia hoi, ina ua palahalaha ae ka ino ma na paia o ka hale;   
\q1
\v 40 Alaila e kauoha ke kahuna e lawe aku lakou i na pohaku i pili ai ka ino, a e kiola lakou ia mau mea mawaho o ke kulanakauhale, ma kahi haumia.   
\q1
\v 41 E kepa ae oia ia loko o ka hale a puni, a e ninini aku lakou i ka lepo a lakou i kepa ai, mawaho o ke kulanakauhale ma kahi haumia:   
\q1
\v 42 A e lawe lakou i na pohaku hou a hahao ma kahi o kela mau pohaku; a e lawe oia i ka puna hou e hamo i ka hale.   
\b  
\q1
\v 43 A ina e hiki hou mai ka ino, a poha hon mahope iho o ka lawe ana aku o na pohaku, a mahope hoi o kona kepa ana i ka hale, a mahope hoi o kona hamoia'na;   
\q1
\v 44 Alaila e hele mai ke kahuna a e nana, aia hoi, ina ua palahalaha ae ka ino maloko o ka hale, he lepera ia e aai ana iloko o ka hale, he haumia ia.   
\q1
\v 45 A e hoohiolo hoi oia i ka hale, i kona mau pohaku a me kona mau laau, a me ka puna a pau o ka hale; a e halihali oia ia mau mea mawaho o ke kulanakauhale i kahi haumia.   
\q1
\v 46 O ka mea hoi i hele ae iloko o ka hale i kona wa a pau i papaniia'i, e haumia oia a hiki i ke altiahi.   
\q1
\v 47 A o ka mea moe ma ia hale, e holoi oia i kona kapa; a o ka mea ai maloko o ka kale, e holoi oia i kona kapa.   
\b  
\q1
\v 48 A ina e komo ke kahuna, a e nana aku ia mea, aia hoi, aole i palahalaha ka mai ino maloko o ka hale mahope iho o ka hamoia'na o ka hale; alaila e olelo ke kahuna pule he maemae ka hale, no ka mea, ua ola ka mai ino.   
\q1
\v 49 A lawe oia e hoomaemae i ka hale, i na manu elua, a me ka laau kedera, a me ka ulaula, a me ka huaopa;   
\q1
\v 50 A e pepehi oia i kekahi o na manu, maloko o ka ipu lepo maluna o ka wai e kahe ana;   
\q1
\v 51 A e lawe oia i ka laau kedera, a me ka husopa, a me ka ulaula, a me ka manu e ola ana, a e hou ia mau mea iloko o ke koko o ka manu i pepehiia, a iloko hoi o ka wai e kahe ana, a e pipi i ka hale, ehiku ka pipi ana.   
\q1
\v 52 A e hoomaemae oia i ka hale me ke koko o ka manu a me ka wai e kahe ana, a me ka manu e ola ana, a me ka laau kedera, a me ka huaopa a me ka ulaula.   
\q1
\v 53 Aka, e hookuu aku oia i ka manu e ola ana mawaho ma ke kula, a e hana i kalahala no ka hale; a e maemae no ia.   
\b  
\q1
\v 54 Oia ke kanawai no ka mai ino o kela lepera keia lepera;   
\q1
\v 55 A no ke kapa lepera, a me ka hale no hoi;   
\q1
\v 56 A no ka pahu ana, a me ka pehupala, a me kahi lilelile:   
\q1
\v 57 E hoakaka'i i ka wa e haumia ai ia, a i ka wa e maemae ai hoi; oia ke kanawai o ka lepera.   
\c 15  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose a me Aarona, i mai la,   
\q1
\v 2 E olelo olua i na mamo a Iseraela, e i aku ia lakou, O ke kanaka, he mai kahe mailoko aku o kona io; e haumia no ia, no kona hilo.   
\q1
\v 3 O kona haumia no ia iloko o kono hilo; ina e kahe ana kona io i kona hilo, a ina i paa paha kona io, aole kahe i kona hilo, o kona haumia no ia.   
\q1
\v 4 O kela moe keia moe a ka mea hilo e moe ai maluna iho, e haumia no ia; a o ka mea ana e noho ai maluna iho, e haumia no ia.   
\q1
\v 5 A o ka mea i pai kona moe, e holoi oia i kona mau kapa, a e auau i ka wai, a e haumia a hiki i ke ahiahi.   
\q1
\v 6 O ka mea e noho ma ka mea a ka mea hilo i noho ai, e auau oia i ka wai, a e haumia ia a hiki i ke ahiahi.   
\q1
\v 7 A o ka mea i pa i ka io o ka mea hilo, e holoi oia i kona kapa, a e auau i ka wai, a e haumia a hiki i ke ahiahi.   
\q1
\v 8 A ina e kuha ka mea hilo maluna o ka mea maemae; alaila e holoi oia i kona mau kapa, a e auau i ka wai, a e haumia a hiki i ke ahiahi.   
\q1
\v 9 A o ka noho lio a ka mea hilo e holo ai, e haumia ia.   
\q1
\v 10 A o ka mea i pa i kekahi mea malalo oua, e haumia ia a hiki i ke ahiahi; a o ka mea e hali i kauwahi o ia mau mea, e holoi oia i kona mau kapa, a e auau hoi i ka wai, a e haumia no a hiki i ke ahiahi.   
\q1
\v 11 A o ka mea a ka mea hilo e hoopa aku ai, aole hoi i holoi kona lima i ka wai, e holoi oia i kona mau kapa, a e auau i ka wai, a e haumia hoi ia a hiki i ke ahiahi.   
\q1
\v 12 A o ka ipu lepo a ka mea hilo i pa ai, e wawahiia ia; a o na ipu laau, e holoiia ia i ka wai.   
\b  
\q1
\v 13 A i ka wa e maemae ai ka mea hilo i kona hilo, alaila e hela oia nona i na la ehiku no kona hoomaomaeia'na, a e holoi i kona mau kapa, a o hoauau i kona io i ka wai kahe, a e maemae hoi ia.   
\q1
\v 14 A i ka walu o ka la, e lawe oia nona i na kuhukuku elua, a i ole ia, i elua manu nunu opiopio, a e hele mai imua o ke alo o Iehova, ma ka puka o ka halelewa o ke anaina, a e haawi ia mau mea i ke kahuna.   
\q1
\v 15 A e kaumaha aku ke kahuna ia mau mea, hookahi i mohailawehala, a i kekahi i mohaikuni; a e hana ke kahuna i kalahala nona ma ke alo o Iehova, no kona hilo.   
\b  
\q1
\v 16 A ina e puka aku ka anoano o ke kanaka mailoko aku ona, alaila e holoi oia i kona kino okoa i ka wai, a e haumia hoi a hiki i ke ahiahi.   
\q1
\v 17 A o ke kapa, a o ka ili, he anoano kanaka maluna iho, e holoiia ia i ka wai, a e haumia hoi a hiki i ke ahiahi.   
\q1
\v 18 A o ka wahine hoi a ke kanaka i moe aku ai, me ka anoano, e auau no laua i ka wai, a e haumia hoi a hiki i ke ahiahi.   
\b  
\q1
\v 19 A ina he mai kahe ko ka wahine, a he koko ka mea kahe o kona io, e hookaawaleia'e oia i na la ehiku; a o ka mea i hoopa ia ia, e haumia oia a hiki i ke ahiahi.   
\q1
\v 20 A o ka mea ana e moe ai maluna iho, i kona kaawale ana, e haumia ia; a o ka mea ana e noho ai maluna iho, e haumia no ia.   
\q1
\v 21 O ka mea i pa i kona wahi moe, e holoi oia i kona mau kapa, a e auau i ka wai, a e haumia hoi ia a hiki i ke ahiahi.   
\q1
\v 22 O ka mea hoi i pa i ka mea ana i noho ai maluna iho, e holoi no hoi oia i kona mau kapa, a e auau i ka wai, a e haumia hoi a hiki i ke ahiahi.   
\q1
\v 23 Ina hoi he mea maluna o ka moe, a maluna o kahi ana i noho ai maluna iho, aia pa aku ke kanaka ia, e haumia ia a hiki i ke ahiahi.   
\q1
\v 24 A ina e moe ke kanaka me ia a pili kona koko ia ia, a haumia no ia i na la ehiku; a o ka moe a pau a ia kanaka i moe ai maluna iho, e haumia ia.   
\b  
\q1
\v 25 A ina he heekoko ko ka wahine i na la he nui mawaho o ka wa o kona kaawale ana, a ina e kahe hou no ia mahope o ka pau ana o kona wa kaawale, e like no hoi na la a pau o kona haumia me na la o kona kaawale ana, e haumia no ia.   
\q1
\v 26 O kela moe keia moe ana e moe ai i na la a pau o kona heekoko ana, e like no ia ia ia me ka moe o kona kaawale ana; a o ka mea ana i noho ai maluna iho, e haumia ia, e like me ka haumia o kona kaawale ana.   
\q1
\v 27 A o ka mea i pa ia mau mea, e haumia no ia, a e holoi i kona mau kapa, a e auau i ka wai, a e haumia hoi a hiki i ke ahiahi.   
\q1
\v 28 Aka ina i hoomaemaeia oia i kona heekoko ana, alaila e helu oia nona i na la ehiku, a mahope iho e maemae no ia.   
\q1
\v 29 A i ka walu o ka la, e lawe oia nana i elua kuhukuku, a i ole ia, i elua manu nunu opiopio, a e hali mai i ke kahuna ma ka puka o ka halelewa o ke anaina.   
\q1
\v 30 A e kaumaha aku ke kahuna i kekahi i mohailawehala, a o kekahi i mohaikuni; a e hana ke kahuna i kalahala nona imua o Iehova no kona heekoko haumia.   
\b  
\q1
\v 31 Pela e hookaawale ai oukou i na mamo a Iseraela mai ko lakou haumia ana, i ole ai lakou e make iloko o ko lakou haumia, i ko lakou hoohaumia ana i kuu halelewa iwaena o lakou.   
\q1
\v 32 Oia ke kanawai no ka mea hilo, a no ka mea ua puka mailoko ae ona kona anoano i haumia ai oia;   
\q1
\v 33 A no ka wahine mai heekoko hoi, a me ka mea hilo; o ke kanaka, a o ka wahine, a me ka mea moe me ka wahine haumia.   
\c 16  
\b  
\q1
\v 1 OLELO mai la o Iehova ia Mose mahope iho o ka make ana o na keiki elua a Aarona, i ko laua kaumaha ana imua o Iehova a make iho la:   
\q1
\v 2 I mai la hoi o Iehova ia Mose, E olelo ae oe ia Aarona i kou kaikuaana, i ole ai ia e hele mai i na wa a pau iloko o kahi hoano, maloko o ka paku, ma ke alo o ka noho aloha, ka mea maluna o ka pahu, o make ia; no ka mea, e ikea au iloko o ke ao, maluna o ka noho aloha.   
\q1
\v 3 Penei e komo ai o Aarona iloko o kahi hoano, me ka bipikane opiopio i mohailawehala, a me ka hipakane i mohaikuni.   
\q1
\v 4 E hookomo oia i kahi kapa komo olona hoano, a o ka lole wawae olona kahi ma kona io, a e kaeiia oia me ke kaei olona, a me ka papale olona oia e kahikoia'i: oia na kapa hoano; nolaila e holoi oia i kona io i ka wai, a pela e hookomo ai ia mau mea.   
\q1
\v 5 E lawe oia i na keiki kao elua o ke anaina o na mamo a Iseraela, i mohailawehala, a i ka hipakane i mohaikuni.   
\q1
\v 6 A e kaumaha o Aarona i kana bipikane he mohailawehala, ka mea nona iho, a e hana i kalahala nona iho, a i kalahala no kona ohana.   
\q1
\v 7 A e lawe oia i ua mau kao la elua, a e hoike hoi ia laua ma ke alo o Iehova, ma ka puka o ka halelewa o ke anaina.   
\q1
\v 8 A e hailona iho o Aarona no na kao elua, o kekahi no Iehova, o kekahi no ke I kao hele.   
\q1
\v 9 A e lawe mai o Aarona i ke kao i lilo no Iehova, a e kaumaha hoi ia i mohailawehala.   
\q1
\v 10 Aka o ke kao i lilo i kao hele, oia ke hoike ola ia ma ke alo o Iehova, e hana i kalahala me ia, a e hookuuia'e e hele ia i kao kela iloko o ka waonahele.   
\b  
\q1
\v 11 A e lawe mai o Aarona i ka bipikane he mohailawehala, ka mea nona iho, a e hana oia i kalahala nona iho, a no kona ohana, a e pepehi hoi oia i ka bipikane o ka mohailawehala, ka mea nona iho.   
\q1
\v 12 A e lawe oia i hookahi ipu kapuwahi piha i na lanahu ahi e aa ana, mai luna iho o ke kuahu ma ke alo o Iehova, a me ka piha o kona mau lima i ka mea ala i hoowaliia, a e hali ae, iloko ae o ka paku.   
\q1
\v 13 A e kau oia i ka mea ala maluna iho o ke ahi ma ke alo o Iehova, i uhi ae ke ao o ka mea ala, i ka noho aloha maluna o ka berita, i ole ai ia e make.   
\q1
\v 14 E lawe hoi oia i kauwahi o ke koko o ka bipikane, a e pipi ae ia maluna o ka noho aloha, me kona mananianalima, ma ka hikina; a ma ke alo o ka noho aloha oia e pipi ae i ke koko, me kona manamanalima, ehiku ka pipi ana.   
\b  
\q1
\v 15 Alaila e pepehi oia i ke kao, i ka mohailawehala no na kanaka, a e lawe mai i kona koko maloko o ka paku, a e hana me ia koko e like me kana i hana'i me ke koko o ka bipikane, a e pipi ae ia maluna o ka noho aloha, a ma ke alo o ka noho aloha.   
\q1
\v 16 A e hana oia i kalahala no kahi hoano, no ka haumia o na mamo a Iseraela, a no ko lakou mau hala ma ko lakou hewa a pau; a pela no oia e hana'i no ka halelewa o ke anaina, e waiho ana iwaena o lakou, iwaenakonu o ko lakou haumia.   
\q1
\v 17 Aole loa he kanaka maloko o ka halelewa o ke anaina i kona wa e komo ai e hana i kalahala ma kahi hoano, a puka hou ia, a ua hana hoi oia i Kalahala nona iho, a no kona ohana, a no ke anaina a pau o ka Iseraela.   
\q1
\v 18 A e hele ae ia iwaho i ke kuahu, ka mea ma ke alo o Iehova, a e hana i kalahala nona; a e lawe oia i kauwahi o ke koko o ka bipikane, a me kauwahi o ke koko o ke kao, a e kau ma na pepeiaohao o ke kuahu a puni.   
\q1
\v 19 A e pipi oia i kauwahi o ke koko maluna ona, me kona manamanalima, ehiku ka pipi ana; a e hoomaemae ia mea, a e hoano hoi ia mai ka haumia o na mamo a Iseraela.   
\b  
\q1
\v 20 A pau kona huikala ana i kahi hoano, a me ka halelewa o ke anaina, a me ke kuahu, alaila e lawe mai oia i ke kao oia:   
\q1
\v 21 A e kau o Aarona i kona mau lima maluna o ke poo o ke kao ola: a e hai ae maluna ona i na hewa a pau o na mamo a Iseraela, a me ko lakou hala a pau, ma ko lakou lawehala ana a pau, e waiho ana ia mau mea ma ko poo o ke kao, a e hookuu aku ia ia ma ka lima o ke kanaka pono, iloko o ka waonahele.   
\q1
\v 22 A e hali aku ke kao i ko lakou hewa a pau maluna ona i ka aina kanaka ole; a e hookuu wale aku oia i ke kao iloko o ka waonahele.   
\b  
\q1
\v 23 A e komo o Aarona maloko o ka halelewa o ke anaina, a e hoohemo ae i kona kapa olona, ana i hookomo ai i kona wa i hele ai iloko o kahi hoano, a e waiho iho ia mau mea malaila.   
\q1
\v 24 A e holoi oia i kona io i ka wai, ma kahi hoano, a e hookomo oia i kona mau kapa, a e hele iwaho, a e kaumaha i kona mohaikuni, a me ka mohaikuni o na kanaka, a e hana hoi oia i kalahala nona iho, a no na kanaka.   
\q1
\v 25 A o ke kaikea o ka mohailawehala, oia kana e kuni ai maluna o ke kuahu.   
\q1
\v 26 A o ka mea nana i hookuu i ke kao i ka waoakua, e holoi oia i kona kapa, a e auau i ka wai, a mahope iho e hele mai ia iloko o kahi hoomoana.   
\q1
\v 27 A o ka bipikane, ka mohailawehala, a mo ke kao, ka mohailawehala, ua laweia ko laua koko iloko e hana i kalahala ma kahi hoano, oia ke laweia'e mawaho o kahi hoomoana; a e hoopau lakou i ke ahi i ko laua mau ili, a me ko laua io, a me ko laua lepo.   
\q1
\v 28 A o ka mea i puhi ia mau mea, e holoi oia i kona mau kapa, a e auau i ka wai, a mahope iho e hele mai ia iloko o kahi hoomoana.   
\b  
\q1
\v 29 Eia hoi ke kanawai e mau ana no oukou; i ka hiku o ka malama, i ka la umi o ka malama, e hookaumaha i ko oukou mau uhane, aole e hana iki i ka hana, o ke kanaka o ko oukou aina iho, a o ka malihini e noho ana iwaena o oukou:   
\q1
\v 30 No ka mea, oia ka la e hana'i i kalahala no oukou, e huikala ai ia oukou i maemae oukou, mai ko oukou hewa a pau, imua o ke alo o Iehova.   
\q1
\v 31 E lilo hoi ia i Sabati e maha'i no oukou, a e hookaumaha i ko oukou mau uhane, ma ke kanawai mau loa.   
\q1
\v 32 A o ke kahuna ana e poni ai, a e hoolaa ai, e hana ma ka oihanakahuna ma kahi o kona makuakane, oia ke hana i kalahala, a e hookomo i na kapa olona, i na kapa hoano.   
\q1
\v 33 A e hana oia i kalahala no ke keenakapu hoano, a e hana hoi oia i kalahala no ka halelewa o ke anaina, a me ke kuahu; a e hana hoi i kalahala no na kahuna, a me na kanaka a pau o ke anaina.   
\q1
\v 34 E lilo ia i kanawai mau loa no oukou, e hana i kalahala no na mamo a Iseraela no ko lakou hewa a pau, pakahi i ka makahiki. Hana iho la ia e like me ka Iehova kauoha ia Mose.   
\c 17  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 2 E olelo ae oe ia Aarona a me kana mau keiki, a me na mamo a pau a Iseraela, a e i aku ia lakou; Eia ka mea a Iehova i kauoha mai ai, i ka i ana mai,   
\q1
\v 3 O kela kanaka, keia kanaka o ka ohana o Iseraela, nana i pepehi i ka bipikauo, a i ke keikihipa paha, a i ke kao paha, maloko o kahi hoomoana, a i pepehi ae paha ia mawaho o kahi hoomoana,   
\q1
\v 4 Aole hoi i lawe mai ia mea ma ka puka o ka halelewa o ke anaina, e kaumaha i ka mohai ia Iehova, ma ke alo o ka halelewa o Iehova; e hooiliia ke koko maluna o ia kanaka, ua hookahe oia i ke koko; a e okiia'ku ua kanaka la maiwaena aku o kona poe kanaka:   
\q1
\v 5 I mea e lawe mai ai na mamo a Iseraela i ka lakou mau mohai i kaumaha ai lakou ma ke kula, e lawe mai lakou ia mau mea ia Iehova, ma ka puka o ka halelewa o ke anaina, i ke kahuna, a e kaumaha ia mau mea i mau mohaihoomalu no Iehova.   
\q1
\v 6 A e pipi ke kahuna i ke koko maluna o ke kuahu o Iehova, ma ka puka o ka halelewa o ke anaina, a e puhi i ke kaikea i mea ala ono no Iehova.   
\q1
\v 7 Aole e kaumaha hou lakou i ka lakou mau mohai i na daimonio, mamuli o ia mau mea lakou i hele moe kolohe ai. He kanawai e mau ana keia no lakou i ko lakou mau hanauna.   
\b  
\q1
\v 8 A e olelo aku oe ia lakou, O kela kanaka keia kanaka o ka ohana o Iseraela, a o na malihini e noho ana iwaena o oukou, o ka mea e kaumaha i mohaikuni a i alanapaha,   
\q1
\v 9 Aole nae e lawe mai ia ma ka puka o ka halelewa o ke anaina e kaumaha no Iehova; e okiia'ku ua kanaka la maiwaena aku o kona poekanaka.   
\b  
\q1
\v 10 A o kela kanaka keia kanaka o ka ohana o Iseraela, a o na malihini e noho ana iwaena o oukou, o ka mea e ai i kahi koko, e hooku e au i kuu maka i kela kanaka, a e oki aku au ia ia mai waena aku o kona poe kanaka.   
\q1
\v 11 No ka mea, iloko o ke koko ke ola o ka io, a ua haawi au ia mea ia oukou maluna o ke kuahu i mea e hana i kalahala no ko oukou mau uhane; no ka mea, o ke koko ka i hana i kalahala no ka uhane.   
\q1
\v 12 Nolaila i olelo aku ai au i na mamo a Iseraela, Aole kekahi o oukou e ai i ke koko, aole hoi kekahi malihini e noho ana iwaena o oukou e ai i ke koko.   
\q1
\v 13 A o kela kanaka keia kanaka o na mamo a Iseraela, a o na malihini e noho ana iwaena o oukou, e huli ana a e paa ana i ka holoholona a i ka manu paha e pono ke aiia, e ninini oia i kona koko a e hoouhi me ka lepo.   
\b  
\q1
\v 14 No ka mea, o ke ola o ka io a pau, o ke koko ke ola nona. Nolaila i olelo aku ai au i na mamo a Iseraela, Aole oukou e ai i ke koko o kela io keia io; no ka mea, o ke koko ke ola o na io a pau: o ka mea e ai ia mea, e okiia'ku no ia.   
\q1
\v 15 A o ke kanaka nana e ai i ka mea make wale, a i ka mea paha i pepehiia e na holoholona, o ka mea o ko oukou aina ponoi, a o ka malihini paha, e holoi oia i kona mau kapa, e auau hoi i ka wai, a e haumia a hiki i ke ahiahi.   
\q1
\v 16 Aka ina e holoi ole oia ia mau mea, aole hoi i hoauau i kona io; alaila maluna ona kona hewa.   
\c 18  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 2 E olelo aku i na mamo a Iseraela, a e i aku ia lakou, Owau no Iehova ko oukou Akua.   
\q1
\v 3 Mamuli o na hana a ka aina o Aigupita, kahi i noho ai oukou, aole oukou e hana aku; a mamuli o na hana a ka aina o Kanaana, kahi e lawe ae ai au ia oukou, aole oukou e hana aku; aole hoi oukou e hele ma ka lakou mau oihana.   
\q1
\v 4 E hana hoi oukou ma ko'u mau kanawai, a e malama i ka'u mau oihana, e hele malaila: owau no Iehova ko oukou Akua.   
\q1
\v 5 Nolaila, e malama oukou i ka'u mau kauoha, a me ko'u mau kanawai: ina e hana ke kanaka ia, e ola no oia ia mau mea: owau no Iehova.   
\b  
\q1
\v 6 Aole kekahi o oukou e hookokoke aku i ka io o kona io iho; e wehe i kahi huna: owau no Iehova.   
\q1
\v 7 O kahi huna o kou makuakane, a o kahi huna o kou makuwahine, mai wehe oe: o kou makuwahine no ia, mai wehe oe i kahi huna ona.   
\q1
\v 8 O kahi huna o ka wahine a kou makuakane, mai wehe oe: o kahi huna ia o kou makuakane.   
\q1
\v 9 O kahi huna o kou kaikuwahine, o ke kaikamahine a kou makuakane, o ke kaikamahine o kou makuwahine paha, ua hanau ma kou wahi noho paha, ua hanau ma kahi e paha, mai wehe oe i kahi huna o laua.   
\q1
\v 10 O kahi huna o ke kaikamahine a kau keikikane, a me ke kaikamahine a kau kaikamahine, mai wehe oe i kahi huna o laua: no ka mea, o ko laua, o kou wahi huna no ia.   
\q1
\v 11 O kahi huna o ke kaikamahine a ka wahine a kou makuakane, na kou makuakane i hanau, o kou kaikuwahine no ia, mai wehe oe i kona wahi huna.   
\q1
\v 12 Mai wehe oe i kahi huna o ke kaikuwahine o kou makuakane, o ka io no ia o kou makuakane.   
\q1
\v 13 Mai wehe oe i kahi huna o ka hoahanau wahine o kou makuwahine; no ka mea, o ka io no ia o kou makuwahine.   
\q1
\v 14 Mai wehe oe i kahi huna o ka hoahanaukane o kou makuakane, mai hookokoke aku i kana wahine, he makuwahine ia nou.   
\q1
\v 15 Mai wehe oe i kahi huna o kau hunonawahine: o ka wahine ia a kau keiki: mai wehe oe i kona wahi huna.   
\q1
\v 16 Mai wehe oe i kahi huna o ka wahine a kou hoahanaukane; o kahi huna ia o kou hoahanaukane.   
\q1
\v 17 Mai wehe oe i kahi huna o ka wahine a me kana kaikamahine, aole hoi oe e lawe i ke kaikamahine a kana keiki, aole hoi i ke kaikamahine a kana kaikamahine, e wehe i kona wahi huna; o kona io no lakou; he mea hewa ia.   
\q1
\v 18 Mai lawe oe i ka wahine me kona hoahanauwahine pu, e hoino ia ia, i ka wehe i kona wahi huna, i ka wa e ola ana kela.   
\b  
\q1
\v 19 Aole hoi oe e hookokoke aku i ka wahine e wehe i kona wahi huna, i ka wa e hookaawaleia'i ia no kona haumia.   
\q1
\v 20 Mai moe oe i ka wahine a kou hoalauna, e hoohaumia iho ia oe iho me ia.   
\q1
\v 21 Mai haawi i kahi keiki au e lilo ia Moleka, aole hoi oe e hoino i ka inoa o kou Akua: owau no Iehova.   
\q1
\v 22 Mai moe i ke kanaka, me he wahine la: he mea ia e inainaia.   
\q1
\v 23 Aole hoi oe e moe i ka holoholona, e hoohaumia iho ia oe iho me ia; aole hoi e ku ka wahine imua o ka holoholona e moe iho ia ia; he mea haumia hilahila ia.   
\b  
\q1
\v 24 Mai hoohaumia oukou ia oukou iho ma kekahi o keia mau mea, no ka mea, ma keia mau mea a pau ua haumia na lahuikanaka a'u e kipaku aku ai mai mua aku o oukou.   
\q1
\v 25 Ua haumia ka aina; nolaila, ke hoopai nei au i kona hewa maluna iho ona, a ke luai aku nei no ka aina i kona poe kamaaina.   
\q1
\v 26 No ia mea, e malama oukou i ka'u mau kauoha a me ko'u mau kanawai, aole hoi e hana i kekahi o keia mau mea e inainaia, aole kekahi o ko oukou lahuikauaka, aole hoi o ka malihini e noho ana iwaena o oukou:   
\q1
\v 27 (No ka mea, ua hana na kanaka o ka aina mamua o oukou, i keia mau mea inainaia a pau, a ua haumia ka aina;)   
\q1
\v 28 I ole ai e luai aku ka aina ia oukou kekahi, i ka wa e hoohaumia ai oukou ia ia, e like me kona luai ana'ku i na lahuikanaka, ka poe mamua o oukou.   
\q1
\v 29 No ka mea o ka mea e hana i kekahi o keia mau mea inainaia, o na kanaka e hana, e okiia lakou maiwaena aku o ko lakou poe kanaka.   
\q1
\v 30 Nolaila, e malama oukou i ka'u oihana, aole e hana ma keia mau hana inainaia, i hanaia mamua o oukou; aole hoi oukou e hoohaumia ia oukou iho malaila: owau no Iehova ko oukou Akua.   
\c 19  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 2 E olelo aku oe i ke anaina a pau o na mamo a Iseraela, a e i aku ia lakou, I hemolele oukou; no ka mea, he hemolele no wau o Iehova ko oukou Akua.   
\b  
\q1
\v 3 E weliweli oukou kela kanaka keia kanaka i kona makuwahine a i kona makuakane, a e malama hoi i kuu mau Sabati: owau no Iehova ko oukou Akua.   
\b  
\q1
\v 4 Mai huli oukou ma na kii, aole hoi e hana i na akua i hooheheeia no oukou: owau no Iehova ko oukou Akua.   
\b  
\q1
\v 5 A ina e kaumaha aku oukou i ka alana o na mohai hoomalu, ia Iehova, e kaumaha oukou ia na ko oukou makemake iho.   
\q1
\v 6 E aiia ia i ka la i kaumaha ai oukou ia mea, a ia la aku hoi; a ina e koe kauwahi i ke kolu o ka la, e hoopauia ia i ke ahi.   
\q1
\v 7 A ina e ai iki ia ia i ke kolu o ka la, e hoowahawahaia ia, aole e maliuia.   
\q1
\v 8 Nolaila, o ka mea e ai ia, e kau no kona hewa maluna ona, no kana hoino ana i ka mea hoano no Iehova: a e okiia'ku kela kanaka maiwaena aku o kona poe kanaka.   
\b  
\q1
\v 9 Aia oki oukou i ka ai o ko oukou aina, mai oki loa i na kihi o kau mahinaai aole hoi oe e hoiliili i na haulena o kau ai.   
\q1
\v 10 Mai ohi loa i ko kau malawaina, aole hoi oe e hoiliili i na huawaina a pau loa o kau malawaina; e waiho no oe ia mau mea na ka mea ilihune, a me ka malihini: owau no Iehova ko oukou Akua.   
\b  
\q1
\v 11 Mai aihue oukou, aole hoi e hookamani, aole hoi e hoopunipuni kekahi i kekahi.   
\b  
\q1
\v 12 Mai hoohiki oukou ma ko'u inoa me ka wahahee, aole hoi oe e hoino i ka inoa o kou Akua; owau no Iehova.   
\b  
\q1
\v 13 Mai alunu oe i kou hoalauna, aole hoi oe e kaili wale: o ka uku o ka mea i hoolimalimaia, mai waiho pu me oe i ka po okoa a kakahiaka ae.   
\b  
\q1
\v 14 Mai kuamuamu aku oe i ke kuli, aole hoi oe e waiho i ka mea e hina ai mamua o ka makapo, aka e makau oe i kou Akua; owau no Iehova.   
\b  
\q1
\v 15 Mai hana ino oukou ma ka hoopai ana; mai manao oe i ke kino o ka mea ilihune, aole hoi e mahalo i ke kino o ka mea ikaika: aka ma ka pololei e hooponopono ai oe i kou hoalauna.   
\b  
\q1
\v 16 Mai hele oe io ia nei me he holoholo olelo la iwaena o kou poe kanaka; aole hoi oe e ku e i ke koko o kou hoalauna: owau no Iehova.   
\b  
\q1
\v 17 Mai inaina aku oe i kou hoahanau iloko o kou naau; e ao io aku no oe i kou hoalauna, aole hoi e waiho i ka hewa maluna ona.   
\b  
\q1
\v 18 Mai hoomaau, mai hoomauhala i na keiki o kou poe kanaka; aka e aloha oe i kou hoalauna e like me oe iho: owau no Iehova.   
\b  
\q1
\v 19 E malama oukou i ko'u mau kanawai Mai kuu aku oe e hoohanau kau holoholona me ka holoholona ano okoa; aole hoi oe e lulu i kou mahinaai, me na hua ano elua; aole hoi e kau i ke kapa olona me ka hulu hipa i huiia, maluna ou.   
\b  
\q1
\v 20 O ka mea moe aku i ka wahine, he kauwawahine, i hoopalauia na ke kane, aole i ukupanaiia, aole i haawiia ia ia ke ku i ka wa; e uhauia'na; aole e hoomakeia laua, no ka mea, aole i kaawale ia wahine.   
\q1
\v 21 A e lawe mai ua kanaka la i ka mohaihala ia Iehova, i ka puka o ka halelewa o ke anaina, he hipakane, i mohaihala.   
\q1
\v 22 A e hana ke kahuna i kalahala nona me ka hipakane mohaihala, ma ke alo o Iehova, no kona hewa ana i hana'i; a e kalaia kona hewa ana i hana'i.   
\b  
\q1
\v 23 A komo oukou i ka aina, a kanu i kela laau i keia laau i mea ai, alaila e kapa ae oukou i kona hua he okipoepoe ole ia; ekolu makahiki he okipoepoe ole ia ia ia oukou; aole e aiia.   
\q1
\v 24 Aka i ka ha o ka makahiki, e hoano ko na hua a pau, i mea e hoolea ai ia Iehova.   
\q1
\v 25 A i ka lima o ka makahiki, e ai oukou i kona hua, e haawi ai oia i kona hua ia oukou: owau no Iehova ko oukou Akua.   
\b  
\q1
\v 26 Mai ai oukou me ke koko: aole hoi e kuka-moo, aole hoi e nana-ao.   
\q1
\v 27 Mai hoopoepoe i na kihi o ko oukou mau poo, aole hoi oe e hoino i na kihi o kou umiumi.   
\q1
\v 28 Mai okioki i ko oukou io no ka mea make, aole hoi e kakau kaha ma ko oukou kino: owau no Iehova.   
\b  
\q1
\v 29 Mai hoonoa i kau kaikamahine e hoolilo ia ia i hookamakama; o lilo ka aina i ka moe kolohe, a piha ae la ka aina i ka hewa.   
\b  
\q1
\v 30 E malama oukou i ko'u mau Sabati, a e mahalo i ko'u keenakapu: owau no Iehova.   
\b  
\q1
\v 31 Mai manao oukou i na mea ninau-uhane, aole hoi e imi aku i na kupua, e haumia ai oukou ia lakou: owau no Iehova ko oukou Akua.   
\b  
\q1
\v 32 Ma ke alo o ke poohina, e ku ae ai oe iluna, a e mahalo aku i ke alo o ka elemakule, a e weliweli i kou Akua: owau no Iehova.   
\b  
\q1
\v 33 A ina e noho ka malihini me oe ma ko oukou aina, mai hooluhihewa ia ia.   
\q1
\v 34 Aka o ka malihini e noho ana me oukou, e like auanei ia ia oukou me he kupa la i hanau iwaena o oukou, a e aloha oe ia ia e like me oe iho; no ka mea, he mau malihini no oukou ma ka aina o Aigupita: owau no Iehova ko oukou Akua.   
\b  
\q1
\v 35 Mai hana kekee oukou i ka hooponopono ana, ma ke ana ana, ma ka paona, a ma ke ana.   
\q1
\v 36 E malama no oukou i paona pololei, i poka pono, i epa pono, i hina pono; owau no Iehova ko oukou Akua nana oukou i lawe mai, mailoko mai o ka aina o Aigupita.   
\q1
\v 37 Nolaila, e malama oukou i ka'u mau kauoha a pau, a me ko'u mau kanawai a pau, a e hana ma ia mau mea; owau no Iehova.   
\c 20  
\b  
\q1
\v 1 OLELO mai la o Iehova ia Mose, i mai la,   
\q1
\v 2 E olelo hou aku oe i na mamo a Iseraela, O kela kanaka keia kanaka, o na mamo a Iseraela, a o na malihini e noho ana ma ka Iseraela, nana e haawi i kahi keiki ana ia Moleka, e make io no ua kanaka la; na na kanaka o ka aina ia e hailuku aku me na pohaku.   
\q1
\v 3 A e hooku e au i ko'u maka i kela kanaka, a e oki aku hoi au ia ia maiwaena aku o kona poe kanaka, no kona haawi ana i kekahi keiki ana ia Moleka; e hoohaumia i kuu keenakapu, a me ka hoino i ko'u inoa hoano.   
\q1
\v 4 A ina e huna iki na kanaka o ka aina i ko lakou mau maka i na kanaka la, i kona wa e haawi ai i kekahi keiki ana ia Moleka, aole hoi hoomake ia ia;   
\q1
\v 5 Alaila, na'u no e hooku e i kuu maka i ua kanaka la a me kona ohana, a e oki aku au ia ia, a me ka poe a pau e hele moe kolohe mamuli ona, e moe kolohe me Moleka, maiwaena aku o ko lakou poe kanaka.   
\b  
\q1
\v 6 A o ke kanaka huli mamuli o na mea ninau-uhane, a mamuli hoi o na kupua, e hele moe kolohe mamuli o lakou, e hooku e au i kuu maka i kela kanaka, a e oki aku hoi au ia ia maiwaena aku o kona poe kanaka.   
\b  
\q1
\v 7 Nolaila, e huikala oukou ia oukou iho, i hoano hoi oukou: no ka mea, owau no Iehova ko oukou Akua.   
\q1
\v 8 E malama oukou i ko'u mau kanawai, a e hana hoi ma ia mau mea: owau no Iehova nana oukou e hoolaa nei.   
\b  
\q1
\v 9 No ka mea, o kela kanaka keia kanaka i kuamuamu i kona makuakane a i kona makuwahine paha, e make io no ia: ua hoino aku oia i kona makuakane, a i kona makuwahine paha; maluna ona kona koko iho.   
\b  
\q1
\v 10 O ke kanaka moe kolohe aku i ka wahine a kekahi kanaka, o ka mea moe kolohe i ka wahine a kona hoalauna, e make io no ke kanaka moe kolohe a me ka wahine moe kolohe.   
\q1
\v 11 O ke kanaka moe me ka wahine a kona makuakane, ua wehe ae oia i kahi huna o kona makuakane; e make io no laua pu; maluna o laua ko laua koko iho.   
\q1
\v 12 Ina e moe ke kanaka me kana hunonawahine, e make io no laua pu, ua hana laua i ka mea haumia hilahila; maluna o laua ko laua koko iho.   
\q1
\v 13 Ina e moe aku ke kanaka i ke kane e like me kona moe aku i ka wahine, ua hana pu laua i ka mea haumia hilahila; e make io no laua pu; maluna o laua ko laua koko.   
\q1
\v 14 Ina e mare ke kanaka i ka wahine a me kona makuwahine, he hewa ia: e puhi pu ia lakou i ke ahi, oia pu me laua la; i ole ai he hewa iwaena o oukou.   
\q1
\v 15 A ina e moe ke kanaka i ka holoholona, e make io no ia; a e pepehi oukou ia holoholona.   
\q1
\v 16 A ina e hookokoke aku ka wahine i ka holoholona e moe iho ia ia, e pepehi oe ia wahine, a me ka holoholona: e make io no laua pu; maluna o laua ko laua koko.   
\b  
\q1
\v 17 A ina e lawe ke kanaka i kona kaikuwahine, i ke kaikamahine a kona makuakane, a i ke kaikamahine a kona makuwahine paha, a ike aku i kona wahi huna, a ike mai kela i kona wahi huna, he mea hewa io no ia; e okiia laua ma ke alo o ko laua poe kanaka: ua wehe oia i kahi huna o kona kaikuwahine; e kau no kona hewa maluna ona.   
\q1
\v 18 A ina e moe aku ke kanaka i ka wahine i kona mai ana, a wehe ae i kona wahi huna; ua wehe ae ia i kona punawai, a ua wehe ae ia wahine i ke kumu o kona koko, e oki pu ia'ku hoi laua maiwaena aku o ko laua poe kanaka.   
\q1
\v 19 Mai wehe oe i kahi huna o ka hoahanauwahine o kou makuwahine, a o ke kaikuwahine a kou makuakane paha; no ka mea, oia ka wehe i kona io iho; e kau no ko laua hewa maluna o laua.   
\q1
\v 20 A ina e moe aku ke kanaka me ka wahine a ka hoahanaukane o kona makuakane, ua wehe ae oia i kahi huna o kela makuakane; e kau no ko laua hewa maluna o laua, e make keiki ole laua.   
\q1
\v 21 A ina e lawe ke kanaka, i ka wahine a kona hoahanaukane, he mea haumia ia; ua wehe ae oia i kahi huna o kona hoahanaukane, aole aku keiki a laua.   
\b  
\q1
\v 22 Nolaila, e malama oukou I ka'u mau kauoha a pau, a me ko'u mau kanawai a pau; i ole ai ka aina kahi a'u e lawe aku ai ia oukou e noho malaila, e luai aku ia oukou.   
\q1
\v 23 Mai hele oukou ma na oihana a na lahuikanaka, a'u e kiola aku ai imua o oukou: no ka mea, ua hana lakou i keia mau mea a pau, nolaila i hoowahawaha aku ai au ia lakou.   
\q1
\v 24 Aka, ua olelo aku au ia oukou, e loaa ia oukou ko lakou aina; na'u ia e haawi aku no oukou ponoi, he aina e kahe ai ka waiu a me ka meli: owau no Iehova ko oukou Akua nana oukou i hookaawale ae mai na lahuikanaka e ae.   
\q1
\v 25 Nolaila e hookaawale ae oukou iwaena o na holoholona maemae, a me ka haumia, a mawaena o na manu haumia, a me ka maemae: mai hoohaumia i ko oukou mau uhane ma kahi holoholona, a me kahi manu, a me kahi mea e kolo ana ma ka lepo, na mea a'u i hookaawale ae mai o oukou ae, me he haumia la.   
\q1
\v 26 E hoano hoi oukou no'u; no ka mea, he hoano no wau, o Iehova, a ua hookaawale ae au ia oukou mai na lahuikanaka e i lilo oukou no'u.   
\b  
\q1
\v 27 O ke kanaka, a o ka wahine paha, he ninau-uhane, a he kupua paha, e make no ia; e hailuku lakou ia laua me na pohaku; e kau no ko laua koko maluna o laua.   
\c 21  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose, E olelo aku i na kahuna, i na keiki a Aarona, a e i aku ia lakou, Aohe kanaka e hoohaumiaia no ka make iwaena o kona poe kanaka:   
\q1
\v 2 Aka no kona io iho, no ka mea kokoke mai ia ia, no kona makuwahine, a me kona makuakane a me kana keiki, a me kana kaikamahine, a me kona hoahanaukane,   
\q1
\v 3 A me kona kaikuwahine, he puupaa, i kokoke mai ia ia, aole i loaa la ia ke kane, e hiki no ke hoohaumiaia oia nona.   
\q1
\v 4 Aole e hoohaumia oia ia ia iho, he haku iwaena o kona poe kanaka, e hoino ia ia iho.   
\q1
\v 5 Aole lakou e hooohule i ko lakou mau poo, aole hoi e kahi i na kihi o ko lakou umiumi, aole hoi e okioki i ko lakou io iho.   
\q1
\v 6 E hoano auanei lakou i ko lakou Akua, aole hoi e hoohaumia i ka inoa o ko lakou Akua; no ka mea, o na mohai o Iehova i kaumahaia ma ke ahi, a me ka berena ua ko lakou Akua, oia ka lakou i kaumaha ai, nolaila, e pono ko hoano lakou.   
\b  
\q1
\v 7 Aole lakou e lawe i ka wahine hookamakama, a he haumia paha; aole hoi lakou e lawe i ka wahine i hookaawaleia'e mai kana kane ae; no ka mea, he hoano oia i kona Akua.   
\q1
\v 8 Nolaila e hoano oe ia ia, no ka mea, o ka berena na kou Akua kana i kaumaha'i; e hoano auanei oia ia oe; no ka mea, he hoano no wau o Iehova kou Akua nana oukou i hoano.   
\b  
\q1
\v 9 O ke kaikamahine a ke kahuna pule, ina e hoohaumia oia ia ia iho i ka moe kolohe, ua hoohaumia oia i kona makuakane; e puhiia oia i ke ahi.   
\b  
\q1
\v 10 A o ke kahuna nui iwaena o kona poe hoahanau, maluna iho o kona poo i nininiia ka aila poni, a ua hoolaaia e komo i ke kapa, aole hoi e uhae i kona mau kapa;   
\q1
\v 11 Aole hoi e komo ae i ka mea i make, aole hoi no kona makuakane, a no kona makuwahine paha, e hoohaumia ai oia ia ia iho.   
\q1
\v 12 Aole hoi oia e puka ae iwaho o ke keenakapu, aole hoi e hoohaumia i ke keenakapu o kona Akua; no ka mea, maluna ona ka lei o ka aila poni o kona Akua: owau no Iehova.   
\q1
\v 13 E mare no hoi oia i ka wahine i kona puupaa ana.   
\q1
\v 14 O ka wahine kane make, a o ka wahine hemo, a o ka haumia, o ka hookamakama, oia mau mea kaua e lawe ole ai; aka e lawe oia i ka wahine puupaa o kona poe kanaka i wahine.   
\q1
\v 15 Aole hoi oia e hoohaumia i kana keiki iwaena o kona poe kanaka; no ka mea, ke hoano nei au o Iehova ia ia.   
\b  
\q1
\v 16 Olelo mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 17 E olelo aku oe ia Aarona, penei, O ka mea o kau mau keiki i ko lakou hanauna, he kina kona, aole ia e hookokoke e kaumaha i ka berena a kona Akua:   
\q1
\v 18 No ka mea, o kela kanaka keia kanaka he kina kona, aole ia e hookokoke mai: o ke kanaka makapo, o ka oona, o ka ihu pepe, a he lala oi aku kona,   
\q1
\v 19 A o ke kanaka ua hai kona wawae, a ua hai kona lima paha,   
\q1
\v 20 A he kuapuu, a he aa, a he kina, ma kona maka, a he puupuu, a he kakio, a he hua pepeia;   
\q1
\v 21 O kela kanaka keia kanaka o na keiki a Aarona he kina kona, aole ia e hookokoke mai e kaumaha i na mohai no Iehova i kaumahaia ma ke ahi; he kina kona, aole ia e hele kokoke mai e kaumaha i ka berena a kona Akua.   
\q1
\v 22 O ka berena a kona Akua, o ka mea hoano loa, a me ka mea hoano, oia kana e ai ai.   
\q1
\v 23 Aole hoi ia o komo i ka paku, aole hoi e hookokoke i ke kuahu, no kona kina ana; o hoohaumia oia i kuu mau keenakapu: no ka mea, na'u na Iehova lakou e hoano nei.   
\q1
\v 24 A hai ae la o Mose ia Aarona, a i kana mau keiki, a i na mamo a pau a Iseraela.   
\c 22  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 2 E olelo aku ia Aarona, a i kana mau keiki, e hookaawale lakou ia lakou iho mai na mea hoano o na mamo a Iseraela, i ole ai lakou e hoino mai i ko'u inoa hoano i na mea a lakou i hoano mai ai no'u; owau no Iehova.   
\q1
\v 3 E olelo aku ia lakou, O ka mea o ka oukou mau keiki a pau iwaena o ko oukou mau hanauna, e hele i na mea hoano a na mamo a Iseraela i hoolaa aku ai ia Iehova, me kona haumia maluna ona, e okiia'ku oia mai ko'u alo aku: owau no Iehova.   
\q1
\v 4 O kela kanaka, keia kanaka he keiki a Aarona, he lepero, a he hilo kahe kona; aole ia e ai i na mea hoano a hiki i kona maemae ana. A o ke kanaka hoopa aku i ka mea haumia no ka mea make, a o ke kanaka ua hele aku kona anoano mai ona aku;   
\q1
\v 5 A o ke kanaka hoopa aku i ka mea kolo e haumia ai, a i ke kanaka paha e haumia ai, o kela haumia keia haumia kona;   
\q1
\v 6 O ke kanaka i pa aku i kekahi o ia mau mea, e haumia no ia a hiki i ke ahiahi, aole ia e ai i na mea hoano, ke holoi ole oia i kona io i ka wai.   
\q1
\v 7 A napoo ka la, e maemae no ia, a mahope iho e ai no oia i na mea hoano; no ka mea, o kana ai no ia.   
\q1
\v 8 O ka mea make wale, a o ka mea i nahaeia, aole oia e ai ia, e hoohauraia'i ia ia iho: owau no Iehova.   
\q1
\v 9 E malama hoi lakou i ka'u oihana, o hooili lakou i ka hewa maluna ona, a make, ke hoohaumia Iakou ia mea: na'u ua Iehova lakou e hoano nei.   
\b  
\q1
\v 10 Aole e ai ka malihini i ka mea hoano; o ko ke kahuna mea e noho malihini mai, a o ke kauwa hoolimalima, aole no e ai i ka mea hoano.   
\q1
\v 11 Aka ina e kuai ke kahuna i ke kanaka me kana kala, e ai no oia ia, a me ka mea i hanau maloko o kona hale; o lakou ke ai i kana ai.   
\q1
\v 12 Ina e mare ke kaikamahine a ke kahuna i ka malihini, aole oia e ai i ka alana o na mea hoano.   
\q1
\v 13 Aka ina he wahinekanemake ke kaikamahine a ke kahuna, a ua hemo paha me ke keiki ole, a ua hoi mai i ka hale o kona makuakane, e like me kona wa kamalii, e ai no oia i ka ai a kona makuakane; aka aole ka malihini e ai ia mea.   
\b  
\q1
\v 14 A ina e ai ke kanaka i ka mea hoano, me ka ike ole, alaila e hui aku oia i ka hapa lima me ia, a e haawi aku i ke kahuna me ka mea hoano.   
\q1
\v 15 Aole lakou e hoohaumia i ka na mamo a Iseraela mau mea hoano a lakou i hoolaa ai ia Iehova:   
\q1
\v 16 Aole hoi e waiho aku maluna o lakou i ka hewa o ka lawehala ana, i ka lakou ai ana i na mea hoano; no ka mea, na'u na Iehova lakou e hoano nei.   
\b  
\q1
\v 17 Olelo mai la hoi o Iehova ia Mose, penei,   
\q1
\v 18 E olelo aku oe ia Aarona, a i kana mau keiki, a i na mamo a pau a Iseraela, a e i aku ia lakou, O kela kanaka keia kanaka o ka ohana o Iseraela, a o na malihini iloko o ka Iseraela, nana e kaumaha i kona mohai no kona hoohiki ana a pau, a no kana mau alana na kona makemake, ka mea a lakou e kaumaha'i ia Iehova, imohaikuni:   
\q1
\v 19 Na ko oukou makemake iho, i ke kane kina ole o na bipi, o na hipa, a o na kao.   
\q1
\v 20 O ka mea kina, aole oukou e kaumaha ia; no ka mea, aole ia e maliuia no oukou.   
\q1
\v 21 A o ke kanaka nana e kaumaha i ka alana o na mahaihoomalu ia Iehova, e hooko ai i kana i hoohiki ai, a ina he mohai na kona makemake, o na bipi, a o na hipa paha, e hemolele ia e maliuia'i: aole aku kina iloko ona.   
\q1
\v 22 O ka makapaa, o ka oopa, a he puu kona, he puupuu, he kakio, aole oukou e kaumaha ia mau mea ia Iehova, aole hoi e hoolilo ia mau mea i mohai e kaumahaia ma ke ahi maluna o ke kuahu ia Iehova.   
\q1
\v 23 O ka bipikane, a o ka hipakeiki, he oi aku ko ka lala ona, he hemahema paha, e hiki no ke kaumaha oe ia i mohai na kou makemake no; aka no ka hoohiki ana aole e maliuia'ku ia.   
\q1
\v 24 O ka mea i pepeia, a i paopaoia, a uhaeia, a i poaia, aole oukou e kaumaha ia mea ia Iehova, aole oukou e hana ma ko oukou aina.   
\q1
\v 25 Aole hoi noloko mai a ko ka malihini lima, e kaumaha ai oukou i ka berena a ko oukou Akua, no keia mau mea; no ka mea, iloko o lakou ko lakou popopo, he mau kina iloko o lakou; aole e maliuia no oukou.   
\b  
\q1
\v 26 Olelo mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 27 Aia hanau ka bipikane, a he hipa paha, a he kao paha, alaila e noho ia malalo iho o ka makua, i na la ehiku; a mai ka walu o ka la, a mahope aku e maliuia'i ia i mohai puhi no Iehova.   
\q1
\v 28 Ina he bipiwahine, a he hipawahine paha, aole oukou e pepehi pu ia mea me kana keiki i ka la hookahi.   
\q1
\v 29 Aia kaumaha aku oukou i ka mohai aloha ia Iehova, e kaumaha oukou ia ua ko oukou makemake no.   
\q1
\v 30 Ia la hookahi no, e aiia ia, aole e hookoe oukou i kauwahi ona a ao ae: owau no Iehova.   
\q1
\v 31 Nolaila e malama oukou i ka'u mau kauoha, a e hana ma ia mau mea: owau no Iehova.   
\q1
\v 32 Aole hoi oukou e hoino i ko'u inoa hoano; e hoanoia no wau iwaena o na mamo a Iseraela; owau no Iehova nana oukou e hoano nei,   
\q1
\v 33 Nana hoi oukoa i lawe mai mai ka aina o Aigupita mai i Akua au no oukou: owau no Iehova.   
\c 23  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 2 E olelo aku i na mamo a Iseraela, a e i aku ia lakou, o na ahaaina a oukou e kala ai he mau houluulu hoano, no'u no ia mau ahaaina.   
\b  
\q1
\v 3 I na la eono, e hanaia'i ka hana, aka o ka hiku o ka la, he Sabati e hoomaha'i ia, he houluulu hoano: aole oukou e hana: he Sabati ia no Iehova maloko o ko oukou mau hale a pau.   
\b  
\q1
\v 4 Eia na ahaaina a Iehova, na houluulu hoano a oukou e kala ai i ko lakou wa pono.   
\q1
\v 5 I ka la umikumamaha o ka malama mua, i ke ahiahi, ilaila ka moliaola a Iehova.   
\q1
\v 6 A i ka la umikumamalima o ia malama no, ka ahaaina o ka berena huole, no Iehova; ehiku la e ai ai oukou i ka berena huole.   
\q1
\v 7 I ka la mua, he houluulu hoano ko oukou, aole oukou e hana i ka hana e luhi ai ilaila:   
\q1
\v 8 Aka e kaumaha oukou i ka mohai puhi ia Iehova i na la ehiku: a i ka hiku o ka la, he houluulu hoano, aole oukou e hana i ka hana e luhi ai.   
\b  
\q1
\v 9 Olelo mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 10 E olelo aku i na mamo a Iseraela, a e i aku ia lakou, Aia komo oukou i ka aina a'u e haawi aku ai ia oukou, a okioki hoi i ka ai ona, alaila e lawe mai oukou i ka pua hua mua o ka oukou ai i ke kahuna.   
\q1
\v 11 A e hoali ae oia i ka pua imua i ke alo o Iehova, e maliuia'i ia no oukou: i ka la e noa ai ka Sabati, e hoali ai ke kahuna.   
\q1
\v 12 A e kaumaha oukou ia la o oukou i hooluli ai i ka pua, i keikihipakane kina ole o ka makahiki hookahi, i mohaikuni no Iehova.   
\q1
\v 13 A o kona mohai ai, elua hapa umi dila o ka palaoa wali i hui pu me ka aila, he mohai puhi no Iehova, i mea ala ono: a o kona mohai inu, he waina, he hapa ha o ka hina.   
\q1
\v 14 A o ka berena, a o ka hua palaoa moa, a o ka hua maka, aole oukou e ai a hiki i ka la i lawe mai ai oukou i ka mohai i ko oukou Akua; he kanawai mau loa ia i ko oukou mau hanauna, iloko o ko oukou mau hale a pau loa,   
\b  
\q1
\v 15 A e helu oukou no oukou iho mai ka la e noa ai ka Sabati, mai ka la i lawe mai ai oukou i ka pua i mohai hoali; ehiku Sabati e pau ai.   
\q1
\v 16 A hiki i ka la e noa ai ka Sabati ahiku, e helu ai oukou i na la he kanalima, a e haawi hou i mohaiai hou ia Iehova.   
\q1
\v 17 E lawe mai hoi oukou i elua popo berena hooluli elua hapa umi dila, he palaoa wali ia, e hoomoaia ia me ka hu; he mau hua mua ia no Iehova.   
\q1
\v 18 A e kaumaha oukou me ka berena, i ehiku keikihipa kina ole o ka makahiki mua, a i hookahi bipikane opiopio, a i elua hipakane: e lilo ia i mohaikuni no Iehova, me ko lakou mohai ai, me ko lakou mohai inu, he alana e kaumahaia ma ke ahi, he mea ala ono no Iehova.   
\q1
\v 19 Alaila e kaumaha oukou i hookahi keikikao, i mohailawehala, a i elua keikihipa o ka makahiki mua, i alana o ua mohaihoomalu.   
\q1
\v 20 A e hoali ke kahuna ia mau mea me ka berena o na hua mua i mohai hoali ma ke alo o Iehova, me na keikihipa elua: e laa ia no Iehova na ke kahuna.   
\q1
\v 21 E hai aku oukou ia la i'houluulu hoano no oukou: aole oukou e hana i ka hana e luhi ai. He kanawai mau loa iloko o ko oukou mau hale a pau, i ko oukou mau hanauna.   
\b  
\q1
\v 22 Aia e okioki oukou i ka ai o ko oukou aina, mai oki loa i na kihi o kau mahinaai, i kou oki ana. aole hoi oe e ohi i na haulena o kau ai: e waiho no oe pela na ka poe ilihune, a na ka malihini; owau no Iehova ko oukou Akua.   
\b  
\q1
\v 23 Olelo mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 24 E olelo aku oe i na mamo a Iseraela, penei, I ka hiku o ka malama, i ka la mua o ka malama, he Sabati ko oukou, he la laa e hookani ai i na pu, he houluulu hoano:   
\q1
\v 25 Mai hana i ka hana e luhi ai, aka e kaumaha i ka mohai puhi ia Iehova.   
\b  
\q1
\v 26 Olelo mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 27 A i ka umi o ka la o ua malama ahiku nei, he la kalahala; he houluulu hoano ia no oukou, a e hookaumaha oukou i ko oukou mau uhane, a e kaumaha i ka mohai puhi ia Iehova.   
\q1
\v 28 Aole hana a oukou e hana'i i ua la la; no ka mea, he la kalahala ia, e hana'i i kalahala no oukou ma ke alo o Iehova ko oukou Akua.   
\q1
\v 29 O kela uhane keia uhane i hookaumaha ole ia i ua la la, e okiia'ku ia maiwaena aku o kona poe kanaka.   
\q1
\v 30 A o kela kanaka keia kanaka e hana i ka hana i ua la la, o ia kanaka ka'u e hooki aku ai maiwaena aku o kona poe kanaka.   
\q1
\v 31 Mai hana iki oukou i ka hana: he kanawai mau loa i ko oukou mau hanauna iloko o ko oukou mau hale a pau.   
\q1
\v 32 E lilo ia i Sabati e hoomaha ai, a e hookaumaha oukou i ko oukou mau uhane; i ka iwa o ka la o ka malama, i ke ahiahi, mai ke ahiahi a hiki i ke ahiahi, e malama ai oukou i ko oukou Sabati.   
\b  
\q1
\v 33 Olelo mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 34 E olelo aku oe i na mamo a Iseraela, penei, I ka la umikumamalima o ua malama ahiku nei, he ahaaipa kauhalelewa i na la ehiku no Iehova.   
\q1
\v 35 I ka la mua, he houluulu hoano, mai hana oukou i ka hana e luhi ai.   
\q1
\v 36 I na la ehiku e kaumaha ai oukou i ka mohai puhi ia Iehova: i ka walu o ka la he houluulu hoano ia oukou, a e kaumaha oukou i ka mohai puhi ia Iehova, he anaina hoano, aole hoi oukou e hana i ka hana e luhi ai.   
\b  
\q1
\v 37 Oia na ahaaina a Iehova, a oukou e hai aku ai he mau houluulu hoano, e kaumaha ai i ka mohai puhi ia Iehova, i ka mohaikuni, i ka mohaiai, i ka alana a me na mohaiinu, kela mea keia mea i kona la iho:   
\q1
\v 38 Okoa na Sabati o Iehova; okoa hoi ko oukou mea haawi; okoa hoi ka oukou mau mea hoohiki a pau; okoa hoi ka oukou mau mohai na ka makemake, a oukou e haawi wale ia Iehova.   
\b  
\q1
\v 39 A i ka la umikumamalima o ka malama ahiku, aia houluulu oukou i ka hua o ka aina, e ahaaina oukou no Iehova i na la ehiku; i ka la mua, he Sabati, a i ka la awalu, he Sabati.   
\q1
\v 40 E lawe hoi oukou no oukou iho i ka la mua i na lala o na laau maikai, i na lala o na laau pama, a me na lala o na laau momona, a me na wilou o ke kahawai; a e hauoli ae oukou ma ke alo o Iehova ko oukou Akua i na la ehiku.   
\q1
\v 41 E malama oukou ia i ahaaina no. Iehova, i na la ehiku o ka makahiki; he kanawai mau loa i ko oukou mau hanauna; i ka hiku o ka malama e ahaaina ai oukou ia.   
\q1
\v 42 E noho oukou iloko o na halelalalaau i na la ehiku; o na mea a pau i hanau he poe Iseraela, e noho no lakou iloko o ua halelalalaau:   
\q1
\v 43 I ike ko oukou mau hanauna, ua hoonoho au i na mamo a Iseraela iloko o na halelalalaan, i ka wa i lawe mai ai au ia lakou mai ka aina mai o Aigupita: owau no Iehova ko oukou Akua.   
\q1
\v 44 A hai aku la o Mose i na ahaaina a Iehova i na mamo a Iseraela.   
\c 24  
\b  
\q1
\v 1 OLELO mai la o Iehova ia Mose, i mai la,   
\q1
\v 2 E kauoha oe i na mamo a Iseraela, e lawe mai ia oe i ka aila oliva maemae i kuiia, i malamalama, e mau ai ka aa ana o na ipukukui.   
\q1
\v 3 Mawaho o ka paku o ka mea hoike, iloko o ka halelewa o ke anaina, e hooponopono mau ai o Aarona ia mai ke ahiahi a kakahiaka ma ke alo o Iehova; he kanawai mau ia i ko oukou mau hanauna.   
\q1
\v 4 E hooponopono mau oia i na kukui maluna o ka ipukukui maemae imua o Iehova.   
\b  
\q1
\v 5 A e lawe oe i ka palaoa wali, a e hoomoa i na popo ona he umikumamalua; elua hapaumi dila iloko o ka popo hookahi.   
\q1
\v 6 A e hoonoho oe ia mau mea ma na lalani elua, eono i ka lalani hookahi, maluna o ka papa maemae, ma ke alo o Iehova.   
\q1
\v 7 A e kau aku oe i ka mea ala maemae maluna o na lalani, i kau ia maluna o ka berena i mea hoomanao, he mohai puhi no Iehova.   
\q1
\v 8 I kela Sabati keia Sabati e hoonoho mau ai oia ia mea ma ke alo o Iehova, na na mamo mai a Iseraela, ma ka berita mau loa.   
\q1
\v 9 E lilo hoi ia na Aarona a na kana mau keiki, a e ai lakou ia ma kahi hoano; no ka mea, he hoano loa ia nona, no na mohai puhi no Iehova ma ke kanawai mau loa.   
\b  
\q1
\v 10 A o ke keiki a ka wahine o ka Iseraela, he kanaka Aigupita kona makuakane, ua hele ae ia iwaena o na mamo a Iseraela: a o keia keiki a ka Iseraela, a me kekahi kanaka Iseraela, ua hakaka pu i kahi hoomoana;   
\q1
\v 11 A ua hoino wale ke keiki a ka wahine Iseraela, i ka Inoa, a ua kuamuamu hoi; a lawe mai lakou ia ia io Mose la: (o Selomita ka inoa o kona makuwahine, ke kaikamahine a Diberi, no ka ohana a Dana:)   
\q1
\v 12 Hahao ae la lakou ia ia i kahi e paa ai, i hoikeia mai ka manao o Iehova ia lakou.   
\q1
\v 13 Olelo mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 14 E lawe ae i ka mea kuamuamu mawaho ae o kahi hoomoana; a o ka poe a pau i lohe, e kau ko lakou mau lima maluna o kona poo, a e hailuku ke anaina a pau ia ia.   
\q1
\v 15 E olelo hoi oe i na mamo a Iseraela, penei, O kela kanaka keia kanaka i kuamuamu i kona Akua, e kau no kona hewa maluna ona iho.   
\q1
\v 16 A o ka mea hoino wale i ka ihoa o Iehova, e make io no ia; e hailuku io aku ke anaina a pau ia ia; o ka malihini, e like pu me ke kamaaina, i ka wa e hoino ai i ka Inoa, e make no ia.   
\b  
\q1
\v 17 A o ka mea pepehi i ke kanaka, e make io no ia.   
\q1
\v 18 A o ka mea pepehi i ka holoholona, e hoihoi aku no oia i holoholona no ka holoholona.   
\q1
\v 19 Ina haawi ke kanaka i kona hoalauna i kina iloko o kona kino, e like me kana hana ana aku, pela no e hanaia mai ai ia;   
\q1
\v 20 He eha no ka eha, he maka no ka maka, he niho no ka niho: me kana i haawi ai i ke kanaka i kina iloko ona, pela no e hanaia'e ai ia.   
\q1
\v 21 O ka mea pepehi i ka holoholona, e hoihoi no oia ia; a o ka mea pepehi i ke kanaka, e make ia.   
\q1
\v 22 I hookahi kanawai ko oukou no ka malihini, a no ka mea o ko oukou aina iho; no ka mea, owau no Iehova ko oukou Akua.   
\b  
\q1
\v 23 Olelo ae la o Mose i na mamo a Iseraela, e lawe ae i ka mea kuarauamu iwaho o kahi hoomoana, a e hailuku aku ia ia me na pohaku; hana iho la ua mamo a Iseraela e like me ke kauoha a Iehova ia Mose.   
\c 25  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose ma ka mauna Sinai, i mai la,   
\q1
\v 2 E olelo aku oe i na mamo a Iseraela, a e i aku ia lakou, Aia komo oukou i ka aina a'u e haawi aku nei ia oukou, alaila e malama ka aina i ka Sabati no Iehova.   
\q1
\v 3 I na makahiki eono e lulu hua ai oe ma kau mahinaai, a i na makahiki eono e paipai ai oe i kou malawaina, a e ohi hoi i kona hua.   
\q1
\v 4 Aka o ka hiku o ka makahiki, e lilo ia i Sabati e hoomaha ai no ka aina, i Sabati no Iehova; mai lulu hua oe ma kau mahinaai, aole hoi oe e paipai i kou malawaina,   
\q1
\v 5 O ka mea ulu wale no kau ai, mai okioki oe ia, aole hoi e ohi i na hua waina o kou kumu waina paipai ole ia; he makahiki ia e hoomaha ai no ka aina.   
\q1
\v 6 A o ka Sabati o ka aina he ai na oukou, nau, a na kau kauwa, a na kau kaikamahine, a na kau kauwa hoolimalimaia, a na kou malihini e noho pu ana me oe,   
\q1
\v 7 A na kau mau holoholona, me na holoholona ma kou aina, he ai kona hua a pau,   
\b  
\q1
\v 8 A e helu oe i na Sabati makahiki ehiku nou, i ehiku hiku mau makahiki, a o ka wa o na Sabati makahiki ehiku, he kanahakumamaiwa mau makahiki nou.   
\q1
\v 9 Alaila e hookani ai oe i ka pu Iubile, i ka la umi o ka malama ahiku, i ka la kalahala, e hookani ai oukou i ka pu ma ko oukou aina a puni.   
\q1
\v 10 A e hoano oukou i ke kanalima o ka makahiki, a e hai aku i ke kuu wale ana a puni ka aina, i ka poe a pau e noho ana ilaila; e lilo ia i Iubile ia oukou, a e hoi oukou kela kanaka keia kanaka i kona aina iho, a e hoi oukou kela kanaka keia kanaka i kona ohana iho.   
\q1
\v 11 He Iubile auanei ia makahiki kanalima ia oukou. Mai lulu hua oukou, aole hoi e okioki i ka mea ulu wale ia makahiki, aole hoi e ohi i ko ke kumuwaina paipai ole ia.   
\q1
\v 12 No ka mea, he Iubile ia, e hoano auanei ia ia oukou; mailoko mai o ka mahinaai, e ai ai oukou i kona hua.   
\b  
\q1
\v 13 I ka makahiki o ua Iubile nei, e hoi ai oukou kela kanaka keia kanaka i kona aina iho.   
\b  
\q1
\v 14 Ina e kuai lilo aku oe i kekahi mea i kou hoalauna, a ina kuai lilo mai oe i kekahi mea mai ka lima mai o kou hoalauna, mai noho oukou a hooluhi hewa kekahi i kekahi.   
\q1
\v 15 E like me ka helu o na makahiki mahope ae o ka Iubile, e kuai lilo mai me kou hoalauna, a e like me ka helu o na makahiki o na hua, a kuai lilo aku oia ia oe.   
\q1
\v 16 Mamuli o ka nui o na makahiki e hoonui ai oe i ke kumu kuai o ia mea; a mamuli o ka uuku o na makahiki, e houuku ai i kona kumu kuai; no ka mea, ma ka helu o na makahiki hua, e kuai lilo aku ai oia ia oe.   
\q1
\v 17 Nolaila, mai hooluhihewa kekahi i kekahi, aka e weliweli oe i kou Akua: owau no Iehova ko oukou Akua.   
\b  
\q1
\v 18 No ka mea, e hana oukou ma ka'u kauoha, a e malama hoi i ko'u mau kanawai, a e hana ma ia mau mea; a e noho no oukou ma ka aina me ka maluhia.   
\q1
\v 19 A e hoohua mai ka aina i kona mau hua, a e ai oukou a maona, a e noho maluhia oukou ilaila.   
\q1
\v 20 A ina olelo oukou, He aha la ka kakou mea e ai ai, i ka hiku o ka makahiki? aia hoi, aole kakou e luluhua, aole hoi e houluulu i ko kakou mau hua;   
\q1
\v 21 Alaila e kauoha ai au i ka'u hoomaikai ana mai una o oukou i ke ono o ka makahiki, a e hoohua mai ia i ka hua no na makahiki ekolu;   
\q1
\v 22 A i ka walu o ka makahiki e lulu hua ai oukou, a e ai no i ka hua kahiko, a hiki i ka iwa o ka makahiki; a komo mai na hua ona, e ai no oukou i ka mea kahiko.   
\b  
\q1
\v 23 Aole e kuai lilo mau ia aku ka aina; no ka mea, no'u no ka aina, no ka mea hoi, he poe malihini oukou, e noho malihini ana me au nei.   
\q1
\v 24 A ma ka aina a pau o oukou, e haawi aku oukou e kuai hou ia ka aina.   
\b  
\q1
\v 25 Ina i ilihune ae kou hoahanau, a ua kuai lilo aku i kauwahi o kona aina, a hele mai kekahi o kona poe hoahanau, e kuai hou, alaila e kuai lilo mai oia i ka mea a kona hoahanau i kuai lilo aku.   
\q1
\v 26 A ina aole o ke kanaka mea nana e kuai lilo hou mai, a e hiki ia ia iho ke kuai lilo hou mai;   
\q1
\v 27 Alaila e helu oia i na makahiki o kona lilo ana i ke kuaiia, a hoihoi aku i ke koena i ke kanaka ia ia ka aina ana i kuai lilo aku ai; i hoi ai oia i kona aina iho.   
\q1
\v 28 Aka ina e hiki ole ia ia ke hoihoi aku ia mea, alaila ka mea i kuai lilo aku e waiho no ia iloko o ka lima o ka mea kuai lilo mai ia mea, a hiki i ka makahiki Iubile; ae hemo ia i ka Iubile, a hoi oia i kona aina iho.   
\b  
\q1
\v 29 A ina e kuai lilo aku kekahi kanaka i ka hale noho maloko o ke kulanakauhale paa i ka pa, alaila e hiki ia ia ke kuai lilo hou mai maloko o ia makahiki okoa, mahope iho o ke kuai lilo ana'ku. Ia makahiki a puni e pono ia ia ke kuai lilo hou mai.   
\q1
\v 30 A ina i ole e kuai lilo mai ia iloko o ka wa e puni ai ka makahiki, alaila ka hale iloko o ke kulanakauhale paa i ka pa, e hoomau loa ia i ka mea nana i kuai lilo mai, i kona mau hanauna; aole ia e hemo i ka labile.   
\q1
\v 31 Aka o na hale ma na kauhale aole i puni i ka pa, e heluia lakou e like me na mahinaai o ka aina; e hiki no ia lakou ke kuai lilo hou ia mai, a e hemo no i ka lubile.   
\q1
\v 32 Aka o na kulanakauhale o ka Levi a me na hale o lakou, e hiki no i na pua a Levi ke kuai lilo hou mai i kela manawa keia manawa,   
\q1
\v 33 Ina e kuai lilo mai kekahi i ko na pua a Levi, alaila ka hale i kuai lilo ia aku, a me ke kulanakauhale ona, e hemo no ia i ka lubile; no ka mea, o na hale o na kulanakauhale o ka poe pua a Levi, o ko lakou waiwai no ia iwaena o na mamo a Iseraela.   
\q1
\v 34 Aka o ka mahinaai e pili ana i ko lakou kulanakauhale, aole ia i kuai lilo ia'ku: no ka mea, o ko lakou waiwai mau no ia.   
\b  
\q1
\v 35 A ina na lilo kou hoahanau i ilihune, a ua nawaliwali ae la kona lima, alaila e kokua oe ia ia; ina hoi he malihini, a he mea noho malihini, i ola pu ia me oe.   
\q1
\v 36 Mai lawe oe i ka uku kuala ona, aole hoi i ka mahuahua ana: aka e weliweli oe i kou Akua, i hiki i kou hoahanau ke ola pu me oe.   
\q1
\v 37 Aole oe e haawi lilo ole ae i kau moni, no ka uku kuala, aole hoi e haawi i kau ai ia ia no ka hoonui ia.   
\q1
\v 38 Owau no o Iehova o ko oukou Akua, ka mea i lawe mai ia oukou mai ka aina mai o Aigupita, e haawi ia oukou i ka aina o Kanaana, i Akua au no oukou.   
\b  
\q1
\v 39 A ina i ilihune ae kou hoahanau, e noho kokoke ana me oe, a kuai lilo ia'ku ia nou, aole oe e hoohana ia ia nou me he kauwa paa la:   
\q1
\v 40 Aka me he paaua la, a, me he mea noho malihini la, e noho ai oia me oe, a e hookauwa oia nau a hiki i ka makahiki Iubile.   
\q1
\v 41 Alaila e hele aku oia, mai ou aku la, oia pu me kana mau keiki me ia, a e hoi aku no i kana ohana, a i ka aina o kona mau makua.   
\q1
\v 42 No ka mea, he mau kauwa na'u lakou, a'u i lawe mai nei mai ka aina mai o Aignpita; aole lakou e kuai lilo ia aku me he mau kauwa paa la.   
\q1
\v 43 Aole oe e hoohaku maluna ona me ke oolea, aka e weliweli oe i kou Akua.   
\q1
\v 44 O kau mau kauwa kaue paa, a me kau mau kauwa wahine paa, i lilo ia oe, no na lahuikanaka e puni ana ia oe lakou; no lakou mai e kuai oukou i mau kauwakane paa, a i mau kauwawahine paa.   
\q1
\v 45 A no na keiki a na malihini e noho malihini ana iwaena o oukou, no lakou e kuai ai oukou, a no ko lakou mau ohana me oukou, i loaa ia lakou ma ko oukou aina; a e lilo lakou i waiwai nau.   
\q1
\v 46 A e lawe hoi oukou ia lakou i waiwai na ka oukou mau keiki mahope o oukou, e ili iho i waiwai ua lakou; aet lilo lakou i kauwa mau na oukou; aka, maluna o ko oukou mau hoahanau, na mamo a Iseraela, aole e hoohaku kekahi maluna o kekahi mo ke oolea.   
\b  
\q1
\v 47 A ina e waiwai nui ae ka mea noho, a o ka malihini me oe, a e ilihune ae kou hoahanau e noho kokoke ana me ia, a kuai lilo aku oia ia ia iho i ka malihini, a i ka mea noho ma ou la, a i ka pua paha o ka ohana a ka malihini;   
\q1
\v 48 Mahope o kona kuai lilo ia'ku, e hiki ke kuai lilo hou ia mai. E hiki i kekahi o kona mau hoahanau ke kuai lilo hou mai.   
\q1
\v 49 E pono i ka hoahanau o kona makuakane, a me ke keiki a ka hoahanau o kona makuakane, ke kuai lilo hou mai, a e hiki i kekahi o kona io iho, no kona ohana iho, ke kuai lilo hou mai ia ia; a ina e hiki i kona lima iho, he pono no ke kuai hou mai oia ia ia iho.   
\q1
\v 50 A e kuka pu oia me ka mea nana ia i kuai lilo mai, mai ka makahiki mai i kuai lilo ia'ku ai oia ia ia, a hiki i ka makahiki Iubile, a o ke kumu kuai ona e hoolikeia ia me ka helu o na makahiki, e like me ka wa o ka paaua, pela no ia ia.   
\q1
\v 51 Ina he nui ua makahiki i koe, e like me ia e haawi ai oia i ke kumu kuai, e kuai lilo hou mai, mailoko mai o ka moni i kuai lilo ia mai ai oia.   
\q1
\v 52 A ina he uuku na makahiki i koe a hiki i ka makahiki lubile, alaila e helu pu me ia, a e like me na makahiki, e haawi hou ai oia ia ia i ke kumu kuai, e kuai lilo hou ia mai ai oia.   
\q1
\v 53 Me he paaua la i hoolimalimaia ma ka makahiki e noho ai oia me ia; aole nae e hoohaku maluna ona me ko oolea mamua o kou mau maka.   
\q1
\v 54 A ina i ole e kuai lilo hou ia mai, ma ia mau mea, alaila e hele aku no ia i ka makahiki Iubile, oia pu me kana mau keiki me ia.   
\q1
\v 55 No ka mea, ia'u nei, he poe kauwa na mamo a Iseraela: o ka'u mau kauwa lakou, a'u i lawe mai nei mai ka aina mai o Aigupita: owau no Iehova ko oukou Akua.   
\c 26  
\b  
\q1
\v 1 MAI hana oukou i na akuakii, a me na kii kalaiia no oukou; aole hoi e kukulu i kii ku, aole hoi e hooka i kii pohaku ma ko oukou aina e kulou iho ia ia; no ka mea, owau no Iehova ko oukou Akua.   
\b  
\q1
\v 2 E malama oukou i ko'u mau Sabati, a e hoano i ko'u keenakapu: owau no Iehova,   
\b  
\q1
\v 3 Ina e hele oukou ma ko'u mau kanawai, a e malama hoi i ka'u mau kauoha, a e hana hoi ma ia mau mea;   
\q1
\v 4 Alaila e haawi aku ai au i ka ua no oukou i ka wa pono, a e haawi mai ka aina i kona mea ulu, a e hoohua mai na laau i ko lakou hua.   
\q1
\v 5 A o ko oukou wa e hahi ai ana e hiki aku ia i ka wa e ohi hua waina ai, a o ka wa e ohi hua waina ai e hiki aku ia i ka wa e lulu hua ai; a e ai oukou i ka oukou berena a maona, a e noho maluhia oukou ma ko oukou aiua.   
\q1
\v 6 A e haawi aku no wau i ka malu ma ko oukou aina, a e moe iho oukou ilalo, aohe mea nana oukou e hooweliweli; ae hoopau aku au i na holoholona ino mailoko aku o ko oukou aina; aole hoi e hele ae ka pahikaua mawaena ae o ko oukou aina,   
\q1
\v 7 E alualu oukou i ko oukou poe enemi, a e haule lakou i ka pahikaua mamua o oukou.   
\q1
\v 8 Elima o oukou e alualu i ka haneri, a he haneri o oukou e hooanhee i na tausani he umi; a e haule ko oukou poe enemi imua o oukou i ka pahikaua.   
\q1
\v 9 No ka mea, e manao aku no au ia oukou, a e hana aku au ia oukou e hua ae, a e hoonui aku au ia oukou, a e hoopaa aku au i kau berita me oukou.   
\q1
\v 10 A e ai oukou i ka mea kahiko, a e lawe mai i ka mea kahiko iwaho, no ka mea hou.   
\q1
\v 11 A e hoonoho au i kuu halelewa iwaena o oukou, aole hoi e hoowahawaha ko'u uhane ia oukou.   
\q1
\v 12 A e hele au iwaena o oukou, a owau no ko oukou Akua, a e noho oukou i kanaka no'u.   
\q1
\v 13 Owau no Iehova ko oukou Akua ka mea nana oukou i lawe mai nei, mai ka aina mai o Aigupita, i ole ai oukou e noho kauwa paa no lakou; a ua moku ia'u na mea e paa ai ka oukou auamo, a hookupono ia oukou i ka hele ana.   
\b  
\q1
\v 14 Aka ina e lohe ole oukou ia'u, aole hoi e hana ma keia mau kauoha a pau;   
\q1
\v 15 A ina e hoowahawaha oukou i ka'u mau kauoha, a e inaina mai ko oukou uhane i ko'u mau kanawai, i ole ai oukou e hana ma ka'u mau kauoha a pau, aka e pale ou kou i ka'u berita;   
\q1
\v 16 Na'u no keia e hana ai ia oukou, e hoomaopopo au maluna o oukou i ka makau, a me ka hokii, a me ka li wela e pau ai na maka, a e ehaeha ai ka naau: a e lulu make hewa oukou i ko oukou hua, no ka mea, na ko oukou mau enemi ia e ai.   
\q1
\v 17 E hooku e hoi au i ko'u maka ia oukou, a e lukuia oukou imua o ko oukou poe enemi: a o ka poe inaina ia oukou e alii ae maluna o oukou, a e auhee oukou i ka alualu ole ai o kekahi ia oukou.   
\q1
\v 18 A ina aole oukou e hoolohe mai ia'u no keia mea, alaila e hoopai pahiku hou aku au ia oukou no ko oukou mau hewa.   
\q1
\v 19 A e wahi aku au i ka haaheo o ko oukou mana; a e hoolilo au i ko oukou lani me he hao la, a i ko oukou honua me he keleawe la.   
\q1
\v 20 A e lilo ko oukou ikaika i ole; no ka mea, aole e haawi mai ko oukou aina i kona mea ulu, aole hoi e hoohua na laau o ka aina i ko lakou mau hua,   
\b  
\q1
\v 21 A ina e hele ku e oukou ia'u, aole hoi e hoolohe mai ia'u, e hooili pahiku hou aku au i na mea ino maiuna o oukou, e like me ko oukou mau hewa.   
\q1
\v 22 E hoouna no hoi au i na holoholona hihiu iwaena o oukou e kaili ae i ka oukou mau keiki, a e luku hoi i ko oukou holoholona, a e houuku ia oukou, a e neoneo ae ko oukou mau alanui.   
\b  
\q1
\v 23 A ina aole oukou e hooponoia e au ma keia mau mea, aka, e hele ku e no oukou ia'u,   
\q1
\v 24 Alaila e hele ku e aku au ia oukou, a e hoopai pahiku aku au ia oukou no ko oukou mau hewa.   
\q1
\v 25 A e lawe au i ka pahikaua maluna o oukou e hoopai ana no ka berita; a akoakoa oukou iloko o ko oukou mau kulanakauhale, e hoouua aku au i ka mai ahulau iwaena o oukou; a e haawiia'ku oukou i ka lima o ka enemi.   
\q1
\v 26 Aia haki ia'u ke kookoo o ka oukou berena, alaila e kahumu na wahine he umi i ka oukou berena ma ka umu hookahi, a e haawi hou lakou i ka oukou berena ia oukou, ma ke kaupaona; a e ai hoi oukou, aole hoi e maona.   
\b  
\q1
\v 27 A ina aole oukou e hoolohe mai ia'u no keia, aka, e hele ku e no oukou ia'u;   
\q1
\v 28 Alaila e hele ku e aku au ia oukou, me ka huhu; a na'u, na'u no oukou e hahau pahiku aku no ko oukou hewa,   
\q1
\v 29 A e ai oukou i ka io o ka oukou mau keikikane, a o ka io no o ka oukou mau kaikamahine ka oukou e ai ai.   
\q1
\v 30 A e hoopau aku au i ko oukou mau wahi kiekie, a e kua iho au i ko oukou mau kii, a e hoolei aku wau i ko oukou mau kupapau maluna iho o na kupapau o ko oukou mau kii a e hoowahawaha aku ko'u uhane ia oukou.   
\q1
\v 31 A e hooneoneo aku au i ko oukou mau kulanakauhale, a e hookae no au i ko oukou mau keenakapu, aole hoi au e honi aku i ke ala o ko oukou mea ala.   
\q1
\v 32 A e hooneoneo aku au i ka aina, a, nolaila e ilihia'i ko oukou poe enemi e noho ana malaila.   
\q1
\v 33 A e hooleilei aku au ia oukou iwaena o na lahuikanaka, a e unuhi ae au i ka pahikaua mahope o oukou; a e neoneo ae ko oukou aina, a e noho ole ia ko oukou mau kulanakauhale.   
\b  
\q1
\v 34 Alaila e loaa i ka aina kona mau Sabati, i kona mau la e neoneo ai, a e noho ai hoi oukou ma ka aina o ko oukou mau enemi; alaila e maha ai ka aina, a e loaa ia ia kona mau Sabati.   
\q1
\v 35 I kona mau la e neoneo ai, e maha no ia; no ka mea, aole ia i maha i ko oukou mau Sabati, ia oukou i noho ai maluna ona.   
\q1
\v 36 A maluna o ko oukou poe e koe ana, e hooili ai au i ka maule ana iloko o ko lakou mau naau, ma na aina o ko lakou mau enemi; a o ka leo o ka lau i puehuia e hooauhee aku ia lakou, a e auhee lakou, me he auhee ana la mai ka pahikaua aku; a haule no lakou i ka wa e ole ai he mea alualu.   
\q1
\v 37 A e hina lakou kekahi maluna o kekahi me he mea la mamua o ka pahikaua, i ka wa e ole ai he mea alualu; aole hoi e hiki iki ia oukou ke ku imua o ko oukou poe enemi.   
\q1
\v 38 A e make oukou mawaena o na lahuikanaka, a e ai no ka aina o ko oukou poe enemi ia oukou.   
\q1
\v 39 A o ke koena o oukou, e mae ae lakou iloko o ko lakou hewa, ma na aina o ko oukou poe enemi; a iloko hoi o ka hewa o ko lakou mau makua lakou e mae pu ai me lakou.   
\b  
\q1
\v 40 Ina e hai mai lakou i ko lakou hewa, a me ka hewa o ko lakou mau makua, a me ka lawehala a lakou i hana hewa mai ai ia'u, a ua hele ku e hoi lakou ia'u;   
\q1
\v 41 A hele ku e hoi au ia lakou, a ua lawo ae hoi ia lakou ma ka aina o ko lakou poe enemi; ina hoi e hoohaahaaia ko lakou mau naau okipoepoe ole ia, a ilaila e ae ai lakou i ka hoopai ana i ko lakou hewa;   
\q1
\v 42 Alaila e hoomanao aku au i kuu berita me Iakoba, a me kuu berita hoi me Isaaka, a me kuu berita hoi me Aberahama ka'u e hoomanao ai, a e hoomanao hoi au i ka aina.   
\q1
\v 43 E haaleleia hoi ka aina e lakou, a e loaa ia ia kona mau Sabati, i kona wa e waiho neoneo ai, aole o lakou; a e ae lakou i ka hoopai ana i ko lakou hewa; no keia, o ko lakou hoowahawaha ana i kuu mau kanawai, a no ko lakou inaina ana i kuu mau kauoha.   
\q1
\v 44 Oia la, aka i ko lakou noho ana ma ka aina o ko lakou poe enemi, aole au e kiola loa ia lakou, aole hoi au e inaina aku ia lakou, e luku loa ai ia lakou, a e uhaki ai i kuu berita me lakou; no ka mea, owau no Iehova ko lakou Akua.   
\q1
\v 45 Aka, no lakou, e hoomanao ai au i ka berita o ko lakou mau kupuna, a'u i lawe mai nei mai ka aina mai o Aigupita imua o na maka o na lahuikanaka, i Akua au no lakou: owau no Iehova.   
\b  
\q1
\v 46 Oia na kapu, a me na kauoha, a me na kanawai a Iehova i haawi mai ai iwaena ona a me na mamo a Iseraela, i ka mauna Sinai, ma ka lima o Mose.   
\c 27  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose i mai la,   
\q1
\v 2 E olelo aku oe i na mamo a Iseraela, a e i aku ia lakou, Aia hoohiki kekahi kanaka i ka mea hoohiki, alaila, no Iehova na kino mamuli o kou manao ana,   
\q1
\v 3 A penei kou manao ana, no ke kane, mai ka makahiki iwakalua a hiki i ka makahiki kanaono ona, o kou manao ana, he kanalima sekela kala, mamuli o ka sekela o ke keenakapu.   
\q1
\v 4 A ina he wahine, alaila o kou manao ana, he kanakolu sekela.   
\q1
\v 5 A ina mai ka makahiki alima ia a hiki i ka makahiki iwakalua ona, alaila, o kou manao ana, no ke kane he iwakalua sekela, a no ka wahine he umi sekela.   
\q1
\v 6 A ina mai ka malama hookahi ia a hiki i ka makahiki alima, alaila o kou manao ana, no ke kane elima sekela kala, a no ka wahine ekolu sekela kala,   
\q1
\v 7 A ina mai ka makahiki kanaono aku ona, alaila, ina he kane, o kou manao, he umikumamalima aekela, a no ka wahine he umi aekela.   
\q1
\v 8 Aka ina i uuku iho kona waiwai i kou mea i manao ai, alaila e hoike oia ia ia iho imua o ke alo o ke kahuna, a e manao ke kahuna ia ia; mamuli o ka mea hiki i kona lima, e manao ai ke kahuna i ka mea i hoohiki.   
\b  
\q1
\v 9 A ina he holoholona i lawe mai ai na kanaka i kauwahi ona i mohai ia Iehova, a ko keia i haawiia no Iehova, e laa no ia.   
\q1
\v 10 Aole oia e hoololi hou ia, aole hoi e kuai oia ia he mea inaikai no ka mea ino, aole hoi i ka mea ino no ka mea maikai; a ina e kuai oia i kekahi holoholona no kekahi holoholona, alaila e laa pu ia me ka holoholona i loaa mai.   
\q1
\v 11 A ina he holoholona haumia i lawe ole ia mai ai kauwahi i mohai ia Iehova, alaila e hoike oia i ka holoholona imua o ke alo o ke kahuna;   
\q1
\v 12 A e manao ae ke kahuna ia ia, he maikai paha, he ino paha, a e like me ka mea i manao ai oe, o ke kahuna, pela no ia.   
\q1
\v 13 Aka ina makemake oia e kuai lilo hou mai ia mea, e hui aku oia i ka hapalima ona me kau mea i manao ai.   
\b  
\q1
\v 14 A ina e hoolaa kekahi kanaka i kona hale i hoano ia ia Iehova, alaila e manao ke kahuna ia mea, ina he maikai paha, ina he ino; a e like me ka manao ana o ke kahuna, pela no ia e ku iho ai.   
\q1
\v 15 A ina makemake ka mea nana ia i hoolaa, e kuai lilo hou mai i kona hale, alaila e hui oia me ia i ka hapalima o ka moni au i manao ai, a e lilo ia nona.   
\b  
\q1
\v 16 A ina e hoolaa ke kanaka i kauwahi o ka mahinaai o kona aina ia Iehova, alaila, mamuli o kona hua kau e manao ai; he homera hua bale, he kanalima sekela kala.   
\q1
\v 17 A ina mai ka makahiki Iubile i hoolaa ai oia i kana mahinaai, alaila e like me kau mea e manao ai, pela no ia e ku iho ai.   
\q1
\v 18 Aka ina i hoolaa oia i kana mahinaai mahope o ka Iubile, alaila e helu ke kahuna i ka moni ia ia e like me na makahiki i koe a hiki i ka makahiki labile, a e laweia'e ia mailoko ae o kau mea i manao ai.   
\q1
\v 19 A ina makemake ka mea nana e hoolaa i ka mahinaai e kuai lilo hou mai ia mea, alaila e hui oia me ia i ka hapalima o ka moni au i manao ai, a e hoomauia ia nona.   
\q1
\v 20 Aka ina aole ia e kuai lilo hou mai ia mahinaai, a ina paha i kuai lilo aku oia ia mahinaai i kekahi kanaka, aole e kuai lilo hou ia mai ia.   
\q1
\v 21 Aka i ka puka ana ae o ka mahinaai i ka Iubile, e laa no ia no Iehova, me he mahinaai i hoolaaia la; e lilo ia i waiwai no ke kahuna.   
\q1
\v 22 A ina e hoolaa aku ke kanaka ia Iehova i ka mahinaai ana i kuai lilo mai, aole no na mahinaai o ko na aina;   
\q1
\v 23 Alaila e helu aku ke kahuna nona i ka waiwai au i manao ai a hiki i ka makahiki Iubile; a e haawi oia, ia la, i kau mea i manao ai, he mea laa ia Iehova.   
\q1
\v 24 I ka makahiki Iubile e hoi aku ka mahinaai i ka mea nona mai ai i ke kuai lilo ia mai, i ka mea nona ka aina mamua.   
\q1
\v 25 A o kou manao ana a pau, ma ke sekela o ke keenakapu ia, iwakalua gera, oia ke sekela.   
\b  
\q1
\v 26 O ka hiapo wale no a na holoholona, ka hiapo no Iehova, aohe kanaka nana ia e hoolaa, ina he bipikauo paha, a ina he hipa paha, no Iehova ia.   
\q1
\v 27 A ina o ka ka holoholona haumia, alaila e kuai lilo hou mai oia ia ia, mamuli o kau mea e manao ai, a e hui me ia i ka hapalima ona: a i ole ia e kuai lilo hou ia mai, alaila e kuai lilo ia aku ia mamuli o kau i manao ai.   
\b  
\q1
\v 28 Aka, o kela mea keia mea laa a ke kanaka i hoolaa ai ia Iehova o kana mau mea a pau, he kanaka, he holoholona, he mahinaai o kona aina, aole ia e kuai lilo ia aku, aole hoi e kuai lilo hou ia mai; o kela mea laa keia mea laa, he hoano loa ia no Iehova.   
\q1
\v 29 Aole mea laa a kanaka i hoolaa ai, e kuai lilo hou ia mai, aka, e make io no ia.   
\b  
\q1
\v 30 A o ka hapaumi a pau o ko ka aina, o ka hua o ka aina, a o ka hua o ka laan, no Iehova ia, he hoano no Iehova.   
\q1
\v 31 A ina makemake ke kanaka e kuai lilo hou mai i ke kauwahi o kona mau hapaumi, e hui oia me ia i ka hapalima ona.   
\q1
\v 32 A no ka hapaumi o ka ohana bipi, a o ka ohana hipa, a o na mea e hele ae malalo ae o ke kookoo, e laa no ka hapaumi ia Iehova.   
\q1
\v 33 Aole ia e huli he maikai paha, he ino paha; aole hoi e kuai oia ia e loaa mai kekahi: a ina e kuai oia ia mea, alaila e laa ia, a me ka mea i loaa mai; aole e kuai lilo hou ia mai.   
\b  
\q1
\v 34 Oia na kauoha a Iehova i kauoha mai ai ia Mose no na mamo a Iseraela, ma ka mauna Sinai.   