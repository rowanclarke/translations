\v 18 Pero Melquisedec, \w rey|strong="H4428"\w* de Salem, \w sacerdote|strong="H3548"\w* del \nd ʼElohim\nd* \w Altísimo|strong="H5945"\w*, \w sacó|strong="H3318"\w* \w pan|strong="H3899"\w* y \w vino|strong="H3196"\w*,  
\v 19 y lo \w bendijo|strong="H1288"\w*:  
\q1 ¡Sea bendecido Abram \w por|strong="H7069"\w* el \nd ʼElohim\nd* \w Altísimo|strong="H5945"\w*,  
\q1 Creador de los \w cielos|strong="H8064"\w* y de la tierra,   
\q1
\v 20 \w Y|strong="H3068"\w* \w bendito|strong="H1288"\w* sea \w el|strong="H3605"\w* \nd ʼElohim\nd* \w Altísimo|strong="H5945"\w*,  
\q1 \w Quien|strong="H3605"\w* \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* tus \w adversarios|strong="H6862"\w* en tu \w mano|strong="H3027"\w*!  
\p \w Y|strong="H3068"\w* \add Abram\add* le \w entregó|strong="H5414"\w* \w el|strong="H3605"\w* diezmo \w de|strong="H5414"\w* \w todo|strong="H3605"\w*.   
\p
\v 21 Entonces el \w rey|strong="H4428"\w* \w de|strong="H5414"\w* \w Sodoma|strong="H5467"\w* dijo \w a|strong="H3068"\w* Abram: \w Dame|strong="H5414"\w* las \w personas|strong="H5315"\w* y \w toma|strong="H3947"\w* \w para|strong="H5414"\w* ti los bienes.   
\p
\v 22 Pero Abram respondió \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de \w Sodoma|strong="H5467"\w*: \w Levanté|strong="H7311"\w* mi \w mano|strong="H3027"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* el \nd ʼElohim\nd* \w Altísimo|strong="H5945"\w*, Creador de los \w cielos|strong="H8064"\w* y de la tierra,  
\v 23 \w que|strong="H3808"\w* \w de|strong="H5704"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* es tuyo, \w no|strong="H3808"\w* \w tomaré|strong="H3947"\w* \w ni|strong="H3808"\w* un hilo \w ni|strong="H3808"\w* una correa \w de|strong="H5704"\w* sandalia \w para|strong="H5704"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* digas: Yo \w enriquecí|strong="H6238"\w* \w a|strong="H3068"\w* Abram,  
\v 24 con la sola excepción de \w lo|strong="H1992"\w* \w que|strong="H1992"\w* comieron \w los|strong="H1992"\w* jóvenes, y la porción de \w Aner|strong="H6063"\w*, Escol y \w Mamre|strong="H4471"\w*, \w los|strong="H1992"\w* hombres \w que|strong="H1992"\w* \w vinieron|strong="H1980"\w* conmigo. \w Solo|strong="H7535"\w* \w ellos|strong="H1992"\w* \w tomarán|strong="H3947"\w* \w su|strong="H1992"\w* \w parte|strong="H2506"\w*.   
\c 15  
\s1 La promesa  
\p
\v 1 \w Después|strong="H1961"\w* \w de|strong="H1697"\w* estas \w cosas|strong="H1697"\w*, la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* Abram en \w visión|strong="H4236"\w*: \wj \+w No|strong="H1961"\+w* \+w temas|strong="H3372"\+w* Abram. \wj*  
\q1 \wj Yo \+w soy|strong="H1961"\+w* tu \+w Escudo|strong="H4043"\+w*. \wj*  
\q1 \wj Tu galardón \+w será|strong="H1961"\+w* \+w muy|strong="H3966"\+w* \+w grande|strong="H7235"\+w*.\wj*   
\p
\v 2 Abram respondió: \nd ʼAdonay\nd*, ¿\w qué|strong="H4100"\w* me \w darás|strong="H5414"\w*? \w Pues|strong="H1931"\w* yo \w ando|strong="H1980"\w* \w sin|strong="H6185"\w* \w hijo|strong="H1121"\w*, y \w el|strong="H1931"\w* heredero \w de|strong="H1121"\w* mi \w casa|strong="H1004"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* damasceno Eliezer.  
\v 3 \w E|strong="H3068"\w* insistió Abram: \w Mira|strong="H2009"\w*, \w no|strong="H3808"\w* me \w has|strong="H5414"\w* \w dado|strong="H5414"\w* descendiente, y \w de|strong="H1121"\w* seguro \w será|strong="H3808"\w* \w mi|strong="H2009"\w* \w heredero|strong="H3423"\w* un esclavo nacido en \w mi|strong="H2009"\w* \w casa|strong="H1004"\w*.   
