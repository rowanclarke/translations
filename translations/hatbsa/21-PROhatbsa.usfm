\id PRO
\h Pwovèb
\toc1 PWOVÈB YO
\toc2 Pwovèb Yo
\toc3 Pwov
\mt1 PWOVÈB YO
\c 1
\p 
\v 1 \x + \xo 1:1 \xt I Wa 4:32\x*Pwovèb Salomon yo, fis a David la, wa Israël la:
\q1 
\v 2 pou konnen sajès avèk enstriksyon,
\q1 Pou dekouvri pawòl \x + \xo 1:2 \xt Pwov 4:1 \x*bon konprann yo,
\q1 
\v 3 Pou \x + \xo 1:3 \xt Pwov 2:1\x*resevwa enstriksyon nan jan pou aji ak sajès,
\q1 ladwati, jistis, menm jan pou tout moun;
\q1 
\v 4 Pou \x + \xo 1:4 \xt Pwov 8:5-12\x*avèti san konprann yo e bay konesans ak pridans a jenn yo.
\q1 
\v 5 Yon nonm saj va tande, va grandi nan konesans li
\q1 e yon \x + \xo 1:5 \xt Pwov 14:6 \x*nonm bon konprann va twouve konsèy ki saj,
\q1 
\v 6 Pou konprann yon pwovèb ak mo kache, pawòl a saj yo avèk \x + \xo 1:6 \xt Nonb 12:8\x*devinèt yo.
\b
\q1 
\v 7 \x + \xo 1:7 \xt Job 28:28\x*Lakrent SENYÈ a se kòmansman sajès la;
\q1 sila ki plen foli, meprize sajès ak lenstriksyon.
\q1 
\v 8 Tande byen, fis mwen an, lenstriksyon papa ou,
\q1 e \x + \xo 1:8 \xt Pwov 6:20 \x*pa abandone leson a manman ou yo;
\q1 
\v 9 Anverite, yo fè yon \x + \xo 1:9 \xt Jen 41:42\x*kouwòn byen bèl sou tèt ou,
\q1 ak yon bèl dekorasyon nan kou ou.
\q1 
\v 10 Fis mwen an, si pechè yo vin tante ou, \x + \xo 1:10 \xt Jen 39:7-10\x*pa dakò.
\q1 
\v 11 Si yo di: “Vini avèk nou, annou \x + \xo 1:11 \xt Pwov 12:6\x*kouche yon pyèj pou san,
\q1 annou fè anbiskad pou inosan yo san koz;
\q1 
\v 12 Annou \x + \xo 1:12 \xt Sòm 124:3\x*vale yo vivan tankou Sejou mò yo,
\q1 menm an antye tankou sila k ap desann nan fòs yo.
\q1 
\v 13 Nou va jwenn tout kalite byen presye,
\q1 nou va ranpli lakay nou ak piyaj.
\q1 
\v 14 Tire osò pa ou ansanm ak nou.
\q1 Nou tout va gen yon sèl bous”—
\q1 
\v 15 Fis mwen an, \x + \xo 1:15 \xt Sòm 1:1\x*pa mache nan chemen avèk yo.
\q1 Anpeche pye ou antre sou wout yo,
\q1 
\v 16 Paske \x + \xo 1:16 \xt Pwov 6:17-18\x*pye yo kouri jwenn mal,
\q1 e yo fè vit pou yo vèse san.
\q1 
\v 17 Anverite, se initil pou ouvri yon filè ak pen gaye
\q1 devan nenpòt kalite zwazo;
\q1 
\v 18 men yap kouche yon pyèj pou pwòp san pa yo.
\q1 \x + \xo 1:18 \xt Pwov 11:19\x* Yo fè anbiskad pou pwòp lavi pa yo.
\q1 
\v 19 Se konsa tout chemen yo ye a pou
\q1 tout moun ki \x + \xo 1:19 \xt Pwov 15:27\x*vin genyen pa mwayen vyolans.
\q1 Se pwòp lavi yo kap vin rache.
\b
\q1 
\v 20 \x + \xo 1:20 \xt Pwov 8:1-3\x*Sajès rele fò nan lari.
\q1 Li leve vwa li nan plas la.
\q1 
\v 21 Nan tèt lari ki gen zen yo, li kriye fò.
\q1 Nan antre pòtay lari yo,
\q1 li fè moun tande tout pawòl li yo:
\q1 
\v 22 “Jiskilè, O moun san bon konprann yo,
\q1 nou va renmen rete san konprann anyen?
\q1 Pou mokè yo rejwi yo nan moke moun e
\q1 moun san konprann yo rayi konesans?
\q1 
\v 23 Vire sou repwòch mwen an.
\q1 Gade byen, mwen \x + \xo 1:23 \xt És 32:15\x*va vide lespri m sou nou.
\q1 Mwen va fè nou konnen pawòl mwen yo.
\q1 
\v 24 Akoz mwen te rele nou e nou te refize;
\q1 mwen te \x + \xo 1:24 \xt És 65:2 \x*lonje men m, e pèsòn pa t okipe sa,
\q1 
\v 25 men nou te neglije tout konsèy mwen yo,
\q1 e nou \x + \xo 1:25 \xt Pwov 15:10 \x*pa t vle tande repwòch mwen;
\q1 
\v 26 konsa, mwen menm anplis, va ri sou malè nou yo.
\q1 Mwen va moke nou lè \x + \xo 1:26 \xt Pwov 10:24 \x*gran laperèz la rive,
\q1 
\v 27 lè gran laperèz nou rive tankou tanpèt
\q1 e gwo dezas nou yo tankou \x + \xo 1:27 \xt Pwov 10:25\x*toubiyon,
\q1 lè gwo pwoblèm ak soufrans rive sou nou.
\q1 
\v 28 Nan lè sa a, yo va rele m, men mwen p ap reponn.
\q1 Yo va \x + \xo 1:28 \xt Pwov 8:17\x*chache mwen avèk dilijans, men yo p ap twouve m,
\q1 
\v 29 akoz yo te \x + \xo 1:29 \xt Job 21:14\x*rayi konesans
\q1 e pa t chwazi gen lakrent SENYÈ a.
\q1 
\v 30 Yo te refize konsèy mwen.
\q1 Yo te rejte tout repwòch mwen yo.
\q1 
\v 31 Pou sa, yo va \x + \xo 1:31 \xt Job 4:8\x*manje fwi a pwòp chemen yo,
\q1 e vant yo va vin plen ak pwòp manèv yo.
\q1 
\v 32 Paske \x + \xo 1:32 \xt Jr 2:19\x* chemen kwochi a moun
\q1 san konprann yo va touye yo.
\q1 Kè kontan a sila ki plen foli va detwi yo.
\q1 
\v 33 Men sila ki koute mwen an
\q1 va viv ansekirite,
\q1 e li va rete alèz san pè malè.”
\c 2
\q1 
\v 1 Fis mwen an, si ou resevwa pawòl mwen yo,
\q1 e \x + \xo 2:1 \xt Pwov 3:1\x*gade kòmandman mwen yo nan kè ou,
\q1 
\v 2 e \x + \xo 2:2 \xt Pwov 22:17\x*fè zòrèy ou atantif a sajès;
\q1 e enkline zòrèy ou vè bon konprann,
\q1 
\v 3 wi, si ou leve vwa w pou sajès;
\q1 e leve vwa ou vè bon konprann;
\q1 
\v 4 si ou chache li kon ajan,
\q1 e fè rechèch dèyè li kon trezò \x + \xo 2:4 \xt Job 3:21\x*ki kache;
\q1 
\v 5 nan lè sa a, ou va dekouvri \x + \xo 2:5 \xt Pwov 1:7\x*lakrent SENYÈ a,
\q1 e dekouvri konesans Bondye a.
\q1 
\v 6 Paske, \x + \xo 2:6 \xt I Wa 3:12\x*SENYÈ a bay sajès.
\q1 Nan bouch Li, soti konesans ak bon konprann.
\q1 
\v 7 Li mete sajès nan depo pou moun dwat la.
\q1 Li se \x + \xo 2:7 \xt Sòm 84:11\x*boukliye pou sila ki mache ak entegrite yo,
\q1 
\v 8 K ap veye chemen lajistis yo,
\q1 e \x + \xo 2:8 \xt I Sam 2:9\x*pwoteje chemen a fidèl Li yo.
\q1 
\v 9 Konsa, ou va dekouvri \x + \xo 2:9 \xt Pwov 8:20\x*ladwati ak jistis,
\q1 e menm egalite avèk tout bon chemen yo.
\q1 
\v 10 Paske, sajès va antre nan kè ou,
\q1 e \x + \xo 2:10 \xt Pwov 22:18 \x*konesans va fè ou alèz jis rive nan nanm ou.
\q1 
\v 11 Bon konprann va \x + \xo 2:11 \xt Pwov 4:6\x*pwoteje ou,
\q1 konesans va veye sou ou,
\q1 
\v 12 pou \x + \xo 2:12 \xt Pwov 28:26\x*pwoteje ou kont chemen mal la,
\q1 kont lòm ki pale bagay pèvès yo.
\q1 
\v 13 Kont sila ki \x + \xo 2:13 \xt Pwov 21:16\x*kite chemen ladwati yo
\q1 pou mache nan chemen fènwa yo;
\q1 
\v 14 ki \x + \xo 2:14 \xt Pwov 10:23\x*pran plezi nan fè sa ki mal
\q1 e rejwi nan mechanste mal la.
\q1 
\v 15 Chemen a sila ki vin \x + \xo 2:15 \xt Sòm 125:5\x*kwochi yo
\q1 e ki vin gaye kò yo nan tout sa yo fè.
\q1 
\v 16 Pou delivre ou soti nan men fanm etranje a,
\q1 soti nan men \x + \xo 2:16 \xt Pwov 23:27\x*fanm adiltè ki flate ak pawòl li;
\q1 
\v 17 ki kite \x + \xo 2:17 \xt Mat 2:14-15\x*konpanyen jenès li a,
\q1 e ki bliye akò a Bondye li;
\q1 
\v 18 paske lakay li mennen a lanmò
\q1 e tras a pla pye li yo rive kote mò yo.
\q1 
\v 19 Pèsòn \x + \xo 2:19 \xt Ekl 7:26\x*ki ale kote li menm, pa retounen ankò,
\q1 ni yo pa jwenn pa lavi.
\q1 
\v 20 Akoz sa a, ou va \x + \xo 2:20 \xt Eb 6:12\x*mache nan chemen a sila ki bon yo,
\q1 e swiv tras a moun ladwati yo.
\q1 
\v 21 Paske moun dwat yo va viv nan peyi a,
\q1 e \x + \xo 2:21 \xt Pwov 28:10 \x*sila ki san tò yo va rete ladann;
\q1 
\v 22 men mechan yo va koupe retire nèt de peyi a,
\q1 e moun trèt yo va \x + \xo 2:22 \xt Det 28:63 \x*dechouke de li.
\c 3
\q1 
\v 1 Fis mwen an, \x + \xo 3:1 \xt Sòm 119:61\x*pa bliye enstriksyon mwen an,
\q1 men kite kè ou kenbe kòmandman Mwen yo;
\q1 
\v 2 paske konsa, longè jou, ane lavi ak lapè yo
\q1 va vin ogmante sou ou.
\q1 
\v 3 Pa kite \x + \xo 3:3 \xt II Sam 15:20\x*dousè ak verite kite ou.
\q1 Mare yo antoure kou ou.
\q1 Ekri yo sou tablo kè ou.
\q1 
\v 4 Konsa, ou va twouve favè avèk \x + \xo 3:4 \xt Sòm 111:10\x*bon repitasyon
\q1 nan men Bondye a, ak moun.
\q1 
\v 5 \x + \xo 3:5 \xt Sòm 37:3-5\x*Mete konfyans nan SENYÈ a ak tout kè ou;
\q1 pa apiye sou pwòp bon konprann pa w.
\q1 
\v 6 Nan tout chemen ou yo rekonèt Li;
\q1 konsa Li va \x + \xo 3:6 \xt És 45:13\x*fè pa ou yo vin dwat.
\q1 
\v 7 \x + \xo 3:7 \xt Wo 12:16\x*Pa vin saj nan pwòp zye pa ou;
\q1 krent SENYÈ a e vire kite mal.
\q1 
\v 8 Li va sèvi kon yon \x + \xo 3:8 \xt Pwov 4:22\x*gerizon pou kò ou,
\q1 ak rafrechisman a zo ou.
\q1 
\v 9 Onore SENYÈ a ak sa ki soti nan bonte ou yo;
\q1 ak \x + \xo 3:9 \xt Egz 23:19 \x*premye pati nan tout prodwi ou,
\q1 
\v 10 pou \x + \xo 3:10 \xt Det 28:8\x*depo ou yo kab vin plen ak abondans,
\q1 e pou sitèn ou yo plen ak diven tounèf.
\q1 
\v 11 \x + \xo 3:11 \xt Job 5:17\x*Fis mwen an, pa rejte disiplin SENYÈ a,
\q1 ni rayi repwòch Li,
\q1 
\v 12 Paske \x + \xo 3:12 \xt Rev 3:19\x*sila ke SENYÈ a renmen an, Li korije li,
\q1 jis tankou yon papa konn korije
\q1 fis nan sila li pran plezi a.
\b
\q1 
\v 13 \x + \xo 3:13 \xt Pwov 8:32-34\x*A la beni nonm ki twouve sajès,
\q1 e nonm ki vin genyen bon konprann nan beni!
\q1 
\v 14 Paske \x + \xo 3:14 \xt Job 28:15-19\x*avantaj li pi bon ke avantaj ajan,
\q1 e pwofi li pi bon ke lò fen.
\q1 
\v 15 Li \x + \xo 3:15 \xt Job 28:18\x*pi presye pase bijou;
\q1 e okenn lòt bagay ke ou ta dezire pa kab konpare avèk li.
\q1 
\v 16 Lavi ki long va trouve nan men dwat li.
\q1 Nan men goch li se \x + \xo 3:16 \xt Pwov 8:18 \x*richès ak lonè.
\q1 
\v 17 \x + \xo 3:17 \xt Mat 11:29\x*Chemen li yo byen dous,
\q1 e tout pa li yo se lapè.
\q1 
\v 18 Li se yon \x + \xo 3:18 \xt Jen 2:9\x*pyebwa lavi a sila ki pran l yo,
\q1 e byen kontan se tout sila ki kenbe l fèm yo.
\q1 
\v 19 SENYÈ a \x + \xo 3:19 \xt Sòm 104:24\x*ak sajès te fonde latè a;
\q1 ak bon konprann Li te etabli syèl yo.
\q1 
\v 20 Ak konesans Li, \x + \xo 3:20 \xt Jen 7:11\x*fon yo te vin ouvri,
\q1 e syèl yo te vin degoute lawouze.
\q1 
\v 21 Fis mwen an, pa kite yo vin disparèt devan zye ou;
\q1 kenbe bon sajès ak bon konprann.
\q1 
\v 22 Konsa yo va \x + \xo 3:22 \xt Det 32:47\x*lavi pou nanm ou
\q1 ak dekorasyon pou kou ou.
\q1 
\v 23 Konsa, ou va mache nan chemen ou ak sekirite,
\q1 e pye ou p ap \x + \xo 3:23 \xt Sòm 91:12 \x*chape.
\q1 
\v 24 Lè ou \x + \xo 3:24 \xt Job 11:9\x*kouche ou p ap pè;
\q1 kouche ou ak dòmi ou va byen dous.
\q1 
\v 25 Pa pè gwo laperèz ki parèt sibitman,
\q1 ni atak a mechan an lè l vini.
\q1 
\v 26 Paske Bondye va konfyans ou,
\q1 e va \x + \xo 3:26 \xt I Sam 2:9\x*veye pye ou pou l pa pran nan pyèj.
\b
\q1 
\v 27 \x + \xo 3:27 \xt Wo 13:7\x*Pa refize fè byen a sila ki merite l yo,
\q1 si se nan kapasite ou pou fè l.
\q1 
\v 28 Pa di vwazen ou: “Ale e retounen pita”,
\q1 oswa “Demen, m ap bay ou”, lè l deja nan men w.
\q1 
\v 29 \x + \xo 3:29 \xt Pwov 6:14\x*Pa kalkile mal kont vwazen ou
\q1 pandan l ap viv an sekirite akote ou.
\q1 
\v 30 Pa fè kont ak yon nonm san koz,
\q1 depi li pa konn fè ou tò.
\q1 
\v 31 \x + \xo 3:31 \xt Sòm 37:1\x*Pinga ou gen anvi a yon nonm vyolan,
\q1 ni pa chwazi chemen li yo.
\q1 
\v 32 Moun pèvès se yon abominasyon a SENYÈ a;
\q1 men SENYÈ a \x + \xo 3:32 \xt Job 29:4 \x*vin toupre a sila yo ki dwat yo.
\q1 
\v 33 Malediksyon SENYÈ a sou kay mechan yo,
\q1 men Li \x + \xo 3:33 \xt Job 8:6 \x*beni abitasyon a moun dwat yo.
\q1 
\v 34 \x + \xo 3:34 \xt Jc 4:6\x*Li moke moun k ap moke,
\q1 men Li bay gras a sila ki aflije yo.
\q1 
\v 35 \x + \xo 3:35 \xt Dan 12:3\x*Saj yo va resevwa gran respè kon eritaj,
\q1 men moun plen foli yo va dezonore.
\c 4
\q1 
\v 1 Tande, O fis yo, \x + \xo 4:1 \xt Sòm 34:11\x*enstriksyon a yon papa,
\q1 e fè atansyon pou ou kab reyisi jwenn bon konprann,
\q1 
\v 2 Paske mwen bay ou bon konsèy;
\q1 \x + \xo 4:2 \xt Sòm 89:30 \x*pa abandone enstriksyon mwen.
\q1 
\v 3 Lè m te yon jenn timoun ak papa m,
\q1 byen jenn e \x + \xo 4:3 \xt Za 12:10\x*sèl fis devan zye a manman m,
\q1 
\v 4 Alò, li te \x + \xo 4:4 \xt Ef 6:4\x*enstwi mwen e te di mwen:
\q1 “Kite kè ou kenbe fèm a pawòl mwen;
\q1 kenbe lòd mwen yo pou ou viv.
\q1 
\v 5 Vin ranmase sajès!
\q1 \x + \xo 4:5 \xt Pwov 16:16\x*Ranmase bon konprann!
\q1 Pa bliye, ni pa vire kite pawòl a bouch mwen yo.
\q1 
\v 6 Pa abandone li e li va pwoteje ou;
\q1 \x + \xo 4:6 \xt II Tim 2:10\x*renmen li e li va veye sou ou.
\q1 
\v 7 Men sa ki kòmansman sajès la:
\q1 \x + \xo 4:7 \xt Pwov 23:23\x*Ranmase sajès!
\q1 Epi avèk sa ou rasanble a,
\q1 chache bon konprann.
\q1 
\v 8 \x + \xo 4:8 \xt I Sam 2:30\x*Mete valè li wo e li va fè ou leve;
\q1 li va bay ou onè si ou anbrase l.
\q1 
\v 9 Li va poze \x + \xo 4:9 \xt Pwov 1:9\x*sou tèt ou yon kouwòn lagras;
\q1 li va prezante ou avèk yon kouwòn byen bèl.”
\b
\q1 
\v 10 Tande, fis mwen an, \x + \xo 4:10 \xt Pwov 2:1\x*vin dakò ak pawòl mwen yo,
\q1 e lane lavi ou yo va vin byen long.
\q1 
\v 11 Mwen te \x + \xo 4:11 \xt I Sam 12:23\x*dirije ou nan chemen sajès la;
\q1 mwen te kondwi ou nan pa ladwati yo.
\q1 
\v 12 Lè ou mache, pa ou yo p ap jennen;
\q1 epi si ou kouri, \x + \xo 4:12 \xt Sòm 91:11 \x*ou p ap glise tonbe.
\q1 
\v 13 \x + \xo 4:13 \xt Pwov 3:18\x*Pran enstriksyon; pa lage menm.
\q1 Pwoteje li paske li se lavi ou.
\q1 
\v 14 \x + \xo 4:14 \xt Sòm 1:1\x*Pa antre nan chemen mechan yo,
\q1 e pa avanse nan vwa malfektè yo.
\q1 
\v 15 Evite li, pa pase kote li;
\q1 vire kite li e ale byen lwen.
\q1 
\v 16 Paske, yo p ap kab dòmi si yo pa fè mal;
\q1 epi dòmi vin vòlè soti nan zye yo
\q1 si yo pa fè lòt glise tonbe.
\q1 
\v 17 Paske yo \x + \xo 4:17 \xt Pwov 13:2\x*manje pen a malveyan yo
\q1 e bwè diven vyolans.
\q1 
\v 18 Men pa a moun dwat yo se tankou limyè granmmaten
\q1 ki \x + \xo 4:18 \xt Dan 12:3 \x* briye pi fò e pi fò jiskaske li vin fè jou nèt.
\q1 
\v 19 \x + \xo 4:19 \xt Job 18:5-6\x*Chemen mechan yo tankou tenèb;
\q1 yo pa konnen sou kisa pou yo tonbe.
\b
\q1 
\v 20 Fis mwen an, \x + \xo 4:20 \xt Pwov 5:1\x*prete atansyon a pawòl mwen yo;
\q1 panche zòrèy ou vè diskou mwen yo.
\q1 
\v 21 Pa kite yo vin disparèt devan zye ou;
\q1 \x + \xo 4:21 \xt Pwov 7:1-2\x*kenbe yo nan fon kè ou.
\q1 
\v 22 Paske yo se \x + \xo 4:22 \xt Pwov 3:22\x*lavi a sila ki jwenn yo,
\q1 ak lasante a tout kò yo.
\q1 
\v 23 Veye sou kè ou ak tout dilijans;
\q1 paske \x + \xo 4:23 \xt Mat 12:34\x*de li, sous lavi yo koule.
\q1 
\v 24 Mete lwen de ou yon bouch manti
\q1 e \x + \xo 4:24 \xt Pwov 19:1 \x*mete tout pawòl foub byen lwen ou.
\q1 
\v 25 Kite zye ou gade tou dwat devan
\q1 e kite vizyon ou konsantre devan nèt.
\q1 
\v 26 \x + \xo 4:26 \xt Pwov 5:21\x*Veye wout pye ou konn pran
\q1 e tout chemen ou yo va byen etabli.
\q1 
\v 27 \x + \xo 4:27 \xt Det 5:32\x*Pa vire ni adwat ni agoch;
\q1 fè pye ou vire kite mal.
\c 5
\q1 
\v 1 Fis mwen an, fè atansyon a sajès mwen,
\q1 \x + \xo 5:1 \xt Pwov 22:17\x*apiye zòrèy ou vè bon konprann mwen;
\q1 
\v 2 pou ou kab kenbe sajès
\q1 e pou \x + \xo 5:2 \xt Mal 2:7 \x*lèv ou ka konsève konesans.
\q1 
\v 3 Paske lèv a fanm adiltè a degoute siwo,
\q1 e pale li \x + \xo 5:3 \xt Sòm 55:21 \x*pi dous pase lwil;
\q1 
\v 4 men a lafen, li vin anmè pase kou fyèl,
\q1 epi file kon yon nepe ki koupe de bò.
\q1 
\v 5 Pye li yo \x + \xo 5:5 \xt Pwov 7:27\x*desann vè lanmò
\q1 e pa li yo kenbe fèm nan chemen Sejou mò yo.
\q1 
\v 6 Li pa reflechi sou pa lavi a;
\q1 vwa li yo pa stab; \x + \xo 5:6 \xt Pwov 30:20 \x*li pa rekonèt bagay sa a.
\b
\q1 
\v 7 Alò, fis mwen yo, koute mwen,
\q1 e \x + \xo 5:7 \xt Sòm 119:102\x*pa bliye pawòl a bouch mwen yo.
\q1 
\v 8 Kenbe wout ou byen lwen li, e
\q1 pa pwoche toupre \x + \xo 5:8 \xt Pwov 9:14 \x*pòt lakay li.
\q1 
\v 9 Oswa ou va bay fòs ou a lòt yo
\q1 ak ane ou yo a mechan an.
\q1 
\v 10 Konsa, etranje yo va ranpli ak fòs ou,
\q1 e byen yo ke ou te ranmase ak swè ou,
\q1 va rive lakay a yon etranje.
\q1 
\v 11 Epi ou va plenyen nan gòj
\q1 lè dènye moman lavi ou rive,
\q1 lè chè ou ak kò ou fin manje nèt.
\q1 
\v 12 Ou va di: “Ki jan mwen te \x + \xo 5:12 \xt Pwov 1:7-29\x*rayi enstriksyon!
\q1 Ak “Ki jan kè m te rayi repwòch!
\q1 
\v 13 Mwen pa t koute vwa a sa yo kap enstwi m yo,
\q1 ni mwen pa t panche zòrèy mwen vè \x + \xo 5:13 \xt Pwov 1:8\x*mèt mwen yo.
\b
\q1 
\v 14 Mwen te prèt pou fini nèt nan mitan asanble a ak kongregasyon an.”
\q1 
\v 15 Bwè dlo nan pwòp sitèn pa ou e dlo fre nan pwi pa ou.
\q1 
\v 16 Èske \x + \xo 5:16 \xt Pwov 5:18\x*sous ou yo dwe dispèse nan peyi etranje,
\q1 kon vwa dlo k ap kouri nan lari yo?
\q1 
\v 17 Kite yo pou ou sèl, e pa pou etranje yo avèk ou yo.
\q1 
\v 18 Kite fontèn dlo ou a rete beni,
\q1 e rejwi ou nan madanm a jenès ou a.
\q1 
\v 19 Tankou yon sèf amourez ak yon bich elegan,
\q1 kite tete li yo satisfè ou tout tan.
\q1 Rete debòde nèt ak lanmou li.
\q1 
\v 20 Paske poukisa fis mwen an,
\q1 ou ta dwe renmen ak yon fanm adiltè,
\q1 e anbrase lestonmak a yon \x + \xo 5:20 \xt Pwov 2:16\x*etranje?
\q1 
\v 21 Paske chemen a yon nonm se devan zye a SENYÈ a,
\q1 e Li \x + \xo 5:21 \xt Pwov 4:26\x*veye tout pa li yo.
\q1 
\v 22 \x + \xo 5:22 \xt Nonb 32:23\x*Pwòp inikite a mechan an va kaptire li.
\q1 Li va kole nan kòd a pwòp peche pa li.
\q1 
\v 23 Li va \x + \xo 5:23 \xt Job 4:21\x*mouri akoz mank enstriksyon,
\q1 e nan grandè foli li, li va vin egare.
\c 6
\q1 
\v 1 Fis mwen an, si ou devni \x + \xo 6:1 \xt Pwov 11:15\x*garanti dèt pou vwazen ou,
\q1 ou te fè pwomès pou yon lòt ki pa pa w.
\q1 
\v 2 Ou te tonbe nan pèlen akoz pawòl a bouch ou,
\q1 ou te kenbe menm, akoz pawòl bouch ou yo.
\q1 
\v 3 Alò fè sa, fis mwen an, pou delivre tèt ou.
\q1 Akoz ou te vin antre nan men a vwazen ou an,
\q1 ale desann pou jennen vwazen ou an.
\q1 
\v 4 Pa kite \x + \xo 6:4 \xt Sòm 132:4\x*dòmi tonbe nan zye ou,
\q1 ni somèy rive sou pòpyè zye ou.
\q1 
\v 5 Chape tèt ou kon yon antilòp nan men a chasè,
\q1 oswa \x + \xo 6:5 \xt Sòm 91:3\x*zwazo a nan pèlen moun lachas la.
\b
\q1 
\v 6 Ale kote \x + \xo 6:6 \xt Pwov 30:24-25\x*foumi, o parese.
\q1 Veye abitid li yo e vin saj!
\q1 
\v 7 Li menm, \x + \xo 6:7 \xt Pwov 30:27\x* san pa gen chèf, ni ofisye, ni mèt,
\q1 
\v 8 konn prepare manje li \x + \xo 6:8 \xt Pwov 10:5\x*nan gran sezon an
\q1 e ranmase pwovizyon li nan rekòlt la.
\q1 
\v 9 Pou konbyen de tan ou va kouche konsa O parese?
\q1 Se kilè ou va leve soti nan dòmi?
\q1 
\v 10 \x + \xo 6:10 \xt Pwov 24:33\x*Yon ti dòmi, yon ti somèy,
\q1 yon ti pliye men ou yo pou repoze;
\q1 
\v 11 \x + \xo 6:11 \xt Pwov 24:34\x*mizè ou va vin parèt sou ou tankou yon vagabon,
\q1 e nesesite ou tankou yon nonm k ap pote zam.
\b
\q1 
\v 12 Yon sanzave, yon moun mechan
\q1 se sila ki mache ak yon \x + \xo 6:12 \xt Pwov 4:24 \x*bouch pèvès,
\q1 
\v 13 ki \x + \xo 6:13 \xt Job 15:12\x*bat zye li, ki fè siy ak pye li,
\q1 ki pwente ak dwèt li;
\q1 
\v 14 ki avèk pèvèsite nan kè l
\q1 fè tout tan sa ki mal,
\q1 ki \x + \xo 6:14 \xt Pwov 6:19 \x*gaye konfli.
\q1 
\v 15 Pou sa, \x + \xo 6:15 \xt Pwov 24:22\x*malè li va parèt sibitman;
\q1 nan yon enstan li va kase nèt;
\q1 e li p ap gen gerizon ditou.
\b
\q1 
\v 16 Gen sis bagay ke SENYÈ a rayi;
\q1 wi sèt menm ki abominab devan l:
\q1 
\v 17 Zye ògeye, \x + \xo 6:17 \xt Sòm 31:18\x*yon lang k ap bay manti,
\q1 avèk men ki vèse san inosan,
\q1 
\v 18 Yon kè ki divize plan mechan yo,
\q1 \x + \xo 6:18 \xt Pwov 1:16 \x*pye ki kouri vit pou jwenn mal,
\q1 
\v 19 Yon \x + \xo 6:19 \xt Sòm 27:1\x*fo temwen ki bay manti,
\q1 ak yon moun ki gaye konfli pami frè yo.
\b
\q1 
\v 20 \x + \xo 6:20 \xt Ef 6:1\x*Fis mwen an, swiv lòd a papa ou
\q1 e pa abandone enstriksyon manman ou.
\q1 
\v 21 \x + \xo 6:21 \xt Pwov 3:3\x*Mare yo tout tan sou kè ou;
\q1 mare yo nan kou ou.
\q1 
\v 22 Lè ou \x + \xo 6:22 \xt Pwov 3:23\x*mache toupatou, yo va gide ou.
\q1 Lè ou dòmi, yo va veye sou ou.
\q1 Epi lè ou leve, yo va pale avèk ou.
\q1 
\v 23 Paske \x + \xo 6:23 \xt Sòm 19:8\x*kòmandman an se yon lanp,
\q1 e enstriksyon li se limyè.
\q1 Konsa, repwòch ki disipline a se chemen lavi a
\q1 
\v 24 pou \x + \xo 6:24 \xt Pwov 5:3\x*anpeche ou rive nan fanm movèz vi a,
\q1 a lang glise de fanm adiltè a.
\q1 
\v 25 \x + \xo 6:25 \xt Mat 5:28\x*Pa dezire bote li nan kè ou,
\q1 ni kite li kapte ou avèk pòpyè zye li.
\q1 
\v 26 Paske akoz yon pwostitiye,
\q1 yon gason redwi a yon mòso pen.
\q1 Yon fanm adiltè fè lachas lavi presye.
\q1 
\v 27 Èske yon nonm kab mete dife poze antre janm li yo
\q1 pou rad li pa brile?
\q1 
\v 28 Oswa èske yon nonm kab mache sou chabon limen,
\q1 san ke pye l pa brile?
\q1 
\v 29 Se konsa li ye ak yon nonm ki
\q1 \x + \xo 6:29 \xt Éz 18:6\x*antre nan madanm vwazen li.
\q1 Nenpòt moun ki manyen l p ap sòti san pinisyon.
\q1 
\v 30 Pèsòn pa meprize yon vòlè
\q1 k ap vòlè pou l kab \x + \xo 6:30 \xt Job 38:39\x*satisfè grangou.
\q1 
\v 31 Men si pa aza, li jwenn li, l ap oblije
\q1 \x + \xo 6:31 \xt Egz 22:1-4\x*repeye li sèt fwa.
\q1 Lap oblije bay tout sa li posede lakay li.
\q1 
\v 32 Sila ki fè adiltè ak yon fanm manke sajès;
\q1 nonm nan ki fè sa a, \x + \xo 6:32 \xt Pwov 7:22-23\x* detwi pwòp nanm li.
\q1 
\v 33 L ap twouve blesi ak gwo wont,
\q1 e repwòch li p ap efase menm.
\q1 
\v 34 Paske \x + \xo 6:34 \xt Pwov 27:4\x*jalouzi fè laraj nan yon nonm;
\q1 li p ap fè gras nan jou vanjans lan.
\q1 
\v 35 Li p ap dakò dedonmaje ak ranson,
\q1 ni li p ap satisfè malgre ou fè li anpil kado.
\c 7
\q1 
\v 1 Fis mwen an, \x + \xo 7:1 \xt Pwov 2:1\x*kenbe pawòl mwen yo
\q1 e kache kòmandman mwen yo anndan ou.
\q1 
\v 2 Kenbe kòmandman mwen yo pou viv,
\q1 ak enstriksyon mwen yo
\q1 \x + \xo 7:2 \xt Det 32:10\x*kon de grenn zye nan tèt ou.
\q1 
\v 3 Mare yo sou dwèt ou;
\q1 \x + \xo 7:3 \xt Pwov 3:3\x*ekri yo sou tablo a kè ou.
\q1 
\v 4 Di a sajès: “Se ou ki sè mwen,”
\q1 e rele sajès pi bon zanmi ou,
\q1 
\v 5 Pou li kab anpeche ou ale
\q1 jwenn ak yon fanm adiltè;
\q1 yon fanm etranje a ki fè flate ak pawòl li.
\q1 
\v 6 Paske bò fenèt lakay mwen,
\q1 mwen te gade \x + \xo 7:6 \xt Pwov 6:32 \x*nan fant fenèt mwen an.
\q1 
\v 7 Konsa, mwen te wè pami moun \x + \xo 7:7 \xt Pwov 1:22\x*sòt yo,
\q1 e te rekonèt pami jenn yo,
\q1 yon jennonm ki te manke bon sans;
\q1 
\v 8 ki t ap pase nan lari a toupre
\q1 kwen kay fanm nan.
\q1 Konsa, li pran chemen pou rive \x + \xo 7:8 \xt Pwov 7:27\x*lakay li,
\q1 
\v 9 nan solèy kouche a, nan aswè,
\q1 nan mitan lannwit ak nan fènwa.
\q1 
\v 10 Epi gade, yon fanm vin pwoche li
\q1 \x + \xo 7:10 \xt Jen 38:14-15\x*abiye kon pwostitiye ak riz nan kè l.
\q1 
\v 11 Li parèt plen kouraj nan rebelyon li.
\q1 \x + \xo 7:11 \xt I Tim 5:13\x*Pye li pa rete lakay li.
\q1 
\v 12 Koulye a nan lari yo, koulye a nan plas yo,
\q1 l ap \x + \xo 7:12 \xt Pwov 23:28\x*kache tann nan tout kwen.
\q1 
\v 13 Konsa, li sezi li, bo li;
\q1 e ak \x + \xo 7:13 \xt Pwov 21:29\x*figi byen ranje, li di li:
\q1 
\v 14 “Mwen te prèt pou ale fè ofrann lapè yo.
\q1 Se jodi a, mwen \x + \xo 7:14 \xt Lev 7:16 \x*fin peye ve mwen yo.
\q1 
\v 15 Konsa, mwen te vin rankontre ou,
\q1 pou jwenn prezans ou;
\q1 e konsa, mwen te twouve ou.
\q1 
\v 16 Mwen byen ranje kabann mwen ak kouvèti;
\q1 avèk bèl \x + \xo 7:16 \xt És 19:9\x*dra Égypte yo.
\q1 
\v 17 Mwen te flite kabann nan ak pafen
\q1 flè jasmen, lwil womaren ak \x + \xo 7:17 \xt Egz 30:23 \x*kanèl.
\q1 
\v 18 Vini, annou bwè ladann
\q1 e fè lanmou jis rive nan maten.
\q1 Annou fè kè nou kontan ak doudous nou yo.
\q1 
\v 19 Paske mari m pa lakay la;
\q1 li ale nan yon gran vwayaj.
\q1 
\v 20 Li te pran yon sak lajan avè l.
\q1 Jis rive nan plèn lin, l ap retounen lakay.”
\q1 
\v 21 Ak anpil ankourajman, li atire li;
\q1 avèk \x + \xo 7:21 \xt Pwov 5:3\x*lèv a flatè, li sedwi li.
\q1 
\v 22 Sibitman, li swiv li tankou
\q1 yon bèf k ap monte labatwa,
\q1 tankou moun sòt
\q1 k ab mache rive nan ne koulan an.
\q1 
\v 23 Jiskaske yon flèch frennen li nan fwa l;
\q1 tankou yon \x + \xo 7:23 \xt Ekl 9:12\x*zwazo k ap fè vit pou rive nan pèlen.
\q1 Se konsa, li pa konnen ke sa va koute lavi li.
\b
\q1 
\v 24 Alò, pou sa, fis yo, \x + \xo 7:24 \xt Pwov 5:7\x*koute mwen
\q1 e okipe pawòl a bouch mwen yo.
\q1 
\v 25 Pa kite kè ou \x + \xo 7:25 \xt Pwov 5:8\x*vire akote nan chemen li yo!
\q1 Pa vin antre egare nan wout li yo!
\q1 
\v 26 Paske, anpil se viktim ke li deja jete anba yo;
\q1 e \x + \xo 7:26 \xt Pwov 9:18\x*anpil se sila ki te mouri akoz li.
\q1 
\v 27 \x + \xo 7:27 \xt Pwov 2:18\x*Lakay li nan wout Sejou mò yo,
\q1 k ap desann nan chanm lanmò yo.
\c 8
\q1 
\v 1 Èske \x + \xo 8:1 \xt Pwov 1:20-21\x*sajès pa rele?
\q1 Èske bon konprann pa leve vwa li?
\q1 
\v 2 Anlè \x + \xo 8:2 \xt Pwov 9:3-14\x*wotè akote chemen yo, akote kafou wout yo;
\q1 la li pran pozisyon li.
\q1 
\v 3 Akote \x + \xo 8:3 \xt Job 29:7\x*pòtay yo, nan ouvèti vil la,
\q1 nan antre pòtay yo, li kriye fò:
\q1 
\v 4 Vè nou menm, O mesye yo, mwen rele!
\q1 Konsa, vwa m se pou fis a lòm yo.
\q1 
\v 5 O moun ensanse yo, vin aprann pridans!
\q1 \x + \xo 8:5 \xt Pwov 1:22-32 \x*Moun fou yo, vin konprann sajès!
\q1 
\v 6 Koute mwen, paske mwen va pale gwo bagay.
\q1 Lè lèv mwen louvri, \x + \xo 8:6 \xt Pwov 23:16 \x*y ap devwale bagay ki kòrèk.
\q1 
\v 7 Paske \x + \xo 8:7 \xt Sòm 37:30\x*bouch mwen va eksprime verite;
\q1 epi mechanste vin abominab a lèv mwen.
\q1 
\v 8 Tout pawòl a bouch mwen yo dwat;
\q1 nanpwen anyen \x + \xo 8:8 \xt Det 32:5\x*kwochi oswa pèvès ladann yo.
\q1 
\v 9 Yo byen dwat pou sila ki konprann nan,
\q1 e kòrèk pou sila ki \x + \xo 8:9 \xt Pwov 3:13 \x*jwenn konesans lan.
\q1 
\v 10 Pran \x + \xo 8:10 \xt Pwov 3:14-15\x*konsèy mwen olye ajan,
\q1 e konesans olye pi chwa nan lò pi.
\q1 
\v 11 Paske, sajès \x + \xo 8:11 \xt Job 28:15-18\x*pi bon ke bijou;
\q1 epi tout pi bèl bagay yo p ap kab konpare avè l.
\b
\q1 
\v 12 Mwen se sajès. Mwen rete avèk bon konprann.
\q1 Konsa, mwen fè jwenn \x + \xo 8:12 \xt Pwov 1:4\x*konesans ak bon sans.
\q1 
\v 13 \x + \xo 8:13 \xt Pwov 3:7\x*Lakrent SENYÈ a se pou rayi mal,
\q1 ansanm ak ògèy, awogans, ak yon bouch pèvès.
\q1 
\v 14 \x + \xo 8:14 \xt Pwov 1:25\x*Konsèy ak bon sajès se pou mwen.
\q1 Entèlijans se non mwen. Pouvwa se pa m.
\q1 
\v 15 Akoz mwen, \x + \xo 8:15 \xt II Kwo 1:10\x*wa yo vin renye;
\q1 e gouvènè yo fè dekrè lajistis.
\q1 
\v 16 Akoz mwen, prens ak nòb yo pran pouvwa;
\q1 tout moun ki fè jijman ki bon yo.
\q1 
\v 17 Mwen renmen sila ki renmen m yo.
\q1 \x + \xo 8:17 \xt Pwov 2:4-5 \x*Sila ki chache mwen ak dilijans yo va jwenn mwen.
\q1 
\v 18 \x + \xo 8:18 \xt Pwov 3:16\x*Richès ak lonè avè m;
\q1 richès k ap dire ak ladwati.
\q1 
\v 19 Fwi mwen \x + \xo 8:19 \xt Job 28:15\x*pi bon ke lò, menm lò pi.
\q1 Rannman mwen pi bon ke pi bèl ajan an.
\q1 
\v 20 Mwen mache nan ladwati,
\q1 nan mitan wout lajistis yo,
\q1 
\v 21 Pou m bay a sila ki renmen m, richès;
\q1 pou m kab \x + \xo 8:21 \xt Pwov 24:4\x*ranpli kès yo.
\b
\q1 
\v 22 SENYÈ a te posede m \x + \xo 8:22 \xt Job 28:26-28\x*nan kòmansman travay pa Li;
\q1 menm avan zèv ansyen Li yo.
\q1 
\v 23 Depi nan etènite, mwen te etabli,
\q1 depi nan kòmansman, \x + \xo 8:23 \xt Jn 17:5 \x*depi nan tan pi ansyen mond lan.
\q1 
\v 24 Lè potko gen \x + \xo 8:24 \xt Jen 1:2\x*pwofondè, mwen te fèt,
\q1 lè pa t gen sous ki t ap bonbade dlo yo.
\q1 
\v 25 \x + \xo 8:25 \xt Job 15:7\x*Avan mòn yo te poze, avan kolin yo,
\q1 mwen te fèt;
\q1 
\v 26 pandan li potko fè tè a ak chan yo,
\q1 ni premye grenn pousyè mond lan.
\q1 
\v 27 Lè Li te etabli syèl yo, mwen te la,
\q1 lè \x + \xo 8:27 \xt Job 26:10 \x*Li te trase yon sèk won fas a pwofondè a,
\q1 
\v 28 lè Li te fè syèl yo anwo vin fèm,
\q1 lè sous nan fon yo te vin etabli,
\q1 
\v 29 lè Li te mete lizyè sou lanmè a pou dlo pa t vyole lòd Li,
\q1 lè Li te make tras \x + \xo 8:29 \xt Job 38:6\x*fondasyon tè a;
\q1 
\v 30 Nan tan sa a, mwen te akote Li,
\q1 yon mèt ouvriye; epi, mwen te fè L plezi tout lajounen
\q1 e te rejwi devan L tout tan,
\q1 
\v 31 Mwen t ap Rejwi nan mond Li a,
\q1 e fè \x + \xo 8:31 \xt Sòm 16:3\x*kè kontan nan fis a lòm yo.
\b
\q1 
\v 32 “Alò, pou sa, fis yo, \x + \xo 8:32 \xt Pwov 5:7\x*koute mwen;
\q1 paske beni se sila ki kenbe chemen mwen yo.
\q1 
\v 33 \x + \xo 8:33 \xt Pwov 4:1\x*Koute lenstriksyon pou ou vin saj e pa neglije l.
\q1 
\v 34 \x + \xo 8:34 \xt Pwov 3:13-18\x*Beni se moun ki koute mwen an,
\q1 k ap veye chak jou nan pòtay mwen yo,
\q1 k ap veye kote poto pòt kay mwen an.
\q1 
\v 35 Paske sila ki twouve mwen an, jwenn lavi
\q1 e resevwa lonè devan SENYÈ a.
\q1 
\v 36 Men sila ki peche kont mwen an, fè pwòp tèt li mal;
\q1 tout sila ki rayi mwen yo, \x + \xo 8:36 \xt Pwov 21:6 \x*renmen lanmò.”
\c 9
\q1 
\v 1 Sajès \x + \xo 9:1 \xt Kol 3:9-10\x*bati kay li a;
\q1 li taye sèt gwo pilye li yo.
\q1 
\v 2 Li te \x + \xo 9:2 \xt Mat 22:4\x*prepare manje li,
\q1 li te mele diven li; anplis, li fin ranje tab li.
\q1 
\v 3 Li \x + \xo 9:3 \xt Sòm 68:11\x*voye demwazèl li yo deyò,
\q1 li rele soti nan anlè wotè pwent vil yo:
\q1 
\v 4 “Pou sila ki ensanse a, kite li antre isit la!”
\q1 Pou sila ki \x + \xo 9:4 \xt Pwov 6:32 \x*manke bon konprann nan, li di:
\q1 
\v 5 “Vin \x + \xo 9:5 \xt Kan 5:1\x*manje manje mwen an,
\q1 e bwè diven ke m te melanje a.
\q1 
\v 6 Kite foli ou pou ou ka viv;
\q1 epi \x + \xo 9:6 \xt Éz 11:20\x*avanse nan chemen bon konprann nan.”
\b
\q1 
\v 7 Sila ki \x + \xo 9:7 \xt Pwov 23:9\x*korije yon mokè resevwa dezonè pou pwòp tèt li,
\q1 e sila ki repwoche yon nonm mechan
\q1 va resevwa ofans sou tèt li.
\q1 
\v 8 Pa repwoche yon mokè, sinon li va rayi ou;
\q1 \x + \xo 9:8 \xt Sòm 141:5\x*repwoche yon nonm saj e li va renmen ou.
\q1 
\v 9 Bay konsèy a yon nonm saj e li va vin pi saj,
\q1 enstwi yon nonm dwat e li va \x + \xo 9:9 \xt Pwov 1:5\x*ogmante konesans li.
\q1 
\v 10 \x + \xo 9:10 \xt Job 28:28\x*Lakrent SENYÈ a se kòmansman a sajès
\q1 e konesans a Sila Ki Sen an se bon konprann.
\q1 
\v 11 Paske \x + \xo 9:11 \xt Pwov 3:16\x*pa mwen, jou ou yo va miltipliye,
\q1 e ane yo ap ogmante sou lavi ou.
\q1 
\v 12 Si ou saj, ou saj \x + \xo 9:12 \xt Job 22:2\x*pou pwòp tèt ou;
\q1 e si ou moke, ou pote sa a pou kont ou.
\b
\q1 
\v 13 Fanm sòt \x + \xo 9:13 \xt Pwov 7:11\x*pale byen fò ak gwo vwa;
\q1 li bèt, e li pa konnen anyen.
\q1 
\v 14 Li chita devan pòtay lakay li,
\q1 sou yon chèz akote \x + \xo 9:14 \xt Pwov 9:3\x*wo plas vil yo.
\q1 
\v 15 Li rele sila ki pase yo,
\q1 ki ap fè chemen yo dwat yo:
\q1 
\v 16 \x + \xo 9:16 \xt Pwov 9:4\x*Sila ki pa konnen anyen an,
\q1 kite li antre isit la.
\q1 Pou sila ki manke konprann nan, li di:
\q1 
\v 17 “Dlo yo vòlè dous
\q1 e \x + \xo 9:17 \xt Pwov 20:17\x*pen ki manje an sekrè byen agreyab.”
\q1 
\v 18 Men mesye a pa konnen ke se la mò yo ye a.
\q1 Vizitè li yo la.
\q1 Yo nan fon Sejou mò yo.
\c 10
\q1 
\v 1 Pwovèb a Salomon yo.
\q1 Yon fis ki saj fè papa li kontan,
\q1 men yon fis ki plen ak foli
\q1 se yon gwo doulè pou manman l.
\q1 
\v 2 \x + \xo 10:2 \xt Sòm 49:7\x*Richès ranmase pa mechanste pa reyisi,
\q1 men ladwati delivre soti nan lanmò.
\q1 
\v 3 SENYÈ a p ap kite moun ladwati yo grangou,
\q1 men l ap rejte lanvi mechan an.
\q1 
\v 4 Malere se sila ki travay ak men lach;
