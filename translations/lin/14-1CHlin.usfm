\id 1CH Biblica® Open Lingala Contemporary Bible 2020 
\h 1 Masolo ya Kala 
\toc1 1 Masolo ya Kala 
\toc2 1 Masolo ya Kala 
\toc3 1Ma 
\mt1 1 Masolo ya Kala 
\c 1  
\ms1 Milongo ya mbotama 
\s1 Longwa na Adamu kino na Semi 
\li4  
\v 1 Adamu, Seti, Enoshi,  
\v 2 Kenani, Maalalele, Yeredi,  
\v 3 Enoki, Metusalemi, Lemeki,  
\v 4 Noa, Semi, Cham mpe Jafeti. 
\b  
\li1  
\v 5 Bana mibali ya Jafeti : 
\li2 Gomeri, Magogi, Madayi, Yavani, Tubali, Mesheki mpe Tirasi. 
\li1  
\v 6 Bana mibali ya Gomeri : 
\li2 Ashikenazi, Difati mpe Togarima. 
\li1  
\v 7 Bana mibali ya Yavani : 
\li2 Elisha, Tarsisi, Kitimi mpe Dodanimi. 
\li1  
\v 8 Bana mibali ya Cham : 
\li2 Kushi, Mitsirayimi, Puti mpe Kanana. 
\li1  
\v 9 Bana mibali ya Kushi : 
\li2 Seba, Avila, Sabita, Raema mpe Sabiteka. 
\li1 Bana mibali ya Raema : 
\li2 Sheba mpe Dedani. 
\li1  
\v 10 Kushi azalaki tata 
\li2 ya Nimirodi oyo azalaki elombe ya liboso ya bitumba kati na mokili. 
\li1  
\v 11 Mitsirayimi azalaki koko 
\li2 ya bato ya Ludi, ya Anami, ya Leabi, ya Nafitu,  
\v 12 ya Patrusi, ya Kasilu (oyo babimisa bato ya Filisitia) mpe ya Kereti. 
\li1  
\v 13 Kanana azalaki tata 
\li2 ya Sidoni, mwana na ye ya liboso, ya Eti,  
\v 14 ya Yebusi, ya Amori, ya Girigazi,  
\v 15 ya Evi, ya Ariki, ya Sini,  
\v 16 ya Arivadi, ya Tsemari mpe ya Amati. 
\li1  
\v 17 Bana mibali ya Semi : 
\li2 Elami, Asuri, Aripakishadi, Ludi mpe Arami. 
\li1 Bana mibali ya Arami : 
\li2 Utsi, Uli, Geteri mpe Mesheki. 
\li1  
\v 18 Aripakishadi abotaki Shela, 
\li2 mpe Shela abotaki Eberi. 
\li1  
\v 19 Eberi abotaki bana mibali mibale ; 
\li2 moko, kombo na ye ezalaki « Pelegi » oyo elingi koloba : Kokabola ; pamba te ezalaki na tango na ye nde bakabolaki mabele. Kombo ya mwana mosusu ezalaki « Yokitani. » 
\li1  
\v 20 Yokitani abotaki 
\li2 Alimodadi, Shelefi, Atsarimaveti, Yera,  
\v 21 Adorami, Uzali, Dikila,  
\v 22 Obali, Abimaeli, Saba, 
\li2  
\v 23 Ofiri, Avila mpe Yobabi. Bango nyonso wana bazalaki bakitani ya Yokitani. 
\s1 Longwa na Semi kino na Ezawu mpe Jakobi 
\li1  
\v 24 Semi, Aripakishadi, Shela, 
\li1  
\v 25 Eberi, Pelegi, Rewu, 
\li1  
\v 26 Serugi, Naori, Tera, 
\li1  
\v 27 mpe Abrami oyo azali Abrayami. 
\li1  
\v 28 Bana mibali ya Abrayami : 
\li2 Izaki mpe Isimaeli. 
\li1  
\v 29 Tala bakitani na bango : 
\li2 Nebayoti, mwana mobali ya liboso ya Isimaeli ; Kedari, Adibeli, Mibisami,  
\v 30 Mishima, Duma, Masa, Adadi, Tema,  
\v 31 Yeturi, Nafishi mpe Kedima. 
\li4 Bango nde bazalaki bana mibali ya Isimaeli. 
\li1  
\v 32 Bana mibali oyo Abrayami abotaki na Ketura, makangu na ye : 
\li2 Zimirani, Yokishani, Medani, Madiani, Ishibaki mpe Shuwa. 
\li1 Bana mibali ya Yokishani : 
\li2 Saba mpe Dedani. 
\li1  
\v 33 Bana mibali ya Madiani : 
\li2 Efa, Eferi, Enoki, Abida mpe Elida. 
\li4 Bango nyonso wana bazalaki bakitani ya Ketura. 
\s1 Bakitani ya Ezawu 
\li4  
\v 34 Abrayami azalaki tata ya Izaki. 
\li1 Bana mibali ya Izaki : 
\li2 Ezawu mpe Isalaele. 
\li1  
\v 35 Bana mibali ya Ezawu : 
\li2 Elifazi, Reweli, Yewushi, Yaelami mpe Kora. 
\li1  
\v 36 Bana mibali ya Elifazi : 
\li2 Temani, Omari, Tsefo, Gaetami, Kenazi, Timina mpe Amaleki. 
\li1  
\v 37 Bana mibali ya Reweli : 
\li2 Naati, Zera, Shama mpe Miza. 
\li1  
\v 38 Bana mibali ya Seiri : 
\li2 Lotani, Shobali, Tsibeoni, Ana, Dishoni, Etseri mpe Dishani. 
\li1  
\v 39 Bana mibali ya Lotani : 
\li2 Ori mpe Omani. Timina azalaki ndeko mwasi ya Lotani. 
\li1  
\v 40 Bana mibali ya Shobali : 
\li2 Alivani, Manaati, Ebali, Shefo mpe Onami. 
\li1 Bana mibali ya Tsibeoni : 
\li2 Aya mpe Ana. 
\li1  
\v 41 Mwana mobali ya Ana : 
\li2 Dishoni. 
\li1 Bana mibali ya Dishoni : 
\li2 Emidani, Eshibani, Yitirani mpe Kerani. 
\li1  
\v 42 Bana mibali ya Etseri : 
\li2 Bilani, Zavani mpe Yaakani. 
\li1 Bana mibali ya Dishani : 
\li2 Utsi mpe Arani. 
\s1 Bakonzi ya Edomi 
\li4  
\v 43 Tala bakonzi oyo bakambaki Edomi liboso ete Isalaele ekoma kokambama na mokonzi : 
\li1 Bela, mwana mobali ya Beori, oyo kombo ya engumba na ye ezalaki « Dinaba. » 
\li1  
\v 44 Tango Bela akufaki, Yobabi, mwana mobali ya Zera, moto ya mokili ya Botsira, akitanaki na ye na bokonzi. 
\li1  
\v 45 Tango Yobabi akufaki, Ushami, moto ya mokili ya Temani, akitanaki na ye na bokonzi. 
\li1  
\v 46 Tango Ushami akufaki, Adadi, mwana mobali ya Bedadi, akitanaki na ye na bokonzi. Alongaki bato ya Madiani na mokili ya bato ya Moabi. Engumba na ye ezalaki Aviti. 
\li1  
\v 47 Tango Adadi akufaki, Samila, moto ya engumba Masireka, akitanaki na ye na bokonzi. 
\li1  
\v 48 Tango Samila akufaki, Saulo, moto ya engumba Reoboti, engumba oyo etongama pembeni ya ebale, akitanaki na ye na bokonzi. 
\li1  
\v 49 Tango Saulo akufaki, Bala-Anani, mwana mobali ya Akibori, akitanaki na ye na bokonzi. 
\li1  
\v 50 Tango Bala-Anani akufaki, Adadi akitanaki na ye na bokonzi. Engumba na ye ezalaki « Pawu, » mpe kombo ya mwasi na ye ezalaki « Meetabeli. » Meetabeli azalaki mwana mwasi ya Matiredi mpe koko ya Mezaabi.  
\v 51 Adadi mpe akufaki. 
\b  
\li4 Tala bakombo ya bakambi ya Edomi : 
\li1 Timina, Aliva, Yeteti,  
\v 52 Olibama, Ela, Pinoni,  
\v 53 Kenazi, Temani, Mibitsari,  
\v 54 Magidieli mpe Irami. 
\li4 Bango nde bazalaki bakonzi ya Edomi. 
\c 2  
\s1 Bana mibali ya Isalaele 
\r (Ebl 35.23-26) 
\li1  
\v 1 Tala bana mibali ya Isalaele : 
\li2 Ribeni, Simeoni, Levi, Yuda, Isakari, Zabuloni,  
\v 2 Dani, Jozefi, Benjame, Nefitali, Gadi mpe Aseri. 
\s1 Libota ya Yuda 
\r (Ebl 38; 46.12) 
\li1  
\v 3 Bana mibali ya Yuda : 
\li2 Eri, Onani mpe Shela. 
\m Ezali Mwana mwasi ya Shuwa, moto ya Kanana, nde abotelaki Yuda bana mibali misato wana. Eri, mwana mobali ya liboso ya Yuda, atambolaki mabe na miso ya Yawe, mpe Yawe abomaki ye. 
\li2  
\v 4 Tamari, bokilo ya Yuda, abotelaki ye Peretsi mpe Zera. 
\li4 Bana mibali nyonso ya Yuda bazalaki mitano. 
\b  
\li1  
\v 5 Bana mibali ya Peretsi : 
\li2 Etsironi mpe Amuli. 
\r (1Ba 5.11) 
\li1  
\v 6 Bana mibali ya Zera : 
\li2 Zimiri, Etani, Emani, Kalikoli mpe Darida ; 
\m bango nyonso bazalaki mitano. 
\r (Joz 7) 
\li1  
\v 7 Mwana mobali ya Karimi : 
\li2 Akari oyo ayeisaki mobulu na Isalaele tango abukaki mobeko ya kozwa biloko oyo babulisaki mpo na Yawe. 
\li1  
\v 8 Mwana mobali ya Etani : 
\li2 Azaria. 
\li1  
\v 9 Bana mibali oyo babotelaki Etsironi : 
\li2 Yerameeli, Rami mpe Kelubayi. 
\r (Mit 1.7; Rit 4.19-22) 
\li1  
\v 10 Rami azalaki tata ya Aminadabi ; 
\li1 mpe Aminadabi azalaki tata 
\li1 ya Nashoni, mokambi ya bato ya Yuda. 
\li1  
\v 11 Nashoni azalaki tata ya Salima ; 
\li1 Salima azalaki tata ya Boazi. 
\li1  
\v 12 Boazi azalaki tata ya Obedi ; 
\li1 mpe Obedi azalaki tata ya Izayi. 
\b  
\li1  
\v 13 Izayi azalaki tata 
\li2 ya Eliabi, mwana na ye ya liboso ya mobali ; ya mibale, Abinadabi ; 
\li2 ya misato, Shimea ;  
\v 14 ya minei, Netaneeli ; 
\li2 ya mitano, Radayi ;  
\v 15 ya motoba, Otsemi ; 
\li2 mpe ya sambo, Davidi. 
\li2  
\v 16 Bandeko na bango ya basi : Tseruya mpe Abigayili. 
\li1 Tseruya abotaki bana mibali misato : 
\li2 Abishayi, Joabi mpe Asaeli. 
\li1  
\v 17 Abigayili abotaki mwana moko ya mobali, mpe kombo na ye ezalaki « Amasa. » Yeteri, moto ya Isimaeli, nde azalaki tata ya Amasa. 
\b  
\li1  
\v 18 Azuba abotelaki Kalebi, mwana mobali ya Etsironi, 
\li2 mwana moko ya mwasi, mpe kombo na ye ezalaki « Yerioti ; » 
\li2 mpe bana mibali misato : Yesheri, Shobabi mpe Aridoni. 
\li1  
\v 19 Tango Azuba akufaki, Kalebi abalaki Efrata oyo abotelaki ye Wuri. 
\li1  
\v 20 Wuri azalaki tata ya Uri, 
\li2 mpe Uri azalaki tata ya Betisaleyeli. 
\b  
\li1  
\v 21 Mpe na sima, Etsironi asangisaki nzoto na mwana mwasi ya Makiri, tata ya bato ya Galadi. Abalaki ye tango azalaki na mibu tuku motoba ; mpe mwana mwasi ya Makiri abotelaki ye Segubi. 
\li2  
\v 22 Segubi azalaki tata ya Yairi oyo azalaki kokonza bingumba tuku mibale na misato kati na mokili ya Galadi. 
\li2  
\v 23 Kasi bato ya Geshuri mpe ya Siri babotolaki na makasi bamboka oyo Yairi azalaki kokonza ; babotolaki mpe Kenati elongo na bamboka na yango ya mike : bingumba nyonso oyo babotolaki ezalaki tuku motoba. 
\li4 Bango nyonso wana bazalaki bakitani ya Makiri, tata ya bato ya Galadi. 
\li1  
\v 24 Sima na kufa ya Etsironi na mboka Kalebi Efrata, mwasi na ye, Abiya, abotaki mwana mobali, mpe kombo na ye « Ashiwuri. » Ashiwuri azalaki tata ya Tekoa. 
\li1  
\v 25 Bana mibali ya Yerameeli, mwana liboso ya Etsironi, bazalaki : 
\li2 Rami, mwana na ye ya liboso ya mobali, Buna, Oreni, Otsemi mpe Ayiya.  
\v 26 Yerameeli abalaki mwasi mosusu oyo kombo na ye ezalaki « Atara. » Atara abotelaki ye Onami. 
\li1  
\v 27 Bana mibali ya Rami, mwana mobali ya liboso ya Yerameeli : 
\li2 Matsi, Yamini mpe Ekere. 
\li1  
\v 28 Bana mibali ya Onami : 
\li2 Shamayi mpe Yada. 
\li1 Bana mibali ya Shamayi : 
\li2 Nadabi mpe Abishuri.  
\v 29 Kombo ya mwasi ya Abishuri ezalaki « Abiyaili. » Abiyaili abotelaki ye Abani mpe Molidi. 
\li1  
\v 30 Bana mibali ya Nadabi : 
\li2 Seledi mpe Apayimi. 
\m Seledi atikalaki kobota te mpe akufaki. 
\li1  
\v 31 Mwana mobali ya Apayimi : 
\li2 Yisheyi oyo azalaki tata ya Sheshani. Sheshani azalaki tata ya Akilayi. 
\li1  
\v 32 Bana mibali ya Yada, ndeko mobali ya Shamayi : 
\li2 Yeteri mpe Jonatan. 
\m Yeteri atikalaki kobota te mpe akufaki. 
\li1  
\v 33 Bana mibali ya Jonatan : 
\li2 Peleti mpe Zaza. 
\li4 Bango wana nde bazalaki bakitani ya Yerameeli. 
\b  
\li1  
\v 34 Sheshani atikalaki kobota bana mibali te, kaka bana basi. Kasi azalaki na mowumbu moko ya mobali na kombo Yara, moto ya Ejipito.  
\v 35 Sheshani abalisaki mwana na ye ya mwasi epai ya Yara, mowumbu na ye ya mobali, mpe mwana yango ya mwasi abotelaki Yara mwana mobali, Atayi. 
\li1  
\v 36 Atayi azalaki tata ya Natan, 
\li1 Natan azalaki tata ya Zabadi. 
\li1  
\v 37 Zabadi azalaki tata ya Efilali, 
\li1 Efilali azalaki tata ya Obedi. 
\li1  
\v 38 Obedi azalaki tata ya Jewu, 
\li1 Jewu azalaki tata ya Azaria. 
\li1  
\v 39 Azaria azalaki tata ya Eletsi, 
\li1 Eletsi azalaki tata ya Eleasa. 
\li1  
\v 40 Eleasa azalaki tata ya Sisimayi, 
\li1 Sisimayi azalaki tata ya Shalumi. 
\li1  
\v 41 Shalumi azalaki tata ya Yekamia, 
\li1 mpe Yekamia azalaki tata ya Elishama. 
\b  
\li1  
\v 42 Bana mibali ya Kalebi, ndeko ya Yerameeli : 
\li2 Mesha, mwana na ye ya liboso oyo azalaki tata ya Zifi, 
\li2 mpe Maresha, tata ya Ebron. 
\li1  
\v 43 Bana mibali ya Ebron : 
\li2 Kora, Tapua, Rekemi mpe Shema. 
\li1  
\v 44 Shema azalaki tata ya Raami, 
\li2 mpe Raami azalaki tata ya Yorikeami. 
\li1 Rekemi azalaki tata ya Shamayi. 
\li1  
\v 45 Mwana mobali ya Shamayi ezalaki Maoni, 
\li2 Maoni azalaki tata ya Beti-Tsuri. 
\li1  
\v 46 Efa, makangu ya Kalebi, abotelaki ye 
\li2 Arani, Motsa mpe Gazezi. 
\li2 Arani azalaki tata ya Gazezi. 
\li1  
\v 47 Bana mibali ya Yadayi : 
\li2 Regwemi, Yotami, Geshani, Peleti, Efa mpe Shaafi. 
\li1  
\v 48 Maaka, makangu mosusu ya Kalebi, abotelaki ye 
\li2 Sheberi mpe Tirana. 
\li2  
\v 49 Abotelaki ye lisusu 
\li2 Shaafi, tata ya Madimana, 
\li2 mpe Sheva, tata ya Makibena mpe Gibea. 
\li1 Kalebi azalaki na mwana moko ya mwasi, Akisa. 
\li4  
\v 50 Bango wana nde bazalaki bakitani ya Kalebi. 
\b  
\li1 Bana mibali ya Wuri, mwana ya liboso oyo abotaki na Efrata, mwasi na ye : 
\li2 Shobali, tata ya Kiriati-Yearimi ;  
\v 51 Salima, tata ya Beteleemi ; mpe Arefi, tata ya Beti-Gaderi. 
\li1  
\v 52 Bakitani ya Shobali, tata ya Kiriati-Yearimi : 
\li2 Aruwe mpe Atsi-Amenuoti.  
\v 53 Mabota ya Kiriati-Yearimi : bato ya Yeteri, ya Puti, ya Shumati mpe ya Mishirayi. Bato ya Tsorea mpe ya Eshitaoli babimelaki na mabota oyo. 
\li1  
\v 54 Bakitani ya Salima : 
\li2 Bato ya Beteleemi, ya Netofa, ya Aroti-Beti-Joabi, ya Atsi-Amanati mpe ya Tsorea,  
\v 55 elongo na mabota ya bato ya mayele oyo bazalaki kovanda na Yaebetsi : bato ya Tirea, ya Shimea mpe ya Sukoti. Bango wana nde bato ya Keni oyo babimeli na Amati, tata ya libota ya Rekabi. 
\c 3  
\s1 Bana mibali ya Davidi 
\r (2Sa 3.2-5) 
\li4  
\v 1 Tala bana mibali ya Davidi oyo babotamaki na Ebron : 
\b  
\li1 Mwana ya liboso ezalaki Aminoni, mwana mobali ya Ayinoami, moto ya Jizireyeli ; 
\li1 ya mibale, Daniele, mwana mobali ya Abigayili, moto ya Karimeli ; 
\li1  
\v 2 ya misato, Abisalomi, mwana mobali ya Maaka, mwana mwasi ya Talimayi, mokonzi ya Geshuri ; 
\li1 ya minei, Adoniya, mwana mobali ya Agite ; 
\li1  
\v 3 ya mitano, Shefatia, mwana mobali ya Abitali ; 
\li1 mpe ya motoba, Yitileami oyo Egila, mwasi na ye, abotaki. 
\b  
\li4  
\v 4 Bango nyonso motoba bazalaki bana mibali ya Davidi oyo babotamaki na Ebron, mboka mokonzi, epai wapi akonzaki mibu sambo na ndambo. 
\b  
\b  
\li4 Davidi akonzaki wuta na Yelusalemi mibu tuku misato na misato. 
\r (2Sa 5.14-16; 1Ma 14.4-7) 
\li4  
\v 5 Tala bakombo ya bana na ye ya mibali oyo babotamaki na Yelusalemi : 
\b  
\li1 Shimea, Shobabi, Natan mpe Salomo. Ezali Batisheba, mwana mwasi ya Amieli, nde abotaki bana mibali minei oyo. 
\li1  
\v 6 Babotelaki ye lisusu bana oyo : Yibari, Elishama, Elifeleti,  
\v 7 Noga, Nefegi, Yafia,  
\v 8 Elishama, Eliyada mpe Elifeleti. 
\li4 Bango nyonso bazalaki libwa. 
\b  
\li4  
\v 9 Bango nyonso nde bazalaki bana mibali ya Davidi, longola bana mibali oyo bamakangu na ye babotelaki ye. Mpe Tamari azalaki ndeko na bango ya mwasi. 
\b  
\li1  
\v 10 Salomo azalaki tata ya Roboami, 
\li1 Roboami azalaki tata ya Abiya, 
\li1 Abiya azalaki tata ya Asa, 
\li1 Asa azalaki tata ya Jozafati, 
\li1  
\v 11 Jozafati azalaki tata ya Yorami, 
\li1 Yorami azalaki tata ya Akazia, 
\li1 Akazia azalaki tata ya Joasi, 
\li1  
\v 12 Joasi azalaki tata ya Amatsia, 
\li1 Amatsia azalaki tata ya Azaria, 
\li1 Azaria azalaki tata ya Yotami, 
\li1  
\v 13 Yotami azalaki tata ya Akazi, 
\li1 Akazi azalaki tata ya Ezekiasi, 
\li1 Ezekiasi azalaki tata ya Manase, 
\li1  
\v 14 Manase azalaki tata ya Amoni, 
\li1 Amoni azalaki tata ya Joziasi, 
\li1  
\v 15 Joziasi azalaki tata ya bana mibali oyo : 
\li2 Yoanani, mwana na ye ya liboso ; 
\li2 Yeoyakimi, ya mibale ; 
\li2 Sedesiasi, ya misato ; 
\li2 Shalumi, ya minei. 
\li1  
\v 16 Bana mibali ya Yeoyakimi : 
\li2 Yekonia mpe Sedesiasi. 
\s1 Bakonzi oyo bakonzaki sima na bowumbu 
\li1  
\v 17 Libota ya Yekonia, mokangami : 
\li2 Shealitieli, mwana na ye ya mobali ;  
\v 18 Malikirami, Pedaya, Shenatsari, Yekamia, Oshama mpe Nedabia. 
\li1  
\v 19 Bana mibali ya Pedaya : 
\li2 Zorobabeli mpe Shimei. 
\li1 Bana mibali ya Zorobabeli : 
\li2 Meshulami mpe Anania. Shelomiti azalaki ndeko na bango ya mwasi. 
\li1  
\v 20 Bana mibali ya Meshulami : 
\li2 Ashuba, Oeli, Berekia, Asadia, Yoshabi-Esedi. 
\li4 Bango nyonso bazalaki mitano. 
\li1  
\v 21 Bakitani ya Anania : 
\li2 Pelatia mpe Ezayi elongo na bana mibali ya Refaya, ya Arinani, ya Abidiasi mpe ya Shekania. 
\li1  
\v 22 Libota ya Shekania : 
\li2 Shemaya elongo na bana na ye ya mibali : Atushi, Yigali, Baria, Nearia mpe Shafati. 
\li4 Bango nyonso bazalaki motoba. 
\li1  
\v 23 Bana mibali ya Nearia : 
\li2 Eliowenayi, Ezekiasi mpe Azirikami. 
\li4 Bango nyonso bazalaki misato. 
\li1  
\v 24 Bana mibali ya Eliowenayi : 
\li2 Odavia, Eliashibi, Pelaya, Akubi, Yoanani, Delaya mpe Anani. 
\li4 Bango nyonso bazalaki sambo. 
\c 4  
\s1 Bituka mosusu ya Yuda 
\li1  
\v 1 Libota ya Yuda : 
\li2 Peretsi, Etsironi, Karimi, Wuri mpe Shobali. 
\li1  
\v 2 Reaya, mwana mobali ya Shobali, azalaki tata ya Yaati, mpe Yaati azalaki tata ya Awumayi mpe ya Laadi. 
\li4 Bango nde bazalaki bakoko ya bituka ya bato ya Tsorea. 
\li1  
\v 3 Tala bana mibali ya Etami : 
\li2 Jizireyeli, Yishima mpe Yidibashi. 
\li2 Kombo ya ndeko na bango ya mwasi ezalaki Atseleliponi. 
\li1  
\v 4 Penueli azalaki tata ya Gedori, mpe Ezeri azalaki tata ya Usha. 
\li4 Bango nde bazalaki bakitani ya Wuri, mwana liboso ya Efrata, tata ya Beteleemi. 
\li1  
\v 5 Ashiwuri, tata ya Tekoa, azalaki na basi mibale : Eleya mpe Nara. 
\li1  
\v 6 Nara abotelaki ye bana mibali oyo : 
\li2 Awuzami, Eferi, Temeni mpe Ahashitari. 
\li1  
\v 7 Eleya abotelaki ye bana mibali oyo : 
\li2 Tsereti, Tsoari mpe Etinani. 
\li1  
\v 8 Kotsi azalaki tata ya Anubi mpe Atsobeba, mpe koko ya mabota ya Aareyeli, mwana mobali ya Arumi. 
\b  
\p  
\v 9 Yaebetsi azalaki na lokumu mingi koleka bandeko na ye ya mibali. Mama na ye apesaki ye kombo « Yaebetsi » mpo na koloba : « Nabotaki yo na pasi. »  
\v 10 Yaebetsi abelelaki Yawe, Nzambe ya Isalaele ; alobaki : « Oh Yawe ! Soki okoki kopambola ngai mpe koyeisa mabele na ngai monene ! Tika ete loboko na Yo ezala likolo na ngai ! Bomba ngai mosika ya mabe mpo ete namona pasi te. » Mpe Nzambe ayanolaki libondeli na ye. 
\b  
\li1  
\v 11 Kelubi, ndeko mobali ya Shuwa, azalaki tata ya Meyiri oyo azalaki tata ya Eshitoni.  
\v 12 Eshitoni azalaki tata ya Beti-Rafa, Paseya mpe Teyina oyo atongaki engumba Naashi. Bango nde bazalaki kovanda na engumba Reka. 
\r (Bil 1.13) 
\li1  
\v 13 Bana mibali ya Kenazi : 
\li2 Otinieli mpe Seraya. 
\li1 Bana mibali ya Otinieli : 
\li2 Atati mpe Meonotayi. 
\li1  
\v 14 Meonotayi abotaki Ofira. 
\li1 Seraya abotaki Joabi, tata ya Ge-Arashimi. Bazalaki kobenga ye bongo, pamba te bato na ye bazalaki kosala misala ya maboko, ya kotula bibende na moto. 
\r (Mit 13.6) 
\li1  
\v 15 Bana mibali ya Kalebi, mwana mobali ya Yefune : 
\li2 Iru, Ela mpe Naame. 
\li1 Mwana mobali ya Ela : 
\li2 Kenazi. 
\li1  
\v 16 Mwana mobali ya Yealeyeli : 
\li2 Zifi, Zifa, Tiria mpe Asareli. 
\li1  
\v 17 Bana mibali ya Esidrasi : 
\li2 Yeteri, Meredi, Eferi mpe Yaloni. Moko kati na basi ya Meredi abotaki Miriami, Shamayi mpe Yishiba, tata ya Eshitemoa.  
\v 18 Mwasi na ye, moto ya Yuda, abotaki Yeredi, tata ya Gedori ; Eberi, tata ya Soko mpe Yekutieli, tata ya Zanoa. 
\m Bango nde bazalaki bana mibali ya Bitiya, mwana mwasi ya Faraon, oyo Meredi abalaki. 
\li1  
\v 19 Bana mibali ya mwasi ya Odia, ndeko mwasi ya Naami : 
\li2 tata ya Keila, moto ya Garima ; mpe Eshitemoa, moto ya mboka Maakati. 
\li1  
\v 20 Bana mibali ya Simona : 
\li2 Aminoni, Rina, Beni-Anani mpe Tiloni. 
\li1 Bana mibali ya Yisheyi : 
\li2 Zoeti mpe Beni-Zoeti. 
\li1  
\v 21 Bana mibali ya Shela, mwana mobali ya Yuda : 
\li2 Eri, tata ya Leka ; Laeda, tata ya Maresha ; mpe mabota ya basali bilamba ya lino, na Beti-Asheba. 
\li2  
\v 22 Yokimi, bato ya Kozeba, Joasi mpe Sarafi oyo bazalaki bakambi kati na Moabi mpe engumba Yashubi-Leemi. Nyonso oyo ezali makambo ya kala.  
\v 23 Bazalaki basali mbeki oyo bazalaki kovanda na Netayimi mpe na Gedera ; batikalaki kuna mpo na kosalela mokonzi. 
\s1 Libota ya Simeoni 
\r (Ebl 46.10; Mit 26.12-13) 
\li1  
\v 24 Bana mibali ya Simeoni : 
\li2 Nemueli, Yamini, Yaribi, Zera ; Saulo, tata ya Shalumi ; 
\li2  
\v 25 Shalumi, tata ya Mibisami ; Mibisami, tata ya Mishima. 
\li1  
\v 26 Bana mibali ya Mishima : 
\li2 Amueli, Zakuri mpe Shimei.  
\v 27 Shimei azalaki na bana mibali zomi na motoba mpe bana basi motoba ; kasi bandeko na ye ya mibali babotaki bana mingi te, yango wana etuka na bango ezalaki na bato ebele te lokola libota ya Yuda. 
\r (Joz 19.1-8) 
\li1  
\v 28 Bazalaki kovanda na Beri-Sheba, na Molada, na Atsari-Shuwali,  
\v 29 na Bila, na Etsemi, na Toladi,  
\v 30 na Betweli, na Orima, na Tsikilagi,  
\v 31 na Beti-Marikaboti, na Atsari-Suzimi, na Beti-Birei mpe na Shaarayimi : nyonso oyo ezalaki bingumba na bango kino na tango ya bokonzi ya Davidi.  
\v 32 Tala bingumba mitano mike oyo ezalaki zingazinga na yango : Etami, Ayini, Rimoni, Tokeni mpe Ashani ;  
\v 33 bakisa bamboka mike mosusu oyo ezingelaki bingumba yango kino na Baalati. Oyo nde ezalaki bisika na bango ya kovanda mpe molongo ya mbotama ya bakoko na bango. 
\b  
\li1  
\v 34 Meshobabi ; Yamileki ; 
\li1 Yosha, mwana mobali ya Amatsia ;  
\v 35 Joeli ; Jewu, mwana mobali ya Yoshibia, mwana mobali ya Seraya, mwana mobali ya Asieli ; 
\li1  
\v 36 Eliowenayi ; Yakoba ; Yeshoaya ; 
\li1 Asaya ; Adieli ; Yesimieli ; Benaya ; 
\li1  
\v 37 Ziza, mwana mobali ya Shifeyi, mwana mobali ya Aloni, mwana mobali ya Yedaya, mwana mobali ya Shimiri, mwana mobali ya Shemaya. 
\b  
\li4  
\v 38 Bato oyo batangamaki na bakombo bazalaki bakambi ya bituka na bango. 
\b  
\p Mabota na bango ekomaki minene  
\v 39 mpe bakendeki na zingazinga ya Gedori, na ngambo ya este ya lubwaku, mpo na koluka matiti ya koleisa bibwele na bango.  
\v 40 Bakutaki kuna : matiti kitoko mpo na koleisa bibwele, mokili moko ya monene, ya kimia mpe ezanga mobulu. Bato oyo bazalaki kovanda kuna na tango ya kala, bazalaki bakitani ya Cham.  
\v 41 Na tango Ezekiasi azalaki mokonzi ya Yuda, bato oyo bakombo na bango ekomami, bakomaki na mokili yango. Babundisaki bakitani ya Cham mpe babebisaki bandako na bango ; mpe lisusu, basilisaki koboma bato ya Mewuni oyo bazalaki kovanda kuna, ndenge yango ezali komonana lelo. Na sima, bavandaki na bisika na bango, mpo ete mokili yango ezalaki na matiti mpo na koleisa bibwele na bango.  
\v 42 Bato ya Simeoni nkama mitano oyo bakambamaki na Pelatia, na Nearia, na Refaya mpe na Uzieli, bana mibali ya Yisheyi, babotolaki na makasi mokili ya bangomba Seiri,  
\v 43 babomaki ndambo ya bato ya Amaleki oyo batikalaki mpe bavandaki kuna kino lelo. 
\c 5  
\s1 Libota ya Ribeni 
\p  
\v 1 Ribeni azalaki mwana mobali ya liboso ya Isalaele. Kasi lokola asangisaki nzoto na mwasi moko kati na basi ya tata na ye, makoki ya bomwana na ye ya liboso epesamaki epai ya bana mibali ya Jozefi, mwana mobali ya Isalaele. Yango wana bazalaki kotanga ye lisusu te lokola mwana ya liboso. Nzokande, Jozefi akomamaki te na buku ya mabota lokola mwana ya liboso.  
\v 2 Yuda alekaki bandeko na ye nyonso ya mibali na makasi, mpe moto oyo akomaki mokonzi abimaki na nzela na ye. Kasi atako bongo, makoki ya bomwana ya liboso epesamaki kaka epai ya Jozefi. 
\r (Ebl 46.9; Mit 26.5-6) 
\li4  
\v 3 Tala bana mibali ya Ribeni, mwana mobali ya liboso ya Isalaele : 
\li2 Enoki, Palu, Etsironi mpe Karimi. 
\li1  
\v 4 Bakitani ya Joeli : 
\li2 Shemaya, mwana mobali ya Joeli ; Gogi, mwana mobali ya Shemaya ; 
\li2 Shimei, mwana mobali ya Gogi ;  
\v 5 Mishe, mwana mobali ya Shimei ; 
\li2 Reaya, mwana mobali ya Mishe ; Bala, mwana mobali ya Reaya ; 
\li2  
\v 6 Beera, mwana mobali ya Bala mpe mokambi ya bato ya Ribeni, oyo Tigilati-Pilezeri, mokonzi ya Asiri, amemaki na bowumbu. 
\li1  
\v 7 Tala bandeko ya Beera kolanda etuka na bango ndenge bakomami na molongo ya botata na bango : 
\li2 mokambi Yeyeli, Zakari ;  
\v 8 Bela, mwana mobali ya Azazi, koko ya Shema, mwana mobali ya Joeli. 
\b  
\p Bazalaki kovanda na mboka Aroeri mpe na etuka oyo ekenda kino na ngomba Nebo mpe na Bala-Meoni.  
\v 9 Bavandaki na ngambo ya este, longwa na mondelo ya esobe kino na ebale Efrate, pamba te bangombe na bango ekomaki ebele kati na mokili ya Galadi.  
\v 10 Na tango Saulo azalaki mokonzi, babundisaki bato ya Agari mpe balongaki bango. Bavandaki na bandako na bango ya kapo oyo ezalaki na etuka mobimba ya ngambo ya Galadi. 
\s1 Libota ya Gadi 
\li4  
\v 11 Bakitani ya Gadi bazalaki kovanda pembeni ya bakitani ya Ribeni, na mokili ya Bashani kino na Salika. 
\b  
\li1  
\v 12 Etuka ya Joeli nde elekaki monene, elandamaki na etuka ya Shafami, mpe bituka ya Yaenayi mpe Shafati esukisaki, kati na Bashani. 
\li1  
\v 13 Bandeko na bango ya mibali kolanda mabota na bango bazalaki : 
\li2 Mikaeli, Meshulami, Sheba, Yorayi, Yaekani, Ziya mpe Eberi. 
\m Bango nyonso bazalaki sambo. 
\li2  
\v 14 Bazalaki bana ya Abiyaili, mwana mobali ya Uri, mwana mobali ya Yaroa, mwana mobali ya Galadi, mwana mobali Mikaeli, mwana mobali ya Yeshishai, mwana mobali ya Yado, mwana mobali ya Buzi. 
\li2  
\v 15 Ayi, mwana mobali ya Abidieli, mwana mobali ya Guni, azalaki mokambi ya bituka na bango. 
\b  
\p  
\v 16 Bango nyonso bazalaki kovanda na Galadi, na Bashani, na bamboka na yango ya zingazinga mpe na bilanga nyonso ya Saroni kino na suka na yango.  
\v 17 Batangaki bato nyonso oyo tango Yotami azalaki mokonzi ya Yuda mpe Jeroboami, mokonzi ya Isalaele. 
\b  
\p  
\v 18 Bakitani ya mabota ya Ribeni, ya Gadi mpe ya ndambo ya libota ya Manase bazalaki bango nyonso nkoto tuku minei na minei na nkama sambo na tuku motoba. Babongamaki mpo na mosala ya soda. Bazalaki bilombe mibali oyo bayebi kosalela nguba, mopanga, tolotolo ; mpe bamilengela mpo na bitumba.  
\v 19 Babundisaki bato ya Agari, ya Yeturi, ya Nafishi mpe ya Nodabi.  
\v 20 Nzambe asungaki bango mpe apesaki bango elonga likolo ya bato ya Agari mpe baninga na bango nyonso oyo bayaki kosunga bango, pamba te babelelaki Yawe na tango ya bitumba. Yawe ayanolaki bango, pamba te batielaki Ye motema.  
\v 21 Bazwaki bibwele ya bato ya Agari : bashamo nkoto tuku mitano, bameme nkoto nkama mibale na tuku mitano, mpe ba-ane nkoto mibale. Bazwaki mpe bakangami nkoto nkama moko :  
\v 22 mingi bakufaki, pamba te bitumba ezalaki na maboko ya Nzambe. Bavandaki na mokili yango kino na tango ya bowumbu. 
\s1 Libota ya Manase 
\p  
\v 23 Bakitani ya ndambo ya libota ya Manase bavandaki na mokili oyo ezalaki longwa na Bashani kino na Bala-Erimoni, Seniri mpe ngomba Erimoni.  
\v 24 Tala bakambi ya bituka na bango : Eferi, Yisheyi, Elieli, Azirieli, Jeremi, Odavia mpe Yadiele. Bazalaki bilombe ya bitumba, bato bayebana mpe bakambi ya mabota na bango. 
\p  
\v 25 Kasi lokola batosaki te Nzambe ya bakoko na bango mpe bakomaki kosalela banzambe ya bato ya mokili oyo Nzambe abebisaki liboso na bango. 
\p  
\v 26 Yango wana Nzambe ya Isalaele alamusaki molimo ya Puli, mokonzi ya Asiri, mpe molimo ya Tigilati-Pilezeri, mokonzi ya Asiri, mpo na komema na bowumbu : bato ya libota ya Ribeni, ya libota ya Gadi mpe ya ndambo ya libota ya Manase. Amemaki bango na Ala, na Abori, na Ara mpe na ngambo ya ebale Gozani, epai wapi bazali kovanda kino lelo. 
\s1 Libota ya Levi 
\r (Ebl 46.11; Mit 26.59-60) 
\li1  
\v 27 Bana mibali ya Levi : 
\li2 Gerishoni, Keati mpe Merari. 
\li1  
\v 28 Bana mibali ya Keati : 
\li2 Amirami, Yitseari, Ebron mpe Uzieli. 
\li1  
\v 29 Bana ya Amirami : 
\li2 Aron, Moyize mpe Miriami. 
\li1 Bana mibali ya Aron : 
\li2 Nadabi, Abiyu, Eleazari mpe Itamari. 
\li2  
\v 30 Eleazari abotaki Pineasi ; 
\li2 Pineasi abotaki Abishuwa ; 
\li2  
\v 31 Abishuwa abotaki Buki ; 
\li2 Buki abotaki Uzi ; 
\li2  
\v 32 Uzi abotaki Zerakia ; 
\li2 Zerakia abotaki Merayoti ; 
\li2  
\v 33 Merayoti abotaki Amaria ; 
\li2 Amaria abotaki Ayitubi ; 
\li2  
\v 34 Ayitubi abotaki Tsadoki ; 
\li2 Tsadoki abotaki Ayimaatsi ; 
\li2  
\v 35 Ayimaatsi abotaki Azaria ; 
\li2 Azaria abotaki Yoanani ; 
\li2  
\v 36 Yoanani abotaki Azaria oyo azalaki Nganga-Nzambe kati na Tempelo oyo Salomo atongaki na Yelusalemi. 
\li2  
\v 37 Azaria abotaki Amaria ; 
\li2 Amaria abotaki Ayitubi ; 
\li2  
\v 38 Ayitubi abotaki Tsadoki, 
\li2 mpe Tsadoki abotaki Shalumi ; 
\li2  
\v 39 Shalumi abotaki Ilikia ; 
\li2 Ilikia abotaki Azaria ; 
\li2  
\v 40 Azaria abotaki Seraya ; 
\li2 Seraya abotaki Yeotsadaki. 
\li2  
\v 41 Yeotsadaki akendeki na bowumbu tango Yawe akabaki Yelusalemi mpe Yuda na maboko ya Nabukodonozori. 
\c 6  
\s1 Bakitani mosusu ya Levi 
\r (Mit 3.17-20) 
\li1  
\v 1 Bana mibali ya Levi : 
\li2 Gerishoni, Keati mpe Merari. 
\li1  
\v 2 Bana mibali ya Gerishoni : 
\li2 Libini mpe Shimei. 
\li1  
\v 3 Bana mibali ya Keati : 
\li2 Amirami, Yitseari, Ebron mpe Uzieli. 
\li1  
\v 4 Bana mibali ya Merari : 
\li2 Maali mpe Mushi. 
\b  
\li4 Tala bakitani ya Levi kolanda batata na bango : 
\li1  
\v 5 Mpo na Gerishoni : 
\li2 Gerishoni abotaki Libini ; 
\li2 Libini abotaki Yaati ; 
\li2 Yaati abotaki Zima ; 
\li2  
\v 6 Zima abotaki Yoa ; 
\li2 Yoa abotaki Ido ; 
\li2 Ido abotaki Zera ; 
\li2 Zera abotaki Yeatirayi. 
\li1  
\v 7 Mpo na Keati : 
\li2 Keati abotaki Aminadabi ; 
\li2 Aminadabi abotaki Kore ; 
\li2 Kore abotaki Asiri ; 
\li2  
\v 8 Asiri abotaki Elikana ; 
\li2 Elikana abotaki Ebiazafi ; 
\li2 Ebiazafi abotaki Asiri ; 
\li2  
\v 9 Asiri abotaki Taati ; 
\li2 Taati abotaki Urieli ; 
\li2 Urieli abotaki Uzia ; 
\li2 Uzia abotaki Saulo. 
\li1  
\v 10 Bana mibali ya Elikana : 
\li2 Amasayi, Ayimoti. 
\li2  
\v 11 Elikana abotaki Tsofayi ; 
\li2 Tsofayi abotaki Naati ; 
\li2  
\v 12 Naati abotaki Eliabi ; 
\li2 Eliabi abotaki Yeroami ; 
\li2 Yeroami abotaki Elikana, 
\li2 mpe Elikana abotaki Samuele. 
\li1  
\v 13 Bana mibali ya Samuele : 
\li2 Joeli, mwana ya liboso ; mpe Abiya, mwana ya mibale. 
\li1  
\v 14 Bakitani ya Merari kolanda batata na bango : 
\li2 Merari abotaki Maali ; 
\li2 Maali abotaki Libini ; 
\li2 Libini abotaki Shimei ; 
\li2 Shimei abotaki Uza ; 
\li2  
\v 15 Uza abotaki Shimea ; 
\li2 Shimea abotaki Agiya ; 
\li2 Agiya abotaki Asaya. 
\p  
\v 16 Tala Balevi oyo Davidi apesaki mokumba ya kotambolisa banzembo kati na Tempelo ya Yawe, wuta tango Sanduku ya Yawe ezwaki kuna esika ya bopemi.  
\v 17 Balevi oyo basalaki mosala na bango na nzela ya banzembo liboso ya Mongombo, Ndako ya kapo ya Bokutani, kino tango Salomo atongaki Tempelo ya Yawe na Yelusalemi, kolanda mibeko oyo bapesaki bango. 
\b  
\li4  
\v 18 Tala bato oyo bazalaki kosala mosala yango, elongo na bana na bango ya mibali : 
\b  
\li1 Kati na bana mibali ya Keati : 
\li2 Moyembi Emani, 
\li2 mwana mobali ya Joeli, mwana mobali ya Samuele, 
\li2  
\v 19 mwana mobali ya Elikana, mwana mobali ya Yeroami, 
\li2 mwana mobali ya Elieli, mwana mobali ya Towa, 
\li2  
\v 20 mwana mobali ya Tsufi, mwana mobali ya Elikana, 
\li2 mwana mobali ya Maalati, mwana mobali ya Amasayi, 
\li2  
\v 21 mwana mobali ya Elikana, mwana mobali ya Joeli, 
\li2 mwana mobali ya Azaria, mwana mobali ya Sofoni, 
\li2  
\v 22 mwana mobali ya Taati, mwana mobali ya Asiri, 
\li2 mwana mobali ya Ebiazafi, mwana mobali ya Kore, 
\li2  
\v 23 mwana mobali ya Yitseari, mwana mobali ya Keati, 
\li2 mwana mobali ya Levi, mwana mobali ya Isalaele. 
\li1  
\v 24 Na ngambo ya loboko ya mobali ya Emani, Azafi nde azalaki kotelema wana mpe azalaki libota moko na Emani. 
\li2 Azafi, mwana mobali ya Berekia, mwana mobali ya Shimea, 
\li2  
\v 25 mwana mobali ya Mikaeli, mwana mobali ya Baaseya, 
\li2 mwana mobali ya Malikiya,  
\v 26 mwana mobali ya Etini, 
\li2 mwana mobali ya Zera, mwana mobali ya Adaya, 
\li2  
\v 27 mwana mobali ya Etani, mwana mobali ya Zima, 
\li2 mwana mobali ya Shimei,  
\v 28 mwana mobali ya Yaati, 
\li2 mwana mobali ya Gerishoni, mwana mobali ya Levi. 
\li1  
\v 29 Na ngambo ya loboko ya mwasi, bandeko na bango, bana mibali ya Merari nde bazalaki kotelema wana na bokambami ya Etani, 
\li2 mwana mobali ya Kishi, mwana mobali ya Abidi, 
\li2 mwana mobali ya Maluki,  
\v 30 mwana mobali ya Ashabia, 
\li2 mwana mobali ya Amatsia, mwana mobali ya Ilikia, 
\li2  
\v 31 mwana mobali Amitsi, mwana mobali ya Bani, 
\li2 mwana mobali ya Shemeri,  
\v 32 mwana mobali ya Maali, 
\li2 mwana mobali ya Mushi, mwana mobali ya Merari, 
\li2 mwana mobali ya Levi. 
\b  
\p  
\v 33 Bandeko na bango ya mibali, bana mosusu ya Levi, baponamaki mpo na kosala misala mosusu liboso ya Mongombo, kati na Esika ya bule ya Nzambe.  
\v 34 Kasi Aron mpe bana na ye ya mibali bapesamelaki mokumba ya kotumba mbeka na likolo ya etumbelo ya nyama mpe etumbelo ya malasi. Bazalaki kosala misala nyonso oyo etali Esika-Oyo-Eleki-Bule mpe mosala ya bolimbisi masumu ya Isalaele kolanda mitindo nyonso oyo Moyize, mosali na Nzambe, apesaki. 
\li1  
\v 35 Tala bakitani ya Aron : 
\li2 Aron abotaki Eleazari, Eleazari abotaki Pineasi, 
\li2 Pineasi abotaki Abishuwa,  
\v 36 Abishuwa abotaki Buki, 
\li2 Buki abotaki Uzi, Uzi abotaki Zerakia, 
\li2  
\v 37 Zerakia abotaki Merayoti, Merayoti abotaki Amaria, 
\li2 Amaria abotaki Ayitubi,  
\v 38 Ayitubi abotaki Tsadoki, 
\li2 mpe Tsadoki abotaki Ayimaatsi. 
\li4  
\v 39 Tala bamboka oyo epesamaki na libota ya Aron kati na etuka ya Keati kolanda bandelo ya mabele na bango ; pamba te bato ya Keati nde bazalaki bato ya liboso ya kozwa libula ya mabele na nzela ya Zeke : 
\li1  
\v 40 engumba ya Ebron, kati na mokili ya Yuda, elongo na bamboka na yango ya zingazinga.  
\v 41 Kasi bilanga mpe bamboka oyo ezingelaki engumba, epesamaki na Kalebi, mwana mobali ya Yefune.  
\v 42 Boye tala bingumba oyo bapesaki na bana mibali ya Aron lokola bingumba ya kokimela : Ebron mpe bamboka na yango ya mike, Libina mpe bamboka na yango ya mike ; Yatiri, Eshitemoa mpe bamboka na yango ya mike ;  
\v 43 Ileni mpe bamboka na yango ya mike ; Debiri mpe bamboka na yango ya mike ;  
\v 44 Ashani mpe bamboka na yango ya mike, Beti-Shemeshi mpe bamboka na yango ya mike. 
\li1  
\v 45 Kati na etuka ya Benjame, bapesaki bango lokola bingumba ya kokimela : Geba mpe bamboka na yango ya mike, Alemeti mpe Anatoti elongo na bamboka na yango ya mike. 
\li4 Bingumba nyonso oyo epesamelaki kati na bituka na bango ezalaki zomi na misato. 
\r (Joz 21.5-8) 
\li1  
\v 46 Bana mosusu ya Keati bazwaki na nzela ya zeke bingumba zomi kati na etuka ya Efrayimi, ya Dani mpe ya ndambo ya libota ya Manase. 
\li1  
\v 47 Bana ya Gerishoni, kolanda etuka na bango, bazwaki bingumba zomi na misato kati na libota ya Isakari, ya Aseri, ya Nefitali mpe kati na libota ya Manase oyo ezalaki na Bashani. 
\li1  
\v 48 Bana ya Merari, kolanda bituka na bango, bazwaki na nzela ya zeke, bingumba zomi na mibale kati na libota ya Ribeni, ya Gadi mpe ya Zabuloni. 
\b  
\li4  
\v 49 Boye bana ya Isalaele bapesaki epai ya bana ya Levi, bingumba wana mpe bamboka na yango ya mike. 
\b  
\li1  
\v 50 Bapesaki bango bingumba wana na nzela ya zeke : balongolaki ndambo ya bingumba yango kati na mabota ya Yuda, ya Simeoni mpe ya Benjame ; bongo bakomaki kobenga yango na bakombo ya mabota wana. 
\b  
\li4  
\v 51 Bituka mosusu ya bana ya Keati bazwaki bingumba ya kokimela kati na libota ya Efrayimi. 
\li1  
\v 52 Bapesaki bango lokola engumba ya kokimela : Sishemi mpe bamboka na yango ya mike, kati na etuka ya bangomba ya Efrayimi, Gezeri mpe bamboka na yango ya mike,  
\v 53 Yokimeami mpe bamboka na yango ya mike, Beti-Oroni mpe bamboka na yango ya mike,  
\v 54 Ayaloni mpe bamboka na yango ya mike, Gati-Rimoni mpe bamboka na yango ya mike. 
\li1  
\v 55 Mpe kati na etuka ya ndambo ya libota ya Manase, bazwaki : 
\li2 Aneri mpe bamboka na yango ya mike, 
\li2 Bileami mpe bamboka na yango ya mike. 
\li4 Bingumba nyonso oyo elongo na bamboka na yango ya mike epesamaki epai ya bituka mosusu ya bana ya Keati. 
\b  
\li4  
\v 56 Bakitani ya Gerishoni bazwaki : 
\li1 Kati na etuka ya ndambo ya libota ya Manase, bazwaki bingumba oyo : 
\li2 Golani kati na Bashani mpe bamboka na yango ya mike, 
\li2 Ashitaroti mpe bamboka na yango ya mike. 
\li1  
\v 57 Kati na libota ya Isakari, bazwaki : 
\li2 Kedeshi mpe bamboka na yango ya mike, 
\li2 Dabirati mpe bamboka na yango ya mike, 
\li2  
\v 58 Ramoti mpe bamboka na yango ya mike, 
\li2 Anemi mpe bamboka na yango ya mike. 
\li1  
\v 59 Kati na libota ya Aseri, bazwaki : 
\li2 Mashali mpe bamboka na yango ya mike, 
\li2 Abidoni mpe bamboka na yango ya mike, 
\li2  
\v 60 Ukoki mpe bamboka na yango ya mike, 
\li2 Reobi mpe bamboka na yango ya mike. 
\li1  
\v 61 Kati na libota ya Nefitali, bazwaki : 
\li2 Kedeshi kati na Galile mpe bamboka na yango ya mike, 
\li2 Amoni mpe bamboka na yango ya mike, 
\li2 Kiriatayimi mpe bamboka na yango ya mike. 
\b  
\li4  
\v 62 Bana mosusu ya Merari bazwaki bingumba oyo : 
\li1 kati na libota ya Zabuloni : 
\li2 Rimono mpe bamboka na yango ya mike, 
\li2 Tabori mpe bamboka na yango ya mike. 
\li1  
\v 63 Kati na libota ya Ribeni, kuna na ngambo ya este ya Yordani, pembeni ya Jeriko, bazwaki bingumba oyo : 
\li2 Betseri, kati na esobe, mpe bamboka na yango ya mike ; 
\li2 Yakatsi mpe bamboka na yango ya mike, 
\li2  
\v 64 Kedemoshi mpe bamboka na yango ya mike, 
\li2 Mefati mpe bamboka na yango ya mike. 
\li1  
\v 65 Kati na libota ya Gadi, bazwaki : 
\li2 Ramoti kati na Galadi mpe bamboka na yango ya mike, 
\li2 Maanayimi mpe bamboka na yango ya mike, 
\li2  
\v 66 Eshiboni mpe bamboka na yango ya mike, 
\li2 Yaezeri mpe bamboka na yango ya mike. 
\c 7  
\s1 Libota ya Isakari 
\r (Ebl 46.13; Mit 26.23-24; Bil 10.1) 
\li1  
\v 1 Isakari abotaki bana mibali minei : 
\li2 Tola, Puwa, Yashubi mpe Shimironi. Bango nyonso bazalaki minei. 
\li1  
\v 2 Bana mibali ya Tola : 
\li2 Uzi, Refaya, Yeriyeli, Yamayi, Yibisami mpe Samuele. 
\m Bango nde babotamaki na nzela ya Tola mpe bazalaki bakambi ya mabota ya botata na bango. Kati na mabota na bango, bazalaki basoda ya mpiko nkoto tuku mibale na mibale na nkama motoba, na tango Davidi azalaki mokonzi. 
\li1  
\v 3 Bana mibali ya Uzi : 
\li2 Yiziraya. 
\li1 Bana mibali ya Yiziraya : 
\li2 Mikaeli, Abidiasi, Joeli mpe Yishiya. 
\m Bango nyonso mitano bazalaki bakambi.  
\v 4 Kati na molongo na bango kolanda bituka na bango mpe mabota na bango ya botata ; ezalaki na basoda ya mpiko nkoto tuku misato na motoba, pamba te bazalaki na basi mpe bana ebele. 
\li4  
\v 5 Bandeko mibali nyonso kati na bituka ya libota ya Isakari, oyo bakomamaki na buku ya mabota, bazalaki nkoto tuku mwambe na sambo. Bazalaki basoda ya mpiko. 
\s1 Libota ya Benjame 
\r (Ebl 46.21; Mit 26.38-39) 
\li1  
\v 6 Benjame abotaki bana mibali misato : 
\li2 Bela, Bekeri mpe Yediayeli. 
\li1  
\v 7 Bela abotaki bana mibali mitano : 
\li2 Etsiboni, Uzi, Uzieli, Yerimoti mpe Iri. 
\m Bazalaki bakambi ya bituka na bango mpe basoda ya mpiko. Motango ya bato oyo batangamaki ezalaki nkoto tuku mibale na mibale na tuku misato na minei. 
\li1  
\v 8 Bana mibali ya Bekeri : 
\li2 Zemira, Yoashi, Eliezeri, Eliowenayi, Omiri, Yeremoti, Abiya, Anatoti mpe Alemeti. 
\m Bango nyonso nde bazalaki bana mibali ya Bekeri.  
\v 9 Motango ya basoda ya mpiko, kolanda bituka na bango, ezalaki nkoto tuku mibale na nkama mibale. 
\li1  
\v 10 Bakitani ya Yediayeli : 
\li2 Bilani. 
\li1 Bana mibali ya Bilani : 
\li2 Yewushi, Benjame, Ewudi, Kenaana, Zetani, Tarsisi, Ayishaari. 
\m  
\v 11 Kati na molongo ya Yediayeli, bakitani nyonso bazalaki bakambi ya bituka na bango mpe basoda ya mpiko. Motango na bango ezalaki nkoto zomi na sambo na nkama mibale. 
\li1  
\v 12 Bana mibali ya Iri : 
\li2 Shupimi mpe Upime. 
\m Ushimi azalaki mwana mobali ya Aeri. 
\s1 Libota ya Nefitali 
\r (Ebl 46.24; Mit 26.48-50) 
\li1  
\v 13 Bana mibali ya Nefitali : 
\li2 Yatseyeli, Guni, Yetseri mpe Shalumi. 
\m Bazalaki bakitani ya Bila. 
\s1 Libota ya Manase 
\li4  
\v 14 Bakitani ya Manase : 
\li2 Asirieli na nzela ya makangu na ye, moto ya Arami. Abotelaki ye lisusu Makiri, tata ya bato ya Galadi.  
\v 15 Makiri abalaki Maaka oyo azalaki ndeko mwasi ya Upime mpe Shupimi. Kombo ya mwana mobali mosusu ya Manase ezalaki « Tselofikadi. » Tselofikadi abotaki kaka bana basi.  
\v 16 Maaka, mwasi ya Makiri, abotelaki ye lisusu mwana mobali oyo apesaki kombo « Peretsi. » Peretsi azalaki na ndeko mobali, Shereshi, oyo abotaki bana mibali oyo : Ulami mpe Rekemi. 
\li1  
\v 17 Ulami abotaki : 
\li2 Bedani oyo azalaki mwana mobali. 
\li1 Bango nde bazalaki bakitani ya Galadi, mwana mobali ya Makiri, mwana mobali ya Manase. 
\li1  
\v 18 Amoleketi, ndeko mwasi ya Manase, abotaki 
\li2 Ishodi, Abiezeri mpe Mala. 
\b  
\li1  
\v 19 Bana mibali ya Shemida : 
\li2 Ayani, Sishemi, Liki mpe Aniami. 
\s1 Libota ya Efrayimi 
\li1  
\v 20 Bakitani ya Efrayimi : 
\li2 Efrayimi abotaki Shutela, Shutela abotaki Beredi, 
\li2 Beredi abotaki Taati, Taati abotaki Eleada, 
\li2 Eleada abotaki Taati,  
\v 21 Taati abotaki Zabadi, 
\li2 mpe Zabadi abotaki Shutela. 
\li2 Bankolo mboka oyo babotamaki na mokili ya Gati, babomaki Ezeri mpe Eleadi, pamba te balukaki kobotola bibwele ya bato ya Gati.  
\v 22 Tata na bango Efrayimi alelaki bango mikolo ebele, mpe bandeko na ye bayaki kobondisa ye.  
\v 23 Sima na yango, Efrayimi asangisaki lisusu nzoto na mwasi na ye oyo azwaki zemi mpe abotaki mwana mobali. Boye Efrayimi apesaki ye kombo « Beria, » pamba te abotamaki tango pasi ezalaki kati na libota na ye.  
\v 24 Efrayimi azalaki lisusu na mwana mwasi, Shera, oyo atongaki Beti-Oroni ya ngomba mpe ya lubwaku, mpe Uzeni-Shera. 
\b  
\li2  
\v 25 Beria abotaki Refa, Refa abotaki Retsefi, 
\li2 Retsefi abotaki Tela, Tela abotaki Tayani, 
\li2  
\v 26 Taani abotaki Laedani, Laedani abotaki Amiwudi, 
\li2 Amiwudi abotaki Elishama, Elishama abotaki Nuni, 
\li2  
\v 27 Nuni abotaki Jozue. 
\li4  
\v 28 Bakitani ya Efrayimi bazwaki lokola libula mpe bisika ya kovanda : Beteli mpe bamboka na yango ya mike, na ngambo ya este ; Narani, na ngambo ya weste ; Gezeri mpe bamboka na yango ya mike ; Sishemi mpe bamboka na yango ya mike kino na Aya mpe bamboka na yango ya mike.  
\v 29 Bakitani ya Manase bazwaki lokola libula : Beti-Sheani, Taanaki, Megido, Dori mpe bamboka na yango ya mike. Bakitani ya Jozefi, mwana mobali ya Isalaele, bazalaki kovanda na bingumba wana nyonso. 
\s1 Libota ya Aseri 
\r (Ebl 46.17; Mit 26.44-45) 
\li1  
\v 30 Bana mibali ya Aseri : 
\li2 Yimina, Yishiva, Yishivi mpe Beria. 
\m Sera azalaki ndeko na bango ya mwasi. 
\li1  
\v 31 Bana mibali ya Beria : 
\li2 Eberi mpe Malikieli oyo azalaki tata ya bato ya Biriza. 
\li1  
\v 32 Bana mibali ya Eberi : 
\li2 Yafeleti, Shomeri, Otami mpe ndeko na bango ya mwasi Shuwa. 
\li1  
\v 33 Bana mibali ya Yafeleti : 
\li2 Pasaki, Bimali mpe Ashivati. 
\li4 Bango nde bazalaki bana mibali ya Yafeleti. 
\li1  
\v 34 Bana mibali ya Shemeri : 
\li2 Ayi, Roega, Yewuba mpe Arami. 
\li1  
\v 35 Bana mibali ya Elemi, ndeko mobali ya Shemeri : 
\li2 Tsofa, Yimina, Sheleshi mpe Amali. 
\li1  
\v 36 Bana mibali Tsofa : 
\li2 Suwa, Arineferi, Shuwali, Beri, Yimira,  
\v 37 Betseri, Odi, Shama, Shilisha, Yitirani mpe Beera. 
\li1  
\v 38 Bana mibali ya Yeteri : 
\li2 Yefune, Pisipa mpe Ara. 
\li1  
\v 39 Bana mibali ya Ula : 
\li2 Ara, Anieli mpe Ritsiya. 
\li4  
\v 40 Bango nyonso bazalaki bakitani ya Aseri : bazalaki bakambi ya mabota na bango, bato ya lokumu, basoda ya mpiko mpe bakambi ya bakambi ya bituka. Motango ya bato nyonso oyo bakomamaki na buku ya mabota mpe bakoki mpo na bitumba, ezalaki nkoto tuku mibale na motoba. 
\c 8  
\s1 Libota ya Benjame 
\r (Ebl 46.21; Mit 26.38-40) 
\li1  
\v 1 Bana mibali ya Benjame : 
\li2 Bela, mwana ya liboso ; 
\li2 Ashibeli, mwana ya mibale ; Ara, mwana ya misato ; 
\li2  
\v 2 Noa, mwana ya minei ; mpe Rafa, mwana ya mitano. 
\li1  
\v 3 Bana mibali ya Bela : 
\li2 Adari, Gera, Abiwudi,  
\v 4 Abishuwa, Namani, Aowa,  
\v 5 Gera, Shefufani mpe Urami. 
\li1  
\v 6 Tala bana mibali ya Ewudi oyo bazalaki bakambi ya bituka ya bavandi ya Geba, mpe bamemaki bato ya Geba na Manaati : 
\li2  
\v 7 Namani, Ayiya mpe Gera. 
\m Ezalaki Gera, tata ya Uza mpe ya Ayiwudi, nde moto amemaki bango na bowumbu. 
\li1  
\v 8 Shaarayimi abotaki bana na mokili ya Moabi, sima na ye kobengana basi na ye mibale : 
\li2 Ushimi mpe Baara. 
\li1  
\v 9 Na nzela ya Odeshi, mwasi na ye ya sika, abotaki : 
\li2 Yobabi, Tsibia, Mesha, Malikami,  
\v 10 Yeutsi, Sakia mpe Mirima. 
\m Bango nde bazalaki bana mibali ya Shaarayimi, oyo bakomaki bakambi ya bituka. 
\li1  
\v 11 Elongo na Ushimi, mwasi na ye, Shaarayimi abotaki : 
\li2 Abitubi mpe Elipaali. 
\li1  
\v 12 Bana mibali ya Elipaali : 
\li2 Eberi, Misheami mpe Shemeri oyo atongaki bingumba Ono mpe Lodi elongo na bamboka na yango ya mike. 
\p  
\v 13 Beria mpe Shema oyo bazalaki bakambi ya bituka ya bavandi ya Ayaloni babenganaki bato ya Gati. 
\li1  
\v 14 Bana mibali ya Beria : 
\li2 Ayiyo, Shashaki, Yeremoti,  
\v 15 Zebadia, Aradi, Ederi,  
\v 16 Mikaeli, Yishipa mpe Yoa, bana mibali ya Beria. 
\li1  
\v 17 Zebadia, Meshulami, Iziki, Eberi,  
\v 18 Yishimerayi, Yiziliya mpe Yobabi bazalaki bana mibali ya Elipaali. 
\li1  
\v 19 Yakimi, Zikiri, Zabidi,  
\v 20 Elienayi, Tsilitai, Elieli,  
\v 21 Adaya, Beraya mpe Shimirati bazalaki bana mibali ya Shimei. 
\li1  
\v 22 Yishipani, Eberi, Elieli,  
\v 23 Abidoni, Zikiri, Anani,  
\v 24 Anania, Elami, Anitotiya,  
\v 25 Yifidea mpe Penueli bazalaki bana mibali ya Shashaki. 
\li1  
\v 26 Shamisherayi, Shearia, Atalia,  
\v 27 Yaareshia, Eliya mpe Zikiri bazalaki bana mibali ya Yeroami. 
\r (1Ma 9.34-44) 
\li4  
\v 28 Bango nyonso bazalaki bakambi ya bituka ndenge bakomama na buku ya mabota na bango, mpe bazalaki kovanda na Yelusalemi. 
\r (1Ma 9.35-43; 1Sa 14.49-51) 
\li1  
\v 29 Yeyeli, tata ya Gabaoni, azalaki kovanda na Gabaoni. 
\li2 Kombo ya mwasi na ye ezalaki « Maaka. »  
\v 30 Abidoni azalaki mwana na ye ya liboso ya mobali ; sima, Tsuri, Kishi, Bala, Nadabi,  
\v 31 Gedori, Ayiyo mpe Zekeri.  
\v 32 Mikiloti abotaki mwana mobali, Shimea. Bango mpe bazalaki kovanda na Yelusalemi elongo na mabota na bango. 
\li1  
\v 33 Neri abotaki Kishi ; 
\li1 Kishi abotaki Saulo ; 
\li1 Saulo abotaki Jonatan, Maliki-Shuwa, Abinadabi mpe Eshibala. 
\li1  
\v 34 Jonatan abotaki Meriba-Bala ; 
\li1 Meriba-Bala abotaki Mishe. 
\li1  
\v 35 Mishe abotaki : 
\li2 Pitoni, Meleki, Taereya mpe Akazi. 
\li1  
\v 36 Akazi abotaki Yeoyada ; 
\li2 Yeoyada abotaki Alemeti, Azimaveti mpe Zimiri, tata ya Motsa. 
\li1  
\v 37 Zimiri abotaki Motsa ; 
\li2 Motsa abotaki Bineya ; 
\li2 Bineya abotaki Rafa ; 
\li2 Rafa abotaki Eleasa ; 
\li2 mpe Elasa abotaki Atseli. 
\li1  
\v 38 Atseli abotaki bana mibali motoba : 
\li2 Azirikami, Bokuru, Isimaeli, Shearia, Abidiasi mpe Anani. 
\li4 Bango nyonso nde bazalaki bana mibali ya Atseli. 
\b  
\li1  
\v 39 Bana mibali ya Esheki, ndeko mobali ya Atseli : 
\li2 Ulami, mwana na ye ya liboso ; Yewushi, mwana ya mibale ; mpe Elifeleti, mwana ya misato. 
\li2  
\v 40 Bana mibali ya Ulami bazalaki basoda ya mpiko oyo bayebaki kosalela tolotolo. Bazalaki na bana mibali mpe bakoko ya mibali ebele : nkama moko na tuku mitano. 
\li4 Bango nyonso bazalaki bakitani ya Benjame. 
\c 9  
\s1 Bavandi ya Yelusalemi sima na bowumbu 
\r (Ne 11.3-19) 
\p  
\v 1 Batangaki bana nyonso ya Isalaele mpe bakomaki bakombo na bango na buku ya masolo ya bakonzi ya Isalaele. Bato ya Yuda bakendeki na bowumbu na Babiloni mpo na kozanga boyengebene.  
\v 2 Bato ya liboso kati na bana ya Isalaele oyo bazongaki lisusu kovanda na bingumba na bango, ezalaki : ndambo ya bana ya Isalaele, Banganga-Nzambe, Balevi mpe basali ya Tempelo ya Yawe. 
\b  
\li4  
\v 3 Nzokande, ndambo ya bana mibali ya Yuda, ya Benjame, ya Efrayimi mpe ya Manase bazalaki kovanda na Yelusalemi : 
\li1  
\v 4 Utayi, mwana mobali ya Amiwudi, mwana mobali ya Omiri, mwana mobali ya Imiri, mwana mobali ya Bani, moko kati na bakitani ya Peretsi, mwana mobali ya Yuda. 
\li1  
\v 5 Kati na bato ya Shiloni : 
\li2 Asaya, mwana ya liboso, mpe bana na ye ya mibali. 
\li1  
\v 6 Kati na bakitani ya Zera : 
\li2 Yeuweli. 
\li4 Mpe bandeko na bango bazalaki nkama motoba na tuku libwa. 
\b  
\li4  
\v 7 Kati na bakitani ya Benjame : 
\li1 Salu, mwana mobali ya Meshulami, mwana mobali ya Odavia, mwana mobali ya Asenuwa ; 
\li1  
\v 8 Yibinea, mwana mobali ya Yeroami ; 
\li1 Ela, mwana mobali ya Uzi mpe koko ya Mikiri ; 
\li1 mpe Meshulami, mwana mobali ya Shefatia mpe koko ya Reweli, mwana mobali ya Yibiniya. 
\li4  
\v 9 Motango ya bato ya Benjame kolanda ndenge bakomamaki na buku ya mabota na bango, ezalaki nkama libwa na tuku mitano na motoba. Bato oyo nyonso bazalaki bakambi ya bituka na bango. 
\b  
\li4  
\v 10 Kati na Banganga-Nzambe : 
\li1 Yedaeya, Yeoyaribi, Yakini ; 
\li1  
\v 11 Azaria, mwana mobali ya Ilikia, mwana mobali ya Meshulami, mwana mobali ya Tsadoki, mwana mobali ya Merayoti, mwana mobali ya Ayitubi oyo azalaki mokambi ya Ndako ya Nzambe. 
\li1  
\v 12 Ezalaki mpe na Adaya, mwana mobali ya Yeroami, mwana mobali ya Pashuri, mwana mobali ya Malikiya ; 
\li1 mpe Maesayi, mwana mobali ya Adieli, mwana mobali ya Yazera, mwana mobali ya Meshulami, mwana mobali ya Meshilemiti, mwana mobali ya Imeri. 
\li4  
\v 13 Banganga-Nzambe oyo bazalaki bakambi ya bituka, bazalaki nkoto moko na nkama sambo na tuku motoba ; bazalaki na molende makasi mpo na mosala ya Ndako ya Nzambe. 
\b  
\li4  
\v 14 Kati na Balevi : 
\li1 Shemaya, mwana mobali ya Ashubi, mwana mobali ya Azirikami, mwana mobali ya Ashabia, mokitani ya Merari ; 
\li1  
\v 15 mpe Bakibakari, Ereshi, Galali mpe Matania, mwana mobali ya Mishe, mwana mobali ya Zikiri, mwana mobali ya Azafi ; 
\li1  
\v 16 Abidiasi, mwana mobali ya Shemaya, mwana mobali ya Galali, mwana mobali ya Yedutuni ; Berekia, mwana mobali ya Asa, mwana mobali ya Elikana oyo azalaki kovanda na mboka Netofa. 
\b  
\li4  
\v 17 Ezalaki mpe na bakengeli bikuke : 
\li1 Shalumi, Akubi, Talimoni, Ayimani mpe bandeko na bango ya mibali. Shalumi nde azalaki mokonzi na bango. 
\li4  
\v 18 Kino lelo, bakitani ya Shalumi bakengelaka ekuke ya ngambo ya este ya Ndako ya Nzambe, ekuke oyo babengaka ekuke ya Mokonzi. Bango wana nde bakengeli bikuke kati na Balevi. 
\li1  
\v 19 Shalumi, mwana mobali ya Kore, mwana mobali ya Ebiazafi, mwana mobali ya Kore elongo na bandeko na bango mosusu ya libota ya Kore, bazalaki na mokumba ya kokengela ekuke ya Ndako ya kapo ya Bokutani ndenge bakoko na bango bazalaki kokengela ekuke ya molako ya Yawe. 
\li1  
\v 20 Pineasi, mwana mobali ya Eleazari, azalaki kala mokonzi na bango, bongo Yawe azalaki elongo na ye.  
\v 21 Zakari, mwana mobali ya Meshelemia, azalaki mpe mokengeli ekuke ya Ndako ya kapo ya Bokutani. 
\li4  
\v 22 Bango nyonso oyo baponamaki mpo ete bazala bakengeli bikuke bazalaki nkama mibale na zomi na mibale. Bakomaki bakombo na bango na buku ya mabota kolanda bamboka na bango. 
\b  
\p Ezali Davidi mpe Samuele oyo azalaki momoni makambo nde batiaki bango na misala na bango.  
\v 23 Boye, bango elongo na bana na bango bazalaki na mokumba ya kokengela bikuke ya Tempelo ya Yawe ; elingi koloba bikuke ya Ndako ya kapo ya Bokutani.  
\v 24 Bakengeli bikuke bazalaki na bangambo minei : este, weste, nor mpe sude.  
\v 25 Bandeko na bango ya mibali oyo bazalaki na bamboka na bango, basengelaki koyaka tango na tango kosunga bango mikolo sambo.  
\v 26 Kasi bakonzi minei ya bakengeli bikuke bazalaki Balevi oyo bazalaki na mokumba ya kokengela bashambre mpe bomengo ya Ndako ya Nzambe.  
\v 27 Bazalaki kolekisa butu na zingazinga ya Ndako ya Nzambe mpo ete basengelaki kokengela yango mpe kofungola yango tongo nyonso. 
\p  
\v 28 Bamoko kati na bango bazalaki na mokumba ya kobatela bisalelo ya losambo mpe kotanga yango tango nyonso bazalaki kokotisa to kobimisa yango.  
\v 29 Bamosusu kati na bango bazalaki na mokumba ya kobatela bambeki mpe bisalelo nyonso ya Esika ya bule : farine, vino, mafuta, ansa mpe malasi.  
\v 30 Kasi bana mibali ya Banganga-Nzambe bazalaki kosala malasi.  
\v 31 Moto moko kati na Balevi, Matitia, mwana mobali ya liboso ya Shalumi, moto ya Kore, azalaki na mokumba ya kotumba mapa na kikalungu.  
\v 32 Bamosusu kati na bango, bato ya Keati, bazalaki na mokumba ya kobongisa mapa na milongo mpo na basaba nyonso. 
\p  
\v 33 Bayembi oyo bazalaki bakambi ya libota ya Levi, bazalaki tango nyonso kovanda na bashambre ya Ndako ya Nzambe. Bazalaki kosala mosala mosusu te kaka kosala kati na Ndako ya Nzambe butu mpe moyi.  
\v 34 Bango nyonso wana bazalaki bakambi ya libota ya Levi kolanda ndenge bakomamaki na buku ya mabota na bango ; mpe bazalaki kovanda na Yelusalemi. 
\s1 Libota ya Saulo 
\r (1Ma 8.28-38) 
\li1  
\v 35 Yeyeli, tata ya Gabaoni, azalaki kovanda na Gabaoni elongo na Maaka, mwasi na ye. 
\li2  
\v 36 Abidoni azalaki mwana na ye ya liboso ; mpe sima, abotaki lisusu Tsuri, Kishi, Bala, Neri, Nadabi,  
\v 37 Gedori, Ayiyo, Zakari mpe Mikiloti.  
\v 38 Mikiloti abotaki Shimeami. 
\li4 Bango mpe bazalaki kovanda na Yelusalemi elongo na bandeko na bango ya mibali. 
\li1  
\v 39 Neri abotaki Kishi ; Kishi abotaki Saulo ; Saulo abotaki Jonatan, Maliki-Shuwa, Abinadabi mpe Eshibala. 
\li1  
\v 40 Jonatan abotaki mwana mobali, Meriba-Bala. 
\li2 Meriba-Bala abotaki Mishe. 
\li1  
\v 41 Bana mibali ya Mishe : 
\li2 Pitoni, Meleki, Taereya mpe Akazi. 
\li2  
\v 42 Akazi abotaki Yayera ; Yayera abotaki Alemeti, Azimaveti mpe Zimiri ; Zimiri abotaki Motsa ;  
\v 43 Motsa abotaki Bineya ; Bineya abotaki Refaya ; Refaya abotaki Eleasa ; Eleasa abotaki Atseli. 
\li1  
\v 44 Atseli abotaki bana mibali motoba : 
\li2 Azirikami, Bokuru, Isimaeli, Shearia, Abidiasi mpe Anani. Bango nde bazalaki bana mibali ya Atseli. 
\c 10  
\s1 Suka ya bomoi ya Saulo 
\r (1Sa 31.1-13; 2Sa 1.4-12) 
\p  
\v 1 Bato ya Filisitia babundisaki bana ya Isalaele. Bana ya Isalaele bakimaki liboso na bango mpe mingi kati na bango bakufaki na ngomba Giliboa.  
\v 2 Nzokande, bato ya Filisitia batingamaki kolanda Saulo mpe bana na ye ya mibali, bongo babomaki Jonatan, Abinadabi mpe Maliki-Shuwa oyo bazalaki bana na ye.  
\v 3 Bitumba ekomaki lisusu makasi mpo na koluka bomoi ya Saulo. Tango basoda oyo babundaka na matolotolo bamonaki ye, Saulo alengaki na somo makasi wana asosolaki ete bakoboma ye.  
\v 4 Saulo alobaki na soda oyo amemaki bibundeli na ye : « Bimisa mopanga na yo mpe boma ngai, noki te bato oyo bakatama ngenga te bakoya kosakanela ngai. » 
\p Kasi soda yango abangaki mpe aboyaki koboma ye ; bongo ye moko Saulo azwaki mopanga mpe amibwakaki na likolo na yango.  
\v 5 Tango soda yango amonaki ete Saulo akufi, ye mpe amibwakaki na likolo ya mopanga mpe akufaki. 
\p  
\v 6 Ezalaki bongo nde Saulo, bana na ye misato ya mibali mpe libota na ye mobimba bakufaki elongo.  
\v 7 Tango bana nyonso ya Isalaele, oyo bazalaki kovanda na lubwaku, bamonaki ete mampinga esili kopanzana, mpe ete Saulo mpe bana na ye ya mibali bakufi, basundolaki bingumba na bango mpe bakimaki. Bato ya Filisitia bayaki kovanda na bingumba yango. 
\p  
\v 8 Mokolo oyo elandaki, tango bato ya Filisitia bayaki mpo na kolongola biloko oyo ezalaki na banzoto ya bibembe, bamonaki Saulo mpe bana na ye ya mibali oyo bakufaki na ngomba Giliboa.  
\v 9 Bazwaki biloko na ye, bamemaki moto na ye elongo na bibundeli na ye, mpe batindaki bato na mokili mobimba ya bato ya Filisitia mpo ete bapanza sango malamu oyo ya elonga epai ya banzambe na bango ya bikeko mpe epai ya bato na bango.  
\v 10 Batiaki bibundeli na ye na tempelo ya banzambe na bango mpe badiembikaki mokuwa ya moto na ye kati na tempelo ya Dagoni. 
\p  
\v 11 Tango bavandi nyonso ya Yabeshi kati na Galadi bayokaki makambo nyonso oyo bato ya Filisitia basalaki Saulo,  
\v 12 bilombe na bango nyonso batelemaki, bakendeki kozwa bibembe ya Saulo mpe ya bana na ye ya mibali ; mpe bamemaki yango na Yabeshi. Sima na bango kokunda mikuwa na bango na Yabeshi, na se ya nzete ya terebente, bakilaki bilei mikolo sambo. 
\b  
\p  
\v 13 Saulo akufaki mpo ete atosaki Yawe te, abatelaki Liloba na Yawe te mpe akendeki kotuna makambo epai ya moto oyo asololaka na milimo ya bakufi, na esika ya kotuna makambo epai na Yawe.  
\v 14 Boye Yawe abomaki ye mpe apesaki bokonzi epai ya Davidi, mwana mobali ya Izayi. 
\c 11  
\s1 Davidi akomi mokonzi ya Isalaele 
\r (2Sa 5.1-3) 
\p  
\v 1 Bato nyonso ya Isalaele basanganaki na Ebron, epai ya Davidi mpe balobaki : « Biso na yo, tozali nzoto moko mpe makila moko na yo.  
\v 2 Na kala, ezala na mikolo oyo Saulo azalaki mokonzi, yo nde ozalaki kokamba mampinga ya Isalaele na bitumba. Nzokande, Yawe, Nzambe na yo, alobaki na yo : ‹ Yo nde okokamba bato na Ngai, Isalaele, mpe okokoma mokambi na bango. › » 
\p  
\v 3 Tango bampaka nyonso ya Isalaele bayaki na Ebron epai ya mokonzi, Davidi asalaki elongo na bango boyokani, na Ebron, liboso ya Yawe ; mpe bapakolaki Davidi mafuta mpo ete akoma mokonzi ya Isalaele, kolanda Liloba na Yawe na nzela ya Samuele. 
\s1 Davidi abotoli Yelusalemi 
\r (2Sa 5.6-10) 
\p  
\v 4 Davidi mpe bato nyonso ya Isalaele bakendeki kobundisa Yelusalemi oyo bazalaki kobenga « Yebusi. » Bato oyo bazalaki kovanda kuna bazali bato ya Yebusi.  
\v 5 Bavandi ya Yebusi balobaki na Davidi : « Okokota awa te ! » 
\p Kasi Davidi abotolaki ndako makasi ya Siona, oyo ezali engumba ya Davidi.  
\v 6 Davidi alobaki na bato na ye : « Moto oyo akobundisa mpe akolonga bato ya Yebusi, akokoma mokonzi ya liboso ya basoda. » 
\p Joabi, mwana mobali ya Tseruya, atelemaki moto ya liboso mpo na kobundisa bato ya Yebusi mpe akomaki mokonzi ya liboso ya mampinga.  
\v 7 Davidi avandaki na ndako yango oyo batonga makasi ; yango wana babengaki yango « Engumba ya Davidi. »  
\v 8 Mpe atongaki bandako zingazinga na yango, longwa na Milo kino na mir ya kati. Bongo Joabi abongisaki bisika oyo etikalaki kati na engumba.  
\v 9 Nguya ya Davidi ezalaki komata se komata, mpe Yawe, Nkolo-Na-Nguya-Nyonso, azalaki elongo na ye. 
\s1 Basoda ya mpiko ya Davidi 
\r (2Sa 23.8-39; 1Ma 27.2-15) 
\p  
\v 10 Tala bakombo ya bakonzi ya basoda ya mpiko ya Davidi oyo, elongo na Isalaele mobimba, basungaki ye mpo na kokomisa bokonzi na ye makasi, kolanda liloba oyo Yawe alobaki na tina na Isalaele.  
\v 11 Tala bakombo ya basoda ya mpiko ya Davidi : 
\p Yashobeami, mwana mobali ya Akimoni, azalaki mokonzi ya limpinga ya basoda misato ya mpiko ; abomaki na likonga bato nkama misato na etumba moko. 
\p  
\v 12 Eleazari, mwana mobali ya Dodo, moto ya Aoyi : azalaki moko kati na limpinga ya basoda misato ya mpiko ;  
\v 13 mpe azalaki elongo na Davidi, na engumba Pasi-Damini, tango bato ya Filisitia basanganaki mpo na bitumba, mpe basoda ya Isalaele bakimaki liboso na bango. Ezalaki kuna mpe na elanga moko etonda na bambuma ya orje.  
\v 14 Kasi basoda ya Eleazari babombamaki kati na elanga, babundelaki yango mpe babomaki bato ya Filisitia. Yawe apesaki bango elonga monene. 
\p  
\v 15 Kati na basoda tuku misato ya mpiko, misato bayaki epai ya Davidi, na libanga monene oyo ezalaki pene ya ebombamelo ya mabanga ya Adulami. Nzokande, basoda ya bato ya Filisitia batongaki molako na bango kati na lubwaku ya bakitani ya Rafa.  
\v 16 Na tango yango, Davidi azalaki kati na ebombamelo moko batonga makasi, mpe basoda ya Filisitia bazalaki kati na Beteleemi.  
\v 17 Mbala moko, Davidi ayokaki posa ya mayi mpe alobaki : « Nani akomemela ngai mayi ya libulu oyo ezali pene ya ekuke ya Beteleemi mpo ete namela ? »  
\v 18 Basoda nyonso misato ya mpiko bakotaki na mayele kati na molako ya bato ya Filisitia, batokaki mayi na libulu oyo ezali pene ya ekuke ya Beteleemi mpe bamemaki yango epai ya Davidi. Kasi Davidi aboyaki komela mayi yango ; asopaki yango na mabele lokola likabo ya masanga mpo na Yawe.  
\v 19 Davidi alobaki : « Tika ete Nzambe na ngai apesa ngai etumbu soki nameli mayi oyo ! Boni, namela penza mayi oyo ezali lokola makila ya bato oyo bandimaki kokende mpe batekaki milimo na bango mpo ete batoka yango ? » 
\p Davidi aboyaki komela mayi yango. Yango nde misala ya kokamwa oyo basoda misato ya mpiko basalaki. 
\p  
\v 20 Abishayi, ndeko mobali ya Joabi, azalaki mokonzi ya basoda misato ya mpiko. Abundisaki bato nkama misato na likonga na ye mpe abomaki bango. Boye, kati na bango misato, ye nde akendeki sango koleka.  
\v 21 Kati na basoda misato ya mpiko ya limpinga ya mibale, ye nde azwaki lokumu koleka mpe akomaki mokonzi na bango, kasi akokanaki te na basoda misato ya limpinga ya liboso. 
\p  
\v 22 Benaya, moto ya mboka Kabitseli mpe mwana mobali ya Yeoyada, azalaki soda ya mpiko mpe asalaki makambo ebele ya kokamwa : abomaki bilombe mibale ya mboka Moabi ; mpe na mokolo moko ya mvula ya pembe, akitaki na libulu moko ya mayi mpe abomaki kuna nkosi.  
\v 23 Ye mpe moto abomaki mbinga mobali moko ya Ejipito, oyo azalaki na bametele mibale na basantimetele tuku mitano na molayi, mpe asimbaki na loboko na ye likonga moko lokola libaya oyo basali bilamba na maboko basalelaka. Abundisaki moto ya Ejipito na lingenda, abotolaki ye likonga oyo azalaki na yango na loboko mpe abomaki ye na likonga na ye moko. 
\p  
\v 24 Yango nde misala ya kokamwa oyo Benaya, mwana mobali ya Yeoyada, asalaki ; ye mpe akendeki sango kati na basoda misato ya mpiko.  
\v 25 Kati na basoda tuku misato ya mpiko, ye nde azalaki na lokumu monene koleka, kasi akokanaki te na basoda misato ya mpiko ya limpinga ya liboso. Mpe Davidi akomisaki ye mokonzi ya bakengeli na ye. 
\b  
\li4  
\v 26 Basoda ya mpiko bazalaki : 
\b  
\li1 Asaeli, ndeko mobali ya Joabi ; 
\li1 Elanani, mwana mobali ya Dodo, moto ya Beteleemi ; 
\li1  
\v 27 Shamoti, moto ya Arori ; 
\li1 Eletsi, moto ya Peloni ; 
\li1  
\v 28 Ira, mwana mobali ya Ikeshi, moto ya Tekoa ; 
\li1 Abiezeri, moto ya Anatoti ; 
\li1  
\v 29 Sibekayi, moto ya Usha ; 
\li1 Ilayi, moto ya Aoyi ; 
\li1  
\v 30 Maarayi, moto ya Netofa ; 
\li1 Eledi, mwana mobali ya Baana, moto ya Netofa ; 
\li1  
\v 31 Itayi, mwana mobali ya Ribayi, moto ya Gibea ya libota ya Benjame ; 
\li1 Benaya, moto ya Piratoni ; 
\li1  
\v 32 Urayi, moto ya mabwaku ya Gashi ; 
\li1 Abieli, moto ya Beti-Ariba ; 
\li1  
\v 33 Azimaveti, moto ya Baarumi ; 
\li1 Eliaba, moto ya Shaaliboni ; 
\li1  
\v 34 Beni-Ashemi, moto ya Gizoni ; 
\li1 Jonatan, mwana mobali ya Shage, moto ya Arari ; 
\li1  
\v 35 Ayami, mwana mobali ya Sakari, moto ya Arari ; 
\li1 Elifali, mwana mobali ya Uri ; 
\li1  
\v 36 Eferi, moto ya Mekera ; 
\li1 Ayiya, moto ya Peloni ; 
\li2  
\v 37 Etsiro, moto ya Karimeli ; 
\li1 Naarayi, mwana mobali ya Ezibayi ; 
\li1  
\v 38 Joeli, ndeko mobali ya Natan ; 
\li1 Mibiari, mwana mobali ya Agiri ; 
\li1  
\v 39 Tseleki, moto ya Amoni ; 
\li1 Naarayi, moto ya Beroti, oyo azalaki komema bibundeli ya Joabi, mwana mobali ya Tseruya ; 
\li1  
\v 40 Ira mpe Garebi, bato ya Yeteri ; 
\li1  
\v 41 Iri, moto ya Iti ; 
\li1 Zabadi, mwana mobali ya Akilayi ; 
\li1  
\v 42 Adina, mwana mobali ya Shiza ya ekolo ya Ribeni mpe mokambi ya mampinga tuku misato ya mpiko ; 
\li1  
\v 43 Anani, mwana mobali ya Maaka ; 
\li1 Jozafati, moto ya Mitini ; 
\li1  
\v 44 Uzia, moto ya Ashitaroti ; 
\li1 Shama mpe Yeyeli, bana mibali ya Otami, moto ya Aroeri ; 
\li1  
\v 45 Yediayeli, mwana mobali ya Shimiri ; 
\li1 Yoa, ndeko na ye ya mobali, moto ya Tishi ; 
\li1  
\v 46 Elieli, moto ya Maavimi ; 
\li1 Yeribayi mpe Yoshavia, bana mibali ya Elinaami ; 
\li1 Yitima, moto ya Moabi ; 
\li1  
\v 47 Elieli, Obedi mpe Yaasieli, bato ya Metsobaya. 
\c 12  
\s1 Basoda ya mpiko basangani na Davidi 
\p  
\v 1 Na tango oyo Davidi akimaki na Tsikilagi mpo na kobombama Saulo, mwana mobali ya Kishi, bato bayaki kosangana na ye. Bazalaki basoda ya mpiko oyo babongami mpo na kosalisa ye na bitumba.  
\v 2 Bazalaki kobunda na batolotolo mpe kosalela malamu loboko ya mwasi mpe ya mobali mpo na kobwaka mabanga mpe kobeta bambanzi ya batolotolo. Bazalaki bato ya ekolo moko na Saulo : ekolo ya Benjame. 
\b  
\li4  
\v 3 Tala bakombo na bango : 
\li1 Akiezeri, mokonzi na bango ; 
\li1 Joasi, mwana mibali ya Shemaa, moto ya Gibea ; 
\li1 Yezieli mpe Peleti, bana mibali ya Azimaveti ; 
\li1 Beraka ; Jewu, moto ya Anatoti ; 
\li1  
\v 4 Yishimaeya, moto ya Gabaoni, moko kati na lisanga ya basoda ya mpiko tuku misato mpe azalaki mokonzi ya lisanga yango ; 
\li1  
\v 5 Jeremi, Yaazieli, Yoanani, Yozabadi, moto ya Gedera ; 
\li1  
\v 6 Elewuzayi, Yerimoti, Bealia, Shemaria, Shefatia, moto ya Arofi ; 
\li1  
\v 7 Elikana, Yishiya, Azareeli, Yoezeri mpe Yashobeami : bango nyonso bazalaki bato ya libota ya Kore ; 
\li1  
\v 8 Yoela mpe Zebadia, bana mibali ya Yeroami, moto ya Gedori. 
\p  
\v 9 Ndambo ya bato ya ekolo ya Gadi bakabwanaki na Saulo mpo na kokende epai ya Davidi, na ndako makasi ya esobe. Bazalaki basoda ya mpiko oyo bayebi kobunda malamu mpe kosalela malamu nguba mpe makonga. Bazalaki makasi lokola nkosi mpe mbangu lokola mboloko na ngomba.  
\v 10 Ezeri azalaki mokonzi na bango ; Abidiasi, mokonzi ya mibale ; Eliabi, mokonzi ya misato ;  
\v 11 Mishimana, mokonzi ya minei ; Jeremi, mokonzi ya mitano ;  
\v 12 Atayi, mokonzi ya motoba ; Elieli, mokonzi ya sambo ;  
\v 13 Yoanani, mokonzi ya mwambe ; Elizabadi, mokonzi ya libwa ;  
\v 14 Jeremi, mokonzi ya zomi ; mpe Makibanayi, mokonzi ya zomi na moko.  
\v 15 Bato oyo ya libota ya Gadi bazalaki bango nyonso bakonzi ya basoda. Mokonzi oyo azalaki na makasi moke akokaki kobunda na bato nkama moko, mpe oyo alekaki makasi akokaki kobunda na bato nkoto moko. 
\p  
\v 16 Ezalaki bango nde bakatisaki mayi ya Yordani, na sanza ya liboso, tango mayi ya ebale etondaki makasi na bangambo nyonso, mpe bakimisaki bato nyonso oyo bazalaki kovanda na mabwaku, ezala na ngambo ya este to ya weste. 
\p  
\v 17 Bato mosusu ya libota ya Benjame mpe ya Yuda bayaki lisusu kosangana na Davidi na ndako na ye ya makasi.  
\v 18 Davidi abimaki mpo na kokutana na bango mpe alobaki : « Soki boyei epai na ngai na makanisi ya kimia mpo ete bosunga ngai, wana ngai mpe bino tokosala boyokani ; kasi soki boyei mpo na koteka ngai epai ya banguna na ngai wana maboko na ngai esali mabe te, tika ete Nzambe ya batata na biso azala motatoli mpe akata likambo ! » 
\p  
\v 19 Boye, Molimo na Nzambe akitelaki Amasayi, mokonzi ya lisanga ya basoda tuku misato, mpe alobaki : 
\q1 « Oh Davidi, tozali ya yo ! 
\q2 Tozali elongo na yo, oh mwana mobali ya Izayi ! 
\q1 Tika ete kimia ezala na yo, ezala na yo penza ; 
\q2 tika ete kimia ezala na moto oyo azali kosunga yo, 
\q2 pamba te Nzambe na yo azali kosunga yo. » 
\p Boye Davidi ayambaki bango mpe akomisaki bango bakonzi ya mampinga na ye. 
\p  
\v 20 Ndambo ya bato ya Manase bakendeki kosala boyokani elongo na Davidi tango akendeki elongo na basoda ya Filisitia, mpo na kobundisa Saulo. Kasi Davidi elongo na bato na ye balongaki te kosunga bato ya Filisitia, pamba te sima na bakambi na bango koyokana, babenganaki Davidi mpe balobaki : « Davidi alingi kobomisa biso mpo ete azongisa boyokani na nkolo na ye Saulo ! » 
\p  
\v 21 Tango Davidi akendeki na Tsikilagi, tala bato ya ekolo ya Manase oyo bakendeki kosala boyokani elongo na ye : Adina, Yozabadi, Yediayeli, Mikaeli, Yozabadi, Eliwu mpe Tsilitai. Moko na moko kati na bango azalaki mokonzi ya bato nkoto moko kati na libota ya Manase.  
\v 22 Basungaki makasi Davidi mpe mampinga na ye, pamba te bango nyonso bazalaki basoda ya mpiko mpe bakomaki bakonzi ya basoda.  
\v 23 Mokolo na mokolo, bato bazalaki koya kosunga Davidi kino mampinga na ye ekomaki monene makasi lokola mampinga ya Nzambe. 
\s1 Basoda mosusu basangani na Davidi 
\li4  
\v 24 Tala motango ya basoda oyo babongisami mpo na bitumba, mpe bayaki epai ya Davidi, na Ebron, mpo na kokweyisa bokonzi ya Saulo mpe kopesa yango epai ya Davidi ndenge Yawe alobaki : 
\b  
\li1  
\v 25 Bato ya Yuda oyo bamemaka nguba mpe makonga : basoda nkoto motoba na nkama mwambe ; 
\li1  
\v 26 bato ya libota ya Simeoni : basoda ya mpiko nkoto sambo na nkama moko ; 
\li1  
\v 27 bato ya libota ya Levi : basoda nkoto minei na nkama motoba ;  
\v 28 mpe lisusu Yeoyada, mokonzi ya libota ya Aron, elongo na basoda na ye nkoto misato na nkama sambo,  
\v 29 mpe Tsadoki, elenge soda ya mpiko elongo na bakambi ya libota na ye tuku mibale na mibale ; 
\li1  
\v 30 kati na libota ya Benjame, bato ya libota ya Saulo : basoda nkoto misato, pamba te mingi kati na bango bandimaki kaka kosalela ndako ya Saulo ; 
\li1  
\v 31 kati na libota ya Efrayimi : basoda ya mpiko nkoto tuku mibale na nkama mwambe oyo bakenda sango kati na mabota na bango ; 
\li1  
\v 32 kati na ndambo ya libota ya Manase : basoda ya mpiko nkoto zomi na mwambe oyo baponamaki na bakombo na bango mpo na kokomisa Davidi mokonzi ; 
\li1  
\v 33 kati na libota ya Isakari : bakambi nkama mibale bayaki elongo na bato oyo bango bazalaki kokamba kati na libota na bango ; bazalaki na mayele ya kososola tango mpo na kolakisa Isalaele lolenge ya kosala liboso ya makambo ; 
\li1  
\v 34 kati na libota ya Zabuloni : basoda ya mpiko nkoto tuku mitano oyo bayebi kosalela bibundeli nyonso mpe babundaka na motema moko ; 
\li1  
\v 35 kati na libota ya Nefitali : bakonzi ya basoda nkoto moko, elongo na basoda nkoto tuku misato na sambo oyo babundaka na nguba mpe makonga ; 
\li1  
\v 36 kati na libota ya Dani : basoda oyo babongisama mpo na bitumba, nkoto tuku mibale na mwambe na nkama motoba ; 
\li1  
\v 37 kati na libota ya Aseri : basoda oyo babongisama mpo na bitumba, nkoto tuku minei ; 
\li1  
\v 38 kati na mabota oyo ezalaki na este ya Yordani : libota ya Ribeni, ya Gadi mpe ndambo ya libota ya Manase, basoda nkoto nkama moko na tuku mibale elongo na bibundeli nyonso ya bitumba. 
\b  
\li4  
\v 39 Basoda oyo nyonso bayaki na Ebron, na milongo ya bitumba mpe na motema moko mpo na kokomisa Davidi mokonzi na Isalaele mobimba. Bana ya Isalaele oyo batikalaki, bango mpe bazalaki na motema moko mpo na kokomisa Davidi mokonzi.  
\v 40 Basalaki kuna mikolo misato elongo na Davidi ; bazalaki kolia mpe komela biloko oyo bandeko na bango babongiselaki bango. 
\p  
\v 41 Ezala bato oyo bawutaki na libota ya Isakari, ya Zabuloni, ya Nefitali : bango mpe bamemaki bilei likolo ya ba-ane, bashamo, bamile mpe bangombe : farine, gato oyo basala na bambuma ya figi, gato oyo basala na bambuma ya vino ekawuka, masanga ya vino, mafuta, bangombe mpe bameme ebele, pamba te esengo ezalaki kati na Isalaele. 
\c 13  
\s1 Davidi amemi Sanduku na ndako ya Obedi-Edomi 
\r (2Sa 6.1-11) 
\p  
\v 1 Davidi asangisaki bakonzi ya basoda, bakonzi ya bankoto mpe bakonzi ya bankama elongo na bato mosusu ya lokumu.  
\v 2 Davidi alobaki na lisanga mobimba ya Isalaele : « Soki bomoni yango malamu mpe soki yango ezali mokano na Yawe, Nzambe na biso, tika ete totinda sango epai ya bandeko na biso oyo batikali na bituka nyonso ya Isalaele mpe epai ya Banganga-Nzambe elongo na Balevi, kati na bingumba oyo bango bazali kovanda mpo ete baya kosangana na biso.  
\v 3 Tozongisa Sanduku ya Nzambe na biso epai na biso, pamba te tolandelaki yango te tango Saulo azalaki mokonzi. » 
\p  
\v 4 Lisanga mobimba endimaki ete basala bongo, pamba te likambo yango emonanaki malamu na miso ya bato nyonso.  
\v 5 Davidi asangisaki bana nyonso ya Isalaele longwa na moluka ya Ejipito kino na Lebo-Amati, mpo na kozongisa Sanduku ya Nzambe wuta na Kiriati-Yearimi. 
\p  
\v 6 Davidi elongo na basoda nyonso ya Isalaele bakendeki na Baala, na Kiriati-Yearimi oyo ezali kati na Yuda, mpo na kolongola kuna Sanduku ya Nzambe, oyo, liboso na yango, bazalaki kobelela Kombo ya Yawe oyo avandaka kati na basheribe.  
\v 7 Batiaki Sanduku ya Nzambe na likolo ya shario ya sika mpe bamemaki yango wuta na ndako ya Abinadabi. Uza mpe Ayiyo nde bazalaki kotambolisa shario yango.  
\v 8 Davidi mpe bato nyonso ya Isalaele bazalaki kosepela makasi na liboso ya Nzambe, na koyemba mpe na kobeta mandanda, banzenze, bambunda ya mike-mike, manzanza mpe bakelelo.  
\v 9 Tango bakomaki na etando ya Kidoni, Uza asembolaki loboko na ye mpo na kosimba Sanduku ya Nzambe, pamba te bangombe eselumukaki mpe elingaki kokweyisa Sanduku ya Nzambe.  
\v 10 Yawe asilikelaki Uza makasi mpe abetaki ye mpo ete asembolaki loboko na ye mpe asimbaki Sanduku ya Nzambe. Boye, Uza akufaki kaka wana liboso ya Nzambe. 
\p  
\v 11 Davidi asilikaki makasi mpo ete Yawe afungolaki lidusu na kobeta Uza ; yango wana, kino na mokolo ya lelo, babengaka esika yango « Peretsi-Uza\f + \fr 13.11 \ft Peretsi-Uza elingi koloba : lidusu ya Uza.\f*. »  
\v 12 Na mokolo wana, Davidi abangaki Nzambe mpe amitunaki : « Ndenge nini namema Sanduku ya Nzambe epai na ngai ? » 
\p  
\v 13 Boye, Davidi amemaki te Sanduku ya Nzambe epai na ye, kati na engumba ya Davidi ; kasi atiaki yango na ndako ya Obedi-Edomi, moto ya Gati.  
\v 14 Sanduku ya Nzambe evandaki sanza misato kati na ndako ya Obedi-Edomi, mpe Yawe apambolaki libota ya Obedi-Edomi mpe biloko na ye nyonso. 
\c 14  
\s1 Davidi na Yelusalemi 
\r (2Sa 5.11-16; 1Ma 3.5-8) 
\p  
\v 1 Irami, mokonzi ya Tiri, atindaki bantoma epai ya Davidi mpo ete bamemela ye mabaya ya sedele, bato oyo bapasolaka mabanga mpe basharipantie ; mpe batongelaki ye ndako.  
\v 2 Davidi asosolaki ete Yawe nde akomisaki ye mokonzi ya Isalaele mpe ete azalaki kotombola bokonzi na ye makasi mpo na Isalaele, bato na Ye. 
\p  
\v 3 Davidi abalaki lisusu basi ebele kati na Yelusalemi mpe abotaki lisusu bana ebele ya mibali mpe ya basi.  
\v 4 Tala bakombo ya bana na ye ya mibali oyo babotamaki na Yelusalemi : Shamuwa, Shobabi, Natan, Salomo,  
\v 5 Yibari, Elishuwa, Elipeleti,  
\v 6 Noga, Nefegi, Yafia,  
\v 7 Elishama, Beliada mpe Elifeleti. 
\s1 Davidi alongi bato ya Filisitia 
\r (2Sa 5.17-25) 
\p  
\v 8 Tango bato ya Filisitia bayokaki sango ete bapakoli Davidi mafuta mpo ete akoma mokonzi ya Isalaele mobimba, bango nyonso bakendeki koluka ye. Kasi tango Davidi ayokaki sango ya mabongisi na bango, abimaki mpo na kokutana na bango.  
\v 9 Bato ya Filisitia bakomaki mpe bapanzanaki na lubwaku ya bakitani ya Rafa.  
\v 10 Davidi atunaki Nzambe : 
\pi1 — Nakoki solo kokende kobundisa bato ya Filisitia ? Okokaba bango solo na maboko na ngai ? 
\p Yawe azongiselaki ye : 
\pi1 — Kende, pamba te nakokaba bango na maboko na yo. 
\p  
\v 11 Bato ya Filisitia bamataki na Bali-Peratsimi, mpe Davidi alongaki bango kuna. Bongo Davidi alobaki : « Na nzela ya loboko na ngai, Nzambe afungoleli ngai nzela kati na banguna na ngai, ndenge mayi epasolaka nzela. » 
\p Yango wana babengaki esika yango Bala-Peratsimi\f + \fr 14.11 \ft Bali-Peratsimi elingi koloba : Nkolo ya banzela.\f*.  
\v 12 Bato ya Filisitia basundolaki kuna banzambe na bango, mpe Davidi apesaki mitindo ete batumba yango na moto. 
\p  
\v 13 Sima na mwa tango, bato ya Filisitia bayaki mpe bapanzanaki lisusu kati na lubwaku.  
\v 14 Bongo Davidi atunaki lisusu Nzambe, mpe Nzambe azongiselaki ye : « Tango okobundisa bango, kolanda bango na sima te ; kasi tambola mopanzi, mosika na bango. Bongo tango okokoma epai bango bazali, bimela bango na liboso, liboso ya zamba ya banzete ya mirie\f + \fr 14.14 \ft Mirie ezali lolenge moko ya nzete oyo mbuma na yango ezalaka mwindo mpe esungaka mpo na kokawusa pota.\f*.  
\v 15 Tango okoyoka lokito ya makolo ya bato na likolo ya banzete ya mirie, na tango wana nde okobima mbala moko mpo na kobunda ; pamba te ekolakisa ete Nzambe abimi liboso na yo mpo na kobeta mampinga ya bato ya Filisitia. » 
\p  
\v 16 Davidi asalaki ndenge Nzambe atindaki ye mpe abomaki bato ya Filisitia, longwa na Gabaoni kino na Gezeri.  
\v 17 Kombo ya Davidi ekendeki sango na mokili mobimba mpe Yawe asalaki ete bikolo nyonso ebanga Davidi. 
\c 15  
\s1 Bamemi Sanduku na Yelusalemi 
\p  
\v 1 Tango Davidi asilisaki kotonga bandako mpo na ye moko kati na engumba ya Davidi, abongisaki esika mpo na Sanduku ya Nzambe mpe atelemisaki ndako ya kapo mpo na yango.  
\v 2 Davidi alobaki : « Moto moko te, longola kaka Balevi, akoki komema Sanduku ya Boyokani ya Nzambe, pamba te Yawe aponaki bango mpo na komema Sanduku na Ye mpe kosala mosala na Ye mpo na libela. » 
\p  
\v 3 Davidi asangisaki kati na Yelusalemi bana nyonso ya Isalaele mpo na komema Sanduku ya Yawe na esika oyo abongisaki mpo na yango. 
\b  
\li4  
\v 4 Davidi asangisaki lisusu bakitani ya Aron mpe Balevi : 
\b  
\li1  
\v 5 Mpo na bakitani ya Keati : 
\li2 mokambi Urieli elongo na bandeko na ye ya libota nkama moko na tuku mibale ; 
\li1  
\v 6 mpo na bakitani ya Merari : 
\li2 mokambi Asaya elongo na bandeko na ye ya libota nkama mibale na tuku mibale ; 
\li1  
\v 7 mpo na bakitani ya Gerishoni : 
\li2 mokambi Joeli elongo na bandeko na ye ya libota, nkama moko na tuku misato ; 
\li1  
\v 8 mpo na bakitani ya Elitsafani : 
\li2 mokambi Shemaya elongo na bandeko na ye ya libota, nkama mibale ; 
\li1  
\v 9 mpo na bakitani ya Ebron : 
\li2 mokambi Elieli elongo na bandeko na ye ya libota, tuku mwambe ; 
\li1  
\v 10 mpo na bakitani ya Uzieli : 
\li2 mokambi Aminadabi elongo na bandeko na ye ya libota, nkama moko na zomi na mibale. 
\p  
\v 11 Davidi abengaki Banganga-Nzambe Tsadoki mpe Abiatari elongo na Balevi oyo : Urieli, Asaya, Joeli, Shemaya, Elieli mpe Aminadabi.  
\v 12 Alobaki na bango : « Bozali bakambi ya mabota ya Balevi, bino elongo na bandeko ya mabota na bino ; bomipetola mpo na komema Sanduku ya Yawe, Nzambe ya Isalaele, na esika oyo nabongisi mpo na yango.  
\v 13 Pamba te lokola bino Balevi bozalaki te na mbala ya liboso, yango wana Yawe, Nzambe na biso, asilikelaki biso makasi ; pamba te totunaki Ye te ndenge nini tokokaki komema yango kolanda mibeko. » 
\p  
\v 14 Boye, Banganga-Nzambe mpe Balevi bamipetolaki mpo na komema Sanduku ya Yawe, Nzambe ya Isalaele.  
\v 15 Bongo Balevi bamemaki na banzete Sanduku ya Nzambe na mapeka na bango ndenge kaka Moyize atindaki, kolanda Liloba na Yawe. 
\s1 Babeti miziki mpe bakengeli bikuke 
\p  
\v 16 Davidi alobaki na bakambi ya Balevi ete bapona, kati na bandeko na bango, bayembi mpo na koyemba banzembo ya esengo, na bibetelo mindule : nzenze, lindanda mpe manzanza.  
\v 17 Balevi baponaki Emani, mwana mobali ya Joeli ; Azafi, mwana mobali ya Berekia, kati na bandeko na ye ya mibali ; Etani, mwana mobali ya Kushaya, kati na bana ya Merari, na bandeko na ye ya mibali. 
\p  
\v 18 Mpe mpo na kosunga bango, baponaki Balevi mosusu : Zakari, Beni, Yazieli, Shemiramoti, Yeyeli, Uni, Eliabi, Benaya, Maaseya, Matitia, Elifele, Mikineya, Obedi-Edomi mpe Yeyeli. Bango nyonso bazalaki bakengeli bikuke.  
\v 19 Babeti miziki : Emani, Azafi mpe Etani ; bango bazalaki kobeta manzanza oyo basala na bronze.  
\v 20 Zakari, Azieli, Shemiramoti, Yeyeli, Uni, Eliabi, Maaseya mpe Benaya ; bango bazalaki kobeta nzenze na mongongo ya soprano.  
\v 21 Matitia, Elifele, Mikineya, Obedi-Edomi, Yeyeli mpe Azazia ; bango bazalaki kobeta mandanda ya basinga mwambe mpo na kotambolisa banzembo.  
\v 22 Kenania, mokambi ya Balevi, aponamaki mpo na kotambolisa banzembo ; pamba te ayebaki mosala yango malamu.  
\v 23 Berekia mpe Elikana, bazalaki bakengeli ya Sanduku ya Boyokani. 
\p  
\v 24 Banganga-Nzambe Shebania, Jozafati, Netaneeli, Amasayi, Zakari, Benaya mpe Eliezeri ; bazalaki kobeta kelelo liboso ya Sanduku ya Nzambe. Obedi-Edomi mpe Yeyiya bazalaki mpe bakengeli Sanduku ya Boyokani. 
\s1 Sanduku ekomi na Yelusalemi 
\r (2Sa 6.12-19) 
\p  
\v 25 Davidi, bakambi ya Isalaele mpe bakonzi ya basoda nkoto moko bakendeki kozwa na esengo Sanduku ya Boyokani ya Yawe wuta na ndako ya Obedi-Edomi.  
\v 26 Mpe mpo ete Yawe asunga Balevi oyo bazalaki komema Sanduku ya Boyokani ya Yawe, babonzaki lokola mbeka bangombe sambo ya mibali mpe bameme sambo ya mibali.  
\v 27 Davidi elongo na Balevi nyonso oyo bazalaki komema Sanduku ya Boyokani, bayembi mpe Kenania, mokambi ya bayembi : bango nyonso balataki banzambala ya lino ya talo. Kasi Davidi abakisaki lisusu efode ya lino na likolo.  
\v 28 Bato nyonso ya Isalaele bamemaki Sanduku ya Boyokani ya Yawe na kobeta milolo ya esengo, na kobeta maseke, bakelelo, manzanza, banzenze mpe mandanda.  
\v 29 Tango Sanduku ya Boyokani ya Yawe ekotaki na engumba ya Davidi, Mikali, mwana mwasi ya Saulo, azalaki kotala wuta na lininisa ; mpe tango amonaki mokonzi Davidi kopumbwa mpe kobina na esengo, ayinaki ye kati na motema na ye. 
\c 16  
\s1 Esengo mpe masanzoli 
\p  
\v 1 Bamemaki Sanduku ya Yawe mpe batiaki yango kati na ndako ya kapo oyo Davidi atelemisaki mpo na yango, mpe babonzaki liboso ya Nzambe bambeka ya kotumba mpe bambeka ya boyokani.  
\v 2 Tango Davidi asilisaki kobonza bambeka ya kotumba mpe bambeka ya boyokani, apambolaki bato na Kombo na Yawe.  
\v 3 Bongo apesaki na moto nyonso ya Isalaele : lipa, gato oyo basala na bambuma ya dati mpe gato oyo basala na bambuma ya vino ya kokawuka. 
\b  
\p  
\v 4 Davidi atiaki ndambo ya Balevi mpo na kosala mosala liboso ya Sanduku ya Yawe, mpo na kokanisa, mpo na kosanzola mpe mpo na kokumisa Yawe, Nzambe ya Isalaele :  
\v 5 Azafi azalaki mokambi ; Zakari azalaki molandi na ye ; mpe Yeyeli, Shemiramoti, Yeyeli, Matitia, Eliabi, Benaya, Obedi-Edomi mpe Yeyeli bazalaki kobeta nzenze mpe lindanda ; mpe Azafi azalaki kobeta manzanza. 
\b  
\p  
\v 6 Banganga-Nzambe Benaya mpe Yaazieli bazalaki kobeta tango nyonso bakelelo liboso ya Sanduku ya Boyokani ya Nzambe. 
\s1 Nzembo ya matondi ya Davidi 
\p  
\v 7 Ezalaki mokolo wana nde Davidi aponaki na mbala ya liboso Azafi mpe bandeko na ye, mpo ete bakumisa Yawe : 
\q1  
\v 8 Bokumisa Yawe, bobelela Kombo na Ye, 
\q2 bopanza sango ya misala minene na Ye kati na bikolo ! 
\q1  
\v 9 Boyemba mpo na lokumu na Ye, 
\q2 bosanzola Ye na mindule ! 
\q1 Botatolaka tango nyonso misala minene na Ye nyonso ! 
\q1  
\v 10 Bosepela na Kombo na Ye ya bule ! 
\q2 Tika ete mitema ya bato oyo balukaka Yawe 
\q2 etonda na esengo ! 
\q1  
\v 11 Bomipesa na Yawe mpe bosenga makasi na Ye ! 
\q2 Bolukaka tango nyonso elongi na Ye ! 
\q1  
\v 12 Bokanisa bikamwa, makambo minene oyo asalaki, 
\q2 bitumbu oyo apesaki, 
\q1  
\v 13 bino bakitani ya Isalaele, mosali na Ye ; 
\q2 bino bana mibali ya Jakobi, baponami na Ye ! 
\q1  
\v 14 Yawe azali Nzambe na biso, mikano na Ye ekambaka mokili mobimba. 
\q1  
\v 15 Akanisaka tango nyonso Boyokani na Ye, 
\q2 bilaka na Ye mpo na bikeke nkoto moko, 
\q1  
\v 16 boyokani oyo asalaki elongo na Abrayami, 
\q2 mpe ndayi oyo alapaki epai ya Izaki. 
\q1  
\v 17 Akokisaki bosolo na yango epai ya Jakobi lokola mobeko, 
\q2 epai ya Isalaele lokola boyokani ya libela na libela 
\q1  
\v 18 tango alobaki : « Nakopesa yo mokili ya Kanana 
\q2 lokola libula oyo epesameli yo. » 
\b  
\q1  
\v 19 Bozalaki kaka motango moke ya bato 
\q2 mpe bapaya kati na yango ; 
\q1  
\v 20 bozalaki koyengayenga 
\q2 longwa na ekolo moko kino na ekolo mosusu, 
\q2 longwa na mokili moko kino na mokili mosusu ; 
\q1  
\v 21 kasi Yawe atikaki moto moko te konyokola bango, 
\q2 apamelaki bakonzi na tina na bango : 
\q1  
\v 22 « Bosimba bapakolami na Ngai te, 
\q2 bosala mabe te epai na basakoli na Ngai. » 
\b  
\q1  
\v 23 Bino bato ya mokili mobimba, boyembela Yawe ! 
\q2 Bosakolaka lobiko na Ye mokolo na mokolo ! 
\q1  
\v 24 Bopanza sango ya nkembo na Ye kati na mabota ! 
\q2 Boyebisa bato misala na Ye ya kokamwa kati na bikolo nyonso ! 
\q1  
\v 25 Pamba te Yawe azali monene mpe abongi na lokumu, 
\q2 azali somo makasi mpe aleki banzambe nyonso. 
\q1  
\v 26 Pamba te banzambe nyonso ya bikolo ezali kaka bikeko ya pamba, 
\q2 nzokande Yawe nde akela likolo. 
\q1  
\v 27 Kongenga mpe nkembo monene ezali liboso na Ye, 
\q2 makasi mpe esengo ezali na esika oyo avandaka. 
\q1  
\v 28 Bino bituka ya mabota, bosanzola Yawe, 
\q2 bosanzola Yawe na kopanza sango ya nkembo mpe nguya na Ye ! 
\q1  
\v 29 Bosanzola Yawe mpe bopesa Kombo na Ye nkembo ! 
\q2 Bomema makabo mpe boya liboso na Ye, 
\q2 bogumbamela Yawe mpo na kongenga ya bosantu na Ye ! 
\q1  
\v 30 Bino, bato ya mokili mobimba, bolenga liboso na Ye ! 
\q2 Solo, mokili elendisama makasi, ekoningana te. 
\q1  
\v 31 Tika ete likolo esepela mpe mabele ezala kati na esengo ! 
\q2 Tika ete baloba kati na bikolo : 
\q2 « Yawe azali mokonzi ! » 
\q1  
\v 32 Tika ete ebale monene mpe nyonso oyo ezali kati na yango 
\q2 etia makelele ; 
\q1 tika ete zamba mpe nyonso oyo ezali kati na yango 
\q2 esepela ! 
\q1  
\v 33 Boye, banzete ya zamba ekoyemba, 
\q2 ekoyemba na esengo liboso ya Yawe, 
\q2 pamba te Yawe azali koya kosambisa mabele. 
\b  
\q1  
\v 34 Bosanzola Yawe, pamba te azali malamu, 
\q2 bolingo na Ye ewumelaka seko na seko. 
\q1  
\v 35 Boganga : « Oh Nzambe Mobikisi na biso, bikisa biso, 
\q2 sangisa biso mpe kangola biso wuta na maboko ya bokonzi ya bikolo mosusu, 
\q1 mpo ete tosanzola Kombo na Yo ya bule 
\q2 mpe tosepela na mosala ya kokumisa Yo ! » 
\q1  
\v 36 Tika ete Yawe, Nzambe ya Isalaele, apambolama seko na seko ! 
\m Bato nyonso balobaki : « Amen ! » Mpe bakumisaki Yawe ! 
\b  
\p  
\v 37 Davidi apesaki mokumba, epai ya Azafi mpe bandeko na ye, ya kosala mosala liboso ya Sanduku ya Boyokani ya Yawe kolanda bikateli ya mokolo na mokolo. 
\p  
\v 38 Apesaki lisusu mokumba epai ya Obedi-Edomi, mwana mobali ya Yedutuni, mpe bandeko na bango, tuku motoba na mwambe, ya kosala mosala ya kokengela bikuke elongo na Osa.  
\v 39 Davidi atiaki Nganga-Nzambe Tsadoki mpe Banganga-Nzambe mosusu, liboso ya Mongombo ya Yawe na esambelo ya likolo ya ngomba, oyo ezalaki na Gabaoni,  
\v 40 mpo na kobonza tango nyonso bambeka ya kotumba epai na Yawe, na etumbelo na yango, na tongo mpe na pokwa, kolanda bikateli oyo ekomama na mobeko oyo Yawe apesaki na Isalaele.  
\v 41 Emani mpe Yedutuni bazalaki elongo na bango, mpe bamosusu oyo baponamaki na bakombo na bango mpo na kokumisa Yawe na maloba oyo : « Mpo ete bolingo na Ye ekowumela seko. »  
\v 42 Emani mpe Yedutuni baponamaki mpo na kobeta bakelelo, manzanza mpe bibetelo mosusu ya mindule mpo na kobongisa banzembo na tina na lokumu ya Nzambe. Bana mibali ya Yedutuni bazalaki bakengeli bikuke. 
\p  
\v 43 Bato nyonso bazongaki, moto na moto epai na ye, mpe Davidi azongaki na ndako na ye mpo na kopambola libota na ye. 
\c 17  
\s1 Elaka ya Nzambe epai ya Davidi 
\r (2Sa 7.1-17) 
\p  
\v 1 Wana Davidi avandaki na ndako na ye ya bokonzi, alobaki na mosakoli Natan : 
\pi1 — Nazali kovanda na ndako batonga na mabaya ya sedele, kasi Sanduku ya Boyokani ya Yawe ezali kati na ndako ya kapo. 
\p  
\v 2 Natan azongiselaki Davidi : 
\pi1 — Sala nyonso oyo ozali na yango na motema, pamba te Nzambe azali elongo na yo. 
\p  
\v 3 Kasi na butu wana, Nzambe alobaki na Natan : 
\pm  
\v 4 — Kende koyebisa Davidi, mosali na Ngai : « Tala liloba oyo Yawe alobi : ‹ Ezali yo te moto okotongela Ngai ndako mpo ete navanda kati na yango.  
\v 5 Banda mokolo oyo nabimisaki Isalaele na Ejipito kino lelo, natikali nanu kovanda na ndako moko te ; nazalaki kaka kati na Mongombo, longwa na esika songolo kino na esika pakala.  
\v 6 Na bisika nyonso oyo natamboli elongo na bana nyonso ya Isalaele, boni, nasilaki koloba ata na moko kati na bakambi na bango, oyo natiaki mpo na kobatela bato na Ngai : ‘ Mpo na nini botongeli Ngai te ndako ya mabaya ya sedele ? ’ › 
\pm  
\v 7 Yebisa sik’oyo Davidi, mosali na Ngai : ‹ Tala makambo oyo Yawe, Mokonzi ya mampinga, alobi : Ezali Ngai nde nazwaki yo na zamba epai wapi ozalaki koleisa mpe kobatela bibwele, mpo ete nakomisa yo mokonzi ya bato na Ngai, Isalaele.  
\v 8 Nazalaki elongo na yo na bisika nyonso oyo okendeki mpe nabomaki banguna na yo nyonso liboso na yo. Sik’oyo, nakokomisa kombo na yo monene lokola bakombo ya bato minene oyo bazali kati na mokili.  
\v 9 Nakobongisa esika mpo na bato na Ngai, Isalaele, mpe nakolona bango mpo ete bazala na esika na bango moko mpe batungisa bango lisusu te. Bato mabe bakonyokola bango lisusu te ndenge bazalaki konyokola bango liboso ;  
\v 10 mpe ndenge bazalaki kosala bango tango nyonso wuta tango oyo naponaki bakambi ya bato na Ngai, Isalaele. Nakotia lisusu banguna na yo na se ya bokonzi na yo. 
\pm Boye, nazali koyebisa yo ete Yawe akosala ete bokonzi ewumela kati na libota na yo.  
\v 11 Tango okosilisa mobembo na yo awa na mokili mpe okokende kokutana na batata na yo, nakotombola moko kati na bakitani na yo, oyo akobima penza na mokongo na yo, mpo ete akitana na yo ; mpe nakolendisa bokonzi na ye.  
\v 12 Ezali ye nde akotonga Ndako mpo na Kombo na Ngai, mpe Ngai nakolendisa mpo na libela kiti na ye ya bokonzi.  
\v 13 Nakozala tata mpo na ye, mpe ye akozala mwana mpo na Ngai ; nakotikala kolongola te bolingo na Ngai epai na ye ndenge nalongolaki yango epai ya mokonzi oyo alekaki liboso na yo.  
\v 14 Nakotia ye mokonzi ya ndako na Ngai mpe ya mokili na Ngai mpo na libela, mpe kiti na ye ya bokonzi ekolendisama mpo na libela. › » 
\p  
\v 15 Natan ayebisaki Davidi maloba oyo nyonso mpe emoniseli oyo nyonso. 
\s1 Libondeli ya Davidi 
\r (2Sa 7.18-29) 
\p  
\v 16 Mokonzi Davidi akotaki, avandaki liboso ya Yawe mpe alobaki : 
\pm « Oh Yawe Nzambe, ngai nazali nani, mpe libota na ngai ezali nini, mpo ete okomisa ngai na esika oyo nazali ?  
\v 17 Mpe lokola nde ekokaki te na miso na Yo, Nzambe na ngai, olobi lisusu na tina na lobi ya libota ya bokonzi ya mosali na Yo ! 
\pm Oh Yawe Nzambe, ozali kozwa ngai lokola moto ya lokumu !  
\v 18 Nini oyo Davidi akoki lisusu koloba na Yo mpo na lokumu oyo ozali kopesa na mosali na Yo ? Pamba te, oh Yawe, oyebi mosali na Yo.  
\v 19 Oh Yawe, mpo na mosali na Yo mpe kolanda mokano na Yo, okokisi makambo minene oyo mpe osali ete bilaka minene oyo nyonso eyebana. 
\pm  
\v 20 Oh Yawe, moko te akokani na Yo ; mpe, kolanda nyonso oyo toyoki na matoyi na biso, Nzambe mosusu azali te, bobele Yo !  
\v 21 Boni, ezali solo na ekolo moko kati na mokili, oyo ekokani na bato na Yo, Isalaele ; ekolo oyo, kati na mokili, Nzambe asikola bato na yango mpo na lokumu na Ye moko ? Osalaki ete Kombo na yo ekende sango na nzela ya misala minene mpe ya somo oyo osalaki tango obenganaki bikolo liboso ya bato na Yo, oyo akangolaki na Ejipito.  
\v 22 Okomisi Isalaele bato na Yo mpo na libela, mpe Yo, Yawe, okomi Nzambe na bango. 
\pm  
\v 23 Bongo sik’oyo, oh Yawe, tika ete elaka oyo opesaki epai ya mosali na Yo mpe libota na ye ekokisama mpo na libela ! Sala ndenge olakaki.  
\v 24 Boye, sala ete ekokisama, mpo ete Kombo na Yo ekumisama seko na seko mpe bato bakoma kolobaka : ‹ Yawe, Mokonzi ya mampinga mpe Nzambe ya Isalaele, azali solo Nzambe mpo na Isalaele ! › Boye bokonzi ya libota ya mosali na Yo, Davidi, ekolendisama liboso na Yo. 
\pm  
\v 25 Solo, Yo moko, Nzambe na ngai, olakisaki na mosali na Yo ete okosala ete bokonzi ewumela na libota na ye. Yango wana mosali na Yo azwi makasi ya kosambela Yo.  
\v 26 Sik’oyo oh Yawe, ozali Nzambe ! Olakaki makambo ya malamu epai ya mosali na Yo.  
\v 27 Osepeli sik’oyo kopambola libota ya mosali na Yo mpo ete ewumela seko liboso na Yo ; pamba te ezali Yo, Yawe, nde opamboli yango, mpe epambolami mpo na libela. » 
\c 18  
\s1 Elonga ya Davidi 
\r (2Sa 8.1-14) 
\p  
\v 1 Sima na yango, Davidi alongaki bato ya Filisitia mpe abukaki lolendo na bango. Abotolaki na maboko ya bato ya Filisitia engumba Gati elongo na bamboka na yango ya zingazinga.  
\v 2 Davidi alongaki lisusu bato ya Moabi. Bato ya Moabi bakomaki bawumbu ya Davidi mpe bakomaki kofuta mpako ya mokonzi.  
\v 3 Davidi alongaki lisusu Adadezeri, mokonzi ya Tsoba, na engumba Amati, tango Adadezeri akendeki kovandisa bokonzi na ye pembeni ya ebale Efrate.  
\v 4 Davidi abotolaki Adadezeri bashar nkoto moko, akangaki basoda nkoto sambo oyo babundaka bitumba likolo ya bampunda mpe basoda nkoto tuku mibale oyo babundaka bitumba na makolo ; akataki misisa ya makolo ya bampunda nyonso, kasi atikaki kaka bampunda nkama moko oyo ezalaki kobenda bashario.  
\v 5 Tango bato ya Siri oyo bazalaki kovanda na engumba Damasi bayaki kosunga Adadezeri, mokonzi ya Tsoba, Davidi abomaki kati na bango bato nkoto tuku mibale.  
\v 6 Bongo Davidi atiaki bayangeli na ye kati na engumba Damasi ya Siri ; boye bato ya Siri bakomaki na se ya bokonzi ya Davidi mpe bakomaki kofuta mpako epai na ye. Yawe azalaki kopesa Davidi elonga na bisika nyonso oyo azalaki kokende.  
\v 7 Davidi abotolaki banguba ya wolo oyo bakonzi ya basoda ya Adadezeri bazalaki na yango mpe amemaki yango na Yelusalemi.  
\v 8 Na Tibati mpe na Kuni, bingumba ya mokonzi Adadezeri, Davidi azwaki bronze ebele oyo, na mikolo oyo elandaki, Salomo asalaki na yango nzungu ya monene, makonzi mpe bisalelo mosusu ya bronze. 
\p  
\v 9 Tango Towu, mokonzi ya Amati, ayokaki ete Davidi alongi mampinga nyonso ya Adadezeri, mokonzi ya Tsoba,  
\v 10 atindaki Adorami, mwana na ye ya mobali, kopesa mokonzi Davidi mbote mpe longonya mpo ete abundisaki mpe alongaki Adadezeri oyo azalaki monguna ya Towu. Adorami amemelaki Davidi lolenge nyonso ya biloko ya wolo, ya palata mpe ya bronze.  
\v 11 Mokonzi Davidi abulisaki biloko yango epai na Yawe, ndenge asalaki na wolo mpe palata oyo azwaki na bikolo nyonso, na Edomi, na Moabi, na Amoni, na Filisitia mpe na Amaleki.  
\v 12 Abishayi, mwana mobali ya Tseruya, abomaki bato ya Edomi nkoto zomi na mwambe, kati na Lubwaku ya Mungwa.  
\v 13 Davidi atiaki bayangeli kati na Edomi, mpe bato nyonso ya Edomi bakomaki bawumbu ya Davidi. Yawe apesaki Davidi elonga na bisika nyonso oyo azalaki kokende. 
\s1 Bakalaka ya Davidi 
\r (2Sa 8.15-18) 
\p  
\v 14 Davidi azalaki mokonzi ya Isalaele mobimba, mpe azalaki kosalela bato na ye nyonso makambo ya sembo mpe ya alima.  
\v 15 Joabi, mwana mobali ya Tseruya, azalaki mokonzi ya liboso ya mampinga ; Jozafati, mwana mobali ya Ayiludi, azalaki mobombi mikanda ;  
\v 16 Tsadoki, mwana mobali ya Ayitubi, mpe Abimeleki, mwana mobali ya Abiatari, bazalaki Banganga-Nzambe ; Shavisha azalaki mokomi mikanda ;  
\v 17 Benaya, mwana mobali ya Yeoyada, azalaki kokamba bato ya Kereti mpe ya Peleti ; mpe bana mibali ya Davidi bazalaki bakalaka ya liboso pembeni ya mokonzi. 
\c 19  
\s1 Bitumba ya Davidi na bato ya Amoni 
\r (2Sa 10.1-19) 
\p  
\v 1 Sima na mwa tango, Naashi, mokonzi ya bato ya Amoni, akufaki, mpe mwana na ye ya mobali akitanaki na ye na bokonzi.  
\v 2 Davidi amilobelaki : « Nakotalisa bolamu epai ya Anuni, mwana mobali ya Naashi, pamba te tata na ye atalisaki ngai bolamu. » 
\p Boye Davidi atindaki bato epai ya Anuni mpo na kobondisa ye na tina na kufa ya tata na ye. Tango basali ya Davidi bakomaki epai ya Anuni, na mokili ya bato ya Amoni, mpo na kobondisa ye,  
\v 3 bakambi ya bato ya Amoni balobaki na Anuni : « Okanisi ete ezali mpo na kopesa tata na yo lokumu nde Davidi atindi bato mpo na kobondisa yo ? Bato wana bayei epai na yo mpo na kotala mpe kononga mokili mpo ete babebisa yango. » 
\p  
\v 4 Boye, Anuni akangaki basali ya Davidi, akataki bango mandefu, akataki bango bilamba kino na likolo ya mipende mpe abenganaki bango.  
\v 5 Tango bayebisaki Davidi makambo oyo ekweyelaki bato wana, atindaki bato mosusu mpo na kokende kokutana na bango, pamba te basambwisaki bango makasi. Mokonzi atindelaki bango maloba oyo : « Bovanda na Jeriko kino mandefu na bino ekobota, sima nde bokozonga. » 
\p  
\v 6 Tango bato ya Amoni bamonaki ete bamilukeli makambo epai ya Davidi, Anuni mpe bato ya Amoni batindaki bakilo ya palata nkoto tuku misato epai ya bato ya Siri ya Mezopotami, ya Maaka mpe ya Tsoba, mpo na kodefa bashar mpe basoda oyo babundaka bitumba likolo ya bampunda.  
\v 7 Badefaki bashar, basoda nkoto tuku misato na mibale oyo babundaka likolo ya bampunda, mpe mokonzi ya Maaka elongo na mampinga na ye. Bongo, bayaki kotonga molako na bango pembeni ya Medeba. Kaka na tango yango, bato ya Amoni basanganaki na engumba na bango mpe babimaki mpo na kobunda.  
\v 8 Tango kaka Davidi ayokaki bongo, atindaki Joabi elongo na mampinga nyonso ya basoda ya mpiko. 
\p  
\v 9 Bato ya Amoni babimaki mpe batandamaki na milongo mpo na bitumba, na ekuke ya engumba na bango ; kasi bakonzi oyo bayaki bazalaki na esika mosusu, kati na zamba.  
\v 10 Tango Joabi amonaki ete milongo ya bitumba ezali na liboso mpe na sima na ye, aponaki basoda ya Isalaele, oyo baleki na mpiko mpe atiaki bango na milongo mpo na kobundisa bato ya Siri.  
\v 11 Atiaki basoda oyo batikalaki na se ya bokonzi ya ndeko na ye ya mobali, Abishayi ; mpe atandaki bango na milongo ya bitumba mpo na kobundisa bato ya Amoni.  
\v 12 Joabi alobaki : « Soki bato ya Siri baleki ngai na makasi, yo okoya kosunga ngai ; kasi soki bato ya Amoni baleki yo na makasi, wana ngai nakosunga yo.  
\v 13 Yika mpiko, mpe tobunda lokola bilombe mpo na bato na biso mpe mpo na bingumba ya Nzambe na biso. Tika ete Yawe asala oyo ezali malamu na miso na Ye. » 
\p  
\v 14 Boye, Joabi mpe basoda oyo bazalaki elongo na ye bapusanaki mpo na kobundisa bato ya Siri ; mpe bato yango ya Siri bakimaki liboso na ye.  
\v 15 Tango bato ya Amoni bamonaki bato ya Siri kokima, bango mpe bakimaki liboso ya Abishayi, ndeko mobali ya Joabi, mpe bazongaki na engumba. Bongo, Joabi azongaki na Yelusalemi. 
\p  
\v 16 Tango bato ya Siri bamonaki ete Isalaele alongi bango, batindaki bantoma kobenga bato mosusu ya Siri oyo bazalaki na ngambo mosusu ya ebale Efrate. Tsofaki, mokonzi ya mampinga ya Adadezeri, azalaki liboso na bango.  
\v 17 Tango Davidi azwaki sango yango, asangisaki bato nyonso ya Isalaele mpe akatisaki Yordani ; apusanaki mpe asalaki molongo ya bitumba liboso na bango ya bato ya Siri, mpe bato ya Siri babundisaki ye.  
\v 18 Kasi bato ya Siri bakimaki liboso ya Isalaele, mpe Davidi abomaki basoda na bango, nkoto sambo oyo babundaka bitumba likolo ya bampunda mpe basoda nkoto tuku minei oyo babundaka bitumba na makolo. Davidi abomaki lisusu Tsofaki, mokonzi na bango ya mampinga.  
\v 19 Tango bawumbu ya Adadezeri bamonaki ete Isalaele alongi bango, basalaki kimia elongo na Davidi mpe bakomaki na se ya bokonzi na ye. Boye bato ya Siri balingaki lisusu te kosunga bato ya Amoni. 
\c 20  
\r (2Sa 11.1; 12.29-31) 
\p  
\v 1 Na mobu oyo elandaki, na tango oyo bakonzi bazalaka na momesano ya kokende na bitumba, Joabi akambaki mampinga na bitumba mpe abebisaki mokili ya bato ya Amoni ; bongo akendeki kotonga molako liboso ya Raba. Kasi Davidi atikalaki na Yelusalemi. 
\p Joabi abundisaki engumba Raba mpe apanzaki yango.  
\v 2 Davidi alongolaki motole oyo ezalaki na moto ya mokonzi na yango. Bamonaki ete esalemaki na bakilo ya wolo koleka tuku misato mpe ezalaki na libanga ya talo likolo na yango. Wuta na tango wana, ekomaki na moto ya Davidi. Akamataki bomengo ebele ya bitumba kati na engumba yango.  
\v 3 Amemaki na bowumbu bato oyo bazalaki kuna, atiaki bango na misala oyo basalaka na si, na piki\f + \fr 20.3 \ft Piki ezali ebende ya basonge mibale, oyo babengaka na lifalanse pioche.\f* mpe na epasola. Davidi asalaki ndenge wana na bavandi ya bingumba nyonso ya bato ya Amoni ; bongo azongaki na Yelusalemi elongo na mampinga na ye nyonso. 
\s1 Bitumba na bato ya Filisitia 
\r (2Sa 21.15-22) 
\p  
\v 4 Sima na mwa tango, ezalaki lisusu na bitumba na bato ya Filisitia, kuna na mboka Gezeri. Ezalaki na tango yango nde Sibekayi, moto ya Usha, abomaki Sipayi, moko kati na bakitani ya Rafa ; mpe bato ya Filisitia bayokisamaki soni. 
\p  
\v 5 Ezalaki lisusu na bitumba na bato ya Filisitia ; mpe Elanani, mwana mobali ya Yairi, abomaki Lami, ndeko mobali ya Goliati, moto ya Gati, oyo nzete ya likonga na ye ezalaki monene lokola libaya oyo basali bilamba na maboko basalelaka.  
\v 6 Ezalaki lisusu na bitumba oyo esalemaki kuna na Gati ; mpe ezalaki kuna na mbinga mobali moko, mokitani ya Rafa, oyo azalaki na misapi motoba na loboko moko na moko, mpe misapi motoba na lokolo moko na moko. Na kosangisa, azalaki na misapi tuku mibale na minei.  
\v 7 Atiolaki Isalaele ; mpe Jonatan, mwana mobali ya Shimea mpe ndeko mobali ya Davidi, abomaki ye.  
\v 8 Bato wana bazalaki bakitani ya Rafa, babotama na Gati mpe bakufaki liboso ya Davidi mpe ya basoda na ye. 
\c 21  
\s1 Davidi atangi bato 
\r (2Sa 24.1-25) 
\p  
\v 1 Satana atelemelaki Isalaele mpe atindikaki Davidi na kotanga motango ya bato ya Isalaele.  
\v 2 Boye, Davidi apesaki mitindo na Joabi mpe na bakambi ya bato : 
\pi1 — Bokende kotanga bato ya Isalaele, longwa na Beri-Sheba kino na Dani, mpe boyebisa ngai motango na bango mpo ete nayeba. 
\p  
\v 3 Kasi Joabi azongisaki : 
\pi1 — Tika ete Yawe akomisa bato na Ye ebele koleka mbala nkama ! Oh mokonzi, nkolo na ngai, bango nyonso bazali te basali ya nkolo na ngai ? Mpo na nini nkolo na ngai alingi kosala bongo ? Mpo na nini komemisa Isalaele ngambo ? 
\p  
\v 4 Kasi mokonzi atingamaki kaka na mitindo oyo apesaki na Joabi. Boye, Joabi abimaki, atambolaki kati na Isalaele mobimba mpe azongaki na Yelusalemi.  
\v 5 Joabi ayebisaki Davidi motango ya bato oyo atangaki, bato oyo bakoki kosalela mopanga na bitumba : bato monkoko moko na nkoto nkama moko kati na Isalaele mobimba, mpe nkoto nkama minei na tuku sambo kati na Yuda.  
\v 6 Kasi kati na bango, Joabi atangaki te ekolo ya Levi mpe ya Benjame ; pamba te etinda ya mokonzi esepelisaki ye te. 
\p  
\v 7 Etinda yango esepelisaki Nzambe te mpe Nzambe apesaki Isalaele etumbu. 
\p  
\v 8 Davidi alobaki na Nzambe : 
\pi1 — Nasali lisumu monene na kotanga bato. Sik’oyo, nabondeli Yo, limbisa mabe ya mosali na Yo ; pamba te nasali makambo lokola moto ya liboma. 
\p  
\v 9 Yawe alobaki na mosakoli Gadi, mopesi toli ya Davidi : 
\pi1  
\v 10 — Kende koyebisa Davidi : « Tala liloba oyo Yawe alobi : ‹ Nazali kotalisa yo bitumbu misato ; pona moko kati na yango mpo ete Ngai nakokisa yango lokola etumbu mpo na yo. › » 
\p  
\v 11 Gadi akendeki koyebisa Davidi makambo oyo Yawe alobaki na ye : 
\pi1 — Tala makambo oyo Yawe alobi : « Oponi etumbu nini :  
\v 12 mibu misato ya nzala makasi ; sanza misato oyo banguna na yo bakolonga yo mpe mipanga na bango ekoboma basoda na yo ; to mikolo misato elongo na mopanga ya Yawe mpe bokono oyo ebomaka, mikolo oyo anjelu ya Yawe akobebisa etuka nyonso ya Isalaele ? Kanisa sik’oyo malamu mpe yebisa ngai eyano oyo ngai nasengeli komema epai na Ye oyo atindi ngai. » 
\p  
\v 13 Davidi azongiselaki Gadi : 
\pi1 — Nazali na pasi makasi kati na motema. Eleki malamu mpo na ngai kokweya na maboko ya Yawe, pamba te mawa na Ye ezali solo monene ; kasi tika ete nakweya te na maboko ya bato ! 
\p  
\v 14 Boye, Yawe atindaki kati na Isalaele bokono oyo ebomaka, mpe bato ya Isalaele nkoto tuku sambo bakufaki.  
\v 15 Nzambe atindaki anjelu na Yelusalemi mpo na kobebisa yango ; kasi wana anjelu azalaki kobebisa, Yawe atalaki mpe ayokaki mawa mpo na pasi wana. Alobaki na anjelu oyo azalaki kobebisa : « Ekoki ! Longola loboko na yo ! » 
\p Anjelu na Yawe atelemaki pembeni ya etando ya Orinani, moto ya Yebusi.  
\v 16 Davidi atombolaki miso mpe amonaki anjelu ya Yawe atelemi kati ya likolo mpe mabele, bongo na loboko na ye oyo asembolaki likolo ya Yelusalemi, asimbaki mopanga ezanga ebombelo. 
\p Davidi mpe bampaka balataki basaki mpe bakweyaki bilongi kino na mabele. 
\p  
\v 17 Davidi alobaki na Nzambe : 
\pi1 — Boni, ezali ngai nde napesaki mitindo ete batanga motango ya bato ? Ngai moko nde nasalaki masumu, ngai moko nde nasalaki mbeba oyo eleki mabe. Bango, bato ya ekolo na ngai, basali mabe moko te. Oh Yawe, Nzambe na ngai, ebongi nde opesa ngai mpe libota na ngai etumbu ; kasi tika ete bokono oyo ebomaka ekweyela te bato na Yo ! 
\s1 Davidi atongi etumbelo mpo na Yawe 
\p  
\v 18 Anjelu na Yawe atindaki Gadi koloba na Davidi : 
\pi1 — Kende kotonga etumbelo mpo na Yawe, na etando ya Orinani, moto ya Yebusi.  
\v 19 Davidi akendeki kuna kolanda liloba oyo Gadi alobaki na Kombo na Yawe.  
\v 20 Bongo, wana Orinani azalaki kotuta ble, abalukaki mpe amonaki anjelu. Boye bana na ye ya mibali minei oyo bazalaki na ye elongo babombamaki. 
\p  
\v 21 Davidi apusanaki pembeni ya Orinani ; mpe tango Orinani atalaki mpe amonaki Davidi, abimaki na etando mpe agumbamaki liboso ya Davidi, elongi kino na mabele.  
\v 22 Davidi alobaki na Orinani : 
\pi1 — Pesa ngai etando na yo, tekela ngai yango na motuya ya mbongo oyo ekoki na yango, mpo ete natonga etumbelo mpo na Yawe ; tekela ngai yango mpo ete etumbu ya bokono oyo ezali koboma bato esila. 
\p  
\v 23 Orinani azongiselaki Davidi : 
\pi1 — Kamata yango ; mpe tika ete mokonzi, nkolo na ngai, asala na yango nyonso oyo amoni ete ezali malamu mpo na ye. Tala, ngai, nakopesa bangombe ya mibali lokola mbeka ya kotumba, banzete oyo babetelaka ble lokola koni, mpe ble lokola mbeka ya bambuma. Nakopesa nyonso wana. 
\p  
\v 24 Kasi mokonzi Davidi alobaki na Orinani : 
\pi1 — Te ! Nasengeli kaka kosomba yango mpe kopesa yo motuya oyo ekoki na yango ; nakomema te epai na Yawe eloko oyo ezali ya yo, nakobonzela Yawe te bambeka ya kotumba oyo nazwi na ofele. 
\p  
\v 25 Boye, Davidi asombaki etando yango epai ya Orinani, na motuya ya mbongo ya bibende ya wolo, nkama motoba.  
\v 26 Davidi atongaki kuna etumbelo mpo na Yawe mpe abonzaki bambeka ya kotumba mpe bambeka ya boyokani. Abelelaki Yawe, mpe Yawe ayanolaki ye na moto oyo ewutaki likolo mpe ekweyaki na etumbelo ya bambeka. 
\p  
\v 27 Boye Yawe alobaki na anjelu, mpe anjelu azongisaki mopanga na ye na ebombelo na yango. 
\p  
\v 28 Banda na tango wana, lokola Davidi amonaki ete Yawe ayanolaki ye na etando ya Orinani, moto ya Yebusi, akomaki kobonza bambeka tango nyonso na esika wana.  
\v 29 Mongombo na Yawe oyo Moyize atongaki na esobe mpe etumbelo ya bambeka ya kotumba ezalaki na tango wana, na esambelo ya likolo ya ngomba ya Gabaoni.  
\v 30 Nzokande Davidi azalaki kokoka te kozwa mokano ya kokende kotuna Nzambe liboso ya Mongombo, pamba te azalaki kobanga mopanga na Yawe. 
\c 22  
\p  
\v 1 Davidi alobaki : « Tempelo ya Yawe Nzambe mpe etumbelo ya mbeka ya kotumba mpo na Isalaele ekozala na esika oyo. » 
\s1 Mabongisi mpo na kotonga Tempelo ya Yawe 
\p  
\v 2 Boye, Davidi apesaki mitindo ya kosangisa bapaya oyo bazalaki kovanda na Isalaele. Mpe kati na bango, aponaki bato oyo bakataka mabanga mpo na kotonga Ndako ya Nzambe.  
\v 3 Davidi apesaki bibende ebele mpo na kosala basete mpe bibende oyo esimbaka bikuke. Apesaki lisusu bronze ebele oyo bakoki kotanga te,  
\v 4 banzete ebele ya sedele oyo bakoki kotanga te, pamba te bato ya Tiri mpe ya Sidoni bamemelaki Davidi banzete yango ebele. 
\p  
\v 5 Davidi alobaki : « Salomo, mwana na ngai ya mobali, azali nanu elenge mpe ayebi nanu makambo malamu te. Nzokande, Ndako oyo esengeli kotongama mpo na Yawe esengeli kozala monene, kitoko mpe na lokumu mingi na miso ya bikolo nyonso. Yango wana, nakobongisa biloko mpo na Ndako yango. » Boye Davidi abongisaki biloko ebele liboso ete akufa. 
\p  
\v 6 Davidi abengisaki Salomo, mwana na ye ya mobali, mpe apesaki ye mokumba ya kotonga Ndako mpo na Yawe, Nzambe ya Isalaele. 
\p  
\v 7 Davidi alobaki na Salomo : « Mwana na ngai, nazwaki likanisi ya kotonga Ndako mpo na Kombo na Yawe, Nzambe na ngai ;  
\v 8 kasi tala maloba oyo Yawe alobaki na ngai : ‹ Osopaki makila ebele mpe obundaki bitumba ebele. Okoki te kotonga ndako mpo na Kombo na Ngai ; pamba te kati na mokili, osopaki makila ebele na miso na Ngai.  
\v 9 Kasi okozala na mwana moko ya mobali oyo akozala moto ya kimia mpe ya boboto. Nakopesa ye bopemi liboso ya banguna na ye nyonso oyo bazingeli ye. Kombo na ye ekozala Salomo ; mpe na mikolo nyonso oyo ye akozala mokonzi, nakopesa kimia mpe bopemi na Isalaele.  
\v 10 Ye nde akotonga Ndako mpo na Kombo na Ngai. Akozala mwana mpo na Ngai, mpe Ngai nakozala Tata mpo na ye, nakolendisa kiti na ye ya bokonzi kati na Isalaele mpo na libela. › 
\p  
\v 11 Sik’oyo, mwana na ngai, tika ete Yawe azala elongo na yo mpo ete otonga Ndako mpo na Yawe, Nzambe na yo, ndenge alobaki na tina na yo !  
\v 12 Tika ete apesa yo bwanya mpe mayele, mpo ete tango okokoma mokonzi ya Isalaele, okoka kobatela mobeko ya Yawe Nzambe na yo !  
\v 13 Boye, okolonga soki obateli malamu bikateli mpe mibeko oyo Yawe apesaki na Moyize mpo na Isalaele. Zala makasi mpe yika mpiko ! Kobanga te mpe kozonga sima te ! 
\p  
\v 14 Tala, namonaki pasi mpo na kosangisa mpo na Tempelo ya Yawe, minkoko misato ya kilo ya wolo, minkoko tuku misato ya kilo ya palata, bronze mpe bibende ebele oyo bakoki kotanga te, mabaya mpe mabanga. Boye yo mpe okoki kobakisa mosusu.  
\v 15 Ozali na bato ebele ya misala ya maboko : bato oyo bakataka mabanga, bato oyo basalaka misala ya mabaya mpe bato oyo basalaka misala nyonso ya maboko.  
\v 16 Ozali na wolo, palata, bronze mpe bibende ebele oyo bakoki kotanga te. Sik’oyo, banda mosala ; mpe tika ete Yawe azala na yo elongo ! » 
\p  
\v 17 Mpe Davidi apesaki mitindo epai ya bakambi nyonso ya Isalaele ete basunga mwana na ye Salomo.  
\v 18 Alobaki na bango : « Boni, Yawe, Nzambe na bino, azali elongo na bino te ? Apesaki bino bopemi na ngambo nyonso te ? Pamba te akabaki na maboko na ngai bato ya mokili oyo. Mokili yango ezali na se ya bokonzi ya Yawe mpe ya bato na Ye.  
\v 19 Sik’oyo, bobongisa mitema mpe milimo na bino mpo na koluka Yawe, Nzambe na bino. Bobanda kotonga Esika ya bule ya Yawe Nzambe mpo ete boyeisa Sanduku ya Boyokani ya Yawe mpe biloko ya bule ya Nzambe, na Tempelo oyo ekotongama mpo na Kombo na Yawe. » 
\c 23  
\s1 Balevi 
\p  
\v 1 Tango Davidi akomaki mobange makasi, akomisaki Salomo, mwana na ye ya mobali, mokonzi ya Isalaele.  
\v 2 Asangisaki bakambi nyonso ya Isalaele elongo na Banganga-Nzambe mpe Balevi.  
\v 3 Batangaki Balevi nyonso oyo bazalaki na mibu tuku misato mpe koleka : motango nyonso ya Balevi ezalaki nkoto tuku misato na mwambe. 
\p  
\v 4 Davidi alobaki : « Tika ete Balevi nkoto tuku mibale na minei bazala bakambi ya misala ya Tempelo ya Yawe, Balevi nkoto motoba bazala bakomi mikanda mpe basambisi,  
\v 5 Balevi nkoto minei bazala bakengeli bikuke, mpe Balevi nkoto minei bakumisa Yawe na bibetelo mindule oyo nasalaki na tina na yango. » 
\b  
\li4  
\v 6 Bongo Davidi akabolaki bango na masanga kolanda buku ya mabota ya bana mibali ya Levi : Gerishoni, Keati mpe Merari. 
\b  
\li1  
\v 7 Mpo na libota ya Gerishoni : 
\li2 Laedani mpe Shimei. 
\li1  
\v 8 Laedani azalaki na bana mibali misato : 
\li2 mokonzi Yeyeli, Zetami mpe Joeli. 
\li1  
\v 9 Shimei azalaki na bana mibali misato : 
\li2 Shelomiti, Azieli mpe Arani. 
\li2 Bango nde bazalaki bakambi ya mabota ya Laedani. 
\li1  
\v 10 Shimei azalaki na bana mibali mosusu minei : 
\li2 Yaati, Ziza, Yewushi mpe Beria. 
\li2  
\v 11 Yaati azalaki mwana ya liboso, mpe Ziza, mwana ya mibale. Nzokande Yewushi mpe Beria bazalaki na bakitani ebele te. Boye batangaki bango lokola libota moko. 
\li1  
\v 12 Keati azalaki na bana mibali minei : 
\li2 Amirami, Yitseari, Ebron mpe Uzieli. 
\li1  
\v 13 Amirami azalaki na bana mibali mibale : 
\li2 Aron mpe Moyize. 
\li2 Aron aponamaki mpo na libela, elongo na bana na ye ya mibali, mpo na kobulisa Esika-Oyo-Eleki-Bule, mpo na kotumba mbeka ya malasi liboso ya Yawe, mpo na kosalela Ye mpe kopambola bato mpo na libela na Kombo na Ye. 
\p  
\v 14 Bana ya Moyize, moto na Nzambe, batangaki bango na ekolo ya Levi. 
\li1  
\v 15 Bana mibali ya Moyize : 
\li2 Gerishomi mpe Eliezeri. 
\li1  
\v 16 Bana mibali ya Gerishomi : 
\li2 Shebueli azalaki mwana mobali ya liboso. 
\li1  
\v 17 Bana mibali ya Eliezeri : 
\li2 Reabia azalaki mwana na ye se moko. 
\m Eliezeri azalaki na bana mosusu te, kasi Reabia azalaki na bana ebele. 
\li1  
\v 18 Bana mibali ya Yitseari : 
\li2 Shelomiti azalaki mwana ya liboso kati na bana mibali ya Yitseari. 
\li1  
\v 19 Bana mibali ya Ebron : 
\li2 Yeriya, mwana ya liboso ; Amaria, mwana ya mibale ; 
\li2 Yaazieli, mwana ya misato mpe Yekameami, mwana ya minei. 
\li1  
\v 20 Bana mibali ya Uzieli : 
\li2 Mishe, mwana ya liboso ; mpe Yishiya, mwana ya mibale. 
\li1  
\v 21 Bana mibali ya Merari : 
\li2 Maali mpe Mushi. 
\li1 Bana mibali ya Maali : 
\li2 Eleazari mpe Kishi. 
\li2  
\v 22 Eleazari akufaki mpe atikalaki kobota bana mibali te, azalaki kaka na bana basi oyo babalanaki na bandeko na bango, bana mibali ya tata leki na bango Kishi. 
\li1  
\v 23 Bana mibali ya Mushi : 
\li2 Maali, Ederi mpe Yeremoti. Bango nyonso bazalaki misato. 
\b  
\li4  
\v 24 Bango nde bazalaki bakitani ya Levi kolanda bituka na bango, mpe bakambi ya bituka na bango kolanda ndenge bakomamaki, moto na moto, na buku ya mabota. Bazwaki mokumba ya kosala misala kati na Tempelo ya Yawe, kobanda na oyo azalaki na mibu tuku mibale mpe koleka.  
\v 25 Bongo Davidi alobaki : « Yawe, Nzambe ya Isalaele, apesi bopemi na bato na Ye mpe avandi libela kati na Yelusalemi.  
\v 26 Boye Balevi bazala lisusu te na mokumba ya komema Mongombo mpe bisalelo na yango nyonso. » 
\p  
\v 27 Ezalaki kolanda malako ya suka ya Davidi nde batangaki bakitani ya Levi kobanda na mibu tuku mibale mpe koleka.  
\v 28 Mosala ya Balevi ezalaki mpo na kosunga bakitani ya Aron na mosala ya Tempelo ya Yawe : kolandela bopeto ya veranda mpe ya bashambre, kopetola biloko nyonso ya bule mpe kosala misala nyonso ya Tempelo.  
\v 29 Bazalaki na mokumba ya kotanda mapa na mesa, kobongisa farine mpo na makabo ya bagato ezanga levire, bagalete mpe bagato batumba na kikalungu, mpe bagato basangisa na mafuta mpe biloko nyonso oyo bamekelaka kilo mpe molayi.  
\v 30 Bazalaki mpe na mokumba ya kotelema liboso ya Yawe, tongo mpe pokwa nyonso, mpo na kokumisa mpe kosanzola Ye ;  
\v 31 mpe kobonza tango nyonso bambeka ya kotumba oyo bazalaki komema epai na Yawe na mikolo ya Saba, na ebandeli ya sanza mpe na mikolo nyonso ya bafeti oyo ekatama, kolanda motango oyo bakatelaki bango mpo na libela liboso ya Yawe.  
\v 32 Boye Balevi bazalaki kosala mosala na bango ya kokengela Ndako ya kapo ya Bokutani mpe Esika ya bule, mpe ya kosunga bandeko na bango ya mibali, bana ya Aron, na mosala ya Tempelo ya Yawe. 
\c 24  
\s1 Kokabola misala ya Balevi 
\p  
\v 1 Tala bituka ya bana mibali ya Aron : Nadabi, Abiyu, Eleazari mpe Itamari.  
\v 2 Nadabi mpe Abiyu bakufaki liboso ya tata na bango mpe batikalaki kobota te. Eleazari mpe Itamari basalaki mosala na bango ya bonganga-Nzambe.  
\v 3 Tala ndenge Davidi akabolaki bango kolanda misala oyo bapesaki bango : Tsadoki, na etuka ya Eleazari ; Ayimeleki, na etuka ya Itamari. 
\p  
\v 4 Bamonaki ete kati na bakitani ya Eleazari, bana mibali bazalaki ebele koleka bato oyo bazalaki kati na bakitani ya Itamari. Boye, bakabolaki bana mibali ya Eleazari lokola bakonzi ya mabota zomi na motoba mpe bana mibali ya Itamari lokola bakonzi ya mabota mwambe.  
\v 5 Babetaki zeke mpo na kokabola bango, pamba te kati na bakitani ya Eleazari mpe ya Itamari, ezalaki na bakambi ya Esika ya bule mpe bakambi ya mosala ya Nzambe.  
\v 6 Shemaya, mokomi mikanda, mwana mobali ya Netaneeli, na libota ya Levi, akomaki bakombo na bango na miso ya mokonzi, ya bakambi, ya Nganga-Nzambe Tsadoki, ya Ayimeleki, mwana mobali ya Abiatari ; mpe ya bakambi ya mabota ya Banganga-Nzambe mpe Balevi. Babetaki zeke mbala mibale mpo na etuka ya Eleazari, mpe mbala moko, mpo na etuka ya Itamari. 
\b  
\li4  
\v 7 Tala ndenge bakambi ya mabota baponamaki na nzela ya zeke : 
\li1 zeke ya liboso ekweyaki epai ya Yeoyaribi ; 
\li1 zeke ya mibale ekweyaki epai ya Yedaeya ; 
\li1  
\v 8 zeke ya misato ekweyaki epai ya Arimi ; 
\li1 zeke ya minei ekweyaki epai ya Seorimi ; 
\li1  
\v 9 zeke ya mitano ekweyaki epai ya Malikiya ; 
\li1 zeke ya motoba ekweyaki epai ya Miyamini ; 
\li1  
\v 10 zeke ya sambo ekweyaki epai ya Akotsi ; 
\li1 zeke ya mwambe ekweyaki epai ya Abiya ; 
\li1  
\v 11 zeke ya libwa ekweyaki epai ya Jozue ; 
\li1 zeke ya zomi ekweyaki epai ya Shekania ; 
\li1  
\v 12 zeke ya zomi na moko ekweyaki epai ya Eliashibi ; 
\li1 zeke ya zomi na mibale ekweyaki epai ya Yakimi ; 
\li1  
\v 13 zeke ya zomi na misato ekweyaki epai ya Upa ; 
\li1 zeke ya zomi na minei ekweyaki epai ya Yeshebeabi ; 
\li1  
\v 14 zeke ya zomi na mitano ekweyaki epai ya Biliga ; 
\li1 zeke ya zomi na motoba ekweyaki epai ya Imeri ; 
\li1  
\v 15 zeke ya zomi na sambo ekweyaki epai ya Eziri ; 
\li1 zeke ya zomi na mwambe ekweyaki epai ya Apitsetsi ; 
\li1  
\v 16 zeke ya zomi na libwa ekweyaki epai ya Petaya ; 
\li1 zeke ya tuku mibale ekweyaki epai ya Ezekieli ; 
\li1  
\v 17 zeke ya tuku mibale na moko ekweyaki epai ya Yakini ; 
\li1 zeke ya tuku mibale na mibale ekweyaki epai ya Gamuli ; 
\li1  
\v 18 zeke ya tuku mibale na misato ekweyaki epai ya Delaya ; 
\li1 zeke ya tuku mibale na minei ekweyaki epai ya Maazia. 
\p  
\v 19 Ezalaki ndenge wana nde bakabolaki bango mpe bazalaki kolandana kati na mosala mpo na kokota kati na Tempelo ya Yawe. Bazalaki kosala misala na bango kolanda mibeko oyo tata na bango, Aron, apesaki bango, mpe ndenge Yawe, Nzambe ya Isalaele, atindaki ye. 
\s1 Bakitani mosusu ya Levi 
\li4  
\v 20 Tala bakitani mosusu ya Levi oyo bazalaki bakambi ya bituka : 
\b  
\li1 Shubaeli, mpo na etuka ya Amirami ; 
\li1 Yedeya, mpo na etuka ya Shubaeli ; 
\li1  
\v 21 Yishiya, mpo na etuka ya Reabia ; 
\li1  
\v 22 Shelomoti, mpo na etuka ya Yitseari ; 
\li1 Yaati, mpo na etuka ya Shelomiti. 
\li1  
\v 23 Bana mibali ya Ebron : 
\li1 mwana ya liboso, Yeriya ; 
\li1 mwana ya mibale, Amaria ; 
\li1 mwana ya misato, Yaazieli ; 
\li1 mpe mwana ya minei, Yekameami ; 
\li1  
\v 24 Shamiri, mpo na etuka ya Mishe, mwana mobali ya Uzieli ; 
\li1  
\v 25 Zakari, mpo na etuka ya Yishiya, ndeko mobali ya Mishe. 
\li1  
\v 26 Bana mibali ya Merari : 
\li1 Maali mpe Mushi. 
\li1 Beno, mpo na etuka ya Yaaziya. 
\li1  
\v 27 Bakitani ya Merari : 
\li1 na nzela ya mwana na ye ya mobali Yaaziya : Beno, Shoami, Zakuri mpe Ibiri. 
\li1  
\v 28 Na nzela ya mwana na ye ya mobali Maali : 
\li1 Eleazari oyo atikalaki kobota te. 
\li1  
\v 29 Mpo na Kishi : 
\li1 Yerameeli, mwana na ye ya mobali. 
\li1  
\v 30 Bana mibali ya Mushi : 
\li1 Maali, Ederi mpe Yerimoti. 
\b  
\li4 Bango wana nde bazalaki bakitani ya Levi kolanda bituka na bango. 
\b  
\p  
\v 31 Bango mpe babetaki zeke lokola bandeko na bango ya mibali, bakitani ya Aron, na miso ya mokonzi Davidi, ya Tsadoki, ya Ayimeleki, ya bakambi ya mabota ya Banganga-Nzambe mpe ya Balevi. Boye bazalaki komona mabota nyonso ndenge moko, ezala libota ya kulutu to ya leki. 
\c 25  
\s1 Masanga ya bayembi 
\p  
\v 1 Na lisungi ya bakonzi ya mampinga, Davidi atiaki pembeni ndambo ya bana mibali ya Azafi, ya Emani mpe ya Yedutuni mpo na kosala mosala ya kosakola mpe ya kosalela banzenze, mandanda mpe manzanza. Tala bakombo ya bato oyo basalaki mosala yango : 
\b  
\li1  
\v 2 Mpo na bana mibali ya Azafi : 
\li2 Zakuri, Jozefi, Netania mpe Asareyela. Bana mibali ya Azafi bazalaki na bokambami ya tata na bango Azafi oyo azalaki kosakola na bokambami ya mokonzi. 
\li1  
\v 3 Mpo na Yedutuni, bazwaki kati na bana na ye ya mibali : 
\li2 Gedalia, Tseri, Ezayi, Shimei, Ashabia mpe Matitia. Bazalaki bango nyonso motoba na bokambami ya tata na bango Yedutuni oyo azalaki kosakola mpe kosalela lindanda mpo na kopesa matondi mpe kokumisa Yawe. 
\li1  
\v 4 Mpo na Emani, bazwaki kati na bana na ye ya mibali : 
\li2 Bukiya, Matania, Uzieli, Shebueli, Yerimoti, Anania, Anani, Eliyata, Gidaliti, Romamiti-Ezeri, Yoshibekasha, Maloti, Otiri mpe Maazioti.  
\v 5 Bango nyonso bazalaki bana mibali ya Emani, mosakoli ya mokonzi, oyo azalaki koyebisa ye maloba na Nzambe mpo na konetola nguya na Ye. Nzambe apesaki na Emani bana mibali zomi na minei mpe bana basi misato. 
\b  
\p  
\v 6 Bango nyonso bazalaki na bokambami ya tata na bango mpo na kobeta miziki na Tempelo ya Yawe mpe kobeta manzanza, mandanda mpe banzenze ; mpe mpo na kosala mosala kati na Ndako ya Nzambe. 
\p Azafi, Yedutuni mpe Emani bazalaki na bokambami ya mokonzi.  
\v 7 Motango na bango elongo na bandeko na bango ya mibali oyo bayekolaki koyembela Yawe malamu ezalaki nkama mibale na tuku mwambe na mwambe.  
\v 8 Ezala mpo na bakulutu to mpo na baleki, mpo na balakisi to mpo na bayekoli, bazalaki kobeta zeke mpo na kokabola misala na bango. 
\b  
\li1  
\v 9 Zeke ya liboso, oyo ezalaki mpo na libota ya Azafi, ekweyaki epai ya Jozefi, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1 Zeke ya mibale ekweyaki epai ya Gedalia, bandeko na ye ya mibali mpe bana na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 10 Zeke ya misato ekweyaki epai ya Zakuri, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 11 Zeke ya minei ekweyaki epai ya Yitseri, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 12 Zeke ya mitano ekweyaki epai ya Netania, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 13 Zeke ya motoba ekweyaki epai ya Bukiya, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 14 Zeke ya sambo ekweyaki epai ya Yesareela, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 15 Zeke ya mwambe ekweyaki epai ya Ezayi, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 16 Zeke ya libwa ekweyaki epai ya Matania, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 17 Zeke ya zomi ekweyaki epai ya Shimei, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 18 Zeke ya zomi na moko ekweyaki epai ya Azareeli, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 19 Zeke ya zomi na mibale ekweyaki epai ya Ashabia, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 20 Zeke ya zomi na misato ekweyaki epai ya Shubaeli, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 21 Zeke ya zomi na minei ekweyaki epai ya Matitia, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 22 Zeke ya zomi na mitano ekweyaki epai ya Yeremoti, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 23 Zeke ya zomi na motoba ekweyaki epai ya Anania, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 24 Zeke ya zomi na sambo ekweyaki epai ya Yoshibekasha, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 25 Zeke ya zomi na mwambe ekweyaki epai ya Anani, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 26 Zeke ya zomi na libwa ekweyaki epai ya Maloti, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 27 Zeke ya tuku mibale ekweyaki epai ya Eliyata, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 28 Zeke ya tuku mibale na moko ekweyaki epai ya Otiri, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 29 Zeke ya tuku mibale na mibale ekweyaki epai ya Gidaliti, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 30 Zeke ya tuku mibale na misato ekweyaki epai ya Maazioti, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\li1  
\v 31 Zeke ya tuku mibale na minei ekweyaki epai ya Romamiti-Ezeri, bana na ye ya mibali mpe bandeko na ye ya mibali : 
\li2 bazalaki bato zomi na mibale. 
\c 26  
\s1 Masanga ya bakengeli bikuke 
\li4  
\v 1 Tala masanga ya bakengeli bikuke : 
\b  
\li4 Mpo na bato ya Kore : 
\li1 Meshelemia, mwana mobali ya Kore, moko kati na bana mibali ya Azafi. 
\li1  
\v 2 Meshelemia azalaki na bana mibali oyo : 
\li2 mwana ya liboso, Zakari ; 
\li2 mwana ya mibale, Yediayeli ; 
\li2 mwana ya misato, Zebadia ; 
\li2 mwana ya minei, Yatinieli ; 
\li2  
\v 3 mwana ya mitano, Elami ; 
\li2 mwana ya motoba, Yoanani ; 
\li2 mpe mwana ya sambo, Eliowenayi. 
\li1  
\v 4 Obedi-Edomi mpe azalaki na bana mibali oyo : 
\li2 mwana ya liboso, Shemaya ; 
\li2 mwana ya mibale, Yozabadi ; 
\li2 mwana ya misato, Yoa ; 
\li2 mwana ya minei, Sakari ; 
\li2 mwana ya mitano, Netaneeli ; 
\li2  
\v 5 mwana ya motoba, Amieli ; 
\li2 mwana ya sambo, Isakari ; 
\li2 mwana ya mwambe, Pewulitayi ; 
\li2 pamba te Nzambe apambolaki Obedi-Edomi. 
\li1  
\v 6 Mwana na ye ya mobali Shemaya azalaki mpe na bana mibali oyo bazalaki bakambi ya libota ya tata na bango, pamba te bazalaki bilombe mibali.  
\v 7 Bana mibali ya Shemaya : 
\li2 Otini, Refaeli, Obedi, Elizabadi ; 
\li2 mpe bandeko na ye ya mibali oyo bazalaki bilombe, Eliwu mpe Samakia. 
\li4  
\v 8 Bango nyonso bazalaki bakitani ya Obedi-Edomi. Bango, bana na bango mpe bandeko na bango ya mibali bazalaki bilombe mpe bato ya mpiko mpo na mosala. Bakitani nyonso ya Obedi-Edomi bazalaki tuku motoba na mibale. 
\li4  
\v 9 Meshelemia azalaki na bana mibali mpe bandeko mibali oyo bazalaki bilombe : bango nyonso bazalaki zomi na mwambe. 
\b  
\li1  
\v 10 Osa, moko kati na bana mibali ya Merari, azalaki na bana mibali oyo : 
\li2 Shimiri oyo tata na ye atiaki ye mokonzi atako azalaki mwana ya liboso te ; 
\li2  
\v 11 Ilikia, mwana ya mibale ; 
\li2 Tebalia, mwana ya misato ; 
\li2 mpe Zakari, mwana ya minei. 
\li4 Bana mibali mpe bandeko mibali ya Osa bazalaki bango nyonso zomi na misato. 
\b  
\li4  
\v 12 Masanga ya bakengeli bikuke ezalaki na mokumba ya kokengela bikuke ya Tempelo ya Yawe, na bokambami ya bakonzi na bango ndenge bandeko na bango bazalaki mpe kosala.  
\v 13 Boye kobanda na leki kino na kulutu, bazalaki kobeta zeke mpo na ekuke moko na moko, kolanda mabota na bango. 
\li1  
\v 14 Mpo na ekuke ya ngambo ya este, zeke ekweyaki epai ya libota ya Shelemia. 
\li1 Bongo babetaki zeke mpo na mwana na ye ya mobali Zakari oyo azalaki mopesi toli ya bwanya, mpe zeke mpo na ekuke ya ngambo ya Nor ekweyaki likolo na ye. 
\li1  
\v 15 Mpo na ekuke ya ngambo ya sude, zeke ekweyaki epai ya Obedi-Edomi ; mpe mpo na ndako oyo babombelaka biloko, zeke ekweyaki epai ya bana na ye ya mibali. 
\li1  
\v 16 Mpo na ekuke ya ngambo ya weste mpe ekuke ya Shaleketi, na nzela oyo emata na likolo, zeke ekweyaki epai ya Shupimi mpe Osa. 
\b  
\li4 Tala ndenge bakabolaki masanga ya bakengeli bikuke : 
\li1  
\v 17 mokolo na mokolo, ezalaki na Balevi motoba na ngambo ya este, 
\li1 Balevi minei na ngambo ya nor, 
\li1 mpe Balevi minei na ngambo ya sude ; 
\li1 mpe masanga mibale oyo moko na moko ezalaki na bato mibale, na ndako oyo babombelaka biloko. 
\li1  
\v 18 Mpo na lopango ya weste, ezalaki na bakengeli minei na nzela ; mpe mibale kati na lopango. 
\b  
\li4  
\v 19 Oyo nde ezalaki masanga ya bakengeli bikuke oyo baponamaki kati na libota ya Kore mpe ya Merari. 
\s1 Misala mosusu ya Balevi 
\p  
\v 20 Balevi mosusu lokola Ayiya, bazalaki na mokumba ya kobatela bozwi ya Tempelo mpe biloko ya bule. 
\p  
\v 21 Tala bakitani ya Laedani, oyo bazalaki bato ya etuka ya Gerishoni mpe bakambi, moto na moto ya libota na ye : bato ya Yeyeli ;  
\v 22 mpe bana mibali ya Yeyeli : Zetami mpe ndeko na ye ya mobali Joeli. Bazalaki na mokumba ya kobatela bozwi ya Tempelo ya Yawe. 
\b  
\li4  
\v 23 Mpo na bakitani ya Amirami, ya Yitseari, ya Ebron mpe ya Uzieli : 
\b  
\li2  
\v 24 Shebueli, mokitani ya Gerishomi, mwana mobali ya Moyize, azalaki mokonzi ya babateli bozwi ya Tempelo.  
\v 25 Tala bandeko na ye ya mibali oyo babotamaki na nzela ya Eliezeri : Reabia, Ezayi, Yorami, Zikiri mpe Shelomiti. 
\li2  
\v 26 Shelomiti elongo na bandeko na ye ya mibali bazalaki na mokumba ya kobatela biloko nyonso oyo mokonzi Davidi abulisaki mpo na Yawe ; bakambi ya mabota, bakambi ya bankoto, bakambi ya bankama mpe bakonzi mosusu ya mampinga.  
\v 27 Babulisaki biloko mosusu oyo bazwaki na bitumba mpo na kobongisa Tempelo ya Yawe.  
\v 28 Shelomiti mpe bandeko na ye ya mibali bazalaki na mokumba ya kobatela biloko nyonso oyo Samuele, momoni makambo ; Saulo, mwana mobali ya Kishi ; Abineri, mwana mobali ya Neri ; Joabi oyo kombo ya mama na ye ezalaki « Tseruya, » babulisaki mpo na Yawe. 
\li2  
\v 29 Mpo na bakitani ya Yitseari : 
\li2 Kenania mpe bana na ye ya mibali oyo bazalaki bakomi mikanda mpe basambisi. Bazalaki na mokumba ya kotala makambo ya boyokani ya Isalaele na bikolo mosusu. 
\li2  
\v 30 Mpo na bakitani ya Ebron : 
\li2 Ashabia mpe bandeko na ye ya mibali, bilombe mibali nkoto moko na nkama sambo. Bazalaki kokamba Isalaele na ngambo ya weste ya Yordani ; mpe bazalaki na mokumba ya misala nyonso ya Yawe mpe ya mokonzi.  
\v 31 Mpo na bakitani ya Ebron : Yeriya azalaki mokonzi na bango, kolanda milongo ya mabota na bango. 
\li2 Na mobu ya tuku minei ya bokonzi ya Davidi, batalaki malamu na buku ya mabota mpe bamonaki kati na engumba Yaezeri ya Galadi, bilombe mibali kati na bakitani ya Ebron.  
\v 32 Yeriya azalaki na bandeko mibali nkoto mibale na nkama sambo : bazalaki bilombe mibali mpe bakambi ya mabota. Mokonzi Davidi apesaki bango mokumba ya misala nyonso ya Nzambe mpe ya mokonzi kati na libota ya Ribeni, ya Gadi mpe ya ndambo ya libota ya Manase. 
\c 27  
\s1 Bakonzi ya mampinga ya Davidi 
\li4  
\v 1 Tala bana ya Isalaele oyo bazalaki kosalela mokonzi : ezalaki na bakambi ya mabota, bakonzi ya bankoto mpe ya bankama ya basoda mpe bakomi mikanda. Mosala na bango ezalaki : kotala makambo oyo etali mabongisi ya mampinga. Sanza na sanza kati na mobu, lisanga moko ezalaki kokota na mosala mpe lisanga mosusu ezalaki kobima. Lisanga moko na moko ezalaki na mibali nkoto tuku mibale na minei. 
\b  
\li1  
\v 2 Mpo na sanza ya liboso : lisanga ya Yashobeami, mwana mobali ya Zabidieli ; lisanga yango ezalaki na mibali nkoto tuku mibale na minei.  
\v 3 Yashobeami azalaki mokitani ya Peretsi mpe azalaki mokonzi ya bakonzi nyonso ya mampinga mpo na sanza ya liboso. 
\li1  
\v 4 Mpo na sanza ya mibale : lisanga ya Dodayi, moto ya libota ya Aoyi. Mikiloti azalaki mokambi ya lisanga ya Dodayi. Lisanga yango ezalaki na mibali nkoto tuku mibale na minei. 
\li1  
\v 5 Mpo na sanza ya misato : lisanga ya Benaya, mwana mobali ya Yeoyada, mokonzi ya Banganga-Nzambe ; lisanga yango ezalaki na mibali nkoto tuku mibale na minei.  
\v 6 Benaya azalaki moko kati na basoda ya mpiko tuku misato mpe azalaki mokonzi na bango ; Amizadabi, mwana na ye ya mobali, azalaki moko kati na basoda ya lisanga yango. 
\li1  
\v 7 Mpo na sanza ya minei : lisanga ya Asaeli, ndeko mobali ya Joabi. Zebadia, mwana na ye ya mobali, akitanaki na ye ; lisanga yango ezalaki na bato nkoto tuku mibale na minei. 
\li1  
\v 8 Mpo na sanza ya mitano : lisanga ya mokambi Shamewuti, moto ya libota ya Yizirayi ; lisanga yango ezalaki na mibali nkoto tuku mibale na minei. 
\li1  
\v 9 Mpo na sanza ya motoba : lisanga ya Ira, mwana mobali ya Ikeshi, moto ya libota ya Tekoa ; lisanga yango ezalaki na mibali nkoto tuku mibale na minei. 
\li1  
\v 10 Mpo na sanza ya sambo : lisanga ya Eletsi, moto ya libota ya Peloni, moko kati na bato ya libota ya Efrayimi ; lisanga yango ezalaki na mibali nkoto tuku mibale na minei. 
\li1  
\v 11 Mpo na sanza ya mwambe : lisanga ya Sibekayi, moto ya libota ya Usha, moko kati na bakitani ya Zera ; lisanga yango ezalaki na mibali nkoto tuku mibale na minei. 
\li1  
\v 12 Mpo na sanza ya libwa : lisanga ya Abiezeri, moto ya libota ya Anatoti, moko kati na bato ya libota ya Benjame ; lisanga yango ezalaki na bato nkoto tuku mibale na minei. 
\li1  
\v 13 Mpo na sanza ya zomi : lisanga ya Maarayi, moto ya libota ya Netofa, moko kati na bakitani ya Zera ; lisanga yango ezalaki na mibali nkoto tuku mibale na minei. 
\li1  
\v 14 Mpo na sanza ya zomi na moko : lisanga ya Benaya, moto ya libota ya Piratoni, moko kati na bato ya libota ya Efrayimi ; lisanga yango ezalaki na mibali nkoto tuku mibale na minei. 
\li1  
\v 15 Mpo na sanza ya zomi na mibale : lisanga ya Elidayi, moto ya libota ya Netofa, moko kati na bakitani ya Otinieli ; lisanga yango ezalaki na mibali nkoto tuku mibale na minei. 
\s1 Bakonzi ya mabota ya Isalaele 
\li4  
\v 16 Tala bakonzi ya mabota ya Isalaele : 
\b  
\li1 Mpo na libota ya Ribeni : 
\li2 Eliezeri, mwana mobali ya Zikiri ; 
\li1 mpo na libota ya Simeoni : 
\li2 Shefatia, mwana mobali ya Maaka ; 
\li1  
\v 17 mpo na libota ya Levi : 
\li2 Ashabia, mwana mobali ya Kemweli ; 
\li1 mpo na libota ya Aron : 
\li2 Tsadoki ; 
\li1  
\v 18 mpo na libota ya Yuda : 
\li2 Eliwu, ndeko mobali ya Davidi ; 
\li1 mpo na libota ya Isakari : 
\li2 Omiri, mwana mobali ya Mikaeli ; 
\li1  
\v 19 mpo na libota ya Zabuloni : 
\li2 Yishimaeya, mwana mobali ya Abidiasi ; 
\li1 mpo na libota ya Nefitali : 
\li2 Yerimoti, mwana mobali ya Azirieli ; 
\li1  
\v 20 mpo na libota ya Efrayimi : 
\li2 Oze, mwana mobali ya Azazia ; 
\li1 mpo na ndambo ya libota ya Manase : 
\li2 Joeli, mwana mobali ya Pedaya ; 
\li1  
\v 21 mpo na ndambo ya libota ya Manase kati na Galadi : 
\li2 Yido, mwana mobali ya Zakari ; 
\li1 mpo na libota ya Benjame : 
\li2 Yaasieli, mwana mobali ya Abineri ; 
\li1  
\v 22 mpo na libota ya Dani : 
\li2 Azareeli, mwana mobali ya Yeroami. 
\b  
\li4 Bango wana nde bazalaki bakonzi ya mabota ya Isalaele. 
\b  
\p  
\v 23 Davidi atangaki te molongo ya mibali oyo bazalaki na se ya mibu tuku mibale ya mbotama, pamba te Yawe alakaki ete akokomisa Isalaele ebele lokola minzoto ya likolo.  
\v 24 Joabi, mwana mobali ya Tseruya, abandaki kotanga bango kasi asilisaki te. Pamba te likolo ya botangi wana, Yawe akitiselaki Isalaele kanda na Ye. Boye, motango ya bato yango ekomamaki te na buku ya masolo ya mokonzi Davidi. 
\s1 Babateli bozwi ya mokonzi 
\li1  
\v 25 Azimaveti, mwana mobali ya Adieli, azalaki kobatela bibombelo ya bozwi ya mokonzi. 
\li1 Jonatan, mwana mobali ya Oziasi, azalaki mobateli ya bibombelo na bazamba, na bingumba, na bamboka mike mpe na bandako milayi. 
\li1  
\v 26 Eziri, mwana mobali ya Kelubi, azalaki mokambi ya basali bilanga ; 
\li1  
\v 27 Shimei, moto ya engumba Rama, azalaki mobateli bilanga ya vino ; 
\li1 Zabidi, moto ya engumba Shefami, azalaki mobateli masanga ya vino mpe bilanga ya vino. 
\li1  
\v 28 Bala-Anani, moto ya engumba Gederi, azalaki mobateli banzete ya olive mpe ya sikomori, na lubwaku ya ngambo ya weste ; 
\li1 Yoashi azalaki mobateli mafuta ya olive ; 
\li1  
\v 29 Shitrayi, moto ya engumba Saroni, azalaki mobateli bangombe oyo ezalaki kolia na Saroni ; 
\li1 Shafati, mwana mobali ya Adilayi, azalaki mobateli bangombe na mabwaku. 
\li1  
\v 30 Obili, moto ya libota ya Isimaeli, azalaki mobateli bashamo ; 
\li1 Yedeya, moto ya libota ya Meronoti, azalaki mobateli ba-ane ya basi. 
\li1  
\v 31 Yazizi, moto ya libota ya Agari, azalaki mobateli bibwele. 
\li4 Bango nyonso bazalaki babateli bozwi ya mokonzi Davidi. 
\b  
\li1  
\v 32 Jonatan, ndeko ya tata ya Davidi, azalaki mopesi toli, moto ya mayele mpe mokomi mikanda. 
\li1 Yeyeli, mwana mobali ya Akimoni, azalaki kolandela bana mibali ya mokonzi. 
\li1  
\v 33 Ayitofeli azalaki mopesi toli ya mokonzi ; 
\li1 mpe Ushayi, moto ya Ariki, azalaki mobateli sekele ya mokonzi. 
\li4  
\v 34 Yeoyada, mwana mobali ya Benaya, elongo na Abiatari, bakitanaki na Ayitofeli. 
\li1 Joabi azalaki mokonzi ya mampinga ya mokonzi. 
\c 28  
\s1 Mabongisi ya Davidi mpo na Ndako ya Nzambe 
\p  
\v 1 Davidi abengisaki bakambi nyonso ya Isalaele, na Yelusalemi : bakonzi ya mabota, bakonzi ya masanga ya basoda oyo bazalaki kosalela mokonzi, bakonzi ya bankoto mpe ya bankama ya basoda, babateli bozwi mpe bibwele ya mokonzi, bato oyo balandelaka bana na ye ya mibali elongo na basali ya ndako ya mokonzi, basoda ya mpiko mpe bato nyonso ya lokumu.  
\v 2 Mokonzi Davidi atelemaki mpe alobaki : 
\pi1 — Boyoka ngai, bandeko na ngai mpe bato na ngai : Nazalaki na likanisi ya kotonga esika ya kopema mpo na Sanduku ya Boyokani ya Yawe, enyatelo ya makolo ya Nzambe na biso ; bongo nabongisaki biloko mpo na kotonga yango.  
\v 3 Kasi Nzambe alobaki na ngai : « Okotonga ndako mpo na Kombo na Ngai te, pamba te ozali moto ya bitumba mpe osopaki makila. » 
\pi1  
\v 4 Nzokande, Yawe, Nzambe ya Isalaele, aponaki ngai kati na libota na ngai mobimba mpo ete nazala mokonzi ya Isalaele mpo na libela. Aponaki Yuda mpo ete azala mokonzi ; mpe kati na ndako ya Yuda, aponaki libota ya tata na ngai ; mpe kati na bana mibali ya tata na ngai, asepelaki kokomisa ngai mokonzi ya Isalaele mobimba.  
\v 5 Kati na bana na ngai nyonso ya mibali, pamba te Yawe apesi ngai bango ebele, aponaki Salomo, mwana na ngai ya mobali, mpo ete avanda na Kiti ya Bokonzi ya Yawe kati na Isalaele.  
\v 6 Alobaki na ngai : « Mwana na yo, Salomo, nde akotonga Ndako na Ngai mpe lopango na Ngai, pamba te naponaki ye mpo ete azala mwana mpo na Ngai, mpe Ngai nakozala tata mpo na ye.  
\v 7 Nakolendisa bokonzi na ye mpo na libela soki akangami makasi na mibeko na Ngai ndenge azali kosala yango lelo. » 
\pi1  
\v 8 Sik’oyo, napesi bino mokumba liboso ya Isalaele mobimba, ya lisanga ya Yawe, mpe liboso ya Nzambe na biso, oyo azali koyoka biso : Bosala keba mpo na kolanda mitindo nyonso ya Yawe, Nzambe na bino, mpo ete bozwa mokili oyo ya kitoko mpe kotika yango lokola libula epai ya bakitani na bino mpo na libela.  
\v 9 Bongo, yo Salomo, mwana na ngai, yeba Nzambe ya tata na yo mpe salela Ye na motema na yo mobimba mpe na esengo ; pamba te Yawe amonaka kino na bozindo ya mitema nyonso mpe asosolaka makanisi na yango nyonso. Soki oluki Ye, okomona Ye ; kasi soki atiki Ye, akobwaka yo mpo na libela.  
\v 10 Yeba sik’oyo ete Yawe aponi yo mpo ete otongela Ye Ndako oyo ekozala Esika na Ye ya Bule. Yika mpiko mpe sala mosala. 
\p  
\v 11 Davidi apesaki Salomo, mwana na ye ya mobali, elili ya ndako moke ya kokotela na Tempelo, ya bandako mosusu ya Tempelo, ya bibombelo na yango, ya bashambre na yango ya likolo, ya bashambre na yango ya kati mpe ya esika ya bolimbisi masumu.  
\v 12 Apesaki ye elili ya nyonso oyo molimo atiaki na makanisi na ye na tina na lopango ya Tempelo ya Yawe, ya bashambre nyonso ya zingazinga, ya biloko ya talo ya Ndako ya Nzambe mpe ya biloko ya bule.  
\v 13 Davidi apesaki ye mibeko na tina na masanga ya Banganga-Nzambe mpe ya Balevi, na tina na misala nyonso mpe bisalelo nyonso ya Tempelo ya Yawe.  
\v 14 Mpo na bisalelo ya mosala, Davidi atalisaki kilo ya wolo oyo ekoki mpo na bisalelo nyonso ya wolo ; kilo ya palata oyo ekoki mpo na bisalelo nyonso ya palata :  
\v 15 kilo ya wolo mpo na bitelemiselo ya minda basala na wolo mpe minda na yango ya wolo kolanda kilo ya etelemiselo moko na moko ya minda elongo na minda na yango ; kilo ya palata mpo na etelemiselo moko na moko ya minda, basala na palata mpe minda na yango ya palata kolanda mosala ya etelemiselo moko na moko ya mwinda ;  
\v 16 kilo ya wolo mpo na mesa moko na moko ya mapa oyo ebulisami, kilo ya palata mpo na bamesa ya palata ;  
\v 17 kilo ya wolo ya peto mpo na bakanya, basani oyo basalelaka mpo na kosopa mayi, mpe mpo na bakopo ya milayi ; kilo ya wolo mpo na kopo moko na moko ya moke moko ; kilo ya palata mpo na moko na moko ya bakopo mike ya palata ;  
\v 18 mpe kilo ya wolo ya peto mpo na etumbelo ya malasi. Apesaki ye lisusu elili ya shar ya basheribe ya wolo oyo mapapu na yango ezali ya kofungwama mpe ezipi Sanduku ya Boyokani ya Yawe. 
\p  
\v 19 Davidi alobaki : 
\pi1 — Nyonso oyo nazali na yango na mokanda oyo, ekomami na loboko na Yawe ; Ye moko apesi ngai mayele mpo na kososola misala nyonso oyo elili ezali kotalisa. 
\p  
\v 20 Davidi alobaki lisusu na Salomo, mwana na ye ya mobali : 
\pi1 — Yika mpiko mpe sala mosala ! Kobanga te, kozala mpe na somo te ; pamba te Yawe, Nzambe na ngai, azali elongo na yo ; akotika yo te mpe akobwaka yo te kino mosala nyonso ya Tempelo ya Yawe ekosila.  
\v 21 Ezali mpe na masanga ebele ya Banganga-Nzambe mpe ya Balevi oyo babongisami mpo na misala ya ndenge na ndenge kati na Tempelo ya Yawe. Na mosala oyo nyonso, okozwa lisungi ya bato oyo bayebi mosala malamu, oyo bamipesa bango moko mpo na misala ya ndenge na ndenge. Bakonzi mpe bato nyonso bakotosa mitindo na yo. 
\c 29  
\s1 Makabo mpo na kotonga Tempelo ya Yawe 
\p  
\v 1 Mokonzi Davidi alobaki na lisanga mobimba : 
\pi1 — Salomo, mwana na ngai ya mobali, moko kaka oyo Nzambe aponi, azali nanu elenge mpe ayebi penza makambo malamu te. Nzokande, mosala ezali monene, pamba te Ndako oyo ezali mpo na moto te kasi mpo na Yawe Nzambe.  
\v 2 Na bozwi na ngai nyonso, nabongisaki mpo na Ndako ya Nzambe na ngai : wolo mpo na misala ya wolo, palata mpo na misala ya palata, ebende mpo na misala ya bibende, mabaya mpo na misala ya mabaya, mabanga ya onikisi mpe mabanga ya kobamba, mabanga oyo engengaka mpe ya balangi ebele, mabanga ya talo ya lolenge nyonso mpe mabanga ya marbre. Biloko oyo nyonso ezalaki penza ebele.  
\v 3 Mpe lisusu, na tina na bolingo na ngai mpo na Ndako ya Nzambe na ngai, napesi sik’oyo wuta na bozwi na ngai moko : wolo mpe palata mpo na Ndako ya Nzambe na ngai likolo ya nyonso oyo nabongisaki mpo na Ndako oyo ya bule :  
\v 4 kilo nkoto nkama moko ya wolo ya peto ya Ofiri, kilo nkoto nkama mibale na tuku mitano ya palata ya peto mpo na kolatisa bamir ya Ndako.  
\v 5 Wolo mpe palata yango ebongisami mpo na misala ya wolo mpe ya palata, mpe mpo na misala nyonso oyo bato ya misala ya maboko basengeli kosala. Sik’oyo, nani alingi kopesa na esengo mpe na motema moko epai na Yawe ? 
\p  
\v 6 Boye, bakambi ya mabota, bakonzi ya mabota ya Isalaele, bakonzi ya bankoto mpe ya bankama mpe bakambi ya misala ya mokonzi bapesaki makabo wuta na mitema na bango moko.  
\v 7 Mbala moko, bapesaki mpo na mosala ya Ndako ya Nzambe : bakilo nkama tuku sambo ya wolo, biloko ya wolo nkoto zomi, bakilo koleka minkoko nkama misato ya palata, bakilo nkoto nkama motoba ya bronze, mpe bakilo koleka minkoko misato ya bibende.  
\v 8 Bato nyonso oyo bazalaki na mabanga ya talo bapesaki yango na ebombelo ya bozwi ya Tempelo ya Yawe epai ya Yeyeli, moto ya libota ya Gerishoni.  
\v 9 Bato basepelaki mingi na makabo oyo bango moko bapesaki wuta na mokano ya mitema na bango, pamba te bazalaki kopesa yango epai ya Yawe, na motema mobimba. Mokonzi Davidi mpe asepelaki na yango mingi. 
\s1 Losambo ya Davidi 
\p  
\v 10 Davidi akumisaki Yawe liboso ya lisanga mobimba na maloba oyo : 
\q1 « Oh Yawe, Nzambe ya Isalaele, tata na biso, 
\q2 tika ete ozwa lokumu mpo na libela ! 
\q1  
\v 11 Oh Yawe, monene, nguya, kongenga, 
\q2 nkembo mpe bokonzi ezali ya Yo ; 
\q1 pamba te biloko nyonso oyo ezali na likolo mpe na se ezali ya Yo. 
\q2 Yawe, bokonzi ezali ya Yo, 
\q2 osalaka nyonso oyo olingi na ekelamu nyonso. 
\q1  
\v 12 Bozwi mpe lokumu ewutaka epai na Yo ; 
\q2 ozali na bokonzi likolo na nyonso, 
\q1 makasi mpe nguya ezali na maboko na Yo 
\q2 mpo na kotombola mpe kopesa makasi na moto nyonso. 
\q1  
\v 13 Nzambe na biso, tozali sik’oyo kosanzola Yo 
\q2 mpe kokumisa Kombo na Yo. 
\q1  
\v 14 Nazali nani, mpe bato na ngai bazali banani, 
\q2 mpo ete tozwa makoki ya kopesa makabo oyo, 
\q1 wuta na mokano ya mitema na biso moko ? 
\q2 Nyonso ewutaka epai na Yo, 
\q2 mpe topesi Yo kaka oyo ewuti na loboko na Yo. 
\q1  
\v 15 Liboso na Yo, tozali bapaya mpe baleki nzela, 
\q2 ndenge ezalaki batata na biso. 
\q1 Mikolo na biso awa na mokili ezali koleka 
\q2 lokola elili oyo ezangi elikya. 
\q1  
\v 16 Oh Yawe, Nzambe na biso, 
\q2 bomengo nyonso oyo tobongisi mpo na kotonga Tempelo 
\q1 mpo na lokumu ya Kombo na Yo ya Bule 
\q2 ewuti na loboko na Yo mpe ezali ya Yo. 
\q1  
\v 17 Oh Nzambe na ngai, 
\q2 nayebi ete oyebi bozindo ya mitema na biso, 
\q1 osepelaka na bosembo. 
\q2 Napesi nyonso oyo wuta na mokano ya motema na ngai moko 
\q1 mpe na makanisi ya lokuta te. 
\q2 Sik’oyo, namoni ndenge nini bato na Yo, oyo bazali awa, 
\q2 bapesi Yo makabo oyo na motema malamu. 
\q1  
\v 18 Oh Yawe, Nzambe ya Abrayami, Izaki mpe Isalaele, batata na biso, 
\q2 batela makanisi oyo kati na mitema ya bato na Yo mpo na libela 
\q2 mpe sala ete mitema na bango ekangama na Yo. 
\q1  
\v 19 Pesa na mwana na ngai ya mobali, Salomo, motema ya boyengebene 
\q2 mpo na kobatela mitindo na Yo, malako na Yo mpe bikateli na Yo ; 
\q1 mpo na kosala nyonso mpe kotonga Ndako 
\q2 oyo nasaleli mabongisi oyo nyonso. » 
\p  
\v 20 Davidi alobaki na bato nyonso : 
\pi1 — Bopambola Yawe, Nzambe na bino ! 
\p Boye, bato nyonso bakumisaki Yawe, Nzambe ya bakoko na bango, bagumbamaki mpe bafukamaki liboso ya Yawe mpe ya mokonzi. 
\s1 Bapakoli Salomo mafuta ya bokonzi 
\p  
\v 21 Mokolo oyo elandaki, babonzaki bambeka mpe bambeka ya kotumba epai na Yawe : bangombe ya mibali nkoto moko, bameme ya mibali nkoto moko mpe bana meme nkoto moko elongo na makabo ya masanga ya vino mpe makabo mosusu ebele, mpo na Isalaele mobimba.  
\v 22 Baliaki mpe bamelaki liboso ya Yawe na esengo na mokolo wana, mpe batatolaki mpo na mbala ya mibale ete Salomo, mwana mobali ya Davidi, azali mokonzi. Bapakolaki ye mafuta mpo ete azala mokonzi ; mpe Tsadoki, mpo ete azala Nganga-Nzambe.  
\v 23 Salomo avandaki na Kiti ya Bokonzi ya Yawe lokola mokonzi na esika ya Davidi, tata na ye. Apambolamaki mpe Isalaele mobimba etosaki ye.  
\v 24 Bakonzi nyonso, basoda ya mpiko mpe bana nyonso ya mibali ya mokonzi Davidi batosaki mokonzi Salomo.  
\v 25 Yawe atombolaki Salomo makasi liboso ya Isalaele mobimba, mpe apesaki ye lokumu ya bokonzi koleka bakonzi nyonso ya Isalaele oyo balekaki liboso na ye. 
\s1 Kufa ya Davidi 
\r (1Ba 2.10-12) 
\p  
\v 26 Davidi, mwana mobali ya Izayi, azalaki mokonzi ya Isalaele mobimba.  
\v 27 Davidi akonzaki Isalaele mibu tuku minei : mibu sambo na Ebron mpe mibu tuku misato na misato na Yelusalemi. 
\p  
\v 28 Akufaki na kimobange ya esengo. Atondisamaki na mibu ebele, na bozwi mpe na lokumu ; bongo Salomo, mwana na ye ya mobali, akitanaki na ye na bokonzi. 
\p  
\v 29 Makambo mosusu oyo etali bokonzi ya Davidi, wuta na ebandeli kino na suka, ekomama kati na buku ya misala ya mosakoli Samuele, na buku ya misala ya mosakoli Natan mpe na buku ya misala ya mosakoli Gadi.  
\v 30 Kati na babuku ya misala yango, balobelaki mpe makambo nyonso ya bokonzi mpe ya makasi na ye, makambo nyonso oyo ekomelaki ye, Isalaele mpe mikili nyonso ya zingazinga.