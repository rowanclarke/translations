\v 9 “\w Therefore|strong="H3068"\w*, keep \w the|strong="H3605"\w* terms \w of|strong="H3068"\w* \w this|strong="H6440"\w* covenant \w and|strong="H3478"\w* obey \w them|strong="H6440"\w* \w so|strong="H6440"\w* \w that|strong="H3605"\w* \w you|strong="H6440"\w* \w may|strong="H3068"\w* \w be|strong="H3068"\w* successful \w in|strong="H3478"\w* \w everything|strong="H3605"\w* \w you|strong="H6440"\w* \w do|strong="H3068"\w*.  
