\v 9 \w Philisti|strong="H6430"\w* rhoek te \w cet|strong="H5927"\w* uh \w tih|strong="H9999"\w* \w Judah|strong="H3063"\w* \w ah|strong="H9996"\w* a \w rhaeh|strong="H2583"\w* uh \w hatah|strong="H9999"\w* \w Lehi|strong="H3896"\w* kaep ah khaw khawk \w yaal|strong="H5203"\w* uh.  
\v 10 Te \w dongah|strong="H9999"\w* \w Judah|strong="H3063"\w* \w hlang|strong="H0376"\w* rhoek loh, “\w Balae|strong="H4100"\w* \w tih|strong="H9997"\w* \w kaimih|strong="H9900"\w* \w soah|strong="H5921"\w* na \w luei|strong="H5927"\w* uh,” a \w ti|strong="H0559"\w* nah \w hatah|strong="H9999"\w*, “\w Samson|strong="H8123"\w* \w te|strong="H0853"\w* \w khoh|strong="H0631"\w* \w ham|strong="H9997"\w* neh \w kaimih|strong="H9900"\w* \w taengah|strong="H9997"\w* a \w saii|strong="H6213"\w* \w bangla|strong="H9995"\w* \w anih|strong="H9909"\w* \w taengah|strong="H9997"\w* \w saii|strong="H6213"\w* van \w ham|strong="H9997"\w* kam \w paan|strong="H5927"\w* uh coeng,” a \w ti|strong="H0559"\w* uh.   
\p
\v 11 Te \w dongah|strong="H9999"\w* \w Judah|strong="H3063"\w* \w hlang|strong="H0376"\w* \w thawng|strong="H0505"\w* \w thum|strong="H7969"\w* te \w Etam|strong="H5862"\w* \w thaelpang|strong="H5553"\w* kah \w thaelvap|strong="H5585"\w* \w la|strong="H0413"\w* \w suntla|strong="H3381"\w* uh \w tih|strong="H9999"\w* \w Samson|strong="H8123"\w* \w te|strong="H9997"\w*, “\w Philisti|strong="H6430"\w* loh \w mamih|strong="H9900"\w* ng'\w ngol|strong="H4910"\w* \w thil|strong="H9996"\w* \w te|strong="H3588"\w* na \w ming|strong="H3045"\w* \w pawt|strong="H3808"\w* \w nim|strong="H9994"\w*, \w kaimih|strong="H9900"\w* \w ham|strong="H9997"\w* \w balae|strong="H4100"\w* na \w saii|strong="H6213"\w* \w he|strong="H2063"\w*?,” a \w ti|strong="H0559"\w* na uh.  
\p \w Tedae|strong="H9999"\w* \w amih|strong="H9908"\w* \w te|strong="H9997"\w* Samson loh, “\w Kai|strong="H9901"\w* \w taengah|strong="H9997"\w* a \w saii|strong="H6213"\w* uh \w vanbanglam|strong="H9995"\w* ni \w amih|strong="H9908"\w* \w taengah|strong="H9997"\w* khaw ka \w saii|strong="H6213"\w* \w van|strong="H3651"\w*,” a \w ti|strong="H0559"\w* nah.   
\p
\v 12 Te \w vaengah|strong="H9999"\w*, “\w Nang|strong="H9905"\w* \w khih|strong="H0631"\w* \w ham|strong="H9997"\w* neh \w Philisti|strong="H6430"\w* \w kut|strong="H3027"\w* \w ah|strong="H9996"\w* \w tloeng|strong="H5414"\w* \w ham|strong="H9997"\w* ni ka \w suntlak|strong="H3381"\w* uh,” a \w ti|strong="H0559"\w* uh. Te \w dongah|strong="H9999"\w* \w amih|strong="H9908"\w* \w te|strong="H9997"\w* \w Samson|strong="H8123"\w* loh, “\w Kai|strong="H9901"\w* \w taengah|strong="H9997"\w* \w toemngam|strong="H7650"\w* uh dae, \w kai|strong="H9901"\w* tarha \w nan|strong="H0859"\w* \w cuuk|strong="H6293"\w* uh \w thil|strong="H9996"\w* \w ve|strong="H6435"\w*,” a \w ti|strong="H0559"\w* nah.   
\p
\v 13 Te \w dongah|strong="H9999"\w* \w Samson|strong="H9909"\w* \w te|strong="H9997"\w* a \w doo|strong="H0559"\w* uh tih, “\w Nang|strong="H9905"\w* te \w dawk|strong="H3588"\w* kang \w khih|strong="H0631"\w* la kang \w khih|strong="H0631"\w* uh \w vetih|strong="H9999"\w* \w a|strong="H9908"\w* \w kut|strong="H3027"\w* \w ah|strong="H9996"\w* kan \w tloeng|strong="H5414"\w* ham ngawn ni, \w nang|strong="H9905"\w* te kan \w duek|strong="H4191"\w* rhoe kan \w duek|strong="H4191"\w* sak uh \w mahpawh|strong="H3808"\w*,” a \w ti|strong="H0559"\w* na uh. Te \w dongah|strong="H9999"\w* \w anih|strong="H9909"\w* te \w rhuivaeh|strong="H5688"\w* a \w thai|strong="H2319"\w* \w rhoi|strong="H8147"\w* \w neh|strong="H9996"\w* a \w khih|strong="H0631"\w* uh \w tih|strong="H9999"\w* \w thaelpang|strong="H5553"\w* \w lamloh|strong="H4480"\w* a \w khuen|strong="H5927"\w* uh.   
\p
\v 14 \w Lehi|strong="H3896"\w* \w la|strong="H5704"\w* a \w pawk|strong="H0935"\w* \w vaengah|strong="H9999"\w* \w anih|strong="H9909"\w* te \w doe|strong="H7122"\w* \w hamla|strong="H9997"\w* \w Philisti|strong="H6430"\w* rhoek \w yuhui|strong="H7321"\w* uh. \w Tedae|strong="H9999"\w* \w anih|strong="H9909"\w* \w te|strong="H5921"\w* \w BOEIPA|strong="H3068"\w* \w Mueihla|strong="H7307"\w* loh a \w thaihtak|strong="H6743"\w* sak \w dongah|strong="H9999"\w* \w a|strong="H9909"\w* \w ban|strong="H2220"\w* \w dongkah|strong="H5921"\w* \w rhuivaeh|strong="H5688"\w* te \w hmai|strong="H0784"\w* \w neh|strong="H9996"\w* a \w do|strong="H1197"\w* \w hlamik|strong="H6593"\w* \w bangla|strong="H9995"\w* \w poeh|strong="H1961"\w*. Te \w dongah|strong="H9999"\w* \w a|strong="H9909"\w* \w kut|strong="H3027"\w* \w dong|strong="H5921"\w* \w lamkah|strong="H4480"\w* \w a|strong="H9909"\w* \w pinyennah|strong="H0612"\w* te \w tlae|strong="H4549"\w*.  
\v 15 Te \w vaengah|strong="H9999"\w* \w laak|strong="H2543"\w* kah a \w kam|strong="H3895"\w* \w haeng|strong="H2961"\w* te a \w hmuh|strong="H4672"\w* \w dongah|strong="H9999"\w* \w a|strong="H9909"\w* \w kut|strong="H3027"\w* a \w yueng|strong="H7971"\w* \w tih|strong="H9999"\w* a \w loh|strong="H3947"\w*. \w Te|strong="H9907"\w* \w nen|strong="H9996"\w* te \w hlang|strong="H0376"\w* \w thawngkhat|strong="H0505"\w* a \w ngawn|strong="H5221"\w*.  
\v 16 Te \w dongah|strong="H9999"\w* \w Samson|strong="H8123"\w* loh, “\w Laak|strong="H2543"\w* kah a \w kam|strong="H3895"\w* \w neh|strong="H9996"\w* \w paelh|strong="H2565"\w* \w paelh|strong="H2565"\w*, \w laak|strong="H2543"\w* kah \w kam|strong="H3895"\w* \w neh|strong="H9996"\w* \w hlang|strong="H0376"\w* \w thawngkhat|strong="H0505"\w* ka \w ngawn|strong="H5221"\w* coeng,” a \w ti|strong="H0559"\w*.  
\v 17 A \w thui|strong="H1696"\w* \w te|strong="H9997"\w* \w a|strong="H9909"\w* \w khah|strong="H3615"\w* \w nen|strong="H9995"\w* tah \w a|strong="H9909"\w* \w kut|strong="H3027"\w* \w dongkah|strong="H4480"\w* laak \w kam|strong="H3895"\w* \w te|strong="H9998"\w* khaw vik a \w voeih|strong="H7993"\w*. Te \w phoeiah|strong="H9999"\w* \w tekah|strong="H1931"\w* \w hmuen|strong="H4725"\w* \w te|strong="H9997"\w* \w Ramathlehi|strong="H7437"\w* a \w sak|strong="H7121"\w*.  
