\s1 God sent a rainbow to help people remember what he promised  
\p
\v 12 \w And|strong="H5769"\w* \w God|strong="H5414"\w* said, “\w I|strong="H5414"\w* \w will|strong="H5315"\w* \w give|strong="H5414"\w* \w you|strong="H5414"\w* \w something|strong="H3605"\w* \w to|strong="H5414"\w* help \w you|strong="H5414"\w* remember \w what|strong="H2063"\w* \w I|strong="H5414"\w* \w promised|strong="H5414"\w* \w to|strong="H5414"\w* \w you|strong="H5414"\w*, \w and|strong="H5769"\w* \w to|strong="H5414"\w* \w all|strong="H3605"\w* \w of|strong="H3605"\w* \w the|strong="H3605"\w* \w animals|strong="H2416"\w* \w living|strong="H2416"\w* \w on|strong="H3605"\w* \w the|strong="H3605"\w* earth, \w and|strong="H5769"\w* \w to|strong="H5414"\w* \w your|strong="H3605"\w* kids, \w and|strong="H5769"\w* \w to|strong="H5414"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5315"\w* \w that|strong="H3605"\w* \w will|strong="H5315"\w* \w be|strong="H5769"\w* born later \w on|strong="H3605"\w*.  
\v 13 \w It|strong="H5414"\w* \w is|strong="H1961"\w* \w my|strong="H5414"\w* \w rainbow|strong="H7198"\w*, \w up|strong="H5414"\w* \w there|strong="H1961"\w* \w in|strong="H5414"\w* \w the|strong="H5414"\w* sky. \w I|strong="H5414"\w*’m \w putting|strong="H5414"\w* \w it|strong="H5414"\w* \w there|strong="H1961"\w* \w to|strong="H1961"\w* \w help|strong="H1961"\w* \w you|strong="H5414"\w* remember what \w I|strong="H5414"\w* \w promised|strong="H5414"\w* \w to|strong="H1961"\w* \w you|strong="H5414"\w*, \w and|strong="H1285"\w* \w to|strong="H1961"\w* everything \w that|strong="H5414"\w* \w lives|strong="H1961"\w* \w on|strong="H1961"\w* \w the|strong="H5414"\w* earth. \w I|strong="H5414"\w* \w promised|strong="H5414"\w* \w that|strong="H5414"\w* \w I|strong="H5414"\w* \w will|strong="H1961"\w* never \w again|strong="H1961"\w* \w send|strong="H5414"\w* \w a|strong="H3068"\w* real big flood \w to|strong="H1961"\w* finish \w up|strong="H5414"\w* everything \w on|strong="H1961"\w* \w the|strong="H5414"\w* earth.  
\v 14 Sometimes \w I|strong="H5921"\w* \w will|strong="H1961"\w* send rain \w clouds|strong="H6051"\w* \w into|strong="H5921"\w* \w the|strong="H5921"\w* sky, \w and|strong="H7200"\w* \w there|strong="H1961"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w a|strong="H3068"\w* \w rainbow|strong="H7198"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* \w clouds|strong="H6051"\w* \w too|strong="H5921"\w*.  
