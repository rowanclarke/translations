\id 3JN
\h 3 ra̱ Xuua
\toc1 Ja ua rá̱ hyu̱ ra̱ carta bi 'yo'tra̱ Xuua.
\toc2 3 ra̱ Xuua
\toc3 3 Jn.
\mt1 3 ra̱ Xuua
\mt2 Ja ua rá̱ hyu̱ ra̱ carta bi 'yo'tra̱ Xuua.
\c 1
\p 
\v 1 Nu̱gä dí 'bɛt'o ngue rá̱ hya̱ Oja̱, da̱di zɛngua'i, ague ma̱ ndø'amigo Gayo. Ja̱njua̱ni̱ da̱di̱ ma̱'i̱.
\p 
\v 2 Ague ma̱ zi cu̱'i̱, dí äpä Oja̱ ngue da̱ mäxa̱'i̱ te guí øt'e. 'Nɛ̱ dí äpi ngue xta̱ nzaqui'i, tengu̱tho ga̱ nzaqui ni̱ nt'ɛ̱c'ɛ̱i̱ i ja.
\v 3 Ja̱njua̱ni̱ dá̱ johya 'mø ma̱ øde te mma̱nya ma̱ cu̱hʉ bá̱ sømp'ʉ guí 'bʉi. Mi̱ zä mi̱ zøcua, bi xiqui ngue gue'a̱ ra̱ hya̱ ma̱jua̱ni̱ guí ha̱ts'i̱.
\v 4 Hi̱n'yʉgui̱ ma̱n'na ra̱ johya jag'mø dí øde ngue nu̱ya ma̱ ba̱si̱ ya ha̱xhna̱ ra̱ hya̱ ma̱jua̱ni̱.
\s1 ---------
\p 
\v 5 Ague ma̱ zi cu̱'i̱, ya xa̱nho te guí øt'e ngue guí ørpa̱bi̱ ra̱ 'bäxte'ʉ ma̱ cu̱hʉ, ma̱da̱que'a̱ n'nanni̱ ni̱ 'yɛ̱hɛ̱, pɛ guí fäts'i.
\v 6 Ma̱mbá̱ pengya ma̱ cu̱hʉ, bá̱ sømp'ʉ guí 'bʉi. Nu̱'mø ma̱ mpɛtihe, bi xicje ngue ɛ̱mmɛ̱i̱ ga̱di̱ ma̱di̱. A nu̱yá, nu̱'mø bi̱ mapʉ ma̱høn'a̱, da̱mi̱ 'yøtra̱ ma̱te ngue gui fäts'i te honi̱ n'namhma̱ da̱ zä di sigue'a̱ te ga̱ 'yo. Gui 'yørpa̱bi̱ tengu̱tho nne Oja̱ ngue gui 'yøt'e.
\v 7 Porque nu̱'ʉ 'yo ngue ørpa̱bi̱ rá̱ 'bɛfi ra̱ Jesucristo. Nu̱ya yø mɛfi ya, hi̱ngui̱ tø'mi̱ ngue gue'ʉ yø ja̱'i̱ hi̱ngui̱ ɛ̱c'ɛ̱i̱ Oja̱ da̱ mäts'i.
\v 8 Ja̱na̱ngue jatho ga̱ fäxhʉ'ʉ to mma̱nna̱ ra̱ hya̱ ma̱jua̱ni̱, n'namhma̱ ngue gätho ga̱hʉ ga̱ mfäxhʉ'a̱ te ga̱ 'yo ra̱ hya̱.
\s1 ---------
\p 
\v 9 Nu̱gä dá̱ ot'a̱ n'na ra̱ carta ga̱ pɛnnba̱bi̱ yø ja̱'i̱ di̱ mpɛti p'ʉ ja ra̱ ni̱ja̱. Pɛ nu̱na̱ ra̱ Diótrefes ngue nne di̱ m'mɛt'o p'ʉ 'bʉhyø 'yɛ̱c'ɛ̱i̱, hi̱ngui̱ ørpa̱tho ma̱su̱ te dí xifi.
\v 10 Ja̱na̱ngue nu̱'mø ga̱ mmagä p'ʉya, ga̱ xi'a̱hʉ hanja ngue hi̱ngui̱ säya mma̱nyø fɛhni̱ conná̱ ngueque. 'Nɛ̱ hi̱nga̱ hønt'a̱ øt'a̱ p'ʉya, sinoque hi̱ndi̱ u̱nna̱ ts'äya'ʉ ma̱ cu̱hʉ sømp'ʉ 'bʉi. Nu̱'ʉ te'o nne di u̱nna̱ ts'äya, hi̱ngui̱ nnepe, 'nɛ̱ høn'athi p'ʉ ha di̱ mpɛti yø 'yɛ̱c'ɛ̱i̱.
\p 
\v 11 Ague ma̱ zi cu̱'i̱, 'yo guí øt'e tengu̱ na̱ ra̱ nts'o øt'a̱ dí xi'i ya. Sinoque gue'a̱ xa̱nho gui 'yøt'e. Nu̱ ra̱ ja̱'i̱ øt'a̱ te xa̱nho, gue'a̱ rá̱ ba̱si̱ Oja̱'a̱. Pɛ nu̱'a̱ to øt'a̱ te xa̱nts'o, ya hi̱ngrá̱ mpa̱di̱ui Oja̱'a̱.
\p 
\v 12 Gätho yø ja̱'i̱ i̱ nnømma̱nho na̱ ra̱ Demetrio, 'nɛ̱ ma̱jua̱ni̱'a̱ te dí øde i hma̱. Nu̱gähe xquet'a̱ da̱di jahe ma̱jua̱ni̱ ngue xa̱nho te ga̱ 'yo na̱, 'nɛ̱ guí pa̱hmʉ ngue nu̱'mø dá̱ ma̱ngähe n'na ra̱ hya̱, ma̱jua̱ni̱'a̱ te dí̱ mma̱m'me.
\s1 ---------
\p 
\v 13 I ja mi̱'da yø hya̱ dí̱ nne ga̱ xi'i, pɛ hi̱ndí̱ nne gä ga̱ cuatä ua ja ra̱ carta yø hya̱.
\v 14 Porque dí tø'mi̱ ngue hi̱mma̱ ya'atho ga̱ mmap'ʉ, ya da̱ zä ga̱ nya̱sɛui p'ʉya.
\p 
\v 15 Da̱ hyu̱t'a̱ ni̱ mmʉi Oja̱. Di zɛngua'i ni̱ amigo 'bʉcua. 'Yørca̱ ra̱ ma̱te da̱mi̱ zɛngua quits'ʉ n'na ngu̱ n'na'ʉ ma̱ amigogähe 'bʉp'ʉ guí 'bʉhmʉ.
