\p 
\v 22 \w El|strong="H1121"\w* \w jefe|strong="H6496"\w* \w de|strong="H5048"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* en Jerusalén \w era|strong="H1121"\w* Uzi, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* \w Bani|strong="H1137"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* \w Hasabías|strong="H2811"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Matanías, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Micaía, \w de|strong="H5048"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5048"\w* Asaf, \w cantores|strong="H7891"\w* \w que|strong="H1121"\w* estaban al \w frente|strong="H5048"\w* del servicio al \w Templo|strong="H1004"\w* \w de|strong="H5048"\w* \nd ʼElohim\nd*,
\v 23 \w por|strong="H5921"\w* \w cuanto|strong="H3588"\w* \w había|strong="H3588"\w* un mandato \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H3588"\w* un reglamento \w para|strong="H5921"\w* \w los|strong="H5921"\w* \w cantores|strong="H7891"\w*, \w que|strong="H3588"\w* determinaba \w las|strong="H5921"\w* \w cosas|strong="H1697"\w* \w para|strong="H5921"\w* \w cada|strong="H1697"\w* \w día|strong="H3117"\w*.
\p 
\v 24 Petaías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Mesezabeel|strong="H4898"\w*, \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Zera|strong="H2226"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, representaba \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w para|strong="H5971"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* asuntos del \w pueblo|strong="H5971"\w*.
\p 
\v 25 En cuanto \w a|strong="H3068"\w* las \w aldeas|strong="H1323"\w* con sus \w campos|strong="H7704"\w*, algunos \w de|strong="H1121"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* vivieron en Quiriat-arba y sus \w aldeas|strong="H1323"\w*, \w Dibón|strong="H1769"\w* y sus \w aldeas|strong="H1323"\w*, Jecabseel y sus \w aldeas|strong="H1323"\w*,
\v 26 \w Jesuá|strong="H3442"\w*, Molada, Bet-pelet,
\v 27 Hazar-sual, Beerseba y sus \w aldeas|strong="H1323"\w*,
\v 28 \w Siclag|strong="H6860"\w*, Mecona y sus \w aldeas|strong="H1323"\w*,
\v 29 En-rimón, Zora, Jarmut,
\v 30 Zanoa, Adulam \w y|strong="H5704"\w* sus \w aldeas|strong="H1323"\w*, Laquis \w y|strong="H5704"\w* sus \w campos|strong="H7704"\w*, \w y|strong="H5704"\w* \w Azeca|strong="H5825"\w* \w y|strong="H5704"\w* sus \w aldeas|strong="H1323"\w*. Vivieron \w desde|strong="H5704"\w* Beerseba \w hasta|strong="H5704"\w* el \w valle|strong="H1516"\w* \w de|strong="H5704"\w* Hinom.
\v 31 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Benjamín|strong="H1144"\w* estaban en Geba, Micmas, Aía, Bet-ʼEl y sus \w aldeas|strong="H1323"\w*,
