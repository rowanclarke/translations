\v 16 \w non|strong="G3756"\w* \w plus|strong="G2532"\w* \w comme|strong="G5613"\w* \w un|strong="G2532"\w* \w esclave|strong="G1401"\w*, \w mais|strong="G1161"\w* \w bien|strong="G2532"\w* \w mieux|strong="G3123"\w* \w qu|strong="G2532"\w*’\w un|strong="G2532"\w* \w esclave|strong="G1401"\w*, \w comme|strong="G5613"\w* \w un|strong="G2532"\w* \w frère|strong="G2532"\w* \w bien-aimé|strong="G1722"\w*, \w tout|strong="G2532"\w* \w particulièrement|strong="G3122"\w* \w aimé|strong="G2532"\w* \w de|strong="G2532"\w* \w moi|strong="G1473"\w*, \w et|strong="G2532"\w* \w combien|strong="G4214"\w* \w plus|strong="G2532"\w* \w de|strong="G2532"\w* \w toi|strong="G4771"\w*, \w aussi|strong="G2532"\w* \w bien|strong="G2532"\w* \w selon|strong="G1722"\w* \w la|strong="G2532"\w* \w chair|strong="G4561"\w* \w que|strong="G2532"\w* \w selon|strong="G1722"\w* \w le|strong="G2532"\w* \w Seigneur|strong="G2962"\w* ?\f + \fr 1:16 \ft 16. \fq Selon la chair \ft sous le rapport social, étant ton esclave ; \qt selon le Seigneur\qt*, en sa qualité de chrétien.\f*
\v 17 \w Si|strong="G1487"\w* \w donc|strong="G3767"\w* \w tu|strong="G1487"\w* \w me|strong="G1473"\w* \w tiens|strong="G2192"\w* \w pour|strong="G5613"\w* étroitement uni \w à|strong="G2192"\w* toi, accueille-le \w comme|strong="G5613"\w* \w moi-même|strong="G1473"\w*.
