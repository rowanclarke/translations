\id PRO  
\h Solomona 
\toc1 Solomona 
\toc2 Solomona 
\toc3 Solomona 
\mt1 Solomona  
\c 1  
\s1 NA OLELO AKAMAI  
\q1
\v 1 O NA olelo akamai a Solomona ke keiki a Davida ke alii o ka Iseraela.   
\q1
\v 2 He mea ia e ike ai i ka noiau a me ke aoia mai, E hoomaopopo i na olelo e naauao ai;   
\q1
\v 3 E loaa'i ka ike e akamai ai, Ma ka pono a me ka hoopono, a me ka pololei;   
\q1
\v 4 E haawi i ka maalea i ka poe naaupo, A me ka ike, a me ka noonoo i ke kanaka ui.   
\q1
\v 5 E hoolohe ka mea naauao, a mahuahua ka ike, E loaa no i ka mea i aoia'i ka ike o naauao ai;   
\q1
\v 6 E ike i ka olelo akamai a me ka hoakaka ana o ia mea, I na olelo a ka poe naauao, a me ka lakou olelo pohihi.   
\b  
\q1
\v 7 O ka makau ia Iehova, oia ka hoomaka ana o ka ike; A o ka naauao. a me ke aoia mai, ua hoowahawahaia e ka poe lapuwale.   
\b  
\q1
\v 8 E kuu keiki, e hooloke mai i ke ao ana a kou makuakane, Aole hoi e haalele i ke kanawai o kou maku wahine;   
\q1
\v 9 No ka mea, he mea nani ia no kou poo, He mau lei hoi no kou a-i.   
\b  
\q1
\v 10 E kuu keiki, ina e hoowale wale mai ka poe hewa ia oe, Mai ae aku oe.   
\q1
\v 11 Ina lakou e olelo mai, E, e hele pu kakou, E hoohalua no ke koko, E hoohalua wale i ka mea hala ole;   
\q1
\v 12 E moni ola ia lakou me he malu make, E moni okoa hoi e like me ka poe e haule ana i ka lua:   
\q1
\v 13 E loaa ia kakou ka waiwai maikai he nui, E hoopiha i ko kakou mau hale me ka waiwai pio;   
\q1
\v 14 E hailona pu oe me makou i kou kuleana, I hookahi hipuu na kakou a pau:   
\q1
\v 15 E kuu kiekie e, mai hele pu oe mo lakou ma ke ala; E haalele kou wawae i ko lakou mau kuamoo;   
\q1
\v 16 No ka mea, holo kiki ko lakou wawae i ka hewa, Wikiwiki hoi lakou i ka hookahe koko.   
\q1
\v 17 Make hewa no ke kau ana i ka hei, Ma ke alo o na mea eheu a pau.   
\q1
\v 18 Moe malu lakou no ko lakou koko; Makaala hoi no na uhane o lakou.   
\q1
\v 19 Pela ka aoao o ka poe makee waiwai a pau, E kaili ana i ke ola o ka mea nona ia.   
\b  
\q1
\v 20 Hea ae la ka naauao mawaho; Pane mai kona leo ma ke alanui;   
\q1
\v 21 Ma ka welau o na ala oia e kahea mai ai: Ma na kahua o na puka kulanakauhale kana olelo ana, I mai la,   
\q1
\v 22 Pehea ka loihi, e ka poe ike ole, E makemake ai oukou i ka naaupo? A oukou hoi, e ka poe hoowahawaha, E makemake ai i ka hoowahawaha ana? A o oukou, e ka poe naaupo, e inaina aku ai i ka naauao?   
\q1
\v 23 E huli mai oukou i ka'u ao ana; Aia hoi e niuini aku au i ko'u Uhane maluna o oukou. E hoike aku hoi ia oukou i ka'u mau olelo.   
\b  
\q1
\v 24 I ko'u wa i hea aku ai, hoole mai oukou; Kikoo aku la au i ko'u lima, aohe mea i manao mai;   
\q1
\v 25 Haalele oukou i ko'u mau manao a pau, Aole hoi oukou i makemake i ka'u ao ana:   
\q1
\v 26 Nolaila, i ko oukou popilikia e akaaka au, E hoowahawaha au i ka hiki ana o ko oukou makau;   
\q1
\v 27 A hiki mai ko oukou makau me he mea ino la, A hookokoke mai ko oukou popilikia me he puahiohio la, A loohia oukou e ka pilihua a me ke kaumaha:   
\q1
\v 28 Alaila, e hea mai lakou ia'u, aole au e pane aku; E imi koke lakou ia'u aole e loaa mai;   
\q1
\v 29 No ka mea, hoowahawaha lakou i ka ike, A o ka makau ia Iehova, aole lakou i koho mai;   
\q1
\v 30 Aole o lakou makemake i ka'u ao ana; Manao ino hoi i ka'u mau olelo a pau.   
\q1
\v 31 Nolaila, e ai lakou i ka hua o ko lakou aoao iho, A ma ko ka manao ana o lakou e maona ai.   
\q1
\v 32 No ka mea, o ka haalele ana aku o ka poe naaupo, oia ko lakou pepehiia mai, A o ka noho nanea ana o ka poe lapuwale, o ko lakou make ia.   
\q1
\v 33 Aka, o ka mea hoolohe mai ia'u. e noho oluolu no ia, E noho no ia me ka makau ole i ka poino.   
\c 2  
\b  
\q1
\v 1 E KUU keiki, ina e lawe oe i ka'u mau olelo, A e waiho pu me oe i ko'u kanawai;   
\q1
\v 2 E haliu mai kou pepeiao i ka naauao, A e huli kou naau i ka ike;   
\q1
\v 3 Ina paha e hea aku oe i ka ike, A e o aku kou leo i ka naauao;   
\q1
\v 4 Ina e imi aku oe ia ia me he kala la, A e huli hoi ia ia me he waiwai huna la;   
\q1
\v 5 Alaila, e ike oe i ka makau ia Iehova, A e loaa ia oe ka ike i ke Akua.   
\q1
\v 6 No ka mea, na Iehova e haawi mai i ka naauao; Mai kona waha mai ka ike a me ka noiau.   
\q1
\v 7 Hoano e oia i ke ola no ka poe pono; He paku ia no ka poe hele pololei;   
\q1
\v 8 E malama i na ala o ka mea hoopono, E kiai hoi i ka aoao o kona poe haipule.   
\q1
\v 9 Alaila, e ike oe i ka pono a me ka hoopono, A me ka pololei a me na aoao maikai a pau.   
\b  
\q1
\v 10 No ka mea, e komo ka naauao iloko o kou naau, E ono hoi ka ike i kou uhane.   
\q1
\v 11 Na ke akamai oe e malama aku, O ka noiau hoi ke kiai ia oe,   
\q1
\v 12 E hoopakele ia oe mai ka aoao hewa aku, Mai ke kanaka hoi i wahahee ka olelo:   
\q1
\v 13 Haalele lakou i ka aoao pololei, I hele ai hoi ma na ala o ka pouli.   
\q1
\v 14 Olioli lakou ke hana hewa, Hauoli hoi lakou i ka ino o ka mea aia.   
\q1
\v 15 O lakou ke hookekee i ko lakou hele ana, Kekee wale hoi ma ko lakou aoao:   
\q1
\v 16 I hoopakeleia oe i ka wahine e, I ka wahine malihini i hoomalimali ka olelo.   
\q1
\v 17 Oia ka i haalele i ke alakai o kona wa opiopio, A hoopoina hoi i ka berita o kona Akua.   
\q1
\v 18 No ka mea, e hina ana kona hale ilalo i ka make, A o kona mau ala hoi ma kahi o ka poe make.   
\q1
\v 19 O ka poe a pau e komo aku io na la, aole e hoi hou mai, Aole hoi e hiki aku lakou i ke ala o ke ola.   
\q1
\v 20 I hele oe ma ke ala o ka poe pono, I malama hoi oe i ka aoao o ka poe pololei.   
\q1
\v 21 No ka mea, e noho paa ka poe maikai ma ka aina, A e mau no malaila ka poe pololei.   
\q1
\v 22 Aka, e okiia ana ka poe hewa mailoko aku o ka aina, A e uhukiia hoi ka poe lawehala malaila aku.   
\c 3  
\b  
\q1
\v 1 E KUU keiki, mai haalele oe i ko'u kanawai, E waiho hoi i ka'u mau kauoha ma kou naau.   
\q1
\v 2 No ka mea, oia ka mea e nui ai na la a me na makahiki o kou ola ana, A o ka malu hoi e haawiia ia oe.   
\q1
\v 3 I ole e haalele ia oe ka lokomaikai a me ke aloha; E hawele ia mau mea ma kou a-i; E kakau hoi ma ka papa o ka naau.   
\q1
\v 4 Pela e loaa'i ka lokomaikai a me ka ike oiaio, Imua o Iehova a me na kanaka.   
\b  
\q1
\v 5 E paulele ia Iehova me kou naau a pau; Mai hilinai hoi ma kou naauao iho.   
\q1
\v 6 Ma kou aoao a pau ia ia no oe e nana aku ai, A nana no e hoopololei i kou hele ana.   
\b  
\q1
\v 7 Mai hooakamai oe ma kou manao iho; E makau ia Iehova a e haalele i ka hewa.   
\q1
\v 8 Oia ke ola no kou mau olona, A me ka lolo no kou mau iwi.   
\q1
\v 9 E hoonani ia Iehova ma kou waiwai, A me na hua mua o na mea a pau i loaa'i ia oe:   
\q1
\v 10 Alaila, e hoopihaia kou waihona waiwai a hu, E hu ae kau mau mea kaomi waina i ka waina hou.   
\b  
\q1
\v 11 E kuu keiki, mai hoole oe i ke aoia mai e Iehova; Mai pauaho oe i kona hooponopono ana mai.   
\q1
\v 12 No ka mea, o ka mea a Iehova i aloha'i oia kana i paipai mai. Me he makua la i ke keiki ana i makemake ai.   
\b  
\q1
\v 13 Pomaikai ke kanaka ke loaa ia ia ka naauao, A o ke kanaka hoi i makaukau i ka ike.   
\q1
\v 14 No ka mea, ua oi aku ka waiwai o ia mea mamua o ke kala, A o ke kuai ana hoi mamua o ke gula.   
\q1
\v 15 Ua maikai oia mamua o na momi; A o na mea a pau au e makemake ai, aole e liko me ia ka maikai.   
\q1
\v 16 Aia ma kona lima akau ka loihi o na la; A ma kona lima hema ka waiwai a me ka hanohano.   
\q1
\v 17 O kona mau aoao he mau aoao oluolu no, Ua pau hoi kona mau alanui i ka maluhia,   
\q1
\v 18 Oia ka laau o ke ola no ka poe e hoopaa ana ia ia, Poinaikai hoi ka mea e apo ana ia ia.   
\q1
\v 19 Ma ke akamuai i hookumu iho ai o Iehova i ka honua; A ma ka ike i kau aku ai i ka lani.   
\q1
\v 20 Ma kona ike hoi i wawahiia'i na wahi hohonu, A ninini mai no na ao i ka ua.   
\b  
\q1
\v 21 E kuu keiki e, mai huli e aku kou mau maka; E hoopaa i ka naauao a me ka ike.   
\q1
\v 22 He ola no ia no kou uhane, He hanohano no ia i kou a-i.   
\q1
\v 23 Alaila, e hele makau ole oe ma kou ala, A o kou wawae hoi, aole ia e palaha.   
\q1
\v 24 I kou moe ana, aole oe e makau; E moe iho no oe, a e oluolu kou hiamoe ana.   
\q1
\v 25 Mai weliweli oe i ka mea e makau ai ke hikilele mai, Aole hoi i ka luku ana o ka poe hewa ke hiki mai.   
\q1
\v 26 No ka mea, o Iehova no kou mea e peulele ai, E malama no oia i kou wawae i ole no e heiia.   
\b  
\q1
\v 27 Mai aua oe i ka maikai i ka mea e pono ai ia, Ke hiki i kou lima ke hana aku.   
\q1
\v 28 Mai olelo oe i kou hoanoho, O hele oe a hoi mai, apopo e haawi aku au, Ke waiho wale ia mea ia oe.   
\q1
\v 29 Mai imi hala oe i kou hoanoho, No ka mea, ke noho la oia ma ou la me ka maluhia.   
\b  
\q1
\v 30 Mai hoopaapaa hala ole oe me ke kanaka, Ina aole oia i hana hewa aku ia oe.   
\b  
\q1
\v 31 Mai hoolalike oe me ke kanaka huhu, Mai koho hoi oe i kekahi aoao ona.   
\q1
\v 32 No ka mea, he mea hoopailua ka aia ia Iehova, O ka poe pololei oia kona poe hoakuka.   
\b  
\q1
\v 33 O ka hoino o Iehova aia ma ka hale o ka mea hewa, Hoopomaikai oia i kahi noho ai o ka poe pono.   
\q1
\v 34 E hoowahawaha mai oia i ka poe hoowahawaha; E haawi mai oia i ka lokomaikai i ka poe i haahaa ka naau.   
\q1
\v 35 E ili mai ka hanohano no ka poe naauao; O ka hookiekieia mai o ka poe hewa, he mea hilahila ia.   
\c 4  
\b  
\q1
\v 1 E HOOLOHE mai, e na keiki, i ke ao ana a ka makua, E haliu mai hoi e ike i ka naauao.   
\q1
\v 2 No ka mea, he ike pono ka'u e haawi aku nei ia oukou, Mai haalele oukou i ko'u kanawai.   
\q1
\v 3 No ka mea, he keiki no wau a ko'u makua, He malamia, a he hanaukahi imua o ko'u makuwahine.   
\q1
\v 4 Ao mai la oia, i mai la ia'u, E hoopaa kou naau i ka'u olelo; E malama hoi i ka'u mau kauoha i ola oe.   
\q1
\v 5 E imi i ka naauao, e imi hoi i ka ike a loaa; Mai hoopoina, mai waiho wale i na olelo a ko'u waha.   
\q1
\v 6 Mai haalele oe ia mea, a nana oe e malama mai; E aloha oe ia ia, a nana oe e kiai mai.   
\q1
\v 7 O ka naauao ka mea nui, e imi i ka naauao a loaa: Me na mea a pau au e imi ai, E imi pu i ka ike a loaa.   
\q1
\v 8 E hoonani oe ia ia, nana oe e hookiekie ae; E hoohanohano ia oe i kou wa e hoopaa aku ai ia ia   
\q1
\v 9 E haawi mai ia i lei aloha no kou poe; He lei hanohano hoi kana e haawi mai ai ia oe.   
\b  
\q1
\v 10 E hoolohe mai, e kuu keiki, e hoopaa i ka'u olelo; A e nui ae hoi ia oe na makahiki o kou ola ana.   
\q1
\v 11 E ao aku au ia oe ma ka aoao naauao, E kuhikuhi hoi au ia oe ma ko ala pololei.   
\q1
\v 12 I kou hele ana, aole e hihia kou kapuwai; A ina o holo oe aole o hina.   
\q1
\v 13 E hoopaa oe i ke aoia mai, mai hookuu oe; E malama oe ia ia, no ka mea, he ola ia nou.   
\b  
\q1
\v 14 Ma ke alanui o ka poe hewa, mai hele oe, Mai hele hoi ma ka aoao o ka poe hewa.   
\q1
\v 15 E haalele ia wahi, mai maalo ilaila, E huli ae mai ia wahi mai, a e hele aku.   
\q1
\v 16 No ka mea, aole o lakou hiamoe, ke hana hewa ole aku; Ua lele hoi ka hiamoe, ke hoohina ole ia kekahi e lakou.   
\q1
\v 17 No ka mea, ai lakou i ka berena no ka hewa, Inu hoi lakou i ka waina no ke kaili wale,   
\q1
\v 18 Aka, o ke ala o ka poe pono, ua like ia me ka malamalama e aa ana, E mahuahua mau ana i ke awakea loa.   
\q1
\v 19 O ka aoao o ka poe hewa, ua like ia me ka pouli: Aole i ike i ko lakou mea e hina ai.   
\b  
\q1
\v 20 E kuu keiki e, e haliu mai ka'u olelo, I ka'u olelo hoi o huli mai ai i ka pepeiao.   
\b  
\q1
\v 21 Mai noho a nalowale ia mai kou mau maka aku; E malama oe ia iloko o kou naau.   
\q1
\v 22 No ka mea, he ola ia no na mea i loaa'i ia, He laau hoola hoi no ke kino a pau.   
\b  
\q1
\v 23 E kiai oe i kou naau me ka malama loa; No ka mea, noloko olaila ka waipuna o ke ola.   
\q1
\v 24 E waiho aku oe i ku waha wahahee wale, E haalele loa hoi i na lehelehe hoopunipuni.   
\q1
\v 25 I nana pono ae kou mau maka, I pololei hoi kou mau lihilihi mamua ou.   
\q1
\v 26 E hoopololei ae i ke ala no kou mau kapuwai, A e pololei hoi kou hele ana a pau.   
\q1
\v 27 Mai huli ae oe i ka lima akau aole hoi i ka lima hema; E huli nae kou wawae mai ka hewa aku.   
\c 5  
\b  
\q1
\v 1 E KUU keiki, e hoolohe mai i ko'u naauao, E haliu mai hoi kou pepeiao i ko'u iko:   
\q1
\v 2 I malama oe i ke aoia mai, E hoopaa hoi kou mau lehelehe i ka ike.   
\b  
\q1
\v 3 No ka mea, o na lehelehe o ka wahine hookamakama he meli ia e kulu ana, A ua oi aku ka pahee o kona waha i ko ka aila.   
\q1
\v 4 Aka, na awahia kona hope, e like me ka laau awaawa, Oioi hoi o like me ka pahikaua oi lua.   
\q1
\v 5 Ke iho iho la kona mau wawae i ka make, E pili ana hoi kona mau kapuwai i ka lua,   
\q1
\v 6 I ole oe e noonoo i ke ala o ko ola, He loli wale kona noho ana i ole oe e ike aku.   
\b  
\q1
\v 7 Ano la, e na keiki, hoolohe mai ia'u, Mai haliu ae mai ka olelo aku a kuu waha.   
\q1
\v 8 E hooneenee loa aku i kou hele ana mai ona aku, Mai hookokoke aku oe i ka puka o kona hale:   
\q1
\v 9 O haawi oe i kou nani i na mea e, A me kon mau makahiki hoi i ka mea aloha ole:   
\q1
\v 10 O lako hoi na mea e i kou mau mea maikai; A me na hale o ka malihini i kau waiwai;   
\q1
\v 11 A uwe oe i kou hope, I ka pau ana o kou io a me kou kino;   
\q1
\v 12 A e olelo hoi, Auwe ko'u inaina aku i ka ike, A me ka hoowahawaha ana o ko'u naau i ke aoia mai!   
\q1
\v 13 Aole au i hoolohe i ka leo o ka'u mau kumu, Aole hoi i haliu aku ko'u pepeiao i ka poe i ao mai ia'u!   
\q1
\v 14 Mai noho au ma na hewa a pau loa, Mawaena o ke anaina a me ka ahakanaka.   
\b  
\q1
\v 15 E ia u oe i ka wai noloko ae o kou punawai, A i na waikahe hoi noloko ae o kou kahawai.   
\q1
\v 16 E hu aku iwaho kou mau lokowai, A kahe na auwai ma na alanui.   
\q1
\v 17 Nau wale iho no lakou, Aole na ka poe malihini pu me oe.   
\q1
\v 18 E hoomaikaiia kou punawai; A e olioli oe me ka wahine o kou wa ui.   
\q1
\v 19 He dia aloha ia a me ka ibeka oluolu; E maona oe i na la a pau i kona waiu, E ana mau oe i kona aloha.   
\q1
\v 20 No ke aha la e ona oe, e kuu keiki, i ka wahine e, A e apo oe i ka wahine a hai ma kou umauma?   
\q1
\v 21 No ka mea, e kau pono ana na maka o Iehova i ka aoao o ke kanaka, E ike ana no hoi i kona mau aoao a pau,   
\b  
\q1
\v 22 E puni ka mea hewa i kona hala iho, E heiia hoi oia i ka hei o kona hewa iho.   
\q1
\v 23 E make oia me ke ao ole ia mai; A e hele hewa oia i ka nui o kona naaupo ana.   
\c 6  
\b  
\q1
\v 1 E KUU keiki, ina e hoohiki oe e panai no kou hoalauna, Ina i pai kou lima me ka malihini,   
\q1
\v 2 A i puni oe i ka olelo a kou waha, A i punihei oe i ka olelo a kou waha.   
\q1
\v 3 Ano la, e kuu keiki, e hana oe i keia, i pakele. I kou lilo ana i ka lima o kou hoalauna: O hele, e hoohaabaa ia oe iho, e hoolaulea i kou hoalauna.   
\q1
\v 4 Mai haawi i ka hiamoe i kou mau maka, Aole hoi e pipili kou mau lihilihi:   
\q1
\v 5 E hemo aku oe me he dia la mailoko ae o ka lima, A e like hoi me ka manu mai ka lima ae o ke kuhea manu.   
\b  
\q1
\v 6 E ka mea hiamoe, e hele oe i ka anonanona, E nana i kona aoao a e hoonaauao iho:   
\q1
\v 7 Aohe alii ia ia, Aole haku, aole hoi lunakanawai;   
\q1
\v 8 Hoahu no oia i kana ai i ke kau, I ka wa e ohi ai, hoiliili oia i kana mea ai.   
\q1
\v 9 E ka mea hiamoe, pehea ka loibi o kou hiamoe ana? Ahea la oe e ala mai ai mai kou hiamoe ana mai?   
\q1
\v 10 He moe iki ae, he hiamoe iki ae, He pelu hou iki ae i ka lima a hiamoe:   
\q1
\v 11 A e hiki mai kou ilihune me he kanaka hele la, A me kou nele e like me ke kanaka kaua.   
\b  
\q1
\v 12 O ke kanaka aia, o ke kanaka hewa, Hele no oia me ka waha hoopunipuni.   
\q1
\v 13 Iimo oia me ka maka, ao aku oia me ka wawae, Kuhikuhi oia me kona manamanalima;   
\q1
\v 14 He kolohe no ma kona naau, Noonoo ino oia i na la a pau, Hookonokono oia i ka hakaka.   
\q1
\v 15 Nolaila, e loohia koke mai oia e ka make; E haihai koke ia oia, aole mea nana e hoola,   
\b  
\q1
\v 16 O keia mau mea eono, he mau mea e inaina mai ai o Iehova; Ehiku hoi e hoopailua ai o kona naau.   
\q1
\v 17 O na maka kiekie, o ke elelo wahahee, A me na lima hookahe koko hala ole,   
\q1
\v 18 O ka naau e imi ana i na manao kolohe, A me na wawae e holo kiki ana i ka hewa,   
\q1
\v 19 O ka mea hoike hoopunipuni e hana ana i ka wahahee, A me ka mea hookonokono i ka hakaka mawaena o na hoahanau.   
\b  
\q1
\v 20 E kuu keiki, e malama oe i ke kanoha a kou makuakane, Mai haalele hoi i ke kanawai o kon makuwahine.   
\q1
\v 21 E hawele mau oe ia mau mea ma kou naau, E nakii oe ia mau mea ma kou a-i.   
\q1
\v 22 I kou hele ana, ea, e kai aku ia ia oe; I kou moe ana e kiai oia maluna ou; I kou ala ana iluna, oia ke kamailio pu me oe.   
\q1
\v 23 No ka mea, he kukui ke kauoha, He malamalama ke kanawai, O ka aoao o ke ola oia ke ao ana e naauao ai:   
\q1
\v 24 I malamaia oe i ka wahine ino, I ka malihini i hoomalimali me kona elelo.   
\q1
\v 25 Mai kuko aku i kona maikai maloko o kou naau, Aole hoi e puniheiia e kona mau lihilihi.   
\q1
\v 26 No ka mea, no ka wahine hookamakama, E nele ke kanaka a i ka apana ai; Hoohalua no ka wahine moe kolohe i ka uhane i minaminaia.   
\q1
\v 27 E lawe anei ke kanaka i ke ahi ma kona poli, Aole hoi e wela kona kapa?   
\q1
\v 28 Ina o hele ke kanaka ma na nanahu e aa ana, Aole anei e wela kona kapuwai?   
\q1
\v 29 Pela ka mea e komo ae ana i ka wahine a kona hoalauna; Aole e aponoia na mea hoopa ia ia.   
\q1
\v 30 Aole i hoowahawahaia ka aihue i kona aihue ana, Ina he mea ia e maona ai kona pololi.   
\q1
\v 31 Aka, i loaa oia, e uku pahiku no, E haawi oia i ka waiwai a pau o kona hale.   
\q1
\v 32 O ka mea moe kolohe me ka wahine, aole ona naauao; O ka make o kona uhane kana i hana'i.   
\q1
\v 33 E loaa ia ia ka eha a me ka hoowahawahaia mai. Aole hoi o holoiia kona mea e hilahila ai.   
\q1
\v 34 No ka mea, o ka lili, oia ko ke kanaka mea e ukiuki ai; Aole oia e hoopakele i kona la e hoopai aku ai.   
\q1
\v 35 Aole oia e manao mai i ka uku; Aole hoi oia o oluolu, ke haawi mai oe i na makana he nui.   
\c 7  
\b  
\q1
\v 1 E KUU keiki e, e malama oe i ka'u mau olelo, E waiho pu hoi i ka'u kauoha me oe.   
\q1
\v 2 E malama oe i ka'u kauoha i ola oe, A me ko'u kanawai hoi, e like me ke kii onohi o kou mau maka.   
\q1
\v 3 E hawele oe ia mau mea ma kou mau manamanalima, E kakau hoi ia mau mea ma ka papa o kou naau.   
\q1
\v 4 E i ae oe i ka naauao, O oe no ko'u kaikuwahine; E kapa aku oe i ka ike, he hoalauna:   
\q1
\v 5 I malamaia oe i ka wahine e, I ka malihini hoi i hoomalimali mai me kana olelo.   
\b  
\q1
\v 6 No ka mea, ma ka puka o ko'u hale, Ma ko'u puka makani, nana aku la au;   
\q1
\v 7 Ike iho la au iwaena o ka poe noonoo ole, Ike iho la hoi au mawaena o ka poe opiopio, I kekahi kanaka ui manao ole.   
\q1
\v 8 Hele ae la ia ma ke ala e kokoke ana i kona huina, Hele ae la oia ma ke kuamoo e hiki aku ai i kona hale;   
\q1
\v 9 I ke ahiahi, i ka napoo ana o ka la, I ke aumoe, i ka poeleele;   
\q1
\v 10 Aia hoi, halawai pu me ia kekahi wahine, Ua kahiko hookamakama ia; Ua maalea kona naau.   
\q1
\v 11 He walaau kona a me ka hoolohe ole, Aole noho kona mau wawae ma kona hale iho.   
\q1
\v 12 I kekahi wa mawaho oia, I kekahi wa ae ma ke alanui, A hoohalua oia ma na huina a pau.)   
\q1
\v 13 Apo iho la kela ia ia a honi iho la, a Me ka maka hilahila ole, i aku la ia ia,   
\q1
\v 14 He mau mohai aloha ko'u; I keia la no, mohai aku la au i ka'u mea i hoohiki ai   
\q1
\v 15 Nolaila, i hele mai nei au e halawai me oe, E imi hoi ia oe, a ua loaa iho nei.   
\q1
\v 16 Hohola iho la au i ko'u wahi moe me ke kapa, Me ke kapa onionio hoi mai Aigapita mai   
\q1
\v 17 Kopipi iho la au i ko'u wahi moe I ka mura, a me ka aloe, a me ke kinamona.   
\q1
\v 18 Ina kaua i maona i ke aloha a hiki i kakahiaka, E lealea kaua i ke aloha.   
\q1
\v 19 No ka mea, o ke kane, aole ia ma kona hale, Ua hele oia ma kahi loihi e aku.   
\q1
\v 20 Lawe oia i ka eke kala ma kona lima, A piha ka mahina, alaila, e hoi mai oia i kona hale.   
\q1
\v 21 Ua paa kela i ka nui o kana olelo maalea; Ua lilo hoi oia i ka malimali ana o kona mau leheiehe.   
\q1
\v 22 Ukali koke oia mahope ona, E like me ka hele ana o ka bipi i kona wahi e maka ai; E like hoi me ka naaopo i hoopaiia mai ma ka laau kupee;   
\q1
\v 23 A o aku la ka pua i kona ake, E like me ka lele ana o ka manu i ke pahele, Aole ona ike no kona oia ia.   
\b  
\q1
\v 24 Ano la, e na keiki, e hoolohe mai ia'u. E maliu mai oukou i ka olelo a ko'u waha.   
\q1
\v 25 Mai huli ae kou naau ma kona aoao; Mai hele hewa oe ma kona alanui.   
\q1
\v 26 No ka mea, manomano ka poe i hina ia ia me ka eha, Na mea ikaika hoi, ua pau ia ia i ka make.   
\q1
\v 27 Ma kona hale ke ala e hiki ai i ka po, E iho ana ilalo i ka make.   
\c 8  
\b  
\q1
\v 1 A OLE anei i hea mai ka naauao? Aole anei i pane mai ka ike i kona leo?   
\q1
\v 2 Maluna o na wahi kiekie, ma ke ala, Ma kahi o na alanui, ku ae la oia.   
\q1
\v 3 Ma na ipuka, ma ke alo o ke kulanakauhale, Ma na wahi e komo ai, kahea mai la oia.   
\q1
\v 4 Ke hea aku nei au ia oukou, e na kanaka; O ko'u leo hoi i na keiki a kanaka.   
\q1
\v 5 E na mea ike ole, e ike oukou i ke akamai; E hoonaauao hoi oukou, e ka poe naaupo.   
\q1
\v 6 E hoolohe mai, no ka mea, e hai ana au i na mea maikai; O ka oaka ana hoi o ko'u mau lehelehe ma na mea pono ia.   
\q1
\v 7 No ka mea, e hoike mai kuu waha i ka oiaio; He mea hoopailua ka hewa i ko'u mau lehelehe.   
\q1
\v 8 Ma ka pono na olelo a pau a ko'u waha; Aole wahahee, aohe mea kekee malaila.   
\q1
\v 9 Pau loa no ia i ka pololei i ka mea naauao, Ua kupono hoi i ka poe i loaa ka ike.   
\q1
\v 10 E koho oukou i ke aoia mai, aole ke kala, A me ka ike hoi mamua o ke gula maikai.   
\q1
\v 11 No ka mea, ua maikai ka naauao mamua o na momi; A o na mea i makemakeia a pau, aole i like me ia.   
\b  
\q1
\v 12 Owau hoi, o ka naauao, ke pili nei i ke akamai, Ua loaa ia'u ka ike i na mea e naauao ai.   
\q1
\v 13 O ka makau ia Iehova, oia ke inaina aku i ka hewa; O ka haaheo, o ka hookiekie, o ka aoao ino, O ka waha aaka, oia ka'u i hoowahawaha aku ai.   
\q1
\v 14 Ia'u ka ike a me ke akamai; Owau no ka noonoo, ia'u hoi ka ikaika.   
\q1
\v 15 Ma o'u nei no e nohoalii ai na alii, A e kau aku ai no hoi na kaukaualii i ke kanawai pono.   
\q1
\v 16 Ma o'u nei no hoi e hoomalu ai na kiaaina, A me na'lii, a me na lunakanawai a pau o ka honua.   
\q1
\v 17 He aloha ko'u i ka poe e aloha mai ia'u; O ka poe imi pono mai, o lakou ke loaa ia'u.   
\q1
\v 18 Me au ka waiwai a me ka hanohano; O ka waiwai e mau ana hoi a me ka pono.   
\q1
\v 19 Ua maikai ko'u hua mamua o ke gula a me ke gula maikai; He mea kohoia hoi ka waiwai ma o'u nei mamua o ke kala.   
\q1
\v 20 Ma ke ala o ka pono ka'u e alakai ai, Mawaena hoi o na alanui o ka hoopono:   
\q1
\v 21 I hooili au i ka waiwai no ka poe aloha mai ia'u, A e hoopiha au i ko lakou waihona waiwai.   
\b  
\q1
\v 22 Na Iehova no wau i kinohou o kona noho ana, Mamua o kana hana ana i ka wa kahiko.   
\q1
\v 23 Mai ka po mai ua hoonohoia au, Mai kinohi mai, mamua hoi o ka honua.   
\q1
\v 24 I ka wa i ole ai na wahi hohonu, ua hanau no au, I wa i ole ai na puuawai i piha i ka wai.   
\q1
\v 25 Mamua o ka hoonoho ana i na mauna, Mamua o na kuahiwi ua hanau au:   
\q1
\v 26 Aole hoi oia i hana i ka honua a me na kula, A me kahi huna lepo iki o ka honua.   
\q1
\v 27 I kona hohola ana i ka lani, owau no kekahi malaila, I kona kau ana i ke kanawai maluna o ka hohonu;   
\q1
\v 28 I kona hoolewalewa ana i na ao maluna, I kona hoonoho ana i na punawai o ka hohonu;   
\q1
\v 29 I kona kau ana i ke kanawai no ka moana, I ole e hu wale aku na kai mamua ona; I kona hookumu paa ana i ka honua:   
\q1
\v 30 Alaila, owau pu kekahi me ia me he keiki hiwahiwa la; O kona olioli no au i kela la i keia la, E hauoli mau ana hoi imua o kona alo;   
\q1
\v 31 E hauoli ana i na wahi i noho ai na kanaka o ka honua ona; O ko'u olioli nui hoi, aia me na keiki a kanaka.   
\b  
\q1
\v 32 Ano la, e na keiki, e hoolohe mai ia'u; Pomaikai ka poe i malama mai i ko'u aoao.   
\q1
\v 33 E hoolohe mai i ke ao ana a e hoomanao iho, Mai pale ae oukou.   
\q1
\v 34 Pomaikai ke kanaka ke lohe mai i ka'u, He kiai hoi oia, i ko'u mau puka i kela la i keia la, Ke kakali hoi oia ma na kia o ko'u mau puka.   
\q1
\v 35 No ka mea, o ka mea o'u i loaa ai, ua loaa ia ia ke ola, E loaa hoi ia ia ka lokomaikaiia mai e Iehova.   
\q1
\v 36 Aka, o ka mea i hana ino mai ia'u, ua pepehi oia i kona uhane iho; O ka poe inaina mai ia'u oia ka i koho i ka make.   
\c 9  
\b  
\q1
\v 1 KUKULU ae la ka naauao i kona hale, Kalai iho la oia i kona mau kia ehiku.   
\q1
\v 2 Kalua oia i kana mau mea momona; Kawili ae la oia i kona waina; Hoomakaukau no i kana papaaina.   
\q1
\v 3 Hoouna aku la oia i kana poe kauwawahine, E hea aku maluna o na wahi kiekie o ke kulanakauhale,   
\q1
\v 4 Owai ka mea naaupo? e huli mai ia io'u nei: I ka mea noonoo ole hoi, olelo ae la oia ia ia,   
\q1
\v 5 Ina, e ai mai oukou i ka'u berena, E inu hoi i ka waina a'u i kawili ai.   
\q1
\v 6 E haalele i ka poe manao ole, i ola oukou, E hele hoi ma ke ala o ka naauao.   
\b  
\q1
\v 7 O ka mea e ao aku i ke kanaka aia, E loaa ia ia ka hilahila; O ka mea e ao aku i ka mea hewa, e loaa ia ia ka palahea.   
\q1
\v 8 Mai ao aku i ke kanaka aia, O hoowahawaha mai oia ia oe; E ao aku i ka mea naauao, A e aloha mai oia ia oe.   
\q1
\v 9 E haawi na ka mea naauao, A e oi mau ka naauao; E ao hoi i ka mea hoopono, A e mahuahua ae la kona ike.   
\q1
\v 10 O ka mole o ka naauao, Oia ka makau ia Iehova; O ka ike i ka Mea hemolele, Oia ka noonoo ana,   
\q1
\v 11 No ka mea, ma o'u nei, e mahuahua ae ai kou mau la, A e nui ai hoi na makahiki o kou ola ana.   
\q1
\v 12 Ina e naauao oe, e naauao no oe nou iho; Ina e hoowahawaha oe, maluna ou wale no ia mea.   
\b  
\q1
\v 13 O ka wahine naaupo, he walaau kona; Ua manao ole, aole oia i ike i kekahi mea.   
\q1
\v 14 Noho no oia ma ka puka o kona hale, Ma ka noho hoi ma kahi kiekie o ke kulanakauhale,   
\q1
\v 15 E hea aku i ka poe hele ma ke ala, Ka poe hele pololei ma ke alanui;   
\q1
\v 16 Owai ka mea manao ole? e huli mai i o'u nei; I ka mea naaupo, olelo aku la oia ia ia,   
\q1
\v 17 Ua ono no na wai i aihueia, Ua mananalo hoi ka berena ke ai malu.   
\q1
\v 18 Aole nae i ike kela, malaila ka poe make, Aia kona poe hoaai ilalo loa i ka malu make.   
\c 10  
\b  
\q1
\v 1 O KE keiki akamai, hoohauoli mai oia i kona makuakane; A o ke keiki lapuwale, hoouluhua mai oia i kona makuwahine.   
\q1
\v 2 O ka waiwai i loaa hewa mai, aole he mea ia e pomaikai ai; Aka, o ka pono, oia ka i hoopakele i ka make.   
\q1
\v 3 Aole e waiho mai o Iehova i ka uhane o ka mea pono a pololi; Aka, hoole no ia i ka makemake o ka poe hewa.   
\q1
\v 4 O ka lima hoopalaleha, he mea ia e ilihune ai; Aka, o ka lima hooikaika mau i ka hana, oia ka mea e waiwai ai.   
\q1
\v 5 O ka mea hooiliili i ke kau, he keiki naauao ia; O ka mea hiamoe i ka wa e ohi ai, he keiki hoohilahila ia.   
\q1
\v 6 O na mea e pomaikai ai, aia maluna o ke poo o ka mea pono; Aka, ma ka waha o ka poe hewa i hunaia'i ka ino.   
\q1
\v 7 O ka hoomanao ana i ka mea hoopono, he mea hauoli ia; A o ka inoa o ka poe hewa, E palakahuki ia.   
\q1
\v 8 O ka mea i akamai ka naau, e hoopaa oia i na kauoha; Aka, o ka mea i lapuwale na lehelehe, e hina oia.   
\q1
\v 9 O ka mea hele ma ka pololei, hele paa pono no ia; A o ka mea hookekee i kona aoao, e ikeia oia.   
\q1
\v 10 O ka mea i imo ka maka, hoeha mai oia; O ka mea i lapuwale na lehelehe, e hina oia.   
\q1
\v 11 He punawai hoola ka waha o ka mea hoopono; Ma ka waha o ka poe hewa i hunaia'i ka ino.   
\q1
\v 12 Hookonokono ka inaina i ka hakaka; Aka, uhi mai no ke aloha i na hewa a pau.   
\q1
\v 13 Ma na lehelehe o ka mea naauao i loaa'i ke akamai; Aka, o ka laau hahau, no ke kua ia o ka mea manao ole.   
\q1
\v 14 Hoopaa ka poe akamai i ka ike; A o ka waha o ka mea lapuwale, kokoke ia i ka make.   
\q1
\v 15 O ka waiwai o ka mea waiwai, oia kona kulanakauhale paa; O ka poino o ka poe ilihune, o ko lakou nele no ia.   
\q1
\v 16 O ka hana a ka mea pono, pili no ia i ke ola; O ka hua o ka mea hewa, pili no ia i ka make.   
\q1
\v 17 Ma ka aoao o ke ola ka mea i malama i ke ao ana mai; O ka mea i pale ae i ke ao ana, ua hana lapuwale oia.   
\q1
\v 18 O ka mea huna i ka huhu me na lehelehe wahahee, A ahiahi wale aku, oia ka lapuwale.   
\q1
\v 19 I ka nui o na huaolelo, aole loa e ole ka hewa; O ka mea hamau i kona mau lehelehe, e naauao no ia.   
\q1
\v 20 O ke elelo o ka mea pono, he kala maikai ia; O ka naau o ka poe hewa, he wahi mea iki wale no ia.   
\q1
\v 21 O na lehelehe o ka mea pono, hanai no i na mea he nui; O ka poe lapuwale, no ka noonoo ole e make ana lakou.   
\q1
\v 22 O ka hoomaikai o Iehova, oia ka mea e waiwai ai, Aole hoi mea e eha ai ka manao malaila.   
\q1
\v 23 Ua akaaka ka mea lapuwale, ke hana kolohe; O ke akamai, na ke kanaka ike no ia.   
\q1
\v 24 O ka weliweli o ka mea hewa, e hookoia auanei ia maluna ona; O ka manaolana o ka mea pono, e hooiaioia mai ia nona.   
\q1
\v 25 E like me ka holo ana aku o ka puahiohio, pela ka mea hewa, aole ia; Aka, o ka mea pono, na onipaa ia a mau loa no.   
\q1
\v 26 E like me ka vinega i na niho, A me ka uahi i na maka, Pela ka mea molowa i ka poe nana ia e hoounauna aku.   
\q1
\v 27 O ka makau ia Iehova, oia ka mea e nui ai na la; O na makahiki o ka poe hewa, e hoopokoleia.   
\q1
\v 28 O ka manaolana o ka poe pono, he hauoli ia; O ka manaolana o ka poe hewa, e pio no ia.   
\q1
\v 29 O ka aoao o Iehova, o ka mea ia i ikaika ai ka mea pono; O ka make hoi ia i ka poe hana hewa.   
\q1
\v 30 E mau ana ka mea pono, aole ia e naue ae; O ka poe hewa, aole no lakou ka honua.   
\q1
\v 31 O ka waha o ka mea pono, hoike mai ia i ka naauao; A o ke elelo hoinoino, e okiia ae.   
\q1
\v 32 O na lehelehe o ka mea pono, ua hoikeike i ka mea oluolu; A o ka waha o ka poe hewa i ka inoino.   
\c 11  
\b  
\q1
\v 1 O KE kaupaona hoopunipuni, he koopailua ia ia Iehova; O ke kaupaona kupono, oia kona makemake.   
\q1
\v 2 A hiki mai ka haaheo, alaila hiki mai ka hilahila; Me ka poe naau haahaa hoi ka naauao.   
\q1
\v 3 O ka pono o ka mea pololei oia kona alakai; Ma ka wahahee hoi e make ai ka poe hoopunipuni.   
\q1
\v 4 O ka waiwai, aohe mea ia e pono ai i ka la e inaina mai ai; Aka, o ka pono oia ke hoopakele ae i ka make.   
\q1
\v 5 O ka pono o ka poe pololei, oia ke kuhikuhi o kona ala; E haule hoi ka mea hewa i kona hewa iho.   
\q1
\v 6 Ma ka pono e pakele ai ka poe pololei; Ma ke kolohe hoi e heiia'i ka poe aia.   
\q1
\v 7 I ka make ana o ke kanaka hewa, pau kona manaolana; E poho no hoi ka manao o ka poe hewa.   
\q1
\v 8 Laweia'ku ka mea pono mai ka popilikia aku, A hiki mai ka mea hewa ma kona hakahaka.   
\q1
\v 9 Ma ka waha o ka aia e make ai kona hoa; Ma ka ike oiaio hoi e pakele ai ka poe pono.   
\q1
\v 10 I ka lanakila ana o ka poe pono e hauoli ke kulanakauhale; I ke pio ana o ka poe hewa he olioli no.   
\q1
\v 11 Ma ka hoomaikaiia mai o ka poe pololei, E hookiekieia ke kulanakauhale; Ma ka waha o ka poe hewa, ua hoohioloia.   
\q1
\v 12 O ka mea hailiili aku i kona hoanoho, he naaupo ia; A o ke kanaka naauao, noho hamau oia;   
\q1
\v 13 O ka mea holoholo olelo, hai wale aku ia i na mea huna; O ka mea manao oiaio, e huna ana no oia.   
\q1
\v 14 Ma kahi e ahaolelo ole ai, e haule na kanaka; Ma ka lehulehu o ka poe kukakuka he maluhia.   
\q1
\v 15 E hihia no ka mea pai lima me ka malihini; A o ka mea hoole i ke pai lima ana, ua pakele ia.   
\q1
\v 16 O ka wahine lokomaikai, e loaa io no ka mahaloia mai; E loaa no hoi ka waiwai i ka poe hana ikaika.   
\q1
\v 17 O ka mea minamina i kona uhane iho, he kanaka lokomaikai oia; O ka mea hoino i kona kino, he aloha ole kona.   
\q1
\v 18 O ka mea hewa, he hana inea kana; O ka mea lulu i ka pono, he uku oiaio kona.   
\q1
\v 19 E like me ka pili ana o ka pono i ke ola, Pela e pili ai ka make i ka mea hana hewa.   
\q1
\v 20 He mea hoopailua ia Iehova ka poe naau hoopunipuni; Aka, o ka poe i pololei ka aoao, oia kona makemake.   
\q1
\v 21 Ina e kui kahi lima i kekahi lima, aole nae e hoopakeleia ka mea hewa; O ka mamo hoi o ka poe pono, e hoopakeleia oia.   
\q1
\v 22 Me he apo gula la ma ka ihu o ka puaa, Pela ka wahine i maikai ka maka a nele i ka noonoo ole.   
\q1
\v 23 O ka makemake o ka mea pono, he hope maikai kona; O ka manaolana hoi o ka poe hewa, he inainaia mai ka hope.   
\q1
\v 24 Hoohelelei kekahi, a nui hou ae no nae; Aua hoi kekahi i ka mea ku ole i ka pono, a o ka nele ka hope.   
\q1
\v 25 O ka mea e hoomanawalea aku, e momona ia; A o ka mea e hoomauu aku, e hoomauuia mai oia.   
\q1
\v 26 O ka mea aua i ka ai, e hoino na kanaka ia ia; E kau ana hoi ka hoomaikaiia mai ma ke poo o ka mea kuai aku.   
\q1
\v 27 O ka mea imi i ka maikai, imi no ia i ke alohaia mai; O ka mea imi i ka hewa, e hiki mai no ia io na la.   
\q1
\v 28 O ka mea paulele i kona waiwai, e haule oia; Aka, me he lala laau la e ulu ai ka poe pono.   
\q1
\v 29 O ka mea hoonaukiuki i ko kona hale, e ili mai nona ka makani; E hookauwa aku auanei ka naaupo na ka mea naauao.   
\q1
\v 30 O ka hua no ka pono, oia ka laau o ke ola; O ka mea hoohuli i na uhane, oia ke akamai.   
\q1
\v 31 Aia hoi, e hooukuia ka mea pono ma ka honua; Pela no a oi aku ka mea hewa a me ka ino.   
\c 12  
\b  
\q1
\v 1 O KA mea makemake i ke aoia mai, oia ka i makemake i ka ike; O ka mea hoowahawaha i ke aoia mai, he holoholona ia.   
\q1
\v 2 O ka mea maikai, e loaa ia ia ka lokomaikai no Iehova mai; A e hoohewa mai oia i ke kanaka hoopunipuni.   
\q1
\v 3 Aole ma ka hewa e ku paa'i ke kanaka; O ka hookumu ana o ka poe pono, aole ia e neenee ae.   
\q1
\v 4 O ka wahine noho pono he papale alii oia i kana kane; Aka, me he mea popopo la i kona mau iwi ka wahine e hoohilahila aku.   
\q1
\v 5 O ka manao ana o ka poe pono, aia ma ka hoopono; O ke kuka ana o ka poe hewa, aia ma ka hoopunipuni.   
\q1
\v 6 O ka olelo a ka poe hewa, he hoohalua ia i ke koko; Aka, o ka waha o ka poe pololei, oia ka lakou e hoopakele aku.   
\q1
\v 7 Ua hooauhulihia ka poe hewa, a nalowale; E ku mau ana hoi ka hale o ka poe pono.   
\q1
\v 8 E hoomaikaiia ke kanaka e like me kona akamai; Aka, o ka mea naau lokoino, e hoowahawahaia oia.   
\q1
\v 9 O ka mea i hoowahawahaia, a he kauwa nana, Oi aku oia i ka mea hoohanohano ia ia iho, a nele i ka ai ole.   
\q1
\v 10 Manao no ke kanaka pono i ka ola o kona holoholona; Aka, o ke aloha o ka poe hewa, he lokoino no ia.   
\q1
\v 11 O ka mea i mahi i kona aina, e maona no i ka ai; Aka, o ka hoopili mea ai me ka poe palaualelo, he lapuwale ia.   
\q1
\v 12 He lealea i ka mea hewa ka punihei ino ana; O ke kumu o ka poe pono e hua mai no ia.   
\q1
\v 13 Ma ka ino o na lehelehe i puniheiia'i ka mea hewa; E puka mai no hoi ka mea pono noloko ae o ka pilikia.   
\q1
\v 14 Ma ka hua o ka waha, e maona ai ke kanaka i ka maikai; O ka uku o ko ke kanaka lima e haawiia ia ia.   
\q1
\v 15 O ka aoao o ka mea naaupo, ua pololei ia i kona manao iho; Aka, o ka mea hoolohe i ke aoia mai, ua naauao oia.   
\q1
\v 16 O ka huhu o ka naaupo o ike koke ia; Hoonalowale ka mea maalea i ka mea e hilahila'i.   
\q1
\v 17 O ka mea hai aku i ka oiaio, hoike oia i ka pono; A o ka hoike wahahee hoi, hoike oia i ka hoopunipuni.   
\q1
\v 18 Olelo kekahi e like me ka hou ana o ka pahikaua; A o ke elelo o ka poe naauao, ma ka hoola ia.   
\q1
\v 19 O na lehelehe oiaio, e mau ana no ia; O ke elelo wahahee e pau koke no ia.   
\q1
\v 20 He hoopunipuni ma ka naau o ka poe manao ino; A no ka poe kukakuka i ka maluhia, he olioli.   
\q1
\v 21 Aole e loohia mai ka mea pono e ka poino; Aka, piha no ka poe hewa i na mea e ino ai.   
\q1
\v 22 He mea hoopailua ia Iehova na lehelehe hoopunipuni; O ka poe hana ma ka oiaio, oia kona olioli.   
\q1
\v 23 O ke kanaka noeau, e waiho ana ia ia ka ike; O ka naau o na naaupo, hoike wale no ia i ka lapuwale.   
\q1
\v 24 O ka lima o ka poe hana mau e lilo oia i haku; O ka mea hoomolowa, malalo no ia o ka hookupu.   
\q1
\v 25 O ke kaumaha iloko o ka naau o ka kanaka, he mea e kulou iho ai; Aka, ma ka olelo maikai ia e hooluoluia'i.   
\q1
\v 26 Ua maikai ka mea pono mamua o kona hoanoho; O ka aoao o ka poe hewa, e hoowalewale oia ia lakou.   
\q1
\v 27 Aole o hopu ka molowa i kana mea ai; Aka, o ka waiwai o ke kanaka maikai, he gula ia.   
\q1
\v 28 Ma ke ala pono ke ola, Ma kolaila kuamoo no hoi, aole e make.   
\c 13  
\b  
\q1
\v 1 O KE keiki akamai, aia no ia ma ke aoia e kona makuakane; O ka mea hoowahawaha, aole ia e hoolohe i ke aoia mai.   
\q1
\v 2 Ma ka hua o ka waha e ai ai ke kanaka i ka maikai: E ai ka uhane o ka poe aia i ka poino.   
\q1
\v 3 O ka mea malama i kona waha, malama no ia i kona uhane; O ka mea hoohamama i ka waha, e loaa ia ia ka make.   
\q1
\v 4 Makemake wale ka uhane o ka mea hiamoe, aole i loaa; O ka uhane o ka poe hana mau, e maona no ia.   
\q1
\v 5 Ua inaina mai ka mea pono i ka olelo wahahee; O ka mea hewa la, he hoopailua ia a me ka hilahila.   
\q1
\v 6 Na ka pono e kiai i ka mea hele pololei; Na ka hewa hoi e hoohiolo i ka mea lawehala.   
\q1
\v 7 Hoowaiwai kekahi ia ia iho, aole nae he wahi mea ia ia; Hoonele hoi kekahi ia ia iho, a nui no nae kana waiwai.   
\q1
\v 8 O ka panai ana o ko ke kanaka ola, o kona waiwai no ia; O ka mea ilihune, aole ia e hoolohe i ke aoia mai.   
\q1
\v 9 O ka malamalama o ka poe pono, he mea hoohauoli ia; O ke kukui o ka poe hewa, e pio auauei ia.   
\q1
\v 10 Ma ka haaheo wale no ka hakaka; Ma ka poe kukakuka pono ka naauao.   
\q1
\v 11 E hele liilii ka waiwai i haapuka wale ia; O ka mea hoiliili ma ka hana, e mahuahua no.   
\q1
\v 12 O ka manaolana i hoopaneeia, oia ka mea e maule ai ka naau; A hiki mai ka mea i makemakeia, oia ka laau o ke ola.   
\q1
\v 13 O ka mea hoowahawaha i ka olelo, e make no ia; O ka mea makau aku i ke kanawai, e ukuia oia,   
\q1
\v 14 O ke ao ana o ke kanaka naauao, he punawai ola ia, He mea hoi e pakele ai i na pahele o ka make.   
\q1
\v 15 Ma ka noonoo pono i loaa'i ka lokomaikaiia mai; O ka aoao o ka poe aia, he pilikia ia.   
\q1
\v 16 E haua no na mea noonoo a pau ma ka ike; O ka naaupo hoi ka i hoike aku i ka lapuwale.   
\q1
\v 17 O ke kukini hewa, haule oia i ka lalau, O ka elele oiaio hoi, oia ka mea e pono ai.   
\q1
\v 18 He ilihune a he hilahila i ka mea haalele i ke aoia mai; O ka mea malama i ke aoia mai, e hoomaikaiia mai oia.   
\q1
\v 19 O ka makemake i loaa mai, he ono no ia i ka uhane; He mea hoowahawaha i ka poe lapuwale, ka haalele i ka hewa.   
\q1
\v 20 O ka mea hele pu me ka poe akamai, akamai no ia; O ka hoalauna o ka poe lapuwale, e mahuahua ka hewa.   
\q1
\v 21 Hahai ka poino i ka poe hewa; E ukuia ka poe pono i ka pomaikai.   
\q1
\v 22 E hooili mai ko ka mea maikai no kana poe mamo; Ua waihoia hoi na ka poe pono ka waiwai o ka mea hewa.   
\q1
\v 23 O ka ai nui, aia ma ka mahiai o ka poe ilihune; Lilo wale hoi kekahi no ka noonoo ole.   
\q1
\v 24 O ka mea hookaaokoa i ka laau hahau, oia ke aloha ole i kana keiki; O ka mea aloha ia ia, imi no ia i ke aoia mai nona.   
\q1
\v 25 E ai no ka poe pono, a maona kona uhane, O ka opu o ka poe hewa, e nele ia i ka ai ole.   
\c 14  
\b  
\q1
\v 1 O KA wahine naauao, oia ke kukulu i kona hale; Wawahi iho la ka mea naaupo me kona mau lima.   
\q1
\v 2 O ka mea hele ma kona pololei, oia ka i makau ia Iehova; O ka mea i hookekee i kona aoao, oia ka i hoowahawaha ia ia.   
\q1
\v 3 Ma ka waha o ka mea naaupo, he laau hahau ka haaheo; O na lehelehe o ka poe naauao, oia ke malama aku ia lakou.   
\q1
\v 4 I ole na bipi, kaawale ka hale waihona ai, A ua nui hoi ka waiwai ma ka ikaika o ka bipi.   
\q1
\v 5 O ka mea hoike oiaio, aole oia e wahahee; E hai wahahee mai no ka mea hoike hoopunipuni.   
\q1
\v 6 Imi ae la ka mea hoowahawaha i ke akamai, aole loaa; He hikiwawe no ka ike i ka mea naauao.   
\q1
\v 7 E huli ae oe mai ke alo aku o ke kauaka lapuwale, Ke hoomaopopo ole oe i na lehelehe ike.   
\q1
\v 8 O ke akamai o ka mea ike, oia ka hoomaopopo ana i kona aoao; O ka lapuwale o ka poe naaupo, oia ka hoopunipuni.   
\q1
\v 9 Akaaka ka poe lapuwale i ka hewa; Me ka poe hoopololei ka hoomaikaiia.   
\q1
\v 10 Ua ike ka naau i ke kaumaha o kona uhane iho; Aohe hoi i mea mai ka malihini i kona olioli.   
\q1
\v 11 O ka hale o ka poe hewa, e hoohioloia; O ka halelewa o ka poe pololei, e paa mau no ia,   
\q1
\v 12 O kekahi aoao, he pololei ia i kanaka; O kona hope hoi, oia ka aoao o ka make.   
\q1
\v 13 I ka akaaka ana, he ehaeha ko ka naau; O ka hope hoi o ia lealea, oia ke kaumaha.   
\q1
\v 14 E hoopihaia auauei ka naau o ka mea hoi hope i kona aoaoiho; A o ke kanaka maikai hoi i kona hua iho.   
\q1
\v 15 Manaoio no ka mea noonoo ole i na olelo a pau; Aka, o ka mea maalea, nana pono oia i kona hele ana.   
\q1
\v 16 O ka mea naauao, makau no ia, a haalele i ka hewa; O ka mea lapuwale hoi, he haaheo kona a me ka makau ole.   
\q1
\v 17 O ka hiki wawe o ka huhu, oia ka hana lapuwale; O ke kanaka imi i na manao hewa, ua inaina oia.   
\q1
\v 18 E ili mai ka lapuwale no ka poe noonoo ole; E kau hoi ka ike me he lei la maluna o ka poe naauao.   
\q1
\v 19 Kulou ae ka poe hewa imua i ke alo o ka poe maikai; O ka poe aia hoi ma ka ipuka o ka mea pono.   
\q1
\v 20 Ua inainaia ka mea ilihune e kona hoanoho; O ka mea waiwai, lehulehu kona poe makamaka.   
\q1
\v 21 O ka mea hoowahawaha i kona hoanoho, ua hewa oia; O ka mea lokomaikai aku i ka mea i nele, pomaikai oia.   
\q1
\v 22 Aole anei he lalau wale ko ka poe imi hewa? He aloha a he oiaio na ka poe imi maikai.   
\q1
\v 23 Ma ka hana a pau he waiwai no; Aka, o ke kamailio wale o na lehelehe, pili i ka ilihune wale no.   
\q1
\v 24 O ka lei o ka poe akamai, oia ko lakou waiwai; O ka lapuwale o ka poe naaupo, he lapuwale wale iho no ia.   
\q1
\v 25 Hoopakele i na uhane ka mea hoike oiaio; O ka mea hoike wahahee, hoopunipuni no ia.   
\q1
\v 26 Ma ka makau ia Iehova, malaila ka paulele nui; He puuhonua hoi ia na kana poe keiki.   
\q1
\v 27 O ka makau ia Iehova, he punawai ola ia, He mea ia e haalele ai i na pahele o ka make.   
\q1
\v 28 Ma ka lehulehu o na kanaka ka hanohano o ke alii, A i ole na kanaka ua make ke alii.   
\q1
\v 29 O ka mea uumi i ka huhu, oia ka noonoo nui; O ka mea hikiwawe i ka huhu, oia ke hoike i ka lapuwale.   
\q1
\v 30 O ke ola no ke kino, oia ka naau oluolu, O ka lili, oia ka popopo o na iwi.   
\q1
\v 31 O ka mea hookaumaha i ka mea nele, oia ka i hoowahawaha i ka Mea nana ia i hana; O ka mea malama aku ia ia, oia ke aloha i ka mea ilihune.   
\q1
\v 32 Hookukeia ka mea hewa iloko o kona hewa; Lana hoi ka manao o ka mea pono i kona make ana.   
\q1
\v 33 Noho no ka naauao ma ka naau o ka mea noonoo; Ua ikea hoi ko loko o ka poe lapuwale.   
\q1
\v 34 Hookiekie ae la ka pono i ka lahuikanaka; O ka hewa hoi ka mea e hoowahawahaia'i na kanaka.   
\q1
\v 35 O ka makemake o ke alii, aia i ke kauwa naauao; O kona huhu aia i ka mea e hilahila ai.   
\c 15  
\b  
\q1
\v 1 O KA olelo akahai, oia ke pale ae i ka huhu; O ka olelo huhu hoi, oia ke hoala ae i ka inaina.   
\q1
\v 2 O ke elelo o ka poe akamai, hoike pololei aku ia i ka ike; O ka waha hoi o ka poe lapuwale, hu ae la ia i ka lapuwale.   
\q1
\v 3 Ma na wahi a pau na maka o Iehova, E haka pono ana i na mea hewa a me na mea maikai   
\q1
\v 4 O ke elelo akahai oia ka laau o ke ola; O ka awahia iloko o ia mea, oia ka nahae ana o ka uhane.   
\q1
\v 5 Hoowahawaha ka mea lapuwale i ke aoia mai e kona makua, O ka mea hoolohe i ke aoia mai, oia ka mea naauao.   
\q1
\v 6 O ka hale o ka mea pono, he waiwai nui; Ma na mea i hoahuia e ka mea hewa, he poino.   
\q1
\v 7 O na lehelehe o ka poe akamai hoolaha no i ka ike; O ka naau o ka poe lapuwale, aole pela.   
\q1
\v 8 O ka mohai o ka poe hewa, he hoopailua ia ia Iehova; O ka pule a ka poe pololei, oia kona makemake.   
\q1
\v 9 He hoopailua ia Iehova ka aoao o ka mea hewa; O ka mea hahai mahope o ka pono, oia kana mea i aloha ai.   
\q1
\v 10 O ka hoopaiia mai, he mea kaumaha ia i ka mea haalele i ka aoao; O ka mea hoowahawaha hoi i ke aoia mai, e make oia.   
\q1
\v 11 O ka lua a me ka make, aia no imua o Iehova; Pela io no ka naau o na keiki a na kanaka.   
\q1
\v 12 Aole i aloha aku ka mea hoowahawaha i ka mea i ao mai ia ia; Aole hoi oia e hele i ka poe naauao.   
\q1
\v 13 Ina olioli ka naau, oluolu no hoi ka maka; A i kaumaha ka naau, nahae no ka uhane.   
\q1
\v 14 O ka naau o ka mea naauao, imi oia i ka ike; O ka waha o ka poe naaupo, paina no ia i ka lapuwale.   
\q1
\v 15 Poino no na la a pau o ka poe popilikia; O ka mea naau oluolu, he ahaaina mau no kana.   
\q1
\v 16 Maikai kahi mea iki me ka makau ia Iehova, Mamua o ka waiwai nui ke pili pu me ka hakaka.   
\q1
\v 17 Maikai kahi launahele ke ai me ke aloha pu kekahi, Mamua o ka bipi momona, ina he inaina hoi kekahi.   
\q1
\v 18 O ke kanaka huhu, oia ke hoala ae i ka hakaka; O ka mea akahele ka huhu, hoomalielie oia i ka hakaka.   
\q1
\v 19 O ka aoao o ka mea palaualelo, ua like ia me kahi paapu i na kakalaioa; O ka aoao hoi o ka poe pololei ua hooponoponoia.   
\q1
\v 20 O ke keiki akamai, hoohauoli oia i kona makuakane; O ke kanaka lapuwale, hoowahawaha oia i kona makuwahine.   
\q1
\v 21 O ka hana lapuwale, he olioli ia i ka naaupo; O ke kanaka naauao hoi, oia ka i hele pololei.   
\q1
\v 22 Hill hewa na manao, ke ole ke kukakuka ana; A i ka nui o ka poe kukakuka, e paa no.   
\q1
\v 23 He olioli ko ke kanaka ma ka pane ana o kona waha; O ka huaolelo hoi i ka wa kupono, ua maikai ia.   
\q1
\v 24 O ke ala o ke ola, malaila e pii ai ka poe naauao, I pakele ae i ka malu make malalo.   
\q1
\v 25 O ka hale o ka poe haaheo, na Iehova ia e hoohiolo; Hookupaa oia i ka mokuna aina o ka wahinekanemake.   
\q1
\v 26 He hoopailua ia Iehova na manao o ka mea hewa; He oluolu nae ka olelo a ka poe maemae.   
\q1
\v 27 O ka mea makee waiwai, hana ino loa oia i ko kona hale; A o ka mea hoowahawaha i na makana, e ola ia.   
\q1
\v 28 O ka naau o ka mea pono, noonoo ia i kaua mea e olelo aku ai; O ka waha o ka poe hewa, hu ae la ia i ka ino.   
\q1
\v 29 Ua loihi e aku o Iehova mai ka poe hewa aku; Hoolohe hoi oia i ka pule a ka poe pono.   
\q1
\v 30 O ka malamalama o na maka, he mea ia e olioli ai ka naau; A o ka lohe i ka mea maikai, oia ka mea e momona ai na iwi.   
\q1
\v 31 O ka pepeiao o lohe ana i ke aoia mai no ke ola, Noho mau ia iwaena o ka poe naauao.   
\q1
\v 32 O ka mea hoole i ke aoia mai, oia ka i hoowahawaha i kona uhane iho; O ka mea hoolohe i ke aoia mai e loaa ia ia ka naauao.   
\q1
\v 33 O ka makau ia Iehova, oia ka ike ana i ka naauao: O ka naau haahaa mamua ia o ka mahaloia mai.   
\c 16  
\b  
\q1
\v 1 O KA makaukau o ko ke kanaka naau, A me ka pane ana o ke elelo, no Iehova mai ia.   
\q1
\v 2 O na aoao a pau o ke kanaka ua maemae i kona maka iho; Aka, kaupaona o Iehova i na uhane.   
\q1
\v 3 E hooili aku i kau mau hana maluna o Iehova, A e hookupaaia kou mau manao.   
\q1
\v 4 Hana iho la o Iehova i na mea a pau nona iho; I ka mea hewa hoi kekahi no ka la e poiuo ai.   
\q1
\v 5 He hoopailua ia Iehova na naau kiekie a pau; Ina e kui kahi lima i kahi lima, aole nae e ole kona hoopaiia.   
\q1
\v 6 Ma ka lokomaikai a me ka oiaio ua kalaia ka hewa; Ma ka makau ia Iehova ka haalele ana i ka hewa.   
\q1
\v 7 I ka manao oluolu ana o Iehova i ka aoao o ke kanaka, Noho launa no kona poe enemi ia ia.   
\q1
\v 8 Maikai kahi mea iki me ka pono hoi kekahi, Mamua o ka waiwai nui ke pono ole.   
\q1
\v 9 Noonoo iho la ko ke kanaka naau i kona aoao iho; Aka, na Iehova e alakai i kona mau kapuwai.   
\q1
\v 10 Aia ka olelo kupono ma na lehelehe o ke alii; Ma ka hooponopono ana aole i hewa kona waha.   
\q1
\v 11 O ke kaupaona a me na mea anapaona pololei, na Iehova no ia; O kana hana no na mea anapaona a pau iloko o ka eke.   
\q1
\v 12 He mea hoopailua no na alii ke hana hewa; No ka mea, ma ka pono i paa'i ka nohoalii.   
\q1
\v 13 O ka makemake o na'lii. oia na lehelehe pono, A o ka mea olelo pololei, oia ka i alohaia.   
\q1
\v 14 O ka huhu o ke alii, o na elele ia no ka make; O ke kanaka akamai, oia ke hoomaalili aku.   
\q1
\v 15 Ma ka maka oluolu o ke alii ke ola, O kona lokomaikai hoi ua like me ke ao i ke kuaua hope.   
\q1
\v 16 O ka loaa ana o ke akamai, ua maikai ia mamua o ke gula; O ka loaa ana o ka naauao, e pono ke kohoia mamua o ke kala.   
\q1
\v 17 O ke alanui o ka poe pololei, hele ae la ia mai ka hewa aku; O ka mea malama i kona uhane, oia ke kiai i kona aoao.   
\q1
\v 18 Mamua o ka hina ana, ka haaheo, A mamua o ka haule ana ka naau kiekie.   
\q1
\v 19 E aho ka naau haahaa iwaena o ka poe akahai, Mamua o ka hoopuunaue ana i ka waiwai pio me ka poe haaheo.   
\q1
\v 20 O ka mea huli pono i kekahi mea e loaa ia ia ka maikai: O ka mea paulele ia Iehova e pomaikai ana oia.   
\q1
\v 21 O ka mea naau akamai, e kapaia he naauao; Ma ka oluolu o na lehelehe e mahuahua ai ka ike.   
\q1
\v 22 He punawai ola ka naauao i ka mea nona ia; O ke aoia mai o ka poe lapuwale, he lapuwale no ia.   
\q1
\v 23 O ka mea naauao, ao no oia i kona waha iho; Hooponopono hoi oia i kona mau lehelehe.   
\q1
\v 24 He mea ono na olelo oluolu. He ono i ka uhane, a he ola i ka iwi.   
\q1
\v 25 Pololei kekahi aoao i ko ke kanaka manao; Aka, o kona hope, oia na aoao o ka make.   
\q1
\v 26 O ka mea hana, hana oia nana iho: O kona waha ka i koi mai ia ia.   
\q1
\v 27 O ke kanaka aia, huai oia i ka ino; A ma kona mau lehelehe he ahi e aa ana.   
\q1
\v 28 O ke kanaka hoopaapaa, hoeueu oia i ka hakaka; A o ka mea holoholo olelo, hookaawale no ia i na makamaka.   
\q1
\v 29 O ke kanaka huhu, hoowalewale oia i kona hoalauna, Alakai hoi ia ia ma ka aoao maikai ole.   
\q1
\v 30 Hoopili oia i kona mau maka e noonoo ino ana: Naunau oia i kona lehelehe a hoomaopopo i ka hewa.   
\q1
\v 31 He lei naui ke poohina, Ke loaa ia ma ka aoao o ka pono.   
\q1
\v 32 Maikai ke ahonui mamua o ka ikaika; A o ka mea hoomalu i kona uhane mamua o ka mea hoopio I ke kulanakanhale.   
\q1
\v 33 Ma ka puolo i hooleiia ai ka hailona, Na Iehova nae ka hooponopono ana.   
\c 17  
\b  
\q1
\v 1 MAIKAI hahi huna ai maloo me ke aloha pu kekahi, Mamua o ka hale i piha i na mohai ke pili me ka hakaka.   
\q1
\v 2 O ke kauwa noonoo, e noho oia maluna o ke keiki e hana hilahila ana; A mawaena o na hoahanau e loaa ia ia kekahi hooilina.   
\q1
\v 3 He ipu hoohehee, no ke kala ia; no ke gula hoi he kapuahi uuku; Aka, na Iehova e hoao mai i na naau.   
\q1
\v 4 O ka mea hewa la hoolohe oia i na lehelehe wahahee; O ka mea wahahee hoi, haliu kona pepeiao i ke elelo ino.   
\q1
\v 5 O ka mea hoomaewaewa i ka mea nele, Ua hoowahawaha oia i ka mea nana ia i hana; O ka mea hoi i olioli i ka poino, Aole ia e pakele i ka hoopai ana.   
\q1
\v 6 O ka lei o ka poe elemakule, oia na keiki a na keiki; O ka nani hoi o na keiki, oia na makuakane o lakou.   
\q1
\v 7 Aole i kupono i ka mea naaupo ka lehelehe pololei; Aole loa hoi i ke alii ka lehelehe wahahee.   
\q1
\v 8 He pohaku waiwai io ka makana i ka maka o ka mea nana ia; Ma na wahi a pau e loaa ana he mea ia e pono ai.   
\q1
\v 9 O ka mea huna i ka hewa, oia ke imi i ke aloha; O ka mea hoolaha hou ae, hookaawale oia i na makamaka.   
\q1
\v 10 Komo ke aoia mai iloko o ka mea naauao, Mamua o na hahau ana he haneri iloko o ka mea lapuwale.   
\q1
\v 11 Ma ke kipi wale no e imi ai ke kanaka ino; Nolaila, hoounaia ka ilamuku io na la.   
\q1
\v 12 E aho ke halawai ka bea keiki make me ke kanaka, Aole ka mea naaupo iloko o kona lapuwale.   
\q1
\v 13 O ka mea hana ino aku na ka mea hana pono mai, Aole e kaawale ka ino mai kona hale aku.   
\q1
\v 14 E like me ka hookahe ana o ka wai, Pela ka hoomaka ana o ka hakaka; Nolaila, e oki e i ka hakaka mamua o kona mahuahua ana.   
\q1
\v 15 O ka mea hoopono aku i ka mea hewa, A o ka mea hoahewa aku i ka mea pono, Ho mau mea hoopailua laua ia Iehova.   
\q1
\v 16 No ke aha la keia, he kumu kuai ma ka lima o ka mea lapuwale, E kuai aku ai i ke akamai, aohe ona manao malaila?   
\q1
\v 17 I na manawa a pau e aloha ana ka makamaka, A no ka la popilikia i hanau ai ka hoahanau.   
\q1
\v 18 O ke kanaka naauao ole, pai oia i ka lima, Lilo ia i mea panai imua o kona makamaka.   
\q1
\v 19 O ka mea makemake i ke kipi, oia ka i makemake i ka hakaka; O ka mea hookiekie ae i kona ipuka, imi oia i ka make.   
\q1
\v 20 O ka mea naau kekee, aole i loaa ia ia ka maikai; O ka mea elelo hoopunipuni, e haule oia i ka ino.   
\q1
\v 21 O ka mea i hanau mai nana ke keiki lapuwale, he kaumaha kona; Aole e olioli ka makuakane o ke keiki naaupo.   
\q1
\v 22 O ka naau olioli, he laau lapaau ia e hooluolu ana; O ka uhane i hana pepe ia, hoomaloo ia i na iwi.   
\q1
\v 23 Kaili ae ka mea hewa i ka waiwai kipe, I kona hoohaunaele ana i ka aoao pono.   
\q1
\v 24 Imua i ke alo o ka mea noonoo malaila ka naauao; Aia hoi na maka o ka mea lapuwale, ma na welau o ka honua.   
\q1
\v 25 O ke keiki lapuwale, ke kaumaha ia no kona makuakane, He mea awahia hoi i ka mea nana ia i hanau mai.   
\q1
\v 26 O ka hoopai hewa i ka mea pono, aole ia he maikai, Aole hoi ke papai aku i na'lii no ka pololei.   
\q1
\v 27 O ka mea ike nui, akahele oia i ka olelo; He uhane noho malie ko ke kanaka naauao.   
\q1
\v 28 O ka mea naaupo hoi, i kona mumule ana, ua kuhiia oia he naauao; O ka mea pani i kona mau lehelehe hoi, he kanaka ike no ia.   
\c 18  
\b  
\q1
\v 1 NO ka makemake wale e imi ai ke kanaka manao ku e, A pale aku no i na manao pono a pau.   
\q1
\v 2 Aole i haliu mai ka mea lapuwale i ka ike, Aka, ma ka hoike ana i kona naau.   
\q1
\v 3 A hiki mai ka hewa, hiki mai no hoi ka hoowahawaha; A o ka hilahila pu kekahi me ka hoomaewaewa.   
\q1
\v 4 He wai hohonu na olelo o ko ke kanaka waha; He punawai e hu ana, ke kumu o ka naauao.   
\q1
\v 5 O ka hooluolu aku i ka mea hewa, aole ia he maikai; Aole hoi ka opea aku i ka mea pono ma ka hookolokolo ana.   
\q1
\v 6 O na lehelehe o ka mea lapuwale, aia no ma ka hoopaapaa; Ua maopopo kona waha e pono ke hahauia.   
\q1
\v 7 O ka waha o ka mea lapuwale, oia kona mea e make ai; A o kona mau lehelehe hoi, oia ke pahele o kona uhane.   
\q1
\v 8 O na olelo ahiahi, ua like me na olelo paani, A komo no nae iloko loa o ka opu.   
\q1
\v 9 O ka mea hoomolowa ma kana hana ana, He kaikaina oia o ka mea hoomaunauna wale.   
\q1
\v 10 He pakaua ikaika ka inoa o Iehova; Malaila e holo ai ka mea pono a maluhia iho la.   
\q1
\v 11 O ka waiwai o ka mea waiwai, oia kona kulanakauhale paa I ka pa, Ua like hoi me ka pa kiekie i kona manao.   
\q1
\v 12 Mamua o ka make, ua haaheo ka naau o ke kanaka, Mamua hoi o ka hookiekieia mai, he akahai.   
\q1
\v 13 O ka mea hoopuka i kona manao mamua o kona lohe ana, He lapuwale ia, a he mea ia nona e hilahila ai.   
\q1
\v 14 O ka uhane o ke kanaka, hoomanawanui no ia i ka nawaliwali; Aka, o ka uhane e eha ana, owai la e hiki ai ke hoomanawanui?   
\q1
\v 15 O ka naau o ka mea naauao e loaa ia ia ka ike; O ka pepeiao hoi o ka poe akamai, e imi no i ka naauao.   
\q1
\v 16 O ko ke kanaka makana, he mea ia e hookaawale ai i wahi nona; A e kai aku hoi ia ia imua o na kanaka koikoi.   
\q1
\v 17 Ua pono ka mea i hoopiiia i kana olelo mua ana; Aka, hele mai kona hoanoho a imi ae i kona ano.   
\q1
\v 18 O ka hailona ana ka mea e pau ai ka hoopaapaa; He mea hoi e uwao ai iwaena o ka ikaika.   
\q1
\v 19 Aole ikaika ke kulanakauhale paa i ka pa e like me ka hoahanau i hoonaukiukiia; A o ko laua hoopaapaa ana, ua like me na kaolahao o ka halealii.   
\q1
\v 20 Ma na hua o ko ke kanaka waha, e maona ai kona opu; A ma ka waiwai o kona mau lehelehe e piha ai oia.   
\q1
\v 21 Ma ke elelo ka make a me ke ola; O ka mea makemake malaila, e ai oia i kona hua.   
\q1
\v 22 O ka mea loaa ia ia ka wahine, loaa no ka mea maikai, Ua loaa hoi ia ia ka lokamaikai no Iehova mai.   
\q1
\v 23 He noi ko ke kanaka ilihune; A o ka mea waiwai, ua olelo kalakala oia.   
\q1
\v 24 O ke kanaka i nui na hoalauna, e poino oia malaila; Aka, o kekahi hoaaloha ua oi aku kona pipili ana mamua o ko ka hoahanau.   
\c 19  
\b  
\q1
\v 1 MAIKAI ka mea ilihune i hele ma kona pololei, Mamua o ka mea lehelehe wahahee, a lapuwale hoi.   
\q1
\v 2 O ka uhane i nele i ka ike, he pono ole ia; O ka mea i wikiwiki na wawae, hele hewa no ia.   
\q1
\v 3 O ka lapuwale o ke kanaka, oia ka i hookapae i kona aoao; A ukiuki aku kona naau ia Iehova.   
\q1
\v 4 O ka waiwai ka mea e hoonui ai i na makamaka; Ua hookaawaleia hoi ka mea ilihune mai kona hoanoho aku.   
\q1
\v 5 O ka mea hoike wahahee, aole e ole kona hoopaiia mai; O ka mea olelo wahahee hoi, aole ia e pakele.   
\q1
\v 6 Nui ka poe hoopili aku i ke alii; He hoalauna hoi kela mea keia mea no ke kanaka haawi wale.   
\q1
\v 7 Pau loa ka poe hoahanau o ka mea nele i ke aloha ole ia ia; Haalele loa hoi kona mau hoalauna ia ia; Hahai oia me na olelo, aole lakou.   
\q1
\v 8 O ka mea loaa ia ia ka naauao oia ke aloha i kona uhane; O ka mea hoopaa i ka ike, e loaa ia ia ka pono.   
\q1
\v 9 O ka mea hoike wahahee, aole e ole kona ahewaia mai, O ka mea olelo hoopunipuni, e make oia.   
\q1
\v 10 Aole i ku pono ka hanohano i ka mea lapuwale; Aole loa hoi i ke kauwa, ke noho maluna o na'lii.   
\q1
\v 11 O ko ke kanaka naauao, oia ke hoopanee aku i ka huhu; O kona naui hoi, oia ke kala ana i ka hala.   
\q1
\v 12 He uwo ana me he liona la ka huhu o ke alii; E like hoi me ka hau ma ka weuweu kona lokomaikai.   
\q1
\v 13 He mea poino i ka makuakane ke keiki lapuwale; He kulu mau ana ka hoopaapaa o ka wahine.   
\q1
\v 14 O ka hale a me ka waiwai, oia ka hooilina no na makua mai; Na Iehova mai hoi ka wahine manao pono.   
\q1
\v 15 O ka palaualelo ka mea e poho ai iloko o ka hiamoe nui; A o ka uhane hoomolowa, e pololi no ia.   
\q1
\v 16 O ka mea malama i ke kanawai, oia ka i malama i kona uhane; O ka mea malama ole i kona aoao, e make no ia.   
\q1
\v 17 O ka mea manawalea aku i ka ilihune, haawi aku oia na Iehova; A o kana mea i haawi ai, na kela no e hoihoi mai ia ia.   
\q1
\v 18 E haua i kau keiki oi laua ka manao nona, Mai menemene kou uhane no kona uwe ana.   
\q1
\v 19 O ka mea huhu nui, e hooukuia oia; Ina paha e hookuu aku oe ia ia, pono e hana hou no.   
\q1
\v 20 E hoolohe i ka oleloao, e haliu hoi i ke aoia mai, I naauao oe i kou hopena.   
\q1
\v 21 Nui na manao maloko o ka naau o ke kanaka, Aka, o ka manao o Iehova, oia ke ku paa.   
\q1
\v 22 O ka nani o ke kanaka, oia kona lokomaikai; Maikai hoi ke kanaka ilihune mamua o ka mea wahahee.   
\q1
\v 23 O ka makau ia Iehova, oia ke ola; E noho oluolu oia, aole e ike mai ka hewa ia ia.   
\q1
\v 24 Hookomo ka mea palaualelo i kona lima iloko o ka umeke, Aole oia e hoihoi hou aku ia i kona waha.   
\q1
\v 25 E pepehi i ka mea hoowahawaha, a e ao ka mea malama ole; E ao aku hoi i ka mea noonoo, a e ike oia i ka naauao.   
\q1
\v 26 O ka mea hao i kona makuakaue, a hookuke aku i kona makuwahine, Oia ke keiki hoino, a me ka hoohilahila.   
\q1
\v 27 Ua oki, e kuu keiki, mai hoolohe i ke ao ana, E hooauwana ai mai ka olelo aku o ka ike.   
\q1
\v 28 I aia ka mea hoike, hoowahawaha oia i ka pololei; O ka waha o ka poe hewa, moni no ia i ka ino.   
\q1
\v 29 Ua makaukau ka hoopaiia no ka poe haakei, O ka haua hoi no ke kua o ka poe lapuwale.   
\c 20  
\b  
\q1
\v 1 HE mea henehene ka waina, he walaau nui hoi ka mea e ona'i; O na mea a pau i puni malaila, aole i naauao.   
\q1
\v 2 He uwo ana me he liona la, ka weliweli i ke alii; O ka mea hoonaukiuki ia ia, hoeha no oia i kona uhane iho.   
\q1
\v 3 He mea nani no ke kanaka, ke hooki i ka hoopaapaa: Aka, e huhu no na mea lapuwale a pau.   
\q1
\v 4 Aole e mahiai ka mea palaualelo no ke anu; A e makilo oia i ka wa e ohi ai, aole e loaa.   
\q1
\v 5 He wai hohonu, ka oleloao iloko o ko kanaka naau; Na ke kanaka naauao e uhuki ae.   
\q1
\v 6 E hai aku ka nui o na kanaka i ko lakou pono iho; O ke kanaka hana oiaio, ia wai la i loaa'i ia?   
\q1
\v 7 O ka mea hele ma kona pololei, he mea pono oia; E hoomaikaiia hoi kana poe keiki mahope ona.   
\q1
\v 8 O ke alii e noho ana ma ka noho hookolokolo, Hooauhee oia i na hewa a pau me kona mau maka.   
\q1
\v 9 Owai la ke hiki e olelo aku, Ua hoomaemae au i ko'u naau? Ua kaawale au i ko'u hewa?   
\q1
\v 10 He ana paona palua a he ana palua no na mea e ae, He hoopailua ia Iehova ia mau mea elua.   
\q1
\v 11 Ua ikeia ke keiki ma ka hana ana, Ina paha he maemae, a he pololei kana hana.   
\q1
\v 12 O ka pepeiao lohe, a o ka maka nana, Na Iehova no i hana ia mau mea elua.   
\q1
\v 13 Mai makemake oe i ka hiamoe o lilo oe i mea nele; E wehe ae i kou mau maka, a e maona i ka ai.   
\q1
\v 14 He ino, he ino, wahi a ka mea kuai mai; A i kona hele ana aku, alaila, haanui oia.   
\q1
\v 15 Aia he gula a me na pohaku maikai he nui wale; Aka, o ka mea nani loa, oia ka lehelehe ike.   
\q1
\v 16 E lawe oe i ke kapa o kekahi ke panai oia no ka malihini, A no na malihini hoi i lawe i kekahi waiwai ana.   
\q1
\v 17 Ua ono i ke kanaka ka ai no ka wahahee; A mahope iho, e piha kona waha i ke one.   
\q1
\v 18 Ua paa ka manao ma ke kukakuka pu ana; Ma ka noonoo pololei hoi e kaua aku ai.   
\q1
\v 19 O ka mea holoholo olelo, hoike aku oia i na mea i hunaia; Mai launa aku me ka mea hoomalimali me koua mau lehelehe.   
\q1
\v 20 O ka mea hailiili aku i kona makuakane a me kona makuwahine, E pio kona kukui i ke onohi o ka pouli.   
\q1
\v 21 O ka hooilina i loaa mua ma ke kaili wale, O kona hopena, aole e pomaikai ia.   
\q1
\v 22 Mai olelo ae oe, E hoopai aku au i ka hewa; E kakali oe ia Iehova, nana no oe o kokua mai.   
\q1
\v 23 He hoopailua ia Iehova na ana paona papalua; O ke kaupaona hoopunipuni aole i pono ia.   
\q1
\v 24 Na Iehova mai ka hele ana o ke kanaka; Pehea hoi e hiki ai i ke kanaka ko ike i kona aoao iho?   
\q1
\v 25 He mea hihia i ke kanaka, ke hoohiki naaupo i ka mea hemolele; A mahope iho o ka hoohiki ana, alaila noonoo.   
\q1
\v 26 Hoopuehu ae ke alii akamai i ka poe hewa, Hookaa oia i ke kaa maluna o lakou.   
\q1
\v 27 O ke kukui o Iehova, o ka hanu ia o ke kanaka, E komo ana ma na wahi a pau o ka opu.   
\q1
\v 28 Na ka lokomaikai a me ka oiaio e malama mai i ke alii; Ua paa hoi kona nohoalii i ka lokomaikai.   
\q1
\v 29 O ka ikaika ka mea e kaulana'i na kanaka ui; O ke poohina ka mea e nani ai ka elemakule.   
\q1
\v 30 O ka pahu ana o ka mai he mea hoomaemae i ka ino; O ka haua hoi, i koloko o ka opu.   
\c 21  
\b  
\q1
\v 1 HE mau auwai ka naau o ke alii, iloko o ka lima o Iehova, Nana e hookahe ae e like me kona makemake.   
\q1
\v 2 O na aoao a pau o ke kanaka, ua pololei ia i kona maka iho, Hoao ae la o Iehova i na naau.   
\q1
\v 3 O ka hana ana i ka pono a me ka pololei, Ua makemakeia e Iehova mamua o ka mohai.   
\q1
\v 4 O ka maka haaheo, o ka naau hookiekie, O ka pomaikai ana hoi o ka poe hewa he pono ole no ia.   
\q1
\v 5 O ka manao o ka mea hana mau, pili no ia i ka lako; O ko ka mea wikiwiki wale, pili no ia i ka nele.   
\q1
\v 6 O ka imi ana i ka waiwai ma ke elelo wahahee, He opala i hoopuehuia e ka poe e imi ana i ka make.   
\q1
\v 7 O ke kaili wale o ka poe hewa, e kaili aku ia ia lakou; No ka mea, hoole lakou, aole e hana ma ka hoopono.   
\q1
\v 8 He kekee ka aoao o ke kanaka, a he ano e hoi; O ka mea maemae hoi, ua pololei kana hana.   
\q1
\v 9 E aho ka noho ma ke kihi maluna o ka hale, Aole hoi me ka wahine hakaka ma ka hale kanaka.   
\q1
\v 10 O ka uhane o ka mea hewa, makemake no ia i ka hewa; Aole ona lokomaikai mai i kona hoanoho.   
\q1
\v 11 Ma ka hoopaiia mai o ka mea hoowahawaha, e hoonaauaoia'i ka mea ike ole; I ke ao ana aku i ka mea akamai, e loaa no ia ia ka ike.   
\q1
\v 12 Noonoo nui ka mea pono i ka hale o ka mea hewa; Ua hookahuliia ka poe hewa no ka hana hewa ana.   
\q1
\v 13 O ka mea i papani i kona pepeiao i ka uwe ana o ka mea nele, E hea aku no oia, aohe mea e hoolohe mai.   
\q1
\v 14 O ka makana malu, pale ae no ia i ka huhu; Pela hoi ka makana poli i ka inaina ikaika.   
\q1
\v 15 He olioli i ka mea pono ke hana ma ka pololei; He make no ko ka poe hana hewa.   
\q1
\v 16 O ke kanaka hele hewa mai ka aoao ae o ka naauao, E noho no oia ma ke anaina o ka poe malu make.   
\q1
\v 17 O ka mea makemake i ka lealea, e ilihune auanei ia, O ka mea makemake i ka waina a me ka aila, aole ia e waiwai.   
\q1
\v 18 Pani ka mea hewa i ka hakahaka no ka mea pono; Pela ka mea lawe hala no ka mea pololei.   
\q1
\v 19 E aho ka noho noho ana ma ka waoakua. Aole me ka wahine huhu a me ka hakaka.   
\q1
\v 20 Aia ka waiwai i makemakeia a me ka aila ma ka hale o ka mea naauao; A o ke kanaka lapuwale, moni iho la oia ia mea.   
\q1
\v 21 O ka mea hahai mahope o ka pono, a me ka lokomaikai, E loaa ia ia ke ola a me ka pono a me ka nani.   
\q1
\v 22 Pii ae ka mea naauao maluna o ke kulanakauhale o ka poe ikaika, Hoohiolo oia i ka ikaika a lakou i paulele ai.   
\q1
\v 23 O ka mea malama i kona waha a me kona alelo, Oia ka i hoopakele i kona uhane i ka popilikia.   
\q1
\v 24 O ka haaheo, o ka hookano, o ka hoowahawaha, Oia ka inoa o ka mea hana ma ka huhu ikaika.   
\q1
\v 25 O ka makemake o ka mea palaualelo oia kona mea e make ai; No ka mea, hoole kona mau lima i ka hana.   
\q1
\v 26 Kuko wale aku no ia a po ka la; Haawi aku hoi ka mea pono me ka aua ole.   
\q1
\v 27 O ka mohai o ka poe hewa, he hoopailua ia; Ua oi aku hoi ka hewa, ke lawe oia ia mea me ka manao ino.   
\q1
\v 28 O ka mea hoike wahahee, e make no ia; O ke kanaka hoolohe, oia ke olelo mau.   
\q1
\v 29 Hoopaakiki ke kanaka hewa i kona maka; O ka mea pololei hoi, hoopololei oia i kona aoao.   
\q1
\v 30 Aohe akamai, aohe noonoo; Aole hoi oleloao e hiki ai ke ku e aku ia Iehova.   
\q1
\v 31 Ua hoomakaukauia ka lio no ka la e kaua ai; Aka, ia Iehova no ka hoopakele ana.   
\c 22  
\b  
\q1
\v 1 HE mea makemakeia ke kaulaua mamua o ka waiwai he nui; A mamua hoi o ke kala a me ke gula ka lokomaikai io.   
\q1
\v 2 Halawai pu ka poe waiwai a me ka poe ilihune; Na Iehova lakou a pau i hana.   
\q1
\v 3 Nana ae la ka mea noonoo i ka ino, a huna ia ia iho; Hele wale aku hoi ka mea naaupo a hihia oia.   
\q1
\v 4 No ka naau haahaa, ka makau ia Iehova, Ka waiwai hoi a me ka hanohano a me ke ola.   
\q1
\v 5 Aia na kakalaioa a me na mea hihia ma ke ala o ka mea hele kekee; O ka mea malama i kona uhane, kaawale no oia ia mau mea.   
\q1
\v 6 E ao aku i ke kamalii i kona aoao, A elemakule oia, aole ia e huli ae mailaila aku.   
\q1
\v 7 Noho alii ka mea waiwai maluna o ka poe ilihune, He kauwa hoi ka mea hoopili wale na ke kanaka haawi wale.   
\q1
\v 8 O ka mea lulu aku i ka hewa, e ohi ia i ka popilikia; Ua hoopauia ka laau hahau o kona huhu.   
\q1
\v 9 O ka mea maka lokomaikai, e hoomaikaiia oia; No ka mea, ua haawi wale ia i kekahi o kana berena i ka mea nele.   
\q1
\v 10 E hookuke aku i ka mea hoowahawaha, a e kaawale aku hoi ka hoopaapaa; E pau hoi ka hakaka a me ka hoomaewaewa.   
\q1
\v 11 O ka mea makemake aku i ka naau maemae, No ka lokomaikai o kona mau lehelehe, o lilo ke alii i hoaaloha nona.   
\q1
\v 12 O na maka o Iehova, malama aku no i ka ike, Hoohiolo oia i na olelo a ka mea aia.   
\q1
\v 13 Olelo ae la ka mea palaualelo, he liona mawaho, E make auanei au ma ke alanui.   
\q1
\v 14 He lua hohonu ka waha o ka wahine hookamakama, O ka mea inainaia e Iehova, e haule no ia malaila.   
\q1
\v 15 Ua paa ke kolohe iloko o ka naau o ke kamalii, O ka laau hahau, oia ke hoohemo ae ia mea mai ona aku.   
\q1
\v 16 O ka mea hookaumaha i ka mea ilihune i mea e hoomahuahua ai i kana iho, A o ka mea haawi no ka mea waiwai, e nele io no laua a elua.   
\b  
\q1
\v 17 E haliu mai kou pepeiao a e hoolohe i na olelo a ka poe naauao, A e imi iho kou naau i ko'u ike.   
\q1
\v 18 No ka mea, he oluolu no ke malama oe ia mau mea iloko ou, E ku pono no hoi i kou mau lehelehe;   
\q1
\v 19 I paulele oe ia Iehova, Oia ka'u i hoike ai ia oe, ia oe no i keia la,   
\q1
\v 20 Aole anei i palapala aku au ia oe i na maikai, Ma na oleloao a me ka ike?   
\q1
\v 21 I hoike aku ai au ia oe i ka oiaio o ka olelo pololei, I hai pololei aku oe i ka poe i hoounaia mai ia oe.   
\b  
\q1
\v 22 Mai kaili wale oe i ka ka mea ilihune no kona ilihune ana; Aole hoi e hookaumaha i ka mea nele ma kahi o ka ipuka:   
\q1
\v 23 No ka mea, na Iehova e hooponopono no lakou, E hao mai oia i ka uhane o ka poe i hao aku ia lakou.   
\b  
\q1
\v 24 Mai hoolauna aku oe me ka mea huhu, A, me ke kanaka inaina hoi, mai hele pu oe;   
\q1
\v 25 O ao iho oe i kona mau aoao, A loaa i kou uhane ka hihia.   
\b  
\q1
\v 26 Mai hui ae oe me ka poe pai aku i ka lima; Aole hoi me ka poe panai no ka aie:   
\q1
\v 27 Ina aole au mea e hookaa aku ai, No ke aha la e laweia aku ai kou wahi moe mailalo aku ou?   
\b  
\q1
\v 28 Mai honeenee oe i na mokuna aina kahiko, Na mea a kou poe kupuna i hoonoho ai.   
\b  
\q1
\v 29 Ua ike anei oe i ke kanaka miki ma kana hana? E ku no ia imua o na'lii, Aole oia e ku imua o ka poe naaupo.   
\c 23  
\b  
\q1
\v 1 I KOU noho iho ana e ai pu me ke alii, E noonoo pono i na mea imua ou:   
\q1
\v 2 A e kau i ka pahi ma kahi i moni ai, Ke pololi oe.   
\q1
\v 3 Aka, mai iini aku oe i kana mau mea ono; He wahi ni hoopunipuni no ia.   
\b  
\q1
\v 4 Mai hooikaika i waiwai ai; E hoole i kou naauao iho.   
\q1
\v 5 E kau anei oe i kou mau maka ma ka mea e ole ana? No ka mea, e hana io no ia mea i mau eheu nona iho; Me he aeto la e lele aku ai i ka lewa.   
\b  
\q1
\v 6 Mai ai oe i ka ai a ka mea maka ino; Mai iini aku oe i kana mau mea ono;   
\q1
\v 7 No ka mea, e like me ia i noonoo ai ma kona naau, pela no ia; E ai oe, ea, a e inu oe, wahi ana ia oe, Aka, aole me oe kona naau.   
\q1
\v 8 O ka mamala ai au i moni iho ai e luai hou aku oe; A e lilo wale kau mau olelo oluolu.   
\b  
\q1
\v 9 Mai hai aku oe i na pepeiao o ka mea lapuwale; No ka mea, e hoowahawaha oia i ka pololei o kau olelo.   
\b  
\q1
\v 10 Mai hooneenee ae oe i na mokuna aina kahiko; Ma na kihapai o ka poe makua ole, mai komo oe.   
\q1
\v 11 No ka mea, o ka lakou Hoola he mana no kona; Nana no e hooponopono iwaena o lakou a me oe.   
\q1
\v 12 E haliu ae i kou naau i ke aoia mai, A me kou mau pepeiao hoi i na olelo e naauao ai.   
\b  
\q1
\v 13 Mai waiho oe i ka hooponopono ana i ke keiki; No ka mea, ina e haua oe ia ia me ka laau, aole ia e make.   
\q1
\v 14 E haua oe ia ia me ka laau, A e hoopakele i kona uhane i ka lua.   
\b  
\q1
\v 15 E kuu keiki e, ina e naauao kou naau, E hauoli io no ka naau o'u:   
\q1
\v 16 E olioli io ko'u mau puhaka, Ke hai aku kou mau lehelehe i na mea pololei.   
\b  
\q1
\v 17 Mai huahua kou naau i ka poe hewa; Aka, e noho mau oe me ka makau ia Iehova a po ka la.   
\q1
\v 18 No ka mea, e hiki io mai no ka hope; A e pio ole ana no kou manaolana.   
\q1
\v 19 E hoolohe mai oe, e ka'u keiki, e hoonaauao iho, E hoopololei i kou naau ma ke ala.   
\q1
\v 20 Mai noho pu oe me ka poe inu waina; Me ka poe hoopalupalu i ko lakou kino iho.   
\q1
\v 21 No ka mea, o ka mea ona a me ka mea pakela ai, e ilihune auanei oia; A no ka palaualelo e komo kekahi i na weluwelu.   
\b  
\q1
\v 22 E hoolohe i kou makuakane ka mea nana mai oe; Mai hoowahawaha oe i ka luwahine ana o kou makuwahine.   
\q1
\v 23 E kuai lilo mai i ka oiaio, mai kuai lilo aku; I ka naauao hoi a me ke aoia mai a me ka ike.   
\b  
\q1
\v 24 E hauoli nui ka makuakane o ka mea pono; O ka mea i hanau mai uana ke keiki naauao, he olioli no kona.   
\q1
\v 25 E hauoli no kou makuakane a me kou makuwahine, E olioli hoi ka mea nana oe i hanau mai.   
\b  
\q1
\v 26 E kuu keiki, e haawi mai ia'u i kou naau, E nana mai hoi kou mau maka i ko'u aoao.   
\q1
\v 27 No ka mea, he auwaha hohonu ka wahine hookamakama, He lua ino hoi ka wahine e.   
\q1
\v 28 Oia ka i hoohalua, me he powa la, Hoonui oia i ka lawehala ana iwaena o na kanaka.   
\b  
\q1
\v 29 Ia wai la ka uwe ana? Ia wai la ka poino? Ia wai la ka hakaka? Ia wai la ka nuku wale ana? Ia wai la na palapu loaa wale? Ia wai la na maka ulaula?   
\q1
\v 30 I ka poe e hoomau ana ma ka waina, I ka poe e hele ana e imi i ka waina i kawiliia.   
\q1
\v 31 Mai nana oe i ka waina i kona ulaula ana, I kona aleale ana ma ke kiaha, I kona hu ana a maikai.   
\q1
\v 32 Mahope iho, e nahu mai me he nahesa la, A e pa mai me he moonihoawa la.   
\q1
\v 33 E nana auanei kou maka i na wahine e, A e hai aku kou naau i na mea ino.   
\q1
\v 34 E lilo ana oe me he mea la i moe iho mawaena konu o ka moana, E like hoi me ka mea i hoomoe ia ia iho ma kahi oioi loa o ke kia moku.   
\q1
\v 35 Pepehi mai lakou ia'u, aole au i eha, Hahaua mai lakou ia'u, aole au i ike iho: Ahea la au e ala'i? E imi hou aku no au ia mea.   
\c 24  
\b  
\q1
\v 1 MAI kuko oe i ka aoao o na kanaka hewa, Aole makemake hoi e noho pu me lakou.   
\q1
\v 2 No ka mea, noonoo ae la ko lakou naau i ka mea e make ai, A no ka ino hoi ko lakou lehelehe e kamailio ai.   
\b  
\q1
\v 3 Ma ke akamai i kukuluia'i ka hale, Ma ka naauao hoi ia i hookupaaia'i.   
\q1
\v 4 Na ka ike e hoopihaia'i na keena, I na waiwai a pau, he maikai no a he nani hoi.   
\b  
\q1
\v 5 O ke kanaka naauao, he ikaika no ia; E mahuahua ana no ka ikaika o ke kanaka ike.   
\q1
\v 6 No ka mea, ma ka noonoo nui oe e kaua aku ai, A he ola no ma ka nui o ka poe kukakuka pu.   
\b  
\q1
\v 7 He kiekie loa ka naauao maluna o ka mea naaupo; Aole e oaka kona waha ma ka ipuka.   
\b  
\q1
\v 8 O ka mea noonoo e hana hewa aku, E kapaia'ku ia he mea hana kolohe.   
\q1
\v 9 O ka manao lapuwale, he hewa ia; A he hoopailua i na kanaka ka mea hoowahawaha.   
\b  
\q1
\v 10 Ina pauaho oe i kou la popilikia, Uuku wale no kou ikaika.   
\b  
\q1
\v 11 Ina e hookaulua oe e hoopakele i ka poe i hana paa ia e make, A me ka poe e kokoke ana i ka pepehiia mai;   
\q1
\v 12 Ina e i ae oe, E, aole makou i ike; Aole anei e noonoo mai ka mea nana e kaupaona na naau? A o ka mea hoi nana e malama i ka uhane, aole anei oia e ike? Aole anei oia e hoopai i ke kanaka e like me kana hana ana?   
\b  
\q1
\v 13 E kuu keiki, e ai iho oe i ka meli, no ka mea, he maikai ia; A i ka waihona meli hoi he ono ia i kou waha;   
\q1
\v 14 Pela hoi ka ike ana i ka naauao i kou uhane; A i loaa ia oe, alaila he hope, A o kou manaolana aole ia e poho.   
\b  
\q1
\v 15 Mai hoohalua, e ke kanaka hewa, ma ka hale o ka mea pono; Mai powa aku oe ma kona wahi e moe ai.   
\q1
\v 16 No ka mea, ehiku no ka haule ana o ka mea pono, a ala hou mai no; O ka poe hewa, e hina no lakou iloko o ka poino.   
\b  
\q1
\v 17 I ka haule ana o kou euemi, mai hauoli oe, I koua hina ana hoi mai olioli kou naau;   
\q1
\v 18 O ike mai Iehova he hewa ia i kona mau maka, A e hoohuli oia i kona huhu mai ona aku.   
\b  
\q1
\v 19 Mai ukiuki oe no ka poe hewa, Aole hoi e kuko i ka noho ana o ka poe hana ino.   
\q1
\v 20 No ka mea, aohe uku maikai no ka mea hewa; O ke kukui o ka poe hewa, e pio ana no ia.   
\b  
\q1
\v 21 E kuu keiki, e makau aku ia Iehova, a me ke alii; Me ka poe lolelua ka naau, mai launa aku.   
\q1
\v 22 No ka mea, e hiki wawe mai ko lakou poino; A o ka make ana o laua a elua, owai ka mea ike aku?   
\b  
\q1
\v 23 Na ka poe naauao hoi keia mau mea: O ka manao kapakahi ma ka hookolokolo ana, aole i pono ia.   
\q1
\v 24 O ka mea olelo aku i ka mea hewa, He pono no oe; E hoino aku no na kanaka ia ia, E hoowahawaha hoi na lahuikanaka ia ia.   
\q1
\v 25 Aka, he oluolu ko ka poe i ao aku, E hiki mai hoi ia lakou ka pomaikai io.   
\q1
\v 26 E honiia'ku na lehelehe O ka mea olelo aku ma ka pololei.   
\b  
\q1
\v 27 Muwaho e hoomakaukau ai i kau hana, A e hooponopono nou iho ma ke kula; A mahope iho, e kukula ae i kou hale.   
\b  
\q1
\v 28 Mai liio hala ole oe i hoike ku e i kou hoanoho; Aole hoi e hoopunipuni me kou mau lehelehe.   
\q1
\v 29 Mai olelo oe, E like me ia i hana mai ai ia'u, pela au e hana aku ai ia ia; E hoopai aku au i ke kanaka e like me kana hana ana.   
\b  
\q1
\v 30 Ma ke kihapai o ka mea palaualelo i maalo ai au, Ma ka pawaina hoi o ke Kanaka noonoo ole:   
\q1
\v 31 Aia hoi, ulu paapu ae la ka puakala, Uhi mai la maluna ona na kakalaioa, O kona pa pohaku hoi, ua hiolo iho la ia.   
\q1
\v 32 Nana aku la au, halalo iho la ko'u naau; Ike iho la au, a loaa ia'u ke aoia mai.   
\q1
\v 33 He moe iki ae, he hiamoe iki ae, He pelu hou iki ae i na lima a hiamoe;   
\q1
\v 34 A e hiki mai kou ilihune me he kanaka hele la, A me kou nele e like me ke kanaka kaua.   
\c 25  
\b  
\q1
\v 1 EIA no hoi na olelo akamai a Solomona, na na kanaka o Hezekia ke alii o ka Iuda i kakau hou iho.   
\b  
\q1
\v 2 He mea nani i ke Akua ke huna i kekahi mea; He mea nani hoi i na'lii ke imi aku.   
\q1
\v 3 O ka lani he kiekie, o ka honua he hohonu, A o ka naau o na alii, he mau mea ike ole ia.   
\q1
\v 4 E hookaawale aku i ka lepo o ke kala, A e puka mai kekahi ipu no ka mea hoohehee.   
\q1
\v 5 E hookaawale aku i ka mea hewa mai ke alo aku o ke alii, A e paa iho no kona nohoalii ma ka pono.   
\q1
\v 6 Mai hookiekie ae imua o ke alii, A ma kahi o ka poe koikoi mai ku ae oe.   
\q1
\v 7 No ka mea, he maikai ke olelo mai ia oe, e pii mai oe ia nei, Mamua o kou hoohaahaaia mai imua o ke alii, Ka mea a kou mau maka i nana aku ai.   
\b  
\q1
\v 8 Mai hiki wawe aku oe i ka hakaka, No ka mea, heaha kau e hana'i mahope aku, Ke hoohilahila mai kou hoanoho ia oe?   
\q1
\v 9 Me kou hoanoho oe e hoopaapaa aku ai, Mai hoike aku i ka mea ia hai;   
\q1
\v 10 O henehene mai ia oe ka mea lohe, Aole e pau ka olelo ino mai nou.   
\b  
\q1
\v 11 O na ohia gula ma na kii kala, Oia ka huaolelo i oleloia i ka wa pono.   
\q1
\v 12 He apo pepeiao gula, a he mea gula maemae e nani ai, Oia ka hoonaauao ana i ka pepeiao hoolohe.   
\q1
\v 13 E like me ke anu o ka hau i ka wa e ohi ai, Pela ka elele oiaio i ka mea nana ia e hoounauna aku; Hooluolu oia i ka uhane o kona mau haku.   
\q1
\v 14 O na ao a me ka makani ua ole, Oia ke kanaka e haanui ana no ka makana hoopunipuni.   
\q1
\v 15 Ma ka hoomanawanui i hoohuliia ai ke alii, O ke elelo akahai ke uhai aku i ka iwi.   
\q1
\v 16 Ua loaa anei ia oe ka meli? e ai iho e like me ka pono nou, O hookuku oe ia mea a e luai aku ia.   
\q1
\v 17 Ua oki kou wawae i ka hele i ka hale o kou hoanoho, O luhi oia ia oe a e inaina mai no hoi.   
\q1
\v 18 O ka hamare a me ka pahikaua a me ka pua oioi, Oia ke kanaka hoike wahahee no kona hoanoho.   
\q1
\v 19 O ka niho i haiia, o ka wawae okupe, Oia ka paulele ana i ka mea lohe ole i ka wa popilikia.   
\q1
\v 20 O ka mea lawe aku i ke kapa i ka wa anu, A o ka vinega hoi ma ka paakai, Oia ke mele aku i ke mele i ka mea naau kaumaha.   
\q1
\v 21 Ina pololi kou enemi, e haawi aku ia ia i ka ai, Ina i makewai ia, e hoohainu ia ia i ka wai;   
\q1
\v 22 Pela no oe e kau aku ai i na nanahu wela maluna o kona poo, A na Iehova oe e uku mai.   
\q1
\v 23 O ka makani akau, pale aku ia i ka ua, A o ka maka huhu hoi i ke elelo akiaki.   
\q1
\v 24 E aho ka noho ana ma kahi kihi oluna o ka hale, Aole me ka wahine nuku wale ma ka hale kanaka.   
\q1
\v 25 O ka wai huihui i ka mea makewai la, Oia ka olelo hooluolu mai ka aina loihi e mai.   
\q1
\v 26 He punawai lepolepo, a he waipuna pilopilo, Oia ka mea pono e haule ana imua o ka mea hewa.   
\q1
\v 27 O ka ai ana i ka meli a nui, aole ia he maikai, Pela hoi ka imi ana i ke kaulana nui loa.   
\q1
\v 28 O ke kulanakauhale hiolo, aohe pa, Oia ke kanaka hoomalu ole i kona uhane iho.   
\c 26  
\b  
\q1
\v 1 E LIKE me ka hau i ke kau, E like me ka ua i ka wa e ohi ai, Pela i ku ole ai ka hanohano i ka mea lapuwale.   
\q1
\v 2 E like me ka zepora e auwana ana, E like me ka derora e lele ana, Pela ka poino, aole ia e hiki wale mai.   
\q1
\v 3 I mea hahau no ka lio, i kaulawaha no ka hoki, I laau hahau hoi no ke kua o na mea lapuwale.   
\q1
\v 4 Mai olelo aku i ka mea lapuwale e like me kona naaupo ana, O like oe me ia.   
\q1
\v 5 E olelo no i ka mea lapuwale e like me kona naaupo ana, O naauao oia i kona maka iho.   
\q1
\v 6 O ka mea oki ne i na wawae a loaa ia ia ka poino, Oia ka i kauoha aku i na manao ma ka lima o ka mea lapuwale.   
\q1
\v 7 E lawe aku i na wawae o ka mea oopa, A me ka olelonane mailoko ae o ka waha o ka poe lapuwale.   
\q1
\v 8 E like me ka nakii ana i ka iliili ma ka maa a paa, Pela ka haawi ana i ka hanohano no ka mea lapuwale.   
\q1
\v 9 O ka mea oioi e o ana i ka lima o ka mea ona, Oia ka olelonane ma ka waha o ka poe lapuwale.   
\q1
\v 10 O ka mea nui nana i hana na mea a pau, Oia ka mea nana e hoopai i ka mea lapuwale a e hoopai hoi i ka poe lawehala.   
\q1
\v 11 E like me ka ilio i hoi hou aku i kona luai, Pela ka mea naaupo e hoi hou ana i kona lapuwale.   
\q1
\v 12 Ua ike anei oe i ke kanaka naauao i kona manao iho? He lana ka manao no ka mea naaupo aole nona.   
\q1
\v 13 I ae la ka mea palaualelo, He liona ma ke ala, He liona iwaena o ke kuamoo.   
\q1
\v 14 O ka luli ana o ke pani ma kona ami, Oia ka mea palaualelo ma kona moena.   
\q1
\v 15 Hookomo ka mea palaualelo i kona lima iloko o ke pa, A he mea kaumaha ia ia ke hapai hou ae ia i kona waha.   
\q1
\v 16 He naauao loa ka mea pulaualelo i kona manao iho, Mamua o na kanaka ehiku e hoike ana i ka oiaio.   
\q1
\v 17 O ka mea lalau i ka ilio ma na pepeiao, Oia ka mea e maalo ana, a lawe pu i ka hakaka pili ole ia ia.   
\q1
\v 18 E like me ka mea e hooleilei ana i na ihe wela, a me na pua a me ka make;   
\q1
\v 19 Pela ke kanaka e hoopunipuni ana i kona hoanoho, I ae la hoi, Aole anei he paani ko'u?   
\q1
\v 20 I ole ka wahie, e pio no ke ahi, I ole ka mea holoholo olelo, pau ka hakaka.   
\q1
\v 21 O ka nanahu i na nanahu wela, a me ka wahie i ke ahi, Oia ke kanaka huhu e hookonokono ana i ka hakaka.   
\q1
\v 22 O na olelo a ka mea holoholo olelo, Ua like no ia me na olelo paani, Komo ilalo nae ia a iloko lilo o ka opu.   
\q1
\v 23 O ke kala maemae ole i hoopiliia me kahi pohue, Oia na lehelehe e alohaloha ana me ka naau ino.   
\q1
\v 24 O ka mea inaina, huna oia ma kona mau lehelehe, A iloko ona iho i waiho ai oia i ka hoopunipuni.   
\q1
\v 25 Ina i oluolu kana olelo, mai manaoio aku ia ia; No ka mea, ehiku mau mea ino iloko o kona naau.   
\q1
\v 26 O ka mea i hunaia kona inaina i ka hoopunipuni, E hoikeia kona hewa imua o ke anaina kanaka.   
\q1
\v 27 O ka mea eli i ka lua, oia ke haule ilaila; O ka mea olokaa i ka pohaku, e hoi hou mai ia maluna ona.   
\q1
\v 28 O ke elelo wahahee, oia ke inaina aku i ka mea poino malaila; O ka waha malimali, oia ke hana i ka mea e make ai.   
\c 27  
\b  
\q1
\v 1 MAI olioli wale oe no ka la apopo, No ka mea, aole oe i ike i ka mea a kekahi la e hoopuka mai ai.   
\q1
\v 2 Na ka mea e e hoomaikai mai ia oe, aole na kou waha iho; Na ka malihini hoi, aole na kou mau lehelehe iho.   
\q1
\v 3 Koikoi ka pohaku, kaumaha hoi ke one; Aka, o ka inaina o ka mea naaupo, ua kaumaha ia mamua o ia mau mea elua.   
\q1
\v 4 He aloha ole ka inaina, he mea make ka huhu, Owai la hoi e hiki ke ku imua o ka huahua?   
\q1
\v 5 Maikai ke ao maopopo ana, Mamua o ke aloha i hunaia.   
\q1
\v 6 Maikai ka hoehaia mai e ka hoaaloha, He nunui hoi ka honi ana o ka enemi.   
\q1
\v 7 Hehi no ka mea maona i ka waihona meli; Aka, i ka mea pololi la, ua ono na mea awaawa a pau.   
\q1
\v 8 E like me ka manu i auwana ae mai kona punana aku, Pela ke kanaka e auwana ana mai kona wahi aku.   
\q1
\v 9 O ka aila a me ka mea ala, hoohauoli ia i ka naau; Hooluolu hoi ka hoaaloha o kekahi mea ma ka olelo oiaio.   
\q1
\v 10 O kou hoalauna a me ka hoalauna o kou makuakane, mai haalele oe; Aole hoi e komo aku i ka hale o kou hoahanau i kou manawa popilikia; Maikai ka mea e noho kokoke ana, mamua o ka hoahanau ma kahi loihi aku.   
\b  
\q1
\v 11 E kuu keiki e, e naauao hoi oe i olioli ko'u naau, I olelo aku au i ka mea hoino mai ia'u.   
\q1
\v 12 O ka mea noonoo la, ike e oia mamua i ka poino a huna ia ia iho; Hele wale aku hoi ka poe nanea a hihia iho la.   
\q1
\v 13 E lawe i ka aahu o ka mea nana e hoopanai no ka malihini, E lawe hoi i uku nona no ka wahine e.   
\q1
\v 14 O ka mea hoomaikai aku i kona hoanoho me ka leo nui, I kona ala ana i ke kakahiaka nui, E lilo ia i mea poino nona.   
\q1
\v 15 O ke kulu mau ana i ka la ua, A me ka wahine nuku wale, na like.   
\q1
\v 16 O ka mea hoonalowale i kana, hoonalowale no ia i ka makani, A me ka aila o kona lima akau e pa mai ana.   
\q1
\v 17 Hookala kahi mea hao i kekahi mea hao, Hookala hoi ke kanaka i ka maka o kona hoalauna.   
\q1
\v 18 O ka mea malama i ka laau fiku, oia ke ai i kona hua; O ka mea malama hoi i kona haku e hoonaniia oia.   
\q1
\v 19 Ma ka wai, he helehelena e ku ana i kahi helehelena, Pela hoi ka naau kanaka i kekahi kanaka.   
\q1
\v 20 O ka lua a me ka hohonu, aole i piha, A o na maka o ke kanaka aole no e maona.   
\q1
\v 21 He ipu hoohehee no ke kala, a he kapuahi no ke gula, Pela ke kanaka imua o kona mahaloia mai.   
\q1
\v 22 Ina e kui oe i ka mea naaupo ma ka papawiliai, Oia pu me ka ai i ka pohaku kui, Aole loa e hemo ae kona naaupo ana mai ona aku.   
\b  
\q1
\v 23 E ike pono oe i ke ano o kau poe hipa, E nana hoi i ke ano o kau poe holoholona;   
\q1
\v 24 No ka mea, aole e mau ana ka waiwai: O ka papale alii hoi, oia mau anei ia i na hanauna a pau?   
\q1
\v 25 Kupu mai ka weuweu, ikea mai ka mauu, A e ohiia ana ka mea ulu o ka mauna.   
\q1
\v 26 O na keikihipa no kou kapa komo, O ka poe kao kane ke kumukuai no ka aina.   
\q1
\v 27 A e nui ka waiu kao no kau ai ana, No ka ai ana hoi o ko ka hale ou, A he ola no kou poe kauwawahine.   
\c 28  
\b  
\q1
\v 1 HOOHEE wale ka mea hewa, aohe mea e hahai ana; O ka poe pono hoi, wiwo ole lakou me he liona la.   
\q1
\v 2 No ka hewa o ka aina, nui no kolaila poe alii; A ma ke kanaka noonoo a ike hoi e paa loihi ana no ia.   
\q1
\v 3 O ke kanaka ilihune e hookaumaha ana i ka poe ilihune, Oia ka ua e hoopau ana i ka ai a pau.   
\q1
\v 4 O ka poe haalele i ke kanawai, hoomaikai no lakou i ka mea hewa: O ka poe malama hoi i ke kanawai, ku e aku no i ua poe la.   
\q1
\v 5 Aole i ike ka poe aia i ka hoopono; A o ka poe imi ia Iehova, ike no i na mea a pau.   
\q1
\v 6 E aho ka mea ilihune ke hele oia ma ka pololei, I ka mea waiwai i hookekee i kona aoao.   
\q1
\v 7 O ka mea malama i ke kanawai, he keiki naauao ia; O ka hoa no ka poe hookai wale, oia ka i hoohilahila i kona makuakane.   
\q1
\v 8 O ka mea hoonui i kona waiwai ma ka uku kuala a me ke kaili wale, E hooiliili oia ia mea na ka mea e aloha aku i ka poe ilihune.   
\q1
\v 9 O ka mea haliu aku i kona pepeiao aole hoolono i ke kanawai, E hoopailuaia kana pule.   
\q1
\v 10 O ka mea kai hewa aku i ka poe pololei ma ka aoao hewa, Ma kona lua iho oia e haule ai; A o ka poe pololei hoi, e ili mai ka maikai no lakou.   
\q1
\v 11 Ua naauao no ke kanaka waiwai i kona manao iho; Aka, o ka mea ilihune a naauao hoi, oia ka i ike aku ia ia.   
\q1
\v 12 I ka hauoli ana o ka poe pono, nui ka hanohano; A i ke ku ana'e o ka poe hewa, ua hunaia ke kanaka.   
\q1
\v 13 O ka mea huna i kona hewa iho, aole oia e pomaikai; Aka, o ka mea hooia a haalele hoi, e alohaia mai oia,   
\q1
\v 14 Pomaikai ke kanaka ke mau aku kona makau; O ka mea hoopaakiki i kona naau, e haule oia i ka popilikia.   
\q1
\v 15 O ka liona uwo a me ka bea holoholo, Oia ke alii hewa maluna o na kanaka ilihune.   
\q1
\v 16 O ke alii naauao ole, nui kona hookaumaha ana; O ka mea hoowahawaha i ka makee waiwai, e loihi no kona mau la.   
\q1
\v 17 O ke kanaka hewa i ke koko o kekahi, E holo oia i ka lua; mai keakea kekahi ia ia.   
\q1
\v 18 O ka mea hele pololei e ola oia; O ka mea hookekee i kona aoao, e haule koke no ia.   
\q1
\v 19 O ka mea mahi i ka aina e maona oia i ka ai; O ka mea hoopili mea ai mahope o ka poe lapuwale e piha oia i ka ilihune.   
\q1
\v 20 O ke kanaka hooiaio, nui wale kona mau mea e pomaikai ai; O ka mea holo kiki mahope o ka waiwai, aole e ole kona hala.   
\q1
\v 21 O ka manao ana i ko ke kanaka kino, aole ia he maikai; No kahi apana ai e lawehala no ua kanaka la.   
\q1
\v 22 O ka mea hooikaika ma ka waiwai, he maka ino kona, Aole oia e ike o ka ilihune kana mea e loaa ai.   
\q1
\v 23 O ka mea ao aku i ke kanaka, mahope iho e loaa ia ia ka lokomaikaiia mai, Mamua o ka mea malimali me kona alelo.   
\q1
\v 24 O ke mea kaili wale i ka kona makuakane a me ka kona makuwahine, Me ka i ana ae, Aole ia he hewa, Oia ka hoa no ka pepehi kanaka.   
\q1
\v 25 O ka mea i haaheo ka naau, oia ka i hookonokono i ka hakaka; O ka mea paulele ia Iehova e lako loa oia.   
\q1
\v 26 O ka mea paulele i kona naau iho, oia ka mea naaupo: O ka mea hele ma ka naauao, e hoopakeleia oia.   
\q1
\v 27 O ka mea haawi wale na ka mea ilihune, aole oia e nele; A o ka mea i uhi ae i kona mau maka, e nui kona hoinoia mai.   
\q1
\v 28 I ke ku ana o ka poe hewa, ua huna ke kanaka ia ia iho; A make lakou, alaila mahuahua ka poe pono.   
\c 29  
\b  
\q1
\v 1 O KE kanaka i ao pinepine ia a hoopaakiki hoi i kona a-i, E make koke no ia, aole mea e ola'i.   
\q1
\v 2 I ka lehulehu ana e ka poe pono, hauoli na kanaka; A i ke alii ana o ka mea hewa, ulono ae la na kanaka.   
\q1
\v 3 O ke kanaka e ake ana i ka naauao, hoohauoli oia i kona makuakane; O ka mea launa aku me na wahine hookamakama, hokai wale aku oia i kana waiwai.   
\q1
\v 4 Ma ka hoopono, e hooku paa ai ke alii i ka aina; O ka mea lawe i na makana, oia ke hoohiolo iho.   
\q1
\v 5 O ke kanaka malimali aku i kona hoanoho, Oia ka i hohola i ka hei no kona mau wawae.   
\q1
\v 6 Puniheiia ke kanaka hewa ma kona hewa iho; Hauoli no ka mea pono me ka olioli.   
\q1
\v 7 Ike aku no ka mea pono i ka pilikia o ka poe ilihune; A o ka mea hewa, aole ona manao e ike aku.   
\q1
\v 8 O ka poe hoowahawaha, hoohihia lakou i ke kulanakauhale; O ka poe naauao, pale ae lakou i ka huhu.   
\q1
\v 9 Ina e hoopaapaa ke kanaka naauao, me ke kanaka hewa, He huhu paha kona, he akaaka paha, aohe oluolu iki.   
\q1
\v 10 O ka poe punikoko, inaina aku lakou i ka mea pololei; Imi hoi ka poe hoopono i ke ola nona.   
\q1
\v 11 Hoopuka mai ka mea naaupo i kona manao a pau; Noho malie hoi ka mea naauao a mahope aku.   
\q1
\v 12 Ina e haliu ae ke alii i ka olelo wahahee, Pau loa kana poe kauwa i ka hana hewa.   
\q1
\v 13 O ka mea ilihune, a o ke kanaka hookaumaha e halawai pu laua; Na Iehova e hoomalamalama i na maka o laua a elua.   
\q1
\v 14 O ke alii e hooponopono ana i ka poe ilihune ma ka oiaio, E paa mau loa no kona nohoalii.   
\q1
\v 15 O ka laau hahau, a me ke aoia mai, haawi no i ka naauao; A o ko keiki waiho wale ia, oia ke hoohilahila i kona makuwahine.   
\q1
\v 16 I ka mahuahua ana o ka poe howa, mahuahua no ke kolohe; E ike hoi ka poe pono i ko lakau haule ana.   
\q1
\v 17 E haua i kau keiki, a nana oe e hoomaha mai; E lilo no ia i mea e olioli ai kou uhane.   
\q1
\v 18 I ole ke aoia mai, hele hewa na kanaka; A o ka mea malama i ke kanawai, pomaikai oia.   
\q1
\v 19 Ma ka olelo wale ana, aole e aoia mai ke kauwa; No ka mea ina paha i ike, aole ia e pane mai,   
\q1
\v 20 Ua ike anei oe i ke kanaka wikiwiki i ka olelo? Ua lana ka manao no ka mea naaupo aole nona.   
\q1
\v 21 O ka mea hoohiwahiwa i kana kauwa mai kona wa uuku mai, Mahope iho, e lilo oia i keiki nana.   
\q1
\v 22 O ke kanaka huhu, oia ka i hookonokono i ka hakaka, A o ka mea inaina wale, nui ae la kona hewa.   
\q1
\v 23 O ka haaheo o ke kanaka, oia ka mea uana ia e hoohaahaa iho; E pili hoi ka hanohano i ka mea haahaa ka naau.   
\q1
\v 24 O ka mea lawe pu me ka aihue, inaina aku oia i kona uhane iho; Ua lohe oia i ka hailiili, aole hoi i hoike aku.   
\q1
\v 25 O ka makau i ke kanaka, he mea ia e hihia ai; O ka mea paulele ia Iehova ua palekana oia.   
\q1
\v 26 Nui ka poe imi i ka lokomaikaiia mai e ke alii, Aka, no Iehova mai ka hoopono ana i ke kanaka.   
\q1
\v 27 He mea hoopailua i ka poe pono ke kanaka hoopono ole; He mea hoopailua hoi i ka mea hewa, ka mea pololei ma kona aoao.   
\c 30  
\b  
\q1
\v 1 HE mau wahi olelo a Agura ke keiki a Iake. He wanana; na ke kanaka i hoike mai ia Itiela; ia Itiela laua me Ukala.   
\q1
\v 2 Owau ka mea hupo loa o na kanaka, Aole o'u wahi noonoo kanaka.   
\q1
\v 3 Aole i loaa ia u ka naauao, Aole hoi o'u ike i ka Mea hemolele.   
\q1
\v 4 Owai ka mea i pii ae i ka lani, a i iho mai hoi? Owai ka mea i hooiliili i ka makani ma kona lima? Owai ka mea i hoopaa i na wai ma kona aahu? Owai ka mea i hoonoho i na welelau a pau o ka honua? Owai hoi kona inoa, owai ka inoa o kana keiki? E hoike mai paha oe.   
\b  
\q1
\v 5 Pau loa na huaolelo a ke Akua i ka maemae; Oia ka palekaua i ka poe paulele aku ia ia.   
\q1
\v 6 Mai hui ae oe i kekahi mea me kana mau huaolelo, O ao mai oia ia oe, a e lilo oe i mea wahahee.   
\b  
\q1
\v 7 Elua mau mea a'u i noi aku ai ia oe, Mai aua oe mamua o ko'u make ana.   
\q1
\v 8 O ka lapuwale, a o ka wahahee, E hookaawale ae mai o'u aku nei; Mai haawi mai ia'u i ka ilihune, aole hoi i ka waiwai; E hanai mai ia'u i ka ai ku pono no'u;   
\q1
\v 9 O hookuku ai au, a hoole aku hoi, Me ka i ana, Owai la o Iehova? O ilihune hoi au a aihue iho, A hoohiki ino i ka inoa o ko'u Akua.   
\b  
\q1
\v 10 Mai hoopii oe i ke kauwa imua o kona haku, O hooino mai oia ia oe, a e lilo oe i lawehala.   
\b  
\q1
\v 11 O kekahi hanauna, hoino no i ka makuakane, Aole hoi i hoomaikai i ka makuwahine.   
\q1
\v 12 O kekahi hanauna hoi, he maemae ia i ko lakou maka iho, Aole hoi i holoiia ka paumaele.   
\q1
\v 13 O kekahi hanauna, hookano loa na maka o lakou! Hookiekie hoi na lihilihi o lakou.   
\q1
\v 14 O kekahi hanauna, he mau pahikaua ko lakou niho, He mau pahi hoi ko lakou mau kui. E ai ana i ka poe ilihune mai ka honua aku, A o ka poe nele hoi iwaena o na kanaka.   
\b  
\q1
\v 15 He mau kaikamahine elua ka ka omokoko, E i ana, E ho mai, e ho mai, ea. Akolu no mea piha ole, Eha hoi, aole e olelo mai, Ua ana:   
\q1
\v 16 O ka lua, o ka opu pa; A o ka honua i mauu ole i ka wai; A o ke ahi, aole ana olelo mai, Ua nui.   
\q1
\v 17 O ka maka i hoowahawaha i kona makuakane, A hoole hoi aole e malama i kona makuwahine, E kiko iho ka poe koraka o ke awawa ia mea, A e ai iho no ka poe aito opiopio.   
\b  
\q1
\v 18 Ekolu mau mea kupanaha loa ia'u, Eha hoi, aole au i ike iho.   
\q1
\v 19 O ka aoao o ka aito ma ka lewa; O ka aoao o ka nahesa maluna o ka pohaku; O ka aoao o ka moku iwaena o ka moana; A o ka aoao o ke kanaka me ka wahine puupaa.   
\q1
\v 20 Peneia ka aoao o ka wahine hookamakama, Ai iho la oia a holoi i kona nuku, A olelo ae, Aole au i hana hewa.   
\b  
\q1
\v 21 Ekolu mau mea e haunaele ai ka honua, Eha hoi e hiki ole ai ke hoomanawanui:   
\q1
\v 22 O ke kauwa ke lilo i alii; O ka mea lapuwale ke maona i ka ai;   
\q1
\v 23 O ka wahine huhu wale ke mareia oia; A o ke kauwawahine he hooilina o kona hakuwahine.   
\b  
\q1
\v 24 Eha mau mea liilii loa ma ka honua nei, A ua akamai loa no nae:   
\q1
\v 25 O ka poe anonanona, he poe ikaika ole lakou, Hoomakaukau no nae i ke kau i ka lakou ai;   
\q1
\v 26 O ka poe rabita, he poe nawaliwali lakou, Ma na pohaku hoi i hana'i i ko lakou mau hale;   
\q1
\v 27 O ka poe uhini, aole o lakou alii, Hele papa no hoi lakou.   
\q1
\v 28 O ka moo, lalau no oia me kona mau lima, Aia no ia ma na hale hanohano o ke alii.   
\b  
\q1
\v 29 Ekolu mau mea, i maikai ka hele ana, Eha hoi i maikai ke hele ae.   
\q1
\v 30 O ka liona ka mea ikaika loa o na holoholona, Aole hoi oia e huli ae mai ke alo aku o lakou a pau;   
\q1
\v 31 O ka ilio hahai, a o ke kao kane hoi, A o ke alii, hiki ole ke ku e ia ia.   
\b  
\q1
\v 32 Ina he lapuwale oe i kou hookiekie ana, Ina paha he manao ino kou, e kau ana ka lima ma ka waha.   
\q1
\v 33 Ma ka hooluliluli ana i ka waiu e puka mai ai ka bata, Ma ka uwi ana i ka ihu e kahe mai ai ke koko; A ma ka hooioi ana i ka huhu e puka mai ai hoi ka hakaka.   
\c 31  
\b  
\q1
\v 1 NA olelo a Lemuela ke alii, ka wanana a kona makuwahine i ao mai ai ia ia.   
\b  
\q1
\v 2 Heaha, e ka'u keiki? Heaha, e ke keiki a ko'u opu? Heaha hoi, e ke keiki no ko'u hoohiki ana?   
\q1
\v 3 Mai haawi aku i kou ikaika i na wahine, Aole hoi i kou aoao i ka mea e make ai na alii.   
\q1
\v 4 Aole na na'lii, e Lemuela e, Aole na na'lii e inu i ka waina, Aole hoi na ka poe aialo e inu i ka mea ikaika;   
\q1
\v 5 O inu lakou a hoopoina i ke kanawai, A kapae i ka pono o ka poe pilikia.   
\q1
\v 6 E haawi i ka mea ikaika i ka mea e make ana, A i ka waina hoi i ka poe i kaumaha ka naau.   
\q1
\v 7 E inu iho oia a o hoopoina i kona ilihune, Aole hoi e hoomanao hou ae i kona mea kaumaha.   
\q1
\v 8 E oaka oe i kou waha no ka mea kuli, No ka hoopono i na keiki makua ole a pau.   
\q1
\v 9 E oaka oe i kou waha, e hooponopono ma ka pololei, E imi hoi i ka pono no ka poe ilihune a me ka mea nele.   
\b  
\q1
\v 10 Owai ka mea i loaa ia ia ka wahine noho pono? He waiwai oia i oi aku i ko na momi.   
\q1
\v 11 Paulele ia ia ka naau o kana kane, Aole e nele oia i ka loaa ole.   
\q1
\v 12 He maikai no kana e hana'i ia ia aole hoi ho hewa, I na la a pau loa o kona ola ana.   
\q1
\v 13 Imi oia i ka huluhipa a me ke olona, Oluolu oia i ka hana me kona mau lima.   
\q1
\v 14 Ua like no ia me na moku kalepa, Mai kahi loihi e mai i loaa'i ia ia kana ai.   
\q1
\v 15 I ka wanaao, ala oia a haawi i ka ai na ko kona hale, A me ka mea e maona ai na kana poe kauwawahine.   
\q1
\v 16 Noonoo oia i ka mahinaai a kuai lilo mai; Me ka hua o kona mau lima, kanu iho no oia i ka malawaina.   
\q1
\v 17 Kaei oia i kona puhaka me ka ikaika, Hooikaika hoi oia i kona mau lima.   
\q1
\v 18 Hoao oia i kona waiwai i maikai ia; Aole i pio kona kukui i ka po.   
\q1
\v 19 O aku kona mau lima ma kahi e kau ai ke olona, Lalau kona mau lima i ka mea milo lope.   
\q1
\v 20 O aku oia i kona mau lima i ka poe nele; Kikoo oia i kona mau lima i ka poe ilihune.   
\q1
\v 21 Aole ona makau e ana ko kona hale; No ka mea, pau ko kona hale i ke komo kapa ulaula.   
\q1
\v 22 Hana oia i na kapa hoalii nona iho; O ke kilika a me ka mea ulaula, oia kona kahiko ana.   
\q1
\v 23 Ua ikeia kana kane ma na ipuka, I kona noho pu ana me na lunakahiko o ka aina.   
\q1
\v 24 Hana oia i ka lole olona maikai, a kuai aku; Haawi oia i na kaei i ka poe kalepa.   
\q1
\v 25 O ka ikaika, a o ka hanohano, oia kona kahiko ana; E hauoli oia i ka manawa mahope aku.   
\q1
\v 26 Oaka oia i kona waha ma ka naauao; A o ke aloha oia ke kanawai o kona alelo.   
\q1
\v 27 Kiai oia i ka hele ana o ko kona hale, A o ka ai no ka palaualelo, aole oia e ai iho.   
\q1
\v 28 Ku ae kana mau keiki a hoomaikai ia ia; O kana kane hoi, mahalo oia ia ia.   
\q1
\v 29 Nui na kaikamahine i hana pono, A ua oi aku oe mamua o lakou a pau.   
\q1
\v 30 He hoopunipuni ke alohaia mai, he mea ole ka maka maikai; O ka wahine hoi i makau ia Iehova, oia ke hiilaniia.   
\q1
\v 31 E haawi aku nana i ka hua o kona mau lima; O kana mau hana, oia ke hiilani ia ia ma na ipuka.   