\id MAT - Biblica® Open Kurdi Sorani Standard Version
\h مەتا
\toc1 مزگێنی بەپێی نووسینی مەتا
\toc2 مەتا
\toc3 مەتا
\mt1 مزگێنی بەپێی نووسینی مەتا
\c 1
\s1 بنەچەی عیسا
\m 
\v 1 ئەمە ڕەچەڵەکی عیسای مەسیحە، کوڕی داود، کوڕی ئیبراهیم:
\b
\li1 
\v 2 ئیبراهیم باوکی ئیسحاق بوو،
\li1 ئیسحاق باوکی یاقوب بوو،
\li1 یاقوب باوکی یەهودا و براکانی بوو،
\li1 
\v 3 یەهودا باوکی پێرێز و زەرەح بوو کە تامار دایکیان بوو،
\li1 پێرێز باوکی حەسرۆن بوو،
\li1 حەسرۆن باوکی ڕام\f + \fr 1:3 \ft یۆنانی: \tl ئارام‏\tl*، بەڵام لە زمانی عیبری پێی دەگوترێت (ڕام). بڕوانە \xt ڕائووس 4‏:19‏\xt*\ft ‏.‏\f* بوو،
\li1 
\v 4 ڕام باوکی عەمیناداب بوو،
\li1 عەمیناداب باوکی نەحشۆن بوو،
\li1 نەحشۆن باوکی سەلمۆن بوو،
\li1 
\v 5 سەلمۆن باوکی بۆعەز بوو کە ڕاحاب دایکی بوو،
\li1 بۆعەز باوکی عوبێد بوو کە ڕائووس دایکی بوو،
\li1 عوبێد باوکی یەسا بوو،
\li1 
\v 6 یەسا باوکی داودی پاشا بوو.
\b
\li1 داود باوکی سلێمان بوو لەو ژنەی کە پێشتر ژنی ئوریا\f + \fr 1:6 \ft دایکی سلێمان لەدوای کوژرانی ئوریا بووە ژنی داود.‏\f* بوو،
\li1 
\v 7 سلێمان باوکی ڕەحەڤەعام بوو،
\li1 ڕەحەڤەعام باوکی ئەبیا بوو،
\li1 ئەبیا باوکی ئاسا بوو،
\li1 
\v 8 ئاسا باوکی یەهۆشافات بوو،
\li1 یەهۆشافات باوکی یەهۆرام بوو،
\li1 یەهۆرام باوکی عوزیا بوو،
\li1 
\v 9 عوزیا باوکی یۆتام بوو،
\li1 یۆتام باوکی ئاحاز بوو،
\li1 ئاحاز باوکی حەزقیا بوو،
\li1 
\v 10 حەزقیا باوکی مەنەشە بوو،
\li1 مەنەشە باوکی ئامۆن بوو،
\li1 ئامۆن باوکی یۆشیا بوو،
\li1 
\v 11 یۆشیا باوکی یەهۆیاکین\f + \fr 1:11 \ft یۆنانی: \tl یەکنیا‏\tl*، بەڵام عیبرییەکە لە پەیمانی کۆندا \tl یەهۆیاکین‏\tl*ە، بڕوانە \xt دووەم پاشایان 24‏:6‏\xt*\ft .‏\f* و براکانی بوو، لە کاتی ڕاپێچکردنەکە بۆ بابل.
\b
\li1 
\v 12 لەدوای ڕاپێچکردنەکە بۆ بابل،
\li1 یەهۆیاکین باوکی شەئەلتیێل بوو،
\li1 شەئەلتیێل باوکی زروبابل بوو،
\li1 
\v 13 زروبابل باوکی ئەبیهود بوو،
\li1 ئەبیهود باوکی ئەلیاقیم بوو،
\li1 ئەلیاقیم باوکی ئازور بوو،
\li1 
\v 14 ئازور باوکی سادۆق بوو،
\li1 سادۆق باوکی ئەکیم بوو،
\li1 ئەکیم باوکی ئەلیهود بوو،
\li1 
\v 15 ئەلیهود باوکی ئەلعازار بوو،
\li1 ئەلعازار باوکی مەتان بوو،
\li1 مەتان باوکی یاقوب بوو،
\li1 
\v 16 یاقوب باوکی یوسفی مێردی مریەم بوو، ئەوەی عیسای لێبوو، کە بە مەسیح\f + \fr 1:16 \ft بە زمانی عیبری پێی دەگوترێ \tl مەشیخ‏\tl* یان \tl مەشیح‏\tl*. بە زمانی یۆنانی دەبێتە \tl کریستۆس‏\tl*، کە بە واتای (دەستنیشانکراو) لەلای خودا دێت کە ڕزگارکەری گەلەکەیەتی. بڕوانە یەکەم ساموئێل 16.‏\f* ناودەبردرێت.
\b
\p 
\v 17 بەم شێوەیە هەموو نەوەکان لە ئیبراهیمەوە هەتا داود چواردە نەوەن، لە داودەوە هەتا ڕاپێچکردنەکە بۆ بابل چواردە نەوەن، لە ڕاپێچکردنەکەشەوە بۆ بابل هەتا مەسیح چواردە نەوەن.
\s1 لەدایکبوونی عیسا
\p 
\v 18 لەدایکبوونی عیسای مەسیح بەم شێوەیە بوو: کاتێک مریەمی دایکی دەستگیرانی یوسف بوو، پێش ئەوەی بگوازرێتەوە، دەرکەوت کە بەهۆی ڕۆحی پیرۆزەوە سکی پڕبووە.
\v 19 یوسفی دەستگیرانی کە پیاوێکی چاک بوو، نەیویست ئابڕووی ببات، بڕیاری دا بە نهێنی دەستی لێ هەڵبگرێت.
\p 
\v 20 کاتێک بیری لەم شتانە دەکردەوە، فریشتەیەکی یەزدان هاتە خەونی و پێی فەرموو: «ئەی یوسفی نەوەی داود، مەترسە لەوەی مریەم بهێنیت، چونکە ئەوەی ئەو سکی پێی هەیە لە ڕۆحی پیرۆزە.
\v 21 کوڕێکی دەبێت ناوی دەنێیت عیسا\f + \fr 1:21 \ft یۆنانی: \tl یێسوس‏\tl*. عیبری: \tl یەشوع‏\tl*. واتا (خودا ڕزگار دەکات.)‏\f*، چونکە گەلەکەی لە گوناهەکانیان ڕزگار دەکات.»
\p 
\v 22 ئەمانە هەمووی ڕوویدا تاکو ئەوەی یەزدان لە ڕێگەی پێغەمبەرەکە\f + \fr 1:22 \ft مەبەست لە پێغەمبەر ئیشایایە.‏\f* فەرموویەتی بێتە دی:
\v 23 ﴿ئەوەتا پاکیزەیەک سکی دەبێت و کوڕێکی دەبێت، ناوی لێ دەنێن ئیمانوێل،﴾\f + \fr 1:23 \ft \xt ئیشایا 7‏:14‏\xt*\ft ‏\f* کە بە واتای خودا لەگەڵمانە دێت.
\p 
\v 24 کاتێک یوسف لە خەو هەستا، ئەوەی فریشتەکەی یەزدان فەرمانی پێدابوو ئەنجامی دا و ژنەکەی گواستەوە.
\v 25 بەڵام هەتا کوڕەکەی نەبوو لەگەڵی جووت نەبوو، ئینجا ناوی لێنا عیسا.
\c 2
\s1 مۆغەکان سەردانی مەسیح دەکەن
\p 
\v 1 لەدوای لەدایکبوونی عیسا لە بێت‌لەحمی یەهودیا\f + \fr 2:1 \ft لە پەیمانی کۆن ناوی یەهودا بووە.‏\f*، لە سەردەمی هێرۆدسی\f + \fr 2:1 \ft هێرۆدس: هێرۆدسی گەورە لە 37‏–4 پ. ز. پاشای یەهودیا بوو.‏\f* پاشا، هەندێک مۆغ\f + \fr 2:1 \ft بە زمانی یۆنانی پێی دەگوترێت مەغۆس. مۆغان پیاوانی ئایینی زەردەشتی بوون کە ئەستێرەناسیش بوون.‏\f* لە ڕۆژهەڵاتەوە هاتنە ئۆرشەلیم،
\v 2 پرسییان: «پاشای لەدایکبووی جولەکە لەکوێیە‏؟ لە ڕۆژهەڵاتەوە ئەستێرەی ئەومان بینی، هاتووین کڕنۆشی بۆ ببەین.»
\p 
\v 3 کاتێک هێرۆدسی پاشا ئەمەی بیست، پەشۆکا و هەموو خەڵکی ئۆرشەلیم لەگەڵی پەشۆکان.
\v 4 هەموو کاهینانی\f + \fr 2:4 \ft کاهین: پیاوێکی ئایینی جولەکەیە کە هەڵدەستێ بە ئەرکی قوربانی کردن لەناو پەرستگا و فێرکردنی وشەی خودا و شەریعەتی پەیمانی کۆن بە خەڵکی.‏\f* باڵا و مامۆستایانی تەوراتی\f + \fr 2:4 \ft مالم.‏\f* گەلی کۆکردەوە، لێی پرسین: «مەسیح لەکوێ لە دایک دەبێت؟»
\v 5 وەڵامیان دایەوە: «لە بێت‌لەحمی یەهودیا، چونکە لە ڕێی پێغەمبەرەکەوە\f + \fr 2:5 \ft مەبەست لە پێغەمبەر میخایە.‏\f* ئاوا نووسراوە:
\q1 
\v 6 «﴿بەڵام تۆ ئەی بێت‌لەحمی خاکی یەهودا،
\q2 کەمتر نیت لە شارۆچکەکانی دیکەی یەهودا،
\q1 چونکە لە تۆوە فەرمانڕەوایەک دەردەکەوێت،
\q2 شوانایەتی گەلی ئیسرائیلم دەکات.﴾\f + \fr 2:6 \ft \xt میخا 5‏:2‏\xt*\ft ‏\f*»
\p 
\v 7 دوای ئەمە هێرۆدس بە نهێنی مۆغەکانی بانگکرد و لەبارەی کاتی دەرکەوتنی ئەستێرەکە لێکۆڵینەوەی لەگەڵ کردن.
\v 8 ئینجا بۆ بێت‌لەحمی ناردن و پێی گوتن: «بڕۆن و بە وردی بەدوای منداڵەکەدا بگەڕێن. کاتێک دۆزیتانەوە هەواڵم بدەنێ، تاکو منیش بێم و کڕنۆشی بۆ ببەم.»
\p 
\v 9 لەدوای ئەوەی گوێبیستی پاشا بوون، ڕۆیشتن، هەمان ئەو ئەستێرەیەی کە لە ڕۆژهەڵات بینیبوویان، پێشیان کەوت و هات و لەسەر ئەو شوێنە ڕاوەستا کە منداڵەکەی لێبوو.
\v 10 کاتێک ئەستێرەکەیان بینی، زۆر شادمان بوون،
\v 11 چوونە ماڵەکە، منداڵەکەیان لەگەڵ مریەمی دایکی بینی، دانەوینەوە و کڕنۆشیان بۆ برد و سندوقی گەنجینەکانیان کردەوە، زێڕ و بخوور و موڕیان\f + \fr 2:11 \ft موڕ: بەکاردەهێنرا لە ئامادەکردنی تەرم بۆ ناشتن، بڕوانە \xt یۆحەنا 19‏:39‏\xt*\ft ‏.‏\f* بە دیاری پێشکەش کرد.
\v 12 ئینجا خودا لە خەوندا مۆغەکانی ئاگادار کردەوە کە نەگەڕێنەوە لای هێرۆدس، ئەوانیش بە ڕێگایەکی دیکەدا گەڕانەوە وڵاتی خۆیان.
\s1 هەڵاتن بەرەو میسر
\p 
\v 13 دوای ڕۆیشتنی مۆغەکان، فریشتەیەکی یەزدان هاتە خەونی یوسف و گوتی: «هەستە، منداڵەکە و دایکی ببە و ڕابکە بۆ میسر. لەوێ بمێنەوە هەتا پێت دەڵێم، چونکە هێرۆدس وا بە شوێن منداڵەکەدا دەگەڕێت، بۆ ئەوەی بیکوژێت.»
\p 
\v 14 یوسفیش هەستا و لە شەودا منداڵەکە و دایکی برد و بەرەو میسر ڕۆیشت،
\v 15 هەتا مردنی هێرۆدس لەوێ مایەوە، تاوەکو ئەوەی یەزدان لە ڕێگەی پێغەمبەرەکەوە\f + \fr 2:15 \ft مەبەست لە پێغەمبەر هۆشەعە.‏\f* فەرموویەتی بێتە دی، کە دەفەرموێ: ﴿من کوڕی خۆمم لە میسر بانگ کرد.﴾\f + \fr 2:15 \ft \xt هۆشەع 11‏:1‏\xt*\ft ‏.‏\f*
\p 
\v 16 کاتێک هێرۆدس زانی مۆغەکان فریویان داوە، زۆر تووڕە بوو. بەگوێرەی ئەو کاتەی لە مۆغەکانەوە لێی کۆڵیبووەوە، ناردی و هەموو کوڕێکی تەمەن دوو ساڵ بەرەو خواری لە بێت‌لەحم و دەوروبەری کوشت.
\v 17 ئینجا ئەوەی لە ڕێگەی پێغەمبەر یەرمیا گوترابوو هاتە دی:
\q1 
\v 18 ﴿دەنگێک لە ڕامەوە بیسترا،
\q2 گریان و شیوەنێکی گەورە،
\q1 ڕاحێل\f + \fr 2:18 \ft ڕاحێل یەکێکە لە ژنەکانی حەزرەتی یاقوب، دایکی یوسف و بنیامینە، لێرەدا هێمایە بۆ دایکە بنیامینییەکان.‏\f* بۆ منداڵەکانی دەگریێت،
\q2 ڕازی نییە دڵنەوایی بکرێت،
\q1 چونکە نەماون.﴾\f + \fr 2:18 \ft \xt یەرمیا 31‏:15‏\xt*\ft ‏\f*
\s1 گەڕانەوە بۆ شاری ناسیرە
\p 
\v 19 کاتێک هێرۆدس مرد، فریشتەیەکی یەزدان لە میسر هاتە خەونی یوسف و
\v 20 گوتی: «هەستە، منداڵەکە و دایکی ببە و بڕۆ بۆ خاکی ئیسرائیل، چونکە ئەوانەی دەیانویست منداڵەکە بکوژن، مردن.»
\p 
\v 21 یوسفیش هەستا، منداڵەکە و دایکی برد و گەڕایەوە خاکی ئیسرائیل.
\v 22 بەڵام کاتێک بیستی ئەرخیلاوس لە یەهودیا لە جێی هێرۆدسی باوکی فەرمانڕەوایە، ترسا بچێتە ئەوێ. دوای ئەوەی لە خەوندا ئاگادار کرایەوە، گەڕایەوە ناوچەی جەلیل.
\v 23 جا هات و لە شارۆچکەیەک نیشتەجێ بوو بە ناوی ناسیرە، بۆ ئەوەی ئەو فەرمایشتەی لە ڕێگەی پێغەمبەرانەوە گوترابوو بێتە دی: ﴿بە ناسیرەیی ناودەبردرێت.﴾
\c 3
\s1 حەزرەتی یەحیا
\p 
\v 1 هەر لەو ڕۆژانەدا، یەحیای لەئاوهەڵکێش\f + \fr 3:1 \ft یەحیا بەم نازناوە ناسراوە بەهۆی ئەوەی کە لە ڕووباری ئوردون ئەو خەڵکەی لە ئاو هەڵدەکێشا کە تۆبەیان دەکرد.‏ یەحیا لە زمانی عیبریدا پێی دەگوترێت (یۆخەنا).\f* لە دەشتی یەهودیا دەرکەوت و پەیامی خودای ڕادەگەیاند،
\v 2 دەیگوت: «تۆبە بکەن، چونکە پاشایەتی ئاسمان نزیک بووەتەوە.»
\v 3 یەحیا ئەو کەسەیە کە لە ڕێگەی پێغەمبەر ئیشایاوە دەربارەی گوتراوە:
\q1 ﴿کەسێک لە چۆڵەوانی هاوار دەکات و دەڵێت:
\q2 «ڕێگا بۆ هاتنی یەزدان ئامادە بکەن،
\q2 ڕێچکەکانی بۆ ڕێکبخەن.»﴾\f + \fr 3:3 \ft \xt ئیشایا 40‏:3‏\xt*\ft ‏\f*
\p 
\v 4 جلوبەرگی یەحیا لە مووی وشتر بوو، پشتێنێکی چەرمیشی لە ناوقەدی دەبەست، خواردنیشی کوللە و هەنگوینی کێوی بوو.
\v 5 ئیتر خەڵکی ئۆرشەلیم و تەواوی یەهودیا و هەموو ناوچەکانی دەوروبەری ڕووباری ئوردون هاتنە لای،
\v 6 دانیان بە گوناهەکانیاندا دەنا و لەسەر دەستی ئەو لە ڕووباری ئوردون لە ئاو هەڵدەکێشران.
\p 
\v 7 کە بینی زۆر لە فەریسی\f + \fr 3:7 \ft مەزەبێکی جولەکە بوون، لە بەجێگەیاندنی تەورات توندڕەو بوون.‏\f* و سەدوقییەکان\f + \fr 3:7 \ft مەزەبێکی جولەکە بوون کە زۆربەیان کاهین بوون، باوەڕیان بە فریشتە و هەستانەوە نەبوو.‏\f* بۆ لەئاوهەڵکێشانەکەی\f + \fr 3:7 \ft یۆنانی: \tl باپتسمە‏\tl*، بە واتای شوشتن دێت بۆ پاکبوونەوە لە گوناه، وەک (بسمیلکردن).‏\f* دێن، پێی گوتن: «ئەی بێچووە ماران، کێ ئاگاداری کردوونەتەوە لە دەست تووڕەیی داهاتوو هەڵبێن؟
\v 8 با بەرهەمێکتان هەبێت لە تۆبەکردن بوەشێتەوە.
\v 9 پێتان وا نەبێت دەتوانن بەخۆتان بڵێن: ”ئیبراهیم باوکمانە.“ پێتان دەڵێم، خودا دەتوانێت لەم بەردانە نەوە بۆ ئیبراهیم دروستبکات.
\v 10 ئەوەتا تەور خراوەتە سەر ڕەگی دار، هەر دارێک بەرهەمی باش نەدات، دەبڕدرێتەوە و فڕێدەدرێتە ناو ئاگرەوە.
\p 
\v 11 «من بۆ تۆبەکردن لە ئاوتان هەڵدەکێشم، بەڵام ئەوەی لەدوای من دێت، لە من بەتواناترە، شایانی ئەوە نیم تەنانەت پێڵاوەکانیشی بۆ هەڵبگرم. ئەو لە ڕۆحی پیرۆز و لە ئاگرتان هەڵدەکێشێت\f + \fr 3:11 \ft بە واتای شوشتن دێت بۆ پاکبوونەوە لە گوناه بەهۆی ڕۆحی پیرۆز.‏\f*.
\v 12 شەنی بەدەستەوەیە بۆ پاککردنەوەی جۆخینەکەی\f + \fr 3:12 \ft جۆخین یان سەرخەرمان ئەو زەوییە تەرخانکراوەیە کە لەلایەن وەرزێر و جوتیارەوە بەکارهێنراوە بۆ کوتانی دانەوێڵە لەسەری لەدوای کۆکردنەوەی لە کێڵگە.‏\f*، گەنمەکە لە ئەمباردا کۆدەکاتەوە و قەسەڵەکەش\f + \fr 3:12 \ft قەسەڵ لاسکە وشکەکەیە کە دوای دروێنە دەمێنێتەوە، کاتێک قەسەڵەکە دەکوترێت دەبێت بە کا.‏\f* بە ئاگرێکی نەکوژاوە دەسووتێنێت.»
\s1 لەئاوهەڵکێشانی عیسا
\p 
\v 13 ئینجا عیسا لە ناوچەی جەلیلەوە هاتە سەر ڕووباری ئوردون، تاوەکو لەسەر دەستی یەحیا لە ئاو هەڵبکێشرێت.
\v 14 بەڵام یەحیا دەیویست ڕێی لێ بگرێت و دەیگوت: «من پێویستیم بەوەیە لەسەر دەستی تۆ لە ئاو هەڵبکێشرێم، کەچی تۆ دێیت بۆ لای من؟»
\p 
\v 15 عیساش وەڵامی دایەوە: «لە ئێستادا ڕێگا بدە بەم جۆرە بێت، چونکە ئاوا لە ئێمە دەوەشێتەوە بۆ ئەوەی هەموو ڕاستودروستییەک\f + \fr 3:15 \ft مەبەست ئەوەیە کە دەبێت هەموو شتێک بەگوێرەی خواستی خودا پەیڕەو بکرێت.‏\f* بێتە دی.» ئینجا ڕێی دا.
\p 
\v 16 هەرکە عیسا لە ئاو هەڵکێشرا، لە ئاوەکە هاتە دەرەوە. لەو ساتەدا ئاسمان کرایەوە و ڕۆحی خودای بینی وەک کۆترێک هاتە خوارەوە و لەسەری نیشتەوە.
\v 17 دەنگێکیش لە ئاسمانەوە فەرمووی: «ئەمە کوڕی خۆشەویستمە، ئەوەی زۆر پێی دڵشادم.»
\c 4
\s1 تاقیکردنەوەی عیسا
\p 
\v 1 پاشان عیسا بەهۆی ڕۆحی پیرۆزەوە بردرایە چۆڵەوانی، تاکو لەلایەن ئیبلیسەوە تاقی بکرێتەوە.
\v 2 دوای ئەوەی کە چل شەو و چل ڕۆژ بەڕۆژوو بوو، برسی بوو.
\v 3 تاقیکەرەوە لێی هاتە پێش، پێی گوت: «ئەگەر تۆ کوڕی خودایت\f + \fr 4:3 \ft بڕوانە لیستی زاراوەکان لە پاشکۆ.‏\f*، بەم بەردانە بڵێ با ببن بە نان.»
\p 
\v 4 بەڵام عیسا وەڵامی دایەوە: «نووسراوە: ﴿مرۆڤ تەنها بە نان ناژیێت، بەڵکو بە هەر وشەیەک کە لە دەمی خوداوە دێتە دەرەوە.﴾\f + \fr 4:4 \ft \xt دواوتار 8‏:3‏\xt*\ft .‏\f*»
\p 
\v 5 ئینجا ئیبلیس بردییە شاری پیرۆز\f + \fr 4:5 \ft شاری پیرۆز: مەبەستی لە ئۆرشەلیمە.‏\f* و لەسەر گوێسەبانەی\f + \fr 4:5 \ft سواندە.‏\f* پەرستگا ڕایگرت و
\v 6 پێی گوت: «ئەگەر تۆ کوڕی خودایت خۆت هەڵبدە خوارەوە. لەبەر ئەوەی نووسراوە:
\q1 «﴿سەبارەت بە تۆ فەرمان بە فریشتەکانی دەدات،
\q2 لەسەر دەستیان هەڵتدەگرن،
\q1 تاکو پێت بەر بەردێک نەکەوێت.﴾\f + \fr 4:6 \ft \xt زەبوورەکان 91‏:11‏-12‏\xt*\ft ‏\f*»
\p 
\v 7 عیساش پێی فەرموو: «هەروەها نووسراوە: ﴿یەزدانی پەروەردگارتان تاقی مەکەنەوە.﴾\f + \fr 4:7 \ft \xt دواوتار 6‏:16‏\xt*\ft ‏\f*»
\p 
\v 8 دیسان ئیبلیس بۆ سەر شاخێکی زۆر بڵندی برد و هەموو شانشینەکانی جیهان و شکۆی ئەوانی پیشان دا و
\v 9 پێی گوت: «هەموو ئەمانەت دەدەمێ ئەگەر کڕنۆش ببەیت و بمپەرستی.»
\p 
\v 10 ئینجا عیساش پێی فەرموو: «ئەی شەیتان لێم دووربکەوە! چونکە نووسراوە: ﴿کڕنۆش بۆ یەزدانی پەروەردگارت دەبەیت و تەنها ئەو دەپەرستیت.﴾\f + \fr 4:10 \ft \xt دواوتار 6‏:13‏\xt*\ft ‏\f*»
\p 
\v 11 ئیتر ئیبلیس وازی لێ هێنا و چەند فریشتەیەک هاتن و خزمەتیان دەکرد.
\s1 مژدەبەخشین لە جەلیل
\p 
\v 12 کاتێک عیسا بیستی یەحیا گیراوە، گەڕایەوە بۆ ناوچەی جەلیل.
\v 13 ناسیرەی بەجێهێشت و هات لە شاری کەفەرناحوم نیشتەجێ بوو، کە لەسەر دەریاچەیە، لە سنووری زەبولون و نەفتالی\f + \fr 4:13 \ft دوو ناوچەی بچووکن دەکەونە باکووری فەلەستین و ڕۆژئاوای دەریاچەی جەلیل، بە ناوی دووان لە کوڕەکانی حەزرەتی یاقوب ناونراون.‏\f*،
\v 14 تاکو ئەوەی لە ڕێگەی پێغەمبەر ئیشایاوە گوتراوە بێتە دی:
\q1 
\v 15 ﴿ئەی خاکی زەبولون و خاکی نەفتالی،
\q2 ئەوەی لە ڕێگای دەریایە، ئەوبەری ڕووباری ئوردون،
\q2 جەلیلی ناجولەکەکان،
\q1 
\v 16 ئەو گەلەی لە تاریکیدا دانیشتووە،
\q2 ڕووناکییەکی گەورەی بینی،
\q1 دانیشتووان لە خاکی سێبەری مەرگ
\q2 ڕووناکی بەسەریاندا هەڵهات.﴾\f + \fr 4:16 \ft \xt ئیشایا 9‏:1‏-2‏\xt*\ft ‏\f*
\p 
\v 17 لەو کاتەوە عیسا دەستی کرد بە جاڕدان و دەیفەرموو: «تۆبە بکەن، چونکە پاشایەتی ئاسمان نزیک بووەتەوە.»
\s1 هەڵبژاردنی قوتابییەکان
\p 
\v 18 کاتێک عیسا بە کەناری دەریاچەی جەلیلدا دەڕۆیشت، دوو برای بینی، شیمۆن کە پێی دەگوترا پەترۆس لەگەڵ ئەندراوسی برای، تۆڕیان فڕێدەدایە دەریاچەکە، چونکە ماسیگر بوون.
\v 19 عیسا پێی فەرموون: «وەرن دوام بکەون، دەتانکەم بە ڕاوکەری مرۆڤ\f + \fr 4:19 \ft مەبەست لە هێنانی خەڵکە بۆ ئەوەی ببەن بە قوتابی مەسیح.‏\f*.»
\v 20 دەستبەجێ تۆڕەکانیان بەجێهێشت و دوای کەوتن.
\p 
\v 21 کە لەوێ ڕۆیشت، دوو برای دیکەی بینی، یاقوبی کوڕی زەبدی و یۆحەنای برای، لە بەلەمێکدا لەگەڵ زەبدی باوکیان تۆڕەکانیان چاک دەکردەوە، ئەوانیشی بانگکرد.
\v 22 دەستبەجێ بەلەمەکە و باوکیان بەجێهێشت و دوای عیسا کەوتن.
\s1 عیسا نەخۆش چاک دەکاتەوە
\p 
\v 23 ئینجا عیسا بە هەموو جەلیلدا دەگەڕا، لە کەنیشتەکانیان\f + \fr 4:23 \ft کەنیشت: بەو شوێنە دەگوترێت کە جولەکەکان نوێژ و خواپەرستی و خوێندنی تەوراتی لێ ئەنجام دەدەن.‏\f* خەڵکی فێر دەکرد و مزگێنی\f + \fr 4:23 \ft یۆنانی: \tl ئیوانجیلیۆن‏\tl*، لە زمانی عەرەبی بووە بە ئینجیل. لە زمانی یۆنانی بە واتای مژدە دێت، بە تایبەتی ڕاگەیاندنی هاتنی پاشا، لێرەدا بۆ هاتنی مەسیح بەکارهاتووە.‏\f* پاشایەتییەکەی ڕادەگەیاند، هەرچی نەخۆشی و نەساغی نێو خەڵک هەبوو چاکی دەکردنەوە.
\v 24 لەبەر ئەوە دەنگوباسی تەواوی سوریای\f + \fr 4:24 \fq سوریا \ft لەو سەردەمەدا بە خاکی باکووری جەلیل گوتراوە سوریا، کە هەرێمێکی ژێر دەسەڵاتی ڕۆمانی بووە.‏\f* گرتەوە، ئەوانیش هەموو نەخۆشێکیان دەهێنایە لای، بە جۆرەها دەرد و ئازارەوە، ئەوانەی کە ڕۆحی پیسیان تێدابوو و فێدار و ئیفلیج بوون، چاکی دەکردنەوە.
\v 25 جا خەڵکێکی زۆر لە جەلیل و دە شارەکە\f + \fr 4:25 \ft دە شارەکە: دیکاپۆلیس، دەکەوێتە ڕۆژهەڵاتی ڕووباری ئوردون.‏\f* و ئۆرشەلیم و یەهودیا و ئەوبەری ڕووباری ئوردون دوای کەوتن.
\c 5
\s1 وتاری سەر چیا
\p 
\v 1 کاتێک عیسا خەڵکەکەی بینی، چووە سەر چیا، ئینجا دانیشت و قوتابییەکانی هاتنە لای،
\v 2 دەستی کرد بە فێرکردنیان و فەرمووی:
\q1 
\v 3 «خۆزگە دەخوازرێت بەوانەی کە بە ڕۆح هەژارن\f + \fr 5:3 \ft ئەوانەی کە دەزانن لەلایەنی ڕۆحییەوە کەموکوڕییان هەیە.‏\f*،
\q2 چونکە شانشینی ئاسمان بۆ ئەوانە.
\q1 
\v 4 خۆزگە دەخوازرێت بەوانەی کە ماتەمدارن،
\q2 چونکە دڵنەوایی دەکرێن.
\q1 
\v 5 خۆزگە دەخوازرێت بە دڵنەرمەکان،
\q2 چونکە زەوییان بە میراتیی بۆ دەمێنێتەوە.
\q1 
\v 6 خۆزگە دەخوازرێت بەوانەی کە برسی و تینوون بۆ ڕاستودروستی\f + \fr 5:6 \ft مەبەست ئەوەیە کە دەبێت هەموو شتێک بەگوێرەی خواستی خودا پەیڕەو بکرێت.‏\f*،
\q2 چونکە تێر دەکرێن.
\q1 
\v 7 خۆزگە دەخوازرێت بەوانەی کە دڵیان پڕ لە بەزەییە،
\q2 چونکە بەر بەزەیی دەکەون.
\q1 
\v 8 خۆزگە دەخوازرێت بە دڵپاکەکان،
\q2 چونکە خودا دەبینن.
\q1 
\v 9 خۆزگە دەخوازرێت بە ئاشتیخوازان،
\q2 چونکە بە ڕۆڵەی خودا ناودەبردرێن.
\q1 
\v 10 خۆزگە دەخوازرێت بەوانەی لە پێناوی ڕاستودروستی دەچەوسێنرێنەوە،
\q2 چونکە شانشینی ئاسمان بۆ ئەوانە.
\p 
\v 11 «خۆزگە دەخوازرێت بە ئێوە کاتێک خەڵکی جنێوتان پێدەدەن‏ و دەتانچەوسێننەوە، لەبەر من هەموو جۆرە بوختانێکتان بۆ هەڵدەبەستن.
\v 12 دڵخۆش و شادمان بن، لەبەر ئەوەی لە ئاسمان پاداشتتان گەورەیە، چونکە پێش ئێوە پێغەمبەرانیشیان ئاوا چەوساندووەتەوە.
\s1 خوێی زەوی و ڕووناکی جیهان
\p 
\v 13 «ئێوە خوێی زەوین، بەڵام ئەگەر خوێ سوێرییەکەی نەما، چۆن تامە سوێرەکەی بۆ دەگەڕێندرێتەوە؟ ئیتر بەکەڵکی هیچ نایەت، ئەوە نەبێ فڕێبدرێتە دەرەوە و خەڵکی پێشێلی بکەن.
\p 
\v 14 «ئێوە ڕووناکی جیهانن، شارێک لەسەر شاخ دروست‏کرابێت ناتوانرێت بشاردرێتەوە.
\v 15 هەروەها خەڵکی چرا هەڵناکەن تاکو بیخەنە ژێر تەشتەوە، بەڵکو لەسەر چرادان دایدەنێن بۆ ئەوەی ڕووناکی بداتە هەموو ئەوانەی لە ماڵەکەدان.
\v 16 بە هەمان شێوە، با ئێوەش ڕووناکیتان بۆ خەڵک بدرەوشێتەوە، تاکو کردارە باشەکانتان ببینن و ستایشی باوکتان بکەن کە لە ئاسمانە.
\s1 تەواوکردنی تەورات
\p 
\v 17 «وا بیر نەکەنەوە من هاتووم تەورات یان نووسراوی پێغەمبەران بسڕمەوە، نەهاتووم بۆ سڕینەوەیان، بەڵکو هاتووم بۆ تەواوکردنیان.
\v 18 ڕاستیتان پێ دەڵێم: هەتا زەوی و ئاسمان لەئارادا بێت، پیتێک یان خاڵێک لە تەورات لەناو ناچێت، هەتا هەمووی دێتە دی.
\v 19 بۆیە ئەوەی بچووکترینی ئەم ڕاسپاردانە بشکێنێت و خەڵکیش ئاوا فێر بکات، لە شانشینی ئاسمان بە بچووکترین ناودەبردرێت. بەڵام ئەوەی پەیڕەویان بکات و خەڵکی فێر بکات، لە شانشینی ئاسمان بە مەزن ناودەبردرێت.
\v 20 ئیتر پێتان دەڵێم: ئەگەر ڕاستودروستیتان لە مامۆستایانی تەورات و فەریسییەکان زیاتر نەبێت، هەرگیز ناچنە ناو شانشینی ئاسمانەوە.
\s1 تووڕەیی
\p 
\v 21 «بیستووتانە بە پێشینان گوتراوە: ﴿مەکوژن﴾\f + \fr 5:21 \ft \xt دەرچوون 20‏:13‏\xt*\ft ‏\f* و ”ئەوەی بکوژێت شایانی حوکم بەسەردادان دەبێت.“
\v 22 بەڵام من پێتان دەڵێم ئەوەی لە خوشکی یان براکەی تووڕە بێ، دەبێ حوکم بدرێت. ئەوەی بە براکەی بڵێ ”هیچوپووچ،“ دەبێت بدرێتە ئەنجومەنی باڵای جولەکە، ئەوەش بڵێت ”گێلە“، دەبێت بخرێتە ناو ئاگری دۆزەخەوە.
\p 
\v 23 «لەبەر ئەوە ئەگەر قوربانیت بۆ قوربانگا هێنا و لەوێ بیرت کەوتەوە کە خوشکت یان برات شتێکی بەسەرتەوە هەیە،
\v 24 لەوێ لەبەردەم قوربانگا قوربانییەکەت بەجێبهێڵە و بڕۆ یەکەم جار خوشکت یان برات ئاشت بکەرەوە، ئینجا وەرە و قوربانییەکەت بکە.
\p 
\v 25 «خێرا لەگەڵ ڕکابەرەکەت ئاشت بەرەوە لەو کاتەی لەگەڵتە و بە ڕێگاوەن بۆ دادگا، نەوەک ڕکابەرەکەت بتداتە دەست دادوەر و دادوەریش بتداتە دەست پۆلیس و فڕێبدرێیتە بەندیخانە.
\v 26 ڕاستیت پێ دەڵێم: لەوێ دەرناچی هەتا دوایین فلس نەدەیتەوە.
\s1 داوێنپیسی
\p 
\v 27 «بیستووتانە گوتراوە: ﴿داوێنپیسی مەکەن.﴾\f + \fr 5:27 \ft \xt دەرچوون 20‏:14‏\xt*\ft ‏\f*
\v 28 بەڵام من پێتان دەڵێم: ئەوەی بە هەوەسبازییەوە سەیری ئافرەتێک بکات، ئەوا لە دڵی خۆیدا داوێنپیسی لەگەڵ کردووە.
\v 29 ئەگەر چاوی ڕاستت تووشی گوناهی کردیت، دەریبهێنە و فڕێیبدە. بۆ تۆ باشترە ئەندامێکت لەدەست بچێت، لەوەی هەموو لەشت فڕێبدرێتە ناو دۆزەخ.
\v 30 ئەگەر دەستی ڕاستت تووشی گوناهی کردیت، بیبڕەوە و فڕێیبدە. بۆ تۆ باشترە ئەندامێکت لەدەست بچێت، لەوەی هەموو لەشت بچێتە دۆزەخەوە.
\s1 تەڵاق
\p 
\v 31 «دیسان گوتراوە: ﴿ئەوەی ژنەکەی تەڵاق بدات، با تەڵاقنامەی بداتە دەست.﴾\f + \fr 5:31 \ft \xt دواوتار 24‏:1‏\xt*\ft ‏\f*
\v 32 بەڵام من پێتان دەڵێم: ئەوەی بەبێ هۆی داوێنپیسی ژنەکەی خۆی تەڵاق بدات، وای لێدەکات داوێنپیسی بکات. ئەوەش تەڵاقدراوێک بهێنێت، ئەوا داوێنپیسی دەکات.
\s1 سوێندخواردن
\p 
\v 33 «دیسان بیستووتانە کە بە پێشینان گوتراوە: ﴿سوێندەکانت مەشکێنە، بەڵکو سوێندەکانت بۆ یەزدان بەرەسەر.﴾\f + \fr 5:33 \ft \xt لێڤییەکان 19‏:12‏\xt*\ft ‏\f*
\v 34 بەڵام من پێتان دەڵێم: هەرگیز سوێند مەخۆن، نە بە ئاسمان، لەبەر ئەوەی تەختی شاهانەی خودایە،
\v 35 نە بە زەوی، لەبەر ئەوەی تەختەپێیەتی\f + \fr 5:35 \ft کاتێک کەسێک لەسەر کورسییەکی بەرز دادەنیشێت تەختەپێ لەژێر پێیەکانی دادەنرێت.‏\f*، نە بە ئۆرشەلیم، لەبەر ئەوەی شاری پاشای پایەبەرزە.
\v 36 سوێند بە سەری خۆت مەخۆ، چونکە ناتوانیت تاڵە مووێکی سپی یان ڕەش بکەیت.
\v 37 با قسەتان ”بەڵێ“ بۆ ”بەڵێ“ و ”نەخێر“ بۆ ”نەخێر“ بێت، لەمە بترازێت لە شەیتانەوەیە\f + \fr 5:37 \ft یۆنانی: خراپەکار.‏\f*.
\s1 تۆڵەسەندن
\p 
\v 38 «بیستووتانە گوتراوە: ﴿چاو بە چاو، ددان بە ددان.﴾\f + \fr 5:38 \ft \xt دەرچوون 21‏:24‏\xt*\ft ‏\f*
\v 39 بەڵام من پێتان دەڵێم: بەربەرەکانێی خراپەکار مەکەن، بەڵکو ئەوەی لە ڕوومەتی ڕاستی دایت، لایەکەی دیکەشی بۆ شل بکە،
\v 40 ئەوەی ویستی بتداتە دادگا و کراسەکەت لێ بستێنێت، چاکەتەکەشتی بدەرێ.
\v 41 ئەوەی یەک میل بێگاری پێ کردیت، دووانی لەگەڵ بڕۆ.
\v 42 ئەوەی داوای شتێکی لێکردیت بیدەرێ. ئەوەی داوای قەرزی لێکردیت پشتی تێمەکە.
\s1 خۆشویستنی دوژمنان
\p 
\v 43 «بیستووتانە گوتراوە: ﴿نزیکەکەت خۆشبوێت،﴾\f + \fr 5:43 \ft \xt لێڤییەکان 19‏:18‏\xt*\ft ‏\f* ”ڕقت لە دوژمنت بێتەوە.“
\v 44 بەڵام من پێتان دەڵێم: دوژمنەکانتان خۆشبوێ، نوێژ بکەن بۆ ئەوانەی دەتانچەوسێننەوە،
\v 45 تاکو ببنە ڕۆڵەی ئەو باوکەتان کە لە ئاسمانە، ئەو خۆری خۆی بەسەر چاک و خراپدا هەڵدێنێت و باران بەسەر پیاوچاک و زۆرداریشدا دەبارێنێت.
\v 46 ئەگەر هەر ئەوانەتان خۆشبوێ کە ئێوەیان خۆشدەوێت، چ پاداشتێک وەردەگرن؟ ئایا باجگرانیش ئەمە ناکەن؟
\v 47 ئەگەر سڵاوتان تەنها لە ناسیاوەکانتان کرد، چی زیاترتان کردووە؟ ئایا بتپەرستانیش ئەمە ناکەن؟
\v 48 بۆیە ئێوە کامڵ و تەواو بن، هەروەک باوکی ئاسمانیتان کامڵ و تەواوە.
\c 6
\s1 خێرکردن
\p 
\v 1 «هۆشیار بن و نەکەن لەبەرچاوی خەڵک چاکە بکەن بۆ ئەوەی بتانبینن، ئەگینا لەلای باوکی ئاسمانیتان پاداشتتان نابێت.
\p 
\v 2 «لەبەر ئەوە کاتێک خێرێک دەکەیت، زوڕنای بۆ لێمەدە هەروەک دووڕووان کە لە کەنیشت و سەر شەقامەکان دەیکەن، بۆ ئەوەی لەلایەن خەڵکەوە ستایش بکرێن. ڕاستیتان پێ دەڵێم: ئەوانە پاداشتی خۆیان وەرگرتووە.
\v 3 بەڵام تۆ کە خێرێک دەکەیت، مەهێڵە دەستی چەپت بزانێت دەستی ڕاستت چی دەکات،
\v 4 تاکو خێرەکەت بە نهێنی بێت. باوکیشت کە هەموو نهێنییەک دەبینێت، پاداشتت دەداتەوە.
\s1 نوێژکردن
\p 
\v 5 «کاتێک نوێژ دەکەن وەک دووڕووان مەبن، چونکە ئەوان حەز دەکەن بە پێوە لە کەنیشت و سووچی شەقامەکان نوێژ بکەن، بۆ ئەوەی خەڵکی بیانبینن. ڕاستیتان پێ دەڵێم: ئەوانە پاداشتی خۆیان وەرگرتووە.
\v 6 بەڵام تۆ کاتێک نوێژ دەکەیت، بڕۆ ژوورەکەت و دەرگا لەسەر خۆت دابخە، نوێژ بکە بۆ باوکی نەبینراوت. باوکیشت کە هەموو نهێنییەک دەبینێت، پاداشتت دەداتەوە.
\v 7 کاتێک نوێژ دەکەن، وەک بتپەرستان ئەوەندە وشەکان دووبارە مەکەنەوە، چونکە وا دەزانن بە زۆر گوتنیان گوێیان لێ دەگیرێت.
\v 8 لەبەر ئەوە وەک ئەوان مەبن، چونکە باوکتان دەزانێت پێویستیتان بە چییە، پێش ئەوەی داوای لێ بکەن.
\p 
\v 9 «بەڵام ئێوە بەم شێوەیە نوێژ بکەن و بڵێن:
\q1 «”ئەی باوکمان لە ئاسمان،
\q1 با ناوت پیرۆز بێت،\f + \fr 6:9 \ft واتا شکۆدارکردنی ناوی خودا لەلایەن بەدیهێنراوانی.‏\f*
\q1 
\v 10 با پاشایەتییەکەت بێ\f + \fr 6:10 \ft بە واتای هاتنی پاشایەتی خودا لە ئاسمانەوە بۆ سەر زەوی.‏\f*،
\q1 با خواستت لەسەر زەوی پەیڕەو بکرێت وەک لە ئاسمان.
\q1 
\v 11 نانی ڕۆژانەمان ئەمڕۆش بدەرێ.
\q1 
\v 12 لە گوناهەکانمان\f + \fr 6:12 \ft یۆنانی: قەرزەکان.‏\f* خۆشبە،
\q2 وەک چۆن ئێمە لەوانە خۆشدەبین کە خراپەمان بەرامبەر دەکەن.
\q1 
\v 13 مەمانخەرە تاقیکردنەوە،
\q1 بەڵکو لە شەیتان\f + \fr 6:13 \ft یۆنانی: خراپەکارەکە.‏\f* ڕزگارمان بکە،
\q1 [چونکە هەتاهەتایە پاشایەتی و هێز و شکۆ هی تۆیە. ئامین.]“
\m 
\v 14 ئەگەر گەردنی خەڵکی لەبەر خراپەکانیان ئازاد بکەن، ئەوا باوکی ئاسمانیشتان لێتان خۆشدەبێت.
\v 15 بەڵام ئەگەر گەردنی خەڵکی ئازاد نەکەن، ئەوا باوکیشتان لە گوناهەکانتان خۆش نابێت.
\s1 ڕۆژووگرتن
\p 
\v 16 «کاتێک بەڕۆژوو دەبن، ڕووگرژ مەبن وەک دووڕووان، چونکە ئەوان خۆیان پەرێشان دەردەخەن تاکو بۆ خەڵکی دەربخەن کە بەڕۆژوون. ڕاستیتان پێ دەڵێم: ئەوانە پاداشتی خۆیان وەرگرتووە.
\v 17 بەڵام تۆ کە بەڕۆژوو دەبیت، سەرت چەور بکە و دەموچاوت بشۆ،
\v 18 تاکو بۆ خەڵک دەرنەکەوێت کە بەڕۆژوویت، تەنها بۆ باوکی نەبینراوت نەبێت، باوکیشت کە هەموو نهێنییەک دەبینێت، پاداشتت دەداتەوە.
\s1 سامانی ڕاستەقینە
\p 
\v 19 «لەسەر زەوی سامان بۆ خۆتان کۆمەکەنەوە کە مۆرانە و ژەنگ لێی دەدەن و دز دەیبڕێت و دەیدزێت.
\v 20 بەڵکو سامان بۆ خۆتان لە ئاسمان کۆبکەنەوە کە مۆرانە و ژەنگ لێی نادەن و دزیش نایبڕێت و نایدزێت،
\v 21 چونکە سامانت لەکوێ بێت، دڵیشت لەوێ دەبێت.
\p 
\v 22 «چاو چرای جەستەیە، ئەگەر چاوت ساغ بێت، ئەوا جەستەت هەمووی ڕووناکییە،
\v 23 بەڵام ئەگەر چاوت ساغ نەبێت، ئەوا هەموو جەستەت تاریک دەبێت، لەبەر ئەوە ئەگەر ئەو ڕووناکییەی لە تۆدایە تاریکی بێت، ئاخۆ دەبێ تاریکی چۆن بێت!
\p 
\v 24 «کەس ناتوانێت کۆیلایەتی دوو گەورە بکات، چونکە ڕقی لە یەکێکیان دەبێتەوە و ئەوەی دیکەی خۆشدەوێت، یان دەست بە یەکێکیانەوە دەگرێت و ئەوەی دیکە پشتگوێ دەخات. ئێوەش ناتوانن کۆیلەی خودا و پارە بن.
\s1 خودا خەممان دەخوات
\p 
\v 25 «بۆیە پێتان دەڵێم: خەم بۆ ژیانتان مەخۆن کە چی بخۆن و چی بخۆنەوە؛ هەروەها بۆ جەستەتان کە چی بپۆشن. ئایا ژیان لە خواردن گرنگتر نییە؟ یان جەستە لە جلوبەرگ؟
\v 26 سەیری باڵندەی ئاسمان بکەن، نە تۆو دەکەن و نە دروێنە و نە لە ئەمبار کۆدەکەنەوە، لەگەڵ ئەوەشدا باوکی ئاسمانیتان بەخێویان دەکات. ئایا ئێوە لەوان بەنرختر نین؟
\v 27 کێ لە ئێوە ئەگەر خەم بخوات، دەتوانێت یەک کاتژمێر لە تەمەنی خۆی زیاد بکات؟
\p 
\v 28 «هەروەها بۆچی خەمی جلوبەرگتانە؟ سەیری گوڵی سەوسەن بکەن چۆن گەشە دەکات، نە خۆی ماندوو دەکات و نە دەڕێسێت،
\v 29 بەڵام پێتان دەڵێم: تەنانەت سلێمانیش لەوپەڕی شکۆمەندیدا وەک یەکێک لەوانەی نەپۆشیوە.
\v 30 ئەی کەم باوەڕینە، ئەگەر خودا ئەو گیایەی کە ئەمڕۆ لە کێڵگەیە و بەیانی دەخرێتە تەنوورەوە بەو شێوەیە بپۆشێت، ئایا ئێوە زیاتر نین هەتا پۆشتەتان بکات!
\v 31 جا خەم مەخۆن بڵێن، ”چی بخۆین؟“ یان ”چی بخۆینەوە؟“ یان ”چی لەبەر بکەین؟“
\v 32 چونکە بێباوەڕان هەوڵ بۆ هەموو ئەم شتانە دەدەن، باوکی ئاسمانیشتان دەزانێت پێویستیتان بە هەموو ئەوانە هەیە.
\v 33 بەڵکو یەکەم جار داوای پاشایەتییەکەی خودا و ڕاستودروستییەکەی بکەن، هەموو ئەمانەتان بۆ دابین دەکرێت.
\v 34 لەبەر ئەوە خەمی بەیانی مەخۆن، چونکە بەیانی خەمی خۆی دەخوات. هەر ڕۆژێک خراپی خۆی بەسە.
\c 7
\s1 خەڵکی تاوانبار مەکەن
\p 
\v 1 «خەڵکی تاوانبار مەکەن تاکو خودا تاوانبارتان نەکات،
\v 2 چونکە بەو شێوەیەی خەڵک تاوانبار دەکەن خودا تاوانبارتان دەکات، بەو پێوانەیەی ئێوە بۆ خەڵک دەیپێون، خودا بۆتان دەپێوێتەوە.
\p 
\v 3 «بۆچی سەرنج لە پووشی ناو چاوی براکەت دەدەیت، بەڵام ئاگات لە کاریتەکەی ناو چاوی خۆت نییە؟
\v 4 یان، چۆن بە براکەت دەڵێی: ”ڕێم بدە با پووشەکەی ناو چاوت دەربهێنم،“ لەکاتێکدا کاریتەیەک لەناو چاوی خۆتدایە؟
\v 5 ئەی دووڕوو، یەکەم جار کاریتەکەی ناو چاوی خۆت دەربهێنە، ئینجا باش دەبینیت بۆ دەرهێنانی پووشەکەی ناو چاوی براکەت.
\p 
\v 6 «شتی پیرۆز مەدەن بە سەگ، مرواریشتان فڕێمەدەنە بەردەمی بەراز، نەوەک پێشێلیان بکەن و هەڵبگەڕێنەوە و پارچەپارچەتان بکەن.
\s1 داوا بکەن، بگەڕێن، لە دەرگا بدەن
\p 
\v 7 «داوا بکەن، پێتان دەدرێت. بگەڕێن، دەدۆزنەوە. لە دەرگا بدەن، لێتان دەکرێتەوە،
\v 8 چونکە هەرکەسێک داوا بکات، وەردەگرێت. ئەوەی بگەڕێت، دەدۆزێتەوە. ئەوەش لە دەرگا دەدات، لێی دەکرێتەوە.
\p 
\v 9 «کێ لە ئێوە ئەگەر کوڕەکەی داوای نانی لێ بکات، بەردی دەداتێ؟
\v 10 یان داوای ماسی لێ بکات، ماری دەداتێ؟
\v 11 جا ئێوە کە خراپن، بزانن شتی باش بدەنە منداڵەکانتان، باوکتان لە ئاسمان چەند زیاتر شتی باش دەداتە ئەوانەی داوای لێدەکەن!
\v 12 چۆن دەتانەوێ خەڵکی هەڵسوکەوتتان لەگەڵ بکەن، ئێوەش بەو شێوەیە هەڵسوکەوتیان لەگەڵ بکەن، چونکە ئەمەیە پوختەی تەورات و پەیامی پێغەمبەران.
\s1 دەرگای تەسک
\p 
\v 13 «لە دەرگای تەنگەوە بچنە ژوورەوە، چونکە ئەو دەرگایە پانە و ئەو ڕێگایە بەرینە کە بەرەو لەناوچوون دەچێت و زۆرن ئەوانەی پێیدا دەچنە ژوورەوە.
\v 14 بەڵام تەسکە دەرگا و تەنگە ئەو ڕێگایەی بەرەو ژیان دەچێت، کەم کەسیش دەیدۆزێتەوە.
\s1 ناسین بە بەرهەم
\p 
\v 15 «ئاگاداری پێغەمبەرانی درۆزن بن کە لە پێستی مەڕدا بۆ لاتان دێن، بەڵام لەناوەوە گورگی دڕندەن.
\v 16 بە بەرهەمیان دەیانناسنەوە. ئایا ترێ لە دڕک دەکرێتەوە یان هەنجیر لە چقڵ؟
\v 17 بەم شێوەیە هەموو دارێکی باش بەری باش دەدات، داری خراپیش بەری خراپ.
\v 18 داری چاک ناتوانێت بەری خراپ بدات و داری خراپیش ناتوانێت بەری باش بدات.
\v 19 هەر دارێک بەری باش نەدات دەبڕدرێتەوە و فڕێدەدرێتە ناو ئاگر.
\v 20 کەواتە بە بەرهەمیان دەیانناسنەوە.
\s1 شوێنکەوتەی ڕاستەقینە کێیە؟
\p 
\v 21 «نەک هەرکەسێک پێم بڵێت: ”پەروەردگارم، پەروەردگارم!“ دەچێتە ناو شانشینی ئاسمان، بەڵکو ئەوەی خواستی باوکم ئەنجام دەدات کە لە ئاسمانە.
\v 22 لەو ڕۆژەدا\f + \fr 7:22 \ft لەو ڕۆژەدا: مەبەستی لە ڕۆژی لێپرسینەوەیە.‏\f*، زۆر کەس پێم دەڵێن: ”پەروەردگارم، پەروەردگارم! ئایا بە ناوی تۆوە پەیامی خودامان ڕانەگەیاند، بە ناوی تۆوە ڕۆحی پیسمان دەرنەکرد، بە ناوی تۆوە پەرجووی\f + \fr 7:22 \ft پەرجوو: موعجیزە.‏\f* زۆرمان نەکرد؟“
\v 23 ئینجا منیش پێیان ڕادەگەیەنم: ”قەت ئێوەم نەناسیوە. لێم دوور بکەونەوە، ئەی بەدکاران!“
\s1 بناغەی پتەو و بناغەی لاواز
\p 
\v 24 «لەبەر ئەوە هەرکەسێک گوێی لەم وتانەم بێت و پەیڕەوی بکات، وەک پیاوێکی دانا وایە کە خانووەکەی لەسەر بەرد دروستکردبێت.
\v 25 باران باری و لافاو هەستا و ڕەشەبا هەڵیکرد و لە خانووەکەی دا، بەڵام نەڕووخا، چونکە لەسەر بەرد دروستکرابوو.
\v 26 هەرکەسێکیش گوێی لەم وتانەم بێت و پەیڕەوی نەکات، وەک پیاوێکی گێل وایە خانووەکەی لەسەر لم دروستکردبێت.
\v 27 باران باری و لافاو هەستا و ڕەشەبا هەڵیکرد و لەو خانووەی دا و ڕووخاندی، ڕووخاندنەکەشی گەورە بوو.»
\p 
\v 28 کاتێک عیسا ئەم وتانەی تەواو کرد، خەڵکەکە لە فێرکردنەکەی سەرسام بوون،
\v 29 چونکە وەک دەسەڵاتدارێک فێری دەکردن، نەک وەکو مامۆستایانی تەورات.
\c 8
\s1 پاکبوونەوە لە گولی
\p 
\v 1 کاتێک عیسا لە چیاکە هاتە خوارەوە، خەڵکێکی زۆر دوای کەوتن.
\v 2 ئەوە بوو پیاوێک هات کە نەخۆشی گولی\f + \fr 8:2 \ft گول: یۆنانی: \tl لەپرۆس‏\tl*. تەنها واتای نەخۆشی گولی نادات، بەڵکو بۆ چەندین نەخۆشی پێست بەکارهێنراوە.‏\f* هەبوو، کڕنۆشی بۆ برد و گوتی: «گەورەم، ئەگەر بتەوێت، دەتوانیت پاکم بکەیتەوە.»
\p 
\v 3 عیساش دەستی بۆ درێژکرد و دەستی لێدا و فەرمووی: «دەمەوێت، پاک بەرەوە!» دەستبەجێ لە گولی پاک بووەوە.
\v 4 ئینجا عیسا پێی فەرموو: «ئاگاداربە، بە کەس مەڵێ، بەڵام بڕۆ خۆت پیشانی کاهین بدە و ئەو قوربانییەی موسا فەرمانی کردووە بیکە، وەک شایەتییەک بۆیان.»
\s1 باوەڕی سەرپەلێک
\p 
\v 5 کاتێک عیسا چووە ناو کەفەرناحوم، سەرپەلێک\f + \fr 8:5 \ft وشە یۆنانییەکە مەبەست لە سەرکردەی سەد سەربازە لە سوپای ڕۆم.‏\f* هاتە لای، لێی پاڕایەوە
\v 6 و گوتی: «گەورەم، خزمەتکارەکەم بە ئیفلیجی لە ماڵەوە کەوتووە و ئازارێکی زۆری هەیە.»
\p 
\v 7 عیسا پێی فەرموو: «من دێم و چاکی دەکەمەوە.»
\p 
\v 8 سەرپەلەکەش وەڵامی دایەوە: «گەورەم شایانی ئەوە نیم خۆت بێیتە ماڵەکەم، بەڵکو تەنها وشەیەک بفەرموو خزمەتکارەکەم چاکدەبێتەوە،
\v 9 چونکە منیش خۆم کەسێکم لەژێر فەرماندام، سەربازیشم لەژێر دەستدایە. بەمە دەڵێم: ”بڕۆ،“ دەڕوات؛ بەوی دیکەش دەڵێم: ”وەرە،“ دێت؛ بە کۆیلەکەشم دەڵێم: ”ئەمە بکە،“ دەیکات.»
\p 
\v 10 کاتێک عیسا گوێی لەمە بوو، سەرسام بوو، بەوانەی فەرموو کە دوای کەوتبوون: «ڕاستیتان پێ دەڵێم، لە ئیسرائیلدا کەسم نەدیوە باوەڕێکی بەهێزی ئاوای هەبێت.
\v 11 پێتان دەڵێم کە خەڵکێکی زۆر لە ڕۆژهەڵات و ڕۆژئاواوە دێن و لەگەڵ ئیبراهیم و ئیسحاق و یاقوب لە شانشینی ئاسماندا لەسەر خوان دادەنیشن.
\v 12 بەڵام ڕۆڵەکانی شانشین\f + \fr 8:12 \ft مەبەستی لە جولەکەیە.‏\f* فڕێدەدرێنە تاریکی دەرەوە، جا گریان و جیڕەی ددان لەوێ دەبێت.»
\p 
\v 13 ئینجا عیسا بە سەرپەلەکەی فەرموو: «بڕۆ! با هەروەک باوەڕت هێنا، بۆت ببێت.» جا لەو کاتەدا خزمەتکارەکەی چاک بووەوە.
\s1 چاککردنەوەی خەسووی پەترۆس
\p 
\v 14 عیسا هاتە ماڵی پەترۆس، خەسووی پەترۆسی بینی لەناو جێگادا کەوتووە، تای هەیە.
\v 15 عیسا دەستی لە دەستی دا و تایەکە بەریدا. ئەویش هەستا و دەستی کرد بە خزمەتکردنیان.
\p 
\v 16 کاتێک ئێوارە داهات، زۆر کەسیان بۆ هێنا ڕۆحی پیسیان تێدابوو، ئەویش بە وشەیەک ڕۆحە پیسەکانی دەرکرد و هەموو نەخۆشەکانی چاککردەوە،
\v 17 تاکو ئەوەی لە ڕێگەی پێغەمبەر ئیشایاوە گوتراوە بێتە دی کە دەڵێ:
\q1 ﴿ئەو دەردەکانی ئێمەی هەڵگرت و
\q2 نەخۆشییەکانمانی برد.﴾\f + \fr 8:17 \ft \xt ئیشایا 53‏:4‏\xt*\ft ‏.‏\f*
\s1 نرخی شوێنکەوتنی عیسا
\p 
\v 18 کاتێک عیسا خەڵکێکی زۆری لە دەوری خۆی بینی، فەرمانی بە قوتابییەکانی دا کە بپەڕنەوە ئەوبەری دەریاچەکە.
\v 19 مامۆستایەکی تەورات هاتە لای و پێی گوت: «مامۆستا، بۆ هەرکوێ بچیت دوات دەکەوم.»
\p 
\v 20 عیساش پێی فەرموو: «ڕێوی کونی هەیە و باڵندەی ئاسمانیش هێلانە، بەڵام کوڕی مرۆڤ\f + \fr 8:20 \ft کوڕی مرۆڤ: مەسیح بەم نازناوە خۆی دەناسێنێت. بڕوانە \xt دانیال 7‏:13‏-14.‏\xt*\ft ‏\f* جێیەکی نییە کە سەری لەسەر دابنێت.»
\p 
\v 21 یەکێکی دیکە لە قوتابییەکانی پێی گوت: «گەورەم، ڕێگام بدە یەکەم جار بچم باوکم بنێژم.»\f + \fr 8:21 \ft مەبەستی ئەوەیە کە لەگەڵ باوکی بێت هەتا ئەو کاتەی دەمرێت.‏\f*
\p 
\v 22 بەڵام عیسا پێی فەرموو: «دوام بکەوە، واز لە مردووان بهێنە با مردووەکانی خۆیان بنێژن.»
\s1 عیسا ڕەشەبا هێمن دەکاتەوە
\p 
\v 23 کاتێک عیسا سواری بەلەمەکە بوو، قوتابییەکانی دوای کەوتن.
\v 24 لەناکاو ڕەشەبایەکی بەهێز هەڵیکردە سەر دەریاچەکە، خەریک بوو شەپۆلەکان بەلەمەکە داپۆشن، بەڵام عیسا نوستبوو.
\v 25 ئینجا قوتابییەکانی چوون و هەڵیانستاند و گوتیان: «گەورەم، ڕزگارمان بکە! وا لەناودەچین!»
\p 
\v 26 ئەویش پێی فەرموون: «ئەی کەم باوەڕینە، بۆچی دەترسن؟» ئینجا هەستا، لە ڕەشەبا و دەریاچەکەی ڕاخوڕی، ئیتر بووە هێمنییەکی تەواو.
\p 
\v 27 ئەوانیش سەرسام بوون و گوتیان: «ئەمە چ مرۆڤێکە؟ تەنانەت با و دەریاش گوێڕایەڵی دەبن!»
\s1 دەرکردنی ڕۆحی پیس
\p 
\v 28 کاتێک عیسا گەیشتە ئەوبەری دەریاچەکە، لە هەرێمی گەدەرین، دوو کەسی تووش بوو کە ڕۆحی پیسیان تێدابوو، لە گۆڕستانەوە هاتبوونە دەرەوە. بە ڕادەیەک توندوتیژ بوون کە تەنانەت کەس نەیدەتوانی بەو ڕێگایەدا تێبپەڕێت.
\v 29 هاواریان کرد و گوتیان: «چیت لێمان دەوێ، ئەی کوڕی خودا؟ ئایا پێشوەخت بۆ ئێرە هاتوویت، تاکو ئەشکەنجەمان بدەیت؟»
\p 
\v 30 لە دووری ئەوانەوە ڕانە بەرازێکی گەورە دەلەوەڕان.
\v 31 ڕۆحە پیسەکانیش لێی پاڕانەوە و گوتیان: «ئەگەر دەرماندەکەیت، بماننێرە ناو ڕانە بەرازەکە.»
\p 
\v 32 ئەویش پێی فەرموون: «بڕۆن!» ئەوانیش لە دوو کەسەکە هاتنە دەرەوە و چوونە ناو بەرازەکان، ئەوە بوو هەموو ڕانەکە بە خێرایی لە قەدپاڵەکەوە بۆ ناو دەریاچەکە هەڵدێران و لە ئاوەکەدا خنکان.
\v 33 بەرازەوانەکانیش ڕایانکرد بۆ ناو شار و هەموو شتێکیان گێڕایەوە، بگرە ئەو ڕووداوەشیان گێڕایەوە کە بەسەر ئەوانەدا هاتبوو کە ڕۆحی پیسیان تێدابوو.
\v 34 ئەوە بوو شارەکە هەمووی بۆ بینینی عیسا هاتنە دەرەوە، کە بینییان، لێی پاڕانەوە ناوچەکەیان بەجێبهێڵێت.
\c 9
\s1 چاککردنەوەی ئیفلیجێک
\p 
\v 1 ئینجا عیسا سواری بەلەمێک بوو، پەڕییەوە و هاتەوە شارەکەی خۆی\f + \fr 9:1 \ft ناسیرە.‏\f*.
\v 2 کابرایەکی ئیفلیجیان هێنایە لای لەناو جێگادا کەوتبوو، کاتێک عیسا باوەڕی ئەوانی بینی، بە ئیفلیجەکەی فەرموو: «کوڕم، ورەت بەرز بێت، گوناهەکانت بەخشران.»
\p 
\v 3 جا هەندێک لە مامۆستایانی تەورات لە دڵی خۆیاندا گوتیان: «ئەمە کفر دەکات!»
\p 
\v 4 عیساش زانی بیر لە چی دەکەنەوە و فەرمووی: «بۆچی لە دڵتاندا بیر لە خراپە دەکەنەوە؟
\v 5 کامیان ئاسانترە بگوترێت، ”گوناهەکانت بەخشران،“ یان بگوترێت، ”هەستە و بڕۆ“؟
\v 6 بەڵام بۆ ئەوەی بزانن کوڕی مرۆڤ لەسەر زەوی دەسەڵاتی گوناهبەخشینی هەیە،…» بە ئیفلیجەکەی فەرموو: «هەستە، نوێنەکەت هەڵگرە و بڕۆرەوە ماڵەوە.»
\v 7 ئەویش هەستا و گەڕایەوە ماڵ.
\v 8 کاتێک خەڵکەکە ئەمەیان بینی، سام دایگرتن و ستایشی خودایان کرد، کە دەسەڵاتی ئاوای بە مرۆڤ داوە.
\s1 عیسا بۆ گوناهباران هاتووە
\p 
\v 9 کاتێک عیسا بەوێدا تێدەپەڕی، پیاوێکی بینی لە شوێنی باجگری دانیشتبوو، ناوی مەتا بوو. پێی فەرموو: «دوام بکەوە.» ئەویش هەستا و دوای کەوت.
\p 
\v 10 لە کاتێکدا عیسا لە ماڵی مەتا لەسەر خوان بوو، زۆر لە باجگران و گوناهباران هاتن و لەگەڵ عیسا و قوتابییەکانی بۆ نانخواردن پاڵیاندایەوە.
\v 11 کە فەریسییەکان ئەمەیان بینی، بە قوتابییەکانی ئەویان گوت: «بۆچی مامۆستاکەتان لەگەڵ باجگر و گوناهباران نان دەخوات؟»
\p 
\v 12 جا کاتێک عیسا گوێی لێبوو، فەرمووی: «لەشساغ پێویستی بە پزیشک نییە، بەڵکو نەخۆش.
\v 13 بڕۆن و واتای ئەمە فێربن: ﴿من میهرەبانیم دەوێ نەک قوربانی.﴾\f + \fr 9:13 \ft \xt هۆشەع 6‏:6‏\xt*\ft ‏\f* چونکە نەهاتووم ڕاستودروستان بانگهێشت بکەم، بەڵکو گوناهباران.»
\s1 لەبارەی ڕۆژووەوە
\p 
\v 14 ئینجا قوتابییەکانی یەحیا هاتنە لای عیسا و گوتیان: «بۆچی ئێمە و فەریسییەکان زۆر جار بەڕۆژوو دەبین، بەڵام قوتابییەکانی تۆ بەڕۆژوو نابن؟»
\p 
\v 15 عیسا پێی فەرموون: «ئایا بانگهێشتکراوانی زەماوەند دەتوانن شیوەن بگێڕن کاتێک زاوا لەگەڵیاندایە؟ بەڵام ڕۆژێک دێت زاوایان لێ دوور دەخرێتەوە، ئەوسا بەڕۆژوو دەبن.
\p 
\v 16 «کەس کراسی کۆن بە پەڕۆیەک کە نەچووبێتە ئاو پینە ناکات، چونکە پینەکە کراسەکە لێک ڕادەکێشێت و دڕاوییەکە خراپتر دەکات.
\v 17 شەرابی نوێش ناکەنە ناو مەشکەی کۆنەوە، ئەگینا مەشکەکە دەدڕێت، جا شەرابەکە دەڕژێت و مەشکەکەش لەناودەچێت. بەڵکو شەرابی نوێ دەکرێتە ناو مەشکەی نوێوە و هەردووکیان پارێزراو دەبن.»
\s1 زیندووکردنەوەی کچێک و چاککردنەوەی ژنێک
\p 
\v 18 کاتێک ئەمانەی دەفەرموو، یەکێک لە پێشەوایانی کەنیشت\f + \fr 9:18 \ft پێشەوای کەنیشت.‏\f* هات و کڕنۆشی بۆ برد و گوتی: «هەر ئێستا کچەکەم مرد، بەڵام وەرە دەستی لەسەر دابنێ، زیندوو دەبێتەوە.»
\v 19 عیساش هەستا و لەگەڵی چوو، قوتابییەکانیش دوایان کەوتن.
\p 
\v 20 هەر لەو کاتەدا ژنێک کە ماوەی دوازدە ساڵ بوو خوێنبەربوونی هەبوو، لە دواوە لێی نزیک بووەوە و دەستی لە چمکی کراسەکەی دا،
\v 21 چونکە لە دڵی خۆیدا گوتی: «ئەگەر تەنها دەست لە کراسەکەی بدەم، چاکدەبمەوە.»
\p 
\v 22 عیسا ئاوڕی دایەوە، بینی و فەرمووی: «کچم دڵنیابە، باوەڕەکەت تۆی چاککردەوە.» ژنەکە دەستبەجێ چاک بووەوە.
\p 
\v 23 کاتێک عیسا چووە ماڵی پێشەواکە، شیوەنگێڕان\f + \fr 9:23 \ft لەلای جولەکەکان باو بووە کە بە شمشاڵ لێدان شیوەن بۆ مردوو بگێڕن وەک سەردولکەبێژ.‏\f* و خەڵکێکی زۆری بینی کە دەنگەدەنگیان دەکرد،
\v 24 فەرمووی: «لاچن، کچەکە نەمردووە، بەڵکو نوستووە.» ئەوانیش پێی پێکەنین.
\v 25 کاتێک خەڵکەکە دەرکران، هاتە ژوورەوە و دەستی کچەکەی گرت، کچەش هەستایەوە.
\v 26 ئەم هەواڵەش بە هەموو ئەو ناوچەیەدا بڵاو بووەوە.
\s1 چاککردنەوەی دوو کەسی نابینا
\p 
\v 27 کاتێک عیسا بەوێدا تێدەپەڕی، دوو کەسی نابینا دوای کەوتن، هاواریان دەکرد و دەیانگوت: «کوڕی داود، بەزەییت پێماندا بێتەوە.»
\p 
\v 28 کاتێک هاتە ماڵەوە، کەسە نابیناکان هاتنە لای. عیساش پێی فەرموون: «باوەڕتان بەوە هەیە کە من بتوانم ئەمە بکەم؟»
\p وەڵامیان دایەوە: «بەڵێ گەورەم.»
\p 
\v 29 ئینجا ئەویش دەستی لە چاویان دا و فەرمووی: «با بەگوێرەی باوەڕتان بۆتان ببێت.»
\v 30 ئیتر بیناییان بۆ گەڕایەوە، عیساش بە توندی ئاگاداری کردنەوە: «ئاگاداربن با کەس نەزانێت.»
\v 31 بەڵام ئەوان ڕۆیشتن و هەواڵی ئەویان لە هەموو ناوچەکەدا بڵاوکردەوە.
\s1 لاڵێک دەکەوێتە قسەکردن
\p 
\v 32 کاتێک دوو کابراکە دەچوونە دەرەوە، چەند کەسێک لاڵێکیان هێنایە لای عیسا کە ڕۆحی پیسی تێدابوو.
\v 33 کاتێک ڕۆحە پیسەکە دەرکرا، لاڵەکە قسەی کرد. خەڵکەکەش سەرسام بوون و گوتیان: «هەرگیز شتی لەم جۆرە لە ئیسرائیلدا نەبینراوە.»
\p 
\v 34 بەڵام فەریسییەکان گوتیان: «بە شای ڕۆحە پیسەکان ڕۆحی پیس دەردەکات.»
\s1 دروێنەی زۆر و سەپانی کەم
\p 
\v 35 عیسا بە هەموو شار و گوندەکاندا دەگەڕا، لە کەنیشتەکانیان خەڵکی فێر دەکرد و مزگێنی پاشایەتییەکەی ڕادەگەیاند و هەموو نەخۆشی و نەساغییەکی چاک دەکردەوە.
\v 36 کاتێک خەڵکەکەی بینی دڵی پێیان سووتا، چونکە وەک مەڕی بێ شوان پەرێشان و سەرلێشێواو بوون.
\v 37 جا بە قوتابییەکانی فەرموو: «دروێنە زۆرە، بەڵام سەپان\f + \fr 9:37 \ft سەپان: پاڵە، وەرزێر، ئەو کەسەی دەغڵ و دان دەدروێتەوە.\f* کەمە.
\v 38 لەبەر ئەوە داوا لە خاوەنی دروێنە بکەن تاکو سەپان بۆ دروێنەکەی بنێرێت.»
\c 10
\s1 بانگکردنی دوازدە نێردراوەکە
\p 
\v 1 ئینجا عیسا دوازدە قوتابییەکەی بانگکرد، دەسەڵاتی پێدان تاکو ڕۆحی پیس دەربکەن و هەرچی نەخۆشی و نەساغی هەبوو، چاکی بکەنەوە.
\b
\li4 
\v 2 ئەمانەش ناوی دوازدە نێردراوەکەیە:
\b
\li1 یەکەمین، شیمۆن کە بە پەترۆس ناودەبردرا و ئەندراوسی برای؛
\li1 یاقوبی کوڕی زەبدی و یۆحەنای برای؛
\li1 
\v 3 فیلیپۆس و بەرتۆلماوس؛
\li1 تۆماس و مەتای باجگر؛
\li1 یاقوبی کوڕی حەلفا و تەداوس؛
\li1 
\v 4 شیمۆنی کانەوی\f + \fr 10:4 \ft کانەوی پارتێکی نەتەوەیی ڕادیکالی جولەکە بوو، شیمۆنیش سەر بەو پارتە بوو. بڕوانە \xt لۆقا 6‏:15‏\xt*\ft ‏.‏\f* و یەهوزای ئەسخەریوتی کە عیسای بە گرتن دا.
\b
\s1 عیسا نێردراوەکانی دەنێرێت
\p 
\v 5 عیسا ئەم دوازدە کەسەی نارد، فەرمانی پێ کردن: «بە ڕێگای ناجولەکەکاندا مەڕۆن و مەچنە شاری سامیرەییەکان،
\v 6 بەڵکو لەبری ئەوە بڕۆنە لای مەڕە ونبووەکانی ماڵی ئیسرائیل.
\v 7 کاتێک دەچن، ئەم پەیامە ڕابگەیەنن: ”پاشایەتی ئاسمان نزیک بووەتەوە.“
\v 8 نەخۆش چاک بکەنەوە، مردوو زیندوو بکەنەوە، گەڕوگول پاک بکەنەوە، ڕۆحی پیس دەربکەن. بەخۆڕایی وەرتانگرتووە، بەخۆڕاییش بیدەن.
\p 
\v 9 «زێڕ و زیو و مس لە پشتێنتان هەڵمەگرن،
\v 10 نە توورەکە بۆ ڕێگا، نە کراس و نە پێڵاوی زیادە و نە گۆچانیش، چونکە کرێکار شایانی نانی خۆیەتی.
\v 11 چوونە هەر شار و گوندێک، بە شوێن کەسێکی شایستەدا بگەڕێن و هەتا ئەوێ بەجێدەهێڵن لە ماڵی ئەو کەسە بمێننەوە.
\v 12 کە چوونە ماڵەکە سڵاو بکەن.
\v 13 ئەگەر ماڵەکە شایستە بوون، با ئاشتیتان بۆیان بێت، بەڵام ئەگەر شایستە نەبوون، با ئاشتیتان بۆ خۆتان بگەڕێتەوە.
\v 14 ئەوەی پێشوازی لێ نەکردن و گوێی لە قسەتان نەگرت، لەو ماڵە یان لەو شارۆچکەیە بڕۆنە دەرەوە و تۆزی پێتان بتەکێنن.
\v 15 ڕاستیتان پێ دەڵێم: لە ڕۆژی لێپرسینەوەدا، سزای خاکی سەدۆم و عەمۆرا لە هی ئەم شارە سووکتر دەبێت.
\p 
\v 16 «من وەک مەڕ بۆ ناو گورگتان دەنێرم. جا وەک مار ژیر بن و وەک کۆتر لە خراپە بێبەری بن.
\v 17 لە خەڵکی بەئاگابن، چونکە دەتاندەنە دادگا و لە کەنیشتەکان بە قامچی لێتان دەدەن،
\v 18 لە پێناوی مندا دەبردرێنە بەردەم فەرمانڕەوا و پاشایان، وەک شایەتی بۆ ئەوان و بۆ نەتەوەکانیش.
\v 19 کاتێکیش بە گرتنتان دەدەن، نیگەران مەبن لەوەی کە چی بڵێن و چۆن بیڵێن، لەو کاتەدا پێتان دەدرێت چی بڵێن،
\v 20 لەبەر ئەوەی ئەوە ئێوە نین کە قسە دەکەن، بەڵکو ڕۆحی باوکتانە لە ئێوەدا قسە دەکات.
\p 
\v 21 «برا برای خۆی بۆ مردن بە دەستەوە دەدات، باوکیش منداڵی خۆی. منداڵان لە دایک و باوکیان هەڵدەگەڕێنەوە و بە کوشتنیان دەدەن.
\v 22 لەبەر ناوی من هەمووان ڕقیان لێتان دەبێتەوە، بەڵام ئەوەی هەتا کۆتایی دانبەخۆیدا بگرێت، ڕزگاری دەبێت.
\v 23 کە لەم شارە دەتانچەوسێننەوە، ڕاکەن بۆ شارێکی دیکە. ڕاستیتان پێ دەڵێم: شارەکانی ئیسرائیل تەواو ناکەن پێش هاتنی کوڕی مرۆڤ\f + \fr 10:23 \ft هاتنی کوڕی مرۆڤ: زۆربەی شارەزایان هاوڕان لەسەر ئەوەی کە لێرەدا مەبەست لە هاتنەوەی عیسایە لە ڕۆژی دوایی.‏\f*.
\s1 مەترسن
\p 
\v 24 «قوتابی لە مامۆستاکەی زیاتر نییە و کۆیلەش لە گەورەکەی زیاتر نییە.
\v 25 بۆ قوتابی بەسە وەک مامۆستاکەی بێت و کۆیلەش وەک گەورەکەی. ئەگەر خاوەن ماڵ بە ”بەعل‌زەبول“\f + \fr 10:25 \ft بەعل‌زەبول: خوداوەندی شاری عەقرون بوو لە فەلەستین، بە واتای شەیتان دێت.‏\f* ناو ببردرێت، چەند زیاتر خانەوادەکەی؟
\p 
\v 26 «لەبەر ئەوە لێیان مەترسن، چونکە هیچ شتێکی شاردراوە نییە ئاشکرا نەبێت و نهێنی نییە دەرنەکەوێت.
\v 27 ئەوەی لە تاریکیدا پێتانی دەڵێم، لە ڕووناکیدا بیڵێنەوە، ئەوەی بە چرپە دەیبیستن، بە دەنگی بەرز لە سەربانان ڕایبگەیەنن.
\v 28 لەوانە مەترسن کە جەستە دەکوژن، بەڵام ناتوانن گیان بکوژن، بەڵکو لەوە بترسن کە دەتوانێ جەستە و گیان بە یەکەوە لە دۆزەخدا لەناوبەرێت.
\v 29 ئایا دوو چۆلەکە بە فلسێک نافرۆشرێت؟ کەچی هیچ یەکێکیان بەبێ خواستی باوکتان ناکەوێتە سەر زەوی.
\v 30 ئێوە تەنانەت مووی سەریشتان هەمووی ژمێردراوە.
\v 31 کەواتە مەترسن، ئێوە زۆر لە چۆلەکە بەنرخترن.
\p 
\v 32 «بۆیە ئەوەی لەبەردەم خەڵک دانم پێدا بنێت، منیش لەلای باوکم کە لە ئاسمانە، دانی پێدا دەنێم.
\v 33 بەڵام ئەوەی لەلای خەڵک نکۆڵی لە ناسینی من بکات، منیش لەلای باوکم کە لە ئاسمانە، نکۆڵی لێ دەکەم.
\s1 ئاشتی نا بەڵکو شمشێر
\p 
\v 34 «وا مەزانن کە هاتووم تاکو ئاشتی بهێنمە سەر زەوی. نەهاتووم بۆ هێنانی ئاشتی، بەڵکو شمشێر!\f + \fr 10:34 \ft واتا بەهۆی هاتنی مەسیح، خەڵک دژایەتی قوتابییەکانی دەکەن.‏\f*
\v 35 چونکە من هاتووم بۆ هەڵگەڕاندنەوەی
\q1 «﴿کوڕ لە باوکی و
\q2 کچ لە دایکی و
\q1 بووک لە خەسووی،
\q2 
\v 36 دوژمنی مرۆڤیش لە خانەوادەکەی خۆی دەبێت.﴾\f + \fr 10:36 \ft \xt میخا 7‏:6‏\xt*\ft ‏\f*
\p 
\v 37 «ئەوەی باوک یان دایکی لە من زیاتر خۆشبوێت، شایانی من نییە. ئەوەی کوڕ یان کچی لە من زیاتر خۆشبوێت، شایانی من نییە.
\v 38 ئەوەی خاچەکەی هەڵنەگرێت و دوام نەکەوێت شایانی من نییە.
\v 39 ئەوەی دەست بە ژیانییەوە بگرێت دەیدۆڕێنێت، بەڵام ئەوەی ژیانی خۆی لە پێناوی من بدۆڕێنێت، بەدەستی دەهێنێت.
\p 
\v 40 «ئەوەی پێشوازیتان لێ بکات، پێشوازی لە من دەکات، ئەوەش پێشوازی لە من بکات، پێشوازی لەوە دەکات کە منی ناردووە.
\v 41 ئەوەی پێشوازی لە پێغەمبەرێک بکات بە ناوی پێغەمبەر، ئەوا پاداشتی پێغەمبەرێک وەردەگرێت. ئەوەش پێشوازی لە پیاوچاکێک بکات بە ناوی پیاوچاک، ئەوا پاداشتی پیاوچاکێک وەردەگرێت.
\v 42 ئەوەی تەنها جامە ئاوێکی سارد بداتە یەکێک لەم بچووکانە، لەبەر ئەوەی قوتابی منن، ڕاستیتان پێ دەڵێم: پاداشتی ون نابێت.»
\c 11
\s1 عیسا و حەزرەتی یەحیا
\p 
\v 1 پاش ئەوەی عیسا لە ڕێنمایی دوازدە قوتابییەکەی تەواو بوو، لەوێ ڕۆیشت و چوو بۆ فێرکردن و ڕاگەیاندنی پەیامی خودا لە شارۆچکەکانیان.
\p 
\v 2 کاتێک یەحیا لە زینداندا کارەکانی مەسیحی بیست، قوتابییەکانی خۆی ناردە لای،
\v 3 لێیان پرسی: «ئایا تۆی ئەوەی کە دێت، یان چاوەڕێی یەکێکی دیکە بکەین؟»
\p 
\v 4 عیساش لە وەڵامدا پێی فەرموون: «بڕۆن، ئەوەی دەیبیستن و دەیبینن بە یەحیای ڕابگەیەنن:
\v 5 کوێر دەبینێت، شەل دەڕوات، گەڕوگول پاک دەبێتەوە، کەڕ دەبیستێت، مردوو هەڵدەستێتەوە و هەژار مزگێنی پێدەدرێت\f + \fr 11:5 \ft مەبەست لە هاتنی مەسیحە وەک ڕزگارکەر، بڕوانە \xt لۆقا 4‏:18‏\xt*\ft ‏.‏\f*.
\v 6 خۆزگە دەخوازرێ بەوەی گومانم لێ ناکات.»
\p 
\v 7 لە کاتێکدا قوتابییەکانی یەحیا دەڕۆیشتن، عیسا ڕووی لە خەڵکەکە کرد و سەبارەت بە یەحیا فەرمووی: «بۆ بینینی چی چوونە چۆڵەوانی؟ قامیشێک کە با دەیجوڵێنێتەوە؟
\v 8 ئەی بۆ بینینی چی چوون؟ مرۆڤێک کە جلوبەرگی گرانبەهای پۆشیوە؟ نەخێر، ئەوانەی جلوبەرگی گرانبەها دەپۆشن لە کۆشکی پاشاکانن.
\v 9 ئیتر بۆ بینینی چی چوون؟ پێغەمبەرێک؟ بەڵێ، پێتان دەڵێم، لە پێغەمبەریش مەزنتر.
\v 10 یەحیا ئەو کەسەیە کە دەربارەی نووسراوە:
\q1 «﴿من نێردراوی خۆم لەپێشتەوە دەنێرم،
\q2 ئەوەی ڕێگات بۆ ئامادە دەکات.﴾\f + \fr 11:10 \ft \xt مەلاخی 3‏:1‏\xt*\ft ‏\f*
\m 
\v 11 ڕاستیتان پێ دەڵێم: لەنێو ئەوانەی لە ژن لەدایک بوون، کەس لە یەحیای لەئاوهەڵکێش پایەبەرزتر نییە، بەڵام بچووکترینی ئەوەی لە شانشینی ئاسمانە لەو پایەبەرزترە.
\v 12 لە ڕۆژانی یەحیای لەئاوهەڵکێشەوە هەتا ئێستا شانشینی ئاسمان بە هێز تێدەکۆشێت، تێکۆشەرانیش دەستی پێوەدەگرن\f + \fr 11:12 \ft بڕوانە \xt لۆقا 16‏:16‏\xt*\ft ‏.‏\f*،
\v 13 چونکە هەموو پێغەمبەران و تەورات، هەتا هاتنی یەحیا پێشبینییان کردووە.
\v 14 ئەگەر دەتانەوێ پەسەندی بکەن، ئەم یەحیایە ئەو ئەلیاسەیە کە خەریکە بێت\f + \fr 11:14 \ft بڕوانە \xt مەلاخی 4‏:5،‏\xt*\ft ‏ پێش هاتنی ڕۆژی لێپرسینەوە ئەلیاس دێتەوە.‏\f*.
\v 15 ئەوەی گوێی هەیە، با ببیستێت!
\p 
\v 16 «بەڵام ئەم نەوەیە بە چی بەراورد بکەم؟ لەو منداڵانە دەچن کە لە بازاڕەکاندا دانیشتوون و یەکتری بانگ دەکەن و
\v 17 دەڵێن:
\q1 «”زوڕنامان بۆ لێدان و هەڵنەپەڕین،
\q2 شینمان بۆ گێڕان و لە خۆتان نەدا.“
\m 
\v 18 یەحیا هات، نەیدەخوارد و نەیدەخواردەوە، دەڵێن: ”ڕۆحی پیسی تێدایە.“
\v 19 ئینجا کوڕی مرۆڤ هات، دەخوات و دەخواتەوە، دەڵێن: ”ئەمە کابرایەکی نەوسن و مەیخۆرە، هاوڕێی باجگران و گوناهبارانە.“ بەڵام دانایی ڕاستەقینە لە کردارەکانیەوە دەردەکەوێت.»
\s1 شارە گوناهبارەکان
\p 
\v 20 ئینجا عیسا دەستی کرد بە سەرزەنشتکردنی ئەو شارانە کە زۆربەی پەرجووەکانی تێیاندا ئەنجام دابوو، چونکە تۆبەیان نەکردبوو.
\v 21 «قوڕبەسەرت، ئەی شاری خورازین! قوڕبەسەرت، ئەی بێت‌سەیدا! چونکە ئەو پەرجووانەی لەنێو ئێوەدا کران، ئەگەر لە سور و سەیدا بکرایە، ئەوا هەر زوو خەڵکەکەی بە جلوبەرگی گوش\f + \fr 11:21 \ft لە کاتی ماتەمگێڕان و تۆبەکردندا جلوبەرگی لە گوش دروستکراویان لەبەرکردووە کە ئەزیەتی پێستیانی داوە.‏\f* و لەناو خۆڵەمێشدا تۆبەیان دەکرد.
\v 22 بەڵام پێتان دەڵێم: لە ڕۆژی لێپرسینەوەدا سزای سور و سەیدا سووکتر دەبێت لەوەی بۆ ئێوەیە.
\v 23 تۆش ئەی کەفەرناحوم، ئایا بۆ ئاسمان بەرز دەکرێیتەوە؟ نەخێر، تۆ بۆ جیهانی مردووان\f + \fr 11:23 \ft یۆنانی: \tl هادیس‏\tl*: لە ئەندێشە یۆنانییەکان شوێنی ڕۆحی مردووانە لەدوای مردن و بەر لە حوکمدانی یەکجارەکی. بەرامبەر \tl شیۆل‏\tl*ی پەیمانی کۆنە. بڕوانە \xt پەیدابوون 37‏:35.‏\xt*\ft ‏\f* دەچیتە خوارەوە، چونکە ئەگەر ئەو پەرجووانەی کە لەنێو تۆدا کرا لە سەدۆمدا بکرابووایە، ئەوا تاکو ئەمڕۆ دەمایەوە.
\v 24 بەڵام پێتان دەڵێم: لە ڕۆژی لێپرسینەوەدا سزای خاکی سەدۆم لە هی تۆ سووکتر دەبێت.»
\s1 وەرن بۆ لام، من دەتانحەسێنمەوە
\p 
\v 25 لەو کاتەدا عیسا فەرمووی: «ئەی باوک سوپاست دەکەم، پەروەردگاری ئاسمان و زەوی، چونکە ئەمانەت لە دانا و تێگەیشتووان شاردووەتەوە و بۆ منداڵانت ئاشکرا کردووە.
\v 26 بەڵێ ئەی باوک، چونکە ئەمەت پێ باش بوو.
\p 
\v 27 «باوکم هەموو شتێکی پێ سپاردووم، کەس کوڕەکە ناناسێت باوک نەبێت، کەسیش باوک ناناسێت تەنها کوڕەکە و ئەو کەسانە نەبێت کە کوڕەکە دەیەوێ بۆیانی ئاشکرا بکات.
\p 
\v 28 «وەرن بۆ لام ئەی هەموو ماندووان و بارگرانەکان، من دەتانحەسێنمەوە.
\v 29 نیری\f + \fr 11:29 \fq نیر: \ft دارێکە دەخرێتە سەر شانی گا یان ڕەشەوڵاخ بۆ ڕاکێشانی عەرەبانە یان ئامێری جووت. \f* من بخەنە سەر خۆتان و لە منەوە فێربن، چونکە دڵنەرم و بێفیزم، حەسانەوەش بۆ دەروونتان دەدۆزنەوە،
\v 30 چونکە نیرەکەم گونجاوە و بارم سووکە.»
\c 12
\s1 گەورەی ڕۆژی شەممە
\p 
\v 1 لەو کاتەدا، لە ڕۆژێکی شەممەدا عیسا بەناو دەغڵدا تێدەپەڕی، قوتابییەکانی برسییان بوو، دەستیان کرد بە گوڵەگەنم پرواندن و خواردنی.
\v 2 کە فەریسییەکان بینییان، پێیان گوت: «بڕوانە، ئەوەی قوتابییەکانت دەیکەن دروست نییە لە شەممەدا بکرێت.»
\p 
\v 3 ئەویش پێی فەرموون: «ئایا نەتانخوێندووەتەوە داود چی کرد\f + \fr 12:3 \ft بڕوانە \xt یەکەم ساموئێل 21‏:6.‏\xt*\ft ‏\f*، کاتێک خۆی و ئەوانەی لەگەڵی بوون برسییان بوو؟
\v 4 چۆن چووە ناو ماڵی خودا و نانی تەرخانکراوی\f + \fr 12:4 \ft ئەم نانە پێشکەشی خودا کراوە لە پەرستگا و بۆی تەرخانکراوە، تەنها کاهینان بۆیان هەبوو لەو نانە بخۆن. بڕوانە \xt دەرچوون 25‏:30‏\xt*\ft ‏.‏\f* خوارد، کە بۆ ئەو و ئەوانەی لەگەڵی بوون دروست نەبوو بیخۆن، تەنها بۆ کاهینان نەبێ؟
\v 5 یان لە تەوراتدا نەتانخوێندووەتەوە کە هەرچەندە کاهینان بەهۆی ئەرکیان لە پەرستگا لە ڕۆژانی شەممەدا ڕاسپاردەی ڕۆژی شەممە دەشکێنن بەڵام بە بێتاوان دادەنرێن؟
\v 6 پێتان دەڵێم، کەسێک لێرەیە کە لە پەرستگا مەزنترە.
\v 7 بەڵام ئەگەر لە واتای ئەمە تێبگەیشتنایە: ﴿من میهرەبانیم دەوێ نەک قوربانی،﴾\f + \fr 12:7 \ft \xt هۆشەع 6‏:6‏\xt*\ft ‏\f* ئەوا بێتاوانتان تاوانبار نەدەکرد،
\v 8 چونکە کوڕی مرۆڤ گەورەی ڕۆژی شەممەیە.»
\s1 چاککردنەوەی نەخۆش لە ڕۆژی شەممە
\p 
\v 9 ئینجا عیسا لەوێ ڕۆیشت و چووە کەنیشتەکەیان،
\v 10 لەوێ پیاوێکی لێبوو دەستێکی وشک ببوو. بۆ ئەوەی فەریسییەکان بتوانن سکاڵای لێ بکەن، لێیان پرسی: «ئایا لە ڕۆژی شەممەدا چاککردنەوەی نەخۆش دروستە؟»
\p 
\v 11 پێی فەرموون: «کێ لە ئێوە ئەگەر مەڕێکی هەبێت و لە ڕۆژی شەممەدا بکەوێتە ناو چاڵێکەوە، نایگرێت و دەریناهێنێت؟
\v 12 مرۆڤ چەند لە مەڕ بەنرخترە! کەواتە لە شەممەدا چاکەکردن دروستە.»
\p 
\v 13 ئینجا بە پیاوەکەی فەرموو: «دەستت درێژ بکە.» ئەویش درێژی کرد و چاک بووەوە، وەکو ئەوەی دیکە.
\v 14 بەڵام فەریسییەکان کە هاتنە دەرەوە، تەگبیریان کرد چۆن بیکوژن.
\s1 بەندەی هەڵبژێردراوی خودا
\p 
\v 15 عیساش کە بەمەی زانی لەوێ ڕۆیشت و خەڵکێکی زۆر دوای کەوتن، ئەویش هەموو نەخۆشەکانی چاککردەوە.
\v 16 ئاگاداری کردنەوە لەلای کەس باسی نەکەن،
\v 17 تاکو ئەوەی لە ڕێگەی پێغەمبەر ئیشایاوە گوتراوە بێتە دی کە دەڵێت:
\q1 
\v 18 ﴿ئەوەتا خزمەتکارەکەم، ئەوەی هەڵمبژاردووە،
\q2 ئەو خۆشەویستەم کە پێی دڵشادم،
\q1 ڕۆحی خۆمی دەخەمە سەر،
\q2 جاڕی دادپەروەری بۆ نەتەوەکان دەدات.
\q1 
\v 19 شەڕ ناکات و هاوار ناکات،
\q2 کەسیش لە شەقامدا دەنگی نابیستێت.
\q1 
\v 20 قامیشێکی کوتراو ناشکێنێت،
\q2 پڵیتەیەکی پرتەپرتکەر ناکوژێنێتەوە،
\q1 هەتا دادپەروەری بە سەرکەوتن دەگەیەنێت.
\q2 
\v 21 نەتەوەکان هیوایان بە ناوی ئەو دەبێت.﴾\f + \fr 12:21 \ft \xt ئیشایا 42‏:1‏-4‏\xt*\ft ‏\f*
\s1 عیسا و شای ڕۆحە پیسەکان
\p 
\v 22 ئینجا پیاوێکیان بۆ هێنا ڕۆحی پیسی تێدابوو، نابینا و لاڵ بوو، ئەویش چاکیکردەوە بە جۆرێک کە توانی قسە بکات و ببینێت.
\v 23 خەڵکەکە هەموو سەرسام بوون و گوتیان: «ئەمە کوڕی داود نییە؟»
\p 
\v 24 بەڵام فەریسییەکان کە ئەمەیان بیست، گوتیان: «ئەمە ڕۆحی پیس دەرناکات، مەگەر بە بەعل‌زەبولی\f + \fr 12:24 \ft بڕوانە پەراوێزی \xt مەتا 10‏:25‏\xt*\ft ‏\f* شای ڕۆحە پیسەکان نەبێت.»
\p 
\v 25 بەڵام عیسا بە بیرکردنەوەی ئەوانی زانی، پێی فەرموون: «هەر شانشینێک دووبەرەکی تێدابێت، وێران دەبێت، هەر شارێک یان ماڵێک دووبەرەکی تێدابێت، خۆی ڕاناگرێت.
\v 26 ئەگەر شەیتان، شەیتان دەربکات، ئەوا دووبەرەکییان تێدایە، کەواتە چۆن شانشینەکەی خۆی ڕادەگرێت؟
\v 27 ئەگەر من بە بەعل‌زەبول ڕۆحی پیس دەربکەم، ئەی شوێنکەوتەکانی ئێوە بە کێ دەریاندەکەن؟ لەبەر ئەوە ئەوان دەبنە دادوەرتان.
\v 28 بەڵام ئەگەر من بە ڕۆحی خودا ڕۆحی پیس دەربکەم، ئەوا پاشایەتی خودا هاتووەتە سەرتان.
\p 
\v 29 «یان چۆن کەسێک دەتوانێ بچێتە ماڵی پیاوێکی بەهێز و شتەکانی تاڵان بکات، ئەگەر یەکەم جار نەیبەستێتەوە، ئینجا ماڵەکەی تاڵان بکات؟
\p 
\v 30 «ئەوەی لەگەڵ من نییە لە دژی منە، ئەوەش لەگەڵ من کۆناکاتەوە، بڵاو دەکاتەوە.
\v 31 لەبەر ئەوە پێتان دەڵێم: هەموو گوناه و کفرکردنێکی مرۆڤ دەبەخشرێت، بەڵام کفرکردن سەبارەت بە ڕۆحی پیرۆز نابەخشرێت.
\v 32 ئەوەی قسە لە دژی کوڕی مرۆڤ بکات، دەبەخشرێت، بەڵام ئەوەی قسە لە دژی ڕۆحی پیرۆز بکات، نابەخشرێت، نە لەم دنیا و نە لەو دنیا.
\s1 دار بە بەرهەمی دەناسرێت
\p 
\v 33 «دار بە بەرهەمەکەی دەناسرێتەوە. ئەگەر دار باش بێت، بەرهەمی باش دەدات، ئەگەر دار خراپ بێت، بەرهەمی خراپ دەدات.
\v 34 ئەی بێچووە ماران، کە ئێوە خراپ بن، چۆن دەتوانن بە چاکە بدوێن؟ دەم ئەوە دەڵێت کە لە دڵەوە هەڵدەقوڵێت.
\v 35 مرۆڤی چاک لە گەنجینەی چاکی ناخیدا، شتی چاک دەردەهێنێت، مرۆڤی خراپیش لە گەنجینەی خراپی ناخیدا، شتی خراپ دەردەهێنێت.
\v 36 بەڵام پێتان دەڵێم: هەر وشەیەکی پووچ کە خەڵک پێی دەدوێ، لە ڕۆژی لێپرسینەوەدا حیسابی خۆی هەیە،
\v 37 چونکە بە وشەکانی خۆت بێتاوان دەکرێیت، بە وشەکانی خۆشت تاوانبار دەکرێیت.»
\s1 نیشانەی یونسی پێغەمبەر
\p 
\v 38 ئینجا هەندێک مامۆستای تەورات و فەریسی وەڵامیان دایەوە و گوتیان: «مامۆستا، دەمانەوێ نیشانەیەکت لێ ببینین.»
\p 
\v 39 کەچی وەڵامی دانەوە: «نەوەیەکی بەدکار و داوێنپیس\f + \fr 12:39 \ft لێرەدا مەبەست لە واتای مەجازی داوێنپیسییە، بەو واتایەی کە گەلی خودا دڵسۆز نەبوون بۆ خودای یاقوب و سەرپێچی فەرمانەکانیان کردووە.‏\f* داوای نیشانە دەکات، بەڵام نیشانەی نادرێتێ، جگە لە نیشانەی یونسی پێغەمبەر.
\v 40 هەروەک چۆن یونس سێ شەو و سێ ڕۆژ لەناو سکی ماسییەکی گەورەدا بوو، ئاواش کوڕی مرۆڤ سێ شەو و سێ ڕۆژ لە ناخی زەویدا دەمێنێتەوە.
\v 41 خەڵکی نەینەوا لە ڕۆژی لێپرسینەوەدا، لەگەڵ ئەم نەوەیە لە مردن هەڵدەستنەوە و تاوانباری دەکەن، چونکە تۆبەیان کرد کاتێک یونس پەیامی خودای ڕاگەیاند. ئەوەتا لە یونس مەزنتر لێرەیە.
\v 42 شاژنی باشوور\f + \fr 12:42 \ft شاژنی باشوور: مەبەست شاژنە بەلقیسە کە لە سەردەمی حەزرەتی سلێمان فەرمانڕەوای یەمەن بوو.‏\f* لە ڕۆژی لێپرسینەوەدا لەگەڵ ئەم نەوەیە لە مردن هەڵدەستێتەوە و تاوانباری دەکات، چونکە لەوپەڕی زەوییەوە هات بۆ گوێگرتن لە دانایی سلێمان. ئەوەتا لە سلێمان مەزنتر لێرەیە.
\s1 گەڕانەوەی ڕۆحی پیس
\p 
\v 43 «کاتێک ڕۆحی پیس لە مرۆڤێک دەردەچێت، لە شوێنە وشکەکاندا بەدوای حەوانەوەدا دەگەڕێت و دەستی ناکەوێت.
\v 44 ئینجا دەڵێت: ”دەگەڕێمەوە بۆ ئەو ماڵەی کە بەجێمهێشت.“ کاتێک دەگەڕێتەوە دەبینێت چۆڵە و گسکدراوە و ڕێکخراوە.
\v 45 ئەوسا دەچێت و حەوت ڕۆحی پیسی دیکە لە خۆی خراپتر لەگەڵ خۆی دەهێنێت، دەچنەوە نێو مرۆڤەکە و لەناویدا دەژین. ئینجا کۆتایی ئەو مرۆڤە لە جاران خراپتر دەبێت. بۆ ئەم نەوە بەدکارەش، ئاوا دەبێت.»
\s1 دایک و براکانی عیسا
\p 
\v 46 لە کاتێکدا کە عیسا قسەی بۆ خەڵکەکە دەکرد، دایک و براکانی لە دەرەوە ڕاوەستابوون، داوایان دەکرد لەگەڵی بدوێن.
\v 47 کەسێک هات و پێی گوت: «وا دایک و براکانت لە دەرەوە ڕاوەستاون، دەیانەوێ لەگەڵت بدوێن.»
\p 
\v 48 ئەویش وەڵامی دایەوە و فەرمووی: «دایکم کێیە و براکانم کێن؟»
\v 49 ئینجا دەستی بۆ قوتابییەکانی ڕاکێشا و فەرمووی: «ئەوەتا دایک و براکانم،
\v 50 چونکە ئەوەی خواستی باوکم ئەنجام بدات کە لە ئاسمانە، خوشک و برا و دایکمە.»
\c 13
\s1 نموونەی جوتیارێک
\p 
\v 1 هەر لەو ڕۆژەدا عیسا لە ماڵ هاتە دەرەوە و لە کەناری دەریاچەی جەلیل دانیشت.
\v 2 خەڵکێکی ئێجگار زۆر لێی کۆبووەوە، هەتا وای لێهات چووە ناو بەلەمێک دانیشت، هەموو خەڵکەکەش لە کەنارەکە ڕاوەستان.
\v 3 بە نموونە باسی زۆر شتی بۆ کردن و فەرمووی: «جوتیارێک چووە دەرەوە تۆو بکات.
\v 4 کە تۆوی دەوەشاند، هەندێکی کەوتنە سەر ڕێگا، باڵندەش هاتن و خواردیانن.
\v 5 هەندێکیش کەوتنە سەر زەوییەکی بەردەڵان کە خۆڵی کەم بوو، خێرا سەریان دەرکرد، چونکە زەوییەکەی قووڵ نەبوو.
\v 6 بەڵام کە ڕۆژ هەڵهات سووتان و وشک بوون، چونکە ڕەگیان نەبوو.
\v 7 هەندێکیشیان کەوتنە نێو دڕکان، دڕکەکان گەورە بوون و خنکاندیانن.
\v 8 بەڵام هەندێکی دیکەیان کەوتنە سەر زەوییەکی باش و بەرهەمیان دا، هەندێک یەک بە سەد و هەندێک یەک بە شەست و هەندێکیش یەک بە سی.
\v 9 ئەوەی گوێی هەیە، با ببیستێت!»
\s1 بۆچی عیسا بە نموونە دەدوێت؟
\p 
\v 10 قوتابییەکان هاتن و لێیان پرسی: «بۆچی بە نموونە قسەیان بۆ دەکەیت؟»
\p 
\v 11 وەڵامی دانەوە: «لەبەر ئەوەی بە ئێوە دراوە نهێنی شانشینی ئاسمان بزانن، بەڵام بەوان نەدراوە،
\v 12 چونکە ئەوەی هەیەتی، پێی دەدرێت و لێی دەڕژێ، بەڵام ئەوەی نییەتی، تەنانەت ئەوەی هەشیەتی لێی دەسەنرێتەوە.
\v 13 لەبەر ئەوە بە نموونە قسەیان بۆ دەکەم:
\q1 «چونکە سەیر دەکەن، بەڵام نابینن،
\q2 گوێ دەگرن، بەڵام نابیستن و تێناگەن.
\m 
\v 14 پێشبینییەکەی ئیشایا لەواندا هاتە دی، کە دەفەرموێ:
\q1 ﴿ئێوە هەمیشە دەبیستن بەڵام هەرگیز تێناگەن،
\q2 ئێوە هەمیشە سەیر دەکەن بەڵام هەرگیز نابینن،
\q1 
\v 15 چونکە دڵی ئەم گەلە ڕەق بووە و
\q2 گوێیان قورس بووە،
\q2 چاویان نوقاندووە،
\q1 نەوەک بە چاویان ببینن و
\q2 بە گوێیان ببیستن،
\q2 بە دڵیان تێبگەن و بگەڕێنەوە،
\q1 منیش چاکیان بکەمەوە.﴾\f + \fr 13:15 \ft \xt ئیشایا 6‏:9‏-10‏\xt*\ft ‏\f*
\m 
\v 16 بەڵام ئێوە، خۆزگە دەخوازرێت بە چاوتان، چونکە دەبینن، بە گوێتان، چونکە دەبیستن.
\v 17 ڕاستیتان پێ دەڵێم: زۆر پێغەمبەر و پیاوچاک بە ئاواتەوە بوون ئەوە ببینن کە ئێوە دەیبینن بەڵام نەیانبینی، ئەوەش ببیستن کە ئێوە دەیبیستن، بەڵام نەیانبیست.
\s1 ڕوونکردنەوەی نموونەی جوتیارەکە
\p 
\v 18 «کەواتە گوێ لە واتای نموونەی جوتیارەکە بگرن:
\v 19 هەرکەسێک پەیامی شانشین ببیستێت و تێینەگات، شەیتان\f + \fr 13:19 \ft یۆنانی: خراپەکارەکە.‏\f* دێت و ئەوەی لە دڵیدا تۆوکراوە دەیڕفێنێت. ئەمانە ئەو تۆوانەن کە کەوتنە سەر ڕێگاکە.
\v 20 ئەوانەی کەوتنە سەر بەردەڵانەکە، ئەو کەسانەن کە پەیامەکە دەبیستن و دەستبەجێ بە خۆشییەوە وەریدەگرن.
\v 21 بەڵام لەبەر ئەوەی کە ڕەگیان نییە و کاتین، کاتێک لەبەر پەیامەکە تووشی تەنگانە و چەوسانەوە دەبن، یەکسەر دەکەون.
\v 22 ئەوانەش کە کەوتنە نێو دڕکەکان، ئەو کەسانەن کە پەیامەکە دەبیستن، بەڵام خەمی ژیان و فریوخواردنی دەوڵەمەندی پەیامەکە دەخنکێنن، ئیتر بێ بەرهەم دەبن.
\v 23 بەڵام ئەوانەی کەوتنە سەر زەوییە باشەکە، ئەو کەسانەن کە پەیامەکە دەبیستن و لێی تێدەگەن و بەرهەم دەدەن، یەک بە سەد و یەک بە شەست و یەک بە سی.»
\s1 نموونەی گەنم و زیزان
\p 
\v 24 نموونەیەکی دیکەی بۆ هێنانەوە و فەرمووی: «شانشینی ئاسمان لە مرۆڤێک دەچێت، تۆوی چاک لە کێڵگەکەی بچێنێت.
\v 25 بەڵام کاتێک خەڵک لە خەودا بوون، دوژمنەکەی هات و لەناو گەنمەکەدا زیزانی چاند و ڕۆیشت.
\v 26 کاتێک گەنمەکە ڕوا و گوڵی دەرکرد، زیزانەکەش دەرکەوت.
\p 
\v 27 «کۆیلەی خاوەن ماڵ هاتن و پێیان گوت: ”گەورەم، مەگەر لە کێڵگەکەتدا تۆوی چاکت نەوەشاند، ئیتر ئەم زیزانە لەکوێوە هات؟“
\p 
\v 28 «ئەویش وەڵامی دانەوە: ”دوژمن ئەمەی کردووە.“ کۆیلەکانیش پێیان گوت: ”دەتەوێ بچین زیزانەکان بژار بکەین؟“»
\p 
\v 29 گوتی: «”نەخێر، نەوەک لەگەڵ بژارکردنی زیزان، گەنمیش هەڵبکێشن.
\v 30 هەتا کاتی دروێنە لێگەڕێن با بەیەکەوە پێبگەن، جا لە کاتی دروێنەدا بە سەپانەکان دەڵێم، یەکەم جار زیزانەکە بژار بکەن و بیانکەنە مەڵۆ بۆ ئەوەی بسووتێنرێن، بەڵام گەنمەکە لە ئەمبارەکەم کۆبکەنەوە.“»
\s1 نموونەی دەنکە خەرتەلە
\p 
\v 31 نموونەیەکی دیکەی بۆ هێنانەوە و فەرمووی: «شانشینی ئاسمان وەک دەنکە خەرتەلەیەک\f + \fr 13:31 \ft گیایەکی یەک ساڵەیە و چەندین جۆری هەیە. جۆرێکی لە وڵاتی ئیسرائیل هەیە کە بەرزییەکەی دەگاتە نزیکەی 3 بۆ 4 مەتر.‏\f* وایە، کە یەکێک بیهێنێت و لە کێڵگەکەیدا بیچێنێ،
\v 32 هەرچەندە لە هەموو تۆوەکانی دیکە بچووکترە، بەڵام کاتێک گەشە دەکات، ڕووەکێکی گەورەی لێ دەردەچێت و دەبێتە درەخت، تەنانەت باڵندەی ئاسمانیش دێن و لەسەر لقەکانی هێلانە دەکەن.»
\s1 نموونەی هەویرترش
\p 
\v 33 نموونەیەکی دیکەی بۆ هێنانەوە: «شانشینی ئاسمان لە هەویرترشێک\f + \fr 13:33 \ft هەویرترش: هەوێن، خومرە.‏\f* دەچێت، ئافرەتێک هێنای و کردییە ناو سێ پێوانە\f + \fr 13:33 \ft یۆنانی: سێ \tl ساتا‏\tl*، واتا 22 لیتر.‏\f* ئاردەوە، هەتا هەمووی هەڵهات.»
\p 
\v 34 عیسا هەموو ئەم بابەتانەی بە نموونە بۆ خەڵکەکە باسکرد، بەبێ نموونە قسەی بۆ نەدەکردن،
\v 35 تاکو ئەوەی خودا لە ڕێگەی پێغەمبەرەکەوە فەرموویەتی بێتە دی:
\q1 ﴿بە نموونە دەمم دەکەمەوە،
\q2 ئەوەی لە دامەزراندنی جیهانەوە شاراوەیە ڕایدەگەیەنم.﴾\f + \fr 13:35 \ft \xt زەبوورەکان 78‏:2‏\xt*\ft ‏\f*
\s1 ڕوونکردنەوەی نموونەی زیزان
\p 
\v 36 ئینجا خەڵکەکەی بەڕێکرد و گەڕایەوە بۆ ماڵ. قوتابییەکانی هاتنە لای و گوتیان: «نموونەی زیزانی ناو کێڵگەکەمان بۆ لێکبدەوە.»
\p 
\v 37 وەڵامی دایەوە: «ئەوەی تۆوە چاکەکەی چاند، کوڕی مرۆڤە.
\v 38 کێڵگەکەش جیهانە، تۆوە چاکەکەش ڕۆڵەکانی شانشینن، زیزانەکەش ڕۆڵەکانی شەیتانن،
\v 39 دوژمنەکەش کە تۆوی کردن ئیبلیسە، دروێنەکەش کۆتایی زەمانە\f + \fr 13:39 \ft مەبەست هاتنەوەی مەسیحە کاتێک لەسەر زەوی حوکم دەکات.‏\f*، سەپانەکانیش فریشتەکانن.
\p 
\v 40 «هەروەک چۆن زیزانەکە بژارکرا و بە ئاگر سووتێنرا، لە کۆتایی زەمانیشدا وا دەبێت.
\v 41 کوڕی مرۆڤ فریشتەکانی دەنێرێت و هەموو هۆکارێکی گوناه و خراپەکاران لە شانشینییەکەی کۆدەکەنەوە و
\v 42 فڕێیان دەدەنە ناو کوورەی ئاگرەوە، جا گریان و جیڕەی ددان لەوێ دەبێت.
\v 43 ئەوسا ڕاستودروستان لە شانشینی باوکیاندا وەک ڕۆژ دەدرەوشێنەوە. ئەوەی گوێی هەیە، با ببیستێت!
\s1 نموونەی گەنجینە و مرواری
\p 
\v 44 «شانشینی ئاسمان لە گەنجینەیەک دەچێت لە کێڵگەیەکدا شاردرابێتەوە. کەسێک دەیدۆزێتەوە و دیسان دەیشارێتەوە، ئینجا لە خۆشییان دەچێت و هەرچیی هەیە دەیفرۆشێت و ئەو کێڵگەیەی پێ دەکڕێت.
\p 
\v 45 «هەروەها شانشینی ئاسمان لە بازرگانێک دەچێت کە بە شوێن مرواری نایابدا دەگەڕێت.
\v 46 کاتێک مروارییەکی گرانبەها دەدۆزێتەوە، دەچێت هەرچیی هەیە دەیفرۆشێت و مروارییەکەی پێ دەکڕێت.
\s1 نموونەی تۆڕ
\p 
\v 47 «هەروەها شانشینی ئاسمان لە تۆڕێک دەچێت فڕێدرابێتە دەریاچەوە، لە هەموو جۆرەکانی ماسی کۆدەکاتەوە.
\v 48 کاتێک تۆڕەکە پڕ بوو، ماسیگرەکان ڕایانکێشایە کەنار، باشەکانیان لە سەبەتەدا کۆکردەوە و خراپەکانیشیان فڕێدا.
\v 49 کۆتایی زەمانیش ئاوا دەبێت: فریشتەکان دێن و بەدکاران لەناو ڕاستودروستاندا دەردەهێنن و
\v 50 فڕێیان دەدەنە ناو کوورەی ئاگرەوە. جا گریان و جیڕەی ددان لەوێ دەبێت.»
\p 
\v 51 عیسا لێی پرسین: «ئایا هەموو ئەمانە تێگەیشتن؟»
\p وەڵامیان دایەوە: «بەڵێ.»
\p 
\v 52 جا پێی فەرموون: «لەبەر ئەوە هەر مامۆستایەکی تەورات کە بووەتە قوتابی لە شانشینی ئاسمان، لە خاوەن ماڵێک دەچێت لە گەنجینەکەیدا لە کۆن و نوێ دەربهێنێت.»
\s1 ڕەتکردنەوەی عیسا
\p 
\v 53 کاتێک عیسا ئەم نموونانەی تەواو کرد، لەوێ ڕۆیشت.
\v 54 هاتەوە شارەکەی خۆی، لە کەنیشتەکەیان دەستی کرد بە فێرکردنیان، هەتا ئەوەی سەرسام بوون و گوتیان: «ئەمە ئەم دانایی و پەرجووانەی لەکوێ بوو؟
\v 55 ئایا ئەمە کوڕی دارتاشەکە نییە؟ ئەی دایکی ناوی مریەم نییە؟ یاقوب و یوسف و شیمۆن و یەهوزا برای نین؟
\v 56 ئەوە نییە خوشکەکانی هەموویان لەلامانن؟ ئەی ئەمە هەموو ئەمانەی لەکوێ بوو؟»
\v 57 جا ڕەتیان کردەوە.
\p بەڵام عیسا پێی فەرموون: «پێغەمبەر بێ ڕێز نییە، تەنها لە شار و ماڵی خۆی نەبێت.»
\p 
\v 58 لەوێ پەرجووی زۆری نەکرد، لەبەر بێباوەڕییان.
\c 14
\s1 کوشتنی حەزرەتی یەحیا
\p 
\v 1 لەو کاتەدا هێرۆدسی ئەنتیپاس کە فەرمانڕەوای\f + \fr 14:1 \ft یۆنانی: \tl تیترارک‏\tl*: فەرمانڕەوای هەرێمێک لە ئیمپراتۆریەتی ڕۆمانی.‏\f* جەلیل بوو، ناوبانگی عیسای بیست،
\v 2 بە پیاوەکانی گوت: «ئەمە یەحیای لەئاوهەڵکێشە لەناو مردوواندا هەستاوەتەوە، لەبەر ئەوە کاری پەرجوو لەسەر دەستی ئەو دەکرێت.»
\p 
\v 3 هێرۆدس، لەبەر هێرۆدیای ژنی فیلیپۆسی برای، یەحیای گرتبوو، پەلبەستی کردبوو و خستبوویە زیندانەوە،
\v 4 چونکە یەحیا پێی دەگوت: «دروست نییە براژنەکەت بخوازیت.»
\v 5 هێرۆدسیش دەیویست یەحیا بکوژێت، بەڵام لە خەڵکەکە دەترسا، چونکە بە پێغەمبەریان دادەنا.
\p 
\v 6 لە جەژنی لەدایکبوونی هێرۆدس، کچی هێرۆدیا لە ناوەڕاستی میواناندا سەمای کرد و هێرۆدسی دڵخۆش کرد.
\v 7 ئەویش سوێندی بۆ خوارد و بەڵێنی پێ دا کە حەزی لە چی بێت بیداتێ.
\v 8 کچەش بە فیتی دایکی، گوتی: «لێرە لەسەر سینییەک سەری یەحیای لەئاوهەڵکێشم بدەرێ.»
\v 9 پاشاش دڵگران بوو، بەڵام لەبەر ئەوەی لەبەردەم میوانەکاندا سوێندی خواردبوو، فەرمانی دا بیدەنێ.
\v 10 ئینجا ناردی و لە زیندان سەری یەحیایان پەڕاند و
\v 11 سەرەکەی لەسەر سینییەک هێنرا و درایە کچەکە، ئەویش بردییە لای دایکی.
\v 12 قوتابییەکانی یەحیا هاتن تەرمەکەیان هەڵگرت و ناشتیان. ئینجا چوون بۆ لای عیسا و هەواڵیان پێدا.
\s1 تێرکردنی پێنج هەزار کەس
\p 
\v 13 کە عیسا ئەمەی بیست، سواری بەلەمێک بوو و بە تەنها چووە شوێنێکی چۆڵ. کاتێک خەڵک بیستیان، لە شارەکانەوە بە پێیان دوای کەوتن.
\v 14 کاتێک عیسا لە بەلەمەکە دابەزی، خەڵکێکی بێشوماری بینی و دڵی پێیان سووتا و نەخۆشەکانی ئەوانی چاککردەوە.
\p 
\v 15 کاتێک ئێوارە داهات، قوتابییەکانی هاتنە لای و گوتیان: «ئەم شوێنە چۆڵە و کاتیش درەنگە. خەڵکەکە بەڕێ بکە با بڕۆنە گوندەکان و خواردن بۆ خۆیان بکڕن.»
\p 
\v 16 بەڵام عیسا پێی فەرموون: «پێویست ناکات بڕۆن. ئێوە شتێکیان بدەنێ با بیخۆن.»
\p 
\v 17 ئەوانیش وەڵامیان دایەوە: «لێرە لە پێنج نان و دوو ماسی زیاترمان نییە.»
\p 
\v 18 ئەویش فەرمووی: «بۆمی بهێننە ئێرە.»
\v 19 فەرمانی بە خەڵکەکە دا لەسەر گیاکە دانیشن. ئینجا پێنج نانەکە و دوو ماسییەکەی هەڵگرت و تەماشای ئاسمانی کرد، سوپاسی خودای کرد و نانەکانی لەتکرد، ئینجا دایە قوتابییەکان و ئەوانیش دایانە خەڵکەکە.
\v 20 هەموو خواردیان و تێر بوون، پاشان لەو پەلکەنانەی مایەوە دوازدە سەبەتەی پڕیان هەڵگرتەوە.
\v 21 ژمارەی ئەوانەی کە نانیان خوارد نزیکەی پێنج هەزار پیاو بوون، بێجگە لە ژن و منداڵ.
\s1 عیسا بەسەر ئاودا دەڕوات
\p 
\v 22 دەستبەجێ عیسا قوتابییەکانی ناچار کرد سواری بەلەمەکە بن و پێش خۆی بپەڕنەوە ئەوبەری دەریاچەکە، هەتا خۆی خەڵکەکە بەڕێ دەکات.
\v 23 لەدوای ئەوەی خەڵکەکەی بەڕێکرد، سەرکەوتە سەر شاخێک بۆ ئەوەی بە تەنها نوێژ بکات. کە ئێوارە داهات بە تەنها لەوێ بوو،
\v 24 بەلەمەکەش مەودایەکی زۆری لە وشکانییەوە بڕیبوو، شەپۆلەکانیش پێیاندا دەکێشا، چونکە ئاراستەی ڕەشەباکە پێچەوانە بوو.
\p 
\v 25 پێش خۆرهەڵاتن عیسا هاتە لایان و بەسەر دەریاچەکەدا دەڕۆیشت.
\v 26 کاتێک قوتابییەکان بینییان بەسەر دەریاچەکەدا دەڕوات، شێوان و گوتیان: «ئەمە دێوەزمەیە!» لە ترسانیشدا هاواریان کرد.
\p 
\v 27 دەستبەجێ عیسا قسەی لەگەڵ کردن: «ورەتان بەرز بێ! ئەوە منم. مەترسن.»
\p 
\v 28 پەترۆس وەڵامی دایەوە: «گەورەم، ئەگەر تۆی، فەرمانم پێبدە بەسەر ئاوەکەدا بێمە لات.»
\p 
\v 29 فەرمووی: «وەرە.» پەترۆس لە بەلەمەکە دابەزی و بەسەر ئاوەکەدا ڕۆیشت و بەرەو لای عیسا بەڕێکەوت.
\v 30 بەڵام کاتێک توندی بایەکەی بینی، ترسا و خەریک بوو نوقوم دەبوو، هاواری کرد: «گەورەم، ڕزگارم بکە!»
\p 
\v 31 عیساش یەکسەر دەستی درێژکرد و گرتی و پێی فەرموو: «کەم باوەڕ، بۆچی گومانت کرد؟»
\p 
\v 32 کە سەرکەوتنە ناو بەلەمەکە، ڕەشەباکە وەستا.
\v 33 ئەوانەی لەناو بەلەمەکەدا بوون، کڕنۆشیان بۆ برد و گوتیان: «بەڕاستی تۆ کوڕی خودای.»
\p 
\v 34 کاتێک پەڕینەوە ئەوبەر، هاتنە خاکی جەنیسارەت.
\v 35 خەڵکی ئەو ناوچەیە عیسایان ناسییەوە، هەواڵیان دا بە ناوچەکانی دەوروبەر و هەموو نەخۆشەکانیان بۆی هێنا.
\v 36 لێی دەپاڕانەوە کە تەنها دەست لە چمکی کراسەکەی بدەن. جا هەموو ئەوانەی دەستیان لێی دەدا چاکدەبوونەوە.
\c 15
\s1 سەرپێچیکردنی ڕاسپاردەی خودا
\p 
\v 1 ئینجا چەند کەسێک لە مامۆستایانی تەورات و فەریسییەکان لە ئۆرشەلیمەوە هاتنە لای عیسا و لێیان پرسی:
\v 2 «بۆچی قوتابییەکانت نەریتی پیران دەشکێنن؟ پێش نانخواردن دەستیان ناشۆن!»
\p 
\v 3 ئەویش وەڵامی دانەوە: «ئەی بۆچی ئێوە لەبەر نەریتی خۆتان سەرپێچیی ڕاسپاردەی خودا دەکەن؟
\v 4 چونکە خودا فەرموویەتی: ﴿ڕێزی دایک و باوکتان بگرن﴾\f + \fr 15:4 \ft \xt دەرچوون 20‏:12 و دواوتار 5‏:16‏\xt*\ft ‏\f*، ﴿ئەوەی نەفرەت لە دایکی یان باوکی بکات، دەبێت بکوژرێت.﴾\f + \fr 15:4 \ft \xt دەرچوون 21‏:17 و لێڤییەکان 20‏:9‏\xt*\ft ‏\f*
\v 5 بەڵام ئێوە دەڵێن: ”ئەگەر یەکێک بە دایک یان باوکی بڵێت: ’ئەوەی بەنیاز بووم بیدەمە ئێوە بۆ خودام تەرخان کردووە،‘
\v 6 ئەوا پێویست ناکات کە ڕێزی دایک و باوکی بگرێت.“ جا لەبەر نەریتی خۆتان دەسەڵاتی ڕاسپاردەی خودا ڕەت دەکەنەوە.
\v 7 ئەی دووڕووان! سەبارەت بە ئێوە ئیشایای پێغەمبەر پێشبینییەکی باشی کردووە کە فەرموویەتی:
\q1 
\v 8 «﴿ئەم گەلە هەر بە دەم ڕێزم لێ دەگرن،
\q2 بەڵام دڵیان لێم دوورە.
\q1 
\v 9 بەخۆڕایی دەمپەرستن،
\q2 تەنها ڕاسپاردەی مرۆڤانە فێری خەڵک دەکەن.﴾»\f + \fr 15:9 \ft \xt ئیشایا 29‏:13‏\xt*\ft ‏\f*
\s1 ئەوەی مرۆڤ گڵاو دەکات
\p 
\v 10 عیسا خەڵکەکەی بانگکرد و پێی فەرموون: «گوێ بگرن و تێبگەن.
\v 11 ئەوەی دەچێتە ناو دەمەوە مرۆڤ گڵاو ناکات، بەڵکو ئەوەی لە دەم دێتە دەرەوە، ئەوە مرۆڤ گڵاو دەکات.»
\p 
\v 12 ئینجا قوتابییەکان هاتنە پێش و لێیان پرسی: «دەزانی کاتێک فەریسییەکان گوێیان لە قسەکە بوو بێزار بوون؟»
\p 
\v 13 وەڵامی دایەوە: «هەر ڕووەکێک باوکی ئاسمانیم نەیچاندبێت، هەڵدەکەنرێت.
\v 14 وازیان لێ بهێنن، ئەوانە کوێرن و ڕێنمایی کوێرەکان دەکەن. ئەگەر کوێر ڕێنمایی کوێر بکات، هەردووکیان دەکەونە چاڵەوە.»
\p 
\v 15 پەترۆس پێی گوت: «ئەم نموونەیەمان بۆ ڕوون بکەوە.»
\p 
\v 16 عیسا فەرمووی: «ئێوەش هێشتا تێناگەن؟
\v 17 ئایا نازانن هەرچی دەچێتە ناو دەم دەڕواتە ناو سک و پاشان دەچێتە دەرەوەی جەستە؟
\v 18 بەڵام ئەوەی لە دەمەوە دێتە دەرەوە، لە دڵەوە سەرچاوە دەگرێت کە دەبێتە هۆی گڵاوبوونی مرۆڤ،
\v 19 چونکە بیری خراپ لە دڵەوە دەردەچێت، کوشتن، داوێنپیسی، بەدڕەوشتی، دزی، شایەتی درۆ، کفرکردن.
\v 20 ئەمانە مرۆڤ گڵاو دەکەن. بەڵام نانخواردن بەبێ دەست شوشتن مرۆڤ گڵاو ناکات.»
\s1 باوەڕی ژنێکی کەنعانی
\p 
\v 21 عیسا لەوێ ڕۆیشت و چوو بۆ ناوچەکانی سور و سەیدا.
\v 22 ژنێکی کەنعانی خەڵکی دەوروبەری ئەوێ، بەرەو ڕووی هات و هاواری کرد: «گەورەم، ئەی کوڕی داود، بەزەییت پێمدا بێتەوە! کچەکەم بەهۆی ڕۆحی پیسەوە ئازارێکی زۆری هەیە.»
\p 
\v 23 بەڵام عیسا تەنانەت بە وشەیەکیش وەڵامی نەدایەوە. قوتابییەکانی هاتنە پێشی و تکایان لێی کرد: «بەڕێی بکە، وا بەدوامانەوە هاوار دەکات.»
\p 
\v 24 وەڵامی دایەوە: «من تەنها بۆ مەڕە ونبووەکانی ماڵی ئیسرائیل نێردراوم.»
\p 
\v 25 بەڵام ژنەکە هات و کڕنۆشی بۆ برد و گوتی: «گەورەم، یارمەتیم بدە!»
\p 
\v 26 وەڵامی دایەوە: «ناشێت نانی منداڵان ببڕدرێت و فڕێبدرێت بۆ سەگ.»
\p 
\v 27 ژنەکە گوتی: «ڕاستە گەورەم، بەڵام سەگیش لەو پاشماوەیە دەخوات کە لە خوانی گەورەکانی بەردەبێتەوە.»
\p 
\v 28 ئینجا عیسا وەڵامی دایەوە: «خانم، باوەڕی تۆ بەهێزە! ئەوەی داوای دەکەیت با بۆت ببێت.» لەو کاتەوە کچەکەش چاک بووەوە.
\s1 تێرکردنی چوار هەزار کەس
\p 
\v 29 ئینجا عیسا لەوێ ڕۆیشت و هاتە لای دەریاچەی جەلیل، چووە سەر شاخێک و لەوێ دانیشت.
\v 30 ئەوە بوو خەڵکێکی زۆر هاتنە لای، شەل و کوێر و گۆج و لاڵ و زۆری دیکەشیان لەگەڵ بوو، لەبەرپێی دایاننان، ئەویش چاکیکردنەوە.
\v 31 تەنانەت خەڵکەکە سەرسام بوون کە بینییان لاڵ قسە دەکات و گۆج چاکدەبێتەوە و شەل بە ڕێکی دەڕوات و کوێر دەبینێت، جا ستایشی خودای ئیسرائیلیان کرد.
\p 
\v 32 ئینجا عیسا قوتابییەکانی بانگکرد و فەرمووی: «دڵم بەو خەڵکە دەسووتێت، ئەوە سێ ڕۆژە لەگەڵمدان و هیچیان نییە بیخۆن. ناشمەوێت بە برسیێتی بیاننێرمەوە، نەوەک لە ڕێگا بڕ نەکەن.»
\p 
\v 33 قوتابییەکانی وەڵامیان دایەوە: «لەم چۆڵەوانییە ئەو نانە زۆرەمان لەکوێ بوو بۆ ناندانی ئەم هەموو خەڵکە؟»
\p 
\v 34 عیساش پێی فەرموون: «چەند نانتان پێیە؟»
\p گوتیان: «حەوت، لەگەڵ چەند ماسییەکی بچووک.»
\p 
\v 35 ئیتر فەرمانی دا خەڵکەکە لەسەر زەوی دانیشن.
\v 36 حەوت نان و ماسییەکانی لێ وەرگرتن و سوپاسی خودای کرد و لەتی کردن و دایە قوتابییەکان، قوتابییەکانیش دایانە خەڵکەکە.
\v 37 هەموو خواردیان و تێربوون، دوایی حەوت سەبەتەی پڕ پەلکەنانیان کۆکردەوە.
\v 38 نانخۆران چوار هەزار پیاو بوون، بێجگە لە ژن و منداڵ.
\v 39 ئینجا عیسا خەڵکەکەی بەڕێکرد و سواری بەلەم بوو و هاتە سنووری مەگەدان.
\c 16
\s1 داواکردنی نیشانەی ئاسمانی
\p 
\v 1 فەریسی و سەدوقییەکان هاتنە لای عیسا بۆ ئەوەی تاقی بکەنەوە، داوایان لێکرد نیشانەیەکی ئاسمانییان پیشان بدات.
\p 
\v 2 عیسا وەڵامی دایەوە: «کە ئێوارە دادێت، دەڵێن، ”ساماڵ دەبێت، چونکە ئاسمان سوور هەڵگەڕاوە،“
\v 3 سەر لە بەیانیش، ”ئەمڕۆ باوبۆران دەبێت، چونکە ئاسمان سوور هەڵگەڕاوە و هەورە.“ ئێوە دەزانن ڕووی ئاسمان بخوێننەوە، بەڵام ناتوانن نیشانەکانی زەمانە لێکبدەنەوە!
\v 4 نەوەیەکی بەدکار و داوێنپیس داوای نیشانە دەکات، نیشانەی نادرێتێ، جگە لە نیشانەی یونس.» ئینجا بەجێی هێشتن و ڕۆیشت.
\s1 هەویرترشی فەریسی و سەدوقییەکان
\p 
\v 5 کاتێک قوتابییەکان گەیشتنە ئەوبەری دەریاچەکە، بینییان لەبیریان چووە لەگەڵ خۆیان نان ببەن.
\v 6 عیسا پێی فەرموون: «وریابن، ئاگاداری هەویرترشی فەریسی و سەدوقییەکان بن.»
\p 
\v 7 لەناو خۆیاندا گفتوگۆیان کرد و گوتیان: «ئەوە بۆیە وا دەڵێت، چونکە نانمان لەگەڵ خۆمان نەهێناوە.»
\p 
\v 8 عیسا زانی و پێی فەرموون: «ئەی کەم باوەڕینە، بۆچی لەنێو خۆتان دەڵێن نانمان نییە؟
\v 9 ئایا هێشتا تێنەگەیشتوون؟ نایەتە بیرتان پێنج نانەکەی پێنج هەزارەکە و چەند سەبەتەشتان هەڵگرتەوە؟
\v 10 یان حەوت نانەکەی چوار هەزارەکە و چەند سەبەتەشتان هەڵگرتەوە؟
\v 11 چۆن تێناگەن من باسی نانم بۆ نەکردن؟ ئاگاداری هەویرترشی فەریسی و سەدوقییەکان بن!»
\v 12 ئینجا تێگەیشتن کە ئەو لە هەویرترشی نان ئاگاداریان ناکاتەوە، بەڵکو لە فێرکردنی فەریسی و سەدوقییەکان.
\s1 پەترۆس دان بە عیسادا دەنێت کە مەسیحەکەیە
\p 
\v 13 کە عیسا گەیشتە ناوچەی قەیسەرییەی فیلیپۆس، لە قوتابییەکانی پرسی: «ئایا خەڵک دەڵێن کوڕی مرۆڤ کێیە؟»
\p 
\v 14 وەڵامیان دایەوە: «هەندێک دەڵێن یەحیای لەئاوهەڵکێشە، هەندێکی دیکە دەڵێن ئەلیاسە، هەندێکیش یەرمیا یان یەکێک لە پێغەمبەران.»
\p 
\v 15 پێی فەرموون: «ئەی ئێوە دەڵێن من کێم؟»
\p 
\v 16 شیمۆن پەترۆس وەڵامی دایەوە: «تۆ مەسیحەکەیت، کوڕی خودای زیندووی.»
\p 
\v 17 عیساش وەڵامی دایەوە: «شیمۆنی کوڕی یۆنا، خۆزگەت پێ دەخوازرێت، چونکە گۆشت و خوێن ئەمەیان بۆت ئاشکرا نەکرد، بەڵکو ئەو باوکەم کە لە ئاسمانە.
\v 18 منیش پێت دەڵێم، تۆ پەترۆسی\f + \fr 16:18 \ft پەترۆس بە زمانی یۆنانی واتا بەرد.‏\f* و لەسەر ئەم بەردە کۆمەڵەی\f + \fr 16:18 \ft یۆنانی: کڵێسا.‏\f* خۆم بنیاد دەنێم کە دەروازەکانی دۆزەخ\f + \fr 16:18 \ft مەبەست لەوەیە کە دوژمن لە بەهێزترین بەرەنگاربوونەوەی لەگەڵ کڵێسادا، هەرگیز ناتوانێت کڵێسا لەناوببات.‏\f* پێی ناوێرێت.
\v 19 کلیلەکانی شانشینی ئاسمانت دەدەمێ، ئەوەی تۆ لەسەر زەوی دایبخەیت، لە ئاسماندا داخراو دەبێت، ئەوەی تۆ لەسەر زەوی بیکەیتەوە، لە ئاسماندا کراوە دەبێت.»
\v 20 ئینجا قوتابییەکانی ڕاسپارد کە بە کەس نەڵێن ئەو مەسیحەکەیە.
\s1 یەکەم باسی مردنی عیسا
\p 
\v 21 لەو کاتەوە عیسا دەستی کرد بە ڕوونکردنەوە بۆ قوتابییەکانی کە دەبێت بچێتە ئۆرشەلیم، لەوێ بە دەستی پیران و کاهینانی باڵا و مامۆستایانی تەورات زۆر ئازار بچێژێت و بکوژرێت و لە ڕۆژی سێیەم هەستێنرێتەوە.
\p 
\v 22 پەترۆس عیسای هێنایە ئەم لاوە و دەستی کرد بە سەرزەنشتکردنی: «خودا نەکات گەورەم! هەرگیز ئەمەت بەسەرنەیەت!»
\p 
\v 23 عیسا ئاوڕی دایەوە و بە پەترۆسی فەرموو: «لەبەرچاوم لاچۆ، ئەی شەیتان! تۆ کۆسپی لەبەردەمم، چونکە بیر لە کاروبارە خوداییەکان ناکەیتەوە، بەڵکو کاروباری مرۆڤانە.»
\s1 خۆ ئامادەکردن بۆ مردن
\p 
\v 24 ئینجا عیسا بە قوتابییەکانی فەرموو: «ئەگەر کەسێک دەیەوێت ببێتە قوتابی من، با نکۆڵی لە خۆی بکات و خاچەکەی هەڵبگرێت و دوام بکەوێت.
\v 25 ئەوەی بیەوێت ژیانی خۆی ڕزگار بکات، دەیدۆڕێنێت، بەڵام ئەوەی لە پێناوی من ژیانی خۆی بدۆڕێنێت، بەدەستی دەهێنێت.
\v 26 چی بەکەڵکی مرۆڤ دێت ئەگەر هەموو جیهان بباتەوە و خۆی بدۆڕێنێت؟ یان کەسێک لە بەرامبەر ژیانیدا چ بەهایەک دەدات؟
\v 27 کوڕی مرۆڤ بە شکۆی باوکیەوە لەگەڵ فریشتەکانی خۆی دەگەڕێتەوە، ئەوسا پاداشتی هەرکەسێک بەپێی کرداری دەداتەوە.
\p 
\v 28 «ڕاستیتان پێ دەڵێم: هەندێک لەوانەی لێرە ڕاوەستاون، مردن ناچێژن هەتا کوڕی مرۆڤ نەبینن وەک پاشا دێتەوە.»
\c 17
\s1 شێوە گۆڕانی عیسا
\p 
\v 1 دوای شەش ڕۆژ، عیسا بە تەنها پەترۆس و یاقوب و یۆحەنای برای لەگەڵ خۆی برد و بۆ سەر چیایەکی بەرز ڕێبەریی کردن.
\v 2 پاشان لەپێشیان شێوەی گۆڕا، ڕووی وەک ڕۆژ دەدرەوشایەوە و جلەکانی وەک ڕووناکی سپی هەڵگەڕان.
\v 3 لەناکاو موسا و ئەلیاسیان بۆ دەرکەوت و لەگەڵ عیسادا کەوتنە گفتوگۆ.
\p 
\v 4 ئینجا پەترۆس بە عیسای گوت: «گەورەم، پێمان باشە لێرە بین. ئەگەر حەز دەکەیت لێرە سێ کەپر دروستدەکەم، یەکێک بۆ تۆ و یەکێک بۆ موسا و یەکێکیش بۆ ئەلیاس.»
\p 
\v 5 کاتێک قسەی دەکرد، هەورێکی ڕۆشن باڵی بەسەریاندا کێشا و دەنگێک لە هەورەکەوە فەرمووی: «ئەمە کوڕی خۆشەویستمە، ئەوەی پێی دڵشادم. گوێی لێ بگرن!»
\p 
\v 6 کاتێک قوتابییەکان گوێیان لەو دەنگە بوو، بەدەمدا کەوتن، زۆر ترسان.
\v 7 بەڵام عیسا هات، دەستی لێدان و فەرمووی: «هەستن، مەترسن!»
\v 8 ئینجا چاویان هەڵبڕی و لە عیسا زیاتر کەسیان نەبینی.
\p 
\v 9 کاتێک لە چیاکە دەهاتنە خوارەوە، عیسا فەرمانی پێدان و فەرمووی: «ئەمەی بینیتان بە کەسی مەڵێن، هەتا کوڕی مرۆڤ لەناو مردووان هەڵدەستێنرێتەوە.»
\p 
\v 10 قوتابییەکانی لێیان پرسی: «باشە بۆچی مامۆستایانی تەورات دەڵێن دەبێت یەکەم جار ئەلیاس بێت؟»
\p 
\v 11 عیسا وەڵامی دانەوە: «ڕاستە، ئەلیاس دێت و هەموو شتێک ڕێک دەخاتەوە.
\v 12 بەڵام پێتان دەڵێم: ئەلیاس هات و نەیانناسی، چییان ویست پێیان کرد. هەروەها کوڕی مرۆڤیش بە دەستیانەوە ئازار دەچێژێت.»
\v 13 ئەوسا قوتابییەکان تێگەیشتن کە باسی یەحیای لەئاوهەڵکێشی بۆ کردن.
\s1 دەرکردنی ڕۆحی پیس لە کوڕێکدا
\p 
\v 14 کاتێک گەیشتنە لای خەڵکەکە، کابرایەک هات و لەبەردەمی چۆکی دادا و
\v 15 گوتی: «گەورەم، بەزەییت بە کوڕەکەمدا بێتەوە، فێدارە و ئازارێکی زۆر دەچێژێت. زۆر جار دەکەوێتە ناو ئاگر و زۆر جاریش ناو ئاوەوە.
\v 16 هێنامە لای قوتابییەکانت، بەڵام نەیانتوانی چاکی بکەنەوە.»
\p 
\v 17 جا عیسا وەڵامی دایەوە: «ئەی نەوەی بێباوەڕ و خوار، هەتا کەی لەگەڵتان بم؟ هەتا کەی بەرگەتان بگرم؟ ئەو کوڕە بهێننە ئێرە بۆ لام.»
\v 18 عیسا لە ڕۆحە پیسەکەی ڕاخوڕی و لە کوڕەکە هاتە دەرەوە، لەو کاتەوە کوڕەکە چاک بووەوە.
\p 
\v 19 پاشان قوتابییەکان بە تەنها هاتنە لای عیسا و گوتیان: «بۆچی ئێمە نەمانتوانی دەریبکەین؟»
\p 
\v 20 ئەویش پێی فەرموون: «لەبەر کەمی باوەڕتان. ڕاستیتان پێ دەڵێم: ئەگەر ئەوەندەی دەنکە خەرتەلەیەک باوەڕتان هەبێ، بەو کێوە دەڵێن ”لەوێ بڕۆ،“ دەڕوات و هیچ شتێک بۆتان مەحاڵ نابێت. [
\v 21 بەڵام ئەم جۆرە ڕۆحانە دەرناکرێن، بە نوێژ و ڕۆژوو نەبێت.]»
\s1 دووەم باسی مردنی عیسا
\p 
\v 22 کاتێک قوتابییەکان لە جەلیل کۆبوونەوە، عیسا پێی فەرموون: «کوڕی مرۆڤ دەدرێتە دەست خەڵک و
\v 23 دەیکوژن، لە ڕۆژی سێیەم هەڵدەستێنرێتەوە.» قوتابییەکانیش بەمە زۆر دڵگران بوون.
\s1 باجی پەرستگا
\p 
\v 24 کاتێک عیسا و قوتابییەکانی گەیشتنە کەفەرناحوم، باجگرانی دوو درهەمەکەی پەرستگا\f + \fr 17:24 \ft باجی تایبەت بووە بە پەرستگا، ساڵانە کۆدەکرایەوە. بڕوانە \xt دەرچوون 30‏:13‏\xt*\ft ‏.‏\f* هاتنە لای پەترۆس و گوتیان: «ئەرێ مامۆستاکەتان باجی پەرستگا نادات؟»
\p 
\v 25 گوتی: «بەڵێ.»
\p کاتێک پەترۆس هاتە ماڵەوە، عیسا پێشی کەوت و فەرمووی: «ڕات چییە شیمۆن؟ پاشایانی زەوی سەرانە و باج لە کێ وەردەگرن؟ لە هاوڵاتییانی خۆیان یان لە خەڵکی بیانی؟»
\p 
\v 26 پەترۆس گوتی: «لە بیانی.»
\p عیساش پێی فەرموو: «کەواتە هاوڵاتییان ئازادن.
\v 27 بەڵام تاکو بۆیان نەبینە کۆسپ، بڕۆ دەریاچەکە و قولاپ هەڵبدە، یەکەم ماسی کە دەیگریت، دەمی بکەرەوە، دراوێکی ستاتیر\f + \fr 17:27 \ft ستاتیر جۆرە دراوێک بووە کە دەیکردە چوار درهەم.‏\f* دەبینیتەوە، بیبە و لە جیاتی خۆم و خۆت بیاندەرێ.»
\c 18
\s1 کێ لە شانشینی ئاسماندا پایەبەرزترە؟
\p 
\v 1 لەو کاتەدا قوتابییەکان هاتنە لای عیسا و گوتیان: «کێ لە شانشینی ئاسماندا پایەبەرزترە؟»
\p 
\v 2 ئەویش منداڵێکی بانگکرد و لە ناوەڕاستیاندا ڕایگرت،
\v 3 فەرمووی: «ڕاستیتان پێ دەڵێم: ئەگەر نەگۆڕێن و وەک منداڵتان لێنەیەت، هەرگیز ناچنە ناو شانشینی ئاسمانەوە.
\v 4 بۆیە ئەوەی وەک ئەم منداڵە خۆی نزم بکاتەوە، لە شانشینی ئاسماندا پایەبەرزترە.
\v 5 ئەوەی بە ناوی منەوە پێشوازی لە منداڵێکی وەک ئەمە بکات، پێشوازی لە من دەکات.
\s1 ئاگادارکردنەوە لە کەوتنە ناو گوناه
\p 
\v 6 «ئەوەی یەکێک لەم بچووکانەی کە باوەڕیان بە من هەیە تووشی گوناه بکات، باشترە بۆی بەرداشێکی گەورە بە ملیەوە هەڵبواسرێت و نوقومی بنی دەریا بکرێت.
\v 7 قوڕبەسەر جیهان لەبەر ئەو شتانەی کە خەڵکی تووشی گوناه دەکەن، چونکە گوناهکردن هەر دەبێت هەبێت، بەڵام قوڕبەسەر ئەوەی کە دەبێتە هۆکار بۆ کەوتنە نێو گوناه.
\v 8 ئەگەر دەستت یان پێت تووشی گوناهی کردیت، بیبڕەوە و فڕێیبدە.\f + \fr 18:8 \ft لێرەدا مەبەست لە بڕینی ئەندامی لەش نییە، بەڵکو مەبەستی ئەوەیە کە باوەڕدار ئامادەبێت ئەندامی لەشی خۆی ببڕێت، بەڵام گوناه نەکات.‏\f* بۆ تۆ باشترە بێ دەست یان بێ پێ بچیتە ناو ژیانەوە، لەوەی کە بە دوو دەست یان دوو پێوە فڕێبدرێیتە ناو ئاگری هەتاهەتاییەوە.
\v 9 ئەگەر چاوت تووشی گوناهی کردیت، دەریبهێنە و فڕێیبدە. بۆ تۆ باشترە بە یەک چاوەوە بچیتە ناو ژیانەوە لەوەی بە دوو چاوەوە فڕێبدرێیتە ناو ئاگری دۆزەخەوە.
\s1 نموونەی مەڕی ونبوو
\p 
\v 10 «ئاگاداربن! بە سووکی مەڕواننە یەکێک لەم بچووکانەی کە باوەڕیان بە من هەیە، چونکە پێتان دەڵێم فریشتەکانیان لە ئاسماندا بەردەوام ڕووی باوکم دەبینن کە لە ئاسماندایە. [
\v 11 کوڕی مرۆڤ هاتووە بۆ ئەوەی ونبووان ڕزگار بکات.]
\p 
\v 12 «ڕاتان چییە؟ ئەگەر یەکێک سەد سەر مەڕی هەبێت و دانەیەکی لێ ون بێت، ئایا نەوەد و نۆیەکە لە چیادا بەجێناهێڵێت تاکو بچێت بەدوای ونبووەکەدا بگەڕێت؟
\v 13 ڕاستیتان پێ بڵێم: ئەگەر دۆزییەوە، لە نەوەد و نۆیەکەی تر کە بزر نەببوون زیاتر پێی دڵخۆش دەبێت!
\v 14 بە هەمان شێوە باوکتان لە ئاسمان نایەوێت یەکێک لەم بچووکانە لەناوبچێت.
\s1 گلەیی برایانە
\p 
\v 15 «ئەگەر خوشک یان براکەت خراپەی لەگەڵ کردیت، بڕۆ بە تەنها لەنێوان خۆت و خۆی گلەیی لێ بکە. ئەگەر گوێی لێگرتی، ئەوا براکەت بەدەستدەهێنیتەوە.
\v 16 خۆ ئەگەر گوێی نەگرت، یەک یان دوو کەس لەگەڵ خۆت ببە، تاکو ﴿هەر بابەتێک لەسەر زاری دوو یان سێ شایەت ڕاستییەکەی بسەلمێنرێت.﴾\f + \fr 18:16 \ft \xt دواوتار 19‏:15‏\xt*\ft ‏\f*
\v 17 ئەگەر بەگوێی نەکردن، بە کڵێسا بڵێ، ئەگەر بەگوێی کڵێساشی نەکرد، ئەوا بە بتپەرست و باجگری دابنێ.
\p 
\v 18 «ڕاستیتان پێ دەڵێم: ئەوەی ئێوە لەسەر زەوی دایبخەن، لە ئاسمانیش داخراو دەبێت، ئەوەی لەسەر زەوی بیکەنەوە، لە ئاسمانیش کراوە دەبێت.
\p 
\v 19 «دیسان ڕاستیتان پێ دەڵێم: ئەگەر دووان لە ئێوە لەسەر زەوی لەسەر هەر شتێک ڕێک بکەون، هەرچی داوا بکەن، باوکم کە لە ئاسمانە بۆتان جێبەجێ دەکات،
\v 20 چونکە لە هەرکوێیەک دوو یان سێ کەس بە ناوی منەوە کۆببنەوە، من لەوێ لەنێوانیاندا دەبم.»
\s1 گەردن ئازادکردن
\p 
\v 21 ئینجا پەترۆس هات و پێی گوت: «گەورەم، دەبێ چەند جار گەردنی براکەم ئازاد بکەم کە خراپەم لەگەڵ دەکات؟ تاکو حەوت جار؟»
\p 
\v 22 عیساش پێی فەرموو: «من پێت ناڵێم حەوت جار، بەڵکو حەفتا کەڕەت حەوت جار!
\p 
\v 23 «لەبەر ئەوە پاشایەتی ئاسمان لە پاشایەک دەچێت ویستی حیساب لەگەڵ خزمەتکارەکانی بکات.
\v 24 کاتێک دەستی پێکرد، یەکێکیان بۆ هێنا دە هەزار کیسە زێڕ\f + \fr 18:24 \ft کیسە زێڕ: یۆنانی: \tl تالنت‏\tl*، هەر تالنتێک نزیکەی 34 کگم بووە؛ یەک \tl تالنت‏\tl* زێڕ دەیکردە کرێی 15 ساڵی کرێکارێک.‏\f* قەرزار بوو.
\v 25 کە هیچی نەبوو بیداتەوە، گەورەکەی فەرمانی دا، خۆی و ژن و منداڵ و هەرچی هەیەتی بفرۆشرێت و قەرزەکە بداتەوە.
\p 
\v 26 «لەبەر ئەوە خزمەتکارەکە لەبەردەمی چۆکی دادا و گوتی: ”لەسەرم ڕابوەستە، هەمووت دەدەمەوە.“
\v 27 گەورەی ئەو خزمەتکارە دڵی پێی سووتا، ئازادی کرد و لە قەرزەکە خۆشبوو.
\p 
\v 28 «ئەم خزمەتکارە ڕۆیشت، خزمەتکارێکی هاوکاری خۆی بینی کە سەد دینار\f + \fr 18:28 \ft یەک دینار کرێی ڕۆژانەی کرێکارێک بووە.‏\f* قەرزاری بوو، ملی گرت و گوتی: ”ئەوەی بەسەرتەوەیە بمدەرەوە!“
\p 
\v 29 «خزمەتکارە هاوکارەکەی لەبەرپێی چۆکی دادا و لێی پاڕایەوە: ”لەسەرم ڕابوەستە، دەتدەمەوە.“
\p 
\v 30 «بەڵام ڕازی نەبوو، چوو فڕێیدایە زیندانەوە، هەتا قەرزەکەی بداتەوە.
\v 31 کاتێک خزمەتکارە هاوکارەکانیان ڕووداوەکەیان بینی، زۆریان پێ ناخۆش بوو، هاتن و هەموو ئەوەی ڕوویدابوو بۆ گەورەکەیان گێڕایەوە.
\p 
\v 32 «ئەوسا گەورەکە خزمەتکارەکەی بانگ کرد و پێی گوت: ”خزمەتکاری بەدکار، لە هەموو ئەو قەرزە خۆشبووم، چونکە لێم پاڕایتەوە.
\v 33 ئایا نەدەبوو تۆش بەزەییت بە خزمەتکارە هاوکارەکەتدا بێتەوە، هەروەک چۆن من بەزەییم پێتدا هاتەوە؟“
\v 34 جا گەورەکەی تووڕە بوو و دایە دەست جەلادەکانەوە، هەتا هەموو قەرزەکەی بداتەوە.
\p 
\v 35 «باوکی ئاسمانیشم واتان لێدەکات، ئەگەر هەریەکەتان لە دڵەوە گەردنی خوشکی یان براکەی ئازاد نەکات.»
\c 19
\s1 ژنهێنان و تەڵاقدان
\p 
\v 1 کاتێک عیسا لەم قسانە بووەوە، جەلیلی بەجێهێشت و هاتە هەرێمی یەهودیا، لەبەری ئەوبەری ڕووباری ئوردون.
\v 2 خەڵکێکی زۆر دوای کەوت، ئەویش لەوێ چاکیکردنەوە.
\p 
\v 3 هەندێک فەریسی هاتنە لای بۆ ئەوەی تاقیی بکەنەوە و گوتیان: «ئایا دروستە مێرد لەبەر هەر هۆیەک بێت ژنەکەی تەڵاق بدات؟»
\p 
\v 4 عیسا وەڵامی دانەوە: «ئایا نەتانخوێندووەتەوە، ئەوەی لە سەرەتاوە بەدیهێناوە ﴿بە نێر و مێ بەدیهێنان﴾\f + \fr 19:4 \ft \xt پەیدابوون 1‏:27.‏\xt*\ft ‏\f*؟
\v 5 هەروەها فەرمووی: ﴿لەبەر ئەوە پیاو دایک و باوکی خۆی بەجێدەهێڵێت و بە ژنەکەیەوە دەنووسێت، ئیتر هەردووکیان دەبنە یەک جەستە.﴾\f + \fr 19:5 \ft \xt پەیدابوون 2‏:24‏\xt*\ft ‏\f*
\v 6 کەواتە چیتر دوو نین بەڵکو یەک جەستەن. لەبەر ئەوە ئەوەی خودا بە یەکتری گەیاندووە، با مرۆڤ جیای نەکاتەوە.»
\p 
\v 7 لێیان پرسی: «ئەی بۆچی موسا فەرمانی داوە پیاو تەڵاقنامە بە ژنەکەی بدات و لێی جودا ببێتەوە؟»
\p 
\v 8 پێی فەرموون: «لەبەر دڵڕەقیتان موسا ڕێی پێدان ژنەکانتان تەڵاق بدەن، ئەگینا لە سەرەتاوە وا نەبوو.
\v 9 بەڵام پێتان دەڵێم: ئەوەی بەبێ هۆی داوێنپیسی ژنەکەی خۆی تەڵاق بدات و یەکێکی دیکە بهێنێت، ئەوا داوێنپیسی دەکات.»
\p 
\v 10 قوتابییەکانی پێیان گوت: «ئەگەر حاڵی پیاو لەگەڵ ژن وابێت، باشترە ژن نەهێنێت!»
\p 
\v 11 عیسا پێی فەرموون: «هەموو خەڵکی ناتوانن ئەم قسەیە پەسەند بکەن، تەنها ئەوانەی پێیان دراوە.
\v 12 خەساو هەن زگماکن، خەساویش هەن مرۆڤ خەساندویانن\f + \fr 19:12 \ft لەو سەردەمە هەندێک لە پیاوە گەورەکان کۆیلەکانی خۆیان دەخەساند، تەنها بۆ کارپێکردن تەرخان دەکران.‏\f*، خەڵکیش هەیە بڕیاریان داوە لە پێناوی شانشینی ئاسمان وەک خەساو بژین\f + \fr 19:12 \ft باوەڕدار لە پێناوی خزمەتکردنی مەسیح بە ڕەبەنی دەمێنێتەوە.‏\f*. کێ دەتوانێت پەسەندی بکات، با پەسەندی بکات.»
\s1 عیسا منداڵان بەرەکەتدار دەکات
\p 
\v 13 ئینجا خەڵکی منداڵیان هێنایە لای عیسا تاوەکو دەستیان لەسەر دابنێت و لە پێناویاندا نوێژ بکات، بەڵام قوتابییەکان سەرزەنشتیان کردن.
\p 
\v 14 بەڵام عیسا فەرمووی: «لێگەڕێن منداڵان بێنە لام، ڕێیان لێ مەگرن، چونکە شانشینی ئاسمان هی وەک ئەمانەیە.»
\v 15 دەستی لەسەر دانان و لەوێ ڕۆیشت.
\s1 گەنجە دەوڵەمەندەکە
\p 
\v 16 ئینجا یەکێک هاتە لای و گوتی: «مامۆستا، چ چاکەیەک بکەم تاکو ژیانی هەتاهەتایی بەدەست بهێنم؟»
\p 
\v 17 عیسا وەڵامی دایەوە: «بۆچی لەبارەی چاکەوە پرسیارم لێ دەکەیت؟ تەنها یەکێک چاکە. بەڵام ئەگەر دەتەوێت بچیتە ناو ژیانەوە، ڕاسپاردەکان بەجێبگەیەنە.»
\p 
\v 18 پێی گوت: «کامیان؟»
\p عیساش فەرمووی: «﴿مەکوژە، داوێنپیسی مەکە، مەدزە، شایەتی درۆ مەدە،
\v 19 ڕێزی دایک و باوکت بگرە،﴾\f + \fr 19:19 \ft \xt دەرچوون 20‏:12‏-16 و دواوتار 5‏:16‏-20‏\xt*\ft ‏\f* هەروەها ﴿نزیکەکەت وەک خۆت خۆشبوێت.﴾\f + \fr 19:19 \ft \xt لێڤییەکان 19‏:18‏\xt*\ft ‏\f*»
\p 
\v 20 گەنجەکەش پێی گوت: «هەموو ئەمانەم بەجێگەیاندووە، ئیتر لە چیم کەمە؟»
\p 
\v 21 عیسا پێی فەرموو: «ئەگەر دەتەوێت کامڵ و تەواو بیت، بڕۆ هەرچیت هەیە بیفرۆشە و بیدە هەژاران، ئیتر گەنجینەیەکت لە ئاسماندا دەبێت و وەرە دوام بکەوە.»
\p 
\v 22 بەڵام گەنجەکە کە ئەم قسەیەی بیست، بە دڵتەنگییەوە ڕۆیشت، چونکە سامانێکی زۆری هەبوو.
\p 
\v 23 عیساش بە قوتابییەکانی فەرموو: «ڕاستیتان پێ دەڵێم: بە زەحمەت دەوڵەمەند دەچێتە ناو شانشینی ئاسمانەوە.
\v 24 دیسان پێتان دەڵێم: ئاسانترە وشترێک بە کونی دەرزییەکەوە بچێت لەوەی دەوڵەمەندێک بچێتە ناو شانشینی خوداوە.»
\p 
\v 25 قوتابییەکان کە گوێیان لەمە بوو زۆر سەرسام بوون و گوتیان: «کەواتە کێ دەتوانێت ڕزگاری بێت؟»
\p 
\v 26 عیساش سەیری کردن و فەرمووی: «ئەمە بۆ مرۆڤ مەحاڵە، بەڵام لەلای خودا هەموو شتێک دەبێت.»
\p 
\v 27 ئینجا پەترۆس وەڵامی دایەوە و پێی گوت: «ئەوەتا ئێمە وازمان لە هەموو شتێک هێناوە و دوات کەوتووین، ئێمە چیمان بۆ دەبێت؟»
\p 
\v 28 عیساش پێی فەرموون: «ڕاستیتان پێ دەڵێم، لە نوێبوونەوەدا\f + \fr 19:28 \ft مەبەست لە کاتی ڕۆژی زیندووبوونەوەیە، کە هەموو شتێک سەرلەنوێ دروستدەکرێتەوە.‏\f*، کاتێک کوڕی مرۆڤ لەسەر تەختی شکۆمەندی خۆی دادەنیشێت، ئێوەش کە دوام کەوتوون لەسەر دوازدە تەخت دادەنیشن و دوازدە هۆزەکەی ئیسرائیل حوکم دەدەن.
\v 29 هەرکەسێکیش لەبەر ناوی من، ماڵ، برا، خوشک، دایک، باوک، ژن، منداڵ یان کێڵگەی بەجێهێشتووە، سەد ئەوەندە وەردەگرێتەوە و ژیانی هەتاهەتاییش بە میرات وەردەگرێت.
\v 30 بەڵام زۆر لە یەکەمینەکان دەبنە دواهەمین و دواهەمینەکانیش دەبنە یەکەمین.»
\c 20
\s1 نموونەی کرێکارانی ناو ڕەز
\p 
\v 1 «شانشینی ئاسمان لە خاوەن ڕەزێک دەچێت، بەیانی زوو دێتە دەرەوە تاکو بچێت کرێکار بۆ ڕەزەکەی بگرێت.
\v 2 لەگەڵ کرێکارەکان ڕۆژی بە دینارێک ڕێککەوت، ئینجا ئەوانی بۆ ڕەزەکەی نارد.
\p 
\v 3 «نزیکی کاتژمێر نۆ\f + \fr 20:3 \ft بەرامبەرە لەگەڵ کاتژمێر سێی عیبری، چونکە دەستپێکردنی یەکەم کاتژمێری ڕۆژێکی نوێ بە کاتی عیبری بەرامبەرە بە کاتژمێر شەشی بەیانی ئێستا.‏\f* دووبارە چووە دەرەوە، لە مەیداندا هەندێکی دیکەی بینی بێکار ڕاوەستابوون،
\v 4 پێی گوتن: ”ئێوەش بڕۆن لە ڕەزەکەمدا کار بکەن، چەندتان بکەوێ دەتاندەمێ.“
\v 5 ئەوانیش ڕۆیشتن.
\p «ئینجا کاتژمێر دوازدە و کاتژمێری سێ ڕۆیشتەوە و هەمان شتی کردەوە.
\v 6 نزیکی کاتژمێر پێنجی ئێوارە دیسان ڕۆیشت، کرێکاری دیکەی بینی ڕاوەستاون، لێی پرسین: ”بۆچی بە درێژایی ڕۆژ لێرە بێکار ڕاوەستاون؟“
\p 
\v 7 «وەڵامیان دایەوە: ”چونکە کەس بە کرێی نەگرتووین.“ ئەویش پێی گوتن: ”ئێوەش بڕۆن لە ڕەزەکەمدا کار بکەن!“
\p 
\v 8 «کاتێک ئێوارە داهات خاوەن ڕەزەکە بە سەرکارەکەی خۆی گوت: ”کرێکارەکان بانگ بکە و کرێیەکانیان بدەرێ، لەوانەوە دەستپێبکە کە لە کۆتاییەوە هاتن بۆ ئەوانەی لە سەرەتاوە هاتن.“
\p 
\v 9 «جا ئەوانەی کاتژمێر پێنج\f + \fr 20:9 \ft یۆنانی: کاتژمێری یازدەیەم.‏\f* هاتن، هەریەکە دینارێکیان وەرگرت.
\v 10 یەکەمینەکانیش هاتن و وایانزانی زیاتر وەردەگرن، بەڵام هەریەکە دینارێکیان وەرگرت.
\v 11 کە وەریاندەگرت بۆڵەبۆڵیان بەسەر خاوەن ڕەزەکەدا دەکرد و
\v 12 دەیانگوت: ”دواهەمینەکان کاتژمێرێک ئیشیان کرد. تۆش لەگەڵ ئێمە یەکسانت کردن کە سەختی و گەرمای ڕۆژمان کێشاوە.“
\p 
\v 13 «وەڵامی یەکێکیانی دایەوە: ”برادەر، من غەدرم لێ نەکردوویت. ئایا لەگەڵ من بە دینارێک ڕێک نەکەوتوویت؟
\v 14 هی خۆت ببە و بڕۆ. من دەمەوێت بەوەی دواهەمینیش وەک تۆی بدەمێ.
\v 15 ئایا بۆم نییە ئەوەی دەمەوێت بە ماڵی خۆمی بکەم؟ یان چاوت بەوەدا هەڵنایەت کە من کەسێکی دەستکراوەم؟“
\p 
\v 16 «بەم شێوەیە دواهەمین دەبنە یەکەمین و یەکەمینیش دەبنە دواهەمین.»
\s1 سێیەم باسی مردنی عیسا
\p 
\v 17 کاتێک عیسا بەرەو ئۆرشەلیم دەڕۆیشت، دوازدە قوتابییەکەی جیا کردەوە و بە ڕێگاوە پێی فەرموون:
\v 18 «ئەوا بۆ ئۆرشەلیم سەردەکەوین، کوڕی مرۆڤ دەدرێتە دەست کاهینانی باڵا و مامۆستایانی تەورات، ئەوانیش بڕیاری مردنی دەدەن و
\v 19 بۆ گاڵتە پێکردن و بە قامچی لێدان و لەخاچدان دەیدەنە دەست ناجولەکەکان، لە ڕۆژی سێیەمیش هەڵدەستێنرێتەوە.»
\s1 خزمەتکار پایەبەرزترینە
\p 
\v 20 ئینجا دایکی کوڕەکانی زەبدی لەگەڵ کوڕەکانی هاتە لای عیسا و کڕنۆشی برد و داوای لێکرد شتێکی بۆ بکات.
\p 
\v 21 ئەویش پێی فەرموو: «چیت دەوێت؟» گوتی: «بفەرموو با هەردوو کوڕەکەم لە شانشینییەکەتدا یەکێکیان لەلای ڕاستت و ئەوی دیکەیان لەلای چەپت دانیشن.»
\p 
\v 22 عیسا وەڵامی دایەوە: «ئێوە نازانن داوای چی دەکەن. ئایا دەتوانن ئەو جامە\f + \fr 20:22 \ft مەبەستی لەو ئازارەیە کە بەگوێرەی پلانی خودا لەسەر خاچ دەیچێژێت.‏\f* بخۆنەوە کە من دەیخۆمەوە؟»
\p وەڵامیان دایەوە: «دەتوانین.»
\p 
\v 23 ئەویش پێی فەرموون: «لە ڕاستیدا لە جامی من دەخۆنەوە، بەڵام دانیشتن لەلای ڕاست و چەپمەوە، بۆ من نییە بیدەم، بەوانە نەبێت کە باوکم بۆی ئامادە کردوون.»
\p 
\v 24 کاتێک دە قوتابییەکەی دیکە قسەکانیان بیستەوە، لە دوو براکە تووڕە بوون.
\v 25 بەڵام عیسا بانگی کردن و فەرمووی: «دەزانن سەرۆکی نەتەوەکانی دیکە وەک میر فەرمانڕەواییان بەسەردا دەکەن و گەورەکانیان دەسەڵاتیان بەسەردا دەسەپێنن.
\v 26 بەڵام لەنێو ئێوەدا ئاوا نابێت، بەڵکو ئەوەی دەیەوێت لەنێوتاندا پایەی بەرز بێت، با ببێتە خزمەتکارتان و
\v 27 ئەوەش کە دەیەوێ لەنێوتاندا ببێتە یەکەم، با ببێتە بەندەتان،
\v 28 وەک چۆن کوڕی مرۆڤ کە نەهاتووە تاکو خزمەت بکرێت، بەڵکو خزمەت بکات و ژیانی خۆی بەخت بکات بۆ کڕینەوەی خەڵکێکی زۆر.»
\s1 چاککردنەوەی دوو کەسی نابینا
\p 
\v 29 کاتێک عیسا و قوتابییەکانی ئەریحایان بەجێدەهێشت، خەڵکێکی زۆر دوای کەوت.
\v 30 ئەوە بوو دوو کەسی نابینا لە قەراغ ڕێگاکەدا دانیشتبوون، کاتێک گوێیان لێبوو عیسا وا بەوێدا دەڕوات، هاواریان کرد: «گەورەم، کوڕی داود، بەزەییت پێماندا بێتەوە.»
\p 
\v 31 جا خەڵکەکە سەرزەنشتیان کردن تاکو بێدەنگ بن، بەڵام ئەوان زیاتر هاواریان کرد: «گەورەم، کوڕی داود، بەزەییت پێماندا بێتەوە!»
\p 
\v 32 عیسا ڕاوەستا و بانگی کردن و فەرمووی: «چیتان دەوێت بۆتان بکەم؟»
\p 
\v 33 وەڵامیان دایەوە: «گەورەم، دەمانەوێت چاومان بکەیتەوە.»
\p 
\v 34 عیساش دڵی پێیان سووتا و دەستی لە چاویان دا، دەستبەجێ بیناییان بۆ گەڕایەوە و دوای کەوتن.
\c 21
\s1 کەژاوەی پاشایانە
\p 
\v 1 کاتێک لە ئۆرشەلیم نزیک بوونەوە و گەیشتنە گوندی بێت‌فاجی لەلای کێوی زەیتوون، عیسا دووان لە قوتابییەکانی نارد و
\v 2 پێی فەرموون: «بڕۆنە ئەو گوندەی بەرامبەرتان، دەستبەجێ ماکەرێک دەبینن بەستراوەتەوە، جاشکەکەی لەگەڵە. بیکەنەوە و بۆ منیان بهێنن.
\v 3 ئەگەر یەکێک شتێکی پێ گوتن، دەڵێن: گەورەمان پێویستی پێیانە، ئەویش یەکسەر دەیاننێرێت.»
\p 
\v 4 ئەمەش ڕوویدا تاکو ئەوەی لە ڕێگەی پێغەمبەرەکە\f + \fr 21:4 \ft مەبەست لە پێغەمبەر زەکەریایە.‏\f* گوتراوە بێتە دی کە دەفەرموێ:
\q1 
\v 5 ﴿بە شاری سییۆن بڵێن،
\q2 ئەوەتا پاشاکەت دێتە لات،
\q1 دڵنەرمە و سواری ماکەرێک و
\q2 جاشی ماکەرێک بووە.﴾\f + \fr 21:5 \ft \xt زەکەریا 9‏:9‏\xt*\ft ‏\f*
\p 
\v 6 قوتابییەکان ڕۆیشتن و وەک ئەوەی عیسا فەرمانی پێدابوون، کردیان.
\v 7 ماکەر و جاشکەکەیان هێنا، کەواکانیان خستە سەر پشتی و عیسا سواربوو.
\v 8 خەڵکێکی ئێجگار زۆر کەواکانیان لەسەر ڕێگاکە ڕاخست. خەڵکی دیکە لقە داریان دەبڕییەوە و لەسەر ڕێگاکە ڕایاندەخست.
\v 9 ئەو خەڵکەی لەپێشی دەڕۆیشتن و ئەوانەش کە دوای کەوتبوون، هاواریان دەکرد:
\q1 «هۆسانا\f + \fr 21:9 \ft لە زمانی عیبری دەربڕینێکە بە واتای ڕزگارمان بکە، بووە هاواری ستایش.‏\f* بۆ کوڕی داود!»
\b
\q1 «﴿پیرۆزە ئەوەی بە ناوی یەزدانەوە دێت!﴾\f + \fr 21:9 \ft \xt زەبوورەکان 118‏:26‏\xt*\ft ‏\f*»
\b
\q1 «هۆسانا بۆ خودا!»
\p 
\v 10 کاتێک عیسا چووە ناو ئۆرشەلیم، هەموو شارەکە خرۆشا و گوتیان: «ئەمە کێیە؟»
\p 
\v 11 خەڵکەکەش دەیانگوت: «ئەمە پێغەمبەر عیسایە، خەڵکی ناسیرەی جەلیلە.»
\s1 پاککردنەوەی پەرستگا
\p 
\v 12 عیسا چووە ناو حەوشەکانی پەرستگا و هەموو ئەوانەی دەرکرد کە لەوێ خەریکی کڕین و فرۆشتن بوون، مێزی پارەگۆڕەوان و کورسی کۆترفرۆشانی سەرەوژێر کرد.
\v 13 پێی فەرموون: «نووسراوە، ﴿ماڵەکەم بە ماڵی نوێژ ناودەبردرێت،﴾\f + \fr 21:13 \ft \xt ئیشایا 56‏:7‏\xt*\ft ‏\f* بەڵام ئێوە دەیکەنە ﴿ئەشکەوتی دزان!﴾\f + \fr 21:13 \ft \xt یەرمیا 7‏:11‏\xt*\ft ‏\f*»
\p 
\v 14 نابینا و شەلەکان لە پەرستگا هاتنە لای و ئەویش چاکیکردنەوە.
\v 15 بەڵام کاتێک کاهینانی باڵا و مامۆستایانی تەورات ئەم کارە سەرسوڕهێنەرانەیان بینی کە ئەو کردی، هەروەها منداڵانیش کە لە حەوشەکانی پەرستگا هاواریان دەکرد: «هۆسانا بۆ کوڕی داود!» تووڕە بوون و
\v 16 لێیان پرسی: «گوێت لێیە ئەو منداڵانە چی دەڵێن؟»
\p عیساش پێی فەرموون: «بەڵێ، ئەی قەت نەتانخوێندووەتەوە:
\q1 «﴿لە زاری منداڵان و شیرەخۆرانەوە
\q2 ستایشت بۆ خۆت داڕشتووە﴾؟»\f + \fr 21:16 \ft \xt زەبوورەکان 8‏:2‏\xt*\ft ‏\f*
\p 
\v 17 ئەوسا بەجێی هێشتن و چووە دەرەوەی شار، بەرەو گوندی بێت‌عەنیا بەڕێکەوت و شەو لەوێ مایەوە.
\s1 دار هەنجیری بێ بەر
\p 
\v 18 بەیانی زوو کە عیسا دەگەڕایەوە شار، برسی بوو.
\v 19 دار هەنجیرێکی لەسەر ڕێگاکە بینی و چووە لای، بەڵام لە گەڵا زیاتر هیچی پێوە نەبینی، ئینجا پێی فەرموو: «ئیتر هەرگیز بەر نەگریت!» دەستبەجێ دارەکە وشک بوو.
\p 
\v 20 کاتێک قوتابییەکان ئەمەیان بینی، سەرسام بوون و گوتیان: «چۆن دەستبەجێ دار هەنجیرەکە وشک بوو؟»
\p 
\v 21 عیساش وەڵامی دانەوە: «ڕاستیتان پێ دەڵێم: ئەگەر باوەڕتان هەبێت و گومان نەکەن، نەک هەر ئەمەی دار هەنجیرەکە دەکەن، بەڵکو ئەگەر بەم کێوە بڵێن، ”هەڵبکەنرێ و بکەوە ناو دەریاوە،“ وا دەبێت.
\v 22 جا هەرچی لە نوێژدا بە باوەڕەوە داوای بکەن، وەریدەگرن.»
\s1 دەسەڵاتی عیسا
\p 
\v 23 کاتێک عیسا چووە حەوشەکانی پەرستگا و خەڵکەکەی فێردەکرد، کاهینانی باڵا و پیرانی گەل هاتنە لای و گوتیان: «ئەمانە بە چ دەسەڵاتێک دەکەیت؟ کێ ئەم دەسەڵاتەی بە تۆ داوە؟»
\p 
\v 24 عیسا وەڵامی دانەوە: «منیش پرسیارێکتان لێ دەکەم، ئەگەر وەڵامتان دامەوە، ئەوا پێتان دەڵێم بە چ دەسەڵاتێک ئەمانە دەکەم.
\v 25 لەئاوهەڵکێشانی یەحیا، لەکوێوە بوو؟ لە ئاسمانەوە بوو یان لە مرۆڤەوە؟»
\p لەنێو خۆیاندا کەوتنە ڕاوێژکردن و گوتیان: «ئەگەر بڵێین، ”لە ئاسمانەوە بوو،“ دەڵێت، ”باشە بۆچی باوەڕتان پێی نەکرد؟“
\v 26 ئەگەریش بڵێین، ”لە مرۆڤەوە بوو،“ لە خەڵکەکە دەترسین، چونکە هەموو یەحیا بە پێغەمبەر دادەنێن.»
\p 
\v 27 ئینجا وەڵامی عیسایان دایەوە: «نازانین.»
\p ئەویش پێی فەرموون: «منیش پێتان ناڵێم بە چ دەسەڵاتێک ئەمانە دەکەم.»
\s1 نموونەی دوو کوڕەکە
\p 
\v 28 ئینجا عیسا فەرمووی: «ڕاتان چییە؟ پیاوێک دوو کوڕی هەبوو. چووە لای یەکەمیان و گوتی: ”کوڕم ئەمڕۆ بڕۆ لە ڕەزەکەدا کار بکە.“
\p 
\v 29 «ئەویش وەڵامی دایەوە: ”ناچم.“ بەڵام پاشان پەشیمان بووەوە و چوو.
\p 
\v 30 «ئینجا پیاوەکە چووە لای کوڕەکەی دیکەی و هەمان قسەی کرد. وەڵامی دایەوە: ”بەسەرچاو\f + \fr 21:30 \ft یۆنانی: من.‏\f*، گەورەم!“ بەڵام نەچوو.
\p 
\v 31 «ئایا کام لەم دووانە بە خواستی باوکیان کرد؟»
\p گوتیان: «یەکەمیان.»
\p عیساش پێی فەرموون: «ڕاستیتان پێ دەڵێم: باجگران و لەشفرۆشان لە چوونە ناو شانشینی خودا پێشتان دەکەون،
\v 32 چونکە یەحیا هات بۆ ئەوەی ڕێگای ڕاستودروستیتان نیشان بدات بەڵام ئێوە باوەڕتان پێی نەکرد، بەڵام باجگران و لەشفرۆشان باوەڕیان پێی کرد. پاشان کە بینیشتان، هەر تۆبەتان نەکرد و باوەڕتان پێی نەکرد.»
\s1 نموونەی ڕەزەوانەکان
\p 
\v 33 «گوێ لە نموونەیەکی دیکە بگرن: خاوەن زەوییەک هەبوو ڕەزێکی چاند و پەرژینێکی بە دەوریدا کرد، گوشەرێکی ترێی تێدا هەڵکۆڵی و قوللەیەکی چاودێری بنیاد نا. ئینجا دایە دەست چەند ڕەزەوانێک و گەشتی کرد.
\v 34 کاتێک وەرزی بەرهەم نزیک بووەوە، خزمەتکارەکانی ناردە لای ڕەزەوانەکان تاکو بەرهەمەکەی وەربگرن.
\p 
\v 35 «ڕەزەوانەکان خزمەتکارەکانیان گرت، لە یەکێکیان دا و یەکێکیان کوشت و ئەوی دیکەشیان بەردباران کرد.
\v 36 دیسان خزمەتکاری زیاتری لەوانەی پێشوو نارد، ڕەزەوانەکان هەمان شتیان لەوانیش کرد.
\v 37 لە کۆتاییدا کوڕەکەی بۆ لایان نارد و گوتی: ”ڕێزی کوڕەکەم دەگرن.“
\p 
\v 38 «بەڵام ڕەزەوانەکان کە کوڕەکەیان بینی لەناو خۆیاندا گوتیان: ”ئەمە میراتگرەکەیە. با بیکوژین و دەست بەسەر میراتەکەیدا بگرین.“
\v 39 ئینجا گرتیان و فڕێیان دایە دەرەوەی ڕەزەکە و کوشتیان.
\p 
\v 40 «کاتێک خاوەنی ڕەزەکە دێت، چی لەم ڕەزەوانانە دەکات؟»
\p 
\v 41 وەڵامیان دایەوە: «ئەو خراپەکارانە بە خراپی لەناودەبات و ڕەزەکەش دەداتە دەست ڕەزەوانانی دیکە، ئەوانەی لە وەرزی خۆی بەرهەمی دەدەنێ.»
\p 
\v 42 عیسا پێی فەرموون: «ئایا هەرگیز لە نووسراوە پیرۆزەکان\f + \fr 21:42 \ft مەبەست لە هەر 39 پەڕتووکەکەی پەیمانی کۆنە، تەوراتی موسا و زەبووری داود و پەندەکانی سلێمانی دانا و مێژوو و پێغەمبەرەکان.‏\f* نەتانخوێندووەتەوە:
\q1 «﴿ئەو بەردەی وەستاکان ڕەتیان کردەوە
\q2 بوو بە گرنگترین بەردی بناغە\f + \fr 21:42 \ft بەردێکی گەورەیە کە لە گۆشەی دیوار دادەنرێت، لەو بەردانە بەهێزترە کە لە دیوارەکە بەکاردێت و دەبێتە هۆی بەهێزکردنی دیوارەکە.‏\f*،
\q1 ئەمە لەلایەن یەزدانەوە بوو،
\q2 لەبەرچاومان سەیرە﴾\f + \fr 21:42 \ft \xt زەبوورەکان 118‏:22‏-23‏\xt*\ft ‏\f*؟
\p 
\v 43 «لەبەر ئەوە پێتان دەڵێم: شانشینی خوداتان لێ دەسەنرێتەوە و دەدرێتە نەتەوەیەک کە بەرهەم دەدات.
\v 44 ئەوەی بەسەر ئەم بەردەدا بکەوێت تێکدەشکێت، ئەوەش کە بەردەکە بەسەریدا بکەوێت وردوخاشی دەکات.»
\p 
\v 45 کاتێک کاهینانی باڵا و فەریسییەکان نموونەکانیان بیست، زانییان باسی ئەوان دەکات.
\v 46 لەبەر ئەوە دەیانویست بیگرن، بەڵام لە خەڵکەکە ترسان، چونکە بە پێغەمبەریان دادەنا.
\c 22
\s1 نموونەی داوەتی پاشا
\p 
\v 1 عیسا دووبارە بە نموونە قسەی بۆ کردن، فەرمووی:
\v 2 «پاشایەتی ئاسمان لە پاشایەک دەچێت کە زەماوەندی بۆ کوڕەکەی گێڕا.
\v 3 کۆیلەکانی نارد تاکو بانگهێشتکراوان بۆ زەماوەندەکە بانگ بکەن، بەڵام نەیانویست بێن.
\p 
\v 4 «دیسان کۆیلەی دیکەی نارد و گوتی: ”بە بانگهێشتکراوان بڵێن، ئەوەتا خوانم ئامادە کردووە، گا و دابەستەکانیشم سەربڕیوە و هەموو شتێک ئامادەیە. وەرنە زەماوەندەکە!“
\p 
\v 5 «بەڵام گوێیان نەدایێ و ڕۆیشتن، یەکێک بۆ کێڵگەکەی و ئەوی دیکە بۆ بازرگانییەکەی.
\v 6 ئەوانی دیکە کۆیلەکانی ئەویان گرت و سووکایەتییان پێ کردن و کوشتیانن.
\v 7 جا پاشا زۆر تووڕە بوو، سوپاکەی نارد و بکوژەکانی لەناوبرد و شارەکەیانی سووتاند.
\p 
\v 8 «ئینجا بە کۆیلەکانی گوت: ”زەماوەند ئامادەیە، بەڵام ئەوانەی کە بانگهێشتم کردن شایستە نەبوون،
\v 9 کەواتە بڕۆنە سەر ڕێگاکان و ئەوەی بینیتان بۆ زەماوەندەکە بانگهێشتی بکەن.“
\v 10 ئەو کۆیلانەش چوونە دەرەوە بۆ سەر ڕێگاوبانەکان و هەموو ئەوانەی لە باش و خراپ بینییان کۆیان کردنەوە، تاکو زەماوەندەکە پڕبوو لە میوان.
\p 
\v 11 «کاتێک پاشا هاتە ژوورەوە بۆ ئەوەی میوانەکان ببینێت، لەوێ یەکێکی بینی جلی زەماوەندی\f + \fr 22:11 \ft کاتێک پاشا زەماوەند دەگێڕێت جلوبەرگی تایبەت دابەش دەکات.‏\f* لەبەر نەکردبوو.
\v 12 پێی دەڵێت: ”برادەر، چۆن بێ جلی زەماوەند هاتییە ژوورەوە؟“ ئەو بێدەنگ بوو.
\p 
\v 13 «ئینجا پاشا بە خزمەتکارانی گوت: ”پەلبەستی بکەن و فڕێیبدەنە تاریکیی دەرەوە، جا گریان و جیڕەی ددان لەوێ دەبێت.“
\p 
\v 14 «چونکە بانگهێشتکراوان زۆرن، بەڵام هەڵبژێردراوان کەمن.»
\s1 سەرانەدان بە قەیسەر
\p 
\v 15 ئینجا فەریسییەکان ڕۆیشتن و تەگبیریان کرد کە چۆن عیسا بە قسەکانی خۆی تووش بکەن.
\v 16 قوتابییەکانی خۆیان و هێرۆدسییەکانیان ناردە لای و گوتیان: «مامۆستا، دەزانین تۆ ڕاستگۆیت و بە ڕاستی خەڵکی فێری ڕێگای خودا دەکەیت و سڵ لە کەس ناکەیتەوە، چونکە تەماشای ڕواڵەتی خەڵک ناکەیت.
\v 17 کەواتە پێمان بفەرموو ڕات چییە؟ دروستە سەرانە بدرێتە قەیسەر یان نا؟»
\p 
\v 18 عیسا کە بە نیازخراپی ئەوانی دەزانی، فەرمووی: «ئەی دووڕووان، بۆچی تاقیم دەکەنەوە؟
\v 19 پارەی سەرانەم پیشان بدەن.» ئەوانیش دینارێکیان بۆ هێنا.
\v 20 پێی فەرموون: «ئەم وێنە و نووسینە هی کێیە؟»
\p 
\v 21 وەڵامیان دایەوە: «هی قەیسەرە.»
\p پاشان پێی فەرموون: «کەواتە ئەوەی هی قەیسەرە بیدەنە قەیسەر و ئەوەش هی خودایە بیدەنە خودا.»
\p 
\v 22 کە گوێیان لێبوو سەرسام بوون، ئینجا بەجێیان هێشت و ڕۆیشتن.
\s1 زیندووبوونەوەی مردووان
\p 
\v 23 لە هەمان ڕۆژدا سەدوقییەکان کە دەڵێن زیندووبوونەوە نییە، هاتنە لای و پرسیاریان لێکرد:
\v 24 «مامۆستا، موسا فەرمووی، ئەگەر پیاوێکی وەجاخکوێر مرد، ئەوا براکەی براژنەکەی دەخوازێتەوە و وەچە بۆ براکەی دەخاتەوە.
\v 25 جا لەلای ئێمە حەوت برا هەبوون، یەکەمیان ژنی هێنا و بە وەجاخکوێری مرد و ژنەکەی بۆ براکەی بەجێهێشت،
\v 26 بە هەمان شێوە دووەم و سێیەم هەتا گەیشتە حەوتەم.
\v 27 لەدوای هەموویان ژنەکەش مرد.
\v 28 ئایا لە ڕۆژی زیندووبوونەوەدا دەبێتە ژنی کام لە حەوتەکە، چونکە هی هەموویان بووە؟»
\p 
\v 29 عیسا لە وەڵامدا پێی فەرموون: «ئێوە بە هەڵەدا چوونە، چونکە نە لە نووسراوە پیرۆزەکان دەزانن و نە لە هێزی خودا.
\v 30 لە هەستانەوەدا خەڵکی نە ژن دەهێنن و نە مێرد دەکەن، بەڵکو وەک فریشتە لە ئاسمان دەبن.
\v 31 بەڵام دەربارەی هەستانەوەی مردووان، ئایا ئەوەتان نەخوێندووەتەوە کە لە خوداوە بە ئێوە گوتراوە؟ دەفەرموێ:
\v 32 ﴿من خودای ئیبراهیم و خودای ئیسحاق و خودای یاقوبم﴾\f + \fr 22:32 \ft \xt دەرچوون 3‏:6‏\xt*\ft ‏\f* ئەو خودای مردووان نییە، بەڵکو هی زیندووانە.»
\p 
\v 33 کاتێک خەڵکەکە گوێیان لێی بوو، لە فێرکردنەکەی سەرسام بوون.
\s1 گەورەترین ڕاسپاردە
\p 
\v 34 کاتێک فەریسییەکان بیستیان کە عیسا سەدوقییەکانی بێدەنگ کردووە، پێکەوە کۆبوونەوە.
\v 35 یەکێکیان تەوراتناس بوو، پرسیاری لێکرد تاکو تاقی بکاتەوە:
\v 36 «مامۆستا، گرنگترین ڕاسپاردەی تەورات چییە؟»
\p 
\v 37 عیسا پێی فەرموو: «﴿بە هەموو دڵ و بە هەموو گیان و لە هەموو بیرتانەوە یەزدانی پەروەردگارتان خۆشبوێ.﴾\f + \fr 22:37 \ft \xt دواوتار 6‏:5‏\xt*\ft ‏\f*
\v 38 ئەمە گرنگترین و یەکەم ڕاسپاردەیە.
\v 39 دووەمیشیان وەک ئەو وایە: ﴿نزیکەکەت وەک خۆت خۆشبوێت.﴾\f + \fr 22:39 \ft \xt لێڤییەکان 19‏:18‏\xt*\ft ‏\f*
\v 40 جا هەموو تەورات و پەیامی پێغەمبەران بەم دوو ڕاسپاردەیەوە بەندن.»
\s1 مەسیح و داود
\p 
\v 41 کاتێک فەریسییەکان پێکەوە کۆببوونەوە، عیسا لێی پرسین:
\v 42 «دەربارەی مەسیح چی دەڵێن؟ کوڕی کێیە؟»
\p وەڵامیان دایەوە: «کوڕی داودە.»
\p 
\v 43 ئەویش پێی فەرموون: «کەواتە، چۆن داود بە سروشی ڕۆحی پیرۆز پێی دەڵێ، ”خاوەن شکۆ“؟ چونکە دەڵێ:
\q1 
\v 44 «﴿یەزدان بە خاوەن شکۆی منی فەرموو:
\q2 ”لە دەستەڕاستم دابنیشە
\q2 هەتا دوژمنانت دەخەمە ژێر پێت.“﴾\f + \fr 22:44 \ft \xt زەبوورەکان 110‏:1‏\xt*\ft ‏\f*
\m 
\v 45 بۆیە ئەگەر داود پێی بڵێ ”خاوەن شکۆ“، ئیتر چۆن دەبێتە کوڕی؟»
\p 
\v 46 جا کەسیان نەیانتوانی بە وشەیەکیش وەڵامی بدەنەوە، لەو ڕۆژەشەوە ئیتر نەیانوێرا هیچی دیکەی لێ بپرسن.
\c 23
\s1 ئاگادارکردنەوە لە دووڕوویی ڕابەرانی ئایینی
\p 
\v 1 پاشان عیسا بە خەڵکەکە و قوتابییەکانی خۆی
\v 2 فەرموو: «مامۆستایانی تەورات و فەریسییەکان لەسەر کورسی موسا دانیشتن.
\v 3 لەبەر ئەوە ڕێک هەموو ئەوانە جێبەجێ بکەن کە پێتان دەڵێن، بەڵام بە کرداری ئەوان مەکەن، چونکە ئەوان باسی شتێک دەکەن، بەڵام خۆیان کاری پێ ناکەن.
\v 4 باری قورس و گران دەپێچنەوە و دەیخەنە سەر شانی خەڵکی، بەڵام خۆیان نایانەوێت بە هیچ شێوەیەک لە هەڵگرتنی بارەکاندا یارمەتییان بدەن.
\p 
\v 5 «هەموو کردارەکانیان بۆ ئەوەیە خەڵکی بیانبینن، بە پانکردنی نوشتەکانیان و گەورەکردنی گوڵینگەکانیان\f + \fr 23:5 \ft بڕوانە پەڕتووکی \xt سەرژمێری 15‏:37‏-40.‏\xt*\ft ‏\f*.
\v 6 حەز دەکەن لە میوانیدا لەلای سەرەوە و لە کەنیشتەکانیش لە ڕیزی پێشەوە دابنیشن،
\v 7 لە بازاڕیشدا سڵاویان لێ بکرێت و خەڵک بە ”ڕابی\f + \fr 23:7 \ft ڕابی: وشەیەکی عیبرییە بە واتای مامۆستا دێت.‏\f*“ بانگیان بکەن.
\p 
\v 8 «بەڵام با ئێوە بە ”ڕابی“ بانگ نەکرێن، چونکە تەنها یەک مامۆستاتان هەیە و ئێوەش هەموو بران.
\v 9 کەسیش لەسەر زەوی بە ”باوک“ بانگ مەکەن، چونکە یەک باوکتان هەیە، ئەوەی لە ئاسمانە.
\v 10 با بە ”مامۆستا“ بانگ نەکرێن، چونکە یەک مامۆستاتان هەیە، ئەویش مەسیحە.
\v 11 ئەوەی لەنێوتان پایەبەرزترە، دەبێتە خزمەتکارتان.
\v 12 ئەوەی خۆی بەرز بکاتەوە نزم دەکرێتەوە، ئەوەش خۆی نزم بکاتەوە بەرز دەکرێتەوە.
\s1 دووڕوویی فەریسییەکان
\p 
\v 13 «بەڵام قوڕبەسەرتان ئەی مامۆستایانی تەورات و فەریسییەکان! دووڕووان! چونکە دەرگای شانشینی ئاسمان بە ڕووی خەڵکدا دادەخەن، نە خۆتان دەچنە ژوورەوە و نە دەهێڵن ئەوانەی کە دەیانەوێ، بچنە ژوورەوە.
\p 
\v 14 [«قوڕبەسەرتان ئەی مامۆستایانی تەورات و فەریسییەکان! دووڕووان! ماڵی بێوەژن\f + \fr 23:14 \ft لە کتێبی پیرۆزدا بێوەژن مەبەست لەو ئافرەتانەیە کە مێردیان مردووە.‏\f* هەڵدەلووشن، بۆ خۆدەرخستنیش نوێژ درێژ دەکەنەوە، لەبەر ئەوە سزاتان گەورەترە.]
\p 
\v 15 «قوڕبەسەرتان ئەی مامۆستایانی تەورات و فەریسییەکان! دووڕووان! دەریا و وشکانی دەگەڕێن تاکو یەکێک بکەنە جولەکە، کە بووە جولەکە، ئەوسا دوو ئەوەندەی خۆتان دەیکەنە کوڕی دۆزەخ.
\p 
\v 16 «قوڕبەسەرتان ئەی ڕابەرە کوێرەکان! ئێوە دەڵێن: ”ئەوەی سوێند بە پەرستگا بخوات، هیچ نییە. بەڵام ئەوەی سوێند بە زێڕی پەرستگا بخوات، ئەوا دەبێت سوێندەکەی بباتەسەر.“
\v 17 ئەی گێل و کوێرینە! کامیان گرنگترە، زێڕەکە یان پەرستگا کە زێڕەکە پیرۆز دەکات؟
\v 18 هەروەها ئێوە دەڵێن: ”ئەوەی سوێند بە قوربانگا بخوات، هیچ نییە، بەڵام ئەوەی سوێند بە قوربانییەکەی سەری بخوات، ئەوا دەبێت سوێندەکەی بباتەسەر.“
\v 19 ئەی کوێرینە کامیان گرنگترە، قوربانی یان قوربانگا کە قوربانییەکە پیرۆز دەکات؟
\v 20 بۆیە ئەوەی سوێند بە قوربانگا دەخوات، ئەوا سوێند بەو دەخوات و بە هەموو ئەوەش کە لەسەریەتی.
\v 21 ئەوەی سوێند بە پەرستگا دەخوات، ئەوا سوێند بەو دەخوات و بە ئەوەش کە تێیدا نیشتەجێیە.
\v 22 ئەوەی سوێند بە ئاسمان دەخوات، ئەوا سوێند بە تەختی خودا دەخوات و بەوەش کە لەسەری دانیشتووە.
\p 
\v 23 «قوڕبەسەرتان ئەی مامۆستایانی تەورات و فەریسییەکان! دووڕووان! چونکە دەیەکی پونگ و شویت\f + \fr 23:23 \ft شبیت.‏\f* و زیرە دەدەن بەڵام ڕاسپاردە گرنگەکانی تەورات وەکو دادپەروەری و بەزەیی و دڵسۆزیتان پشتگوێ خستووە. پێویست بوو ئەمانە پەیڕەو بکەن و ئەوانەی دیکەش پشتگوێ نەخەن.
\v 24 ئەی ڕابەرە کوێرەکان! ئێوە شلەمەنی لە مێشوولە دەپاڵێون، بەڵام وشتر قووتدەدەن!
\p 
\v 25 «قوڕبەسەرتان ئەی مامۆستایانی تەورات و فەریسییەکان! دووڕووان! چونکە دەرەوەی جام و قاپ پاک دەکەنەوە، بەڵام ناوەکەی پڕە لە چاوچنۆکی و بەڕەڵایی.
\v 26 ئەی فەریسی کوێر، یەکەم جار ناو جام پاک بکەرەوە، تاکو دەرەوەشی پاک بێتەوە.
\p 
\v 27 «قوڕبەسەرتان ئەی مامۆستایانی تەورات و فەریسییەکان! دووڕووان! چونکە ئێوە لە گۆڕی سپیکراو دەچن، کە بە ڕواڵەت جوان دیارە، بەڵام ناوەوەی پڕە لە ئێسقانی مردووان و هەموو پیسییەک.
\v 28 ئێوەش ئاوان، بە ڕواڵەت لەلای خەڵک ڕاستودروستن، بەڵام ناختان پڕە لە دووڕوویی و خراپە.
\p 
\v 29 «قوڕبەسەرتان ئەی مامۆستایانی تەورات و فەریسییەکان! دووڕووان! ئێوە گۆڕی پێغەمبەران هەڵدەبەستن و ئارامگای پیاوچاکان دەڕازێننەوە و
\v 30 دەڵێن: ”ئەگەر لە سەردەمی باوباپیراندا بژیاینایە، لە خوێنڕشتنی پێغەمبەران بەشداریان نەدەبووین.“
\v 31 کەواتە شایەتی لەسەر خۆتان دەدەن کە نەوەی بکوژانی پێغەمبەرانن.
\v 32 جا ئێوە پێوانەی باوباپیرانتان پڕ بکەن!
\p 
\v 33 «ئەی مارینە! ئەی بێچووە ماران! چۆن لە سزای دۆزەخ هەڵدێن؟
\v 34 لەبەر ئەمەیە ئەوەتا پێغەمبەر و دانا و مامۆستایانی تەوراتتان بۆ دەنێرم. هەندێکیان دەکوژن و لە خاچیان دەدەن، هەندێکی دیکەیان لە کەنیشتەکانتان بەر قامچی دەدەن و لە شارێکەوە بۆ شارێکی دیکە ڕاویان دەنێن.
\v 35 لەبەر ئەوە خوێنی هەموو پیاوچاکان کە لەسەر ئەم زەوییەدا ڕژاوە دەکەوێتە ئەستۆتان، لە خوێنی هابیلی ڕاستودروستەوە هەتا خوێنی زەکەریای کوڕی بەرەخیا کە لەنێوان قوربانگا و پەرستگادا کوشتتان.
\v 36 ڕاستیتان پێ دەڵێم: ئۆباڵی هەموو ئەمانە دەکەوێتە ئەستۆی ئەم نەوەیە.»
\s1 خەمباری عیسا سەبارەت بە ئۆرشەلیم
\p 
\v 37 «ئەی ئۆرشەلیم، ئەی ئۆرشەلیم، بکوژی پێغەمبەران و بەردبارانکەری ئەوانەی بۆت نێردران، چەند جار ویستم منداڵەکانت کۆبکەمەوە، هەروەک چۆن مریشک جوجەڵەکانی لەژێر باڵیدا کۆدەکاتەوە، بەڵام نەتانویست.
\v 38 ئەوەتا ماڵەکەتان بە وێرانی بۆ بەجێدەهێڵدرێ!
\v 39 پێتان دەڵێم، ئیتر نامبیننەوە، هەتا ئەو کاتەی دەڵێن: ﴿پیرۆزە ئەوەی بە ناوی یەزدانەوە دێت.﴾\f + \fr 23:39 \ft \xt زەبوورەکان 118‏:26‏\xt*\ft ‏\f*»
\c 24
\s1 پێشبینی وێرانبوونی پەرستگا
\p 
\v 1 عیسا لە پەرستگا هاتە دەرەوە، هێشتا لە ڕێگا بوو کاتێک قوتابییەکانی لێی هاتنە پێشەوە تاکو سەرنجی بۆ تەلارەکانی پەرستگا ڕابکێشن.
\v 2 عیسا پێی فەرموون: «هەموو ئەمانە دەبینن؟ ڕاستیتان پێ دەڵێم: لێرەدا بەردی بەسەر بەردیەوە نامێنێت و هەمووی دەڕووخێت.»
\s1 نیشانەکانی کۆتایی زەمان
\p 
\v 3 کاتێک لەسەر کێوی زەیتوون دانیشتبوو، قوتابییەکان بە تەنها هاتنە لای و گوتیان: «پێمان بفەرموو کەی ئەمە ڕوودەدات؟ هەروەها نیشانەی هاتنەوەت و کۆتایی زەمان چییە؟»
\p 
\v 4 عیسا وەڵامی دایەوە: «ئاگاداربن، کەس چەواشەتان نەکات،
\v 5 چونکە زۆر کەس بە ناوی منەوە دێن و دەڵێن ”من مەسیحەکەم،“ زۆر کەسیش چەواشە دەکەن.
\v 6 جەنگ و هەواڵی جەنگیش دەبیستن، وریابن مەتۆقن، چونکە دەبێت ئەمە ڕووبدات، بەڵام هێشتا کۆتایی نییە.
\v 7 نەتەوە لە نەتەوە ڕاست دەبێتەوە و شانشین لە شانشین، قاتوقڕی و بوومەلەرزەش لە شوێنی جیاجیا دەبێت.
\v 8 بەڵام ئەمانە هەمووی سەرەتای ژانەکانن.
\p 
\v 9 «ئینجا بۆ چەوسانەوە بە گرتنتان دەدەن و دەتانکوژن، هەموو نەتەوەکان لەبەر ناوی من ڕقیان لێتان دەبێتەوە.
\v 10 ئەو کاتە زۆر کەس واز لە باوەڕەکەیان دەهێنن و یەکتری بە گرتن دەدەن و ڕقیان لە یەکتری دەبێتەوە.
\v 11 زۆر پێغەمبەری درۆزن دەردەکەون، زۆر کەس چەواشە دەکەن.
\v 12 لەبەر زۆربوونی خراپە، خۆشەویستی زۆر کەس سارد دەبێتەوە.
\v 13 بەڵام ئەوەی هەتا کۆتایی دانبەخۆیدا بگرێت، ڕزگاری دەبێت.
\v 14 ئەم مزگێنی پاشایەتییەش لە هەموو جیهاندا ڕادەگەیەنرێت، وەک شایەتییەک بۆ هەموو نەتەوەکان، ئینجا کۆتاییەکە دێت.
\s1 گەورەترین تەنگانە
\p 
\v 15 «لەبەر ئەوە کاتێک دەبینن ﴿قێزەونی وێرانکەر﴾\f + \fr 24:15 \ft \xt دانیال 9‏:27؛ 11‏:31؛ 12‏:11‏\xt*\ft ‏\f* لە شوێنی پیرۆزدا ڕاوەستاوە، ئەوەی پێغەمبەر دانیال باسی کردووە (با خوێنەر تێبگات)،
\v 16 ئینجا با ئەوانەی لە یەهودیان بەرەو چیاکان ڕابکەن،
\v 17 ئەوەی لە سەربانە با نەیەتە خوارەوە تاکو شتەکانی لە ماڵەوە ببات.
\v 18 هەروەها ئەوەی لە کێڵگەیە با نەگەڕێتەوە تاکو جلەکەی ببات.
\v 19 لەو ڕۆژانەدا قوڕبەسەر دووگیان و شیردەر!
\v 20 نوێژ بکەن با هەڵاتنتان لە زستان یان لە شەممەدا نەبێت،
\v 21 چونکە لەو کاتەدا تەنگانەیەکی وا گەورە ڕوودەدات کە لە سەرەتای جیهانەوە هەتا ئێستا ئاوا نەبووە و نابێت.
\p 
\v 22 «ئەگەر ئەو ڕۆژانە کەم نەکرابوونایەوە، کەس ڕزگاری نەدەبوو. بەڵام لە پێناوی ئەوانەی هەڵبژێردراون، ئەو ڕۆژانە کەم دەکرێنەوە.
\v 23 ئەگەر ئەو کاتە یەکێک پێی گوتن: ”ئەوەتا مەسیح لێرەیە!“ یان: ”ئەوەتا لەوێیە!“ باوەڕ مەکەن،
\v 24 چونکە چەند مەسیحێکی درۆزن\f + \fr 24:24 \ft کەسانێک بانگەشەی ئەوە دەکەن کە مەسیحن.‏\f* و پێغەمبەرانی درۆزن دەردەکەون، نیشانەی گەورە و پەرجوو دەکەن، بە شێوەیەک ئەگەر بکرێت تەنانەت هەڵبژێردراوانیش چەواشە دەکەن.
\v 25 ئەوەتا پێشوەخت پێم گوتن.
\p 
\v 26 «لەبەر ئەوە ئەگەر پێیان گوتن: ”ئەوەتا لە چۆڵەوانییە!“ مەڕۆن، یان ”ئەوەتا لە ژوورەوەیە!“ باوەڕ مەکەن،
\v 27 چونکە وەک چۆن هەورەتریشقە دێت و ڕووناکی دەدات لە ڕۆژهەڵاتەوە هەتا ڕۆژئاوا، هاتنەوەی کوڕی مرۆڤیش ئاوا دەبێت.
\v 28 کەلاک لەکوێ بێت، داڵ لەوێ کۆدەبێتەوە.
\s1 هاتنەوەی عیسا
\p 
\v 29 «دەستبەجێ دوای تەنگانەی ئەو ڕۆژانە،
\q1 «﴿خۆر تاریک دەبێت، مانگ ڕووناکییەکەی نادات،
\q2 ئەستێرەکان لە ئاسمان دەکەون،
\q1 تەنی ئاسمانی دەهەژێن.﴾\f + \fr 24:29 \ft \xt ئیشایا 13‏:10؛ 34‏:4‏\xt*\ft ‏\f*
\p 
\v 30 «لەو کاتە نیشانەی کوڕی مرۆڤ لە ئاسماندا دەردەکەوێت، ئەوسا هەموو نەتەوەکانی زەوی شیوەن دەگێڕن، کاتێک کوڕی مرۆڤ دەبینن بەسەر هەوری ئاسمانەوە بە هێز و شکۆیەکی مەزنەوە دێت.\f + \fr 24:30 \ft \xt دانیال 7‏:13‏\xt*\ft ‏\f*
\v 31 فریشتەکانی بە کەڕەنایەکی دەنگ بەرزەوە دەنێرێت، لە ئاراستەی هەر چوار بایەکە، لەم سەری ئاسمانەوە هەتا ئەو سەری، هەڵبژێردراوانی خودا کۆدەکەنەوە.
\s1 پەندی دار هەنجیر
\p 
\v 32 «پەند لە دار هەنجیر وەربگرن: کاتێک لقەکانی نەرم بوون و گەڵایان کرد، دەزانن هاوین نزیکە.
\v 33 بە هەمان شێوە، کاتێک ئێوەش هەموو ئەم شتانە دەبینن، بزانن کە نزیکە و لە بەردەرگایە.
\v 34 ڕاستیتان پێ دەڵێم: ئەم نەوەیە بەسەرناچێت، هەتا هەموو ئەمانە نەیەنە دی.
\v 35 ئاسمان و زەوی بەسەردەچن، بەڵام وشەکانم هەرگیز بەسەرناچن.
\s1 کەس ئەو کاتە نازانێت
\p 
\v 36 «سەبارەت بەو ڕۆژ و کاتە کەس نایزانێت، نە فریشتەکانی ئاسمان و نە کوڕەکە، تەنها باوک نەبێت.
\v 37 ڕۆژانی نوح چۆن بوو، کاتی هاتنەوەی کوڕی مرۆڤیش ئاوا دەبێت.
\v 38 وەک چۆن لە ڕۆژانی پێش لافاوەکە دەیانخوارد و دەیانخواردەوە، ژنیان دەهێنا و مێردیان دەکرد، هەتا ئەو ڕۆژەی نوح چووە ناو کەشتییەکە،
\v 39 کەس نەیدەزانی چی ڕوودەدات، هەتا لافاوەکە هات و هەمووی برد. هاتنەوەی کوڕی مرۆڤیش ئاوا دەبێت.
\v 40 لەو کاتەدا دوو پیاو لە کێڵگە دەبن، یەکیان دەبردرێت و ئەوی دیکە بەجێدەهێڵدرێت.
\v 41 دوو ژن دەستاڕ دەگێڕن، یەکیان دەبردرێت و ئەوی دیکە بەجێدەهێڵدرێت.
\p 
\v 42 «لەبەر ئەوە ئێشک بگرن، چونکە نازانن لە چ ڕۆژێکدا مەسیحی خاوەن شکۆتان دێتەوە.
\v 43 بەڵام ئەوەش بزانن: ئەگەر گەورەی ماڵ بزانێت لە چ کاتێکدا دز دێتە سەری، ئێشک دەگرێت و نایەڵێت ماڵەکەی ببڕدرێت.
\v 44 کەواتە ئێوەش ئامادە بن، چونکە کوڕی مرۆڤ لە کاتێکدا دێتەوە کە بیری لێ ناکەنەوە.
\s1 نموونەی کۆیلەی دڵسۆز
\p 
\v 45 «کەواتە ئەو کۆیلە دڵسۆز و ژیرە کێیە کە گەورەکەی کردوویەتی بە لێپرسراوی خزمەتکارەکانی دیکەی تاکو لە کاتی خۆیدا خواردنیان بداتێ؟
\v 46 خۆزگە دەخوازرێت بەو کۆیلەیە کاتێک گەورەکەی دێتەوە دەبینێت ئەرکی خۆی جێبەجێ دەکات.
\v 47 ڕاستیتان پێ دەڵێم: بەسەر هەموو ماڵەکەیەوە دایدەنێت.
\v 48 بەڵام وای دابنێ کە ئەو کۆیلەیە خراپە و لە دڵی خۆیدا دەڵێ: ”گەورەکەم دوادەکەوێت،“
\v 49 بەو هۆیەوە دەست دەکات بە لێدانی کۆیلە هاوکارەکانی و لەگەڵ سەرخۆشان دەخوات و دەخواتەوە.
\v 50 ئیتر گەورەی ئەو کۆیلەیە لە ڕۆژێکدا دێتەوە کە چاوەڕێی ناکات و لە کاتژمێرێک کە نایزانێت.
\v 51 ئەوسا پارچەپارچەی دەکات و بەشی لەگەڵ دووڕوواندا دادەنێت، جا گریان و جیڕەی ددان لەوێ دەبێت.
\c 25
\s1 نموونەی کچە داناکان و کچە گێلەکان
\p 
\v 1 «لەو کاتەدا شانشینی ئاسمان وەکو دە پاکیزە دەبێ، کە چرایان هەڵگرتبێت و بەرەوپیری زاوا بچن.
\v 2 پێنج لەوان گێل بوون، پێنجیش دانا.
\v 3 گێلەکان چراکانیان برد و زەیتیان\f + \fr 25:3 \ft لەو سەردەمەدا چرا بە زەیتی زەیتوون ئیشی دەکرد.‏\f* لەگەڵ خۆیان نەبرد.
\v 4 بەڵام داناکان لەگەڵ چراکانیان زەیتیان لەناو گۆزەدا برد.
\v 5 کاتێک زاوا دواکەوت، هەموو خەو بردنییەوە و نوستن.
\p 
\v 6 «لە نیوەشەودا هاوار کرا: ”ئەوەتا زاوا هات! بەرەوپیری بچن!“
\p 
\v 7 «هەموو ئەو پاکیزانەش هەستان و چراکانیان ئامادە کرد.
\v 8 گێلەکان بە داناکانیان گوت: ”لە زەیتەکەی خۆتان بەشمان بدەن، چونکە چراکانمان دەکوژێتەوە!“
\p 
\v 9 «بەڵام داناکان وەڵامیان دانەوە: ”لەوانەیە بەشی ئێمە و ئێوە نەکات. چاکترە بچنە لای فرۆشیاران و بۆ خۆتان بکڕن.“
\p 
\v 10 «لەکاتێکدا گێلەکان ڕۆیشتن بۆ زەیت کڕین، زاوا گەیشت، ئەوانەی ئامادە بوون لەگەڵی چوونە ژوورەوە بۆ زەماوەندەکە و دەرگا داخرا.
\p 
\v 11 «پاشان پاکیزەکانی دیکەش هاتن و گوتیان: ”گەورەم، گەورەم! دەرگامان لێ بکەرەوە!“
\p 
\v 12 «وەڵامی دایەوە: ”ڕاستیتان پێ دەڵێم، من ناتانناسم.“
\p 
\v 13 «کەواتە ئێشک بگرن، چونکە ڕۆژ و کاتەکە نازانن.
\s1 نموونەی دواکەوتنی گەورەی ماڵ
\p 
\v 14 «هەروەها شانشینی ئاسمان وەک پیاوێکە کە پێش گەشتکردنی، کۆیلەکانی بانگ کرد و ماڵ و سامانەکەی خۆی دایە دەستیان.
\v 15 پێنج کیسە زێڕی\f + \fr 25:15 \ft کیسە زێڕ: یۆنانی: \tl تالنت‏\tl*، هەر تالنتێک نزیکەی 34 کگم بووە؛ یەک \tl تالنت‏\tl* زێڕ دەکاتە کرێی 15 ساڵی کرێکارێک.‏\f* دایە یەکێکیان و ئەوی دیکە دوو کیسە و سێیەمیش یەک کیسە، هەریەکە بەگوێرەی توانای خۆی. ئینجا چووە گەشت.
\v 16 ئەوەی پێنج کیسە زێڕەکەی وەرگرت، ڕۆیشت و ئیشی پێوە کرد، پێنجی دیکەشی قازانج کرد.
\v 17 بە هەمان شێوە ئەوەی دوو کیسە زێڕەکەش، دووی دیکەی قازانج کرد.
\v 18 بەڵام ئەوەی یەک کیسە زێڕەکەی وەرگرت، ڕۆیشت و چاڵێکی لە زەویدا هەڵکەند و زێڕی گەورەکەی تێدا شاردەوە.
\p 
\v 19 «دوای ماوەیەکی زۆر گەورەی ئەو کۆیلانە گەڕایەوە و حیسابی لەگەڵ کردن.
\v 20 ئەوەی پێنج کیسە زێڕەکەی وەرگرتبوو، هات و پێنج کیسەی دیکەشی هێنا و پێی گوت: ”گەورەم تۆ پێنج کیسە زێڕت دامێ، ئەوەتا پێنج کیسە زێڕی دیکەم قازانج کردووە.“
\p 
\v 21 «گەورەکەی پێی گوت: ”ئافەرین، ئەی کۆیلەی چاک و دەستپاک! لە کەم دەستپاک بوویت، زۆرت پێ دەسپێرم. وەرە ژوورەوە بۆ خۆشی گەورەکەت.“
\p 
\v 22 «هەروەها ئەوەی دوو کیسە زێڕەکەی وەرگرتبوو، هات و گوتی: ”گەورەم تۆ دوو کیسە زێڕت دامێ، ئەوەتا دوو کیسە زێڕی دیکەم قازانج کردووە.“
\p 
\v 23 «گەورەکەی پێی گوت: ”ئافەرین، ئەی کۆیلەی چاک و دەستپاک! لە کەم دەستپاک بوویت، زۆرت پێ دەسپێرم. وەرە ژوورەوە بۆ خۆشی گەورەکەت.“
\p 
\v 24 «ئینجا ئەوەی یەک کیسە زێڕەکەی وەرگرتبوو، هات و گوتی: ”گەورەم، زانیم تۆ پیاوێکی دڵڕەقیت، لە شوێنێک کۆدەکەیتەوە کە نەتچاندووە و لە شوێنێکیش دروێنە دەکەیت کە تۆوت نەکردووە.
\v 25 جا ترسام و چووم کیسە زێڕەکەتم لەناو زەویدا شاردەوە. ها ئەوە ماڵەکەتە.“
\p 
\v 26 «گەورەکەی وەڵامی دایەوە: ”ئەی کۆیلەی بەدکار و تەوەزەل! کە زانیت من دروێنە لەو شوێنە دەکەم کە نەمچاندووە، لەوە کۆدەکەمەوە کە تۆوم نەکردووە،
\v 27 دەبووایە زێڕەکەمت لە بانک دابنابووایە، لە گەڕانەوەمدا ئەوەی هی منە لەگەڵ سوودەکەی وەرمدەگرتەوە.
\p 
\v 28 «”لەبەر ئەوە ئەو کیسە زێڕەی لێ بسەننەوە و بیدەنە ئەوەی دە کیسە زێڕەکەی پێیە،
\v 29 چونکە ئەوەی هەیەتی، پێی دەدرێت و لێی دەڕژێ، بەڵام ئەوەی نییەتی تەنانەت ئەوەی هەشیەتی لێی دەسەنرێتەوە.
\v 30 کۆیلە بێ سوودەکەش فڕێبدەنە تاریکی دەرەوە، جا گریان و جیڕەی ددان لەوێ دەبێت.“
\s1 عیسا حوکم بەسەر جیهاندا دەدات
\p 
\v 31 «کاتێک کوڕی مرۆڤ بە شکۆمەندی خۆیەوە دێتەوە و هەموو فریشتەکانیش لەگەڵیدان، لەسەر تەختی شکۆمەندیی خۆی دادەنیشێت.
\v 32 هەموو نەتەوەکان لەبەردەمی کۆدەبنەوە و ئەویش لە یەکتریان جیا دەکاتەوە، وەک چۆن شوان مەڕ لە بزن جیا دەکاتەوە.
\v 33 جا مەڕەکان لەلای ڕاستی خۆی ڕادەگرێت، بەڵام بزنەکان لەلای چەپ.
\p 
\v 34 «ئینجا پاشا بەوانەی لای ڕاستیەوەن دەفەرموێ: ”وەرن ئەی ئەوانەی باوکم بەرەکەتی پێدان، ببنە میراتگری ئەو شانشینە کە لە دامەزراندنی جیهانەوە بۆتان ئامادە کراوە،
\v 35 چونکە برسی بووم نانتان دامێ، تینوو بووم ئاوتان دامێ، نامۆ بووم شوێنتان کردمەوە.
\v 36 ڕووت بووم جلتان لەبەرکردم، نەخۆش بووم سەرتان لێدام، زیندانی بووم هاتنە لام.“
\p 
\v 37 «ئەوسا ڕاستودروستان وەڵام دەدەنەوە: ”گەورەم، کەی تۆمان بە برسیێتی بینیوە و نانمان داویتێ، یان تینوو و ئاومان داویتێ؟
\v 38 کەی تۆمان بە نامۆیی بینیوە و شوێنمان کردوویتەوە، یان بە ڕووتی و جلمان لەبەرکردوویت؟
\v 39 کەی تۆمان بە نەخۆشی یان زیندانی بینیوە و هاتووین بۆ لات؟“
\p 
\v 40 «ئینجا پاشا وەڵامیان دەداتەوە: ”ڕاستیتان پێ دەڵێم، هەرچییەکتان بۆ یەکێک لەم برا بچووکانەم کردووە، بۆ منتان کردووە.“
\p 
\v 41 «دواتر بەوانەی لەلای چەپیەوەن دەفەرموێ: ”ئەی ئەوانەی کە نەفرەتتان لێکراوە! لێم دوور بکەونەوە و بەرەو ئاگری هەتاهەتایی بڕۆن، ئەوەی بۆ ئیبلیس و فریشتەکانی ئامادە کراوە،
\v 42 چونکە برسی بووم نانتان نەدامێ، تینوو بووم ئاوتان نەدامێ،
\v 43 نامۆ بووم شوێنتان نەکردمەوە، ڕووت بووم جلتان لەبەر نەکردم، نەخۆش و زیندانی بووم سەرتان لێ نەدام.“
\p 
\v 44 «ئەوانیش وەڵام دەدەنەوە: ”گەورەم، کەی تۆمان بە برسیێتی یان تینووێتی یان نامۆیی یان ڕووتی یان نەخۆشی یان زیندانی بینیوە و خزمەتمان نەکردوویت؟“
\p 
\v 45 «ئەویش وەڵامیان دەداتەوە: ”ڕاستیتان پێ دەڵێم: هەرچییەکتان بۆ یەکێک لەم بچووکانە نەکردووە، بۆ منتان نەکردووە.“
\p 
\v 46 «ئەوانە بۆ سزای هەتاهەتایی دەچن، بەڵام ڕاستودروستان بۆ ژیانی هەتاهەتایی.»
\c 26
\s1 پیلانگێڕی بۆ کوشتنی عیسا
\p 
\v 1 کاتێک عیسا ئەم وتانەی هەموو تەواو کرد، بە قوتابییەکانی خۆی فەرموو:
\v 2 «دەزانن جەژنی پەسخە\f + \fr 26:2 \ft جەژنێکی جولەکەیە، یادی ڕزگاربوونی گەلی ئیسرائیلە لە میسر لە نزیکەی 1400 ساڵ پ. ز. بە ڕابەرایەتی موسا. بڕوانە \xt دەرچوون 12‏:1‏-50.‏\xt*\ft ‏\f* دوو ڕۆژی ماوە. کوڕی مرۆڤیش بە گرتن دەدرێت تاکو لە خاچ بدرێت.»
\p 
\v 3 ئینجا کاهینانی باڵا و پیرانی گەل لە کۆشکی سەرۆکی کاهینان کە ناوی قەیافا بوو کۆببوونەوە،
\v 4 پێکەوە تەگبیریان دەکرد بۆ ئەوەی بە فێڵێک عیسا بگرن و بیکوژن.
\v 5 گوتیان: «با لە جەژندا نەبێت، نەوەک ئاژاوە بکەوێتە ناو خەڵک.»
\s1 ئامادەکردنی عیسا بۆ ناشتنی
\p 
\v 6 کاتێک عیسا لە گوندی بێت‌عەنیا لە ماڵی شیمۆنە گول بوو،
\v 7 ژنێک بە بوتڵێکی ئەلەباستەریی\f + \fr 26:7 \ft لە بەردی ئەلەباستەر دروستکرابوو، ئەم جۆرە بەردە لە میسر هەیە بۆ تاشین ئاسانە و ڕەنگەکەی قاوەییە.‏\f* بۆنی گرانبەهاوە بۆ لای هات و بۆنەکەی بەسەریدا ڕژاند کە لەسەر خوان بوو.
\p 
\v 8 کاتێک قوتابییەکان ئەمەیان بینی، تووڕە بوون و گوتیان: «ئەم دەستبڵاوییەی بۆ چییە؟
\v 9 دەکرا ئەو بۆنە بە نرخێکی گران بفرۆشرایە و پارەکەی بدرایە بە هەژاران.»
\p 
\v 10 عیسا بەمەی زانی و پێی فەرموون: «بۆچی ئەم ژنە بێزار دەکەن؟ شتێکی چاکی بۆ من کرد.
\v 11 هەژاران هەمیشە لەگەڵتانن، بەڵام من هەمیشە لەلاتان نیم.
\v 12 کاتێک ئەو ئەم بۆنەی بەسەر لەشمدا ڕژاند، بۆ ئامادەکردنم بۆ ناشتن ئەمەی کرد.
\v 13 ڕاستیتان پێ دەڵێم: لە هەر شوێنێکی جیهاندا ئەم مزگێنییە ڕابگەیەنرێت، وەک یادکردنەوەیەک باسی ئەوەش دەکرێت کە ئەم ژنە کردوویەتی.»
\s1 ناپاکی یەهوزا
\p 
\v 14 ئینجا یەکێک لە دوازدە قوتابییەکە کە ناوی یەهوزای ئەسخەریوتی بوو، چوو بۆ لای کاهینانی باڵا،
\v 15 گوتی: «چیم دەدەنێ تاکو بیدەمە دەستتان؟» ئەوانیش سی دراوی زیویان بۆ ژمارد.
\v 16 ئیتر لەو کاتەوە یەهوزا بۆ هەلێک دەگەڕا تاکو عیسا بە گرتن بدات.
\s1 جەژنی پەسخە
\p 
\v 17 لە یەکەم ڕۆژی جەژنی فەتیرەدا\f + \fr 26:17 \ft ناوێکی دیکەیە بۆ جەژنی پەسخە، بە یادی ڕۆژانی ئاوارەیی لە میسر نانی فەتیرەیان خواردووە.‏\f*، قوتابییەکان هاتنە لای عیسا و لێیان پرسی: «دەتەوێ لەکوێ ئامادەکاریت بۆ بکەین تاکو نانی پەسخە بخۆیت؟»
\p 
\v 18 فەرمووی: «بڕۆنە ناو شار، بۆ لای فڵانە کەس، پێی بڵێن: ”مامۆستا دەفەرموێ، کاتم نزیک بووەتەوە، لەگەڵ قوتابییەکانم لەلای تۆ نانی پەسخە دەخۆم.“»
\v 19 قوتابییەکانیش فەرمانی عیسایان جێبەجێ کرد و نانی پەسخەیان ئامادە کرد.
\p 
\v 20 کە ئێوارە داهات، عیسا لەگەڵ دوازدە قوتابییەکە پاڵی دایەوە.
\v 21 کاتێک نانیان دەخوارد، فەرمووی: «ڕاستیتان پێ دەڵێم: یەکێکتان بە گرتنم دەدات.»
\p 
\v 22 ئەوانیش زۆر خەمبار بوون، هەریەکە پێیان گوت: «گەورەم، خۆ ئەو کەسە من نیم؟»
\p 
\v 23 وەڵامی دایەوە: «ئەوەی لەگەڵم دەست دەخاتە ناو قاپەکە، ئەو بە گرتنم دەدات.
\v 24 کوڕی مرۆڤ دەبێت وەک ئەوەی لەبارەیەوە نووسراوە بڕوات، بەڵام قوڕبەسەر ئەوەی کوڕی مرۆڤ بە گرتن دەدات! باشتر بوو بۆ ئەو کەسە هەر لەدایک نەبووایە.»
\p 
\v 25 ئینجا یەهوزا، ئەوەی بە گرتنی دەدات، وەڵامی دایەوە: «ڕابی، خۆ ئەو کەسە من نیم؟»
\p پێی فەرموو: «خۆت گوتت.»
\s1 دوایین شێوی مەسیح
\p 
\v 26 کاتێک نانیان دەخوارد، عیسا نانێکی هەڵگرت، سوپاسی خودای کرد و لەتی کرد، دایە قوتابییەکان و فەرمووی: «وەریبگرن و بیخۆن، ئەمە جەستەی منە.»
\p 
\v 27 ئینجا جامێکی هەڵگرت و سوپاسی خودای کرد، پێیدان و فەرمووی: «هەموو لێی بخۆنەوە،
\v 28 چونکە ئەمە خوێنی منە، خوێنی پەیمانەکەیە کە لە پێناوی خەڵکێکی زۆر بۆ گوناه بەخشین دەڕژێت.
\v 29 پێتان دەڵێم: لەمەودوا ئیتر لەم بەرهەمەی مێو ناخۆمەوە، هەتا ئەو ڕۆژە دێت کە سەر لە نوێ لە شانشینی باوکم لەگەڵتان دەیخۆمەوە.»
\p 
\v 30 ئینجا گۆرانیی ڕۆحییان\f + \fr 26:30 \ft خوێندنەوەی زەبوور لە شێوەی گۆرانی.‏\f* گوت و چوون بۆ دەرەوەی شار بۆ کێوی زەیتوون.
\s1 پێشبینی نکۆڵیکردنی پەترۆس
\p 
\v 31 ئینجا عیسا پێی فەرموون: «ئەمشەو بەهۆی ئەوەی بەسەرم دێت هەمووتان پشتم تێ دەکەن، چونکە نووسراوە:
\q1 «﴿لە شوانەکە دەدەم،
\q2 مەڕی مێگەلەکە پەرت دەبن.﴾\f + \fr 26:31 \ft \xt زەکەریا 13‏:7‏\xt*\ft ‏\f*
\m 
\v 32 بەڵام دوای هەستانەوەم، پێشتان دەکەوم بۆ جەلیل.»
\p 
\v 33 پەترۆس وەڵامی دایەوە: «ئەگەر لەوەی بەسەرت بێت هەموو پشتت لێ بکەن، من قەت پشتت لێ ناکەم.»
\p 
\v 34 عیسا پێی فەرموو: «ڕاستیت پێ دەڵێم، ئەمشەو پێش خوێندنی کەڵەشێر، سێ جار نکۆڵی لە ناسینی من دەکەیت.»
\p 
\v 35 پەترۆسیش پێی گوت: «تەنانەت ئەگەر پێویست بکات لەگەڵیشت بمرم، هەرگیز نکۆڵیت لێ ناکەم.» هەموو قوتابییەکانی دیکەش وایان گوت.
\s1 نوێژی عیسا لە باخی گەتسیمانی
\p 
\v 36 دوای ئەوە عیسا لەگەڵیان بۆ شوێنێک چوو پێی دەگوترا، گەتسیمانی، بە قوتابییەکانی فەرموو: «لێرە دانیشن هەتا دەچمە ئەوێ نوێژ دەکەم.»
\v 37 پەترۆس و دوو کوڕەکەی زەبدی برد و پەژارە و دڵتەنگی دایدەگرت.
\v 38 پێی فەرموون: «زۆر دڵتەنگم خەریکە بمرم، لێرە بمێننەوە و ئێشکم لەگەڵ بگرن.»
\p 
\v 39 کەمێک چووە پێش و بەسەر ڕوودا کەوت، نوێژی کرد و فەرمووی: «باوکە، ئەگەر دەکرێت، با ئەم جامەم لێ دوور بخرێتەوە، بەڵام نەک بە خواستی من، بەڵکو بە خواستی تۆ.»
\p 
\v 40 ئینجا گەڕایەوە بۆ لای قوتابییەکان، بینی نوستوون، بە پەترۆسی فەرموو: «ئەرێ نەتانتوانی کاتژمێرێک ئێشکم لەگەڵ بگرن؟
\v 41 ئێشک بگرن و نوێژ بکەن، تاکو نەکەونە ناو تاقیکردنەوەوە. ڕۆح چالاکە، بەڵام جەستە لاوازە.»
\p 
\v 42 دیسان چووەوە نوێژی کرد: «باوکە! ئەگەر ناکرێت ئەمە لەسەرم تێبپەڕێت و هەر دەبێت بیخۆمەوە، با خواستی تۆ پەیڕەو بکرێت.»
\p 
\v 43 کاتێک کە دووبارە گەڕایەوە، بینی نوستوون، چونکە چاویان قورس ببوو.
\v 44 ئیتر وازی لێ هێنان و چوو بۆ جاری سێیەم نوێژی کرد و هەمان شتی گوتەوە.
\p 
\v 45 دوایی هاتەوە لای قوتابییەکان و پێی فەرموون: «هێشتا نوستوون و پشوو دەدەن؟ ئەوەتا کاتەکە نزیک بووەتەوە و کوڕی مرۆڤ دەدرێتە دەست گوناهباران.
\v 46 هەستن با بڕۆین! ئەوەتا ئەوەی بە گرتنم دەدات نزیک بووەوە.»
\s1 گرتنی عیسا
\p 
\v 47 هێشتا ئەو قسەی دەکرد، یەهوزا هات، کە یەکێک بوو لە دوازدە قوتابییەکە، کۆمەڵێکی زۆری لەگەڵ بوو کە بە شمشێر و کوتەکەوە لەلایەن کاهینانی باڵا و پیرانی گەلەوە نێردرابوون.
\v 48 ئەوەی بە گرتنی دەدا نیشانەیەکی پێدابوون، گوتبووی: «ئەوەی ماچی دەکەم ئەوە خۆیەتی، بیگرن.»
\v 49 دەستبەجێ هاتە لای عیسا و گوتی: «سڵاو ڕابی\f + \fr 26:49 \ft ڕابی: وشەیەکی عیبرییە بە واتای مامۆستا دێت.‏\f*.» ئینجا ماچی کرد.
\p 
\v 50 عیساش پێی فەرموو: «هاوڕێ، ئەوەی بۆی هاتووی بیکە.» ئینجا هاتنە پێشەوە و عیسایان دەستبەسەر کرد و گرتییان.
\v 51 لەناکاو یەکێک لەوانەی لەگەڵ عیسادا بوو، دەستی درێژکرد و شمشێرەکەی هەڵکێشا، لە خزمەتکاری سەرۆکی کاهینانی دا و گوێی بڕی.
\p 
\v 52 عیسا پێی فەرموو: «شمشێرەکەت بگەڕێنەوە شوێنی خۆی، چونکە هەموو ئەوانەی شمشێر هەڵدەگرن، بە شمشێر دەمرن.
\v 53 ئایا وا دەزانیت ناتوانم بانگی باوکم بکەم و زیاتر لە دوازدە لەشکر فریشتەم بۆ بنێرێت؟
\v 54 بەڵام ئیتر چۆن نووسراوە پیرۆزەکان دێنە دی، کە دەڵێن بەو شێوەیە پێویستە ڕووبدات؟»
\p 
\v 55 لەو کاتەدا عیسا بە خەڵکەکەی فەرموو: «ئایا من کەسێکی یاخیبووم کە بە کوتەک و شمشێرەوە هاتوون بمگرن؟ ڕۆژانە لە حەوشەکانی پەرستگا دانیشتبووم خەریکی فێرکردن بووم، نەتانگرتم.
\v 56 بەڵام ئەمانە هەمووی ڕوویدا بۆ هاتنەدی نووسراوە پیرۆزەکانی پێغەمبەران.» ئینجا هەموو قوتابییەکان بەجێیان هێشت و ڕایانکرد.
\s1 دادگاییکردنی عیسا
\p 
\v 57 ئەوانەی عیسایان گرت، بردیانە لای قەیافای سەرۆکی کاهینان، لەوێ مامۆستایانی تەورات و پیران کۆببوونەوە.
\v 58 پەترۆسیش دووربەدوور بۆ حەوشەی ماڵی سەرۆکی کاهینان دوای کەوت، ئینجا چووە ژوورەوە و لەنێو خزمەتکاران دانیشت تاکو دەرئەنجامەکەی ببینێت.
\p 
\v 59 کاهینانی باڵا و هەموو ئەندامانی ئەنجومەنی باڵای جولەکە\f + \fr 26:59 \ft ئەنجومەنی باڵای جولەکە کە لە یۆنانی پێی گوتراوە \tl سەنهەدرین‏\tl*، باڵاترین دەسەڵاتی جولەکە بووە کە دەسەڵاتی دەرکردنی بڕیاری ئایینی و شارستانی و تاوانبارکردنی هەبووە.‏\f* بەدوای شایەتییەکی درۆدا دەگەڕان لەسەر عیسا، تاکو سزای کوشتنی بەسەردا بدەن.
\v 60 بەڵام هیچیان نەدۆزییەوە، هەرچەندە زۆر شایەتی درۆزن هاتن.
\p لە کۆتاییدا دووان هاتن،
\v 61 گوتیان: «ئا ئەمە گوتی: ”دەتوانم پەرستگای خودا بڕووخێنم و بە سێ ڕۆژ بنیادی بنێمەوە.“»
\p 
\v 62 جا سەرۆکی کاهینان هەستا و پێی گوت: «هیچ وەڵام نادەیتەوە؟ ئەم پیاوانە چ شایەتییەکت لەسەر دەدەن؟»
\v 63 بەڵام عیسا بێدەنگ بوو.
\p سەرۆکی کاهینانیش پێی گوت: «سوێندت دەدەم بە خودای زیندوو، پێمان بڵێ، ئایا تۆ مەسیحەکەی\f + \fr 26:63 \ft جولەکەکان چاوەڕێی هاتنی مەسیحیان دەکرد کە کوڕی خودایە و بۆ ئازادکردنی گەلی ئیسرائیل دێتە سەر زەوی.‏\f*، کوڕی خودای.»
\p 
\v 64 عیسا پێی فەرموو: «خۆت گوتت. منیش پێتان دەڵێم، لە ئێستاوە کوڕی مرۆڤ دەبینن لە دەستەڕاستی خودای توانادار دادەنیشێت و بەسەر هەوری ئاسمانەوە دێتەوە.\f + \fr 26:64 \ft \xt زەبوورەکان 110‏:1 و دانیال 7‏:13‏،14‏.‏\xt*\ft ‏\f*»
\p 
\v 65 ئینجا سەرۆکی کاهینان جلەکانی خۆی دادڕی و گوتی: «کفری کرد! ئیتر چ پێویستیمان بە شایەت هەیە؟ ئەوەتا گوێتان لە کفرەکە بوو.
\v 66 ڕاتان چییە؟»
\p وەڵامیان دایەوە: «شایانی مردنە!»
\p 
\v 67 ئینجا تفیان لە ڕووی کرد و مستیان لێدا، هەندێکیش زللەیان لێدا و
\v 68 گوتیان: «ئەی مەسیح، ئەگەر پێغەمبەریت، بزانە کێ بوو لێیدایت؟»
\s1 پەترۆس نکۆڵی لە عیسا دەکات
\p 
\v 69 لەو کاتەدا پەترۆس لە دەرەوە، لە حەوشەکە دانیشتبوو. کارەکەرێک هاتە لای و گوتی: «تۆش لەگەڵ عیسای جەلیلی بوویت.»
\p 
\v 70 ئەویش لەبەردەم هەموویان نکۆڵیی کرد: «نازانم چی دەڵێیت.»
\p 
\v 71 ئینجا پەترۆس چووە دەرەوە بۆ ناو داڵانەکە، کارەکەرێکی دیکەش بینی و بەوانەی ئەوێی گوت: «ئەمە لەگەڵ عیسای ناسیرەیی بوو.»
\p 
\v 72 دیسان بە سوێندخواردنەوە نکۆڵی لێکرد: «ئەو پیاوە ناناسم!»
\p 
\v 73 دوای کەمێک ئەوانەی لەوێ ڕاوەستابوون هاتن و بە پەترۆسیان گوت: «بەڕاستی تۆش لەوانیت، شێوەزارەکەت ئاشکرات دەکات\f + \fr 26:73 \ft خەڵکی جەلیل شێوەزاریان جیا بوو لەگەڵ خەڵکی ئۆرشەلیم.‏\f*.»
\p 
\v 74 جا دەستی کرد بە نەفرەتکردن و سوێندخواردن و گوتی: «ئەو پیاوە ناناسم!»
\p دەستبەجێ کەڵەشێر خوێندی.
\v 75 ئەوسا پەترۆس قسەکانی عیسای بیرکەوتەوە کە فەرمووی: «پێش ئەوەی کەڵەشێر بخوێنێت، سێ جار نکۆڵیم لێ دەکەیت.» ئیتر چووە دەرەوە و بەکوڵ گریا.
\c 27
\s1 عیسا دەدرێتە دەست پیلاتۆس
\p 
\v 1 کاتێک ڕۆژبووەوە، هەموو کاهینانی باڵا و پیرانی گەل تەگبیریان کرد کە عیسا بکوژن.
\v 2 جا بەستیانەوە و بردیان و دایانە دەست پیلاتۆسی فەرمانڕەوا.
\s1 یەهوزا خۆی دەکوژێ
\p 
\v 3 ئینجا یەهوزا، ئەوەی بە گرتنی دا کە بینی عیسا حوکمی بەسەردا درا، پەشیمان بووەوە، سی دراوە زیوەکەی بۆ کاهینانی باڵا و پیران گەڕاندەوە و
\v 4 گوتی: «گوناهم کرد کە ناپاکیم لە مرۆڤێکی بێتاوان کرد.»
\p گوتیان: «بە ئێمە چی؟ خۆت دەزانیت.»
\p 
\v 5 ئەویش زیوەکانی لە پەرستگا فڕێدا و چوو خۆی هەڵواسی.
\p 
\v 6 بەڵام کاهینانی باڵا دراوە زیوەکانیان هەڵگرتەوە و گوتیان: «دروست نییە بیخەینە گەنجینەی پەرستگاوە، چونکە نرخی خوێنە.»
\v 7 ئینجا تەگبیریان کرد و کێڵگەی گۆزەکەرەکەیان بۆ گۆڕستانی بێگانان پێ کڕی.
\v 8 لەبەر ئەوە ئەو کێڵگەیە هەتا ئەمڕۆش پێی دەگوترێ کێڵگەی خوێن.
\v 9 ئەوسا ئەوەی بەهۆی پێغەمبەر یەرمیا گوتراوە، هاتە دی: ﴿سی پارچە زیوەکەیان برد، ئەم نرخە لەلایەن نەوەی ئیسرائیلەوە لەسەری خەمڵێنرا،
\v 10 ئینجا بە کێڵگەی گۆزەکەرەکەیان دا، وەک یەزدان فەرمانی پێدام.\f + \fr 27:10 \ft \xt زەکەریا 11‏:12‏-13 و یەرمیا 19‏:1‏-13؛ 32‏:6‏-9.‏\xt*\ft ‏\f*﴾
\s1 پیلاتۆس پرسیار لە عیسا دەکات
\p 
\v 11 عیساش لەبەردەم پیلاتۆسی فەرمانڕەوا ڕاوەستا، فەرمانڕەواش لێی پرسی و گوتی: «ئایا تۆ پاشای جولەکەی؟»
\p عیساش فەرمووی: «خۆت گوتت.»
\p 
\v 12 کاتێک کاهینانی باڵا و پیران سکاڵایان لێی دەکرد، هیچ وەڵامی نەدەدایەوە.
\v 13 پیلاتۆس پێی گوت: «ئایا گوێت لێ نییە چەند شایەتیت لەسەر دەدەن؟»
\v 14 بەڵام عیسا تەنانەت بە وشەیەکیش وەڵامی نەدایەوە، فەرمانڕەواش زۆر سەرسام بوو.
\s1 بڕیاری لەخاچدانی عیسا
\p 
\v 15 لە هەر جەژنێکدا فەرمانڕەوا کردبوویە نەریت بەگوێرەی خواستی خەڵکەکە بەندکراوێک ئازاد بکات.
\v 16 لەو کاتەدا گیراوێکی بەناوبانگیان هەبوو کە ناوی باراباس بوو.
\v 17 لەبەر ئەوە کاتێک کۆببوونەوە، پیلاتۆس لێی پرسین: «دەتانەوێت کێتان بۆ ئازاد بکەم، باراباس یان عیسا، ئەوەی پێی دەگوترێ مەسیح؟»
\v 18 چونکە زانی لەبەر ئیرەیی عیسایان بە گرتن دابوو.
\p 
\v 19 کاتێک پیلاتۆس لەسەر کورسی دادوەری دانیشتبوو، ژنەکەی هەواڵی بۆ نارد: «هیچ لەو بێتاوانە مەکە، چونکە ئەمڕۆ لە خەوندا لەبەر ئەو زۆر ئازارم چێژت.»
\p 
\v 20 بەڵام کاهینانی باڵا و پیران خەڵکەکەیان جۆشدا کە داوا بکەن باراباس ئازاد بکرێ و عیسا لەناو ببردرێت.
\p 
\v 21 فەرمانڕەوا وەڵامی دانەوە: «لەم دووانە کامەتان دەوێ بۆتان ئازاد بکەم؟»
\p گوتیان: «باراباس.»
\p 
\v 22 پیلاتۆس لێی پرسین: «ئەی چی لە عیسا بکەم، ئەوەی پێی دەگوترێ مەسیح؟»
\p هەموو گوتیان: «با لە خاچ بدرێت!»
\p 
\v 23 ئەویش گوتی: «بۆ؟ چ خراپەیەکی کردووە؟»
\p بەڵام ئەوان زیاتر هاواریان دەکرد: «با لە خاچ بدرێت!»
\p 
\v 24 پیلاتۆس بینی سوودی نییە و خەریکە ئاژاوە ڕوودەدات، ئاوی هێنا و لەبەردەم خەڵکەکە دەستی شوشت و گوتی: «لە خوێنی ئەمە بێتاوانم! لە ئەستۆی ئێوەیە!»
\p 
\v 25 گەل هەموو وەڵامیان دایەوە: «با خوێنی لە ئەستۆی ئێمە و منداڵمان بێت!»
\p 
\v 26 ئەوسا باراباسی بۆ ئازاد کردن، بەڵام فەرمانی دا کە عیسا بدرێتە بەر قامچی و پاشان لە خاچ بدرێت.
\s1 سەربازەکان گاڵتە بە عیسا دەکەن
\p 
\v 27 سەربازەکانی فەرمانڕەوا عیسایان بۆ کۆشکی فەرمانڕەوا برد و تەواوی سەربازەکان لە دەوری کۆبوونەوە.
\v 28 ڕووتیان کردەوە و کەوایەکی سووریان لەبەرکرد.
\v 29 هەروەها تاجێکیان لە دڕک دروستکرد و لە سەریان کرد، قامیشێکیان دایە دەستی ڕاستی، لەبەردەمی چۆکیان دادا و گاڵتەیان پێ دەکرد و دەیانگوت: «سڵاو ئەی پاشای جولەکە!»
\v 30 تفیان لێکرد، قامیشەکەیان برد و بە سەریاندا کێشا.
\v 31 دوای ئەوەی گاڵتەیان پێکرد، کەواکەیان لەبەر داکەند و کراسەکەی خۆیان لەبەرکردەوە، بردیان تاوەکو لە خاچی بدەن.
\s1 لەخاچدانی عیسا
\p 
\v 32 کاتێک دەهاتنە دەرەوە پیاوێکی کورێنییان\f + \fr 27:32 \ft کورێن: شارێکی یۆنانی بووە کە دەکەوێتە ناو وڵاتی لیبیای ئێستا.‏\f* بینی ناوی شیمۆن بوو، ناچاریان کرد خاچەکەی ئەو هەڵبگرێت.
\v 33 کە گەیشتنە ئەو شوێنەی پێی دەگوترا گولگۆسا، کە بە واتای «شوێنی کاسەسەر» دێت،
\v 34 شەرابی تێکەڵ بە تاڵاویان دایە عیسا تاکو بیخواتەوە، کە تامی کرد نەیویست بیخواتەوە.
\v 35 کە لە خاچیان دا، بە تیروپشک جلەکانیان دابەش کرد.
\v 36 ئینجا لەوێ دانیشتن و ئێشکیان بۆ گرت.
\v 37 لەژوور سەرییەوە تاواننامەکەی ئەویان دانا کە نووسرابوو:
\pc «ئەمە عیسایە، پاشای جولەکە.»
\p 
\v 38 دوو دزیشیان لەگەڵی لە خاچ دا، یەکێک لەلای ڕاستی و ئەوەی دیکەش لەلای چەپی.
\v 39 ئەوانەی بەوێدا تێدەپەڕین، جنێویان پێی دەدا و سەریان بادەدا و
\v 40 دەیانگوت: «ئەی ڕووخێنەری پەرستگا و بنیادنەرەوەی لە سێ ڕۆژدا، خۆت ڕزگار بکە! ئەگەر تۆ کوڕی خودای، لە خاچەکە دابەزە!»
\v 41 بە هەمان شێوە کاهینانی باڵا لەگەڵ مامۆستایانی تەورات و پیران گاڵتەیان پێدەکرد و دەیانگوت:
\v 42 «خەڵکی دیکەی ڕزگار کرد، بەڵام ناتوانێ خۆی ڕزگار بکات! ئەگەر پاشای ئیسرائیلە، با ئێستا لە خاچەکە دابەزێت، باوەڕی پێدەهێنین!
\v 43 پشتی بە خودا بەست، با ئێستا خودا ڕزگاری بکات، ئەگەر ئەمی دەوێت، چونکە گوتی: ”من کوڕی خودام.“»
\v 44 دزەکانیش کە لەگەڵی لە خاچ درابوون قسەیان پێ دەگوت.
\s1 مردنی عیسا
\p 
\v 45 لە کاتژمێر دوازدەوە\f + \fr 27:45 \ft یۆنانی: کاتژمێری شەشەم.‏\f* هەتا سێ\f + \fr 27:45 \ft یۆنانی: کاتژمێری نۆیەم.‏\f*، تاریکی باڵی بەسەر هەموو زەویدا کێشا.
\v 46 نزیکەی کاتژمێر سێ عیسا بە دەنگێکی بەرز هاواری کرد: «﴿\tl ئێلی، ئێلی، لەما شەبەقتانی؟\tl*﴾» کە بە واتای ﴿خودای من، خودای من، بۆ وازت لێ هێنام؟﴾\f + \fr 27:46 \ft \xt زەبوورەکان 22‏:1.‏\xt*\ft ‏\f* دێت.
\p 
\v 47 کاتێک هەندێک لەوانەی لەوێ ڕاوەستابوون گوێیان لێی بوو، گوتیان: «ئەوە بانگی ئەلیاس دەکات!»
\p 
\v 48 دەستبەجێ یەکێک لەوان ڕایکرد و ئیسفەنجێکی هەڵگرت، خستییە ناو سرکەوە و کردی بەسەر قامیشێکەوە و پێیدا تاکو بیخواتەوە،
\v 49 بەڵام ئەوانی دیکە گوتیان: «لێگەڕێ، با بزانین ئەلیاس دێت ڕزگاری بکات؟»
\p 
\v 50 عیساش بە دەنگێکی بەرز هاواری کردەوە و گیانی سپارد.
\p 
\v 51 لەو کاتەدا پەردەی پەرستگا لە سەرەوە هەتا خوارەوە شەق بوو و بوو بە دوو پارچەوە. زەوی لەرزی و بەرد درزیان برد و
\v 52 گۆڕەکان کرانەوە، زۆرێک لە لاشەی گەلی پیرۆزی خودا کە مردبوون هەستانەوە.
\v 53 دوای هەستانەوەی عیسا، لە گۆڕەکان هاتنە دەرەوە و چوونە ناو شاری پیرۆز، بۆ زۆر کەسیش دەرکەوتن.
\p 
\v 54 کاتێک سەرپەلەکە و ئەوانەی لەگەڵی پاسەوانیی عیسایان دەکرد، بوومەلەرزەکە و ئەو شتانەیان بینی کە ڕوویدا، زۆر ترسان و گوتیان: «بەڕاستی ئەمە کوڕی خودا بوو!»
\p 
\v 55 زۆر ژن لەوێ بوون، لە دوورەوە تەماشایان دەکرد، ئەوانەی لە جەلیلەوە دوای عیسا کەوتبوون و خزمەتیان دەکرد،
\v 56 مریەمی مەجدەلی و مریەمی دایکی یاقوب و یوسف، لەگەڵ دایکی کوڕەکانی زەبدی لەنێویان بوون.
\s1 ناشتنی عیسا
\p 
\v 57 کاتێک ئێوارە داهات، پیاوێکی دەوڵەمەندی خەڵکی ڕامە هات، ناوی یوسف بوو، ئەو خۆی قوتابی عیسا بوو.
\v 58 چوو بۆ لای پیلاتۆس و داوای تەرمەکەی عیسای لێکرد، ئینجا پیلاتۆس فەرمانی دا بیدرێتێ.
\v 59 یوسفیش تەرمەکەی برد و بە کەتانی پاک پێچای و
\v 60 لەو گۆڕە نوێیەی خۆی ناشتی کە لە تاشەبەرد هەڵکەنرابوو، ئینجا بەردێکی گەورەی گلۆر کردەوە سەر دەرگای گۆڕەکە و ڕۆیشت.
\v 61 مریەمی مەجدەلی و مریەمەکەی دیکەش لەوێ بوون، بەرامبەر گۆڕەکە دانیشتبوون.
\s1 ئێشکگرتنی گۆڕی عیسا
\p 
\v 62 بۆ بەیانی، کە دوای ڕۆژی خۆ ئامادەکردنە\f + \fr 27:62 \ft ڕۆژی خۆ ئامادەکردن: مەبەست لە ڕۆژی هەینییە کەوا لە کەلتوری جولەکەکاندا ئامادەکاری تێدا دەکرێت بۆ پێشوازی لە ڕۆژی شەممە، چونکە دروست نییە لە ڕۆژی شەممەدا هیچ کارێک بکرێت.‏\f*، کاهینانی باڵا و فەریسییەکان لەلای پیلاتۆس کۆبوونەوە،
\v 63 گوتیان: «گەورەم، هاتەوە بیرمان ئەو چەواشەکارە کاتێک زیندوو بوو گوتی: ”دوای سێ ڕۆژ هەڵدەستمەوە.“
\v 64 جا فەرمان بدە هەتا ڕۆژی سێیەم گۆڕەکەی پاس بکرێت، نەوەک قوتابییەکانی بێن و بیدزن، ئەوسا بە گەل بڵێن لەنێوان مردووان هەستاوەتەوە. جا چەواشەی دوایی لەوەی یەکەم خراپتر دەبێت.»
\p 
\v 65 پیلاتۆسیش گوتی: «پاسەوانتان هەیە، بڕۆن چۆنتان پێ باشە وا پاسی بکەن.»
\v 66 ئەوانیش چوون گۆڕەکەیان پاس کرد، مۆریان لە بەردەکە دا و پاسەوانیان دانا.
\c 28
\s1 زیندووبوونەوەی عیسا
\p 
\v 1 دوای شەممە لە بەرەبەیانی یەکەم ڕۆژی هەفتەدا، مریەمی مەجدەلی و مریەمەکەی دیکە هاتن تەماشای گۆڕەکە بکەن.
\p 
\v 2 لەناکاو بوومەلەرزەیەکی بەهێز ڕوویدا، چونکە فریشتەیەکی یەزدان لە ئاسمانەوە هاتە خوارەوە، چوو بەردەکەی گلۆر کردەوە و لەسەری دانیشت.
\v 3 ڕوخساری وەک بروسکە وابوو، جلەکانی وەک بەفر سپی بوون.
\v 4 پاسەوانەکان لە ترسی ئەو لەرزین و وەک مردوویان لێ هات.
\p 
\v 5 بەڵام فریشتەکە بە ژنەکانی گوت: «مەترسن، چونکە دەزانم بە شوێن عیسای لەخاچدراودا دەگەڕێن.
\v 6 ئەو لێرە نییە، هەروەک خۆی فەرمووی، هەستاوەتەوە. وەرن سەیری ئەو شوێنە بکەن کە لێی درێژکرابوو.
\v 7 خێرا بڕۆن و بە قوتابییەکانی بڵێن: ”ئەو لەنێو مردوواندا هەستاوەتەوە، پێش ئێوە دەچێتە جەلیل، لەوێ دەیبینن.“ ئەوەتا پێم گوتن.»
\p 
\v 8 دوو ژنەکە خێرا لەلای گۆڕەکە ڕۆیشتن، بە ترس و خۆشییەکی گەورەوە ڕایانکرد، بۆ ئەوەی هەواڵ بدەنە قوتابییەکانی.
\v 9 ئەوە بوو عیسا تووشیان هات و فەرمووی: «سڵاو!» ئەمانیش چوونە پێشەوە، پێی عیسایان گرت و کڕنۆشیان بۆ برد.
\v 10 عیسا پێی فەرموون: «مەترسن، بڕۆن بە براکانم بڵێن با بچنە جەلیل، لەوێ دەمبینن.»
\s1 قسەی پاسەوانەکان
\p 
\v 11 کە دەڕۆیشتن، هەندێک لە پاسەوانەکان هاتنە ناو شار و ئەوەی ڕوویدابوو بۆ کاهینانی باڵایان گێڕایەوە.
\v 12 ئەوانیش لەگەڵ پیران کۆبوونەوە و ڕاوێژیان کرد، زیوێکی زۆریان دایە سەربازەکان و
\v 13 گوتیان: «بڵێن، ”کاتێک ئێمە خەوتبووین، قوتابییەکانی لە شەودا هاتن و دزییان.“
\v 14 ئەگەر ئەمەش لەلای فەرمانڕەوا بیسترا، ئەوا ڕازی دەکەین و لە کێشە و گرفت دەتانپارێزین.»
\v 15 ئەوانیش زیوەکەیان وەرگرت و چۆن فێرکران، وایانکرد، ئیتر ئەم قسەیە هەتا ئەمڕۆش لەناو جولەکەدا بڵاو بووەتەوە.
\s1 دەرکەوتنی عیسا بۆ قوتابییەکان
\p 
\v 16 ئیتر یازدە قوتابییەکە چوونە جەلیل، بۆ ئەو کێوەی عیسا فەرمانی پێدابوون.
\v 17 کاتێک ئەویان بینی کڕنۆشیان بۆ برد، بەڵام هەندێکیان گومانیان کرد.
\v 18 عیسا لێیان نزیک بووەوە و پێی فەرموون: «هەموو دەسەڵاتێکم لە ئاسمان و لەسەر زەوی دراوەتێ.
\v 19 کەواتە بڕۆن، هەموو نەتەوەکان بکەنە قوتابی، بە ناوی باوک و کوڕ و ڕۆحی پیرۆز لە ئاویان هەڵبکێشن،
\v 20 فێریان بکەن با کار بکەن بە هەموو ئەو شتانەی کە ڕامسپاردوون. دڵنیابن من هەموو ڕۆژێک لەگەڵتانم، هەتا کۆتایی زەمان.»
