\id JOL - Biblica® Open Ewe Contemporary Scriptures 2020 
\h Yoel 
\toc1 Yoel ƒe agbalẽ 
\toc2 Yoel 
\toc3 Yol 
\mt1 Yoel 
\mt2 ƒe agbalẽ 
\c 1  
\p  
\v 1 Esiae nye gbedeasi si va na Yoel, Petuel ƒe vi, tso Yehowa gbɔ. 
\b  
\s1 Ʋetsuviwo ƒe vava 
\q1  
\v 2 Miɖo to afii, mi Israel ƒe ame tsitsiwo! 
\q2 Mi anyigbadzitɔwo, mise nya sia ɖa. 
\q1 Le miaƒe agbemeŋkekewo katã me ɖe, 
\q2 miese nya sia tɔgbi kpɔa? 
\q1  
\v 3 Mitsɔe xlɔ̃ nu mia viwoe 
\q2 eye woawo hã nagblɔe na wo viwo 
\q2 ne wòazu xotunya tso dzidzime yi dzidzime. 
\q1  
\v 4 Nu siwo ʋetsuviwo ƒe ha gã agblẽ ɖi la, 
\q2 ʋetsuviwo aɖui, 
\q1 nu siwo ʋetsuviwo agblẽ ɖi la, 
\q2 ʋetrawo aɖui, eye nu siwo ʋetrawo agblẽ ɖi la, 
\q2 abɔwo aɖui. 
\b  
\q1  
\v 5 Minyɔ, mi ahanomunɔwo, 
\q2 ne miafa avi hehehe, 
\q1 mi waintsunolawo, 
\q2 mifa avi, elabena woɖe wain le miaƒe nu me, 
\q1 eye miagakpɔ wain yeye ano o! 
\q1  
\v 6 Dukɔ gã aɖe va xɔ anyigba la katã dzi. 
\q2 Ŋɔdzi le wo ŋu ŋutɔ 
\q2 eye ame aɖeke mate ŋu axlẽ wo o, 
\q1 evɔ woƒe aɖuwo hã le ɖaɖam abe dzatatsu ƒe aɖuwo 
\q2 kple dzatanɔ ƒe tsyowo ene! 
\q1  
\v 7 Wogblẽ nye waingble dome. 
\q2 Wogblẽ nye gbotiwo, 
\q1 wokuko tsro le atilɔwo ŋuti ƒiaƒiaƒia eye wofu ɣie. 
\b  
\q1  
\v 8 Mifa konyi abe ale si ɖetugbi si 
\q2 ƒe ŋugbetɔsrɔ̃ ku la wɔnɛ ene. 
\q1  
\v 9 Nuɖuvɔsa kple nunovɔsa le Yehowa ƒe gbedoxɔ me nu tso; 
\q2 ale dɔwuame to na nunɔlaawo 
\q1 kple ame siwo subɔna le Yehowa ƒe aƒe me 
\q2 eye wole konyi fam. 
\q1  
\v 10 Agblewo ɖi gbɔlo, anyigba ƒu kplakplakpla, 
\q2 bliwo dome gblẽ, 
\q2 wain yeye megali o, eye ami hã nu tso. 
\b  
\q1  
\v 11 Azɔ mi agbledelawo, 
\q2 dzika netso mia ƒo, eye mialulũ, 
\q1 mi waingbledelawo, 
\q2 mifa avi sesĩe. 
\q1 Mifa avi ɖe lu kple ƒo hã ta 
\q2 elabena nuŋeŋe nu tso le agble me. 
\q1  
\v 12 Wainkawo ku, gboti yrɔ, 
\q2 yevuboɖatiwo ƒu, 
\q1 detiwo kple atɔtɔŋutiwo 
\q2 kple agblemetiwo katã kura hã ku. 
\q1 Amegbetɔ ƒe dzidzɔ ɖe sia ɖe nu tso. 
\s1 Yɔyɔ hena dzimetɔtrɔ 
\q1  
\v 13 O mi nunɔlawo, mita akpanya eye mixa nu. 
\q2 Mifa avi, mi ame siwo subɔna le vɔsamlekpui la ŋgɔ, 
\q1 mitsi ŋu dɔ miafa avi zã blibo la katã, 
\q2 mi ame siwo subɔna le nye Mawu ŋkume. 
\q1 Elabena womagatsɔ nuɖuvɔsa 
\q2 kple nunovɔsa va miaƒe Mawu la ƒe aƒe me o. 
\q1  
\v 14 Miɖo nutsitsidɔ kɔkɔe 
\q2 eye miyɔ takpekpe tɔxɛ. 
\q1 Miyɔ ame tsitsiwo 
\q2 kple anyigbadzinɔlawo katã yi ɖe Yehowa, miaƒe Mawu la 
\q2 ƒe gbedoxɔ me eye miafa avi le afi ma na Yehowa. 
\b  
\q1  
\v 15 O ŋkeke ma! 
\q2 Elabena Yehowa ƒe ŋkeke la tu aƒe. 
\q1 Ava abe gbegblẽ ene tso Ŋusẽkatãtɔ la gbɔ. 
\b  
\q1  
\v 16 Ɖe nuɖuɖuwo mevɔ le mia ŋkume eye dzidzɔ 
\q2 kple aseyetsotso le miaƒe Mawu la 
\q2 ƒe gbedoxɔ me mawu enu oa? 
\q1  
\v 17 Nukuwo ƒaƒã ɖe woƒe gowo me, 
\q2 blivawo kple texɔwo tsi ƒuƒlu 
\q1 eye bli matsimatsiwo ku, heƒu ɖe bo dzi. 
\q1  
\v 18 Nyiwo le ŋeŋem, 
\q2 nyihawo le nu kpɔm nublanuitɔe, 
\q1 elabena nuɖuɖu meli na wo o, 
\q2 eye alẽhawo le fu kpem. 
\b  
\q1  
\v 19 Yehowa, xɔ na mí! 
\q2 Elabena dzo bi gbe damawo, 
\q1 eye dzo ƒe aɖe fia atiwo katã le gbedzi. 
\q1  
\v 20 Gbemelãwo gɔ̃ hã le ɣli dom be nàxɔ na yewo, 
\q2 elabena tsi mie le tɔʋuwo me, 
\q2 dzo bi gbe siwo le lãnyiƒewo keŋ. 
\c 2  
\s1 Ʋetsuviwo ƒe ha gã aɖe 
\q1  
\v 1 Miku kpẽ le Zion! 
\q2 Miku aʋadzedze ƒe kpẽ la be 
\q2 woasee le nye to kɔkɔe la dzi! 
\b  
\q1 Anyigbadzitɔwo katã nedzo nyanyanya kple vɔvɔ̃, 
\q2 elabena Yehowa ƒe ŋkeke la tu aƒe vɔ. 
\q1  
\v 2 Anye viviti kple blukɔ ƒe ŋkeke, 
\q2 eye lilikpo kple viviti tsiɖitsiɖi ado. 
\q1 Abe ale si ŋdikekeli klẽna ɖe towo tame ene la, 
\q2 nenema ke aʋakɔ gã sẽŋu aɖe avae. 
\q1 Ame siawo la, womekpɔ wo tɔgbi kpɔ o, 
\q2 eye womagakpɔ wo tɔgbi kpɔ 
\q2 le xexea me ƒe dzidzimewo dome o! 
\b  
\q1  
\v 3 Dzo bibi le nu fiam le wo ŋgɔ 
\q2 eye dzo ƒe aɖewo le wo megbe. 
\q1 Anyigba la le ŋgɔ abe Edenbɔ ene 
\q2 gake ezua gbegbe le wo megbe. 
\q2 Naneke mate ŋu asi le enu o. 
\q1  
\v 4 Wodzena abe sɔwo ene 
\q2 eye woƒua du abe sɔdolawo ene. 
\q1  
\v 5 Wole kpo tim le towo tame, 
\q2 woƒe afɔziwo le ɖiɖim abe tasiaɖamwo tɔ ene 
\q2 eye abe dzoe le gbe ƒuƒu bim ene. 
\q1 Wole du ƒum abe asrafo kalẽtɔwoe 
\q2 le du dzi yina ɖe aʋa ene. 
\b  
\q1  
\v 6 Dukɔwo kpɔe hedzo nyanyanya 
\q2 eye woƒe mowo fu tititi le vɔvɔ̃ ta. 
\q1  
\v 7 Wozɔ yi ŋgɔ kple kalẽ abe aʋawɔlawo ene 
\q2 eye woflɔ gliawo abe asrafowo ene. 
\q1 Wo katã yi ŋgɔgbe eye ɖeke meto miame alo ɖusime o. 
\q1  
\v 8 Ɖeke mebe ɖe nɔvia xa o. 
\q2 Ame sia ame le enɔƒe pɛpɛpɛ 
\q1 Aʋawɔnu aɖeke mate ŋu 
\q2 anɔ te ɖe wo ŋu o. 
\q1  
\v 9 Wo katã lũ ɖe du la dzi; 
\q2 woflɔ gli la zɔ etame hege ɖe aƒewo 
\q1 kple xɔwo me abe ale si fiafitɔ toa fesre nue ene. 
\b  
\q1  
\v 10 Anyigba ʋuʋu kpekpekpe 
\q2 eye dziƒo dzo nyanyanya le wo ŋgɔ. 
\q1 Ɣe kple ɣleti do viviti eye ɣletiviwo megaklẽ o. 
\q1  
\v 11 Yehowa ŋutɔ le eƒe aʋakɔ la ŋgɔ le gbe ɖem. 
\q2 Esiae nye eƒe aʋakɔ gã la eye ame siwo 
\q2 le eƒe gbeɖeɖe dzi wɔm la nye ame sesẽwo. 
\q1 Yehowa ƒe ŋkeke la anye ŋkeke gã, 
\q2 ŋɔdzi kple vɔvɔ̃ anɔ eŋu. 
\q2 Ame kae ate ŋu anɔ te ɖe enu? 
\s1 Mitrɔ dzi me 
\q1  
\v 12 “Eya ta Yehowa be, 
\q2 ‘Mitrɔ ɖe ŋunye azɔ, 
\q2 kple miaƒe dzi blibo. 
\q1 Miva kple nutsitsidɔ, 
\q2 avifafa kple konyifafa.’ ” 
\b  
\q1  
\v 13 Midze miaƒe dziwo, 
\q2 menye miaƒe awuwo o. 
\q1 Mitrɔ ɖe Yehowa, miaƒe Mawu la 
\q2 ŋu, elabena amenuveve 
\q2 kple nublanuikpɔkpɔ bɔ ɖe esi. 
\q1 Medoa dziku kabakaba o, 
\q2 eƒe dɔ me nyo, eye metsia dzi be yeahe to na ame o. 
\q1  
\v 14 Ame kae nya be ɖewohĩ atrɔ ave mía nu 
\q2 eye wòagblẽ yayra ɖi na mí? 
\q1 Ekema míagatsɔ nuɖuvɔsa 
\q2 kple nunovɔsa vɛ na Yehowa, mia Mawu la. 
\b  
\q1  
\v 15 Miku kpẽ le Zion! 
\q2 Miɖo nutsitsidɔ kɔkɔe eye miyɔ takpekpe tɔxɛ. 
\q1  
\v 16 Miƒo ameawo nu ƒu; 
\q2 mikɔ ameha la ŋuti, ame tsitsiwo, 
\q2 ɖeviwo kple vi nonowo siaa. 
\q1 Ŋugbetɔsrɔ̃ nedo tso eƒe xɔ me 
\q2 eye ŋugbetɔ nedo go tso xɔ gã me. 
\q1  
\v 17 Nunɔla siwo subɔna le Yehowa ŋkume la 
\q2 netsi tsitre ɖe ameawo kple vɔsamlekpui la dome, 
\q1 afa avi ado gbe ɖa be, “Yehowa, kpɔ nublanui na wò dukɔ; 
\q2 mègana wò domenyinu nazu fewuɖunu 
\q2 kple ŋukpenanu le dukɔwo dome o. 
\q1 Nu ka ta dukɔwo anɔ gbɔgblɔm be, 
\q2 ‘Afi ka woƒe Mawu la le?’ ” 
\s1 Yehowa ƒe ŋuɖoɖo 
\q1  
\v 18 Ekema Yehowa aʋã ŋu ɖe dukɔ la nu, 
\q2 eye wòakpɔ nublanui na eƒe amewo. 
\p  
\v 19 Yehowa aɖo eŋu be, 
\q1 “Kpɔ ɖa, mele bli, 
\q2 wain yeye kple ami ɖom ɖe mi be miaɖi ƒo. 
\q2 Nyemagawɔ mi mianye fewuɖunu na dukɔwo azɔ o. 
\b  
\q1  
\v 20 “Maɖe asrafo siwo tso dzigbeme la ɖa le mia gbɔ, 
\q2 matrɔ wo aɖo ɖe kuɖiɖinyigba kple gbegbe. 
\q1 Matsɔ ŋgɔgbenɔlawo ade ɣedzeƒeƒu la me 
\q2 eye matsɔ megbenɔlawo ade ɣetoɖoƒeƒu la me. 
\q2 Ale woƒe ʋeʋẽ kũu la axɔ anyigba la dzi.” 
\b  
\q1 Vavã, Yehowa wɔ nukunu triakɔ aɖe. 
\q2  
\v 21 Nye dukɔ, mègavɔ̃ o; 
\q2 kpɔ dzidzɔ eye nàtso aseye azɔ 
\q1 elabena Yehowa wɔ nukunu gãwo na wò. 
\q1  
\v 22 Mi gbemelãwo katã, migavɔ̃ o, 
\q2 elabena lãnyiƒewo agada ama abe tsã ene. 
\q1 Atiwo agatse ku eye gbotiwo kple wainkawo 
\q2 agatse kplanyaa abe tsã ene. 
\q1  
\v 23 O, mi Ziontɔwo, dzi nedzɔ mi le Yehowa, 
\q2 miaƒe Mawu la me! 
\q1 Elabena tsidzadza si wòɖo ɖa la nye 
\q2 eƒe tsɔtsɔke ƒe dzesi. 
\q1 Adame kple kelemetsiwo adza ɖe ɖoɖo nu pɛpɛpɛ. 
\q1  
\v 24 Lu ayɔ lugbɔƒe fũu, eye wain 
\q2 kple ami asɔ gbɔ ɖe nudzraɖoƒewo. 
\b  
\q1  
\v 25 “Magaɖo ƒe siwo ʋetsuviwo, ʋetrawo, 
\q2 abɔwo kple ŋɔwo ɖu nu la teƒe na mi. 
\q1 Woawoe nye nye aʋakɔ gã si medɔ ɖe mia ŋu. 
\q1  
\v 26 Miaɖu nu aɖi ƒo abe tsã ene 
\q2 eye miakafu Yehowa, miaƒe Mawu la. 
\q1 Miakafu Yehowa, miaƒe Mawu la ƒe ŋkɔ, 
\q2 ame si wɔ nukunu siawo katã na mi. 
\q1 Ŋu magakpe nye dukɔ azɔ o. 
\q1  
\v 27 Mianyae be mele afii le nye dukɔ Israel dome, 
\q2 eye mianyae hã be nye Yehowa, 
\q2 ɖeka hɔ̃ɔ koe nye miaƒe Mawu. 
\q1 Ŋu magakpe nye dukɔ la azɔ o. 
\s1 Yehowa ƒe ŋkeke 
\q1  
\v 28 “Le nu siawo megbe la, 
\q2 matrɔ nye Gbɔgbɔ akɔ ɖe amewo katã dzi! 
\q1 Mia viŋutsuwo kple nyɔnuwo agblɔ nya ɖi, 
\q2 miaƒe ame tsitsiwo aku drɔ̃ewo 
\q2 eye miaƒe ɖekakpuiwo akpɔ ŋutegawo. 
\q1  
\v 29 Matrɔ nye Gbɔgbɔ la akɔ ɖe nye subɔlawo katã dzi, 
\q2 ŋutsuwo kple nyɔnuwo siaa dzi le ŋkeke mawo me 
\q1  
\v 30 eye mana dzesi wɔnukuwo nado ɖe dziƒo 
\q2 kple anyigba dzi, siwo anye ʋu, 
\q2 dzo kple dzudzɔ babla kɔtɔɔ. 
\q1  
\v 31 Ɣe ado viviti eye ɣleti atrɔ zu ʋu hafi Aƒetɔ la ƒe ŋkeke gã, 
\q2 dziŋɔ la nava ɖo. 
\q1  
\v 32 Ame sia ame si yɔa Aƒetɔ la ƒe ŋkɔa la, 
\q2 akpɔ ɖeɖe eye xɔname anɔ Zion towo dzi 
\q1 kple Yerusalem kple ame siwo Aƒetɔ yɔ la dome 
\q2 abe ale si Aƒetɔ la do ŋugbee la ene. 
\c 3  
\s1 Ʋɔnudɔdrɔ̃ dukɔawo 
\q1  
\v 1 “Le ŋkeke mawo kple ɣe ma ɣi me ne megaɖo Yuda 
\q2 kple Yerusalem te la, 
\q1  
\v 2 maƒo dukɔwo nu ƒu ɖe Yehosafat ƒe Balime 
\q2 eye madrɔ̃ ʋɔnu wo le afi ma 
\q1 le nye amewo kple nye domenyinu Israel ta, 
\q2 elabena wokaka nye domenyinu la ɖe dukɔwo dome 
\q2 eye woma nye anyigba. 
\b  
\q1  
\v 3 “Wodzidze nu ɖe nye dukɔ dzi 
\q2 eye woma nye amewo. 
\q1 Wotsɔ ŋutsuviwo ɖɔli gbolowoe 
\q2 eye wotsɔ nyɔnuviwo na ɖe wain si woano amu ta. 
\p  
\v 4 “Tiro kple Sidon kple Filistitɔwo ƒe duwo katã, ɖe miele didim be miabia hlɔ̃ mahã? Mikpɔ nyuie elabena nye asi atre tsɔtsɔ na mi eye nu si mieɖo la atrɔ adze miawo ŋutɔ ƒe ta dzi. 
\p  
\v 5 “Mieva lɔ nye klosalo kple sika kple nye kesinɔnu veviwo tsɔ yi ɖe miaƒe trɔ̃wo ƒe xɔwo mee.  
\v 6 Miedzra Yudatɔwo kple Yerusalemtɔwo na Trɔ̃subɔlawo eye wokplɔ wo dzoe le woawo ŋutɔ ƒe anyigba dzi yi didiƒe ke.  
\v 7 Gake magakplɔ wo agbɔe tso teƒe siwo katã wokplɔ wo yii eye maɖo nu vɔ̃ siwo katã miewɔ la teƒe na mi.  
\v 8 Matsɔ mia viŋutsuwo kple nyɔnuwo adzra na Yudatɔwo eye woawo hã adzra wo na Sabeatɔwo le didiƒe ke. Yehowae gblɔe. 
\q1  
\v 9 “Miɖe gbeƒã nu sia le dukɔwo dome be, 
\q2 ‘Midzra ɖo na aʋawɔwɔ!’ 
\q1 Mitia miaƒe asrafo kalẽtɔwo, 
\q2 miƒo miaƒe aʋawɔlawo katã nu ƒu na aʋawɔwɔ. 
\q1  
\v 10 Mitsɔ miaƒe agblenuwo tu aʋawɔyiwoe 
\q2 eye mitsɔ miaƒe hɛ gobɛwo tu akplɔwoe. 
\q1 Ame gblɔewo negblɔ be, 
\q2 ‘Miawoe nye ŋusẽtɔwo.’ 
\q1  
\v 11 Mi dukɔ siwo kaka ɖe afi sia afi, 
\q2 miƒo mia ɖokuiwo nu ƒu ne miava. 
\b  
\q1 “O Yehowa, dɔ wò aʋakɔwo be woaɖiɖi ava anyi! 
\b  
\q1  
\v 12 “Miƒo dukɔwo nu ƒu; 
\q2 mikplɔ wo va Yehosafat ƒe Balimee, 
\q1 afi ma manɔ adrɔ̃ ʋɔnu wo katã. 
\q1  
\v 13 Azɔ nukuxahɛ newɔ eƒe dɔ 
\q2 elabena nukuawo tsi vɔ 
\q2 hele lalam na nuŋeɣi. 
\q1 Miva, mifanya waintsetseawo, 
\q2 elabena wainfiaƒe la yɔ, 
\q1 eye waindzraɖoƒe la yɔ gbagba, 
\q2 elabena woƒe nu tovowo wɔwɔ sɔ gbɔ.” 
\b  
\q1  
\v 14 Ame akpe akpewo le Nyametsotso ƒe Balime 
\q2 elabena Yehowa ƒe Ŋkeke la tu aƒe le Nyametsotso Balime la. 
\q1  
\v 15 Ɣe kple ɣleti ado viviti eye ɣletiviwo magaklẽ o. 
\q2  
\v 16 Yehowa aɖe gbe tso Zion 
\q2 eye eƒe gbe aɖi tso Yerusalem 
\q2 eye dziƒo kple anyigba ade asi ʋuʋu me. 
\q1 Ke Yehowa anye sitsoƒe na eƒe amewo 
\q2 kple mɔ sesẽ na eƒe dukɔ Israel. 
\s1 Yayra na Mawu ƒe amewo 
\q1  
\v 17 “Mlɔeba la, miava nya be 
\q2 nyee nye Yehowa, miaƒe Mawu, 
\q2 si le Zion, nye To Kɔkɔe la dzi. 
\q1 Yerusalem azu kɔkɔeƒe; 
\q2 ɣeyiɣi li gbɔna esi dutasrafowo 
\q2 magakpɔ mɔ aho aʋa ɖe eŋu o. 
\b  
\q1  
\v 18 “Le ɣe ma ɣi me la, wain yeye anɔ tsyɔtsyɔm tso towo ŋuti 
\q2 eye nyinotsi anɔ sisim bababa tso togbɛwo tame. 
\q1 Tsi ayɔ Yɔdan tɔʋuwo me banaa, 
\q2 eye tsi asi tso Yehowa ƒe gbedoxɔ la me ade tsi Sitim ƒe Balime. 
\q1  
\v 19 Egipte azu aƒedo eye Edom azu gbegbe 
\q2 elabena wowɔ vɔ̃ ɖe Yudatɔwo ŋuti, 
\q1 eye wokɔ ʋu maɖifɔwo ɖi le du mawo me. 
\q1  
\v 20 Ke Yuda anɔ anyi tegbetegbe, 
\q2 eye Yerusalem anɔ anyi tso dzidzime yi dzidzime. 
\q1  
\v 21 Mahe to na Egiptetɔwo kple Edomtɔwo 
\q2 ɖe woƒe ʋu maɖifɔ kɔkɔɖi ta.” 
\b  
\qc Yehowa le Zion.