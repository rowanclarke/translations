\v 1 \w La|strong="H3068"\w* \w parole|strong="H1697"\w* \w du|strong="H3117"\w* \w SEIGNEUR|strong="H4428"\w*\f + \fr 1.1 \ft Lorsqu'il est écrit en LETTRES MAJUSCULES, « SEIGNEUR » ou « DIEU » est la traduction du nom propre de Dieu (en hébreu « \+wh יהוה\+wh* », généralement prononcé Yahweh).\f* \w qui|strong="H3068"\w* \w fut|strong="H3068"\w* \w adressée|strong="H1697"\w* \w à|strong="H3068"\w* \w Osée|strong="H1954"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* Beéri, \w aux|strong="H3068"\w* \w jours|strong="H3117"\w* d'\w Ozias|strong="H5818"\w*, \w de|strong="H1121"\w* \w Jotham|strong="H3147"\w*, d'\w Achaz|strong="H4428"\w* \w et|strong="H1121"\w* d'\w Ézéchias|strong="H2396"\w*, \w rois|strong="H4428"\w* \w de|strong="H1121"\w* \w Juda|strong="H3063"\w*, \w et|strong="H1121"\w* \w aux|strong="H3068"\w* \w jours|strong="H3117"\w* \w de|strong="H1121"\w* \w Jéroboam|strong="H3379"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Joas|strong="H3101"\w*, \w roi|strong="H4428"\w* d'\w Israël|strong="H3478"\w*.   
\p
\v 2 \w Lorsque|strong="H3588"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H1696"\w* commença \w à|strong="H3068"\w* \w parler|strong="H1696"\w* \w par|strong="H3068"\w* \w Osée|strong="H1954"\w*, \w le|strong="H3068"\w* \w SEIGNEUR|strong="H1696"\w* \w dit|strong="H1696"\w* \w à|strong="H3068"\w* \w Osée|strong="H1954"\w* : « \w Va|strong="H3212"\w*, prends-toi \w une|strong="H3068"\w* \w femme|strong="H3947"\w* \w de|strong="H1696"\w* \w prostitution|strong="H2181"\w* \w et|strong="H3068"\w* \w des|strong="H3068"\w* \w enfants|strong="H3206"\w* d'\w infidélité|strong="H2181"\w* ; \w car|strong="H3588"\w* \w le|strong="H3068"\w* \w pays|strong="H3068"\w* \w se|strong="H3068"\w* \w livre|strong="H3588"\w* \w à|strong="H3068"\w* \w un|strong="H3068"\w* \w grand|strong="H3947"\w* \w adultère|strong="H2181"\w* \w en|strong="H3068"\w* abandonnant \w le|strong="H3068"\w* \w SEIGNEUR|strong="H1696"\w*. »   
\p
\v 3 \w Il|strong="H1121"\w* \w alla|strong="H3212"\w* \w donc|strong="H3212"\w* \w prendre|strong="H3947"\w* \w Gomer|strong="H1586"\w*, \w fille|strong="H1323"\w* \w de|strong="H1121"\w* \w Diblaïm|strong="H1691"\w* ; \w elle|strong="H1121"\w* \w conçut|strong="H2029"\w* \w et|strong="H1121"\w* \w lui|strong="H3205"\w* \w enfanta|strong="H3205"\w* \w un|strong="H1121"\w* \w fils|strong="H1121"\w*.   
\p
\v 4 \w Le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* \w lui|strong="H3068"\w* \w dit|strong="H3068"\w* : « Appelle-le \w Jizreel|strong="H3157"\w*, \w car|strong="H3588"\w* d'\w ici|strong="H3068"\w* \w peu|strong="H4592"\w* \w de|strong="H1004"\w* \w temps|strong="H4592"\w*, \w je|strong="H3588"\w* vengerai \w le|strong="H3068"\w* \w sang|strong="H1818"\w* \w de|strong="H1004"\w* \w Jizreel|strong="H3157"\w* \w sur|strong="H5921"\w* \w la|strong="H3068"\w* \w maison|strong="H1004"\w* \w de|strong="H1004"\w* \w Jéhu|strong="H3058"\w*, \w et|strong="H3068"\w* \w je|strong="H3588"\w* \w mettrai|strong="H3588"\w* \w fin|strong="H7673"\w* \w au|strong="H3068"\w* \w royaume|strong="H4468"\w* \w de|strong="H1004"\w* \w la|strong="H3068"\w* \w maison|strong="H1004"\w* d'\w Israël|strong="H3478"\w*.  
\v 5 \w Il|strong="H3117"\w* \w arrivera|strong="H3117"\w*, \w en|strong="H3117"\w* \w ce|strong="H1931"\w* \w jour-là|strong="H1931"\w*, \w que|strong="H3117"\w* \w je|strong="H3117"\w* \w briserai|strong="H7665"\w* l'\w arc|strong="H7198"\w* d'\w Israël|strong="H3478"\w* \w dans|strong="H3117"\w* \w la|strong="H3117"\w* \w vallée|strong="H6010"\w* \w de|strong="H3117"\w* \w Jizreel|strong="H3157"\w*. »   
\p
\v 6 \w Elle|strong="H3588"\w* \w conçut|strong="H2029"\w* \w de|strong="H1004"\w* \w nouveau|strong="H3254"\w* \w et|strong="H3478"\w* \w enfanta|strong="H3205"\w* \w une|strong="H5375"\w* \w fille|strong="H1323"\w*.  
\p \w Puis|strong="H3808"\w* \w il|strong="H3478"\w* \w lui|strong="H1004"\w* \w dit|strong="H3478"\w* : « Appelle-la Lo-Ruchama,\f + \fr 1.6 \ft Lo-Ruchama signifie « celle qui n'a pas obtenu miséricorde » ou « sans compassion ».\f* \w car|strong="H3588"\w* \w je|strong="H3588"\w* \w ne|strong="H3808"\w* \w ferai|strong="H3588"\w* \w plus|strong="H5750"\w* \w miséricorde|strong="H7355"\w* \w à|strong="H3478"\w* \w la|strong="H5375"\w* \w maison|strong="H1004"\w* d'\w Israël|strong="H3478"\w*, \w au|strong="H1004"\w* \w point|strong="H3808"\w* \w de|strong="H1004"\w* \w leur|strong="H5375"\w* pardonner.  
\v 7 Mais \w je|strong="H3068"\w* \w ferai|strong="H3068"\w* \w miséricorde|strong="H7355"\w* \w à|strong="H3068"\w* \w la|strong="H3068"\w* \w maison|strong="H1004"\w* \w de|strong="H1004"\w* \w Juda|strong="H3063"\w*, \w et|strong="H3068"\w* \w je|strong="H3068"\w* \w les|strong="H3068"\w* \w sauverai|strong="H3467"\w* \w par|strong="H3068"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* \w leur|strong="H3068"\w* \w Dieu|strong="H3068"\w*,\f + \fr 1.7 \ft Le mot hébreu traduit par « Dieu » est « \+wh אֱלֹהִ֑ים\+wh* » (Élohim).\f* \w et|strong="H3068"\w* \w je|strong="H3068"\w* \w ne|strong="H3808"\w* \w les|strong="H3068"\w* \w sauverai|strong="H3467"\w* \w ni|strong="H3808"\w* \w par|strong="H3068"\w* l'\w arc|strong="H7198"\w*, \w ni|strong="H3808"\w* \w par|strong="H3068"\w* l'\w épée|strong="H2719"\w*, \w ni|strong="H3808"\w* \w par|strong="H3068"\w* \w la|strong="H3068"\w* \w guerre|strong="H4421"\w*, \w ni|strong="H3808"\w* \w par|strong="H3068"\w* \w les|strong="H3068"\w* \w chevaux|strong="H5483"\w*, \w ni|strong="H3808"\w* \w par|strong="H3068"\w* \w les|strong="H3068"\w* \w cavaliers|strong="H6571"\w*. »   
\p
\v 8 \w Après|strong="H3205"\w* avoir \w sevré|strong="H1580"\w* Lo-Ruchama, \w elle|strong="H1121"\w* \w conçut|strong="H2029"\w* \w et|strong="H1121"\w* \w enfanta|strong="H3205"\w* \w un|strong="H1121"\w* \w fils|strong="H1121"\w*.   
\p
\v 9 \w Il|strong="H5971"\w* \w dit|strong="H5971"\w* : « Appelle-le Lo-Ammi,\f + \fr 1.9 \ft Lo-Ammi signifie « pas mon peuple ».\f* \w car|strong="H3588"\w* \w vous|strong="H3808"\w* n'\w êtes|strong="H5971"\w* \w pas|strong="H3808"\w* \w mon|strong="H7121"\w* \w peuple|strong="H5971"\w*, \w et|strong="H5971"\w* \w je|strong="H3588"\w* \w ne|strong="H3808"\w* \w serai|strong="H1961"\w* \w pas|strong="H3808"\w* \w à|strong="H7121"\w* \w vous|strong="H3808"\w*.  
\v 10 Cependant, le nombre des enfants d'Israël sera comme le sable de la mer, qui ne peut être ni mesuré ni compté ; et il arrivera qu'au lieu où on leur disait : “Vous n'êtes pas mon peuple”, on les appellera “fils du Dieu vivant”.  
\v 11 Les enfants de Juda et les enfants d'Israël seront rassemblés, ils s'établiront un seul chef, et ils monteront du pays ; car grand sera le jour de Jizreel.   
\c 2
\p
\v 1 « \w Dites|strong="H3808"\w* \w à|strong="H3478"\w* \w vos|strong="H5971"\w* \w frères|strong="H1121"\w* : “\w Mon|strong="H1961"\w* \w peuple|strong="H5971"\w* !”\f + \fr 2.1 \ft « Ammi » en hébreu\f*  
\q2 \w et|strong="H1121"\w* \w à|strong="H3478"\w* \w vos|strong="H5971"\w* \w sœurs|strong="H1121"\w* : “Objet \w de|strong="H1121"\w* compassion !”\f + \fr 2.1 \ft « Ruchama » en hébreu ; c'est-à-dire « celle qui a obtenu miséricorde ».\f*   
\q1
\v 2 Plaidez \w contre|strong="H5927"\w* \w votre|strong="H3588"\w* \w mère|strong="H3117"\w* !  
\q2 Plaidez, \w car|strong="H3588"\w* \w elle|strong="H3588"\w* n'\w est|strong="H3117"\w* \w pas|strong="H5927"\w* \w ma|strong="H3117"\w* \w femme|strong="H3117"\w*,  
\q2 \w et|strong="H1121"\w* \w je|strong="H3588"\w* \w ne|strong="H3478"\w* \w suis|strong="H3588"\w* \w pas|strong="H5927"\w* \w son|strong="H3117"\w* \w mari|strong="H3117"\w* ;  
\q1 \w qu|strong="H3588"\w*'\w elle|strong="H3588"\w* ôte \w de|strong="H1121"\w* \w son|strong="H3117"\w* visage \w ses|strong="H3117"\w* prostitutions,  
\q2 \w et|strong="H1121"\w* \w ses|strong="H3117"\w* adultères d'\w entre|strong="H7760"\w* \w ses|strong="H3117"\w* seins ;   
\q1
\v 3 \w de|strong="H5971"\w* peur \w que|strong="H5971"\w* \w je|strong="H5971"\w* \w ne|strong="H5971"\w* \w la|strong="H5971"\w* dépouille \w pour|strong="H5971"\w* \w la|strong="H5971"\w* \w laisser|strong="H5971"\w* nue,  
\q2 \w que|strong="H5971"\w* \w je|strong="H5971"\w* \w ne|strong="H5971"\w* \w la|strong="H5971"\w* \w rende|strong="H5971"\w* \w comme|strong="H5971"\w* \w au|strong="H5971"\w* jour \w de|strong="H5971"\w* sa naissance,  
\q1 \w que|strong="H5971"\w* \w je|strong="H5971"\w* \w ne|strong="H5971"\w* \w la|strong="H5971"\w* change \w en|strong="H5971"\w* \w un|strong="H5971"\w* désert,  
\q2 \w que|strong="H5971"\w* \w je|strong="H5971"\w* \w ne|strong="H5971"\w* \w la|strong="H5971"\w* réduise \w en|strong="H5971"\w* \w une|strong="H5971"\w* \w terre|strong="H5971"\w* aride,  
\q2 \w et|strong="H5971"\w* \w que|strong="H5971"\w* \w je|strong="H5971"\w* \w ne|strong="H5971"\w* \w la|strong="H5971"\w* fasse mourir \w de|strong="H5971"\w* soif.   
\q1
\v 4 \w En|strong="H6440"\w* \w effet|strong="H6440"\w*, \w je|strong="H3588"\w* n'aurai \w pas|strong="H3808"\w* \w de|strong="H6440"\w* miséricorde \w pour|strong="H6440"\w* \w ses|strong="H6440"\w* \w enfants|strong="H6440"\w*,  
\q2 \w car|strong="H3588"\w* \w ce|strong="H1931"\w* \w sont|strong="H6440"\w* \w des|strong="H6440"\w* \w enfants|strong="H6440"\w* \w d|strong="H6440"\w*'infidélité.   
\q1
\v 5 Car \w leur|strong="H3117"\w* \w mère|strong="H3117"\w* s'\w est|strong="H3117"\w* prostituée.  
\q2 \w Celle|strong="H3205"\w* \w qui|strong="H3117"\w* \w les|strong="H7760"\w* \w a|strong="H3068"\w* conçus s'\w est|strong="H3117"\w* couverte \w de|strong="H3117"\w* honte ;  
\q1 car \w elle|strong="H3117"\w* \w a|strong="H3068"\w* \w dit|strong="H3117"\w* : “\w J|strong="H3068"\w*'irai \w après|strong="H3205"\w* \w mes|strong="H3117"\w* amants,  
\q2 \w qui|strong="H3117"\w* \w me|strong="H3117"\w* donnent \w mon|strong="H7760"\w* \w pain|strong="H3117"\w* \w et|strong="H3117"\w* \w mon|strong="H7760"\w* eau,  
\q2 \w ma|strong="H3117"\w* laine \w et|strong="H3117"\w* \w mon|strong="H7760"\w* lin,  
\q2 \w mon|strong="H7760"\w* huile \w et|strong="H3117"\w* \w ma|strong="H3117"\w* boisson.”   
\q1
\v 6 C'\w est|strong="H1121"\w* \w pourquoi|strong="H3588"\w*, \w voici|strong="H3588"\w*,\f + \fr 2.6 \ft « Voici », de « \+wh הִנֵּה\+wh* », signifie regarder, prêter attention, observer, voir ou contempler. Il est souvent utilisé comme interjection.\f* \w je|strong="H3588"\w* \w vais|strong="H3588"\w* barrer \w ton|strong="H1121"\w* chemin \w avec|strong="H1121"\w* \w des|strong="H1121"\w* ronces,  
\q2 \w et|strong="H1121"\w* \w je|strong="H3588"\w* dresserai \w un|strong="H1121"\w* mur \w contre|strong="H3808"\w* \w elle|strong="H3588"\w*,  
\q2 afin \w qu|strong="H3588"\w*'\w elle|strong="H3588"\w* \w ne|strong="H3808"\w* \w trouve|strong="H3588"\w* \w plus|strong="H3808"\w* \w ses|strong="H1121"\w* sentiers.   
\q1
\v 7 \w Elle|strong="H3588"\w* poursuivra \w ses|strong="H5414"\w* \w amants|strong="H5414"\w*,  
\q2 \w mais|strong="H3588"\w* \w elle|strong="H3588"\w* \w ne|strong="H4325"\w* \w les|strong="H5414"\w* rattrapera \w pas|strong="H5414"\w* ;  
\q1 \w elle|strong="H3588"\w* \w les|strong="H5414"\w* cherchera,  
\q2 \w mais|strong="H3588"\w* \w ne|strong="H4325"\w* \w les|strong="H5414"\w* trouvera \w pas|strong="H5414"\w*.  
\q1 \w Alors|strong="H5414"\w* \w elle|strong="H3588"\w* dira : “\w Je|strong="H3068"\w* \w vais|strong="H3588"\w* retourner \w vers|strong="H3212"\w* \w mon|strong="H5414"\w* premier \w mari|strong="H5414"\w*,  
\q2 \w car|strong="H3588"\w* j'\w étais|strong="H5414"\w* \w plus|strong="H5414"\w* heureuse \w alors|strong="H5414"\w* \w qu|strong="H3588"\w*'aujourd'hui.”   
\q1
\v 8 \w Car|strong="H3651"\w* \w elle|strong="H3808"\w* n'\w a|strong="H3068"\w* \w pas|strong="H3808"\w* reconnu \w que|strong="H3808"\w* c'\w est|strong="H1870"\w* \w moi|strong="H3808"\w* \w qui|strong="H1870"\w* \w lui|strong="H3808"\w* \w donnais|strong="H3808"\w* \w le|strong="H4672"\w* blé, \w le|strong="H4672"\w* vin nouveau \w et|strong="H3808"\w* l'huile,  
\q2 \w et|strong="H3808"\w* \w qui|strong="H1870"\w* multipliais \w pour|strong="H1870"\w* \w elle|strong="H3808"\w* l'\w argent|strong="H3808"\w* \w et|strong="H3808"\w* l'or, qu'\w ils|strong="H3651"\w* ont utilisés \w pour|strong="H1870"\w* Baal.   
\q1
\v 9 C'\w est|strong="H2896"\w* \w pourquoi|strong="H3588"\w* \w je|strong="H3588"\w* \w reprendrai|strong="H7725"\w* \w mon|strong="H3588"\w* blé \w en|strong="H3212"\w* \w son|strong="H7725"\w* \w temps|strong="H7223"\w*,  
\q2 \w et|strong="H3212"\w* \w mon|strong="H3588"\w* \w vin|strong="H3212"\w* \w nouveau|strong="H7725"\w* \w en|strong="H3212"\w* \w sa|strong="H7725"\w* saison,  
\q2 \w et|strong="H3212"\w* \w je|strong="H3588"\w* retirerai \w ma|strong="H7725"\w* laine \w et|strong="H3212"\w* \w mon|strong="H3588"\w* lin \w qui|strong="H3808"\w* \w devaient|strong="H3808"\w* couvrir \w sa|strong="H7725"\w* nudité.   
\q1
\v 10 \w Maintenant|strong="H3588"\w* \w je|strong="H3588"\w* découvrirai \w sa|strong="H5414"\w* \w honte|strong="H5414"\w* \w aux|strong="H5414"\w* \w yeux|strong="H5414"\w* \w de|strong="H6213"\w* \w ses|strong="H6213"\w* \w amants|strong="H5414"\w*,  
\q2 \w et|strong="H6213"\w* \w personne|strong="H3588"\w* \w ne|strong="H3808"\w* \w la|strong="H6213"\w* délivrera \w de|strong="H6213"\w* \w ma|strong="H5414"\w* \w main|strong="H7235"\w*.   
\q1
\v 11 \w Je|strong="H3068"\w* \w ferai|strong="H7725"\w* \w aussi|strong="H3651"\w* cesser \w toutes|strong="H7725"\w* \w ses|strong="H3947"\w* réjouissances :  
\q2 \w ses|strong="H3947"\w* \w fêtes|strong="H4150"\w*, \w ses|strong="H3947"\w* nouvelles \w lunes|strong="H4150"\w*, \w ses|strong="H3947"\w* sabbats, \w et|strong="H7725"\w* \w toutes|strong="H7725"\w* \w ses|strong="H3947"\w* assemblées \w solennelles|strong="H4150"\w*.   
\q1
\v 12 \w Je|strong="H3068"\w* dévasterai \w ses|strong="H3027"\w* \w vignes|strong="H3027"\w* \w et|strong="H3027"\w* \w ses|strong="H3027"\w* figuiers,  
\q2 \w dont|strong="H5869"\w* \w elle|strong="H3027"\w* disait : “C'\w est|strong="H5869"\w* \w le|strong="H3027"\w* salaire \w que|strong="H3808"\w* \w mes|strong="H3027"\w* amants m'\w ont|strong="H5869"\w* \w donné|strong="H3808"\w*.”  
\q2 \w J|strong="H3068"\w*'\w en|strong="H5869"\w* \w ferai|strong="H3027"\w* \w une|strong="H3027"\w* forêt,  
\q2 \w et|strong="H3027"\w* \w les|strong="H3027"\w* animaux \w des|strong="H3027"\w* champs \w les|strong="H3027"\w* \w dévoreront|strong="H5869"\w*.   
\q1
\v 13 \w Je|strong="H3068"\w* \w la|strong="H7673"\w* punirai \w pour|strong="H4150"\w* \w les|strong="H3605"\w* jours \w des|strong="H2282"\w* Baals,  
\q2 auxquels elle brûlait \w de|strong="H3605"\w* l'encens,  
\q1 lorsqu'elle se paraît \w de|strong="H3605"\w* \w ses|strong="H3605"\w* anneaux \w et|strong="H2320"\w* \w de|strong="H3605"\w* \w ses|strong="H3605"\w* bijoux,  
\q2 \w et|strong="H2320"\w* qu'elle allait \w après|strong="H2320"\w* \w ses|strong="H3605"\w* amants  
\q2 \w en|strong="H2282"\w* m'oubliant », dit \w le|strong="H3605"\w* SEIGNEUR.   
\q1
\v 14 « C'\w est|strong="H2416"\w* pourquoi, voici, \w je|strong="H5414"\w* \w vais|strong="H5414"\w* \w la|strong="H5414"\w* séduire,  
\q2 \w je|strong="H5414"\w* \w la|strong="H5414"\w* conduirai \w au|strong="H5414"\w* désert,  
\q2 \w et|strong="H5414"\w* \w je|strong="H5414"\w* parlerai \w à|strong="H5414"\w* \w son|strong="H5414"\w* \w cœur|strong="H7760"\w*.   
\q1
\v 15 \w De|strong="H3117"\w* \w là|strong="H3068"\w*, \w je|strong="H3117"\w* \w lui|strong="H3068"\w* \w donnerai|strong="H3068"\w* \w ses|strong="H5921"\w* vignobles,  
\q2 \w et|strong="H3068"\w* \w la|strong="H3068"\w* \w vallée|strong="H3117"\w* \w d|strong="H1992"\w*'Akor \w comme|strong="H3068"\w* \w une|strong="H3068"\w* \w porte|strong="H5921"\w* \w d|strong="H1992"\w*'espérance ;  
\q1 \w et|strong="H3068"\w* \w là|strong="H3068"\w*, \w elle|strong="H3117"\w* \w répondra|strong="H3117"\w*  
\q2 \w comme|strong="H3068"\w* \w aux|strong="H3068"\w* \w jours|strong="H3117"\w* \w de|strong="H3117"\w* \w sa|strong="H3068"\w* jeunesse,  
\q2 \w et|strong="H3068"\w* \w comme|strong="H3068"\w* \w au|strong="H3068"\w* \w jour|strong="H3117"\w* \w où|strong="H3117"\w* \w elle|strong="H3117"\w* \w est|strong="H3068"\w* \w montée|strong="H3068"\w* \w du|strong="H3117"\w* \w pays|strong="H3068"\w* \w d|strong="H1992"\w*'Égypte.   
