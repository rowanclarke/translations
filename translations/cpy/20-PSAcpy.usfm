\s1 Rajahaa-wentari Tajorentsi maawoeni rowetsikani
\q1 
\v 1 ¡Pajahaa-wentee-yaari Tajorentsi inkiteki!
\q1 ¡Pajahaa-wentee-yaari ojenokiperotzinta!
\q1 
\v 2 ¡Pimateero eeroka ronampiripaeni tajorentsi, pajahaa-wentee-yaari!
\q1 ¡Eeroka rowayiritepaeni inkite-jatzi, pajahaa-wentyaari!
\q1 
\v 3 ¡Eejatzi eeroka ooryaa, kashiri, pajahaa-wentyaari Tajorentsi!
\q1 ¡Pimateero eeroka ikaatzi oorenta-chari, pajahaa-wentyaari!
\q1 
\v 4 ¿Pajahaa-wentee-yaari eeroka, Jenoki-pero-jatzi,
\q1 Pimateero eeroka, nijaa jeekatsiri inkiteki!
\q1 
\v 5 Pajahaa-wentee-yaawo iwaero Tajorentsi,
\q1 Tema apatziro iñaawaetaki rirori, wetsika-yitanakimi eeroka-paeni.
\c 149
\c 150
