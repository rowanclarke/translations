\id PSA
\ide UTF-8
\h MANIKAYKURRU MÄRR‐YIŊGATHINYARAWUY
\toc1 PSALMS Märr‐yiŋgathinyarawuynha manikaykurru, wokthunarana Godku
\toc2 Psalms
\mt1 PSALMS
\mt2 Märr‐yiŋgathinyarawuynha manikaykurru, wokthunarana Godku
\c 1
\s1 Rom‐djulŋi yolŋu
\s2 1:1–6 (True happiness)
\q1 
\v 1 Yol dhika yolŋu galŋa‐ŋamathirrinydja yukurra?
\q1 Yolŋu yurru galŋa‐ŋamathirrinydja yukurra,
\q2 ŋunhi ŋayi yurru yakana ŋula mäkiri'‐witjun ŋuriki rom‐yätjkunydja yolŋuwu,
\q2 ga yakana ŋayi yurru malthun yätjmirriwunydja,
\q2 ga yakana ŋayi yurru ḻunduthirri ŋuriki walalaŋgu ŋunhi walala ŋuli yukurra warku'yun Godnha.
\q1 
\v 2 Yo. Ŋunhiyi yolŋu galŋa‐ŋamathirrinydja yukurra, wirrkina goŋmirriyirri,
\q2 ŋunhi ŋayi ŋuli yukurra girrirriyun Garraywalaŋuwu romgu munha‐ŋupan ga walu‐ŋupan;
\q1 Bitjanna liŋguna guyaŋirrinydja ŋayi ŋuli yukurra Gunhu'wuna dhäruk.
\q1 
\v 3 Liŋgu ŋayinydja ŋunhiyinydja yolŋu balanyara bitjan dharpa ŋunhi ŋuli djingaryun galki gapuŋura.
\q1 Ŋunhiyi dharpa ŋuli bitjanna liŋguna borummirriyirri,
\q2 ga man'tjarrnydja malanha ŋunhiyi dharpa yakana ŋuli dhika galaḏa'yun.
\q1 Ga balanyarayina ŋayinydja ŋunhiyinydja yolŋu ŋunhi ŋayi ŋuli yukurra dhärra Garraywala romŋura;
\q2 Dhuwurr‐djulŋina balanyarana ya' yolŋu,
\q2 liŋgu nhä ŋayi ŋuli warkthun, ŋayinydja yurru nhanŋu ŋanydjaḻa'yundja maḻŋ'thun ŋamakurru'na yanana.
\b
\q1 
\v 4 Yurru yätjmirrinydja yolŋu'‐yulŋu yaka balanyarayi bitjan walŋamirri dharpa;
\q1 Walalanydja ŋunhi yätjmirrinydja yolŋu balanyarana bitjan räwak mulmu ŋunhi ŋuli watayunydja bo'yun ya',
\q2 bala buṯthunmaramana, winya'yunmaramana.
\q1 
\v 5 Yo. Godthu boŋguŋu yätjmirrinhanydja yolŋunha walalanha warrkuḻuŋuna;
\q2 Yakana walala boŋguŋu miṯtjiŋura nhini rom‐ŋamakurru'mirriwalanydja.
\q1 
\v 6 Liŋgu Garraynydja marŋgina ŋilimurruŋgu,
\q2 ŋayi yukurra goŋ‐nherraṉmirri rom‐ŋamakuli'mirriwunydja yolŋu'‐yulŋuwu,
\q1 yurru rom‐yätjmirrinydja yolŋu'‐yulŋu boŋguŋu winya'‐winyayurruna gupaḏalkuŋuna.
\c 2
\s1 Ŋurruŋuna wal'ŋu yana ŋayi Garraynydja
\s2 2:1–12 (God is in control of all things)
\q1 
\v 1 Nhäku warray walala ŋuli miṯtjiyu yolŋu'‐yulŋuyu nyinyaŋdhundja, ŋapa‐nherraṉmirrinydja nhanŋu Godku?
\q1 Nhäku warray walala ŋuli waŋa bitjandja, “Ŋanapurrunydja yurru yukurra nhina ŋanapurruŋgala yana djälkurru ga guyaŋinyarakurru wal'ŋu.”
\q1 
\v 2 Walala ŋunhi ŋurru'‐ŋurruŋunydja buŋgawamirrinydja ŋuli waŋa bitjan, “Yakana yurru ŋanapurruwaynydja buku‐nyilŋ'thun ga dhäruk‐märrama ŋanya Garraynha,
\q2 ga ŋunhinhanydjayi ŋunhi ŋayi djarr'yurruna be buŋgawa ŋanapurruŋgu ŋayi.
\q1 
\v 3 Yana ŋilimurru dhayaḻakunhamirrina, yänana wal'ŋu nhina yukurra.
\q2 Yakana ŋanapurrunydja yurru nhina yukurra garrpiṉara Garraywuŋunydja wo ŋula yolkuŋu yolŋuwuŋu,”
\q2 bitjan walala ŋuli yukurra waŋanydja.
\b
\q1 
\v 4 Ga ŋayinydja Garraynydja ŋunha yukurra nhina nhanukalay ŋayi wäŋaŋura djiwarr'ŋura,
\q2 nhämanydja ŋayi yukurra, bala gitkitthunna yana;
\q1 bitjan ŋayi yukurra warku'yunna ŋunhinydja yolŋu'‐yulŋunha,
\q2 ŋunhi walala ŋuli guyaŋirri yanapi walala yurru djuḻkthunmarama ŋanya Garraynha.
\q1 
\v 5 Bala ŋayi yurru waŋanydja nhanukalay ŋayi ŋuriŋi ŋaramurryuna,
\q2 ga walalanydja yurru barrarirrina yanana.
\q1 
\v 6 Bala ŋayi Godtja yukurra waŋa bitjanna, “Liŋgu ŋarra nherrara buŋgawanhanydja yolŋunha gal'ŋu ŋunhala muka ŋunhi \f + \fr 2:6 \ft Zion\f*Djäyan bukuŋura,
\q2 ŋayina yurru nhinanydja yukurra ŋurruŋuna ŋayi wal'ŋu bukmakkuna.”
\b
\q1 
\v 7 Yo, ŋarra nhumalaŋgu yurru ḻakaramana ŋunhi nhaltjan ŋayi yukurra Godthu ḻakarama, ga waŋa ŋarrakalaŋuwuy,
\q2 waŋanydja ŋayi yukurra bitjan, “Nhenydja dhuwalanydja gäthuna ŋarraku.
\q2 Gäthuranydja waluyu ŋarra nhuŋu bäpa'mirriŋuyinana.
\q1 
\v 8 Ga waŋanydja nhe yurru ŋäŋ'thundja ŋarranha,
\q2 ga ŋarranydja yurru nhuŋu wekamana miṯtjinhanydja bukmaknha yana;
\q1 Bukmak ŋunha miṯtji ga bäpurru' yolŋu walala buku‐ḻiw'marama ŋunha munatha'ŋura wäŋaŋura,
\q2 warrpam' nhuŋuway yana wal'ŋu.
\q1 
\v 9 Nhenydja yurru walalanha bitjan ḏaw'‐ḏawyunna ŋuriŋina ḏälyuna gal'ŋu dharpayu,
\q2 ŋunhi walala yurru yakanydja dhäruk‐märrama nhuna;
\q1 walala yurru ḏaw'‐ḏawyundja marrtji muṉguythirrina ŋuriŋi nhokalay goŋdhunydja bunharayunydja,”
\q2 bitjarrana yukurrana Garray waŋananydja.
\b
\q1 
\v 10 Yo, nhuma ŋurru'‐ŋurruŋu buŋgawamirri yolŋu walala,
\q2 mäkiri'‐witjurra walala dhiyaku dhärukkunydja, ga marŋgithiya muka,
\q2 dhiyaŋuyinydjayi dhärukthu ŋarra nhumalanha yukurra raypirri'yun waŋa.
\q1 
\v 11 Rom‐wiyaṉiyiyana biyakana Garraywunydja, ga märr‐ŋal'yurra nhanukalaynha;
\q1 
\v 12 Marr'‐marryurrana biyakana, ga nyilŋ'maranhamiyana nhanukala,
\q2 märr yurru ŋayi yaka muka waḏutjanydja nhumalaŋgu maḏakarritjthirri,
\q2 bala baḏuwaḏuyundja nhumalanha warrpam'thundja yurru.
\q1 Yurru ŋayipinydja Garraynydja wal'ŋu ŋilimurruŋgu ŋurrwu'na,
\q2 ŋayina yurru gunganhamirriyamanydja ŋula yolnha yolŋunha ŋunhi walala yurru marrtji nhanukalanydja,
\q2 ga ŋunhiyinydjayi yolŋu yurru nhina goŋmirriyanharawuynha wal'ŋu yana Garraywuŋunydja.
\c 8
\s1 Godthu gurrunhara ḻatju'kuŋala yolŋuwu
\s2 8:1–9 (God honoured man)
\q1 
\v 1 Garray gay' marrkapmirri,
\q2 nhe muka ŋanapurruŋgu Garraynydja,
\q1 bukmak dhuwala munatha'ŋura ŋorra marrtji, nhunana yukurra mel‐ḻakarama;
\q1 Ḻatju' dhuwala nhe yolŋunydja, Garray.
\q1 
\v 2 Dhuwali djiwarr'ŋura wokthun yukurra nhuŋu yana,
\q2 ga yutjuwaḻa'mirrinydja yumurrku' yolŋu'‐yulŋu nhuŋu yukurra yana märr‐gorruma,
\q2 wokthundhi nhuŋu ga ḻatju'‐ḻakarama.
\q1 Nhinanydja nhe yukurra wuṉḏaŋarr yana wal'ŋu dhika,
\q2 ga yakana yurru ŋula miriŋunydja marrtji galkithirrinydja,
\q2 liŋgu nhe yukurra gulmaramana ŋula yolnhanydja ŋunhi ŋayi ŋuli nhuŋu ŋapa‐nherraṉmirri.
\q1 
\v 3 Wiripunydja ŋarra ŋuli bakuruma garrwar,
\q2 bala nhämana ŋuli gäraktja ŋunhi nhokuŋu bokmanaranydja.
\q1 Nhe bokmara ŋaḻindi ga ganyu' malanha,
\q2 ga nherrara nhe walalanha gäraklili.
\q1 Nhäma ŋarra ŋuli yulŋunydja,
\q2 bala ŋarra ŋuli guyaŋirrina bitjan,
\q1 
\v 4 “Nhäku warray Garrayyu yukurra guyaŋirri ga ḻayḻayyun yolŋuwalanydja?
\q1 Yolŋunydja dhuwala yutjuwaḻa'na, nyumukuṉiny'nha yana,
\q2 yurru mukthun ŋayi ŋuli Garraynydja yolŋuwu djäka.
\q1 Nhäyinyarana dhuwala ŋayi yolŋunydja?”
\q2 Bitjan ŋarra ŋuli guyaŋirri.
\b
\q1 
\v 5 Yuwalk muka nhe bokmara yolŋunhanydja,
\q2 bala ŋurrulilina nhe ŋanya nherraranydja.
\q1 Yolŋunydja dhuwala yaka nyumukuṉiny' nhokala maŋutjiŋura.
\q1 Nhepina wal'ŋu biyapulnydja‐wala ŋurruŋu yolŋuwu,
\q2 ga yolŋunydja ŋurruŋu dhiyaku malanyŋuwu ŋunhi nhe goŋ.
\q1 
\v 6-8 Goŋ‐nherraranydja nhe ŋanya yolŋunhanydja;
\q1 Nhanukala yolŋuwala goŋŋura bukmak dhika ŋorra yukurra;
\q2 boḏiny wäyin ga wäyin wakinŋu,
\q2 buṯthunaramirri wäyin ga gaḻ'yunaramirri, ga gapuŋura guya.
\q1 Bukmaknha yana nhe wekaŋala yolŋuwala dharraylili.
\b
\q1 
\v 9 Garray gay', marrkapmirri,
\q2 nhe muka ŋanapurruŋgu Garraynydja.
\q1 Bukmakthu dhiyaŋu malaŋuyu nhuna yukurra mel‐ḻakaramana.
\q1 Ḻatjuŋ'ka dhuwala nhe yulŋunydja, Garray.
\c 14
\s1 Ḻakarama yukurra rom‐yätjmirrinha yolŋu'‐yulŋunha
\s2 14:1–7 (Telling about foolish men)
\q1 
\v 1 Nyalmirinydja ŋunhinydja yolŋu ŋuli waŋa bitjanna gam'.
\q2 “Wanhaka dhika ŋayi Godtja be? . . .
\q2 bäyŋu warray dhika Godtja.”
\q1 Yo, bukmak yolŋu walala djarrpi'mirrinydja yana wal'ŋu;
\q2 Djämanydja walala ŋuli mirithirrina dhika yätjnha romdja,
\q2 yakana ŋula yol waŋgany yolŋu ŋayi yurru djäma ŋamathama.
\q1 
\v 2 Yo, Garrayyunydja marrtji nhäma ŋulaŋuru djiwarr'ŋurunydja,
\q2 lili djipmarama dhipala munatha'lilinydja wäŋalili,
\q2 nhäma'‐nhama ŋayi marrtji bitjan yolŋu'‐yulŋunha ŋilimurrunha;
\q1 Nhämanydja ŋayi ŋunhi marrtji ḻarrumanydja ŋuriki yolŋuwu ŋunhi ŋayi ŋuli djäma ḻiya‐djambatjthu gal'ŋu yana,
\q2 ŋuriki wal'ŋu ŋunhi ŋayi yuwalkkuma yukurra djälthirri malthunarawu Godku.
\q1 
\v 3 Liŋgu bukmak yolŋunydja walala bilyurruna yukurrana ŋulaŋurunydja Godkalanydja,
\q2 bukmakthinana gatjpaḻ'yurrunana dhuwurr‐djarrpi'yinana;
\q2 Yakana ŋula waŋgany rom‐ŋamakurru'thinanydja Godkala maŋutjiŋura.
\b
\q1 
\v 4 Ga ŋayi Garraynydja yukurra waŋa bitjan, “Nhä ŋunhanydja dhuwurr‐yätjmirrinydja yolŋu'‐yulŋu? . . . dhuŋamirri?
\q2 Yakana ŋunha walala marŋginydja?
\q1 Balanyarana ŋunha walala yätjmirrinydja ŋunhinydja yolŋu'‐yulŋu,
\q2 bitjan walala marrtji bumana ŋarrakunydja ŋunhi yolŋu'‐yulŋunha,
\q2 ga yakana walala ŋuli bukumirriyama ŋarrakalanydja.”
\q1 
\v 5 Yuwalk yana yurru ŋunhiyi dhuwurr‐yätjmirrinydja walala barrarirri dhika wal'ŋu,
\q2 liŋgu Godtja galki yana wal'ŋu ŋurikalanydja walalaŋgala ŋunhi walala dhäruk‐märranharamirri walala nhanŋu.
\q1 
\v 6 Ŋuriŋi dhuwurr‐yätjmirriyunydja warku'yun yukurra ŋunhinydja rom‐dharraḏamirrinhanydja yolŋu'‐yulŋunha,
\q2 yurru Godtja dhuwala balanyara bitjan ŋayi ŋurrwu'na ŋurikinydja yolŋu'‐yulŋuwu ŋurruwuykmirriwunydja gal'ŋu,
\q2 ŋayi ŋunhiyinydjayi gunganhamirriyama yukurra walalanha.
\q1 
\v 7 Garray, ŋarranydja yukurra ŋäŋ'thun, ŋunhi nhe nhina yukurra ŋunha gay' bukuŋura \f + \fr 14:7 \ft Zion\f*Djäyan,
\q2 nhe yurru walŋakuma \f + \fr 14:7 \ft Israel\f*Yitjuralnhanydja miṯtjinha,
\q2 dhawaṯmarama walalanha beŋuru miriŋuwalanydja goŋŋuru yurru.
\q1 Nhäna ŋunhiyinydjayi djulŋithinyaramirri yurru walu ŋuriki Yitjuralwunydja miṯtjiwu,
\q2 ŋunhi nhe yurru Garray nhuŋuwaynha yolŋu'‐yulŋunha gämana lili, wäŋa‐roŋinyamaramana yurru walalanha.
\c 15
\s1 Balanyara dhuwala Godkunydja yolŋu'‐yulŋu
\s2 15:1–5 (This is what God’s people are like)
\q1 
\v 1 Yo, Garray, yol yurru dhika nhina yukurra nhokalanydja buṉbuŋura?
\q2 Yol yurru dhika buku‐ŋal'yun yukurra ŋunhala nhokalanydja bukuŋura \f + \fr 15:1 \ft Zion\f*Djäyandja wäŋaŋura?
\q1 
\v 2 Balanyara warray gam' yolŋu yurru nhina yukurra galkinydja gal'ŋu Godkalanydja,
\q2 ŋunhiyi ŋunhi ŋayi yurru dhäruk ŋanya märrama gal'ŋu warrpam'thun yana,
\q2 ga djäma ŋayi yurru bitjan liŋgu nhä ŋunhi ŋamakurru',
\q2 ga yuwalk ŋayi yurru waŋanydja yukurra yuwalkŋu yana dhäruktja, yaka bothinyarayŋu.
\q1 
\v 3 Yaka ŋayi yurru waŋa yätjkuma ŋunha wiripuŋunha yolŋunha,
\q2 ga yaka ŋayi yurru wiḏiyal‐gäma ŋuriŋi yolŋuyu;
\q2 Yaka ŋayi yurru ŋayaŋu‐yätjkuma nhanukalay ŋayi dhärukthu.
\q1 
\v 4 Ŋunhiyinydjayi yolŋu rom‐dhunupanydja gal'ŋu, yakana ŋayi yurru galkithirri ŋurikalanydja yolŋuwala ŋunhi ŋayi yaka ḏukṯuk Godku,
\q2 yana ŋayi yurru gananna ŋanya;
\q1 Yurru ŋayi märr‐ŋal'yundja yurru ŋurikalana yolŋuwala ŋunhi ŋayi yukurra rom‐wiyaṉiyirri Godku Garraywu,
\q2 ga dhäruk ŋanya märrama.
\q1 
\v 5 Ŋunhi ŋayi yurru ŋuriŋiyi yolŋuyu dhuwurr‐ŋamakurru'yu wekama yana guwarr,
\q2 ga märramanydja ŋayi yurru ŋunhi yana liŋgu nhä ŋayi wekaŋala ŋäthili,
\q1 ga yaka ŋayi yurru yukurra bothinyarayŋu dhäwu' ŋula nhä ḻakarama ŋurikala yolŋuwala mala‐yarr'yunaramirriwala yana ŋuriki rrupiyawu märranharawu.
\b
\q1 Yo, balanyarayinydjayi yolŋu yurru yukurra dhärra wuṉḏaŋarrnha wal'ŋu yana,
\q2 yakana ŋanya yurru ŋula nhäyu galkinyamaramanydja,
\q2 liŋgu ŋayinydja ŋunhinydjayi yolŋu gunganharawuynha Garraywuŋunydja.
\c 16
\s1 Ŋarranydja walŋa warray djäkaŋura Godkala warray
\s2 16:1–11 (I am safe in God’s care)
\q1 
\v 1 Garray God, gunganhamirriyaŋa ŋarranha,
\q2 liŋgu ŋarra yukurra märr‐nherraṉmirri nhokalay gal'ŋu yana;
\q1 Nhepi ŋuli ŋarranha gämanydja ḻatju'kuma dhika.
\q1 
\v 2 Ŋarra ŋuli waŋa Garraywala bitjan, “Nhenydja dhuwala ŋarraku Garray;
\q1 Bukmak nhä malanha ŋunhi ŋarra yukurra ŋayathama nhokuŋuway yana warrpam' ḻatju'mirri ŋanya dhika.”
\q1 
\v 3 Ŋarra yukurra märr‐ŋamathirri ŋurikinydja yolŋu'‐yulŋuwu ŋuli walala yukurra märr‐ŋamathirri nhuŋu;
\q2 Yuwalk ŋarra yana ḏukṯukthirri yukurra nhinanharawu walalaŋgunydja galkiwunydja gal'ŋu.
\q1 
\v 4 Wiripu‐guḻkuny'tja yurru gulŋiyirri yukurra marilili, yindilili wal'ŋu,
\q2 liŋgu mirithirri walala yukurra ḏukṯukthirri wiripuŋuwuna waŋarrwu.
\q1 Ŋarranydja yurru yaka buku‐ŋal'yun yukurra walalaŋgalaŋuwunydja waŋarrwu,
\q2 ga yaka yurru ŋarra mundhurr‐wekama ŋula nhä bitjan gulaŋ‐waṉḏinyamarama walalaŋgalanydja.
\b
\q1 
\v 5 Garray, ŋarranydja ḏukṯuk nhuŋuway yana waŋganygu,
\q2 nhenydja ŋuli marrtji rarryun bukmak nhänydja malanha ḻatju' dhika ŋarraku,
\q2 ga dhuwalana gay' ŋarra yulŋunydja nhokala goŋŋurana.
\q1 
\v 6 Nhenydja ŋamakurru' wal'ŋu yana God, ga wekamanydja nhe ŋuli nhä ŋamakurru',
\q2 ŋunhina liŋgu dhapirrkmirrina dhika wal'ŋu nhe ŋuli wekamanydja ŋarraku.
\q1 
\v 7 Ŋarra wokthun nhuŋu yulŋunydja Garray,
\q2 liŋgu nhepi ŋuli gämanydja ŋarranha marrtji ŋuliwitjandja dhukarrkurru dhunupakurrunydja;
\q1 munhakunydja ŋuli nhe ŋarrakala waŋa ŋayaŋuŋura ŋunha wal'ŋu,
\q2 marŋgikuma ŋarranha marrtji bitjan nhäku malaŋuwu ŋamakurru'wu,
\q2 ga dharraykuma nhe ŋuli waŋa ŋulaŋuru yätjmirriwalanydja.
\q1 
\v 8 Garray, bitjan warray liŋgu ŋarra ŋuli guyaŋirrinydja yukurra nhuna,
\q2 ŋunhi nhenydja dhiyalami bitjan liŋgu ŋarrakala ŋuli galki.
\q1 Galki yana nhenydja ŋarrakala,
\q2 yakana ŋarranha yurru ŋula nhäyu galkinyamaramanydja.
\q1 
\v 9 Dhiyakuyinayi märrwu ŋarra yukurra djulŋithirrina yana wirrkina yulŋunydja,
\q2 ga ŋayaŋunydja ŋarraku yukurra mirithirrina wal'ŋu goŋmirriyirri dhikana.
\q1 Ga nhinanydja ŋarra yurru walŋana yana,
\q2 gunganharayu ŋuriŋina nhokalaynha ganydjarryu walŋamirriyuna.
\q1 
\v 10 Nhe ŋarranhanydja yurru walŋakuma beŋuru rakunydhinyaraŋurunydja romŋuru,
\q2 yaka nhe yurru ŋarranhanydja gonha'yun ŋunha ŋunhi rakunymirriwalanydja wäŋalili.
\q1 
\v 11 Nhe maḻŋ'maraŋala ŋarrakala dhukarr ŋunhi walŋamirrinydja,
\q2 ga ŋunhalanydja ŋarra yurru nhina yukurra nhokalanydja galkina yana wal'ŋu,
\q2 bena dhika goŋmirriyirrina ŋarra yurru, ŋayaŋu‐djulŋithirrina wal'ŋu.
\q1 Ga ŋunhalanydja goŋŋura dhunupaŋuranydja nhokalaynydja ŋarra yurru nhina yukurra goŋmirriyirrina, gupaḏalnha‐wala yanana yurru.
\c 19
\s1 Godku rom malanha dhapirrkmirrinydja djämawuyŋurana ŋunhana
\s2 19:1–14 (God’s glory in creation)
\q1 
\v 1 Nhäna ŋunha gäraktja? . . . ḻatju'na dhikana ŋiniya?
\q1 Gärakthunydja ŋuriŋiyi yukurra ḻakarama Godnhana,
\q2 nhäyinyara ŋunhi ŋayinydja Godtja ḻatju' wal'ŋu ŋanya dhika.
\q1 Ŋayinydja ŋunhi goŋ‐djana'mirrina God ŋiniya?
\q2 liŋgu gäraktja ŋunha nhanukuŋuway yana djämawuy.
\q1 
\v 2 Bitjan liŋgu walu‐ŋupan ŋayi gärakthunydja yukurra ḻakaramana Godnha,
\q2 ga munha‐ŋupandja yolŋuyu walalay ŋuli gäraklilinydja bakuruma,
\q2 bala marŋgiyirrina yukurra Godku, ŋunhi ŋayinydja mirithirrina wal'ŋu ḻatju'na dhikana ŋanyana.
\q1 
\v 3 Ŋunhayi gäraktja rirrakaymiriw yana,
\q2 yakana ŋayi yukurra dhäruktja waŋa,
\q1 
\v 4 yurru yolŋu walala ŋuli buku‐ḻiw'marama marŋgiyirri Godku nhänharayuna yukurranharayu,
\q2 ŋunhi walala ŋuli bakuruma gäraklili, ga nhäma;
\q1 Birrka'mirriŋurana wäŋaŋuranydja yolŋuyu walalay ŋuli dharaŋanna ŋäma dhäwuny'tja,
\q2 ŋunhi yukurra nhaltjan gärakthu ḻakarama Godnha.
\q1 
\v 5 Ŋunhayi gäraktja balanyara bitjan yindi wal'ŋu buṉbu djämawuy Godkuŋu ŋuriki waluwu.
\q1 Bitjan liŋgu djaḏaw'yunarayunydja ŋayi ŋuli walunydja gaŋgathirri goŋmirriyirrina dhikana wal'ŋu,
\q2 ŋayaŋu‐yiŋgathirrina ŋayi marrtjinydja ŋuli gärakkurrunydja bala,
\q2 bitjanna bitjan ŋuli yuṯa ḏarramu ŋunhi waṉḏirri yukurra bata'yunaralili bala.
\q1 
\v 6 Marrtjinydja ŋayi ŋuli yukurra waŋganyŋuru gali'ŋuru,
\q2 yana liŋgu ga ŋunhana bala gali'ŋura gärrinydja ŋayi ŋuli;
\q1 Bala ŋayi yukurra waluyunydja ŋunhi ḻithanmaramanydja birrka'mirrina wäŋanydja,
\q2 yakana yukurra waŋgany wäŋa ŋorra djuḻuḻ'yundja nhanukalanydja goŋŋuru.
\b
\q1 
\v 7 Yo, Garraywunydja dhuwala rom ḻatju' warray ŋanya, dhapirrk warray dhika,
\q2 balanyara warray bitjan buŋgaṯmarama ŋayi ŋuli ŋunha ŋayaŋu.
\q1 Ŋilimurrunydja dhuwalanydja yolŋu'‐yulŋunydja, yaka ŋali marŋgi ŋuruku yuwalkŋuwunydja,
\q2 yurru ŋuriŋi Garraywalanydja dhärukthu ŋali ŋuli marŋgiyirrina marrtji,
\q2 bala ḻiya‐djambatjthirrina.
\q1 
\v 8 Yo, nhanŋunydja Garraywunydja dhukarr dhunupa warray yana,
\q2 ga ŋunhinydja walala ŋunhi walala ŋuli marrtji ŋuliwitjandhi dhukarrkurru,
\q2 nhinanydja walala yurru ŋayaŋu‐djulŋithirrina.
\q1 Garraywunydja rom dhuwala ḏarrtjalk dhika wal'ŋu ralkthunara djeŋarra',
\q2 bitjan yurru ŋuriŋi ḏarrtjalkkumana ŋilimurruŋgu ŋayaŋuna,
\q2 märr yurru ŋali nhina mälkuma nhämanydja,
\q2 bala marŋgiyirrina ŋuriki yuwalkŋuwunydja.
\q1 
\v 9 Yo, ŋamakurru' ŋunhi ŋali ŋuli rom‐wiyaṉiyirrinydja Garraywu;
\q2 bitjanna liŋgu gupaḏalnha‐wala yolŋunydja walala yurru nhina dhäruk‐märranharamirrina yanana.
\q1 Ŋayipinydja ŋuli Garrayyunydja djäma nhänydja ŋamakurru' ga dhunupa,
\q2 ga gupaḏalnha ŋunhiyi dhäruktja nhanŋu yurru yukurra dhärra djambimiriwnha nhämiriwnha.
\b
\q1 
\v 10 Yo, ŋunhinydja mel‐wiḏi'mirrinydja girri' manymak warray,
\q2 yurru Godkunydja rom ŋunhinydja biyapul'nha wal'ŋu ŋamakurru' dhika,
\q2 djuḻkmarama yukurra ŋunhiyi girri'nha mel‐wiḏi'mirrinhanydja.
\q1 Ga gukunydja dhuwala dhäkay‐ḻatju' muka ŋanya dhika,
\q2 yurru nhanŋunydja Godkunydja dhäruk ŋunhi biyapul gal'ŋu,
\q2 djuḻkmarama yukurra ŋunhiyi gukunhanydja.
\b
\q1 
\v 11 Garray, ŋuriŋi nhokalanydja dhärukthu ŋarranha ŋuli marrtji marŋgikuma,
\q2 liŋgu ŋarranydja dhuwala nhuŋu djämamirri.
\q1 Ŋuriŋi nhokala dhärukthunydja ŋarranha ŋuli raypirri'yun,
\q2 dharraykuma ŋarranha ŋula nhäŋuru yätjŋuru;
\q1 Rarr'yundja nhe ŋuli ŋarraku biyapul wal'ŋu dhika, goŋmirriyama wal'ŋu ŋarranha,
\q2 ŋunhi ŋarra ŋuli dhäruktja nhuna märrama.
\q1 
\v 12 Garray, wiripunydja ŋarra ŋuli rom‐waḏatjtjun nhuna,
\q2 bitjan ŋarra yurru yaka dharaŋan ŋunhiyi.
\q1 Rurrwuyurra ŋarranha Garray, ḏarrtjalkkuŋa ŋuliŋuruyi yätjŋurunydja dhukarrŋuru ga guyaŋinyaraŋuru,
\q2 ŋunhi yukurra djuḻuḻ'yun ŋarrakala ŋorra ŋayaŋuŋura.
\q1 
\v 13 Mulkiya ŋarranha baṯ biyaka,
\q2 märr ŋarra yurru yaka ḏukṯukthirri ŋuriki yätjkunydja.
\q1 Gunganhamirriyaŋa ŋarranha biyaka Garray,
\q2 märr yurru ŋarraku ŋayi yaka yätjtja buŋgawayirri,
\q1 bala ŋarra yurru ŋuliŋurunydja nhina ŋula nhämiriwnha yana wal'ŋu,
\q2 yakana ŋarra yurru djäma nhänydja ŋunhi yätj.
\q1 
\v 14 Garray, biyaka ḏarrtjalkkuŋa ŋarranha,
\q2 märr yurru ŋarra waŋa yukurra ŋamakurru' yana dhäruktja malanha, ga guyaŋirri ralkthunara yana wal'ŋu,
\q2 märr yurru ŋarrakala ŋuriŋi guyaŋinyarawuyyunydja ga dhärukthunydja nhunanydja galŋa‐djulŋikuma goŋmirriyama.
\q1 Garray, nhenydja ŋarraku ŋurrwu',
\q2 liŋgu nhe ŋarranha walŋakuŋala, märraŋala dhawaṯmaraŋala ŋuliŋuru yätjkalanydja goŋŋuru.
\c 23
\s1 Garray dhuwala ŋilimurrumbala djäkamirri
\s2 23:1–6 (The Lord is my shepherd)
\q1 
\v 1 Garraynydja dhuwala djäkamirri ŋarraku,
\q2 ga ŋarranydja dhuwala balanyara bitjan wäyin bembi nhanŋu.
\q1 Ŋayi ŋuli yukurra ŋarraku dharray ḻatju'kuma,
\q2 yakana ŋarra yukurra nhina dhäpark ŋula nhämiriw.
\q1 
\v 2 Ŋayi ŋuli ŋarranha yorrkumanydja ḻatju'lili mulmulilinydja,
\q2 ga nhinanydja ŋarra ŋuli maranhuna yana;
\q1 Gämanydja ŋarranha ŋayi ŋuli wurrkurrum'lili gapulili,
\q2 wurkthundja ŋarra ŋuli, bala ŋoynydja yal'yunna.
\q1 
\v 3 Ŋunhi ŋarra ŋuli djawaryundja, ganydjarrmiriwyirrinydja,
\q1 ŋayinydja ŋarranha ŋuli ganydjarrmirriyamayi, buŋgaṯthunmaramayi yurru.
\q1 Gämanydja ŋayi ŋuli ŋarranha dhukarrkurrunydja dhunupa'kurru yana,
\q2 liŋgu yuwalk muka ŋayi ŋamakurru' djäkamirri.
\b
\q1 
\v 4 Wiripunydja ŋarra ŋuli marrtji buku‐munha'kurru dhukarrkurru,
\q2 bitjan warraw'yu rakunydhinyaramirriyu ŋarranha ŋuli monyguma,
\q1 yurru ŋarranydja yurru yakana beyaṉiyirri ŋula nhäku,
\q2 bili nhena ŋuli Garray galki ŋarrakala bitjan liŋgu.
\q1 Nhenydja yukurra gäma dharpa wutthunarawu ŋula yolku miriŋuwu,
\q2 ga ŋarrakunydja nhe yukurra gäma wapitja weḻaŋ'thunarawu, ḻaw'maranharawu ŋarraku.
\q1 Ŋarra ŋuli marrtjinydja yukurra marrparaŋ'nha, beyaṉumiriwnha,
\q2 nhokalaynha yana djäkakurru' ga goŋgurru.
\b
\q1 
\v 5 Nhe ŋuli ŋäthilimirriyama wäŋa ŋarraku ḻatju' dhika, ŋatha‐guḻku'mirri;
\q1 Miriŋuyu walalay ŋuli ŋarranha ḻiw'maramana djingaryun, ŋayan'mirrinydja walala,
\q2 yurru ŋarranydja ŋuli marrtji mukthunna ḻuka ŋathanydja ga gapunydja,
\q2 beyaṉumiriwnha dhika wal'ŋu.
\q1 Nhe ŋuli ŋarraku gumurr‐ŋamathirri marrkapthun manapan,
\q2 bitjanna bitjan galkiwuywu gurruṯu'mirriwu.
\q1 Ga ŋayaŋunydja ŋarraku ŋuli marrtji dhaŋaŋdhirri galŋa‐djulŋithinyarayunydja,
\q2 ŋanbaw'‐ŋanbawyunna marrtji ŋuli.
\b
\q1 
\v 6 Yuwalk muka ŋayi yurru Garraynydja galki yana ŋarrakala,
\q2 bitjanna liŋgu nhanukalay märr‐ŋamathinyarayunydja ga ŋoy‐wuyunaramirriyunydja ŋarranha yurru yukurra gäma,
\q1 ga ŋarra boŋguŋu nhininydja dhiyaliyina Garraywala wäŋaŋuranydja,
\q2 biyakuna liŋguna, gupaḏalnha‐wala.
\c 24
\s1 Biyapul wal'ŋu buŋgawa ŋurruŋu ŋayi
\s2 24:1–10 (The Great King)
\q1 
\v 1 Dhuwalanydja munathany'tja wäŋa nhanŋuway yana ḻiw'marama Garraywu,
\q2 ga bukmak yolŋu walala nhina marrtji buku‐ḻiw'marama warrpam' yana dhulŋuŋu nhanŋuway Garraywu.
\q1 
\v 2 Ŋayipi djäma warrpam'thurruna dhuwala munatha', ga ŋunha gapu moṉuk ga maya'‐mayaŋ,
\q2 bukmak dhuwalayi yulŋunydja nhanukuŋuway yana djämawuynydja warrpam'.
\b
\q1 
\v 3 Yol yurru ŋayi dhika marrtji ŋunha bukulilinydja dhuwaṯthun Garraywalanydja wäŋalili?
\q1 Yol ŋayi rom‐ŋamakurruny'tja wal'ŋu yolŋu? . . .
\q2 ŋayi yurru marrtji, ga gärri ŋunhiwalayi nhanukala dharrpallilinydja wäŋalili?
\q1 
\v 4 Balanyara dhuwala yolŋunydja yurru marrtji gulŋiyirri gam',
\q2 ŋunhi ŋayi ŋuli djäma dhunupa yana ŋamakurru' wal'ŋu,
\q2 ga guyaŋirri ŋayi ŋuli ḻatju'kuma, ḏarrtjalkkuma dhika;
\q1 Ŋunhiyinydjayi yolŋu rom‐dhunupanydja, yaka ŋayi ŋuli buku‐ŋal'yun ŋula waŋarrwu wiripuŋuwunydja,
\q2 ga yaka ŋayi ŋuli dhawu'‐nherraṉ, yana mayali'‐wilkthundja ŋuriŋiyi.
\q1 
\v 5 Yuwalk yana Garrayyunydja yurru ŋunhiyinydja yolŋunha goŋmirriyamana dhika wal'ŋu,
\q2 ga walŋakumana ŋanya yurru.
\q1 
\v 6 Yo, balanyarayina walalana yurru marrtji galkithirrinydja gal'ŋu Garraywala,
\q2 bala gulŋiyirrina ŋunhiwalayi dharrpallilinydja Godkala Buṉbulili.
\b
\q1 
\v 7 Way, ḻapmaraŋana dhuwaliyi ḻoḻunydja dhurrwara,
\q2 märr yurru ŋayi ŋunhi djeŋarrany'tja buŋgawa marrtjina ŋuliwitjandhiyi gulŋiyirrina.
\q1 
\v 8 Yol ŋayi ŋunhi yolŋunydja ḻatjuny'tja dhikanydja buŋgawa? . . . Yol?
\q1 Garray ŋunhiyinydjayi ŋayinydja,
\q2 wuṉḏaŋarr ŋayi dhika wal'ŋu, ganydjarr‐ḏumurru;
\q1 Bitjan liŋgu ŋayi ŋuli djuḻkmarama yukurra galkinyamarama nhanŋuway ŋunhi miriŋunhanydja.
\b
\q1 
\v 9 Ḻapmaraŋana dhurrwaranydja wal'ŋu biyakana dhuwali wäŋanydja ḻoḻunydja,
\q2 bala ŋayinydja yurru ŋunhiyinydja ḻatjuny'tja dhikanydja buŋgawa gärrina lili gulŋiyirrina.
\q1 
\v 10 Yol ŋayi ŋunhi ḻatjuny'tja dhika buŋgawa?
\q1 Garray muka ŋunhi ŋayipi,
\q2 ŋunhi ŋayi djuḻkmaraŋalana bumara dhawar'maraŋalana miriŋunhanydja liŋguna,
\q2 ŋayi ŋunhiyi buŋgawanydja wal'ŋu, benydja‐wala garrwarnydja.
\c 27
\s1 Garray dhuwala ŋarraku djarraṯawun'tja ga walŋakunharamirrinydja
\s2 27:1–14 (The Lord is my light and my salvation)
\q1 
\v 1 Yo, Garraynydja ŋarraku dhuwala djarraṯawun', ga walŋakunharamirri ŋayi,
\q2 yakana ŋarra yurru barrarirri ŋula yolkunydja;
\q1 Ŋayipi muka Garrayyu ŋarranha ŋuli gunganhamirriyamanydja,
\q2 bala ŋarra ŋuli nhinana yukurra walŋana,
\q2 yakana ŋarra yukurra dhuwala barrarirri ŋula nhäkunydja.
\q1 
\v 2 Wiripunydja ŋuli dhuwurr‐yätjmirri ŋunhi yolŋu'‐yulŋu ŋayaŋu‐dhärra,
\q2 yana ḏukṯukthirri bunharawu ŋarraku,
\q2 yurru ŋunhiyi miriŋunydja walala ŋuli galkirrina marrtji yana.
\q1 
\v 3 Wiripunydja ŋarranha ŋuli dhaŋaŋdhu dhika wal'ŋu miriŋuyu ḻiw'marama dhärra,
\q2 yurru yakana ŋarranydja yurru barrarirri;
\q1 Ŋarra yurru mukthunna yana dhärrana yukurra,
\q2 bitjan ŋayaŋu‐nherraṉmirrina ŋarra yurru Garraywala.
\b
\q1 
\v 4 Waŋganyguna ŋarra yana ḏukṯuktja wal'ŋu, dhiyakuna gam':
\q2 Ŋarranydja ḏukṯuk ŋarra yurru nhina yukurra ŋunha Godkalanydja Buṉbuŋura bitjanna liŋguna, gupaḏalnha‐wala.
\q1 Ŋarra ḏukṯuk ŋarra yurru nhäma yukurra ŋanya Garraynha ŋunha nhanukala Buṉbuŋura,
\q2 ŋunhi ŋayi dhapirrkmirri dhika wal'ŋu,
\q2 ga ŋäŋ'thun ŋarra yurru ŋanya yulŋunydja,
\q2 ŋayi yurru ŋarranha marrtji guŋga'yun dhiyala munatha'ŋura.
\q1 
\v 5 Yo, ŋunhi yurru dhuwala wäŋa marimirriyirrinydja, bathalanydja yurru mari,
\q2 ŋarranydja yurru waṉḏirri ŋunha nhanukala, ḏalwaḏalwa'lili gulŋiyirri,
\q2 ga ŋunhalayina nhanukalanydja ŋurrwu'ŋura ŋayi yurru ŋarranha gunganhamirriyamanydja;
\q1 Ŋayi yurru ŋarranha ḻaw'maramanydja,
\q2 ga ŋunha buku‐warrwarlilina guṉḏalili nherraṉ yurru.
\q1 
\v 6 Ga bitjandhiyina ŋayi yurru ŋarranha märrama walŋakuma ŋuliŋuru miriŋuwalanydja goŋŋuru,
\q2 ga ŋunhalayinydja Godkalanydja Buṉbuŋura ŋarra yurru bathanna mundhurrnha nhanŋu wekama ŋunhiliyi, buku‐ŋal'yunna nhanŋu,
\q2 bitjan ŋarra yurru yatjunna dhika wirrkina, dhä‐warrwarnha yurru miyamandja goŋmirriyirrina;
\q1 Ŋarra yurru miyaman manikaynha wokthunna wal'ŋu Garraywu.
\b
\q1 
\v 7 Garray, ŋäka ŋarranha ŋunhi ŋarra yurru märrliliyamanydja wäthundja nhokala;
\q1 Djäka ŋarraku mel‐wuyurra, ga dhäruk buku‐ruŋinyamaranharawuy wekaŋa.
\q1 
\v 8 Garray, nhe yukurra waŋa bitjan, “Marrtjiya lili galkithiya ŋarrakala, ga buku‐ŋal'yurra ŋarraku.”
\q1 Ga ŋarrakunydja yukurra ŋayaŋu waŋa bitjanna, “Garray, ŋarra yurru marrtjina nhokala galkithirrina,
\q2 yuwalkkumana ŋarra yurru buku‐ŋal'yundja nhuŋu.
\q1 
\v 9 Ŋarranydja ḏukṯuk nhuŋu nhänharawu bukuwu,
\q2 yaka djuḻuḻ'maranharamiya ŋarrakala.”
\q1 Garray, ŋarranydja nhuŋu djämamirri dhuwala,
\q2 yaka ŋarrakala ŋaramurryiyanydja,
\q2 ga yaka ŋarranha buku‐nherrala ga gukuŋa.
\q1 Ŋäthilinydja ŋunhinydja nhe ŋarranha guŋga'yurruna marrtjina.
\q1 Garray, nhenydja ŋarraku walŋakunharamirrina waŋarr,
\q2 yaka ŋarranha gonha'yurra.
\q1 
\v 10 Mak ŋarranha yurru ŋäṉḏi'mirriŋuyu ga bäpa'mirriŋuyunydja ganan,
\q2 yurru nhenydja, Garray, yurru nhepina goŋ‐nherraṉmirri ŋarrakunydja.
\b
\q1 
\v 11 Garray, marŋgikuŋa ŋarranha, märr ŋarra yurru marŋgithirrina wal'ŋu nhokalaŋu romguna,
\q2 ŋurru‐warryurra ŋarranha ŋuliwitjarra nhokalayŋukurru yana dhukarrkurru,
\q2 liŋgu guḻku' mirithirri ŋarraku ŋayan'mirrinydja walala marrtji dhärra.
\q1 
\v 12 Wiripunydja ŋuli walala waŋa bothirri ḻakaranhamirri ŋarranha,
\q2 yana bitjan ŋurru‐waywayyun ŋarranha;
\q2 wirrki yana walala ḏukṯukthirri yukurra ŋarraku galkinyamaranharawunydja.
\q1 Garray, yaka ŋarranha dhayuŋala goŋlili walalaŋgalanydja.
\q1 
\v 13 Ŋarra marŋgi ŋunhi ŋarra yurru nhina yukurra walŋanydja nhokala,
\q2 ga nhäma ŋarra yurru nhuŋu nhä malanha ŋamakurru',
\q2 ga nhepi yurru, Garray, guŋga'yundja marrtji ŋarranha dhiyala munatha'ŋuranydja.
\b
\q1 
\v 14 Märr‐nherraṉmiya walala Garraywala,
\q2 ga dhärriyanydja wuṉḏaŋarrthiya yana,
\q2 ga yakana barrariyanydja;
\q1 Yana galkurra biyaka gatjpu'yurra yukirriya Garraywuna,
\q2 ga yuwalk yana ŋayi yurru guŋga'yundja nhuna.
\c 32
\s1 Milkunharaminyarana Garraywala
\s2 32:1–11 (Confession and forgiveness)
\q1 
\v 1 Yolŋu yurru galŋa‐djulŋithirrinydja yukurra nhina,
\q2 ŋunhi nhanŋu yätjpuynydja dhuwurrwuy liŋguna buwayakkunharana.
\q1 
\v 2 Yo, ŋunhi yurru Garrayyu nhämanydja nhuna, bala ŋayaŋu‐dhunupa ḻakaramana,
\q2 nhenydja dhuwala yolŋu yuwalknha wal'ŋu yurru galŋa‐ŋamathirrina.
\b
\q1 
\v 3 Märr‐yawungunydja ŋarra rom‐yätjthinya,
\q2 bala djuḻuḻ'maranhana ŋarrakuway yätjtja rom;
\q2 yakana ŋarra milkunharaminya ḻakaranhaminya Garraywala.
\q1 Bala ŋarra galŋa‐yätjthinana,
\q2 ŋäthinana yukurrana bitjarrana liŋguna.
\q1 
\v 4 Walu‐ŋupara ga munha‐ŋupara ŋarra dhäkay‐ŋänharaminanydja baṉḏanynha, ganbarknha,
\q2 bitjan ŋuli wäŋa räwakthirri ŋuriŋiyi waluyu.
\q1 
\v 5 Bala ŋarra guyaŋina bitjarra,
\q2 “Yakana ŋarra yurru djuḻuḻ'maramanydja;
\q2 Ḻakaranharamirrina yurru ŋarra Garraywalana ŋarrakuway yätjtja rom.”
\q1 Bala ŋarra wekanhaminana nhokala, Garray,
\q2 bala nhe ŋarraku bäy‐ḻakaraŋalana,
\q2 buwayakkuŋala yätjtja ŋarraku rom.
\b
\q1 
\v 6 Yo. Ŋunhi ŋilimurru yurru galŋa‐yätjthirri ya', ga bitjan buku‐warwumirriyirri,
\q2 ŋilimurrunydja yurru yana bukumirriyamana Garraynha, ḻakaranhamirrina nhanukala;
\q1 Yakana yurru ŋula nhäyu ŋilimurrunha mulkanydja,
\q2 ŋunhi ŋilimurru yurru yukurra djuḻuḻ'yundja nhanukala ŋurrwu'ŋura.
\q1 
\v 7 Garray, nhenydja ŋurrwu ŋarraku,
\q1 ŋarra yurru ŋurrwu'yundja nhokala muka,
\q2 ga walŋakuma nhe ŋuli ŋarranha ŋula nhäŋuru romŋuru.
\q1 Ŋarra yurru miyaman manikay,
\q2 wokthun ŋarra yurru nhuŋu manikaykurru,
\q2 liŋgu nhe ŋuli ŋarraku watjarr‐mulkanydja.
\b
\q1 
\v 8 Garraynydja waŋa yukurra bitjanna,
\q1 “Ŋarra nhuna yurru gäma marrtji bala,
\q2 marŋgikuma marrtji,
\q2 märr yurru nhe marrtjinydja dhukarrkurru dhunupakurru yana.
\q1 
\v 9 Yaka nhenydja ḏalwurthiya, bitjan ŋunha yarraman' ya'.
\q2 Yarraman'tja ŋuli marrtjina‐wala nhanukalay ŋayi ḏukṯukthu,
\q2 bala yana yolŋuyuna ŋuli bilyu'‐bilyunmaramanydja ŋanya raki'yuna,
\q2 märr yurru ŋayi marrtji dhunupakurru dhukarrkurru.
\q1 Yaka nhenydja biyakayi ḏalwurthiya,
\q2 yana nyilŋ'maranhamiya nhepi, ga malthurra marrtjiya nhanŋuway Garraywu ḏukṯukku.”
\b
\q1 
\v 10 Yätjmirrinydja yolŋu'‐yulŋu ŋuli wirrkina warwuyunmirri, galŋa‐yätjthirri manapan.
\q1 Ga ŋunhinydja walala yolŋu'‐yulŋu ŋunhi walala ŋayaŋu‐nherraṉmina Garraywala,
\q2 walalanhanydja yukurra ḻiw'marama monyguma nhanukalay ŋayi märr‐ŋamathinyarayuna.
\b
\q1 
\v 11 Go nhuma ŋayaŋu‐dhunupamirrinydja, ŋayaŋu‐djulŋithiyana,
\q2 märr‐yiŋgathiyana Garraywala go wirrkina;
\q1 Ŋilimurru nhanbalanydja malthumaramirri walala,
\q2 wokthunna nhanŋu ŋayaŋu‐djulŋithinyarayuna,
\q2 märr‐yiŋgathirrina wirrkina go.
\c 34
\s1 God yukurra ḻatju'thirri ŋarrakala
\s2 34:1–22 (Praising God’s goodness)
\q1 
\v 1 Ŋarranydja yurru bitjanna liŋguna buku‐wekama Garraynhana,
\q2 yakana ŋarra yurru gulyundja Garraywala märr‐ŋal'yunaraŋuru.
\q1 
\v 2 Bitjanna bili ŋarra yurru yukurra ḻakarama nhanukalaŋuwuy,
\q2 ŋunhi ŋayi yukurra ḻatju'thirri ŋarrakala.
\b
\q1 Ŋäka walala, nhumanydja ŋuriŋinydja walala yolŋu'‐yulŋuyu, ŋunhi nhuma ṉiṉ'ṉiṉmaranhara, ŋayaŋu‐ŋonuŋmirriyunydja,
\q1 märraŋa ŋarranha dhäruktja, bala ŋoy‐djulŋithiyana.
\q1 
\v 3 Go, ŋilimurru wokthunna Garraywuna yäkuwu,
\q2 waŋgany‐manapanmirrina ŋilimurru go,
\q2 bili ŋayi dhuwala yäku‐ḏumurrunydja, bulunydja‐wala wal'ŋu.
\b
\q1 
\v 4 Ŋarra bukumirriyaŋala waŋana Garraywala,
\q2 bala ŋayi buku‐ruŋiyinmaraŋala ŋarrakunydja;
\q1 Ŋayinydja ŋarranha marrtjina ŋoy‐ḏälkuŋala warray,
\q2 märr ŋarra yurru yakana barrarirri biyapulnydja.
\q1 
\v 5 Way yolŋu walala, bakuruŋa walala ŋanya Garraynha, bala nhäŋana,
\q2 bala yurru nhuŋu ŋayaŋunydja ḻayyunna;
\q1 Yakana nhe yurru ŋaḏi'yundja ŋanya nhäma.
\q1 
\v 6 Ŋunhi nhe ŋuli yukurra nhina gurrupurumirrina yolŋu,
\q2 yana Garraywuna wäthurra,
\q1 bala ŋayinydja yurru nhuna ŋämana, bala yana walŋakuma,
\q2 dhawaṯmarama yurru ŋuliŋuruyi galŋa‐yätjthinyamirriŋuru romŋuru.
\q1 
\v 7 Yo, Garraywala ŋuriŋi djiwarr'wuyyunydja yolŋu'‐yulŋuyu gungamana ŋuli yukurra ŋunhinhanydja yolŋunha ŋunhi ŋayi yukurra Garraywunydja romgu borrk‐beyaṉiyirrina,
\q2 ŋapatjkumana ŋanya yukurra burakinyaraŋuruna, ŋula nhäŋuruna romŋuru.
\b
\q1 
\v 8 Gatjuŋga, nhe yurru maḻŋ'marama nhepi,
\q2 gatjarr'yurra nhe Garraynha;
\q1 Nhe yurru maḻŋ'maramanydja ŋanya, ŋunhi ŋayinydja ḻatju' warray nhuŋu dhika.
\q1 Gärriyana‐wala nhanukala ŋurrwu'lilina.
\q2 bala nhe yurru nhina yukurra ŋoy‐djulŋithirrina, dharray‐djulŋimirriwalana.
\q1 
\v 9 Nhuma ŋunhi walala yolŋu'‐yulŋu ya' Garraywu,
\q2 romgu borrk‐barrariya nhanŋu.
\q1 Ŋayi ŋuli yukurra dharray ŋurikinydja walalaŋgu yolŋu'‐yulŋuwu
\q2 ŋunhi walala ŋuli yukurra malthun nhanŋuway yana dhärukku.
\q1 
\v 10 Wiripunydja ŋuli wäyin walala martj‐martjtjun‐dharra djaṉŋarrmirrina,
\q2 bili walalaŋgu bäyŋuna ŋula ŋatha.
\q1 Yurru ŋunhinydja yolŋu ŋunhi ŋayi yukurra rom‐wiyaṉiyirri Garraywu, ga märrama ŋanya,
\q2 ŋayinydja yakana yurru warrya'yun ŋula nhäku,
\q2 bili ŋanyanydja yurru Garrayyu warray maranhu‐wekama.
\b
\q1 
\v 11 Go, gäthu walala gay', lili marrtjiya.
\q1 Nhuma yuḏayuḏa yolŋu'‐yulŋu, mäkiri'‐witjurra,
\q2 ŋäkana ŋarranha dhäruk;
\q1 Ŋarra yurru nhumalanha marŋgikumanydja,
\q2 märr nhumanydja yurru romgu‐wiyaṉiyirri Garraywu,
\q2 bala malthunna‐wala marrtji nhanŋu Garraywu.
\q1 
\v 12 Ḏukṯukka nhuma yulŋunydja? . . . nhuma yurru galŋa‐djulŋithirri nhina? . . .
\q2 Walŋa weyin? . . . ga buta'kuma nhina?
\q1 
\v 13 Ŋuli nhe ŋamathanharawunydja nhinanharawu ḏukṯuk,
\q2 yaka waŋiya yätj dhäruk,
\q2 ga yaka bothiya ḻakaraŋa.
\q1 
\v 14 Yarrkthurra ŋuliŋuru ŋäṉukkala dhukarrŋuru,
\q2 ga marrtjiya ŋamathaŋa bala, rom‐dhunupayiya.
\q1 Mukthurra nhiniyanydja yukirriya ga ḻunduthiya wiripu‐guḻku'wunydja yolŋu'‐yulŋuwu,
\q2 ga galŋa‐ŋamathiya birrka'mirriwu.
\q1 Yaka marinydja ŋula nhänydja guyaŋiya,
\q2 dharraḏa yana nhiniyanydja yukirriya.
\q1 
\v 15 Liŋgu Garrayyunydja nhäma yukurra ŋunhinha rom‐dhunupanhanydja yolŋunha;
\q2 djäka marrtji yurru nhanŋu.
\q1 Ŋayi yurru Garraynydja mäkiri'‐witjunna nhanŋu ŋunhi ŋayi yurru wäthun Garraywu.
\q1 
\v 16 Yurru ŋurikinydja dhuwurr‐yätjmirriwu yolŋu'‐yulŋuwu ŋayi ŋuli ŋapa‐wekanharamirrina,
\q2 ḻäy‐yarryunna ŋayi yukurra Garraynydja walalaŋgu;
\q1 Walala yurru murrmurryundja,
\q2 ga yäkunydja walalanha yurru meṉgumana walala, buku‐dhumukthirrina.
\b
\q1 
\v 17 Ŋe. Rom‐dhunupanydja yolŋu ŋuli wäthun Garraywu,
\q2 bala Garraynydja ŋuli mäkiri'‐witjunna nhanŋu;
\q1 Dhunupana ŋayi yurru guŋga'yunna‐wala, dhawaṯmaramana ŋanya,
\q2 walŋakumana ŋuliŋuru burakinyamirriŋurunydja romŋuru.
\q1 
\v 18 Ŋunhi nhe yurru ganydjarr‐wiḏi'yundja, ŋayaŋumiriwyirrinydja manapan,
\q1 Garraynydja yurru ŋunhiliyi galki,
\q2 guŋga'yun yurru wuṉḏaŋarrkumayi nhuna.
\b
\q1 
\v 19 Wiripunydja ŋuli rom‐dhunupa yolŋu marilili gärri,
\q2 yana ŋayi yurru Garrayyunydja ḏälkumana ŋanya mulka,
\q2 bala gämana marrtji,
\q2 ga yana liŋgu ga dhawaṯmarama yurru.
\q1 
\v 20 Garraynydja yurru djäka yukurra nhanŋu ŋamathama yana,
\q2 yakana yurru nhanŋu ŋula ŋarakanydja ḏaw'yun.
\q1 
\v 21 Rom‐yätjmirrinydja yolŋu walala yurru rakunydhirrina,
\q2 liŋgu yätjthu romdhu ŋuriŋiyi yurru walalanha buma murrkay'kuma.
\q1 Ga bitjandhi liŋgu Garrayyunydja yurru ŋurrkamana,
\q2 dhä‐ḏir'yunna ŋunhinhanydja yolŋunha ŋunhi ŋayi yukurra ŋaramurryirri rom‐dhunupawu yolŋuwu.
\b
\q1 
\v 22 Yo, Garrayyunydja yurru walŋakumana nhanŋuwaynydja ŋayi ŋunhi yolŋu'‐yulŋunha,
\q2 ŋunhinhanydja walalanha ŋunhi walala yurru gärri nhanukala ŋurrwu'lili;
\q1 ŋunhinydja walala Garraywunydja yolŋu'‐yulŋu yurru yukurra nhina walŋana,
\q2 ŋäkirrmaranharana ŋula nhäŋurunydja.
\c 37
\s1 Nhäyinyarana yurru ŋunhi maḻŋ'thun dhuwurr‐yätjku ga dhuwurr‐ŋamakuli'wu
\s2 37:1–40 (What will happen to the wicked and the good)
\q1 
\v 1 Yaka walala galŋa‐yätjthiya ŋunhi nhe yurru nhäma yätjmirrinha
\q2 ŋunhi yolŋunha walalanha gal'ŋu,
\q2 ŋunhi walala yurru marrtji ḻuŋ'marama ŋula nhä malanha, dhaŋaŋ mirithirri walalaŋguway.
\q1 
\v 2 Galki yurru ŋunhiyinydjayi yätjmirrinydja gal'ŋu yolŋu walala bäyŋuthirrina,
\q2 bitjanna bitjan mulmu ŋunhi ŋayi yurru yana gurriri dhärra,
\q2 bala ŋayi yurru räwakthirrina marrtji rakunydhirrina.
\q1 
\v 3 Yana märr‐yuwalkthiya, märr‐nherraṉmiya Godkala yana,
\q2 ga djäma ŋamathaŋana wal'ŋu,
\q1 bala yurru nhe nhina dhiyalanydja wäŋaŋura goŋmirrina dhikana,
\q2 märr‐walŋathirrina ŋuliŋurunydja yätjŋurunydja romŋuru.
\b
\q1 
\v 4 Yo, djulŋithiyanydja nhanukalay Garraywala yana waŋganygala,
\q2 ga ŋayinydja yurru nhuŋu wekamana ŋunhi nhäku nhe yukurra ŋayaŋu ḏukṯukthirri.
\q1 
\v 5 Yana dhayuŋanna nhe yurru nhuŋuway rom ŋayaŋu‐ŋonuŋdhinyaramirrinydja ŋunhinydja Garraywalana goŋlili wekaŋa,
\q2 ga märr‐nherraṉmiya nhanukalay yana,
\q2 bala ŋayipina yurru djämanydja yukurra, guŋga'yundja nhuna.
\q1 
\v 6 Yo, ŋayipina yurru djämanydja dhika wal'ŋu,
\q2 märr yurru birrka'mirriyu yolŋuyu nhämanydja mälkumana warraŋulkumana wal'ŋu,
\q2 ŋunhi nhenydja ŋunhiyinydja märr‐yunupa yolŋu, yaka ŋula nhä.
\q1 
\v 7 Yana galŋa‐mundurrthiya nhiniya yukirriya Garraywala galki,
\q2 ga galkurra yukirriya ŋayaŋu‐witjunmiya nhanŋuway,
\q2 bala ŋayipina yurru djämanydja marrtji.
\q1 Yaka galŋa‐yätjthiyanydja ŋurikala rom‐yätjkalanydja yolŋuwala,
\q2 ŋunhi ŋayi ŋuli nhina yukurra nhanukalay ŋayi nhäyu malaŋuyu guḻku'yu;
\q1 Ga yaka warwuyurra ŋurikinydja ŋunhi ŋayi yurru dhuwurr‐yätjthu yolŋuyu nherraṉ dhukarr yätj gal'ŋu.
\q1 
\v 8 Yaka nhenydja warwuyurra yukirriya ŋula nhäku,
\q2 ga yakana ŋayaŋu‐yätjthiya ga maḏakarritjthiya,
\q2 yana gonha'yurrana ŋunhiyi ŋaramurrthinyaramirrinydja romnha,
\q1 liŋgu ŋuriŋiyinydjayi romdhu yukurra gäma ŋunhana‐wala marimirrililina romlili.
\q1 
\v 9 Yo, ŋayipinydja Garrayyunydja yurru ŋunhinydja yätjmirrinhanydja yolŋu'‐yulŋunha gukumana‐wala, yarrkthunmarama yurru,
\q1 ga dhuwalanydja wäŋa yurru yukurra dhärra ŋurikina walalaŋgu ŋunhi walala yurru märr‐nherraṉmirri yukurra nhanukala gal'ŋu Garraywala yana.
\b
\q1 
\v 10 Yo, galkina ŋunhinydja yolŋu dhuwurr‐yätjmirrinydja yurru yana winya'yunna‐wala;
\q2 Nhäma'‐nhamanydja nhe yurru yana marrtji dhuwala wäŋanydja,
\q2 yurru yakana ŋayi yurru dhiyalanydjayi ŋunhiyinydja dhuwurr‐yätjtja yolŋu.
\q1 
\v 11 Liŋgu dhuwalanydja wäŋa ŋurikina walalaŋgu wal'ŋu yolŋu'‐yulŋuwu ŋayaŋu‐wurrkurrum'mirriwuna,
\q2 walalana yurru yukurra nhina dhiyalanydja wäŋaŋura goŋmirriyirrinydja,
\q2 märr‐ḏaw'yunna bitjanna yurru nhäyu malaŋuyu ŋamakurru'yunydja.
\b
\q1 
\v 12 Yo, ŋuriŋinydja dhuwurr‐yätjthunydja yolŋuyu ŋuli buku‐nherraṉ ŋaramurryirri ŋurikinydja yolŋuwu dhuwurr‐ŋamakurru'wunydja,
\q2 dhukarrnydja ŋayi ŋuli nherraṉ yana galkinyamaranharawu nhanŋu ŋuriki rom‐dhunupawu yolŋuwu.
\q1 
\v 13 Yurru ŋayipinydja Garraynydja ŋuli ŋunhi beyarrmakthirrina ŋurikalanydja ŋunhi dhuwurr‐yätjkalanydja yolŋuwala,
\q2 liŋgu ŋayinydja marŋgi ŋunhi galki yurru dhuwurr‐yätjtja ŋunhinydja yolŋu baḏuwaḏuyunna warrpam'nha.
\q1 
\v 14 Yo, ŋayinydja ŋunhi dhuwurr‐yätjtja yolŋu yukurra dhärra goŋ‐garamirrina,
\q2 gumurr‐ŋamathirrina ŋurikina yolŋuwu bunharawu murrkay'kunharawu dhuwurr‐ŋamakurru'wuna.
\q1 
\v 15 Ga ŋuriŋiyinydja garayu ŋayipina yurru ŋunhina liŋgu burakirrinydja mar'yunarapuyŋuna,
\q2 ga ŋunhiyi garanydja yurru bakthunna, ḏaw'yunna.
\b
\q1 
\v 16 Mak ŋuli ŋayi ŋuriŋi rom‐dhunupayunydja yolŋuyu ŋayathama yukurra märr‐ḻurrkun' yana girri' malanha,
\q2 ga ŋuriŋiyi märr‐ḻurrkun'thunydja ŋayi yurru yana märr‐ḏaw'yunna.
\q1 Ga ŋayinydja dhuwurr‐yätjthunydja yolŋuyu yukurra ŋayathama be‐warray girri',
\q2 buku‐yattjatthirri warray yukurra nhanŋunydja,
\q2 yurru yakana ŋayi yurru ŋuriŋi märr‐ḏaw'yundja.
\q1 
\v 17 Ḻiŋgu Garrayyunydja ŋayipinydja yurru ŋunhi bak‐bakmaramana ganydjarr ŋurikinydja dhuwurr‐yätjkunydja,
\q2 ga walalana yurru ŋunhi yalŋgi'yirrinydja,
\q1 bala ŋayi yurru gunganhamirriyamanydja ŋunhinayi rom‐ŋamakurru'nhana yolŋunha,
\q2 ganydjarr‐wekamanydja marrtji.
\q1 
\v 18 Garraynydja ŋuli djäka muka marrtji ŋurikinydja yolŋuwu ŋunhi ŋayi ŋuli marrtji nhanukalay yana dhukarrkurru ḏarrtjalkkurru,
\q2 ga ŋunhiyi nhä malanha wekanhara Godkuŋu nhanukuŋuway yurru ŋunhiyinydja ŋuriki dhäruk‐märranharamirriwu yolŋuwu gupaḏalnha‐wala yana.
\q1 
\v 19 Ŋunhi yurru dhuwalanydja wäŋa yukurra dhärra marimirrinydja,
\q2 ga walala yurru rom‐dhunupamirrinydja ŋunhinydja yolŋu'‐yulŋu nhina yukurra ŋamathamana dhikana wal'ŋu;
\q1 Ḻuka walala yurru marrtji ŋatha, ŋunhi yurru ŋayi wäŋa ŋathamiriwyirrinydja.
\q1 
\v 20 Ga walalanydja yurru ŋunhinydja rom‐yätjtja yolŋu walala marrtji murrmurryunna;
\q1 Yo, ŋunhiyinydja walala ŋunhi walala ŋuli ŋurru‐nyinyaŋdhun ga ŋapa‐wekama Godku,
\q2 walalanydja yurru yana wiḏi'‐wiḏiyunna‐wala,
\q2 bitjanna bitjan ŋawulul' ŋunhi ŋuli wiḏi'yun.
\b
\q1 
\v 21 Dhuwurr‐yätjtja ŋunhinydja yolŋu, ŋayinydja ŋuli bitjan warray liŋgu ŋäŋ'thun nhina, rrupiya warray yana gombuma,
\q2 ga yakana ŋayi ŋuli buku‐ruŋinyamarama, bäyim balanydja.
\q1 Ga ŋayinydja ŋunhinydja yolŋu rom‐dhunupanydja, dhapinya warray ŋayinydja,
\q2 yänana ŋayi ŋuli marrtji wekamanydja ŋuriki wiripu‐guḻku'wunydja.
\q1 
\v 22 Liŋgu ŋunhinydja walala ŋunhi walala Godkuŋu goŋmirriyanharawuy,
\q2 walala yurru ŋayathama wäŋa walalaŋguwaynha,
\q1 ga ŋunhinydja yolŋu ŋunhi ŋayi yukurra ŋuyulkthirri Godku,
\q2 ŋayinydja yurru ŋanya yana djuy'yunna‐wala, bena‐wala waṉḏinyamaramana;
\q2 Yakana ŋayi yurru märrama yukurra ŋula nhä nhanukuŋunydja Garraywuŋunydja.
\b
\q1 
\v 23 Yo, ŋayipi Garrayyunydja gäma marrtji ŋurru‐warryun ŋayipi yolŋunhanydja,
\q2 märr yurru ŋayi yukurra marrtji ŋuliwitjandhi ŋamakurru'kurru‐wala dhukarrkurru yana;
\q1 Gunganhamirriyama warray ŋayinydja ŋuli Garrayyunydja ŋunhinydja yolŋu'‐yulŋunha,
\q2 ŋunhi walala ŋuli ŋayaŋu‐djulŋikuma ŋanya.
\q1 
\v 24 Wiripunydja ŋuli yolŋu ŋunhiyi galkirri,
\q2 yurru yaka ŋayi yurru ŋorra yukurra gupaḏalnydja ŋunhiliyi,
\q2 liŋgu ŋayipi Godthunydja yurru ŋanya ŋunhi märrama gaŋgathinyamirriyama, dhärranhamarama nhanukalaynydja ŋayi goŋdhu.
\b
\q1 
\v 25 Yo, ŋarranydja dhuwala worruŋuna ŋarra yolŋu, nhinananydja ŋarra yukurrana weyinŋumirri,
\q2 yurru yaka ŋarra nhäŋala ŋunhi ŋayi Garrayyu gonha'yurrunana dhuwurr‐dhunupanha yolŋunha,
\q2 ga yaka ŋarra yana nhäŋala yumurrku'nha ŋuriki rom‐dhunupamirriwu yolŋu'‐yulŋuwu marrya'wuynydja nhinanhara, ŋäthinyara ŋula ŋathawunydja.
\q1 
\v 26 Liŋgu ŋayinydja ŋuriŋinydja rom‐dhunupayu yolŋuyu bitjan warray liŋgu ŋuli marrtji maranhu‐wekama yana yolŋu'‐yulŋuwunydja,
\q2 ga nhanŋu ŋunhi yumurrkuny'tja nhina yukurra goŋmirriyinana yana walala.
\b
\q1 
\v 27 Yo, gonha'yurrana dhuwali yätjtja rom, ga nhiniya ŋamathaŋana,
\q2 liŋgu ŋuliwitjandhinydjayi gatjaḻkurru nhe yurru nhina ŋunhalanydja Godkalanydja wäŋaŋura gupaḏalnha‐wala yanana.
\q1 
\v 28 Liŋgu Godtja märr‐ŋamathirri yukurra ŋuli nhä ŋunhi ŋamakurru' wal'ŋu ga dhunupa,
\q2 yaka ŋayi yurru ŋapa‐nherraṉmirri nhanukalayŋunydja ŋayi yolŋu'‐yulŋuwu.
\q1 Märr‐yuwalk yurru yana ŋunhinydja yolŋu'‐yulŋu rom‐dhunupamirrinydja nhina yukurra walŋana gunganharaŋurana gupaḏalnha‐wala yanana.
\q1 Ga ŋunhinydja mala‐wunhara rom‐yätjkuŋunydja ŋurikiŋinydja,
\q2 walalanhanydja yurru ŋupanna, bena‐wala yana yarrkmaramana.
\q1 
\v 29 Yo, dhuwalanydja gay' wäŋa yurru yukurra djingaryun ŋurikina yana walalaŋgu rom‐dhunupamirriwuna,
\q2 ga walalana yurru yukurra nhinanydja dhiyalanydja gupaḏalnha‐wala yana.
\b
\q1 
\v 30-31 Yo, rom‐ŋamakurruny'tja yolŋu ŋuli waŋa be dhunupa dhäruk ga djambatj,
\q2 liŋgu ŋayi yukurra ŋayathama rom Godkuŋu ŋunha ŋayaŋuyu nhanukalay,
\q2 ga yakana ŋayi bilyun yurru gatjpaḻ'yun, ga galkirri.
\q1 
\v 32 Ŋayi ŋuli rom‐yätjthunydja yolŋuyu guyaŋirri yukurra,
\q2 wanhawitjan dhukarrkurru ŋayi yurru gatjpaḻ'yunmarama ga buma ŋunhi rom‐ŋamakurru'nha yolŋunha.
\q1 
\v 33 Yurru Garrayyunydja ŋayipinydja yakana yurru ŋanya ganan ŋunhiwalayi miriŋuwalanydja goŋlili.
\q1 Ga ŋuli walala yurru gäma ŋunhi rom‐dhunupanha yolŋunha bala dhä‐wirrka'yunarawunydja,
\q2 yakana walala yurru waŋa yätj‐ḻakaramanydja ŋanya ga dhä‐ḏir'yundja.
\q1 
\v 34 Galkurra yana mukthurra, dhukarr‐nhäŋa yukirriya bulnha Garraywunydja,
\q2 ga dhäruk marrtjiya märraŋa ŋanya Garraynha,
\q1 bala ŋayinydja yurru märr‐ŋal'yunna nhokala, ga wekama wäŋanydja nhokalana goŋlili,
\q2 bala nhe yurru nhämana ŋunhi rom‐yätjmirrinhanydja yolŋunha baḏuwaḏuyunarana.
\b
\q1 
\v 35-36 Yo, nhäŋala ŋarra rom‐yätjnhanydja yolŋunha, ŋayi yukurrana nhinana buŋgawana ŋayi wirrkina wal'ŋu,
\q1 ga yalalaŋumirriyunydja ŋunhi ŋarra ḻarruŋalanydja nhanŋu nhäŋalanydja,
\q2 bäyŋuna ŋarra maḻŋ'maraŋalanydja ŋanya,
\q2 yana ŋayi winya'yurrunana buwayakthinana‐wala.
\b
\q1 
\v 37 Nhäŋa ŋunhi ya' rom‐dhunupanha yolŋunha.
\q1 Nhinanydja ŋayi yukurra ŋayaŋu‐wurrkurrum'thirri yana,
\q2 ga djamarrkuḻi'‐mäypamirri ŋayi ŋunhi yolŋunydja.
\q1 
\v 38 Ga dhuwurr‐yätjmirrinhanydja, ŋayi yurru baḏuwaḏuyunna‐wala warrpam'thunna yana,
\q2 ga bitjandhi liŋgu djamarrkuḻi'nhanydja nhanŋu baḏuwaḏuyundhi yurru‐wala.
\q1 
\v 39 Yo, Garrayyu yurru walŋakumana ŋunhinydja rom‐dhunupamirrinhanydja yolŋu'‐yulŋunha,
\q2 bitjan ŋayi yurru gunganhamirriyama ŋuriŋinydja waluyu marimirriyunydja.
\q1 
\v 40 Ŋayi yurru guŋga'yun warray nhanŋuwaynydja yolŋu'‐yulŋunha,
\q2 ga märrama ŋayi yurru walalanha dhawaṯmarama ŋuliŋuru goŋŋuru miriŋuwalanydja,
\q1 liŋgu walala ŋuli marrtjinydja nhanukalaynha Garraywalana yana ŋurrwu'lilinydja,
\q2 ga ŋayina walalanha yurru yukurra gunganhamirriyamanydja.
\c 40
\s1 Manikay ḻakarama yukurra wokthunarawuynha
\s2 40:1–11 (A song of praise)
\q1 
\v 1 Yo, ŋarra galkurrunanydja yukurrana ŋayaŋuyunydja wurrkurrum'thu,
\q2 bukumirriyaŋala bitjarra marrtjina Garraywala,
\q2 ga ŋayi ŋäkulanydja ŋarranha, bala yana guŋga'yurrunana.
\q1 
\v 2 Bitjarra ŋayi waṉa‐djarryurruna märraŋala ŋarranha,
\q2 bala warryurrunana ŋuliŋurunydja ŋunhi ŋarra yukurrana ŋorrana balanyaraŋura bitjan dhoḻu ŋunhi wäŋa.
\q1 Yo, dhawaṯmaraŋalanydja ŋayi ŋarranha warryurruna ḻaw'maraŋalanydja,
\q2 bala nherrara ŋunhana guṉḏalilina gal'ŋu,
\q2 bala ŋarra dhuwala dhärranydja yukurra walŋana, ŋayaŋu‐walŋana ŋarra.
\q1 
\v 3 Ga biyapul ŋayi wekaŋala ŋarraku manikay yuṯana gal'ŋu dhikana,
\q2 ŋuriŋiyi manikayyunydja ŋarra yukurra wokthunna nhanŋu ŋilimurruŋgalaŋuwu Garraywuna.
\q1 Yo, bukmakthuna yurru ŋunhi nhämanydja,
\q2 bala rom‐wiyaṉiyirrina yurru walala Garraywunydja,
\q2 bala ŋayaŋu‐nherraṉmirrina yurru nhanukala.
\q1 
\v 4 Yo, ŋayipi yurru Godthunydja goŋmirriyamana ŋunhinhanydja yolŋunha ŋunhi ŋayi ŋuli ŋayaŋu‐nherraṉmirri gal'ŋu nhanukala,
\q2 ga ŋunhinhanydja ŋunhi ŋayi yurru yaka malthun yukurra ŋuriki walalaŋgu ŋunhi walala ŋuli ŋapa‐nherraṉmirri Godku,
\q2 ga yaka ŋuli ŋayi waŋgany‐manapanmirri gal'ŋu ŋurikala yolŋu'‐yulŋuwala ŋunhi walala ŋuli buku‐ŋal'yun yukurra wiripuŋuwu waŋarrwu;
\q1 Ŋayi yurru ŋunhiyinydjayi yolŋu nhina yukurra goŋmirriyirrina dhikana djulŋithirrina.
\b
\q1 
\v 5 Gunhu' Waŋarr, nhenydja ŋunhi djäma mirithirri manymak gal'ŋu yana rom malanha ŋanapurruŋgu,
\q2 ga yakana ŋula waŋgany waŋarr balanyara biyaka ŋuli nhe.
\q1 Bitjan warray liŋgu nhenydja ŋuli gurrunhan ŋamakurru' warray yana dhukarr ŋanapurruŋgunydja,
\q2 nhepina yana waŋganynha wal'ŋu ŋamakurruny'tja dhikanydja Waŋarr.
\q1 
\v 6 Yaka nhenydja ḏukṯuk ŋurikinydja, ŋunhi ŋarra yurru gäma nhuŋu mundhurr‐wekama ŋula wäyinnhanydja bathanarawu ŋunhi barŋlilinydja,
\q2 yakana yana nhe ŋuli bäy‐ḻakarama ŋurikinydja ŋunhi ŋarra ŋuli wekama nhuŋu ŋula nhä;
\q1 Yana nhenydja ŋunhi mäkiri'na ḻapmaraŋala ŋarraku,
\q2 märr yurru ŋarra ŋäma nhunapinyay dhäruk.
\q1 
\v 7 Bala ŋarra mäkiri'‐witjurrunanydja ga ŋäkulana yana,
\q2 ga waŋana bitjarrana nhokala, “Garray, dhuwalana ŋarranydja.
\q1 
\v 8 Nhokala ŋuriŋi djorra'yunydja ḻakarama yukurra ŋarranhanydja,
\q2 ŋunhi ŋarra ŋuli ŋayaŋu‐djulŋithirri nhokalayŋuwu yana djälwunydja malthunarawu;
\q1 Nhepi yana ŋarraku Godtja,
\q2 ga ŋayathamanydja ŋarra yukurra baṯ bitjan nhuŋuway yana romdja ŋarrakalay ŋayaŋuyunydja.”
\b
\q1 
\v 9 Yo, liŋguna ŋarra Garray waŋananydja ḻakaraŋalanydja marrtjina yolŋu'‐yulŋuwanydja,
\q2 ŋuripanydja ŋunhi walala ŋuli ḻuŋ'maranharamirri waŋgany‐manapanmirri nhuŋu yolŋu'‐yulŋu,
\q2 ŋarra ḻakaraŋalanydja bitjarra ŋunhi nhenydja walŋakunharamirri ŋanapurruŋgu.
\q1 Garray, nhenydja marŋgi muka ŋarrakunydja,
\q2 ŋunhi ŋarra yurru yaka ḏaḏawyundja ḻakaranharaŋuru ŋuliŋuruyi manymakŋurunydja dhäwu'ŋuru.
\q1 
\v 10 Yaka yana ŋarra ŋuli djuḻuḻ'maramanydja ŋarrakuwaynydja ŋarra ŋayaŋuyu,
\q2 bitjan bili yana ŋarra ŋuli ḻakaramanydja marrtji nhokalaŋuwuy, ŋunhi nhenydja God märr‐yuwalkthinyaramirri,
\q2 ŋunhi nhenydja yurru bitjan warray liŋgu walŋakuma yukurra ŋanapurrunha.
\q1 Yo, ŋunhi walala ŋuli yolŋunydja walala marrtji waŋgany‐manapanmirrinydja,
\q2 ŋarranydja ŋuli yana ḻakaramana walalaŋgu warraŋulkumana nhuna,
\q2 ŋunhi nhenydja yuwalk yana gal'ŋu märryu‐ḏapmarama yukurra ŋanapurrunha.
\q1 
\v 11 Garray, ŋarra marŋgi nhuŋu yolŋunydja, ŋunhi nhenydja yurru bitjan warray liŋgu maŋutji‐wuyunaramirri ŋarraku,
\q2 bitjan liŋgu yana nhe yurru yukurra gämanydja ŋarranha nhokalay nhe märr‐ŋamathinyarayunydja,
\q2 bitjan gunganharamirriyamana ŋarranha nhäŋuru yätjŋurunydja.
\c 42
\s1 Godku ŋar'ŋaryun
\s2 42:1–5 (Thirsting for God)
\q1 
\v 1 Gunhu' Waŋarr. Ŋarra yukurra dhuwala ŋanhdharkthirrina;
\q1 Ŋarranydja nhuŋu ḏukṯukthirri yukurra wirrkina,
\q2 bitjan ŋuli wäyin ḏukṯukthirri gapuwu, wirrkina ŋar'ŋaryun.
\q1 
\v 2 Ŋarraku ŋayaŋunydja yukurra ŋanhdharkthirrina, baṉḏanynha.
\q1 Nhepina dhuwala walŋa‐ḏikṯiktja waŋarr,
\q2 nhuŋunydja ŋarra yukurra ḏukṯukthirri wirrkina.
\q1 Nhäthana ŋarra yurru balanydja marrtji?
\q2 Wirrki yana ŋarra ḏukṯukthirri yukurra nhänharawu bukuwunydja nhuŋu,
\q2 ga buku‐ŋal'yunarawunydja nhuŋu yana.
\q1 
\v 3 Bitjanna liŋguna ŋarra ŋuli ŋäthinydja marrtji, munha‐ŋupan ga walu‐ŋupan,
\q2 liŋgu bitjanna liŋgu walala ŋuli miriŋuyunydja waŋa marrtji ŋarranha,
\q2 “Wanhaka be nhuŋu Waŋarrnydja?” bitjanna ŋuli.
\b
\q1 
\v 4 Roŋiyirri ŋarra ŋuli guyaŋirri ŋurikiy ŋäthiliŋuwuy,
\q2 bala ŋarraku ŋuli ŋayaŋunydja yätjthirrina.
\q1 Yo, marrtjinya ŋarra ŋuli Buṉbulili Dhuyulili, rrambaŋi wiripu‐guḻku'wala miṯtjiwala;
\q2 marrtjinya ŋarra ŋuli, ŋurru‐warryuna yolŋunha miṯtjinha;
\q1 Rrambaŋi ŋanapurru ŋuli marrtjinya Godkalanydja Buṉbulili,
\q2 bala ŋanapurru ŋuli miyamana manikay, märr‐yiŋgathinya rrambaŋi,
\q2 wokthuna ŋuli yukurranha Garraywu.
\b
\q1 
\v 5 Nhäku ŋarra yukurra dhuwala galŋa‐yätjthirrinydja?
\q2 Nhäku ŋarra warwuyundja yukurra?
\q1 Ŋarra yurru yana märr‐nherraṉmirri Garraywalana,
\q2 gatjpu'yun yukurra galkunna nhanŋu;
\q1 Ŋarra yurru biyapul wokthun yukurra Garraywunydja,
\q2 bili ŋayi ŋarraku Walŋakunharamirrinydja ga Waŋarr Godtja,
\q2 nhanukalaynha yana ŋarra yurru ŋayaŋu‐nherraṉmirrinydja.
\c 46
\s1 Godtja ŋilimurruŋgala galki yana
\s2 46:1–11 (God is with us)
\q1 
\v 1 Yo, Godtja dhuwala ŋilimurruŋgu ŋayi ŋurrwu,
\q2 ga wekamanydja ŋayi ŋuli ganydjarr ŋilimurrunha.
\q1 Bitjan liŋgu yana ŋayi ŋuli galki ŋilimurruŋgala yulŋunydja,
\q2 girri'‐ŋamathirri yukurra guŋga'yunarawuna ŋilimurruŋgu ŋunhi ŋilimurru ŋuli marililinydja gärri.
\q1 
\v 2 Ga dhiyakuyinayi märrwu ŋilimurru yurru yakana barrarirrinydja ŋula nhäku,
\q2 bäyyi ŋunhi yurru dhuwala munathany'tja wäŋa marrmarryun,
\q2 ga buku yurru ŋunha wäŋa buku‐yupthun ŋunhana‐wala gapulili moṉuklilina.
\q1 
\v 3 Wiripunydja ŋuli ŋayi gapu ŋunha ŋoy‐ḻaw'yun gaŋgathirri wal'ŋu,
\q2 ga rirrakaymirriyirrina biyapulnha gal'ŋu, bathalana rirrakay,
\q2 ga ŋunha buku wäŋa yurru marrmarryunna,
\q1 yurru yakana ŋilimurrunydja yurru barrarirri.
\q1 
\v 4 Yo, ŋunha gapunydja yukurra mayaŋ'tja waṉḏirri beŋuruyi Godkala,
\q2 ga wäŋa ŋunhi Godkunydja walŋa yana yukurra djingaryun ŋuriŋiyinydjayi gapuyu.
\q1 
\v 5 Yo, God ŋunhiliminydjayi wäŋaŋura,
\q2 ga yakana yurru ŋayi ŋunhiyi wäŋa baḏuwaḏuyundja ŋula nhäyu;
\q1 Waḏutja yana Godthunydja yurru ŋunhiyinha wäŋanha guŋga'yun nhanŋuwaynydja ŋayi.
\q1 
\v 6 Ŋunha wiripunydja miṯtji yolŋu walala yukurra barrarirrina wirrkina yana wal'ŋu,
\q2 liŋgu Godthunydja yukurra rur'ruryunna ŋunhiyi,
\q2 bala burruḻ'yunna walalanydja yukurra;
\q1 Rirrakayyunydja wakindhu yana ŋayi yurru waŋanydja dhika wal'ŋu,
\q2 bala dhuwala munathany'tja yurru wäŋa winya'yunna‐wala yana buwayakthirrina.
\q1 
\v 7 Ŋayinydja ŋunhinydja God ganydjarr‐ḏumurrunydja wal'ŋu dhika ŋilimurruŋgala dhiyala,
\q2 dhika bäyma ŋayi galki yana.
\q1 Yo, ŋayinydja ŋunhi \f + \fr 46:7 \ft Jacob\f*Djaykupkunydja God, bitjan ŋilimurruŋgu ŋayi ŋurrwu'na.
\b
\q1 
\v 8 Go marrtjiyana lili, ga nhäŋana ŋunha Godkuŋu djämawuynydja,
\q2 nhä ŋayi yukurra djäma bukmakkurru wäŋakurru buku‐ḻiw'marama.
\q1 
\v 9 Ŋunha miṯtji ga miṯtji yukurra bunharamirri bala‐lili'yunmirri,
\q2 yurru ŋayipinydja Godthunydja yurru ŋunhiyi gulmaramana, ḏaḏawmaramana marina;
\q1 Ḏaw'‐ḏawyunna ŋayi yurru garanydja malanha walalaŋgu,
\q2 bala nhäranhamaramana ŋayi yurru ŋunhi gunganharamirrinydja girri'.
\b
\q1 
\v 10 Yo, biyaka nhiniya galŋa‐mundurrthiyana wurrkurrum'thiyana,
\q2 ga marŋgithiyana biyakana ŋarraku, ŋunhi ŋarranydja dhuwala God.
\q1 Yo, bukmakthu yurru yolŋuyunydja walalay bäpurru'yu ga bäpurru'yu buku‐ḻiw'marama nhäma dharaŋanna ŋarranha,
\q2 ŋunhi ŋarranydja dhuwala God garrwar wal'ŋu be‐wala birr;
\q1 Bukmakthu yolŋuyu walalay buku‐ḻiw'marama wäŋakurru ŋarranha yurru ḻakaramanydja garrwar‐ḻakaramana.
\q1 
\v 11 Yo, Garray Godtja ŋunhi ganydjarr‐ḏumurrunydja wal'ŋu ŋilimurruŋgala galki yana ŋayi,
\q2 ga ŋayinydja ŋunhi bitjan ŋilimurruŋgu ŋayi ŋurrwu'na.
\c 47
\s1 Garray ŋurruŋu buŋgawa bukmakku bäpurru'wu
\s2 47:1–9 (God is the Supreme Ruler)
\q1 
\v 1 Go walala yolŋu'‐yulŋu, goŋ‐ḻurr'‐ḻurryurrana walala,
\q2 märr‐yiŋgathiyana, ga manikaynha miyamala go!
\q2 Wokthurrana wirrkina yana rirrakaynydja buku‐warrwarthiyana.
\q1 
\v 2 Liŋgu Garray warray biyapulnydja‐wala wal'ŋu garrwarnydja,
\q2 ŋilimurru borrk‐beyaṉiyirri nhanŋu;
\q1 Ŋayi dhuwala buŋgawa ŋurruŋunydja,
\q1 ga bukmak dhuwala wäŋa nhanukala yukurra goŋŋura djingaryun.
\q1 
\v 3 Wiripu bäpurru' yolŋu miriŋuyina ŋilimurruŋgu,
\q2 yurru ŋilimurrunydja djuḻkmaraŋala walalanha Garraywalana ŋuriŋi ganydjarryu,
\q2 bala ŋayi nherrara dharraylili walalanhanydja ŋilimurruŋgalana.
\q1 
\v 4 Ŋayi djarr'yurruna ŋilimurruŋgu wäŋa nhinanharawu,
\q2 liŋgu wirrkina ŋayi yukurra märryu‐ḏapthunmarama ŋilimurrunha.
\b
\q1 
\v 5 Godtja dhuwala liŋguna ŋurruŋuyina buŋgawayina,
\q2 ŋunha ŋayi nhinanydja yukurra djiwarr'ŋurana,
\q1 ga yolŋunydja walala girrirriyunna yukurra yiŋgathirrina,
\q2 wokthunna nhanŋu bena buku‐warrwaryuna rirrakayyu.
\b
\q1 
\v 6 Go ŋilimurrunydja miyamanna, wokthundhi nhanŋu,
\q2 wokthunna ŋilimurru go ŋilimurruŋgalaŋuwu Garraywu Godkunydja,
\q2 liŋgu ŋayi ŋilimurruŋgu buŋgawa.
\q1 
\v 7 Yo, Gunhu' Waŋarrnydja buŋgawana bukmakku wäŋawu buku‐ḻiw'marama yana.
\q2 Wokthunna go nhanŋu,
\q2 manikaynha miyaman wokthunna manapan.
\b
\q1 
\v 8 Yo, Gunhuny'tja ŋunha nhina yukurra nhanukalay wäŋaŋura djiwarr'ŋurana,
\q2 ŋayathama ŋayi yukurra yolŋu'‐yulŋunha bukmaknha, bäpurru'nha ga bäpurru'nha.
\q1 
\v 9 Mulku'‐mulkurunydja yolŋu walala marrtjina yurrum'thurrunana waŋgany‐manapanminana ŋanapurruŋgala,
\q2 waŋganyŋura ŋilimurru yukurra buku‐ŋal'yundja Garraywu;
\q1 Ga mariwuynydja girri' ŋunhinydja goŋŋuru yupthurrunana,
\q2 liŋgu ŋayi Gunhu' Waŋarr buŋgawa ŋurruŋunydja bukmakku bäpurru'wu,
\q2 bukmak dhuwala yolŋu'‐yulŋu nhanukala waŋganygala yukurra djingaryun goŋŋura.
\c 49
\s1 Yakana yurru yolŋu walŋathirri be nhäyunydja nhanukalay ŋayi
\s2 49:1–20 (You can’t be saved by your own riches)
\q1 
\v 1 Yo nhuma yolŋu walala bukmak bäpurru', ŋäka walala,
\q2 mäkiri'‐witjurra nhuma yolŋu walala birrka'mirriŋura buku‐ḻiw'marama.
\q1 
\v 2 Nhuma ŋunhi be gal'ŋu wakinmirri bathalamirri, ga yumurrku',
\q2 ga nhuma ḻukunydjamirri ga ŋurruwuykmirri,
\q2 mäkiri'‐witjurra walala rrambaŋithiya.
\q1 
\v 3-4 Ŋarranydja yurru waŋa dhärukthu ḻiya‐djambatjthu warray,
\q2 ga ḻakaramanydja ŋarra yurru warraŋulkuma yana maḻŋ'marama,
\q2 märr yurru nhenydja dharaŋan ŋunhi mayaliny'tja.
\b
\q1 
\v 5 Yakana ŋarra yurru barrarirrinydja ŋunhi yurru wäŋa marimirrinydja yukurra dhärra,
\q2 ŋunhi ŋayi yurru miriŋu marrtji ga ḻiw'marama ŋarranha.
\q1 
\v 6 Yo, ŋunhiyi dhuwurr‐yätjmirri yolŋu walala ŋuli ŋurr'yunmirri waŋanharamirri walalanhawuy walala,
\q2 yanapi ŋayi yurru ŋuriŋiyinydja ḻukunydjathinyarayunydja walalanha walŋakuma.
\q1 
\v 7 Yolŋunydja yurru yakana dhawaṯmaranharamirri ŋanyapinyay ŋayi ŋuliŋurunydja goŋŋuru ŋula yolkalanydja ŋuriŋi nhanukalay ŋayi be rrupiyayunydja.
\q1 Nhä dhika ŋayi yurru ŋuriŋi yolŋuyu wekama Godkunydja nhanŋunydja,
\q2 märr yurru ŋayi yukurra nhina walŋanydja?
\q1 
\v 8-9 Bäythi ŋayi ŋunhi be ḻukunydja wal'ŋu mirithirrinydja,
\q2 yurru yaka ŋunhiyi ganany'tja, märr yurru ŋayi ŋuriŋiyi bäyim walŋana,
\q2 märr yurru ŋayi yukurra nhina weyinŋumirri be wal'ŋu, ga yakana yurru rakunydhirrinydja.
\b
\q1 
\v 10 Yo, bukmak yurru dhuwala yolŋunydja walala murrmurryun,
\q2 ŋunhiyi ḻiya‐djambatj gal'ŋu yolŋu, ga ŋunhi bawa'mirri yolŋu, ḻiya‐dhumuk ŋunhi,
\q2 märrma'yirrina walala yurru ŋunhi buwayakthirrinydja winya'yundja‐wala;
\q1 Bukmaknha yurru yana gonha'yun nhä walala yukurra ŋayathama ŋuli,
\q2 ga ŋuriŋina walalaŋgala yumurrku'yuna yurru yukurra märramanydja ŋunhi rrupiyanydja dhika nhänydja malanha.
\q1 
\v 11 Ga ŋunhiyinydja walala walalawuynydja yurru ŋorra marrtji moluŋurana,
\q2 ga ŋunhiyina bili yurru wäŋanydja walalaŋgu moluna yana gupaḏalŋuwuna nhinanharawu,
\q2 bäyyi ŋunhi walala ŋuli waŋanha marrtjinya wäŋanha ḻakaranha walalaŋguway.
\q1 
\v 12 Yo, bäyyi ŋayi ŋunhi yolŋu garrwar wal'ŋu be ŋayi bathala,
\q2 ŋunhiyinydjayi yolŋu yana ŋayi yurru rakunydhirrina‐wala,
\q2 bitjanna bitjan wäyin ŋuli ŋunhi rakunydhirri;
\q1 yakana ŋanya yurru walŋakuma ŋuriŋinydja be nhäyunydja malaŋuyu ŋunhi ŋayi yukurra ŋayathama.
\b
\q1 
\v 13 Yo, yolŋunydja walala ŋuli yukurra märr‐ḏaw'yun ŋuriŋina be walalaŋgalay nhäyuna malaŋuyu.
\q1 Walala ŋuli guyaŋirri yanapi walala yurru ŋuriŋiyinydjayi nhina yukurra walŋana,
\q2 yurru yaka warray;
\q1 
\v 14 Walala yurru yana murrmurryunna bitjanna bitjan wäyin ŋunhi bembi,
\q2 ga ŋunhina bili yäkunydja Rakunynha yurru bitjan djäkamirrinydja walalaŋgu.
\q1 Dhunupana yana yurru walalaŋgu rumbalnydja ŋunhi winya'yunna‐wala yana ŋunhana moluŋurana,
\q2 buwayakthirrina yurru,
\q1 ga gupaḏalnha‐wala yanana ŋunhiyi walala yolŋunydja walala yurru yukurra nhina ŋunhilimina wäŋaŋura rakunymirriwalana.
\q1 
\v 15 Yurru Godthu warray ŋayipi yurru ŋarranhanydja walŋakuma,
\q2 ŋayi yurru ŋarranha märrama dhawaṯmarama warray ŋuliŋurunydja romŋuru rakunydhinyaramirriŋurunydja,
\q2 ga märramana‐wala yana ŋarranha yurru nhanukalaynha wäŋalili ŋunhana.
\b
\q1 
\v 16 Yaka biyaka ŋayaŋu‐yätjthiyanydja ŋunhi ŋayi ŋuli yukurra yolŋu nhina ḻukunydja gal'ŋu,
\q2 ga bäyyi ŋunhi nhanŋu nhä malanha ŋayi ŋuli marrtji bukulili ŋal'‐ŋalmarama buku‐yattjatkuma.
\q1 
\v 17 Ŋunhi ŋayi yurru ŋunhiyi yolŋu rakunydhirrinydja, yakana ŋayi yurru ŋunhi djaw'yun galkinydja,
\q2 dhäparknha ŋayi yurru goŋnha yana marrtji ŋunhiwalanydja wäŋalili rakunydhinyaramirrililinydja.
\q1 
\v 18 Yo, ŋayaŋu‐djulŋithinya ŋayi ŋuli nhinanha be dhiyalanydja munatha'ŋuranydja,
\q2 ga yolŋunydja walala ŋanya ŋuli ḻakaranha goŋmirri‐ḻakaranhana, wokthunana nhanŋu,
\q2 yanapi ŋayi be wal'ŋu bathala yolŋu.
\q1 
\v 19 Yurru rakunydhirrinydja ŋayi yurru ŋunhi yolŋunydja,
\q2 ga ŋunhilina rakunymirriwalana wäŋaŋura ŋayi yurru nhinanydja yukurra ŋurruk‐manapanmirri märi'muwalana walalaŋgala dhambay,
\q2 yakana biyapulnydja walala yurru djarraṯawun'tja nhäma.
\b
\q1 
\v 20 Yo, bäyyi ŋayi ŋunhi yolŋu garrwar wal'ŋu be mirithirri,
\q2 yanana ŋayi yurru rakunydhirrina‐wala bitjanna bitjan wäyin ŋuli ŋunhi rakunydhirri;
\q1 yakana ŋanya yurru walŋakuma ŋuriŋinydja be nhäyunydja ŋunhi ŋayi yukurra ŋayathama.
\c 51
\s1 Bukumirriyaŋa bäy‐ḻakaranharawu
\s2 51:1–17 (A prayer for forgiveness)
\q1 
\v 1 Garray God Waŋarr, maŋutji‐wuyurra ŋarraku, nhuŋunydja ŋayaŋu‐ŋamathinyara yuwalk warray, weyinŋumirri warray,
\q2 wuyurra ŋarraku, ga buwayakkuŋana ŋarrakuŋu yätjtja.
\q1 
\v 2 Garray rurrwuyurrana ŋarranha ḏarrtjalkkuŋana,
\q2 baḏuwaḏuyurrana ŋarraku yätjtja dhuwurr.
\q1 
\v 3 Ŋarra dhuwala dhuwurr‐yätj yolŋu,
\q2 yurru yakana ŋarra yukurra djuḻuḻ'marama meṉguma ŋarrakuŋu yätjtja dhuwurr;
\q1 Bitjanna liŋguna ŋarra ŋuli yukurra guyaŋirri, bitjan wuyunna ŋarrakalayŋu ŋarra yätjkuna.
\q1 
\v 4 Nhunapinyay, Garray, ŋarra ŋayaŋu‐yätjkuŋala,
\q2 liŋgu ŋarra ḏaw'yurruna nhuŋu rom.
\q1 Dhunupa warray nhuŋu yulŋunydja, ŋunhi nhe ŋarranha rom‐nyamir'yurrunanydja, murr'yunmaraŋalanydja manapara;
\q1 
\v 5 Yuwalknha ŋarra dhuwala yätjtja ḏarramu.
\q1 Yo, beŋuru liŋgu ya' ŋunhi ŋarra ŋäṉḏi'mirriŋuwala guḻunŋura,
\q2 ga yana liŋgu dhawal‐wuyaŋina ŋarra dhuwurr‐yätj yana.
\b
\q1 
\v 6 Garray, nhe ḏukṯuk ŋarraku, ŋarra yurru nhina yukurra ŋayaŋunydja‐ḏarrtjalk,
\q2 garrkuḻuk nhenydja yana, ga yuwalkŋu wal'ŋu.
\q1 Guryunmaraŋa ŋarrakala ḻiyalili ḏarrtjalk ga dhunupa guyaŋinyara.
\q1 
\v 7 Rurrwuyurrana nhe ŋarranha Garray, garrkuḻukkuŋana,
\q2 bala ŋarra yurru garrkuḻukthirrina.
\q1 
\v 8 Liŋguna nhe ŋarranha muŋdhurrunanydja yukurrana, buḻwaŋ'maraŋalanydja,
\q2 dhä‐ḏir'yurruna yätjŋuru ŋarranha.
\q1 Garray God, ŋayaŋu‐ŋamathaŋana ŋarranha,
\q2 märr ŋarra yurru biyapul ŋayaŋu‐ŋamathirriyi.
\q1 
\v 9 Maŋutjinydja nhe dhaḻ'yunmiya, Garray,
\q2 ga yaka weyin nhäŋa ŋarraku yätjtja dhuwurr;
\q2 Rurrwuyurrana yana biḏiwiḏitjkuŋana ŋarrakala yätjtja dhuwurr.
\b
\q1 
\v 10 God, yuṯakuŋana ŋarranha ŋayaŋunydja,
\q2 wirrkina garrkuḻukkuŋa, ḻatju'kuŋana wal'ŋu;
\q1 Nherrala yuṯana wal'ŋu birrimbirr ŋunha ŋarrakala ŋayaŋulili.
\q1 
\v 11 Yakana ŋarranha ḏupthurra nhokiyingala goŋŋurunydja,
\q2 yaka djaw'yurra Walŋanha ŋunhi Birrimbirrnha ŋarrakala.
\q1 
\v 12 Ŋäthilinydja ŋunhi nhe walŋakuŋala ŋarranha ya',
\q2 ŋarra ŋulinyaramirriyunydja wirrkina ŋayaŋu‐djulŋithina.
\q1 Garray, wekaŋana lili roŋinyamaraŋana ŋarranha ŋunhiyi yana liŋgu ŋayaŋu‐djulŋithinyara;
\q2 Mulkiya ŋarranha, Garray, märr yurru ŋarra bitjan liŋgu dhäruk‐märranharamirri nhuŋu yulŋunydja.
\q1 
\v 13 Bala ŋarra yurru marŋgikuma ŋunha yätjmirrinhana yolŋu'‐yulŋunha,
\q2 walala yurru marŋgithirri nhokalaŋuwu romgu,
\q2 bala roŋiyirri liliyi yurru nhokala.
\b
\q1 
\v 14 Garray God, nhenydja ŋarraku walŋakunharamirri.
\q1 Walŋakuŋana ŋarranha go, dhawaṯmaraŋana rakunyŋurunydja romŋuru,
\q2 bala ŋarra yurru dhäwuny'tja barrkuwatjkumana ḻakarama nhokalaŋuwuy,
\q2 ŋunhi warray ŋunhi nhenydja ŋuli djäma rom‐dhunupa yana.
\q1 
\v 15 Guŋga'yurrana ŋarranha, bala dhäruk wekaŋana ŋarraku,
\q2 bala ŋarra yurru nhuŋu wokthunna waŋana dhiyaŋu ŋarrakalay dhärukthuna.
\q1 
\v 16 Ŋuli nhe bini ḏukṯukthinya ŋanapurruŋgu yolŋu'‐yulŋuwu,
\q2 ŋanapurru bini bunha wäyin murrkay'kunha, mundhurr‐wekanharawu nhuŋu,
\q2 bala ŋarra bini gänhanydja nhuŋuna Garray,
\q1 yurru nhenydja yaka warray bini ŋayaŋu‐djulŋithinya ŋuriŋiyi mundhurr‐wekanharayu.
\q1 
\v 17 Nhenydja yukurra ḏukṯukthirri ŋarrakuway,
\q2 ŋarra yurru yana ŋarrapi nyilŋ'maranharamirri ŋarranhawuy ŋarra,
\q2 bala wekanharamirrina nhokala,
\q2 bala yana wuyunmirrina ŋurikiy yätjpuy ŋunhi yukurra ŋorra ŋunha ŋayaŋuŋura ŋarrakala.
\q1 Yo, ŋunhi ŋarraku yurru ŋayaŋu wuyunmirrinydja,
\q2 bala gonha'yunna yätjtja, ŋapa‐wekamana yurru ŋurikiyinydja,
\q2 ga yakana nhe ŋuli ŋarranha ŋurrkamanydja.
\c 63
\s1 Märryu‐ŋupan Garraynha
\s2 63:1–11 (Longing for God)
\q1 
\v 1 God Waŋarr, Waŋarr ŋarraku, nhuŋuwaynha ŋarra yukurra warrya'yun dhika bukmakthunydja ŋayaŋuyu ŋarrakalay;
\q2 Nhuŋunydja ŋarra yukurra ḏukṯukthirri wirrkina dhika wal'ŋu.
\q1 Ŋayaŋunydja ŋarra dhika yukurra baṉḏanydhirrina,
\q2 bitjan ŋuli wäŋa ŋula gapumiriw;
\q1 ŋayaŋu‐ŋanhdharkthirrina ŋarra yukurra nhinanydja ŋuli nhuŋu.
\q1 
\v 2 Ŋarranydja ḏukṯuk ŋarra yurru nhäma nhuna, Garray, dhiyali nhokala wäŋaŋura,
\q2 liŋgu nhenydja dhuwala ganydjarr‐ḏumurru, ga ḻatju' wal'ŋu dhika.
\q1 
\v 3 Yo, manymaknha ŋunhi nhinanharawu, ŋarra yurru nhina walŋanydja,
\q2 yurru bulunydja wal'ŋu ḻatju' nhokalana ŋarra ŋuli nhina märr‐ŋamathinyaraŋura.
\q1 
\v 4 Bala ŋarra nhuŋu wokthunna yukurra yurru,
\q1 bitjanna liŋgu weyinŋumirrina ŋarra yurru buku‐wekamanydja nhuŋu,
\q2 yakana yurru ḏaḏawyun;
\q1 Goŋdja ŋarra yurru garrwarthirri yana, wokthunna yukurra nhuŋu bukumirriyamanydja manapan.
\q1 
\v 5 Yo, ŋarrakala ŋayaŋuyunydja bitjanna liŋgu ŋuli yukurra ḻukana maranhukunharamirrina,
\q2 yurru ŋuriŋina bili nhokalay märr‐ŋamathinyarayunydja ŋayaŋu‐ḏaw'yun;
\q1 Manikaynha ŋarra yurru yukurra miyaman, goŋmirriyirrina dhika wal'ŋu,
\q2 wokthunna yurru nhuŋu, Garray God.
\b
\q1 
\v 6 Wiripunydja ŋarra ŋuli ŋorra nhina, bira'yun ŋuli ya',
\q2 bala ŋarra ŋuli guyaŋirrina nhina,
\q2 märryu‐ŋupan nhuna ŋuli munha‐ŋupan.
\q1 
\v 7 Liŋgu bitjanna liŋgu nhepiŋga yana ŋarraku ŋuli djäkanydja,
\q2 guŋga'yundja ŋuli ŋarranha;
\q1 Ŋoy‐djulŋithirrina ŋarra ŋuli nhina nhokala djäkaŋura,
\q2 bitjanna bitjan ŋuli yothu wäyin ŋäṉḏi'mirriŋuwala binbarrŋura djuḻuḻ'yun nhina;
\q2 barkparkthunna ŋarra ŋuli manikay galŋa‐djulŋithinyarayunydja.
\q1 
\v 8 Ŋarra yukurra baṯ bitjanna mulkanydja nhuna,
\q2 ga nheŋga ŋarranha yukurra goŋdhu mulka baṯ bitjandja,
\q2 walŋakumanydja yukurra ŋarranha.
\b
\q1 
\v 9-10 Wiripu‐guḻkuny'tja yolŋu'‐yulŋu ŋuli ŋarraku yukurra ŋaramurryirri,
\q2 bunharawu walala ŋarraku ḏukṯuk;
\q1 Walalana yurru raku'‐rakunydhirrinydja bunharaminyarayunydja,
\q2 bala yurru rumbalnydja walalanha ḻuka waṯuyuna wakinŋuyuna.
\b
\q1 
\v 11 Ga ŋarranydja yurru märr‐yiŋgathirrina,
\q2 goŋmirriyirrina dhika wal'ŋu Godkala.
\q1 Yo, Godkuna ŋunhi yolŋu walala yurru galŋa‐ŋamathirrinydja,
\q2 liŋgu Godthunydja yurru dhäruk‐mukmaramana ŋunhinydja bothinyaramirrinhanydja walalanha yolŋu'‐yulŋunha.
\c 67
\s1 Buku‐wekama yukurra
\s2 67:1–7 (A song of thanksgiving)
\q1 
\v 1 Gunhu' Waŋarr, ŋayaŋu‐wuyurra ŋanapurruŋgu;
\q2 Nhäŋanydja ŋanapurrunha nhe yurru yukirriya goyulŋu'yu dhika wal'ŋu yana,
\q2 ga gäŋa ŋanapurrunha yukirriya goŋmirriyaŋa dhika wal'ŋu,
\q1 
\v 2 märr yurru ŋuruŋu wiripuŋuyunydja bäpurru'yu yolŋu'‐yulŋuyu nhämana nhuŋu ḻatjuny'tja rom;
\q1 Walala yurru nhämana, bala marŋgithirrina,
\q2 ŋunhi nheŋga dhuwala waŋarr walŋakunharamirrinydja.
\b
\q1 
\v 3 God milkunhamiyana nhunapinyay nhe ŋurukala wiripuwurruŋgalanydja bäpurru'wala,
\q2 märr yurru walala wokthun yukurra nhuŋuwaynha;
\q2 Bukmaknha yana yurru yolŋu'‐yulŋu buku‐ŋal'yun yukurra nhuŋuwaynha yanana.
\q1 
\v 4 Walala yurru ŋayaŋu‐ŋamathirrina, ga miyamanna ŋayaŋu‐djulŋithinyarayuna dhikana,
\q2 liŋgu nhenydja dhuwala rom‐dhunupa warray Waŋarr, garrkuḻuk warray,
\q2 ga gämanydja nhe yukurra bukmaknha yolŋunha miṯtjinha yuwalkkuma dhika wal'ŋu.
\b
\q1 
\v 5 God milkunhamiyana nhunapinyay nhe ŋurukala wiripuwurruŋgalanydja bäpurru'wala,
\q2 märr yurru walala wokthun yukurra nhuŋuwaynha,
\q2 bukmaknha yana yurru yolŋu'‐yulŋu buku‐ŋal'yun yukurra nhuŋuwaynha yana.
\b
\q1 
\v 6 Yo, wäŋanydja dhuwala marrtji borum‐mäypamirriyirrina,
\q2 liŋgu ŋayipi Gunhu'yu Godthu ŋilimurrunha yukurra gäma goŋmirriyamanydja.
\q1 
\v 7 Wirrkina dhikana ŋayi ŋayaŋu‐ŋamathirri yukurra ŋilimurruŋgu;
\q2 Bukmaknha dhika yolŋu birrka'mirriŋurana wäŋaŋura yurru märr‐ŋal'yun yukurra nhanŋu Garraywunydja.
\c 69
\s1 Gawaw'yun yukurra guŋga'yunarawuna
\s2 69:1–36 (A cry for help)
\q1 
\v 1 Garray God, go marrtjiya lili, guŋga'yurrana ŋarranha.
\q1 Ŋarranydja dhuwala balanyarana yolŋu bitjan ŋurru‐ḻupthunna ŋarra yurru gapuŋurana,
\q2 bitjanna ŋarra yukurra bitjan dhoḻuyu ŋarranha marrtji garrpiṉ,
\q2 ga yakana ŋarra yukurra maḻŋ'marama ŋarrakuway ŋarra ḏäl garminyarr dhärranharawu.
\q1 
\v 2 Ga gapunydja dhuwala bena‐wala gal'ŋu yana,
\q2 ga ŋuriŋi dhaḻawandhu ŋarranha marrtji bumana;
\q2 galki ŋarra yurru ŋurru‐ḻupthunna‐wala dhuwala yulŋunydja.
\q1 
\v 3 Märr‐weyinnha ŋarra yukurrana gawaw'yurrunanydja märrliliyaŋalanydja guŋga'yunarawunydja,
\q2 ga djawaryunna ŋarra marrtji dhuwala, ga mayaŋdja ŋarraku dhulku'mirrina,
\q2 ga maŋutji ŋarra marrtji bitjan djawaryunna dhukarr‐nhänharayunydja.
\b
\q1 
\v 4 Yo, guḻku'yu mirithirri yukurra nyinyaŋdhundja nhämanydja ŋarranha ŋurrumiriwŋurana nhämiriwŋurana,
\q2 ŋuriŋiyinydja walalay yolŋu'‐yulŋuyu wuṉḏaŋarrmirriyu be ganydjarr‐ḏilkurruyu,
\q1 ga ŋamaŋamayunmirrinydja walala yukurra ŋarraku bunharawuna yana,
\q2 ga ḻakarama walala yukurra bothirrina ŋarranha.
\q1 Nhaltjanna dhika ŋarra yurru roŋinyamarama wekamanydja walalaŋgu,
\q2 ŋunhi ŋarra yaka manaŋina wo ŋula nhaltjarra walalaŋgalaŋuŋuru?
\q1 
\v 5 Garray God, nhenydja marŋgi ŋarraku.
\q1 Nhenydja ŋuli nhäma marrtji ŋarranha djämalili,
\q2 ŋunhi ŋarra ŋuli warkthun ŋula nhä malanha yätj.
\q1 
\v 6 Ŋarra yaka ḏukṯuk ŋurikinydja ŋunhi walala yurru ŋunhiyi märr‐yuwalkthinyaramirri yolŋu'‐yulŋu goramirriyirri,
\q2 liŋgu ŋarrakala ŋuriŋi ḻiya‐dhumukthinyarayu yätjthu djämayu.
\q1 
\v 7 Yo, wiripuŋuyunydja yolŋuyu ŋarranha ŋuli yätj ḻakaramana gal'ŋu yanana,
\q1 liŋgu ŋarranydja dhuwala nhuŋuway yana,
\q2 ga ŋuriŋiyinydjayi romdhu ŋarranha ŋuli goramirriyamana.
\q1 
\v 8 Wiripunydja ŋuli ŋarrakala gurruṯu'mirriyu mulkuru‐ḻakaramana ŋarranha,
\q2 yanapi ŋarra ŋula yolnha.
\b
\q1 
\v 9 Yo, wirrki yana ŋarra märr‐ŋamathirrinydja yukurra wal'ŋu yana nhokalaŋuwu Buṉbuwunydja,
\q2 bitjanna bitjan gurtha ŋuli nhära yukurra ŋatŋatthun ŋarrakala ŋayaŋuŋura.
\q1 Walala yukurra yätj‐ḻakaramana dhikana wal'ŋu nhunanydja Garray,
\q2 ga ŋuriŋi walalaŋgala dhärukthunydja yukurra ŋarranhana ŋayaŋu‐wutthun ga ŋayaŋu‐yätjkuma.
\q1 
\v 10 Wiripunydja ŋarra ŋuli galŋa‐mundurrthirri, ŋoy‐ŋathamiriw nhina wal'ŋu,
\q2 ga walalanydja ŋuli bitjana warku'yuna warray ŋarranha, beyarrmakkunha warray.
\q1 
\v 11 Walala ŋuli gitkitthunna ŋarrakunydja, ŋunhi ŋarra ŋuli dhaṯthunmirri ŋuriŋi girri'yu,
\q2 yana milkunharamirri bitjan ŋunhi ŋarra ŋuli wuyunmirri ŋarrakalayŋuwu ŋarra yätjku.
\q1 
\v 12 Ŋunha dhukarrŋuranydja walala yukurra waŋanharamirri, bitjan ḻayḻaymaramana ŋarranha,
\q2 ga ŋuruŋu ŋänitjimirriyu muḻkurr‐leŋumirriyu walalay ŋarranha ŋuli manikaykurruna warku'yunna miyamanna.
\b
\q1 
\v 13 Yurru ŋarranydja yurru bukumirriyamana yana gal'ŋu nhokalaynha, Garray,
\q2 yana buku‐ruŋinyamaraŋa dhäruknha ŋarraku lili,
\q2 ŋuriŋina waluyu ŋunhi nhe nherrara guŋga'yunarawu ŋarraku.
\q1 Liŋgu nhe dhawu'mirriyaŋala muka, ŋunhi nhe yurru walŋakuma ŋarranha.
\q1 
\v 14 Garray, dhawaṯmaraŋana ŋarranha dhipuŋuru walŋakuŋana dhoḻuŋurunydja,
\q2 dhawaṯmaraŋa warryurrana ŋarranha dhipuŋuru dhulmu‐ḻuḻnyinŋurunydja gapuŋuru,
\q2 liŋgu nhuŋunydja märr‐ŋamathinyara yukurra dhärra warray gupaḏalnha‐wala, djambimiriwnha nhämiriwnha.
\q1 
\v 15 Dhawaṯmaraŋana ŋarranha märraŋana,
\q2 märr yurru ŋarra yakana biyapulnydja ŋurru‐ḻupthun;
\q1 Märraŋana ŋarranha dhawaṯmaraŋana ŋulaŋuru miriŋuwalanydja goŋŋuru.
\b
\q1 
\v 16 Garray, ŋäka ga mäkiri'‐witjurra ŋarranha,
\q2 ga buku‐ruŋinyamaraŋana yana dhäruktja,
\q2 liŋgu nhenydja ŋunhi ḻatju' warray dhika waŋarr.
\q1 Nhuŋu märr‐ŋamathinyaranydja yukurra dhärra bitjanna liŋguna gupaḏalnha‐wala;
\q2 dhiyaŋi ŋunhi nhokalay mel‐wuyunaramirriyunydja bilyurrana, ga walŋakuŋana ŋarranha.
\q1 
\v 17 Yakana djuḻuḻ'maranharamiyanydja ŋarrakala nhe yurru.
\q1 Ŋarranydja dhuwala djämamirri nhuŋu ŋarra,
\q2 ga dhuwalana gay' ŋarra mariŋurana yulŋunydja.
\q2 Go marrtjiyana lili waḏutjana, ga guŋga'yurrana ŋarranha.
\q1 
\v 18 Gumurr‐walkithiyana ga walŋakuŋana ŋarranha,
\q2 märraŋana yana ŋarranha warryurra ŋulaŋuru miriŋuwalanydja goŋŋuru.
\b
\q1 
\v 19 Garray, nhe marŋgi muka, ga ŋäma nhe ŋuli yolŋunha walalanha,
\q2 ŋunhi walala ŋuli marrtji waŋa yätj dhäruk ŋarraku.
\q1 Ga nhäma nhe ŋuli ŋunhiyi miriŋunhanydja walalanha,
\q2 ŋunhi walala ŋuli warku'yun ŋarranha.
\q1 
\v 20 Ŋarraku ŋayaŋunydja ŋuli ŋayaŋu‐yätjthirrina ŋuriŋiyinydjayi walalaŋgala dhärukthunydja yätjthunydja,
\q2 bala ŋarra ŋuli nhinanydja galŋa‐yätjthirrina, warwumirriyirrina bitjanna yukurra.
\q1 Ŋarra gatjpu'yurruna yulŋunydja ŋula yolnha,
\q2 ŋunhi ŋayi yurru ŋarraku maŋutji‐wuyun, ga marrparaŋ'kuma ŋarranha.
\q1 Yurru bäyŋu warray,
\q2 yakana yana ŋula waŋgany yolŋu nhinana ŋarrakala galki, bämara' ŋarraku.
\q1 
\v 21 Ŋarra marrya'yinanydja, ga walalanydja ŋarranha wekaŋala ŋula nhäna Nawukuku'na;
\q1 Ŋarra ŋanhdharkthinanydja, ga walalanydja ŋarranha wekaŋala dhäkay‐murrkthunarana gapu.
\b
\q1 
\v 22 Garray, yakana yana walalanha guŋga'yurranydja,
\q2 yaka yana walalambala galkithiyanydja wal'ŋu, ŋunhi walala ŋuli waŋgany‐manapan marrtji ḻuŋ'maranhamirri ŋula nhäku maḏayin'ku ŋathawu ḻukanharawu.
\q1 
\v 23 Yana walala yurru maŋutjinydja bambaythirrina dhumukthirrina,
\q2 märr yurru walala yakana nhäma,
\q2 bitjan walala yurru galkirrina marrtji, marrmarryunmirrina ŋuriŋi yalŋgi'yinyarayuna.
\q1 
\v 24-25 Dhä‐ḏir'yurrana walalanha ŋuriŋiyina nhokalay nhe ŋaramurryuna,
\q2 ga yakana ŋula dhayuŋan nhe yurru waŋganynhanydja walŋakuma.
\q1 
\v 26 Liŋgu walala bumara yukurrana ŋayaŋu‐yätjkuŋala ŋunhinhanydja ŋunhi ŋayi dhä‐ḏir'yunara märraŋala nhokuŋu;
\q1 Ŋuriŋi bili nhokalay ŋayi ŋunhi gaṯpurr'thinanydja,
\q2 yurru walalanydja beyarrmakkuŋala warray, gitkitthunmina warray nhanŋu,
\q2 ŋunhi ŋayi yukurrana rirrikthurrunanydja batjpatjthurrunanydja.
\q1 
\v 27 Garray, guyaŋiyana walalaŋgu ŋunhiyinydjayi yätjtja malanha,
\q2 ga dhä‐ḏir'yurranydja walalanha wirrkina yana gal'ŋu;
\q1 Yakana yana walala yurru nhina galkinydja gal'ŋu nhokala.
\q1 
\v 28 Biyaka biḏiwiḏitjkuŋana yäkunydja walalanha ŋuliŋuruyi djorra'ŋuru walŋamirriŋurunydja,
\q2 ga yakana yana walala yurru ŋunhiyinydja walala nhina yukurra galki nhokalaŋuwala ŋurikalanydja ŋayaŋu‐dhunupamirriwalanydja gal'ŋu.
\b
\q1 
\v 29 Yo Garray, dhuwalana gay' ŋarranydja, rirrikthunna ŋarra yukurra ŋorr'‐ŋurryunna batjpatjtjunna,
\q2 ga wirrkina wal'ŋu ŋayaŋu‐yätjthirri ŋayaŋunydja ŋarra.
\q1 Garray, märraŋana ŋarranha ḻaw'maraŋana biyakana walŋakuŋana.
\q1 
\v 30 Bala ŋarranydja yurru wokthunna nhuŋu wal'ŋu yana, manikaykurruna wokthun;
\q1 Ŋarra yurru ḻakaramana nhunanydja, ŋunhi nhenydja biyapul gal'ŋu bathala,
\q2 wokthundja ŋarra yurru nhuŋu buku‐wurrpanarayuna manapan.
\q1 
\v 31 Ga ŋuriŋiyinydjayi nhuna yurru ŋarra bitjan galŋa‐djulŋithinyamirriyamana.
\q1 Liŋgu nhenydja yaka ḏukṯuk ŋarraku, ŋunhi ŋarra yurru gäma wäyindja ŋula nhänydja mundhurr‐wekanharawu.
\q1 
\v 32 Ga ŋunhinydja walala ŋunhi walalanha ŋuli ŋayaŋu‐ŋonuŋguma dhurrpalayu romdhu,
\q2 walalanydja yurru nhämana dharaŋanna,
\q2 bala walala yurru djulŋithirrina, goŋmirriyirrina dhikana.
\b
\q1 
\v 33 Yo, nhenydja ŋunhi nhe ḻarruma yukurra warrya'yun Godku, yana nhiniya wurrkurrum'thiya,
\q2 gatjpu'yurra biyaka ŋamakurru'wu maḻŋ'thunarawuna wal'ŋu.
\q1 Liŋgu ŋayipinydja Godthunydja yukurra ŋäma warray bukumirriyanharawuy ŋunhinhanydja walalanha gurrupuruŋumirrinhanydja yolŋu'‐yulŋunha;
\q1 Yaka ŋayi yurru meṉguma nhanŋuwaynydja ŋayi ŋunhi yolŋu'‐yulŋunha, ŋunhi walala yukurra nhina garrpiṉarawuy ŋula nhäkuŋu.
\b
\q1 
\v 34 Wokthurrana biyakana nhumanydja, ŋunhi nhuma djiwarr'wuy walala;
\q2 buku‐ŋal'yurrana nhanŋu nhumanydja yolŋu'‐yulŋu ŋunhi nhuma yukurra nhina dhiyala munatha'ŋura.
\q1 
\v 35-36 Yuwalk yana märr‐yuwalk ŋayi yurru walŋakuma wäŋanha \f + \fr 69:35-36 \ft 69:35-36 Jerusalem\f*Djurutjalamdja,
\q2 ga biyapul yurru ŋayi ŋunhiyi gaŋgathinyamirriyama dhuḻ'yundhi ŋunhi yulŋunydja buṉbuma.
\q1 Ga ŋunhiyinydjayi yolŋu walala mala‐wunharawuynydja nhanukalaŋuwuŋu djämamirriwuŋunydja walalaŋguŋu,
\q2 walalana yukurra yurru nhina ŋunhiliyinydjayi wäŋaŋura;
\q1 Ga walalaŋguwaynha yana yurru ŋunhi yulŋunydja wal'ŋu dhulŋuŋuna gupaḏalnha‐wala,
\q2 ŋurikinydja walalaŋgu yolŋu'‐yulŋuwu ŋunhi walala yukurra märryu‐ḏapmaranhamirriyu märr‐ŋamathinyarayu ŋayathama ŋanya,
\q2 ga walalana yurru yukurra nhina ŋunhiliyinydja wäŋaŋura gupaḏalnha‐wala yanana.
\c 91
\s1 Garray dhuwala ŋurrwuny'tja ŋilimurruŋgu
\s2 91:1–16 (God is our protector)
\q1 
\v 1 Garray dhuwala ŋurrwuny'tja ŋilimurruŋgu, ŋayi yurru ŋilimurrunha monyguma ŋurrwu'yunmarama,
\q2 bili ŋayi ŋunhi biyapulnydja‐wala garrwar Waŋarrnydja.
\q1 Ŋuli yurru ŋula yol yolŋu gärrinydja nhanukala ŋurrwu'lili,
\q2 bala nhinana yukurra yurru nhanukala,
\q2 ŋayinydja yurru walŋathirri warray, Garraywala ŋuriŋi gunganharayu.
\q1 
\v 2 Ŋayi yurru waŋa Garraywala bitjanna,
\q2 “Nhenydja dhuwala ŋarraku watjarr'mirri, ga ŋurrwu' walŋamirri.
\q2 Nhepina ŋarrakunydja Waŋarr; ŋarra yurru nhokalana ŋayaŋu‐nherraṉmirri.”
\b
\q1 
\v 3 Ŋe! Ŋunha Yätjthu Ŋäṉukthunydja yukurra ŋayathama raki'na ḏapmaranharawu nhuŋu,
\q2 yurru Garrayyunydja nhuna yurru walŋakuma warray, yupmaramana yurru nhokala,
\q2 ga walŋakuma ŋayi yurru nhuna gungama rerriŋuru ga rakunydhinyaramirriŋuru.
\q1 
\v 4 Walŋana nhe yurru nhina yukurra Garraywalanydja djäkaŋura,
\q2 bitjandhina bitjan ŋunha wäyindhu ŋuli dhangi'yun yothu'nha wäyinnha binbarrlili yaluŋura,
\q2 djuḻuḻ'marama ŋuli burakinyaraŋuru;
\q1 Bitjandhi bili nhunanydja yurru djuḻuḻ'marama Garrayyunydja nhanukalay ŋurrwu'lili,
\q2 walŋakumayi nhuna yurru.
\q1 
\v 5 Munhakunydja nhe yurru nhina yukurra beyaṉumiriwnha,
\q2 ga bitjandhi liŋgu walupuynydja,
\q2 beyaṉumiriw yana nhe yurru yukurra nhina.
\q1 
\v 6 Yakana nhuna yurru ŋula yolthu djaw'yun, ŋula buma nhuna yurru,
\q2 bili Garrayyuna yukurra nhuna gungama,
\q2 ŋurrwu'yunmarama yurru walu‐ŋupan ga munha‐ŋupan.
\b
\q1 
\v 7 Wiripu‐guḻku' yolŋu walala yurru galkirrinydja marrtji,
\q2 murrmurryundja yurru ŋula nhokala ḻiw'marama.
\q1 
\v 8 Nhenydja yurru yaka warray burakirri ŋula nhäyu,
\q2 nhenydja yurru yana nhäma ŋunhi dhuwurr‐yätjmirrinha,
\q2 walala yurru galkirri marrtji ŋuriŋi Garraywala dhä‐ḏir'yunarayu.
\q1 
\v 9-10 Nhunanydja yurru yaka ŋula yätjthu romdhu wutthun,
\q2 liŋgu nhanukala Garraywala nhenydja wekanharamina goŋlili;
\q1 Ŋayi ŋunhi garrwar wal'ŋu Waŋarr God nhuŋunydja gunganharamirri ga watjarr‐mulkanharamirri,
\q2 yakana yurru ŋula nhä mari galkithirri nhokalanydja wäŋalili.
\q1 
\v 11 Liŋgu Godthu yurru goŋ‐nherraṉ nhuŋu djäkamirrinha yolŋu'‐yulŋunha,
\q2 walala yurru ŋunhi djiwarr'wuy walala marrtji dharraynydja nhuŋu wanhawitjan nhe yurru marrtji;
\q1 
\v 12 Mulkana yurru walala marrtji nhuna baṯ bitjanna,
\q2 märr nhe yurru yakana ŋula galkirri,
\q2 ga burakirri ḻukunydja ḏaw'yun guṉḏayunydja.
\q1 
\v 13 Ŋuli nhe yurru nhäma ŋula wakinŋunha wäyinnha maḏakarritjnha,
\q2 nhenydja yurru yana bumana ŋanya, gukumana yurru;
\q1 Nhämana nhe yurru moḻ'ŋunha maḏakarritjnhanydja,
\q2 bala yana muŋdhunna ŋanya nhokalay nhe djalkiriyuna.
\b
\q1 
\v 14 Garray yukurra waŋa bitjan,
\q1 “Ŋarranydja yurru walŋakuma yolŋunha ŋunhinha,
\q2 ŋunhi ŋayi yukurra mulka rambuma ŋarranha;
\q1 Ŋarranydja yurru nhanŋu dharray, ŋapatjkumana ŋanya,
\q2 liŋgu ŋayi marŋgina wal'ŋu ŋarraku, nhäyinyara ŋarra yulŋunydja Godtja.
\q1 
\v 15-16 Ŋunhi ŋayi yurru wäthun ŋula ŋarraku,
\q2 bala ŋarra yurru waŋa buku‐wakmarama nhanŋu;
\q1 Ga ŋuli ŋayi yurru ŋula marilili gärri,
\q2 ŋarranydja yurru ŋunhili nhanukala galki,
\q2 walŋakumanydja ŋarra yurru ŋanya, märramana dhawaṯmaramana ŋuliŋuru mariŋuru.
\q1 Bala ŋarra yurru märr‐ŋal'yunna nhanŋu ŋuriki yolŋuwu ŋunhi ŋayi ŋarrakala yukurra märryu ḏapmarama,
\q2 ga buku‐ruŋiyinmarama ŋarra yurru nhanŋu;
\q1 Weyinnha ŋayi yurru nhina yukurra dhiyala munatha'ŋuranydja,
\q2 liŋgu ŋayi yurru marŋgithirrina ŋarraku walŋamirriwuna romgu.”
\q2 Ga bitjan yukurra Garray waŋanydja.
\c 93
\s1 Godtja dhuwala ŋurruŋuna wal'ŋu ŋayinydja
\s2 93:1–5 (God is King)
\q1 
\v 1 Yo, Garraynydja dhuwala buŋgawa ŋayi gal'ŋu,
\q2 ŋunha nhinanydja ŋayi yukurra girri'yunydja dhaṯthunminyara dhika dhapirrkmirriyu, ḻatju'yu dhika wal'ŋu;
\q1 Nhinanydja ŋayi yukurra ŋunha ŋuriŋi ganydjarryu, ganydjarr‐ḏumurruyu wal'ŋu dhika giṯthunamiriwyu.
\q1 Ŋayi ŋunhi Garrayyu djämanydja dhuwala wäŋanha munatha'nhanydja,
\q2 ga nherraranydja ŋayi giṯmaranhamiriw yana gal'ŋu,
\q2 yakana ŋayi yurru giṯthun bala ga lili bitjan.
\q1 
\v 2 Garray, beŋuru liŋgu ŋurruŋuru nhe yukurrana nhinananydja buŋgawa wal'ŋu, ŋurruŋu nhe,
\q2 ga bitjan liŋgu walŋa yana nhe yulŋunydja.
\q1 
\v 3 Ŋunha gapu moṉuktja ganydjarr‐ḏumurru wal'ŋu,
\q2 ga ŋunha dhaḻawan yukurra galkirri ŋunha munatha'lili be rirrakayyu wal'ŋu bathalayu ŋanya.
\q1 
\v 4 Yurru Garraynydja wal'ŋu biyapul warray, be‐wala ŋurikalayinydjayi gapuwalanydja;
\q1 Ŋuriŋi nhanukalanydja ganydjarryu bitjan ŋayi yukurra gäma dhuwala munatha'nha wäŋanha warrpam'thun yana,
\q2 ŋayinydja biyapul gal'ŋu ganydjarr‐ḏumurru ŋayi ŋurikalanydja be bathala‐wala ḏowuwalanydja.
\q1 
\v 5 Yo, Garrayyunydja nherrara ŋunhi romdja, ŋunhi ŋayi yurru dhärra yukurra yana mukthun, djambimiriw nhämiriw.
\q1 Garray, nhuŋunydja ŋunhi wäŋa biyapul warray wal'ŋu dhuyu, ḏarrtjalk warray,
\q2 ganaŋ'thun yukurra ŋuliŋuru yätjkalanydja,
\q2 bitjanna liŋguna dhärra yurru yukurra gupaḏalnha‐wala.
\c 97
\s1 Godtja biyapulwala wal'ŋu wiripu‐guḻku'walanydja waŋarrwala
\s2 97:1–12 (God is greater than all other gods)
\q1 
\v 1 Yo, Garraynydja dhuwala buŋgawa ŋayi wal'ŋu.
\q1 Biyaka goŋmirriyaŋa wokthurrana manaparra nhuma munathany'tja wäŋa,
\q2 ga nhumanydja ŋunhi nhuma nhina yukurra gapuŋura ga runu'‐runuŋura, biyaka galŋa‐djulŋithiyana gal'ŋu.
\q1 
\v 2 Garraynydja yukurra nhina dhika dhapirrk warray wal'ŋu yana ŋayipinydja,
\q2 bitjan ŋayi yukurra ŋäkirrmaranhamirrinydja ŋanyapinyay ŋayi ŋuriŋina waŋupini'yuna,
\q1 ga nhinanydja ŋayi yukurra ŋunha be‐wala djiwarr'ŋura wal'ŋu,
\q2 gämanydja ŋayi marrtji dhuwala wäŋanha munatha'nha goŋdhunydja nhanukalay ŋayi.
\q1 
\v 3 Nhinanydja ŋayi yukurra ŋunhiliyi dhunupa wal'ŋu yana,
\q2 ga ŋuliŋuruyi nhanukala yukurra marrtjinydja gurthana dhawaṯthundja,
\q2 nhäranhamaramana yukurra ŋunhi miriŋunhanydja nhanŋuway,
\q2 ga yakana ŋula waŋgany walŋanydja.
\q1 
\v 4-5 Ŋuliŋuruyi nhanukala dhawaṯthun yurru bitjan djaḻka'‐djaḻkarryunna,
\q2 ga ṉilŋṉilŋdja ŋunhinydja yurru wärakkumana mulka ŋuriŋi birrka'mirrina wäŋa;
\q1 Ŋayi yurru munatha'yunydja wäŋayu nhämana, bala marrmarryunmirrina,
\q1 bala barr'‐barryunna yurru buku'‐wukunydja wäŋa, buḻwaŋ'thunna marrtji gumurrŋura nhanukalanydja Garraywalanydja,
\q2 ŋunhi ŋayi yukurra nhina ŋunha Garray wal'ŋu ŋayi ŋurruŋu dhiyaku munatha'wu warrpam'ku yana.
\q1 
\v 6 Bukmakthu ŋuruŋunydja gärakpuyyunydja walalay bitjan ganyu'yu ga ŋaḻindiyu dhika nhäyu ḻakaramana ŋanya yukurra,
\q2 ŋunhi ŋayinydja rom dhunupa wal'ŋu yana,
\q1 ga bukmakthu buku‐ḻiw'marama wäŋaŋuru miṯtjiyunydja yukurra nhämana ŋunhi dhapirrktja dhikanydja ŋanyanydja djarraṯawun'.
\b
\q1 
\v 7 Yo, ŋunhinydja walala ŋunhi walala yukurra buku‐ŋal'yun wiripuŋuwu waŋarrwu ga ŋula nhäku maḏayin'kunydja, walalanydja yurru goramirriyirrina,
\q2 liŋgu birrka'mirri waŋarr malanha yurru buku‐nyilŋ'thun nhanŋuwaynha yana waŋganyguna Garraywuna.
\q1 
\v 8 Yo, yolŋu walala ŋunhi \f + \fr 97:8 \ft Jerusalem\f*Djurutjalambuy wäŋawuy yukurra mirithirrina yana ŋayaŋu‐djulŋithirrina,
\q2 goŋmirriyirrina yukurra nhina ḻiw'marama ŋunhi wäŋakurru,
\q2 liŋgu nhenydja God yukurra djäma dhunupa warray dhika wal'ŋu.
\q1 
\v 9 Nhenydja dhuwala ganydjarr‐ḏumurru wal'ŋu God yana, wäŋa‐nininyŋu,
\q2 ga nhepi yukurra ŋayathama dhuwala wäŋanha munatha'nhanydja ḻiw'marama yana.
\q1 Nhenydja biyapul wal'ŋu djuḻkmarama yukurra yana bukmaknhanydja ŋunhinydja ŋunhi walala ŋuli yolŋu'‐yulŋuyu waŋarr‐ḻakarama yukurra.
\q1 
\v 10 Yo Garray, nhenydja yukurra märr‐ŋamathirri warray ŋurikinydja yolŋu'‐yulŋuwu ŋunhi walala yukurra ŋuyulkthirri nyinyaŋdhun yätjku;
\q2 Nhepi ŋuli gunganhamirriyamanydja walŋakumanydja walalanha, ŋunhi nhuŋuwaynydja gal'ŋu yolŋu'‐yulŋunha,
\q2 märrama nhe ŋuli dhawaṯmarama walalanha ŋuliŋurunydja goŋŋuru yätjkalanydja.
\q1 
\v 11 Nhe ŋuli djarraṯawun'kumana dhukarrnydja ŋuriki rom‐waŋganymirriwunydja ŋayaŋu‐dhunupamirriwunydja yolŋu'‐yulŋuwu,
\q2 märr yurru walala nhina ŋayaŋu‐djulŋithirrina, goŋmirriyirrina dhikana wal'ŋu.
\q1 
\v 12 Yo, biyaka galŋa‐djulŋithiya wirrki wal'ŋu yana nhumanydja ŋunhi ŋayaŋu‐dhunupamirrinydja.
\q1 Ŋayaŋu‐djulŋithiya yana Garraywalanydja,
\q2 ga buku‐wurrpala wekaŋa nhanŋu,
\q2 liŋgu ŋayinydja ŋunhi gäna wal'ŋu, ḏarrtjalk yana ŋayi Garray.
\c 100
\s1 Wokthun Garraywu
\s2 100:1–5 (Praise the Lord)
\q1 
\v 1 Go wäŋa malanha bukmak, yiŋgathiya Garraywu,
\q2 goŋmirriyiyana nhanŋu go rirrakay‐djulŋithinyamirriyuna.
\q1 
\v 2 Märr‐ŋal'yurra nhanŋu ŋoy‐djulŋithinyarayu,
\q2 ga marrtjiya lili nhanukala, miyamala ŋayaŋu‐djulŋithinyaramirri manikay.
\b
\q1 
\v 3 Marŋgithiyana nhanŋu Garraywu, ŋunhi ŋayi dhuwala Gunhu' Waŋarr, ŋayipi yana.
\q2 Ŋayi bokmara ŋilimurrunha, ga ŋilimurrunydja dhuwala nhanŋuwaynha mala yolŋu;
\q2 ŋilimurru nhanukalana goŋŋura, liŋgu ŋayi ŋilimurruŋgunydja djäkamirri.
\b
\q1 
\v 4 Go gärriyana lili nhanukala Buṉbulilina, buku‐wekaŋana ŋanya,
\q2 ŋilimurru wokthunna nhanŋu wal'ŋu mirithirrina;
\q1 Buku‐wekaŋa ŋanya, ga yäkuna ŋanya garrwarkuŋa.
\b
\q1 
\v 5 Bili Garray dhuwala ḻatjuny'tja,
\q2 nhanŋu märr‐ŋamathinyaranydja dhärrana yukurra,
\q2 ga bitjanna liŋguna yurru, weyinŋumirrina.
\q1 Garraynydja dhuwala märr‐yuwalkthinyaramirri;
\q1 Ŋilimurrunydja yurru ga yumurrku' ŋilimurruŋgu märr‐nherraṉmirrina nhanukala,
\q2 liŋgu ŋayipinydja yurru yukurra dhärra bitjanna liŋguna djambimiriwnha‐wala yana.
\c 103
\s1 Ŋayaŋu‐ŋamathinyara Godku
\s2 103:1–22 (The love of God)
\q1 
\v 1 Ŋarranydja liŋguna djarr'yurruna,
\q2 ŋarra yurru wokthun nhanŋu Garraywuna;
\q1 Bukmakthu ŋarrakalay ŋayaŋuyu ŋarra yurru wokthunna nhanŋu,
\q2 liŋgu yäkunydja ŋayi djeŋarra' warray wal'ŋu, biyapul warray‐wala wiripu‐guḻku'walanydja.
\q1 
\v 2 Bitjanna liŋguna ŋarra yurru wokthun nhanŋu Garraywu,
\q2 ga yakana ŋuli meṉgumanydja nhaltjan ŋayi ŋuli yukurra ŋarranha gäma ḻatju'kuma dhika wal'ŋu.
\q1 
\v 3 Ŋayi biḏiwiḏitjkuma marrtji bala ŋuli ŋarrakala yätj malanha,
\q2 warrpam ḏarrtjalkkuma ŋarranha,
\q1 ga ḏukthunmarama ŋayi ŋuli ŋarranha marrtji bala,
\q2 baḏarraŋ'kuma birrka'mirriŋuru rerriŋuru,
\q1 
\v 4 Ŋarranha ŋayi ŋuli walŋakuma rakunydhinyaraŋuru,
\q2 ga nhinanydja ŋarra yukurra walŋana yana nhanukalana djäkaŋura.
\q1 Ga monyguma ŋarranha ŋayi ŋuli märr‐ŋamathinyarayu,
\q2 nhanukalay ŋayi ŋoy‐wuyunaramirriyu ŋuli yukurra ŋarranha gäma ḻatju'kumana.
\q1 
\v 5 Ŋayi ŋarranha ŋuli maranhu‐wekama ḻatju'mirriyu nhäyu malaŋuyu,
\q2 yuṯana yana ŋarra ŋuli yukurra nhina ḏälnha, bitjan ŋuli ḏamala,
\q2 bili nhanukala goŋŋura Garraywala.
\q1 
\v 6 Wiripuŋuyu yolŋuyu ŋarranha mak wakinŋu‐ḻakarama yukurra,
\q2 yurru Garraynydja ŋarrakala gali'ŋura;
\q2 ŋayi ŋarranhanydja yukurra gäma ŋamathama dhika wal'ŋu.
\q1 
\v 7 Ŋäthili baman' ŋayi milkuŋala nhanŋuway ŋayi dhukarr ŋurikala ḏarramuwala \f + \fr 103:7 \ft Moses\f*Mawtjitjkala,
\q2 ga bukmakthu yolŋu'‐yulŋuyu bäpurru'yu \f + \fr 103:7 \ft Israel\f*Yitjuralpuyŋuyunydja nhäŋala Garraywu ḻatjuny'tja djäma nhanukala Mawtjitjkala.
\q1 
\v 8 Garraynydja dhuwala mel‐wuyunaramirrina,
\q2 bitjanna liŋguna ŋayi yukurra ŋayaŋu‐ŋamathirrinydja ŋilimurruŋgu.
\q1 Yakana ŋayi ŋuli dhika waḏutja ŋaramurryirri;
\q2 djäkana ŋuli ŋamathamana, gel'yunna gäma.
\q1 
\v 9 Wiripunydja ŋayi ŋilimurrunha ŋuli waŋa raypirri'yun yätjŋuru,
\q2 yurru yaka gupaḏalnydja ŋayi ŋuli ŋilimurrunha murr'marama,
\q2 ga yaka ŋayi ŋuli weyinmaramanydja gäma ŋunhi nhanŋuway ŋayi ŋaramurr.
\q1 
\v 10 Wiripunydja ŋilimurru ŋuli ŋanya buma ŋayaŋu‐yätjkuma ŋuriŋi ŋilimurruŋgala yätjthu,
\q2 yurru Garraynydja ŋuli yaka buku‐ruŋiyirri ŋilimurruŋgu, buma ŋitjalanhanydja.
\q1 
\v 11 Godkunydja märr‐ŋamathinyara dhiŋgina, bena‐wala birr';
\q2 wirrki ŋayi yukurra märryu‐ḏapmarama märr‐ŋamathinyarayu ŋunhinhanydja walalanha ŋunhi walala dhäruk‐märranharamirri nhanŋu;
\q1 
\v 12 Liŋguna ŋayi yarrkyarrkmaraŋala ŋilimurruŋgu yätjtja dhuwurr,
\q2 barrkulilina wuyupmaraŋalana, bena‐wala birr' ŋilimurruŋgala.
\q1 
\v 13 Yo, Garraynydja yukurra wuyun ŋilimurruŋgu,
\q2 bitjandhi bitjan ŋuli yolŋu mäḻu'mirriŋu wuyun nhanukalayŋuwu gäthu'mirriŋuwu.
\q1 
\v 14 Bili ŋayi marŋgi ŋilimurruŋgu, ŋunhi ŋilimurrunydja dhuwala munatha',
\q2 munatha' muka ŋayi yolŋukuŋala djämanydja.
\b
\q1 
\v 15 Yolŋunydja dhuwala yaka yurru weyin yukurra nhina dhiyala munatha'ŋura,
\q1 gurriri'ŋu yana nhanŋu walŋanydja, balanyara bitjan mulmu.
\q1 Mulmu ŋuli ŋuthan ḻatju'thirri,
\q1 
\v 16 bala ŋuli watayunydja bo'yun, buṯthunmaramana,
\q2 ḏaŋgalkmaramana ŋuli winya'yunmaramana;
\q2 Yakana biyapulnydja yurru nhäma ŋunhiyi ŋula yolthu.
\q1 
\v 17 Yurru Garraywunydja märr‐ŋamathinyara yakana ŋuli winya'yun;
\q1 Bitjanna liŋguna Garraynydja yukurra ŋayaŋu‐ŋamathirri ŋurikinydja walalaŋgu yolŋu'‐yulŋuwu,
\q2 ŋunhi walala borrk‐barrarirri yukurra nhanŋu;
\q1 Walalaŋgu ŋayi yukurra ŋayaŋu‐ŋamathirrinydja, ga yumurrku'wu walalaŋgalaŋuwu,
\q2 ga walalaŋgalaŋuwu yumurrku'walaŋuwu yumurrku'wu.
\q1 
\v 18 Bitjanna liŋguna ŋayi yukurra yurru guyaŋirrinydja ŋunhiyi walalanha,
\q2 ŋunhi walala yukurra ḏälkuma rom nhanŋu,
\q2 ŋunhi walala yukurra dhärukku malthun nhanŋuway.
\b
\q1 
\v 19 Garraynydja yukurra nhina ŋunha djiwarr'ŋurana,
\q2 djiwarrny'tja ŋunha nhanŋuwayŋga wäŋa;
\q1 Ŋayiŋga ŋunha ŋurruŋunydja buŋgawanydja,
\q2 nhanukalaynha goŋŋura ŋorra yukurra nhä malanha bukmak.
\q1 
\v 20 Wokthurra Garraywuna, nhuma djiwarr'wuynydja yolŋu'‐yulŋu,
\q2 ŋunhi nhuma dhäruk‐märranhamirri nhanŋu.
\q1 
\v 21 Wokthurra Garraywuna, nhuma djämamirrinydja walala nhanŋu,
\q2 ŋunhi nhuma djäma yukurra nhanukalay djälkurru.
\q1 
\v 22 Wokthurra Garraywuna, nhumanydja walala birrka'mirriŋura wäŋaŋura,
\q2 bukmak nhä malanha ŋunhi ŋayi bokmara nhumalanha.
\q1 Wokthurrana walala,
\q2 ga bitjandhiyi liŋgu ŋarranydja yukurra wokthundhi nhanŋu Garraywu,
\q2 gupaḏalnha‐wala yanana yurru.
\c 107
\s1 Wokthurrana biyakana Garraywunydja ga nhanukalaŋuwu ŋamakurru'wunydja
\s2 107:1–43 (Praise the Lord for his goodness)
\q1 
\v 1 Nhuma yolŋu walala buku‐wurrpalana ŋanya Godnhanydja,
\q2 liŋgu ŋayinydja ŋunhi manymak mirithirri warray Garray Waŋarr;
\q1 Yuwalk yana märr‐yuwalk ŋayi yukurra märr‐ŋamathirrinydja ŋilimurruŋgu,
\q2 ga bitjan liŋgu ŋayi yurru.
\q1 
\v 2 Nhuma yolŋu walala ŋunhi nhumalanha ŋayi walŋakuŋala,
\q2 waŋiya ḻakaraŋa nhanukalaŋuwuy ŋunhi ŋayinydja biyapul warray wal'ŋu, dhapirrk warray,
\q2 liŋgu märraŋala ŋayi nhumalanha dhawaṯmaraŋala beŋuru ŋunhi miriŋuwala goŋŋuru.
\q1 
\v 3 Ŋayi ḻuŋ'maraŋalanydja marrtjina nhumalanha birrka'mirriŋuru yana wäŋaŋurunydja,
\q2 ŋulaŋuru dhimurru'ŋuru ga bärra'ŋuru, ga ḻuŋgurrmaŋuru ga djalathaŋŋuru,
\q2 bitjarra ŋayi gäŋala nhumalanha lili wäŋalilina roŋinyamaraŋala.
\b
\q1 
\v 4 Wiripunydja nhuma yolŋu walala yukurranha ŋuli bäymana wirwiryuna ŋanhdharkŋurana, räwakŋurana gawarrka'ŋurana wäŋaŋura,
\q2 ga yakana nhuma maḻŋ'maraŋala dhukarr ŋunhinydja ŋunhi ŋayi marrtji ŋorra ŋunhimala wäŋalili ḻatju'lilinydja,
\q2 märr yurru nhe yukurra nhinana ŋunhili.
\q1 
\v 5 Marrya'na nhe ga ŋanhdharknha,
\q2 ga ŋayaŋunydja nhuŋu ŋunhi ŋunhanydja märr‐yawaryurrunana djawaryurrunana gal'ŋu.
\q1 
\v 6 Yo, mariŋura nhe yulŋunydja ŋayaŋunydja,
\q2 bala nhe wäthurrunana märrliliyaŋalana Garraywala bitjarrana, “Garray, guŋga'yurra ŋarranha,” bitjarra.
\q1 Ga ŋayinydja nhuna yuwalkthi walŋakuŋalana,
\q2 ga märraŋala ŋayi nhuna dhawaṯmaraŋalana beŋuruyinydjayi marimirriŋurunydja.
\q1 
\v 7 Ga gäŋalanydja ŋayi nhuna yukurrana ŋuliwitjarrana dhukarrkurru dhunupakurruna yana,
\q2 ga yana liŋgu ga mulkana nhe ŋunhi wäŋa nhinanharawu, wäŋaranharawuna wal'ŋu.
\b
\q1 
\v 8 Way nhuma yolŋu walala, biyaka buku‐wurrpalana Godnhanydja,
\q2 liŋgu ŋayinydja ŋunhi dhapirrk warray, ŋanya warray dhika;
\q1 Yuwalk yana märr‐yuwalk ŋayi märr‐ŋamathirrinydja yukurra ŋilimurruŋgu,
\q2 ga bitjan warray liŋgu ŋayi yukurra djämanydja ŋamakurru' mirithirri wal'ŋu yana ŋilimurruŋgu yolŋu'‐yulŋuwunydja.
\q1 
\v 9 Yo, ŋunhi ŋilimurru ŋuli marrya'yirri ga ŋanhdharkthirri,
\q2 ŋayinydja ŋuli ŋilimurrunha maranhu‐wekama,
\q2 ga rarr'yundja ŋayi ŋuli mirithirri yana manymak nhänydja malanha ŋilimurruŋgu.
\q1 
\v 10-11 Wiripunydja nhuma ŋuli nhinanha yukurranha buku‐munha'ŋura ŋunha wäŋaŋura,
\q2 garrpiṉarana nhumalanha ŋuli yukurranha ŋuriŋi raki'yu dhika nhäyu malaŋuyu,
\q2 liŋgu nhe ŋapa‐nherraṉmina yukurrana Garraywu;
\q1 Yaka nhe ḏukṯukthina nhinanharawu nhanukalaŋuwunydja romgu wal'ŋu.
\q1 
\v 12 Ga dhiyakuyinayi märrwu nhe ŋuli ŋayaŋunydja nhuŋu djawaryuna ŋuriŋinayi gänharayu ŋonuŋdhuna romdhu,
\q2 bala nhe ŋuli galkinyana yana, ga yakana nhuŋu ŋula yol dhärranhamaranharawunydja guŋga'yunarawunydja.
\q1 
\v 13 Yana nhe ŋayaŋu‐yätjthinana yukurrana yulŋunydja,
\q2 bala nhe wäthurrunana, märrliliyaŋalana Garraywala bitjarrana, “Garray, guŋga'yurra ŋarranha,” bitjarra.
\q1 Ga dhunupana yana ŋayinydja nhuna yuwalkthi walŋakuŋalana,
\q2 dhawaṯmaraŋalana märraŋala yana beŋuruyinydjayi marimirriŋurunydja;
\q1 
\v 14 Märraŋalana ŋayi nhuna ŋuliŋuruyi buku‐munha'ŋurunydja wäŋaŋuru dhawaṯmaraŋalana,
\q2 ga gulk‐gulkthurrunana ŋayi nhokala rakiny'tja ŋunhinydja garrpi'‐garrpiṉarawuynydja,
\q2 dhayaḻakuŋalana nhuna ŋayi.
\b
\q1 
\v 15 Way yolŋu walala, biyaka buku‐wurrpalana Godnhanydja,
\q2 liŋgu ŋayinydja ŋunhi dhapirrk warray waŋarr, ŋanya warray dhika.
\q1 Yuwalk yana märr‐yuwalk ŋayi märr‐ŋamathirrinydja yukurra ŋilimurruŋgu,
\q2 ga bitjan liŋgu ŋayi yukurra djämanydja ŋamakurru' mirithirri wal'ŋu yana ŋilimurruŋgu yolŋu'‐yulŋuwunydja.
\q1 
\v 16 Yo, liŋgu ŋayi bakmaraŋalana ŋayipina ŋunhi ḏälnydja raki' ŋunhi yukurrana garrpira ŋilimurrunha,
\q2 dhawaṯmaraŋalana ŋayi yänana dhayaḻakuŋalana ŋuliŋuruyi garrpiṉminyaraŋurunydja romŋuru.
\b
\q1 
\v 17 Wiripunydja nhuma yolŋu walala yukurranha ŋuli nhinanha ḻiya‐dhumuknha yana,
\q2 ga wiripunydja nhe ŋuli ŋayaŋu‐yätjthinya burakinyarana, liŋgu ŋuriŋi nhokalay yätjthu.
\q1 
\v 18 Yana nhe ŋuli ŋuyulkthirrina ŋathawunydja, galki rakunydhinyarawuna.
\q1 
\v 19 Yo, mariŋurana yana nhe yulŋunydja,
\q2 bala nhe wäthurruna Garraywalana märrliliyaŋala bitjarrana, “Garray, guŋga'yurra ŋarranha,” bitjarrana.
\q1 Ga ŋayinydja nhuna yuwalkthi walŋakuŋalana, ga märraŋalana ŋayi nhuna beŋurunydja yätjŋurunydja ŋayaŋu‐yätjthinyaramirriŋurunydja romŋuru.
\b
\q1 
\v 20 Yo, ŋayi waŋana dhäruk‐waŋgany, bala nhenydja baḏarraŋ'thinana,
\q2 ḏukthurrunana nhe yulŋunydja ŋuriŋi bili dhärukthu yana; ŋayi walŋakuŋala nhuna,
\q2 märr yurru nhe yaka muka rakunydhirrinydja.
\q1 
\v 21 Yana nhenydja yurru buku‐wurrpala ŋanya Godnhanydja,
\q2 liŋgu ŋayinydja ŋamakurru' warray dhika waŋarr;
\q1 Yuwalk yana märr‐yuwalk ŋayi märr‐ŋamathirrinydja yukurra ŋilimurruŋgu,
\q2 ga bitjan warray liŋgu ŋayi yukurra djämanydja ŋilimurruŋgu yolŋu'‐yulŋuwunydja ŋamakurru' dhika wal'ŋu mirithirri yana.
\q1 
\v 22 Go gäŋana lili nhanŋu mundhurrnha Garraywunydja,
\q2 ga buku‐wurrpalana ŋanya;
\q1 Ḻakaraŋana ŋanya ŋurikiynha ŋunhi ŋayi yukurra djäma mirithirri bathala,
\q2 miyamalana manikaynha, wokthurrana manaparana biyakana Garraywalanydja ŋayaŋu‐djulŋithinyaramirriyuna.
\q1 
\v 23 Wiripunydja nhuma yukurranha ŋuli yolŋu'‐yulŋuyu gänha mitjiya be dhulmukurru wal'ŋu wulangurru,
\q2 djäma nhuma ŋuli ŋula nhä malanha yana ḻukunydjakunharaminya ŋuriŋi djämayu.
\q1 
\v 24 Ga wiripunydja nhuma ŋuli nhänhana Garraywuŋu djämawuynydja,
\q2 nhä ŋayi ŋuli djäma nhanukalay ŋayi ganydjarryu ŋula dhulmuŋura gapuŋura.
\q1 
\v 25 Wiripunydja ŋayi ŋuli waŋanha dhäruk yana waŋgany,
\q2 bala ŋayi ŋuli watayunydja bo'yunana ŋuriŋi ganydjarrmirriyuna wal'ŋu,
\q2 bathalayuna ganydjarryu ŋayi ŋuli djäma,
\q2 ga ŋunhiyi ḏowu dhaḻawan ŋuli gaŋgathinya mirithinyana dhikana wal'ŋu, barrari‐wukunhana nhumalanha yolŋu'‐yulŋunhana.
\q1 
\v 26 Yo, wiripunydja ŋayi ŋuli ŋunhi mitjiya gaŋgathinyamirriyanha ŋuriŋi dhaḻawandhu ḏowuyu,
\q2 ga be yana galkinya ŋunha ŋoylilinydja gapulili,
\q2 ga nhuma yolŋunydja walala ŋuli barrarinyana yukurranha mirithinyana;
\q1 
\v 27 Yo, ḏur'‐ḏuryunana nhuma ŋuli bala ga lili ŋuriŋi ḏowuyunydja,
\q2 bitjana bitjan ŋuli leŋumirri ŋunhi yolŋu ŋunhi ŋayi ŋuli marrtji yukurra bala ga lili buku‐wirwiryun,
\q2 ga yakana nhe yana marŋginydja nhaltjanarawu nhinanharawu walŋathinyarawu.
\b
\q1 
\v 28 Yo, mariŋuranydja nhe ŋuli bathalaŋura yana wal'ŋu dhika, bala nhe ŋuli wäthuna Garraywala bitjana, “Garray, walŋakuŋa ŋanapurrunha,” bitjana.
\q1 
\v 29 Ga yuwalkthi yana märr‐yuwalk ŋayi nhumalanha walŋakuŋalanydja märraŋala dhawaṯmaraŋalanydja ŋuliŋuruyi barrarimirriŋurunydja dhikanydja wal'ŋu romŋuru;
\q1 Yana ŋayi ŋuli waŋananydja dhäruknha waŋganynha,
\q2 mukmaraŋala ŋayi ŋunhi watanhanydja ga gapunhanydja,
\q1 bala ŋayi ŋunhi watanydja ga gapunydja wurrkurrum'thinana mukthurrunana,
\q2 bukmak ŋunhi nhä malanha warrpam' wapurarrnha, wapurarryinana yana.
\q1 
\v 30 Yo, nhänhanydja nhuma ŋuli gapu nyilŋ'thunaranydja mukthunaranydja wurrkurrum'thinyaranydja,
\q2 bala ŋayaŋu‐djulŋithinyana dhikana goŋmirriyinyana ŋuli,
\q2 liŋgu gäŋalanydja ŋayi nhumalanha walŋana yana ŋunhimala wäŋalili ŋunhi wanhamala nhe ḏukṯukthinya ŋuli nhinanharawu.
\q1 
\v 31 Ga nhenydja ŋuli guyaŋinya muka ŋanya Garraynha, buku‐wurrpanaŋga manapana ŋanya,
\q2 liŋgu ŋayinydja manymak warray dhika warray God;
\q1 Yuwalk ŋayi märr‐yuwalk yana märr‐ŋamathirrinydja yukurra ŋilimurruŋgu,
\q2 ga bitjan warray liŋgu ŋayi ŋuli gämanydja ŋamathama warray dhika ŋilimurrunha yolŋu'‐yulŋunhanydja goŋmirriyama warray.
\q1 
\v 32 Yo, ḻakaraŋa ŋuripa yolŋu'‐yulŋuwanydja ŋunhi walala ŋuli ḻuŋ'maranhamirri marrtji nhanukala yäkuyu,
\q2 garrwarkuŋana wal'ŋu ḻakaraŋa ŋuriki ḏalkarra'mirriwu yolŋu'‐yulŋuwu ga ŋurru'‐ŋurruŋuwu wal'ŋu,
\q2 liŋgu ŋayinydja ŋunhi God wokthunaramirri warray dhika wal'ŋu.
\b
\q1 
\v 33 Yo, nhuma yolŋu walala ŋuli yukurranha nhinanha mirithirrina yätjnha yanana,
\q2 ga ŋayinydja Garrayyunydja baṉḏanyguŋala mayaŋ' wäŋa,
\q2 märr ŋayi yurru ŋunhiyi wäŋa baṉḏanydhirri;
\q1 
\v 34 Baṉḏanynha ŋayi ŋunhi wäŋa ganbarknha,
\q2 ga yakana ŋayi ŋathanydja yukurra ŋuthan ŋunhiliyi wäŋaŋura,
\q2 liŋgu ŋuriŋina nhokala yätjthuna djämayu.
\q1 
\v 35 Yurru ŋayi ŋuli Garrayyu wekama warray gapu ŋurikinydja yolŋuwu dhuwurr‐ŋamakurru'wunydja,
\q2 märr yurru ŋayi ŋunhi ganbarktja gapumiriwnydja wäŋa gapumirriyirrina biyapul,
\q1 
\v 36 ga yolŋu walala marrtji yurru nhina ŋunhili gapumirriŋuranydja wäŋaŋura,
\q2 ga yakana walala yurru biyapulnydja ŋula marrya'yirri.
\q1 
\v 37 Yo, walala ŋuli ḻämu‐nherrulu ŋathanydja malanha ŋula nhänydja,
\q2 ga dhunupana ŋuli yana ŋuthanna mirithirrina dhirrimukthirrina dhikana wal'ŋu;
\q1 Ga ŋuliŋuruyi borum‐dharpaŋuru walala ŋuli gulkthundja marrtji mirithirrina guḻku'na, dhirrimuknha dhikana.
\q1 
\v 38 Yo, guŋga'yun warray ŋayinydja yukurra nhanŋuwaynydja ŋayi ŋunhi yolŋu'‐yulŋunha,
\q2 gäma marrtji dhika ḻatju'kuma warray,
\q2 märr walalaŋgu yumurrkuny'tja yurru marrtji miṯtji‐guḻku'thirri, ga wäyin malanha walalaŋgu yurru mirithirrina guḻku'na yana,
\q2 yakana walala yurru rirrikthun ga rakunydhirri marrtji murrmurryun.
\q1 
\v 39 Yo, wiripunydja ŋuli ŋunhi Godku yolŋu walala mariŋura yana,
\q2 walala ŋuli ŋayaŋu‐ŋonuŋdhinya warwuyu dhika nhäyu malaŋuyu.
\q1 Yurru Godtja yaka ḏukṯuk ŋurikinydjayi walalaŋgu yolŋu'‐yulŋuwu ŋaḻapaḻmirriwunydja wal'ŋu bathalamirriwunydja buŋgawamirriwunydja,
\q2 ŋunhi walala ŋuli muŋdhun yukurra wiripu‐guḻku'nha;
\q1 
\v 40 Djäma ŋayi ŋuli yulŋunydja walalaŋgala,
\q2 märr yurru walala yukurra wirwiryun ŋuliwitjanna baṉḏanygurruna räwakkurruna wäŋakurru,
\q2 yana yukurra marrtji buku‐wirwiryunna, ḻarruma marrtji dhukarrwuna.
\q1 
\v 41 Yurru ŋayi ŋuli Godthunydja ḻaw'marama ŋunhinhana yolŋunha ŋunhi ŋayi gurrupuruŋu ŋunhi yolŋumiriw,
\q2 ŋunhiyina ŋayi yurru märrama dhawaṯmaramanydja marimirriŋurunydja wäŋaŋuru, ga ŋayaŋu‐yätjthinyaramirriŋurunydja,
\q1 ga guŋga'yun ŋayi ŋuli goŋmirriyama bitjan walalaŋgu gurruṯu'mirrinhanydja,
\q2 märr yurru walala nhina yukurra galŋa‐djulŋithirri.
\q1 
\v 42 Yo, ŋuriŋi ŋayaŋu‐dhunupayunydja yolŋuyu yurru nhämana,
\q2 bala ŋayaŋunydja ŋayi yurru djulŋithirrina dhikana;
\q1 Yurru ŋunhi dhuwurr‐yätjtja yana nhina yukurra dhäruk‐mukthunna,
\q2 liŋgu bäyŋuna nhanŋu dhäruk waŋanharawu.
\b
\q1 
\v 43 Yo, ŋuli nhe be ḻiya‐djambatjtja, ga guyaŋirri nhe yukurra ŋamathama, dhunupa wal'ŋu,
\q2 guyaŋiyana biyakana nhenydja ŋuparrana dhäruknha ŋunhiyi.
\q1 Ga biyakana liŋguna‐wala yana wokthurrana Garraywunydja,
\q2 liŋgu ŋayinydja ŋunhi mirithirri ŋamakurru' warray, manymak warray Garray,
\q2 bitjan warray liŋgu ŋayi yukurra gäma warray nhanukalaynydja märr‐ŋamathinyarayu.
\c 110
\s1 Waŋgany buŋgawa ŋurruŋu wal'ŋu nherraṉara Godkuŋu
\s2 110:1–7 (The king appointed by the Lord)
\q1 
\v 1 Garraynydja God Waŋarrnydja waŋana ŋarrakalaŋuwalanydja Garraywala bitjarra,
\q2 “Go nhiniya galki dhiyala gay' ŋarrakala gali'ŋura dhunupa'ŋuŋura,
\q1 yana liŋgu ga galkinyamarama ŋarra yurru nhuŋu miriŋunha ŋunhi,
\q2 bala nhe yurru djalkirina dhärra walalaŋgala miriŋuwalanydja nhokalaŋuwala.”
\q1 
\v 2 Yo, Garrayyunydja liŋgu nhuna nherrara,
\q2 nhe yurru yukurra nhinana buŋgawana ŋurruŋuna wal'ŋu ŋunhala \f + \fr 110:2 \ft Jerusalem\f*Djurutjalamdja;
\q1 Ŋulaŋuruyinydja nhenydja yurru buŋgawana ŋuriki nhokalaŋuwu ŋunhi miriŋuwunydja walalaŋgu,
\q2 bukmakthirrina walala yurru bun'kumu‐djipthundja nhokala.
\q1 
\v 3 Yurru nhuŋuwaynydja gal'ŋu ŋunhinydja yolŋu walala yurru malthun marrtji yänana‐wala nhuŋu,
\q2 ŋuriŋinydja waluyu ŋunhi nhe yurru marrtji lili nhokalay nhe ganydjarryu bathalayu wal'ŋu,
\q2 djuḻkmaranharawu ŋuriki miriŋuwunydja walalaŋgu.
\q1 Yurru dhaṯthunmirrinydja walala yurru ŋunhiyi walala ŋuriŋina ḏarrtjalkthuna dhikana girri'yunydja mel‐wiḏi'yuna,
\q2 ga ŋunhi yolŋu walala yuḏayuḏa yurru marrtji galkithirrina nhokala ŋunhawalana dhuyulilina bukulili.
\b
\q1 
\v 4 Yo, ŋayipi Garrayyu Waŋarryunydja dhawu'‐nherrara yulŋunydja ŋunhiyi,
\q2 ga dhawu'‐nherraṉarawuynydja ŋunhiyi yurru yukurra dhärrana bitjanna liŋguna‐wala djambimiriwnha nhämiriwnha;
\q1 Ga dhuwala ŋayi bitjarra dhawu'mirriyaŋalanydja gam'.
\q1 Nhenydja dhuwala ḏalkarra'mirri ŋunhi yolŋu wal'ŋu,
\q2 dhärranydja nhe yurru yukurra gupaḏalnha‐wala, bitjanna liŋguna yurru,
\q1 yurru balanyarana nhe yurru ŋunhi ḏalkarra'mirrinydja gam' bitjan \f + \fr 110:4 \ft Melchizedek\f*Milkitjitik yäku yolŋu,
\q2 ganaŋ'thun yukurra yana wal'ŋu wiripu‐guḻku'walanydja ḏalkarra'mirriwala walalaŋgala.
\q1 
\v 5 Yo, ŋayipinydja Garraynydja yukurra dhärra dhunupa'ŋuŋura yana gali'ŋuranydja wal'ŋu nhokala,
\q1 ga ŋulinyaramirriyunydja ŋunhi ŋayi boŋguŋu ŋaramurryina wirrkina,
\q2 bala ŋayi boŋguŋu buŋuna marrtji baḏuwaḏuyurruna buŋgawanhanydja walalanha,
\q2 warrpam'thurruna yana buwayakkuŋuna biyakuna.
\q1 
\v 6 Yo, dhä‐wirrka'yundja ŋayi yurru mala‐yarr'yundja bitjandja ŋunhi dhuwurr‐yätjmirrinhanydja miṯtjinha,
\q2 bala ŋayi yurru dhä‐ḏir'yunna walalanha yana yulŋunydja warrpam'thunna,
\q1 ga wäŋanydja ŋunhi yurru gungama ŋuriŋi rakunymirriwalanydja rumbalyu,
\q2 Walala yurru marrtji ŋorra warrpam'nha murrmurryunarana rakunymirrina,
\q2 yolŋu'‐yulŋu ŋunhi ga walalaŋgu ŋurruŋumirri.
\q1 
\v 7 Ga ŋayipinydja yurru Garraynydja marrtjina yukurra lili,
\q2 marrtjinydja ŋayi yurru yukurra ŋuliwitjandhinayi gapumirrikurruna wäŋakurrunydja,
\q2 ḻuka marrtji ŋayi yurru yukurra bala.
\q1 Bala ŋayi yurru dhärranydja wuṉḏaŋarrnha dhikana wal'ŋu,
\q2 djuḻkmaramana yurru ŋunhi miriŋunhanydja.
\c 115
\s1 Waŋganyguna yana yuwalkkuma Godku ŋilimurru wokthundja yukurra yurru
\s2 115:1–18 (Praise the one true God)
\q1 
\v 1 Garray, nhepina dhuwala waŋgany yana dhapirrktja ŋanyanydja dhikanydja,
\q2 yakana ŋanapurrunhanydja ŋuli ŋula yolthu ḻakaraŋu dhapirrk‐ḻakaraŋu;
\q1 Nhepina waŋganynha yana märr‐ŋamathinyaramirrinydja ga goyulŋuny'tja,
\q2 liŋgu nhe ŋuli dhärra yukurra yana djambimiriwnha.
\q1 
\v 2 Nhäku warray walala ŋuli yolŋu'‐yulŋuyu ŋuriŋi märr‐yuwalkthinyamiriwyunydja walalay dhä‐wirrka'yun ŋanapurrunha bitjandja,
\q2 “Wanhaka dhika be nhumalaŋgu Godtja?” bitjan.
\q1 
\v 3 Ŋanapurruŋgunydja God ŋunha djiwarr'ŋura warray,
\q2 ga djämanydja ŋayi yukurra ŋuriŋi nhanukalay ŋayi yana ḏukṯukthunydja malaŋuyu.
\q1 
\v 4 Ga nhumalaŋgunydja waŋarr walŋamiriw warray,
\q2 dharpana ŋula nhäna guṉḏana yana, goŋbuynha yana djämawuynydja.
\q1 
\v 5 Yo, nhumalaŋgunydja ŋunhi waŋarr mala dhurrwaramirri warray yulŋunydja,
\q2 yurru bäyŋuna walala yurru waŋanydja;
\q2 maŋutjimirri walala, yurru bäyŋuna walala yurru nhämanydja.
\q1 
\v 6 Buthurumirri warray ŋayi yulŋunydja ga ŋurrumirri,
\q2 yurru bäyŋuna ŋayi waŋgi'yundja yurru wo ŋämanydja.
\q1 
\v 7 Ŋarambiya'mirri ga djalkirimirri ŋayi,
\q2 yurru yakana ŋayi yurru ŋarambiya'yunydja mulka ŋula nhä,
\q2 ga marrtji ŋayi yurru djalkiriyu, bäyŋuna.
\q1 Ga bäyŋu warray ŋayi yurru waŋa ŋula waŋgany dhäruk.
\q1 
\v 8 Yo, ŋunhanydja walala ŋunhi walala ŋuli djäma ŋunhiyi goŋbuynha waŋarrnha ŋula nhänha,
\q2 ga ŋunhinydja yolŋu'‐yulŋu ŋunhi walala ŋuli ŋayaŋu‐nherraṉmirri ŋunhimalayi ŋula nhäkala,
\q1 walalanydja yurru yana bitjanna ḻiya‐dhumukthirrina guyaŋinyamiriwnha, bawa'mirrina yurru,
\q2 bitjan yana liŋgu bitjan ŋunhiyi waŋarr ŋunhi walala ŋuli djäma goŋdhu.
\b
\q1 
\v 9 Nhuma yolŋu walala \f + \fr 115:9 \ft Israel\f*Yitjuralpuyŋu,
\q2 märr‐nherraṉmiya nhanukalaynha Garraywalana yana;
\q1 Ŋayi warray nhumalanhanydja guŋga'yun ŋuli yukurra,
\q2 ga gunganhamirriyama nhumalanha ŋula nhäŋuru.
\q1 
\v 10 Ga nhuma ḏalkarra'mirri mala Godku,
\q2 biyaka märr‐nherraṉmiyana märr‐yuwalkthiyana Garraywu;
\q1 Ŋayi nhumalanhanydja guŋga'yun yukurra ŋuli,
\q2 ga gunganhamirriyama ŋuli ŋayipi yana.
\q1 
\v 11 Nhuma yolŋu'‐yulŋu ŋunhi nhuma ŋuli yukurra rom‐wiyaṉirri Godkunydja,
\q2 biyaka märr‐nherraṉmiya nhanukalaynha yana Garraywalana,
\q2 liŋgu ŋayipi waŋgany nhumalaŋgunydja guŋga'yunaramirri,
\q2 ga gunganharamirri ŋayi.
\q1 
\v 12 Bitjan liŋgu Garrayyunydja Godthunydja yukurra guyaŋirri ŋilimurrunhanydja,
\q2 goŋmirriyama ŋayi yukurra yurru ŋilimurrunha yulŋunydja.
\q1 Wirrki yana wal'ŋu ŋayi yurru goŋmirriyamanydja ŋilimurrunha nhanŋuwaynydja ŋunhinydja dhulŋuŋunydja yolŋunha walalanha,
\q2 ga bitjandhi liŋgu ŋayi yurru guŋga'yun nhanŋuway ŋunhi ḏalkarra'mirrinhanydja walalanha.
\q1 
\v 13 Yo, ŋunhi ŋayi yurru ŋula yol yolŋu märr‐ŋal'yun nhanukalay, ga dhäruk ŋanya märrama,
\q2 ŋayinydja ŋunhiyinydjayi yolŋu goŋmirriyanharana Garraywuŋunydja,
\q2 bäythi ŋunhi ŋayi be bathala wal'ŋu ga yumurrku'.
\b
\q1 
\v 14 Ŋarranydja yukurra dhuwala bukumirriyama yulŋunydja,
\q2 märr yurru ŋayi Garrayyunydja goŋmirriyama muka nhumalanha ga biyapul nhumalaŋgu yumurrku'nha.
\q1 
\v 15 Ga yuwalk yana Garrayyu yukurra goŋmirriyamanydja nhumalanha,
\q2 bitjan ŋayi yukurra gäma nhumalanha ḻatju'kuma dhika wal'ŋu,
\q2 ŋuriŋinydja Godthu Waŋarryu ŋunhi ŋayi djäma ŋunha djiwarr' ga dhuwala munatha'.
\q1 
\v 16 Ŋunha djiwarrny'tja wäŋa nhanŋuway yana waŋganygu dhulŋuŋu Godku,
\q2 ga dhuwalanydja gay munathany'tja wäŋa ŋayi wekaŋala ŋanapurruŋgala yolŋu'‐yulŋuwala goŋlili.
\q1 
\v 17 Dhuwurr‐yätjmirri yolŋu walala ŋunhi liŋguna murrmurryurrunana,
\q2 yaka walala yukurra goŋmirriyirrinydja wokthundja yukurra Garraywu.
\q1 
\v 18 Ga ŋilimurru dhuwala ŋunhi ŋilimurru nhina yukurra walŋamirri,
\q2 ŋilimurru gul' buku‐wurrpanna ŋanya Godnhana,
\q2 dhiyaŋu‐wala ga bitjanna liŋguna yurru‐wala.
\b
\q1 Garray, ŋanapurru dhuwala wokthunna yukurra nhuŋu yulŋunydja.
\c 117
\s1 Wokthurra Garraywu
\s2 117:1–2 (Praise the Lord)
\q1 
\v 1 Go bukmak bäpurru yolŋu walala, wokthurrana Garraywu;
\q2 Goŋmirriyana Garraywu, nhuma yolŋu walala wäŋakurru buku‐ḻiw'marama.
\q1 
\v 2 Wirrkina ŋayi yukurra märr‐gorruma ŋilimurruŋgunydja;
\q2 ŋayi yukurra ŋoy‐ŋamathirri yuwalkkumana yana.
\q1 Ŋayipi waŋgany yana märr‐yuwalkmirrinydja Garray,
\q2 liŋgu dhärranydja ŋayi yukurra yurru bitjanna liŋguna djambimiriw.
\q1 Wokthunna gul' Garraywuna.
\c 119
\s1 Garraywu ḻatju' rom
\s2 119:9–20, 89, 97–105
\q1 
\v 9 Nhaltjurru dhika ŋuli yuṯanydja ḏarramu nhini yukirri ḏarrtjalk ŋula nhämiriw?
\q2 Ŋuli ŋayi yurru Godku romgu malthundja marrtji bala,
\q2 ŋayi yurru nhina yukurra ŋamathamana dhika wal'ŋu.
\q1 
\v 10 Garray, ŋarra yukurra ḏukṯukthirri nhuŋu malthunarawu,
\q2 nhuŋuwaynha waŋganyguna ŋarra yukurra warrya'yun;
\q1 Mulkiya ŋarranha galkikuŋa wal'ŋu,
\q2 märr ŋarra yakana yurru yarrkthun nhokala dhärukŋuru.
\q1 
\v 11 Liŋguna ŋarra nhuŋuwaynha yana dhäruk ruwamŋu nherraranydja ŋarrakalay ŋayaŋulilinydja,
\q2 märr ŋarra yurru yakana rom‐waḏatjtjun nhunanydja.
\q1 
\v 12 Ŋarra yukurra wokthunna nhuŋu, Garray,
\q2 marŋgikuŋa ŋarranha nhokalayŋuwu romgu.
\q1 
\v 13 Dhiyaŋu ŋarrakala dhärukthu ŋarra ŋuli waŋa marrtji bala,
\q1 ḻakaramana ŋuli yukurra nhuŋu romnha malanha.
\q1 
\v 14 Yaka ŋarranydja rrupiyawu ḏukṯuk ŋal'yunmaranharawu,
\q2 liŋgu nhokalana dhiyaŋu romdhu ŋarranydja yukurra märr‐ḏaw'yun,
\q2 galŋa‐ŋamathinyamarama ŋuli yukurra.
\q1 
\v 15 Ŋarra yurru bitjanna liŋguna guyaŋirri yukurra nhuŋuwaynha dhäruk,
\q2 muḻkurr‐nherraṉmirri nhokiyingalana romlili.
\q1 
\v 16 Galŋa‐ḻayyunaramirrina rom ŋarra ŋuli maḻŋ'marama nhuŋunydja,
\q1 yakana yurru ŋarra meṉgumanydja nhuŋu dhäruktja.
\b
\q1 
\v 17 Garray, ŋarranydja dhuwala djämamirri yolŋu nhuŋu,
\q2 djäka yukirriya ŋarraku,
\q2 märr ŋarra yurru nhina yukurra, ŋamathama dhika wal'u,
\q2 ga malthun yurru nhuŋuway dhärukku.
\q1 
\v 18 Ḻapmaraŋa ŋarranha maŋutji,
\q2 märr ŋarra yurru nhäma dharaŋan dhäruktja nhuŋu,
\q1 ga maḻŋ'marama yurru ḻatju'mirrina dhika, yuwalkŋuna wal'ŋu rom.
\q1 
\v 19 Ŋarranydja dhuwala märr‐gurriri nhina yurru dhiyala munatha'ŋuranydja,
\q2 yaka djuḻuḻ'maraŋa ŋarrakala romdja nhuŋuway!
\q1 
\v 20 Ḏukṯukthirri ŋarra yukurra dhuwala wirrkina dhika,
\q2 bitjanna liŋguna ŋarra yukurra ŋoy‐ŋaḏupthun nhokalaŋuwu romgunydja marŋgithinyarawu.
\b
\q1 
\v 89 Garray, nhuŋunydja dhäruk djingaryunna yukurra yurru gupaḏalŋuna,
\q2 bitjanna liŋguna dhärra yukurra nininyŋuna ŋunha djiwarr'ŋurana.
\b
\q1 
\v 97 Ŋarra yukurra wirrkina märr‐ŋamathirri nhokalaŋuwunydja romgu,
\q2 guyaŋirrinydja ŋarra ŋuli bitjan liŋgu walu‐ŋupanna.
\q1 
\v 98 Dhiyaŋu nhokala dhärukthu ŋarranha ŋuli wekama dhunupana guyaŋinyara,
\q2 bala ŋarra ŋuli djuḻkmaramana ŋayan'mirrinha walalanha dhiyaŋu dhärukthunydja.
\q1 
\v 99 Ŋarranydja wirrki warray marŋgi nhokalaŋuwu romgu,
\q2 djuḻkmaramana yukurra ŋunhanydja walalanha yolŋu'‐yulŋunha, ŋunhi walala ŋarranha marŋgikuŋala,
\q1 liŋgu bitjan liŋgu ŋarra ŋuli yukurra märryu‐ŋupan nhaltjan nhe ŋuli ŋarraku ḻakarama.
\q1 
\v 100 Wirrki warray ŋarra marŋgi nhokalaŋuwu romgunydja,
\q2 djuḻkmarama yukurra ŋunha ḏilkurruwurrunhanydja yolŋu'‐yulŋunha,
\q2 liŋgu ŋarra yukurra ŋayathama baṯ bitjanna nhuŋu rom.
\b
\q1 
\v 101 Yaka ŋarra yukurra yätjkurru dhukarrkurru marrtji,
\q2 ḻäy‐yarryun ŋarra yukurra ŋuruku dhukarrwu,
\q2 liŋgu wirrki ŋarra ḏukṯuk nhokalaŋuwu dhärukku malthunarawu.
\q1 
\v 102 Nhe muka ŋarranhanydja marŋgikuŋala;
\q2 yakana ŋarranydja yurru ŋapa‐wilyun nhokalanydja romŋuru, ganan yurru.
\b
\q1 
\v 103 Garray, nhuŋunydja dhäruk ḻatju'na dhikana ŋanya,
\q2 dhäkay‐djulŋina bitjan guku.
\q1 
\v 104 Nhokalana dhärukthu ŋarranha ŋuli yukurra marŋgikumanydja,
\q2 bala ŋarranydja ŋuli marŋgithirri warray nhokalaŋuwu yuwalkŋuwuna wal'ŋu dhukarrwu,
\q2 ga dhiyakuyina märrwu ŋarra yukurra yarryunna ŋuriki bothinyarayŋuwunydja romgu.
\b
\q1 
\v 105 Garray, dhäruktja dhuwala nhuŋu bitjan baḏayala'na;
\q1 Ŋarra ŋuli marrtji balakurruyi baḏayala'kurru, ga yakana ŋula galkirrinydja,
\q2 liŋgu nhokala ŋuriŋi dhärukthu djarraṯawun'kuma ŋuli yukurra ŋarraku dhukarr,
\q2 milkuma ŋuli dhukarr marrtjinyarawu bala.
\c 121
\s1 Garray dhuwala ŋilimurruŋgu watjarr'ŋu
\s2 121:1–8 (The Lord our protector)
\q1 
\v 1 Yolthu yurru ŋarranha guŋga'yundja?
\q2 Wanhaŋuru dhika? . . . Ŋulaŋuru bukuŋuru gay'?
\q1 
\v 2 Garray yana ŋayipi ŋarraku guŋga'yunaramirri,
\q2 ŋunhiyi ŋunhi ŋayi bokmarama djiwarr' ga munatha' wäŋa dhuwala.
\q1 
\v 3 Yakana ŋarra yurru galkirri,
\q2 bili ŋayina ŋarranha yukurra mulka, wuṉḏaŋarrkuma ŋuli.
\q1 
\v 4 Bitjanna liŋguna ŋayi ŋuli mukthunna djäka;
\q2 yaka warray ŋayinydja ŋuli ŋorra, ŋula gonha'yun.
\b
\q1 
\v 5 Yo, Garraynydja dhuwala watjarr‐mulkanharamirri ŋilimurruŋgu,
\q2 ŋayinydja dhuwala dhika ŋayi bäyma galki,
\q2 monyguma yukurra ŋilimurrunha gunganhamirriyama ŋula nhäŋuru malaŋuŋuru.
\q1 
\v 6 Yakana nhuna yurru waluyu räwakkuma,
\q2 ga munhakunydja yakana ŋuli ŋula nhuna baymatthurru warumuktja;
\q1 Yakana yurru nhuna ŋula nhäyu buma,
\q1 bili nhenydja Garraywala goŋŋura.
\q1 
\v 7 Ŋayi ŋuli nhuŋu yukurra gungama ŋula nhäŋuru yätjmirriwalanydja walalaŋgala,
\q2 djäka yukurra ŋuli nhuŋu, walŋakuma nhuna.
\b
\q1 
\v 8 Nhe yurru marrtji ŋula wanhamala barrkulili,
\q2 ga ŋayinydja yurru Garray nhuŋu djäka yukurra;
\q1 Ga roŋiyirri nhe ŋuli marrtji liliyi,
\q2 mukthun yana ŋayi nhuŋu yurru Garraynydja marrtji goŋ‐nherraṉmirri.
\q1 Bitjanna liŋgu nhe yurru marrtji walŋana yana,
\q2 dhiyaŋu‐wala ga bitjanna liŋguna, weyinŋumirrina‐wala yurru.
\c 130
\s1 Märrliliyaŋa Garraywala
\s2 130:1–8 (A prayer for help)
\q1 
\v 1 Garray, guŋga'yurra ŋarranha,
\q2 liŋgu ŋarra dhuwala ŋayaŋu‐ḏaḏawyunna yukurra.
\q1 
\v 2 Ŋäka ŋarranha rirrakaynydja, Garray,
\q2 ga guŋga'yurrana go.
\q1 
\v 3 Ŋunhi bini nhe bothurrunydja ŋanapurruŋgu yätjtja rom malanha,
\q2 nhe bini ŋanapurrunha bukmaknha murr'maranha,
\q1 
\v 4 Yurru nhenydja bäy‐ḻakarama warray ŋuli ŋanapurruŋgu,
\q2 märr yurru ŋanapurru borrk‐barrarirri nhuŋu,
\q2 bala märramana yurru nhuŋu dhäruk.
\b
\q1 
\v 5 Ŋe. Bulnha ŋarra yurru galkun gatjpu'yun yukurra nhanŋu Garraywu.
\q1 Ŋarranydja yukurra märr‐yuwalkthirri dhärukku nhanŋu,
\q2 Yuwalk ŋayi yurru ŋarranha guŋga'yundja.
\q1 
\v 6 Yo, galkundja ŋarra ŋuli yukurra Garraywu,
\q2 bitjandhi liŋgu bitjan yolŋu ŋuli nhina marrtji bira'yun dhukarr‐nhämana munha‐ŋupan,
\q2 yana liŋgu ga wäŋa ŋuli djaḏaw'yun.
\b
\q1 
\v 7 Nhuma \f + \fr 130:7 \ft Israel\f*Yitjuralpuynydja yolŋu'‐yulŋu, biyakayi märr‐nherraṉmiya Garraywala.
\q1 liŋgu ŋayaŋu‐ŋamathinyara nhanŋunydja ḻatju'na dhikana, djambimiriwnha.
\q1 Dhunupana ŋayi yurru nhuna guŋga'yunna,
\q2 yakana yurru ŋayi waŋa nhuŋu yaka'yundja.
\q1 
\v 8 Ŋayi yurru yana yätjtja dhuwurr warrkuḻumana nhanukalaŋuwala miṯtjiwalanydja,
\q2 walŋakumana yurru walalanha dhawaṯmarama ŋula yolkala goŋŋuru.
\c 139
\s1 Godtja Birrka'mirriŋura
\s2 139:1–24 (God’s complete knowledge and care)
\q1 
\v 1 Garray nhe liŋguna nhäŋa'‐nhaŋala ŋarranha ŋayaŋu;
\q2 Nhe marŋgi ŋarraku bukmakku yana,
\q2 ga marŋgina nhe nhä ŋarra yukurra djäma.
\q1 
\v 2 Nhe ŋuli nhäma ŋarranha nhinanhara ga gaŋgathinyara,
\q2 ga bitjandhiyi liŋgu nhe marŋgina nhaltjan ŋarra ŋuli yukurra guyaŋirri.
\q1 
\v 3 Ŋunhi ŋarra yurru marrtji ŋula wanhamala,
\q2 nhenydja ŋuli ŋarranha nhäma warray;
\q1 Ga ŋunhi ŋarra ŋuli mukthun nhina,
\q2 nhe marŋgina ŋarraku bukmaknha yana.
\q1 
\v 4 Nhe ŋuli marŋgithirri ŋathil'yun ŋarraku dhärukku,
\q2 ŋunhi ŋarra ŋuli gäthuraŋga dhurrwara ḻapthun waŋanharawu.
\q1 
\v 5 Marrtjinydja nhe ŋuli ŋurruŋu, ŋurru‐warryun ŋarranha,
\q2 ga munguyun nhe ŋuli, nhepi yana;
\q1 Bämara'yun ŋarranha nhe ŋuli bitjanna liŋguna,
\q2 goŋ‐nherraṉmirri marrtji ŋarraku ŋuli.
\b
\q1 
\v 6 Ḻatju'na ŋiniya!
\q1 Biyapulnha‐wala garrwarnha nhuŋunydja guyaŋinyara barrkuna,
\q2 yakana ŋarra yukurra mulka ŋarrakalay muḻkurryu.
\q1 
\v 7 Garray, nhenydja dhuwala bawala'mirriŋurana.
\q1 Wanhamala ŋarra yurru waṉḏirrinydja? . . . winya'yundja nhokala?
\q1 
\v 8 Ŋunhi ŋarra dhawuṯthurru djiwarr'lili ŋuli, ga nhenydja ŋunhala warray,
\q2 ga ŋuli ŋarra yarrupthurru, rakunymirriwala wäŋalili buni, nhenydja ŋunhalayi.
\q1 
\v 9-10 Ŋuli ŋarra winya'yurru barrkulili wäŋalili, bena‐wala barrkulilina birr',
\q2 nhenydja ŋunhalayi, ŋurru‐warryun ŋarranha ŋuli,
\q2 ga guŋga'yun ŋarranha marrtji.
\q1 
\v 11 Ŋuli ŋarra ŋula djuḻuḻ'yurru buku munhalili, gulkuruna ŋunhiyi,
\q2 liŋgu munhakunydja dhuwala balanyara bitjan walupuy yana nhuŋunydja;
\q1 
\v 12 Nhuŋunydja djarraṯawun' warrpam warray räkukuma yukurra munhanydja;
\q2 Nhe ŋuli ŋarranha nhäma munhalilinydja bitjan yana liŋgu bitjan walupuy.
\b
\q1 
\v 13 Garray nhepi ŋarranha ŋamaŋamayurruna,
\q2 nhe bokmara ŋarranha ŋunha ŋäṉḏiwala guḻunŋura.
\q1 
\v 14 Ḻatju'kuŋala nhe dhika bokmara ŋarranha rumbalnydja, dhapirrkkuŋalana dhika wal'ŋu,
\q2 bukmak nhuŋu djämanydja ḻatju'na dhika;
\q1 Ŋarranydja yukurra wokthun nhuŋu wirrkina.
\q1 
\v 15 Nhäŋala nhe ŋarranha yukurrana,
\q2 ŋunhi ŋarra yutjuwaḻaŋ'ka yana yothuŋga ŋunha ŋäṉḏiwalaŋga rumbalŋura;
\q1 
\v 16 Nhenydja ŋäthili ŋarraku marŋgi, liŋgu nhe nhäŋala ŋarranha ŋuthanara marrtjinyara,
\q2 yurruna ŋarra dhawal‐wuyaŋina,
\q2 ga bitjarrayi nhe dhukarr gurrunhara ŋathil'yurruna ŋarraku.
\q1 
\v 17 Waŋarr God, nhuŋu guyaŋinyaranydja barrkuna,
\q2 yakana ŋarra yukurra guyaŋirri ga mulka.
\q1 Nhokuŋu guyaŋinyara guḻku'na mirithirrina, biyapulnha guḻku'.
\q1 
\v 18 Ŋunhi ŋarra ŋuli bothurrunydja, yakana ŋuli buku‐mulki,
\q2 bitjanna liŋguna nhe guyaŋirri yukurra ŋarranha.
\q1 Ŋunhi ŋarra ŋuli yakurrthirri,
\q2 nhenydja ŋunhiliyi warray;
\q1 Ga ŋunhi ŋarra ŋuli gaŋgathirri yakurrŋuru,
\q2 nhenydja mukthun yana ŋunhili ŋarrakala galki.
\b
\q1 
\v 19 Garray! Nhäku warray nhe ŋuli yakanydja buma ŋunhi yätjmirrinhanydja yolŋu'‐yulŋunha?
\q2 Yana walala bini winya'yunana‐wala ŋarrakala.
\q1 
\v 20 Bitjanna liŋgu walala ŋuli waŋa yätjkumanydja nhuna.
\q1 Garray, wirrkina ŋarra yukurra ŋaramurryirri walalaŋgu,
\q1 liŋgu nhuŋu walala yukurra ŋaramurryirri.
\q1 
\v 21 Ŋarra yukurra yarryunna walalaŋgu, yakana ḏukṯukthirri,
\q2 liŋgu walala yukurra nhuŋu yarryun.
\q1 
\v 22 Yuwalknha ŋarra yukurra yaka ḏukṯukthirri walalaŋgu, yarryunna yukurra,
\q1 yakana ŋarra yurru walalanha ḻundukuma.
\b
\q1 
\v 23 Garray, nhäŋa'‐nhaŋa ŋarrakala ŋayaŋulili,
\q2 ḻarru'‐ḻarruŋa ga gatjarr'yurra ŋarraku guyaŋinyara;
\q1 
\v 24 Ḻakaraŋa dhunupamirriyaŋa nhä yukurra ŋarrakala yätj ŋorra ŋayaŋuŋura ga ḻiyaŋura,
\q2 nhä ŋarra yukurra balaŋu djuḻuḻ'marama nhokala.
\b
\q1 Garray! Gäŋana ŋarranha, ŋurru‐warryurra dhunupakurru dhukarrkurru,
\q2 ŋulawitjarra bili walŋamirrikurru dhukarrkurru. Ga liŋguna.
\c 148
\s1 Wokthurrana Garraywu go
\s2 148:1–14 (Let everything praise the Lord)
\q1 
\v 1-2 Wokthurrana Garraywu go, nhuma bukmak yana djiwarr'wuynydja nhä malanha.
\q1 Wokthurrana Garraywuna nhuma yolŋu walala djiwarr'wuy, nhanŋu dhäruk‐märranhamirri walala,
\q2 wokthurrana nhanŋu, goŋmirriyiyana walala.
\q1 
\v 3 Nhe walu ga ŋaḻindi,
\q2 ga wiripuwurru ganyu' walala, wokthurrayi nhumanydja nhanŋu.
\q1 
\v 4 Nhe gärak, ga waŋupini malanha,
\q2 nhumanydja wokthurrayi yukirriya walala, biyakayi bili.
\q1 
\v 5 Nhumanydja dhuwalinydja malanha djiwarr'puyŋunydja, wokthurra bukmaknha yana,
\q2 yäkuna garrwarkuŋa ŋanya Garraynhana.
\q1 Bili ŋayi Garray waŋana, dhäruk waŋgany,
\q2 bala yana marrtjina nhä malanha maḻŋ'thurrunana;
\q1 
\v 6 Ŋayi nherra'‐nhirrara nhumalanha nininygarrmurana,
\q2 nhuma dhuwali bukmak yana djiwarr'puyŋunydja;
\q1 Wokthurrana walala,
\q2 märr‐yiŋgathiyana Garraywu.
\b
\q1 
\v 7 Ga nhuma bukmak yana munatha'wuynydja nhä malanha,
\q1 Wokthurrayi Garraywuna,
\q2 nhuma guya walala, ga wiripu‐guḻku' nhä malanha ŋunhi marrtji ŋorra gapuŋura dhuḻupurrŋura,
\q2 wokthurrana nhumanydja gatjuy.
\q1 
\v 8 Nhe maḻwurrk, ga maykarraṉ', ga wärrk, nhanŋu dhäruk‐malthunaramirri walala,
\q2 wokthurrana nhanŋu Garraywu.
\b
\q1 
\v 9 Ga nhe wäŋa ŋaraka, buku ga djulam,
\q2 borummirri dharpa ga retja malanha,
\q2 wokthurrana walala nhumanydja.
\b
\q1 
\v 10 Ga nhuma wäyin walala boḏinymirri ga maḏakarritjmirri,
\q2 gaḻ'yunaramirri ga buṯthunaramirri,
\q2 ḏiltjiwuy ga raŋiwuy,
\q2 wokthurrana nhumanydja bukmaknha yana.
\b
\q1 
\v 11-12 Nhuma yolŋu walala, buŋgawamirri ŋurru'‐ŋurruŋu ga wiripu‐guḻku' yolŋu walala,
\q2 yuḏayuḏa yawirriny' dhäykawurru ga ḏarramuwurru,
\q2 worru'‐wurruŋu ga djamarrkuḻi',
\q2 nhumanydja wokthurrayi Garraywu, goŋmirriyiyana walala.
\q1 
\v 13 Nhuma dhuwala bukmak yana munatha'wuynydja nhä malanha,
\q2 wokthurrana walala,
\q2 märr‐yiŋgathiyana Garraywu.
\q1 Liŋgu Garraynydja dhuwala yäku‐ḏumurru, djuḻkmarama yukurra wiripu‐guḻku'nhanydja;
\q1 Ŋayinydja yukurra nhina ŋunha djeŋarra'na dhikana, garrkuḻuknha,
\q2 biyapulnha‐wala wal'ŋu garrwarnha,
\q2 buku‐nyumaramana yukurra munatha'na ga djiwarr'nha.
\b
\q1 
\v 14 Garraynydja yukurra wirrkina ŋayaŋu‐ŋamathirri nhanukalayŋuwu yolŋu'‐yulŋuwu;
\q1 Ŋilimurru \f + \fr 148:14 \ft Israel\f*Yitjuralpuyŋunydja marrkapmirrina walala nhanŋu,
\q2 ŋayi ŋilimurrunha ganydjarrmirriyaŋala,
\q2 märr ŋilimurrunydja yurru nhanŋu wokthunna.
\q1 Wokthurrana go Garraywuna. 
