\v 20 ¿\w Cuál|strong="H4310"\w* \w entre|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \tl ʼelohim\tl* \w de|strong="H3588"\w* esas tierras \w libró|strong="H5337"\w* \w su|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w mi|strong="H3389"\w* \w mano|strong="H3027"\w*? ¿\nd \w Yavé|strong="H3068"\w*\nd* libraría \w a|strong="H3068"\w* Jerusalén \w de|strong="H3588"\w* \w mi|strong="H3389"\w* \w mano|strong="H3027"\w*?
\p 
\v 21 \w Pero|strong="H3588"\w* \w ellos|strong="H1931"\w* callaron \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w respondieron|strong="H6030"\w* \w ni|strong="H3808"\w* una \w palabra|strong="H1697"\w*, \w porque|strong="H3588"\w* \w la|strong="H1931"\w* orden del \w rey|strong="H4428"\w* decía: \w No|strong="H3808"\w* \w le|strong="H1931"\w* respondan.
\p 
\v 22 Entonces Eliaquim, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Hilcías|strong="H2518"\w*, \w mayordomo|strong="H5921"\w* \w del|strong="H5921"\w* palacio, \w Sebna|strong="H7644"\w*, \w el|strong="H5921"\w* \w escriba|strong="H5608"\w*, \w y|strong="H5921"\w* Joa, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Asaf, \w el|strong="H5921"\w* cronista, \w se|strong="H5921"\w* presentaron ante Ezequías \w con|strong="H5921"\w* sus ropas rasgadas \w y|strong="H5921"\w* \w le|strong="H5921"\w* \w declararon|strong="H5046"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w del|strong="H5921"\w* \tl \w Rabsaces|strong="H7262"\w*\tl*.
\c 37
\s1 Fracaso y muerte de Senaquerrib, rey de Asiria
\p 
\v 1 \w Sucedió|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* el \w rey|strong="H4428"\w* Ezequías lo \w oyó|strong="H8085"\w*, también \w rasgó|strong="H7167"\w* sus ropas. \w Se|strong="H1961"\w* \w cubrió|strong="H3680"\w* de tela áspera y \w fue|strong="H1961"\w* \w a|strong="H3068"\w* la \w Casa|strong="H1004"\w* de \nd \w Yavé|strong="H3068"\w*\nd*.
\v 2 \w Envió|strong="H7971"\w* \w a|strong="H3068"\w* Eliaquim, \w mayordomo|strong="H5921"\w* \w de|strong="H5921"\w* palacio, \w a|strong="H3068"\w* \w Sebna|strong="H7644"\w*, \w el|strong="H5921"\w* \w escriba|strong="H5608"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w más|strong="H5921"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*, \w cubiertos|strong="H3680"\w* \w de|strong="H5921"\w* tela áspera, \w al|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Amoz,
\v 3 \w y|strong="H3588"\w* le dijeron: Ezequías dijo: \w Hoy|strong="H3117"\w* \w es|strong="H2088"\w* un \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w angustia|strong="H6869"\w*, castigo \w y|strong="H3588"\w* vergüenza. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* llegaron \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* cuello del útero, \w pero|strong="H3588"\w* \w no|strong="H3588"\w* hay \w fuerza|strong="H3581"\w* \w para|strong="H5704"\w* dar \w a|strong="H3068"\w* luz.
\v 4 Quizás \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* haya escuchado las \w palabras|strong="H1697"\w* del \tl \w Rabsaces|strong="H7262"\w*\tl*, \w a|strong="H3068"\w* quien su amo, el \w rey|strong="H4428"\w* \w de|strong="H1697"\w* Asiria, \w mandó|strong="H7971"\w* para \w provocar|strong="H2778"\w* \w al|strong="H4428"\w* \nd ʼElohim\nd* \w viviente|strong="H2416"\w*, y \w reprenda|strong="H3198"\w* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w escuchó|strong="H8085"\w*. \w Por|strong="H1157"\w* tanto, haz \w oración|strong="H8605"\w* \w por|strong="H1157"\w* el remanente \w que|strong="H1697"\w* queda.
\p 
\v 5 Los esclavos del \w rey|strong="H4428"\w* Ezequías fueron \w a|strong="H3068"\w* \w Isaías|strong="H3470"\w*,
\v 6 quien les respondió: Digan \w a|strong="H3068"\w* su amo: \nd \w Yavé|strong="H3068"\w*\nd* \w dice|strong="H1697"\w*: \wj \w No|strong="H6440"\w* \w temas|strong="H3372"\w* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* \w oíste|strong="H8085"\w*, con las cuales los esclavos del \w rey|strong="H4428"\w* \w de|strong="H6440"\w* Asiria \w me|strong="H3541"\w* vituperaron.\wj*
\v 7 \wj \w Ciertamente|strong="H2005"\w* \w pondré|strong="H5414"\w* cierto \w espíritu|strong="H7307"\w* en \w él|strong="H5307"\w*. \w Oirá|strong="H8085"\w* un \w rumor|strong="H8052"\w*, regresará \w a|strong="H3068"\w* su tierra, y en su tierra lo \w haré|strong="H5414"\w* \w caer|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*.\wj*
\p 
\v 8 \w Así|strong="H3588"\w* \w que|strong="H3588"\w* \w el|strong="H5921"\w* \tl \w Rabsaces|strong="H7262"\w*\tl*, quien \w oyó|strong="H8085"\w* \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria \w se|strong="H5921"\w* retiró \w de|strong="H5921"\w* Laquis, regresó \w y|strong="H3588"\w* \w lo|strong="H5921"\w* \w halló|strong="H4672"\w* \w cuando|strong="H3588"\w* combatía \w contra|strong="H5921"\w* \w Libna|strong="H3841"\w*.
\v 9 \w Al|strong="H5921"\w* \w oír|strong="H8085"\w* \w que|strong="H5921"\w* Tirraca, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Etiopía|strong="H3568"\w*, \w salió|strong="H3318"\w* \w a|strong="H3068"\w* luchar \w contra|strong="H5921"\w* \w él|strong="H5921"\w*, \add el rey de Asiria\add* \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* Ezequías \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w le|strong="H5921"\w* dijeran:
\v 10 Digan \w a|strong="H3068"\w* Ezequías, \w rey|strong="H4428"\w* \w de|strong="H5414"\w* \w Judá|strong="H3063"\w*: \w No|strong="H3808"\w* te \w engañe|strong="H5377"\w* tu \nd ʼElohim\nd* en Quien confías, \w al|strong="H4428"\w* pensar \w que|strong="H3808"\w* Jerusalén \w no|strong="H3808"\w* \w será|strong="H3808"\w* \w entregada|strong="H5414"\w* en \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w* \w de|strong="H5414"\w* Asiria.
\v 11 \w Ciertamente|strong="H2009"\w* \w tú|strong="H6213"\w* \w mismo|strong="H3605"\w* \w oíste|strong="H8085"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* de Asiria \w hicieron|strong="H6213"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* países cuando \w los|strong="H3605"\w* exterminaron. ¿\w Tú|strong="H6213"\w* te \w librarás|strong="H5337"\w*?
\v 12 ¿\w Los|strong="H1121"\w* \tl ʼelohim\tl* \w de|strong="H1121"\w* las \w naciones|strong="H1471"\w* \w que|strong="H1121"\w* mis antepasados \w destruyeron|strong="H7843"\w* las \w libraron|strong="H5337"\w*? ¿\w Libraron|strong="H5337"\w* \w a|strong="H3068"\w* \w Gozán|strong="H1470"\w*, \w Harán|strong="H2771"\w* y Resef, y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Edén \w que|strong="H1121"\w* estaban en Telasar?
\v 13 ¿Dónde están el \w rey|strong="H4428"\w* de Hamat, el \w rey|strong="H4428"\w* de Arpad, el \w rey|strong="H4428"\w* de la \w ciudad|strong="H5892"\w* de Sefarvaim, de Hena y de Iva?
\p 
\v 14 Así \w que|strong="H3027"\w* Ezequías \w recibió|strong="H3947"\w* la \w carta|strong="H5612"\w* \w de|strong="H6440"\w* \w mano|strong="H3027"\w* \w de|strong="H6440"\w* los \w mensajeros|strong="H4397"\w* y la \w leyó|strong="H7121"\w*. Después Ezequías \w subió|strong="H5927"\w* \w a|strong="H3068"\w* la \w Casa|strong="H1004"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* y la \w extendió|strong="H6566"\w* \w ante|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 15 \w Y|strong="H3068"\w* Ezequías \w oró|strong="H6419"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*:
\v 16 ¡Oh \nd \w Yavé|strong="H3068"\w*\nd* de las huestes, \nd ʼElohim\nd* de \w Israel|strong="H3478"\w*, entronizado por encima de \w los|strong="H3427"\w* \w querubines|strong="H3742"\w*! \w Solo|strong="H1931"\w* \w Tú|strong="H6213"\w* \w eres|strong="H1931"\w* \nd ʼElohim\nd* sobre \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w reinos|strong="H4467"\w* de \w la|strong="H1931"\w* tierra. \w Tú|strong="H6213"\w* \w hiciste|strong="H6213"\w* \add el\add* \w cielo|strong="H8064"\w* y \add la\add* tierra.
\v 17 \w Inclina|strong="H5186"\w* tu \w oído|strong="H8085"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*, y \w escucha|strong="H8085"\w*. \w Abre|strong="H6491"\w* tus \w ojos|strong="H5869"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*, y \w mira|strong="H7200"\w*. \w Escucha|strong="H8085"\w* \w todas|strong="H3605"\w* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* Senaquerib \w envió|strong="H7971"\w* para \w provocar|strong="H2778"\w* al \nd ʼElohim\nd* \w vivo|strong="H2416"\w*.
\v 18 Oh \nd \w Yavé|strong="H3068"\w*\nd*, ciertamente \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* de Asiria \w destruyeron|strong="H2717"\w* \w todas|strong="H3605"\w* las naciones y sus tierras.
\v 19 Echaron \w sus|strong="H1992"\w* \tl ʼelohim\tl* al fuego, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w son|strong="H3588"\w* \nd ʼElohim\nd*, \w sino|strong="H3588"\w* \w obra|strong="H4639"\w* \w de|strong="H3588"\w* \w manos|strong="H3027"\w* \w de|strong="H3588"\w* hombre, \w de|strong="H3588"\w* \w madera|strong="H6086"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* piedra. \w Por|strong="H3588"\w* eso fueron destruidos.
\v 20 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* nuestro, \w sálvanos|strong="H3467"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reinos|strong="H4467"\w* \w de|strong="H3588"\w* \w la|strong="H3605"\w* tierra \w sepan|strong="H3045"\w* \w que|strong="H3588"\w* solo Tú eres \nd \w Yavé|strong="H3068"\w* ʼElohim.\nd*
\p 
\v 21 Entonces \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amoz, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* Ezequías: \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, dice: \wj En cuanto \w a|strong="H3068"\w* lo \w que|strong="H1121"\w* pediste en oración con respecto \w a|strong="H3068"\w* Senaquerib, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Asiria.\wj*
\v 22 \wj \w Ésta|strong="H2088"\w* \w es|strong="H2088"\w* \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w que|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w habló|strong="H1696"\w* \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w él|strong="H5921"\w*: \w La|strong="H5921"\w* \w virgen|strong="H1330"\w* \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w Sion|strong="H6726"\w* \w te|strong="H5921"\w* desprecia \w y|strong="H5921"\w* \w se|strong="H5921"\w* burla \w de|strong="H5921"\w* \w ti|strong="H5921"\w*. \w La|strong="H5921"\w* \w hija|strong="H1323"\w* \w de|strong="H5921"\w* Jerusalén menea despectivamente \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w a|strong="H3068"\w* tu espalda.\wj*
\p 
\v 23 \wj ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* provocaste \w y|strong="H5921"\w* vituperaste? ¿\w Contra|strong="H5921"\w* \w quién|strong="H4310"\w* \w alzaste|strong="H5375"\w* \w la|strong="H5921"\w* \w voz|strong="H6963"\w* \w y|strong="H5921"\w* levantaste tus \w ojos|strong="H5869"\w* \w con|strong="H5921"\w* \w altivez|strong="H7311"\w*? ¡\w Contra|strong="H5921"\w* \w el|strong="H5921"\w* \w Santo|strong="H6918"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*!\wj*
\v 24 \wj \w Por|strong="H3027"\w* \w medio|strong="H3027"\w* de tus esclavos afrentaste \w a|strong="H3068"\w* ʼAdonay y dijiste: Con la \w multitud|strong="H7230"\w* de mis carrozas subí \w a|strong="H3068"\w* las \w alturas|strong="H4791"\w* de las montañas, \w a|strong="H3068"\w* lo más inaccesible del \w Líbano|strong="H3844"\w*. Talé sus más altos cedros y sus mejores cipreses. Llegué hasta el último de sus refugios, hasta lo más denso de su \w bosque|strong="H3293"\w*.\wj*
\v 25 \wj \w Cavé|strong="H6979"\w* y \w bebí|strong="H8354"\w* \w aguas|strong="H4325"\w*, y sequé \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ríos|strong="H2975"\w* \w de|strong="H4325"\w* Egipto con \w la|strong="H3605"\w* planta \w de|strong="H4325"\w* mis \w pies|strong="H6471"\w*.\wj*
\p 
\v 26 \wj ¿\w No|strong="H3808"\w* \w lo|strong="H3808"\w* \w oíste|strong="H8085"\w*? Desde antaño \w lo|strong="H3808"\w* decidí. En \w tiempos|strong="H3117"\w* remotos \w lo|strong="H3808"\w* preparé y \w ahora|strong="H6258"\w* decido \w que|strong="H3808"\w* suceda. \w Tú|strong="H6213"\w* \w estás|strong="H6213"\w* puesto \w para|strong="H1961"\w* reducir las \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w* \w a|strong="H3068"\w* pilas de ruinas,\wj*
\v 27 \wj y \w que|strong="H1961"\w* sus \w habitantes|strong="H3427"\w*, impotentes, abatidos y confusos, \w sean|strong="H1961"\w* \w como|strong="H1961"\w* pasto del \w campo|strong="H7704"\w*, \w como|strong="H1961"\w* \w hierba|strong="H6212"\w* \w verde|strong="H3419"\w*, \w como|strong="H1961"\w* herbaje \w de|strong="H6440"\w* tejado \w que|strong="H1961"\w* \w se|strong="H1961"\w* marchita \w antes|strong="H6440"\w* \w de|strong="H6440"\w* crecer.\wj*
\v 28 \wj Yo \w conozco|strong="H3045"\w* tu sentarte, tu \w salir|strong="H3318"\w*, tu entrar y tu \w ira|strong="H3318"\w* contra Mí.\wj*
\v 29 \wj \w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* tu enfurecimiento contra Mí y tu soberbia llegaron \w a|strong="H3068"\w* mis oídos, \w pondré|strong="H7760"\w* mi garfio en tu nariz y mi rienda en tu \w boca|strong="H8193"\w*. Te \w haré|strong="H7760"\w* regresar \w por|strong="H3282"\w* el \w camino|strong="H1870"\w* en el cual viniste.\wj*
\p 
\v 30 \wj \w Esto|strong="H2088"\w* te servirá de señal: \w Este|strong="H2088"\w* \w año|strong="H8141"\w* comerán \w lo|strong="H2088"\w* \w que|strong="H2088"\w* brota de ella y el \w segundo|strong="H8145"\w* \w año|strong="H8141"\w* de \w lo|strong="H2088"\w* \w que|strong="H2088"\w* brote sin sembrar. Al tercer \w año|strong="H8141"\w* siembren y cosechen, planten \w viñas|strong="H3754"\w* y coman de su \w fruto|strong="H6529"\w*.\wj*
\v 31 \wj \w El|strong="H6213"\w* remanente de la \w Casa|strong="H1004"\w* de \w Judá|strong="H3063"\w* que \w quede|strong="H7604"\w* \w a|strong="H3068"\w* salvo, de nuevo echará \w raíces|strong="H8328"\w* por \w abajo|strong="H4295"\w* y dará \w frutos|strong="H6529"\w* por \w arriba|strong="H4605"\w*.\wj*
\v 32 \wj \w Porque|strong="H3588"\w* \w saldrá|strong="H3318"\w* un remanente \w de|strong="H3588"\w* Jerusalén, \w los|strong="H3588"\w* sobrevivientes \w de|strong="H3588"\w* \w la|strong="H3588"\w* Montaña \w Sion|strong="H6726"\w*. ¡\w El|strong="H3588"\w* \w celo|strong="H7068"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H3588"\w* las huestes \w hará|strong="H6213"\w* \w esto|strong="H2063"\w*!\wj*
