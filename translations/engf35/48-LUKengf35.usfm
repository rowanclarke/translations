\v 6 \w So|strong="G1161"\w* \w it|strong="G1161"\w* \w happened|strong="G1096"\w* \w that|strong="G3588"\w* \w when|strong="G1161"\w* \w they|strong="G1161"\w* \w got|strong="G1096"\w* \w there|strong="G1563"\w* \w the|strong="G1722"\w* \w days|strong="G2250"\w* \w for|strong="G1161"\w* \w her|strong="G1438"\w* \w to|strong="G1722"\w* \w give|strong="G5088"\w* \w birth|strong="G5088"\w* \w were|strong="G1510"\w* completed;
