\id AMO - Biblica® Open Kikuyu Holy Word of God
\h Amosi
\toc1 Amosi
\toc2 Amosi
\toc3 Amos
\mt1 AMOSI
\c 1
\p 
\v 1 Ũyũ nĩguo ũhoro wa Amosi, ũmwe wa arĩithi arĩa maarĩithagia Tekoa,\f + \fr 1:1 \ft Tekoa rĩarĩ itũũra rĩa Juda, gũthini wa itũũra rĩa Bethilehemu.\f* wa ũndũ ũrĩa onire ũkoniĩ Isiraeli mĩaka ĩĩrĩ mbere ya gĩthingithia, hĩndĩ ĩrĩa Uzia aarĩ mũthamaki wa Juda nake Jeroboamu mũrũ wa Joashu aarĩ mũthamaki wa Isiraeli.
\p 
\v 2 Oigire atĩrĩ:
\q1 “Jehova araramaga arĩ Zayuni,
\q2 na akaruruma arĩ Jerusalemu;
\q1 ũrĩithio wa arĩithi a mbũri nĩũkooma,
\q2 nako gacũmbĩrĩ ga Karimeli kahoohe.”
\s1 Ituĩro rĩa Ciira kũrĩ Andũ arĩa Mariganĩtie na Isiraeli
\p 
\v 3 Jehova ekuuga atĩrĩ:
\q1 “Nĩ ũndũ wa mehia matatũ ma Dameski, o na mana-rĩ,
\q2 niĩ ndikahũndũra mangʼũrĩ makwa.
\q1 Tondũ nĩahũũrire Gileadi na ibũi
\q2 irĩ na magego ma kĩgera,
\q1 
\v 4 nĩngaitĩrĩria nyũmba ya Hazaeli mwaki
\q2 ũrĩa ũgaacina ciĩhitho iria nũmu cia Beni-Hadadi.
\q1 
\v 5 Nĩngoinanga kĩhingo kĩa Dameski;
\q2 nĩngananga mũthamaki ũrĩa ũtũũraga Gĩtuamba kĩa Aveni,
\q1 na niine ũrĩa ũnyiitĩte njũgũma ya wathani kũu Bethi-Edeni.
\q2 Andũ a Suriata nĩmagatahwo matwarwo Kiri,”
\q4 ũguo nĩguo Jehova ekuuga.
\p 
\v 6 Jehova ekuuga atĩrĩ:
\q1 “Nĩ ũndũ wa mehia matatũ ma Gaza,\f + \fr 1:6 \ft Gaza rĩarĩ itũũra rĩmwe rĩa bata rĩa matũũra matano ma Afilisti, hamwe na matũũra ma Ashidodi, na Ashikeloni, na Ekironi, o na Gathu.\f* o na mana-rĩ,
\q2 niĩ ndikahũndũra mangʼũrĩ makwa.
\q1 Tondũ nĩanyiitire kĩrĩndĩ gĩothe mĩgwate,
\q2 agĩkĩendia kũu Edomu.
\q1 
\v 7 Nĩngaitĩrĩria thingo cia Gaza mwaki
\q2 ũrĩa ũgaacina ciĩhitho iria nũmu ciakuo.
\q1 
\v 8 Nĩngananga mũthamaki wa Ashidodi,
\q2 na niine ũrĩa ũnyiitĩte njũgũma ya wathani kũu Ashikeloni.
\q1 Guoko gwakwa nĩgũgokĩrĩra Ekironi,
\q2 o nginya hĩndĩ ĩrĩa Mũfilisti wa mũthia agaakua,”
\q4 ũguo nĩguo Mwathani Jehova ekuuga.
\p 
\v 9 Ningĩ Jehova ekuuga atĩrĩ:
\q1 “Nĩ ũndũ wa mehia matatũ ma Turo, o na mana-rĩ,
\q2 niĩ ndikahũndũra mangʼũrĩ makwa.
\q1 Tondũ nĩendirie kĩrĩndĩ gĩothe kĩa mĩgwate kũu Edomu,
\q2 akĩaga gũtĩĩa kĩrĩkanĩro kĩa ũiguano kĩa ariũ a ithe.
\q1 
\v 10 Nĩngaitĩrĩria thingo cia Turo mwaki
\q2 ũrĩa ũgaacina ciĩhitho iria nũmu ciakuo.”
\p 
\v 11 Jehova ekuuga atĩrĩ:
\q1 “Nĩ ũndũ wa mehia matatũ ma Edomu, o na mana-rĩ,
\q2 niĩ ndikahũndũra mangʼũrĩ makwa.
\q1 Tondũ nĩatengʼeririe mũrũ wa nyina na rũhiũ rwa njora,
\q2 atarĩ na tha,
\q1 tondũ marakara make mahiũ matiathiraga,
\q2 na mangʼũrĩ make makĩrĩrĩmbũka matekũhoreka,
\q1 
\v 12 nĩĩngaitĩrĩria Temani mwaki
\q2 ũrĩa ũgaacina ciĩhitho iria nũmu cia Bozara.”
\p 
\v 13 Jehova ekuuga atĩrĩ:
\q1 “Nĩ ũndũ wa mehia matatũ ma Amoni, o na mana-rĩ,
\q2 niĩ ndikahũndũra mangʼũrĩ makwa.
\q1 Tondũ nĩatarũrire nda cia andũ-a-nja a Gileadi arĩa maarĩ na nda,
\q2 nĩgeetha aaramie mĩhaka ya gwake.
\q1 
\v 14 Nĩngaitĩrĩria thingo cia Raba mwaki
\q2 ũrĩa ũgaacina ciĩhitho iria nũmu ciakuo,
\q1 gatagatĩ-inĩ ka mbugĩrĩrio ya mbaara mũthenya ũcio wa mbaara,
\q2 ũhaana ta rũhuho rũnene mũthenya wa kĩhuhũkanio.
\q1 
\v 15 Mũthamaki wakuo nĩagatahwo, athaamio,
\q2 we mwene, hamwe na anene ake,”
\q4 ũguo nĩguo Jehova ekuuga.
\b
\c 2
\p 
\v 1 Jehova ekuuga atĩrĩ:
\q1 “Nĩ ũndũ wa mehia matatũ ma Moabi, o na mana-rĩ,
\q2 niĩ ndikahũndũra mangʼũrĩ makwa.
\q1 Tondũ nĩacinire mahĩndĩ ma mũthamaki wa Edomu,
\q2 magĩtuĩka ta coka,
\q1 
\v 2 nĩngaitĩrĩria Moabi mwaki
\q2 ũrĩa ũgaacina ciĩhitho iria nũmu cia Keriothu.
\q1 Moabi nĩakagũa thĩ na mũrurumo mũnene,
\q2 gatagatĩ-inĩ ka mbugĩrĩrio ya mbaara,
\q2 na kũhuhwo kwa mũgambo wa karumbeta.
\q1 
\v 3 Nĩngananga mwathi wakuo,
\q2 na njũrage anene ake othe hamwe nake,”
\q4 ũguo nĩguo Jehova ekuuga.
\b
\q1 
\v 4 Jehova ekuuga atĩrĩ:
\q1 “Nĩ ũndũ wa mehia matatũ ma Juda, o na mana-rĩ,
\q2 niĩ ndikahũndũra mangʼũrĩ makwa.
\q1 Tondũ nĩmaregete watho wa Jehova,
\q2 na makaaga kũrũmia irĩra ciake cia watho wa kũrũmĩrĩrwo,
\q1 tondũ nĩmahĩtithĩtio nĩ ngai cia maheeni,
\q2 ngai iria maithe mao ma tene maarũmagĩrĩra.
\q1 
\v 5 Nĩngaitĩrĩria Juda mwaki
\q2 ũrĩa ũgaacina ciĩhitho iria nũmu cia Jerusalemu.”
\s1 Isiraeli Gũtuĩrwo Ciira
\q1 
\v 6 Jehova ekuuga atĩrĩ;
\q1 “Nĩ ũndũ wa mehia matatũ ma Isiraeli, o na mana-rĩ,
\q2 niĩ ndikahũndũra mangʼũrĩ makwa.
\q1 Mendagia andũ arĩa athingu betha,
\q2 na arĩa abatari-rĩ, makamendia nyamũga igĩrĩ.
\q1 
\v 7 Marangagĩrĩria mĩtwe ya arĩa athĩĩni
\q2 taarĩ rũkũngũ rwa thĩ,
\q2 na makaagithia kĩhooto arĩa ahinyĩrĩrie.
\q1 Mũndũ na ithe makomaga na mũirĩtu ũmwe,
\q2 nĩ ũndũ ũcio magathaahia rĩĩtwa rĩakwa itheru.
\q1 
\v 8 Makomaga harĩa hothe harĩ na kĩgongona,
\q2 magakomera nguo iria irutĩtwo irũgamĩrĩre thiirĩ.\f + \fr 2:8 \ft Watho ndwetĩkĩrĩtie mũndũ kũiga nguo iria ingĩarũgamĩrĩire thiirĩ ũtukũ wothe, tondũ no cio andũ meehumbagĩra.\f*
\q1 Kũu thĩinĩ wa nyũmba ya ngai yao,
\q2 nĩkuo manyuuagĩra ndibei ĩrĩa ĩrutĩtwo ya ndooco.
\b
\q1 
\v 9 “Nĩndanangire Aamori mehere mbere yao,
\q2 o na gũtuĩka maarĩ araihu ta mĩtĩ ya mĩtarakwa,
\q2 na marĩ na hinya ta mĩtĩ ya mĩgandi.
\q1 Nĩndanangire matunda make kuuma na igũrũ,
\q2 na ngĩananga mĩri yake kuuma na thĩ.
\b
\q1 
\v 10 “Ndakwambatirie ngĩkũruta bũrũri wa Misiri,
\q2 na ngĩgũtongoria mĩaka mĩrongo ĩna kũu werũ-inĩ,
\q2 nĩguo ngũhe bũrũri wa Aamori.
\q1 
\v 11 Ningĩ nĩndarahũrire anabii kuuma kũrĩ ariũ aku,
\q2 na ngĩarahũra Anaziri kuuma kũrĩ aanake aku.
\q1 Githĩ ũcio ti ũhoro wa ma, inyuĩ andũ a Isiraeli?”
\q4 ũguo nĩguo Jehova ekuuga.
\q1 
\v 12 “No inyuĩ nĩmwaheire Anaziri ndibei manyue,
\q2 na mũgĩatha anabii matikanarathe ũndũ.
\b
\q1 
\v 13 “Na rĩrĩ, niĩ nĩngamũhehenja
\q2 o ta ũrĩa ngaari ĩiyũrĩte ngano ĩhehenjaga.
\q1 
\v 14 Mũndũ ũrĩa ũrĩ ihenya ndakahota kwĩhonokia.
\q2 Ũrĩa ũrĩ hinya ndagateithio nĩ hinya ũcio wake,
\q2 nayo njamba ya ita ndĩkahonokia muoyo wayo.
\q1 
\v 15 Mũrathi na mĩguĩ ndakeyũmĩrĩria,
\q2 na mũthigari ũrĩa ũhiũkaga ndakahota kũũra,
\q2 na ũrĩa ũhaicĩte mbarathi ndakahonokia muoyo wake.
\q1 
\v 16 O nacio njamba cia ita iria nyũmĩrĩru mũno,
\q2 ikoora irĩ njaga mũthenya ũcio,”
\q4 ũguo nĩguo Jehova ekuuga.
\c 3
\s1 Aira Gwĩtwo Marute Ũira wa Gũũkĩrĩra Isiraeli
\p 
\v 1 Ta iguai ũhoro ũyũ Jehova aarĩtie wa kũmũũkĩrĩra, inyuĩ andũ a Isiraeli, ũira wa gũũkĩrĩra nyũmba yothe ĩrĩa ndaarutire bũrũri wa Misiri:
\q1 
\v 2 “Inyuĩ no inyuĩ ndĩthuurĩire
\q2 kuuma harĩ nyũmba ciothe cia thĩ;
\q1 nĩ ũndũ ũcio nĩngamũherithia
\q2 tondũ wa mehia manyu mothe.”
\b
\q1 
\v 3 Andũ eerĩ maahota gũtwarana atĩa
\q2 matarĩ na karĩĩko?
\q1 
\v 4 Mũrũũthi-rĩ, nĩũraramaga kĩhinga-inĩ
\q2 ũtarĩ kĩndũ ũnyiitĩte?
\q1 Nĩũraramaga ũrĩ kĩmamo-inĩ
\q2 ũtanyiitĩte kĩndũ?
\q1 
\v 5 Nyoni-rĩ, no ĩgwe thĩ mũtego-inĩ
\q2 hatarĩ kĩndũ gĩa kũmĩheenereria?
\q1 Mũtego-rĩ, no ũtegũke, uume thĩ
\q2 ũtagwatĩtie kĩndũ?
\q1 
\v 6 Karumbeta no kahuhwo itũũra-inĩ inene,
\q2 na andũ mage gwĩtigĩra?
\q1 Mũtino no ũũke itũũra-inĩ inene,
\q2 na gũtuĩke ti Jehova ũũrehete?
\b
\q1 
\v 7 Ti-itherũ Mwathani Jehova ndarĩ ũndũ angĩĩka
\q2 atamenyithĩtie anabii, ndungata ciake,
\q2 ũrĩa atuĩte gwĩka.
\b
\q1 
\v 8 Mũrũũthi nĩũraramĩte,
\q2 nũũ ũtangĩĩtigĩra?
\q1 Mwathani Jehova nĩarĩtie,
\q2 nũũ ũtangĩratha maũndũ?
\b
\q1 
\v 9 Anĩrĩrai mwĩre ciĩhitho iria nũmu cia Ashidodi,
\q2 na ciĩhitho iria nũmu cia bũrũri wa Misiri ũciĩre atĩrĩ:
\q1 “Ũnganai irĩma igũrũ cia Samaria,
\q2 mwĩonere inegene inene rĩrĩa rĩrĩ kuo,
\q2 na ũhinyanĩrĩria ũrĩa ũrĩ thĩinĩ wa andũ.”
\b
\q1 
\v 10 Jehova ekuuga atĩrĩ:
\q2 “Andũ arĩa mahĩbaga indo cia gũtunyana
\q1 na indo cia ndaho kũu ciĩhitho-inĩ nũmu ciao,
\q2 matiũĩ gwĩka ũrĩa kwagĩrĩire.”
\p 
\v 11 Nĩ ũndũ ũcio Mwathani Jehova ekuuga atĩrĩ,
\q1 “Thũ nĩĩkaharagania bũrũri;
\q2 nĩĩgatharia ciĩgitĩro cianyu cia hinya,
\q2 na ciĩhitho cianyu nũmu nĩigatahwo.”
\p 
\v 12 Jehova ekuuga atĩrĩ:
\q1 “O ta ũrĩa mũrĩithi angĩteithũra
\q2 magũrũ meerĩ kana gacunjĩ ga gũtũ kuuma kanua ka mũrũũthi,
\q2 ũguo noguo andũ a Isiraeli makaahonokio,
\q1 acio maikaraga Samaria
\q2 maikarĩire mĩthia ya marĩrĩ mao,
\q2 o na arĩa maikarĩire itanda ciao marĩ Dameski.”
\p 
\v 13 Mwathani Jehova, Ngai Mwene-Hinya-Wothe, ekuuga atĩrĩ: “Ta iguai ũhoro ũyũ, na inyuĩ mũrute ũira wa gũũkĩrĩra nyũmba ya Jakubu.
\q1 
\v 14 “Mũthenya ũrĩa ngaaherithia Isiraeli nĩ ũndũ wa mehia make-rĩ,
\q2 nĩngananga igongona cia Betheli;
\q1 na ndinie hĩa cia kĩgongona kĩu
\q2 igwe thĩ.\f + \fr 3:14 \ft Mehia ma Isiraeli maagĩire mĩri marĩ Betheli rĩrĩa Mũthamaki Jeroboamu aathondekire ngai ya gacaũ, na akĩmĩakĩra kĩgongona kuo.\f*
\q1 
\v 15 Nĩngatharia nyũmba ya hĩndĩ ya gathano,
\q2 o hamwe na nyũmba ya hĩndĩ ya riũa;
\q1 nyũmba iria ngʼemie na mĩguongo nĩikaanangwo,
\q2 nacio nyũmba iria nene mũno nĩikamomorwo,”
\q4 ũguo nĩguo Jehova ekuuga.
\c 4
\s1 Isiraeli Kwaga Gũcookerera Ngai
\q1 
\v 1 Ta iguai ũhoro ũyũ, inyuĩ ngʼombe cia Bashani
\q2 mũrĩ kũu igũrũ rĩa Kĩrĩma gĩa Samaria,
\q1 o inyuĩ andũ-a-nja arĩa mũhinyagĩrĩria athĩĩni
\q2 na mũkahehenja arĩa abatari,
\q1 na mũkeeraga athuuri anyu atĩrĩ:
\q2 “Tũreherei ndibei tũnyue!”
\q1 
\v 2 Mwathani Jehova nĩehĩtĩte na ũtheru wake, akoiga atĩrĩ,
\q2 “Ti-itherũ ihinda nĩrĩroka
\q1 rĩrĩa mũkaguucũrũrio na mboorio,
\q2 na ũrĩa wanyu ũgaatigara aguucũrũrio na ndwano.
\q1 
\v 3 Mũkoimio nja ũmwe kwa ũmwe,
\q2 muumĩrio mĩanya-inĩ ya rũthingo,
\q2 na mũikanio na kũu Harimoni,”
\q4 ũguo nĩguo Jehova ekuuga.
\q1 
\v 4 “Thiĩi Betheli mũkeehie;
\q2 o na thiĩi Giligali mũgakĩrĩrĩrie kwĩhia.\f + \fr 4:4 \ft Betheli na Giligali maarĩ matũũra ma bata, na nĩkuo andũ maathiiaga gũkũngũĩra ũrĩa Jehova anamateithia.\f*
\q1 Rutagai magongona manyu o rũciinĩ,
\q2 mũrutage gĩcunjĩ kĩanyu gĩa ikũmi o mĩaka ĩtatũ.
\q1 
\v 5 Cinagai mĩgate ĩĩkĩrĩtwo ndawa ya kũimbia,
\q2 ĩtuĩke igongona rĩa gũcookia ngaatho,
\q1 na mwĩrahage nĩ ũndũ wa maruta manyu ma kwĩyendera,
\q2 na mwĩtĩĩage nĩ ũndũ wamo, inyuĩ andũ a Isiraeli,
\q1 nĩgũkorwo ũguo nĩguo mwendaga gwĩka,”
\q4 ũguo nĩguo Mwathani Jehova ekuuga.
\b
\q1 
\v 6 “Ndaatũmire mũhũte mũrĩ matũũra-inĩ manyu manene,
\q2 na ngĩtũma mwage irio matũũra-inĩ,
\q2 no rĩrĩ, inyuĩ mũtiigana kũnjookerera,”
\q4 ũguo nĩguo Jehova ekuuga.
\b
\q1 
\v 7 “O na ningĩ ngĩmũima mbura,
\q2 hĩndĩ ĩrĩa magetha maatigĩtie o mĩeri ĩtatũ.
\q1 Nĩndoiririe mbura itũũra rĩmwe,
\q2 no ngĩaga kuuria itũũra rĩrĩa rĩngĩ.
\q1 Mũgũnda ũmwe ũkiurĩrwo;
\q2 ũrĩa ũngĩ ũkĩaga kuurĩrwo, ũkĩũma.
\q1 
\v 8 Andũ magĩtũgũũga kuuma itũũra rĩmwe nginya rĩrĩa rĩngĩ
\q2 magĩcaria maaĩ,
\q1 no mationire maaĩ maiganu ma kũnyua,
\q2 no rĩrĩ, inyuĩ mũtiigana kũnjookerera,”
\q4 ũguo nĩguo Jehova ekuuga.
\b
\q1 
\v 9 “Mahinda maingĩ nĩndahũũrire mĩgũnda yanyu ya irio na ya mĩthabibũ,
\q2 ngĩmĩhũũra na mbaa, na mbuu.
\q1 Ngigĩ nĩciarĩire mĩtĩ yanyu ya mĩkũyũ na ya mĩtamaiyũ,
\q2 no rĩrĩ, inyuĩ mũtiigana kũnjookerera,”
\q4 ũguo nĩguo Jehova ekuuga.
\b
\q1 
\v 10 “Nĩndamũrehithĩirie mĩthiro
\q2 ta ũrĩa ndeekire bũrũri wa Misiri.
\q1 Aanake anyu ngĩmoragithia na rũhiũ rwa njora,
\q2 na ngĩmũtunya mbarathi cianyu.
\q1 Ngĩtũma mũnungo wa ciimba kuuma kambĩ yanyu
\q2 ũnungĩrĩre maniũrũ manyu,
\q2 no rĩrĩ, inyuĩ mũtiigana kũnjookerera,”
\q4 ũguo nĩguo Jehova ekuuga.
\b
\q1 
\v 11 “Nĩndangʼaũranirie amwe anyu
\q2 ta ũrĩa ndangʼaũranirie Sodomu na Gomora.
\q1 Mwahaanaga ta gĩcinga kĩraakana kĩrutĩtwo mwaki-inĩ,
\q2 no rĩrĩ, inyuĩ mũtiigana kũnjookerera,”
\q4 ũguo nĩguo Jehova ekuuga.
\b
\q1 
\v 12 “Nĩ ũndũ ũcio, ũũ nĩguo ngũgwĩka wee Isiraeli,
\q2 na tondũ nĩngũgwĩka ũguo-rĩ,
\q2 wĩhaarĩrie gũtũngana na Ngai waku, wee Isiraeli.”
\b
\q1 
\v 13 Ũrĩa ũmbaga irĩma
\q2 nowe ũmbaga rũhuho,
\q2 na akaguũrĩria mũndũ meciiria make,
\q1 o we ũtũmaga rũciinĩ kũgĩe nduma,
\q2 na agathiĩra thĩ kũrĩa gũtũũgĩru,
\q2 rĩĩtwa rĩake nĩ Jehova Ngai Mwene-Hinya-Wothe.
\c 5
\s1 Andũ a Isiraeli kwĩrwo Meerire
\p 
\v 1 Ta iguai ũhoro ũyũ, inyuĩ nyũmba ya Isiraeli, mũigue ngĩcakaya nĩ ũndũ wanyu:
\q1 
\v 2 “Mũirĩtu gathirange, nĩwe Isiraeli, nĩagwĩte,
\q2 na ndagookĩra rĩngĩ,
\q1 atiganĩirio bũrũri-nĩ wake mwene,
\q2 hatarĩ na mũndũ wa kũmũũkĩria.”
\p 
\v 3 Mwathani Jehova ekuuga atĩrĩ:
\q1 “Itũũra inene rĩrĩa rĩatũmaga thigari ngiri cia Isiraeli-rĩ,
\q2 no thigari igana igaatigara;
\q1 narĩo itũũra rĩrĩa rĩatũmaga thigari igana-rĩ,
\q2 no thigari ikũmi igaatigara.”
\p 
\v 4 Jehova ekwĩra nyũmba ya Isiraeli atĩrĩ:
\q1 “Njariai mũtũũre muoyo;
\q2 
\v 5 tigai kũrongooria Betheli,
\q1 tigai gũthiĩ Giligali,
\q2 na mũtikanyiite rũgendo rwa gũthiĩ Birishiba.
\q1 Tondũ andũ a Giligali ti-itherũ nĩmagatahwo,
\q2 na andũ a Betheli matuuo kĩndũ hatarĩ.”
\q1 
\v 6 Rongoriai Jehova, mũtũũre muoyo,
\q2 ndakae gũtuthũkĩra nyũmba ya Jusufu ta mwaki;
\q1 naguo mwaki ũcio nĩũkaniinana,
\q2 nakuo Betheli kwage mũndũ ũngĩhota kũũhoria.
\b
\q1 
\v 7 Inyuĩ arĩa mũgarũraga kĩhooto gĩgatuĩka ũrũrũ,
\q2 na mũkarangĩrĩria ũthingu thĩ
\q1 
\v 8 (we ũrĩa wombire njata iria ciĩtagwo Kĩrĩmĩra na Karaũ,
\q2 o we ũrĩa ũgarũraga nduma ndumanu ĩgatuĩka rũciinĩ,
\q2 na agatumania mũthenya ũgatuĩka ũtukũ,
\q1 ũrĩa wĩtaga maaĩ ma iria rĩrĩa inene
\q2 akamaitũrũra gũkũ thĩ-rĩ:
\q2 Jehova nĩrĩo rĩĩtwa rĩake;
\q1 
\v 9 areehagĩra kĩĩhitho kĩrũmu mwanangĩko o rĩmwe ta rũheni,
\q2 narĩo itũũra inene rĩrĩa rĩirigĩre akarĩanangithia),
\q1 
\v 10 inyuĩ mũthũũraga ũrĩa ũkananagia maũndũ iciirĩro-inĩ,
\q2 nake ũrĩa waragia ũhoro wa ma mũkamũmena.
\b
\q1 
\v 11 Mũrangagĩrĩria mũthĩĩni,
\q2 na mũkamũtunya ngano na hinya.
\q1 Nĩ ũndũ ũcio, o na gũtuĩka nĩmwakĩte nyũmba nene cia mahiga-rĩ,
\q2 mũtigacitũũra;
\q1 o na gũtuĩka nĩmũhaandĩte mĩgũnda mĩega ya mĩthabibũ-rĩ,
\q2 mũtikanyua ndibei yayo.
\q1 
\v 12 Tondũ niĩ nĩnjũũĩ ũrĩa mahĩtia manyu maigana,
\q2 na ngamenya ũrĩa mehia manyu marĩ manene.
\b
\q1 Inyuĩ mũhinyagĩrĩria andũ arĩa athingu,
\q2 na mũkaamũkĩra mahaki,
\q2 na mũkaagithia athĩĩni kĩhooto maciirĩro-inĩ.
\q1 
\v 13 Tondũ ũcio mũndũ ũrĩa mũbacĩrĩri
\q2 no gũkira akiraga ki mahinda ta macio,
\q2 tondũ nĩ mahinda mooru.
\b
\q1 
\v 14 Rongoriai maũndũ marĩa mega, no ti marĩa mooru,
\q2 nĩguo mũtũũre muoyo.
\q1 Nake Jehova Ngai Mwene-Hinya-Wothe
\q2 nĩarĩkoragwo hamwe na inyuĩ,
\q2 o ta ũrĩa mũtũire muugaga.
\q1 
\v 15 Thũũrai maũndũ marĩa mooru,
\q2 mwendage marĩa mega;
\q2 tũũriai kĩhooto maciirĩro-inĩ.
\q1 Jehova Ngai Mwene-Hinya-Wothe
\q2 ahota kũiguĩra matigari ma Jusufu tha.
\p 
\v 16 Tondũ ũcio-rĩ, Jehova Ngai Mwene-Hinya-Wothe, o we Mwathani, ekuuga atĩrĩ:
\q1 “Nĩgũkaagĩa na mũcakayo njĩra-inĩ ciothe iria nene,
\q2 na kĩrĩro kĩa ruo rwa ngoro ihaaro-inĩ ciothe.
\q1 Arĩmi nĩmagatũmanĩrwo moke marĩre,
\q2 nao arĩa macakayaga moke macakae.
\q1 
\v 17 Nĩgũkaagĩa mũcakayo mĩgũnda-inĩ yothe ya mĩthabibũ,
\q2 nĩgũkorwo nĩngatuĩkanĩria gatagatĩ-inĩ kanyu,”
\q4 ũguo nĩguo Jehova ekuuga.
\s1 Mũthenya wa Jehova
\q1 
\v 18 Kaĩ inyuĩ mwĩriragĩria mũthenya wa Jehova
\q2 mũrĩ na haaro-ĩ!
\q1 Nĩ kĩĩ gĩtũmaga mwĩrirĩrie mũthenya ũcio wa Jehova?
\q2 Mũthenya ũcio ũgaatuĩka nduma, no ti ũtheri.
\q1 
\v 19 Ũgaatuĩka ta mũndũ akĩũrĩra mũrũũthi,
\q2 agatũngana na nduba,
\q1 kana atoonye nyũmba yake,
\q2 nake aigĩrĩra guoko gwake rũthingo-inĩ,
\q2 arũmwo nĩ nyoka.
\q1 
\v 20 Githĩ mũthenya ũcio wa Jehova ndũgaagĩtuĩka nduma, no ti ũtheri;
\q2 ĩĩ, nduma ndumanu, gũtarĩ na mũrũri wa ũtheri?
\b
\q1 
\v 21 “Niĩ nĩthũire na nganyarara ciathĩ cianyu;
\q2 ndingĩkirĩrĩria ciũngano cianyu.
\q1 
\v 22 O na mũngĩndehera maruta ma njino,
\q2 na maruta ma ngano-rĩ,
\q2 ndikametĩkĩra.
\q1 O na mũngĩkarehe maruta marĩa mega ma ũiguano-rĩ,
\q2 ndikamarũmbũiya.
\q1 
\v 23 Thengiai inegene rĩu rĩa nyĩmbo cianyu!
\q2 Ndigathikĩrĩria mĩgambo ya inanda cianyu cia mũgeeto.
\q1 
\v 24 No kĩhooto nĩkĩrekwo gĩthererage ta rũũĩ,
\q2 na ũthingu ũthererage ta karũũĩ gatahũũaga.
\b
\q1 
\v 25 “Inyuĩ nyũmba ya Isiraeli-rĩ,
\q2 nĩmwandutagĩra magongona na maruta
\q2 mĩaka mĩrongo ĩna mũrĩ kũu werũ-inĩ?
\q1 
\v 26 Nĩmũtũũgĩrĩtie ihooero rĩa mũthamaki wanyu,
\q2 o na njikarĩro ya mĩhianano yanyu,
\q2 o njata ĩyo ya ngai yanyu,
\q2 ĩrĩa mwethondekeire inyuĩ ene.
\q1 
\v 27 Tondũ ũcio-rĩ, nĩngatũma mũtahwo mũtwarwo mbere ya Dameski,”
\q2 ũguo nĩguo Jehova ekuuga, ũrĩa wĩtagwo Ngai Mwene-Hinya-Wothe.
\c 6
\s1 Haaro kũrĩ arĩa Megangarĩte
\q1 
\v 1 Kaĩ mũrĩ na haaro-ĩ! inyuĩ mũikaraga mwĩgangarĩte mũrĩ kũu Zayuni,
\q2 na inyuĩ mũiguaga mũrĩ agitĩre mũrĩ kĩrĩma-igũrũ gĩa Samaria;\f + \fr 6:1 \ft O na gũtuĩka Amosi aarathagĩra ũthamaki wa gathigathini, haha aakũũmaga mothamaki meerĩ.\f*
\q1 o inyuĩ mũrĩ igweta thĩinĩ wa rũrĩrĩ rũrĩa rũrĩ mbere ya iria ingĩ,
\q2 kũrĩa andũ a Isiraeli mathiiaga.
\q1 
\v 2 Thiĩi Kaline mũkeyonere kuo,
\q2 ningĩ muume kuo mũthiĩ nginya Hamathu, itũũra rĩu inene,
\q2 mũcooke mũikũrũke mũkinye Gathu kwa Afilisti.
\q1 Anga acio nĩega magakĩra mothamaki manyu meerĩ?
\q2 Bũrũri wao-rĩ, nĩ mũnene gũkĩra wanyu?
\q1 
\v 3 Inyuĩ mũtĩĩragia mũthenya wa ũũru,
\q2 na mũkareharehe wathani wa ũhinya ũkuhĩrĩrie.
\q1 
\v 4 Mũkomagĩra marĩrĩ magemetio na mĩguongo,
\q2 na mũgetambũrũkia itanda-inĩ cianyu.
\q1 Mũrĩĩaga tũgondu tũrĩa twega mũno,
\q2 na tũcaũ tũrĩa tũnoru.
\q1 
\v 5 Mũtiindaga mũkĩhũũra inanda cianyu cia mũgeeto o ta Daudi,
\q2 na mũgethondekera inanda ingĩ cia kũina nacio.
\q1 
\v 6 Mũnyuuaga ndibei mbakũri riita,
\q2 na mũkehakaga maguta marĩa mega mũno,
\q2 no mũtiiguaga kĩeha nĩ ũndũ wa mwanangĩko wa Jusufu.
\q1 
\v 7 Tondũ ũcio-rĩ, mũgaatuĩka a mbere gũtahwo;
\q2 ndĩa cianyu na gũikara mwĩtambũrũkĩtie ithire.
\s1 Jehova Nĩathũire Mwĩtĩĩo wa Isiraeli
\p 
\v 8 Mwathani Jehova nĩehĩtĩte akĩĩgwetaga we mwene, o we Jehova Ngai Mwene-Hinya-Wothe, akoiga atĩrĩ:
\q1 “Nĩthũire mwĩtĩĩo wa Jakubu,
\q2 na ngamena ciĩhitho ciake iria nũmu;
\q1 nĩngarekereria itũũra rĩu inene
\q2 na kĩrĩa gĩothe kĩrĩ thĩinĩ warĩo kũrĩ thũ.”
\p 
\v 9 Andũ ikũmi mangĩgatigara thĩinĩ wa nyũmba ĩmwe-rĩ, o nao no magaakua.
\v 10 Nake mũndũ wao ũrĩa wa gũcina mĩĩrĩ ĩyo angĩũka kũmiumia nja ya nyũmba na orie mũndũ ũrĩa wĩhithĩte kuo thĩinĩ atĩrĩ, “Kũrĩ mũndũ ũngĩ ũtakuĩte mũrĩ nake?” Nake oige atĩrĩ, “Aca.” Nake acookie oige atĩrĩ, “Kira ki! Tũtikagwete rĩĩtwa rĩa Jehova.”
\q1 
\v 11 Nĩgũkorwo Jehova nĩathanĩte,
\q2 nake nĩagathutha nyũmba ĩrĩa nene ĩtuĩke icunjĩ,
\q2 na nyũmba ĩrĩa nini ituĩke tũcunjĩ.
\b
\q1 
\v 12 Kaĩ mbarathi ingĩhota gũtengʼera nyanjara-inĩ cia mahiga?
\q2 Kũrĩ mũndũ ũngĩrĩma kuo na mũraũ wa ndegwa?
\q1 No inyuĩ mũgarũrĩte kĩhooto gĩgatuĩka ũrogi,
\q2 na matunda ma ũthingu magatuĩka ũrũrũ,
\q1 
\v 13 inyuĩ arĩa mũkenagĩra ũhootani ũrĩa ũtarĩ ho,
\q2 na mũkoigaga atĩrĩ, “Githĩ tũtiatunyanire Karinaimu na hinya witũ ithuĩ ene?”
\b
\q1 
\v 14 Nĩgũkorwo Jehova Ngai Mwene-Hinya-Wothe ekuuga atĩrĩ,
\q2 “Nĩngarahũra rũrĩrĩ rũgũũkĩrĩre, wee nyũmba ya Isiraeli,
\q1 rũrĩa rũgakũhinyĩrĩria
\q2 kuuma itoonyero rĩa Hamathu, o nginya mũkuru wa Araba.”
\c 7
\s1 Ngigĩ, na Mwaki, na Kabirũ
\p 
\v 1 Mwathani Jehova aanyonirie ũũ: Nĩkũhaarĩria aharagĩria mĩrumbĩ ya ngigĩ thuutha wa magetha marĩa maagethagĩrwo mũthamaki, o ihinda rĩrĩa kĩmera gĩa keerĩ kĩambagĩrĩria.
\v 2 Ciarĩkia kũrĩa tũhuti tuothe, bũrũri ũgĩthera biũ, ngĩkaya ngiuga atĩrĩ, “Mwathani Jehova, marekere! Jakubu-rĩ, angĩhonoka gĩkuũ atĩa? Nĩgũkorwo nĩ mũnini mũno!”
\p 
\v 3 Nĩ ũndũ ũcio Jehova akĩigua tha.
\p Jehova akiuga atĩrĩ, “Ũndũ ũcio ndũgwĩkĩka.”
\p 
\v 4 Ningĩ Mwathani Jehova akĩnyonia ũũ: Mwathani Jehova nĩ gwĩtia eetagia mwaki amaciirithie naguo; mwaki ũcio ũkĩniaria maaĩ ma kũrĩa kũriku mũno, na ũkĩniina bũrũri.
\v 5 Ningĩ ngĩkaya, ngiuga atĩrĩ, “Mwathani Jehova ndagũthaitha, tiga! Jakubu-rĩ, angĩhonoka gĩkuũ atĩa? Nĩgũkorwo nĩ mũnini mũno!”
\p 
\v 6 Nĩ ũndũ ũcio Jehova akĩigua tha.
\p Mwathani Jehova akiuga atĩrĩ, “Ũndũ ũcio o naguo ndũgwĩkĩka.”
\b
\p 
\v 7 Ningĩ akĩnyonia ũũ: Mwathani aarũgamĩte rũthingo-inĩ rwakĩtwo na rũgathimwo wega na kabirũ nake anyiitĩte rũrigi rwa kabirũ na guoko.
\v 8 Nake Jehova akĩnjũũria atĩrĩ, “Amosi, nĩ kĩĩ ũroona”?
\p Na niĩ ngĩmũcookeria atĩrĩ: “Nĩ kabirũ ndĩrona.”
\p Ningĩ Jehova akĩnjĩĩra atĩrĩ, nĩ kabirũ ndĩracuuria gatagatĩ ka andũ akwa a Isiraeli, ndigacooka kũmaiguĩra tha rĩngĩ.
\q1 
\v 9 “Kũndũ kũrĩa gũtũũgĩru kwa Isaaka nĩgũkaniinwo,
\q2 na kũndũ kũrĩa kwamũre kwa Isiraeli nĩgũkanangwo;
\q2 na nĩngokĩrĩra nyũmba ya Jeroboamu na rũhiũ rwakwa rwa njora.”
\s1 Amosi na Amazia
\p 
\v 10 Nake Amazia mũthĩnjĩri-ngai wa Betheli agĩtũmana kũrĩ Jeroboamu, mũthamaki wa Isiraeli, akĩmwĩra atĩrĩ, “Amosi nĩagũciirĩire agũũkĩrĩre arĩ o gũkũ thĩinĩ wa Isiraeli. Bũrũri ndũngĩhota gũkirĩrĩria ndeto ciake ciothe.
\v 11 Nĩgũkorwo Amosi aroiga atĩrĩ:
\q1 “ ‘Jeroboamu akooragwo na rũhiũ rwa njora,
\q2 na ti-itherũ andũ a Isiraeli nĩmagatahwo,
\q2 matwarwo kũraya na bũrũri wao.’ ”
\p 
\v 12 Ningĩ Amazia akĩĩra Amosi atĩrĩ, “Umagara wee muoni-maũndũ ũyũ! Cooka bũrũri wa Juda. Wĩcaragĩrie gĩa kũrĩa kuo, na ũrathage maũndũ ũrĩ kuo.
\v 13 Ndũkaarathĩre ũhoro rĩngĩ gũkũ Betheli tondũ gũkũ nĩkuo kwamũrĩirwo gĩikaro kĩa mũthamaki na hekarũ ya ũthamaki.”
\p 
\v 14 Amosi agĩcookeria Amazia atĩrĩ, “Niĩ-rĩ, ndiarĩ mũnabii kana mũrũ wa mũnabii, no ndaarĩ mũrĩithi wa mahiũ na ningĩ mũmenyereri wa mĩkũyũ.
\v 15 No Jehova akĩnduta rũũru-inĩ rwa mahiũ akĩnjĩĩra atĩrĩ, ‘Thiĩ ũkarathĩre andũ akwa a Isiraeli ũhoro.’
\v 16 Na rĩrĩ, kĩigue ũhoro wa Jehova. Wee ũroiga atĩrĩ,
\q1 “ ‘Ndũkarathĩre Isiraeli ũndũ mũũru,
\q2 na ũtige kũhunjia maũndũ ma gũũkĩrĩra nyũmba ya Isaaka.’
\p 
\v 17 “Nĩ ũndũ ũcio Jehova ekuuga ũũ:
\q1 “ ‘Mũtumia waku nĩagatuĩka mũmaraya itũũra-inĩ inene,
\q2 nao aanake aku na airĩtu aku makooragwo na rũhiũ rwa njora.
\q1 Bũrũri waku ũgaathimwo na ũgayanio,
\q2 na wee mwene-rĩ, ũgaakuĩra bũrũri wa andũ matooĩ Ngai.
\q1 Na ti-itherũ andũ a Isiraeli no nginya magaatahwo,
\q2 matwarwo kũraya na bũrũri wao.’ ”
\c 8
\s1 Gĩkabũ kĩa Matunda Meeru
\p 
\v 1 Mwathani Jehova aanyonirie ũũ: aanyonirie gĩkabũ kĩrĩ na matunda meeru.
\v 2 Nake akĩnjũũria atĩrĩ, “Amosi, nĩ kĩĩ kĩu ũroona?”
\p Ngĩmũcookeria atĩrĩ, “Ndĩrona gĩkabũ kĩrĩ na matunda meeru.”
\p Ningĩ Jehova akĩnjĩĩra atĩrĩ, “Ihinda rĩa mũthia nĩ ikinyu rĩa andũ akwa a Isiraeli; ndigacooka kũmaiguĩra tha rĩngĩ.”
\p 
\v 3 Mwathani Jehova ekuuga atĩrĩ, “Mũthenya ũcio-rĩ, nyĩmbo iria ciinagwo kũu hekarũ-inĩ ikaagarũrũka ituĩke kĩrĩro. Ciimba nyingĩ mũno igaateagwo kũndũ guothe gũkirĩtwo ki!”
\q1 
\v 4 Iguai ũndũ ũyũ inyuĩ arĩa mũrangagĩrĩria abatari
\q2 na mũkaniina athĩĩni a bũrũri,
\b
\q2 
\v 5 mũkĩũragia atĩrĩ,
\q1 “Karũgamo ka Mweri gagaathira-rĩ,
\q2 nĩguo twendie irio,
\q1 na Thabatũ ĩthire,
\q2 nĩguo twendie ngano,\f + \fr 8:5 \ft Karũgamo ka Mweri o na Thabatũ ciarĩ ciathĩ nyamũre; nĩ ũndũ ũcio andũ matingĩendirie kĩndũ ihinda-inĩ rĩu.\f*
\q1 tũkĩnyiihagia ithimi,
\q2 tũkĩongagĩrĩra thogora,
\q2 na tũkĩheenanagia na ratiri itarĩ cia ma;
\q1 
\v 6 tũgũrage athĩĩni na betha,
\q2 nao arĩa abatari tũkamagũra na nyamũga igĩrĩ,
\q2 o na twendagie magira hamwe na ngano.”
\p 
\v 7 Jehova o we ũrĩa Jakubu etĩĩagĩra, ehĩtĩte akoiga atĩrĩ, “Ndirĩ hĩndĩ ngariganĩrwo nĩ ciĩko ciothe iria maneeka.
\q1 
\v 8 “Githĩ bũrũri ndũkainaina nĩ ũndũ wa ũguo,
\q2 na arĩa othe matũũraga kuo macakae?
\q1 Bũrũri wothe nĩkũiyũra ũkaiyũra ta Rũũĩ rwa Nili,
\q2 ũhũũrane, na ũcooke ũhũũcũke
\q2 ta rũũĩ rwa Misiri.”
\p 
\v 9 Mwathani Jehova ekuuga atĩrĩ, “Mũthenya ũcio-rĩ,
\q1 “nĩngatũma riũa rĩthũe mĩaraho,
\q2 na ndũme thĩ kũgĩe nduma mũthenya barigici.
\q1 
\v 10 Nĩngagarũra ciathĩ cianyu ituĩke macakaya,
\q2 na kũina kwanyu guothe gũtuĩke kĩrĩro.
\q1 Nĩngatũma inyuothe mwĩhumbe makũnia,
\q2 na ndĩmwenje mĩtwe.
\q1 Nĩngatũma ihinda rĩu rĩhaane ta hĩndĩ ya macakaya ma mwana wa mũmwe,
\q2 naguo mũthia warĩo ũtuĩke ta mũthenya mũrũrũ.”
\b
\q1 
\v 11 Mwathani Jehova ekuuga atĩrĩ:
\q2 “Matukũ nĩmarooka, rĩrĩa ngaatũma ngʼaragu bũrũri-inĩ,
\q1 na ti ngʼaragu ya irio kana nyoota wa maaĩ,
\q2 no nĩ ngʼaragu ya kũigua ciugo cia Jehova.
\q1 
\v 12 Andũ magaatũgũũgaga kuuma iria-inĩ rĩmwe nginya rĩrĩa rĩngĩ,
\q2 na morũũrage kuuma gathigathini nginya irathĩro,
\q1 magĩcaria kiugo kĩa Jehova,
\q2 no matigakĩona.
\p 
\v 13 “Mũthenya ũcio-rĩ,
\q1 “airĩtu arĩa ciĩrorerwa na aanake arĩa marĩ hinya
\q2 nĩmakaringĩka nĩ nyoota.
\q1 
\v 14 Acio mehĩtaga na thoni cia Samaria,
\q2 kana makoiga atĩrĩ, ‘Ti-itherũ o ta ũrĩa ngai ĩyo yaku ĩtũũraga muoyo wee Dani’,
\q2 o na kana makoiga atĩrĩ, ‘Ti-itherũ o ta ũrĩa ngai ĩyo ya Birishiba itũũraga muoyo’:
\q1 nĩmakaagũa,
\q2 na maticooke gũũkĩra rĩngĩ.”
\c 9
\s1 Isiraeli Nĩgũkanangwo
\p 
\v 1 Nĩndonire Mwathani arũgamĩte kĩgongona-inĩ, nake akiuga atĩrĩ:
\q1 “Gũtha ciongo cia itugĩ,
\q2 nĩgeetha hingĩro cia nyũmba cienyenye.
\q1 Hingĩro icio nĩigwĩre mĩtwe ya andũ othe,
\q2 na arĩa magatigara nĩngamooraga na rũhiũ rwa njora.
\q1 Gũtirĩ o na ũmwe ũkoora;
\q2 gũtirĩ ũkaahonoka.
\q1 
\v 2 O na mangĩkenja thĩ makinye kwa ngoma,
\q2 guoko gwakwa no gũkaamaruta kuo.
\q1 O na mangĩkaahaica igũrũ,
\q2 nĩngamaharũrũkia kuuma kuo.
\q1 
\v 3 O na mangĩkehitha igũrũ rĩa kĩrĩma gĩa Karimeli,
\q2 nĩngamaguĩma kuo ndĩmanyiite.
\q1 O na mangĩkehitha mathiĩ rungu rwa iria-rĩ,
\q2 o nakuo nĩngatha nyoka ĩmarũme.
\q1 
\v 4 O na mangĩgaatwarwo ithaamĩrio nĩ thũ ciao,
\q2 nĩngathana mooragĩrwo kuo na rũhiũ rwa njora.
\q1 Ngamakũũrĩra maitho makwa,
\q2 maitho ma ũũru, no ti ma wega.”
\b
\q1 
\v 5 Mwathani, o we Jehova Mwene-Hinya-Wothe,
\q2 ũrĩa ũhutagia thĩ, ĩgatweka,
\q2 nao arĩa othe matũũraga kuo magacakaya,
\q1 bũrũri wothe nĩkũiyũra ũiyũrĩte ta Rũũĩ rwa Nili,
\q2 ningĩ ũkahũcũka ta rũũĩ rwa Misiri,
\q1 
\v 6 we ũrĩa wakaga gĩikaro gĩake kĩa ũthamaki kĩraihu kũu igũrũ,
\q2 na akahaanda gĩtina gĩakĩo gũkũ thĩ,
\q1 ũrĩa wĩtaga maaĩ ma iria rĩrĩa inene,
\q2 na akamaitũrũra gũkũ thĩ-rĩ,
\q2 Jehova nĩrĩo rĩĩtwa rĩake.
\b
\q1 
\v 7 Jehova ekuuga atĩrĩ:
\q1 “Githĩ inyuĩ andũ a Isiraeli
\q2 mũtihaana andũ a Kushi harĩ niĩ?
\q1 Githĩ ti niĩ ndaarutire na ngĩambatia andũ a Isiraeli kuuma bũrũri wa Misiri,
\q2 na Afilisti kuuma Kafitori,
\q2 na Asuriata ngĩmaruta Kiri?
\b
\q1 
\v 8 “Ti-itherũ, maitho ma Mwathani Jehova
\q2 nĩmacũthagĩrĩria makona ũthamaki ũrĩa wĩhagia.
\q1 Nĩngawananga,
\q2 ũthire gũkũ thĩ,
\q1 no ndikaananga
\q2 nyũmba ya Jakubu biũ,”
\q4 ũguo nĩguo Jehova ekuuga.
\q1 
\v 9 “Nĩgũkorwo nĩngathana,
\q2 na nĩngainainia nyũmba ya Isiraeli
\q2 gatagatĩ-inĩ ka ndũrĩrĩ ciothe,
\q1 o ta ũrĩa ngano ĩinainagio ĩrĩ gĩcungi-inĩ,
\q2 na gũkaaga kahĩndĩ kangĩgũa thĩ.
\q1 
\v 10 Andũ arĩa othe ehia thĩinĩ wa andũ akwa
\q2 makooragwo na rũhiũ rwa njora,
\q1 o arĩa othe moigaga atĩrĩ,
\q2 ‘Tũtingĩkorererwo nĩ mũtino, kana ũtũtũnge.’
\s1 Gũcookio kwa Isiraeli
\q1 
\v 11 “Mũthenya ũcio nĩngacookereria
\q2 hema ya Daudi ĩrĩa ĩgwĩte,
\q1 thondeke kũrĩa yunĩkangĩte,
\q2 na njookererie kũrĩa yanangĩtwo,
\q2 na ndĩmĩake o ta ũrĩa yatariĩ mbere,
\q1 
\v 12 nĩgeetha makegwatĩra matigari ma Edomu,
\q2 na ndũrĩrĩ ciothe iria ciĩtanagio na rĩĩtwa rĩakwa,”
\qc ũguo nĩguo Jehova ekuuga,
\q4 ũrĩa ũgeeka maũndũ macio.
\p 
\v 13 Jehova ekuuga atĩrĩ, “Matukũ nĩmarooka,
\q1 “rĩrĩa mũgethi agaakorererwo nĩ mũciimbi,
\q2 nake mũhaandi akorererwo nĩ mũndũ ũrĩa ũhihaga thabibũ.
\q1 Ndibei ya mũhihano ĩgaatataga kuuma irĩma-inĩ,
\q2 na ĩthererage kuuma tũrĩma-inĩ tuothe.
\q1 
\v 14 Nĩngacookia andũ akwa a Isiraeli arĩa maatahĩtwo,
\q2 nao macookererie matũũra manene marĩa maanangĩtwo, matũũre kuo;
\q1 ningĩ marĩme mĩgũnda ya mĩthabibũ na manyuuage ndibei yayo.
\q2 Magathondeka mĩgũnda ya irio na marĩĩage maciaro mayo.
\q1 
\v 15 Niĩ ngaahaanda Isiraeli bũrũri wao ene,
\q2 na matigacooka kũrutwo rĩngĩ bũrũri ũcio niĩ ndĩmaheete,”
\b
\q4 ũguo nĩguo Jehova Ngai wanyu ekuuga.
