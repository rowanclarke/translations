\v 12 \w Entonces|strong="H3651"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w congregación|strong="H6951"\w* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* \w gran|strong="H1419"\w* \w voz|strong="H6963"\w*: ¡\w Sí|strong="H5921"\w*! \w Que|strong="H5921"\w* \w se|strong="H5921"\w* \w haga|strong="H6213"\w* \w con|strong="H5921"\w* \w nosotros|strong="H3605"\w* \w según|strong="H5921"\w* \w tu|strong="H6213"\w* \w palabra|strong="H1697"\w*.  
\v 13 \w Pero|strong="H3588"\w* \w la|strong="H3588"\w* \w gente|strong="H5971"\w* \w es|strong="H2088"\w* \w mucha|strong="H7227"\w* \w y|strong="H3588"\w* \w es|strong="H2088"\w* \w tiempo|strong="H6256"\w* \w de|strong="H3588"\w* \w lluvias|strong="H1653"\w*. \w No|strong="H3808"\w* tenemos \w fuerza|strong="H3581"\w* \w para|strong="H3588"\w* permanecer \w afuera|strong="H2351"\w*, \w ni|strong="H3808"\w* \w es|strong="H2088"\w* \w éste|strong="H2088"\w* un trabajo \w de|strong="H3588"\w* un \w día|strong="H3117"\w* \w o|strong="H3068"\w* \w dos|strong="H8147"\w*, \w porque|strong="H3588"\w* somos \w muchos|strong="H7227"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* pecamos \w en|strong="H3588"\w* \w esto|strong="H2088"\w*.   
