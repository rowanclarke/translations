\id 2CO - Biblica® Open Igbo Contemporary Bible 2020
\h 2 Ndị Kọrint
\toc1 2 Ndị Kọrint
\toc2 2 Ndị Kọrint
\toc3 2Kọ
\mt1 2 Ndị Kọrint
\c 1
\p 
\v 1 Pọl, onyeozi nke Jisọs Kraịst dịka ọchịchọ nke Chineke si dị, na Timoti nwanne anyị nwoke,
\b
\p Na-edegara chọọchị Chineke nke dị na Kọrint, na ndị nsọ niile ndị nọ nʼala Akaịa akwụkwọ:
\b
\p 
\v 2 Ka amara na udo nke sitere na Chineke Nna anyị, na Onyenwe anyị Jisọs Kraịst dịrị unu.
\b
\s1 Ekele dịrị Chineke onye nkasiobi
\p 
\v 3 Otuto dịrị Chineke na Nna nke Onyenwe anyị Jisọs Kraịst, bụ Nna nke obi ebere, nakwa Chineke nke nkasiobi niile.
\v 4 Onye na-akasị anyị obi nʼime nsogbu anyị niile, ka anyị site nʼụzọ dị otu a nwee ike ịkasị ndị ọzọ niile nọ na nsogbu dị iche iche obi. Inyere ha aka dịka anyị onwe anyị si nata inyeaka site nʼaka Chineke.
\v 5 Nʼihi na dịka anyị si eketa oke nʼime ọtụtụ ahụhụ nke Kraịst, otu a nkasiobi anyị na-ababiga ụba site na Kraịst.
\v 6 Ma ọ bụrụ na anyị na-ahụ ahụhụ, ọ bụ nʼihi na nkasiobi unu, nakwa nzọpụta unu. Ọ bụrụkwa na a na-akasị anyị obi, ọ bụkwa nʼihi nkasiobi unu, nke na-arụpụta ike na ume iji ntachiobi die ụdị ahụhụ nke anyị onwe anyị na-edikwa.
\v 7 Olileanya anyị nwere nʼebe unu nọ sịrị ike, ebe anyị maara na dịka unu si eketa oke nʼịta ahụhụ anyị, otu ahụkwa ka unu ga-esi keta oke na nkasiobi ahụ anyị na-anata.
\p 
\v 8 Anyị chọrọ ka unu mara ụmụnna m, ihe banyere nsogbu e sogburu anyị nʼEshịa. Nʼezie, nsogbu ahụ karịrị anyị ike, mee ka anyị hapụ inwekwa olileanya na anyị ga-emesi dịrị ndụ.
\v 9 Nʼezie, ọ dị nnọọ nʼoge ahụ, dịka a ga-asị na a mara anyị ikpe ọnwụ. Ma anyị maara na o si otu a mee ka anyị nwee ike ịmụta na o kwesighị ka anyị tụkwasị obi nʼike nke aka anyị, kama ka anyị nwee olileanya nʼime Chineke, onye pụrụ ime ka ndị nwụrụ anwụ si nʼọnwụ bilie.
\v 10 Ọ bụ Chineke bụ onye zọpụtara anyị site nʼime oke ọnwụ dị otu a. Anyị nwekwara ntụkwasị obi na ọ ga-aga nʼihu na-azọpụtakwa anyị,
\v 11 dịka unu ga-enyekwara anyị aka site nʼekpere unu, ka ọtụtụ nwere ike nye ekele nʼihi anyị maka onyinye amara anyị natara na nzaghachi ekpere ọtụtụ mmadụ ndị a na-ekpere anyị.
\s1 Mgbanwe nzube Pọl
\p 
\v 12 Ịnya isi anyị bụ nke a, na akọnuche anyị na-agbara anyị akaebe na anyị kpara agwa ọma nʼụwa, karịchasịa nʼebe unu nọ, nʼịdị nsọ na izi ezi nke si nʼaka Chineke. Nke a bụ site nʼamara o nyere anyị, ọ bụghị site nʼamamihe nke mmadụ.
\v 13 Nʼihi na ihe anyị na-edere unu abụghị ihe unu na agaghị agụta maọbụ ghọta. Enwere m nchekwube na unu ga-aghọta ya nke ọma.
\v 14 Dịka unu ghọtarala anyị nwa nke nta ugbu a, unu ga-eji anyị anya isi nʼụbọchị nke Onyenwe anyị Jisọs.
\p 
\v 15 Ihe m na-ekwu were m anya, nke mere m ji chọọ ibu ụzọ bịa leta unu ka unu nwee uru abụọ.
\v 16 Ebu m ya nʼobi na m ga-akwụsị hụ unu mgbe m na-agafe ịga Masidonia. Ebukwa m ya nʼobi m na mgbe m si Masidonia na-alaghachi na m ga-akwụsịkwa ileta unu, ka unu nweekwa ike inyere anyị aka mgbe anyị bidoro ịlaghachi Judịa.
\v 17 E nwere m obi abụọ mgbe m chọrọ ime nke a? Ana m ezube nzube m dịka mmadụ nkịtị, onye dị nkwadobe ikwu “E,” na “E e,” nʼotu oge ahụ?
\p 
\v 18 Ma dịka Chineke si bụrụ onye kwesiri ntụkwasị obi, okwu anyị gwara unu abụghị “E,” na “E e.”
\v 19 Nʼihi na Ọkpara Chineke, Jisọs Kraịst, onye e sitere nʼọnụ Saịlas na Timoti na mụ onwe m kwusaa abụghị “E” na “E e,” kama nʼime ya ọ bụ naanị “E.”
\v 20 Nʼime Kraịst ka anyị hụrụ “E” na nkwa niile nke Chineke kwere ụmụ mmadụ. Nke a mere anyị ji site na ya kwee “Amen” nʼinye Chineke otuto.
\v 21 Ọ bụ Chineke nʼonwe ya mere ka anyị na unu guzosie ike nʼime Kraịst. O meela ka anyị bụrụ ndị e tere mmanụ.
\v 22 Ọ kara anyị akara nʼihu, nyekwa anyị Mmụọ Nsọ ya ka o biri nʼobi anyị, dịka onye ga-ahụ na anyị ga-emezu nkwa ahụ niile.
\p 
\v 23 Ana m akpọku Chineke dịka onye akaebe m, ọ bụ nʼihi ịnapụta unu mere m ji hapụ ịbịa Kọrint.
\v 24 Ọ bụghị na anyị bụ ndị ọchịchị nke okwukwe unu, kama anyị so unu na-arụkọ ọrụ ka unu nwe ọṅụ nʼihi na ọ bụ site nʼokwukwe ka unu ga-esi kwụrụ chịm.
\c 2
\nb 
\v 1 Ekpebiri m nʼime obi m na-agaghị m abịakwute unu ọzọ, iwetara unu ihe mwute.
\v 2 Nʼihi na ọ bụrụ na m eme ka obi jọọ unu njọ, onye kwanụ ga-akasị m obi ma ọ bụghị unu, unu onwe unu ndị m mere ka obi jọọ njọ?
\v 3 E deere unu akwụkwọ a dịka m kwesiri ime ka m ghara inwe mwute mgbe m bịara, site nʼaka ndị kwesiri ime ka obi dị m mma, nʼihi na o doro m anya na ọṅụ m ga-abụ ọṅụ nke unu niile.
\v 4 Eji m anya mmiri dị ukwuu na oke obi mgbu na obi mgbawa deere unu akwụkwọ, ọ bụghị ka m kpasuo unu iwe kama ka unu nwee ike ịmata oke ịhụnanya m nwere nʼebe unu nọ.
\s1 Mgbaghara dịrị onye mmehie
\p 
\v 5 Ọ bụrụ na onye ọbụla mere ihe butere obi mgbu, ka a hapụ ikwu ya karịa ka o kwesiri, ọ bụghị naanị m ka o wetaara obi mgbu, o wetakwaara unu niile obi mgbu.
\v 6 Nʼihi na ntaramahụhụ unu niile kpebiri nye ya ezuola.
\v 7 Ugbu a, bikonu ụmụnna m, o kwesiri ka unu gbaghara ya, ma kasịe ya obi, ka ọ hapụ inwe obi ilu maọbụ daa mba na mmụọ ya, rubiga ụjụ oke.
\v 8 Ya mere ana m arịọ unu, bikonu, gosinụ ya na unu hụrụ ya nnọọ nʼanya.
\v 9 Ihe mere m ji dee ihe m dere nʼakwụkwọ nke mbụ bụ ka m chọpụta ma unu jikekwara mgbe niile irube isi nʼihe niile.
\v 10 Ọ bụrụ na unu agbaghara onye ahụ mụ onwe m kwa agbagharala ya. Mgbaghara m, a sịkwa na o nwere ihe m na-agbaghara, ana m eme ya nʼihi unu nʼihu Kraịst.
\v 11 Anyị na-eme nke a ka Ekwensu ghara ịghọgbu anyị. Anyị maara ihe niile ọ na-ezube.
\s1 Ndị ozi nke ọgbụgba ndụ ọhụrụ
\p 
\v 12 Mgbe m bịarutere Troas ikwusa oziọma Kraịst, e megheere m ụzọ nʼime Onyenwe anyị.
\v 13 Ma enweghị m izuike nʼime obi m, nʼihi na ahụghị m Taịtọs ezi nwanna m nʼebe ahụ. Nke a mere m jiri kelee ha hapụ ha gawa Masidonia.
\s1 Mmeri na-adị site na Kraịst
\p 
\v 14 Ma ekele dịrị Chineke, onye na-edugharị anyị na-enye anyị mmeri, nʼihi njikọ e jikọtara anyị na Kraịst, onye na-eji anyị arụ ọrụ, ime ka onye ọbụla nụrụ isisi ụtọ nke oziọma ya.
\v 15 Nʼihi na anyị bụ mmanụ isi ụtọ nke Kraịst nye Chineke, nʼetiti ndị ọ na-azọpụta na nʼetiti ndị na-ala nʼiyi.
\v 16 Nʼetiti ndị ahụ na-ala nʼiyi, isisi ụtọ a bụ ihe na-ewetara ha ọnwụ, ma nʼetiti ndị ahụ a na-azọpụta, ọ bụ isisi ụtọ a na-ewetara ha ndụ. Onye zuru ime ihe ndị a?
\v 17 Nʼihi na anyị adịghị ka ọtụtụ mmadụ ndị na-eji okwu Chineke azụ ahịa. Kama, nʼime Kraịst anyị na-ekwu okwu anyị site nʼobi dị ọcha, dịka ndị ahụ Chineke zipụrụ ịrụ ọrụ a.
\c 3
\s1 Ndị ozi ọgbụgba ndụ ọhụrụ
\p 
\v 1 Anyị na-ebido ito onwe anyị ọzọ? Ọ dị a mkpa anyị inye unu, maọbụ ịnata nʼaka unu akwụkwọ nkọwa iji too onwe anyị dịka ụfọdụ mmadụ ndị ọzọ si eme?
\v 2 Unu onwe unu bụ akwụkwọ ozi anyị nke e dere nʼobi anyị nke mmadụ niile maara ma gụọkwa.
\v 3 Unu na-egosikwa na unu bụ akwụkwọ ozi si nʼebe Kraịst nọ, mpụta ihe nke ozi anyị jere. Ọ bụghị ihe e ji inki\f + \fr 3:3 \ft Ya bụ, mkpisi akwụkwọ\f* dee na mbadamba nkume, kama ọ bụ mmụọ Chineke na-adị ndụ ka e ji dee ya na mbadamba obi mmadụ.
\p 
\v 4 Nke a bụ ntụkwasị obi anyị nwere site na Kraịst nʼebe Chineke nọ.
\v 5 Ọ dịkwaghị mgbe anyị ji chee nʼime onwe anyị, na anyị nwere ike ime ihe ọbụla bara uru site nʼike aka anyị, kama ihe ọbụla anyị nwere, ihe ọbụla anyị rụpụtara, sitere nʼaka Chineke.
\v 6 Onye mere ka anyị zuo oke ịbụ ndị ozi ya nke ọgbụgba ndụ ọhụrụ, nke edeghị nʼakwụkwọ iwu kama nʼime Mmụọ. Ihe e dere nʼakwụkwọ iwu na-eweta ọnwụ, ma Mmụọ na-enye ha ndụ.
\s1 Ebube nke ọgbụgba ndụ ọhụrụ
\p 
\v 7 Ma ọ bụrụ nʼije ozi ahụ nke na-eweta ọnwụ bụ nke e gbunyere nʼelu nkume ji ebube dị ukwuu bịa, nke mere na ụmụ Izrel apụghị ilegide Mosis anya nʼihu mgbe o si nʼelu ugwu Saịnaị rịdata nʼihi ebube nke ihu ya, bụ ebube nke na-agabiga agabiga,
\v 8 ọ bụ nʼije ozi nke Mmụọ nsọ agaghị adị ebube karịa?
\v 9 Ọ bụrụ na-enwere ebube nʼime ije ozi nke amamikpe, ije ozi nke ezi omume ga-adị ebube karịa ya.
\v 10 Nʼezie, ihe jupụtara nʼebube mgbe ochie enwekwaghị ebube ọbụla ugbu a, nʼihi na ebube nke ọgbụgba ndụ ọhụrụ ekpuchiela ya.
\v 11 Ọ bụrụ na ihe na-agafe agafe nwere ebube dị otu a, ihe ga-anọgide mgbe niile ga-enwe ebube karịa ya.
\p 
\v 12 Ya mere, ebe ọ bụ na anyị nwere olileanya dị otu a, anyị enweghị egwu ọbụla.
\v 13 Anyị agaghị adị ka Mosis onye weere akwa kpuchie ihu ya, nʼihi na ọ chọghị ka ụmụ Izrel hụ ebube ahụ na-agbanwe agbanwe.
\v 14 Kama e mechiri obi ha ruo taa. Nʼihi na mgbe ọbụla ha gụrụ akwụkwọ ọgbụgba ndụ ochie ahụ, akwa mkpuchi ahụ na-anọgidekwa apụghị apụ nʼobi ha, nʼihi na ọ bụ naanị site nʼime Kraịst ka ọ ga-eji pụọ.
\v 15 Ee, tutu ruo taa, mgbe ọbụla ha na-agụ akwụkwọ iwu ahụ Mosis dere, ihe mkpuchi na-adịgide nʼobi ha.
\v 16 Ma mgbe onye ọbụla tụgharịrị nʼebe Onyenwe anyị nọ, a na-ewepụ akwa mkpuchi ahụ.
\v 17 Nʼihi na Onyenwe anyị bụ Mmụọ, ma ebe ọbụla kwa Mmụọ Onyenwe anyị nọ, nʼebe ahụ ka mmadụ pụrụ inwere onwe ya.
\v 18 Anyị niile bụ ndị e wepụrụla akwa mkpuchi site nʼihu, na-egosi ebube nke Onyenwe anyị. A na-agbanwe anyị ịbanye nʼoyiyi ya site nʼebube ruo nʼebube, nke si nʼaka Onyenwe anyị, onye bụ Mmụọ.
\c 4
\s1 Akụ ebube dị nʼite aja
\p 
\v 1 Ya mere, ebe anyị natara ije ozi a site nʼebere Chineke, ike adịghị agwụ anyị nʼobi.
\v 2 Anyị ahapụla omume nzuzo niile na-eweta ihere. Anyị ahapụla ụzọ aghụghọ niile, maọbụ iji okwu Chineke na-atụ asị. Kama site nʼikwupụta eziokwu ahụ ka ndị mmadụ were ezi akọnuche ha mata ụdị mmadụ anyị bụ nʼihu Chineke.
\v 3 Ma a sịkwa na oziọma nke anyị na-ekwusa dịka ihe e zoro ezo, ọ bụ ihe e zoro ezo nye ndị ahụ na-ala nʼiyi.
\v 4 Nʼebe ha nọ, chi nke ụwa a ekpuchiela uche ndị na-ekweghị ekwe iji gbochie ha ịhụ ìhè nke oziọma ahụ na-ezipụta ebube Kraịst, onye dị nʼụdị Chineke nʼonwe ya.
\v 5 Nʼihi na ọ bụghị anyị onwe anyị ka anyị na-ekwusa, kama anyị na-ekwusa na Kraịst Jisọs bụ Onyenwe anyị. Ma anyị onwe anyị bụ ụmụodibo unu nʼihi Jisọs.
\v 6 Nʼihi na ọ bụ Chineke ahụ sịrị, ka ìhè si nʼọchịchịrị chawapụta;\f + \fr 4:6 \ft \xt Jen 1:3\xt*\f* bụkwa onye mere ka ìhè ya nwuwa nʼime obi anyị. Nke a ka o mere iji wetara anyị ìhè amamihe nke ebube Chineke nʼihu Kraịst.
\p 
\v 7 Anyị onwe anyị bụ ndị natara akụ nke dị oke ọnụahịa dị nʼime ite ụrọ, iji gosi na ike kacha elu si nʼaka Chineke, ọ bụghị nʼaka anyị.
\v 8 A na-akpagbu anyị nʼakụkụ niile, ma adịghị emeri anyị. Mgbe ụfọdụ, anyị nọ na mgbagwoju anya ma anyị adịghị ada mba.
\v 9 A na-esogbu anyị, ma adịghị ahapụ naanị anyị; mgbe ụfọdụ, a na-akụtu anyị nʼala ma adịghị ala anyị nʼiyi.
\v 10 Ọtụtụ mgbe, anyị na-ebugharị nʼahụ anyị ọnwụ Jisọs, ka ndụ nke Jisọs nwekwa ike pụta ìhè nʼahụ anyị.
\v 11 Mgbe ọbụla anyị dị ndụ, anyị nọ nʼọnwụ nʼihi Jisọs, ka ndụ Jisọs nwee ike pụta ìhè nʼahụ anyị pụrụ ịnwụ anwụ.
\v 12 Nke a pụtara na ọnwụ na-arụsị ọrụ ike nʼime anyị, ma na ndụ na-arụ ọrụ nʼime unu.
\p 
\v 13 Ebe ọ bụ na anyị nwere otu mmụọ nke okwukwe ahụ, dịka e si dee nʼakwụkwọ nsọ, “Ekweere m, ya mere m ji kwuo.”\f + \fr 4:13 \ft \xt Abụ 116:10\xt*\f* Anyị onwe anyị kwekwara, nʼihi nke a mere anyị ji na-ekwu,
\v 14 ma anyị maara na onye mere ka Onyenwe anyị Jisọs si nʼọnwụ bilie, ga-emekwa ka anyị soro Jisọs si nʼọnwụ bilie, ma kpọbatakwa anyị na unu nʼihu ya.
\v 15 Ihe ndị a niile bụ maka nʼihi unu, ka ọ ga-abụ amara na-abawanye irute ọtụtụ mmadụ aka, ka o nwee ike na-abawanye inye ekele maka otuto nke Chineke.
\p 
\v 16 Ọ bụ nke a mere ike adịghị agwụ anyị nʼobi. Ọ bụ ezie na anụ ahụ anyị na-anwụ anwụ, ma a na-agba mmụọ anyị ume kwa ụbọchị.
\v 17 Nwantịntị ahụhụ nke anyị na-ata ugbu a, nke na-adị nwa oge, na-akwadoro anyị otuto ebighị ebi dị ukwuu.
\v 18 Nʼihi na anyị adịghị ele ihe anya nwere ike ịhụ, kama anyị na-ele anya nʼihe ahụ anya na-adịghị ahụ. Nʼihi na ihe ahụ anya na-ahụ na-adị naanị nwa oge, ma ihe ahụ anya na-adịghị ahụ na-adị ruo mgbe ebighị ebi.
\c 5
\s1 Ebe obibi anyị nʼeluigwe
\p 
\v 1 Nʼihi na anyị ma nke ọma na mgbe e mebiri ụlọ ikwu nke anyị bi nʼime ya, bụ ụlọ nke ụwa a, anyị nwere ụlọ nke sitere na Chineke, ụlọ nke ejighị aka wuo, ga-adị ebighị ebi nʼeluigwe.
\v 2 Ugbu a anyị nọ na-asụ ude, na-enwe agụụ inweta ebe obibi anyị dị nʼeluigwe.
\v 3 Ka ọ ga-abụ anyị yiri ya, ka anyị hapụ ịdị ka ndị gba ọtọ.
\v 4 Mgbe ahụ niile anyị nọ nʼime ụlọ ikwu a,\f + \fr 5:4 \ft Anụ ahụ nke ụwa\f* anyị na-anọgide nʼịsụ ude nke ibu arọ. Ọ bụghị nʼihi na anyị chọrọ ịnwụ anwụ bụrụ ndị na-enweghị anụ ahụ, kama ọ bụ nʼihi na anyị chọrọ ka e yikwasị anyị anụ ahụ nke eluigwe ahụ, ka anụ ahụ a pụrụ ịnwụ anwụ yikwasị ndụ ebighị ebi.
\v 5 Chineke onye ya onwe ya, bụ onye kwadobere anyị maka mgbanwo nke a, nyekwara anyị Mmụọ Nsọ ka ọ bụrụ onye ga-ahụ na anyị ga-enwetazu nkwa ahụ niile.
\p 
\v 6 Nʼihi nke a, anyị nwere obi ike mgbe niile, nʼihi na anyị maara na mgbe anyị na-aga nʼihu na-adị ndụ nʼanụ ahụ a, anyị na Onyenwe anyị anọghị.
\v 7 Nʼihi ọ bụ okwukwe ka anyị ji adị ndụ ọ bụghị ihe anya hụrụ.
\v 8 Obi siri anyị ike. Ọ gaara amasị anyị ịhapụ ụlọ nke a anyị bi na ya, bụ ahụ anyị ma lakwuru Onyenwe anyị nʼebe obibi ya.
\v 9 Ya mere, ma anyị nọ nʼụlọ a maọbụ nʼọzọ, ihe anyị chọrọ bụ ka anyị mee ihe ga-atọ ya ụtọ.
\v 10 Nʼihi na anyị niile ga-eguzo nʼihu oche ikpe Kraịst, mgbe ahụ onye ọbụla nʼime anyị, nʼotu nʼotu, ga-anata ụgwọ ọrụ dịka ihe ọ rụrụ na-anụ ahụ ya mgbe ọ nọ nʼime ụwa si dị, maọbụ ezi ihe maọbụ ihe ọjọọ.
\s1 Ije ozi nke ịdị na mma
\p 
\v 11 Ọ bụ nʼihi na anyị maara nnọọ ihe ịtụ egwu Onyenwe anyị pụtara, ka anyị ji na-arụsị ọrụ ike ka ndị mmadụ mata Chineke makwaara ụdị mmadụ anyị bụ. Enwekwara m olileanya na nke a pụtara ihe nye akọnuche unu.
\v 12 Anyị adịghị agbalị ịgwa unu na anyị dị mma, kama anyị chọrọ inye unu ihe unu ga-eji nyaa isi mgbe unu na-ekwu ihe banyere anyị, ka unu nwee ike ịmata ihe unu ga-azaghachi ndị ahụ na-anya isi banyere ihe ha ji anya ha hụ, kama ihe dị mmadụ nʼobi.
\v 13 Ọ bụrụ na anyị amaghị onwe anyị, ọ bụ nʼihi Chineke, ọ bụrụ na anyị nwere uche zuruoke, ọ bụ nʼihi unu.
\v 14 Ọ bụ ịhụnanya Kraịst na-akwagide anyị, nʼihi na anyị kwere na otu onye nwụrụ maka mmadụ niile, nke pụtara na mmadụ niile anwụọla.
\v 15 Ọ nwụrụ nʼihi mmadụ niile, ka ndị dị ndụ gharakwa ịdịrị onwe ha ndụ ọzọ, kama maka onye ahụ nwụrụ nʼihi ha ma sikwa nʼọnwụ kulie.
\p 
\v 16 Bido ugbu a gawa, anyị adịghị elekwa onye ọbụla anya dịka mmadụ nkịtị. Nʼihi na anyị sitere nʼụzọ dị otu a lee Kraịst anya, chee na ọ bụ mmadụ efu. Ma ugbu a, anyị amakwaghị ya nʼụzọ dị otu a.
\v 17 Ya mere, ọ bụrụ na onye ọbụla amalite ịdị ndụ nʼime Kraịst, ọ ghọọla onye e kere ọhụrụ, ihe ochie agaala, nke ọhụrụ anọchie.
\v 18 Ma ọ bụ Chineke bụ onye na-eme ihe ndị a. Ọ bụ ya onwe ya sitere nʼaka Kraịst mee ka anyị na ya dịrị nʼudo. Ma ugbu a, o nyela anyị ọrụ ije ozi, ịkpọ ndị ọzọ ka ha bịa ka ya na ha dịrịkwa nʼudo.
\v 19 Ihe nke a pụtara bụ na Chineke sitere na Kraịst na-eme ka ya na ụwa dị na mma. Ọ dịghị agụkọrọ ụmụ mmadụ mmehie niile, kama o tinyela nʼaka anyị ozi banyere ụzọ o si eme ka ya na ụmụ mmadụ dịkwa na mma ọzọ.
\v 20 Ya mere, anyị bụ ndị na-anọchi anya Kraịst ijere ya ozi nʼụwa. Chineke ji anyị na-agwa unu okwu. Anyị na-arịọ unu dịka ọ bụ Kraịst nʼonwe ya na-arịọ unu. Biko, bịanụ ka unu na Chineke dịrị nʼudo.
\v 21 Nʼihi na o mere ka onye ahụ na-amaghị mmehie bụrụ mmehie nʼọnọdụ anyị, ka esi otu a mee ka anyị nwee oke nʼime ezi omume Chineke site na ya.
\c 6
\p 
\v 1 Dịka ndị ha na ya na-arụkọ ọrụ nʼotu, anyị na-arịọ arịrịọ sị unu ahapụla ịnara amara a Chineke na-enye unu nʼefu.
\v 2 Nʼihi na ọ na-ekwu,
\q1 “Nʼoge m na-anara mmadụ nke ọma anụrụ m olu unu.
\q2 Ọ bụkwa ụbọchị nzọpụta ka m nyeere unu aka.”\f + \fr 6:2 \ft \xt Aịz 49:8\xt*\f*
\m Lee, ugbu a bụ oge a na-anabata mmadụ nke ọma, ugbu a bụ ụbọchị nzọpụta.
\s1 Ahụhụ Pọl hụrụ
\p 
\v 3 Anyị etinyeghị ihe ịsọ ngọngọ nʼụzọ onye ọbụla ka ọ ghara iwetara ọrụ anyị ihe ịta ụta.
\v 4 Kama nʼime ihe niile, anyị na-agbalịsị ike ime ka ndị mmadụ mara na anyị bụ ndị na-ejere Chineke ozi. Anyị ji ndidi na ntachiobi na-edi nsogbu niile na mkpagbu niile na ahụhụ niile na-adakwasị anyị.
\v 5 A na-eti anyị ihe otiti ọtụtụ mgbe. E tinyekwala anyị nʼime ụlọ mkpọrọ dị iche iche. Ọtụtụ mgbe ka igwe mmadụ tikwara anyị ihe otiti. Anyị na-adọgbu onwe anyị nʼọrụ. Ọtụtụ abalị anyị nọkwara nʼime ịmụ anya na-erighị nri,
\v 6 nʼime ịdị ọcha na ezi nghọta na ntachiobi nke anyị nwere, nʼinwe obiọma na ezi ịhụnanya nke ihu abụọ nʼadịghị na ya nʼime Mmụọ Nsọ,
\v 7 sitekwa nʼikwu eziokwu na site nʼike Chineke. Anyị buru ezi omume dịka ngwa agha nʼaka nri na nʼaka ekpe.
\v 8 Ụfọdụ na-asọpụrụ anyị ma ndị ọzọ na-eme anyị ihe ihere. Ụfọdụ na-ata anyị ụta, ma ụfọdụ na-eto anyị. Ụfọdụ mmadụ na-agụ anyị dị ka ndị ụgha, ma anyị nọgidesịrị ike na-ekwu eziokwu.
\v 9 Ụwa amaghị anyị, ma a maara anyị. Ọ bụ ezie na anyị na ọnwụ na-anọ nso mgbe niile, ma lee anyị ka dịkwa ndụ. A na-ata anyị ahụhụ, ma lee anyị anwụghị.
\v 10 Anyị na-anọ nʼihe mwute mgbe niile, ma lee ọṅụ juru anyị obi. Anyị bụ ndị ogbenye, ma anyị na-eme ka ọtụtụ mmadụ bụrụ ndị ọgaranya. Anyị enweghị ihe ọbụla, ma lee anyị nwere ihe niile.
\p 
\v 11 Ndị enyi anyị nọ na Kọrint, anyị agwala unu ihe niile dị anyị nʼobi, anyị emeghepụla obi anyị nye unu.
\v 12 Anyị ji obi anyị niile hụ unu nʼanya, ma unu mechiri obi unu nʼebe anyị nọ.
\v 13 Ugbu a, ana m ekwu dịka ana m agwa ụmụntakịrị. Na-emesonu anyị dịka anyị si emeso unu, meenụ ka obi unu saa mbara nʼebe anyị nọ.
\s1 Ndị Kraịst na ndị na-ekweghị ekwe
\p 
\v 14 Unu ekwela ka unu na ndị na-ekweghị ekwe nwee nkekọta ọbụla. Nʼihi na gịnị ka ezi omume na ajọ omume nwekọrọ? Olee ụdị mmekọ ìhè na ọchịchịrị ga-enwekọ?
\v 15 Ọ bụ nwekọ dị aṅaa dị na-agbata Kraịst na ekwensu? Gịnịkwa ka onye kwere ekwe na onye na-ekweghị ekwe nwekọrọ?
\v 16 Gịnị bụ ihe jikọtara ụlọnsọ Chineke na arụsị? Nʼihi na anyị onwe anyị bụ ụlọnsọ Chineke dị ndụ. Dịka Chineke kwuru,
\q1 “M ga-ebi nʼime ha.
\q2 Jegharịakwa nʼime ha.
\q1 M ga-abụkwa Chineke ha,
\q2 ma ha onwe ha ga-abụkwa ndị nke m.”\f + \fr 6:16 \ft \xt Lev 26:12; Jer 32:38; Izk 37:27\xt*\f*
\m 
\v 17 Ya mere,
\q1 “Sinụ nʼetiti ha pụta.
\q2 Nọpụkwanụ iche nʼebe ha nọ.
\q2 Otu a ka Onyenwe anyị kwuru.
\q1 Unu emetụkwala ihe ọbụla rụrụ arụ aka.
\q2 Mụ onwe m ga-akpọbatakwa unu.”\f + \fr 6:17 \ft \xt Aịz 52:11; Izk 20:34,41\xt*\f*
\m 
\v 18 Ma,
\q1 “Aga m abụrụ unu Nna,
\q2 unu onwe unu ga-abụkwara m ụmụ m ndị ikom na ndị inyom.
\q2 Otu a ka Onyenwe anyị, Onye pụrụ ime ihe niile kwuru.”\f + \fr 6:18 \ft \xt 2Sa 7:14; 7:8\xt*\f*
\c 7
\p 
\v 1 Ya mere, ndị enyi m, ebe anyị nwere nkwa ndị a niile, ka anyị debe onwe anyị ọcha nʼime ihe niile ọbụla nke na-emerụ ahụ anyị na mmụọ anyị. Ka anyị mezuo ịdị nsọ nʼịtụ egwu Chineke.
\s1 Ihe na-enye Pọl obi ụtọ
\p 
\v 2 Megheenụ obi unu nabata anyị, nʼihi na o nweghị onye ọbụla nʼetiti unu anyị mere ihe ọjọọ. O nwekwaghị onye anyị duhiere. Ọ dịkwaghị onye ọbụla anyị rigburu.
\v 3 Anaghị m ekwu ihe ndị a ka m maa unu ikpe, dịka m kwuburu na mbụ, na anyị bu unu nʼobi anyị, ịdịkọ ndụ, maọbụ ịnwụkọkwa ọnwụ nʼotu.
\v 4 Nkwuwa okwu m ji gwa unu okwu dị ukwuu; ịnya isi m nʼihi unu dịkwa ukwuu. Abụ m onye a gbara ume nʼebe ọ dị ukwu, nʼime ọnọdụ ahụhụ anyị niile, ana m aṅụrịbiga ọṅụ oke.
\p 
\v 5 Nʼihi na mgbe anyị batara Masidonia, anyị enweghị izuike ma ọlị. Kama mkpagbu si nʼaka nri na aka ekpe bịakwute anyị, ọgụ nʼezi, egwu nʼime.
\v 6 Ma otu ọ dị, Chineke, onye na-agba ndị ike gwụrụ ume, gbara anyị ume site nʼọbịbịa Taịtọs.
\v 7 Ọ bụkwaghị naanị nʼihi na ọbịbịa ọ bịara nyere anyị obi ụtọ, kama akụkọ o ji bịa, gbasara otu unu si gbaa ya ume, gwakwa anyị otu unu si na-ele anya ịhụ m, na otu unu si na-eru ụjụ nʼihi ihe niile mere, na otu unu si guzosie ike nʼukwu m, na ụdị ịhụnanya unu nwere nʼebe m nọ, obi tọrọ m ụtọ nke ukwuu.
\p 
\v 8 Ọ naghị ewutekwa m ugbu a na m deere unu akwụkwọ ahụ, ọ bụ ezie na o wutere m mgbe ahụ m na-ede ya, nʼihi na amaara m na ọ ga-ewetara unu obi ọjọọ mgbe unu gụrụ ya. Ma obi ọjọọ ahụ abụrụla naanị nke nwa oge nta.
\v 9 Ma ugbu a ana m aṅụrị ọṅụ na m dere akwụkwọ ahụ. Ọ bụghị nʼihi na ọgụgụ ya wetaara unu obi ọjọọ, kama ọ bụ nʼihi na mwute o wutere unu emeela ka unu chegharịa. Ụdị mwute unu nwere bụ ụdị mwute Chineke chọrọ ka ndị nke ya nwee. Ya mere, o nweghị ihe ọjọọ bịakwasịrị unu nʼihi akwụkwọ anyị deere unu.
\v 10 Nʼihi na iru ụjụ otu Chineke chọrọ na-eweta nchegharị nke na-eduba mmadụ na nzọpụta, bụ nchegharị nke a na-apụghị ịkwa ụta banyere ya. Ma iru ụjụ dịka ụwa si eme na-eweta ọnwụ.
\v 11 Leenụ ihe Chineke rụpụtara site nʼihe mwute dakwasịrị unu. Ugbu a, unu abụrụla ndị ọ na-anụ ọkụ nʼobi na ndị jikeere izi anyị na aka unu abụọ dị ọcha. Lee otu unu si zi iwe unu, otu unu si zikwa na ihe ahụ wutere unu. Lee otu unu si tụọ ụjọ ihe mmehie ahụ nwere ike iwetara unu. Leekwanụ otu unu si mee ihe niile igosi na unu kwagidere m. Leekwanụ otu unu si nye onye ahụ mere mmehie ahụ ntaramahụhụ ngwangwa. Unu egosila na aka unu dị ọcha nʼokwu ndị a niile.
\v 12 Ọ bụ ezie na m deere unu akwụkwọ ahụ, ma edeghị m ya nʼihi onye ahụ mehiere, maọbụ nʼihi onye ahụ e mehiere megide. Kama edere m ya ime ka Chineke gosi unu otu ihe gbasara anyị si na-anụ unu ọkụ nʼobi.
\v 13 Nʼụzọ niile ndị a, anyị bụ ndị a gbara ume site nʼịhụnanya unu nwere nʼebe anyị nọ.
\p A gbara anyị ume karịa site na ịhụ ọṅụ Taịtọs nʼihi nnabata unu nabatara, na otu unu si mee ka mmụọ ya zuru ike mgbe ọ bịakwutere unu.
\v 14 Nʼihi na tupu ọ hapụ anyị bịakwute unu, anyara m isi nʼihu ya banyere unu; ugbu a, obi dị m ụtọ nke ukwuu nʼihi na unu emeghị ka ihere mee m. Anyị ekwuola eziokwu nye unu. Ugbu a, ịnya isi m nʼebe Taịtọs nọ egosila na anyị bụ ndị eziokwu.
\v 15 Ugbu a, ịhụnanya o nwere nʼebe unu nọ na-aba ụba nke ukwuu, nʼihi ncheta ọ na-echeta otu unu niile si jiri ọṅụ gee ya ntị na otu unu si jiri ịtụ egwu na ahụ ịma jijiji nabata ya.
\v 16 Nke a na-enyekwa m obi ụtọ nʼihi na enwere m ntụkwasị obi nʼebe unu nọ nʼime ihe niile.
\c 8
\s1 Ihe onyinye maka ndị nsọ
\p 
\v 1 Anyị chọrọ ime ka unu mara, ụmụnna m, ihe banyere ihe nke amara Chineke rụrụ na nzukọ niile dị na Masidonia.
\v 2 Nʼime ọnọdụ oke mkpagbu na ihe mwute, ha nwere ọṅụ dị nnọọ ukwuu ruo na ha gbasara aka ha nye ndị ọzọ ihe, wezugakwa na ọ bụ ezie na ha bụ ndị ogbenye ọnụ ntụ.
\v 3 Ana m agba ama na ha nyere dịka ike ha, ha nyekwara ọ bụladị karịa otu a tụrụ anya. Onyinye ha si nʼobi ha pụta.
\v 4 Nʼezie, ha rịọsiri anyị arịrịọ ike ka anyị nara onyinye amara ha nyere nʼihi iso keta oke inyere ndị nsọ ndị ọzọ nọ na mkpa aka.
\v 5 Nke ka nke, ha nyere karịa ihe anyị lere anya na ha ga-enye. Nʼihi na ha buru ụzọ were onwe ha nye Onyenwe anyị. Ha sitekwara nʼọchịchọ Chineke nyekwa anyị onwe ha.
\v 6 Ya mere, anyị rịọrọ Taịtọs, onye malitere ọrụ ka ọ rụzuo ọrụ amara ahụ ruo nʼisi.
\v 7 Ma ebe unu babigara ụba oke nʼihe niile unu nwere, nʼokwukwe, na okwu, nʼihe ọmụma, na ịnụ ọkụ nʼobi, na ịhụnanya unu hụrụ anyị, lezie unu anya hụ na unu babigakwara ụba oke nʼamara nke inye ihe a.
\p 
\v 8 Anaghị m enye unu iwu, kama site nʼizi unu otu o si na-anụ ndị ọzọ ọkụ nʼobi inyeaka, achọrọ m ịchọpụta ma ịhụnanya unu na ịnụ ọkụ nʼobi unu ọ ga-adakọtakwa.
\v 9 Nʼihi na unu maara ụdị amara nke Onyenwe anyị Jisọs Kraịst nwere. Ọ bụ ezie na ọ bụ ọgaranya, ma ọ họọrọ ịbụ ogbenye nʼihi unu, ka unu onwe unu site nʼogbenye ya bụrụ ọgaranya.
\p 
\v 10 Nke a bụ ndụmọdụ m na-enye unu nʼokwu a. Ọ baara unu uru ka unu rụzuo ọrụ unu malitere ịrụ nʼafọ gara aga. Unu bụ ndị mbụ buru ụzọ chepụta ịrụ ọrụ a, unu bụkwa ndị mbụ buru ụzọ malite ime ihe banyere ya.
\v 11 Ma ugbu a mezuonụ ihe unu chepụtara ime. Ka ịnụ ọkụ nʼobi unu nwere na mbụ ịrụ ọrụ a bụrụkwa ihe unu ga-eji mezuo ya dịka ihe unu nwere si dị.
\v 12 Nʼihi na ọ bụrụ na ịnụ ọkụ nʼobi dị ebe ahụ, a na-anara ya dịka ihe mmadụ nwere ike inye, ọ bụghị ihe ọ na-enweghị ike inye.
\p 
\v 13 Nzube m abụghị ka unu nye nʼụzọ ihe ga-esi siere unu ike nʼihi na unu nyere. Kama ka e nwe nhatanha.
\v 14 Ugbu a, ọ bụ ihe dị mma ka unu nyere ndị ọzọ nọ na mkpa aka. Mgbe unu ga-anọkwa na mkpa, ha ga-enyere unu aka ma ha nwee hie nne. Nʼụzọ dị otu a, a ga-enwe nhatanha.
\v 15 Nke a bụkwa ihe akwụkwọ nsọ kwuru, “Onye ahụ chịkọtara hie nne enweghị karịa. Onye nke chịkọtara ihe dị nta enweghị ihe fọdụrụ ya inweta ihe ọ chọrọ.”\f + \fr 8:15 \ft \xt Ọpụ 16:18\xt*\f*
\s1 Nzipụ Taịtọs ka ọ gaa Kọrint
\p 
\v 16 Ekelere m Chineke onye tinyere nʼobi Taịtọs otu ịnụ ọkụ ahụ banyere unu ekele, dịka o si emetụ m nʼobi.
\v 17 Ọ bụghị naanị na o kweere ime dịka anyị si rịọrọ ya, kama nʼihi ịhụnanya o nwere nʼebe unu nọ, o kpebiri nʼime obi ya ịbịakwute unu na inyere unu aka.
\v 18 Anyị na-ezitekwa ya na nwanna anyị onye ahụ nzukọ niile na-asọpụrụ nʼihi ọrụ ikwusa oziọma ahụ.
\v 19 Ma ọ bụghị naanị nke a, kama nzukọ họpụtara ya iso anyị, na inyere anyị aka dịka anyị na-ebu onyinye a, bụ ije ozi anyị na-eje nʼihi iwetara Onyenwe anyị otuto, na izipụta njikere anyị inyere ibe anyị aka.
\v 20 Anyị na-eze ka onye ọbụla ghara ịta anyị ụta nʼihe ọbụla, nʼihi ụzọ anyị si jee ozi gbasara onyinye mgbasapụ aka a.
\v 21 Ọ bụ ọchịchọ anyị ime ihe ọma, ọ bụghị naanị nʼihu Onyenwe anyị, kama nʼihu ndị mmadụ kwa.
\p 
\v 22 Ugbu a anyị na-ezitekwara unu nwanna anyị nwoke ọzọ ka o soro ha bịakwute unu, nwanna anyị a bụ onye anyị nwapụtara, onye ọ na-anụ ọkụ nʼobi inyeaka. Ugbu a, o nwekwara ntụkwasị obi dị ukwuu nʼebe unu nọ.
\v 23 Ma banyere Taịtọs, ọ bụ onye otu m nʼọrụ a, bụrụkwa onye mụ na ya na-arụkọ ọrụ nʼetiti unu. Ma banyere ụmụnna anyị ndị ọzọ a, ha bụ ndị na-anọchite anya nzukọ, na ndị na-ewetara Kraịst otuto.
\v 24 Ya mere, gosinụ ha ihe ga-eme ka ha mata na unu hụrụ ha nʼanya. Meekwanụ ka ha mata ihe bụ ịnya isi anyị banyere unu, ka chọọchị niile hụkwa ya.
\c 9
\s1 Inyere ndị nọ na mkpa aka
\p 
\v 1 Ọ dịghị mkpa idere unu akwụkwọ banyere ozi nke ndị nsọ.
\v 2 Amaara m na unu jikeere inyere ha aka, dịka m nyara isi nye ndị Masidonia banyere unu. Nʼihi na agwara m ha na unu ndị bi na Akaịa ejikerelarị inyere ha aka kemgbe afọ gara aga. Ọ bụkwa ịnụ ọkụ nʼobi unu kwaliri obi ha, ime ihe ha mere.
\v 3 Ugbu a, ana m ezitere unu ụmụnna anyị ndị a ka e mee ka ịnya isi nke m nyara banyere unu ghara ịbụ okwu efu. Ma dịka m gwara ha na unu ejikerela, achọrọ m ka unu jikere nye ha ihe unu chọrọ inye.
\v 4 Nʼihi na ọ bụrụ na ndị Masidonia esoro m bịa hụ na unu ejikeghị ejike, ebe anyị na-anya isi na unu ejikerela, ọ ga-abụrụ m ihe ihere, bụkwara unu ihe ihere, ebe anyị nwere ntụkwasị obi na unu ga-anọ na njikere.
\v 5 Ọ bụ nke a mere m ji hụ na ọ dị mkpa ịrịọ ụmụnna anyị ka ha buru ụzọ bịa, tupu m bịa. Ka unu nwee ike ịkwado onyinye ahụ unu kwere na nkwa inye, jide ya na njikere ruo mgbe m bịara. Ka unu si otu a gosi ndị mụ na ha ga-eso na unu na-enye nʼihi na unu chọrọ inye, ọ bụkwaghị nʼihi na a gwara unu ka unu nye.
\s1 Ngọzị dịrị ndị gbasara aka nye onyinye
\p 
\v 6 Isi okwu bụ nke a, Onye ọbụla na-akụ mkpụrụ ntakịrị, ga-aghọtakwa nke nta, ma onye ahụ na-akụ mkpụrụ buru ibu ga-aghọtakwa mkpụrụ hiri nne.
\v 7 Ka onye ọbụla nye dịka o buru ụzọ kpebie nʼime obi ya inye. Ka ọ ghara inye nʼihi na mmadụ kwagidere ya, maọbụ inye nʼihi na ndị ọzọ na-enye, nʼihi na Chineke hụrụ ndị ji obi ụtọ nye onyinye ha nʼanya.
\v 8 Chineke nwere ike inye unu karịa ihe na-akpa unu, ka unu na-enwezukwa ihe unu chọrọ mgbe niile nʼoge niile. Mgbe ahụ, unu ga-enwezukwa ihe niile unu ji arụ ọrụ ọma.
\v 9 Dịka e dere ya,
\q1 “Ọ gbasara onyinye ya ebe niile nye ndị ogbenye;
\q2 ezi omume ya na-adịgidekwa ruo mgbe ebighị ebi.”\f + \fr 9:9 \ft \xt Abụ 112:9\xt*\f*
\m 
\v 10 Ma onye ahụ na-enye onye ọrụ ubi mkpụrụ nke ọ na-agha nʼubi ya, na-enyekwa mmadụ nri ọ ga-eri, ọ ga-enyekwa unu ihe niile dị unu mkpa, meekwa ka ụlọakụ unu jupụta na mkpụrụ. Ọ ga-emekwa ka mkpụrụ ezi omume unu baa ụba.
\v 11 Ọ ga-emekwa ka unu bụrụ ndị ọgaranya nʼụzọ niile, ka unu nwee ihe ga-ezuru unu na nke unu ga-enye ndị ọzọ mgbe niile. Site nʼaka anyị, afọ ofufu unu ga-enye Chineke ekele nʼihi inyeaka unu nyere ha.
\p 
\v 12 Nʼihi na ije ozi nke ife ofufe a abụghị naanị nke igboro ndị nsọ mkpa ha, kama ọ bụkwa nke na-eme ka ekele ọtụtụ ndị mmadụ na-enye Chineke babiga ụba oke.
\v 13 Nʼihi ije ozi a, nke unu sitere na ya gosi onwe unu dịka ndị kwesiri, ndị ọzọ ga-eto Chineke nʼihi irube isi unu nke dakọtara na nkwupụta unu banyere oziọma nke Kraịst, ya na onyinye afọ ofufu nke unu na-eme ka ha na ndị ọzọ niile soro unu nwekọ.
\v 14 Nke a ga-eme nʼekpere ha maka unu, ha ga-eji obi ha niile rịọọ arịrịọ, nʼihi ịdị ukwu nke amara Chineke dị nʼime unu.
\v 15 Ekele dịrị Chineke nʼihi onyinye ya dị ukwuu nke ọnụ na-apụghị ịkọ.
\c 10
\s1 Anyị bụ ndị Chineke họpụtara
\p 
\v 1 Ma mụ onwe m bụ Pọl, ji ịdị nwayọọ na obi umeala nke Kraịst na-arịọ unu. Mụ, onye na-adị umeala mgbe mụ na unu nọ nʼihu nʼihu, ma na-enwe mkwuwa okwu nʼebe unu nọ mgbe m na-anọghị nʼetiti unu.
\v 2 Arịọ m unu, ka m ghara inwe obi ike mgbe m bịarutere dịka o kwesiri nʼebe ụfọdụ ndị nọ, site na iguzogide ndị ahụ na-eche na anyị na-eme ihe dị ka ndị ụwa si eme ya.
\v 3 Ọ bụ ezie na anyị na-ebi dịka mmadụ, ma anyị adịghị ebu agha dịka usoro anụ ahụ si dị.
\v 4 Nʼihi na ngwa agha anyị ji ebu agha, abụghị ngwa agha nke mmadụ nkịtị nke ụwa, kama ha nwere ike nke mmụọ ịla ebe niile e wusiri ike nʼiyi.
\v 5 Anyị na-ala ịrụ ụka niile na okwu ụgha niile nʼiyi, nke na-egbochiri ụmụ mmadụ ụzọ e si amata Chineke, na-eme ka echiche niile hulata isi nʼokpuru Kraịst.
\v 6 Anyị nọ na njikere ịta erubeghị isi niile ahụhụ, mgbe irube isi gị zuruoke.
\p 
\v 7 Unu na-ele anya nʼihe ndị dị unu nʼihu. Ọ bụrụ na ọ bụ ihe doro anya nye onye ọbụla na ha bụ nke Kraịst, ha matakwa na onwe ha, na otu ahụ ha bụ nke Kraịst na anyị onwe anyị bụkwa nke ya.
\v 8 Ugbu a, ọ bụrụ na m anya isi banyere ikike ahụ Onyenwe anyị nyere m nʼebe unu nọ, ike ahụ o nyere m iji wulie unu elu, ọ bụghị iji wedaa unu ala, ihere agaghị eme m nʼihi nke a.
\v 9 Achọghị ka ọ dịka m a ga-asị na m sitere nʼakwụkwọ ozi m na-emenye unu egwu.
\v 10 Nʼihi na ha na-asị, “Akwụkwọ ozi ya dị arọ dịkwa ike, ma na mmadụ, ma nʼọdịdị ya na mmadụ adịghị ike, okwu ọnụ ya bụkwa ihe na-abaghị uru.”
\v 11 Ma ana m eme ka ndị dị otu a ghọta na ihe anyị na-ekwu site nʼakwụkwọ ozi mgbe anyị na-anọghị nʼetiti unu, ka anyị ga-eme ma anyị nọrọ nʼetiti unu.
\p 
\v 12 Anyị enweghị anya ike ihazi ọnọdụ maọbụ were onwe anyị tụnyere ndị ụfọdụ na ndị ahụ nʼeto onwe ha. Ma mgbe ha na-eji onwe ha na-atụ onwe ha, werekwa onwe ha na-atụnyere onwe ha, ha adịghị ezipụta nghọta.
\v 13 Ma anyị onwe anyị, adịghị anya isi banyere ihe ọbụla anyị na-enweghị ike ime. Kama anyị ga-anya isi nʼoke ọrụ ahụ Chineke kenyere anyị, ka anyị rụrụte ọ bụladị ruo nʼebe unu nọ.
\v 14 Nʼihi na anyị adịghị ekwu okwu karịrị ọnụ anyị mgbe anyị na-etinye anya nʼihe gbasara unu, nʼihi na ọ bụ anyị buru ụzọ bịakwute unu, ikwusara unu oziọma gbasara Kraịst.
\v 15 Ọ bụghị na anyị na-ekwu na ọ bụ anyị rụrụ ọrụ niile, ya na ọrụ nke ndị ọzọ rụrụ nʼetiti unu, kama olileanya anyị bụ na okwukwe unu ga na-eto eto mgbe niile, ka ọrụ ya nʼetiti unu bụrụ nke ga-eto eto.
\v 16 Nke a ga-eme ka anyị nwee ike zisaa oziọma ahụ na mba ndị ọzọ ndị dị nʼofe ala unu, ghara iji ọrụ arụrụ nʼebe ndị ọzọ na-arụ ọrụ na-etu ọnụ.
\v 17 Ma, “Onye ọbụla na-anya isi, ya nyaa nʼime Onyenwe anyị.”\f + \fr 10:17 \ft \xt Jer 9:24\xt*\f*
\v 18 Nʼihi na ọ bụghị onye ji aka ya bulie onwe ya elu ka a na-anabata, kama ọ bụ onye Onyenwe anyị jiri aka ya bulie.
\c 11
\s1 Pọl na ndị ozizi ụgha
\p 
\v 1 Ọ ga-adị m mma ma ọ bụrụ na unu ga-anagide m ka m kwuo okwu ndị a dị ka onye nzuzu. Biko nagidenụ m.
\v 2 Ekworo m nwere nʼebe unu nọ bụ ekworo nke Chineke. Ekwere m nkwa iwere unu nye otu di, ya bụ Kraịst, ka m nwe ike chee unu nʼihu ya dịka nwaagbọghọ dị ọcha nke na-amaghị nwoke.
\v 3 Ma ana m atụ egwu, na dịka agwọ jiri aghụghọ ghọgbuo Iiv, ndị nrafu ga-eji aghụghọ duhie unu, mee ka unu kwụsị iji obi dị ọcha na uche ziri ezi jeere Kraịst ozi.
\v 4 Nʼihi na unu gaara anara onye ọzọ bịakwutere unu na-ekwusa Jisọs ọzọ nke na-abụghị nke anyị kwusara, unu gaara anarakwa ike nke mmụọ ọzọ dị iche na-abụghị ike nke Mmụọ Nsọ ahụ unu natara, unu gaara ekwenyekwa na nkuzi ọzọ dị iche, na-abụghị oziọma ahụ nke unu natara.
\p 
\v 5 Ma echeghị m na ọ dị ụzọ ọbụla ndị ozi a maara aha ha si kara m mma.
\v 6 Ọ bụrụ na m abụghị onye ọka okwu, abụ m onye ọka mmụta. Anyị akọwarala unu nke a ọtụtụ mgbe nʼụzọ dị iche iche nʼihe niile.
\v 7 Ọ ga-abụ na-emere m ihe ọjọọ mgbe m wedara onwe m ala ka e welie unu elu, nʼihi nʼanaghị m unu ihe ọbụla mgbe m na-ekwusara unu oziọma Chineke?
\v 8 Ọ bụ nzukọ nọ nʼebe ọzọ nyeere m aka mgbe m na-arụ ọrụ nʼetiti unu. Ọ bụ site nʼaka ha ka m ji nata nkwado, dịka ụgwọ ọrụ m, ka m nwee ike inyere unu aka.
\v 9 Ma mgbe m nọ nʼetiti unu abụghị m ibu arọ nye onye ọbụla nʼoge mkpa m. Nʼihi na ụmụnna si Masidonia wetaara m ihe niile na-akpa m mkpa. Ebe ọ bụ na m gbalịrị debe onwe m, ka m ghara ịbụ ibu arọ nye unu nʼụzọ ọbụla nʼoge gara aga, agaghị m abụkwa ibu arọ nye unu nʼoge dị nʼihu.
\v 10 Ebe eziokwu nke Kraịst dị nʼime m, ịnya isi m nke a agaghị akwụsị na mpaghara Akaịa\f + \fr 11:10 \ft Akaịa bụkwa Griis.\f* niile.
\v 11 Nʼihi gịnị? Ọ bụ nʼihi na m ahụghị unu nʼanya? Chineke maara na m hụrụ unu nʼanya.
\p 
\v 12 Ma aga m aga nʼihu na-arụ ọrụ m na-achọghị ka unu nyere m aka nʼụzọ ọbụla ka m si otu a mee ka ndị ahụ na-akpọ onwe ha ndị ozi ghara ịnya isi kwuokwa na ha na-arụ ọrụ dịka anyị si arụ ọrụ anyị nʼetiti unu.
\v 13 Nʼihi na ndị dị otu a bụ ndị ozi ụgha, ndị ọrụ aghụghọ, ndị na-eme onwe ha ka ha bụ ndị ozi Kraịst.
\v 14 Ma omume ha adịghị eju m anya, nʼihi na ekwensu gbanwere onwe ya dịrị ka mmụọ ozi na-enye ìhè.
\v 15 Ya mere, ọ bụghị ihe iju anya ma ọ bụrụ na ndị na-ejere ya ozi emee onwe ha dịka ndị na-eje ozi ụzọ ezi omume. Ma nʼọgwụgwụ oge, ha ga-anata ụgwọ dịka ọrụ ha si dị.
\s1 Ịnya isi Pọl
\p 
\v 16 Dịka m kwuru na mbụ, ka onye ọbụla ghara iche na m bụ onye na-enweghị uche. Ọ bụrụkwarị na unu na-eche ụdị echiche a, biko naranụ m dịka onye na-enweghị uche, ka m nwee ike ịnya isi nke nta dịka ndị ọzọ si eme.
\v 17 Ma nʼihe m dabeere na-anya isi, adịghị m ekwu okwu dịka Onyenwe anyị ga-ekwu, maọbụ dịka onye na-enweghị uche.
\v 18 Ebe ọtụtụ mmadụ na-anya isi banyere ihe ha bụ nʼụzọ ụwa si eme. Mụ onwe m ga-anyakwa isi.
\v 19 Unu were obi ụtọ na-anagide ndị na-enweghị uche, ebe unu onwe unu nwere uche.
\v 20 Unu na-anagide ya ma ọ bụrụ na onye ọbụla eme unu ndị ohu ha, maọbụ jiri anya ike nakọrọ unu ihe unu nwere, maọbụ ghọgbuo unu, maọbụ bulie onwe ya elu dịka ha karịrị unu, maọbụ maa unu uraa nʼihu.
\v 21 Nʼezie, ọ bụ ihere m, ịnabata na anyị bụ ndị na-adịghị ike nʼezie nye nke a.
\p Ọ bụrụ na onye ọbụla anwaa anwaa nyaa isi nʼihe ọbụla (ana m ekwu dịka onye nʼenweghị uche), mụ onwe m ga-anyakwa isi.
\v 22 Ha bụ ndị Hibru? Mụ onwe m bụkwa ya. Ha bụ ndị Izrel? Mụ onwe m bụkwa ya. Ha bụ ndị agbụrụ Ebraham? Mụ onwe m bụkwa.
\v 23 Ha bụ ndị na-ejere Kraịst ozi? (Ana m ekwu dịka onye anya na-adịghị mma.) Ma mụ onwe m ejela ozi karịa. Adọgbuola m onwe m nʼọrụ karịa ha niile. Etinyela m nʼụlọ mkpọrọ ọtụtụ mgbe, tinyere ọtụtụ ihe otiti, mgbe mgbe anọọla m nʼọnụ ọnwụ.
\v 24 Ugboro ise ka ndị Juu pịara m ọnụ ụtarị iri anọ e wepụrụ otu.
\v 25 E jirila okporo igwe tie m ugboro atọ. Atụrụ m nkume otu ugboro. Ugboro atọ ka ụgbọ mmiri m nọ nʼime ya kpuru nʼoke osimiri. Anọọla m otu abalị na ụbọchị so ya nʼelu oke osimiri ebe mmiri na-ebugharị m.
\v 26 Ejeela m ọtụtụ ogologo ije nke ọtụtụ ihe ize ndụ dị nʼime ya. Nʼize ndụ site nʼosimiri, ize ndụ site na ndị na-apụnarị mmadụ ihe nʼike, ize ndụ site nʼaka ndị obodo nke aka m. Ọtụtụ mgbe ka m zere ndụ site nʼaka ndị mba ọzọ, nʼime obodo ukwu, nʼọzara ma nʼoke osimiri; na nʼaka ndị kpọrọ onwe ha ụmụnna m, ma ha bụ ndị ụgha.
\v 27 Adọgbuola m onwe m nʼọrụ, anọọla m nʼọnọdụ ịhụju anya na ịmụ anya ọtụtụ abalị. Ọtụtụ mgbe ana m anọ agụụ na-erighị ihe ọbụla, maọbụ ịṅụ ihe ọbụla. Anọọla m ọtụtụ mgbe nʼoge oyi na-ama jijiji nʼihi enweghị uwe dị mma m ji achụ oyi.
\v 28 Ma e wezuga ihe ndị a niile, ana m anọ nʼechiche mgbe niile banyere otu ihe niile si aga nʼime nzukọ.
\v 29 Onye bụ onye ahụ na-adịghị ike nke m na-adịghị eso ya kere oke na-adịghị ike ya? Onye ka e dubara na mmehie nke ọnọdụ ya na-adịghị emetụ m nʼobi?
\p 
\v 30 Kama ọ bụrụ na o kwesiri ka m nyaa isi aga m anya isi banyere ihe ndị ahụ na-egosi adịghị ike m.
\v 31 Chineke, na Nna nke Onyenwe anyị Jisọs, onye e kwesiri ito aha ya ruo mgbe ebighị ebi, maara na ihe ndị a niile m na-ekwu bụ eziokwu.
\v 32 Nʼobodo Damaskọs, onye ọchịchị ala ahụ nke eze obodo ahụ a na-akpọ Aretas họpụtara, ndị na-eche obodo Damaskọs nche ka ha jide m.
\v 33 Ma e tinyere m nʼime nkata, site nʼoghere dị na mgbidi gbara obodo ahụ gburugburu wedata m, m gbanarị ya.
\c 12
\s1 Ọhụ Pọl hụrụ
\p 
\v 1 Aghaghị m ịnya isi, ọ bụ ezie na ọ baghị uru, ugbu a ka m gwa unu ihe banyere ọhụ m hụrụ, na ihe niile Onyenwe anyị kpughere gosi m.
\v 2 Amaara m otu nwoke nọ nʼime Kraịst, onye e duuru gaa nʼeluigwe nke atọ ihe dị ka afọ iri na anọ gara aga, maọbụ nʼanụ ahụ, maọbụ nʼime mmụọ amaghị m, ma Chineke ma.
\v 3 Amatakwara m nwoke dị otu a, maọbụ nʼanụ ahụ, maọbụ nʼime mmụọ amaghị m, ma Chineke maara
\v 4 onye a, nke a kpọọrọ banye na paradaịs, ebe ọ nụrụ ihe ọnụ mmadụ na-apụghị ịkọwa, nke e nyeghịkwa mmadụ ọbụla ike ikwu ihe banyere ya.
\v 5 Ekwesiri m ịnya isi nʼihi nwoke dị otu a ma agaghị m anya isi maka mụ onwe m, ma ọ bụghị maka adịghị ike m.
\v 6 A sị na m chọrọ ịnya isi, agaghị m abụ onye nzuzu, nʼihi na aga m ekwu naanị eziokwu. Otu ọ dị, agaghị m anya isi ka onye ọbụla ghara ịgụ ọnọdụ m karịa ihe ọ hụrụ nʼime m, maọbụ karịa ihe ọ nụrụ nʼọnụ m.
\v 7 Ma nʼihi na ọtụtụ ihe ndị a m ji anya m hụ bụ ihe pụrụ ime ka m bulie onwe m elu karịa ka o si kwesi. E tinyere ihe mgbu nʼanụ ahụ m ka ọ na-adụ m dịka ogwu. Ihe mgbu a dị nʼanụ ahụ m na-eti m aka dịka onyeozi nke ekwensu, na-eme ka m ghara ịfụlị onwe m elu karịa.
\v 8 Ekpeela m ekpere ugboro atọ rịọ Onyenwe anyị ka o wepụrụ m ahụ mgbu a.
\v 9 Ma ọ sịrị m, \wj “Amara m ezuorola gị. Nʼihi na ike m na-ezu oke nʼime adịghị ike.”\wj* Ugbu a, obi dị m ụtọ ịnya isi banyere adịghị ike m. Nʼihi na ọ bụ site nʼọnọdụ adịghị ike m ka ike ebube Kraịst ga-esi nọgide nʼahụ m.
\v 10 Ọ bụ nʼihi Kraịst ka m na-anọgide nʼadịghị ike m niile, mkparị ndị mmadụ, ihe isi ike niile, mkpagbu niile na ihe ndakwasị dị iche iche. Nʼihi na mgbe m na-adịghị ike ka m na-enwe ike karịa.
\s1 Ndị Kọrint dị Pọl nʼobi
\p 
\v 11 Emeela m onwe m onye nzuzu ma unu onwe unu rugidere m ime ya. O kwesiri ka unu bụrụ ndị mbụ ga-eto m. Ọ bụ ezie a na-abụghị m ihe ọbụla, ma o were m anya na ọ dịghị ụzọ ọbụla m si dị ala nʼebe ndị ahụ unu na-eche na ha kachasị elu nʼetiti ndị ozi.
\v 12 Ejiri m ndidi rụọ ọrụ nʼetiti unu, ihe iji gosi na abụ m nwaazụ\f + \fr 12:12 \ft Maọbụ, \fqa onyeozi\f* nʼeziokwu. Egosiri m unu ihe ịrịbama, ọrụ ebube dị iche iche, na ọtụtụ oke ọrụ.
\v 13 Olee ụzọ unu si dị ala nʼebe chọọchị ndị ọzọ dị, ma ọ bụghị na m abụghị ibu arọ nye unu? Gbagharanụ m mmejọ a.
\p 
\v 14 Nke a bụ ugboro atọ m na-ejikere ịbịakwute unu. Agaghị m abụrụ unu ibu arọ, ihe dị m mkpa abụghị akụ unu nwere, kama unu onwe unu. Ọ bụghị ụmụntakịrị ka ọ dịrị ịkpadoro nne na nna ha ihe, kama ọ bụ ọrụ dịrị nne na nna ịkpadoro ụmụ ha ihe.
\v 15 Nʼezie, ọ na-atọ m ụtọ iwere onwe m na ihe niile m nwere nye unu, nʼihi na ahụrụ m unu nʼanya. Ma ọ bụrụ na m hụrụ unu nʼanya karịa, ọ ga-adị mma ma unu hụ m nʼanya nke nta?
\v 16 Nʼagbanyeghị na-abụrụ m unu ibu arọ, ụfọdụ nʼime unu na-ekwu, ọ bụ ezie na ọ dịghị anara anyị ihe ọbụla, maọbụ onye aghụghọ. Ma eleghị anya, o nwere ụzọ aghụghọ dị iche iche o si anara anyị ihe.
\v 17 Ọ dị onye ọbụla m ziteere unu, iji si nʼaka ya rigbuo unu?
\v 18 Arịọrọ m Taịtọs ka ọ bịakwute unu, ya na nwanna anyị nwoke ọzọ. Taịtọs o rigburu unu? O nwere ihe dị iche nʼuche na omume mụ na ya?
\p 
\v 19 Unu chere na ihe anyị na-eme oge niile ndị a bụ ịgọpụ onwe anyị nʼihu unu? Ọ bụ nʼihu Chineke ka anyị na-ekwu nke a nʼime Kraịst. Ndị m hụrụ nʼanya, ihe ndị a anyị na-ekwu bụ maka ọdịmma unu.
\v 20 Nʼihi na ihe na-atụ m egwu bụ na mgbe m bịara nʼetiti unu, ihe m ga-ahụ agaghị atọ m ụtọ. Mgbe ahụ mmeso m ga-emeso unu agakwaghị atọ unu atọ. Nʼihi na ana m atụ egwu na mgbe m bịakwutere unu ọzọ, aga m ahụ ọtụtụ nʼime unu ka unu na-ese okwu, aga m ahụ ka unu na-ekwosa ibe unu ekworo, aga m ahụ unu ka unu na-akpasu ibe unu iwe. Aga m ahụ ọtụtụ ndị na-afụli onwe ha elu, ndị na-ekwu ọtụtụ ihe ọjọọ dị iche iche megide ndị ọzọ; aga m ahụ ọtụtụ ndị jupụtara nʼaghụghọ na ịkpa iche iche.
\v 21 Ana m atụ egwu na mgbe m ga-abịakwute unu ọzọ, Chineke m ga-eme ka m weda onwe m ala nʼihu unu, mee ka m kwa akwa nʼihi ụfọdụ nʼime unu ndị mehiere na mbụ, ma ha achọghị ichegharị site nʼihe ọjọọ ha mere, na nʼihi ọtụtụ nʼime unu na-adị ndụ rere ure, ndụ na-adịghị ọcha, ndụ ịkwa iko, na ndụ ọjọọ.
\c 13
\s1 Ịdọ aka na ntị ikpeazụ
\p 
\v 1 Nke a ga-eme ya ugboro atọ m na-abịa ileta unu. Ọ bụ site nʼama mmadụ abụọ maọbụ atọ gbara ka a ga-eme ka okwu niile guzoro.\f + \fr 13:1 \ft \xt Dit 19:15\xt*\f*
\v 2 Mgbe m bịara leta unu nke ugboro abụọ, abaara m ndị niile dara iwu nʼoge gara aga na mmadụ ndị ọzọ mba, dọọkwa ha aka na ntị, ihu na ihu. Ugbu a m na-anọghị ya, ana m adọkwa ha aka na ntị ọzọ, ọ bụrụ na m bịa ọzọ hụ na ndị mehiere na mbụ echegharịghị, aga m emesi ha ike.
\v 3 Ebe unu chọrọ ka e gosi na Kraịst na-ekwu okwu nʼime m, ọ dịghị egosi adịghị ike mgbe ọ na-emeso unu omume, kama ọ na-eme ka ike ya pụta ìhè nʼebe unu nọ.
\v 4 Ọ bụ ezie na a kpọgidere ya na-adịghị ike, ma ugbu a, ọ na-adị ndụ site nʼike dị ukwuu nke Chineke. Anyị bụkwa ndị na-adịghị ike nʼime ya, ma ozi anyị na-ejere unu na mmekọrịta anyị na unu, anyị ga-eso ya dị ndụ site nʼike nke Chineke.
\p 
\v 5 Ya mere, ka onye ọbụla nʼime unu nyochaa onwe ya, tulekwa omume ya, mara ma ọ ka kwudosiri ike nʼokwukwe ya. Ọ bụ na unu aghọtaghị na Jisọs Kraịst nọ nʼime unu? Ma ọ bụghị na unu enyochaala onwe unu hụ na unu emeghị nke ọma.
\v 6 Enwere m olileanya na unu niile ga-achọpụta na anyị adaghị ule ahụ.
\v 7 Ma anyị na-arịọ Chineke ka unu ghara ime ihe ọjọọ ọbụla. Anyị anaghị eme nke a iji gosi na anyị kwesiri ekwesi, kama ka unu nwee ike mee ihe dị mma, nʼagbanyeghị na ọ ga-adị ka a ga-asị na anyị emeghị nke ọma nʼọrụ anyị.
\v 8 Nʼihi na anyị apụghị ime ihe ọbụla megide eziokwu, kama anyị na-eme ihe niile nʼihi eziokwu.
\v 9 Anyị na-aṅụrị ọṅụ mgbe anyị na-adịghị ike ma hụ na unu dị ike. Ihe anyị na-arịọ Chineke bụ ka unu tozuo oke.
\v 10 Ana m edere unu akwụkwọ a ugbu a, nʼihi na-achọghị m ịbara unu mba na inye unu ntaramahụhụ mgbe m bịara. Achọkwaghị m iji ikike ahụ Onyenwe anyị nyere m nye unu ntaramahụhụ, kama achọrọ m iji ya wulie unu elu dịka ụlọ.
\b
\s1 Ekele mmechi
\p 
\v 11 Nʼikpeazụ ụmụnna m, na-aṅụrịnụ ọṅụ. Gbalịanụ nʼimezi ndụ unu ka o zuo oke, na-agbarịta onwe ume, werenụ otu obi na-eme ihe, na-ebikwanụ nʼudo. Chineke nke udo na ịhụnanya ga-anọnyekwara unu.
\b
\p 
\v 12 Werenụ isurita ọnụ dị nsọ kelerịta onwe unu.
\p 
\v 13 Ndị nsọ niile na-ekelekwa unu.
\b
\p 
\v 14 Ka amara Onyenwe anyị Jisọs Kraịst na ịhụnanya Chineke, na mmekọ nke Mmụọ Nsọ dịnyere unu niile.
