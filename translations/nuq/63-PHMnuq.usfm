\id PHM
\h Filemon
\toc3 Filemon
\toc2 Philemon
\toc1 Te launiu Pol e taataa iaa Filemon
\mt1 Filemon
\mt2 Te launiu Pol e taataa iaa Filemon
\iot Na hakataakoto hakamattua i roto te launiu nei:
\io1 Te tattara kaamata \ior 1.1—1.3\ior*
\io1 Pol e tattara hihia ake Filemon \ior 1.4—1.7\ior*
\io1 Pol e kainno ake Filemon ki hai aroha ake Onesimus \ior 1.8—1.22\ior*
\io1 Tattara hakaoti \ior 1.23—1.25\ior*
\c 1
\p 
\v 1 Anau Pol, anau e karapusi ria i te vahi Jisas Krais, tena maaua ma Timoti te taina taatou raa e tattaa atu,
\p iaa akoe Filemon te taina maaua tera e hehekau hoki peenei ma maaua nei
\v 2 ia ma na tama te lotu tera e kutukkutu i roto te hare akoe raa, tena Afia te kave taatou raa ia ma Arkipus te tama hehekau hoki peenei ma maaua nei raa.
\p 
\v 3 TeAtua taatou Tamana ia ma TeAriki Jisas Krais ki hai aroha kootou, tena ku rorohi hakatauareka kootou ki nnoho laoi.
\s1 Te laoi ia ma te hakatina Filemon
\p 
\v 4 Filemon taku taina, na saaita hakaatoa anau e lotu raa, anau e maanatu tahi akoe, tena anau e hakammaha TeAtua anau raa,
\v 5 maitaname anau e rono pera ma akoe e hakatina i TeAriki Jisas, tena ki laoi na tama e ttapu TeAtua raa hakaatoa.
\v 6 Tena anau e lotu ake pera ma te huhukkui maatou ma na tama te lotu raa e me ki kou atu te atamai hakamaoni ia ma na hoki hakaatoa tera maatou e isi i te huhukkui maatou ma Krais raa.
\v 7 Taku taina, te laoi akoe raa e kou mai anau te hihia e rahi ia ma te tauareka hakamaoni! Akoe e hakahihia roo na hatumanava na tama TeAtua raa hakaatoa.
\s1 Too hakaraoi Onesimus
\p 
\v 8 Tera hea anau se mataku roo te tattara atu pera ma he taina akoe i te vahi Krais ki ppena hea akoe e tau te ppena raa.
\v 9 Maitaname anau e laoi akoe, tena anau ku kainno atu akoe. Niaina ma anau ko Pol te tama hehekau ma Jisas Krais tera e karapusi ria te saaita nei e mee anau e hehekau ma Tama raa.
\v 10 Tena anau e kainno atu akoe i te vahi Onesimus, te tamariki anau i te vahi Krais raa; e mee te saaita anau ni noho i roto te hare karapusi raa, anau e mee pera ma he tamana aia i te vahi te lotu.
\v 11 I mua raa aia he tama vare koi, e meia te saaita nei aia he tama roo hakamaoni e lavaa te tokonaki taaua.
\p 
\v 12 Anau e laoi mahi roo aia, tena anau e me ki kauna ria atu te tama nei vahao nei.
\v 13 Anau e hihai roo ma aia ki nnoho maaua i te kina nei, te saaita nei anau koi noho i roto te hare karapusi e mee te Rono Tauareka raa ma ki lavaa aia te sui te sao akoe no tokonaki anau.
\v 14 Anau se hihai ma ki meatu akoe ki tokonaki anau, tena anau e hihai ma akoe ki ppena hea akoe e hihai raa. Ia tena anau se lavaa te ppena he mee kame akoe se hihai.
\p 
\v 15 Onesimus kame ni noho i taha ma akoe paa saaita koi, ia tena te saaita nei akoe ku lavaa te too aia ki nnoho tahi koorua.
\v 16 Tena te saaita nei aia ku se mee koi pera ma he tama hehekau, e meia aia ku raka hoki ma na tama hehekau raa, ia he taina hakamaoni taatou i te vahi Krais. Te kkira anau raa aia he tama hakamaoni roo! Tena akoe hoki e me ki kite te hakamaoni te tama hehekau ia ma te taina akoe i te vahi TeAriki nei.
\p 
\v 17 Tena kame akoe e maanatu pera ma anau he hakahoa akoe, tena akoe ku too hakaraoi te tama nei i te vahi anau.
\v 18 Kame aia ni ppena he mee e sara i akoe, ia ni taoni he mee i akoe, tena akoe ku hakammau na taoni naa i te inoa anau.
\v 19 Anau Pol e taataa na mee nei ma te rima anau: \sig Anau Pol e me ki sui muri atu.\sig* (Anau se hihai ki meatu hoki pera ma akoe e taoni anau ma te ora akoe.)
\v 20 Ia tena taku taina, taaua ni hai taina i te vahi TeAriki, tena akoe ku ppena hea anau e hihai ki mee anau ki hihia.
\p 
\v 21 Anau e iroa pera ma te saaita anau e taataa atu te launiu nei raa, akoe e me ki pena hea anau e hihai. Emeia anau e iroa hakamaoni roo pera ma akoe e me ki ppena alaa mee hoki e llahi.
\v 22 Teeraa mee hoki, tanattana mai he kina ma anau ki moe, maitaname anau e iroa pera ma TeAtua e me ki kou mai hea taatou ni kainno ake Aia ma ki kauna ria atu anau ki vaakai atu i kootou raa.
\s1 Na tattara hakaoti
\p 
\v 23 Epafras, te tama e ponotia i te hare karapusi ma anau i te vahi Jisas Krais raa e kou atu hoki na tattara hihhia aia,
\v 24 tena Mak, Aristarkus, Demas ia ma Luk e kou atu hoki na tattara hihhia laatou.
\p 
\v 25 Te noho laoi TeAriki Jisas Krais ki nnoho ma kootou hakaatoa.
