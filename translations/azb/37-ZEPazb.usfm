\id ZEP Azeri-N: Azerbaijani Bible 2008 
\h SEFANYA 
\toc1 Sefanya Peyğəmbərin Kitabi 
\toc2 Sefanya 
\toc3 Sef 
\mt1 SEFANYA  
\mt2 PEYĞƏMBƏRİN KİTABI  
\imt1 GİRİŞ  
\ip Sefanya peyğəmbər miladdan əvvəl \sc VII\sc* əsrin 2-ci yarısında, ehtimala görə padşah Yoşiyanın 621-ci ildə etdiyi dini islahatlardan əvvəlki illərdə fəaliyyət göstərmişdir. Kitaba məlum olan peyğəmbərlik mövzuları daxildir: bütlərə ibadət etməsinə görə Yəhudanın üzərinə cəza və dağılma günü gələcək. Rəbb həmçinin başqa millətləri cəzalandıracaq. Yerusəlim də məhkum olacaq, lakin müəyyən vaxt bərpa olunacaq və orada həlim və saleh xalq yaşayacaq.  
\iot Kitabın məzmunu:  
\io2 1:1–2:3 Rəbbin məhkəmə günü  
\io2 2:4-15 Rəbbin millətlərə cəzası  
\io2 3:1-20 Yerusəlimin gələcəyi  
\c 1  
\p
\v 1 \x * \xo 1:1 \xt 2Pad. 22:1–23:30; 2Saln. 34:1–35:27 \x* Yəhuda padşahı Amon oğlu Yoşiyanın hökm etdiyi dövrdə Xizqiya oğlu Amarya oğlu Gedalya oğlu Kuşi oğlu Sefanyaya Rəbbin sözü nazil oldu.   
\s1 Rəbbin məhkəmə günü  
\q1
\v 2 Rəbb belə bəyan edir:  
\q1 «Yer üzündən hər şeyi silib-süpürəcəyəm».   
\q1
\v 3 Budur, Rəbb belə bəyan edir:  
\q1 «İnsanları, heyvanları,  
\q1 Göydəki quşları, dənizdəki balıqları,  
\q1 Pis adamları ilə  
\q1 Şər üçün qurulan tələlərini  
\q1 Silib-süpürəcəyəm,  
\q1 İnsanı yer üzündən yox edəcəyəm.   
\b  
\q1
\v 4 Əlimi uzadıb Yəhuda və Yerusəlim sakinlərinin  
\q1 Hamısını cəzalandıracağam,  
\q1 Baal bütlərinə ibadətin qalıqlarını,  
\q1 Kahinlərlə bütpərəst din xadimlərinin adlarını da buradan silib atacağam.   
\q1
\v 5 Damlarda göy cisimlərinə səcdə edənləri,  
\q1 Həm Rəbbin adına, həm də Milkom bütü adına  
\q1 And içib səcdə edənləri,   
\q1
\v 6 Rəbbin yolundan dönənləri,  
\q1 Rəbbə müraciət etməyənləri,  
\q1 Rəbdən məsləhət almayanları  
\q1 Buradan yox edəcəyəm».   
\b  
\q1
\v 7 Susun Xudavənd Rəbbin qarşısında,  
\q1 Çünki Onun günü yaxınlaşır,  
\q1 Rəbb qurban hazırlayıb, qonaqlarını dəvət edib.   
\q1
\v 8 Rəbb deyir: «O qurban günü əmirləri, şahzadələri,  
\q1 Əcnəbi dəbi ilə geyinənləri cəzalandıracağam.   
\q1
\v 9 O gün kandarından tullanıb keçənləri,  
\q1 Öz ağalarının evlərini zorakılıq və hiylə ilə  
\q1 Dolduranları cəzalandıracağam».   
\b  
\q1
\v 10 Rəbb bəyan edir:  
\q1 «O gün Yerusəlimdə Balıqlar darvazasından fəğan səsi,  
\q1 İkinci Məhəllədən fəryadlar,  
\q1 Təpələrdən isə böyük gurultu eşidiləcək».   
\q1
\v 11 Ey bazar məhəlləsinin sakinləri, nalə çəkin!  
\q1 Bütün tacirləriniz məhv olacaq,  
\q1 Tərəzidə gümüş çəkənləriniz qırılacaq.   
\b  
\q1
\v 12 O zaman Yerusəlimin hər tərəfini  
\q1 Çıraqlarla axtaracağam,  
\q1 Firavan yaşayan qayğısızları, \f + \fr 1:12 \fq Firavan yaşayan qayğısızlar \ft – hərfi tərcümədə \fq çöküntüsü dibə çökmüş şərab kimi olanlar.\f*  
\q1 Ürəklərində  
\q1 «Rəbb nə yaxşılıq, nə də pislik –  
\q1 Heç nə etməz»  
\q1 Deyənləri cəzalandıracağam.   
\q1
\v 13 Var-dövlətləri talan olacaq,  
\q1 Evləri xaraba qalacaq,  
\q1 Tikdikləri evlərdə yaşamayacaqlar,  
\q1 Onlar saldıqları üzümlüklərin  
\q1 Şərablarını içməyəcəklər.   
\b  
\q1
\v 14 Rəbbin möhtəşəm günü yaxınlaşır,  
\q1 Yaxınlaşır, tez gələcək.  
\q1 Rəbbin günündə fəryad səsi çıxacaq,  
\q1 İgid adam belə, fəryad edəcək.   
\q1
\v 15 \x * \xo 1:15 \xt Yoel 2:2 \x* O gün qəzəb günüdür:  
\q1 Hər tərəfi  
\q1 Əziyyət və məşəqqətin,  
\q1 Viran və talanın,  
\q1 Qaranlıq və zülmətin,  
\q1 Qara buludların bürüdüyü gündür!   
\q1
\v 16 O gün istehkamlı şəhərlərə,  
\q1 Hündür künc qüllələrinə qarşı  
\q1 Döyüş üçün çalınan şeypurların,  
\q1 Döyüş nərələrinin səsləndiyi gündür!   
\b  
\q1
\v 17 Rəbb deyir:  
\q1 «Adamlara elə bəla göndərəcəyəm ki,  
\q1 Kor kimi hara gedəcəklərini bilməyəcəklər,  
\q1 Çünki Mən Rəbbə qarşı günah ediblər.  
\q1 Qanları su kimi axacaq, \f + \fr 1:17 \fq Qanları su kimi axacaq \ft – hərfi tərcümədə \fq qan toz kimi töküləcək.\f*  
\q1 Bədənləri yerdə çürüyüb peyin olacaq».   
\q1
\v 18 Rəbbin qəzəb günündə  
\q1 Qızıl-gümüşləri  
\q1 Onları qurtara bilməyəcək,  
\q1 Onun qısqanc qəzəbinin alovunda  
\q1 Bütün ölkə yanıb yox olacaq,  
\q1 Çünki O, bir anda ölkənin sakinlərini qıracaq.   
\c 2  
\s1 Tövbəyə çağırış  
\q1
\v 1 Ey utanmaz millət, toplaşın!   
\q1
\v 2 Fərman çıxmadan,  
\q1 O gün saman çöpü tək uçmadan,  
\q1 Rəbbin qızğın qəzəbi başınıza gəlmədən,  
\q1 Rəbbin qəzəb günü sizə yetişmədən öncə toplaşın!   
\q1
\v 3 Ey Rəbbin hökmünə əməl edən sizlər,  
\q1 Ölkədəki itaətkar insanlar, Rəbbə meyl salın!  
\q1 Salehliyə meyl salın!  
\q1 İtaətkarlığa meyl salın!  
\q1 Bəlkə siz Rəbbin qəzəb günündə qurtula bildiniz.   
\s1 Rəbbin millətlərə cəzası  
\q1
\v 4 \x * \xo 2:4 \xt Yeş. 14:29-31; Yer. 47:1-7; Yez. 25:15-17; Yoel 3:4-8; Amos 1:6-8; Zək. 9:5-7 \x* Qəzzə bomboş qalacaq,  
\q1 Aşqelon xarabalığa dönəcək,  
\q1 Aşdod əhalisi günorta çağı qovulacaq,  
\q1 Eqron özülündən söküləcək!   
\q1
\v 5 Dəniz sahilində yaşayanların –  
\q1 Keretlilərin \f + \fr 2:5 \fq Keret \ft – Krit adası nəzərdə tutulur.\f* vay halına!  
\q1 Ey Filiştlilərin torpağı Kənan,  
\q1 Rəbbin hökmü sizə qarşıdır,  
\q1 Rəbb hamınızı yox edəcək.  
\q1 Ölkədə heç bir sakin sağ qalmayacaq!   
\b  
\q1
\v 6 Dəniz sahilindəki ölkəniz otlaqlara,  
\q1 Çoban daxmalarına və qoyun-keçi ağıllarına dönəcək!   
\q1
\v 7 Bu ölkə Yəhuda nəslindən qalanların əlinə keçəcək,  
\q1 Sürülərini orada otaracaqlar,  
\q1 Axşam Aşqelondakı evlərində yatacaqlar,  
\q1 Çünki özlərinin Allahı Rəbb onları yada salaraq  
\q1 Yenə firavan edəcək.   
\b  
\q1
\v 8 \x * \xo 2:8 \xt Yeş. 15:1–16:14; 25:10-12; Yer. 48:1-47; Yez. 25:8-11; Amos 1:13-15 \x* \x * \xo 2:8 \xt Yer. 49:1-6; Yez. 21:28-32; 25:1-7; Amos 1:13-15 \x*  
\q1 «Moavlıların rişxəndlərini,  
\q1 Ammonluların təhqirlərini eşitdim.  
\q1 Xalqıma rişxənd edib lovğalanaraq dedilər ki,  
\q1 Xalqımın sərhədlərini keçəcəklər.   
\q1
\v 9 \x * \xo 2:9 \xt Yar. 19:24 \x* Buna görə də İsrailin Allahı, Ordular Rəbbi bəyan edir.  
\q1 Varlığıma and olsun ki,  
\q1 Moav mütləq Sodom kimi,  
\q1 Ammon Homorra kimi olacaq:  
\q1 Oraları alaqlar və duzlu çalalar basacaq,  
\q1 Əbədi viranəliyə dönəcək.  
\q1 Xalqımın qalanları oranı talan edəcək,  
\q1 Torpaqlarına millətimdən sağ qalanlar  
\q1 Sahib olacaq».   
\b  
\q1
\v 10 Bu onların məğrurluğunun əvəzi olacaq,  
\q1 Çünki bu xalqlar  
\q1 Ordular Rəbbinin xalqına rişxənd edib lovğalandı.   
\q1
\v 11 Rəbb onları dəhşətə salacaq,  
\q1 Yer üzünün bütün allahlarını yox edəcək.  
\q1 Uzaqlarda yaşayan bütün millətlər  
\q1 Olduqları yerlərdə Ona səcdə edəcək.   
\b  
\q1
\v 12 «Ey Kuşlular, siz də  
\q1 Mənim qılıncımla öldürüləcəksiniz» Rəbb deyir.   
\q1
\v 13 \x * \xo 2:13 \xt Yeş. 10:5-34; 14:24-27; Nah. 1:1–3:19 \x* Rəbb əlini şimala doğru uzadıb  
\q1 Aşşuru yox edəcək,  
\q1 Ninevanı viranəliyə,  
\q1 Səhra kimi quruya çevirəcək,   
\q1
\v 14 Ora sürülərin, hər cür heyvanın  
\q1 Yatdığı yer olacaq.  
\q1 Orada sütun başlarında,  
\q1 Bayquşlar, yapalaqlar yuva quracaq,  
\q1 Onlar pəncərələrdən ulayacaq,  
\q1 Qarğalar kandarlardan qarıldayacaq  
\q1 Evlərdə sidr tirləri görünəcək.   
\q1
\v 15 \x * \xo 2:15 \xt Yeş. 47:8 \x* Bu şəhər zövq-səfalı şəhər idi,  
\q1 Əmin-amanlıq içində yaşayırdı.  
\q1 Hey belə deyərdi:  
\q1 «Mən mənəm, məndən başqası yoxdur!»  
\q1 Necə də bu şəhər xarabalığa döndü,  
\q1 Vəhşi heyvanların yuvası oldu!  
\q1 Yanından keçən hər kəs vahimədən  
\q1 Kənara çəkilir.   
\c 3  
\s1 Yerusəlimin gələcəyi  
\q1
\v 1 Üsyankar, pozğun, qəddar şəhərin vay halına!   
\q1
\v 2 Söz dinləmədi, ibrət dərsi almadı,  
\q1 Rəbbə güvənmədi, Allahına yaxınlaşmadı.   
\q1
\v 3 Başçıları nərildəyən aslanlara bənzəyir,  
\q1 Hakimləri axşam gəzən ac qurdlar kimi  
\q1 Səhərə qədər bir şey qoymaz.   
\q1
\v 4 Peyğəmbərləri məsuliyyətsiz, xain adamlardır,  
\q1 Kahinləri müqəddəs olanı murdarlayıb,  
\q1 Qanunun mənasını pozur.   
\q1
\v 5 Amma şəhərin içində olan Rəbb salehdir,  
\q1 O haqsızlıq etməz.  
\q1 Hər yeni günün səhərində  
\q1 Durmadan ədalətini zühur etdirər,  
\q1 Amma haqsız adam utanmaq bilməz.   
\b  
\q1
\v 6 Rəbb belə deyir:  
\q1 «Millətləri məhv etdim,  
\q1 Künc qüllələri dağıldı.  
\q1 Küçələrini viran qoydum,  
\q1 O küçələrdən artıq gəlib-keçən yoxdur!  
\q1 Şəhərləri xarabalığa döndü,  
\q1 Orada heç bir sakin də qalmadı.   
\q1
\v 7 Mən dedim:  
\q1 “Xalqım Məndən qorxar,  
\q1 İbrət dərsi alar”.  
\q1 Onda məskənləri dağıdılmaz,  
\q1 Verdiyim cəzaların hamısı üzərlərinə gəlməz,  
\q1 Lakin onlar hər cür pozğun iş görməkdən zövq aldı».   
\b  
\q1
\v 8 Buna görə Rəbb bəyan edir:  
\q1 «Şahid kimi qalxdığım  
\q1 Günə qədər Məni gözləyin.  
\q1 Çünki Mən millətləri yığmağı  
\q1 Padşahlıqları toplamağı qərara almışam.  
\q1 Qoy üzərlərinə qeyzimi, qızğın qəzəbimi töküm.  
\q1 Çünki qısqanc qəzəbimin odu ilə bütün yer üzü tələf olacaq.   
\q1
\v 9 O zaman Mən xalqların nitqini dəyişib,  
\q1 Onlara pak dil verəcəyəm ki,  
\q1 Hamı Rəbbin adını çağırsın,  
\q1 Mənə çiyin-çiyinə xidmət etsinlər.   
\q1
\v 10 Qürbətə dağılmış,  
\q1 Mənə səcdə edənlər  
\q1 Kuş çaylarının o tayından  
\q1 Mənə təqdimlər gətirəcək.   
\q1
\v 11 O gün sən, ey xalqım,  
\q1 Mənə qarşı üsyankarlıq etdiyinə görə  
\q1 Daha xəcalətli olmayacaqsan.  
\q1 Çünki qürurlu, təkəbbürlü adamları  
\q1 Sənin arandan uzaqlaşdıracağam,  
\q1 Müqəddəs dağımda bir daha təkəbbürlü olmayacaqsan.   
\q1
\v 12 Sizin aranızda itaətkar və məzlum bir xalqı sağ qoyacağam,  
\q1 Onlar Rəbbin adına pənah gətirəcək.   
\q1
\v 13 \x * \xo 3:13 \xt Vəhy 14:5 \x* İsraildən sağ qalanlar haqsızlıq etməyəcək!  
\q1 Kimsəni aldadaraq yalan söyləməyəcəklər,  
\q1 Çünki onlar qarnı tox yatacaq,  
\q1 Onları qorxudan olmayacaq».   
\s1 Sevinc nəğməsi  
\q1
\v 14 Ey Sion qızı, tərənnüm elə,  
\q1 Ey İsrail, uca səslə çığır!  
\q1 Ey Yerusəlim qızı, bütün qəlbinlə sevin və fərəhlən!   
\q1
\v 15 Rəbb sənin cəzanı ləğv etdi, düşmənlərini qovdu!  
\q1 İsrailin padşahı Rəbb səninlədir,  
\q1 Artıq pislikdən qorxmayacaqsan!   
\b  
\q1
\v 16 O gün Yerusəlimə deyiləcək:  
\q1 «Qorxma, ey Sion, qoy əllərin taqətdən düşməsin!   
\q1
\v 17 Allahın Rəbb,  
\q1 Qüvvətli Qurtarıcın səninlədir!  
\q1 O sənin üçün sevinib şadlanacaq,  
\q1 Səni məhəbbəti ilə yeniləşdirəcək, \f + \fr 3:17 \fq Səni məhəbbəti ilə yeniləşdirəcək \ft – qədim yunan və süryani tərcümələrində belədir, ibrani mətnində isə \fq məhəbbəti ilə susacaq.\f*  
\q1 Sənin üçün tərənnümlə coşacaq!   
\q1
\v 18 Bayram gününü qeyd edən kimi  
\q1 Mən sənin üzərindən bəlaları götürəcəyəm ki,  
\q1 Onlara görə xəcalətli olmayasan. \f + \fr 3:18 \fq Bayram gününü … olmayasan \ft – qədim yunan tərcüməsində belədir, ibrani mətnində isə \fq bayramlar üçün kədərlənənləri səndən yığacağam.\f*   
\q1
\v 19 Budur, vaxt gəlir,  
\q1 Mən sizə zülm edənlərin hamısını cəzalandıracağam,  
\q1 Şikəstləri qurtaracağam, sürgünləri yığacağam,  
\q1 Bütün dünyada çəkdikləri xəcaləti  
\q1 Şan-şöhrətə çevirəcəyəm.   
\q1
\v 20 O zaman sizi toplayıb yurdunuza geri qaytaracağam.  
\q1 Görəcəksiniz, Mən sizi yenə firavan edəndə  
\q1 Bütün dünya xalqları arasında  
\q1 Sizə şan-şöhrət verəcəyəm»  
\q1 Rəbb deyir.   