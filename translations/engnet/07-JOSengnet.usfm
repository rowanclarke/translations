\c 2
\p 
\v 1 \w Joshua|strong="H3091"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Nun|strong="H5126"\w* \w sent|strong="H7971"\w* \w two|strong="H8147"\w* \w spies|strong="H7270"\w* \w out|strong="H7971"\w* \w from|strong="H4480"\w* \w Shittim|strong="H7851"\w* \w secretly|strong="H2791"\w* \w and|strong="H1121"\w* instructed \w them|strong="H7971"\w*: “\w Find|strong="H7200"\w* \w out|strong="H7971"\w* \w what|strong="H7200"\w* \w you|strong="H7971"\w* \w can|strong="H7200"\w* \w about|strong="H4480"\w* \w the|strong="H7200"\w* land, especially \w Jericho|strong="H3405"\w*.” \w They|strong="H8033"\w* stopped \w at|strong="H1004"\w* \w the|strong="H7200"\w* \w house|strong="H1004"\w* \w of|strong="H1121"\w* \w a|strong="H3068"\w* \w prostitute|strong="H2181"\w* \w named|strong="H8034"\w* \w Rahab|strong="H7343"\w* \w and|strong="H1121"\w* \w spent|strong="H7901"\w* \w the|strong="H7200"\w* \w night|strong="H1121"\w* \w there|strong="H8033"\w*.
\v 2 \w The|strong="H2009"\w* \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w Jericho|strong="H3405"\w* received \w this|strong="H2008"\w* report: “\w Note|strong="H2009"\w* well! \w Israelite|strong="H3478"\w* \w men|strong="H1121"\w* \w have|strong="H1121"\w* \w come|strong="H3478"\w* \w here|strong="H2009"\w* \w tonight|strong="H3915"\w* \w to|strong="H3478"\w* spy \w on|strong="H3478"\w* \w the|strong="H2009"\w* land.”
\v 3 \w So|strong="H7971"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* \w Jericho|strong="H3405"\w* \w sent|strong="H7971"\w* \w this|strong="H3588"\w* order \w to|strong="H3318"\w* \w Rahab|strong="H7343"\w*: “Turn \w over|strong="H4428"\w* \w the|strong="H3605"\w* \w men|strong="H3605"\w* \w who|strong="H3605"\w* \w came|strong="H3318"\w* \w to|strong="H3318"\w* \w you|strong="H3588"\w* – \w the|strong="H3605"\w* ones \w who|strong="H3605"\w* \w came|strong="H3318"\w* \w to|strong="H3318"\w* \w your|strong="H3605"\w* \w house|strong="H1004"\w* – \w for|strong="H3588"\w* \w they|strong="H3588"\w* \w have|strong="H3605"\w* \w come|strong="H3318"\w* \w to|strong="H3318"\w* spy \w on|strong="H7971"\w* \w the|strong="H3605"\w* \w whole|strong="H3605"\w* land!”
\v 4 \w But|strong="H3808"\w* \w the|strong="H3947"\w* woman \w hid|strong="H6845"\w* \w the|strong="H3947"\w* \w two|strong="H8147"\w* \w men|strong="H3947"\w* \w and|strong="H3045"\w* replied, “\w Yes|strong="H3651"\w*, \w these|strong="H1992"\w* \w men|strong="H3947"\w* \w were|strong="H1992"\w* clients \w of|strong="H8147"\w* \w mine|strong="H3045"\w*, \w but|strong="H3808"\w* \w I|strong="H3651"\w* didn’t \w know|strong="H3045"\w* \w where|strong="H3808"\w* \w they|strong="H1992"\w* \w came|strong="H8147"\w* \w from|strong="H3947"\w*.
\v 5 \w When|strong="H3588"\w* \w it|strong="H3588"\w* \w was|strong="H1961"\w* \w time|strong="H1961"\w* \w to|strong="H1980"\w* \w shut|strong="H5462"\w* \w the|strong="H3588"\w* \w city|strong="H8179"\w* \w gate|strong="H8179"\w* \w for|strong="H3588"\w* \w the|strong="H3588"\w* \w night|strong="H2822"\w*, \w the|strong="H3588"\w* \w men|strong="H1980"\w* \w left|strong="H3318"\w*. \w I|strong="H3588"\w* don’t \w know|strong="H3045"\w* \w where|strong="H3808"\w* \w they|strong="H3588"\w* \w were|strong="H1961"\w* \w heading|strong="H1980"\w*. \w Chase|strong="H7291"\w* \w after|strong="H7291"\w* \w them|strong="H3318"\w* \w quickly|strong="H4118"\w*, \w for|strong="H3588"\w* \w you|strong="H3588"\w* \w have|strong="H1961"\w* \w time|strong="H1961"\w* \w to|strong="H1980"\w* \w catch|strong="H5381"\w* \w them|strong="H3318"\w*!”
\v 6 (\w Now|strong="H5921"\w* \w she|strong="H1931"\w* \w had|strong="H1931"\w* \w taken|strong="H5927"\w* \w them|strong="H5921"\w* \w up|strong="H5927"\w* \w to|strong="H5927"\w* \w the|strong="H5921"\w* \w roof|strong="H1406"\w* \w and|strong="H6086"\w* \w had|strong="H1931"\w* \w hidden|strong="H2934"\w* \w them|strong="H5921"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* \w stalks|strong="H6086"\w* \w of|strong="H6086"\w* \w flax|strong="H6593"\w* \w she|strong="H1931"\w* \w had|strong="H1931"\w* spread \w out|strong="H5921"\w* \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w roof|strong="H1406"\w*.)
