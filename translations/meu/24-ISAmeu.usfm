\id ISA
\h ISAIA
\toc1 ISAIA
\toc2 ISAIA
\mt1 ISAIA
\c 1
\p 
\v 1 Isaia, Amoso natuna, ena mata-hanai, Iuda bona Ierusalem daidiai e e itaia, Iuda pavapavadia Usia bona Iotam bona Ahasa bona Hesekia edia nega ai.
\b
\q1 
\v 2 Guba e, a kamonai! Tanobada e, a hakala!
\q2 Badina be Iehova vada e hereva, eto:
\q1 Natugu vada na reḡudia bona na hadibadibadia,
\q2 to idia ese vada e daḡedaḡe henigu.
\q1 
\v 3 Boromakau maruanena na biaguna dibana,
\q2 bona doniki na biaguna ese ana e atoa patana dibana;
\q1 a Israel na asi dibana,
\q2 egu bese taudia na lalodia asie pararamu.
\b
\q1 
\v 4 Kara dika besena o!
\q2 Kara havara ese e hametaudiamu taudia,
\q1 kara dika taudia natudia,
\q2 kara koikoi e karamu memerodia.
\q1 Idia ese Iehova vada e rakatania,
\q2 Israel ena Helaḡa Diravana e dadaraia,
\q2 ena amo vada e raka oho vaitani.
\b
\q1 
\v 5 Dahuka dainai mata-hakani doini o vaveamu,
\q2 bena o daḡedaḡe louloumu?
\q1 Kwara idoinai e hisihisimu;
\q2 kudou idoinai e hetahamu.
\q1 
\v 6 Ae lalona amo ela bona kwara
\q2 asi namona ta;
\q1 a rara aru-kubou bona toto,
\q2 bona e raramu berodia;
\q1 rara se hadodoa, bero se kumidia,
\q2 bona dehoro amo se haḡavedia.
\b
\q1 
\v 7 Emui tano vada e vahu,
\q2 emui hanua na lahi ese e aradia;
\q1 umui vaira-tuhutuhumui ai
\q2 idau taudia ese emui tano anidia vada e ha-oredia
\q1 ia na vada e ḡaḡae,
\q2 idau taudia ese vada e havahuraia.
\q1 
\v 8 Siona natuna hahinena na e nohomu,
\q2 kalaga vine imeana lalonai na heto,
\q1 rumaruma kiukamba umana ai na heto,
\q2 e koua heḡeḡe hanuana na heto.
\b
\q1 
\v 9 Iehova Saboata ese
\q2 kwabukwabuda basinema hamaurida,
\q1 ita na Sodoma heḡereḡerena ai baitama noho,
\q2 bona Gomora heḡereḡerena ai baitama hahelao.
\s1 Helao kerehai
\q1 
\v 10 Sodoma lohiamui e,
\q2 Iehova ena hereva a kamonai!
\q1 Gomora taumui e,
\q2 eda Dirava ena hahediba herevadia a hakala heni!
\q1 
\v 11 Iehova na e tomu:
\q2 Emui boubou ḡaudia momo egu ai be dahaka?
\q1 Mamoe mamaruanedia e haḡoledia oho ḡaudia,
\q2 bona ubu-ubu ḡaudia digaradia,
\q2 vada na abi davana.
\q1 Boromakau mamaruanedia eiava mamoe natudia eiava nani mamaru-anedia
\q2 raradia asina moalelaimu.
\b
\q1 
\v 12 Vairagu ai o hedinaraimu negadia ai,
\q2 daika ese e hamaoromui egu ikou tanodia ba moimoilai?
\q1 
\v 13 Herahia ḡaudia asi anidia haida ma basio mailaidia;
\q2 muramura mai bonana na ḡau dika-rohorohona egu ai.
\q1 Hua matamatadia bona dina helaḡadia bona hebou boiboidia,
\q2 kara havara bona hebou helaḡadia,
\q2 na egu ai seme heḡereḡere.
\b
\q1 
\v 14 Emui hua matamatadia bona emui aria negadia na
\q2 lau laumagu ese e inai henidiamu;
\q1 idia na maduna metauna egu ai,
\q2 ihuadia ai na hesikumu.
\q1 
\v 15 Imamui ba toi roro negana ai,
\q2 lau vairagu baina hunia emui ai;
\q1 ena e ḡuriḡuri momo ba gwaurai,
\q2 to lau basina kamonai;
\q2 imamui na rara ai e honumu.
\q1 
\v 16 Sibomui ba hehuri; sibomui ba haheḡoeva;
\q2 emui kerere na vairagu amo bavabi oho.
\q1 Kara dika ba hadoko,
\q2 
\v 17 kara namo ikarana dalana ba tahua;
\q1 hahemaoro ḡoevaḡoeva ba tahua;
\q2 hahehisi karadia ba lao ahu;
\q1 ihareha ba gimaia,
\q2 vabu dainai ba hereva.
\b
\q1 
\v 18 Iehova na e tomu:
\q2 Aoma, aita hereva hebou.
\q1 Ena be emui dika na paira na heto,
\q2 to bae huroka-kuroka \it snow\it* heḡereḡerena;
\q1 ena be idia na kakakaka herea,
\q1 to mamoe huina heḡerḡerena ai baela.
\q1 
\v 19 Lalomui bema manada bona boma kamonai,
\q2 umui ese tano anina namona boma ania;
\q1 
\v 20 a boma gwau edeede bona boma daḡedaḡe,
\q2 dare ese bema alamui mamase;
\q2 badina be Iehova uduna vada e hereva.
\s1 Siona ihahemaorohenina bona ihamaurina
\q1 
\v 21 Kara momokani hanuana, hahemaoro ḡoevaḡoeva ai e honuva hanuana,
\q2 na ariara hahinena heḡereḡerena ai vada ela.
\q1 Kara maoromaoro na ia lalonai e nohova,
\q2 a harihari roroma taudia ese e noholaiamu.
\q1 
\v 22 Emu \it silver\it* na ḡau mirona ai vada ela,
\q2 emui vine ranuna na ranu ida vada e hebulo.
\q1 
\v 23 Emui lohia na daḡedaḡe taudia,
\q2 bona henao taudia ibamodia;
\q1 iboudiai na koikoi henitaona e ura heniamu,
\q1 bona herahia ḡaudia e ḡavadiamu.
\q1 Idia ese ihareha se gimaiamu,
\q2 bona vabu ena heatu-kau dalana se haeroamu.
\b
\q1 
\v 24 Taunabunai Ḡaubada, Iehova Sabaota,
\q2 Israel ena Goada Diravana, eto:
\q1 A! Egu badu na inaigu latadiai baina seia kau,
\q2 bona e inai henigumu taudia baina hadava henidia.
\q1 
\v 25 Imagu na baina toi roro henimui,
\q2 emui miro na muramura amo baina havevea oho,
\q2 e bulolaimui ḡauna dikana idoinai baina abia oho.
\q1 
\v 26 Emui hahemaoro taudia baina haginidia lou, gunaguna heḡereḡerena,
\q2 bona emui haealo taudia danu, nega gunadia ai na heheto.
\q1 Gaeamo bae gwauraimui kara maoromaoro hanuana,
\q2 bona kara momokani hanuana.
\b
\q1 
\v 27 Siona na hahemaoro ḡoevaḡoeva ese baine hamauria,
\q2 bona ia lalonai vada e helalo kerehai taudia na
\q2 kara maoromaoro ese baine hamauridia.
\q1 
\v 28 A daḡedaḡe taudia bona kara dika taudia na bae habuadia tari hebou,
\q2 bona Iehova e rakataniamu taudia na bae aradia ore.
\q1 
\v 29 Badina be \it oak\it* audia, o moalelaiva ḡaudia, daidiai ba hemarai,
\q2 bona uma-uma, vada o abi hidi ḡaudia, daidiai vairamui bae kakakaka.
\q1 
\v 30 Badina be umui na \it oak\it* auna, rauna e maraimu ḡauna,
\q2 bona uma-uma asi pariparina,
\q2 heḡereḡeredia ai ba hahelao.
\q1 
\v 31 Goada tauna na varo haura-haurana ai bainela,
\q2 bona ena ḡaukara na lahi kimoremorena ai bainela;
\q1 ruaosi bae ara bou,
\q2 bona tau ta ese basine habododia.
\c 2
\s1 Iehova ena Maino
\p 
\v 1 Isaia, Amoso natuna, ese e itaia herevana, Iuda bona Ierusalem daidiai.
\b
\q1 
\v 2 Dina gabedia ai ina na baine vara:
\q2 Iehova ena dubu ororona na
\q1 atai-herea ororona ai baine hahelao,
\q2 bona baine heabi isi ororo maraḡidia daediai.
\q1 Bese iboudiai ese bae aru henia,
\q2 
\v 3 taunimanima loḡora baema, baeto:
\q1 Aoma, Iehova ena ororo baita dara dae henia,
\q2 Iakob ena Dirava ena dubu ai;
\q1 ia ese ena kara baine hadibalaida,
\q2 ena dala ai baita raka helaoreana.
\q1 Badina be Siona lalona amo taravatu bainela,
\q2 Ierusalem amo Iehova ena hereva bainela.
\q1 
\v 4 Ia ese bese idau-idau padadiai baine hahemaoro,
\q2 bona hahemaoro herevadia na taunimanima loḡora baine gwaurai henidia;
\q1 bena idia ese edia dare bae hododia, ruarua auridia ai bae halaodia,
\q2 bona edia io bae hododia, kwama-kwama kaiadia ae bae halaodia;
\q1 bese ta ese dare basine veri lasi, bese ta ihadikana totona,
\q2 bona tuari daladia basie hahedibalai lou.
\s1 Heaḡi taudia ihahemaoro-henidia
\p 
\v 5 Iakob besena e, aoma,
\q2 Iehova ena diari ai baita raka.
\b
\q1 
\v 6 Badina be oi ese emu orea taudia vada o dadaraidia,
\q2 Iakob besena vada o dadaraia;
\q1 badina be mari-abi taudia mairiveina kahana amo
\q2 bona rohe taudia Filistia taudia hetomadia ai e honumu,
\q2 bona idau bese taudia ida e utua hehenimu mai ima udeudedia ida.
\q1 
\v 7 Edia tano na \it silver\it* bona \it gold\it* ai e honumu,
\q2 bona edia dava-bada kohudia na asie oremu;
\q1 edia tano na hosi ai e honumu,
\q2 bona edia kariota na asie oremu.
\q1 
\v 8 Edia tano na kaivakuku ai e honumu;
\q2 imadia amo vada e kara ḡaudia,
\q1 ima kwakikwakidia amo vada e kara ḡaudia,
\q2 e toma henidia dihomu.
\q1 
\v 9 Taunimanima na unu amo e hamanaudiamu,
\q2 taunimanima na e hamaraḡidiamu;
\q2 edia dika basio gwau tao.
\q1 
\v 10 Nadi-gini lalonai ba komu,
\q2 ḡahu ai ba hetahuni ahu,
\q1 Iehova igari-henina amo,
\q2 bona ena pavapava hairaina amo.
\q1 
\v 11 Vairadia ai e hekokorokumu taudia ita-itadia bae hamaragi,
\q2 taunimanima edia heaḡi bae hamanau;
\q1 Iehova sibona mo bae imodaia
\q2 una dina ai.
\b
\q1 
\v 12 Badina be Iehova Sabaota na mai ena dina ta,
\q2 heaḡi bona hekokoroku idoidiai
\q1 bona e heabi isimu, atai ai e heatomu, ḡaudia iboudiai ihadikadia dinana;
\q1 
\v 13 Lebanon sida-audia iboudiai,
\q2 ḡau-latalatadia bona kidotaodia,
\q1 bona Basan \it oak\it* audia iboudiai
\q2 ihadikadia dinana;
\q1 
\v 14 ororo badadia iboudiai
\q2 bona ororo ḡau-latalatadia iboudiai
\q2 ihadikadia dinana;
\q1 
\v 15 kohoro latadia iboudiai
\q2 bona maḡu aukadia iboudiai
\q2 ihadikadia dinana;
\q1 
\v 16 Tarasisi lagatoidia iboudiai
\q2 bona lagatoi herea-daedia iboudiai
\q2 ihadikadia dinana.
\q1 
\v 17 Taunimanima edia hekokoroku bae hamanau,
\q2 taunimanima edia heaḡi bae hamaraḡi,
\q1 bona Iehova sibona mo bae imodaia
\q2 una dina ai.
\q1 
\v 18 Bona kaivakuku na bae hapuki,
\q2 bae hapuki vaitani.
\q1 
\v 19 Bena taunimanima na nadi kohuadia lalodiai bae raka vareai,
\q2 bona tano guridia lalodiai danu,
\q1 Iehova igari-henina amo,
\q2 bona ena pavapava hairaina amo,
\q1 tanobada ihagarina totona
\q2 baine tore isi negana ai.
\b
\q1 
\v 20 Una dina ai taunimanima ese
\q2 edia \it silver\it* kaivakukudia bona edia \it gold\it* kaivakukudia,
\q1 bae toma henidia diho totona e karadia ḡaudia,
\q2 na migu bona sisiboi ediai bae negedia;
\q1 
\v 21 bena nadi kohuadia lalodiai bae raka vareai,
\q2 bona nadi-hagadia padadiai danu,
\q1 Iehova igari-henina amo,
\q2 bona ena pavapava hairaina amo,
\q1 tanobada ihagarina totona
\q2 baine tore isi negana ai.
\q1 
\v 22 Taunimanima, laḡa na udu-baubauna ai e miamu ḡauna,
\q2 ena amo ba raka oho,
\q2 badina be ia namona be dahaka?
\c 3
\q1 
\v 1 A itaia, Ḡaubada, Iehova Sabaota, ese
\q2 Ierusalem bona Iuda amo
\q1 edia goada ihavaradia ḡaudia e abidia ohomu,
\q2 aniani ena hahegoada idoinai,
\q2 bona ranu ena danu;
\q1 
\v 2 goada tauna bona tuari tauna,
\q2 hahemaoro tauna bona peroveta tauna,
\q2 mari tauna bona hanua tau-badana,
\q1 
\v 3 imahui lohiana
\q2 bona dagi tauna,
\q1 hahealo tauna bona babalau mai dibana tauna,
\q2 bona mea ḡaudia dibana momo tauna.
\b
\q1 
\v 4 Memero na edia lohia ai baina halaodia,
\q2 karukarudia ese bae biagudia.
\q1 
\v 5 Taunimanima na bae hahehisi heheni,
\q2 ta ta bamona bamona,
\q2 bona ta ta dekena tauna dekena tauna:
\q1 eregabe tauna ese tau badana baine ihi-ihiraia,
\q2 bona lebulebu tauna ese kara momokani tauna baine ḡonaḡonalaia.
\b
\q1 
\v 6 Negana bainema tau ta ese tadikakana enai baine dau kau,
\q2 tamana ena ruma ai, baineto:
\q1 Oi na mai emu dagi dabuana,
\q2 emai hegunalai tauna ai baola,
\q1 bona ini e kohu rumadia nadidia isenudia na
\q2 oi ese ba biagudia.
\q1 
\v 7 Una dina ai ia baine hereva hedinarai, baineto:
\q2 Lau na hisihisi iabi-ohona tauna ai basinala,
\q2 egu ruma ai aniani bona dagi dabuana na lasi;
\q1 oi ese taunimanima igunalaidia tauna ai
\q2 basio halaogu.
\q1 
\v 8 Badina be Ierusalem vada e hetutuhi,
\q2 bona Iuda vada e keto;
\q1 badina be edia hereva bona edia kara ese Iehova e inai heniamu,
\q2 ia hairaina hedinaraina e dadaraiamu.
\b
\q1 
\v 9 Edia hahemaoro gagevadia ese e hadikalaidiamu,
\q2 edia dika e gwaurai hedinaraimu Sodoma na heto,
\q2 asie hunimu.
\q1 Madi ihabaidia!
\q2 Badina be dika na sibodia latadiai vada e hadihoa.
\q1 
\v 10 Kara maoromaoro taudia ba hamaorodia, do bae namo;
\q2 edia kara huahuadia do bae ani.
\q1 
\v 11 Kara dika tauna madi ihabaina! Ia na do baine dika;
\q2 badina be imana ese vada e kara ḡaudia heḡereḡeredia ai ia badi-kara henia.
\q1 
\v 12 Egu bese taudia madi, memero ese e hahisidiamu,
\q2 bona hahine ese e biagudiamu.
\q1 Egu bese taumui e, igunalaimui taudia ese e hakaumui kereremu,
\q2 bona emui raka daladia e haheḡonudiamu.
\b
\q1 
\v 13 Iehova ese ena gabu vada e abia, baine helodu heni;
\q2 ena bese taudia vairadiai e ginimu, baine hahemaoro henidia.
\q1 
\v 14 Iehova ese ena bese tau-badadia bona lohiadia
\q2 e hahemaoro henidia matamamu, e tomu:
\q1 Umui ese vine imeana anidia vada o ani ore,
\q2 bona ogoḡami taudia ediai o dadi kohudia na emui ruma ai mimia.
\q1 
\v 15 Dahaka dainai egu bese taudia o moimoilaidiamu,
\q2 bona ogoḡami taudia vairadia o moidia taomu?
\q2 Ḡaubada, Iehova Sabaota, unu e gwau tomamu.
\s1 Siona kekenidia ihahemaoro-henidia
\b
\q1 
\v 16 Iehova eto:
\q2 Siona kekenidia na e heaḡimu,
\q2 bona rakadia ai aiodia e haboḡemu,
\q1 e mata varuamu,
\q2 bona e raka sihesihemu,
\q2 ae-ganagana tarekodia e hareḡediamu;
\q1 
\v 17 una dainai Ḡaubada ese Siona kekenidia kwaradia baine hapoukadia,
\q2 bona Iehova ese vairadia iḡovalaidia dabuadia baine dabuidia oho.
\p 
\v 18 Una dina ai, Ḡaubada ese ae kapadia, kwara kaparidia, mairi,
\v 19 odo, gana, muko,
\v 20 sera, toea, gaba toradia, muramura mai bonadia mauamauadia toni,
\v 21 ima-kwakikwaki vaḡiva=idia, udu-baubau gadeidia,
\v 22 ipou, he=ova dabuadia, hahedoki badadia, vaina-vaina,
\v 23 dabua severa-severadia, dabua aukadia, kwara ikumilaidia dabuadia bona vaira iḡovalaidia dabuadia iboudiai baine abidia oho.
\b
\q1 
\v 24 Muramura mai bonana na bodaga ese do baine boloa,
\q2 bona gaba torana ibolona na kwanau;
\q1 hui ḡoeva-daena gabuna ai, kwara boha,
\q2 bona dabua namo-hereana gabuna ai, puse ramina,
\q2 bona hairai gabuna ai, hemarai.
\q1 
\v 25 Emu tatau na dare ai bae mase,
\q2 bona emu goada taudia na tuari ai bae mase.
\q1 
\v 26 Siona ena ikoukou bae tai lolololo, bae tai hevale;
\q2 ḡaḡaena ai tano ai baine helai.
\c 4
\p 
\v 1 Una dina ai hahine hahitu ese tau tamona bae dabuia, baeto, Sibomai amai baia ani, bona sibomai emai dabua baia hahedokilai, ḡau tamona, na oi ladamu ai bae gwauraimai kau; emai hemarai bavabia oho.
\b
\s1 Ierusalem ena nega namona baine kau
\p 
\v 2 Una dina ai Iehova ena rigi do baine hairai bona baine herea dae, bo na tano anina na Israel kwabukwabudia edia heaḡi bona edia heimodai ḡauma ai bainela.
\v 3 Bena Siona ai e rakatanidia, Ierusalem ai e nohomu, taudia na helaḡa taudia bae gwauraidia, Ierusalem ai ladadia vada e tore mauri iabina totona taudia iboudiai.
\v 4 Ḡaubada ese Siona kekenidia edia miro baine huri oho, bona Ierusalem bogaraginai rara ese vada e hamiro gabudia na hahemaoro laumana bona heara laumana amo bae haḡoevadia negana murinai.
\v 5 Bena Iehova ese Siona ororona idoinai daenai bona latanai e heboumu taudia daediai ori baine havaraia dina ai, bona kwalahu bona lahi hururu-hururuna hanuaboi ai; badina be hairai idoinai daenai na helao-ahu ḡauna bona kalaga bae mia.
\v 6 Dina ai ia na ikerukeru ai bainela, siahu ilao-ahulaina, bona metai gabuna ai bainela, lai gubana bona medu ilao-ahulaidia.
\c 5
\s1 Sivarai heḡereḡerena: vine imeana
\q1 
\v 1 Ane ta baina abia, egu lalokau tauna ena,
\q2 lalokau anena, ena vine imeana dainai:
\q1 Egu lalokau tauna na mai ena vine imeana ta,
\q2 ororo ai, tano namona ai.
\q1 
\v 2 E ruaia, nadi e negedia,
\q2 bena vine namo-hereadia e hado;
\q1 bogaraginai gima patana e haginia,
\q2 bona nadi e taraia guriguri, vine itaolaidia.
\q1 Bena ia banava eto vine huahuadia bae dobi,
\q2 to uda vinedia huahuadia hetomadia mo e dobi.
\b
\q1 
\v 3 Ierusalem inoholaina taumui e,
\q2 Iuda taumui e,
\q1 Lau na noimuimu, lau bona egu vine imeana
\q2 ba gwauraimai hidi, edena be namo.
\q1 
\v 4 Dahaka bama karaia egu vine imeana enai,
\q2 bena asina karaia?
\q1 Lau banava nato vine huahuadia bae dobi,
\q2 to dahaka dainai uda vinedia huahuadia hetomadia mo e dobi?
\b
\q1 
\v 5 A harihari aina hamaoromui,
\q2 egu vine imeana ede baina ḡaukaralaia toma:
\q1 Arana baina raḡaia,
\q2 bena lahi ai bae doua;
\q1 maḡuna baina ḡiḡia dobi,
\q2 bena bae moimoilaia;
\q1 
\v 6 baina havahua,
\q2 vine rigidia basie kwamadia bona ava basie rau,
\q2 ava ḡiniḡini bona au ginigini na bae tubu;
\q1 dagadaga danu baina haḡanidia,
\q2 medu basie hadihoa ia latanai.
\q1 
\v 7 Badina be Iehova Sabaota ena vine imeana
\q2 na Israel besena,
\q1 bona Iuda taudia na
\q2 ena uhe namodia;
\q1 ia ese hahemaoro ḡoevaḡoeva e tahua,
\q2 a ḡau be rara hebubu mo;
\q1 kara maoromaoro e tahua,
\q2 a ḡau be taitai mo.
\b
\s1 Kara dika taudia, ihabaidia!
\q1 
\v 8 Ruma ta ruma ta ida
\q2 bona uma ta uma ta ida e haboudia taudia,
\q2 madi, ihabaidia!
\q1 Umui na asi emui noho gabuna ta,
\q2 tano bogaraginai vada e hanohomui edea dainai.
\q1 
\v 9 Iehova Sabaota ena gwauhamata na kamonai, eto:
\q2 Ruma momo bae mia ḡaḡae,
\q2 ruma namodia, mai hairaidia, to asi inoholaidia taudia.
\q1 
\v 10 Badina be vine imeana dina tamona ena herua tanona
\q2 anina na bata tamona bae haboua,
\q1 bona uhe nadinadidia homere ta amo
\q2 aniani efa\f + \fr 5:10 \ft Bata; homere; efa. Ini na Heberu taudia edia hahetoho ḡaudia haida.\f* tamona bae abia.
\b
\q1 
\v 11 Unu daba maraḡi ai e tore isimu
\q2 kekero ḡaudia bae tahu totona,
\q1 bena e halahemu ela bona hanuaboi ai
\q2 vine ranuna ese e hakekerodiamu taudia,
\q2 madi, ihabaidia!
\q1 
\v 12 Edia aria ai idia na mai edia hatai-hatai ḡaudia maraḡidia bona badadia,
\q2 bona edia tareko bona ivilikou bona vine ranuna danu;
\q1 to idia ese Iehova ena kara asie lalodiamu,
\q2 bona imana ai e kara ḡaudia asie itadiamu.
\b
\q1 
\v 13 Taunabunai egu bese taudia na dauhai e hanohodiamu,
\q2 asi edia lalo-parara dainai;
\q1 e matauradiamu taudia na e hitolodia masemu,
\q2 bona edia taunimanima hutuma na e ranu masemu.
\q1 
\v 14 Una dainai Mase Gabuna e gadomu,
\q2 bona uduna e haḡaia badabadamu;
\q1 Ierusalem lohiadia bona ena taunimanima hutuma na e diho e laomu,
\q2 ena hegogo taudia bona ia e heaḡilaiamu tauna danu.
\q1 
\v 15 Taunimanima na e ha-igodia dihomu, e atodia dobimu;
\q2 heaḡi taudia matadia e harohadia tarimu.
\q1 
\v 16 A Iehova Sabaota na hahemaoro ḡoevaḡoeva ai e imodaiamu,
\q2 bona Helaḡa Diravana ese ena helaḡa na kara maoromaoro ai e hahedinaraiamu.
\q1 
\v 17 Bena mamoe natudia na bae aniani, edia rei gabudia ai bema aniani na heto;
\q2 ubu-ubu ḡaudia bona nani natudia na ruma ahutudia ai bae aniani.
\b
\q1 
\v 18 Kara havara na koikoi varodia amo e veriamu,
\q2 bona kara dika e veriamu, rerue kwanaudia amo bema veria na heto taudia,
\q2 madi, ihabaidia!
\q1 
\v 19 Idia na e tomu: Baine kara haraḡa,
\q2 ena ḡaukara baine haheaua,
\q2 baia itaia helaoreana;
\q1 Israel ena Helaḡa Diravana ena lalo-hadai baine kahikahi mai,
\q2 bainema, baia dibaia helaoreana.
\q1 
\v 20 Unu dika e gwauraiamu namo bona namo e gwauraiamu dika taudia,
\q2 unu dibura na diari ai bona diari na dibura ai e halaomu taudia,
\q1 unu idita na e hagaihoa bona gaiho na e ha-iditaia taudia,
\q2 madi, ihabaidia!
\q1 
\v 21 Unu sibodia matadia ai mai aonegadia e tomu
\q2 bona sibodia vairadiai mai dibadia momo e tomu taudia,
\q2 madi, ihabaidia!
\q1 
\v 22 Unu mai haridia vine ranuna i'inuna ai,
\q2 bona mai boga-aukadia kekero ḡaudia ibulodia ai taudia,
\q2 madi, ihabaidia!
\q1 
\v 23 Unu henitao koikoi dainai kerere tauna maorona e gwauraiamu
\q2 bona asi ena kerere tauna igwaurai-maorona se uramu taudia,
\q2 madi, ihabaidia!
\b
\q1 
\v 24 Taunabunai, vada e utu reidia badidia lahi ese vada e aradia,
\q2 bona rei kakoro na lahi hururudia ai e ara oremu na heto,
\q2 idia ramudia unu bae houka-houka toma,
\q2 bona buredia bae heoda isi kahu na heto;
\q1 badina be idia ese Iehova Sabaota ena taravatu vada e negea,
\q2 bona Israel ena Helaga Diravana ena hereva vada e dadaraia.
\q1 
\v 25 Taunabunai Iehova ena badu e ḡaraḡara, ena bese taudia latadia
\q2 bena ia imana e toi roro henidia, e rahudia mase,
\q2 bona ororo na e heude-heude;
\q1 bena tau-anidia masedia na momoru na heto,
\q2 ariara bogaragidiai.
\q1 Ḡau tamona, ena badu na do se heabi oho,
\q2 bona imana na doini e hetoi roromu.
\b
\q1 
\v 26 Toa na dauhai e nohomu besena baine henia,
\q2 bona tanobada dokodia amo baine hioga henia.
\q1 A itaia, e mai haraḡa-haraḡamu.
\b
\q1 
\v 27 Ta tauna se boeramu, ta se hetutuhimu,
\q2 ta matana se hakapumu eiava se mahutamu,
\q1 ta ramina se heruhamu,
\q2 tamaka varona ta se motumu;
\q1 
\v 28 edia diba na mamataka-mamataka,
\q2 edia peva iboudiai e marediamu,
\q1 edia hosi aedia na nadi-vasiga na heto,
\q2 edia ava-keikei na koe-hirihiri na heto;
\q1 
\v 29 edia ḡou na leona e ḡoumu na heto,
\q2 leona natudia na heheto e ḡoumu,
\q1 e ḡiḡimu, damudia e korimu,
\q2 e laohaimu, ta basine hamauridia diba.
\q1 
\v 30 Una dina ai bae heḡaralaia,
\q2 davara hurehuredia reḡedia na heheto.
\q1 Ta ese tanobada bema haḡerea,
\q2 dibura bona hisihisi mo bema ita davari;
\q2 bona ia dagadagana ese diari e hadiburaiamu.
\c 6
\s1 Dirava ese Isaia e boiria
\p 
\v 1 King Usia e mase laḡanina lalonai, lau ese Ḡaubada na itaia, terono ai e helaiva, atai ai e heabi isiva; ena dabua latana isena ese dubu e hahonuava.
\v 2 Ia daenai serapi na gigini; idia ta ta hanidia na tauratoi tauratoi amo: rua amo ia vairana e ḡovaia, ma rua amo aena e ḡovadia, ma rua amo rohova.
\v 3 Bena e heboi heheni, eto:
\q1 Iehova Sabaota na helaḡa, helaḡa, helaḡa;
\q1 ia hairaina ese tanobada idoinai e hahonuamu.
\p 
\v 4 Bena boiboi tauna gadona ese raka-vareai iduaradia badidia e hamareredia, bo na kwalahu ese dubu e hahonua.
\v 5 Bena lau nato, Madi, ihabaigu! Badina be lau vada name baia; badina be lau na bibina miroka taugu, bona bibina miroka taudia bogaragidiai na nohomu; badina be matagu ese Pavapava, Iehova Sabaota vada e itaia.
\p 
\v 6 Bena serapi ta na dekegu e roho mai, imana ai na gida ta, ihaboulaina patana amo auri ikahina ai e abia ḡauna.
\v 7 Bena udugu e daua toho, eto, A itaia, ina ḡau ese udumu vada e daua toho; emu kerere vada eme heabi oho, bona emu dika vada eme hegwau tao.
\v 8 Bena Ḡaubada gadona na kamonai; eto, Daika baina siaia? Daika na ai daimai ai bainela? Bena lau nato, Lau o ina, a siaigu.
\v 9 Bena ia eto, Aola, ina bese ba hamaoroa, baoto:
\q1 Ba kamonai loulou, to lalomui basie parara;
\q2 ba ita loulou, to basio diba.
\q1 
\v 10 Ini taunimanima na lalodia ba haduhudia,
\q2 bona taiadia ba hakudimadia,
\q2 bona matadia ba hakapudia;
\q1 matadia amo bema ita,
\q2 bona taiadia amo bema kamonai,
\q1 bona lalodia bema parara,
\q2 bena bema kerehai bona bema namo lou na garina.
\q1 
\v 11 Bena lau nato, Ḡaubada e, ela bona edena nega ai? Bena ia eto:
\q1 Ela bona hanua badadia bae vahu,
\q2 asi inoholaidia tauna ta baine mia,
\q1 bona ruma na asi taunimanimadia ai baela,
\q2 bona tano idoinai baine vahu vaitani;
\q1 
\v 12 bona Iehova ese taunimanima na dauha baine laohaidia,
\q2 bona bae rakatanidia gabudia bae momo tano bogaraginai.
\q1 
\v 13 Ena be karoa gvauta amo karoa ta baine mia,
\q2 to ma baine ara lou,
\q1 \it terebinth\it* auna eiava \it oak\it* auna e hagariamu
\q2 bena badina mo e miamu na heto.
\q1 Ia badina na uhe helaḡana.
\c 7
\s1 Isaia ena gwau-kau herevana Ahasa enai
\p 
\v 1 Ahasa Iotam, Usia tubuna, Iuda pavapavana, ena nega ai, Resini, Suria pavapavana, bona Peka Remalia, Israel pavapavana, na Ierusalem e dae lao, bae tuari henia totona, a asie hadarerea diba.
\v 2 Bena David garana e kamonai Suria na Efraim ida vada e henega hebou negana ai, ia bona ena orea taudia kudoudia e hetaha, uda audia na lai ai e helado-heladomu na heto.
\p 
\v 3 Bena Iehova ese Isaia e hamaoroa, eto, Ahasa ihedavari-henina totona a raka lasi, oi bona natumu Seara-iasubu, atai gohuna dadairana dokona ai, Dabua-huri Tauna ena tano lao dalana ai, Dabua-huri Tauna ena tano lao dalana ai, ia ida ba hedavari.
\v 4 Ba hamaoroa, baoto, Nahuamu ba tohoa, lalomu basine hekwarahi; basio gari bona basio kudou-hetaha ini lahi tutututudia ruaosi, e ara oremu ḡaudia, hari Resini bona Suria bona Remalia natuna, edia badu-ḡaraḡara dainai.
\v 5 Badina be Suria, Efraim bona Remalia natuna ida, oi ihadikamu dalana vada e laloa hata, e tomu
\v 6 “Iuda ihadikana totona baita dae lao, baita hagaria, bena baita hadarerea bona baita abia iseda, bona Tabele natuna na pavapava ai baita halaoa ia bogaraginai”.
\v 7 Una dainai Ḡaubada Iehova na ini e gwau tomamu:
\q1 Una na basine gini,
\q2 bona anina basine vara;
\q1 
\v 8 badina be Suria kwarana na Damasko,
\q2 bona Damasko kwarana na Resini.
\m (Laḡani tauratoi-ahui ima bae lao henia lalonai Efraim na baine makohirohoroho, bona basie gwauraia bese ta.)
\q1 
\v 9 Bona Efraim kwarana na Samaria,
\q2 bona Samaria kwarana na Remalia natuna.
\q1 Bema basio kamonai,
\q2 momokani umui na basio gini tutuka-tutuka.
\b
\s1 Emanuel
\p 
\v 10 Iehova ese Ahasa ma e hereva henia, eto,
\v 11 Iehova, emu Dirava, enai toa ta ba gwauraia; baine dobu, Mase Gabuna na heto, eiava baine dae, guba na heto.
\v 12 A Ahasa eto, Ḡau ta basina gwauraia bona Iehova basina dibaḡania.
\v 13 Bena Isaia eto, Benaini, David garana e, a kamonai! Taunimanima o hahekwarahidiamu na ḡau pipikina dainai egu Dirava danu o hahekwarahiamu a?
\v 14 Taunabunai Ḡaubada sibona ese toa ta baine henimu.
\v 15 A itaia, haneulato ta baine rogorogo, natuna baine havaraia, mero ta; bena ladana baine hatoa Emanuel\f + \fr 7:15 \ft “Emanuel” anina be “Dirava na ita dekedekedai”.\f*. Dika idadaraina bona namo iabi-hidina baine diba negana ai, ia ese rata-hetarina bona bada-ranuna baine ani.
\v 16 Badina be una mero na dika idadaraina bona namo iabi-hidinado basine diba hekada hanai, hari o gari henidiamu pavapavadia raruosi edia tano na bae vahu.
\v 17 Iehova ese nega ta baine havaraia, oi bona emu bese audia bona tamamu ena iduhu latadiai; nega unuhetomana ta se vara, Efraim ese Iuda e rakatania negana amo ema bona hari. Asuria pavapavana bunai.
\p 
\v 18 Una dina ai Iehova ese Aigupto sinavaidia badidia laodia bona Asuria tanona labolabona loḡora baine hioga henidia.
\v 19 Bena iboudiai bae roho mai, koura dobudobudia ai bona haga nadidia kohuadia ai bona au ḡiniḡini ona rei gabudia iboudiai lalodiai bae noho.
\p 
\v 20 Una dina ai Ḡaubada ese vasiga ta Sinavai Badana unukahana amo baine vatua, Asuria pavapavana bunai; bena kwara bona ae baine naudia, bona auki-huina danu.
\p 
\v 21 Una dina ai tau ta ese boromakau hahinena matamatana ta bona mamoe hahinedia rua baine ubudia;
\v 22 bena rata momo herea bae heni dainai, ia ese rata-hetarina baine ania; badina be tano ai do bae noho taudia iboudiai ese rata-hetarina bona bada-ranuna bae ani.
\p 
\v 23 Gunaguna vine audia daha-ta, davadia \it silver\it* sekeledia daha-ta\f + \fr 7:23 \fk Silver\ft sekeledia daha-ta = \fk silver\ft metauna 31 Ibs sisivana.\f* ḡaudia, e varava gabudia iboudiai na una dina ai ava ḡiniḡini bona au ḡiniḡini ese bae habubunidia.
\v 24 Taunimanima na mai pevadia bona mai dibadia ida unu gabu baela; badina be tano idoinai ava ḡiniḡini bona au ḡiniḡini ese bae habubunia.
\v 25 Ororo danu, gunaguna isiva amo avadia e rau; a unu basiola, ava ḡiniḡini bona au ḡiniḡini na garidia. A unu na boromakau heruhadia bona mamoe edia hemoimoilai gabudia ai baela.
\c 8
\s1 Peroveta tauna natuna ladana
\p 
\v 1 Bena Iehova ese e hereva henigu, eto, Nadi palakana badana ta bavabia, bena taunimanima iboudiai dibadia revarevadia amo ba torea “Mahere-salala-hasa-basa ena”.
\v 2 Bena ihamomokanina taudia namodia na abidia. Uria, hahelaḡa tauna, bona Sekaria, Ieberekia natuna, egu kara bae hamomokania totona.
\v 3 Bena peroveta hahinena dekenai na raka vareai, bena ia na e rogorogo, mero ta e havaraia. Bena Iehova ese e hamaorogu, eto, Ladana ba hatoa “Mahere-salala-hasa-basa”;\f + \fr 8:3 \ft “Mahere-salala-hasa-basa” anina be “E dadi kohudia na e heaumu: darinu na e haragamu”.\f*
\v 4 badina be mero na “Mama” eiava “Ina” do basine boi diba negana ai, Damasko ena taḡa bona Samaria ai bae dadi kohudia na Asuria pavapavana vairanai bae hua lao.
\p 
\v 5 Iehova ese ma e hereva henigu, eto,
\v 6 Badina be ina bese ese Siloa ranudia, e aru metaira-metairamu ḡaudia, vada e dadaraidia, bona Resini bona Remalia natuna garidia ese e butudia taomu,
\v 7 una dainai Ḡaubada ese Sinavai Badana ranudia na idia ihadikadia totona e ha-arudia maimu. Unu ranu na goada herea bona momo, Asuria pavapavana mai hairaina idoinai ida; bena abata ese sinavai baine hahonudia, sinavai popotodia iboudiai baine utudia dae;
\v 8 ma baine aru lao ela bona Iuda tanona baine utua dae, ma bainela, baine dae ela bona aio ai baine kau. Emanuel e, hanina hetoi-rorodia ese emu tano lababana baine hahonua.
\b
\q1 
\v 9 Bese idau-idau e, ba heḡiḡi rohoroho, ba gari dikadika!
\q2 Gabu daudau e, ba hakala!
\q1 Emui rami ba hekasilai, ba gari dikadika;
\q2 emui rami ba hekasilai, ba gari dikadika.
\q1 
\v 10 Ba henega bou, to ḡau ta basine vara;
\q2 ba hereva, to emui hereva basine gini;
\q2 badina be Dirava na ai dekedekemai ai.
\s1 Iehova garina ba gari
\b
\p 
\v 11 Badina be Iehova ese unu e hereva henigu toma; imana mai goadana na lau latagu ai e atoa kau, bona e sisiba henigu, ina bese ena dala ai basina raka. Eto,
\v 12 Ina bese ese “dika henegadia” e gwauraimu ḡaudia iboudiai na umui ese “dika henegadia” basio gwauraidia, bona garidia e garimu ḡaudia na garidia basio gari, bona kudoumui basie hetaha.
\v 13 A Iehova Sabaota hari ba gwauraia “helaḡa”; ia mo ba gari henia, bona ia dainai kudoumui bae hetaha.
\v 14 Ia na gabu helaḡana ai bainela, bona Israel oreadia ruaosi ediai hekwakwanai bona hetutuhi nadidia ai bainela, bona Ierusalem inoholaina taudia ediai rikiriki bona idoa ai bainela.
\v 15 Hutuma na ienai bae hetutuhi; bae moru bona bae hehuari; baine idoadia, bena baine abidia.
\p 
\v 16 Hahediba herevadia ba hunidia; egu hahediba taudia mo ba hadibadibalaidia.
\v 17 Iehova baine naria; ia ese vairana na Iakob ena iduhu amo e huniamu; ia baina laroa.
\v 18 A itaia, lau bona natugu, Iehova ese vada e henigu memerodia, na toa bona gware Israel ai, Iehova Sabaota, Siona ororona ai e nohomu Diravana, ena amo.
\v 19 Bae hamaoromui, baeto “Rohe taudia bona mea taudia, e tanatanamu bona e hereva hemaunumu taudia, na ba nanadaidia” negana ai ba laloa, taunimanima ese edia Dirava basiema nanadaia a? Mase taudia bema nanadaidia mauri taudia dadiai a?
\v 20 Hahediba daladia bona hahediba herevadia ba badinadia. Momokani ina e gwauraiamu herevana na asi diarina.
\v 21 Tano bae rakaia hanai mai hisihisi badadia bona mai hitolodia ida; bena bae hitolo negana ai bae badu ḡaraḡara, bena edia pavapava bona edia Dirava bae uduguiraidia. Bae gaga dae,
\v 22 bona tanobada bae raraia, a hisihisi bada bona dibura mo bae ita, hisihisi bada-hereavaburana; bena dibura masemase lalonai bae doridia vareai.
\c 9
\s1 Maino Lohiana
\p 
\v 1 A hisihisi ese e gugubaiava hahinena na vabura ai basinela. Nega gunana ai ia ese Sebulun bona Napatali tanodia na hedadarai gabudia ai e halaodia; a nega gabena ai ia ese davara dalana, loridane sinavaina unukahana tanona, bese idau-idau edia Galilea, baine hahairaia.
\q1 
\v 2 Dibura ai e rakava taudia ese
\q2 diari badana vada e itaia;
\q1 dibura masemase tanona ai e nohova taudia latadiai
\q2 diari vada e tata dae roha.
\q1 
\v 3 Bese vada o hahutumaia,
\q2 bona ena moale vada o habadaia;
\q1 idia na oi vairamu ai e moalemu,
\q2 taboro imoalelaina na heto,
\q2 eiava vada e dadi kohudia e harimu taudia edia moale na heto.
\q1 
\v 4 Badina be ena maduna metauna,
\q2 bona ia paḡana auna,
\q1 bona ia ihahisina tauna ena ikwadi auna,
\q2 oi ese vada o hakwaidu Midian ena dina ai na heto.
\q1 
\v 5 Badina be tuari herou-herouna ai e rakamu taudia edia tamaka iboudiai,
\q2 bona rara ai vada e hekuikuilai dabuadia iboudiai,
\q2 bae gabudia, lahi audia na heheto.
\q1 
\v 6 Badina be meromero ta vada e vara, ita eda;
\q2 mero ta vada e henida.
\q1 Taunimanima ireḡudia na ia paḡana ai baine heato,
\q2 bona ladana bae hatoa:
\q1 Hahealo Tauna Herea-daena, Siahu-bada Diravana,
\q2 Tamada hanaihanai, Maino Lohiana.
\q1 
\v 7 Ena heregu ihabadana bona maino daladia
\q2 na basie doko,
\q1 David ena terono bona ena basileia latadiai,
\q2 baine haginia bona baine ha-aukaia totona,
\q1 mai hahemaoro ḡoevaḡoeva bona mai kara maoromaoro ida,
\q2 hari ina nega ela hanaihanai.
\q1 Ina na Iehova Sabaota ena ura-kwalimu ese baine karaia.
\b
\s1 Iehova ena badu Israel latanai
\q1 
\v 8 Ḡaubada ese hereva ta vada e siaia, Iakob ihadikana;
\q2 ia na Israel latanai baine kau.
\q1 
\v 9 Bena taunimanima iboudiai bae diba,
\q2 Efraim bona Samaria inoholaina taudia na
\q1 edia heaḡi ai bona edia hekokoroku ai e herevamu,
\q2 e tomu:
\q1 
\v 10 E tunu nadidia vada e heḡiḡi dobi,
\q2 a e utu nadidia amo ruma baia haginia;
\q1 suke audia na vada e hagaridia,
\q2 a sida audia baia hadodia idia gabudia ai.
\q1 
\v 11 Taunabunai, Iehova ese idia ihadikadia taudia e hatoredia isimu,
\q2 bona inaidia na e hagaradiamu.
\q1 
\v 12 Suria taudia laurabada kahana ai bona Filistia taudia lahara kahana ai ese
\q2 ududia e hagadiamu, Israel e hadonoamu.
\q1 Ina idoinai vada e vara, to ena badu do se keru;
\q2 ia imana na doini e hetoi roromu.
\b
\q1 
\v 13 E rahudia mase tauna na taunimanima ese asie haḡerea,
\q2 Iehova Sabaota asie tahua.
\q1 
\v 14 Taunabunai, Iehova ese Israel kwarana bona iuna e utu oho,
\q2 reta bona geda, dina tamona lalonai.
\q1 
\v 15 Tau badana, e matauraiamu tauna, na kwara,
\q2 bona koikoi herevadia e hahedibalaimu perovetana na iu;
\q1 
\v 16 badina be ina bese taudia e hakaudia taudia ese e hakaudia kereremu,
\q2 idia ese e hakaudiamu taudia na e hadonodiamu.
\q1 
\v 17 Taunabunai Ḡaubada ese edia eregabe taudia se moalelaidiamu,
\q2 bona edia ihareha bona edia vabu se bogadia hisimu;
\q1 badina be iboudiai na Dirava asie matauraiamu,
\q2 iboudiai na kara dika taudia,
\q2 bona udu iboudiai na e hereva kava hereva kavamu.
\q1 Ina idoinai vada e vara, to ena badu do se keru;
\q2 ia imana na doini e hetoi roromu.
\b
\q1 
\v 18 Badina be kara dika na e aramu, lahi na heto;
\q2 ava ḡiniḡini bona au ginigini e aradia oremu.
\q1 Uda audia hedoma-hedomadia e aramu,
\q2 kwalahudia na e daemu.
\q1 
\v 19 Iehova Sabaota ena badu ḡaraḡara dainai
\q2 tano na e aramu;
\q1 taunimanima na au rakuraku na heto,
\q2 asi tauna ta ese tadikakana e bogaia hisimu.
\q1 
\v 20 Idiba kahana ai e dadidadimu, a doini e hitolodiamu;
\q2 lauri kahana ai e anianimu, a bogadia asie kunumu;
\q2 ta ta ese dekena tauna dekena tauna hidiodia e animu.
\q1 
\v 21 Manase ese Efraim e aniamu, bona Efraim ese Manase e aniamu,
\q2 bona raruosi ese Iuda e hadikaiamu.
\q1 Ina idoinai vada e vara, to ena badu do se keru,
\q2 ia imana na doini e hetoi roromu.
\c 10
\q1 
\v 1 Hahedua herevadia dikadia e gwauraimu taudia madi ihabaidia;
\q2 itorena taudia hahehisi herevadia e tore louloumu, madi ihabaidia!
\q1 
\v 2 E dabumu taudia edia amo hahemaoro ḡoevaḡoeva e lao ahumu,
\q2 bona ogoḡami taudia egu bese lalonai ahudia korikori e dadimu;
\q1 edia dadidadi ḡaudia na vabu,
\q2 bona damudia na ihareha.
\q1 
\v 3 Dika davana iabina dinana ai dahaka ba karaia?
\q2 Lai gubana dauha amo bainema negana ai dahaka ba karaia?
\q1 Daika ba heau henia baine kahamu totona?
\q2 Emu taḡa be edeseni ai ba rakatania?
\q1 
\v 4 Dala ta lasi, to e abidia mauri taudia bogaragidiai ba raki,
\q2 eiava e aladia mase taudia bogaragidiai ba moru.
\q1 Ina idoinai vada e vara, to ena badu do se keru,
\q2 ia imana na doini e hetoi roromu.
\s1 Asuria na Iehova ena gahi
\q1 
\v 5 A! Asuria na egu badu auna,
\q2 egu badu-ḡaraḡara gahina.
\q1 
\v 6 Dirava se matauraiamu besena ihadikana totona na siaia laomu;
\q2 na haganiamu, na badu henidiamu taudia na baine hadikadia.
\q1 Baine dadidadi, kohu momo baine dadi;
\q2 baine moimoilaidia, ariara kopukopuna na heto.
\q1 
\v 7 A unu se laloa tomamu,
\q2 ena lalo-hadai na dia unuheto;
\q1 a ena ura be hahebua-tari,
\q2 bese diaḡau baine butudia tao.
\q1 
\v 8 Badina be ia na e tomu:
\q2 Egu tuari lohiadia iboudiai na dia papavapava a?
\q1 
\v 9 Kalano na Karakemisi ida vada e heḡereḡere,
\q2 bona Hamat na Arapada ida vada e heḡereḡere,
\q2 bona Samaria na Damasko ida vada e heḡereḡere, ani?
\q1 
\v 10 Imagu ese kaivakuku ibadinadia basileiadia vada e toi roro henidia,
\q2 edia dirava laulaudia, e koro ḡaudia, na Ierusalem bona Samaria edia e hereadiava gabudia;
\q1 
\v 11 matona, Samaria bona ena dirava laulaudia vada na kara henidia heḡereḡerena ai,
\q2 Ierusalem mai ena kaivakuku ida basina kara henidia a?
\b
\p 
\v 12 Ḡaubada ese ena ḡaukara idoinai Siona Ororona bona Ierusalem latadiai baine ha-orea murinai, ia ese Asuria pavapavana ena hekokoroku herevadiabona ena heaḡi bada-herea daidiai baine hadikaia.
\v 13 Badina be una taue tomamu:
\q1 Lau imagu goadana amo vada na karaia, bona egu aonega amo danu;
\q2 badina be lau na lalo-parara taugu.
\q1 Bese idau-idau edia tano hetoadia vada na abidia oho,
\q2 bona edia kohu namodia vada na dadi;
\q1 bona terono ai e helaiva taudia vada na doridia dobi,
\q2 boromakau maruanena ese bema doadia dobi heḡereḡerena.
\q1 
\v 14 Imagu ese bese idau-idau edia taḡa vada e davaridia,
\q2 tau ta ese manu rumana bema davaria na heto;
\q1 bona manu hahinena ese vada e rakatanidia gatoidia na taunimanima ese e haboudiamu heḡereḡerena ai,
\q2 lau ese tanobada idoinai tagadia vada na haboudia;
\q1 ta ese hanina se hamarereamu,
\q2 eiava uduna se haḡaiamu, eiava se taimu.
\b
\q1 
\v 15 Ira na sibona baine heaḡi, e utu-utulaiamu tauna baine dadaraia a?
\q2 Eiava iri na sibona baine heimodai, e iri-irilaiamu tauna baine dadaraia a?
\q1 Una na au ese e abia isimu tauna bema kwadi-kwadilaia,
\q2 eiava gahi, au ḡauna, ese tau, dia au ḡauna, bema abia isi na heto.
\q1 
\v 16 Taunabunai Ḡaubada, Iehova Sabaota, ese taudia ihavaroda-varodadia gorerena na
\q2 ena tuari taudia goada-hereadia bogaragidiai baine siaia;
\q1 ia hairaina henunai hururu ta baine vara,
\q2 lahi hururuna na heto.
\q1 
\v 17 Israel Diarina na lahi ai bainela;
\q2 ena Helaḡa Diravana na lahi hururu-hururuna ai bainela;
\q1 ena au ḡiniḡini bona ena ava ḡiniḡini baine aradia,
\q2 dina tamona ai baine aradia ore.
\q1 
\v 18 Ena uda bona ena tano namona hairaidia na
\q2 Iehova ese baine habuadia tari, lauma ai bona tau-anina ai;
\q2 gorere tauna e varoda-varodamu heḡereḡerena ai bainela.
\q1 
\v 19 Ena uda audia oredia bae gadoi vaitani dainai,
\q2 mero maraḡina ta ese baine hagaudia diba.
\b
\p 
\v 20 Una dina ai Israel kwabukwabudia bona Iakob iduhuna ena roho-mauri taudia ese idia e rahudia mase tauna enai basie tao lou, a Iehova, Israel ena Helaḡa Diravana, enai bae tao mai momokanidia ida.
\v 21 A kwabukwabudia na bae lou mai, Iakob iduhuna kwabukwabudia, Siahu Diravana bae lou henia.
\v 22 Badina, ena be emu bese Israel na kone mirina na heto, to kwabukwabudia mo bae lou mai. Kara maoromaoro na e hepurai dobimu, una dainai hahebua-tari na vada e hahedualaia.
\v 23 Badina be Ḡaubada, Iehova Sabaota, ese baine haḡuḡurua vaitani, hahedua heḡereḡerena, tanobada idoinai bogaraginai.
\p 
\v 24 Taunabunai Ḡaubada, Iehova Sabaota, na ini e gwau tomamu: Egu bese taumui e, Siona ai o nohomu taumui e, Asuria taudia ese au amo bae rahumui mase bona edia gahi na ihadikamui totona bae abidia isi, Aigupto taudia e karaia heḡereḡerena, negana ai idia garidia basio gari.
\v 25 Badina be asi vanahana egu lalo-siahu baine ore, bona egu badu eseidia ihabua-taridia baine matamaia.
\v 26 Bena Iehova Sabaota ese ikwadiva varona amo baine hadikadia, Midian na Oreb nadi-ginina badibadinai e rahua mase negana heḡereḡerena ai; bona ena itotohi na davara daenai baine he toi roro, bona baine abia isi, Aigupto ai e karaia heḡereḡerena.
\v 27 Una dina ai ena maduna metauna na pagamui amo baine heabi oho, bona ena maduna auna na aiomui amo baine kwaidu oho.
\b
\p Ia na Rimon amo vada e dae lao,
\v 28 Aiata ai vada e kau;
\q1 Migron vada e rakaia hanai, Mikmasa ai ena kohu e habouamu;
\q1 
\v 29 Ororo makana amo vada e hanai,
\q2 Geba ai e taruha rani;
\q1 Rama na e heude-heudemu,
\q2 Gibea, Saulo ena hanua, vada e heau.
\q1 
\v 30 Galimi hahinemu e, a tai badabada!
\q2 Laisa e, a kamonai!
\q2 Anatoto e, a haere henia!
\q1 
\v 31 Madamena na e heaumu;
\q2 Gebimi inoholaina taudia na e heau maurimu.
\q1 
\v 32 Hari ina dina ai, ia na Nob ai baine gini,
\q2 imana baine kahua kuboro-kuboro,
\q1 Siona kekenina ena ororo baine kahu kuboro henia,
\q2 Ierusalem ororona bunai.
\b
\q1 
\v 33 A itaia, Ḡaubada, Iehova Sabaota, ese
\q2 au rigidia baine utu oho, mai siahu herea-daena ida;
\q1 atai ḡaudia na baine utudia gari,
\q2 atai-herea ḡaudia na henu ai bae heato diho.
\q1 
\v 34 Ia ese uda audia hedoma-hedomadia na ira amo baine utudia,
\q2 bona Lebanon mai ena au hereadia ida bae moru.
\c 11
\s1 Iese Rigina
\q1 
\v 1 Iese badina amo
\q2 tuhutuhu ta baine gara kau;
\q1 bona ia ramuna amo
\q2 rigi ta baine tubu.
\q1 
\v 2 Iehova ena Lauma ese baine rohea,
\q2 aonega bona lalo-parara laumana,
\q2 hahealo bona siahu laumana,
\q2 diba-maoro bona Iehova garina laumana.
\q1 
\v 3 Ia ese Iehova garina baine moalelaia.
\b
\q1 Ia na basine hahemaoro, matana e itamu ḡaudia daidiai,
\q2 bona lalona basine hadaia, taiana e kamonaimu herevadia daidiai;
\q1 
\v 4 a mai kara maoromaorona ida ia ese ogoḡami taudia baine hahemaoro henidia,
\q2 bona ia!ona baine hadaia maoro, tanobada ena manau taudia ediai;
\q1 ia uduna auna amo tanobada baine botaia,
\q2 bona uduna bibinadia hodahodana amo kara dika taudia baine aladia mase.
\q1 
\v 5 Kara maoromaoro na ia gabana ḡauna ai bainela,
\q2 bona kara momokani na ia koekoena igegelaina ḡauna ai bainela.
\b
\q1 
\v 6 Uda sisiana na mamoe natuna ida bae noho,
\q2 bona taiga na nani natuna ida bae hekure;
\q1 boromakau natuna bona leona bona ubu-ubu ḡauna na bae noho hebou,
\q2 bona mero maraḡina ta ese baine hakaudia.
\q1 
\v 7 Boromakau hahinena bona bea bae aniani hebou,
\q2 bona natudia bae hekure hebou;
\q1 bona leona ese rei kakoro baine ania,
\q2 boromakau maruanena na heto.
\q1 
\v 8 Rata e inumu merona na gaigai ena guri latanai baine gadara,
\q2 bona rata vada e dadaraia merona ese imana na duba ena guri lalonai baine toia vareai.
\q1 
\v 9 Basie hahehisi bona basie hahebua tari,
\q2 egu ororo helaḡana idoinai ai;
\q1 badina be tanobada na Iehova idiba-maorona ai baine honu,
\q2 davara ena honuhonu-dae na heto.
\b
\m 
\v 10 Una dina ai Iese ramuna baine gini, taunimanima loḡora edia pepe; bese idau-idau ese ia bae tahua, bona ena noho gabudia bae herea dae.
\b
\s1 Kwabukwabudia bae lou mai
\p 
\v 11 Una dina ai Ḡaubada ese nega iharuana imana baine toia roro, ena bese kwabukwabudia iabi-loudia totona: Asuria amo, Aigupto amo, Pataro amo, Etiopia amo, Elam amo, Sinara amo, Hamat amo, bona kone ahadia amo.
\b
\q1 
\v 12 Ia ese pepe ta baine duduia isi, bese idau-idau edia,
\q2 bona Israel ena henege-daure taudia baine haboudia,
\q1 bona Iuda ena karoho taudia baine gogodia
\q2 tanobada daigunidia haniosi amo.
\q1 
\v 13 Efraim ena vagege baine heabi oho,
\q2 bona Iuda ihahisina taudia bae henege daure;
\q1 Efraim ese Iuda basine vagege henia,
\q2 bona Iuda ese Efraim basine hahisia.
\q1 
\v 14 A Filistia taudia edia ororo gabaedia na bae hedai henidia lahara kahana ai;
\q2 bona hebou tamona ai baela, laurabada kahana taudia edia kohu bae dadi.
\q1 Imadia bae toi roro, Edom bona Moab ihadikadia totona;
\q2 bona Amono taudia ese bae kamonai henidia.
\q1 
\v 15 Bena Iehova ese Aigupto davara dogurana baine habuaia tari vaitani,
\q2 bona Sinavai Badana daenai imana baine davea,
\q2 mai ena lai siahuna ida;
\q1 bena baine botaia parara, rege hitu ai baine aru,
\q2 bona taunimanima na bae raka hanai diba, aedia basie paripari.
\q1 
\v 16 Bena laolao dalana ta baine helailai Asuria amo,
\q2 ena bese kwabukwabudia edia;
\q1 Israel ena heḡereḡerena,
\q2 Aigupto tanona amo e raka lasi negana ai.
\c 12
\s1 Hahenamo Anena
\p 
\v 1 Una dina ai baoto:
\q1 Iehova e, lau baina hanamomu,
\q2 badina ena be o badu henigu,
\q1 to emu badu na egu amo o abia oho,
\q2 bona taugu o haloa.
\b
\q1 
\v 2 A itaia, Dirava na lau ihamaurigu;
\q2 baina heabidadama, basina gari;
\q1 badina be Iehova na egu goada bona egu ane,
\q2 ia na ihamaurigu ai vada e hahelao.
\b
\p 
\v 3 Mai moalemui ida ranu na hahemauri guridia amo ba utu.
\v 4 Bona una dinai ai baoto:
\q1 Iehova ba hanamoa,
\q2 ia ladana ba hahanea;
\q1 ena kara na bese idau-idau ba hadibalaidia,
\q2 ba gwauraia hedinarai, ia ladana na herea-dae.
\b
\q1 
\v 5 Iehova ihanamolaina anedia avabi,
\q2 badina be kara hereadia vada e kara,
\q2 tanobada idoinai unu bae diba toma.
\q1 
\v 6 Siona inoholaina taumui, a lolo, moale anedia avabi;
\q2 badina be Israel ena Helaḡa Diravana na bada,
\q2 umui bogaragimui ai.
\c 13
\s1 Maduna metauna Babulono latanai
\p 
\v 1 Maduna metauna Babulono latanai, Isaia Amoso ese e itaia ḡauna.
\b
\q1 
\v 2 Ororo gagaena ai toa ta ba duduia isi,
\q2 ba boi lolo henidia;
\q1 ba kalodia, bae raka vareai,
\q2 lohia edia ikoukou lalodiai.
\q1 
\v 3 Lau sibogu ese egu helaḡa taudia vada na haḡanidia,
\q2 bona egu goada taudia, egu heaḡi herea taudia, vada na boiridia,
\q2 egu badu karadia bae kara totona.
\b
\q1 
\v 4 A hakala, heloḡo-heloḡo na ororo ai,
\q2 hutuma bada reḡedia na heheto.
\q1 A hakala, basileia idau-idau e heloḡo ahu-ahumu,
\q2 e heboumu besedia na e heloḡo-heloḡomu.
\q1 Iehova Sabaota ese tuari oreana ta e habouamu;
\q1 
\v 5 tano daudau amo e maimu,
\q2 bona guba dokona amo,
\q1 Iehova bona ena badu ḡaudia,
\q2 tanobada idoinai ihabua-tarina totona.
\b
\q1 
\v 6 A tai lolololo, badina be Iehova ena dina eme kahikahi;
\q2 ia na do baine kau, Siahu-idoinai Diravana ena hahebua-tari dinana ai bainela.
\q1 
\v 7 Taunabunai, ima iboudiai bae manoka-manoka;
\q2 taunimanima iboudiai kudoudia bae hetaha,
\q2 
\v 8 bona gari ese baine butudia tao.
\q1 Hisihisi ese baine gugubadia, hisihisi badadia;
\q2 idia na hisi bae ani, hahine ena hekamonai hisina na heto.
\q1 Bae heita heheni mai gari badadia ida;
\q2 vairadia bae kakakaka, lahi na heto.
\b
\q1 
\v 9 A itaia, Iehova ena dina e maimu,
\q2 mai dagedagena bona mai baduna ida,
\q2 mai badu ḡaraḡarana ida;
\q1 tanobada na baine havahua,
\q2 bona kara dika taudia na ia latana amo baine habuadia tari.
\q1 
\v 10 Badina be guba hisiudia edia orea lalodiai na basie diari;
\q2 daba ai dina na baine dibura,
\q2 bona hua basine rara.
\q1 
\v 11 Tanobada na ena dika davana baina henia,
\q2 kara dika taudia na edia kara havara davadia baina heni;
\q1 heaḡi taudia edia hekokoroku baina hadokoa,
\q2 bona asi edia hebogahisi taudia edia heaḡi baina hamaraḡia.
\q1 
\v 12 Taunimanima baina hagadoidia:
\q2 idia na bae gadoi, \it gold\it* namo-hereana baine momo;
\q2 idia na bae gadoi, Ofiri gold-na baine momo.
\q1 
\v 13 Taunabunai, guba baina haheude-heudea;
\q2 bona Iehova Sabaota ena badu ese
\q1 tanobada na ena gabu amo baine bibia oho,
\q2 ena badu baine ḡaraḡara dinana ai.
\q1 
\v 14 E labanaiamu diana na heto,
\q2 eiava mamoe asi ireḡudia na heheto,
\q1 taunimanima ta ta ese ena bese taudia ena bese taudia bae haḡeredia,
\q2 bona taunimanima ta ta na ena tano korikori ena tano korikori bae lou lao.
\q1 
\v 15 Bae davaria tauna na bae gwadaia uru,
\q2 bona bae dabaia tao tauna na dare amo bae alaia mase;
\q1 
\v 16 natudia karukarudia na vairadiai bae huaridia,
\q2 edia ruma kohudia bae dadidia,
\q2 bona adavadia bae hadikadia.
\q1 
\v 17 A itaia, lau ese Mede taudia lalodia baina hasiahudia, bae hadikadia totona;
\q2 idia na \it silver\it* asie laloamu, bona \it gold\it* asie moalelaiamu.
\q1 
\v 18 Edia peva ese eregabe taudia bae aladia mase;
\q2 hahine bogadia anidia na basie hamauridia;
\q2 matadia ese memero bona kekeni na basie bogadia hisi.
\q1 
\v 19 Babulono danu, basileia herea-daena,
\q2 Kaldea taudia edia hairai bona edia heaḡi ḡauna,
\q1 na Sodoma bona Gomora heḡereḡeredia ai bainela,
\q2 Dirava ese e habuadia tari negana ai.
\q1 
\v 20 Haida ese basie noho henia,
\q2 bona basie noholaia ela bona uru iboudiai;
\q1 Arabia tauna ta unuseni ai basine taruha,
\q2 bona mamoe ireḡudia taudia haida ese edia seri basie hahekuredi: unuseni ai.
\q1 
\v 21 A uda boromadia na unuseni ai bae hekure,
\q2 rumadia na e ḡoumu ḡaudia ai bae honu;
\q1 unuseni ai kokokoko bae noho,
\q2 bona huika-huika ḡaudia na unuseni ai bae mavaru.
\q1 
\v 22 Tano ḡaḡaena sisiadia na kohorodia ai bae turo,
\q2 bona uda sisiadia danu lohia rumadia lalodiai;
\q1 ena nega vada eme kahikahi,
\q2 bona ena dina na basie hoho.
\c 14
\s1 Babulono pavapavana iḡonaḡonalaina
\p 
\v 1 Iehova ese Iakob baine bogaia hisi bona Israel baine abia hidi lou; edia tano korikori ai baine atodia lou, bena idau bese taudia na idia ida bae tamona, Iakob besena enai bae tao.
\v 2 Bena unu bese taudia ese bae abidia, edia gabu korikori bae mailaidia; bena Israel taudia ese bae abidia, Iehova ena tano ai, edia hesiai taudia bona hahinedia ai bae halaodia; e abidia mauriva taudia na idia ese bae abidia mauri, bona e hahisidiava taudia na idia ese bae biagudia.
\p 
\v 3 Iehova ese emui hisihisi bona emui hekwarahi bona emui hesiai-laoheniaukana amo laḡa-ani baine henimui negana ai,
\v 4 umui ese ina Babulono pavapavana iḡonaḡonalaina anena ba ladaia isi:
\q1 A itaia! Hahehisi tauna vada e doko,
\q2 heaḡi baduna vada e ore.
\q1 
\v 5 Iehova ese kara dika taudia edia itotohi vada e hakwaidua,
\q2 bona pavapava edia dagi auna danu.
\q1 
\v 6 Ia ese mai baduna ida bese idau-idau taudia e rahudia mase asi dokona;
\q2 ia ese mai baduna ida basileia idau-idau taudia e biagudia,
\q2 e hahisidia, se bogadia hisi.
\q1 
\v 7 Tanobada idoinai e laḡa animu, asi reḡereḡena;
\q2 idia ese ane e ladaia isimu.
\q1 
\v 8 Beroso\f + \fr 14:8 \ft “Beroso” na au ta ladana, Heberu gado ai.\f* audia na oi daimu ai e moalemu,
\q2 bona Lebanon sida audia danu, e tomu,
\q1 Oi o moru negana ema bona hari,
\q2 au-utu tauna ta na ai ihadikamai se maimu.
\q1 
\v 9 Mase Gabuna na e marere-mareremu henumai ai,
\q2 oi ihedavari-henimu totona;
\q1 mase laulaudia na e haodiamu,
\q2 oi ihahenamo-henimu totona,
\q2 tanobada ena hegunalai taudia laulaudia iboudiai;
\q1 basileia idau-idau pavapavadia iboudiai na
\q2 edia terono amo e hatoredia isimu.
\q1 
\v 10 Iboudiai bae hereva,
\q2 bae hamaoromu, baeto,
\q1 Oi danu vada o manoka-manoka, ai bamomai;
\q2 oi na ai heḡereḡeremai ai vada ola.
\q1 
\v 11 Oi hairaimu na Mase Gabuna ai vada e hadihoa,
\q2 emu hatai-hatai ḡaudia reḡedia danu;
\q1 uloulo na emu hekure gedana,
\q2 bona biluga na emu hetaru.
\b
\q1 
\v 12 Daba hisiuna, daba-matana natuna,
\q2 guba amo vada o moru!
\q1 Basileia idau-idau o hamorudia taumu,
\q2 tano ai vada e hamorumu!
\q1 
\v 13 Lalomu ai oto:
\q2 Guba ai baina dae,
\q1 Dirava ena hisiu daediai,
\q2 atai ai egu terono baina hadaia;
\q1 hebou ororona ai baina helai,
\q2 dauhai, mirigini kahana ai;
\q1 
\v 14 lau na atai oridia daediai baina dae,
\q2 Herea Mikamika heḡereḡerena ai baina hahelao.
\q1 
\v 15 A oi na Mase Gabuna ai vada e hadihomu,
\q2 mase gurina ena dobu gabudia ai.
\q1 
\v 16 Bae itamu taudia bae raraimu tao,
\q2 bona bae haerolaimu, baeto:
\q1 Ina na tanobada e haheude-heudea
\q2 bona basileia idau-idau e hamareredia tauna a?
\q1 
\v 17 Ina be tanobada na tano ḡaḡaena ai e halaoa,
\q2 bona ena hanua badadia e ḡiḡidia dobi,
\q2 bona e ḡuidia taudia se kahudia nege tauna a?
\q1 
\v 18 Bese idau-idau pavapavadia iboudiai na hairai ai e hekuremu,
\q2 ta ta ena gara ena gara ai;
\q1 
\v 19 a oi na emu gara amo vada e negemu daudau,
\q2 vara-dika merona, taunimanima ese e dadaraiamu ḡauna, na heto,
\q1 dare ai e mase taudia na emu hetaru,
\q2 Mase Gurina ena dobu gabudia nadidia ai
\q2 mase tau-anina e moimoilaiamu na heto.
\q1 
\v 20 Oi na idia ida basie gurimui hebou,
\q2 badina be emu tano vada o havahua,
\q2 bona emu bese taudia vada o aladia mase.
\b
\q1 Kara dika taudia vevedia ladadia na
\q2 basie hato lou ela bona hanaihanai.
\q1 
\v 21 Natuna iala-masedia dalana ba lailaia,
\q2 tamadia edia kerere daidiai,
\q1 bae tore isi bena tanobada bae ḡaunaia
\q2 bona tanobada kopina na hanua badadia amo bae hahonua na garina.
\b
\p 
\v 22 Iehova Sabaota na e tomu, Lau na ihadikadia totona baina tore isi Iehova na e tomu, Lau ese ladana bona kwabukwabuna, natuna bona garana na Babulono amo baina negedia daure.
\v 23 Iehova Sabaota na e tomu, Lau ese migu ena gabu bona gohugohu gabuna ai baina halaoa, bona hahebua-tari idarona amo baina daroa.
\b
\s1 Asuria baine darere
\p 
\v 24 Iehova Sabaota vada e gwau hamata, eto:
\q1 Vada na laloa hata heḡereḡerena,
\q2 unu baine vara toma;
\q1 bona vada na lalo-hadailaia heḡereḡerena,
\q2 unu baine gini toma.
\q1 
\v 25 Lau ese Asuria tauna na egu tano ai baina huaria,
\q2 bona egu tano ororodia ai baina moimoilaia;
\q1 ena maduna na edia amo baine heabi oho,
\q2 bona ena maduna metauna idia paḡadia amo danu.
\q1 
\v 26 Lalo-hadai binai vada e lalo-hadailaiamu,
\q2 tanobada idoinai dainai;
\q1 e toia roromu imana binai,
\q2 basileia iboudiai daediai.
\q1 
\v 27 Badina be Iehova Sabaota ese vada e lalo-hadailaia,
\q2 bena daika ese baine utua?
\q1 Ia imana vada eme hetoi roro,
\q2 bena daika ese baine haloua?
\b
\s1 Maduna metauna Filistia latanai
\p 
\v 28 King Ahasa ena mase laḡanina ai ina maduna metauna herevana e kau:
\q1 
\v 29 Filistia taumui iboumui ai, basio moale,
\q2 e rahumui mase auna vada e kwaidu dainai;
\q1 badina be gaigai ramuna amo duba ta baine vara,
\q2 bona huahuana baine dobi, roho gaigaina ta.
\q1 
\v 30 Ogoḡami tauna natuna roboana baine aniani,
\q2 bona e dabumu tauna baine hekure diho mai namona ida;
\q1 a lau ese ramumu na doe amo baina hamasea,
\q2 bona emu taunimanima kwabukwabudia baina aladia mase.
\q1 
\v 31 Ikoukou e, a tai! Hanua badana e, a tai lolololo;
\q2 Filistia taumui iboumui ai, gari ese kudoumui baine hahetahadia!
\q1 Badina be tuari kwalahuna na mirigini amo e lasi e maimu,
\q2 bona tuari oreana ai tau ta se halahemu.
\q1 
\v 32 Basileia ena gwaukau taudia na
\q2 ede bae haere henidia toma?
\q1 Iehova ese Siona vada e hadaia,
\q2 bona ia lalonai ena hisihisi taudia ese mauri bae davaria.
\c 15
\s1 Maduna metauna Moab latanai
\p 
\v 1 Maduna metauna Moab latanai:
\q1 Ara na hanuaboi tamona ai vada e havahua dainai,
\q2 Moab na vada e baia;
\q1 Kiri na hanuaboi tamona ai vada e havahua dainai,
\q2 Moab na vada e baia.
\q1 
\v 2 Dibon natuna kekenina vada e dae lao,
\q2 atai gabudia ai baine taitai totona;
\q1 Nebo bona Medeba latadiai,
\q2 Moab na e tai lolololomu.
\q1 Kwara iboudiai vada e naudia,
\q2 auki iboudiai huidia vada e abi;
\q1 
\v 3 ariara ai puse dabuadia e riomu;
\q2 ruma guhidia ai bona hanua bogaragidiai danu
\q1 taunimanima iboudiai na e tai lolololomu,
\q2 bona taitaidia ai taudia e manokamu.
\q1 
\v 4 Hesebon bona Eleale e lolomu,
\q2 gadodia na e kamonaimu ela bona Iahasa;
\q1 taunabunai, Moab ena tuari taudia na e tai badabadamu,
\q2 laumadia na e dauremu.
\q1 
\v 5 Moab dainai lalogu na e taimu,
\q2 ena heau-mauri taudia na e heaumu
\q2 ela bona Soara ela bona Eglata-selisia;
\q1 badina be Luhiti dae-lao dalana ai,
\q2 mai taitaidia ida e dae laomu;
\q1 bona Horonaimi dalana ai,
\q2 hahebua-tari dainai e taitaimu.
\q1 
\v 6 Nimirimi ranu-gabudia vada e kororo,
\q2 rei vada e marai, bona matamatadia se tubumu;
\q2 tano ai e varamu ḡaudia iboudiai vada e ore.
\q1 
\v 7 Taunabunai edia taḡa idoinai
\q2 bona vada e habou ḡaudia iboudiai
\q1 e huadia hanaimu,
\q2 Arabimi Sinavaina unukahana ai.
\q1 
\v 8 Badina be Moab tanona hegegemadai ai,
\q2 taitai na vada ela;
\q1 taitai reḡedia na e laomu ela bona Eglaimi,
\q2 e laomu ela bona Bere-elim.
\q1 
\v 9 Badina be Dibon ranu gabudia na rara ai e honumu,
\q2 ḡau tamona Dibon ena hisi ma baina habadaia;
\q1 leona ta baina siaia Moab amo e roho maurimu taudia ediai,
\q2 bona tano taudia kwabukwabudia ediai.
\c 16
\q1 
\v 1 Idia ese mamoe natudia vada e siaidia,
\q2 tano lohiana dekenai,
\q1 Sela amo, tano ḡaḡaena dalana ai,
\q2 ela bona Siona natuna kekenina ena ororo.
\q1 
\v 2 Manu e roho eva-evamu na heto,
\q2 manu natudia e hakarohodiamu na heto,
\q1 Moab hahinedia na unuheto,
\q2 Aranon turu-hanai gabudia ai.
\q1 
\v 3 Ba hahealo,
\q2 hahemaoro ḡoevaḡoeva ba karaia;
\q1 ikerukerumu na dina tubua ai ba ha-udunaia,
\q2 hanuaboi diburana na heto.
\q1 Vada e luludia lasi taudia ba hunidia,
\q2 e heau maurimu tauna taona basio torea.
\q1 
\v 4 Moab amo e luludia lasi taudia na
\q2 bogaragimui ai bavabidia dae;
\q1 hahebua-tari tauna imana amo
\q2 iharoho-mauridia gabuna ai baola.
\q1 Negana bainema, hahehisi tauna baine boio,
\q2 bona hahebua-tari baine doko,
\q1 bona ae-hemoimoilai karadia e karamu tauna na
\q2 tano amo baine puki;
\q1 
\v 5 una negana ai terono ta na hebogahisi ai baine gini,
\q2 ia latanai heabidadama tauna ta baine helai,
\q2 David ena kalaga ai,
\q1 hahemaoro e karaiamu bona hahemaoro ḡoevaḡoeva e tahuamu
\q2 bona kara maoromaoro ikarana ai e haraḡamu tauna.
\b
\q1 
\v 6 Moab ena heaḡi sivaraina vada ta kamonai,
\q2 ena hekokoroku na dibada;
\q1 e hekokorokumu, e heaḡimu, e gwau daḡemu,
\q2 ena heaḡi herevadia na koikoi.
\q1 
\v 7 Taunabunai, Moab taudia bae tai lolololo,
\q2 bona taunimanima iboudiai na Moab dainai bae tai.
\q1 A tai, mai dara-dokomui ida,
\q2 Kiri-haresete ena vine huahua kaukaudia manedia ba tailaidia.
\q1 
\v 8 Badina be Hesebon umadia na e maraimu,
\q2 bona Sibma vinena danu;
\q1 basileia idau-idau lohiadia ese
\q2 ia rigina vada e bokodia;
\q1 unu rigi na e laova ela bona Iasere,
\q2 e loava ela bona tano ḡaḡaena;
\q1 ia tuhutuhuna na e tubu rohorohova,
\q2 davara e hanaiava.
\q1 
\v 9 Taunabunai Iasere ida a taitaimu,
\q2 Sibma vinena taina a taimu.
\q1 Hesebon bona Eleale e,
\q2 iruru-matagu amo na hapariparimuimu;
\q1 badina be tuari honena vada e kau,
\q2 emui huahua bona emui taboro latadiai.
\q1 
\v 10 Moale bona lalo-namo na
\q2 uma mai anina amo vada eme heabi oho;
\q1 bona vine imeadia lalodiai
\q2 ane asie abimu bona asie hisi daemu;
\q1 vine itaolaidia gabudia ai tau ta ese vine se moimoilaimu,
\q2 bona ta se hisi daemu.
\q1 
\v 11 Taunabunai, Moab dainai lalogu e taimu, hatai-hatai ḡauna na heto,
\q2 bona Kiri-herese danu dainai.
\b
\p 
\v 12 Moab baine hedinarai, atai gabuna ai baine hekwarahi, ena gabu helaḡana ai baine ḡuriḡuri negana ai ḡau ta basine davaria.
\p 
\v 13 Nega gunadia ai Iehova ese Moab na unu e herevalaia toma.
\v 14 A harihari Iehova na e tomu, Ena be Moab taudia na hutuma herea, to laḡani toi, ḡaukara tauna ena gwauhamata laḡanidia heḡereḡeredia, lalodiai Moab hairaina na heihi-ihirai ḡauna ai bainela; bopa bae mauri taudia na baegadoi bona taudia bae manoka.
\c 17
\s1 Maduna metauna Damasko latanai
\p 
\v 1 Maduna metauna Damasko latanai:
\q1 A itaia, Damasko hanuana baine vahu,
\q2 nadi hesenudia ai bainela.
\q1 
\v 2 Hanuadia bae mia ḡaḡae ela bona hanaihanai,
\q2 mamoe seridia edia gabu ai baela;
\q1 mamoe na unuseni ai bae hekure,
\q2 bona tau ta ese basine hagaridia.
\q1 
\v 3 Efraim kohorona baine puki oho,
\q2 bona Damasko basileiana danu;
\q1 Suria taudia kwabukwabudia danu bae boio,
\q2 Israel taudia hairaidia vada e boio heḡereḡerena.
\q2 Iehova Sabaota unu e gwau tomamu.
\b
\s1 Israel ihahemaoro-henina
\q1 
\v 4 Una dina ai, Iakob hairaina na baine maraḡi,
\q2 bona tau-anina baine varoda-varoda;
\q1 
\v 5 uit iutuna tauna ese e ginimu uitina e habouamu
\q2 bena ia imana ese uit anidia e utumu na heto,
\q1 eiava uit anidia momorudia
\q2 Refaim kourana ai e gogomu na heto.
\q1 
\v 6 Momorudia do bae mia,
\q2 olive auna e kwadiamu negana ai na heto;
\q1 huahua rua eiava toi
\q2 atai rigina dorina ai e miamu
\q1 eiava hani eiava ima
\q2 huahua auna rigina ai e miamu na heto.
\q2 Iehova, Israel Diravana, unu e gwau tomamu.
\b
\p 
\v 7 Una dina ai taunimanima ese Ikaradia Diravana na bae laloa, bona matadia ese Israel ena Helaḡa Diravana bae haḡerea;
\v 8 ihaboulaina patadia, imadia amo e kara ḡaudia, na basie lalodia; bona ima-kwakikwakidia amoe kara ḡaudia, Asera ena au-tubua helaḡadia eiava muramura mai bonadiapatadia, na basie haḡeredia.
\p 
\v 9 Una dina ai edia goada hanuadia na Hivi taudia bona Amoro taudia edia hanua ahutudia, Israel taudia daidiai e rakatanidia gabudia, heḡereḡeredia ai baela, bona tano na baine vahu.
\b
\q1 
\v 10 Badina be ihamaurimu Diravana vada o laloa boio,
\q2 bona ihahemetaimu Nadi-ginina so laloa taomu;
\q1 taunabunai, ena be herahera namodia
\q2 bona dirava idauna ena uhe helaḡadia ba hado,
\q1 
\v 11 ena be ba hado dinana ai ba hatubudia
\q2 bona ba hado dabana ai anidia ba havaradia,
\q1 to anidia na bae puki,
\q2 lalo-hisihisi bona asi ihanamona hisina dinana ai.
\b
\q1 
\v 12 Aha! Taunimanima hutuma reḡedia,
\q2 davara hurehuredia gurudia na heheto.
\q1 Aha! Basileia idau-idau reḡedia,
\q2 e heloḡo-heloḡomu, ranu badadia gurudia na heheto.
\q1 
\v 13 Basileia idau-idau taudia na e heloḡo-heloḡomu,
\q2 ranu momo gurudia na heheto,
\q1 a ia ese baine gwau henidia,
\q2 bena dauha bae heau lao;
\q1 lai ese momoru na ororo ai e hoda ohomu na heto,
\q2 eiava lai-gubana ese ḡahu e hodaia isimu na heto.
\q1 
\v 14 A itaia, adorahi ai gari bada-herea!
\q2 Daba do se reremu, idia na lasihidia!
\q1 Ina na eda ḡau e abi ohomu taudia ahudia;
\q2 ina na eda kohu e dadi ohomu taudia davadia.
\c 18
\s1 Etiopia herevana
\q1 
\v 1 Aha! Manu hanidia gurudia tanona,
\q2 Etiopia sinavaidia unukahadia ai;
\q1 
\v 2 ena gwaukau taudia na revareva vanagidia ai e siaidiamu,
\q2 Nilo sinavaina amo.
\q1 Gwaukau taumui mai haragamui e, aola,
\q2 taudia lalata bona kopidia mamanada-mamanada besena dekediai,
\q2 gabu kahikahidia bona gabu daudaudia ai e gari heniamu oreana dekenai;
\q1 una bese na mai siahuna bona mai kwalimuna,
\q2 ena tano na sinavai ese e hapararaiamu.
\b
\q1 
\v 3 Tanobada inoholaina taumui iboumui ai,
\q2 tanobada latanai o nohomu taumui e,
\q1 toa ta ororo ai bae duduia isi negana ai, ba itaia!
\q2 Kibi ta bae hiriria negana ai, ba kamonai!
\q1 
\v 4 Badina be Iehova ese ini e hereva henigu toma, eto:
\q2 Egu noho gabuna amo baina roharoha, asi reḡereḡegu;
\q1 dina e taramu siahuna na heto,
\q2 ninoa taboro negana siahuna ai na heto.
\q1 
\v 5 Badina be taboro negana do basine kau ai,
\q2 bure vada e marai bona vine huahuana e magemu negana ai,
\q1 ia ese kwama-kwama kaiadia amo baine kwamadia,
\q2 bona e hetoi lasimu rigidia baine lapa oho.
\q1 
\v 6 Iboudiai bae mia,
\q2 ororo manudia, damudia e tahumu ḡaudia, adia,
\q2 bona tano boromadia adia.
\q1 Siahu negana ai damudia e tahumu manudia ese bae anidia,
\q2 bona keru negana ai tano boromadia iboudiai ese.
\b
\p 
\v 7 Una negana ai haida ese edia herahia ḡaudia bae mailai, Iehova Sabaota ena.
\q1 Taudia lalata bona kopidia mamanada-mamanada oreana,
\q2 gabu kahikahidia bona gabu daudaudia ai e gari heniamu oreana.
\q1 bese mai siahuna bona mai kwalimuna,
\q2 ena tano na sinavai ese e hapararaiamu besena,
\m ese Siona ororona, Iehova Sabaota ladana e nemaiamu gabuna, bae maila.
\c 19
\s1 Maduna metauna Aigupto latanai
\p 
\v 1 Maduna metauna Aigupto latanai:
\q1 A itaia, Iehova na ori heiruna ai e guimu,
\q2 Aigupto ai e kaumu.
\q1 Aigupto kaivakukudia na ia vairanai bae heude-heude,
\q2 Aigupto taudia na bae lalaḡa.
\q1 
\v 2 Bena lau ese Aigupto taudia lalodia baina hasiahudia,
\q2 bae hahedika heheni, bae heatu heheni,
\q1 ta ta tadikakana tadikakana ida,
\q2 ta ta dekena tauna dekena tauna ida,
\q1 hanua ta hanua ta ida,
\q2 basileia ta basileia ta ida.
\q1 
\v 3 Aigupto taudia laumadia bae daure;
\q2 edia lalo-hata ḡaudia baina laodia ahu.
\q1 Idia ese kaivakuku bona babalau taudia bae nanadaidia,
\q2 bona rohe taudia bona mea taudia danu.
\q1 
\v 4 Bena lau ese Aigupto taudia na
\q2 biagu aukana ta imana ai baina atodia;
\q1 bona pavapava ta mai dagedagena ese baine lohiadia.
\q2 Ḡaubada, Iehova Sabaota, unu e gwau tomamu.
\b
\q1 
\v 5 Nilo sinavaina ranudia bae kororo,
\q2 sinavai baine kororo bona baine haurahaura;
\q1 
\v 6 e gei dadairadia ranudia bae bodaga,
\q2 bona Aigupto ena Sinavai Badana reḡedia bae kororo bona bae haurahaura,
\q2 bona geda bona bota na bae pata rohoroho.
\q1 
\v 7 Nilo sinavaina badibadina tanodia bae ḡaḡae,
\q2 Nilo sinavaina isena tanodia;
\q1 Nilo sinavaina isena ai e hadomu ḡaudia iboudiai na bae marai,
\q2 lai ese baine hodadia oho, baine ha-oredia.
\q1 
\v 8 Haoda taudia na bae taitai, bae hahane,
\q2 Nilo sinavaina ai e kimaimu taudia iboudiai;
\q2 bona reke e toremu taudia na lalodia bae hisihisi.
\q1 
\v 9 Dabua aukadia e hatumu taudia daradia bae doko,
\q2 bona dabua kurokurodia e hatumu taudia danu.
\q1 
\v 10 Tano lohiadia na bae taodia tari,
\q2 bona e gaukaramu mai davadia taudia na lalodia bae hisihisi.
\b
\q1 
\v 11 Soan lohiadia na kavakava herea;
\q2 Farao ena aonega taudia ese hahealo kavakavadia e gwauraimu.
\q1 Farao na ede ba hamaoroa toma, baoto
\q2 “Lau na aonega tauna natuna, pavapava gunadia garadia”?
\q1 
\v 12 Emu aonega taudia na edeseni ai?
\q2 Bae hadibamu bona bae gwaurai hedinarai,
\q2 Iehova Sabaota ese Aigupto ede baine kara henia toma.
\q1 
\v 13 Soan lohiadia na kavakava taudia ai vada ela,
\q2 Memefisi lohiadia na vada e hekoi;
\q1 ena iduhu daiguni-nadidia ese
\q2 Aigupto vada e hakaua kerere.
\q1 
\v 14 Iehova ese daradara na ia bogaraginai vada e havaraia;
\q2 Aigupto na vada e hararagaia ena kara iboudiai lalodiai,
\q2 e kekeromu tauna na mumutana ai e raragamu na heto.
\q1 
\v 15 Aigupto enai ḡau ta basine hekara,
\q2 kwara eiava iu, reta eiava geda, ese bema karaia diba ḡauna.
\b
\p 
\v 16 Una dina ai, Aigupto taudia na hahine heḡereḡeredia ai baela; bona Iehova Sabaota ese imana na idia daediai baine davedavea negana ai, idia na ia vairanai bae heude-heude mai garidia ida.
\v 17 Iuda tanona na gari ḡauna ai bainela Aigupto taudia ediai; bae herevalai henidia taudia iboudiai na bae gari, lalo-hadai, Iehova Sabaota ese idia ihadikadia e lalo-hadailaia, dainai.
\p 
\v 18 Una dina ai, Aigupto hanuadia badadia ima lalodiai Kanaan gadona ai bae hereva, bona edia gwauhamata na Iehova Sabaota bae henia. Ta ladana bae hatoa Dina Hanuana.
\p 
\v 19 Una dina ai, Iehova ena ihaboulaina patana ta na Aigupto tanona bogaraginai baine mia, bona Iehova ena au-tubua ta na ena tano hetoana ai baine gini.
\v 20 Una na Iehova Sabaota toana ai bona ihahedinaraina ḡauna ai bainela, Aigupto tanona ai. Ihahisidia taudia daidiai idia ese Iehova bae tai henia negana ai, ia ese ihamauridia tauna ta na dekedia baine siaia lao; baine gimadia bona baine hamauridia.
\v 21 Bena Iehova ese Aigupto taudia baine hahedinarai henidia.
\p Una dina ai, Aigupto taudia bae diba Iehova, bona bae toma henia diho mai kara helaḡadia bona ḡole-oho bouboudia ida, bona Iehova enai baegwau hamata, bena edia gwauhamata bae hamomokanidia.
\v 22 Bena Iehova ese Aigupto taudia baine rahudia mase; baine rahudia mase ma baine hamauridia. Idia ese Iehova bae lou henia; bena ia ese edia noinoi baine kamonai, bona baine hamauridia.
\p 
\v 23 Una dina ai, laolao dalana baine helailai, Aigupto amo ela bona Asuria. Asuria tauna na Aigupto bainela, bona Aigupto tauna na Asuria bainela; bona Aigupto taudia bona Asuria taudia bae toma diho hebou.
\p 
\v 24 Una dina ai, Israel na Aigupto bona Asuria ida bae hebou, bena orea toiosi na hahenamo ḡauna ai baela, tanobada bogaraginai.
\v 25 Iehova Sabaota ese vada e hanamodia, eto, Egu orea Aigupto, bona imagu amo na karaia ḡauna Asuria, bona dihigu Israel, na bae namo.
\c 20
\s1 Asuria ese Aigupto bona Etiopia baine hadareredia
\p 
\v 1 Tuari lohiana Saragono, Asuria pavapavana ese e siaia mai tauna, na Asdod ema, e tuari henia, bena e abia.
\v 2 (Una negana ai, Iehova ese Isaia Amoso enai vada e hereva, eto, Aola, puse dabuana ba dokia oho, bona emu tamaka na aemu amo ba kokidia oho. Bena ia na unu e kara toma, asi dabuana bona aena asi tamakana vada e loaloava.)
\v 3 Una laḡani lalonai Iehova eto, Egu hesiai tauna Isaia na laḡani toi lalodiai asi dabuana bona aena asi tamakana vada e loaloa, Aigupto bona Etiopia ihadikadia toana bona gwarena;
\v 4 una heḡereḡerena ai, Asuria pavapavana ese Aigupto taudia baine abidia mauri, baine hakaudia lao, bona Etiopia taudia na baine laohaidia, basie lou - eregabedia bona burukadia danu, asi dabuadia bona aedia asi tamakadia bona asi sihidia, Aigupto ihahemaraina.
\v 5 Bena bae dara doko bona bae baia, edia helaro ḡauna Etiopia bona edia heaḡi ḡauna Aigupto daidiai.
\v 6 Bena una dina ai ina kone tanona taudia baeto: A itaia, ina na vada e vara, ta helaro henidia, bona bae duruda, Asuria pavapavana ena amo bae hamaurida, totona ta heau henidia, taudia ediai. Matogana, ita na ede baita roho mauri toma?
\c 21
\s1 Maduna metauna tano ḡaḡaena latanai
\p 
\v 1 Maduna metauna tano ḡaḡaena, davara kahana ḡauna, latanai;
\q1 Koe-hirihiri na diho kahana amo e daro e maimu na heto,
\q2 ia na tano ḡaḡaena amo e maimu,
\q2 tano dika amo e maimu.
\q1 
\v 2 Mata-hanai aukana vada e hahedinarai henigu:
\q2 dadidadi tauna ese e dadidadimu,
\q2 hahebua-tari tauna ese e hahebua tarimu.
\q1 Elam e, a dae lao!
\q2 Media e, a hahegegea ahu!
\q1 Ḡanaḡana idoinai ia ese vada e havaraia na
\q2 lau ese na hadokoamu.
\q1 
\v 3 Taunabunai, koekoegu e hisihisi hereamu;
\q2 hisi ese e gugubagumu,
\q2 hahine ena hekamonai hisidia na heheto.
\q1 Lau na e ha-igogu dihomu dainai asina kamonaimu;
\q2 kudougu e hahetahaiamu dainai asina heitamu.
\q1 
\v 4 Daragu e dokomu, gari ese e butugu taomu;
\q2 adorahi vaburana na hekise-hekise henia,
\q2 to ia na egu heude-heude negana ai vada ela.
\q1 
\v 5 Pata e dabaraiamu, geda e tahomu;
\q2 e anianimu bona e muinumu.
\s1 Lohia taumui e, a tore isi;
\q2 kesi na ba dehorodia.
\q1 
\v 6 Badina be Ḡaubada ese ini e hamaorogu toma:
\q2 Aola, gima tauna bavatoa;
\q2 e itaiamu ḡauna na baine gwauraia hedinarai.
\q1 
\v 7 Gui taudia baine itadia, hosi-gui taudia rarua rarua amo,
\q2 bona doniki-gui taudia bona kamelo-gui taudia danu;
\q1 una negana ai baine hakala balaheni,
\q2 baine hakala balaheni-balaheni.
\q1 
\v 8 Bena e roharoha tauna na e boi lolo, eto:
\q2 Ḡaubada e, gima kohorona ai na ginimu, dina idoinai;
\q2 bona egu gima gabuna ai na hegimamu, hanuaboi idoidiai.
\q1 
\v 9 A itaia, gui taudia na e maimu,
\q2 hosi-gui taudia, rarua rarua amo.
\q1 Bena ia na e haere, eto:
\q2 Babulono vada e moru, vada e moru;
\q1 ena dirava laulaudia iboudiai na
\q2 ia ese vada e huaridia kohi tano ai.
\q1 
\v 10 Bamogu e, e kwadimu bona e tapomu taumu e,
\q2 Iehova Sabaota, Israel Diravana, ena amo vada na kamonai ḡauna na
\q2 oi na hahedinarai henimumu.
\b
\s1 Maduna metauna Duma latanai
\p 
\v 11 Maduna metauna Duma latanai:
\q2 Ta ese Seiri amo e boi henigumu, e tomu:
\q2 Gima taumu, hanuaboi be edeheto?
\q2 Gima taumu, hanuaboi be edeheto?
\q1 
\v 12 Gima tauna e tomu:
\q2 Daba na e maimu, a hanuaboi danu ma bainema;
\q1 bema henanadai o uramu, vada ba henanadai,
\q2 ma ba lou mai.
\b
\s1 Maduna metauna Arabia latanai
\p 
\v 13 Maduna metauna Arabia latanai:
\q1 Dedan laolao hebou oreana taumui e,
\q2 Arabia uda hedoma-hedomadia lalodiai ba taruha.
\q1 
\v 14 Ranu ba mailaia,
\q2 ranu-mase tauna ba henia;
\q1 Tema tanona inoholaina taumui e,
\q2 flaoa bavabia kau,
\q2 heau-mauri tauna ba hedavarilai henia.
\q1 
\v 15 Badina be dare amo vada e heau,
\q2 e veria lasi darena amo,
\q1 e marea pevana amo,
\q2 bona tuari siahuna amo.
\b
\p 
\v 16 Badina be Ḡaubada ese ini e hamaorogu toma: Laḡani tamona lalonai, ḡaukara tauna ena gwauhamata laḡanina na heto, Kedara hairaina idoinai baine ore:
\v 17 bona Kedara garana bogaragidiai goada taudia edia peva taudia oredia bae gadoi; badina be Iehova, Israel Diravana, vada e hereva.
\c 22
\s1 Maduna metauna mata-hanai kourana latanai
\p 
\v 1 Maduna metauna mata-hanai kourana latanai:
\b
\q1 
\v 2 Heloḡo-heloḡo hanuana, moale hisidae hanuana,
\q2 o lalo heboumu taumui e!
\q1 Emui lalo-hadai be dahaka, bena vada o dae,
\q2 iboumui ai ruma guhidia ai vada o dae kau?
\q1 Emui mase taudia na dare amo asie aladia,
\q2 eiava tuari ai asie mase.
\q1 
\v 3 Emui lohia iboudiai nega tamona vada e heau karoho;
\q2 asi edia peva taudia ese e abidia mauri.
\q1 E davarimui taumui, ena be haida e heau daudau,
\q2 to iboumui ai e abimui mauri.
\q1 
\v 4 Taunabunai lau nato:
\q2 Basio haḡeregu, baina tai lalo dika;
\q1 egu bese hane-ulatona vada e habuaia tari,
\q2 taugu ihalona basio gugulaia.
\b
\q1 
\v 5 Badina be Ḡaubada, Iehova Sabaota, na mai ena dina,
\q2 heloḡo-heloḡo bona raka gurudia bona daradara dinana
\q2 mata-hanai kourana lalonai,
\q1 magu iḡiḡi-dobidia
\q2 bona ororo ilolo-henidia dinana.
\q1 
\v 6 Elam ese diba pauana e abia kau,
\q2 bona Aram na hosi ai e gui,
\q2 bona Kiri ese kesi e abia heḡaeḡae.
\q1 
\v 7 Emu koura namo-hereadia na kariota ese e hahonudia,
\q2 bona hosi-gui taudia na ikoukou ai e gini.
\q1 
\v 8 Ia ese Iuda ena maḡu vada e abia oho.
\b
\p Una dina ai, tuari ḡaudia Uda Rumana lalonai o haḡeredia;
\v 9 bona David ena hanua maḡuna o itaia, gabu momo vada e heḡiḡi dobi; bona henu gohuna ranudia o haboudia;
\v 10 bona Ierusalem rumadia o duahidia, bena ruma na o haheḡiḡidia dobi, maḡu iha-aukana totona.
\v 11 Ranu ihabouna gabunana maḡu ruaosi padadiai o karaia, gohu gunana ranuna ihabouna. A ikarana tauna asio haḡerea, bona idau nega ai e laloa hata tauna na asio kamonai henia.
\b
\q1 
\v 12 Una dina ai Ḡaubada, Iehova Sabaota, ese e boi henidia,
\q2 bae taitai bona bae lalo hisihisi,
\q2 kwaradia bae nau bona puse dabuadia bae rio.
\q1 
\v 13 To, a itaia, moale bona hisi-dae,
\q2 boromakau bona mamoe ialadia,
\q2 vamu ianina bona vine ranuna i'inuna.
\q1 “Aita aniani bona aita inuinu,
\q2 badina be kerukeru baita mase.”
\q1 
\v 14 Iehova Sabaota ese vada e hahedinarai henigu,
\q2 taiagu ai vada e hereva, eto:
\q1 Ina emui kara havara na basine hegwau tao ela bona ba mase.
\q2 Ḡaubada, Iehova Sabaota, na unu e gwau tomamu.
\b
\s1 Eliakimi ese Sebna gabuna baine abia
\p 
\v 15 Ḡaubada. Iehova Sabaota, ini e gwau tomamu: Aoma, hari rum; ireguna tauna Sebna dekena baola, ba hamaoroa, baoto:
\v 16 Gara na ata gabuna ai vada o ḡeiamu bona emu noho gabuna na haga-nadina ai o utuamu taumu e, iniseni ai dahaka o karamu, bona iniseni ai daika na dekemu a bena gara gabuna na iniseni ai vada o ḡeia sibomu emu a?
\v 17 Goada taumu e, a itaia, Iehova ese baine negemu daure mai dagedagena ida. Ia ese baine dabaimu tao,
\v 18 bena baine davemu heḡeḡe-heḡeḡe, bolo na heto, tano mai lababana lalonai; unuseni ai ba mase, bona unuseni ai emu kariota, ḡoeva-daedia bae mia, biagumu ena ruma ihahemaraina taumu e!
\v 19 Emu dagi amo baina dorimu lasi, emu ḡaukara gabuna amo ba henege dobi.
\v 20 Una dina ai, lau ese egu hesiai tauna Eliakim Hilkia baina boiria,
\v 21 oiemu dabua amo baina hadabualaia, oiemu gaba ḡauna amo baina ḡeḡelaia, bona oiemu siahu na ia imana ai baina atoa. Bena ia na Ierusalem inoholaina taudia bona Iuda iduhuna taudia tamadia ai bainela.
\v 22 David ena ruma kina na ia paḡana ai baina atoa; ia ese baine kehoa, bena ta ese basine koua; ia ese baine koua, bena ta ese basine kehoa.
\v 23 Ikoko e kokoa kaumu na heto baina kokoa kau, gabu aukana ai; bena ia na hairai teronona ai bainela, tamana ena iduhu lalonai.
\v 24 Tamana ena iduhu metauna idoinai na ienai baine hetau dae, garana bona vevena idoinai, uda-uda ḡaudia maraḡidia iboudiai, kebere amo e dae ela bona bio iboudiai.
\v 25 Iehova Sabaota na e tomu: Una dina ai gabu aukana ai e kokoa kau ikokona baine heraḡa; bena bae utua dobi, bena baine moru; bena ia latanai e miava madunana baine henege daure, badina be Iehova vada e hereva.
\c 23
\s1 Maduna metauna Turo bona Sidono latadiai
\p 
\v 1 Maduna metauna Turo latanai:
\q1 Tarasisi lagatoidia e, ba taitai;
\q2 badina be Turo vada e havahua,
\q2 asi rumana bona asi hetu gabuna.
\q1 Kupro tanona amo
\q2 vada e hahedinarai henidia.
\q1 
\v 2 Kone taumui e, eremui!
\q2 Sidono hoihoi taumui e, eremui!
\q1 Emui gwaukau taudia na gadobada e hanaia,
\q2 
\v 3 davara idau-idau momo ai e laolao;
\q1 emui habou-habou ḡaudia na Sihoro uitina,
\q2 bona Nilo tanona anianidia;
\q2 umui na bese idau-idau edia hoihoi taudia.
\q1 
\v 4 Sidono e, ba hemarai; badina be davara vada e hereva,
\q2 davara ena gabu aukana vada e hereva, eto:
\q1 Asina hekamonai, bona asina mara;
\q2 uhau asina ubudia bona ulato rami-heboudia asina regudia.
\q1 
\v 5 Ina hari na Aigupto ai baine kau negana ai,
\q2 lalodia bae hisihisi herea, Turo harina dainai.
\q1 
\v 6 Tarasisi enai ba hanai;
\q2 kone taumui e, ba taitai!
\q1 
\v 7 O moalelaia hisi dae hanuana,
\q2 nega gunadia ai e hadaia hanuana,
\q1 aena amo ela bona gabu daudau ai ma e noho
\q2 hanuana binai a?
\q1 
\v 8 Turo, havava ḡaudia ihenidia hanuana;
\q2 ena kohu-hoi taudia na lolohia,
\q1 ena hoihoi taudia na tanobada ese e heatolaidiamu;
\q2 daika ese ia ihadikana na ini e lalo hadailaia tomamu?
\q1 
\v 9 Iehova Sabaota ese e lalo hadailaia,
\q2 e heaḡilaiamu hairaina idoinai baine hamiroa totona,
\q2 tanobada ai e matauraidiamu taudia iboudiai baine hahemaraidia totona.
\q1 
\v 10 Tarasisi hahinemu e,
\q2 emu tano ba da'ania, Nilo sinavaina na heto;
\q2 asi ilao-ahumu dalana ta mia.
\q1 
\v 11 Ia ese imana vada e toia roro, davara daenai;
\q2 basileia vada e haheude heudedia.
\q1 Iehova vada e haheḡani Kanaan dainai,
\q2 ena gabu aukadia bae habuadia tari.
\q1 
\v 12 Ia eto: Sidono hane-ulato rami-hebouna e,
\q2 e hahisimumu kekenimu e,
\q2 basio moale hisi dae lou.
\q1 A tore isi, Kupro enai ba hanai,
\q2 a unuseni ai danu basio laḡa ani diba.
\p 
\v 13 Kaldea tanona a itaia; besena bunai, dia Asuria. Turo na uda boromadia edia gabu ai bae halaoa eto. Idia ese tano na hanuana e lareba henia: ena lohia rumadia e haheḡiḡidia dobi, bona hanuana e habuaia tari.
\q1 
\v 14 Tarasisi lagatoidia e, a taitai;
\q2 badina be emu gabu aukana vada e havahua.
\p 
\v 15 Una dina ai, Turo na bae laloa boio ela bona laḡani hitu-ahui bae? ore, hanua pavapavana ta ena nega heḡereḡerena. Bena laḡani hitu-ahui dokona ai, kara ta Turo enai baine vara, ariara hahinena anena lalonai na heto:
\q1 
\v 16 Ariara hahinemu e,
\q2 vada e lalomu boio.
\q1 Gitara avabia,
\q2 hanua lalonai ba loa eva-eva;
\q1 ba hataia gaiho-gaiho,
\q2 ane momo bavabi,
\q2 bae lalomu tao helaoreana.
\p 
\v 17 Laḡani hitu-ahui dokona ai, Iehova ese Turo baine vadivadi heni? bena ena hehoi-nege karana baine lou henia, bona basileia iboudiai tanobada kopina ai ediai baine hehoi nege.
\v 18 Ena hoihoi ḡaudia bona davana na baine hahelaḡadia, Iehova ena; basine haboudia bona basine gogosidia; a ena hoih? ḡaudia ese Iehova vairanai e nohomu taudia na bae ubudia bona bae hadabua-laidia aniani momo bona dabua namo-hereadia danu.
\c 24
\s1 Iehova ese tanobada baine hahemaoro henia
\q1 
\v 1 A itaia, Iehova ese tanobada baine havahua,
\q2 tano ḡaḡaena ai baine halaoa;
\q1 ia ese tano kopina baine harigika-rigikaia,
\q2 bona inoholaina taudia baine hakarohodia rohoroho.
\q1 
\v 2 Hanua taudia ediai baine vara heḡereḡerena ai,
\q2 hahelaḡa tauna enai danu;
\q1 bona hesiai tauna enai heḡereḡerena ai,
\q2 biaguna enai danu;
\q1 bona hesiai kekenina enai heḡereḡerena ai,
\q2 biaguna hahinena enai danu;
\q1 bona kohu e hoiamu tauna enai heḡereḡerena ai,
\q2 davana e abiamu tauna enai danu;
\q1 bona heni-doa tauna enai heḡereḡerena ai,
\q2 abi-doa tauna enai danu;
\q1 bona heni-torehai tauna enai heḡereḡerena ai,
\q2 abi-torehai tauna enai danu.
\q1 
\v 3 Tanobada na baine havahua vaitani bona baine habuaia tari ḡuḡuru,
\q2 badina be Iehova ese ina hereva vada e gwauraia.
\b
\q1 
\v 4 Tanobada na e taitaimu bona e maraimu,
\q2 tanobada na e hisihisimu bona e maraimu,
\q2 guba bona tanobada na e hisihisi heboumu.
\q1 
\v 5 Tanobada na vada e miro,
\q2 inoholaina taudia daidiai;
\q1 badina be idia ese taravatu vada e tata utu,
\q2 bona hahedua herevadia vada e hadikadia,
\q2 bona mia-hanaihanai gwauhamatana vada e dadaraia.
\q1 
\v 6 Una dainai heuduguirai ese tanobada e hadonoamu,
\q2 bona inohoiaina taudia na edia kara dika daidiai e hisihisimu;
\q1 una dainai tanobada inoholaina taudia na lahi ese e aradiamu,
\q2 bona kwabukwabudia mo e nohomu.
\q1 
\v 7 Vine ranuna e taitaimu,
\q2 vine auna e hisihisimu,
\q2 lalodia e moaleva taudia na e ḡanaḡanamu.
\q1 
\v 8 Tareko reḡedia vada e ore,
\q2 hisi-dae taudia eredia vada e doko,
\q2 gitara moalena vada e ore.
\q1 
\v 9 Vine ranuna i'inuna ai ane asie abimu;
\q2 kekero ḡauna vada e idita, i'inuna taudia ediai.
\q1 
\v 10 Hanua asi oromana na vada eme heḡiḡi dobi;
\q2 ruma iboudiai vada eme hekou, tau ta basine raka vareai helaoreana.
\q1 
\v 11 Ariara ai e heloḡo-heloḡo, vine-ranuna lasi dainai;
\q2 moale idoinai e vaburamu,
\q2 tanobada moalena vada e puki oho.
\q1 
\v 12 Hanua na vada e habuaia tari;
\q2 ikoukou na vada e hamakohidia rohoroho.
\q1 
\v 13 Badina be tanobada bogaraginai unu baine vara toma,
\q2 bese idau-idau bogaragidiai,
\q1 olive auna e ureamu negana na heto,
\q2 eiava vine anidia e habou vaitanimu bena momorudia e gogomu negana na heto.
\b
\q1 
\v 14 Ane e lada isimu, moale dainai ane e abimu;
\q2 lahara kahana amo Iehova hairaina e heatolaiamu.
\q1 
\v 15 Una dainai laurabada kahana ai Iehova ba imodaia,
\q2 bona kone tanodia ai danu Iehova, Israel Diravana, ladana ba imodaia.
\q1 
\v 16 Hahenamo anedia ta kamonaimu, tanobada dokodia amo e maimu,
\q2 heimodai anedia, Kara Maoromaoro Diravana ena.
\q1 A lau na tomamu “Daragu e doko e laomu,
\q2 daragu e doko e laomu, madi, ihabaigu;
\q1 badina be kara dibaka taudia na e kara dibakamu;
\q2 oibe, kara dibaka taudia na e kara dika hereamu.”
\b
\q1 
\v 17 Tanobada inoholaina taumu e,
\q2 gari bona guri bona idoa na latamu ai be kaumu.
\q1 
\v 18 Hahegari guruna e kamonaimu bena e heaumu tauna na
\q2 guri lalonai baine moru dobi;
\q1 bona guri amo e rau daemu tauna na
\q2 idoa ese baine idoaia.
\q1 Badina be guba iduaradia eme hekeho,
\q2 bona tanobada badidia vada e heude-heudemu.
\q1 
\v 19 Tanobada na e makohi rohorohomu,
\q2 tanobada na e hedare pararamu,
\q2 tanobada na e heude-heude dikadikamu.
\q1 
\v 20 Tanobada na e raragamu, kekero tauna na heto;
\q2 e marere-mareremu, kalaga na heto.
\q1 Ena kara dika na metau, ia latanai e miamu;
\q2 ia na e morumu, basine tore isi lou.
\b
\q1 
\v 21 Una dina ai, Iehova ese dika davana baine henidia,
\q2 guba oreana guba ai,
\q2 bona tanobada pavapavadia tanobada ai.
\q1 
\v 22 Baine haboudia,
\q2 abi-mauri taudia guri lalonai na heheto;
\q1 dibura rumana ai baine koudia,
\q2 bena dina hoho muridiai edia dika davadia baine henidia.
\q1 
\v 23 Hua baine baia,
\q2 bona dina baine hemarai;
\q1 badina be Iehova Sabaota baine lohia,
\q2 Siona ororona ai bona Ierusalem ai;
\q1 bona ia hairaina baine hahedinaraia,
\q2 ena rahobada vairadiai.
\c 25
\s1 Iehova ihanamolaina anena ta
\q1 
\v 1 Iehova e, oi na egu Dirava;
\q2 baina imodaimu, oi ladamu baina hanamoa;
\q1 badina be oi ese kara hereadia vada o kara,
\q2 gunaguna o lalo hatalai karadia,
\q2 heabidadama karadia bona kara momokanidia.
\q1 
\v 2 Badina be hanua na vada o hasenua,
\q2 hanua mai maḡuna na vada o ḡiḡia dobi;
\q1 idau taudia edia pavapava rumana na hanua ta ai basie gwauraia lou.
\q2 basie haginia lou ela bona hanaihanai.
\q1 
\v 3 Taunabunai, goada besedia ese bae imodaimu;
\q2 asi edia hebogahisi besedia hanuadia ese oi garimu bae gari.
\q1 
\v 4 Badina be oi na ogoḡami tauna ena gabu aukana ema bona hari,
\q2 e dabumu tauna ena gabu aukana ena hisihisi ai,
\q1 hemetai gabuna lai gubana amo,
\q2 bona ikerukeru gabuna siahu amo;
\q1 badina be asi edia hebogahisi taudia edia badu na
\q2 lai gubana ese haba e hohoamu na heto,
\q2 
\v 5 eiava siahu ḡaraḡarana tano kaukauna ai na heto.
\q1 Oi ese idau taudia edia heloḡo-heloḡo o tuiamu;
\q2 siahu na ori ese e hakerukeruamu na heto,
\q2 asi edia hebogahisi taudia edia ane na unu o tuia tomamu.
\b
\s1 Iehova ena ororo
\p 
\v 6 Ina ororo ai Iehova Sabaota ese aria namo-hereana baine karaia, beseboudiai adia: vine-ranuna negarina, aniani gaihodia, vine-ranuna asi nurinurina.
\v 7 Ina ororo ai danu ia ese bese iboudiai e ḡovadia ahumu, bona basileia boudiai e sese-ahulaidiamu, ḡauna baine habuaia tari.
\v 8 Ia ese mase baine a-orea ela bona hanaihanai; Ḡaubada Iehova ese irurumata na vaira iboudiai amo baine dahu oho, bona ena bese taudia edia hemarai na tanobada idoinai amo baine abia oho; badina be Iehova vada e hereva.
\p 
\v 9 Una dina ai, idia na baeto: A itaia, ina na eda Dirava; vada ta naria, baine hamaurida helaoreana. Ina na Iehova; vada ta naria; baita moale, ena hahenamo baita moalelaia.
\p 
\v 10 Badina be Iehova imana na ina ororo latanai baine hetao kau; bona Moab na ena gabu ai baine moia tao, rei kakoro na boromakau tagedia e haboumu gurina ai e hemoi taomu na heto.
\v 11 Bogaraginai, ia imana baine toi roro, nahu tauna ese imana e toi roromu na heto. A Iehova ese ena hekokoroku bona ena ima-dibaka baine hamaraḡidia.
\v 12 Ena maḡu gabudia aukadia na ia ese baine ḡiḡidia dobi, baine hamorudia, tano ai baine tahodia dobi, ḡahu ai baine taodia tari.
\c 26
\s1 Iehova ena hereḡu anena
\p 
\v 1 Una dina ai, ina ane na Iuda tanona ai bae abia:
\q1 Ita na mai eda hanua aukana;
\q2 ia ese ena hahemauri e haginiamu,
\q2 maḡu ai bona imuda ai e halaoamu.
\q1 
\v 2 Ikoukou a kehodia,
\q2 bena kara maoromaoro besena mai ena heabidadama na baine raka vareai.
\q1 
\v 3 Lalona ese oi e badinamumu tauna na
\q2 oi ese maino ḡoeva-daena ai o hanohoamu,
\q2 badina be ia ese oi e abidadama henimumu.
\q1 
\v 4 Iehova bavabidadama henia hanaihanai,
\q2 badina be Iehova na mia-hanaihanai nadi-ginina.
\q1 
\v 5 Badina be ia ese atai hanuana inoholaina taudia
\q2 vada e hamorudia.
\q1 E hamoruamu, e hamoruamu ela bona tano ai,
\q2 ḡahu ai e negea dobi.
\q1 
\v 6 Ae ese e moia taomu,
\q2 ogoḡami taudia aedia ese,
\q2 e dabumu taudia aedia palapaladia ese.
\b
\q1 
\v 7 Kara maoromaoro tauna ena raka dalana na e hedaga maoro;
\q2 oi ese kara maoromaoro tauna ena dala o hamanadaiamu.
\q1 
\v 8 Iehova e, ai ese a narimumu,
\q2 emu hahemaoro daladia ai,
\q1 oi ilalolaimu ladana na
\q2 laumamai ese e ura heniamu ḡauna.
\q1 
\v 9 Hanuaboi ai lalogu ese e hekise-hekise henimumu;
\q2 laumagu ese e tahumu malaka-malakamu.
\q1 Badina be emu hahemaoro herevadia na tanobada ai e miamu negadia a
\q2 tanobada inoholaina taudia ese kara maoromaoro e dibaiamu.
\q1 
\v 10 Kara dika tauna bema lalo namo henia,
\q2 to ia ese kara maoromaoro basinema dibaia;
\q1 kara maoromaoro tanona ai ia na e kara gageva-gagevamu,
\q2 bona Iehova hairaina se itaiamu.
\q1 
\v 11 Iehova e, oi imamu e heabi isimu,
\q2 a idia na asie itaiamu.
\q1 Emu uraheni emu bese taudia ediai na bema itaia, bena bema hemarai;
\q2 oi inaimu iaradia lahina ese bema aradia ore.
\q1 
\v 12 Iehova e, oi ese emai maino na emu hereva amo ba haginia;
\q2 emu ḡaukara iboudiai oi ese vada o kara ai daimai ai.
\q1 
\v 13 Iehova e, emai Dirava,
\q2 lohia idaudia ese vada e lohiamai,
\q2 a oi ladamu mo a abia daemu.
\q1 
\v 14 Idia vada e mase, basie mauri;
\q2 idia na laulau mo, basie tore isi;
\q1 una totona oi ese hahebua-tari na latadiai vada o siaia,
\q2 bona idia ilalo-taolaidia daladia iboudiai vada o rohodia.
\q1 
\v 15 A bese taudia vada o hahutumadia;
\q2 Iehova e, bese taudia vada o hahutumadia;
\q1 idia ese e imodaimumu;
\q2 tano hetoadia iboudiai vada o habadadia.
\q1 
\v 16 Iehova e, hisihisi ai oi e tahumu;
\q2 emu mata-hakani na latadiai e kau negana ai,
\q2 idia ese e ḡanaḡana henimu;
\q1 
\v 17 rogorogo hahinena na heto,
\q2 ena mara negana vada e kahikahi ai,
\q1 ena hekamonai hisidia ai e hebiloumu,
\q2 bona e ḡanaḡanamu.
\q1 Iehova e, ai danu unuheto, oi daimu ai;
\q2 
\v 18 ai na a rogorogo, a hebilou,
\q2 to asi anina, lai na heto.
\q1 Tanobada ai tau ta asia hamauria,
\q2 bona tanobada inoholaina tauna ta se vara, ai daimai ai.
\q1 
\v 19 Emu mase taudia bae mauri,
\q2 tau-anidia bae tore isi.
\q1 Ḡahu ai o nohomu taumui e, a noga!
\q2 Moale anedia bavabi.
\q1 Badina be emu hunu na diari hununa;
\q2 oi ese mase laulaudia edia tano ai ba hadihoa.
\b
\q1 
\v 20 Egu bese taumui e, emui daiutu ai ba raka vareai,
\q2 iduaramui ba kou;
\q1 nega taina ba komu,
\q2 ela bona badu baine ore.
\q1 
\v 21 Badina be, a itaia, Iehova na ena gabu amo e raka lasimu,
\q2 tanobada inoholaina taudia edia dika davadia baine henidia totona;
\q1 tanobada ese ia latanai vada e hebubu rarana na baine hahedinaraia,
\q2 bona ena mase taudia basine ḡovadia ahu lou.
\c 27
\s1 Israel ihamaurina
\p 
\v 1 Una dina ai Iehova ese ena dare aukana bona badana bona goadana amo \it Leviathan\it*, e rau laomu gaigaina, \it Leviathan\it*, e veromu gaigaina, davana baine henia; bona davara hualana na baine alaia mase.
\q1 
\v 2 Una dina ai,
\q2 vine imeana namo-hereana anena bavabia.
\q1 
\v 3 Lau Iehova na ia ireḡuna,
\q2 nega idoinai na dairiamu.
\q1 Hanuaboi ai bona dina ai na gimaiamu,
\q2 ta ese bema hadikaia na garina;
\q2 
\v 4 lau na asi egu badu.
\q1 Au ginigini bona ava ḡiniḡini bema mia,
\q2 lau ese bama tuari henidia;
\q1 ihadikadia totona bama tore isi,
\q2 bama doudia ore.
\q1 
\v 5 Eiava egu hegima lalonai bema vareai,
\q2 lau ida baiama herohemaino,
\q2 lau ida baiama herohemaino.
\b
\q1 
\v 6 Dina gabedia ai, Iakob ramuna baine hekara,
\q2 Israel baine gara kau, tuhutuhuna na bae tubu,
\q2 huahuana na tanobada idoinai bae hahonua.
\b
\q1 
\v 7 Vada e rahudia mase, irahu-masedia taudia e rahudia mase heḡereḡerena a?
\q2 Eiava vada e aladia mase, iala-masedia taudia e aladia mase heḡereḡerena a?
\q1 
\v 8 Taidia taidia amo dauhai iatodia ai o heai henidia;
\q2 ena lai goadana amo e odadia oho, laurabada e toa dinana ai.
\q1 
\v 9 Taunabunai, ini amo Iakob ese ena kerere baine davalaia,
\q2 ena dika iabi-ohona anina momokanina binai:
\q1 ia ese ihaboulaina patadia nadidia iboudiai na
\q2 nadi maḡiḡidia, vada e makohi sisisisi ḡaudia,
\q2 heḡereḡeredia ai baine halaodia;
\q1 bona Asera ena au-tubua ta eiava muramura mai bonadia patana ta basine hamiaia.
\q1 
\v 10 Badina be hanua mai maḡuna vada e ḡaḡae,
\q2 ruma ahutuna, vada e rakatania ḡauna, na heto,
\q2 eiava tano ḡaḡaena na heto.
\q1 Boromakau natuna unuseni ai e anianimu,
\q2 unuseni ai e hekuremu, rigi raudia e animu.
\q1 
\v 11 Rigi e kaukaumu e kwaidumu negana ai,
\q2 hahine na e maimu, edia au rakuraku ai e halaodiamu.
\q1 Badina be ina bese taudia na asi edia lalo-parara,
\q2 taunabunai ikaradia Diravana ese basine bogadia hisi,
\q2 bona oromadia e henidia Diravana ese basine lalo namo henidia.
\b
\p 
\v 12 Una dina ai, Iehova ese uit baine kwadia, Eufrate sinavaina amo ela bona Aigupto Dokana. Bona umui, Israel taumui e, umui na ta ta amo baine haboumui kau.
\v 13 Una dina ai, kibi badana bae hiriria; bena Asuria tanona ai e boio taudia bona Aigupto tanona e luludia lao taudia na baema, Ierusalem ena ororo tubuana ai Iehova bae toma henia diho.
\c 28
\s1 Efraim isisiba-henina
\q1 
\v 1 Efraim ena kekero taudia kwaradia ihavavalaidia ḡaudia na hekokoroku; madi, ihabaidia!
\q2 Vine ranuna e inu kekeromu taudia edia koura namona kwarakauna, ihahairaina ḡauna na e maraimu heraherana, madi, ihabaina!
\q1 
\v 2 A itaia, Ḡaubada enai ta na mai siahuna bona mai goadana;
\q2 medu-hetarina na heto, lai-gubana mai hahebua-tari na heto,
\q1 sinavai abatana e aru goadagoadamu na heto;
\q2 ia ese tano ai baine negea dobi mai daḡedaḡena ida.
\q1 
\v 3 Efraim ena kekero taudia kwaradia ihavavalaidia heaḡina na
\q2 aedia henudiai bae moia tao;
\q1 
\v 4 Bona ia hairaina heraherana, koura namona kwarakauna ai e maraimu ḡauna,
\q2 na suke huahuana ta, huahua negana do se kau ai e mage gunamu
\q2 ḡauna, na heto;
\q1 ta ta ese e itaiamu,
\q2 bena imana ai e abiamu negana ai e ania haraḡamu.
\b
\q1 
\v 5 Una dina ai, Iehova Sabaota na kwara-havava ḡauna mai hairaina ai bainela,
\q2 bona herahera ḡauna herea-daena danu, ena bese taudia kwabukwabudia edia;
\q1 
\v 6 hahemaoro ḡoevaḡoeva laumana ai bainela, hahemaoro tauna enai,
\q2 bona goada ai bainela, tuari na hanua ikoukouna amo e halouamu taudia ediai.
\b
\s1 Ierusalem isisiba-henina
\q1 
\v 7 Ini danu vine ranuna dainai e laigo-laigomu,
\q2 kekero ḡauna dainai e raragamu:
\q1 hahelaḡa tauna bona peroveta tauna na kekero ḡauna dainai e laigolaigomu;
\q2 vine ranuna dainai lalodia e heḡonumu,
\q2 kekero ḡauna dainai e raragamu;
\q1 matadia e madai-madaimu,
\q2 hahemaoro ikarana ai e gwau rea gwau reamu.
\q1 
\v 8 Badina be pata iboudiai na mumuta ai e honumu,
\q2 bona asi mirona gabuna ta dia mia.
\b
\q1 
\v 9 Ia ese aonega na daika baine hadibalaia?
\q2 Ia ese gwaukau herevana anina na daika baine hamaorolaia?
\q1 Rata vada e dadaraia memerodia a?
\q2 Sinadia kemedia amo vada e abidia oho memerodia a?
\q1 
\v 10 Badina be taidia taidia amo bae hadibadia;
\q2 sidia sidia taidia taidia amo,
\q2 iniseni ai taina, unuseni ai taina.
\b
\q1 
\v 11 Lasi, idau mala taudia edia amo,
\q2 bona idau gado taudia edia amo,
\q1 Iehova ese ina bese baine hereva henia.
\q2 
\v 12 Ia ese vada e hamaorodia, eto
\q1 “Ina na laḡa-ani,
\q2 tau-boera taudia na laḡadia ba ha-ani;
\q1 ina na doru-heu”.
\q2 Ḡau tamona, idia na asie ura bae kamonai.
\q1 
\v 13 Taunabunai, Iehova ena hereva idia ediai na
\q2 taidia taidia amo;
\q1 sidia sidia taidia taidia amo,
\q2 iniseni ai taina, unuseni ai taina.
\q1 Idia na baela, bae hekidaera;
\q2 bae hehuari, bae he-idoa, bena bae abidia.
\b
\q1 
\v 14 Taunabunai, umui heḡonaḡonalai taumui,
\q2 Ierusalem ai ina bese o lohiaiamu taumui,
\q2 Iehova ena hereva ba kamonai.
\q1 
\v 15 Badina be umui oto: Ai na mase ida vada a gwauhamata heheni,
\q2 bona Mase Gabuna ida vada a herohemaino;
\q1 una dainai hahedika na abata na heto baine utu utu dae neganai,
\q2 to ia na ai emai ai basine kau;
\q1 badina be koikoi na emai roho-mauri gabuna ai vada a halaoa,
\q2 bona koikoi herevadia ai vada a hemetaimu.
\q1 
\v 16 Taunabunai, Ḡaubada Iehova na ini e gwau tomamu:
\q2 A itaia, Siona ai badi ta na atoamu;
\q1 nadi ta, e tohoa nadina,
\q2 daiguni nadina ḡoeva-daena, badi nadina momokanina.
\q2 Baine abia dae tauna basine haraḡa-haraḡa.
\q1 
\v 17 Hahemaoro ḡoevaḡoeva na hahetoho varona ai baina halaoa,
\q2 bona kara maoromaoro na gini-maoro varona ai baina halaoa;
\q1 bena koikoi ai o roho maurimu gabuna na medu-hetari ese baineha-arua oho,
\q2 bona abata ese hemetai gabuna baine utua dae.
\q1 
\v 18 Bena emui gwauhamata, mase ida, baine heḡiḡi rohoroho;
\q2 bona emui herohemaino, Mase Gabuna ida, basine gini;
\q1 bena hahedika na abata na heto baine utu utu dae negana ai,
\q2 ia ese baine habubunimui.
\q1 
\v 19 Baine utu utu dae negadia iboudiai na baine abimui;
\q2 badina be daba ta ta amo baine utu utu dae,
\q1 dina ai bona hanuaboi ai danu,
\q2 bena gwaukau herevana anina idavarina na mai gari-badana.
\q1 
\v 20 Badina be mahuta ḡauna na kwadogi,
\q2 hekure tauna basine hetoi roro;
\q1 bona hetaru na iora,
\q2 hetaru tauna basine hetaru namonamo.
\q1 
\v 21 Badina be Iehova baine tore-isi, Perasimi ororona ai heḡereḡerena;
\q2 bona baine badu, Gibeon kourana ai heḡereḡerena;
\q1 ena kara ikarana totona (ena kara na idau),
\q2 ena ḡaukara ikarana totona (ena ḡaukara na idau).
\q1 
\v 22 Taunabunai, basio ḡonaḡona,
\q2 iḡuimui baine ha-aukadia na g=arina;
\q1 badina be hahebua-tari e hahedualaia herevana vada na kamonai.
\q1 Ḡaubada, Iehova Sabaota, ena amo, tano idoinai latanai.
\b
\q1 
\v 23 Taiamui a hakiraradia, gadogu a kamonai;
\q2 a hakala, egu hereva a kamonai.
\q1 
\v 24 Hadohado totona tano e ruaiamu tauna ese e ruaia louloumu a?
\q2 Ena tano e ruaia louloumu bona e gaua louloumu a?
\q1 
\v 25 Tano kopina vada e hamanadaia negana ai,
\q2 ia ese aniani avadia e hadomu;
\q1 bona uit danu ere ta ta ai,
\q2 bona bali ena gabu korikori ai,
\q2 bona rae uma isedia ai, ani?
\q1 
\v 26 Badina be vada e hadibaia maoromaoro;
\q2 ena Dirava ese e hadibaiamu.
\b
\q1 
\v 27 Aniani avadia na uit ikwadilaina auna amo asie kwadidiamu,
\q2 eiava rerue ava-keikeina na idia latadiai asie keia hanaimu;
\q1 a au maraḡina amo e kwadidiamu,
\q2 au severa-severana amo e kwadidiamu.
\q1 
\v 28 Flaoa ikaralaina uitina e ririamu a?
\q2 Lasi, se kwadia louloumu.
\q1 Ena rerue ava-keikeina na hosi ese ia latanai e veria hanaimu,
\q2 a se ririamu.
\q1 
\v 29 Ina danu Iehova Sabaota ena amo e maimu;
\q2 hahealo ai ia na namo herea,
\q2 bona aonega ai ia na herea dae.
\c 29
\s1 Ierusalem inaidia
\q1 
\v 1 Ariele\f + \fr 29:1 \ft “Ariele” na Ierusalem ladana ta.\f* e, Ariele e!
\q2 David ese e noholaia hanuana e!
\q1 Laḡani ta laḡani ta murina amo bainema,
\q2 aria na edia nega ta ta ai bae hekara.
\q1 
\v 2 A Ariele baina hahisihisia,
\q2 bae ḡanaḡana, bae tai lolololo;
\q1 ia na ihaboulaina patana rahurahuna heḡereḡerena ai bainela lauegu ai.
\q1 
\v 3 Lau ese baina hataruhamu heḡeḡe,
\q2 kohoro amo baina hadaimu ahu,
\q2 bona tano baina larebaia, oi ihadikamu.
\q1 
\v 4 Bena tano lalona amo ba hereva,
\q2 ḡahu lalona amo emu hereva bainema;
\q1 oi gadomu na tano lalona amo bainema, laulau gadona na heto:
\q2 oi eremu na ḡahu amo baine hemaunu.
\b
\q1 
\v 5 Inaimu bae hutuma, tano ḡahuḡahuna na heto;
\q2 bona asi edia hebogahisi taudia bae hutuma, uit momorudia lai ese e oda ohomu na heto.
\q1 Bena davadavana ai
\q2 
\v 6 Iehova Sabaota ese baine vadivadi henimu taku,
\q1 guba-rahu bona tano-laga bona rege-bada ida,
\q2 bona koe-hirihiri bona lai-gubana bona lahi siahuna hururu-hururunaida.
\q1 
\v 7 Bena Ariele e tuari heniamu besedia loḡora iboudiai,
\q2 ia bona ena gabu aukana e tuari henidiamu bona e hahisihisidiamu besedia iboudiai,
\q2 na nihi eiava hanuaboi mata-hanaina heḡereḡerena ai baela.
\q1 
\v 8 Hitolo tauna na heto, e nihimu bena ena nihi ai e anianimu,
\q2 a mai hitolona ida e nogamu;
\q1 eiava ranu-mase tauna na heto, e nihimu bena ena nihi ai ranu e inumu,
\q2 a mai manorina bona mai ranu-masena ida e nogamu,
\q1 Siona ororona e tuari heniamu besedia loḡora iboudiai na
\q2 unu mo bae heto.
\b
\s1 Israel ena mata-kepulu bona ena koikoi
\q1 
\v 9 Sibomui ba hahekavakava, bena mai kavakavamui ida ba noho;
\q2 sibomui matamui ba hakepulu, bena mai mata-kepulumui ida banoho.
\q1 Ba kekero, a dia vine-ranuna dainai;
\q2 ba raraga, a dia kekero ḡauna dainai.
\q1 
\v 10 Badina be Iehova ese mahuta-hedavauhe laumana na latamui ai vadae seia kau;
\q2 peroveta taudia matadia vada e hakapudia,
\q2 emui mata-hanai taudia kwaradia vada e ḡovadia ahu.
\b
\p 
\v 11 Ina mata-hanai idoinai na vada e koua ahu bukana herevadia heḡereḡeredia ai vada ela, emui ai. Taunimanima ese duahia-duahi mai dibana tauna ta e heniamu, e tomu “Ina na a duahia”, negana ai, ia na e tomu “Basina duahia diba, badina be vada e hekou ahu”.
\v 12 Bena buka na asi duahi-duahi dibana tauna ta e heniamu, e tomu “Ina na a duahia”, negana ai, ia na e tomu “Duahi-duahi asi dibagu”.
\v 13 Bena Ḡaubada eto:
\q1 Badina be ina bese taudia na mai udu-herevadia ida mo e rakahenigu kahimu,
\q2 bona bibinadia amo mo e imodaigumu,
\q2 a lalodia na dauhai;
\q1 bona taunimanima edia haheḡani mo e abia dae kavamu dainai,
\q2 idia ese lau garigu e garimu.
\q1 
\v 14 Taunabunai, lau ese hoa karadia badadia ma baina kara lou ina bese enai;
\q2 hoa karadia, hoa bada karadia;
\q1 bona edia aonega taudia edia aonega baine ore vaitani,
\q2 bona edia lalo-parara taudia edia lalo-parara baine hehuni.
\b
\q1 
\v 15 Edia hahealo na Iehova ena amo e hunia balahenimu taudia, madi ihabaidia!
\q2 Edia kara dika na dibura ai e karamu, e tomu,
\q2 Daika ese e itadamu? Daika ese e dibadamu?
\q1 
\v 16 Umui ese ḡau o karuhi hebubumu!
\q2 Uro ikarana tauna na raro bae gwauraia a?
\s1 E karaia ḡauna ese ikarana tauna baine herevalaia,
\q2 baineto “Ia ese asine karagu”, a?
\q1 Eiava oromana e henia ḡauna ese oromana ihenina tauna baine herevalaia,
\q2 baineto “Ia na asi ena lalo-parara”, a?
\b
\s1 Israel ihamaurina
\q1 
\v 17 Asi vanahana Lebanon na uma mai anina ai bainela;
\q2 bona uma mai anina na imea bae gwauraia, ani?
\q1 
\v 18 Una dina ai, taia-kudima taudia ese buka herevadia bae kamonaidia,
\q2 bona vaburadia bona diburadia amo matakepulu taudia matadia ese ḡau bae ita.
\q1 
\v 19 Manau taudia ese moale matamatana na Iehova enai bae abia;
\q2 bona ogoḡami taudia ese Israel ena Helaḡa Diravana bae moalelaia bada.
\q1 
\v 20 Badina be asi edia hebogahisi taudia na bae baia, bona ḡonaḡona taudia na bae doko;
\q2 bona kara dika ikaradia daladia e tahumu taudia iboudiai na bae negedia daure.
\q1 
\v 21 Idia ese hereva tamona amo tau ta na kerere tauna ai e halaoamu,
\q2 bona hanua ikoukouna ai e hahemaoromu tauna na e idoaiamu,
\q2 bona hereva asi anina amo kara maoromaoro tauna na e hakaua sirimu.
\b
\q1 
\v 22 Taunabunai, Abraham e hamauria Diravana ese Iakob ena iduhu na ini e herevalaia tomamu:
\q1 Iakob na basine hemarai lou;
\q2 ia vairana na basine ḡeḡeva lou.
\q1 
\v 23 Badina be natuna, lau imagu ese e karadia taudia, na bogaraginai baine itadia negana ai,
\q2 idia ese lau ladagu bae hahelaḡaia;
\q1 Iakob ena Helaḡa Diravana bae hahelaḡaia,
\q2 Israel ena Dirava magigina bae magigi.
\q1 
\v 24 Bena lalodia e kereremu taudia na lalodia do bae parara,
\q2 bona e maumaumu taudia ese hahediba herevadia bae abi dae.
\c 30
\s1 Aigupto iabidadama-henina na kavakava
\q1 
\v 1 Iehova na e tomu, Gwau-edeede memerodia madi ihabaidia!
\q2 Idia edia lalo-hata karadia e karamu na dia lauegu;
\q1 e henega boumu, to dia lau laumagu ai;
\q2 unu amo kara dika na kara dika latanai e atoa kaumu.
\q1 
\v 2 Idia vada e tore isi, Aigupto baela e tomu,
\q2 a lauegu hahealo asie tahua;
\q1 Farao ena hegima lalonai bae roho mauri,
\q2 bona Aigupto ikerukeruna ai edia hemetai gabuna bae tahua e tomu
\q1 
\v 3 Taunabunai Farao ena hegima na ihahemaraimui ḡauna,
\q2 bona Aigupto ikerukeruna hemetaina ese baine hahemaraimui bada.
\q1 
\v 4 Badina be, ena be ena heitatao taudia na Soan ai,
\q2 bona ena gwaukau taudia na Hane ai vada e kau,
\q1 
\v 5 to iboudiai na hemarai ese e abidiamu,
\q2 basine hadavalaidia diba besena dainai;
\q1 una bese ese se kahadiamu bona se hadavalaidiamu,
\q2 a hemarai bona hedadarai mo latadiai e hadihomu.
\b
\q1 
\v 6 Maduna metauna diho kahana boromadia latadiai:
\q2 Hekwarahi bona hisihisi-bada tanona,
\q1 leona hahinena bona leona maruanena edia tano,
\q2 hekori gaigaina bona roho gaigaina edia tano amo,
\q1 idia ese edia taḡa ḡaudia na doniki dorudia ai e laohaimu,
\q2 bona dava-bada kohudia na kamelo dorudia ai,
\q2 basine hadavalaidia lou diba besena taudia dekedia.
\q1 
\v 7 Badina be Aigupto ena hekaha na asi namona bona asi anina,
\q2 una dainai ladana vada na hatoa;
\q2 “Rahaba\f + \fr 30:7 \ft “Rahaba” na Heberu taudia edia gori ḡauna ta, gadobada ai e nohova ḡauna, ladana.\f* e helai kavamu”.
\b
\q1 
\v 8 Aola, huro-nadina palaka-palakana ai ba torea, idia vairadiai,
\q2 bona buka lalonai danu ba torea;
\q1 bena nega vairai ia na ihamomokanina ḡauna ai bainela,
\q2 ela bona hanaihanai.
\q1 
\v 9 Badina be idia na gwau-edeede besena,
\q2 koikoi memerodia,
\q1 Iehova ena hahediba herevadia
\q2 ikamonaidia asie uramu memerodia.
\q1 
\v 10 Idia ese mata-hanai taudia e hamaorodiamu,
\q2 e tomu, Basio mata hanai;
\q1 bona peroveta taudia e hamaorodiamu,
\q2 e tomu, Hereva maoromaorodia basio perovetalai henimai;
\q1 hereva gaihodia mo ba hamorolaimai,
\q2 bona lalomai ikoidia herevadia ba perovetalai;
\q1 
\v 11 dala ba rakatania, dala amo ba raka oho,
\q2 Israel ena Helaḡa Diravana herevana basia kamonai lou.
\q1 
\v 12 Taunabunai, Israel ena Helaḡa Diravana ini e gwau tomamu:
\q2 Badina be ina hereva o dadaraiamu,
\q1 bona hahehisi karadia bona kara gageva-gagevadia
\q2 o abidadama henidiamu bona ediai o taomu;
\q1 
\v 13 una dainai ina kara havara na emui ai baine vara,
\q2 hara-lata maḡuna e heḡiḡi dobimu na heto;
\q1 e pavamu ela bona heḡiḡi-dobina e kahira-kahiramu,
\q2 bena negana e kaumu ai, nega tamona ai e heḡiḡi dobi takumu;
\q1 
\v 14 eiava uro e makohimu na heto;
\q2 e makohi rohorohomu, e makohi patapatamu,
\q1 ela bona atagana ta se miamu,
\q2 gida iudalaina heḡereḡerena,
\q2 eiava ranu ikadolaina heḡereḡerena.
\b
\q1 
\v 15 Badina be Ḡaubada Iehova, Israel ena Helaḡa Diravana,
\q2 ini e gwau tomamu:
\q1 Emui lou ai bona emui laḡa-ani ai ba mauri;
\q2 bona maino ai bona heabidadama ai goada ba davaria.
\q1 A umui na asio ura,
\v 16 oto “Lasi, hosi ai baia heau”;
\q2 taunabunai ba heau oho haraḡa;
\q1 ma oto “Hosi mai heaudia latadiai baia gui”;
\q2 taunabunai, ihahavamui taudia na bae heau haraḡa-haraḡa.
\q1 
\v 17 Taunimanima daha-ta bae heau, tau tamona ese baine halalaḡadia dainai;
\q2 bona tatau laima ese bae halalaḡamui dainai umui na ba heau;
\q1 ela bona ba noho, au-tubua ta ororo dorina ai
\q2 eiava pepe ta ororo ai na heto.
\b
\s1 Dirava ena gwauhamata ena bese taudia edia
\q1 
\v 18 Taunabunai Iehova na e henarimu, baine hanamomui e tomamu;
\q2 taunabunai ia na e tore isimu, baine bogamui hisi e tomamu.
\q1 Badina be Iehova na hahemaoro ḡoevaḡoeva Diravana;
\q2 ia e nariamu taudia iboudiai na nanamo.
\b
\p 
\v 19 Oibe, Siona taumui, Ierusalem ai o nohomu taumui, umui na basio taitai lou. Momokani, emui taitai reḡena dainai ia ese baine hanamomui; baine kamonai negana ai baine haere henimui.
\v 20 Ena be Ḡaubada ese hahedika anianina bona hahehisi ranuna baine henimui, to emui Hahediba Tauna na basine komu lou, a matamui ese emui Hahediba Tauna bae itaia.
\v 21 Bona idibamui kahana ai eiava laurimui kahana ai ba raka siri negana ai, taiamui na hereva ta murimui kahana amo bae kamonai, baineto, Dalana binai, ia lalonai ba raka.
\v 22 Bena emui kaivakuku, e korodia bena \it silver\it* amo e ḡovadia ḡaudia, bona e hahetaridia bena \it gold\it* amo e ḡovadia ḡaudia, na ba hamirodia. Ba ḡiḡidia rohoroho, ḡau mirodia na heheto. Ba hamaorodia, baoto, A siri.
\p 
\v 23 Bena ia ese medu baine henimui, tano ai ba hado uhedia idairidia, bona uit danu, tano anidia, bae namo bona bae momo. Una dina ai emui boromakau na rei gabudia badadia ai bae aniani;
\v 24 bona boromakau mamaruanedia bona doniki, tano e ruaiamu ḡaudia, ese aniani mai damenana bae ania, gaga bona igau amo vada e hididia ḡaudia.
\v 25 Ororo badadia bona ororo latadia iboudiai latadiai sinavai maraḡidia bae aru diho, ala-alabadana dinana ai, kohoro bae heḡiḡi dobi negana ai.
\v 26 Ina danu, hua diarina na dina diarina heḡereḡerena ai bainela, bona dina diarina na baine habadaia hahitu, dina hitu diaridia heḡereḡeredia, Iehova ese ena bese taudia edia hisi gabudia baine kumidia bona ena hebota amo vada e havaradia berodia baine hanamodia dinana ai.
\b
\s1 Iehova ena hahemaoro Asuria latanai
\q1 
\v 27 A itaia, Iehova ladana na dauha amo e maimu;
\q2 ena badu e garagaramu, bona kwalahuna e dae badabadamu.
\q1 Ia bibinana na badu ai e honumu,
\q2 bona malana na e heara oremu lahina na heto;
\q1 
\v 28 ia lagana na sinavai abatana na heto,
\q2 e utu daemu ela bona taunimanima aiodia.
\q1 Basileia idau-idau na hahebua-tari amo baine hididia,
\q2 bona bese idau-idau aukidia ai ihakau-kereredia ḡauna baine atoa.
\b
\p 
\v 29 Ane ta bavabia, aria helaḡana e karaiamu hanuaboina ai na heto; bona lalomui bae moale mai ivilikou reḡena ida, Iehova ena ororo, Israel nadi-ginina, ilao-henina totona e tore isimu negana ai na heto.
\v 30 BenaIehova ese ia gadona herea-daena baine hakamonaidia bona ia imana ehadihoamu hebotana baine haheitalaidia, mai badu-ḡaraḡarana bona heara-orelahina hururu-hururuna ida, bona mai medu-barokona bona lai-gubana bonamedu-hetarina ida.
\v 31 Asuria taudia na gari ese baine butudia tao, Iehovagadona dainai, ena au amo baine hebota negana ai.
\v 32 Iehova ena dava ihenina auna amo baine botadia negana ai, hebota ta ta ai tareko bona gitara reḡedia bae dae; ia na imana irubena amo baine tuari henidia.
\v 33 Badina be lahi gabuna na idau nega ai vada e heḡaeḡaelaia; oibe, vada e abia hata, hanua pavapavana ena; vada e hadobua bona lababana vada e habadaia, mai lahina bona au-rakurakuna momo herea ida. Iehova laḡana, heara nadidia e arumu na heto, ese e haraiamu.
\c 31
\s1 Aigupto taudia na taunimanima, dia Dirava
\q1 
\v 1 Hekaha idavarina totona Aigupto e laomu
\q2 bona hosi e abidadama henidiamu taudia,
\q2 madi ihabaidia!
\q1 Idia ese kariota e abidadama henidiamu, badina be momo;
\q2 bona hosi-gui taudia danu, badina be gogoada heherea,
\q1 a Israel ena Helaḡa Diravana asie heḡerea,
\q2 bona Iehova ena hahealo asie hetahulaia.
\q1 
\v 2 Ḡau tamona, ia na mai aonegana, bona e hahebua tarimu,
\q2 ena hereva se haloudiamu;
\q1 a kara dika taudia edia ruma ihadikana totona baine tore isi,
\q2 bona kara havara taudia e durudiamu taudia ihadikadia totona danu.
\q1 
\v 3 Aigupto taudia na taunimanima mo, dia Dirava;
\q2 edia hosi na hidio mo, dia lauma.
\q1 Iehova ese ia imana baine toi roro negana ai,
\q2 hekaha tauna baine hetutuhi,
\q1 bona e kahaiamu tauna baine moru,
\q2 bena raruosi bae mase hebou.
\b
\q1 
\v 4 Badina be Iehova ese ini e hamaorogu toma:
\q2 leona eiava leona natuna na damuna latanai e ḡiḡimu,
\q1 bona mamoe ireḡudia taudia oreana ta ia ihadikana totona e boiridiamu negana ai
\q2 ia na edia lolo dainai se garimu bona edia heloḡo-heloḡo dainai damuna se rakataniamu,
\q1 una heḡereḡerena ai Iehova Sabaota baine diho,
\q2 Siona Ororo ororona latanai baine tuari.
\q1 
\v 5 Iehova Sabaota ese Ierusalem baine manua tao,
\q2 bona baine gimaia;
\q1 ia ese baine gimaia bona baine hamauria,
\q2 baine bogaia hisi bona baine harohoa mauri.
\b
\p 
\v 6 Israel taumui e, vada o daḡedaḡe henia bada Diravana ma ba lou henia.
\v 7 Badina be una dina ai iboumui ai ese emui \it silver\it* kaivakukudia bona emui \it gold\it* kaivakukudia do ba negedia, hari imamui mai dikadia ese emui vada e kara ḡaudia.
\b
\q1 
\v 8 Bena Asuria tauna na dare ai baine mase, a dia taunimanima edia dare;
\q2 dare, dia taunimanima ena, ese baine alaia mase;
\q1 bena dare amo baine heau oho,
\q2 bona ena eregabe taudia na hahedua ḡaukaradia ai bae haḡaukaradia.
\q1 
\v 9 Ena nadi-gini baine puki, gari dainai;
\q2 bona ena tuari biagudia ese pepe bae heautania, laḡaḡa dainai,
\q1 Iehova, ena lahi na Siona ai bona ena amu na Ierusalem ai Diravana,
\q2 unu e gwau tomamu.
\c 32
\s1 Kara maoromaoro Lohiana
\q1 
\v 1 A itaia, pavapava ta na kara maoromaoro ai baine lohia,
\q2 bona lohia na hahemaoro ḡoevaḡoeva ai bae hereḡu.
\q1 
\v 2 Ta ta na lai ilao-ahuna gabuna heḡereḡerena ai baela,
\q2 lai-gubana ilao-ahuna gabuna;
\q1 sinavai-sinavai gabu kaukauna ai na heheto,
\q2 eiava nadi-gini badana ikerukeruna tano ḡaḡaena ai na heto.
\q1 
\v 3 Bena e heitamu taudia matadia na basie hakapu,
\q2 bona e kamonaimu taudia taiadia bae kirara.
\q1 
\v 4 Takutaku tauna ese lalona do baine hadaia maoromaoro,
\q2 bona lanalana taudia maladia bae hereva haraḡa,
\q2 bona bae hereva ḡoevaḡoeva.
\q1 
\v 5 Kavakava tauna na lohia basie gwauraia lou,
\q2 bona kara koikoi tauna na kara momokani tauna basie gwauraia lou.
\q1 
\v 6 Badina be kavakava tauna na e hereva kava hereva kavamu,
\q2 bona lalona ese kara dikadia e lalo hatamu,
\q1 Dirava iḡonaḡonalaina karadia baine kara
\q2 bona Iehova baine herevalaia kerere helaoreana;
\q1 hitolo tauna na bogana basine hakunua
\q2 bona ranu mase tauna na ranu basine henia helaoreana.
\q1 
\v 7 Koikoi tauna ena kara koikoi na didika;
\q2 lalo-hadai dikadia e lalo hatalaimu,
\q1 ogoḡami tauna na koikoi herevadia amo baine hadikaia rohoroho totona,
\q2 e dabumu tauna ena noinoi na momokani negana ai.
\q1 
\v 8 A lalo-ḡoevadae tauna ese kara ḡoeva-daedia e lalo hatalaimu,
\q2 bona kara ḡoeva-daedia daidiai e ginimu.
\b
\s1 Ierusalem hahinedia isisiba-henidia
\q1 
\v 9 Aboni-noho hahinemui e, a tore isi;
\q2 lau eregu ba kamonai.
\q1 Sibomui o heimodaimu kekenimui e,
\q2 egu hereva ba hakala henia.
\q1 
\v 10 Laḡani ta sisivana baine ore,
\q2 bena umui sibomui o heimodaimu hahinemui kudoumui bae hetaha;
\q1 badina be vine na basie huahua,
\q2 bona au huahuadia basio huredia.
\q1 
\v 11 Aboni-noho hahinemui e, a heude-heude;
\q2 sibomui o heimodaimu hahinemui e, kudoumui ae hetaha;
\q2 emui dabua ba doki oho, puse dabuadia ba rio.
\q1 
\v 12 Ba hevale, uma namodia ilalodia
\q2 bona vine mai anidia ilalodia daidiai,
\q1 
\v 13 bona egu bese taudia edia tano ese
\q2 au ginigini bona ava ḡiniḡini e havaradiamu dainai;
\q1 oibe, moale rumadia iboudiai moale hanuana lalonai daidiai.
\q1 
\v 14 Badina be pavapava ena ruma na baine mia ḡaḡae,
\q2 bona hutuma ese e noholaiava hanuana na baine vahu;
\q1 ororo bona hegima rumana na uda ḡaudia ese bae noho henidia;
\q2 uda donikidia ese bae moalelaidia,
\q2 bona mamoe seridia ese reidia bae ani;
\q1 
\v 15 ela bona Lauma na atai amo ita latadai baine hesei kau,
\q2 bona tano ḡaḡaena na uma mai anina ai bainela,
\q2 bona uma mai anina na imea bae gwauraia.
\q1 
\v 16 Bena hahemaoro ḡoevaḡoeva na tano ḡaḡaena ai baine mia,
\q2 bona kara maoromaoro na uma mai anina lalonai baine mia.
\q1 
\v 17 Kara maoromaoro anina na maino,
\q2 bona kara maoromaoro amo laḡa-ani bona heabidadama bae hesiriu hanaihanai.
\q1 
\v 18 Egu bese taudia na maino gabuna ai bae noho,
\q2 asi garidia gabudia bona laḡa-ani gabudia asi reḡereḡedia ai.
\q1 
\v 19 Imea audia na bae gari ore,
\q2 bona hanua badana baine heḡiḡi dobi vaitani.
\q1 
\v 20 Ranu gabudia iboudiai badibadidiai o hadohadomu taumui na nanamo;
\q2 boromakau mamaruanedia bona doniki o kahudia negemu bona o haloaloadiamu taumui danu nanamo.
\c 33
\s1 Iehova ese baine hamaurida
\q1 
\v 1 Hahebua-tari taumu e, madi ihabaimu!
\q2 Oi na asie habuamu tari.
\q1 Kara-dibaka taumu e, madi ihabaimu!
\q2 Ta ese se kara dibaka henimu.
\q1 Hahebua-tari ba hadokoa murinai
\q2 bae habuamu tari;
\q1 bona kara-dibaka karadia ba hadoko murinai
\q2 bae kara dibaka henimu.
\b
\q1 
\v 2 Iehova e, a bogamai hisi; ai ese a narimumu.
\q2 Daba daba iboudiai ai imamai ai baola,
\q2 bona ihamaurimai ai baola, dika negadia ai.
\q1 
\v 3 Rege badana e varamu dainai bese idau-idau e heaumu;
\q2 sibomu emu heabi-isi ai basileia idau-idau e karoho rohorohomu.
\q1 
\v 4 Dadidadi kohudia e haboumu, rautunu ese edia ḡau e haboumu na heto;
\q2 kwadi e rohomu na heto, taunimanima ese unu ḡau latadiai e roho kaumu.
\q1 
\v 5 Iehova na e imodaiamu, badina be ia na atai ai e nohomu;
\q2 Siona na hahemaoro ḡoevaḡoeva bona kara maoromaoro amo e hahonuamu.
\q1 
\v 6 Ia na imuda ai bainela, emui nega ai;
\q2 hahemauri bona aonega bona lalo-parara bae bada herea.
\q2 Iehova garina na ena taḡa.
\b
\q1 
\v 7 A itaia, boga-auka taudia na murimuri ai e taimu;
\q2 maino ena gwaukau taudia na e tai dikadikamu.
\q1 
\v 8 Laolao daladia na e mia ḡaḡaemu;
\q2 taunimanima na asie laolaomu.
\q1 Gwauhamata na e ḡiḡidia rohorohomu,
\q2 hereva ihamomokanidia taudia na e dadaraidiamu;
\q2 taunimanima na asie lalodiamu.
\q1 
\v 9 Tano na e taitaimu, e maraimu;
\q2 Lebanon vada e baia, e kakoromu;
\q1 Saron na tano ḡaḡaena na heto;
\q2 Basan bona Karamele raudia e hehuhumu.
\q1 
\v 10 Iehova na e tomu: Aina tore isi;
\q2 sibogu aina heabi isi; ae imodaigu.
\q1 
\v 11 Uit momorudia na emui ai e varamu, uit badidia o havaradiamu;
\q2 laḡamu na lahi, ia ese baine aramu ore.
\q1 
\v 12 Bese idau-idau bae hegabu, ahu na heto;
\q2 eiava au giniginidia e utumu bona e doumu na heheto.
\b
\q1 
\v 13 Umui dauhai o nohomu taumui e,
\q2 egu kara sivaraina a kamonai.
\q1 Umui kahikahi ai o nohomu taumui e,
\q2 egu siahu bavabia dae.
\q1 
\v 14 Kara dika taudia Siona ai na e garimu,
\q2 Dirava asie matauraiamu taudia kudoudia e hetahamu.
\q1 Daika ita bogaragidai na lahi hururu-hururuna lalonai baine noho diba?
\q2 Daika ita bogaragidai na e ara hanaihanaimu lahina lalonai baine noho diba?
\q1 
\v 15 E raka maoromaoromu bona e hereva maoromaoromu tauna,
\q2 hahehisi karadia amo e abimu ḡaudia e dadaraidiamu tauna;
\q1 imana amo koikoi henitaona e piua daudaumu, baine abia na garina, tauna;
\q2 bona taiana e kodobeamu, rara ihahebubuna herevadia baine
\q2 kamonai na garina, tauna;
\q1 bona matana e hakapudiamu, kara dika baine itaia na garina, tauna.
\q1 
\v 16 Ia na atai ai baine noho,
\q2 helao-ahu nadi-hagadia ai baine noho namonamo;
\q2 ana aniani bae henia, bona ranu ai basine dabu.
\q1 
\v 17 Matamu ese pavapava na hairaina lalonai bae itaia;
\q2 tano rohana latana danu bae itaia.
\q1 
\v 18 Oi lalomu ese hahegari ḡauna baine haeroa:
\q2 ḡau e hagaudia tauna be edeseni ai?
\q1 eaiva ḡaudia e hahetohodia tauna be edeseni ai?
\q2 Kohoro e duahidia tauna be edeseni ai?
\q1 
\v 19 Heḡonaḡonalai taudia na basio itadia lou,
\q2 bona hereva hehunidia, anidia asi dibamu herevadia,
\q1 asi dibamu gadona ai e hereva lanalanamu,
\q2 taudia danu basio itadia lou.
\q1 
\v 20 Siona ba raraia, eda aria, e gwauraidia guna ariadia, hanuana.
\q2 Oi matamu ese Ierusalem bae itaia;
\q1 noho namonamo gabuna asi reḡereḡena,
\q2 basine heraḡa palai rumana,
\q1 ikokona basie heraḡa
\q2 bona kwanauna basie motu ḡauna.
\q1 
\v 21 Unuseni ai Iehova na hairai ai baine hedinarai, ita edai,
\q2 ḡamoḡa bada sinavaidia bona doka gabuna ai;
\q1 unuseni ai vanaḡi ta na basie baraia diba,
\q2 bona lagatoi ta basine heau diba.
\q1 
\v 22 Badina be Iehova na eda hahemaoro tauna, Iehova na eda lohia,
\q2 Iehova na eda pavapava; ia ese baine hamaurida.
\b
\q1 
\v 23 Emu kwanau eme hetu;
\q2 au-tubua asie haginia tutukamu,
\q2 eiava lara asie veria roromu.
\b
\q1 Una negana ai e dadi ḡaudia momo herea bae haridia.
\q2 ae-hedairike taudia danu ḡau bae dadi,
\q2 
\v 24 bona hanua tauna ta basineto “E goreregumu”.
\q1 Unuseni ai e nohomu taudia edia dika na bae hegwau tao.
\c 34
\s1 Iehova ena badu Edom bona basileia idau-idau latadiai
\q1 
\v 1 Basileia idau-idau e, a raka kahira, a kamonai!
\q2 Bese idau-idau e, a hakala!
\q1 Tanobada baine kamonai, mai anina idoinai ida;
\q2 tanobada bona ena amo e varamu ḡaudia iboudiai.
\q1 
\v 2 Badina be Iehova ese basileia idau-idau iboudiai e badu henidiamu,
\q2 ena badu e ḡaraḡaramu edia tuari taudia iboudiai latadiai;
\q2 ia ese vada e revadia, bae aladia mase.
\q1 
\v 3 Edia mase taudia na bae henege lasi murimuri ai;
\q2 tau-anidia bae bodaga, bonadia bae dae,
\q2 bona raradia na ororo amo bae aru diho.
\q1 
\v 4 Guba oreana idoinai baine ore;
\q2 guba na baine heloku, pepa e lokuamu na heto.
\q1 Ena orea taudia iboudiai bae moru,
\q2 vine raudia eiava suke raudia na e hehuhumu na heto.
\q1 
\v 5 Badina be egu dare na rara ai vada e honu honu dae guba ai;
\q2 a itaia, ia na Edom ihahemaoro-henina totona e dihomu,
\q2 vada na revadia mase taudia latadiai.
\q1 
\v 6 Iehova na mai ena dare; ena dare na rara ai vada e honu honu dae,
\q2 bona digara ai vada e ḡataka-ḡataka;
\q1 mamoe natudia bona nani raradia,
\q2 bona mamoe mamaruanedia nadinadidia digaradia.
\q1 Badina be Iehova na mai ena boubou Bosra ai,
\q2 bona mai ena ala-ala badana Edom tanona ai.
\q1 
\v 7 Uda boromakaudia mamaruanedia na idia ida bae hekida diho,
\q2 bona boromakau mamaruanedia matamatadia, boromakau goada hereadia ida.
\q1 Edia tano na rara ese baine haḡonua;
\q2 edia uma tanona na digara ese baine hanamoa herea.
\b
\q1 
\v 8 Badina be Iehova na mai dika davana ihenina dinana,
\q2 bona mai ena dava ikarana laḡanina, Siona dainai.
\q1 
\v 9 Edom sinavaidia na e havevemu nadidia ai bae hahelao,
\q2 bona ena uma tanodia na heara nadidia ai baela;
\q2 ena tano na e aramu nadina ai bainela.
\q1 
\v 10 Hanuaboi ai bona dina ai ia na basine bodo;
\q2 kwalahuna na baine dae hanaihanai.
\s1 Uru ta ta amo ia na baine mia ḡaḡae;
\q2 tau ta ese basine rakaia hanai ela bona hanaihanai.
\q1 
\v 11 Bogibada bona miḡu ese bae ḡaunaia,
\q2 baimumu bona mukou ese bae noholaia.
\q1 Ia ese oromana iabi-ohona na ia daenai baine veria, hahetoho varonana heto,
\q2 bona anina iha-orena ena lohia daediai, gini-maoro varona na heto.
\q1 
\v 12 Ladana bae hatoa “Asi Basileiana Unuseni Ai”;
\q2 bona ena lohia iboudiai bae lasihi lasihi.
\b
\q1 
\v 13 Au ginigini ese ena gabu aukadia bae habubunidia,
\q2 bona ava ḡiniḡini ese ena kohoro bae hahonudia.
\q1 Uda sisiadia na unuseni ai bae loa,
\q2 bona kokokoko na unuseni ai bae noho.
\q1 
\v 14 Uda ḡaudia na tano ḡaḡaena sisiadia ida bae hedavari,
\q2 bona huika-huika ḡauna ese bamona baine tai henia.
\q1 Oibe, unuseni ai lai-gubana laumana baine roho kau,
\q2 ena laḡa-ani gabuna baine davaria.
\b
\q1 
\v 15 Unuseni ai baimumu ese ena ruma baine karaia,
\q2 ena gatoi baine atodia, baine hapapadia,
\q2 bona natuna na ikerukeruna ai baine haboudia.
\q1 Oibe, bogibada na unuseni ai bae hebou,
\q2 hahinedia bona mamaruanedia.
\q1 
\v 16 Iehova ena buka ai a tahua, ini ba duahia toma:
\q2 Ini ta basine boio;
\q2 bona hahine ta basine noho kava, asi bamona maruanena.
\q1 Badina be Iehova uduna na vada e haheḡani,
\q2 bona ena Lauma ese vada e haboudia.
\q1 
\v 17 Ia ese mari vada e abi, idia edia;
\q2 ia imana ese idia ahudia vada e hahetoho henidia;
\q1 idia ese bae ḡaunaia hanaihanai,
\q2 uru ta ta lalodiai idia ese bae noholaia.
\c 35
\s1 Dirava ena bese baine gini lou
\q1 
\v 1 Tano ḡaḡaena bona tano kaukauna bae moale;
\q2 tano ḡaḡaena baine moale, bona baine burea;
\q1 vahuvahu na heto
\v 2 baine burea momo;
\q2 baine moale hisi dae mai ane iabina ida.
\q1 Lebanon hairaina bae henia,
\q2 Karamele bona Saron herea-daedia danu.
\q1 Idia ese Iehova hairaina bae itaia,
\q2 eda Dirava herea-daena bae itaia.
\b
\q1 
\v 3 Ima manokadia ba hagoadadia;
\q2 tui manokadia ba ha-aukadia.
\q1 
\v 4 Kudoudia e hetahamu taudia ba hamaorodia, baoto:
\q2 Ba goada, basio gari!
\q1 A itaia, emui Dirava bainema,
\q2 mai dika davana ihenina ida,
\q1 Dirava ena dava ikarana ida;
\q2 ia na bainema, bena baine hamaurimui.
\b
\q1 
\v 5 Una negana ai mata-kepulu taudia matadia na bae papa,
\q2 bona taia-kudima taudia taiadia na bae kirara;
\q1 
\v 6 una negana ai ae-hedairike tauna baine roho isi roho isi, dia na heto;
\q2 bona mu tauna malana ese moale anedia baine abi.
\q1 Badina be tano ḡaḡaena ai ranu baine lohi lohi dae,
\q2 bona tano kaukauna ai sinavai bae aru;
\q1 
\v 7 miri tanona mai siahuna na gohu ai bainela;
\q2 bona ranu-mase tanona na ranu lohi-lohi gabuna ai bainela;
\q1 uda sisiadia edia loa gabudia na gohugohu ai bae hahelao,
\q2 bona rei na geda bona siriho ese bae boloa.
\b
\q1 
\v 8 Unuseni ai laolao dalana baine mia,
\q2 bona ladana bae hatoa “Dala Helaḡana”;
\q1 dia ḡoeva taudia ese basie rakalaia,
\q2 bona kavakava taudia na ia lalonai basie kerere.
\q1 
\v 9 Unuseni ai leona ta basine noho, bona
\q2 una dala ai kasiri aniani ḡauna daḡedaḡena ta basinela;
\q1 basie davaridia una gabu ai;
\q2 a vada e hamauridia taudia na unuseni ai bae raka.
\q1 
\v 10 Iehova ese vada e davalaidia taudia na bae lou mai,
\q2 Siona baema mai anedia ida;
\q1 moale hanaihanai na kwaradia ai baine mia,
\q2 moale bona lalo-namo bae abi,
\q2 bona lalo-hisihisi bona ḡanaḡana na bae ore.
\c 36
\s1 Senakerib ena tuari
\p 
\v 1 King Hesekia ena lohia laḡanina ihagwauta-hanina ai, Senakerib, Asuria pavapavana, ese luda hanuadia mai maḡudia iboudiai e tuari henidia bona e abidia.
\v 2 Bena Asuria pavapavana ese Rabsake\f + \fr 36:2 \ft “Rabsake” na dia tau ta ladana, to ena dagi ladana.\f* bona tuari, oreana badana ta Lakisi amo e siaidia lao, King Hesekia dekenai, Ierusalem ai. Ia na atai gohuna dadairana badibadinai e gini, Dabua-huri Tauna Ena Tano lao dalana ai.
\v 3 Bena Eliakim Hilkia, hanua pavapavana ena ruma ireḡuna tauna, bona Sebna, toretore tauna, bona Ioa Asaf, e tore pepadia inaridia tau, tatoiosi na e raka lasi ia dekenai.
\p 
\v 4 Bena Rabsake ese e hereva henidia, eto, Hesekia na ba hamaoroa, baoto, Pavapava badana, Asuria pavapavana, na ini e gwau tomamu: Dahaka o halahalahamu dainai so daradaramu?
\v 5 Oi o laloamu hereva kavakavadia na tuari ihaerolaina bona igoadalaina a? Daika enai o helalo kaumu dainai vada o gwau edeede henigu?
\v 6 A itaia, oi na Aigupto enai o helalo kaumu, a ia be siriho kwaiduna tau ta ese hetao-kau ai imana baine gwadaia uru ḡauna na heto. Farao, Aigupto pavapavana, na unuheto, ienai e helalo kaumu taudia iboudiai ediai.
\v 7 A boma hamaorogu “Ai na Iehova, emai Dirava, enai a helalo kaumu”; matona, iena atai gabudia bona ena ihaboulaina patadia na Hesekia ese vada e abi oho, bona Iuda taudia bona Ierusalem taudia vada e hamaorodia, eto “Ina ihaboulaina patana vairanai ba toma diho”, ani?
\v 8 Be, biagugu Asuria pavapavana ida ba gwau hamata. Ia e tomu “Lau ese hosi daha-rua baina henimu, bema oi ese gui taudia na latadiai ba hahelaidia kau diba negana ai”.
\v 9 Aigupto edia kariota bona edia hosi-gui taudia ediai o helalo kaumu negana ai, biagugu ena hesiai taudia bogaragidia amo tuari biaguna maraḡi-maraḡina tamona ma ede ba hadarerea toma?
\v 10 Ina danu, oi o tomamu ina gabu ituari-henina bona ihabua-tarina vada nama lalonai Iehova na dia lau ida a? Lasi, Iehova ese e haḡanigu, eto, Ina tano ba tuari henia bona ba habuaia tari.
\p 
\v 11 Bena Eliakim bona Sebna bona Ioa ese Rabsake e hereva henia, eto, Mani emu kara emu hesiai taudia na Aram gadona ai ba hereva henimai, badina be ikamonaina mai dibamai, a Heberu gadona ai basio hereva henimai, maḡu latanai e helaimu taudia bae kamonai na garina.
\v 12 A Rabsake ese e hamaorodia, eto, Biagugu vada e siaigu, ina hereva na umui biagumui bona umui emui ai mo baina gwaurai totona, dia unu maḡu latanai e helaimu taudia, idia na umui ida vada e ahumui vaitani sibomui tagemui bavani bona meimui ba inu taudia, ediai a?
\p 
\v 13 Bena Rabsake na e tore isi, Heberu gadona ai e boi lolo, eto, Pavapava badana, Asuria pavapavana, ena hereva a kamonai.
\v 14 Pavapava na ini e gwau tomamu: Hesekia ese basine koimui, badina be ia ese basine harohomui mauri diba.
\v 15 Bona Hesekia ese Iehova enai baine hahelalomui kau, baineto “Momokani Iehova ese baine hamaurida; ina hanua na Asuria pavapavana imana ai basine atoa kau”, na basio abia dae.
\v 16 Hesekia basio kamonai henia; badina be Asuria pavapavana na ini e gwau tomamu: umui na lau ida baita herohe maino; lau dekegu ba raka lasi mai. Bena iboumui ai na ta ta ena vine ena vine ena suke ena suke anidia baine ani, bona ena guri ena guri ranuna baine inu;
\v 17 ela bona lau baina vasi, bena tano ta baina laohaimui, umui emui tano heḡereḡerena, uit bona vine-ranuna tanona, flaoa bona vine imeadia tanona.
\v 18 Nahuamui ba toho, Hesekia ese baine koimui na garina, baineto “Iehova ese baine harohoda mauri”. Bese idau-idau diravadia ta ese nega ta ai ena tano na Asuria pavapavana imana amo vada e hamauria a?
\v 19 Hamat bona Arapada diravadia be edeseni ai? Sefaravaimi diravana be edeseni ai? Samaria na imagu amo vada e hamauria a?
\v 20 Ini tano idau-idau diravadia iboudiai bogaragidiai, daidia ese edia tano na lau imagu amo baine hamauria a? Matona, Iehova ese Ierusalem na lau imagu amo baine hamauria a?
\p 
\v 21 A taunimanima na asi reḡereḡedia e nohova, hereva ta asie haere henia; badina be hanua pavapavana ese vada e haḡanidia, eto, Basio haere henia.
\v 22 Bena Eliakim Hilkia, hanua pavapavana ena ruma ireḡuna tauna bona Sebna, toretore tauna, bona Ioa Asaf, e tore pepadia inaridia tau, na edia dabua e dare, bena Hesekia dekenai e raka vareai, Rabsake ena hereva e hamaorolaia.
\c 37
\s1 Iuda ihamaurina
\p 
\v 1 King Hesekia ese hereva e kamonai, bena ena dabua e dare, puse dabuadia e hahedokilai; bena Iehova ena dubu ai e raka vareai.
\v 2 Bena ia ese Eliakim, ena ruma ireḡuna tauna, bona Sebna, toretore tauna, bona hahelaḡa taudia badadia, na e siaidia, puse dabuadia bae doki, bena peroveta tauna Isaia Amoso dekena baela.
\v 3 Idia ese e hamaoroa, eto, Hesekia na ini e gwau tomamu: Hari dina na lalo-hisihisi bona gwau-gwaubona hemarai dinana; memero edia vara negana vada e kau, to ihavaradia ai goada na vada lasi.
\v 4 Reana Iehova, emu Dirava, ese Rabsake, biaguna Asuria pavapavana ese e siaia Mauri Diravana baine ḡonaḡonalaia tauna, ena hereva iboudiai vada e kamonai. Reana Iehova, emu Dirava, ese e kamonai herevadia baine gwaudia tubu. Taunabunai, taunimanima kwabu-kwabudia doini e nohomu daidiai ba ḡuriḡuri.
\p 
\v 5 King Hesekia ena hesiai taudia na Isaia dekenai e kau negana ai,
\v 6 Isaia ese e hereva henidia, eto, Baigumui ba hamaoroa, baoto “Iehova na ini e gwau tomamu: Basio gari, o kamonai herevadia, Asuria pavapavana ena hesiai taudia ese lau e ḡonaḡonalaigu herevadia, daidiai.
\v 7 A itaia, lau ese lauma ta ia lalonai baina atoa, bena sivarai lahulahuna ta baine kamonai, bena ena tano korikori baine lou lao. Bena ena tano korikori ai lau ese ena mase dalana na dare amo baina havaraia”.
\p 
\v 8 Bena Rabsake e lou ela, Asuria pavapavana e davaria, ia ese Libna e tuari heniava; badina be vada e kamonai hanua pavapavana na Lakisi amo vada e raka oho.
\v 9 Bena hanua pavapavana ese Tirihaka, Etiopia pava pavana, harina e kamonai, haida eto “Ia na vada e tore isi, oi ituari-henimu e maimu”. Una hereva e kamonai negana ai, ia ese gwaukau taudia haida na Hesekia dekena e siaidia, eto,
\v 10 Hesekia, Iuda pavapavana, ini ba hamaoroa toma, baoto: Emu Dirava, o abidadama heniamu Diravana, ese Ierusalem na Asuria pavapavana imana ai basine atoa gwauhamatana amo basine koilaimu.
\v 11 Vada o kamonai Asuria pavapavana ede vada e kara toma; tano iboudiai vada e habuadia tari vaitani. Bena umui na ba roho mauri a?
\v 12 Bese idau-idau, senegu ese e habuadia tari besedia, Gosan, Haran, Resef, bona Eden taudia Tel-asara ai e nohova, na edia dirava ese vada e hamauridia a?
\p 
\v 13 Hamat bona Arapada bona Sefaravaimi hanuana bona Hena bona Iva pavapavadia be edeseni ai?
\p 
\v 14 Hesekia ese revareva na gwaukau taudia imadia amo e abia, bena e duahia. Bena Hesekia na Iehova ena dubu ai e dae kau, bena revareva e kehoa Iehova vairanai.
\v 15 Bena Hesekia ese Iehova e ḡuria, eto,
\v 16 Iehova Sabaota e, Israel Diravana, oi na kerubi daediai o helaimu; oi mo sibomu tanobada basileiadia iboudiai edia Dirava; oi ese guba bona tanobada vada o karadia.
\v 17 Iehova e, taiamu a hakala, bona ba kamonai. Iehova e, matamu a hapapa, ba roharoha. Senakerib ena hereva iboudiai, Mauri Diravana iḡonaḡonalaina totona e siaidia herevadia, na ba kamonai.
\v 18 Momokani, Iehova e, Asuria pavapavadia ese bese idau-idau iboudiai mai ediatano ida vada e habuadia tari,
\v 19 bona edia dirava na lahi ai vada e tahodia kau; badina be idia na dia dirava korikoridia, a taunimanima imadia ese e kara ḡaudia, au bona nadi; una dainai vada e habuadia tari.
\v 20 Taunabunai, Iehova emai Dirava e, ia imana amo ba hamaurimai, bena tanobada basileiadia iboudiai na bae diba, Iehova e, oi mo sibomu Dirava.
\p 
\v 21 Bena Isaia Amoso ese gwau-kau na Hesekia dekena e siaia lao, eto, Iehova, Israel Diravana, na ini e gwau tomamu: Badina be vada o ḡurigu, Senakerib, Asuria pavapavana, herevadia vada o gwaurai, dainai,
\v 22 Iehova ese ini vada e herevalaia toma:
\q1 Siona natuna hane-ulato rami-hebouna ese
\q2 e dadaraimumu bona e ḡonaḡonalaimumu;
\q1 Ierusalem natuna hahinena ese
\q2 oi murimu ai kwarana e taiko-taikomu.
\b
\q1 
\v 23 Daika vada o ḡonaḡonalaia, vada o ihi-ihiraia?
\q2 Daika ihadikana ai gadomu vada o habadaia
\q1 bona matamu o helari dae heniamu?
\q2 Israel ena Helaḡa Diravana enai.
\q1 
\v 24 Emu hesiai taudia ududia amo Iehova vada o ḡonaḡonalaia,
\q2 oto, Egu kariota momo amo
\q1 ororo doridia ai vada na dara dae,
\q2 ela bona Lebanon ena gabu hehunidia.
\q1 Ena sida audia lata-hereadia na hagaridia,
\q2 bona ena beroso audia namo-hereadia danu.
\q1 Ia doridorina ai na dara dae,
\q2 bona ena uda ahu ai danu.
\q1 
\v 25 Guri na geidia,
\q2 ranu na inu;
\q1 aegu lalona amo
\q2 Aigupto sinavaidia iboudiai na hakororodia.
\b
\q1 
\v 26 Oi to kamonai a,
\q2 lau ese idau nega ai na heḡaeḡaelaia?
\q1 Harihari na havaramu karadia na
\q2 idau nega ai na lalodia, nato,
\q1 oi ese hanua mai maḡudia na
\q2 nadi senudia ai ba halaodia;
\q1 
\v 27 bena edia goada baine ore dainai
\q2 inoholaidia taudia na daradia bae doko bona bae baia;
\q1 tano avadia eiava rei matamata
\q2 heḡereḡeredia ai baela,
\q1 eiava ruma guhidia ai rei e varamu na heto,
\q2 do se huahua ai na e maraimu.
\q1 
\v 28 A lau na emu helai diho dibagu,
\q2 emu raka lasi bona emu raka vareai,
\q2 bona emu heihi-ihirai egu ai danu.
\q1 
\v 29 Vada o ihi-ihiraigu dainai,
\q2 bona emu hekokoroku herevadia vada na kamonai dainai,
\q1 lau ese egu igau na udu-baubaumu ai baina atoa,
\q2 bona egu udu-aurina danu udumu ai;
\q1 bena ma baina haloumu,
\q2 oi oma dalana amo.
\p 
\v 30 Toana emu ai binai: ina laḡani lalonai vara kava ḡauna bavania, bona laḡani iharuana ai ma iena amo baine vara ḡauna bavania; laḡani ihatoina ai ba hadohado bona ba taboro, vine imeadia ba hado, bona anidia bavani.
\v 31 Bona Iuda kwabukwabudia dounu mamauri na ramudia bae diho bona tuhutuhudia bae dae;
\v 32 badina be kwabukwabudia na Ierusalem amo bae raka lasi, bona Siona ororona amo roho-mauri taudia oreana na bainela. Iehova ena ura kwalimu ese ina na baine havaraia.
\p 
\v 33 Taunabunai, Iehova ese Asuria pavapavana na ini e herevalaia tomamu: Ia na ina hanua basinema, eiava diba ta basine kino henia, eiava mai kesina ida hanua vairanai basinema, eiava tano na hanua vairanai basine larebaia dae.
\v 34 Ema dalana amo ma baine lou; ina hanua lalonai basine raka vareai Iehova vada e hereva.
\v 35 Badina be ina hanua baina gimaia bona baina namauria, lau sibogu daigu ai bona egu hesiai tauna David dainai.
\p 
\v 36 Bena Iehova ena aneru na e raka lasi, taunimanima domaga-ta gerebu-taurahani daha-ima\f + \fr 37:36 \ft Domaga-ta gerebu-taurahani daha-ima = 185,000.\f* Asuria taudia edia taruha ai e aladia mase. Daba e rere, haida e tore isi, e itadia, unu na iboudiai mase taudia mo.
\v 37 Bena Senakerib, Asuria pavapavana, na e raka oho, e lou lao, Nineve ai e noho.
\v 38 Bena ena dirava, ladana Nisrok, ena dubu ai e ḡuriḡuriva negana ai, ia natuna Adram-melek bona Saresere ese dare amo e alaia mase, bena e heau mauri, Ararat tanona ela. Bena natuna ta, ladana Esarahadon, ese ia gabuna ai e lohia.
\c 38
\s1 Hesekia e gorerea
\p 
\v 1 Unu dinadia ai Hesekia na e gorerea, mokona e mase. Bena peroveta tauna Isaia Amoso na dekena ema, e hereva henia, eto, Iehova na ini e gwau tomamu: Emu ḡau iboudiai bavatodia ḡoevaḡoeva, badina be oi na ba mase, emu gorere amo basio namo lou.
\v 2 Bena Hesekia vairana na haba e henia, bona Iehova e ḡuria, eto,
\v 3 Iehova e, na noimumu ba laloa tao, lau na oi vairamu ai vada na raka mai heabidadamagu bona mai lalogu idoinai ida, bona oi vairamu ai vada na kara maoromaoro. Bena Hesekia na e tai dikadika.
\p 
\v 4 Bena Iehova ena hereva na Isaia enai e kau, eto,
\v 5 Aola, Hesekia ba hamaoroa, baoto, Iehova, tamamu David ena Dirava, na ini e gwau tomamu: Emu ḡuriḡuri vada na kamonai, bona iruru-matamu vada na ita; a itaia, emu mauri na ma baina hadaudaua ela bona laḡani gwauta-ima.
\v 6 Oi bona ina hanua na Asuria pavapavana imana amo baina harohomui mauri, bona ina hanua baina gimaia.
\v 7 Toana binai oiemu, Iehova ena amo, Iehova ese vada e gwauraia hamata ḡauna na baine karaia:
\v 8 A itaia, dina e gelomu ai na Ahasa ena dina hahetoho ḡauna ai e ha-ikerukerumu vadavadadiagwauta amo ikerukeru baina haloua. Taunabunai, dina ese ikerukeru na vadavada gwauta amo e haloua, hari dina hahetoho ḡauna ai.
\p 
\v 9 Hesekia, Iuda pavapavana, ena revareva, ena gorere amo e namo lou murinai e torea ḡauna, herevadia bini:
\q1 
\v 10 Egu mauri dina-tubuana ai
\q2 baina lao bubuni nato;
\q1 Mase Gabuna ikoukouna vada e siaigu lao,
\q2 egu laḡani oredia ai unuseni ai baina noho.
\q1 
\v 11 Iehova basina itaia
\q2 mauri taudia edia tano ai nato;
\q1 taunimanima na basina itadia lou
\q2 tanobada inoholaina ḡaudia bogaragidiai nato.
\q1 
\v 12 Egu noho gabuna vada e raḡaia, egu amo vada e abia oho,
\q2 mamoe ireḡudia tauna ena kalaga na heto;
\q1 egu mauri vada na lokua, dabua ihatuna tauna ese dabua e lokuamu na heto;
\q2 ia ese dabua ihatulaina ḡauna amo e utugu ohomu.
\q1 Dina ela bona hanuaboi oi ese vada o alagumu;
\q2 
\v 13 ikahagu dalana na tahua tai tahua taimu ela bona daba.
\q1 Leona na heto ia ese turiagu iboudiai e hakwaidudiamu;
\q2 dina ela bona hanuaboi oi ese vada o alagumu.
\b
\q1 
\v 14 Aibisi eiava noko na heto na taimu,
\q2 pune na heto na ḡanaḡanamu.
\q1 Na roha dae daudaumu dainai matagu e hisihisimu;
\q2 Ḡaubada e, e hahisihisigumu; oi na igimagu ai baola.
\q1 
\v 15 A dahaka bainato? Badina be ia ese vada e hereva henigu;
\q2 ia sibona ese vada e karaia.
\q1 Lau na asina mahutamu,
\q2 lalogu iditana dainai.
\q1 
\v 16 Ḡaubada e, ini ḡau daidiai taunimanima na e maurimu,
\q2 bona laumagu ena mauri na ini ḡau iboudiai lalodiai.
\q2 Goada ba henigu lou, bona ba hamaurigu.
\q1 
\v 17 A itaia, lau ihanamogu totona
\q2 hisi badadia na ani;
\q1 a oi ese egu mauri na
\q2 mase gurina amo o rauaia;
\q1 badina be oi ese egu kara dika iboudiai na
\q2 murimu ai vada o nege.
\q1 
\v 18 Badina be Mase Gabuna ese basine hanamomu diba,
\q2 bona mase ese basine imodaimu diba;
\q1 guri ai e dihomu taudia ese
\q2 emu momokani basie laroa diba.
\q1 
\v 19 Mauri tauna, mauri tauna, ia ese e hanamomumu,
\q2 lau ese hari dina ai na hanamomumu heḡereḡerena;
\q1 tama ese natuna na
\q2 emu momokani e hadibalaidiamu.
\b
\q1 
\v 20 Iehova ese baine hamaurigu,
\q2 bena ita ese ane baita abi mai gitara ihataidia ida,
\q1 eda mauri dinadia iboudiai lalodiai,
\q2 Iehova ena dubu ai.
\b
\p 
\v 21 Isaia vada eto, Suke manena ta bae abia, iohururu ai bae atoa kau, bena baine namo lou.
\v 22 Bena Hesekia vada eto, Lau na Iehova ena dubu ai baine dae kau toana be dahaka?
\c 39
\s1 Gwau-kau taudia Babulono amo
\p 
\v 1 Una negana ai Merodak-baladan, Babulono pavapavana Baladan natuna, ese gwaukau taudia haida e siaidia, revareva bona herahia tauna na Hesekia dekena bae laohai; badina be ia e kamonai Hesekia vada e gorerea ma vada e namo lou.
\v 2 Bena Hesekia ese e abidia dae, ena tohu namo-hereadia e habouva rumana na e haheitalaidia, \it silver\it*, \it gold\it*, muramura mai bonadia, dehoro namo-hereana, ena tuari ḡaudia iboudiai, bona ḡau iboudiai ena kohu-habou rumadia ai mimia; asi ḡauna ta ena ruma ai eiava ena tano ai Hesekia ese se haheitalaidia.
\p 
\v 3 Bena peroveta tauna Isaia na King Hesekia dekena ema, e nanadaia, eto, Unu tatau na dahaka e gwaurai? Bona ede amo oi dekemu ema? Hesekia eto, Gabu daudau amo vada ema, Babulono amo.
\v 4 Isaia ma eto, Oiemu ruma ai dahaka dahaka e ita? Hesekia ma e haere, eto, Ḡau iboudiai egu ruma ai na vada e itadia; asi ḡauna ta egu kohu-habou rumadia ai lau ese asina haheitalaidia.
\p 
\v 5 Bena Isaia ese Hesekia e hamaoroa, eto, Iehova ena hereva a kamonai:
\v 6 Dinadia vada e maimu, emu ruma kohudia iboudiai, senemu ese vada e haboudia ema bona hari dina, na Babulono bae laohaidia; ḡau ta basine mia. Iehova e gwaumu.
\v 7 Bona oi natumu haida, oi ese o havaradia memerodia, na bae laohaidia; idia na hesiai taudia ai baela, Babulono pavapavana ena ruma ai.
\v 8 Bena Hesekia ese Isaia e hamaoroa, eto, Iehova ena hereva oi ese vada o gwauraia na hereva namona. Badina be ia na ini e helalo toma, eto, Lauegu dina lalodiai maino bona noho-namo baemia.
\c 40
\s1 Iehova ena tauhalo herevadia
\q1 
\v 1 Emui Dirava na e tomu,
\q2 Egu bese na tauna ba haloa, tauna ba haloa.
\q1 
\v 2 Ierusalem ba hereva manada henia;
\q2 ba boi henia, ba hamaoroa,
\q1 ena tuari vada e ore,
\q2 bona ena kara havara vada eme hegwau tao,
\q1 bona Iehova imana amo
\q2 ena kara dika iboudiai davadia na vada e abi harua.
\b
\q1 
\v 3 Gado ta e boimu, e tomu,
\q2 Tano ḡaḡaena ai Iehova ena dala ba lailaia,
\q1 bona tano kaukauna ai laolao dalana ba hamaoromaoroa,
\q2 eda Dirava ena.
\q1 
\v 4 Koura iboudiai bae heabi isi,
\q2 ororo badadia bona ororo maraḡidia iboudiai bae hataora;
\q2 tano diho-dae bae hedaga maoro,
\q2 bona gabu gudu-isidia bae hataora.
\q1 
\v 5 Iehova hairaina baine hedinarai,
\q2 bona taunimanima iboudiai ese bae itaia,
\q2 badina be Iehova uduna vada e hereva.
\b
\q1 
\v 6 Gado ta e tomu, A boiboi! Bena lau nato, Dahaka baina boilaia?
\q1 Hidio idoinai na rei na heto,
\q2 bona ia hairaina idoinai na tano heraheradia na heheto.
\q1 
\v 7 Rei e kakoromu, herahera e maraimu,
\q2 Iehova ese e hahodi henidiamu negana ai;
\q2 momokani, taunimanima na rei mo.
\q1 
\v 8 Rei e kakoromu, herahera e maraimu;
\q2 a eda Dirava ena hereva baine gini hanaihanai.
\b
\q1 
\v 9 Sivarai namona Siona o gwaurai heniamu taumu e,
\q2 ororo latana ta ai ba dara dae,
\q1 Sivarai namona Ierusalem o gwaurai heniamu taumu e,
\q2 gadomu ba habadaia mai goadamu ida;
\q2 ba habadaia, basio gari.
\q1 Iuda hanuadia ba hamaorodia, baoto,
\q2 Emui Dirava ba itaia.
\q1 
\v 10 A itaia, Ḡaubada Iehova na mai siahuna ida e maimu,
\q2 ia imana na e lohiamu;
\q1 a itaia, dava na ienai,
\q2 bona ahu na ia vairanai.
\q1 
\v 11 Ia ese ena seri baine ubua, mamoe ireḡudia tauna na heto;
\q2 mamoe natudia na imana ai baine rosidia,
\q1 bona kemena ai baine rosidia lao,
\q2 bona e rogorogomu ḡaudia na metaira-metaira baine hakaudia.
\b
\s1 Israel ena Dirava na herea-dae
\q1 
\v 12 Daika ese imana nuana ai davara vada e hahetohoa,
\q2 bona imana kwakikwakina amo guba vada e hahetohoa?
\q1 Daika ese tanobada ḡahuna na hahetoho ḡauna ai vada e udaia,
\q2 bona ororo badadia na metau ihahetohona ḡauna ai vada e atoa,
\q2 bona ororo maraḡidia metaudia vada e hahetoho?
\q1 
\v 13 Daika ese Iehova ena Lauma vada e duanai henia,
\q2 eiava ena hahelao amo vada e hadibaia?
\q1 
\v 14 Ia ese daika e nanadaia, lalona ihadiarina totona?
\q2 Daika ese hahemaoro ḡoevaḡoeva dalana e hadibaia?
\q1 Daika ese aonega e hadibalaia,
\q2 bona lalo-parara dalana e haheitalaia?
\q1 
\v 15 A itaia, tanobada besedia na ranu hetuturuna tamona na heto,
\q2 hodu amo e hetuturu dobimu;
\q2 idia na ḡahu, metau ihahetohona ḡauna ai, na heto.
\q1 A itaia, motumotu na e abidia isimu,
\q2 ḡahu dimura-dimurana na heto.
\q1 
\v 16 Lebanon audia na basie heḡereḡere, au rakuraku ai baela,
\q2 bona ia boromakauna na basie heḡereḡere, ḡole-oho bouboudia ḡaudia ai baela.
\q1 
\v 17 Bese iboudiai na dia ḡau ta ia vairanai;
\q2 ia ese e haerodiamu, idia na dia ḡau ta, bona asi anidia.
\b
\q1 
\v 18 Dirava na daika ida ba haheḡereḡerea?
\q2 Ia ida-idana be daika?
\q1 
\v 19 Kaivakuku na ima-idibaka tauna ese e hahetariamu,
\q2 bona \it gold\it* iḡaukaralaina tauna ese \it gold\it* amo e ḡovaiamu,
\q2 bena ena \it silver\it* varodia e hahetaridiamu.
\q1 
\v 20 Ogoḡami tauna ese basine houka-houka auna e abia hidimu,
\q2 ena herahia ḡauna ai e halaoamu;
\q1 ia ese ima idibaka tauna ta e tahuamu,
\q2 kaivakuku ta, basine marere diba ḡauna, baine haginia totona.
\b
\q1 
\v 21 Umui na asi dibamui a? Asio kamonai a?
\q2 Matamana negana amo asie hamaoromui a?
\q1 Tanobada na ena gabu ai e haginia guna negana amo,
\q2 lalomui asie parara a?
\q1 
\v 22 Tanobada kuborona daenai e helaimu,
\q2 bona inoholaina taudia e nenediamu, ita-itadia kwadi na heto, Diravana,
\q1 ia ese guba e idia roromu, seseahu na heto,
\q2 e veria roromu, palai rumana na heto,
\q2 baine noholaia totona;
\q1 
\v 23 ia ese lohia na e hamorudiamu,
\q2 bona tanobada lohiadia e veridia dobimu.
\b
\q1 
\v 24 E hadodiamu, bena e kobomu,
\q2 bona ramudia e tubu matamamu;
\b
\q1 bena asi vanahana ia ese e hahodi henidiamu, bena e maraimu;
\q2 bena lai gubana ese e odadia ohomu, rei kakoro na heto.
\b
\q1 
\v 25 Helaḡa Diravana na e tomu, Daika ida ba haheḡereḡeregu,
\q2 bena ia ida baina heḡereḡere?
\q1 
\v 26 Ba gaga dae, ba itaia,
\q2 unu hisiu na daika ese e karadia?
\q1 Ia ese edia orea na ta ta amo e halasidiamu,
\q2 bona iboudiai ladadia e hatomu;
\q1 ena goada herea-daena amo,
\q2 bona ena siahu na bada dainai,
\q2 ta se boiomu.
\b
\q1 
\v 27 Iakob e, dahaka dainai o gwaumu,
\q2 Israel e, dahaka dainai o herevamu, o tomu
\q1 “Egu dala na Iehova ena amo eme hehuni,
\q2 egu Dirava ese ahugu korikorina se laloamu”?
\q1 
\v 28 Asi dibamu a? To kamonai a?
\q2 Iehova na noho-hanaiharlai Diravana;
\q2 ia na tanobada dokodia ikaradia Diravana.
\q1 Ia tauna se manorimu, se boeramu;
\q2 ena diba na ta ese basine davaria diba.
\q1 
\v 29 Manori taudia na ia ese e hagoadadiamu,
\q2 bona asi ena goada tauna enai goada e habadaiamu.
\q1 
\v 30 Uhau na taudia bae manori, bae boera;
\q2 eregabe na edia goada bae ore bena bae keto.
\q1 
\v 31 A Iehova e nariamu taudia ese edia goada bae hamatamata,
\q2 hanidia amo bae roho dae, ugava na heheto;
\q1 idia na bae heau, taudia basie boera,
\q2 bae raka, taudia basie manori.
\c 41
\s1 Dirava ena gwauhamata Israel enai
\q1 
\v 1 Kone tanodia e, asi reḡereḡemui a hakala henigu; q2 bese idau-idau ese edia goada bae hamatamata;
\q1 raka kahi mai, bena bae hereva;
\q2 baita raka kahi hebou, hahemaoro totona.
\b
\q1 
\v 2 Daika ese tau ta mairiveina kahana amo e hatorea isi?
\q2 Una tau na ena dala idoinai e kwalimu louloumu.
\q1 Ia ese basileia idau-idau na una tau vairanai e hadarerediamu,
\q2 bena una tau ese hanua pavapavadia na aena amo e moidia taomu;
\q1 ḡahu heḡereḡerena ai e halaodiamu, ena dare amo,
\q2 rei kakoro lai ese e odaiamu heḡereḡerena ai e halaoamu, ena peva amo.
\q1 
\v 3 E hahavadiamu, bena e raka e laomu mai namona ida;
\q2 ia ese do se rakalaidia daladia amo e laomu.
\q1 
\v 4 Ina na daika ese e havaraia bona e karaia,
\q2 bona matamana negana amo uru ta ta vada e boiridia?
\q1 Lau na Iehova; lau na gini-gunana,
\q2 bona lau na gini-gabena ida; Lau na Ia.
\b
\q1 
\v 5 Kone tanodia vada e itaia, bena e garimu;
\q2 tanobada dokodia na e heude-heudemu;
\q2 idia na vada e raka kahi mai.
\q1 
\v 6 Iboudiai ese ta ta dekena tauna dekena tauna e durudiamu,
\q2 bona tadikakadia e hamaorodiamu, e tomu:
\q2 A boga auka.
\q1 
\v 7 Ima idibaka tauna ese \it gold\it* iḡaukaralaina tauna e hagoadaiamu,
\q2 bona auri ihodo-palakana tauna ese haheato-kau aurina e hodoamutauna e hagoadaiamu;
\q1 auri ihahekamo-kubouna e herevalaiamu, e tomu “Ena na namo”,
\q2 bena idia ese ikoko amo e kokoamu, basine marere diba halaoreana.
\b
\q1 
\v 8 A oi, Israel, egu hesiai tauna,
\q2 Iakob, vada na abia hidi tauna,
\q2 turagu Abraham garana;
\q1 
\v 9 oi, tanobada dokodia amo na abimu
\q2 bona gunigunidia amo na boirimu taumu,
\q1 na hamaoromu, nato: Oi na egu hesiai tauna,
\q2 vada na abimu hidi, asina kahumu nege.
\q1 
\v 10 Basio gari, badina be lau na oi ida;
\q2 kudoumu basine hetaha, badina be lau na oiemu Dirava;
\q1 baina hagoadamu, baina durumu,
\q2 imagu idibana mai kwalimuna ida amo baina imudamu tao.
\b
\q1 
\v 11 A itaia, e badu henimumu taudia iboudiai na
\q2 bae hemarai bona bae baia;
\q1 e tuari henimumu taudia na
\q2 bae boio bona bae mase ore.
\q1 
\v 12 E heai henimumu taudia na ba tahudia,
\q2 to basio davaridia;
\q1 e tuari henimumu taudia na
\q2 bae boio vaitani.
\q1 
\v 13 Badina be lau Iehova, emu Dirava, ese
\q2 oi imamu idibana na dogoa taomu;
\q1 lau ese na hamaoromumu, na tomu:
\q2 Basio gari, baina durumu.
\b
\q1 
\v 14 Oi Iakob, biluga e, basio gari!
\q2 Israel taumui e, basio gari!
\q1 Iehova na e tomu “Baina durumui”.
\q2 Ihamaurimui na Israel ena Helaḡa Diravana.
\q1 
\v 15 A itaia, lau ese uit ikwadilaina auna ai baina halaomui,
\q2 matamatana, mai ganona bona mai isena;
\q1 ororo badadia ba kwadidia, ba hapatapatadia,
\q2 ororo maraḡidia na uit momoruna heḡereḡerena ai ba halaodia;
\q1 
\v 16 ba tapodia hidi, bena lai ese baine odadia oho,
\q2 lai gubana ese baine odadia rohoroho.
\q1 Bena Iehova ba moalelaia,
\q2 Israel ena Helaḡa Diravana ba imodaia.
\b
\q1 
\v 17 Ogoḡami taudia bona e dabumu taudia na ranu bae tahua, bena basie davaria,
\q2 a gadodia bae kaukau ranu-mase dainai;
\q1 una negana ai lau Iehova ese baina haere henidia,
\q2 lau, Israel Diravana, ese basina rakatanidia.
\q1 
\v 18 Ororo nemuka-nemukadia ai sinavai baina ha-arudia,
\q2 bona koura lalodiai ranu lohilohi gabudia baina kehodia;
\q1 tano ḡaḡaena na gohu ai baina halaoa,
\q2 bona tano kaukauna na ranu lohilohi gabuna ai baina halaoa.
\q1 
\v 19 Tano ḡaḡaena ai sida audia baina hado,
\q2 bona kela bona keroro bona olive audia danu;
\q1 tano kaukauna ai beroso bona tidara bona teasuru\f + \fr 41:19 \ft Beroso, tidara, teasuru. Ini na au haida ladadia, Heberu taudia edia gado ai.\f* audia
\q2 baina hadodia hebou.
\q1 
\v 20 Bena taunimanima ese bae itaia, bena bae diba,
\q2 bae haeroa hebou bena lalodia bae parara,
\q1 Iehova imana ese ina na vada e karaia,
\q2 Israel ena Helaḡa Diravana ese vada e havaraia.
\b
\s1 Iehova ese dirava koikoidia e guru henidia
\q1 
\v 21 Iehova na e tomu, Emui ginikau herevadia a gwaurai hedinarai;
\q2 Iakob ena pavapava na e tomu, Emui hereva ba hamomokanidia.
\q1 
\v 22 Ihamomokanina herevadia bae mailai,
\q2 bona dahaka baine vara bae hadibalaida.
\q1 Nega gunadia ḡaudia ba hamaorolai henimai,
\q2 bena baia haerodia,
\q1 bena baia diba dahaka dahaka na edia amo bae vara;
\q2 eiava do bae vara ḡaudia ba hamaorolai henimai.
\q1 
\v 23 Kerukeru vanegai bae vara ḡaudia ba hadibalaimai,
\q2 bena baia diba umui na didirava;
\q1 kara namo eiava kara dika ba kara,
\q2 bena baia gari, kudoumai bae hetaha.
\q1 
\v 24 A itaia, umui na dia ḡau ta,
\q2 emui ḡaukara na asi anina,
\q2 e abimui hidimu tauna na dika rohoroho.
\b
\q1 
\v 25 Mirigini kahana amo tau ta na hatorea isi, bena vada ema,
\q2 dina e daemu kahana amo, bena ia ese lau ladagu baine hahanea;
\q1 ia ese lohia baine moimoilaidia,
\q2 raro nadidia ihahekamo-taodia ḡauna e moimoilaiamu na heto,
\q2 uro ikarana tauna ese raro e kuiamu na heto.
\q1 
\v 26 Daika ese matamana amo e gwauraia,
\q2 baita diba helaoreana?
\q1 Daika ese e gwaurai guna,
\q2 baitato “Ia na maoro” helaoreana?
\q1 Ta ese se herevalaia,
\q2 ta ese se gwauraia hedinarai,
\q2 ta ese emui hereva se kamonaidia.
\q1 
\v 27 Siona vada na gwaurai henia guna, q2 sivarai namo igwauraina tauna ta Ierusalem na heniamu.
\q1 
\v 28 A na roha heniamu negana ai tau ta asina itaiamu;
\q2 idia bogaragidiai asi hahealo tauna ta na henanadaimu negana ai e haere henigumu.
\q1 
\v 29 A itaia, iboudiai na lalo-haguhi asi anidia,
\q2 edia ḡaukara danu asi anidia,
\q2 edia auri kaivakukudia na lai mo, asi anidia.
\c 42
\s1 Iehova ena hesiai tauna
\q1 
\v 1 Egu hesiai tauna a itaia; lau ese na imudaiamu.
\q2 Ia na egu abi-hidi tauna; lau laumagu ese e moalelaiamu.
\q1 Lauma ese e roheamu;
\q2 ia ese hahemaoro ḡoevaḡoeva na bese idau-idau baine halasi henidia.
\q1 
\v 2 Ia na basine lolo, gadona basine habadaia,
\q2 eiava ariara ai ia erena basie kamonai;
\q1 
\v 3 siriho pou basine hakwaidua,
\q2 bona gida basine habodoa;
\q1 na hahemaoro ḡoevaḡoeva baine halasia
\q2 mai momokanina ida.
\q1 
\v 4 Ena diari basine bodo; ia na basine helou kwaidu,
\q2 ela bona hahemaoro ḡoevaḡoeva na tanobada ai baine haginia,
\q2 bona kone tanodia ese iena taravatu bae laroa.
\b
\q1 
\v 5 Dirava Iehova, guba e karaia bona e idia roro Diravana,
\q2 tanobada e lahaia bona anina e havaramu Diravana,
\q1 tanobada ai e nohomu taudia na laḡa e henidiamu
\q2 bona lalonai e loamu taudia na lauma e henidiamu Diravana,
\q2 ini e gwau tomamu:
\q1 
\v 6 Lau na Iehova; kara maoromaoro ai vada na boirimu,
\q2 oi imamu vada na abia, vada na reḡumu;
\q1 gwahamata toana ai vada na halaomu bese idau-idau ediai,
\q2 bona diari ai vada na halaomu basileia idau-idau ediai,
\q1 
\v 7 mata-kepulu taudia matadia ihapapadia totona,
\q2 bona iḡui taudia na hekou kunuka-kunuka rumana amo
\q1 bona dibura ai e helaimu taudia na dibura rumana amo
\q2 ba hakaudia lasi totona.
\q1 
\v 8 Lau na Iehova, ladagu bunai;
\q2 hairaigu na ta asina heniamu,
\q2 i'imodaigu na e koro kaivakukudia asina henidiamu.
\q1 
\v 9 A itaia, ḡau gunadia vada e vara,
\q2 harihari ḡau matamatadia na gwaurai hedinaraimu;
\q1 idia na do asie hedinarai negana ai
\q2 na hamaorolaimuimu.
\b
\s1 Iehova i'imodaina
\q1 
\v 10 Ane matamatana avabia, Iehova ena;
\q2 tanobada dokona amo ia ba imodaia.
\q1 Davara baine guru, mai anina idoinai ida;
\q2 kone tanodia danu, mai inoholaidia taudia ida.
\q1 
\v 11 Tano ḡaḡaena mai hanuana hidaosi ida, gadodia bae habada,
\q2 Kedara ese e noholaidiamu hanuadia danu.
\q1 Sela inoholaina taudia ese moale anedia bae abi,
\q2 ororo doridia amo bae lolo.
\q1 
\v 12 Idia ese Iehova bae imodaia,
\q2 ia iheatolaina herevadia na kone tanodia ai bae gwaurai henidia.
\q1 
\v 13 Iehova na e raka lasimu, goada-herea tauna na heto,
\q2 tuari tauna na heto ena badu e hasiahuamu;
\q1 e boi lolomu, e lolo badabadamu,
\q2 ia inaina ihadikadia ai ena goada e hahedinaraiamu.
\b
\q1 
\v 14 Nega daudau asi reḡereḡegu vada na noho;
\q2 asina marere, na haheauka.
\q1 Harihari baina tai lolo, e hekamonaimu hahinena na heto,
\q2 baina laḡa dae laḡa dae, baina ḡanaḡana.
\q1 
\v 15 Ororo badadia bona maraḡidia baina havahudia,
\q2 latadiai e varamu ḡaudia iboudiai baina hakakorodia;
\q1 sinavai na motumotu ai baina halaodia,
\q2 gohu na baina hakororodia.
\q1 
\v 16 Mata-kepulu taudia na baina hakaudia,
\q2 asi dibadia dalana ai;
\q1 do asie dibadia daladia lalodiai
\q2 lau ese baina hakaudia.
\q1 Dibura na diari ai baina halaoa idia vairadiai;
\q2 gabu gudu-isidia na tano hedaga-maorodia ai baina halaodia.
\q1 Baina kara ḡaudia bini,
\q2 basina rakatanidia.
\q1 
\v 17 E koro kaivakukudia e abidadama henidiamu,
\q2 bona e hahetaridia kaivakukudia e hamaorodiamu, e tomu
\q2 “Umui na emai dirava”,
\q1 taudia na baina haloudia,
\q2 bona baina hahemaraidia vaitani.
\b
\s1 Israel ena taia-kudima
\q1 
\v 18 Taia-kudima taumui, a kamonai!
\q2 Mata-kepulu taumui, a gaga isi, ḡau ba ita totona!
\q1 
\v 19 Daika matana e kepulumu? Lauegu hesiai tauna mo.
\q2 Daika taiana e kudimamu, egu gwaukau ilaohaina na siaiamutauna heḡereḡerena?
\q1 Daika matana e kepulumu, egu helaḡa tauna heḡereḡerena?
\q2 Daika mata e kepulumu, Iehova ena hesiai tauna heḡereḡerena?
\q1 
\v 20 Ḡau momo e itamu, to se matadia davarimu;
\q2 taiana e kiraramu, to se kamonaimu.
\q1 
\v 21 Iehova na e moaleva, ena kara maoromaoro dainai,
\q2 ena taravatu ihanamona bona i'imodaina helaoreana.
\q1 
\v 22 A ina na vada e henaodia bona e dadidia besena;
\q2 iboudiai na rikiriki guridia ai e heabi,
\q2 bona dibura rumadia ai vada e hehuni.
\q1 Idia na damu ai vada ela, asi iharoho-mauridia;
\q2 idia na dina ai vada ela, ta basineto “A kahudia nege”.
\q1 
\v 23 Umui bogaragimui ai daika ese ina hereva baine hakala henia?
\q2 Daika baine hakala? Daika baine kamonai, baine gini dae negana dainai?
\q1 
\v 24 Daika ese Iakob na dadidadi taudia e henidia?
\q2 Daika ese Israel na henao taudia e henidia?
\q1 Iehova, vada ta kara dika henia Diravana, ese ani?
\q2 Idia na ena dala irakalaidia asie ura,
\q2 bona ena taravatu ikamonaina asie uralaia.
\q1 
\v 25 Taunabunai ia ese ena badu ḡaraḡarana na ia latanai e bubua,
\q2 bona tuari siahuna danu;
\q1 a e doua heḡeḡe, to lalona se parara;
\q2 vada e araia, to se haeroa namonamo.
\c 43
\s1 Ihamaurida na Iehova mo
\q1 
\v 1 Iakob e, e havaramu Diravana,
\q2 Israel e, e karamu Diravana,
\q1 Iehova, harihari ini e gwau tomamu:
\q2 Basio gari, badina be lau ese vada na hamaurimu;
\q2 ladamu vada na hatoa, oi na lauegu.
\q1 
\v 2 Ranu lalodia amo ba hanai negana ai, lau na oi ida;
\q2 sinavai lalodia amo ba hanai negana ai na basie habubunimu;
\q1 lahi amo ba raka hanai negana ai, basio heara;
\q2 lahi hururu-hururuna ese basine golemu oho.
\q1 
\v 3 Badina be lau na Iehova, emu Dirava,
\q2 Israel ena Helaḡa Diravana, oi Ihamaurimu.
\q1 Aigupto na henimu, oiemu mauri davana,
\q2 Etiopia bona Seba na henimu, oi ibodohilaimu.
\q1 
\v 4 Badina be oi davamu na bada lau vairagu ai;
\q2 na matauraimumu, na ura henimumu;
\q1 taunimanima na henimu, oi davamu,
\q2 bona bese na henimu, oiemu mauri ibodohilaina.
\q1 
\v 5 Basio gari, badina be lau na oi ida;
\q2 oi garamu na laurabada kahana amo baina hakaudia mai,
\q2 bona lahara kahana amo baina haboumui.
\q1 
\v 6 Mirigini kahana baina hamaoroa, bainato “A kahudia nege”,
\q2 bona diho kahana baina hamaoroa, bainato “Asio rudia”;
\q1 natugu mamaruanedia na dauha amo
\q2 bona natugu hahinedia na tanobada dokona amo
\q2 ba hakaudia mai;
\q1 
\v 7 lau ladagu e henemailaidia taudia iboudiai,
\q2 ihahairaidia totona na havaradia, na karadia bona oromadia na henidia taudia.
\b
\q1 
\v 8 Mai matadia to matadia e kepulumu taudia,
\q2 mai taiadia to taiadia e kudimamu taudia,
\q2 a hakaudia lasi.
\q1 
\v 9 Basileia iboudiai bae hegogo,
\q2 bese idau-idau bae hebou.
\q1 Idia bogaragidiai daika ese ina na baine gwauraia?
\q2 Daika ese ḡau gunadia baine haheitalaida?
\q1 Edia hereva ihamomokanidia taudia bae mailaidia, igwaurai-maorodia totona;
\q2 bae kamonai, bena baeto “Hereva momokanina”.
\q1 
\v 10 Iehova na e tomu: Umui na egu hereva ihamomokanidia taumui;
\q2 umui na egu hesiai, vada na abimui hidi,
\q1 ba dibagu bona bavabiabiraigu totona,
\q2 bona lalomui bae parara Lau na Ia.
\q1 Asi dirava ta ese lau e gunalaigu,
\q2 bona lau murigu ai danu dirava ta basine hedinarai.
\q1 
\v 11 Lau binai Iehova,
\q2 asi ihamaurimui ta, lau mo sibogu.
\q1 
\v 12 Iehova na e tomu:
\q2 Idau dirava ta lasi bogaragimui ai negana ai,
\q1 na herevava, na hahemauriva, na gwaurai hedinaraiva;
\q2 bona umui na egu hereva ihamomokanidia taumui.
\q1 
\v 13 Lau na Dirava; ina harihari amo ela Lau na Ia;
\q2 ta ese lau imagu amo basine harohomui mauri diba.
\q1 Lau na ḡaukaramu:
\q2 daika ese egu ḡaukara ilao-ahuna mai dibana?
\b
\q1 
\v 14 Ihamaurimui, Israel ena Helaḡa Diravana,
\q2 Iehova, ini e gwau tomamu:
\q1 Umui daimui ai haida na Babulono baina siaidia lao,
\q2 bona auri iboudiai baina hakwaidudia;
\q2 bena Kaldea taudia edia hone na
\q2 taitai ai bainela.
\q1 
\v 15 Lau na Iehova, emui Helaḡa Diravana,
\q2 Israel Ihavarana, emui Pavapava.
\q1 
\v 16 Iehova na unu e gwau tomamu;
\q2 ia ese dala e lailaiamu davara lalonai,
\q2 davara badadia lalodiai danu.
\q1 
\v 17 Ia ese kariota bona hosi e hakaudia lasimu,
\q2 bona tuari oreana bona tuari taudia danu;
\q1 idia na e hekuremu, basie tore isi diba;
\q2 idia na e bodomu, gida e bodomu na heto.
\q1 
\v 18 Ḡau gunadia basio lalodia tao,
\q2 nega gunadia basio haerodia.
\q1 
\v 19 A itaia, ḡau matamatana na karaiamu,
\q2 harihari e hedinaraimu; asio itaiamu a?
\q1 Lau ese dala ta tano ḡaḡaena ai baina karaia,
\q2 bona sinavai baina kara, tano kaukauna ai.
\q1 
\v 20 Uda boromadia ese bae imodaigu,
\q2 uda sisiadia bona kokokoko ese danu;
\q1 badina be tano ḡaḡaena ai ranu na henimu,
\q2 bona sinavai tano kaukauna ai danu,
\q2 egu abi-hidi besena ranu baina henia totona.
\q1 
\v 21 Besena bunai vada na karaia egu,
\q2 lau i'imodaigu herevadia bae gwaurai totona.
\b
\q1 
\v 22 Ḡau tamona, Iakob e, oi ese so boi henigu;
\q2 Israel e, egu ai vada o hesiku.
\q1 
\v 23 Emui mamoe na egu ai asio mailaidia, ḡole-oho ḡaudia ai baela totona;
\q2 emui boubou ḡaudia amo asio imodaigu.
\q1 Lau na boubou karadia amo asina hametaumui,
\q2 bona muramura mai bonana dainai asina hahesikumui.
\q1 
\v 24 Egu kane\f + \fr 43:24 \ft Kane: Heberu taudia edia muramura mai bonana ta.\f* asio hoi;
\q2 emui boubou ḡaudia digaradia asio henigu davana.
\q1 A emui kara dika amo vada o hametaugu,
\q2 bona emui kara havara amo vada o hahesikugu.
\b
\q1 
\v 25 Lau na emui kerere e abidia ohomu Diravana, lau sibogu daigu ai;
\q2 emui kara dika na basina lalodia tao.
\q1 
\v 26 Ba hahelalogu une, baita hedorilai heheni;
\q2 emui gini-kau gabuna ba gwauraia hedinarai, bae gwauraimui maoro totona.
\q1 
\v 27 Emui bese ihavarana tauna vada e kara dika,
\q2 bona emui peroveta taudia ese e kara havara henigu.
\q1 
\v 28 Emui pavapava ese egu gabu helaḡana e hamiroa;
\q2 taunabunai, Iakob na habuaia tari vaitani,
\q2 bona Israel na ḡonaḡonalaia.
\c 44
\s1 Dirava tamona na Iehova
\q1 
\v 1 Iakob e, egu hesiai tauna,
\q2 Israel e egu abi-hidi tauna, a kamonai!
\q1 
\v 2 Iehova, ikaramu Diravana,
\q2 sinamu bogana ai e hadudumu
\q1 bona do baine durumu Diravana,
\q2 ini e gwau tomamu:
\q1 Iakob e, egu hesiai tauna,
\q2 Iesurunu e, egu abi-hidi tauna, asio gari.
\q1 
\v 3 Badina be lau ese ranu na tano haura-haurana latanai baina seia diho,
\q2 bona sinavai na tano kaukauna latanai danu;
\q1 egu Lauma na oi garamu latadiai baina seia,
\q2 bona egu hahenamo na oi vevemu latadiai danu.
\q1 
\v 4 Idia na bae tubu, rei na heto, ranu gabudia ai e tubumu,
\q2 eiava au na heto, e arumu sinavaidia badibadidiai e tubumu.
\q1 
\v 5 Ta baineto “Lau na Iehova ena”,
\q2 ma ta be sibona Iakob ladana baine henemailai;
\q1 ma ta ese imana ai baine torea “Iehova ena”,
\q2 bona sibona ladana baine hehato Israel.
\b
\q1 
\v 6 Iehova, Israel pavapavana,
\q2 bona Ihamaurina, Iehova Sabaota,
\q2 ini e gwau tomamu:
\q1 Lau na gini-gunana bona gini-gabena;
\q2 asi dirava ta, lau mo sibogu.
\q1 
\v 7 Daika na lau heḡereḡeregu? Ia ese baine gwauraia hedinarai;
\q2 lau vairagu ai baine herevalaia bona baine hahedinaraia.
\q1 Daidia ese do bae vara ḡaudia na nega gunadia amo e gwaurai?
\q2 Idia ese do bae vara ḡaudia na ma bae gwaurai henida.
\q1 
\v 8 Asio gari, kudoumui basie hetaha;
\q2 nega gunadia amo asina hamaoromui bona asina gwauraia hedinarai a?
\q2 Bona umui na egu hereva ihamomokanidia taumui.
\q1 Dirava idauna ta e nohomu a?
\q2 Asi Nadi-ginina ta; ta asi dibagu.
\b
\s1 Kaivakuku
\p 
\v 9 Kaivakuku e karamu taudia na asi anidia, bona e moalelaimu ḡaudia ese asie hanamodiamu; ihamomokanidia taudia ese ḡau asie itamu bona asie dibamu, taunabunai bae hahemaraidia.
\v 10 Daika ese dirava asi anina ta e karaiamu eiava laulau asi anina ta e hahetariamu?
\v 11 A itaia, ia bamona iboudiai na bae hahemaraidia; bona ima idibaka taudia na taunimanima mo. Iboudiai na bae hebou, bae gini lasi; gari ese baine butudia tao, bona bae hemarai bou.
\p 
\v 12 Auri iḡaukaralaina tauna ese gida mai lahidia latadiai e gaukaralaiamu; hodohodo auridia amo e hodoamu, bona imana goadana amo oromana e karaiamu; e hitoloamu, bena ena goada e oremu; ranu se inumu, bena tauna e manorimu.
\p 
\v 13 Kamuta tauna ese ena hahetoho varona e veria roromu, bona puri amo toana e toremu; naunau auridia amo e nauamu, bona kuboro-hahetohona aurina amo e hahetohoa heḡeḡemu. Bena e koroamu, tau oromana ai, tau raho-namona heḡereḡerena ai, ruma ai baine hamiaia e tomu.
\p 
\v 14 Ia ese sida audia e hagaridiamu; eiava budabuda eiava diharoha e abia hidimu, e nariamu ela bona baine kiriri, uda audia padadiai; sida auna ta danu e hadoamu, bena medu ese e hatubuamu.
\v 15 Bena tau ta ese ena lahi auna ai e halaoamu; kahana e ha-araiamu sibona e heganamu, makahana e ha-araiamu, flaoa e gabulaiamu. Bena ena dirava ta e karaiamue toma henia dihomu; laulau ta e koroamu, vairanai e igo dihomu.
\v 16 Kahana na lahi ai e araiamu; ma kahana latanai ana vamu e gabuamu; e gabuamu ḡauna e aniamu, bogana e kunumu. E heganamu danu, e tomu “Aha! Taugu na e siahumu, lahi vada name itaia.”
\v 17 Bena au orena na dirava ta e karalaiamu, ena kaivakuku; bena vairanai e igo dihomu, e toma henia dihomu; e guriamu, e tomu “A hamaurigu, badina be oi na egu dirava”.
\p 
\v 18 Idia na asi dibadia, lalodia na asie pararamu; badina be ia ese matadia vada e hakapudia, bena basie itaia diba, bona lalodia vada e haduhudia, bena lalodia na basie parara diba.
\v 19 Ta ese lalona se hadaiamu, ta asi aonegana eiava asi lalo-pararana, bena e tomu: Kahana na lahi ai vada na araia; bona gida latadiai ilaoa bona vamu vada na gabudia, vada na aniani; matona, orena amo ḡau dika-hereana baina karaia a? Au kavakava vairanaibaina toma diho a?
\v 20 Ia na kahu e animu; ena lalo-duhu ese vada ehakaua kerere. Asi ena dala sibona baine hahemauri, eiava baineto “Imagu idibana ai koikoi na dia mia a?”
\b
\s1 Iehova na Israel Ihamaurina
\q1 
\v 21 Iakob e, ini ḡau ba lalodia tao;
\q2 Israel e, ba lalodia tao, badina be oi na egu hesiai tauna.
\q1 Lau ese vada na karamu; oi na egu hesiai tauna;
\q2 Israel e, basina lalomu boio.
\q1 
\v 22 Emu kara kereredia vada na abidia oho, ori na heto,
\q2 bona emu kara dikadia, ninoa na heto;
\q1 a lou henigu,
\q2 badina be lau ese vada na hamaurimu.
\b
\q1 
\v 23 Guba e, ane avabia, badina be Iehova ese vada e haḡuḡurua;
\q2 tanobada ena dobu gabudia e, a lolo!
\q1 Ororo e, ane a lada isi;
\q2 oi danu, uda e, mai aumu iboudiai.
\q1 Badina be Iehova ese Iakob vada e hamauria,
\q2 bona Israel lalonai bae imodaia.
\b
\q1 
\v 24 Iehova, oi Ihamaurimu Diravana,
\q2 sinamu bogana ai e hadudumu Diravana,
\q2 ini e gwau tomamu:
\q1 Lau binai Iehova; ḡau iboudiai na karadia;
\q2 lau sibogu ese guba na idia roro;
\q1 lau ese tanobada na idia roro;
\q2 daika na lau ida?
\q1 
\v 25 Lau ese koikoi taudia edia toa na gwau tubumu,
\q2 bona mari-abi taudia na hakavakavadiamu;
\q1 aonega taudia na haloudiamu,
\q2 bona edia aonega na kavakava ai na halaoamu.
\q1 
\v 26 Lau ese egu hesiai tauna ena hereva na hamomokaniamu,
\q2 bona egu gwaukau taudia edia hahealo heḡereḡerena ai na karaiamu.
\q1 Ierusalem na herevalaiamu, na tomu
\q2 “Haida ese bae noholaia”;
\q1 bona Iuda hanuadia na herevalaidiamu, na tomu
\q2 “Do bae gini; vada e heḡiḡi rohoroho ḡaudia na
\q2 lau ese baina haginidia lou”.
\q1 
\v 27 Gadobada na hamaoroamu, na tomu
\q2 “A kororo; emu sinavai baina hakororodia”.
\q1 
\v 28 Lau ese Kurese na herevalaiamu, na tomu
\q2 “Ia na egu mamoe ireḡudia tauna,
\q2 bona ia ese egu lalo-hadai idoinai baine haḡuḡurua”;
\q1 bona Ierusalem na herevalaiamu, na tomu “Baine gini”,
\q2 bona Dubu Helaḡa na hamaoroamu, na tomu “Badimu baine heato”.
\c 45
\s1 Kurese herevana
\q1 
\v 1 Iehova ena hereva, e horoa tauna Kurese enai;
\q2 ia imana idibana vada na kahua tao,
\q1 bese idau-idau na ia vairanai baina hadareredia
\q2 bona pavapava baina hamanokadia totona,
\q1 iduara na ia vairanai baina kehodia
\q2 bona ikoukou na basie hekou helaoreana.
\b
\q1 
\v 2 Lau na oi vairamu ai bainala,
\q2 ororo baina hahedagadia maoro;
\q1 auri labora-labora iduaradia baina hamakohidia rohoroho,
\q2 pbona auri baina utudia parara.
\q1 
\v 3 Dibura gabudia kohudia baina henimu,
\q2 bona gabu hehunidia ai e habou ḡaudia;
\q2 bena ba diba lau Iehova, Israel Diravana, ese
\q2 oi ladamu vada na hatoa.
\q1 
\v 4 Egu hesiai tauna Iakob,
\q2 egu abi-hidi tauna Israel, dainai,
\q2 oi ladamu na hatoamu;
\q1 be asi dibamu lau,
\q2 to ladamu ta na hahenemailaimu.
\b
\q1 
\v 5 Lau binai Iehova, idauna ta na lasi;
\q2 asi dirava ta, lau mo sibogu.
\q1 Ena be asi dibamu lau,
\q2 to lau ese na hagoadamumu;
\q1 
\v 6 bena dina-dae kahana amo bona dina-diho kahana amo,
\q2 taunimanima na bae diba idauna ta na lasi;
\q2 lau binai Iehova, idauna ta na lasi.
\q1 
\v 7 Diari na karaiamu, bona dibura na havaraiamu;
\q2 namo na karaiamu, bona dika na havaraiamu;
\q2 lau na Iehova, ini ḡau iboudiai na karamu.
\b
\s1 Iehova, ḡau iboudiai ihavaradia
\q1 
\v 8 Guba e, kara maoromaoro ba hadihoa;
\q2 guba amo baine diho, medu na heto.
\q1 Tanobada baine parara, hahemauri baine tubu dae totona;
\q2 kara maoromaoro danu baine hatubua dae;
\q2 lau Iehova ese vada na havaraia.
\b
\q1 
\v 9 Ia ikarana Diravana e heai heniamu tauna, madi ihabaina;
\q2 ia na uro ikarana tauna e heai heniamu urona na heto!
\q1 o ese iḡaukaralaina tauna e gwau heniamu a?
\q2 E tomu “Dahaka o karamu?” eiava “O karaiamu ḡauna na asi imana” a?
\q1 
\v 10 Tama ta e hamaoroamu, e tomu “Dahaka o havaraiamu?”
\q2 eiava hahine ta e hamaoroamu, e tomu “Dahaka ḡau na bogamu ai?”
\q2 tauna na madi ihabaina!
\b
\q1 
\v 11 Iehova, Israel ena Helaḡa Diravana bona Ikarana Diravana,
\q2 ini e gwau tomamu:
\q1 nanadaigu natugu daidiai,
\q2 eiava ba haḡanigu imagu ese e kara ḡaudia daidiai, a?
\q1 
\v 12 Lau ese tanobada na karaia,
\q2 bona taunimanima na havaradia ia latanai;
\q1 imagu ese guba e idia roro,
\q2 bona ena orea iboudiai na haḡanidia.
\q1 
\v 13 Lau ese kara maoromaoro ai vada na hatorea isi,
\q2 bona ena dala iboudiai baina hamaoromaorodia;
\q1 ese egu hanua badana baine haginia,
\q2 bona dauhai na hanohodia tao taudia baine ruhadia nege,
\q1 dava dainai eiava hahenamo ihalouna dainai;
\q2 Iehova Sabaota na unu e gwau tomamu.
\b
\q1 
\v 14 Iehova na ini e gwau tomamu:
\q2 Aigupto ena taḡa bona Etiopia ena hoihoi ḡaudia,
\q2 bona Sabea taudia, taunimanima ḡaulatalatadia,
\q1 oiemu ai bae hanai, oiemu taunimanima ai baela,
\q2 oi murimu ai bae raka;
\q1 gadeadia ida emu ai bae hanai,
\q2 bona bae toma henimu diho.
\q1 noi henimu, baeto:
\q2 Dirava na oi mo ida, idauna ta na lasi;
\q2 asi dirava ta, ia mo sibona.
\q1 
\v 15 Momokani, oi na o noho hehunimu Diravana;
\q2 Israel Diravana, Hahemauri Diravana.
\q1 
\v 16 Idia iboudiai na bae hemarai bona bae baia;
\q2 kaivakuku ikaradia taudia na mai lalo-heḡonudia ida e raka heboumu.
\q1 
\v 17 A Israel na Iehova ese vada e hamauria,
\q2 vada e hamauria hanaihanai;
\q1 oi na basio hemarai bona basio baia,
\q2 ela bona hanaihanai.
\b
\q1 
\v 18 Badina be Iehova, guba ikarana Diravana,
\q2 ini e gwau tomamu.
\q1 Ia na Dirava;
\q2 ia ese tanobada e hadaia bona oromana e henia,
\q2 bona e haginia tutuka-tutuka;
\q1 ia ese se karaia ḡau asi oromana,
\q2 a haida ese bae noholaia totona e karaia.
\q1 Ia na e tomu: Lau na Iehova;
\q2 idauna ta na lasi.
\q1 
\v 19 Lau asina hereva hehuni
\q2 dibura tanona ai;
\q1 Iakob garana asina hamaorodia, asinato
\q2 “Gabu asi oromana ai ba tahugu”.
\q1 Lau Iehova na hereva momokanimu;
\q2 hereva maoromaorona na gwauraiamu.
\b
\s1 Babulono Kaivakukudia
\q1 
\v 20 Basileia kwabukwabumui e, a hegogo mai;
\q2 ba raka kahi hebou.
\q1 Edia au kaivakukudia e loalaidiamu taudia na asi aonegadia;
\q2 ihamauridia asi dibana diravana na idia ese e ḡuria louloumu.
\q1 
\v 21 Emui gini-kau herevana ba gwauraia hedinarai;
\q2 idia ese bae henegalaia hebou.
\q1 Ina na daika ese nega gunana ai e gwauraia?
\q2 Daika ese idau nega ai e gwauraia hedinarai?
\q1 Lau Iehova, ani?
\q2 Asi dirava idauna ta, lau mo sibogu;
\q1 Kara Maoromaoro Diravana, Hahemauri Diravana,
\q2 idauna ta na lasi.
\b
\q1 
\v 22 Tanobada dokodia iboumui ai,
\q2 lau ba haḡeregu, bena ba mauri;
\q2 badina be lau na Dirava, idauna ta na lasi.
\q1 
\v 23 Lau sibogu daigu ai vada na gwau hamata;
\q2 basine lou herevana na kara maoromaoro ai lau udugu amo vada e lasi,
\q1 e tomu “Lau vairagu ai tui iboudiai bae hadai,
\q2 bona mala iboudiai bae gwau hamata”.
\q1 
\v 24 Bae herevalaigu, baeto:
\q2 Kara maoromaoro bona goada na Iehova mo enai;
\q1 e badu heniamu taudia iboudiai na
\q2 ia dekena baema, bena bae hemarai.
\q1 
\v 25 Israel garana iboudiai na Iehova bagunai bae kwalimu,
\q2 bona ia bae imodaia.
\c 46
\q1 
\v 1 Bel e igo dihomu, Nebo e toma dihomu;
\q2 kaivakukudia na doniki bona boromakau dorudiai;
\q1 hari o loalaidiamu ḡaudia na
\q2 tau-boera donikidia edia maduna metaudia ai vada o halaodia.
\q1 
\v 2 Idia na e toma dihomu, e igo dihomu,
\q2 maduna metauna irauana na asi dibadia,
\q2 a idia sibodia e laomu, vada bae ḡuidia.
\b
\q1 
\v 3 Iakob ena iduhu e,
\q2 Israel ena iduhu taumui kwabukwabumui e,
\q2 a kamonai henigu!
\q1 O vara dinana amo lau ese vada na abimui loaloa,
\q2 sinamui bogadia amo vada na rosimui eva-eva;
\q1 
\v 4 ela bona ba iahu ai, lau na Ia;
\q2 ela bona huimui bae buruka, lau ese baina rosimui eva-eva.
\q1 Vada na karamui, vada baina abimui loaloa,
\q2 baina rosimui eva-eva, bona baina hamaurimui.
\b
\q1 
\v 5 Daika ida ba lalolaigu hebou, bena ba haheḡereḡeremai?
\q2 Daika ida ba haerolaigu hebou, bena baia heḡereḡere?
\q1 
\v 6 \it Gold\it* na moda amo e vaiamu
\q2 bona \it silver\it* na metau-hahetoho ḡauna ai e hahetohoamu taudia ese
\q2 \it gold\it* iḡaukaralaina tauna ta e vatuamu,
\q2 bena ia ese dirava ta e karalaiamu;
\q1 bena idia na e goru dihomu,
\q2 e tomu henia dihomu.
\q1 
\v 7 Idia ese e abia isimu, pagadia ai e atoamu,
\q2 e huaia laomu, bena gabuna ai e haginiamu;
\q1 a unuseni ai e miamu,
\q2 ena gabu amo basine raka oho diba.
\q1 Ta ese baine tai henia, to ia na basine haere,
\q2 bona hekwakwanai amo basine harohoa mauri.
\b
\q1 
\v 8 Ina ba laloa tao bona ba haeroa;
\q2 kerere taumui e, ba helalolaia une,
\q2 
\v 9 nega gunadia ḡaudia ba lalodia tao;
\q1 badina be lau na Dirava, idauna ta na lasi;
\q2 lau na Dirava, asi idaigu.
\q1 
\v 10 Matamana negana ai dokona na gwauraia,
\q2 bona nega gunadia ai do asie vara ḡaudia na gwaurai guna;
\q1 nato “Egu hahealo baine mia,
\q2 bona egu lalo-hadai idoinai baina haḡuḡurua”.
\q1 
\v 11 Kasiri aniani manuna ta mairiveina kahana amo na boiria,
\q2 bona egu hahealo tauna danu, tano daudau amo.
\q1 Vada na hereva, bona anina baina havaraia;
\q2 vada na laloa hata, bona baina karaia.
\b
\q1 
\v 12 Lalo-auka taumui e, a kamonai henigu;
\q2 irauamui dalana na daudau.
\q1 
\v 13 Lau ese rauaraua na vasilaiamu; ia na dia daudau;
\q2 egu hahemauri na basine halahe;
\q1 hahemauri na Siona ai baina atoa,
\q2 bona hairaigu na Israel baina henia.
\c 47
\s1 Hahemaoro Babulono latanai
\q1 
\v 1 Babulono hane-ulato rami-hebouna e,
\q2 aoma, gahu ai ba helai.
\q1 Kaldea natuna hahinena e,
\q2 tano ai ba helai, asi emu lohia helai ḡauna.
\q1 Badina be tau-anina manada-manada bona aniani inonoḡadia ianidia hahinena na
\q2 basie gwauraimu lou.
\q1 
\v 2 Huro nadidia avabi, uit ba idi patapata;
\q2 vairamu iḡovalaina dabuana ba kokia;
\q1 emu hahedoki ba doki oho, aemu bae ḡaḡae,
\q2 sinavai amo ba turu hanai.
\q1 
\v 3 Asi ramimu bae itamu,
\q2 emu hemarai baine hedinarai.
\q1 Dava baina abia,
\q2 tau ta basina bogaia hisi.
\q1 
\v 4 Ihamaurida Diravana ladana na Iehova Sabaota;
\q2 ia na Israel ena Helaga Diravana.
\b
\q1 
\v 5 Kaldea natuna hahinena e, asi reḡereḡemu a helai,
\q2 dibura lalonai baola;
\q1 badina be basileia ilohiadia hahinena na
\q2 basie gwauraimu lou.
\q1 
\v 6 Egu bese taudia na badu henidia,
\q2 ahugu na hamiroa;
\q1 oi imamu ai na atodia,
\q2 oi ese so bogadia hisi;
\q1 emu maduna o hametaua herea,
\q2 iahu latadiai.
\q1 
\v 7 Oi oto “Baina lohia hanaihanai”,
\q2 taunabunai ini gau so lalodia,
\q2 bona dokodia so lalo tao.
\b
\q1 
\v 8 Taunabunai, moale iura-henina hahinemu e,
\q2 ina hereva ba kamonaia.
\q1 O helai namonamomu,
\q2 lalomu ai o tomamu
\q1 “Lau binai, idauna ta na lasi;
\q2 lau na basina vabu, bona natugu ta basine mase”.
\q1 
\v 9 A ini ḡau rua na emu ai bae kau,
\q2 nega tamona ai, dina tamona ai:
\q1 ena be emu mea karadia na momo,
\q2 bona emu babalau karadia na siahu-herea,
\q1 to natumu edia mase bona emu vabu ese
\q2 bae hametaumu herea.
\b
\q1 
\v 10 Emu kara havara ai o noho namonamova oto;
\q2 oto “Ta ese se itagumu”;
\q1 emu aonega bona emu lalo-parara ese
\q2 e hakaumu kerere;
\q1 bona lalomu ai oto
\q2 “Lau binai, idauna ta na lasi”.
\q1 
\v 11 A dika na oi latamu ai baine kau,
\q2 basio hamamaia ahu diba;
\q1 ala-ala na latamu ai baine diho,
\q2 basio hamamaia ahu diba;
\q1 hahebua-tari ese baine lasimu tao taku,
\q2 asi dibamu ḡauna.
\b
\q1 
\v 12 Emu babalau karadia ba kara balaheni,
\q2 bona emu mea karadia danu, kekenimu negana amo vada o goadalai ḡaudia,
\q1 bena readia anidia bae vara,
\q2 bena taunimanima na ba hagaridia.
\q1 
\v 13 Emu hahealo taudia na hutuma dainai lalomu na e hekwarahimu;
\q2 vada bae gini tore, bena bae hamaurimu.
\q1 Idia ese guba e hahetohoamu,
\q2 bona hisiu e orodiamu,
\q1 bona hua matamata negadia ai e gwaurai hatamu,
\q2 dahaka na emu ai baine vara.
\b
\q1 
\v 14 A itaia, idia na rei kakoro na heto,
\q2 lahi ese e aradia oremu;
\q1 idia na lahi hururu-hururudia amo
\q2 sibodia irauadia asi dibadia.
\q1 Ina na dia gida, bena bae hegana;
\q2 eiava lahi, bena badibadinai bae helai.
\q1 
\v 15 Oi ida vada o hekwarahi hebou taudia,
\q2 kekenimu negana amo oi ida vada o gaukara hebou taudia,
\q2 oiemu ai na unu heheto.
\q1 Idia na e loa eva-evamu, ta ta ena dala ena dala ai,
\q2 a oi na asi ihamaurimu ta.
\c 48
\s1 Ḡau matamatadia
\q1 
\v 1 Iakob iduhuna e, ina na a kamonai!
\q2 Umui na Israel ladana o henemailaiamu,
\q2 bona Iuda ese e havaramui.
\q1 Umui na Iehova ladana ai o gwau hamatamu,
\q2 bona Israel Diravana o gwauraia hedinaraimu,
\q2 a dia hereva momokani ai bona dia kara maoromaoro ai.
\q1 
\v 2 Badina be sibomui hanua helaḡana o henemailaiamu,
\q2 bona Israel Diravana enai o taomu;
\q2 ia ladana na Iehova Sabaota.
\b
\q1 
\v 3 Ḡau gunadia na idau nega ai na gwaurai hedinarai;
\q2 herevadia na udugu amo e lasi, na hahedinaraidia;
\q2 na karadia taku, bena e vara.
\q1 
\v 4 Badina be lau dibagu oi lalomu na auka,
\q2 bona aiomu na auri,
\q2 bona bagumu na auri labora-laborana.
\q1 
\v 5 Nega gunana amo emu ai na gwauraidia hedinarai,
\q2 do asie vara ai na herevalai henimu,
\q1 oi na baoto “Egu kaivakuku ese e karadia,
\q2 egu dirava laulauna, e koroa ḡauna bona e hahetaria ḡauna,
\q2 ese e haganilaidia”, na garina.
\b
\q1 
\v 6 Vada o kamonai; harihari ina idoinai ba itaia;
\q2 basio gwauraia hedinarai a?
\q1 Ina negana amo lau ese ḡau matamatadia baina hamaorolaimu,
\q2 ḡau hehunidia, do asi dibamu ḡaudia.
\q1 
\v 7 Harihari vada na havaradia, dia idau nega ai;
\q2 ema bona ina dina, sivaraidia na so kamonai,
\q2 baoto “A itaia, vada na dibadia” na garina.
\q1 
\v 8 Nega ta so kamonai, nega ta so diba,
\q2 nega gunadia amo taiamu se kirara.
\q1 Badina be lau dibagu oi na kara dibaka herea taumu,
\q2 bona emu vara dinana amo gwau-edeede tauna e gwauraimuva.
\b
\q1 
\v 9 Lau ladagu dainai egu badu na halahelaiamu,
\q2 lau i'imodaigu dainai emu ai na laoa ahumu,
\q2 basina negemu daure helaoreana.
\q1 
\v 10 A itaia, vada na haḡoevamu, a dia \it silver\it* heḡereḡerena,
\q2 hisihisi amuna ai vada na tohomu.
\q1 
\v 11 Lau sibogu daigu ai na karaiamu, lau sibogu daigu ai,
\q2 badina be lau ladagu na ede bae hamiroa toma?
\q2 Lau hairaigu na ta basina henia.
\b
\s1 Iehova ese Israel baine hamauria
\q1 
\v 12 Iakob e, a kamonai henigu!
\q2 Israel, na boiria tauna, a kamonai henigu!
\q1 Lau na Ia; lau na gini-gunana;
\q2 lau na gini-gabena danu.
\q1 
\v 13 Lau imagu ese tanobada badina e atoa,
\q2 bona imagu idibana ese guba e idia roro;
\q1 lau na boi henidiamu negadia ai,
\q2 idia na e gini tore heboumu.
\q1 
\v 14 Umui iboumui ai, a hegogo, ba kamonai!
\q2 Idia bogaragidia ai daika ese ini ḡau vada e gwaurai?
\q1 Iehova ese ia e lalokau heniamu;
\q2 ia ese iena lalo-hadai na Babulono latanai baine karaia,
\q2 bona ia imana ese Kaldea taudia baine hadikadia.
\q1 
\v 15 Lau, lau sibogu, vada na hereva, vada na boiria,
\q2 vada na hakaua mai, bona ena dala ai ena namo baina habadaia.
\q1 
\v 16 A raka henigu kahi, ina na ba kamonai:
\q2 Matamana negana amo asina hereva hehuni;
\q2 kara e vara negana amo lau na unuseni ai.
\q1 Harihari Ḡaubada Iehova ese vada e siaigu,
\q2 bona ena Lauma danu.
\q1 
\v 17 Iehova, Ihamaurimu Diravana,
\q2 Israel ena Helaḡa Diravana,
\q2 ini e gwau tomamu:
\q1 Lau binai Iehova, emu Dirava;
\q2 emu namo ihabadana dalana na hadibalaimumu,
\q2 emu raka dalana namona ai na hakaumumu.
\q1 
\v 18 Egu haheḡani boma kamonai henidia bema namo;
\q2 bena emu maino na sinavai ida bema heḡereḡere,
\q2 bona emu kara maoromaoro na davara hurehuredia ida bema heḡereḡere;
\q1 
\v 19 oi garamu bema vara kone mirina na heto,
\q2 bona oi vevemu miri dimuradia heḡereḡeredia;
\q1 idia ladadia na basiema boio,
\q2 bona lau vairagu ai basiema helalo nege.
\b
\q1 
\v 20 Babulono amo ba raka lasi, Kaldea ba heautania;
\q2 ina na ba gwauraia mai moale hisi-daena ida,
\q2 ba gwauraia hedinarai;
\q1 ba siaia lao ela bona tanobada dokona,
\q2 baoto “Iehova ese ena hesiai tauna Iakob vada e hamauria”.
\q1 
\v 21 Ia ese tano ḡaḡaena ai e hakaudia hanai negana ai,
\q2 idia na asie ranu mase;
\q1 nadi-gini amo ia ese ranu e ha-arua,
\q2 nadi-gini e botaia parara, bena ranu na e aru lasi.
\q1 
\v 22 Iehova na e tomu:
\q2 Kara dika taudia na asi edia maino.
\c 49
\s1 Iehova ena hesiai tauna na bese idau-idau edia diari
\q1 
\v 1 Kone tanodia e, a kamonai henigu!
\q2 Gabu daudau amo vada oma taumui e, a hakala!
\q1 Iehova ese boga amo vada e boirigu;
\q2 sinagu bogana ai na nohova ai, e boi henigu;
\q1 
\v 2 Udugu na dare mataka-matakana heḡereḡerena ai e halaoa;
\q2 ia imana ikerukeruna ai e hunigu.
\q1 Ia ese e karagu, diba kimore-kimorena ta;
\q2 ena diba pauana ai e hunigu.
\q1 
\v 3 E hamaorogu, eto: Oi na egu hesiai tauna Israel;
\q2 i'imodaigu na oiemu ai baine hedinarai.
\q1 
\v 4 A lau nato: Vada na hekwarahi kava,
\q2 goadagu vada na ha-orea kava, asi anina;
\q1 gau tamona igwaurai-maorogu na Iehova enai,
\q2 bona egu hahenamo ihalouna na egu Dirava enai.
\q1 
\v 5 Harihari Iehova na e herevamu;
\q2 ia ese sinagu bogana ai e karagu, ena hesiai tauna ai bainala.
\q1 Iakob na ienai baina haloua
\q2 bona Israel taudia na ienai baina haboudia mai totona;
\q1 ina be Iehova vairanai lau na mai imatauraigu,
\q2 bona egu Dirava na egu goada ai vada e hahelao.
\q1 
\v 6 Ia eto: Egu hesiai tauna ai baola,
\q2 Iakob iduhudia ba hatoredia isi,
\q1 a Israel kwabukwabudia ba haginidia lou,
\q2 una na ḡau pipikina;
\q1 ese basileia idau-idau edia diari ai baina halaomu,
\q2 egu hahemauri na tanobada dokona ai baine kau helaoreana.
\b
\q1 
\v 7 E dadaraia hereamu, bese idau-idau ese e lalo dika henia badamu tauna,
\q2 lohia edia hesiai tauna, na
\q1 Iehova, Israel Ihamaurina bona ena Helaḡa Diravana, ese
\q2 ini e gwau henia tomamu:
\q1 Pavapava ese bae itaia, bena bae tore isi;
\q2 lohia ese bae itaia, bena bae goru goru diho;
\q1 Iehova dainai, badina be ia na momokani;
\q2 Israel ena Helaḡa Diravana dainai, badina be ia ese vada e abimu hidi.
\b
\s1 Siona ihagini-louna gwauhamatana
\p 
\v 8 Iehova ini e gwau tomamu:
\q2 Madi-namo negarla ai vada na haere henimu,
\q2 hahemauri dinana ai vada na durumu;
\q1 vada na narimu,
\q2 taunimanima taravadia iatudia toana ai vada na halaomu,
\q1 o ba hanamoa lou,
\q2 bona e haḡaḡaea tanona na taunimanima ba hari henidia totona.
\q1 
\v 9 Iḡui taudia ba hamaorodia, baoto “A raka lasi”;
\q2 dibura ai e nohomu taudia ba hamaorodia, baoto “A hedinarai”.
\q1 Idia na dala ai bae aniani,
\q2 bona ororo nemuka-nemukadia iboudiai latadiai aniani bae davaria.
\b
\q1 
\v 10 Idia na basie hitolo bona basie ranu mase,
\q2 lai siahuna eiava dina ese basine hahisidia;
\q1 badina be e bogadia hisimu Diravana ese baine hakaudia,
\q2 ranu gabudia badibadidiai baine hakaudia.
\q1 
\v 11 Lau ese ororo iboudiai na dala ai baina halaodia,
\q2 bona egu laolao daladia bae lailaidia.
\q1 
\v 12 A itaia, ini na dauha amo baema;
\q2 a itaia, ini na mirigini kahana amo bona lahara kahana amo baema;
\q2 bona ini na Suene tanona amo baema.
\q1 
\v 13 Guba e, moale anedia avabi!
\q2 Tanobada e, a moale hisi dae!
\q2 Ororo e, ane a lada isi!
\q1 Badina be Iehova ese ena bese na taudia vada e halodia,
\q2 bona ena hisi-ani taudia na baine bogadia hisi.
\b
\q1 
\v 14 A Siona eto “Iehova ese vada e rakatanigu;
\q2 egu Ḡaubada ese vada e lalogu boio”.
\q1 
\v 15 Be! Mararoto hahinena ta ese e ubuamu merona baine laloa boio a?
\q2 Ia bogana amo e vara merona basine bogaia hisi a?
\q1 Oibe, unu idia na bae helalo boio readia;
\q2 a lau ese oi basina lalomu boio.
\q1 
\v 16 A itaia, imagu palapaladia ai oi toamu vada na torea;
\q2 oi maḡumu na lau vairagu ai vada e hedinarai louloumu.
\q1 
\v 17 Oi ihaginimu taudia ese ihabua-tarimu taudia na e hereadiamu,
\q2 bona e havahumu taudia na emu amo e raka lasimu.
\q1 
\v 18 A gaga isi, ba roharoha, ba itaia;
\q2 iboudiai na e heboumu, e vasimu.
\q1 Iehova na e tomu: Lau na maurimu heḡereḡerena,
\q2 oi ese iboudiai bavabidia, emu herahera ḡaudia;
\q2 ba heralaidia, headava matamata hahinena ese e heralaimu na heto.
\b
\q1 
\v 19 Momokani, emu gabu ḡaḡaedia, emu deḡedeḡe-rahu gabudia,
\q2 emu tano, e havahua ḡauna,
\q1 momokani, oi na ba maraḡi, basio heḡereḡere emu taunimanima ese bae noholaimu;
\q2 bona e hadonomu taudia na dauhai bae noho.
\q1 
\v 20 Natumu, emu lalo-hisihisi negana ai e vara memerodia na
\q2 taiamu lalonai bae hereva, baeto:
\q1 Gabu na maraḡi egu ai;
\q2 baina noholaia gabuna ba lailaia.
\q1 
\v 21 Bena lalomu ba hadaia, baoto:
\q2 Ini na daika ese e havaradia egu?
\q1 Vada na lalo hisihisi bona na gabani,
\q2 dauhai e hanohogu bona e negegu daure,
\q2 a ini be daika ese e ubudia?
\q1 A itaia, lau na noho edeava;
\q2 ini na ede amo vada ema?
\q1 
\v 22 Ḡaubada Iehova na ini e gwau tomamu:
\q2 A itaia, imagu baina duduia isi, basileia idau-idau ediai,
\q2 bona bese idau-idau na egu toa baina hahedinarai henidia;
\q1 bena natumu mamaruanedia na kopadia ai bae mailaidia,
\q2 bona natumu kekenidia na paḡadia ai bae ududia.
\q1 
\v 23 Pavapava ese bae reḡumu,
\q2 bona pavapava hahinedia ese bae ubumu;
\q1 tano ai bae goru diho, bae toma henimu diho,
\q2 aemu ḡahudia bae demari.
\q1 Bena vada ba diba lau na Iehova;
\q2 lau bae narigu taudia na ta ese basine hahemaraidia.
\b
\q1 
\v 24 Damu na goada tauna ena amo bae abia oho diba a?
\q2 Lohia mai daḡedaḡena ena iḡui taudia bae ruhadia nege diba a?
\q1 
\v 25 Momokani, Iehova na ini e gwau tomamu:
\q2 Goada tauna ena iḡui taudia na bae abidia oho,
\q2 bona lohia mai daḡedaḡena damuna na bae hamauridia;
\q1 badina be e heai henimumu taudia na
\q2 lau ese baina heai henidia,
\q2 bona natumu baina hamauridia.
\q1 
\v 26 E hahisihisimu taudia na lalodia baina ha-uradia,
\q2 bena sibodia hidiodia bae ani,
\q1 bona sibodia raradia bae inu kekero,
\q2 vine ranuna amo bema kekero na heto.
\q1 Bena taunimanima iboudiai na bae diba,
\q2 lau na Iehova, oi Ihamaurimu,
\q1 oi idavalaimu Diravana,
\q2 Iakob ena Goada Diravana.
\c 50
\q1 
\v 1 Iehova ini e gwau tomamu:
\q2 Sinamu ena hekoho revarevana,
\q1 na hadihoa negana ai na henia ḡauna,
\q2 be edeseni ai?
\q1 Eiava e henigu torehai bena enai na hoimu
\q2 tauna be daika?
\q1 A itaia, emu kara havara daidiai na hoimu,
\q2 bona emu kerere daidiai sinamu na hadihoa.
\q1 
\v 2 Badina be dahaka nama negana ai tau ta se noho?
\q2 Badina be dahaka na boiboi negana ai tau ta se haere?
\q1 Imagu e tunamu bena basine hamaurimu diba a?
\q2 Eiava asi siahugu baina harohomu mauri a?
\q1 A itaia, egu gwaugwau amo davara na hakororoamu,
\q2 bona sinavai na tano kaukauna ai na halaoamu;
\q1 edia gwarume na e bodagamu,
\q2 ranu ai e dabumu dainai e masemu.
\q1 
\v 3 Guba na korema-korema ai na hadabualaiamu,
\q2 bona puse dabuadia ai na ḡovalaiamu.
\b
\s1 Iehova ena hesiai tauna ena kamonai
\q1 
\v 4 E hadibadia taudia maladia na Ḡaubada Iehova ese e henigu,
\q2 tau-boera tauna na egu hereva amo baina hagoadaia diba helaoreana.
\q1 Daba ta ta amo e haogumu, taiagu e hakiraradiamu,
\q2 e hadibadia taudia heḡereḡeredia ai baina kamonai helaoreana.
\q1 
\v 5 Ḡaubada Iehova ese taiagu vada e hakiraradia,
\q2 bena asina gwau edeede, asina raka muri.
\q1 
\v 6 Dorugu na hebota taudia na henidia,
\q2 bona vahagu na auki-huidia ibutudia taudia na mede henidia;
\q2 vairagu na hemarai bona hekanudi amo asina hunia.
\b
\q1 
\v 7 Badina be Ḡaubada Iehova ese e durugumu,
\q2 una dainai asina baia;
\q1 una dainai vairagu vada na ha-aukaia nadi-vasiga na heto,
\q2 bona dibagu ta ese basine hahemaraigu;
\q1 
\v 8 igwaurai-maorogu tauna na eme kahikahi.
\q1 Daika ese baine heai henigu? Baita tore isi hebou.
\q2 Lau inaigu be daika? Baine raka kahi mai.
\q1 
\v 9 A itaia, Ḡaubada Iehova ese e durugumu;
\q2 daika ese kereregu baine gwaurai?
\q1 A itaia, iboudiai na bae mouka-mouka, dabua na heto;
\q2 pitopito ese bae anidia ore.
\b
\q1 
\v 10 Umui bogaragimui ai daika ese Iehova garina e garimu,
\q2 bona ena hesiai tauna erena e kamonaimu?
\q1 Daika na dibura ai e rakamu, asi ena diari,
\q2 to Iehova ladana e abidadama heniamu,
\q2 bona ena Dirava enai e tabe kaumu?
\q1 
\v 11 A itaia, umui lahi o ha-araiamu
\q2 bona lahi tutudia o ha-aramu taumui!
\q1 Emui lahi diarina ai ba raka,
\q2 bona lahi tutudia diaridia ai danu.
\q1 Lau imagu amo bavabia ḡauna binai:
\q2 oi na hisi-ani ai ba hekure.
\c 51
\s1 Tauhalo herevadia Siona ena
\q1 
\v 1 Umui haheroho-mauri o ḡavaiamu taumui,
\q2 Iehova o tahuamu taumui,
\q2 a hakala henigu!
\q1 Enai e utumui nadina ba itaia,
\q2 bona enai e ḡeimui gurina danu.
\q1 
\v 2 Tamamui Abraham ba laloa,
\q2 bona e havaramui hahinena Sara danu;
\q1 badina be ia na asi besena negana ai na boiria,
\q2 bena na hanamoa, besena na hahutumaia.
\q1 
\v 3 Badina be Iehova ese Siona baine hamarumarua,
\q2 ena gabu ḡaḡaedia iboudiai baine hamarumarudia,
\q1 ena tano ḡaḡaena na Eden heḡereḡerena ai baine halaoa,
\q2 ena tano kaukauna na Iehova ena uma heḡereḡerena ai baine halaoa;
\q1 moale bona lalo-namo na ia lalonai bae davaridia,
\q2 bona hahenamo bona ane gadodia danu.
\b
\q1 
\v 4 Egu bese taumui e, a kamonai henigu!
\q2 Egu basileia taumui e, a hakala henigu!
\q1 Badina be taravatu ta na lauegu amo baine lasi,
\q2 bona egu hahemaoro ḡoevaḡoeva na bese idau-idau edia diari ai bainela.
\q1 
\v 5 Egu haheroho-mauri na e kahi mai haraḡamu,
\q2 egu hahemauri na vada e raka lasi,
\q2 bona lau imagu amo bese idau-idau baina lohiadia.
\q1 Kone tanodia na e narigumu,
\q2 bona imagu dainai e helaromu.
\q1 
\v 6 Ba gaga dae, guba ba itaia;
\q2 ba igo diho, tanobada ba itaia;
\q1 badina be guba baine puki, kwalahu na heto,
\q2 bona tanobada baine mouka-mouka, dabua na heto,
\q2 bona inoholaina taudia na bae mase, namo na heheto;
\q1 a egu hahemauri baine hesiriu hanaihanai,
\q2 bona egu haheroho-mauri na basine doko ela bona hanaihanai.
\b
\q1 
\v 7 Kara maoromaoro mai dibamui taumui,
\q2 egu taravatu na lalomui ai e miamu taumui,
\q2 a kamonai henigu!
\q1 Taunimanima edia gwaugwau garina basio gari,
\q2 bona edia heihi-ihirai herevadia daidiai kudoumui basie hetaha.
\q1 
\v 8 Badina be pitopito ese bae anidia ore, dabua na heto,
\q2 bona gaigai-gaigai ese bae anidia, mamoe huina na heto;
\q1 a lauegu haheroho-mauri na baine hesiriu hanaihanai,
\q2 bona egu hahemauri ela bona uru iboudiai.
\q1 
\v 9 Iehova imana e,
\q2 a helada isi, a helada isi, goada ba rioa!
\q1 A helada isi, nega gunadia ai heḡereḡerena,
\q2 sene taudia edia uru ai heḡereḡerena.
\q1 Oi ese Rahaba\f + \fr 51:9 \ft “Rahaba” na Heberu taudia edia gori ḡauna ta, gadobada ai e nohova ḡauna, ladana.\f* o utua sisi-sisi ani?
\q2 Oi ese gadobada gaigaina badana o gwadaia ani?
\q1 
\v 10 Oi ese davara o hakororoa
\q2 bona dobu gabudia ranudia danu ani?
\q1 Oi ese davara ena dobu gabudia na
\q2 vada o hamauridia taudia edia raka-hanai dalana ai o halaoa ani?
\q1 
\v 11 Iehova ese vada e davalaidia taudia na bae lou mai,
\q2 Siona baema mai anedia ida;
\q1 moale hanaihanai na tubuadia ai baine mia,
\q2 moale bona lalo-namo bae abi,
\q2 lalo-hisihisi bona ḡanaḡana bae boio.
\b
\q1 
\v 12 Lau binai taumui ihalodia tauna.
\q2 Oi na daika, taunimanima, e masemu ḡauna, o gari heniamu?
\q2 Oi na daika, taunimanima natuna, e hekaramu rei na heto ḡauna, o gari heniamu?
\q1 
\v 13 Oi na daika, Iehova, oi ikaramu Diravana, vada o laloa boio?
\q2 Ia ese guba e idia roro, bona tanobada badidia e atodia.
\q1 Oi na daika, dina idoinai o gari louloumu,
\q2 hahehisi tauna ese ena badu dainai e hahebua tari matamamu negana ai?
\q2 Hahehisi tauna ena badu garag-ara na edeseni ai?
\q1 
\v 14 Ena maduna ese e ha-igoamu tauna bae ruhaia nege haraḡa;
\q2 ia na basine mase, guri ai basine diho,
\q2 bona ana aniani basine ore.
\q1 
\v 15 Badina be lau na Iehova, emu Dirava;
\q2 lau ese davara na haraivaraivamu,
\q1 bena hurehuredia e gurumu.
\q2 (Ia ladana na Iehova Sabaota).
\q1 
\v 16 Egu hereva na oi udumu ai vada na atodia,
\q2 bona imagu ikerukeruna ai vada na hunimu;
\q1 guba vada na idia roro,
\q2 bona tanobada badidia vada na atodia,
\q1 bona Siona vada na hamaoroa, nato
\q2 “Oi na egu bese”.
\q1 
\v 17 Ierusalem e, a helada isi,
\q2 a helada isi, a tore isi!
\q1 Iehova imana amo
\q2 ena badu keherena vada o inua;
\q1 raraga keherena nurina na
\q2 vada o inu ore.
\q1 
\v 18 Ia natuna, vada e havaradia memerodia, iboudiai bogaragidiai
\q2 ta ese ia basine hakaua;
\q1 ia natuna, vada e ubudia memerodia, iboudiai bogaragidiai
\q2 ta ese ia imana ai basine abia.
\q1 
\v 19 Ini ḡau rua na emu ai vada e vara:
\q2 daika ese taumu baine haloa?
\q1 Gaudia be hahevahu bona hahebua-tari, doe bona dare:
\q2 daika ese taumu baine haloa?
\q1 
\v 20 Oi natumu mamaruanedia vada e mase rea,
\q2 ariara ta ta iduaradia ai e hekuremu,
\q2 uda diana huo lalonai na heto;
\q1 Iehova ena badu ediai e honu honu daemu,
\q2 emu Dirava ena gwaugwau ediai e honu honu daemu.
\b
\q1 
\v 21 Taunabunai, vada e hahisihisimui taumui e,
\q2 vada o kekero (a dia vine ranuna amo) taumui e,
\q2 ina na ba kamonai!
\q1 
\v 22 Emui Ḡaubada Iehova, emui Dirava,
\q2 ena bese ena gini-kau herevana e gwauraiamu Diravana,
\q2 ini e gwau tomamu:
\q1 A itaia, lau ese raraga keherena na
\q2 oi imamu amo vada na abia oho.
\q1 egu badu keherena na basio inua lou;
\q2 
\v 23 bena e hahisihisimuimu taudia imadia ai baina atoa.
\q1 Idia ese vada e hamaoromui, eto
\q2 “Ba goru diho, bena latamui amo baia raka hanai”;
\q1 bena umui ese dorumui na tano heḡereḡerena ai o halaoa,
\q2 bona ariara heḡereḡerena ai danu,
\q2 idia ese bae rakamui hanai totona.
\c 52
\s1 Dirava ese Siona baine hamauria
\q1 
\v 1 Siona e, a helada isi, a helada isi,
\q2 goadamu ba rioa!
\q1 Ierusalem e, hanua helaḡana e,
\q2 emu dabua herea-daedia ba hahedokilai!
\q1 Badina be asie peritomedia taudia bona asie haheḡoeva taudia na oi lalomu ai basie raka vareai lou.
\q1 
\v 2 Ierusalem e, vada e guimu hanuana e,
\q2 ḡahumu a heruirui oho, ba tore isi!
\q1 Siona hahinemu e, e ḡuimu hahinena e,
\q2 gadea na aiomu amo ba kokia oho!
\p 
\v 3 Badina be Iehova ini e gwau tomamu: Asi davamui e hoimui, ma asi davamui bae hamaurimui.
\v 4 Badina be Ḡaubada Iehova ini e gwau tomamu: Gunaguna egu orea taudia na Aigupto ela, unuseni ai bae noho totona; bona Asuria taudia ese e hahisihisidia, asi badina.
\v 5 Iehova na e tomu: Harihari dahaka name davaria iniseni ai? Badina be egu orea taudia na e abidia oho, asi badina. Iehova ma e tomu: Edia lohia na e tai lolomu, bona dina idoinai lau ladagu e dadaraiamu.
\v 6 Taunabunai egu orea taudia ese lau ladagu bae dibaia. Taunabunai una dina ai idia na bae diba, e herevamu tauna na lau. Lau na iniseni ai.
\b
\q1 
\v 7 Hari namodia e mailaimu tauna
\q2 aena na daka namo ororo latadiai!
\q1 Ia ese maino herevadia e gwauraidia hedinaraimu,
\q2 bona kara namo haridia namodia e mailaimu;
\q1 hahemauri herevadia e haperedia rohorohomu,
\q2 bona Siona e hereva heniamu, e tomu
\q2 “Emu Dirava e lohiamu”.
\q1 
\v 8 A kamonai, emu gima taudia ese gadodia e habadadiamu,
\q2 moale anedia e abi heboumu;
\q1 badina be Iehova ese Siona e lou heniamu ai,
\q2 idia na matana matana amo e heita hehenimu.
\q1 
\v 9 Ierusalem ena gabu ḡaḡaedia e,
\q2 ane ba lada isi!
\q1 Badina be Iehova ese ena orea taudia na taudia vada e halodia;
\q2 ia ese Ierusalem vada e hamauria.
\q1 
\v 10 Iehova ese ia imana helaḡana vada e toia roro,
\q2 basileia iboudiai vairadiai;
\q1 bona ta'nobada dokodia iboudiai ese
\q2 eda Dirava ena hahemauri bae itaia.
\b
\q1 
\v 11 A raka oho, a raka oho, ena amo a raka lasi;
\q2 ḡau mirona ta basio daua toho.
\q1 Iehova ena nau, kibo, kehere o huamu taumui,
\q2 ia bogaragina amo a raka lasi, ba haheḡoeva.
\q1 
\v 12 Badina be basio raka lasi haraḡa,
\q2 bona basio heau lao;
\q1 badina be Iehova na vairamui ai bainela,
\q2 bona Israel Diravana na murimui igimana bainela.
\b
\s1 Iehova ena hesiai tauna ena hisihisi
\q1 
\v 13 A itaia, egu hesiai tauna ena namo baine habadaia,
\q2 bae imodaia, bae abia isi;
\q2 ia na atai herea gabuna ai baine noho.
\q1 
\v 14 Hutuma ese ia e hoalaia;
\q2 ia ita-itana na vada e hadikaia, dia taunimanima ita-itana na heto,
\q2 bona oromana vada e hadikaia, dia taunimanima natudia oromadia na heheto.
\q1 
\v 15 Taunabunai ia ese basileia momo baine hahoadia;
\q2 pavapava ese ududia bae hakapudia ia dainai;
\q1 badina be ta ese se hamaorolaidia ḡaudia na bae ita,
\q2 bona asie kamonai ḡaudia na bae diba.
\c 53
\q1 
\v 1 Vada ta kamonai herevana na daika ese vada e abia dae?
\q2 Iehova imana na daika enai vada e hedinarai?
\q1 
\v 2 Badina be ia vairanai e vara isi, au matamatana ta na heto,
\q2 bona au ramuna ta tano kaukauna ai na heto.
\q1 Ia na asi oromana bona asi hairaina, bena baitama raraia;
\q2 bona asi raho-namona, bena baitama ura henia.
\q1 
\v 3 Taunimanima ese e dadaraia bona e rakatania,
\q2 lalo-hisihisi tauna, hisi-ani na mai dibana;
\q1 bena taunimanima ese vairadia na ena amo e huniamu tauna ta na heto e dadaraia,
\q2 bona asita lalo namo henia.
\b
\q1 
\v 4 Momokani, ia ese eda hisi-ani vada e huahaida,
\q2 bona eda lalo-hisihisi danu;
\q1 ḡau tamona, ta helalolaia ia na vada e alaia tauna,
\q2 Dirava ese vada e rahua mase bona vada e hahisihisia tauna.
\q1 
\v 5 Ita eda kerere daidiai e haberoa,
\q2 bona ita eda kara havara daidiai e hahisihisia;
\q1 ia e dadabaia dainai ita ese maino tame abia,
\q2 bona ia berona daidiai ita ta maurimu.
\q1 
\v 6 Ita iboudai vada ta raka boio raka boio, mamoe na heheto,
\q2 ta ta ena ura dalana ena ura dalana ai vada ta raka oho;
\q1 bona Iehova ese ita iboudai eda kara dika na
\q2 ia latanai vada e ato kau.
\b
\q1 
\v 7 E daḡedaḡe henia bona e hahisihisia,
\q2 to ia ese uduna se haḡaia;
\q1 mamoe natuna na ialana gabuna e hakaua laomu na heto,
\q2 eiava mamoe na huina iutuna taudia vairadiai e mumu na heto, ia ese uduna se haḡaia.
\q1 
\v 8 Daḡedaḡe bona hahemaoro ai e abia oho,
\q2 bena ena uru ai daika ese e laloa
\q1 ia na mauri taudia edia tano amo vada e negea daure
\q2 bona egu orea taudia edia kerere daidiai vada e alaia?
\q1 
\v 9 Ena be ia ese ala-ala karana ta se karaia,
\q2 bona hereva koikoina ta se gwauraia,
\q1 to ena mase ai idia ese kara dika taudia ida e guria,
\q2 bona taḡa tauna ida danu.
\b
\q1 
\v 10 Ḡau tamona, Iehova ena ura dainai e haberoa;
\q2 ia ese e hagorerea.
\q1 Dika iabi-ohona boubouna ai baine hahelao negana ai,
\q2 ia ese garana do baine itadia, bona ena mauri dinadia baine hahohodia.
\q1 Iehova ena ura anina baine tubu ia imana ai;
\q2 
\v 11 ena lalo-hekwarahi anina baine itaia,
\q2 bena lalona baine heḡereḡere.
\q1 Iena aonega dainai kara maoromaoro tauna, egu hesiai tauna, ese
\q2 hutuma na kara maoromaoro taudia baine gwauraidia,
\q2 bona edia kara havara baine huahaidia.
\q1 
\v 12 Taunabunai, taunimanima badadia ida ahuna baina hari henidia,
\q2 bona goada taudia ida e dadi kohudia bae hari;
\q1 badina be ia ese maurina e bubua nege mase enai,
\q2 bona kerere taudia ida e duahia hebou;
\q1 ḡau tamona, ia ese hutuma edia kara dika e huahaidia,
\q2 bona kerere taudia daidiai e noinoi.
\c 54
\s1 Iehova ese Israel e lalokau henia hanaihanaimu
\q1 
\v 1 Gabani hahinemu e, asi natumu hahinemu e,
\q2 ane avabia!
\q1 Nega ta hekamonai hisina so abia hahinemu e,
\q2 ane ba lada isi, ba lolo badabada!
\q1 Badina be Iehova na e tomu:
\q2 Hane vado natuna-bae hutuma,
\q2 a vada e headava hahinena natuna na basie hoho.
\q1 
\v 2 Emu dabua kalagana ba habadaia,
\q2 emu kalaga dabuadia ba veridia roro;
\q1 basio halahe, emu kwanau ba halatadia,
\q2 bona emu ikoko ba ha-aukadia.
\q1 
\v 3 Badina be umui na ba pere rohoroho, idiba kahana ai bona lauri kahana ai,
\q2 bona oi garamu ese basileia idau-idau bae abidia,
\q2 bona vada e vahu hanuadia bae noholaidia.
\b
\q1 
\v 4 Basio gari, badina be oi na basio hemarai;
\q2 basio baia, badina be haida ese basie hahemaraimu;
\q1 badina be eregabemu negana hemaraina ba laloa boio,
\q2 bona vabumu negana hemaraina basio laloa une.
\q1 
\v 5 Badina be Ikaramu Diravana na oi adavamu,
\q2 ia ladana na Iehova Sabaota;
\q1 Israel ena Helaḡa Diravana na oi Ihamaurimu,
\q2 tanobada idoinai Diravana e gwauraiamu.
\q1 
\v 6 Badina be Iehova ese vada e boirimu,
\q2 vada e hadihoa bena lalona e hisihisimu hahinena na heto,
\q1 eregabena ai e hadihoa hahinena na heto.
\q2 Emu Dirava vada e herevamu.
\q1 
\v 7 Nega sisina mo na rakatanimu,
\q2 a mai hebogahisi-badagu ida baina haboumu.
\q1 
\v 8 Egu badu e hepurai dobi dainai
\q2 nega sisina lau vairagu na emu amo na hunia;
\q2 a mia-hanaihanai helalokauna amo baina bogamu hisi.
\q2 Iehova, Ihamaurimu Diravana, vada e herevamu.
\b
\q1 
\v 9 Badina be ina na Noa ena nega na heto lauegu ai:
\q2 lau na gwau hamata, Noa ena ranu ese tanobada basie utua dae lou nato,
\q1 una heḡereḡerena vada na gwau hamata, basina badu henimu,
\q2 bona basina gwau henimu.
\q1 
\v 10 Badina be ororo badadia na readia dauha baela,
\q2 bona ororo maraḡidia na readia bae heabi oho,
\q1 a lauegu hebogahisi ese basine rakatanimu,
\q2 bona egu maino gwauhamatana na basine heabi oho.
\q1 Iehova, e bogamu hisimu Diravana,
\q2 vada e herevamu.
\b
\s1 Ierusalem matamatana
\q1 
\v 11 O hisihisimu, o hegure-heguremu hanuana,
\q2 taumu asi ihalona hanuana,
\q1 a itaia, emu nadinadi na puku nadidia bogaradiai baina atodia,
\q2 bona badimu na sapairo nadidia amo baina kara;
\q1 
\v 12 kogemu na kadakodo\f + \fr 54:12 \ft Puku, sapairo, kadakodo. Ini na Heberu taudia edia herahera nadidia haida ladadia.\f* nadidia amo baina kara,
\q2 bona ikoukoumu nadi hururu-hururudia amo,
\q2 bona emu haba idoinai dava-bada nadidia amo.
\q1 
\v 13 Natumu mamaruanedia iboudiai na Iehova ese baine hadibadia;
\q2 oibe, natumu mamaruanedia edia noho na baine namo herea.
\q1 
\v 14 Kara maoromaoro ai do baina haginimu,
\q2 hahehisi karana amo dauhai ba noho, badina be basio gari,
\q2 bona hahegari karana amo danu, badina be basine kahi henimu.
\q1 
\v 15 Ta ese heiri-heiri bema havaraia,
\q2 unu na dia lauegu amo;
\q1 baine heiri-heiri henimu tauna na
\q2 oi daimu ai baine moru.
\q1 
\v 16 A itaia, lau ese auri iḡaukaralaina tauna vada na karaia;
\q2 ia ese lahi e hahururuamu, bena tuari ḡauna e karaiamu,
\q2 bae tuarilaia helaoreana.
\q1 Lau ese ala-ala tauna danu vada na karaia, hahebua-tari totona;
\q2 
\v 17 tuari ḡauna ta oi ihadikamu totona e karaiamu na
\q2 ena ḡaukara anina basine vara;
\q1 bona hahemaoro ai bae habadelaimu herevadia iboudiai na
\q2 oi ese ba laodia ahu.
\q1 Ina na Iehova ena hesiai taudia ahudia,
\q2 bona igwaurai-maorodia lauegu amo.
\q2 Iehova vada e herevamu.
\c 55
\s1 Hebogahisi na asi davana taunimanima iboudiai edia
\q1 
\v 1 E! Ranu mase taudia iboudiai ese
\q2 ranu bae mai henia,
\q1 bona asi ena moni tauna na bainema,
\q2 baine hoihoi, baine aniani.
\q1 Aoma, vine ranuna bona rata ba hoi,
\q2 asi monina bona asi davana.
\q1 
\v 2 Dahaka dainai emui moni o negeamu, basio ania ḡauna davana,
\q2 bona emui hekwarahi danu, boga basine hakunu ḡauna davana?
\q1 A kamonai henigu balaheni, ḡau namodia bavani,
\q2 aniani gaihona ba moalelaia.
\q1 
\v 3 Taiamui a hakala, lau dekegu baoma;
\q2 a kamonai, laumamui bae mauri helaoreana;
\q1 bena lau na umui ida baita hegwauhamata heheni,
\q2 baine mia hanaihanai gwauhamatana,
\q2 egu hebogahisi korikori David enai.
\q1 
\v 4 A itaia, lau ese hereva ihamomokanina tauna ai na halaoa,
\q2 bese idau-idau ediai,
\q1 bona bese idau-idau igunalaidia tauna ai,
\q2 bona edia lohia ai danu.
\q1 
\v 5 A itaia, do asi dibamu basileiadia ba boiridia,
\q2 bona asie dibamuva basileiadia na dekemu bae heau mai,
\q1 Iehova, emu Dirava bona Israel ena Helaḡa Diravana, dainai;
\q2 badina be ia ese vada e hahairaimu.
\b
\q1 
\v 6 Iehova a tahua, doini ba davaria diba negana ai;
\q2 a boi henia, ia na doini kahikahi negana ai.
\q1 
\v 7 Kara dika tauna ese ena dala baine rakatania,
\q2 bona kara gageva-gageva tauna ese ena lalo-hadai baine rakatanidia,
\q1 Iehova baine lou henia, bena ia ese baine bogaia hisi,
\q2 eda Dirava baine lou henia, bena ia ese ena dika idoinai baine gwaua tao.
\q1 
\v 8 Badina be Iehova na e tomu:
\q2 Lauegu lalo-hadai na dia emui lalo-hadai,
\q2 bona lauegu dala na dia emui dala.
\q1 
\v 9 Badina be guba na tanobada daenai heḡereḡerena,
\q2 lauegu dala na emui dala daediai,
\q2 bona lauegu lalo-hadai na emui lalo-hadai daediai.
\q1 
\v 10 Badina be medu bona medu-hetarina na guba amo e dihomu na heto,
\q2 bena asie dae loumu, a tanobada e haparipariamu,
\q1 bena uma anidia e tubumu bona e tuhutuhumu,
\q2 bena hadohado tauna ese uhe e davariamu,
\q2 bona baine aniani e tomu tauna ese aniani e animu,
\q1 
\v 11 heḡereḡerena ai, lau udugu amo e lasimu herevana na unu baine heto,
\q2 ia na basine lou henigu kava,
\q1 a egu ura baine haḡuḡurua,
\q2 bona dainai na siaia ḡauna ena namo baine habadaia.
\b
\q1 
\v 12 Badina be moale ai ba raka lasi,
\q2 bona maino ai bae hakaumui lasi;
\q1 umui vairamui ai ororo badadia bona maraḡidia ese
\q2 ane bae lada isi,
\q1 bona tano paka audia iboudiai ese
\q2 imadia bae patapata.
\q1 
\v 13 Au ginigini gabuna ai beroso\f + \fr 55:13 \ft “Beroso” na au ta ladana, Heberu gado ai.\f* auna baine vara,
\q2 bona ava ḡiniḡini gabuna ai keroro auna baine tubu;
\q1 bena unu na Iehova ihelalolaina ḡaudia ai baela,
\q2 bona mia-hanaihanai toana, basine henege daure diba ḡauna.
\c 56
\s1 Dirava ena taravatu ibadinana na mai davana
\q1 
\v 1 Iehova ini e gwau tomamu:
\q2 Hahemaoro ba karaia ḡoevaḡoeva,
\q2 kara maoromaorodia ba kara;
\q1 badina be asi vanahana egu hahemauri bainema,
\q2 bona egu haheroho-mauri baine hedinarai.
\q1 
\v 2 Unu e kara tomamu tauna na namo,
\q2 bona taunimanima natuna, e badinaia tarika-tarikamu tauna, danu.
\q1 Ia ese dina helaḡa e badinaiamu, se hadikaiamu;
\q2 bona imana e nariamu, kara dika ta baine karaia na garina.
\q1 
\v 3 Idau tauna Iehova ena orea lalonai vada e vareai na basineto
\q2 “Iehova ese ena orea amo do baine bibigu tabe”;
\q1 bona e taravaia tauna basineto
\q2 “A itaia, lau na au kaukauna”.
\q1 
\v 4 Badina be Iehova ini e gwau tomamu:
\q2 E taravadia taudia hahidaosi ese egu dina helaḡadia e badinadiamu,
\q1 bona lalogu ihanamolaina ḡaudia e abidia hidimu
\q2 bona egu taravatu e badinaia tarika-tarikamu, taudia na
\q1 
\v 5 lau ese egu ruma ai bona egu haba lalodiai
\q2 pupuna ta bona lada ta baina henidia,
\q2 natu-adora memerodia bona kekenidia ihereadia ḡaudia;
\q1 lada mia-hanaihanaina baina henidia,
\q2 bena edia amo basine boio.
\b
\q1 
\v 6 Idau bese taudia Iehova ena orea ai vada e vareai,
\q2 ia bae toma henia diho helaoreana
\q1 bona Iehova ladana bae lalokau henia
\q2 bona isiaina bae lao heni totona taudia,
\q1 dina helaḡa e badinaiamu, asie hadikaiamu,
\q2 bona egu taravatu e badinaia tarika-tarikamu, taudia iboudiai na
\q1 
\v 7 lau ese egu ororo helaḡana ai baina hakaudia dae,
\q2 bona egu ḡuriḡuri rumana ai baina hamoaledia;
\q1 edia ḡole-oho bouboudia bona edia boubou ḡaudia idau-idau na
\q2 egu ihaboulaina patana ai baina abidia dae;
\q1 badina be egu dubu na bese loḡora iboudiai
\q2 edia ḡuriḡuri rumana bae gwauraia.
\q1 
\v 8 Ḡaubada Iehova, Israel bogaragina amo e luludia oho taudia
\q2 e haboudiamu Diravana, e tomu
\q1 “Lau ese ma haida ienai baina haboudia,
\q2 na haboudia guna taudia ida”.
\b
\s1 Israel edia kaivakuku irevadia
\q1 
\v 9 Umui tano paka boromadia na baoma, amui bavani,
\q2 umui uda-ahu boromadia danu.
\q1 
\v 10 Ena gima taudia matadia na kekepulu,
\q2 iboudiai na asi aonegadia;
\q1 idia na sisia asi gadodia na heheto,
\q2 asi kwaru dibadia;
\q1 e nihimu, e hekuremu,
\q2 mahuta e ura henia lalo-dikamu.
\q1 
\v 11 Sisia na e gadodiamu,
\q2 bogadia asie kunumu;
\q1 mamoe ireḡudia taudia danu lalodia asie pararamu,
\q2 iboudiai na sibodia edia dala ai e raka sirimu,
\q1 iboudiai ta ta sibona ena namo sibona ena namo ihabadana e tahuamu,
\q2 ta se dabumu.
\q1 
\v 12 Idia na e tomu: Aoma, vine ranuna baita abia,
\q2 inuinu ḡauna goadana baita inua doroka-doroka;
\q1 bena kerukeru na hari dina ida baine heḡereḡere,
\q2 bada bona bada herea.
\c 57
\q1 
\v 1 Kara maoromaoro tauna e masemu negana ai,
\q2 ta ese se laloamu;
\q1 Dirava e matauraiamu taudia na e heabi ohomu negana ai,
\q2 ta lalona se pararamu.
\q1 Badina be kara maoromaoro tauna na hahehisi ḡaudia amo e heabi ohomu,
\q2 
\v 2 bona maino ai e vareaimu;
\q1 edia kara maoromaoro ai e rakamu taudia na
\q2 edia mahuta patadia latadiai laḡadia e animu.
\q1 
\v 3 A umui, mea hahinena natuna mamaruanemui,
\q2 heuda-hanai tauna bona ariara hahinena ese e havaramui taumui,
\q2 ini a raka mai.
\q1 
\v 4 Daidia o hevasehalaidiamu?
\q2 Daidia ihadikadia totona udumui o hahaḡa henidiamu,
\q2 bona malamui o toi lasimu?
\q1 Umui na dia kara kerere taudia natudia a?
\q2 Umui na dia kara koikoi ese e havaradia taudia a?
\q1 
\v 5 Umui na \it oak\it* imeadia ai o mata bodagamu,
\q2 bona au mauridia iboudiai henudiai danu, ani?
\q1 Umui ese natumui na koura ai o aladia masemu,
\q2 bona nadi kohuadia ai danu, ani?
\q1 
\v 6 Oi ahumu na koura nadidia manada-manadadia bogaragidiai;
\q2 momokani, idia na oi ahumu;
\q1 inuinu boubou ḡauna vada o seia ediai,
\q2 bona flaoa boubou ḡauna vada o mailaia.
\q2 Lalogu na baine keru unu ḡau daidiai a?
\q1 
\v 7 Ororo badana bona ḡaulatalatana dorinai
\q2 emu mahuta patana vada o atoa;
\q1 unu o dara dae lao,
\q2 emu boubou ḡauna ihahelaḡana totona.
\q1 
\v 8 Iduara bona iduara ihua-ihuana muridiai,
\q2 emu toa ḡauna vada o haginia;
\q1 badina be vada o rakatanigu, emu mahuta ḡauna vada o lailaia,
\q2 vada o dae henia, lababana vada o habadaia;
\q1 idia ida vada o gwau hamata,
\q2 edia mahuta patana vada o ura henia,
\q2 ḡaḡaedia ai vada o itadia.
\q1 
\v 9 Dehoro o abia kau, Molek dekena ola,
\q2 emu muramura mai bonadia danu o hahohodia;
\q1 emu gwaukau taudia na dauha o siaidia lao,
\q2 oibe, o siaidia diho, mase taudia edia dirava ediai.
\q1 
\v 10 Emu dala na daudau dainai o hesiku,
\q2 to asioto “Asi helarona”;
\q1 emu goada o hamatamataia,
\q2 taunabunai taumu se manori.
\b
\q1 
\v 11 Daika o gari henia?
\q2 Daika garina o gari bena o koikoi,
\q2 bona so lalogu tao, so lalogu une?
\q1 Nega daudau lau asina hereva,
\q2 taunabunai lau garigu so gari, a?
\q1 
\v 12 Emu lalo-maoromaoro bona emu kara baina herevalaidia,
\q2 to idia ese basie durumu.
\q1 
\v 13 Ba tai lolololo negana ai,
\q2 emu kaivakuku iboudiai ese bema hamaurimu;
\q1 a idia na lai ese baine odadia oho,
\q2 hodahoda ta ese baine abidia oho dauhai.
\q1 A egu ai baine roho mauri tauna ese tano baine ḡaunaia,
\q2 bona egu ororo helaḡana baine abia, ia ahuna.
\b
\s1 Dirava ena hekaha bona ena hahemauri
\p 
\v 14 Baeto: A larebaia, a larebaia;
\q2 dala avabia heḡaeḡae;
\q1 helao-ahu ḡaudia iboudiai na
\q2 egu orea taudia edia dala amo avabi oho.
\q1 
\v 15 Badina be Atai bona Herea-dae Diravana,
\q2 e noho hanaihanaimu bona ladana na helaḡa Diravana,
\q2 ini e gwau tomamu:
\q1 Lau na atai bona helaḡa gabuna ai na nohomu,
\q2 bona e helalo kerehaimu bona e lalo manaumu tauna ida danu,
\q1 lalo-manau tauna laumana baina haloua
\q2 bona e helalo kerehaimu tauna lalona baina haloua helaoreana.
\q1 
\v 16 Badina be basina heai hanaihanai,
\q2 bona basina badu hanaihanai;
\q1 badina be lauma na lauegu amo e lasimu,
\q2 bona mauri laḡana na lau ese vada na havaraia.
\q1 
\v 17 Ena mata-ḡaniḡani ai e kara havara dainai na badu,
\q2 na rahua mase, vairagu na hunia, na badu;
\q1 a ia na e roha muri havara-havara,
\q2 ia sibona lalona ena ura heḡereḡerena.
\q1 
\v 18 Ena kara vada na itadia, to baina hanamoa lou,
\q2 baina hakaua bona tauhalo baina henia;
\q1 e tailaiamu taudia ediai udu bibinadia anidia baina havaradia.
\q1 
\v 19 Iehova na e tomu: Maino, maino,
\q2 gabu daudau taudia bona gabu kahikahi taudia ediai;
\q2 bona lau ese baina hanamoa lou.
\q1 
\v 20 A kara dika taudia na davara hurehurena na heto,
\q2 ia na basine laḡa ani diba,
\q1 bona ena hurehure ese
\q2 e hanurika-nurikaiamu bona e haduhuamu.
\q1 
\v 21 Egu Dirava na e tomu:
\q2 Kara dika taudia ediai maino se miamu.
\c 58
\s1 Anivaga herevadia
\q1 
\v 1 A boi lolo, udumu basio hakapua,
\q2 gadomu ba habadaia, kibi na heto;
\q1 egu orea taudia na edia kerere ba hadibalaidia,
\q2 Iakob iduhuna taudia na edia dika ba hadibalaidia.
\q1 
\v 2 Ḡau tamona, idia na dina iboudiai e tahugumu,
\q2 egu dala idibadia e moalelaiamu,
\q1 kara maoromaoro e karamu bona edia Dirava ena taravatu se rakataniamu
\q2 besena na heto;
\q1 hahemaoro ḡoevaḡoevadia egu ai e noimu,
\q2 bona Dirava iraka-kahi-henina e moalelaiamu.
\q1 
\v 3 E tomu: Dahaka dainai ai vada a anivaga, a oi ese so itaia?
\q2 Dahaka dainai ai vada a hahemanau, a oi ese so dibaia?
\q1 A itaia, emui anivaga dinana ai sibomui emui ura o tahuamu,
\q2 bona emui ḡaukara taudia iboudiai o hahisihisidiamu.
\q1 
\v 4 A itaia, o anivagamu lalodiai o heaimu bona o heatumu mo,
\q2 bona imamui kahu-kuborodia dikadia amo o hetutumu.
\q1 Ina dina ai unu o anivaga tomamu dainai,
\q2 gadomui na atai ai basie hekamonai:
\q1 
\v 5 Lau na abia hidimu anivagana binai a:
\q2 tau ta sibona baine hahemanau,
\q1 bona kwarana baine ha-igoa diho, hido helouna na heto,
\q2 bona henunai puse dabuadia baine laha bona kahu baine ḡiḡi?
\q1 Ina na anivaga dinana
\q2 bona Iehova ese baine abia dae dinana ba gwauraia a?
\q1 
\v 6 Lasi, vada na abia hidi anivagana binai ani:
\q2 kara dika iḡuidia ba ruhadia,
\q2 bona maduna varodia danu;
\q1 e hahisihisidiamu taudia na ba ruhadia nege,
\q2 bona maduna iboudiai ba hakwaidudia?
\q1 
\v 7 Hitolo taudia ida amu aniani ba haria,
\q2 bona ogoḡami taudia asi edia ruma na emu ruma ai ba hakaudia vareai, ani?
\q1 Asi ena dabua tauna ba hadabualaia,
\q2 bona varavaramu edia amo basio komu, ani?
\q1 
\v 8 Una negana ai emu diari baine hedinarai, daba e kiniamu na heto,
\q2 bona ihanamo-loumu baine haraḡa;
\q1 emu kara maoromaoro na vairamu ai bainela,
\q2 bona Iehova hairaina na murimu igimana ai bainela.
\q1 
\v 9 Bena ba boiboi, bona Iehova baine haere;
\q2 ba tai henia, bena ia baineto “Lau o ina”.
\b
\q1 Bogaragimui amo maduna boma abia oho,
\q2 bona heduanai mataka-mataka bona hereva dikadia danu;
\q1 
\v 10 sibomui boma hebubu dua, hitolo taudia daidiai,
\q2 bona hisi e animu taudia na edia ura ḡaudia ba henidia;
\q1 bena emu diari na dibura ai baine hedinarai,
\q2 bona emu vabura na dina tubua ai bainela.
\q1 
\v 11 Iehova ese baine hakaumu hanaihanai,
\q2 bona ḡau namodia amo emu ura baine haḡuḡurua,
\q2 bona turiamu baine ha-aukadia;
\q1 bena e dairia louloumu umana heḡereḡerena ai baola,
\q2 ranu-lohilohi gabuna, ranuna se kororomu ḡauna, na heto.
\q1 
\v 12 Emui hanua gunadia, vada e vahu ḡaudia, na bae hahegini lou,
\q2 bona uru momo ba havaradia matama;
\q1 bae gwauraimu “e ḡiḡi dobi gabuna ibanina tauna”,
\q2 bona “taunimanima edia noho gabudia ihagini-loudia tauna”.
\b
\s1 Dina Helaḡa ibadinana
\q1 
\v 13 Dina Helaḡa ai aemui boma naridia,
\q2 bona sibomui emui ura basioma kara egu dina helaḡana lalonai;
\q1 bona Dina Helaḡa na moale dinana
\q2 bona Iehova ena dina helaḡana na hemataurai dinana boma gwauraia;
\q1 boma matauraia, sibomui emui dala ai basioma raka,
\q2 sibomui emui ura basioma tahua,
\q2 bona basioma hereva kava hereva kava;
\q1 
\v 14 bena Iehova ba moalelaia,
\q2 bona lau ese tanobada ena gabu badadia ai baina hakaumui;
\q1 senemui Iakob ahuna amo baina ubumui,
\q2 badina be Iehova uduna vada e hereva.
\c 59
\s1 Basileia ena kara dika ihahedinaraina
\q1 
\v 1 A itaia, Iehova imana bema tuna, ia na basinema hahemauri diba,
\q2 to se tunamu;
\q1 eiava taiana bema kudima, ia na basinema kamonai diba,
\q2 to se kudimamu.
\q1 
\v 2 A emui kara havara ese
\q2 umui bona emui Dirava vada e hapararamui;
\q1 bona emui kara dika ese
\q2 ia vairana na emui ai vada e hunia;
\q2 taunabunai ia na se kamonaimu.
\q1 
\v 3 Badina be imamui na rara ese vada e hamirodia,
\q2 bona imamui kwakikwakidia danu kara havara ese;
\q1 udumui bibinadia ese hereva koikoidia vada e gwaurai,
\q2 bona malamui ese dika e hemudumalaia.
\q1 
\v 4 Asi tauna ta e hahebade maoromaoromu,
\q2 asi tauna ta e hahemaoro momokanimu;
\q1 idia na hereva asi anidia ai e taomu,
\q2 bona e hereva koikoimu;
\q1 kara koikoi e lalo hatamu,
\q2 bona kara havara e havaramu.
\q1 
\v 5 Duba gatoidia e hapapadiamu,
\q2 bona magera valavalana e karaiamu;
\q1 gatoidia e animu taudia na e masemu,
\q2 bona e moia taomu gatoina amo derekaka na e lasimu.
\q1 
\v 6 Valavaladia na basie heḡereḡere hahedoki ḡaudia;
\q2 e karamu ḡaudia na taunimanima ese basie hahedokilai.
\q1 Edia ḡaukara na kara havara,
\q2 bona ala-ala karadia na imadia ai.
\q1 
\v 7 Aedia ese dika e heau heniamu,
\q2 bona asi edia kerere taudia raradia na e hahebubudia haraḡaharaḡamu;
\q1 edia lalo-hadai ai kara dika e lalolai hadaimu,
\q2 hahevahu bona hahebua-tari na edia laolao daladia ai.
\q1 
\v 8 Maino dalana na asi dibadia,
\q2 bona edia dala lalodiai hahemaoro ḡoevaḡoeva na lasi;
\q1 idia ese edia dala vada e hagagevadia,
\q2 bona unu dala lalodiai e rakamu taudia iboudiai na maino asi dibadia.
\b
\q1 
\v 9 Taunabunai, ai emai ai hahemaoro ḡoevaḡoeva na dauhai,
\q2 bona kara maoromaoro ese se lasimai taomu;
\q1 diari a tahuamu, a dibura mo a itaiamu,
\q2 diari paitapaitana a tahuamu, a vabura ai a rakamu.
\q1 
\v 10 Haba a darahuamu, mata-kepulu taudia na heheto,
\q2 a hedarahumu, asi matadia taudia na heheto;
\q1 dina tubua ai a hetutuhimu, adorahi mairumairuna ai na heto,
\q2 goada korikori taudia bogaragidiai ai na mase taudia na heheto.
\q1 
\v 11 Ai iboumai ai na bea heḡereḡeredia a ḡoumu;
\q2 a tai louloumu, pune na heheto.
\q1 Hahemaoro ḡoevaḡoeva a tahuamu, to asi ḡauna;
\q2 hahemauri a tahuamu, to ia na dauhai.
\q1 
\v 12 Badina be emai kerere na momo herea oi vairamu ai,
\q2 bona emai kara dika ese e habadelaimaimu;
\q1 emai kerere na emai ai mimia,
\q2 bona emai kara havara dibamai.
\q1 
\v 13 A kereremu, Iehova a ḡoreamu,
\q2 emai Dirava igavana amo a raka ohomu;
\q1 hahehisi bona daḡedaḡe karadia a herevalaimu,
\q2 hereva koikoidia a havaradiamu, bona lalomai amo a gwauraimu.
\q1 
\v 14 Hahemaoro ḡoevaḡoeva vada e lou,
\q2 bona kara maoromaoro na dauhai e ginimu;
\q1 badina be hereva momokani na hanua ariaradia ai vada e moru,
\q2 bona hereva maoromaoro na basine raka vareai diba.
\q1 
\v 15 Hereva momokani na se miamu,
\q2 bona dika e rakataniamu tauna na sibona damuḡa ai e hahelao.
\q1 Iehova ese e itaia, bena baduna e badu,
\q2 hahemaoro ḡoevaḡoeva na lasi dainai.
\q1 
\v 16 E itaia, asi tauna ta noho,
\q2 e hoa, badina be asi helao-ahu tauna ta;
\q1 bena sibona imana e kwalimu,
\q2 bona ena kara maoromaoro ese e imudaia.
\q1 
\v 17 Kara maoromaoro na e dokia, kemena aurina,
\q2 bona hahemauri na kwarana ai e atoa, ena kwara ḡauna;
\q1 dika davana ihalouna e hahedokilaia, ena dabua,
\q2 bona badu e hetarulaia, ena dabua badana.
\q1 
\v 18 Edia kara heḡereḡeredia ai ia ese davadia baine henidia,
\q2 badu na e heai heniamu taudia ediai,
\q1 bona dava ihalouna na e inai heniamu taudia ediai;
\q2 bona kone tanodia ediai danu dava baine haloua.
\q1 
\v 19 Taunabunai, lahara kahana amo Iehova ladana bae gari henia,
\q2 bona dina-dae kahana amo ia hairaina garina bae gari;
\q1 badina be utu-utu heḡereḡerena ai bainema,
\q2 Iehova ena lai ese e ha-utua daemu ḡauna.
\b
\q1 
\v 20 Iehova na e tomu:
\q2 Ia na Siona bainema, taunimanima ihamauridia totona,
\q2 bona Iakob ena iduhu ai hahidaosi ese edia kerere bae rakatanidia taudia ediai danu.
\b
\p 
\v 21 Iehova na e tomu, Ina na egu gwauhamata idia ediai: lau laumagu oi latamu ai bona egu hereva oi udumu ai vada na ato ḡaudia ese udumu basie rakatania, bona natumu ududia bona garamu ududia basie rakatanidia, ina nega amo ela bona hanaihanai. Iehova na e herevamu.
\c 60
\s1 Siona hairaina
\q1 
\v 1 A tore isi, a diari-diari, badina be emu diari vada e kau,
\q2 bona Iehova hairaina na emu ai vada e tata dae roha,
\q1 
\v 2 Badina be dibura ese tanobada baine gorua ahu,
\q2 dibura ḡabora ese tanobada besedia baine gorudia ahu;
\q1 a Iehova na oiemu ai baine tata dae roha,
\q2 bona ia hairaina na emu ai baine hedinarai.
\q1 
\v 3 Bese idau-idau ese diarimu bae mai henia,
\q2 bona pavapava ese emu tata-dae-roha diarina ai baema.
\b
\q1 
\v 4 Ba roharoha, ba itaia,
\q2 idia na e heboumu, e vasimu;
\q1 natumu mamaruanedia na dauha amo baema,
\q2 bona natumu kekenidia na bae dagiradia.
\q1 
\v 5 Do ba itaia, bena vairamu baine hairai,
\q2 bona lalomu baine haraḡa-haraḡa moale dainai;
\q1 badina be davara anina loḡora na emu ai bae mailai,
\q2 bona basileia idau-idau edia taḡa na emu ai bae kau.
\q1 
\v 6 Kamelo hutuma bada ese emu tano bae hahonua,
\q2 Midian bona Efa edia kamelo natudia;
\q2 bona Sieba ena iboudiai danu baema.
\q1 Idia ese \it gold\it* bona muramura mai bonana bae hua mai,
\q2 Iehova ihanamona bae gwauraia hedinarai.
\q1 
\v 7 Kedara ena mamoe seridia iboudiai na emu ai bae haboudia,
\q2 Nebaioto ena mamoe mamaruanedia ese oi isiaimu bae lao heni;
\q1 egu ihaboulaina patana baema negana ai baina abidia dae,
\q2 bona egu dubu herea-daena hairaina baina habadaia.
\b
\q1 
\v 8 Ini be daidia, ori na heto e heaumu,
\q2 eiava pune ese edia ruma gaba-maurudia e roho henimu na heto?
\q1 
\v 9 Badina be kone tanodia ese bae narigu,
\q2 Tarasisi lagatoidia bae guna;
\q1 natumu mamaruanedia na dauha amo bae mailaidia,
\q2 mai edia \it silver\it* bona edia \it gold\it* ida danu,
\q1 Iehova, emu Dirava, ladana dainai,
\q2 Israel ena Helaḡa Diravana bagunai;
\q2 badina be ia ese vada e hahairaimu.
\q1 
\v 10 Idau bese taudia ese maḡumu baine larebadia,
\q2 edia pavapava ese isiaimu bae lao heni;
\q1 badina be egu badu ai na rahumu mase,
\q2 to egu lalo-namo ai vada na bogamu hisi.
\q1 
\v 11 Emu ikoukou bae hekeho hanaihanai,
\q2 dina ai bona hanuaboi ai basie hekou;
\q1 bena taunimanima ese basileia idau-idau edia taḡa na dekemu baemailai,
\q2 bona iru ta ta ai edia pavapava bae hakaudia mai.
\q1 
\v 12 Badina be isiaimu basine lao heni besena eiava basileiana na baine mase;
\q2 unu bese na bae hebua tari vaitani.
\q1 
\v 13 Lebanon hairaina na emu ai baine kau,
\q2 beroso bona tidara bona teasuru\f + \fr 60:13 \ft Beroso, tidara, teasuru. Ini na Heberu taudia edia au haida ladadia.\f* audia,
\q1 egu gabu helaḡana ihahairaina totona;
\q2 bona aegu gabuna hairaina baina habadaia.
\q1 
\v 14 E hahisihisimuva taudia natudia na
\q2 oi vairamu ai bae igo diho,
\q1 bona e dadaraimuva taudia iboudiai na
\q2 oi aemu badidiai bae toma diho;
\q1 bae gwauraimu “Iehova ena Hanua,
\q2 Israel ena Helaḡa Diravana ena Siona”.
\b
\q1 
\v 15 Vada e rakatanimu bona e inai henimu,
\q2 bona ta na lalomu amo se raka hanai;
\q1 to lau ese lohia hairaina do baina henimu, emu ai baine mia hanaihanai,
\q2 bona uru uru iboudiai moaledia ai baina halaomu.
\q1 
\v 16 Basileia idau-idau ratadia ba inu,
\q2 pavapava ratadia ba topo;
\q1 bona ba diba, lau Iehova na Ihamaurimu Diravana,
\q2 oi Irauamu, Iakob ena Goada Diravana.
\b
\q1 
\v 17 Auri labora-labora ibolona ai \it gold\it* baina mailaia,
\q2 bona auri ibolona ai \it silver\it*;
\q1 au ibolona ai auri labora-labora baina mailaia,
\q2 bona nadi ibolodia ai auri.
\q1 Maino na baina henimu, baine itamu tao,
\q2 bona kara maoromaoro baina henimu, baine biagumu.
\q1 
\v 18 Ala-ala reḡedia basio kamonai lou emu tano ai,
\q2 eiava hahevahu eiava hahebua-tari emu hetoa lalodiai;
\q1 emu maḡu ladadia ba hato “Hahemauri”,
\q2 bona emu ikoukou “Heimodai”.
\b
\q1 
\v 19 Dina ese basine hadiarimu lou dina ai,
\q2 eiava hua kiama-kiamana ese basine hadiarimu hanuaboi ai;
\q1 a Iehova na emu mia-hanaihanai diarina ai bainela,
\q2 bona emu Dirava na hairaimu ai bainela.
\q1 
\v 20 Emu dina na basine diho lou,
\q2 bona emu hua diarina na basine maraḡi lao,
\q1 badina be Iehova na emu mia-hanaihanai diarina ai bainela,
\q2 bona emu tai dinadia bae ore.
\q1 
\v 21 Emu taunimanima iboudiai na bae kara maoromaoro,
\q2 tano na bae ḡaunaia hanaihanai,
\q1 na hadoa uhena, lau imagu ḡaukarana,
\q2 lau bae imodaigu totona.
\q1 
\v 22 Gabe tauna na iduhu ta ai bainela,
\q2 bona maragi-maragina na bese badana mai goadana ai bainela.
\q1 Lau binai Iehova;
\q2 negana korikorina ai lau ese baina havaraia haraḡa.
\c 61
\s1 Hahemauri Herevadia Siona ena
\q1 
\v 1 Ḡaubada Iehova ena Lauma ese e rohegumu,
\q2 badina be Iehova ese vada e horogu,
\q2 hisi e animu taudia dekediai hari namodia baina mailai totona.
\q1 Ia ese vada e siaigu,
\q2 dara-doko taudia taudia ihalodia
\q1 bona iḡui taudia iruha-negedia
\q2 bona dibura rumana ai e hekoumu taudia ikehodia
\q2 baina gwaurai totona.
\q1 
\v 2 Vada e siaigu, Iehova ena hahenamo laḡanina
\q2 bona dika idavalaina dinana, eda Dirava ena, baina gwaurai,
\q2 bona taitai taudia iboudiai taudia baina halodia totona.
\q1 
\v 3 Vada e siaigu, Siona ai e taitaimu taudia iboudiai na
\q2 herahera iturina baina henidia, kahu ibolona,
\q1 bona moale dehorona, taitai ibolona,
\q2 bona heimodai dabuana, lalo-manoka ibolona;
\q1 bena kara maoromaoro audia bae gwauraidia,
\q2 Iehova ese e hado ḡaudia,
\q2 ia bae imodaia helaoreana.
\q1 
\v 4 Idia ese idau nega ai e heḡiḡi dobi rumadia na bae haginidia lou,
\q2 bona e vahu guna gabudia na bae hamatamatadia;
\q1 bona e heḡiḡi dobi hanuadia na bae hanamodia lou,
\q2 uru momo lalodiai vada e vahu ḡaudia.
\b
\q1 
\v 5 Idau taudia na bae gini, emui mamoe seridia bae ubudia,
\q2 idau bese taudia na emui tano iruadia bona emui vine ireḡudia taudia ai baela;
\q1 
\v 6 a umui na Iehova ena hahelaḡa taudia bae gwauraimui,
\q2 bae herevalaimui, eda Dirava isiaina ilao-henina taumui;
\q1 basileia idau-idau edia taḡa ai bavaniani,
\q2 bona edia kohu namodia iabidia ai ba heaḡi.
\q1 
\v 7 Emui hemarai ibolona na ahumui rua bavabi,
\q2 bona idadaraimui ibolona na ahumui ba moalelai;
\q1 taunabunai emui tano ai ahumui rua bavabi,
\q2 bona moale hanaihanai na emui ai baine mia.
\b
\q1 
\v 8 Badina be lau Iehova ese hahemaoro ḡoevaḡoeva na ura heniamu,
\q2 bona dadidadi karadia bona kara dikadia na inai henimu;
\q1 lau ese davadia baina henidia mai momokanigu ida,
\q2 bona mia-hanaihanai gwauhamatana baina henidia.
\q1 
\v 9 Garadia haridia na basileia idau-idau bogaragidiai bae hedinarai,
\q2 bona vevedia haridia danu bese idau-idau bogaragidiai;
\q1 bae itadia taudia iboudiai ese bae herevalaidia, baeto,
\q2 idia na Iehova ese vada e hanamodia taudia.
\b
\q1 
\v 10 Lau ese Iehova baina moalelaia bada,
\q2 lau laumagu-ese egu Dirava baine heaḡilaia;
\q1 badina be ia ese hahemauri dabuadia ai vada e hadabualaigu,
\q2 bona kara maoromaoro dabuana ai vada e hatarulaigu,
\q1 headava matamata tauna ese herahera iturina amo sibona e heralaimu
\q2 bona headava matamata hahinena ese herahera nadidia amo sibona e heralaimu na heheto.
\q1 
\v 11 Badina be tano ese tuhutuhu e havaradiamu
\q2 bona uma ese ia lalonai e hado ḡaudia e hatubudiamu na heto,
\q1 Ḡaubada Iehova ese kara maoromaoro bona heimodai na
\q2 unu baine hatubudia toma, bese iboudiai variadiai.
\c 62
\q1 
\v 1 Siona dainai lau udugu basina hakapua,
\q2 bona Ierusalem dainai laḡagu basina ania,
\q1 ela bona ia igwaurai-maorona baine lasi, diari na heto,
\q2 bona ia ihamaurina, kede na heto.
\q1 
\v 2 Basileia idau-idau ese oi igwaurai-maoromu bae itaia,
\q2 bona pavapava iboudiai ese oi hairaimu bae itaia;
\q1 bona lada matamatana bae hahenemailaimu,
\q2 Iehova uduna ese baine heni ladana.
\q1 
\v 3 Oi na kwara ihavavalaina ḡauna mai hairaina ai baola, Iehova imana ai,
\q2 bona pavapava kwarana ihavavalaina ḡauna ai, emu Dirava imana ai.
\q1 
\v 4 Oi ladamu basie hatoa lou “Vada e rakatania”,
\q2 bona emu tano basie gwauraia lou “Vada e vahu”;
\q1 a oi ladamu bae hatoa “Na moalelaiamu”,
\q2 bona emu tano bae gwauraia “Vada e headava”;
\q1 badina be Iehova ese oi e moalelaimumu,
\q2 bona emu tano na baine headava.
\q1 
\v 5 Badina be tauhau ese hane-ulato rami-hebouna e adavaiamu na heto,
\q2 oi Ihaginimu Tauna ese baine adavamu;
\q1 bona headava matamata tauna ese adavana e moalelaiamu heḡereḡerena,
\q2 emu Dirava ese unu baine moalelaimu toma.
\b
\q1 
\v 6 Ierusalem e, gima taudia vada na atodia heḡaeḡae,
\q2 oiemu maḡu latadiai;
\q1 dina idoinai bona hanuaboi idoinai
\q2 idia na eredia basie kuma.
\q1 Umui Iehova o hahelaloa une taumui,
\q2 basio laḡa ani,
\q1 
\v 7 bona basio halaḡaia ani,
\q2 ela bona ia ese Ierusalem baine haginia, auka,
\q2 bona heimodai ḡauna ai baine halaoa tanobada ai.
\q1 
\v 8 Iehova ese imana idibana bona imana mai goadana
\q2 daidiai vada e gwau hamata, eto:
\q1 Lau ese emu uit na oi inaimu basina ubulaidia lou,
\q2 bona idau taudia ese emu vine ranuna, o hekwarahilaia ḡauna, na basie inua,
\q1 
\v 9 a e gogoamu taudia ese bae ania,
\q2 bena Iehova bae imodaia,
\q1 bona e habouamu taudia ese bae inua,
\q2 egu gabu helaḡana ikoudia ai.
\b
\q1 
\v 10 A raka vareai, ikoukou amo a raka vareai,
\q2 taunimanima edia dala a heḡaeḡaelaia;
\q1 laolao dalana a haḡoevaia, a haḡoevaia,
\q2 nadi na ba gogo oho;
\q1 pepe a duduia isi
\q2 bese idau-idau daediai!
\q1 
\v 11 A itaia, Iehova ese vada e gwauraia hedinarai
\q2 ela bona tanobada dokona, eto,
\q1 Siona hahinena ba hamaoroa, baoto:
\q2 A itaia, ihamaurimu na e maimu;
\q1 a itaia, ena dava na ia ida,
\q2 bona ena ahu na ia vairanai.
\q1 
\v 12 Idia ladadia bae hato
\q2 “Orea helaḡana, Iehova ese vada e rauadia taudia”;
\q1 bona oi ladamu bae hatoa
\q2 “E tahuamu, se rakataniamu, hanuana”.
\c 63
\s1 Iehova ena dava-kara dinana
\q1 
\v 1 Una na daika Edom amo e maimu?
\q2 Daika mai dabuana kakakakana ida Bosra amo e maimu?
\q1 Mai dabuana herea-daedia bona mai goada bada-hereana ida
\q2 e rakamu tauna be daika?
\b
\q1 Tauna na lau, igwaurai-maorona na gwauraimu;
\q2 mai siahugu ida baina hahemauri.
\b
\q1 
\v 2 Dahaka dainai emu dabua na kakakaka,
\q2 bona emu hahedoki na vine huahuadia e moimoilaimu tauna ena dabua heḡereḡeredia?
\b
\q1 
\v 3 Sibogu vine huahuadia vada na moimoilai;
\q2 asi tauna ta lau ida, bese idau-idau edia amo.
\q1 Egu badu ai na moimoilaidia,
\q2 egu badu ḡaraḡara ai na moidia tao;
\q1 edia mauri raradia ese egu hahedoki vada e nevaridia,
\q2 egu dabua iboudiai vada na hamirodia.
\q1 
\v 4 Badina be dika davana ikarana dinana na lalogu ai e miava,
\q2 bona egu raua-raua laḡanina vada e kau.
\q1 
\v 5 Lau na roha lao, to asi idurugu ta;
\q2 daragu e doko, to asi imudagu ta;
\q1 taunabunai, sibogu imagu amo kwalimu na abia,
\q2 bona egu badu ḡaraḡara ese e imudagu.
\q1 
\v 6 Egu badu ai bese idau-idau na moidia tari,
\q2 egu badu ḡaraḡara amo na hakekerodia,
\q2 bona edia mauri raradia na tano ai na hahebubudia.
\b
\s1 Iehova ena hahenamo Israel enai
\q1 
\v 7 Iehova ena hebogahisi baina herevalaia,
\q2 bona Iehova i'imodaina danu,
\q1 Iehova ese vada e henida ḡaudia iboudiai heḡereḡeredia,
\q2 bona Israel besena ihanamodia karadia badadia danu,
\q1 ia ese vada e henidia ena hebogahisi heḡereḡerena,
\q2 ena lalokau bada-hereana heḡereḡerena.
\q1 
\v 8 Badina be ia eto “Momokani idia na lauegu bese,
\q2 lau natugu, basie kara koikoi”;
\q1 bena ia na Ihamauridia Diravana ai ela,
\q2 
\v 9 edia hisihisi iboudiai ia ese e hisihisilai,
\q2 bona ia vairana amo ema aneruna ese e hamauridia;
\q1 ena lalokau bona ena hebogahisi ai ia ese e rauadia,
\q2 nega gunadia iboudiai lalodiai ia ese e abidia isi bona e dosidia.
\q1 
\v 10 A idia na e daḡedaḡe,
\q2 bona iena Lauma helaḡana e hahisihisia;
\q1 taunabunai, ia na e kerehai,
\q2 adia inai tauna ai ela,
\q2 ia sibona ese e tuari henidia.
\q1 
\v 11 Bena ia ese nega gunadia e helalolai une,
\q2 ena hesiai tauna Mose negana.
\q1 Ena mamoe serina ireḡuna tauna na
\q2 davara lalona amo e hakaua dae Diravana be edeseni ai?
\q1 Ena Lauma helaḡana idia bogaragidiai e atoa,
\q2 
\v 12 bona ia imana herea-daena ese Mose imana idibana e bamoava,
\q1 bona vairadiai ranu e hapararadia,
\q2 mia-hanaihanai ladana ta sibona baine abia totona,
\q1 
\v 13 bona dobu gabudia amo e hakaudia hanai,
\q2 Diravana be edeseni ai?
\q1 Hosi tano ḡaḡaena ai na heto,
\q2 idia na asie hetutuhi;
\q1 
\v 14 boromakau koura ai e hekei dihomu na heheto,
\q2 Iehova ena Lauma ese laḡadia e ha-ani.
\q1 Taunabunai oi ese emu bese taudia o hakaudia,
\q2 lada herea-daena sibomu bavabia totona.
\b
\s1 Hebogahisi bona Hekaha inoilaina
\q1 
\v 15 Guba amo ba roha dobi,
\q2 emu noho gabuna helaḡana bona herea-daena amo ba itaia.
\q1 Goadamu bona siahumu be edeseni ai?
\q2 Emu lalokau bona emu hebogahisi na lauegu amo vada o rua.
\q1 
\v 16 Badina be oi na ai Tamamai;
\q2 ena be Abraham asi dibana ai,
\q1 bona Israel ese besena ai se halaomaimu,
\q2 to oi Iehova na ai Tamamai;
\q1 oi ladamu na ai Irauamai,
\q2 nega gunadia amo.
\q1 
\v 17 Iehova e, dahaka dainai emu dala ai o hakereremaimu,
\q2 bona lalomai o ha-aukadiamu, bena asia gari henimumu?
\q1 Emu hesiai taudia, oi dihimu besena,
\q2 daidiai ba lou mai.
\q1 
\v 18 Nega taina emu bese helaḡana ese emu gabu helaḡana e noholaia;
\q2 a inaimai ese vada e moia tari.
\q1 
\v 19 Ai na nega ta so lohiadia taudia heḡereḡeredia ai vada ala,
\q2 oi ladamu asie henemailai taudia heḡereḡeredia ai.
\c 64
\q1 
\v 1 Guba boma hapararaia, boma diho!
\q2 Ororo bema heude-heude oi vairamu ai!
\q1 
\v 2 Lahi ese au rakodia e aradiamu,
\q2 bena ranu e hadaidaiamu na heto,
\q1 oi ese ladamu na inaimu ba hadibalaia,
\q2 bona basileia idau-idau na oi vairamu ai bae heude-heude helaoreana.
\q1 
\v 3 Hahegari karadia, asia larova karadia, o kara negana ai,
\q2 oi na o diho, bena ororo na oi vairamu ai e heude-heude.
\q1 
\v 4 Sene negana amo tau ta se kamonai,
\q2 eiava taiana ai reḡe ta se vareai,
\q1 bona mata ta ese dirava idauna ta se itaia, oi mo sibomu;
\q2 oi na e narimumu taudia daidiai o ḡaukaramu Diravana.
\q1 
\v 5 Oi ese mai moalena ida e kara maoromaoromu tauna
\q2 bona emu dala ai e lalomu taomu taudia
\q2 o hedavari henidiamu.
\q1 A itaia, oi na o badu, bona ai na a kara dika,
\q2 emai kara dika ai vada a noho daudau;
\q2 baia hahemauri diba a?
\q1 
\v 6 Ai iboumai ai na se haheḡoeva tauna na heto,
\q2 bona emai kara maoromaorodia iboudiai na e hamiroa dabuana na heto.
\q1 Ai iboumai ai a maraimu, au rauna ta na heto,
\q2 bona emai kara havara ese e odamai ohomu, lai na heto.
\q1 
\v 7 Asi tauna ta ese oi ladamu e hahaneamu,
\q2 eiava oi ikahu-taomu e gugulaiamu;
\q1 badina be oi ese vairamu na ai emai amo vada o hunia,
\q2 bona emai kara havara lalodiai vada o negemai.
\b
\q1 
\v 8 Ḡau tamona, Iehova e, oi na ai Tamamai;
\q2 ai na raro, oi na ikuimai Tauna;
\q2 ai iboumai ai na oi imamu karakaradia.
\q1 
\v 9 Iehova e, basio badu ḡaraḡara,
\q2 bona kara havara na basio lalo tao hanaihanai.
\q1 A itaia bona ba haeroa,
\q2 ai iboumai ai na oiemu bese taumai.
\q1 
\v 10 Oiemu hanua helaḡadia vada e ḡaḡae,
\q2 Siona danu vada e ḡaḡae,
\q2 Ierusalem vada e hahevahu.
\q1 
\v 11 Emai dubu helaḡana mai hairaina,
\q2 senemai ese oi e imodaimuva gabuna,
\q1 na
\s1 lahi ese vada e araia,
\q2 bona a moalelaiva gabudia vada e vahu.
\q1 
\v 12 Iehova e, ini ḡau e varamu, a imamu do ba veria dua a?
\q2 Asi reḡereḡemu ba noho, bona ba hahisihisimai badabada a?
\c 65
\s1 Gwau-edeede davana
\q1 
\v 1 Lau na heḡaeḡae, asie nanadailaigu taudia bae tahugu nato;
\q2 na heḡaeḡae, asie tahugu taudia bae davarigu nato.
\q1 Ladagu asie hahanea basileiana taudia na hereva henidia,
\q2 nato “Lau o ina, lau o ina”.
\q1 
\v 2 Dagedage besena, dala dia namo ai e rakamu taudia,
\q2 sibodia edia ura e ḡavadiamu taudia, na
\q2 imagu na toi roro henidiamu, dina idoinai.
\q1 
\v 3 Idia ese ihabadugu karadia
\q2 lau vairagu ai e kara louloumu;
\q1 uma lalodiai boubou karadia e karamu,
\q2 bona e tunu nadidia latadiai muramura mai bonadia e gabumu;
\q1 
\v 4 gara gabudia ai e helaimu,
\q2 bona gabu hehunidia ai e noho ranimu.
\q1 Idia ese boroma hidiodia e animu,
\q2 bona ḡau dika-rohorohodia vasiahudia na edia uro ai.
\q1 
\v 5 Idia na e tomu “Dauhai ba noho, basio raka henigu kahi,
\q2 badina be lau na helaḡa oiemu ai”.
\q1 Ini na kwalahu, udu-baubaugu ai,
\q2 dina idoinai e aramu lahina.
\q1 
\v 6-7 A itaia, lau vairagu ai ini e hetore toma:
\q2 Iehova na e tomu,
\q1 Udugu basina hakapua, a dava baina haloua,
\q2 oibe, edia kara havara bona tamadia edia kara havara
\q2 danu davadia na latadiai baina halou henidia;
\q1 badina be muramura mai bonadia na ororo badadia ai vada e gabu,
\q2 bona ororo maraḡidia ai vada e ḡonaḡonalaigu;
\q1 una dainai edia kara gunadia davadia na
\q2 latadiai baina hahetoho henidia.
\b
\q1 
\v 8 Iehova ini e gwau tomamu:
\q2 Vine ranuna na vine takona e abiamu,
\q1 bena idia na e tomu “Basio hadikaia,
\q2 badina be hahenamo na ia lalonai”;
\q1 una heḡereḡerena ai lau danu baina karaia
\q2 egu hesiai taudia daidiai,
\q2 bena iboudiai basina habuadia tari.
\q1 
\v 9 Iakob garana na baina havaradia,
\q2 bona Iuda ena amo egu ororo inoholaidia taudia na baina havaradia;
\q1 egu abi-hidi taudia ese bae biagua,
\q2 bona egu hesiai taudia na unuseni ai bae noho.
\q1 
\v 10 Saron na mamoe seridia edia rei gabuna ai bainela,
\q2 bona Akoro Kourana na boromakau seridia edia hekure gabuna ai bainela,
\q2 egu bese taudia, vada e tahugu taudia, edia.
\q1 
\v 11 A Iehova o rakataniamu
\q2 bona egu ororo helaḡana o laloa boiomu taumui e,
\q1 Mari patana o lailaiamu
\q2 bona vine ranudia o bulodiamu, Bagu-haoro keheredia o hahonumu, taumui e,
\q1 
\v 12 lauegu bagu-haoro emui ai be dare,
\q2 iboumui ai na ala-ala ai ba mase;
\q1 badina be na boiboi negana ai asio haere,
\q2 bona na hereva negana ai asio kamonai,
\q1 a kara dika na lauegu ita-ita ai o karaia,
\q2 bona lau asina moalelaia ḡauna o abia hidi.
\b
\q1 
\v 13 Taunabunai Ḡaubada Iehova na ini e gwau tomamu:
\q2 A itaia, egu hesiai taudia bae aniani,
\q2 to umui na ba hitolo;
\q1 a itaia, egu hesiai taudia na ranu bae inu,
\q2 to umui na ba ranu mase;
\q1 a itaia, egu hesiai taudia bae moale,
\q2 to umui na bae hahemaraimui;
\q1 
\v 14 a itaia, egu hesiai taudia ese ane bae abi, edia lalo-namo dainai,
\q2 to umui na emui lalo-hisihisi ai ba tai lolololo,
\q2 bona emui lauma-daure ai ba ḡanaḡana.
\q1 
\v 15 Umui ladamui na heuduguirai herevadia ai baela,
\q2 egu abi-hidi taudia ududia ai.
\q1 Ḡaubada Iehova ese umui baine alamui mase,
\q2 a ena hesiai taudia na lada idauna ta ai baine hahenemailaidia.
\q1 
\v 16 Una dainai tano ai sibona baine hahenamo tauna na
\q2 hereva momokani Diravana ladana ai baine hahenamo,
\q1 bona tano ai baine gwau hamata tauna na
\q2 hereva momokani Diravana ladana ai baine gwau hamata;
\q1 badina be hekwarahi gunadia na lalodia amo vada e boio,
\q2 bona lau matagu amo vada e hehuni.
\b
\s1 Guba matamatana bona tanobada matamatana
\q1 
\v 17 A itaia, guba matamatana bona tanobada matamatana na karadiamu,
\q2 bona ḡau gunadia na basie lalodia tao bona basie lalodia une.
\q1 
\v 18 A ba lalo namo, ba moale hanaihanai,
\q2 na karamu ḡaudia ba moalelai;
\q1 badina be Ierusalem na karaiamu, moale ḡauna,
\q2 bona ena taunimanima na karadiamu, moale taudia.
\q1 
\v 19 Lau ese Ierusalem baina moalelaia,
\q2 bona egu bese taudia danu baina moalelaidia;
\q1 ia lalonai taitai reḡedia na basie hekamonai lou,
\q2 bona lalo-hisihisi ganaganadia danu.
\q1 
\v 20 Dina dia hoho e maurimu merona,
\q2 eiava ena dina se haḡuḡurudiamu tau-burukana,
\q2 na ia lalonai basie hedinarai lou;
\q1 badina be mero na baine noho ela bona laḡani sinahu-ta,
\q2 bona laḡani sinahu-ta basine hagugurudia tauna na
\q2 kara dika tauna bae gwauraia.
\q1 
\v 21 Ruma bae haginidia bena bae noholai;
\q2 vine imeadia bae hado, bena anidia bae ani.
\q1 
\v 22 Dia idia ese bae haginidia, bena idauna ta ese baine noholai,
\q2 bona dia idia bae hadohado, bena idauna ta ese baine anianilai;
\q1 badina be au ena mauri dinadia heḡereḡeredia,
\q2 egu bese taudia edia mauri dinadia unu bae hoho toma;
\q1 bona egu abi-hidi taudia ese
\q2 imadia ḡaukaradia bae moalelai daudau.
\q1 
\v 23 Basie hekwarahi kava,
\q2 bona natudia basie havaradia, dika ena;
\q1 badina be idia na Iehova ena lalokau taudia natudia,
\q2 bona idia natudia danu idia ida.
\q1 
\v 24 Do basie boiboi ai, lau baina haere;
\q2 bona dounu e herevamu ai, lau baina kamonai.
\q1 
\v 25 Uda sisiana bona mamoe natuna na bae aniani hebou,
\q2 leona ese rei baine ania, boromakau na heto;
\q2 bona ḡahu na gaigai ana aniani ai bainela.
\q1 Basie hahehisi bona basie hahebua-tari,
\q2 egu ororo helaḡana idoinai latanai.
\q2 Iehova na e herevamu.
\c 66
\s1 Iehova ese Ierusalem e herevalaia
\q1 
\v 1 Iehova ini e gwau tomamu:
\q2 Guba na egu terono, bona tanobada na aegu ihadaidia ḡauna;
\q1 ruma edehetomana ba haginia, egu,
\q2 bona egu laḡa-ani gabuna be edena?
\q1 
\v 2 Ini ḡau iboudiai lau imagu ese vada e kara,
\q2 una dainai ini ḡau iboudiai na lauegu.
\q2 Iehova na e herevamu.
\q1 A baina haḡerea tauna binai:
\q2 e lalo-manaumu bona e helalo kerehaimu tauna,
\q2 egu hereva magigina e magigimu tauna.
\b
\q1 
\v 3 Boromakau maruanena e alaia masemu tauna na
\q2 tau ta e alaia masemu tauna heḡereḡerena;
\q1 mamoe natuna na boubou ḡauna ai e halaoamu tauna na
\q2 sisia aiona e hakwaiduamu tauna heḡereḡerena;
\q1 flaoa boubouna e hahelagaiamu tauna na
\q2 boroma rarana e hahelaḡaiamu tauna heḡereḡerena;
\q1 muramura mai bonana na helalo-tao herahiana ai e halaoamu tauna na
\q2 kaivakuku e hanamoamu tauna heḡereḡerena.
\q1 Unu iboudiai ese sibodia edia dala vada e abia hidi,
\q2 bona lalodia ese edia kara dika-hereadia na e moalelaidiamu.
\q1 
\v 4 Lau ese danu hisi-ani baina abia hidi, edia,
\q2 bona e gari henimu ḡaudia na latadiai baina havara;
\q1 badina be na boiboiva ai, ta se haere,
\q2 bona na herevava ai, idia na asie kamonai;
\q1 a lauegu ita-ita ai e kara dika,
\q2 bona lau ese asina moalelaia ḡauna e abia hidi.
\b
\q1 
\v 5 Iehova ena hereva ba kamonai,
\q2 umui ena hereva magigina o magigimu taumui!
\q1 Tadikakamui, e inai henimuimu
\q2 bona lau ladagu dainai e negemui daure taudia,
\q1 vada e hereva, eto “Iehova aita imodaia,
\q2 bena emui moale baia itaia”;
\q2 a idia hari bae hahemaraidia.
\b
\q1 
\v 6 A hakala, hanua badana amo heloḡo-heloḡo e daemu,
\q2 bona gado ta dubu helaḡana amo!
\q1 Ina na Iehova gadona,
\q2 ia ese ana inai taudia davadia e henidiamu.
\b
\q1 
\v 7 Do se hekamonai negana ai,
\q2 hahine na e mara;
\q1 hisihisi do se mamia negana ai,
\q2 ia ese mero ta e havaraia.
\q1 
\v 8 Daika ese ḡau unuhetomana ta vada e kamonai?
\q2 Daika ese ḡau unuhetomadia vada e ita?
\q1 Tano ta be dina tamona ai baine vara a?
\q2 Bese ta be asi vanahana ai bae havaraia?
\q1 Badina be Siona na e hekamonaiva negana ai,
\q2 maoromaoro natuna e havaradia.
\q1 
\v 9 Iehova na e tomu,
\q2 Lau ese mara baina havaraia, bena anina basina hahedinaraia a?
\q1 Emui Dirava na e tomu,
\q2 Lau, anina ihahedinaraina Diravana, ese baine hahegabani a?
\b
\q1 
\v 10 Ierusalem ida ba moale hebou, bona ia dainai ba moale danu,
\q2 umui ia o ura heniamu taumui iboumui ai;
\q1 moale ai ia ida ba moale hebou,
\q2 umui ia taina o taimu taumui iboumui ai;
\q1 
\v 11 bena ia ratana ba topo,
\q2 bona kemena ai ba doro;
\q1 ia hairaina bada-hereana amo
\q2 ba inu doroka-doroka, mai moalemui ida.
\b
\q1 
\v 12 Badina be Iehova ini e gwau tomamu:
\q2 A itaia, ena namo baina habadaia, sinavai na heto,
\q2 bona basileia idau-idau edia taḡa baina henia badabada, abata na heto;
\q1 ratana ba topoa, ia ese baine dagiramui,
\q2 bona tuina ai baine haroho-harohomui.
\q1 
\v 13 Sinana ese tauna e haloamu merona na heto,
\q2 lau ese umui taumui baina halodia;
\q2 Ierusalem dainai tauhalo ba davaria.
\q1 
\v 14 Ba itaia, bena lalomui bae moale,
\q2 bona turiamui bae tubu, rei matamata na heto;
\q1 bena taunimanima na bae diba Iehova imana na ena hesiai taudia ida,
\q2 bona ena badu na ana inai taudia latadiai.
\b
\q1 
\v 15 A itaia, Iehova na lahi ai bainema,
\q2 bona ena kariota na lai gubana na heto baema,
\q1 ena badu ihagaragarana
\q2 bona ena gwau-gwau ihahururuna totona.
\q1 
\v 16 Badina be Iehova na lahi amo baine hahemaoro,
\q2 bona ena dare amo danu, taunimanima iboudiai latadiai;
\q2 bona Iehova ese baine aladia mase taudia na bae hutuma.
\b
\p 
\v 17 Iehova na e tomu: Sibodia e hahelaḡamu bona e haheḡoevamu, uma lalodiai bae vareai totona, bena bogaragidiai e nohomu tauna ta murina amo baela, boroma hidiodia bona ḡau dika-rohorohodia bona bita baeani, taudia na bae ore bou.
\p 
\v 18 Badina be edia ḡaukara bona edia lalo-hadai na dibagu, bona basileia idau-idau bona gado idau-idau taudia iboudiai igogodia na vasimu; bena idia na baema, lau hairaigu bae itaia,
\v 19 bona toa ta idia bogaragidiai baina atoa. Bona kwabukwabudia idia edia amo do baina siaidia lao, basileia idau-idau ediai, Tarasisi bona Put bona Lud, peva-mare taudia, ediai, bona Tubal bona Iavan taudia ediai, bona kone tanodia gabu daudau ai, harigu do asie kamonai bona hairaigu do asie itaia, taudia ediai; bena idia ese lau hairaigu bae gwauraia hedinarai, basileia idau-idau bogaragidiai.
\v 20 Bena idia ese tadikakamui iboudiai, basileia idau-idau iboudiai bogaragidia amo, bae mailaidia, boubou ḡauna ai baela, Iehova ena; hosi ai bona kariota ai bona ivitoto ai bona doniki ai bona kamelo ai bae mailaidia, egu ororo helaḡana Ierusalem baema, Israel taudia ese idia flaoa boubouna na nau ḡoevaḡoevana ai Iehova ena dubu lalonai e mailaiamu na heto. Iehova na e herevamu.
\v 21 Iehova ma e tomu, Haida danu baina abidia, hahelaḡa taudia bona Levi taudia ai baina halaodia.
\b
\q1 
\v 22 Iehova na a tomu:
\q2 Badina be guba matamatana bona tanobada matamatana,
\q1 lau ese baina kara ḡaudia, na
\q2 lau vairagu ai bae mia heḡereḡerena ai,
\q1 umui garamui bona umui ladamui na
\q2 unu bae mia toma.
\q1 
\v 23 Hua matamatana ta ela bona hua matamatana ma ta,
\q2 bona dina helaḡana ta ela bona dina helaḡana ma ta,
\q1 taunimanima iboudiai na baema, lau vairagu ai bae toma diho.
\q2 Iehova na e herevamu.
\b
\p 
\v 24 Bena bae raka lasi, e daḡedaḡe henigu taudia na masedia ai bae itadia; badina be edia uloulo basine mase bona edia lahi basine bodo, bena hedadarai ḡaudia ai baela, taunimanima iboudiai ediai. 
