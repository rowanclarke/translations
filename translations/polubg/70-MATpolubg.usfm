\id MAT
\h Mateusza
\toc1 Ewangelia Mateusza
\toc2 Mateusza
\toc3 Mt
\mt1 Ewangelia Mateusza
\c 1
\m 
\v 1 Księga rodu Jezusa Chrystusa, syna Dawida, syna Abrahama.
\m 
\v 2 Abraham spłodził Izaaka, a Izaak spłodził Jakuba, a Jakub spłodził Judę i jego braci.
\m 
\v 3 A Juda spłodził z Tamar Faresa i Zarę, a Fares spłodził Ezroma, a Ezrom spłodził Arama.
\m 
\v 4 A Aram spłodził Aminadaba, a Aminadab spłodził Naasona, a Naason spłodził Salmona.
\m 
\v 5 A Salmon spłodził z Rachab Booza, a Booz spłodził z Rut Obeda, a Obed spłodził Jessego.
\m 
\v 6 A Jesse spłodził króla Dawida, a król Dawid spłodził Salomona z tej, która \add była żoną\add* Uriasza.
\m 
\v 7 A Salomon spłodził Roboama, a Roboam spłodził Abiasza, a Abiasz spłodził Azę.
\m 
\v 8 A Aza spłodził Jozafata, a Jozafat spłodził Jorama, a Joram spłodził Ozjasza.
\m 
\v 9 A Ozjasz spłodził Joatama, a Joatam spłodził Achaza, a Achaz spłodził Ezechiasza.
\m 
\v 10 A Ezechiasz spłodził Manassesa, a Manasses spłodził Amona, a Amon spłodził Jozjasza.
\m 
\v 11 A Jozjasz spłodził Jechoniasza i jego braci w czasie uprowadzenia do Babilonu.
\m 
\v 12 A po uprowadzeniu do Babilonu Jechoniasz spłodził Salatiela, a Salatiel spłodził Zorobabela.
\m 
\v 13 A Zorobabel spłodził Abiuda, a Abiud spłodził Eliakima, a Eliakim spłodził Azora.
\m 
\v 14 A Azor spłodził Sadoka, a Sadok spłodził Achima, a Achim spłodził Eliuda.
\m 
\v 15 A Eliud spłodził Eleazara, a Eleazar spłodził Matana, a Matan spłodził Jakuba.
\m 
\v 16 A Jakub spłodził Józefa, męża Marii, z której narodził się Jezus, zwany Chrystusem.
\m 
\v 17 Tak więc wszystkich pokoleń od Abrahama aż do Dawida \add jest\add* czternaście; a od Dawida aż do uprowadzenia do Babilonu – pokoleń czternaście; a od uprowadzenia do Babilonu aż do Chrystusa – pokoleń czternaście.
\m 
\v 18 A z narodzeniem Jezusa Chrystusa było tak: Gdy Maria, jego matka, została zaślubiona Józefowi, zanim się zeszli, okazało się, że jest brzemienna z Ducha Świętego.
\m 
\v 19 Ale Józef, jej mąż, będąc sprawiedliwym i nie chcąc jej zniesławić, chciał ją potajemnie oddalić.
\m 
\v 20 A gdy o tym rozmyślał, oto anioł Pana ukazał mu się we śnie i powiedział: Józefie, synu Dawida, nie bój się przyjąć Marii, twojej żony. To bowiem, co się w niej poczęło, jest z Ducha Świętego.
\m 
\v 21 I urodzi syna, któremu nadasz imię Jezus. On bowiem zbawi swój lud od jego grzechów.
\m 
\v 22 A to wszystko się stało, aby się wypełniło, co powiedział Pan przez proroka:
\m 
\v 23 Oto dziewica będzie brzemienna i urodzi syna, któremu nadadzą imię Emmanuel, co się tłumaczy: Bóg z nami.
\m 
\v 24 Wtedy Józef, obudziwszy się ze snu, uczynił tak, jak mu rozkazał anioł Pana, i przyjął swoją żonę.
\m 
\v 25 Ale nie obcował z nią, dopóki nie urodziła swego pierworodnego syna, któremu nadał imię Jezus.
\c 2
\m 
\v 1 A gdy Jezus urodził się w Betlejem w Judei za dni króla Heroda, oto mędrcy ze Wschodu przybyli do Jerozolimy i pytali:
\m 
\v 2 Gdzież jest ten król Żydów, który się urodził? Widzieliśmy bowiem jego gwiazdę na Wschodzie i przyjechaliśmy, aby oddać mu pokłon.
\m 
\v 3 Gdy król Herod to usłyszał, przeraził się, a z nim cała Jerozolima.
\m 
\v 4 Zebrawszy więc wszystkich naczelnych kapłanów i nauczycieli ludu, wypytywał ich, gdzie miał się urodzić Chrystus.
\m 
\v 5 A oni mu powiedzieli: W Betlejem w Judei; bo tak jest napisane przez proroka:
\m 
\v 6 A ty, Betlejem, ziemio Judy, wcale nie jesteś najmniejsze wśród władców Judei, z ciebie bowiem wyjdzie władca, który będzie rządził moim ludem, Izraelem.
\m 
\v 7 Wtedy Herod wezwał potajemnie mędrców i dowiadywał się dokładnie o czas ukazania się gwiazdy.
\m 
\v 8 A posyłając ich do Betlejem, powiedział: Jedźcie i wypytajcie się dokładnie o to dziecko, a gdy je znajdziecie, donieście mi, abym i ja pojechał i oddał mu pokłon.
\m 
\v 9 Oni więc, wysłuchawszy króla, odeszli. A oto gwiazda, którą widzieli na Wschodzie, prowadziła ich, aż przyszła i zatrzymała się nad \add miejscem\add*, gdzie było dziecko.
\m 
\v 10 A gdy zobaczyli gwiazdę, ogromnie się ucieszyli.
\m 
\v 11 Kiedy weszli do domu, zobaczyli dziecko z Marią, jego matką, i upadłszy, oddali mu pokłon, potem otworzyli swoje skarby i ofiarowali mu dary: złoto, kadzidło i mirrę.
\m 
\v 12 Lecz będąc ostrzeżeni przez Boga we śnie, aby nie wracali do Heroda, powrócili do swojej ziemi inną drogą.
\m 
\v 13 A gdy oni odeszli, oto anioł Pana ukazał się we śnie Józefowi i powiedział: Wstań, weź dziecko oraz jego matkę i uciekaj do Egiptu, i zostań tam, aż ci powiem. Herod bowiem będzie szukał dziecka, aby je zabić.
\m 
\v 14 Wstał więc, wziął w nocy dziecko oraz jego matkę i uciekł do Egiptu.
\m 
\v 15 I przebywał tam aż do śmierci Heroda, aby się wypełniło, co powiedział Pan przez proroka: Z Egiptu wezwałem mego syna.
\m 
\v 16 Wówczas Herod, widząc, że został oszukany przez mędrców, bardzo się rozgniewał i kazał zabić wszystkie dzieci, które były w Betlejem i całej okolicy, w wieku do dwóch lat, stosownie do czasu, o którym się dokładnie dowiedział od mędrców.
\m 
\v 17 Wtedy wypełniło się to, co zostało powiedziane przez proroka Jeremiasza:
\m 
\v 18 Słychać głos w Rama, lament, płacz i wielkie zawodzenie. Rachel opłakuje swoje dzieci i nie daje się pocieszyć, bo \add już\add* ich nie ma.
\m 
\v 19 A gdy Herod umarł, oto anioł Pana ukazał się we śnie Józefowi w Egipcie;
\m 
\v 20 I powiedział: Wstań, weź dziecko oraz jego matkę i idź do ziemi izraelskiej. Umarli bowiem ci, którzy czyhali na życie dziecka.
\m 
\v 21 Wstał więc, wziął dziecko oraz jego matkę i przybył do ziemi izraelskiej.
\m 
\v 22 Lecz gdy usłyszał, że Archelaus króluje w Judei w miejsce Heroda, swego ojca, bał się tam iść. Ale będąc napomniany przez Boga we śnie, odszedł w strony Galilei.
\m 
\v 23 A przyszedłszy, mieszkał w mieście zwanym Nazaret, aby się wypełniło to, co zostało powiedziane przez proroków: Będzie nazwany Nazarejczykiem.
\c 3
\m 
\v 1 W tych dniach przyszedł Jan Chrzciciel, głosząc na pustyni judzkiej:
\m 
\v 2 Pokutujcie, bo przybliżyło się królestwo niebieskie.
\m 
\v 3 To bowiem jest ten, o którym powiedziano przez proroka Izajasza: Głos wołającego na pustyni: Przygotujcie drogę Pana, prostujcie jego ścieżki.
\m 
\v 4 A ów Jan miał ubranie z sierści wielbłądziej i pas skórzany wokół bioder, a jego pokarmem była szarańcza i miód leśny.
\m 
\v 5 Wtedy przychodziła do niego Jerozolima oraz cała Judea i cała okolica nad Jordanem.
\m 
\v 6 I byli przez niego chrzczeni w Jordanie, wyznając swoje grzechy.
\m 
\v 7 A gdy zobaczył wielu spośród faryzeuszy i saduceuszy przychodzących do chrztu, powiedział im: Plemię żmijowe, któż was ostrzegł, żebyście uciekali przed nadchodzącym gniewem?
\m 
\v 8 Wydajcie więc owoce godne pokuty;
\m 
\v 9 A nie myślcie, że możecie sobie mówić: Naszym ojcem jest Abraham. Mówię wam bowiem, że Bóg może i z tych kamieni wzbudzić dzieci Abrahamowi.
\m 
\v 10 Już i siekiera do korzenia drzew jest przyłożona. Każde więc drzewo, które nie wydaje dobrego owocu, zostaje wycięte i wrzucone w ogień.
\m 
\v 11 Ja was chrzczę wodą ku pokucie; ten zaś, który idzie za mną, jest mocniejszy ode mnie; nie jestem godny nosić mu obuwia. On będzie was chrzcił Duchem Świętym i ogniem.
\m 
\v 12 \add Ma\add* swoje wiejadło w ręku i wyczyści swoje klepisko, i zgromadzi swoją pszenicę do spichlerza, a plewy spali w ogniu nieugaszonym.
\m 
\v 13 Wtedy Jezus przyszedł z Galilei nad Jordan do Jana, aby być przez niego ochrzczonym.
\m 
\v 14 Ale Jan powstrzymywał go, mówiąc: Ja potrzebuję być ochrzczonym przez ciebie, a ty przychodzisz do mnie?
\m 
\v 15 A Jezus mu odpowiedział: Ustąp teraz, bo godzi się nam wypełnić wszelką sprawiedliwość. Wtedy mu ustąpił.
\m 
\v 16 A gdy Jezus został ochrzczony, zaraz wyszedł z wody, a oto otworzyły mu się niebiosa i ujrzał Ducha Bożego zstępującego jak gołębica i przychodzącego na niego.
\m 
\v 17 I rozległ się głos z nieba: To jest mój umiłowany Syn, w którym mam upodobanie.
\c 4
\m 
\v 1 Wtedy Jezus został zaprowadzony przez Ducha na pustynię, aby był kuszony przez diabła.
\m 
\v 2 A po czterdziestu dniach i czterdziestu nocach postu poczuł głód.
\m 
\v 3 Wówczas przystąpił do niego kusiciel i powiedział: Jeśli jesteś Synem Bożym, powiedz, aby te kamienie stały się chlebem.
\m 
\v 4 A on odpowiedział: Jest napisane: Nie samym chlebem będzie żył człowiek, ale każdym słowem pochodzącym z ust Boga.
\m 
\v 5 Wtedy diabeł wziął go do miasta świętego i postawił na szczycie świątyni.
\m 
\v 6 I powiedział mu: Jeśli jesteś Synem Bożym, rzuć się w dół, jest bowiem napisane: Rozkaże o tobie swoim aniołom i będą cię nosić na rękach, abyś nie uderzył swojej nogi o kamień.
\m 
\v 7 Jezus mu odpowiedział: Jest też napisane: Nie będziesz wystawiał na próbę Pana, swego Boga.
\m 
\v 8 Znowu wziął go diabeł na bardzo wysoką górę i pokazał mu wszystkie królestwa świata oraz ich wspaniałość.
\m 
\v 9 I powiedział do niego: Dam ci to wszystko, jeśli upadniesz i oddasz mi pokłon.
\m 
\v 10 Wtedy Jezus powiedział mu: Idź precz, szatanie! Jest bowiem napisane: Panu, swemu Bogu, będziesz oddawał pokłon i tylko jemu będziesz służył.
\m 
\v 11 Wówczas diabeł go opuścił, a oto aniołowie przystąpili \add do niego\add* i mu służyli.
\m 
\v 12 A gdy Jezus usłyszał, że Jan został wtrącony \add do więzienia\add*, wrócił do Galilei.
\m 
\v 13 A opuściwszy Nazaret, przyszedł i zamieszkał w Kafarnaum, które leży nad morzem, w granicach Zabulona i Neftalego;
\m 
\v 14 Aby się wypełniło, co zostało powiedziane przez proroka Izajasza:
\m 
\v 15 Ziemia Zabulona i ziemia Neftalego, \add wzdłuż\add* drogi nadmorskiej, za Jordanem, Galilea pogan.
\m 
\v 16 Lud, który siedział w ciemności, ujrzał światłość wielką, a siedzącym w krainie i cieniu śmierci wzeszła światłość.
\m 
\v 17 Od tego czasu Jezus zaczął głosić i mówić: Pokutujcie, przybliżyło się bowiem królestwo niebieskie.
\m 
\v 18 A gdy Jezus przechodził nad Morzem Galilejskim, zobaczył dwóch braci: Szymona, zwanego Piotrem, i Andrzeja, jego brata, którzy zapuszczali sieć w morze; byli bowiem rybakami.
\m 
\v 19 I powiedział im: Chodźcie za mną, a uczynię was rybakami ludzi.
\m 
\v 20 Oni natychmiast porzucili sieci i poszli za nim.
\m 
\v 21 A gdy poszedł stamtąd dalej, zobaczył innych dwóch braci, Jakuba, \add syna\add* Zebedeusza, i Jana, jego brata, jak ze swoim ojcem Zebedeuszem naprawiali w łodzi swoje sieci. I wezwał ich.
\m 
\v 22 A oni natychmiast opuścili łódź i swego ojca i poszli za nim.
\m 
\v 23 I obchodził Jezus całą Galileę, nauczając w ich synagogach, głosząc ewangelię królestwa i uzdrawiając wszystkie choroby i wszelkie dolegliwości wśród ludzi.
\m 
\v 24 A wieść o nim rozeszła się po całej Syrii. I przyprowadzano do niego wszystkich, którzy się źle czuli, którzy byli nękani różnymi chorobami i cierpieniami, a także opętanych, obłąkanych i sparaliżowanych, a on ich uzdrawiał.
\m 
\v 25 A szło za nim mnóstwo ludzi z Galilei i Dekapolu, Jerozolimy, Judei i Zajordania.
\c 5
\m 
\v 1 A \add Jezus\add*, widząc tłumy, wszedł na górę, a gdy usiadł, podeszli do niego jego uczniowie.
\m 
\v 2 Wtedy otworzył usta i nauczał ich:
\m 
\v 3 Błogosławieni ubodzy w duchu, ponieważ do nich należy królestwo niebieskie.
\m 
\v 4 Błogosławieni, którzy się smucą, ponieważ oni będą pocieszeni.
\m 
\v 5 Błogosławieni cisi, ponieważ oni odziedziczą ziemię.
\m 
\v 6 Błogosławieni, którzy łakną i pragną sprawiedliwości, ponieważ oni będą nasyceni.
\m 
\v 7 Błogosławieni miłosierni, ponieważ oni dostąpią miłosierdzia.
\m 
\v 8 Błogosławieni czystego serca, ponieważ oni zobaczą Boga.
\m 
\v 9 Błogosławieni czyniący pokój, ponieważ oni będą nazwani synami Bożymi.
\m 
\v 10 Błogosławieni, którzy cierpią prześladowanie z powodu sprawiedliwości, ponieważ do nich należy królestwo niebieskie.
\m 
\v 11 Błogosławieni jesteście, gdy z mego powodu będą wam złorzeczyć, prześladować was i mówić kłamliwie wszystko, co złe, przeciwko wam.
\m 
\v 12 Radujcie się i weselcie, ponieważ obfita jest wasza nagroda w niebie; tak bowiem prześladowali proroków, którzy \add byli\add* przed wami.
\m 
\v 13 Wy jesteście solą ziemi; lecz jeśli sól zwietrzeje, czym \add ją\add* posolą? Na nic się już nie przyda, tylko na wyrzucenie i podeptanie przez ludzi.
\m 
\v 14 Wy jesteście światłością świata. Nie może się ukryć miasto położone na górze.
\m 
\v 15 Nie zapala się świecy i nie stawia jej pod naczyniem, ale na świeczniku, i świeci wszystkim, którzy \add są\add* w domu.
\m 
\v 16 Tak niech wasza światłość świeci przed ludźmi, aby widzieli wasze dobre uczynki i chwalili waszego Ojca, który jest w niebie.
\m 
\v 17 Nie sądźcie, że przyszedłem znieść Prawo albo Proroków. Nie przyszedłem znieść, ale wypełnić.
\m 
\v 18 Zaprawdę bowiem powiadam wam: Dopóki niebo i ziemia nie przeminą, ani jedna jota, ani jedna kreska nie przeminie z prawa, aż wszystko się wypełni.
\m 
\v 19 Kto by więc złamał jedno z tych najmniejszych przykazań i uczyłby tak ludzi, będzie nazwany najmniejszym w królestwie niebieskim. A kto by \add je\add* wypełniał i uczył, ten będzie nazwany wielkim w królestwie niebieskim.
\m 
\v 20 Mówię wam bowiem: Jeśli wasza sprawiedliwość nie będzie obfitsza niż uczonych w Piśmie i faryzeuszy, żadnym sposobem nie wejdziecie do królestwa niebieskiego.
\m 
\v 21 Słyszeliście, że powiedziano przodkom: Nie będziesz zabijał, a kto by zabił, podlega sądowi.
\m 
\v 22 Lecz ja wam mówię: Każdy, kto się gniewa na swego brata bez przyczyny, podlega sądowi, a kto powie swemu bratu: Raka, podlega Radzie, a kto powie: Głupcze, podlega \add karze\add* ognia piekielnego.
\m 
\v 23 Jeśli więc przyniesiesz swój dar na ołtarz i tam przypomnisz sobie, że twój brat ma coś przeciwko tobie;
\m 
\v 24 Zostaw swój dar tam przed ołtarzem, idź i najpierw pojednaj się ze swoim bratem, a potem przyjdź i ofiaruj swój dar.
\m 
\v 25 Pogódź się ze swoim przeciwnikiem szybko, dopóki jesteś z nim w drodze, aby przeciwnik nie wydał cię sędziemu, a sędzia strażnikowi, i aby nie wtrącono cię do więzienia.
\m 
\v 26 Zaprawdę powiadam ci: Nie wyjdziesz stamtąd, dopóki nie oddasz ostatniego grosza.
\m 
\v 27 Słyszeliście, że powiedziano przodkom: Nie będziesz cudzołożył.
\m 
\v 28 Lecz ja wam mówię: Każdy, kto patrzy na kobietę, aby jej pożądać, już popełnił z nią cudzołóstwo w swoim sercu.
\m 
\v 29 Jeśli więc twoje prawe oko jest ci powodem upadku, wyłup je i odrzuć od siebie. Pożyteczniej bowiem jest dla ciebie, aby zginął jeden z twoich członków, niż żeby całe twoje ciało było wrzucone do ognia piekielnego.
\m 
\v 30 A jeśli twoja prawa ręka jest ci powodem upadku, odetnij ją i odrzuć od siebie. Pożyteczniej bowiem jest dla ciebie, aby zginął jeden z twoich członków, niż żeby całe twoje ciało było wrzucone do ognia piekielnego.
\m 
\v 31 Powiedziano też: Kto oddala swoją żonę, niech jej da list rozwodowy.
\m 
\v 32 Lecz ja wam mówię: Kto oddala swoją żonę – poza przypadkiem nierządu – prowadzi ją do cudzołóstwa, a kto żeni się z oddaloną, cudzołoży.
\m 
\v 33 Słyszeliście też, że powiedziano przodkom: Nie będziesz fałszywie przysięgał, ale dotrzymasz Panu swych przysiąg.
\m 
\v 34 Lecz ja wam mówię: Wcale nie przysięgajcie – ani na niebo, gdyż jest tronem Boga;
\m 
\v 35 Ani na ziemię, gdyż jest podnóżkiem jego stóp, ani na Jerozolimę, gdyż jest miastem wielkiego króla.
\m 
\v 36 Ani na swoją głowę nie będziesz przysięgał, gdyż nie możesz jednego włosa uczynić białym albo czarnym.
\m 
\v 37 Ale wasza mowa niech będzie: Tak – tak, nie – nie. A co jest ponadto, pochodzi od złego.
\m 
\v 38 Słyszeliście, że powiedziano: Oko za oko i ząb za ząb.
\m 
\v 39 Lecz ja wam mówię: Nie sprzeciwiajcie się złemu, ale jeśli ktoś uderzy cię w prawy policzek, nadstaw mu i drugi.
\m 
\v 40 Temu, kto chce się z tobą procesować i wziąć twoją szatę, zostaw i płaszcz.
\m 
\v 41 A jeśli ktoś cię przymusza, żebyś \add szedł\add* z nim jedną milę, idź z nim \add i\add* dwie.
\m 
\v 42 Temu, kto cię prosi, daj, a od tego, kto chce od ciebie pożyczyć, nie odwracaj się.
\m 
\v 43 Słyszeliście, że powiedziano: Będziesz miłował swego bliźniego, a swego nieprzyjaciela będziesz nienawidził.
\m 
\v 44 Lecz ja wam mówię: Miłujcie waszych nieprzyjaciół, błogosławcie tym, którzy was przeklinają, dobrze czyńcie tym, którzy was nienawidzą i módlcie się za tych, którzy wam wyrządzają zło i prześladują was;
\m 
\v 45 Abyście byli synami waszego Ojca, który \add jest\add* w niebie. On bowiem sprawia, że jego słońce wschodzi nad złymi i nad dobrymi i deszcz zsyła na sprawiedliwych i niesprawiedliwych.
\m 
\v 46 Jeśli bowiem miłujecie tych, którzy was miłują, jakąż macie nagrodę? Czyż i celnicy tego nie czynią?
\m 
\v 47 A jeśli tylko waszych braci pozdrawiacie, cóż szczególnego czynicie? Czyż i celnicy tak nie czynią?
\m 
\v 48 Bądźcie więc doskonali, tak jak doskonały jest wasz Ojciec, który jest w niebie.
\c 6
\m 
\v 1 Pilnujcie się, abyście waszej jałmużny nie dawali przed ludźmi \add po to\add*, aby was widzieli, inaczej nie będziecie mieli nagrody u waszego Ojca, który jest w niebie.
\m 
\v 2 Dlatego, gdy dajesz jałmużnę, nie trąb przed sobą, jak to robią obłudnicy w synagogach i na ulicach, aby ich ludzie chwalili. Zaprawdę powiadam wam: Odbierają swoją nagrodę.
\m 
\v 3 Ale ty, gdy dajesz jałmużnę, niech nie wie twoja lewa ręka, co czyni prawa;
\m 
\v 4 Aby twoja jałmużna pozostała w ukryciu, a twój Ojciec, który widzi w ukryciu, odda ci jawnie.
\m 
\v 5 A gdy się modlisz, nie bądź jak obłudnicy. Oni bowiem chętnie modlą się, stojąc w synagogach i na rogach ulic, aby ludzie ich widzieli. Zaprawdę powiadam wam: Odbierają swoją nagrodę.
\m 
\v 6 Ale ty, gdy się modlisz, wejdź do swego pokoju, zamknij drzwi i módl się do twego Ojca, który jest w ukryciu, a twój Ojciec, który widzi w ukryciu, odda ci jawnie.
\m 
\v 7 A modląc się, nie bądźcie wielomówni jak poganie; oni bowiem sądzą, że ze względu na swoją wielomówność będą wysłuchani.
\m 
\v 8 Nie bądźcie do nich podobni, gdyż wasz Ojciec wie, czego potrzebujecie, zanim go poprosicie.
\m 
\v 9 Wy więc tak się módlcie: Ojcze nasz, który jesteś w niebie, niech będzie uświęcone twoje imię.
\m 
\v 10 Niech przyjdzie twoje królestwo, niech się dzieje twoja wola na ziemi, tak jak w niebie.
\m 
\v 11 Daj nam dzisiaj naszego powszedniego chleba.
\m 
\v 12 I przebacz nam nasze winy, jak i my przebaczamy tym, którzy przeciw nam zawinili.
\m 
\v 13 I nie wystawiaj nas na pokusę, ale wybaw nas od złego; twoje bowiem jest królestwo, moc i chwała na wieki. Amen.
\m 
\v 14 Bo jeśli przebaczycie ludziom ich przewinienia, i wam przebaczy wasz Ojciec niebieski.
\m 
\v 15 Lecz jeśli nie przebaczycie ludziom ich przewinień, to i wasz Ojciec nie przebaczy wam waszych przewinień.
\m 
\v 16 A gdy pościcie, nie miejcie twarzy smutnej jak obłudnicy; szpecą bowiem swoje twarze, aby ludzie widzieli, że poszczą. Zaprawdę powiadam wam: Odbierają swoją nagrodę.
\m 
\v 17 Ale ty, gdy pościsz, namaść sobie głowę i umyj twarz;
\m 
\v 18 Aby nie ludzie widzieli, że pościsz, lecz twój Ojciec, który jest w ukryciu; a twój Ojciec, który widzi w ukryciu, odda ci jawnie.
\m 
\v 19 Nie gromadźcie sobie skarbów na ziemi, gdzie mól i rdza niszczą i gdzie złodzieje włamują się i kradną;
\m 
\v 20 Ale gromadźcie sobie skarby w niebie, gdzie ani mól, ani rdza nie niszczą i gdzie złodzieje nie włamują się i nie kradną.
\m 
\v 21 Gdzie bowiem jest wasz skarb, tam będzie i wasze serce.
\m 
\v 22 Światłem ciała jest oko. Jeśli więc twoje oko jest szczere, całe twoje ciało będzie pełne światła.
\m 
\v 23 Jeśli zaś twoje oko jest złe, całe twoje ciało będzie pełne ciemności. Jeśli więc światło, które jest w tobie, jest ciemnością, \add sama\add* ciemność jakaż \add będzie\add*?
\m 
\v 24 Nikt nie może dwom panom służyć, gdyż albo jednego będzie nienawidził, a drugiego będzie miłował, albo jednego będzie się trzymał, a drugim pogardzi. Nie możecie służyć Bogu i mamonie.
\m 
\v 25 Dlatego mówię wam: Nie troszczcie się o wasze życie, co będziecie jeść albo co będziecie pić, ani o wasze ciało, w co będziecie się ubierać. Czyż życie nie jest czymś więcej niż pokarm, a ciało niż ubranie?
\m 
\v 26 Spójrzcie na ptaki nieba, że nie sieją ani nie żną, ani nie zbierają do spichlerzy, a jednak wasz Ojciec niebieski żywi je. Czy wy nie jesteście o wiele cenniejsi niż one?
\m 
\v 27 I któż z was, martwiąc się, może dodać do swego wzrostu jeden łokieć?
\m 
\v 28 A o ubranie dlaczego się troszczycie? Przypatrzcie się liliom polnym, jak rosną; nie pracują ani nie przędą.
\m 
\v 29 A mówię wam, że nawet Salomon w całej swojej chwale nie był \add tak\add* ubrany, jak jedna z nich.
\m 
\v 30 Jeśli więc trawę polną, która dziś jest, a jutro zostanie wrzucona do pieca, Bóg tak ubiera, czyż nie tym bardziej was, ludzie małej wiary?
\m 
\v 31 Nie troszczcie się więc, mówiąc: Cóż będziemy jeść? albo: Co będziemy pić? albo: W co się ubierzemy?
\m 
\v 32 Bo o to wszystko poganie zabiegają. Wie bowiem wasz Ojciec niebieski, że tego wszystkiego potrzebujecie.
\m 
\v 33 Ale szukajcie najpierw królestwa Bożego i jego sprawiedliwości, a to wszystko będzie wam dodane.
\m 
\v 34 Dlatego nie troszczcie się o dzień jutrzejszy, gdyż dzień jutrzejszy sam się zatroszczy o swoje \add potrzeby\add*. Dosyć ma dzień swego utrapienia.
\c 7
\m 
\v 1 Nie sądźcie, abyście nie byli sądzeni.
\m 
\v 2 Jakim bowiem sądem sądzicie, takim będziecie sądzeni, i jaką miarą mierzycie, taką będzie wam odmierzone.
\m 
\v 3 A czemu widzisz źdźbło w oku swego brata, a na belkę, która jest w twoim oku, nie zwracasz uwagi?
\m 
\v 4 Albo jak możesz mówić swemu bratu: Pozwól, że wyjmę źdźbło z twego oka, gdy belka jest w twoim oku?
\m 
\v 5 Obłudniku, wyjmij najpierw belkę ze swego oka, a wtedy przejrzysz, aby wyjąć źdźbło z oka twego brata.
\m 
\v 6 Nie dawajcie psom tego, co święte, i nie rzucajcie swoich pereł przed świnie, by ich nie podeptały swymi nogami i odwróciwszy się, nie rozszarpały was.
\m 
\v 7 Proście, a będzie wam dane, szukajcie, a znajdziecie, pukajcie, a będzie wam otworzone.
\m 
\v 8 Każdy bowiem, kto prosi, otrzymuje, kto szuka, znajduje, a temu, kto puka, będzie otworzone.
\m 
\v 9 I czy jest wśród was człowiek, który da synowi kamień, gdy ten prosi o chleb?
\m 
\v 10 A gdy prosi o rybę, czy da mu węża?
\m 
\v 11 Jeśli więc wy, będąc złymi, umiecie dawać dobre dary waszym dzieciom, o ileż bardziej wasz Ojciec, który jest w niebie, da dobre rzeczy tym, którzy go proszą.
\m 
\v 12 Wszystko więc, co chcecie, aby wam ludzie czynili, i wy im czyńcie. To bowiem jest Prawo i Prorocy.
\m 
\v 13 Wchodźcie przez ciasną bramę. Szeroka bowiem jest brama i przestronna droga, która prowadzi na zatracenie, a wielu jest takich, którzy przez nią wchodzą.
\m 
\v 14 Ciasna bowiem jest brama i wąska droga, która prowadzi do życia, a mało jest takich, którzy ją znajdują.
\m 
\v 15 Strzeżcie się fałszywych proroków, którzy przychodzą do was w owczej skórze, ale wewnątrz są drapieżnymi wilkami.
\m 
\v 16 Po ich owocach poznacie ich. Czy zbierają winogrona z cierni albo z ostu figi?
\m 
\v 17 Tak każde dobre drzewo wydaje dobre owoce, ale złe drzewo wydaje złe owoce.
\m 
\v 18 Nie może dobre drzewo wydawać złych owoców ani złe drzewo wydawać dobrych owoców.
\m 
\v 19 Każde drzewo, które nie wydaje dobrego owocu, zostaje wycięte i wrzucone w ogień.
\m 
\v 20 Tak więc po ich owocach poznacie ich.
\m 
\v 21 Nie każdy, kto mi mówi: Panie, Panie, wejdzie do królestwa niebieskiego, lecz ten, kto wypełnia wolę mojego Ojca, który jest w niebie.
\m 
\v 22 Wielu powie mi tego dnia: Panie, Panie, czyż nie prorokowaliśmy w twoim imieniu i w twoim imieniu nie wypędzaliśmy demonów, i w twoim imieniu nie czyniliśmy wielu cudów?
\m 
\v 23 A wtedy im oświadczę: Nigdy was nie znałem. Odstąpcie ode mnie wy, którzy czynicie nieprawość.
\m 
\v 24 Każdego więc, kto słucha tych moich słów i wypełnia je, przyrównam do człowieka mądrego, który zbudował swój dom na skale.
\m 
\v 25 I spadł deszcz, przyszła powódź, zerwały się wichry i uderzyły w ten dom, ale się nie zawalił, bo był założony na skale.
\m 
\v 26 A każdy, kto słucha tych moich słów, a nie wypełnia ich, będzie przyrównany do człowieka głupiego, który zbudował swój dom na piasku.
\m 
\v 27 I spadł deszcz, przyszła powódź, zerwały się wichry i uderzyły w ten dom, i zawalił się, a jego upadek był wielki.
\m 
\v 28 A gdy Jezus dokończył tych słów, ludzie zdumiewali się jego nauką.
\m 
\v 29 Uczył ich bowiem jak ten, który ma moc, a nie jak uczeni w Piśmie.
\c 8
\m 
\v 1 A gdy zszedł z góry, poszło za nim mnóstwo ludzi.
\m 
\v 2 A oto trędowaty podszedł i oddał mu pokłon, mówiąc: Panie, jeśli chcesz, możesz mnie oczyścić.
\m 
\v 3 Jezus wyciągnął rękę i dotknął go, mówiąc: Chcę, bądź oczyszczony. I natychmiast został oczyszczony z trądu.
\m 
\v 4 Wtedy Jezus powiedział do niego: Uważaj, abyś nikomu nie mówił, ale idź, pokaż się kapłanowi i ofiaruj dar, który nakazał Mojżesz, na świadectwo \add dla\add* nich.
\m 
\v 5 A gdy Jezus wszedł do Kafarnaum, przyszedł do niego setnik i prosił go:
\m 
\v 6 Panie, mój sługa leży w domu sparaliżowany i bardzo cierpi.
\m 
\v 7 I powiedział mu Jezus: Przyjdę i uzdrowię go.
\m 
\v 8 Lecz setnik odpowiedział: Panie, nie jestem godny, abyś wszedł pod mój dach, ale powiedz tylko słowo, a mój sługa będzie uzdrowiony.
\m 
\v 9 Bo i ja jestem człowiekiem podległym władzy i mam pod sobą żołnierzy. Mówię jednemu: Idź, a idzie; a drugiemu: Chodź tu, a przychodzi; a memu słudze: Zrób to, a robi.
\m 
\v 10 A gdy Jezus to usłyszał, zdziwił się i powiedział do tych, którzy szli za nim: Zaprawdę powiadam wam: Nawet w Izraelu nie znalazłem tak wielkiej wiary.
\m 
\v 11 A mówię wam: Wielu przyjdzie ze wschodu i z zachodu i zasiądą za stołem z Abrahamem, Izaakiem i Jakubem w królestwie niebieskim.
\m 
\v 12 Lecz synowie królestwa będą wyrzuceni do ciemności zewnętrznych. Tam będzie płacz i zgrzytanie zębów.
\m 
\v 13 I powiedział Jezus setnikowi: Idź, a jak uwierzyłeś, tak niech ci się stanie. I o tej godzinie jego sługa został uzdrowiony.
\m 
\v 14 A gdy Jezus przyszedł do domu Piotra, zobaczył jego teściową, która leżała w gorączce.
\m 
\v 15 Dotknął więc jej ręki i opuściła ją gorączka. Ona zaś wstała i usługiwała im.
\m 
\v 16 Kiedy nastał wieczór, przyprowadzono do niego wielu opętanych. A on wypędził duchy słowem i uzdrowił wszystkich chorych;
\m 
\v 17 Aby się wypełniło, co zostało powiedziane przez proroka Izajasza: On nasze słabości wziął \add na siebie\add* i nosił nasze choroby.
\m 
\v 18 A Jezus, widząc wokół siebie mnóstwo ludzi, kazał przeprawić się na drugi brzeg.
\m 
\v 19 Wtedy podszedł pewien uczony w Piśmie i powiedział do niego: Mistrzu, pójdę za tobą, dokądkolwiek pójdziesz.
\m 
\v 20 I powiedział mu Jezus: Lisy mają nory, a ptaki niebieskie – gniazda, ale Syn Człowieczy nie ma gdzie położyć głowy.
\m 
\v 21 A inny spośród jego uczniów powiedział do niego: Panie, pozwól mi najpierw pójść i pogrzebać mego ojca.
\m 
\v 22 Ale Jezus mu odpowiedział: Pójdź za mną, a umarli niech grzebią swoich umarłych.
\m 
\v 23 Gdy wsiadł do łodzi, weszli za nim i jego uczniowie.
\m 
\v 24 A oto zerwała się na morzu wielka burza, tak że fale zalewały łódź. On zaś spał.
\m 
\v 25 A jego uczniowie, podszedłszy, obudzili go, mówiąc: Panie, ratuj nas! Giniemy!
\m 
\v 26 I powiedział do nich: Czemu się boicie, ludzie małej wiary? Potem wstał, zgromił wichry i morze i nastała wielka cisza.
\m 
\v 27 A ludzie dziwili się i mówili: Cóż to za człowiek, że nawet wichry i morze są mu posłuszne?
\m 
\v 28 Kiedy przeprawił się na drugą stronę do krainy Gerazeńczyków, zabiegli mu \add drogę\add* dwaj opętani, którzy wyszli z grobowców, tak bardzo groźni, że nikt nie mógł przechodzić tą drogą.
\m 
\v 29 I zaczęli krzyczeć: Cóż my mamy z tobą, Jezusie, Synu Boży? Przyszedłeś tu przed czasem dręczyć nas?
\m 
\v 30 Z dala od nich pasło się wielkie stado świń.
\m 
\v 31 Demony więc prosiły go: Jeśli nas wypędzasz, pozwól nam wejść w to stado świń.
\m 
\v 32 I powiedział im: Idźcie. A one, wyszedłszy, weszły w to stado świń. Naraz całe stado ruszyło pędem po urwisku do morza i zginęło w wodach.
\m 
\v 33 A pasterze uciekli i poszedłszy do miasta, opowiedzieli wszystko, także to, \add co się stało\add* z opętanymi.
\m 
\v 34 Wówczas całe miasto wyszło Jezusowi na spotkanie, a ujrzawszy go, prosili, aby odszedł z ich granic.
\c 9
\m 
\v 1 Wtedy wsiadł do łodzi, przeprawił się \add na drugi brzeg\add* i przybył do swego miasta.
\m 
\v 2 A oto przynieśli mu sparaliżowanego, leżącego na posłaniu. Jezus, widząc ich wiarę, powiedział do sparaliżowanego: Ufaj, synu! Twoje grzechy są ci przebaczone.
\m 
\v 3 A niektórzy z uczonych w Piśmie pomyśleli sobie: On bluźni.
\m 
\v 4 Lecz Jezus, znając ich myśli, powiedział: Dlaczego myślicie złe rzeczy w swoich sercach?
\m 
\v 5 Cóż bowiem jest łatwiej powiedzieć: Przebaczone są twoje grzechy, czy powiedzieć: Wstań i chodź?
\m 
\v 6 Ale abyście wiedzieli, że Syn Człowieczy ma na ziemi moc przebaczać grzechy – wtedy powiedział do sparaliżowanego: Wstań, weź swoje posłanie i idź do domu.
\m 
\v 7 A on wstał i poszedł do swego domu.
\m 
\v 8 Kiedy tłumy to ujrzały, dziwiły się i chwaliły Boga, który dał ludziom taką moc.
\m 
\v 9 A odchodząc stamtąd, Jezus zobaczył człowieka zwanego Mateuszem, siedzącego w punkcie celnym. I powiedział do niego: Pójdź za mną. A on wstał i poszedł za nim.
\m 
\v 10 Gdy Jezus siedział za stołem w \add jego\add* domu, przyszło wielu celników i grzeszników i usiedli z Jezusem oraz jego uczniami.
\m 
\v 11 Widząc to, faryzeusze zapytali jego uczniów: Dlaczego wasz nauczyciel je z celnikami i grzesznikami?
\m 
\v 12 A gdy Jezus \add to\add* usłyszał, powiedział im: Nie zdrowi, lecz chorzy potrzebują lekarza.
\m 
\v 13 Idźcie więc i nauczcie się, co \add to\add* znaczy: Miłosierdzia chcę, a nie ofiary. Bo nie przyszedłem wzywać do pokuty sprawiedliwych, ale grzeszników.
\m 
\v 14 Wtedy przyszli do niego uczniowie Jana i zapytali: Dlaczego my i faryzeusze często pościmy, a twoi uczniowie nie poszczą?
\m 
\v 15 I powiedział im Jezus: Czy przyjaciele oblubieńca mogą się smucić, dopóki jest z nimi oblubieniec? Ale przyjdą dni, gdy oblubieniec zostanie od nich zabrany, i wtedy będą pościć.
\m 
\v 16 Nikt nie przyszywa łaty z nowego sukna do starej szaty, bo taka łata ściąga nieco szatę i rozdarcie staje się gorsze.
\m 
\v 17 Ani nie wlewa się młodego wina do starych bukłaków, bo inaczej bukłaki pękają, a wino wycieka i bukłaki się psują. Ale młode wino wlewa się do nowych bukłaków, a wtedy zachowuje się jedno i drugie.
\m 
\v 18 Gdy to do nich mówił, pewien przełożony synagogi przyszedł, oddał mu pokłon i powiedział: Moja córka dopiero co umarła, ale przyjdź i połóż na nią rękę, a ożyje.
\m 
\v 19 Wtedy Jezus wstał i wraz ze swoimi uczniami poszedł za nim.
\m 
\v 20 I oto kobieta, która od dwunastu lat cierpiała na krwotok, podeszła z tyłu i dotknęła brzegu jego szaty.
\m 
\v 21 Mówiła bowiem sobie: Jeśli tylko dotknę jego szaty, będę uzdrowiona.
\m 
\v 22 Ale Jezus odwrócił się i ujrzawszy ją, powiedział: Ufaj, córko! Twoja wiara cię uzdrowiła. I od tej chwili kobieta była zdrowa.
\m 
\v 23 A gdy Jezus przyszedł do domu przełożonego i zobaczył flecistów i ludzi czyniących zgiełk;
\m 
\v 24 Powiedział im: Odejdźcie, bo dziewczynka nie umarła, tylko śpi. I naśmiewali się z niego.
\m 
\v 25 Ale gdy wygnano tych ludzi, wszedł, ujął ją za rękę i dziewczynka wstała.
\m 
\v 26 I wieść o tym rozeszła się po całej \add tamtejszej\add* ziemi.
\m 
\v 27 A gdy Jezus odchodził stamtąd, szli za nim dwaj ślepi i wołali: Synu Dawida, zmiłuj się nad nami!
\m 
\v 28 Gdy zaś wszedł do domu, przyszli do niego ślepi. I zapytał ich Jezus: Wierzycie, że mogę to uczynić? Odpowiedzieli mu: Tak, Panie.
\m 
\v 29 Wtedy dotknął ich oczu i powiedział: Według waszej wiary niech się wam stanie.
\m 
\v 30 I otworzyły się ich oczy, a Jezus przykazał im surowo: Uważajcie, aby nikt się \add o tym\add* nie dowiedział.
\m 
\v 31 Lecz oni, wyszedłszy, rozsławili go po całej tamtejszej ziemi.
\m 
\v 32 A gdy wychodzili, przyprowadzono do niego niemowę opętanego przez demona.
\m 
\v 33 Kiedy demon został wypędzony, niemy przemówił. A tłumy dziwiły się i mówiły: Nigdy czegoś takiego nie widziano w Izraelu.
\m 
\v 34 Lecz faryzeusze mówili: Przez władcę demonów wypędza demony.
\m 
\v 35 I obchodził Jezus wszystkie miasta i wioski, nauczając w ich synagogach i głosząc ewangelię królestwa, uzdrawiając wszystkie choroby i wszelkie słabości wśród ludzi.
\m 
\v 36 A widząc \add tłumy\add* ludzi, użalił się nad nimi, bo byli utrudzeni i rozproszeni jak owce niemające pasterza.
\m 
\v 37 Wtedy powiedział do swoich uczniów: Żniwo wprawdzie wielkie, ale robotników mało.
\m 
\v 38 Proście więc Pana żniwa, aby wysłał robotników na swoje żniwo.
\c 10
\m 
\v 1 A przywoławszy swoich dwunastu uczniów, dał im moc nad duchami nieczystymi, aby je wypędzali i \add aby\add* uzdrawiali wszystkie choroby i wszelkie słabości.
\m 
\v 2 A takie są imiona dwunastu apostołów: pierwszy Szymon, zwany Piotrem, i jego brat Andrzej, Jakub, \add syn\add* Zebedeusza, i Jan, jego brat;
\m 
\v 3 Filip i Bartłomiej, Tomasz i celnik Mateusz, Jakub, syn Alfeusza, i Lebeusz, nazwany Tadeuszem;
\m 
\v 4 Szymon Kananejczyk i Judasz Iskariota, ten, który go zdradził.
\m 
\v 5 Tych dwunastu posłał Jezus i nakazał im: Nie wchodźcie na drogę pogan i nie wstępujcie do \add żadnego\add* miasta Samarytan.
\m 
\v 6 Idźcie raczej do owiec zaginionych z domu Izraela.
\m 
\v 7 A idąc, głoście: Przybliżyło się królestwo niebieskie.
\m 
\v 8 Uzdrawiajcie chorych, oczyszczajcie trędowatych, wskrzeszajcie umarłych, wypędzajcie demony. Darmo otrzymaliście, darmo dawajcie.
\m 
\v 9 Nie bierzcie ze sobą do trzosa złota ani srebra, ani miedzi;
\m 
\v 10 Ani torby na drogę, ani dwóch ubrań, ani obuwia, ani laski. Godny jest bowiem pracownik swego wyżywienia.
\m 
\v 11 A gdy wejdziecie do jakiegoś miasta albo wioski, dowiedzcie się, kto w nim jest godny i tam mieszkajcie, dopóki nie odejdziecie.
\m 
\v 12 A wchodząc do domu, pozdrówcie go.
\m 
\v 13 Jeśli ten dom jest tego godny, niech zstąpi na niego wasz pokój, a jeśli nie jest godny, niech wasz pokój powróci do was.
\m 
\v 14 A jeśli ktoś was nie przyjmie i nie usłucha waszych słów, wychodząc z tego domu albo miasta, strząśnijcie pył z waszych nóg.
\m 
\v 15 Zaprawdę powiadam wam: Lżej będzie ziemi sodomskiej i gomorskiej w dzień sądu niż temu miastu.
\m 
\v 16 Oto ja was posyłam jak owce między wilki. Bądźcie więc roztropni jak węże i niewinni jak gołębice.
\m 
\v 17 I strzeżcie się ludzi. Będą was bowiem wydawać radom i będą was biczować w swoich synagogach.
\m 
\v 18 Także przed namiestników i przed królów będą was prowadzić z mego powodu, na świadectwo \add przeciwko\add* nim i poganom.
\m 
\v 19 Ale gdy was wydadzą, nie martwcie się, jak i co macie mówić. Będzie wam bowiem dane w tej godzinie, co macie mówić.
\m 
\v 20 Bo nie wy mówicie, ale Duch waszego Ojca mówi w was.
\m 
\v 21 I wyda na śmierć brat brata, a ojciec syna. Dzieci powstaną przeciwko rodzicom i spowodują ich śmierć.
\m 
\v 22 I będziecie znienawidzeni przez wszystkich z powodu mego imienia. Lecz kto wytrwa do końca, będzie zbawiony.
\m 
\v 23 A gdy będą was prześladować w tym mieście, uciekajcie do innego. Zaprawdę powiadam wam, że nie obejdziecie miast Izraela, aż przyjdzie Syn Człowieczy.
\m 
\v 24 Uczeń nie przewyższa mistrza ani sługa swego pana.
\m 
\v 25 Wystarczy uczniowi, że będzie jak jego mistrz, a sługa jak jego pan. Jeśli gospodarza nazywali Belzebubem, o ile bardziej \add będą\add* tak \add nazywać\add* jego domowników.
\m 
\v 26 Dlatego nie bójcie się ich. Nie ma bowiem nic ukrytego, co by nie miało być ujawnione, ani nic tajemnego, o czym by się nie miano dowiedzieć.
\m 
\v 27 Co mówię wam w ciemności, opowiadajcie w świetle, a co słyszycie na ucho, rozgłaszajcie na dachach.
\m 
\v 28 Nie bójcie się tych, którzy zabijają ciało, lecz nie mogą zabić duszy. Bójcie się raczej tego, który może i duszę, i ciało zatracić w piekielnym ogniu.
\m 
\v 29 Czy nie sprzedają dwóch wróbli za pieniążek? A \add jednak\add* żaden z nich nie spadnie na ziemię bez \add woli\add* waszego Ojca.
\m 
\v 30 Nawet wszystkie włosy na waszej głowie są policzone.
\m 
\v 31 Nie bójcie się więc, jesteście cenniejsi niż wiele wróbli.
\m 
\v 32 Każdego więc, kto mnie wyzna przed ludźmi, i ja wyznam przed moim Ojcem, który jest w niebie.
\m 
\v 33 A tego, kto się mnie wyprze przed ludźmi, i ja się wyprę przed moim Ojcem, który jest w niebie.
\m 
\v 34 Nie sądźcie, że przyszedłem przynieść pokój na ziemię. Nie przyszedłem przynieść pokoju, ale miecz.
\m 
\v 35 Bo przyszedłem poróżnić syna z jego ojcem i córkę z jej matką, a synową z teściową.
\m 
\v 36 I nieprzyjaciółmi człowieka \add będą\add* jego domownicy.
\m 
\v 37 Kto miłuje ojca albo matkę bardziej niż mnie, nie jest mnie godny. I kto miłuje syna albo córkę bardziej niż mnie, nie jest mnie godny.
\m 
\v 38 Kto nie bierze swego krzyża i nie idzie za mną, nie jest mnie godny.
\m 
\v 39 Kto znajdzie swoje życie, straci je, a kto straci swoje życie z mego powodu, znajdzie je.
\m 
\v 40 Kto was przyjmuje, mnie przyjmuje, a kto mnie przyjmuje, przyjmuje tego, który mnie posłał.
\m 
\v 41 Kto przyjmuje proroka w imię proroka, otrzyma nagrodę proroka. Kto przyjmuje sprawiedliwego w imię sprawiedliwego, otrzyma nagrodę sprawiedliwego.
\m 
\v 42 A kto poda jednemu z tych małych choćby kubek zimnej \add wody\add* w imię ucznia, zaprawdę powiadam wam, nie straci swojej nagrody.
\c 11
\m 
\v 1 Kiedy Jezus skończył rozkazywać swoim dwunastu uczniom, odszedł stamtąd, aby nauczać i głosić w ich miastach.
\m 
\v 2 A gdy Jan usłyszał w więzieniu o czynach Chrystusa, posłał dwóch ze swoich uczniów;
\m 
\v 3 Z pytaniem: Czy ty jesteś tym, który ma przyjść, czy mamy oczekiwać innego?
\m 
\v 4 A Jezus odpowiedział im: Idźcie i oznajmijcie Janowi, co słyszycie i widzicie.
\m 
\v 5 Ślepi widzą, chromi chodzą, trędowaci zostają oczyszczeni, głusi słyszą, umarli zmartwychwstają, a ubogim opowiadana jest ewangelia.
\m 
\v 6 A błogosławiony jest ten, kto się nie zgorszy z mojego powodu.
\m 
\v 7 A gdy odeszli, Jezus zaczął mówić do tłumów o Janie: Co wyszliście oglądać na pustyni? Trzcinę kołyszącą się na wietrze?
\m 
\v 8 Ale co wyszliście zobaczyć? Człowieka ubranego w miękkie szaty? Oto ci, którzy noszą miękkie szaty, są w domach królewskich.
\m 
\v 9 Ale co wyszliście zobaczyć? Proroka? Owszem, mówię wam, nawet więcej niż proroka.
\m 
\v 10 Bo on jest tym, o którym jest napisane: Oto ja posyłam mego posłańca przed twoim obliczem, który przygotuje twoją drogę przed tobą.
\m 
\v 11 Zaprawdę powiadam wam: Nie powstał z tych, którzy rodzą się z kobiet, większy od Jana Chrzciciela. Ale ten, kto jest najmniejszy w królestwie niebieskim, jest większy niż on.
\m 
\v 12 A od dni Jana Chrzciciela aż dotąd królestwo niebieskie doznaje gwałtu i gwałtownicy je zdobywają.
\m 
\v 13 Bo wszyscy Prorocy i Prawo prorokowali aż do Jana.
\m 
\v 14 A jeśli chcecie \add to\add* przyjąć, on jest Eliaszem, który miał przyjść.
\m 
\v 15 Kto ma uszy do słuchania, niech słucha.
\m 
\v 16 Ale do kogo przyrównam to pokolenie? Podobne jest do dzieci, które siedzą na rynku i wołają na swoich towarzyszy:
\m 
\v 17 Graliśmy wam na flecie, a nie tańczyliście; śpiewaliśmy pieśni żałobne, a nie płakaliście.
\m 
\v 18 Przyszedł bowiem Jan, nie jadł i nie pił, a mówią: Ma demona.
\m 
\v 19 Przyszedł Syn Człowieczy, jedząc i pijąc, a mówią: Oto żarłok i pijak, przyjaciel celników i grzeszników. Lecz usprawiedliwiona jest mądrość przez swoje dzieci.
\m 
\v 20 Wtedy zaczął ganić miasta, w których działo się najwięcej jego cudów, że nie pokutowały, \add mówiąc\add*:
\m 
\v 21 Biada tobie, Korozain! Biada tobie, Betsaido! Bo gdyby w Tyrze i Sydonie działy się te cuda, które się w was dokonały, dawno by w worze i popiele pokutowały.
\m 
\v 22 Ale mówię wam: Lżej będzie Tyrowi i Sydonowi w dniu sądu niż wam.
\m 
\v 23 A ty, Kafarnaum, które jesteś wywyższone aż do nieba, aż do piekła będziesz strącone. Bo gdyby w Sodomie działy się cuda, które się w tobie dokonały, przetrwałaby aż do dziś.
\m 
\v 24 Ale mówię wam: Lżej będzie ziemi Sodomy w dzień sądu niż tobie.
\m 
\v 25 W tym czasie Jezus powiedział: Wysławiam cię, Ojcze, Panie nieba i ziemi, że zakryłeś te sprawy przed mądrymi i roztropnymi, a objawiłeś je niemowlętom.
\m 
\v 26 Tak, Ojcze, gdyż tak się tobie upodobało.
\m 
\v 27 Wszystko zostało mi dane od mego Ojca i nikt nie zna Syna, tylko Ojciec, ani nikt nie zna Ojca, tylko Syn i ten, komu Syn zechce objawić.
\m 
\v 28 Przyjdźcie do mnie wszyscy, którzy jesteście spracowani i obciążeni, a ja wam dam odpoczynek.
\m 
\v 29 Weźcie na siebie moje jarzmo i uczcie się ode mnie, że jestem cichy i pokornego serca, a znajdziecie odpoczynek dla waszych dusz.
\m 
\v 30 Moje jarzmo bowiem jest przyjemne, a moje brzemię lekkie.
\c 12
\m 
\v 1 W tym czasie Jezus przechodził w szabat wśród zbóż, a jego uczniowie byli głodni i zaczęli zrywać kłosy, i jeść.
\m 
\v 2 Kiedy faryzeusze to zobaczyli, powiedzieli mu: Oto twoi uczniowie robią to, czego nie wolno robić w szabat.
\m 
\v 3 A on im powiedział: Czy nie czytaliście, co zrobił Dawid, gdy był głodny, on i ci, którzy z nim byli?
\m 
\v 4 Jak wszedł do domu Bożego i jadł chleby pokładne, których nie wolno było jeść jemu ani tym, którzy z nim byli, tylko samym kapłanom?
\m 
\v 5 Albo czy nie czytaliście w prawie, że w szabat kapłani w świątyni naruszają szabat, a są bez winy?
\m 
\v 6 Ale mówię wam, że tu jest \add ktoś\add* większy niż świątynia.
\m 
\v 7 A gdybyście wiedzieli, co to znaczy: Miłosierdzia chcę, a nie ofiary, nie potępialibyście niewinnych.
\m 
\v 8 Syn Człowieczy bowiem jest też Panem szabatu.
\m 
\v 9 I odszedłszy stamtąd, wszedł do ich synagogi.
\m 
\v 10 A był tam człowiek, który miał uschłą rękę. I chcąc go oskarżyć, zapytali: Czy wolno uzdrawiać w szabat?
\m 
\v 11 A on im odpowiedział: Któż z was, mając jedną owcę, która w szabat wpadłaby do dołu, nie chwyci jej i nie wyciągnie?
\m 
\v 12 A o ileż ważniejszy jest człowiek niż owca! Tak więc wolno w szabat dobrze czynić.
\m 
\v 13 Wtedy powiedział do tego człowieka: Wyciągnij rękę. On ją wyciągnął i znowu stała się zdrowa jak i druga.
\m 
\v 14 A faryzeusze, wyszedłszy, naradzali się przeciwko niemu, w jaki sposób go zgładzić.
\m 
\v 15 Lecz Jezus, poznawszy to, odszedł stamtąd. Poszło za nim mnóstwo ludzi, a on uzdrowił ich wszystkich.
\m 
\v 16 I przykazał im, aby go nie ujawniali;
\m 
\v 17 Żeby się wypełniło, co zostało powiedziane przez proroka Izajasza, który powiedział:
\m 
\v 18 Oto mój sługa, którego wybrałem, mój umiłowany, w którym moja dusza ma upodobanie. Złożę na nim mojego Ducha, a on ogłosi sąd narodom.
\m 
\v 19 Nie będzie się spierał ani krzyczał i nikt nie usłyszy na ulicach jego głosu.
\m 
\v 20 Trzciny nadłamanej nie złamie, a knota tlącego się nie zagasi, dopóki nie doprowadzi sądu do zwycięstwa.
\m 
\v 21 A w jego imieniu narody będą pokładać nadzieję.
\m 
\v 22 Wtedy przyprowadzono do niego opętanego, który był ślepy i niemy. I uzdrowił go tak, że ten ślepy i niemy mówił i widział.
\m 
\v 23 A wszyscy ludzie, zdumieni, mówili: Czyż to nie jest syn Dawida?
\m 
\v 24 Ale faryzeusze, usłyszawszy to, powiedzieli: On nie wypędza demonów inaczej, jak tylko przez Belzebuba, władcę demonów.
\m 
\v 25 Lecz Jezus, znając ich myśli, powiedział im: Każde królestwo podzielone wewnętrznie pustoszeje i żadne miasto albo dom podzielony wewnętrznie nie przetrwa.
\m 
\v 26 A jeśli szatan wypędza szatana, jest podzielony wewnętrznie. Jakże więc przetrwa jego królestwo?
\m 
\v 27 Jeśli ja przez Belzebuba wypędzam demony, to przez kogo wypędzają wasi synowie? Dlatego oni będą waszymi sędziami.
\m 
\v 28 A jeśli ja wypędzam demony Duchem Bożym, to przyszło do was królestwo Boże.
\m 
\v 29 Albo jak może ktoś wejść do domu mocarza i zagrabić jego własność, jeśli najpierw nie zwiąże mocarza? Dopiero wtedy ograbi jego dom.
\m 
\v 30 Kto nie jest ze mną, jest przeciwko mnie, a kto nie zbiera ze mną, rozprasza.
\m 
\v 31 Dlatego mówię wam: Każdy grzech i bluźnierstwo będzie ludziom przebaczone, ale bluźnierstwo przeciwko Duchowi \add Świętemu\add* nie będzie ludziom przebaczone.
\m 
\v 32 I ktokolwiek powie słowo przeciwko Synowi Człowieczemu, będzie mu przebaczone, ale kto mówi przeciwko Duchowi Świętemu, nie będzie mu przebaczone ani w tym świecie, ani w przyszłym.
\m 
\v 33 Sprawcie, aby drzewo było dobre i jego owoc dobry, albo sprawcie, aby drzewo było złe i jego owoc zły. Po owocu bowiem poznaje się drzewo.
\m 
\v 34 Plemię żmijowe! Jakże możecie mówić dobre rzeczy, będąc złymi? Gdyż z obfitości serca mówią usta.
\m 
\v 35 Dobry człowiek wydobywa z dobrego skarbca serca dobre \add rzeczy\add*, a zły człowiek wydobywa ze złego skarbca złe \add rzeczy\add*.
\m 
\v 36 Ale mówię wam, że z każdego bezużytecznego słowa, które wypowiedzą ludzie, zdadzą sprawę w dzień sądu.
\m 
\v 37 Bo na podstawie twoich słów będziesz usprawiedliwiony i na podstawie twoich słów będziesz potępiony.
\m 
\v 38 Wtedy niektórzy z uczonych w Piśmie i z faryzeuszy odpowiedzieli: Nauczycielu, chcemy widzieć znak od ciebie.
\m 
\v 39 A on odpowiedział im: Pokolenie złe i cudzołożne żąda znaku, ale żaden znak nie będzie mu dany, oprócz znaku proroka Jonasza.
\m 
\v 40 Jak bowiem Jonasz był w brzuchu wieloryba trzy dni i trzy noce, tak Syn Człowieczy będzie w sercu ziemi trzy dni i trzy noce.
\m 
\v 41 Ludzie z Niniwy staną na sądzie z tym pokoleniem i potępią je, ponieważ pokutowali wskutek głoszenia Jonasza, a oto tu \add ktoś\add* więcej niż Jonasz.
\m 
\v 42 Królowa z Południa stanie na sądzie z tym pokoleniem i potępi je, bo przybyła z krańców ziemi, aby słuchać mądrości Salomona, a oto tu \add ktoś\add* więcej niż Salomon.
\m 
\v 43 Kiedy nieczysty duch wychodzi z człowieka, przechadza się po miejscach bezwodnych, szukając odpoczynku, ale nie znajduje.
\m 
\v 44 Wtedy mówi: Wrócę do swego domu, z którego wyszedłem. A przyszedłszy, zastaje \add go\add* pustym, zamiecionym i przyozdobionym.
\m 
\v 45 Wówczas idzie i bierze ze sobą siedem innych duchów gorszych niż on sam i wszedłszy, mieszkają tam. I końcowy stan tego człowieka staje się gorszy niż początkowy. Tak będzie i z tym złym pokoleniem.
\m 
\v 46 A gdy on jeszcze mówił do ludzi, jego matka i bracia stanęli przed domem, chcąc z nim rozmawiać.
\m 
\v 47 I powiedział mu ktoś: Oto twoja matka i twoi bracia stoją przed domem, chcąc z tobą mówić.
\m 
\v 48 Lecz on odpowiedział temu, który mu to oznajmił: Któż jest moją matką i kto to są moi bracia?
\m 
\v 49 A wyciągnąwszy rękę ku swoim uczniom, powiedział: Oto moja matka i moi bracia!
\m 
\v 50 Kto bowiem wypełnia wolę mojego Ojca, który jest w niebie, ten jest moim bratem i siostrą, i matką.
\c 13
\m 
\v 1 A tego dnia Jezus wyszedł z domu i usiadł nad \add brzegiem\add* morza.
\m 
\v 2 I zebrały się wokół niego wielkie tłumy, dlatego wszedł do łodzi i usiadł, a wszyscy ludzie stali na brzegu.
\m 
\v 3 I mówił do nich wiele w przypowieściach. I powiedział: Oto siewca wyszedł siać.
\m 
\v 4 A gdy siał, niektóre \add ziarna\add* padły przy drodze, przyleciały ptaki i wydziobały je.
\m 
\v 5 Inne padły na \add miejsca\add* skaliste, gdzie nie miały wiele ziemi. Zaraz wzeszły, bo ziemia nie była głęboka.
\m 
\v 6 Lecz gdy wzeszło słońce, zostały spalone, a ponieważ nie miały korzenia, uschły.
\m 
\v 7 Inne padły między ciernie, a ciernie wyrosły i zagłuszyły je.
\m 
\v 8 Inne zaś padły na dobrą ziemię i wydały plon, jedne stokrotny, inne sześćdziesięciokrotny, a jeszcze inne trzydziestokrotny.
\m 
\v 9 Kto ma uszy do słuchania, niech słucha.
\m 
\v 10 Wtedy uczniowie podeszli i zapytali go: Dlaczego mówisz do nich w przypowieściach?
\m 
\v 11 A on odpowiedział im: Wam dano poznać tajemnice królestwa niebieskiego, ale im nie jest dane.
\m 
\v 12 Kto bowiem ma, temu będzie dodane i będzie miał w obfitości, ale kto nie ma, zostanie mu zabrane nawet to, co ma.
\m 
\v 13 Dlatego mówię do nich w przypowieściach, bo patrzą, a nie widzą, i słuchają, a nie słyszą ani nie rozumieją.
\m 
\v 14 I spełnia się na nich proroctwo Izajasza, które mówi: Słuchając, będziecie słyszeć, ale nie zrozumiecie i patrząc, będziecie widzieć, ale nie zobaczycie.
\m 
\v 15 Utyło bowiem serce tego ludu, stępiały ich uszy i zamknęli swe oczy, żeby przypadkiem oczami nie widzieli ani uszami \add nie\add* słyszeli, a sercem \add nie\add* zrozumieli i \add nie\add* nawrócili się, i żebym ich \add nie\add* uzdrowił.
\m 
\v 16 Ale błogosławione wasze oczy, bo widzą, i wasze uszy, bo słyszą.
\m 
\v 17 Bo zaprawdę powiadam wam: Wielu proroków i sprawiedliwych pragnęło widzieć \add to\add*, co \add wy\add* widzicie, ale nie zobaczyli, i słyszeć \add to\add*, co \add wy\add* słyszycie, ale nie usłyszeli.
\m 
\v 18 Wysłuchajcie więc przypowieści o siewcy.
\m 
\v 19 Gdy ktoś słucha słowa o królestwie, a nie rozumie, przychodzi zły i porywa to, co zostało zasiane w jego sercu. To jest ten posiany przy drodze.
\m 
\v 20 A posiany na \add miejscach\add* skalistych to ten, który słucha słowa i natychmiast z radością je przyjmuje.
\m 
\v 21 Nie ma jednak w sobie korzenia, lecz trwa do czasu. Gdy bowiem przychodzi ucisk albo prześladowanie z powodu słowa, zaraz się gorszy.
\m 
\v 22 A posiany między ciernie to ten, który słucha słowa, ale troski tego świata i ułuda bogactwa zagłuszają słowo i staje się \add on\add* bezowocny.
\m 
\v 23 A posiany na dobrej ziemi to ten, który słucha słowa i rozumie je. On też wydaje plon: jeden stokrotny, inny sześćdziesięciokrotny, a jeszcze inny trzydziestokrotny.
\m 
\v 24 Podał im \add też\add* inną przypowieść: Królestwo niebieskie podobne jest do człowieka, który zasiał dobre ziarno na swoim polu.
\m 
\v 25 Lecz gdy ludzie spali, przyszedł jego nieprzyjaciel, nasiał kąkolu między pszenicę i odszedł.
\m 
\v 26 A gdy zboże urosło i wydało plon, wtedy ukazał się też kąkol.
\m 
\v 27 Wówczas słudzy gospodarza przyszli i zapytali go: Panie, czy nie posiałeś na swoim polu dobrego ziarna? Skąd więc ten kąkol?
\m 
\v 28 A on im odpowiedział: Nieprzyjaciel to zrobił. I zapytali go słudzy: Czy chcesz, żebyśmy poszli i zebrali go?
\m 
\v 29 Lecz on odpowiedział: Nie, żebyście przypadkiem, zbierając kąkol, nie wykorzenili razem z nim \add i\add* pszenicy.
\m 
\v 30 Pozwólcie obydwu razem rosnąć aż do żniwa, a w czasie żniwa powiem żniwiarzom: Zbierzcie najpierw kąkol i zwiążcie go w snopki na spalenie, pszenicę zaś zgromadźcie w moim spichlerzu.
\m 
\v 31 Podał im \add też\add* inną przypowieść: Królestwo niebieskie podobne jest do ziarna gorczycy, które człowiek, wziąwszy, zasiał na swoim polu.
\m 
\v 32 Jest ono najmniejsze ze wszystkich nasion, ale kiedy wyrośnie, jest największe ze wszystkich jarzyn i staje się drzewem, tak że ptaki niebieskie przylatują i gnieżdżą się w jego gałęziach.
\m 
\v 33 Opowiedział im \add jeszcze\add* inną przypowieść: Królestwo niebieskie podobne jest do zakwasu, który kobieta wzięła i włożyła w trzy miary mąki, aż wszystko się zakwasiło.
\m 
\v 34 To wszystko mówił Jezus do tłumu w przypowieściach, a bez przypowieści nic do nich nie mówił;
\m 
\v 35 Aby się wypełniło, co zostało powiedziane przez proroka: Otworzę moje usta w przypowieściach, wypowiem rzeczy ukryte od założenia świata.
\m 
\v 36 Wtedy Jezus odprawił tłum i przyszedł do domu. Podeszli do niego jego uczniowie i mówili: Wyjaśnij nam przypowieść o kąkolu na polu.
\m 
\v 37 A on odpowiedział im: Tym, który sieje dobre ziarno, jest Syn Człowieczy.
\m 
\v 38 Polem jest świat, dobrym ziarnem są synowie królestwa, kąkolem zaś są synowie złego.
\m 
\v 39 Nieprzyjacielem, który go posiał, jest diabeł, żniwem jest koniec świata, a żniwiarzami są aniołowie.
\m 
\v 40 Jak więc zbiera się kąkol i spala w ogniu, tak będzie przy końcu tego świata.
\m 
\v 41 Syn Człowieczy pośle swoich aniołów, a oni zbiorą z jego królestwa wszystkie zgorszenia i tych, którzy popełniają nieprawość;
\m 
\v 42 I wrzucą ich do pieca ognistego. Tam będzie płacz i zgrzytanie zębów.
\m 
\v 43 Wtedy sprawiedliwi będą jaśnieć jak słońce w królestwie swego Ojca. Kto ma uszy do słuchania, niech słucha.
\m 
\v 44 Ponownie królestwo niebieskie jest podobne do skarbu ukrytego w polu, który człowiek znalazł i ukrył. Uradowany nim poszedł, sprzedał wszystko, co miał, i kupił to pole.
\m 
\v 45 Królestwo niebieskie podobne jest też do kupca, który szukał pięknych pereł.
\m 
\v 46 A znalazłszy jedną bardzo cenną perłę, poszedł, sprzedał wszystko, co miał, i kupił ją.
\m 
\v 47 Królestwo niebieskie podobne jest również do sieci zarzuconej w morze i zagarniającej \add ryby\add* wszelkiego rodzaju.
\m 
\v 48 Gdy się napełniła, \add rybacy\add* wyciągnęli ją na brzeg, a usiadłszy, dobre \add ryby\add* wybrali do naczyń, a złe wyrzucili.
\m 
\v 49 Tak będzie przy końcu świata: wyjdą aniołowie i wyłączą złych spośród sprawiedliwych;
\m 
\v 50 I wrzucą ich do pieca ognistego. Tam będzie płacz i zgrzytanie zębów.
\m 
\v 51 Jezus ich zapytał: Zrozumieliście to wszystko? Odpowiedzieli mu: Tak, Panie.
\m 
\v 52 A on powiedział do nich: Dlatego każdy uczony w Piśmie, \add który jest\add* pouczony o królestwie niebieskim, podobny jest do gospodarza, który wydobywa ze swego skarbca nowe i stare rzeczy.
\m 
\v 53 Kiedy Jezus dokończył tych przypowieści, odszedł stamtąd.
\m 
\v 54 A przyszedłszy w swoje rodzinne strony, nauczał ludzi w ich synagodze, tak że się bardzo zdumiewali i mówili: Skąd on ma tę mądrość i moc?
\m 
\v 55 Czyż to nie jest syn cieśli? Czyż jego matce nie jest na imię Maria, a jego bracia \add to\add* Jakub, Józef, Szymon i Juda?
\m 
\v 56 A jego siostry, czyż wszystkie nie są wśród nas? Skąd więc on ma to wszystko?
\m 
\v 57 I byli nim zgorszeni. Lecz Jezus powiedział do nich: Nigdzie nie jest prorok bez czci, tylko w swojej ojczyźnie i w swoim domu.
\m 
\v 58 I nie uczynił tam wielu cudów z powodu ich niewiary.
\c 14
\m 
\v 1 W tym czasie tetrarcha Herod usłyszał wieść o Jezusie.
\m 
\v 2 I powiedział swoim sługom: To jest Jan Chrzciciel. On zmartwychwstał i dlatego cuda dokonują się przez niego.
\m 
\v 3 Herod bowiem schwytał Jana, związał go i wtrącił do więzienia z powodu Herodiady, żony swego brata Filipa.
\m 
\v 4 Bo Jan mówił mu: Nie wolno ci jej mieć.
\m 
\v 5 I chciał go zabić, ale bał się ludu, bo uważano go za proroka.
\m 
\v 6 A gdy obchodzono dzień urodzin Heroda, córka Herodiady tańczyła wśród \add gości\add* i spodobała się Herodowi.
\m 
\v 7 Dlatego pod przysięgą obiecał jej dać, o cokolwiek poprosi.
\m 
\v 8 A ona, namówiona przedtem przez swoją matkę, powiedziała: Daj mi tu na misie głowę Jana Chrzciciela.
\m 
\v 9 I zasmucił się król, ale ze względu na przysięgę i współbiesiadników kazał \add jej\add* dać.
\m 
\v 10 A posławszy \add kata\add*, ściął Jana w więzieniu.
\m 
\v 11 I przyniesiono jego głowę na misie, i dano dziewczynie, a ona zaniosła ją swojej matce.
\m 
\v 12 Potem przyszli jego uczniowie, zabrali ciało i pogrzebali je, a poszedłszy, powiedzieli \add o tym\add* Jezusowi.
\m 
\v 13 A Jezus, usłyszawszy to, oddalił się stamtąd łodzią na miejsce odludne, \add żeby być\add* na osobności. Kiedy ludzie o tym usłyszeli, pieszo poszli za nim z miast.
\m 
\v 14 Gdy Jezus wyszedł \add z łodzi\add*, zobaczył wielki tłum, ulitował się nad nimi i uzdrawiał ich chorych.
\m 
\v 15 A gdy nastał wieczór, podeszli do niego jego uczniowie i powiedzieli: Miejsce to jest puste, a pora już późna. Odpraw tych ludzi, aby poszli do wiosek i kupili sobie żywności.
\m 
\v 16 Lecz Jezus im odpowiedział: Nie muszą odchodzić, wy dajcie im jeść.
\m 
\v 17 A oni mu powiedzieli: Nie mamy tu nic prócz pięciu chlebów i dwóch ryb.
\m 
\v 18 On powiedział: Przynieście mi je tutaj.
\m 
\v 19 Wtedy nakazał ludziom usiąść na trawie, wziął te pięć chlebów i dwie ryby, a spojrzawszy w niebo, pobłogosławił i łamiąc chleby, dawał uczniom, a uczniowie ludziom.
\m 
\v 20 I jedli wszyscy do syta. I zebrali z pozostałych kawałków dwanaście pełnych koszy.
\m 
\v 21 A tych, którzy jedli, było około pięciu tysięcy mężczyzn, nie licząc kobiet i dzieci.
\m 
\v 22 Zaraz też Jezus przymusił swoich uczniów, aby wsiedli do łodzi i wyprzedzili go na drugi brzeg, a on tymczasem odprawi tłumy.
\m 
\v 23 A odprawiwszy je, wszedł sam na górę, aby się modlić. A gdy nastał wieczór, \add nadal\add* był tam sam.
\m 
\v 24 Łódź tymczasem była już na środku morza, miotana przez fale, bo wiatr był przeciwny.
\m 
\v 25 Lecz o czwartej straży nocnej przyszedł do nich Jezus, idąc po morzu.
\m 
\v 26 A uczniowie, gdy ujrzeli go idącego po morzu, przerazili się i powiedzieli: \add To\add* zjawa! I krzyknęli ze strachu.
\m 
\v 27 Ale Jezus zaraz do nich powiedział: Ufajcie, \add to\add* ja jestem! Nie bójcie się!
\m 
\v 28 Piotr odezwał się do niego: Panie, jeśli to jesteś ty, każ mi przyjść do siebie po wodzie.
\m 
\v 29 A on powiedział: Przyjdź! I Piotr, wyszedłszy z łodzi, szedł po wodzie, aby przyjść do Jezusa.
\m 
\v 30 Lecz widząc gwałtowny wiatr, zląkł się, a gdy zaczął tonąć, krzyknął: Panie, ratuj mnie!
\m 
\v 31 Jezus natychmiast wyciągnął rękę, uchwycił go i powiedział: Człowieku małej wiary, dlaczego zwątpiłeś?
\m 
\v 32 A gdy wsiedli do łodzi, wiatr się uciszył.
\m 
\v 33 Ci zaś, którzy byli w łodzi, podeszli i oddali mu pokłon, mówiąc: Naprawdę jesteś Synem Bożym.
\m 
\v 34 I przeprawiwszy się, przybyli do ziemi Genezaret.
\m 
\v 35 A ludzie z tamtych okolic, poznawszy go, rozesłali \add wiadomość\add* po całej okolicy i przyniesiono do niego wszystkich chorych.
\m 
\v 36 I prosili go, aby mogli dotknąć tylko brzegu jego szaty, a ci, którzy dotknęli, zostali uzdrowieni.
\c 15
\m 
\v 1 Wtedy z Jerozolimy przyszli do Jezusa uczeni w Piśmie i faryzeusze i zapytali:
\m 
\v 2 Czemu twoi uczniowie postępują wbrew tradycji starszych? Nie myją bowiem rąk przed jedzeniem chleba.
\m 
\v 3 A on odpowiedział im: Czemu i wy postępujecie wbrew przykazaniu Bożemu dla waszej tradycji?
\m 
\v 4 Bóg bowiem nakazał: Czcij swego ojca i matkę, oraz: Kto złorzeczy ojcu albo matce, niech poniesie śmierć.
\m 
\v 5 Ale wy mówicie: Kto by powiedział ojcu albo matce: To, co powinieneś otrzymać ode mnie jako pomoc, jest darem \add ofiarnym\add*;
\m 
\v 6 I nie uczciłby swego ojca ani matki, \add będzie bez winy\add*. I tak unieważniliście przykazanie Boże przez waszą tradycję.
\m 
\v 7 Obłudnicy, dobrze prorokował o was Izajasz:
\m 
\v 8 Lud ten przybliża się do mnie swymi ustami i czci mnie wargami, ale ich serce daleko jest ode mnie.
\m 
\v 9 Lecz na próżno mnie czczą, ucząc nauk, \add które\add* są przykazaniami ludzkimi.
\m 
\v 10 Potem przywołał do siebie tłum i powiedział: Słuchajcie i zrozumiejcie.
\m 
\v 11 Nie to, co wchodzi do ust, kala człowieka, ale co z ust wychodzi, to kala człowieka.
\m 
\v 12 Wtedy podeszli jego uczniowie i powiedzieli do niego: Wiesz, że faryzeusze zgorszyli się, gdy usłyszeli te słowa?
\m 
\v 13 A on odpowiedział: Każda roślina, której nie zasadził mój Ojciec niebieski, będzie wykorzeniona.
\m 
\v 14 Zostawcie ich! To są ślepi przewodnicy ślepych, a jeśli ślepy prowadzi ślepego, obaj w dół wpadną.
\m 
\v 15 Wtedy Piotr powiedział do niego: Wyjaśnij nam tę przypowieść.
\m 
\v 16 Jezus odpowiedział: Wy też jeszcze jesteście niepojętni?
\m 
\v 17 Jeszcze nie rozumiecie, że wszystko, co wchodzi do ust, idzie do żołądka i zostaje wydalone do ustępu?
\m 
\v 18 Ale to, co z ust wychodzi, pochodzi z serca i to kala człowieka.
\m 
\v 19 Z serca bowiem pochodzą złe myśli, zabójstwa, cudzołóstwa, nierząd, kradzieże, fałszywe świadectwa, bluźnierstwa.
\m 
\v 20 To właśnie kala człowieka. Lecz jedzenie nieumytymi rękami nie kala człowieka.
\m 
\v 21 Potem Jezus odszedł stamtąd i udał się w okolice Tyru i Sydonu.
\m 
\v 22 A oto kobieta kananejska, wyszedłszy z tamtych okolic, wołała do niego: Zmiłuj się nade mną, Panie, Synu Dawida! Moja córka jest ciężko dręczona przez demona.
\m 
\v 23 On jednak nie odpowiedział jej ani słowa. Wówczas jego uczniowie podeszli i prosili go: Odpraw ją, bo woła za nami.
\m 
\v 24 A on odpowiedział: Jestem posłany tylko do owiec zaginionych z domu Izraela.
\m 
\v 25 Lecz ona podeszła i oddała mu pokłon, mówiąc: Panie, pomóż mi!
\m 
\v 26 On jednak odpowiedział: Niedobrze jest brać chleb dzieci i rzucać szczeniętom.
\m 
\v 27 A ona powiedziała: Tak, Panie, ale i szczenięta jedzą okruchy, które spadają ze stołu ich panów.
\m 
\v 28 Wtedy Jezus jej odpowiedział: O kobieto, wielka jest twoja wiara! Niech ci się stanie, jak chcesz. I od tej chwili jej córka była zdrowa.
\m 
\v 29 A Jezus odszedł stamtąd i przyszedł nad Morze Galilejskie. Wszedł na górę i tam usiadł.
\m 
\v 30 I przyszły do niego wielkie tłumy, mając ze sobą chromych, ślepych, niemych, ułomnych oraz wielu innych. Położyli ich u nóg Jezusa, a on ich uzdrowił;
\m 
\v 31 Tak że tłumy dziwiły się, widząc, że niemi mówią, ułomni są uzdrowieni, chromi chodzą, a ślepi widzą. I wielbili Boga Izraela.
\m 
\v 32 Lecz Jezus przywołał swoich uczniów i powiedział: Żal mi tych ludzi, bo już trzy dni przy mnie trwają i nie mają co jeść. Nie chcę ich odprawić głodnych, aby przypadkiem nie zasłabli w drodze.
\m 
\v 33 Wtedy jego uczniowie powiedzieli mu: Skąd na tej pustyni weźmiemy tyle chleba, aby nakarmić takie mnóstwo ludzi?
\m 
\v 34 Zapytał ich Jezus: Ile macie chlebów? A oni odpowiedzieli: Siedem i kilka rybek.
\m 
\v 35 I nakazał ludziom usiąść na ziemi.
\m 
\v 36 Potem wziął te siedem chlebów i ryby, a podziękowawszy, łamał i dawał swoim uczniom, a uczniowie ludziom.
\m 
\v 37 I jedli wszyscy do syta, a z pozostałych kawałków zebrali siedem pełnych koszy.
\m 
\v 38 Tych zaś, którzy jedli, było cztery tysiące mężczyzn, nie licząc kobiet i dzieci.
\m 
\v 39 A gdy odprawił ludzi, wsiadł do łodzi i przybył w okolice Magdali.
\c 16
\m 
\v 1 Podeszli faryzeusze i saduceusze i wystawiając go na próbę, prosili, aby pokazał im znak z nieba.
\m 
\v 2 A on im odpowiedział: Gdy nastaje wieczór, mówicie: \add Będzie\add* pogoda, bo niebo się czerwieni.
\m 
\v 3 Rano zaś: Dziś \add będzie\add* niepogoda, bo niebo się czerwieni i jest zachmurzone. Obłudnicy, wygląd nieba umiecie rozpoznać, a znaków tych czasów nie możecie?
\m 
\v 4 Pokolenie złe i cudzołożne żąda znaku, ale \add żaden\add* znak nie będzie mu dany oprócz znaku proroka Jonasza. I opuściwszy ich, odszedł.
\m 
\v 5 A gdy jego uczniowie przeprawili się na drugą stronę \add morza\add*, zapomnieli wziąć chleba.
\m 
\v 6 I powiedział im Jezus: Uważajcie i strzeżcie się zakwasu faryzeuszy i saduceuszy.
\m 
\v 7 A oni rozmawiali między sobą: Nie wzięliśmy chleba.
\m 
\v 8 Gdy Jezus to zauważył, powiedział im: Ludzie małej wiary, czemu rozmawiacie między sobą o tym, że nie wzięliście chleba?
\m 
\v 9 Jeszcze nie rozumiecie ani nie pamiętacie tych pięciu chlebów i pięciu tysięcy \add ludzi\add* oraz ile koszy zebraliście?
\m 
\v 10 Ani tych siedmiu chlebów i czterech tysięcy \add ludzi\add* oraz ile koszy zebraliście?
\m 
\v 11 Jak to jest, że nie rozumiecie, iż nie o chlebie wam powiedziałem, \add mówiąc\add*, abyście się strzegli zakwasu faryzeuszy i saduceuszy?
\m 
\v 12 Wtedy zrozumieli, że nie mówił, aby się strzegli zakwasu chlebowego, ale nauki faryzeuszy i saduceuszy.
\m 
\v 13 A gdy Jezus przyszedł w okolice Cezarei Filipowej, pytał swoich uczniów: Za kogo mnie, Syna Człowieczego, uważają ludzie?
\m 
\v 14 A oni odpowiedzieli: Jedni za Jana Chrzciciela, inni za Eliasza, a jeszcze inni za Jeremiasza albo za jednego z proroków.
\m 
\v 15 I zapytał ich: A wy za kogo mnie uważacie?
\m 
\v 16 Szymon Piotr odpowiedział: Ty jesteś Chrystusem, Synem Boga żywego.
\m 
\v 17 Wtedy Jezus powiedział do niego: Błogosławiony jesteś, Szymonie, synu Jonasza, bo nie objawiły ci \add tego\add* ciało i krew, ale mój Ojciec, który jest w niebie.
\m 
\v 18 Ja ci też mówię, że ty jesteś Piotr, a na tej skale zbuduję mój kościół, a bramy piekła go nie przemogą.
\m 
\v 19 I tobie dam klucze królestwa niebieskiego. Cokolwiek zwiążesz na ziemi, będzie związane i w niebie, a cokolwiek rozwiążesz na ziemi, będzie rozwiązane \add i\add* w niebie.
\m 
\v 20 Wtedy przykazał swoim uczniom, aby nikomu nie mówili, że on, Jezus, jest Chrystusem.
\m 
\v 21 I odtąd zaczął Jezus tłumaczyć swoim uczniom, że musi iść do Jerozolimy i wiele cierpieć od starszych, od naczelnych kapłanów i uczonych w Piśmie, i być zabity, a trzeciego dnia zmartwychwstać.
\m 
\v 22 A Piotr, wziąwszy go \add na bok\add*, zaczął go strofować, mówiąc: Zmiłuj się nad sobą, Panie! Nie przyjdzie to na ciebie.
\m 
\v 23 Lecz on odwrócił się i powiedział do Piotra: Odejdź ode mnie, szatanie! Jesteś dla mnie zgorszeniem, bo nie pojmujesz tego, co Boże, ale to, co ludzkie.
\m 
\v 24 Wtedy Jezus powiedział do swoich uczniów: Jeśli ktoś chce pójść za mną, niech się wyprze samego siebie, weźmie swój krzyż i idzie za mną.
\m 
\v 25 Bo kto chce zachować swoje życie, straci je, a kto straci swoje życie z mojego powodu, znajdzie je.
\m 
\v 26 Cóż pomoże człowiekowi, choćby cały świat pozyskał, a na swojej duszy poniósł szkodę? Albo co da człowiek w zamian za swoją duszę?
\m 
\v 27 Syn Człowieczy przyjdzie bowiem w chwale swego Ojca ze swoimi aniołami i wtedy odda każdemu według jego uczynków.
\m 
\v 28 Zaprawdę powiadam wam: Są wśród stojących tutaj tacy, którzy nie zakosztują śmierci, aż ujrzą Syna Człowieczego przychodzącego w swoim królestwie.
\c 17
\m 
\v 1 A po sześciu dniach wziął Jezus Piotra, Jakuba i Jana, jego brata, i wprowadził ich na wysoką górę, \add żeby byli\add* na osobności.
\m 
\v 2 I został przemieniony przed nimi: jego oblicze zajaśniało jak słońce, a jego szaty stały się białe jak światło.
\m 
\v 3 A oto ukazali się im Mojżesz i Eliasz, którzy z nim rozmawiali.
\m 
\v 4 Wtedy Piotr powiedział do Jezusa: Panie, dobrze nam tu być. Jeśli chcesz, postawimy tu trzy namioty: jeden dla ciebie, jeden dla Mojżesza i jeden dla Eliasza.
\m 
\v 5 Kiedy on jeszcze mówił, oto jasny obłok zacienił ich, a z obłoku rozległ się głos: To jest mój umiłowany Syn, w którym mam upodobanie, jego słuchajcie.
\m 
\v 6 Uczniowie, słysząc to, upadli na twarz i bardzo się bali.
\m 
\v 7 Wtedy Jezus podszedł, dotknął ich i powiedział: Wstańcie, nie bójcie się.
\m 
\v 8 Oni zaś, podniósłszy oczy, nikogo nie widzieli, tylko samego Jezusa.
\m 
\v 9 A gdy schodzili z góry, Jezus im przykazał: Nikomu nie mówcie o tym widzeniu, aż Syn Człowieczy zmartwychwstanie.
\m 
\v 10 I pytali go jego uczniowie: Dlaczego więc uczeni w Piśmie mówią, że najpierw ma przyjść Eliasz?
\m 
\v 11 A Jezus im odpowiedział: Istotnie, najpierw przyjdzie Eliasz i wszystko odnowi.
\m 
\v 12 Lecz mówię wam, że Eliasz już przyszedł, jednak nie poznali go, ale zrobili z nim, co chcieli. Tak i Syn Człowieczy dozna od nich cierpień.
\m 
\v 13 Wtedy uczniowie zrozumieli, że mówił im o Janie Chrzcicielu.
\m 
\v 14 A gdy przyszli do tłumu, podszedł do niego \add pewien\add* człowiek, upadł przed nim na kolana;
\m 
\v 15 I powiedział: Panie, zmiłuj się nad moim synem, bo jest obłąkanym i bardzo cierpi. Często bowiem wpada w ogień i często w wodę.
\m 
\v 16 Przyprowadziłem go do twoich uczniów, ale nie mogli go uzdrowić.
\m 
\v 17 A Jezus odpowiedział: O pokolenie bez wiary i przewrotne! Jak długo będę z wami? Jak długo mam was znosić? Przyprowadźcie mi go tutaj.
\m 
\v 18 I zgromił Jezus tego demona, i wyszedł z niego. Od tej chwili chłopiec był zdrowy.
\m 
\v 19 Wtedy uczniowie, podszedłszy do Jezusa, zapytali go na osobności: Czemu my nie mogliśmy go wypędzić?
\m 
\v 20 A Jezus im odpowiedział: Z powodu waszej niewiary. Zaprawdę bowiem powiadam wam: Jeśli będziecie mieć wiarę jak ziarno gorczycy, powiecie tej górze: Przenieś się stąd na tamto miejsce, a przeniesie się. I nic nie będzie dla was niemożliwe.
\m 
\v 21 Lecz ten rodzaj nie wychodzi inaczej, jak tylko przez modlitwę i post.
\m 
\v 22 A gdy przebywali w Galilei, Jezus powiedział do nich: Syn Człowieczy zostanie wydany w ręce ludzi;
\m 
\v 23 I zabiją go, ale trzeciego dnia zmartwychwstanie. I bardzo się zasmucili.
\m 
\v 24 A gdy przyszli do Kafarnaum, podeszli do Piotra poborcy podatku i zapytali: Czy wasz nauczyciel nie płaci podatku?
\m 
\v 25 On odpowiedział: Płaci. A gdy wchodził do domu, uprzedził go Jezus, mówiąc: Jak ci się wydaje, Szymonie? Od kogo królowie ziemscy pobierają cło albo podatek? Od swoich synów czy od obcych?
\m 
\v 26 Piotr mu odpowiedział: Od obcych. I powiedział mu Jezus: A więc synowie są wolni.
\m 
\v 27 Ale żebyśmy ich nie zgorszyli, idź nad morze, zarzuć wędkę, weź pierwszą złowioną rybę i otwórz jej pyszczek, a znajdziesz statera. Weź go i daj im za mnie i za siebie.
\c 18
\m 
\v 1 W tym czasie podeszli do Jezusa uczniowie, pytając: Kto jest największy w królestwie niebieskim?
\m 
\v 2 A Jezus, zawoławszy dziecko, postawił je pośród nich;
\m 
\v 3 I powiedział: Zaprawdę powiadam wam: Jeśli się nie nawrócicie i nie staniecie się jak dzieci, nie wejdziecie do królestwa niebieskiego.
\m 
\v 4 Kto się więc uniży jak to dziecko, ten jest największy w królestwie niebieskim.
\m 
\v 5 A kto przyjmie jedno takie dziecko w moje imię, mnie przyjmuje.
\m 
\v 6 Kto zaś zgorszy jednego z tych małych, którzy we mnie wierzą, lepiej byłoby dla niego, gdyby zawieszono mu u szyi kamień młyński i utopiono go w morskiej głębinie.
\m 
\v 7 Biada światu z powodu zgorszeń! Muszą bowiem przyjść zgorszenia, ale biada temu człowiekowi, przez którego przychodzi zgorszenie!
\m 
\v 8 Dlatego jeśli twoja ręka albo noga jest ci powodem upadku, odetnij ją i odrzuć od siebie. Lepiej jest dla ciebie wejść do życia chromym albo ułomnym, niż mając dwie ręce albo dwie nogi, być wrzuconym do ognia wiecznego.
\m 
\v 9 A jeśli twoje oko jest ci powodem upadku, wyłup je i odrzuć od siebie. Lepiej jest dla ciebie jednookim wejść do życia, niż mając dwoje oczu, być wrzuconym do ognia piekielnego.
\m 
\v 10 Uważajcie, abyście nie gardzili żadnym z tych małych. Mówię wam bowiem, że ich aniołowie w niebie zawsze patrzą na oblicze mojego Ojca, który jest w niebie.
\m 
\v 11 Przyszedł bowiem Syn Człowieczy, aby zbawić to, co zginęło.
\m 
\v 12 Jak wam się wydaje? Gdyby jakiś człowiek miał sto owiec, a jedna z nich zabłąkałaby się, czyż nie zostawi tych dziewięćdziesięciu dziewięciu i nie pójdzie w góry szukać zabłąkanej?
\m 
\v 13 A jeśli uda mu się ją znaleźć, zaprawdę powiadam wam, że cieszy się z niej bardziej niż z tych dziewięćdziesięciu dziewięciu, które się nie zabłąkały.
\m 
\v 14 Tak też nie jest wolą waszego Ojca, który jest w niebie, aby zginął jeden z tych małych.
\m 
\v 15 Jeśli twój brat zgrzeszy przeciwko tobie, idź, strofuj go sam na sam. Jeśli cię usłucha, pozyskałeś twego brata.
\m 
\v 16 Jeśli zaś cię nie usłucha, weź ze sobą jeszcze jednego albo dwóch, aby na podstawie zeznania dwóch albo trzech świadków oparte było każde słowo.
\m 
\v 17 Jeśli ich nie usłucha, powiedz kościołowi. A jeśli kościoła nie usłucha, niech będzie dla ciebie jak poganin i celnik.
\m 
\v 18 Zaprawdę powiadam wam: Cokolwiek zwiążecie na ziemi, będzie związane i w niebie. A cokolwiek rozwiążecie na ziemi, będzie rozwiązane i w niebie.
\m 
\v 19 Mówię wam też: Jeśli dwaj z was na ziemi będą zgodnie prosić o cokolwiek, otrzymają to od mego Ojca, który jest w niebie.
\m 
\v 20 Gdzie bowiem dwaj albo trzej są zgromadzeni w moje imię, tam jestem pośród nich.
\m 
\v 21 Wtedy Piotr podszedł do niego i zapytał: Panie, ile razy mam przebaczyć mojemu bratu, gdy zgrzeszy przeciwko mnie? Czy aż siedem razy?
\m 
\v 22 I odpowiedział mu Jezus: Nie mówię ci, że aż siedem razy, ale aż siedemdziesiąt siedem razy.
\m 
\v 23 Dlatego królestwo niebieskie podobne jest do króla, który chciał się rozliczyć ze swymi sługami.
\m 
\v 24 A gdy zaczął się rozliczać, przyprowadzono mu jednego, \add który\add* był mu winien dziesięć tysięcy talentów.
\m 
\v 25 A ponieważ nie miał \add z czego\add* oddać, jego pan kazał go sprzedać wraz z żoną, dziećmi i wszystkim, co miał, i spłacić \add dług\add*.
\m 
\v 26 Wtedy sługa upadł i oddał mu pokłon, mówiąc: Panie, okaż mi cierpliwość, a wszystko ci oddam.
\m 
\v 27 Pan tego sługi, ulitowawszy się \add nad nim\add*, uwolnił go i darował mu dług.
\m 
\v 28 Lecz gdy ten sługa wyszedł, spotkał jednego ze swoich współsług, który był mu winien sto groszy. Chwycił go i zaczął dusić, mówiąc: Oddaj, coś winien!
\m 
\v 29 Wtedy jego współsługa upadł mu do nóg i prosił go: Okaż mi cierpliwość, a wszystko ci oddam.
\m 
\v 30 On jednak nie chciał, ale poszedł i wtrącił go do więzienia, dopóki nie odda długu.
\m 
\v 31 A jego współsłudzy, widząc, co się stało, zasmucili się bardzo i poszedłszy, oznajmili swemu panu wszystko, co zaszło.
\m 
\v 32 Wtedy jego pan wezwał go i powiedział: Zły sługo, darowałem ci cały ten dług, ponieważ mnie prosiłeś.
\m 
\v 33 Czyż i ty nie powinieneś był zmiłować się nad swoim współsługą, jak ja zmiłowałem się nad tobą?
\m 
\v 34 I jego pan, rozgniewany, wydał go katom, dopóki nie odda wszystkiego, co był mu winien.
\m 
\v 35 Tak i wam uczyni mój Ojciec niebieski, jeśli każdy z was nie przebaczy z serca swemu bratu jego przewinień.
\c 19
\m 
\v 1 A gdy Jezus dokończył tych mów, odszedł z Galilei i przybył na pogranicze Judei za Jordan.
\m 
\v 2 I poszły za nim wielkie tłumy, a on ich tam uzdrowił.
\m 
\v 3 Wtedy przyszli do niego faryzeusze, wystawiając go na próbę i pytając: Czy wolno człowiekowi oddalić swoją żonę z jakiegokolwiek powodu?
\m 
\v 4 A on im odpowiedział: Nie czytaliście, że ten, który stworzył \add ich\add* na początku, uczynił ich mężczyzną i kobietą?
\m 
\v 5 I powiedział: Dlatego opuści mężczyzna ojca i matkę i połączy się ze swoją żoną, i będą dwoje jednym ciałem.
\m 
\v 6 A tak już nie są dwoje, ale jedno ciało. Co więc Bóg złączył, człowiek niech nie rozłącza.
\m 
\v 7 Zapytali go: Dlaczego więc Mojżesz nakazał dać list rozwodowy i oddalić ją?
\m 
\v 8 Odpowiedział im: Z powodu zatwardziałości waszego serca Mojżesz pozwolił wam oddalić wasze żony, ale od początku tak nie było.
\m 
\v 9 Lecz ja wam mówię: Kto oddala swoją żonę – z wyjątkiem przypadku nierządu – i żeni się z inną, cudzołoży, a kto żeni się z oddaloną, cudzołoży.
\m 
\v 10 Powiedzieli mu jego uczniowie: Jeśli tak ma się sprawa mężczyzny z \add jego\add* żoną, to lepiej się nie żenić.
\m 
\v 11 A on im powiedział: Nie wszyscy to pojmują, ale \add tylko ci\add*, którym to jest dane.
\m 
\v 12 Są bowiem eunuchowie, którzy tacy wyszli z łona matki; są też eunuchowie, których ludzie takimi uczynili; są również eunuchowie, którzy się sami takimi uczynili dla królestwa niebieskiego. Kto może pojąć, niech pojmuje.
\m 
\v 13 Wtedy przyniesiono mu dzieci, aby położył na nie ręce i pomodlił się, ale uczniowie ich gromili.
\m 
\v 14 Lecz Jezus powiedział: Zostawcie dzieci i nie zabraniajcie im przychodzić do mnie, bo do takich należy królestwo niebieskie.
\m 
\v 15 Położył na nie ręce i odszedł stamtąd.
\m 
\v 16 A oto pewien człowiek podszedł i zapytał go: Nauczycielu dobry, co dobrego mam czynić, aby mieć życie wieczne?
\m 
\v 17 Lecz on mu odpowiedział: Dlaczego nazywasz mnie dobrym? Nikt nie jest dobry, tylko jeden – Bóg. A jeśli chcesz wejść do życia, przestrzegaj przykazań.
\m 
\v 18 I zapytał go: Których? Jezus odpowiedział: Nie będziesz zabijał, nie będziesz cudzołożył, nie będziesz kradł, nie będziesz mówił fałszywego świadectwa;
\m 
\v 19 Czcij swego ojca i matkę oraz będziesz miłował swego bliźniego jak samego siebie.
\m 
\v 20 Powiedział mu młodzieniec: Tego wszystkiego przestrzegałem od mojej młodości. Czego mi jeszcze brakuje?
\m 
\v 21 Jezus mu odpowiedział: Jeśli chcesz być doskonały, idź, sprzedaj, co posiadasz, i rozdaj ubogim, a będziesz miał skarb w niebie. Potem przyjdź i chodź za mną.
\m 
\v 22 Kiedy młodzieniec usłyszał te słowa, odszedł smutny, miał bowiem wiele dóbr.
\m 
\v 23 Wtedy Jezus powiedział swoim uczniom: Zaprawdę powiadam wam, że bogaty z trudnością wejdzie do królestwa niebieskiego.
\m 
\v 24 Mówię wam też: Łatwiej jest wielbłądowi przejść przez ucho igielne, niż bogatemu wejść do królestwa Bożego.
\m 
\v 25 Gdy jego uczniowie \add to\add* usłyszeli, zdumieli się bardzo i pytali: Któż więc może być zbawiony?
\m 
\v 26 A Jezus, spojrzawszy na nich, powiedział im: U ludzi to niemożliwe, lecz u Boga wszystko jest możliwe.
\m 
\v 27 Wtedy Piotr odezwał się do niego: Oto my opuściliśmy wszystko i poszliśmy za tobą. Cóż \add za\add* to będziemy mieli?
\m 
\v 28 A Jezus im powiedział: Zaprawdę powiadam wam, że przy odrodzeniu, gdy Syn Człowieczy zasiądzie na tronie swojej chwały, i wy, którzy poszliście za mną, zasiądziecie na dwunastu tronach, sądząc dwanaście pokoleń Izraela.
\m 
\v 29 I każdy, kto opuści domy, braci lub siostry, ojca lub matkę, żonę, dzieci lub pole dla mego imienia, stokroć więcej otrzyma i odziedziczy życie wieczne.
\m 
\v 30 A wielu pierwszych będzie ostatnimi, a ostatnich pierwszymi.
\c 20
\m 
\v 1 Królestwo niebieskie bowiem podobne jest do gospodarza, który wyszedł wczesnym rankiem, aby nająć robotników do swojej winnicy.
\m 
\v 2 I umówił się z robotnikami na grosz za dzień i posłał ich do winnicy.
\m 
\v 3 A wyszedłszy około godziny trzeciej, zobaczył innych, którzy stali bezczynnie na rynku;
\m 
\v 4 I powiedział do nich: Idźcie i wy do winnicy, a co będzie słuszne, dam wam. I poszli.
\m 
\v 5 Około godziny szóstej i dziewiątej wyszedł znowu i zrobił tak samo.
\m 
\v 6 Potem wyszedł około godziny jedenastej i znalazł innych, którzy stali bez zajęcia, i zapytał ich: Dlaczego tu bezczynnie stoicie cały dzień?
\m 
\v 7 Odpowiedzieli mu: Bo nikt nas nie najął. I powiedział im: Idźcie i wy do winnicy, a co będzie słuszne, otrzymacie.
\m 
\v 8 A gdy nastał wieczór, pan winnicy powiedział do swego zarządcy: Zwołaj robotników i wypłać im należność, zaczynając od ostatnich aż do pierwszych.
\m 
\v 9 Kiedy przyszli ci, którzy \add byli najęci\add* około godziny jedenastej, każdy z nich otrzymał po groszu.
\m 
\v 10 Gdy przyszli pierwsi, sądzili, że dostaną więcej, ale również każdy z nich otrzymał po groszu.
\m 
\v 11 A otrzymawszy, szemrali przeciwko gospodarzowi;
\m 
\v 12 Mówiąc: Ci ostatni jedną godzinę pracowali, a zrównałeś ich z nami, którzy znosiliśmy ciężar dnia i upał.
\m 
\v 13 A on odpowiedział jednemu z nich: Przyjacielu, nie robię ci krzywdy. Czyż nie umówiłeś się ze mną na grosz?
\m 
\v 14 Weź, co \add jest\add* twoje, i odejdź. Chcę bowiem temu ostatniemu dać tyle, co tobie.
\m 
\v 15 Czyż z tym, co moje, nie wolno mi robić, co chcę? Czy twoje oko jest złe dlatego, że ja jestem dobry?
\m 
\v 16 Tak to ostatni będą pierwszymi, a pierwsi ostatnimi. Wielu bowiem jest wezwanych, ale mało wybranych.
\m 
\v 17 A gdy Jezus szedł do Jerozolimy, w drodze wziął ze sobą na ubocze dwunastu uczniów i powiedział do nich:
\m 
\v 18 Oto idziemy do Jerozolimy, a Syn Człowieczy zostanie wydany naczelnym kapłanom i uczonym w Piśmie, a oni skażą go na śmierć.
\m 
\v 19 I wydadzą go poganom na pośmiewisko, ubiczowanie i ukrzyżowanie, ale trzeciego dnia zmartwychwstanie.
\m 
\v 20 Wtedy podeszła do niego matka synów Zebedeusza ze swoimi synami, oddając \add mu\add* pokłon i prosząc go o coś.
\m 
\v 21 A on ją zapytał: Czego chcesz? Odpowiedziała mu: Powiedz, aby ci dwaj moi synowie siedzieli jeden po twojej prawej, a drugi po lewej stronie w twoim królestwie.
\m 
\v 22 Ale Jezus odpowiedział: Nie wiecie, o co prosicie. Czy możecie pić kielich, który ja będę pił, i być ochrzczeni chrztem, którym ja się chrzczę? Odpowiedzieli mu: Możemy.
\m 
\v 23 Wtedy im powiedział: Mój kielich będziecie pić i chrztem, którym ja się chrzczę, będziecie ochrzczeni, ale nie do mnie należy danie miejsca po mojej prawej i lewej stronie, lecz \add będzie dane tym\add*, którym zostało przygotowane przez mojego Ojca.
\m 
\v 24 A gdy owych dziesięciu \add to\add* usłyszało, oburzyli się na tych dwóch braci.
\m 
\v 25 Ale Jezus przywołał ich \add do siebie\add* i powiedział: Wiecie, że władcy narodów panują nad nimi, a ci, którzy \add są\add* wielcy, sprawują swą władzę nad nimi.
\m 
\v 26 Lecz nie tak ma być wśród was, ale kto między wami chce być wielki, niech będzie waszym sługą.
\m 
\v 27 I kto wśród was chce być pierwszy, niech będzie waszym sługą.
\m 
\v 28 Tak jak Syn Człowieczy nie przyszedł, aby mu służono, ale aby służyć i oddać swoje życie na okup za wielu.
\m 
\v 29 A gdy wychodzili z Jerycha, szedł za nim wielki tłum.
\m 
\v 30 A oto dwaj ślepi, siedzący przy drodze, usłyszawszy, że Jezus przechodzi, zawołali: Zmiłuj się nad nami, Panie, Synu Dawida!
\m 
\v 31 Tłum surowo nakazywał im milczeć, lecz oni tym bardziej wołali: Zmiłuj się nad nami, Panie, Synu Dawida!
\m 
\v 32 Wtedy Jezus zatrzymał się, zawołał ich i zapytał: Co chcecie, abym dla was zrobił?
\m 
\v 33 Odpowiedzieli mu: Panie, aby się otworzyły nasze oczy.
\m 
\v 34 Wtedy Jezus ulitował się \add nad nimi\add*, dotknął ich oczu, a natychmiast odzyskali wzrok i poszli za nim.
\c 21
\m 
\v 1 A gdy się przybliżyli do Jerozolimy i przyszli do Betfage na Górę Oliwną, wtedy Jezus posłał dwóch uczniów;
\m 
\v 2 Mówiąc im: Idźcie do wsi, która jest przed wami, a zaraz znajdziecie uwiązaną oślicę i oślątko z nią. Odwiążcie \add je\add* i przyprowadźcie do mnie.
\m 
\v 3 A gdyby wam ktoś coś mówił, powiedzcie: Pan ich potrzebuje, a zaraz je puści.
\m 
\v 4 To wszystko się stało, aby się wypełniło, co zostało powiedziane przez proroka:
\m 
\v 5 Powiedzcie córce Syjonu: Oto twój król przychodzi do ciebie cichy, siedzący na ośle, na oślątku, źrebięciu oślicy.
\m 
\v 6 Poszli więc uczniowie i uczynili tak, jak im nakazał Jezus.
\m 
\v 7 Przyprowadzili oślicę i oślątko, położyli na nie swoje szaty i posadzili go na nich.
\m 
\v 8 A wielki tłum słał swoje szaty na drodze, inni zaś obcinali gałązki z drzew i kładli na drodze.
\m 
\v 9 A tłumy, które szły przed nim i za nim, wołały: Hosanna Synowi Dawida! Błogosławiony, który przychodzi w imieniu Pana! Hosanna na wysokościach!
\m 
\v 10 Kiedy wjechał do Jerozolimy, poruszyło się całe miasto i pytano: Któż to jest?
\m 
\v 11 A tłumy odpowiadały: To jest Jezus, prorok z Nazaretu w Galilei.
\m 
\v 12 Wtedy Jezus wszedł do świątyni Boga i wypędził wszystkich sprzedających i kupujących w świątyni; poprzewracał stoły wymieniających pieniądze i stołki sprzedających gołębie.
\m 
\v 13 I powiedział im: Jest napisane: Mój dom będzie nazwany domem modlitwy, a wy zrobiliście z niego jaskinię zbójców.
\m 
\v 14 Wtedy ślepi i chromi podeszli do niego w świątyni, a on ich uzdrowił.
\m 
\v 15 A gdy naczelni kapłani i uczeni w Piśmie zobaczyli cuda, które czynił, i dzieci wołające w świątyni: Hosanna Synowi Dawida, rozgniewali się.
\m 
\v 16 I zapytali go: Słyszysz, co one mówią? A Jezus im odpowiedział: Tak. Czy nigdy nie czytaliście: Przez usta niemowląt i ssących przygotowałeś \add sobie\add* chwałę?
\m 
\v 17 A opuściwszy ich, wyszedł z miasta do Betanii i tam przenocował.
\m 
\v 18 A wracając rano do miasta, poczuł głód.
\m 
\v 19 I widząc przy drodze drzewo figowe, podszedł do niego, ale nie znalazł na nim nic oprócz samych liści. I powiedział do niego: Niech się już nigdy nie rodzi z ciebie owoc. I drzewo figowe natychmiast uschło.
\m 
\v 20 A gdy uczniowie to zobaczyli, dziwili się, mówiąc: Jak szybko uschło to drzewo figowe!
\m 
\v 21 Wtedy Jezus im odpowiedział: Zaprawdę powiadam wam: Jeśli będziecie mieć wiarę i nie zwątpicie, nie tylko to, \add co się stało\add* z drzewem figowym, uczynicie, ale jeśli i tej górze powiecie: Podnieś się i rzuć się do morza, stanie się \add tak\add*.
\m 
\v 22 I wszystko, o cokolwiek poprosicie w modlitwie, wierząc, otrzymacie.
\m 
\v 23 A gdy przyszedł do świątyni i nauczał, podeszli do niego naczelni kapłani i starsi ludu, pytając: Jakim prawem to czynisz? I kto dał ci tę władzę?
\m 
\v 24 A Jezus im odpowiedział: I ja was spytam o pewną rzecz. Jeśli mi odpowiecie, i ja wam powiem, jakim prawem to czynię.
\m 
\v 25 Skąd pochodził chrzest Jana? Z nieba czy od ludzi? A oni zastanawiali się między sobą i mówili: Jeśli powiemy, że z nieba, zapyta nas: Czemu więc mu nie uwierzyliście?
\m 
\v 26 Jeśli zaś powiemy, że od ludzi – boimy się tłumu, bo wszyscy uważają Jana za proroka.
\m 
\v 27 Odpowiedzieli więc Jezusowi: Nie wiemy. On również im odpowiedział: I ja wam nie powiem, jakim prawem to czynię.
\m 
\v 28 Jak wam się wydaje? \add Pewien\add* człowiek miał dwóch synów. Podszedł do pierwszego i powiedział: Synu, idź, pracuj dziś w mojej winnicy.
\m 
\v 29 Ale on odpowiedział: Nie chcę. Lecz potem odczuł żal i poszedł.
\m 
\v 30 Podszedł do drugiego i powiedział to samo. On zaś odpowiedział: \add Idę\add*, panie. Ale nie poszedł.
\m 
\v 31 Który z tych dwóch wypełnił wolę ojca? Odpowiedzieli mu: Ten pierwszy. Jezus im powiedział: Zaprawdę powiadam wam, że celnicy i nierządnice wchodzą przed wami do królestwa Bożego.
\m 
\v 32 Przyszedł bowiem do was Jan drogą sprawiedliwości, a nie uwierzyliście mu, ale celnicy i nierządnice mu uwierzyli. A wy, chociaż \add to\add* widzieliście, nie odczuliście żalu, aby mu uwierzyć.
\m 
\v 33 Posłuchajcie innej przypowieści: Był pewien gospodarz, który założył winnicę. Ogrodził ją płotem, wykopał w niej prasę, zbudował wieżę i wydzierżawił ją rolnikom, i wyjechał.
\m 
\v 34 A gdy nadszedł czas \add zbiorów\add*, posłał swoje sługi do rolników, aby odebrali plony tej \add winnicy\add*.
\m 
\v 35 Lecz rolnicy schwytali jego sługi, jednego pobili, innego zabili, a jeszcze innego ukamienowali.
\m 
\v 36 Wtedy posłał inne sługi, więcej niż za pierwszym razem, ale postąpili z nimi tak samo.
\m 
\v 37 W końcu posłał do nich swego syna, mówiąc: Uszanują mego syna.
\m 
\v 38 Lecz rolnicy, gdy zobaczyli syna, mówili między sobą: To jest dziedzic. Chodźmy, zabijmy go, a posiądziemy jego dziedzictwo.
\m 
\v 39 I schwytali go, wyrzucili z winnicy i zabili.
\m 
\v 40 Gdy więc przyjdzie pan winnicy, co zrobi z tymi rolnikami?
\m 
\v 41 Odpowiedzieli mu: Złych srogo wytraci, a winnicę wydzierżawi innym rolnikom, którzy będą mu oddawać plony we właściwym czasie.
\m 
\v 42 Powiedział im Jezus: Czy nigdy nie czytaliście w Pismach: Kamień, który odrzucili budujący, stał się kamieniem węgielnym; Pan to sprawił i jest to cudowne w naszych oczach?
\m 
\v 43 Dlatego mówię wam: Królestwo Boże zostanie wam zabrane, a dane narodowi, który wyda jego owoce.
\m 
\v 44 A kto upadnie na ten kamień, rozbije się, na kogo zaś \add on\add* upadnie, zmiażdży go.
\m 
\v 45 Kiedy naczelni kapłani i faryzeusze usłyszeli jego przypowieści, domyślili się, że o nich mówił.
\m 
\v 46 I chcieli go schwytać, ale bali się tłumów, ponieważ uważały go za proroka.
\c 22
\m 
\v 1 A Jezus, odpowiadając, znowu mówił do nich w przypowieściach tymi słowy:
\m 
\v 2 Królestwo niebieskie podobne jest do króla, który wyprawił wesele swemu synowi.
\m 
\v 3 I posłał swe sługi, aby wezwali zaproszonych na wesele, ale oni nie chcieli przyjść.
\m 
\v 4 Ponownie posłał inne sługi, mówiąc: Powiedzcie zaproszonym: Oto przygotowałem moją ucztę, zabito moje woły i tuczne zwierzęta i wszystko jest gotowe. Chodźcie na wesele.
\m 
\v 5 Lecz oni zlekceważyli to i odeszli, jeden na swoje pole, a inny do swego kupiectwa;
\m 
\v 6 A inni schwytali jego sługi, znieważyli \add ich\add* i zabili.
\m 
\v 7 Gdy król to usłyszał, rozgniewał się, a posławszy swoje wojska, wytracił tych morderców i spalił ich miasto.
\m 
\v 8 Potem powiedział swoim sługom: Wesele wprawdzie jest gotowe, lecz zaproszeni nie byli godni.
\m 
\v 9 Idźcie więc na rozstaje dróg i zaproście na wesele wszystkich, których spotkacie.
\m 
\v 10 Wtedy słudzy ci wyszli na drogi i zgromadzili wszystkich, których spotkali, złych i dobrych. I \add sala\add* weselna napełniła się gośćmi.
\m 
\v 11 A gdy król wszedł, aby zobaczyć gości, ujrzał tam człowieka, który nie był ubrany w strój weselny.
\m 
\v 12 I zapytał go: Przyjacielu, jak tu wszedłeś, nie mając stroju weselnego? A on zaniemówił.
\m 
\v 13 Wtedy król powiedział sługom: Zwiążcie mu nogi i ręce, weźcie go i wrzućcie do ciemności zewnętrznych. Tam będzie płacz i zgrzytanie zębów.
\m 
\v 14 Wielu jest bowiem wezwanych, lecz mało wybranych.
\m 
\v 15 Wtedy faryzeusze odeszli i naradzali się, jak by go usidlić w mowie.
\m 
\v 16 I posłali do niego swoich uczniów \add wraz\add* z herodianami, którzy powiedzieli: Nauczycielu, wiemy, że jesteś prawdziwy i drogi Bożej w prawdzie nauczasz, i nie zważasz na nikogo. Nie oglądasz się bowiem na osobę ludzką.
\m 
\v 17 Powiedz nam więc, jak ci się wydaje: Czy wolno płacić podatek cesarzowi, czy nie?
\m 
\v 18 Ale Jezus poznał ich niegodziwość i powiedział: Czemu wystawiacie mnie na próbę, obłudnicy?
\m 
\v 19 Pokażcie mi monetę podatkową. I podali mu grosz.
\m 
\v 20 A on ich zapytał: Czyj to wizerunek i napis?
\m 
\v 21 Odpowiedzieli mu: Cesarza. Wtedy powiedział im: Oddajcie więc cesarzowi to, co należy do cesarza, a Bogu to, co należy do Boga.
\m 
\v 22 A gdy to usłyszeli, zdziwili się, zostawili go i odeszli.
\m 
\v 23 Tego dnia przyszli do niego saduceusze, którzy mówią, że nie ma zmartwychwstania, i pytali go:
\m 
\v 24 Nauczycielu, Mojżesz powiedział: Jeśli ktoś umrze, nie mając dzieci, to jego brat ma ożenić się z jego żoną i wzbudzić potomstwo swemu bratu.
\m 
\v 25 Było więc u nas siedmiu braci. Pierwszy ożenił się i umarł, a nie mając potomstwa, zostawił żonę swemu bratu.
\m 
\v 26 Podobnie drugi i trzeci, aż do siódmego.
\m 
\v 27 A w końcu po wszystkich umarła też ta kobieta.
\m 
\v 28 Żoną którego z tych siedmiu będzie więc przy zmartwychwstaniu? Gdyż wszyscy ją mieli \add za żonę\add*.
\m 
\v 29 A Jezus im odpowiedział: Błądzicie, nie znając Pisma ani mocy Boga.
\m 
\v 30 Przy zmartwychwstaniu bowiem ani nie będą się żenić, ani za mąż wychodzić, ale będą jak aniołowie Boga w niebie.
\m 
\v 31 A co do zmartwychwstania umarłych, czy nie czytaliście, co wam zostało powiedziane przez Boga:
\m 
\v 32 Ja jestem Bogiem Abrahama, Bogiem Izaaka i Bogiem Jakuba? Bóg nie jest Bogiem umarłych, ale żywych.
\m 
\v 33 A tłumy, słysząc to, zdumiewały się jego nauką.
\m 
\v 34 Lecz gdy faryzeusze usłyszeli, że zamknął usta saduceuszom, zeszli się razem.
\m 
\v 35 I jeden z nich, znawca prawa, wystawiając go na próbę, spytał:
\m 
\v 36 Nauczycielu, które przykazanie w prawie jest największe?
\m 
\v 37 A Jezus mu odpowiedział: Będziesz miłował Pana, swego Boga, całym swym sercem, całą swą duszą i całym swym umysłem.
\m 
\v 38 To jest pierwsze i największe przykazanie.
\m 
\v 39 A drugie jest do niego podobne: Będziesz miłował swego bliźniego jak samego siebie.
\m 
\v 40 Na tych dwóch przykazaniach opiera się całe Prawo i Prorocy.
\m 
\v 41 A gdy faryzeusze byli zebrani, Jezus ich zapytał:
\m 
\v 42 Co sądzicie o Chrystusie? Czyim jest synem? Odpowiedzieli mu: Dawida.
\m 
\v 43 I powiedział im: Jakże więc Dawid w Duchu nazywa go Panem, mówiąc:
\m 
\v 44 Powiedział Pan memu Panu: Siądź po mojej prawicy, aż położę twoich nieprzyjaciół jako podnóżek pod twoje stopy?
\m 
\v 45 Jeśli więc Dawid nazywa go Panem, to jakże może być jego synem?
\m 
\v 46 I nikt nie mógł mu odpowiedzieć ani słowa. Od tego też dnia nikt nie śmiał go więcej pytać.
\c 23
\m 
\v 1 Wtedy Jezus powiedział do tłumów i do swoich uczniów:
\m 
\v 2 Na katedrze Mojżesza zasiedli uczeni w Piśmie i faryzeusze.
\m 
\v 3 Czyńcie więc i przestrzegajcie wszystkiego, co nakazują wam przestrzegać, ale według ich uczynków nie postępujcie. Mówią bowiem, ale nie czynią.
\m 
\v 4 Bo wiążą brzemiona ciężkie i nie do uniesienia i kładą je na barki ludzi, lecz sami nie chcą ich ruszyć nawet palcem.
\m 
\v 5 A wszystkie swoje uczynki spełniają, aby ludzie ich widzieli. Poszerzają swoje filakterie i wydłużają frędzle swoich płaszczy.
\m 
\v 6 Kochają też pierwsze miejsca na ucztach i pierwsze krzesła w synagogach;
\m 
\v 7 I pozdrowienia na rynkach, i aby ludzie nazywali ich: Rabbi, Rabbi!
\m 
\v 8 Ale wy nie nazywajcie się Rabbi. Jeden bowiem jest wasz Mistrz, Chrystus, a wy wszyscy jesteście braćmi.
\m 
\v 9 I nikogo na ziemi nie nazywajcie waszym ojcem. Jeden bowiem jest wasz Ojciec, który jest w niebie.
\m 
\v 10 Niech też was nie nazywają mistrzami, gdyż jeden jest wasz Mistrz, Chrystus.
\m 
\v 11 Ale kto z was jest największy, będzie waszym sługą.
\m 
\v 12 Kto się wywyższa, będzie poniżony, a kto się poniża, będzie wywyższony.
\m 
\v 13 Lecz biada wam, uczeni w Piśmie i faryzeusze, obłudnicy, bo zamykacie królestwo niebieskie przed ludźmi. Sami bowiem tam nie wchodzicie ani wchodzącym nie pozwalacie wejść.
\m 
\v 14 Biada wam, uczeni w Piśmie i faryzeusze, obłudnicy, bo pożeracie domy wdów i dla pozoru odprawiacie długie modlitwy. Dlatego otrzymacie surowszy wyrok.
\m 
\v 15 Biada wam, uczeni w Piśmie i faryzeusze, obłudnicy, bo obchodzicie morza i lądy, aby pozyskać jednego współwyznawcę, a gdy się nim stanie, czynicie go synem piekła dwa razy takim jak wy sami.
\m 
\v 16 Biada wam, ślepi przewodnicy, którzy mówicie: Kto przysięga na świątynię, to nic nie znaczy, ale kto przysięga na złoto świątyni, jest związany \add przysięgą\add*.
\m 
\v 17 Głupi i ślepi! Cóż bowiem jest ważniejsze: złoto czy świątynia, która uświęca złoto?
\m 
\v 18 A kto przysięga na ołtarz, to nic nie znaczy, lecz kto przysięga na ofiarę, która jest na nim, jest związany \add przysięgą\add*.
\m 
\v 19 Głupi i ślepi! Cóż bowiem \add jest\add* ważniejsze: ofiara czy ołtarz, który uświęca ofiarę?
\m 
\v 20 Kto więc przysięga na ołtarz, przysięga na niego i na to wszystko, co na nim leży.
\m 
\v 21 A kto przysięga na świątynię, przysięga na nią i na tego, który w niej mieszka.
\m 
\v 22 I kto przysięga na niebo, przysięga na tron Boga i na tego, który na nim zasiada.
\m 
\v 23 Biada wam, uczeni w Piśmie i faryzeusze, obłudnicy, bo dajecie dziesięcinę z mięty, anyżu i kminku, a opuszczacie \add to, co\add* ważniejsze w prawie: sąd, miłosierdzie i wiarę. To należało czynić i tamtego nie zaniedbywać.
\m 
\v 24 Ślepi przewodnicy! Przecedzacie komara, a połykacie wielbłąda.
\m 
\v 25 Biada wam, uczeni w Piśmie i faryzeusze, obłudnicy, bo oczyszczacie kubek i misę z zewnątrz, a wewnątrz pełne są zdzierstwa i niepowściągliwości.
\m 
\v 26 Ślepy faryzeuszu, oczyść najpierw wnętrze kubka i misy, aby i to, co jest na zewnątrz, było czyste.
\m 
\v 27 Biada wam, uczeni w Piśmie i faryzeusze, obłudnicy, bo jesteście podobni do grobów pobielanych, które z zewnątrz wydają się piękne, ale wewnątrz pełne są kości umarłych i wszelkiej nieczystości.
\m 
\v 28 Tak i wy na zewnątrz wydajecie się ludziom sprawiedliwi, ale wewnątrz jesteście pełni obłudy i nieprawości.
\m 
\v 29 Biada wam, uczeni w Piśmie i faryzeusze, obłudnicy, bo budujecie grobowce proroków i zdobicie nagrobki sprawiedliwych;
\m 
\v 30 I mówicie: Gdybyśmy żyli za dni naszych ojców, nie bylibyśmy ich wspólnikami w \add przelewaniu\add* krwi proroków.
\m 
\v 31 A tak sami sobie wystawiacie świadectwo, że jesteście synami tych, którzy pozabijali proroków.
\m 
\v 32 I wy dopełnijcie miary waszych ojców!
\m 
\v 33 Węże, plemię żmijowe! Jakże będziecie mogli uniknąć potępienia ognia piekielnego?
\m 
\v 34 Dlatego ja posyłam do was proroków, mędrców i uczonych w Piśmie. \add Niektórych\add* z nich zabijecie i ukrzyżujecie, a niektórych ubiczujecie w waszych synagogach i będziecie ich prześladować od miasta do miasta;
\m 
\v 35 Aby spadła na was wszelka krew sprawiedliwa przelana na ziemi, od krwi sprawiedliwego Abla aż do krwi Zachariasza, syna Barachiasza, którego zabiliście między świątynią a ołtarzem.
\m 
\v 36 Zaprawdę powiadam wam: Spadnie to wszystko na to pokolenie.
\m 
\v 37 Jeruzalem, Jeruzalem, które zabijasz proroków i kamienujesz tych, którzy są do ciebie posłani! Ile razy chciałem zgromadzić twoje dzieci, tak jak kokoszka gromadzi swe kurczęta pod skrzydła, a nie chcieliście!
\m 
\v 38 Oto wasz dom zostanie wam pusty.
\m 
\v 39 Mówię wam bowiem: Odtąd nie ujrzycie mnie, aż powiecie: Błogosławiony, który przychodzi w imieniu Pana.
\c 24
\m 
\v 1 A Jezus wyszedł ze świątyni i oddalił się. I podeszli do niego jego uczniowie, aby pokazać mu zabudowania świątynne.
\m 
\v 2 Lecz Jezus powiedział do nich: Czyż nie widzicie tego wszystkiego? Zaprawdę powiadam wam, nie zostanie tu kamień na kamieniu, który by nie został zwalony.
\m 
\v 3 A gdy siedział na Górze Oliwnej, podeszli do niego uczniowie i pytali na osobności: Powiedz nam, kiedy się to stanie i jaki będzie znak twego przyjścia i końca świata?
\m 
\v 4 I odpowiedział im Jezus: Uważajcie, aby was ktoś nie zwiódł.
\m 
\v 5 Wielu bowiem przyjdzie pod moim imieniem, mówiąc: Ja jestem Chrystusem. I wielu zwiodą.
\m 
\v 6 Usłyszycie też o wojnach i pogłoski o wojnach. Uważajcie, abyście się nie trwożyli. Wszystko to bowiem musi się stać, ale \add to\add* jeszcze nie koniec.
\m 
\v 7 Powstanie bowiem naród przeciwko narodowi i królestwo przeciwko królestwu i będzie głód, zaraza i trzęsienia ziemi miejscami.
\m 
\v 8 Lecz to wszystko jest początkiem boleści.
\m 
\v 9 Wtedy wydadzą was na udrękę, będą was zabijać i będziecie znienawidzeni przez wszystkie narody z powodu mego imienia.
\m 
\v 10 A wówczas wielu się zgorszy, będą się wzajemnie wydawać i jedni drugich nienawidzić.
\m 
\v 11 Powstanie też wielu fałszywych proroków i wielu zwiodą.
\m 
\v 12 A ponieważ wzmoże się nieprawość, miłość wielu oziębnie.
\m 
\v 13 Lecz kto wytrwa aż do końca, ten będzie zbawiony.
\m 
\v 14 A ta ewangelia królestwa będzie głoszona po całym świecie na świadectwo wszystkim narodom. I wtedy przyjdzie koniec.
\m 
\v 15 Gdy więc zobaczycie obrzydliwość spustoszenia, o której mówił prorok Daniel, stojącą w miejscu świętym (kto czyta, niech rozumie);
\m 
\v 16 Wtedy ci, którzy \add będą\add* w Judei, niech uciekają w góry.
\m 
\v 17 Kto będzie na dachu, niech nie schodzi, aby coś zabrać ze swego domu.
\m 
\v 18 Kto zaś będzie w polu, niech nie wraca, aby wziąć swe szaty.
\m 
\v 19 A biada brzemiennym i karmiącym w tych dniach!
\m 
\v 20 Módlcie się więc, aby wasza ucieczka nie wypadła w zimie albo w szabat.
\m 
\v 21 Wtedy bowiem będzie wielki ucisk, jakiego nie było od początku świata aż dotąd ani nigdy nie będzie.
\m 
\v 22 A gdyby te dni nie były skrócone, żadne ciało nie byłoby zbawione. Ale ze względu na wybranych dni te będą skrócone.
\m 
\v 23 Jeśli wtedy ktoś wam powie: Oto tu jest Chrystus, albo: \add Jest\add* tam – nie wierzcie.
\m 
\v 24 Powstaną bowiem fałszywi Chrystusowie i fałszywi prorocy i będą czynić wielkie znaki i cuda, żeby zwieść, o ile można, nawet wybranych.
\m 
\v 25 Oto wam przepowiedziałem.
\m 
\v 26 Jeśli więc wam powiedzą: Oto jest na pustyni – nie wychodźcie; Oto wewnątrz domu – nie wierzcie.
\m 
\v 27 Jak bowiem błyskawica pojawia się na wschodzie i jest widoczna aż na zachodzie, tak będzie z przyjściem Syna Człowieczego.
\m 
\v 28 Bo gdzie jest padlina, tam się zgromadzą i orły.
\m 
\v 29 A zaraz po ucisku tych dni słońce się zaćmi i księżyc nie da swego blasku, gwiazdy będą spadać z nieba i moce niebieskie zostaną poruszone.
\m 
\v 30 Wówczas ukaże się na niebie znak Syna Człowieczego. Wtedy będą lamentować wszystkie ludy ziemi i ujrzą Syna Człowieczego przychodzącego na obłokach niebieskich z mocą i wielką chwałą.
\m 
\v 31 Pośle on swoich aniołów z potężnym głosem trąby i zgromadzą jego wybranych z czterech stron świata, od jednego krańca nieba aż do drugiego.
\m 
\v 32 A od drzewa figowego uczcie się przez podobieństwo: Gdy jego gałąź już staje się miękka i wypuszcza liście, poznajecie, że lato jest blisko.
\m 
\v 33 Tak i wy, gdy ujrzycie to wszystko, wiedzcie, że jest blisko, u drzwi.
\m 
\v 34 Zaprawdę powiadam wam: Nie przeminie to pokolenie, aż się to wszystko stanie.
\m 
\v 35 Niebo i ziemia przeminą, ale moje słowa nie przeminą.
\m 
\v 36 Lecz o tym dniu i godzinie nikt nie wie, nawet aniołowie niebiescy, tylko sam mój Ojciec.
\m 
\v 37 A jak było za dni Noego, tak będzie z przyjściem Syna Człowieczego.
\m 
\v 38 Jak bowiem za tych dni przed potopem jedli i pili, żenili się i za mąż wydawali aż do tego dnia, w którym Noe wszedł do arki;
\m 
\v 39 I nie spostrzegli się, aż przyszedł potop i zabrał wszystkich – tak będzie i z przyjściem Syna Człowieczego.
\m 
\v 40 Wtedy dwóch będzie w polu, jeden będzie wzięty, a drugi zostawiony.
\m 
\v 41 Dwie będą mleć na żarnach, jedna będzie wzięta, a druga zostawiona.
\m 
\v 42 Czuwajcie więc, ponieważ nie wiecie, o której godzinie wasz Pan przyjdzie.
\m 
\v 43 A to wiedzcie, że gdyby gospodarz wiedział, o jakiej porze ma przyjść złodziej, czuwałby i nie pozwoliłby włamać się do swego domu.
\m 
\v 44 Dlatego i wy bądźcie gotowi, bo Syn Człowieczy przyjdzie o godzinie, której się nie spodziewacie.
\m 
\v 45 Któż więc jest sługą wiernym i roztropnym, którego pan ustanowił nad swoją służbą, aby im dawał pokarm o \add właściwej\add* porze?
\m 
\v 46 Błogosławiony ten sługa, którego pan, gdy przyjdzie, zastanie tak czyniącego.
\m 
\v 47 Zaprawdę powiadam wam, że ustanowi go nad wszystkimi swymi dobrami.
\m 
\v 48 Lecz jeśli powie ten zły sługa w swoim sercu: Mój pan zwleka z przyjściem;
\m 
\v 49 I zacznie bić współsługi, jeść i pić z pijakami;
\m 
\v 50 Przyjdzie pan tego sługi w dniu, w którym się nie spodziewa, i o godzinie, której nie zna.
\m 
\v 51 Wtedy odłączy go i wyznaczy mu dział z obłudnikami. Tam będzie płacz i zgrzytanie zębów.
\c 25
\m 
\v 1 Wtedy królestwo niebieskie będzie podobne do dziesięciu dziewic, które wzięły swoje lampy i wyszły na spotkanie oblubieńca.
\m 
\v 2 Pięć z nich było mądrych, a pięć głupich.
\m 
\v 3 Te głupie, wziąwszy swoje lampy, nie wzięły ze sobą oliwy.
\m 
\v 4 Lecz mądre wraz z lampami zabrały oliwę w naczyniach.
\m 
\v 5 A gdy oblubieniec zwlekał \add z przyjściem\add*, wszystkie zmorzył sen i zasnęły.
\m 
\v 6 O północy zaś rozległ się krzyk: Oblubieniec idzie, wyjdźcie mu na spotkanie!
\m 
\v 7 Wtedy wstały wszystkie te dziewice i przygotowały swoje lampy.
\m 
\v 8 A głupie powiedziały do mądrych: Dajcie nam ze swej oliwy, bo nasze lampy gasną.
\m 
\v 9 I odpowiedziały mądre: \add Nie damy\add*, bo mogłoby i nam, i wam nie wystarczyć. Idźcie raczej do sprzedawców i kupcie sobie.
\m 
\v 10 A gdy odeszły kupić, nadszedł oblubieniec. Te, które były gotowe, weszły z nim na wesele i zamknięto drzwi.
\m 
\v 11 Potem przyszły też pozostałe dziewice i powiedziały: Panie, Panie, otwórz nam!
\m 
\v 12 Lecz on odpowiedział: Zaprawdę powiadam wam, nie znam was.
\m 
\v 13 Czuwajcie więc, bo nie znacie dnia ani godziny, o której Syn Człowieczy przyjdzie.
\m 
\v 14 \add Królestwo niebieskie\add* bowiem podobne \add jest\add* do człowieka, który odjeżdżając, zwołał swoje sługi i powierzył im swoje dobra.
\m 
\v 15 Jednemu dał pięć talentów, drugiemu dwa, a trzeciemu jeden, każdemu według jego zdolności, i zaraz odjechał.
\m 
\v 16 A ten, który otrzymał pięć talentów, poszedł, obracał nimi i zyskał drugie pięć talentów.
\m 
\v 17 Tak samo i ten, który \add otrzymał\add* dwa, zyskał drugie dwa.
\m 
\v 18 Ten zaś, który otrzymał jeden, poszedł, wykopał \add dół\add* w ziemi i ukrył pieniądze swego pana.
\m 
\v 19 A po dłuższym czasie przybył pan tych sług i \add zaczął\add* się z nimi rozliczać.
\m 
\v 20 Wówczas przyszedł ten, który otrzymał pięć talentów, przyniósł drugie pięć talentów i powiedział: Panie, powierzyłeś mi pięć talentów, oto drugie pięć talentów zyskałem.
\m 
\v 21 I powiedział mu jego pan: Dobrze, sługo dobry i wierny! W niewielu rzeczach byłeś wierny, nad wieloma cię ustanowię. Wejdź do radości swego pana.
\m 
\v 22 Przyszedł i ten, który otrzymał dwa talenty i powiedział: Panie, powierzyłeś mi dwa talenty, oto drugie dwa talenty zyskałem.
\m 
\v 23 Powiedział mu jego pan: Dobrze, sługo dobry i wierny! Ponieważ byłeś wierny w niewielu \add rzeczach\add*, nad wieloma cię ustanowię. Wejdź do radości swego pana.
\m 
\v 24 Przyszedł i ten, który otrzymał jeden talent i powiedział: Panie, wiedziałem, że jesteś człowiekiem surowym: żniesz, gdzie nie posiałeś i zbierasz, gdzie nie rozsypałeś.
\m 
\v 25 Bojąc się więc, poszedłem i ukryłem twój talent w ziemi. Oto masz, co twoje.
\m 
\v 26 A jego pan mu odpowiedział: Sługo zły i leniwy! Wiedziałeś, że żnę, gdzie nie posiałem i zbieram, gdzie nie rozsypałem.
\m 
\v 27 Powinieneś więc był dać moje pieniądze bankierom, a ja po powrocie odebrałbym to, co moje, z zyskiem.
\m 
\v 28 Dlatego odbierzcie mu ten talent i dajcie temu, który ma dziesięć talentów.
\m 
\v 29 Każdemu bowiem, kto ma, będzie dane i będzie miał w obfitości. Temu zaś, kto nie ma, zostanie zabrane nawet to, co ma.
\m 
\v 30 A nieużytecznego sługę wrzućcie w ciemności zewnętrzne. Tam będzie płacz i zgrzytanie zębów.
\m 
\v 31 Gdy Syn Człowieczy przyjdzie w swojej chwale i wszyscy święci aniołowie z nim, wtedy zasiądzie na tronie swojej chwały.
\m 
\v 32 I będą zgromadzone przed nim wszystkie narody, a on odłączy jedne od drugich, jak pasterz odłącza owce od kozłów.
\m 
\v 33 I postawi owce po swojej prawej, a kozły po lewej stronie.
\m 
\v 34 Wtedy król powie do tych, którzy \add będą\add* po jego prawej stronie: Przyjdźcie, błogosławieni mego Ojca, odziedziczcie królestwo przygotowane dla was od założenia świata.
\m 
\v 35 Byłem bowiem głodny, a daliście mi jeść, byłem spragniony, a daliście mi pić, byłem obcym, a przyjęliście mnie;
\m 
\v 36 Byłem nagi, a ubraliście mnie, byłem chory, a odwiedziliście mnie, byłem w więzieniu, a przyszliście do mnie.
\m 
\v 37 Wtedy sprawiedliwi mu odpowiedzą: Panie, kiedy widzieliśmy cię głodnym i nakarmiliśmy \add cię\add* albo spragnionym i daliśmy \add ci\add* pić?
\m 
\v 38 I kiedy widzieliśmy cię obcym i przyjęliśmy \add cię\add* albo nagim i ubraliśmy cię?
\m 
\v 39 Albo kiedy widzieliśmy cię chorym lub w więzieniu i przyszliśmy do ciebie?
\m 
\v 40 A król im odpowie: Zaprawdę powiadam wam: To, co uczyniliście jednemu z tych moich braci najmniejszych, mnie uczyniliście.
\m 
\v 41 Potem powie i do tych, którzy \add będą\add* po lewej stronie: Idźcie ode mnie, przeklęci, w ogień wieczny, przygotowany dla diabła i jego aniołów.
\m 
\v 42 Byłem bowiem głodny, a nie daliście mi jeść, byłem spragniony, a nie daliście mi pić;
\m 
\v 43 Byłem obcym, a nie przyjęliście mnie, byłem nagi, a nie ubraliście mnie, byłem chory i w więzieniu, a nie odwiedziliście mnie.
\m 
\v 44 Wtedy i oni mu odpowiedzą: Panie, kiedy widzieliśmy cię głodnym albo spragnionym, albo obcym, albo nagim, albo chorym, albo w więzieniu, a nie usłużyliśmy tobie?
\m 
\v 45 Wówczas im odpowie: Zaprawdę powiadam wam, czego nie uczyniliście jednemu z tych najmniejszych, nie uczyniliście i mnie.
\m 
\v 46 I pójdą ci na męki wieczne, sprawiedliwi zaś do życia wiecznego.
\c 26
\m 
\v 1 A gdy Jezus dokończył tych wszystkich mów, powiedział do swoich uczniów:
\m 
\v 2 Wiecie, że za dwa dni będzie Pascha, a Syn Człowieczy zostanie wydany na ukrzyżowanie.
\m 
\v 3 Wtedy to naczelni kapłani, uczeni w Piśmie i starsi ludu zebrali się na dziedzińcu najwyższego kapłana, zwanego Kajfaszem;
\m 
\v 4 I naradzali się, jak by podstępnie schwytać i zabić Jezusa.
\m 
\v 5 Lecz mówili: Nie w święto, aby nie wywołać rozruchu wśród ludu.
\m 
\v 6 A gdy Jezus był w Betanii, w domu Szymona Trędowatego;
\m 
\v 7 Przyszła do niego kobieta, która miała alabastrowe naczynie bardzo drogiego olejku, i wylała go na jego głowę, gdy siedział przy stole.
\m 
\v 8 Widząc to, jego uczniowie oburzyli się i powiedzieli: I na cóż to marnotrawstwo?
\m 
\v 9 Przecież można było ten olejek drogo sprzedać, a \add pieniądze\add* rozdać ubogim.
\m 
\v 10 Gdy Jezus to zauważył, powiedział im: Dlaczego sprawiacie przykrość tej kobiecie? Przecież dobry uczynek spełniła wobec mnie.
\m 
\v 11 Ubogich bowiem zawsze macie u siebie, ale mnie nie zawsze mieć będziecie.
\m 
\v 12 Bo ona, wylewając ten olejek na moje ciało, zrobiła to, aby przygotować mnie na mój pogrzeb.
\m 
\v 13 Zaprawdę powiadam wam: Gdziekolwiek po całym świecie będzie głoszona ta ewangelia, będzie się też opowiadać na jej pamiątkę to, co zrobiła.
\m 
\v 14 Wtedy jeden z dwunastu, zwany Judaszem Iskariotą, poszedł do naczelnych kapłanów;
\m 
\v 15 I powiedział: Co chcecie mi dać, a ja wam go wydam. A oni wyznaczyli mu trzydzieści srebrników.
\m 
\v 16 I odtąd szukał sposobności, aby go wydać.
\m 
\v 17 W pierwszy dzień Przaśników uczniowie podeszli do Jezusa i zapytali go: Gdzie chcesz, abyśmy przygotowali ci Paschę do spożycia?
\m 
\v 18 A on odpowiedział: Idźcie do miasta, do pewnego \add człowieka\add* i powiedzcie mu: Nauczyciel mówi: Mój czas jest bliski; u ciebie będę obchodził Paschę z moimi uczniami.
\m 
\v 19 Uczniowie zrobili tak, jak im nakazał Jezus, i przygotowali Paschę.
\m 
\v 20 Kiedy nastał wieczór, usiadł \add za stołem\add* z dwunastoma.
\m 
\v 21 A gdy jedli, powiedział: Zaprawdę powiadam wam, że jeden z was mnie wyda.
\m 
\v 22 I bardzo zasmuceni zaczęli pytać jeden po drugim: Czy to ja, Panie?
\m 
\v 23 A on odpowiedział: Ten, który macza ze mną rękę w misie, on mnie wyda.
\m 
\v 24 Syn Człowieczy odchodzi, jak jest o nim napisane, ale biada człowiekowi, przez którego Syn Człowieczy będzie wydany! Lepiej byłoby dla tego człowieka, aby się nie urodził.
\m 
\v 25 Wtedy Judasz, który go zdradził, zapytał: Czy to ja, Mistrzu? Odpowiedział mu: Ty \add sam to\add* powiedziałeś.
\m 
\v 26 A gdy jedli, Jezus wziął chleb, pobłogosławił, połamał i dał uczniom, mówiąc: Bierzcie, jedzcie, to jest moje ciało.
\m 
\v 27 Potem wziął kielich, złożył dziękczynienie i dał im, mówiąc: Pijcie z niego wszyscy;
\m 
\v 28 To bowiem jest moja krew nowego testamentu, która wylewa się za wielu na przebaczenie grzechów.
\m 
\v 29 Ale mówię wam: Odtąd nie będę pił z tego owocu winorośli aż do dnia, gdy go będę pił z wami nowy w królestwie mego Ojca.
\m 
\v 30 A gdy zaśpiewali hymn, wyszli ku Górze Oliwnej.
\m 
\v 31 Wtedy Jezus powiedział do nich: Wy wszyscy zgorszycie się z mojego powodu tej nocy. Jest bowiem napisane: Uderzę pasterza i rozproszą się owce stada.
\m 
\v 32 Lecz gdy zmartwychwstanę, udam się do Galilei przed wami.
\m 
\v 33 A Piotr odezwał się do niego: Choćby się wszyscy zgorszyli z twojego powodu, ja się nigdy nie zgorszę.
\m 
\v 34 Powiedział mu Jezus: Zaprawdę powiadam ci, że tej nocy, zanim kogut zapieje, trzy razy się mnie wyprzesz.
\m 
\v 35 Odpowiedział mu Piotr: Choćbym miał z tobą umrzeć, nie wyprę się ciebie. Podobnie mówili wszyscy uczniowie.
\m 
\v 36 Wtedy Jezus przyszedł z nimi na miejsce zwane Getsemani i powiedział do uczniów: Siądźcie tu, a ja tymczasem odejdę tam i będę się modlił.
\m 
\v 37 A wziąwszy ze sobą Piotra i dwóch synów Zebedeusza, zaczął się smucić i odczuwać udrękę.
\m 
\v 38 Wtedy \add Jezus\add* powiedział do nich: Smutna jest moja dusza aż do śmierci. Zostańcie tu i czuwajcie ze mną.
\m 
\v 39 A odszedłszy trochę dalej, upadł na twarz i modlił się, mówiąc: Mój Ojcze, jeśli to możliwe, niech mnie ominie ten kielich. Jednak \add niech się stanie\add* nie jak ja chcę, ale jak ty.
\m 
\v 40 Potem przyszedł do uczniów i zastał ich śpiących, i powiedział do Piotra: Czy nie mogliście przez jedną godzinę czuwać ze mną?
\m 
\v 41 Czuwajcie i módlcie się, abyście nie ulegli pokusie. Duch wprawdzie jest ochoczy, ale ciało słabe.
\m 
\v 42 Znowu, po raz drugi odszedł i modlił się, mówiąc: Mój Ojcze, jeśli ten kielich nie może mnie minąć, tylko abym go wypił, niech się stanie twoja wola.
\m 
\v 43 A gdy przyszedł, znowu zastał ich śpiących, bo oczy same im się zamykały.
\m 
\v 44 I zostawiwszy ich, odszedł znowu i modlił się po raz trzeci tymi samymi słowami.
\m 
\v 45 Potem przyszedł do swoich uczniów i powiedział do nich: Śpijcie jeszcze i odpoczywajcie. Oto nadchodzi godzina i Syn Człowieczy będzie wydany w ręce grzeszników.
\m 
\v 46 Wstańcie, chodźmy! Oto zbliża się ten, który mnie wyda.
\m 
\v 47 A gdy on jeszcze mówił, nadszedł Judasz, jeden z dwunastu, a z nim liczny tłum z mieczami i kijami, od naczelnych kapłanów i starszych ludu.
\m 
\v 48 Ten zaś, który go zdradził, ustalił z nimi znak, mówiąc: Ten, którego pocałuję, to on. Schwytajcie go.
\m 
\v 49 Zaraz też podszedł do Jezusa i powiedział: Witaj, Mistrzu! I pocałował go.
\m 
\v 50 Jezus powiedział do niego: Przyjacielu, po co przyszedłeś? Wtedy podeszli, rzucili się na Jezusa i schwytali go.
\m 
\v 51 A oto jeden z tych, \add którzy\add* byli z Jezusem, wyciągnął rękę i dobył miecz, a uderzywszy sługę najwyższego kapłana, odciął mu ucho.
\m 
\v 52 Wtedy Jezus powiedział do niego: Schowaj miecz na swoje miejsce. Wszyscy bowiem, którzy za miecz chwytają, od miecza zginą.
\m 
\v 53 Czy sądzisz, że nie mógłbym teraz prosić mego Ojca, a wystawiłby mi więcej niż dwanaście legionów aniołów?
\m 
\v 54 Ale jakże wypełniłyby się Pisma, \add które mówią\add*, że musi się tak stać?
\m 
\v 55 W tym momencie Jezus powiedział do tłumów: Wyszliście jak na bandytę z mieczami i kijami, aby mnie schwytać. Codziennie siadałem z wami, nauczając w świątyni, a nie schwytaliście mnie.
\m 
\v 56 Ale to wszystko się stało, aby się wypełniły Pisma proroków. Wtedy wszyscy uczniowie opuścili go i uciekli.
\m 
\v 57 A ci, którzy schwytali Jezusa, zaprowadzili go do Kajfasza, najwyższego kapłana, gdzie zebrali się uczeni w Piśmie i starsi.
\m 
\v 58 Piotr zaś szedł za nim z daleka aż do dziedzińca najwyższego kapłana i wszedłszy tam, siedział ze sługami, aby zobaczyć, jak to się skończy.
\m 
\v 59 Tymczasem naczelni kapłani, starsi i cała Rada szukali fałszywego świadectwa przeciwko Jezusowi, aby go skazać na śmierć;
\m 
\v 60 Lecz nie znaleźli. I chociaż przychodziło wielu fałszywych świadków, \add jednak niczego\add* nie znaleźli. A na koniec wystąpili dwaj fałszywi świadkowie;
\m 
\v 61 Mówiąc: On powiedział: Mogę zburzyć świątynię Bożą i w trzy dni ją odbudować.
\m 
\v 62 Wtedy najwyższy kapłan powstał i zapytał go: Nic nie odpowiadasz? \add Cóż znaczy to\add*, co oni przeciwko tobie zeznają?
\m 
\v 63 Lecz Jezus milczał. A najwyższy kapłan powiedział mu: Zaklinam cię na Boga żywego, abyś nam powiedział, czy ty jesteś Chrystusem, Synem Bożym?
\m 
\v 64 Odpowiedział mu Jezus: Ty powiedziałeś. Ale mówię wam: Odtąd ujrzycie Syna Człowieczego siedzącego po prawicy mocy \add Boga\add* i przychodzącego na obłokach niebieskich.
\m 
\v 65 Wtedy najwyższy kapłan rozdarł swoje szaty i powiedział: Zbluźnił! Czyż potrzebujemy jeszcze świadków? Oto teraz słyszeliście bluźnierstwo.
\m 
\v 66 Jak wam się zdaje? A oni odpowiedzieli: Zasługuje na śmierć.
\m 
\v 67 Wówczas \add zaczęli\add* pluć mu w twarz i bili go pięściami, a inni go policzkowali;
\m 
\v 68 Mówiąc: Prorokuj nam, Chrystusie: Kto cię uderzył?
\m 
\v 69 Piotr zaś siedział na zewnątrz, na dziedzińcu. Podeszła do niego pewna dziewczyna i powiedziała: Ty też byłeś z Jezusem z Galilei.
\m 
\v 70 Lecz on wyparł się wobec wszystkich, mówiąc: Nie wiem, o czym mówisz.
\m 
\v 71 A gdy wyszedł do przedsionka, zobaczyła go inna \add dziewczyna\add* i powiedziała do tych, którzy tam byli: On też był z Jezusem z Nazaretu.
\m 
\v 72 I znowu wyparł się pod przysięgą: Nie znam tego człowieka.
\m 
\v 73 Po chwili ci, którzy tam stali, podeszli i powiedzieli do Piotra: Na pewno ty też jesteś \add jednym\add* z nich, bo i twoja mowa cię zdradza.
\m 
\v 74 Wtedy zaczął się zaklinać i przysięgać: Nie znam tego człowieka. I zaraz zapiał kogut.
\m 
\v 75 I przypomniał sobie Piotr słowa Jezusa, który mu powiedział: Zanim kogut zapieje, trzy razy się mnie wyprzesz. Wyszedł na zewnątrz i gorzko zapłakał.
\c 27
\m 
\v 1 A gdy nastał ranek, wszyscy naczelni kapłani i starsi ludu naradzili się przeciwko Jezusowi, aby go zabić.
\m 
\v 2 Związali go, odprowadzili i wydali namiestnikowi Poncjuszowi Piłatowi.
\m 
\v 3 Wtedy Judasz, który go wydał, widząc, że został skazany, żałował \add tego\add* i zwrócił trzydzieści srebrników naczelnym kapłanom i starszym;
\m 
\v 4 Mówiąc: Zgrzeszyłem, wydając krew niewinną. A oni powiedzieli: Cóż nam do tego? To twoja sprawa.
\m 
\v 5 Wtedy rzucił te srebrniki w świątyni i oddalił się, a \add potem\add* poszedł i powiesił się.
\m 
\v 6 A naczelni kapłani wzięli srebrniki i mówili: Nie wolno ich kłaść do skarbca świątynnego, gdyż jest to zapłata za krew.
\m 
\v 7 I naradziwszy się, kupili za nie pole garncarza, aby grzebać \add na nim\add* cudzoziemców.
\m 
\v 8 Dlatego to pole aż do dziś nazywa się Polem Krwi.
\m 
\v 9 Wtedy się wypełniło, co zostało powiedziane przez proroka Jeremiasza: I wzięli trzydzieści srebrników, zapłatę \add za\add* oszacowanego, którego oszacowali synowie Izraela;
\m 
\v 10 I dali je za pole garncarza, jak mi nakazał Pan.
\m 
\v 11 Jezus stał przed namiestnikiem. I zapytał go namiestnik: Czy ty jesteś królem Żydów? Jezus mu odpowiedział: Ty \add sam to\add* mówisz.
\m 
\v 12 A gdy oskarżali go naczelni kapłani i starsi, nic nie odpowiedział.
\m 
\v 13 Wtedy Piłat zapytał go: Nie słyszysz, jak wiele zeznają przeciwko tobie?
\m 
\v 14 Lecz mu nie odpowiedział na żadne słowo, tak że namiestnik bardzo się dziwił.
\m 
\v 15 A na święto namiestnik miał zwyczaj wypuszczać ludowi jednego więźnia, \add tego\add*, którego chcieli.
\m 
\v 16 Trzymano zaś w tym czasie osławionego więźnia, zwanego Barabaszem.
\m 
\v 17 Gdy więc się zebrali, zapytał ich Piłat: Którego chcecie, abym wam wypuścił? Barabasza czy Jezusa, zwanego Chrystusem?
\m 
\v 18 Wiedział bowiem, że wydali go z zawiści.
\m 
\v 19 A gdy on siedział na krześle \add sędziowskim\add*, jego żona posłała \add wiadomość\add* do niego: Nie miej nic do czynienia z tym sprawiedliwym, bo dzisiaj we śnie wiele wycierpiałam z jego powodu.
\m 
\v 20 Tymczasem naczelni kapłani i starsi namówili tłumy, aby prosiły o Barabasza, a \add domagały się\add* stracenia Jezusa.
\m 
\v 21 Namiestnik zapytał ich: Którego z tych dwóch chcecie, abym wam wypuścił? A oni odpowiedzieli: Barabasza.
\m 
\v 22 Piłat zapytał ich: Cóż więc mam zrobić z Jezusem, którego nazywają Chrystusem? Odpowiedzieli mu wszyscy: Niech będzie ukrzyżowany!
\m 
\v 23 Namiestnik zaś zapytał: Cóż właściwie złego uczynił? Lecz oni jeszcze głośniej wołali: Niech będzie ukrzyżowany!
\m 
\v 24 Gdy Piłat zobaczył, że nic nie osiąga, ale \add przeciwnie\add*, zamieszanie staje się większe, wziął wodę i umył ręce przed tłumem, mówiąc: Nie jestem winny krwi tego sprawiedliwego. To wasza sprawa.
\m 
\v 25 A cały lud odpowiedział: Krew jego na nas i na nasze dzieci.
\m 
\v 26 Wtedy wypuścił im Barabasza, a Jezusa, po ubiczowaniu, wydał na ukrzyżowanie.
\m 
\v 27 Wówczas żołnierze namiestnika zaprowadzili Jezusa na ratusz i zebrali wokół niego cały oddział.
\m 
\v 28 A rozebrawszy go, ubrali go w szkarłatny płaszcz.
\m 
\v 29 Upletli koronę z cierni i włożyli mu na głowę, a w prawą rękę \add dali\add* trzcinę. I padając przed nim na kolana, naśmiewali się z niego, mówiąc: Witaj, królu Żydów!
\m 
\v 30 A plując na niego, brali tę trzcinę i bili go po głowie.
\m 
\v 31 Kiedy go wyszydzili, zdjęli z niego płaszcz, ubrali go w jego szaty i odprowadzili na ukrzyżowanie.
\m 
\v 32 A wychodząc, spotkali człowieka z Cyreny, imieniem Szymon. Tego przymusili, aby niósł jego krzyż.
\m 
\v 33 Gdy przyszli na miejsce zwane Golgotą, czyli Miejscem Czaszki;
\m 
\v 34 Dali mu do picia ocet zmieszany z żółcią. Skosztował, ale nie chciał pić.
\m 
\v 35 A gdy go ukrzyżowali, rozdzielili jego szaty i rzucali losy, aby się wypełniło, co zostało powiedziane przez proroka: Rozdzielili między siebie moje szaty, a o moje ubranie rzucali losy.
\m 
\v 36 A siedząc, tam go pilnowali.
\m 
\v 37 I umieścili nad jego głową napis z podaniem jego winy: To jest Jezus, król Żydów.
\m 
\v 38 Ukrzyżowano też z nim dwóch bandytów, jednego po prawej, a drugiego po lewej stronie.
\m 
\v 39 A ci, którzy przechodzili obok, bluźnili mu, kiwając głowami;
\m 
\v 40 I mówiąc: Ty, który burzysz świątynię i w trzy dni \add ją\add* odbudowujesz, ratuj samego siebie. Jeśli jesteś Synem Bożym, zejdź z krzyża.
\m 
\v 41 Podobnie naczelni kapłani z uczonymi w Piśmie i starszymi, naśmiewając się, mówili:
\m 
\v 42 Innych ratował, a samego siebie uratować nie może. Jeśli jest królem Izraela, niech teraz zejdzie z krzyża, a uwierzymy mu.
\m 
\v 43 Ufał Bogu, niech go teraz wybawi, jeśli go sobie upodobał. Przecież powiedział: Jestem Synem Bożym.
\m 
\v 44 Tak samo urągali mu też bandyci, którzy byli z nim ukrzyżowani.
\m 
\v 45 A od godziny szóstej aż do dziewiątej ciemność ogarnęła całą ziemię.
\m 
\v 46 Około godziny dziewiątej Jezus zawołał donośnym głosem: Eli, Eli, lama sabachthani? To znaczy: Boże mój, Boże mój, czemu mnie opuściłeś?
\m 
\v 47 Wtedy niektórzy z tych, co tam stali, usłyszawszy to, mówili: On woła Eliasza.
\m 
\v 48 I zaraz jeden z nich podbiegł, wziął gąbkę i napełnił ją octem, a włożywszy na trzcinę, dał mu pić.
\m 
\v 49 Lecz inni mówili: Przestań, zobaczmy, czy przyjdzie Eliasz, aby go wybawić.
\m 
\v 50 Jezus zaś zawołał ponownie donośnym głosem i oddał ducha.
\m 
\v 51 A oto zasłona świątyni rozerwała się na pół, od góry aż do dołu, ziemia się zatrzęsła i skały popękały.
\m 
\v 52 Grobowce się otworzyły, a wiele ciał świętych, którzy zasnęli, powstało.
\m 
\v 53 I wyszli z grobów po jego zmartwychwstaniu, weszli do miasta świętego i ukazali się wielu.
\m 
\v 54 Wtedy setnik i ci, którzy z nim pilnowali Jezusa, widząc trzęsienie ziemi i to, co się działo, bardzo się zlękli i powiedzieli: On prawdziwie był Synem Bożym.
\m 
\v 55 A było tam wiele kobiet, które przypatrywały się z daleka. Szły one za Jezusem od Galilei i usługiwały mu.
\m 
\v 56 Wśród nich były: Maria Magdalena, Maria, matka Jakuba i Józefa, oraz matka synów Zebedeusza.
\m 
\v 57 A gdy nastał wieczór, przyszedł bogaty człowiek z Arymatei, imieniem Józef, który też był uczniem Jezusa.
\m 
\v 58 Udał się on do Piłata i poprosił o ciało Jezusa. Wtedy Piłat rozkazał, aby \add mu\add* je wydano.
\m 
\v 59 A Józef zabrał ciało, owinął je w czyste płótno;
\m 
\v 60 I złożył w swoim nowym grobowcu, który wykuł w skale. Przed wejście do grobowca zatoczył wielki kamień i odszedł.
\m 
\v 61 A Maria Magdalena i druga Maria siedziały tam naprzeciw grobowca.
\m 
\v 62 Następnego dnia, \add pierwszego\add* po \add dniu\add* przygotowania, naczelni kapłani i faryzeusze zebrali się u Piłata;
\m 
\v 63 I oznajmili: Panie, przypomnieliśmy sobie, że ten zwodziciel powiedział, gdy jeszcze żył: Po trzech dniach zmartwychwstanę.
\m 
\v 64 Rozkaż więc zabezpieczyć grobowiec aż do trzeciego dnia, by przypadkiem jego uczniowie nie przyszli w nocy, nie wykradli go i nie powiedzieli ludowi: Powstał z martwych. I ostatni błąd będzie gorszy niż pierwszy.
\m 
\v 65 Piłat powiedział im: Macie straż. Idźcie, zabezpieczcie, jak umiecie.
\m 
\v 66 Poszli więc i zabezpieczyli grobowiec, pieczętując kamień i stawiając straż.
\c 28
\m 
\v 1 A gdy skończył się szabat i świtało pierwszego \add dnia\add* tygodnia, Maria Magdalena i druga Maria przyszły obejrzeć grób.
\m 
\v 2 A oto powstało wielkie trzęsienie ziemi. Anioł Pana bowiem, zstąpiwszy z nieba, podszedł, odwalił kamień od wejścia i usiadł na nim.
\m 
\v 3 Jego oblicze było jak błyskawica, a jego szaty białe jak śnieg.
\m 
\v 4 A strażnicy drżeli ze strachu i stali się jak umarli.
\m 
\v 5 Anioł zaś powiedział do kobiet: Wy się nie bójcie! Wiem bowiem, że szukacie ukrzyżowanego Jezusa.
\m 
\v 6 Nie ma go tu. Powstał bowiem, jak powiedział. Chodźcie, zobaczcie miejsce, gdzie leżał Pan.
\m 
\v 7 Idźcie szybko i powiedzcie jego uczniom, że zmartwychwstał i oto udaje się do Galilei przed wami. Tam go ujrzycie. Oto wam powiedziałem.
\m 
\v 8 Odeszły więc szybko od grobu z bojaźnią i z wielką radością i pobiegły przekazać to jego uczniom.
\m 
\v 9 Kiedy szły przekazać to jego uczniom, nagle Jezus wyszedł im na spotkanie i powiedział: Witajcie! A one podeszły, objęły go za nogi i oddały mu pokłon.
\m 
\v 10 Wtedy Jezus powiedział do nich: Nie bójcie się! Idźcie, powiedzcie moim braciom, aby poszli do Galilei. Tam mnie ujrzą.
\m 
\v 11 A gdy one poszły, niektórzy ze straży przyszli do miasta i oznajmili naczelnym kapłanom wszystko, co się stało.
\m 
\v 12 Ci zaś zebrali się ze starszymi i naradziwszy się, dali żołnierzom sporo pieniędzy;
\m 
\v 13 I powiedzieli: Mówcie, że jego uczniowie przyszli w nocy i wykradli go, gdy spaliście.
\m 
\v 14 A gdyby to doszło do namiestnika, my go przekonamy, a wam zapewnimy bezpieczeństwo.
\m 
\v 15 Wzięli więc pieniądze i zrobili, jak ich pouczono. I rozniosła się ta wieść wśród Żydów, i trwa aż do dziś.
\m 
\v 16 Potem jedenastu uczniów poszło do Galilei na górę, na którą Jezus im polecił.
\m 
\v 17 A gdy go ujrzeli, oddali mu pokłon. Niektórzy jednak wątpili.
\m 
\v 18 Wtedy Jezus podszedł i powiedział do nich: Dana mi jest wszelka władza na niebie i na ziemi.
\m 
\v 19 Idźcie więc i nauczajcie wszystkie narody, chrzcząc je w imię Ojca i Syna, i Ducha Świętego;
\m 
\v 20 Ucząc je przestrzegać wszystkiego, co wam przykazałem. A oto ja jestem z wami przez wszystkie dni aż do końca świata. Amen. 
