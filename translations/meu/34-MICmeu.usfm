\id MIC .01, Micah 1, Motu, PNG, RTWP 12/92
\h MIKA
\toc1 MIKA
\toc2 MIKA
\mt1 MIKA
\c 1
\s1 Rohe-ahu Samaria bona Ierusalem latadiai
\p 
\v 1 Iehova ena hereva, Mika, tau Moresete, enai e kau, Iuda pavapavadia Iotam bona Ahasa bona Hesekia edia nega ai, Samaria bona Ierusalem herevadia.
\q1 
\v 2 Taunimanima iboumui ai, a kamonai;
\q2 tanobada mai lalona ḡaudia iboudiai ida, a hakala;
\q1 Ḡaubada Iehova ese baine habadelaimw,
\q2 Ḡaubada ese ena dubu helaḡana amo.
\q1 
\v 3 Badina be, a itaia, Iehova na ena gabu amo e raka lasimu,
\q2 ia na baine diho, tanobada ena atai gabudia baine moimoilaidia.
\q1 
\v 4 Ia henunai ororo bae veve,
\q2 bona koura bae parara,
\q1 \it wax\it* lahi vairanai na heto,
\q2 ranu haga amo e hebubu dobimu na heto.
\q1 
\v 5 Ina idoinai na Iakob ena kerere dainai,
\q2 Israel besena ena kara dika dainai.
\q1 Iakob ena kerere be dahaka?
\q2 Ena kerere na Samaria ani?
\q1 Bona Iuda besena ena kara dika be dahaka?
\q2 Ena kara dika na Ierusalem ani?
\q1 
\v 6 Taunabunai, lau ese Samaria baina hasenua tano paka ai,
\q2 vine imeadia ihadodia gabuna ai baina halaoa;
\q1 ena nadi na koura ai baina bubudia dobi,
\q2 ena badi nadidia baina hulalai.
\q1 
\v 7 Ena dirava laulaudia iboudiai bae huaridia patapata,
\q2 ena ariara karadia davadia iboudiai na lahi ese baine goledia oho;
\q2 ena kaivakuku iboudiai na lau ese baina habuadia tari;
\q1 badina be lebulebu hahinena ahuna amo e haboudia,
\q2 bena lebulebu hahinena ahuna ai ma baela.
\b
\q1 
\v 8 Ina dainai baina rohe ahu, baina tai lolololo;
\q2 egu dabua baina doki oho, gagaegu ai bainala;
\q1 uda sisiadia na heheto baina tai lolololo,
\q2 kokokoko na heheto baina tai badabada.
\q1 
\v 9 Badina be ia berona na basie hanamoa diba;
\q2 Iuda ai vada e kau,
\q1 egu bese taudia edia ikoukou ai vada e kau,
\q2 Ierusalem ai vada e kau.
\q1 
\v 10 Gata al basio herevalaia,
\q2 basio tai;
\q1 Bete-le-afra ai
\q2 ḡahu ai ba hekui-hekui.
\q1 
\v 11 Safiri taumui e,
\q2 emui dala ai ba raka lao,
\q2 ḡaḡaemui ai, mai hemaraimui ida.
\q1 Saanan taudia na
\q2 asie raka lasimu;
\q1 Bet-esele ena taitai ese
\q2 ena gini gabuna na emui amo baine abia oho.
\q1 
\v 12 Maroto taudia ese namo e nariamu,
\q2 mai kudou-hetahadia ida;
\q1 badina be dika na Iehova ena amo vada e diho,
\q2 Ierusalem ikoukouna enai.
\q1 
\v 13 Lakisi taumui e,
\q2 hosi na kariota ai ba guidia;
\q1 umui na kara dika matamana
\q2 Siona natuna kekenina enai,
\q1 badina be umui lalomui ai
\q2 Israel ena kerere e davaridia.
\q1 
\v 14 Taunabunai hahetoni herahiadia na
\q2 Moresete-gata ba henia;
\q1 Aksib rumadia na koikoi ḡaudia ai baela
\q2 Israel pavapavadia ediai.
\q1 
\v 15 Maresa inoholaina taumui e,
\q2 kwalimu tauna na ihadareremui totona ma baina mailaia;
\q1 Israel hairaina na
\q2 Adulama enai baine kau.
\q1 
\v 16 Kwaramui ba nau, huimui ba utu,
\q2 emui lalokau memerodia daidiai;
\q1 kwaramui ba nau, ugava kwaradia na heheto,
\q2 badina be natumui na emui amo bae raka oho,
\q2 gabu daudauna ai bae hanohodia.
\c 2
\s1 Hahehisi taudia herevadia
\q1 
\v 1 Kara havara e lalo hatamu,
\q1 bona kara dika daladia na edia mahuta patadia ai e haeromu taudia,
\q2 madi ihabaidia!
\q1 Daba e reremu ai, e karaiamu,
\q2 badina be una na imodia lalodiai.
\q1 
\v 2 Biru tanodia e hekise-hekise henidiamu, bena e dadidiamu,
\q2 ruma danu, bena e abidia ohomu;
\q1 tau ta mai ena ruma ida,
\q2 tau ta mai ahuna ida, e hahisihisidiamu.
\q1 
\v 3 Taunabunai Iehova ini e gwau tomamu:
\q2 A itaia, ina iduhu ihadikana dalana na laloa hatamu,
\q2 aiomui na ia metauna henuna amo basio abidia oho diba;
\q1 bena basio raka mai hekokorokumui,
\q2 badina be nega na baine dika.
\q1 
\v 4 Una dina ai ehona na latamui ai bae kurea lao kurea lao,
\q2 edia rohe-ahu ai bae tai lolololo,
\q1 baeto “Ai na vada a dika vaitani;
\q2 ia ese egu bese ahuna e ha-idauamu,
\q2 egu amo e abia ohomu.
\q1 Ia ese emai biru tanodia na
\q2 e guimai taudia e henidia hagau-hagaumu”.
\q1 
\v 5 Taunabunai, Iehova ena hebou taudia bogaragidiai,
\q2 tau ta basine noho,
\q2 tano hetoana na mari amo basine davaria.
\b
\q1 
\v 6 Idia na e gwaugwaumu, “Basio haroro” e tomu;
\q2 “gau unuhetomadia basio harorolai;
\q2 ihahemaraida ḡaudia ese basie lasida tao”.
\q1 
\v 7 Iakob besena e, ini e gwau tomamu be namo eiava?
\q2 Iehova ena Lauma se haheaukamu a?
\q2 Ini na iena kara a?
\q1 Egu hereva ese raka maoromaoro tauna na
\q2 asie hanamoamu a?
\q1 
\v 8 A umui na o tore isimu, egu bese taudia o inai henidiamu;
\q2 maino taudia, heabidadama ai e raka hanaimu
\q1 bona tuari asie laloa hatamu taudia,
\q2 edia dabua o dabuidia ohomu.
\q1 
\v 9 Egu bese hahinedia na
\q2 edia ruma namodia amo o luludia lasimu;
\q1 bona natudia maraḡidia edia amo
\q2 lau hairaigu o abia oho vaitanimu.
\q1 
\v 10 A tore isi, baola;
\q2 badina be ina na dia laḡa-ani gabuna ta;
\q1 badina be hahemiro ese e habuaiamu,
\q2 e habuaia tarimu.
\q1 
\v 11 Tau ta bema loaeva-eva,
\q2 hereva asi anidia bona hereva koikoidia bema gwaurai,
\q1 bema toma “Vine ranuna bona inuinu ḡaudia goadadia
\q2 baina harorolai henimui”,
\q1 ia na bema heḡereḡere ina bese enai,
\q2 edia haroro tauna ai bema lao.
\q1 
\v 12 Iakob besena taumui e, momokani lau ese iboumui ai baina haboumui,
\q2 Israel taudia kwabukwabudia danu baina haboudia.
\q1 Baina gogodia,
\q2 mamoe na edia maḡu ai e hegogomu na heheto,
\q1 mamoe serina edia rei gabuna ai e nohomu na heto,
\q2 taunimanima hulumana, mai heloḡo-heloḡodia ida.
\q1 
\v 13 Maḡu ihamauruna tauna na idia vairadiai bainela,
\q2 bena bae tata uru, ikoukou amo bae hanai,
\q2 unu amo bae didi lasi.
\q1 Edia pavapava ese baine gunalaidia,
\q2 Iehova na mata ai bainela.
\c 3
\s1 Israel lothiadia ihabadedia
\q1 
\v 1 Bena lau nato: Iakob besena ikwarana taumui e!
\q1 Israel besena ilohiana taumui e!
\q2 Hahemaoro ḡoevaḡoeva ikarana boma diba ani?
\q1 
\v 2 Umui ese namo o inai heniamu,
\q2 bona dika o ura heniamu;
\q1 umui ese egu bese taudia kopidia o kopadia ohomu,
\q2 bona hidiodia na turiadia amo o vakadia ohomu;
\q1 
\v 3 umui ese egu bese taudia hidiodia o animu,
\q2 bona kopidia o kopadia ohomu,
\q1 bona turiadia o hakwaidudia rohorohomu,
\q2 bona o utudia sisisisimu,
\q1 vamu uro lalonai na heto,
\q2 hidio tohe lalonai na heto.
\b
\q1 
\v 4 Bena Iehova bae tai henia,
\q2 a ia ese basine haere henidia;
\q1 una negana ai vairana na edia amo baine hunia,
\q2 badina be idia na vada e kara dika.
\b
\q1 
\v 5 Peroveta taudia ese egu bese taudia na
\q2 e hakaudia kereremu;
\q1 adia e davariamu negana ai
\q2 e boiboimu, e tomu “Maino”,
\q1 a adia se henidiamu tauna na
\q2 e tuari heniamu.
\q1 Iehova ese unu e herevalaidia tomamu.
\q2 
\v 6 Taunabunai hanua baine boi emui ai,
\q2 basio mata hanai,
\q1 bona baine dibura emui ai,
\q2 asi bagu-haoro ḡauna.
\q1 Dina baine diho peroveta taudia latadiai,
\q2 dina baine dibura idia daediai;
\q1 
\v 7 mata-hanai taudia na bae hahemaraidia,
\q2 bagu-haoro taudia danu bae hahemaraidia;
\q1 iboudiai ese ududia bae tao ahu,
\q2 badina be asi haere ta Dirava ena amo.
\q1 
\v 8 A lau na siahu ai vada name honu,
\q2 Iehova ena Lauma ese vada e rohegu,
\q2 mai hahemaoro ḡoevaḡoevagu bona mai goadagu ida,
\q1 Iakob ena kerere bona Israel ena kara dika
\q2 ihahedinarai-henidia totona.
\b
\q1 
\v 9 Iakob besena ikwarana taumui e!
\q2 Israel besena ilohiana taumui e!
\q2 Ina na ba kamonai.
\q1 Umui ese hahemaoro ḡoevaḡoeva o inai heniamu,
\q2 bona ahu korikoridia iboudiai o hakererediamu.
\q1 
\v 10 Umui ese Siona o haginiamu rara amo,
\q2 bona Ierusalem kara dika amo.
\q1 
\v 11 Ikwarana taudia na hahemaoro e karaiamu,
\q2 koikoi henitaona dainai;
\q1 ena hahelaḡa taudia e hahedibamu, hevatu dainai;
\q2 ena peroveta taudia e bagu haoromu, moni dainai;
\q1 ḡau tamona, idia ese Iehova e abidadama heniamu, e tomu:
\q2 Iehova na ita bogaragida ani?
\q2 Dika ta na latadai basine kau.
\q1 
\v 12 Taunabunai, umui daimui ai Siona bae ruaia,
\q2 biru tanona na heto;
\q1 Ierusalem na vada e heḡiḡi dobi rumadia senudia ai bainela,
\q2 bona dubu ororona na uda ese baine udaia ahu.
\c 4
\s1 Iehova ena maino
\q1 
\v 1 Dina gabedia ai Iehova ena dubu ororona na
\q2 ororo atai-hereana ai baine hahelao,
\q2 ororo daediai baine heabi isi.
\q1 Taunimanima ese ia lalonai bae didi vareai,
\q2 
\v 2 bona bese momo baema, baeto:
\q1 Aoma, Iehova ena ororo ai baita dara dae,
\q2 Iakob ena Dirava ena dubu baita dae henia;
\q1 ia ese ena dala baine hadibalaida
\q2 bona iena dala ai baita raka helaoreana.
\q1 Badina be Siona lalona amo taravatu baine lasi,
\q2 bona Iehova ena hereva danu Ierusalem amo.
\q1 
\v 3 Ia ese taunimanima momo padadiai baine hahemaoro,
\q2 bona dauhai e nohomu besedia mai goadadia daidiai baine gwau maoro;
\q1 bena edia dare na ruarua isivadia bae karalaidia,
\q2 bona edia io na ilapa bae karalaidia;
\q1 bese ta ese dare basine abia isi, bese ta ituari-henina totona,
\q2 bona tuari daladia basie tahudia;
\q1 
\v 4 a ta ta ena vine auna ena vine auna bona ena suke auna ena suke auna
\q2 henudiai bae helai,
\q1 bona tau ta ese basine hagaridia;
\q2 badina be Iehova Sabaota na uduna amo vada e hereva.
\b
\q1 
\v 5 Badina be bese iboudiai na e rakamu,
\q2 ta ta ena dirava ladana ena dirava ladana ai;
\q1 a ita ese Iehova, eda Dirava, ladana ai baita raka,
\q2 ela bona hanaihanai.
\s1 Israel iruha-negena
\q1 
\v 6 Iehova na e tomu:
\q2 Una dina ai lau ese ae-hedairike taudia baina haboudia,
\q1 bona vada e luludia oho taudia ma baina gogodia,
\q2 bona vada na hahisihisidia taudia danu.
\q1 
\v 7 Ae-hedairike taudia na bese kwabukwabuna ai baina halaodia,
\q2 bona e negedia daure taudia na bese mai goadana ai baina halaodia;
\q1 bena Iehova ese baine lohiadia Siona ororona ai,
\q2 ina negana amo ela bona hanaihanai.
\b
\q1 
\v 8 Oi, mamoe serina igimana kohorona,
\q2 oi, Siona natuna kekenina ena ororo,
\q1 oi dekemu ai siahu gunana ma baine kau,
\q2 Ierusalem natuna kekenina ena basileia danu.
\b
\q1 
\v 9 Dahaka dainai harihari o tai lolololomu?
\q2 Oi na asi pavapavamu a?
\q1 Emu hahealo tauna vada e mase,
\q2 bena hisihisi ese e gugubamu
\q2 hekamonai hahinena na heto a?
\q1 
\v 10 Siona natuna kekenina e,
\q2 ba hehure-hehure, ba ḡanaḡana,
\q2 hekamonai hahinena na heto;
\q1 badina be hanua lalona amo ba raka lasi,
\q2 tano paka ai ba noho,
\q2 Babulono do baola.
\q1 Unuseni ai do bae rauamu,
\q2 unuseni ai Iehova ese oi inaimu imadia amo baine hamaurimu.
\b
\q1 
\v 11 Harihari bese momo e heboumu,
\q2 ituari-henimu totona;
\q1 idia na e tomu “Bae hamiroa,
\q2 bena matada ese Siona bae raraia tao”.
\q1 
\v 12 A idia na Iehova ena lalo-hadai asi dibadia,
\q2 ena lalo-hata ḡaudia asi dibadia;
\q1 asi dibadia ia ese vada e haboudia,
\q2 uit ikumidia na uit ikwadilaina gabuna ai e haboumu na heto.
\q1 
\v 13 Siona natuna kekenina e,
\q2 a tore isi, a kwadidia!
\q1 Badina be doamu na auri ai baina halaoa,
\q2 bona aemu na auri-laboralabora ai baina halaodia;
\q1 bese momo ba botadia patapata,
\q2 edia kohu na ba hahelagaia, Iehova ena,
\q2 edia taḡa na ba hahelaḡaia, tanobada idoinai Lohiana ena.
\c 5
\q1 
\v 1 Harihari vada e maḡumu ahu;
\q1 vada e kouda heḡege;
\q2 hebota auna amo
\q1 Israel lohiana vahana e botaiamu.
\s1 Hahemauri Tauna Betelehem amo
\q1 
\v 2 Betelehem Efrata e,
\q2 oi na maragi, Iuda iduhudia bogaragidiai,
\q1 to oiemu amo tau ta baine tore isi egu,
\q2 ia na Israel lohiana ai bainela;
\q1 ena hematama na nega gunana amo,
\q2 sene negadia amo.
\b
\q1 
\v 3 Taunabunai, ia ese baine rakatanidia,
\q2 ela bona hekamonai hahinena baine mara negana ai,
\q1 benil tadikakana orena bae lou mai
\q2 Israel taudia dekediai.
\q1 
\v 4 Bena ia na baine gini, ena mamoe serina baine ubua,
\q2 Iehova goadana ai,
\q2 Iehova, ena Dirava, ladana siahuna ai.
\q1 Idia na mai mainodia ida bae noho,
\q2 badina be ia na baine bada,
\q2 ela bona tanobada dokodia.
\b
\q1 
\v 5 Maino dalana binai,
\q2 Asuria tauna na eda kaha ai bainema,
\q2 bona eda tano baine moimoilaia negana ai:
\q1 ita ese mamoe ireḡudia taudia hahitu baita haginidia, ia ilao-ahuna,
\q2 bona hanua lohiadia taurahani danu.
\q1 
\v 6 Idia ese Asuria tanona bae lohiaia, dare amo;
\q2 bona Nimrod ena tano danu, ala-ala darena amo.
\q1 Idia ese Asuria tauna imana amo bae hamaurida,
\q2 eda kaha bainema, eda tano baine moimoilaia, negana ai.
\b
\q1 
\v 7 Bena Iakob taudia kwabukwabudia na
\q2 bese momo bogaragidiai bae noho,
\q1 hunu Iehova ena amo na heto,
\q2 medu batugu rei latanai na heto;
\q1 unu na asie halahemu, taunimanima daidiai,
\q2 taunimanima natudia asie naridiamu.
\q1 
\v 8 Iakob taudia kwabukwabudia na
\q2 basileia idau-idau bogaragidiai bae noho,
\q2 bese momo bogaragidiai bae noho,
\q1 leona uda boromadia bogaragidiai na heto,
\q2 leona natuna mamoe seridia bogaragidiai na heto;
\q1 e raka hanaimu negana ai,
\q2 e moi tao moi taomu,
\q1 e dare patapatamu,
\q2 asi tauna ta baine hahemauri.
\q1 
\v 9 Imamui na bae heabi isi, amui inai taudia daediai,
\q2 inaimui na bae henege daure.
\b
\q1 
\v 10 Iehova na e tomu: Una dina ai
\q2 emui hosi na baina aladia mase bogaragimui ai,
\q2 bona emui kariota baina hamakohidia rohoroho.
\q1 
\v 11 Emui tano hanuadia baina habuadia tari,
\q2 bona emui gabu aukadia iboudiai baina ḡiḡidia dobi;
\q1 
\v 12 mea ḡaudia na imamui ai baina hamakohidia,
\q2 emui rohe taudia na bae ore;
\q1 
\v 13 emui kaivakuku baina utudia gari,
\q2 bona emui au-tubua danu bogaragimui ai;
\q1 bena imamui amo e kara ḡaudia na
\q2 basio toma henidia diho lou;
\q1 
\v 14 emui au-tubua helaḡadia baina hagaridia bogaragimui ai,
\q2 bona emui hanua baina habuadia tari.
\q1 
\v 15 Mai badugu ida bona mai badu-ḡaraḡaragu ida,
\q2 lau ese dava baina kara,
\q2 asi edia kamonai besedia latadiai.
\c 6
\s1 Iehova ese Israel e gwau henia
\q1 
\v 1 Iehova ena hereva a kamonai:
\q2 A tore isi, ororo vairadiai emui gini-kau gabuna ba herevalaia,
\q2 ororo komutadia na gadomui bae kamonai.
\q1 
\v 2 Ororo e, Iehova ena gwau-gwau herevadia a kamonai,
\q2 tanobada badidia, o mia hanaihanaimu gabudia, danu a kamonai;
\q1 badina be Iehova ese ena bese taudia e gwau henidiamu,
\q2 ia ese Israel baine heai henia.
\b
\q1 
\v 3 Egu bese taumui e, ede vada na karamui toma?
\q2 Ede vada na hahisihisimui toma?
\q2 A haere henigu.
\q1 
\v 4 Badina be Aigupto tanona amo na hakaumui lasi,
\q2 iḡui rumana amo na hamaurimui;
\q1 Mose bona Aaron bona Miriama na
\q2 umui vairamui ai na siaidia guna.
\q1 
\v 5 Egu bese taumui e, ba laloa,
\q2 Balak, Moab pavapavana, ena lalo-hata be dahaka,
\q2 bona Balaam Beoro ese ede e haere henia toma,
\q1 bona Sitim ela bona Gilgal dahaka e vara;
\q2 bena Iehova ena hahemauri karadia ba diba.
\s1 Iehova ena ura
\q1 
\v 6 Dahaka baina mailai Iehova vairanai,
\q2 atai Diravana baina toma henia diho totona?
\q1 Ḡole-oho boubou ḡaudia ia vairanai baina mailaidia a?
\q2 Boromakau natudia, laḡani tamona ḡaudia, a?
\q1 
\v 7 Iehova ese nani mamaruanedia daha daha baine moalelaidia a?
\q2 Eiava dehoro sinavaidia gerebu gerebu a?
\q1 Natugu roboana baina heni, egu kerere davana, a?
\q2 tau-anigu amo e vara ḡauna baina heni, laumagu ena dika davana, a?
\q1 
\v 8 Taunimanima e, ia ese vada e hamaoromu, kara namona be dahaka,
\q2 Iehova ena ura oiemu ai be dahaka.
\q1 Ina mo: ba hahemaoro ḡoevaḡoeva, hebogahisi ba ura henia,
\q2 bona emu Dirava ida ba raka hebou mai manaumu ida, ani?
\b
\q1 
\v 9 Iehova gadona ese hanua e boi heniamu,
\q2 (oi ladamu igarilaina na aonega namona),
\q1 e tomu: Bese laumui boua hanua laumui e, a kamonai!
\q2 
\v 10 Kara dika kohudia, kara dika taudia edia ruma ai,
\q1 bona hahetoho koikoi karadia, e uduguiraidiamu gaudia,
\q2 baina lalodia boio diba a?
\q1 
\v 11 Mai ena hahetoho ḡauna dikana
\q2 bona ena hahetoho auridia koikoidia modana tauna na
\q2 maorona baina gwauraia a?
\q1 
\v 12 Emui taḡa taudia na daḡedaḡe ai e honumu;
\q2 emui hanua taudia na e hereva koikoimu,
\q2 maladia na mai koikoidia, ududia lalodiai.
\q1 
\v 13 Taunabunai lau ese vada na rahumui mase matama;
\q2 vada na habuamui, emui kara dika daidiai.
\q1 
\v 14 Bavaniani, a bogamui basie kunu,
\q2 tau-animui do bae hitolo;
\q1 ḡau bavato tabe, to basio gogo,
\q2 bona ba gogo ḡaudia na lau ese dare baina henia.
\q1 
\v 15 Ba hadohado, to basio ḡeiḡei;
\q2 olive huahuadia ba moimoilai, to kopimui na dehorodia basio dahulai;
\q2 vine huahuadia ba moimoilai, to vine ranuna basio inua.
\q1 
\v 16 Badina be Omri ena taravatu vada o badinadia,
\q2 bona Ahaba iduhuna ena ḡaukara idoinai danu,
\q2 bona edia hahealo ai vada o raka;
\q1 una dainai baina habuamui tari,
\q2 emui hanua taudia na bae si henidia,
\q2 bona bese idau-idau ese bae ihi-ihiraimui.
\c 7
\s1 Israel ena kara bodaga
\q1 
\v 1 Madi ihabaigu!
\q2 Lau na huahuana vada e buruki ore auna
\q2 eiava vinena vada e gogo ore imeana na heto;
\q1 asi vine-takona ta mia, lau ese baina ania,
\q2 asi suke-huahuana ta, egu hitolo ilao-ahuna.
\q1 
\v 2 Dirava imatauraina tauna vada e mase tanobada ai,
\q2 asi kara-maoromaoro tauna ta noho, taunimanima bogaragidiai;
\q1 iboudiai na e banimu, rara ihahebubuna totona,
\q2 iboudiai ese huo e otomu, tadikakadia iabidia totona.
\q1 
\v 3 Imadia na e heḡaeḡaemu, kara dika ikarana,
\q2 vada bae kara balaheni;
\q1 hanua lohiana bona hahemaoro tauna ese
\q2 henitao koikoi ḡauna e tahuamu,
\q1 bona tau badana ese ena heḡahusi ḡaudia e gwauraimu;
\q2 unu amo kara maoromaoro e moḡeamu.
\q1 
\v 4 Idia bogaragidiai tau namona na ava ḡiniḡini na heto,
\q2 bona kara maoromaoro tauna na au ginigini na heto.
\q1 Edia gima taudia edia dina, edia dava-abi dinana, vada e gini dae,
\q2 harihari ihabuadia dinana be kaumu.
\q1 
\v 5 Dekemu tauna basio abidadama henia,
\q2 turamu basio abiabiraia;
\q1 udumu ba naria,
\q2 dekemu ai e hekuremu hahinena enai;
\q1 
\v 6 badina be mero ese tamana e dadaraiamu,
\q2 bona kekeni ese sinana e inai heniamu;
\q1 rava-maraḡi hahinena ese rava-bada hahinena e daḡedaḡe heniamu,
\q2 bona ruma taudia korikoridia ese ruma biaguna e inai heniamu.
\q1 
\v 7 A lau ese Iehova baina haḡerea,
\q2 ihamaurigu Diravana baina naria;
\q1 egu Dirava ese baine kamonai henigu.
\b
\s1 Iehova ena Hahemauri
\q1 
\v 8 Inaigu e, lau latagu ai basio moale;
\q2 baina keto negana ai ma baina tore isi;
\q1 dibura ai baina helai negana ai,
\q2 Iehova na egu diari ai bainela.
\q1 
\v 9 Iehova ena badu henunai baina haheauka,
\q2 badina be vada na kara dika henia;
\q1 eIa bona ia ese egu gini-maoro gabuna baine herevalaia,
\q2 bona hahemaoro baine karaia lau daigu ai.
\q1 Ia ese diari ai baine hakaugu lasi,
\q2 ena hahemauri do baina itaia.
\q1 
\v 10 Bena inaigu ese baine itaia,
\q2 bona e hereva henigu, eto
\q1 “Iehova, emu Dirava, na edeseni ai?”, hahinena na
\q2 hemarai ese baine ḡovaia ahu.
\q1 Matagu ese ena hemarai bae moalelaia;
\q2 harihari vada bae moimoilaia,
\q2 ariara kopukopudia na heheto.
\q1 
\v 11 Emui maḡu ihaginidia dinana!
\q2 Una dina ai emui tano hetoadia bae bada.
\q1 
\v 12 Una dina ai taunimanima na dekemui baema,
\q2 Asuria amo ela bona Aigupto,
\q2 Aigupto amo ela bona Sinavai Badana,
\q1 davara amo ela bona davara,
\q2 ororo amo ela bona ororo.
\q1 
\v 13 A tanobada na baine vahu
\q2 inoholaina taudia daidiai,
\q2 edia kara huahuadia daidiai.
\s1 Iehova ena hebogahisi
\q1 
\v 14 Emu bese taudia na emu itotohi amo ba reḡudia,
\q2 idia na emu mamoe korikoridia;
\q1 idia na uda ai e noho hedoamu,
\q2 biru tanodia bogaragidiai.
\q1 Basan ai bona Gilead ai bae heubu,
\q2 nega gunadia heḡereḡeredia.
\b
\q1 
\v 15 Aigupto tanona amo o raka lasi dinadia ai heḡereḡerena
\q2 lau ese hoa ḡaudia baina haheitalaidia.
\b
\q1 
\v 16 Bese idau-idau ese bae itaia, bena bae hemarai,
\q2 edia goada idoinai hemaraina bae hemarai;
\q1 ududia na imadia amo bae tao ahu,
\q2 taiadia na bae kudima.
\q1 
\v 17 Ḡahu bae demaria, gaigai na heheto,
\q2 tano ai e raumu ḡaudia na heheto;
\q1 edia gabu aukadia amo bae raka lasi,
\q2 mai heude-heudedia ida;
\q1 Iehova, eda Dirava, bae haḡerea mai garidia ida,
\q2 oi daimu ai bae gari.
\b
\q1 
\v 18 Edena Dirava na oi heḡereḡeremu?
\q2 Kara dika e gwau taomu,
\q1 bona kerere e lalo negemu,
\q2 dihina kwabukwabudia daidiai.
\q1 Ia ese ena badu basine hahesiriua hanaihanai,
\q2 badina be hebogahisi e moalelaiamu.
\q1 
\v 19 Ia ese ma baine bogada hisi,
\q2 ia ese eda kara havara baine moidia tao,
\q2 ia aena henudiai.
\q1 Oi ese emai kara dika iboudiai na
\q2 davara ena dobu gabudia ai ba negedia.
\q1 
\v 20 oi ese emu heabidadama na Iakob ba hahedinarai henia,
\q2 bona emu hebogahisi na Abraham ba haheitalaia,
\q1 senemai o gwau henidia hamata heḡereḡerena,
\q2 nega gunadia amo. 
