\v 38 \w El|strong="H1931"\w* \w año|strong="H8141"\w* 11, \w el|strong="H1931"\w* \w mes|strong="H2320"\w* \w de|strong="H1697"\w* Bul, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w mes|strong="H2320"\w* \w octavo|strong="H8066"\w*, \w la|strong="H1931"\w* \w Casa|strong="H1004"\w* \w fue|strong="H1931"\w* terminada con \w todos|strong="H3605"\w* \w sus|strong="H1931"\w* detalles y \w de|strong="H1697"\w* conformidad con \w el|strong="H1931"\w* diseño prefijado. \w La|strong="H1931"\w* \w edificó|strong="H1129"\w* en \w siete|strong="H7651"\w* \w años|strong="H8141"\w*.
\c 7
\s1 Otras obras de Salomón
\p 
\v 1 Después \w Salomón|strong="H8010"\w* \w edificó|strong="H1129"\w* su propia \w casa|strong="H1004"\w* en 13 \w años|strong="H8141"\w*, y terminó \w toda|strong="H3605"\w* su \w casa|strong="H1004"\w*.
\v 2 \w Edificó|strong="H1129"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w del|strong="H5921"\w* \w bosque|strong="H3293"\w* \w del|strong="H5921"\w* \w Líbano|strong="H3844"\w*, \w la|strong="H5921"\w* cual tenía 45 metros \w de|strong="H5921"\w* longitud, 22,5 metros \w de|strong="H5921"\w* \w anchura|strong="H7341"\w* \w y|strong="H5921"\w* 13,5 metros \w de|strong="H5921"\w* \w altura|strong="H6967"\w*, \w sobre|strong="H5921"\w* cuatro hileras \w de|strong="H5921"\w* \w columnas|strong="H5982"\w* \w de|strong="H5921"\w* cedro \w con|strong="H5921"\w* vigas \w de|strong="H5921"\w* cedro \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*.
\v 3 Estaba cubierta \w de|strong="H5921"\w* cedro \w encima|strong="H4605"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* vigas \w que|strong="H5921"\w* \w se|strong="H5921"\w* apoyaban \w sobre|strong="H5921"\w* 45 \w columnas|strong="H5982"\w*, 15 \w columnas|strong="H5982"\w* \w por|strong="H5921"\w* hilera.
\v 4 Había \w tres|strong="H7969"\w* hileras de ventanas, \w una|strong="H6471"\w* ventana frente \w a|strong="H3068"\w* otra, en grupos de \w tres|strong="H7969"\w*.
\v 5 \w Todas|strong="H3605"\w* las \w puertas|strong="H6607"\w* y ventanas tenían marcos cuadrados, y \w una|strong="H6471"\w* ventana estaba frente \w a|strong="H3068"\w* otra, en grupos de \w tres|strong="H7969"\w*.
\p 
\v 6 También \w hizo|strong="H6213"\w* \w el|strong="H5921"\w* patio \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*, \w que|strong="H5921"\w* tenía 22,5 metros \w de|strong="H5921"\w* longitud \w por|strong="H5921"\w* 13,5 metros \w de|strong="H5921"\w* \w anchura|strong="H7341"\w*. Frente \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w* \w de|strong="H5921"\w* este patio \w había|strong="H6213"\w* otro patio \w con|strong="H5921"\w* \w columnas|strong="H5982"\w*, \w que|strong="H5921"\w* tenía una cubierta \w delante|strong="H6440"\w*.
\p 
\v 7 También \w edificó|strong="H6213"\w* \w el|strong="H6213"\w* patio del \w trono|strong="H3678"\w* \w donde|strong="H8033"\w* iba \w a|strong="H3068"\w* juzgar, \w el|strong="H6213"\w* patio del \w juicio|strong="H4941"\w*. \w Lo|strong="H6213"\w* recubrió \w con|strong="H5704"\w* cedro \w desde|strong="H5704"\w* \w el|strong="H6213"\w* suelo \w hasta|strong="H5704"\w* las vigas.
\v 8 En la \w casa|strong="H1004"\w* \w donde|strong="H8033"\w* \w vivía|strong="H3427"\w*, \w había|strong="H1961"\w* \w otro|strong="H2088"\w* \w patio|strong="H2691"\w* más \w adentro|strong="H1004"\w* del \w patio|strong="H2691"\w*, del mismo tipo de construcción. \w Salomón|strong="H8010"\w* \w también|strong="H2088"\w* \w edificó|strong="H6213"\w* una \w casa|strong="H1004"\w* parecida \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w patio|strong="H2691"\w* \w para|strong="H1961"\w* la \w hija|strong="H1323"\w* de \w Faraón|strong="H6547"\w* \w a|strong="H3068"\w* \w quien|strong="H6213"\w* \w tomó|strong="H3947"\w* \w como|strong="H1961"\w* esposa.
\p 
\v 9 \w Todas|strong="H3605"\w* estas obras, \w desde|strong="H5704"\w* \w los|strong="H3605"\w* cimientos \w hasta|strong="H5704"\w* las cornisas, \w y|strong="H5704"\w* \w afuera|strong="H2351"\w* \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w gran|strong="H1419"\w* \w patio|strong="H2691"\w*, eran \w de|strong="H5704"\w* piedras costosas \w y|strong="H5704"\w* bloques tallados \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w medida|strong="H4060"\w*, cortados \w con|strong="H5704"\w* sierra \w por|strong="H5704"\w* \w el|strong="H3605"\w* lado interior \w y|strong="H5704"\w* \w el|strong="H3605"\w* exterior.
\v 10 El \w cimiento|strong="H3245"\w* era de \w grandes|strong="H1419"\w* piedras costosas de 4,5 metros y de 3,6 metros.
\v 11 De allí hacia \w arriba|strong="H4605"\w*, también eran piedras costosas, bloques tallados \w a|strong="H3068"\w* \w medida|strong="H4060"\w* y madera de cedro.
\v 12 El \w gran|strong="H1419"\w* \w patio|strong="H2691"\w* tenía \w alrededor|strong="H5439"\w* un muro de \w tres|strong="H7969"\w* hileras de bloques tallados y una hilera de vigas de cedro, como el \w patio|strong="H2691"\w* \w interior|strong="H6442"\w* de la \w Casa|strong="H1004"\w* de \nd \w Yavé|strong="H3068"\w*\nd* y el \w patio|strong="H2691"\w* de la \w casa|strong="H1004"\w*.
\s1 Los muebles del Templo
\p 
\v 13 El \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* traer \w a|strong="H3068"\w* \w Hiram|strong="H2438"\w* desde \w Tiro|strong="H6865"\w*.
\v 14 \w Este|strong="H1931"\w* \w era|strong="H1931"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* una viuda \w de|strong="H1121"\w* \w la|strong="H1931"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* Neftalí, \w cuyo|strong="H1931"\w* padre \w era|strong="H1931"\w* un \w hombre|strong="H1121"\w* \w de|strong="H1121"\w* Tiro, artesano en bronce. \w Él|strong="H1931"\w* estaba \w lleno|strong="H4390"\w* \w de|strong="H1121"\w* \w sabiduría|strong="H2451"\w*, \w inteligencia|strong="H8394"\w* y pericia para \w hacer|strong="H6213"\w* \w cualquier|strong="H3605"\w* \w obra|strong="H4399"\w* en bronce. \w Éste|strong="H1931"\w* \w fue|strong="H1931"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w toda|strong="H3605"\w* \w su|strong="H1931"\w* \w obra|strong="H4399"\w*.
\p 
\v 15 Hizo el vaciado de las \w dos|strong="H8147"\w* \w columnas|strong="H5982"\w* de bronce. Cada \w columna|strong="H5982"\w* tenía 8,1 metros de \w altura|strong="H6967"\w*. La circunferencia de cada \w columna|strong="H5982"\w* medida con un cordel era de 5,4 metros.
\v 16 \w Hizo|strong="H6213"\w* \w dos|strong="H8147"\w* \w capiteles|strong="H3805"\w* \w de|strong="H5921"\w* bronce fundido \w para|strong="H5921"\w* ponerlos \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w cabezas|strong="H7218"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*. Cada \w capitel|strong="H3805"\w* tenía 2,25 metros \w de|strong="H5921"\w* \w altura|strong="H6967"\w*.
\v 17 \w Había|strong="H3805"\w* \w redes|strong="H7638"\w* \w de|strong="H5921"\w* trabajo \w de|strong="H5921"\w* malla \w y|strong="H5921"\w* trenzas \w en|strong="H5921"\w* trabajo \w de|strong="H5921"\w* cadenilla \w para|strong="H5921"\w* \w los|strong="H5921"\w* \w capiteles|strong="H3805"\w* \w que|strong="H5921"\w* \w estaban|strong="H7218"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w cabezas|strong="H7218"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*: \w siete|strong="H7651"\w* \w para|strong="H5921"\w* cada \w capitel|strong="H3805"\w*.
\p 
\v 18 \w Hizo|strong="H6213"\w* \w también|strong="H3651"\w* \w dos|strong="H8147"\w* hileras \w de|strong="H5921"\w* \w granadas|strong="H7416"\w* \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* cada red, \w para|strong="H5921"\w* \w cubrir|strong="H3680"\w* \w los|strong="H5921"\w* \w capiteles|strong="H3805"\w* \w que|strong="H5921"\w* \w estaban|strong="H7218"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w cabezas|strong="H7218"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w* \w con|strong="H5921"\w* \w las|strong="H5921"\w* \w granadas|strong="H7416"\w*, \w lo|strong="H5921"\w* mismo \w para|strong="H5921"\w* cada \w capitel|strong="H3805"\w*.
\v 19 \w Los|strong="H5921"\w* \w capiteles|strong="H3805"\w* \w que|strong="H5921"\w* \w estaban|strong="H7218"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* patio tenían forma \w de|strong="H5921"\w* \w lirios|strong="H7799"\w*, \w y|strong="H5921"\w* eran \w de|strong="H5921"\w* 1,8 metros.
\v 20 \w Los|strong="H5921"\w* \w capiteles|strong="H3805"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w* tenían 200 \w granadas|strong="H7416"\w* \w en|strong="H5921"\w* \w dos|strong="H8147"\w* hileras, \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* parte abultada \w del|strong="H5921"\w* \w capitel|strong="H3805"\w* \w que|strong="H5921"\w* estaba \w encima|strong="H4605"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* red, \w tanto|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* primer \w capitel|strong="H3805"\w* \w como|strong="H1571"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w segundo|strong="H8145"\w*.
\p 
\v 21 \w Erigió|strong="H6965"\w* también las \w columnas|strong="H5982"\w* en el patio del Lugar Santo. \w Erigió|strong="H6965"\w* la \w columna|strong="H5982"\w* \w derecha|strong="H3233"\w*, y la \w llamó|strong="H7121"\w* Jaquín. \w Erigió|strong="H6965"\w* la \w columna|strong="H5982"\w* \w izquierda|strong="H8042"\w*, y la \w llamó|strong="H7121"\w* \w Boaz|strong="H1162"\w*.
\v 22 Puso un diseño \w de|strong="H5921"\w* \w lirios|strong="H7799"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* parte superior \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*. Estas \w columnas|strong="H5982"\w* fueron diseñadas \w del|strong="H5921"\w* mismo modo.
\s1 El mar de fundición
\p 
\v 23 \w Hizo|strong="H6213"\w* también \w el|strong="H6213"\w* \w mar|strong="H3220"\w*\f + \fr 7:23 \fqa Mar. \ft Recipiente para agua.\f* \w de|strong="H5704"\w* fundición \w de|strong="H5704"\w* forma circular \w de|strong="H5704"\w* 4,5 metros \w de|strong="H5704"\w* borde \w a|strong="H3068"\w* borde, 2,25 metros \w de|strong="H5704"\w* alto \w y|strong="H5704"\w* 13,5 metros \w de|strong="H5704"\w* circunferencia.
\v 24 Había calabazas \w debajo|strong="H8478"\w* y \w alrededor|strong="H5439"\w* del borde, \w diez|strong="H6235"\w* \add calabazas\add* \w por|strong="H8478"\w* \w cada|strong="H6235"\w* 45 centímetros, dispuestas \w en|strong="H8478"\w* \w dos|strong="H8147"\w* hileras \w alrededor|strong="H5439"\w* del \w mar|strong="H3220"\w*, las cuales fueron fundidas \w en|strong="H8478"\w* una sola pieza con el \w mar|strong="H3220"\w*.
\p 
\v 25 \add El mar\add* \w estaba|strong="H5975"\w* asentado \w sobre|strong="H5921"\w* 12 \w bueyes|strong="H1241"\w*. \w Tres|strong="H7969"\w* \w miraban|strong="H6437"\w* \w al|strong="H5921"\w* \w norte|strong="H6828"\w*, \w tres|strong="H7969"\w* \w al|strong="H5921"\w* occidente, \w tres|strong="H7969"\w* \w al|strong="H5921"\w* sur \w y|strong="H5921"\w* \w tres|strong="H7969"\w* \w al|strong="H5921"\w* \w oriente|strong="H4217"\w*. \w El|strong="H5921"\w* \w mar|strong="H3220"\w* \w estaba|strong="H5975"\w* asentado \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*. \w Todas|strong="H3605"\w* \w las|strong="H5921"\w* ancas daban \w hacia|strong="H5921"\w* \w la|strong="H5921"\w* parte interior.
\v 26 Su espesor era de 7,5 centímetros, y su borde, como el borde de un \w cáliz|strong="H3563"\w* de \w flor|strong="H6525"\w* de lirio. Su capacidad era de 44.000 litros.
\p 
\v 27 \w Hizo|strong="H6213"\w* también las \w diez|strong="H6235"\w* \w basas|strong="H4350"\w* de bronce. 1,8 metros era la longitud y la \w anchura|strong="H7341"\w* de \w cada|strong="H6235"\w* basa y 1,35 metros la \w altura|strong="H6967"\w*.
\p 
\v 28 \w Este|strong="H2088"\w* \w era|strong="H2088"\w* \w el|strong="H1992"\w* diseño de \w las|strong="H1992"\w* \w basas|strong="H4350"\w*. Tenían marcos, \w los|strong="H1992"\w* cuales estaban entre \w los|strong="H1992"\w* paneles.
\v 29 \w Sobre|strong="H5921"\w* \w los|strong="H5921"\w* marcos \w que|strong="H5921"\w* había \w entre|strong="H5921"\w* \w los|strong="H5921"\w* paneles había figuras \w de|strong="H5921"\w* leones, \w bueyes|strong="H1241"\w* \w y|strong="H5921"\w* \w querubines|strong="H3742"\w*. \w Sobre|strong="H5921"\w* \w los|strong="H5921"\w* paneles, \w tanto|strong="H5921"\w* \w encima|strong="H4605"\w* \w como|strong="H5921"\w* \w debajo|strong="H8478"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* leones \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w bueyes|strong="H1241"\w*, había guirnaldas \w en|strong="H5921"\w* bajorrelieve.
\p 
\v 30 Cada basa tenía cuatro ruedas \w de|strong="H8478"\w* bronce con ejes \w de|strong="H8478"\w* bronce. Sus cuatro patas tenían soportes \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* la \w fuente|strong="H3595"\w*, los cuales eran \w de|strong="H8478"\w* bronce fundido. Tenían molduras \w a|strong="H3068"\w* cada \w lado|strong="H3802"\w*.
\v 31 Su abertura sobresalía 45 centímetros \w del|strong="H5921"\w* interior, \w a|strong="H3068"\w* manera \w de|strong="H5921"\w* \w capitel|strong="H3805"\w*. Su abertura era circular, hecha \w como|strong="H1571"\w* una base \w de|strong="H5921"\w* 68 centímetros. \w También|strong="H1571"\w* \w alrededor|strong="H5921"\w* \w de|strong="H5921"\w* su abertura \w había|strong="H3805"\w* bajorrelieves. Sus marcos \w eran|strong="H3808"\w* cuadrados, \w no|strong="H3808"\w* circulares.
\v 32 Las cuatro ruedas estaban \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* los marcos. Los ejes \w de|strong="H8478"\w* las ruedas salían \w de|strong="H8478"\w* la base. Cada rueda tenía 68 centímetros \w de|strong="H8478"\w* alto.
\v 33 \w El|strong="H3605"\w* diseño de las ruedas era como \w el|strong="H3605"\w* de las ruedas de una carroza. Sus ejes, sus aros, sus rayos y sus cubos, \w todo|strong="H3605"\w* era de fundición.
\p 
\v 34 También los cuatro soportes \w de|strong="H4480"\w* las cuatro \w esquinas|strong="H6438"\w* \w de|strong="H4480"\w* cada base salían \w de|strong="H4480"\w* la misma base.
\v 35 \w En|strong="H5921"\w* \w la|strong="H5921"\w* \w parte|strong="H2677"\w* superior \w de|strong="H4480"\w* \w la|strong="H5921"\w* base había un soporte circular \w de|strong="H4480"\w* 23 centímetros \w de|strong="H4480"\w* \w altura|strong="H6967"\w*. \w Sobre|strong="H5921"\w* \w la|strong="H5921"\w* base había molduras \w y|strong="H5921"\w* tableros \w que|strong="H4480"\w* salían \w de|strong="H4480"\w* \w la|strong="H5921"\w* misma.
\v 36 \w Sobre|strong="H5921"\w* \w las|strong="H5921"\w* planchas \w de|strong="H5921"\w* sus soportes \w y|strong="H5921"\w* \w de|strong="H5921"\w* sus marcos grabó \w querubines|strong="H3742"\w*, leones \w y|strong="H5921"\w* palmeras, \w según|strong="H5921"\w* \w el|strong="H5921"\w* espacio \w de|strong="H5921"\w* cada uno, \w con|strong="H5921"\w* guirnaldas \w alrededor|strong="H5439"\w*.
\v 37 De \w esta|strong="H2063"\w* manera \w hizo|strong="H6213"\w* las \w diez|strong="H6235"\w* bases de una sola fundición, de \w la|strong="H2063"\w* misma \w medida|strong="H4060"\w* y de \w la|strong="H2063"\w* misma forma.
\p 
\v 38 \w Hizo|strong="H6213"\w* también \w diez|strong="H6235"\w* \w fuentes|strong="H3595"\w* \w de|strong="H5921"\w* bronce. \w Cada|strong="H6235"\w* una tenía una capacidad \w de|strong="H5921"\w* 880 litros. \w Cada|strong="H6235"\w* \w fuente|strong="H3595"\w* tenía 1,8 metros. Puso una \w fuente|strong="H3595"\w* \w sobre|strong="H5921"\w* \w cada|strong="H6235"\w* una \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w diez|strong="H6235"\w* bases.
\v 39 \w Puso|strong="H5414"\w* \w cinco|strong="H2568"\w* bases \w al|strong="H5921"\w* \w lado|strong="H3802"\w* sur \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* otras \w cinco|strong="H2568"\w* \w al|strong="H5921"\w* \w lado|strong="H3802"\w* norte. \w El|strong="H5921"\w* \w mar|strong="H3220"\w* \w lo|strong="H5921"\w* colocó \w al|strong="H5921"\w* \w lado|strong="H3802"\w* sur \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w*, \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* sureste.
\s1 Otros utensilios
\p 
\v 40 \w Hiram|strong="H2438"\w* también \w hizo|strong="H6213"\w* las ollas, las palas y \w los|strong="H3605"\w* \w tazones|strong="H4219"\w*. \w Hiram|strong="H2438"\w* terminó de realizar \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w* para \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* en \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd \w Yavé|strong="H3068"\w*\nd*:
\v 41 \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w columnas|strong="H5982"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w capiteles|strong="H3805"\w* circulares \w que|strong="H5921"\w* \w estaban|strong="H7218"\w* \w en|strong="H5921"\w* \w lo|strong="H5921"\w* alto \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w columnas|strong="H5982"\w*, \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w redes|strong="H3805"\w* \w que|strong="H5921"\w* \w cubrían|strong="H3680"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* \w capiteles|strong="H3805"\w* \w que|strong="H5921"\w* \w estaban|strong="H7218"\w* \w en|strong="H5921"\w* \w lo|strong="H5921"\w* alto \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*;
\v 42 \w las|strong="H5921"\w* 400 \w granadas|strong="H7416"\w* \w para|strong="H5921"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w redes|strong="H3805"\w*: \w dos|strong="H8147"\w* hileras \w de|strong="H5921"\w* \w granadas|strong="H7416"\w* \w por|strong="H5921"\w* red, \w para|strong="H5921"\w* \w cubrir|strong="H3680"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* \w capiteles|strong="H3805"\w* \w que|strong="H5921"\w* coronaban \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*;
\v 43 \w las|strong="H5921"\w* \w diez|strong="H6235"\w* bases \w y|strong="H5921"\w* \w diez|strong="H6235"\w* \w fuentes|strong="H3595"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* bases;
\v 44 el \w mar|strong="H3220"\w*, con los 12 \w bueyes|strong="H1241"\w* \w debajo|strong="H8478"\w* del \w mar|strong="H3220"\w*;
\v 45 las ollas, las palas y \w los|strong="H3605"\w* \w tazones|strong="H4219"\w*. \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* utensilios \w que|strong="H3605"\w* \w Hiram|strong="H2438"\w* \w hizo|strong="H6213"\w* para \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd \w Yavé|strong="H3068"\w*,\nd* para \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*, eran de bronce abrillantado.
\p 
\v 46 El \w rey|strong="H4428"\w* ordenó fundir todo esto en tierra \w arcillosa|strong="H4568"\w* en la llanura del \w Jordán|strong="H3383"\w*, entre Sucot y Saretán.
\v 47 \w Salomón|strong="H8010"\w* decidió \w no|strong="H3808"\w* pesar \w todos|strong="H3605"\w* \w estos|strong="H3605"\w* utensilios por su \w gran|strong="H3966"\w* cantidad. \w El|strong="H3605"\w* \w peso|strong="H4948"\w* del bronce \w nunca|strong="H3808"\w* pudo ser averiguado.
\p 
\v 48 \w Salomón|strong="H8010"\w* \w también|strong="H7979"\w* \w hizo|strong="H6213"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* utensilios \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*: \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w*, \w la|strong="H5921"\w* \w mesa|strong="H7979"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* cual \w estaba|strong="H1004"\w* \w el|strong="H5921"\w* \w Pan|strong="H3899"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Presencia|strong="H6440"\w*,
\v 49 los \w cinco|strong="H2568"\w* candelabros \w de|strong="H6440"\w* \w oro|strong="H2091"\w* \w puro|strong="H5462"\w* que estaban al sur, y los otros \w cinco|strong="H2568"\w* al norte, \w delante|strong="H6440"\w* del Lugar Santísimo, con las \w flores|strong="H6525"\w*, las \w lámparas|strong="H5216"\w* y las tenazas \w de|strong="H6440"\w* \w oro|strong="H2091"\w*.
\v 50 Asimismo, hizo las copas, las despabiladeras, los \w tazones|strong="H4219"\w*, las \w cucharas|strong="H3709"\w* y los \w incensarios|strong="H4289"\w* de \w oro|strong="H2091"\w* \w puro|strong="H5462"\w*. También eran de \w oro|strong="H2091"\w* las bisagras de las \w puertas|strong="H1817"\w* de la Sala \w Interior|strong="H6442"\w*, del Lugar \w Santísimo|strong="H6944"\w*, y los de las \w puertas|strong="H1817"\w* de la sala de la \w Casa|strong="H1004"\w*.
\p 
\v 51 Se completó \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w* \w que|strong="H3605"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* \w hizo|strong="H6213"\w* \w para|strong="H5414"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H5414"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w Salomón|strong="H8010"\w* introdujo las cosas \w que|strong="H3605"\w* su padre \w David|strong="H1732"\w* consagró. Depositó \w la|strong="H3605"\w* \w plata|strong="H3701"\w*, \w el|strong="H3605"\w* \w oro|strong="H2091"\w* y \w los|strong="H3605"\w* utensilios en \w la|strong="H3605"\w* tesorería \w de|strong="H5414"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H5414"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\c 8
\s1 Consagración de la Casa
\p 
\v 1 Entonces \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* reunió en Jerusalén \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w ancianos|strong="H2205"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* las \w tribus|strong="H4294"\w* y \w los|strong="H1121"\w* líderes \w de|strong="H1121"\w* las casas paternas \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* ante \w él|strong="H1931"\w*, para llevar \w el|strong="H1931"\w* Arca del \w Pacto|strong="H1285"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* desde \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* \w Sion|strong="H6726"\w*.
\v 2 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres de \w Israel|strong="H3478"\w* \w se|strong="H1931"\w* congregaron ante \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* en \w la|strong="H1931"\w* \w solemnidad|strong="H2282"\w* del \w mes|strong="H2320"\w* de Etanim, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w mes|strong="H2320"\w* \w séptimo|strong="H7637"\w*.
\p 
\v 3 Cuando \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* de \w Israel|strong="H3478"\w* llegaron, \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* levantaron \w el|strong="H3605"\w* Arca.
\v 4 \w Los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* y \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* llevaron \w el|strong="H3605"\w* Arca de \nd \w Yavé|strong="H3068"\w*\nd*, \w el|strong="H3605"\w* Tabernáculo de Reunión y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios \w sagrados|strong="H6944"\w* \w que|strong="H3605"\w* había dentro del Tabernáculo.
\v 5 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* congregación \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w que|strong="H3808"\w* \w se|strong="H5921"\w* había reunido \w con|strong="H5921"\w* \w él|strong="H5921"\w*, estaban \w delante|strong="H6440"\w* \w del|strong="H5921"\w* Arca \w para|strong="H5921"\w* sacrificar \w ovejas|strong="H6629"\w* \w y|strong="H5921"\w* becerros, tantos \w que|strong="H3808"\w* \w no|strong="H3808"\w* pudieron ser \w contados|strong="H5608"\w* \w ni|strong="H3808"\w* calculados \w por|strong="H5921"\w* su gran cantidad.
\p 
