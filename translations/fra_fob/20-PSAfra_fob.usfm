\v 9 \w Car|strong="H6440"\w* \w il|strong="H3068"\w* n'\w y|strong="H3068"\w* \w a|strong="H3068"\w* \w point|strong="H3068"\w* \w de|strong="H6440"\w* sincérité \w dans|strong="H6440"\w* \w leur|strong="H3068"\w* \w bouche|strong="H6440"\w*; \w leur|strong="H3068"\w* \w cœur|strong="H6440"\w* n'\w est|strong="H3068"\w* \w que|strong="H6440"\w* malice, \w leur|strong="H3068"\w* gosier \w est|strong="H3068"\w* \w un|strong="H3068"\w* tombeau ouvert; \w ils|strong="H6440"\w* flattent \w avec|strong="H6440"\w* \w leur|strong="H3068"\w* \w langue|strong="H3068"\w*.
\v 10 Condamne-les, ô \w Dieu|strong="H3588"\w*! \w Qu|strong="H3588"\w*'\w ils|strong="H6310"\w* échouent \w dans|strong="H7130"\w* \w leurs|strong="H6310"\w* desseins; renverse-les \w à|strong="H3588"\w* \w cause|strong="H3588"\w* \w de|strong="H6310"\w* \w la|strong="H3588"\w* multitude \w de|strong="H6310"\w* \w leurs|strong="H6310"\w* crimes; \w car|strong="H3588"\w* \w ils|strong="H6310"\w* \w se|strong="H3588"\w* \w sont|strong="H6310"\w* révoltés contre \w toi|strong="H7130"\w*.
