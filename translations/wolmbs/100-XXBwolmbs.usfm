\id XXB - Hebrew Calendar
\h Nattinu jamono ci bànni Israayil
\toc1 Nattinu jamono ci bànni Israayil
\toc2 Nattinu jamono ci bànni Israayil
\toc3 Nattinu jamono ci bànni Israayil
\mt1 Nattinu jamono ci bànni Israayil
\m Tur yi ci keppu yi ( . . . ), weer waa ngi ci Kàddug Yàlla waaye tur wi nekku ca.
\tr 
\th1 Limeefu weer wi
\th2 Turu weer wi
\th3 Yemook
\th4 Jamonoy mbey
\th5 Màggal yi ci seen bés
\tr 
\tc1 1
\tc2 Abiib, Nisan
\tc3 mars, jàpp awril
\tc4 taw bu mujj, ngóobum lors
\tc5 14 bés ci Abiib: màggalu bésub Mucc (Mucc ga 12.18). Bési 15 ba 21 ci Abiib: màggalug ayu bésu Mburu mu amul lawiir (Mucc ga 12.14-20). 16 bés ci Abiib: màggalu Ndoortel meññeef (Sarxalkat 23.9-11).
\tr 
\tc1 2
\tc2 Siw, (Iyar)
\tc3 awril, jàpp me
\tc4 
\tc5 
\tr 
\tc1 3
\tc2 Siwan
\tc3 me, jàpp suweŋ
\tc4 ngóobum bele
\tc5 Ñeenteelu bés ci Siwan: Pàntakot, ñu koy tudde itam màggalug Ngóob (Sarxalkat 23.15-16).
\tr 
\tc1 4
\tc2 (Tamus)
\tc3 suweŋ, jàpp sulet
\tc4 
\tc5 
\tr 
\tc1 5
\tc2 (Ab)
\tc3 sulet, jàpp ut
\tr 
\tc1 6
\tc2 Elul
\tc3 ut, jàpp sàttumbar
\tc4 wittum reseñ ak figg ak oliw
\tc5 
\tr 
\tc1 7
\tc2 Etanin, (Tisri)
\tc3 sàttumbar, jàpp oktoobar
\tc4 taw bu jëkk
\tc5 Bés bu jëkk ci Etanin: màggalu bésu Liit yi (Sarxalkat 23.24). Fukkeelu bés bi: bésu Njotlaay (Sarxalkat 16). Bési 15 ba 21 ci Etanin: màggalu ayu bésu Mbaar yi (Sarxalkat 23.34-40). Bésu 22 ci Etanin: Ndaje mu sell (Sarxalkat 23.36).
\tr 
\tc1 8
\tc2 Bul, (Marxeswan)
\tc3 oktoobar, jàpp nowàmbar
\tc4 
\tc5 
\tr 
\tc1 9
\tc2 Kislew
\tc3 nowàmbar, jàpp desàmbar
\tc4 
\tc5 Bésu 25 ci Kislew: bés ba ñuy baaxantal daloog kër Yàlla ga (Yowaan 10.22).
\tr 
\tc1 10
\tc2 Tebet
\tc3 desàmbar, jàpp saawyee
\tc4 
\tc5 
\tr 
\tc1 11
\tc2 Sebat
\tc3 saawyee, jàpp fewriyee
\tc4 
\tc5 
\tr 
\tc1 12
\tc2 Adar
\tc3 fewriyee, jàpp màrs
\tc4 wittum doomi garab
\tc5 Bési 14 ba 15 ci Adar: màggalu bési Purim (Esteer 9.21). 
