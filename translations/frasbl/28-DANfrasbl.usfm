\v 19 Alors \w Nebucadnetsar|strong="H5020"\w* \w fut|strong="H5020"\w* \w rempli|strong="H4391"\w* \w de|strong="H5922"\w* \w fureur|strong="H2528"\w*, \w et|strong="H6032"\w* l'expression \w de|strong="H5922"\w* \w son|strong="H5922"\w* \w visage|strong="H5922"\w* \w changea|strong="H8133"\w* \w à|strong="H5922"\w* l'égard \w de|strong="H5922"\w* \w Schadrac|strong="H7715"\w*, \w Méschac|strong="H4336"\w* \w et|strong="H6032"\w* \w Abed-Négo|strong="H6032"\w*. \w Il|strong="H5922"\w* \w ordonna|strong="H6032"\w* \w de|strong="H5922"\w* \w chauffer|strong="H5922"\w* \w la|strong="H5922"\w* \w fournaise|strong="H5922"\w* \w sept|strong="H7655"\w* \w fois|strong="H7655"\w* \w plus|strong="H5922"\w* \w qu|strong="H1768"\w*'\w il|strong="H5922"\w* n'\w était|strong="H6755"\w* \w d|strong="H1768"\w*'usage.  
\v 20 Puis il commanda à quelques-uns \w des|strong="H1768"\w* \w soldats|strong="H1400"\w* \w les|strong="H2429"\w* \w plus|strong="H2429"\w* \w vigoureux|strong="H1401"\w* \w de|strong="H2429"\w* \w son|strong="H2429"\w* \w armée|strong="H2429"\w* \w de|strong="H2429"\w* \w lier|strong="H3729"\w* \w Schadrac|strong="H7715"\w*, \w Méschac|strong="H4336"\w* \w et|strong="H2429"\w* Abed-Négo, \w et|strong="H2429"\w* \w de|strong="H2429"\w* \w les|strong="H2429"\w* \w jeter|strong="H7412"\w* \w dans|strong="H7412"\w* \w la|strong="H1768"\w* \w fournaise|strong="H1768"\w* \w ardente|strong="H3345"\w*.  
\v 21 Ces \w hommes|strong="H1400"\w* \w furent|strong="H1400"\w* alors \w liés|strong="H3729"\w* avec leurs pantalons, leurs \w tuniques|strong="H6361"\w*, leurs \w manteaux|strong="H3737"\w* et leurs autres \w vêtements|strong="H3831"\w*, et \w jetés|strong="H7412"\w* \w au|strong="H7412"\w* \w milieu|strong="H1459"\w* \w de|strong="H1459"\w* la fournaise \w ardente|strong="H3345"\w*.  
\v 22 \w Comme|strong="H6903"\w* l'\w ordre|strong="H4406"\w* \w du|strong="H4481"\w* \w roi|strong="H4430"\w* \w était|strong="H4430"\w* \w sévère|strong="H2685"\w* \w et|strong="H4430"\w* \w que|strong="H1768"\w* \w la|strong="H4481"\w* \w fournaise|strong="H4481"\w* \w était|strong="H4430"\w* \w extraordinairement|strong="H3493"\w* chaude, \w la|strong="H4481"\w* \w flamme|strong="H7631"\w* \w du|strong="H4481"\w* \w feu|strong="H5135"\w* \w tua|strong="H6992"\w* \w les|strong="H3606"\w* \w hommes|strong="H1400"\w* \w qui|strong="H1400"\w* \w y|strong="H4481"\w* avaient \w jeté|strong="H5267"\w* \w Schadrac|strong="H7715"\w*, \w Méschac|strong="H4336"\w* \w et|strong="H4430"\w* Abed-Négo.  
\v 23 \w Et|strong="H5308"\w* \w ces|strong="H5308"\w* \w trois|strong="H8532"\w* \w hommes|strong="H1400"\w*, \w Schadrac|strong="H7715"\w*, \w Méschac|strong="H4336"\w* \w et|strong="H5308"\w* Abed-Négo, \w tombèrent|strong="H5308"\w* \w liés|strong="H3729"\w* \w au|strong="H3729"\w* \w milieu|strong="H1459"\w* \w de|strong="H1459"\w* la fournaise \w ardente|strong="H3345"\w*.   
\p
\v 24 Alors \w le|strong="H6966"\w* \w roi|strong="H4430"\w* \w Nebucadnetsar|strong="H5020"\w* \w fut|strong="H4430"\w* frappé \w de|strong="H4430"\w* stupeur \w et|strong="H4430"\w* \w se|strong="H4430"\w* \w leva|strong="H6966"\w* précipitamment. \w Il|strong="H4430"\w* \w prit|strong="H4430"\w* \w la|strong="H3809"\w* \w parole|strong="H6032"\w* \w et|strong="H4430"\w* \w dit|strong="H6032"\w* \w à|strong="H4430"\w* \w ses|strong="H4430"\w* \w conseillers|strong="H1907"\w* : « N'avons-nous \w pas|strong="H3809"\w* \w jeté|strong="H7412"\w* \w trois|strong="H8532"\w* \w hommes|strong="H1400"\w* \w liés|strong="H3729"\w* \w au|strong="H7412"\w* \w milieu|strong="H1459"\w* \w du|strong="H1459"\w* \w feu|strong="H5135"\w* ? »  
\p \w Ils|strong="H4430"\w* \w répondirent|strong="H6032"\w* \w au|strong="H7412"\w* \w roi|strong="H4430"\w* : « C'est \w vrai|strong="H3330"\w*, ô \w roi|strong="H4430"\w*. »   
\p
\v 25 Il \w reprit|strong="H6032"\w* : « Eh \w bien|strong="H1888"\w*, \w je|strong="H3809"\w* \w vois|strong="H2370"\w* \w quatre|strong="H2370"\w* \w hommes|strong="H1400"\w* déliés \w qui|strong="H3809"\w* \w marchent|strong="H1981"\w* \w au|strong="H1981"\w* \w milieu|strong="H1459"\w* \w du|strong="H1459"\w* \w feu|strong="H5135"\w* \w sans|strong="H3809"\w* subir \w aucun|strong="H3809"\w* dommage. \w Et|strong="H6032"\w* l'\w aspect|strong="H7299"\w* \w du|strong="H1459"\w* \w quatrième|strong="H7244"\w* \w ressemble|strong="H1821"\w* \w à|strong="H6032"\w* \w celui|strong="H1768"\w* \w d|strong="H1768"\w*'\w un|strong="H2370"\w* \w fils|strong="H1247"\w* \w des|strong="H1768"\w* dieux.\f + \fr 3.25 \ft Ou, le Fils de Dieu.\f* »   
\p
\v 26 Ensuite, \w Nebucadnetsar|strong="H5020"\w* s'\w approcha|strong="H7127"\w* \w de|strong="H4481"\w* l'ouverture \w de|strong="H4481"\w* \w la|strong="H4481"\w* \w fournaise|strong="H4481"\w* \w ardente|strong="H3345"\w*. \w Il|strong="H4481"\w* \w prit|strong="H5020"\w* \w la|strong="H4481"\w* \w parole|strong="H6032"\w* \w et|strong="H6032"\w* \w dit|strong="H6032"\w* : « \w Schadrac|strong="H7715"\w*, \w Méschac|strong="H4336"\w* \w et|strong="H6032"\w* \w Abed-Négo|strong="H6032"\w*, \w serviteurs|strong="H5649"\w* \w du|strong="H4481"\w* \w Dieu|strong="H4481"\w* Très-Haut, \w sortez|strong="H5312"\w* \w et|strong="H6032"\w* venez ici ! »  
\p Alors \w Schadrac|strong="H7715"\w*, \w Méschac|strong="H4336"\w* \w et|strong="H6032"\w* \w Abed-Négo|strong="H6032"\w* \w sortirent|strong="H5312"\w* \w du|strong="H4481"\w* \w milieu|strong="H1459"\w* \w du|strong="H4481"\w* \w feu|strong="H5135"\w*.  
\v 27 \w Les|strong="H8133"\w* satrapes, \w les|strong="H8133"\w* \w intendants|strong="H5460"\w*, \w les|strong="H8133"\w* \w gouverneurs|strong="H6347"\w* \w et|strong="H4430"\w* \w les|strong="H8133"\w* \w conseillers|strong="H1907"\w* \w du|strong="H1907"\w* \w roi|strong="H4430"\w* \w se|strong="H4430"\w* rassemblèrent ; \w ils|strong="H4430"\w* \w virent|strong="H2370"\w* \w que|strong="H1768"\w* \w le|strong="H1768"\w* \w feu|strong="H5135"\w* n'\w avait|strong="H4430"\w* \w eu|strong="H2370"\w* \w aucun|strong="H3809"\w* \w pouvoir|strong="H7981"\w* \w sur|strong="H7981"\w* \w le|strong="H1768"\w* \w corps|strong="H1655"\w* \w de|strong="H4430"\w* \w ces|strong="H4430"\w* \w hommes|strong="H1400"\w*, \w que|strong="H1768"\w* \w les|strong="H8133"\w* \w cheveux|strong="H8177"\w* \w de|strong="H4430"\w* \w leur|strong="H1768"\w* \w tête|strong="H7217"\w* n'avaient \w pas|strong="H3809"\w* \w été|strong="H3809"\w* roussis, \w que|strong="H1768"\w* \w leurs|strong="H4430"\w* pantalons n'étaient \w pas|strong="H3809"\w* \w endommagés|strong="H8133"\w*, \w et|strong="H4430"\w* \w que|strong="H1768"\w* l'\w odeur|strong="H7382"\w* \w du|strong="H1907"\w* \w feu|strong="H5135"\w* \w ne|strong="H3809"\w* \w les|strong="H8133"\w* \w avait|strong="H4430"\w* même \w pas|strong="H3809"\w* imprégnés.   
\p
\v 28 \w Nebucadnetsar|strong="H5020"\w* \w prit|strong="H4430"\w* \w la|strong="H3606"\w* \w parole|strong="H6032"\w* \w et|strong="H4430"\w* \w dit|strong="H6032"\w* : « \w Béni|strong="H1289"\w* \w soit|strong="H5922"\w* \w le|strong="H5922"\w* \w Dieu|strong="H5922"\w* \w de|strong="H4430"\w* \w Schadrac|strong="H7715"\w*, \w de|strong="H4430"\w* \w Méschac|strong="H4336"\w* \w et|strong="H4430"\w* \w d|strong="H1768"\w*'\w Abed-Négo|strong="H6032"\w*, \w qui|strong="H3809"\w* \w a|strong="H3068"\w* \w envoyé|strong="H7972"\w* \w son|strong="H5922"\w* \w ange|strong="H4398"\w* \w et|strong="H4430"\w* \w délivré|strong="H7804"\w* \w ses|strong="H5922"\w* \w serviteurs|strong="H5649"\w* \w qui|strong="H3809"\w* \w se|strong="H4430"\w* \w sont|strong="H3809"\w* confiés \w en|strong="H4430"\w* \w lui|strong="H5922"\w*, \w qui|strong="H3809"\w* \w ont|strong="H3809"\w* transgressé l'\w ordre|strong="H4406"\w* \w du|strong="H5922"\w* \w roi|strong="H4430"\w* \w et|strong="H4430"\w* \w ont|strong="H3809"\w* \w livré|strong="H3052"\w* \w leur|strong="H5922"\w* \w corps|strong="H1655"\w*, \w afin|strong="H1768"\w* \w de|strong="H4430"\w* \w ne|strong="H3809"\w* \w servir|strong="H6399"\w* \w et|strong="H4430"\w* \w de|strong="H4430"\w* n'\w adorer|strong="H5457"\w* \w aucun|strong="H3809"\w* \w autre|strong="H3606"\w* \w dieu|strong="H5922"\w* \w que|strong="H1768"\w* \w leur|strong="H5922"\w* propre \w Dieu|strong="H5922"\w*.  
\v 29 C'\w est|strong="H5922"\w* \w pourquoi|strong="H5922"\w* \w je|strong="H1836"\w* promulgue \w un|strong="H4481"\w* \w décret|strong="H5922"\w* : \w tout|strong="H3606"\w* \w peuple|strong="H5972"\w*, \w toute|strong="H3606"\w* nation \w ou|strong="H1768"\w* \w toute|strong="H3606"\w* \w langue|strong="H3961"\w* \w qui|strong="H3809"\w* parlera mal \w du|strong="H4481"\w* \w Dieu|strong="H4481"\w* \w de|strong="H4481"\w* \w Schadrac|strong="H7715"\w*, \w de|strong="H4481"\w* \w Méschac|strong="H4336"\w* \w et|strong="H4481"\w* \w d|strong="H4481"\w*'Abed-Négo \w sera|strong="H1005"\w* \w mis|strong="H5648"\w* \w en|strong="H5648"\w* \w pièces|strong="H1917"\w*, \w et|strong="H4481"\w* \w leurs|strong="H3606"\w* \w maisons|strong="H1005"\w* \w seront|strong="H1005"\w* \w réduites|strong="H7761"\w* \w en|strong="H5648"\w* \w un|strong="H4481"\w* tas \w d|strong="H4481"\w*'\w immondices|strong="H5122"\w*, \w parce|strong="H6903"\w* \w qu|strong="H1768"\w*'\w il|strong="H5922"\w* n'\w y|strong="H5922"\w* \w a|strong="H3068"\w* \w aucun|strong="H3809"\w* \w autre|strong="H3606"\w* \w dieu|strong="H4481"\w* \w qui|strong="H3809"\w* \w puisse|strong="H3202"\w* \w délivrer|strong="H5338"\w* \w de|strong="H4481"\w* \w cette|strong="H1836"\w* manière. »   
\p
\v 30 Alors le \w roi|strong="H4430"\w* \w fit|strong="H4430"\w* \w prospérer|strong="H6744"\w* \w Schadrac|strong="H7715"\w*, \w Méschac|strong="H4336"\w* \w et|strong="H4430"\w* Abed-Négo dans \w la|strong="H4430"\w* \w province|strong="H4083"\w* \w de|strong="H4430"\w* Babylone.   
\c 4
\pi1
\v 1 \w Le|strong="H1934"\w* roi \w Nébucadnetsar|strong="H5020"\w*,  
\pi1 à tous les peuples, à toutes les nations \w et|strong="H1005"\w* aux hommes \w de|strong="H1005"\w* toutes langues, qui habitent sur toute la terre :  
\pi1 Que la paix vous \w soit|strong="H1005"\w* multipliée !   
\pi1
\v 2 \w Il|strong="H5922"\w* m'\w a|strong="H3068"\w* semblé bon \w de|strong="H5922"\w* faire connaître \w les|strong="H5922"\w* signes et \w les|strong="H5922"\w* prodiges que \w le|strong="H5922"\w* \w Dieu|strong="H5922"\w* Très-Haut \w a|strong="H3068"\w* accomplis envers moi.   
\q1
\v 3 \w Que|strong="H1768"\w* ses \w signes|strong="H4481"\w* \w sont|strong="H4481"\w* \w grands|strong="H3606"\w* !  
\q2 \w Que|strong="H1768"\w* ses prodiges \w sont|strong="H4481"\w* puissants !  
\q1 \w Son|strong="H4481"\w* \w règne|strong="H4481"\w* \w est|strong="H2493"\w* \w un|strong="H4481"\w* \w règne|strong="H4481"\w* éternel,  
\q2 \w et|strong="H4481"\w* \w sa|strong="H4481"\w* domination subsiste \w de|strong="H4481"\w* \w génération|strong="H4481"\w* \w en|strong="H4481"\w* \w génération|strong="H4481"\w*.   
\pi1
\v 4 \w Moi|strong="H6925"\w*, Nébucadnetsar, \w je|strong="H3809"\w* vivais tranquille \w dans|strong="H5954"\w* ma maison \w et|strong="H3809"\w* prospère \w dans|strong="H5954"\w* mon palais.  
\v 5 \w J|strong="H3068"\w*'eus \w un|strong="H5705"\w* \w songe|strong="H2493"\w* \w qui|strong="H1841"\w* m'effraya ; \w les|strong="H5954"\w* \w pensées|strong="H5954"\w* \w qui|strong="H1841"\w* \w me|strong="H6925"\w* poursuivaient sur \w mon|strong="H5705"\w* lit \w et|strong="H1841"\w* \w les|strong="H5954"\w* \w visions|strong="H5954"\w* \w de|strong="H5705"\w* \w mon|strong="H5705"\w* \w esprit|strong="H7308"\w* \w me|strong="H6925"\w* troublèrent.  
\v 6 \w Je|strong="H3068"\w* donnai donc l'\w ordre|strong="H2370"\w* \w de|strong="H3809"\w* faire \w venir|strong="H3809"\w* devant moi \w tous|strong="H3606"\w* \w les|strong="H3606"\w* \w sages|strong="H3606"\w* \w de|strong="H3809"\w* Babylone, \w afin|strong="H1768"\w* \w qu|strong="H1768"\w*'ils me fassent \w connaître|strong="H3046"\w* l'interprétation \w du|strong="H6591"\w* \w songe|strong="H2493"\w*.  
\v 7 Alors vinrent \w les|strong="H5922"\w* magiciens, \w les|strong="H5922"\w* enchanteurs, \w les|strong="H5922"\w* \w Chaldéens|strong="H5922"\w* \w et|strong="H7690"\w* \w les|strong="H5922"\w* devins. \w Je|strong="H3068"\w* \w leur|strong="H5922"\w* racontai \w le|strong="H5922"\w* songe, mais ils ne m'\w en|strong="H1934"\w* firent pas connaître l'interprétation.  
\v 8 Enfin, Daniel \w se|strong="H8065"\w* présenta devant moi, \w lui|strong="H3606"\w* dont \w le|strong="H3606"\w* \w nom|strong="H3606"\w* est Belteshatsar d'après \w le|strong="H3606"\w* \w nom|strong="H3606"\w* \w de|strong="H7314"\w* mon \w dieu|strong="H3606"\w*, \w et|strong="H7236"\w* en \w qui|strong="H3606"\w* réside l'esprit \w des|strong="H3606"\w* dieux saints. \w Je|strong="H3068"\w* \w lui|strong="H3606"\w* racontai \w le|strong="H3606"\w* \w songe|strong="H3606"\w* :   
\pi1
\v 9 « Belteshatsar, chef \w des|strong="H4481"\w* magiciens, puisque je sais \w que|strong="H3606"\w* l'esprit \w des|strong="H4481"\w* \w dieux|strong="H4481"\w* saints est \w en|strong="H4481"\w* toi \w et|strong="H4481"\w* \w qu|strong="H3606"\w*'\w aucun|strong="H3606"\w* mystère ne \w t|strong="H4481"\w*'embarrasse, dis-moi \w les|strong="H3606"\w* \w visions|strong="H4481"\w* \w de|strong="H4481"\w* mon \w songe|strong="H3606"\w* \w que|strong="H3606"\w* \w j|strong="H4481"\w*'ai eues, \w et|strong="H4481"\w* \w son|strong="H4481"\w* interprétation.  
\v 10 \w Voici|strong="H4481"\w* \w les|strong="H5922"\w* \w visions|strong="H2376"\w* \w de|strong="H4481"\w* \w mon|strong="H5922"\w* \w esprit|strong="H7217"\w* \w pendant|strong="H5922"\w* \w que|strong="H4481"\w* \w j|strong="H4481"\w*'étais \w sur|strong="H5922"\w* \w mon|strong="H5922"\w* lit : \w je|strong="H1934"\w* \w regardais|strong="H1934"\w*, \w et|strong="H4481"\w* \w voici|strong="H4481"\w*, \w il|strong="H5922"\w* \w y|strong="H5922"\w* \w avait|strong="H5922"\w* \w un|strong="H1934"\w* arbre \w au|strong="H5922"\w* \w milieu|strong="H4481"\w* \w de|strong="H4481"\w* \w la|strong="H4481"\w* \w terre|strong="H4481"\w*, \w et|strong="H4481"\w* \w sa|strong="H5922"\w* hauteur était immense.  
\v 11 \w L|strong="H3068"\w*'arbre grandit \w et|strong="H4481"\w* devint puissant. \w Sa|strong="H4481"\w* cime atteignait \w le|strong="H4481"\w* ciel \w et|strong="H4481"\w* \w on|strong="H4481"\w* \w le|strong="H4481"\w* \w voyait|strong="H4481"\w* jusqu'aux \w extrémités|strong="H4481"\w* \w de|strong="H4481"\w* \w toute|strong="H4481"\w* \w la|strong="H4481"\w* \w terre|strong="H4481"\w*.  
\v 12 Son feuillage \w était|strong="H2423"\w* magnifique \w et|strong="H5974"\w* ses fruits abondants ; il portait \w de|strong="H5974"\w* \w la|strong="H1768"\w* \w nourriture|strong="H1768"\w* \w pour|strong="H5974"\w* tous. \w Les|strong="H5974"\w* \w bêtes|strong="H2423"\w* \w des|strong="H1768"\w* \w champs|strong="H1251"\w* s'abritaient sous son ombre, \w les|strong="H5974"\w* \w oiseaux|strong="H5974"\w* \w du|strong="H2920"\w* \w ciel|strong="H8065"\w* habitaient dans ses branches, \w et|strong="H5974"\w* toute \w la|strong="H1768"\w* chair s'\w en|strong="H7662"\w* nourrissait.   
\pi1
\v 13 » \w Je|strong="H3068"\w* regardais \w dans|strong="H5922"\w* \w les|strong="H5922"\w* \w visions|strong="H4481"\w* \w de|strong="H4481"\w* \w mon|strong="H5922"\w* esprit \w sur|strong="H5922"\w* \w mon|strong="H5922"\w* lit, \w et|strong="H4481"\w* \w voici|strong="H4481"\w*, \w un|strong="H4481"\w* veilleur saint descendit \w du|strong="H4481"\w* ciel.  
\v 14 \w Il|strong="H5922"\w* s'écria avec \w force|strong="H5922"\w* : « Abattez l'arbre \w et|strong="H6966"\w* \w coupez|strong="H6966"\w* \w ses|strong="H5922"\w* branches ! Secouez \w son|strong="H5922"\w* \w feuillage|strong="H5922"\w* \w et|strong="H6966"\w* \w dispersez|strong="H6966"\w* \w ses|strong="H5922"\w* fruits ! \w Que|strong="H1768"\w* \w les|strong="H5922"\w* \w bêtes|strong="H5922"\w* fuient \w de|strong="H5922"\w* dessous \w lui|strong="H5922"\w*, \w et|strong="H6966"\w* \w les|strong="H5922"\w* \w oiseaux|strong="H5922"\w* \w de|strong="H5922"\w* \w ses|strong="H5922"\w* branches !  
\v 15 Toutefois, laissez \w en|strong="H4430"\w* \w terre|strong="H4430"\w* \w la|strong="H3606"\w* souche \w de|strong="H4430"\w* \w ses|strong="H4430"\w* racines, liée avec \w des|strong="H4430"\w* \w chaînes|strong="H7308"\w* \w de|strong="H4430"\w* \w fer|strong="H2445"\w* \w et|strong="H4430"\w* \w de|strong="H4430"\w* bronze, \w dans|strong="H3606"\w* \w la|strong="H3606"\w* tendre herbe \w des|strong="H4430"\w* champs ; \w qu|strong="H1768"\w*'\w il|strong="H4430"\w* \w soit|strong="H4430"\w* \w trempé|strong="H6591"\w* par \w la|strong="H3606"\w* \w rosée|strong="H3606"\w* \w du|strong="H4437"\w* ciel, \w et|strong="H4430"\w* \w que|strong="H1768"\w* sa part \w soit|strong="H4430"\w* avec \w les|strong="H3606"\w* \w bêtes|strong="H3606"\w* \w dans|strong="H3606"\w* l'herbe \w de|strong="H4430"\w* \w la|strong="H3606"\w* \w terre|strong="H4430"\w*.  
\v 16 \w Que|strong="H1768"\w* \w son|strong="H6032"\w* \w cœur|strong="H2298"\w* \w d|strong="H1768"\w*'homme lui \w soit|strong="H4430"\w* ôté, \w et|strong="H4430"\w* \w qu|strong="H1768"\w*'\w un|strong="H2298"\w* \w cœur|strong="H2298"\w* \w de|strong="H4430"\w* bête lui \w soit|strong="H4430"\w* donné. Puis, \w que|strong="H1768"\w* sept temps passent sur lui.   
\pi1
\v 17 « \w Cette|strong="H2370"\w* sentence est \w un|strong="H2370"\w* \w décret|strong="H2370"\w* \w des|strong="H1768"\w* veilleurs, \w et|strong="H7236"\w* \w cette|strong="H2370"\w* résolution est \w un|strong="H2370"\w* \w ordre|strong="H2370"\w* \w des|strong="H1768"\w* saints, \w afin|strong="H1768"\w* \w que|strong="H1768"\w* \w les|strong="H3606"\w* vivants sachent \w que|strong="H1768"\w* \w le|strong="H3606"\w* Très-Haut domine sur \w la|strong="H3606"\w* royauté \w des|strong="H1768"\w* \w hommes|strong="H3606"\w*, \w qu|strong="H1768"\w*'il \w la|strong="H3606"\w* donne à \w qui|strong="H3606"\w* il veut, \w et|strong="H7236"\w* \w qu|strong="H1768"\w*'il y élève \w le|strong="H3606"\w* plus humble \w des|strong="H1768"\w* \w hommes|strong="H3606"\w*. »   
\pi1
\v 18 » Voilà \w le|strong="H3606"\w* \w songe|strong="H3606"\w* \w que|strong="H3606"\w* j'ai eu, moi, \w le|strong="H3606"\w* roi Nébucadnetsar. \w Et|strong="H3606"\w* toi, Belteshatsar, donnes-en l'interprétation, puisque \w tous|strong="H3606"\w* \w les|strong="H3606"\w* \w sages|strong="H3606"\w* \w de|strong="H7690"\w* mon royaume sont incapables \w de|strong="H7690"\w* me \w la|strong="H3606"\w* faire connaître ; mais toi, tu \w le|strong="H3606"\w* peux, car l'esprit \w des|strong="H2423"\w* dieux saints est en toi. »   
\pi1
\v 19 Alors Daniel, \w dont|strong="H1768"\w* \w le|strong="H1768"\w* nom est Belteshatsar, resta \w un|strong="H8065"\w* moment stupéfait, \w et|strong="H4430"\w* \w ses|strong="H4430"\w* pensées \w le|strong="H1768"\w* troublaient. \w Le|strong="H1768"\w* \w roi|strong="H4430"\w* \w reprit|strong="H4430"\w* : « Belteshatsar, \w que|strong="H1768"\w* \w le|strong="H1768"\w* \w songe|strong="H1768"\w* \w et|strong="H4430"\w* l'interprétation \w ne|strong="H4430"\w* te troublent pas. »  
\pi1 Belteshatsar répondit : « Mon seigneur, \w que|strong="H1768"\w* \w le|strong="H1768"\w* \w songe|strong="H1768"\w* \w soit|strong="H4430"\w* pour ceux \w qui|strong="H4430"\w* te haïssent, \w et|strong="H4430"\w* son interprétation pour tes adversaires !  
\v 20 \w L|strong="H3068"\w*'arbre \w que|strong="H1768"\w* \w tu|strong="H1768"\w* \w as|strong="H1768"\w* \w vu|strong="H2370"\w*, \w qui|strong="H4430"\w* \w a|strong="H3068"\w* grandi \w et|strong="H4430"\w* s'\w est|strong="H5922"\w* fortifié, \w dont|strong="H1768"\w* \w la|strong="H4481"\w* cime atteignait \w le|strong="H5922"\w* \w ciel|strong="H8065"\w* \w et|strong="H4430"\w* \w qu|strong="H1768"\w*'\w on|strong="H4430"\w* \w voyait|strong="H4481"\w* \w de|strong="H4481"\w* \w toute|strong="H4481"\w* \w la|strong="H4481"\w* \w terre|strong="H4481"\w*,  
\v 21 \w cet|strong="H1836"\w* arbre \w dont|strong="H1768"\w* \w le|strong="H5922"\w* \w feuillage|strong="H5922"\w* \w était|strong="H4430"\w* magnifique \w et|strong="H4430"\w* \w les|strong="H5922"\w* fruits abondants, \w qui|strong="H4430"\w* portait \w de|strong="H4430"\w* \w la|strong="H5922"\w* \w nourriture|strong="H1768"\w* \w pour|strong="H5922"\w* tous, sous lequel s'abritaient \w les|strong="H5922"\w* \w bêtes|strong="H5922"\w* \w des|strong="H4430"\w* champs, \w et|strong="H4430"\w* \w sur|strong="H5922"\w* \w les|strong="H5922"\w* branches duquel nichaient \w les|strong="H5922"\w* \w oiseaux|strong="H5922"\w* \w du|strong="H5922"\w* ciel,  
\v 22 c'\w est|strong="H1934"\w* \w toi|strong="H5922"\w*, ô \w roi|strong="H4481"\w*, \w qui|strong="H4437"\w* \w as|strong="H1768"\w* grandi \w et|strong="H4481"\w* \w qui|strong="H4437"\w* \w es|strong="H1768"\w* devenu \w puissant|strong="H7990"\w* ; \w ta|strong="H5922"\w* grandeur s'\w est|strong="H1934"\w* accrue \w et|strong="H4481"\w* \w a|strong="H3068"\w* atteint \w le|strong="H5922"\w* \w ciel|strong="H8065"\w*, \w et|strong="H4481"\w* \w ta|strong="H5922"\w* domination s'étend jusqu'\w aux|strong="H5922"\w* \w extrémités|strong="H4481"\w* \w de|strong="H4481"\w* \w la|strong="H4481"\w* \w terre|strong="H4481"\w*.   
\pi1
\v 23 » \w Le|strong="H4481"\w* \w roi|strong="H4481"\w* \w a|strong="H3068"\w* vu \w un|strong="H4481"\w* veilleur saint descendre \w du|strong="H4481"\w* \w ciel|strong="H8065"\w* \w et|strong="H4481"\w* dire : « Abattez l'arbre \w et|strong="H4481"\w* détruisez-le ; toutefois, \w laissez|strong="H7662"\w* \w en|strong="H4481"\w* \w terre|strong="H4481"\w* \w la|strong="H4481"\w* souche \w de|strong="H4481"\w* ses \w racines|strong="H8330"\w*, liée avec \w des|strong="H4481"\w* \w chaînes|strong="H4481"\w* \w de|strong="H4481"\w* \w fer|strong="H4481"\w* \w et|strong="H4481"\w* \w de|strong="H4481"\w* bronze, dans \w la|strong="H4481"\w* tendre herbe \w des|strong="H4481"\w* champs ; \w qu|strong="H1768"\w*'\w il|strong="H4481"\w* soit trempé \w par|strong="H4481"\w* \w la|strong="H4481"\w* \w rosée|strong="H4481"\w* \w du|strong="H4481"\w* \w ciel|strong="H8065"\w*, \w et|strong="H4481"\w* \w que|strong="H1768"\w* \w sa|strong="H4481"\w* \w part|strong="H4481"\w* soit avec \w les|strong="H4481"\w* \w bêtes|strong="H4481"\w* \w des|strong="H4481"\w* champs, jusqu'\w à|strong="H4481"\w* \w ce|strong="H4481"\w* \w que|strong="H1768"\w* sept temps passent sur \w lui|strong="H4481"\w*. »   
\pi1
\v 24 » \w Voici|strong="H2006"\w* l'interprétation, ô \w roi|strong="H4430"\w*, \w et|strong="H4430"\w* c'\w est|strong="H1934"\w* \w le|strong="H5922"\w* \w décret|strong="H5922"\w* \w du|strong="H5922"\w* Très-Haut \w qui|strong="H4430"\w* \w s|strong="H2006"\w*'abat \w sur|strong="H5922"\w* \w mon|strong="H5922"\w* \w seigneur|strong="H5922"\w* \w le|strong="H5922"\w* \w roi|strong="H4430"\w* :  
\v 25 \w Tu|strong="H5922"\w* seras chassé \w du|strong="H5922"\w* \w milieu|strong="H5922"\w* \w des|strong="H4430"\w* \w hommes|strong="H3606"\w*, \w et|strong="H4430"\w* \w ta|strong="H5922"\w* demeure \w sera|strong="H4430"\w* avec \w les|strong="H3606"\w* \w bêtes|strong="H3606"\w* \w des|strong="H4430"\w* champs. \w On|strong="H4430"\w* \w te|strong="H5922"\w* fera manger \w de|strong="H4430"\w* l'herbe comme \w les|strong="H3606"\w* \w bœufs|strong="H5922"\w*, \w tu|strong="H5922"\w* seras trempé par \w la|strong="H3606"\w* \w rosée|strong="H3606"\w* \w du|strong="H5922"\w* ciel, \w et|strong="H4430"\w* sept temps passeront \w sur|strong="H5922"\w* \w toi|strong="H5922"\w*, jusqu'\w à|strong="H5922"\w* \w ce|strong="H4430"\w* \w que|strong="H3606"\w* \w tu|strong="H5922"\w* reconnaisses \w que|strong="H3606"\w* \w le|strong="H5922"\w* Très-Haut domine \w sur|strong="H5922"\w* \w la|strong="H3606"\w* royauté \w des|strong="H4430"\w* \w hommes|strong="H3606"\w*, \w et|strong="H4430"\w* \w qu|strong="H3606"\w*'\w il|strong="H5922"\w* \w la|strong="H3606"\w* \w donne|strong="H5922"\w* \w à|strong="H5922"\w* \w qui|strong="H3606"\w* \w il|strong="H5922"\w* veut.  
\v 26 Quant \w à|strong="H5922"\w* l'ordre \w de|strong="H5922"\w* \w laisser|strong="H1965"\w* \w la|strong="H5922"\w* souche \w et|strong="H4437"\w* \w les|strong="H5922"\w* \w racines|strong="H5922"\w* \w de|strong="H5922"\w* l'arbre, \w ton|strong="H5922"\w* \w royaume|strong="H4437"\w* \w te|strong="H5922"\w* \w sera|strong="H1934"\w* assuré \w dès|strong="H1768"\w* \w que|strong="H1768"\w* \w tu|strong="H1768"\w* \w auras|strong="H5922"\w* reconnu \w que|strong="H1768"\w* \w le|strong="H5922"\w* Ciel \w domine|strong="H4437"\w*.  
\v 27 C'\w est|strong="H4437"\w* pourquoi, ô \w roi|strong="H4430"\w*, \w que|strong="H1768"\w* mon conseil \w te|strong="H4437"\w* \w soit|strong="H4430"\w* agréable : mets \w un|strong="H1668"\w* \w terme|strong="H1668"\w* \w à|strong="H4430"\w* \w tes|strong="H3809"\w* \w péchés|strong="H3809"\w* par \w la|strong="H1768"\w* justice, \w et|strong="H4430"\w* \w à|strong="H4430"\w* \w tes|strong="H3809"\w* \w iniquités|strong="H3809"\w* \w en|strong="H4430"\w* faisant miséricorde aux pauvres. Peut-être \w que|strong="H1768"\w* ta tranquillité \w sera|strong="H4430"\w* prolongée. »   
\pi1
\v 28 Tout \w cela|strong="H4406"\w* s'accomplit sur \w le|strong="H4481"\w* \w roi|strong="H4430"\w* \w Nébucadnetsar|strong="H5020"\w*.  
\v 29 \w Au|strong="H5922"\w* \w bout|strong="H3046"\w* \w de|strong="H4481"\w* douze mois, \w il|strong="H5922"\w* se promenait \w dans|strong="H5922"\w* \w le|strong="H5922"\w* \w palais|strong="H5922"\w* \w royal|strong="H4437"\w* \w de|strong="H4481"\w* \w Babylone|strong="H4481"\w*.  
\v 30 \w Le|strong="H5922"\w* \w roi|strong="H4481"\w* \w prit|strong="H5020"\w* \w la|strong="H4481"\w* \w parole|strong="H4406"\w* : « N'est-ce pas \w ici|strong="H5705"\w* l'illustre \w Babylone|strong="H4481"\w*, \w que|strong="H1768"\w* \w j|strong="H4481"\w*'ai bâtie \w pour|strong="H5922"\w* \w être|strong="H4481"\w* \w une|strong="H5705"\w* résidence royale, \w par|strong="H4481"\w* \w la|strong="H4481"\w* \w force|strong="H5922"\w* \w de|strong="H4481"\w* \w ma|strong="H5922"\w* \w puissance|strong="H4481"\w* \w et|strong="H4481"\w* \w pour|strong="H5922"\w* \w la|strong="H4481"\w* \w gloire|strong="H4481"\w* \w de|strong="H4481"\w* \w ma|strong="H5922"\w* majesté ? »   
\pi1
\v 31 \w La|strong="H5922"\w* \w parole|strong="H1768"\w* était encore \w dans|strong="H5922"\w* \w la|strong="H5922"\w* \w bouche|strong="H5922"\w* \w du|strong="H5922"\w* roi \w qu|strong="H1768"\w*'une voix descendit \w du|strong="H5922"\w* \w ciel|strong="H8065"\w* : « Apprends, roi \w Nébucadnetsar|strong="H5020"\w*, \w que|strong="H1768"\w* \w le|strong="H5922"\w* \w royaume|strong="H4437"\w* t'\w est|strong="H5922"\w* retiré.  
\v 32 \w Tu|strong="H1768"\w* \w seras|strong="H1768"\w* chassé du milieu \w des|strong="H1768"\w* \w hommes|strong="H3606"\w*, \w et|strong="H3809"\w* ta \w demeure|strong="H1753"\w* \w sera|strong="H3809"\w* \w avec|strong="H5648"\w* \w les|strong="H3606"\w* \w bêtes|strong="H3606"\w* \w des|strong="H1768"\w* champs. On te \w fera|strong="H5648"\w* manger \w de|strong="H3809"\w* l'herbe comme \w les|strong="H3606"\w* bœufs. Sept temps passeront \w sur|strong="H1753"\w* toi, jusqu'à \w ce|strong="H4101"\w* \w que|strong="H1768"\w* \w tu|strong="H1768"\w* reconnaisses \w que|strong="H1768"\w* \w le|strong="H3606"\w* Très-Haut domine \w sur|strong="H1753"\w* \w la|strong="H3606"\w* royauté \w des|strong="H1768"\w* \w hommes|strong="H3606"\w*, \w et|strong="H3809"\w* \w qu|strong="H1768"\w*'il \w la|strong="H3606"\w* donne à \w qui|strong="H4101"\w* il veut. »   
\pi1
\v 33 \w À|strong="H5922"\w* l'heure \w même|strong="H4437"\w*, cette parole s'accomplit \w sur|strong="H5922"\w* Nébucadnetsar. \w Il|strong="H5922"\w* \w fut|strong="H5922"\w* chassé \w du|strong="H5922"\w* \w milieu|strong="H5922"\w* \w des|strong="H4437"\w* hommes \w et|strong="H4437"\w* \w mangea|strong="H5922"\w* \w de|strong="H5922"\w* l'herbe comme \w les|strong="H5922"\w* \w bœufs|strong="H5922"\w* ; \w son|strong="H5922"\w* corps \w fut|strong="H5922"\w* trempé par \w la|strong="H5922"\w* \w rosée|strong="H5922"\w* \w du|strong="H5922"\w* ciel, jusqu'\w à|strong="H5922"\w* \w ce|strong="H5922"\w* que \w ses|strong="H5922"\w* cheveux poussent comme \w les|strong="H5922"\w* \w plumes|strong="H5922"\w* \w des|strong="H4437"\w* aigles, \w et|strong="H4437"\w* \w ses|strong="H5922"\w* ongles comme \w les|strong="H5922"\w* griffes \w des|strong="H4437"\w* \w oiseaux|strong="H5922"\w*.   
\pi1
\v 34 \w À|strong="H4430"\w* \w la|strong="H3606"\w* fin \w de|strong="H4430"\w* \w ces|strong="H3606"\w* jours, moi, \w Nébucadnetsar|strong="H5020"\w*, je levai \w les|strong="H3606"\w* yeux vers \w le|strong="H3606"\w* \w ciel|strong="H8065"\w*, \w et|strong="H4430"\w* \w la|strong="H3606"\w* raison me revint. \w Je|strong="H3068"\w* bénis \w le|strong="H3606"\w* Très-Haut, je louai \w et|strong="H4430"\w* glorifiai \w celui|strong="H4430"\w* \w qui|strong="H3606"\w* vit éternellement,  
\q1 car sa domination est \w une|strong="H4430"\w* domination éternelle,  
\q2 \w et|strong="H4430"\w* son \w règne|strong="H3606"\w* subsiste \w de|strong="H4430"\w* \w génération|strong="H4430"\w* \w en|strong="H4430"\w* \w génération|strong="H4430"\w*.   
\q1
\v 35 Tous les habitants de la terre sont comptés pour rien ;  
\q2 il agit comme il lui plaît avec l'armée des cieux  
\q2 et avec les habitants de la terre ;  
\q1 et personne ne peut arrêter sa main,  
\q2 ni lui dire : « Que fais-tu ? »   
\pi1
\v 36 En ce même temps, la raison me revint ; la gloire de mon royaume, ma majesté et ma splendeur me furent rendues. Mes conseillers et mes grands me cherchèrent ; je fus rétabli dans mon royaume, et ma grandeur s'accrut encore.  
\v 37 Maintenant, moi, Nébucadnetsar, je loue, j'exalte et je glorifie le Roi des cieux, car toutes ses œuvres sont vérité et ses voies sont justice ; et il \w a|strong="H3068"\w* le pouvoir d'abaisser ceux qui marchent dans l'orgueil.   
\c 5
\p
\v 1 \w Le|strong="H6903"\w* \w roi|strong="H4430"\w* \w Belschatsar|strong="H1113"\w* \w fit|strong="H4430"\w* \w un|strong="H5648"\w* \w grand|strong="H7229"\w* \w festin|strong="H3900"\w* pour mille \w de|strong="H4430"\w* \w ses|strong="H4430"\w* dignitaires, \w et|strong="H4430"\w* \w il|strong="H7229"\w* \w but|strong="H8355"\w* \w du|strong="H8355"\w* \w vin|strong="H2562"\w* \w en|strong="H4430"\w* \w leur|strong="H5648"\w* \w présence|strong="H6903"\w*.  
