\v 10  \w You|strong="H5921"\w* \w will|strong="H1961"\w* \w cultivate|strong="H5647"\w* \w the|strong="H5921"\w* land \w for|strong="H5921"\w* \w him|strong="H5921"\w* – \w you|strong="H5921"\w* \w and|strong="H1121"\w* \w your|strong="H5921"\w* \w sons|strong="H1121"\w* \w and|strong="H1121"\w* \w your|strong="H5921"\w* \w servants|strong="H5650"\w*. \w You|strong="H5921"\w* \w will|strong="H1961"\w* \w bring|strong="H1961"\w* \w its|strong="H5921"\w* \w produce|strong="H1961"\w* \w and|strong="H1121"\w* \w it|strong="H5921"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w food|strong="H3899"\w* \w for|strong="H5921"\w* \w your|strong="H5921"\w* master’s \w grandson|strong="H1121"\w* \w to|strong="H1961"\w* \w eat|strong="H3899"\w*. \w But|strong="H1961"\w* \w Mephibosheth|strong="H4648"\w*, \w your|strong="H5921"\w* master’s \w grandson|strong="H1121"\w*, \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w a|strong="H3068"\w* \w regular|strong="H8548"\w* guest \w at|strong="H5921"\w* \w my|strong="H5921"\w* \w table|strong="H7979"\w*.” (\w Now|strong="H1961"\w* \w Ziba|strong="H6717"\w* \w had|strong="H1961"\w* \w fifteen|strong="H2568"\w* \w sons|strong="H1121"\w* \w and|strong="H1121"\w* \w twenty|strong="H6242"\w* \w servants|strong="H5650"\w*.)   
\p
\v 11  \w Ziba|strong="H6717"\w* \w said|strong="H3651"\w* \w to|strong="H6213"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w*, “\w Your|strong="H3605"\w* \w servant|strong="H5650"\w* \w will|strong="H4428"\w* \w do|strong="H6213"\w* \w everything|strong="H3605"\w* \w that|strong="H3605"\w* \w my|strong="H3605"\w* lord \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w has|strong="H4428"\w* \w instructed|strong="H6680"\w* \w his|strong="H3605"\w* \w servant|strong="H5650"\w* \w to|strong="H6213"\w* \w do|strong="H6213"\w*.” \w So|strong="H3651"\w* \w Mephibosheth|strong="H4648"\w* \w was|strong="H4428"\w* \w a|strong="H3068"\w* regular guest \w at|strong="H5921"\w* David’s \w table|strong="H7979"\w*, \w just|strong="H3605"\w* \w as|strong="H6213"\w* though \w he|strong="H6213"\w* \w were|strong="H1121"\w* \w one|strong="H3605"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w*’s \w sons|strong="H1121"\w*.   
