\v 5 \w Kai|strong="H9901"\w* he \w tui|strong="H4325"\w* loh ka \w hinglu|strong="H5315"\w* \w duela|strong="H5704"\w* a \w li|strong="H0661"\w* tih, \w tuidung|strong="H8415"\w* loh \w kai|strong="H9901"\w* m'\w vael|strong="H5437"\w*. \w Carhaek|strong="H5488"\w* loh \w ka|strong="H9901"\w* \w lu|strong="H7218"\w* a \w bol|strong="H2280"\w*.  
\v 6 \w Tlang|strong="H2022"\w* \w yung|strong="H7095"\w* \w duela|strong="H9997"\w* ka \w suntla|strong="H3381"\w* tih \w diklai|strong="H0776"\w* loh \w a|strong="H9907"\w* \w thohkalh|strong="H1280"\w* te \w kai|strong="H9901"\w* \w ham|strong="H1157"\w* \w kumhal|strong="H5769"\w* \w duela|strong="H9997"\w* a kalh. \w Tedae|strong="H9999"\w* \w ka|strong="H9901"\w* \w Pathen|strong="H0430"\w* \w BOEIPA|strong="H3068"\w* loh \w ka|strong="H9901"\w* \w hingnah|strong="H2416"\w* he \w vaam|strong="H7845"\w* \w lamloh|strong="H4480"\w* na \w doek|strong="H5927"\w*.  
\v 7 \w Kai|strong="H9901"\w* \w lamkah|strong="H5921"\w* ka \w rhae|strong="H5848"\w* \w vaengah|strong="H9996"\w* \w BOEIPA|strong="H3068"\w* \w te|strong="H0853"\w* \w ka|strong="H9901"\w* \w hinglu|strong="H5315"\w* neh ka \w poek|strong="H2142"\w*. \w Namah|strong="H9905"\w* kah \w hmuencim|strong="H6944"\w* \w bawkim|strong="H1964"\w* \w ah|strong="H0413"\w* \w ka|strong="H9901"\w* \w thangthuinah|strong="H8605"\w* te \w namah|strong="H9905"\w* \w taengla|strong="H0413"\w* ham \w pha|strong="H0935"\w*.  
\v 8 A \w honghi|strong="H1892"\w* aka \w ngaithuen|strong="H8104"\w* rhoek loh a \w poeyoek|strong="H7723"\w* la \w a|strong="H9908"\w* \w sitlohnah|strong="H2617"\w* a \w hnawt|strong="H5800"\w* uh.  
\v 9 \w Tedae|strong="H9999"\w* \w kai|strong="H0589"\w* tah \w namah|strong="H9903"\w* \w taengah|strong="H9997"\w* \w uemonah|strong="H8426"\w* \w ol|strong="H6963"\w* \w neh|strong="H9996"\w* kan \w nawn|strong="H2076"\w* vetih ka \w caeng|strong="H5087"\w* \w bangla|strong="H0834"\w* \w BOEIPA|strong="H3068"\w* \w lamkah|strong="H9997"\w* \w khangnah|strong="H3444"\w* te ka \w thuung|strong="H7999"\w* ni,” a \w ti|strong="H0559"\w*.  
