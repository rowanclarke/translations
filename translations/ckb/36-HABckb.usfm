\id HAB - Biblica® Open Kurdi Sorani Standard Version 
\h حەبەقوق 
\toc1 حەبەقوق 
\toc2 حەبەقوق 
\toc3 حەبەقوق 
\mt1 حەبەقوق 
\c 1  
\p  
\v 1 ئەو سروشەی\f + \fr 1:1 \ft فەرموودەیەکی خودایە کە لە ڕێگای ڕۆحی پیرۆزەوە بۆ مرۆڤ هاتبێت.‏\f* کە بۆ حەبەقوقی پێغەمبەر هات. 
\b  
\s1 سکاڵای حەبەقوق 
\q1  
\v 2 ئەی یەزدان، هەتا کەی هانات بۆ بهێنم و 
\q2 تۆش گوێ ناگریت؟ 
\q1 هەتا کەی لە دەست ستەم هاوارت بۆ دەهێنم و 
\q2 تۆش ڕزگار ناکەیت؟ 
\q1  
\v 3 بۆ چی ناڕەواییم پیشان دەدەیت؟ 
\q2 بۆ چی بەرگەی خراپە دەگریت؟ 
\q1 وێرانکردن و ستەم لەبەردەممە، 
\q2 ناکۆکی و ڕکابەری سەرهەڵدەدات. 
\q1  
\v 4 لەبەر ئەوە تەورات لەکارخراوە و 
\q2 دادپەروەری قەد سەرکەوتوو نابێت. 
\q1 خراپەکار گەمارۆی کەسی ڕاستودروستی دا، 
\q2 لەبەر ئەوە دادپەروەری دەشێوێنرێت. 
\s1 وەڵامی یەزدان 
\q1  
\v 5 «تەماشای نەتەوەکان بکەن و سەرنج بدەن، 
\q2 بە تەواوی سەرسام بن، 
\q1 چونکە لە سەردەمی ئێوەدا کارێکی وا دەکەم، 
\q2 ئەگەر باس بکرێت باوەڕ ناکەن. 
\q1  
\v 6 من بابلییەکان\f + \fr 1:6 \ft عیبری: کلدانییەکان؛ لەژێر سەرکردایەتی نەبوخودنەسری دووەم بوون.‏\f* هەڵدەستێنمەوە، 
\q2 گەلێکی دڵڕەق و بە پەلە، 
\q1 بە فراوانی زەوی ڕێگای گرتووەتەبەر، 
\q2 بۆ داگیرکردنی ئەو نشینگانەی کە هی خۆی نییە. 
\q1  
\v 7 تۆقێنەر و ترسێنەرە، 
\q2 خۆیان حوکم دادەنێن و 
\q2 شکۆی خۆیان دەسەپێنن. 
\q1  
\v 8 ئەسپەکانیان لە پڵنگ بەتاوترن و 
\q2 لە گورگی ئێواران توندوتیژترن، 
\q1 سوارەکانی بە پڕتاوی 
\q2 لە دوورەوە دێن، 
\q1 وەک هەڵۆیەکی بە پەلە بۆ خواردن دەفڕن. 
\q2  
\v 9 هەموو بۆ ستەمکاری دێن، 
\q1 ئاپۆرەکەیان وەک بای ڕۆژهەڵات بەرەو پێش دەچێت، 
\q2 وەک لم دیل کۆدەکەنەوە. 
\q1  
\v 10 گاڵتە بە پاشایان دەکەن و 
\q2 میران دەکەنە گاڵتەجاڕ، 
\q1 بە هەموو شارێکی قەڵابەند پێدەکەنن، 
\q2 خۆڵ دەکەنە گرد و دەیگرن. 
\q1  
\v 11 ئینجا وەک با هەڵدەکەن و دەڕۆن، 
\q2 تاوانبارن، هێزی خۆیان دەپەرستن.» 
\s1 دووەم سکاڵای حەبەقوق 
\q1  
\v 12 ئەی یەزدان، ئایا تۆ لە ئەزەلەوە نیت؟ 
\q2 خودای من، پیرۆزەکەم، تۆ هەرگیز نامریت. 
\q1 ئەی یەزدان، بابلییەکانت بۆ جێبەجێکردنی حوکمەکانت دانا، 
\q2 ئەی تاشەبەرد، ئەرکی سزادانت بەوان سپاردووە. 
\q1  
\v 13 چاوەکانت لەوە پاکترن تەماشای خراپە بکەن، 
\q2 ناتوانیت بەرگەی خراپەکاری بگریت. 
\q1 کەواتە بۆچی بەرگەی ناپاکەکان دەگریت؟ 
\q2 بۆچی بێدەنگ دەبیت کاتێک بەدکار کەسێکی لە خۆی ڕاستودروستتر قووت دەدات؟ 
\q1  
\v 14 مرۆڤ وەک ماسی دەریا لێدەکەیت، 
\q2 وەک بوونەوەری ئاوی کە فەرمانڕەوای نییە. 
\q1  
\v 15 دوژمنی خراپەکار بە قولاپەکەی هەمووان سەردەخات، 
\q2 بە تۆڕەکەی ڕاویان دەکات، 
\q1 لەناو تۆڕەکەی کۆیان دەکاتەوە، 
\q2 لەبەر ئەوە شاد و دڵخۆشە. 
\q1  
\v 16 هەر لەبەر ئەوەش قوربانی بۆ تۆڕەکەی سەردەبڕێت و 
\q2 بخووری بۆ دەسووتێنێت، 
\q1 چونکە بەهۆی تۆڕەکەیەوە خۆش ڕادەبوێرێت و 
\q2 خواردنەکەی چەورە. 
\q1  
\v 17 هەتا کەی بەردەوام دەبێ لەوەی بە تۆڕەکەی ڕاو بکات، 
\q2 بە بێ بەزەیی نەتەوەکان لەناوببات؟ 
\b  
\c 2  
\q1  
\v 1 لە خاڵی چاودێریکردنەکەم دەوەستم و 
\q2 سەردەکەومە سەر قوللەی چاودێری، 
\q1 چاوەڕێ دەکەم تاکو بزانم یەزدان چیم پێ دەڵێت و 
\q2 بۆ وەڵامی ئەو سکاڵایە چی بڵێم. 
\s1 وەڵامی یەزدان 
\p  
\v 2 ئینجا یەزدان وەڵامی دامەوە و فەرمووی: 
\q1 «سروشەکە\f + \fr 2:2 \ft فەرموودەیەکی خودایە کە لە ڕێگای ڕۆحی پیرۆزەوە بۆ مرۆڤ هاتبێت.‏\f* بنووسەوە و 
\q2 لەسەر تابلۆ هەڵیبکۆڵە، 
\q2 تاکو پەیامنێر بە دروستی پەیامەکە بگەیەنێت، 
\q1  
\v 3 چونکە سروشەکە بۆ کاتی دیاریکراوە، 
\q2 باسی کۆتایی دەکات و 
\q2 درۆ ناکات. 
\q1 ئەگەر درێژەی کێشا چاوەڕێی بکە، 
\q2 چونکە بێگومان دێت و دواناکەوێت. 
\b  
\q1  
\v 4 «تەماشا، دوژمن\f + \fr 2:4 \ft مەبەستی لە بابلییەکانە بڕوانە 1‏:13‏،15.‏\f* خۆی گف کردووەتەوە، 
\q2 ئارەزووەکانی ڕەوا نییە، 
\q2 بەڵام کەسی ڕاستودروست بە باوەڕی خۆی دەژیێت. 
\q1  
\v 5 لە ڕاستیدا شەراب فریوی دەدات، 
\q2 لەخۆباییە و هەرگیز هێور نابێتەوە، 
\q1 چونکە وەک گۆڕ ئارەزووی بەرفراوانە، 
\q2 وەک مردنە، هەرگیز تێر نابێت، 
\q1 هەموو نەتەوەکان بۆ خۆی کۆدەکاتەوە و 
\q2 هەموو گەلان بە دیل دەگرێت. 
\p  
\v 6 «ئایا گەلەکان پەند و توانج لەو ناگرن، دەڵێن: 
\q1 «”قوڕبەسەر ئەوەی شتی دزراو کەڵەکە دەکات و 
\q2 بە ستەمکاری خۆی دەوڵەمەند دەکات! 
\q2 ئەو دۆخە هەتا کەی بەردەوام دەبێت؟“ 
\q1  
\v 7 ئایا قەرزدەرەکانت کتوپڕ لێت ڕاستنابنەوە؟ 
\q2 ئایا بەئاگا نایێن و ناتلەقێنن؟ 
\q2 ئینجا دەبیتە دەستکەوت بۆیان. 
\q1  
\v 8 لەبەر ئەوەی تۆ چەندین نەتەوەت تاڵان کرد، 
\q2 ئەو گەلانەی کە ماونەتەوە تۆ تاڵان دەکەن، 
\q1 لەبەر ئەوەی تۆ خوێنی مرۆڤت ڕشت، 
\q2 تۆ خاک و شار و هەموو دانیشتووانەکەیت وێران کرد. 
\b  
\q1  
\v 9 «قوڕبەسەر ئەوەی دەستکەوتی ناڕەوا بۆ ماڵەکەی بەدەستدەهێنێت و 
\q2 هێلانەکەی لە بەرزایی دادەنێت، 
\q2 تاکو لە چنگی خراپە دەرباز بێت! 
\q1  
\v 10 پیلانی ڕیشەکێشکردنی گەلانێکی زۆرت گێڕا، 
\q2 شەرمەزاریت هێنایە سەر ماڵەکەت و خۆتت دۆڕاند. 
\q1  
\v 11 لەبەر ئەوە بەرد لەناو دیوارەوە هاوار دەکات و 
\q2 کاریتەش لە دارەوە دەنگ دەداتەوە. 
\b  
\q1  
\v 12 «قوڕبەسەر ئەوەی بە خوێنڕشتن شار بنیاد دەنێت و 
\q2 بە ستەمکاری شارۆچکە دادەمەزرێنێت. 
\q1  
\v 13 ئایا ئەوە لەلایەن یەزدانی سوپاسالارەوە نییە 
\q2 کە ماندووبوونی گەلان تەنها بۆ ئاگر بێت، 
\q2 شەکەتبوونی نەتەوەکان بێ سوود بێت؟ 
\q1  
\v 14 چونکە زەوی پڕ دەبێت لە ناسینی شکۆمەندی یەزدان، 
\q2 هەروەک ئاو دەریا دادەپۆشێت. 
\b  
\q1  
\v 15 «قوڕبەسەر ئەوەی شەراب دەرخواردی نزیکەکەی دەدات، 
\q2 هەتا سەرخۆش دەبێت لە مەشکەکەوە بۆی تێدەکات، 
\q2 تاکو جەستەیان بە ڕووتی ببینێت. 
\q1  
\v 16 تێردەبیت لە شەرمەزاری لە جیاتی شکۆمەندی. 
\q2 ئێستا نۆرەی تۆیە! بینۆشە و ڕووت ببەوە، 
\q1 جامی دەستی ڕاستی یەزدان دێتە سەر تۆ، 
\q2 شەرمەزاریش شکۆی تۆ دادەپۆشێت. 
\q1  
\v 17 ئەو ستەمەی لە لوبنانت کرد بەسەرت دێتەوە، 
\q2 لەناوبردنی ئاژەڵەکانی دەتترسێنێت. 
\q1 لەبەر ئەوەی تۆ خوێنی مرۆڤت ڕشت، 
\q2 تۆ خاک و شار و هەموو دانیشتووانەکەیت وێران کرد. 
\b  
\q1  
\v 18 «ئەو بتەی کە دەتاشرێت چ کەڵکێکی هەیە؟ 
\q2 یان ئەو پەیکەرە لەقاڵبدراوەی خەڵکی فێری درۆ دەکات؟ 
\q1 چونکە دروستکەرەکەی پشتی پێ دەبەستێت، 
\q2 بتێکی دروستکردووە ناتوانێت قسە بکات. 
\q1  
\v 19 قوڕبەسەر ئەوەی بە تەختەدار دەڵێت: ”هەستە!“ 
\q2 بە بەردی بێ هەست و نەست: ”بە ئاگابە!“ 
\q1 ئایا دەتوانێت ڕێنمایی بکات؟ 
\q2 بە زێڕ و زیو ڕووکەش کراوە، 
\q2 ڕۆحی تێدا نییە.» 
\b  
\q1  
\v 20 بەڵام یەزدان لەناو پەرستگای پیرۆزیدایە، 
\q2 با هەموو دانیشتووانی زەوی لەبەردەمیدا بێدەنگ بن. 
\c 3  
\s1 نوێژێکی حەبەقوق 
\d  
\v 1 نوێژێکی حەبەقوقی پێغەمبەر. لەسەر ئاوازی «شگیانۆت»: 
\q1  
\v 2 ئەی یەزدان، هەواڵی تۆم بیست، 
\q2 ئەی یەزدان، لە کارەکانت ترسام، 
\q1 لە سەردەمی ئێمە دووبارەیان بکەوە، 
\q2 با لە سەردەمی ئێمە بزانرێن، 
\q2 لە تووڕەییدا بەزەیی بهێنەرەوە یادت! 
\b  
\q1  
\v 3 خودا لە تێمانەوە هات، 
\q2 پیرۆزەکە لە کێوی پارانەوە هات.\f + \fr 3:3 \ft لە دەقی عیبری لێرە و لە ناوەڕاستی ئایەتی 9 و لە کۆتایی ئایەتی 13، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1 شکۆی ئەو ئاسمانی داپۆشیوە و 
\q2 ستایشی ئەو زەوی پڕکردووە. 
\q1  
\v 4 پڕشنگی ئەو وەک تیشکی بەرەبەیانە، 
\q2 لە دەستیەوە ڕووناکی دەبارێت، 
\q2 لەوێدا توانای شاردرابووەوە. 
\q1  
\v 5 پەتا لەپێشیەوە ڕۆیشت، 
\q2 گرانەتاش لەدوای هەنگاوەکانی ئەو بوو. 
\q1  
\v 6 ڕاوەستا و زەوی هەژاند، 
\q2 تەماشای کرد و هەموو گەلەکانی لەرزاند. 
\q1 چیا دێرینەکان کوتران، 
\q2 گردە لەمێژینەکان هاتنە خوارەوە، 
\q2 بەڵام یەزدان جاویدانییە. 
\q1  
\v 7 چادرەکانی کوشانم لە تەنگوچەڵەمەدا بینی، 
\q2 ڕەشماڵەکانی میدیان دەلەرزین. 
\b  
\q1  
\v 8 ئەی یەزدان، ئایا جۆشی تووڕەیی تۆ لە ڕووبارەکان بوو؟ 
\q2 ئایا لە ڕووبارەکان تووڕە بوویت؟ 
\q1 ئایا هەڵچوونی تۆ لە دەریا بوو، 
\q2 تاکو سواری ئەسپ بیت و 
\q2 گالیسکەکانت بەرەو سەرکەوتن بچن؟ 
\q1  
\v 9 کەوانەکەی خۆتت ئامادە کرد و 
\q2 داوای تیرێکی زۆرت کرد. 
\q1 بە ڕووبارەکان زەویت شەقکردووە، 
\q2  
\v 10 چیاکان تۆیان بینی و لەرزین، 
\q1 لافاوی ئاوەکان تێپەڕین، 
\q2 قووڵاییەکان دەنگیان هات، 
\q2 شەپۆلەکانی بەرزبوونەوە. 
\b  
\q1  
\v 11 خۆر و مانگ لە ئاسمان وەستان\f + \fr 3:11 \ft بڕوانە \xt یەشوع 10‏:12‏-14.‏\ft ‏\f*، 
\q2 بە بریسکانەوەی تیرە هاوێژراوەکانت، 
\q2 بە درەوشانەوەی ڕمە پڕشنگدارەکەت. 
\q1  
\v 12 بە تووڕەییەوە لەسەر زەوی گەڕایت، 
\q2 بە تووڕەییەوە نەتەوەکانت وردوخاش کرد. 
\q1  
\v 13 بۆ ڕزگارکردنی گەلەکەت هاتییە دەرەوە، 
\q2 بۆ ڕزگارکردنی دەستنیشانکراوەکەت. 
\q1 سەرۆکی وڵاتی بەدکارت وردوخاش کرد، 
\q2 لە سەرەوە هەتا پێی ڕووتت کردەوە. 
\q1  
\v 14 بە تیرەکانی خۆی سەری سەرکردەکانی ئەوت کونت کرد، 
\q2 کاتێک هێرشیان هێنا بۆ پەرتەوازەکردنمان، 
\q1 خۆشیان ئامادە کرد 
\q2 بۆ ڕاوکردنی ئەو کڵۆڵەی خۆی ماتداوە. 
\q1  
\v 15 بە ئەسپەکانت بەناو دەریادا ڕێگات گرتەبەر، 
\q2 ئاوە زۆرەکانت هەژاند. 
\b  
\q1  
\v 16 بیستم و هەناوم کەوتە خوارەوە، 
\q2 لەبەر دەنگەکە لێوەکانم لەرزین، 
\q1 ئێسکەکانم کلۆر بوون، 
\q2 چۆکم لەرزی. 
\q1 لەگەڵ ئەوەشدا بە ئارامییەوە چاوەڕێی ڕۆژی تەنگانەم 
\q2 بۆ ئەو نەتەوانەی هێرشیان هێنایە سەرم. 
\q1  
\v 17 لەگەڵ ئەوەی دار هەنجیر گوڵ ناکات و 
\q2 دار مێوەکان هێشووە ترێیان نییە، 
\q1 لەگەڵ ئەوەی دار زەیتوون بەر ناگرێت و 
\q2 کێڵگەکان خواردن بەرهەم ناهێنن، 
\q1 لەگەڵ ئەوەی مەڕ لە پشتیر\f + \fr 3:17 \ft پشتیر: گەوڕ، شوێنێکی تایبەت بووە بە پەروەردەکردنی ئاژەڵ.‏\f* دەبڕدرێتەوە و 
\q2 مانگا لەسەر ئاخوڕ نییە، 
\q1  
\v 18 بەڵام من بە یەزدان دڵشاد دەبم، 
\q2 بە خودای ڕزگارکەرم دڵخۆش دەبم. 
\b  
\q1  
\v 19 یەزدانی پەروەردگار هێزی منە، 
\q2 پێیەکانم وەک پێی ئاسک لێدەکات، 
\q2 توانام پێ دەبەخشێت بچمە سەر بەرزاییەکان. 
\b  
\d بۆ سەرۆکی گۆرانیبێژەکان، لەسەر ئامێرە ژێدارەکانم.