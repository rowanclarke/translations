\id GAL
\h  إِڭَالَاطِييّنْ 
\toc1  إِڭَالَاطِييّنْ 
\toc2  إِڭَالَاطِييّنْ 
\toc3 ڭال. 
\mt1 إِڭَالَاطِييّنْ  
\c 1
\s1 أَسدْجمْ غَارْ ؤُمزْوَارُو  
\m
\v 1 بُولُوسْ، رَّاسُولْ - وَارْ إِدْجِي زڭْ إِوْذَانْ ؤُڒَا س \add ڒْْخَاضَارْ ن\add* إِجّْ ن بْنَاذمْ، مَاشَا س يَاسُوع لْمَاسِيحْ، ؤُ س أَربِّي، بَابَاسْ، ونِّي إِ-ث-إِ-د-إِسّْنكَّارنْ زِي ثَادَّارْثْ ن إِمتِّيننْ - \f ◼ \fr 1:‏1 \ft \+bd ’رَّاسُولْ‘\+bd* - نِيغْ ’أَمَازَانْ‘.\f*  
\v 2 ؤُ مَارَّا أَوْمَاثنْ إِنِّي إِدْجَانْ أَكِيذِي، إِ ثْمسْمُونِينْ ن ڭَالَاطِييَا:  
\v 3 أَرْضَا ذ ڒهْنَا أَذْ خَاومْ إِڒِينْ زِي أَربِّي، بَابَاثْنغْ، ؤُ زِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، \x ◘ \xo 1:‏3 \xt رُوم. 1‏:‏7؛ 1 كُور. 1‏:‏3؛ أَفا. 1‏:‏2؛ 1 بُط. 1‏:‏2. \x*  
\v 4 ونِّي إِوْشِينْ إِخفْ نّسْ خْ دّْنُوبْ نّغْ، حِيمَا أَذْ أَنغْ إِفكّْ زِي دُّونشْثْ-أَ ثَاعفَّانْثْ أَمْ مَامّشْ ت إِخْسْ أَربِّي، بَابَاثْنغْ. \x ◘ \xo 1:‏4 \xt مت. 20‏:‏28؛ ڭال. 2‏:‏20؛ أَفا. 5‏:‏2؛ ثِيث. 2‏:‏14؛ عبر. 9‏:‏14. \x*  
\v 5 إِ نتَّا ؤُمِي إِ غَارْ إِدْجَا ؤُعُودْجِي إِ ڒبْذَا قَاعْ. أَمِينْ.   
\b  
\m  
\s1 ڒخْبَارْ أَصبْحَانْ ن لْمَاسِيحْ  
\m
\v 6 تّْبهْثغْ ؤُمِي ثْسمْحمْ أَمُّو ذغْيَا ذِي لْمَاسِيحْ، ونِّي ذ أَومْ د-إِڒَاغَانْ س أَرْضَا نّسْ. \add ثتّخْسمْ أَذْ ثْذوْڒنْ\add* غَارْ إِجّْ ن ڒخْبَارْ أَصبْحَانْ نّغْنِي، \f ◼ \fr 1:‏6 \ft \+bd ’نّغْنِي‘\+bd* - إِخْسْ أَذْ يِينِي ’مْژُووَّارْ‘.\f*  
\v 7 نِّي وَارْ ذِينْ إِدْجِي، مَاشَا ذِينْ شَا ن يِينِّي كنِّيوْ إِحيَّارنْ ؤُشَا خْسنْ أَذْ سّْعوّْجنْ ڒخْبَارْ أَصبْحَانْ ن لْمَاسِيحْ. \x ◘ \xo 1:‏7 \xt ڒخ. 15‏:‏1. \x*  
\v 8 مَاشَا مَاڒَا نشِّينْ نِيغْ إِجّْ ن لْمَالَاكْ زڭْ ؤُجنَّا أَذْ أَومْ إِبَارّحْ س يِيجّْ ن ڒخْبَارْ أَصبْحَانْ نّغْنِي خْ ڒخْبَارْ أَصبْحَانْ إِ زِي نْبَارّحْ إِ كنِّيوْ، أَذْ يِيڒِي ذ أَمنْعُوڒْ. \x ◘ \xo 1:‏8 \xt 2 كُور. 11‏:‏4. \x*  
\v 9 أَمْ إِزَّارغْ نِّيغْ، قَّارغْ ث عَاوذْ ڒخُّو إِجّْ ن ؤُمُورْ نّغْنِي: مَاڒَا إِبشَّارْ حذْ إِ كنِّيوْ س إِجّْ ’ڒخْبَارْ أَصبْحَانْ‘ نّغْنِي خْ ونِّي ثْقبْڒمْ، أَذْ ثَافْ أَذْ إِتّْوَانْعڒْ.   
\m
\v 10 مَا أَرزُّوغْ ڒخُّو أَذْ سّْقنّْعغْ إِوْذَانْ نِيغْ أَربِّي؟ نِيغْ أَرزُّوغْ أَذْ أَرْضِيغْ إِوْذَانْ؟ مَاڒَا أَرزُّوغْ أَذْ أَرْضِيغْ إِوْذَانْ، وَارْ تِّيڒِيغْ ذ أَمْسخَّارْ ن لْمَاسِيحْ. \x ◘ \xo 1:‏10 \xt 1 تس. 2‏:‏4؛ يَاع. 4‏:‏4. \x*   
\b  
\m  
\s1 پُولُوسْ، رّْرَاسُولْ ن ڒخْبَارْ أَصبْحَانْ ن يَاسُوع لْمَاسِيحْ  
\m
\v 11 مَاشَا أَذْ أَومْ مْڒغْ، \add أَ\add* أَيْثْمَا، بلِّي ڒخْبَارْ أَصبْحَانْ إِ ذ إِتّْوَابَارّْحنْ زَّايِي، وَارْ إِدْجِي زِي بْنَاذمْ، \x ◘ \xo 1:‏11 \xt 1 كُور. 15‏:‏1. \x*  
\v 12 مَاغَارْ نشّْ وَارْ ث تّطّْفغْ نِيغْ وَارْ ث ڒْمِيذغْ زِي بْنَاذمْ، مَاشَا س ؤُسَارْڭبْ ن يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏12 \xt أَفا. 3‏:‏3. \x*  
\v 13 أَقَا ثسْڒِيمْ مَامّشْ ثُوغَا ڭُّورغْ قْبڒْ ذِي دِّينْ ن وُوذَاينْ، ثُوغَا ذَارّْشغْ خْ ثْمسْمُونْثْ ن أَربِّي أَطَّاسْ، أَرزُّوغْ أَذْ ت أَردّْدْجغْ. \x ◘ \xo 1:‏13 \xt ڒخ. 8‏:‏3؛ 9‏:‏1؛ 22‏:‏4؛ 26‏:‏9؛ فِيل. 3‏:‏6؛ 1 تِيم. 1‏:‏13. \x*  
\v 14 ثُوغَا إِزَّارغْ ذِي دِّينْ ن وُوذَاينْ خْ وَاطَّاسْ ن إِقْرِيننْ زِي ڒْڭنْسْ إِنُو، مِينْزِي ثُوغَا محْضغْ أَطَّاسْ خْ ثْغُورِي ن ڒجْذُوذْ إِنُو.   
\m
\v 15 مَاشَا ڒَامِي ثُوغَا يَارْضَا نتَّا، ونِّي ذ أَيِي إِحُوزنْ \add ؤُمِي ذ أَيِي ثُوغَا عَاذْ\add* ذڭْ ؤُعذِّيسْ ن يمَّا، ؤُشَا إِڒَاغَا أَيِي س أَرْضَا نّسْ، \x ◘ \xo 1:‏15 \xt ڒخ. 9‏:‏15؛ 13‏:‏2. \x*  
\v 16 مَاحنْذْ أَذْ ذَايِي د-إِسّضْهَارْ مِّيسْ حِيمَا أَذْ زَّايسْ بَارّْحغْ جَارْ ڒڭْنُوسْ، خنِّي وَارْ سَّارْڭِيبغْ مَانْ أَيَا ذغْيَا إِ \add ينِّي غَارْسنْ إِدْجَا\add* دَّاثْ ذ إِذَامّنْ. \x ◘ \xo 1:‏16 \xt مت. 16‏:‏17؛ ڒخ. 9‏:‏15؛ 13‏:‏2؛ 22‏:‏21؛ ڭال. 2‏:‏8؛ أَفا. 3‏:‏8. \x*  
\v 17 عَاوذْ وَارْ رُوحغْ شَا غَارْ ؤُرْشَالِيمْ، غَارْ يِينِّي إِ ثُوغَا ذ رُّوسُولْ قْبڒْ إِنُو، مَاشَا رُوحغْ غَارْ عَارَابِييَّا، ؤُشَا ذوْڒغْ-د \add خنِّي\add* عَاوذْ غَارْ ذِيمَاشْقْ.   
\m
\v 18 ثْڒَاثَا ن إِسڭّْوُوسَا أَوَارْنِي أَسْ، رُوحغْ غَارْ ؤُرْشَالِيمْ حِيمَا أَذْ مّڒْقِيغْ أَكْ-ذ كِيفَا ؤُشَا زذْغغْ أَكِيذسْ خمّسْطَاشْ ن وُوسَّانْ.  
\v 19 وَارْ ژْرِيغْ حذْ نّغْنِي زِي رُّوسُولْ مْغِيرْ يَاعْقُوبْ، ؤُمَاسْ ن سِيذِيثْنغْ.  
\v 20 مِينْ ذ أَومْ تَّارِيغْ ڒخُّو، أَقَا ذَا \add شهّْذغْ\add* زَّاثْ إِ أَربِّي: وَارْ سّْخَارِّيقغْ شَا! \x ◘ \xo 1:‏20 \xt رُوم. 1‏:‏9؛ 9‏:‏1؛ 2 كُور. 1‏:‏23؛ 11‏:‏31؛ 1 تس. 2‏:‏5؛ 1 تِيم. 5‏:‏21؛ 2 تِيم. 4‏:‏1. \x*  
\v 21 أَوَارْنِي مَانْ أَيَا رُوحغْ غَارْ جّْوَايهْ ن سُورِييَا ذ كِيلِيكِييَا.  
\v 22 ثِيمسْمُونِينْ ن يَاهُوذِييَّا إِ إِدْجَانْ ذِي لْمَاسِيحْ، وَارْ سِّيننْ أَغمْبُوبْ إِنُو.  
\v 23 نِيثْنِي ثُوغَا سْڒِينْ خَافِي أَمُّو وَاهَا: ”أَقَا ونِّي ثُوغَا خَانغْ إِذَارّْشنْ قْبڒْ، ڒخُّو إِتّْبَارّحْ س لْ-إِيمَانْ إِ ثُوغَا يَاردّدْجْ زِيشْ!“،  
\v 24 ؤُشَا سّمْغَارنْ ذِي أَربِّي زِي سِّيبّثْ إِنُو.   
\b  
\b  
\m  
\c 2
\s1 پُولُوسْ ذ رُّوسُولْ ذِي ؤُرْشَالِيمْ  
\m
\v 1 أَوَارْنِي ڒَامِي عْذُونْ أَرْبعْطَاشْ ن إِسڭّْوُوسَا، رُوحغْ عَاوذْ غَارْ ؤُرْشَالِيمْ أَكْ-ذ بَارْ-نَابَا ؤُشَا إِوْيغْ أَكِيذِي عَاوذْ ثِيثُوسْ. \x ◘ \xo 2:‏1 \xt ڒخ. 15‏:‏2. \x*  
\v 2 مَاشَا ثُوغَا رُوحغْ عْلَاحْسَابْ إِجّْ ن ؤُسَارْڭبْ \add ن أَربِّي\add* ؤُ مْڒغْ أَسنْ ڒخْبَارْ أَصبْحَانْ إِ تّْبَارّْحغْ جَارْ ڒڭْنُوسْ، إِ يِينِّي غَارْ إِدْجَا ؤُوقَّارْ وحّذْسنْ، حِيمَا وَارْ تِّيزّْڒغْ نِيغْ أَذْ أَزّْڒغْ بَاطڒْ. \x ◘ \xo 2:‏2 \xt ڒخ. 19‏:‏21. \x*  
\v 3 عَاوذْ ثِيثُوسْ، ونِّي ثُوغَا أَكِيذِي، وَاخَّا نتَّا ذ أَرَامِييُو، وَارْ خَاسْ ڭّنْ س ؤُغِيڒْ مَاحنْذْ أَذْ إِتّْوَاخْثنْ. \x ◘ \xo 2:‏3 \xt ڒخ. 16‏:‏3؛ 1 كُور. 9‏:‏21. \x*  
\v 4 مَاشَا مِينْزِي ؤُذْفنْ-د أَوْمَاثنْ إِسّْخَارِّيقنْ غَارْنغْ، حِيمَا أَذْ شكّْمنْ خْ ثِيڒلِّي ثنِّي غَارْنغْ ذِي يَاسُوع لْمَاسِيحْ، حِيمَا أَذْ أَيِي ڭّنْ ذ إِسْمغْ، \x ◘ \xo 2:‏4 \xt ڒخ. 15‏:‏24. \x*  
\v 5 أَقَا نشِّينْ وَارْ ذ أَسنْ نْوَاضعْ ؤُڒَا ذ إِشْثْ ن ثْزحْزِيحْثْ إِ ڒحْصَارثْ نْسنْ، حِيمَا ثِيذتّْ ن ڒخْبَارْ أَصبْحَانْ أَذْ ثقِّيمْ أَكِيذْومْ.   
\m
\v 6 إِنِّي ثُوغَا إِتّْبَاننْ ذ شَا \add جَارْ أَسنْ\add* - مِينْ مَا عْنَانْ وَارْ ذ أَيِي إِشْقِي، مِينْزِي أَربِّي وَارْ إِتّڭّْ شَا س وُوذْمَاونْ - أَقَا وَارْ خَافِي نَّانْ وَالُو. \x ◘ \xo 2:‏6 \xt أَعَوذ. 10‏:‏17؛ 2 إِم. 19‏:‏7؛ أَيُوبْ 34‏:‏19؛ ڒخ. 10‏:‏34؛ رُوم. 2‏:‏11؛ أَفا. 6‏:‏9؛ كُول. 3‏:‏25؛ 1 بُط. 1‏:‏17. \x*  
\v 7 س ڒْعكْسْ، مَاغَارْ ژْرِينْ، بلِّي تّْكلّْفغْ خْ ڒخْبَارْ أَصبْحَانْ إِ يِينِّي بْڒَا أَخْثَانْ أَمْ مَامّشْ \add إِتّْكلّفْ\add* بُوطْرُوسْ خْ ڒخْبَارْ أَصبْحَانْ إِ يِينِّي س وخْثَانْ،  
\v 8 - مِينْزِي ونِّي إِعَارّْننْ بُوطْرُوسْ ذِي ڒْخذْمثْ نّسْ أَمْ رَّاسُولْ جَارْ إِنِّي إِخثْننْ، إِعَارّنْ أَيِي عَاوذْ، حِيمَا أَذْ ڭّغْ ڒْخذْمثْ ن رَّاسُولْ جَارْ ڒڭْنُوسْ - \x ◘ \xo 2:‏8 \xt ڒخ. 9‏:‏15؛ 13‏:‏2؛ 22‏:‏21؛ ڭال. 1‏:‏16؛ أَفا. 3‏:‏8. \x*  
\v 9 ؤُشَا ؤُمِي يَاعْقُوبْ ذ كِيفَا ذ يُوحَانَّا، إِنِّي إِتّْوَاحسْبنْ ذ إِمْغَارنْ، نعْمنْ س أَرْضَا إِ ذ أَيِي إِمّوْشنْ، وْشِينْ أَنغْ أَفُوسْ أَفُوسِي ن ثْمُونْثْ \add ن ثَاوْمَاثْ\add* إِ نشّْ ذ بَارْ-نَابَا، حِيمَا نشِّينْ أَذْ نِيڒِي \add نتّْسخَّارْ\add* جَارْ ڒڭْنُوسْ ؤُشَا نِيثْنِي جَارْ إِنِّي س وخْثَانْ.  
\v 10 ثُوغَا إِتّْخصَّا أَنغْ أَذْ نْفكَّارْ ذڭْ إِمزْڒَاضْ وَاهَا، ؤُشَا خنِّي شْضَارغْ عَاوذْ مَاحنْذْ أَذْ ڭّغْ مَانْ أَيَا. \x ◘ \xo 2:‏10 \xt ڒخ. 11‏:‏30؛ 24‏:‏17؛ رُوم. 15‏:‏25؛ 1 كُور. 16‏:‏1؛ 2 كُور. 8‏:‏1؛ 9‏:‏1. \x*   
\b  
\m  
\s1 پُولُوسْ إِتّمْعَاڒَا أَكْ-ذ بُوطْرُوسْ س بْطَايْطَايْ  
\m
\v 11 مَاشَا ؤُمِي د-يُوسَا كِيفَا غَارْ أَنْثِييُوخِييَا، مّْعَاڒِيغْ أَكِيذسْ س بْطَايْطَايْ، مِينْزِي نِيثْنِي نّْقَارْضنْ زَّايسْ.  
\v 12 مِينْزِي قْبڒْ مَا د-ؤُسِينْ شَا زِي يَاعْقُوبْ، ثُوغَا إِتّتّْ أَكْ-ذ يِينِّي \add يُومْننْ\add* زِي ڒڭْنُوسْ، مَاشَا أَوَارْنِي ڒَامِي د-ؤُسِينْ نِيثْنِي، إِعْقبْ ؤُشَا إِسّْبعّذْ إِخفْ نّسْ زَّايْسنْ، مِينْزِي ثُوغَا إِڭّْوذْ زڭْ إِنِّي إِدْجَانْ زڭْ وخْثَانْ.  
\v 13 ؤُڒَا ذ ؤُذَاينْ إِنّغْنِي تّْوَاجبّْذنْ أَكِيذسْ غَارْ مَانْ أَيَا، أَمنِّي عَاوذْ بَارْ-نَابَا، أَقَا نذْهنْ ث ذِي نِّيفَاقْ نْسنْ.  
\v 14 مَاشَا ؤُمِي ژْرِيغْ بلِّي وَارْ ڭُّورنْ شَا نِيشَانْ خْ وبْرِيذْ ن ثِيذتّْ ن لْ-إِنْجِيلْ، نِّيغْ إِ كِيفَا زَّاثْ إِ مَارَّا: ”مَاڒَا شكْ، أَمْ ثدْجِيذْ ذ ؤُذَايْ، ثدَّارذْ أَمْ يِيجّْ ن أَرَامِييُو، وَارْ إِدْجِي أَمْ وُوذَايْ، مَايمِّي ثڭِّيذْ أَغِيڒْ خْ يِينِّي زِي ڒڭْنُوسْ، حِيمَا أَذْ دَّارنْ أَمْ وُوذَاينْ؟ \x ◘ \xo 2:‏14 \xt ڒخ. 10‏:‏28. \x*   
\m
\v 15 أَقَا نشِّينْ، إِنِّي إِدْجَانْ ذ ؤُذَاينْ عْلَاحْصَابْ طّْبِيعثْ، وَارْ ندْجِي شَا ذ إِمذْنَابْ زِي ڒڭْنُوسْ،  
\v 16 نُومنْ ذِي يَاسُوع لْمَاسِيحْ، مِينْزِي نسّنْ بلِّي بْنَاذمْ وَارْ إِتّْوَاسڭّذْ شَا س ڒخْذَايمْ ن شَّارِيعَا، مَاشَا س لْ-إِيمَانْ ن يَاسُوع لْمَاسِيحْ، أَڒَامِي ؤُڒَا ذ نشِّينْ أَذْ نتّْوَاسڭّذْ س لْ-إِيمَانْ ن لْمَاسِيحْ، وَارْ إِدْجِي س ڒخْذَايمْ ن شَّارِيعَا، مِينْزِي س ڒخْذَايمْ ن شَّارِيعَا ؤُڒَا ذ إِجّْ ن بْنَاذمْ وَارْ إِتّْوَاسڭَّاذْ شَا \add عمَّارْصْ\add*. \x ◘ \xo 2:‏16 \xt ڒخ. 13‏:‏38؛ رُوم. 3‏:‏20، 28؛ 8‏:‏3؛ ڭال. 3‏:‏11؛ عبر. 7‏:‏18. \x*   
\m
\v 17 مَاشَا مَاڒَا نشِّينْ، أَمْ نَارزُّو أَذْ نتّْوَاسڭّذْ س لْمَاسِيحْ، نُوفَا بلِّي نشِّينْ عَاوذْ ذ إِمذْنَابْ، مَا يَاسُوع لْمَاسِيحْ \add خنِّي\add* ذ أَمْسخَّارْ ن دّْنُوبْ؟ وَايَّاوْ!  
\v 18 مِينْزِي مَاڒَا بْنِيغْ عَاوذْ مِينْ هذْمغْ، أَذْ سّشْنغْ بلِّي نشّْ س إِخفْ إِنُو ذ ونِّي إِعدُّونْ خْ ثوْصِييّثْ.  
\v 19 مِينْزِي س شَّارِيعَا \add أَقَا نشّْ\add* مُّوثغْ إِ شَّارِيعَا، حِيمَا أَذْ دَّارغْ إِ أَربِّي. \x ◘ \xo 2:‏19 \xt رُوم. 7‏:‏4؛ 14‏:‏7؛ 2 كُور. 5‏:‏15؛ 1 تس. 5‏:‏10؛ عبر. 9‏:‏14؛ 1 بُط. 4‏:‏2. \x*  
\v 20 تّْوَاصلّْبغْ أَكْ-ذ لْمَاسِيحْ ؤُشَا زِي سَّا ذ ثْسَاونْثْ وَارْ قِّيمغْ دَّارغْ عَاذْ نشّْ، مَاشَا لْمَاسِيحْ إِدَّارْ ذَايِي. ؤُشَا مِينْ دَّارغْ ڒخُّو عَاذْ ذِي أَرِّيمثْ، دَّارغْ س لْ-إِيمَانْ ن مِّيسْ ن أَربِّي ونِّي ذ أَنغْ إِتّخْسنْ ؤُ إِوْشَا إِخفْ نّسْ خَانغْ. \x ◘ \xo 2:‏20 \xt ڭال. 1‏:‏4؛ أَفا. 5‏:‏2؛ ثِيث. 2‏:‏14. \x*  
\v 21 وَارْ بضْڒغْ شَا أَرْضَا ن أَربِّي، مِينْزِي مَاڒَا ثُوغَا ثَاسڭْذَا س شَّارِيعَا، أَذْ يِيڒِي إِمُّوثْ لْمَاسِيحْ خْ وَالُو.“ \x ◘ \xo 2:‏21 \xt عبر. 7‏:‏11. \x*   
\b  
\b  
\m  
\c 3
\s1 ثَاسڭْذَا س لْ-إِيمَانْ  
\m
\v 1 \add أَ\add* إِڭَالَاطِييّنْ إِفْغُوڒنْ، وِي كنِّيوْ إِسُّوفّْغنْ زڭْ وبْرِيذْ؟ أَقَا لْمَاسِيحْ ثُوغَا إِتّْوَارْشمْ قِيبَاتْشْ إِ ثِيطَّاوِينْ نْومْ أَمْ ونِّي إِمُّوثنْ خْ صَّالِيبْ. \x ◘ \xo 3:‏1 \xt ڭال. 5‏:‏7. \x*  
\v 2 ذڭَّا وَاهَا خْسغْ أَذْ ث سّْنغْ زَّايْومْ: مَا ثطّْفمْ أَرُّوحْ س ڒخْذَايمْ ن شَّارِيعَا نِيغْ ؤُمِي ثتّڭّمْ أَرَّايْ إِ لْ-إِيمَانْ؟  
\v 3 مَا أَمنِّي ثدْجَامْ ذ إِفْغُوڒنْ، أَقَا ثبْذَامْ س أَرُّوحْ، مَا ڒخُّو أَذْ ثْكمّْڒمْ س دَّاثْ؟  
\v 4 مَا ثكْسِيمْ ثَامَارَا أَطَّاسْ خْ وَالُو؟ مَا ثُوغَا س ثِيذتّْ خْ وَالُو؟  
\v 5 ونِّي ذ أَومْ إِوْشِينْ أَرُّوحْ ؤُشَا إِتّڭّْ لْمُوعْجِيزَاثْ جَارْ أَومْ، مَا إِتّڭّْ إِ-ثنْثْ زِي ڒخْذَايمْ ن شَّارِيعَا نِيغْ ؤُمِي ثتّسْڒَامْ \add ثَابَارّحْثْ\add* ن لْ-إِيمَانْ،  
\v 6 أَمْ مَامّشْ ثُوغَا إِبْرَاهِيمْ يُومنْ ذِي أَربِّي ؤُشَا \add خنِّي\add* إِتّْوَاحْسبْ أَسْ-د مَانْ أَيَا ذ ثَاسڭْذَا. \x ◘ \xo 3:‏6 \xt أَمز. 15‏:‏6؛ رُوم. 4‏:‏3؛ يَاع. 2‏:‏23. \x*  
\v 7 س ؤُينِّي سّْنمْ، بلِّي إِنِّي إِدْجَانْ ن لْ-إِيمَانْ، نِيثْنِي ذ أَيْثْ ن إِبْرَاهِيمْ.  
\v 8 مِينْزِي إِسّنْ أَربِّي قْبڒْ، أَقَا ڒڭْنُوسْ أَذْ تّْوَاسڭّْذنْ س لْ-إِيمَانْ، إِزَّارْ إِبشَّارْ نتَّا إِ إِبْرَاهِيمْ س ڒخْبَارْ أَصبْحَانْ، أَمْ مَامّشْ قَّارنْثْ ثِيرَا إِقدّْسنْ: ”ذَايكْ إِ غَا تّْوَابَارْكنْ ڒڭْنُوسْ مَارَّا.“ \x ◘ \xo 3:‏8 \xt أَمز. 12‏:‏3؛ 18‏:‏18؛ 22‏:‏18؛ 26‏:‏4؛ 49‏:‏10؛ ڒخ. 3‏:‏25. \x*  
\v 9 س ؤُينِّي إِنِّي يُومْننْ أَذْ تّْوَابَارْكنْ أَكْ-ذ ڒْمُومنْ إِبْرَاهِيمْ.   
\m
\v 10 مَارَّا إِنِّي إِدَّارنْ س ڒخْذَايمْ ن شَّارِيعَا، أَقَا نِيثْنِي سَاذُو نّعْڒثْ، مِينْزِي ثُورَا: ”ذ أَمنْعُوڒْ كُوڒْ إِجّنْ ونِّي وَارْ إِقِّيمنْ إِتّطّفْ ذِي مَارَّا ثِيمسْڒَايِينْ يُورَانْ ذڭْ وذْلِيسْ ن شَّارِيعَا حِيمَا أَذْ ثنْثْ إِڭّْ!“ \x ◘ \xo 3:‏10 \xt أَعَوذ. 27‏:‏26؛ ڭال. 3‏:‏10\x*  
\v 11 أَقَا إِتّْبَانْ مْلِيحْ بلِّي وَارْ ذِينْ حذْ إِ غَا إِتّْوَاسڭّْذنْ غَارْ أَربِّي س شَّارِيعَا، مِينْزِي ثُورَا: ”أَمْسڭَّاذْ س لْ-إِيمَانْ أَذْ إِدَّارْ!“ \x ◘ \xo 3:‏11 \xt حَاب. 2‏:‏4؛ رُوم. 1‏:‏17؛ 3‏:‏20؛ ڭال. 2‏:‏16؛ عبر. 10‏:‏38\x*  
\v 12 \add خنِّي\add* شَّارِيعَا وَارْ ثْكمّڒْ شَا س لْ-إِيمَانْ، مَاشَا بْنَاذمْ ونِّي إِتّڭّنْ مِينْ ذَايسْ يُورِينْ، أَذْ زَّايسْ إِدَّارْ. \x ◘ \xo 3:‏12 \xt لَاوِي 18‏:‏5؛ حِز. 20‏:‏11؛ رُوم. 10‏:‏5. \x*  
\v 13 \add مَاشَا\add* لْمَاسِيحْ أَقَا إِخدْجصْ خَانغْ، حِيمَا أَذْ أَنغْ إِفكّْ زِي نّعْڒثْ نِّي إِدْجَانْ خْ يِينِّي سَاذُو شَّارِيعَا أَمْ ذ إِذْوڒْ خَانغْ ذ أَمنْعُوڒْ، مِينْزِي ثُورَا: ”ذ أَمنْعُوڒْ كُوڒْ إِجّنْ إِ ث غَا يُويْڒنْ خْ ثحْنَاشْثْ!“، \x ◘ \xo 3:‏13 \xt أَعَوذ. 21‏:‏23؛ رُوم. 8‏:‏3؛ 2 كُور. 5‏:‏21. \x*  
\v 14 حِيمَا أَذْ ثِيوضْ لْبَارَاكَا ن إِبْرَاهِيمْ غَارْ ڒڭْنُوسْ س يَاسُوع لْمَاسِيحْ، مَاحنْذْ س لْ-إِيمَانْ أَذْ نطّفْ لْوَاعْذْ ن أَرُّوحْ.   
\b  
\m  
\s1 شَّارِيعَا ذ لْوَاعْذْ  
\m
\v 15 \add أَ\add* أَيْثْمَا، أَذْ سِّيوْڒغْ خْ ڒحْسَابْ ڒعْقڒْ ن بْنَاذمْ: أَقَا إِجّْ ن ڒْعَاهْذْ إِتّْوَاڭّنْ جَارْ إِوْذَانْ، وَارْ إِزمَّارْ ؤُڒَا ذ إِجّْ أَذْ ث إِبْضڒْ نِيغْ أَذْ ذَايسْ إِبدّڒْ شَا. \x ◘ \xo 3:‏15 \xt عبر. 9‏:‏17. \x*  
\v 16 أَقَا لْوُوعُوذْ تّْوَاڭّنْ إِ إِبْرَاهِيمْ ذ زَّارِيعثْ نّسْ. نتَّا وَارْ ذ أَسْ يِينِي شَا: ”إِ إِعقَّاينْ ن زَّارِيعثْ نْومْ!“، أَمْ إِ وَاطَّاسْ، مَاشَا: ”إِ ؤُعقَّا ن زَّارِيعثْ نّشْ!“، أَمْ إِ يِيجّنْ، أَقَا-ث ذ لْمَاسِيحْ. \x ◘ \xo 3:‏16 \xt ڭال. 3‏:‏8. \x*  
\v 17 \add خنِّي\add* قَّارغْ \add أَمُّو\add*: ڒْعَاهْذْ نِّي إِڭِّينْ أَربِّي زِيشْ ذِي لْمَاسِيحْ، وَارْ ث ثْبطِّيڒْ شَا شَّارِيعَا، ثنِّي ثُوسَا-د أَربْعَا-مْيَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا أَوَارْنِي مَانْ أَيَا، حِيمَا أَذْ ثڭّْ لْوَاعْذْ إِخْوَانْ. \x ◘ \xo 3:‏17 \xt أَمز. 15‏:‏13؛ ؤُف. 12‏:‏40؛ ڒخ. 7‏:‏6. \x*  
\v 18 مِينْزِي مَاڒَا ڒْوَارْثْ إِدْجَا س شَّارِيعَا، أَقَا وَارْ إِدْجِي عَاذْ س لْوَاعْذْ إِ إِبْرَاهِيمْ. مَاشَا أَربِّي أَقَا إِوْشَا أَسْ ث س لْوَاعْذْ. \x ◘ \xo 3:‏18 \xt رُوم. 4‏:‏14. \x*   
\m
\v 19 خنِّي إِ ؤُمِي ثْنفّعْ شَّارِيعَا؟ أَقَا ثتّْوَامَّارْنِي \add غَارْ لْوَاعْذْ\add* خْ سِّيبّثْ ن دّْنُوبْ أَڒَامِي د-ثُوسَا زَّارِيعثْ ثنِّي ؤُمِي إِتّْوَاڭّْ لْوَاعْذْ. ؤُ س لْمَالَاكَاثْ ثمّوْشْ شَّارِيعَا ذڭْ ؤُفُوسْ ن إِجّْ ن لْوَاسِيثْ. \x ◘ \xo 3:‏19 \xt أَعَوذ. 5‏:‏5؛ يُوح. 1‏:‏17؛ 15‏:‏22؛ ڒخ. 7‏:‏38، 53؛ رُوم. 4‏:‏15؛ 5‏:‏20؛ 7‏:‏8. \x*  
\v 20 لْوَاسِيثْ وَارْ إِدْجِي \add ذ لْوَاسِيثْ\add* ن إِجّنْ، مَاشَا أَربِّي ذ إِجّنْ.   
\m
\v 21 مَا خنِّي شَّارِيعَا ضِيدّْ إِ لْوَاعْذْ ن أَربِّي؟عمَّارْصْ! مِينْزِي مَاڒَا ثُوغَا ثمّوْشْ إِشْثْ ن شَّارِيعَا ثْزمَّارْ أَذْ ثسّدَّارْ، ذ ثِيذتّْ ثُوغَا ثَاسڭْذَا س شَّارِيعَا.  
\v 22 مَاشَا ثِيرَا \add إِقدّْسنْ\add* بلّْعنْثْ خْ مَارَّا ذِي دّْنُوبْ، حِيمَا لْوَاعْذْ أَذْ إِمّوْشْ س لْ-إِيمَانْ ذِي يَاسُوع لْمَاسِيحْ إِ يِينِّي يُومْننْ. \x ◘ \xo 3:‏22 \xt رُوم. 3‏:‏9؛ 11‏:‏32. \x*   
\m
\v 23 مَاشَا قْبڒْ مَا إِ د غَا يَاسْ لْ-إِيمَانْ، ثُوغَا أَنغْ نمّحْضَا ذِي شَّارِيعَا ؤُشَا إِتّْوَابلّعْ خَانغْ زِي لْ-إِيمَانْ، ونِّي ثُوغَا إِ غَا إِضْهَارنْ \add عَاذْ\add*.  
\v 24 س ؤُينِّي ثُوغَا شَّارِيعَا أَمْ ونِّي ذ أَنغْ إِتَّاربَّانْ أَڒْ لْمَاسِيحْ، حِيمَا أَذْ نتّْوَاسڭّذْ س لْ-إِيمَانْ. \x ◘ \xo 3:‏24 \xt مت. 5‏:‏17؛ ڒخ. 13‏:‏38؛ رُوم. 10‏:‏4. \x*  
\v 25 مَاشَا ڒخُّو، ؤُمِي د-يُوسَا لْ-إِيمَانْ، أَقَا وَارْ نقِّيمْ عَاذْ سَاذُو ونِّي إِتَّاربَّانْ.   
\m
\v 26 مِينْزِي مَارَّا كنِّيوْ ذ أَرَّاونْ ن أَربِّي س لْ-إِيمَانْ ن يَاسُوع لْمَاسِيحْ. \x ◘ \xo 3:‏26 \xt إِشا. 56‏:‏5؛ يُوح. 1‏:‏12؛ رُوم. 8‏:‏15؛ ڭال. 4‏:‏5. \x*  
\v 27 مِينْزِي مَارَّا إِنِّي إِتّْوَاسّْغضْصنْ ذِي لْمَاسِيحْ، أَقَا أَرْضنْ لْمَاسِيحْ. \x ◘ \xo 3:‏27 \xt رُوم. 6‏:‏3. \x*  
\v 28 \add خنِّي\add* وَارْ ذِينْ ؤُذَايْ نِيغْ أَرَامِييْ، وَارْ ذِينْ \add عَاذْ\add* إِسْمغْ نِيغْ أَحُورِّي، وَارْ ذِينْ \add عَاذْ\add* أَرْيَازْ نِيغْ ثَامْغَارْثْ، مِينْزِي مَارَّا كنِّيوْ ذ إِجّنْ إِ ثدْجَامْ ذِي يَاسُوع لْمَاسِيحْ. \x ◘ \xo 3:‏28 \xt يُوح. 17‏:‏21. \x*  
\v 29 مَاڒَا كنِّيوْ ثدْجَامْ ن لْمَاسِيحْ، أَقَا كنِّيوْ ذ زَّارِيعثْ ن إِبْرَاهِيمْ ؤُشَا عْلَاحْسَابْ لْوَاعْذْ ذ إِوْرِيثنْ. \x ◘ \xo 3:‏29 \xt أَمز. 21‏:‏12؛ رُوم. 9‏:‏7؛ عبر. 11‏:‏18. \x*   
\b  
\b  
\m  
\c 4
\s1 أَرَّاونْ ن أَربِّي  
\m
\v 1 خْسغْ أَذْ إِنِيغْ، مشْحَاڒْ مَا ذ أَوْرِيثْ أَقَا-ث \add عَاذْ\add* ذ أَحنْجِيرْ، وَارْ ذِينْ بُو ڒْفَارْقْ خْ ؤُمْسخَّارْ، وَاخَّا نتَّا ذ بَابْ ن مَارَّا نِيثْنِي.  
\v 2 نتَّا إِدْجَا عَاذْ سَاذُو إِمحْذَاينْ ؤُ سَاذُو إِنِّي إِتّْسيَّارنْ ثَادَّارْثْ أَڒْ ڒْوقْثْ إِ يڭَّا بَابَاسْ.  
\v 3 أَمُّو عَاوذْ نشِّينْ، ؤُمِي ذ أَنغْ ثُوغَا عَاذْ ذ إِحنْجِيرنْ، ثُوغَا أَنغْ ذ إِسمْغَانْ سَاذُو \add صُّولْطَا ن\add* لْفَارَايِيضْ ن دُّونشْثْ\add -أَ\add*.  
\v 4 مَاشَا ؤُمِي د-يِيوضْ ؤُعمَّارْ ن ڒْوقْثْ، أَربِّي أَقَا إِسّكّْ-د مِّيسْ إِ يدْجَانْ زِي ثمْغَارْثْ ذ ونِّي إِدْجَانْ سَاذُو شَّارِيعَا، \x ◘ \xo 4:‏4 \xt أَمز. 49‏:‏10؛ دَان. 9‏:‏24؛ مت. 5‏:‏17. \x*  
\v 5 حِيمَا أَذْ إِفْذِي إِنِّي إِدْجَانْ سَاذُو شَّارِيعَا ؤُشَا \add خنِّي\add* نشِّينْ أَذْ نطّفْ ڒفْضڒْ مَاحنْذْ أَذْ نتّْوَاقْبڒْ ذ مِّيسْ. \f ◼ \fr 4:‏5 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  \x ◘ \xo 4:‏5 \xt يُوح. 1‏:‏12؛ ڭال. 3‏:‏26. \x*   
\m
\v 6 مِينْزِي كنِّيوْ ثدْجَامْ ذ أَرَّاونْ، أَربِّي إِسّكّْ أَرُّوحْ ن مِّيسْ ذڭْ وُوڒَاونْ نْومْ، ونِّي إِتّْڒَاغَانْ: ’بَابَا، بَابَاثْنغْ!‘ \x ◘ \xo 4:‏6 \xt رُوم. 8‏:‏15. \x*  
\v 7 س ؤُينِّي وَارْ ثدْجِيمْ عَاذْ ذ إِمْسخَّارنْ، مَاشَا ذ أَرَّاونْ ؤُ مَاڒَا أَرَّاونْ إِ ثدْجَامْ، أَقَا كنِّيوْ عَاوذْ ذ إِوْرِيثنْ ن أَربِّي س يَاسُوع لْمَاسِيحْ.  
\v 8 مَاشَا ذِي زّْمَانْ إِ وَارْ ثسِّينمْ شَا أَربِّي، ثُوغَا ثْعبّْذمْ إِنِّي وَارْ إِدْجِينْ س ثوَّا ذ إِربِّيثنْ. \x ◘ \xo 4:‏8 \xt 1 كُور. 8‏:‏4. \x*  
\v 9 مَاشَا ڒخُّو، أَوَارْنِي ڒَامِي ثسّْنمْ أَربِّي، عَاذْ حْسنْ أَربِّي يَارْڭبْ خَاومْ، أَقَا ثْعقْبمْ عَاوذْ غَارْ \add صُّولْطَا ن\add* لْفَارَايِيضْ إِضعْفنْ إِزڒْضنْ \add ن دُّونشْثْ-أَ\add*، ثخْسمْ عَاوذْ أَذْ أَسنْثْ ثمَّارْسمْ إِخفْ نْومْ أَمْ زڭْ وشْحَاڒْ ؤُيَا! \x ◘ \xo 4:‏9 \xt كُول. 2‏:‏20. \x*  
\v 10 ثْحطَّامْ ؤُسَّانْ ذ إِيُورنْ ذ زّْمَانَاثْ ذ إِسڭّْوُوسَا. \x ◘ \xo 4:‏10 \xt رُوم. 14‏:‏5؛ كُول. 2‏:‏16. \x*  
\v 11 تّڭّْوذغْ خَاومْ أَقَا تَّامَارغْ جَارْ أَومْ خْ وَالُو.   
\b  
\m  
\s1 ثْغُويِّيثْ ن ذغْيَا  
\m
\v 12 \add أَ\add* أَيْثْمَا، تّْزَاوَاڭغْ كنِّيوْ، إِڒِيمْ أَمْ نشّْ، مِينْزِي نشّْ أَمْ كنِّيوْ. كنِّيوْ وَارْ ذ أَيِي ثڭِّيمْ وَالُو مِينْ وَارْ إِحْڒِينْ.  
\v 13 أَقَا كنِّيوْ ثسّْنمْ بلِّي بَارّْحغْ أَومْ-د س ڒخْبَارْ أَصبْحَانْ ذڭْ ؤُمزْوَارُو س ثُوضْعفْثْ ن أَرِّيمثْ إِنُو.  
\v 14 كنِّيوْ وَارْ ثسّحْقَارمْ نِيغْ ثسّْطيّْحمْ زڭْ ؤُمَارّثْ ن أَرِّيمثْ إِنُو، مَاشَا ثْقبْڒمْ أَيِي أَمْ يِيجّْ ن لْمَالَاكْ ن أَربِّي ؤُ أَمْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 4:‏14 \xt مـَال. 2‏:‏7؛ مت. 10‏:‏40؛ يُوح. 13‏:‏20. \x*  
\v 15 مَانِي ثْرُوحْ خنِّي لْبَارَاكَا نْومْ؟ مِينْزِي شهّْذغْ خَاومْ بلِّي، مَاڒَا ثُوغَا ثْزمَّارمْ، أَذْ ثْقڒْعمْ ثِيطَّاوِينْ نْومْ، حِيمَا أَذْ أَيِي ثنْثْ ثوْشمْ.  
\v 16 مَا ذوْڒغْ ذ ڒعْذُو نْومْ، مِينْزِي بَارّْحغْ كنِّيوْ س ثِيذتّْ؟  
\v 17 نِيثْنِي شْضَارنْ أَطَّاسْ خَاومْ، مَاشَا وَارْ إِدْجِي أَمنِّي وَاهَا، مَاغَارْ خْسنْ أَذْ كنِّيوْ حبّْسنْ، حِيمَا كنِّيوْ أَذْ ثشْضَارمْ خَاسنْ. \x ◘ \xo 4:‏17 \xt رُوم. 10‏:‏2؛ 2 كُور. 11‏:‏12. \x*  
\v 18 \add وَاهْ\add*، مْلِيحْ أَذْ ثِيڒِيمْ ڒبْذَا ثْشطَّارمْ ذِي مِينْ إِدْجَانْ ذ أَصبْحَانْ، \add مَاشَا\add* وَارْ إِدْجِي خْمِي كِيومْ إِ غَا حْضَارغْ وَاهَا.  
\v 19 \add أَ\add* إِحنْجِيرنْ إِنُو، ثْوَاڒَا نّغْنِيثْ أَقَا أَيِي إِ كنِّيوْ أَمْ يِيشْثْ ن ثمْغَارْثْ ثنِّي إِكْسِينْ دّيْسثْ زَّايْومْ س ؤُنزْبَارْ ن ثَارْوَا، أَڒْ ذَايْومْ إِ غَا إِڒِينْثْ ثفْرَاسْ ن لْمَاسِيحْ. \x ◘ \xo 4:‏19 \xt 1 كُور. 4‏:‏15؛ فلمن. 10؛ يَاع. 1‏:‏18. \x*  
\v 20 خْسغْ ڒخُّو أَذْ إِڒِيغْ أَكِيذْومْ ؤُشَا أَذْ بدّْڒغْ ثْمِيجَّا إِنُو، مِينْزِي أَقَا ؤُڭْنُوغْ زَّايْومْ.   
\b  
\m  
\s1 أَمذْيَا ن هَاجَارْ ذ سَارَا  
\m
\v 21 إِنِيمْ أَيِي، كنِّيوْ إِنِّي إِتّخْسنْ أَذْ ثِيڒِيمْ سَاذُو شَّارِيعَا، مَا وَارْ ثطِّيعمْ شَا شَّارِيعَا؟  
\v 22 مِينْزِي أَقَا ثُورَا بلِّي إِبْرَاهِيمْ ثُوغَا غَارسْ ثْنَاينْ ن إِحنْجِيرنْ، إِجّنْ ن ثَايَّا، ونّغْنِي ن ثْحُورّشْثْ. \x ◘ \xo 4:‏22 \xt أَمز. 16‏:‏2، 15؛ 21‏:‏2؛ ڒخ. 7‏:‏8؛ عبر. 11‏:‏11. \x*  
\v 23 ونِّي ن ثَايَّا أَقَا إِتّْوَاخْڒقْ-د عْلَاحْسَابْ دَّاثْ، مَاشَا ونِّي ن ثْحُورّشْثْ إِتّْوَاخْڒقْ-د عْلَاحْسَابْ لْوَاعْذْ. \x ◘ \xo 4:‏23 \xt يُوح. 8‏:‏39؛ رُوم. 9‏:‏7. \x*  
\v 24 ثِينَا ذ ثْنَاينْ ن إِمذْيَا ن ثْنَاينْ ن ڒْعُوهُوذْ، إِجّنْ ن وذْرَارْ ن سِينَا، ونِّي إِ د-إِتَّارْونْ ثَاسْمُوغِي، أَقَا-ث هَاجَارْ.  
\v 25 مِينْزِي هَاجَارْ ذ أَذْرَارْ ن سِينَا ذِي عَارَابِييَّا، ثنِّي يَاروْسنْ ذِي ؤُرْشَالِيمْ ن ڒخُّو، ثنِّي إِدْجَانْ ذِي ثسْمُوغِي أَكْ-ذ ثَارْوَا نّسْ. \x ◘ \xo 4:‏25 \xt ؤُف. 19، 20. \x*  
\v 26 مَاشَا ؤُرْشَالِيمْ ن سنّجْ ذ ثَاحُورّشْثْ، أَقَا-ت ذ يمَّاثْنغْ. \x ◘ \xo 4:‏26 \xt أَسَا. 21‏:‏2. \x*  
\v 27 مِينْزِي ثُورَا:  
\b  
\m \qt ”فَارْحْ، ثنِّي وَارْ إِتِّيرْونْعمَّارْصْ!\qt*  
\m \qt ذُوقّزْ س ؤُسْڒِيوْڒوْ، سْغُويّْ س جّهْذْ،\qt*  
\m \qt \+tl أَ\+tl* شمْ ثنِّي وَارْ إِسِّيننْ ڒوْجعْ ن ثَارْوَا،\qt*  
\m \qt مَاغَارْ ثَارْوَا ن ثنِّي ذِي سمْحنْ\qt*  
\m \qt ذ أَطَّاسْ خْ ثَارْوَا ن ثنِّي غَارْ إِدْجَا ورْيَازْ.“\qt* \x ◘ \xo 4:‏27 \xt إِشا. 54‏:‏1\x*   
\b  
\m
\v 28 مَاشَا نشِّينْ، \add أَ\add* أَيْثْمَا، ذ ثَارْوَا ن لْوَاعْذْ أَمْ إِسْحَاقْ. \x ◘ \xo 4:‏28 \xt رُوم. 9‏:‏7، 8. \x*  
\v 29 مَاشَا أَمْ ذِي ڒْوقْثْ نِّي وِي د-إِثْوَاخڒْقنْ عْلَاحْسَابْ دَّاثْ ثُوغَا إِمَارّثْ ونِّي د-إِتّْوَاخڒْقنْ عْلَاحْسَابْ أَرُّوحْ، أَمُّو عَاوذْ ڒخُّو. \x ◘ \xo 4:‏29 \xt أَمز. 21‏:‏9. \x*  
\v 30 مَاشَا مِينْ قَّارنْثْ ثِيرَا إِقدّْسنْ؟ ”نْضَارمْ بَارَّا ثَايَّا ذ مِّيسْ، مِينْزِي وَارْ إِتِّيڒِي مِّيسْ ن ثَايَّا ذ أَوْرِيثْ أَكْ-ذ مِّيسْ ن ثْحُورّشْثْ.“ \x ◘ \xo 4:‏30 \xt أَمز. 21‏:‏10. \x*  
\v 31 س ؤُينِّي، \add أَ\add* أَيْثْمَا، أَقَا وَارْ ندْجِي شَا ذ ثَارْوَا ن ثَايَّا، مَاشَا ثَارْوَا ن ثْحُورّشْثْ. \f ◼ \fr 4:‏31 \ft \+bd ’ثَارْوَا ن ثَايَّا‘\+bd* - إِخْسْ أَذْ يِينِي ’ثَارْوَا ن هَاجَارْ‘.\f*   
\b  
\b  
\m  
\c 5
\s1 ثِيڒلِّي ذِي لْمَاسِيحْ  
\m
\v 1 بدّمْ نِيشَانْ ذِي ثِيڒلِّي ثنِّي ؤُمِي ذ أَنغْ إِفكّْ لْمَاسِيحْ، ؤُشَا وَارْ تّْذكّْوِيڒمْ عَاوذْ، مَاحنْذْ أَذْ ثكْسِيمْ أَزَايْڒُو ن ثسْمُوغِي. \x ◘ \xo 5:‏1 \xt إِشا. 9‏:‏3؛ يُوح. 8‏:‏32؛ رُوم. 6‏:‏18؛ 1 بُط. 2‏:‏16. \x*   
\m
\v 2 أَقَا أَيِي نشّْ بُولُوسْ أَذْ أَومْ إِنِيغْ، مَاڒَا ثتّْوَاخثْنمْ، لْمَاسِيحْ وَارْ كنِّيوْ إِنفّعْ ذڭْ وَالُو. \x ◘ \xo 5:‏2 \xt ڒخ. 15‏:‏1. \x*  
\v 3 عَاوذْ شهّْذغْ إِ مَارَّا بْنَاذمْ إِ غَا إِتّْوَاخثْننْ، أَقَا نتَّا س ؤُمَارْوَاسْ حِيمَا أَذْ إِڭّْ مَارَّا مِينْ إِدْجَانْ ذِي شَّارِيعَا.  
\v 4 كنِّيوْ إِنِّي \add إِتّخْسنْ\add* أَذْ تّْوَاسڭّْذمْ س شَّارِيعَا، أَقَا ثْذوْڒنْ ثَارْخُومْ زِي لْمَاسِيحْ، ؤُشَا زِي أَرْضَا إِ زِي د-ثوْضَامْ.  
\v 5 مِينْزِي نشِّينْ نتّْرَاجَا أَسِيثمْ ن ثْسڭْذَا س أَرُّوحْ نِّي إِدْجَانْ زِي لْ-إِيمَانْ.  
\v 6 مَاغَارْ ذِي يَاسُوع لْمَاسِيحْ، أَخْثَانْ نِيغْ بْڒَا أَخْثَانْ وَارْ إِسكّْوِي وَالُو، مَاشَا مْغِيرْ لْ-إِيمَانْ وَاهَا نِّي إِتّْوَاكمّْڒنْ س ثَايْرِي. \x ◘ \xo 5:‏6 \xt مت. 12‏:‏50؛ يُوح. 15‏:‏14؛ 1 كُور. 7‏:‏19؛ 2 كُور. 5‏:‏17؛ ڭال. 6‏:‏15؛ كُول. 3‏:‏11؛ 1 تس. 1‏:‏3. \x*   
\m
\v 7 كنِّيوْ ثُوزّْڒمْ مْلِيحْ! وِي كنِّيوْ إِمنْعنْ أَڒَامِي وَارْ ثتّطِّيفمْ عَاذْ س ڒَامَانْ ذِي ثِيذتّْ؟ \x ◘ \xo 5:‏7 \xt ڭال. 3‏:‏1. \x*  
\v 8 طْوَاعْ-أَ نْومْ وَارْ إِدْجِي زڭْ ونِّي ذ أَومْ إِتّْڒَاغَانْ.  
\v 9 شْوَايْثْ ن ونْثُونْ إِسّْممّْ مَارَّا ڒْعجْنثْ \add ن وَارشْثِي\add*. \x ◘ \xo 5:‏9 \xt 1 كُور. 5‏:‏6. \x*  
\v 10 نشّْ تِّيقّغْ ذَايْومْ ذِي سِيذِيثْنغْ، أَقَا وَارْ غَارْونْ ثِيڒِي نّيّثْ نّغْنِي. ؤُ ونِّي كنِّيوْ إِتّْسدَّاعنْ، أَقَا أَذْ يَارْبُو ڒْحُوكْمْ، مَانْ ونْ مَا إِعْنَا نتَّا. \x ◘ \xo 5:‏10 \xt 2 كُور. 2‏:‏3؛ 8‏:‏22. \x*   
\m
\v 11 \add أَ\add* أَيْثْمَا، مَاڒَا نشّْ تّْبَارّْحغْ كنِّيوْ عَاذْ س وخْثَانْ، مَايمِّي عَاذْ إِ غَا تّْوَامَارّْثغْ؟ مَا \add خنِّي\add* ثتّْوَابطّڒْ ثَاعنْكْرِيفْثْ ن صَّالِيبْ؟ \x ◘ \xo 5:‏11 \xt 1 كُور. 1‏:‏23. \x*  
\v 12 معْلِيكْ قَاعْ تّخْسغْ، أَقَا إِنِّي إِتّخْسنْ أَذْ كنِّيوْ قسّنْ، أَذْ تّْوَاقسّنْ سِيمَانْثْ نْسنْ.\x ◘ \xo 5:‏12 \xt ياش. 7‏:‏25. \x*   
\m
\v 13 إِ ثِيڒلِّي ؤُمِي د-ثتّْوَاڒَاغَامْ كنِّيوْ، \add أَ\add* أَيْثْمَا، مَاشَا وَارْ تّْقدْجْبمْ ثِيڒلِّي أَمْ لْفُورْصَا إِ ويْسُومْ، مَاشَا سخَّارمْ إِجّنْ إِ ونّغْنِي س ثَايْرِي. \x ◘ \xo 5:‏13 \xt 1 كُور. 8‏:‏9؛ 1 بُط. 2‏:‏16؛ يَاه. 4. \x*  
\v 14 مِينْزِي مَارَّا شَّارِيعَا ثْكمّڒْ س يِيجّْ ن وَاوَاڒْ، أَقَا س مَانْ أَيَا: ”أَذْ ثخْسذْ جَّارْ نّشْ أَمشْنَاوْ إِخفْ نّشْ.“ \x ◘ \xo 5:‏14 \xt لَاوِي 19‏:‏18؛ مت. 22‏:‏39؛ مك. 12‏:‏31؛ رُوم. 13‏:‏8؛ يَاع. 2‏:‏8. \x*  
\v 15 مَاشَا مَاڒَا ثْزعّْفمْ ؤُ ثتّتّمْ إِجّنْ ونّغْنِي، \add خنِّي\add* حْضَامْ إِخفْ نْومْ وَارْ ثتّتّمْ شَا أَيَاوْيَا \add قَاعْ\add*. \x ◘ \xo 5:‏15 \xt 2 كُور. 12‏:‏20. \x*   
\b  
\m  
\s1 ثُوذَارْثْ س أَرُّوحْ إِقدّْسنْ  
\m
\v 16 مَاشَا نشّْ أَذْ أَومْ إِنِيغْ: ؤُيُورمْ ذِي أَرُّوحْ، وَارْ تّْكمّْڒنْعمَّارْصْ نّشْوَاثْ ن ويْسُومْ. \x ◘ \xo 5:‏16 \xt رُوم. 13‏:‏14؛ 1 بُط. 2‏:‏11. \x*  
\v 17 مِينْزِي دَّاثْ يَارزُّو مِينْ إِدْجَانْ ضِيدّْ ن أَرُّوحْ، ؤُشَا أَرُّوحْ يَارزُّو مِينْ إِدْجَانْ ضِيدّْ ن ويْسُومْ. نِيثْنِي س ثْنَاينْ تّْبدَّانْ أَكْ-ذ وَايَاوْيَا، خْ ؤُينِّي وَارْ ثْزمَّارمْ أَذْ ثڭّمْ مِينْ ثخْسمْ. \x ◘ \xo 5:‏17 \xt رُوم. 7‏:‏15‏-‏26. \x*  
\v 18 مَاشَا مَاڒَا أَرُّوحْ إِنْذهْ إِ كنِّيوْ، وَارْ ثدْجِيمْ عَاذْ سَاذُو شَّارِيعَا.   
\m
\v 19 \bd ڒخْذَايمْ ن ويْسُومْ\bd* بَاننْثْ، أَقَا أَثنْثْ ذ زِّينَا ذ ڒخْمجْ ذ فَارْقْ-شّْغڒْ \f ◼ \fr 5:‏19 \ft \+bd ’فَارْقْ-شّْغڒْ‘\+bd* - نِيغْ ’ڒقْبَاحثْ‘.\f*  \x ◘ \xo 5:‏19 \xt 1 كُور. 3‏:‏3؛ يَاع. 3‏:‏14. \x*  
\v 20 ذ ؤُعْبَاذْ إِ لْ-أَصْنَامْ ذ ثْسحَّارْثْ ذ ڒعْذَاوثْ ذ ؤُمْشبّشْ ذ ڒحْسذْ ذ ثفْقحْثْ ذ ؤُغوّغْ ذ ؤُبطُّو ذ ثْغُورِيوِينْ إِ د-إِتّفّْغنْ زڭْ وبْرِيذْ، \f ◼ \fr 5:‏20 \ft \+bd ’أَمْشُوبّشْ‘\+bd* - نِيغْ ’لْخِيلَافْ‘ (لِيخَالَافَاثْ).\f*  
\v 21 ذ ثُوسْمِي ذ ونْغَايْ ذ ؤُغلِّي ذ ڒفْسذْ ؤُڒَا ذ ثِيمسْڒَايِينْ نّغْنِيثْ أَمْ ثِينَا. إِنِّي إِتّْشغْڒنْ إِخفْ نْسنْ أَكْ-ذ ثْمسْڒَايِينْ-أَ، أَقَا إِزْوَارغْ نِّيغْ ث، ؤُ أَذْ ث إِنِيغْ عَاوذْ، أَقَا نِيثْنِي وَارْ وَارّْثنْ شَا ثَاڭلْذِيثْ ن أَربِّي. \x ◘ \xo 5:‏21 \xt 1 كُور. 6‏:‏10؛ أَفا. 5‏:‏5؛ كُول. 3‏:‏6؛ أَسَا. 22‏:‏15. \x*   
\m
\v 22 مَاشَا \bd ڒْغِيدْجثْ ن أَرُّوحْ\bd* أَقَا-ت ذ ثَايْرِي ذ ڒفْرَاحثْ ذ ڒهْنَا ذ ڒضْرَافثْ ذ تَّاسِيعْ ن ڒْخَاضَارْ ذ ثْشُونِي ذ لْ-إِيمَانْ ذ ثمْهِينْثْ ؤُڒَا ذ صّْبَارْ. \x ◘ \xo 5:‏22 \xt أَفا. 5‏:‏9. \x*  
\v 23 شَّارِيعَا وَارْ ثدْجِي ضِيدّْ ن ثْمسْڒَايِينْ-أَ. \x ◘ \xo 5:‏23 \xt 1 تِيم. 1‏:‏9. \x*  
\v 24 مَاشَا إِنِّي إِدْجَانْ زِي لْمَاسِيحْ أَقَا صلّْبنْ أَيْسُومْ نْسنْ أَكْ-ذ مَارَّا شّهْوَاثْ ذ نّشْوَاثْ. \x ◘ \xo 5:‏24 \xt رُوم. 6‏:‏6؛ 13‏:‏14؛ ڭال. 2‏:‏20؛ 1 بُط. 2‏:‏11. \x*  
\v 25 أجّْ أَنغْ أَذْ ندَّارْ س أَرُّوحْ ؤُ أَذْ نْسلّمْ إِخفْ نّغْ إِ أَرُّوحْ.  
\v 26 وَارْ ذ أَنغْ إِتّجِّي أَذْ نْوقَّارْ إِجّْ ونّغْنِي س نِّيفَاقْ، أَمْ نسّحْقَارَا إِجّنْ ونّغْنِي ؤُ نتَّاسمْ ؤُڒَا ذ إِجّنْ زڭْ ونّغْنِي.   
\b  
\b  
\m  
\c 6
\s1 إِعْدْجِيمنْ إِنڭُّورَا ذ ؤُسدْجمْ  
\m
\v 1 \add أَ\add* أَيْثْمَا، مَاڒَا حذْ جَارْ أَومْ إِوْضَا-د خَاسْ دّنْبْ، أجّْ \add خنِّي\add* إِنِّي إِڭُّورنْ ذِي أَرُّوحْ أَذْ ث سڭّْذنْ س أَرُّوحْ ن ثمْهِينْثْ. حْضَامْ، حِيمَا وَارْ ثتّْوَاجَارّْبمْ ؤُڒَا ذ كنِّيوْ. \f ◼ \fr 6:‏1 \ft \+bd ’إِوْضَا-د خَاسْ دّنْبْ‘\+bd* - نِيغْ: ’إِسّحْصرْ إِ-ث دّنْبْ‘.\f*  \x ◘ \xo 6:‏1 \xt رُوم. 14‏:‏1؛ 15‏:‏1؛ 1 كُور. 9‏:‏22. \x*   
\m
\v 2 كْسِيمْ دّْقڒْ إِجّنْ خْ ونّغْنِي، أَمُّو إِ غَا ثْكمّْڒمْ شَّارِيعَا ن لْمَاسِيحْ. \x ◘ \xo 6:‏2 \xt مت. 11‏:‏29؛ يُوح. 13‏:‏14؛ رُوم. 15‏:‏1؛ 1 تس. 5‏:‏14. \x*  
\v 3 مَاغَارْ مَاڒَا شَا ن يِيجّنْ إِتّْغِيڒْ أَسْ أَقَا نتَّا ذ شَا، أَمْ ث وَارْ إِدْجِي، إِخدّعْ إِخفْ نّسْ.  
\v 4 مَاشَا أجّْ كُوڒْ إِجّنْ أَذْ إِقدْجبْ ڒْخذْمثْ ن يِيخفْ نّسْ، خنِّي أَذْ غَارسْ يِيڒِي ؤُسمْغَارْ ذڭْ يِيخفْ نّسْ، وَارْ إِدْجِي ذڭْ إِنّغْنِي،  
\v 5 مِينْزِي كُوڒْ إِجّنْ أَذْ إِكْسِي دّْقڒْ ن يِيخفْ نّسْ. \x ◘ \xo 6:‏5 \xt إِزهد. 62‏:‏13؛ إِرْم. 17‏:‏10؛ 32‏:‏19؛ مت. 16‏:‏27؛ رُوم. 2‏:‏6؛ 14‏:‏12؛ 1 كُور. 3‏:‏8؛ 2 كُور. 5‏:‏10؛ أَسَا. 2‏:‏23؛ 22‏:‏12. \x*   
\m
\v 6 أجّْ ونِّي إِسْڒِينْ أَوَاڒْ، أَذْ إِشَارْشْ زِي مَارَّا ثِيصبْحَانِينْ \add إِ غَارسْ\add* أَكْ-ذ ونِّي زَّايسْ ث إِسْڒَانْ. \x ◘ \xo 6:‏6 \xt رُوم. 15‏:‏27؛ 1 كُور. 9‏:‏11. \x*   
\m
\v 7 وَارْ تّْخدّْعمْ إِخفْ نْومْ، أَربِّي وَارْ إِتّجِّي حذْ أَذْ خَاسْ إِقصَّارْ. مِينْزِي مِينْ مَا إِزَارْعْ بْنَاذمْ، أَذْ ث إِمْجَارْ عَاوذْ. \x ◘ \xo 6:‏7 \xt لك. 16‏:‏25؛ 1 كُور. 6‏:‏10. \x*  
\v 8 مِينْزِي ونِّي إِزَارّْعنْ ذڭْ ويْسُومْ، زڭْ ويْسُومْ أَذْ إِمْجَارْ ڒْغشّْ. مَاشَا ونِّي إِزَارّْعنْ ذِي أَرُّوحْ، زِي أَرُّوحْ أَذْ إِمْجَارْ ثُوذَارْثْ إِتّْذُومَانْ.  
\v 9 أجّْ أَنغْ وَارْ نتِّيحڒْ شَا ؤُمِي نتّڭّْ مِينْ إِدْجَانْ ذ أَصبْحَانْ، مِينْزِي أَذْ د-ثَاسْ ڒْوقْثْ نِّي ذِي غَا نمْجَارْ، ؤُ مَانْ أَيَا وَارْ ذ أَنغْ إِسِّيهِيڒْ شَا. \x ◘ \xo 6:‏9 \xt 2 تس. 3‏:‏13. \x*  
\v 10 أجّْ أَنغْ ڒخُّو، أَڒَامِي غَارْنغْ عَاذْ لْفُورْصَا، أَذْ نڭّْ ثْشُونِي إِ مَارَّا، أَمزْوَارُو إِ يِينِّي ذ إِشْرِيشنْ أَكِيذْنغْ ذِي ثَادَّارْثْ ن يِينِّي يُومْننْ. \x ◘ \xo 6:‏10 \xt 1 تِيم. 5‏:‏8. \x*   
\b  
\m
\v 11 خْزَارمْ، \add مَارَّا\add* ثِيرَا-يَا إِ ذ أَومْ د-ؤُرِيغْ، ؤُرِيغْ ت س ؤُفُوسْ إِنُو.  
\v 12 مَارَّا وِي إِخْسنْ أَذْ سّمْغَارنْ ذڭْ ويْسُومْ، أَقَا نِيثْنِي تّڭّنْ خَاومْ أَغِيڒْ حِيمَا أَذْ ثتّْوَاخثْنمْ حِيمَا وَارْ تّْوَامَارّْثنْ نِيثْنِي خْ سِّيبّثْ ن صَّالِيبْ ن لْمَاسِيحْ.  
\v 13 مِينْزِي ؤُڒَا ذ إِنِّي إِتّْوَاخثْننْ وَارْ طِّيفنْ شَا ذِي شَّارِيعَا، مَاشَا نِيثْنِي خْسنْ أَذْ ثتّْوَاخثْنمْ حِيمَا أَذْ سّمْغَارنْ \add ذِي ڒخْثَانْ\add* ذڭْ ويْسُومْ نْومْ.  
\v 14 مَاشَا إِڭّْوجنْ خَافِي مَاحنْذْ أَذْ سّمْغَارغْ مْغِيرْ ذِي صَّالِيبْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ س ونِّي ثتّْوَاصلّبْ دُّونشْثْ إِ نشّْ ؤُ نشّْ إِ دُّونشْثْ.  
\v 15 أَخْثَانْ نِيغْ بْڒَا أَخْثَانْ وَارْ إِسكّْوِي وَالُو، مَاشَا ونِّي د-إِتّْوَاخڒْقنْ زِي جْذِيذْ وَاهْ. \x ◘ \xo 6:‏15 \xt مت. 12‏:‏50؛ يُوح. 15‏:‏14؛ 2 كُور. 5‏:‏16؛ ڭال. 5‏:‏6؛ كُول. 3‏:‏11. \x*  
\v 16 مَارَّا وِي غَا يُويُورنْ عْلَاحْسَابْ أَبْرِيذْ-أَ، أَذْ خَاسنْ يِيڒِي ڒهْنَا ذ أَرّحْمثْ ؤُڒَا خْ إِسْرَائِيل ن أَربِّي. \x ◘ \xo 6:‏16 \xt إِزهد. 125‏:‏5. \x*   
\m
\v 17 وَارْ ذ أَيِي إِتّْسذِّيعْ حذْ، مِينْزِي إِوْيغْ-د شَّامَاثْ ن سِيذِيثْنغْ يَاسُوع ذِي أَرِّيمثْ إِنُو. \x ◘ \xo 6:‏17 \xt 2 كُور. 4‏:‏10. \x*   
\m
\v 18 \add أَ\add* أَيْثْمَا، أَذْ يِيڒِي أَرْضَا ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ أَكْ-ذ أَرُّوحْ نْومْ. أَمِينْ.   