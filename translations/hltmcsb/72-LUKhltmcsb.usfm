\p 
\v 18 Te \w dongah|strong="G3767"\w* koep a \w thui|strong="G3004"\w* \w tih\w*, \wj “ \w Balae|strong="G5101"\w* \w Pathen|strong="G2316"\w* \w kah|strong="G3588"\w* \w ram|strong="G0932"\w* \w phek|strong="G3664"\w* la aka \w om|strong="G2076"\w*?\wj*
\v 19 \wj \w Tedae|strong="G2532"\w* \w metlam|strong="G5101"\w* ka \w thuidoek|strong="G3666"\w* eh \w te|strong="G0848"\w*? Te te \w mukang|strong="G4615"\w* \w mu|strong="G2848"\w* \w phek|strong="G3664"\w* la \w om|strong="G2076"\w*. \w Te|strong="G3739"\w* te \w hlang|strong="G0444"\w* loh a \w loh|strong="G2983"\w* tih \w a|strong="G1438"\w* \w dum|strong="G2779"\w* \w ah|strong="G1519"\w* a \w haeh|strong="G0906"\w*. \w Tedae|strong="G2532"\w* a \w rhoeng|strong="G0837"\w* \w vaengah|strong="G2532"\w* \w thing|strong="G1186"\w* la \w poeh|strong="G1096"\w* \w tih|strong="G2532"\w* \w vaan|strong="G3772"\w* \w kah|strong="G3588"\w* \w vaa|strong="G4071"\w* \w loh|strong="G3588"\w* \w a|strong="G0846"\w* \w hlaeng|strong="G2798"\w* \w dongah|strong="G1722"\w* bu a \w tuk|strong="G2681"\w*,”\wj* \w a\w* \w ti|strong="G2036"\w* \w nah\w*.
\p 
\v 20 Te \w phoeiah|strong="G2532"\w*, \wj “ Ka \w thuidoek|strong="G3666"\w* thil ham \w Pathen|strong="G2316"\w* \w kah|strong="G3588"\w* \w ram|strong="G0932"\w* \w te|strong="G5101"\w* tah \w tolrhu|strong="G2219"\w* \w phek|strong="G3664"\w* la \w om|strong="G2076"\w*\wj*.
\v 21 \wj \w Te|strong="G3739"\w* te \w huta|strong="G1135"\w* loh a \w loh|strong="G2983"\w* tih \w vaidam|strong="G0224"\w* \w khoi|strong="G4568"\w* \w thum|strong="G5140"\w* \w boeih|strong="G3650"\w* a \w rhoi|strong="G2220"\w* \w hil|strong="G2193"\w* khaw \w a|strong="G3739"\w* \w hlum|strong="G1470"\w* \w thil|strong="G1519"\w*,” \wj* koep a \w ti|strong="G2036"\w*.
\s1 Long Caek
\p 
\v 22 \w Khopuei|strong="G4172"\w* \w vangca|strong="G2968"\w* \w ah|strong="G2596"\w* \w pah|strong="G1279"\w* \w tih\w* \w a\w* \w thuituen|strong="G1321"\w* \w phoeiah|strong="G2532"\w* \w tah\w* \w Jerusalem|strong="G2414"\w* \w la|strong="G1519"\w* \w a\w* \w caeh|strong="G4197"\w* long a \w tarhoek|strong="G4160"\w*.
\v 23 Te \w vaengah|strong="G1161"\w* \w hlang\w* \w pakhat|strong="G5100"\w* \w loh\w* \w a|strong="G0846"\w* \w taengah\w*, “\w Boeipa|strong="G2963"\w*, \w te|strong="G3588"\w* \w rhoek\w* \w ca|strong="G3641"\w* bueng \w khang|strong="G4982"\w* \w koinih|strong="G1487"\w*,” a \w ti|strong="G2036"\w* nah.
\p 
\v 24 Te \w dongah|strong="G1161"\w* Jesuh \w loh|strong="G3588"\w* \w amih|strong="G0848"\w* \w te|strong="G4314"\w*, \wj “ \w Thohka|strong="G2374"\w* \w caek|strong="G4728"\w* \w longah|strong="G1223"\w* \w kun|strong="G1525"\w* hamla \w thingthuel|strong="G0075"\w* uh lah. \w Nangmih|strong="G5213"\w* taengah ka \w thui|strong="G3004"\w*, a \w yet|strong="G4183"\w* loh \w kun|strong="G1525"\w* hamla a \w toem|strong="G2212"\w* uh \w suidae|strong="G2532"\w* \w noeng|strong="G2480"\w* uh \w mahpawh|strong="G3756"\w*\wj*.
\v 25 \wj \w Imkung|strong="G3617"\w* \w loh|strong="G3588"\w* \w thoo|strong="G1453"\w* \w tih|strong="G2532"\w* \w thohka|strong="G2374"\w* a \w khaih|strong="G0608"\w* \w nen|strong="G0575"\w* \w tah|strong="G0302"\w*, \w poeng|strong="G1854"\w* ah na \w pai|strong="G2476"\w* uh \w pahoi|strong="G0756"\w* \w vetih|strong="G2532"\w* \w thohka|strong="G2374"\w* \w te|strong="G3588"\w* na \w khoek|strong="G2925"\w* uh ni. Te vaengah\wj*, '\wj \w Boeipa|strong="G2963"\w*, \w kaimih|strong="G2254"\w* ham \w ong|strong="G0455"\w* dae\wj*,' \wj na \w ti|strong="G3004"\w* uh ni. \w Tedae|strong="G2532"\w* \w nangmih|strong="G5213"\w* te n'\w doo|strong="G0611"\w* vaengah\wj*, '\wj \w Nangmih|strong="G5209"\w* \w me|strong="G4159"\w* kah aka \w om|strong="G2075"\w* rhoek nim? kam \w ming|strong="G1492"\w* \w moenih|strong="G3756"\w*\wj*,’ \wj a \w ti|strong="G2046"\w* ni\wj*.
\v 26 \wj Te \w vaengah|strong="G5119"\w*\wj*, '\wj \w Namah|strong="G4675"\w* \w taengah|strong="G1799"\w* ka \w caak|strong="G5315"\w* ka \w ok|strong="G4095"\w* uh \w tih|strong="G2532"\w*, \w kaimih|strong="G2257"\w* kah \w toltung|strong="G4113"\w* \w ah|strong="G1722"\w* na \w thuituen|strong="G1321"\w* ta\wj*,’ \wj na \w ti|strong="G3004"\w* uh ni\wj*.
\v 27 \x - \xo 13.27 \xt Tgt 6. 9\x*\wj \w Tedae|strong="G2532"\w* \w nangmih|strong="G5213"\w* taengah a \w thui|strong="G2046"\w* vetih\wj*, '\wj \w Nangmih|strong="G5209"\w* \w mekah|strong="G4159"\w* aka \w om|strong="G2075"\w* rhoek nim kam \w ming|strong="G1492"\w* \w moenih|strong="G3756"\w*, \w boethae|strong="G0093"\w* kah \w bibikung|strong="G2040"\w* rhoek \w kai|strong="G1473"\w* taeng \w lamkah|strong="G0575"\w* loh \w boeih|strong="G3956"\w* \w nong|strong="G0868"\w* uh\wj*,’ \wj a \w ti|strong="G3004"\w* ni\wj*.
\v 28 \x - \xo 13.28 \xt Mat 22. 13; 25. 30\x*\x - \xo 13.28 \xt Mat 8. 11,12\x*\wj \w Te|strong="G1563"\w* ah te \w rhah|strong="G2805"\w* \w neh|strong="G2532"\w* \w no|strong="G3599"\w* \w rhuengnah|strong="G1030"\w* ni aka \w om|strong="G2071"\w* eh. \w Pathen|strong="G2316"\w* \w kah|strong="G3588"\w* \w ram|strong="G0932"\w* \w ah|strong="G1722"\w* \w Abraham|strong="G0011"\w*, \w Isaak|strong="G2464"\w*, \w Jakob|strong="G2384"\w* \w neh|strong="G2532"\w* \w tonghma|strong="G4396"\w* rhoek te \w boeih|strong="G3956"\w* na \w hmuh|strong="G3708"\w* uh \w vaengah|strong="G3752"\w* \w nangmih|strong="G5209"\w* te \w phawn|strong="G1854"\w* \w n'thaek|strong="G1544"\w* uh ni\wj*.
\v 29 \wj Te \w vaengah|strong="G2532"\w* \w khocuk|strong="G0395"\w* \w neh|strong="G2532"\w* \w khotlak|strong="G1424"\w* \w lamkah|strong="G0575"\w*, \w tlangpuei|strong="G1005"\w* \w neh|strong="G2532"\w* \w tuithim|strong="G3558"\w* \w lamkah|strong="G0575"\w* loh ha \w pawk|strong="G2240"\w* uh \w vetih|strong="G2532"\w* \w Pathen|strong="G2316"\w* \w kah|strong="G3588"\w* \w ram|strong="G0932"\w* \w ah|strong="G1722"\w* \w ngolhlung|strong="G0347"\w* uh ni\wj*.
\v 30 \x - \xo 13.30 \xt Mat 19. 30; 20. 16; Mrk 10. 31\x*\wj A \w hnuk|strong="G2078"\w* la aka \w om|strong="G1526"\w* \w rhoek|strong="G3739"\w* te \w lamhma|strong="G4413"\w* la \w om|strong="G2071"\w* uh \w vetih|strong="G2532"\w*, \w lamhma|strong="G4413"\w* la aka \w om|strong="G1526"\w* rhoek \w te|strong="G3739"\w* a \w hnuk|strong="G2078"\w* la \w om|strong="G2071"\w* uh ni \w ke|strong="G2400"\w*,” \wj* a \w ti|strong="G2036"\w* nah.
\s1 Jesus neh Herod Antipas
\p 
\v 31 \w Amah|strong="G0846"\w* \w tekah|strong="G3588"\w* \w a\w* \w tue|strong="G5610"\w* \w vaengah|strong="G1722"\w* \w Pharisee|strong="G5330"\w* \w pakhat|strong="G5100"\w* \w loh\w* \w Jesuh|strong="G2424"\w* \w te\w* \w a\w* \w paan|strong="G4334"\w* \w tih\w*, “\w Khoe|strong="G1831"\w* \w uh\w* \w lamtah|strong="G2532"\w* \w cet|strong="G4198"\w* \w dingdoeng|strong="G1782"\w* laeh, \w Herod|strong="G2264"\w* \w loh\w* \w nang|strong="G4571"\w* \w ngawn|strong="G0615"\w* \w ham\w* \w a\w* \w ngaih|strong="G2309"\w*,” a \w ti|strong="G3004"\w* nah.
\p 
\v 32 Te \w dongah|strong="G2532"\w* \w amih|strong="G0846"\w* te, \wj “ \w Cet|strong="G4198"\w* uh lamtah \w maetang|strong="G0258"\w* \w te|strong="G5026"\w* \w thui|strong="G2036"\w* pa uh, \w rhaithae|strong="G1140"\w* ka \w haek|strong="G1544"\w* \w tih|strong="G2532"\w* \w tihnin|strong="G4594"\w* ah \w hoeihnah|strong="G2392"\w* ka \w saii|strong="G0658"\w* he \w thangvuen|strong="G0839"\w* \w neh|strong="G2532"\w* \w omvai|strong="G5154"\w* \w ah|strong="G3588"\w* ka \w coeng|strong="G5048"\w* ni\wj*.
\v 33 \wj \w Tedae|strong="G4133"\w* \w kai|strong="G3165"\w* ham \w tihnin|strong="G4594"\w* \w neh|strong="G2532"\w* \w thangvuen|strong="G0839"\w* \w te|strong="G3588"\w* \w khaw|strong="G2532"\w* a \w kuek|strong="G1163"\w* dongah \w caeh|strong="G4198"\w* hamla \w om|strong="G2192"\w*. \w Jerusalem|strong="G2419"\w* \w voel|strong="G1854"\w* ah \w tonghma|strong="G4396"\w* \w sai a caeh|strong="G0622"\w* te \w yae|strong="G1735"\w* \w boel|strong="G3756"\w* saeh\wj*.
\s1 Jerusalem a Rhaengsae
\p 
\v 34 \wj \w Jerusalem|strong="G2419"\w*, \w Jerusalem|strong="G2419"\w*, \w tonghma|strong="G4396"\w* rhoek \w te|strong="G3588"\w* aka \w ngawn|strong="G0615"\w* \w tih|strong="G2532"\w* \w a|strong="G0848"\w* \w taengla|strong="G4314"\w* a \w tueih|strong="G0649"\w* pah rhoek \w te|strong="G3588"\w* khaw aka \w dae|strong="G3036"\w*, \w ainu|strong="G3733"\w* loh a \w phae|strong="G4420"\w* \w hmuiah|strong="G5259"\w* \w a|strong="G1438"\w* \w aicahui|strong="G3555"\w* khoep a ku vaengkah a \w longim|strong="G5158"\w* \w bangla|strong="G3739"\w*, \w na|strong="G4675"\w* \w ca|strong="G5043"\w* rhoek \w te|strong="G3739"\w* ka \w kholcui|strong="G1996"\w* ham ka \w ngaih|strong="G2309"\w* \w taitu|strong="G4212"\w* \w dae|strong="G2532"\w* na \w ngaih|strong="G2309"\w* uh \w pawh|strong="G3756"\w*\wj*.
\v 35 \x - \xo 13.35 \xt Tgt 118. 26\x*\wj \w Na|strong="G5216"\w* \w im|strong="G3624"\w* \w te|strong="G3588"\w* \w nangmih|strong="G5213"\w* taengla han \w hlah|strong="G0863"\w* \w coeng \w* \w he|strong="G2400"\w*. \w Tedae|strong="G1161"\w* \w nangmih|strong="G5213"\w* ham ni ka \w thui|strong="G3004"\w*. \w Boeipa|strong="G2963"\w* \w ming neh|strong="G1722"\w* aka \w pawk|strong="G2064"\w* \w tah|strong="G3588"\w* a \w yoethen|strong="G2127"\w*\wj*, '\wj na \w ti|strong="G2036"\w* \w uh tue te|strong="G3753"\w* ha \w pawk|strong="G2240"\w* \w duela|strong="G2193"\w* \w kai|strong="G3165"\w* nan \w hmuh|strong="G3708"\w* uh \w loengloeng|strong="G3361"\w* \w mahpawh|strong="G3756"\w*,” \wj* a \w ti|strong="G2036"\w* nah.
\c 14
\s1 Sabbath Boeipa
\p 
\v 1 Sabbath a pha vaengah Jesuh tah Pharisee boeilu pakhat im ah buh ca la cet. Te vaengah amah te a om thil uh tih a dawn uh.
\v 2 Te vaengah hlang pakhat bungthung aka khueh te a hmaiah pakcak a pawk pah.
\v 3 Te dongah Jesuh loh olming rhoek neh Pharisee rhoek te a doo tih a voek vaengah, \wj “Sabbath hnin ah tloh hoeih sak ham tueng a, a tueng moenih a?”\wj* a ti nah.
\p 
\v 4 Tedae amih loh a hil a phah uh dongah a hoeih sak hlang te a mawt tih a tueih.
\v 5 \x - \xo 14.5 \xt Mat 12. 11\x*Te phoeiah amih te, \wj “Na ca mai khaw, vaito mai khaw tangrhom ah aka cungku te, Sabbath hnin ah pahoi a doek moenih a?”\wj* a ti nah.
\p 
\v 6 Tedae te te oelh uh thai pawh.
\s1 A Dang La Aka Yalh
\p 
\v 7 Hmuensang te mat a laehdawn tih aka tuek, a cael rhoek te nuettahnah a thui pah.
\v 8 \x - \xo 14.8 \xt Olc 25. 6,7\x*Te vaengah amih te, \wj “Yuluei kung la hlang khat khat loh n'khue uh vaengah, hmuensang ah ngol uh boeh, anih loh a khue te nang lakah a khoelh la vik om ve.\wj*
\v 9 \wj Te vaengah nang neh anih aka khue te ha pawk vetih nang te, ‘Anih he hmuen pae dae,’ a ti ni. Te vaengah yah te na poh van vetih a hmuen hnukkhueng te na dang ni.\wj*
\v 10 \wj Te dongah n'khue vaengah cet lamtah hnukkhueng hmuen ah ngol. Te daengah ni nang aka khue te ha pawk vaengah nang te, ‘Paya aw, thoo hang dae,’ a ti vetih na taengkah aka ngol rhoek boeih taengah nang hamla thangpomnah a om eh.\wj*
\v 11 \x - \xo 14.11 \xt Mat 23. 12; Luk 18. 14\x*\wj Amah aka pomsang boeih tah tlarhoel vetih amah aka tlarhoel tah a pomsang ni,”\wj* a ti nah.
\p 
\v 12 Te phoeiah amah aka khue te khaw, \wj “Buhkoknah neh hlaembuh na saii vaengah, na paya, na manuca, na huiko, na imben kuirhang rhoek te khue boeh. Amih loh namah te n'buhung van vetih kutthungnah loh namah taengla ha thoeng ve.\wj*
\v 13 \wj Tedae buhloei na tael vaengah khodaeng, kut ngun kho ngun, aka khaem, mikdael te khue.\wj*
\v 14 \wj Yoethen la na om bitni, nang n'sah ham te khueh pawt cakhaw aka dueng rhoek kah thohkoepnah dongah nang ham a sah bitni,”\wj* a ti nah.
\s1 Hlaembuh Kawng Nuettahnah
\p 
\v 15 A yaak uh vaengah aka ngol rhoek khuikah pakhat loh, “Yoethen long te tah Pathen kah ram ah buh a caak ni,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 16 Anih te khaw Jesuh loh, \wj “Hlang pakhat loh hlaembuh muep a thong tih hlang muep a khue.\wj*
\v 17 \wj Hlaembuh tue ah tah a sal te a khue rhoek taengla a tueih tih, ‘Ham paan uh laeh, sikim la om coeng,’ a ti nah.\wj*
\v 18 \wj Tedae a bangtlang la boeih a thaanah uh tih, lamhma kah loh, ‘Lo ka lai tih aka hip la caeh ham a kueknah la ka om. Namah taengah kam bih mai eh, om mai saeh, kai tah ng'rhoe mai,’ a ti nah.\wj*
\v 19 \wj Pakhat loh, ‘Vaito a rhoi panga ka lai tih, nainong ham ka cet ni, Namah taengah kam bih mai eh, om mai saeh, kai tah ng'hoep mai,’ a ti nah.\wj*
\v 20 \wj Pakhat bal loh, ‘Yuu ka loh tih ka lo ham coeng mahpawh,’ a ti nah.\wj*
\v 21 \wj Te dongah sal te a pawk vaengah tah a boeipa taengla a puen pah. Te vaengah imkung tah kosi a hong tih a sal te, ‘Khopuei kah toltung neh imhlai laklo ah a loe la cet lamtah, khodaeng, a kut a kho aka ngun, mikdael, aka khaem te pahoi hang khuen,’ a ti nah.\wj*
\v 22 \wj Sal loh, ‘Boeipa, nan tueih bangla ka saii coeng dae a hmuen om pueng,’ a ti nah.\wj*
\v 23 \wj Te dongah boei loh sal taengah, ‘Khohla longpuei neh vongtung taengah khaw cet lamtah ha kun ham tanolh dae, te daengah ni ka im ah hlang a bae eh.\wj*
\v 24 \wj Nangmih taengah ka thui coeng, ka khue hlang rhoek loh kai kah hlaembuh ten uh boel saeh,’ a ti nah,”\wj* te a thui pah.
\s1 Hnukbang he A Phu Kuel
\p 
\v 25 Jesuh te hlangping loh muep a puei hatah, amih taengla mael tih,
\v 26 \x - \xo 14.26 \xt Mat 10. 37\x*\wj “Khat khat te kai taengla ha lo vaengah a napa neh a manu, a yuu neh a ca, pacaboeina neh tanu takhong, amah kah a hinglu khaw a toeng thil bal pawt atah ka hnukbang la om ham a coeng moenih.\wj*
\v 27 \x - \xo 14.27 \xt Mat 10. 38; 16. 24; Mrk 8. 34; Luk 9. 23\x*\wj Amah kah thinglam a koh pawt ah kai hnukla aka lo te tah ka hnukbang la om ham a coeng moenih.\wj*
\v 28 \wj Nangmih khui lamkah loh imsang sak ham aka ngaih te unim? Lamhma la ngol tih a hnonah te a tae moenih a? Imcoeng ham khueh mai cakhaw?\wj*
\v 29 \wj A khoengim a sut tih coeng thai pawt koinih aka hmu boeih loh anih te pahoi a tamdaeng ni.\wj*
\v 30 \wj hlang loh sak hamla a tong dae a coeng thai moenih,’ a ti uh ta.\wj*
\v 31 \wj Mebang manghai khaw manghai pakhat te a noem tih ni caem la a caeh. Te vaengah ngol lamhma tih a doe ham te thawng rha a om thai atah anih te thawng kul neh paan thil ham a moeh moenih a?\wj*
\v 32 \wj Te pawt koinih voelh a om vaengah rhoepnah ham laipai a tueih vetih a dawt ni.\wj*
\v 33 \wj Te dongah nangmih boeih khaw, a khuehtawn boeih aka hlah pawt te tah ka hnukbang la om ham a coeng moenih.\wj*
\v 34 \wj Lungkaeh khaw tui, tedae lungkaeh te khaw a dap atah ba nen lae a hlihlim sak eh?\wj*
\v 35 \wj Laimen ham khaw om pawt tih, aek lam khaw hoeikhang laklo pawt dongah phawn a voeih uh. Yaak nah hna aka khueh rhoek loh yaa uh,”\wj* a ti nah.
\c 15
\s1 Tu aka Hma Nuettahnah
\p 
\v 1 \x - \xo 15.1 \xt Luk 5. 29,30\x*A om uh vaengah mangmucoi rhoek neh hlangtholh rhoek loh anih taengah hnatun ham boeih a paan uh.
\v 2 Te vaengah Pharisee rhoek neh cadaek rhoek te cai uh tih, “Anih loh hlangtholh rhoek a doe tih amih taengah a caak,” a ti uh.
\p 
\v 3 Te dongah hekah nuettahnah he amih ham a thui pa tih,
\v 4 \wj “Nangmih khuikah mebang hlang khaw tu yakhat a khueh vetih te khui lamkah loh pakhat te poci koinih, sawmko pako te khosoek ah a hnoo tih a hmuh duela aka poci te a hnuk ah a hlak moenih a?\wj*
\v 5 \wj A hmuh vaengah khaw a laengpang dongah a tloeng tih omngaih ta.\wj*
\v 6 \wj Im la a pawk vaengah khaw a paya rhoek neh imben rhoek te a hueh tih, ‘Kamah taengah omngaih uh, ka tu aka poci te ka hmuh coeng,’ a ti.\wj*
\v 7 \wj Te vanbangla nangmih taengah ka thui. Yutnah aka ngoe pawh hlang dueng sawmko pako so lakah aka yut hlangtholh pakhat soah ni vaan ah omngaihnah a om eh.”\wj*
\s1 Tangka Hma
\p 
\v 8 \wj “Huta loh tangkanuei lung rha te a khueh. Tangkanuei pakhat te a hlong atah, hmaiim te a tok phoeiah im te a nawt, a hmuh pawt atah khaelh khaelh a tlap.\wj*
\v 9 \wj A hmuh daengah, a paya rhoek neh imben rhoek te a hueh tih, ‘Tangkanuei ka poci sak te ka hmuh dongah kamah taengah omngaih uh,’ a ti pueng.\wj*
\v 10 \wj Te vanbangla nangmih taengah kan thui. Hlangtholh pakhat a yut soah ni Pathen kah puencawn rhoek hmaiah omngaihnah a om,”\wj* a ti nah.
\s1 Capa Hlang Pam
\p 
\v 11 Te phoeiah, \wj “Hlang pakhat loh capa panit a khueh.\wj*
\v 12 \wj Amih rhoi khuiah a noe loh a napa te, ‘A pa, koe a kaekvang na hmoel te kamah m'pae laeh,’ a ti nah. Te dongah a napa loh amih rhoi ham khosaknah te a tael pah.\wj*
\v 13 \wj Tedae khohnin muep a koe kolla boeih aka kool a capa a noe tah kho hla la yiin. Te phoeiah a koe te pahoi a poek tih cungpoeh cungdam la hing.\wj*
\v 14 \wj Boeih a hnonah phoeiah tah te rhoek pingpang ah khokha loh muep a pai thil tih anih khaw vawt tangkhuet.\wj*
\v 15 \wj Te dongah te pingpang kah pilnam pakhat taengah cet tih kap. Te vaengah anih te ok vuelh ham lohma la a tueih.\wj*
\v 16 \wj Te vaengah ok loh a caak canghlam koi te caak ham a hue dae anih te pae uh pawh.\wj*
\v 17 \wj Te daengah amah te a cueih koep om tih, ‘A pa kah kutcoep rhoek te yet pataeng buh a coih sak uh dae kai tah khokha neh ka poci pahoi coeng.\wj*
\v 18 \wj Ka thoo vetih a pa taengla ka cet pawn ni. Amah taengah, “A pa, vaan neh nang hmaiah ka tholh coeng.\wj*
\v 19 \wj Na ca la khue ham khaw a koihvaih la ka om moenih, kai he na kutcoep pakhat la ng'khueh,” ka ti nah ni,’ a ti.\wj*
\v 20 \wj Te dongah thoo tih a napa te a paan. Tedae a hla la a om vaengah a napa loh a hmuh tih a thinphat. Te dongah yong tih a rhawn ah a kop tih a mok.\wj*
\v 21 \wj Te vaengah a capa loh, ‘A pa, vaan neh namah hmaiah ka tholh coeng, na ca la khue ham khaw ka a koihvaih la ka om moenih,’ a ti nah.\wj*
\v 22 \wj Tedae a napa loh a sal rhoek te, ‘Hnikul tanglue te a loe la hang khuen uh lamtah anih he bai sak uh. A kut dongah kutbuen, a kho dongah khokhom buen sak uh.\wj*
\v 23 \wj Vaito puetsuet te han khuen uh, te te ngawn uh. Te phoeiah uum uh sih lamtah ca uh sih.\wj*
\v 24 \wj Ka ca a duek la aka om he koep hing, aka poci la om dae koep a phoe coeng dongah pahoi uum sih,’ a ti nah.\wj*
\p 
\v 25 \wj Te vaengah lohma ah aka om a capa a ham te, im vat ham pha tih toembael neh a lam uh te a yaak.\wj*
\v 26 \wj Te dongah camoe pakhat a khue tih tekah hno aka om te a dawt.\wj*
\v 27 \wj Te long te anih taengah, ‘Na mana te ha pawk coeng. Te dongah na pa loh vaito puetsuet te a ngawn tih anih te sading la a doe,’ a ti nah.”\wj*
\p 
\v 28 \wj “Te dongah kosi a hong tih kun ham ngaih pawh. Tedae a napa tah cet tih anih te a hloep.\wj*
\v 29 \wj Tedae a napa te a doo tih, ‘Kum, he yet na taengah sal ka bi tih na olpaek ka poe moenih he. Tedae kai ham tah ka paya neh uum hamla maae pataeng nan paek moenih.\wj*
\v 30 \wj Tedae hlanghalh rhoek neh na khosaknah aka yoop na capa tah ha pawk vaengah, vaito puetsuet te anih ham na ngawn pah,’ a ti nah.”\wj*
\p 
\v 31 \wj “Tedae a napa loh amah te, ‘Camoe aw, nang tah kai taengah rhawp na om tih, kai koe boeih he nang hut coeng ni.\wj*
\v 32 \wj Tedae uum vaengah khaw omngaih ham a kuek ta. Na mana tah aka duek la om coeng dae ha hing koep, poci coeng dae koep ha phoe,’ a ti,”\wj* a ti nah.
\c 16
\s1 Hnokhoem Thae
\p 
\v 1 A hnukbang rhoek te khaw, \wj “Hlang pakhat tah kuirhang la om tih hnokhoem a khueh. Te long te a khuehtawn a haeh pah dongah amah a khotoh nah.\wj*
\v 2 \wj Te dongah anih te a khue tih, ‘Nang kawng ka yaak he me tlam lae? Na hnokhoemnah dongkah olka te thuung laeh, na khoom ham na coeng voel moenih,’ a ti nah.\wj*
\v 3 \wj Te vaengah hnokhoem amah te, ‘Balae ka saii lah eh? Ka boeipa loh hnokhoemnah he kai lamloh a lat coeng, diklai daeng ham khaw ka noeng pawh, bih ham khaw ka yak,\wj*
\v 4 \wj Ka saii ham te ka ming coeng. Te daengah ni hnokhoemnah lamkah ka puen uh vaengah a im khuila kai n'doe uh eh,’ a ti.\wj*
\v 5 \wj Te dongah, a boeipa kah purhong rhoek te rhip a khue tih, lamhma taengah, ‘Ka boeipa taengah meyet na ba?’ a ti nah.\wj*
\v 6 \wj Te long te, ‘Situi um yakhat,’ a ti nah. Te vaengah anih te, ‘Na cabu na doe vaengah ngol pahoi lamtah sawmnga mah daek,’ a ti nah.\wj*
\v 7 \wj Pakhat te khaw, ‘Nang tah meyet na ba,’ a ti nah. Te long te, ‘Cang phueih yakhat,’ a ti nah. Anih te, ‘Cabu na doe vaengah sawmrhet la daek,’ a ti nah.\wj*
\v 8 \wj A thai a lai neh a saii dongah boethae kah hnokhoem te boeipa loh a koeh. Ta kumhal kah ca rhoek he amah cadil khuiah tah vangnah kah a ca rhoek lakah cueih uh.\wj*
\v 9 \wj Te dongah kai loh nangmih taengah ka thui, Boethae laikhuehtawn te khaw na paya la khueh uh. Te daengah ni dungyan dap khuila na khum vaengah n'doe uh eh.\wj*
\v 10 \wj A yit dongah uepom la aka om tah a len dongah khaw uepom la om tih, a yit dongah aka halang tah a len dongah khaw halang.\wj*
\v 11 \wj Halang, laikhuehtawn neh uepom la na om uh pawt bal atah unim nangmih rhep aka tangnah te?\wj*
\v 12 \wj Te dongah na hlanglang tih uepom la na om pawt atah na koe te u long nangmih m'paek eh.\wj*
\v 13 \x - \xo 16.13 \xt Mat 6. 24\x*\wj Imkhut pakhat loh boei panit kah sal a bi thai moenih, pakhat te a toeng vetih pakhat te a lungnah ni, pakhat te a talong vetih pakhat te a hnoel ni. Pathen neh laikhuehtawn kah sal na bi rhenten thai moenih,”\wj* a ti nah.
\s1 Ram Kah A Phu
\p 
\v 14 Te te naivoei la aka om Pharisee rhoek loh boeih a yaak uh vaengah amah te a nueih thil uh.
\v 15 Te dongah amih te, \wj “Nangmih loh hlang hmaiah aka tang la na om uh. Tedae Pathen loh nangmih thinko te a ming. Hlang soah aka sang te Pathen hmaiah tueilaehnah la om.\wj*
\v 16 \x - \xo 16.16 \xt Mat 11. 12,13\x*\wj Olkhueng neh tonghma rhoek loh Johan hil, te lamkah loh Pathen kah ram tah ana phong coeng tih a khuila la boeih ana ael uh.\wj*
\v 17 \x - \xo 16.17 \xt Mat 5. 18\x*\wj Olkhueng te a dek pakhat a rhul lakah vaan neh diklai a khum te a phoeng la om pueng.\wj*
\v 18 \x - \xo 16.18 \xt Mat 5. 32; 1Ko 7. 10,11\x*\wj A yuu te a tueih tih a tloe aka lo boeih tah samphaih coeng. Te phoeiah va aka ma aka yunah te khaw samphaih.\wj*
\s1 Kuirhang neh Lazarus
\p 
\v 19 \wj “Hlang pakhat tah kuirhang la om. Te dongah daidi, hnithen neh khuk uh tih hnin takuem thayoei tuipan la a uum.\wj*
\v 20 \wj Te vaengah khodaeng pakhat, a ming ah Lazarus tah buhlut neh a vongka ah a yalh pah.\wj*
\v 21 \wj Te dongah kuirhang caboei lamkah aka bo nen te bunghah khaw a nai. Tedae ui rhoek long pataeng ha pawk uh vaengah a buhlut te a laeh pa uh.\wj*
\v 22 \wj Tedae khodaeng te a duek vaengah puencawn rhoek loh Abraham rhang dongla a khuen. Te phoeiah kuirhang te khaw duek tih a up uh.\wj*
\v 23 \wj Tedae saelkhui ah a mik a hoh tih nganboh neh kho a sak vaengah tah Abraham neh a rhang dongkah Lazarus te a hla lamkah a hm uh.\wj*
\v 24 \wj Te dongah a pang neh, ‘A pa Abraham, kai he n'rhen lamtah Lazarus te han tueih mai. A kutdawn kah a hmoicue te tui dongah naek saeh lamtah ka lai he sul sak saeh, hmaitak khuiah mat n'yuek coeng he,’ a ti nah.”\wj*
\p 
\v 25 \wj “Tedae Abraham loh, ‘Camoe, na hingnah dongkah na hnothen na dang te poek. Te vaengah Lazarus tah yoethae bangla om. Tedae anih a mong vaengah he nang tah patang loh n'yuek coeng.\wj*
\v 26 \wj He rhoek boeih khuiah khaw kaimih neh nangmih laklo kah longhoi tah muep n'lak coeng. Te dongah nangmih taengla hlaikan dingdoeng aka ngaih long khaw coeng pawh, kaimih taengla hlaikan dingdoeng ham khaw coeng pawh,’ a ti nah.”\wj*
\p 
\v 27 \wj “Te phoeiah, ‘A pa namah ni kan hloep. Te dongah anih te a pa im la tueih mai.\wj*
\v 28 \wj Manuca panga ka khueh dongah amih te uen mai saeh. Te daengah ni amih khaw hekah nganboh hmuen la ha pawk uh pawt eh,’ a ti nah.”\wj*
\p 
\v 29 \wj “Tedae Abraham loh, ‘Moses neh tonghma te a khueh uh ta, amih taengah hnatun uh saeh,’ a ti nah.\wj*
\v 30 \wj Tedae te long te, ‘Moenih, a pa Abraham, aka duek tangtae pakhat loh amih te paan koinih yut uh ni,’ a ti nah.”\wj*
\p 
\v 31 \wj “Tedae anih te, ‘Moses neh tonghma rhoek kah olthui te a hnatun uh pawt atah, duek khui lamkah khat khat thoo cakhaw ngaitang mahpawh,’ a ti nah,”\wj* a ti.
\c 17
\s1 Jesuh Taengkah Thuituennah
\p 
\v 1 Te phoeiah a hnukbang rhoek te, \wj “Thangkui te a thoeng pawt ham om tloel coeng. Tedae anunae anih lamloh aka thoeng sak aih.\wj*
\v 2 \wj He camoe rhoek khuikah pakhat a khah ham lakah tah a rhawn ah lungto phaklung a oi tih tuili la voei koinih anih ham hoeikhang lah.\wj*
\v 3 \x - \xo 17.3 \xt Mat 18. 15\x*\wj Namamih te ngaithuen uh, na manuca loh a tholh atah amah te toel, a yut atah anih te hlah laeh.\wj*
\v 4 \wj Hnin at neh nang soah voei rhih tholh coeng dae namah taengla voei rhih ha bal tih, ‘Ka yut,’ a ti coeng atah anih te hlah laeh,”\wj* a ti nah.
\s1 Tangnah neh Pongthoh Nah
\p 
\v 5 Caeltueih rhoek loh Boeipa taengah, “Kaimih ham tangnah han thap lah,” a ti uh.
\p 
\v 6 Tedae Boeipa loh, \wj “Tangnah he mukang mu tet na khueh uh koinih, hekah thaihae kung he, ‘Phong uh lamtah tuili ah phung,\wj*’ \wj na ti uh mai cakhaw nangmih kah te a ngai ni.\wj*
\v 7 \wj Nangmih khuiah sal aka khueh te tah lai a thol pah tih boiva a dawn pah. Lohma lamkah a paipaek vaengah anih te u long, ‘Ha kun lamtah cawt ngol dae,’ a ti na eh?\wj*
\v 8 \wj Anih te, ‘Mebang khaw tawn lamtah ka ca eh, te phoeiah cihnin vaep lamtah ka caak ka ok vaengah kai taengah thotat, te phoeiah ni na caak na ok eh,’ ti na mahpawt nim?\wj*
\v 9 \wj A uen te a saii dongah sal soah lungvatnah khueh mapawt nim?\wj*
\v 10 \wj Nangmih khaw, nangmih ng'uen te boeih na saii uh tangloeng dae, ‘Kaimih tah sal hlangkhue hlangvaih rhoek ni, saii ham a kuek te ni n'saii,’ ti uh mai,”\wj* a ti nah.
\s1 Hmaibae Hlangrha
\p 
\v 11 Jerusalem la a caeh a om vaengah Jesuh tah Samaria neh Galilee laklo longah cet.
\v 12 Te vaengah vangca pakhat la a kun hatah hmaibae hlang parha loh Jesuh te a doe uh tih amamih tah soei pai uh.
\v 13 Te phoeiah a ol a huel uh tih, “Boeipa Jesuh kaimih n'rhen lah,” a ti uh.
\p 
\v 14 \x - \xo 17.14 \xt Tho 14. 1-32\x*Amih te a hmuh vaengah, \wj “Cet uh lamtah namamih te khosoih rhoek taengah tueng uh,”\wj* a ti nah.
\p Tedae a caeh uh li vaengah mah amih te boeih cim uh.
\v 15 Tedae amih khuikah pakhat long tah a hoeih te a hmuh vaengah bal tih ol ue la Pathen te a thangpom.
\v 16 Te phoeiah anih tah Samaria dae ni a kho kung ah maelhmai a buluk thil tih Jesuh te a uem.
\v 17 Te dongah Jesuh loh a doo tih, \wj “Parha la a cim uh moenih a? Pako rhoek ta melae?\wj*
\v 18 \wj Anih kholong hlang pawt atah Pathen te thangpomnah paek ham aka bal hmu uh boel saeh a?”\wj* a ti nah.
\p 
\v 19 Te phoeiah anih te, \wj “Thoo, cet laeh, namah kah tangnah loh namah ng'khang coeng,”\wj* a ti nah.
\s1 Ram Ha Pai
\p 
\v 20 Pathen kah ram ha pawk vaengkah te Pharisee rhoek loh a dawt dongah amih te a doo tih, \wj “Pathen kah ram tah hmuhnah neh ha pawk moenih.\wj*
\v 21 \wj ‘He la he, ke la ke,’ ti uh mahpawh. Pathen kah ram tah namamih khuiah ni a om te,”\wj* a ti nah.
\p 
\v 22 Te phoeiah hnukbang rhoek te, \wj “Khohnin ha pawk vaengah hlang capa kah khohnin te hnin at hmuh ham na hue uh suidae na hmuh uh mahpawh.\wj*
\v 23 \wj Nangmih taengah, ‘Ke la ke, he la he,’ a ti uh akhaw cet uh boeh, hnuktlak uh boeh.\wj*
\v 24 \wj Khophaa loh phaa tih vaan hmui pakhat lamkah loh vaan hmui pakhat la sae ni. Hlang capa tah amah tue vaengah ha om tangloeng bitni.\wj*
\v 25 \wj Tedae lamhma la muep a patang ham neh tahae cadil loh a hnawt ham khaw a kuek.\wj*
\v 26 \x - \xo 17.26 \xt Sue 6. 5-8\x*\wj Noah tue vaengkah a om vanbangla, hlang capa kah a tue vaengah khaw om van ni.\wj*
\v 27 \x - \xo 17.27 \xt Sue 7. 6-24\x*\wj Noah lawng khuila a kun khohnin duela yuloh rhaihlan neh a caak a ok uh. Te dongah tuilii ha pawk vaengah boeih poci.\wj*
\v 28 \x - \xo 17.28 \xt Sue 18. 20—19. 25\x*\wj Lot kah khohnin vaengah khaw amah boeiloeih la om uh tih a caak uh‍, a ok uh‍, a lai uh‍, a yoih uh‍, a tawn uh‍, a sak uh‍.\wj*
\v 29 \wj Tedae Sodom lamkah loh Lot a caeh khohnin ah, vaan lamkah hmai neh kat a tlan pah tih boeih poci.\wj*
\v 30 \wj Hlang capa a pumphoe tue vaengah amah boeiloeih la om ni.\wj*
\v 31 \x - \xo 17.31 \xt Mat 24. 17,18; Mrk 13. 15,16\x*\wj Te khohnin vaengah imphu ah aka om tah, im khuikah a hno te loh hamla suntla boel saeh. Lohma kah long khaw a hnuk la mael van boel saeh.\wj*
\v 32 \x - \xo 17.32 \xt Sue 19. 26\x*\wj Lot yuu te poek uh.\wj*
\v 33 \x - \xo 17.33 \xt Mat 10. 39; 16. 25; Mrk 8. 35; Luk 9. 24; Jhn 12. 25\x*\wj A hinglu te kutloh ham aka toem long tah poci ni, tedae aka hlong long tah tekah a hing thil ni.\wj*
\v 34 \wj Nangmih taengah ka thui, tekah khoyin ah panit loh thingkong pakhat dongah om rhoi cakhaw, pakhat te a khuen vetih pakhat te a hlun ni.\wj*
\v 35 \wj Amah nawn ah sum aka kuelh panit om ni. Pakhat te a khuen vetih, pakhat a hlun ni,”\wj* a ti nah.
\p 
\v 36 Te dongah amah te a doo uh tih, “Melae Boeipa,” a ti na uh.
\p 
\v 37 Tedae amih te, \wj “Rhok te tah langta loh pahoi a bo van ni,”\wj* a ti nah.
\c 18
\s1 Kobawt Kolla Thangthuinah
\p 
\v 1 Thangthui yoeyah ham neh thathae pawt ham a kuek soah amih te nuettahnah neh a voek tih,
\v 2 \wj “Kho pakhat ah laitloekkung pakhat om tih Pathen taengah birhih pawt tih hlang taengah a yahnah om pawh.\wj*
\v 3 \wj Te vaengah kho khuiah aka om nuhmai loh anih te a paan tih, ‘Ka kocaelh hmaiah kai n'tang sak,’ a ti nah.\wj*
\v 4 \wj Tedae te khohnin ham ngaih pawh. Te phoeiah amah te, ‘Pathen taengah ka birhih pawt tih hlang te ka yahnah mai ngawn pawh.\wj*
\v 5 \wj Te akhaw he nuhmai he kamah thakthaenah la n'toeh dongah anih ka tang sak eh. Te daengah ni a bawtnah la pawk vetih kai n'ngae pawt eh,’ a ti,”\wj* a ti nah.
\p 
\v 6 Te phoeiah Boeipa loh, \wj “Laitloekkung loh a boethae kah a cal te ya uh.\wj*
\v 7 \wj A taengah khoyin khothaih aka pang, a coelh hlang kah kutthungnah te Pathen loh a saii mueh moenih. Te dongah amih taengah a thinsen a?\wj*
\v 8 \wj Nangmih taengah ka thui te, amih kah kutthungnah te thamaa la a saii ni ta. Tedae hlang capa ha pawk vaengah tangnah he diklai hmanah a hmuh venim?”\wj* a ti nah.
\s1 Pharisee neh Mangmucoi Kah Thangthuinah
\p 
\v 9 A dueng la om ham amah neh amah pangtung tih a tloe aka hnaelcoe hlangvang rhoek te khaw hekah nuettahnah neh,
\v 10 \wj “Hlang panit tah thangthui ham bawkim la cet rhoi. Pakhat tah Pharisee tih pakhat te mangmu aka coi ni.\wj*
\v 11 \wj Pharisee tah amah la pai tih, ‘Hlang tloe kutveet aka khueh, halang rhoek, samphaih rhoek, neh he kah mangmucoi bangla ka om pawt dongah Pathen nang he kan uem,\wj*
\v 12 \wj Sabbath te hnavoei ka yaeh, ka kaelh boeih te parha pakhat la vawpvawp ka paek,’ tila thangthui.\wj*
\v 13 \wj Tedae mangmucoi tah soei pai tih mik pataeng vaan la a dai ngaih pawh. A lungkoe te a tum tih, ‘Pathen aw, ka tholh he han dawth lah,’ a ti.\wj*
\v 14 \x - \xo 18.14 \xt Mat 23. 12; Luk 14. 11\x*\wj Nangmih taengah ka thui, anih he pakhat lakah aka tang ngai la a im te a paan. Te dongah amah neh amah aka pomsang boeih tah a tlarhoel sak ni. Tedae amah neh amah aka yalh tah a pomsang ni,”\wj* a ti nah.
\s1 Camoe a Uem
\p 
\v 15 Te vaengah cahni rhoek te taek van saeh tila amah taengla a bawnhlak uh. Tedae hnukbang rhoek loh a hmuh vaengah amih te a tlung uh.
\v 16 Tedae Jesuh loh amih a khue tih, \wj “Camoe rhoek te kamah taengla ha pawk ham han hlah uh, amih te kang uh boeh. Amih ham ni Pathen kah ram a om.\wj*
\v 17 \wj Nangmih taengah rhep ka thui, Pathen kah ram te camoe bangla aka doe pawt long tah a khuiah kun loengloeng mahpawh,”\wj* a ti nah.
\s1 Khoboei Cadong
\p 
\v 18 Jesuh te boei pakhat loh a dawt tih, “Saya then, mebang ka saii nen lae dungyan hingnah ka pang eh?” a ti nah.
\p 
\v 19 Te dongah anih te Jesuh loh, \wj “Balae tih kai he then na ti? Pathen amah bueng pawt atah aka then a om moenih.\wj*
\v 20 \x - \xo 18.20 \xt Sng 20. 14; Olr 5. 18; \xt Sng 20. 13; Olr 5. 17; \xt Sng 20. 15; Olr 5. 19; \xt Sng 20. 16; Olr 5. 20; \xt Sng 20. 12; Olr 5. 16\x*\wj Olpaek rhoek te na ming coeng, samphaih boeh, hlang ngawn boeh, huen boeh, laithae boeh, na pa neh na nu te hinyah,”\wj* a ti nah.
\p 
\v 21 Tedae te long te, “Te rhoek te ka camoe lamkah loh boeih ka tuem coeng,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 22 A yaak vaengah Jesuh loh anih te, \wj “Pakhat na vawt pueng. Na khueh sarhui te boeih yoi lamtah khodaeng rhoek ham tael pah. Te daengah ni vaan ah khohrhang na khueh eh. Te phoeiah kai taengah pahoi ha bang,”\wj* a ti nah.
\p 
\v 23 Tedae anih te kuirhang la muep a om dongah te ol te ngang a yaak vaengah sut om.
\s1 Khuehtawn neh Pathen Ram
\p 
\v 24 Ngang a yaak te Jesuh loh a hmuh vaengah, \wj “Tangka aka khueh rhoek loh Pathen kah ram khuila a kun ham tah bahoeng kuel mai.\wj*
\v 25 \wj Kuirhang te Pathen ram khuiah a kun lakah phamet khui ah kalauk a kun te a phoeng la om,”\wj* a ti nah.
\p 
\v 26 Aka ya rhoek loh, “Te koinih unim aka daem thai ve?” a ti uh.
\p 
\v 27 Tedae Jesuh loh, \wj “Hlang loh a tloel nah te Pathen taengah tah yoeikoek la om mai,”\wj* a ti nah.
\p 
\v 28 Te vaengah Peter loh, “Amah kah imlo aka toeng kaimih long tah namah kam vai uh he,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 29 Te dongah Jesuh loh amih te, \wj “Nangmih taengah rhep ka thui, Pathen kah ram ham im khaw, yuu khaw, manuca khaw, manu napa khaw, a ca khaw aka toeng te a om moenih.\wj*
\v 30 \wj Anih tah tahae tue vaengah a pawklaih neh kumhal ah dungyan hingnah aka thoeng te dang mueh pawt suidae?\wj* a ti nah.
\s1 A Dueknah Te A Thui Bal
\p 
\v 31 Hlainit te a khuen tih amih taengah, \wj “Jerusalem la cet uh sih ne, tonghma rhoek loh a daek hlang capa kawng te boeih soep pawn ni.\wj*
\v 32 \wj Namtom rhoek taengah a voeih vetih a tamdaeng ni, a neet ni, a timthoih ni,\wj*
\v 33 \wj Anih te a boh uh vetih a ngawn uh ni, tedae a thum hnin ah koep thoo ni,”\wj* a ti nah.
\p 
\v 34 Tedae amih loh te te a hmuhming uh moenih. Hekah oltak long he amih taeng lamloh a thuh uh pueng dongah a thui te yakming uh pawh.
\s1 Mikdael Loh Kho A Hmuh
\p 
\v 35 Jerikho te a pha tom vaengah mikdael pakhat loh long taengah ngol tih a bih.
\v 36 Hlangping kah a pah te a yaak vaengah, “Balae aka om he,” a ti.
\p 
\v 37 Te vaengah Nazareth Jesuh a pah te a taengla a puen pa uh.
\v 38 Te dongah pang tih, “David Capa, Jesuh, kai n'rhen lah,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 39 Te vaengah aka lamhma rhoek loh anih te kamkhuem sak ham a ho uh. Tedae anih te muep lat pang tih, “David capa kai ng'rhen lah,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 40 Te dongah Jesuh tah pai tih, anih te amah taengla mawt hamla ol a paek. A yoei uh vaengah Jesuh loh mikdael amah te a dawt.
\v 41 \wj “Nang ham na ngaih te balae kan saii eh,”\wj* a ti nah.
\p Te vaengah mikdael loh, “Boeipa, hmuh ham,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 42 Jesuh loh anih te, \wj “Tueng saeh, namah kah tangnah loh nang n'khang,”\wj* a ti nah.
\p 
\v 43 Te vaengah pahoi a hmuh dongah Jesuh hnuk a vai doeah Pathen te a thangpom. Pilnam boeih long khaw a hmuh vaengah Pathen te thangthennah a paek.
\c 19
\s1 Zakkhaeus Taengah Pah
\p 
\v 1 Jerikho te a kun thil tih a hil.
\v 2 Te vaengah hlang pakhat, a ming ah Zakkhaeus la a khue te lawt om. Anih tah mangmu boei neh kuirhang la om.
\v 3 Anih long khaw Jesuh te hmuh hamla a toem. Tedae a pumrho he merheh la a om dongah hlangping te aep thai pawh.
\v 4 Tedae a khum ham te a om coeng dongah a hmai la a khal tih amah hmuh ham thaibah dongla yoeng.
\v 5 Tekah hmuen la a pha vaengah Jesuh tah oeloe tih anih te, \wj “Zakkhaeus, a loe la rhum, tihnin ah nang im ah ka naeh ham a kuek,”\wj* a ti nah.
\p 
\v 6 Te dongah suntla tok tih Jesuh a doe te omngaih coeng.
\v 7 Boeih a hmuh uh vaengah cai uh tih, “Hlang tholh taengah pah hamla kun,” a ti uh.
\p 
\v 8 A pai neh Zakkhaeus loh Boeipa taengah, “Boeipa, Ka khuehtawn he rhakthuem he khodaeng rhoek ka paek. Hlang khat khat kah hno khat khat ni ka rhawt pah bal atah rhaepli la ka thuung coeng he,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 9 Te dongah anih te Jesuh loh, \wj “Anih tah Abraham capa la a om van dongah tihnin ah tah khangnah loh he imkhui la pai coeng.\wj*
\v 10 \x - \xo 19.10 \xt Mat 18. 11\x*\wj Hlang Capa ha pawk he aka poci te toem ham neh khang ham rhoe pai ni,”\wj* a ti.
\s1 Tangka Nuettahnah
\p 
\v 11 Jerusalem a pha tom vaengah a yaak neh Pathen kah ram a tueng hamla cai tomlael coeng tila a poek dongah nuettahnah pakhat te a thap tih a thui.
\v 12 Te dongah, \wj “Tongpa hlangtang pakhat tah, a ram loh ham kho hla la cet tih ha voei hamla cai.\wj*
\v 13 \wj Te dongah a sal hlangrha te a khue tih mina lungrha te amih taengah a paek. Te phoeiah amih te, ‘Amah ka pawk hil thenpom uh,’ a ti nah.\wj*
\v 14 \wj Tedae a pilnam rhoek loh anih te a hmuhuet uh. Te dongah amah hnukah laipai tloep a tueih uh tih, ‘Kaimih soah a manghai ham he ka ngaih uh moenih,\wj*’ \wj a ti na uh.\wj*
\v 15 \wj Ram te a loh tih amah ha mael vaengah tah tangka a paek a sal rhoek te amah taengla a khue tih metla a thenpom uh khaw ming hamla a dawt.\wj*
\v 16 \wj Te vaengah aka pawk lamhma loh, ‘Boeipa, nang kah mina pakhat te mina parha ka kum thil,’ a ti nah.\wj*
\v 17 \wj Te vaengah anih te, ‘Then, sal then a yit dongah uepom la na om tih, kho parha soah saithainah aka khueh la om laeh,’ a ti nah.\wj*
\v 18 \wj Aka pawk pabae long khaw, ‘Nang kah, mina loh mina panga a sak boeipa,’ a ti nah.\wj*
\v 19 \wj Anih khaw, ‘Nang loh kho panga om thil van,\wj*’ \wj a ti nah.\wj*
\v 20 \wj Te phoeiah pakhat loh ha pawk tih, ‘Boeipa, nang kah mina tah himbaica khuiah ka khueh tih ka tung he.\wj*
\v 21 \wj Dikkhih dikkhaeh hlang la na om dongah namah khaw kang rhih. Na khueh pawt te na phueih tih na tuh pawt te na ah,’ a ti nah.\wj*
\v 22 \wj Anih te tah, ‘Na ka lamkah vanbangla nang taengah ol ka tloek ni, sal thae aw, kai he dikkhih dikkhaeh hlang la ka om te na ming coeng. Ka khueh pawt te ka poh tih ka tuh pawt te ka ah het a?\wj*
\v 23 \wj Te vaengah balae tih ka tangka te caboei dongla na tloeng pawh. Kai ka pawk vaengah a casai neh ka dang kolo mako,’ a ti nah.\wj*
\v 24 \wj Te phoeiah aka pai rhoek te, ‘Anih taengkah mina te lo uh lamtah mina lungrha aka khueh te pae uh,’ a ti nah.\wj*
\v 25 \wj Te vaengah anih te, ‘Boeipa, mina parha a khueh ta,’ a ti na uh.\wj*
\v 26 \x - \xo 19.26 \xt Mat 13. 12; Mrk 4. 25; Luk 8. 18\x*\wj Nangmih taengah ka thui, Aka khueh boeih te a paek thil vetih, aka khueh pawt tah a khueh te khaw a loh pahni.\wj*
\v 27 \x - \xo 19.27 \xt Mat 25. 14-30\x*\wj Tedae amih soah kai manghai sak ham aka ngaih pawh ka rhal rhoek te pahoi hang khuen uh lamtah ka hmaiah ngawn uh,’ a ti nah,”\wj* te a thui pah.
\s1 Jerusalem La Kun
\p 
\v 28 Te te a thui phoeiah a hmai la cet tih Jerusalem la luei.
\v 29 Olives tlang a ti uh taengkah Bethphage neh Bethany te vat a pha vaengah hnukbang panit te a tueih tih,
\v 30 \wj “Rhaldan kah kho la cet rhoi, a khuila na kun rhoi vaengah laakca a pael te na hmuh rhoi ni. Te soah hlang ngol noek pawt dae hlam lamtah hang khuen rhoi.\wj*
\v 31 \wj khat loh nangmih rhoi te, ‘Ba ham lae na hlam?’ tila n'dawt atah, ‘Boeipa loh a ngoe,’ ti nah,”\wj* a ti nah.
\p 
\v 32 Te dongah a tueih rhoi loh a caeh rhoi vaengah a ti nah bangla a hmuh rhoi.
\v 33 laak ca te a hlam rhoi vaengah a boei loh amih rhoi te, “Balae tih laak ca te na hlam rhoi,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 34 Te rhoi long khaw, “Boeipa loh a ngoe,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 35 Te te Jesuh taengla a khuen rhoi. Te phoeiah laak ca te a himbai neh a khuk uh tih Jesuh te a soah a ngol sak uh.
\v 36 A caeh vaengah a himbai te long ah a phaih uh.
\v 37 Olives tlang kah singling te a pha tom vaengah a thaomnah te hnukbang rhaengpuei loh pahoi boeih a hmuh uh. Te boeih nen te omngaih uh tih Pathen te ol neh rhuprhup a thangthen uh.
\v 38 \x - \xo 19.38 \xt Tgt 118. 26\x*“Boeipa ming neh aka pawk manghai tah a yoethen, vaan ah ngaimongnah, thangpomnah tah a sangkoek ah om saeh,” a ti uh.
\p 
\v 39 Te dongah hlangping lamkah Pharisee hlangvang loh amah te, “Saya, na hnukbang rhoek te toel lah,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 40 Tedae a doo tih, \wj “Nangmih taengah ka thui, amih paa uh koinih lungto rhoek loh pang uh ni,”\wj* a ti nah.
\s1 Jerusalem Ham A Thinphat
\p 
\v 41 Khopuei te a tueng tom vaengah a rhah thil.
\v 42 \wj “Tahae kah ngaimongnah he nang long khaw tihnin ah na ming koinih, tedae na mikhmuh lamloh a thuh coeng.\wj*
\v 43 \wj Khohnin loh nang taengla ha pawk vetih na rhal rhoek loh nang te vaam n'too thil ni. Te vaengah nang te n'dum vetih voeivang ah nang te ng'et ni.\wj*
\v 44 \wj Te phoeiah namah neh na khuikah na ca rhoek te a hnaa uh ni. Namamih kah hiphoelnah tue te na ming pawt yueng, na khuikah lungto sokah lungto pakhat pataeng hmaai uh mahpawh,”\wj* a ti nah.
\s1 Bawkim a Ciim
\p 
\v 45 Bawkim la a kun neh hno aka yoi rhoek te a vai.
\v 46 \x - \xo 19.46 \xt Isa 56. 7; Jer 7. 11\x*Amih te, “‘\wj Ka im tah thangthuinah im la om ni,’ tila a daek coeng dae nangmih loh dingca rhoek kah khuirhung la na saii uh,”\wj* a ti nah.
\p 
\v 47 \x - \xo 19.47 \xt Luk 21. 37\x*Te phoeiah hnin takuem bawkim khuiah om tih a thuituen. Tedae khosoihham rhoek, cadaek rhoek neh pilnam kah a congkhang long tah anih te poci sak ham a mae uh.
\v 48 Tedae pilnam loh Jesuh te a hmaitoh tih boeih a hnatun dongah metla a saii uh ham khaw ming uh pawh.
\c 20
\s1 Jesuh kah Saithainah
\p 
\v 1 Hnin at ah bawkim khuikah pilnam te a thuituen tih olthangthen a phong vaengah khosoihham rhoek, cadaek rhoek neh patong rhoek loh a pai thil uh.
\v 2 Te vaengah anih te a voek uh tih, “Mebang saithainah nen lae na saii he kaimih taengah thui lah? He saithainah he nang aka paek om nim?” a ti na uh.
\p 
\v 3 Te dongah amih te a doo tih, \wj “Nangmih te ol pakhat kan dawt saeh lamtah kai n'doo uh.\wj*
\v 4 \wj Johan kah baptisma tah vaan lamkah a, hlang lamkah a om?\wj*” a ti nah.
\p 
\v 5 Amih long khaw amamih te poek uh tih, “Vaan lamkah n'ti uh koinih, ‘Balae tih anih te na tangnah uh pawh,’ a ti veh.
\v 6 ‘Hlang lamkah loh,’ n'ti bal nim te pilnam pum loh mamih he n'dae veh,” a ti uh.
\p Johan te tonghma aka om la ana pang uh.
\v 7 Te dongah, “Me lamkah nim, ka ming pawh,” a ti uh.
\v 8 Te dongah Jesuh loh amih te, \wj “Kai loh mebang saithainah neh ka saii khaw nangmih taengah ka thui mahpawh,”\wj* a ti nah.
\s1 Dum Khueh Nuettahnah
\p 
\v 9 \x - \xo 20.9 \xt Isa 5. 1\x*Te dongah pilnam taengah hekah nuettahnah he a tong tih, \wj “Hlang pakhat loh dum a tue tih lotawn a phaam sak. Te phoeiah amah te kum a sen puet vik yiin.\wj*
\v 10 \wj A tue vaengah tah dum kah a thaih te amah taengah ham pae uh saeh tila sal pakhat te lotawn rhoek taengla a tueih. Tedae lotawn rhoek loh anih te a boh uh tih a tling la a tueih uh.\wj*
\v 11 \wj Te phoeiah sal a tloe a rhaep la a tueih bal. Tedae anih a boh uh tih yah a bai phoeiah a tling la a tueih uh.\wj*
\v 12 \wj A pathum nen khaw a rhaep tih a tueih dae te khaw hmalaem la a haek uh.\wj*
\v 13 \wj Te dongah dum boei loh, ‘Balae ka saii eh? Ka capa thintlo he ka tueih eh, anih tah a yahnah uh khaming,’ a ti.”\wj*
\p 
\v 14 \wj “Tedae anih te lotawn rhoek loh a hmuh uh vaengah khat neh khat dawtlet uh thae tih, ‘Rhopangkung tah anih coeng ni, anih he ngawn uh sih, te vaengah rho te mamih ham om saeh,’ a ti uh.\wj*
\v 15 \wj Te dongah anih te a vai uh tih dum voelah a ngawn uh. Te vaengah dum boei loh amih te metlam a saii eh?\wj*
\v 16 \wj Tedae amih lotawn rhoek te a paan vetih a poci sak ni, dum te khaw a tloe taengla a paek ni,”\wj* a ti nah.
\p A yaak uh vaengah, “A coeng moenih,” a ti uh.
\p 
\v 17 \x - \xo 20.17 \xt Tgt 118. 22\x*Tedae Jesuh loh amih te a sawt tih, \wj “A daek tangtae he balae aka om bal pueng. Im aka sa rhoek loh a hnawt lungto te, imkil a soi la pawk ta.\wj*
\v 18 \wj Tekah lungto aka tlak thil boeih te tah tlawt uh vetih, amah a tlak thil atah amah te tip ni,”\wj* a ti nah.
\p 
\v 19 Te dongah cadaek rhoek neh khosoihham rhoek long tah amah vaengah Jesuh te kut hlah thil ham a mae uh. He nuettahnah he amih a thui thil te a ming uh ngawn dae pilnam te khaw koek a rhih uh.
\s1 Pathen neh Kaisar
\p 
\v 20 Anih aka dawn rhoek te a huep la a tueih uh tih amamih te a dueng la om ham sa uh. Te vaengah a ol tuuk pah ham, Jesuh te boeilu neh khoboei kah saithainah dongah voeih hamla cai uh.
\v 21 Te dongah Jesuh te a dawt uh tih, “Saya, nang loh buelh buelh na thui tih na thuituen dongah maelhmai na dan pawt te ka ming uh. Tedae Pathen kah oltak longpuei ah ni na thuituen.
\v 22 Kaisar taengah mangmu paek he mamih ham thuem a, thuem pawt a?” a ti na uh.
\p 
\v 23 Tedae amih kah rhaithinah te a hmat dongah amamih te,
\v 24 \wj “Denari pakhat te kai n'tueng uh lah, u kah muei neh ming lae aka om,”\wj* a ti nah hatah, “Kaisar kah,” a ti uh.
\p 
\v 25 Te dongah Jesuh loh amih te, \wj “Kaisar koe te Kaisar taengla, Pathen koe te Pathen taengla mael uh,”\wj* a ti nah.
\p 
\v 26 Tedae pilnam hmaiah anih ol tuuk pah ham coeng uh voel pawh. A ollannah te khaw a ngaihmang uh tih a kam a khuem uh.
\s1 Sadducees neh Thohkoepnah
\p 
\v 27 \x - \xo 20.27 \xt Clt 23. 8\x*Thohkoepnah om pawh tila boe aka koek Sadducee hlangvang long khaw a paan uh tih a dawt uh.
\v 28 \x - \xo 20.28 \xt Olr 25. 5\x*Te vaengah, “Saya, Moses loh kaimih ham a daek coeng, pakhat te a maya loh yuu a khueh tih a duek vaengah cakol la a om atah a yuu te a mana loh lo saeh lamtah a maya ham a tiingan thoh pah saeh,’ a ti.
\v 29 Te vaengah boeinaphung parhih lo uh tih, lamhma loh yuu a loh dae cakol la duek.
\v 30 Te phoeiah a pabae neh a pathum loh huta te a loh.
\v 31 Te vanbangla a parhih long khaw camoe om mueh la a caehtak tih duek bal.
\v 32 A hnukkhueng ah huta te khaw duek.
\v 33 Thohkoepnah dongah huta te u kah yuu lam lae a om eh? Parhih loh anih te yuu la a khueh uh tih,” a ti na uh.
\p 
\v 34 Te dongah amih te Jesuh loh, \wj “Ta kumhal kah camoe rhoek loh yuloh rhaihlan neh om uh.\wj*
\v 35 \wj Kumhal kah te dang ham neh duek lamkah loh thohkoepnah dongkah aka tiing rhoek long tah yuu a loh va a sak uh moenih.\wj*
\v 36 \wj Vaan puencawn la a om uh dongah koep duek ham khaw om pawh. Pathen kah a ca la om uh tih thohkoepnah kah a ca la poeh uh bal.\wj*
\v 37 \x - \xo 20.37 \xt Sng 3. 6\x*\wj Tedae aka duek rhoek a thoh te Moses loh tangpuem taengah ana phoe pataeng coeng. Te vanbangla Boeipa te Abraham Pathen, Isaak Pathen neh Jakob Pathen ana ti coeng.\wj*
\v 38 \wj Tedae aka duek rhoek kah pawt tih aka hing rhoek kah Pathen ni, anih dongah ni boeih a hing uh,”\wj* a ti nah.
\p 
\v 39 Cadaek hlangvang rhoek loh a doo tih, “Saya, buelh na thui coeng,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 40 Amah te dawt ham ngaingaih uh voel pawh.
\s1 Messiah kawng Dawtnah
\p 
\v 41 Jesuh loh amih te, \wj “Metlamlae Khrih te, ‘David capa ni,’ a ti uh?\wj*
\v 42 \x - \xo 20.42 \xt Tgt 110. 1\x*\wj David amah loh Tingtoeng cabu dongah a thui tah,\wj*
\q2 \wj ‘Boeipa loh ka boeipa taengah,\wj*
\q1 
\v 43 \wj “Na rhal te na kho ham khotloeng la\wj*
\q2 \wj ka khueh hlan atah kai kah bantang ah ngol dae,” a ti,’ \wj*
\p 
\v 44 \wj David loh anih te Boeipa la a khue atah metlamlae a capa la a om eh?”\wj* a ti nah.
\s1 Cadaek Rhoek Ngaithuen
\p 
\v 45 Pilnam boeih kah a yaak ah a hnukbang rhoek te,
\v 46 \wj “Cadaek rhoek te ngaithuen uh, hnikul neh pongpa aka ngaih uh tih hnoyoih hmuen kah toidalnah, tunim ah ngolhmuen then, buhkung kah hmuensang a lungnah uh.\wj*
\v 47 \wj Amih loh nuhmai rhoek kah im te a yoop pa uh tih mueituengnah ham khing thangthui uh. He rhoek long ni laitloeknah muep a yook eh,”\wj* a ti nah.
\c 21
\s1 Nuhmai kah Kutdoe
\p 
\v 1 A dan vaengah kuirhang rhoek kah a kutdoe tangkabu khuila a sang uh te a hm uh.
\v 2 Te vaengah khodaeng nuhmai pakhat loh mucih panit a sang te a hmuh bal.
\v 3 Te dongah, \wj “Nangmih taengah rhep kan thui, hekah nuhmai khodaeng loh amih boeih lakah muep a sang coeng.\wj*
\v 4 \wj Amih tah amamih kah a coih te kutdoe la boeih a sang uh. Anih long tah a vawtthoeknah khui lamkah a khosaknah ham a khueh te boeih a sang coeng,”\wj* a ti nah.
\s1 Bawkim Hma Ni A Ti
\p 
\v 5 Bawkim te lungto khaw then tih nawnnah neh a thoeihcam coeng bet a ti uh.
\p 
\v 6 \wj “Hekah he na hmuh uh dae khohnin ha pawk ni. Te vaengah a phil pawt te lungto pakhat dongah lungto pakhat khaw hmaai mahpawh,”\wj* a ti nah.
\s1 Diklai A Bawt Tue Kah Miknoek
\p 
\v 7 Amah te a dawt uh tih, “Saya, te koinih te te me vaengah lae a om eh? Miknoek loh a om tom vaengah balae aka om eh?” a ti na uh.
\p 
\v 8 Te dongah Jesuh loh. \wj “Ng'rhaithi pawt ham hmat uh. Ka ming neh muep ha pawk uh vetih, ‘Kai coeng ni, a tue loh yoei coeng,’ ti uh cakhaw amih hnukah cet uh boeh.\wj*
\v 9 \wj Caem neh soekloeknah na yaak uh vaengah let uh boeh. Te te lamhma la a om ham ngawn a kuek. Tedae a bawtnah long tah pha koeloe mahpawh,”\wj* a ti nah.
\p 
\v 10 Te phoeiah amih te, \wj “Namtu loh namtu, ram loh ram a thoh thil ni.\wj*
\v 11 \wj Lingluei puei neh khokha loh hmuen tom ah tlung vetih duektahaw khaw pul ni. Mueirhih neh vaan lamkah miknoek long khaw mat ha thoeng ni.\wj*
\v 12 \wj Tedae te hlan ah te hlang boeih kah a kut te nangmih pum dongla a hlah uh vetih n'hnaemtaek uh ni. Tunim neh thongim la n'thak uh ni. Kai ming kongah manghai tom neh khoboei tom taengla ng'khuen uh ni.\wj*
\v 13 \wj Nangmih ham laipai la poeh bitni.\wj*
\v 14 \x - \xo 21.14 \xt Luk 12. 11,12\x*\wj Te dongah na thinko khuiah khueh uh lamtah huul uh ham khaw tawn boeh.\wj*
\v 15 \wj Kai loh olka neh cueihnah te nangmih kam paek bitni. Te te nangmih aka kingkalh rhoek boeih loh a kamkaih ham neh a oelh ham coeng thai mahpawh.\wj*
\v 16 \wj Nangmih te manu napa, manuca rhoek, huiko neh paya laikoi long khaw m'voeih uh vetih n'duek sak ni.\wj*
\v 17 \wj Kai ming kongah hlang boeih kah a hmuhuet la na om uh ni.\wj*
\v 18 \wj Tedae na lu sokah sampin pataeng poci loengloeng mahpawh.\wj*
\v 19 \wj Namamih kah uehnah nen ni na hinglu te na kaelh uh eh.”\wj*
\s1 Jerusalem Poci Ni
\p 
\v 20 \wj “Caem loh Jerusalem a vael uh te na hmuh uh vaengah, anih kah mitmoengnah loh yoei coeng tite ming uh.\wj*
\v 21 \wj Te vaengah Judea kah rhoek loh tlang la rhaelrham uh saeh. A laklung kah rhoek long khaw coe uh saeh. Tekah kho kah rhoek khaw a khuila kun boel saeh.\wj*
\v 22 \x - \xo 21.22 \xt Hos 9. 7\x*\wj Te dongah a daek tangtae te boeih soep sak ham ni te rhoek kah kutthungnah khohnin tah a om.\wj*
\v 23 \wj Anunae bungvawn la aka om neh te khohnin kah cacun rhoek aih. Diklai hmankah a kueknah a len neh he pilnam taengah kosi la om bitni.\wj*
\v 24 \wj Te vaengah cunghang ha dongah cungku uh vetih namtom boeih taengah a sol uh ni. Namtom rhoek kah a tue a soep duela Jerusalem khaw namtom kah a til ham ni a om eh.”\wj*
\s1 Hlang Capa Ha Pawk Vaengkah Miknoek
\p 
\v 25 \x - \xo 21.25 \xt Isa 13. 10; Ezk 32. 7; Joe 3. 4; Olp 6. 12,13\x*\wj “Te vaengah tah miknoek boeih loh khomik, hla neh aisi dongah om uh ni. Tuipuei kah olhum neh tuiphu kah ngaihitnah dongah namtom rhoek kah ngaisaknah te diklai ah om ni.\wj*
\v 26 \wj Lunglai ah aka thoeng rhihnah neh lamsonah dongah hlang he sut hit uh ni. Vaan kah thaomnah long khaw hinghuen uh ni.\wj*
\v 27 \x - \xo 21.27 \xt Dan 7. 13; Olp 1. 7\x*\wj Te vaengah khomai dongah thaomnah neh thangpomnah a len neh aka pawk hlang capa te a hmuh uh ni.\wj*
\v 28 \wj Nangmih kah tlannah tah a yoei coeng dongah, aka om ham te a moe vaengah pai uh lamtah na lu dangrhoek uh,”\wj* a ti nah.
\s1 Thaibu Kung
\p 
\v 29 Te phoeiah amih ham nuettahnah neh, \wj “Thaibu neh thing boeih ke na hmuh uh.\wj*
\v 30 \wj Tahae kah aka boe te aka hmuh rhoek long tah namah neh namah te, khohal vat a pha coeng tila na ming uh.\wj*
\v 31 \wj Te vanbangla nangmih long khaw he he ha thoeng tih na hmuh uh vaengah Pathen kah ram tah pai tom coeng tila ming uh.\wj*
\v 32 \wj Nangmih taengah rhep ka thui, boeih a thoeng hlan atah tahae kah cadil loh a khum mueh la om mahpawh.\wj*
\v 33 \wj Vaan neh diklai tah khum ni, tedae kai ol khum loengloeng mahpawh.”\wj*
\s1 Hak Uh Laeh
\p 
\v 34 \wj “Te dongah namamih te ngaithuen uh lukilnah, rhuihahnah, khosak rhamsak kah mawntangnah dongah na thinko loh n'nan ve. Tekah khohnin loh nangmih soah buengrhuet ha pai ve.\wj*
\v 35 \wj Thaang bangla diklai maelhmai tom ah aka ngol rhoek boeih te a thoeng thil ni.\wj*
\v 36 \wj Tedae aka thangthui rhoek loh a tue cungkuem dongah hak uh. Te daengah ni om la aka cai boeih he poenghal ham neh, hlang capa hmaiah pai ham na noeng uh eh,”\wj* a ti nah.
\p 
\v 37 \x - \xo 21.37 \xt Luk 19. 47\x*Khothaih puet bawkim ah om tih a thuituen dae khoyin ah tah Olive a ti uh tlang soah cet tih rhaeh.
\v 38 Te vaengah pilnam boeih loh anih ol yaak ham bawkim khuikah amah taengla ana yue uh coeng.
\c 22
\s1 Jesuh A Mae Uh
\p 
\v 1 \x - \xo 22.1 \xt Sng 12. 1-27\x*Yoom a ti uh vaidamding khotue tah yoei coeng.
\v 2 Te vaengah khosoihham rhoek neh cadaek rhoek loh pilnam te loei a rhih uh dongah Jesuh metla ng'ngawn eh tila a mae uh.
\v 3 Te vaengah Satan loh hlainit khuikah hlangmi pakhat la aka om Iskariot a ti uh Judas te a kun thil.
\v 4 Te dongah cet tih amih taengla Jesuh metla a voeih ham khaw khosoihham rhoek neh imtawt boei rhoek te a voek.
\v 5 Te vaengah a uem uh tih anih te tangka paek ham a kotluep uh.
\v 6 Ko a tluep puei tih, amih hlangping kah mikvoelh ah Jesuh voeih ham a tuethen te a dawn.
\s1 Yoom Khotue
\p 
\v 7 Vaidamding khohnin tah a pha coeng. Te vaengah yoom te ngawn ham a kuek.
\v 8 Te dongah Peter neh Johan te a tueih tih, \wj “Cet rhoi lamtah mamih kah yoom n'caak ham te rhoekbah rhoi,”\wj* a ti nah.
\p 
\v 9 Amih rhoi long khaw amah taengah, “Melam saii ham na ngaih?” a ti nah.
\p 
\v 10 Jesuh loh amih rhoi te, \wj “Khopuei la na kun rhoi vaengah, tuitang dongah tui aka phuei hlang pakhat loh nangmih rhoi te n'doe ni. Anih loh a kun thil im duela anih te vai rhoi ne.\wj*
\v 11 \wj Te phoeiah im kungmah te, ‘Nang taengah saya loh, “Yinpanah tah melam a om, te ah te ka hnukbang rhoek te Yoom ka caak puei mai eh,” a ti,’ ti nah.\wj*
\v 12 \wj Anih loh imhman aka ka te a khoem tangtae la nangmih rhoi n'tueng bitni, te ah te rhoekbah rhoi,”\wj* a ti nah.
\p 
\v 13 A caeh rhoi vaengah a ti nah bangla a hmuh rhoi tih Yoom te a rhoekbah rhoi.
\s1 Boeipa Hlaembuh
\p 
\v 14 A tue loh a pha vaengah, amah taengkah caeltueih rhoek te a ngol puei.
\v 15 Te phoeiah amih te, \wj “Ka patang hlanah nangmih neh Yoom caak ham he thincavat la ka hue.\wj*
\v 16 \wj Nangmih taengah kan thui, Pathen kah ram ah a soep hlan atah he he ka ca voel mahpawh,”\wj* a ti nah.
\p 
\v 17 Boengloeng te a loh tih a uem phoeiah, \wj “He he lo uh lamtah namamih te tael uh thae.\wj*
\v 18 \wj Nangmih taengah ka thui, tahae lamloh Pathen ram a pai hlan khuiah misur thaih te ka o voel mahpawh,”\wj* a ti nah.
\p 
\v 19 Vaidam te a loh tih a uem phoeiah a aeh tih amih te a paek. Te vaengah, \wj “He tah nangmih hamla ka paek ka pum ni. Kai poekkoepnah neh he he saii uh,”\wj* a ti nah.
\p 
\v 20 \x - \xo 22.20 \xt Jer 31. 31-34\x*Te vanbangla boengloeng te khaw a vael uh tih, \wj “He boengloeng tah ka thii dongkah paipi thai ni, te tah nangmih ham long coeng.\wj*
\v 21 \x - \xo 22.21 \xt Tgt 41. 10\x*\wj Tedae caboei dongah kamah aka om puei kah a kut loh kamah m'voeih coeng he.\wj*
\v 22 \wj Hlang Capa tah a hmoel tangtae bangla cet pai dae, anih dongah hlang aka voei hlang te tah anunae,”\wj* a ti.
\v 23 Te dongah te bang saii hamla aka caii te amih lakli ah u lam nim a pawk ve tila amamih khuiah koe oelh uh thae.
\s1 A Tanglue Tukvat Uh Thae
\p 
\v 24 \x - \xo 22.24 \xt Mat 18. 1; Mrk 9. 34; Luk 9. 46\x*Te vaengah amih khuiah tanglue la om ham aka koih te unim tila, amamih khuiah tuituknah khaw om.
\v 25 Tedae amih taengah Jesuh loh, \wj “Namtom manghai rhoek loh amih a tulnoi uh tih a buem rhapsat te hlangrhoei rhoek la a khue uh.\wj*
\v 26 \x - \xo 22.26 \xt Mat 23. 11; Mrk 9. 35\x*\x - \xo 22.26 \xt Mat 20. 25-27; Mrk 10. 42-44\x*\wj Tedae nangmih tah te tlam moenih, nangmih khuiah aka tanglue loh a noe bangla om saeh, hlang aka mawt long khaw aka thotat la om saeh.\wj*
\v 27 \x - \xo 22.27 \xt Jhn 13. 12-15\x*\wj Te dongah aka vael neh aka thothat khuiah ulae aka tanglue? Aka vael te moenih a? Tedae kai tah nangmih lakli ah aka thotat lam ni ka om.\wj*
\v 28 \wj Nangmih tah kai kah cuekhalhnah khuikah he kai neh aka tukkai la na om uh.\wj*
\v 29 \wj Ram te a pa loh kai taengah a hal bangla nangmih taengah kai loh kang hal coeng.\wj*
\v 30 \x - \xo 22.30 \xt Mat 19. 28\x*\wj Te daengah ni ka ram kah ka caboei dongah na caak na ok uh eh. Te vaengah Israel kah lai aka tloek koca hlainit te ngolkhoel soah na ngol thil uh ni.”\wj*
\s1 Peter Loh A Huek Uh Tak Ni
\p 
\v 31 \wj “Simon, Simon, Satan loh cang bangla hlaih ham nangmih n'laem coeng te.\wj*
\v 32 \wj Kai tah nang kah tangnah te a muei pawt ham ni nang ham ka thangthui. Tedae na bal vaengah na manuca rhoek te duel nawn,”\wj* a ti nah.
\p 
\v 33 Tedae Simon loh, “Boeipa, namah nen tah thongim neh duek paan ham khaw sikim la ka om ngawn,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 34 Jesuh loh, \wj “Peter, namah taengah kan thui, kai hmat hamla voeithum na huek uh hlan atah tihnin ah ai khong mahpawh,”\wj* a ti nah.
\s1 Sungkoi Sungsa neh Tumca
\p 
\v 35 \x - \xo 22.35 \xt Mat 10. 9,10; Mrk 6. 8,9; Luk 9. 3; 10. 4\x*Te phoeiah amih te, \wj “Sungkoi, sungsa neh khokhom khuen kolla nangmih kan tueih vaengah pakhat khaw na hlavawt uh pawt nim?” \wj* a ti nah.
\p Te vaengah amih loh, “Om pawh,” a ti uh.
\p 
\v 36 Te phoeiah amih te, \wj “Tedae tahae atah, sungkoi aka khueh loh khuen saeh, sungsa khaw khuen saeh. Aka khueh pawt loh a himbai te yoi saeh lamtah cunghang lai saeh.\wj*
\v 37 \x - \xo 22.37 \xt Isa 53. 12\x*\wj Nangmih ham kan thui, a daek tangtae te kai soah a soep ham a kuek. ‘Anih te lailak rhoek neh a tae thil,’ a ti, kai kawng loh hmakhah a pha,”\wj* a ti nah.
\p 
\v 38 Te vaengah amih loh, “Boeipa, cunghang yungnit om he,” a ti na uh. Te dongah Jesuh loh amih te, \wj “Rhoeh coeng te,”\wj* a ti nah.
\s1 Dum ah Thangthui
\p 
\v 39 A khosing vanbangla cet tih Olive tlang te a paan. Te vaengah hnukbang rhoek long khaw anih te a vai uh.
\v 40 A hmuen a pha vaengah amih te, \wj “Cuekhalhnah khuiah kun pawt ham thangthui uh,”\wj* a ti nah.
\p 
\v 41 Te phoeiah Jesuh tah amih taeng lamloh lungto dongat tluk ah khoe uh tih, khuklu cungkueng neh thangthui.
\v 42 Te vaengah, \wj “A pa, na ngaih atah boengloeng he, kai taeng lamkah loh khoe mai. Tedae kai kongaih boel saeh lamtah namah kongaih la om saeh,”\wj* a ti.
\p 
\v 43 Te vaengah vaan lamkah puencawn te a taengah phoe tih anih te thaa a cong pah.
\v 44 A thangthui te khaw thingthuelnah la mat a om pah. A hlantui khaw a thii cip bangla a om pah tih diklai la a bo pah.
\v 45 Thangthuinah lamloh thoo tih hnukbang rhoek taengla a pawk vaengah a kothaenah lamloh a ih uh te a hm uh.
\v 46 Te dongah amih te, \wj “Balae tih na ih uh? Thoo uh lamtah thangthui uh, te daengah ni cuekhalhnah khuila na kun uh pawt eh,”\wj* a ti nah.
\s1 Judas Loh A Mok
\p 
\v 47 A thui vaengah hlangping tarha ha pawk. Te vaengah hlainit khuikah pakhat Judas a ti long te amih hmaiah a lamhma pah tih Jesuh te mok hamla a paan.
\v 48 Tedae Jesuh loh amah te, \wj “Judas, moknah mai neh hlang capa te na voeih nama?”\wj* a ti nah.
\p 
\v 49 A taengkah rhoek loh a hmuh uh vaengah aka om ham te, “Boeipa, cunghang neh ka boeng uh koinih ta,” a ti na uh.
\p 
\v 50 Te dongah amih khuikah pakhat loh khosoihham kah sal te a boeng tih a bantang hna a pat pah.
\v 51 Tedae Jesuh loh a doo tih, \wj “Te te hlah laeh,”\wj* a ti nah.
\p Te phoeiah a hna te a taek pah tih a hoeih sak.
\v 52 Te phoeiah Jesuh loh amah taengla aka pawk khosoihham rhoek neh bawkim kah imtawt boei rhoek, patong rhoek taengah, \wj “Dingca a, cunghang neh thingboeng neh na caeh thil uh.\wj*
\v 53 \x - \xo 22.53 \xt Luk 19. 47; 21. 37\x*\wj Hnin takuem bawkim khuiah nangmih taengah ka om tih kai soah kut na thueng uh moenih. Tedae tahae tue neh yinnah kah saithainah tah nangmih ah om,”\wj* a ti nah.
\s1 Peter Loh A Huek Tak
\p 
\v 54 Jesuh te a tuuk uh phoeiah a mawt uh tih khosoihham im khuila a khuen uh. Tedae Peter long tah soeisoei a vai.
\v 55 Te vaengah imtol kah a laklung ah hmai a toih uh tih a ngoltun uh hatah Peter khaw amih lakli ah ngol van.
\v 56 Tedae hmaivang ah aka ngol salnu pakhat loh anih a hmuh vaengah a hmaitang tih, “He khaw he anih taengah om,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 57 Tedae Peter loh basa tih, “Anih, ka ming moenih, huta,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 58 Rhaih a om phoeiah pakhat loh anih te hmuh tih, “Nang khaw amih taengah na om van,” \w a\w* \w ti\w* \w nah\w*.
\p Tedae Peter loh, “Hlang khaw he, kai ka om moenih,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 59 Khonoek pakhat tluk a koe phoeiah a tloe pakhat loh, “Oltak ni, he khaw anih taengah om ta, amah khaw Galilee hlang ni,” rhap a ti nah.
\p 
\v 60 Tedae Peter loh, “Hlang khaw he, banim na thui ka ming moenih,” \w a\w* \w ti\w* \w nah\w*.
\p Te tlam te a thui li vaengah ai pahoi khong.
\v 61 Te vaengah Peter te Boeipa loh a mael thil tih a sawt. Te daengah, \wj “Tihnin kah ai a khong hlanah kai voeithum nan huek uh tak ni,”\wj* a ti nah vaengkah Boeipa ol te Peter loh a thoelh.
\v 62 Te dongah phawn cet tih hlawk hlawk rhap.
\s1 Jesuh a Tamdaeng tih A Boh Uh
\p 
\v 63 Jesuh te hlang rhoek loh a et uh phoeiah a tamdaeng uh tih a boh uh.
\v 64 Amah te a khuk uh tih a dawt uh vaengah, “Nang aka bael te unim phong lah,” a ti na uh.
\p 
\v 65 A tloe nen khaw muep a salpham uh tih anih te a voek uh.
\s1 Khoboei Im A Pha
\p 
\v 66 Khothaih a pha vaengah pilnam kah kangham rhoek, khosoihham rhoek neh cadaek rhoek te tingtun uh. Te phoeiah Jesuh te amamih kah khoboei taengla a khuen uh.
\v 67 Te vaengah, “Khrih la na om atah kaimih taengah thui laeh,” a ti na uh.
\p Tedae amih te, \wj “Nangmih taengah kan thui cakhaw na tangnah uh loengloeng mahpawh.\wj*
\v 68 \wj Kan dawt bal cakhaw nan doo uh loengloeng mahpawh.\wj*
\v 69 \wj Tahae lamkah hlang capa tah Pathen kah thaomnah bantang ah aka ngol la om pueng ni,”\wj* a ti nah.
\p 
\v 70 Tedae hlang boeih loh, “Nang tah Pathen capa la na om van a?” a ti na uh. Te dongah Jesuh loh amih te, \wj “Ka om te na thui uh coeng,”\wj* a ti nah.
\p 
\v 71 Te vaengah amih loh, “Laipai a ngoe pueng a te? A ka lamkah te mamih loh n'yaak uh coeng,” a ti uh.
\c 23
\s1 Jesuh tah Pilat neh Hum Uh
\p 
\v 1 Amih te rhaengpuei la huek pai uh tih Jesuh te Pilat taengla a khuen uh.
\v 2 Te vaengah Jesuh te pahoi a paelnaeh uh tih, “Anih loh mah namtu he a pamdah sak, Kaisar taengah mangmu paek ham te a paa sak tih amah te, ‘Khrih manghai ni,’ a ti khaw ka hmuh,” a ti uh.
\p 
\v 3 Te phoeiah Pilat loh a dawt tih, “Nang he Judah manghai la na om a?” a ti nah.
\p Tedae Jesuh loh anih te a doo tih, \wj “Nang long ni na ti,”\wj* a ti nah.
\p 
\v 4 Te dongah Pilat loh khosoihham rhoek neh hlangping rhoek te, “Hekah hlang soah a lolh ka hmuh moenih,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 5 Tedae amih loh a mangkhak la, “Pilnam a hueh tih, Galilee lamloh he hil, Judah tom ah pahoi a thuituen,” a ti uh.
\s1 Jesuh neh Herod Antipa
\p 
\v 6 Pilat loh a yaak vaengah, “Hekah hlang tah Galilee hoel la om maco,” a ti.
\v 7 Te daengah Herod kah saithainah dongah aka om la a ming tih Herod taengla a tueih. Te vaeng tue ah Herod khaw Jerusalem ah om.
\v 8 Herod loh Jesuh te a hmuh vaengah bahoeng omngaih. Hlamat kum lamkah a kawng a yaak coeng dongah amah hmuh ham te ngaihlih ana om coeng. Te dongah anih loh a saii miknoek khat khat te hmuh hamla a ngaiuep.
\v 9 Te dongah Jesuh te ol muep a dawt. Tedae Jesuh loh anih te a doo moenih.
\v 10 Te vaengah khosoihham rhoek neh cadaek rhoek loh pai uh tih Jesuh te rhaprhap a paelnaeh uh.
\v 11 Herod neh a rhalkap rhoek long khaw Jesuh te a hnaelcoe uh tih a tamdaeng uh. Te phoeiah himbai a cim thik a bai sak tih Pilat taengla a tueih uh.
\v 12 Te khohnin kuelhuelh ah Herod neh Pilat loh khat neh khat paya la coeng rhoi. A noek ah amih rhoi te thunkha la om rhoi dae ta.
\s1 Jesuh neh Barabbas
\p 
\v 13 Te dongah Pilat loh khosoihham rhoek, boei rhoek neh pilnam te a hueh tih,
\v 14 “Hekah hlang he kai taengah pilnam aka palet bangla nang khuen uh. Kai loh nangmih hmaiah ka boelh het coeng dae a lolh la anih na paelnaeh uh thil te hekah hlang soah ka hmuh moenih he.
\v 15 Herod long khaw a hmuh pawt dongah ni anih he mamih taengla han tueih. A saii te dueknah neh aka tiing a om moenih he.
\v 16 Te dongah anih he ueih sak lamtah ka hlah eh,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 17 Khotue ah amih ham hlang pakhat tah a loeih sak ham manghkhak la a kuek.
\v 18 Tedae huek pang uh tih, “Anih he khuen laeh, Barabbas mah kaimih ham han hlah,” a ti uh.
\p 
\v 19 Barabbas tah khopuei ah olpungnah bet a om vaengah ngawnnah a saii dongah thongim khuila a hlak uh.
\v 20 Jesuh te hlah a ngaih dongah Pilat loh amih te koep a khue.
\v 21 Tedae amih loh a o uh tih, “Anih te tai laeh, tai laeh,” a ti uh.
\p 
\v 22 Tedae Pilat loh amih te, “He loh boethae balae a saii tih, dueknah ham koila anih soah a lolh ka hmuh moenih. Anih he ueih sak lamtah ka hlah tangloeng eh,” voeithum a ti nah.
\p 
\v 23 Tedae a lalh uh coeng dongah Jesuh tai ham te ol ue la a hoe uh tih amih ol loh boeih a khumla uh.
\v 24 Pilat long khaw amih kah bihhoenah te rhoirhi ham ko a tam.
\v 25 Te dongah a hoe uh vanbangla olpungnah neh ngawnnah dongah thongim khuila a det tangtae te a hlah. Tedae Jesuh te amih kongaih bangla a voeih pah.
\s1 Thinglam Longpuei
\p 
\v 26 Anih te a khuen uh vaengah Kurena Simon te lohma lamkah ha pawk hatah a tuuk uh tih Jesuh hnukah koh pah ham thinglam te a tloeng pa uh.
\v 27 Te vaengah anih te pilnam rheangpuei neh anih aka rhaengsae tih aka hlai huta rhoek loh muep a vai uh.
\v 28 Amih te Jesuh loh a mael thil tih, \wj “Jerusalem nu rhoek, kai hamla rhap uh boeh. Namamih ham neh na ca rhoek ham mah rhap uh.\wj*
\v 29 \wj ‘Cayaa, camoe aka cun pawh bung, aka khut pawh rhang suk loh a yoethen,’ a ti uh tue tah ha pawk coeng he.\wj*
\v 30 \x - \xo 23.30 \xt Hos 10. 8; Olp 6. 16\x*\wj Te vaengah tlang taengah, ‘Kaimih n'tim thil laeh,’ mol taengah khaw, ‘Kaimih m'vuei laeh,’ pahoi a ti uh ni.\wj*
\v 31 \wj Thing te a thingsup pataeng te tlam te a saii uh atah a koh vaengah metlam a om eh?”\wj* a ti nah.
\s1 Laihmu laklo ah A Tai
\p 
\v 32 A tloe laihmuh panit te khaw anih taengah ngawn ham a khuen uh.
\v 33 Lurhuh a ti uh hmuen te a pha uh vaengah Jesuh neh laihmuh rhoi te pahoi a tai uh. Laihmu rhoi khuiah pakhat te bantang ben ah pakhat banvoei ben ah a tai uh.
\v 34 \x - \xo 23.34 \xt Tgt 22. 19\x*Te vaengah Jesuh loh, \wj “A pa, amih he tholh hlah mai, a saii uh he khaw a ming uh moenih,”\wj* a ti.
\p Te phoeiah a himbai te a phen uh tih hmulung a naan thil uh.
\v 35 \x - \xo 23.35 \xt Tgt 22. 8\x*Te vaengah pilnam loh pai tih a sawt. Boei rhoek long khaw a nueih thil tih, “Hlang tloe aka khang te amah khaw khang uh saeh. Anih he Pathen kah a coelh Khrih la a om atah,” a ti uh.
\p 
\v 36 \x - \xo 23.36 \xt Tgt 69. 22\x*Anih te rhalkap rhoek long khaw a tamdaeng uh tih a paan uh.
\v 37 Anih te yuthui a paek uh tih, “Nang he Judah rhoek kah manghai la na om atah namah khang uh saw,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 38 A sokah a ming khaw, \sc ‘Judah rhoek kah manghai tah anih ni’\sc* tila a om pah.
\v 39 Te vaengah laihmu rhoi a hoei uh khuikah pakhat loh anih te a soehsal tih, “Nang he Khrih la na om mahnim? Namah khaw kaimih rhoi khaw ng'khang lah,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 40 Tedae pakhat loh anih te a doo tih a ho. Te vaengah, “Nang tah Pathen ke na rhih moenih a? Laitloeknah khuiah na om boeiloeih dae.
\v 41 Mamih rhoi ngawn tah mah khoboe te n'yook tueng tih tiktam coeng. Tedae anih tah a halang la a saii moenih,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 42 Te phoeiah Jesuh te, “Na ram khuiah na pawk vaengah kai m'poek ne,” \w a\w* \w ti\w* \w nah\w*.
\p 
\v 43 Te dongah anih te, \wj “Namah taengah rhep kan thui, tihnin ah paradai ah kai taengah na om pawn ni,”\wj* a ti nah.
\s1 Jesuh kah Dueknah
\p 
\v 44 \x - \xo 23.44 \xt Sng 26. 31-33\x*Khonoek parhuk tluk a pha vaengah diklai pum ah yinnah loh a thing tih khonoek pako hil Khomik khaw hmuep.
\v 45 Te vaengah bawkim kah hniyan loh phak phin uh.
\v 46 \x - \xo 23.46 \xt Tgt 31. 6\x*Jesuh tah ol ue la pang tih, \wj “A pa, na kut dongah ka mueihla kan paek,”\wj* a ti nah.
\p Te a thui neh pahoi pat.
\v 47 Aka om hno te rhalboei loh a hmuh vaengah Pathen te a thangpom tih, “Hekah hlang tah hlang dueng la om taktak,” a ti.
\p 
\v 48 A miklaw kah hlangping aka taai uh boeih loh aka om hno te a hmuh uh vaengah a lungkoe te a tum uh tih bal uh.
\v 49 \x - \xo 23.49 \xt Luk 8. 2,3\x*Te vaengah khohla lamkah a huiko khaw boeih ha pai uh. Galilee lamloh a taengah aka bang huta rhoek long khaw a hmuh uh.
\s1 Jesuh Upnah
\p 
\v 50 Te vaengah hlang pakhat, a ming ah Joseph tah khoboei la tapkhoeh om. Anih tah hlang then neh hlang dueng la om.
\v 51 Anih tah Judah khopuei pakhat Arimathea lamkah tih amih kah mangtaengnah neh khoboe dongah tlangnaem tlangphai la om pawh. Anih long tah Pathen kah ram ni a lamtawn.
\v 52 Te long te Pilat a paan tih Jesuh kah rhok te a bih.
\v 53 Rhok te a hlak tih himbai neh a yen. Te phoeiah rhok te phuel lung khuiah a khueh. Tekah phuel ah aka yalh om hlan.
\v 54 Tedae khohnin tah rhuengphong la om tih Sabbath tom coeng.
\v 55 Te vaengah huta rhoek loh a hloem uh. Amih tah Galilee lamkah loh Jesuh aka puei la om uh tih phuel neh a rhok metla a khueh te a hmuh uh.
\v 56 \x - \xo 23.56 \xt Sng 20. 10; Olr 5. 14\x*A bal uh vaengah bo-ul neh botui te a hmoel uh. Tedae Sabbath vaengah tah olpaek vanbangla duem uh.
\c 24
\s1 Thohkoep Mincang
\p 
\v 1 Sabbath poeng kah a cuek hnin mincang hi ah bo-ul a hmoel te a khuen uh tih phuel la cet uh.
\v 2 Tedae phuel lamkah lungto vik a paluet te a hmuh uh.
\v 3 A kun uh vaengah tah Boeipa Jesuh pum te hmu uh pawh.
\v 4 He kawng dongah amamih te ingang la a om vaengah hlang panit te himbai leklek a phaa la tarha a pai pa uh.
\v 5 Amih khaw lakueng ngaiha neh om uh tih diklai la a maelhmai a buluk uh. Te vaengah amih te, “Balae tih aka hing te aka duek taengah na toem uh.
\v 6 \x - \xo 24.6 \xt Mat 16. 21; 17. 22,23; 20. 18,19; Mrk 8. 31; 9. 31; 10. 33,34; Luk 9. 22; 18. 31-33\x*He ah a om moenih thoo coeng. Galilee ah a om vaengah nangmih taengah a thui te poek uh.
\v 7 ‘Hlang capa he hlang tholh kut ah a voeih vetih a tai ni, a thum hnin ah a thoh ham a kuek,’ a ti ta,” a ti rhoi.
\v 8 A ol te a poek uh van dongah,
\v 9 phuel lamloh bal uh tih hlaiat taeng neh a tloe rhoek boeih taengah puen uh.
\v 10 Te vaengah Magadala Mary, Joanna, Jakob manu Mary khaw om. Te phoeiah amih taengkah a tloe rhoek long khaw caeltueih rhoek taengah a thui pa uh.
\v 11 Tedae amih taengah tah cil ol bangla a om pah dongah a hnalval tak uh.
\v 12 Peter tah thoo tih phuel la yong. Te phoeiah a sawt thuk hatah himbai bueng te a hm uh. Te dongah amah khaw aka om hno dongah ngaihmang la khoe uh.
\s1 Emmaus Longpuei Kah Hnukbang Rhoi
\p 
\v 13 Amah tekah khohnin ah Jerusalem lamkah phalong sawmrhuk aka hla, a ming ah Emmaus vangca la khoem aka cet rhoi te om.
\v 14 Amih rhoi loh te rhoek kah aka thoeng hno boeih te khat neh khat taengah a thui rhoi.
\v 15 A thui rhoi tih a oelh uh rhoi vaengah Jesuh amah long khaw a paan tih amih rhoi te a puei.
\v 16 Tedae anih te a hmat pawt ham a mik a buem pah.
\v 17 Te phoeiah amih rhoi te, \wj “Aka cet paitai loh khat neh khat taengah na saep rhoi te mebang olka nim he,”\wj* a ti nah hatah a hmueprhut la pai rhoi.
\v 18 Te dongah Kleopas aka ming nah loh anih te a doo tih, “Namah loh Jerusalem te na kuepkol thil dae tihnin kah a khuiah aka om te na ming mahnim?” a ti nah.
\p 
\v 19 Te vaengah amih rhoi te, \wj “Aba e te?”\wj* a ti nah.
\p Te rhoi van loh amah te, “Nazareth Jesuh kawng ca, anih tah tonghma pa la om, a khoboe neh a ol khaw Pathen neh pilnam boeih taengah a thaom.
\v 20 Anih te mamih kah khosoihham rhoek neh boei rhoek loh dueknah neh laitloek thil ham a voeih uh tih a tai uh.
\v 21 Tedae Israel tlan ham aka cai tah anih ni tila kaimih loh ka ngaiuep uh. Te boeih te khaw a poeng tih, tahae kah hno a om lamloh a thum hnin pataeng a pha coeng he.
\v 22 Kamamih khuikah huta hlangvang long khaw kaimih n'limlum sak uh. Phuel ah yue om uh coeng.
\v 23 Tedae a pum te hmu uh mueh la ha pawk uh. Puencawn rhoek kah mangthui a hmuh te khaw a thui uh. Amah a hing te amih loh a thui uh.
\v 24 Te dongah kaimih taengkah hlangvang tah phuel la cet uh. Te vaengah huta rhoek loh a thui bangla a hmuh uh van tangloeng tih amah te tah hmu uh pawh,” a ti nah rhoi.
\p 
\v 25 Te vaengah amah loh amih rhoi te, \wj “Hlangang rhoi aw, na thinko a rhihnun cukduk la, tonghma rhoek loh a thui te boeih tangnah rhoi saw.\wj*
\v 26 \wj Khrih te a patang phoeiah a thangpomnah khuila a kun te a kuek moenih a?”\wj* a ti nah.
\p 
\v 27 Moses lamkah a tong tih tonghma rhoek boeih neh cacim boeih khuiah khaw amah kawng te amih ham a thuicaih pah coeng.
\v 28 Vangca te vat a pha uh vaengah amah tah voelh cet la sa uh.
\v 29 Tedae amah te a hloh rhoi tih, “Kaimih rhoi taengah rhaeh mai, hlaem a pha tih khohnin khaw khum coeng,” \w a\w* \w ti\w* \w nah\w*.
\p Te dongah amih rhoi taengah rhaeh hamla kun.
\v 30 A tue a pha tih amih rhoi taengah a ngol puei. Vaidam te a loh tih a uem phoeiah a aeh tih amih rhoi te a paek.
\v 31 Te vaengah a mik tah a tueng pah rhoi tih amah te a hmat rhoi. Tedae amah tah amih rhoi taeng lamloh vova a hma pah.
\v 32 Te daengah khat neh khat te, “Mamih rhoi kah thinko tah a ung moenih a? Longpueng ah mamih ham a thui bangla mamih rhoi taengah om pai, cacim he mamih rhoi khuiah puk pai,” a ti rhoi.
\v 33 Te dongah amah tekah a tue ah thoo rhoi tih Jerusalem la bal rhoi. Te vaengah hlaikhat rhoek neh a taengkah rhoek ana tingtun uh te a hmuh rhoi.
\v 34 Boeipa tah thoo rhep tih Simon taengla a phoe te ana thui uh.
\v 35 Amih rhoi long khaw longpueng kah te a thui rhoi tih vaidam a aehnah nen te amih a ming sak.
\s1 Jesuh Thoo Tang Tang
\p 
\v 36 A thui uh li vaengah amah te amih lakli ah a pai pah tih amih te, \wj “Nangmih taengah ngaimongnah om saeh,”\wj* a ti nah.
\p 
\v 37 Tedae let uh tih mueihla aka hmuh bangla a poek uh dongah lakueng ngaiha la om uh.
\v 38 Te phoeiah amih te, \wj “Balae tih na thuen neh na om uh, poeknah te balae tih na thinko ah a phul?\wj*
\v 39 \wj Kai kamah ni tite ka kut rhoi neh ka kho rhoi he so uh. Kai he n'phathuep uh lamtah m'ming uh, mueihla loh a saa neh a rhuh a khueh moenih, nam hmuh uh vanbangla kai ka khueh he,”\wj* a ti nah.
\p 
\v 40 He he a thui phoeiah a kut rhoi neh a kho rhoi te amih a tueng.
\v 41 Tedae omngaihnah lamloh a hnalval uh pueng tih a ngaihmang uh dongah amih te, \wj “Caakkoi khat khaw na khueh uh a he?\wj*” a ti nah.
\p 
\v 42 Amih loh amah te nga phoeng kaekvang a paek uh.
\v 43 Te dongah a doe tih amih hmaiah a caak pah.
\v 44 Te phoeiah amih te, \wj “Nangmih taengah ka om vaengah nangmih ham ka thui ka ol tah he ni. Moses kah olkhueng neh tonghma rhoek, tingtoeng dongah khaw kai kawng a daek te boeih a soep ham a kuek ta,”\wj* a ti nah.
\p 
\v 45 Te daengah cacim hmuhming ham te a lungbuei puk uh.
\v 46 Te dongah amih te, \wj “Khrih a patang ham neh a thum hnin ah duek lamkah a thoh ham khaw,\wj*
\v 47 \wj Jerusalem lamkah loh tong uh lamtah namtom boeih taengah tholh khodawkngainah ham yutnah te amah ming neh hoe ham a daek tangloeng coeng.\wj*
\v 48 \wj Nangmih tah he rhoek kah laipai rhoek ni.\wj*
\v 49 \x - \xo 24.49 \xt Clt 1. 4\x*\wj Kai loh nangmih taengah a pa kah olkhueh te kan tueih coeng he. Tedae nangmih tah a sang lamkah thaomnah na bai uh hlan atah kho khuiah ana ngol uh,”\wj* a ti nah.
\s1 Jesuh Vaan La Luei
\p 
\v 50 \x - \xo 24.50 \xt Clt 1. 9-11\x*Amih te Bethany duela voelh a khuen phoeiah a kut a phuel tih amih te yoethen a paek.
\v 51 Amih yoethen a paek nen tah amih taeng lamloh khoe uh tih vaan la a khuen.
\v 52 Te vaengah amih loh amah te a bawk uh tih Jerusalem ah omngaihnah neh muep bal uh.
\v 53 Te phoeiah bawkim khuiah om taitu uh tih Pathen te a uem uh. 
