\v 33 \w par|strong="G1223"\w* \w la|strong="G1223"\w* \w foi|strong="G4102"\w*, \w ils|strong="G3739"\w* \w ont|strong="G3739"\w* conquis \w des|strong="G1223"\w* royaumes, exercé \w la|strong="G1223"\w* \w justice|strong="G1343"\w*, \w obtenu|strong="G2013"\w* \w l|strong="G3739"\w*’effet \w des|strong="G1223"\w* \w promesses|strong="G1860"\w*, fermé \w la|strong="G1223"\w* \w gueule|strong="G4750"\w* \w des|strong="G1223"\w* \w lions|strong="G3023"\w*,\f + \fr 11:33 \ft 33-34 \fq Des lions\ft  : Jug. 14, 6 ; David, 2 Sam. 16, 34 sv. ; Dan. 6, 17. — \qt Du feu\qt* : Dan. 3, 27. — \qt De l’épée\qt* : 1 Sam. 18, 11 ; 1Sa. 19, 1 sv. ; 2 Rois, 6, 13 sv. ; 1 Mach. 2, 28. — \qt De la maladie\qt* : 2 Rois, xx. — \qt Des armées ennemies\qt* : Jug. 7, 1 Rois, xvi ; il s’agit peut-être aussi des Machabées, comme le donnerait à entendre la qualification ἀλλοτρίων.\f*
\v 34 \w éteint|strong="G4570"\w* \w la|strong="G1722"\w* violence \w du|strong="G1722"\w* \w feu|strong="G4442"\w*, \w échappé|strong="G5343"\w* \w au|strong="G1722"\w* \w tranchant|strong="G4750"\w* \w de|strong="G1722"\w* \w l|strong="G1722"\w*’\w épée|strong="G3162"\w*, triomphé \w de|strong="G1722"\w* \w la|strong="G1722"\w* maladie, déployé \w leur|strong="G1722"\w* vaillance \w à|strong="G1722"\w* \w la|strong="G1722"\w* \w guerre|strong="G4171"\w*, \w mis|strong="G1096"\w* \w en|strong="G1722"\w* \w fuite|strong="G5343"\w* \w des|strong="G1722"\w* \w armées|strong="G3925"\w* \w ennemis|strong="G1722"\w* ;\f + \fr 11:34 \ft 34-38. \fq Des femmes\ft  : 1 Rois, 17, 17 ; 2 Rois, 4, 17 sv. — \qt Torturés\qt* : tel le saint vieillard Éléazar, les 7 frères Machabées, 2 Mach. 6, 18 sv. — \qt Les chaînes\qt*, etc. : Jér. chapitres 20, 22, xxxvii. — \qt Lapidés\qt* : Zacharie, fils de Joiada (II Par. 24, 20 ; comp. Matth. 23, 35). — \qt Sciés\qt* : Isaïe. — \qt Éprouvés\qt*, tentés : comment ? par la torture sans doute. Ce mot manque dans plusieurs manuscrits et anciennes versions. Au lieu de ἐπειράσθησαν quelques uns proposent de lire ἐπυράσθησαν, \qt ils ont été livrés au feu\qt*, comme par exemple, les frères Machabées, chap, 7, 5. Mais cette leçon, plus facile pour le sens, paraît trop conjecturale. De nombreux mss. et des meilleurs placent ces trois mots en cet ordre : lapidés, mis à la torture, sciés. — \qt De l’épée\qt* : tels ces prophètes que fit mourir Jézabel (I Rois, 19, 10) Urie, frappé par le roi Joakim (Jér. 26, 23) et ces 8.000 Juifs que le roi Antiochus fit périr trois jours après la prise de Jérusalem (II Mach. 5, 13). — \qt Peaux\qt* de \qt brebis\qt*, par exemple Élie (I Rois, 19, 13-19). Comp. Zach. 13, 4.\f*
\v 35 \w par|strong="G1537"\w* \w eux|strong="G1161"\w* \w des|strong="G1537"\w* \w femmes|strong="G1135"\w* \w ont|strong="G3588"\w* \w recouvré|strong="G1161"\w* \w leurs|strong="G3588"\w* \w morts|strong="G3498"\w* ressuscités. \w Les|strong="G1161"\w* \w uns|strong="G1537"\w* \w ont|strong="G3588"\w* péri \w dans|strong="G1161"\w* \w les|strong="G1161"\w* tortures, refusant \w la|strong="G1161"\w* délivrance \w afin|strong="G2443"\w* \w d|strong="G1537"\w*’\w obtenir|strong="G2983"\w* \w une|strong="G1161"\w* \w meilleure|strong="G2909"\w* \w résurrection|strong="G1537"\w*  ;
\v 36 \w d|strong="G2532"\w*’\w autres|strong="G2087"\w* \w ont|strong="G2532"\w* \w souffert|strong="G2532"\w* \w les|strong="G2532"\w* \w moqueries|strong="G1701"\w* \w et|strong="G2532"\w* \w les|strong="G2532"\w* verges ; \w de|strong="G2532"\w* \w plus|strong="G2532"\w*, \w les|strong="G2532"\w* \w chaînes|strong="G1199"\w* \w et|strong="G2532"\w* \w les|strong="G2532"\w* cachots ;
\v 37 ils ont \w été|strong="G1722"\w* \w lapidés|strong="G3034"\w*, \w sciés|strong="G4249"\w*, \w éprouvés|strong="G3985"\w* ; ils \w sont|strong="G1722"\w* morts \w par|strong="G1722"\w* \w le|strong="G1722"\w* tranchant \w de|strong="G1722"\w* \w l|strong="G1722"\w*’\w épée|strong="G3162"\w* ; ils ont erré çà \w et|strong="G1722"\w* \w là|strong="G1722"\w*, couverts \w de|strong="G1722"\w* \w peaux|strong="G1192"\w* \w de|strong="G1722"\w* \w brebis|strong="G3374"\w* \w et|strong="G1722"\w* \w de|strong="G1722"\w* chèvres, \w dénués|strong="G5302"\w* \w de|strong="G1722"\w* \w tout|strong="G1722"\w*, \w persécutés|strong="G2346"\w*, \w maltraités|strong="G2558"\w*,
\v 38 — \w eux|strong="G3739"\w* \w dont|strong="G3739"\w* \w le|strong="G2532"\w* \w monde|strong="G2889"\w* \w n|strong="G3756"\w*’\w était|strong="G3588"\w* \w pas|strong="G3756"\w* \w digne|strong="G3756"\w* ; — \w ils|strong="G2532"\w* \w ont|strong="G3588"\w* \w été|strong="G3756"\w* \w errants|strong="G4105"\w* \w dans|strong="G2532"\w* \w les|strong="G2532"\w* \w déserts|strong="G2047"\w* \w et|strong="G2532"\w* \w les|strong="G2532"\w* \w montagnes|strong="G3735"\w*, \w dans|strong="G2532"\w* \w les|strong="G2532"\w* \w cavernes|strong="G4693"\w* \w et|strong="G2532"\w* \w dans|strong="G2532"\w* \w les|strong="G2532"\w* \w antres|strong="G3692"\w* \w de|strong="G2532"\w* \w la|strong="G2532"\w* \w terre|strong="G1093"\w*.
\v 39 \w Cependant|strong="G2532"\w* \w eux|strong="G3778"\w* \w tous|strong="G3956"\w* \w que|strong="G2532"\w* \w leur|strong="G2532"\w* \w foi|strong="G4102"\w* \w a|strong="G2532"\w* \w rendus|strong="G2532"\w* recommandables, \w n|strong="G3756"\w*’\w ont|strong="G3588"\w* \w pas|strong="G3756"\w* \w obtenu|strong="G2865"\w* \w l|strong="G2532"\w*’objet \w de|strong="G2532"\w* \w la|strong="G2532"\w* \w promesse|strong="G1860"\w*
\v 40 parce \w que|strong="G2443"\w* \w Dieu|strong="G2316"\w* \w nous|strong="G2249"\w* \w a|strong="G2316"\w* \w fait|strong="G3588"\w* \w une|strong="G5100"\w* condition \w meilleure|strong="G2909"\w* \w pour|strong="G2443"\w* \w qu|strong="G2443"\w*’\w ils|strong="G3361"\w* \w n|strong="G3361"\w*’obtinssent \w pas|strong="G3361"\w* \w sans|strong="G3361"\w* \w nous|strong="G2249"\w* \w la|strong="G3361"\w* \w perfection|strong="G5048"\w* \add du bonheur\add*.
\c 12
\cp 12
\s2 4. Chap. 12, 1-13 : Deux autres motifs de persévérance. — a) L’exemple de Jésus-Christ (1-3). — b) Les épreuves sont un témoignage du paternel amour de Dieu : attestation de l’Écriture (4-6) ; la fin que Dieu se propose quand il châtie (7-11). Conclusion (12-13).
\p 
\v 1 \w Donc|strong="G2532"\w*, \w nous|strong="G2249"\w* \w aussi|strong="G2532"\w*, \w puisque|strong="G5105"\w* \w nous|strong="G2249"\w* \w sommes|strong="G2249"\w* \w environnés|strong="G4029"\w* \w d|strong="G2532"\w*’\w une|strong="G2532"\w* \w si|strong="G2532"\w* \w grande|strong="G5118"\w* \w nuée|strong="G3509"\w* \w de|strong="G2532"\w* \w témoins|strong="G3144"\w*, rejetons \w tout|strong="G3956"\w* \w ce|strong="G3588"\w* \w qui|strong="G3588"\w* \w nous|strong="G2249"\w* appesantit \w et|strong="G2532"\w* \w le|strong="G2532"\w* \w péché|strong="G2532"\w* \w qui|strong="G3588"\w* \w nous|strong="G2249"\w* \w enveloppe|strong="G2249"\w*, \w et|strong="G2532"\w* \w courons|strong="G5143"\w* \w avec|strong="G2532"\w* \w persévérance|strong="G5281"\w* \w dans|strong="G2532"\w* \w la|strong="G2532"\w* \w carrière|strong="G2532"\w* \w qui|strong="G3588"\w* \w nous|strong="G2249"\w* \w est|strong="G3588"\w* \w ouverte|strong="G4295"\w*,
\v 2 \w les|strong="G2532"\w* \w yeux|strong="G2532"\w* \w fixés|strong="G2532"\w* \w sur|strong="G1519"\w* \w Jésus|strong="G2424"\w*, \w l|strong="G3739"\w*’auteur \w et|strong="G2532"\w* \w le|strong="G2532"\w* \w consommateur|strong="G5051"\w* \w de|strong="G2532"\w* \w la|strong="G2532"\w* \w foi|strong="G4102"\w*, \w lui|strong="G2532"\w* \w qui|strong="G3588"\w*, \w au|strong="G1722"\w* \w lieu|strong="G1722"\w* \w de|strong="G2532"\w* \w la|strong="G2532"\w* \w joie|strong="G5479"\w* \w qu|strong="G3739"\w*’\w il|strong="G2532"\w* \w avait|strong="G2532"\w* \w devant|strong="G2532"\w* \w lui|strong="G2532"\w*, méprisant \w l|strong="G3739"\w*’ignominie, \w a|strong="G1519"\w* \w souffert|strong="G5278"\w* \w la|strong="G2532"\w* \w croix|strong="G4716"\w*, \w et|strong="G2532"\w* « \w s|strong="G2532"\w*’\w est|strong="G3588"\w* \w assis|strong="G2523"\w* \w à|strong="G1519"\w* \w la|strong="G2532"\w* \w droite|strong="G1188"\w* \w du|strong="G2532"\w* \w trône|strong="G2362"\w* \w de|strong="G2532"\w* \w Dieu|strong="G2316"\w* ».\f + \fr 12:2 \ft 12, 2. \fq L’auteur\ft , le guide (gr. ἀρχηγός), qui nous a précédés dans ce combat de la foi et nous donne le parfait modèle de la confiance absolue en Dieu. Le \qt consommateur\qt* de notre foi, parce qu’il l’affermit par son exemple, la perfectionne par sa grâce, et la conduit à son glorieux achèvement, la vision intuitive (x, 35). La Vulgate peut être interprétée dans le même sens.\f*
\v 3 Considérez \w celui|strong="G3588"\w* \w qui|strong="G3588"\w* \w a|strong="G1519"\w* \w supporté|strong="G5278"\w* \w contre|strong="G1519"\w* \w sa|strong="G1519"\w* \w personne|strong="G3361"\w* \w une|strong="G1519"\w* \w si|strong="G1063"\w* grande contradiction \w de|strong="G3588"\w* \w la|strong="G1519"\w* \w part|strong="G1519"\w* \w des|strong="G1519"\w* pécheurs, \w afin|strong="G2443"\w* \w de|strong="G3588"\w* \w ne|strong="G3361"\w* \w pas|strong="G3361"\w* \w vous|strong="G5210"\w* \w laisser|strong="G5210"\w* abattre \w par|strong="G5259"\w* \w le|strong="G1519"\w* découragement.
\p 
