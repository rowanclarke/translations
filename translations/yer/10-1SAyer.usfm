\id 1SA - Tarok
\h Nlir aSamuwel Aga aZəng
\toc3 1 aSam
\toc2 1 aSamuwel
\toc1 Nlir aSamuwel Aga aZəng
\mt1 ASamuwel
\mt2 Aga Zəng
\c 1
\s1 Amar aSamuwel
\p 
\v 1 Unəm uro uwa ka̱ yà ka̱ aRama kà̱ mbin aZufim ka̱ ashe mbin ngga aɗuktum aEfrayim. Aɗiɗin pa̱ uElkana uya aJeroham, uya aElihu, uya àTohu, uya àZup ka̱ akum ìjili aEfrayim.
\v 2 Uza̱ ká̱ ochar pa̱ oparəm, aɗin oza̱ pa̱ uHana ká̱ uPənina. UPənina ká̱ ovan, uHana ǹnyi te á yà ká̱ ovan ka̱t.
\v 3 Nza̱ ìzun nggo te, uElkana i wong kà̱ ìtong wò i ga aShilo, ka̱kul pa̱ na ô nəm awop, kang ô na nləfər ûYawe uGa ngGatək. UEli ká̱ ovan wò oga oparəm uHopəni ká̱ uFinehas òma onəm oga mpyal awop áYawe ka̱ awalang va̱ ta.
\v 4 Nra va̱ uElkana i yichi nləfər wò te, uza̱ i na ngba̱k ìzhe ìro ûchar wò uPənina, kang ovan aPənina onunggwan ká̱ ochar uza̱ i na ngba̱k pa̱ nzəng udanggo.
\v 5 Ǹnyi te, uza̱ i na ûHana ndan pa̱ mparəm, ka̱kul pa̱ uza̱ ma̱n na ma̱n, káp ka̱ nva̱ pa̱ uYawe gún atak amar kà̱ na a.
\v 6 Ukpəkpat i wong te, i náp avyal á na, na ô lak ìgwak á na ka̱kul pa̱ uYawe gún atak amar kà̱ na.
\v 7 Uza̱ i náp avyal á na nza̱ ìzun nggo. Awalang va káp uHana á ga awop kà̱ nzhi aYawe te, uPənina i náp avyal a na, á nak na uza̱ pak inok ayə́ng kang à yang ká̱ nri iya̱m.
\v 8 Te uɓəɓar uElkana i ɓəp na pa̱, <<ÁHana, ɓu yə́ng iza̱ yà? Iza̱ nak kang u ri iya̱m-nrì ka̱t yà? Iza̱ lak ìgwak a ɓu yà? Mmami te, n ji ovan onunggwan a ɓu pa̱ ogba̱pchi ka̱t ɗò?>>
\p 
\v 9 Ka̱ nda nro te, nva̱ngva̱ oza̱ gba̱l ká̱ nri ká̱ ngwa chit ka̱ aShilo, te uHana wong ka̱ ashe nlak ìgwak i far afar ká̱ ayə́ng ûYawe. Ka̱ awalang va̱ ta te, uEli unəm uga mpyal awop uwa ka̱ yà kà̱ ntəm ka̱ apal itok wò ka̱ izər ndar ngga anung nzhi aYawe.
\v 10 UHana ka̱ ashe nlak ìgwak pa̱ gənggəng, nva̱ uza̱ kà̱ nfar afar ká̱ ayə́ng ûYawe.
\v 11 Uza̱ yar nsar nnap-nlà, là pa̱, <<ÁYawe uGa ngGatək, a yà pa̱ u dər mɓək anung ázwal ɓu, kang u rəng ká̱ mi, u kong ká̱ uzwal ɓu ka̱t, wa na uyen ununggwan á mi, te mi le ká̱ na á ɓu. Uza̱ i yà uji ɓu i ga i chu nkur irirìriri, kang ìkpal ishi i yà ká̱ ndok ishishi ka̱t.>>
\p 
\v 12 Nva̱ uza̱ ka̱ pak inok nfar afar ûYawe, te uEli wa kà̱ ndər anunung.
\p 
\v 13 UHana wa kà̱ nfar afar ka̱ ashe ìgwak wò, kang ichəchu mí fe ka̱t, anunung na i gha̱p chwat, te uEli rəng pa̱ nchè à ra̱n na
\v 14 kang uza̱ là á na pa̱, <<Nkpak pa̱ ú wá nchè ú ra̱n ká̱ kang ɓu ɓa ka̱ ta̱ ɗò? Re ngwa ndəng ìba̱ngba̱ng ɓu.>>
\p 
\v 15 UHana na ama̱n pa̱, <<Ánəm uga nzhi mi, pa ka̱t. Mmami uchar uva ka̱ ashe nlak ìgwak pa̱ gənggəng. Na ngwá ndəng ìba̱ngba̱ng ka̱t te nchè chit ka̱t, mmami kà̱ nlà ìgwak mi ûYawe.
\v 16 Kang wa yar uzwal ɓu pa̱ uchar uga nnəm mmai ka̱t. N yar awalang va̱ ta̱ pa̱, ń nəm afar ka̱kul nɗaktak ká̱ nlak ìgwak va̱ n yà ishi mi kà̱ á.>>
\p 
\v 17 Te uEli là pa̱, <<Ga ká̱ ikángkáng, re Inan iga aIsa̱rila á na iya̱m va̱ a ɓu u chal kà̱ ná.>>
\p 
\v 18 UHana là pa̱, <<Re uzwal ɓu á ya nnap-nnəna̱n kà̱ mpyal ɓu.>> Te uza̱ ga iya̱m wò kang a ri iya̱m-nrì, kang ìgugwak lak lap ka̱t.
\p 
\v 19 Atak fa tàn ká̱ ìɓotak te, oza̱ wong kang oza̱ wop uYawe. Te oza̱ le nzhi oza̱ ka̱ aRama. UElkana ga atak nra kà̱ uchar wò uHana, kang uYawe rəng ká̱ na.
\v 20 Kang awalang ɓa chu te, uHana təm ká̱ anyám, a mar uyen ununggwan, te uza̱ sok aɗin á na pa̱, uSamuwel, uza̱ là pa̱, <<N chál uYawe ka̱kukul.>>
\s1 UHana yichi aSamuwel
\p 
\v 21 Te uElkana ká̱ nkpaktak nzhi wò ga pa̱ ô yichi nləfər ngga nza̱ ìzun nggo ûYawe, na ô yə́l nsar nnap-nlà wò kpa,
\v 22 nnyi te, uHana ga ji wò ka̱t. Uza̱ là ûɓar wò pa̱, <<UYen i re mbyal te, mi yar na kang mi ga ká̱ na kà̱ mpyal aYawe, kang uza̱ i təm ka̱ ta mbyetbyet.>>
\p 
\v 23 UElkana là á na pa̱, <<Nəm iya̱m va u ya ma ká̱ ɓu. Lòk na uyen á re mbyal kang, re nnap-nlà aYawe á yə́l.>> Te uHana təm kà̱ nzhi dər uyen wò ga chu awalang va̱ uyen re mbyal ká̱.
\p 
\v 24 Nva̱ngva̱ uyen re mbyal te, uHana yar na, ya uyen va̱ ta uwa uɓwakan nzəng ká̱ ìna ìnunggwan iga ìzun pa̱ ishatɗing, ká̱ mma̱k kà̱ ìkpáng, ká̱ aba̱ng ndəng ìba̱ngba̱ng. Uza̱ ɓa ká̱ kà̱ nzhi aYawe ka̱ aShilo.
\v 25 Ka̱ nva̱ngva̱ oza̱ pà ìna va̱ ta chit, te oza̱ ɓa ká̱ uyen va̱ ta ûEli,
\v 26 kang uHana là pa̱, <<Ánəm uga nzhi mi, yar mpat á mi, u rərəng ká̱ mi na ta̱ lap ɗò? Mmami na uchar va̱ ka̱ nsat ka̱ ta̱ kà̱ mpyal ɓu, kang i far afar ûYawe á.
\v 27 UYen va ta̱ ka̱ n far ûYawe pa̱ á na mi, kang uza̱ na iya̱m va̱ á mi chit ka̱ n chal ka̱ atətak.
\v 28 Ǹyangmata̱ mmami kà̱ nná na ûYawe. Kang nkpaktak nra irirìriri, uza̱ yà ujini chit.>> Te uza̱ wop uYawe ka̱ ta.
\c 2
\s1 Afar aHana
\p 
\v 1 Kang uHana nəm afar a là pa̱,
\q1 <<Mmami ká̱ nchàng ìgwak ka̱kul aYawe.
\q2 UYawe nak ìkam yà ka̱ mi chit.
\q1 M ma̱ka̱n okpa ìkum mi chit.
\q2 Mmami ka̱ nchang ìgwak ka̱kul pa̱ u ka̱m ishi mi.
\q1 
\v 2 Unəm uro yà uyə́ryər wa aYawe ka̱t,
\q2 uwa byet unəm uro yà lap ka̱t.
\q2 ÌPang iro yà wa Inan yi ka̱t.
\q1 
\v 3 Kang ó là nnap-nlà ngga nrup ká̱ ishi
\q2 ka̱t te ó re anung wó á là nnap-nlà ngga nkak ishi ka̱t.
\q1 Ka̱kul uYawe uwa Inan va nyi,
\q2 kang uwa i màl nnap nnəm wó.
\q1 
\v 4 Ijang oshozha oga ǹnyi ikum ɓun chit,
\q2 ǹnyi te, onəm oga nyà ká̱ ikàm ka̱t yà onəm okamkàm chit.
\q1 
\v 5 Onəm va̱ ka̱ yà ká̱ iya̱m-nrì pa̱ makmak matmat te, ǹyangmata̱ oza̱ kà̱ nnəm inok ka̱kul nram iya̱m-nrì,
\q2 ǹnyi te, onəm va̱ ka̱ yà ká̱ ayang te, afu yə́l oza̱ chit.
\q1 Uchar va̱ ka̱ səsat te, á mar ovan chit pa̱ ofangshat,
\q2 ǹnyi te, uchar va̱ ka̱ mar ovan pa̱ kyák te, á təm ulakchi chit.
\q1 
\v 6 UYawe uwa ɓa ká̱ ikú kang uwa na irirì.
\q2 Uwa ga ká̱ onəm ka̱ ashe awap kang uwa à wong ká̱ oza̱ kpa.
\q1 
\v 7 UYawe uwa na nkun oro kang uwa na idur oro.
\q2 Uza̱ yen ká̱ oro kang à rup ká̱ oro.
\q1 
\v 8 Uza̱ wong ká̱ oga nkun ka̱ ashe mɓwang,
\q2 kang uza̱ wong ká̱ oga nlang ka̱ apal ìsal,
\q1 uza̱ nak oza̱ təm nzəng ká̱ onəm oga atak nsat,
\q2 kang á nak atak ntəm nchumchum yà iya̱mkup oza̱.
\q1 Oga mbang apambin nji aYawe.
\q2 Ka̱ apal oza̱ na uza̱ pak apambin.
\q1 
\v 9 Uza̱ i kpak ashar onəm wò oga nnandər,
\q2 ǹnyi te, onəm oɓá̱ngɓa̱ng i zhì ka̱ ashe atak kpa̱rkpa̱r,
\q2 ka̱ atak ìkàm na unəm i ya igwan ka̱t.
\q1 
\v 10 Onəm va̱ yang uYawe te, oza̱ i zhì.
\q2 UGa iChumchum i nə́m ìgbarman ka̱ apaɓur,
\q1 uYawe i náp akwali n̂kpaktak apambin.
\q2 Uza̱ i na ìkam ûponzhi wò,
\q2 kang uza̱ i rup ká̱ agbəshi anəm ugargar wò.>>
\p 
\v 11 Te uElkana le nzhi ka̱ aRama, ǹnyi te, uSamuwel təm nnəm inok ûYawe ka̱ ashe awo aEli, unəm uga mpyal awop.
\s1 Inga ovan aEli onunggwan
\p 
\v 12 Ovan aEli onunggwan onga, oza̱ yà ká̱ ayər ûYawe ka̱t.
\v 13 Asa̱l va ta̱ na ka̱ yà nnap nnəm onəm oga mpyal awop pa̱, awalang va kap unəm uro i yichi nləfər te, ukpari anəm uga mpyal awop i ɓa ká̱ ìga̱pchi iga ifang pa̱ ishatɗing ká̱ awo wò, ya ìzhe ya kà̱ nfə́l ka̱ apər.
\v 14 Uza̱ i kyer ìga̱pchi iga ifang va̱ ta ka̱ ashe ngbət kang iya̱m va ìga̱pchi fa ká̱ te, i yà iji ánəm uga mpyal awop. Asa̱l va ta̱ oza̱ nəm n̂gkpaktak oIsa̱rila va̱ ɓa aShilo.
\v 15 Ǹnyi te, kang mí shì mpip te, ukpari anəm uga mpyal awop i ɓa i là ûnəm va̱ kà̱ ǹyichi nləfər pa̱, <<Ná ìzhe ìro na mmá wàng ûnəm uga mpyal awop, uza̱ i yà ká̱ nka̱m ìpəkpək ka̱ atak ɓu ka̱t, ya ìlulong chwat.>>
\p 
\v 16 A yà pa̱ unəm uga ǹyichi nləfər a là á na pa̱, <<Re mmá shì mpip mpyal kang ɓu kpa̱k wa nva u ɗom,>> te ukpari anəm uga mpyal awop i na ama̱n pa̱, <<O'o, na mi ǹyangmata̱, kang a yà pa ka̱t, te mi kpa̱k ká̱ ìfan.>>
\p 
\v 17 Nnap-mɓá̱ngɓa̱ng ovanza̱m va̱ ta̱ mak byet kà̱ mpyal aYawe, ka̱kul oza̱ vyap oga iya̱m inana áYawe.
\s1 USamuwel ka̱ aShilo
\p 
\v 18 Ǹnyi te, uSamuwel, uwa ka̱ nnəm inok ûYawe, uyen va̱ ta pá ìlukwan ìkwoksok iga alinin.
\v 19 Nza̱ ìzun nggo te, unənang i dán ìlukwan ìwángwang kang i ga á na ka̱ awalang va̱ uza̱ ká̱ uɓar wò i ga pa̱ ô yichi nləfər ngga nza̱ ìzun nggo.
\v 20 UEli i pa̱r uElkana ká̱ uchar wò, i là pa̱, <<Re uYawe á na ovan oro a ɓu ka̱ atak achar va̱ ta̱ ka̱ anung ava̱ uza̱ far afar kà̱ kang uza̱ na ûYawe á.>> Te oza̱ i le i ga nzhi.
\v 21 Kang uYawe dər uHana ká̱ aɗor, uza̱ mar ovan onunggwan pa̱ oshatɗing ká̱ ovan ochar pa̱ oparəm. Ǹnyi te, uyen va̱ ta, uSamuwel rup kà̱ mpyal aYawe.
\s1 UEli ká̱ ovan wò
\p 
\v 22 Ǹyangmata̱ uEli gbák chit pa̱ gənggəng, kang kà̱ nfe nkpaktak iya̱m va̱ ovəvan onunggwan kà̱ nnənəm n̂kpaktak oIsa̱rila ká̱ nva̱ oza̱ i ra ká̱ ochar va̱ kà̱ nnəm inok ka̱ anung asa̱l Aghal Mɓut á.
\v 23 Te uza̱ là óza̱ pa̱, <<Iza̱ nak kang ó nəm oga nnàp wa nva̱ ta̱ yà? Ka̱kul n fe ka̱ atak nkpaktak onəm oga nnap nnəm nnga va̱ mmawó kà̱ nnənəm á.
\v 24 Ó re, óvan mi, á ɓyen ka̱t, iya̱m va̱ onəm aYawe ka̱ nləlà ka̱ apal ishi wó te, a ɓa̱ng byet.
\v 25 A yà pa̱ unəm nəm nnap-mɓá̱ngɓa̱ng ûwan wò te, Inan i chal ka̱kukul, ǹnyi te, a yà pa̱ unəm nəm nnap-mɓá̱ngɓa̱ng ûYawe te, uda i chal ka̱kukul yà?>> Ká̱ nna te, ovəvan onunggwan yang ká̱ nkpak nnap-nlà apo oza̱, ka̱kul uYawe ka̱ nak chit pa̱ ô gbá̱ng oza̱.
\p 
\v 26 Ǹnyi te, uyen ununggwan va̱ ta, uSamuwel ga mpyal ká̱ nrup, kang nchəchər ba̱l kà̱ mpyal aYawe ká̱ onəm.
\s1 Nlà nre Inan ka̱ apal nzhi aEli
\p 
\v 27 N̂da aro te, unəm Inan ɓa atak aEli kang à là á na pa̱, <<Iya̱m va ta̱ uYawe là, <Ka̱ n nyám ishi mi ôkəka ɓu ka̱ awalang va̱ oza̱ ka̱ yà kà̱ nnəm izwal ûponzhi uga aMasar ka̱t ɗò?
\v 28 N yak akum akəka ɓu ka̱ ashe nkpaktak aIsa̱rila pa̱ á yà onəm oga mpyal awop mi, pa̱ á ga atak nshì iya̱m awop mi, á shì njəng nnə́ngnəng nchángchàng, á pá ìlukwan ìkwoksok ka̱ mpyal mi. Kang n na nzhi akəka ɓu nkpaktak oga nləfər va̱ oIsa̱rila yichi á.
\v 29 Iza̱ nak kang ó nəm vyákshin ká̱ nləfər ká̱ iya̱m inana va̱ n nak ka̱kul mi yà? ÁEli, iza̱ nak kang u na ichumchum ôvan ɓu na ji mi ka̱ atak nnak ishi ká̱ ishi wó, ó mwal nva̱ o ri ka̱ ashe iya̱m iyakyak va̱ onəm mi oIsa̱rila yichi á mi yà?>
\v 30 Ka̱kul nva̱ ta te, uYawe, Inan iga aIsa̱rila, là pa̱,<Ka̱ n yar nsar nnap-nlà chit pa̱ mmaɓu ká̱ nzhi ɓu ó tong onəm oga mpyal awop á mi mbyet.> Ǹnyi te, ǹyangmata̱ uYawe là pa̱, <Á yà pa lap ka̱t, ka̱kul ovəngva̱ na ichumchum á mi, te mi rup ká̱ oza̱, ǹnyi te, ovəngva̱ ɓak mi, te mi yen ká̱ oza̱.
\v 31 Dər, awalang na kà̱ mɓa ava mi gbá̱ng ovanza̱m oga nzhi ɓu ká̱ akum ìjili ɓu. Ka̱kul nva̱ ta te, mí yà ká̱ ǹya unəm uro i gbák kà̱ nzhi ɓu lap ka̱t,
\v 32 kang ɓu ya nɗaktak. Ka̱ nna te, mi nak nnap-nnəna̱n ka̱ apal aIsa̱rila, ǹnyi te, ka̱ ashe nzhi ɓu te, mí yà ká̱ ǹya unəm uro i təm i ga i gbák ka̱t.
\v 33 Mi yà ka̱ mgba̱ng nkpaktak akum ìjili ɓu ka̱t, ǹnyi te, unəm va̱ mi re ká̱ irirì pa̱ a yà unəm uga mpyal awop á mi, te uza̱ i təm ka̱ ashe ìgwak ìlaklak ká̱ aɗor kang uza̱ i fo. Te nkpaktak oga akum ìjili ɓu ó kú ikú iga mɓək anung.
\p 
\v 34 << <Kang iya̱m va̱ i ya ovan ɓu onunggwan oga oparəm, uHopəni ká̱ uFinehas te, i nyám ipir nnap a ɓu, oza̱ i kú ká̱ nda nzəngtəng.
\v 35 Kang mi wong ká̱ unəm uga mpyal awop mi uga nnandər, uva i wop mi kang i nəm iya̱m va ìgwak mi ɗom á. Mi nak nnap-nnəna̱n n̂zhizhi, kang oza̱ i təm mbyet kà̱ mpyal aponzhi mi ugargar.
\v 36 Kang unəm va̱ re ká̱ irirì kà̱ nzhi ɓu te, i kuchi ka̱ mpipyal i chál mbwai ká̱ iya̱m-nrì. Uza̱ i chál pa̱, <<Mmá na inok iro á mi iga mpyal awop, na n ya iya̱m-nrì n ri.>> > >>
\c 3
\s1 UYawe wór uSamuwel
\p 
\v 1 Ǹnyi te, uyen ununggwan va̱ ta, uSamuwel uwa ka̱ nnəm inok ûYawe, ka̱ ashe awo aEli. Ka̱ ashe oga nra va̱ ta te, uYawe mà ma̱n nlà nnàp ká̱ onəm pe ka̱t, kang oga alár bal pe ka̱t kpa.
\v 2 N̂da nro ká̱ izwam te, uEli va i ya atak dakdak lap ka̱t, uwa kà̱ nra ka̱ atak nra wò.
\v 3 Nna mmá gba̱l apitila Inan chit ka̱t, kang uSamuwel uwa ka̱ nra ka̱ ashe nzhi awop aYawe dát ká̱ atak va̱ mí nak akwati aga nsar nnap-nlà Inan kà̱.
\p 
\v 4 Te uYawe wór uSamuwel, kang uSamuwel ma̱n pa̱, <<Mmami na ta̱.>>
\v 5 Kang uza̱ chər ga atak aEli, uza̱ là pa̱, <<Mmami na ta̱, u wór mi.>>
\p Ǹnyi te, uEli là á na pa̱, <<N wór ɓu ka̱t, le ga ra.>> Te uSamuwel le ga ra.
\p 
\v 6 UYawe wór kà̱ɗi pa̱, <<ÁSamuwel>> Te uSamuwel wong kang à ga atak aEli, là pa̱, <<Mmami na ta̱, u wór mi.>>
\p Te uEli là pa̱, <<N wór ɓu ka̱t áyen mi, le ga ra.>>
\p 
\v 7 Ǹnyi te, uSamuwel uwa ka̱ nyi uYawe chit ka̱t, ka̱kul uYawe uwa ka̱ nyám ká̱ nnap nla wò á na chit kang ka̱t.
\p 
\v 8 Kang uYawe wór uSamuwel kà̱ɗi ngga nshatɗing. Te uSamuwel wong kang a ga atak aEli là pa̱, <<Mmami na ta̱, u wór mi.>>
\p Nna chit te, uEli nyi ɗak pa̱ uYawe i wór uyen ununggwan va̱ ta̱.
\v 9 Te uEli là ûSamuwel pa̱, <<Ga, na ú ra kang a yà pa̱ uza̱ a wór ɓu kà̱ɗi te, là pa̱, <Là, áYawe, ka̱kul uzwal ɓu ka̱ nggwong achwang.> >> Te uSamuwel le kang à ga ra ka̱ atak nra wò.
\p 
\v 10 Te uYawe ɓa sat ka̱ ta i wór awór kà̱ɗi wa nva̱ uza̱ ka̱ wór pa̱, <<ÁSamuwel, áSamuwel.>>
\p Kang uSamuwel là pa̱, <<Là, ka̱kul uzwal ɓu kà̱ nggwong achwang.>>
\p 
\v 11 Te uYawe là ûSamuwel pa̱, <<Mmami kà̱ ngga nnəm iya̱m iro ka̱ ashe aIsa̱rila iva unəm va̱ pa̱ kap i fe ka̱ achwang wò te, i ga̱m.
\v 12 N̂da va̱ ta te, mi yə́l nkpaktak iya̱m va̱ n là ka̱ apal ishi aEli ka̱ nzhizhi, kà̱ mɓəɓan i ga i chu nkukur.
\v 13 Ka̱ nləlà á na pa̱ mi ga nnáp-akwali n̂zhizhi mbyet, ka̱kul nnap-mɓá̱ngɓa̱ng va̱ uza̱ nyi ka̱ apal ovan wò onunggwan nva̱ oza̱ vyap aɗin aYawe, ǹnyi te, uza̱ ɗa̱t oza̱ ka̱t.
\v 14 Ka̱kul nva̱ ta te, ka̱ n sóng anung n̂zhi aEli pa̱, <Nləfər nro ka̱t te iya̱m inana iro yà iva̱ mí yichi pa̱ á yar nsur nnap-mɓá̱ngɓa̱ng n̂zhizhi ka̱t mbyet.> >>
\p 
\v 15 USamuwel ra atak fa tan, kang uza̱ bol oga anung nzhi agga ntar nzhi aYawe. Uza̱ nəm ayər nlà ûEli iya̱m va̱ uYawe là á na ka̱ ashe alár,
\v 16 ǹnyi te, uEli wór na kang à là pa̱, <<ÁYen mi, uSamuwel.>>
\p Te uSamuwel ma̱n pa̱, <<Mmami na ta̱.>>
\p 
\v 17 Te uEli ɓəp na pa̱, <<Iza̱ uYawe là a ɓu yà? Kang wa bwam iya̱m iro ka̱ mi ka̱t. Re Inan á vyap ɓu, a yà pa̱ u bwam iya̱m iro kà̱ mi ka̱ ashe nkpaktak iya̱m va̱ uza̱ la á ɓu á.>>
\v 18 Te uSamuwel là iza̱ nggo á na, a bwam iya̱m iro ka̱ na ka̱t. Nna chit te uEli là pa̱, <<Uza̱ uwà uYawe, re uza̱ á nəm iya̱m va uza̱ ya ɓyen á.>>
\p 
\v 19 USamuwel rup, kang uYawe uwa yà nzəng ká̱ na, kang nkpaktak iya̱m va̱ uSamuwel là te, Inan nak á yə́l.
\v 20 Te nkpaktak oIsa̱rila, ɓàn ka̱ aDan ka̱ asa̱l mpal ga chu aBeyersheba ka̱ asa̱l nkwandal, nyi ɗak pa̱ uSamuwel, unəm uga nka̱m nre ka̱ atak Inan uva uYawe à re.
\v 21 UYawe pak inok nnyám ishi wò ka̱ aShilo, kang ka̱ ta uza̱ nyám ishi wò ûSamuwel ka̱ atak nnap-nlà wò.
\c 4
\p 
\v 1 Kang nnap-nlà aSamuwel ɓa n̂kpaktak oIsa̱rila.
\s1 OFilisti vyat akwati aga nsar Nnap-nlà
\p Te oIsa̱rila fa ìkum kà̱ oFilisti, kang oza̱ ra apa̱k ka̱ aEbenezer, nnyi te oFilisti ra apa̱k ka̱ aAfek.
\v 2 OFilisti gbar izər pa̱ ó lung oIsa̱rila, kang awalang va̱ ìkum sur te, oFilisti nəm igwan ká̱ oIsa̱rila, kang a gbá̱ng oza̱ ìkalong pa̱ ìneɗing ka̱ mpyal ìkum va̱ ta.
\v 3 Awalang va̱ oshozha le apa̱k te, onəmgbak oIsa̱rila ɓəp pa̱, <<Iza̱ nak kang uYawe re oFilisti nəm igwan ká̱ yi nda ata̱ yà? Re i ɓa ká̱ akwati aga nsar nnap-nlà aYawe ka̱ aShilo, na uza̱ á ka̱m ishi yi ka̱ ashe awo okpa ìkum yi.>>
\v 4 Te oza̱ re onəm ga aShilo, kang oza̱ ɓa ká̱ Akwati aga nsar nnap-nlà aYawe uGa ngGatək, uva təm ka̱ ishimshe oga akerup. Kang ovan onunggwan aEli oga oparəm, uHopəni ká̱ uFinehas, oma ka̱ yà ka̱ ta ká̱ akwati aga nsar nnap-nlà Inan.
\p 
\v 5 Kang awalang va̱ akwati aga nsar nnap-nlà aYawe fa chu ashe apa̱k te, nkpaktak oIsa̱rila bà achu kang mbin yənggət.
\v 6 Awalang va̱ oFilisti fe mbà achu te, oza̱ ɓəp pa̱, <<Iza̱ nak kang achu i bà wa nta̱ ka̱ ashe apa̱k onəm aIbərahim yà?>> Nva̱ngva̱ oza̱ fe pa̱ mmá ɓa ká̱ akwati aga nsar nnap-nlà aYawe chit ka̱ ashe apa̱k,
\v 7 te ayər nəm oFilisti, oza̱ là pa̱, <<Inan à ɓa ashe apa̱k.>>Te oza̱ là pa̱ <<Á kùr ká̱ yi chit, ka̱kul nna mmá nəm apir iya̱m chit wa iva̱ ta̱ ka̱t.
\v 8 Á lak ká̱ yi chit. Uda i ka̱m ishi yi ka̱ ashe awo oga inan ichumchum va̱ ta̱ yà? Oga inan va ta̱ gbá̱ng onəm oga aMasar ká̱ apir oga nɗaktak pa̱ ɗongɗong ka̱ ashe nzam.
\v 9 ÓFilisti, ó nəm nkám ìpa̱ng, ó lung oza̱, ka̱kul na kang ó nyáng ozwal onəm aIbərahim wa nva̱ oza̱ ka̱ yà ozwal wó ka̱t. Ó tong pa̱ kakkərak wa onunggwan, ó lung ìkum.>>
\p 
\v 10 Te oFilisti lung ìkum va̱ ta ká̱ nkpaktak nkàm oza̱, kang oza̱ ri oIsa̱rila, oshozha oIsa̱rila chəng, udanggo kpán asa̱l aghal wò. Mmá gbá̱ng oIsa̱rila pa̱ makmak, kang onəm va̱ mmá gbá̱ng te, ìkalong ìsəm pa̱ ishatɗing.
\v 11 Mmá vyat akwati aga nsar nnap-nlà Inan, kang ovan onunggwan aEli oga oparəm, uHopəni ká̱ uFinehas, mmá gbá̱ng kpa.
\s1 Ikú aEli
\p 
\v 12 Unəm uro ka̱ akum ìjili aBenjamin chər ka̱ atak ìkum ɓa chu aShilo ka̱ nda va̱ ta. Uza̱ ká̱ ìlukwan ikankan kang ká̱ mɓwang ka̱ ishi wò.
\v 13 Awalang va̱ uza̱ ɓa chu te, uEli uwa ka̱ yà ka̱ ntəm ka̱ apal iya̱m ntəm wò ka̱ ngba̱k asa̱l pa̱ na ô fe nnap ìkum va̱, ka̱kul ìgugwak ra ka̱ apal akwati aga nsar nnap-nlà aYawe va̱ ka̱t. Awalang va̱ unəm va̱ ta tar ashe ìtong kang à là kpaktak iya̱m va̱ fa ônəm te, nkpaktak ìtong bà ká̱ ayə́ng.
\v 14 UEli fe mbà ayə́ng te, uza̱ ɓəp pa̱, <<Iza̱ mí bà ayə́ng kà̱ yà?>>
\p Te unəm va̱ ta gha̱n ɓa kang à là ûEli iya̱m va̱ fa.
\v 15 Ka̱ awalang va̱ ta te, uEli ká̱ ìzun ìsəm pa̱ ìfangzəngtəng ama̱n pa̱ na̱nne kang uza̱ fo chit, i ya atak lap ka̱t.
\p 
\v 16 Uza̱ là ûEli pa̱, << N chər ka̱ atak ìkum, m ɓa n̂da ata̱.>>
\p Te uEli ɓəp pa̱, <<Áyen mi, iza̱ kà̱ ngga yà?>>
\p 
\v 17 Te unəm va̱ ɓa ka̱ nggwol va̱ ta na ama̱n pa̱, <<OIsa̱rila chəng kà̱ mpyal oFilisti, kang oFilisti gbá̱ng onəm pa̱ makmak nzəng ká̱ ovan ɓu onunggwan oga oparəm, uHopəni ká̱ uFinehas. Kang mmá vyat akwati aga nsar nnap-nlà Inan kpa.>>
\p 
\v 18 Nva̱ngva̱ uEli fe nnap akwati aga nsar nnap-nlà Inan va̱ ta te, uza̱ ru ka̱ asa̱l nsəm ka̱ apal ìtok wò ka̱ anung asa̱l ìtong. Kang uza̱ ɓəkchi ìshak, uza̱ kú, ka̱kul uza̱ unəm ugbakgbak umwalmwal. Uza̱ ka̱ yà unəm uga mpyal oIsa̱rila ìzun ìsəm pa̱ ìneɗing.
\p 
\v 19 Uchar à ya aEli, uFinehas ka̱ yà ká̱ anyám, á dát ká̱ amar chit. Awalang va̱ uchar va̱ ta fe pa̱ mmá vyat akwati aga nsar nnap-nlà Inan chit, kang pa̱ ukəka ká̱ uɓəɓar oza̱ kú chit kpá, te nrwa afu amar wong ka̱ na, uza̱ kúchi mar te, uza̱ kú.
\v 20 Uza̱ ka̱ anung ikú te, ochar va̱ kà̱ nnak ishi ká̱ na là á na pa̱, <<Kang ayər á nəm ɓu ka̱t, ka̱kul u mar uyen ununggwan>> Ǹnyi te, uza̱ na ama̱n ka̱t, kang uza̱ nak ishi ká̱ oza̱ ka̱t.
\p 
\v 21 Te uza̱ sok aɗin ûyen va̱ ta pa̱ uIkabot, uza̱ là pa̱, <<Ìzhàn kap ká̱ aIsa̱rila chit.>> Ka̱kul mmá vyat akwati aga nsar nnap-nlà Inan chit, kang ukəka ká̱ uɓəɓar kú chit kpá.
\v 22 Uza̱ là pa̱, <<Ìzhàn kap ká̱ aIsa̱rila chit, ka̱kul mmá vyat akwati aga nsar nnap-nlà Inan chit.>>
\c 5
\s1 Akwati aga Nsar Nnap-nlà Inan ka̱ awo oFilisti
\p 
\v 1 Kà̱ nva̱ngva̱ oFilisti vyat akwati aga nsar nnap-nlà Inan chit ka̱ atak ìkum ka̱ aEbenezer, te oza̱ ga ká̱ ka̱ aAshdot.
\v 2 Oza̱ yar akwati aga nsar nnap-nlà Inan nak ka̱ ashe nzhi aDagon, oza̱ nak datkulung ká̱ aDagon.
\v 3 Nva̱ngva̱ onəm oga aAshdot wong ká̱ ìɓotak te, oza̱ ya aDagon ru chit zəp ká̱ afu kà̱ mpyal akwati aga nsar nnap-nlà aYawe. Te oza̱ yar oza̱ yal ka̱ atak nvəva̱ng.
\v 4 Ǹnyi te, atak fa tàn ká̱ ìpin kang oza̱ wong te, oza̱ ya aDagon ru chit zəp ká̱ afu kà̱ mpyal akwati aga nsar nnap-nlà aYawe. Ishishi ká̱ oga awuwo ɓun ra ka̱ anung asa̱l, izəzər na le chwat.
\v 5 Iya̱m va ta nak kang ɓa chu n̂da va̱ ta̱ te, onəm oga mpyal awop aDagon ka̱t te nkpaktak ovəngva̱ i táng ashe nzhi awop aDagon pa̱ ó wop na, i tòng anung asa̱l nzhi aDagon ka̱ aAshdot ka̱t.
\p 
\v 6 UYawe nyán ká̱ onəm oga aAshdot, ká̱ oga atak va̱ gáng na ká̱ arwa oga nsomo.
\v 7 Onəm oga aAshdot ya chit pa te, oza̱ là pa̱, <<Kang i re akwati aga nsar nnap-nlà Inan oIsa̱rila a təm ka̱ atak yi ka̱t. Ka̱kul Inan oIsa̱rila kà̱ nnyán ká̱ yi ká̱ inan yi aDagon.>>
\v 8 Te oza̱ re ǹre mmá ɓut nkpaktak oponzhi oFilisti, kang oza̱ ɓəp pa̱, <<Iza̱ í nəm ká̱ akwati aga nsar nnap-nlà Inan oIsa̱rila va̱ ta̱ yà?>>
\p Te oponzhi va̱ ta na ama̱n pa̱, <<Mmá yar akwati aga nsar nnap-nlà Inan oIsa̱rila, mmá ga ká̱ ka̱ aGat.>> Te oza̱ yar ga ká̱ ka̱ aGat, ìtong oFilisti ìro.
\p 
\v 9 Nva̱ngva̱ oza̱ ga ká̱ chit ka̱ aGat te, uYawe nyán ká̱ onəm oga ìtong va̱ ta. Ovan ká̱ onəmgbak, uza̱ lə̀p kpaktak oza̱ ká̱ arwa oga nsomo.
\v 10 Te oza̱ re nre ká̱ akwati aga nsar nnap-nlà Inan ga aEkron.
\p Awalang va̱ akwati aga nsar nnap-nlà Inan va̱ ta ɓa chu aEkron te, onəm bà ayə́ng, oza̱ là pa̱, <<Oza̱ ɓa ká̱ akwati aga nsar nnap-nlà Inan oIsa̱rila ka̱ ta̱ pa̱ na á gbá̱ng yi pa̱ chatchat.>>
\v 11 Te oza̱ wór nkpaktak oponzhi oFilisti ka̱ atak zəngtəng, kang oza̱ là pa̱, <<Ó re ǹre ká̱ akwati aga nsar nnap-nlà Inan oIsa̱rila á le atak va̱ fa kà̱, ka̱t te i gbá̱ng yi ká̱ onəm yi.>> Arwa aɓá̱ngɓa̱ng ka̱ atak Inan á ɓàn chit ka̱ ashe ìtong ka̱kul Inan kà̱ nnyán ká̱ ìtong va̱ ta.
\v 12 Onəm va̱ kú ka̱t te, mmá lə̀p oza̱ ká̱ nsomo, kang ayə́ng onəm ɓa chu apaɓur.
\c 6
\s1 OFilisti le ká̱ aKwati aga Nsar Nnap-nlà Inan ka̱ aIsa̱rila
\p 
\v 1 Kà̱ nva̱ngva̱ akwati aga nsar nnap-nlà aYawe nəm ape pa̱ fangshat ka̱ ashe mbin oFilisti te,
\v 2 oFilisti wór onəm oga mpyal awop ká̱ onəm oga iva̱k, ɓəp oza̱ pa̱, <<Iza̱ í nəm ká̱ akwati aga nsar nnap-nlà aYawe va̱ ta̱ yà? Ó là á yi asa̱l va̱ í nəm kang í le ká̱ ka̱ atak nvəva̱ng.>>
\p 
\v 3 Oza̱ na ama̱n pa̱, <<A yà pa̱ ó le ká̱ akwati aga nsar nnap-nlà Inan oIsa̱rila te, kang ó re á ga pa alakchi ka̱t, nkpak ó na iya̱m inana iga ǹyar mpat á na. Nna chit te ó ya ikángkáng kà̱ɗi, kang ó nyi ìpir iya̱m va̱ nak kang uYawe re nyán ká̱ wó ka̱t.>>
\p 
\v 4 OFilisti ɓəp pa̱, <<Nza̱ apir iya̱m inana iga ǹyar mpat a màl pa̱ í re nre ká̱ yà?>>
\p Te oza̱ na ama̱n pa̱, <<Ó la oga nsomo ngga azənariya pa̱ ntukun ká̱ ipí pa̱ ìtukun iga azənariya ka̱ apal ìyəl oponzhi oFilisti, ka̱kul arwa azəngtəng na ya wó ká̱ oponzhi wó.
\v 5 Ó la apir oga nsomo va̱ nəm wó, ká̱ apir ipí va̱ vyap iya̱m ka̱ mbin wó, na ó na ichumchum Înan oIsa̱rila. Mwote uza̱ i yar mɓək anung va̱ ta i le a wó ká̱ oga inan wó, kang ká̱ mbin wó nggo.
\v 6 Iza̱ nak kang ó twat igwak wó wa onəm oga aMasar ká̱ uponzhi oza̱ yà? Nva̱ngva uYawe nyán ká̱ oza̱ chit pa̱ gənggəng te, oza̱ re onəm oIsa̱rila kpan asa̱l ga ka̱t ɗò?
\p 
\v 7 <<Ǹyangmata̱ te, ó nəm akeke ina apipe, te ó ran ina pa̱ iparəm iva ivan oza̱ na ka̱ mmá mbyal, iva na mmá ran ayok ôza̱ chit ka̱t, ǹnyi te, ó re ivan oza̱ ka̱ ashe afo.
\v 8 Te ó yar akwati aga nsar nnap-nlà aYawe va̱ ta, ó nak ka̱ apal akeke, te ó nak oga iya̱m va̱ ó la ká̱ azənariya ka̱ ashe akwati aro ka̱ ngbəgba̱k, iva ó re nre ká̱ ûYawe wa iya̱m inana iga nyar mpat. Te ó re na á fa á ga asa̱l wò,
\v 9 ǹnyi te, ó dər. A yà pa̱ a kpán asa̱l aBet-Shemesh te, í nyi pa̱ uYawe uwa i nyán ká̱ yi, kang a yà pa ka̱t te, í nyi pa̱ uwa i nyán ká̱ yi ka̱t. Á ya yi pa mwang.>>
\p 
\v 10 OFilisti nəm wa nva mmá là ôza̱. Oza̱ wur ina iga ivan pa̱ iparəm ran akeke ina ôza̱, kang oza̱ kùk ivan oza̱ ka̱ ashe afo.
\v 11 Te oza̱ nak akwati aga nsar nnap-nlà aYawe ka̱ apal akeke ina ká̱ akwati oga nsomo ngga azənariya ká̱ ipí iga azənariya ka̱ ngba̱k akwati aga nsar nnap-nlà aYawe.
\v 12 Oga ina va̱ ta kpán asa̱l nzwang i ga aBet-Shemesh, oza̱ ka̱ ngga oza̱ ka̱ ǹyə́ng. Oza̱ lyep awo ari ka̱t te apəra̱m ka̱t. Oponzhi oFilisti wà nva̱ng oza̱ ga chu aswari aBet-Shemesh.
\p 
\v 13 Ǹyangmata̱ te, onəm oga aBet-Shemesh ka̱ mɓən ìzangzəng oza̱ ka̱ ashe mba̱nda̱m, kang awalang va̱ oza̱ wong ká̱ iwú, kang oza̱ ya akwati aga nsar nnap-nlà te, ìgwak nchang oza̱ kà̱ nya akwati va̱ ta.
\p 
\v 14 Akeke ina va̱ ta tar ashe ìram aJoshuwa uga aBet-Shemesh kang à sat ka̱ ta, kà̱ ngba̱k ìnang ìpang. Te onəm ghak akun akeke ina va̱ ta mà̱k apər ká̱ kang oza̱ yichi ina va̱ ta iya̱m inana iga nshì pa̱ ɗwot ûYawe.
\v 15 OLawi yar akwati aga nsar nnap-nlà aYawe va̱ ta ká̱ akwati va̱ kà̱ ngbəgba̱k, ava mmá nak oga ala̱ka̱n va̱ mmá nəm ká̱ azənariya ka̱ ashishe, kang oza̱ nak ka̱ apal ìnang ìpang va̱ ta. Te onəm oga aBet-Shemesh yichi iya̱m inana iga nshì pa̱ ɗwot ká̱ nləfər ûYawe n̂da va̱ ta.
\v 16 Oponzhi oFilisti oga otukun va̱ ta ya te, oza̱ le n̂da va ta ga aEkron.
\p 
\v 17 Oga nsomo ngga azənariya va̱ oFilisti re nre ká̱ wa iya̱m inana iga ǹyar mpat ûYawe te, oma ta̱, pa̱ zəng ka̱kul aAshdot, pa̱ zəng ka̱kul aGaza, pa̱ zəng ka̱kul aAshəkelon, pa̱ zəng ka̱kul aGat kang pa̱ zəng ka̱kul aEkron.
\v 18 Kang ipí iga azənariya ka̱ anung oga itong oFilisti iga itukun va̱ ta, iva iji oponzhi oga otukun va̱ ta, oga itong iga akamsəlang ká̱ ivan itong iva yà ká̱ akamsəlang ka̱t. Ìnang ìpang va̱ oza̱ nak akwati aga nsar nnap-nlà aYawe kà̱ te, ì ya yà n̂da va̱ ta̱ ka̱ ashe ìram aJoshuwa uga aBet-Shemesh.
\p 
\v 19 Te uYawe gbá̱ng onəm oga aBet-Shemesh ìsəm pa̱ ìfangshat ka̱kul oza̱ dər ashe akwati aga nsar nnap-nlà aYawe. Iya̱m va̱ ta nak onəm oga aBet-Shemesh yə́ng ikú pa̱ gənggəng.
\v 20 Kang onəm oga aBet-Shemesh ɓəp pa̱, <<Uda kúr nsat ka̱ mpyal aYawe, Inan ìyə́ryər va̱ ta̱ yà? Í re akwati aga nsar nnap-nlà va̱ ta̱ i ga che kang i kap ká̱ yi yà?>>
\p 
\v 21 Te oza̱ re onəm oga nre ka̱ atak onəm oga ntəm ka̱ aKiriyat-Jeyarim pa̱, <<OFilisti le ká̱ akwati aga nsar nnap-nlà aYawe chit, ó ɓa na ó yar á ga ka̱ atak wó.>>
\c 7
\p 
\v 1 Te onəm oga aKiriyat-Jeyarim ɓa yar akwati aga nsar nnap-nlà aYawe ga ká̱ kà̱ nzhi aAbinadap ka̱ apal aɗuktum. Kang oza̱ gár uyiyen uEleyazar pa̱ á pángchí akwati aga nsar nnap-nlà aYawe va̱ ta.
\s1 USamuwel nəm igwan ká̱ oFilisti ka̱ aMizpa
\p 
\v 2 Akwati aga nsar nnap-nlà va̱ ta təm ka̱ aKiriyat-Jeyarim awalang pa̱ makmak, a ga chu ìzun ìsəm pa̱ ìparəm. Ka̱ awalang va̱ ta te, nkpaktak oIsa̱rila ga̱ɓa̱n yə́ng ka̱ mpyal aYawe pa̱ á ka̱mshi wó.
\p 
\v 3 Te uSamuwel là n̂kpaktak oIsa̱rila pa̱, <<A yà pa̱ mmawó kà̱ nle atak aYawe ká̱ nkpaktak igwak wó te, ó swang oga inan iga mbin nro ká̱ inan aAshtoret ka̱ ashe wó, na ó nak ìgwak ka̱ atak aYawe, ó wop uwa byet, te uza̱ i ka̱mshi wó ka̱ ashe awo oFilisti.>>
\v 4 Te oIsa̱rila swang oga aBaal ká̱ oga aAshtoret kang oza̱ wop uYawe wa byet.
\p 
\v 5 Te uSamuwel là pa̱, <<Ó ɓut nkpaktak oIsa̱rila ka̱ aMizpa, te mi far ûYawe ka̱kul wó.>>
\p 
\v 6 Awalang va̱ oza̱ ɓut ka̱ aMizpa te, oza̱ dàp ndəng sháng kà̱ mpyal aYawe. Oza̱ yar ndəng gbà̱l ká̱ nda va̱ ta kang oza̱ là pa̱, <<Í nəm nnap-mɓá̱ngɓa̱ng ûYawe chit.>>Ǹyangmata̱ te, uSamuwel ka̱ yà ka̱ nnəm iponzhi oIsa̱rila ka̱ aMizpa.
\p 
\v 7 Awalang va̱ oFilisti fe pa̱ oIsa̱rila ɓut chit ka̱ aMizpa, te oponzhi oFilisti kyen ga pa̱ na ó ru oza̱ ka̱ ìkum. Kang awalang va̱ oIsa̱rila fe te, ayər nəm oza̱ ka̱kul oFilisti.
\v 8 Te oza̱ là ûSamuwel pa̱, <<Í chal ɓu, kang wa re nfar afar ûYawe, Inan yi ka̱kul yi ka̱t, na mwote uza̱ á ka̱mshi yi ka̱ ashe awo oFilisti nggo.>>
\v 9 Te uSamuwel kpán ìya ìtam iga mma mbyal kang à yichi na iya̱m inana iga nshì pa̱ ɗwot ûYawe. Te uSamuwel far ûYawe ka̱kul oIsa̱rila, te uYawe ma̱n á na.
\v 10 Nva̱ uSamuwel ka̱ ǹyichi nləfər va̱ ta̱ ká̱ iya̱m inana iga nshì pa̱ ɗwot ûYawe te, oFilisti ka̱ mɓa pa̱ ó ru oIsa̱rila ká̱ ìkum. Te uYawe ləp ìgbarman ká̱ nda va̱ ta ka̱ apal oFilisti, te a na ayər ôza̱, kang oza̱ le nva̱ng chəng kà̱ mpyal oIsa̱rila.
\v 11 Te oshozha oIsa̱rila fa ka̱ ashe aMizpa kang oza̱ ɓak oFilisti, kang nəm inok ngbá̱ng oza̱ ga dat ká̱ aBetkar.
\p 
\v 12 Te uSamuwel yar ìpang nak ká̱ ishimshe aMizpa ká̱ aShen kang à na aɗin a na pa̱ aEbenezer, uza̱ là pa̱, <<Á ɓa chu ǹyangmata̱ uYawe wa ka̱ nka̱mshi yi.>>
\v 13 Wa nnà ta oIsa̱rila nəm igwan ká̱ oFilisti, kang oza̱ táng aswari mbin oIsa̱rila lap ka̱t.
\p Ǹnyi te, uYawe nəm inok nnyán ká̱ oFilisti ka̱ ashe nkpaktak nra aSamuwel.
\v 14 Te mmá le ká̱ oga itong oIsa̱rila va̱ oFilisti vyat ka̱ oza̱ á, ɓàn ká̱ aEkron ga chu aGat, kang oIsa̱rila ka̱m oga aswari mbin oza̱ kpa ka̱ ashe awo oFilisti. Kang ntəm ikángkáng yà ká̱ ishimshe oIsa̱rila ká̱ oAmori.
\p 
\v 15 USamuwel nəm iponzhi oIsa̱rila ka̱ ashe nkpaktak nra irirìriri.
\v 16 Nza̱ ìzun nggo te, uSamuwel i ranggang i ga aBetel, aGilgal ká̱ aMizpa, kang uza̱ i náp akwali oga itong va̱ ta̱.
\v 17 Te uza̱ i le aRama nzhizhi, kang uza̱ i náp akwali ôIsa̱rila ka̱ ta kpa. Kang uSamuwel me atak nshì iya̱m awop ûYawe ka̱ aRama.
\c 8
\s1 OIsa̱rila ɗom Uponzhi
\p 
\v 1 Awalang va̱ uSamuwel gbák chit, te uza̱ kyep ovan wò onunggwan yà onəm oga mpyal oIsa̱rila.
\v 2 Aɗin ayiyen uga ngəshi pa̱ uJowel, kang uga uparəm pa̱ uAbijah, kang oza̱ nəm inok ka̱ aBeyersheba.
\v 3 Ǹnyi te, ovəvan yar nnap-nnənəm ka̱t. Oza̱ ga̱ɓa̱n ka̱kul nram mmak, oza̱ i ga̱ɓa̱n nnandər ka̱ atak nka̱m iya̱m iga mmulam anung ka̱ atak onəm.
\p 
\v 4 Te nkpaktak onəm oga mpyal oIsa̱rila ɓut kang a ɓa atak aSamuwel ka̱ aRama.
\v 5 Oza̱ là á na pa̱, <<Dər, ǹyangmata̱ u gbák chit, kang ovan ɓu onunggwan yar nnap-nnəm ɓu ka̱t. Ka̱kul nva̱ ta te, kyer uponzhi á yi, uva i nəm ká̱ yi wa aɓoshi oga mbin.>>
\p 
\v 6 Nva̱ oza̱ là pa̱, <<Kyer uponzhi á yi, uva i nəm ká̱ yi,>> te nnap va̱ ta ɗak uSamuwel, kang uza̱ far afar ûYawe.
\v 7 Te uYawe là ûSamuwel pa̱, <<Nəm ôza̱ wa nva oza̱ ɗom á. Ka̱kul oza̱ yang mmaɓu ka̱t, oza̱ yang mmami pa̱ n yà uponzhi oza̱ ka̱t.
\v 8 Á ɓan ka̱ ashe nra va̱ n fa ka̱ oza̱ kà̱ mbin aMasar, á ɓa chu nda va̱ ta̱, oza̱ ga̱ɓa̱n asəm á mi, oza̱ i wop inan iro, te wa nnà ta oza̱ kà̱ nnənəm a ɓu.
\v 9 Ǹyangmata̱ te, nəm ôza̱ wa nva̱ oza̱ ɗom, ǹnyi te, dàp achwang oza̱ pa̱ gənggəng, là ôza̱ apir iya̱m va̱ uponzhi va̱ ta i nəm ôza̱.>>
\p 
\v 10 Te uSamuwel là ônəm va̱ ɓəp pa̱ mmá na uponzhi ôza̱, nkpaktak iya̱m va̱ uYawe là á.
\v 11 USamuwel là ôza̱ pa̱, <<Asa̱l va ta̱ uponzhi va̱ ta i nəm iponzhi wò ka̱ apal wó, uza̱ i wur ovan wó onunggwan i nak i yà onəm oga nkwak akeke ipəripəri, oro i tong onəm oga nkwak ipəripəri, kang oro i chəng ka̱ mpyal akeke ipəripəri.
\v 12 Kang uza̱ i nak oro i yà onəm oga mpyal ìkukum ka̱ apal oshozha ìkalong, kang oro ka̱ apal oshozha ìsəm pa̱ itukun, kang oro i wap ìrəram, kang i ɓən iyəya̱m á na kpa, oro i lá iya̱m ìkum á na ká̱ iya̱m akeke ipəripəri.
\v 13 UPonzhi va̱ ta i wur ovan ochar wó i nak i nyang onəm oga nnəm nturari, ká̱ mpə́k iya̱m-nrì, ká̱ ngwang nzəngkəng á na.
\v 14 Uza̱ i vyat iram wó inəna̱n, ká̱ iram iba̱ngba̱ng inəna̱n, ká̱ ikun mpyet wó inəna̱n i na ônəm oga nnəm inunok.
\v 15 Uza̱ i ka̱m uzəng ka̱ apal agba̱pchi iga ìpirkur ká̱ iga ìba̱ngba̱ng wó i na ônəm oga mpyal wò ká̱ onəm oga nnəm inunok.
\v 16 Uza̱ i wur ozwal wó onunggwan ká̱ ochar, ká̱ ina\f + \fr 8.16 \fq ina \ft ka̱ ashe oga nsar nnap-nlà Inan nro te, á là pa̱ \fqa ovan nza̱m.\f* va ɓyen ji ká̱ oga azhaki wó, ka̱kul nnəm inunok.
\v 17 Uza̱ i ka̱m uzəng ka̱ apal agba̱pchi iga iya̱mkang wó, kang mmawó ká̱ ishi wó, ó tong ozuzwal.
\v 18 Awalang va̱ ta i ɓa i chu te, ó chal pa̱ mmá ka̱m ishi wó ka̱ atak aponzhi va̱ ta, ǹnyi te, uYawe i gwong achwang kà̱ wó n̂da va̱ ta ka̱t.>>
\p 
\v 19 Káp ka̱ nna te, onəm va̱ ta gwong achwang ka̱ uSamuwel ka̱t. Oza̱ là pa̱, <<O'o, í ɗom uponzhi pa̱ á nəm ká̱ yi,
\v 20 ka̱kul na í yà wa aɓoshi oga mbin. Í ɗom uponzhi pa̱ á nəm ká̱ yi, kang i ləp mpyal á yi ka̱ atak ìkum.>>
\p 
\v 21 Ka̱ nva̱ngva̱ uSamuwel fe nkpaktak iya̱m va̱ onəm là te, uza̱ là ûYawe iya̱m va̱ oza̱ là.
\v 22 Te uYawe là ûSamuwel pa̱, <<Nəm ôza̱ wa nva̱ oza̱ ɗom, kyer uponzhi ôza̱.>>
\p Te uSamuwel là oIsa̱rila pa̱, <<Udanggo á le nzhi wò.>>
\c 9
\s1 Mmá yak uShawulu uponzhi
\p 
\v 1 Unəm uga atak nsat uro uwa ka̱ yà ka̱ akum ìjili aBenjamin, aɗiɗin pa̱ uKish, uya aAbiyel, uya aZeror, uya aBekorat, uya aAfiya, uya aBenjamin.
\v 2 UKish uwa ká̱ uyen ununggwan aɗiɗin pa̱ uShawulu, uyenza̱m uro yà ɓyen ji na ka̱ ashe ovanza̱m oIsa̱rila ka̱t, kang uza̱ mak ji nkpaktak oIsa̱rila ká̱ ìrup ashar pa̱ zəng.
\p 
\v 3 N̂da nro te, oga azhaki aKish lar, te uza̱ là uyen wò uShawulu pa̱, <<Ga ká̱ ukpari mi uro na ó mwo oga azhaki va̱ ta.>>
\v 4 Te uShawulu ga nzəng ká̱ uzəngtəng ka̱ ashe okpari apupo, oza̱ kyén ga aɗuktum mbin aEfrayim, ká̱ mbin oShalisha te, oza̱ ya azhaki va̱ ta ka̱t. Oza̱ watar ga mbin aShayalim ká̱ nna te, oza̱ ya oga azhaki ka̱ ta ka̱t. Te oza̱ lyam ga ashe mbin aBenjamin, káp ka̱ nna te, oza̱ ya oga azhaki va̱ ta ka̱t.
\p 
\v 5 Nva̱ngva̱ oza̱ ɓa chu mbin aZup te, uShawulu là ûkpari va̱ ta pa̱, <<Re, í le nzhi ka̱kul kang upo mi a le á ya ka̱ nɗaktak ka̱ apal yi a ji oga azhaki va̱ ta ka̱t.>>
\p 
\v 6 Ǹnyi te, ukpari va̱ ta là á na pa̱, <<UNəm Inan uwa ka̱ ashe ìtong\f + \fr 9.6 \ft Mwote \fqa aRama.\f* va̱ ta̱ uva mmá na ichumchum á na byet, iya̱m va pa̱ kpaktak uza̱ i là te, i yə́l. Í ga atətak, mwote uza̱ a là á yi atak va̱ oga azhaki va̱ ta kà̱ nggo.>>
\p 
\v 7 Te uShawulu ɓəp ukpari wò va̱ ta pa̱, <<A yà pa̱ í ga atak anəm va̱ ta te, iza̱ í na á na yà? Ka̱kul nzəngkəng va̱ ka̱ ashe oga azhal yi te, á kúr chit, kang i yà ká̱ iya̱m va̱ pa̱ i na á na ka̱t. Mwote iya̱m iro nna yà ɗak ɓo?>>
\p 
\v 8 Ukpari va̱ ta na ama̱n á na kà̱ɗi pa̱, <<Dər, na n yà ká̱ azurfa pa̱ ɗa̱p, mi na ûnəm Inan va̱ ta, te uza̱ i nyám asa̱l va̱ á yi, í lyep kà̱.>>
\v 9 Kà̱ nra ngga nva̱ng te, ka̱ ashe mbin oIsa̱rila, unəm va̱ i ɗom pa̱ ó ga ó fe ka̱ atak Inan te, i là pa̱, <<Í ga atak anəm uga dər mpyal.>>Ka̱kul unəm va̱ mí wór pa̱ unəm uga nka̱m nre ka̱ atak Inan ǹyangmata̱ te, matmat te, mí wór pa̱ unəm uga dər mpyal.
\v 10 Te uShawulu là ukpari wò pa̱, <<Ichən va̱ ta̱ ɓyen byet, í ga.>> Te oza̱ kpan asa̱l aga ngga ashe ìtong va̱ unəm Inan va̱ ta kà̱.
\p 
\v 11 Nva̱ oza̱ kà̱ nkyén mɓa ngga aɗuktum ìtong va̱ ta te, oza̱ gwang ovanɓyen oro kà̱ nfa pa̱ na ó ga ó dàp ndəng, te oza̱ ɓəp oza̱ pa̱, <<Unəm va̱ i dər mpyal te, uwa ka̱ ta̱ ɗò?>>
\p 
\v 12 Ovanɓyen va̱ ta ma̱n pa̱, <<À, uwa yà, ó gha̱n, ó ga ǹyangmata̱, uwa kà̱ mpyal wó. Uwa tar ìtong yi nda ata̱, ka̱kul mmá kà̱ ngga nnəm nləfər ka̱ atak awop aga aɗuktum.
\v 13 Ka̱ ntar wó na byet te, ó ya na kang uza̱ i ga atak awop aga aɗuktum ka̱kul nrì iya̱m-nrì. Onəm i yà ká̱ nri iya̱m ka̱t, ya uza̱ i ɓa i pa̱r nləfər kang. Nna chit te, onəm va̱ mmá chal te, i ri iya̱m ɗak. Ó ga ǹyangmata̱, ó ya na ya ka̱ awalang a ta̱.>>
\p 
\v 14 Te oza̱ táng ga ashe ìtong va̱ ta, kang nva̱ oza̱ kà̱ ntáng te, oza̱ gwang uSamuwel kà̱ mɓa ka̱ asa̱l isu oza̱ kà̱ ngga atak awop aga aɗuktum.
\p 
\v 15 Kang uShawulu i ɓa te, uYawe ka̱ là nnap ûSamuwel chit pa̱,
\v 16 <<Ìpin ká̱ awalang wa nta̱, mi re nre a ɓu ká̱ unəm ka̱ ashe mbin aBenjamin. Gòr na á yà unəm uga mpyal oIsa̱rila, uza̱ i fa ká̱ onəm mi ka̱ ashe awo oFilisti. Ka̱kul n ya mɓək anung onəm mi chit, kang ayə́ng oza̱ ɓa chu atak mi chit.>>
\p 
\v 17 Awalang va̱ uSamuwel ya uShawulu te, uYawe là á na pa̱, <<Unəm va ta̱ ka̱ nlà nnənap a ɓu, uwa i nəm iponzhi ká̱ onəm mi.>>
\p 
\v 18 Te uShawulu ga atak aSamuwel ka̱ anung asa̱l ìtong kang uza̱ ɓəp na pa̱, <<Mmami ka̱ nchal ɓu, nzhi anəm uga ndər mpyal ka̱ che yà?>>
\p 
\v 19 USamuwel na ama̱n á na pa̱, <<Mmami na unəm uga ndər mpyal va̱. Watar mpyal na í ga atak awop, ka̱kul n̂da ata̱ ɓu ga nri iya̱m-nrì nzəng ká̱ mi. Kang ìpin ká̱ ìɓotak te, mi re ɓu na ú ga, kang mi là iya̱m va̱ a ɓu pa̱ kpaktak ka̱ ashe ìgwak ɓu.
\v 20 Kang á ɗak ɓu kà̱ nnap oga azhaki va̱ lár nra chit pa̱ nshatɗing nda ata̱ ka̱t, ka̱kul mmá ya oza̱ chit. Mmami ka̱ nlà a ɓu pa̱, mmaɓu ká̱ nzhi apo ɓu na nkpaktak oIsa̱rila kà̱ nnak ìgwak kà̱.>>
\p 
\v 21 UShawulu na ama̱n pa̱, <<Mmami ka̱ akum ìjili aBenjamin, akum va yen ji ka̱ ashe akum oIsa̱rila, kang ka̱ ashe akum aBenjamin te, mmami ka̱ ashe nzhi va yen ji ka̱ɗi lap. Te iza̱ nak kang ɓu là nnap á mi wa nva̱ ta̱ yà?>>
\p 
\v 22 Te uSamuwel ka̱m uShawulu ká̱ ukpari wò táng ká̱ ka̱ ashe nzhi mɓut, kang uza̱ nak oza̱ ka̱ atak ntəm kà̱ mpyal onəm va mmá chal, ova i chu ìsəm pa̱ ishatɗing chu.
\v 23 Kang uSamuwel là ûnəm uga pə́k iya̱m-nrì pa̱, <<Ɓa ká̱ ìzhe va̱ ka̱ n ná a ɓu, i va ka̱ nlà a ɓu pa̱, u nak pa̱ɗi á.>>
\p 
\v 24 Te unəm uga mpə́k iya̱m-nrì va̱ ta yar ìsong ìzhe ká̱ iya̱m va̱ ka̱ apəpal ɓa cher ka̱ mpyal aShawulu. Kang uSamuwel là á na pa̱, <<Ìzhe va ta̱ mmá nak á ɓu, ri, ka̱kul n nak m̂maɓu pa̱ na u ri, ka̱ awalang va̱ ka̱ nlà pa̱, <N chal onəmchən ká̱ á.> >> N̂da va̱ ta te, uShawulu ri iya̱m nzəng ká̱ uSamuwel.
\p 
\v 25 Ka̱ nva̱ngva̱ oza̱ fəng chit ka̱ atak awop aga aɗuktum kang à táng ashe ìtong te, uSamuwel là nnap ká̱ uShawulu ka̱ apal apal aga nzhi wò.
\v 26 Atak fa tan ká̱ ìpin te, uSamuwel wór uShawulu ka̱ apal apal aga nzhi, a là pa̱, <<Gbar izər, mmami kà̱ ngga nre ɓu na u kpan asa̱l.>>Nva̱ngva̱ uShawulu gbar izər chit, te uSamuwel fa ká̱ na ga re ka̱ apal asa̱l.
\v 27 Nva̱ oza̱ ga dat ká̱ nkur ìtong te, uSamuwel là ûShawulu pa̱, <<Là ûkpari ɓu pa̱ à gəga kang.>> Te ukparikpari ga. Nna chit te, uSamuwel là á na pa̱, <<Sat ka̱ ta̱, na n là nre Inan á ɓu.>>
\c 10
\s1 USamuwel gar uShawulu uponzhi
\p 
\v 1 Te uSamuwel yar afal mmì mpyet zuk uShawulu ká̱ ishi, uza̱ fəkchi na kang á là pa̱, <<Mmami ka̱ nnəm iya̱m va̱ ta̱ á ɓu ka̱kul uYawe gar ɓu chit pa̱ u yà uponzhi ka̱ apal iya̱mkup wò, oIsa̱rila.
\v 2 Nva̱ngva̱ ɓu re mi n̂da ata̱ te, ɓu gwang onəm pa̱ oparəm dat ka̱ awap aRahila ka̱ aZelza, ka̱ aswari mbin aBenjamin. Oza̱ i là a ɓu pa̱, <Oga azhaki va̱ mmá ya chit, kang upo ɓu kong ká̱ nnap oza̱ chit, ǹnyi te, uza̱ ká̱ nɗaktak ka̱ apal wó ǹyangmata̱. Uza̱ ka̱ mɓəp pa̱, <<Mi nəm sang ka̱ apal ayen mi yà?>> >
\p 
\v 3 <<Te ɓu ga mpyal ká̱ achen ɓu ga ɓu chu atak ìnang ìkun iga aTabor. Ka̱ ta te, ɓu gwang onəm pa̱ oshatɗing ova ka̱ ngga nnəm awop Înan ka̱ aBetel. Uro ká̱ ivan iɓəl pa̱ shatɗing, uro ká̱ nzəngkəng pa̱ nshatɗing, kang uga ushatɗing ká̱ ndəng ìba̱ngba̱ng ka̱ ashe ìza̱mɓar.
\v 4 Oza̱ i re anung a ɓu kang i yichi nzəngkəng a ɓu pa̱ mparəm, te ɓu ka̱m ka̱ oza̱.
\p 
\v 5 <<Ka̱ nvəva̱ng te, ɓu ga aGibeya Inan, atak va oshozha oFilisti ra apa̱k kà̱. Ɓu ga ɓu dat ká̱ ìtong te, ɓu gwang ìdonkong onəm oga nka̱m nre ka̱ atak Inan kà̱ nfəng ka̱ atak awop aga aɗuktum. Kà̱ mpyal oza̱ te, mmá ka̱ nnə́m aɓwa, ká̱ aɓwa acham, ká̱ ìganggáng, ká̱ mɓur ìzur, ká̱ ngba̱p nza̱m, kang oza̱ kà̱ nlà nre Inan.
\v 6 ARuhu aYawe i vàng ka̱ apal ɓu ká̱ ichumchum, te ɓu là nre Inan, kang ɓu ga̱ɓa̱n ɓu wal unəm ukak.
\v 7 Ka̱ nva̱ngva̱ oga iya̱m va̱ ta fa chit, te wa nəm iya̱m iva pa̱ kpaktak awo ɓu ya məma pa̱ u nəm, ka̱kul Inan ya yà nzəng ká̱ ɓu.
\p 
\v 8 <<Ga aGilgal kang mi ɓa. Mi ɓa mi ya ɓu ka̱ ta kang mi yichi nləfər ngga nshì pa̱ ɗwot ká̱ iya̱m inana iga ntəm ikángkáng. Ǹnyi te, nkpak pa̱ u lok ka̱ ta nra pa̱ nfangshat ya ɓa mi chu, mi nlà iya̱m va̱ a ɓu ɓu nəm kang.>>
\s1 Mmá kyer iponzhi ûShawulu
\p 
\v 9 Nva̱ngva̱ uShawulu ga̱ɓa̱n chit kà̱ ngga, te Inan ga̱ɓa̱n ìgugwak. Kang nkpaktak oga ǹnyám ipir nnap va̱ uSamuwel là te, á yə́l n̂da va ta.
\v 10 Awalang va̱ uShawulu ká̱ ukpari wò ɓa chu aGibeya te, ìdonkong onəm oga nka̱m nre ka̱ atak Inan ɓa gwang na, kang aRuhu Inan vàng ka̱ apal ishishi ká̱ ichumchum te, uza̱ gwang ishi ká̱ oza̱ ka̱ nlà nre Inan.
\v 11 Awalang va̱ nkpaktak onəm va̱ nyi na nyi kang a fe na kà̱ nlà nre Inan nzəng ka̱ onəm oga nka̱m nre ka̱ atak Inan te, oza̱ ɓəp owan oza̱ pa̱, <<Iza̱ ya uya aKish yà? UShawulu yà unəm uga nka̱m nre ka̱ atak Inan chit kpa ɗò?>>
\p 
\v 12 Unəm uro ka̱ ashe onəm oga atak va̱ ta na ama̱n pa̱, <<Uda upo oza̱ yà?>> Ka̱kul nva̱ ta te, á sat ngba nnap pa̱, <<UShawulu ka̱ ashe onəm oga nka̱m nre ka̱ atak Inan kpa ɗò?>>
\v 13 Nva̱ngva̱ uShawulu gba̱l ká̱ nlà nre Inan chit, te uza̱ kyen ga atak awop aga aɗuktum.
\p 
\v 14 UKyan aShawulu ɓəp na ká̱ ukparikpari pa̱, <<Ó ga che yà?>>
\p Te uza̱ là pa̱, <<Í ga mmwo oga azhaki. Kang nva̱ngva̱ í ya pa̱, i ya ka̱t, te í ga atak aSamuwel.>>
\p 
\v 15 Te uKyan aShawulu là pa̱, <<Là á mi iya̱m va̱ uSamuwel là á ɓu á.>>
\p 
\v 16 Kang uShawulu là ûkyan wò pa̱, <<Uza̱ là á yi pa̱ mmá ya oga azhaki va̱ chit.>>Ǹnyi te, uza̱ là iya̱m iro ûkyan wò ka̱ apal nnap iponzhi va̱ uSamuwel là á na ka̱t.
\p 
\v 17 USamuwel wór nkpaktak oIsa̱rila kà̱ mpyal aYawe ka̱ aMizpa,
\v 18 kang uza̱ là ôza̱ pa̱, <<Iya̱m va ta̱ uYawe, Inan oIsa̱rila là, <N fa ká̱ aIsa̱rila ka̱ ashe aMasar, kang n fa ká̱ wó ka̱ akum ichumchum aMasar ká̱ nkpaktak oga mbin va̱ nyán ká̱ wo á.>
\v 19 Ǹnyi te, ǹyangmata̱ ó yang ká̱ Inan wó chit, uva fa ká̱ wó ka̱ ashe nkpaktak mɓək anung ká̱ oga nɗaktak wó. Kang ó là pa̱, <Pa ka̱t, mmá kyer uponzhi á yi.> Ǹyangmata̱ te, ó ɓa mpyal aYawe, akum ká̱ akum, kang nzhi ká̱ nzhi.>>
\p 
\v 20 Awalang va̱ uSamuwel ɓa ká̱ nkpaktak akum ìjili oIsa̱rila kà̱ mpyal aYawe te, mmá yak akum ìjili aBenjamin ka̱ atak mmàng ayàk.
\v 21 Te uza̱ ɓa ká̱ akum ìjili aBenjamin nzhi ká̱ nzhi, kang ayàk ga ru ka̱ apal akum aMatiri. Kà̱ nkukur te, ayàk ga ru ûShawulu uya aKish. Ǹnyi te, oza̱ mwo na kang oza̱ ya na ka̱t.
\v 22 Te oza̱ ɓəp uYawe kà̱ɗi pa̱, <<Unəm va̱ ɓa chit ka̱ ta̱ ɗò?>>
\p Kang uYawe là pa̱, <<À, uwa bwam ka̱ ashe iya̱m iɓutɓut.>>
\p 
\v 23 Te oza̱ ga ɓa ka̱ na, kang nva̱ uza̱ sat ka̱ ìshimshe onəm te, uwa mak ji onəm pa̱ kpaktak ká̱ ìrup ashar pa̱ zəng.
\v 24 USamuwel là n̂gkpaktak onəm pa̱, <<Unəm va ta̱ uYawe yak pa̱ á yà uponzhi wó. Unəm uro yà wa njini ka̱ ashe nkpaktak onəm ka̱t.>>
\p Te nkpaktak onəm bà achu pa̱, <<Re irirì aponzhi á ganggáng.>>
\p 
\v 25 Te uSamuwel nyám ônəm apir inok va̱ uponzhi i nəm ká̱ iva̱ onəm i nəm ûponzhi. Kang uza̱ lir ka̱ apal awa achəndərchəndər, uza̱ nak kà̱ mpyal aYawe. Kang uSamuwel re onəm le nzhi oza̱ kà̱ɗi.
\p 
\v 26 UShawulu ga nzhi wò kpa ka̱ aGibeya, nzəng ká̱ onunggwan oga nkám ìgwak, ovəngva̱ Inan dok igwak oza̱.
\v 27 Ǹnyi te, onəm oro oga nɗom ntəm ikángkáng ka̱t là pa̱, <<Wa nsang kang unəm va̱ ta̱ i ka̱m ishi yi yà?>> Oza̱ ɓak na, kang oza̱ yang ká̱ ngga ká̱ imwa á na. Ká̱ nna te, uShawulu nak ishi ká̱ oza̱ ka̱t.
\c 11
\s1 UShawulu ri oAmmon ká̱ ìkum
\p 
\v 1 UNahash uponzhi uga aAmmon ɓa ru aJabesh Gileyat ká̱ ìkum. Kang nkpaktak onunggwan oga aJabesh là á na pa̱, <<Yar nsar nnap-nlà ká̱ yi, te í yà ozwal ɓu.>>
\p 
\v 2 Ǹnyi te, uNahash na ama̱n pa̱, <<Mi yar nsar nnap-nlà ká̱ wó ka̱ apal iya̱m va ta̱ na cwat pa̱, nza̱ unəm nggo te, mi tur ìwu iga awo ari á na, na á ta̱l iya̱m ìwuswa n̂gkpaktak oIsa̱rila.>>
\p 
\v 3 Te onəmgbak oga aJabesh là á na pa̱, <<Ná nra á yi pa̱ nfangshat na í re nre ká̱ onəm oga nre a ga ka̱ ashe nkpaktak aIsa̱rila kang. A yà pa̱, í ya unəm va̱ i ka̱mshi yi ka̱t, te í na ishi yi a ɓu.>>
\p 
\v 4 Awalang va̱ onəm oga nre va̱ ta ɓa chu aGibeya va uShawulu i təm kà̱ kang à là nnap va̱ ta ônəm te, nkpaktak onəm bà ayə́ng.
\v 5 UShawulu kà̱ nle ka̱ atak nshàng ìram ká̱ ina na byet, te uza̱ ɓəp pa̱, <<Iza̱ i ɗak onəm yà? Sang kang mí bà ayə́ng wa nta̱ yà?>> Te oza̱ là á na iya̱m va̱ onəm oga aJabesh là.
\p 
\v 6 Awalang va̱ uShawulu fe nnap-nlà va̱ ta te, aRuhu Inan vàng ka̱ apal ishishi ká̱ ichumchum, kang ìgwak lak na pa̱ gənggəng.
\v 7 Uza̱ wur ina pa̱ iparəm pà, nyat izhizhe pa̱ nyimənyimən, kang a re onəm oga nre ká̱ pa̱ á ga ká̱ ka̱ ashe nkpaktak oIsa̱rila, oza̱ á là pa̱, <<Iya̱m va ta̱ mí nəm ká̱ ina ánəm va̱ yang ká̱ nyar nva̱ng aShawulu ká̱ uSamuwel ka̱ atak ìkum.>> Te ayər aYawe fər ka̱ apal ishi onəm kang oza̱ fa wa anəm pa̱ uzəng.
\v 8 Awalang va̱ uShawulu ɓut oza̱ ka̱ aBezek, kang uza̱ kung onəm te, uza̱ ya onunggwan oga aIsa̱rila ìkalong ìgba̱l pa̱ ishatɗing, kang ovəngva̱ ka̱ aYahudi ìkalong ìsəm pa̱ ishatɗing.
\p 
\v 9 Oza̱ là ônəm oga nre va̱ mmá re ɓa pa̱, <<Ó là ônunggwan oga aJabesh Gileyat,<Ìpin, awalang va̱ alum i chu apal ndəng chit, te mí ka̱m ishi wó.> >> Nva̱ngva̱ onəm oga nre va̱ ta ga là ônunggwan oga aJabesh chit, te ìgwak chàng oza̱ pa̱ gənggəng.
\v 10 Oza̱ là ôAmmon pa̱, <<Ìpin te, í ga nna ishi yi á wó, na ó nəm iya̱m va pa̱ káp ó ɗom nəm ka̱ yi.>>
\p 
\v 11 Ká̱ ìzwam te, uShawulu kap onunggwan ìdonkong pa̱ ishatɗing. Kang ká̱ ìɓotak oza̱ ɓa táng ashe apa̱k oAmmon, kang à gbá̱ng oza̱ ga chu alum ka̱ apal ndəng. Ovəngva̱ lár te, oza̱ lyangshin, ɓu yà ká̱ ǹya onəm pa̱ oparəm ka̱ atak azəngtəng ka̱t.
\s1 Iponzhi aShawulu təm
\p 
\v 12 Te onəm là ûSamuwel pa̱, <<Oda va̱ ka̱ là pa̱, <UShawulu i nəm iponzhi ka̱ apal yi ka̱t> yà? Mmá ɓa ká̱ oza̱ á yi na í gbá̱ng oza̱.>>
\p 
\v 13 Ǹnyi te, uShawulu là pa̱, <<Mí yà ká̱ ngba̱l unəm uro n̂da ata̱ ka̱t, ka̱kul n̂da ta̱ uYawe ɓa ká̱ nka̱m ishi ngga irirì ôIsa̱rila chit.>>
\p 
\v 14 Te uSamuwel là ônəm pa̱, <<Ó ɓa, re í ga aGilgal na í nyám ká̱ iponzhiponzhi kà̱ɗi.>>
\v 15 Te nkpaktak onəm ɓa ga aGilgal, kang à kyer uShawulu kà̱ mpyal aYawe təm uponzhi. Ka̱ ta te, oza̱ yichi iya̱m inana iga ntəm ikángkáng ûYawe, kang uShawulu ká̱ nkpaktak oIsa̱rila nəm nchàng izər pa̱ gənggəng.
\c 12
\s1 USamuwel là nnap ngga nkur anung
\p 
\v 1 Te uSamuwel là n̂kpaktak oIsa̱rila pa̱, <<N gwong achwang chit kà̱ nkpaktak iya̱m va̱ ó là á mi, kang n na uponzhi á wó chit pa̱ á nəm ká̱ wó.
\v 2 Ǹyangmata̱ te, na ó yà ká̱ uponzhi, uwa unəm uga mpyal wó. Mmami te, n gbák chit, kang izwál fa á mi chit, ǹnyi te, ovan mi onunggwan oma yà nzəng ká̱ wó. M ɓàn nlə́p mpyal a wó, ya na ka̱ n yà uyenza̱m á ɓa chu n̂da va̱ ta̱.
\v 3 Mmami na ta̱, ó nyám ká̱ iya̱m va̱ á mi n nəm ɓa̱ng ka̱ mpyal aYawe ká̱ ugargargargar. ÌNa ada n vyat yà? AZhaki áda n vyat yà? Uda n ka̱r na yà? Uda m mwar na yà? N ka̱m iya̱m ka̱ atak áda pa̱ na ń ka̱r nnandər ká̱ yà? A yà pa̱ n nəm iya̱m iro nəm ka̱ ashe oga iya̱m va̱ ta̱ te, mi mwa anunung.>>
\p 
\v 4 Oza̱ na ama̱n pa̱, <<U m mwar yi ka̱t, ka̱t te u ka̱r yi ka̱t. U ka̱m iya̱m iro kà̱ unəm uro pa̱ na ú ka̱r nnandər ká̱ ka̱t.>>
\p 
\v 5 Te uSamuwel là ôza̱ pa̱, << UYawe uwa kà̱ ǹya wó, kang ugargargargar uwa ka̱ ǹya wó nda va̱ ta̱ kpa, pa̱ ó ya iya̱m iro ka̱ awo mi ka̱t.>>
\p Kang oza̱ là pa̱, <<Uza̱ uwa ka̱ ǹya.>>
\p 
\v 6 Te uSamuwel là ônəm pa̱, <<UYawe uwa yak uMusa ká̱ uHaruna kang à fa ká̱ okəka wó ka̱ ashe mbin aMasar.
\v 7 Ǹyangmata̱ te, ó tong pa̱ kwak, mmami kà̱ ngga ń rəng ká̱ a wó ka̱ mpyal aYawe, oga nnap-nnəna̱n ngga nka̱m ishi va̱ uYawe nəm ka̱kul wó ká̱ okəka wó á.
\p 
\v 8 <<Awalang va̱ uYakup wa ka̱ aMasar te, oza̱ yar ayə́ng ûYawe ka̱kul nka̱m ishi. Kang uYawe re nre ká̱ uMusa ká̱ uHaruna, ova fa ká̱ okəka wó ka̱ ashe aMasar, kang á nak oza̱ təm kà̱ mbin va̱ ta̱.
\v 9 Ǹnyi te, oza̱ kong ká̱ uYawe, Inan oza̱. Kang uYawe yap ká̱ oza̱ ka̱ ashe awo aSisəra, unəm uga mpyal oshozha oga aHazor, kang ka̱ ashe awo oFilisti, ká̱ uponzhi uga aMowap, ova lung oza̱.
\p 
\v 10 <<Te oza̱ yə́ng ûYawe kang à là pa̱, <Í nəm nnap-mɓá̱ngɓa̱ng chit, ka̱kul í re ngwop uYawe chit, í wop oga aBaal ká̱ oga aAshtoret. Ǹnyi te, ǹyangmata̱, ka̱m ishi yi ka̱ ashe awo okpa ìkum yi, te í le í wop ɓu.>
\v 11 Te uYawe re nre ká̱ uJerup-Baal, ká̱ uBarak, ká̱ uJepta, ká̱ uSamuwel, kang uza̱ ka̱m ishi wó ka̱ ashe awo okpa ìkum wó kà̱ nza̱ ngba̱k nggo, kang ó təm ká̱ ikángkáng.
\p 
\v 12 <<Ǹnyi te, awalang va̱ ó ya uNahash uponzhi oAmmon kà̱ mɓa ka̱ apal wó, te ó là á mi pa̱, <Pa ka̱t, í ɗom uponzhi pa̱ á nəm iponzhi ka̱ apal yi,> káp ká̱ nva̱ pa̱, uYawe, Inan wó uwa uponzhi wó á.
\v 13 Ǹyangmata̱, ó dər uponzhi va̱ ó yak, uva ó ɓəp pa̱ mmá na wó, te uYawe na á wó chit.
\v 14 A yà pa̱ ó nəm ayər aYawe, ó wop na, ó kpak nnap-nnəm á na, ó yáng nkpak nnap-mpakpakpakpak ka̱t, kang a yà pa̱ mmawó ká̱ uponzhi va̱ i nəm ká̱ wó, ó le ó yar nva̱ng aYawe, Inan wó, te ó təm ká̱ ikángkáng.
\v 15 Ǹnyi te, a yà pa̱ ó kpak nnap-nnəm ûYawe ka̱t, kang a yà pa̱ ó fa iya̱mkak ka̱ apal oga nnap-mpakpakpakpak, te uza̱ i nyám ntàn á wó wa nva̱ uza̱ ka̱ nyám ôkəka wó á.
\p 
\v 16 <<Ǹyangmata̱ te, ó tong pa̱ kwak, na ó ya iya̱m ichumchum va̱ uYawe kà̱ ngga nnənəm kà̱ mpyal wó.
\v 17 Ǹyangmata̱, awalang aga nkpám ìbəshi ka̱t ɗò? Mi ngga nfar ûYawe pa̱, á re nre ká̱ ìva̱r ká̱ ìgbarman. Te ó nyi iya̱m inga va̱ ó nəm kà̱ mpyal aYawe, nva̱ ó ɓəp pa̱ mmá na uponzhi a wó á.>>
\p 
\v 18 Te uSamuwel far ûYawe, kang uYawe re nre ká̱ ìva̱r ká̱ ìgbarman n̂da nva̱ ta. Kang nkpaktak onəm tong nəm ayər aYawe ká̱ uSamuwel.
\p 
\v 19 Te oza̱ là ûSamuwel pa̱, <<Far ûYawe, Inan ɓu ka̱kul yi, le kang í kú ka̱t. Í nəm nnap-mɓá̱ngɓa̱ng á na chit pa̱ makmak, kang ǹyangmata̱, í nəm á na chit kà̱ɗi ka̱ atak mɓəp uponzhi.>>
\p 
\v 20 USamuwel là ônəm pa̱, <<Kang ayər a nəm wó ka̱t. Káp ká̱ nva̱ pa̱ ó nəm nnap-mɓá̱ngɓa̱ng chit, ka̱ nna te, kang ó ga̱ɓa̱n ó re uYawe ka̱t. Ka̱kul nva̱ ta te, ó wop uYawe ká̱ nkpaktak ìgwak wó.
\v 21 Kang ó ga̱ɓa̱n ó wop ichər iya̱m ilakchilakchi ka̱t. Oza̱ yà ká̱ nka̱mshi ka̱t, le kang oza̱ i fa ká̱ wó, ka̱kul oza̱ iya̱m ilakchilakchi.
\v 22 Ka̱kul aɗin aYawe achumchum te, uza̱ i yà ká̱ ǹyang ká̱ onəm wò ka̱t. Ka̱kul uYawe uwa ya ma pa̱ ô yak wó, ó yà onəm wò.
\v 23 Mmami nnyi te, mi yà ká̱ nnəm nnap-mɓá̱ngba̱ng uYawe ka̱ atak nre nfar afar ka̱kul wó ka̱t, kang mi ɗyang asa̱l anəna̱n a wó aga nnəm nnandər.
\v 24 Ǹnyi te, ó nəm ayər aYawe, ó wop na ká̱ nnandər ká̱ nkpaktak ìgwak wó. Ó rəng oga iya̱m ichumchum va̱ uza̱ nəm ka̱kul wó á.
\v 25 Kang a yà pa̱ ó ga mpyal ká̱ nnəm nnap-mɓá̱ngɓa̱ng, te mmawó ká̱ uponzhi wó ó zhì.>>
\c 13
\s1 USamuwel ra̱n ká̱ uShawulu
\p 
\v 1 UShawulu ri iponzhi ya uwa yà ká̱ izun ìsəm pa̱ ishatɗing, kang uza̱ nəm iponzhi ka̱ apal oIsa̱rila ìzun ìsəm pa̱ ineɗing ama̱n pa̱ parəm.
\p 
\v 2 UShawulu yak onunggwan ìkalong pa̱ ishatɗing ka̱ ashe oIsa̱rila. Uza̱ nak ìkalong pa̱ ìparəm nzəng ká̱ na ka̱ aMikmat ká̱ mbin aɗuktum aga aBetel, kang ìkalong pa̱ ìzəng nzəng ká̱ uJonatan ka̱ aGibeya kà̱ mbin aBenjamin. Te uza̱ re aɓo onunggwan le nzhi oza̱.
\p 
\v 3 UJonatan ru ìdonkong oshozha oFilisti ká̱ ìkum ka̱ apa̱k oza̱ ka̱ aGeba, kang oFilisti fe nnap va̱ ta. Te uShawulu nak mmá ɓur agbəshi ka̱ ashe nkpaktak mbin oIsa̱rila, kang à là pa̱, <<Re oHiburu á fe.>>
\v 4 Te nkpaktak oIsa̱rila fe nnap va̱ ta pa̱, <<UShawulu ru ìdonkong oshozha oFilisti chit ká̱ ìkum, kang ǹyangmata̱ te, oIsa̱rila sat onəm oga ajan chit ka̱ mpyal oFilisti.>> Te mmá wor onəm ɓut pa̱ á gwang uShawulu ka̱ aGilgal.
\p 
\v 5 OFilisti ɓut pa̱ na ó lung oIsa̱rila, ká̱ oga akeke ipəri ìkalong ìsəm pa̱ ishatɗing, ká̱ onəm oga nkwak ipəri ìkalong pa̱ ìkpa̱ɗing, ká̱ oshozha yə́l yà ká̱ nkung ka̱t. Oza̱ ga ra apa̱k ka̱ aMikmat ka̱ asa̱l nfa alum aBet Aven.\f + \fr 13.5 \fq aBet Aven \ft Aɗin \fqa aBetel \ft akak.\f*
\v 6 Awalang va̱ oIsa̱rila ya pa̱ ìkum sur chit, kang okpa ìkum kà̱ nlung oza̱ pa̱ gənggəng, te oza̱ bwam ka̱ ashe oga agba̱k, ká̱ ipəpa, ká̱ ishimshe ipang, ká̱ oga ache, kang ká̱ oga ache ndəng nka̱pka̱p.
\v 7 Oro ka̱ ashe oza̱ pa̱ng awang aUrdun, ga mbin aGat ká̱ aGileyat.
\p Ǹnyi te, uShawulu ta̱l ka̱ aGilgal, kang nkpaktak onəm va̱ ká̱ na ka̱ ntán ká̱ ayər.
\v 8 Uza̱ lok ka̱ aGilgal nra pa̱ nfangshat pa̱ ô gwang ká̱ uSamuwel, wa nva uSamuwel ka̱ là á na, ǹnyi te, uSamuwel ɓa ka̱t, kang onəm aShawulu ɓàn nlyangshin.
\v 9 Te uShawulu là pa̱, <<Mmá ɓa ká̱ iya̱m inana iga nshì pa̱ ɗwot, ká̱ iga ntəm ikángkáng á mi.>> Kang uShawulu yichi nləfər ngga nshì.
\v 10 UShawulu kà̱ ngba̱l ká̱ ǹyichi iya̱m inana iga nshì va̱ ta byet, te uSamuwel ɓa chu, kang uShawulu fa pa̱ ô gwang na, ô re anung á na.
\p 
\v 11 Te uSamuwel ɓəp na pa̱, <<Iza̱ u nəm ta̱ yà?>>
\p UShawulu na ama̱n pa̱, <<N ya onunggwan kà̱ nlyangshin, kang nna ka̱ u ɓa chit ka̱t, ka̱ awalang va̱ u nak á, kang oFilisti oma ɓut ka̱ aMikmat.
\v 12 Te n rəng pa̱, <OFilisti iga nru mi ká̱ ìkum ǹyangmata̱ ka̱ aGilgal, kang nna ka̱ n chal uYawe chit ka̱kul nka̱mshi ka̱t.> Te n ya məma pa̱ ń yichi nləfər.>>
\p 
\v 13 USamuwel là pa̱, <<U nəm mpərək. U kpak nnap-nlà aYawe, Inan ɓu nva̱ uza̱ na a ɓu ka̱t. Ká̱ yà pa̱ u kpəkpak te, uYawe ká̱ pak akum iponzhi ɓu ka̱ apal oIsa̱rila mbyet.
\v 14 Te ǹyangmata̱ akum iponzhi ɓu i təm mbyet lap ka̱t, ka̱kul uYawe yak unəm chit uva ɗom ìgugwak. Uza̱ kyer na chit pa̱ á yà unəm uga mpyal onəm wò, ka̱kul u kpak nnap-mpakpak aYawe ka̱t.>>
\p 
\v 15 Te uSamuwel wong re aGilgal ga aGibeya kà̱ mbin aBenjamin. Kang uShawulu kung aɓo oshozha va̱ nzəng ká̱ na te, uza̱ ya ìgba̱l pa̱ ìkpa̱ɗing.
\s1 OIsa̱rila yà ká̱ iya̱m ìkum ka̱t
\p 
\v 16 UShawulu ká̱ uyen wò, uJonatan ká̱ oshozha va̱ nzəng ká̱ oza̱ ka̱ yà ka̱ ntəm ka̱ aGeba ka̱ ashe mbin aBenjamin, ǹnyi te, oFilisti ra apa̱k oza̱ ka̱ aMikmat.
\v 17 Oshozha oFilisti fa ka̱ ashe apa̱k, kap ìdonkong pa̱ ishatɗing. Ìdonkong iga ìzəng ga asa̱l mpal aOfəra ka̱ ashe mbin aShuwal,
\v 18 ìdonkong iga ìparəm ga asa̱l aBet Horon, kang ìdonkong iga ishatɗing ga asa̱l ìsu aswari va̱ dər asa̱l mba̱nda̱m aZeboyim ava dər ashe nzam.
\p 
\v 19 Onəm oga nla ala yà ka̱ ashe mbin oIsa̱rila ka̱t, ka̱kul oFilisti là pa̱ <<Kang oHiburu a la oga ndokchi ká̱ oga aɓár ka̱kul ishi oza̱ ka̱t.>>
\v 20 A nak te, nkpaktak oIsa̱rila i ga atak onəm oga nla ala oFilisti ka̱kul ntan anung oga ashan, aɗyə̀r, ikù, ká̱ ika oza̱.
\v 21 Amwa ka̱kul ntan anung ashan ina ka̱t te aɗyə̀r te, uparəm ka̱ apal ashatɗing ashekel, kang ka̱kul ikù ka̱t te iya̱m iga mɓak ina oza̱ te, uzəng ka̱ apal ashatɗing ashekel.
\p 
\v 22 N̂da va̱ ìkum wong te, mmá ya unəm uro ka̱ ashe oIsa̱rila ká̱ ndokchi ka̱t te, ká̱ aɓár ka̱t, uShawulu ká̱ uJonatan, oma ká̱ byet.
\s1 UJonatan ru oFilisti ká̱ ìkum
\p 
\v 23 Te oFilisti re nre ká̱ ìdonkong oshozha pa̱ á pángchí asa̱l aga ntar aMikmat.
\c 14
\p 
\v 1 N̂da nro te, uJonatan uya aShawulu là ûkpari wò uga yar iya̱m ìkukum pa̱, <<Ɓa, í pa̱ng mba̱nda̱m í ga apa̱k oFilisti.>> Ǹnyi te, uza̱ là ûpo wò ka̱t.
\p 
\v 2 UShawulu ká̱ onunggwan wò ìgba̱l pa̱ ìkpa̱ɗing oma ká̱ nra apa̱k ká̱ nkur aGibiya ka̱ avəng ìkun ìkúmkúm ka̱ aMigron.
\v 3 Ka̱ ashe onunggwan aShawulu te, uAhija unəm uga mpyal awop uwa yà ka̱ ashe oza̱, uva pa ìlukwan ìkwoksok. UAhija uya aAhitup, ugənang aIkabot, uya aFinehas, uka aEli, unəm uga mpyal awop ka̱ aShilo. UNəm uro yà nyi pa̱ uJonatan re ashe oIsa̱rila chit ka̱t.
\p 
\v 4 Asa̱l va̱ uJonatan ɗom n wòl kà̱ kang o ga atak apa̱k oFilisti te, kà̱ ishimshe aɓam pa̱ parəm ava unəm uro i chu nkyen kà̱ oga ngba̱k oza̱ ka̱t. Aɓam aro mí wór pa̱ aBozet, kang azəngtəng mí wór pa̱ aSene.
\v 5 Aro ka̱ asa̱l mpal a dər aMikmat, kang aro ka̱ asa̱l nkwandal a dər aGeba.
\p 
\v 6 UJonatan là ûnəm uga ǹyar iya̱m ìkum á na pa̱, <<Ɓa, í pa̱ng atak apa̱k onəm oga ache amulur va̱ ta̱. Mwote, uYawe a na igwan a yi nggo. Iya̱m iro yà i gəl uYawe kà̱ nna ìgwan ka̱ atak onəm ìkum pa̱ kyák ka̱t te pa̱ ɗa̱p ka̱t.>>
\p 
\v 7 Te unəm uga ǹyar iya̱m ìkum á na là pa̱, <<Nəm iya̱m va u ya məma á, nna n yà nzəng ká̱ ɓu ka̱ ashe iya̱m va̱ u ɗom nnənəm.>>
\p 
\v 8 UJonatan là á na pa̱, <<Ɓa na í pa̱ng na oza̱ á ya yi.
\v 9 A yà pa̱ oza̱ là á yi pa̱ í tong ka̱ atak va̱ mmayi kà̱, kang ô ɓa ô ya yi te, í tong í yà ká̱ ngga atak oza̱ ka̱t.
\v 10 Ǹnyi te, a yà pa̱ oza̱ là pa̱ ì ɓa atak oza̱ te, í kyen í ga. Nna ta i nyám pa̱ uYawe i ga nka̱mshi yi, í nəm igwan ká̱ oza̱.>>
\p 
\v 11 Nna chit te, mparəm oza̱ fa nyám ishi oza̱ ôFilisti. OFilisti là pa̱, <<Dər, oHiburu ka̱ nnár i fa ka̱ ashe ache atak va̱ oza̱ bwam kà̱.>>
\v 12 Te onəm ka̱ ashe apa̱k wór uJonatan ká̱ unəm uga ǹyar iya̱m ìkum á na pa̱, <<Ó ɓa, na í ɗyang ntan a wó.>>
\p UJonatan là ûnəm uga ǹyar iya̱m ìkum wò pa̱, <<Kyen, yar nva̱ng mi, ka̱kul uYawe na oza̱ chit ka̱ ashe awo oIsa̱rila.>>
\v 13 Te uJonatan kyen aɓam va̱ ta i nár ká̱ irəng ká̱ awo, ká̱ unəm uga ǹyar iya̱m ikum á na. Te oFilisti tak kà̱ mpyal aJonatan kang unəm uga ǹyar iya̱m ikum á na, yar nvəva̱ng gbá̱ng oza̱.
\v 14 Onunggwan va̱ uJonatan ká̱ unəm uga ǹyar iya̱m ìkum á na gbá̱ng nggəshi te, á chu ìsəm pa̱ ìparəm chu ka̱ ashe agbagba va á chu nshang iram ina chu ilum pa̱ ìzəng.
\s1 OIsa̱rila nəm igwan ká̱ oFilisti
\p 
\v 15 Te ayər nəm nkpaktak oshozha, ovəngva̱ ka̱ ashe apa̱k ká̱ ovəngva̱ ka̱ agbagba ìkum, káp ká̱ oshozha oga mpángchí atak ká̱ oga nlə́p mpyal ìkum, kang mbin tan. Inan uwa nak ayər va̱ ta.
\p 
\v 16 Oshozha oga mpángchí atak aShawulu ka̱ aGibeya aga mbin aBenjamin, ya oshozha oFilisti zwar kang ka̱ nlyangshin.
\v 17 Te uShawulu là ônunggwan wò pa̱, <<Ó kung oshozha na ó nyi unəm va̱ yà ka̱t.>> Nva̱ngva̱ oza̱ kung te, oza̱ ya uJonatan ká̱ unəm uga ǹyar iya̱m ìkum á na yà ka̱t.
\p 
\v 18 UShawulu là ûAhija pa̱, <<Ɓa ka̱ akwati aga nsar nnap-nlà Inan ka̱ ta̱.>> Ka̱ awalang va̱ ta te, akwati aga nsar nnap-nlà Inan nna ka̱ yà nzəng ká̱ oIsa̱rila.
\v 19 Nva̱ uShawulu ka̱ yà ka̱ nlà nnap ká̱ unəm uga mpyal awop te, nzwar ka̱ ngga mpyal ka̱ ashe apa̱k oFilisti. Te uShawulu là ûnəm uga mpyal awop pa̱, <<Kang á ɗak ɓu ka̱t, í ga.>>
\p 
\v 20 Te uShawulu ká̱ nkpaktak onunggwan wò ɓut kang à ga atak ìkum. Kang oza̱ ga ya oFilisti zwar chit pa̱ makmak, le í gbá̱ng owan oza̱ ká̱ ndokchi.
\v 21 OHiburu va̱ ka̱ yà nzəng ká̱ oFilisti kang a ga nzəng ká̱ oza̱ ka̱ apa̱k oza̱ te, á le ga atak oIsa̱rila va̱ ka̱ yà nzəng ká̱ aShawulu ká̱ uJonatan á.
\p 
\v 22 Awalang va̱ nkpaktak oIsa̱rila va̱ ka̱ bwam ka̱ ashe aɗuktum aga mbin aEfrayim fe pa̱ oFilisti kà̱ nchəng te, oza̱ fa gwang ɓak oza̱ ká̱ ìkum kpa.
\p 
\v 23 Te uYawe ka̱m ishi oIsa̱rila n̂da va̱ ta, kang onəm lung ìkum ga watar aBet-Aven.
\s1 UJonatan ri mmàl irizhe
\p 
\v 24 Ǹyangmata̱ te, oshozha oIsa̱rila bəlak byet n̂da va̱ ta, ka̱kul uShawulu ka̱ yar nsóng anung chit pa̱, <<Unəm va̱ a ri iya̱m-nrì kang arurong i nəm te, re Inan á vyap na, ya mi pyat nnàp ka̱ apal oFilisti kang.>> Te unəm uro yà ri iya̱m iro n̂da va̱ ta ka̱t.
\v 25 Nkpaktak oshozha táng ashe ikun te, oza̱ ya mmàl irizhe kà̱ mbin.
\p 
\v 26 Awalang va̱ oza̱ táng ashe ikun te, oza̱ ya mmàl irizhe kà̱ nwàr, ǹnyi te, unəm uro yà dok ká̱ ifang ga ká̱ ka̱ anung wò ka̱t. Ka̱kul oza̱ nəm á yər nsóng anung va.
\p 
\v 27 Ǹnyi te, uJonatan uwa ka̱ fe chit pa̱ upo wò sóng anung chit ka̱t, te uza̱ pa ishi idari va ká̱ awuwo ka̱ ashe mmàl irizhe. Te uza̱ nak ka̱ awo wò tam, kang uza̱ ya ìkam.
\v 28 Te uro ka̱ ashe oshozha là ûJonatan pa̱, <<Upo ɓu ka̱ sóng anung oshozha chit kəkam pa̱, <Unəm va̱ i ri iya̱m-nrì n̂da ta̱ te, i vyap.> Nna nak te, onunggwan bəlak á yà ká̱ ikam ka̱t.>>
\p 
\v 29 Te uJonatan là pa̱, <<Upo mi ɓa kà̱ nɗaktak chit ka̱ ashe mbin. Dər asa̱l awu va̱ n ya ìkam ká̱, nvəngva̱ n dok irizhe va̱ ta̱ pa̱ ɗa̱p á.
\v 30 Ka̱ yà pa̱ mmá ká̱ məma̱n ôshozha pa̱ á ri iya̱m-nrì va̱ oza̱ wur ka̱ atak okpa ìkum oza̱ te, mmá ka̱ gbá̱ng oFilisti ka̱ ji va̱ ta̱ ji ka̱t ɗò?>>
\p 
\v 31 N̂da va̱ ta, nva̱ngva̱ oIsa̱rila ɓàn gbá̱ng oFilisti ka̱ aMikmat ga chu aAijalon te, oza̱ bəlak pa̱ gənggəng.
\v 32 Oza̱ gba̱ng izər ka̱ ngwur iya̱m iga ngwur ka̱ atak ìkum, itam, ina, ká̱ ivan ina, kang oza̱ pà oza̱ ri ká̱ nchə̀chər.
\v 33 Te unəm uro là ûShawulu pa̱, <<Dər, onunggwan kà̱ nəm nnap-mɓá̱ngɓa̱ng ûYawe ka̱ atak nri izhé va ka̱ nchə̀r.>>
\p UShawulu là pa̱, <<Ó vyap nnap-mpakpak chit. Ó ɓəndəng ìnang ìpang á mi ka̱ ta̱.>>
\v 34 Te uza̱ là pa̱, <<Ó ga ó là ônunggwan pa̱, <Udanggo á ɓa ká̱ ìna wò ká̱ ìtam wò á mi, kang ó pà oza̱ ka̱ ta̱ ó ri. Kang ó nəm mpat ûYawe ka̱ atak nri izhé kà̱ nchə̀chər ka̱t.> >>
\p Te udanggo ɓa ká̱ ìna wò ká̱ izwam va̱ ta kang à pà ka̱ ta.
\v 35 Te uShawulu me atak nshi iya̱m awop ûYawe, nna ta, atak awop aga nggəshi va̱ uza̱ me.
\v 36 Te uShawulu là pa̱, <<Í fəng í ga na í ɓak oFilisti ká̱ izwam va̱ ta̱, í wur iya̱m oza̱ kang atak ì tan, kang í gbá̱ng oza̱, í re unəm uro ka̱ irirì ka̱t.>>
\p Te oza̱ là pa̱, <<Nəm iya̱m va u ya məmal ká̱ ɓu.>>
\p Ǹnyi te, unəm uga mpyal awop là pa̱, <<Re í ɓəp Inan kang.>>
\p 
\v 37 Te uShawulu ɓəp Inan pa̱, <<N ru oFilisti va̱ ta̱ ɗò? Ɓu na oza̱ na ka̱ ashe awo oIsa̱rila ɗò?>> Ǹnyi te, Inan na ama̱n a na n̂da va̱ ta ka̱t.
\p 
\v 38 Ka̱kul nva̱ ta te, uShawulu là pa̱, <<Ó ɓa ka̱ ta̱, nkpaktak onəm oga mpyal oshozha, re í mwo nnap-mɓá̱ngɓa̱ng va̱ mmá nəm chit n̂da va̱ ta̱.
\v 39 Wa nva uYawe uga nka̱mshi oIsa̱rila wa ya te, n sóng anung ká̱ aɗiɗin, kang a yà pa̱ uyen mi uJonatan uwa nəm mpat va̱ ta̱ te, nkpak uza̱ i kú.>>Ǹnyi te, ushozha uro yà na ama̱n á na ka̱t.
\p 
\v 40 Te uShawulu là n̂kpaktak oIsa̱rila pa̱, <<Ó tong ka̱ ngba̱k pa̱ nzəng, kang mmami ká̱ uJonatan i tong ka̱ ngba̱k nro.>>
\p Kang oza̱ là á na pa̱, <<Nəm iya̱m va̱ u ya məmal ká̱ ɓu á.>>
\p 
\v 41 Te uShawulu far ûYawe, Inan oIsa̱rila pa̱, <<Iza̱ nak kang u na ama̱n ûzwal ɓu ká̱ n̂da a ta̱ ka̱t yà? A yà pa̱ mpat kà̱ mmami ka̱t te uyen mi uJonatan te, wa ama̱n ká̱ aUrim ǹnyi te, a yà pa̱ onunggwan oga aIsa̱rila oma ká̱ mpat te, wa ama̱n ká̱ aTumim.\f + \fr 14.41 \ft Dər aLev 8:8.\f*>> Kang oza̱ mang ayàk te, ayàk ru ká̱ apal aJonatan ká̱ uShawulu, kang onungwan va̱ ta mmá ya oza̱ ká̱ mpat ka̱t.
\p 
\v 42 UShawulu là pa̱, <<Ó mang ayàk ká̱ ishimshe mi ká̱ uyen mi, uJonatan.>> Kang ayàk ga yar uJonatan.
\p 
\v 43 Te uShawulu là ûJonatan pa̱, <<Là á mi, iza̱ u nəm yà?>>
\p Kang uJonatan là á na pa̱, << N dok mmàl irizhe ká̱ ishi idari mi kang n tàm. Te ǹyangmata̱ nkpak pa̱ ń kú.>>
\p 
\v 44 UShawulu là pa̱, << Re uYawe á ɓək anung á mi pa̱ gənggəng, a yà pa̱ u kú ka̱t á, aJonatan.>>
\p 
\v 45 Ǹnyi te, onunggwan va̱ ta là ûShawulu pa̱, <<A màl pa̱ uJonatan a kúkú á, uza̱ va ɓa ká̱ nnang nka̱mshi ôIsa̱rila ɗò? Nva̱ ta i yà ka̱ nnəm ka̱t. Wa nva uYawe wa ya te, akpap ishishi aro pa̱ zəng i ru ka̱ mbin ka̱t, ka̱kul Inan a ka̱mshi á na kang uza̱ nəm igwan va̱ ta̱ n̂da va̱ ta̱.>> Te onunggwan va̱ ta ka̱m ishi aJonatan, kang mmá gbá̱l na ka̱t.
\p 
\v 46 Te uShawulu re mɓàk oFilisti, kang oFilisti le nva̱ng ga mbin oza̱.
\p 
\v 47 Nva̱ngva̱ uShawulu yà uponzhi oIsa̱rila te, uza̱ lung nkpaktak okpa ìkum oza̱ ka̱ nza̱ nggba̱k nggo, oMowap, ká̱ oAmmon, ká̱ oEdom, ká̱ oponzhi oga aZobak, kang ká̱ oFilisti. Kang atak va kpaktak uza̱ ga ìkum kà̱ te, uza̱ nəm igwan.
\p 
\v 48 Uza̱ lung ikum ká̱ nkam ipa̱ng, kang à nəm igwan ká̱ oAmalek. Uza̱ ka̱m ishi oIsa̱rila ka̱ ashe awo onəm va̱ ka̱ wur iya̱m oza̱ ká̱ ìkum.
\s1 Onəm oga nzhi aShawulu
\p 
\v 49 Ovan onunggwan áShawulu oma, uJonatan, ká̱ uYishwi, ká̱ uMalkishuwa. Kang aɗin ovəvan ochar, uMerap uwa uga nggəshi, ká̱ uMikal uwa uɓwakan.
\v 50 Aɗin achichar pa̱ uAhinowam, uyen uchar aAhima'az. Aɗin ánəm uga mpyal oshozha aShawulu pa̱ uAbner, uya aNer, kang uNer nnyi te, ukyan aShawulu.
\v 51 Upo aShawulu uKish ká̱ upo aAbner uNer, oma ovan aAbiyel onunggwan.
\p 
\v 52 UShawulu nəm ìkum pa̱ gənggəng ká̱ oFilisti ka̱ ashe nkpaktak nra iponzhiponzhi. Kang ununggwan va uShawulu ya kəkam, ka̱t te ká̱ nkam ìgwak te, uza̱ i ɓa ká̱ na ka̱ ashe oshozha wò.
\c 15
\s1 UYawe yang uShawulu ká̱ iponzhi
\p 
\v 1 Te uSamuwel là ûShawulu pa̱, <<UYawe re mi pa̱ n gor ɓu uponzhi ka̱ apal onəm wò oIsa̱rila. Ǹyangmata̱ te, gong achwang kà̱ nre va̱ ka̱ atak aYawe.
\v 2 Iya̱m va ta̱ uYawe uGa ngGatək là,<Mi ga nnyám ntàn oAmalek ka̱kul oza̱ ru oIsa̱rila ká̱ ìkum ka̱ awalang va̱ oza̱ fa ka̱ ashe mbin aMasar.
\v 3 Ǹyangmata̱ te, ga na u ru akum oAmalek ká̱ ìkum kang ɓu zhì nkpaktak iya̱m va̱ iji oza̱. Kang wa re oza̱ ka̱t, gbá̱ng onunggwan, ká̱ ochar, ká̱ ovan, ká̱ ovan oba̱k, ká̱ ina, ká̱ itam, ká̱ oga alakəmi, kang ká̱ oga azhaki.> >>
\p 
\v 4 Te uShawulu ɓut oshozha wò ka̱ aTəleyim, kang a kung oza̱ te, uza̱ ya ìkalong ìgba̱l pa̱ ìparəm ka̱ aɓoshi akum aIsa̱rila, kang ìkalong pa̱ ìgba̱pchi ka̱ aYahudi.
\v 5 Te uShawulu ga ìtong oAmalek ga ra anyimnyal ka̱ ashe aba̱nda̱m.
\v 6 Te uza̱ là ôKeni pa̱, <<Ó fa, ó re oAmalek kang mmá gbá̱ng wó nzəng ká̱ oza̱ ka̱t, ka̱kul ka̱ ó nyám ikin n̂gkpaktak oIsa̱rila, ka̱ awalang va̱ oza̱ fa ka̱ aMasar á.>> Te oKeni fa re oAmalek.
\p 
\v 7 Te uShawulu gbá̱ng oAmalek á ɓàn ka̱ aHavila ga chu aShur, dat ká̱ aswari asa̱l nfa alum ngga aMasar.
\v 8 Uza̱ kpán uAgak uponzhi uga aAmalek ká̱ irirì, kang uza̱ zhì aɓoshi onənəm pa̱ kpaktak ká̱ ndokchi.
\v 9 Ǹnyi te, uShawulu ká̱ oshozha re uAgak ká̱ irirì, ká̱ itam inəna̱n, ká̱ ina, ká̱ ivan itam ká̱ ivan ina inəna̱n, ká̱ nkpaktak iya̱m va̱ ɓyen ká̱ oza̱, oga iya̱m va̱ ta̱ ri ìgwak ôza̱, oza̱ zhì oza̱ ka̱t. Kang nkpaktak ivəngva̱ ɓyen ká̱ oza̱ ka̱t, te oza̱ zhì oza̱ pa̱ chatchat.
\p 
\v 10 Te uYawe là ûSamuwel pa̱,
\v 11 <<Mmami ká̱ nlak ìgwak nva̱ n nak uShawulu yà uponzhi á, ka̱kul uza̱ ga̱ɓa̱n asəm á mi chit, kang uza̱ yang ka̱ nkpak nnap-mpakpak mi chit.>> USamuwel fe iya̱m va̱ ta te, ìgwak lak na pa̱ gənggəng kang uza̱ chal uYawe ka̱ ashe nkpaktak ìzwam va̱ ta.
\p 
\v 12 Ìpin fa kpa̱k ká̱ ìɓotak te, uSamuwel wong ga pa̱ na ô ya uShawulu. Te mmá là á na pa̱, <<UShawulu ga aKarmel chit. Uza̱ me iya̱m ka̱kul nrəng ká̱ aɗin wò ka̱ ta, kang uza̱ ga aGilgal chit.>>
\p 
\v 13 Awalang va̱ uSamuwel ga ya na te, uShawulu là á na pa̱, <<Re uYawe á pa̱r ɓu, n yəl kà̱ nnap-nlà aYawe chit.>>
\p 
\v 14 Ǹnyi te, uSamuwel là pa̱, <<A ya pa na te, iza̱ mmami kà̱ nfife yà? Ayə́ng itam ká̱ ina ka̱t ɗò?>>
\p 
\v 15 UShawulu na ama̱n pa̱, <<OShozha ɓa ká̱ oza̱ ka̱ atak oAmalek, oza̱ yak itam inəna̱n ká̱ ina ka̱kul na mmá yichi nləfər ûYawe, Inan ɓu ká̱. Ǹnyi te, í zhì nkpaktak iza̱ nggo.>>
\p 
\v 16 Te uSamuwel là ûShawulu pa̱, <<Ma̱r, na n là a ɓu iya̱m va̱ uYawe là á mi ká̱ ìzwam ká̱ nlam.>>
\p UShawulu là pa̱, <<Là á mi.>>
\p 
\v 17 Te uSamuwel là pa̱, <<Káp ká̱ nva̱ u ya ishi ɓu iya̱m iro ka̱t, ka̱ nna te, u nyang unəm uga mpyal oga akum oIsa̱rila ka̱t ɗò? UYawe gor ɓu chit uponzhi oIsa̱rila.
\v 18 Kang uza̱ re ɓu pa̱, <Ga ɓu zhì onəm oɓá̱ngɓa̱ng va̱ ta, oAmalek pa̱ kpaktak, lung oza̱ na u gba̱ng oza̱ pa̱ chatchat.>
\v 19 Iza̱ nak kang u kpak nnap-nlà aYawe ka̱t yà? Sang kang u wur iya̱m iga ngwur ka̱ atak ìkum kang u nəm iya̱m iɓá̱ngɓa̱ng wanta̱ kà̱ mpyal aYawe yà?>>
\p 
\v 20 Ǹnyi te, uShawulu là pa̱, <<N kpak nnap-nlà aYawe kpak, n nəm nre wa nva uza̱ re mi á. N zhì nkpaktak oAmalek kang m ɓa ká̱ uAgak uponzhi oza̱.
\v 21 Oshozha wur itam ká̱ ina inəna̱n ka̱ atak ìkum iva mal pa̱ mmá zhì ka̱kul pa̱ ó yichi nləfər ûYawe Inan ɓu ká̱, ka̱ aGilgal.>>
\p 
\v 22 Te uSamuwel na ama̱n pa̱,
\q1 <<Iza̱ uYawe ɗom ji yà?
\q2 Iya̱m inana ɓu iga nshì ká̱ nləfər ka̱t te nkpak nnap-nlà aYawe ɗò?
\q1 Nkpak nnap-nlà ɓyen ji nna nləfər ji,
\q2 nfe nnap ɓyen ji mpyìp inagam ji.
\q1 
\v 23 Nfa iya̱mkak ká̱ uYawe á sat wa nnap-mɓá̱ngɓa̱ng iva̱k.
\q2 Kang nkak ishi te, á ɓa̱ng wa ngwop ìchər.
\q1 Ka̱kul u yang ká̱ nnap-mpakpak aYawe chit,
\q2 te wa nnà ta uza̱ yang ɓu chit ká̱ nyà uponzhi.>>
\p 
\v 24 Te uShawulu là ûSamuwel pa̱, <<N nəm nnap-mɓá̱ngɓa̱ng chit. N kpak nnap-mpakpak aYawe ka̱t, kang n kpak nnap-nlà ɓu ka̱t kpa, ka̱kul n nəm ayər oshozha, nna nak te, n nəm iya̱m va̱ oza̱ ɗom.
\v 25 Ǹyangmata̱ n chal ɓu, yar nnap-mɓá̱ngɓa̱ng á mi, na u le nzəng ká̱ mi, na n wop uYawe.>>
\p 
\v 26 Te uSamuwel là pa̱, <<Mi ya ka̱ nle nzəng ká̱ ɓu ka̱t. Ka̱kul u yang nkpak nnap-nlà aYawe, te uYawe yang ɓu chit ká̱ nyà uponzhi oIsa̱rila.>>
\p 
\v 27 Awalang va̱ uSamuwel ga̱ɓa̱n pa̱ na ô ga te, uShawulu kpán arwangchwang ìlukwanlukwan te, ìlukwan va̱ ta kakchi.
\v 28 USamuwel là á na pa̱, <<Wa nva̱ u kakchi ìlukwan mi te, wa nnà ta uYawe kakchi iponzhi oIsa̱rila chit ka̱ atak ɓu n̂da ta̱, kang uza̱ na ûnəm uro pa̱ɗi, uva á ɓyen ji ɓu ji.
\v 29 Uza̱ va Ìzhàn oIsa̱rila i nap akwam ka̱t, uza̱ i ga̱ɓa̱n nnap-nlà wò ka̱t, ka̱kul uza̱ unəmləbər kang i ga̱ɓa̱n nnap-nlà wò ka̱t.>>
\p 
\v 30 Te uShawulu na ama̱n pa̱, <<N nəm nnap-mɓá̱ngɓa̱ng chit. Ka̱ nna kpa te, n chal ɓu, wa ma̱n te, wa na ichumchum á mi kà̱ mpyal onəm oga mpyal onəm mi ká̱ oIsa̱rila, le nzəng ká̱ mi na n wop uYawe, Inan ɓu.>>
\v 31 USamuwel ga̱ɓa̱n, a le ga nzəng ká̱ na, kang uShawulu wop uYawe.
\p 
\v 32 Te uSamuwel là pa̱, <<Ɓa ká̱ uAgak uPonzhi oAmalek á mi.>>
\p Te uAgak ɓa ka̱ mpipyal ka̱ ashe ìkan, uza̱ rəng pa̱, <<Nnandər ikú va̱ ka̱ apal mi te á lyam chit.>>
\p 
\v 33 Ǹnyi te, uSamuwel là pa̱, <<Wa va̱ ndokchi ɓu nak ochar pa̱ makmak lang ovan oza̱ te, unang ɓu i ga nlang uyen wò kpa.>> Te uSamuwel kyen uAgak ka̱ ndokchi pa̱ nyimənnyimən kà̱ mpyal aYawe ka̱ aGilgal.
\p 
\v 34 Te uSamuwel le aRama, ǹnyi te, uShawulu le nzhi wò ka̱ aGibeya aShawulu.
\v 35 Te uSamuwel ga atak uShawulu lap ka̱t ga chu nra va̱ uSamuwel kú ká̱, ǹnyi te, uSamuwel yà ka̱ aɗor ka̱ apal aShawulu pa̱ makmak. Kang uYawe ká̱ nlak ìgwak ka̱kul nva̱ uza̱ nak uShawulu yà uponzhi oIsa̱rila á.
\c 16
\s1 USamuwel gor uDawuda pa̱ a yà uponzhi
\p 
\v 1 UYawe là ûSamuwel pa̱, <<Ázəmo kang ɓu re nnəm aɗor ka̱ apal ishi aShawulu yà? N yang na chit ká̱ ǹyà uponzhi ka̱ apal oIsa̱rila. Yə́l agbəshi ɓu ká̱ mmì mpyet na u ga aBet-Lehem, mmami kà̱ nre ɓu ka̱ atak aJese, ka̱kul n yak uyiyen uro chit pa̱ a yà uponzhi.>>
\p 
\v 2 Ǹnyi te, uSamuwel là pa̱, <<Mi nəm sang kang mi nəm iya̱m va̱ ta̱ yà? A yà pa̱ uShawulu i fe te, i gbá̱l mi.>>
\p Te uYawe là pa̱, <<Yar ìya ìna ìchar ka̱ awo, te là pa̱, <M ɓa pa̱ n yichi nləfər ûYawe.>
\v 3 Chal uJese kà̱ nləfər va̱ ta, kang mi nyám iya̱m va̱ a ɓu pa̱ u nəm. Ɓu gor uro va̱ mi nyám á ɓu.>>
\p 
\v 4 USamuwel nəm wa nva uYawe là á na. Awalang va̱ uza̱ chu aBet-Lehem te, onəmgbak oga aBet-Lehem fa gwang na ká̱ ayər. Oza̱ ɓəp pa̱, <<U ɓa amwang na lyát ɗò?>>
\p 
\v 5 USamuwel ma̱n pa̱, <<M ɓa ikángkáng pa̱ sham. M ɓa pa̱ n yichi nləfər ûYawe. Ó gár ishi wó na ó ɓa nzəng ká̱ mi ka̱ atak nləfər.>> Te uSamuwel gar uJese ká̱ ovəvan onunggwan, kang uza̱ chal oza̱ kpa kà̱ nləfər va̱ ta.
\p 
\v 6 Awalang va̱ oza̱ chu chit kang uSamuwel dər uEliyap uya aJese te, uza̱ rəng pa̱, <<Nkpak uwà uYawe gor.>>
\p 
\v 7 Ǹnyi te, uYawe là ûSamuwel pa̱, <<Kang wa dər ka̱ acham izər, ka̱t te ìmak ka̱t, ka̱kul n yang na chit. UYawe i dər iya̱m wa nva unəmləbər i dər ka̱t. Onəmləbər i dər ka̱ acham izər, ǹnyi te, uYawe i dər ìgwak.>>
\v 8 Te uJese là ûyen wò uAbinadap pa̱ uza̱ a lyam kà̱ mpyal aSamuwel, ǹnyi te, uSamuwel là pa̱, <<UYawe yak uva̱ ta̱ ka̱t na kpa.>>
\v 9 Te uJese le nak uShamma lyam kà̱ mpyal aSamuwel, te uSamuwel là pa̱, <<UYawe yak na ka̱t na kpa.>>
\v 10 UJese nak ovan wò onunggwan pa̱ ofangshat, lyam kà̱ mpyal aSamuwel, ǹnyi te, uSamuwel là a na pa̱, <<UYawe yak uro ka̱ ashe oza̱ ka̱t.>>
\v 11 Te uza̱ ɓəp uJese pa̱, <<Ovan ɓu onunggwan oma ta̱ byet ɗò?>>
\p UJese na ama̱n pa̱, <<Uɓwakan oza̱ uwa yà ka̱ atak nkpàk iya̱mkang ka̱ ashe nzam.>>
\p Te uSamuwel là á na pa̱, <<Re nre kà̱ na, í yà kà̱ ntəm ka̱t ya uza̱ i ɓa kang.>>
\p 
\v 12 Te uJese re nre mmá ɓa ká̱ na. Uza̱ uyenza̱m uga mɓyen ndər uva ká̱ ikángkáng.
\p Te uYawe là pa̱, <<Wóng, uwa ta gor na.>>
\p 
\v 13 USamuwel yar agbəshi mmì zuk uDawuda ká̱ ishi kang uza̱ gor na ka̱ kà̱ mpyal ogənanggənang. Ɓan ka̱ n̂da va̱ ta te, aRuhu aYawe vàng ká̱ ìkam ka̱ apal ishi aDawuda. Nna chit te uSamuwel le aRama ɗak.
\s1 UDawuda nəm inok kà̱ nzhi aShawulu
\p 
\v 14 ARuhu aYawe re uShawulu, kang uYawe re nre ka̱ aruhu aɓá̱ngɓa̱ng nyán ká̱ na.
\v 15 Oro ka̱ ashe okpari aShawulu là á na pa̱, <<Dər, aruhu aɓá̱ngɓa̱ng vàng chit ka̱ atak Inan kà̱ nyán ká̱ ɓu.
\v 16 Re, anəm uga nzhi yi, í mwo unəm uga ǹnyi nnə́m aɓwa, na awalang va̱ aruhu aɓá̱ngɓa̱ng ka̱ atak Inan a vàng ka̱ apal ɓu te, uza̱ i nə́m aɓwa va̱ ta na nnap nəm ɓu á ɓa kà̱ɗi.>>
\p 
\v 17 Te uShawulu là ôkpari wò pa̱, <<Ó ram unəm va̱ nyi nnə́m aɓwa byet, na ó ɓa ká̱ na á mi.>>
\p 
\v 18 Uro ka̱ ashe okparikpari na ama̱n pa̱, << Uya aJese unəm uga aBet-Lehem uro wa yà nyi nnə́m aɓwa byet. Uza̱ kam ìgwak, kang i lung ìkum byet. Uza̱ ká̱ aghan nnap-nlà kpa, kang uza̱ uyenza̱m uga mɓyen ndər. UYawe uwa yà nzəng ká̱ na.>>
\p 
\v 19 Te uShawulu re onəm oga nre ka̱ atak aJese pa̱, <<Re nre á mi ká̱ uyen ɓu uDawuda, uyen uga nkpak iɓəl ɓu.>>
\v 20 Te uJese re nre ká̱ uDawuda nzəng ká̱ nzəngkəng ka̱ apal azhaki, ká̱ aba̱ng ndəng iba̱ngba̱ng ká̱ iya iɓəl ga ûShawulu.
\p 
\v 21 UDawuda ɓa atak aShawulu kang a ɓàn nnəm inok á na. UShawulu ma̱n ká̱ uDawuda byet, kang uDawuda sat uzəngtəng ka̱ ashe onəm oga ǹyar iya̱m ìkukum.
\v 22 Te uShawulu re nre ûJese pa̱, << Re uDawuda á təm a nəm inok á mi, ka̱kul m ma̱n ká̱ na pa̱ gənggəng.>>
\p 
\v 23 Awalang va̱ aruhu aɓá̱ngɓa̱ng ka̱ atak Inan i vàng ka̱ apal ishi aShawulu te, uDawuda i nə́m aɓwa wò. Te aruhu aɓá̱ngɓa̱ng va̱ ta i re uShawulu kang nnap-nnənəm i le i ɓa.
\c 17
\s1 UDawuda ká̱ uGoliyat
\p 
\v 1 Te oFilisti ɓut oshozha oza̱ ka̱kul ìkum, ka̱ aSoko ka̱ aYahudi. Oza̱ ra apa̱k ka̱ aEfes Dammim, ka̱ ishimshe aSoko ká̱ aAzeka.
\v 2 UShawulu ká̱ oIsa̱rila ɓut kang a ra apa̱k ka̱ mba̱nda̱m aEla, oza̱ gbar izər ka̱kul ìkum ká̱ oFilisti.
\v 3 OFilisti tong ka̱ aɗuktum aro kang oIsa̱rila tong ka̱ aro, ká̱ mba̱nda̱m ká̱ ishimshe oza̱.
\p 
\v 4 Te uGoliyat uponzhi ìkum oFilisti unəm uga ìtong aGat, fa ta̱l ká̱ ishimshe oFilisti ká̱ oIsa̱rila, i rurup ji ashar pa̱ fangzəngtəng ji.
\v 5 Uza̱ pa atagya aga acham arəzang ká̱ ìlukwan iga acham arəzang, iɗəɗək ìkalong pa̱ ìtukun iga ashekel.
\v 6 Uza̱ mwak acham arəzang ka̱ ashar wò, kang uza̱ gantal aɓár akəla̱pkəla̱p aga acham arəzang ka̱ agar.
\v 7 Azar aɓəɓar wa ìdari iga nka̱p atani, kang ishi aɓəɓar, iɗəɗək i nəm ashekel igba̱l pa̱ ikpa̱ɗing nəm. Unəm uga ǹyar nggwànggwàng ìkukum i ləp mpyal a na.
\p 
\v 8 UGoliyat fa sat kà̱ mpyal oshozha oIsa̱rila kang à lə̀p achu pa̱, <<Ó tong iza̱ yà? Ó ɓa ìkum ka̱t ɗò? Mmami unəm oFilisti, kang mmawó okpari aShawulu ka̱t ɗò? Ó yak unəm uro á ɓa ka̱ ashe mba̱nda̱m na á lung mi ka̱ta̱.
\v 9 A yà pa̱ uza̱ á lung mi kang a gbá̱l mi te, oFilisti i yà ozwal wó, ǹnyi te, a yà pa̱ ma ji nkəka̱m kang n gbá̱l na te, ó yà ozwal yi.>>
\v 10 Te unəm oFilisti là pa̱, <<M ɓak oshozha oIsa̱rila n̂da va̱ ta̱. Ó re unəm wó uro á ɓa ná í lung owan yi.>>
\v 11 Ká̱ nfe nnap-nlà aFilisti va̱ ta te, ayər nəm uShawulu ká̱ nkpaktak oshozha oIsa̱rila kang oza̱ tán pa̱ gənggəng.
\p 
\v 12 Ǹyangmata̱ te, uDawuda uya aJese, unəm uga aEfərata ka̱ aBet-Lehem ka̱ ashe mbin aYahudi. UJese ka̱ ovan onunggwan pa̱ ona̱nne kang ka̱ awalang iponzhi aShawulu te, uza̱ gbák chit.
\v 13 Ovan aJese onəmgbak pa̱ oshatɗing ga ìkum chit ká̱ uShawulu. Unəmgbàk te, ka̱ yà uEliyap uga uparəm uAbinadap, kang uga ushatɗing uShamma.
\v 14 UDawuda uwa uyen ka̱ ashe nkpaktak ovan onunggwan aJese. Onəmgbaknəmgbak oga oshatɗing va̱ ta yar nva̱ng aShawulu,
\v 15 ǹnyi te, uDawuda i wong i ga atak apa̱k aShawulu kang i le i ga aBet-Lehem ka̱kul nkpak iya̱m nkang apo wò.
\p 
\v 16 Nra ìsəm pa̱ ineɗing uFilisti va̱ ta ka̱ nnəm inok mpyar oshozha oIsa̱rila ìpin ká̱ arurong.
\p 
\v 17 N̂da nro te, uJese là ûDawuda pa̱, <<Yar ìkur ifórfòr ìkpáng iga mma iya̱m ká̱ nzəngkəng pa̱ ngba̱pchi ga ogənang ɓu pa̱ kəlak ka̱ apa̱k.
\v 18 Te yar mbyal ina nva mmá pə́k chit nə́k pa̱ ngba̱pchi ga unəm uga mpyal oza̱. Wa dər ikángkáng ogənang ɓu kang ɓu ɓa ká̱ iya̱m iro a mi iva i nyám pa̱ oma yà ká̱ ikángkáng.
\v 19 Ogənang ɓu oma yà nzəng ká̱ uShawulu ká̱ oshozha oIsa̱rila ka̱ mba̱nda̱m aEla kà̱ nnəm ìkum ká̱ oFilisti.>>
\p 
\v 20 Ipin fa kpa̱k ká̱ iɓotak te, uDawuda wong re iya̱m nkang ka̱ ashe awo anəm uga nkpak iya̱m nkang uro. Uza̱ wur iya̱m va̱ upupo uJese re na ka̱ á. Uza̱ ga chu apa̱k ka̱ awalang va oshozha oIsa̱rila ka̱ ngga agbagba ìkum, kà̱ nnə́m achu ìkum.
\v 21 Oshozha oFilisti ká̱ oIsa̱rila fa agbagba ìkum tong i dər owan oza̱.
\v 22 Te uDawuda re iya̱m va̱ uza̱ ɓa ká̱ ka̱ atak anəm uga mpángchí iya̱m kang uza̱ chər ga agbagba ìkum re anung ogənang wò.
\v 23 Uza̱ ka̱ nlà nnap ka̱ oza̱, ta byet te, uGoliyat unəm oFilisti ka̱ aGat, fa ka̱ ashe oshozha oFilisti, kang i là apir nnap-nlà wò ngga mpyar oza̱ ka̱ anung, te uDawuda fe.
\v 24 Nkpaktak awalang va̱ oshozha oIsa̱rila ya na te, oza̱ ɓàn nchəng í le ka̱kul ayər nəm oza̱ byet.
\p 
\v 25 Ǹyangmata̱ te, oIsa̱rila i là pa̱, <<Ó ya agbar anəm va̱ cho ya fa ta ɗò? Uza̱ fa pa̱ ô ɓak oIsa̱rila. Uponzhi i ga nná idur imakmak ûnəm va̱ i gbá̱l na, uza̱ i na uyen wò uchar uro á na i ka̱m, kang onənəm te, oza̱ imwa mbwai mbin ka̱t.>>
\p 
\v 26 Te uDawuda ɓəp onəm va̱ dat ká̱ na pa̱, <<Iza̱ mí nəm unəm va̱ i gbá̱l uFilisti va̱ ta̱ kang ì yar iwuswa va̱ ta̱ i le oIsa̱rila yà? Uda uFilisti va̱ ta̱ unəm uga ache amulur, kang i ɓak oshozha Inan iga irirì yà?>>
\p 
\v 27 Kang oshozha na ama̱n á na wa nva mmá là á. Oza̱ là pa̱, <<Iya̱m va ta amwa ka̱kul anəm va̱ i gba̱l na.>>
\p 
\v 28 Awalang va̱ uEliyap unəmgbàk aDawuda fe na ka̱ nlà nnap ka̱ oshozha te, ìgwak lak na kà̱ na kang uza̱ ɓəp na pa̱, <<Iza̱ u ɓa kà̱ ka̱ta̱ yà? U re itam iga nɗa̱p va̱ uda ka̱ ashe nzam yà? N nyi ɓu ká̱ nrup ishi ká̱ nkak ishi nyi. U ɓa pa̱ na u dər nlung ìkum.>>
\p 
\v 29 UDawuda ɓəp pa̱, <<Nza̱ mpat n nəm chit ǹyangmata̱ yà? Mi là nnap-nlà lap ka̱t ɗò?>>
\v 30 Te uza̱ re na ga̱ɓa̱n atak ashozha uro, kang uza̱ ɓəp na wa nva uza̱ ka̱ ɓəp. Te oshozha va̱ ta na ama̱n á na wa nva mmá ka̱ na á na á.
\p 
\v 31 Iya̱m va̱ uDawuda là te, oza̱ ga là ûShawulu, kang uShawulu re nre pa̱ mmá ɓa ká̱ na.
\v 32 UDawuda là ûShawulu pa̱, <<Kang ìchəgwak á ləp unəm uro ka̱ uFilisti va̱ ta̱ ka̱t. Uzwal ɓu i ga i lung na.>>
\p 
\v 33 UShawulu ma̱n ûDawuda pa̱, <<Ɓu nəm sang kang ɓu lung uFilisti va̱ ta̱ yà? Mmaɓu uyen uɓwakan, kang uza̱ ununggwan ìkum ɓan ká̱ ivanzəza̱m na byet.>>
\p 
\v 34 Ǹnyi te, uDawuda là ûShawulu pa̱, <<Uzwal ɓu i kpak iya̱m nkang apo wò. Awalang va̱ ìlir ka̱t te abiya ɓa nkpán ìtam ka̱ ashe nggatək iya̱m nkang,
\v 35 mi ɓàk na, mi la̱p kang mi vyat ìtam va̱ ta ka̱ anunung. Awalang va̱ i ga̱ɓa̱n ìkum ká̱ mi te, mi kpán na ka̱ akpap kang mi nə́m ka̱ ikəka̱m ikú.
\v 36 Uzwal ɓu gba̱l ìlir ká̱ abiya chit, mi ga nnəm uFilisti uga ache amulur va̱ ta̱ wanta na kpa, ka̱kul nva̱ uza̱ ɓak oshozha Inan iga irirì chit.
\v 37 UYawe va fa ká̱ mi ka̱ ashe awo ìlir ká̱ abiya va̱ ta te, uwa i fa ká̱ mi ka̱ ashe awo aFilisti va̱ ta̱.>>
\p UShawulu là ûDawuda pa̱, <<Ga mpyal ka̱, uYawe a ya nzəng ká̱ ɓu.>>
\p 
\v 38 Te uShawulu mwak iya̱m ìkum wò ûDawuda, uza̱ pa atagya acham arəzang ká̱ ìlukwan acham á na.
\v 39 UDawuda mwak chit, te uza̱ gal ndokchi uza̱ ɗak pa̱ ô chen ká̱ te, a ma̱t na ka̱kul uwa mwak apir ìlukwan va̱ ta̱ chit ka̱t.
\p UDawuda là ûShawulu pa̱, <<Mi nyi nchen ká̱ iya̱m va̱ ta̱ ka̱t, ka̱kul nna mwak apipir chit ka̱t.>> Te uDawuda zəp iya̱m va̱ ta le.
\v 40 Te uza̱ yar ìdari wò ka̱ awo, wur ipang pa̱ ìtukun imálkanmalkan ka̱ ashe awang, uza̱ nak ka̱ ashe azhal aga nkpak iya̱m nkang wò, ká̱ nchwalak wò ka̱ awo kang uza̱ ga dát ká̱ unəm oFilisti va̱ ta.
\p 
\v 41 Ǹnyi te, uFilisti va̱ ta nzəng ká̱ unəm uga ǹyar nggwanggwang ìkum á na kà̱ mpyal, fa mɓa nggwang uDawuda.
\v 42 Uza̱ dər uDawuda te, uza̱ ya na uwa yà uyen uɓwakan uga mɓyen dər, uva ká̱ ikángkáng, te uza̱ ɓak na.
\v 43 Uza̱ là ûDawuda pa̱, <<Mmami iva kang ɓu ɓa ká̱ mi ká̱ idari ɗò?>> Kang uFilisti va̱ ta vyap uDawuda ká̱ aɗin inənan.
\v 44 Uza̱ là pa̱, <<Ɓa ka̱ta̱, na n ná ìzhe ɓu inyil ká̱ izhé iga anyin.>>
\p 
\v 45 UDawuda là ûFilisti va̱ ta pa̱, <<U ɓa kà̱ mi ka̱ ndokchi, ká̱ aɓár ká̱ aɓár akəla̱pkəla̱p, ǹnyi te, m ɓa kà̱ ɓu ka̱ ashe aɗin aYawe uGa ngGatək, Inan oshozha oIsa̱rila, uva u ɓak á.
\v 46 N̂da va̱ ta̱ uYawe i na ɓu ka̱ ashe awo mi, kang mi gba̱l ɓu mi gəl ishi ɓu. Te n̂da va̱ ta̱ mi na oga akúm oshozha oFilisti înyil ká̱ izhé iga anyin, kang nkpaktak apambin i nyi pa̱, Inan i ya yà ka̱ aIsa̱rila.
\v 47 Nna chit te, nkpaktak nggatək va̱ ka̱ta̱ i nyi pa̱ uYawe i ka̱mshi onəm wò ká̱ aɓár ka̱t te ndokchi ka̱t. Ìkum iji àYawe, uza̱ i na nkpaktak wó ka̱ ashe awo yi.>>
\p 
\v 48 UFilisti va̱ ta səng ɓa dát pa̱ na ú ru na te, uDawuda gha̱n chər ga dát ká̱ ngba̱k va̱ oFilisti kà̱, pa̱ ô gwang na.
\v 49 Kang uDawuda pa awo ka̱ ashe azhal wò yar ìpang ka̱ ashe azhal aga nkpak iya̱m nkang wò, uza̱ nak ka̱ ashe nchwalak kang uza̱ mang ləp uFilisti va̱ ta ká̱ ìsu. Ìpang va̱ ta tar ka̱ ashe ìkpang ishishi, kang uGoliyat ru zəp kà̱ mbin.
\p 
\v 50 Te uDawuda nəm igwan ka̱ uFilisti va̱ ta ká̱ nchwalak ká̱ ìpang. Uza̱ gbá̱l uFilisti va̱ ta nzəng ká̱ ndokchi ka̱ awuwo ka̱t.
\p 
\v 51 Te uDawuda chər ga sat ka̱ apal ishishi. Uza̱ tur ndokchi aFilisti va̱ ta ka̱ ashe avakchivakchi. Nva̱ngva̱ uza̱ gba̱l na te, uza̱ gəl ishi á na ká̱ ndokchi va̱ ta.
\p Awalang va̱ oFilisti ya chit pa̱ uponzhi ìkum oza̱ kú chit, te oza̱ chəng le nva̱ng.
\v 52 Te oIsa̱rila ká̱ oYahuda bà achu aga igwan, kang oza̱ ɓàk oFilisti ga chu ká̱ ka̱ anung asa̱l aGat, ká̱ anung oga asa̱l aEkron. OFilisti va̱ kú te, a tak ka̱ asa̱l á ga ngga aShayarayim á ga chu aGat ká̱ aEkron.
\v 53 Awalang va̱ oshozha oIsa̱rila le ka̱ atak nwà oFilisti te, oza̱ wur iya̱m iga nwur ka̱ atak ikum ka̱ ashe apa̱k oFilisti.
\p 
\v 54 UDawuda yar ishi aFilisti va̱ ta ɓa ká̱ ka̱ aUrushelima te, uza̱ nak iya̱m ìkum àGoliyat ka̱ ashe aghal wò.
\p 
\v 55 Nva̱ uShawulu ka̱ ya uDawuda kà̱ nfa ngga pa̱ ô lung uFilisti te, a ɓəp uAbner unəm uga mpyal oshozhashozha pa̱, <<Uyen va̱ ta̱ uya ada yà?>>
\p Te uAbner là pa̱, <<Irirì aponzhi á təm mbyet, n nyi upupo ka̱t.>>
\p 
\v 56 Uponzhi là ûAbner pa̱, << Ga ɓəp, uda upupo yà?>>
\p 
\v 57 Nva̱ngva̱ uDawuda le chit ka̱ atak ngbá̱l uFilisti te, uAbner ka̱m na ɓa ká̱ ûShawulu ya ishi aFilisti va̱ ta na ka̱ awo aDawuda.
\v 58 UShawulu ɓəp na pa̱, <<Ayen nza̱m, mmaɓu uya ada yà?>>
\p Te uDawuda là pa̱, <<Mmami uya azwal ɓu uJese, unəm uga aBet-Lehem.>>
\c 18
\s1 Ayər aShawulu ka̱ apal aDawuda
\p 
\v 1 Ka̱ nva̱ngva̱ uDawuda gbá̱l kà̱ nlà nnap chit ká̱ uShawulu te, uJonatan, uya aShawulu ɗom uDawuda pa̱ makmak, kang uJonatan ma̱n na wa nva uza̱ ma̱n ishi wò á.
\v 2 A ɓàn n̂da va̱ ta te, uShawulu re uDawuda le nzhi lap ka̱t, uza̱ təm ká̱ na.
\v 3 Kang uJonatan yar nsar nnap-nlà ká̱ uDawuda, ka̱kul uza̱ ma̱n na wa ishi wò.
\v 4 UJonatan tur ìlukwan wò uza̱ na ûDawuda, nzəng ká̱ ìlukwan ìkukum, ká̱ ndokchi, ká̱ ìjang, ká̱ ngbat.
\p 
\v 5 Atak va pa̱ kpaktak uShawulu i re uDawuda pa̱ uza̱ a ga a nəm ìkum te, uDawuda i nəm igwan ká̱. Te uShawulu nak na uzəngtəng ka̱ ashe onəm ochumchum oshozhashozha, kang ìgwak chàng nkpaktak oshozha ká̱ onəm oga mpyal oshozha.
\p 
\v 6 Awalang va̱ oshozha kà̱ nle nzhi nva̱ngva̱ uDawuda gbá̱l uFilisti va̱ ta chit te, ochar fa ka̱ ashe oga itong oIsa̱rila pa̱ kpaktak pa̱ na ó gwang uponzhi uShawulu. Te oza̱ i shì nnap-nshì kang i gba̱p nza̱m, ká̱ nnap-nshì ngga nchang ìgwak ká̱ iganggáng ká̱ oga aɓwa acham.
\v 7 Oza̱ i gba̱p nza̱m kang i shì nnap-nshì i là ka̱ pa̱,
\q1 <<UShawulu gbá̱ng oji wò ikalong,
\q2 kang uDawuda gbá̱ng oji wò ikalong pa̱ igba̱pchi.>>
\p 
\v 8 Nnap nshì va̱ ta̱ lak ìgwak uShawulu pa̱ gənggəng. Kang uza̱ là pa̱, <<Iza̱ wa nva̱ ta̱ yà? Oza̱ là pa̱ n gbá̱ng ikalong na byet, kang pa̱ uDawuda gbá̱ng ikalong pa̱ igba̱pchi. Te iza̱ ɓur lap ɗa, a ɓur iponzhi na á na chwat ka̱t ɗò?>>
\v 9 Ka̱ awalang va ta byet te, uShawulu nak iwu uDawuda.
\p 
\v 10 Ipin fa kpa̱k te, Inan re ǹre ká̱ aruhu aɓá̱ngɓa̱ng ka̱ apal aShawulu ká̱ nkam i nyán ká̱ na. Uza̱ ɓan nnə́m achu wa anəm ura̱nra̱n ka̱ ashe nzhi wò. Te uDawuda ɓàn nnə́m aɓwa á na wa nva̱ uza̱ mà nə́m á na á. Ǹnyi te, uShawulu uwa ka̱ yà ká̱ aɓár ka̱ awo wò,
\v 11 kang uza̱ gha̱p aɓár i là îshi wò pa̱, <<Mi bàng uDawuda ká̱ ka̱ izər nzhi>> Ǹnyi te, uDawuda ra nggà nva̱ng pa̱ mparəm.
\p 
\v 12 UShawulu nəm ayər aDawuda, ka̱kul uYawe uwa ya nzəng ká̱ uDawuda, ǹnyi te, uza̱ kap ká̱ uShawulu chit.
\v 13 Te uShawulu fa ka̱ uDawuda re nzhi iponzhi, uza̱ nak na ya unəm uga mpyal oshozha ìkalong, kang uDawuda ləp mpyal ôza̱ ka̱ atak ìkum.
\p 
\v 14 Ka̱ ashe nkpaktak iya̱m va̱ uDawuda nəm te, uza̱ i nəm igwan, ka̱kul uYawe uwa yà nzəng ká̱ na.
\v 15 Awalang va̱ uShawulu ya igwan aDawuda chit te, uza̱ nəm ayəyər.
\v 16 Ǹnyi te, nkpaktak oIsa̱rila ká̱ oYahuda ma̱n uDawuda, ka̱kul uza̱ ləp mpyal ôshozha ka̱ atak ìkum ka̱ asa̱l va məma.
\p 
\v 17 UShawulu là ûDawuda pa̱, <<Mi ga nna uyen mi uchar ugəshi, uMerap a ɓu, ɓu ka̱m ichar ká̱ na. Ǹnyi te, ɓu nyám ishi ɓu á mi pa̱ mmaɓu uyen ununggwan ka̱ atak nlung ìkum àYawe.>> UShawulu ka̱ nrəng ka̱ ashe ìgwak pa̱, << Awo mi i dok na ka̱t, re oFilisti oma á gbá̱l na.>>
\p 
\v 18 Kang uDawuda là ûShawulu pa̱, <<Mmami uda yà, akum mi iza̱ ka̱ ashe oIsa̱rila kang mi yà ugwar àponzhi yà? Akum apo mi chu iya̱m iro ka̱t.>>
\v 19 Awalang chu chit pa̱ mmá na uMerap ûDawuda pa̱ á ka̱m, te uShawulu yar na ná ûAdəriyel, unəm oMehola.
\p 
\v 20 Te uya àShawulu uMikal ma̱n uDawuda byet, kang nva̱ngva̱ uShawulu fe te, ìgwak chàng na.
\p 
\v 21 Te uShawulu là îshi wò pa̱, <<Mi na uMikal ûDawuda, na n lwak na ká̱, na oFilisti á gbá̱l na.>> Kang uShawulu là ûDawuda kà̱ɗi pa̱, <<Ǹyangmata̱ ɓu ga ǹyà ugwar mi.>>
\p 
\v 22 Te uShawulu là ônəm wò pa̱, <<Ó là ûDawuda ka̱ ayi pa̱, <Dər uponzhi ma̱n ɓu byet kang mmayi kpa. Ǹyangmata̱ ma̱n na u yà ugwar àponzhi.> >>
\p 
\v 23 Oza̱ là nnap va̱ ta ûDawuda. Ǹnyi te, uDawuda là pa̱, <<Ó rəng pa̱ nnap mɓwakan pa̱ unəm a yà ugwar àponzhi ɗò? Mmami unəm ukunkun u va mmá nyi na mak ka̱t.>>
\p 
\v 24 Awalang va̱ onəm aShawulu le ga là ûponzhi iya̱m va̱ uDawuda là te,
\v 25 uza̱ là pa̱, <<Ó là ûDawuda pa̱, n ɗom iya̱m igwar iro ka̱t, iya̱m va̱ n ɗom te, awa anung ache oFilisti ìgba̱l, ka̱kul na mmá pyat akat ka̱ apal okpa ìkum àponzhi.>> Nɗom aShawulu na ta̱ pa̱ oFilisti a gbá̱l uDawuda.
\p 
\v 26 Awalang va̱ onəm aShawulu là nnap va̱ ta ûDawuda te, ìgwak chàng uDawuda. Te uza̱ ma̱n pa̱ ô yà ugwar àponzhi. Kang ilum va̱ ta i chu,
\v 27 uDawuda wong ká̱ onəm wò ga kang á gbá̱ng oFilisti ìgba̱l pa̱ ìparəm kyèn awa ache oza̱. Oza̱ kung mmak iyəyil ûponzhi na uDawuda a yà ugwar àponzhi. Te uShawulu na uyen wò uchar, uMikal ûDawuda yà uchichar.
\p 
\v 28 Awalang va̱ uShawulu nyi chit pa̱ uYawe uwa ya nzəng ká̱ uDawuda, kang uyiyen uMikal ɗom uDawuda byet,
\v 29 te ayər nəm uShawulu jujwak ká̱ uDawuda. Uza̱ nak uDawuda sat ukpa ìkum wò kà̱ nkpaktak irirìriri.
\p 
\v 30 Kang awalang va kpaktak onəm oga mpyal ìkum oFilisti i ru ìkum te, uDawuda i nəm igwan ka̱ apal oza̱ iji aɓo onəm oga mpyal ìkum àShawulu ji. Ka̱kul nva̱ ta̱ te, aɗin aDawuda dam pa̱ gənggəng.
\c 19
\s1 UShawulu ɗak pa̱ ô gba̱l uDawuda
\p 
\v 1 UShawulu nok nkpaktak okpari wò ká̱ uJonatan uyiyen pa̱ oza̱ agba̱l uDawuda. Ǹnyi te uJonatan ma̱n uDawuda byet,
\v 2 uza̱ là á na pa̱, <<Upo mi ka̱ nram ɓu pa̱ ô gbá̱l. Ka̱kul nva̱ ta te, nəm pa̱ dakdak ipin ká̱ iɓotak te, ram atak mbwam kang ɓu təm ka̱ ta.
\v 3 Mi là ûpo mi pa̱ i fa i tong ka̱ agbagba ka̱ atak va̱ u bwam kà̱, kang mi là nnàp á na ka̱ apal ishi ɓu. Te mi là a ɓu iya̱m va̱ pa̱ kpaktak n fe ka̱tətak.>>
\p 
\v 4 Ipin fa kpa̱k te uJonatan là nnap nnəna̱n ka̱ apal aDawuda ûpo wò. Uza̱ là pa̱, <<Kang wa nəm iya̱m iɓá̱ngɓa̱ng ukpari ɓu uDawuda ka̱t aponzhi, uza̱ uwa a nəm iya̱m iɓá̱ngɓa̱ng iro a ɓu chit ka̱t. Iya̱m va̱ uza̱ nəm te, nna yà ká̱ nka̱mshi á ɓu pa̱ makmak.
\v 5 U kong ka̱ nva̱ uza̱ yang ká̱ irirì wò uza̱ gbá̱l agbar oFilisti, nna nak te uYawe na igwan oIsa̱rila ka̱t ɗò? Iya̱m va̱ ta a chàng ìgwak a ɓu pa̱ gənggəng. Te sang kang ɓu ɗom pa̱ u gbá̱l unəm unəna̱n wa aDawuda yà? Ipir iga ngbá̱l na yà ka̱t.>>
\p 
\v 6 Te uShawulu gwong achwang ka̱ nnap-nlà aJonatan kang uza̱ sóng anung pa̱, <<UYawe uwa ya te, unəm uro i gbá̱l uDawuda ka̱t.>>
\v 7 Ka̱ nva̱ng va̱ ta te, uJonatan wór uDawuda a shal á na iya̱m va̱ upupo là á. Te uza̱ ka̱m uDawuda ga ká̱ ka̱ atak aShawulu, ta byet te iya̱m ra pa̱ dakdak wa nva̱ ka̱ yà matmat á.
\p 
\v 8 A gba̱ng nva̱ng ka̱t te ìkum fa kà̱ɗi, te uDawuda ga ká̱ oshozha wò ru oFilisti ká̱ ikam. Kang uza̱ gbá̱ng oza̱ pa̱ makmak oza̱ chəng.
\p 
\v 9 N̂da nro uShawulu wa ka̱ ntəm ka̱ nzhi wò ka̱ aɓár ka̱ awo, te uYawe re ǹre ka̱ aruhu aɓá̱ngɓa̱ng uShawulu i nyán ká̱ na kà̱ɗi. Te uDawuda ɓàn nnə́m aɓwa á na wa nva uza̱ ma nə́m á,
\v 10 te uShawulu yar aɓár pa̱ ô bàng uDawuda ká̱ ka̱ izər nzhi, ǹnyi te, uDawuda ra nggà kang aɓár ga bàng izər nzhi. Kang uDawuda fa ká̱ izwam va̱ ta chər.
\p 
\v 11 UShawulu re ǹre ka̱ onunggwan pa̱ a pángchí nzhi aDawuda, na oza̱ á gbá̱l na ká̱ iɓotak. Ǹnyi te, uMikal uchar aDawuda, là á na pa̱, <<A yà pa̱ ɓu chər ká̱ izwam va̱ ta̱ ka̱kul iriri ɓu ka̱t, ipin i kpa̱k te, mí gbá̱l ɓu.>>
\v 12 Te uMikal nak uDawuda fa ka̱ mɓol ayir nzhi kang uza̱ chər.
\v 13 Te uMikal yar ìchər nak ka̱ apal alyer kang a dang ká̱ iya̱m iga ndang izər kang a nak akpap iɓəl ka̱ ishishi.
\p 
\v 14 Awalang va̱ uShawulu re ǹre ká̱ onunggwan pa̱ a kpán uDawuda te, uMikal là ôza̱ pa̱, <<Uza̱ rurwa.>>
\p 
\v 15 Te uShawulu re onunggwan pa̱ á ga á dər uDawuda kang à là ôza̱ pa̱, <<Ó ɓa ká̱ na á mi ka̱ apal aləlyer na ń gbá̱l na.>>
\v 16 Ǹnyi te, awalang va̱ oza̱ ɓa táng te, oza̱ ya ìchər ka̱ apal alyer kang ká̱ oga akpap iɓəl ka̱ ishishi.
\p 
\v 17 UShawulu là ûMikal pa̱, <<Sang kang u lam mi wa nta̱ yà kang u re ukpa ìkum mi gà yà?>>
\p UMikal là a na pa̱, <<Uza̱ là a mi pa̱, <Re mi ngga. Le kang ma gba̱l ɓu.> >>
\p 
\v 18 Awalang va̱ uDawuda chər chit, te uza̱ ga atak aSamuwel ka̱ aRama, kang uza̱ là á na nkpaktak iya̱m va̱ uShawulu nəm á na. Te uSamuwel ká̱ uDawuda ga aNayot kang à təm ka̱ ta.
\v 19 Mmá là ûShawulu pa̱, <<UDawuda wa ka̱ aNayot ka̱ aRama,>>
\v 20 te uza̱ re onunggwan pa̱ á ga á kpan na. Ǹnyi te, awalang va̱ oza̱ ga ya idongkong onəm oga nlà ìchu Inan ka̱ nlà iya̱m va̱ ka̱ ngga nfa, kang uSamuwel wa ka̱ ta wa anəm uga mpyal oza̱, te aruhu Inan vàng ka̱ apal onunggwan aShawulu, kang oza̱ ɓàn nlà iya̱m va̱ i ga nfa kpa.
\v 21 Mmá là ûShawulu iya̱m va̱ kà̱ nchen te, uza̱ re nre ká̱ onunggwan okak ka̱ɗi kang oza̱ là iya̱m va̱ iga nfa kpa. UShawulu re nre ká̱ onunggwan ngga nshishat kang oza̱ ɓàn nlà iya̱m va̱ i ga nfa kpa.
\v 22 Ká̱ nkukur te, uza̱ wong ká̱ ishi wò kà̱ ngga aRama kang uza̱ ga chu ache ndəng nchumchum nka̱pka̱p ka̱ aSeku te, uza̱ ɓəp pa̱, <<USamuwel ká̱ uDawuda ka̱ che yà?>>
\p Mmá là á na pa̱, <<Oma yà ka̱ aNayot ka̱ aRama.>>
\p 
\v 23 Te uShawulu ga aNayot ka̱ aRama. Ǹnyi te, aRuhu Inan vàng ka̱ apal ishishi kpa kang uza̱ kà̱ nchen kà̱ nlà iya̱m va̱ i ga nfa uza̱ ga chu ká̱, ka̱ aNayot.
\v 24 Uza̱ zə̀p ilukwan wò kang uza̱ là iya̱m va̱ i ga nfa kpa kà̱ mpyal aSamuwel. Uza̱ ra umaləng nkpaktak alum ká̱ izwam. Iya̱m va ta̱ nak kang onəm i là pa̱, <<UShawulu ka̱ ashe onəm oga nlà ìchu Inan kpa ɗò?>>
\c 20
\s1 UJonatan ka̱mshi ûDawuda
\p 
\v 1 Te uDawuda chər ka̱ aNayot ka̱ aRama ga atak aJonatan. Uza̱ ɓəp na pa̱, <<Iza̱ n nəm yà? Iza̱ mpat mi yà? N nəm mpat ûpo ɓu wa nsang kang uza̱ ɗom pa̱ ô gbá̱l mi yà?>>
\p 
\v 2 Te uJonatan là pa̱, << Pa ka̱t, mmaɓu kà̱ ngga nkú ka̱t. Dər, upo mi i yà kà̱ nnəm iya̱m iro ichumchum ka̱t te iɓwakan i va uza̱ i nəm mi nyi ka̱t ɗò ka̱t. Ka̱kul iza̱ kang uza̱ i bwam i va̱ ta̱ kà̱ mi yà? Iya̱m iro yà pa ka̱t.>>
\p 
\v 3 Ǹnyi te, uDawuda sóng anung là pa̱, <<Upo ɓu nyinyi pa̱ kpátkpát pa̱ nna n yà ká̱ nchə̀r mba̱lba̱l kà̱ mpyal ɓu, te uza̱ là ishi wò pa̱, <A màl pa̱ uJonatan á nyi nnap va̱ ta ka̱t, ka̱t te i lak ìgwak a na.> Nva̱ uYawe wa yà ká̱ iriri kang na u yà ká̱ iriri te, ishimshe mi ká̱ ikú a ɓur ntong ashar.>>
\p 
\v 4 UJonatan là ûDawuda pa̱, <<Nkpaktak iya̱m va̱ u ɗom pa̱ n nəm a ɓu te, mi nənəm a ɓu.>>
\p 
\v 5 Te uDawuda là á na pa̱, <<Dər, ipin te mí ga nnəm nchang izər ngga ape apipe, kang a màl pa̱ n təm nrì iya̱m-nrì nzəng ká̱ uponzhi, ǹnyi te, re mi mbwam ka̱ ashe nzam a ga a chu arurong aga nra ngga nshatɗing kang.
\v 6 A yà pa̱ upo ɓu a lang mi te, là a na pa̱, <UDawuda chál mɓa̱r pa̱ ô ga nzhi wò ka̱ aBet-Lehem kəlak kang, ka̱kul nləfər ngga akum ìjili oza̱ ngga nza̱ ìzun nggo.>
\v 7 A yà pa̱ uza̱ là pa̱, <Dakdak,> te i nyám ɗak pa̱ uzwal ɓu yà ká̱ nɗaktak ka̱t. Ǹnyi te, a yà pa̱ uza̱ mən ìkum ká̱ ɓu te, ɓu nyi ɗak pa̱ uza̱ kà̱ nɗom nnəm iɓá̱ngɓa̱ng á mi.
\v 8 Mmaɓu te, wa nyám nnap nnəna̱n ûzwal ɓu, ka̱kul u yar nsar nnap-nlà ká̱ mi chit kà̱ mpyal aYawe. A yà pa̱ m pat te, wa gbá̱l mi ká̱ ishi ɓu. Sang kang ɓu na mi ka̱ ashe awó apo ɓu yà?>>
\p 
\v 9 UJonatan là pa̱, <<Pa ka̱t, ka̱ yà pa̱ n nyinyi pa̱ upo mi uwa ya ká̱ iɓá̱ngɓa̱ng iro ka̱kul ɓu te, ká̱ nlà a ɓu ka̱t ɗò?>>
\p 
\v 10 UDawuda ɓəp uJonatan pa̱, <<A yà pa̱ upo ɓu ma̱n a ɓu ká̱ ìkum te, uda i là á mi yà?>>
\p 
\v 11 UJonatan là á na pa̱, <<Fa í ga ashe agbagba.>> Te oza̱ fa ga ashe agbagba.
\v 12 Te uJonatan là ûDawuda pa̱, <<N sóng anung kà̱ mpyal àYawe, Inan ìga aIsa̱rila, ká̱ awalang wanta̱ ìpin ka̱t te nlomo te, mi ɗak na n nyi nrəng nnàp àpo mi. A yà pa̱ uza̱ uwa ya ká̱ iya̱m iro ká̱ ìgwak ka̱ apal ɓu te, mi re ǹre mí là a ɓu.
\v 13 Ǹnyi te, a yà pa̱ upo mi uwa ɗom nnəm iya̱m iɓá̱ngɓa̱ng iro a ɓu te, re uYawe á nyán ká̱ uJonatan pa̱ gənggəng, a yà pa̱ n nyám ka̱ a ɓu ka̱t kang nre ɓu u ga ká̱ ikangkang. Te re uYawe á yà nzəng ká̱ ɓu wa nva̱ uza̱ ka̱ yà nzəng ká̱ upo mi á.
\v 14 Ǹnyi te, nyám ikin ikúrkùr ka̱t á mi wa ikin aYawe a yà pa̱ n na n yà ká̱ irirì á, na kang mmá gba̱l mi ka̱t.
\v 15 Awalang va̱ uYawe á zhì nkpaktak okpa ìkum aDawuda ka̱ apambin te, kang wa re nyám ikin ɓu n̂zhi mi ka̱t mbyet mbyet.>>
\p 
\v 16 Te uJonatan yar nsàr nnap-nlà ká̱ nzhi àDawuda là pa̱, <<Re uYawe á zhì okpa ìkum aDawuda pa̱ kpaktak.>>
\v 17 Kang uJonatan nak uDawuda yar nsóng anung kà̱ɗi ka̱kul ma̱n va̱ uza̱ ká̱ a na, ka̱kul uza̱ ma̱n na wa va uza̱ ma̱n ishi wò.
\p 
\v 18 Te uJonatan là ûDawuda pa̱, <<Ìpin te, mí nəm nchang izər ngga ape apipe kang mí lang ɓu ka̱kul atak ntəm ɓu i təm nlakchi.
\v 19 Nlomo ka̱ arurong te, ga atak va̱ ka̱ u bwam ká̱ awalang va̱ nɗaktak va̱ ta̱ ɓan, kang ɓu lok kà̱ ngba̱k ìpang aEzel.
\v 20 Mi tat iwar pa̱ ishatɗing i ga ngba̱k ìpang va̱ ta, na mmami kà̱ mmang ìji.
\v 21 Te mi re uyen ununggwan kang mi là a na pa̱, <Ga mwo iwar va̱ ta.> A yà pa̱ n là á na pa̱, <Dər, iwar va̱ ta kà̱ ngba̱k va ta̱, kà̱ ishimshe mi ká̱ ɓu, ɓa ká̱ ka̱ ta̱,> te wa ɓa, ka̱kul wa nva uYawe wa ká̱ iriri te, na u yà ká̱ iriri, nɗaktak nro yà ka̱t.
\v 22 Ǹnyi te, a yà pa̱ n là ûyen ununggwan va̱ ta pa̱, <Dər, iwar na yà kà̱ mpyal ɓu,> te nkpak pa̱ u ga, ka̱kul uYawe re ɓu chit pa̱ u ga achen ɓu.
\v 23 Kang ka̱ apal iya̱m va̱ ta̱ ká̱ i shal te, i rəng ká̱, uYawe uwa sat ká̱ ishimshe mi ká̱ ɓu mbyet.>>
\p 
\v 24 Te uDawuda bwam ka̱ ashe nzam, kang awalang va̱ mmá ɓàn nnəm nchang izər ngga ape apipe te, uponzhi təm pa̱ ô ri iya̱m-nrì.
\v 25 Uza̱ təm ka̱ atak va̱ uza̱ mmà təm ka̱ ka̱ izər nzhi, uJonatan təm màl ikwoksok ká̱ na, kang uAbner təm kà̱ ngba̱k aShawulu, ǹnyi te, atak ntəm aDawuda təm nlakchi.
\v 26 UShawulu là iya̱m iro n̂da va̱ ta ka̱t, ka̱kul uza̱ rəng pa̱, <<Iya̱m iro na ya uDawuda va nak na yà ká̱ adak. Nna nak kang uza̱ yà ka̱ atak nchang izər ka̱t.>>
\v 27 Ǹnyi te, ipin fa kpa̱k, kà̱ nra ngga mparəm ngga ape te, atak aDawuda nna a təm nlakchi. Te uShawulu ɓəp uyən wò uJonatan pa̱, <<Iza̱ nak kang uya àJese ɓa atak nri iya̱m-nrì ka̱ nlam ka̱t, ka̱t te n̂da ka̱t yà?>>
\p 
\v 28 UJonatan na ama̱n pa̱, <<UDawuda ɓəp mɓa̱r ɓəp ka̱ atak mi pa̱ ô ga aBet-Lehem.
\v 29 Uza̱ là á mi pa̱,<Re mi n ga, ka̱kul nzhi yi ka̱ ngga nnəm nləfər ka̱ ashe ìtong, kang ugənang mi nak pa̱ n yà ka̱ ta. A yà pa̱ nchə̀r mi bəba̱l kà̱ mpyal ɓu te, re mi, n ga n ya ogənang mi.> Nna nak kang uza̱ ɓa atak nri iya̱m-nrì aponzhi ka̱t.>>
\p 
\v 30 UShawulu yà ká̱ nlàk ìgwak pa̱ gənggəng kà̱ uJonatan kang uza̱ là á na pa̱, <<Mmaɓu uyen ununggwan ulakchilakchi, amar achar umaimai. N nyinyi pa̱ mmaɓu kà̱ nlə́p asəm uDawuda uya aJese na a yà uponzhi ka̱ anung ɓu, wanta na u ɗom pa̱ u ná iwuswa îshi ɓu ká̱ unang va̱ mar ɓu ɗò?
\v 31 Nva̱ pa̱ uya aJese uwa ká̱ irirì ka̱ apambin va̱ ta̱ te, ɓu yà uponzhi ka̱t. Ǹyangmata̱ te, re unəm uro á ɓa ká̱ na a mi, ka̱kul nkpak pa̱ uza̱ a kú.>>
\p 
\v 32 Te uJonatan ɓəp upo wò pa̱, << Mí gbá̱l na ka̱kul iza̱ yà? Iza̱ uza̱ nəm yà?>>
\v 33 Ǹnyi te, uShawulu mang na ká̱ aɓár pa̱ na ô gbá̱l na. Nna chit te, uJonatan nyi ɗak pa̱, upo wò ka̱ nɗom ngbá̱l uDawuda.
\p 
\v 34 Te uJonatan wong ka̱ apal atebəl ka̱ ashe nlàk ìgwak pa̱ gənggəng, kà̱ nra ngga mparəm ngga nchang izər va̱ ta, uza̱ ri iya̱m-nrì ka̱t, ka̱kul a ɗak na byet ka̱ iya̱m va̱ upupo là a na ka̱ apal aDawuda.
\p 
\v 35 Ká̱ ìpin te, uJonatan fa ga ashe nzam pa̱ na ô gwang ká̱ uDawuda wa nva oza̱ ka̱ sar á. Uza̱ ga ká̱ uyen ununggwan uɓwakan nzəng ká̱ na,
\v 36 kang uza̱ là ûyen ununggwan va̱ ta pa̱, <<Chə́r na u mwo iwar va̱ n tat.>> Nva̱ uyen ununggwan va̱ ta ka̱ nchə́r te, uza̱ mang ìwar ka̱ mpipyal.
\v 37 Awalang va̱ uyen ununggwan va̱ ta ɓa chu atak va̱ ìwar aJonatan ru ka̱ te. UJonatan wor na là pa̱ <<Ìwar yà ka̱ mpyal ɓu ka̱t ɗò?>>
\v 38 Te uza̱ ləp achu á na pa̱, <<Ghəgha̱n, ga pa̱ kəlak, kang wa kali ka̱t.>> Te uyen ununggwan va̱ ta yar ìwar va̱ ta kang a ga ká̱ ûnəm uga nzhi wò.
\v 39 Uyen ununggwan va̱ ta nyi iya̱m iro ka̱ apal nkpaktak iya̱m va̱ ta ka̱t. UJonatan ká̱ uDawuda oma nyi chwat.
\v 40 Te uJonatan na oga iya̱m aɓang wò ûyen ununggwan va̱ ta kang à là a na pa̱, <<Wur, ga ka̱ oza̱ kà̱ ìtong.>>
\p 
\v 41 Nva̱ngva̱ uyen ununggwan va̱ ta ga chit, te uDawuda fa ka̱ asa̱l nkwandal ìpang va̱ta kang à ɓəram kà̱ mpyal aJonatan nva̱ng pa̱ nshatɗing, uza̱ kwangtal asa̱l awu wò ka̱ avəng. Te oza̱ fəkchi owan oza̱ kang oza̱ yə́ng, ǹnyi te, uDawuda uwa yə́ng ji.
\p 
\v 42 UJonatan là ûDawuda pa̱, <<Ga ká̱ ikángkáng, ka̱kul í yar nsar nnap-nlà ikpa owan yi chit ka̱ ashe aɗin aYawe, i là pa̱, <UYawe uwa sat ka̱ ishimshe mi ká̱ ɓu, kang ka̱ ishimshe oga akum ìjili ɓu ká̱ oga akum ìjili mi mbyet.> >> Te uDawuda ga, kang uJonatan le ga ashe ìtong.
\c 21
\s1 UDawuda ka̱ aNop
\p 
\v 1 UDawuda ga aNop ka̱ atak aAhimelek unəm uga mpyal awop. UAhimelek ya na te a tán, kang uza̱ ɓəp na pa̱, <<Sang kang mmaɓu ka̱ nkukwa, unəm uro nzəng ká̱ ɓu ka̱t yà?>>
\p 
\v 2 UDawuda na ama̱n ûAhimelek unəm uga mpyal awop pa̱, <<Uponzhi re mi ka̱ nre, kang a là a mi pa̱, <Kang unəm uro a nyi iya̱m iro ka̱ apal nre va̱ mmami kà̱ nre ɓu kà̱ ka̱t.> N là atak va̱ ônəm mi chit pa̱ oza̱ a gwang mi kà̱.
\v 3 Ǹyangmata̱ te, iza̱ mmaɓu ká̱ yà? Na nzəngkəng á mi pa̱ ntukun, ka̱t te iya̱m va kap mmaɓu ká̱ á.>>
\p 
\v 4 Ǹnyi te, unəm uga mpyal awop na ama̱n ûDawuda pa̱, <<N yà ka̱ nzəngkəng ngga nri onəm pa̱ vàvà ka̱t, nva̱ mmami ka̱ te nzəngkəng ǹyəryər, o riri, a yà pa̱ ovan nza̱m va̱ mmaɓu ká̱ oma ra ka̱ ochar chit ka̱t.>>
\v 5 UDawuda na ama̱n pa̱, << Pa̱ ɗəkər te, í pángchí ishi yi ka̱ nnap ochar a yà pa̱ í wong achen wa nva̱ ta̱. Kang jwak pa̱ achen va̱ ta̱ ká̱ ipipir.>>
\p 
\v 6 Te unəm uga mpyal awop na nzəngkəng ǹyəryər á na ka̱kul pa̱ nzəngkəng nro yà ka̱ atak ka̱t, nva̱ ka̱ ta te, nva mmá yar chit kà̱ mpyal àYawe ka̱ apal atebəl, kang mmá nak nkak nsur ka̱ atətak.
\p 
\v 7 N̂da va̱ ta te uDoyek unəm oEdom, unəm uga mpyal ga nkpak iya̱m nkang àShawulu uwa ka̱ta, uva mmá gəl na kà̱ mpyal àYawe.
\p 
\v 8 UDawuda ɓəp uAhimelek pa̱, <<Nna u ya ká̱ aɓár ka̱t te ndokchi ka̱ ta̱ ɗò? N yar ndokchi ka̱t te iya̱m ìkum iro ka̱t, ka̱kul inok aponzhi iga ijəjak, á nak te n fa ka̱ nggha̱n.>>
\p 
\v 9 UAhimelek na ama̱n pa̱, <<Ndokchi aGoliyat unəm oFilisti na byet uva u gbá̱l ka̱ mba̱nda̱m aEla, na mmá chəndər mmá nak ka̱ nsəm ìlukwan ìkwoksok. Yar a yà pa̱ u ɗuɗom á, ka̱kul nna mmami ká̱ byet.>>
\p Te uDawuda là pa̱, <<Á ɓyen byet, na á mi.>>
\s1 UDawuda ka̱ aGat
\p 
\v 10 Ka̱ n̂da va̱ ta te, uDawuda chər ka̱ atak aShawulu kang a ga atak aAkish, uponzhi uga aGat.
\p 
\v 11 Ǹnyi te, okpari aAkish là á na pa̱, <<UDawuda va ta̱ uponzhi uga mbin ka̱t ɗò? Uwa oIsa̱rila i shì nnap ká̱ na pa̱,
\q1 << <UShawulu gbá̱ng oji wò ikalong,
\q2 kang uDawuda gbá̱ng oji wò ikalong pa̱ igba̱pchi> ka̱t ɗò?>>
\p 
\v 12 UDawuda kpan oga nnap-nlà va̱ ta̱ ka̱ ìgwak kang ayər nəm na pa̱ gənggəng ka̱kul aAkish uponzhi uga aGat.
\v 13 Te uza̱ ga̱ɓa̱n i nəm wa anəm ura̱nra̱n, nkpaktak awalang va̱ uza̱ nzəng ká̱ oza̱ te, uza̱ i nəm wa anəm ura̱nra̱n, uza̱ i cha iya̱m ka̱ izər anung oga asa̱l kang uza̱ re nshí i wàr á na ka̱ nggyer.
\p 
\v 14 UAkish là ôkpari wò pa̱, <<Ó dər, unəm va̱ ta̱ á rəra̱n. Sang kang ó ɓa ká̱ na á mi yà?
\v 15 N lang onəm ora̱nra̱n kang o ɓa ka̱ unəm va̱ ta̱ pa̱ a pak inok nnəm nra̱n kà̱ mpyal mi ɗò? Nkpak pa̱ unəm a ta̱ a ɓa mpyal mi ɗò?>>
\c 22
\s1 UDawuda ka̱ aAdulam ká̱ aMizpa
\p 
\v 1 UDawuda re aGat kang uza̱ chər ga agba̱k aga aAdulam. Awalang va̱ ogənanggənang ká̱ nkpaktak onəm oga nzhi apupo fe te oza̱ fa ga ya na ka̱ta.
\v 2 Nkpaktak onəm va̱ ka̱ ashe mɓək anung, ká̱ ovəngva̱ ká̱ akat, ká̱ ovəngva̱ ká̱ mɓa̱ng ìgwak, oza̱ ɓut ka̱ atak aDawuda. Onəm ga chu ìgba̱l pa̱ ìneɗing kang uza̱ yà unəm uga mpyal oza̱.
\p 
\v 3 Ka̱ ta te uDawuda wong ga aMizpa kà̱ mbin aMowap, kang uza̱ là ûponzhi oMowap pa̱, << Kusuk ɓu məma̱n pa̱ n re upo mi ká̱ unang mi á təm ka̱ atak ɓu, na ń nyi iya̱m va̱ Inan i ga nnəm á mi kang ɗò?>>
\v 4 Te uza̱ re oza̱ ká̱ uponzhi oga aMowap kang oza̱ təm ká̱ na ka̱ ashe nkpaktak awalang va̱ uDawuda uwa kà̱ mbwam ka̱ atak mbwam wò á.
\p 
\v 5 Ǹnyi te, unəm uga nlà ìchu Inan, uGat là ûDawuda pa̱, <<Kang wa təm ka̱ ashe atak va̱ mmaɓu kà̱ mbwam ka̱ ka̱t. Ga ashe mbin aYahuda.>> Te uDawuda ga ashe ikun iga aHeret.
\s1 UShawulu gbá̱ng onəm oga mpyal awop oga aNop
\p 
\v 6 Ǹyangmata̱ te, uShawulu fe pa̱ mmá ya atak aDawuda ká̱ onəm wò chit. Kang uShawulu uwa ka̱ ntəm ka̱ aGibeya ka̱ avəng ìkun atamariki ka̱ apal aɗuktum, uwa ká̱ aɓár ka̱ awo, kang onəm oga nəm inunok tong ka̱ nggbəgba̱k.
\v 7 Uza̱ là ôza̱ pa̱, <<Ó gwong achwang ônunggwan oga aBenjamin, uya aJese i na iram na ká̱ iram iba̱ngba̱ng nkpaktak wo ɗò? Uza̱ i nak nkpaktak wo nak ó sat onəm oga mpyal oshozha ikalong ka̱t te igba̱l ɗò?
\v 8 Nna nak kang nkpaktak wo ó gwang anung ka̱ apal mi ɗò? Unəm uro yà là á mi ka̱t, awalang va̱ uyen mi yar nsar nnap-nlà ká̱ uya aJese. A ɗak unəm uro ká̱ mi ka̱t, ka̱t te á là á mi pa̱ uyen mi nok ukpari mi pa̱ á ra anyimnyal kà̱ mi, wa nva̱ uza̱ nəm ká̱ nda va̱ ta̱ á.>>
\p 
\v 9 Ǹnyi te, uDoyek unəm uga aEdom, uva ka̱ yà kà̱ nsat nzəng ká̱ onəm oga nnəm inok aShawulu te, á là pa̱, <<N ya uya aJese ɓa atak aAhimelek uya aAhitub ka̱ aNop.
\v 10 UAhimelek ɓəp uYawe a na. Uza̱ na iya̱m-nrì á na kpa ká̱ ndokchi àGoliyat unəm oFilisti.>>
\p 
\v 11 Te uPonzhi re ǹre kà̱ uAhimelek uya aAhitub unəm uga mpyal awop ká̱ nkpaktak onəm oga nzhizhi, ova onəm oga mpyal awop ka̱ aNop, kang nkpaktak oza̱ ɓa atak aponzhi.
\v 12 UShawulu là pa̱, <<Gwong achwang kà̱ mi, á ya aAhitub.>>
\p Uza̱ na ama̱n pa̱, <<Mmami kà̱ nfe ɓu ánəm uga nzhi.>>
\p 
\v 13 UShawulu là a na pa̱, <<Iza̱ nak kang ó gwang anung kà̱ mi, mmaɓu ká̱ uya aJese, u na iya̱m-nrì á na ká̱ ndokchi, kang u ɓəp Inan á na, nnà kang uza̱ fa iya̱mkak ká̱ mi, kang i ra anyimnyal kà̱ mi, wa nva̱ uza̱ nəm n̂da va̱ ta̱ yà?>>
\p 
\v 14 UAhimelek na ama̱n ûponzhi pa̱, <<Unəm uro wa yà ka̱ ashe nkpaktak okpari ɓu ká̱ nnandər wa aDawuda ugwar ɓu, uwa unəm uga mpyal onəm oga mpángchí ɓu, kang uwa mmá na ichumchum á na ji ka̱ ashe nzhi ɓu ɗò?
\v 15 Nna ta̱ kang mmami kà̱ mɓəp Inan ka̱kukul nggəshi ɗò? Wanta ka̱t, re kang uponzhi a ná mpat ûkpari wò ka̱t te unəm uro ka̱ ashe nzhizhi ka̱t, ka̱kul ukpari ɓu nyi iya̱m iro ka̱ apal ngwang anung ka̱ apal ɓu ka̱t.>>
\p 
\v 16 Ǹnyi te, uponzhi là pa̱, <<ÁAhimelek, nkpak pa̱ u kú mmaɓu ká̱ nkpaktak nzhi apo ɓu.>>
\p 
\v 17 Te uza̱ là ônəm oga mpángchí na va̱ kà̱ mbəbəp pa̱, <<Ó gbá̱ng onəm oga mpyal awop aYawe va̱ ta̱, ka̱kul oza̱ gwang anung ká̱ uDawuda. Oza̱ nyinyi pa̱ uza̱ ka̱ nchə́r, te unəm uro ka̱ ashe oza̱ là á mi ka̱t.>> Ǹnyi te, onəm oga mpyal àponzhi yang ká̱ ngha̱p awo pa̱ na ó ngbá̱ng onəm oga mpyal awop aYawe va̱ ta.
\p 
\v 18 Te uponzhi là ûDoyek pa̱, <<Ga̱ɓa̱n gbá̱ng onəm oga mpyal awop va̱ ta̱.>> Te uDoyek unəm uga aEdom gbá̱ng oza̱. N̂da va̱ ta te, uza̱ gbá̱ng onəm ìsəm pa̱ na̱nne ama̱n pa̱ tukun, ova̱ mwak ilukwan ikwoksok iga alinin.
\v 19 UShawulu nak kpa mmá gbá̱ng onəm oga aNop, ìtong onəm oga mpyal awop. Mmá gbá̱ng onunggwan ká̱ ochar, ovan ká̱ ovanba̱k, ká̱ ina, ká̱ azhaki, ká̱ itam.
\p 
\v 20 Ǹnyi te, uAbiyatar uzəngtəng ka̱ ashe ovan onunggwan àAhimelek uya aAhitub, a mulit kang à chər ga atak aDawuda.
\v 21 Uza̱ là ûDawuda pa̱, <<UShawulu gbá̱ng onəm oga mpyal awop aYawe chit.>>
\p 
\v 22 Te uDawuda là ûAbiyatar pa̱, <<Ka̱ awalang va̱ n ya uDoyek unəm oga Edom ka̱ta n̂da va̱ ta te, n nyi nkpak pa̱ uza̱ i ləlà ûShawulu. Ka̱kul mi na mmá gbá̱ng onəm oga nzhi ɓu pa̱ kpaktak.
\v 23 Təm ká̱ mi, kang ayər a nəm ɓu ka̱t. Unəm va̱ kà̱ nɗom ngbá̱l ɓu te, kà̱ nɗom ngba̱l mi na kpa. Nzəng ka̱ mi te, iya̱m iro i nəm ɓu ka̱t.>>
\c 23
\s1 UDawuda ka̱mshi aKeyila
\p 
\v 1 Awalang va̱ mmá là ûDawuda pa̱, <<OFilisti ka̱ nlung ìkum ká̱ aKeyila, kang ka̱ ngwur ìpirkur ká̱ ayi ka̱ atak mpə́k iya̱m,>>
\v 2 te uza̱ ɓəp uYawe pa̱, <<N ga na n ru oFilisti va̱ta ká̱ ìkum ɗò?>>
\p UYawe na ama̱n á na pa̱, <<Ga na u ru oFilisti ká̱ ìkum, na u ka̱mshi aKeyila.>>
\p 
\v 3 Ǹnyi te, onəm aDawuda là á na pa̱, <<Ka̱ ta̱, ka̱ ashe mbin aYahuda te, mmayi ka̱ ntəm ká̱ ayər, te i yà sáng kang pa̱ i ga aKeyila na i lung oshozha oFilisti yà?>>
\p 
\v 4 UDawuda ɓəp uYawe kà̱ɗi, kang uYawe na ama̱n á na pa̱, <<Ga aKeyila, ka̱kul mmami kà̱ ngga nna oFilisti ka̱ ashe awo ɓu.>>
\v 5 Te uDawuda ká̱ onəm wò ga aKeyila. Oza̱ nyán ka̱ oFilisti kang à gbá̱ng oza̱ pa̱ makmak, oza̱ wur iya̱m nkang oza̱, kang oza̱ ka̱mshi onəm oga aKeyila.
\v 6 Awalang va̱ uAbiyatar uya aAhimelek chər ga atak aDawuda ka̱ aKeyila te, uwa ka̱ ya ká̱ ìlukwan ìkwoksok.
\s1 UShawulu ɓàk nva̱ng aDawuda
\p 
\v 7 UShawulu fe pa̱ uDawuda ka̱ aKeyila te, uza̱ là pa̱, <<A ɓyen paɗi, Inan ná na chit ka̱ ashe awo mi. Ka̱kul uza̱ tar ajəp chit, nva̱ uza̱ tar ashe ìtong va mmá ká ká̱ akamsəlang kang mí kùk anunung kùk ká̱ ndar acham nnárnàr.>>
\v 8 Te uShawulu wór nkpaktak oshozha wò ka̱kul ìkum, pa̱ oza̱ á ga aKeyila oza̱ á gang uDawuda ká̱ onənəm.
\p 
\v 9 Awalang va̱ uDawuda fe iya̱m iɓá̱ngɓa̱ng va̱ uShawulu kà̱ nɗom nnənəm a na te, uza̱ là ûAbiyatar unəm uga mpyal awop pa̱, <<Ɓa ká̱ ìlukwan ìkwoksok va̱ ka̱ ta̱.>>
\v 10 Te uDawuda far pa̱, << ÁYawe, Inan oIsa̱rila, n fe pa̱ uShawulu kà̱ nɗom pa̱ ô ɓa ô zhì aKeyila ka̱kul mi.
\v 11 Onəm oga aKeyila i na mi na á na ɗò? UShawulu i vəvang wa nva̱ mmami uzwal ɓu nfe ɗò? ÁYawe, Inan oIsa̱rila, là ûzwal ɓu.>>
\p Te uYawe na ama̱n pa̱, <<Uza̱ i vəvang.>>
\p 
\v 12 UDawuda ɓəp kà̱ɗi pa̱, <<Onəm oga aKeyila i na mi na ká̱ onəm mi ûShawulu ɗò?>>
\p Te uYawe ma̱n pa̱, <<Oza̱ i na wó na.>>
\p 
\v 13 Te uDawuda ká̱ onəm wò ìgba̱l pa̱ ìkpa̱ɗing fa re aKeyila, oza̱ i ranggang atak pa̱ kpakpa. Awalang va̱ uShawulu fe chit pa̱ uDawuda fa chit re ashe aKeyila, te uza̱ ɗak ngga a ta lap ka̱t.
\p 
\v 14 UDawuda təm ka̱ atak mbwam ka̱ aɗuktum aga ashe nzam mmaləng aZif. UShawulu nəm inok nram na ka̱ ashe nzam nra ka̱ apal nra, ǹnyi te, Inan ná na ka̱ ashe awo aShawulu ka̱t.
\p 
\v 15 Nva̱ uDawuda uwa ka̱ yà ka̱ aHoresh ka̱ ashe nzam aZif te, uza̱ fe pa̱ uShawulu fa ka̱ nram na pa̱ na ô gbá̱l.
\v 16 Kang uJonatan uya àShawulu ga atak aDawuda ka̱ aHoresh, á na nkám ìrəng á na pa̱ uza̱ á sat kà̱ Inan á kəkam.
\v 17 UJonatan là á na pa̱, <<Kang ayər á nəm ɓu ka̱t. Awo apo mi uShawulu i yà ka̱ ndok ɓu ka̱t. Mmaɓu ka̱ ngga ǹya uponzhi oIsa̱rila, kang mi yà uga uparəm ɓu. Upo mi uShawulu nyi nva̱ ta nyi.>>
\v 18 Mparəm oza̱ yar nsar nnap-nlà owan oza̱ ka̱ mpyal àYawe. Te uJonatan le nzhi ǹnyi te, uDawuda təm ka̱ aHoresh.
\p 
\v 19 Onəm oga aZif ga atak uShawulu ka̱ aGibeya kang oza̱ là á na pa̱, << UDawuda uwa yà kà̱ mbwam ka̱ ashe yi, ka̱ atak mbwam ngga aHoresh ka̱ aɗuktum aHakila, ava ka̱ nkwandal aJeshimon ka̱t ɗò?
\v 20 Irirì aponzhi a gba̱ng, ìlum va̱ wa ɗom te, wa vàng, í kpan na í na ka̱ ashe awo ɓu.>>
\p 
\v 21 UShawulu na ama̱n pa̱, <<UYawe á nak nnap nnəna̱n á wó, ka̱kul ó nak ishi ká̱ mi.
\v 22 Ó ga na ó ɓəp nnap ka̱ apəpal pa̱ makmak, ó ɓəp atak va̱ uDawuda i ga kà̱, ká̱ onəm va̱ ya na. ka̱kul mmá là á mi pa̱ uza̱ tan byet.
\v 23 Ó ga ó dər na o nyi oga atak va̱ uza̱ i bwam kà̱, na ó ɓa ka̱ nnandərnandər á mi. Te mi ga nzəng ka̱ wó, kang a yà pa̱ u wa ka̱ atak va̱ ta, te mi ram na kà̱ atak va̱ uza̱ bwam kà̱, kà̱ nkpaktak aYahuda.>>
\p 
\v 24 Te oza̱ wong ga aZif mpyal uShawulu. UDawuda ká̱ onəm wò oma ka̱ ashe nzam mmaləng aMayon ka̱ mba̱nda̱m aAraba ka̱ nkwandal aJeshimon.
\v 25 UShawulu ká̱ onəm wò fa kà̱ nram uDawuda, kang nva̱ngva̱ uDawuda fe te, uza̱ fər ga anang aɗuktum aga ashe nzam mmaləng aMayon kang uza̱ təm ka̱ta. Awalang va̱ uShawulu fe chit pa te, uza̱ ɓàk nvəva̱ng ka̱ ashe nzam mmaləng va̱ ta.
\p 
\v 26 UShawulu ká̱ onəm wò kà̱ ngga kà̱ ngba̱k anang aɗuktum nro, ǹnyi te, uDawuda ká̱ onəm wò kà̱ ngba̱k nzəngtəng. UDawuda ka̱ onəm wò kà̱ nggha̱n pa̱ na ó chəng ka̱ atak aShawulu. UShawulu ká̱ onəm wò ɓa dat pa̱ na ó kpán uDawuda ká̱ onənəm te,
\v 27 unəm uga ǹre ɓa là ûShawulu pa̱, <<Ɓa pa̱ kəlak, oFilisti ɓa ru oIsa̱rila chit ká̱ ìkum.>>
\v 28 Te uShawulu re ngwà uDawuda kang à le ga nlung oFilisti. Nna nak te, mmá wór aɗin atak va̱ ta pa̱, aƊuktum aga nKap.
\v 29 Te uDawuda kyén ɓa ga atak mbwam ngga aEngedi təm ka̱ta.
\c 24
\s1 UDawuda re uShawulu ká̱ iriri
\p 
\v 1 Ka̱ nva̱ngva̱ uShawulu le chit ka̱ atak nnəm ìkum ká̱ oFilisti te, mmá là á na pa̱, <<UDawuda uwa ka̱ ashe nzam mmaləng ngga aEngedi.>>
\v 2 Te uShawulu yak oshozha ìkalong pa̱ ishatɗing ka̱ ashe nkpaktak oIsa̱rila pa̱ oza̱ á ga á ram uDawuda ká̱ onəm wò dát ká̱ Ipang Iɓəl iga ashe Nzam.
\p 
\v 3 Nva̱ uShawulu chu atak oga afo itam ka̱ apal asa̱l te, uza̱ tar ashe agba̱k pa̱ na ô man aməng. UDawuda uwa yà kà̱ nkur agba̱k va̱ ta ká̱ onəm wò kà̱ mbwam ka̱ta.
\v 4 Onəm aDawuda là á na pa̱, <<Ìlum va ta̱ uYawe ka̱ là nnap kà̱, nva̱ uza̱ ka̱ là a ɓu pa̱, <Mi na unəm uga nkpang ɓu ka̱ ashe awo ɓu, na u nəm iya̱m va̱ ka̱ na u ɗom á.> >> Te uDawuda nár ga pà arwangchwang ìlukwan aShawulu nzəng ká̱ nnyi aShawulu ka̱t.
\p 
\v 5 Ka̱ nvəva̱ng te, ìgwak aDawuda ra ka̱t, ka̱kul nva̱ uza̱ pà arwangchwang ìlukwan aShawulu á.
\v 6 Uza̱ là ônəm wò pa̱, <<UYawe a kap mi ká̱, nva̱ pa̱ nnəm iya̱m va̱ ta ûnəm uga nzhi mi, ugorgor aYawe, ka̱t te, n dok na ká̱ awo mi ka̱kul uza̱ uwa ugorgor aYawe.>>
\v 7 Ká̱ oga nnap-nlà va ta̱ uDawuda ra̱n ká̱ onəm wò, kang uza̱ gəl oza̱ kà̱ ngbá̱l uShawulu. Te uShawulu fa ka̱ ashe agba̱k ga iya̱m wò.
\p 
\v 8 Te uDawuda fa ka̱ ashe agba̱k kang à wór uShawulu pa̱ gbá̱ngbá̱ng pa̱, <<Ánəm uga nzhi mi, uponzhi.>> Ka̱ awalang va̱ uShawulu ga̱ɓa̱n ya uDawuda te, uDawuda ru zəp ká̱ afu kà̱ mbin.
\v 9 Uza̱ là ûShawulu pa̱, <<Sang kang ɓu gwong achwang kà̱ onəm va̱ là pa̱, <UDawuda kà̱ nɗom nnəm inga a ɓu> yà?
\v 10 N̂da va̱ ta̱ u ya chit ká̱ iwu ɓu asa̱l va̱ uYawe na ɓu ka̱ ashe awo mi, awalang va̱ na u yà ka̱ ashe agba̱k. Onəm oro là pa̱ ń gbá̱l ɓu, ǹnyi te, n re ɓu ká̱ iriri. N là pa̱, <Mi nak awo mi ka̱ apal anəm uga nzhi mi ka̱t, ka̱kul uza̱ ugorgor aYawe.>
\v 11 Apo mi, dər arwangchwang ìlukwan ɓu ka̱ ashe awo mi. M pà arwangchwang ìlukwan ɓu, ǹnyi te, n gbá̱l ɓu ka̱t. Iya̱m iro yà ka̱ ashe awo mi va̱ nyám pa̱, mmami ká̱ mpat, ka̱t te n fa iya̱mkak ka̱t. N nəm mpat a ɓu ka̱t, ǹnyi te, mmaɓu kà̱ nram mi pa̱ ú gbá̱l.
\v 12 Re uYawe á nap akwali ká̱ ishimshe mi ká̱ ɓu. Kang re uYawe a pyat mpat va̱ u nəm a mi, ǹnyi te, awo mi i yà ká̱ ndok ɓu ka̱t.
\v 13 Wa nva̱ ntar achu mmatmat là pa̱, <Ka̱ ashe onəm onga na, iya̱m inga i fa.> Ka̱kul nva̱ ta te, awo mi i yà ká̱ ndok ɓu ka̱t.
\p 
\v 14 <<Mmaɓu va̱ uPonzhi oIsa̱rila, uda u fa pa̱ u lung yà? Uda ɓu ɓak yà? Aməma pa̱ u lak awalang ɓu kà̱ mɓak ìva ikuku, ka̱t te ìbebe wa nji mi ɗò?
\v 15 Re uYawe á nap akwali á yi na uza̱ a va̱n nnandər ká̱ ishimshe yi. Re uza̱ a yà unəm uga nka̱mshi mi, uza̱ i ka̱mshi mi ka̱ ashe awo ɓu.>>
\p 
\v 16 Nva̱ngva̱ uDawuda gba̱l ka̱ nlà nnap va̱ ta̱ te, uShawulu ɓəp pa̱, <<Ìchu ɓu yà ɗò, ayen mi, uDawuda?>> Kang uza̱ yə́ng pa̱ gbá̱nggbá̱ng.
\v 17 Uza̱ là ûDawuda pa̱, <<U ji mi ji ká̱ nnandər. U nəm ikin á mi, ǹnyi te, n nəm iɓá̱ngɓa̱ng á ɓu.
\v 18 Ǹyangmata̱ u là á mi chit inəna̱n va̱ u nəm á mi, uYawe na mi ka̱ ashe awo ɓu, ǹnyi te, u gbá̱l mi ka̱t.
\v 19 Uda pa̱ wat, i ya ukpa ìkum wò ka̱ ashe awo kang i re i ga ká̱ ikángkáng yà? Re uYawe á mwa ɓu ká̱ inəna̱n ka̱kul inəna̱n va̱ u nəm á mi n̂da va̱ ta̱ á.
\v 20 N nyi chit ǹyangmata̱ pa̱ ɓu ga ǹya uponzhi kang iponzhi oIsa̱rila i ga mpyal ka̱ ashe awo ɓu.
\v 21 Ǹyangmata̱, sóng anung á mi kà̱ mpyal àYawe pa̱ ɓu yà ká̱ ngbá̱ng akum ìjili mi, ka̱t te ɓu dərkən aɗin mi ka̱ ashe nzhi apo mi ka̱t .>>
\p 
\v 22 Te uDawuda yar nsar nnap-nlà wò ûShawulu. Te uShawulu ga nzhi, ǹnyi te, uDawuda ká̱ onunggwan wò le kyen ga atak mbwam oza̱.
\c 25
\s1 UDawuda ká̱ uNabal ká̱ uAbigel
\p 
\v 1 Ka̱ nvəva̱ng te, uSamuwel kú, kang nkpaktak oIsa̱rila ɓut ka̱kul ǹyə́ng ikuku. Oza̱ li na ka̱ nzhizhi ka̱ aRama. Te uDawuda wong ga ashe nzam mmaləng aParan.
\v 2 Unəm uro uwa yà ka̱ aMayon ká̱ iya̱m nkang ka̱ aKarmel kang à dur byet. Uza̱ ká̱ iɓəl ìkalong kang itam ìkalong pa̱ ishatɗing kang u wa kà̱ nkpat akpap itam wò ka̱ aKarmel.
\v 3 Unəm va̱ ta aɗiɗin ka̱ yà pa̱ uNabal, uchichar aɗiɗin ka̱ yà pa̱ uAbigel. Uza̱ ka̱ yà uchar uɓyenɓyen uga aghan, ǹnyi te, uɓəɓar unəm uga mɓa̱ng ka̱ afu kang à yà ká̱ aɗor ka̱t ka̱ ashe iya̱m va̱ uza̱ i nəm, uza̱ ka̱ yà ka̱ akum ìjili aKalip.
\p 
\v 4 Awalang va̱ uDawuda ka̱ ashe nzam mmaləng te, uza̱ fe pa̱ uNabal kà̱ nkpat akpap itam wò.
\v 5 Te uza̱ re ovan nza̱m wò pa̱ ogba̱pchi, kang à là ôza̱ pa̱, <<O ga atak aNabal ka̱ aKarmel na o re anung á na ka̱ ashe aɗin mi.
\v 6 Ó là á na pa̱, <Irirì ɓu á təm mbyet, nnap nnəna̱n a yà ka̱ apal ishi ɓu ká̱ nzhi ɓu, ká̱ nkpaktak iya̱m va̱ mmaɓu ká̱ á.
\p 
\v 7 << <N fe pa̱ mmaɓu kà̱ nkpat akpap itam ɓu. Awalang va̱ onəm oga nkpak iya̱m nkang ɓu təm ka̱ ashe yi ka̱ aKarmel te, í nyán ká̱ oza̱ ka̱t kang iya̱m oza̱ iro yà lar ka̱t.
\v 8 Ɓəp okpari ɓu, te oza̱ i là a ɓu pa̱ wanta na. Ka̱kul nva̱ ta te, nəm nka̱mshi ônəm mi, ka̱kul i ɓa ka̱ awalang aga nnəm nchang izər. Kusuk na ozwal ɓu ká̱ uyen ɓu uDawuda iya̱m va̱ pa̱ kap u ya màl pa̱ u na ôza̱.> >>
\p 
\v 9 Nva̱ngva̱ onəm aDawuda chu te, oza̱ là ǹre va̱ ta ûNabal ka̱ ashe aɗin aDawuda. Te oza̱ lok pa̱ ó fe aməma̱n.
\p 
\v 10 UNabal na ama̱n ôkpari aDawuda pa̱, <<Uda uDawuda va̱ yà? Uya àJese va̱ uda yà? Ka̱ ashe oga nra va̱ ta̱ te, okpari onəm pa̱ makmak fa iya̱mkak ká̱ onəm oga nzhi oza̱.
\v 11 Ka̱kul iza̱ kang mi yar nzəngkəng mi ká̱ ndəng ngwa mi, ká̱ izhé va̱ m pà ka̱kul onəm oga kpat akpap iya̱m nkang mi, mi na onunggwan ova mmá nyi atak va̱ oza̱ fa ka̱ ka̱t yà?>>
\p 
\v 12 Te ovan nza̱m va̱ uDawuda re te, le ga là á na iya̱m va̱ uNabal là pa̱ kpaktak.
\v 13 Te uDawuda là ôza̱ pa̱, <<Uda nggo á gal ndokchi wò.>> Te nkpaktak oza̱ gal ndokchi oza̱, kang uDawuda gal ndokchi nji wò kpa. Onunggwan chu ìgba̱l chu pa̱ ineɗing yar nva̱ng aDawuda, kang mmá re onunggwan ìgba̱l pa̱ iparəm pa̱ a pángchí iya̱m ìkum oza̱.
\p 
\v 14 Uzəngtəng ka̱ ashe okpari aNabal là ûAbigel, uchar aNabal pa̱, <<UDawuda re okpari wò ka̱ ashe nzam mmaləng pa̱ á ná nre anung wò ûnəm uga nzhi yi, ǹnyi te, uza̱ pwat oza̱.
\v 15 Ká̱ nna kpa te, onunggwan va̱ ta nəm inəna̱n á yi byet. I ɓək anung ka̱ ashe awo oza̱ ka̱t, nkpaktak awalang va̱ mmayi ka̱ atak nkpak iya̱m nkang nzəng ká̱ oza̱ te, iya̱m iro yà lar ká̱ yi ka̱t.
\v 16 Oza̱ gang yi wa akamsəlang izwam ká̱ alum. Oza̱ ipángchí yi nkpaktak awalang va̱ mmayi kà̱ nkpak itam dat ka̱ oza̱.
\v 17 Ǹyangmata̱ rəng nnap pa̱ dakdak kang ɓu dər iya̱m va̱ mal pa̱ u nəm, ka̱kul mɓək anung i ga ǹya ûnəm uga nzhi yi ka̱ nkpaktak nzhizhi. Ka̱kul uza̱ unəm ulakchilakchi uva unəm uro i là nnap á na i ka̱m ka̱t.>>
\p 
\v 18 UAbigel gha̱n wur oga nzəngkəng ìgba̱l pa̱ ìparəm, ká̱ ndəng iba̱ngba̱ng ka̱ ashe awa pa̱ parəm, ká̱ itam pa̱ itukun iva mmá pà mmá pək chit, ká̱ ìpir ikur iforfor ikpang iga mma iya̱m pa̱ igba̱pchi ama̱n pa̱ shatɗing, ká̱ mɓit awar iba̱ngba̱ng va wom chit ìgba̱l, ká̱ mɓit awar ipipyan ìgba̱l pa̱ ìparəm va wom chit. Uza̱ ɓak oza̱ ka̱ apal oga azhaki.
\v 19 Te uza̱ là ôkpari wò pa̱, <<Ó gəga kang mi ɓa ka̱ nva̱ng wó.>> Ǹnyi te, uza̱ là atak ngga wò uɓar wò uNabal ka̱t.
\p 
\v 20 Nva̱ uza̱ kà̱ nkwak azhaki wò ga chu akum aɓam te, uDawuda uwa ta̱ ká̱ onəm wò kà̱ nfəng nvang, te uza̱ gwang oza̱.
\v 21 UDawuda ka̱ là pa̱, <<A sat iya̱m ilakchi nva̱ n pak inok nnak ishi ká̱ iya̱m anəm va̱ ta̱ ka̱ ashe nzam mmaləng, kang iyəya̱m iro yà ka̱ lar ka̱t. N nəm inəna̱n á na ǹnyi te, uza̱ mwa mi ká̱ inga.
\v 22 Re Inan á zhì mi, a yà pa̱ ìpin ká̱ ìɓotak kang n re ununggwan uro re ká̱ irirì ka̱ ashe nzhizhi pa̱ uzəng á.>>
\p 
\v 23 Awalang va̱ uAbigel ya uDawuda te, uza̱ fər ka̱ apal azhaki wò pa̱ kəlak, uza̱ ru zəp ká̱ afu ka̱ mbin ka̱ mpipyal.
\v 24 Uza̱ ru ka̱ apal ashəshar uza̱ là pa̱, <<Yar mpat ûzwal ɓu, anəm uga nzhi mi. Re n là nnap ka̱ ɓu, gwong achwang ká̱ iya̱m va̱ uzwal ɓu ká̱ pa̱ ô là.
\v 25 Kang unəm uga nzhi mi á nak ishi ká̱ uNabal unəm ulakchilakchi ka̱t, ka̱kul uza̱ wa aɗiɗin. Ipir aɗiɗin pa̱ mpərək, kang nnəm mpərək i kap ká̱ na ka̱t. Kang wa mmami uzwal ɓu ǹnyi te, n ya onəm va̱ u re nre ká̱ ka̱t.
\v 26 Ǹyangmata̱, ánəm uga nzhi mi, wa nva uYawe Inan ɓu uwa ka̱ irirì, kang wa nva na u ya ka̱ irirì, ka̱kul uYawe ka̱ dang ɓu chit ka̱ ntar nchə̀r ká̱ mpyat mpat, re nkpaktak okpa ìkum ɓu ká̱ ovəngva̱ ka̱ nɗom pa̱ ó nəm inga á ɓu a ya wa aNabal.
\v 27 Re unəm uga nzhi mi a ka̱m imwa va̱ ta̱ uzwal ɓu ɓa ká̱ á ɓu, na u ná ôvan nza̱m va̱ nzəng ká̱ ɓu.
\p 
\v 28 <<N chal ɓu yar mpat uzwal ɓu a yà pa̱ m pat a ɓu ká̱ asa̱l aro á. UYawe Inan ɓu, i nak iponzhi iga akum ìjili ɓu i təm mbyet, ka̱kul ìkum va̱ mmaɓu ka̱ nlulung te, iji àYawe. Re mpat nro a yà ka̱ ɓu ka̱t ka̱ ashe nkpaktak irirì ɓu.
\v 29 A yà pa̱ unəm uro wong pa̱ ô ram irirì ɓu te, uYawe, Inan ɓu uwa i kpak irirì ɓu ká̱ ikángkáng ka̱ ashe onəm oga irirì. Ǹnyi te, uYawe i mang irirì okpa ìkum ɓu wa nva mí mang ìpang ká̱ nchwalak á.
\v 30 Nva̱ngva̱ uYawe a yəl nkpaktak iya̱m inəna̱n va̱ uza̱ yar nsar nnap-nlà ûnəm uga nzhi mi kà̱ kang uza̱ nak na chit uponzhi oIsa̱rila te,
\v 31 kang ìgwak ɓu a nak ɓu pa̱ mmaɓu ká̱ mpat ka̱t, ka̱t te, ɓu nak pa̱ na u yà ká̱ nchə̀r ka̱ awo ɓu ka̱t, kang wa pyat mpat ká̱ ishi ɓu ka̱t. Nva̱ngva̱ uYawe Inan ɓu a na igwan ûnəm uga nzhi mi te, wa rəng ká̱ uzwal ɓu.>>
\p 
\v 32 UDawuda là ûAbigel pa̱, <<Ashep təm aji aYawe, Inan oIsa̱rila, uva re ɓu chit n̂da va̱ ta̱ pa̱ u gwang mi á.
\v 33 Re nnap nnəna̱n a təm ka̱ apal ɓu ka̱kul aghan ɓu, nva̱ u ɗa̱t mi kà̱ ntar nchə̀r kang u ɗa̱t mi ka̱ mpyat mpat ká̱ ishi mi kpa n̂da va̱ ta̱ á.
\v 34 UYawe ɗa̱t mi ka̱ nnəm iɓá̱ngɓa̱ng a ɓu. Ká̱ yà pa̱ u mor u gha̱n u gwang mi ta̱ ka̱t te, n sóng anung a ɓu ká̱ uYawe Inan oIsa̱rila uga irirì pa̱, ìpin te, ununggwan àNabal uro yà pa̱ uzəng uva̱ mmá ká̱ re ká̱ irirì ka̱t.>>
\p 
\v 35 Te uDawuda ka̱m imwa va̱ uza̱ ɓa ká̱ ka̱ awuwo, kang à là á na pa̱, <<Ga nzhi ká̱ ikángkáng. N fe iya̱m va̱ chit u là, kang mi nəm iya̱m va̱ nəm u ɗom.>>
\p 
\v 36 Awalang va̱ uAbigel le te, á ya uNabal kà̱ nzhi kà̱ nnəm mɓut ngga nchang izər wa apir nja aponzhi. Uza̱ ka̱ ashe nchang izər kang à wa iya̱m iwawa gbá̱l na pa̱ gənggəng te, uAbigel là iya̱m iro á na ka̱t ipin fa kpa̱k kang.
\v 37 Ká̱ ipin awalang va̱ nnap nnəm aNabal ɓa izəzər chit, te uchichar là á na iya̱m va̱ fa pa̱ kpaktak te, ìchəgwak ləp na, uza̱ yà wa ìpang.
\v 38 Kà̱ nva̱ng nra pa̱ ngba̱pchi te, uYawe ləp uNabal kang uza̱ kú.
\s1 UDawuda ka̱m ichar ká̱ uAbigel
\p 
\v 39 Awalang va̱ uDawuda fe pa̱ uNabal kú chit, te uza̱ là pa̱, <<Ashep təm aji aYawe, uva sat ka̱ apal mi ka̱ awalang va̱ uNabal ɓak mi. UYawe ɗa̱t mi kà̱ nnəm inga kang uza̱ le ká̱ inga aNabal á na chit ka̱ apal ishishi.>>
\p Te uDawuda re nrè ûAbigel pa̱, uza̱ a ma̱n ô ka̱m na a yà uchar wò.
\v 40 Awalang va̱ onəm oga ǹre àDawuda ga aKarmel te, oza̱ là ûAbigel pa̱, <<UDawuda á re yi pa̱, í ka̱m ɓu i ɓa ká̱ na ú yà uchar wò.>>
\p 
\v 41 UAbigel ru zəp ká̱ afu ka̱ mbin, kang à là pa̱, <<Mmami uzuzwal kang m məma̱n pa̱ n nəm inok á na kang mì nàl ashar ozwal anəm uga nzhi mi.>>
\v 42 UAbigel wong pa̱ kəlak kyen azhaki, kang ovan ɓyen oga nnəm inok á na pa̱ otukun yar nvəva̱ng, kang uza̱ ga nzəng ká̱ onəm oga nre va̱ uDawuda re á. Te uza̱ ga təm uchar àDawuda.
\v 43 UDawuda ka̱m ichar ká̱ uAhinowam uga aJezireyel kpa, kang oza̱ pa̱ oparəm va̱ ta tong ochəchar.
\v 44 UShawulu ka̱ yar uyen wò uMikal uchar àDawuda chit, ná ûPalti uya àLayish unəm uga aGalim, a təm uchəchar.
\c 26
\s1 UDawuda re uShawulu ká̱ irirì ka̱ɗi
\p 
\v 1 Onəm oga aZip ga atak aShawulu ka̱ aGibeya oza̱ là á na pa̱, <<UDawuda uwa ka̱ mbwam ka̱ aɗuktum aHakila, ava dər aJeshimon ka̱t ɗò?>>
\p 
\v 2 Te uShawulu yak oshozha ìkalong pa̱ ishatɗing ka̱ ashe oIsa̱rila va̱ fa ga ká̱ ka̱ ashe nzam mmaləng aZip, pa̱ na ó ram uDawuda.
\v 3 UShawulu ləp apa̱k ka̱ ngba̱k asa̱l ka̱ apal aɗuktum aHakila, a va dər asa̱l awu aJeshimon, ǹnyi te, uDawuda təm ka̱ ashe nzam mmaləng. Awalang va̱ uDawuda fe chit pa̱ uShawulu ka̱ mɓàk nva̱ng wò ka̱ ta,
\v 4 uza̱ re onəm oga nsòng mbin, kang uza̱ ga nyi pa̱ uShawulu uwa ka̱ ta.
\p 
\v 5 Te uDawuda wong ga atak va̱ uShawulu ləp apa̱k kà̱ te, uza̱ ya atak va̱ uShawulu ká̱ uAbner uya àNer, unəm uga mpyal oshozhashozha ra kà̱. UShawulu kà̱ nra ka̱ ashe apa̱k, ká̱ oshozha ra gang na.
\p 
\v 6 Te UDawuda ɓəp uAhimelek unəm oHiti ká̱ uAbishayi uya àZeruya, ugənang àJowap pa̱, <<Uda i məma̱n i ga nzəng ká̱ mi ka̱ ashe apa̱k aShawulu yà?>>
\p Te uAbishayi ma̱n pa̱, <<M məma̱n, mi ga nzəng ká̱ ɓu.>>
\p 
\v 7 Te uDawuda ká̱ uAbishayi ga ashe apa̱k aShawulu ká̱ ìzwam, kang oza̱ ya na kà̱ nra nda ka̱ ashe apa̱k kang aɓəɓar na pak ka̱ mbin dat ká̱ ishishi. UAbner ká̱ aɓo oshozha oma kà̱ nra nda gang na.
\p 
\v 8 UAbishayi là ûDawuda pa̱, <<Inan na unəm uga nkpang ɓu chit ka̱ ashe awo ɓu n̂da va̱ ta̱. Ǹyangmata̱ re n tar na ká̱ aɓár á ga á fu ka̱ mbin pa̱ nzəng pa̱ ták, mi ya ka̱ ndan pa̱ mparəm ka̱t.>>
\p 
\v 9 Ǹnyi te, uDawuda là ûAbishayi pa̱, <<Kang wa zhì na ka̱t. Uda i nak awo ka̱ apal anəm va̱ uYawe gar kang i yà ká̱ mpat ka̱t yà?>>
\v 10 UDawuda ga mpyal ká̱ nlà pa̱, <<Wa nva̱ uYawe uwa yà ká̱ irirì te, uYawe uwa i gbá̱l na ká̱ ishi wò, ka̱t te nra ngga ikuku na i ɓa kang uza̱ i kú, ka̱t te mí gbá̱l na ka̱ atak ìkum.
\v 11 UYawe á dáng mi nva̱ pa̱ n gbá̱l unəm va̱ uza̱ gar á. Ǹyangmata̱ te, yar aɓəɓar ká̱ aba̱ng ndədəng va̱ dat ká̱ ishishi, na í ga.>>
\p 
\v 12 Te uDawuda yar aɓəɓar ká̱ aba̱ng ndədəng va̱ dat ká̱ ishishi, kang oza̱ le. Unəm uro ya oza̱ ka̱t te a nnyi iya̱m iro ka̱ apəpal ka̱t, le kang unəm uro ì yenda̱l. Nkpaktak oza̱ oma kà̱ nra nda, ka̱kul uYawe nak oza̱ chit ra nda nɗəkɗək.
\p 
\v 13 Te uDawuda pa̱l ngba̱k nro kang à sat ka̱ apal ishi aɗuktum a va gbəgba̱ng ka̱ atak apa̱k aShawulu. Kang anang agbagba na yà ka̱ ishimshe oza̱.
\v 14 Te uza̱ ləp achu ôshozha ká̱ uAbner uya àNer pa̱, <<Mmaɓu kà̱ nfe mi ɗò, áAbner.>>
\p Te uAbner na ama̱n pa̱, <<Mmaɓu uda ɓu wór uponzhi yà?>>
\p 
\v 15 UDawuda là pa̱, <<Mmaɓu nza̱ apir anəm yà? Uda wa mmaɓu ka̱ ashe oIsa̱rila yà? Iza̱ nak kang u pángchí unəm uga nzhi ɓu uponzhi ka̱t yà? Nna gba̱ng nva̱ng chit ka̱t unəm uro ɓa pa̱ u gbá̱l unəm uga nzhi ɓu uponzhi.
\v 16 ÁAbner, iya̱m va̱ ta̱ u nəm ta̱ á ɓyen ka̱t. Wa nva̱ uYawe uwa yà ká̱ irirì te, mmaɓu ká̱ onunggwan ɓu nkpak pa̱ ó kú, ka̱kul ó pángchí unəm uga nzhi wó, ugargar àYawe ka̱t. Ó dər, aɓár ká̱ aba̱ng ndəng àponzhi va̱ ka̱ dat ká̱ ishishi te, ka̱ che yà?>>
\p 
\v 17 Nva̱ngva̱ uShawulu nyi ichu àDawuda te, uza̱ là pa̱, <<Ichu ɓu yà ɗò, ayen mi, uDawuda?>>
\p Te uDawuda na ama̱n pa̱, <<À ichu mi yà, anəm uga nzhi mi, áponzhi.>>
\v 18 UDawuda ga mpyal ká̱ nlà pa̱, <<Iza̱ ɓu ɓàk uzwal ɓu ka̱ yà, anəm uga nzhi mi? Iza̱ n nəm yà, kang iza̱ mpat mi yà?
\v 19 Ǹyangmata̱ re unəm uga nzhi mi uponzhi á gwong achwang ka̱ nnap-nlà azwal wò. A yà pa̱ uYawe à nok ɓu pa̱ na u nəm ìkum ká̱ mi te, re uza̱ á ka̱m iya̱m inana mi. Ǹnyi te, a yà pa̱ nnap va̱ ta̱ onəm à nəm te, re uYawe á vyap oza̱. Oza̱ ɓàk mi ká̱ n̂da va̱ ta̱ ka̱kul pa̱ na kang n ya nkap ka̱ ashe iya̱m akup aYawe ka̱t, kang oza̱ là pa̱,<Ga wop inan iro.>
\v 20 Ǹyangmata̱ kang wa re mmá gbá̱l mi ka̱ ashe mbin nkak va gbəgba̱ng ká̱ mpyal àYawe ka̱t. Sang kang uponzhi oIsa̱rila i fa nram ìbebe wa mmami pa̱ ô gba̱l yà? Sang kang ɓu fa abar mi wa inyil iro iga apal aɓam yà?>>
\p 
\v 21 Te uShawulu là pa̱, <<N nəm nnap mɓá̱ngɓa̱ng chit, le ɓa, ayen mi uDawuda. Mi yà ká̱ nnəm iya̱m iro a ɓu lap ka̱t, ka̱kul nva̱ u dər irirì mi ká̱ ichumchum kang u re mi n̂da va̱ ta̱ á. N nəm mpərək, mpat ɓa̱ng byet.>>
\p 
\v 22 UDawuda là pa̱, <<Aɓár ɓu na ta̱, áponzhi. Re uro ka̱ ashe ovan nza̱m ɓu á ɓa na á ka̱m.
\v 23 UYawe i mwa udanggo ka̱kul inəna̱nnəna̱n ká̱ nna nnandərnandər. UYawe na ɓu ka̱ ashe awo mi ká̱ n̂da va̱ ta̱, ǹnyi te, n ndok ugargar àYawe ka̱t.
\v 24 Wa nva n dər irirì ɓu ká̱ ichumchum ká̱ n̂da va̱ ta̱ te, re uYawe a dər irirì mi ká̱ ichumchum, kang ì fa ka̱ mi ka̱ ashe nkpaktak mɓək anung.>>
\p 
\v 25 Te uShawulu là ûDawuda pa̱, <<Re nnap nnəna̱n á yà ka̱ apal ɓu, ayen mi, uDawuda. Ɓu ga nnəm oga iya̱m ichumchum, kang ɓu nəm igwan pa̱ makmak.>>
\p Te uDawuda ga iya̱m wò, kang uShawulu le nzhi.
\c 27
\s1 UDawuda təm ka̱ ashe oFilisti
\p 
\v 1 Ǹnyi te, uDawuda kat ka̱ ashe ìgwak wò, á là pa̱, <<N̂da nro na mi wong mi kú ka̱ ashe awo aShawulu. Iya̱m va̱ ɓyen pa̱ n nəm te, mi chər mi ga mbin oFilisti. Te uShawulu i re nram mi ɗak ka̱ ashe mbin oIsa̱rila, kang mi fa ka̱ ashe awuwo.>>
\p 
\v 2 Te uDawuda ká̱ onunggwan wò ìgba̱l pa̱ ìkpa̱ɗing oza̱ ga atak aAkish uya aMayok, uponzhi uga aGat.
\v 3 UDawuda ká̱ onunggwan wò ká̱ nzhi oza̱ təm ka̱ atak aAkish ka̱ aGat. UDawuda ga nzəng ká̱ ochar wò oga oparəm, uAhinoyam uyen uga aJezerel, ká̱ uAbigel uyen uga aKarmel, uchar ukpələng àNabal.
\v 4 Nva̱ngva̱ mmá là ûShawulu pa̱ uDawuda chər chit ga aGat te, uza̱ re nram na.
\p 
\v 5 Te uDawuda là ûAkish pa̱, <<A yà pa̱ nchə̀r mi bəba̱l kà̱ mpyal ɓu te, na atak aro á mi ka̱ ashe ivan itong n təm kà̱. A màl pa̱ uzwal ɓu a təm nzəng ká̱ ɓu ka̱ ashe ìnang ìtong iga iponzhi ka̱t.>>
\p 
\v 6 Te n̂da va̱ ta uAkish na ìtong aZiklak á na, nna nak te, aZiklak təm ajiwo oponzhi oga aYahuda a ɓa chu nda va̱ ta̱.
\v 7 UDawuda təm kà̱ mbin oFilisti ìzun pa̱ ìzəng ká̱ ape pa̱ neɗing.
\p 
\v 8 Ǹyangmata̱ uDawuda ká̱ onəm wò nəm inok ngga ka̱ ìkum onəm oga aGeshur, ká̱ aGirzi, ká̱ aAmalek. Ká̱ mmatmat te, onəm va ta̱ təm ka̱ mbin va̱ ta ga chu aShur ká̱ aMasar.
\v 9 Awalang va̱ uDawuda i ru atak ká̱ ìkum te, uza̱ i re ununggwan ka̱t te uchar ká̱ irirì ka̱t. Uza̱ i wur itam, ká̱ ina, ká̱ oga azhaki ká̱ oga alakəmi, ká̱ ilukwan. Te uza̱ i le atak aAkish.
\p 
\v 10 Awalang aro te uAkish i ɓəp pa̱, <<U ga ìkum ka̱ che nda va̱ ta̱ yà?>> Te uDawuda i là pa̱, <<N ga kà̱ nkwandal aYahuda>> ka̱t te, <<Kà̱ nkwandal aJerameyel>> ka̱t te, <<Kà̱ nkwandal oKeni.>>
\v 11 UDawuda i re ununggwan ka̱t te uchar ká̱ irirì ka̱t, ka̱kul kang oza̱ a ga aGat a là pa̱, <<Iya̱m va ta̱ uDawuda nəm.>> Nnap nnənəm nata uza̱ i nəm pa̱ ɗəkər nva̱ uza̱ ka̱ ntəm ka̱ ashe oFilisti á.
\v 12 UAkish na nnandər ká̱ uDawuda, kang a là îshi wò pa̱, <<Uza̱ sat iya̱m iga ajan chit ônəm wò oIsa̱rila, ǹyangmata̱ te, uza̱ i yà uzwal mi nkpaktak irirìriri.>>
\c 28
\p 
\v 1 Ka̱ ashe oga nra va̱ ta te, oFilisti ɓut oshozha oza̱ pa̱ ó lung ìkum ká̱ oIsa̱rila. Te uAkish là ûDawuda pa̱, <<Á màl pa̱ u nyi pa̱, mmaɓu ká̱ onəm ɓu, i gwang ishi ká̱ mi kà̱ ìkum va̱ ta̱ .>>
\p 
\v 2 UDawuda là pa̱, <<Á chàng byet. Ɓu ya ká̱ ishi ɓu iya̱m va̱ mi nənəm.>>
\p Te uAkish na ama̱n pa̱, <<Dakdak, mi ga nnak ɓu yà ushozha uga mpángchí mi mbyet.>>
\s1 UShawulu ga atak achar uga iva̱k
\p 
\v 3 Ǹyangmata̱ uSamuwel kú chit, kang nkpaktak oIsa̱rila yə́ng ikuku kang oza̱ li na kà̱ ìtutong ka̱ aRama. UShawulu ka̱ wà onəm oga ishi ibolbol ká̱ onəm oga iva̱k chit ka̱ ashe mbin va̱ ta.
\p 
\v 4 OFilisti ɓut kang à ɓa pak apa̱k oza̱ ka̱ aShunem. UShawulu ǹnyi te, ɓut nkpaktak oIsa̱rila kang oza̱ pak apa̱k ka̱ aGilbowa.
\v 5 Awalang va̱ uShawulu ya oshozha oFilisti te, ìchəgwak ləp na, ayər nəm na pa̱ gənggəng.
\v 6 Uza̱ mwo nɗom aYawe, ǹnyi te, uYawe na ama̱n á na ka̱ atak nlár izwam, ka̱t te ka̱ atak aUrim,\f + \fr 28.6 \fq aUrim: \ft Iya̱m va unəm uga mpyal awop i nəm inok ká̱ pa̱ na ô nyi nɗòm Inan.\f* ka̱t te ka̱ atak onəm oga nlà ìchu Inan ka̱t.
\v 7 UShawulu là ônəm oga nəm inok á na pa̱, <<Ó ram uchar uga ishi ibolbol á mi, na n ga m ɓəp na iya̱m va̱ i ga nfa.>>
\p Oza̱ là pa̱, <<Uchar uga ishi ibolbol uro uwa yà ka̱ aEndor.>>
\p 
\v 8 Te uShawulu mwak ìlukwan iro pa̱ɗi na ô lar ishi wò, kang uza̱ ga nzhi achar va̱ ta ká̱ ìzwam ká̱ onəm wò oro pa̱ oparəm. UShawulu là pa̱, <<Wór aruhu anəm ukúkú uro á mi, wong ká̱ unəm va̱ á mi, mi wór aɗiɗin.>>
\p 
\v 9 Ǹnyi te, uchar va̱ ta là á na pa̱, <<Nnandər u nyi iya̱m va̱ nyi uShawulu nəm. Uza̱ ɓàk nkpaktak onəm oga ishi ibolbol ká̱ onəm oga iva̱k ka̱ mbin va̱ ta̱. Te sang kang ɓu lwak ajip á mi ka̱kul pa̱ mmá gbá̱l mi yà?>>
\p 
\v 10 Te uShawulu sóng anung á na ká̱ aɗin aYawe pa̱, <<Wa nva̱ uYawe uwa yà ká̱ irirì te, iya̱m iro yà i ya ɓu ka̱kul nnap va̱ ta̱ ka̱t.>>
\p 
\v 11 Te uchar va̱ ta ɓəp pa̱, << Uda u ɗom pa̱ m ɓa ká̱ na á ɓu yà?>>
\p Te uShawulu là pa̱, <<Le ɓa ká̱ uSamuwel á mi.>>
\p 
\v 12 Awalang va̱ uchar va̱ ta ya uSamuwel te, uza̱ ləp achu pa̱ gbá̱nggbá̱ng kang à là ûShawulu pa̱, <<Sang kang u lam mi yà? Mmaɓu uShawulu.>>
\p 
\v 13 Uponzhi là á na pa̱, <<Kang ayər a nəm ɓu ka̱t. Iza̱ u ya yà?>>
\p Uchar va̱ ta là pa̱, <<N ya aruhu aro kà̱ nfa ka̱ ashe mbin.>>
\p 
\v 14 Uza̱ ɓəp pa̱, <<U ya na wa nsang yà?>>
\p Uchar là pa̱, <<Unəm ugbakgbak pá ìlukwan iwángwang kà̱ nfa.>>
\p Te uShawulu nyi pa̱ uSamuwel, kang uza̱ ru zəp ká̱ afu kà̱ mbin.
\p 
\v 15 USamuwel là ûShawulu pa̱, <<Iza̱ nak kang u ɗak mi ka̱ atak ngwong ká̱ mi wanta̱ yà?>>
\p UShawulu là pa̱, << Mmami ka̱ ashe nɗaktak pa̱ gənggəng. OFilisti kà̱ nlung ìkum ká̱ mi, kang Inan re mi chit. Uza̱ na ama̱n a mi ka̱ atak onəm oga nlà ichu Inan, ka̱t te ka̱ atak nlár izwam lap ka̱t. Nna nak te, n wór ɓu pa̱ na u là iya̱m va̱ á mi, n nəm.>>
\p 
\v 16 USamuwel là pa̱, <<Ɓu ɓəp mi ka̱ iza̱ yà? Nna uYawe re ɓu chit, kang à sat ukpa ìkum ɓu chit á.
\v 17 UYawe nəm chit wa nva̱ uza̱ ka̱ là ka̱ anung mi á. UYawe kakchi iponzhi chit ka̱ awo ɓu, kang à na ûnəm uro uga ndatkulung ká̱ ɓu, uDawuda.
\v 18 Ka̱kul u yang ká̱ nkpak nnap-nlà àYawe ka̱t te ǹnyám nlak ìgugwak ka̱ apal oAmalek te, uYawe nəm iya̱m va̱ ta̱ a ɓu chit n̂da va̱ ta̱.
\v 19 UYawe i ga nna ɓu ká̱ oIsa̱rila ka̱ ashe awo oFilisti, kang ìpin mmaɓu ká̱ ovan ɓu onunggwan ó ga ǹya nzəng ká̱ mi. UYawe i ga nna oshozha oIsa̱rila ka̱ ashe awo oFilisti kpa.>>
\p 
\v 20 Ká̱ nfe nnap-nlà va̱ uSamuwel là á na byet te, uShawulu ru zəp ká̱ afu ka̱ mbin, ka̱kul ayər nəm na pa̱ gənggəng. Uza̱ bəlak ka̱kul uza̱ ri iya̱m iro ka̱ n̂da va̱ ta ka̱t, izwam ká̱ alum.
\p 
\v 21 Awalang va̱ uchar va̱ ta ɓa atak uShawulu te, uza̱ ya na ka̱ ashe nɗaktak pa̱ gənggəng, kang à là á na pa̱, <<Dər, uzwal ɓu a kpak nnap nnəm á ɓu chit. N na irirì mi kang n nəm iya̱m va̱ chit u là á mi pa̱ n nəm.
\v 22 Ǹyangmata̱, kusuk gwong achwang ka̱ iya̱m va̱ uzwal ɓu i là á ɓu. Re n na iya̱m-nrì á ɓu ú ri na ú ya ìkam iga nle.>>
\p 
\v 23 Uza̱ yang kang à là pa̱, <<Mi ri ka̱t.>>
\p Ǹnyi te, onənəm ká̱ uchar va̱ ta gwang chál na kang uza̱ ma̱n, te uza̱ wong kà̱ mbin təm ka̱ apal alyer.
\p 
\v 24 Uchar va̱ ta kpán ìya ìna va̱ uza̱ ka̱ kang ɓyen ka̱ nzhi wò, te uza̱ gha̱n ga kpán pà. Uza̱ kpa̱k mma̱k kál kang uza̱ ɓit nzəngkəng ngga ǹya ká̱ anyer ka̱t.
\v 25 Te uza̱ ɓa ká̱ kà̱ mpyal àShawulu ká̱ onənəm, kang oza̱ ri. Te oza̱ wong kang oza̱ ga ká̱ ìzwam va̱ ta.
\c 29
\s1 UAkish re uDawuda le ga aZiklak
\p 
\v 1 OFilisti ɓut nkpaktak oshozha oza̱ ka̱ aAfek, ǹnyi te, oIsa̱rila ra apa̱k ka̱ anung ndəng mɓəlɓəl ka̱ aJezerel.
\v 2 Nva̱ onəm oga mpyal oFilisti fa chit ká̱ oshozha ìgba̱l ìgba̱l ká̱ ìkalong ìkalong te, uDawuda ká̱ onunggwan wò ka̱ mɓa ka̱ nva̱ng nzəng ká̱ uAkish.
\v 3 Onəm oga mpyal oshozha oFilisti ɓəp pa̱, <<OHiburu va̱ ta̱ i nəm iza̱ ka̱ ta̱ yà?>>
\p UAkish na ama̱n pa̱, <<Unəm va̱ ta̱ uDawuda ukpari aShawulu uponzhi oIsa̱rila. Uza̱ yà chit nzəng ká̱ mi ji ìzun pa̱ izəng, kang na n ya mpat nro chit ka̱ atətak ka̱t ɓàn ka̱ nda va̱ uza̱ re uShawulu ká̱ ɓa chu ǹyangmata̱.>>
\p 
\v 4 Ǹnyi te, ìgwak lak onəm oga mpyal oshozha oFilisti kà̱ uAkish, kang oza̱ là pa̱, <<Re unəm va̱ ta á le a ga atak va̱ u na á na pa̱ uza̱ a təm ka̱. Uza̱ i yà ká̱ ngga ìkum nzəng ká̱ yi ka̱t, le kang uza̱ a wong a ga̱ɓa̱n ìjili ìjang ká̱ yi kà̱ mpyal ìkum ka̱t. Mwote asa̱l va ta uza̱ a ɗa̱mshi ishimshe wò ká̱ ká̱ unəm uga nzhi wò ka̱ atak ngbá̱ng onəm yi nggo.
\v 5 Rəng, uDawuda va ta̱ mí shì nnap ká̱ na ka̱ ashe ngba̱p nza̱m mí là pa̱,
\q1 <<UShawulu gbá̱ng oji wò ikalong,
\q2 kang uDawuda gbá̱ng oji wò ikalong pa̱ igba̱pchi.>>
\p 
\v 6 Te uAkish wór uDawuda là á na pa̱, <<Nva̱ uYawe uwa ká̱ irirì, mmaɓu unəm ukin, n ɗom pa̱ u ga ìkum nzəng ká̱ oshozha mi. A ɓàn ká̱ nda va̱ u ɓa ká̱ te, na n ya ɓu chit ká̱ mpat nro ka̱t ɓa chu n̂da va̱ ta̱. Ǹnyi te, nkpaktak onəm oga mpyal ma̱n ká̱ ɓu ka̱t.
\v 7 Ǹyangmata̱ le ga ká̱ ikángkáng, kang wa nəm iya̱m iro iva i lak ìgwak ônəm oga mpyal oFilisti ka̱t.>>
\p 
\v 8 UDawuda ɓəp pa̱, <<Iza̱ n nəm yà? Nza̱ mpat u ya ukpari ɓu ká̱ ɓan ká̱ n̂da va̱ m ɓa ká̱ ɓa chu ǹyangmata̱ yà? Iza̱ nak kang mi ga mi lung okpa ìkum anəm uga nzhi mi uponzhi ka̱t yà?>>
\p 
\v 9 UAkish na ama̱n pa̱, <<Ka̱ atak mi te, nnap nnəm ɓu á ɓyen ká̱ mi wa ama̱leka Inan. Kap ka̱ nna te, onəm oga mpyal oshozha oFilisti là pa̱ ɓu yà ká̱ ngga ìkum nzəng ká̱ yi ka̱t.
\v 10 Ǹyangmata̱ te, ipin ká̱ iɓotak wa fa nzəng ká̱ onəm oga nnəm inok unəm uga nzhi ɓu va̱ ɓa nzəng ka̱ ɓu. Nva̱ngva̱ atak ɓan ghan chit, te ó kpán asa̱l.>>
\p 
\v 11 Te uDawuda ká̱ onəm wò wong ká̱ ìpin kpan asa̱l pa̱ o le o ga mbin oFilisti, ǹnyi te, oFilisti kyen ga aJezerel.
\c 30
\s1 UDawuda ga ìkum kà̱ OAmalek
\p 
\v 1 Ka̱ nva̱ngva̱ uDawuda ká̱ onunggwan wò ɓa chu aZiklak kà̱ nra ngga nshatɗing te, oza̱ ya oAmalek ru aNegep ká̱ aZiklak chit ká̱ ìkum. Oza̱ pwak aZiklak pa̱ chatchat,
\v 2 kang oza̱ wur ochar ká̱ nkpaktak onəm va̱ ka̱ ashe ìtong va̱ ta, ovan ká̱ onəmgbak. Oza̱ gbá̱l unəm uro ka̱t, ǹnyi te, oza̱ wur oza̱ ga ká̱.
\p 
\v 3 Awalang va̱ uDawuda ká̱ onəm wò chu aZiklak te, oza̱ ya mmá pwak ìtong va̱ ta chit, kang mmá wur ochar oza̱ ká̱ ovan ochar, ká̱ ovan onunggwan oza̱ chit ka̱ ìkum.
\v 4 Te uDawuda nzəng ká̱ onəm wò yə́ng pa̱ gənggəng, oza̱ ga lang ìkam iga ayə́ng.
\v 5 Mmá ka̱ wur ochar aDawuda oga oparəm uAhinoyam uga aJezerel ká̱ uAbigel uwa uɓəɓar ka̱ yà uNabal unəm uga aKarmel á.
\v 6 UDawuda yà ka̱ ashe nɗaktak pa̱ gənggəng, ka̱kul onəm kà̱ nlà pa̱ ó gwan na ká̱ ipang, ka̱kul udanggo ka̱ ashe nlak ìgwak, nva̱ oza̱ lang ovan oza̱ onunggwan ká̱ ochar. Ǹnyi te, uDawuda da̱r nkàm ka̱ atak aYawe Inan wò.
\p 
\v 7 Te uDawuda là ûAbiyatar unəm uga mpyal awop uyen nunggwan aAhimelek pa̱, <<Ɓa ká̱ ìlukwan ìkwoksok á mi.>> Kang uAbiyatar ɓa ká̱ á na,
\v 8 kang uDawuda ɓəp uYawe pa̱, <<M ɓàk nva̱ng onəm va̱ ta̱ ɓa ru yi ká̱ ìkum ɗò? Mi ɓàn oza̱ ɓàn ɗò?>>
\p Kang uYawe na ama̱n pa̱, <<Ga, ɓàk nva̱ng oza̱, ɓu ɓàn oza̱ ɓàn kang ɓu vyat nkpaktak iya̱m va̱ oza̱ wur ká̱ ìkum.>>
\v 9 UDawuda ká̱ onunggwan wò ìgba̱l pa̱ ìkpa̱ɗing va̱ nzəng ká̱ na ru asa̱l ngga, kang oza̱ ɓa chu awang aBesor te, oro tong ka̱ta.
\v 10 Onəm ìgba̱l pa̱ ìparəm ɓa bəlak mpa̱ng awang ma̱t oza̱, ǹnyi te, uDawuda ká̱ onəm ìgba̱l pa̱ ìneɗing ga mpyal ká̱ mɓàk oza̱.
\p 
\v 11 Onəm aDawuda ga ya unəm uga aMasar uro ka̱ ashe nzam, kang oza̱ ɓa ká̱ na ka̱ atak aDawuda. Oza̱ na ndəng á na ká̱ iya̱m-nrì pa̱ á ri,
\v 12 oza̱ na awar ìpipyan iɓitɓit á na ká̱ awar ìba̱ngba̱ng iɓitɓit pa̱ ìparəm. Nva̱ngva̱ uza̱ ri te, nnap nnənəm ɓa, ka̱kul nra pa̱ ishatɗing uwa ri iya̱m iro ka̱t te wa iya̱m iro chit ka̱t ìzwam ká̱ alum.
\p 
\v 13 UDawuda ɓəp na pa̱, <<Uda unəm uga nzhi ɓu yà? U fa ka̱ che yà?>>
\p Uza̱ na ama̱n pa̱, <<Mmami unəm uga aMasar, uzwal anəm uga aAmalek uro. Unəm uga nzhi mi re mi kà̱ nva̱ng nra chit pa̱ nshatɗing ka̱kul n rurwa.
\v 14 I ru aNegep aga aKeret ká̱ ìkum, ká̱ aNegep aga mbin aYahuda, ká̱ aNegep aga mbin aKalep. Kang í pwak aZiklak kpa.>>
\p 
\v 15 UDawuda ɓəp na pa̱, <<Ɓu məma̱n ɓu ga ká̱ mi ka̱ atak onəm ìkum va̱ ta ɗò?>>
\p Uza̱ na ama̱n pa̱, <<A yà pa̱ ɓu sóng anung á mi ká̱ aɗin Inan pa̱ ɓu ya ka̱ ngbá̱l mi ka̱t, ka̱t te ɓu na mi ka̱ ashe awo anəm uga nzhi mi ka̱t, te mi ga ká̱ ɓu ka̱ atak oza̱.>>
\p 
\v 16 Uza̱ ga ká̱ uDawuda ka̱ atak oza̱, kang uza̱ ya oza̱ pəl chit ka̱ ashe agbagba, oza̱ ka̱ nri ká̱ ngwa ka̱ ngba̱p nza̱m ká̱ nchang izər ka̱kul nkpaktak iya̱m iga ngwur ka̱ atak ìkum va̱ oza̱ wur ka̱ mbin aFilisti ká̱ mbin aYahuda á.
\v 17 UDawuda ru oza̱ ká̱ ìkum ká̱ arurong va̱ ta ga chu arurong aga ìpin ìkpa̱kkpa̱k. Unəm uro yà lár ka̱t, ya ovan nza̱m oro ìgba̱l pa̱ ìneɗing ova chəng ka̱ apal oga alakəmi oza̱ chwat.
\v 18 UDawuda vyat nkpaktak iya̱m va̱ oAmalek wur, nzəng ká̱ ochar wò va̱ pa̱ oparəm.
\v 19 Iya̱m iro yà lar ka̱t, iɓwakan ka̱t te ichumchum, ovan onunggwan ka̱t te ovan ochar. UDawuda le ká̱ nkpaktak iya̱m va̱ oAmalek wur ká̱ ìkum.
\v 20 Uza̱ wur nkpaktak itam ká̱ iɓəl, ina ká̱ alakəmi oAmalek nak kà̱ mpyal iji oza̱ kang onənəm wà nggatək iya̱m nkang va̱ ta nzəng ká̱ iji oza̱, i là pa̱, <<Iya̱m iga ngwur ka̱ atak ìkum aDawuda nna ta̱.>>
\p 
\v 21 Te uDawuda le atak onunggwan oga igba̱l pa̱ ìparəm ova̱ ka̱ bəlak chit, achen ma̱t oza̱ kang mmá ka̱ re ka̱ nva̱ng ka̱ awang aBesor. Oza̱ fa pa̱ ó gwang uDawuda ká̱ onəm va̱ nzəng ká̱ na. Nva̱ngva̱ uDawuda ká̱ onəm wò ɓa chu te, a re anung ôza̱.
\v 22 Ǹnyi te, nkpaktak onəm onga ká̱ onəm olakchilakchi ka̱ ashe onəm aDawuda là pa̱, << Ka̱kul oza̱ ga nzəng ká̱ yi ka̱t te, i yà ká̱ nkap iya̱m iga ngwur ka̱ atak ìkum nzəng ká̱ oza̱ ka̱t. Ká̱ nna te, nza̱ unəm nggo a yar uchar wò ká̱ ovan wò na á ga.>>
\p 
\v 23 Ǹnyi te, uDawuda na ama̱n ôza̱ pa̱, <<Pa ka̱t, ogənang mi, kang o nəm pa ká̱ iya̱m va̱ uYawe na á yi ka̱t. Uza̱ kpak yi kang à na okpa ìkum yi chit ka̱ ashe awo yi, ova̱ ɓa ru yi ká̱ ìkum á.
\v 24 Uda i gwong achwang ka̱ iya̱m va̱ ta̱ mmawó ka̱ nləla yà? Unəm va̱ gà ìkum ká̱ unəm va̱ təm mpángchí ayì te, mí kap iya̱m nkár.>>
\v 25 Á ɓàn ka̱ n̂da va̱ ta ɓa chu n̂da va̱ ta̱, uDawuda nak iya̱m va̱ ta sat nnap mpakpak ká̱ nnap nnəm ka̱ ashe oIsa̱rila.
\p 
\v 26 Awalang va̱ uDawuda chu aZiklak te, uza̱ re ǹre ka̱ iya̱m iga ngwur ka̱ atak ìkum iro ônəm oga mpyal oYahuda, ova okpəkpa, uza̱ là pa̱, <<Imwa nata̱ ka̱kul wó, í wur ka̱ atak okpa ìkum aYawe.>>
\v 27 Uza̱ re ǹre ká̱ imwa va̱ ta ônəm oga mpyal oga itong va̱ ta̱, aBetel, ká̱ aRamot Negep, ká̱ aJatir,
\v 28 ká̱ aAroya, ká̱ aSipmot, ká̱ aEshtemowa,
\v 29 ká̱ aRakal, ká̱ oga itong oJeramel, ká̱ itong oKeni,
\v 30 ká̱ aHorma, ká̱ aBor Ashan, ká̱ aAtak,
\v 31 ká̱ aHebron ká̱ nkpaktak aɓoshi oga atak va̱ uDawuda ká̱ onəm wò chen kà̱.
\c 31
\s1 Ikú aShawulu ká̱ ovan wò onunggwan
\r (1 Nnap Nshet 10.1-12)
\p 
\v 1 Ka̱ ashe ngga te, oFilisti ru oIsa̱rila ká̱ ìkum, kang onunggwan oIsa̱rila chəng ka̱ mpyal oFilisti. OFilisti gbá̱ng oza̱ pa̱ makmak ka̱ agəgər aƁam aGilbowa.
\v 2 OFilisti ɓàk uShawulu ká̱ ovan wò onunggwan, kang oza̱ gbá̱ng ovəvan oga oshatɗing uJonatan ká̱ uAbinadap, ká̱ uMalkishuwa.
\v 3 Ìkum sur chit pa̱ gənggəng ka̱ apal aShawulu, kang ovan onunggwan oga ìjang oFilisti nak aɓang á na məmak.
\p 
\v 4 UShawulu là ûnəm uga wur iya̱m ìkum wò pa̱, <<Tur ndokchi ɓu na u gbá̱l mi ká̱, le kang onəm oga ache amulur va̱ ta̱ a ɓa a kpan mi a na idumdum á mi, a nap avyal ká̱ mi ka̱t.>> Ǹnyi te, unəm uga ngwur iya̱m ìkukum yang, ka̱kul ayər nəm na nəm. Te uShawulu yar ndokchi kyer ishi wò ká̱ ru kú.
\v 5 Awalang va̱ unəm uga ngwur iya̱m ìkum aShawulu ya uza̱ kú chit, te uza̱ yar ndokchi wò kyer ishi wò ká̱, uza̱ ru kú nzəng ká̱ na.
\v 6 Wanta na uShawulu ká̱ ovan wò onunggwan oga oshatɗing, ká̱ unəm uga ngwur iya̱m ìkukum, ká̱ nkpaktak oshozhashozha, oza̱ kú n̂da nzəngtəng.
\v 7 Ká̱ nva̱ngva̱ oIsa̱rila va̱ ka̱ gwong mba̱nda̱m aJezerel ká̱ ova̱ ka̱ gwong awang aUrdun ya pa̱ oshozha oIsa̱rila chəng chit kà̱ mpyal ìkum kang uShawulu ká̱ ovan wò onunggwan kú chit, te oza̱ re oga itong oza̱, a chəng. Kang oFilisti ɓa ra ka̱ ashe oga itong va̱ ta.
\p 
\v 8 Ipin fa kpa̱k te, oFilisti ga pa̱ na o wur iya̱m onəm va̱ mmá gbá̱ng te, oza̱ ya akúm aShawulu ká̱ ovan wò onunggwan oga oshatɗing ka̱ apal aƁam aGilbowa.
\v 9 Kang oza̱ gəl ishi aShawulu oza̱ zəp iya̱m ìkukum. Te oza̱ re ǹre ká̱ onəm oga nre ka̱ ashe nkpaktak mbin oFilisti, pa̱ oza̱ a ga ka̱ nnap-nlà nchángchàng va̱ ta̱ ka̱ atak nzhi ichər oza̱ ká̱ n̂kpaktak onəm oza̱.
\v 10 Oza̱ nak iya̱m ìkukum ka̱ ashe nzhi aAshtoret, kang oza̱ ran akúkum ka̱ izər akamsəlang ìtong aBet Shan.
\p 
\v 11 Kang onəm oga aJabesh Gileyat fe iya̱m va̱ oFilisti nəm ûShawulu te,
\v 12 nkpaktak ovan onunggwan oga nkam ìgwak ka̱ ashe ìtong va̱ ta chen ka̱ ashe izwam va̱ ta ga aBet Shan. Oza̱ ga wur akúm aShawulu ká̱ ovəvan onunggwan va̱ oza̱ ran ká̱ izər akamsəlang aBet Shan á. Oza̱ ɓa ká̱ oza̱ ká̱ aJabesh, oza̱ shì izər oza̱ ka̱ta.
\p 
\v 13 Te oza̱ wur akup oza̱ kang oza̱ li ka̱ avəng ìkun atamariki\x - \xo 31.13 \xt 22.6; Mɓan 21.33\x* ka̱ aJabesh, kang oza̱ yar ndəng gbà̱l nra pa̱ nfangshat.
