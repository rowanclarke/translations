\id PSA - Baibal Kathoung New Testament 
\h SAM 
\toc1 SAM 
\toc2 Sam 
\toc3 Sam 
\mt1 SAM  
\mt2 (The Book of Psalms)  
\c 1  
\s1 Tami kathout hoi tamikalannaw e lamthung  
\d Kasakkung: Panuekhoeh  
\q1
\v 1 Tamikathoutnaw e khokhangnae koe ka cet hoeh e tami,  
\q2 tamikayonnaw e lamthung dawk kangdout hoeh e tami,  
\q2 kadudamnaw e kamkhuengnae koe hai ka tahung hoeh e tami,   
\q1
\v 2 BAWIPA e lawk ka ngâi niteh,  
\q2 a kâlawknaw hah karum khodai luepluep ka pouk e tami teh a yawhawi.   
\q1
\v 3 Ahni teh tui teng vah ung e,  
\q2 a tue a pha torei ka paw niteh,  
\q2 a hna hai kamyai hoeh e thingkung hoi a kâvan.  
\q2 A tawksak e naw dawk hawinae a hmu han.   
\q1
\v 4 Tamikathoutnaw teh, hottelah laipalah,  
\q2 kahlî ni a palek e cahik hoi a kâvan awh.   
\q1
\v 5 Hatdawkvah, tamikathoutnaw teh, lawkcengnae hnin navah kangdout thai awh mahoeh.  
\q2 Tamikayonnaw hai tami kalannaw e kamkhuengnae dawk bawk thai mahoeh.   
\q1
\v 6 Bangkongtetpawiteh, BAWIPA ni tami kalannaw e lamthung teh a panue.  
\q2 Tamikathoutnaw e lamthung teh rawknae koe a pha han.   
\c 2  
\s1 Messiah tânae hoi uknae  
\d Kathutkung: Devit  
\q1
\v 1 Miphunnaw teh bangkongmaw ruengruengti awh.  
\q2 Tamimaya teh bangkongmaw ayawmyin hno a sak awh.   
\q1
\v 2 BAWIPA hoi Messiah taran lahoi, talai bawinaw cungtalah a kamkhueng awh teh,  
\q2 lawkcengkungnaw cungtalah kho a khang awh.   
\q1
\v 3 Tho awh. A kâkateknae naw hah ratham pouh sei.  
\q2 Kâkateknae rui hah tâkhawng pouh sei.   
\q1
\v 4 Kalvan ka tahung e ni panuikhai vaiteh,  
\q2 Bawipa ni panuilai lah a sak han.   
\q1
\v 5 Hahoi, lungkhuek laihoi ahnimouh koe lawk dei vaiteh,  
\q2 puenghoi a lungrei a thaisak han.   
\q1
\v 6 Hateiteh, kaie mon kathoung Zion vah,  
\q2 ka siangpahrang ka ta toe.   
\q1
\v 7 BAWIPA ni nang teh ka Capa doeh.  
\q2 Sahnin vah na khe telah kai koe a dei e hah ka pâpho han .   
\q1
\v 8 Kai koe het haw. Râw lah miphunnaw na poe vaiteh,  
\q2 talai pout ditouh na coe hanelah na poe han.   
\q1
\v 9 Sumtaboung hoi na uk vaiteh,  
\q2 talai hlaamkabokung ni a hem e patetlah rek na hem han.   
\q1
\v 10 Hatdawkvah, Oe siangpahrangnaw, na lungang awh leih.  
\q2 Talai lawkcengkungnaw yuenae kâhmo awh haw.   
\q1
\v 11 Taki laihoi BAWIPA thaw tawk awh haw.  
\q2 Pâyaw laihoi konawm awh.   
\q1
\v 12 Capa teh pahnuem awh.  
\q2 Hoehpawiteh, a lungkhuek payon vaih.  
\q2 Dongdeng a lungphuen toteh, lam vah koung na kahmat payon vaih.  
\q2 Ama kâuep e pueng teh tami yawkahawi e doeh.   
\c 3  
\s1 BAWIPA ni a taminaw runae a kabawp  
\d Kathutkung: Devit, Devit ni a sak e la: A capa Absalom koehoi a yawng nah sak e  
\q1
\v 1 Oe BAWIPA, kaie tarannaw teh apap poung.  
\q2 Kai na ka tarannaw apap poung.   
\q1
\v 2 Taminaw ni, ahni teh Cathut koehoi e kabawpnae awmhoeh  
\q2 telah kai hanelah a dei awh. Selah.   
\q1
\v 3 Hatei, Oe BAWIPA, nang teh kai hanlah kânguenae bahling,  
\q2 kaie bawilennae lah na o teh, kaie lû katawmkung lah na o.   
\q1
\v 4 Kai ni hram laihoi, BAWIPA hah ka kaw toteh,  
\q2 ahni ni kathounge mon dawk hoi kai hah na pato. Selah.   
\q1
\v 5 BAWIPA ni na kabawp dawkvah,  
\q2 kai teh ka i thai teh, ka kâhlaw thai.   
\q1
\v 6 Kai hah avoivang lahoi na kalup niteh,  
\q2 na ka tuk e tami thong hra touh ka phat hai ka taket hoeh.   
\q1
\v 7 Oe BAWIPA, thaw haw. Kaie Cathut, na rungngang haw.  
\q2 Bangkongtetpawiteh, nang ni ka tarannaw pueng e kamhru hah,  
\q2 na hem pouh teh, tamikathoutnaw e a hâ hah na khoe pouh.   
\q1
\v 8 Rungngangnae teh BAWIPA e doeh.  
\q2 Nange yawhawinae teh,  
\q2 na taminaw koe phat lawiseh. Selah.   
\c 4  
\s1 Yuemkamcunaw roumnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe lannae Cathut,  
\q2 na kaw toteh na thai pouh haw.  
\q2 Ka runae hah na hlai haw.  
\q2 Na pahren haw, ka ratoumnae hah na thai pouh haw.   
\q1
\v 2 Oe tami capanaw,  
\q2 ka bawilennae hah nâtotouh maw kayanae lah na coung sak awh han.  
\q2 Nâtotouh maw ayawmyin hno hah na lungpataw awh vaiteh,  
\q2 payonnae hah na tawng awh han. Selah.   
\q1
\v 3 BAWIPA ni cathutlae tami teh a rawi tie hah panuek awh haw.  
\q2 Ka kaw toteh BAWIPA ni na thai pouh han.   
\q1
\v 4 Na lungkhuek yawkaw, yonnae teh sak hanh.  
\q2 Na ikhun dawk na lung hoi pouk nateh duem awm.   
\q1
\v 5 Lannae thuengnae hah poe nateh,  
\q2 BAWIPA hah kâuep haw.   
\q1
\v 6 Apinimaw hawinae na hmusak han na ka tet pouh e moi ao awh.  
\q2 BAWIPA kaimouh koe na minhmai angnae hoi na tue haw.   
\q1
\v 7 Cakang hoi misur moikapap a hmu awh dawk  
\q2 konawmnae hlak kalenhnawn e konawmnae hah  
\q2 ka lung thung na ta toe.   
\q1
\v 8 Duem ka yan vaiteh, ka i han toe.  
\q2 Bangkongtetpawiteh, Oe BAWIPA,  
\q2 nang ni dueng doeh karoumcalah na o sak thai.   
\c 5  
\s1 Lam hmusak nahan ratoumnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA, ka lawk na thai pouh haw.  
\q2 Ka khopouknae hah na pouk pouh haw.   
\q1
\v 2 Ka siangpahrang hoi ka Cathut,  
\q2 ka hramnae hah na thai pouh haw.  
\q2 Nang koevah, ka ratoum.   
\q1
\v 3 Oe BAWIPA, amom vah, ka lawk na thai han.  
\q2 Amom vah nang koe lah kangvawi laihoi,  
\q2 lathueng lah ka khet han.   
\q1
\v 4 Bangkongtetpawiteh, nang teh thoenae dawk  
\q2 a lung kahawi e Cathut nahoeh.  
\q2 Thoenae hai nang koe awm hoeh.   
\q1
\v 5 Na hmithmu vah kâoupnaw teh kangdout thai mahoeh.  
\q2 Payonnae ka sak e pueng teh na hmuhma.   
\q1
\v 6 Laithoe kadeinaw hah na raphoe teh,  
\q2 dumyennae hoi tami theikahrannaw hah Bawipa ni a panuet.   
\q1
\v 7 Hatei kai teh, na lungmanae apap kecu dawk na im vah ka tho han.  
\q2 Nang taki laihoi kathounge Bawkim koelah kangvawi laihoi na bawk han.   
\q1
\v 8 Oe BAWIPA, ka tarannaw kecu dawk na lannae hoi na hrawi haw,  
\q2 ka hmalah na lam hah lan sak haw.   
\q1
\v 9 Bangkongtetpawiteh, a pahni dawk yuemkamcunae awmhoeh.  
\q2 Athung lae teh rawknae doeh.  
\q2 A lawkron teh kamawng e tangkom doeh.  
\q2 A laihoi dueng doeh ayânaw a oup awh.   
\q1
\v 10 Oe Cathut, yon pen haw.  
\q2 Amamouh ni a sak awh e dawk letlang bawt awh naseh.  
\q2 Kâtapoenae moipap dawkvah, tâkhawng haw.  
\q2 Bangkongtetpawiteh, nang taran laihoi taran a thaw awh.   
\q1
\v 11 Hatei, nang ka kâuep e pueng, konawm awh naseh.  
\q2 Na ngue dawkvah, konawm laihoi hram awh naseh.  
\q2 Na min ka lungpataw naw hai nang dawk konawm awh naseh.   
\q1
\v 12 Bangtelane Oe BAWIPA, tamikalan yawhawi na poe vaiteh,  
\q2 minhmai kahawi hoi bahling patetlah na ramuk han.   
\c 6  
\s1 Runae thung hoi yuemkamcu ratoumnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA, lungkhuek laihoi na yue hanh,  
\q2 na lungphuen laihoi na yue hanh.   
\q1
\v 2 Oe BAWIPA, na pahren haw. Ka tha a youn.  
\q2 Oe BAWIPA, na dam sak haw.  
\q2 Ka hrunaw teh runae a kâhmo toe.   
\q1
\v 3 Ka hringnae hai a ru toe.  
\q2 Oe BAWIPA, nâsittouh maw na ro han.   
\q1
\v 4 Oe BAWIPA, bout ban nateh, na rungngang haw.  
\q2 Oe na lungmanae hoi na rungngang haw.   
\q1
\v 5 Bangkongtetpawiteh, duenae koehoi nang pouknae awmhoeh,  
\q2 apinimouh phuen koehoi lunghawinae lawk a dei han.   
\q1
\v 6 Ka cingounae koe ka tâwn.  
\q2 Kho pei ka dai lah ka ikhun dawk ka ka teh,  
\q2 ka mitphi ni lahoung koung a duk sak.   
\q1
\v 7 Lungmathoenae kecu dawk ka mit koung a ro teh,  
\q2 ka tarannaw kecu dawk a mawm toe.   
\q1
\v 8 Payonnae kasaknaw pueng,  
\q2 na cettakhai awh leih.  
\q2 Bangkongtetpawiteh, BAWIPA ni ka kanae lawk hai a thai.   
\q1
\v 9 BAWIPA ni ka kâheinae hah a thai toe.  
\q2 BAWIPA ni ka ratoumnae hah a dâw han.   
\q1
\v 10 Ka taran pueng kaya laihoi ru awh naseh.  
\q2 Ban awh naseh, vaitalahoi kayak awh naseh.   
\c 7  
\s1 Taran kut thung hoi rungngang nahanlah ratoumnae  
\d Kathutkung: Devit, Devit teh Benjamin tami Kush e lawk kecu dawk BAWIPA hmalah a sak e la  
\q1
\v 1 Oe BAWIPA, ka Cathut, nang teh na kâuep.  
\q2 Na ka pacekpahlek e pueng koehoi na rungngang nateh na hlout sak haw.   
\q1
\v 2 Hoehpawiteh, sendek patetlah na kei vaiteh,  
\q2 rungngangkung ao hoehnahlan vah, na paset awh han doeh.   
\q1
\v 3 Oe BAWIPA ka Cathut, kai ni hottelah ka sak vaiteh,  
\q2 ka kut dawk payonnae kaawm nakunghai,   
\q1
\v 4 Kai koe duem kaawm e hah thoenae hoi ka patho teh,  
\q2 ka tarannaw hah a khuekhaw awm laipalah ka coungroe pawiteh,   
\q1
\v 5 taran ni na pâlei naseh, na phat naseh.  
\q2 Kahringnae hah talai dawk repcoungroe awh naseh.  
\q2 Minhmai barinae hah vaiphu dawk tat awh naseh. Selah.   
\q1
\v 6 Oe BAWIPA, lungkhuek laihoi thaw haw,  
\q2 ka tarannaw e lungkhueknae hah ngang haw.  
\q2 Kâ na poe tangcoung patetlah kai han lawkceng hanlah thaw haw.   
\q1
\v 7 Miphunnaw kamkhueng awh vaiteh,  
\q2 nang hah na kalup awh han.  
\q2 Ahnimouh hanlah arasangnae koe ban haw.   
\q1
\v 8 BAWIPA ni lawk a ceng han.  
\q2 Oe BAWIPA, ka lannae hoi ka thung kaawm e yuemkamcu lah  
\q2 ka o e patetlah lawk na ceng haw.   
\q1
\v 9 Oe tamikathoutnaw,  
\q2 thoenae teh poutsak lah awm lawiseh.  
\q2 Hatei, lannae teh caksak lah awm seh.  
\q2 Bangkongtetpawiteh, ka lan e Cathut ni lungthin hoi  
\q2 pouknae hah ouk a tanouk.   
\q1
\v 10 Lungthin kalannaw rungngangkung Cathut teh  
\q2 kai kânguenae lah ao.   
\q1
\v 11 Cathut teh kalan e lawkcengkung lah ao teh,  
\q2 Cathut teh tamikathoutnaw koe hnintangkuem a lungkhuek.   
\q1
\v 12 Pankângai hoehpawiteh, a tahloi hah kata vaiteh,  
\q2 licung hah sawn vaiteh, coungkacoe lah ao han.   
\q1
\v 13 Duenae senehmaica hai ahni hanlah a rakueng teh,  
\q2 hmai kang thai e samtang hah a sak awh.   
\q1
\v 14 Tamikathout ni yonnae hah a khe.  
\q2 Runae hah a vawn teh laithoe ouk a khe.   
\q1
\v 15 Tangkom kadungpoung lah a tai teh,  
\q2 a tai e tangkom dawk ama letlang a bo.   
\q1
\v 16 A sak e runae hah amae lû van bout ban vaiteh,  
\q2 a tâcosak e thoenae teh amae lû van bout a pha han.   
\q1
\v 17 BAWIPA teh a lan e patetlah ka pholen han.  
\q2 Lathueng Poung BAWIPA min pholen hoi la ka sak han.   
\c 8  
\s1 Hno sak e dawk BAWIPA lentoenae  
\d Kathutkung: Devit  
\q1
\v 1 Oe kaimae Bawipa, Jehovah teh,  
\q2 talai van pueng dawk na min ahawi toungloung.  
\q2 Na bawilennae teh kalvannaw lathueng vah na ta.   
\q1
\v 2 Bangkongtetpawiteh, na tarannaw kecu dawk  
\q2 moipathungkung hoi taran na roum sak thai nahanlah,  
\q2 sanu ka net e camonaw pahni dawk hoi thaonae hah na cak sak.   
\q1
\v 3 Na kutdawn hoi na sak e kalvannaw hoi  
\q2 na caksak e thapa hoi âsinaw hah ka khet navah,   
\q1
\v 4 tami heh banglamouh ao teh,  
\q2 na lungthung hoi na pouk.  
\q2 Tami capa heh banglamouh ao teh khuet na pai sin.   
\q1
\v 5 Bangkongtetpawiteh, ahni hah kalvantaminaw hlak bet ka rahnoum lah na sak teh,  
\q2 bawilennae hoi pholennae hah na kâmuk sak.   
\q1
\v 6 Na kutsaknaw koe kâ na tawn sak teh,  
\q2 a khok rahim bangpuengpa na hruek pouh.   
\q1
\v 7 Maitotan hoi tu pueng hai,  
\q2 kahrawngum e saring pueng hoi,   
\q1
\v 8 kalvan e tavanaw hoi, talî thung e tanganaw hoi,  
\q2 talaipui thung kaawm e pueng hoi,   
\q1
\v 9 Oe BAWIPA, kaimae Bawipa,  
\q2 talai van pueng dawk na min teh ahawi toungloung.   
\c 9  
\s1 BAWIPA lawkcengnae dawk lunghawi lawk dei ratoumnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA, ka lungthin abuemlahoi na pholen han.  
\q2 Na sak e kângairu hno pueng ka dei han.   
\q1
\v 2 Nang dawk konawm lahoi ka nawm han.  
\q2 Oe Lathueng Poung, na min pholen hoi la ka sak han.   
\q1
\v 3 Ka tarannaw a ban awh toteh,  
\q2 na hmalah tâlaw awh naseh, rawk awh naseh.   
\q1
\v 4 Bangkongtetpawiteh, bawitungkhung dawk tahung hoi  
\q2 lannae hoi lawk na ceng teh,  
\q2 ka lannae hoi coungnae hah na cak sak.   
\q1
\v 5 Miphunnaw hah na yue teh,  
\q2 tamikathoutnaw hah na raphoe teh,  
\q2 ahnimae min teh ayungyoe hoi a yungyoe totouh na raphoe toe.   
\q1
\v 6 Oe ka tarannaw, rawknae teh a yungyoe poutnae koe a pha toe.  
\q2 Khopui teh na raphoe teh noutnae ao hoeh totouh a kahma toe.   
\q1
\v 7 Hatei, BAWIPA teh a yungyoe a kangning.  
\q2 Lawkceng nahanelah bawitungkhung teh a rakueng toe.   
\q1
\v 8 Lannae lahoi talaivan heh lawkceng vaiteh,  
\q2 a lannae dawk lawkcengnae hah taminaw hanelah a cak sak.   
\q1
\v 9 BAWIPA teh repcoungroenaw hane lahai rapanim lah ao teh,  
\q2 runae kâhmo nah kâhronae lah ao han.   
\q1
\v 10 Na min kapanueknaw ni nang na kâuep awh han.  
\q2 Bangkongtetpawiteh, BAWIPA,  
\q2 nang katawngnaw teh na cettakhai boihoeh.   
\q1
\v 11 Zion kaawm e naw, BAWIPA pholen hoi la sak awh.  
\q2 A sak e hno hah taminaw koe pâpho awh.   
\q1
\v 12 Thipaling phu moi a pathung toteh, pahnim hoeh.  
\q2 Kârahnoumnaw e hram lawk hai pahnim hoeh.   
\q1
\v 13 Oe BAWIPA, na pahren haw.  
\q2 Na kahmuhmanaw kecu dawk ka runae hah pouk haw.  
\q2 Nang teh duenae longkha thung hoi na kahloutsakkung doeh.   
\q1
\v 14 Hottelah, nang pholennae pueng hah,  
\q2 Zion canu longkha koehoi roeroe ka pâpho thai nahanlah,  
\q2 na rungngangnae dawk ka konawm han.   
\q1
\v 15 Miphunnaw teh amamouh ni a tai awh e tangkom dawk koung a bo awh.  
\q2 Arulahoi a patung awh e tangkam dawk a khok a kâman awh.   
\q1
\v 16 BAWIPA teh lawk a ceng e patetlah panue thai.  
\q2 Tamikathoutnaw teh amamouh ni a sak e hno dawk a kâman awh.   
\q1
\v 17 Tamikathoutnaw teh Cathut ka pahnim e  
\q2 miphunnaw hoi sheol dawk a kak awh han.   
\q1
\v 18 Bangkongtetpawiteh, kavoutthoupnaw teh pahnim lah pou awm awh mahoeh.  
\q2 Karoedengnaw, e ngaihawinae hai pou kahmat mahoeh.   
\q1
\v 19 Oe BAWIPA thaw haw, tami ni na tâ hanh naseh.  
\q2 Miphunnaw teh na mithmu vah lawkceng lah awm awh naseh.   
\q1
\v 20 Oe BAWIPA, miphunnaw ni tami lah  
\q2 ao awh e a panue awh nahanelah,  
\q2 lungpuennae dawk tat haw. Selah.   
\c 10  
\s1 Cathut ni yon a tânae dawk lungmawngnae  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 Oe BAWIPA, bangkongmaw ahlanae koe na kangdue.  
\q2 Bangkongmaw runae tueng nah na kâhro.   
\q1
\v 2 Tamikathoutnaw ni kâoupnae lahoi  
\q2 tami karoedengnaw hah a rektap awh.  
\q2 A sak awh e ni amamouh letlang man naseh.   
\q1
\v 3 Tamikathoutnaw teh amamae lungngainae dawk  
\q2 ouk a kâoup awh.  
\q2 Kahounlounnaw ni BAWIPA a hnoun awh teh,  
\q2 a dudam awh.   
\q1
\v 4 Tamikathoutnaw ni kâoupnae lahoi  
\q2 Cathut tawng ngai awh hoeh.  
\q2 A pouknae dawkvah, Cathut awm hoeh ati awh.   
\q1
\v 5 Lawkcengnae teh ahni hoi ahla arasang dawkvah,  
\q2 a tarannaw pueng hah a dudam.   
\q1
\v 6 A lungthung hoi, kâhuen mahoeh,  
\q2 nâtuek hai runae kâhmo mahoeh telah a pouk.   
\q1
\v 7 A pahni teh thoebonae,  
\q2 dumnae hoi repcoungroenae lawk hoi akawi.  
\q2 A lai rahim vah runae hoi payonnae teh ao.   
\q1
\v 8 Kho tangkuem lampawp koe a tahung teh,  
\q2 tami ni hmuhoehnae koe yonnae ka tawn hoeh e naw hah a thei awh.  
\q2 Tami ka roedeng e hah arulahoi a pawp awh.   
\q1
\v 9 Sendek ni a kâkhu dawk hoi a pawp e patetlah  
\q2 arulahoi tami ouk a pawp.  
\q2 Tami ka roedeng hah man hanlah a pawp.  
\q2 A tamlawk hoi a sawn toteh tami ka roedeng a kâman.   
\q1
\v 10 Hottelah, karoedengnaw hah a thaonae lahoi rawp sak nahanlah,  
\q2 ka rahnoumca lah a tabo awh.   
\q1
\v 11 A lungthung hoi, Cathut ni a pahnim toe.  
\q2 A minhmai hai a hro toe.  
\q2 Nâtuek hai hmawt mahoeh toe telah a pouk.   
\q1
\v 12 Oe BAWIPA, thaw haw.  
\q2 Oe Cathut, na kut dâw haw.  
\q2 Kârahnoumnaw hah pahnim hanh.   
\q1
\v 13 Bangkongmaw tamikathoutnaw ni Cathut banglahai a noutna awh hoeh.  
\q2 A lungthung hoi, banglah pouk mahoeh ouk ati awh.   
\q1
\v 14 Hateiteh, lungreithai hoi runae teh na pakhingpalang teh,  
\q2 na kut hoi moipathung hanlah na hmu toe.  
\q2 Karoedengnaw, teh nang koe a kâhnawng awh teh,  
\q2 nang teh, na pa ka tawn hoeh naw kabawmkung lah na o.   
\q1
\v 15 Tamikathoutnaw hoi tamikayonnaw e kut hah khoe pouh nateh,  
\q2 ceitakhai e awm laipalah, hawihoehnae pueng koung pâphue pouh haw.   
\q1
\v 16 BAWIPA teh a yungyoe hoi a yungyoe totouh siangpahrang doeh.  
\q2 A ram thung hoi miphunnaw koung a kahma awh.   
\q1
\v 17 Repcoungroe e hoi na pa ka tawn hoeh naw koevah,  
\q2 kângingnae sak hanelah,  
\q2 talai taminaw ni repcoungroe hoeh nahanelah,   
\q1
\v 18 BAWIPA, kârahnoumnaw e ngainae teh na panue teh,  
\q2 ahnimouh lawkceng hanelah na hnâ teh na pakeng pouh.   
\c 11  
\s1 BAWIPA lannae dawk kâuepnae  
\d Kathutkung: Devit  
\q1
\v 1 BAWIPA dawk ka kâuep.  
\q2 Bangkongtetpawiteh, ka hringnae koevah,  
\q2 na monsom vah tavaca patetlah kamleng telah na dei thai.   
\q1
\v 2 Bangtelah tetpawiteh, na khenhaw!  
\q2 Tamikathoutnaw ni licung a sawn awh teh,  
\q2 lungthin kalannaw arulahoi ka hanelah, lirui dawk pala coungkacoe a mawp awh toe.   
\q1
\v 3 Adunaw hah raphoe lah awm pawiteh,  
\q2 tamikalan ni bangmouh a sak thai han.   
\q1
\v 4 BAWIPA teh kathounge Bawkim dawk ao teh,  
\q2 BAWIPA bawitungkhung teh kalvan vah ao.  
\q2 A mit hoi a khet teh, tami capanaw teh a mitlakhuem hoi a tanouk.   
\q1
\v 5 BAWIPA ni tamikalan hah ouk a tanouk.  
\q2 Hatei, tamikathout hoi thama lah kalawmnaw teh,  
\q2 a hringnae hoi a hmuhma.   
\q1
\v 6 Tamikathoutnaw koe hmaisaan hmaito a rak sak vaiteh,  
\q2 hmai hoi gan hoi hmaikahlî teh a coe awh hane manang lah ao han.   
\q1
\v 7 Bangkongtetpawiteh, BAWIPA teh a lan.  
\q2 Lannae hah lung a pataw teh, tamikalan teh a khet.    
\c 12  
\s1 Cathut yuemkamcu lah onae  
\d Kathutkung: Devit  
\q1
\v 1 BAWIPA na kabawm haw.  
\q2 Bangkongtetpawiteh, cathutlae tami awm hoeh toe.  
\q2 Tami capanaw dawk yuemkamcu e awm hoeh toe.   
\q1
\v 2 A imrinaw hoi laithoe lawk a kâdei awh teh,  
\q2 lungsamphei laihoi lawk a dei awh.   
\q1
\v 3 BAWIPA ni pasawtpanepnae pahni hoi,  
\q2 kâoupnae lai hah tâtueng naseh.   
\q1
\v 4 Ahnimouh ni, ka lai hoi ka tâ han.  
\q2 Ka pahni hai kama e doeh.  
\q2 Apimouh kaimouh lathueng ka bawi han telah ati awh.   
\q1
\v 5 BAWIPA ni, repcoungroe e tami ka roedeng e hoi,  
\q2 voutthoup laihoi kacingounaw hanlah,  
\q2 atu ka thaw vaiteh, a ngaihawi awh e roumnae hmuen koe  
\q2 ka o sak han telah ati.   
\q1
\v 6 BAWIPA e lawknaw teh, ka thoung e lawk doeh.  
\q2 Talai hoi thoung sak nahanelah,  
\q2 hmai dawk vai sari touh sôlêi tangcoung e ngun patetlah ao.   
\q1
\v 7 Oe BAWIPA, nang ni na khetyawt.  
\q2 Hete senaw thung dawk hoi a yungyoe na roum sak.   
\q1
\v 8 Tami capanaw ni tamikapo a tawmrasang awh toteh,  
\q2 tamikathoutnaw teh hmuen tangkuem a kâva awh.   
\c 13  
\s1 BAWIPA rungngangnae kâuepnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA, nâtotouh maw na pahnim yungyoe han.  
\q2 Nâtotouh maw kai koehoi na minhmai na hro han rah.   
\q1
\v 2 Kai teh, ka lung pou a mathoe.  
\q2 Nâtotouh ne kamadueng lungreithai hoi ka i han vai.  
\q2 Nâtotouh ne ka lathueng ka taran ni a kâoup han rah vai.   
\q1
\v 3 Oe BAWIPA ka Cathut, kangvawi nateh ka lawk hah na thai pouh haw.  
\q2 Ka mit ang sak haw. Hoehpawiteh, duenae patetlah ka ip payon vaih.   
\q1
\v 4 Hoehpawiteh, ka taran ni ahni ka tâ toe ati han doeh.  
\q2 Hoehpawiteh, ka kâroe navah, runae na kapoenaw a konawm awh langvaih.   
\q1
\v 5 Hatei, na lungmanae hah ka kâuep teh,  
\q2 na rungngangnae dawk ka lungthin a konawm han.   
\q1
\v 6 BAWIPA koe la ka sak han.  
\q2 Bangkongtetpawiteh, ka lathueng ahawi tangngak.   
\c 14  
\s1 Cathut laipalah pathunae doeh  
\d Kathutkung: Devit  
\q1
\v 1 Tamipathu ni a lungthung hoi,  
\q2 Cathut awmhoeh ati. A rawk toe.  
\q2 Panuet ka tho e hno doeh a sak.  
\q2 Hawinae ka sak e awm hoeh toe.   
\q1
\v 2 Cathut ka tawng niteh,  
\q2 ka panuek thai e ao han na ou tie panue han ngai dawk,  
\q2 BAWIPA ni kalvan hoi tami capanaw hah a khet cathuk.   
\q1
\v 3 Abuemlahoi lam a phen awh teh,  
\q2 cungtalah koung a rawk awh toe.  
\q2 Hawinae kasakkung apihai awmhoeh. Buet touh boehai awmhoeh.   
\q1
\v 4 Payonnae kasaknaw ni panuenae tawn awh hoeh ma aw.  
\q2 Rawca ca e patetlah ka taminaw hah a ca awh teh,  
\q2 BAWIPA kaw awh hoeh.   
\q1
\v 5 Hawvah, takinae kalen koe ao awh.  
\q2 Bangkongtetpawiteh, Cathut teh tami kalannaw koelah ao.   
\q1
\v 6 Tami karoedengnaw e pouknae teh a kaya sak awh.  
\q2 Hatei, BAWIPA teh ahnimae kânguenae doeh.   
\q1
\v 7 Oe Isarel rungngangnae teh Zion hoi tâcawt naseh.  
\q2 BAWIPA ni san lah kaawm e taminaw a bankhai toteh,  
\q2 Jakop teh konawm naseh. Isarel hai lunghawi naseh.   
\c 15  
\s1 Cathut hoi rei hringnae nuen  
\d Kathutkung: Devit  
\q1
\v 1 BAWIPA, na lukkareiim dawk apimouh kangning han.  
\q2 Na mon kathoung dawk apimouh kaawm han.   
\q1
\v 2 Kângingnae hoi ka hring niteh,  
\q2 lannae a sak laihoi a lung hoi lawkkatang ka dei niteh,   
\q1
\v 3 a lai hoi tamthoe ka dei boihoeh niteh,  
\q2 a imri lathueng thoenae sak laipalah,  
\q2 a huinaw min hai ka pathoe boihoeh niteh,   
\q1
\v 4 tami ka pacekpahleknaw hah a mit hoi khen hoeh,  
\q2 hatei, BAWIPA ka taketnaw hah a bari teh,  
\q2 thoebo laihoi lawk ka kam e teh ama pataw nahanelah ao nakunghai kamlang laipalah,   
\q1
\v 5 a pung lahoi tangka ka cawi boihoeh niteh,  
\q2 yonnae ka tawn hoeh e koe tadawnghno ka lat boihoeh e naw han doeh.  
\q2 Hot patet e hno ka sak e naw teh, nâtuek hai kâhuen mahoeh.   
\c 16  
\s1 Yuemkamcu ngaihawinae  
\d Kathutkung: Devit  
\q1
\v 1 Oe Cathut, na roum sak haw.  
\q2 Bangkongtetpawiteh, nang doeh na kângue.   
\q1
\v 2 Oe ka hringnae, Jehovah koe nang teh ka Bawipapa doeh,  
\q2 nang laipateh ka hawinae hah banghai bang hoeh lah ao telah dei haw.   
\q1
\v 3 Talaivan kaawm e tami kathoungnaw hanelah,  
\q2 ahnimouh teh tami kahawi katang,  
\q2 ka konawmnae pueng onae doeh telah ka ti.   
\q1
\v 4 Karangpoung lah cathut louk hnukkâbangnaw teh,  
\q2 rucatnae moi a khang awh han. Awi hane thuengnae thi hah ka poe mahoeh.  
\q2 Ka pahni hoi a min hai ka dei mahoeh.   
\q1
\v 5 Oe BAWIPA, nang teh ka ham hoi ka manang lah na o teh,  
\q2 ka ham hah na cak sak.   
\q1
\v 6 Ka khori teh, kai hanlah kahawipoung e ram dawk a kâen.  
\q2 Kahawi katang e râw teh ka coe han.   
\q1
\v 7 Pouknae na kapoekung BAWIPA teh ka pholen han.  
\q2 Karum hai ka lungthin ni kahringnae a hroecoe.   
\q1
\v 8 BAWIPA teh kahma lah pou ka hruek.  
\q2 Ama teh aranglae kut lah ao dawkvah, ka kâhuen mahoeh.   
\q1
\v 9 Hatdawkvah, ka lungthin a lunghawi teh, ka bawilennae teh a konawm.  
\q2 Ka takthai hai ngaihawinae hoi a kâhat han.   
\q1
\v 10 Bangkongtetpawiteh, ka muitha teh phuen vah na cettakhai mahoeh.  
\q2 Na tami kathoung teh pawklawi e na pasoung mahoeh.   
\q1
\v 11 Hringnae lamthung na hmu sak han.  
\q2 Nang koe konawmnae ka kuep teh ao.  
\q2 Nange aranglae kut dawk a yungyoe nawmnae teh ao.   
\c 17  
\s1 A hnukteng rungngang nahanlah yuemkamcu ratoumnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA, lannae koe lah awm nateh,  
\q2 ka hramnae hah na thai pouh haw.  
\q2 Dumnae ka dei boihoeh e pahni hoi ka ratoumnae hah na thai pouh haw.   
\q1
\v 2 Ka kong dawk lawk tâtuengnae hah na hmalah tâcawt naseh,  
\q2 na mit teh kalan e hno dawk um naseh.   
\q1
\v 3 Ka lungthin teh na tanouk toe. Karum vah na pai toe.  
\q2 Na tanouk teh banghai na hmawt hoeh.  
\q2 Ka pahni ni payon hoeh nahanelah ka noe toe.   
\q1
\v 4 Taminaw ni sak e kong dawk,  
\q2 karaphoekungnaw e lam hah na lawk lahoi ouk ka roun toe.   
\q1
\v 5 Na lamthung dawk ka dawn lahun nah  
\q2 ka tâlaw payon hoeh nahanlah, na ka bawm haw.   
\q1
\v 6 Oe Cathut, nang ni na thai pouh dawkvah, kai ni ka hei.  
\q2 Na hnâ pakeng nateh, ka lawk hah na thai pouh haw.   
\q1
\v 7 Nang kâuepnaw hah, katarankungnaw e kut dawk hoi,  
\q2 rungngangkung Cathut, pahrenlungmanae hah kamnuek sak haw.   
\q1
\v 8 Kai rep na kacuengroe e tamikayonnaw hoi  
\q2 kai thei hanlah na kalup e tarannaw kut dawk hoi,   
\q1
\v 9 Mitmu patetlah kai hah na ring haw.  
\q2 Na rathei rahim vah na ramuk haw.   
\q1
\v 10 Ahnimouh teh amamae thâwnae hah a kâuep awh teh,  
\q2 kâoup laihoi lawk a dei awh.   
\q1
\v 11 Ka ceinae lam hah a kalup awh teh,  
\q2 talai dawk rawp sak hanelah a mit pakhap laipalah na khet awh.   
\q1
\v 12 Sendek ni a kei e moi ca han thouk a ngai e patetlah thoseh,  
\q2 sendek kanaw ni arulahoi a pawp e patetlah thoseh ao awh.   
\q1
\v 13 Oe BAWIPA, thaw haw.  
\q2 Kangdout sin nateh, rawm sak haw.  
\q2 Tamikathoutnaw e kut dawk hoi na tahloi hoi na rungngang haw.   
\q1
\v 14 Oe BAWIPA, talai tami lah kaawm e hotnaw e kut dawk hoi  
\q2 na rungngang haw.  
\q2 Ahnimouh teh atuvah, amamouh hanelah, a pang awh toe.  
\q2 Ahnimae ngainae hah hnopai hoi a kawi sak.  
\q2 A canaw hai a tawnta awh teh,  
\q2 a catounnaw koe a hnopainaw hah a parâw pouh awh.   
\q1
\v 15 Kai niteh, lannae lahoi na minhmai ka hmu han.  
\q2 Nang patetlah ka kâhlaw toteh ka lung a kuep han.   
\c 18  
\s1 Lathueng Poung rungngangkung Cathut  
\d Kathutkung: Devit, Bawipa e san, Devit ni Sawl koehoi taran kut dawk hoi, hloutsaknae hawinae coe torei teh, BAWIPA hmalah sak e la  
\q1
\v 1 Oe ka thaonae BAWIPA,  
\q2 nang teh na lungpataw han.   
\q1
\v 2 BAWIPA teh kaie lungsong,  
\q2 kaie rapan, kaie rungngangkung lah ao.  
\q2 Kaie Cathut, ka thaonae,  
\q2 ka kâuep e bahling hoi ka rungngangnae ki hoi ka rapanim lah ao.   
\q1
\v 3 Pholen kamcu BAWIPA teh ka kaw vaiteh,  
\q2 ka tarannaw um hoi rungngang lah ka o han.   
\q1
\v 4 Due patawnae ni na kalup,  
\q2 Cathut takihoehnae tuikalen ni na taki sak.   
\q1
\v 5 Sheol lungmathoenae ni na kalup teh,  
\q2 duenae tangkam ni na kangdue sin.   
\q1
\v 6 Kângairu kecu dawk BAWIPA ka kaw teh,  
\q2 ka Cathut koe ka hram.  
\q2 A Bawkim koehoi na thai pouh teh,  
\q2 a hmalah ka hramnae hah a hnâ koe a pha.   
\q1
\v 7 Hottelah, talai a kâhuet teh a pâyaw.  
\q2 A lungkhuek dawkvah, mondunaw totouh a pâyaw teh,  
\q2 a kâhuet awh.   
\q1
\v 8 A hnawng dawk hoi hmaikhu a luen takhang teh,  
\q2 a pahni dawk hoi ka tâcawt e hmai ni, koung a kak awh teh,  
\q2 hote e niyah hmaisaan a kaman sak.   
\q1
\v 9 Ama ni kalvan a kamkuisak teh, a kum cathuk.  
\q2 A khok rahim vah hmonae teh ao.   
\q1
\v 10 Cherub a kâcui teh a kamleng.  
\q2 Kahlî rathei van vah a kamleng.   
\q1
\v 11 Hmonae teh ka dungpoung e hmuen lah a coung sak.  
\q2 Tui hmonae hoi kathapoung e kalvan tâmai hah  
\q2 ama kangangkung lah ao.   
\q1
\v 12 A hmalae angnae ni, kathapoung e tâmai a kâhin sak teh,  
\q2 roun hoi hmaisaan a bo.   
\q1
\v 13 BAWIPA ni kalvan hoi khoparit sak,  
\q2 A Lathueng Poung Cathut ni a lawk a tâcosak.   
\q1
\v 14 A lipala hah a pathui teh, a taran hah a pâyaw sak.  
\q2 Sumpa a palik sak teh, koung a tâ.   
\q1
\v 15 Oe BAWIPA, na yuenae hoi na hnawng dawk e kâha ni a hmu dawkvah,  
\q2 talî laheipadin teh koung a kamnue teh,  
\q2 talaivan e dunaw teh a kamnue awh.   
\q1
\v 16 Lathueng hoi na kut na dâw teh,  
\q2 moikapap e tui thung hoi na rasa toe.   
\q1
\v 17 A thakaawmpounge ka taran kut dawk hoi na rungngang teh,  
\q2 na ka hmuhma ni teh athakaawmpounge naw koehoi  
\q2 haiyah na rungngang.   
\q1
\v 18 Ahnimouh ni runae ka kâhmo navah, na kangdue sin awh.  
\q2 Hatei, BAWIPA teh ka kâuep e doeh.   
\q1
\v 19 A hmuen kaw poung koe kai hah na thak.  
\q2 Kai dawk a lunghawi dawkvah, na rungngang.   
\q1
\v 20 BAWIPA ni, ka lannae patetlah aphu na poe.  
\q2 Ka kut a thoung e patetlah na patho toe.   
\q1
\v 21 Bangkongtetpawiteh, BAWIPA e lamthung hah ka pâkuem teh,  
\q2 ka Cathut teh kahawihoeh lahoi ka cettakhai boihoeh.   
\q1
\v 22 Bangkongtetpawiteh, a lawkcengnae pueng teh ka hmalah ao teh,  
\q2 a coungnae hah ka tâkhawng boihoeh.   
\q1
\v 23 A hmaitung toun awm laipalah ka o teh,  
\q2 payonnae hah ka roun.   
\q1
\v 24 Hatdawkvah, BAWIPA ni ka lannae patetlah na patho.  
\q2 A mithmu ka thoungnae patetlah na patho.   
\q1
\v 25 Tami ka pahren e koe pahrennae na kamnue sak vaiteh,  
\q2 tamikalan koe lannae hah na kamnue sak han.   
\q1
\v 26 Tami kathoung koe na thoungnae na kamnue sak vaiteh,  
\q2 tami ka taran e koe tarannae hah na kamnue sak han.   
\q1
\v 27 Bangkongtetpawiteh, kârahnoumnaw hah,  
\q2 na rungngang teh, kâoupnaw hah na pabo han.   
\q1
\v 28 Ka hmaiim hah na ang sak teh,  
\q2 BAWIPA ka Cathut ni kaie hmonae hah a ang sak han.   
\q1
\v 29 Nang pawlawk lahoi ransahu hah ka raphoe han.  
\q2 Ka Cathut pawlawk lahoi khorapan ka kawi thai han.   
\q1
\v 30 Cathut e lamthung teh a kuep.  
\q2 BAWIPA e lawk teh a thoung dawkvah,  
\q2 Ama kâuep e tami pueng hanelah bahling lah ao.   
\q1
\v 31 Bangkongtetpawiteh, BAWIPA laipateh,  
\q2 bangpatet e Cathut alouke maw kaawm.   
\q1
\v 32 Thaonae hoi na kapathoupkung teh Cathut doeh.  
\q2 Ka lamthung hai a kuep sak.   
\q1
\v 33 Ama ni ka khok heh sayuk khok patetlah a sak teh,  
\q2 a hmuen rasangnae koe na o sak.   
\q1
\v 34 Ka kut heh tarantuknae a cangkhai.  
\q2 Hatdawkvah, ka kut ni rahum licung patenghai a sawn thai.   
\q1
\v 35 Na rungngangnae bahling hai na poe toe.  
\q2 Aranglae kut hoi na kuet,  
\q2 na panguepnae ni na tawmdawm.   
\q1
\v 36 Ka ceinae lamthung na kaw sak dawkvah,  
\q2 tâlaw laipalah ka o.   
\q1
\v 37 Ka taran ka pâlei teh ka pha.  
\q2 Koung ka raphoe hoehroukrak ka ban takhai boihoeh.   
\q1
\v 38 Bout a thaw thai hoeh nahanelah, hmâ ka paca teh,  
\q2 ka khok rahim koung a rawp awh.   
\q1
\v 39 Tarantuk hanelah na pathoup toung dawkvah,  
\q2 na katarankung teh ka rahim vah tâ lah ao.   
\q1
\v 40 Ka taran teh na yawng sak.  
\q2 Hottelah na kahmuhmanaw heh ka raphoe.   
\q1
\v 41 Ahnimouh teh a hram awh.  
\q2 Hatei, ahnimouh rungngangkung awm hoeh.  
\q2 BAWIPA koe a hram awh ei, pato hoeh.   
\q1
\v 42 Hottelah, vaiphu kahlî ni a palek e patetlah  
\q2 dikkaneng lah ka nep teh,  
\q2 lamthung dawk e songnawng patetlah ka tâkhawng.   
\q1
\v 43 Ka yonnaw thung hoi na rungngang teh,  
\q2 miphunnaw e lû lah na coung sak.  
\q2 Ka panue hoeh e naw ni ka thaw a tawk awh han.   
\q1
\v 44 Ka lawk a thai awh tahma vah, a tarawi awh teh,  
\q2 ramlouk taminaw hai kai koe a kâhei awh.   
\q1
\v 45 Ramlouk taminaw teh koung a yawng awh teh,  
\q2 a kâhronae hmuen koehoi, taki laihoi a tâco awh.   
\q1
\v 46 BAWIPA teh a hring.  
\q2 Kaie lungsong teh pholen lah awm seh.  
\q2 Kaie rungngangnae Cathut teh tawm lah awm seh.   
\q1
\v 47 Cathut teh moipathung pouh kung lah ao teh,  
\q2 ka rahim e taminaw katâkung lah ao.   
\q1
\v 48 Ka tarannaw koehoi na rungngang teh,  
\q2 na katarankungnaw lathueng vah, na tawm.  
\q2 Rektapnaw kut dawk hoi na rungngang.   
\q1
\v 49 Hatdawkvah BAWIPA, Jentelnaw rahak vah,  
\q2 nang koe lunghawilawk ka dei vaiteh,  
\q2 na min pholen hoi la ka sak han.   
\q1
\v 50 A siangpahrang koevah, ka len e hloutnae a poe teh,  
\q2 satui awi e Devit hoi, a catounnaw lathueng vah,  
\q2 a yungyoe hoi a lungmanae a kamnue sak.   
\c 19  
\s1 Ka kuep e BAWIPA kamnuenae  
\d Kathutkung: Devit  
\q1
\v 1 Kalvannaw ni Cathut bawilennae a pathang awh.  
\q2 Kakaw poung e kalvan ni a kutsak tie a kamnue sak.   
\q1
\v 2 Khosei ni khodai koe lawk a dei teh,  
\q2 karum ni karum koe a cangkhai.   
\q1
\v 3 Lawk dei e, lawk kâpan e  
\q2 ahnimae pahni dawk hoi thai hoeh eiteh,   
\q1
\v 4 ahnimae lawk teh talai van pueng a cei teh,  
\q2 talai poutnae koe totouh a pha.  
\q2 Ahnimouh koevah, kanî hanelah lukkareiim a ta pouh.   
\q1
\v 5 Hahoi, kanî teh, yupaluenkung imrakhan thung hoi ka tâcawt e patetlah ao teh,  
\q2 yawngkâtânae koe a tha kaawm poung e, konawm laihoi ka yawng hane patetlah ao.   
\q1
\v 6 Avang lae kalvan apoutnae koehoi, a tâco teh,  
\q2 avanglae kalvan apoutnae koe totouh, a kâhei dawkvah,  
\q2 a kâannae dawk hoi kahlout e awm hoeh.   
\q1
\v 7 BAWIPA e kâlawk teh akuep dawkvah,  
\q2 hringnae a roung sak.  
\q2 BAWIPA e lawkpanuesaknae teh a kamceng dawkvah,  
\q2 kamawngrame hah a lung a ang sak.   
\q1
\v 8 BAWIPA e phunglawk teh a lan teh, lungthin a konawm sak.  
\q2 BAWIPA ni kâpoe e teh a thoung teh, mit a ang sak.   
\q1
\v 9 BAWIPA takinae teh a thoung teh, a yungyoe a kangning.  
\q2 BAWIPA lawkcengnae teh a lan teh, katang e lah ao.   
\q1
\v 10 Sui hlak hai sôlêi e sui hlak hai ngai hanelah ao.  
\q2 Khoitui hoi khoipha hlak hai a radiphnawn.   
\q1
\v 11 Hothloilah, hotnaw hno lahoi na san hah kâhruetcuet na poe teh,  
\q2 hote lawknaw tarawinae tawkphu teh a len poung.   
\q1
\v 12 Apimaw mae payonnae ka panuek thai.  
\q2 Pâpha e payonnae dawk hoi na thoung sak haw.   
\q1
\v 13 Na san heh yonnae ka sak hoeh nahanlah,  
\q2 thama lahoi na kuen nateh,  
\q2 hotnaw teh ka lathueng vah kâ tawn sak hanh.   
\q1
\v 14 Oe BAWIPA, ka thaonae hoi na ka ratangkung,  
\q2 ka dei e dawk hoi ka pouk e naw heh,  
\q2 na mithmu vah na lung ka youk lah awm seh.   
\c 20  
\s1 Cathut rungngangnae thaw  
\d Kathutkung: Devit  
\q1
\v 1 Runae hnin dawk BAWIPA ni na pato naseh.  
\q2 Jakop Cathut min lahoi na roum sak naseh.   
\q1
\v 2 Hmuen kathoung koehoi kabawpnae teh tâcawt sak naseh.  
\q2 Zion hoi tha awm sak naseh.   
\q1
\v 3 Na thuengnae pueng na thai pouh naseh.  
\q2 Hmaisawi thuengnae hai dâw naseh.   
\q1
\v 4 Na ngainae patetlah na poe naseh,  
\q2 na pouknae patetlah kuep sak naseh.   
\q1
\v 5 Na rungngangnae dawk ka konawm awh vaiteh,  
\q2 Cathut min lahoi lukkarei a yap awh han.  
\q2 BAWIPA ni na hei e pueng kuep sak lawiseh.   
\q1
\v 6 BAWIPA ni satui awi e a rungngang tie atuvah panue awh toe.  
\q2 Kathounge kalvan hoi a rungngangnae aranglae kut,  
\q2 athakaawme hoi na pato han.   
\q1
\v 7 Atangawn ni leng a kâuep awh teh,  
\q2 atangawn ni marang a kâuep awh.  
\q2 Hatei, kaimouh teh, BAWIPA Cathut min hah pou ka kâuep awh han.   
\q1
\v 8 Ahnimouh teh tabut hoi a rawp awh.  
\q2 Hatei, kaimouh teh ka thaw awh teh, kalancalah ka kangdue awh.   
\q1
\v 9 BAWIPA rungngang haw.  
\q2 Ka kaw toteh siangpahrang ni na pato naseh.   
\c 21  
\s1 BAWIPA rungngangnae dawk konawmnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA, na thaonae dawk siangpahrang ni a konawm han.  
\q2 Na rungngangnae dawk banghloimaw a konawmnae a tawn han,   
\q1
\v 2 Apâhni hoi a kâhei e hah na oun hoeh niteh,  
\q2 a lungthin ngainae hah na poe toe. Selah.   
\q1
\v 3 Bangkongtetpawiteh, hawinae yawhawi hoi na dawn teh,  
\q2 a lû dawk suikathoung bawilukhung hoi na kâmuk sak.   
\q1
\v 4 Nang koe a hei e hringnae,  
\q2 a yungyoe hoi a yungyoe totouh hringsawnae hah na poe.   
\q1
\v 5 A bawilennae teh na rungngangnae dawkvah a len,  
\q2 barinae hoi taluenae teh ahni dawk na patue toe.   
\q1
\v 6 Bangkongtetpawiteh, a yungyoe hane yawhawinae lentoe kacoekung lah na sak teh,  
\q2 na hmalah puenghoi a lung kahawi hanelah na coung sak.   
\q1
\v 7 Bangkongtetpawiteh, siangpahrang ni BAWIPA hah a kâuep.  
\q2 Lathueng Poung lungmanae lahoi kâhuen mahoeh.   
\q1
\v 8 Na kut ni na taran pueng hmawt vaiteh,  
\q2 aranglae na kut ni na ka hmuhma e pueng hah a hmu han.   
\q1
\v 9 Na lungkhuek toteh, ahnimouh hah takhuen patetlah na coung sak han.  
\q2 BAWIPA ni ahnimouh teh,  
\q2 a lungkhueknae lahoi payawp vaiteh,  
\q2 a hmai ni koung a kak awh han.   
\q1
\v 10 A catounnaw hah talai van hoi koung takhoe pouh vaiteh,  
\q2 a catounnaw hah miphunnaw thung hoi na takhoe han.   
\q1
\v 11 Bangkongtetpawiteh, nang taran lahoi,  
\q2 hawihoehnae hah sak han a kâcai awh teh,  
\q2 a sak thai awh hoeh e hah sak han a kâcai awh.   
\q1
\v 12 Hatdawkvah, ahnimouh teh na yawng sak vaiteh,  
\q2 ahnimae a mithmainaw dawk na licung hoi coungkacoe na nue toe.   
\q1
\v 13 Oe BAWIPA, na thaonae dawk tawm lah na o.  
\q2 Na thaonae pholen hoi la ka sak han.   
\c 22  
\s1 Messiah rektap khangnae  
\d Kathutkung: Devit  
\q1
\v 1 Ka Cathut, ka Cathut, bangkongmaw na cei takhai.  
\q2 Bangkongmaw ka kâhramnae lawk thai laipalah,  
\q2 na kabawp hoeh nahanlah ahlanae koe na o.   
\q1
\v 2 Oe Cathut, khodai lah kâhram ei, nang ni na thai pouh hoeh.  
\q2 Karum lahai duem ka onae awm hoeh.   
\q1
\v 3 Hatei, nang teh, na thoung.  
\q2 Isarelnaw ni pholen e lah na o.   
\q1
\v 4 Ka mintoenaw ni na kâuep teh,  
\q2 na rungngang.   
\q1
\v 5 Na kaw awh teh, na rungngang.  
\q2 Na kâuep awh teh, yeiraipo boi awh hoeh.   
\q1
\v 6 Hatei, kai teh tangraet lah doeh ka o.  
\q2 Ayâ ni pathoe e hoi pacekpahlek e lah ka o.   
\q1
\v 7 Na ka hmawt e pueng ni na panuikhai, a pahni na ke sin awh.  
\q2 A lû na saling sin awh.   
\q1
\v 8 BAWIPA a kâuep nahoehmaw, ama ni rungngang na haw seh.  
\q2 Ahni dawk a ngainae awm pawiteh,  
\q2 atu roeroe rungngang na haw seh, telah ati awh.   
\q1
\v 9 Hatei, nang teh anu von thung hoi na karasatkung doeh.  
\q2 Sanu ka nei lahun nah puennae na takhoe pouh.   
\q1
\v 10 Pek khe hoi nang dawk hruek e lah ka o.  
\q2 Anu von thung hoi patenghai, nang teh ka Cathut lah yo la na o toe.   
\q1
\v 11 Kai koehoi ahlanae koe awm hanh.  
\q2 Bangkongtetpawiteh, runae a hnai teh kabawmkung awm hoeh.   
\q1
\v 12 Maitotan moikapap ni na kalup.  
\q2 Bashan ram e athakaawme maitotannaw ni na kalup.   
\q1
\v 13 A pahni na ang sin awh teh,  
\q2 sendek patetlah a cairing awh.   
\q1
\v 14 Tui patetlah rabawk lah ka o teh,  
\q2 ka hruhrawng pueng teh koung a kâla.  
\q2 Ka lungthin teh khoilai patetlah ka thung vah, a kamyawt toe.   
\q1
\v 15 Ka tharui teh ampaikei patetlah a ke teh,  
\q2 ka lai hai ka dangka dawk a kâbet teh,  
\q2 duenae vaiphu dawk na ceikhai.   
\q1
\v 16 Bangkongtetpawiteh, uinaw ni na kalup awh.  
\q2 Tamikathoutnaw ni na kalup awh.  
\q2 Ka kut hoi ka khok pawkkayawng lah a thut awh.   
\q1
\v 17 Ka hru pueng koung ka touk thai.  
\q2 Pout laipalah na khet awh teh, a lungkhuekti awh.   
\q1
\v 18 Ka khohna a kârei awh teh,  
\q2 ka angki hah cungpam a rayu awh.   
\q1
\v 19 Oe BAWIPA na hlat takhai hanh.  
\q2 Oe ka thaonae karanglah na kabawm haw.   
\q1
\v 20 Senehmaica hoi na rungngang haw,  
\q2 ka hringnae ka sungren e heh uinaw thaonae koehoi  
\q2 na rungngang haw.   
\q1
\v 21 Sendek kâko dawk hoi na rungngang nateh,  
\q2 savi ki dawk hoi na rungngang haw. Na pato leih.   
\q1
\v 22 Ka hmaunawnghanaw koe na min ka pâpho vaiteh,  
\q2 kamkhuengnaw koe na pholen han.   
\q1
\v 23 Nangmouh BAWIPA kataketnaw, ama teh pholen awh.  
\q2 Jakop catounnaw pueng ama teh tawmrasang awh nateh,  
\q2 Isarel catounnaw pueng ama teh taket awh.   
\q1
\v 24 Bangkongtetpawiteh, runae ka khang e runae hah,  
\q2 dudam hoeh niteh, ahni koehoi a minhmai hai hrawk hoeh.  
\q2 Hatei, ahni koe a hram toteh a thai.   
\q1
\v 25 Kalen e kamkhuengnae koe ka pholen e teh nang han doeh.  
\q2 Ama kataketnaw hmalah ka lawkkam hah ka kuep sak han.   
\q1
\v 26 Tami ka roedeng ni cat vaiteh a von a paha han.  
\q2 Ama katawngnaw ni BAWIPA teh a pholen han.  
\q2 Na lungthin hah pou kâhlaw seh.   
\q1
\v 27 Talai poutnae pueng ni a pâkuem awh teh,  
\q2 BAWIPA koe a kamlang awh vaiteh, miphun pueng ni na bawk awh han.   
\q1
\v 28 Bangkongtetpawiteh, uknaeram teh BAWIPA e doeh.  
\q2 Miphunnaw hah a uk.   
\q1
\v 29 Talaivan katawntanaw pueng ni cat awh vaiteh a bawk awh han.  
\q2 Ma e hringnae ring thai awh hoeh.  
\q2 Vaiphu lah ka ban e pueng a hmalah a tabo awh han.   
\q1
\v 30 Ahnimae catounnaw ni hai a bawk awh vaiteh,  
\q2 catounnaw ni hai BAWIPA e kamthang hah a dei awh han.   
\q1
\v 31 A lannae, pâpho hanelah a tho awh vaiteh,  
\q2 khe lah kaawm hane naw koe  
\q2 BAWIPA ni hetheh a sak telah a pâpho awh han.   
\c 23  
\s1 Tukhoumkung kahawi  
\d Kathutkung: Devit  
\q1
\v 1 BAWIPA teh kaie tukhoumkung lah ao dawkvah,  
\q2 voutthoup hoi kaawm mahoeh.   
\q1
\v 2 Pho kahring um vah na tabo sak teh,  
\q2 kâhatnae tui teng vah na hrawi.   
\q1
\v 3 Ka hringnae a katha sak teh,  
\q2 amae min lahoi lannae lam dawk na hrawi.   
\q1
\v 4 Duenae tâhlip ravo dawk ka cet nakunghai,  
\q2 yawthoenae hai ka taket mahoeh.  
\q2 Bangkongtetpawiteh, kai koevah nang na o,  
\q2 na sonron hoi na tahroe ni ka lung na mawng sak.   
\q1
\v 5 Ka tarannaw hmalah rawca na poe,  
\q2 ka lû dawk satui na awi teh,  
\q2 kaie manang teh poum lah a poum.   
\q1
\v 6 Ka hring nathung lungmanae hoi  
\q2 hawinae ni na kâbang sin vaiteh,  
\q2 BAWIPA im dawk a yungyoe ka o han.   
\c 24  
\s1 Lentoenae siangpahrang  
\d Kathutkung: Devit  
\q1
\v 1 Talai hoi athung e hno kaawm naw pueng BAWIPA e doeh.  
\q2 Talai hoi avan e kaawm e taminaw pueng hai amae doeh.   
\q1
\v 2 tuipui dawk adu a ung teh,  
\q2 tuinaw dawk acaksak.   
\q1
\v 3 BAWIPA mon dawk apimaw ka luen thai han.  
\q2 A bawkim kathoung vah apimaw ka kâen thai han   
\q1
\v 4 Tawksaknae hoi lungthin a thoung teh,  
\q2 kahrai ka bawk hoeh e, dumyennae lawkkamnae ka sak hoeh e naw hah  
\q2 a luen thai awh vaiteh a kâen thai awh han.   
\q1
\v 5 BAWIPA ni yawhawinae a poe vaiteh,  
\q2 ahnimouh kaie rungngangnae Cathut ni  
\q2 na yon hoeh atipouh awh han.   
\q1
\v 6 Hot patetlah, taminaw teh  
\q2 Cathut koe ka phat thai e taminaw doeh.  
\q2 Jakop e Cathut hmalah ka tâcawt thai e doeh.   
\q1
\v 7 Oe longkhanaw na lû loungouk awh haw.  
\q2 Yungyoe takhangnaw loungouk awh haw.  
\q2 Bawilennae Siangpahrang teh a kâen han.   
\q1
\v 8 Ka lentoe e Siangpahrang teh apimaw  
\q2 BAWIPA teh athakasai ni teh athakaawme,  
\q2 BAWIPA teh taran tuknae hmuen koe athakaawme doeh.   
\q1
\v 9 Oe longkhanaw na lû loungouk awh haw  
\q2 Yungyoe takhangnaw loungouk awh haw.  
\q2 Bawilennae Siangpahrang teh a kâen han.   
\q1
\v 10 Bawilennae Siangpahrang teh apimaw  
\q2 Ama teh ransahu BAWIPA,  
\q2 ka lentoe e Siangpahrang doeh.   
\c 25  
\s1 Ngaithoumnae hoi rungngangnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA nang koe ka ratoum.   
\q1
\v 2 Oe ka Cathut nang teh na kâuep dawkvah,  
\q2 Kayanae koe na phat sak hanh,  
\q2 ka tarannaw ni na tâ hanh naseh.   
\q1
\v 3 Nang na karingnaw teh kayak awh mahoeh.  
\q2 Hatei, nang taran hanlah a hue karangnaw teh a kaya awh han.   
\q1
\v 4 Oe, BAWIPA na lamthung hah  
\q2 na cangkhai nateh na panuek sak haw.   
\q1
\v 5 Nang teh kaie rungngangnae lah na o dawkvah  
\q2 na lawkkatang boiboe lah hringnae teh na cangkhai haw.  
\q2 Amon hoi kanîloum ditouh nang hah na kâuep han.   
\q1
\v 6 Oe BAWIPA yampa hoi ka lathueng vah  
\q2 na la kamnue sak e lungpatawnae, pahrennae teh pahnim hanh.   
\q1
\v 7 Ka naw nah ka yonnae hoi ka payonnae teh  
\q2 na ngaithoum haw, kacakpounge na lungmanae hoi  
\q2 na hawinae kecu dawk kai teh na pahnim hanh Bawipa.   
\q1
\v 8 BAWIPA teh a lan teh ahawi.  
\q2 Tamikayonnaw ni a dawn e lamthungnaw hai a cangkhai.   
\q1
\v 9 A lungthin kârahnoum e teh lam kalan dawk a hrawi teh  
\q2 angnae hno hah a cangkhai.   
\q1
\v 10 A lawkkam hoi kâlawk katarawinaw teh  
\q2 lungpatawnae hoi a hrawi teh yuemkamculah a ceikhai.   
\q1
\v 11 Oe, Cathut ka yonnae teh banghloi kalen nakunghai  
\q2 na min lahoi na ngaithoum haw.   
\q1
\v 12 BAWIPA kâlawk ka tarawi e teh  
\q2 a dawn hane lamthung a panue han.   
\q1
\v 13 Lungnem lahoi na o vaiteh na canaw teh  
\q2 hete ram dawkvah phu kanepcalah kho a sak awh han.   
\q1
\v 14 BAWIPA e kâlawk katarawinaw e hui lah  
\q2 ao teh a lawkkam teh a cangkhai awh.   
\q1
\v 15 BAWIPA teh kâuep yungyoe,  
\q2 hatdawvak tangkam dawk hoi ka khoh hah a rasa han.   
\q1
\v 16 Oe, BAWIPA kai koe lah kangvawi nateh na pahren haw,  
\q2 bangdawk tetpawiteh ka o a ru teh ka thayung abaw.   
\q1
\v 17 Ka lung reithainae naw pueng teh na panue patetlah  
\q2 ka runae pueng koehoi na rungngang haw.   
\q1
\v 18 Ka reithainae puenghoi ka khangnae naw pueng hah,  
\q2 na pouk pouh teh, ka yonnae naw pueng teh na ngaithoum haw.   
\q1
\v 19 Ka tarannaw apap e hoi,  
\q2 kai puenghoi na hmuhma awh e hah pouk haw.   
\q1
\v 20 Ka hringnae ring nateh na rungngang haw.  
\q2 Hloutnae hmu ka ngai dawkvah nang teh na pâtam.  
\q2 Yeiraipo hoi na awm sak hanh.   
\q1
\v 21 Nang teh na kâuep dawkvah ka hawinae hoi  
\q2 laithoehoehnae ni na la ngue lawi seh.   
\q1
\v 22 Oe, BAWIPA Isarelnaw runae koehoi  
\q2 rungngang haw.   
\c 26  
\s1 Ratang nahanelah ratoumnae  
\d Kathutkung: Devit  
\q1
\v 1 BAWIPA, nang ni kai lawk na ceng haw,  
\q2 lungcaknae hoi ka cei teh  
\q2 BAWIPA nang na kâuep dawkvah ka kâhuen mahoeh.   
\q1
\v 2 Kai hah na noumcai nateh, oe BAWIPA,  
\q2 ka lung ni a ngai e naw hoi ka pouknae hah na khen pouh haw.   
\q1
\v 3 Ka cak e na lungpatawnae lamthung kai na patue haw,  
\q2 yuemkamcunae ni pou na hrawi.   
\q1
\v 4 Dumyennae hoi cungtalah ka hmawng hoeh.  
\q2 Tami kahawihoehnaw hai ka hmawng hoeh.   
\q1
\v 5 Tami kahawihoehnaw e kamkhuengnae hah ka hmuhma,  
\q2 Tamikathoutnaw hoi reirei ka tahung hoeh.   
\q1
\v 6 Ka kut heh thoungnae hoi ka pâsu teh  
\q2 BAWIPA namae thuengnae ka lawngven.   
\q1
\v 7 Lunghawilawkdeinae la ka sak teh  
\q2 kângairu hno na sak e hah ka dei.   
\q1
\v 8 BAWIPA na onae im hah kai lungpataw teh  
\q2 na bawilennae hmuen hah kai ni ka ngai.   
\q1
\v 9 Tamikayonnaw koe kai mek thei sin hanlah  
\q2 tami kathetnaw koe kai na tâkhawng sin hanh.   
\q1
\v 10 Ahnimouh teh hawihoehnae yungyoe a sak awh.  
\q2 Tadawnghno ka ngai e taminaw doeh.   
\q1
\v 11 Kai teh hnokahawi hoeh e ka sak,  
\q2 na pahren nateh na rungngang haw.   
\q1
\v 12 Hnâroumcalah tanghling dawk ka kangdue teh  
\q2 maya a kamkhuengnae koe BAWIPA nang na pholen.   
\c 27  
\s1 Yuemnae dawk lunghawinae  
\d Kathutkung: Devit  
\q1
\v 1 BAWIPA nang teh angnae hoi kaie rungngangnae doeh.  
\q2 Apihai ka taket ma hoeh. BAWIPA nang teh na kanguekung  
\q2 ka rapan la doeh na o ka lungpuen mahoeh.   
\q1
\v 2 Tami kahawihoehnaw ni na tuk teh  
\q2 thei hanlah na nout navah ouk a rawp awh teh ouk a tâlaw awh.   
\q1
\v 3 Ransahu kalenpoung ni na kalup nakunghai ka lungpuen mahoeh.  
\q2 Taran ni na ka tuk nahai Cathut nang teh na kângue mingming han.   
\q1
\v 4 BAWIPA koe hno hei han ka ngai e hno buet touh doeh kaawm.  
\q2 Hothateh ka hring yunglam BAWIPA imthung o hane hoi yah,  
\q2 kângai runae lahoi lam na hrawi tie hah doeh.   
\q1
\v 5 Rucatnae atueng dawkvah hnâroumcalah a rathei rahim na o sak.  
\q2 A bawkim thung vah hnâroumcalah na ta,  
\q2 ka rasang e lungsong van na thueng.   
\q1
\v 6 Hatdawkvah ka tengpam e kaawm e ka taran teh katâ han  
\q2 lunghawinae pawlawk hoi a bawkim thungvah  
\q2 thuengnae teh ka poe han.   
\q1
\v 7 BAWIPA pahren lahoi, kai ni na kaw navah ka lawk  
\q2 na thai pouh nateh kahei e na thai pouh haw.   
\q1
\v 8 Kai koe, Tho haw na ka tet e  
\q2 BAWIPA koe ka tho han.   
\q1
\v 9 Kai koe na minhmai hrawk hanh.  
\q2 Kai koe na lungphuen hanh, na san heh na pâlei hanh lah a.  
\q2 Oe Cathut kaie rungngangnae nang teh kabawmkung doeh.  
\q2 Na cettakhai hanh. Pak na tha hanh lah a.   
\q1
\v 10 Anu hoi apa ni na ka pahnawt nakunghai  
\q2 BAWIPA nang ni pou na khenyawn lah a.   
\q1
\v 11 Oe, BAWIPA taran ka tawn dawkvah roumnae lam koe lahoi na cetkhai lah a.  
\q2 Na ngainae na pâtu haw.   
\q1
\v 12 Laithoe hoi pou na ka yue e  
\q2 taran koe na tat hanh.   
\q1
\v 13 A taminaw lathueng BAWIPA hawinae  
\q2 ka hmu roeroe han telah ka yuem.   
\q1
\v 14 BAWIPA teh kângue awh, yuemnae tawn awh,  
\q2 na lungpout awh hanh.  
\q2 BAWIPA teh kângue awh.   
\c 28  
\s1 BAWIPA teh ka tha hoi kânguenae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA nang teh na kaw.  
\q2 Ka lungsong, lawkkamuem na awm mahoeh.  
\q2 Nang ni banglahai na ngaihoeh lah, lawkkamuem na awm pawiteh,  
\q2 kai teh tangkom dawk ka bawt e patetlah doeh ka o toe.   
\q1
\v 2 Bawipa nang koe ka hramki laihoi kabawpnae ka hei nahai thoseh,  
\q2 Bawipa nange hmuenkathoung, a thung lah ka kut ka dâw to hai thoseh,  
\q2 kai ni ka hei e hah na thai pouh haw.   
\q1
\v 3 Tamikathoutnaw hoehpawiteh,  
\q2 yonnae ka sak e naw hoi cungtalah kai hah na sawn hanh la.   
\q1
\v 4 Ahnimae sakyoenae hoi kathoute nuencang patetlah patho haw.  
\q2 Amamae kut hoi a sak awh e patetlah patho haw.  
\q2 Ahnimouh ni a khang kawi e hah amamae van bout phat sak haw.   
\q1
\v 5 Ahnimouh teh, BAWIPA e thawnaw hai thoseh,  
\q2 A kutsaknaw hai thoseh,  
\q2 kâhruetcuet laihoi a pouk awh hoeh dawkvah,  
\q2 ahnimanaw hah raphoe vaiteh,  
\q2 nâtuek hai ahnimouh teh bout thaw thai mahoeh toe.   
\q1
\v 6 BAWIPA teh yawhawinae awmseh.  
\q2 Bangkongtetpawiteh, ka heinae lawk hah a thai toe.   
\q1
\v 7 BAWIPA teh kaie ka thaonae hoi kaie e bahling lah ao.  
\q2 Ka lungthin ni a kâuep teh, kabawpnae hah a coe.  
\q2 Hatdawkvah, puenghoi ka konawm. Kai ni la hoi ka pholen han.   
\q1
\v 8 BAWIPA teh a miphunnaw e tha lah ao teh,  
\q2 satui awi e naw ni kâuep e rungngangnae lah ao.   
\q1
\v 9 Na miphun hah rungngang na teh,  
\q2 Nange râw hah yawhawi poe haw.  
\q2 Ahnimae tukhoumkung lah awm na teh,  
\q2 ahnimanaw hah a yungyoe sin haw.   
\c 29  
\s1 BAWIPA lawk  
\d Kathutkung: Devit  
\q1
\v 1 Oe nangmouh athakaawmnaw,  
\q2 BAWIPA teh pâtam awh haw.  
\q2 BAWIPA koe bawilennae hoi thayung hah poe awh.   
\q1
\v 2 BAWIPA koe a min hoi kamcu e bawilennae hah poe awh  
\q2 BAWIPA teh thoungnae kamthoup lahoi bawk awh.   
\q1
\v 3 BAWIPA lawk teh tui dawk ao teh,  
\q2 Cathut bawilennae teh puenghoi a cai,  
\q2 BAWIPA teh tui moikapap dawk ao.   
\q1
\v 4 BAWIPA lawk teh bahuonae hoi a kawi.  
\q2 BAWIPA lawk teh taluenae hoi a kawi.   
\q1
\v 5 BAWIPA lawk ni sidar thingnaw a khoe,  
\q2 BAWIPa ni Lebanon mon e sidar thingnaw a pâyaw sak.   
\q1
\v 6 Maitoca patetlah a cawkdawk sak teh,  
\q2 Lebanon hoi Sirion hah savica patetlah a cawkdawk sak.   
\q1
\v 7 BAWIPA lawk ni hmaisaan hah a kapek.   
\q1
\v 8 BAWIPA lawk ni kahrawng hai a kahuet,  
\q2 BAWIPA ni Kadesh kahrawng hai a kahuet.   
\q1
\v 9 BAWIPA lawk ni sayuk ca a khe sak teh,  
\q2 kahrawng e thinghna pueng koung a due.  
\q2 A bawkim dawk tami pueng ni 'a sungren' telah ati awh.   
\q1
\v 10 Tuikalen dawkvah bawitungkhung dawk  
\q2 BAWIPA teh a tahung  
\q2 BAWIPA teh siangpahrang patetlah pou a tahung.   
\q1
\v 11 BAWIPA ni a taminaw hah a thaosak teh,  
\q2 BAWIPA ni a taminaw hah roumnae lahoi  
\q2 yawhawi a poe han.   
\c 30  
\s1 Ratoum patonae yawhawi  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA na pholen han.  
\q2 Bangkongtetpawiteh, na tawmrasang.  
\q2 Ka tarannaw ni na panuikhai hane na pasoung hoeh.   
\q1
\v 2 Oe BAWIPA, ka Cathut, nang koe ka hram teh,  
\q2 na kabawp teh na dam sak.   
\q1
\v 3 Oe BAWIPA, ka hringnae heh phuen thung hoi na rasa teh,  
\q2 tangkom dawk ka bo hoeh nahanlah na hring sak.   
\q1
\v 4 A tamikathoungnaw, BAWIPA pholen hoi la sak awh.  
\q2 A min kathoung pahnim hoeh nahanlah, konawm lawk dei awh.   
\q1
\v 5 A lungkhueknae teh tawkkadek doeh,  
\q2 a ngaikhainae teh hringyung hane doeh.  
\q2 Kanae teh tangmin vah a roe. Hatei, amom vah konawmnae a pha.   
\q1
\v 6 Ka tawnta nateh,  
\q2 ka vout mahoeh toe ka ti.   
\q1
\v 7 BAWIPA na ngaikhainae lahoi,  
\q2 ka mon teh kacaklah na kangdue sak.  
\q2 Na minhmai na hro toteh, ka lungrei a thai.   
\q1
\v 8 Oe BAWIPA nang koe ka hram teh,  
\q2 BAWIPA koe ka kâhei.   
\q1
\v 9 Tangkom dawk ka bo toteh,  
\q2 ka thi ni bang hawinae maw a tawn.  
\q2 Vaiphu ni na pholen vaiteh  
\q2 na lawkkatang hah a pâpho han na maw.   
\q1
\v 10 Oe BAWIPA, ka lawk na thai pouh haw.  
\q2 Na pahren haw. BAWIPA kabawmkung lah pou awm haw.   
\q1
\v 11 Ka cingounae hah  
\q2 lamnae lah na coung sak.   
\q1
\v 12 Apout totouh ka bawilennae ni kâhat laipalah na pholen teh, la a sak thai nahanlah,  
\q2 Oe BAWIPA ka Cathut, a yungyoe hoi konawmnae lawk ka dei han.   
\c 31  
\s1 Tarannaw koehoi BAWIPA kânguenae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA, nang doeh na kâuep.  
\q2 Kaya hoi na awm sak hanh. Na lannae hoi na rungngang haw.   
\q1
\v 2 Kai koelah na hnâpakeng nateh, karanglah na rungngang haw.  
\q2 Ka kâhronae lungsong hoi rungngang nahanlah  
\q2 ngangnae rapan lah awm haw.   
\q1
\v 3 Bangkongtetpawiteh, nang teh ka lungsong hoi ka kâhronae lah na o.  
\q2 Hatdawkvah, na min kecu dawk na hrawi nateh, na patue haw.   
\q1
\v 4 Kai hanlah, arulahoi a phai awh e tamlawk dawk hoi na rasat haw.  
\q2 Bangkongtetpawiteh, nang teh ka thaonae doeh.   
\q1
\v 5 Oe BAWIPA, lawkkatang Cathut,  
\q2 na kut dawk ka muitha ka hruek.   
\q1
\v 6 Cungkeihoehe meikaphawk alawkpui lah kahruengnaw hah ka hmuhma.  
\q2 Hatei, kai teh BAWIPA ka kâuep.   
\q1
\v 7 Na pahrennae lahoi, ka konawm vaiteh, ka lung pou ahawi han.  
\q2 Bangkongtetpawiteh, ka runae hah ouk na hmu pouh.  
\q2 Runae thung ka hringnae hah na panue.   
\q1
\v 8 Taran kut dawk na poe laipalah,  
\q2 A hmuen kawnae koe ka khok hah ouk na hruek.   
\q1
\v 9 Oe BAWIPA, na pahren haw.  
\q2 Bangkongtetpawiteh, runae thungvah ka o.  
\q2 Ka lungmathoe lawi ka mit koung a ro toe.  
\q2 Bokheiyah, ka muitha hoi ka takthai totouh a ro toe.   
\q1
\v 10 Bangkongtetpawiteh, ka hringnae heh  
\q2 lungmathoenae hoi koung ka hno toe.  
\q2 Kum moikasawlah ka cingou.  
\q2 Ka payonnae ni ka thaonae a baw sak.  
\q2 Ka hru hai koung a hmawn toe.   
\q1
\v 11 Ka tarannaw ni pathoe hanelah doeh ka o.  
\q2 A lawkpui lah, ka imrinaw hanelah hoe ka o.  
\q2 Ka hui kahawi ni na panuet teh,  
\q2 lam dawk na ka hmawt e ni na yawng takhai.   
\q1
\v 12 Tami kadout patetlah pahnim lah ka o teh,  
\q2 ampaikei patetlah ka o.   
\q1
\v 13 Bangkongtetpawiteh, tami moikapap ni a dei awh e ka thai.  
\q2 A hmuen tangkuem takinae ao.  
\q2 Ka hringnae la hanelah kâcai laihoi a kamkhueng awh teh,  
\q2 kho a khan awh.   
\q1
\v 14 Hatei, Oe BAWIPA, kai ni teh nang doeh na kâuep.  
\q2 Ka Cathut doeh ka ti.   
\q1
\v 15 Kaie tuengnaw teh na kut dawk ao.  
\q2 Ka tarannaw kut dawk hoi, na kapahuipalamnaw kut dawk hoi,  
\q2 na rungngang haw.   
\q1
\v 16 Na san koe na mei ang naseh.  
\q2 Na pahrennae lahoi na rungngang lawiseh.   
\q1
\v 17 Oe BAWIPA, kaya hoi na awm sak hanh.  
\q2 Bangkongtetpawiteh, nang teh na kaw toe.  
\q2 Tamikathoutnaw teh, kaya laihoi phuen vah  
\q2 duem awm awh naseh.   
\q1
\v 18 Tamikalannaw taran lahoi, kâoupnae,  
\q2 hoi matheng laihoi laithoe deinae pahni teh,  
\q2 lawkkamuem lah o sak lah awm seh.   
\q1
\v 19 Oe nang kataketnaw hanelah,  
\q2 na pâkhueng e hoi tami capanaw mithmu vah,  
\q2 nang kâuepnaw hanelah,  
\q2 na noe e na hawinae hah banghloimaw a bawilen.   
\q1
\v 20 Taminaw e arulahoi khokhangnae thung hoi,  
\q2 hlout sak nahanelah, ahnimanaw teh,  
\q2 na onae koe na hmalah na hro han.  
\q2 Tamthoe kadeinaw e lai dawk hoi na rungngang vaiteh,  
\q2 na rim dawk na hro han.   
\q1
\v 21 BAWIPA teh pholen lah awm seh.  
\q2 Bangkongtetpawiteh, kângairu a pahrennae teh,  
\q2 kacakpounge khopui dawk na hmu sak.   
\q1
\v 22 Bangkongtetpawiteh, kai teh na mithmu vah,  
\q2 tâkhawng lah yo ka o toe telah tang ka dei.  
\q2 Hatei, ka hram teh pahrennae ka hei e lawk hah na thai.   
\q1
\v 23 Oe tamikathoungnaw pueng,  
\q2 BAWIPA teh lungpataw awh.  
\q2 Bangkongtetpawiteh, BAWIPA ni yuemkamcu e hah a khetyawt teh,  
\q2 kâoupnaw hah moi a pathung.   
\q1
\v 24 BAWIPA kâuepnaw pueng, tarankahawi lah awm awh,  
\q2 na lungthin a thao sak han.   
\c 32  
\s1 Ngaithoumnae hoi konawmnae  
\d Kathutkung: Devit  
\q1
\v 1 Kâtapoenae ngaithoum lah kaawm e hoi  
\q2 a yonnae ramuk pouh lah kaawm e teh a yawkahawi e doeh.   
\q1
\v 2 BAWIPA ni yonnae ka tawn hoeh e lah a pouk e hoi,  
\q2 a muitha dawk dumyennae kaawm hoeh e teh,  
\q2 tami a yawkahawi e doeh.   
\q1
\v 3 Yon pâpho laipalah ka o teh, kanîruirui ka cingou navah,  
\q2 ka hrunaw teh koung a hmawn toe.   
\q1
\v 4 Bangkongtetpawiteh, kanîruirui nange kut ni ka van vah a ri teh,  
\q2 ka thaonae teh kawmpoi kâan e patetlah rem a phui.   
\q1
\v 5 Ka yonnae hah nang koe ka pâpho.  
\q2 Ka payonnae hai ka ramuk hoeh.  
\q2 BAWIPA koe ka yonnae ka pâpho han ka ti.  
\q2 Hahoi, nang ni, ka yonnae hah na ngaithoum.   
\q1
\v 6 Bangkongtetpawiteh, hmu thai lah na o navah,  
\q2 Cathutlae tami pueng ni, nang koe ratoum naseh.  
\q2 Tûili ka tho nakunghai, ahnimouh teh phat mahoeh.   
\q1
\v 7 Nang teh kai hanlah, kâhronae hmuen doeh.  
\q2 Runae thung hoi na hlout sak han.  
\q2 Hloutnae la hoi na kalup han. Selah.   
\q1
\v 8 Na cei nahane lamthung na patue han.  
\q2 Na cangkhai vaiteh, ka mit hoi khet laihoi na hrawi han.   
\q1
\v 9 Thaipanueknae ka tawn hoeh e marang hoi la patetlah awm hanh.  
\q2 Hotnaw teh nang koe a hnai awh hoeh dawkvah,  
\q2 pahnimoum hoi sawn lah ao han.   
\q1
\v 10 Tamikathoutnaw teh lungreknae moi a khang awh.  
\q2 Hatei, BAWIPA kâuep e naw teh a pahrennae ni a kalup han.   
\q1
\v 11 Tami kalannaw, BAWIPA dawk lunghawi awh nateh,  
\q2 lannae dawk konawm awh.  
\q2 Lungthin kalan e tami pueng,  
\q2 lunghawi awh nateh hram awh haw.   
\c 33  
\s1 BAWIPA dawk hringnae  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 Oe, tamikalannaw, BAWIPA dawk konawm awh nateh, la sak awh.  
\q2 Pholennae teh lungthin kalannaw hanelah a kamcu doeh.   
\q1
\v 2 Ratoung hoi BAWIPA teh pholen awh.  
\q2 rui hra touh e ratoung hoi pholen awh.   
\q1
\v 3 Ama koe la katha sak awh nateh,  
\q2 lunghawilawk hoi kathoum katang lahoi kueng awh.   
\q1
\v 4 Bangkongtetpawiteh, BAWIPA lawk teh a lan,  
\q2 a tawk e pueng teh yuemkamculah ao.   
\q1
\v 5 Lannae hoi kângingnae hah a lungpataw teh,  
\q2 talai teh BAWIPA hawinae hoi koung akawi.   
\q1
\v 6 BAWIPA e lawk hoi kalvannaw sak lah ao teh,  
\q2 kalvan kaawm e pueng hai a kâko hoi e kâha hoi sak e seng doeh.   
\q1
\v 7 Talîpui tuinaw hah a pâkhueng teh,  
\q2 kadungpoung e tuinaw hah ao nahane hmuen koe a hruek.   
\q1
\v 8 Talai pueng ni BAWIPA taket naseh,  
\q2 talaivan kaawm e pueng ni ama teh taket awh naseh.   
\q1
\v 9 Bangkongtetpawiteh, lawk a dei boteh ao.  
\q2 Kâ a poe boteh, kacaklah hmawi a kangdue.   
\q1
\v 10 BAWIPA ni miphunlouknaw e kâpannae teh a takhoe toe.  
\q2 Tamimaya ni sutpouknae hai banghai bang hoeh lah a coung sak.   
\q1
\v 11 BAWIPA ni kâpankhai e teh a yungyoe a kangning.  
\q2 Sut a pouk e teh catounnaw hane totouh a cak.   
\q1
\v 12 A Cathut Jehovah lah kaawm e miphun teh a yawhawi.  
\q2 Ama ni râw lah a rawi e miphun teh, tami yawkahawi e doeh.   
\q1
\v 13 BAWIPA ni kalvan hoi a khet teh,  
\q2 tami capa pueng koung a hmu.   
\q1
\v 14 A onae hmuen koehoi talai van  
\q2 kaawm e pueng koung a radoung.   
\q1
\v 15 Tami pueng e lungthin koung a pathoup teh,  
\q2 a sak e puenghai koung a pouk pouh.   
\q1
\v 16 Siangpahrang teh ransa moikapap a tawn dawk  
\q2 rungngang lah awm hoeh.  
\q2 Tami a tha kaawm hai a thaonae ni rungngang mahoeh.   
\q1
\v 17 Marang teh rungngang nahanelah  
\q2 cungkeihoehe ngaihawinae doeh.  
\q2 Thaonae kalen ni hai rungngang thai hoeh.   
\q1
\v 18 Duenae koehoi hringnae rasa hane hoi  
\q2 takang dawk due hoeh nahanlah,   
\q1
\v 19 khenhaw! BAWIPA e mit ni  
\q2 ama ka taketnaw koe pou a khet.   
\q1
\v 20 Ka hringnae ni BAWIPA a ring,  
\q2 ama teh kabawmkung hoi ka bahling doeh.   
\q1
\v 21 Bangkongtetpawiteh, ka lungthin teh ama dawk a konawm han.  
\q2 Bangkongtetpawiteh, a min kathoung teh kâuep awh.   
\q1
\v 22 Oe BAWIPA, nang dawk ngaihawinae ka tawn awh e patetlah  
\q2 na pahrennae teh, kaimouh lathueng awm lawiseh.   
\c 34  
\s1 Cathut kâuepnaw konawmnae  
\d Kathutkung: Devit, Abimelek hmalah pathu a kâsak nah ahni ni a hrek teh, a ceitakhai nah sak e la  
\q1
\v 1 BAWIPA teh pou ka pholen han.  
\q2 Ama pholennae teh ka kâko hoi pou tâcawt seh.   
\q1
\v 2 Ka hringnae ni BAWIPA dawk a kâoup han.  
\q2 Kârahnoumnaw ni a thai awh vaiteh, a lunghawi awh han.   
\q1
\v 3 Oe BAWIPA teh na pholen khai awh haw.  
\q2 A min teh rei kâoupkhai awh sei.   
\q1
\v 4 BAWIPA ka tawng navah, ama ni na thai pouh.  
\q2 Ka takinae pueng thung hoi na rasa.   
\q1
\v 5 Ama kakhennaw teh, minhmai a pan awh.  
\q2 Nâtuek hai kayanae awm mahoeh.   
\q1
\v 6 Hete mathoe ni a hram teh, BAWIPA ni a thai.  
\q2 Runae pueng thung hoi a rasa.   
\q1
\v 7 Ama kataketnaw teh, BAWIPA e kalvantami ni  
\q2 a teng vah petkâkalup lahoi a tungpup sin awh teh, ouk a rasa awh.   
\q1
\v 8 Oe, BAWIPA hawinae patek awh nateh khen awh haw.  
\q2 Ama kâuepnaw teh tami a yawkahawinaw doeh.   
\q1
\v 9 Oe, a tamikathoungnaw, BAWIPA teh taket awh.  
\q2 A ma kataketnaw teh voutthoup hoi awm boihoeh.   
\q1
\v 10 Sendektancanaw patenghai ca hane tawn laipalah  
\q2 vonhlam hoi ouk ao awh.  
\q2 Hatei, BAWIPA katawngnaw teh, hnokahawi tawn laipalah,  
\q2 awm awh mahoeh.   
\q1
\v 11 Camonaw tho awh haw, ka lawk thai awh haw.  
\q2 BAWIPA takinae na cangkhai awh han.   
\q1
\v 12 Apimaw nuenkahawi hoi hring han ka ngai.  
\q2 Apimaw hnokahawi hmu hanlah hring saw ka ngai.   
\q1
\v 13 Na lai teh yonnae thung hoi ring nateh,  
\q2 na pahni hah dumnae lawk dei hoeh nahanlah ring haw.   
\q1
\v 14 Yonnae cettakhai nateh hawinae sak.  
\q2 Roumnae tawng nateh pâleih.   
\q1
\v 15 BAWIPA mit ni tamikalannaw a khet teh,  
\q2 a hramnae lawk thai hanelah a hnâ a pakeng.   
\q1
\v 16 BAWIPA minhmai ni hawihoehnae kasakkungnaw hah a taran.  
\q2 Talai van ahnimouh pou pouknae tâkhawng pouh lah ao han.   
\q1
\v 17 Tamikalan a hram toteh, BAWIPA ni a thai pouh teh  
\q2 runae thung hoi a rasa.   
\q1
\v 18 A lungkareknaw hanelah,  
\q2 BAWIPA a hnai teh, muitha lungkamathoutnaw a rungngang.   
\q1
\v 19 Tamikalannaw ni runae moi a kâhmo awh.  
\q2 Hatei, BAWIPA ni hotnaw thung hoi a rungngang.   
\q1
\v 20 A hru pueng a ring pouh,  
\q2 buet touh boehai khoe lah awm mahoeh.   
\q1
\v 21 Hawihoehnae ni tamikathout thet vaiteh,  
\q2 tamikalan kahmuhmanaw teh thoebo lah ao awh han.   
\q1
\v 22 BAWIPA ni a sannaw hringnae hah a ratang teh,  
\q2 ama kâuepnaw teh buet touh boehai thoebo lah awm mahoeh.   
\c 35  
\s1 A taminaw hanlah BAWIPA ni moipathungnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA, kai na ka tarannaw hah, taran van haw.  
\q2 Kai na katuknaw hah tuk van haw.   
\q1
\v 2 Taisawm hoi bahling lat nateh,  
\q2 kai kabawp hanelah kangdout haw.   
\q1
\v 3 Tahroe hai patuem nateh, na kapâleinaw hah ngang haw.  
\q2 Ka hringnae koe vah na kaie rungngangnae doeh tie dei haw.   
\q1
\v 4 Ka hringnae la hanelah, kakâcainaw hah kayayeirai hoi awm sak nateh,  
\q2 runae poe hanlah kakâcainaw hah yawng sak nateh,  
\q2 lungpout hoi awm sak haw.   
\q1
\v 5 Kahlî ni vaikong palek e patetlah awm awh naseh.  
\q2 BAWIPA e kalvantami ni koung kahmat lah pâlei naseh.   
\q1
\v 6 Ahnimouh ni a dawn awh e lamthung teh, kahmot e,  
\q2 ka pâhnan e lam lah awm naseh.  
\q2 Hawvah, BAWIPA e kalvantaminaw ni pâlei naseh.   
\q1
\v 7 Bangkongtetpawiteh, a khuekhaw awm laipalah,  
\q2 ka kâman nahanelah arulahoi tamlawk a yap awh toe.  
\q2 A khuekhaw awm laipalah, ka bo nahane tangkom a tai awh.   
\q1
\v 8 Pouk laipalah ahnimouh teh rawk awh naseh.  
\q2 Arulahoi tamlawk a yap awh e dawk amamouh kâman awh naseh.  
\q2 Amamae tangkom dawk amamouh bawt awh naseh.   
\q1
\v 9 Ka hringnae heh BAWIPA dawk a lunghawi vaiteh,  
\q2 a rungngangnae dawk a konawm han.   
\q1
\v 10 Ka hru pueng ni, BAWIPA nang patetlah apimaw kaawm.  
\q2 Ahnimouh hlak a tha kaawmnaw thung hoi mathoenaw hah na rasa.  
\q2 Bokheiyah, mathoe hoi ka voutthoup e hah,  
\q2 ahnimouh karaphoekung thung hoi na rungngang toe, ati awh han.   
\q1
\v 11 Kapanuekkhai kaphawk a tho awh teh,  
\q2 ka panue hoeh e naw hah na pacei awh.   
\q1
\v 12 Ka muitha lungmathoe sak nahanelah,  
\q2 hawinae hah thoenae hoi a patho awh.   
\q1
\v 13 Hatei, kai niteh, a pataw awh navah, buri ka kâkhu,  
\q2 rawcahai hoi kârahnoum hoi ka o.  
\q2 Hahoi, ka ratoumnae teh ka lungthin koe letlang a ban.   
\q1
\v 14 Hui hoi hmaunawngha ka khui e patetlah,  
\q2 manu hoi ka khui e patetlah ka kâhlai teh ka tabut.   
\q1
\v 15 Hatei, ahnimouh niteh, ka kangduenae a mathoe toteh,  
\q2 konawm laihoi a kamkhueng awh.  
\q2 Na ka tarannaw teh cungtalah a kamkhueng awh teh,  
\q2 hot hah ka panuek hoeh. Kâhat laipalah, koung na phi awh.   
\q1
\v 16 Cathutlaipa e naw ni,  
\q2 pawibu vennae koe na panuikhai awh teh, a hâkam na kata sin awh.   
\q1
\v 17 BAWIPA nâtotouh maw sut na khet han.  
\q2 Raphoe hanlah kâcainae thung hoi na rungngang haw.  
\q2 Sendek koehoi ka hringnae hah hlout sak haw.   
\q1
\v 18 Ka lentoe e kamkhuengnae koe,  
\q2 konawmnae lawk hah ka dei vaiteh,  
\q2 tami moikapap hmalah ka pholen han.   
\q1
\v 19 Laithoehrawnghrang lahoi ka tarannaw ni kai dawk a konawm hanh naseh.  
\q2 A khuekhaw awm laipalah, na kahmuhmanaw ni,  
\q2 na hmaiet hanh naseh.   
\q1
\v 20 Bangtelah tetpawiteh, roumnae lawk hah dei awh hoeh niteh,  
\q2 hete ram taminaw duem ao awh lahunnah,  
\q2 dumnae lawk dueng doeh a dei awh.   
\q1
\v 21 A pahni na ang sin awh teh,  
\q2 vehveh, ka mit hoi ka hmu toe ati awh.   
\q1
\v 22 Oe BAWIPA, het heh na hmu doeh.  
\q2 Duem awm hanh. Oe BAWIPA, na hlat takhai hanh.   
\q1
\v 23 Ka Cathut hoi ka BAWIPA,  
\q2 kai dawk ka phat e lawkceng hane kabawp hanelah,  
\q2 kâhlaw nateh, thaw haw.   
\q1
\v 24 Oe BAWIPA, ka Cathut, na lannae lahoi lawk na ceng pouh haw.  
\q2 Kai dawk a konawm awh nahanh seh.   
\q1
\v 25 Ahnimouh ni a lung thung hoi  
\q2 maimae lungngai akuep han toe,  
\q2 koung payawp awh han toe tet awh hanh naseh.   
\q1
\v 26 Ka rucatnae dawk a lungkahawi e naw hah, kayak awh naseh.  
\q2 Kai lathueng kâoupnaw hah kayayeirai hoi awm awh naseh.   
\q1
\v 27 Ka lannae dawk kanawmkhaikung teh,  
\q2 lunghawi hoi la sak naseh.  
\q2 A san dawk a lung ka hawi e BAWIPA teh,  
\q2 pholen lah awm seh telah pou dei awh naseh.   
\q1
\v 28 Hahoi, ka lai ni na lannae lawk a dei vaiteh,  
\q2 kanîruirui nang na pholen han.   
\c 36  
\s1 Tami thoenae hoi Cathut kuepcingnae  
\d Kathutkung: Devit  
\q1
\v 1 Tamikathoutnaw ni kâtapoenae dawk  
\q2 ka lungthung hoi ka tâcawt e teh,  
\q2 ahnimae mit dawk Cathut takinae banghai awm hoeh.   
\q1
\v 2 A payonnae hmawt hoeh,  
\q2 panuek hoeh telah, a mithmu vah amahoima  
\q2 tamikalan lah a kâsak awh.   
\q1
\v 3 A dei e lawk teh, thoenae hoi dumnae dueng doeh.  
\q2 Kahawi hno sak hane hoi  
\q2 lungang hane hah a pahnawt awh.   
\q1
\v 4 A ikhun van hawihoehnae hah a pouk teh,  
\q2 kahawihoehe lamthung thama lahoi a dawn teh,  
\q2 yonnae hah panuet hoeh.   
\q1
\v 5 Oe BAWIPA na pahrennae teh kalvan ao teh,  
\q2 yuem na kamcunae ni tâmai koe a pha.   
\q1
\v 6 Na lannae teh kalen e mon patetlah ao teh,  
\q2 na lawkcengnae teh ka dungpoung e tui patetlah ao.  
\q2 Oe BAWIPA, tami hoi saringnaw hah ouk na khetyawt.   
\q1
\v 7 Oe Cathut, na lungpatawnae teh banghloimaw a sungren.  
\q2 Hatdawkvah, tami capanaw ni na tâhlip hah a kâuep awh.   
\q1
\v 8 Na imthung vah, kapap e hnokahawi hoi na boum sak teh,  
\q2 na konawmnae palangtui na nei sak.   
\q1
\v 9 Nang koe vah hringnae tuikhu teh ao.  
\q2 Na angnae dawkvah, angnae hah ka hmu awh.   
\q1
\v 10 Oe, nang kapanueknaw koe,  
\q2 na lungpatawnae pou awm na seh,  
\q2 lungthin kalannaw koe na lannae kamnuek naseh,   
\q1
\v 11 Kâoupnae khok teh kai taranlahoi  
\q2 tho nahanh seh.   
\q1
\v 12 Haw tueng vah, tamitongthoenaw koung a rawp awh toe.  
\q2 Tâkhawng lah ao awh teh, thaw awh mahoeh toe.   
\c 37  
\s1 Tamikalan ni coe e râw hoi tamikathout ni coe e rawk kahmanae  
\d Kathutkung: Devit  
\q1
\v 1 Thoenae kasaknaw kecu dawk lungmathoe hoi awm hanh awh.  
\q2 Payonnae kasaknaw hai ut awh hanh.   
\q1
\v 2 Bangkongtetpawiteh, phokahring patetlah palang kamyai awh vaiteh,  
\q2 anhna kahring patetlah palang a due awh han.   
\q1
\v 3 BAWIPA kâuep nateh, hawinae hah sak haw.  
\q2 Ram thung awm nateh, yuemkamcunae hah hringkhaih.   
\q1
\v 4 BAWIPA dawk konawm haw.  
\q2 Na lungngai e hah na poe han.   
\q1
\v 5 Na lamthung hah BAWIPA koe poe haw,  
\q2 ama kâuep haw, ama ni a sak han.   
\q1
\v 6 Na lannae teh angnae patetlah tâcawt sak vaiteh,  
\q2 na kângingnae hah kanîthun patetlah ao sak han.   
\q1
\v 7 BAWIPA dawk kâhat nateh, lungsaw laihoi ring haw.  
\q2 Amamae lamthung dawk tânae kahmawtnaw kecu dawk thoseh,  
\q2 thoenae a noe e naw dawk a kâvoe awh kecu dawk thoseh,  
\q2 na lungmathout hanh.   
\q1
\v 8 Na lungphuen sak hanh,  
\q2 lungkhueknae cettakhai haw.  
\q2 Lungmathoe hoi awm hanh.  
\q2 Hot ni teh, hawihoehnae koe doeh na hrawi.   
\q1
\v 9 Bangtelah tetpawiteh, thoenae kasaknaw teh, raphoe lah ao awh han.  
\q2 Hatei, BAWIPA ka ngaihawi e naw ni, talai heh râw lah a coe awh han.   
\q1
\v 10 Bangtelah tetpawiteh, tamikathoutnaw teh dongdengca dawk awm awh mahoeh toe.  
\q2 Bokheiyah, a onae hmuen koe kahawicalah na tawng han,  
\q2 hatei, awm mahoeh toe.   
\q1
\v 11 Hatei, a lungkanem e ni talai râw a coe vaiteh,  
\q2 kapap e roumnae dawk a lunghawi awh han.   
\q1
\v 12 Tamikathout ni tamikalan a youk teh,  
\q2 a hâkam a kata sin.   
\q1
\v 13 Hatei, Bawipa ni tamikathout teh a panui sin.  
\q2 Bangkongtetpawiteh, ahnimae hnin ka tho hane hah a panue.   
\q1
\v 14 Mathoe hoi kavoutthoupnaw kamlei sak hane hoi,  
\q2 kalan lah kahringnaw thei hanelah,  
\q2 tamikathoutnaw ni amamae tahloi sut a rayu awh teh,  
\q2 licung sut a sawn awh toe.   
\q1
\v 15 Hatei, amamae tahloi teh amamae lung dawk kâen vaiteh,  
\q2 ahnimae licung teh khoe lah ao han.   
\q1
\v 16 Tamikathout ni tawnta e hlak,  
\q2 tamikalan ni younca a tawn e ahawihnawn.   
\q1
\v 17 Bangtelah tetpawiteh, tamikathout e kut teh khoe lah awm vaiteh,  
\q2 tamikalan e kut teh BAWIPA ni a kabawp han.   
\q1
\v 18 BAWIPA ni tamikalannaw e hnin a panue pouh teh,  
\q2 a coe awh e râw teh a yungyoe kangning e doeh.   
\q1
\v 19 Ahnimouh teh, atueng mathoe nahaiyah,  
\q2 yeirai phawt awh mahoeh.  
\q2 Takang tue nahaiyah, a von a paha awh han.   
\q1
\v 20 Hatei, tamikathout teh a kahma han.  
\q2 BAWIPA e tarannaw teh,  
\q2 ka sungren e phokahring patetlah kahmat awh vaiteh,  
\q2 hmaikhu lah a pâyam awh vaiteh a kahma awh han.   
\q1
\v 21 Tamikathout niteh, a cawi e patho hoeh toe.  
\q2 Hatei, tamikalan niteh, a pahren teh a poe.   
\q1
\v 22 Bangtelah tetpawiteh, yawhawi poe lah kaawmnaw ni  
\q2 talai râw a coe awh han.  
\q2 Thoebo lah kaawmnaw teh raphoe lah ao awh han.   
\q1
\v 23 Tamikalannaw e khoktabei teh BAWIPA ni a caksak teh,  
\q2 a ceinae lamthung hah a ngai pouh.   
\q1
\v 24 A tâlaw nakunghai, poutnae koe phat mahoeh.  
\q2 Bangkongtetpawiteh, BAWIPA ni ahnie kut a kuet pouh.   
\q1
\v 25 Thoundoun lah ka o teh ka matawng toe.  
\q2 Tamikalan ceitakhai e ka hmawt boihoeh.  
\q2 A ca catounnaw kutdaw lah ao e ka hmawt boihoeh.   
\q1
\v 26 Ayâ a lungma teh, a cawi sak dawkvah,  
\q2 a ca catounnaw teh yawhawinae a coe awh.   
\q1
\v 27 Yonnae cettakhai nateh, hawinae sak nateh,  
\q2 hete ram dawk pou awm haw.   
\q1
\v 28 Bangkongtetpawiteh, BAWIPA ni kângingnae hah a lungpataw.  
\q2 A tamikathoungnaw cettakhai boihoeh.  
\q2 Lungmawng lah pou ao sak.   
\q1
\v 29 Tamikalan ni ram heh râw lah a coe vaiteh,  
\q2 a thung vah kho pou a sak awh han.   
\q1
\v 30 Tamikalan e pahni ni lungangnae lawk a dei teh,  
\q2 a lai ni kângingnae hah a pâpho.   
\q1
\v 31 A Cathut e kâlawk teh a lungthin thung ao dawkvah,  
\q2 a cei toteh tâlaw mahoeh.   
\q1
\v 32 Tamikathout ni tamikalan a pawp teh,  
\q2 thei hanelah ouk a tawng.   
\q1
\v 33 Hatei, BAWIPA ni ahnie kut dawk tamikalan hah tâkhawng mahoeh.  
\q2 Lawkceng lah ao nakunghai yonpen lah awm mahoeh.   
\q1
\v 34 BAWIPA hah ring haw.  
\q2 A lamthung hah dawn haw.  
\q2 Hete ram coe hanelah, na tawmrasang han.  
\q2 Tamikathoutnaw koung raphoe lah ao e hah na hmu han.   
\q1
\v 35 Tamikathout hoi tamitongthoenaw teh, ung e thingkung patetlah,  
\q2 hluthlut a naw awh e hah ka hmu toe.   
\q1
\v 36 Hatei, a due teh, khenhaw! ahni teh awm hoeh toe.  
\q2 Bokheiyah, ka tawng eiteh, hmu hane awm hoeh toe.   
\q1
\v 37 Kuepnae hah pouk nateh, lannae hah lueplueppouk haw.  
\q2 Bangkongtetpawiteh, hmâ lah a coe hane teh,  
\q2 lungmawngnae doeh.   
\q1
\v 38 Hatei, tamikayonnaw teh,  
\q2 koung raphoe lah awm vaiteh,  
\q2 tamikathoutnaw ni a coe hane haiyah,  
\q2 raphoenae hah doeh.   
\q1
\v 39 Tamikalan rungngangnae teh, BAWIPA koehoi doeh.  
\q2 Ahni teh runae tueng nah kânguenae im doeh.   
\q1
\v 40 BAWIPA ni kabawm vaiteh, a rungngang han.  
\q2 Ama a kâuep dawkvah, tamikathoutnaw thung hoi  
\q2 a rasa teh ouk a rungngang.   
\c 38  
\s1 Yuenae tueng nah ratoumnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA lungphuen laihoi na yue hanh lah a.  
\q2 Puenghoi lungkhuek laihoi hai na yue hanh.   
\q1
\v 2 Na tahroe ni kai hah na thut dawkvah,  
\q2 na kut ni hoe na nam sin.   
\q1
\v 3 Na lungphuennae kecu dawk, ka takthai dawk damnae awm hoeh.  
\q2 Ka yonnae kecu dawk ka hru damnae awm hoeh.   
\q1
\v 4 Ka payonnae ni ka lû a ramuk dawkvah,  
\q2 ka phu thai hoeh e hno patetlah doeh ao.   
\q1
\v 5 Ka pathunae kecu dawk, ka hmâ dukhnai teh,  
\q2 a hmui a tho toe.   
\q1
\v 6 Patawnae khang hoi ka kâkalawng teh,  
\q2 kanîruirui lungmathoe hoi ka cingou.   
\q1
\v 7 Bangkongtetpawiteh, ka laheibawnaw a kâan poung dawkvah,  
\q2 ka takthai dawk damnae roeroe awm hoeh.   
\q1
\v 8 Ka tâwn poung teh ka lung a rek dawkvah,  
\q2 ka lung a kâraphei teh ka cingou.   
\q1
\v 9 BAWIPA, ka ngainae pueng teh na hmalah ao.  
\q2 Ka cingounae hai koung na panue.   
\q1
\v 10 Ka lung a duem teh tha ka tawn hoeh toe.  
\q2 Ka mit angnae hai takuettakuet a mawm toe.   
\q1
\v 11 Ka patawnae dawk ka pahren e naw hoi huikonaw ni,  
\q2 na hnai ngai awh hoeh toe.  
\q2 Ka imthungnaw ni hai na roun awh toe.   
\q1
\v 12 Ka hringnae la han kakâcainaw nihai,  
\q2 kai hanlah karap a patûng awh.   
\q1
\v 13 Hatei, kai teh, hnâpang patetlah ka thai hoeh,  
\q2 lawka patetlah doeh ka o.   
\q1
\v 14 Hottelah, ka thai hoeh e patetlah ka o teh,  
\q2 ka pato thai hoeh e patetlah ka o.   
\q1
\v 15 Oe BAWIPA, nang dawk ngaihawinae ka tawn dawkvah,  
\q2 Oe BAWIPA, ka Cathut, na thai pouh haw.   
\q1
\v 16 Na thai pouh haw, hoehpawiteh, kai dawk a konawm awh vaiteh,  
\q2 ka khok a thawn toteh, kai taranlahoi kâoup awh payon vaih ka ti.   
\q1
\v 17 Kai teh rawp hane coungkacoe ka o dawkvah,  
\q2 ka lungmathoenae teh pou ka pouk.   
\q1
\v 18 Ka yonnae ni ka lung a puen sak dawkvah,  
\q2 peng ka pâpho ngala toe.   
\q1
\v 19 Hatei, ka tarannaw teh, a tak a dam awh, a thao awh.  
\q2 A khuekhaw awm laipalah na kahmuhmanaw teh, apap awh.   
\q1
\v 20 Hawinae hah yonnae hoi kapathonaw hai,  
\q2 hawinae ka tarawi kecu ka taran lah ao awh.   
\q1
\v 21 Oe BAWIPA, na cettakhai hanh.  
\q2 Oe ka Cathut, na hlat takhai hanh.   
\q1
\v 22 Oe rungngangnae BAWIPA,  
\q2 karanglah na kabawm haw.   
\c 39  
\s1 Lungangnae hoi ngaithoumnae  
\d Kathutkung: Devit  
\q1
\v 1 Lawk hoi boehai ka payon hoeh nahanelah,  
\q2 kai teh ka kâhruetcuet han.  
\q2 Tamikathoutnaw ka hmalah ao awh lahun nah,  
\q2 ka pahni ka moum han telah ka ti.   
\q1
\v 2 Lawk dei laipalah duem ka o.  
\q2 Hawinae boehai dei laipalah duem ka o teh,  
\q2 ka lung hoehoe a mathoe.   
\q1
\v 3 Ka lungthin teh ka thung vah a kâan.  
\q2 Luepluep ka pouk lahun nah, hmai a kak.  
\q2 Hat toteh, ka kâko hoi lawk ka dei.   
\q1
\v 4 BAWIPA ka thayounnae ka panue thai nahan,  
\q2 ka poutnae na panuek sak haw.  
\q2 Ka hringnae hnin hai na panuek sak haw.   
\q1
\v 5 Bokheiyah, ka hringyung heh khap touh dueng na sak teh,  
\q2 ka kumnaw hai na hmalah, banghai bang hoeh lah doeh ao.   
\q1
\v 6 Tami pueng teh tâhlip patetlah doeh koung a loum awh.  
\q2 Banghai bang hoeh e doeh a pâlei awh.  
\q2 Hnopai thouk a pâkhueng awh teh,  
\q2 apie lah maw ao han vai tie panuek awh hoeh.   
\q1
\v 7 Bawipa, atu ka panue e heh bang na maw.  
\q2 Nang teh ka ngaihawi e lah na o.   
\q1
\v 8 Kâtapoenae pueng thung hoi na rasat haw,  
\q2 tamipathunaw ni panuikhai hanelah na awm sak hanh.   
\q1
\v 9 Nang teh, kasakkung lah na o dawkvah,  
\q2 ka kâko ka ang laipalah duem ka o.   
\q1
\v 10 Na reknae heh na takhoe pouh leih,  
\q2 na kut hoi hemnae ni koung na raphoe toe.   
\q1
\v 11 Taminaw e payonnae hah na yue teh,  
\q2 na rek pawiteh ahriai ni a ca e patetlah,  
\q2 taminaw e taluenae teh, na kahma sak.  
\q2 Atangcalah, tamipueng ahrawnghrang doeh.   
\q1
\v 12 Oe, BAWIPA, ka ratoumnae na thai pouh haw.  
\q2 Ka hramnae lawk koelah, na hnâpakeng haw.  
\q2 Ka mintoenaw patetlah imyin hoi kahlawng ka cet rumram e lah ka o.   
\q1
\v 13 Kaawm toung laipalah, ka khup hoehnahlan vah,  
\q2 ka ko bout a nawm nahanelah, na pasai haw.   
\c 40  
\s1 Tanouknae dawk kacaklah yuemnae  
\d Kathutkung: Devit  
\q1
\v 1 BAWIPA teh lungsaw laihoi ka ring.  
\q2 Kai koe lah a kamlang teh, ka hram e lawk hah a thai.   
\q1
\v 2 Rawknae tangkom hoi tangdong thung hoi na rasa.  
\q2 Ka khok hah talung van a hruek teh, kacaklah na kangdue sak.   
\q1
\v 3 Maimae Cathut pholennae la katha hah ka pahni dawk a hruek.  
\q2 Tamimaya ni hot hah hmawt vaiteh, a taki awh vaiteh,  
\q2 BAWIPA a kâuep awh han.   
\q1
\v 4 Ka kâoupnaw hoi cathutkaphawk koe lah lam kaphennaw koe lam ka phen hoeh niteh,  
\q2 BAWIPA ka kâuepnaw teh tami yawkahawi e doeh.   
\q1
\v 5 Oe BAWIPA kaie Cathut, kângairu hno na sak e naw hoi,  
\q2 kaimouh hanlah na pouk e naw hah moi apap.  
\q2 Na hmalah boeba hai ka dei thai lek hoeh.  
\q2 Ka dei vaiteh, ka pâpho pawiteh, touk thai e hloilah doeh ao.   
\q1
\v 6 Thuengnae hoi poenae hah na ngai e nahoeh.  
\q2 Hmaisawi thuengnae hoi yon thuengnae hah na hei e nahoeh.  
\q2 Ka hnâ teh na ang sak.   
\q1
\v 7 Hatnavah, khenhaw! cakalawng dawk kaie kong thut e patetlah  
\q2 kai teh ka tho.   
\q1
\v 8 Oe Cathut, na lungngai sak e heh ka konawmnae doeh.  
\q2 Na kâlawk hai ka lungthung vah ao.   
\q1
\v 9 Kalenpounge kamkhuengnae koe vah, lannae kamthang hah ka pâpho toe.  
\q2 Dei hanelah ka kâcakuep hoeh.  
\q2 Oe BAWIPA, nang nama ni roeroe na panue doeh.   
\q1
\v 10 Na lannae teh, ka lungthung vah ka hro teh,  
\q2 yuemkamculah na onae hoi na rungngangnae hah ouk ka pâpho.  
\q2 Puenghoi kamkhuengnae koe na pahrennae hoi na lawkkatang teh  
\q2 duem kaawm khai thai hoeh.   
\q1
\v 11 Oe BAWIPA, ngai kaawm e na lungmanae teh  
\q2 na pasoung laipalah awm hoeh.  
\q2 Na pahrennae hoi na lawkkatang ni, pout laipalah na ngue lawiseh.   
\q1
\v 12 Bangkongtetpawiteh, touklek hoeh e runae ni na kalup,  
\q2 ka payonnae ni na tâ.  
\q2 Hatdawkvah, lathueng lah ka khen thai hoeh.  
\q2 Ka lû dawk e sam hlak apap. Hatdawkvah, ka lungthin teh a tâwn.   
\q1
\v 13 Oe BAWIPA, pahren lahoi na rungngang haw.  
\q2 Oe BAWIPA, karanglah na kabawm haw.   
\q1
\v 14 Ka hringnae raphoe hanlah katawngnaw teh,  
\q2 kaya laihoi awm awh naseh.  
\q2 Kai thoenae dueng kangainaw teh,  
\q2 kaya laihoi pâlei lah awm naseh.   
\q1
\v 15 Eheh, Eheh, katetnaw hah  
\q2 a pouknae kadeng lah kayak awh naseh.   
\q1
\v 16 Nang katawngnaw pueng teh,  
\q2 nang dawk konawm laihoi lunghawi awh naseh.  
\q2 Na rungngangnae ka lungpataw naw ni,  
\q2 BAWIPA teh tawmrasang lah awmseh telah pout laipalah tet awh naseh.   
\q1
\v 17 Kai teh tamimathoe hoi tamikavout doeh.  
\q2 Hatei, BAWIPA ni ouk na pouk.  
\q2 Nang teh na kabawmkung hoi rungngangkung doeh.  
\q2 Hnawngcawn hanh lawi a ka Cathut.   
\c 41  
\s1 Cathut e tami khangnae hoi yawhawinae  
\d Kathutkung: Devit  
\q1
\v 1 Tamimathoe hanelah ka pouk pouh e tami teh a yawkahawi e doeh.  
\q2 Runae tueng nah ahni hah BAWIPA ni a hlout sak han.   
\q1
\v 2 BAWIPA ni a hlout sak vaiteh, a pasai han.  
\q2 A tarannaw koe poe hanlah na pasoung mahoeh.   
\q1
\v 3 A pataw teh sut a yan navah BAWIPA ni thapoe vaiteh,  
\q2 amae hmalah bout na thaw sak han.   
\q1
\v 4 BAWIPA na pahren haw, ka hringnae heh dam sak haw.  
\q2 Bangkongtetpawiteh, nang taranlahoi ka yon toe telah ka ti.   
\q1
\v 5 Ka tarannaw ni nâtuek maw a due vaiteh a min raphoe lah ao han telah,  
\q2 thoenae koelah dueng na dei awh.   
\q1
\v 6 Na tho sin nahaiyah laithoe duengdoeh a dei awh.  
\q2 A lungthin ni payonnae dueng hah a pâkhueng teh,  
\q2 alawilah a tâco nah tangkuem koe ouk a dei.   
\q1
\v 7 Na kahmuhmanaw pueng ni kai taranlahoi arulawk a kâdei awh teh,  
\q2 kai pataw nahane dueng doeh a kâdei awh.   
\q1
\v 8 Patawnae kathout ni a man toung dawkvah, atu sut a yan toe,  
\q2 thaw mahoeh toe telah a kâdei awh.   
\q1
\v 9 Ka hui kahawi, ka kâuep e, kaie rawca ka cat e niyah,  
\q2 kai taranlahoi a khokpaimai na tawm sin.   
\q1
\v 10 Hatei, Oe BAWIPA, ahnimouh moi ka pathung thai nahanlah,  
\q2 na pahren nateh, bout na thaw sak haw.   
\q1
\v 11 Hete kong dawk kai dawk na lunghawi doeh tie ka panue.  
\q2 Bangkongtetpawiteh, ka tarannaw ni na tâ awh hoeh.   
\q1
\v 12 Kai teh pouknae kalan ka tawn dawkvah,  
\q2 na tawm nateh na hmalah pou na hrueng haw.   
\q1
\v 13 Isarel BAWIPA teh, a yungyoe hoi a yungyoe totouh  
\q2 pholen lah awm lawiseh.  
\q2 Amen hoi Amen.   
\c 42  
\s1 Runae koehoi Cathut dounnae  
\d Kathutkung: Korah capanaw  
\q1
\v 1 Sakhi ni tuisi a doun e patetlah Oe Cathut,  
\q2 ka hringnae ni nang na doun.   
\q1
\v 2 Ka hringnae ni Cathut, ka hring Cathut hah a kahran.  
\q2 Nâtuek ne Cathut koe ka pha vaiteh, ka minhmai ka patue van han vai.   
\q1
\v 3 Ayânaw ni na Cathut teh nâmouh ao vâ pou ati awh dawkvah,  
\q2 karum khodai ka mitphi teh khap laipalah ka rawca lah ao.   
\q1
\v 4 Tamimaya hoi Cathut im rei cei awh navah, konawm laihoi,  
\q2 pholen la rei sak awh navah,  
\q2 tamimaya hoi pawi koe rei cei awh e naw hah,  
\q2 bout ka pouk toteh, ka hringnae heh ka thung vah ka rabawk.   
\q1
\v 5 Oe, ka hringnae bang dawk ne sut na ngam.  
\q2 Bangkongmaw ka thungvah runae na kâhmo.  
\q2 Cathut hah ngaihawi haw.  
\q2 Bangkongtetpawiteh, ama teh ka pholen han rah,  
\q2 na ka rungngangkung hoi ka Cathut.   
\q1
\v 6 Ka hringnae teh ka lungthung a lungmathoe dawkvah,  
\q2 Jordan ram, Hermon ram hoi Mizar,  
\q2 mon koehoi nang teh pou na pouk.   
\q1
\v 7 Na tuitâto pawlawk dawk,  
\q2 tui kadung hoi tui kadung a kâpan teh,  
\q2 na tuicapa ka thaw e ni koung na ramuk toe.   
\q1
\v 8 BAWIPA ni khodai lah a pahrennae hah na poe teh,  
\q2 karum lah pholennae la sak laihoi,  
\q2 ka hringnae Cathut koe ratoum laihoi ka o.   
\q1
\v 9 Ka lungsong, Cathut koevah, bangkongmaw na pahnim.  
\q2 Bangkongmaw ka tarannaw ni  
\q2 na pahuipalam awh kecu dawk  
\q2 ka lung a mathoe han rah, telah ka dei han.   
\q1
\v 10 Ka tarannaw ni nâmouh na Cathut teh ao telah  
\q2 na panuikhai kecu dawk,  
\q2 ka hru koung a khoe awh mue toe telah ka pouk.   
\q1
\v 11 Ka hringnae bangkongmaw na lung a mathoe.  
\q2 Bangkongmaw ka thungvah, runae na kâhmo.  
\q2 Cathut hah kâuep haw.  
\q2 Bangkongtetpawiteh, ama teh ka pholen han rah.  
\q2 Na kabawmkung hoi na ka damsakkung doeh.   
\c 43  
\s1 Runae thung hoi Cathut koe ratoumnae  
\d Kathutkung: Korah capanaw  
\q1
\v 1 Oe Cathut, lawk na ceng pouh haw.  
\q2 Cathutlaipa e miphunnaw hmalah  
\q2 ka kong heh lawk na ceng pouh haw.  
\q2 Oe tamikathoutnaw hoi kadumyennaw koehoi na rungngang haw.   
\q1
\v 2 Bangkongtetpawiteh, nang teh kaie Cathut rapanim doeh.  
\q2 Bangkongmaw na hnoun.  
\q2 Bangkongmaw na ka tarannaw kecu ka lung ouk a mathoe.   
\q1
\v 3 Oe, na angnae hoi lawkkatang hah patoun haw.  
\q2 Hot niyah na hrawi naseh.  
\q2 Na mon kathoung hoi na onae lukkareiim dawk na phatkhai naseh.   
\q1
\v 4 Hottelah Cathut e thuengnae khoungroe,  
\q2 ka konawmnae Cathut koe ka cei han.  
\q2 Oe Cathut, ka Cathut, ratoung hoi na pholen han.   
\q1
\v 5 Oe ka hringnae Bangkongmaw na lung a mathoe.  
\q2 Bangkongmaw ka thung vah, runae na kâhmo.  
\q2 Cathut hah kâuep haw, ama teh ka pholen han.  
\q2 Na kabawmkung hoi na kadamsakkung Cathut doeh.   
\c 44  
\s1 Yeiraiponae koehoi ratangnae pahnimhoehnae  
\d Kathutkung: Korah capanaw  
\q1
\v 1 Oe Cathut, ayan vah mintoenaw se nah na sak e hah,  
\q2 a dei awh teh ka hnâ ni a thai.   
\q1
\v 2 Na kut hoi miphunlouknaw hah na pâlei.  
\q2 Hatei, mintoenaw hah a hmuen na poe,  
\q2 ayânaw hah runae na poe teh na pâlei.   
\q1
\v 3 Bangkongtetpawiteh, ram teh tahloi hno lahoi a la awh e nahoeh.  
\q2 A kut hoi kârungngang awh e hai tho hoeh.  
\q2 Hatei, na thaonae kut hoi na minhmai angnae lahoi ram a la awh e doeh.   
\q1
\v 4 Oe Cathut, nang teh kaie Siangpahrang doeh.  
\q2 Jakop hanelah tânae kâ poe haw.   
\q1
\v 5 Nang pawlawk lahoi ka taran hah ka tâ awh han.  
\q2 Na min lahoi ka tarannaw hah rep ka coungroe awh han.   
\q1
\v 6 Bangkongtetpawiteh, kaie licung hah ka kâuep mahoeh.  
\q2 Kaie senehmaica ni na rungngang mahoeh.   
\q1
\v 7 Hatei, ka taran thung hoi na rungngang teh,  
\q2 na kahmuhmanaw hah yeiraipo hoi na o sak.   
\q1
\v 8 Hnintangkuem Cathut dawk ka kâoup teh,  
\q2 a min hah pou ka pholen.   
\q1
\v 9 Hatei atu teh hnam na thun takhai teh, yeiraipo hoi na o sak.  
\q2 Kaimae ransanaw koe bout na cet boihoeh.   
\q1
\v 10 Taran hmalah na yawng sak teh,  
\q2 na ka tarannaw ni a ngai patetlah na lawp awh.   
\q1
\v 11 Tu thei hane patetlah na ceikhai teh,  
\q2 miphun pueng koe koung na kathek awh.   
\q1
\v 12 Na taminaw hah banghai bang hoeh lah na yo teh,  
\q2 aphu teh na bawi khai kalawn hoeh.   
\q1
\v 13 Imrinaw lungkuep nahane hoi,  
\q2 tengpam e taminaw ni dudam e hoi,  
\q2 panuikhai hanelah na coung sak awh toe.   
\q1
\v 14 Miphunlouknaw ni lairui lah rui hane hoi,  
\q2 taminaw ni lûsaling sin hanelah na coung sak awh toe.   
\q1
\v 15 Na kapathoenaw hoi na kahmuhmanaw e lawk kecu hoi,  
\q2 tarannaw hoi moi ka pathungnaw kecu dawk,   
\q1
\v 16 kayanae teh ka hmalah pout laipalah ao teh,  
\q2 ka kayanae ni ka minhmai a ramuk.   
\q1
\v 17 Hotnaw pueng ni na bo sin.  
\q2 Hatei, na pahnim boihoeh.  
\q2 Na lawkkam hai ka tapoe boihoeh.   
\q1
\v 18 Kaimae lungthin hnuk kâhnawn hoeh niteh,  
\q2 na lamthung hai ka phen boi awh hoeh.   
\q1
\v 19 Hatei nang ni kahrawnguinaw onae koe koung na phi teh,  
\q2 kaimouh lathueng duenae tâhlip hoi na ramuk awh.   
\q1
\v 20 Kaimouh ni, kamamae Cathut min ka pahnim awh teh,  
\q2 ramlouk cathut koe ka kut ka dâw awh pawiteh,   
\q1
\v 21 Cathut ni tang panuek mahoeh maw.  
\q2 Bangkongtetpawiteh, lungthin e arulawk hai kapanuekkung doeh.   
\q1
\v 22 Nang hanelah hnintangkuem thei lah ka o awh.  
\q2 A thei hane tu patetlah doeh na pouk awh.   
\q1
\v 23 Kâhlaw haw, Oe BAWIPA, bangkongmaw muet na i.  
\q2 Thaw nateh hnamthun takhai hanh leih.   
\q1
\v 24 Bangkongmaw na minhmai pou na hro teh,  
\q2 runae hoi kapahuipalamnaw kâhmo awh e heh ouk na pahnim.   
\q1
\v 25 Talai dawk minhmai rekkâbet lah ka tabut teh,  
\q2 vaiphu dawk ka tabo.   
\q1
\v 26 Na kabawmkung hanelah tho haw,  
\q2 na lungmanae lahoi na ratang haw.   
\c 45  
\s1 Messiah hoi a langa bawilennae  
\d Kathutkung: Korah capanaw  
\q1
\v 1 Ka lungthin heh hnokahawi hoi a poum teh,  
\q2 Siangpahrang kong hah ka dei han.  
\q2 Ka lai teh ca kathutkung e cacung patetlah coungkacoe ao.   
\q1
\v 2 Nang teh tami capanaw hlak na mei ahawihnawn.  
\q2 Na pahni dawk pahrennae awi lah ao.  
\q2 Hatdawkvah, Cathut ni yawhawi pou na poe.   
\q1
\v 3 Oe athakaawme, na bawilennae hoi na taluenae hoi,  
\q2 na tahloi teh na keng dawk kâyeng haw.   
\q1
\v 4 Lawkkatang hoi kârahnoumnae hoi lannae kecu dawkvah,  
\q2 na taluenae hoi ka tânae lahoi marang dawk kâcui haw.  
\q2 Hottelah, aranglae kut hoi kângairu hnonaw hah na cangkhai han.   
\q1
\v 5 Ka pasum e tahroe hoi siangpahrang e tarannaw e lung teh  
\q2 poukkayawng lah thun naseh.  
\q2 Na lungtabue dawk koung rawm awh naseh.   
\q1
\v 6 Oe Cathut, na bawitungkhung teh a yungyoe kangning e doeh.  
\q2 Lannae na sonron hai na ram sonron lah doeh ao.   
\q1
\v 7 Lannae hah lung na pataw teh, thoenae hah na hmuhma.  
\q2 Hatdawkvah, Cathut, na Cathut ni, satui hah na awi toe.  
\q2 Na huinaw hlak hai, konawmnae satui hah na awi toe.   
\q1
\v 8 Na khohna pueng dawk hoi murah hoi aloenaw hoi,  
\q2 khasia hmuitui a hmui teh, kasaino hoi pathoup e  
\q2 siangpahrang imnaw ni na lunghawi sak.   
\q1
\v 9 Bari kaawm e napui na tawn e naw thung dawkvah,  
\q2 ramlouk siangpahrangnaw e canunaw hai a bawk teh,  
\q2 nange aranglah Ophir sui hoi kamthoup e siangpahrangnu teh a tahung.   
\q1
\v 10 Oe, Canu thai haw, pouk nateh na hnâpakengh.  
\q2 Na taminaw hoi na pa im kaawm e naw hai pahnim haw.   
\q1
\v 11 Hottelah pawiteh, siangpahrang ni na meihawinae hah  
\q2 a ngai katang han, ahni teh na bawipa doeh, bari haw.   
\q1
\v 12 Taire canu ni poehno sin vaiteh, tamimaya thung dawk hoi  
\q2 na tawnta e ni na minhmai hawi a tawng awh han.   
\q1
\v 13 Siangpahrang im e siangpahrang canu teh,  
\q2 a sungrenpoung teh, a khohna teh sui hoi pathoup e lah ao.   
\q1
\v 14 Pathoup e hni kahawi kâkhu hoi siangpahrang koe cetkhai awh vaiteh,  
\q2 tanglakacuemnaw ama hnukkâbang hane naw hah  
\q2 ahni koe a thokhai awh han.   
\q1
\v 15 Lunghawi thahmeica lahoi thokhai awh vaiteh,  
\q2 siangpahrang im a kâen awh han.   
\q1
\v 16 Napanaw yueng lah na canaw awm awh vaiteh,  
\q2 ahnimouh teh talai van pueng dawk siangpahrang lah na o sak han.   
\q1
\v 17 Na min teh se pueng dawk panue hanelah ka sak han.  
\q2 Hatdawkvah, tami ni pou na pholen han.   
\c 46  
\s1 Kânguenae Cathut  
\d Kathutkung: Korah capanaw  
\q1
\v 1 Cathut teh ka kânguenae hoi ka thaonae doeh.  
\q2 Runae tueng navah kabawmkung kahnai poung e doeh.   
\q1
\v 2 Hatdawkvah, talai heh kampuen niteh,  
\q2 monnaw teh talî dawk ka bawt nakunghai, ka taket mahoeh.   
\q1
\v 3 Tuinaw teh hramki laihoi ka phuen nakunghai,  
\q2 tuicapa ni mon totouh ka thaw nakunghai, ka taket mahoeh.   
\q1
\v 4 Palang buet touh ao teh, a cakang teh Cathut khopui,  
\q2 Lathueng Poung onae koe totouh, ka konawmsakkung lah ao.   
\q1
\v 5 Cathut teh a thung vah ao teh, kâhuen mahoeh.  
\q2 Khodai toteh Cathut ni a kabawp han.   
\q1
\v 6 Miphun pueng teh a hramki awh.  
\q2 Uknae pueng teh a kâhuet.  
\q2 Ahni ni a lawk a tho boteh, talai teh a kamyawt.   
\q1
\v 7 Ransahu BAWIPA teh, maimouh koe ao teh,  
\q2 Jakop Cathut teh kânguenae doeh.   
\q1
\v 8 Tho awh haw, BAWIPA ni a sak e naw hoi  
\q2 talai van e hno a raphoe e naw pueng hah khenhaw.   
\q1
\v 9 Ama ni tarantuknae hah talai pout totouh a roum sak teh,  
\q2 licung hah a khoe.  
\q2 Tahroe hah a tâtueng teh, lengnaw hah hmai hoi koung a sawi.   
\q1
\v 10 Duem awm awh nateh, Cathut lah ka o e heh panuek awh.  
\q2 Miphunnaw koe tawm lah ka o vaiteh,  
\q2 talai van vah tawm lah ka o han.   
\q1
\v 11 Ransahu BAWIPA teh, maimouh koe ao.  
\q2 Jakop Cathut teh kânguenae doeh,   
\c 47  
\s1 Talai ukkungnaw Cathut pholen awh  
\d Kathutkung: Korah capanaw  
\q1
\v 1 Oe taminaw pueng, na kuttabawng awh nateh,  
\q2 tânae lawk hoi Cathut koe hram awh sei.   
\q1
\v 2 Jehovah Lathueng Poung teh takitho poung.  
\q2 Ama teh talai pueng e Siangpahrang kalen doeh.   
\q1
\v 3 Maimae rahim tamipueng tabut sak vaiteh,  
\q2 maimae khok rahim miphunnaw a tabut sak han.   
\q1
\v 4 A lungpataw e Jakop hanelah, kahawipoung e bawilennae lah kaawm e,  
\q2 maimae râw hah maimouh hanlah na rawi pouh.   
\q1
\v 5 Cathut teh hram laihoi a luen teh,  
\q2 BAWIPA teh mongka lawk hoi a luen.   
\q1
\v 6 Cathut pholen hoi la sak awh nateh, pholen hoi la sak awh.  
\q2 Maimae Siangpahrang koe pholen hoi la sak awh nateh,  
\q2 pholen hoi la sak awh.   
\q1
\v 7 Cathut teh talai pueng e Siangpahrang doeh.  
\q2 Sam la hoi pholen la sak awh.   
\q1
\v 8 Cathut teh miphun pueng lathueng Siangpahrang lah ao teh,  
\q2 Cathut teh a bawitungkhung dawk lawkceng laihoi a tahung.   
\q1
\v 9 Miphun pueng e tami kacuenaw teh,  
\q2 Abraham Cathut e miphun koe a kamkhueng awh.  
\q2 Bangkongtetpawiteh, talai siangpahrangnaw teh,  
\q2 Cathut ni a tawn e doeh. Ama teh hoe tawmrasang lah ao.   
\c 48  
\s1 Zion vah Cathut bawilennae  
\d Kathutkung: Korah capanaw  
\q1
\v 1 BAWIPA teh a lentoe poung.  
\q2 Cathut khopui dawk lentoe poung lah,  
\q2 amae mon kathoung dawk pholen hanlah a kamcu.   
\q1
\v 2 Zion mon atunglah kaawm e teh  
\q2 arasang teh a meihawi.   
\q1
\v 3 Cathut teh a im dawkvah ao teh,  
\q2 a kânguenae rapan tie panue lah ao.   
\q1
\v 4 Bangkongtetpawiteh, siangpahrangnaw a kamkhueng awh teh,  
\q2 cungtalah a dei awh.   
\q1
\v 5 A hmu awh toteh, a kalue awh teh  
\q2 koung a yawng awh.   
\q1
\v 6 Kanîtholah e kahlî hoi  
\q2 Tarshish long kalennaw ouk a raphoe e patetlah,   
\q1
\v 7 Haw tueng vah, takinae ni a man awh teh,  
\q2 napui camokhe pataw e patetlah a man awh.   
\q1
\v 8 Panue awh tangcoung e hoi hmu awh tangcoung e patetlah,  
\q2 ransahu BAWIPA khopui, maimae Cathut khopui teh,  
\q2 Cathut ni a yungyoe hanelah a caksak han.   
\q1
\v 9 Oe Cathut, na bawkim lungui vah,  
\q2 na pahrenlungmanae ouk ka pouk awh.   
\q1
\v 10 Oe Cathut, na min patetlah nang pholennae ni,  
\q2 talai pout totouh a pha teh,  
\q2 nange aranglae kut teh lannae hoi akawi.   
\q1
\v 11 Na lawkcengnae dawkvah,  
\q2 Zion mon teh lunghawi naseh,  
\q2 Zion canu hai konawm naseh.   
\q1
\v 12 Zion hah lawngven awh nateh,  
\q2 imrasangnaw hah parei awh haw.   
\q1
\v 13 Sekatha dawk kaawm han rae naw koe  
\q2 patuen na dei thai awh nahanlah,  
\q2 kalupnae hah pâkuem awh nateh,  
\q2 siangpahrang imnaw hah pouk awh haw.   
\q1
\v 14 Bangkongtetpawiteh, Cathut teh a yungyoe maimae Cathut doeh.  
\q2 Ahni teh maimouh due totouh hai na kahrawikung lah ao.   
\c 49  
\s1 Pathu lungmawngnae  
\d Kathutkung: Korah capanaw  
\q1
\v 1 Tamimaya hetheh thai awh haw.  
\q2 Talai van kaawm e pueng thai awh haw.   
\q1
\v 2 Ka rahnoum hoi ka rasang,  
\q2 ka tawnta hoi ka mathoe pueng cungtalah thai awh haw.   
\q1
\v 3 Ka kâko ni lungangnae lawk a dei han.  
\q2 Hahoi, ka lungthin khopouknae ni panuethainae a poe han.   
\q1
\v 4 Cingthuilawk koe lah ka hnâ ka pakeng vaiteh,  
\q2 lawk ka ru ka dei e hah, ka ratoung hoi ka cai sak han.   
\q1
\v 5 Thoenae ni na kalup navah,  
\q2 bangkongmaw hnin kathout nah ka taki han.   
\q1
\v 6 Ahnimouh teh amamae hnopai hah a kâuep awh teh,  
\q2 a tawnta awh e dawk ka kâoup awh nakunghai,   
\q1
\v 7 amamae hmaunawngha apinihai ratang thai mahoeh.  
\q2 Ratangnae phu Cathut koe poe thai hoeh.   
\q1
\v 8 Ahnimae hringnae ratang nahane aphu apap poung.  
\q2 Hatdawkvah, nâtuek hai poe hane khout thai hoeh.   
\q1
\v 9 Ratang pawiteh, a yungyoe a hring han doeh.  
\q2 Pawknae koe phat mahoeh.   
\q1
\v 10 Tamilungkaang hai a due.  
\q2 Hot patetvanlah, tamipathu hoi  
\q2 bangpuibangpa lah kaawm hoeh e hai a due van.  
\q2 Hahoi, hnopainaw hah ayânaw hanelah  
\q2 a ceitakhai awh tie hah a hmu awh.   
\q1
\v 11 A lungthung hoi teh amamae im hah  
\q2 a yungyoe kangning hanelah a pouk awh.  
\q2 A onae im hah se pueng dawk kangning hanelah a pouk awh.  
\q2 Amamae ram hah a min a phu sak awh.   
\q1
\v 12 Hatei, tami heh bari lah ao eiteh, kangning hoeh.  
\q2 Kahmakatanae koe ka phat e saring patetlah doeh ao.   
\q1
\v 13 Hethateh tamipathunaw e lamthung doeh.  
\q2 Hahoi, a catounnaw hai a dei awh e patetlah ao awh.   
\q1
\v 14 A duenae hmuen koelah ceikhai e tu patetlah ao awh.  
\q2 Duenae ni a ca awh han.  
\q2 Tamikalannaw ni khodai toteh a uk awh han.  
\q2 A onae hmuen koehoi ahlanae hmuen koe  
\q2 a takthai meihawinae naw teh,  
\q2 phuen vah koung a pawk han.   
\q1
\v 15 Hatei, ka hringnae hateh,  
\q2 Cathut ni phuen thaonae koehoi a ratang han.  
\q2 Bangkongtetpawiteh, ama ni na coe han.   
\q1
\v 16 Tami buet touh a tawnta teh, a imthungkhu bawilennae hoi  
\q2 hoehoe a kâthap navah, taket hanh.   
\q1
\v 17 Bangkongtetpawiteh, a due toteh banghai sin thai kalawn mahoeh.  
\q2 A bawilennae ni hai kâbang sin kalawn mahoeh.   
\q1
\v 18 A hring nathung yawhawi kacoepounge lah kâpouk nakunghai,  
\q2 na tawnta dawkvah tami ni ka pholen nakunghai,   
\q1
\v 19 a napanaw ceinae koe a cei van vaiteh,  
\q2 nâtuek hai kho ang hmawt thai awh mahoeh toe.   
\q1
\v 20 Tami ni bari e lah ao eiteh, panuethainae ka tawn hoeh e teh,  
\q2 saring kahmakata e patetlah doeh ao.   
\c 50  
\s1 Lannae lahoi lawkcengkung Cathut  
\d Kathutkung: Asaph  
\q1
\v 1 Athakaawme, BAWIPA Cathut ni lawk a dei.  
\q2 Talai heh kanîtho koehoi kanîloum totouh ka kaw.   
\q1
\v 2 Meihawinae kuep Zion hoi  
\q2 Cathut teh a ang han.   
\q1
\v 3 Maimae Cathut tho vaiteh, duem awm mahoeh.  
\q2 A hmalah hmai kang vaiteh, petkâkalup lah kahlî a tho han.   
\q1
\v 4 A taminaw lawkceng thai nahanlah,  
\q2 lathueng lae kalvannaw kaw vaiteh, talai hai a kaw han.   
\q1
\v 5 Thuengnae lahoi kama koe lawkkamnae ka sak e ka tamikathoungnaw,  
\q2 kai koe kamkhueng awh ati han.   
\q1
\v 6 Kalvannaw ni a lannae pâpho naseh.  
\q2 Bangkongtetpawiteh, Cathut ma roeroe heh lawkcengkung doeh.   
\q1
\v 7 Oe ka taminaw, thai awh haw, lawk ka dei vai.  
\q2 Oe Isarel, nang taranlahoi ka dei han. Kai heh Cathut na Cathut doeh.   
\q1
\v 8 Nange thuengnae dawk na yue mahoeh.  
\q2 Ka hmalah pout laipalah kaawm e hmaisawi thuengnae dawk  
\q2 hai na yue mahoeh.   
\q1
\v 9 Na imthung e maitotan ka lat mahoeh.  
\q2 Na saring thung e hmaetan hai ka lat mahoeh.   
\q1
\v 10 Bangkongtetpawiteh, ratu dawk e sarang pueng teh kaie doeh.  
\q2 Mon 1,000 touh dawk ka pâ e moithangnaw hai kaie doeh.   
\q1
\v 11 Monsom e tavaca pueng ka panue.  
\q2 Mon 1,000 touh dawk ka pâ e moithangnaw hai kaie doeh.   
\q1
\v 12 Ka vonhlam pawiteh nang koe ka dei mahoeh.  
\q2 Bangkongtetpawiteh, talaivan hoi a thung e kaawm e pueng teh kaie doeh.   
\q1
\v 13 Maitotan moi ka ca han namaw.  
\q2 Hmae thi ka nei han namaw.   
\q1
\v 14 Lunghawilawkdeinae thuengnae hah Cathut koe poe haw.  
\q2 Lathueng Poung koe na lawkkamnae hah kuep sak haw.   
\q1
\v 15 Runae na kâhmo navah kai hah na kaw haw.  
\q2 Kai ni na rasa han, nang ni hai kai hah na bawilen sak han.   
\q1
\v 16 Hatei Cathut ni tamikathout koevah,  
\q2 bangkongmaw ka coungnae hah na pâpho teh,  
\q2 na pahni hoi ka lawkkam hah na pâpho.   
\q1
\v 17 Kaie yuenae hah na hmuhma teh,  
\q2 ka lawk hah hnuklah na tâkhawng.   
\q1
\v 18 Tamru na hmu toteh tang na kamyawngkhai teh,  
\q2 uicuknaw na hmu toteh tang na kambawngkhai.   
\q1
\v 19 Na kâko hah thoenae koe na hno teh,  
\q2 na lai hah dumyennae koe bout na hno.   
\q1
\v 20 Na tahung teh, na hmaunawngha tounkhouknae lawk na dei.   
\q1
\v 21 Hottelah na o nahlangva kai ni duem na o takhai navah,  
\q2 nama patetlah kai hah na pouk.  
\q2 Hatei, na yue vaiteh na yonnae hah na hmaitung vah peng ka dan han.   
\q1
\v 22 Nangmouh Cathut na kapahnimnaw hetheh pouk awh haw.  
\q2 Hoehpawiteh, kai ni koung na phi payon vaih.  
\q2 Karasatkung na tawn mahoeh.   
\q1
\v 23 Lunghawilawkdeinae thuengnae ka sak e pueng teh,  
\q2 kai ka bawilen sak e lah ao.  
\q2 A cei nahan lamthung ka pouk e tami koe  
\q2 Cathut e rungngangnae lamthung ka pâtue han.   
\c 51  
\s1 Yon pankângai ratoumnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe Cathut, na pahren han ngai e patetlah na pahren haw.  
\q2 Kapap ni teh kahawi e na lungmanae dawkvah,  
\q2 kâtapoenae hah na tha pouh haw.   
\q1
\v 2 Ka sakpayon e pueng kathoungcalah na pâsu pouh haw.  
\q2 Ka yonnae dawk hoi na thoung sak haw.   
\q1
\v 3 Kâtapoenae hah ka panue toe.  
\q2 Ka yonnae teh pou ka pouk.   
\q1
\v 4 Nang taranlahoi nang koe roeroe ka yon toe.  
\q2 Na mithmu vah hawihoehnae ka sak toe.  
\q2 Ka kong na dei toteh atang doeh.  
\q2 Lawk na ceng toteh, toun han awm hoeh.   
\q1
\v 5 Kai teh payonnae lahoi khe e lah ka o teh,  
\q2 anu ni yon hoi doeh na vawn toe.   
\q1
\v 6 Lungthin kalan e hah na ngai dawkvah,  
\q2 ka lungthin thung lungangnae hah na cangkhai haw.   
\q1
\v 7 Dingsala hoi na hui haw, ka thoung han.  
\q2 Na pâsu haw tadamtui patetlah ka pangaw han.   
\q1
\v 8 Na khoe tangcoung e hrunaw konawm nahanlah,  
\q2 konawmnae hoi lunghawinae lawk na thaisak haw.   
\q1
\v 9 Ka yonnae dawk hoi na minhmai hrawk nateh,  
\q2 ka yonnae pueng hah na takhoe pouh haw.   
\q1
\v 10 Oe Cathut, ka thungvah lungthin kathoung bout sak nateh,  
\q2 kai dawk kacakpounge muitha hah bout roung sak haw.   
\q1
\v 11 Nang koehoi na pâlei hanh lah a.  
\q2 Na Kathoung Muitha teh kai koehoi na lat pouh hanh.   
\q1
\v 12 Na rungngangnae dawk konawmnae hah bout na poe haw.  
\q2 Hringpasoungnae na Muitha hoi na kuen haw.   
\q1
\v 13 Hottelah, kâtapoenaw hah na lamthung ka cangkhai vaiteh,  
\q2 tamikayonnaw teh nang koe a kâthung awh han.   
\q1
\v 14 Oe Cathut, kaie rungngangnae Cathut,  
\q2 tami thei e yon hoi na hlout sak haw.  
\q2 Na lannae hah ka lai ni kacaipounglah la a sak han.   
\q1
\v 15 Oe BAWIPA, ka pahni heh paawng nateh,  
\q2 ka pahni ni na pholen han.   
\q1
\v 16 Bangkongtetpawiteh, thuengnae hah na ngai e nahoeh.  
\q2 Hoehpawiteh, yo na poe han doeh toe.  
\q2 Hmaisawi thuengnae dawk hai na lungyouknae awm hoeh.   
\q1
\v 17 Cathut ngai e patetlah thuengnae hateh, muitha rek e hah doeh.  
\q2 Lungthin rek laihoi pankângai e heh,  
\q2 Oe Cathut, banglahai noutna laipalah na awm mahoeh.   
\q1
\v 18 Zion vah na ngai e hawinae hah sak haw,  
\q2 Jerusalem rapan hah kangdout sak haw.   
\q1
\v 19 Hottelah hoiyah, lannae thuengnae hoi hmaisawi thuengnae hoi  
\q2 takbuem hmaisawi thuengnae dawk na lunghawi vaiteh,  
\q2 na thuengnae khoungroe van vah, maitotan hah a thueng awh han.   
\c 52  
\s1 Tamikathout poutnae hoi Cathut tami roumnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe athakaawme tami, bangkong ne thoenae hoi na kambawng.  
\q2 Cathut hawinae teh a kangning yungyoe.   
\q1
\v 2 Na lai ni rawknae heh a sak teh, sam ngawnae pataca patetlah dumyennae hah na sak.   
\q1
\v 3 Hawinae hlak thoenae hah na ngaihnawn teh,  
\q2 lannae hlak hai laithoe dei e hah na ngaihnawn. Selah.   
\q1
\v 4 Nang kadumyenkung lai,  
\q2 pathoenae pueng hah na doun.   
\q1
\v 5 Hot patetlah Cathut ni kho na saknae hmuen koehoi na pâlei han.  
\q2 Kahringnaw onae ram koehoi na phawk vaiteh, na raphoe vaiteh,  
\q2 a yungyoe na kahma han. Selah.   
\q1
\v 6 Tamikalannaw ni hmawt awh vaiteh  
\q2 a taki awh han.   
\q1
\v 7 Cathut kâuep laipalah, mae tawnta e kâuep niteh,  
\q2 mae hawihoehnae dawk mangkhak kaawm e hei,  
\q2 khenhaw! hei, tet awh vaiteh, a panuikhai awh han.   
\q1
\v 8 Kai teh Cathut e im dawk olive thing dikhring e patetlah ka o teh,  
\q2 Cathut e a lungmanae teh a yungyoe ka kâuep han.   
\q1
\v 9 Nang ni na sak dawkvah, a yungyoe na pholen han.  
\q2 Na tami kathoungnaw hmalah na min ka ngaihawi han.  
\q2 Bangkongtetpawiteh, hetteh ahawi.   
\c 53  
\s1 Cathut laipalah pathunae  
\d Kathutkung: Devit  
\q1
\v 1 Tamipathu niteh, a lungthung hoi Cathut awm hoeh ati awh.  
\q2 Ka rawk niteh, panuet ka tho e payonnae hah a sak awh teh,  
\q2 hawinae kasakkung awm awh hoeh.   
\q1
\v 2 Thaipanueknae ka tawn e tami hoi  
\q2 Cathut ka tawng e tami ao han vaimoe titeh panue han a ngai dawkvah,  
\q2 Cathut ni kalvan hoi talai van a khet cathuk.   
\q1
\v 3 Tami pueng koung a payon awh teh, koung a rawk awh.  
\q2 Hawinae kasakkung awm hoeh.  
\q2 Buet touh boehai awm hoeh.   
\q1
\v 4 Vaiyei ca e patetlah ka taminaw hah a ca awh teh,  
\q2 Cathut ka kaw hoeh e tamikathoutnaw panueknaen tawn laipalah maw ao awh.   
\q1
\v 5 Taki hane ohoehnae koe puenghoi a taki awh.  
\q2 Bangkongtetpawiteh, nang na kalup niteh,  
\q2 na ka tarannaw e hru teh Cathut ni paringparang a kâyat sak.  
\q2 Ahnimouh teh Cathut ni a takhoe dawkvah,  
\q2 kayayeirai phu hoi ao sak han.   
\q1
\v 6 Oe Isarel rungngangnae teh Zion hoi tâcawt naseh.  
\q2 San lah kaawm e taminaw Cathut ni bout a tâcokhai toteh,  
\q2 Jakop konawm naseh, Isarel lunghawi naseh.   
\c 54  
\s1 Katarankung koehoi hloutnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe Cathut, na min lahoi na rungngang haw.  
\q2 Na thaonae hoi lawk na ceng pouh haw.   
\q1
\v 2 Oe Cathut, ka ratoum e heh thai haw.  
\q2 Ka dei e lawk heh na thai pouh haw.   
\q1
\v 3 Bangkongtetpawiteh, ramlouknaw ni kai taranlahoi a thaw awh teh,  
\q2 rep kacuengroenaw ni thei hanlah a kâcai awh.  
\q2 Cathut minhmai khoeroe khen awh hoeh. Selah.   
\q1
\v 4 Khenhaw! Cathut teh na kabawmkung doeh.  
\q2 BAWIPA teh ka hringnae karingkungnaw koe ao.   
\q1
\v 5 A tawksak awh e thoenae hah ama ni a patho han.  
\q2 Ahnimouh teh na lawkkatang hoi raphoe haw.   
\q1
\v 6 Kai hai lungthocalah hoi nang koe thuengnae ka sak han.  
\q2 Oe BAWIPA, na min teh ka pholen han.  
\q2 Bangkongtetpawiteh, nang teh na hawi.   
\q1
\v 7 Kai hah runae phunkuep thung hoi na hlout sak teh,  
\q2 ka tarannaw koe ka phat e hah ka mit ni khei a hmu toe.   
\c 55  
\s1 Yuemkamcu hoeh e hui kong dawk Cathut kâuepnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe Cathut, ka ratoumnae hah na thai pouh haw,  
\q2 nang koe kâhei navah na kâhrawk takhai hanh.   
\q1
\v 2 Na thai pouh haw, na pato haw.  
\q2 Ka reithainae dawkvah, pou ka phuenangnae kâhat thai hoeh.   
\q1
\v 3 Bangkongtetpawiteh, ka tarannaw pawlawk hoi,  
\q2 tamikathoutnaw ni repcoungroenae kecu dawk,  
\q2 runae kai dawk a pha sak teh, lungkhuek laihoi na hmuhma awh.   
\q1
\v 4 Ka lungthin teh ka lung thung puenghoi a pataw teh,  
\q2 due takinae ni na tho sin.   
\q1
\v 5 Takinae hoi pâyawnae ni na tho sin teh,  
\q2 kaluenae ni na ramuk.   
\q1
\v 6 Oe bakhu patetlah rathei tawn ka ngai.  
\q2 Hottelah ka tawn pawiteh, vi kamleng vaiteh, duem kâhat han eite.   
\q1
\v 7 Ahlanae koe ka cei vaiteh,  
\q2 kahrawng vah ka o han eite. Selah.   
\q1
\v 8 Hete kahlî tûilî ka tho e hoi ka hlout nahanlah,  
\q2 karanglah ka yawng han toe telah ka pouk.   
\q1
\v 9 Oe BAWIPA, ahnimae lawk hah a kahma nahanlah,  
\q2 koung kâkapek sak haw. Bangkongtetpawiteh,  
\q2 kho thung vah, thamanae hoi lawpnae ka hmu.   
\q1
\v 10 Karum khodai pout laipalah, rapan dawk hoi a kâhêi awh teh,  
\q2 kho thung vah thoenae hoi runae lah ao awh,   
\q1
\v 11 Kho thung vah thoenae ao teh,  
\q2 repcoungroenae hoi dumnae teh lamnaw dawk ao.   
\q1
\v 12 Kai na ka pathoe e teh ka taran nahoeh.  
\q2 Hoehpawiteh, ka pouk thai han ei.  
\q2 Na ka taran ni teh kai na ka hmuhma e hai ka taran nahoeh.  
\q2 Hoehpawiteh, ahni hah ka roun thai han ei.   
\q1
\v 13 Hottelah ka tet e tami teh nang doeh.  
\q2 Kai hoi kâtakawi e ka hui, ka kâpanuek e doeh.   
\q1
\v 14 Buet touh hoi buet touh lawk kapan e,  
\q2 Cathut im dawk tamimaya hoi reirei ka cet e doeh.   
\q1
\v 15 Duenae ni man naseh.  
\q2 Hringo hoi sheol dawk cet naseh.  
\q2 Bangkongtetpawiteh, hawihoehnae teh ahnimouh koe ao.   
\q1
\v 16 Kai teh Cathut ka kaw vaiteh,  
\q2 BAWIPA ni na rungngang han.   
\q1
\v 17 Amom, kanîthun, tangmin lah ka ratoum han.  
\q2 Kacaipounglah ka hram vaiteh, ka lawk hah a thai han.   
\q1
\v 18 Kai taranlahoi na tuknae hmuen koehoi,  
\q2 ka hringnae heh karoumcalah a ratang toe.  
\q2 Kai koelah kaawm e teh apap awh.   
\q1
\v 19 Ayan hoi kangning e Cathut ni a thai teh,  
\q2 ahnimouh hah a khang sak han. Selah.  
\q2 Ahnimouh teh a kâthung awh hoeh dawkvah, Cathut taket awh hoeh.   
\q1
\v 20 Ahnimouh teh hui hah a taran awh teh,  
\q2 lawkkam a raphoe awh.   
\q1
\v 21 Apâhni hoi a dei awh e lawk teh,  
\q2 maito sanutui kamkak e hlak a pâhnan.  
\q2 Hatei, a lungthung tarankâtuknae ao.  
\q2 A lawk teh satui hlak a nem eiteh,  
\q2 rayu tangcoung e tahloi lah doeh ao.   
\q1
\v 22 Na hnokari hah BAWIPA dawk patue haw, ama ni na hlai han.  
\q2 Tami kalan rawp hane pasoung hoeh.   
\q1
\v 23 Oe Cathut, alouknaw teh rawknae tangkom dawk koung na pabo han.  
\q2 Tamikathetnaw hoi yuemkamcuhoeh e naw teh,  
\q2 a hringyung tangawn patenghai hring awh mahoeh.  
\q2 Kai teh nang doeh na kâuep han.   
\c 56  
\s1 Runae kapoekung thung hoi hlout nahanlah ratoumnae  
\d Kathutkung: Devit, Devit teh Gath kho vah, Filistin kut dawk a pha nah a sak e la  
\q1
\v 1 Oe Cathut, kai na pahren haw.  
\q2 Taminaw ni padoun hanelah hnintangkuem na tuk teh,  
\q2 na rektap awh.   
\q1
\v 2 Ka tarannaw ni hnintangkuem na kaven awh.  
\q2 Oe Lathueng Poung, na ka tarannaw teh apap poung.   
\q1
\v 3 Ka lung a puen toteh,  
\q2 nang na kâuep han.   
\q1
\v 4 Cathut dawk (a lawk ka pholen han),  
\q2 Cathut ka kâuep dawkvah, taki han awm hoeh.  
\q2 Tami ni kai dawk bangmouh a sak thai han.   
\q1
\v 5 Ahnimouh teh kaie lawk hah hnintangkuem  
\q2 alouklah a pouk awh.  
\q2 Kai dawk kahawihoehe pouknae dueng doeh a pouk awh.   
\q1
\v 6 Kai thei hanelah a kâcai awh teh,  
\q2 cungtalah a kamkhueng awh teh,  
\q2 ka khokhnuk hah mitnout a ta awh.   
\q1
\v 7 Ahnimouh teh a payonnae dawk hoi a hlout awh han namaw.  
\q2 Oe Cathut, na lungkhuek nateh, ahnimanaw hah koung pâlei haw.   
\q1
\v 8 Ka kâvanae hah na touk teh,  
\q2 tuium dawk ka mitphi hah na ta.  
\q2 Na cauk dawk ao nahoehmaw.   
\q1
\v 9 Nang koe ka hram toteh, ka tarannaw koung a yawng awh han.  
\q2 Hetheh ka panue.  
\q2 Bangkongtetpawiteh, Cathut teh kaie doeh.   
\q1
\v 10 Cathut dawk (a lawk hah ka pholen han),  
\q2 BAWIPA dawk (a lawk hah ka pholen han).   
\q1
\v 11 Cathut ka kâuep dawkvah, ka taket mahoeh.  
\q2 Tami ni kai dawk bangmouh a sak thai han.   
\q1
\v 12 Oe Cathut, nang koe ka lawkkamnae ni na katek teh,  
\q2 nang koevah, pholennae ka dei han.   
\q1
\v 13 Bangkongtetpawiteh, ka hringnae heh duenae thung hoi na rungngang.  
\q2 Kahringnaw e angnae rahim vah,  
\q2 Cathut hmalah ka pai thai na han,  
\q2 ka khok kamthui hoeh nahan,  
\q2 na rungngang toe nahoehmaw.   
\c 57  
\s1 Taran kut dawk hoi roum nahanlah ratoumnae  
\d Kathutkung: Devit, Sawl koehoi lungngoum dawk a yawng navah, a sak e la  
\q1
\v 1 Na pahren haw, Oe Cathut, na pahren haw.  
\q2 Bangkongtetpawiteh, ka hringnae ni na kâuep .  
\q2 Hete yawthoenae heh a baw hoehroukrak na rathei tâhlip dawk ka kâhro han.   
\q1
\v 2 Lathueng Poung Cathut, bangpuengpa na kasakpouhkung,  
\q2 ka Cathut teh na kaw han.   
\q1
\v 3 Kalvan hoi a patoun vaiteh, na rungngang han,  
\q2 payawp hanlah kakâcainaw hah a yue han. Selah.   
\q1
\v 4 Cathut ni lungmanae hoi lawkkatang hah a patoun han.  
\q2 Ka hringnae heh sendek um doeh ao.  
\q2 Lungkhueknae hmai ka kang lahun e taminaw um vah ka i.  
\q2 Ahnimae hânaw teh tahroe hoi palanaw patetlah ao awh.  
\q2 Ahnimae lai hai kahran e tahloinaw patetlah ao awh.   
\q1
\v 5 Oe Cathut, kalvannaw lathueng vah, pholen lah awm haw.  
\q2 Na bawilennae teh talai van pueng awm lawiseh.   
\q1
\v 6 Ka khok hanlah, tamlawk a yangda awh teh, ka hringnae teh a tabut.  
\q2 Ka hmalah tangkom a tai awh.  
\q2 Hatei, a lungui vah amamouh letlang a bo awh. Selah.   
\q1
\v 7 Ka lungthin teh a cak doeh, Oe Cathut,  
\q2 ka lungthin teh a cak doeh, pholennae hoi la ka sak han.   
\q1
\v 8 Ka bawilennae kâhlaw haw, ratoung hoi tamawinaw kâhlaw awh haw.  
\q2 Kai ni teh kho ka dai khai han.   
\q1
\v 9 Oe BAWIPA, tamimaya koe na pholen han.  
\q2 Miphun pueng koe nang pholen hoi la ka sak han.   
\q1
\v 10 Bangkongtetpawiteh, na lungmanae ni kalvan a pha teh,  
\q2 na lawkkatang ni tâmai a pha.   
\q1
\v 11 Oe Cathut, kalvan vah pholen lah awm naseh,  
\q2 na bawilennae teh talai van pueng awm lawiseh.   
\c 58  
\s1 Tamikathoutnaw hanlah kalan e lawkcengnae  
\d Kathutkung: Devit  
\q1
\v 1 Nangmouh duem na kaawm e naw,  
\q2 lannae lawk hah na dei awh katang maw.  
\q2 Oe tami capanaw kalanlah lawk na ceng awh maw.   
\q1
\v 2 Na ceng awh hoeh, na lungthung vah, hawihoehnae na sak awh.  
\q2 Talaivan na kut hoi thamanae yawcu hoi na khing awh.   
\q1
\v 3 Tamikathoutnaw teh, von thung hoi lam a payon awh toe.  
\q2 A tâco awh tahma vah, laithoe dei laihoi lam a payon awh.   
\q1
\v 4 Asue teh hrunthoesue patetlah ao.  
\q2 A hnâ ka pang e tahrun a hnâ pahru e patetlah ao.   
\q1
\v 5 Hote tahrun ni teh tahrun camnae lawk hai thai thai hoeh.  
\q2 Camnae la sak e hai thai thai hoeh.   
\q1
\v 6 Oe Cathut, a kâko e hâ hah khoe pouh haw.  
\q2 Oe BAWIPA, athakaawme sendek nônaw hah khoe pouh haw.   
\q1
\v 7 Ka lawng lahun e tui patetlah kahmat awh naseh.  
\q2 Licung a sawn awh toteh, ahnimae palanaw teh koung kâkhoe naseh.   
\q1
\v 8 A cei lahun nah kahmat e kongkaraw patetlah kahmat awh naseh.  
\q2 Camo karawk e ni kanî a hmu hoeh e patetlah awm awh naseh.   
\q1
\v 9 Pâkhing pho hoi patawi e hmai, hlaam a bet hoehnahlan vah,  
\q2 kahring e pâkhing pho hoi hmai ka kang e pâkhing phonaw teh,  
\q2 bongparui ni cetkhai naseh.   
\q1
\v 10 Tamikalannaw ni hot patetlah  
\q2 e reknae hah a hmu awh toteh,  
\q2 a konawm awh han.   
\q1
\v 11 Tamikathoutnaw e thi dawk a khok a pâsu awh han.  
\q2 Hottelah tami ni, ayânaw hanelah tawkphu ao tie hoi  
\q2 lawkcengkung Cathut ao katang ati awh han.   
\c 59  
\s1 Tamikathout lawkcengnae  
\d Kathutkung: Devit, Sawl ni a patoun e naw ni Devit thei hanelah im a ring awh navah sak e la  
\q1
\v 1 Oe ka Cathut, ka taran kut dawk hoi na rungngang haw.  
\q2 Na ka tarannaw koehoi na hlout sak haw.   
\q1
\v 2 Ka payonnaw koehoi na rungngang haw.  
\q2 Tami kathetnaw kut dawk hoi na rungngang haw.   
\q1
\v 3 Ahnimouh ni thei hanelah na pawp awh.  
\q2 Athakaawmnaw teh, kai taranlahoi a kamkhueng awh.  
\q2 Oe BAWIPA, ka yonnae hoi kâtapoenae dawk nahoeh.   
\q1
\v 4 Ka payon hoeh e dawk hoi a yawng awh teh, a kâcai awh.  
\q2 Thaw nateh, khenhaw! na kabawm haw.   
\q1
\v 5 Hatdawkvah, oe ransahu BAWIPA Cathut, Isarel Cathut,  
\q2 miphun pueng rek hanlah thaw haw,  
\q2 kâtapoe e tamikathoutnaw hah pahren hanh. Selah.   
\q1
\v 6 Tangmin vah a ban awh teh,  
\q2 khopui a lawngven awh teh,  
\q2 ui patetlah a rauk awh.   
\q1
\v 7 Ahnimouh teh, dudamnae lawk a dei awh teh,  
\q2 ahnimae pahni dawk tahloi ao teh,  
\q2 apinimouh a thai han aw ati awh.   
\q1
\v 8 Hatei, oe BAWIPA, ahnimouh teh na panuikhai han.  
\q2 Miphun pueng teh nang hanlah panui ka tho e lah ao awh.   
\q1
\v 9 Oe nang, a tha kaawm e, pou na ring han.  
\q2 Bangkongtetpawiteh, Cathut teh kânguenae doeh.   
\q1
\v 10 Lungmakung Cathut ni, na dawn han.  
\q2 Cathut ni ka tarannaw lathueng,  
\q2 ka ngainae a pha sak e hah na hmu sak han.   
\q1
\v 11 Ahnimouh teh thet hanh.  
\q2 Hoehpawiteh, ka taminaw ni a pahnim payon awh han doeh.  
\q2 Oe BAWIPA, kaie bahling, na thaonae hoi kapek nateh,  
\q2 koung rahnoum sak haw.   
\q1
\v 12 Bangkongtetpawiteh, a pahni dawk hoi a tâco sak e dei payonnae lawk kecu dawkvah,  
\q2 a kâoupnae dawk kâman awh naseh.  
\q2 Thoebonae hoi laithoe a dei awh.   
\q1
\v 13 Lungkhuek laihoi kahmat sak haw.  
\q2 Hahoi Cathut ni Jakop lathueng vah,  
\q2 lawk a ceng tie hah talai poutnae koe totouh panuek awh naseh.   
\q1
\v 14 Tangmin lah ban awh naseh.  
\q2 Ui patetlah rauk laihoi khopui hah lawngven awh naseh.   
\q1
\v 15 Ca hane rawca a tawng awh teh,  
\q2 a von a paha hoehroukrak a rauk awh.   
\q1
\v 16 Hatei, na thaonae hah la hoi ka sak han.  
\q2 Amom vah na lungmanae hah,  
\q2 kacaipounglah la hoi ka sak han.  
\q2 Bangkongtetpawiteh, nang teh ka kânguenae hoi  
\q2 lungpout navah, ka yawngnae lah na o.   
\q1
\v 17 Oe ka thaonae, nang koe pholennae la ka sak han.  
\q2 Bangkongtetpawiteh, Cathut teh ka kânguenae lah ao teh,  
\q2 lungmakung Cathut lah ao.   
\c 60  
\s1 Cathut ngaikhainae dawk ratoumnae  
\d Kathutkung: Devit Mesopotamia hoi Siria Zabathnaw a tuk teh, Joab a ban teh, Palawi yawn dawk tami 12, 000 touh a thei navah a sak e la  
\q1
\v 1 Oe Cathut, na lungkhuek dawkvah,  
\q2 kaimouh na pahnawt teh,  
\q2 kho tangkuem na kathek toe.  
\q2 Bout na roung sak haw.   
\q1
\v 2 Talai heh na pâyaw sak teh na kâbawng sak.  
\q2 Kâbawng e naw hah bout pâbing haw, pou a kâhuet hei.   
\q1
\v 3 Na taminaw heh ka ru e hno na hmu sak teh,  
\q2 runae misur hah na pânei.   
\q1
\v 4 Nang kataketnaw hah lawkkatang pâwlawk dawk ung vaiteh,  
\q2 yap hanelah lukkarei na poe.   
\q1
\v 5 Na pahren e naw hah rungngang lah ao awh nahanlah,  
\q2 nange aranglae kut hoi rungngang haw.   
\q1
\v 6 Cathut ni a thoungnae lahoi a dei toe.  
\q2 Ka konawm vaiteh, Shekhem kho kapek vaiteh,  
\q2 Sakut yawn hah ka bangnue han.   
\q1
\v 7 Gilead teh kaie doeh, Manasseh teh kaie doeh.  
\q2 Ephraim hai kaie bawilakhung doeh.  
\q2 Judah teh kaie kâlawk kapoekung doeh.   
\q1
\v 8 Moab teh ka kamhluknae kawlung doeh.  
\q2 Edom ram teh, ka khok coungroenae lah ao han.  
\q2 Kai kecu dawk Filistin lathueng tânae hram lawk a tâco han.   
\q1
\v 9 Kacake khopui dawk, apimaw na hrawi han.  
\q2 Edom vah, apimaw na hrawi han.   
\q1
\v 10 Oe Cathut, na kapahnawtkung teh, nang nahoehmaw.  
\q2 Ransanaw koe ka cet hoeh e hah teh, nang nahoehmaw.   
\q1
\v 11 Runae um vah, na kabawm haw.  
\q2 Bangkongtetpawiteh, tami kabawpnae teh cungkeihoeh.   
\q1
\v 12 Cathut pawlawk dawk taranhawi laihoi namnei awh han.  
\q2 Bangkongtetpawiteh, ama ni maimae tarannaw hah rep a coungroe han.   
\c 61  
\s1 Cathut ni yungyoe ringnae  
\d Kathutkung: Devit, La kahrawikung hanlah, rui thueng e tumkhawng hoi ni sak e la  
\q1
\v 1 Oe Cathut, ka hramnae lawk heh na thai pouh haw.  
\q2 Ka ratoumnae heh na thai pouh haw.   
\q1
\v 2 Ka lung tha a tawn teh, talai poutnae koehoi nang koe ka hram.  
\q2 Kai hlak ka rasang e lungsong koe na hrawi haw.   
\q1
\v 3 Bangkongtetpawiteh, nang teh kai hanlah kânguenae lah na o teh,  
\q2 tarannaw hmalah kacakpounge imrasang lah na o.   
\q1
\v 4 Na rim dawk pou ka o han.  
\q2 Na rathei hoi na ramuknae koe ka kângue han.   
\q1
\v 5 Bangkongtetpawiteh Oe Cathut,  
\q2 ka lawkkam hah na thai pouh haw.  
\q2 Na min kabarinaw e râw hah kai na poe.   
\q1
\v 6 Siangpahrang, hringyung na saw sak teh,  
\q2 a kum hai se moikasaw kangning naseh.   
\q1
\v 7 Cathut hmalah a yungyoe a kangning han.  
\q2 Oe ahni roum sak nahanlah,  
\q2 lungmanae hoi lawkkatang hah rakueng pouh haw.   
\q1
\v 8 Ka lawkkam hah hnintangkuem ka kuep sak nahan  
\q2 a yungyoe a min pholen hoi la ka sak han.   
\c 62  
\s1 Cathut rungngangnae duem ringnae  
\d Kathutkung: Devit, La kahrawikung Jeduthun koe sak e la  
\q1
\v 1 Atangcalah ka hringnae ni Cathut teh duem a ring.  
\q2 Kai rungngangnae teh ama koehoi doeh a tho.   
\q1
\v 2 Ama dueng doeh ka lungsong hoi ka rungngangnae lah kaawm.  
\q2 Ama teh rapan lah ao, ka kâhuen mahoeh.   
\q1
\v 3 Bangkongmaw tami buet touh heh na uk han.  
\q2 ka rawm e rapan hoi kâhuen e tapang patetlah  
\q2 nâtotouh maw na raphoe awh han.   
\q1
\v 4 Arasangnae koehoi pabo hanelah a kâpan awh.  
\q2 Laithoe deinae koe a lunghawi awh teh.  
\q2 A pahni hoi yawhawi a poe awh ei teh,  
\q2 a lungthung hoi thoe a bo awh.   
\q1
\v 5 Ka hringnae, Cathut dueng maha duem ring lawih.  
\q2 Bangkongtetpawiteh, ka ngaihawinae teh a ma koehoi doeh a tho.   
\q1
\v 6 Ama dueng doeh ka lungsong hoi rungngangnae lah ao.  
\q2 Ka kâhuen mahoeh.   
\q1
\v 7 Ka rungngangnae hoi bawilennae teh, Cathut dawk ao.  
\q2 Ka thaonae lungsong hoi ka kânguenae teh ka Cathut dawk ao.   
\q1
\v 8 Tamimaya, ama teh a yungyoe kâuep awh haw.  
\q2 A hmalah na lungthin rabawk awh haw.  
\q2 Cathut teh maimouh kânguenae doeh.   
\q1
\v 9 Kangduenae hmuen kârahnoumnaw ahrawnghrang lah ao awh teh,  
\q2 kangduenae hmuen ka rasangnaw teh, laithoe doeh.  
\q2 Yawcu hoi khing pawiteh, hotnaw teh ahrawnghrang hlak a pâhaw awh.   
\q1
\v 10 Rektapnae hah kâuep awh hanh.  
\q2 Thama lahoi lawp e dawk kâuep awh hanh.  
\q2 Hno tawnta e dawk na lungpen awh hanh.   
\q1
\v 11 Cathut ni vai touh a dei toe.  
\q2 Apâhni bout ka thai e lawk teh, bahu teh Cathut dawk ao.   
\q1
\v 12 Oe BAWIPA, nang teh pahrennae hoi na kawi.  
\q2 Nang ni tamipueng amamae tawksak e patetlah ouk na poe.   
\c 63  
\s1 Cathut hoi kâhuiko konawmnae  
\d Kathutkung: Devit, Judah kahrawngum ao navah a sak e la  
\q1
\v 1 Oe Cathut, nang teh ka Cathut doeh.  
\q2 Amom vah na tawng han.  
\q2 Ka hringnae ni nang na kahran.  
\q2 Ka takthai ni nang na rabui.  
\q2 Kenae hoi tui kahrannae, tui ohoehnae ram dawk kaawm e lah ka o.   
\q1
\v 2 Na bawilennae hmu hanlah,  
\q2 hmuen kathoung thung na tawng toe.   
\q1
\v 3 Na pahrennae teh hringnae hlak hai a hawihnawn dawkvah,  
\q2 ka pahni hoi ka pholen han.   
\q1
\v 4 Hot patetlah ka hringyung thung na pholen han.  
\q2 Na min lahoi ka kut ka dâw han.   
\q1
\v 5 Ka hringnae heh rakhing hoi a thaw kaboum lah ca e patetlah a lungkuep han.  
\q2 Hateh, konawm pahni hoi na pholen han.   
\q1
\v 6 Ka ikhun dawk hoi ka pouk navah,  
\q2 karumsaning totouh ouk ka pouk.   
\q1
\v 7 Bangkongtetpawiteh, nang teh na kabawmkung doeh.  
\q2 Hatdawkvah, na rathei rahim vah ka konawm han.   
\q1
\v 8 Ka hringnae ni kahnaicalah na hruiyun teh,  
\q2 nama e aranglae kut hoi na kuet.   
\q1
\v 9 Hatei, ka hringnae thei hanlah katawngnaw teh,  
\q2 adungpoungnae koe talai thung vah a cei awh han.   
\q1
\v 10 Tahloi hoi dout awh vaiteh,  
\q2 Asuinaw ni ca hanelah, ao han.   
\q1
\v 11 Hatei, siangpahrang teh Cathut dawk konawm vaiteh,  
\q2 Cathut noe laihoi thoekâbo e pueng ni, a pholen awh han.  
\q2 Hatei laithoe kadeinaw e pahninaw teh, tabuem lah ao awh han.   
\c 64  
\s1 Tamikathout repcoungroenae hoi BAWIPA lunghawinae  
\d Kathutkung: Devit  
\q1
\v 1 Oe Cathut, ka phuenangnae dawk, ka lawk na thai pouh haw.  
\q2 Ka tarannaw ka takinae koehoi ka hringnae na khetyawt lawih.   
\q1
\v 2 Tamikathoutnaw e kâdeikâpannae koehoi thoseh,  
\q2 Payonnae kasaknaw kamkhuengnae koehoi thoseh, na ngue haw.   
\q1
\v 3 Ahnimouh ni amamae lai hah,  
\q2 tahloi patetlah a hran sak awh.   
\q1
\v 4 Yonnae ka tawn hoeh e tami hah arulahoi ka hanelah,  
\q2 lawkthoeumkha pala hoi a nue awh teh,  
\q2 takinae tawn laipalah vaitalahoi ouk a ka awh.   
\q1
\v 5 Hawihoehnae dawk buet touh hoi buet touh a kâhroecoe awh.  
\q2 Tangkhek patung hanelah a kâpan awh teh,  
\q2 apinimouh na hmu han vah ouk ati awh.   
\q1
\v 6 Hawihoehnae hah ma hanelah a pâphue awh.  
\q2 Ngit a pâphue awh.  
\q2 Lungthin thung lengkaleng a pouknae teh a dungpoung.   
\q1
\v 7 Ahnimouh teh Cathut ni pala hoi a ka vaiteh,  
\q2 pouk laipalah hmâ a ca awh han.   
\q1
\v 8 A dei awh e lawk dawk letlang a rawp sak vaiteh,  
\q2 ka hmawt e pueng ni a yawng takhai awh han.   
\q1
\v 9 Tami pueng ni taket vaiteh,  
\q2 Cathut ni a sak e doeh tie a pâpho awh han.  
\q2 Bangkongtetpawiteh, hmantang a sak awh e hah a pouk awh han.   
\q1
\v 10 Tamikalan teh BAWIPA dawk konawm vaiteh,  
\q2 ama hah a kâuep han.  
\q2 A lungthin kalan e pueng ni a pholen awh han.   
\c 65  
\s1 Rungngangnae hoi khetyawtnae dawkvah, Cathut pholen  
\d Kathutkung: Devit  
\q1
\v 1 Oe Cathut pholennae niyah na ring,  
\q2 lawkkamnae teh nang koe ka sak awh han.   
\q1
\v 2 Oe, ratoumnae lawk kathaikung,  
\q2 tami pueng nang koe a tho awh han.   
\q1
\v 3 Payonnae ni na taran teh, kâtapoenae ni na ka tâ nakunghai,  
\q2 kaimae yonnae hah nang ni yontha pouh toe.   
\q1
\v 4 Na thongma dawk ao thai nahan,  
\q2 nang koe hnai hanlah na rawi e tami yawkahawi e lah ao.  
\q2 Na im hawinae hoi na bawkim hawinae dawk ka lungkuep han toe.   
\q1
\v 5 Lannae dawk kângairu hnosak e lahoi na pato han.  
\q2 Oe ka rungngangnae Cathut,  
\q2 nang teh talîpui namran lah kaawmnaw hoi, talai poutnae koe kaawmnaw hoi,   
\q1
\v 6 thaonae hoi kamthoup niteh,  
\q2 thaonae hoi monnaw kacaksakkung,   
\q1
\v 7 Ka cairing lahun e talîpui hoi tuicapa ka thaw lahun e hoi,  
\q2 tamimaya ruengruengtinae karoumsakkung, lah na o.   
\q1
\v 8 Ahla poungnae koe kaawmnaw nihai,  
\q2 na mitnoutnae hah a taki awh.  
\q2 Amom tangmin kaphatnaw koe konawmnae na phu sak.   
\q1
\v 9 Talai heh na rip teh, kho thouk na rak sak teh,  
\q2 tui hoi ka kawi e Cathut e palangnaw hah tawntanae hoi na pathoup.  
\q2 Hottelah, talai heh na pathoup teh,  
\q2 talai van kaawmnaw a pawhik na rakueng pouh.   
\q1
\v 10 Laikongnaw hah tui na awi teh, laikawknaw hah na cak sak.  
\q2 Khotui hoi na nem sak teh, caticamu ka paw e naw hah yawhawi ouk na poe.   
\q1
\v 11 A kumnaw hah na hawinae hoi na ramuk teh,  
\q2 na khoknaw ni a thâw a lawi sak.   
\q1
\v 12 Kahrawng e thingkung ni dik kahringcalah ao teh,  
\q2 monruinaw hai a lunghawi awh.   
\q1
\v 13 Pho kahringnaw onae koe saringnaw akawi teh,  
\q2 ayawn hai rawca kung hoi akawi teh,  
\q2 konawm laihoi la a sak awh.   
\c 66  
\s1 Hno kalan a sak e dawkvah, Cathut pholen  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 Talaivan pueng Cathut koe  
\q2 konawm hoi hram awh haw.   
\q1
\v 2 A min bari laihoi la sak awh nateh,  
\q2 ka sungren poung lah pholen awh.   
\q1
\v 3 Cathut koe, na sak e heh banghloi kângai lah a ru.  
\q2 Kângairu na sak e dawkvah,  
\q2 na tarannaw hah nang koe a poe han.   
\q1
\v 4 Talai van pueng ni, bawk laihoi nang koe pholen la sak awh vaiteh,  
\q2 na min pholen laihoi la a sak awh han  
\q2 telah tet awh naseh. Selah.   
\q1
\v 5 Tho awh nateh Cathut ni sak e naw hah khenhaw.  
\q2 Tami capanaw hanelah, a sak e naw hah kângairu hanelah ao.   
\q1
\v 6 Ama ni talîpui hah talai kaphui lah a coung sak teh,  
\q2 talîpui dawk khok hoi a cei awh.  
\q2 Hawvah ama dawk a konawm awh.   
\q1
\v 7 A thaonae hoi pou a uk, A mit hoi miphun pueng hah a khet.  
\q2 Tarankathawnaw teh kâphokâlen awh hanh naseh. Selah.   
\q1
\v 8 Oe tamimaya, maimae Cathut teh pholen awh haw.  
\q2 Pholennae lawk heh thai kamcu lah sak awh.   
\q1
\v 9 Kahringnaw koe maimouh hringnae hah a kuet teh,  
\q2 maimouh kamthui hane hai na pasoung hoeh.   
\q1
\v 10 Bangkongtetpawiteh, Oe Cathut, nang ni na tanouk teh,  
\q2 ngun tanouk e patetlah na tanouk.   
\q1
\v 11 Tamlawk hoi na man teh,  
\q2 kaimae loung dawk hnori hah na patue.   
\q1
\v 12 Kaimae lû dawk tami na kâcui sak teh,  
\q2 hmai hoi tuikalen hah na raka.  
\q2 Hatei, kakuep e tawntanae hmuen koe na hrawi.   
\q1
\v 13 Hmaisawi thuengnae hoi kathâw e saring hoi  
\q2 hmuitui tuca hoi na im dawk a kâen han.   
\q1
\v 14 Hat hateh, runae ka kâhmo navah,  
\q2 ka pahni hoi ka dei e patetlah ka pâpho tangcoung e doeh.   
\q1
\v 15 Hmaisawi thuengnae dawkvah,  
\q2 kathâw e saring hoi hmuitui tuca hoi ka poe vaiteh,  
\q2 maitotan hah hmae hoi ka poe han. Selah.   
\q1
\v 16 Cathut ka taket e pueng, tho awh nateh thai awh haw.  
\q2 Ka hring nahanelah a sak e hah na pâpho pouh vai.   
\q1
\v 17 Ka pahni hoi ama koe ka hram teh,  
\q2 ka lai hoi ama teh ka tawm.   
\q1
\v 18 Ka lungthin ni payonnae hah noutna hoeh pawiteh,  
\q2 Bawipa ni na thai pouh mahoeh.   
\q1
\v 19 Hatei, Cathut ni na thai pouh katang teh,  
\q2 ka hramnae lawk hai kahawicalah a thai.   
\q1
\v 20 Ka ratoumnae pahnawt hoeh niteh,  
\q2 kai koehoi a lungmanae ka puen hoeh e,  
\q2 Cathut teh pholen lah awm seh.   
\c 67  
\s1 Ratoumnae hoi pholennae la  
\d Kasakkung: Panuekhoeh  
\q1
\v 1 Cathut ni na lungma awh teh,  
\q2 yawhawi na poe awh naseh.  
\q2 A minhmai angnae teh maimouh koe ang lawiseh.   
\q1
\v 2 Talai van vah na lamthung pnue lah ao teh,  
\q2 na rungngangnae teh miphun pueng koe panue lah awm lawiseh.   
\q1
\v 3 Oe Cathut, taminaw ni na pholen naseh.  
\q2 Tami pueng ni na pholen naseh.   
\q1
\v 4 Oe miphun pueng lunghawi laihoi la sak awh naseh.  
\q2 Bangkongtetpawiteh, tami pueng hah kalanlah lawk a ceng teh,  
\q2 talai van e miphunnaw hah na uk. Selah.   
\q1
\v 5 Oe Cathut, taminaw ni na pholen naseh.  
\q2 Tami pueng ni na pholen naseh.   
\q1
\v 6 Hottelah, talai ni a pawhik hoehoe tâcawt sak vaiteh,  
\q2 Cathut, maimae Cathut ni yawhawi na poe han.   
\q1
\v 7 Cathut ni yawhawi na poe vaiteh,  
\q2 tami pueng ni a ma a taki awh han.   
\c 68  
\s1 Isarel koe hawinae dawk Cathut pholennae  
\d Kathutkung: Devit  
\q1
\v 1 Cathut, thaw nateh tarannaw koung kâkayei naseh.  
\q2 Cathut kahmuhmanaw teh ama koehoi yawng awh naseh.   
\q1
\v 2 Hmaikhu a kahma e patetlah ahnimouh teh koung kahmat naseh.  
\q2 Khoilai teh hmai hma lah a kamyawt e patetlah,  
\q2 tamikathoutnaw teh Cathut hmalah kahmat awh naseh.   
\q1
\v 3 Hatei, tamikalannaw teh lunghawi laihoi  
\q2 Cathut hmalah konawm awh naseh.  
\q2 Bokheiyah, puenghoi konawm awh naseh.   
\q1
\v 4 Cathut koe la sak hoi a min pholen la sak awh.  
\q2 Tâmai dawk kâcuie hateh pholen awh nateh, a min teh BAWIPA,  
\q2 pholen laihoi a hmalah lunghawi awh.   
\q1
\v 5 Na pa ka tawn hoeh naw e napa, lahmainunaw karingkung,  
\q2 Cathut teh hmuen kathoung koe ao.   
\q1
\v 6 Cathut ni amadueng kho ka sak e hah imthung a poe teh,  
\q2 paung e naw hai tawntanae hmuen koe a hrawi.  
\q2 Hatei, tarankathawnaw teh kenae hmuen koe ao sak.   
\q1
\v 7 Oe Cathut na taminaw hrawi hanelah na tâco teh,  
\q2 kahrawngum vah hmalah na cei navah, Selah.   
\q1
\v 8 Talai a kâhuet teh, Cathut hmalah kalvan ni kho a rak sak.  
\q2 Sinai mon teh Cathut hmalah, Isarel Cathut hmalah a kâhuet.   
\q1
\v 9 Oe Cathut nang ni kho thouk na rak sak teh,  
\q2 na râw taminaw ka patang e hah na kabawp.   
\q1
\v 10 Hawvah na tamimaya teh kho a sak awh.  
\q2 Oe Cathut, nang ni ka mathoenaw hah na hawinae hoi na kawk.   
\q1
\v 11 BAWIPA ni lawk a dei teh,  
\q2 hote kong ka dei e tamimaya teh ao.   
\q1
\v 12 Siangpahrang e ransanaw teh a yawng awh teh,  
\q2 im ka ring e napuinaw ni lawphno a kârei awh.   
\q1
\v 13 Tutakha thung na ka ip nakunghai,  
\q2 ngun hoi pathoup e bakhu rathei patetlah thoseh,  
\q2 sui hoi pathoup e rathei muen patetlah thoseh, na o awh han.   
\q1
\v 14 Athakasaipounge Cathut ni siangpahrangnaw a kayei navah,  
\q2 Zalmon mon dawk e ka pangaw e tadamtui patetlah ao.   
\q1
\v 15 Bashan mon teh Cathut e mon lah ao teh,  
\q2 Bashan mon dawk monsom moikapap ao.   
\q1
\v 16 Monsomnaw bangkongmaw utsinnae mit hoi na hmaiet awh.  
\q2 Hetheh, Cathut ni o han ngainae mon lah ao.  
\q2 BAWIPA teh hawvah pou ao han.   
\q1
\v 17 Cathut e lengnaw teh a thong thong hra hlak moi apap.  
\q2 BAWIPA teh Sinai mon, hmuenkathoung koe ao e patetlah ahnimouh koe ao.   
\q1
\v 18 Arasangnae koe na luen teh, tami moikapap na man teh,  
\q2 BAWIPA Cathut teh taminaw koe ao thai nahanlah,  
\q2 tami koehoi dueng laipalah,  
\q2 ka taran e taminaw koe totouh poehno hah a dâw.   
\q1
\v 19 Hnintangkuem hnori na ka hlai e Bawipa,  
\q2 rungngangnae Cathut teh pholen lah awm lawiseh.   
\q1
\v 20 Cathut teh rungngangnae Cathut doeh.  
\q2 Duenae koehoi hloutnae hai Bawipa Jehovah e doeh.   
\q1
\v 21 Hateiteh, Cathut ni a tarannaw lû thoseh,  
\q2 yon pou kasaknaw e sam onae lû roeroe thoseh, hmâ a ca sak han.   
\q1
\v 22 Bawipa ni Bansan hoi ka bankhai vaiteh,  
\q2 ka dungpoung e talîpui koehoi bout ka bankhai han.   
\q1
\v 23 Na khok ni na taran thi coungroe vaiteh,  
\q2 na uinaw ni hai a palem awh han telah ati.   
\q1
\v 24 Oe Cathut, hmuen kathoung koe na tho e,  
\q2 ka Cathut, kaie Siangpahrang na tho e hah a hmu awh toe.   
\q1
\v 25 La kasakkungnaw hmalah a cei awh teh,  
\q2 tumkhawng katumnaw ni a kâbang awh.  
\q2 A lungui vah tanglanaw ni tâbaw a khawng awh.   
\q1
\v 26 Kamkhueng e maya thung dawk,  
\q2 Cathut Isarel hringnae a kung,  
\q2 BAWIPA teh pholen awh.   
\q1
\v 27 Hawvah, cahnoung Benjamin hoi kahrawikung ao.  
\q2 Judah bawinaw a huinaw ni a kâbang teh Zebulun hoi  
\q2 Naphtali bawinaw ni a kâbang awh.   
\q1
\v 28 Na Cathut ni na thaonae teh kâ a poe toe.  
\q2 Oe Cathut kaimouh hanlah na sak tangcoung e patetlah hoehoe thasai sak haw.   
\q1
\v 29 Jerusalem e na bawkim kecu,  
\q2 siangpahrangnaw ni poehno a sin awh han.   
\q1
\v 30 Lungpum um e sarangnaw hai thoseh, maitotannaw hoi,  
\q2 maitolanaw hai thoseh, a yue teh, tangka hoi kârahnoum awh naseh.  
\q2 Tarantuk ka ngai e miphunnaw hah, koung kayei naseh.   
\q1
\v 31 Izip hoi laiceinaw tho awh vaiteh,  
\q2 Ethiopianaw ni Cathut koe karang poung lah a kut a dâw awh han.   
\q1
\v 32 Talai siangpahrang uknae Cathut koe la sak laihoi  
\q2 Bawipa pholen laihoi la sak awh. Selah.   
\q1
\v 33 Ayan vah, kalvannaw e kalvan kâcuie koevah,  
\q2 athakaawme lawk, a lawk roeroe a tâco sak.   
\q1
\v 34 Cathut koe thaonae hah poe awh.  
\q2 A lawkpuilah, ahawinae hah Isarelnaw lathueng ao.  
\q2 A thaonae teh tâmai dawkvah ao.   
\q1
\v 35 Oe Cathut, na hmuen kathoung hlak hai takithohnawn.  
\q2 Isarel Cathut teh a taminaw thaonae hoi hnotithainae kapoekung doeh.  
\q2 Cathut teh pholen lah awm lawiseh.   
\c 69  
\s1 Runae thung hoi ratoumnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe Cathut, na rungngang haw.  
\q2 Bangkongtetpawiteh, tui ni ka lahuen totouh na muem toe.   
\q1
\v 2 Ka dung e tangdong dawk ka bo teh, kangdue nahan awm hoeh.  
\q2 Tui kadung, tuicapa ni na ramuknae koe ka pha.   
\q1
\v 3 Ka hram lawi ka tâwn toe.  
\q2 Ka dangka a ke toe.  
\q2 Ka Cathut ngaihawi laihoi ka mit a tâwn toe.   
\q1
\v 4 A khuekhaw awm laipalah na kahmuhmanaw teh,  
\q2 ka sam hlak apap awh.  
\q2 Ayawmyin lah na taran awh teh,  
\q2 raphoe hanlah kakâcainaw teh, a thao awh.  
\q2 Banghai ka parawt hoeh ei, boutbout pathoe hanelah ao.   
\q1
\v 5 Oe Cathut, ka pathunae heh ka panue.  
\q2 Ka yonnae heh ka hrawk hoeh.   
\q1
\v 6 Oe Jehovah, ransahu Cathut,  
\q2 na karingkungnaw teh kai kecu dawk kayak awh nahanh seh.  
\q2 Oe Isarel Cathut, nang katawngkung hah kai kecu dawk  
\q2 a lungpout awh nahanh seh.   
\q1
\v 7 Nang kecu dawk pathoenae ka kâhmo teh,  
\q2 kayanae ni ka minhmai a ramuk.   
\q1
\v 8 Ka hmaunawnghanaw thung dawk imyin lah ka o teh,  
\q2 manu buet touh ni na khe e thung dawk patenghai  
\q2 ramlouk e tami lah ka o.   
\q1
\v 9 Na im hanlah pouknae ni na ca teh,  
\q2 na kapathoenaw e lawk teh kai dawk a pha.   
\q1
\v 10 Rawcahai hoi ratoum hringnae dawk doeh na pathoe awh.   
\q1
\v 11 Buri ka khohna toteh, na panuikhai awh.   
\q1
\v 12 Longkha koe katahungnaw ni ka kong a dei awh teh,  
\q2 yamuhrinaw ni la lah na sak awh.   
\q1
\v 13 Hatei, kai hanelah teh ka ratoumnae heh nang koe doeh.  
\q2 Oe BAWIPA, ngai kaawm e tueng dawk Oe Cathut,  
\q2 na lungmanae apap e patetlah,  
\q2 na rungngangnae lawkkatang hoi ka lawk heh na thai pouh haw.   
\q1
\v 14 Kai hah tangdong dawk hoi na rasat haw, na bawt sak hanh.  
\q2 Na kahmuhmanaw kut dawk hoi thoseh,  
\q2 tui kadung thung hoi thoseh, na hlout sak haw.   
\q1
\v 15 Tui kalen ni na muem teh, tui kadung ni na payawp hanh naseh.  
\q2 Tangkom kadung ni na pakhum hanh naseh.   
\q1
\v 16 Oe BAWIPA na thai pouh haw.  
\q2 Bangkongtetpawiteh, na lungpatawnae teh ahawi.  
\q2 Lungmanae kapap hoi kai koe lah kamlang haw.   
\q1
\v 17 Na san koehoi na minhmai hrawk hanh.  
\q2 Bangkongtetpawiteh, runae koe ka pha toe.  
\q2 Karang poung lah na thai pouh haw.   
\q1
\v 18 Ka hringnae koe hnai nateh, na ratang haw.  
\q2 Ka tarannaw ao dawkvah, na rungngang haw.   
\q1
\v 19 Kayanae, yeiraiponae hoi na barihoehnae teh na panue.  
\q2 Ka taran pueng teh na hmalah koung ao.   
\q1
\v 20 Pathoenae ni ka lung a pout sak teh a lungpuen sak.  
\q2 Na kapahrenkung ka tawng teh buet touh hai ka hmawt hoeh.  
\q2 Lungpahawikung ka tawng teh buet touh hai ka hmawt hoeh.   
\q1
\v 21 Ka rawca lah kakhat e na poe awh teh,  
\q2 tui kahran toteh misurtui kathut e hah na poe awh.   
\q1
\v 22 Ahnimae caboi teh amamouh hanelah karap lah thoseh,  
\q2 tangkhek lah thoseh, a kang hanelah thoseh, coung awh naseh.   
\q1
\v 23 A hmu thai awh hoeh nahanlah a mitmawm naseh.  
\q2 A laheibaw thouk pâyaw naseh.   
\q1
\v 24 Na lungkhueknae hah ahnimouh lathueng awi nateh,  
\q2 na lungphuennae ni rekpatawt naseh.   
\q1
\v 25 Ahnimouh khosaknae hmuen teh kingkadi lah awm naseh,  
\q2 ahnimae im dawk apihai awm hanh naseh.   
\q1
\v 26 Bangkongtetpawiteh, na rek e hah a rektap awh teh,  
\q2 hmâ na ca sak e naw hah, rek a panai awh.   
\q1
\v 27 ahnimae yon dawk yon rek poe nateh,  
\q2 na lannae dawk kâen hanh naseh.   
\q1
\v 28 Hringnae cauk dawk hoi raphoe lah awm awh naseh.  
\q2 Tamikalannaw hoi rei thut lah awm hanh naseh.   
\q1
\v 29 Hateiteh kai teh mathoe hoi lung ka mathout e lah ka o.  
\q2 Oe Cathut, na rungngangnae ni a rasangnae koe na tat naseh.   
\q1
\v 30 Cathut min teh la hoi ka pholen han.  
\q2 Lunghawilawkdeinae hoi ama teh ka tawm han.   
\q1
\v 31 BAWIPA ni ki hoi khoksamen hoi kaawm e maitotan a ngai e hlak,  
\q2 hote hringnuen hah a ngaihnawn.   
\q1
\v 32 Ka kârahnoumnaw ni hetheh a hmu awh vaiteh, a lunghawi awh han.  
\q2 Nangmouh Cathut katawngnaw e lung teh thaonae hoi akawi han.   
\q1
\v 33 Bangkongtetpawiteh, ka mathoenaw e lawk hah a thai pouh teh,  
\q2 thongim ka bawt e amae taminaw hah pacekpahlek hoeh.   
\q1
\v 34 Talai hoi kalvan ni ama teh a pholen teh,  
\q2 talîpui hoi a thung kaawm e pueng ni, ama teh, pholen naseh.   
\q1
\v 35 Cathut ni Zion a rungngang teh,  
\q2 Judah kho hah a kangdue sak teh,  
\q2 Ahnimouh ni ao awh teh a pang awh.   
\q1
\v 36 A san catounnaw ni hai pang awh vaiteh,  
\q2 a min ka lungpataw e teh athung vah kho a sak awh han.   
\c 70  
\s1 Katarankung koehoi hlout nahanlah ratoumnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe Cathut, kai rungngang hanlah karanglah kâroe haw.  
\q2 Kai kabawp hanlah karanglah kâroe haw.   
\q1
\v 2 Kai thei hanlah kakâcainaw teh  
\q2 kayayeirai po laihoi awm awh naseh,  
\q2 runae poe hanlah kakâcainaw heh  
\q2 yawng awh naseh.   
\q1
\v 3 Vehveh, na katetsinnaw teh  
\q2 kaya laihoi yawng awh naseh.   
\q1
\v 4 Nang na ka tawng pueng teh,  
\q2 nang dawk lunghawi thahmeica lah awm awh naseh.  
\q2 Na rungngangnae ka lungpataw naw ni pout laipalah,  
\q2 Cathut teh pholen lah awm seh, telah tet awh naseh.   
\q1
\v 5 Hatei, kai teh tami ka mathoe hoi ka voutthoup e lah ka o.  
\q2 Oe, Cathut, karang na pâtam leih.  
\q2 Nang teh ka rungngangkung hoi kabawmkung doeh.  
\q2 Oe BAWIPA ngailawi awm hanh leih.   
\c 71  
\s1 Rungngangnae lungsong Cathut  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 Oe BAWIPA, nang doeh na kâuep.  
\q2 Kaya hoi na awm sak hanh.   
\q1
\v 2 Na lannae hoi na rungngang nateh, na hlout sak haw.  
\q2 Kai koe lah na hnâpakeng nateh na rungngang haw.   
\q1
\v 3 Kai ni pou ka pâtam teh ka onae lungsong lah awm haw.  
\q2 Kai rungngang hanelah kâ na poe teh,  
\q2 kaie lungsong, kaie rapan lah na o.   
\q1
\v 4 Oe ka Cathut, tamikathout kut dawk hoi thoseh,  
\q2 tamikalanhoehe hoi tamitongthoe kut dawk hoi thoseh,  
\q2 na rungngang haw.   
\q1
\v 5 Bangkongtetpawiteh, oe Bawipa Jehovah,  
\q2 nang teh ka camo nahoi na kâuep e lah na o.   
\q1
\v 6 Pek ka khe hoi na kuet teh,  
\q2 nang teh anu von thung hoi na ka lat e lah na o.  
\q2 Nang teh pou na pholen han.   
\q1
\v 7 Tami moikapap kângai karusakkung lah ka o.  
\q2 Hatei, nang teh kacake kânguenae doeh.   
\q1
\v 8 Ka pahni teh nang pholennae hoi akawi teh,  
\q2 hnintangkuem nange pholennae hoi kawi naseh.   
\q1
\v 9 Ka matawng toteh na hnoun hanh lah a.  
\q2 Ka tha a youn toteh na cettakhai hanh lah a.   
\q1
\v 10 Bangkongtetpawiteh, ka tarannaw ni na pathoe awh.  
\q2 Kai thei han a ngai awh dawkvah, pouknae a kâpoe awh teh, na pawp awh.   
\q1
\v 11 Cathut ni a ceitakhai toe.  
\q2 Pâlei awh nateh man awh.  
\q2 Bangkongtetpawiteh, ka rungngang hane awm hoeh telah ati awh.   
\q1
\v 12 Oe Cathut, na hlat takhai hanh.  
\q2 Oe ka Cathut, karanglah na kabawm haw.   
\q1
\v 13 Ka hringnae ka tarannaw hah kayayeirai hoi rawknae koe phat awh naseh.  
\q2 Runae poe hanlah kakâcainaw hah pahuipalamnae hoi  
\q2 yeiraiponae ni ramuk awh naseh.   
\q1
\v 14 Hatei, pou ka ngaihawi vaiteh,  
\q2 hoehoe ka pholen han.   
\q1
\v 15 Ka pahni ni na lannae a dei vaiteh,  
\q2 na rungngangnae heh hnintangkuem a hramkhai han.  
\q2 Bangkongtetpawiteh, a lungmanae parei teh baw thai hoeh.   
\q1
\v 16 Bawipa Jehovah, thaonae dawk ka cei han.  
\q2 Na lannae nange lannae dueng doeh ka dei han.   
\q1
\v 17 Oe Cathut, ka camo nah hoi na cangkhai toe,  
\q2 Atu totouh kângairu hno na sak e hah ka pâpho.   
\q1
\v 18 Sekatha taminaw hoi ka tâcawt hane naw koe na thaonae hoi  
\q2 na hnotithainae ka pâpho hoeh roukrak,  
\q2 ka matawng teh ka sam a po toteh, Oe Cathut na cettakhai hanh.   
\q1
\v 19 Oe Cathut, na lannae hai a rasang poung.  
\q2 Oe Cathut, hnokalen kasakkung, nang patetlah  
\q2 apimouh ouk kaawm va.   
\q1
\v 20 Kalen ni teh ka patawpoung e runae  
\q2 na kâhmosakkung nang ni na roung sak nateh,  
\q2 kadung poung e talai thung hoi bout na rasat haw.   
\q1
\v 21 Ka tawntanae na pung sak vaiteh,  
\q2 lung bout na pahawi han.   
\q1
\v 22 Tamawi hoi na pholen han.  
\q2 Oe Cathut, yuemkamcu lah na onae hah ka pholen han.  
\q2 Oe Isarel e Kathoung Cathut,  
\q2 ratoung hoi la sak laihoi na pholen han.   
\q1
\v 23 Nang pholen laihoi la ka sak toteh,  
\q2 ka pahni teh a lunghawi katang han.  
\q2 Na ratang e ka hringnae hai a lunghawi han.   
\q1
\v 24 Ka lai ni hai kanîruirui pout laipalah na lannae a dei han.  
\q2 Bangkongtetpawiteh, runae poe hanlah kakâcainaw hah  
\q2 lungpout laihoi yeiraipo sak lah ao toe.   
\c 72  
\s1 Messiah uknae Bawilennae hoi lentoenae  
\d Kathutkung: Solomon  
\q1
\v 1 Oe Cathut, na lawkcengnae heh siangpahrang poe nateh,  
\q2 na lannae hah siangpahrang capanaw hanelah hrueng pouh haw.   
\q1
\v 2 Ahni ni na taminaw hah lannae hoi lawkceng vaiteh,  
\q2 nange karoedengnaw hah   
\q1
\v 3 Monnaw ni tamimaya koe roumnae poe vaiteh,  
\q2 monruicanaw ni lannae hah na poe awh han.   
\q1
\v 4 Ama ni ka mathoe e tamimaya koe kângingnae thokhai vaiteh,  
\q2 ka voutthoup e catounnaw hah rungngang vaiteh,  
\q2 rep kacuengroenaw hah a rek awh han.   
\q1
\v 5 Kanî hoi thapa a kangning roukrak,  
\q2 tami kâkuen e pueng ni nang teh na taki awh han.   
\q1
\v 6 Ama teh pho kahring va hoehnahlan e kho ka rak e patetlah thoseh,  
\q2 talai kakawkkung kho a rak e patetlah thoseh a kum han.   
\q1
\v 7 Ama se nah teh, tamikalannaw kâroe vaiteh,  
\q2 thapa ao roukrak teh, lungkuep roumnae ao han.   
\q1
\v 8 Ama ni talîpui avanglah hoi avanglah totouh,  
\q2 talîpui koehoi talai pout totouh a uk han.   
\q1
\v 9 Kahrawngum vah kho kasaknaw ni  
\q2 a hmalah tabawk awh vaiteh,  
\q2 a tarannaw ni vaiphu hah a palem awh han.   
\q1
\v 10 Tarshish ram hoi tuilum siangpahrangnaw ni,  
\q2 hno poe hane sin awh vaiteh,  
\q2 Sheba hoi Seba siangpahrangnaw ni hai  
\q2 poehnonaw hah a poe awh han.   
\q1
\v 11 Bokheiyah, siangpahrangnaw pueng,  
\q2 a hmalah tabawk awh vaiteh,  
\q2 miphun pueng ni a thaw a tawk awh han.   
\q1
\v 12 Bangkongtetpawiteh, kavoutthoupnaw a hram awh toteh, a rungngang han.  
\q2 Mathoenaw hoi kabawmkung ka tawn hoeh naw hai a kabawp han.   
\q1
\v 13 Mathoe hoi voutthoup naw hah pahren vaiteh,  
\q2 voutthoup hringnae hah a rungngang han.   
\q1
\v 14 Repcoungroenae hoi kaisuenae thung hoi  
\q2 a hringnae ratang vaiteh,  
\q2 a thipaling teh a mithmu vah ka sungren poung e lah ao han.   
\q1
\v 15 Ama teh a hring vaiteh, Sheba sui hah ama koe poe lah ao han.  
\q2 Ratoumnae hai ama koe pou poe lah awm vaiteh,  
\q2 hnintangkuem pholen lah ao han.   
\q1
\v 16 Ram dawk cakang moi awm vaiteh,  
\q2 monsom e a pawhiknaw hah Lebanon patetlah kâhuen vaiteh,  
\q2 khothung e taminaw teh,  
\q2 talai phokahring patetlah a kâhuet awh han.   
\q1
\v 17 A min teh a yungyoe roum mahoeh toe.  
\q2 Kanî a ang roukrak a min ao yungyoe han.  
\q2 Ama dawk ayânaw ni yawhawi hmawt awh vaiteh,  
\q2 miphun pueng ni tami yaw kahawi e ati awh han.   
\q1
\v 18 BAWIPA Cathut, Isarel Cathut,  
\q2 kângairu hno kasakkung dueng pholen lah awm lawiseh.   
\q1
\v 19 A min sungren teh a yungyoe pholen lah awm naseh.  
\q2 Talai abuemlah a sungrennae hoi  
\q2 kawi lawiseh. Amen hoi Amen.   
\q1
\v 20 Jesi Capa Devit ratoumnae a pout toe.   
\c 73  
\s1 Tamikathout poutnae hoi BAWIPA kâuep yawhawinae  
\d Kathutkung: Asaph  
\q1
\v 1 Cathut teh Isarel hane hoi lungthin  
\q2 kathoungnaw hanelah ahawi tangngak.   
\q1
\v 2 Hatei, kai raitat meimei ka rawp teh,  
\q2 meimei ka thawn toe.   
\q1
\v 3 Bangkongtetpawiteh, tamikathoutnaw e  
\q2 yawhawi ka hmu navah, kakaisuenaw hah ka ut toe.   
\q1
\v 4 Ahnimouh teh a due awh hoehroukrak  
\q2 patawnae khang awh hoeh, a tha pou ao awh.   
\q1
\v 5 Ayânaw patetlah runae dawk awm awh hoeh,  
\q2 ayânaw patetlah kuekluek pataw awh hoeh.   
\q1
\v 6 Hatdawkvah, kâoupnae teh awi lah a awi awh teh,  
\q2 rektapnae khohna hah a khohna awh.   
\q1
\v 7 A thâw awh lawi vah, a mitkatueng awh.  
\q2 A pouk awh e hlak ka paphnawn a tawn awh.   
\q1
\v 8 Repcoungroenae hah a panuikhai awh teh,  
\q2 kâoupnae lawk a dei awh.   
\q1
\v 9 A lawk dei e ni kalvan totouh a taran teh,  
\q2 a lai ni talai pueng a katin.   
\q1
\v 10 Hatdawkvah, a taminaw teh ahnimouh koe a ban awh teh,  
\q2 tui moikapap e hah koung a nei awh.   
\q1
\v 11 Bangtelah hoi maw Cathut ni a panue.  
\q2 Lathueng Poung dawk panuenae ao maw telah ati awh.   
\q1
\v 12 Khenhaw! hetnaw heh Cathut ka bari hoeh e,  
\q2 banghai pouk laipalah ka hring e lah ao awh teh,  
\q2 hoehoe a tawnta awh.   
\q1
\v 13 Ka lungthin kathoung sak nakunghai,  
\q2 atangcalah cungkeihoeh.  
\q2 Yon thuengnae lahoi ka kut ka pâsu nakunghai cungkeihoeh.   
\q1
\v 14 Hnin tangkuem tarawknae hoi  
\q2 amom karoitawi yuenae doeh ka khang.   
\q1
\v 15 Hottelah ka dei han ka tet pawiteh,  
\q2 khenhaw! na catounnaw koe torei teh,  
\q2 tamikalan hoeh lah kaawm han.   
\q1
\v 16 Hetheh, thaipanuek nahanelah ka pouk torei teh,  
\q2 hothateh kai hanelah ka pataw katang e lah ao.   
\q1
\v 17 Cathut hmuen kathoung koe kâen toteh,  
\q2 ahnimouh poutnae heh ka thaipanuek katang toe.   
\q1
\v 18 Ahnimouh teh pâhnannae koe na ta teh,  
\q2 rawkphainae hmuen koe na tâkhawng.   
\q1
\v 19 Oe, bangtelah, tawkkadek dawk rawknae koe louk a pha awh vaw.  
\q2 Takitho e ni koung louk a ca awh vaw.   
\q1
\v 20 Kâhlaw toteh, karum mang patetlah,  
\q2 Bawipa na pâhlaw toteh,  
\q2 ahnimae meikaphawk hah na pacekpahlek pouh han.   
\q1
\v 21 Hot patetlah ka lungthin a pataw teh,  
\q2 ka pouknae hai a ru.   
\q1
\v 22 Panuenae ka tawn hoeh e hoi tamipathu lah ka o teh,  
\q2 na hmalah saring patetlah doeh ka o.   
\q1
\v 23 Hatei nakunghai, nang koe pou ka o teh,  
\q2 aranglae kut dawk na kuet pouh.   
\q1
\v 24 Na mae kâpankhainae lahoi lam na hrawi teh,  
\q2 hathnukkhu bawilennae hah na coe pouh.   
\q1
\v 25 Kalvan vah nang laipalah apimouh ka tawn.  
\q2 Talaivan hai nang laipalah,  
\q2 ka ngai e alouke awm hoeh toe.   
\q1
\v 26 Ka takthai hoi ka lungthin teh a tâwn.  
\q2 Hatei, Cathut teh, a yungyoe hoi  
\q2 ka lungthin thaonae hoi ham lah ao.   
\q1
\v 27 Bangkongtetpawiteh, nang hoi kâhlat e teh,  
\q2 kahmat awh roeroe han doeh.  
\q2 Nang koe kâyawt e pueng teh raphoe lah ao han.   
\q1
\v 28 Hateiteh, kai hanelah teh Cathut hnai e heh ahawi.  
\q2 Na sak e hno pueng heh ka kamnue sak thai nahanlah,  
\q2 Bawipa Jehovah dawk doeh ka kâuep toe.   
\c 74  
\s1 Repcoungroenae koehoi hlout nahanlah kâheinae  
\d Kathutkung: Asaph  
\q1
\v 1 Oe Cathut bangkongmaw na pahnawt vaw.  
\q2 Bangkongmaw na saring a pânae koe e na tuhunaw  
\q2 taranlahoi na lungkhueknae hmaikhu a pâyam rah bo vaw.   
\q1
\v 2 Kamkhueng e tamimaya, yampa na ran e,  
\q2 râw lah na pang e miphun,  
\q2 na ratang e naw heh pahnim hanh.   
\q1
\v 3 Raphoe tangcoung e hmuen koe tho haw.  
\q2 Hmuen kathoung dawk e hno pueng hah  
\q2 taran ni koung a raphoe toe.   
\q1
\v 4 Na taminaw a kamkhuengnae hmuen koe,  
\q2 na tarannaw teh a hramki awh teh,  
\q2 mitnoutnaw hah a vo awh.   
\q1
\v 5 Ratu thing ka tâtueng hane patetlah,  
\q2 cakânaw teh a palik awh.   
\q1
\v 6 Dongdengca dawk bawkim hnonaw hah  
\q2 amamae cakâ, cakkinnaw hoi a raphoe awh.   
\q1
\v 7 Thoungnae hmuen hah hmai a sawi awh teh,  
\q2 na min onae hmuen hah a khin sak awh toe.   
\q1
\v 8 Koung raphoe awh sei ati awh teh,  
\q2 ram thung e Cathut bawknae hmuen pueng hah hmai koung a sawi awh.   
\q1
\v 9 Kaimouh teh mae mitnoutnae ka hmawt awh hoeh toe.  
\q2 Profet hai awm hoeh toe.  
\q2 Bangkong han nama aw,  
\q2 telah kapanuekkung kaimouh koe awm hoeh toe.   
\q1
\v 10 Oe Cathut, bangkongmaw na tarannaw ni na pathoe han.  
\q2 Taran ni na min pou a pacekpahlek han na maw.   
\q1
\v 11 Bangkongmaw na kut aranglae hah na dâw hoeh vaw.  
\q2 Bout dâw nateh, ahnimanaw hah koung raphoe haw.   
\q1
\v 12 Bangtelah tetpawiteh, Cathut teh ayan hoi talai taminaw koe  
\q2 rungngangnae kasakkung kaie Siangpahrang doeh.   
\q1
\v 13 Na thaonae lahoi talîpui hah na kapek teh,  
\q2 tui thung tuitamnaw e lû hah na khoe pouh.   
\q1
\v 14 Leviathan lû hah koung na khoe pouh teh,  
\q2 kahrawng kaawmnaw ni ca hanelah na poe.   
\q1
\v 15 Tuikhu hoi palangnaw hah na palang pouh teh,  
\q2 palangpuinaw hah na hak sak.   
\q1
\v 16 Khodai hoi karum hai nange doeh  
\q2 Kanî hoi angnae hah na sak toe.   
\q1
\v 17 Talai khori pueng hai thoseh,  
\q2 kompawi hoi kasik pueng hai thoseh na sak toe.   
\q1
\v 18 Oe BAWIPA, taran ni na pathoe e hoi  
\q2 tamipathunaw ni na min a pacekpahlek e hah pahnim hanh.   
\q1
\v 19 Oe, na bakhu hringnae heh sarang koe poe hanh.  
\q2 Ka mathoe e na taminaw e hringnae heh  
\q2 a yungyoe pahnim hanh.   
\q1
\v 20 Lawkkam hah bari haw. Bangkongtetpawiteh,  
\q2 talai a hmonae hmuennaw hah rektap lawpnae hoi akawi.   
\q1
\v 21 Oe, repcoungroe e naw heh,  
\q2 kaya laihoi ban sak hanh.  
\q2 Mathoe hoi a reikathainaw ni na min pholen naseh.   
\q1
\v 22 Oe Cathut, thaw nateh, na kong hah kangdoutkhai haw.  
\q2 Tamipathu ni hnintangkuem  
\q2 na pathoe e hah pahnim hanh.   
\q1
\v 23 Na tarannaw lawk heh pahnim hanh.  
\q2 Nang na ka tarannaw e ruengruengtinae lawk teh  
\q2 hoehoe a kampaw e hah pahnim hanh.   
\c 75  
\s1 Kalan Cathut lawkcengnae lunghawi lawk dei ratoumnae  
\d Kathutkung: Asaph  
\q1
\v 1 Oe Cathut, nang koe lunghawi lawk ka dei, lunghawi lawk ka dei.  
\q2 Bangkongtetpawiteh, na sak e kângairu hnonaw ni  
\q2 na min a hnainae a kamnue sak.   
\q1
\v 2 Kâdawk e tueng a pha toteh,  
\q2 kânging lah lawk na ceng han.   
\q1
\v 3 Talai hoi a thung kaawm e naw pueng raphoe lah ao teh,  
\q2 a khom hah kacaklah a ung. Selah.   
\q1
\v 4 Mithmaikhet e naw koevah, minhmai khen hanh awh.  
\q2 Tamikathoutnaw koe na ki hno hanh.   
\q1
\v 5 Na ki teh a lathueng lah saw sak hanh awh.  
\q2 Lahuen pata lahoi lawk dei hanh awh telah ka ti.   
\q1
\v 6 Bangkongtetpawiteh, tawmnae teh kanîtho,  
\q2 kanîloum, akalah hoi tho hoeh.   
\q1
\v 7 Hateiteh, Cathut teh lawkcengkung doeh.  
\q2 Buet touh a rahnoum sak teh alouke a rasang sak.   
\q1
\v 8 Bangkongtetpawiteh, Cathut kut dawk manang ao teh,  
\q2 misurtui teh a paling.  
\q2 Koung kalawt hnukkhu a rabawk.  
\q2 A laheipadin totouh talai van e tamikayonnaw ni  
\q2 koung a nei awh han.   
\q1
\v 9 Hateiteh, Jakop Cathut teh, ka pholen han,  
\q2 a yungyoe ka pholen han.   
\q1
\v 10 Tamikayon e ki pueng teh,  
\q2 koung ka tâtueng han.  
\q2 Hateiteh, tamikalan e ki teh,  
\q2 tawm lah ao han.   
\c 76  
\s1 Lawkcengnae koe Cathut lentoenae  
\d Kathutkung: Asaph  
\q1
\v 1 Judah vah Cathut panue lah ao teh,  
\q2 Isarel vah a min teh a lentoe.   
\q1
\v 2 Salem haiyah lukkareiim ao teh,  
\q2 Zion vah a onae hmuen ao.   
\q1
\v 3 Hawvah, licung pala, tarantuknae,  
\q2 bahling hoi tahloinaw hah  
\q2 a khoe awh. Selah.   
\q1
\v 4 Nang teh, tarantuknae monnaw hlak  
\q2 na sungren teh na hawihnawn.   
\q1
\v 5 A tarankahawinaw lawp lah ao teh,  
\q2 mat a i awh toe.  
\q2 Tami a tha kaawm apinihai a kut dâw thai awh hoeh.   
\q1
\v 6 Oe Jakop Cathut, na yuenae dawk hoi  
\q2 marang hoi ranglengnaw teh kadout e patetlah  
\q2 koung a rawp awh.   
\q1
\v 7 Nang teh taki na tho doeh.  
\q2 Na lungkhuek pawiteh, na hmalah  
\q2 apimouh kangdout thai han.   
\q1
\v 8 Talai vah repcoungroe e naw rungngang teh  
\q2 lawkceng hanelah Cathut a kangdue toteh,   
\q1
\v 9 Na lawkcengnae lawk hah kalvan hoi na patoun teh,  
\q2 talai teh taki laihoi duem ao. Selah.   
\q1
\v 10 Taminaw e lungkhueknae ni na pholen roeroe han.  
\q2 Ka cawi e lungkhueknae hai na keng dawk na kâyeng han.   
\q1
\v 11 BAWIPA na Cathut koevah,  
\q2 lawkkam awh nateh, kuep sak awh.  
\q2 Atengpam kaawm e pueng ni,  
\q2 taki hanelah kaawm e koevah, poehno hah poe awh.   
\q1
\v 12 Ama ni lawkcengkungnaw e lung hah, a rahnoum sak han.  
\q2 Talai siangpahrangnaw hanelah takikatho poung e lah ao.   
\c 77  
\s1 Cathut ratangnae panuenae dawk lungpahawinae  
\d Kathutkung: Asaph  
\q1
\v 1 Ka lawk hoi Cathut koe ka hram.  
\q2 Ka lawk roeroe hoi Cathut koe ka hram teh,  
\q2 ama ni na thai pouh.   
\q1
\v 2 Runae kâhmo navah Bawipa teh ka kaw.  
\q2 Karum vah ka kut hah pou ka dâw teh,  
\q2 ka hringnae ni duem awm ngai hoeh.   
\q1
\v 3 Cathut ka pouk teh ka cingou.  
\q2 Luepluep ka pouk teh,  
\q2 ka muitha ngawt a tâwn. Selah.   
\q1
\v 4 Ka mit pou na padai sak teh,  
\q2 pou ka kâroe dawkvah, lawk ka dei thai hoeh.   
\q1
\v 5 Yampa e hninnaw hoi  
\q2 ayan e kumnaw hah ouk ka pouk.   
\q1
\v 6 Karum vah lanaw hah pahnim hoeh nahanlah ka pouk teh,  
\q2 ka lungthung hoi ouk ka pouk.  
\q2 Ka muitha ni hai atangcalah a tawng.   
\q1
\v 7 Bawipa ni pou na pahnim han na maw.  
\q2 Lunghawi laipalah maw ao han aw.   
\q1
\v 8 A lungmanae teh ka pout han na maw.  
\q2 A lawkkam hai kuep laipalah maw pou ao han toung.   
\q1
\v 9 Cathut ni pahrennae a pahnim han na maw.  
\q2 Lungkhuek laihoi a ngai e lungmanae hah a khan toe khe.   
\q1
\v 10 Hete ni ka lung a pataw sak.  
\q2 Hatei, Lathueng Poung aranglae kut  
\q2 a kamnue lahunnae kum hah ka pahnim mahoeh ka ti.   
\q1
\v 11 BAWIPA ni ayan e kângairu hno a sak e naw hah  
\q2 ka pahnim mahoeh.   
\q1
\v 12 Na sak e naw puenghai ka pouk teh,  
\q2 na tawk e hah ka dei han.   
\q1
\v 13 Oe Cathut, na lam teh hmuen kathoung koe ao.  
\q2 Ka Cathut patetlah ka lentoe e Cathut teh apimaw .   
\q1
\v 14 Nang teh, kângairu hno ka sak e Cathut doeh.  
\q2 Tamimaya koe na thaonae hah na kamnue sak.   
\q1
\v 15 Na taminaw hoi Jakop hoi Joseph catounnaw hah  
\q2 na kut hoi na ratang. Selah.   
\q1
\v 16 Oe Cathut, tuinaw ni na hmu.  
\q2 Tuinaw ni na hmu awh teh, na taki awh.  
\q2 Kadung poung e tui hai a kâhuet.   
\q1
\v 17 Tâmainaw ni tui a rabawk awh teh,  
\q2 kalvannaw a cairing teh,  
\q2 na palanaw teh avoivang lah a yawng awh.   
\q1
\v 18 Na khoparit lawk teh, bongparui dawk ao teh,  
\q2 sumpapalik ni talai pheng a ang sak.  
\q2 Talai teh a kâhuet teh a pâyaw.   
\q1
\v 19 Na lam teh talîpui dawk ao teh,  
\q2 na lamthung teh kakaw e tui dawk ao teh,  
\q2 na khokhnuk teh panue e lah awm hoeh.   
\q1
\v 20 Mosi hoi Aron kut hoi na taminaw hah  
\q2 tuhu patetlah na hrawi.   
\c 78  
\s1 Isarel taranthawnae koe Cathut lungmanae  
\d Kathutkung: Asaph  
\q1
\v 1 Oe, ka taminaw ka kâlawk hah tarawi awh nateh,  
\q2 ka dei e lawk hah na hnâpakeng awh.   
\q1
\v 2 Bangnuenae lahoi ka pahni ka ang vaiteh,  
\q2 ayan e lawkkaru hah ka pâpho han.   
\q1
\v 3 Hothateh, ka thai teh, ka panue tangcoung e  
\q2 mintoenaw ni a dei awh e doeh.   
\q1
\v 4 A canaw koehoi kâhrawk mahoeh.  
\q2 Ka tho hane senaw koevah,  
\q2 BAWIPA pholennae, a thaonae,  
\q2 hoi hno kângairu a sak e hah ka dei han.   
\q1
\v 5 Bangtelah tetpawiteh, mintoenaw hah kâ a poe teh,  
\q2 a ca catounnaw koe a panue sak awh nahanlah,  
\q2 Jakop koe lawkpanuesaknae hah acak sak teh,  
\q2 Isarel koe kâlawk hah a poe.   
\q1
\v 6 Kaawm han rae se hoi ka tâcawt han rae camonaw ni,  
\q2 a catounnaw koe a dei awh vaiteh,  
\q2 a panue awh nahanlah,   
\q1
\v 7 Cathut dawk a ngaihawi awh nahan hoi  
\q2 Cathut hnosak hah pahnim laipalah  
\q2 kâpoelawknaw a pahnim awh hoeh nahanlah,   
\q1
\v 8 Mintoenaw patetlah lungpatanae,  
\q2 taranthawnae, kalan e hno dawk a lung kaawm hoeh e,  
\q2 Cathut hanelah yuemkamcu hoeh e muitha lah ao awh hoeh nahane doeh.   
\q1
\v 9 Ephraim catoun teh tarantuknae a khohna teh licung a patuep ei,  
\q2 tarantuk hnin navah a yawng.   
\q1
\v 10 Cathut lawkkam tarawi awh hoeh.  
\q2 Kâlawk tarawi e ngai awh hoeh.   
\q1
\v 11 A sak e hoi hno kângairu a sak e hah,  
\q2 a pahnim awh.   
\q1
\v 12 A na mintoenaw e mithmu vah,  
\q2 kângairu hno hah Izip ram  
\q2 Zoan tanghling dawk a sak.   
\q1
\v 13 Talîpui hah a kapek teh ahnimanaw hah a cei sak.  
\q2 Tui hah hnopai patetlah a pâhlawp.   
\q1
\v 14 Kanîthun hai tâmai hoi a hrawi teh,  
\q2 tangmin karoitawi hmaiang hoi a hrawi.   
\q1
\v 15 Kahrawngum vah, lungsong a bawng teh,  
\q2 talîpui tui patetlah moikapap e tui a pânei.   
\q1
\v 16 Lungsong thung hoi tui a tâco sak teh,  
\q2 palangpui patetlah a lawng sak.   
\q1
\v 17 Hatei, ama taranlahoi hoehoe a yon awh teh,  
\q2 kahrawngum vah Lathueng Poung taranlahoi taran a thaw awh.   
\q1
\v 18 Ca han a ngai poung awh e hah a hei awh teh,  
\q2 a lungthin hoi Cathut hah a tanouk awh.   
\q1
\v 19 Bokheiyah, Cathut taranlahoi a dei awh e teh,  
\q2 kahrawngum vah Cathut ni  
\q2 rawca na poe thai awh han na maw, telah ati awh.   
\q1
\v 20 Khenhaw! tui a tâco teh,  
\q2 tuiko muen ka kawi lah a lawng nahan lah  
\q2 lungsongpui hah a hem.  
\q2 Rawca hai a poe thai namaw.  
\q2 A taminaw hah moi a poe thai han na ou, telah ati awh.   
\q1
\v 21 Hatdawkvah, BAWIPA ni hote lawk hah a thai teh a lungkhuek.  
\q2 Hat toteh, Jakop taranlahoi hmaito a tâco teh,  
\q2 Isarel taranlahoi a lungkhuek.   
\q1
\v 22 Bangkongtetpawiteh, Cathut hah yuem awh hoeh.  
\q2 A rungngangnae hai kâuep awh hoeh.   
\q1
\v 23 Hottelah nahlangva, lathueng lae tâmai hah kâ a poe teh,  
\q2 kalvan longkha hah a paawng pouh.   
\q1
\v 24 Ca hane mana hah ahnimouh lathueng a rak sak teh,  
\q2 kalvanlae rawca hah a poe.   
\q1
\v 25 Taminaw ni thaonae  
\q2 rawca hah a ca awh teh,  
\q2 kaboumlah ca hane a patawn.   
\q1
\v 26 Kanîtholae kahlî hah kalvan a tho sak teh,  
\q2 a hnotithainae lahoi a cum lae kahlî hah a tho sak.   
\q1
\v 27 Vaiphu patetlah moi hah a rak sak teh,  
\q2 rathei ka tawn e tavanaw hah tuirai e  
\q2 sadi yit touh apap awh.   
\q1
\v 28 A roenae tengpam  
\q2 petkâkalup lah a bo pouh.   
\q1
\v 29 Hateh, a ca awh teh king a boum awh.  
\q2 Bangkongtetpawiteh, a ngai awh e patetlah a poe.   
\q1
\v 30 Hatei, a ngai awh e rawca a hmawt awh hoehnahlan,  
\q2 a ca awh lahun navah,   
\q1
\v 31 Cathut lungkhueknae teh ahnimouh koe a pha.  
\q2 A tami tha kaawmnaw hah a thei teh,  
\q2 Isarel thoundounnaw hah koung a rawp sak.   
\q1
\v 32 Hottelah nahlangva, hoehoe a yon awh teh,  
\q2 hno kalen a sak awh e hai bout yuem awh hoeh.   
\q1
\v 33 Hatdawkvah, hringyung hnin hah ayawmyin lah a coung sak awh teh,  
\q2 lungpuennae hoi a kum teh a baw sak awh.   
\q1
\v 34 Ahnimanaw hah a thei awh teh,  
\q2 a ma tawng hanelah a ban awh teh,  
\q2 atangcalah Cathut heh a tawng awh.   
\q1
\v 35 Cathut teh amamae lungsongpui doeh tie a panue awh teh,  
\q2 Lathueng Poung Cathut teh na  
\q2 karatangkung doeh tie a panue awh.   
\q1
\v 36 Hateiteh, ama teh a pahni hoi a pholen teh,  
\q2 lai hoi laithoe a dei awh.   
\q1
\v 37 Bangkongtetpawiteh, ahnimae lungthin teh a hmalah lan hoeh,  
\q2 a lawkkam dawk yuemkamcu awh hoeh.   
\q1
\v 38 Hatei, ama teh lungmanae hoi akawi teh,  
\q2 a payonnae heh a ngaithoum teh,  
\q2 koung raphoe hoeh.  
\q2 Bokheiyah, avai moikapap lungkhueknae a roum sak teh,  
\q2 a lungphuennae kaman sak ngai hoeh.   
\q1
\v 39 Bangkongtetpawiteh, takthai lah ao awh teh,  
\q2 bout ban hoeh hanelah, kâha a poe e tie hah pahnim awh hoeh.   
\q1
\v 40 Thingyeiyawn vah vai nâyittouh maw  
\q2 a lungkhuek sak awh teh, ramke vah avai nâyittouh maw  
\q2 a lungmathoe sak awh toe.   
\q1
\v 41 Bokheiyah, atuhoitu Cathut a tanouk awh teh,  
\q2 Isarelnaw e Tami Kathoung hah a taran awh.   
\q1
\v 42 A thaonae pâkuem ngai awh hoeh,  
\q2 a tarannaw koehoi a rungngang ei nakunghai,  
\q2 pâkuem ngai awh hoeh.   
\q1
\v 43 Izip ram hoi Zoan yawn dawk  
\q2 kângairu hno a sak e hoi.   
\q1
\v 44 Ahnimae palang hah thipaling lah a coung sak teh,  
\q2 ahnimae tuikhunaw hai nei thai hoeh hanlah  
\q2 thipaling lah koung a coung sak.   
\q1
\v 45 Ahnimouh ka kei e bitseinaw hoi,  
\q2 ahnimouh karaphoekung ekkanaw hah a tha pouh.   
\q1
\v 46 Ahnimae a pawhiknaw hah,  
\q2 ahri ni ca hanelah a poe teh,  
\q2 a tawksak awh e a pawhik hah samtongnaw a poe pouh.   
\q1
\v 47 Ahnimae misurnaw teh roun ni koung a raphoe pouh teh,  
\q2 thailahei kungnaw hai tadamtui ni koung a thei pouh.   
\q1
\v 48 Ahnimae saringnaw hai roun ni dêi hanelah a poe pouh teh,  
\q2 saringnaw hah kei ni a ka pouh.   
\q1
\v 49 Takitho e a lungkhueknae hah  
\q2 ahnimouh lathueng a rabawk teh,  
\q2 lungkhueknae, lungpoutnae, hoi runae hah  
\q2 ahnimouh koe thoenae kaphawtkung  
\q2 kalvan tami totouh a tha pouh.   
\q1
\v 50 A lungkhueknae hanlah lamthung a sak,  
\q2 a hringnae hah duenae hlak pasai laipalah,  
\q2 lacik mathout hah letlang a poe.   
\q1
\v 51 Izip vah camin pueng hoi Ham e rim  
\q2 a thaonae hmaloe poung e hoi koung a raphoe.   
\q1
\v 52 Hatei, a taminaw teh tu patetlah a hrawi teh,  
\q2 saringnaw patetlah kahrawngum vah a hrawi.   
\q1
\v 53 Karoumcalah a hrawi teh, taki hane banghai awm hoeh.  
\q2 A tarannaw teh talîpui ni koung a ramuk.   
\q1
\v 54 Hahoi, ramri kathoung, aranglae kut hoi a tawn e,  
\q2 mon totouh a hrawi.   
\q1
\v 55 Ahnimae hmalah, alouke miphunnaw hah a pâlei pouh.  
\q2 A pang awh hane râw hah a bangnue pouh teh,  
\q2 alouklouk lah hmuen a poe.   
\q1
\v 56 Hat nahlangva, Lathueng Poung Cathut hah  
\q2 a tanouk awh teh, a lungkhuek sak awh teh,  
\q2 a panuesaknae lawk hah tarawi awh hoeh.   
\q1
\v 57 A na mintoenaw patetlah a kamlang awh teh,  
\q2 yuemkamcu hoeh lah a kâroe awh.  
\q2 Dumyennae licung patetlah a kâkamei awh.   
\q1
\v 58 Bangkongtetpawiteh, ahnimae hmuerasangnaw ni  
\q2 a lungkhuek sak teh,  
\q2 a sak awh e meikaphawknaw ni dipma sinnae a tâco sak.   
\q1
\v 59 Hetheh Cathut ni a thai toteh,  
\q2 puenghoi a lungkhuek teh,  
\q2 Isarel hah puenghoi a panuet.   
\q1
\v 60 Hatdawkvah, taminaw koe a ta e  
\q2 Shiloh rim koe totouh a ceitakhai.   
\q1
\v 61 A thaonae teh san lah a coung sak teh,  
\q2 a lentoenae teh a tarannaw kut dawk a poe.   
\q1
\v 62 A taminaw tahloi a kâhmo sak teh,  
\q2 râw lah a coe e naw koe a lungkhuek.   
\q1
\v 63 A thoundounnaw teh hmai ni a kak awh teh,  
\q2 a tanglanaw ni vâ kâhmo awh hoeh.   
\q1
\v 64 A vaihmanaw teh tahloi hoi a thei awh eiteh,  
\q2 lahmainaw ni khui awh hoeh.   
\q1
\v 65 BAWIPA teh ka ip e patetlah a kâhlaw teh,  
\q2 misurtui kecu dawk ka hram e athakaawme tami patetlah a hram.   
\q1
\v 66 A taran hah a pâlei teh,  
\q2 a yungyoe min mathoenae hah a poe.   
\q1
\v 67 Hothloilah Joseph rim hah a pahnawt teh,  
\q2 Ephraim miphun hah rawi ngai hoeh.   
\q1
\v 68 Ama koehoi Judah miphun,  
\q2 Zion mon ka pahren e heh a rawi.   
\q1
\v 69 A hmuen kathoung hah karasang e patetlah a sak teh,  
\q2 talai patetlah a yungyoe acak sak.   
\q1
\v 70 A san Devit hai a rawi teh  
\q2 tutakha thung hoi a la.   
\q1
\v 71 Tumanu, a canaw ouk a hrawi e patetlah,  
\q2 a tami Jakop hoi a coe e râw Isarelnaw  
\q2 khenyawnkung hanelah a la.   
\q1
\v 72 Hothloilah, a lungthin ahawi e patetlah,  
\q2 a khetyawt teh, a thoumnae kut hoi a hrawi awh.   
\c 79  
\s1 Isarel khuinae hoi ratoumnae  
\d Kathutkung: Asaph  
\q1
\v 1 Oe Cathut, miphun louknaw teh  
\q2 nange râw thung a kâen awh teh,  
\q2 Bawkim kathoung a khin sak awh teh,  
\q2 Jerusalem hah a raphoe awh toe..   
\q1
\v 2 Na sannaw e ro hah kalvan tavanaw  
\q2 rawca lah a poe awh teh,  
\q2 na tami kathoungnaw e moi teh kahrawng sarangnaw a paca awh.   
\q1
\v 3 A thipaling teh Jerusalem vah tui patetlah a rabawk awh teh,  
\q2 kapakawpkung buet touh boehai awm hoeh.   
\q1
\v 4 Imrinaw ni pathoe e lah ka o awh teh,  
\q2 tengpam e naw ni na dudam awh teh na panuikhai awh.   
\q1
\v 5 BAWIPA nâtotouh ne na lungkhuek han vai.  
\q2 Nâtotouh ne na lung roum laipalah, hmai patetlah a kak han vai.   
\q1
\v 6 Nang panue hane ka ngai hoeh e miphun hoi  
\q2 na min ka kaw ngaihoeh e ram koevah,  
\q2 na lungkhueknae hah awi haw.   
\q1
\v 7 Bangkongtetpawiteh, Jakop catoun hah a kâphi awh teh,  
\q2 ahnie hmuen hai a raphoe awh.   
\q1
\v 8 Oe, ayan e payonnae hah kaimouh taran nahanelah pâkuem hanh,  
\q2 na lungmanae ni karang poung lah na kabawm naseh.  
\q2 Bangkongtetpawiteh, puenghoi  
\q2 rahnoum sak lah ka o awh toe.   
\q1
\v 9 Oe rungngangnae Cathut, na kabawm haw.  
\q2 Bangkongtetpawiteh, na min lentoe nahan lah  
\q2 na rungngang haw.  
\q2 Na min kecu dawk ka yonnae hah yonthanae na sak pouh haw.   
\q1
\v 10 Bangkong alouke miphunnaw ni,  
\q2 nâmouh ahnimae Cathut te, ati awh.  
\q2 Na sannaw e thipaling phu moi na pathung e hah  
\q2 ka mithmu vah miphun pueng ni, panuek awh naseh.   
\q1
\v 11 Thongkabawtnaw kâhramnae lawk teh, nang koe phat naseh.  
\q2 Ka lentoe e na hnotithainae patetlah  
\q2 due hanlah a pouk awh e hah, hlout sak haw.   
\q1
\v 12 Oe Jehovah, na min a mathoesaknae hah,  
\q2 ka imrinaw e phai dawk roeroe vah,  
\q2 let sari touh hoi patho haw.   
\q1
\v 13 Hottelah, nang koe ka pawngpa awh e,  
\q2 tuhu lah kaawm e na tami kaimanaw ni nang teh  
\q2 pou na pholen awh vaiteh, pholennae teh,  
\q2 se pueng koe ka pâpho awh han.   
\c 80  
\s1 Isarel ban nahanlah ratoumnae  
\d Kathutkung: Asaph  
\q1
\v 1 Oe Isarel Tukhoumkung, tuhu patetlah  
\q2 Joseph kahrawikung na thai pouh haw.  
\q2 Nang Cherubim koe na kaawm e ang haw.   
\q1
\v 2 Ephraim, Benjamin, hoi Manasseh hmalah  
\q2 na thaonae hah hroecoe nateh,  
\q2 tho nateh, na rungngang haw.   
\q1
\v 3 Oe Cathut, na roung sak haw,  
\q2 na minhmai hah ang sak nateh,  
\q2 rungngang lah ka o awh han.   
\q1
\v 4 Oe ransahu Cathut BAWIPA,  
\q2 na taminaw ratoumnae taranlahoi  
\q2 bangkong na lungkhuek.   
\q1
\v 5 Mitphi rawca hoi na kawk teh,  
\q2 mitphi hah ka boum lah na pânei.   
\q1
\v 6 Imrinaw ni yue hanelah na o sak teh,  
\q2 ka tarannaw ni na panuikhai awh.   
\q1
\v 7 Oe Cathut, na roung sak haw,  
\q2 na minhmai hah ang sak nateh,  
\q2 rungngang lah ka o awh han.  
\q2 Oe ransabawi Cathut na roung sak haw.  
\q2 Na minhmai hah ang sak nateh, rungngang lah ka o han.   
\q1
\v 8 Izip hoi misurkung na la teh,  
\q2 Jentelnaw na pâlei teh na ung.   
\q1
\v 9 Ahni hane hmuen na hmoun pouh.  
\q2 Kadung poung lah tangpha na payang teh  
\q2 ram pueng koung akawi.   
\q1
\v 10 Mon hah a tâhlip hoi a ramuk teh,  
\q2 a kang teh kalen e sidar patetlah ao.   
\q1
\v 11 A kangnaw ni talîpui a pha teh,  
\q2 a dawn teh tuipui koe a pha.   
\q1
\v 12 Lam dawk kacetnaw pueng ni,  
\q2 a paw a khi awh nahanelah,  
\q2 Bangkongmaw tumdumnae rapan hah a raphoe awh.   
\q1
\v 13 Ratu thung e pangan ni a hre teh,  
\q2 kahrawng sarang ni a ca awh.   
\q1
\v 14 Oe ransabawi Cathut, ka kâhei.  
\q2 Bout ban nateh, kalvan hoi hete misurkung hah,  
\q2 khen nateh, ring haw.   
\q1
\v 15 Aranglae kut hoi na ung teh,  
\q2 nang hanlah thao sak e  
\q2 cakang misur patetlah ao han.   
\q1
\v 16 Hmai dawk pâeng lah ao teh, tâtueng lah ao.  
\q2 Mei hoi mei kâhmo lah na yue e hah,  
\q2 khang thai laipalah koung a kahma awh.   
\q1
\v 17 Aranglae kut dawk kaawm e tami,  
\q2 nang hanelah thao sak e tami capa lathueng vah,  
\q2 na kut hah awm lawiseh.   
\q1
\v 18 Hottelah pawiteh, nang koehoi kamlang awh mahoeh.  
\q2 Na hring sak haw, na min ka kaw han.   
\q1
\v 19 Oe Cathut, na roung sak haw,  
\q2 na minhmai hah ang sak nateh,  
\q2 rungngang lah ka o awh han.  
\q2 Oe ransahu Cathut na roung sak haw.  
\q2 Na minhmai hah ang sak nateh, rungngang lah ka o han.   
\c 81  
\s1 Isarel yon pankângai nahanlah kâheinae.  
\d Kathutkung: Asaph  
\q1
\v 1 Maimae thaonae Cathut koe kacaipounglah la sak awh.  
\q2 Jakop Cathut koe konawm laihoi hram awh.   
\q1
\v 2 La sak awh nateh cecak hah khawng awh.  
\q2 A lawk kahawi e ratoung tamawi hah kueng awh.   
\q1
\v 3 Thapa rei hnin, kamhluem hnin,  
\q2 pawi hnin vah mongka ueng awh.   
\q1
\v 4 Bangkongtetpawiteh, hethateh,  
\q2 Isarelnaw hanlah phunglam lah ao teh,  
\q2 Jakop Cathut kâlawk lah ao.   
\q1
\v 5 Hethateh, Izip ram pueng a cei awh teh,  
\q2 thai panuek hoeh e lawk thainae hmuen koevah,  
\q2 lawkpanuesaknae Joseph koe a sak e doeh.   
\q1
\v 6 A loung dawk a hrawm e hnori hah a puen pouh teh,  
\q2 a kut hoi a tawm e a bawm hah a kuem pouh.   
\q1
\v 7 Rucat navah na kaw teh na rungngang awh.  
\q2 khoparitnae hmuen koehoi na pato awh teh,  
\q2 Meribah tui koehoi na tanouk awh. Selah.   
\q1
\v 8 Oe ka taminaw thai awh haw,  
\q2 lawk na thui vai.  
\q2 Oe Isarel ka lawk tarawi awh haw.   
\q1
\v 9 Miphun louk cathut nangmouh koe awm mahoeh.  
\q2 Miphun louk cathut na bawk awh mahoeh.   
\q1
\v 10 Kai teh Cathut Jehovah,  
\q2 Izip ram hoi na kahrawikung doeh.  
\q2 Ka kaw lah na pahni ang awh nateh, ka kawi sak han.   
\q1
\v 11 Hatei, ka taminaw ni ka lawk hah ngai awh hoeh.  
\q2 Isarelnaw ni banglahai na pouk awh hoeh.   
\q1
\v 12 Amamae lungpatanae koe ka poe teh,  
\q2 amamouh ngai patetlah ao awh.   
\q1
\v 13 Oe ka taminaw ni ka lawk hah ngai boilah,  
\q2 Isarel ni ka lamthung dawn haw pawiteh khe.   
\q1
\v 14 A taran tang ka tâ pouh vaiteh,  
\q2 ahnimouh katarankungnaw koe  
\q2 ka kut ka dâw pouh han eite.   
\q1
\v 15 BAWIPA kahmuhmanaw ni  
\q2 a hmalah kâhet awh vaiteh,  
\q2 ka taminaw teh pou a kangning awh han eite.   
\q1
\v 16 Kahawi poung e tavai hoi ka kawk vaiteh,  
\q2 lungsong thung e khoitui hoi a lungkhuekti sak han eite.   
\c 82  
\s1 Lan nahanlah kâheinae  
\d Kathutkung: Asaph  
\q1
\v 1 Cathut teh cathutnaw a kamkhuengnae koe a kangdue teh,  
\q2 cathutnaw lawk a ceng.   
\q1
\v 2 Nâtotouh ne kânging hoeh lah lawk na ceng awh vaiteh,  
\q2 tamikathoutnaw hah na kapek awh han vai. Selah.   
\q1
\v 3 Mathoe hoi naranaw hanlah lawkceng pouh nateh,  
\q2 runae kâhmonaw hoi kavoutnaw hah  
\q2 kânging lah lawkceng awh.   
\q1
\v 4 Mathoe hoi kavoutnaw hah rasat awh nateh,  
\q2 tamikathoutnaw kut dawk hoi tâcawt sak awh,   
\q1
\v 5 Panuek awh hoeh, thai panuek awh hoeh,  
\q2 hmonae koe a kâva awh teh, talaidu pueng teh a kâhuet.   
\q1
\v 6 Nangmouh teh cathutnaw doeh,  
\q2 Lathueng Poung e canaw lah na o awh.   
\q1
\v 7 Hatei, tami patetlah na due han,  
\q2 bawi thung dawk e buet touh patetlah  
\q2 na rawp awh han.   
\q1
\v 8 Oe Cathut thaw haw, talai heh lawkceng haw.  
\q2 Bangkongtetpawiteh,  
\q2 miphun pueng heh râw lah na pang han.   
\c 83  
\s1 Isarel hlout nahanlah ratoumnae  
\d Kathutkung: Asaph  
\q1
\v 1 Oe Cathut, duem awm hanh leih,  
\q2 lawk tho laipalah duem awm hanh.  
\q2 Oe Cathut duem awm hanh.   
\q1
\v 2 Na tarannaw teh ruengruengti awh.  
\q2 Nang kahmuhmanaw teh a loungouk awh.   
\q1
\v 3 Na taminaw taranlahoi hnephnap hoi kho a khan awh teh,  
\q2 na hro e na taminaw taran laihoi pouknae a kâoup awh.   
\q1
\v 4 Tho awh, miphun lah aonae koehoi raphoe awh sei,  
\q2 Isarel min hai panue hoeh nahanlah ati awh.   
\q1
\v 5 Lungpouk buet touh lah, a kâpan awh teh,  
\q2 nang taranlahoi lawkkamnae teh a sak awh.   
\q1
\v 6 Edom hoi Ishmael rim dawk kaawmnaw,  
\q2 Moab hoi Hagar,   
\q1
\v 7 Gebal hoi Amon, Amalek hoi Filistin,  
\q2 hoi Taire kaawm e naw hoi lawkkam a sak awh.   
\q1
\v 8 Assyria hai ahnimouh koelah a kambawng teh,  
\q2 Lot catounnaw hah a kabawp. Selah.   
\q1
\v 9 Ahnimouh teh Midian koe na sak e patetlah,  
\q2 Kishion palang vah Sisera koehoi Jabin koe na sak e patetlah,  
\q2 bout sak pouh haw.   
\q1
\v 10 Ahnimouh teh Endor vah a due awh teh,  
\q2 talai dawk vaipuen lah a coung awh.   
\q1
\v 11 A tami kalennaw teh Oreb hoi Zeeb patetlah sak nateh,  
\q2 Bokheiyah, ahnimae siangpahrang pueng hah  
\q2 Zeeb hoi Zalmunna patetlah sak haw.   
\q1
\v 12 Hotnaw ni Cathut e saring pânae hmuen koehoi,  
\q2 kamamouh hanlah ka la awh han ati awh.   
\q1
\v 13 Oe Cathut ahnimouh teh vaiphu kahlî ni palek e hoi  
\q2 vaikong kahlî ni a palek e patetlah coung sak haw.   
\q1
\v 14 Hmai ni thing a kak e hoi,  
\q2 mon hah hmai ni a kak e patetlah coung sak haw.   
\q1
\v 15 Ahnimouh teh na kahlî kathout hoi pâlei nateh,  
\q2 puenghoi katang e kahlî hoi pakhi haw.   
\q1
\v 16 Oe BAWIPA, na min a tawng awh nahan lah  
\q2 a minhmai ka paling lah kayak sak ngala haw.   
\q1
\v 17 Nang dueng doeh BAWIPA min ka sin e hoi  
\q2 talai van pueng dawk Lathueng Poung  
\q2 lah na o e hah na panue thai awh nahanelah,   
\q1
\v 18 Yeiraipo hoi rucat hoi pou awm sak haw.  
\q2 Bokheiyah, kaya hoi awm sak nateh,  
\q2 koung kahmat naseh.   
\c 84  
\s1 Cathut im khosak yawhawinae  
\d Kathutkung: Korah capanaw  
\q1
\v 1 Oe ransahu BAWIPA, na onae teh  
\q2 banghloimaw ngai ao.   
\q1
\v 2 Ka hringnae ni a rabui, Bokheiyah,  
\q2 BAWIPA thongma rabui laihoi ka tâwn.  
\q2 Ka lungthin hoi ka takthai ni  
\q2 kahring Cathut teh atangcalah a kaw.   
\q1
\v 3 Oe ransahu BAWIPA, ka Siangpahrang hoi ka Cathut,  
\q2 na thuengnae khoungroe dawk pusu ni tabu a tuk teh,  
\q2 pingpit ni hai a canaw ta nahanelah tabu a tuk.   
\q1
\v 4 Na im dawk kaawmnaw teh,  
\q2 a yaw kahawi e doeh.  
\q2 Pou na pholen awh han. Selah.   
\q1
\v 5 Nang thaonae lah ka hnonaw hoi  
\q2 hmuen ka thoung koe cei ngainae  
\q2 lungthin ka tawn naw teh tami a yaw kahawi e doeh.   
\q1
\v 6 Baca yawn dawk a cei awh navah,  
\q2 tuiphuek tâconae lah a coung sak teh,  
\q2 khotui hai a kamuem sak.   
\q1
\v 7 Thaonae koehoi thathoenae koe lah cei awh teh,  
\q2 buet touh hnukkhu buet touh  
\q2 Zion Cathut hmalah a kamnue awh.   
\q1
\v 8 Oe ransahu Cathut BAWIPA,  
\q2 ka ratoumnae heh na thai pouh haw.  
\q2 Oe, Jakop Cathut, na hnâpakeng haw.   
\q1
\v 9 Oe Cathut, ka bahling khen nateh,  
\q2 Satui na awi e mei hah khenhaw!   
\q1
\v 10 Bangkongtetpawiteh,  
\q2 na thongma dawk hnin touh o e teh,  
\q2 alouklah hnin 1,000 touh o e hlak ahawihnawn.  
\q2 Thoenae rim dawk o e hlak teh  
\q2 Cathut im longkha ring e ka ngaihnawn.   
\q1
\v 11 Bangkongtetpawiteh, BAWIPA Cathut teh  
\q2 kanî hoi bahling doeh.  
\q2 BAWIPA ni lungmanae hoi bawilennae a poe han.   
\q1
\v 12 Oe ransahu BAWIPA,  
\q2 nang kâuep e teh a yaw kahawi e doeh.   
\c 85  
\s1 Ram hanlah BAWIPA koe ratoumnae  
\d Kathutkung: Korah capanaw  
\q1
\v 1 Oe, BAWIPA, na ram hah na lungyouk teh,  
\q2 Jakop catoun san lah a hrawi e naw hah  
\q2 bout na bankhai toe.   
\q1
\v 2 Na taminaw e payonnae hah na ngaithoum teh,  
\q2 a yonnae pueng na ramuk pouh toe.   
\q1
\v 3 Na lungkhueknae pueng hai na dam sak teh,  
\q2 na lungkâannae pueng hai na kamlang takhai toe.   
\q1
\v 4 Oe ka rungngangnae Cathut,  
\q2 bout na roung sak haw,  
\q2 ka lathueng na lungkhueknae teh na takhoe pouh haw.   
\q1
\v 5 Kaimouh koe na lung pou a khuek han maw.  
\q2 Na lungkhueknae teh se pueng dawk na caksak han na maw.   
\q1
\v 6 Nang dawk na taminaw a konawm thai awh nahan,  
\q2 bout na pâhlaw mahoeh toung na maw.   
\q1
\v 7 BAWIPA, na lungmanae na hmawt sak nateh,  
\q2 na rungngangnae na poe haw.   
\q1
\v 8 BAWIPA Cathut ni a dei hane lawk hah ka tarawi han.  
\q2 Bangkongtetpawiteh, a taminaw hoi  
\q2 a tamikathoungnaw koevah,  
\q2 lungmawngnae lawk hah a dei han.  
\q2 Hatei, pathunae koe lah teh kamlang awh hanh.   
\q1
\v 9 Maimae ram dawk bawilennae ao thai nahan,  
\q2 a rungngangnae teh ama ka taketnaw hoi a hnai tangngak.   
\q1
\v 10 Lungmanae hoi lawkkatang a kâhmo teh,  
\q2 lannae hoi lungmawngnae a kâpahnuep.   
\q1
\v 11 Lawkkatang teh talai dawk hoi a dâwn teh,  
\q2 lannae ni kalvan hoi a khet.   
\q1
\v 12 Bokheiyah, BAWIPA ni hnokahawi a poe.  
\q2 Maimae ram ni a tâcokhai e a pawhik teh a pung han.   
\q1
\v 13 A hmalah lannae a cei vaiteh,  
\q2 khokhnuk teh lamthung lah a sak han.   
\c 86  
\s1 BAWIPA pouk laihoi lungmanae hei ratoumnae  
\d Kasakkung: Devit  
\q1
\v 1 Oe BAWIPA, na hnâpakeng nateh, na thai pouh haw.  
\q2 Bangkongtetpawiteh, mathoe hoi ka vout e lah ka o.   
\q1
\v 2 ka hringnae heh na khetyawt teh, ka thoung e lah ka o.  
\q2 Ka Cathut lah na o.  
\q2 Nang kâuep e na san hah na rungngang haw.   
\q1
\v 3 Oe BAWIPA, na pahren haw.  
\q2 Bangkongtetpawiteh, kanîloum totouh nang teh pou na kaw.   
\q1
\v 4 Na san hringnae heh lunghawi sak haw.  
\q2 Bangkongtetpawiteh, Oe Bawipa,  
\q2 ka hringnae ni nang dueng doeh na khet.   
\q1
\v 5 Bangkongtetpawiteh, Bawipa, nang teh na hawi.  
\q2 Ngaithoum hanelah coungkacoe na kâcai teh,  
\q2 na ka kaw e pueng koe pahrennae moikapap na ka tawn e lah na o.   
\q1
\v 6 Oe BAWIPA, ka ratoumnae heh na thai pouh haw.  
\q2 Pahrennae ka hei e heh na thai pouh haw.   
\q1
\v 7 Runae kâhmo navah na kaw han.  
\q2 Bangkongtetpawiteh, nang ni teh na pato han.   
\q1
\v 8 Oe BAWIPA, cathutnaw thung dawk  
\q2 nang hoi kâvan e awm hoeh.  
\q2 Na sak e patetlah ka sak thai e hai awm hoeh.   
\q1
\v 9 Oe Bawipa na sak e miphun pueng,  
\q2 na hmalah tho vaiteh na bawk awh vaiteh,  
\q2 na min a pholen awh han.   
\q1
\v 10 Bangkongtetpawiteh, nang teh na lentoe teh,  
\q2 kângairuhno ouk na sak.  
\q2 Nang dueng doeh Cathut.   
\q1
\v 11 Oe BAWIPA, na lam heh na cangkhai haw.  
\q2 Na lawkkatang dawk ka o han.  
\q2 Na min bari nahanelah lungthin buet touh lah na tawn sak haw.   
\q1
\v 12 Oe Bawipa ka Cathut, ka lungthin abuemlahoi na pholen vaiteh,  
\q2 na min teh a yungyoe hoi ka tawmrasang han.   
\q1
\v 13 Bangkongtetpawiteh, kai dawk  
\q2 na lungmanae teh a len poung.  
\q2 Ka dungpoung e Sheol hoi ka muitha teh na rungngang toe.   
\q1
\v 14 Oe Cathut, tami kâoupnaw ni na taran teh,  
\q2 tamimathoutnaw ni ka hringnae a tawng awh,  
\q2 a hmalah nang hah na tat awh hoeh.   
\q1
\v 15 Hatei, Oe BAWIPA, nang teh, lungmanae,  
\q2 lungpatawnae, lungsawnae, poukthainae,  
\q2 hoi lawkkatang hoi kakawi e Cathut doeh.   
\q1
\v 16 Kai koelah kamlang nateh na pahren haw.  
\q2 Na san koe thaonae na poe haw,  
\q2 na sannu capa heh na rungngang haw.   
\q1
\v 17 Hawinae hanlah mitnoutnae kamnuek sak haw.  
\q2 Na kahmawt ngaihoeh naw ni a hmu awh toteh, kayak awh naseh.  
\q2 BAWIPA nang ni na kabawp teh lung na pahawi.   
\c 87  
\s1 Cathut khopui bawilennae  
\d Kathutkung: Korah capanaw  
\q1
\v 1 Khopui teh mon ka thoung dawk a kangdue sak.   
\q1
\v 2 Jakop khosaknae pueng hlak hai BAWIPA ni  
\q2 Zion longkha a lungpatawhnawn.   
\q1
\v 3 Oe Cathut e khopui, na kong heh  
\q2 ka sungren poung lah ouk a dei awh. Selah.   
\q1
\v 4 Na kapanueknaw koe Rahab hoi  
\q2 Babilon kong hah ka dei han.  
\q2 Khenhaw! Oe Filistin hoi Taire, Ethiopia,  
\q2 hetheh, haw hoi ka tâcawt e doeh ati awh han.   
\q1
\v 5 Zion kong dawk hettelah a dei awh han.  
\q2 Het hoi hot teh ama dawk hoi ka tâcawt e doeh.  
\q2 Lathueng Poung ni a ma teh, a caksak telah ati awh han.   
\q1
\v 6 BAWIPA ni tami pueng min a thut toteh,  
\q2 hethateh, haw e ka tâcawt e doeh telah mitnout a ta awh han.   
\q1
\v 7 La kasaknaw hoi tumkhawng kakhawngnaw ni,  
\q2 tuiphuek pueng nang koe ao telah ati awh han.   
\c 88  
\s1 Lungpoutnae hoi kabawp heinae  
\d Kasakkung: Korah Capa Heman  
\q1
\v 1 Oe BAWIPA kaie rungngangnae Cathut,  
\q2 na hmalah karum khodai ka hram.   
\q1
\v 2 Na hmalah ka ratoumnae phat naseh,  
\q2 ka hramnae heh na thai pouh haw.   
\q1
\v 3 Ka hringnae teh runae hoi a kawi teh,  
\q2 Sheol phuen teng rek ka pha toe.   
\q1
\v 4 Tangkom dawk kâennaw hoi mek touksin lah ka o teh,  
\q2 thaonae ka tawn hoeh e patetlah ka o.   
\q1
\v 5 Taran ni a thei teh tangkom dawk pakawp e patetlah,  
\q2 tami kadoutnaw koe tâkhawng lah ka o teh,  
\q2 pouk hoeh e kabawp hoeh e patetlah ka o.   
\q1
\v 6 Tangkom dawk a dengnae koe, adungnae koe,  
\q2 a hmo poungnae koe vah na ta.   
\q1
\v 7 Na lungkhueknae ni na ratet teh,  
\q2 na tuicapa ni na ramuk. Selah.   
\q1
\v 8 Ka panue e naw hah kai koehoi ahlanae koe na ta teh,  
\q2 ahnimouh hanlah panuettho e lah na coung sak.  
\q2 na taren sin teh ka tâcawt thai hoeh toe.   
\q1
\v 9 Runae kecu ka mit a mom.  
\q2 Hnintangkuem BAWIPA ka kaw teh, ka kut nang koe ka dâw.   
\q1
\v 10 Tami kadoutnaw hanlah kângairu na sak han na maw.  
\q2 Tamikadout thaw vaiteh, na pholen han na maw. Selah.   
\q1
\v 11 Na lungpatawnae teh phuen koe pâpho vaiteh,  
\q2 yuemkamcu lah na onae hah  
\q2 duenae hmuen koe pâpho han na maw.   
\q1
\v 12 Kângairu na sak e hah hmonae koe panue han na maw.  
\q2 Na lannae teh pahnim e ram dawk panue thai han na maw.   
\q1
\v 13 Hatei, Oe BAWIPA, nang koevah ka hram.  
\q2 Amom ka ratoumnae nang koe a pha han.   
\q1
\v 14 BAWIPA bangkongmaw ka hringnae hah na tâkhawng.  
\q2 Bangkongmaw kaimouh koehoi na minhmai na hro.   
\q1
\v 15 Ka camo nah hoi runae ka khang teh, due hane coungkacoe ka o toe.  
\q2 Taki na thonae hah ka khang teh  
\q2 kabawmkung ka tawn hoeh.   
\q1
\v 16 Na lungkhueknae ni na ramuk teh,  
\q2 taki na thonae ni na raphoe toe.   
\q1
\v 17 Hotnaw ni tui patetlah kanîloum totouh  
\q2 pou na ramuk teh na kalup.   
\q1
\v 18 Ka pahren e hoi ka huikonaw heh ahlanae koe a ta teh,  
\q2 ka panue e naw hai hmonae koe na o sak.   
\c 89  
\s1 Cathut lawkkam  
\d Kasakkung: Ethan  
\q1
\v 1 BAWIPA lungmanae teh la hoi pou ka sak han.  
\q2 Yuemkamcu lah na onae teh se pueng dawk  
\q2 ka pahni ni a pholen han.   
\q1
\v 2 Lungmanae teh a kangning.  
\q2 Yuemkamcu lah na onae teh kalvan roeroe vah,  
\q2 acak telah ka dei toe.   
\q1
\v 3 Ka rawi e koevah lawk ka kam toe.  
\q2 Ka san Devit koe thoe ka bo toe.   
\q1
\v 4 Na catoun hah pou ka caksak han.  
\q2 Na bawitungkhung hah se pueng dawk  
\q2 kangdue sak han. Selah.   
\q1
\v 5 Oe BAWIPA, kalvannaw ni kângairu lah  
\q2 na onae hah a pholen awh teh,  
\q2 tamikathoungnaw kamkhuengnae koe  
\q2 yuemkamcu lah na onae hai, a pholen awh han.   
\q1
\v 6 Bangkongtetpawiteh, kalvan vah BAWIPA hoi  
\q2 bangnue thai e apimouh kaawm.  
\q2 Athakaawmnaw thung dawk  
\q2 BAWIPA patet e ao han na ou.   
\q1
\v 7 Tamikathoungnaw kamkhuengnae koe Cathut teh,  
\q2 lentoe poung lahoi taki hanelah ao.  
\q2 A tengpam e tami pueng ni a bari awh hanelah ao.   
\q1
\v 8 Oe, kalvan ransabawi Cathut BAWIPA,  
\q2 nang patetlah athakaawm ao nama,  
\q2 Oe, BAWIPA, yuemkamcu lah na onae ni koung na kalup.   
\q1
\v 9 Talîpui tuicapa ka thaw e hai na uk teh,  
\q2 tuicapa a thaw teh na roum sak.   
\q1
\v 10 Tami ni taran a thei e patetlah,  
\q2 Rahab hah na raphoe teh, koung na kayei.  
\q2 Na taran hah na kut thaonae hoi koung na pâlei.   
\q1
\v 11 Kalvannaw hah nange lah ao teh,  
\q2 talai hai nange doeh.  
\q2 Talaivan hoi a thung kaawm e pueng hah na kangdue sak toe.   
\q1
\v 12 Atung aka heh na sak e lah ao teh,  
\q2 Tabor hoi Hermon teh na min dawk a konawm.   
\q1
\v 13 Athakaawme kutbuembue hah na tawn.  
\q2 Na kut heh a tha a sai teh aranglae  
\q2 kut teh hoe a rasang.   
\q1
\v 14 Lannae hoi kângingnae teh,  
\q2 na bawitungkhung kamtuenae lah ao teh,  
\q2 lungmanae hoi lawkkatang teh na hmalah a cei.   
\q1
\v 15 Lunghawinae kamthang ka thai e teh,  
\q2 tami yawkahawi e doeh.  
\q2 Oe BAWIPA, ahnimouh teh na minhmai  
\q2 angnae dawk kho a sak awh.   
\q1
\v 16 Na min dawkvah hnintangkuem a lunghawi awh teh,  
\q2 na lannae dawkvah tawm lah ao awh.   
\q1
\v 17 Bangkongtetpawiteh, nang teh ka sungren e  
\q2 a thaonae lah na o.   
\q1
\v 18 Bangkongtetpawiteh, BAWIPA teh maimae  
\q2 bahling lah ao teh, Isarelnaw e Kathoung E,  
\q2 maimae siangpahrang lah ao.   
\q1
\v 19 Hottelah, na tamikathoung koe kamnuenae lahoi  
\q2 lawk na dei teh, athakaawme hah kabawp teh,  
\q2 tamimaya thung hoi rawi e teh ka pholen.   
\q1
\v 20 Ka san Devit hah ka hmu teh,  
\q2 kathounge satui hoi ka awi toe.   
\q1
\v 21 Ka kut hoi kacaklah ka kuet vaiteh,  
\q2 ka kutbuembue ni a tha ao sak han.   
\q1
\v 22 Taran ni na dum thai mahoeh,  
\q2 tami ni patawnae na poe thai mahoeh.   
\q1
\v 23 Ama ka tarannaw hah a hmalah ka parawp vaiteh,  
\q2 ama kahmuhmanaw hah ka hem han.   
\q1
\v 24 Ama koe yuemkamcu lah ka onae hoi,  
\q2 lungmanae teh pou ao han.  
\q2 Ka min kecu dawk a ki hah tawm lah ao han.   
\q1
\v 25 A kut hai talîpui dawk ka ta vaiteh,  
\q2 aranglae kut hah palangpui dawk ka ta han.   
\q1
\v 26 Ama ni kai koe vah, nang teh apa ka Cathut,  
\q2 ka rungngangnae lungsongpui lah  
\q2 na o telah a hram han.   
\q1
\v 27 Ama teh ka camin lah ka coung sak vaiteh,  
\q2 talai siangpahrang ka rasang poung lah ka coung sak han.   
\q1
\v 28 Ka lungmanae hoi pou ka ring vaiteh,  
\q2 ahni koe ka lawkkam teh kacaklah a kangdue han.   
\q1
\v 29 A catoun hai yungyoe ka kangning sak vaiteh,  
\q2 a bawitungkhung hai kalvan  
\q2 a kangning roukrak ka kangning sak han.   
\q1
\v 30 A canaw ni ka kâlawk a kamlang takhai awh teh,  
\q2 ka lawkcengnae patetlah awm laipalah,   
\q1
\v 31 ka phunglam a tapoe awh teh,  
\q2 kaie kâpoelawknaw tarawi awh hoeh pawiteh,   
\q1
\v 32 Kâtapoenae dawk sumtaboung hoi ka rek vaiteh,  
\q2 payonnae dawk ka hem awh han.   
\q1
\v 33 Hatei, ka lungmanae teh  
\q2 ahni koehoi koung ka lat pouh mahoeh.  
\q2 Yuemkamcu lah ka onae hah  
\q2 ayawmyin lah ao hane ka pasoung hoeh.   
\q1
\v 34 Ka lawkkam ka raphoe mahoeh,  
\q2 ka pahni dawk hoi ka tâcawt e lawk heh  
\q2 ka thung mahoeh toe.   
\q1
\v 35 Vai touh kaie thoungnae hoi thoe ka bo teh,  
\q2 Devit koe laithoe ka dei mahoeh.   
\q1
\v 36 A catoun hah a yungyoe a kangning vaiteh,  
\q2 a bawitungkhung teh ka hmalah,  
\q2 kanî patetlah a kangdue han.   
\q1
\v 37 Thapa patetlah a yungyoe hanelah caksak lah awm vaiteh,  
\q2 kalvan yuemkamcu panuekkhaikung patetlah ao han. Selah.   
\q1
\v 38 Hatei, nang ni hnamthun takhai hoi na panuet teh,  
\q2 satui awi e dawkvah na lungkhuek.   
\q1
\v 39 Na san hoi lawkkamnae na raphoe teh,  
\q2 a bawilakhung talai dawk a bo teh  
\q2 banglah na ngai pouh hoeh.   
\q1
\v 40 Kalupnae tapangpueng na raphoe teh,  
\q2 na rapanim hah he na raphoe.   
\q1
\v 41 Lam dawk ka cet e pueng ni hno a la pouh awh teh,  
\q2 a tengpam e naw ni a pathoe awh.   
\q1
\v 42 A tarannaw e kut tha na o sak teh,  
\q2 a tarannaw pueng hah a lung na tho sak.   
\q1
\v 43 Ka hran e tahloi hah na ban sak teh,  
\q2 tarantuknae koe na kabawm hoeh toe.   
\q1
\v 44 A lentoenae hah na pout sak teh,  
\q2 a bawitungkhung hah talai dawk na tâkhawng pouh.   
\q1
\v 45 A nawsainae tueng na duem sak teh,  
\q2 yeirai hni hah na kâkhu sak.   
\q1
\v 46 BAWIPA bangkong ngailawi na o han.  
\q2 Pou na kâhro han maw.  
\q2 Na lungkhueknae teh hmai patetlah  
\q2 pou a kaman han maw.   
\q1
\v 47 Ka tueng a duemnae hah na pahnim pouh hanh.  
\q2 Bangkongtetpawiteh, tami catounnaw hah  
\q2 cungkeihoeh lah na sak.   
\q1
\v 48 Apipatet mouh duenae kâhmo laipalah ka hring thai.  
\q2 Phuen thaonae dawk hoi kârungngang thai e apimouh kaawm.   
\q1
\v 49 BAWIPA, Devit koe thoe na bo e  
\q2 ahmaloe e lungpatawnae teh, nâne ao toung.   
\q1
\v 50 BAWIPA, na sannaw pathoe lah a onae pahnim hanh.  
\q2 Athakaawme tami moikapap ni pathoenae hah kai ni ka khang.   
\q1
\v 51 Oe BAWIPA, na taran ni na pathoe teh,  
\q2 satui awi e a cei nah pueng koe a pathoe awh.   
\q1
\v 52 BAWIPA teh a yungyoe hoi a yungyoe  
\q2 pholen lah awm lawiseh.  
\q2 Amen hoi Amen.   
\c 90  
\s1 Cathut e tami Mosi ratoumnae  
\d Kasakkung: Mosi  
\q1
\v 1 BAWIPA nang teh se pueng dawk  
\q2 ka onae doeh.   
\q1
\v 2 Montamnaw na sak hoehnahlan,  
\q2 talai hoi talai hnonaw na sak hoehnahlan hoi,  
\q2 nang teh a yungyoe hoi a yungyoe e Cathut lah na o.   
\q1
\v 3 Tami teh rawkphainae koe na ban sak teh,  
\q2 tami canaw ban awh leih na ti.   
\q1
\v 4 Bangkongtetpawiteh, na mithmu vah  
\q2 kum 1,000 touh heh kaloum  
\q2 tangcoung e paduem patetlah ao teh,  
\q2 tangmin buet touh patetlah ao.   
\q1
\v 5 Ahnimouh teh tuikalen patetlah na loum sak teh,  
\q2 vai touh muet ka ip e patetlah na o sak.  
\q2 Amom e phokahring ka nâw e patetlah doeh ao.   
\q1
\v 6 Amom vah dikhring lah a nâw teh,  
\q2 tangmin lah tâtueng lah ao teh a kamyai awh.   
\q1
\v 7 Bangkongtetpawiteh, na lungkhueknae lahoi  
\q2 rawkphainae koe pha awh toe.  
\q2 Na lungkhueknae lahoi na pakhi awh toe.   
\q1
\v 8 Ka payonnae teh na hmalah thoseh,  
\q2 ka hro awh e yonnae teh,  
\q2 na minhmai angnae koe thoseh, pheng dan lah ao.   
\q1
\v 9 Bangkongtetpawiteh, ahninnaw teh  
\q2 na lungkhueknae dawk a loum awh teh,  
\q2 ka kumnaw teh cingounae dawk ka baw sak awh.   
\q1
\v 10 Hringyung teh kum 70 touh doeh.  
\q2 Thao dawkvah, kum 80 touh hai a pha thai.  
\q2 Hatei, kum sawnae teh,  
\q2 thatawnnae hoi lungmathoenae lah doeh ao.  
\q2 Bangkongtetpawiteh, tang a loum teh  
\q2 maimouh hai tang due awh.   
\q1
\v 11 Na lungkhuek thaonae heh apinimouh a panue.  
\q2 Na lungkhueknae heh taki han totouh apinimaw a taki.   
\q1
\v 12 Hottelah lungangnae lungthin  
\q2 tawn thai awh nahanelah,  
\q2 ahnintha pareinae na cangkhai haw.   
\q1
\v 13 Oe BAWIPA, bout ban haw.  
\q2 Nâtotouh maw na o han.  
\q2 Na sannaw heh pahren haw.   
\q1
\v 14 Ka hringyung thung ka lunghawi awh teh,  
\q2 kanawm thai awh nahanelah,  
\q2 na lungmanae hoi karanglah lung na kuep sak haw.   
\q1
\v 15 Hno kathout hmonae kum pueng hoi,  
\q2 na rektapnae hninthapa pueng hah  
\q2 ka lunghawinae lah coung sak haw.   
\q1
\v 16 Na sak e hah na sannaw koe kamnue sak nateh,  
\q2 na bawilennae teh a canaw koe kamnuek naseh.   
\q1
\v 17 BAWIPA Cathut na lunghawinae teh,  
\q2 kai koe awm naseh.  
\q2 Ka kut ni a tawk e naw teh, maimouh hanlah cak seh.  
\q2 Ka kut ni a tawk e naw teh, caksak lah awm lawiseh.   
\c 91  
\s1 Cathut hmalah pou o e doeh roumnae  
\d Kasakkung: Panuekhoeh  
\q1
\v 1 Lathueng Poung ni nguenae hmuen koe kaawm e teh,  
\q2 Athakasaipounge a tâhlip dawk ao han.   
\q1
\v 2 Ama teh ka kânguenae hoi ka rapanim,  
\q2 ka Cathut, ka kâuep e lah ao,  
\q2 telah BAWIPA hah ka dei han.   
\q1
\v 3 Ama ni karap dawk hoi thoseh,  
\q2 lacik kathout dawk hoi thoseh na rungngang han.   
\q1
\v 4 A rathei hoi na ramuk vaiteh,  
\q2 a rathei rahim na lung a mawng han.  
\q2 A lawkkatang teh na lungmawngnae bahling lah ao han.   
\q1
\v 5 Karum lae runae hoi khodai lae  
\q2 pala hai na taket mahoeh.   
\q1
\v 6 Khohmo nah ka tho e lacik na taket mahoeh,  
\q2 kanîthun ka tho e rawkphainae hai na taket mahoeh.   
\q1
\v 7 Na teng vah thong touh kamlet niteh,  
\q2 aranglah thong hra touh kamlet nakunghai,  
\q2 nang koe hnai mahoeh.   
\q1
\v 8 Na mit hoi khen nateh,  
\q2 tamikathoutnaw ni a kâhmo awh e teh,  
\q2 na hmu han doeh.   
\q1
\v 9 BAWIPA teh kânguenae lah ao telah na dei teh,  
\q2 Lathueng Poung dawk na o nahanelah na sak dawkvah,   
\q1
\v 10 thoenae banghai nang koe phat mahoeh.  
\q2 Na onae koe lacik kathout tho mahoeh.   
\q1
\v 11 Na lamthung pueng khenyawnkung lah,  
\q2 kalvan taminaw hah kâ a poe han.   
\q1
\v 12 A kut hoi na tawm vaiteh,  
\q2 na khok hoi talung na kamthui mahoeh.   
\q1
\v 13 Sendek hoi hrunthoe van na luen vaiteh,  
\q2 Sendek hoi khorui hah na khok hoi na coungroe han.   
\q1
\v 14 Ahni ni na lungpataw dawkvah,  
\q2 kai ni ka rungngang han.  
\q2 Ka min a panue dawkvah ka tawm han.   
\q1
\v 15 Na kaw toteh ka pato han.  
\q2 Runae a kâhmo toteh, ahni koe ka o vaiteh,  
\q2 ka rungngang vaiteh, ka bari han.   
\q1
\v 16 Hringsawnae hoi a lung ka kuep sak vaiteh,  
\q2 ka rungngangnae hah ka pâtue han.   
\c 92  
\s1 Yuemkamcunae hoi lungpatawnae dawk Cathut pholennae  
\d Kasakkung: panuekhoeh  
\q1
\v 1 Bawipa koe lunghawilawk dei e heh ahawi.  
\q2 Oe a Lathueng Poung Cathut,  
\q2 na min pholen teh la sak e heh ahawi tangngak.   
\q1
\v 2 Rui hra touh thueng e ratoung hoi  
\q2 tamawi hoi lawk phunkuep kacai e tumkhawng e hoi,   
\q1
\v 3 a pahrennae hoi yuemkamcunae naw teh,  
\q2 amom karoitawi tangmin karoitawi pâpho hanelah ahawi tangngak.   
\q1
\v 4 Oe BAWIPA, na hnosak e naw ni banghloimaw  
\q2 lung na hawi sak.  
\q2 na kutsaknaw dawk  
\q2 lunghawi hoi la ka sak han.   
\q1
\v 5 Oe BAWIPA na tawk e hah banghloimaw a len.  
\q2 Na pouknae naw teh adung tangngak.   
\q1
\v 6 Tamipathu ni teh panuek hoeh,  
\q2 thaipanuek hoeh.   
\q1
\v 7 Tamikathoutnaw teh phokahring patetlah a cawn awh teh,  
\q2 ka payonnaw pueng a tawnta awh toteh,  
\q2 a yungyoe a rawk awh nahanelah, letlang a coung.   
\q1
\v 8 Hatei, BAWIPA nang teh  
\q2 a rasangnae koe na o yungyoe.   
\q1
\v 9 Oe BAWIPA, na tarannaw heh khenhaw!  
\q2 Bangkongtetpawiteh, khenhaw!  
\q2 na tarannaw koung a kahma han.  
\q2 Payonnae ka sak e naw pueng teh, koung kayei lah ao han.   
\q1
\v 10 Hatei, ka ki heh sakrak e ki patetlah na saw sak teh,  
\q2 satui katha hoi awi lah ka o.   
\q1
\v 11 Ka tarannaw koe phat seh  
\q2 ka tie hah ka mit ni a hmu toe.  
\q2 Na ka taran e tamikathout koe ka pouk e a kuep teh, ka hnâ ni a thai.   
\q1
\v 12 Tamikalan teh samtue patetlah kâhuen vaiteh,  
\q2 Lebanon mon e Sidar thing patetlah a roung han.   
\q1
\v 13 BAWIPA im dawk ung e naw teh,  
\q2 Cathut thongma dawk a kâhuet awh han.   
\q1
\v 14 A matawng totouh a pawhik katha lah tâcawt vaiteh,  
\q2 pou a kâhuet awh han.   
\q1
\v 15 BAWIPA teh a lan tie kamnue saknae lah,  
\q2 ama teh lungsong lah ao teh,  
\q2 ama dawk lanhoehnae banghai awm hoeh.   
\c 93  
\s1 A yungyoe BAWIPA uknae  
\d Kasakkung: panuekhoeh  
\q1
\v 1 BAWIPA ni a uk, taluenae hoi a kamthoup.  
\q2 BAWIPA kamthoupnae lah ao teh,  
\q2 thaonae hah a keng dawk a kâyeng.  
\q2 Talaivan heh a kâhuet thai hoeh nahanlah caksak lah ao.   
\q1
\v 2 Na bawitungkhung teh ayan hoi caksak lah ao teh,  
\q2 nang teh a yungyoe hoi na o toe.   
\q1
\v 3 Oe BAWIPA, tuikalen a thaw,  
\q2 tuikalen ni a cairing teh  
\q2 tuikalen ni tuicapa a thaw sak.   
\q1
\v 4 A rasangnae koe kaawm e BAWIPA teh,  
\q2 tui moikapap pawlawk hoi,  
\q2 talîpui tuicapa thaonae hlak hai a thaohnawn.   
\q1
\v 5 Na lawkpanuesaknae naw teh, a kamceng.  
\q2 Oe BAWIPA, a yungyoe hoi na im teh  
\q2 thoungnae hoi pathoup e lah ao.   
\c 94  
\s1 Tami kalan hanelah kânguenae Cathut  
\d Kasakkung: Panuekhoeh  
\q1
\v 1 Oe BAWIPA Cathut, moipathungnae katawnkung,  
\q2 Oe Cathut moipathungnae katawnkung, ang haw.   
\q1
\v 2 Talai taminaw lawkcengkung,  
\q2 thaw haw, ka kâoupnaw hah moipathung haw.   
\q1
\v 3 Oe BAWIPA, tamikathoutnaw teh nâtotouh ne,  
\q2 nâtotouh ne a lunghawi awh han vai.   
\q1
\v 4 A ngai patetlah lawk a dei awh teh,  
\q2 a lawk a hram awh teh,  
\q2 nâtotouh ne a kâoup awh han vai.   
\q1
\v 5 Oe BAWIPA, na taminaw hah a pacekpahlek awh teh,  
\q2 nange râw hah a rektap awh.   
\q1
\v 6 Lahmainu hoi imyinnaw hah a thei awh teh,  
\q2 na pa kaawm hoeh e naw hah ouk a thei awh.   
\q1
\v 7 BAWIPA ni hmawt mahoeh,  
\q2 Jakop Cathut ni hai panuek mahoeh ati awh.   
\q1
\v 8 Maya thung dawk e tamipathunaw,  
\q2 panuek awh haw,  
\q2 Nâtuek maw na lungang awh han vai.   
\q1
\v 9 Thainae hnâ kasakkung ni thai mahoeh ou.  
\q2 Mit kasakkung ni hmawt mahoeh ou.   
\q1
\v 10 Miphunnaw kacangkhaikung hoi  
\q2 panuenae kacangkhaikung ni panuek mahoeh ou.   
\q1
\v 11 BAWIPA ni taminaw e pouknae  
\q2 banghai bang hoeh e hah a panue.   
\q1
\v 12 Oe BAWIPA, na kâlawk dawk hoi na cangkhai teh,  
\q2 na yue e naw teh a yawkahawi e lah ao.   
\q1
\v 13 Tamikathout hanelah tangkom tai hoehroukrak,  
\q2 runae dawk hoi na kâhat sak thai mahoeh.   
\q1
\v 14 Bangkongtetpawiteh, BAWIPA ni  
\q2 a taminaw hah hnoun mahoeh,  
\q2 a râw takhoe mahoeh.   
\q1
\v 15 Hatei, tamikalan koe lawkcengnae ban vaiteh,  
\q2 a lungthin kalan e pueng ni a tarawi awh han.   
\q1
\v 16 Yonnae kasaknaw taran hanelah  
\q2 apimouh kai hanlah ka thaw han.  
\q2 Payonnae kasaknaw taran hanelah  
\q2 apimaw kai yueng lah kangdout han.   
\q1
\v 17 BAWIPA teh kabawmkung lah awm hoeh pawiteh,  
\q2 duem onae koe ka hringnae yout kahmat han doeh toe.   
\q1
\v 18 Kangduenae hawihoeh ka tet pawiteh,  
\q2 Oe BAWIPA, na lungmanae ni na kuet han.   
\q1
\v 19 Ka lung mak pathu navah,  
\q2 lung na pahawinae ni ka lung ahawi sak.   
\q1
\v 20 Payonnae bawitungkhung,  
\q2 hawihoehnae phung hai a sak awh e teh,  
\q2 nang hoi kâhuiko thai han vaimoe.   
\q1
\v 21 Ayânaw hringnae taranlahoi a kâhmo teh,  
\q2 yonnae ka tawn hoeh naw hah yon a pen awh.   
\q1
\v 22 Hatei, BAWIPA teh ka kânguenae doeh.  
\q2 Ka Cathut teh ka lungsong doeh.   
\q1
\v 23 A payonnae hah amamouh lathueng phat sak nateh,  
\q2 hawihoehnae a sak awh lahun nah  
\q2 koung a tâtueng awh han.  
\q2 BAWIPA maimae Cathut ni koung a tâtueng awh han.   
\c 95  
\s1 Kâlawk tarawi hane hoi bawk hanelah counnae  
\d Kasakkung: panuekhoeh  
\q1
\v 1 Oe, tho awh haw, BAWIPA koe la sak awh sei.  
\q2 Maimae rungngangnae lungsong hah  
\q2 pholen laihoi lunghawi hoi hram awh sei .   
\q1
\v 2 Lunghawilawkdeinae lahoi a hmalah cet awh sei.  
\q2 Lunghawinae la hoi ama koe hram awh sei.   
\q1
\v 3 BAWIPA teh ka lentoe e Cathut lah ao,  
\q2 cathut pueng e Siangpahrang kalen lah ao.   
\q1
\v 4 Talai a dungpoungnae teh a kut dawk ao teh,  
\q2 mon karasangnaw hai amae doeh.   
\q1
\v 5 Talîpui hai a sak teh, amae doeh.  
\q2 Talai hai a kutsak doeh.   
\q1
\v 6 Tho awh, tabo laihoi bawk awh sei.  
\q2 BAWIPA na kasakkung hmalah  
\q2 khokcuengkhuem awh sei.   
\q1
\v 7 Ama teh maimae Cathut doeh.  
\q2 Maimouh hai ama koe ka pawngpa e  
\q2 a kut rahim e tuhu lah o awh.   
\q1
\v 8 Sahnin vah nangmouh teh  
\q2 a lawk na thai awh nahlangva  
\q2 na lungpatak sak hanh awh.   
\q1
\v 9 Nangmae mintoenaw ni kum 40 touh thung,  
\q2 kai hah aphunphun lah na tanouk awh teh,  
\q2 kaie thaw a hmunae kahrawngum vah,  
\q2 kai na taran awh teh,  
\q2 na tanouk awh e patetlah awm awh hanh leih.   
\q1
\v 10 Hote miphunnaw hah kai ni ka panuet teh,  
\q2 a lungthin lam pou ka payon e lah ao awh.  
\q2 Kaie lamthung hah panuek thai awh hoeh.   
\q1
\v 11 Hatdawkvah, ka lungkhuek teh,  
\q2 kaie kâhatnae hmuen koe na kâen awh mahoeh, telah thoe ka bo.   
\c 96  
\s1 Ka tho hane lawkcengnae dawk Cathut pholennae la  
\d Kasakkung: Devit  
\q1
\v 1 Oe BAWIPA koe la katha sak awh.  
\q2 Talai taminaw pueng, BAWIPA koe la sak awh.   
\q1
\v 2 BAWIPA koe la sak awh nateh,  
\q2 a min teh pholen awh.  
\q2 Rungngangnae kamthang kahawi teh hnintangkuem pathang awh.   
\q1
\v 3 Miphun pueng koe a bawilennae teh pâpho awh haw.  
\q2 Tami pueng koe kângairu lah a onae hah pâpho awh.   
\q1
\v 4 BAWIPA teh a len, puenghoi pholen hanelah ao,  
\q2 Cathut pueng hlak taki hanelah ao,   
\q1
\v 5 Miphunlouknaw e cathut pueng teh ayawmyin doeh.  
\q2 BAWIPA ni teh kalvan hah a sak.   
\q1
\v 6 A hmalah barinae hoi taluenae teh ao.  
\q2 A hmuen kathoung koe thaonae hoi meihawinae teh ao.   
\q1
\v 7 Oe, tami pueng hoi imthung pueng,  
\q2 BAWIPA teh bawilennae hoi thaonae hah poe awh.   
\q1
\v 8 BAWIPA e min teh, bawilennae poe awh.  
\q2 Pasoung hno sin laihoi a thongma koe tho awh.   
\q1
\v 9 Oe, thoungnae kamthoup laihoi BAWIPA bawk awh.  
\q2 Talai taminaw pueng a hmalah pâyaw awh.   
\q1
\v 10 Miphun pueng koe BAWIPA ni a uk tet awh.  
\q2 Talaivan hai kacaklah kangdue sak teh, kâhuen mahoeh.  
\q2 Ama ni kalan lah lawk a ceng han.   
\q1
\v 11 Kalvan teh lunghawi naseh,  
\q2 talai hai konawm naseh.  
\q2 Talîpui hoi a thung e kaawm e pueng  
\q2 ni hai cairing naseh.   
\q1
\v 12 Law hoi a thung e kaawm e pueng lunghawi naseh.  
\q2 kahrawng e kaawm e pueng nihai  
\q2 BAWIPA koe konawm laihoi la sak naseh.   
\q1
\v 13 Bangkongtetpawiteh, ama teh a tho.  
\q2 Talai taminaw lawkceng hanelah a tho.  
\q2 Talaivan hah lannae hoi lawkceng vaiteh,  
\q2 a lawkkatang hoi tami lawk a ceng han.   
\c 97  
\s1 BAWIPA dawk hringnae pholen la  
\d Kasakkung: panuekhoeh  
\q1
\v 1 BAWIPA ni a uk, talai lunghawi seh.  
\q2 Tuilumnaw hai lunghawi awh naseh.   
\q1
\v 2 Tâmai hoi hmonae ni a ramuk teh,  
\q2 lannae hoi kângingnae teh  
\q2 a bawitungkhung a kamtuenae doeh.   
\q1
\v 3 A hmalah hmai a cei teh,  
\q2 ka kalup e tarannaw teh a kak awh.   
\q1
\v 4 Sumpapalik ni talai a ang sak teh,  
\q2 talai ni a hmu toteh a pâyaw.   
\q1
\v 5 Monnaw pueng teh BAWIPA hmalah,  
\q2 talai van pueng teh Bawipa hmalah  
\q2 khoilai patetlah koung a kamyawt.   
\q1
\v 6 Kalvan ni a lannae hah a pâpho teh,  
\q2 tami pueng ni a bawilennae hah a hmu awh.   
\q1
\v 7 Meikaphawk thaw ka tawk e pueng,  
\q2 ayawmyin dawk kakâoupnaw pueng teh,  
\q2 kaya laihoi awm awh naseh,  
\q2 cathutnaw pueng ama teh bawk awh haw.   
\q1
\v 8 Bangkongtetpawiteh, Oe BAWIPA  
\q2 nange lawkcengnae dawkvah,  
\q2 Zion a lunghawi teh Judah canunaw hai a konawm awh.   
\q1
\v 9 Oe BAWIPA, nang teh talai van pueng hlak a lathueng poung lah na o.  
\q2 Cathut pueng lathueng vah tawm lah na o.   
\q1
\v 10 Nangmouh Cathut lungpataw naw,  
\q2 kathoute hah panuet awh nateh,  
\q2 ama ni a tamikathoungnaw e hringnae hah a khetyawt teh,  
\q2 tamikathoutnaw e kut dawk hoi a rungngang.   
\q1
\v 11 Tamikalannaw koe a ang teh lungthin  
\q2 kalannaw koe konawmnae teh ouk a pha.   
\q1
\v 12 Nangmouh tami kalannaw,  
\q2 BAWIPA koe konawm awh haw.  
\q2 A min kathoung hah pholen awh.   
\c 98  
\s1 A lawkcengnae hoi rungngangnae dawk BAWIPA pholennae la  
\d Kasakkung: panuekhoeh  
\q1
\v 1 Oe, BAWIPA koe la katha sak awh.  
\q2 Bangkongtetpawiteh, kângairu hno hah a sak.  
\q2 Aranglah a kut hoi kathoung e  
\q2 kut ni tânae teh a pang toe.   
\q1
\v 2 BAWIPA ni a rungngangnae teh a kamnue sak toe.  
\q2 A lannae teh miphun pueng koe a kamnue sak.   
\q1
\v 3 Isarel imthung koe a lungmanae hoi  
\q2 yuemkamcu lah a onae hah pahnim hoeh.  
\q2 Talai van pueng ni Cathut rungngangnae teh  
\q2 hmu awh toe.   
\q1
\v 4 Talai taminaw pueng BAWIPA pholen hoi,  
\q2 konawm laihoi hram awh haw.  
\q2 La sak laihoi lunghawi awh haw.  
\q2 Pholen la hah sak awh haw.   
\q1
\v 5 Ratoung hoi BAWIPA koe la sak awh.  
\q2 Ratoung kueng lawk hoi pholennae  
\q2 la kahawi hoi pholen awh.   
\q1
\v 6 Mongka hoi tuki hoi Siangpahrang BAWIPA hmalah,  
\q2 lunghawicalah hoi hram awh haw.   
\q1
\v 7 Talî hoi a thung kaawm e pueng hoi,  
\q2 talai hoi a thung kaawm e pueng ni  
\q2 a lawk tâcawt sak awh.   
\q1
\v 8 Palangnaw ni a kuttabawng naseh.  
\q2 Monnaw hai BAWIPA hmalah konawm naseh.   
\q1
\v 9 Bangkongtetpawiteh, talai lawkceng hanlah a tho.  
\q2 Talaivan heh lannae hoi lawk a ceng vaiteh,  
\q2 suetalah taminaw lawk a ceng han   
\c 99  
\s1 BAWIPA teh a thoung dawkvah pholen awh  
\d Kasakkung: panuekhoeh  
\q1
\v 1 BAWIPA ni a uk, tami pueng pâyaw naseh.  
\q2 Ama teh cherubim rahak ao.  
\q2 Talai kâhuen naseh.   
\q1
\v 2 BAWIPA teh Zion vah a lentoe teh,  
\q2 tami pueng hlak tawm lah ao.   
\q1
\v 3 Ka lentoe e hoi takikatho e na min hah,  
\q2 pholen awh naseh, ama teh a thoung.   
\q1
\v 4 Siangpahrang thaonae ni hai kângingnae teh a pahren teh,  
\q2 kânging e lawkcengnae hah a caksak.  
\q2 Jakop koe lannae hoi kângingnae hah a kangdue sak.   
\q1
\v 5 BAWIPA Cathut teh tawm awh nateh,  
\q2 a khok koe bawk awh, ama teh a thoung.   
\q1
\v 6 Mosi hoi Aron teh a vaihmanaw thung e doeh.  
\q2 Samuel teh a min kakawnaw thung e doeh.  
\q2 Ahnimouh ni BAWIPA hah a kaw awh teh, ama ni a pato.   
\q1
\v 7 Tâmai thung hoi ahnimouh koe lawk a dei teh,  
\q2 ahnimouh koe a poe e lawkpanuesaknae hoi  
\q2 a phunglam hah a tarawi.   
\q1
\v 8 Oe, BAWIPA kaimae Cathut, nang ni na pato awh.  
\q2 A sak awh e dawk moi na pathung nakunghai,  
\q2 nang teh ahnimouh na ka ngaithoumkung lah na o.   
\q1
\v 9 BAWIPA maimae Cathut teh tawmrasang awh nateh,  
\q2 amon kathoung dawk ama teh bawk awh.  
\q2 Bangkongtetpawiteh, BAWIPA maimae Cathut teh a thoung.   
\c 100  
\d Kasakkung: panuekhoeh  
\q1
\v 1 Talai taminaw pueng BAWIPA teh pholen awh.   
\q1
\v 2 BAWIPA thaw hah lunghawi laihoi tawk awh.  
\q2 A hmalah la sak laihoi tho awh.   
\q1
\v 3 BAWIPA teh Cathut doeh tie hah panuek awh.  
\q2 Ahni ni maimouh na sak toe.  
\q2 Maimouh teh amae lah o awh.  
\q2 Maimouh teh amae tami lah o awh,  
\q2 ama koe ka pâ e tuhu lah o awh.   
\q1
\v 4 Lunghawilawkdeinae lahoi longkha dawk kâen awh,  
\q2 pholen laihoi a takhang dawk kâen awh.  
\q2 Ama koe lunghawi awh nateh,  
\q2 a min hah yawhawi poe awh.   
\q1
\v 5 Bangkongtetpawiteh, BAWIPA teh ahawi,  
\q2 a pahrenlungmanae teh a yungyoe a kangning,  
\q2 yuemkamcunae teh a yungyoe a cak.   
\c 101  
\s1 BAWIPA koe yuemkamcu lawkkamnae  
\d Kasakkung: Devit  
\q1
\v 1 Lungmanae hoi kângingnae la ka sak han.  
\q2 BAWIPA nang koe pholennae la ka sak han.   
\q1
\v 2 Ka kuep e lamthung dawk lungang lahoi ka hring han.  
\q2 Oe, nâtuek ne kai koe na tho han vai.  
\q2 Ka imthungkhu dawk ka thoung e lungthin hoi ka o han.   
\q1
\v 3 Ka mithmu vah hawihoehnae banghai ka tat mahoeh.  
\q2 Katâlawnaw ni tawksaknae hah ka hmuhma teh,  
\q2 kai dawk kâbet mahoeh.   
\q1
\v 4 Lungthin longkawinae ni na ceitakhai vaiteh,  
\q2 hawihoehnae hah ka panuek mahoeh.   
\q1
\v 5 Arulahoi a imri ka pathoe e pueng ka raphoe vaiteh,  
\q2 a minhmai kâoup niteh,  
\q2 a lungpouk ka rasang e naw hah ka panguep mahoeh.   
\q1
\v 6 Yuemkamcu e khocanaw teh kai koe ao awh nahanelah, ka khetyawt han.  
\q2 Ka kuep e lamthung ka dawn e ni kaie thaw a tawk awh han.   
\q1
\v 7 Tami ka dumyen e teh, ka im dawk awm mahoeh.  
\q2 Laithoe kadeinaw teh, ka hmalah pou awm awh mahoeh.   
\q1
\v 8 Hawihoehnae ka sak e naw hah  
\q2 BAWIPA e khopui dawk hoi raphoe nahanlah,  
\q2 tamikathoutnaw pueng teh palang a raphoe han toe.   
\c 102  
\s1 BAWIPA lungpatawnae  
\d Kasakkung: panuekhoeh  
\q1
\v 1 Oe BAWIPA ka ratoumnae na thai pouh awh.  
\q2 Ka kanae hai nang koe phat naseh.   
\q1
\v 2 Ka rucat navah kai koe na minhmai na hrawk pouh hanh.  
\q2 Kai koe lah na hnâpakeng nateh,  
\q2 na kaw toteh karanglah na pato haw.   
\q1
\v 3 Bangkongtetpawiteh,  
\q2 kaie hninnaw teh hmaikhu patetlah a kahma han.  
\q2 Ka hrunaw hah hmaito patetlah a kak.   
\q1
\v 4 Ka lungthin teh phokahring patetlah,  
\q2 hem lah ao teh a kamyai.  
\q2 Rawca ca hane hai ouk ka pahnim.   
\q1
\v 5 Ka cingounae dawkvah,  
\q2 ka hru hoi ka vuen khik kâbet.   
\q1
\v 6 Kahrawng e tavaca patetlah ka o teh,  
\q2 ka rawk tangcoung e kho dawk e bukbu patetlah ka o.   
\q1
\v 7 Ka i nah ka mitmasip thai hoeh,  
\q2 lemphu vah amadueng kaawm e  
\q2 mongmang va patetlah ka o.   
\q1
\v 8 Ka tarannaw ni kanîruirui na pathoe awh.  
\q2 Kaie avanglah na ka pacekpahlek e naw ni  
\q2 kai hah bangnuenae lah thoe na bo awh.   
\q1
\v 9 Bangtelah tetpawiteh, hraba hah rawca lah ka khan teh,  
\q2 ka nei hane tui hai mitphi hoi a kâkalawt.   
\q1
\v 10 Na lungkhueknae kecu dawk,  
\q2 na tawm teh na tâkhawng.   
\q1
\v 11 Kaie hninnaw teh kanîka patetlah ao teh,  
\q2 phokahring patetlah a kamyai.   
\q1
\v 12 Hatei, Oe BAWIPA, nang teh a yungyoe na kangning.  
\q2 Na min pahnimhoehnae teh se pueng dawk a kangning.   
\q1
\v 13 Na thaw vaiteh, Zion na lungma han,  
\q2 Zion kho rungngang nahane tueng,  
\q2 atueng khoe e teh a pha toe.   
\q1
\v 14 Na sannaw teh talungnaw dawk a konawm awh teh,  
\q2 hraba totouh a doun awh.   
\q1
\v 15 Miphunlouknaw ni BAWIPA min teh a taki awh han.  
\q2 Talaivan e siangpahrang pueng ni  
\q2 na bawilennae hah a taki awh han.   
\q1
\v 16 BAWIPA ni Zion kho kangdue sak teh  
\q2 a bawilennae lahoi a kamnue sak.   
\q1
\v 17 Kavoutnaw e ratoumnae na thai pouh vaiteh,  
\q2 a kâheinae teh noutna laipalah na awm hoeh.   
\q1
\v 18 Hetheh, kaawm hane se hanelah thut lah ao teh  
\q2 kaawm hane tamimaya ni  
\q2 BAWIPA teh a pholen awh han.   
\q1
\v 19 Thongkabawtnaw kâhram lawk  
\q2 thai hane hoi a due han toe telah  
\q2 pouk e naw hlout sak hane hoi,   
\q1
\v 20 Zion hoi BAWIPA min pâpho hane hoi  
\q2 Jerusalem hoi ama pholen hanelah,   
\q1
\v 21 BAWIPA thaw tawk hanlah tami pueng hoi  
\q2 ram pueng hmuen touh koe kamkhueng awh toteh,   
\q1
\v 22 a rasangnae hmuen kathoung koehoi a khet navah,  
\q2 BAWIPA ni talai heh kalvan hoi a khet.   
\q1
\v 23 Lamthung dawk ka thaonae a youn teh,  
\q2 kanî hah a duem sak teh,   
\q1
\v 24 Oe ka Cathut, ka hringyung na lat pouh hanh telah ka ti.  
\q2 Nange na kum teh se pueng hane doeh telah ka ti.   
\q1
\v 25 Nang ni ahmaloe hoi talai heh na kangdue sak toe.  
\q2 Kalvannaw hah na kut sak doeh.   
\q1
\v 26 Hotnaw teh rawknae koe ka phat nakunghai,  
\q2 nang teh a yungyoe na kangning.  
\q2 Hotnaw pueng teh, khohna patetlah ka pawn han.  
\q2 Khohna kâthung patetlah na thung vaiteh  
\q2 kâhleng awh nakunghai,   
\q1
\v 27 nang teh kâhlengnae awm hoeh.  
\q2 Na kum hai bawnae awm hoeh.   
\q1
\v 28 Na sannaw e ca catounnaw teh,  
\q2 kangning awh vaiteh,  
\q2 catounnaw hai na hmalah caksak lah ao han.   
\c 103  
\s1 BAWIPA lungmanae pholennae  
\d Kathutkung: Devit  
\q1
\v 1 Oe ka hringnae BAWIPA teh pholen haw.  
\q2 Ka thung kaawm e pueng  
\q2 a min kathoung teh pholen awh.   
\q1
\v 2 Oe ka hringnae BAWIPA teh pholen nateh  
\q2 ahawinae pueng hah pahnim hanh.   
\q1
\v 3 Na payonnae pueng ka ngaithoumkung,  
\q2 na patawnae pueng kadamsakkung,   
\q1
\v 4 rawk kahmanae koehoi na hringnae  
\q2 karatangkung hoi ngai kaawm e lungmanae hoi  
\q2 lungpatawnae bawilakhung na kamuksakkung,   
\q1
\v 5 Na nawnae hah mataw patetlah bout katha nahanlah,  
\q2 na cue toteh hnokahawi hoi na lung a kuep sak.   
\q1
\v 6 BAWIPA ni kângingnae hah a kangdue sak teh,  
\q2 repcoungroenae pueng hanelah,  
\q2 kângingnae lah a kangdue sak.   
\q1
\v 7 A lamthung hah Mosi koe a panue sak teh,  
\q2 a sak e naw hah Isarelnaw koe a panue sak.   
\q1
\v 8 BAWIPA teh lungmanae hoi pahrennae lah ao.  
\q2 A lungsaw teh, lungpatawnae hoi a kawi.   
\q1
\v 9 Pou na yue mahoeh,  
\q2 a lung pou khuek mahoeh.   
\q1
\v 10 Yon awh e patetlah maimouh koe sak mahoeh.  
\q2 Payon e patetlah na pathung mahoeh.   
\q1
\v 11 Bangkongtetpawiteh,  
\q2 kalvan teh talai hlak a rasang e patetlah,  
\q2 ama kataketnaw koe vah a lungmanae teh a len.   
\q1
\v 12 Kanîtho hoi kanîloum a kâhla e patetlah,  
\q2 kâtapoenae teh maimouh koehoi  
\q2 ahla poungnae koe na ta pouh awh.   
\q1
\v 13 Na pa ni canaw a lungma e patetlah,  
\q2 BAWIPA ni ama kataketnaw hah a lungma.   
\q1
\v 14 Bangkongtetpawiteh,  
\q2 maimae tak heh a panue teh  
\q2 vaiphu lah o awh e hah pahnim hoeh.   
\q1
\v 15 Tami e ahninnaw teh pho kahring patetlah ao teh  
\q2 kahrawng e a pei patetlah doeh ao.   
\q1
\v 16 Bangtelah tetpawiteh, kahlî ni a palek teh a pei a kahma,  
\q2 a onae hmuen hai panuek hoeh toe.   
\q1
\v 17 Hatei, BAWIPA lungmanae teh  
\q2 a ma taketnaw lathueng vah,  
\q2 a yungyoe hoi a yungyoe totouh a kangning.   
\q1
\v 18 A lawkkam tarawi kangainaw hoi  
\q2 kâpoelawk kapâkuemnaw teh,  
\q2 a lannae hoi catounnaw totouh a kangning han.   
\q1
\v 19 BAWIPA ni kalvan vah  
\q2 a bawitungkhung a caksak teh,  
\q2 a uknaeram ni bangpuengpa koung a uk.   
\q1
\v 20 Kalvantaminaw BAWIPA teh pholen awh.  
\q2 A lawk ka ngai ni teh katarawinaw hoi  
\q2 acawilah thaonae hoi pathoup e lah na o awh.   
\q1
\v 21 Nangmouh ransahu pueng,  
\q2 a thaw katawkkungnaw hoi,  
\q2 a ngainae kasaknaw BAWIPA teh pholen awh,   
\q1
\v 22 A sak e hno pueng kecu dawk,  
\q2 a uknaeram pueng thungvah,  
\q2 BAWIPA teh pholen awh.  
\q2 Oe ka hringnae BAWIPA teh pholen haw.   
\c 104  
\s1 Saknae hoi khetyawtnae dawk BAWIPA pholennae  
\d kasakkung: panuekhoeh  
\q1
\v 1 Oe, ka hringnae BAWIPA teh pholen haw.  
\q2 Oe BAWIPA ka Cathut nang teh na lentoe tangngak.  
\q2 Taluenae hoi barinae hoi kamthoup e lah na o.   
\q1
\v 2 Khohna patetlah angnae na khohna teh,  
\q2 kalvannaw hah hni patetlah na yap.   
\q1
\v 3 Na onae im van adunaw hah tui dawk na pâhung teh,  
\q2 tâmai patet hah leng lah na coung sak teh  
\q2 kahlî rathei hoi na tho.   
\q1
\v 4 Na patounenaw hah kahlî patetlah thoseh,  
\q2 thaw katawknaw hah hmaito patetlah  
\q2 thoseh na coung sak.   
\q1
\v 5 Talai adu hah nâtuek hai  
\q2 a kampuen hoeh nahanlah ka caksak e lah na o   
\q1
\v 6 Talai hah hni hoi khu e patetlah  
\q2 tui hoi na khu teh,  
\q2 tui hah monsom vah a kangdue.   
\q1
\v 7 Na yue toteh, a yawng awh.  
\q2 Khoparit lawk a thai awh toteh  
\q2 karangpoung lah a yawng awh.   
\q1
\v 8 Mon lah a luen awh teh,  
\q2 ravonaw dawk hoi a kum awh teh  
\q2 ao nahane hmuen koe koung a pha awh.   
\q1
\v 9 Tuinaw bout a tho teh,  
\q2 talai a muem hoeh nahanlah,  
\q2 a tapuet thai hoeh hane khori hah a khuen pouh.   
\q1
\v 10 Ravo dawk lawng hanelah tui hah a tha teh,  
\q2 mon hoi a lawng cathuk awh.   
\q1
\v 11 Saring pueng ni nei hanelah a poe teh,  
\q2 kahrawng e lanaw ni hai tui kahran a dap sak awh.   
\q1
\v 12 Ateng vah kalvan e tavanaw tabu a tuk awh teh,  
\q2 thingkungnaw dawk a cai awh.   
\q1
\v 13 A im van hoi monnaw tui a awi teh,  
\q2 na tawk e ni talai heh ka boum lah a kawk.   
\q1
\v 14 Talai ni rawca a tâco sak nahanlah  
\q2 saringnaw hanlah pho a paw sak teh  
\q2 taminaw hanlah thingthairompo a paw sak.   
\q1
\v 15 Misur ni tami lungthin a nawm sak,  
\q2 satui ni mei a kâpi sak, rawca ni tha ao sak.   
\q1
\v 16 BAWIPA e thingkung lebanon mon vah  
\q2 a ung e sidar thingnaw hai a boum awh.   
\q1
\v 17 Hawvah, tavanaw ni a tabu a tuk awh teh,  
\q2 hmaica thing teh kahrawng cawmpainaw e im lah ao.   
\q1
\v 18 Lungha teh Athanaw o nahanelah ao teh,  
\q2 savehnaw teh talung koe a kâhro awh.   
\q1
\v 19 Ama ni thapa hah hnintha  
\q2 touk nahanlah a sak teh,  
\q2 kanî ni khup nahan tue a panue.   
\q1
\v 20 Hmonae na sak teh hothateh karum doeh.  
\q2 ratu thung e saring pueng a tâconae tue lah ao.   
\q1
\v 21 Sendektanca ni kei hane a tawng teh,  
\q2 Cathut koehoi e rawca a tawng.   
\q1
\v 22 Kanî a tâco toteh a onae  
\q2 a kâkhu dawk lengkaleng a tabo awh.   
\q1
\v 23 Tami teh thaw tawk hanelah a tâco teh,  
\q2 tangmin lah totouh a tawk.   
\q1
\v 24 Oe BAWIPA, na sak e hno teh apap poung.  
\q2 Lungangnae hoi na sak e seng doeh.  
\q2 Talai teh na tawntanae hoi akawi.   
\q1
\v 25 Hete ka kaw ni teh kalen e talîpui dawkvah,  
\q2 touklek thai hoeh e saring kathoung kalen a kâhlai awh.   
\q1
\v 26 Haw e hmuen koe long a cei teh,  
\q2 hawvah ka paitun hanelah na sak e  
\q2 tangapui Leviathan hai ao.   
\q1
\v 27 A tue a pha toteh, rawca na poe thai nahanlah  
\q2 abuemlahoi nang na ring awh.   
\q1
\v 28 Na poe e pueng a la awh teh,  
\q2 na kut na dâw teh hno kahawi hoi a kâkawk awh.   
\q1
\v 29 Na minhmai na hro pouh toteh, a lungpuen awh.  
\q2 A kâha na lat pouh pawiteh  
\q2 a due awh teh vaiphu lah a coung awh.   
\q1
\v 30 Na Muitha na tha toteh hotnaw teh sak e lah ao.  
\q2 Talai meilam hai bout na katha sak.   
\q1
\v 31 BAWIPA bawilennae teh yungyoe kangning seh.  
\q2 BAWIPA teh a sak e dawk konawm naseh.   
\q1
\v 32 Talai a khet nah a pâyaw,  
\q2 mon a tek nah hmaikhu a tâco.   
\q1
\v 33 Ka hringyung thung BAWIPA koe la ka sak vaiteh,  
\q2 ka hringyung thung Cathut pholen hoi la ka sak han.   
\q1
\v 34 Ka khopouknae hah ahni hanelah radip naseh.  
\q2 BAWIPA dawk ka konawm han.   
\q1
\v 35 Tamikayon teh talai hoi raphoe lah awm naseh.  
\q2 Tamikathout awm hanh lawiseh.  
\q2 Oe kahringnae BAWIPA teh pholen haw.  
\q2 Hallelujah.   
\c 105  
\s1 A yungyoe BAWIPA yuemkamcunae  
\d Kathutkung: Devit  
\q1
\v 1 Oe, BAWIPA koe lunghawilawk dei awh.  
\q2 A min lahoi kaw awh nateh,  
\q2 a sak e hno hah tami pueng koe panueksak awh.   
\q1
\v 2 Ama koe la sak awh, ama koe la sak laihoi,  
\q2 a sak e hno kângairu hno pueng hah dei awh.   
\q1
\v 3 A min kathoung teh bari awh.  
\q2 BAWIPA katawngnaw e lungthin teh nawm naseh.   
\q1
\v 4 BAWIPA hoi a thaonae hah tawng awh nateh,  
\q2 a minhmai hah hoehoe tawng awh.   
\q1
\v 5 Kângairu hno a sak e hah hoehoe pâkuem awh nateh,  
\q2 kângairunae hoi a pahni dawk hoi  
\q2 ka tâcawt e lawkcengnae hah pâkuem awh.   
\q1
\v 6 Oe a san Abraham catoun,  
\q2 nangmouh Jakop catounnaw,  
\q2 ama ni rawi e lah na o awh.   
\q1
\v 7 Ama teh BAWIPA Cathut lah ao teh,  
\q2 a lawkcengnae ni talai pueng koung a katin.   
\q1
\v 8 A lawkkam teh pou a pâkuem teh  
\q2 se thong totouh nakunghai thoseh,   
\q1
\v 9 Abraham koe lawk a kam e hoi  
\q2 Isak koe thoe a bo e hai thoseh,  
\q2 kâ a poe e lawk teh a pâkuem.   
\q1
\v 10 Hotnaw teh Jakop Catounnaw hanelah,  
\q2 ka cak e phung lah a sak teh,  
\q2 Isarel hanelah a yungyoe e lawkkam doeh.   
\q1
\v 11 Kanaan ram heh râw lah  
\q2 na poe han telah lawk a kam.   
\q1
\v 12 Tami kayounca lah ao awh lahunnah,  
\q2 oe kayounca lah imyin lah ka o awh.   
\q1
\v 13 Kho touh hnukkhu kho touh,  
\q2 uknaeram hnukkhu alouke koe a kâva awh.   
\q1
\v 14 Ahnimouh rektap hane pasoung hoeh.  
\q2 Bokheiyah, ahnimouh kecu dawk  
\q2 siangpahrang hah a yue pouh.   
\q1
\v 15 Satui ka awi e naw hah tek awh hanh.  
\q2 Ka profetnaw hah runae poe hanh telah a ti.   
\q1
\v 16 Hothloilah, ram thung takang a tho sak teh,  
\q2 cang hoi apawhik naw koung a raphoe pouh.   
\q1
\v 17 Ahnimae hmalah a patoun awh e,  
\q2 Joseph teh san patetlah a yo awh.   
\q1
\v 18 a khok hlong a buet pouh awh teh,  
\q2 sumbawtarui hoi a rektap awh.   
\q1
\v 19 A dei tangcoung e a kuep hoehroukrak,  
\q2 BAWIPA ni ahni teh a tanouk.   
\q1
\v 20 Hottelah siangpahrang ni a patoun teh a tâco sak teh,  
\q2 ukkung lah o hanlah a hlout sak.   
\q1
\v 21 A imthungkhu kahrawikungnaw a tawn e pueng hoi,   
\q1
\v 22 a tami bawinaw yue thainae kâ hoi  
\q2 kahrawikungnaw lungangnae cangkhai hanelah,  
\q2 kaukkung lah a coung sak.   
\q1
\v 23 Isarel hai Izip ram lah a tho teh,  
\q2 Jakop hai Ham ram vah ao.   
\q1
\v 24 A taminaw moi a pung sak teh,  
\q2 ahnimouh ka tarannaw hlak  
\q2 a tha hoe kaawm lah a coung sak.   
\q1
\v 25 A taminaw hah a tarannaw ni a hmuhma awh teh,  
\q2 a sannaw hah huenghai hoi  
\q2 dumyen hanelah a lungthin a kâhleng sak.   
\q1
\v 26 A san Mosi hoi a rawi e  
\q2 Aron hoi a patoun.   
\q1
\v 27 Mitnout hah a taminaw koe a sak teh,  
\q2 Ham ram dawk kângairu hno hah a sak.   
\q1
\v 28 Hmonae hah a tho teh koung a hmo.  
\q2 Hahoi a lawk teh oun thai awh hoeh.   
\q1
\v 29 Ahnimae tui hah thi lah a coung sak teh,  
\q2 tangawn hah a due sak.   
\q1
\v 30 Ahnimae ram teh ekka hoi king akawi teh,  
\q2 siangpahrang imthung totouh koung akawi.   
\q1
\v 31 Lawk a dei boteh bitsei thouk a tâco teh  
\q2 ahri hai a ram pueng dawk a tâco.   
\q1
\v 32 Kho rak yueng lah roun a poe,  
\q2 a ram dawk hmaito hai a tâco sak.   
\q1
\v 33 Misurkung hoi thaibunglung kung  
\q2 koung a raphoe teh a ram dawk e  
\q2 thingkungnaw a khoe pouh.   
\q1
\v 34 Lawk a dei teh samtongnaw a tho awh teh,  
\q2 touklek hoeh lah a tho awh.   
\q1
\v 35 Hotnaw ni a ram dawk e  
\q2 apawhik pueng a ca teh,  
\q2 apawhik pueng hah capingkacailah a ca awh.   
\q1
\v 36 A ram dawk e camin pueng hai a raphoe teh,  
\q2 aluepaw pueng hai koung a raphoe pouh.   
\q1
\v 37 Hothloilah, sui hoi ngun hoi a tâco sak teh,  
\q2 a taminaw thung dawk kabawp han totouh,  
\q2 ka vout e awm hoeh.   
\q1
\v 38 A tâco awh navah, Izipnaw a lunghawi awh.  
\q2 Bangkongtetpawiteh, ahnimouh hah a taki awh.   
\q1
\v 39 Ka ngue hanelah tâmai a pâyam sak teh,  
\q2 khohmo ka ang sak hanlah hmai hah a poe.   
\q1
\v 40 Tamimaya ni a hei awh e tamuem hah a poe teh,  
\q2 kalvanlae rawca hoi a von a paha awh.   
\q1
\v 41 Lungsong a paawng teh, tui a tâco,  
\q2 kahrawngum palang patetlah a lawng.   
\q1
\v 42 Bangtelah tetpawiteh, a san  
\q2 Abraham koe kathounge a lawkkam hah pahnim hoeh.   
\q1
\v 43 A taminaw hah konawm laihoi a hrawi teh,  
\q2 a rawi e naw hah thadamcalah a hrawi.   
\q1
\v 44 A phunglam hah tarawi vaiteh,  
\q2 kâlawk a tarawi thai awh nahanlah,   
\q1
\v 45 Jentelnaw e ram hah a poe teh,  
\q2 ayâ ni a tawk tangcoung e hah a pang sak.  
\q2 Hallelujah.   
\c 106  
\s1 Isarel yon pankângainae dawk lunghawinae  
\d Kasakkung: panuekhoeh  
\q1
\v 1 BAWIPA teh pholen awh.  
\q2 Oe BAWIPA koe lunghawilawk dei awh.  
\q2 Bangkongtetpawiteh, ama teh ahawi.  
\q2 A lungmanae teh a yungyoe a kangning.   
\q1
\v 2 BAWIPA ni a sak e thaonae hah  
\q2 apinimaw a dei thai han.  
\q2 Apinimaw pholennae pueng  
\q2 koung a pholen thai han.   
\q1
\v 3 Nâtuek haiyah kalan lah ka tawksak e hoi  
\q2 lannae kâuepkhai e teh, tami yawkahawi e lah ao.   
\q1
\v 4 Oe BAWIPA na rawi e naw e hawinae hah  
\q2 ka hmu thai nahanlah thoseh,  
\q2 na miphun lunghawinae koe  
\q2 ka lunghawi nahan nange râw lah  
\q2 kaawmnaw hoi cungtalah lunghawi nahanelah thoseh,   
\q1
\v 5 Na taminaw ni a coe awh e na ngaikhainae hah  
\q2 na pahnim hanh lah a.  
\q2 Rungngangnae hoi pâtam haw.   
\q1
\v 6 Mintoenaw hoi reirei ka payon awh toe.  
\q2 Yonnae hah ka sak awh teh, hnokathout ka sak awh toe.   
\q1
\v 7 Mintoenaw ni Izip ram vah kângairu hno  
\q2 na sak e hah thaipanuek awh hoeh.  
\q2 na Lungmanae apapnae hai pâkuem awh hoeh.  
\q2 Tuipui paling teng patenghai taran a thaw awh.   
\q1
\v 8 Hatei, amae min thaonae bahu hoi duengdoeh na rungngang.  
\q2 A hnosakthainae hoi a thaonae  
\q2 panue sak thai nahane doeh.   
\q1
\v 9 Tuipui paling hai a yue teh rem a hak.  
\q2 Hottelah ka dungpoung e tui a raka awh teh,  
\q2 kahrawngum vah a hrawi.   
\q1
\v 10 Ama kahmuhmanaw e kut dawk hoi a rungngang teh,  
\q2 tarannaw kut dawk hoi a ratang.   
\q1
\v 11 Tarannaw hah tui ni koung a muem teh,  
\q2 buet touh hai ka hring e awm hoeh.   
\q1
\v 12 Hottelah a lawk hah a yuem awh teh,  
\q2 ama pholen hoi la a sak awh.   
\q1
\v 13 A sak awh e hah tang a pahnim awh teh,  
\q2 a noenae hah coe ngai awh hoeh.   
\q1
\v 14 Hatei, kahrawngum vah takthai  
\q2 ngainae a len dawkvah,  
\q2 kahrawngum vah Cathut hah a tanouk awh.   
\q1
\v 15 A hei awh e hah a poe.  
\q2 Hatei, muitha hringnae dawk kamsoenae hah a poe sin.   
\q1
\v 16 A roe awhnae koe Mosi hah a ut awh teh,  
\q2 Oe BAWIPA tamikathoung Aron hai a ut awh.   
\q1
\v 17 Talai ni a pahni a ang teh, Dathan hah a payawp.  
\q2 Abiram e taminaw hah koung a ramuk.   
\q1
\v 18 Ahnimouh koehoi hmai a tâco teh,  
\q2 tamikathoutnaw hmai koung a kak.   
\q1
\v 19 Horeb vah maitoca meikaphawk hah a sak awh teh,  
\q2 sakhlawn meikaphawk hah a bawk awh.   
\q1
\v 20 Hottelah a bawilennae teh,  
\q2 phovai ka cat e maitotan patetlah a coung sak awh.   
\q1
\v 21 Izip vah hno kalennaw a sak e hoi,   
\q1
\v 22 Ham vah a sak e kângairu hnonaw hoi,  
\q2 tuipuipaling koe e takikatho hno a sak e naw hoi  
\q2 ahnimouh ka rungngangkung Cathut teh a pahnim awh.   
\q1
\v 23 Hat toteh, a rawi e Mosi ni,  
\q2 a lungkhueknae hah takhoe vaiteh,  
\q2 ahnimanaw raphoe hoeh nahanelah,  
\q2 raphoenae hmuen, a hmalah kangdout hoeh pawiteh,  
\q2 ahnimanaw raphoe han telah a kâcai.   
\q1
\v 24 Hathnukkhu, kahawi e ram teh a pacekpahlek awh teh,  
\q2 a lawk hah yuem ngai awh hoeh.   
\q1
\v 25 Amamae rimnaw hah a phuenang sin awh teh,  
\q2 BAWIPA e lawk hah tarawi ngai awh hoeh.   
\q1
\v 26 Hatdawkvah, ahnimouh teh kahrawngum vah  
\q2 koung due sak hanelah thoseh,   
\q1
\v 27 A catounnaw hai miphunlouknaw koe  
\q2 tâkhawng hanelah hoi ram tangkuem kâkapek sak hane thoseh,  
\q2 ahnimae a vang lah thoe a bo.   
\q1
\v 28 Ahnimouh teh Peor e Baal hoi a kâkuet awh teh,  
\q2 tami kadout hmalah thueng e hno hah a ca awh.   
\q1
\v 29 Hottelah a sak awh e hno ni a lungkhuek sak teh,  
\q2 ahnimouh koe lacik kathout hah a tha pouh.   
\q1
\v 30 Hatnavah, Phinehas a kangdue teh,  
\q2 lawk a ceng navah lacik teh a roum.   
\q1
\v 31 Hothateh, ama lannae lah a yungyoe hoi se pueng dawk,  
\q2 pouk pouh e lah ao.   
\q1
\v 32 Meribah tui koehai a lungkhuek sak awh teh,  
\q2 ahnimouh kecu dawk Mosi koe  
\q2 totouh thoebonae teh a pha.   
\q1
\v 33 Mosi e a lungthin a  
\q2 tarawk awh dawkvah,  
\q2 pouk laipalah ahni teh lawk a dei.   
\q1
\v 34 BAWIPA ni a dei e patetlah sak hoeh.  
\q2 Miphunlouknaw raphoe laipalah ao awh.   
\q1
\v 35 Jentelnaw hoi a kâkalawt awh teh,  
\q2 ahnimae hringnuen hah a kamtu awh.   
\q1
\v 36 Ahnimae meikaphawk thaw hah a tawk awh.  
\q2 Hothateh ahnimouh hanelah karap doeh.   
\q1
\v 37 A capanaw hah thueng nahanelah a poe awh teh,  
\q2 a canunaw hah kahrai koe a poe awh.   
\q1
\v 38 Yon ka tawn hoeh e thi hah a rabawk awh teh,  
\q2 a capanaw hoi a canunaw e thi hoi roeroe vah,  
\q2 Kanaan ram meikaphawk cathut thuengnae lah  
\q2 a hno awh teh, hottelah thipalawng e lahoi  
\q2 ram a khin sak awh.   
\q1
\v 39 Hottelah a sak awh e hno hoi roeroe a kâkhinsak awh,  
\q2 a sak awh e hoi roeroe a yon awh.   
\q1
\v 40 Hatdawkvah, BAWIPA lungkhueknae teh  
\q2 a taminaw taran lahoi a kaman teh,  
\q2 a râw lah kaawm e hah a panuet.   
\q1
\v 41 Ahnimanaw teh Jentel kut dawk a poe teh,  
\q2 a hmuhma e naw ni a uk awh.   
\q1
\v 42 A taran ni rep a coungroe awh teh,  
\q2 a kut rahim vah ao awh.   
\q1
\v 43 Avai moikapap a rungngang toe.  
\q2 Hatei, amamouh khokhannae dawk hoi  
\q2 taran a thaw awh teh,  
\q2 amamae payonnae ni a rahnoum sak awh.   
\q1
\v 44 Hatei, runae a kâhmo awh toteh  
\q2 a hram awh e ka thai pouh teh,  
\q2 ahnimouh han pouk pouh laipalah awm thai hoeh.   
\q1
\v 45 Ahnimouh kecu dawk a lawkkam teh pou a panue teh,  
\q2 a lungmanae apap dawkvah, a pahren awh.   
\q1
\v 46 San lah kahrawinaw e lungthin dawk hai  
\q2 ahnimouh a pahren sak.   
\q1
\v 47 Na min kathoung dawk lunghawinae lawk dei hane hoi,  
\q2 na pholennae dawk tânae hmu hanelah,  
\q2 Oe BAWIPA maimae Cathut, na rungngang haw.  
\q2 Jentel miphun thung hoi cungtalah  
\q2 bout na pâkhueng haw.   
\q1
\v 48 Isarel BAWIPA Cathut teh,  
\q2 a yungyoe hoi a yungyoe totouh, pholen lah awm seh.  
\q2 Tami pueng ni Amen tet naseh.  
\q2 BAWIPA teh pholen awh.   
\c 107  
\s1 BAWIPA koe lunghawilawk deinae  
\d Kasakkung: panuekhoeh  
\q1
\v 1 Oe BAWIPA koe lunghawilawk hah dei awh.  
\q2 Bangkongtetpawiteh, ama teh ahawi,  
\q2 a lungmanae teh a yungyoe a kangning.   
\q1
\v 2 BAWIPA ni a ratang tangcoung,  
\q2 taran kut dawk hoi a ratang e naw ni,  
\q2 hottelah dei awh naseh.   
\q1
\v 3 Kho tangkuem hoi, kanîtho,  
\q2 kanîloum, aka, atung lahoi koung a pâkhueng.   
\q1
\v 4 Thingyeium ramke lamthung dawk a kâva awh teh,  
\q2 o nahane kho hmawt awh hoeh.   
\q1
\v 5 Vonhlam tui kahran hoi a lung apout awh.   
\q1
\v 6 Runae koehoi BAWIPA hah a kaw awh teh,  
\q2 rucatnae thung hoi a rasa awh.   
\q1
\v 7 Khosaknae hmuen khopui vah a cei thai awh nahanelah,  
\q2 lam kalan dawk a hrawi awh.   
\q1
\v 8 Oe taminaw niyah BAWIPA hawinae hoi  
\q2 taminaw hanelah kângairu hno a sak e naw dawkvah,  
\q2 lunghawilawk dei awh haw boipawiteh khe.   
\q1
\v 9 Bangtelah tetpawiteh, hringnae ni a rabui e hah kuep sak vaiteh,  
\q2 vonhlamrincinaw hah hawinae hoi a paha sak han.   
\q1
\v 10 Hmonae hoi duenae tâhlip dawk  
\q2 ka tahung e naw hah,  
\q2 runae sumrui hoi katek lah ao.   
\q1
\v 11 Bangkongtetpawiteh, Cathut lawk a oun, a taran awh teh,  
\q2 Lathueng Poung e pouknae hai banglah ngâi awh hoeh.   
\q1
\v 12 Hatdawkvah, ahnimae lungthin teh  
\q2 karanglah a tabut sak,  
\q2 a rawpkhai awh teh,  
\q2 kabawmkung apihai awm hoeh.   
\q1
\v 13 Hottelah runae koehoi BAWIPA a kaw awh teh,  
\q2 ahni ni amamae rucatnae thung hoi a tâco takhai.   
\q1
\v 14 Hmonae hoi duenae tâhlip thung hoi a rasa teh,  
\q2 ahnimouh kateknae sumbawtarui hah a rading pouh.   
\q1
\v 15 Oe taminaw niyah BAWIPA hawinae hoi taminaw  
\q2 hanelah kângairu hno a sak e naw dawkvah,  
\q2 lunghawilawk dei awh haw boipawiteh khe.   
\q1
\v 16 Ama ni rahum tho hah a raphoe teh,  
\q2 tarennae sumtaboung hah a raphoe.   
\q1
\v 17 Tamipathu hah kâtapoenae hoi  
\q2 a payonnae dawk runae khang sak lah ao.   
\q1
\v 18 A hringnae ni ca hane pueng a panuet teh,  
\q2 duenae tho koe a pâtam awh.   
\q1
\v 19 Hottelah runae koehoi BAWIPA a kaw awh teh,  
\q2 ahni ni amamae rucatnae thung hoi a tâco takhai.   
\q1
\v 20 A lawk patoun lahoi a dam sak teh,  
\q2 a kahmanae koehoi a rungngang.   
\q1
\v 21 Oe taminaw niyah BAWIPA hawinae hoi taminaw  
\q2 hanelah kângairu hno a sak e naw dawkvah,  
\q2 lunghawilawk dei awh haw boipawiteh khe.   
\q1
\v 22 Lunghawilawkdeinae thuengnae poe laihoi  
\q2 a tawk e naw hah lunghawi lahoi pâpho naseh.   
\q1
\v 23 Talîpui dawk long hoi kahlawng ka cet e,  
\q2 ka kaw e talîpui dawk hnopai kayawtnaw ni,   
\q1
\v 24 kadung poung e tui thung vah,  
\q2 kângairu hoi BAWIPA hno sak e hah ouk a hmu awh.   
\q1
\v 25 Bangkongtetpawiteh, ama ni kâ a poe teh kahlî a tho sak,  
\q2 hote kahlî ni tuicapa a thaw sak.   
\q1
\v 26 Kalvan totouh a luen teh,  
\q2 adungnae koe bout a bo awh teh,  
\q2 takithonae dawk a lung a pout awh.   
\q1
\v 27 Yamu ka parui e tami patetlah rawrawcu awh teh,  
\q2 bangtelah o nahan panuek awh hoeh.   
\q1
\v 28 Hottelah runae koehoi BAWIPA a kaw awh teh,  
\q2 ahni ni amamae rucatnae thung hoi a tâco takhai.   
\q1
\v 29 Kahlî a roum sak teh,  
\q2 tuicapa hai a roum.   
\q1
\v 30 Hottelah a roum dawkvah, a lunghawi teh,  
\q2 pha han ngaipoungnae hmuen koe a phakhai.   
\q1
\v 31 Oe taminaw niyah BAWIPA hawinae hoi  
\q2 taminaw hanelah kângairu hno  
\q2 a sak e naw dawkvah, lunghawilawk  
\q2 dei awh haw boipawiteh khe.   
\q1
\v 32 Tamimaya a kamkhuengnae koehai  
\q2 ama teh tawm awh naseh.  
\q2 Kacuenaw hmalah hai  
\q2 pholen awh naseh.   
\q1
\v 33 Ama ni palangpui hah ayawn lah a coung sak teh,  
\q2 tui hah talai kaphui e lah a coung sak.   
\q1
\v 34 Bangtelah tet pawiteh,  
\q2 a thung kaawm e yonnae kecu dawk,  
\q2 ram kahawi teh palawi talai lah ouk a coung sak.   
\q1
\v 35 Ayawn hah tuikamuemnae lah a coung sak teh,  
\q2 ramkenaw hah tui onae hmuen lah a coung sak.   
\q1
\v 36 Khosaknae hmuen khopui lah a kangdue thai nahan,  
\q2 vonkahlamnaw hah ao sak.   
\q1
\v 37 Moikapap a paw thai nahanelah,  
\q2 misur takha a sak awh.   
\q1
\v 38 Yawhawi a poe teh moikapap a pung sak.  
\q2 A paca e saringnaw kahma hane pasoung hoeh.   
\q1
\v 39 Repcoungroenae hoi runae,  
\q2 pankângainae kecu dawk rahnoumnae hoi,  
\q2 raphoe lah ao navah,   
\q1
\v 40 a tami bawinaw koe, pacekpahleknae a pha sak teh,  
\q2 lamthung ohoehnae kahrawngum vah, a kâva sak.   
\q1
\v 41 Hottelah hoi tami ka roedeng e hah  
\q2 runae tangkom dawk hoi hmuen rasangnae koe  
\q2 a tawm teh, saringhu patetlah imthung a sak pouh.   
\q1
\v 42 Tamikalannaw ni a hmu awh navah,  
\q2 a lunghawi awh. Payonnae ka sak pueng teh  
\q2 pahni tabuem pouh lah ao.   
\q1
\v 43 A lungkaang pueng ni hete hnonaw heh  
\q2 a pâkuem awh vaiteh,  
\q2 BAWIPA lungpatawnae hah a thai panuek awh han.   
\c 108  
\s1 Cathut tânae  
\d Kathutkung: Devit  
\q1
\v 1 Oe Cathut, ka lungthin heh a cak,  
\q2 pholennae na poe haw la ka sak han.  
\q2 Ka bawilennae totouh na poe han.   
\q1
\v 2 Ratoung tamawi kâhlaw haw.  
\q2 Kai hai amom ka kâhlaw han.   
\q1
\v 3 Oe BAWIPA, tamimaya hmalah na pholen han.  
\q2 Miphunnaw rahak vah,  
\q2 nang koe pholennae la ka sak han.   
\q1
\v 4 Bangkongtetpawiteh, na lungmanae ni kalvannaw totouh thoseh,  
\q2 na lawkkatang ni tâmai totouh thoseh a pha.   
\q1
\v 5 Oe Cathut, kalvannaw lathueng tawm lah awm nateh,  
\q2 na bawilennae teh talai van pueng lathueng vah, tawm lah awm seh.   
\q1
\v 6 Na pahren e naw hlout sak lah ao awh nahanelah,  
\q2 aranglae kut hoi rungngang nateh, na thai pouh haw.   
\q1
\v 7 Cathut ni, a thoungnae lahoi ka konawm vaiteh,  
\q2 Shekhem hah ka pek han.  
\q2 Sukoth ram hah koung ka bangnue han telah a ti.   
\q1
\v 8 Gilead teh kaie lah ao teh,  
\q2 Manasseh teh kai doeh.  
\q2 Ephraim hai kai hanlah bawilakhung lah ao teh,  
\q2 Judah teh ka tahroe lah ao.   
\q1
\v 9 Moab teh tui kamhluknae hlaam lah ao teh,  
\q2 Edom van vah khokkhawm ka tâkhawng han.  
\q2 Filistin van vah tânae ka pang han.   
\q1
\v 10 Ka cak e khopui dawk apinimaw na kaênkhai han.  
\q2 Edom vah apinimaw na hrawi han.   
\q1
\v 11 Oe Cathut, kai na ka pahnawt e  
\q2 nang ni na sak e nahoehmaw.  
\q2 Oe Cathut, kaimae ransanaw hoi cungtalah  
\q2 na ka cet hoeh e nang ni na sak nahoehmaw.   
\q1
\v 12 Runae thung hoi na kabawm haw.  
\q2 Bangkongtetpawiteh, taminaw e  
\q2 kabawpnae teh cungkeihoeh.   
\q1
\v 13 Cathut hoi cungtalah maimouh teh,  
\q2 taranhawi laihoi sak awh han.  
\q2 Bangkongtetpawiteh, ama teh,  
\q2 maimae tarannaw rep kacuengroekung doeh.   
\c 109  
\s1 Taran hanelah heinae  
\d Kathutkung: Devit  
\q1
\v 1 Oe ka pholen e ka Cathut, duem awm hanh.   
\q1
\v 2 Bangkongtetpawiteh, tamikathoutnaw hoi  
\q2 tami kadumyennaw ni, a pahni na ang sin awh teh,  
\q2 lai na thoe sin awh.   
\q1
\v 3 Hmuhmanae lawk hoi na kalup awh teh,  
\q2 a khuekhaw awm laipalah na tuk awh.   
\q1
\v 4 Ka lungpataw e naw teh na katarankung lah a coung awh.  
\q2 Hatei, ratoum laihoi ka o.   
\q1
\v 5 Ahnimouh ni hawinae hah hawihoehnae hoi na patho awh teh,  
\q2 ka pahrennae hah hmuhmanae hoi na patho awh.   
\q1
\v 6 Ahnimae lathueng vah tamikathoutnaw tat nateh,  
\q2 aranglah vah tarannaw awm naseh.   
\q1
\v 7 Lawkceng navah sung naseh,  
\q2 a ratoumnae teh yonnae lah coung pouh naseh.   
\q1
\v 8 A hringnae hnin duem naseh,  
\q2 a thaw teh ayâ alouk ni patawm naseh.   
\q1
\v 9 A canaw teh nara lah awm awh naseh,  
\q2 a yu teh lahmai naseh.   
\q1
\v 10 A canaw teh kâva awh naseh,  
\q2 ka rawk tangcoung e amamae hmuen koehoi  
\q2 rawca tawng awh naseh.   
\q1
\v 11 Tangka kacawisaknaw ni a canaw teh  
\q2 laiba dawk lat pouh naseh,  
\q2 a tawk teh a tawn tangcoung e hai  
\q2 apimouh ti panue hoeh e ni koung lat pouh naseh.   
\q1
\v 12 A lathueng vah apinihai lungmanae kamnuek sak hanh naseh.  
\q2 A ca naranaw hai apinihai pahren hanh naseh.   
\q1
\v 13 A ca catounnaw hai dout naseh.  
\q2 A catoun awm laipalah a min kahmat naseh.   
\q1
\v 14 A na mintoenaw e yonnae teh,  
\q2 BAWIPA hmalah pou pâkuem naseh.  
\q2 A manu yonnae raphoe pouh hanh naseh.   
\q1
\v 15 Hotnaw teh BAWIPA hmalah pou kamnuek naseh.  
\q2 Het talai van vah, ahnimouh pahnimhoehnae  
\q2 awm hanh naseh.   
\q1
\v 16 Bangkongtetpawiteh, lungmanae kamnue sak hanelah, panuek awh hoeh.  
\q2 A lung ka tangpawk e patenghai a thei thai awh nahanelah,  
\q2 a reikathai hoi mathoenaw hah a pacekpahlek awh.   
\q1
\v 17 Thoe a bo awh e hah amamouh lathueng bawt naseh.  
\q2 Banglahai a noutna awh hoeh e yawhawi ni  
\q2 ahla poungnae koe cettakhai naseh.   
\q1
\v 18 Thoebonae hah angki lah a kho e patetlah,  
\q2 a von dawk tui patetlah kâen naseh.  
\q2 A hru thung satui patetlah kâen naseh.   
\q1
\v 19 A kâkhu e hah a khohna patetlah coung naseh,  
\q2 taisawm patetlah a keng dawk pou kâyeng naseh.   
\q1
\v 20 Hothateh, ka tarannaw koe  
\q2 BAWIPA ni moipathungnae lah awm naseh.  
\q2 Na pathoe awh dawkvah,  
\q2 a pang awh e lah awm naseh.   
\q1
\v 21 Hateiteh Oe Bawipa Jehovah,  
\q2 kai hateh na min kecu dawk hawinae hoi  
\q2 na awmkhai haw.  
\q2 Na lungmanae dawkvah, na rungngang haw.   
\q1
\v 22 Tami ka roedeng hoi tami ka vout e lah doeh ka o.  
\q2 Ka thung vah ka lungthin teh hmâ a ca.   
\q1
\v 23 Kanîka patetlah ka kahma teh,  
\q2 awsi patetlah ka kâhuet.   
\q1
\v 24 Ka khokpakhu teh rawcahai kecu dawk cak hoeh,  
\q2 ka takthai teh a kamsoe.   
\q1
\v 25 Ahnimouh ni na pathoe hanelah ka o teh,  
\q2 na hmu awh toteh lû na saling sin awh.   
\q1
\v 26 Oe BAWIPA ka Cathut, na kabawm haw.  
\q2 Na lungmanae patetlah na rungngang haw.   
\q1
\v 27 BAWIPA, hethateh na kut hoi sak e doeh  
\q2 tie a panue thai awh nahanlah.   
\q1
\v 28 Ahnimouh ni thoe na bo eiteh,  
\q2 nang ni yawhawi na poe haw.  
\q2 Ahnimouh a thaw awh navah kayak awh naseh.  
\q2 Hatei, na san teh konawm naseh.   
\q1
\v 29 Na katukkungnaw teh kayanae ni ramuk awh naseh.  
\q2 Min mathoenae hni ni koung ramuk naseh.   
\q1
\v 30 Ka pahni hoi BAWIPA teh puenghoi ka pholen han.  
\q2 Bokheiyah, maya hmalah ama teh ka pholen han.   
\q1
\v 31 Bangkongtetpawiteh, yon kapennaw kut dawk hoi rungngang hanelah,  
\q2 ka roedengnaw e aranglah a kangdue han.   
\c 110  
\s1 Messiah uknae kong pathangnae  
\d Kathutkung: Devit  
\q1
\v 1 BAWIPA ni ka Bawipa koevah,  
\q2 na taran hah na khoktoungnae lah ka sak hoehroukrak,  
\q2 kaie kut arang lah tahung atipouh.   
\q1
\v 2 BAWIPA ni, na thaonae tahroe teh,  
\q2 Zion hoi ka patoun han.  
\q2 Na tarannaw lungui uk haw.   
\q1
\v 3 Na taran na tuk hnin vah,  
\q2 na taminaw teh amamouh lungthocalah hoi na thosin awh han.  
\q2 Na thoundounnaw teh amom e tadamtui patetlah,  
\q2 nang koe monkathoung dawkvah, a tâco awh han.   
\q1
\v 4 BAWIPA ni nang teh, Melkhizedek patetlah  
\q2 a yungyoe vaihma bawi telah thoe na bo toung dawkvah,  
\q2 nâtuek hai bout kâhno mahoeh toe.   
\q1
\v 5 BAWIPA teh nange aranglah ao teh,  
\q2 a lungkhueknae hnin dawk siangpahrangnaw koung na thei han.   
\q1
\v 6 Miphunnaw hah lawk koung ceng vaiteh,  
\q2 hmuen pueng koe tami ro hoi akawi han.  
\q2 Ram moikapap kahrawikungnaw hah koung a thei han.   
\q1
\v 7 Lam teng e sawkcanaw a nei awh vaiteh,  
\q2 lû hah a tawm awh han.   
\c 111  
\s1 A lannae hoi yuemkamcunae dawk Cathut pholennae  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 BAWIPA teh pholen awh.  
\q2 Tami kalannaw kamkhuengnae koe, maya um vah,  
\q2 BAWIPA teh ka lungthin abuemlahoi ka pholen han.   
\q1
\v 2 BAWIPA ni a sak e thaw teh a len.  
\q2 Ka ngai e pueng ni teh a kamtu awh.   
\q1
\v 3 A tawk e teh bari a kamcu teh, a sungren.  
\q2 A lannae teh a yungyoe a kangning.   
\q1
\v 4 Kângairu hno a sak e teh a yungyoe panue hanelah a sak.  
\q2 BAWIPA teh pahrennae hoi lungmanae hoi ka kawi e doeh.   
\q1
\v 5 Ama ka taketnaw hah rawca ca hane a poe.  
\q2 A lawkkam teh nâtuek hai pahnim hoeh.   
\q1
\v 6 Miphunnaw e râw hah a miphunnaw a poe teh,  
\q2 a taminaw koe a tawk e thaonae hah a pâpho pouh.   
\q1
\v 7 A kut hoi sak e naw teh lawkkatang hoi lannae lah ao.  
\q2 Phunglawknaw teh yuem a kamcu.   
\q1
\v 8 Hotnaw teh a yungyoe hoi a yungyoe a kangning han.  
\q2 Hotnaw teh lawkkatang hoi lannae hoi sak e lah ao.   
\q1
\v 9 A taminaw koe ratangnae hah a patawn teh,  
\q2 a lawkkam teh a yungyoe a kangning nahanlah, kâ a poe.  
\q2 A min teh a thoung, taki a tho.   
\q1
\v 10 BAWIPA taki e heh lungang kamtawngnae lah ao.  
\q2 Kâpoelawknaw katarawinaw ni thaipanueknae kahawi a tawn.  
\q2 Pholennae teh a yungyoe a kangning.   
\c 112  
\s1 Kalan e ram yawhawinae  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 BAWIPA teh pholen awh.  
\q2 BAWIPA ka taketnaw hoi kâpoelawknaw  
\q2 a lung kahawikhai katang e teh a yaw kahawi e doeh.   
\q1
\v 2 A catounnaw ni talai van a thao awh vaiteh,  
\q2 tami kalannaw e catounnaw teh a yawhawi awh han.   
\q1
\v 3 A im vah hnopai a tawnta awh vaiteh,  
\q2 a lannae teh a yungyoe a kangning han.   
\q1
\v 4 Tami kalan hanelah teh hmonae koehoi angnae a tâco teh,  
\q2 ama teh pahrennae lungmanae, lannae hoi ka kawi e lah ao.   
\q1
\v 5 Tami kahawi niteh, pahrennae lahoi a cawi sak teh,  
\q2 ama teh ka lan lah kho a sak han.   
\q1
\v 6 Khoeroe kâhuen mahoeh.  
\q2 Tami kalan teh panue e lah pou ao han.   
\q1
\v 7 Kamthang kahawihoehe ni taket sak mahoeh.  
\q2 BAWIPA a kâuep teh a lungthin a cak.   
\q1
\v 8 A lungthin caksak lah ao dawkvah,  
\q2 a tarannaw koe a ngai e a pha totouh, taket mahoeh.   
\q1
\v 9 Lungthocalah hoi a rei teh,  
\q2 karoedengnaw hah a poe toe.  
\q2 A lannae teh a yungyoe a kangning.  
\q2 A ki teh barinae lahoi tawm lah ao han.   
\q1
\v 10 Tamikathoutnaw ni hmawt awh vaiteh,  
\q2 a lungkhuek awh han.  
\q2 A hâkam kata awh vaiteh, koung atum pouh han.  
\q2 Tamikathoutnaw e ngainae teh koung a kahma pouh han.   
\c 113  
\s1 Cathut dawk hringnae  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 BAWIPA teh pholen awh.  
\q2 Oe BAWIPA e sannaw, pholen awh.  
\q2 BAWIPA min teh pholen awh.   
\q1
\v 2 BAWIPA min teh atuhoi a yungyoe ditouh  
\q2 pholen lah awm lawiseh.   
\q1
\v 3 Kanîtho koehoi kanîloum totouh,  
\q2 BAWIPA min teh pholen lah awm lawiseh.   
\q1
\v 4 BAWIPA teh miphun pueng e lathueng vah ao teh,  
\q2 a bawilennae teh kalvan hlak a rasang.   
\q1
\v 5 A rasang hmuen koe ao eiteh,  
\q2 BAWIPA Cathut patetlah apimouh kaawm .   
\q1
\v 6 Kalvan e hno hoi talai hnonaw ka khen e  
\q2 BAWIPA patetlah apimaw kaawm.   
\q1
\v 7 Mathoenaw hah vaiphu koehoi ka pathaw niteh,  
\q2 kavoutthoupnaw hah vaipuen koehoi a tawm teh,   
\q1
\v 8 bawinaw hai thoseh, a taminaw hoi  
\q2 cungtalah ao thai awh nahanelah thoseh hmuen a poe.   
\q1
\v 9 Cakaroe e napui o nahan im a poe teh,  
\q2 camo ka tawn e napui patetlah a konawm.  
\q2 Hallelujah.   
\c 114  
\s1 Isarel rungngang nahanelah kâheinae  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 Isarel hah Izip ram hoi a rasa teh,  
\q2 Jakop imthung hah lawk phunlouk koehoi a tâcokhai awh toteh,   
\q1
\v 2 Judah teh hmuen kathoung lah a coung.  
\q2 Isarel teh uknae lah a coung.   
\q1
\v 3 Talîpui ni a hmu teh a yawng,  
\q2 Jordan palang teh a ban.   
\q1
\v 4 Monnaw teh tutan patetlah,  
\q2 monruinaw teh tuca patetlah a coukdouk awh.   
\q1
\v 5 Oe talîpui bangdawkmaw na yawng,  
\q2 Oe Jordan palang, bangdawkmaw na ban.   
\q1
\v 6 Oe monnaw bangdawkmaw tutan patetlah na coukdouk.  
\q2 Oe monruinaw bangdawkmaw tuca patetlah na coukdouk awh.   
\q1
\v 7 Oe talai, BAWIPA hmalah pâyaw nateh,  
\q2 Jakop Cathut hmalah pâyaw haw.   
\q1
\v 8 Ama teh, lungsong hah tuikamuem lah,  
\q2 lungtaw hah tuiphuek lah kacoungsakkung doeh.   
\c 115  
\s1 Meikaphawk banglah a ohoehnae hoi Cathut yuem a kamcunae  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 Oe BAWIPA, na lungmanae hoi na lawkkatang kecu dawkvah,  
\q2 na bawilennae teh kaimouh koe laipalah,  
\q2 na min dawkvah awm lawiseh.   
\q1
\v 2 Bangkong mouh Jentelnaw niyah,  
\q2 ahnimae Cathut teh nâmouh ao ati awh va.   
\q1
\v 3 Maimae Cathut teh kalvan vah ao teh,  
\q2 a ngai e pueng hah ouk a sak.   
\q1
\v 4 Ahnimae meikaphawknaw teh sui hoi ngun lah ao awh teh,  
\q2 kut hoi sak e lah ao awh.   
\q1
\v 5 Pahni a tawn awh ei, lawk dei thai hoeh.  
\q2 Mit a tawn awh ei, hmawt thai hoeh.   
\q1
\v 6 Hnâ a tawn awh ei, thai awh hoeh.  
\q2 Hnawng a tawn awh ei, hmui thai awh hoeh.   
\q1
\v 7 Kut a tawn awh ei, banghai tek thai awh hoeh.  
\q2 Khok a tawn awh ei, cet thai awh hoeh.  
\q2 Hotnaw e lawkron dawk hoi lawk tâcawt hoeh.   
\q1
\v 8 Hotnaw kasakkung teh a sak awh e hoi doeh a kâvan awh.  
\q2 Hotnaw kâuep e hai sue touh lah a kâvan awh.   
\q1
\v 9 Oe Isarel, BAWIPA hah kâuep haw.  
\q2 Ahni teh nangmouh na kabawmkung hoi kângue e bahling doeh.   
\q1
\v 10 Oe Aron imthungnaw, BAWIPA hah kâuep awh.  
\q2 Ahni teh nangmouh kabawmkung hoi kânguenae bahling doeh.   
\q1
\v 11 Nangmouh BAWIPA ka taket e naw,  
\q2 BAWIPA hah kâuep awh haw.  
\q2 Ahni teh nangmouh kabawmkung hoi  
\q2 kânguenae bahling doeh.   
\q1
\v 12 BAWIPA ni pou na panue teh,  
\q2 yawhawi na poe han.  
\q2 Isarel imthung hai yawhawi a poe vaiteh,  
\q2 Aron imthung hai yawhawi a poe han.   
\q1
\v 13 BAWIPA ka taket e teh,  
\q2 tami kalen kathoung yawhawi a poe han.   
\q1
\v 14 Namamouh hoi na canaw khuehoi  
\q2 BAWIPA ni hoehoe na pung sak naseh.   
\q1
\v 15 Talai hoi kalvan kasakkung  
\q2 BAWIPA ni yawhawi na poe awh naseh.   
\q1
\v 16 Kalvan teh kalvannaw totouh BAWIPA e doeh.  
\q2 Hatei, talai teh talai taminaw hah a poe toe.   
\q1
\v 17 Tami kadout ni BAWIPA pholen hoeh.  
\q2 Duem kâhatnae koe kacettangcoungnaw nihai  
\q2 BAWIPA pholen boihoeh.   
\q1
\v 18 Hatei, maimouh niteh,  
\q2 BAWIPA hah atuhoi a yungyoe totouh pholen awh han.  
\q2 BAWIPA teh pholen awh.   
\c 116  
\s1 Duenae koehoi rungngangnae koe lunghawilawk deinae  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 BAWIPA teh ka lungpataw.  
\q2 Bangkongtetpawiteh, ka lawk hoi ka kâhei e hah na thai pouh.   
\q1
\v 2 Kai koe lah a hnâ a pakeng dawkvah,  
\q2 ka hringyung thung ka kaw han.   
\q1
\v 3 Due patawnae ni na kalup,  
\q2 sheol patawnae ni na kuet,  
\q2 kângairu lungmathoe hoi ka o.   
\q1
\v 4 Hat toteh, Oe BAWIPA,  
\q2 pahren lahoi ka hringnae hah na rungngang haw telah  
\q2 BAWIPA min teh ka palaw.   
\q1
\v 5 BAWIPA teh lungmakung hoi lannae lah ao.  
\q2 Bokheiyah, maimae Cathut teh lungmanae hoi akawi.   
\q1
\v 6 BAWIPA ni tami kamawngramenaw hah a khetyawt.  
\q2 Kai teh ka kârahnoum navah, ama ni na rungngang.   
\q1
\v 7 Oe, ka hringnae na lungmawngnae koe ban leih.  
\q2 Bangkongtetpawiteh, BAWIPA ni nang lathueng vah  
\q2 hnokahawi a sak toe.   
\q1
\v 8 Bangkongtetpawiteh, ka hringnae heh duenae koehoi  
\q2 na rungngang teh, ka mit heh mitphi bonae koehoi,  
\q2 ka khok heh tâlawnae koehoi na rungngang toe.   
\q1
\v 9 BAWIPA hmalah kahringnaw  
\q2 onae hmuen koe ka kâhlai han.   
\q1
\v 10 Kai teh ka yuem dawkvah, lawk ka dei,  
\q2 puenghoi na rektap awh.   
\q1
\v 11 Tami pueng laithoe a dei awh telah  
\q2 koe ka dei payon.   
\q1
\v 12 Kai lathueng vah, BAWIPA ni hnokahawi a sak e naw dawkvah,  
\q2 bangmouh ahni hanlah hawinae ka sak van han vai.   
\q1
\v 13 Rungngangnae manang hah ka la vaiteh,  
\q2 BAWIPA min teh ka kaw han.   
\q1
\v 14 Ka lawkkam e teh BAWIPA hmalah ka kuep sak han.  
\q2 A taminaw pueng e hmalah ka kuep sak han.   
\q1
\v 15 A tami kathoungnaw due e teh, BAWIPA hmalah a phuopoung.   
\q1
\v 16 Oe BAWIPA, na san lah ka o.  
\q2 Na sannaw e capa lah ka o.  
\q2 Kai dawk e kateknae teh na rathap pouh toe.   
\q1
\v 17 Lunghawilawkdeinae nalaihoi,  
\q2 BAWIPA min teh ka kaw han.   
\q1
\v 18 Atuvah, ka lawkkam e hah BAWIPA hoi  
\q2 a taminaw e hmalah ka kuep sak han.   
\q1
\v 19 Oe Jerusalem, na kho lungui  
\q2 BAWIPA e im thongma dawk roeroe ka kuep sak han.  
\q2 Hallelujah.   
\c 117  
\s1 Tami pueng ni pholen naseh  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 Miphunnaw pueng BAWIPA teh pholen awh.  
\q2 Taminaw pueng ama teh pholen awh.   
\q1
\v 2 Bangkongtetpawiteh, ahnie pahrenlungmanae teh  
\q2 maimouh koe a cak teh a len.  
\q2 BAWIPA e yuemkamcunae hai a yungyoe a kangning.  
\q2 Hallelujah.   
\c 118  
\s1 A lungmanae teh a yungyoe akangning  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 Oe BAWIPA koe lunghawilawk dei awh.  
\q2 Bangkongtetpawiteh, ama teh ahawi,  
\q2 a lungmanae teh a yungyoe a kangning.   
\q1
\v 2 A lungmanae teh a yungyoe a kangning telah  
\q2 Isarelnaw ni atu dei awh naseh.   
\q1
\v 3 A lungmanae teh a yungyoe a kangning telah  
\q2 Aron imthung ni atu dei awh naseh.   
\q1
\v 4 A lungmanae teh a yungyoe a kangning telah  
\q2 BAWIPA ka taket e naw ni atu dei awh naseh.   
\q1
\v 5 Ka lungpout nah BAWIPA ka kaw teh,  
\q2 BAWIPA ni hai na pato teh, hmuen akawnae koe na o sak.   
\q1
\v 6 BAWIPA ni na kampangkhai dawkvah ka taket mahoeh,  
\q2 Tami ni kai lathueng bangmouh a sak thai han.   
\q1
\v 7 BAWIPA teh na kabawm e lah ao.  
\q2 Hatdawkvah, na ka hmuhma e naw koe ka lungngai akuep han.   
\q1
\v 8 Tami kâuep hlak  
\q2 BAWIPA kâuep ahawihnawn.   
\q1
\v 9 Bawinaw kâuep hlak BAWIPA kâuep ahawihnawn.   
\q1
\v 10 Miphun pueng ni na kalup awh.  
\q2 Hatei, ahnimanaw teh BAWIPA min lahoi koung ka raphoe han.   
\q1
\v 11 Ahnimouh ni na kalup awh, na tuembue awh.  
\q2 Hatei, BAWIPA min lahoi koung ka raphoe han.   
\q1
\v 12 Khoi ni a kayo e patetlah na kalup nakunghai,  
\q2 buruk hmai kang e patetlah a roum awh.  
\q2 Bangkongtetpawiteh, BAWIPA min lahoi koung ka raphoe han.   
\q1
\v 13 Ka rawp nahanlah puenghoi na ka tanawt nakunghai,  
\q2 BAWIPA ni na kabawp.   
\q1
\v 14 BAWIPA teh ka tha hoi ka la doeh.  
\q2 Ahni teh kaie rungngangnae doeh.   
\q1
\v 15 Tami kalannaw e rim dawkvah,  
\q2 konawmnae pawlawk hoi rungngangnae pawlawk teh ao.  
\q2 BAWIPA e aranglae kut ni taranhawinae lahoi a tawk.   
\q1
\v 16 BAWIPA e aranglae kut teh, tawm lah ao teh,  
\q2 BAWIPA e aranglae kut ni taranhawi lahoi ouk a tawk.   
\q1
\v 17 Dout laipalah, ka hring vaiteh,  
\q2 BAWIPA hnosak e hah ka pâpho han.   
\q1
\v 18 BAWIPA ni puenghoi na yue, hatei due hane teh  
\q2 pasoung hoeh rah.   
\q1
\v 19 Lannae takhang teh na paawng pouh haw.  
\q2 Hawvah ka kâen vaiteh, BAWIPA ka pholen han.   
\q1
\v 20 Hethateh, BAWIPA e longkha,  
\q2 tami kalannaw a kâen nahane doeh.   
\q1
\v 21 Nang teh, na pholen han.  
\q2 Bangkongtetpawiteh, nang ni na pato teh,  
\q2 kaie rungngangnae lah na o.   
\q1
\v 22 Im kasakkungnaw ni a pahnawt awh e talung hah  
\q2 alawkpui poung e a takinlung lah ao.   
\q1
\v 23 Hothateh, BAWIPA ni a sak e doeh.  
\q2 Maimae mithmu haiyah kângairu hanlah ao.   
\q1
\v 24 Hethateh, BAWIPA ni a sak e hnin a tho.  
\q2 Hote hnin dawkvah, lunghawi awh han. Konawm awh han.   
\q1
\v 25 Oe BAWIPA, atu na rungngang haw telah ka ratoum.  
\q2 Oe BAWIPA kuepcingnae hah na poe haw telah ka ratoum.   
\q1
\v 26 BAWIPA min lahoi ka tho e teh tami yawkahawi e doeh.  
\q2 BAWIPA imthung hoi yawhawi teh na poe awh.   
\q1
\v 27 Cathut teh BAWIPA lah ao teh angnae hah na poe awh toe.  
\q2 Thueng nahane hateh thuengnae khoungroe ki dawk  
\q2 rui hoi pâkhit nateh pen awh.   
\q1
\v 28 Nang teh, kaie Cathut lah na o, na pholen han.  
\q2 Nang teh, ka Cathut lah na o. Na tawm han.   
\q1
\v 29 Oe, BAWIPA koe lunghawilawk dei awh.  
\q2 Bangkongtetpawiteh, ama teh ahawi.  
\q2 A lungmanae teh a yungyoe a kangning.   
\c 119  
\d Kathutkung: Panuekhoeh, tami tangawn ni Ezra a ti awh  
\s1 א ALEPH  
\d BAWIPA lawk dawk khosaknae  
\q1
\v 1 BAWIPA e a lamthung ka phen hoeh niteh,  
\q2 a lawk dawk ka dawn e tami teh a yawhawi.   
\q1
\v 2 Bawipa e lawkpanuesaknae ka hringkhai niteh,  
\q2 Bawipa hah a lungthin abuemlahoi ka tawng e teh a yawhawi.   
\q1
\v 3 Ahnimouh teh payonnae sak awh hoeh.  
\q2 Ahnie lamthung dawk a dawn awh.   
\q1
\v 4 Maimouh ni tarawi awh hanelah,  
\q2 Nang ni kâlawknaw hah na cangkhai awh toe.   
\q1
\v 5 Bawipa e phunglawknaw dawk ka dawn thai nahanlah,  
\q2 ka lamthungnaw teh lan naseh.   
\q1
\v 6 Kai ni Bawipa e kâpoelawknaw  
\q2 ka tarawi navah kayak mahoeh.   
\q1
\v 7 Nange kalan lah lawkcengnae ka kamtu navah,  
\q2 kalan e lungthin hoi nang teh, na pholen han.   
\q1
\v 8 Nange phunglawknaw hah ka tarawi han.  
\q2 Kai hah khoeroe na hnoun hanh loe.  
\s1 ב BETH  
\d Lawk   
\q1
\v 9 Nawsai ni amae lamthung hah  
\q2 bangtelamaw a thoungsak han tet pawiteh,  
\q2 Bawipa e a lawk patetlah a tarawi han.   
\q1
\v 10 Kai ni nang teh, ka lungthin abuemlahoi na tawng.  
\q2 Bawipa nange kâpoelawknaw dawk hoi kai na phensak hanh.   
\q1
\v 11 Bawipa koe ka yon hoeh nahanlah,  
\q2 ka lung thung a lawknaw hah ka hmouk toe.   
\q1
\v 12 Oe BAWIPA, nang teh yawhawi lah na o.  
\q2 Nange phunglawknaw hah na cangkhai haw.   
\q1
\v 13 Nang ni pahni hoi lawkcengnae pueng hah  
\q2 ka pahni hoi ka pâpho han.   
\q1
\v 14 Hnopai tawnta e dawk ka lunghawi e patetlah,  
\q2 nange panuesaknae lawk dawk ka konawm han.   
\q1
\v 15 Nange phunglawk hah luepluep pouk laihoi,  
\q2 na lamthungnaw hah ka bari han.   
\q1
\v 16 Nange phunglamnaw dawk kho ka sak han.  
\q2 Na lawk hah ka pahnim mahoeh.  
\s1 ג GIMEL  
\d Panuesaknae   
\q1
\v 17 Na san ni kahring vaiteh,  
\q2 na lawk ka tarawi thai nahanlah na pahren haw.   
\q1
\v 18 Nange na kâlawknaw dawk hoi kângairu hno  
\q2 ka hmu thai nahan ka mit ang sak haw.   
\q1
\v 19 Kai teh het talai van vah imyin lah ka o.  
\q2 Kâpoelawknaw hah hrawk hanh loe.   
\q1
\v 20 Nange lawkcengnae naw hah  
\q2 pou ka doun e lahoi ka lung a tangpo.   
\q1
\v 21 Nange kâpoelawknaw dawk hoi ka phen awh niteh,  
\q2 ka kâoupnaw hoi thoebo lah kaawm e naw hah yue haw.   
\q1
\v 22 Kai teh, nange panuesaknae hah  
\q2 ka tarawi dawkvah, pathoenae hoi  
\q2 banglah noutnahoehnae dawk hoi na hlout sak haw.   
\q1
\v 23 Kacuenaw ni a tahung awh teh,  
\q2 kai hah na ka taran awh nakunghai,  
\q2 nange na san teh, na phunglamnaw hah luepluep ka pouk han.   
\q1
\v 24 Nange lawkpanuesaknae teh,  
\q2 ka khosaknae hoi kâpankhaikung lah ao.  
\s1 ד DALETH  
\d Ukpadi   
\q1
\v 25 Ka muitha teh vaiphu dawk rep a kâbet.  
\q2 Na lawk dawk na hring sak haw.   
\q1
\v 26 Ka lamthung ka pâpho toteh nang ni na thai pouh.  
\q2 Na phunglamnaw hah na cangkhai haw.   
\q1
\v 27 Na phunglawk hah na panueksak haw,  
\q2 na sak e kângairu hno hah ka pouk han.   
\q1
\v 28 ka lungmathoe lahoi ka lungthin teh a kamyawt toe.  
\q2 Na lawk patetlah tha na awm sak haw.   
\q1
\v 29 Payonnae lamthung ka roun thai nahan na pahren nateh,  
\q2 kâlawknaw hah na poe haw.   
\q1
\v 30 Lam kalan teh ka rawi toe.  
\q2 na lawkcengnae naw teh kahma lah ka hruek toe.   
\q1
\v 31 Oe BAWIPA, na lawkpanuesaknae hah ka kuet.  
\q2 Na kayak sak hanh.   
\q1
\v 32 Ka lungthin na kaw sak toteh,  
\q2 na poe e kâpoelawknaw dawk tarawi laihoi ka yawng han.  
\s1 ה HE  
\d Phunglawk panue nahane   
\q1
\v 33 Oe BAWIPA, na phunglam hah na cangkhai haw.  
\q2 Apout totouh ka tarawi han.   
\q1
\v 34 Thaipanueknae hah na poe haw,  
\q2 na kâlawknaw teh ka tarawi han,  
\q2 oe ka lungthin abuemlahoi ka tarawi han.   
\q1
\v 35 Na poe e kâpoelawknaw hah na dawn sak haw.  
\q2 Bangkongtetpawiteh, hothateh, ka lunghawinae doeh.   
\q1
\v 36 Ka lungthin hah hounlounnae koe laipalah,  
\q2 na lawkpanuesaknae koe lah pahei haw.   
\q1
\v 37 Ahrawnghrang koe lah ka khet hoeh nahanlah,  
\q2 ka mit heh alouklah kangvawi sak haw.  
\q2 Na lamthung dawkvah, na hring sak haw.   
\q1
\v 38 Na san koevah, na lawk hah caksak haw.  
\q2 Nang takinae hoi a hring nahanlah.   
\q1
\v 39 Tamthoe takinae koehoi na kamlang sak haw.  
\q2 Bangkongtetpawiteh, na lawkcengnae teh ahawi.   
\q1
\v 40 Khenhaw! Na phunglawknaw teh ka rabui,  
\q2 na lannae hoi na roung sak haw.  
\s1 ו VAU  
\d Kâlawk   
\q1
\v 41 Oe BAWIPA na lawkkam e patetlah  
\q2 na lungmanae hoi  
\q2 na rungngangnae teh kai koe phat lawiseh.   
\q1
\v 42 Hottelah hoiyah, kai min mathoe ka dei e naw hah ka pathung thai han.  
\q2 Bangkongtetpawiteh, nange lawkkatang doeh ka kâuep.   
\q1
\v 43 Nange lawkcengnae hah ka ngaihawi dawkvah,  
\q2 lawkkatang lawk hah ka pahni dawk hoi na takhoe pouh hanh loe.   
\q1
\v 44 Kai teh nange kâlawknaw hah a yungyoe hoi  
\q2 a yungyoe totouh ka tarawi han.   
\q1
\v 45 Nange phunglawknaw hah ka tawng toung dawkvah,  
\q2 hloutnae dawkvah ka cei han toe.   
\q1
\v 46 Kai teh nange panuesaknae naw hah  
\q2 siangpahrangnaw hmalah ka pâpho han.  
\q2 Kayakkhai mahoeh.   
\q1
\v 47 Kai ni ka lungpataw e nange kâpoelawknaw dawkvah,  
\q2 kai teh ka lunghawikhai han.   
\q1
\v 48 Ka lungpataw e nange kâpoelawknaw hanlah,  
\q2 ka kut ka dâw vaiteh,  
\q2 nange phunglamnaw hah luepluep ka pouk han.  
\s1 ז ZAIN  
\d Phunglawk   
\q1
\v 49 Na san koe e lawk hah pahnim hanh.  
\q2 Hote ni doeh ngaihawinae na tawn sak.   
\q1
\v 50 Hethateh, runae kâhmo navah,  
\q2 ka lungmawngnae doeh.  
\q2 Bangkongtetpawiteh, na lawk ni hringnae na poe.   
\q1
\v 51 Ka kâoupnaw niteh, lung na paroum nah awh.  
\q2 Hatei, nange kâlawk teh ka phen takhai mahoeh.   
\q1
\v 52 Oe BAWIPA, yampa e na lawkcengnae teh ka pahnim hoeh  
\q2 Hothateh, ka lungmawngnae doeh.   
\q1
\v 53 Nange kâlawk kapahnawtnaw  
\q2 kecu dawkvah, ka lung a ro.   
\q1
\v 54 Kahlawng ka ceinae im dawkvah,  
\q2 na phunglawk teh kaie la lah doeh ao.   
\q1
\v 55 Oe BAWIPA, karum hai na min teh ka pahnim hoeh.  
\q2 Na kâlawk teh ka tarawi.   
\q1
\v 56 Na phunglawknaw teh ka tarawi dawkvah,  
\q2 kaie lah a coung awh.  
\s1 ח CHETH  
\d Bawipa e kâlawk kâuepnae   
\q1
\v 57 Oe BAWIPA, nang teh kai kaham doeh.  
\q2 Nange na lawk hah ka tarawi han telah ka dei toe.   
\q1
\v 58 Ka lungthin abuemlahoi na minhmai teh ka tawng.  
\q2 Na lawk patetlah kai na pahren haw.   
\q1
\v 59 Ka lamthungnaw hah ka pouk teh,  
\q2 ka khoktakannaw teh na panuesaknae koelah ka kamlang sak .   
\q1
\v 60 Kâpoelawknaw tarawi hanelah, hnawngcawn laipalah,  
\q2 karanglah ka kâroe.   
\q1
\v 61 Tamikaponaw e tangron ni na katek ei nakunghai,  
\q2 nange kâlawk teh ka pahnim hoeh.   
\q1
\v 62 Nang ni kalan lah na lawkcengnae dawkvah,  
\q2 karumsaning nang koe lunghawilawk dei hanelah ka thaw han.   
\q1
\v 63 Nang na ka taket e pueng hoi nange  
\q2 phunglawk katarawinaw e hui lah doeh ka o.   
\q1
\v 64 Oe BAWIPA, talai hah na lungmanae hoi akawi teh,  
\q2 na phunglam hah na cangkhai haw.  
\s1 ט TETH  
\d Bawipa e kâlawk ahawinae   
\q1
\v 65 Oe BAWIPA, na lawk patetlah  
\q2 na san kai koe na hawi toe.   
\q1
\v 66 Kai teh, na lawkcengnae kahawi hoi,  
\q2 panuethainae hah na cangkhai haw.  
\q2 Nange kâpoelawknaw hah ka yuem.   
\q1
\v 67 Kai teh runae kâhmo hoehnahlan vah lam ka payon.  
\q2 Atuteh nange na lawk heh ka tarawi toe.   
\q1
\v 68 Nang teh na hawi, hawinae hai na sak.  
\q2 Na phunglam hah na cangkhai haw.   
\q1
\v 69 Tami kâoupnaw niteh, kai hah laithoe hoi  
\q2 na ka taran nakunghai,  
\q2 kai teh nange phunglawknaw hah  
\q2 ka lungthin abuemlahoi ka tarawi.   
\q1
\v 70 Ahnimae lungthin teh sathaw patetlah a thâw.  
\q2 Kai teh, nange kâlawk doeh ka lunghawikhai.   
\q1
\v 71 Nange phunglam ka kamtu thai nahanlah,  
\q2 runae ka kâhmo e naw heh kai hanelah ahawi.   
\q1
\v 72 Suingun thong moikapap hlakvah,  
\q2 na pahni dawk hoi ka tâcawt e  
\q2 na lawk teh kai han lah ahawihnawn.  
\s1 י YOD  
\d Bawipa e kâlawk teh a lan   
\q1
\v 73 Bawipa nange kut ni kai hah na sak teh,  
\q2 meilam hah na poe toe.  
\q2 Nange kâpoelawknaw kamtu thai nahanlah,  
\q2 panuenae hoi na kawi sak haw.   
\q1
\v 74 Na lawk ka ngaihawinae dawkvah,  
\q2 Bawipa ka taketnaw ni kai na hmu awh toteh,  
\q2 a lunghawi awh han.   
\q1
\v 75 Oe BAWIPA, na lawkcengnae teh a lan.  
\q2 Runae na kâhmo sak e hai yuemkamcu lahoi  
\q2 na kâhmo sak tie ka panue.   
\q1
\v 76 Na san kai koe na lawk patetlah na lungmanae teh,  
\q2 ka lungmawngnae lah tho lawiseh telah ka ratoum.   
\q1
\v 77 Na lungmanae teh ka hring nahanlah kai koe kamnuek naseh.  
\q2 Bangkongtetpawiteh, nange kâlawk teh, ka lunghawinae lah ao.   
\q1
\v 78 Tami kâoupnaw teh, yeiraipo hoi awm awh naseh.  
\q2 Bangkongtetpawiteh, a khuekhaw awm laipalah,  
\q2 kai dawk kamsoum hoeh lah hno a sak awh.  
\q2 Hatei, kai teh, na phunglawknaw hah luepluep ka pouk.   
\q1
\v 79 Bawipa nang ka taket e nange kampangkhainaw ka panuek e naw teh,  
\q2 kai koe kamlang awh naseh.   
\q1
\v 80 Kaya hoeh nahanelah, ka lungthin teh  
\q2 na phunglamnaw dawk tounnae  
\q2 awm laipalah awm lawi naseh.  
\s1 ך KAPH  
\d Hlout nahanlah ratoumnae   
\q1
\v 81 Ka muitha teh na rungngangnae pouk laihoi tha a tâwn toe.  
\q2 Hatei, na lawk doeh ka ngaihawi.   
\q1
\v 82 Nâtuek maw lung na mawng sak han ti hoi  
\q2 ngaihawi laihoi ka mit tha abaw toe.   
\q1
\v 83 Bangkongtetpawiteh, tungking ka cawt e  
\q2 phaivuen um patetlah doeh ka o.  
\q2 Hatei, na phunglam teh ka pahnim hoeh.   
\q1
\v 84 Na san ka hringnae hah nâsittouh han na maw.  
\q2 Na ka rektap e naw hah nâtuek maw lawk na ceng han.   
\q1
\v 85 Tami kâoupnaw nange kâlawk katapoenaw ni  
\q2 kai hanelah tangkomnaw hah a tai awh toe.   
\q1
\v 86 Na kâlawknaw pueng teh, yuem a kamcu.  
\q2 Ahnimouh ni kamsoum hoeh lah na rektap awh,  
\q2 na kabawm haw.   
\q1
\v 87 Ahnimouh ni kai teh, talai van meimei na pahma awh toe.  
\q2 Hatei, nange phunglawknaw teh ka pahmat hoeh.   
\q1
\v 88 Na pahrenlungmanae hoi bout na kâhlaw sak haw.  
\q2 Na lawkpanuesaknae teh ka tarawi han.  
\s1 ל LAMED  
\d Bawipa e kâlawk teh yuemkamcu   
\q1
\v 89 Oe BAWIPA, na lawk teh kalvan kho vah  
\q2 a yungyoe a cak.   
\q1
\v 90 Yuemkamcunae teh a se tangkuem a kangning.  
\q2 Talai heh na caksak teh a kangning.   
\q1
\v 91 Hnocawngca pueng teh na san lah ao awh dawkvah,  
\q2 sahnin ditouh a kangning awh.   
\q1
\v 92 Na kâlawk heh ka lunghawinae lah awm hoeh pawiteh,  
\q2 yampa runae ka kâhmo navah, kadout han doeh toe.   
\q1
\v 93 Na phunglawk hah ka pahnim roeroe mahoeh.  
\q2 Bangkongtetpawiteh, hotnaw lahoi doeh hringnae teh na poe.   
\q1
\v 94 Nange lah ka o, na rungngang haw.  
\q2 Bangkongtetpawiteh, na phunglawk doeh ka tawng.   
\q1
\v 95 Tamikathoutnaw ni thei hanelah na pawp awh.  
\q2 Hatei, na lawkpanuesaknae hah luepluep ka pouk han.   
\q1
\v 96 Kuepnae pueng ni poutnae hai ka hmu toe.  
\q2 Hatei, kâpoelawk teh a kaw toungloung.  
\s1 ם MEM  
\d Bawipa e kâlawk teh ka ngai   
\q1
\v 97 Oe nange kâlawk teh ka lungpataw poung.  
\q2 Hothateh kanîruirui luepluep ka pouk e lah ao.   
\q1
\v 98 Nange kâpoelawknaw ni ka tarannaw hlak ka lung a ang sak.  
\q2 Bangkongtetpawiteh, kai koe pou ao awh.   
\q1
\v 99 Nange panuesaknae naw teh,  
\q2 luepluep ka pouk dawkvah,  
\q2 na kacangkhaikungnaw hlak hoe ka thaipanuek.   
\q1
\v 100 Nange phunglawknaw hah ka tarawi dawkvah,  
\q2 kacuenaw hlak hai ka thaipanuek.   
\q1
\v 101 Na lawk ka tarawi thai nahanlah,  
\q2 hawihoehnae lamthungnaw pueng heh ka roun.   
\q1
\v 102 Na lawkceng e naw hah ka roun hoeh.  
\q2 Bangkongtetpawiteh, nama roeroe ni na cangkhai toe.   
\q1
\v 103 Na lawk teh kai hanlah ka dangka dawk banghloimaw a radip.  
\q2 Kai hanlah ka pahni dawk khoitui hlak hai a radip.   
\q1
\v 104 Na phunglawknaw lahoi, thaipanueknae ka tawn toe.  
\q2 Hatdawkvah, lampaiheinaw teh ka hmuhma toe.  
\s1 ן NUN  
\d Bawipa e kâlawk teh angnae   
\q1
\v 105 Na lawk teh ka khok hanlah hmaiim lah ao teh,  
\q2 ka lamthung hanlah angnae lah ao.   
\q1
\v 106 Na lawkcengnae kalan teh  
\q2 ka tarawi han telah lawk ka kam toe.   
\q1
\v 107 Oe BAWIPA, kai teh puenghoi rektapnae ka kâhmo.  
\q2 Na lawk patetlah na hring sak haw.   
\q1
\v 108 Oe BAWIPA, lungthocalah hoi ka pahni hoi  
\q2 thuengnae hah na dâw pouh haw telah ka ratoum.  
\q2 Na lawkcengnae hah na cangkhai haw.   
\q1
\v 109 Ka hringnae heh ka kut dawk pou ao.  
\q2 Hatei, na lawk teh ka pahnim hoeh.   
\q1
\v 110 Tamikaponaw ni kai hanlah karap teh a patûng awh.  
\q2 Hatei, na phunglawk hah ka phen takhai mahoeh.   
\q1
\v 111 Na lawkpanuesaknae teh a yungyoe râw lah ka la toe.  
\q2 Bangkongtetpawiteh, lung kahawisakkung doeh.   
\q1
\v 112 Na phunglamnaw tarawi hanelah,  
\q2 ka lungthin hah pou ka hroecoe toe.  
\s1 ס SAMEK  
\d Bawipa e kâlawk teh kâhatnae   
\q1
\v 113 Ayawmyin e taminaw teh ka hmuhma,  
\q2 hatei nange kâlawk teh ka lungpataw.   
\q1
\v 114 Nang teh, ka kânguenae hoi bahling lah na o teh,  
\q2 na lawk teh ka ngaihawinae lah ao.   
\q1
\v 115 Nangmouh hawihoehnae kasaknaw kai koehoi kâkhoe awh.  
\q2 Bangkongtetpawiteh, ka Cathut e kâpoelawknaw dueng doeh  
\q2 ka pâkuem han.   
\q1
\v 116 Ka hring nahanlah na lawk patetlah na kangdout sak haw.  
\q2 Ka hawinae hah yeirai lah coungsak hanh.   
\q1
\v 117 Na kuen haw, ka hlout han.  
\q2 Na phunglam hah pou ka tarawi han.   
\q1
\v 118 Na phunglam dawk hoi ka phen e pueng heh koung na pahnawt.  
\q2 Bangkongtetpawiteh, ahnimae dumyennae teh laithoe doeh.   
\q1
\v 119 Talai tamikaponaw pueng teh,  
\q2 ei patetlah na tâkhawng.  
\q2 Hatdawkvah, nange lawkpanuesaknae teh ka lungpataw han.   
\q1
\v 120 Nang taki lawi ka takthai a pâyaw teh,  
\q2 na lawkcengnae hah ka bari.  
\s1 ע AIN  
\d Bawipa e kâlawk teh tarawi hane   
\q1
\v 121 Kai teh lawkcengnae hoi lannae hah katawksak toe.  
\q2 Rep kacuengroenaw koe na cettakhai hanh.   
\q1
\v 122 Na san kai hanlah kacakpounge kabawmkung lah awm nateh,  
\q2 ka kâoupnaw ni repcoungroe e lah na awm sak hanh.   
\q1
\v 123 Na rungngangnae hoi lannae lawk  
\q2 ka radoungnae koe ka mit teh tha abaw toe.   
\q1
\v 124 Na san hanelah na lungmanae kamnuek sak nateh,  
\q2 na phunglam hah na cangkhai haw.   
\q1
\v 125 Kai teh nange san doeh.  
\q2 Na lawkpanuesaknae hah ka panue thai nahanlah  
\q2 thaipanueknae na poe haw.   
\q1
\v 126 Oe BAWIPA, na tawk nahane tueng a pha toe.  
\q2 Bangkongtetpawiteh, na kâlawk teh banghai  
\q2 bang hoeh lah a coungsak awh.   
\q1
\v 127 Hatdawkvah, nange kâpoelawknaw teh  
\q2 sui hlak hai ka lungpataw teh,  
\q2 suituici hlak hai ka lung hoe ka pataw.   
\q1
\v 128 Hatdawkvah, bangpueng hlak hai  
\q2 na phunglawknaw hah a thuem telah ka pouk.  
\q2 Lampaihei teh ka hmuhma.  
\s1 ף PE  
\d BAWIPA e kâlawk teh tarawi ka ngai   
\q1
\v 129 Na lawkpanuesaknae teh kângai lah a ru.  
\q2 Hatdawkvah, ka hringnae ni a pâkuem.   
\q1
\v 130 Na lawk caisaknae ni angnae a poe teh,  
\q2 kamawngramnaw hah thaipanueknae a poe.   
\q1
\v 131 Ka kâko ka ang teh puenghoi ka kâha.  
\q2 Bangkongtetpawiteh, nange kâpoelawknaw hah ka rabui poung.   
\q1
\v 132 Na min kalungpatawnaw na pahrennae patetlah,  
\q2 na khen nateh, na pahren haw.,   
\q1
\v 133 Ka khoktakannaw hah na lawk hoi caksak haw,  
\q2 ka lathueng vah payonnae ni kâ tawn sak hanh.   
\q1
\v 134 Na phunglawknaw ka tarawi thai nahanlah,  
\q2 ayâ ni repcoungroenae hmuen koehoi na rasat haw.   
\q1
\v 135 Na san koevah, na minhmai ang sak nateh,  
\q2 na phunglam hah na cangkhai haw.   
\q1
\v 136 Ayânaw ni nange kâlawk a tarawi awh hoeh dawkvah,  
\q2 ka mitphi teh palang tui patetlah a lawng.  
\s1 ץ TZADDI  
\d BAWIPA E kâlawk teh Lannae   
\q1
\v 137 Oe BAWIPA, nang teh na lan doeh,  
\q2 na lawkcengnae hai a lan doeh.   
\q1
\v 138 Na poe e panuesaknae teh a lan teh,  
\q2 yuemkamcu e lah ao.   
\q1
\v 139 Ka tarannaw ni na lawk a pahnim awh dawkvah,  
\q2 ka lungthaonae ni kai teh na rek.   
\q1
\v 140 Na lawk teh a thoung tangngak.  
\q2 Hatdawkvah, na san kai ni ka ngai.   
\q1
\v 141 Kai teh tami titca, hnephnap e lah kaawm ei nakunghai,  
\q2 nange phunglamnaw teh ka pahnim hoeh.   
\q1
\v 142 Na lannae teh a yungyoe lannae lah ao teh,  
\q2 na kâlawk teh a thuem doeh.   
\q1
\v 143 Runae hoi mathoenae ni na ka tho sin nakunghai,  
\q2 nange kâpoelawknaw teh ka lunghawinae lah ao.   
\q1
\v 144 Na panuesaknae lannae teh  
\q2 a yungyoe a kangning, thaipanueknae  
\q2 na poe haw ka hring han.  
\s1 ק KOPH  
\d Hlout nahan ratoumnae   
\q1
\v 145 Ka lungthin abuemlahoi na kaw,  
\q2 Oe BAWIPA na thai pouh haw,  
\q2 na phunglam teh ka tarawi han.   
\q1
\v 146 Nang koe ka hramki, na rungngang haw.  
\q2 Na lawkpanuesaknae teh ka tarawi han.   
\q1
\v 147 Khodai hoehnahlan ka thaw teh,  
\q2 kabawpnae hei laihoi ka hram.  
\q2 Na lawk teh ka ngaihawi.   
\q1
\v 148 Na lawk lueplueppouk thai nahan,  
\q2 karum tuettuet ip laipalah ka hra.   
\q1
\v 149 Na lungpatawnae patetlah ka lawk hah na thai pouh haw.  
\q2 Oe BAWIPA na lawkcengnae patetlah na hring sak haw.   
\q1
\v 150 Hawihoehnae kasaknaw teh hoehoe a hnai awh toe.  
\q2 Na kâlawk hoi ahlanae koe ao awh.   
\q1
\v 151 Oe BAWIPA, nang teh na hnai teh,  
\q2 nange kâpoelawknaw teh lawkkatang doeh.   
\q1
\v 152 Na lawkpanuesaknae a yungyoe na ta e hah  
\q2 ahmaloe hoi ka panue toe.  
\s1 ר RESH  
\d Rungngang nahan ratoumnae   
\q1
\v 153 Ka khang e runae hah khen nateh,  
\q2 na rungngang haw.  
\q2 Bangkongtetpawiteh, nange kâpoelawk teh ka pahnim hoeh.   
\q1
\v 154 Kai hanelah pouk nateh, na ratang haw.  
\q2 Na lawk patetlah na pâhlaw haw.   
\q1
\v 155 Rungngangnae teh tami kahawihoehnaw koehoi ahla toungloung.  
\q2 Bangkongtetpawiteh, na phunglam hah tawng awh hoeh.   
\q1
\v 156 Oe BAWIPA ka kamcu e na lungmanae teh a len tangngak.  
\q2 Na lawkcengnae patetlah na pâhlaw haw.   
\q1
\v 157 Na ka pacekpahlek e hoi ka taran apap.  
\q2 Hatei, na panuesaknae teh ka phen hoeh.   
\q1
\v 158 Lawkkam kacakhoehnaw ka hmu nah,  
\q2 ka lung caca a pataw.  
\q2 Bangkongtetpawiteh, na lawk tarawi ngai awh hoeh.   
\q1
\v 159 Nange phunglawknaw ka lungpatawnae heh na pouk pouh haw.  
\q2 Oe BAWIPA, na pahrenlungmanae patetlah na pâhlaw haw.   
\q1
\v 160 Na lawk pueng teh lawkkatang doeh,  
\q2 kalan lah lawkcengnae teh, a yungyoe a kangning.  
\s1 ש SHIN  
\d Bawipa kâlawk tarawi han ka ngai   
\q1
\v 161 Bawinaw ni a khuekhaw awm laipalah na rektap awh.  
\q2 Hatei, ka lungthin teh kângaikaru na lawk dawkvah a kangdue.   
\q1
\v 162 Hnopai moi ka tawnta e patetlah  
\q2 na lawk ni ka konawm sak.   
\q1
\v 163 Laithoe lawk teh ka hmuhma, ka panuet.  
\q2 Hatei, nange kâlawk teh ka ngai.   
\q1
\v 164 Na lawkcengnae a lan dawkvah,  
\q2 hnin touh dawk vaisari touh ka pholen.   
\q1
\v 165 Kâlawk ka lungpataw naw koe lungmawngnae kalen ao.  
\q2 Lungpout nahane awm hoeh.   
\q1
\v 166 BAWIPA, na rungngangnae heh ka ngaihawi.  
\q2 Na kâpoelawknaw hah ka tarawi.   
\q1
\v 167 Na panuesaknae heh ka hringnae ni a tarawi teh,  
\q2 ka lungpataw katang doeh.   
\q1
\v 168 Na phunglawk hoi na lawkpanuesaknae teh ka tarawi.  
\q2 Bangkongtetpawiteh, ka lamthung pueng teh na hmalah ao.  
\d ת TAU: Kabawp heinae ratoum   
\q1
\v 169 Oe BAWIPA, ka hramnae lawk teh nang koe phat naseh.  
\q2 Na lawk patetlah thaipanueknae na poe haw.   
\q1
\v 170 Ka kâheinae teh nang koe phat naseh,  
\q2 na lawk patetlah na rungngang haw.   
\q1
\v 171 Nange phunglawk hah na cangkhai dawkvah,  
\q2 ka pahni ni a pholen han.   
\q1
\v 172 Ka lai ni na lawk a dei han.  
\q2 Bangkongtetpawiteh, nange kâpoelawknaw pueng teh lannae lah ao.   
\q1
\v 173 Na kut teh na kabawmkung lah awm seh.  
\q2 Bangkongtetpawiteh, na phunglawk hah ka rawi toe.   
\q1
\v 174 Oe BAWIPA, na rungngangnae teh ka rabui toungloung.  
\q2 Na kâpoelawk teh ka lunghawinae doeh.   
\q1
\v 175 Ka hringnae teh hring naseh.  
\q2 Na pholen han.  
\q2 Na lawkcengnae ni na ka bawm naseh.   
\q1
\v 176 Tu kahmat e patetlah ka kahma.  
\q2 Na san heh na tawng haw.  
\q2 Bangkongtetpawiteh, nange kâpoelawknaw teh ka pahnim hoeh.   
\c 120  
\d Kathutkung: Panuekhoeh, tami tangawn ni Hezekiah a ti awh  
\q1
\v 1 Kai teh runae kâhmo navah,  
\q2 BAWIPA ka kaw teh Bawipa ni na pato.   
\q1
\v 2 Oe BAWIPA, ka muitha hah laithoe e pahni dawk hoi thoseh,  
\q2 dumyennae lai dawk hoi thoseh, na rungngang haw.   
\q1
\v 3 Oe dumyennae lai, Bawipa ni nang hah  
\q2 bangtelah vaimoe na ti han vai,  
\q2 nang hah bang hoi vaimoe runae na poe han vai tet pawiteh,   
\q1
\v 4 athakaawmnaw e kahran e pala hoi  
\q2 kongkang hmaisaan hoi doeh.   
\q1
\v 5 Kai teh, Meshek ram vah, kahlawng ka cei teh  
\q2 Kedarnaw e rim dawk ka o dawkvah,  
\q2 yawthoe lah a o   
\q1
\v 6 Ka muitha teh roumnae ka hmuhma e naw hoi  
\q2 rei ao e hroung asaw toe.   
\q1
\v 7 Kai teh roumnae ka ngai.  
\q2 Hatei, ka dei navah,  
\q2 ahnimouh teh tarantuk hane doeh a ngai awh.   
\c 121  
\s1 Kabawpnae teh BAWIPA koehoi a tho  
\d Kathutkung: Panuekhoeh, tami tangawn ni Hezekiah a ti awh  
\q1
\v 1 Kabawpnae teh nâhoi maw a tho han ka titeh,  
\q2 monnaw koelah ka khet.   
\q1
\v 2 Kalvan hoi talai kasakkung  
\q2 BAWIPA koehoi doeh a tho.   
\q1
\v 3 Bawipa ni na khok tâlaw sak hoeh.  
\q2 Nang khenyawnkung teh ngâm boihoeh.   
\q1
\v 4 Atangcalah Isarelnaw khenyawnkung  
\q2 Ahni teh ngâm boihoeh, ip hai ip boihoeh.   
\q1
\v 5 BAWIPA ni nang teh, na khetyawt.  
\q2 BAWIPA teh, aranglae tâhlip, na kângue e doeh.   
\q1
\v 6 Khodai vah kanî, karum vah thapa ni  
\q2 runae na poe mahoeh.   
\q1
\v 7 BAWIPA ni runae pueng thung hoi na khetyawt han,  
\q2 na hringnae hai a khetyawt han.   
\q1
\v 8 BAWIPA ni, na ceinae,  
\q2 na thonae pueng hah  
\q2 atuhoi pout laipalah, a khetyawt han.   
\c 122  
\s1 Jerusalem hanelah ratoum awh sei  
\d Kathutkung: Devit  
\q1
\v 1 BAWIPA e im dawk cet awh sei telah,  
\q2 kai koe ati awh navah, ka lunghawi.   
\q1
\v 2 Oe Jerusalem, kaimae khok teh,  
\q2 nange takhang thungvah a kangdue han.   
\q1
\v 3 Jerusalem teh kacakpounglah sak e lah ao.   
\q1
\v 4 BAWIPA e miphunnaw teh hote kho dawk a cei awh katang.  
\q2 Isarelnaw e phung patetlah BAWIPA e a miphunnaw teh  
\q2 BAWIPA min pholen hanelah,  
\q2 BAWIPA min pholen nahanelah a ceitakhang awh.   
\q1
\v 5 Bangkongtetpawiteh, hote hmuen koevah, bawitungkhungnaw,  
\q2 Devit imthung bawitungkhungnaw lawkceng nahanelah a hruek awh.   
\q1
\v 6 Jerusalem a roum nahanlah ratoum awh.  
\q2 Nang lungpataw naw teh a hmacawn awh naseh.   
\q1
\v 7 Nange rapannaw roumnae awmseh.  
\q2 Na impui hawinae coe awh naseh.   
\q1
\v 8 Ka hmaunawngha han hoi ka huikonaw hanelah,  
\q2 nang dawk roumnae awm seh telah ka dei han.   
\q1
\v 9 Maimae BAWIPA Cathut im hane dawkvah,  
\q2 nange hawinae hah ka tawng han.   
\c 123  
\s1 BAWIPA ngaihawinae  
\d Kathutkung: Panuekhoeh, tami tangawn ni Hezekiah a ti awh  
\q1
\v 1 Kalvan kho a tungkhung kaawm e  
\q2 nang koe doeh ka ngaihawi .   
\q1
\v 2 Sanpanaw ni a bawipa kut a ngaihawi e patetlah thoseh,  
\q2 Sannunaw ni a bawipa kut a ngaihawi e patetlah thoseh,  
\q2 kaimouh ni lungmanae ka coe awh hoehroukrak  
\q2 BAWIPA Cathut doeh na ngaihawi awh.   
\q1
\v 3 Oe BAWIPA, kaimouh na lungma haw.  
\q2 Kaimouh na lungma haw. Bangkongtetpawiteh,  
\q2 banglah noutnahoehnae teh koung ka boum awh toe.   
\q1
\v 4 Kaimae hringnae teh, ka kâoupnaw ni yeiraipo saknae hai thoseh,  
\q2 lunglenpansa lah kaawm naw ni banglah noutnahoehnae hai thoseh,  
\q2 koung ka boum awh toe.   
\c 124  
\s1 Maimouh koe kaawm e BAWIPA  
\d Kathutkung: Devit  
\q1
\v 1 BAWIPA ni na awmkhai hoeh pawiteh,  
\q2 telah Isarelnaw ni atu a dei awh hane teh,   
\q1
\v 2 BAWIPA teh maimouh koe lah awm hoeh pawiteh,  
\q2 taminaw ni na taran awh navah,   
\q1
\v 3 a lungkhuek awh vaiteh, maimouh hah  
\q2 hringo na payawp awh toe.   
\q1
\v 4 Hatnavah, tui ni maimanaw teh  
\q2 muen na ramuk teh tui ka lawng e ni,  
\q2 maimae hringnae van muen a lawng sin toe.   
\q1
\v 5 Puenghoi kalawng e tui ni maimae hringnae teh  
\q2 muen a lawng sin toe, tie hah doeh.   
\q1
\v 6 Ahnimouh ni hâ hoi na ai awh nahanelah,  
\q2 maimanaw hah ahnimouh koe na poe awh hoeh.  
\q2 BAWIPA teh pholen lah awm seh.   
\q1
\v 7 Maimae hringnae teh, tangkam dawk hoi  
\q2 kahlout e tava patetlah a hlout toe.  
\q2 Tangkam a lawt teh, maimouh hlout awh toe.   
\q1
\v 8 Maimouh kabawpnae teh, kalvan hoi talai ka sak e  
\q2 BAWIPA min lahoi coe awh.   
\c 125  
\s1 Miphunnaw ni kâuepnae  
\d Kathutkung: Panuekhoeh, tami tangawn ni Hezekiah a ti awh  
\q1
\v 1 BAWIPA ka kâuep e naw teh,  
\q2 kâhuen hoeh niteh, a yungyoe kangning e  
\q2 Zion mon patetlah ao han.   
\q1
\v 2 Monnaw ni Jerusalem a kalup e patetlah,  
\q2 BAWIPA ni a miphunnaw hah atuhoi pout laipalah a kalup.   
\q1
\v 3 Tami kalannaw ni amamae kut hoi,  
\q2 kahawihoehe hno a sak awh hoeh nahanelah,  
\q2 tamikaponaw e sonron teh,  
\q2 tami kalannaw e râw talai dawk awm hanh naseh.   
\q1
\v 4 Oe BAWIPA, tami kahawinaw hoi  
\q2 tami kalannaw koe hawinae sak haw.   
\q1
\v 5 Amamae dumyennae lam dawk ka cet e naw hateh,  
\q2 yonnae ka sak e naw hoi cungtalah,  
\q2 BAWIPA ni a pâlei han. Isarelnaw koe roumnae awm lawiseh.   
\c 126  
\s1 Zion hawinae bout a coe sak  
\d kathutkung: panuekhoeh  
\q1
\v 1 A man awh teh a hrawi awh e Zioncanaw hah  
\q2 BAWIPA ni bout a ban sak toteh,  
\q2 kai teh mang ka mang e patetlah ka o.   
\q1
\v 2 Hat toteh, kaimae pahni teh panuinae hoi thoseh,  
\q2 kaimae lai teh, la saknae hoi thoseh a kawi han.  
\q2 Ayânaw niteh, BAWIPA ni ahnimouh hanelah  
\q2 hno kalen a sak pouh toe, telah miphunnaw rahak vah a dei awh.   
\q1
\v 3 BAWIPA ni kaimouh hanlah hno kalen a sak toe.  
\q2 Kaimouh teh ka lunghawi awh.   
\q1
\v 4 Oe BAWIPA, a man awh teh, a hrawi awh e kaimanaw hah,  
\q2 Negeb e palangtui patetlah bout tho sak haw.   
\q1
\v 5 Mitphi tui hoi cati katunaw ni  
\q2 lunghawi la sak laihoi a a awh han.   
\q1
\v 6 Cati ka phawt niteh, tha thout laipalah,  
\q2 khuika laihoi ka tâcawt e tami teh,  
\q2 cabongnaw hrawm vaiteh,  
\q2 lunghawi la sak laihoi bout a ban katang han.   
\c 127  
\s1 BAWIPA ni im sak hoeh pawiteh  
\d kathutkung: Solomon  
\q1
\v 1 BAWIPA ni im sak hoeh pawiteh,  
\q2 ka tawk e pueng ni ayawmyin doeh a tawk awh.  
\q2 BAWIPA ni kho ring hoeh pawiteh,  
\q2 ka ring e pueng ni ayawmyin doeh a ring awh.   
\q1
\v 2 Amom ka thaw niteh, karumsaning torei ka ip niteh,  
\q2 nget ka tawn lah tawk laihoi ka cat nakunghai,  
\q2 ayawmyin doeh.  
\q2 Bangkongtetpawiteh, Bawipa ni a pahren e naw koe  
\q2 duedue inae a poe.   
\q1
\v 3 Khenhaw! Canu capanaw teh, BAWIPA ni na poe e râw doeh.  
\q2 Khe e camo teh, tawkphu doeh.   
\q1
\v 4 Na naw nah na khe e canu capanaw teh,  
\q2 athakaawme tami kut dawk e pala hoi a kâvan.   
\q1
\v 5 Ama e palabom hah hote palasamtang hoi  
\q2 ka kawi sak e tami teh a yawhawi.  
\q2 Ahnimouh teh, kayanae awm mahoeh.  
\q2 Tarannaw hah longkha koe a ngang awh han.   
\c 128  
\s1 BAWIPA ka taket e imthung  
\d Kathutkung: Panuekhoeh, tami tangawn ni Hezekiah a ti awh  
\q1
\v 1 BAWIPA ka taket niteh, a lamthung ka dawn e tami pueng teh,  
\q2 tami yawkahawi e doeh.   
\q1
\v 2 Hottelah na sak pawiteh, nang teh na kut hoi  
\q2 na tawk e hah atangcalah na ca han.  
\q2 Yawhawi awm vaiteh, lunghawinae na coe han.   
\q1
\v 3 Na yu teh na im thung kaawm niteh,  
\q2 a paw moi kapaw e misurkung hoi a kâvan.  
\q2 Na canu capanaw teh, na caboi petkâkalup lah,  
\q2 ung e olivekungnaw patetlah ao awh han.   
\q1
\v 4 Khenhaw! Bawipa ka taket e teh,  
\q2 hot patet e yawhawinae a coe han.   
\q1
\v 5 BAWIPA ni Zion hoi yawhawi na poe seh.  
\q2 Na hringyung thung Jerusalem e hawinae na hmawt naseh.   
\q1
\v 6 Na canaw ni a khe e canaw hai na hmawt naseh.  
\q2 Isarelnaw koe roumnae awm seh.   
\c 129  
\s1 Taran tâ nahanelah ratoumnae  
\d Kathutkung: Panuekhoeh, tami tangawn ni Hezekiah a ti awh  
\q1
\v 1 Ka nawca hoiyah ahnimouh ni na rektap awh,  
\q2 telah Isarelnaw ni tet awh naseh.   
\q1
\v 2 Ka nawca hoiyah ahnimouh ni kai teh, na rektap awh.  
\q2 Hatei, na tâ awh hoeh.   
\q1
\v 3 Ka hnukthun vah talai thawn e patetlah a thawn awh teh,  
\q2 laikong kasawlah a sak awh.   
\q1
\v 4 Hatei, BAWIPA teh a lan.  
\q2 Ahni ni tamikaponaw e tangronnaw teh,  
\q2 thouk thouk a bouk pouh.   
\q1
\v 5 Zion kahmuhmanaw pueng teh,  
\q2 kayak awh naseh, hnuklah ban awh naseh.   
\q1
\v 6 Ahnimouh teh, a kung a len hoehnahlan  
\q2 remke e lemphu e phokung patetlah awm awh naseh.   
\q1
\v 7 Hote pho teh, kaanaw hanelah,  
\q2 kut kasum khuem hai phat hoeh.  
\q2 Ka tangoungnaw hanelah, tapam khuem hai phat hoeh.   
\q1
\v 8 Ka cet kaawm pueng nihai,  
\q2 BAWIPA e yawhawi teh nangmouh koe awm lawiseh.  
\q2 Kaimouh ni BAWIPA min lahoi nangmouh  
\q2 yawhawi na poe awh telah a dei awh mahoeh.   
\c 130  
\s1 BAWIPA ni ratangnae  
\d Kathutkung: Panuekhoeh, tami tangawn ni Hezekiah a ti awh  
\q1
\v 1 Oe BAWIPA, kai ni a dungnae koehoi na kaw.   
\q1
\v 2 Oe Cathut, kaie lawk hah na thai pouh haw.  
\q2 Kai ni ka kâheinae lawk hah hnâpakeng haw.   
\q1
\v 3 Oe Bawipa Jehovah, nang ni payonnae hah  
\q2 na pâkuem pawiteh, apimouh ka khang thai han va.   
\q1
\v 4 Hatei, nang ni na ngaithoum dawkvah,  
\q2 taminaw ni nang teh, na taki awh teh na bari awh.   
\q1
\v 5 Kai teh, BAWIPA doeh ka ngaihawi.  
\q2 Ka hringnae ni a ngaihawi.  
\q2 Kai teh Bawipa e a lawk hah ka kâuep.   
\q1
\v 6 Ramvengnaw ni amom a ngaihawi awh e hlak,  
\q2 atangcalah ramvengnaw ni amom a ngaihawi awh e hlak,  
\q2 ka hringnae ni Bawipa teh a ngaihawi.   
\q1
\v 7 Oe Isarel miphun, BAWIPA hah ngaihawi awh haw.  
\q2 Bangkongtetpawiteh, BAWIPA dawk pahrenlungmanae ao.  
\q2 Ka kuep e ratangnae hai Bawipa koe ao.   
\q1
\v 8 Bawipa ni Isarel miphunnaw teh  
\q2 payonnae kaawm e pueng dawk hoi a ratang han.   
\c 131  
\s1 Cathut kâuep laihoi ratoumnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA, kai teh ka pouknae rasang hoeh,  
\q2 ka mit hai kâ rasang hoeh,  
\q2 kai hanelah kalenpounge hno hoi,  
\q2 ka ru poung e hno dawk ka nuen hoeh.   
\q1
\v 2 Atangcalah, kai teh sanu pâphei e camo patetlah,  
\q2 ka lungroum teh,  
\q2 ka lungthin teh sanu pâphei e camo patetlah ao.   
\q1
\v 3 Isarelnaw ni atuhoi  
\q2 BAWIPA hah ngaihawi awh naseh.   
\c 132  
\s1 Devit hoi Zion rawinae  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 Oe BAWIPA, Devit hai thoseh,  
\q2 a khang e rektapnae hai thoseh,   
\q1
\v 2 BAWIPA koe bangtelane thoe a kâbo tie hai thoseh,  
\q2 Jakop miphun e athakaawme Bawipa koe  
\q2 bangtelamaw lawk a kam tie hai thoseh, pouk haw.   
\q1
\v 3 Ahni ni BAWIPA onae,  
\q2 Jakop miphun e Athakasaipounge a onae hmuen  
\q2 ka hmu hoehroukrak,   
\q1
\v 4 kama im ka ban mahoeh,  
\q2 ka ikhun dawk ka luen mahoeh,   
\q1
\v 5 ka ip mahoeh, ka mit ka pakhap mahoeh  
\q2 telah lawk a kam.   
\q1
\v 6 Khenhaw! Ephrath vah, ka thai a teh,  
\q2 ratu thung vah ka hmu awh.   
\q1
\v 7 Ama onae koe cet awh sei .  
\q2 Ama khok toungnae hmalah tabawk awh sei .   
\q1
\v 8 Oe BAWIPA nama e thaonae thingkong hoi cungtalah,  
\q2 nama e roumnae koe luen haw.   
\q1
\v 9 Nange vaihmanaw teh lannae hah khohnat awh naseh.  
\q2 Nange tami kathoungnaw ni hai lunghawicalah la sak awh naseh.   
\q1
\v 10 Na san Devit minhmai khet lahoi satui na awi e hah  
\q2 pahnawt hanh loe.   
\q1
\v 11 BAWIPA ni Devit koe thoe a bo teh  
\q2 bout raphoe hoeh hane lawk teh:  
\q2 na catoun hah na bawitungkhung dawk ka tahung sak han.   
\q1
\v 12 Na capanaw ni kaie lawkkam hoi  
\q2 kaie lawkpanuesaknae hah tarawi awh pawiteh,  
\q2 ahnimae capanaw hai nange bawitungkhung dawk  
\q2 pou a tahung awh han tie hah doeh.   
\q1
\v 13 Bangkongtetpawiteh, BAWIPA ni Zion hah a rawi teh,  
\q2 hawvah o nahane hmuen lah ta hane a ngai dawkvah,   
\q1
\v 14 hote hmuen teh a yungyoe kaie roumnae hmuen lah ao.  
\q2 Hote hmuen hah ka ngai dawkvah, hawvah ka o han.   
\q1
\v 15 Hote hmuen koe rawca yawhawi ka poe han.  
\q2 Hote hmuen koe mathoenaw hai rawca ka boum sak han.   
\q1
\v 16 Hote hmuen koe e vaihmanaw heh  
\q2 rungngangnae hoi ka ramuk vaiteh,  
\q2 tami kathoungnaw ni lunghawi laihoi la a sak awh han.   
\q1
\v 17 Hawvah, Devit e ki hah ka cawn sak han.  
\q2 Satui ka awi e tami hanelah,  
\q2 hmaiim sut ka hruek pouh.   
\q1
\v 18 Kai ni ahnie tarannaw hah  
\q2 kayayeirai hoi ka ramuk pouh han.  
\q2 Ahni koe teh, amae lentoenae lukhung  
\q2 kamhlawng sak han telah a ti.   
\c 133  
\s1 Hmaunawngha lungkâpatawnae  
\d Kathutkung: Devit  
\q1
\v 1 Khenhaw! Hmaunawnghanaw ni  
\q2 lungkânging lahoi cungtalah kho a sak awh e teh  
\q2 ahawipoung teh, ngai ao poung.   
\q1
\v 2 Aphu kaawm e satui lû dawk awi teh,  
\q2 pâkhamuen totouh ka lawi e,  
\q2 Aron e pâkhamuen totouh ka lawi niteh,  
\q2 a lahuen koehoi a khohna dawk ka lawi e hoi a kâvan.   
\q1
\v 3 Zion mon dawk ka bawt niteh,  
\q2 Hermon mon e tadamtui patetlah ao.  
\q2 Bangkongtetpawiteh, hote hmuen koe  
\q2 a yungyoe hringnae yawhawi teh na poe han telah  
\q2 BAWIPA ni lawk na kam pouh.   
\c 134  
\s1 BAWIPA yawhawi poe awh sei  
\d Kathutkung: Panuekhoeh, tami tangawn ni Hezekiah a ti awh  
\q1
\v 1 BAWIPA e sannaw pueng tho awh,  
\q2 Karum vah, BAWIPA e im dawk thaw katawknaw pueng,  
\q2 BAWIPA teh pholen awh.   
\q1
\v 2 Thoungnae hmuen koe lah na kut dâw awh nateh,  
\q2 BAWIPA teh pholen awh.   
\q1
\v 3 Kalvan hoi talai ka sak e BAWIPA ni  
\q2 Zion hoi nang hah yawhawinae na poe lawiseh.   
\c 135  
\s1 BAWIPA lennae  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 BAWIPA teh pholen awh. BAWIPA min teh pholen awh.  
\q2 BAWIPA e a sannaw ama teh pholen awh.   
\q1
\v 2 BAWIPA e min dawk thoseh,  
\q2 maimae Cathut im thongma dawk thoseh,  
\q2 thaw ka tawk e a sannaw pueng ama teh pholen awh.   
\q1
\v 3 BAWIPA teh ahawi, BAWIPA teh pholen awh.  
\q2 Bawipa e min hah la sak awh. Hottelah sak e teh a kamcu.   
\q1
\v 4 Atangcalah BAWIPA ni Jakop hah ama hanelah thoseh,  
\q2 Isarel hah amae hno lah o sak hanelah thoseh a rawi toe.   
\q1
\v 5 Hatdawkvah, Jehovah teh a len e hoi maimae Bawipa teh,  
\q2 cathut pueng e lathueng lah ao tie hah ka panue.   
\q1
\v 6 BAWIPA teh kalvan hoi talai hai thoseh,  
\q2 tuipui hoi adungnae koehai thoseh,  
\q2 a ngai e patetlah a sak.   
\q1
\v 7 BAWIPA ni tâmainaw hah  
\q2 talai apoutnae koehoi a luen sak teh,  
\q2 kho hoi sumpa a palik sak teh,  
\q2 kahlî hah a hnoim thung hoi a tâco sak.   
\q1
\v 8 Ama ni Izip ram vah tami hoi saring totouh  
\q2 caminnaw hah a thei pouh.   
\q1
\v 9 Oe Izip ram ahni ni mitnoutnaw hoi  
\q2 kângairu mitnoutnaw hah nangmouh koe,  
\q2 Faro siangpahrang hoi a thaw katawknaw  
\q2 pueng koe a thosak toe.   
\q1
\v 10 Bawipa ni miphun moikapap a moum teh,  
\q2 athakaawme siangpahrangnaw hah a thei.   
\q1
\v 11 Hotnaw teh Amor siangpahrang Sihon,  
\q2 Bashan siangpahrang Og, hoi kanaan uknaeramnaw doeh   
\q1
\v 12 Hathnukkhu, ahnimae talai hah a tami Isarelnaw râw lah a poe.   
\q1
\v 13 Oe BAWIPA, nange min teh a yungyoe a kangning.  
\q2 Oe BAWIPA, na kamthang teh catounnaw totouh a cak.   
\q1
\v 14 Bangkongtetpawiteh, BAWIPA Cathut ni  
\q2 a miphun hah lawk a ceng teh, a sannaw hah a pahrenlungma,   
\q1
\v 15 Jentelnaw e meikaphawknaw teh,  
\q2 sui, ngun lah ao teh, kut hoi sak e lah ao.   
\q1
\v 16 Hotnaw teh pahni a tawn awh ei lawk dei thai awh hoeh.  
\q2 Mit a tawn awh ei, hmawt thai awh hoeh.   
\q1
\v 17 Hnâ a tawn awh ei, thai awh hoeh.  
\q2 Ahnimae kâko dawk kâha hai awm hoeh.   
\q1
\v 18 Hotnaw ka sak e hoi kayuemnaw pueng hai  
\q2 hotnaw patetlah ao awh han.   
\q1
\v 19 Oe Isarelnaw, BAWIPA hah yawhawi poe awh.  
\q2 Aron catounnaw BAWIPA hah yawhawi poe awh.   
\q1
\v 20 Oe Levih catounnaw BAWIPA hah pholen awh.  
\q2 BAWIPA ka taket e naw, BAWIPA hah pholen awh.   
\q1
\v 21 Jerusalem vah kaawm e BAWIPA Cathut teh,  
\q2 Zion hoi pholen awh.  
\q2 Hallelujah.   
\c 136  
\s1 Lunghawilawkdeinae la  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 BAWIPA koe lunghawi lawk dei awh.  
\q2 Bangkongtetpawiteh, ahni teh ahawi.  
\q2 A lungmanae teh a yungyoe a kangning.   
\q1
\v 2 Cathut pueng e Cathut koe lunghawi lawk dei awh.  
\q2 Bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 3 Bawi pueng e Bawi koe lunghawi lawk dei awh.  
\q2 Bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 4 Kângairu hno kalen heh amadueng ka sak e koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 5 A lungangnae hoi kalvan ka sak koe,  
\q2 bangkongtetpawiteh, a lungmanae teh  
\q2 a yungyoe a kangning.   
\q1
\v 6 Talai hah tui van ka phai e Bawipa koe,  
\q2 bangkongtetpawiteh, a lungmanae teh  
\q2 a yungyoe a kangning.   
\q1
\v 7 Kalenpoung angnae ka sak e koe,  
\q2 bangkongtetpawiteh, a lungmanae teh  
\q2 a yungyoe a kangning.   
\q1
\v 8 Khodai ka uk hanlah kanî ka sak e koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 9 Karum ka uk hanlah thapa hoi âsinaw ka sak e koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 10 Izipnaw e caminnaw ka thet e koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 11 Isarelnaw hah Izipnaw thung hoi ka tâcawtkhaikung koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 12 Athakaawme kut, a dâw e kut hoi ka tâcawtkhai koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 13 Tuipui paling hah kahni telah rak ka bawng e koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 14 Isarelnaw hah hote tuipui lungui hoi ka cet sakkung koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 15 Faro siangpahrang hoi a ransanaw teh,  
\q2 tui dawk koung ka tâkhawng koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 16 A miphunnaw hah thingyei yawn dawk ka cetkhaikung koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 17 Siangpahrang kalennaw kathetkung koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 18 A min kamthang e siangpahrangnaw kathetkung koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 19 Amor siangpahrang Sihon ka thet koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 20 Bashan siangpahrang Og ka thet koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 21 Ahnimae ram hah râw lah kapoekung koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 22 San hah Isarelnaw râw lah kapoekung koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 23 Maimouh bo awh lahun nah, pou na kapoukung koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 24 Maimanaw heh taran um hoi na karasatkung koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 25 Moithang pueng rawca ka poe koe,  
\q2 bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\q1
\v 26 Kalvan Cathut koe lunghawi lawk dei awh.  
\q2 Bangkongtetpawiteh, a lungmanae teh a yungyoe a kangning.   
\c 137  
\s1 Zion la  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 Kaimouh teh Babilon palang teng ka tahung awh teh,  
\q2 Zion ka pouk awh dawkvah, ka ka awh.   
\q1
\v 2 Kaimae ratoungnaw hah  
\q2 sumpakung dawk ka bang awh.   
\q1
\v 3 Bangkongtetpawiteh, hote hmuen koe maimouh na ka man niteh,  
\q2 na kahrawinaw ni kai koe la a hei awh.  
\q2 Kaimouh karektapnaw ni hai amamouh nawm nahanelah  
\q2 Zion la kaimouh hanlah sak haw ati awh.   
\q1
\v 4 Kaimouh ni Jentelnaw e ram dawk bangtelamaw  
\q2 BAWIPA pholennae la ka sak thai awh han vaw.   
\q1
\v 5 Oe Jerusalem, nang hah kai ni na pahnim pawiteh,  
\q2 kama e aranglae kut ni a tawksak thai e hah pahnim naseh.   
\q1
\v 6 Nang hah na pouk hoeh boilah,  
\q2 Jerusalem hah ka lunghawinae  
\q2 lathueng ka hrueng hoeh pawiteh,  
\q2 ka lai teh ka dangka dawk kâbet naseh.   
\q1
\v 7 Oe BAWIPA, Jerusalem a rawp nah hnin vah,  
\q2 raphoe awh, khomdu totouh raphoe awh telah  
\q2 kahram awh e Edomnaw hah pouk haw.   
\q1
\v 8 Oe Babilon canu, raphoe lah na o han toe.  
\q2 Kaimouh koe na sak e patetlah,  
\q2 nang koe ka patho e teh a lunghawi naseh.   
\q1
\v 9 Nange camonaw hah kaman niteh,  
\q2 talung dawk rekrek ka suk e teh a lunghawi naseh.   
\c 138  
\s1 BAWIPA koe lunghawilawk deinae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA, kai teh nange pahrennae hah  
\q2 ka lungthin abuemlahoi ka pholen han,  
\q2 cathutnaw hmalah nang koe pholennae la ka sak han.   
\q1
\v 2 Kai teh nange kathounge Bawkim koelah  
\q2 kangvawi laihoi ka bawk vaiteh,  
\q2 nange pahrenlungmanae hoi nange lawkkatang hanelah,  
\q2 na Min teh ka pholen.   
\q1
\v 3 Bangkongtetpawiteh, nang teh nama ni na dei e naw hah na min onae lathueng vah na tawm toe.  
\q2 Kai ni na kawnae hnin navah, nang ni na pato teh,  
\q2 ka hringnae teh tha hoi na kawisak.   
\q1
\v 4 Oe BAWIPA talai van e siangpahrang pueng ni,  
\q2 nange lawk a thai awh toteh, na pholen awh han.   
\q1
\v 5 BAWIPA e lamthungnaw dawk la a sak awh han.  
\q2 Bangkongtetpawiteh, BAWIPA e bawilennae teh a len poung.   
\q1
\v 6 Atangcalah BAWIPA teh arasang ei nakunghai,  
\q2 ka rahnoum e naw hah a khetyawt.  
\q2 Hatei, kâoupnaw teh ahlanae koehoi a panue toe.   
\q1
\v 7 Kai teh runae um ka cet ei nakunghai,  
\q2 Bawipa ni na hring sak han.  
\q2 Bawipa ni a kut dâw vaiteh,  
\q2 ka tarannaw e lungkhueknae hah ngang vaiteh,  
\q2 Bawipa e aranglae kut hoi kai hah na rungngang han.   
\q1
\v 8 BAWIPA ni kai hanlah a noenae a kuep sak han.  
\q2 Oe BAWIPA nange pahrenlungmanae teh a kangning.  
\q2 Na kut hoi na sak e naw heh hnoun hanh lah a.   
\c 139  
\s1 A yungyoe lentoenae hoi kawi e Cathut  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA, nang ni na pâphue teh na panue toe.   
\q1
\v 2 Kai ka tahungnae, ka thawnae pueng hah na panue.  
\q2 Kaie ka pouknae pueng hai ahlanae koehoi na panue.   
\q1
\v 3 Ka ceinae lamthung hai thoseh,  
\q2 ka inae hai thoseh, na pâphue teh,  
\q2 ka coungnae puenghai na panue.   
\q1
\v 4 Kai ni lawk kam touh boehai  
\q2 ka dei hoeh nakunghai Oe BAWIPA,  
\q2 nang ni koung na panue.   
\q1
\v 5 Nang ni kai pet na kalup teh,  
\q2 kaie van vah na kut hah na toung toe.   
\q1
\v 6 Hot patet e panuenae teh kângairu, arasang,  
\q2 kai ni ka phat thai hoeh.   
\q1
\v 7 Nange Muitha hoi hlout nahanelah nâmouh ka cei thai han va.  
\q2 Na hmalah hoi ka hlout nahanelah nâmouh ka cei thai han va.   
\q1
\v 8 Kalvan ka luen pawiteh hawvah nang teh na o.  
\q2 Phuen koe yannae ka phai nakunghai hawvah nang teh na o.   
\q1
\v 9 Amom ratheinaw ka lat niteh,  
\q2 tuipui avanglae rai koe kaawm nakunghai,   
\q1
\v 10 hote hmuen koehai Bawipa e kut ni na thak teh,  
\q2 aranglae kut ni na kuet han.   
\q1
\v 11 Hmonae ni ka ramuk nakunghai,  
\q2 karum hai kaie tengpam vah angnae lah ao han.   
\q1
\v 12 Bawipa hmalah hmonae ni banghai ramuk thai mahoeh.  
\q2 Karum teh khodai patetlah a ang.  
\q2 Hmonae hoi angnae teh reikâvan.   
\q1
\v 13 Bawipa ni kaie kuen hah a sak teh,  
\q2 anu von thungvah kai hah na ramuk toe.   
\q1
\v 14 Kai ni na pholen han. Bangkongtetpawiteh,  
\q2 takikatho lah, kângailah a ru. Ka hringnae ni kacaicalah a panue.   
\q1
\v 15 Kai hah arulahoi na sak teh,  
\q2 talai thung vah na pahlawm navah,  
\q2 ka tak teh na hmalah hro lah awm hoeh.   
\q1
\v 16 Nange mit niteh, kamnuek hoeh rae ka tak hai na hmu toe.  
\q2 Kai hanelah na hmoun e hninthanaw  
\q2 hnin touh boehai ao hoehnahlan hoiyah  
\q2 nama e cauk dawk ngit na thut e lah ao toe.   
\q1
\v 17 Oe Cathut, kai dawkvah nange pouknae teh aphu o poung.  
\q2 Banghloi apap tangngak.   
\q1
\v 18 Hote pouknae teh parei han pawiteh,  
\q2 sadi hlak hai apap han doeh.  
\q2 Ka kâhlaw toteh nang hoi pou ka o.   
\q1
\v 19 Oe Cathut, tamikaponaw hah na thet pawiteh ahawi han doeh.  
\q2 Tami thei hanlah thi ka phuen e naw, kai koehoi tâcawt awh.   
\q1
\v 20 Ahnimouh teh, ponae lahoi Bawipa tarannae lawk a dei awh.  
\q2 Nange tarannaw ni na min hah ayawmyin lah a hno awh.   
\q1
\v 21 Oe BAWIPA, nang ni na hmuhma e naw  
\q2 hai kai ni hai ka hmuhma nahoehmaw.  
\q2 Nang ka tarannaw hai kai ni ka panuet nahoehmaw.   
\q1
\v 22 Kai ni ahnimouh hah puenghoi ka hmuhma.  
\q2 Ka taran lah doeh ka pouk.   
\q1
\v 23 Oe Cathut, kai hah na pâphue teh,  
\q2 kaie ka lungthin hah hmawt haw.  
\q2 Kai hah na noumcai nateh ka pouknae pueng panuek haw.   
\q1
\v 24 Kai ni lamthung kathout dawk ka dawn ou,  
\q2 ka dawn hoeh ou tie na khen nateh,  
\q2 a yungyoe e lamthung dawk na hrawi haw.   
\c 140  
\s1 Rungngang hanelah ratoumnae  
\d Kathutkung: Devit, Devit ni tumkhawngkung hanelah a sak e la  
\q1
\v 1 Oe BAWIPA, tamikathoutnaw e kut dawk hoi  
\q2 kai hah na hlout sak haw.  
\q2 Ka mathoutmakainaw e kut dawk hoi na rungngang haw.   
\q1
\v 2 Ahnimouh teh a lungthung vah hawihoehnae hah a pouk awh teh,  
\q2 kâtuknae ao nahanelah, hnintangkuem cungtalah a pouk awh.   
\q1
\v 3 Ahnimouh teh amamae lai hah tahrun e lai patetlah,  
\q2 a hran sak awh.  
\q2 Ahnimae pahni thung vah hrunthoe sue ao. Selah.   
\q1
\v 4 Oe BAWIPA, tamikathoutnaw e kut dawk hoi  
\q2 kai hah na ring haw.  
\q2 Ka mathoutmakainaw e kut dawk hoi na rungngang haw.  
\q2 Ahnimouh ni ka tâlaw nahanelah kho a khang awh.   
\q1
\v 5 Ka kâoupnaw ni kai hanelah arulahoi tangkam a patûng awh.  
\q2 Lamthung dawk tamlawk a yangda awh teh,  
\q2 kai hanelah karap a patûng awh. Selah.   
\q1
\v 6 Nang teh kaie Cathut lah na o tie hah Jehovah koe ka dei.  
\q2 Oe BAWIPA, kai ni ka kâhei e hah na thai pouh haw.   
\q1
\v 7 Oe Bawipa Jehovah, nang teh kaie rungngangnae tha lah na o.  
\q2 Tarankâtuk hnin vah, nang ni kaie ka lû teh na ramuk pouh.   
\q1
\v 8 Oe BAWIPA, tamikathoutnaw e ngainae teh kuep pouh hoeh.  
\q2 Hawihoehnae sak hanelah noenae teh kuep sak pouh hoeh.  
\q2 Hoehpawiteh, kârasang awh langvaih.   
\q1
\v 9 Hot patet e taminaw teh, kaie ka tengpam vah,  
\q2 amamae lû loungouk awh laipalah,  
\q2 amamouh ni a dei awh e hawihoehnae ni  
\q2 amamanaw teh ramuk naseh.   
\q1
\v 10 Hmaisaannaw teh amamae van bawt naseh.  
\q2 Ahnimouh teh hmai dawk thoseh, tangkawm thung thoseh,  
\q2 tâkhawng e lah awm awh naseh, bout thaw awh hanh lawiseh.   
\q1
\v 11 Thoenae ka dei e naw teh, talai van cak awh hanh naseh,  
\q2 ka mathoutmakai e taminaw koe runae ni pâlei awh naseh.   
\q1
\v 12 BAWIPA ni runae kâhmonaw hah a khetyawt teh,  
\q2 kavoutthoupnaw koelah kalan lah lawk a ceng han tie ka panue.   
\q1
\v 13 Atangcalah, tami kalannaw ni na min a pholen awh han.  
\q2 A lungthin kalannaw ni hai na hmalah ao awh han.   
\c 141  
\s1 Kahawihoeh hno sakpayon hoeh nahanelah ratoumnae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA, nang teh, kai ni na kaw.  
\q2 Karanglah kai koe tho haw.  
\q2 Kai ni nang na kaw nah kaie ka lawk hah na thai pouh haw.   
\q1
\v 2 Kaie ratoumnae teh na hmalah hmuitui hmaisawi e patetlah thoseh,  
\q2 ka kut ka dâw e teh kanî a khup nah thueng e patetlah thoseh,  
\q2 pouk e lah awm lawiseh.   
\q1
\v 3 Oe BAWIPA, ka pahni karingkung na tat pouh haw.  
\q2 Ka pahni takhang hai ring haw.   
\q1
\v 4 Payonnae ka sak e taminaw hoi hawihoehnae sak nahanelah,  
\q2 ka lungthin heh hawihoehnae koe lah na kangvawi sak hanh.  
\q2 Ahnimae canei kawi hai na catnet sak hanh.   
\q1
\v 5 Tami kalan ni kai na hem naseh.  
\q2 Hot hateh pahrenlungmanae lah ao.  
\q2 Kai hah na yue naseh.  
\q2 Hot hateh, lû dawk satui awi e lah ao.  
\q2 Ka lû ni hot hateh mat hanh naseh.  
\q2 Bangkongtetpawiteh, kaie ratoumnae niteh,  
\q2 hawihoehnae ka sak e naw hah pou a taran han.   
\q1
\v 6 Ahnimouh ka ukkungnaw teh pango dawk tanawt lah ao awh han.  
\q2 Hat toteh, kaie lawknaw teh ngai ao tie hah na panue awh han.   
\q1
\v 7 Talai tai e laitueng pâpâwn e patetlah,  
\q2 kaie ka hrunaw teh phuen longkha koe a kâyat.   
\q1
\v 8 Hatei, Oe Bawipa Jehovah, kai teh, nang doeh na khet toe.  
\q2 Nang doeh na kângue toe.  
\q2 Ka hringnae hah kângue han kaawm hoeh lah awm sak hanh.   
\q1
\v 9 Ahnimouh ni kai hanelah sut patûng e tangkam dawk hoi thoseh,  
\q2 payonnae kasaknaw e karap dawk hoi thoseh,  
\q2 kai hah na khoum haw.   
\q1
\v 10 Kai ni hote tangkamnaw ka tapoung toteh,  
\q2 tamikathoutnaw teh amamouh ni  
\q2 a patûng awh e tangkam dawk reirei bawt awh naseh.   
\c 142  
\s1 Runae um hoi hramki laihoi kâheinae.  
\d Kathutkung: Devit, Lungngoum thung aonae koehoi a sak e  
\q1
\v 1 Kai teh, BAWIPA koevah ka hram.  
\q2 BAWIPA koe hram laihoi ka kâhei.   
\q1
\v 2 Na hma lah ka phuenangnae ka pâpho teh,  
\q2 ka reithainae hai a hmalah ka dei pouh.   
\q1
\v 3 Ka muitha ni ka thungvah a puen toteh,  
\q2 Bawipa nang dueng ni doeh kaie lamthung teh na panue.  
\q2 Taminaw ni ka dawn e lamthung dawkvah,  
\q2 tangkam hah arulahoi a patûng awh.   
\q1
\v 4 Aranglah na khet teh na panue.  
\q2 Kai na kapanuekkhaikung apihai awm hoeh.  
\q2 Ka yawng nahane lam hai awm hoeh.  
\q2 Ka hringnae kapasaikung hai awm hoeh.   
\q1
\v 5 Oe BAWIPA kai teh nang koe vah ka hramki toe.  
\q2 Nang teh kai ni kângue e lah na o teh,  
\q2 kahringnaw onae ram dawk kaie kaham lah ao telah kai ni ka dei.   
\q1
\v 6 Kai ni ka hram e lawk hah na thai pouh haw.  
\q2 Bangkongtetpawiteh, kai teh puenghoi runae ka kâhmo toe.  
\q2 Kai na karektapnaw kut dawk hoi na hlout sak haw.  
\q2 Bangkongtetpawiteh, ahnimouh teh kai hlak a tha ao awh.   
\q1
\v 7 Bawipa nange min ka pholen thai nahanelah  
\q2 kai hah thongim thung hoi na rasat haw.  
\q2 Hottelah hawinae na sak toteh,  
\q2 tami kalannaw ni kai hah na kalup awh han.   
\c 143  
\s1 Hramki laihoi kabawp heinae  
\d Kathutkung: Devit  
\q1
\v 1 Oe BAWIPA, kaie ratoum lawk heh na thai pouh haw.  
\q2 Kai ni ka kâhei e hah na thai pouh haw.   
\q1
\v 2 Nange yuemkamcunae lahoi thoseh,  
\q2 nange lannae lahoi thoseh, kai hah na pato haw.  
\q2 Nange na san hoi lawkcengnae koe na kâenkhai hanh.  
\q2 Bangkongtetpawiteh, kahring e tami buet touh boehai  
\q2 na hmalah a lan tie awm hoeh.   
\q1
\v 3 Atangcalah taran ni ka hringnae heh a rektap teh,  
\q2 ka hringnae hai talai dawk rekrek a suk teh,  
\q2 ngailawi kasawlah kadout tangcoung e patetlah  
\q2 hmonae um hai kai hah na o sak.   
\q1
\v 4 Kai teh, ka lung apout teh  
\q2 ka thung vah ka lung a rek.   
\q1
\v 5 Kaloum tangcoung e a hninnaw hah ka pouk teh,  
\q2 Bawipa ni a sak e hnonaw hoi kut hoi a sak e  
\q2 hnonaw hah luepluep ka pouk.   
\q1
\v 6 Bawipa nang koe ka kut ka daw.  
\q2 Talai ka ke e patetlah ka hringnae ni nang teh na doun. Selah.   
\q1
\v 7 Oe BAWIPA karanglah na pato haw.  
\q2 Ka muitha teh a tha abaw toe.  
\q2 Kai teh duenae tangkawm dawk ka kum hane tami patetlah  
\q2 alouklah na kangvawi takhai hanh loe.   
\q1
\v 8 Amom vah nange pahrenlungmanae hah na thai sak haw.  
\q2 Bangkongtetpawiteh, kai ni nang teh na kâuep toe.  
\q2 Ka dawn hane lamthung hah na panuek sak.  
\q2 Bangkongtetpawiteh, ka hringnae ni nang doeh na kângue toe.   
\q1
\v 9 Oe BAWIPA, ka tarannaw e kut dawk hoi  
\q2 kai hah na hlout sak haw.  
\q2 Kai teh nang doeh na kângue.   
\q1
\v 10 Nange ngainae ka tawk thai nahan,  
\q2 na cangkhai haw.  
\q2 Bangkongtetpawiteh, nang teh kaie Cathut lah na o.  
\q2 Nange Muitha teh ahawi, kai hah lamkalan dawk na thak lawiseh.   
\q1
\v 11 Oe BAWIPA na min kecu dawk kai hah na hring sak haw.  
\q2 Na lannae kecu dawk ka hringnae hah  
\q2 runae thung hoi rasat haw.   
\q1
\v 12 Kai teh nange san lah ka o dawkvah,  
\q2 namae pahrenlungmanae lahoi ka tarannaw hah,  
\q2 na takhoe pouh haw.   
\c 144  
\s1 Siangpahrang Ratoumnae  
\d Kathutkung: Devit  
\q1
\v 1 Kaie lungsong lah kaawm e BAWIPA teh  
\q2 yawhawi lah awm lawiseh.  
\q2 Bawipa ni kaie kut hah tarankâtuk nahanelah a cangkhai teh,  
\q2 ka kutdawnnaw hah kâtuk nahanelah a cangkhai.   
\q1
\v 2 Bawipa teh kai lung na kapatawkung,  
\q2 kaie rapan, kai karasang e imrasang,  
\q2 kai na ka rungngangkung, kaie bahling lah ao.  
\q2 Kai teh ahni a ka kângue.  
\q2 Bawipa ni ka miphunnaw hah ka kut dawk a pha sak.   
\q1
\v 3 Oe BAWIPA, tami hah banglamouh ao teh, khuet na pouk va.  
\q2 Tami capa teh banglamouh ao teh,  
\q2 alawkpui lah khuet na ta va.   
\q1
\v 4 Tami teh kâha patetlah doeh ao.  
\q2 Ahnie a hninnaw haiyah tang kaloum e tâhlip patetlah doeh ao.   
\q1
\v 5 Oe BAWIPA, na kalvan rahnoum sak nateh, kum haw.  
\q2 Monnaw dawk hoi hmaikhu a tâco nahanelah kâbet haw.   
\q1
\v 6 Sumpapalik sak nateh, tarannaw hah kâkapek sak haw,  
\q2 na pala hoi ka nateh, ahnimanaw hah raphoe haw.   
\q1
\v 7 Arasangnae koehoi na kut dâw haw.  
\q2 Moikapap e tui thung hoi thoseh,  
\q2 Jentelnaw e kut dawk hoi thoseh,  
\q2 kai hah na rungngang nateh, na hlout sak haw.   
\q1
\v 8 Ahnimanaw e pahni teh laithoe hrawnghrang doeh a dei awh.  
\q2 Ahnimae aranglae kut hai dumyennae kut lah doeh ao.   
\q1
\v 9 Oe Cathut, kai teh, nang koe la katha ka sak han.  
\q2 A rui hra touh thueng e ratoung hoi na pholen han.   
\q1
\v 10 Bawipa, nang ni siangpahrangnaw hah rungngangnae na poe.  
\q2 Nange san Devit hai tahloi dawk hoi na hlout sak.   
\q1
\v 11 Jentelnaw e kut dawk hoi na rungngang nateh,  
\q2 na hlout sak haw.  
\q2 Ahnimae pahni teh laithoe hrawnghrang a dei awh.  
\q2 Ahnimae aranglae kut hai dumyennae kut lah a o   
\q1
\v 12 Kaimae capanaw teh a naw awh lahun navah  
\q2 a dawn ka sai lahun e patetlah awm awh naseh.  
\q2 Kaimae canunaw teh hak pathoup tangcoung e  
\q2 takinkhom patetlah awm naseh.   
\q1
\v 13 Kaimae capainaw teh,  
\q2 law dawk e a pawnaw hoi kawi lawiseh.  
\q2 Kaimae tunaw hai talai dawk thong touh,  
\q2 thong hra touh pungdaw lawiseh.   
\q1
\v 14 Kaimae maitonaw teh  
\q2 thaw tawk hanlah a tha awm naseh.  
\q2 Thama lah kâennae awm hanh naseh,  
\q2 lawpnae awm hanh naseh.  
\q2 kaimae lamthung dawk khuikanae hai awm hanh naseh.   
\q1
\v 15 Hot patetlah e yawhawinae hah  
\q2 ka coe e miphun teh yawhawi ao.  
\q2 BAWIPA hah amae Cathut lah  
\q2 ka bawk e miphun teh yawhawi ao.   
\c 145  
\s1 Cathut lentoenae hah pholennae  
\d Kathutkung: Devit  
\q1
\v 1 Kaie Cathut, kaie siangpahrang,  
\q2 Bawipa nang teh na tawm han.  
\q2 Bawipa nange min teh a yungyoe ka pholen han.   
\q1
\v 2 Kai ni Bawipa nang hah hnintangkuem na pholen vaiteh,  
\q2 nange min hah a yungyoe ka pholen han.   
\q1
\v 3 BAWIPA teh a lenpoung dawkvah,  
\q2 puenghoi pholen han kawi lah ao.  
\q2 Ahnie lennae teh boeba hai pâphue thai lah awm hoeh.   
\q1
\v 4 Catoun buet touh hnukkhu buet touh ni  
\q2 Bawipa ni a sak e naw hah a pholen awh han.  
\q2 Bawipa e thaonae hnosakenaw hai a pathang awh han.   
\q1
\v 5 Nange taluenae hah bari kaawm bawilen poung lah thoseh,  
\q2 kângairu hno hai thoseh, ka dei han.   
\q1
\v 6 Ahnimouh niteh, Bawipa kângairu  
\q2 lentoenae hah a dei awh han.  
\q2 Kai ni hai Bawipa e lennae hah ka dei han.   
\q1
\v 7 Ahnimouh niteh, Bawipa e hawinae hah pahnim hoeh nahanlah,  
\q2 dei awh vaiteh, Bawipa e lannae hah  
\q2 lunghawi laihoi a pholen awh han.   
\q1
\v 8 BAWIPA teh hawinae, pahrennae hoi akawi teh,  
\q2 a lungsaw teh, lungmanae hoi akawi.   
\q1
\v 9 BAWIPA teh bangpueng dawk hai ahawi.  
\q2 Ama ni a sak e hnopueng hai a pahren.   
\q1
\v 10 Oe BAWIPA, na sak e hnopueng ni  
\q2 nama e hawinae teh a pholen awh han.  
\q2 A tami kathoung pueng ni hai a pholen awh han.   
\q1
\v 11 Ahnimouh ni nange uknaeram bawilennae kong a dei awh han.  
\q2 Nange thaonae hai a dei awh han.   
\q1
\v 12 Hettelah hoi nange thaonae hnosakenaw hoi,  
\q2 uknaeram bawilen taluenae teh  
\q2 tami capa pueng koe a panue sak awh han.   
\q1
\v 13 Na uknaeram teh a yungyoe e uknae lah ao teh,  
\q2 na kâtawnnae teh se pueng dawk a kangning.   
\q1
\v 14 BAWIPA ni ka rawm e taminaw hah a pathaw teh,  
\q2 ka tabut e taminaw hah a loungouk sak.   
\q1
\v 15 Tami pueng ni ngaihawi laihoi na khet awh teh,  
\q2 atueng a pha toteh, rawca a poe.   
\q1
\v 16 A kut a kadai teh, kahring e moithang pueng hah  
\q2 a lungkuep sak.   
\q1
\v 17 Bawipa teh amae lamthung pueng dawk a lan teh,  
\q2 a sak e hnopueng dawk yuem a kamcu.   
\q1
\v 18 BAWIPA teh ama ka kaw e pueng,  
\q2 lawkkatang lahoi ka kaw pueng koe a hnai sin.   
\q1
\v 19 Bawipa ni ama ka taketnaw e lungngai akuep sak pouh.  
\q2 Ahnimae hramki lawk hai a thai pouh teh,  
\q2 ahnimanaw hah a rungngang.   
\q1
\v 20 BAWIPA ni ama ka lungpataw e pueng a khetyawt.  
\q2 Hatei, tamikathout pueng teh a raphoe han.   
\q1
\v 21 Ka pahni ni BAWIPA pholennae a dei han.  
\q2 Tami pueng ni a min kathoung hah  
\q2 a yungyoe hoi a yungyoe pholen awh naseh.   
\c 146  
\s1 Pahrennae hoi kawi Cathut  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 BAWIPA teh pholen awh.  
\q2 Oe ka hringnae BAWIPA hah pholen haw.   
\q1
\v 2 Kai teh, kahring lahun nah BAWIPA ka pholen han.  
\q2 Ka hringyung thung ka Cathut teh la sak hoi ka pholen han.   
\q1
\v 3 Bawinaw hoi na ka rungngang thai hoeh e  
\q2 taminaw hah kâuep awh hanh.   
\q1
\v 4 Ahnimae muitha a tâco toteh, talai lah doeh a ban awh.  
\q2 Hatnah hnin vah, ahnimae pouknae pueng teh be a rawk pouh.   
\q1
\v 5 Jakop e Cathut hah na kabawmkung lah kaawm sak e,  
\q2 amae Cathut ka ngaihawi e teh, a yaw ahawi.   
\q1
\v 6 Hote Cathut ni kalvan, talai, tuipui,  
\q2 hoi hetnaw dawk kaawm e naw pueng hah a sak.   
\q1
\v 7 Rektap lah kaawmnaw hanelah, lawk a ceng pouh teh,  
\q2 a von kahlamnaw rawca a poe.  
\q2 BAWIPA ni thongkabawtnaw a hlout sak.   
\q1
\v 8 BAWIPA ni mitdawnnaw mit a hmu sak.  
\q2 BAWIPA ni katabutnaw hah a loungouk sak teh,  
\q2 tamikalannaw hah a lungpataw.   
\q1
\v 9 BAWIPA ni Jentelnaw hah a khetyawt teh,  
\q2 naranaw hoi lahmainunaw hah a kabawp.  
\q2 Tamikathoutnaw e lamthung teh, a rawk sak.   
\q1
\v 10 BAWIPA ni a yungyoe a uk han.  
\q2 Oe Zion na Cathut ni catounnaw totouh a uk han.  
\q2 Hallelujah.   
\c 147  
\s1 Ka lentoe Cathut pholennae  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 BAWIPA teh pholen awh.  
\q2 Maimae Cathut hah la sak laihoi pholen e teh ahawi.  
\q2 Pholen e teh atangcalah, a kamcu teh ngai ao poung.   
\q1
\v 2 BAWIPA ni Jerusalem kho a sak teh  
\q2 pâlei lah kaawm e Isarelnaw hah a kamkhueng sak.   
\q1
\v 3 A lungthin kareknaw hah a dam sak teh,  
\q2 ahnimae hmânaw hah a kawm pouh.   
\q1
\v 4 Âsinaw hah a parei teh,  
\q2 ahnimae minnaw hai koung a phung.   
\q1
\v 5 Maimae Bawipa teh a len teh,  
\q2 thaonae dawk bahu ao,  
\q2 thaipanueknae dawk khori tawn hoeh.   
\q1
\v 6 BAWIPA ni kârahnoum e naw hah a tawm,  
\q2 tamikathoutnaw hah talai dawk rek a payan.   
\q1
\v 7 Lunghawilawkdeinae laihoi BAWIPA koe la sak awh.  
\q2 Ratoung kueng laihoi maimae Cathut hah pholen awh.   
\q1
\v 8 Kalvan hah tâmai hoi a huem teh,  
\q2 talai hanelah kho a rak sak teh,  
\q2 monruinaw dawk phonaw a pâw sak.   
\q1
\v 9 Moithangnaw hoi kacaikaringe  
\q2 vongacanaw hah rawca a poe.   
\q1
\v 10 Bawipa ni marang tha lunghawikhai hoeh.  
\q2 Tami e khoknaw lunghawikhai hoeh.   
\q1
\v 11 Bawipa ni ama ka taket e taminaw hoi  
\q2 amae pahrennae ka ngaihawi e taminaw doeh a lunghawikhai   
\q1
\v 12 Oe Jerusalem, BAWIPA hah pholen haw.  
\q2 Oe Zion, na Cathut hah pholen haw.   
\q1
\v 13 Bangkongtetpawiteh, Bawipa ni nange  
\q2 kholongkha khannae hah a caksak teh,  
\q2 nang thung kaawm e camonaw hah yawhawi a poe.   
\q1
\v 14 Bawipa ni nange thungup vah roumnae ao sak teh,  
\q2 katuipounge rawca hoi na von a paha sak han.   
\q1
\v 15 Ama e kâpoelawk hah, talai van a patoun.  
\q2 A lawk teh, karang poung lah a yawng.   
\q1
\v 16 Tadamtui hah tumuen patetlah a poe.  
\q2 Tadamtui kamkak e hah hraba patetlah a dan.   
\q1
\v 17 Ama e rounnaw hah vaiyei kanuinaw patetlah a pabo.  
\q2 Bawipa ni a pâding sak e hah apinimaw a khang thai han.   
\q1
\v 18 A lawk hah a patoun teh, hotnaw hah a kamyawt sak.  
\q2 Ama e kahlî a tho sak toteh, tuinaw teh a lawng awh.   
\q1
\v 19 A lawk hah Jakop miphun koe thoseh,  
\q2 phung hoi lawkcengnae teh Isarel miphun koe thoseh, a pâpho.   
\q1
\v 20 A louk e apipatet e miphun koehai hettelah sak boihoeh.  
\q2 Hote Jentelnaw teh,  
\q2 Lawkcengnae hah panuek awh hoeh. BAWIPA teh pholen awh.   
\c 148  
\s1 Sak e pueng ni BAWIPA teh pholen awh  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 BAWIPA teh pholen awh.  
\q2 BAWIPA hah kalvan hoi pholen awh.  
\q2 A rasang poungnae koe pholen awh.   
\q1
\v 2 A kalvantaminaw pueng ama teh pholen awh.  
\q2 Rasahu pueng ama teh pholen awh.   
\q1
\v 3 Kanî hoi thapa naw ama teh pholen awh.  
\q2 Ka ang e âsinaw pueng ama teh pholen awh.   
\q1
\v 4 Karasangpoung e kalvannaw hoi,  
\q2 kalvannaw lathueng kaawm e tuinaw ama teh pholen awh.   
\q1
\v 5 Hotnaw pueng teh BAWIPA e kâ lahoi sak e lah ao awh dawkvah,  
\q2 a min teh pholen awh.   
\q1
\v 6 Ama ni hotnaw pueng teh pou acak sak teh  
\q2 kahmat thai hoeh e phung hah a poe.   
\q1
\v 7 Adungpoungnae koe  
\q2 kaawm e naw hoi khoruinaw   
\q1
\v 8 hmai hoi roun, tadamtui hoi a kahû,  
\q2 a lawk patetlah kâroe e kahlî,   
\q1
\v 9 monnaw hoi monrui pueng,  
\q2 thingthai rompo hoi sidarkung pueng,   
\q1
\v 10 moithang ka matheng hoi saring ka mawng pueng,  
\q2 vonpui hoi kâva e hoi kamleng e tava pueng,   
\q1
\v 11 talai van e siangpahrangnaw hoi tami pueng,  
\q2 kacuenaw hoi ukkung khobawi pueng,   
\q1
\v 12 thoundounnaw hoi tanglanaw pueng,  
\q2 matawngnaw hoi camonaw pueng,  
\q2 BAWIPA teh talai van hoi pholen awh.   
\q1
\v 13 A min dueng doeh ka taluepoung,  
\q2 a bawilennae teh talai hoi kalvan lathueng ao dawkvah,  
\q2 BAWIPA min teh pholen awh.   
\q1
\v 14 A taminaw e ki teh a tawm pouh dawkvah,  
\q2 ateng kaawm e taminaw,  
\q2 a tami Isarelnaw e pholen lah kaawm e  
\q2 tamikathoungnaw ni pholen e lah na o.  
\q2 Hallelujah.   
\c 149  
\s1 Tami kathoungnaw ni BAWIPA pholennae  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 BAWIPA teh pholen awh.  
\q2 BAWIPA koe la katha hah sak awh haw.  
\q2 Tami kathoungnaw kamkhuengnae koe  
\q2 a pahrennae hah pholen awh.   
\q1
\v 2 Isarelnaw ni amamouh kasakkung koe lunghawi naseh.  
\q2 Zion canunaw ni amamae siangpahrang koe konawm naseh.   
\q1
\v 3 Ahnimouh ni lamtu laihoi  
\q2 Bawipa min teh pholen awh naseh.  
\q2 Tâbaw khawng laihoi, ratoung kueng laihoi,  
\q2 pholen hoi la sak awh naseh.   
\q1
\v 4 Bangkongtetpawiteh, BAWIPA ni  
\q2 amae taminaw dawk a lungyouk.  
\q2 A ma ni kârahnoum e naw hah  
\q2 rungngangnae hoi a kamcu sak.   
\q1
\v 5 Tami kathoungnaw ni a bawilennae dawkvah,  
\q2 lunghawi awh naseh.  
\q2 Amamae ikhun dawk lunghawi laihoi la sak awh naseh.   
\q1
\v 6 Ahnimae pahni dawk karasangpoung lah  
\q2 Cathut pholennae awm naseh.  
\q2 Ahnimae kut dawk hai,  
\q2 avoivang kahran e tahloi patuem awh naseh.   
\q1
\v 7 Ahnimouh ni khoramnaw moipathung hane hoi  
\q2 taminaw reknae thoseh,   
\q1
\v 8 ahnimae siangpahrangnaw hai sumrui hoi pâkhi vaiteh,  
\q2 ahnimouh thung dawk e bari kaawm e taminaw hah  
\q2 khok dawk hlong buet hoi pâkhi hane thoseh,   
\q1
\v 9 thut e lawkcengnae hah,  
\q2 ahnimouh koe pha sak nahane doeh.  
\q2 Hethateh, tami kathoungnaw pueng koe  
\q2 kaawm hane barinae doeh.  
\q2 Hallelujah.   
\c 150  
\s1 BAWIPA teh pholen awh  
\d Kathutkung: Panuekhoeh  
\q1
\v 1 BAWIPA teh pholen awh.  
\q2 Thoungnae hmuen koe Cathut teh pholen awh.  
\q2 A Bawilen kamnuenae koe kalvan vah pholen awh.   
\q1
\v 2 Athaonae hnosakenaw dawkvah pholen awh.  
\q2 A lentoenae dawkvah pholen awh.   
\q1
\v 3 Mongka ueng laihoi ama teh pholen awh.  
\q2 Ratoung tamawi kueng laihoi ama teh pholen awh.   
\q1
\v 4 Tâbaw khawng laihoi, lam laihoi,  
\q2 ama teh pholen awh.  
\q2 Rui thueng e naw kueng laihoi,  
\q2 vovit tum laihoi ama teh pholen awh.   
\q1
\v 5 Cecak khawng laihoi ama teh pholen awh.  
\q2 Kacaipounge cecak khawng laihoi ama teh pholen awh.   
\q1
\v 6 Kahring e moithang pueng ni  
\q2 BAWIPA teh pholen awh naseh.  
\q2 Hallelujah.   