\id TDX
\h Topical Index
\toc1 Dora 'anai sadoi'i tatara nara maani'i tara'i mareho ororiu
\toc2 Topical Index
\mt1 Dora 'anai sadoi'i tatara nara maani'i tara'i mareho ororiu
\p \k 'A'auhiai nata nei\k*
\pi1 (Helping others) \xt Matiu 6:1-4; 7:12; 25:31-46; Luk 3:10-11; 6:38; Buka Tatau'aro 11:27-30; 1 Korin 10:24; 2 Korin 8:1-15; 9:1-15; Galesia 6:9-10; Pilipae 4:14-19; Hibru 10:24; 13:1-3; 13:16; Jems 1:27; 2:15-16; 1 Jon 3:16-18. \xt*
\p \k 'Adoma'i nugasi\k*
\pi1 (Forgiveness)
\pi1 'Ia God 'a 'adoma'i nugasi'i 'inogaa'i. \xt Matiu 26:28; Mak 11:25-26; Buka Tatau'aro 5:31; 10:43; 26:18; Efesas 1:7; Kolosae 1:13-14; 2:13-14; Hibru 10:17-18; 1 Jon 1:8—2:2. \xt*
\pi1 'Adoma'i nugasiai nata nei. \xt Matiu 6:12-15; 18:21-35; Mak 11:25; Luk 6:37; 17:3-4; 2 Korin 2:5-11; Efesas 4:31-32; Kolosae 3:13. \xt*
\p \k Araisuria God\k*
\pi1 (Obedience to God) \xt Jon 14:15; 14:21; 14:23-24; 15:10-17; Rom 13:8-10; 1 Pita 1:14-16; 1 Jon 2:3-8; 3:22-24; 2 Jon 5-6. \xt*
\p \k Aro\k*
\pi1 (Heaven) \xt Luk 12:32-34; Jon 14:1-3; 2 Korin 5:1-8; Pilipae 1:23; Kolosae 3:1; 1 Pita 1:4-5; Buka Ha'ata'i 4:1-11; 21:1-4; 21:22—22:5; 22:14-15. \xt*
\p \k Awa manego; Ha'a-anoano'o; Ha'a-auruhi'o\k*
\pi1 (Humility) \xt Matiu 5:3-12; 18:1-5; Luk 14:7-11; 18:9-14; Efesas 4:2; Pilipae 2:3-11; Kolosae 3:12-13; Jems 4:5-10; 1 Pita 5:5-7. \xt*
\p \k Baronganai sae hinihini\k*
\pi1 (Characteristics of a Christian) \xt Jon 13:34-35; 14:27; Rom 12:9-13; Galesia 5:22-26; Kolosae 3:12-17; 1 Tesalonaeka 5:16-18. \xt*
\p \k Bwareomaea\k*
\pi1 (Baptism) \xt Matiu 28:18-20; Jon 3:22; 4:1-2; Buka Tatau'aro 2:37-42; 8:12; 8:36-38; 10:44-48; 16:14-15; 16:31-33; 19:1-7; 22:12-16; Rom 6:1-4; Galesia 3:26-27; Kolosae 2:12; 1 Pita 3:20-22. \xt*
\p \k Dora ni ha'amama'ai; Dora ni rongomaata'i; 'Eu na bwa'i kuru\k*
\pi1 (Hell) \xt Matiu 10:28; 13:41-42, 47-50; 25:41; Luk 16:23-26; 2 Tesalonaeka 1:9; Buka Ha'ata'i 20:10-15; 21:8. \xt*
\p \k Gare ana'ia God\k*
\pi1 (Children of God) \xt Jon 1:12-13; Rom 8:14-17; Galesia 4:6-7; Hibru 12:5-11; 1 Jon 3:1-3. \xt*
\p \k God\k*
\pi1 (God) \xt Mak 10:27; 12:29-30; Luk 1:37; 6:35-36; Jon 4:24; Buka Tatau'aro 14:14-17; 17:22-31; Rom 1:18-23; 11:33-36; 1 Korin 8:4-6; 2 Korin 1:3; 1 Timoti 1:17; 6:15-16; Hibru 4:13; 10:30-31; Jems 1:17; 1 Pita 1:14-17; 1 Jon 1:5; 4:7-12; 4:16; Jiud 24-25; Buka Ha'ata'i 4:8-11; 15:3-4. \xt*
\p \k Gono raha 'ini waini bweu\k*
\pi1 (Drunkenness) \xt Rom 13:13; 1 Korin 5:11; 6:9-11; Galesia 5:19-21; Efesas 5:18; 1 Timoti 3:1-3; Taetas 1:7; 1 Pita 4:3-5. \xt*
\p \k Gaumani\k*
\pi1 (Government) \xt Matiu 22:15-22; Buka Tatau'aro 5:27-29; Rom 13:1-7; 1 Timoti 2:1-4; Taetas 3:1; 1 Pita 2:13-17. \xt*
\p \k Ha'a; Toto'ora\k*
\pi1 (Money, possessions) \xt Matiu 6:19-21; 6:24-34; Luk 12:13-21; 12:32-34; Buka Tatau'aro 20:35; 1 Timoti 6:6-10; 6:17-19; Hibru 13:5-6; Jems 2:1-9; 5:1-6. \xt*
\p \k Ha'agorohiai sae baaniai daoha\k*
\pi1 (Healing) \xt Matiu 4:23-25; 9:35; 11:2-5; Buka Tatau'aro 3:1-6; 8:4-8; 19:11-16; 28:8-9; 1 Korin 12:9; 12:29-30; 2 Korin 12:7-10; 1 Timoti 5:23; 2 Timoti 4:20; Jems 5:14-15. \xt*
\p \k Ha'apwa'ara\k*
\pi1 (Creation) \xt Matiu 19:4; Jon 1:3; Buka Tatau'aro 14:15; 17:24-26; 1 Korin 8:6; Kolosae 1:15-16; Hibru 1:2; 11:3; Buka Ha'ata'i 4:11. \xt*
\p \k Ha'arahesi\k*
\pi1 (Prayer)
\pi1 Ha'ausuringa'i 'ini ha'arahesi. \xt Matiu 6:5-13; 7:7-11; 18:19-20; Mak 11:24-25; Luk 11:1-13; 18:1-8; 21:36; Jon 14:13-14; 15:7; 16:23-26; Rom 8:26-27; 12:12; Efesas 2:18; 6:18; Pilipae 4:6-7; Kolosae 4:2; 1 Tesalonaeka 5:17; 1 Timoti 2:1-4; 2:8; 4:4-5; Hibru 4:16; 10:19-22; Jems 1:5-8; 4:2-3; 5:13-18; 1 Pita 4:7; 1 Jon 3:21-22; 5:14-15. \xt*
\pi1 Heiha'auu 'ini ha'arahesi. \xt Matiu 11:25-26; 14:23; 19:13-15; Mak 1:35; Luk 5:16; 6:12; 22:32; 22:39-46; Jon 11:41-42; 17:1-26; Buka Tatau'aro 4:24-31; 16:25; 20:36; 21:5; Rom 1:9-10; 10:1-2; 15:30-33; 2 Korin 12:7-10; Efesas 1:15-20; 3:14-21; 6:19-20; Pilipae 1:3-5; 1:9-11; Kolosae 1:9-12; 4:3-4; 1 Tesalonaeka 3:9-13; 2 Tesalonaeka 1:11-12; 3:1-5; Hibru 5:7; 7:25. \xt*
\p \k Ha'arahesi araaranunu mana haa'i ha'abu'oahu 'iniai mena anai adaro\k*
\pi1 (Idol worship and Sorcery) \xt Matiu 4:10; Buka Tatau'aro 13:4-12; 17:22-31; 19:11-20; 1 Korin 5:11; 6:9-11; 8:1-13; 10:1-22; 2 Korin 6:14-18; Galesia 5:19-21; 1 Tesalonaeka 1:9-10; 1 Jon 5:21; Buka Ha'ata'i 21:8; 22:15. \xt*
\p \k Ha'ariri 'ini ngau; Nuga ngau\k*
\pi1 (Fasting) \xt Matiu 6:16-18; Mak 2:18-20; Buka Tatau'aro 13:1-3; 14:23. \xt*
\p \k Ha'atee ha'agorohiai nata nei; Tagio tanaai nata nei\k*
\pi1 (Thankfulness) \xt Luk 17:11-19; Jon 6:11; Rom 1:21; Efesas 5:20; Kolosae 2:7; 3:17; 4:2; 1 Tesalonaeka 5:18; 1 Timoti 2:1; 4:4-5. \xt*
\p \k Hagu nagai haua beiraaui sae hinihini\k*
\pi1 (Fellowship with believers) \xt Matiu 18:19-20; Buka Tatau'aro 2:41-47; Rom 12:4-8; Efesas 1:22-23; 4:11-16; Kolosae 3:15-17; 1 Timoti 4:13; Hibru 10:24-25. \xt*
\p \k Haigaasi\k*
\pi1 (Divorce) \xt Matiu 5:31-32; 19:3-9; Luk 16:18; Rom 7:2-3; 1 Korin 7:10-16. \xt*
\p \k Heisoi ana Jisas Kraest\k*
\pi1 (Church of Jesus Christ) \xt Matiu 16:13-20; Buka Tatau'aro 2:41-42; Rom 12:4-8; 1 Korin 12:12-30; Efesas 1:22-23; 2:19-22; 4:1-16; Kolosae 1:18; Hibru 10:24-25; 1 Pita 2:4-10; Buka Ha'ata'i 19:5-10. \xt*
\p \k Heita'ahi\k*
\pi1 (Love)
\pi1 Heita'ahi ana God tanagia. \xt Jon 3:16; Rom 5:8; Efesas 2:4-5; 1 Jon 4:9-10. \xt*
\pi1 Gai ta'ahia God. \xt Matiu 22:37-38; Mak 12:28-30; Jon 14:21; 1 Pita 1:8; 1 Jon 5:3. \xt*
\pi1 Gai ta'ahigaau hairiu. \xt Matiu 5:43-48; 22:39; Jon 13:34-35; 15:12-17; Rom 12:9-10; 13:8-10; 1 Korin 13:1-13; 16:14; Galesia 5:13-14; 1 Tesalonaeka 4:9-10; 1 Pita 4:8; 1 Jon 2:9-11; 3:11-18; 4:7-21. \xt*
\p \k Herehere 'anai ha'ahehoa Saetan mana heiohongi\k*
\pi1 (Overcoming Satan and temptation) \xt Matiu 4:1-11; 6:13; Luk 22:31-32; Jon 17:14-19; Rom 8:31-39; 12:12; 16:19-20; 1 Korin 10:12-13; 16:13; 2 Korin 12:7-10; Efesas 3:20-21; 6:10-18; Pilipae 4:13; 1 Tesalonaeka 3:5-8; 2 Tesalonaeka 3:3; 2 Timoti 1:7-8; Hibru 2:18; 4:14-16; 12:1-2; Jems 4:7; 1 Pita 1:5; 5:8-11; 1 Jon 4:4; 5:3-5; Buka Ha'ata'i 12:7-12. \xt*
\p \k Hihiiri ana God; Dangi ni hihiiri\k*
\pi1 (Judgment of God) \xt Matiu 7:21-23; 16:24-27; 25:31-46; Jon 3:18-21; 5:24-29; Buka Tatau'aro 17:30-31; Rom 2:1-11; 14:10-12; 1 Korin 3:10-15; 4:5; 2 Korin 5:9-10; 2 Tesalonaeka 1:5-10; Hibru 9:27-28; 10:26-31; 1 Pita 1:17; 4:3-5; Buka Ha'ata'i 20:11-15. \xt*
\p \k Hinihini\k*
\pi1 (Faith, believing)
\pi1 Dauai tahi tarau 'iniai hinihini. \xt Jon 1:12; 3:15-18; 3:36; 6:47; 14:6; 20:31; Buka Tatau'aro 4:12; 16:30-31; Rom 3:20-22; 10:9-10; Galesia 2:16; Efesas 2:8-9. \xt*
\pi1 Hinihini nagai haua 'onaai sae hinihini. \xt Mak 11:22-25; Luk 17:5-6; Jon 14:1; Rom 5:1-2; 14:22-23; 1 Korin 13:13; 2 Korin 5:6-7; Galesia 5:6; Hibru 11; Jems 1:2-8; 2:14-26; 1 Pita 1:3-9. \xt*
\p \k Hi'ona Maea\k*
\pi1 (Holy Spirit) \xt Matiu 28:19; Mak 1:9-11; 3:28-30; Luk 1:35; 3:16; 4:1; 11:13; 12:12; Jon 1:32-34; 3:5-8; 7:37-39; 14:15-17; 14:26; 15:26; 16:7-15; 20:19-23; Buka Tatau'aro 1:4-5; 1:8; 2:1-18; 2:38-39; 4:31; 5:3-5; 8:14-17; 10:44-48; 13:2-4; 15:28; 16:7-10; 19:1-7; Rom 5:5; 7:6; 8:9-16; 8:26-27; 1 Korin 2:4; 2:9-16; 3:16; 6:11; 6:19; 12:1-13; 2 Korin 1:21-22; 5:5; Galesia 3:2-5; 4:6; 5:16-18; 5:22-25; Efesas 1:13-14; 1:17; 3:16; 4:3-4; 4:30; 5:18-20; 6:17-18; 1 Tesalonaeka 1:5-6; 5:19; 2 Tesalonaeka 2:13; Taetas 3:5-6; Hibru 2:4; 9:14; 1 Pita 1:2; 1:11; 2 Pita 1:20-21; 1 Jon 2:20; 3:24; 4:13; 5:6-8. \xt*
\p \k Ho'asi; Watea Haari'o tanaa God\k*
\pi1 (Sacrifice) \xt Matiu 9:13; Mak 12:33; Rom 12:1; Hibru 9:6—10:18. \xt*
\p \k Jisas Kraest\k*
\pi1 (Jesus Christ)
\pi1 Jisas Kraest na Garena God. \xt Matiu 11:27-30; 16:13-17; Luk 1:35; Jon 1:1-18; 5:19-29; 6:35-40; 8:58; 11:25-27; 14:5-11; 17:1-5; 20:26-31; Buka Tatau'aro 3:13-16; 4:10-12; Rom 1:3-4; 1 Korin 3:11; 2 Korin 4:4-6; 5:21; Galesia 4:4-5; Pilipae 2:5-11; Kolosae 1:15-20; 2:9-10; Hibru 1:1-14; 7:26-28; 1 Jon 2:1-2; 5:20; Buka Ha'ata'i 1:12-18; 19:11-16. \xt*
\pi1 Jisas Kraest 'a huta 'onaai noni. \xt Jon 1:14; Luk 1:26-38; Matiu 1:18-25; Luk 2:1-20; Matiu 2:1-23; Galesia 4:4-5; Pilipae 2:6-7; Hibru 2:14-18. \xt*
\pi1 Jisas 'a ha'ausuriraaui noni ma ha'agorohiraau baani'i daoha. \xt Matiu 4:23-25; 7:28-29; 9:35-36; 11:1-6; Luk 4:14-44; Buka Tatau'aro 10:36-38; Jon 20:30-31. \xt*
\pi1 Jisas 'a haa'i mwani ha'abu'oahu. \xt Matiu 8:1-4; 8:5-13; 8:14-15; 8:23-27; 8:28-33; 9:1-7; 9:18-26; 9:27-31; 9:32-33; 12:9-14; 12:22; 14:15-21; 14:22-32; 15:22-28; 15:32-38; 17:14-18; 20:29-34; 21:18-22; Mak 1:21-28; 7:32-37; 8:22-25; Luk 5:4-8; 7:11-15; 13:10-13; 14:1-4; 17:12-14; 22:50-51; Jon 2:1-11; 4:46-54; 5:5-9; 9:1-7; 11:11-44; 21:4-6; Buka Tatau'aro 2:22. \xt*
\pi1 'Iraau na'otara rau daua Jisas marau hiiria 'anai ha'amaesia. \xt Matiu 26:47-68; 27:1-2; 27:11-31; Mak 14:43-65; 15:1-20; Luk 22:47-53; 22:63-71; 23:1-25; Jon 18:1-14; 18:19-24; 18:28—19:16. \xt*
\pi1 Ra rabua Jisas na'i dadaahoro. \xt Matiu 27:32-56; Mak 15:21-41; Luk 23:26-49; Jon 19:17-37. \xt*
\pi1 Ra aoraa Jisas na'i wabwa. \xt Matiu 27:57-66; Mak 15:42-47; Luk 23:50-56; Jon 19:38-42. \xt*
\pi1 Jisas 'a tahi aho'i ma ha'ata'i tanaraaui noni. \xt Matiu 28:1-20; Mak 16:1-8; Luk 24:1-49; Jon 20:1—21:14; Buka Tatau'aro 1:3-8; 2:24-32; 3:15; 4:10; 4:33; 10:39-43; 13:29-39; 17:2-3; 17:30-31; Rom 1:4; 4:24-25; 1 Korin 15:3-8; 15:12-21; Buka Ha'ata'i 1:18. \xt*
\pi1 Jisas 'a ara'ai aro. \xt Luk 24:50-51; Buka Tatau'aro 1:9-11; 2:32-36; 5:30-31; Rom 8:34; Efesas 1:20-23; Pilipae 2:9-11; Hibru 1:3-11; 2:9; 4:14-16; 7:25-26; 10:12-14; 1 Pita 3:22. \xt*
\pi1 Jisas 'ai boi aho'i mau. \xt Matiu 24:29-44; Jon 14:1-3; Buka Tatau'aro 1:10-11; 3:19-21; Pilipae 3:20-21; Kolosae 3:4; 1 Tesalonaeka 1:9-10; 3:13; 4:13—5:11; 2 Tesalonaeka 1:6-10; 2:1-4; 1 Timoti 6:13-15; 2 Timoti 4:8; Hibru 9:28; 2 Pita 3:1-18; 1 Jon 3:1-3; Buka Ha'ata'i 1:7; 22:12-13. \xt*
\p \k Mae\k*
\pi1 (Death) \xt Jon 6:39-40; 11:17-27; 14:1-4; Rom 8:10-11; 8:38-39; 14:7-9; 1 Korin 15:12-58; 2 Korin 5:1-10; Pilipae 1:20-24; 1 Tesalonaeka 4:13-18; Hibru 2:14-15; Buka Ha'ata'i 14:13; 21:1-4; 22:1-5. \xt*
\p \k Na'otara na'i heisoi\k*
\pi1 (Church leaders)
\pi1 Barongadi na'otara na'i heisoi. \xt Buka Tatau'aro 6:1-6; Buka Tatau'aro 14:23; 1 Timoti 3:1-13; Taetas 1:5-9. \xt*
\pi1 Ha'ausuringa'i tanaraaui na'otara na'i heisoi. \xt Matiu 28:18-20; Luk 22:24-27; Buka Tatau'aro 20:17-35; 1 Tesalonaeka 2:1-12; 1 Timoti 4:1-16; 2 Timoti 2:1-26; 3:10-17; 4:1-5; Taetas 2:7-8; 1 Pita 5:1-4. \xt*
\pi1 Ha'ahouraaui na'otara na'i heisoi. \xt 1 Korin 9:14; Galesia 6:6; 1 Tesalonaeka 5:12-13; 1 Timoti 5:17-22; Hibru 13:7; 13:17. \xt*
\p \k Ngau maea\k*
\pi1 (The Lord's Supper) \xt Matiu 26:26-30; Mak 14:22-26; Luk 22:14-20; Jon 6; 1 Korin 10:14-22; 11:17-34. \xt*
\p \k Nora ta'airaaui sae hinihini\k*
\pi1 (Persecution) \xt Matiu 5:10-12; Mak 13:9-13; Luk 12:4-9; Jon 15:18-21; 16:1-4; Buka Tatau'aro 5:41; Rom 8:35-37; 12:12-14; 12:17-21; 1 Korin 4:11-13; 2 Korin 4:8-11; 12:10; Pilipae 1:28-29; 2 Tesalonaeka 1:4-8; 3:2-4; 2 Timoti 3:10-13; Hibru 10:32-39; 12:3-4; 1 Pita 3:13-17; 4:12-19; Buka Ha'ata'i 2:10. \xt*
\p \k Odo-odo na'i maana God\k*
\pi1 (Justification) \xt Buka Tatau'aro 13:38-39; Rom 3:21-26; 5:1; 5:9-10; 5:18-19; Galesia 2:16; 3:6-9; Taetas 3:7. \xt*
\p \k Ora-ora'a; 'Ino; Here ta'aa\k*
\pi1 (Sin)
\pi1 'E taha naasi ora-ora'a? \xt Rom 1:18-32; 8:5-8; Galesia 5:19-21; Efesas 2:1-3; 5:3-5; Kolosae 3:5-10; Jems 4:17; 1 Pita 4:3; 1 Jon 3:4-5. \xt*
\pi1 Mwani sae hako ra ora-ora'a. \xt Jon 8:7-9; Rom 3:9-20; 3:23; 5:12; Galesia 3:22; 1 Jon 1:8-10. \xt*
\pi1 'A ororiu do'ia God 'ai ha'atahiraaui noni baaniai ha'amama'ai nai boi ta 'oha. \xt Matiu 10:28; 13:41-42; Jon 3:18-20; 3:36; Buka Tatau'aro 17:30-31; Rom 1:18-19; 6:23; Galesia 6:7-8; Kolosae 3:5-6; 2 Tesalonaeka 1:7-9; Hibru 9:27; 10:26-31; 1 Pita 1:17; 4:3-5; Jiud 7; Buka Ha'ata'i 20:11-15. \xt*
\p \k Rihosi baaniai ora-ora'a\k*
\pi1 (Repentance) \xt Matiu 4:17; Mak 6:12; Luk 13:1-5; 15:1-31; 24:45-47; Buka Tatau'aro 2:37-40; 3:19-20; 17:29-31; 20:21; 26:19-20; 2 Korin 7:8-11; 2 Pita 3:9; Buka Ha'ata'i 9:20-21. \xt*
\p \k Rongomaata'i\k*
\pi1 (Suffering) \xt Rom 8:18-25; 8:28; 2 Korin 1:4; 4:16-18; Jems 1:2-4; 1 Pita 1:6-9; 2:19-21; 5:8-10. \xt*
\p \k Ruhasigaau ma'ua ha'atahigaau baaniai ora-ora'a; Dauai tahi tarau\k*
\pi1 (Salvation) \xt Jon 3:16-17; Buka Tatau'aro 2:37-39; 4:11-12; Rom 5:1-11; 10:9-13; Efesas 2:1-10; 1 Timoti 1:15-16; 2:3-7; 1 Pita 1:3-5. \xt*
\p \k Saetan\k*
\pi1 (Satan) \xt Matiu 13:19; 25:41; Luk 4:1-13; 22:3-4; Jon 8:42-44; 2 Korin 2:10-11; 4:4; 11:13-15; Efesas 2:2; 1 Tesalonaeka 2:18; 2 Tesalonaeka 2:9-12; 1 Pita 5:8-9; 1 Jon 3:8-10; Buka Ha'ata'i 12:7-12; 20:1-3; 20:10. \xt*
\p \k Tahinganai rua sae ha'iwai bei'i gare adaru'i\k*
\pi1 (Family life)
\pi1 Rua ha'iwai. \xt Matiu 19:4-6; 1 Korin 7:1-16; Efesas 5:21-33; Kolosae 3:18-19; Taetas 2:3-5; Hibru 13:4; 1 Pita 3:1-7. \xt*
\pi1 Mwani gare. \xt Matiu 15:3-6; Luk 2:51; Efesas 6:1-3; Kolosae 3:20; 1 Timoti 5:4; 5:8; Hibru 12:7-11. \xt*
\pi1 Ama mana ina. \xt Efesas 6:4; Kolosae 3:21; 1 Timoti 3:4-5. \xt*
\pi1 'Iraaui nao. \xt Buka Tatau'aro 6:1; Rom 7:2-3; 1 Korin 7:39-40; 1 Timoti 5:3-16; Jems 1:27. \xt*
\p \k Tahi tarau\k*
\pi1 (Eternal life) \xt Matiu 19:16-30; Luk 10:25-28; Jon 3:1-16; 5:19-29; 10:10; 11:25-26; 14:6; 17:2-3; 20:31; Rom 5:21; 6:5-14; 8:10-17; 2 Korin 5:17; Galesia 2:20; Efesas 2:1-6; Kolosae 2:13; 3:1-4; 2 Timoti 1:10; Taetas 3:4-7; 1 Pita 1:23; 1 Jon 5:11-13. \xt*
\p \k Taritari'a baaniai urao amua ma'ua mwane amua\k*
\pi1 (Adultery) \xt Matiu 5:27-30; Jon 8:2-11; Rom 13:8-10; 6:9-20; Galesia 5:19; Hibru 13:4. \xt*
\p \k Taroha Goro\k*
\pi1 (Good news) \xt Buka Tatau'aro 20:24; Rom 1:2-4, 16-17; 1 Korin 1:17-25; 15:1-7; Galesia 1:6-12; Efesas 1:13; Pilipae 1:27; Kolosae 1:5-6; 1 Tesalonaeka 1:5; 2 Tesalonaeka 2:14; 2 Timoti 1:8-11; 2:8-10. \xt*
