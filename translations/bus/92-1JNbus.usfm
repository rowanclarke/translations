\id 1JN 1 John in Bokobaru, Ross Jones
\h 1 YOHANA
\toc1 YOHANA TAKADA KAAKU
\toc2 1 YOHANA
\mt1 YOHANA TAKADA KAAKU
\c 1
\s1 Yã wɛ̃̀ndidee
\p 
\v 1 Yã kɛ̀ kuu zaa káaku, kɛ̀ wa à yã mà, ben wa à è kↄ̃n wɛ́ɛo, wa à gwà, wa ↄ kɛ̀a, Yã wɛ̃̀ndidee pì baarun wée kpaaare.
\v 2 Wɛ̃̀ndidee pì bↄ̀ gupuraaa, wa à è, wámbe à sèedadeenↄ ũ. Wɛ̃̀ndidee pì kú De Luda kiiamɛ yã, ben à bↄ̀ à mↄ̀wazi. À baarun wée kpaaare.
\v 3 Yã kɛ̀ wá mà bensↄ̃ wá èn wée ooare, lɛ apinↄ se à e àgↄ̃ kúwao kↄ̃ gbɛ̃nↄ ũ, zaakɛ wá kuu kↄ̃ gbɛ̃nↄ ũ kↄ̃n De Ludaomɛ kↄ̃n à Nɛ́ Yesu Kirisi pìo.
\v 4 Wée yã kɛ̀nↄ ooare lɛ wa pↄnnaa e àgↄ̃ papana.
\s1 Luda nɛ́ gupuraamɛ
\p 
\v 5 Baaru kɛ̀ wá mà à kiia, wée kpaaareen yɛ̀: Luda nɛ́ gupuraamɛ, gusiaa kú à kiiaro, baa féte.
\v 6 Tó wa bè wá kúo kↄ̃ gbɛ̃nↄ ũ, ben wá kú gusiaan, ɛgɛɛn wée too, wée zĩi kɛ yãpuraaaro.
\v 7 Tó wá kú gupuraan, lán Ludaa kú gupuraan nà, ɛ̃ndɛ̃ wá kuu kↄ̃ gbɛ̃nↄ ũ, à Nɛ́ Yesu aru è wa durun píngi kɛ̃wa.
\p 
\v 8 Tó wa bè wá durun vĩro, wée wa zĩnda kɛkɛɛmɛ, yãpuraa kúwaro.
\v 9 Tó wa wa durunnↄ ò Ludanɛ, à náanɛ vĩ è yã kɛ a zɛ́a, eé wa durun pìnↄ kɛ̃wa, eé yã zaa píngi worowa.
\v 10 Tó wa bè wée durun kɛro, wa Luda dìɛ ɛgɛdee ũmɛ, à yã kú wa swɛ̃̀ guuro.
\c 2
\p 
\v 1 Ma nɛ́ yenzideenↄ, mɛ́ɛ yã beee ooare, lɛ àton durun kɛro yãnzimɛ. Mↄde tó a gbɛ̃ke durun kɛ̀, wá zɛnyodee vĩ De Luda kiia, àmbe taarisaide Yesu Kirisi ũ.
\v 2 Àmbe wa durunnↄ agbaakpabↄ ũ. Èe kɛ wa durunnↄn adoro, kↄ̃n anduna píngi gbɛ̃nↄ pↄ́omɛ.
\p 
\v 3 Tó wá yã kɛ̀ à dìɛnↄ kũna, beee ↄ̀dↄawe yãpura kɛ̀ wá à dↄ̃.
\v 4 Tó gbɛ̃ bè á à dↄ̃, ben à à yã kɛ̀ à dìɛnↄ kũnaro, ɛgɛdeemɛ, yãpuraa kú à swɛ̃̀ guuro.
\v 5 Gbɛ̃ kɛ̀ à à yã kũna sↄ̃, Luda yenzi papana à guu yãpura. Pↄ́ kɛ̀ eé tó wà dↄ̃ kɛ̀ wá kú à guun yɛ̀:
\v 6 Gbɛ̃ kɛ̀ bè á kú à guu, séde àgↄ̃ kuu lán Kirisi kuu nà yã.
\s1 Yã dufu diɛna
\p 
\v 7 Ma gbɛ̃ yenzideenↄ, èe kɛ yã dufun mɛ́ɛ ooarero, yã zii kɛ̀ wà dìɛare zaa káakumɛ. Yã zii pìn yã kɛ̀ á mà ũ.
\v 8 Baa kↄ̃n beeeo yã kɛ̀ mɛ́ɛ ooaree dufumɛ dↄ, wè à yãpuraa e à kiia kↄ̃n a kiiao, zaakɛ gusiaa e gɛ̃tɛɛ, ben gupura yãpura e puu sa.
\p 
\v 9 Gbɛ̃ kɛ̀ bè á kú gupuraan, ben à za a gbɛ̃daaan, adee kú gusiaa guumɛ ai tia.
\v 10 Gbɛ̃ kɛ̀ ye a gbɛ̃daaazi kú gupuraan, à yãke è tó gbɛ̃ke furo.
\v 11 Gbɛ̃ kɛ̀ za a gbɛ̃daaan kú gusiaan, à tɛ́ gusiaan, à dↄ̃ guu kɛ̀ èe gaanlo, kɛ̀ gusiaa à vĩ̀a kũ̀ yãnzi.
\q1 
\v 12 Ma nɛ́ yenzideenↄ, mɛ́ɛ beee ooare
\q1 kɛ̀ a durunnↄ kɛ̃̀awa à tↄ́ gãzĩ yãnzimɛ.
\q1 
\v 13 Mareenↄ, mɛ́ɛ beee ooare
\q1 kɛ̀ á gbɛ̃ kɛ̀ kuu zaa káaku dↄ̃ yãnzimɛ.
\q1 Gↄ̃kparɛnↄ, mɛ́ɛ beee ooare
\q1 kɛ̀ a zĩ̀ blè Setãn-a yãnzimɛ.
\q1 Ma nɛ́ yenzideenↄ, má òare
\q1 kɛ̀ á De Luda dↄ̃ yãnzimɛ.
\q1 
\v 14 Mareenↄ, má òare
\q1 kɛ̀ á gbɛ̃ kɛ̀ kuu zaa káaku dↄ̃ yãnzimɛ.
\q1 Gↄ̃kparɛnↄ, má òare
\q1 kɛ̀ á gbãa vĩ, Luda yã kú a swɛ̃̀ guu,
\q1 bensↄ̃ a zĩ̀ blè Setãn-a yãnzimɛ.
\b
\p 
\v 15 Àtongↄ̃ ye andunaziro ke pↄ́ kɛ̀ kú à guunↄ. Tó gbɛ̃ ye andunazi, à ye De Ludaziro.
\v 16 Zaakɛ yã kɛ̀ kú anduna guu píngi, mɛ̀ pↄ́nidɛna kↄ̃n sãnkarawɛɛo kↄ̃n auziki ĩadãnao e bↄ De Luda kiiaro, à bↄ̀ anduna kiiamɛ.
\v 17 Anduna e gɛ̃tɛɛ kↄ̃n a pↄ́nidɛnao, mↄde ludapↄyezikɛri égↄ̃ kuu gurↄ píngimɛ.
\s1 Kirisi ibɛɛ
\p 
\v 18 Ma nɛ́ yenzideenↄ, gurↄ zãan wá kún kɛ̀. Lán á mà kɛ̀ Kirisi ibɛɛ e mↄↄ nà, à ibɛɛnↄ gĩakɛ wà kɛ̀ pari. Beee ↄ̀dↄawe kɛ̀ wá kú gurↄ zãanↄa.
\v 19 Gbɛ̃ pìnↄ bↄ̀ wa kiiamɛ, mↄde wa gbɛ̃nↄnlo. Tó wa gbɛ̃nↄmɛ yã, lɛ aↄ̃ↄ kúwao. Aↄ̃ bↄ̀, lɛ wà dↄ̃ kɛ̀ aↄ̃ gbɛ̃kee kuu wa gbɛ̃ ũro yãnzimɛ.
\p 
\v 20 Apinↄ sↄ̃, Luda a Ninii dìare, ben á yãpuraa dↄ̃ a píngi.
\v 21 Ma beee òare, kɛ̀ á yãpura dↄ̃ yãnzimɛ, èe kɛ kɛ̀ á dↄ̃ro yãnzinlo. Á dↄ̃ kɛ̀ ɛgɛ ke è bↄ yãpuraa guuro.
\v 22 Dén ɛgɛdee ũu? Gbɛ̃ kɛ̀ gì Yesu mɛsayakɛɛzimɛ. Gbɛ̃ beeen Kirisi ibɛɛ ũ, à gì De Ludazi kↄ̃n à Nɛ́omɛ.
\v 23 Gbɛ̃ kɛ̀ gì Luda Nɛ́zi De Luda vĩro. Gbɛ̃ kɛ̀ zɛ̀ kↄ̃n Luda Nɛ́o bé à De Luda vĩ.
\p 
\v 24 À tó yã kɛ̀ á mà zaa káaku gↄ̃ kú a swɛ̃̀ guu. Tó yã kɛ̀ á mà zaa káaku pì kú a swɛ̃̀ guu, apinↄ sↄ̃, ègↄ̃ kú Luda Nɛ́ guu kↄ̃n à Deo.
\v 25 Pↄ́ kɛ̀ Kirisi à lɛ́ gbɛ̃̀ween wɛ̃̀ndi kɛ̀ è yãaroo ũ.
\p 
\v 26 Ma yã beee òare gbɛ̃ kɛ̀ aↄ̃ↄe a sãsãanↄ yã musu.
\v 27 Amↄanↄ sↄ̃, Ninii kɛ̀ á è Kirisia kú a guu. A bà kú kↄ̃n gbɛ̃ke yãdadanaareeoro, zaakɛ à Ninii e yã píngi dadaaare, à yãpuraa vĩ, ɛgɛɛ kú à guuro. Lán èe dadaaare nà, àgↄ̃ kú Kirisi guu lɛ.
\p 
\v 28 Tia sa ma nɛ́ yenzideenↄ, àgↄ̃ kú à guu, lɛ gurↄↄ kɛ̀ à bↄ̀ gupuraaa, wa swɛ̃̀ gↄ̃ diɛna, wí tón wa kũ à sugurↄro.
\p 
\v 29 Zaakɛ á dↄ̃ kɛ̀ Ludaa maa, àgↄ̃ dↄ̃ kɛ̀ yãmaakɛri píngi nɛ́ à nɛ́mɛ.
\c 3
\s1 Luda nɛ́nↄ
\p 
\v 1 À gwa lán De Ludaa yewazi à kɛ̀ bíta nà ai è wa sisi a nɛ́nↄ. Wá sↄ̃ↄ dɛ à ũ! Anduna wa dↄ̃ro, kɛ̀ èe à dↄ̃ro yãnzi.
\v 2 Ma gbɛ̃ yenzideenↄ, Luda nɛ́nↄn wa ũ tia, dian wégↄ̃ dɛ nà e bↄ gupuraaa kↄ̀ro. Wá dↄ̃ kɛ̀ gurↄↄ kɛ̀ eé bↄ gupuraaa, wégↄ̃ dɛ lán à bà, zaakɛ wé wɛ́ɛ siàlɛ wà e lán à dɛ nà.
\v 3 Gbɛ̃ kɛ̀ wɛ́ɛ dↄzi lɛ è a swɛ̃̀ pípi, lán Kirisi swɛ̃̀ pipina nà.
\p 
\v 4 Gbɛ̃ kɛ̀ durun kɛ̀ bↄ̀ doka kpɛɛmɛ, zaakɛ durunkɛna nɛ́ bↄna doka kpɛɛmɛ.
\v 5 Á dↄ̃ kɛ̀ Kirisi mↄ̀ durunkɛ̃nnɛna yãnzimɛ, durun sↄ̃ↄ kú à swɛ̃̀ guuro.
\v 6 Gbɛ̃ kɛ̀ kú à guu ègↄ̃ kpɛɛ gↄ̃ durun kɛɛro. Durunkɛri kee e à ero, èe à dↄ̃ro.
\p 
\v 7 Ma nɛ́nↄ, àton tó gbɛ̃ke a sãsãro, yãmaakɛri bé à maa, lán Kirisi maa nà.
\v 8 Gbɛ̃ kɛ̀ è durun kɛɛ nɛ́ Ibilisi pↄ́mɛ, zaakɛ Ibilisi durun kɛ̀ zaa káakumɛ. Ibilisi yãnↄ kaatɛna yãnzin Luda Nɛ́ mↄ̀zi.
\v 9 Gbɛ̃ kɛ̀ Ludaa ì ègↄ̃ kpɛɛ gↄ̃ durun kɛɛro, zaakɛ Luda borii bé à kú à guu. Eé fↄ̃ àgↄ̃ kpɛɛ gↄ̃ durun kɛɛro, kɛ̀ Luda à ì yãnzi.
\v 10 Dian wá Luda nɛ́nↄ dↄ̃kↄ̃zi kↄ̃n Ibilisi nɛ́nↄon yɛ̀: Gbɛ̃ kɛ̀ è yã maaa kɛro ke gbɛ̃ kɛ̀ ye a gbɛ̃daaaziroo nɛ́ Luda nɛ́nlo.
\s1 Yekↄ̃zina
\p 
\v 11 Yã kɛ̀ á mà zaa káakun yɛ̀: Wàgↄ̃ yekↄ̃zi.
\v 12 Àtongↄ̃ dɛ lán Kaini bàro. À kuu Setãn pↄ́ ũmɛ, ben à a dãaro dɛ̀. Bↄ́yãnzin à à dɛ̀zi? Kɛ̀ à yãkɛna zaa, bensↄ̃ à dãaro pↄ́ maa yãnzimɛ.
\v 13 Ma gbɛ̃nↄ, tó anduna zàagu, àton tó à bↄ a saɛro.
\v 14 Wá dↄ̃ kɛ̀ wa bↄ gaan wa gɛ̃ wɛ̃̀ndi guu, kɛ̀ wá ye wa Yesude daanↄzi yãnzi. Gbɛ̃ kɛ̀ ye gbɛ̃ziroo nɛ́ gɛ̀mɛ ai tia.
\v 15 Gbɛ̃ kɛ̀ zà a gbɛ̃daaan nɛ́ gbɛ̃dɛrimɛ. Á dↄ̃ kɛ̀ gbɛ̃dɛri ke ègↄ̃ wɛ̃̀ndi kɛ̀ è yãaroo vĩ a guuro.
\p 
\v 16 Yã kɛ̀ wá yenzi pì dↄ̃̀an yɛ̀: Kirisi a zĩnda kpà wa yãnzi. Wapinↄ sↄ̃, séde wà wa zĩnda kpá wa Yesude daanↄa.
\v 17 Tó gbɛ̃ anduna pↄ́ vĩ, ben à è a Yesude daa kú pↄ́nidɛna guu, tó èe à wɛ̃nda dↄ̃ro, Luda yenzi kú à swɛ̃̀ guuↄ́?
\v 18 Ma nɛ́ yenzideenↄ, wàtongↄ̃ yekↄ̃zi kↄ̃n lɛ́oro. Wàgↄ̃ yekↄ̃zi yãpuraa guu kↄ̃n wa yãkɛnao.
\v 19 Beee ↄ̀dↄawe kɛ̀ yãpura gbɛ̃nↄn wa ũ, gbasa wa swɛ̃̀ e àgↄ̃ diɛna Luda aɛ.
\v 20 Tó wá laasuu e wa kù vĩi sↄ̃, wá dↄ̃ kɛ̀ Luda bíta dɛ wa laasuula, à yã píngi dↄ̃.
\p 
\v 21 Ma gbɛ̃ yenzideenↄ, tó wá laasuu e wa kù vĩro, wa swɛ̃̀ égↄ̃ diɛna Luda aɛ,
\v 22 kɛ̀ wá yã kɛ̀ à dìɛnↄ kũna, ben wée yã kɛ̀ è kánɛ kɛɛ yãnzi, wé pↄ́ kɛ̀ wá gbèkaa e.
\v 23 Yã kɛ̀ à dìɛween yɛ̀: Wà à Nɛ́ Yesu Kirisi náanɛ kɛ, wégↄ̃ yekↄ̃zi lán à dìɛwe nà.
\v 24 Gbɛ̃ kɛ̀ yã kɛ̀ à dìɛnↄ kũna kú à guu, Luda pì kú adee guu se. Wá dↄ̃ kɛ̀ à kú wa guu à Ninii kɛ̀ à kpàwa yãnzi.
\c 4
\s1 Niniinↄ dↄ̃kↄ̃zina
\p 
\v 1 Ma gbɛ̃ yenzideenↄ, àton nini píngi náanɛ kɛro. À niniinↄ tàasi kɛ à gwa, tó aↄ̃ bↄ̀ Luda kiiamɛ, zaakɛ annabi ɛgɛɛnↄ pari kũ̀ anduna guu.
\v 2 Yã kɛ̀ eé tó à Luda Nini dↄ̃ↄn yɛ̀: Ninii kɛ̀ bè Yesu Kirisi mↄ̀ gbɛ̃ntee ũu bↄ̀ Luda kiiamɛ.
\v 3 Ninii kɛ̀ Yesu dↄ̃ lɛroo e bↄ Luda kiiaro. Kirisi ibɛɛ kɛ̀ á mà èe mↄↄn gwe. À sↄ̃ↄ kú anduna guu kↄ̀.
\p 
\v 4 Ma nɛ́ yenzideenↄ, Luda gbɛ̃nↄn a ũ, a zĩ̀ blè annabi ɛgɛɛ pìnↄa, zaakɛ gbɛ̃ kɛ̀ kú a guu bíta dɛ gbɛ̃ kɛ̀ kú anduna guula.
\v 5 Anduna gbɛ̃nↄn ń ũ. Beee yãnzin aↄ̃è yã o anduna zɛ́kpaɛ guuzi, ben anduna gbɛ̃nↄ è ń yã ma.
\v 6 Luda gbɛ̃nↄn wa ũ. Gbɛ̃ kɛ̀ Luda dↄ̃ↄ è wa yã ma, gbɛ̃ kɛ̀ kú Luda pↄ́ ũroo è wa yã maro. Àmbe à tò wá Nini Yãpurade dↄ̃kↄ̃zi kↄ̃n nini ɛgɛdeeo.
\s1 Ludan yenzi ũ
\p 
\v 7 Ma gbɛ̃ yenzideenↄ, wàgↄ̃ yekↄ̃zi, zaakɛ yenzi è bↄ Luda kiiamɛ. Gbɛ̃ kɛ̀ yenzi vĩ nɛ́ Luda nɛ́mɛ, à Luda dↄ̃.
\v 8 Gbɛ̃ kɛ̀ yenzi vĩroo Luda dↄ̃ro, zaakɛ Ludan yenzi ũ.
\v 9 Dian Luda a yenzi ↄ̀dↄawe gupuraaa nàn yɛ̀: À a Nɛ́ mɛ̀n do léle zĩ̀ anduna guu, lɛ wà wɛ̃̀ndi e kↄ̃n à gbãaao.
\v 10 Yenzi pìn yɛ̀: Èe kɛ wámbe wá ye Ludaziro, Luda bé à yewazi, ben à a Nɛ́ zĩ̀ wa durunnↄ agbaakpapↄ ũ.
\v 11 Ma gbɛ̃ yenzideenↄ, lán Ludaa yewazi lɛ nà, séde wàgↄ̃ yekↄ̃zi.
\v 12 Gbɛ̃kee e wɛ́ɛ si Ludalɛ zikiro, Mↄde tó wá yekↄ̃zi, Ludaa kú wa guu, ben à yenzi pì papana wa guu.
\p 
\v 13 Wá dↄ̃ kɛ̀ wá kú à guu bensↄ̃ à kú wa guu, kɛ̀ à a Ninii kpàwa yãnzi.
\v 14 Wá è, ben à sèedadeenↄn wa ũ, kɛ̀ De Luda a Nɛ́ zĩ̀ anduna Mìsiri ũ.
\v 15 Gbɛ̃ kɛ̀ ò gupuraan kɛ̀ Yesu nɛ́ Luda Nɛ́mɛ, Ludaa kú à guu, bensↄ̃ à kú Luda guu.
\v 16 Wá Luda yenawazii dↄ̃, ben wá à náanɛ vĩ.
\p Ludan yenzi ũ. Gbɛ̃ kɛ̀ ègↄ̃ yenzi vĩ kú Luda guu, ben Ludaa kú à guu.
\v 17 Pↄ́ kɛ̀ tò yenzi pì papana wa guun yɛ̀: Wa swɛ̃̀ égↄ̃ diɛna yãkpaɛkɛgurↄↄ zĩ. Zaakɛ lán Kirisi dɛ nà, wapinↄ se, lɛn wá dɛ lɛ anduna kɛ̀ guu.
\v 18 Yenzi pì ègↄ̃ vĩa vĩro. Yenzi wásawasa è pɛ́ vĩaa, zaakɛ vĩa nɛ́ wɛ́ɛtãmma yãmɛ. Vĩadee yenzi ègↄ̃ wásawasaro.
\p 
\v 19 Wapinↄ, wá yenzi vĩ, kɛ̀ Luda gĩakɛ à yewazi yãnzimɛ.
\v 20 Tó gbɛ̃ bè á ye Ludazi, ben à zà a Yesude daaan, ɛgɛdeemɛ. Zaakɛ gbɛ̃ kɛ̀ ye a Yesude daaa kɛ̀ èe eeziro, eé fↄ̃ àgↄ̃ ye Luda kɛ̀ èe à erooziↄ́?
\v 21 Yã kɛ̀ à dìɛween yɛ̀: Gbɛ̃ kɛ̀ ye Ludazi, séde àgↄ̃ ye a Yesude daaazi.
\c 5
\s1 Luda Nɛ́ náanɛkɛna
\p 
\v 1 Gbɛ̃ kɛ̀ è Yesu náanɛ kɛ Mɛsaya ũ, Luda bé à adee ì. Gbɛ̃ kɛ̀ ye dezi ye à nɛ́zimɛ se.
\v 2 Tó wá ye Ludazi, ben wá yã kɛ̀ à dìɛnↄ kũna, beee bé à ↄ̀dↄawe kɛ̀ wá ye Luda nɛ́nↄzi.
\v 3 Zaakɛ yena Ludazi bé à dɛ yã kɛ̀ à dìɛnↄ kũna ũ. Yã kɛ̀ à dìɛ pìnↄↄ kuu asoo ũ sↄ̃ro.
\v 4 Zaakɛ gbɛ̃ kɛ̀ Ludaa ì è zĩ̀ ble andunaamɛ. Wa ludanaanɛkɛna bé è tó wà zĩ̀ ble andunaa.
\v 5 Dé bé è zĩ̀ ble andunaa? Sé gbɛ̃ kɛ̀ sì kɛ̀ Yesu nɛ́ Luda Nɛ́mɛ.
\s1 Yesu Kirisi sèedadeenↄ
\p 
\v 6 Yesu Kirisi pìn gbɛ̃ kɛ̀ mↄ̀ à batisi kɛ̀ à a aru kwɛ̀ɛ ũ. Èe kɛ batisimɛ adoro, à batisi kɛ̀ à a aru kwɛ̀ɛ se. Luda Ninin à sèedadee ũ, zaakɛ àmbe yãpuradee ũ.
\v 7 Sèedadeenↄↄ kuu mɛ̀n aagↄ̃mɛ.
\v 8 Luda Nini kↄ̃n í pìo kↄ̃n aru pìo. Pↄ́ mɛ̀n aagↄ̃ↄ pìnↄ píngi dↄ̃nkↄ̃mɛ.
\v 9 Lán weè gbɛ̃ntee sèedadekɛna sí nà, Luda sèedadekɛna dɛ beeela, zaakɛ Luda yã pì ò a Nɛ́ yã musu.
\v 10 Gbɛ̃ kɛ̀ è Luda Nɛ́ náanɛ kɛɛ sèeda pì vĩ a swɛ̃̀ guu. Gbɛ̃ kɛ̀ èe Luda yã síroo Luda pì dìɛ ɛgɛdee ũmɛ, zaakɛ èe yã kɛ̀ Ludaa ò a Nɛ́ musu síro.
\v 11 Yã kɛ̀ à òn yɛ̀: Luda wa gba wɛ̃̀ndi kɛ̀ è yãaroo, wɛ̃̀ndi pì sↄ̃ↄ kú à Nɛ́ kiiamɛ.
\v 12 Gbɛ̃ kɛ̀ Luda Nɛ́ vĩi wɛ̃̀ndi kɛ̀ è yãaroo vĩ. Gbɛ̃ kɛ̀ Nɛ́ pì vĩroo wɛ̃̀ndi pì vĩro.
\s1 Wɛ̃̀ndi kɛ̀ è yãaroo
\p 
\v 13 Mɛ́ɛ yã beeenↄ ooare, amↄa kɛ̀ ée Luda Nɛ́ náanɛ kɛɛnↄ, lɛ àgↄ̃ dↄ̃ kɛ̀ á wɛ̃̀ndi kɛ̀ è yãaroo vĩ.
\v 14 Pↄ́ kɛ̀ tò wa swɛ̃̀ ègↄ̃ diɛna Luda aɛn yɛ̀: Tó wa pↄ́ wɛ́ɛ kɛ̀a lán à pↄↄ yezi nà, è síwe.
\v 15 Lán wá dↄ̃ kɛ̀ è wa wɛ́ɛkɛɛ ma nà, wá dↄ̃ kɛ̀ pↄ́ kɛ̀ wa wɛ́ɛ kɛ̀a pì wa gĩakɛ wá è kↄ̀.
\p 
\v 16 Tó gbɛ̃ a Yesude daaa è, èe durun kɛ̀ è ń kaatɛroo kɛɛ, à wɛ́ɛ kɛ lɛ Luda à gba wɛ̃̀ndi. Durun kɛ̀ è ń kaatɛroon má tɛ́a. Durun kɛ̀ è ń kaatɛ kuu, èe kɛ beeen ma bè à wɛ́ɛ kɛ à musuro.
\v 17 Yãzaakɛna píngi nɛ́ durummɛ, mↄde durun kɛ̀ è ń kaatɛroo kuu.
\p 
\v 18 Wá dↄ̃ kɛ̀ gbɛ̃ kɛ̀ Ludaa ì ègↄ̃ kpɛɛ gↄ̃ durun kɛɛro, zaakɛ Luda Nɛ́ è à dãkpa, Setãn è fↄ̃ à ↄ kɛaro.
\v 19 Wá dↄ̃ kɛ̀ Luda gbɛ̃nↄn wa ũ, baa kɛ̀ anduna píngi kú Setãn ↄzĩmɛ.
\v 20 Wá dↄ̃ kɛ̀ Luda Nɛ́ mↄ̀, ben à wa wɛ́ɛ kɛ̃̀, lɛ wà e wà Yãpuradee dↄ̃. Wá kú Yãpuradee pì guu kↄ̃n à Nɛ́ Yesu Kirisio. Àmbe Luda yãpuradee pì ũ. Àmbe wɛ̃̀ndi kɛ̀ è yãaroo ũ.
\p 
\v 21 Ma nɛ́ yenzideenↄ, à làakari kɛ tãanↄzi. 
