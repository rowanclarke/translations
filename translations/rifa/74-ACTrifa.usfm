\id ACT
\h ڒخْذَايمْ ن رُّوسُولْ 
\toc1 ڒخْذَايمْ ن رُّوسُولْ 
\toc2 ڒخْذَايمْ ن رُّوسُولْ 
\toc3 ڒخ. 
\mt1 ڒخْذَايمْ ن رُّوسُولْ  
\c 1
\s1 ثَامزْوَارُوثْ  
\m
\v 1 أَذْلِيسْ أَمزْوَارُو إِ ؤُرِيغْ، \add أَ\add* ثِييُوفِيلِيسْ، \add ؤُرِيغْ ث\add* خْ مَارَّا مِينْ إِبْذَا سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ أَذْ إِڭّْ ؤُ أَذْ إِسّڒْمذْ،  
\v 2 أَڒْ أَسّْ إِ ذِي إِمّكْسِي \add غَارْ ؤُجنَّا\add*، أَوَارْنِي ڒَامِي إِوصَّا إِ رُّوسُولْ إِ ثُوغَا يِيخْضَارْ نتَّا س أَرُّوحْ إِقدّْسنْ، \f ◼ \fr 1:‏2 \ft \+bd ’رُّوسُولْ‘\+bd* - نِيغْ ’إِمَازَاننْ‘.\f*  \x ◘ \xo 1:‏2 \xt مك. 16‏:‏19؛ لك. 9‏:‏51؛ يُوح. 20‏:‏21؛ 1 تِيم. 3‏:‏16. \x*  
\v 3 إِنِّي ؤُمِي، أَوَارْنِي ڒَامِي ثُوغَا إِودّبْ، إِسّْشنْ أَسنْ إِخفْ نّسْ س وَاطَّاسْ ن ڒعْڒَامَاثْ بلِّي أَقَا إِدَّارْ، أَمْ ذ أَسنْ د-إِضْهَارْ أَربْعِينْ ن وُوسَّانْ، إِسَّاوَاڒْ خْ ثْڭلْذِيثْ ن أَربِّي. \x ◘ \xo 1:‏3 \xt مك. 16‏:‏14؛ يُوح. 20‏:‏19؛ 21‏:‏1؛ 1 كُور. 15‏:‏5. \x*   
\b  
\m  
\s1 ثَامكْسِيثْ ن يَاسُوع غَارْ ؤُجنَّا  
\m
\v 4 ڒَامِي أَكِيذْسنْ إِشَّا أَغْرُومْ، إِوصَّا ثنْ حِيمَا وَارْ د-تّفّْغنْ شَا زِي ؤُرْشَالِيمْ، مَاشَا أَذْ قِّيمنْ أَذْ رَاجَانْ لْوَاعْذْ ن بَابَا إِ ثُوغَا كنِّيوْ، \add أَمُّو إِ إِنَّا،\add* ”ثسْڒِيمْ زَّايِي، \x ◘ \xo 1:‏4 \xt لك. 24‏:‏48، 49؛ يُوح. 14‏:‏26؛ 15‏:‏26؛ 16‏:‏7. \x*  
\v 5 مِينْزِي يُوحَانَّا ثُوغَا إِسّغْضَاصْ ذڭْ وَامَانْ، \add مَاشَا\add* كنِّيوْ أَذْ تّْوَاسّْغضْصمْ ذِي أَرُّوحْ إِقدّْسنْ أَوَارْنِي ذْرُوسْ ن وُوسَّانْ.“ \x ◘ \xo 1:‏5 \xt إِشا. 44‏:‏3؛ يُووِ. 3‏:‏1؛ مت. 3‏:‏11؛ مك. 1‏:‏8؛ لك. 3‏:‏16؛ يُوح. 1‏:‏26؛ ڒخ. 2‏:‏4؛ 11‏:‏15، 16؛ 19‏:‏4. \x*   
\m
\v 6 خنِّي سّقْسَانْ ث إِنِّي ثُوغَا ذِينْ إِمُوننْ، نَّانْ: ”\add أَ\add* سِيذِيثْنغْ، مَا ذِي ڒْوقْثْ-أَ أَذْ د-ثَارّذْ ثَاڭلْذِيثْ إِ إِسْرَائِيل عَاوذْ؟“ \x ◘ \xo 1:‏6 \xt مت. 24‏:‏3. \x*  
\v 7 إِنَّا أَسنْ: ”وَارْ ذ أَومْ د-يُوسِي أَذْ ثَارڭْبمْ خْ زّْمَانْ ذ زّْمَانَاثْ إِ إِڭَّا بَابَا ذِي صُّولْطَا ن يِيخفْ نّسْ. \x ◘ \xo 1:‏7 \xt مت. 24‏:‏36. \x*  
\v 8 مَاشَا كنِّيوْ أَذْ ثكْسِيمْ جّهْذْ خْمِي خَاومْ د غَا إِهْوَا أَرُّوحْ إِقدّْسنْ ؤُشَا كنِّيوْ أَذْ ثِيڒِيمْ ذ ڒشْهُوذْ ذِي ؤُرْشَالِيمْ، ذِي مَارَّا يَاهُوذِييَّا، ذِي سَامَارْيَا، \add وَاهْ،\add* أَڒْ إِنڭُّورَا ن دُّونشْثْ.“ \x ◘ \xo 1:‏8 \xt إِشا. 2‏:‏3؛ لك. 24‏:‏48؛ يُوح. 15‏:‏27؛ ڒخ. 2‏:‏4، 32. \x*   
\m
\v 9 \add أَوَارْنِي ڒَامِي\add* إِنَّا أَيَا، إِمّكْسِي ؤُشَا، أَمْ ث ژْرِينْ نِيثْنِي، إِكْسِي ث إِجّْ ن ؤُسيْنُو، إِذْوڒْ إِنُوفَّارْ خْ ثِيطَّاوِينْ نْسنْ. \x ◘ \xo 1:‏9 \xt مك. 16‏:‏19؛ لك. 24‏:‏51. \x*  
\v 10 أَمْ ذ أَسْ سّضْفَارنْ س ثِيطَّاوِينْ نْسنْ أَمْ إِرُوحْ غَارْ ؤُجنَّا، \add خْزَارْ\add*، أَقَا بدّنْ غَارْسنْ ثْنَاينْ ن يرْيَازنْ أَرْضنْ أَرُّوضْ ذ أَشمْڒَاڒْ، \x ◘ \xo 1:‏10 \xt مت. 28‏:‏3. \x*  
\v 11 ؤُشَا نَّانْ أَسنْ: ”\add أَ،\add* إِرْيَازنْ زِي لْجَالِيلْ، مِينْ كنِّيوْ إِذعْونْ ثتّْبدَّامْ ثْخزَّارمْ غَارْ ؤُجنَّا؟ أَقَا يَاسُوع وَانِيثَا، ونِّي إِمّكْسِينْ خَاومْ غَارْ ؤُجنَّا، أَذْ د-إِعْقبْ أَمْ مَامّشْ ث ثژْرِيمْ إِڭعّذْ غَارْ ؤُجنَّا!“ \x ◘ \xo 1:‏11 \xt دَان. 7‏:‏13؛ زَاك. 14‏:‏1‏-‏15؛ مت. 24‏:‏30؛ مك. 13‏:‏26؛ لك. 21‏:‏27؛ 1 تس. 1‏:‏10؛ 2 تس. 1‏:‏10؛ أَسَا. 1‏:‏7. \x*   
\b  
\m  
\s1 ڒِيخْضَارثْ ن مَاتِّييَا ذڭْ ومْشَانْ ن يَاهُوذَا  
\m
\v 12 خنِّيعقْبنْ غَارْ ؤُرْشَالِيمْ زڭْ وذْرَارْ ؤُمِي قَّارنْ ’ثَادَّارْثْ ن زِّيثُونْ‘ إِ إِدْجَانْ زَّاثْ إِ ؤُرْشَالِيمْ، إِڭّْوجْ خَاسْ عْڒَاحَاڒْ سبْعَا ’إِسْثَاذِييّنْ‘، \add إِخْسْ أَذْ يِينِي عْڒَاحَاڒْ إِجّْ ن كِيلُومِيثْرْ ؤُ ثْڒَاثَا ميَّا مِيثْرْ\add*.  
\v 13 أَوَارْنِي ڒَامِي د-ؤُذْفنْ \add غَارْ ثنْذِينْثْ\add*، ڭعّْذنْ غَارْ ثْغُورْفثْ سنّجْ مَانِي ثُوغَا تّْغِيمَانْ نِيثْنِي: بُوطْرُوسْ، يُوحَانَّا، يَاعْقُوبْ، أَنْذْرَاوُوسْ، فِيلِيبُّوسْ، ثُومَا، مَاتَّا، بَارْ-ثُولُومَاوُوسْ، يَاعْقُوبْ مِّيسْ ن حَالْفَا، شِيمْعُونْ ؤُمِي قَّارنْ ’أَمْعسَّابْ‘، ذ يَاهُوذَا، مِّيسْ ن يَاعْقُوبْ.  
\v 14 إِنَا مَارَّا إِذْسنْ ثُوغَا صْبَارنْ س يِيجّْ ن ذْمَامْ خْ ثْژَادْجِيثْ، أَكْ-ذ ثمْغَارِينْ ؤُ أَكْ-ذ مَارْيَامْ، يمَّاسْ ن يَاسُوع، ؤُ أَكْ-ذ أَيْثْمَاسْ. \x ◘ \xo 1:‏14 \xt مت. 13‏:‏55. \x*   
\m
\v 15 ذڭْ وُوسَّانْ نِّي إِكَّارْ شِيمْعُونْ بُوطْرُوسْ جَارْ أَسنْ، ذِي ڒْوسْطْ ن إِمحْضَارنْ. ثُوغَا ذِينْ مُوننْ عْڒَاحَاڒْ مْيَا ؤُ-عِيشْرِينْ ن إِوْذَانْ، ؤُ نتَّا إِنَّا: \x ◘ \xo 1:‏15 \xt 2 إِم. 5‏:‏12\x*   
\m
\v 16 ”\add أَ\add* إِرْيَازنْ ثَاوْمَاثْ، ثُوغَا إِتّْخصَّا نِيشَانْ أَذْ إِتّْوَاكمّڒْ \add أَوَاڒْ\add* ن ثِيرَا \add إِقدّْسنْ\add* إِ إِتّْوَانَّانْ قْبڒْ س أَرُّوحْ إِقدّْسنْ س ؤُقمُّومْ ن ذَاوُوذْ خْ يَاهُوذَا، ونِّي إِذوْڒنْ ذ أَمْڭوّذْ ن يِينِّي إِحبّْسنْ يَاسُوع، \x ◘ \xo 1:‏16 \xt إِزهد. 41‏:‏10؛ مت. 26‏:‏23، 47؛ مك. 14‏:‏43؛ يُوح. 13‏:‏18؛ 18‏:‏3. \x*  
\v 17 مِينْزِي نتَّا ثُوغَا إِتّْوَاحْسبْ زَّايْنغْ، \add زِي ثنْعَاشْ\add*، ؤُ ثُوغَا إِطّفْ ثَاسْغَارْثْ ذِي ثْسخَّارْثْ-أَ. \x ◘ \xo 1:‏17 \xt مت. 10‏:‏4؛ مك. 3‏:‏19؛ لك. 6‏:‏16. \x*  
\v 18 أَقَا وَا ثُوغَا إِكسّبْ إِجّْ ن إِيَّارْ إِ يِيخفْ نّسْ س ڒْمُونثْ ن دّنْبْ \add نّسْ\add* ؤُشَا ؤُمِي إِوْضَا خْ ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ، أَقَا إِفدْجقْ غَارْ ثجْعِينَّاثِينْ نّسْ ؤُشَا فّْغنْ-د مَارَّا أَذَانْ نّسْ غَارْ بَارَّا. \x ◘ \xo 1:‏18 \xt 2 صم. 17‏:‏23؛ مت. 27‏:‏3‏-‏5. \x*  
\v 19 أَقَا مَانْ أَيَا إِذْوڒْ إِتّْوَاسّنْ غَارْ مَارَّا إِمزْذَاغْ ن ؤُرْشَالِيمْ أَڒَامِي سمَّانْ إِيَّارْ نِّي ذڭْ إِڒسْ ن ثمُّورْثْ نْسنْ ’حَاقْلْ-ذَامَا‘، مِينْ إِخْسْ أَذْ يِينِي ’إِيَّارْ ن إِذَامّنْ‘. \x ◘ \xo 1:‏19 \xt مت. 27‏:‏8. \x*  
\v 20 مِينْزِي ثُورَا ذڭْ وذْلِيسْ ن إِزهِّيذنْ \add ن ذَاوُوذْ\add*:  
\b  
\m \qt ’أَذْ ثذْوڒْ ثَادَّارْثْ نّسْ ذ ڒْخَارْبثْ،\qt*  
\m \qt ؤُڒَا ذ إِجّْ وَارْ ذَايسْ إِزدّغْ!‘\qt*  
\b  
\m ؤُشَا:  
\b  
\m \qt ’أَذْ إِكْسِي ونّغْنِي ثَاسخَّارْثْ نّسْ.‘\qt* \x ◘ \xo 1:‏20 \xt إِزهد. 69‏:‏26؛ 109‏:‏8. \x*   
\b  
\m
\v 21 س ؤُينِّي إِتّْڒِيقْ، أَقَا إِجّنْ زڭْ يرْيَازنْ إِنِّي ثُوغَا ذ إِمْعَاشَارنْ أَكِيذْنغْ كُوڒْ ڒْوقْثْ إِ ذِي ثُوغَا سِيذِيثْنغْ يَاسُوع إِتَّاذفْ ؤُ إِتّفّغْ جَارْ أَنغْ - \x ◘ \xo 1:‏21 \xt ڒخ. 6‏:‏3. \x*  
\v 22 زڭْ ؤُسغْضصْ ن يُوحَانَّا أَڒْ أَسّْ إِ ذِي إِمّكْسِي خَانغْ - أَذْ إِذْوڒْ ذ أَشهَّاذْ أَكِيذْنغْ خْ ثْنُوكْرَا نّسْ.“   
\b  
\m
\v 23 أَرشّْحنْ ثْنَاينْ: يُوسُوفْ، ؤُمِي قَّارنْ بَارْ-سَابَا ونِّي ؤُمِي تّْكنَّانْ يُوسْثُوسْ، ذ مَاتِّييَا. \x ◘ \xo 1:‏23 \xt ڒخ. 6‏:‏6. \x*  
\v 24 أَمْ ثُوغَا تّْژَادْجَانْ، نَّانْ: ”\add أَ\add* سِيذِي، شكْ ثسّْنذْ ؤُڒَاونْ ن مَارَّا، سْشنْ \add أَنغْ\add* مَانْ ونْ زِي ثْنَاينْ-أَ إِ ثِيخْضَارذْ، \x ◘ \xo 1:‏24 \xt 1 صم. 16‏:‏17؛ 1 إِم. 28‏:‏9؛ 29‏:‏17؛ إِزهد. 7‏:‏10؛ إِرْم. 11‏:‏20؛ 17‏:‏10؛ 20‏:‏12؛ ڒخ. 15‏:‏8؛ أَسَا. 2‏:‏23. \x*  
\v 25 حِيمَا أَذْ إِشَارْشْ ذِي ثْسخَّارْثْ-أَ ؤُ ذِي ڒْخذْمثْ ن رُّوسُولْ إِ ذِي إِسْمحْ يَاهُوذَا حِيمَا أَذْ إِرَاحْ غَارْ ومْشَانْ نّسْ.“  
\v 26 خنِّي ڭِّينْ أَكشُّوضْ ؤُشَا يُوسَا-د \add ؤُكشُّوضْ\add* خْ مَاتِّييَا ؤُشَا أَرْنِينْ ث غَارْ حِيطَاشْ ن رُّوسُولْ.   
\b  
\b  
\m  
\c 2
\s1 أَسْفَارّغْ ن أَرُّوحْ إِقدّْسنْ  
\m
\v 1 ؤُمِي كمّْڒنْ وُوسَّانْ أَڒْ ڒْعِيذْ ن خمْسِينْ ن وُوسَّانْ، ثُوغَا أَثنْ مَارَّا جْمِيعْ مُوننْ. \x ◘ \xo 2:‏1 \xt لَاوِي 23‏:‏15؛ أَعَوذ. 16‏:‏9؛ ڒخ. 1‏:‏14. \x*  
\v 2 خْ إِشْثْ ن ڒْغفْڒثْ يُوسَا-د إِجّْ ن زّْهِيرْ زڭْ ؤُجنَّا، إِڭَّا أَخْمِي ذ أَسمِّيضْ إِجهْذنْ أَطَّاسْ، إِشُّورْ مَارَّا ثَادَّارْثْ مَانِي ثُوغَا قِّيمنْ.  
\v 3 ؤُشَا ضْهَارنْ أَسنْ-د إِڒْسَاونْ أَمْ ن ثْمسِّي نِّي إِتّمْسبْضَانْ، أَرْسِينْ خْ كُوڒْ إِجّنْ زَّايْسنْ،  
\v 4 ؤُ مَارَّا نِيثْنِي ذوْڒنْ شُّورنْ س أَرُّوحْ إِقدّْسنْ، بْذَانْ أَذْ سِّيوْڒنْ \bd س إِجّْ ن يِيڒسْ نّغْنِي\bd* أَمْ مَامّشْ ذ أَسنْ إِوْشَا أَرُّوحْ أَذْ زَّايْسنْ نطْقنْ. \x ◘ \xo 2:‏4 \xt مت. 3‏:‏11؛ مك. 1‏:‏8؛ 16‏:‏17؛ لك. 3‏:‏16؛ يُوح. 14‏:‏26؛ 15‏:‏26؛ 16‏:‏13؛ ڒخ. 10‏:‏46؛ 11‏:‏15؛ 19‏:‏6. \x*   
\m
\v 5 ثُوغَا تّْغِيمَانْ ذِي ؤُرْشَالِيمْ إِرْيَازنْ نِّي إِتّڭْوذنْ أَربِّي، ؤُذَاينْ زِي مَارَّا ڒڭْنُوسْ سَاذُو ؤُجنَّا.  
\v 6 ؤُمِي إِكَّارْ زّْهِيرْ-أَ، إِمُونْ مَارَّا ڒْڭنْسْ \add ذِينِّي\add* ؤُشَا ثْبهْثنْ، مِينْزِي كُوڒْ إِجّْ ثُوغَا إِتّسْڒَا أَسنْ سَّاوَاڒنْ س يِيڒْسَاونْ نْسنْ \add إِفَارْزنْ\add*.  
\v 7 ذهْشنْ، ثْبهْثنْ مَارَّا، نَّانْ جَارْ أَسنْ: ”مَا وَارْ دْجِينْ مَارَّا إِنَا إِنِّي \add ذِينْ\add* إِسَّاوَاڒنْ ذ إِجَالِيلِييّنْ؟  
\v 8 مَامّشْ ذ أَسنْ نسْڒَا نشِّينْ، كُوڒْ إِجّْ زَّايْسنْ، \add سَّاوَاڒنْ\add* س يِيڒسْ إِ زِي د-نثْوَاخْڒقْ؟  
\v 9 إِبَارْثِييّنْ ذ إِمِيذِييّنْ ذ إِعِيلَامِييّنْ ذ إِمزْذَاغْ ن مِيسُوپُوثَامْيَا، \add ثنِّي ذ ثَامُّورْثْ جَارْ ثْنَاينْ ن إِغزْرَانْ\add*، ذ وُوذَاينْ ذ إِنِّي زِي كَابَّاذُوكِييَا، إِنِّي د-يُوسِينْ زِي جّْوَايهْ ن بُونْطُوسْ ذ أَسِييَا،  
\v 10 زِي جّْوَايهْ ن فْرِيخِييَا، بَامْفِيلِييَا ذ مِيصْرَا ؤُ زِي جّْوَايهْ ن لِيبِييَا غَارْ قَايْرَاوَانْ، ؤُڒَا ذ إِنِّي د-يُوسِينْ زِي رُومَا، أَمْ ؤُذَاينْ أَمْ يِينِّي إِذوْڒنْ ذ إِمْعَاشَارنْ ن دِّينْ ن وُوذَاينْ،  
\v 11 إِنِّي\add د-يُوسِينْ\add* زِي كْرِيثَا ؤُ \add زِي\add* عَارَابِييَّا، أَقَا نشِّينْ نسْڒَا أَسنْ سَّاوَاڒنْ س يِيڒسْ نّغْ خْ ڒعْجَايبْ إِمقّْرَاننْ ن أَربِّي!“  
\v 12 مَارَّا ثْبهْثنْ ؤُشَا نَّانْ إِجّْ إِ ونّغْنِي: ”مِينْ إِخْسْ أَذْ يِينِي مَانْ أَيَا؟“  
\v 13 مَاشَا إِنّغْنِي سْثْهزَّانْ زَّايْسنْ، نَّانْ: ”نِيثْنِي سْوِينْ بِينُو ن جْذِيذْ.“   
\b  
\m  
\s1 أَبَارّحْ ن بُوطْرُوسْ إِ ڒْغَاشِي  
\m
\v 14 أَوَارْنِي أَسْ إِكَّارْ شِيمْعُونْ بُوطْرُوسْ، أَكْ-ذ حِيطَاشْ ن رُّوسُولْ. نتَّا إِسّْڭعّذْ ثْمِيجَّا نّسْ، إِنَّا أَسنْ:  
\b  
\m ”\add كنِّيوْ\add*، \add أَ\add* إِرْيَازنْ ذ ؤُذَاينْ ؤُ مَارَّا إِمزْذَاغْ ن ؤُرْشَالِيمْ، إِتّْخصَّا أَذْ سْنمْ أَيَا، سْڒمْ غَارْ وَاوَاڒنْ إِنُو!  
\v 15 \add إِوْذَانْ-أَ\add* وَارْ سْشَارنْ شَا أَمْ مَامّشْ ذ أَومْ إِتّْغِيڒْ، مِينْزِي أَقَا-ت ذ ثَاسَاعّثْ ذ ثْڒَاثَا \add ن وَاسّْ\add*.  
\v 16 مَاشَا أَيَا مِينْ إِتّْوَانَّانْ زڭْ ؤُنَابِي يُووِيلْ:   
\b  
\m
\v 17 \qt ’أَذْ يِيڒِي ذڭْ وُوسَّانْ إِنڭُّورَا،\qt*  
\m \qt إِقَّارْ أَربِّي،\qt*  
\m \qt أَقَا أَذْ فَارّْغغْ أَرُّوحْ إِنُو خْ مَارَّا دَّاثْ.\qt*  
\m \qt أَذْ نبَّانْ إِحنْجِيرنْ نْومْ ذ ثْحنْجِيرِينْ نْومْ،\qt*  
\m \qt إِبْڒِيغنْ نْومْ أَذْ ثْوَاڒَانْ إِوحَّانْ،\qt*  
\m \qt ؤُشَا إِمقّْرَاننْ نْومْ أَذْ أَرْجَانْ ثِيرْجَا.\qt* \x ◘ \xo 2:‏17 \xt إِشا. 44‏:‏3؛ حِز. 11‏:‏19؛ 36‏:‏27؛ يُووِ. 3‏:‏1‏-‏5؛ زَاك. 12‏:‏10؛ لك. 2‏:‏36؛ يُوح. 7‏:‏3؛ ڒخ. 10‏:‏45؛ 21‏:‏9. \x*   
\m
\v 18 \qt ؤُڒَا خْ إِمْسخَّارنْ إِنُو ؤُ خْ ثِييَّا إِنُو\qt*  
\m \qt أَذْ فَارّْغغْ أَرُّوحْ إِنُو ذڭْ وُوسَّانْ نِّي،\qt*  
\m \qt ؤُشَا أَذْ نبَّانْ.\qt*   
\b  
\m
\v 19 \qt أَذْ وْشغْ لْمُوعْجِيزَاثْ ذڭْ ؤُجنَّا\qt*  
\m \qt ؤُڒَا ذ ڒعْڒَامَاثْ خْ ثمُّورْثْ:\qt*  
\m \qt إِذَامّنْ ذ ثْمسِّي ذ ڒفْوَارْ ن دّخَّانْ.\qt*   
\m
\v 20 \qt أَذْ ثذْوڒْ ثْفُوشْثْ غَارْ ثَادْجسْثْ،\qt*  
\m \qt ذ ثْزِيرِي غَارْ إِذَامّنْ،\qt*  
\m \qt قْبڒْ د غَا يَاسْ\qt*  
\m \qt وَاسّْ إِمْغَارنْ إِعُودْجنْ ن سِيذِي.\qt* \x ◘ \xo 2:‏20 \xt مـَال. 3‏:‏23\x*   
\m
\v 21 \qt ؤُشَا أَذْ يِيڒِي،\qt*  
\m \qt أَقَا مَارَّا وِي غَا إِڒَاغَانْ خْ يِيسمْ ن سِيذِي،\qt*  
\m \qt أَذْ إِتّْوَاسّنْجمْ!‘\qt* \x ◘ \xo 2:‏21 \xt يُووِ. 3‏:‏1‏-‏5؛ رُوم. 10‏:‏13. \x*   
\b  
\m
\v 22 \add أَ\add* إِرْيَازنْ، أَيْثْ ن إِسْرَائِيل، سْڒمْ أَوَاڒنْ-أَ: يَاسُوع نَّاصِيرِي، أَقَا-ث ذ بْنَاذمْ إِ ذ أَومْ د-إِتّْوَاسّْشَاننْ زِي أَربِّي س ثْمڭَّا ثِيمقّْرَانِينْ ذ ڒعْڒَامَاثْ ذ لْمُوعْجِيزَاثْ إِ يڭَّا أَربِّي س ؤُفُوسْ نّسْ ذِي ڒْوسْطْ نْومْ، أَمْ مَامّشْ ثسّْنمْ كنِّيوْ،  
\v 23 أَقَا وَانِيثَا، ونِّي إِتّْوَاحُوزنْ إِ مَانْ أَيَا إِ نتَّا عْلَاحْسَابْ ثُوسّْنَا ن أَربِّي قْبڒْ ؤُ عْلَاحْسَابْ ڒْخَاضَارْ نّسْ، أَقَا كنِّيوْ ثْسلّْممْ ث ذڭْ إِفَاسّنْ ن إِعفَّاننْ ؤُ ثْصلّْبمْ ث ؤُ ثنْغِيمْ ث. \x ◘ \xo 2:‏23 \xt ڒخ. 4‏:‏28؛ 5‏:‏30. \x*  
\v 24 مَاشَا إِسّْنكَّارْ إِ-ث-إِ-د أَربِّي ؤُشَا إِسَّارْخُو إِسغْوَانْ ن ڒَاخَارْثْ، مَاغَارْ وَارْ إِزمَّارْ أَذْ إِتّْوَاطّفْ ذِي ڒَاخَارْثْ. \x ◘ \xo 2:‏24 \xt ڒخ. 10‏:‏40، 1 إِج. 3‏:‏16‏-‏28.\x*  
\v 25 مِينْزِي ذَاوُوذْ إِنَّا خَاسْ:  
\b  
\m \qt ’ثُوغَا تّْوَاڒِيغْ سِيذِي زَّاثِي ذِي كُوڒْ أَمُورْ،\qt*  
\m \qt أَقَا-ث خْ يفُوسْ إِنُو،\qt*  
\m \qt حِيمَا وَارْ تّْميِّيڒغْ.\qt* \x ◘ \xo 2:‏25 \xt إِزهد. 16‏:‏8‏-‏11. \x*   
\m
\v 26 \qt س ؤُيَا إِفَارّهْ ؤُڒْ إِنُو\qt*  
\m \qt ؤُڒَا ذ أَسمْغَارْ إِنُو إِفيّضْ س ڒفْرَاحثْ،\qt*  
\m \qt ؤُڒَا ذ أَرِّيمثْ إِنُو أَذْ يَاريّحْ\qt*  
\m \qt خْ ؤُسِيثمْ \+tl وَانِيثَا\+tl*،\qt*   
\m
\v 27 \qt مِينْزِي وَارْ ثتّجِّيذْ ڒعْمَارْ إِنُو ذِي ڒَاخَارْثْ،\qt*  
\m \qt ؤُڒَا وَارْ ثتّجِّيذْ أَمْسِيزْذڭْ نّشْ أَذْ إِكِيشُّو.\qt* \x ◘ \xo 2:‏27 \xt إِزهد. 16‏:‏10؛ إِزهد. 49‏:‏10؛ ڒخ. 13‏:‏35 \x*   
\m
\v 28 \qt شكْ ثسّشْنذْ أَيِي أَبْرِيذْ ن ثُوذَارْثْ،\qt*  
\m \qt شكْ أَذْ أَيِي ثشُّورذْ س ڒفْرَاحثْ\qt*  
\m \qt ذِي لْحَاضَارْ نّشْ.‘\qt* \x ◘ \xo 2:‏28 \xt إِزهد. 16‏:‏8‏-‏11. \x*   
\b  
\m
\v 29 \add أَ\add* إِرْيَازنْ ثَاوْمَاثْ، أَقَا ثعْذڒْ أَيِي أَذْ أَومْ سِّيوْڒغْ س بْطَايْطَايْ خْ أَرَّايْسْ ن ڒجْذُوذْ \add نّغْ\add* ذَاوُوذْ، ونِّي أَقَا إِمُّوثْ، إِتّْوَانْضڒْ، ؤُشَا أَنْضڒْ نّسْ أَقَا-ث غَارْنغْ أَڒْ أَسّْ-أَ. \x ◘ \xo 2:‏29 \xt 1 إِج. 2‏:‏10؛ ڒخ. 13‏:‏36. \x*  
\v 30 مَاغَارْ نتَّا ثُوغَا ذ أَنَابِي، إِسّنْ بلِّي أَربِّي إِجُّودْجْ أَسْ س إِشْثْ ن ثْجَادْجِيثْ:  
\b  
\m \qt ’أَذْ سّْغِيمغْ إِجّنْ زِي ڒْغِيدْجثْ ن ثْعذِّيسْثْ نّشْ\qt*  
\m \qt خْ ڒْكُورْسِي ن ڒْعَارْشْ نّسْ.‘\qt* \x ◘ \xo 2:‏30 \xt 2 صم. 7‏:‏12؛ إِزهد. 132‏:‏11؛ لك. 1‏:‏32؛ ڒخ. 13‏:‏23؛ رُوم. 1‏:‏3؛ 2 تِيم. 2‏:‏8. \x*   
\b  
\m
\v 31 أَمُّو ثُوغَا نتَّا إِزْوَارْ إِژْرَا ؤُشَا إِسِّيوڒْ خْ ثْنُوكْرَا ن لْمَاسِيحْ، بلِّي وَارْ إِتّْوَاجِّي شَا ذِي ڒَاخَارْثْ ؤُشَا أَرِّيمثْ نّسْ وَارْ ثتَّاشِي أَكِيشُّو. \x ◘ \xo 2:‏31 \xt إِزهد. 16‏:‏10؛ ڒخ. 13‏:‏35. \x*  
\v 32 يَاسُوع وَانِيثَا أَقَا إِسّْنكَّارْ إِ-ث-إِ-د أَربِّي ؤُ نشِّينْ مَارَّا ذ ڒشْهُوذْ نّسْ. \x ◘ \xo 2:‏32 \xt يُوح. 15‏:‏27؛ ڒخ. 1‏:‏8. \x*  
\v 33 نتَّا إِتّْوَاسّْڭعّذْ أَڒْ \add أَ\add*فُوسْ أَفُوسِي ن أَربِّي ؤُشَا إِطّفْ لْوَاعْذْ ن أَرُّوحْ إِقدّْسنْ زِي بَابَاسْ. أَقَا إِفَارّغْ ثَاوْهِيبْثْ-أَ \add ڒخُّو\add* أَمْ مَامّشْ ثتّْوَاڒَامْ ؤُ ثتّسْڒَامْ. \x ◘ \xo 2:‏33 \xt ڒخ. 1‏:‏4؛ 5‏:‏31؛ 10‏:‏45؛ فِيل. 2‏:‏9. \x*  
\v 34 ذَاوُوذْ مَاشَا وَارْ إِڭعّذْ شَا غَارْ إِجنْوَانْ، مَاغَارْ إِنَّا:  
\b  
\m \qt ’سِيذِي إِنَّا إِ سِيذِي إِنُو:\qt*  
\m \qt قِّيمْ خْ يفُوسْ إِنُو،\qt* \x ◘ \xo 2:‏34 \xt إِزهد. 110‏:‏1؛ 1 كُور. 15‏:‏25؛ أَفا. 1‏:‏20؛ عبر. 1‏:‏13. \x*   
\m
\v 35 \qt أَڒْ ذ غَا ڭّغْ ڒْعذْيَانْ نّشْ\qt*  
\m \qt ذ ثَانبْذَاثْ سَاذُو إِضَارنْ نّشْ.‘\qt* \x ◘ \xo 2:‏35 \xt إِزهد. 110‏:‏1. \x*   
\b  
\m
\v 36 أَذْ ثسّنْ مَارَّا ثَادَّارْثْ ن إِسْرَائِيل نِيشَانْ، بلِّي أَربِّي إِڭَّا يَاسُوع وَانِيثَا، ونِّي ثْصلّْبمْ كنِّيوْ، ذ سِيذِي ذ لْمَاسِيحْ.“   
\b  
\m
\v 37 ڒَامِي سْڒِينْ مَانْ أَيَا، ثُوذفْ أَسنْ ذڭْ وُوڒْ نْسنْ ذَاخڒْ، نَّانْ إِ شِيمْعُونْ ؤُ إِ رُّوسُولْ نّغْنِي: ”مِينْ غَا نڭّْ، أَ ثَاوْمَاثْ نّغْ؟“ \x ◘ \xo 2:‏37 \xt زَاك. 12‏:‏10؛ لك. 3‏:‏10؛ ڒخ. 9‏:‏6؛ 16‏:‏30. \x*  
\v 38 إِنَّا أَسنْ شِيمْعُونْ: ”ثُوبمْ، أجّْ كُوڒْ إِجّنْ زَّايْومْ أَذْ إِتّْوَاسّغْضصْ س يِيسمْ ن سِيذِي يَاسُوع إِ وغْفَارْ ن دّْنُوبْ، ؤُشَا أَذْ ثْقبْڒمْ ثَاوْهِيبْثْ ن أَرُّوحْ إِقدّْسنْ.  
\v 39 مِينْزِي لْوَاعْذْ إِ كنِّيوْ ؤُ إِ ثَارْوَا نْومْ ؤُ إِ مَارَّا إِنِّي إِدْجَانْ غَارْ ڒَاڭّْوَاجْ، إِنِّي خْ إِ ذ غَا إِڒَاغَا أَربِّي نّغْ.“ \x ◘ \xo 2:‏39 \xt يُووِ. 3‏:‏1؛ أَفا. 2؛13. \x*  
\v 40 ؤُشَا س وَاوَاڒنْ نّغْنِي أَطَّاسْ ثُوغَا إِسّقْنعْ ؤُ إِعْڒمْ أَسنْ، إِنَّا: ”نجْممْ زِي ثَاصِيڒثْ-أَ إِفَارْغنْ.“  
\v 41 ثُوغَا جَارْ أَسنْ إِنِّي إِوجْذنْ أَذْ قبْڒنْ أَوَاڒْ نّسْ ؤُشَا تّْوَاسّْغضْصنْ نِيثْنِي. مَّارْنِينْ-د ذڭْ وَاسّْ نِّي عْڒَاحَاڒْ ثڒْثْ-أَڒَافْ ن ڒعْمُورْ.   
\b  
\m  
\s1 ثَامسْمُونْثْ ن ينِّي يُومْننْ ذِي لْمَاسِيحْ  
\m
\v 42 نِيثْنِي قِّيمنْ صْبَارنْ ذِي ثْغُورِي ن رُّوسُولْ ؤُ شَارّْشنْ ذِي ثْژَادْجِيثْ ؤُ ذِي ثَارژِّيثْ ن وغْرُومْ ن نِّيعْمثْ.   
\m
\v 43 كُوڒْ إِجّنْ ثُوذفْ إِ-ث ثِيڭّْوُوذِي ؤُشَا مْسَارنْثْ لْمُوعْجِيزَاثْ ذ ڒعْڒَامَاثْ أَطَّاسْ س إِفَاسّنْ ن رُّوسُولْ ذِي ؤُرْشَالِيمْ. \x ◘ \xo 2:‏43 \xt مك. 16‏:‏17؛ ڒخ. 5‏:‏12. \x*  
\v 44 مَارَّا إِنِّي يُومْننْ ثُوغَا أَثنْ مُوننْ جْمِيعْ، ؤُ مَارَّا مِينْ غَارْسنْ ثُوغَا إِشَارْشْ. \x ◘ \xo 2:‏44 \xt أَعَوذ. 15‏:‏4؛ ڒخ. 4‏:‏32. \x*  
\v 45 إِنِّي غَارْ إِدْجَا وَاڭْڒَا ثُوغَا زّْنُوزَانْ مَانْ أَيَا ؤُشَا بطَّانْ \add أَرْبحْ\add* عْلَاحْسَابْ مِينْ إِحْذَاجْ كُوڒْ إِجّْ. \x ◘ \xo 2:‏45 \xt إِشا. 58‏:‏7؛ ڒخ. 4‏:‏35. \x*  
\v 46 ثُوغَا تّْمُوننْ كُوڒْ أَسّْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ س ذْمَامْ ذ إِجّنْ، تَّارژَّانْ أَغْرُومْ ذِي ثُوذْرِينْ، كْسِينْ مَاشَّا نْسنْ س ڒفْرَاحثْ ؤُ س وُوڒْ إِصْفَا، \x ◘ \xo 2:‏46 \xt ڒخ. 1‏:‏14؛ 20‏:‏7. \x*  
\v 47 أَمْ سّمْغَارَانْ ذِي أَربِّي ؤُ ثُوغَا تّْوَاسّْعِيزّنْ غَارْ مَارَّا إِوْذَانْ. كُوڒْ أَسّْ ثُوغَا سِيذِيثْنغْ يَارنِّي غَارْ ثْمسْمُونْثْ إِنِّي إِوْضنْ غَارْ ثُوذَارْثْ. \x ◘ \xo 2:‏47 \xt ڒخ. 5‏:‏14؛ 11‏:‏21. \x*   
\b  
\b  
\m  
\c 3
\s1 أَسْڭنْفِي ن إِجّْ ن ؤُنعْضَابْ  
\m
\v 1 ذ مَانْ أَيَا إِمْسَارْ ؤُمِي ڭعّْذنْ شِيمْعُونْ بُوطْرُوسْ ذ يُوحَانَّا جْمِيعْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ ذِي ثْسَاعّثْ ن ثْژَادْجِيثْ ثنِّي ذ وِيسّْ ثسْعَا، \add إِخْسْ أَذْ يِينِي ذ ثْڒَاثَا أَوَارْنِي ضّْهُورْ\add*.  
\v 2 خْزَارْ، ثُوغَا ذِينْ إِجّْ ن ورْيَازْ ذ أَنعْضَابْ زڭْ ؤُعذِّيسْ ن يمَّاسْ، أَرْبُونْ ث إِنِّي إِنُّومنْ أَذْ ث-إِ-د-أَوْينْ، سّْغِيمَانْ ث غَارْ ثوَّارْثْ ن زَّاوشْثْ ثَامقّْرَانْثْ ؤُمِي قَّارنْ ’ثَاوَّارْثْ ثَاصبْحَانْثْ‘، حِيمَا أَذْ إِتَّارْ صّذْقثْ زڭْ إِنِّي إِتَّاذْفنْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ. \x ◘ \xo 3:‏2 \xt يُوح. 9‏:‏8؛ ڒخ. 14‏:‏8. \x*  
\v 3 أَقَا وَا، ؤُمِي إِژْرَا بلِّي شِيمْعُونْ ذ يُوحَانَّا تَّاذْفنْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ، إِتَّارْ زَّايْسنْ حِيمَا أَذْ أَسْ وْشنْ إِشْثْ ن صّذْقثْ.  
\v 4 شِيمْعُونْ أَكْ-ذ يُوحَانَّا نْضَارنْ ذَايسْ ثِيطَّاوِينْ، نَّانْ أَسْ: ”خْزَارْ ذَايْنغْ!“  
\v 5 نتَّا إِقْشعْ ذَايْسنْ، إِتّْرَاجَا أَذْ زَّايْسنْ إِطّفْ شَا.  
\v 6 إِنَّا أَسْ شِيمْعُونْ: ”نُّوقَارْثْ ذ وُورغْ وَارْ غَارِي دْجِينْ، مَاشَا مِينْ غَارِي ذ مَانْ أَيَا إِ ذ أَشْ غَا وْشغْ س يِيسمْ ن يَاسُوع لْمَاسِيحْ نَّاصِيرِي! كَّارْ، ثُويُورذْ!“ \x ◘ \xo 3:‏6 \xt ڒخ. 4‏:‏10. \x*  
\v 7 إِطّفْ إِ-ث زڭْ ؤُفُوسْ نّسْ أَفُوسِي ؤُشَا إِسّْنكَّارْ إِ-ث. ڒخْذنِّي منْعنْ إِضَارنْ نّسْ ذ ثِيشعْبِينْ نّسْ،  
\v 8 ؤُشَا إِنْڭزْ ؤُشَا إِبدّْ \add خْ إِضَارنْ\add*، إِڭُّورْ ؤُشَا يُوذفْ أَكِيذْسنْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ، إِڭُّورْ، إِنڭّزْ، إِسّمْغَارَا ذِي أَربِّي. \f ◼ \fr 3:‏8 \ft \+bd ’إِنڭّزْ‘\+bd* - نِيغْ ’إِنطُّو‘.\f*   
\m
\v 9 مَارَّا ڒْڭنْسْ إِژْرَا إِ-ث إِڭُّورْ، إِسّمْغَارَا ذِي أَربِّي.  
\v 10 سّْننْ \add إِوْذَانْ\add* أَقَا نتَّا ذ ونِّي ثُوغَا إِتّْغِيمَانْ إِتّتَّارْ كُوڒْ أَسّْ غَارْ ثوَّارْثْ ن زَّاوشْثْ ثَامقّْرَانْثْ ؤُمِي قَّارنْ ’ثَاصبْحَانْثْ‘ ؤُشَا نِيثْنِي ذوْڒنْ شُّورنْ س وذْهَاشْ ذ ؤُثبْهثْ خْ مِينْ ذ أَسْ إِمْسَارنْ.  
\v 11 أَمْ ثُوغَا \add أَرْيَازْ أَنعْضَابْ\add* إِتّْشبَّارْ ذِي شِيمْعُونْ ذ يُوحَانَّا، دُّوقّْزنْ خَاسنْ مَارَّا إِوْذَانْ غَارْ ؤُسقِّيفْ أَكْ-ذ ؤُكُولْوَارْ ذ إِپِيلَارنْ، ؤُمِي قَّارنْ ’أَسقِّيفْ ن سُولِيمَانْ‘، ثْبهْثنْ.   
\m
\v 12 ؤُمِي إِژْرَا شِيمْعُونْ أَيَا، إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا أَسنْ: ”\add أَ\add* إِرْيَازنْ، إِحنْجِيرنْ ن إِسْرَائِيل، مِينْ كنِّيوْ إِذعْونْ ثتّْبهْثمْ س ؤُيَا؟ مَايمِّي ذَايْنغْ ثجْعَارمْ أَخْمِي س جّهْذْ ن يِيخفْ نّغْ نِيغْ س صُّولْطَا ن يِيخفْ نّغْ نَارَّا إِ-ث إِڭُّورْ؟  
\v 13 أَربِّي ن إِبْرَاهِيمْ ذ إِسْحَاقْ ذ يَاعْقُوبْ، أَربِّي ن ڒجْذُوذْ نّغْ، أَقَا إِسّْعُودْجْ مِّيسْ يَاسُوع ونِّي ثْسلّْممْ ؤُ ثْمنْضَارمْ زَّاثْ ن وُوذمْ ن بِيلَاطُوسْ ونِّي ثُوغَا خَاسْ إِحْكمْ س إِجّْ ن ڒْحُوكْمْ إِسڭّْذنْ ؤُ ثُوغَا إِخْسْ أَذْ أَسْ يَارْخُو. \x ◘ \xo 3:‏13 \xt ؤُف. 3‏:‏6، 15؛ مت. 27‏:‏20؛ مك. 15‏:‏11؛ لك. 23‏:‏18؛ يُوح. 18‏:‏40. \x*  
\v 14 مَاشَا كنِّيوْ أَقَا ثمّنْضَارمْ أَمْقدَّاسْ ذ أَمْسڭَّاذْ، ثْزَاوْڭمْ أَذْ أَومْ إِمّوْشْ أَرْيَازْ أَقتَّاڒْ. \x ◘ \xo 3:‏14 \xt لك. 23‏:‏18. \x*  
\v 15 أَقَا ثنْغِيمْ أَزدْجِيفْ ن ثُوذَارْثْ، ونِّي د-إِسّْنكَّارْ أَربِّي زِي ثَادَّارْثْ ن إِمتِّيننْ، أَقَا نشِّينْ مَارَّا ذ ڒشْهُوذْ خْ مَانْ أَيَا. \x ◘ \xo 3:‏15 \xt ڒخ. 1‏:‏8؛ 2‏:‏32. \x*  
\v 16 س لْ-إِيمَانْ ذڭْ يِيسمْ نّسْ، أَقَا إِسّجْهذْ ؤُ إِسّْڭنْفَا نتَّا وَا، ونِّي ثتّْوَاڒَامْ، ثسّْنمْ ث. لْ-إِمَانْ ذَايسْ أَقَا إِوْشَا أَسْ أَڭنْفِي-يَا زَّاثْومْ مَارَّا.   
\m
\v 17 ڒخُّو، \add أَ\add* أَيْثْمَا، سّْنغْ، أَقَا ثڭِّيمْ أَيَا س ثْقُوبَّانشْثْ، أَمْ مَامّشْ إِ ڭِّينْ ؤُڒَا ذ إِمقّْرَاننْ نْومْ.  
\v 18 أَمُّو أَقَا إِكمّڒْ أَربِّي مِينْ ثُوغَا إِسِّيزْوَارْ إِخبَّارْ خَاسْ س ؤُقمُّومْ ن مَارَّا إِنَابِييّنْ بلِّي لْمَاسِيحْ إِڭُّورْ أَذْ إِودّبْ. \x ◘ \xo 3:‏18 \xt إِشا. 50‏:‏6؛ 53‏:‏5؛ لك. 24‏:‏27. \x*  
\v 19 س ؤُينِّي ثُوبمْ، ثْذوْڒمْ \add غَارْ وبْرِيذْ\add* حِيمَا أَذْ أَومْ تّْوَامسْحنْ دّْنُوبْ نْومْ ؤُشَا خنِّي أَذْ د-أَسنْ زّْمَانَاثْ ن أَرَّاحثْ زَّاثْ إِ وُوذمْ ن سِيذِي، \x ◘ \xo 3:‏19 \xt ڒخ. 2‏:‏38. \x*  
\v 20 ؤُشَا نتَّا أَذْ أَومْ د-إِسّكّْ ونِّي إِوجْذنْ إِ كنِّيوْ \add إِ مَانْ أَيَا\add*: يَاسُوع لْمَاسِيحْ،  
\v 21 ونِّي إِتّْخصَّا ؤُجنَّا أَذْ ث إِقْبڒْ أَڒْ ؤُكمّڒْ ن زّْمَانَاثْ، ن مَارَّا مِينْ خفْ ثُوغَا إِسَّاوَاڒْ أَربِّي س ؤُقمُّومْ ن مَارَّا إِنَابِييّنْ نّسْ إِقدّْسنْ زِي زّْمَانْ.  
\v 22 مَاغَارْ مُوسَا إِنَّا:  
\b  
\m \qt ’سِيذِي أَذْ أَومْ د-إِسّْڭعّذْ إِجّْ ن ؤُنَابِي\qt*  
\m \qt أَمْ نشّْ زڭْ وَاوْمَاثْومْ.\qt*  
\m \qt إِ نتَّا ؤُمِي غَا ثسْڒمْ\qt*  
\m \qt ذِي مَارَّا مِيخفْ ذ أَومْ إِ غَا إِسِّيوڒْ.‘\qt* \x ◘ \xo 3:‏22 \xt أَعَوذ. 18‏:‏15‏-‏16، 18؛ يُوح. 1‏:‏46؛ ڒخ. 7‏:‏37. \x*   
\m
\v 23 \qt أَذْ يِيڒِي بلِّي كُوڒْ ڒعْمَارْ\qt*  
\m \qt إِ وَارْ إِسْڒِينْ غَارْ ؤُنَابِي نِّي،\qt*  
\m \qt أَذْ إِتّْوَاسّْهلّكْ زڭْ ڒْڭنْسْ.\qt*   
\b  
\m
\v 24 مَارَّا إِنَابِييّنْ زِي شَامْوِيلْ ذ \add مَارَّا إِنَابِييّنْ\add* نِّي إِ-ث-إِ-د-إِخڒْفنْ، أَقَا إِزْوَارنْ خبَّارنْ خْ وُوسَّانْ-أَ.  
\v 25 كنِّيوْ ذ أَيْثْ ن إِنَابِييّنْ ؤُ ن ڒْعَاهْذْ إِ إِڭَّا أَربِّي أَكْ-ذ ڒجْذُوذْ نْومْ ڒَامِي ثُوغَا إِقَّارْ إِ إِبْرَاهِيمْ:  
\b  
\m \qt ’س زَّارِيعثْ نّشْ أَذْ تّْوَابَارْكنْثْ\qt*  
\m \qt مَارَّا ثِيقبَّاڒْ ن ثمُّورْثْ!‘\qt* \x ◘ \xo 3:‏25 \xt أَمز. 22‏:‏18؛ ڭال. 3‏:‏8. \x*   
\b  
\m
\v 26 زِيشْ إِڭَّا نتَّا \add ڒْْعَاهْذْ نّسْ\add* أَكِيذْومْ ؤُشَا إِسّكّْ-د أَربِّي ڒخُّو مِّيسْ مَاحنْذْ أَذْ أَومْ إِبَاركْ، مَاڒَا أَذْ ثْذوْڒمْ، أَذْ ثثُوبمْ زِي ڒْغَارْ نْومْ.“   
\b  
\b  
\m  
\c 4
\s1 پُوطْرُوسْ ذ يُوحَانَّا زَّاثْ إِ جْمَاعثْ ثَامقّْرَانْثْ ن وُوذَاينْ  
\m
\v 1 أَمْ ثُوغَا سَّاوَاڒنْ أَوَاڒنْ-أَ أَكْ-ذ ڒْڭنْسْ، خشّنْ-د خَاسنْ إِكهَّاننْ أَكْ-ذ إِصَاذُوقِييّنْ ذ إِمقّْرَاننْ خْ زَّاوشْثْ ثَامقّْرَانْثْ،  
\v 2 مِينْزِي ثُوغَا خيّْقنْ خَاسنْ أَطَّاسْ، مَاغَارْ نِيثْنِي ثُوغَا سّڒْمَاذنْ ڒْڭنْسْ ؤُ تّْبَارّْحنْ ثَانُوكْرَا زِي ثَادَّارْثْ ن إِمتِّيننْ س لْمَاسِيحْ.  
\v 3 سَّارْسنْ خَاسنْ إِفَاسّنْ ؤُشَا حبّْسنْ ثنْ أَڒْ ثِيوشَّا نّسْ، مِينْزِي ثُوغَا ثوْضَا-د ثْمذِّيثْ.  
\v 4 أَطَّاسْ زڭْ إِنِّي إِسْڒِينْ أَوَاڒْ-أَ ؤُمْننْ ؤُ ڒْقدّْ ن يرْيَازنْ يِيوضْ-د عْڒَاحَاڒْ خمْسَا-أَڒَافْ.   
\m
\v 5 ثِيوشَّا نّسْ مُوننْ إِمقّْرَاننْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add* ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذِي ؤُرْشَالِيمْ،  
\v 6 ؤُڒَا ذ حَانَّانْ، أَرَّايْسْ ن إِكهَّاننْ، ذ قَايَافَا ذ يُوحَانَّا ذ أَلِيكْسَانْذِيرْ ذ \add مَارَّا\add* إِنِّي ثُوغَا د-إِقَّارْصنْ زِي ڒَادْجْ ن إِمقّْرَاننْ ن إِكهَّاننْ.  
\v 7 ؤُمِي ثنْ سّْبدّنْ ذِي ڒْوسْطْ، سّقْسَانْ ثنْ: ”س مَانْ جّهْذْ نِيغْ س مَانْ إِسمْ إِ ثڭِّيمْ أَيَا؟“ \x ◘ \xo 4:‏7 \xt ؤُف. 2‏:‏14؛ مت. 21‏:‏23؛ ڒخ. 7‏:‏27. \x*  
\v 8 ڒخْذنِّي إِنَّا أَسنْ شِيمْعُونْ بُوطْرُوسْ إِشُّورنْ س أَرُّوحْ إِقدّْسنْ: ”سْڒمْ، \add أَ\add* إِمقّْرَاننْ ن ڒْڭنْسْ ذ إِمْغَارنْ ن ثَادَّارْثْ ن إِسْرَائِيل!  
\v 9 مَاڒَا أَسّْ-أَ نتّْوَاحْكمْ زَّايْومْ خْ ڒْخَارْ إِ إِتّْوَاڭّنْ إِ ؤُمهْڒُوشْ، س مِينْ زِي إِذْوڒْ ورْيَازْ-أَ إِڭّنْفَا،  
\v 10 إِتّْخصَّا أَذْ ثسّْنمْ كنِّيوْ ذ مَارَّا ڒْڭنْسْ ن إِسْرَائِيل بلِّي أَرْيَازْ وَانِيثَا إِبدّْ زَّاثْومْ إِصحّْ س يِيسمْ ن يَاسُوع لْمَاسِيحْ نَّاصِيرِي، ونِّي ثْصلّْبمْ، \add مَاشَا\add* ونِّي د-إِسّْنكَّارْ أَربِّي زِي ثَادَّارْثْ ن إِمتِّيننْ، \add وَاهْ،\add* أَقَا زَّايسْ إِبدّْ \add أَرْيَازْ-أَ\add* زَّاثْومْ إِصحّْ.  
\v 11 ذ وَا ذ أَژْرُو نِّي ثمّنْضَارمْ \add كنِّيوْ\add*، \add أَ\add* إِبنَّاينْ، \add مَاشَا\add* نتَّا أَقَا إِذْوڒْ ذ \add أَژْرُو\add* أَزدْجِيفْ ن ثغْمَارْثْ. \x ◘ \xo 4:‏11 \xt إِزهد. 118‏:‏22؛ إِشا. 28‏:‏16؛ مت. 21‏:‏42؛ مك. 12‏:‏10؛ لك. 20‏:‏17؛ رُوم. 9‏:‏33؛ 1 بُط. 2‏:‏7. \x*  
\v 12 أَسنْجمْ وَارْ إِدْجِي س إِجّنْ بْنَاذمْ نّغْنِي، مِينْزِي وَارْ ذِينْ إِسمْ نّغْنِي سَاذُو ؤُجنَّا إِ زِي غَا نتّْوَاسّنْجمْ.“ \x ◘ \xo 4:‏12 \xt مت. 1‏:‏21؛ ڒخ. 10‏:‏43؛ 1 تِيم. 2‏:‏5. \x*   
\m
\v 13 ڒَامِي سْڒِينْ أَوَاڒنْ إِ سِّيوْڒنْ شِيمْعُونْ ذ يُوحَانَّا س بْطَايْطَايْ، ؤُشَا ؤُفِينْ بلِّي نِيثْنِي وَارْ دْجِينْ ذ إِمُوسْنَاونْ ن وذْلِيسْ نِيغْ ذ إِوْذَانْ إِنِّي إِڒمْذنْ أَطَّاسْ، أَقَا ثْبهْثنْ ؤُشَاعقْڒنْ بلِّي نِيثْنِي ثُوغَا أَثنْ أَكْ-ذ يَاسُوع.  
\v 14 نِيثْنِي ژْرِينْ بْنَاذمْ إِ ثُوغَا ذ أَنعْضَابْ ؤُشَا إِذْوڒْ إِڭّنْفَا، إِبدّْ أَكِيذْسنْ، ؤُشَا وَارْ ؤُفِينْ مِينْ غَا إِنِينْ خْ مَانْ أَيَا.  
\v 15 ؤُ أَوَارْنِي ڒَامِي ؤُمُورنْ مَاحنْذْ أَذْ ثنْ سُّوفّْغنْ بَارَّا إِ جْمَاعثْ نْسنْ \add ثَامقّْرَانْثْ\add*، مْشَاوَارنْ أَكْ-ذ وَايَاوْيَا، \add نَّانْ\add*: \f ◼ \fr 4:‏15 \ft \+fk جْمَاعثْ \+bdit ثَامقّْرَانْثْ\+bdit*‘ - نِيغْ: ’جْمَاعثْ ن ڒْحُوكَّامْ إِمقّْرَاننْ ن وُوذَاينْ‘.\f*  
\v 16 ”مِينْ غَا نڭّْ س إِرْيَازنْ-أَ؟ مِينْزِي أَقَا إِبَانْ-د مْلِيحْ إِ مَارَّا إِمزْذَاغْ ن ؤُرْشَالِيمْ بلِّي ڒعْڒَامثْ ثمْسَارْ س ؤُفُوسْ نْسنْ، وَارْ نْزمَّارْ أَذْ ت ننْكَارْ. \x ◘ \xo 4:‏16 \xt يُوح. 11‏:‏47. \x*  
\v 17 مَاشَا حِيمَا وَارْ إِتّْوَابَارّحْ ڒخْبَارْ-أَ كْثَارْ جَارْ ويْذُوذْ، أجّْ أَنغْ أَذْ ثنْ نسِّيڭّْوذْ حِيمَا وَارْ سِّيوِيڒنْعمَّارْصْ عَاوذْ ذڭْ يِيسمْ-أَ، ؤُڒَا أَكْ-ذ إِجّْ ن بْنَاذمْ.“  
\v 18 \add خَاسْ ؤُشَا\add* ڒَاغَانْ-د خَاسنْ، ؤُمُورنْ ثنْ مَاحنْذْ وَارْ سِّيوِيڒنْ وَارْ سّڒْمِيذنْعمَّارْصْ عَاذْ ذڭْ يِيسمْ ن يَاسُوع.   
\m
\v 19 مَاشَا شِيمْعُونْ بُوطْرُوسْ ذ يُوحَانَّا أَرِّينْ-د خَاسنْ، نَّانْ أَسنْ: ”حكْممْ كنِّيوْ، مَا إِحِيقّْ زَّاثْ إِ أَربِّي مَاحنْذْ أَذْ نْسڒْ كْثَارْ إِ كنِّيوْ خْ أَربِّي، \x ◘ \xo 4:‏19 \xt ڒخ. 5‏:‏29. \x*  
\v 20 مِينْزِي وَارْ نْزمَّارْ أَذْ نقِّيمْ وَارْ نسِّيوِيڒْ خْ مِينْ نژْرَا ؤُ خْ مِينْ نسْڒَا.“  
\v 21 مَاشَا نِيثْنِي سِّيڭّْوذنْ ثنْ \add عَاذْ كْثَارْ\add*، خنِّي جِّينْ ثنْ أَذْ رَاحنْ، أَڒَامِي وَارْ ؤُفِينْ مِينْ زِي ثنْ إِ غَا عَاقْبنْ زِي سِّيبّثْ ن إِوْذَانْ، مِينْزِي مَارَّا \add إِوْذَانْ\add* ثُوغَا سّمْغَارَانْ ذِي أَربِّي خْ مِينْ إِمْسَارنْ، \x ◘ \xo 4:‏21 \xt ڒخ. 3‏:‏7، 8؛ 5‏:‏26. \x*  
\v 22 مِينْزِي أَرْيَازْ إِ ذَايسْ إِتّْوَاڭّْ ڒعْڒَامثْ-أَ ن ؤُڭنْفِي، ثُوغَا غَارسْ كْثَارْ زِي أَربْعِينْ ن إِسڭّْوُوسَا.   
\b  
\m  
\s1 ثَاژَادْجِيثْ ن ڒْمُومِينِينْ  
\m
\v 23 أَوَارْنِي ڒَامِي ذ أَسنْ أَرْخُونْ، رُوحنْ نِيثْنِي غَارْ أَيْثْمَاثْسنْ ؤُشَا خبَّارنْ ثنْ س مَارَّا مِينْ ذ أَسنْ نَّانْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add*. \x ◘ \xo 4:‏23 \xt ڒخ. 12‏:‏12. \x*  
\v 24 ؤُمِي سْڒِينْ أَيَا، سّْڭعّْذنْ ثْمِيجَّا نْسنْ غَارْ أَربِّي س ذْمَامْ ذ إِجّنْ، نَّانْ: ”\add أَ\add* سِيذِي، شكْ ذ أَربِّي ونِّي إِڭِّينْ أَجنَّا ذ ثمُّورْثْ ذ ڒبْحُورْ ذ مَارَّا مِينْ ذَايسْ، \x ◘ \xo 4:‏24 \xt ؤُف. 20‏:‏11\x*  
\v 25 شكْ ذ ونِّي إِنَّانْ س أَرُّوحْ إِقدّْسنْ س ؤُقمُّومْ ن ؤُمْسخَّارْ نّشْ ذَاوُوذْ:  
\b  
\m \qt ’مَايمِّيغوّْغنْ ڒڭْنُوسْ\qt*  
\m \qt ؤُ \+tl مَايمِّي\+tl* خَارّْصنْ ڒڭْنُوسْ ذِي مِينْ إِخْوَانْ؟\qt* \x ◘ \xo 4:‏25 \xt إِزهد. 2‏:‏1. \x*   
\m
\v 26 \qt أَقَا كَّارنْ إِجدْجِيذنْ ن دُّونشْثْ،\qt*  
\m \qt ؤُشَا إِنِّي غَارْسنْ ثدْجَا صُّولْطَا مْشَاوَارنْ\qt*  
\m \qt ضِيدّْ ن سِيذِي ؤُ ضِيدّْ ن لْمَاسِيحْ نّسْ.‘\qt* \x ◘ \xo 4:‏26 \xt إِزهد. 2‏:‏1، 2. \x*   
\b  
\m
\v 27 مِينْزِي س ثِيذتّْ أَقَا هِيرُوذُوسْ ذ بُونْطِييُوسْ بِيلَاطُوسْ ذ ڒڭْنُوسْ ذ إِبَارُّوثنْ ن إِسْرَائِيل مُوننْ خْ مِّيشْ نّشْ أَمْقدَّاسْ يَاسُوع، ونِّي ؤُمِي ثْمسْحذْ، \x ◘ \xo 4:‏27 \xt مت. 26‏:‏3؛ مك. 14‏:‏1؛ لك. 22‏:‏2؛ يُوح. 11‏:‏47. \x*  
\v 28 حِيمَا أَذْ ڭّنْ مَارَّا مِينْ ثُوغَا إِزْوَارْ إِنيّشْ ؤُفُوسْ نّشْ ذ شّْوَارْ نّشْ أَذْ يِيڒِي.  
\v 29 عَاذْ ڒخُّو، أَ سِيذِي، خْزَارْ غَارْ ؤُسِيڭّْوذْ نْسنْ ؤُشَا أوْشْ إِ إِمْسخَّارنْ نّشْ حِيمَا أَذْ سِّيوْڒنْ س وَاوَاڒْ نّشْ س ثَارْيَاسْثْ،  
\v 30 أَمْ ثسّْوِيژّْضذْ أَفُوسْ نّشْ إِ ؤُسْڭنْفِي ؤُ حِيمَا أَذْ \add ذِينْ\add* إِڒِينْثْ ثِيمڭَّا جهْذنْثْ ذ ڒعْڒَامَاثْ ذ ڒعْجَايبْ ذڭْ يِيسمْ ن مِّيشْ نّشْ أَمْقدَّاسْ: يَاسُوع.“ \x ◘ \xo 4:‏30 \xt مك. 16‏:‏17. \x*  
\v 31 أَوَارْنِي ڒَامِي كمّْڒنْ ثَاژَادْجِيثْ ذ ثْكسِّيثْ س ڒْمعْرُوفْ، إِنْهزّْ ومْشَانْ إِ ذِي ثُوغَا مُوننْ، ؤُ مَارَّا ذوْڒنْ شُّورنْ س أَرُّوحْ إِقدّْسنْ، سَّاوَاڒنْ س وَاوَاڒْ ن أَربِّي س ثرْيَاسْثْ. \x ◘ \xo 4:‏31 \xt ڒخ. 16‏:‏26. \x*   
\b  
\m  
\s1 بدُّو ن ثْمسْمُونْثْ ن يَاسُوع لْمَاسِيحْ  
\m
\v 32 ؤُشَا ڒْغَاشِي ن يِينِّي يُومْننْ ثُوغَا س ڒعْمَارْ ذ ؤُخَارّصْ ذ إِجّنْ ؤُشَا ؤُڒَا ذ إِجّْ وَارْ إِقَّارْ بلِّي مِينْ ثُوغَا غَارسْ أَقَا إِ نتَّا وحّْذسْ، مَاشَا نِيثْنِي شَارْشنْ ذِي كُوڒْشِي جَارْ أَسنْ. \x ◘ \xo 4:‏32 \xt ڒخ. 2‏:‏44؛ 1 بُط. 3‏:‏8. \x*  
\v 33 ثُوغَا رُّوسُولْ نِّي شهّْذنْ س يِيجّْ ن جّهْذْ إِمْغَارْ خْ ثْنُوكْرَا ن يَاسُوع لْمَاسِيحْ ؤُشَا يِيوضْ-د أَرْضَا إِمْغَارْ خْ مَارَّا نِيثْنِي.  
\v 34 وَارْ ثُوغِي جَارْ أَسنْ ؤُڒَا ذ إِجّْ ذَايسْ ڒخْصصْ، مِينْزِي مَارَّا إِنِّي غَارْ إِدْجَا إِيَّارنْ نِيغْ ثُوذْرِينْ زّْنُوزَانْ ثنْ، ؤُشَا تَّاوْينْ-د تَّامَانْ ن مِينْ زّْنُوزَانْ،  
\v 35 سّْرُوسَانْ ث غَارْ إِضَارنْ ن رُّوسُولْ. نِيثْنِي بْضَانْ \add زَّايسْ\add* إِ كُوڒْ إِجّْ عْلَاحْسَابْ مِينْ ثُوغَا إِحْوَاجْ. \x ◘ \xo 4:‏35 \xt إِشا. 58‏:‏7. \x*   
\m
\v 36 يُوسُوفْ ونِّي ؤُمِي ڒَاغَانْ رُّوسُولْ بَارْ-نَابَا\add س\add*، مِينْ إِخْسْ أَذْ يِينِي ’مِّيسْ ن ؤُفوّجْ‘، نتَّا \add زِي ثقْبِيتْشْ\add* ن لَاوِي، يُوسَا-د زِي ثڭْزِيرْثْ ن قُوبْرُوسْ،  
\v 37 ثُوغَا غَارسْ إِجّْ ن إِيَّارْ، إِزّنْزْ إِ-ث ؤُشَا يِيوِي-د ثْمنْيَاثْ، إِسَّارْسْ إِ-ثنْثْ غَارْ إِضَارنْ ن رُّوسُولْ.   
\b  
\b  
\m  
\c 5
\s1 ڒْحُوكْمْ خْ أَنَانِييَاسْ ذ سَافِّيرَا  
\m
\v 1 إِجّْ ن ورْيَازْ قَّارنْ أَسْ أَنَانِييَاسْ، أَكْ-ذ ثمْغَارْثْ نّسْ، قَّارنْ أَسْ سَافِّيرَا، إِزّنْزْ إِيَّارْ نّسْ.  
\v 2 نتَّا إِكْسِي إِجّْ ن وزْينْ ن ثْمنْيَاثْ ن تَّامَانْ \add ن ييَّارْ\add*، أَمْ ثسّنْ ثمْغَارْثْ نّسْ \add مَانْ أَيَا\add*، ؤُشَا إِسّْنُوفَارْ إِ-ث. \add خَاسْ ؤُشَا\add* يِيوِي-د شَا ن ثْمنْيَاثْ ن نُّوقَارْثْ زَّايسْ، إِسَّارْسْ إِ-ت غَارْ إِضَارنْ ن رُّوسُولْ.  
\v 3 إِنَّا أَسْ شِيمْعُونْ: ”\add أَ\add* أَنَانِييَاسْ، مَايمِّي إِشُّورْ شِّيطَانْ ؤُڒْ نّشْ حِيمَا أَذْ ثسّْخَارْقذْ خْ أَرُّوحْ إِقدّْسنْ ؤُ حِيمَا أَذْ ثْنُوفَّارذْ شَا ن ثْمنْيَاثْ ذڭْ إِيَّارْ؟  
\v 4 مَا وَارْ إِدْجِي \add يِييَّارْ\add* نّشْ قْبڒْ إِتّْوَامّنْزْ؟ ؤُ ڒَامِي إِتّْوَامّنْزْ، ثُوغَا صُّولْطَا خْ تَّامَانْ نّسْ \add عَاذْ\add* ذڭْ ؤُفُوسْ نّشْ! مِينْ شكْ إِذعْونْ ثتّڭّذْ مَانْ أَيَا ذڭْ وُوڒْ نّشْ؟ أَقَا شكْ وَارْ ثسّْخَارْقذْ شَا خْ إِوْذَانْ مَاشَا خْ أَربِّي.“  
\v 5 ؤُمِي إِسْڒَا أَنَانِييَاسْ أَوَاڒنْ-أَ، إِوْضَا غَارْ ثمُّورْثْ، إِمُّوثْ، ؤُشَا ثذْوڒْ ثِيڭّْوُوذِي ثمْغَارْ خْ مَارَّا إِنِّي إِسْڒِينْ أَيَا.  
\v 6 كَّارنْ إِبْڒِيغنْ، شفْننْ ث، أَرْبُونْ \add ث\add* غَارْ بَارَّا، نضْڒنْ ث.   
\m
\v 7 أَوَارْنِي ڒَامِي عْذُونْثْ عْڒَاحَاڒْ ثْڒَاثَا ن ثْسَاعّثِينْ، ثُوذفْ-د ثمْغَارْثْ نّسْ، وَارْ ثسِّينْ مِينْ إِمْسَارنْ.  
\v 8 إِنَّا أَسْ شِيمْعُونْ: ”إِنِي أَيِي، مَا أَقَا ثزّنْزمْ إِيَّارْ س وَانشْثْ ؤُيَا؟“ ثنَّا أَسْ: ”وَاهْ، س وَانشْثْ ؤُيَا!“  
\v 9 إِنَّا أَسْ شِيمْعُونْ: ”مِينْ كنِّيوْ إِذعْونْ ثتَّافْقمْ جَارْ أَومْ مَاحنْذْ أَذْ ثْجَارّْبمْ أَرُّوحْ ن سِيذِي؟ خْزَارْ، إِضَارنْ ن يِينِّي إِنضْڒنْ أَرْيَازْ نّمْ، أَقَا أَثنْ غَارْ ثوَّارْثْ، أَذْ شمْ كْسِينْ بَارَّا عَاوذْ.“  
\v 10 ڒخْذنِّي ثوْضَا غَارْ إِضَارنْ نّسْ ؤُشَا ثمُّوثْ. ؤُذْفنْ-د إِبْڒِيغنْ نِّي، ؤُفِينْ ت ثمُّوثْ، كْسِينْ ت، أَرْبُونْ ت غَارْ بَارَّا ؤُشَا نضْڒنْ ت زَّاثْ إِ ورْيَازْ نّسْ،  
\v 11 ؤُشَا ثذْوڒْ ثِيڭّْوُوذِي ثمْغَارْ غَارْ مَارَّا ثَامسْمُونْثْ ؤُ غَارْ مَارَّا إِنِّي إِسْڒِينْ مَانْ أَيَا.   
\b  
\m
\v 12 مْسَارنْثْ وَاطَّاسْ ن ڒعْڒَامَاثْ ذ ڒعْجَايبْ جَارْ إِوْذَانْ س إِفَاسّنْ ن رُّوسُولْ ؤُشَا مَارَّا نِيثْنِي ثُوغَا مُوننْ س وُوڒْ ذ إِجّنْ ذڭْ ؤُسقِّيفْ أَكْ-ذ ؤُكُولْوَارْ ذ إِپِيلَارنْ ن سُولِيمَانْ. \x ◘ \xo 5:‏12 \xt مك. 16‏:‏17؛ ڒخ. 2‏:‏43. \x*  
\v 13 مَاشَا زڭْ إِوْذَانْ إِنّغْنِي وَارْ إِزْعِيمْ حذْ أَذْ كِيسنْ إِڭّْ أَزدْجِيفْ، مَاشَا ڒْڭنْسْ إِوقَّارْ ثنْ أَطَّاسْ.  
\v 14 مَّارنْينْ-د كْثَارْ عَاذْ غَارْ يِينِّي يُومْننْ ذِي سِيذِي، إِبَارُّوثنْ ن يرْيَازنْ ذ ثمْغَارِينْ،  
\v 15 أَڒَامِي ثُوغَا كسِّينْ إِمهْڒَاشْ بَارَّا غَارْ زّْنَاقِي، سّْرُوسَانْ ثنْ خْ ثَاسُّوثْ حِيمَا، خْمِي د غَا يَاسْ شِيمْعُونْ، بَالَاكْ أَذْ ثكّْ مْغِيرْ ثِيڒِي نّسْ خَاسنْ.  
\v 16 ؤُسِينْ-د ؤُڒَا ذ أَطَّاسْ زِي ثْندَّامْ نّغْنِي إِ ذ أَسْ د-إِنّْضنْ إِ ؤُرْشَالِيمْ، إِوْينْ-د إِمهْڒَاشْ نْسنْ ذ يِينِّي ذَايْسنْ ڒَارْيَاحْ إِمنْڭَاسْ، ؤُشَا مَارَّا ڭّنْفَانْ. \x ◘ \xo 5:‏16 \xt مك. 16‏:‏17؛ ڒخ. 8‏:‏7؛ 16‏:‏18؛ 19‏:‏12. \x*   
\b  
\m  
\s1 پُوطْرُوسْ ذ يُوحَانَّا بَارّْحنْ ذِي ثمْزِيذَا ثَامقّْرَانْثْ  
\m
\v 17 أَرَّايْسْ ن إِكهَّاننْ ذ مَارَّا إِنِّي إِدْجَانْ أَكِيذسْ، إِنِّي إِدْجَانْ زِي ثبْرِيذْثْ ن إِصَاذُوقِييّنْ، ذوْڒنْ شُّورنْ س ڒحْسذْ.  
\v 18 نِيثْنِي سَّارْسنْ إِفَاسّنْ خْ رُّوسُولْ، طّْفنْ ثنْ ؤُشَا أَرِّينْ ثنْ ذِي ڒقْيُوذْ ذِي ڒحْبسْ.  
\v 19 مَاشَا لْمَالَاكْ ن سِيذِي يَارْزمْ ثِيوُّورَا ن ڒحْبسْ س دْجِيڒثْ، إِسُّوفّغْ إِ-ثنْ غَارْ بَارَّا، إِنَّا أَسنْ: \x ◘ \xo 5:‏19 \xt ڒخ. 12‏:‏7؛ 16‏:‏26. \x*  
\v 20 ”رُوحمْ، خنِّي ثْبدّمْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، سِيوْڒمْ إِ ڒْڭنْسْ س مَارَّا أَوَاڒنْ-أَ ن ثُوذَارْثْ!“   
\m
\v 21 فّْغنْ-د نِيثْنِي غَارْ ونْقَارْ ن ثْفُوشْثْ، ؤُذْفنْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ، بْذَانْ سّڒْمَاذنْ. مَاشَا إِكَّارْ-د أَرَّايْسْ ن إِكهَّاننْ ذ يِينِّي أَكِيذسْ إِدْجَانْ، ؤُشَا ڒَاغَانْ خْ يِينِّي إِبدّنْ أَكِيذْسنْ ؤُ خْ إِمْغَارنْ ن أَيْثْ ن إِسْرَائِيل، ؤُشَا سّكّنْ \add إِمْسخَّارنْ نْسنْ\add* غَارْ ڒحْبسْ حِيمَا أَذْ ثنْ د-أَوْينْ.  
\v 22 ؤُمِي د-فّْغنْ إِنِّي \add زَّايْسنْ\add* د-إِتّْوَاسّكّنْ \add ذِينِّي\add*، وَارْ ثنْ ؤُفِينْ شَا ذِي ڒحْبسْ، ؤُشَاعقْبنْ، نَّانْ:  
\v 23 ”أَقَا نُوفَا ڒحْبسْ إِبلّعْ مْلِيحْ ؤُ إِعسَّاسنْ بدّنْ بَارَّا غَارْ ثوُّورَا، \add مَاشَا\add* ؤُمِي نَارْزمْ ثَاوَّارْثْ، وَارْ ذِينْ نُوفِي حذْ ذَاخڒْ.“   
\m
\v 24 ڒَامِي سْڒِينْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمقّْرَاننْ ن زَّاوشْثْ ثَامقّْرَانْثْ أَوَاڒنْ-أَ، ثْبهْثنْ أَطَّاسْ، إِودَّارْ أَسنْ مِينْ غَا ڭّنْ.  
\v 25 ؤُشَا يُوسَا-د إِجّْ ن ورْيَازْ إِخبَّارْ إِ-ثنْ، \add إِقَّارْ\add*: ”خْزَارْ، إِرْيَازنْ نِّي ثڭِّيمْ ذِي ڒحْبسْ، أَقَا بدّنْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، سّڒْمَاذنْ إِوْذَانْ!“   
\b  
\m
\v 26 ڒخْذنِّي رُوحنْ \add ذِينْ\add* ڒْقُويَاذْ أَكْ-ذ إِعسَّاسنْ، إِوْينْ ثنْ-د، وَارْ ث ڭِّينْ س ؤُغِيڒْ مِينْزِي ثُوغَا ڭّْوذنْ أَقَا ڒْڭنْسْ أَذْ ثنْ إِحجَّارْ. \x ◘ \xo 5:‏26 \xt مت. 21‏:‏26؛ ڒخ. 4‏:‏21. \x*  
\v 27 ؤُمِي ثنْ د-إِوْينْ، سّْبدّنْ ثنْ زَّاثْ إِ مَارَّا جْمَاعثْ \add ثَامقّْرَانْثْ\add*. إِسّقْسَا ثنْ أَرَّايْسْ ن إِكهَّاننْ، إِقَّارْ:  
\v 28 ”مَا وَارْ كنِّيوْ نُومُورْ س جّهْذْ مَاحنْذْ وَارْ ثسّْغَارَامْ ؤُڒَا ذ إِجّنْ س يِيسمْ-أَ؟ ؤُ خْزَارْ، أَقَا كنِّيوْ ثشُّورمْ ؤُرْشَالِيمْ س ثْغُورِي نْومْ، كنِّيوْ ثخْسمْ أَذْ خَانغْ ثَارّمْ إِذَامّنْ ن بْنَاذمْ-أَ!“ \x ◘ \xo 5:‏28 \xt مت. 27‏:‏25؛ ڒخ. 4‏:‏18. \x*   
\m
\v 29 شِيمْعُونْ ذ رُّوسُولْ أَرِّينْ-د، نَّانْ: ”إِتّْخصَّا أَنغْ أَذْ نتَّاعْ أَربِّي كْثَارْ زڭْ إِوْذَانْ. \x ◘ \xo 5:‏29 \xt ڒخ. 4‏:‏19. \x*  
\v 30 أَربِّي ن ڒجْذُوذْ نّغْ إِسّْنكَّارْ-د يَاسُوع ونِّي ثنْغِيمْ كنِّيوْ، ثُويْڒمْ ث خْ ثفْڒَاوْثْ. \x ◘ \xo 5:‏30 \xt أَعَوذ. 21‏:‏23؛ ڒخ. 3‏:‏15؛ 10‏:‏39؛ 13‏:‏29؛ 1 بُط. 2‏:‏24. \x*  
\v 31 أَربِّي إِڭَّا إِ-ث ذ أَزدْجِيفْ ذ ونِّي إِتِّيشنْ ثُوذَارْثْ، ؤُشَا إِسّْڭعّذْ إِ-ث غَارْ ؤُفُوسْ نّسْ ؤُفُوسِي مَاحنْذْ أَذْ إِوْشْ تُّوبثْ ذ وغْفَارْ ن دّْنُوبْ إِ إِسْرَائِيل. \x ◘ \xo 5:‏31 \xt ڒخ. 2‏:‏33؛ 3‏:‏15؛ فِيل. 2‏:‏9. \x*  
\v 32 نشِّينْ ذ ڒشْهُوذْ خْ مَانْ أَيَا ؤُشَا ؤُڒَا ذ أَرُّوحْ إِقدّْسنْ، إِ يوْشَا أَربِّي إِ يِينِّي ذَايسْ يُومْننْ.“ \x ◘ \xo 5:‏32 \xt يُوح. 15‏:‏27؛ ڒخ. 2‏:‏4. \x*  
\v 33 ڒَامِي سْڒِينْ أَيَا، هَاجنْ أَطَّاسْ ؤُشَا تّمْشَاوَارنْ حِيمَا أَذْ ثنْ نْغنْ.   
\m
\v 34 مَاشَا إِكَّارْ إِجّنْ زڭْ إِفَارِيسِييّنْ، قَّارنْ أَسْ ڭَامَالِييَالْ. نتَّا ذ أَمْسڒْمَاذْ ن شَّارِيعَا ؤُ مَارَّا ڒْڭنْسْ إِتّْوقَّارْ إِ-ث. يُومُورْ نتَّا حِيمَا أَذْ نذْهنْ رُّوسُولْ غَارْ بَارَّا إِ شْوَايْثْ ن ڒْوقْثْ.  
\v 35 إِنَّا أَسنْ: ”\add أَ\add* إِرْيَازنْ، أَيْثْ ن إِسْرَائِيل، حْضَامْ إِخفْ نْومْ، خْزَارمْ مْلِيحْ أَقَا \add مَارَّا\add* مِينْ غَا ثڭّمْ س إِوْذَانْ-أَ أَذْ يِيڒِي س ڒْحقّْ.  
\v 36 مِينْزِي قْبڒْ ڒْوقْثْ-أَ ثُوغَا إِكَّارْ ثُودَّاسْ، إِنَّا أَقَا نتَّا ذ شَا، ڒصْقنْ ذَايسْ عْڒَاحَاڒْ شَا ن أَربْعَا-مْيَا ن يرْيَازنْ. أَقَا نْغِينْ ث ؤُ مَارَّا إِنِّي ثُوغَا ث إِضفَّارنْ، ذوْڒنْ تّْوَازُوزَّارنْ، إِكمّڒْ أَرَّايْ نْسنْ. \x ◘ \xo 5:‏36 \xt ڒخ. 21‏:‏38. \x*  
\v 37 أَوَارْنِي مَانْ أَيَا إِكَّارْ يَاهُوذَا أَجَالِيلِي ذڭْ وُوسَّانْ ن ؤُزمّمْ إِ ؤُخدْجصْ ن ضَّارِيبَا إِ كُوڒْ ؤُزدْجِيفْ \add إِ زَّاوشْثْ ثَامقّْرَانْثْ\add*، ؤُشَا إِسّغْوَا أَطَّاسْ \add ن إِوْذَانْ\add* ذِي ڒْڭنْسْ أَوَارْنِي أَسْ. ؤُشَا نتَّا إِمُّوثْ ؤُشَا مَارَّا إِنِّي إِ-ث-إِ-د-إِضْفَارنْ، ذوْڒنْ تّْوَازدْجْعنْ.  
\v 38 ڒخُّو أَذْ أَومْ إِنِيغْ: ”سْبعّْذمْ إِخفْ نْومْ خْ إِوْذَانْ-أَ، جّمْ ثنْ أَذْ رَاحنْ، مِينْزِي مَاڒَا أَخَارّصْ-أَ نِيغْ ڒْخذْمثْ-أَ زڭْ إِوْذَانْ إِ يدْجَا، خنِّي أَذْ إِقْضَا. \x ◘ \xo 5:‏38 \xt أَوڒن. 21‏:‏30؛ إِشا. 8‏:‏10؛ مت. 15‏:‏13. \x*  
\v 39 مَاشَا مَاڒَا ثُوغَا-ث زِي أَربِّي، وَارْ ثْزمَّارمْ أَذْ ث ثْبطّْڒمْ، حِيمَا أَذْ ثَاغْ كنِّيوْ وَارْ ثتّْوِيفِيمْ ذ إِنِّي إِتّْمنْغَانْ أَكْ-ذ أَربِّي.“ \x ◘ \xo 5:‏39 \xt ڒخ. 9‏:‏5؛ 23‏:‏9. \x*  
\v 40 ڭِّينْ أَذْ تّْوَاسّْقنْعنْ زَّايسْ ؤُشَا أَوَارْنِي ڒَامِي ذ ڒَاغَانْ خْ رُّوسُولْ، جِّينْ أَذْ ثنْ هتّْكنْ س ؤُركُّوضْ،عڒْمنْ أَسنْ حِيمَا وَارْ سِّيوِيڒنْ عَاذْ س يِيسمْ ن يَاسُوع، خنِّي أَرْخُونْ أَسنْ.   
\m
\v 41 نِيثْنِي رُوحنْ زَّايْسنْ، فَارْحنْ ڒَامِي \add ؤُفِينْ بلِّي نِيثْنِي\add* تّْوَاحسْبنْ أَذْ سْذَاهدْجنْ أَبهْذڒْ ذِي طّْوعْ ن يِيسمْ \add نّسْ\add*. \x ◘ \xo 5:‏41 \xt مت. 5‏:‏12. \x*  
\v 42 وَارْ سّْبدّنْ شَا زڭْ ؤُسڒْمَاذْ ذِي مْكُوڒْ أَسّْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ ؤُ ذِي ثُوذْرِينْ ؤُ زڭْ ؤُبَارّحْ س سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.   
\b  
\b  
\m  
\c 6
\s1 ڒِيخْضَارثْ ن سبْعَا إِمْسخَّارنْ ن ڒْمُومِينِينْ  
\m
\v 1 ذڭْ وُوسَّانْ نِّي، ڒَامِي ثُوغَا كْثَارنْ إِمحْضَارنْ أَطَّاسْ، أَقَا إِمحْضَارنْ إِنِّي غَارْسنْ إِڒسْ ن إِيُونَانِييّنْعكْسنْ إِنِّي غَارْسنْ إِڒسْ ن ثْعِيبْرَانِيثْ مِينْزِي ثِيجَّاڒْ نْسنْ فَارّْضنْ ذَايْسنْثْ ذِي ثْسخَّارْثْ \add ن زَّاذْ\add* ن كُوڒْ أَسّْ.  
\v 2 \add س ؤُيَا\add* ڒَاغَانْ ثنْعَاشْ ن رُّوسُولْ خْ مَارَّا أَڭْرَاوْ ن إِمحْضَارنْ مَاحنْذْ أَذْ مُوننْ، نَّانْ أَسنْ: ”وَارْ إِعدّڒْ أَذْ نْسخَّارْ طّْوَابڒْ \add إِ مَاشَّا\add* أَمْ نتّجَّا ذڭْ وَاوَاڒْ ن أَربِّي. \x ◘ \xo 6:‏2 \xt ؤُف. 18‏:‏17. \x*  
\v 3 أَرْزُومْ خنِّي، \add أَ\add* أَيْثْمَا، ؤُ خْضَارمْ سبْعَا ن يرْيَازنْ زَّايْومْ إِنِّي غَارْ ثدْجَا شّْهَاذثْ \add ثشْنَا\add*، شُّورنْ س أَرُّوحْ ن سِيذِي ذ ثِيغِيثْ، ؤُشَا نشِّينْ أَذْ ثنْ نْكلّفْ \add خنِّي\add* س ثْمسْڒَاشْثْ-أَ. \x ◘ \xo 6:‏3 \xt أَعَوذ. 1‏:‏13؛ ڒخ. 1‏:‏21؛ 16‏:‏2؛ 1 تِيم. 3‏:‏7. \x*  
\v 4 مَاشَا نشِّينْ أَذْ نصْبَارْ ذِي ثْژَادْجِيثْ ؤُ ذِي ثْسخَّارْثْ ن وَاوَاڒْ.“  
\v 5 إِعْجبْ وَاوَاڒْ-أَ إِ مَارَّا ڒْغَاشِي ؤُشَا نِيثْنِي إِخْضَارنْ سْثِيفَانُوسْ، إِجّْ ن ورْيَازْ إِشُّورنْ س لْ-إِيمَانْ ذ أَرُّوحْ إِقدّْسنْ، \add خنِّي\add* فِيلِيبُّوسْ ذ بْرُوخُورُوسْ ذ نِيكَانُورْ ذ ثِيمُونْ ذ بَارْمِينَاسْ ذ نِيكُولَاسْ، إِجّْ ن ؤُمْعَاشَارْ ن دِّينْ ن وُوذَاينْ زِي أَنْثِييُوخِييَا. \x ◘ \xo 6:‏5 \xt ڒخ. 11‏:‏24؛ 21‏:‏8. \x*  
\v 6 سّْبدّنْ ثنْ قِيبَاتْشْ إِ رُّوسُولْ ؤُشَا، أَوَارْنِي ڒَامِي ژُّودْجنْ، سَّارْسنْ خَاسنْ إِفَاسّنْ نْسنْ. \x ◘ \xo 6:‏6 \xt ڒخ. 1‏:‏23؛ 8‏:‏17؛ 13‏:‏3؛ 1 تِيم. 4‏:‏14؛ 5‏:‏22؛ 2 تِيم. 1‏:‏6. \x*   
\m
\v 7 ثُوغَا أَوَاڒْ ن أَربِّي إِڭَّامْ ؤُ ڒْقدّْ ن إِمحْضَارنْ ذِي ؤُرْشَالِيمْ ثُوغَا إِمقَّارْ أَطَّاسْ. إِجّْ ن ؤُبَارُّو ذ أَمقّْرَانْ ن وُوذَاينْ إِطَاعْ إِ لْ-إِيمَانْ. \x ◘ \xo 6:‏7 \xt ڒخ. 19‏:‏20. \x*   
\b  
\m  
\s1 ؤُضُوفْ ن سْثِيفَانُوسْ  
\m
\v 8 سْثِيفَانُوسْ، إِشُّورْ س أَرْضَا ذ جّهْذْ، ثُوغَا إِتّڭّْ ڒعْڒَامَاثْ ذ ڒعْجَايبْ مْغَارنْثْ جَارْ ڒْڭنْسْ.  
\v 9 كَّارنْ يرْيَازنْ زِي ثمْزِيذَا ؤُمِي قَّارنْ ’أَلِيبرْثِينُو‘، \add إِرْيَازنْ زِي\add* قَايْرَاوَانْ ذ إِسْكَانْذَارِييَّا، ؤُڒَا زِي كِيلِيكِييَا ذ أَسِييَا، ؤُشَا نِيثْنِي ثُوغَا تّْقَاشَاحنْ سْثِيفَانُوسْ. \f ◼ \fr 6:‏9 \ft \+bd ’أَلِيبرْثِينُو‘\+bd* - إِوْذَانْ قَّارنْ بلِّي إِلِيبِيرْثِينِييّنْ ذ شَا ن إِسْرَائِيل إِيّنْ إِ ثُوغَا حبّْسنْ-ثنْ إِرُومَانِييّنْ إِوْينْ ثنْ غَارْ ثنْذِينْثْ ن رُومَا. منْبَاعْذْ ضȓقنْ-أَسنْ-د، سُّوفْغنْ-ثنْ زِي رُومَا، ؤُشَاعقْبنْ-د غَارْ إِسْرَائِيل ذ إِمُوشَانْ نّغْنِي. (ڒخ. 6:9).\f*  
\v 10 \add مَاشَا\add* وَارْ زمَّارنْ أَذْعكْسنْ ثِيغِيثْ ذ أَرُّوحْ إِ زَّايسْ ثُوغَا إِسَّاوَاڒْ. \x ◘ \xo 6:‏10 \xt ؤُف. 4‏:‏12؛ إِشا. 54‏:‏17؛ لك. 21‏:‏15. \x*  
\v 11 ڒخْذنِّي سّكّنْ إِرْيَازنْ، عَارّْننْ ثنْ مَاحنْذْ أَذْ إِنِينْ: ”أَقَا نسْڒَا أَسنْ سَّاوَاڒنْ س وَاوَاڒنْ إِشقّْفنْ ذِي مُوسَا ؤُ ذِي أَربِّي!“ \x ◘ \xo 6:‏11 \xt مت. 26‏:‏59. \x*  
\v 12 أَقَا سّْغوّْغنْ ڒْڭنْسْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add* ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ؤُشَا ؤُمِي خَاسْ د-دُّوقّْزنْ، طّْفنْ ث، نذْهنْ ث غَارْ جْمَاعثْ \add ثَامقّْرَانْثْ\add*.  
\v 13 ڭِّينْ ڒشْهُوذْ إِسّْخَارِّيقنْ، إِنِّي إِنَّانْ: ”بْنَاذمْ-أَ وَارْ إِسّْبذِّي أَذْ إِشقّفْ ذِي شَّارِيعَا ؤُ ذڭْ ومْشَانْ-أَ إِقدّْسنْ،  
\v 14 مِينْزِي نسْڒَا أَسْ إِقَّارْ بلِّي يَاسُوع نَّاصِيرِي وَانِيثَا أَذْ يَاردّدْجْ أَمْشَانْ-أَ، أَذْ إِبدّڒْ طّْبَايعْ إِ ذ أَنغْ إِوْشَا مُوسَا.“   
\m
\v 15 مَارَّا إِنِّي ثُوغَا غَارْ إِدْجَا ڒْكُورْسِي ذِي جْمَاعثْ \add ثَامقّْرَانْثْ\add*، حكَّارنْ ذَايسْ ؤُ ژْرِينْ أَغمْبُوبْ نّسْ أَمْ ؤُغمْبُوبْ ن إِجّْ ن لْمَالَاكْ.   
\b  
\b  
\m  
\c 7
\s1 أَوَاڒْ ن سْثِيفَانُوسْ زَّاثْ إِ جْمَاعثْ ثَامقّْرَانْثْ  
\m
\v 1 أَرَّايْسْ ن إِكهَّاننْ إِنَّا: ”مَا مَانْ أَيَا ذ ثِيذتّْ؟“  
\v 2 \add خنِّي\add* إِنَّا \add سْثِيفَانُوسْ\add*:  
\b  
\m ”أَ كنِّيوْ، \add أَ\add* إِرْيَازنْ، أَيْثْمَاثْنغْ ذ إِبَابَاثنْ نّغْ، سْڒمْ! أَربِّي ن ؤُعُودْجِي إِضْهَارْ إِ جذِّيثْنغْ إِبْرَاهِيمْ أَمْ ثُوغَا عَاذْ ذِي مِيسُوپُوثَامْيَا، \add ثنِّي ذ ثَامُّورْثْ جَارْ ثْنَاينْ ن إِغزْرَانْ\add*، قْبڒْ مَا أَذْ إِزْذغْ ذِي حَارَانْ.  
\v 3 نتَّا إِنَّا أَسْ: ’فّغْ زِي ثمُّورْثْ نّشْ ؤُ زِي ڒَادْجْ نّشْ، رُوحْ غَارْ ثمُّورْثْ ثنِّي إِ ذ أَشْ غَا سّشْنغْ.‘ \x ◘ \xo 7:‏3 \xt أَمز. 12‏:‏1. \x*  
\v 4 ڒخْذنِّي إِفّغْ إِبْرَاهِيمْ زِي ثمُّورْثْ ن إِكَالْذَانِييّنْ ؤُشَا إِزْذغْ ذِي هَارَانْ. أَوَارْنِي ڒَامِي إِمُّوثْ بَابَاسْ، إِسّْمُوطِّييْ إِ-ث-إِ-د أَربِّي غَارْ ثمُّورْثْ-أَ إِ ذِي ثْزدّْغمْ أَسّْ-أَ.  
\v 5 نتَّا وَارْ ذ أَسْ إِوْشِي شَا ذَايسْ ڒْوَارْثْ ؤُڒَا ذ إِجّْ ن ؤُصُورِيفْ ن ؤُضَارْ، \add مَاشَا\add* إِوَاعْذْ أَذْ أَسْ ت إِوْشْ ذ ڒْوَارْثْ، إِ نتَّا ؤُ إِ زَّارِيعثْ نّسْ أَوَارْنِي أَسْ، أَمْ وَارْ ثُوغِي غَارسْ عَاذْ مِّيسْ. \x ◘ \xo 7:‏5 \xt أَمز. 12‏:‏7؛ 13‏:‏15. \x*  
\v 6 إِسِّيوڒْ أَربِّي أَكِيذسْ، إِنَّا أَسْ: ’أَذْ ثِيڒِي زَّارِيعثْ نّشْ ذ أَمْعزّبْ ذڭْ إِشْثْ ن ثمُّورْثْ ثغْرِيبْثْ، ؤُشَا نِيثْنِي أَذْ ثنْ أَرّنْ ذ إِسمْغَانْ، أَذْ ذَايْسنْغزَّانْ أَربْعَا-مْيَا ن إِسڭّْوُوسَا. \x ◘ \xo 7:‏6 \xt أَمز. 15‏:‏13‏-‏14، 16؛ ؤُف. 12‏:‏40؛ ڭال. 3‏:‏17. \x*  
\v 7 ؤُشَا ڒْڭنْسْ إِ ذ أَسْ غَاعبْذنْ أَمْ يِيسمْغَانْ، أَذْ ث حَاسْبغْ.‘ ؤُشَا يَارْنِي أَربِّي ذڭْ وَاوَاڒْ نّسْ، إِنَّا: ’أَوَارْنِي مَانْ أَيَا أَذْ فّْغنْ، أَذْ أَيِيعبْذنْ ذڭْ ومْشَانْ-أَ‘. \x ◘ \xo 7:‏7 \xt أَمز. 15‏:‏16؛ ؤُف. 3‏:‏12. \x*  
\v 8 نتَّا إِوْشَا أَسْ ڒْعَاهْذْ ن وخْثَانْ. خَاسْ ؤُشَا إِجَّا-د إِسْحَاقْ ؤُشَا إِخْثنْ إِ-ث ذڭْ وَاسّْ وِيسّْ ثْمنْيَا ؤُشَا إِسْحَاقْ إِجَّا-د يَاعْقُوبْ، يَاعْقُوبْ إِجَّا-د ثنْعَاشْ ن ڒجْذُوذْ \add إِمزْوُورَا\add*. \x ◘ \xo 7:‏8 \xt أَمز. 21‏:‏2؛ 25‏:‏24؛ 29‏:‏32؛ 30‏:‏5؛ 35‏:‏23. \x*   
\m
\v 9 ڒجْذُوذْ \add إِمزْوُورَا\add* غَارّنْ زِي يُوسُوفْ ؤُشَا زّنْزنْ ث غَارْ مِيصْرَا. \add مَاشَا\add* أَربِّي ثُوغَا-ث أَكِيذسْ، \x ◘ \xo 7:‏9 \xt أَمز. 37‏:‏3، 28؛ إِزهد. 105‏:‏17. \x*  
\v 10 إِسّنْجمْ إِ-ث زِي مَارَّا ڒمْحَايمْ نّسْ. نتَّا إِوْشَا أَسْ أَرْضَا ذ ثِيغِيثْ قِيبَاتْشْ إِ فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا، ؤُشَا وَانِيثَا إِڭَّا إِ-ث ذ أَزدْجِيفْ خْ مِيصْرَا ؤُ خْ مَارَّا ثَادَّارْثْ نّسْ. \x ◘ \xo 7:‏10 \xt أَمز. 41‏:‏40. \x*  
\v 11 \add مَاشَا\add* يُوسَا-د ڒَاژْ ذ إِشْثْ ن ڒْمحْنثْ ثمْغَارْ ذِي مَارَّا ثَامُّورْثْ ن مِيصْرَا ؤُ ذِي ثمُّورْثْ ن كنْعَانْ، وَارْ ثُوغِي إِ ڒجْذُوذْ نّغْ حِيمَا أَذْ جِيوْننْ. \x ◘ \xo 7:‏11 \xt أَمز. 41‏:‏54؛ إِزهد. 105‏:‏16. \x*  
\v 12 مَاشَا ؤُمِي إِسْڒَا يَاعْقُوبْ بلِّي أَقَا ذِينْ \add عَاذْ\add* مِينْ إِقِّيمنْ \add ن ڒْحبّْ\add* ذِي مِيصْرَا، إِسّكّْ ڒجْذُوذْ نّغْ \add ذِينِّي\add* إِ ؤُمُورْ أَمزْوَارُو. \x ◘ \xo 7:‏12 \xt أَمز. 42‏:‏1. \x*  
\v 13 ڒَامِي ذِينْ رُوحنْ إِ ؤُمُورْ وِيسّْ ثْنَاينْ إِسّضْهَارْ يُوسُوفْ إِخفْ نّسْ إِ يَايْثْمَاسْ ؤُشَا يَارْڭبْ فِيرْعُونْ خْ ڒَادْجْ ن يُوسُوفْ. \x ◘ \xo 7:‏13 \xt أَمز. 45‏:‏4. \x*  
\v 14 إِسّكّْ يُوسُوفْ، يُومُورْ مَاحنْذْ أَذْ د-يَاسْ بَابَاسْ يَاعْقُوبْ ذ مَارَّا ڒَادْجْ نّسْ: خمْسَا ؤُ-سبْعِينْ ن ڒعْمُورْ.  
\v 15 إِهْوَا-د يَاعْقُوبْ غَارْ مِيصْرَا، إِمُّوثْ نتَّا ذ ڒجْذُوذْ نّغْ. \x ◘ \xo 7:‏15 \xt أَمز. 46‏:‏5؛ 49‏:‏33. \x*  
\v 16 إِوْينْ ث غَارْ شَاكِيمْ، سَّارْسنْ ث ذڭْ ونْضڒْ نِّي إِسْغَا إِبْرَاهِيمْ س يِيجّْ ن تَّامَانْ ن نُّوقَارْثْ زڭْ أَيْثْ ن حَامُورْ، بَابَاسْ ن شَاكِيمْ. \x ◘ \xo 7:‏16 \xt أَمز. 23‏:‏16؛ 50‏:‏13؛ ؤُف. 13‏:‏19؛ ياش. 24‏:‏32. \x*   
\m
\v 17 مَاشَا أَڒَامِي د-ثِيوضْ ڒْوقْثْ إِ ثُوغَا إِوَاعْذْ زَّايسْ أَربِّي إِ إِبْرَاهِيمْ س إِشْثْ ن ثْجَادْجِيثْ، ثُوغَا إِڭَامْ ڒْڭنْسْ، إِذْوڒْ إِجْهذْ ذِي مِيصْرَا، \x ◘ \xo 7:‏17 \xt ؤُف. 1‏:‏7؛ إِزهد. 105‏:‏24. \x*  
\v 18 أَڒَامِي د-إِكَّارْ إِجّْ ن ؤُجدْجِيذْ نّغْنِي خْ مِيصْرَا إِ ثُوغَا وَارْ إِسِّيننْ يُوسُوفْ. \x ◘ \xo 7:‏18 \xt ؤُف. 1‏:‏8\x*  
\v 19 وَانِيثَا ثُوغَا إِتّڭّْ س ڒغْذَارْ أَكْ-ذ جَّاذِيرَا نّغْ ؤُشَا إِغزَّا خْ ڒجْذُوذْ نّغْ. يُومُورْ إِ-ثنْ مَاحنْذْ أَذْ نْضَارنْ إِسيْمَانْ نْسنْ حِيمَا وَارْ تّْغِيمِينْ أَذْ دَّارنْ.   
\m
\v 20 ذِي ڒْوقْثْ نِّي إِخْڒقْ-د مُوسَا، يُوسَا أَسْ-د خْ ڒْخَاضَارْ إِ أَربِّي. سّيْمنْ ث ذِي ثَادَّارْثْ ن بَابَاسْ ثْڒَاثَا ن إِيُورنْ. \x ◘ \xo 7:‏20 \xt ؤُف. 2‏:‏2؛ 6‏:‏19؛ ڒخْڒ. 26‏:‏59؛ 1 إِم. 23‏:‏13؛ عبر. 11‏:‏23. \x*  
\v 21 ڒَامِي إِتّْوَامّنْضَارْ زڭْ يمَّاسْ \add ذڭْ إِغْزَارْ\add*، ثُوفَا إِ-ث يدْجِيسْ ن فِيرْعُونْ، ثسّيمْ إِ-ث أَمْ مَامّشْ \add إِدْجَا\add* ذ مِّيسْ ن يِيخفْ نّسْ.  
\v 22 إِتّْوَاسّْغَارْ مُوسَا ذِي مَارَّا ثِيغِيثْ ن إِمِيصْرِييّنْ ؤُشَا ثُوغَا إِتّْقدَّا خْ وَاوَاڒْ ؤُ خْ مِينْ ثُوغَا إِتّڭّْ.   
\m
\v 23 أَڒَامِي غَارسْ أَربْعِينْ ن إِسڭّْوُوسَا، إِضَارْ-د خَاسْ ذڭْ وُوڒْ نّسْ مَاحنْذْ أَذْ يَارْزفْ أَيْثْمَاسْ، أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 7:‏23 \xt ؤُف. 2‏:‏11‏-‏15. \x*  
\v 24 ؤُمِي إِژْرَا أَقَا ضدْجنْ إِجّنْ زڭْ أَيْثْمَاسْ زِي ثقْبِيتْشْ نّسْ، إِخْڒفْ زَّايسْ ذِي طّْوعْ نّسْ، إِڭَّا إِخفْ نّسْ ذ ڒْقَاضِي ذِي سِّيبّثْ نّسْ ؤُشَا إِنْغَا أَمِيصْرِي نِّي ث إِضدْجنْ.  
\v 25 ثُوغَا إِتّْرَاجَا بلِّي ثَاوْمَاثْ نّسْ، أَيْثْ ن إِسْرَائِيل، أَذْ فهْمنْ أَقَا أَربِّي أَذْ أَسنْ إِسِّيوِيضْ أَسنْجمْ س ؤُفُوسْ نّسْ، مَاشَا نِيثْنِي وَارْ فْهِيمنْ.   
\m
\v 26 ذڭْ وَاسّْ أَوَارْنِي أَسْ إِضْهَارْ أَسنْ-د عَاوذْ، ڒَامِي ثُوغَا تّْمنْغَانْ. إِعْڒمْ أَسنْ مَاحنْذْ أَذْ مسّصْڒَاحنْ، إِقَّارْ: ’\add أَ\add* إِرْيَازنْ، كنِّيوْ ذ أَوْمَاثنْ، مَايمِّي ثْعدَّامْ إِجّنْ خْ ونّغْنِي؟‘  
\v 27 ونِّي ثُوغَا إِتّْعدَّانْ خْ ؤُمدُّوكّڒْ نّسْ، إِعَارّنْ إِ-ث، إِقَّارْ: ’وِي شكْ إِڭِّينْ خَانغْ ذ أَزدْجِيفْ ذ ڒْقَاضِي؟ \x ◘ \xo 7:‏27 \xt مت. 21‏:‏23؛ ڒخ. 7‏:‏35؛ 4‏:‏7. \x*  
\v 28 مَا أَذْ ثَاغْ أَذْ ثخْسذْ أَذْ أَيِي ثنْغذْ أَمْ مَامّشْ ثنْغِيذْ إِضنَّاضْ أَمِيصْرِي؟‘ \x ◘ \xo 7:‏28 \xt ؤُف. 2‏:‏14. \x*  
\v 29 ڒخْذنِّي يَارْوڒْ مُوسَا ذِي سِّيبّثْ ن وَاوَاڒْ-أَ ؤُشَا إِذْوڒْ ذ أَمْعزّبْ ذِي ثمُّورْثْ ن مِيذْيَانْ مَانِي د-يجَّا ثْنَاينْ إِحنْجِيرنْ.   
\m
\v 30 أَوَارْنِي ڒَامِي عْذُونْ إِ نتَّا أَربْعِينْ ن إِسڭّْوُوسَا، إِبَانْ أَسْ-د لْمَالَاكْ ن سِيذِي ذِي ڒخْڒَا ن وذْرَارْ ن سِينَا ذِي ثْمسِّي إِتّحْذُوذُوقنْ ذِي شْبَارْقْ أَكْ-ذ إِسنَّاننْ. \x ◘ \xo 7:‏30 \xt ؤُف. 3‏:‏2 \x*  
\v 31 ؤُمِي إِژْرَا مُوسَا مَانْ أَيَا، إِثبْهثْ س ڒوْحِييْ إِ إِژْرَا، ؤُشَا ؤُمِي د-إِقَارّبْ حِيمَا أَذْ إِژَارْ، إِنَّا أَسْ سِيذِي س إِشْثْ ن ثْمِيجَّا:  
\v 32 ’أَقَا ذ نشّْ، أَربِّي ن ڒجْذُوذْ نْومْ، أَربِّي ن إِبْرَاهِيمْ، ن إِسْحَاقْ ؤُ ن يَاعْقُوبْ!‘ إِبْذَا مُوسَا إِتَّارْجِيجِي أَطَّاسْ، وَارْ إِزْعِيمْ أَذْ إِخْزَارْ غَارْ ڒوْحِييْ. \x ◘ \xo 7:‏32 \xt ؤُف. 3‏:‏6؛ مت. 22‏:‏32؛ عبر. 11‏:‏16. \x*  
\v 33 إِنَّا أَسْ سِيذِي: ’كّسْ سَانْذَالِييَاثْ نّشْ زڭْ إِضَارنْ نّشْ، مِينْزِي ثَامُّورْثْ مِيخفْ ثْبدّذْ ثْقدّسْ \add إِ ثدْجَا\add*.‘ \x ◘ \xo 7:‏33 \xt ؤُف. 3‏:‏5، 7، 8، 10؛ ياش. 5‏:‏15. \x*  
\v 34 أَقَا ژْرِيغْ ڒْمحْنثْ ن ڒْڭنْسْ إِنُو ذِي مِيصْرَا ؤُشَا سْڒِيغْ إِ ؤُزهَّارْ نْسنْ، هْوِيغْ-د حِيمَا أَذْ ثنْ سّْنجْمغْ. ؤُشَا ڒخُّو، أَسْ-د ذَا، أَذْ د شكْ سّكّغْ غَارْ مِيصْرَا.‘ \x ◘ \xo 7:‏34 \xt ؤُف. 3‏:‏2‏-‏10. \x*   
\m
\v 35 مُوسَا وَانِيثَا، ونِّي إِنْضَارنْ نِيثْنِي ؤُمِي نَّانْ: ’وِي شكْ إِڭِّينْ خَانغْ ذ أَزدْجِيفْ ذ ڒْقَاضِي؟‘، وَانِيثَا إِسّكّْ إِ-ث إِ-د أَربِّي غَارْسنْ ذ أَزدْجِيفْ ذ ؤُمْسنْجمْ س ؤُفُوسْ ن لْمَالَاكْ نِّي ذ أَسْ د-إِضْهَارنْ ذِي شْبَارْقْ أَكْ-ذ إِسنَّاننْ.  
\v 36 وَانِيثَا إِسُّوفّغْ إِ-ثنْ \add زِي مِيصْرَا\add* أَمْ إِڭَّا ڒعْڒَامَاثْ ذ ڒعْجَايبْ ذ ثْمڭَّا ثِيمقّْرَانِينْ ذِي ثمُّورْثْ ن مِيصْرَا، غَارْ ڒبْحَارْ ن ؤُغَانِيمْ ؤُ ذِي ڒخْڒَا ڒْمِيجَاڒْ ن أَربْعِينْ ن إِسڭّْوُوسَا. \x ◘ \xo 7:‏36 \xt ؤُف. 7؛ 8؛ 9؛ 10؛ 11؛ 13؛ 14؛ 16‏:‏1؛ أَعَوذ. 1‏:‏3. \x*  
\v 37 وَا ذ مُوسَا ونِّي إِنَّانْ إِ أَيْثْ ن إِسْرَائِيل: ’سِيذِي، أَربِّي نْومْ، أَذْ أَومْ د-إِسّْڭعّذْ إِجّْ ن ؤُنَابِي أَمْ نشّْ زِي ثَاوْمَاثْ نْومْ. إِ نتَّا ؤُمِي إِتّْخصَّا أَذْ ثسْڒَامْ!‘ \x ◘ \xo 7:‏37 \xt أَعَوذ. 18‏:‏15، 18؛ يُوح. 1‏:‏46؛ ڒخ. 3‏:‏22؛ مت. 17‏:‏5. \x*  
\v 38 وَانِيثَا ثُوغَا-ث ذِي ثْمسْمُونْثْ ن ڒْڭنْسْ ذِي ڒخْڒَا أَكْ-ذ لْمَالَاكْ ونِّي ثُوغَا أَكِيذسْ إِسَّاوَاڒنْ خْ وذْرَارْ ن سِينَا ؤُڒَا أَكْ-ذ ڒجْذُوذْ نّغْ. أَقَا نتَّا ثُوغَا إِتّطّفْ أَوَاڒنْ ن ثُوذَارْثْ حِيمَا أَذْ أَنغْ ثنْ يوْشْ. \x ◘ \xo 7:‏38 \xt ؤُف. 19‏:‏3؛ ڭال. 3‏:‏19. \x*  
\v 39 \add مَاشَا\add* ڒجْذُوذْ نّغْ وَارْ خْسنْ أَذْ أَسْ مَّارْسنْ إِخفْ نْسنْ، مَاشَا سّْثوّْجنْ ث خَاسنْ ؤُشَاعقْبنْ غَارْ مِيصْرَا ذڭْ وُوڒَاونْ نْسنْ.  
\v 40 مَاغَارْ نَّانْ إِ هَارُونْ: ’أڭّْ أَنغْ إِربِّيثنْ إِنِّي ذ أَنغْ إِ غَا إِزْوَارنْ، مِينْزِي مُوسَا وَانِيثَا ونِّي ذ أَنغْ إِڭوّْذنْ زِي ثمُّورْثْ ن مِيصْرَا، وَارْ نسِّينْ مِينْ ذ أَسْ إِمْسَارنْ.‘ \x ◘ \xo 7:‏40 \xt ؤُف. 32‏:‏1، 23. \x*  
\v 41 ڭِّينْ إِجّْ ن ؤُفُونَاسْ ن صَّانَامْ إِ يِيخفْ نْسنْ ذڭْ وُوسَّانْ نِّي، سّْڭعّْذنْ ثِيغَارْصَا إِ لْ-أَصْنَامْ ؤُشَا فَارْحنْ س مِينْ ڭِّينْ إِفَاسّنْ نْسنْ.  
\v 42 أَربِّي إِوْشَا \add أَسنْ\add* س وعْرُورْ ؤُشَا يَارَّا إِ-ثنْ أَذْعبْذنْ ڒْعسْكَارَاثْ ن ؤُجنَّا أَمْ مَامّشْ ثُوغَا ثُورَا ذڭْ وذْلِيسْ ن إِنَابِييّنْ:  
\b  
\m \qt ’مَايمِّي ثِيوْيمْ أَيِي-د\qt*  
\m \qt زعْمَا إِمُّوذَارنْ ذ ثِيغَارْصَا\qt*  
\m \qt أَربْعِينْ ن إِسڭّْوُوسَا ذِي ڒخْڒَا،\qt*  
\m \qt \+tl أَ\+tl* أَيْثْ ن إِسْرَائِيل؟\qt* \x ◘ \xo 7:‏42 \xt عَام. 5‏:‏25. \x*   
\m
\v 43 \qt أَقَا ثِيوْيمْ-د ثَازذِّيغْثْ ن مَالْكُومْ،\qt*  
\m \qt ذ إِثْرِي ن أَربِّي رِيمْفَانْ،\qt*  
\m \qt ڒخْيَاڒَاثْ إِ ثڭِّيمْ حِيمَا أَذْ ثنْثْ ثْعبْذمْ.\qt*  
\m \qt نشّْ أَذْ كنِّيوْ سّْبعّْذغْ\qt*  
\m \qt أَغِيرِينْ قَاعْ إِ بَابِيلْ.‘\qt* \x ◘ \xo 7:‏43 \xt عَام. 5‏:‏26، 27. \x*   
\b  
\m
\v 44 ثَازذِّيغْثْ ن شّْهَاذثْ ن ڒجْذُوذْ نّغْ ثُوغَا-ت ذِي ڒخْڒَا أَمْ مَامّشْ ثُوغَا يُومُورْ نتَّا ونِّي ثُوغَا إِسَّاوَاڒْ أَكْ-ذ مُوسَا مَاحنْذْ أَذْ ت إِڭّْ خْ ؤُمذْيَا إِ ذ أَسْ إِسّْشنْ. \x ◘ \xo 7:‏44 \xt ؤُف. 25‏:‏40؛ عبر. 8‏:‏5. \x*  
\v 45 ڒجْذُوذْ نّغْ أَكْ-ذ يَاشُووَا سِّيذْفنْ ثَازذِّيغْثْ-أَ غَارْ ثمُّورْثْ نِّي ذ أَسنْ إِوْشَا أَربِّي ذ ڒْوَارْثْ زِي ڒڭْنُوسْ، \add ڒڭْنُوسْ\add* نِّي إِسُّوفّغْ إِ-ثنْ أَربِّي قِيبَاتْشْ إِ ؤُغمْبُوبْ نْسنْ، ؤُ نِيثْنِي أَرْبُونْ ت أَڒْ وُوسَّانْ ن ذَاوُوذْ. \x ◘ \xo 7:‏45 \xt ياش. 3‏:‏14. \x*  
\v 46 وَانِيثَا يُوفَا أَرْضَا غَارْ أَربِّي ؤُشَا إِتَّارْ \add أَسْ\add* أَذْ يَافْ إِشْثْ ن ثْزذِّيغْثْ إِ أَربِّي ن يَاعْقُوبْ. \x ◘ \xo 7:‏46 \xt 1 صم. 16‏:‏1؛ 2 صم. 7‏:‏2؛ 1 إِم. 17‏:‏1؛ إِزهد. 89‏:‏21؛ 132‏:‏5؛ ڒخ. 13‏:‏22. \x*  
\v 47 مَاشَا سُولِيمَانْ إِبْنَا أَسْ ثَادَّارْثْ. \x ◘ \xo 7:‏47 \xt 1 إِج. 6‏:‏1؛ 1 إِم. 17‏:‏12. \x*  
\v 48 مَاشَا أَمْعُودْجِي خْ كُوڒْشِي وَارْ إِزدّغْ ذڭْ \add إِشْثْ ن ثْزذِّيغْثْ\add* إِ إِتّْوَاڭّنْ س إِفَاسّنْ \add ن إِوْذَانْ\add* أَمْ مَامّشْ إِقَّارْ ؤُنَابِي: \x ◘ \xo 7:‏48 \xt 1 إِج. 8‏:‏27؛ ڒخ. 17‏:‏24. \x*   
\b  
\m
\v 49 \qt ’أَجنَّا ذ ڒْعَارْشْ إِنُو\qt*  
\m \qt ؤُ ثمُّورْثْ ذ ثَانبْذَاثْ سَاذُو إِضَارنْ إِنُو.\qt*  
\m \qt مَانِي ثَادَّارْثْ إِ ذ أَيِي غَا ثبْنَامْ،\qt*  
\m \qt إِقَّارْ سِيذِي،\qt*  
\m \qt نِيغْ مَانِي أَمْشَانْ ن أَرَّاحثْ إِنُو؟\qt* \x ◘ \xo 7:‏49 \xt 2 إِم. 6‏:‏33؛ إِشا. 66‏:‏1، 2؛ مت. 5‏:‏34؛ 23‏:‏22. \x*   
\m
\v 50 \qt مَا وَارْ إِڭِّي ؤُفُوسْ إِنُو مَانْ أَيَا مَارَّا؟‘\qt* \x ◘ \xo 7:‏50 \xt إِشا. 66‏:‏1‏-‏2؛ أَمز. 1‏:‏4. \x*   
\b  
\m
\v 51 \add أَ كنِّيوْ\add* إِنِّي إِتّْغنَّانْ ذ يِينِّي وَارْ إِتّْوَاخثْننْ ن وُوڒْ ذ ؤُثسْڒِي، ڒبْذَا ثتّمْعَاڒَامْ خْ أَرُّوحْ إِقدّْسنْ. أَمْ مَامّشْ ڭِّينْ ڒجْذُوذْ نْومْ، أَمُّو إِ ثتّڭّمْ ؤُڒَا ذ كنِّيوْ. \x ◘ \xo 7:‏51 \xt نَاح. 9‏:‏16، 17؛ إِرْم. 6‏:‏1. \x*  
\v 52 مَانْ ونْ زڭْ إِنَابِييّنْ وَارْ ثنْ مَارّْثنْ ؤُ وَارْ ثنْ نْغِينْ ڒجْذُوذْ نْومْ، أَقَا إِنِّي إِزْوَارنْ بَارّْحنْ خْ ثْوَاسِيثْ ن ؤُمْسڭَّاذْ، ونِّي ثْسلّْممْ، ثنْغِيمْ ث كنِّيوْ، \x ◘ \xo 7:‏52 \xt ڒخ. 22‏:‏14؛ رُوم. 3‏:‏26؛ 1 بُط. 3‏:‏18؛ 1 يُوح. 2‏:‏1\x*  
\v 53 كنِّيوْ إِنِّي إِكْسِينْ شَّارِيعَا س ڒُومُورْ ن لْمَالَاكَاثْ مَاشَا وَارْ ذَايسْ ثطِّيفمْ.“ \x ◘ \xo 7:‏53 \xt ؤُف. 19‏:‏3؛ 24‏:‏3؛ يُوح. 7‏:‏19؛ ڭال. 3‏:‏19؛ عبر. 2‏:‏2. \x*   
\b  
\m
\v 54 ؤُمِي سْڒِينْ أَيَا، دُّوقّْزنْ نِيثْنِي س ؤُخيّقْ،غژّنْ ثِيغْمَاسْ نْسنْ غَارسْ.  
\v 55 مَاشَا أَمْ ثُوغَا إِشُّورْ س لْ-إِيمَانْ ذ أَرُّوحْ إِقدّْسنْ، إِكسِّي نتَّا ثِيطَّاوِينْ نّسْ ذڭْ ؤُجنَّا، إِژْرَا أَعُودْجِي ن أَربِّي، ذ يَاسُوع إِبدّْ غَارْ يفُوسْ ن أَربِّي،  
\v 56 إِنَّا: ”خْزَارْ، تّْوَاڒِيغْ إِجنْوَانْ أَرْزْمنْ ؤُ مِّيسْ ن بْنَاذمْ إِبدّْ غَارْ يفُوسْ ن أَربِّي.“  
\v 57 مَاشَا نِيثْنِي، أَمْ سْغُويُّونْ س إِشْثْ ن ثْمِيجَّا ذ ثَامقّْرَانْثْ، قّْننْ إِمجَّانْ نْسنْ ؤُشَا هجْمنْ خَاسْ مَارَّا.  
\v 58 ثْطْفنْ ث، سُّوفّْغنْ ث بَارَّا إِ ثنْذِينْثْ، بْذَانْ تّْحجَّارنْ ث ؤُ ڒشْهُوذْ سَّارْسنْ أَرُّوضْ نْسنْ غَارْ إِضَارنْ ن إِجّْ ن ؤُبْڒِيغْ قَّارنْ أَسْ شَاوُولْ. \x ◘ \xo 7:‏58 \xt 1 إِج. 21‏:‏13؛ لك. 4‏:‏29. \x*  
\v 59 ثُوغَا تّْحجَّارنْ سْثِيفَانُوسْ أَمْ إِتّْڒَاغَا، إِقَّارْ: ”أَ سِيذِيثْنغْ يَاسُوع، طّفْ أَرُّوحْ إِنُو.“ \x ◘ \xo 7:‏59 \xt إِزهد. 31‏:‏6؛ لك. 23‏:‏46. \x*  
\v 60 خنِّي إِوْضَا \add خْ إِفَادّنْ نّسْ\add*، إِسْغُويْ س إِشْثْ ن ثْمِيجَّا ثجْهذْ، إِنَّا: ”أَ سِيذِيثْنغْ، وَارْ ذ أَسنْ تّْحَاسَابْ دّْنُوبْ-أَ!“ أَوَارْنِي ڒَامِي إِنَّا أَيَا، إِطّصْ \add س يِيضسْ ن ڒْموْثْ\add*. \x ◘ \xo 7:‏60 \xt مت. 5‏:‏44؛ لك. 23‏:‏34؛ 1 كُور. 4‏:‏12. \x*   
\b  
\b  
\m  
\c 8
\s1 أَذَارّشْ خْ ثْمسْمُونْثْ ن يَاسُوع لْمَاسِيحْ  
\m
\v 1 شَاوُولْ يَارْضَا خْ ڒْموْثْ نّسْ ؤُشَا إِشَارْشْ ذڭْ ؤُنقِّي نّسْ. ذڭْ وُوسَّانْ نِّي إِمْسَارْ إِجّْ ن ؤُمَارّثْ إِمْغَارْ خْ ثْمسْمُونْثْ ذِي ؤُرْشَالِيمْ ؤُ مَارَّا تّْوَازُوزَّارنْ غَارْ ذْشُورَاثْ ن يَاهُوذِييَّا ذ سَامَارْيَا، مْغِيرْ رُّوسُولْ لَّا. \x ◘ \xo 8:‏1 \xt ڒخ. 11‏:‏19؛ 22‏:‏20. \x*  
\v 2 شَا ن يرْيَازنْ يُومْننْ كْسِينْ ث، أَرْبُونْ سْثِيفَانُوسْ غَارْ ونْضڒْ ؤُشَا ڭِّينْ خَاسْ إِجّْ ن وشْضَانْ أَمقّْرَانْ. \x ◘ \xo 8:‏2 \xt أَمز. 23‏:‏2؛ 50‏:‏10؛ 2 صم. 3‏:‏31\x*  
\v 3 مَاشَا شَاوُولْ ثُوغَا إِتّْذَارّشْ ثَامسْمُونْثْ خْمِي إِتَّاذفْ غَارْ ثُوذْرِينْ، إِتّْجَارَّا إِرْيَازنْ ذ ثمْغَارِينْ، إِندّهْ إِ-ثنْ غَارْ ڒحْبسْ. \x ◘ \xo 8:‏3 \xt ڒخ. 9‏:‏1؛ 22‏:‏4؛ 26‏:‏9؛ 1 كُور. 15‏:‏9؛ ڭال. 1‏:‏13؛ 1 تِيم. 1‏:‏13. \x*   
\b  
\m  
\s1 أَبَارّحْ ن لْ-إِنْجِيلْ س فِيلِيبُّوسْ ذِي ثنْذِينْثْ ن سَامَارِييَا  
\m
\v 4 إِنِّي إِتّْوَازُوزَّارنْ ثُوغَا ڭُّورنْ، تّنّْضنْ، تّْبَارّْحنْ س وَاوَاڒْ ن أَربِّي. \x ◘ \xo 8:‏4 \xt مت. 10‏:‏23؛ ڒخ. 11‏:‏19. \x*  
\v 5 أَمُو إِهْوَا-د فِيلِيبُّوسْ \add عَاوذْ\add* غَارْ إِشْثْ ن ثنْذِينْثْ ن إِسَامَارِييّنْ، إِبَارّحْ إِ-ثنْ س لْمَاسِيحْ.  
\v 6 ؤُمِي سْڒِينْ إِ وَاوَاڒْ نّسْ، تّْوَاسّْقنْعنْ إِوْذَانْ إِ ثُوغَا إِتّسْڒَانْ س مَارَّا مِينْ إِتّْوَانَّانْ زِي فِيلِيبُّوسْ، مَاغَارْ ژْرِينْ ڒعْڒَامَاثْ إِ إِڭَّا.  
\v 7 مِينْزِي أَطَّاسْ ن يِينِّي إِتّْوَاطّْفنْ زِي ڒَارْيَاحْ إِمنْڭَاسْ، سْغُويُّونْ س ثْمِيجَّا إِجهْذنْ ؤُشَا فّْغنْ زَّايْسنْ. إِنّغْنِي إِ ثُوغَا ذ إِنعْضَابنْ ذ إِقجْذَاحنْ تّْوَاسّْڭنْفَانْ. \x ◘ \xo 8:‏7 \xt مك. 16‏:‏17؛ ڒخ. 5‏:‏16؛ 16‏:‏18؛ 19‏:‏11. \x*  
\v 8 ثُوغَا ذِينْ إِشْثْ ن ڒفْرَاحثْ ثمْغَارْ ذِي ثنْذِينْثْ نِّي.   
\m
\v 9 ثُوغَا ذِينْ إِجّْ ن ورْيَازْ، قَّارنْ أَسْ شِيمُونْ، ثُوغَا إِزدّغْ ذِي ثنْذِينْثْ نِّي أَطَّاسْ زڭْ وَامِي. نتَّا ثُوغَا إِسّْغكّْوَا ڒْڭنْسْ ن إِسَامَارِييّنْ س ثْسحَّارْثْ نّسْ، إِتّْبَارّنْ خْ يِيخفْ نّسْ، إِنَّا: ”نشّْ، \add أَقَا\add* نشّْ ذ ونِّي إِمْغَارنْ!“ \x ◘ \xo 8:‏9 \xt ڒخ. 13‏:‏6. \x*  
\v 10 مَارَّا سْڒِينْ غَارسْ، أَمْ ؤُمژْيَانْ، أَمْ ؤُمقّْرَانْ، نَّانْ: ”وَانِيثَا ذ جّهْذْ إِمْغَارنْ ن أَربِّي.“  
\v 11 إِسّقْنعْ إِ-ثنْ مَارَّا س مِينْزِي ثُوغَا إِسَّارْجفْ إِ-ثنْ س سّْحُورْ نّسْ أَطَّاسْ زڭْ وَامِي.  
\v 12 مَاشَا ؤُمِي يُومْننْ ذِي فِيلِيبُّوسْ ونِّي ثُوغَا إِتّْبَارّحْ س ڒخْبَارْ أَصبْحَانْ ن ثْڭلْذِيثْ ن أَربِّي ؤُ س يِيسمْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، تّْوَاسّْغضْصنْ نِيثْنِي، أَمْ يرْيَازنْ أَمْ ثمْغَارِينْ.  
\v 13 شِيمُونْ س يِيخفْ نّسْ عَاوذْ يُومنْ، إِتّْوَاسّغْضصْ ؤُشَا إِقِّيمْ إِضفَّارْ فِيلِيبُّوسْ. ڒَامِي إِژْرَا لْمُوعْجِيزَاثْ ذ ڒعْڒَامَاثْ إِمْغَارنْ إِ إِمْسَارنْ س ؤُفُوسْ نّسْ، إِثبْهثْ، يَارْجفْ.   
\m
\v 14 ؤُمِي سْڒِينْ رُّوسُولْ إِنِّي إِدْجَانْ ذِي ؤُرْشَالِيمْ بلِّي ڒْڭنْسْ ن سَامَارْيَا إِقْبڒْ أَوَاڒْ ن أَربِّي، سّكّنْ غَارْسنْ شِيمْعُونْ بُوطْرُوسْ ذ يُوحَانَّا.  
\v 15 نِيثْنِي هْوَانْ-د غَارْسنْ، ژُّودْجنْ أَسنْ حِيمَا أَذْ طّْفنْ أَرُّوحْ إِقدّْسنْ،  
\v 16 مِينْزِي وَانِيثَا ثُوغَا عَاذْ وَارْ د-يُوسِي خْ ؤُڒَا ذ إِجّْ زَّايْسنْ، ثُوغَا تّْوَاسّْغضْصنْ وَاهَا س يِيسمْ ن سِيذِي يَاسُوع.  
\v 17 خنِّي سَّارْسنْ خَاسنْ إِفَاسّنْ ؤُشَا نِيثْنِي طّْفنْ أَرُّوحْ إِقدّْسنْ. \x ◘ \xo 8:‏17 \xt ڒخ. 6‏:‏6؛ 13‏:‏3؛ 19‏:‏6؛ 1 تِيم. 4‏:‏14؛ 5‏:‏22؛ 2 تِيم. 1‏:‏6. \x*   
\m
\v 18 ؤُمِي إِژْرَا شِيمُونْ بلِّي س ؤُسَارْسِي ن إِفَاسّنْ ن رُّوسُولْ إِمّوْشْ أَسنْ أَرُّوحْ إِقدّْسنْ، خنِّي إِخْسْ أَذْ أَسنْ إِوْشْ \add ثْمنْيَاثْ ن\add* نُّوقَارْثْ،  
\v 19 إِنَّا: ”أوْشْ أَيِي عَاوذْ صُّولْطَا-يَا، حِيمَا مَانْ ونْ إِ خْ غَا سَّارْسغْ أَفُوسْ إِنُو، أَذْ إِقْبڒْ أَرُّوحْ إِقدّْسنْ.“  
\v 20 \add مَاشَا\add* إِنَّا أَسْ شِيمْعُونْ بُوطْرُوسْ: ”أَذْ ثتّحَّا نُّوقَارْثْ نّشْ أَكِيذكْ، مِينْزِي إِتّْغِيڒْ أَشْ أَذْ ثْكسْبذْ ثَاوْهِيبْثْ ن أَربِّي س وَاڭْڒَا ن دُّونشْثْ! \x ◘ \xo 8:‏20 \xt مت. 10‏:‏8. \x*  
\v 21 وَارْ غَاركْ بُو ثسْغَارْثْ ؤُڒَا ذ شَا ذِي لْ-إِيمَانْ وَانِيثَا، مِينْزِي ؤُڒْ نّشْ وَارْ إِدْجِي إِسڭّذْ زَّاثْ إِ أَربِّي.  
\v 22 ثُوبْ زِي ثُوعفّْنَا نّشْ ؤُشَا تَّارْ زِي أَربِّي مَاحنْذْ أَذْ خَاكْ ثتّْوَاغْفَارْ ثحْرَايْمشْثْ-أَ ن وُوڒْ نّشْ،  
\v 23 مِينْزِي تّْوَاڒِيغْ أَقَا شكْ ثوْضِيذْ-د ذڭْ إِجّْ ن ؤُحْرِيرْ ذ أَمرْزَاڭْ ؤُ ذڭْ إِجّْ ن ؤُشذِّي ن ثُوعفّْنَا.“  
\v 24 يَارَّا-د شِيمُونْ، إِنَّا: ”تَّارمْ إِ أَربِّي خَافِي حِيمَا وَارْ د-إِتِّيسْ خَافِي شَا زِي مِينْ ثنَّامْ.“   
\m
\v 25 أَوَارْنِي ڒَامِي شهْذنْ شِيمْعُونْ ذ يُوحَانَّا ؤُ سّْڒمْذنْ أَوَاڒْ ن أَربِّي،عقْبنْ غَارْ ؤُرْشَالِيمْ، بَارّْحنْ س ڒخْبَارْ أَصبْحَانْ ذڭْ وَاطَّاسْ ن ڒذْشُورْ ن إِسَامَارِييّنْ.   
\b  
\m  
\s1 أَسغْضَاصْ ن ڒوْزِيرْ زِي ثمُّورْثْ ن كُوشْ  
\m
\v 26 ؤُشَا لْمَالَاكْ ن سِيذِي إِسِّيوڒْ أَكْ-ذ فِيلِيبُّوسْ، إِنَّا: ”كَّارْ، ثْرُوحذْ غَارْ لْجَانُوبْ ذڭْ وبْرِيذْ نْ ڒخْڒَا إِ د-إِهْوَانْ زِي ؤُرْشَالِيمْ غَارْ غَازَّا.“  
\v 27 إِكَّارْ إِرُوحْ، ؤُشَا إِمّڒْقَا أَكْ-ذ إِجّْ ن ڒوْزِيرْ زِي \add ثمُّورْثْ ن\add* كُوشْ، إِجّْ ن ڒوْزِيرْ ن كَانْذَاكِي، ثَاجدْجِيذْثْ ن أَيْثْ ن كُوشْ. ثُوغَا-ث غَارسْ صُّولْطَا خْ مَارَّا ڒكْنُوزْ نّسْ، يُوسَا-د غَارْ ؤُرْشَالِيمْ حِيمَا أَذْ \add ذِينْ\add* إِعْبذْ. \f ◼ \fr 8:‏27 \ft \+bd ’ثَامُّورْثْ ن كُوشْ‘\+bd* - ذڭْ وُوسَّانْ نِّي ثُوغَا ثَامُّورْثْ ن كُوشْ ثسّْوِيژّضْ إِخفْ نّسْ زِي ثمُّورْثْ ن إِثِييُوبِييَا ذ سُّوذَانْ أَڒْ ثَامُّورْثْ ن مِيصْرَا.\f*  
\v 28 ؤُمِي د-إِعْقبْ، إِقِّيمْ خْ إِجّْ ن ؤُكَارُّو، إِقَّارْ \add ذڭْ وذْلِيسْ\add* ن ؤُنَابِي إِشَاعْيَا.   
\m
\v 29 \add خنِّي\add* إِنَّا أَرُّوحْ إِ فِيلِيبُّوسْ: ”زِيذْ، ثْمُونذْ أَكْ-ذ ؤُكَارُّو-يَا.“  
\v 30 إِقَارّبْ-د \add غَارسْ\add* فِيلِيبُّوسْ، إِسْڒَا أَسْ مِينْ إِقَّارْ \add زڭْ وذْلِيسْ\add* ن ؤُنَابِي إِشَاعْيَا، إِنَّا أَسْ: ”مَا ثْفهْمذْ مِينْ ثقَّارذْ؟“  
\v 31 إِنَّا أَسْ: ”مَامّشْ زمَّارغْ أَذْ فهْمغْ مَاڒَا وَارْ ذِينْ حذْ إِ ذ أَيِي غَا إِسّفْهمنْ؟“ ؤُشَا إِتَّارْ زِي فِيلِيبُّوسْ مَاحنْذْ أَذْ ينْيَا ؤُشَا أَذْ كِيسْ إِقِّيمْ.  
\v 32 ؤُذمْ إِ ثُوغَا إِقَّارْ زڭْ وذْلِيسْ ذ وَا:  
\b  
\m \qt ”أَمشْنَاوْ إِزْمَارْ إِتّْوَانْذهْ\qt*  
\m \qt غَارْ ڒْڭُورْنثْ إِ ثْغَارْصْثْ،\qt*  
\m \qt أَمشْنَاوْ ثخْسِي ثڭْنُو\qt*  
\m \qt قِيبَاتْشْ إِ ونِّي ت إِدْجَاسنْ،\qt*  
\m \qt وَارْ يَارْزِيمْ نتَّا أَقمُّومْ نّسْ.\qt* \x ◘ \xo 8:‏32 \xt إِشا. 53‏:‏7‏-‏8\x*   
\m
\v 33 \qt ذڭْ ؤُسحْقَارْ نّسْ إِتّْوَاكّسْ\qt*  
\m \qt زِي ثْمحْبَاسْثْ ؤُ زِي ڒْحُوكْمْ.\qt*  
\m \qt وِي غَا إِعَاوْذنْ خْ دُّورِييثْ نّسْ؟\qt*  
\m \qt مِينْزِي ثُوذَارْثْ نّسْ ثتّْوَاسّْڭعّذْ\qt*  
\m \qt زِي ثمُّورْثْ.“\qt*   
\b  
\m
\v 34 يَارَّا-د ڒوْزِيرْ خْ فِيلِيبُّوسْ، إِنَّا: ”أَذْ شكْ سّقْسِيغْ، خْ وِي خفْ إِسَّاوَاڒْ ؤُنَابِي مَانْ أَيَا، مَا خْ يِيخفْ نّسْ نِيغْ خْ إِجّنْ نّغْنِي؟“  
\v 35 يَارْزمْ فِيلِيبُّوسْ أَقمُّومْ نّسْ، ؤُشَا إِبْذَا إِتّْبَارّحْ أَسْ س ڒخْبَارْ أَصبْحَانْ ن سِيذِيثْنغْ يَاسُوع س وَاوَاڒْ-أَ زِي ثِيرَا \add إِقدّْسنْ\add*. \x ◘ \xo 8:‏35 \xt لك. 24‏:‏45. \x*   
\m
\v 36 أَمْ ثُوغَا ڭُّورنْ نِيثْنِي ذڭْ وبْرِيذْ، إِوْضنْ غَارْ إِجّْ ن ومْشَانْ مَانِي ثُوغَا دْجَانْ وَامَانْ. إِنَّا ڒوْزِيرْ: ”خْزَارْ، أَقَا ذِينْ أَمَانْ. مِينْ ذَايِي إِطّْفنْ وَارْ تّْوَاسّغْضَاصغْ؟“ \x ◘ \xo 8:‏36 \xt ڒخ. 10‏:‏47. \x*  
\v 37 إِنَّا فِيلِيبُّوسْ: ”مَاڒَا ثُومْنذْ س وُوڒْ نّشْ مَارَّا، ثْحدْجڒْ!“ ؤُشَا نتَّا يَارَّا-د، إِنَّا: ”ؤُمْنغْ أَقَا يَاسُوع لْمَاسِيحْ ذ مِّيسْ ن أَربِّي.“  
\v 38 يُومُورْ أَذْ إِبدّْ ؤُكَارُّو، هْوَانْ ثْنَاينْ إِذْسنْ ذڭْ وَامَانْ ؤُشَا فِيلِيبُّوسْ إِسّغْضصْ ڒوْزِيڒْ.  
\v 39 أَڒَامِي د-ڭعّْذنْ زڭْ وَامَانْ، إِخْضفْ أَرُّوحْ ن سِيذِي فِيلِيبُّوسْ. ؤُشَا ڒوْزِيرْ وَارْ ث إِژْرِي عَاذْ، مَاشَا إِرُوحْ ذڭْ وبْرِيذْ نّسْ س ڒفْرَاحثْ.  
\v 40 مَاشَا فِيلِيبُّوسْ إِتّْوَافْ ذِي أَشْذُوذْ ؤُ سّنِّي إِتّْشُوقَا \add ذِي ثمُّورْثْ\add*، إِتّْبَارّحْ س ڒخْبَارْ أَصبْحَانْ ذِي مَارَّا ثِيندَّامْ أَڒَامِي د-يِيوضْ غَارْ قَايْصَارِييَا.   
\b  
\b  
\m  
\c 9
\s1 شَاوُولْ ذڭْ وبْرِيذْ غَارْ ذِيمَاشْقْ  
\m
\v 1 مَاشَا شَاوُولْ ثُوغَا \add عَاذْ\add* إِتّْسُوضْ س ؤُعذِّي ذ ڒْموْثْ ضِيدّْ ن إِمحْضَارنْ ن سِيذِيثْنغْ. \x ◘ \xo 9:‏1 \xt ڒخ. 8‏:‏3؛ 22‏:‏4؛ 26‏:‏9؛ 1 كُور. 15‏:‏9؛ ڭال. 1‏:‏13؛ 1 تِيم. 1‏:‏13. \x*  
\v 2 إِتَّارْ زڭْ أَرَّايْسْ ن إِكهَّاننْ ثِيبْرَاثِينْ إِ ثمْزِيذَاوِينْ ن ذِيمَاشْقْ، مَاحنْذْ، مَاڒَا يُوفَا شَا ن يِينِّي إِضفَّارنْ ’أَبْرِيذْ-أَ‘، إِرْيَازنْ نِيغْ ثِيمْغَارِينْ، إِزمَّارْ أَذْ ثنْ إِشدّْ ؤُ أَذْ ثنْ د-إِنْذهْ غَارْ ؤُرْشَالِيمْ.   
\m
\v 3 ڒَامِي \add ذِينْ\add* إِرُوحْ، إِمْسَارْ، أَمْ ثُوغَا إِتّْقَارَّابْ غَارْ ذِيمَاشْقْ، ثَاڒْغَا-د خَاسْ ذغْيَا إِشْثْ ن ثْفَاوْثْ زڭْ ؤُجنَّا. \x ◘ \xo 9:‏3 \xt ڒخ. 22‏:‏6؛ 26‏:‏31؛ 1 كُور. 15‏:‏8؛ 2 كُور. 12‏:‏2. \x*  
\v 4 إِوْضَا غَارْ ثمُّورْثْ، خنِّي إِسْڒَا إِ يِيشْثْ ن ثْمِيجَّا ثقَّارْ أَسْ: ”شَاوُولْ، شَاوُولْ مَايمِّي خَافِي ثْذَارَّاشذْ؟ ثْزيَّارذْ خْ يِيخفْ نّشْ ؤُمِي ثشَّاثذْ ذِي سْڒكْ ن بُويْكُوشْضَانْ.“  
\v 5 يَارَّا-د، إِنَّا: ”مِينْ ثعْنِيذْ شكْ، أَ سِيذِي؟“ إِنَّا أَسْ سِيذِيثْنغْ: ”أَقَا ذ نشّْ، يَاسُوع ونِّي خْ ثْذَارّْشذْ. \x ◘ \xo 9:‏5 \xt ڒخ. 5‏:‏39. \x*  
\v 6 كَّارْ، ثُوذْفذْ غَارْ ثنْذِينْثْ، أَذْ أَشْ إِتّْوَانَّا ذِينِّي مِينْ إِتّْخصَّا أَذْ ثڭّذْ!“ \x ◘ \xo 9:‏6 \xt لك. 3‏:‏10؛ ڒخ. 2‏:‏37؛ 16‏:‏30. \x*  
\v 7 ؤُشَا إِرْيَازنْ إِنِّي كِيسْ إِسَافَارنْ، بدّنْ تّْبهْثنْ، مِينْزِي نِيثْنِي سْڒِينْ ثْمِيجَّا، مَاشَا وَارْ ژْرِينْ حذْ. \x ◘ \xo 9:‏7 \xt دَان. 10‏:‏7. \x*   
\m
\v 8 إِكَّارْ-د شَاوُولْ زِي ثمُّورْثْ، وَاخَّا أَرْزْمنْثْ ثِيطَّاوِينْ نّسْ وَارْ إِزمَّارْ أَذْ إِتّْوَاڒَا، ؤُ نِيثْنِي ڭوّْذنْ ث زڭْ ؤُفُوسْ، نذْهنْ ث غَارْ ذِيمَاشْقْ.  
\v 9 ثْڒَاثَا ن وُوسَّانْ ثُوغَا وَارْ إِتّْوِيڒِي، وَارْ إِشِّي، وَارْ إِسْوِي.   
\m
\v 10 ثُوغَا \add ذِينْ\add* ذِي ذِيمَاشْقْ إِجّْ ن ؤُمحْضَارْ قَّارنْ أَسْ أَنَانِييَاسْ. سِيذِي إِنَّا أَسْ ذڭْ إِجّْ ن ڒوْحِييْ: ”\add أَ\add* أَنَانِييَاسْ!“ إِنَّا أَسْ: ”أَقَا أَيِي ذَا، \add أَ\add* سِيذِي إِنُو!“  
\v 11 إِنَّا أَسْ سِيذِيثْنغْ: ”كَّارْ، ثْرُوحذْ غَارْ وبْرِيذْ ؤُمِي قَّارنْ ’أَبْرِيذْ إِسّڭّْذنْ‘، خنِّي غَارْ ثَادَّارْثْ ن يَاهُوذَا، سقْسَا خْ إِجّْ ن ورْيَازْ زِي ثَارْسُوسْ، قَّارنْ أَسْ شَاوُولْ، خْزَارْ، أَقَا إِتّْژَادْجْ \add ذِينْ\add*، \x ◘ \xo 9:‏11 \xt ڒخ. 21‏:‏39؛ 22‏:‏3. \x*  
\v 12 ؤُشَا يُوسَا-د غَارسْ ذڭْ إِجّْ ن ڒوْحِييْ، أَقَا إِجّْ ن ورْيَازْ قَّارنْ أَسْ أَنَانِييَاسْ يُوذفْ-د، إِسَّارْسْ خَاسْ أَفُوسْ نّسْ حِيمَا أَذْ تّْوَارْزْمنْثْ ثِيطَّاوِينْ نّسْ.“  
\v 13 يَارَّا-د أَنَانِييَاسْ: ”أَ سِيذِي، أَقَا سْڒِيغْ أَطَّاسْ \add ن ثْمسْڒَايِينْ\add* خْ ورْيَازْ-أَ، مشْحَاڒْ ذ ڒْغَارْ إِ إِڭَّا ذڭْ إِمْقدَّاسنْ نّشْ ذِي ؤُرْشَالِيمْ. \x ◘ \xo 9:‏13 \xt ڒخ. 9‏:‏1؛ 1 كُور. 15‏:‏9؛ ڭال. 1‏:‏13؛ 1 تِيم. 1‏:‏13. \x*  
\v 14 أَقَا ذَا، عَاوذْ ذَانِيثَا غَارسْ تّسْرِيحْ زڭْ \add ؤُغزْذِيسْ\add* ن إِمقّْرَاننْ ن إِكهَّاننْ، مَاحنْذْ أَذْ إِحبّسْ مَارَّا إِنِّي إِتّْڒَاغَانْ خْ يِيسمْ نّشْ.“  
\v 15 \add مَاشَا\add* سِيذِي إِنَّا أَسْ: ”رُوحْ مِينْزِي وَا أَقَا-ث غَارِي ذ ڒْقشْعثْ إِفَارْزنْ حِيمَا أَذْ يَارْبُو إِسمْ إِنُو غَارْ ڒڭْنُوسْ ؤُ غَارْ إِجدْجِيذنْ ؤُ جَارْ أَيْثْ ن إِسْرَائِيل، \x ◘ \xo 9:‏15 \xt ڒخ. 13‏:‏2؛ 22‏:‏21؛ رُوم. 1‏:‏1؛ ڭال. 1‏:‏15؛ 2‏:‏8؛ أَفا. 3‏:‏8؛ 1 تِيم. 2‏:‏7؛ 2 تِيم. 1‏:‏1. \x*  
\v 16 مِينْزِي أَذْ أَسْ سّشْنغْ مشْحَاڒْ إِتّْخصَّا أَسْ أَذْ إِودّبْ ذِي طّْوعْ ن يِيسمْ إِنُو.“ \x ◘ \xo 9:‏16 \xt ڒخ. 21‏:‏11؛ 2 كُور. 11‏:‏23. \x*   
\m
\v 17 إِرُوحْ أَنَانِييَاسْ، يُوذفْ غَارْ ثَادَّارْثْ، إِسَّارْسْ خَاسْ أَفُوسْ نّسْ، إِنَّا: ”\add أَ\add* ؤُمَا شَاوُولْ، أَقَا سِيذِيثْنغْ يَاسُوع، ونِّي ذ أَشْ د-إِضْهَارنْ ذڭْ وبْرِيذْ إِ زِي د-ثُوسِيذْ، إِسّكّْ أَيِي-د، حِيمَا أَذْ ثتّْوَاڒِيذْ عَاوذْ ؤُ أَذْ ثتّْوَاشُّورذْ س أَرُّوحْ إِقدّْسنْ.“ \x ◘ \xo 9:‏17 \xt ڒخ. 22‏:‏12. \x*  
\v 18 ڒخْذنِّي ثوْضَا-د شَا أَمْ ثقْشُورْثْ زِي ثِيطَّاوِينْ نّسْ، تّْوَارْزْمنْثْ ثِيطَّاوِينْ نّسْ. إِكَّارْ ؤُشَا إِتّْوَاسّغْضصْ.   
\b  
\m  
\s1 شَاوُولْ إِبْذَا إِتّْبَارّحْ س ڒخْبَارْ أَصبْحَانْ ذِي ذِيمَاشْقْ  
\m
\v 19 ؤُمِي إِشَّا، إِمْحضْ ؤُشَا إِقِّيمْ شَا ن وُوسَّانْ أَكْ-ذ إِمحْضَارنْ ذِي ذِيمَاشْقْ.  
\v 20 ڒخْذنِّي إِبْذَا إِتّْبَارّحْ ذِي ثمْزِيذَا ن وُوذَاينْ خْ يَاسُوع، بلِّي نتَّا ذ مِّيسْ ن أَربِّي.  
\v 21 مَارَّا إِنِّي ثُوغَا إِتّسْڒَانْ، تّْبهْثنْ، قَّارنْ: ”مَا وَارْ إِدْجِي ذ وَانِيثَا إِ ثُوغَا إِمَارّْثنْ مَارَّا إِنِّي ثُوغَا إِتّْڒَاغَانْ س يِيسمْ-أَ ذِي ؤُرْشَالِيمْ، ؤُ \add مَا وَارْ إِدْجِي ذ وَانِيثَا\add* إِ د-إِتّْوَاسّكّنْ عَاذْ ذَانِيثَا زِي سِّيبّثْ ذ إِشْثْ، مَاحنْذْ أَذْ ثنْ إِشَارْفْ ؤُ أَذْ ثنْ إِڭوّذْ غَارْ إِمقّْرَاننْ ن إِكهَّاننْ؟“  
\v 22 شَاوُولْ ثُوغَا يَارنِّي ذِي جّهْذْ، إِسّذْهشْ ؤُذَاينْ إِنِّي إِزدّْغنْ ذِي ذِيمَاشْقْ أَمْ ذ أَسنْ إِسّْشنْ بلِّي \add يشُّو\add* وَانِيثَا ذ لْمَاسِيحْ.   
\m
\v 23 ؤُمِي عْذُونْ وُوسَّانْ، ڭِّينْ وُوذَاينْ إِجّْ ن ونْوَايْ س ثحْرَايْمشْثْ حِيمَا أَذْ ث نْغنْ.  
\v 24 مَاشَا ثَاحِيڒثْ نْسنْ إِ زِي ثُوغَا أَرزُّونْ أَذْ ث نْغنْ، ثتّْوَاسَّارْڭبْ إِ شَاوُولْ. \add مَاشَا\add* نِيثْنِي ثُوغَا حطَّانْ ثِيوُّورَا \add ن ثنْذِينْثْ\add* س ؤُزِيڒْ ذ دْجِيڒثْ، مَاحنْذْ أَذْ أَوْضنْ أَذْ ث نْغنْ. \x ◘ \xo 9:‏24 \xt 2 كُور. 11‏:‏32. \x*  
\v 25 مَاشَا إِمحْضَارنْ نّسْ ڭِّينْ ث ذڭْ إِشْثْ ن ثْسُودْجثْ ؤُشَا سّهْوَانْ ث زِي ڒْحِيضْ س دْجِيڒثْ. \x ◘ \xo 9:‏25 \xt ياش. 2‏:‏15؛ 1 صم. 19‏:‏12. \x*   
\b  
\m  
\s1 شَاوُولْ ذِي ؤُرْشَالِيمْ  
\m
\v 26 يُويُورْ نتَّا غَارْ ؤُرْشَالِيمْ، يَارْزُو أَذْ إِمُونْ أَكْ-ذ إِمحْضَارنْ، مَاشَا نِيثْنِي مَارَّا ڭّْوذنْ زَّايسْ، وَارْ تِّيقّنْ شَا بلِّي نتَّا \add إِذْوڒْ\add* ذ أَمحْضَارْ. \x ◘ \xo 9:‏26 \xt ڒخ. 22‏:‏17. \x*  
\v 27 مَاشَا بَارْ-نَابَا إِكْسِي ث غَارسْ ؤُشَا إِنْذهْ إِ-ث غَارْ رُّوسُولْ ؤُشَا \add شَاوُولْ\add* إِخبَّارْ إِ-ثنْ مَامّشْ إِژْرَا سِيذِي ذڭْ وبْرِيذْ ؤُ مَامّشْ كِيسْ إِسِّيوڒْ ؤُ مَامّشْ ثُوغَا إِتّْبَارّحْ س ثرْيَاسْثْ س يِيسمْ ن يَاسُوع ذِي ذِيمَاشْقْ. \x ◘ \xo 9:‏27 \xt ڒخ. 11‏:‏25. \x*  
\v 28 ثُوغَا إِقِّيمْ أَكِيذْسنْ إِتَّاذفْ إِتّفّغْ زِي ؤُرْشَالِيمْ،  
\v 29 ؤُشَا إِتّْبَارّحْ س ثرْيَاسْثْ س يِيسمْ ن يَاسُوع، إِتّْقَاشَاحْ أَكْ-ذ وُوذَاينْ إِنِّي إِسّْننْ \add إِڒسْ ن\add* ثْيُونَانِيثْ، مَاشَا نِيثْنِي أَرْزُونْ أَذْ ث نْغنْ.  
\v 30 ؤُمِي سّْننْ ثَاوْمَاثْ مَانْ أَيَا، نذْهنْ ث غَارْ قَايْصَارِييَا ذِي دْجِيڒثْ ؤُشَا سكّنْ ث سّنِّي غَارْ ثَارْسُوسْ.   
\m
\v 31 ثَامسْمُونْثْ ذِي مَارَّا يَاهُوذِييَّا ذ لْجَالِيلْ ذ سَامَارْيَا ثُوغَا ذَايسْ ڒهْنَا، ثتّْوَابْنَا \add ذِي لْ-إِيمَانْ\add*، ثڭُّورْ ذِي ثِيڭّْوُوذِي ن أَربِّي ؤُشَا ثْرُوحْ ذِي ثْيُومِي س ؤُفوّجْ ن أَرُّوحْ إِقدّْسنْ.   
\b  
\m  
\s1 أَسْڭنْفِي ن أَنِييَاسْ  
\m
\v 32 ڒَامِي ثُوغَا شِيمْعُونْ إِڭُّورْ ذِي ثْندَّامْ، إِهْوَا-د غَارْ إِمْقدَّاسنْ إِنِّي إِزدّْغنْ ذِي ثنْذِينْثْ ن لِيدَّا.  
\v 33 يُوفَا ذِينْ إِجّْ ن بْنَاذمْ، قَّارنْ أَسْ أَنِييَاسْ، إِزّڒْ س ثَاسُّوثْ ؤُ ثعْذُو خَاسْ ثْمنْيَا ن إِسڭّْوُوسَا ذ أَنعْضَابْ.  
\v 34 إِنَّا أَسْ شِيمْعُونْ: ”\add أَ\add* أَنِييَاسْ، يَاسُوع لْمَاسِيحْ أَذْ شكْ إِسّْڭنْفَا. كَّارْ، ثسُّوذْ إِ إِخفْ نّشْ!“ ڒخْذنِّي إِكَّارْ ذغْيَا.  
\v 35 ؤُشَا ژْرِينْ ث مَارَّا إِمزْذَاغْ ن لِيدَّا ذ سَارُونْ، ؤُشَا ذوْڒنْ-د غَارْ أَربِّي.   
\b  
\m  
\s1 أَسْنكَّارْ ن ثَابِيثَا  
\m
\v 36 ثُوغَا ذِي ثنْذِينْثْ ن يَافَّا إِشْثْ ن ثْمحْضَارْثْ، قَّارنْ أَسْ ثَابِيثَا، \add مَاشَا س يِيڒسْ ن ثْيُونَانِيثْ قَّارنْ أَسْ ’ذُورْكَا‘، إِخْسْ أَذْ يِينِي ’غَازَالَا‘\add*. ثَا ثُوغَا ثشُّورْ س ڒخْذَايمْ ثِيصبْحَانِينْ إِ ثُوغَا ثتّڭّْ ؤُ س صّْذَاقِي \add إِ ثُوغَا ثسُّوفُّوغْ\add*.  
\v 37 ذڭْ وُوسَّانْ نِّي ثهْڒشْ ؤُشَا ثمُّوثْ. سِيرْذنْ ت ؤُشَا سَّارْسنْ ت ذِي ثْغُورْفثْ.  
\v 38 مَاشَا إِمحْضَارنْ سْڒِينْ بلِّي شِيمْعُونْ أَقَا-ث ذِي ثنْذِينْثْ ن لِيدَّا، ثنِّي زَّاثْ ن يَافَّا. \add خنِّي\add* سّكّنْ نِيثْنِي ثْنَاينْ ن يرْيَازنْ حِيمَا أَذْ زَّايسْ حشّْمنْ، حِيمَا وَارْ إِتّْعطَّاڒْ مَاحنْذْ أَذْ كِيذْسنْ يُويُورْ!  
\v 39 إِكَّارْ شِيمْعُونْ، يُويُورْ أَكِيذْسنْ. ڒَامِي د-يِيوضْ، نذْهنْ ث غَارْ ثْغُورْفثْ سنّجْ. بدّنْثْ-إِ-د غَارسْ مَارَّا ثِيجَّاڒْ، رُونْثْ، سّْشَاننْثْ أَسْ ثْشَامِيرَاثْ ذ إِجدْجَابنْ إِ ذ أَسنْثْ ثوْشَا ثَابِيثَا أَڒَامِي ثُوغَا-ت عَاذْ ثدَّارْ. \f ◼ \fr 9:‏39 \ft \+bd ’ذُورْكَا‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’غَازَالَا‘.\f*   
\m
\v 40 مَاشَا شِيمْعُونْ إِسُّوفّغْ إِ-ثنْثْ مَارَّا غَارْ بَارَّا، إِسْجذْ، إِژُّودْجْ ؤُشَا إِنّقْڒبْ-د غَارْ ڒْخشْبثْ إِنَّا: ”ثَابِيثَا، كَّارْ!“ نتَّاثْ ثَارْزمْ ثِيطَّاوِينْ نّسْ ؤُشَا ڒَامِي ثژْرَا شِيمْعُونْ، ثقِّيمْ.  
\v 41 إِسّْوِيژّضْ غَارسْ أَفُوسْ نّسْ، إِسّْنكَّارْ إِ-ت-إِ-ذ، خنِّي إِڒَاغَا-د خْ إِمْقدَّاسنْ ذ ثِيجَّاڒْ، إِسّْشنْ أَسنْ ت، بلِّي أَقَا ثدَّارْ.   
\m
\v 42 إِفّغْ-د ڒخْبَارْ-أَ غَارْ ثنْذِينْثْ مَارَّا ؤُشَا أَطَّاسْ ؤُمْننْ ذِي سِيذِيثْنغْ.  
\v 43 ؤُشَا إِقِّيمْ ذِي يَافَّا، وَارْ إِدْجِي ذْرُوسْ ن وُوسَّانْ، غَارْ إِجّْ ن ورْيَازْ نِّي ثُوغَا إِعدّڒْ إِڒْمَاونْ، قَّارنْ أَسْ شِيمْعُونْ.   
\b  
\b  
\m  
\c 10
\s1 پُوطْرُوسْ ذ ڒْقبْطَانْ أَرُومَانِي كُورْنِيلِييُوسْ  
\m
\v 1 ثُوغَا ذِي قَايْصَارِييَا إِجّْ ن ورْيَازْ، إِسمْ نّسْ كُورْنِيلِييُوسْ، أَقَا-ث ذ ڒْقبْطَانْ \add خْ مْيَا\add*، إِنِّي زِي ڒْكُومْبَانِييّثْ ؤُمِي قَّارنْ ’أَطَالْيَانْ‘.  
\v 2 نتَّا ثُوغَا إِتّْوقَّارْ ؤُ إِتّڭّْوذْ أَربِّي أَكْ-ذ أَيْثْبَابْ ن ثَادَّارْثْ نّسْ مَارَّا، إِتِّيشْ أَطَّاسْ ن صّْذَاقِي إِ إِوْذَانْ ؤُشَا إِكسِّي س ڒْمعْرُوفْ إِ أَربِّي ڒبْذَا.  
\v 3 وَا إِژْرَا ذڭْ إِجّْ ن ڒوْحِييْ إِصْفَا أَقَا إِجّْ ن لْمَالَاكْ ن أَربِّي يُوذفْ-د غَارسْ غَارْ ثْسَاعّثْ وِيسّْ ثسْعَا ن وَاسّْ، \add إِخْسْ أَذْ يِينِي غَارْ ثْسَاعّثْ وِيسّْ ثْڒَاثَا ن ؤُزِيڒْ\add*، إِنَّا أَسْ: ”\add أَ\add* كُورْنِيلِييُوسْ!“  
\v 4 ؤُمِي ذَايسْ إِنْضَارْ ثِيطَّاوِينْ نّسْ، إِڭّْوذْ أَطَّاسْ، إِنَّا: ”مِينْ ذِينْ، أَ سِيذِي؟“ إِنَّا أَسْ لْمَالَاكْ: ”ثِيژَادْجِيثِينْ نّشْ ذ صّْذَاقِي نّشْ إِوْضنْثْ غَارْ ڒِيذَارثْ زَّاثْ إِ \add وُوذمْ ن\add* أَربِّي.  
\v 5 سّكّْ ڒخُّو إِرْيَازنْ غَارْ يَافَّا، ثْعَارْضذْ خْ شِيمْعُونْ، ونِّي ؤُمِي قَّارنْ عَاوذْ بُوطْرُوسْ.  
\v 6 خْزَارْ، نتَّا يَارْزفْ غَارْ شِيمْعُونْ، ونِّي إِعدّْڒنْ إِڒْمَاونْ، ونِّي غَارْ إِدْجَا ثَادَّارْثْ غَارْ ثْمَا ن ڒبْحَارْ.“  
\v 7 ؤُمِي إِرُوحْ لْمَالَاكْ ونِّي ثُوغَا أَكِيذسْ إِسَّاوَاڒنْ، إِڒَاغَا نتَّا خْ ثْنَاينْ ن إِمْسخَّارنْ زِي ثَادَّارْثْ نّسْ ؤُ خْ إِجّْ ن ؤُعسْكَارِي إِتّڭّْوذنْ أَربِّي، ونِّي ثُوغَا إِطَاعْ أَسْ.  
\v 8 إِهَاجَا أَسنْ مَارَّا مِينْ إِژْرَا ؤُشَا إِسّكّْ إِ-ثنْ غَارْ يَافَّا.   
\m
\v 9 ثِيوشَّا نّسْ، أَمْ ثُوغَا أَثنْ ذڭْ وبْرِيذْ تّْقَارَّابنْ غَارْ ثنْذِينْثْ، إِڭعّذْ شِيمْعُونْ خْ ثْزقَّا غَارْ ثْسَاعّثْ وِيسّْ ستَّا، \add أَقَا-ت ذ ضّْهُورْ\add*، حِيمَا أَذْ إِژَّادْجْ. \x ◘ \xo 10:‏9 \xt 2 إِج. 4‏:‏33؛ مت. 6‏:‏6. \x*  
\v 10 إِدْجُوژْ أَطَّاسْ ؤُشَا ثُوغَا إِمّژْرِي أَذْ إِشّْ، ؤُشَا، أَمْ ثُوغَا ذ أَسْ سّوْجَاذنْ، إِوْيِي ث ڒوْحِييْ.  
\v 11 إِژْرَا أَجنَّا يَارْزمْ ؤُشَا إِشْثْ ن ڒْقشْعثْ أَمْ يِيشْثْ ن ثْشُوقّثْ ثَامقّْرَانْثْ زِي ڒقْطنْ \add أَزْذَاذْ\add* إِتّْوَاطّْفنْ زِي أَربْعَا ن ثْغمُّورَا نّسْ، ثهْوَا-د زڭْ ؤُجنَّا غَارْ ثمُّورْثْ.  
\v 12 ثُوغَا ذَايسْ مَارَّا إِمُودَّارنْ ن ثمُّورْثْ س أَربْعَا ن إِضَارنْ ؤُڒَا ذ إِمُودَّارنْ نِّي إِتّْبُوعنْ خْ ثمُّورْثْ ذ إِجْضَاضْ ن ؤُجنَّا. \f ◼ \fr 10:‏12 \ft \+bd ’إِمُودَّارنْ‘\+bd* - نِيغْ ’لْحَايَاوَانَاثْ‘.\f*  
\v 13 ثُوسَا-د غَارسْ إِشْثْ ن ثْمِيجَّا، ثقَّارْ أَسْ-د: ”\add أَ\add* شِيمْعُونْ، كَّارْ، غَارْصْ، ثشّذْ!“  
\v 14 مَاشَا شِيمْعُونْ إِنَّا: ”لَّ، \add أَ\add* سِيذِي، وَارْ شِّيغْعمَّارْصْ مِينْ إِدْجَانْ ذ ڒحْرَامْ ؤُڒَا مِينْ وَارْ إِزْذِيڭنْ.“ \x ◘ \xo 10:‏14 \xt لَاوِي 11‏:‏4؛ أَعَوذ. 14‏:‏7. \x*  
\v 15 ثْمِيجَّا \add ثسِّيوڒْ\add* غَارسْ عَاوذْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ، \add ثقَّارْ\add*: ”مِينْ إِسِّيزْذڭْ أَربِّي، وَارْ د ث ثتَّارِّيذْ شَا شكْ ذ ڒحْرَامْ.“ \x ◘ \xo 10:‏15 \xt مت. 15‏:‏11؛ رُوم. 14‏:‏17، 20؛ 1 تِيم. 4‏:‏4؛ ثِيث. 1‏:‏15. \x*  
\v 16 مَانْ أَيَا إِمْسَارْ ثْڒَاثَا ن إِمُوڒنْ، ؤُشَا ذغْيَا ثتّْوَاسّْڭعّذْ ثَاجَارْثِيڒْثْ \add عَاوذْ\add* غَارْ ؤُجنَّا.   
\m
\v 17 أَمْ ثُوغَا شِيمْعُونْ \add عَاذْ\add* إِتّْخَارَّاصْ ذڭْ إِخفْ نّسْ مِينْ إِخْسْ أَذْ يِينِي ڒوْحِييْ إِ إِژْرَا، خْزَارْ، ؤُسِينْ-د ثْنَاينْ ن يرْيَازنْ إِنِّي د-إِتّْوَاسّكّنْ زِي كُورْنِيلِييُوسْ، سّقْسَانْ خْ ثَادَّارْثْ مَانِي ثُوغَا إِقِّيمْ شِيمْعُونْ. نِيثْنِي بدّنْ-د غَارْ ثوَّارْثْ ن ڒمْرَاحْ.  
\v 18 ڒَاغَانْ، سّقْسَانْ: ”مَا شِيمْعُونْ، ؤُمِي تّْكنَّانْ بُوطْرُوسْ، أَقَا-ث ذَانِيثَا؟“   
\m
\v 19 ؤُمِي ثُوغَا شِيمْعُونْ \add عَاذْ\add* إِتّْخَارَّاصْ ذِي ڒوْحِييْ إِ إِژْرَا، إِنَّا أَسْ أَرُّوحْ: ”خْزَارْ، أَقَا ذَا ثْڒَاثَا ن يرْيَازنْ أَرزُّونْ خَاكْ!  
\v 20 كَّارْ، ثهْوِيذْ-د، رُوحْ أَكِيذْسنْ بْڒَا مَا أَذْ ثْشكّذْ ذِي شَا، مِينْزِي ذ نشّْ إِ-ثنْ-د-إِسّكّنْ.“  
\v 21 \add ڒخْذنِّي\add* إِهْوَا شِيمْعُونْ غَارْ يرْيَازنْ نِّي، إِنَّا أَسنْ: ”خْزَارْ، أَقَا ذ نشّْ ونِّي خفْ ثَارزُّومْ. مِينْ غَارْ د-ثُوسِيمْ ذَا؟“  
\v 22 نَّانْ أَسْ: ”كُورْنِيلِييُوسْ، إِجّْ ن ڒْقبْطَانْ خْ مْيَا ذ إِجّْ ن ورْيَازْ إِسڭّذْ إِتّڭّْوذْ أَربِّي، ونِّي خفْ إِشهّذْ مْلِيحْ مَارَّا ڒْڭنْسْ ن وُوذَاينْ، أَقَا إِجّْ ن لْمَالَاكْ إِقدّْسنْ ثُوغَا إِعْڒمْ أَسْ ذڭْ إِجّْ ن ڒوْحِييْ، مَاحنْذْ أَذْ د-إِسّكّْ غَاركْ، حِيمَا أَذْ شكْ د-أَيْوْينْ غَارْ ثَادَّارْثْ نّسْ، \add مَاحنْذْ\add* أَذْ زَّايكْ إِسڒْ إِشْثْ ن ثبْرَاثْ.“  
\v 23 شِيمْعُونْ إِسِّيذفْ إِ-ثنْ غَارْ ذَاخڒْ، إِڭَّا ثنْ ذ إِنوْجِيونْ مَانِي إِقِّيمْ. ثِيوشَّا نّسْ إِكَّارْ، إِرُوحْ أَكِيذْسنْ ؤُ شَا ن وَاوْمَاثنْ إِنِّي إِدْجَانْ زِي يَافَّا رُوحنْ أَكِيذسْ.   
\m
\v 24 ثِيوشَّا نّسْ أَوَارْنِي أَسْ إِوْضنْ غَارْ قَايْصَارِييَا. كُورْنِيلِييُوسْ ثُوغَا إِتّْرَاجَا ثنْ أَمْ سّْمُونَانْ غَارسْ مَارَّا أَيْثْبَابْ ن ڒَادْجْ نّسْ ؤُڒَا ذ إِمدُّوكَّاڒْ إِ-ث-إِ-د-يُوذْسنْ أَطَّاسْ.  
\v 25 ؤُمِي يُوذفْ شِيمْعُونْ، إِڒْقَا ث-إِ-د كُورْنِيلِييُوسْ، إِوْضَا أَسْ غَارْ إِضَارنْ ؤُشَا إِسْجذْ أَسْ.  
\v 26 \add مَاشَا\add* إِسّْنكَّارْ إِ-ث-إِ-د شِيمْعُونْ، إِنَّا أَسْ: ”كَّارْ، أَقَا ؤُڒَا ذ نشّْ ذ بْنَاذمْ \add أَمْ شكْ\add*!“ \x ◘ \xo 10:‏26 \xt ڒخ. 14‏:‏14؛ أَسَا. 19‏:‏10؛ 22‏:‏9. \x*  
\v 27 أَمْ كِيذسْ إِسَّاوَاڒْ، يُوذفْ ؤُشَا يُوفَا ذِينْ أَطَّاسْ إِنِّي د-يُوسِينْ \add تّْمُونَانْ\add* ذِينِّي.  
\v 28 إِنَّا أَسنْ: ”كنِّيوْ ثسّْنمْ أَقَا وَارْ إِحدْجرْ خْ ورْيَازْ ذ ؤُذَايْ أَذْ إِمُونْ أَكْ-ذ إِجّْ ن ؤُبَارَّانِي إِ وَارْ د-إِقَّارْصنْ زِي ثقْبِيتْشْ ن ڒْڭنْسْ نّسْ. مَاشَا أَربِّي إِسّْشنْ أَيِي بلِّي وَارْ إِشُووَّارْ أَذْ ڒَاغِيغْ ؤُڒَا خْ إِجّْ ن بْنَاذمْ إِخْمجْ نِيغْ ذ ڒحْرَامْ. \x ◘ \xo 10:‏28 \xt ؤُف. 23‏:‏32؛ 34‏:‏15؛ أَعَوذ. 7‏:‏2؛ يُوح. 4‏:‏9؛ 18‏:‏28؛ ڒخ. 11‏:‏3؛ 15‏:‏8؛ أَفا. 3‏:‏6. \x*  
\v 29 س ؤُينِّي ؤُسِيغْ-د عَاوذْ \add ذَا\add* بْڒَا مَا أَذْ شكّغْ ذِي شَا ؤُمِي خَافِي ثْعَارْضذْ. مَاشَا خْسغْ أَذْ كنِّيوْ سّقْسِيغْ، مَايمِّي ذ أَيِي ثجِّيمْ أَذْ د-أَسغْ؟“  
\v 30 إِنَّا أَسْ كُورْنِيلِييُوسْ: ”أَربْعَا ن وُوسَّانْ زڭْ وَامِي ثُوغَا تّْژُومّغْ، ؤُشَا خْزَارْ، غَارْ ثْسَاعّثْ وِيسّْ ثسْعَا ؤُمِي ثُوغَا تّْژَادْجِيغْ ذِي ثَادَّارْثْ إِنُو، أَقَا ذِينْ إِجّْ ن ورْيَازْ إِبدّْ-د قِيبَاتْشْ إِنُو س وَارُّوضْ ذ أَشمْڒَاڒْ!  
\v 31 إِنَّا أَيِي: ’\add أَ\add* كُورْنِيلِييُوسْ، ثَاژَادْجِيثْ نّشْ ثتّْوَاسڒْ ؤُ صّْذَاقِي نّشْ إِوْضنْثْ غَارْ ڒِيذَارثْ ن أَربِّي.“ \x ◘ \xo 10:‏31 \xt مت. 28‏:‏3؛ مك. 16‏:‏5؛ لك. 24‏:‏4. \x*  
\v 32 سكّْ \add إِجّنْ\add* غَارْ يَافَّا، ثْعَارْضذْ خْ شِيمْعُونْ ونِّي ؤُمِي تّْكنَّانْ بُوطْرُوسْ. خْزَارْ، أَقَا نتَّا ذ أَنوْجِيوْ ذِي ثَادَّارْثْ ن شِيمْعُونْ، ونِّي إِعدّْڒنْ إِڒْمَاونْ، ثنِّي غَارْ ثْمَا ن ڒبْحَارْ. نتَّا أَذْ د-يَاسْ ؤُشَا أَذْ كِيذكْ إِسِّيوڒْ.  
\v 33 س ؤُينِّي سّكّغْ-د غَاركْ ڒخْذنِّي ؤُ شكْ أَقَا ثڭِّيذْ مْلِيحْ ؤُمِي د-ثُوسِيذْ ذَا. نشِّينْ مَارَّا إِ ذَا ندْجْ قِيبَاتْشْ إِ شكْ، نتّخْسْ أَذْ نْسڒْ مَارَّا مِينْ زِي شكْ يُومُورْ أَربِّي.“   
\b  
\m  
\s1 أَبَارَّاحْ ن لْ‘إِنْجِيلْ إِ ڒڭْنُوسْ ذ ؤُسْفَارّغْ ن أَرُّوحْ إِقدّْسنْ  
\m
\v 34 يَارْزمْ شِيمْعُونْ أَقمُّومْ نّسْ، إِنَّا: ”س ثِيذتّْ، ؤُفِيغْ بلِّي أَربِّي وَارْ إِتّڭّْ شَا س وُوذْمَاونْ. \x ◘ \xo 10:‏34 \xt أَعَوذ. 10‏:‏17؛ 2 إِم. 19‏:‏7؛ أَيُوبْ 34‏:‏19؛ رُوم. 2‏:‏11؛ ڭال. 2‏:‏6؛ أَفا. 6‏:‏9؛ كُول. 3‏:‏25؛ 1 بُط. 1‏:‏17. \x*  
\v 35 مَاشَا ونِّي ث إِتّڭّْوذنْ ذ ونِّي إِتّڭّنْ ثَاسڭْذَا زِي كُوڒْ ڒْڭنْسْ، يُوسَا-د أَسْ خْ ڒْخَاضَارْ نّسْ.  
\v 36 مَاغَارْ وَا ذ أَوَاڒْ إِ إِسّكّْ غَارْ أَيْثْ ن إِسْرَائِيل ذ ونِّي زِي إِ ذ أَسنْ إِبَارّحْ: ڒهْنَا ذ ڒْهُوذْنثْ س يَاسُوع لْمَاسِيحْ، ونِّي ذ سِيذِي ن مَارَّا. \x ◘ \xo 10:‏36 \xt إِشا. 9‏:‏5؛ 52‏:‏7؛ يُوح. 16‏:‏33؛ رُوم. 5‏:‏1؛ كُول. 1‏:‏20. \x*  
\v 37 كنِّيوْ ثسّْنمْ أَقَا أَوَاڒْ يِيوضْ-د غَارْ مَارَّا يَاهُوذِييَّا، \add أَوَارْنِي ڒَامِي\add* إِبْذَا زِي لْجَالِيلْ أَوَارْنِي إِ ؤُسغْضَاصْ إِ زِي ثُوغَا إِتّْبَارّحْ يُوحَانَّا، \x ◘ \xo 10:‏37 \xt إِشا. 8‏:‏23؛ 9‏:‏1؛ مت. 4‏:‏12؛ مك. 1‏:‏14، 38، 39؛ لك. 4‏:‏14. \x*  
\v 38 \add ڒخْبَارْ\add* زِي جِّيهثْ ن يَاسُوع زِي نَّاصِيرَا، مَامّشْ ث إِذْهنْ أَربِّي س أَرُّوحْ إِقدّْسنْ ؤُ س جّهْذْ. نتَّا إِسَّارَا \add ثَامُّورْثْ\add*، إِڭَّا ڒْخَارْ، إِسّْڭنْفَا إِنِّي إِتّْوَاغزَّانْ زڭْ ؤُمْعفَّانْ مِينْزِي أَربِّي ثُوغَا-ث أَكِيذسْ. \x ◘ \xo 10:‏38 \xt إِزهد. 45‏:‏8؛ إِشا. 61‏:‏1؛ لك. 4‏:‏18. \x*  
\v 39 نشِّينْ ذ ڒشْهُوذْ خَاسْ ؤُ خْ مَارَّا مِينْ إِڭَّا ذِي ثمُّورْثْ ن يَاهُوذِييَّا ؤُ ذِي ؤُرْشَالِيمْ. أَقَا ؤُيْڒنْ ث وُوذَاينْ خْ ثحْنَاشْثْ، نْغِينْ ث.  
\v 40 وَا إِسّْنكَّارْ إِ-ث-إِ-د أَربِّي ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا ؤُشَا إِسّضْهَارْ إِ-ث س بْطَايْطَايْ، \x ◘ \xo 10:‏40 \xt مك. 16‏:‏14؛ لك. 24‏:‏34؛ يُوح. 20‏:‏19؛ ڒخ. 2‏:‏24؛ 1 كُور. 15‏:‏5. \x*  
\v 41 مَاشَا وَارْ إِدْجِي إِ مَارَّا ڒْڭنْسْ، مَاشَا إِ ڒشْهُوذْ إِنِّي إِزْوَارْ إِخْضَارْ إِ-ثنْ أَربِّي، إِ نشِّينْ إِنِّي أَكِيذسْ إِشِّينْ إِسْوِينْ أَوَارْنِي ثَانُوكْرَا نّسْ زِي ثَادَّارْثْ ن إِمتِّيننْ.  
\v 42 يُومُورْ أَنغْ أَذْ نْبَارّحْ ؤُ أَذْ نشْهذْ إِ ڒْڭنْسْ، أَقَا ذ نتَّا ذ ونِّي إِڭَّا أَربِّي ذ ڒْقَاضِي خْ يِينِّي إِدَّارنْ ؤُ خْ يِينِّي إِمُّوثنْ. \x ◘ \xo 10:‏42 \xt مت. 28‏:‏19؛ مك. 16‏:‏15؛ يُوح. 15‏:‏16؛ ڒخ. 17‏:‏31. \x*  
\v 43 شهّْذنْ خَاسْ مَارَّا إِنَابِييّنْ، بلِّي كُوڒْ إِجّنْ ونِّي إِ غَا يَامْننْ ذڭْ يِيسمْ نّسْ، أَذْ أَسْ تّْوَاغْفَارنْ دّْنُوبْ نّسْ.“ \x ◘ \xo 10:‏43 \xt أَمز. 3‏:‏15؛ 22‏:‏18؛ 26‏:‏4؛ 49‏:‏10؛ أَعَوذ. 18‏:‏15؛ إِزهد. 132‏:‏11؛ إِشا. 4‏:‏2؛ 7‏:‏14؛ 9‏:‏5؛ 40‏:‏10؛ إِرْم. 23‏:‏5؛ 33‏:‏14؛ حِز. 34‏:‏23؛ 37‏:‏24؛ دَان. 9‏:‏24؛ مِيخَا 7‏:‏20؛ ڒخ. 15‏:‏9. \x*   
\m
\v 44 أَمْ ثُوغَا شِيمْعُونْ إِسَّاوَاڒْ \add عَاذْ\add*، إِهْوَا-د أَرُّوحْ إِقدّْسنْ خْ مَارَّا إِنِّي ثُوغَا إِتّسْڒَانْ إِ وَاوَاڒْ. \x ◘ \xo 10:‏44 \xt ڒخ. 8‏:‏17. \x*  
\v 45 ثَاوْمَاثْ نِّي إِتّْوَاخثْننْ، إِنِّي د-يُوسِينْ أَكِيذسْ، ثْبهْثنْ، ؤُمِي ثَاموْشِي ن أَرُّوحْ إِقدّْسنْ إِتّْوَافَارّغْ عَاوذْ خْ \add ينِّي إِدْجَانْ زِي\add* ڒڭْنُوسْ.  
\v 46 مِينْزِي ثُوغَا ثنْ تّسْڒَانْ سَّاوَاڒنْ \bd س إِجّْ ن يِيڒسْ نّغْنِي\bd*، سّْمغَّارَانْ ذِي أَربِّي. ڒخْذنِّي إِقَّارْ شِيمْعُونْ: \x ◘ \xo 10:‏46 \xt مك. 16‏:‏17؛ ڒخ. 2‏:‏4. \x*  
\v 47 ”مَا إِزمَّارْ حذْ أَذْ إِقْضعْ أَمَانْ مَاحنْذْ وَارْ تّْوَاسّغْضِيصنْ إِنَا؟ مَاغَارْ، خْزَارْ، أَقَا قبْڒنْ أَرُّوحْ إِقدّْسنْ أَمْ نشِّينْ!“ \x ◘ \xo 10:‏47 \xt ڒخ. 8‏:‏36؛ 11‏:‏17. \x*  
\v 48 خنِّي يُومُورْ أَذْ ثنْ سّْغضْصنْ س يِيسمْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، ؤُشَا نِيثْنِي تَّارنْ زَّايسْ أَذْ إِقِّيمْ أَكِيذْسنْ \add عَاذْ\add* شَا ن وُوسَّانْ.   
\b  
\b  
\m  
\c 11
\s1 پُوطْرُوسْ إِسّعْذُو ڒخْبَارْ خْ وغْضَاصْ ن كُورْنِيلِييُوسْ  
\m
\v 1 رُّوسُولْ ذ ثَاوْمَاثْ إِنِّي إِدْجَانْ ذِي يَاهُوذِييَّا سْڒِينْ بلِّي ؤُڒَا ذ ڒڭْنُوسْ قبْڒنْ وَاوَاڒْ ن أَربِّي.  
\v 2 ڒَامِي إِڭعّذْ شِيمْعُونْ غَارْ ؤُرْشَالِيمْ، مْشُوبّْشنْ أَكِيذسْ إِنِّي إِدْجَانْ زڭْ وخْثَانْ.  
\v 3 نَّانْ، بلِّي نتَّا يُوذفْ-د غَارْ إِوْذَانْ إِ وَارْ إِتّْوَاخثْننْ، إِشَّا أَكِيذْسنْ. \x ◘ \xo 11:‏3 \xt ؤُف. 23‏:‏32؛ 34‏:‏15؛ أَعَوذ. 7‏:‏2؛ يُوح. 18‏:‏28. \x*   
\m
\v 4 مَاشَا شِيمْعُونْ إِقْضعْ \add ذَايْسنْ ڒْهَارْذْ\add*، ؤُشَا إِبْذَا أَذْ أَسنْ إِعَاوذْ أَوَاڒْ إِضْفَارْ ؤُمَاسْ:  
\v 5 ”ڒَْامِي ثُوغَا أَيِي ذِي \add ثنْذِينْثْ ن\add* يَافَّا تّْژَادْجِيغْ، ژْرِيغْ ذڭْ إِجّْ ن ڒوْحِييْ أَقَا إِشْثْ ن ڒْقشْعثْ أَمْ ثْشُوقّثْ ثَامقّْرَانْثْ ن ڒقْطنْ \add أَزْذَاذْ\add* إِتّْوَاطّْفنْ زِي أَربْعَا ن ثْغمُّورَا نّسْ ثهْوَا-د زڭْ ؤُجنَّا، ثِيوضْ-د غَارِي. \x ◘ \xo 11:‏5 \xt ڒخ. 10‏:‏9. \x*  
\v 6 خْزَارغْ مْلِيحْ ؤُ ژْرِيغْ أَقَا ذَايسْ \add إِمُودَّارنْ\add* ن ثمُّورْثْ س أَربْعَا ن إِضَارنْ ذ \add إِمُودَّارنْ\add* إِنِّي إِتّْبُوعنْ خْ ثمُّورْثْ ؤُڒَا ذ إِجْضَاضْ ن ؤُجنَّا.  
\v 7 سْڒِيغْ أَوَارْنِي أَيِي إِشْثْ ن ثْمِيجَّا، ثنَّا أَيِي: ’\add أَ\add* شِيمْعُونْ، كَّارْ، غَارْصْ، ثشّذْ!‘  
\v 8 مَاشَا نشّْ نِّيغْ: ’لَّ، \add أَ\add* سِيذِي،عمَّارْصْ وَارْ يُوذِيفْ عَاذْ غَارْ ؤُقمُّومْ إِنُو مِينْ وَارْ إِزْذِيڭنْ نِيغْ مِينْ إِدْجَانْ ذ ڒحْرَامْ.‘ \x ◘ \xo 11:‏8 \xt لَاوِي 11‏:‏4؛ أَعَوذ. 14‏:‏7. \x*  
\v 9 ثنَّا خَافِي ثْمِيجَّا زڭْ ؤُجنَّا عَاوذْ: ’مِينْ إِسِّيزْذڭْ أَربِّي، وَارْ د ث ثتَّارِّيذْ شَا شكْ ذ ڒحْرَامْ!‘  
\v 10 مَانْ أَيَا إِمْسَارْ ثْڒَاثَا ن إِمُورنْ ؤُشَا \add خنِّي\add* إِتّْوَاسّْجْبذْ مَارَّا عَاوذْ غَارْ ؤُجنَّا.  
\v 11 ؤُ خْزَارْ، ڒخْذنِّي أَقَا ذِينْ ثْڒَاثَا ن يرْيَازنْ إِنِّي غَارِي د-إِتّْوَاسّكّنْ زِي كُورْنِيلِييُوسْ زِي قَايْصَارِييَا، بدّنْ غَارْ ثوَّارْثْ ن ڒمْرَاحْ مَانِي ذ أَيِي ثُوغَا.  
\v 12 إِنَّا أَيِي أَرُّوحْ أَقَا إِتّْخصَّا أَذْ كِيسنْ رَاحغْ بْڒَا مَا أَذْ شكّغْ. ثُوغَا أَكِيذِي ؤُڒَا ذ ستَّا ن وَاوْمَاثنْ ؤُ نُوذفْ غَارْ ثَادَّارْثْ ن ورْيَازْ \add نِّي\add*. \x ◘ \xo 11:‏12 \xt ڒخ. 10‏:‏19؛ 15‏:‏7. \x*  
\v 13 نتَّا إِسَّارْڭبْ أَنغْ مَامّشْ إِژْرَا إِجّْ ن لْمَالَاكْ إِ إِبدّنْ ذِي ثَادَّارْثْ نّسْ، ونِّي ذ أَسْ إِنَّانْ: ’سكّْ \add إِجّْ ن ورْيَازْ\add* غَارْ يَافَّا، ثْعَارْضذْ خْ شِيمْعُونْ ونِّي ؤُمِي تّْكنَّانْ بُوطْرُوسْ.  
\v 14 نتَّا أَذْ أَشْ إِسِّيوڒْ أَوَاڒنْ إِ زِي غَا ثطّْفذْ ثُوذَارْثْ، شكْ ذ مَارَّا ثَادَّارْثْ نّشْ.‘  
\v 15 ؤُمِي قِّيمغْ سِّيوْڒغْ، إِهْوَا-د أَرُّوحْ إِقدّْسنْ خَاسنْ أَمْ مَامّشْ خَانغْ د-إِهْوَا عَاوذْ غَارْ ؤُمزْوَارُو.  
\v 16 تّْوَاسّْعقْڒغْ خْ وَاوَاڒْ ن سِيذِيثْنغْ، مَامّشْ إِنَّا: ’يُوحَانَّا ثُوغَا إِسّغْضَاصْ س وَامَانْ مَاشَا كنِّيوْ أَذْ تّْوَاسّْغضْصمْ س أَرُّوحْ إِقدّْسنْ.‘ \x ◘ \xo 11:‏16 \xt إِشا. 44‏:‏3؛ يُووِ. 3‏:‏1؛ مت. 3‏:‏11؛ مك. 1‏:‏8؛ لك. 3‏:‏16؛ يُوح. 1‏:‏26؛ ڒخ. 1‏:‏5؛ 2‏:‏4؛ 19‏:‏4. \x*  
\v 17 مَاڒَا أَربِّي إِوْشَا ثَاموْشِي-يَا إِ ڒڭْنُوسْ نِّي يُومْننْ ذِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ أَمْ مَامّشْ ذ أَنغْ ت إِوْشَا، خنِّي مِينْ عْنِيغْ نشّْ مَاحنْذْ أَذْ سّْبدّغْ أَربِّي؟“ \x ◘ \xo 11:‏17 \xt ڒخ. 15‏:‏9. \x*   
\m
\v 18 ؤُمِي سْڒِينْ أَوَاڒنْ-أَ، هدّْننْ، سّمْغَارنْ أَربِّي، نَّانْ: ”أَذْ ثَاغْ إِوْشَا أَربِّي ؤُڒَا إِ ڒڭْنُوسْ مَاحنْذْ أَذْ د-ذوْڒنْ أَذْ ثُوبنْ إِ ثُوذَارْثْ.“   
\b  
\m  
\s1 ثَامسْمُونْثْ ن يَاسُوع لْمَاسِيحْ ذِي أَنْثِييُوخِييَا  
\m
\v 19 إِنِّي إِتّْوَازُوزَّارنْ زِي سِّيبّثْ ن ڒْمحْنثْ إِ إِمْسَارنْ س سِّيبّثْ ن سْثِيفَانُوسْ، ژْوَانْ غَارْ فِينِيقِييَا ؤُ غَارْ جّْوَايهْ ن قُوبْرُوسْ ؤُ غَارْ أَنْثِييُوخِييَا، أَمْ وَارْ سِّيوِيڒنْ أَكْ-ذ حذْ س وَاوَاڒْ مْغِيرْ أَكْ-ذ وُوذَاينْ وَاهَا. \x ◘ \xo 11:‏19 \xt ڒخ. 8‏:‏1، 4. \x*  
\v 20 ثُوغَا ذِينْ جَارْ أَسنْ شَا ن يرْيَازنْ زِي قُوبْرُوسْ ؤُ زِي قَايْرَاوَانْ إِنِّي، أَڒَامِي د-ؤُسِينْ غَارْ أَنْثِييُوخِييَا، ثُوغَا إِسَّاوَاڒنْ أَكْ-ذ إِيُونَانِييّنْ، بَارّْحنْ أَسنْ س ڒخْبَارْ أَصبْحَانْ ن سِيذِيثْنغْ يَاسُوع.  
\v 21 ثُوغَا أَفُوسْ ن سِيذِي أَكِيذْسنْ ؤُشَا أَطَّاسْ ؤُمْننْ، ذوْڒنْ-د غَارْ سِيذِي. \x ◘ \xo 11:‏21 \xt ڒخ. 2‏:‏47؛ 5‏:‏14. \x*   
\m
\v 22 إِكَّا-د ڒخْبَارْ خَاسنْ خْ إِمزُّوغنْ ن أَيْثْ ن ثْمسْمُونْثْ ذِي ؤُرْشَالِيمْ. نِيثْنِي سّكّنْ بَارْ-نَابَا غَارْ أَنْثِييُوخِييَا.  
\v 23 أَڒَامِي د-يِيوضْ \add ذِينْ\add*، إِژْرَا أَرْضَا ن أَربِّي، ؤُشَا إِفَارْحْ، إِعْڒمْ أَسنْ حِيمَا أَذْ قِّيمنْ تّْشبَّارنْ ذِي سِيذِيثْنغْ س مَارَّا ؤُڒْ نْسنْ. \x ◘ \xo 11:‏23 \xt ڒخ. 13‏:‏43؛ 14‏:‏22. \x*  
\v 24 مِينْزِي ثُوغَا-ث ذ أَرْيَازْ إِسڭّذْ، إِشُّورْ س أَرُّوحْ إِقدّْسنْ ذ لْ-إِيمَانْ، ؤُشَا إِجّْ ن ؤُبَارُّو ذ أَمقّْرَانْ \add ن إِوْذَانْ\add* إِمَّارْنِي-د غَارْ سِيذِيثْنغْ. \x ◘ \xo 11:‏24 \xt ڒخ. 4‏:‏36؛ 6‏:‏5. \x*  
\v 25 خنِّي إِرُوحْ غَارْ ثَارْسُوسْ حِيمَا أَذْ يَارْزُو خْ شَاوُولْ، \x ◘ \xo 11:‏25 \xt ڒخ. 9‏:‏27. \x*  
\v 26 ؤُشَا أَڒَامِي ث يُوفَا، يِيوِي إِ-ث أَكِيذسْ غَارْ أَنْثِييُوخِييَا. ؤُشَا إِمْسَارْ أَقَا نِيثْنِي مُوننْ ذِي ثْمسْمُونْثْ أَسڭّْوَاسْ إِكْمڒْ ؤُشَا سّْڒمْذنْ إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ. زِي  ڒْوقْثْ نِّي تّْوَاسمَّانْ إِمحْضَارنْ ذ ’إِمَاسِيحِييّنْ‘ إِ ؤُمُورْ أَمزْوَارُو. \f ◼ \fr 11:‏26 \ft \+bd ’ثَامسْمُونْثْ‘\+bd* - نِيغْ: ’جْمَاعثْ نْ ڒْمُومِينِينْ‘.\f*   
\m
\v 27 ذڭْ وُوسَّانْ نِّي هْوَانْ-د شَا ن إِنَابِييّنْ زِي ؤُرْشَالِيمْ غَارْ ذِينْ.  
\v 28 ؤُشَا إِكَّارْ إِجّْ ن زَّايْسنْ قَّارنْ أَسْ أَغابُوسْ، إِعْڒمْ أَسنْ س أَرُّوحْ بلِّي إِجّْ ن ڒَاژْ إِمْغَارْ أَذْ يكّْ خْ مَارَّا ثَامُّورْثْ. ؤُشَا يُوسَا-د ڒَاژْ-أَ ذڭْ وُوسَّانْ ن قَايْصَارْ كْلُوذِييُوسْ. \x ◘ \xo 11:‏28 \xt ڒخ. 21‏:‏10. \x*  
\v 29 خنِّي ڭِّينْ إِمحْضَارنْ أَقَا كُوڒْ إِجّْ زَّايْسنْ أَذْ إِڭّْ شَا ن ثْوِيزَا غَارْ ؤُغزْذِيسْ عْلَاحْسَابْ ثِيزمَّارْ نّسْ إِ وَاوْمَاثنْ إِ إِزدّْغنْ ذِي يَاهُوذِييَّا.  
\v 30 ؤُشَا أَمنِّي إِ ڭِّينْ نِيثْنِي، ؤُشَا سّكّنْ ث ذِينْ غَارْ إِمْغَارنْ \add ن ڒْڭنْسْ\add* إِ ذِينْ إِدْجَانْ س ؤُفُوسْ ن بَارْ-نَابَا ذ شَاوُولْ. \x ◘ \xo 11:‏30 \xt ڒخ. 12‏:‏25. \x*   
\b  
\b  
\m  
\c 12
\s1 ڒْموْثْ ن يَاعْقُوبْ ذ ؤُفكِّي ن بُوطْرُوسْ  
\m
\v 1 ذِي ڒْوقْثْ نِّي عْڒَاحَاڒْ إِسّْوِيژّضْ هِيرُوذُوسْ أَفُوسْ نّسْ حِيمَا أَذْ إِكَارْفسْ خْ شَا ن يِينِّي إِدْجَانْ زِي ثْمسْمُونْثْ.  
\v 2 إِنْغَا يَاعْقُوبْ ؤُمَاسْ ن يُوحَانَّا س سِّيفْ. \x ◘ \xo 12:‏2 \xt مت. 4‏:‏21. \x*  
\v 3 ؤُمِي إِژْرَا أَقَا مَانْ أَيَا إِعْجبْ أَسنْ إِ وُوذَاينْ، إِكمّڒْ ذڭْ وبْرِيذْ نِّي مَاحنْذْ أَذْ إِطّفْ ؤُڒَا ذ شِيمْعُونْ بُوطْرُوسْ. ثُوغَا ذ ؤُسَّانْ ن \add وغْرُومْ\add* بْڒَا أَنْثُونْ.  
\v 4 \add ڒَْامِي\add* ث إِطّفْ، إِڭَّا إِ-ث ذِي ڒحْبسْ، ؤُشَا إِڭَّا أَسْ ذڭْ إِفَاسّنْ ن ستَّا -عشْرَا ن إِعسَّاسنْ، حِيمَا أَذْ خَاسْعسّنْ. ثُوغَا إِخْسْ أَذْ ث إِقدّمْ زَّاثْ إِ وُوذَاينْ أَوَارْنِي إِ \add ڒْْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو. \x ◘ \xo 12:‏4 \xt يُوح. 21‏:‏18. \x*  
\v 5 ؤُمِي ثُوغَاعسّنْ خْ شِيمْعُونْ ذِي ڒحْبسْ، ثُوغَا ثژَّادْجْ ثْمسْمُونْثْ إِ أَربِّي بْڒَا قطُّو ذِي طّْوعْ نّسْ.   
\m
\v 6 ذِي دْجِيڒثْ، غَارْ ثُوفُّوثْ إِ ذِي ثُوغَا إِزْعمْ \add هِيرُوذُوسْ\add* أَذْ ث إِقدّمْ، ؤُمِي إِطّصْ شِيمْعُونْ أَمْ ث شدّنْ س ثْنَاينْ ن سّْنَاسڒْ جَارْ ثْنَاينْ ن إِعسَّاسنْ ن ڒْعسْكَارْ ؤُ إِنّغْنِي حطَّانْ غَارْ ثوَّارْثْ ن ڒحْبسْ،  
\v 7 إِبدّْ-د لْمَالَاكْ ن سِيذِي سنّجْ نّسْ ؤُ طّْيَا ن ثْفَاوْثْ ثتّْشعْشِيعْ ذِي مَارَّا أَخَّامْ ؤُشَا نتَّا إِعَارْنْ إِ-ث ذڭْ ؤُغزْذِيسْ نّسْ، إِسّْفَاقْ إِ-ث، إِنَّا: ”كَّارْ ذغْيَا!“ ذغْيَا وْضَانْثْ سّْنَاسڒْ زڭْ إِفَاسّنْ نّسْ. \x ◘ \xo 12:‏7 \xt ڒخ. 5‏:‏19؛ 16‏:‏26. \x*  
\v 8 إِنَّا أَسْ لْمَالَاكْ: ”بْيسْ، ثقّْنذْ ثِيسِيڒَا نّشْ!“ إِڭَّا أَمُّو. إِنَّا أَسْ خنِّي: ”أَرْضْ أَجدْجَابْ نّشْ، ضْفَارْ أَيِي-د!“  
\v 9 خنِّي إِفّغْ، إِضْفَارْ إِ-ث، وَارْ إِسِّينْ مِينْ ذ أَسْ إِڭَّا لْمَالَاكْ، أَقَا مَانْ أَيَا ذ ثِيذتّْ، مَاغَارْ إِتّْغِيڒْ أَسْ إِژْرَا إِجّْ ن ڒوْحِييْ.  
\v 10 أَڒَامِي كِّينْ خْ ؤُعسَّاسْ أَمزْوَارُو ذ خْ ونِّي وِيسّْ ثْنَاينْ، إِوْضنْ غَارْ ثوَّارْثْ ن وُوزَّاڒْ ثنِّي إِتَّاوْينْ غَارْ ثنْذِينْثْ، ثنُّورْزمْ أَسنْ وحّْذسْ. أَوَارْنِي ڒَامِي زَّايسْ فّْغنْ، قضْعنْ إِشْثْ ن زّنْقثْ، ڒخْذنِّي إِجَّا إِ-ث لْمَالَاكْ.   
\m
\v 11 خنِّي إِذْوڒْ-د شِيمْعُونْ غَارْ ڒْبَاڒْ نّسْ، إِنَّا: ”ڒخُّو سّْنغْ س ثِيذتّْ بلِّي سِيذِي إِسّكّْ-د لْمَالَاكْ نّسْ، إِسّنْجمْ أَيِي زڭْ إِفَاسّنْ ن هِيرُوذُوسْ ؤُ زِي مَارَّا مِينْ زعْمنْ أَذْ أَيِي ڭّنْ وُوذَاينْ.“  
\v 12 ؤُمِي ثُوغَا إِتّْخَارّصْ ذِي مَانْ أَيَا، يُوسَا-د غَارْ ثَادَّارْثْ ن مَارْيَامْ، يمَّاسْ ن يُوحَانَّا، ونِّي إِتّْكنَّانْ مَارْكُوسْ، مَانِي ثُوغَا تّْمُونَانْ أَطَّاسْ، تّْژَادْجَانْ \add ذِينْ\add*.   
\m
\v 13 أَڒَامِي إِسّْقَارْقبْ ذِي ثوَّارْثْ ن بَارَّا ن ڒمْرَاحْ، ثُوسَا-د إِشْثْ ن ثْحنْجِيرْثْ، قَّارنْ أَسْ رُوذَا حِيمَا أَذْ ثْسڒْ \add وِي ذِينِّي\add*.  
\v 14 ثعْقڒْ ثْمِيجَّا ن شِيمْعُونْ، ؤُشَا زِي سِّيبّثْ ن ڒفْرَاحثْ وَارْ ثَارْزِيمْ شَا ثوَّارْثْ، \add مَاشَا\add* ثعْقبْ ذغْيَا ؤُشَا ثْخبَّارْ إِ-ثنْ، إِنَّا أَسنْ: ”خْزَارْ، شِيمْعُونْ، أَقَا إِبدّْ غَارْ ثوَّارْثْ ن ڒمْرَاحْ!“  
\v 15 نَّانْ أَسْ: ”أَقَا شمْ ثْخڒْفذْ!“ مَاشَا نتَّاثْ ثقِّيمْ ثقَّارْ أَقَا مَانْ أَيَا نِيشَانْ. نَّانْ أَسْ: ”مَا أَذْ ثَاغْ ذ لْمَالَاكْ نّسْ!“   
\m
\v 16 مَاشَا شِيمْعُونْ، إِقِّيمْ إِسّْقَارْقُوبْ ؤُشَا فّْغنْ، ژْرِينْ ث ؤُشَا ثْبهْثنْ.  
\v 17 إِشيَّارْ أَسنْ س ؤُفُوسْ نّسْ حِيمَا أَذْ سْقَارنْ ؤُشَا إِعَاوذْ أَسنْ مَامّشْ ث-إِ-د-إِسُّوفّغْ سِيذِي زِي ڒحْبسْ، إِنَّا: ”خبَّارمْ يَاعْقُوبْ ذ ثَاوْمَاثْ خْ ؤُيَا!“ خنِّي إِفّغْ غَارْ إِجّْ ن ومْشَانْ نّغْنِي. \x ◘ \xo 12:‏17 \xt ڒخ. 13‏:‏16؛ 19‏:‏33؛ 21‏:‏40. \x*   
\m
\v 18 ڒَامِي د-يِيوضْ ؤُزِيڒْ، إِمْسَارْ إِجّْ ن ؤُخَارْوضْ إِ وَارْ إِدْجِينْ ذْرُوسْثْ جَارْ ڒْعسْكَارْ خْ مِينْ إِمْسَارنْ إِ شِيمْعُونْ.  
\v 19 أَوَارْنِي ڒَامِي ثُوغَا خَاسْ يَارزُّو هِيرُوذُوسْ، مَاشَا وَارْ ث يُوفِي، إِحْكمْ خْ إِعسَّاسنْ س ڒْموْثْ، إِفّغْ زِي يَاهُوذِييَّا، إِقِّيمْ إِزدّغْ ذِي قَايْصَارِييَا.   
\b  
\m  
\s1 ڒْموْثْ ن هِيرُوذُوسْ أَغْرِيبَاسْ  
\m
\v 20 ؤُمِي ثُوغَا ڒعْذَاوثْ ذِي هِيرُوذُوسْ ضِيدّْ إِ أَيْثْ ن صُورْ ذ صَايْذُونْ، مُوننْ نِيثْنِي، إِوْضنْ أَذْ سّْقنْعنْ بْلَاسْثُوسْ أَمْسخَّارْ إِشنّْعنْ ن ؤُجدْجِيذْ ؤُشَا تَّارنْ أَسْ مَاحنْذْ أَذْ أَسنْ إِوْشْ إِجّْ ن وصْڒَاحْ، مِينْزِي مَاشَّا ن ثمُّورْثْ نْسنْ ثكَّا-د زِي ثْڭلْذِيثْ ن هِيرُوذُوسْ.  
\v 21 ذڭْ إِجّْ ن وَاسّْ \add ن ڒْفَارْحْ\add* إِتّْوَاسّْننْ يَارْضْ هِيرُوذُوسْ أَجدْجَابْ ن ؤُجدْجِيذْ أَمْ إِقِّيمْ خْ ڒْكُورْسِي ن شّْرعْ، ؤُشَا إِسِّيوڒْ إِ ڒْغَاشِي.  
\v 22 ؤُشَا مَارَّا ڒْڭنْسْ إِسْغُويْ غَارسْ: ”أَقَا ذ أَوَاڒنْ ن أَربِّي، وَارْ إِدْجِي ن بْنَاذمْ.“  
\v 23 ڒخْذنِّي إِوْثَا إِ-ث لْمَالَاكْ ن سِيذِي، مِينْزِي نتَّا وَارْ إِوْشِي أَعُودْجِي إِ أَربِّي. ؤُشَا ذْڒنْ ث إِكشَّاونْ، إِفّغْ زَّايسْ بُوحْبڒْ.   
\b  
\m
\v 24 أَوَاڒْ ن أَربِّي إِتّْوَابَارّحْ \add زَّايسْ\add*، إِمقَّارْ. \x ◘ \xo 12:‏24 \xt إِشا. 55‏:‏11؛ ڒخ. 6‏:‏7. \x*  
\v 25 بَارْ-نَابَا ذ شَاوُولْعقْبنْ-د زِي ؤُرْشَالِيمْ غَارْ أَنْثِييُوكِييَا أَوَارْنِي ڒَامِي كمّْڒنْ ثَاسخَّارْثْ نْسنْ ؤُشَا إِوْينْ أَكِيذْسنْ يُوحَانَّا، ونِّي ؤُمِي تّْكنَّانْ مَارْكُوسْ.   
\b  
\b  
\m  
\c 13
\s1 ڒِيخْضَارثْ ن بَارْنَابَا ذ بُولُوسْ إِ ثْسخَّارْثْ نْسنْ  
\m
\v 1 ثُوغَا ذِينْ ذِي أَنْثِييُوخِييَا ذِي ثْمسْمُونْثْ إِنَابِييّنْ ذ إِمْسڒْمَاذنْ: بَارْ-نَابَا، ذ شِيمْعُونْ ونِّي إِتّْكنَّانْ نِيجرْ، ذ لُوكِييُوسْ زِي ثنْذِينْثْ ن قَايْرَاوَانْ، ذ مَانَاعِينْ ونِّي ذ مِّيسْ ن ونِّي يَاربَّانْ هِيرُوذُوسْ، ڒْحَاكمْ خْ إِجّْ ن أَرْبَاعْ ن ثمُّورْثْ، ذ شَاوُولْ. \x ◘ \xo 13:‏1 \xt  ڒخ. 14‏:‏26. \x*  
\v 2 أَمْ ثُوغَا تّْژُومَّانْ، تّْزَاوْڭنْ أَربِّي، إِنَّا أَسنْ أَرُّوحْ إِقدّْسنْ: ”فَارْزمْ أَيِي-د بَارْ-نَابَا ذ شَاوُولْ إِ ڒْخذْمثْ ثنِّي ؤُمِي ذ أَسنْ د-ڒَْاغِيغْ.“ \x ◘ \xo 13:‏2 \xt مت. 9‏:‏38؛ ڒخ. 9‏:‏15؛ 22‏:‏21؛ رُوم. 1‏:‏1؛ 10‏:‏15؛ ڭال. 1‏:‏15؛ 2‏:‏8؛ أَفا. 3‏:‏8؛ 1 تِيم. 2‏:‏7؛ 2 تِيم. 1‏:‏11؛ عبر. 5‏:‏4. \x*  
\v 3 أَوَارْنِي ڒَامِي ژُومّنْ، ژُّودْجنْ، سَّارْسنْ خَاسنْ إِفَاسّنْ، سكّنْ ثنْ. \x ◘ \xo 13:‏3 \xt ڒخ. 6‏:‏6؛ 8‏:‏15؛ 19‏:‏6. \x*   
\b  
\m  
\s1 أَسَافَارْ أَمزْوَارُو ن بُولُوسْ غَارْ قُوبْرُوسْ  
\m
\v 4 ڒَامِي ثُوغَا د-تّْوَاسّكّنْ زِي أَرُّوحْ إِقدّْسنْ، هْوَانْ-د غَارْ سَالُوكِييَا ؤُشَا سّنِّي رُوحنْ ذِي ڒبْحَارْ غَارْ قُوبْرُوسْ.  
\v 5 ؤُمِي إِوْضنْ غَارْ سَالَامِيسْ، بَارّْحنْ س وَاوَاڒْ ن سِيذِيثْنغْ ذِي ثمْزِيذَاوِينْ ن وُوذَاينْ. ثُوغَا يُوحَانَّا إِتّْسخَّارْ إِ-ثنْ. \x ◘ \xo 13:‏5 \xt ڒخ. 12‏:‏25. \x*   
\m
\v 6 أَوَارْنِي ڒَامِي ژْوَانْ مَارَّا ثَاڭْزِيرْثْ، إِوْضنْ-د غَارْ بَافُوسْ. نِيثْنِي ؤُفِينْ ذِينْ إِجّْ ن ورْيَازْ ذ ؤُذَايْ، ثُوغَا وَانِيثَا ذ أَسحَّارْ، ذ أَنَابِي إِسّْخَارِّيقنْ، قَّارنْ أَسْ بَارْ-شُومَا. \f ◼ \fr 13:‏6 \ft \+bd ’بَارْ-شُومَا‘\+bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي: ’مِّيسْ ن يِيسمْ‘. س ڒْخطّْ أَڭْڒِينْزِي قَّارنْ أَسْ ’بَارْ-يَاسُوع‘، إِخْسْ أَذْ يِينِي ’مِّيسْ ن يَاسُوع‘. مَاشَا حِيمَا وَارْ ذِينْ إِتِّيڒِي ؤُسكّْوِي جَارْ لْمَاسِيحْ ذ بْنَاذمْ وَانِيثَا، نڭّْ أَسْ ’بَارْ-شُومَا‘.\f*  \x ◘ \xo 13:‏6 \xt ڒخ. 8‏:‏9؛ 19‏:‏13. \x*  
\v 7 نتَّا غَارسْ إِشْثْ ن ثسْغُونْثْ إِمْثنْ أَكْ-ذ إِجّْ ن بْنَاذمْ ذ أَمِيغِيسْ، لْعَامِيلْ ؤُمِي قَّارنْ سَارْجِييُوسْ بُولُوسْ. إِڒَاغَا-د لْعَامِيلْ إِ بَارْ-نَابَا ذ شَاوُولْ، ثُوغَا إِمّژْرِي أَذْ إِسڒْ أَوَاڒْ ن أَربِّي.  
\v 8 مَاشَا أَسحَّارْ بَارْ-شُومَا، إِسمْ وَانِيثَا إِتّْوَاثَارْجمْ س ’إِلِيمَاسْ‘، ثُوغَا إِتّْعكَّاسْ إِ-ثنْ، يَارْزُو أَذْ إِسّْبعّذْ لْوَالِي خْ لْ-إِيمَانْ. \x ◘ \xo 13:‏8 \xt ؤُف. 7‏:‏11؛ 2 تِيم. 3‏:‏8\x*  
\v 9 مَاشَا شَاوُولْ ؤُمِي قَّارنْ عَاوذْ بُولُوسْ، إِتّْوَاشُّورْ س أَرُّوحْ إِقدّْسنْ، إِجْعَارْ ذَايسْ مْلِيحْ، إِنَّا:  
\v 10 ”أَ \add شكْ\add*، أَقَا ثشُّورذْ س كُوڒْ ڒْغشّْ ذ كُوڒْ ثحْرَايْمشْثْ، \add أَ شكْ\add* مِّيسْ ن إِبْڒِيسْ ذ ڒعْذُو ن مَارَّا ثَاسڭْذَا. مَا أَقَا شكْ وَارْ ثْبدّذْ \add عمَّارْصْ\add* أَذْ ثسّْخَارْوْضذْ إِبْرِيذنْ إِسڭّْذنْ ن سِيذِي؟  
\v 11 ڒخُّو، خْزَارْ، أَقَا ذَا أَفُوسْ ن سِيذِي ضِيدّْ نّشْ، أَذْ ثْذوْڒذْ ذ أَذَارْغَاڒْ، وَارْ ثتّْوِيڒِيذْ ثَافُوشْثْ \add عَاذْ\add* إِ يِيجّْ ن ڒْمِيجَاڒْ.“ ڒخْذنِّي ثوْضَا-د خَاسْ ثَايُّوثْ ذ ثَادْجسْثْ ؤُشَا إِبْذَا إِدُّورَا إِتّْفَافَا، يَارزُّو وِي ث غَا إِڭوّْذنْ زڭْ ؤُفُوسْ.  
\v 12 ڒَامِي إِژْرَا لْعَامِيلْ مِينْ إِمْسَارنْ، إِثبْهثْ ؤُشَا يُومنْ ذِي ثْغُورِي ن سِيذِي.   
\b  
\m  
\s1 پُولُوسْ ذ بَارْنَابَا غَارْ أَنْثِييُوخِييَا ذِي بِيسِيذِييَا  
\m
\v 13 بُولُوسْ ذ بَارْ-نَابَا كِّينْ خْ ڒبْحَارْ زِي ثنْذِينْثْ ن بَافُوسْ ؤُشَا إِوْضنْ غَارْ ثنْذِينْثْ ن بِيرْخَا ذِي بَامْفِيلِييَا. سّنِّي يُويُورْ خَاسنْ يُوحَانَّا، إِعْقبْ غَارْ ؤُرْشَالِيمْ. \x ◘ \xo 13:‏13 \xt ڒخ. 15‏:‏38. \x*   
\m
\v 14 مَاشَا نِيثْنِي رُوحنْ زِي بِيرْخَا، \add كِّينْ خْ ثمُّورْثْ،\add* ؤُشَا إِوْضنْ غَارْ أَنْثِييُوخِييَا، إِشْثْ ن ثنْذِينْثْ ذِي \add جّْوَايهْ ن\add* بِيسِيذِييَا. ؤُذْفنْ نِيثْنِي غَارْ ثمْزِيذَا ذڭْ وَاسّْ ن سّبْثْ ؤُشَا قِّيمنْ ذِينِّي.  
\v 15 أَوَارْنِي ثِيغْرِي ن شَّارِيعَا ذ إِنَابِييّنْ، سّكّنْ غَارْسنْ إِمْغَارنْ ن ثمْزِيذَا، نَّانْ: ”\add أَ\add* إِرْيَازنْ ثَاوْمَاثْ، مَاڒَا ثُوغَا غَارْومْ إِجّْ ن وَاوَاڒْ ن ؤُشجّعْ إِ إِوْذَانْ، بَارّْحمْ زَّايسْ إِ ڒْڭنْسْ!“  
\v 16 \add خنِّي\add* إِكَّارْ بُولُوسْ إِشيَّارْ س ؤُفُوسْ نّسْ، إِنَّا:  
\b  
\m ”أَ كنِّيوْ، إِرْيَازنْ ن إِسْرَائِيل ؤُ كنِّيوْ إِنِّي إِتّڭّْوذنْ أَربِّي، سْڒمْ! \x ◘ \xo 13:‏16 \xt ڒخ. 12‏:‏17؛ 19‏:‏33؛ 21‏:‏40. \x*  
\v 17 أَربِّي ن ڒْڭنْسْ-أَ ثُوغَا إِفَارْزْ ڒجْذُوذْ نّغْ ؤُشَا إِسّْڭعّذْ إِ-ثنْ ؤُ إِمَّارْنِي ذَايْسنْ أَطَّاسْ ڒَامِي ثنْ ثُوغَا ذ إِمعْزَابْ ذِي ثمُّورْثْ ن مِيصْرَا ؤُشَا إِسُّوفّغْ إِ-ثنْ س ؤُفُوسْ نّسْ يُوعْڒَانْ، \x ◘ \xo 13:‏17 \xt ؤُف. 1‏:‏1. \x*  
\v 18 إِسّشَّا إِ-ثنْ ڒْمِيجَاڒْ ن أَربْعِينْ ن إِسڭّْوُوسَا ذِي ڒخْڒَا. \x ◘ \xo 13:‏18 \xt ؤُف. 16‏:‏35؛ ڒخْڒ. 14‏:‏34؛ إِزهد. 95‏:‏10. \x*  
\v 19 إِثحَّا سبْعَا ن ڒڭْنُوسْ ذِي ثمُّورْثْ ن كنْعَانْ، ؤُشَا إِوْشَا أَسنْ ثمُّورْثْ نْسنْ ذ ڒْوَارْثْ إِ نِيثْنِي. \x ◘ \xo 13:‏19 \xt أَعَوذ. 7‏:‏1؛ ياش. 14‏:‏2. \x*  
\v 20 نتَّا إِوْشَا أَسنْ ڒْقُوضَاثْ إِ يِيجّْ ن ڒْمِيجَاڒْ ن أَربْعَا-مْيَا ؤُ-خمْسِينْ ن إِسڭّْوُوسَا، أَڒْ ڒْوقْثْ ن ؤُنَابِي شَامْوِيلْ. \x ◘ \xo 13:‏20 \xt ڒقض. 2‏:‏16؛ 3‏:‏9. \x*   
\m
\v 21 خنِّي تَّارنْ إِجّْ ن ؤُجدْجِيذْ إِ يِيخفْ نْسنْ ؤُشَا أَربِّي إِوْشَا أَسنْ شَاوُولْ، مِّيسْ ن كِيسْ، إِجّْ ن ورْيَازْ زِي ثقْبِيتْشْ ن بِينْيَامِينْ، ڒْمِيجَاڒْ ن أَربْعِينْ ن إِسڭّْوُوسَا. \x ◘ \xo 13:‏21 \xt 1 صم. 8‏:‏5؛ 9‏:‏15؛ 10‏:‏15؛ حُوش. 13‏:‏11. \x*  
\v 22 \add خنِّي\add* إِكّسْ إِ-ث، إِسّْڭعّذْ أَسنْ ذَاوُوذْ ذ أَجدْجِيذْ، ونِّي ؤُمِي خْ إِشْهذْ \add أَربِّي\add* عَاوذْ \add أَمُّو\add*: ’ؤُفِيغْ ذَاوُوذْ مِّيسْ ن يَاسَّا، أَقَا-ث ذ إِجّْ ن ورْيَازْ يُوسَا-د خْ ڒْخَاضَارْ إِنُو، ونِّي إِ غَا إِڭِّنْ مَارَّا مِينْ خْسغْ نشّْ.‘ \x ◘ \xo 13:‏22 \xt 1 صم. 13‏:‏14؛ 16‏:‏12؛ إِزهد. 89‏:‏21؛ ڒخ. 7‏:‏45. \x*   
\m
\v 23 زِي زَّارِيعثْ نّسْ إِڭَّا أَربِّي إِ إِسْرَائِيل يَاسُوع أَمْسنْجمْ أَمْ مَامّشْ ثُوغَا زَّايسْ إِوَاعْذْ.  
\v 24 إِسّكّْ يُوحَانَّا حِيمَا أَذْ إِبَارّحْ س ؤُصغْضَاصْ ن تُّوبثْ قْبڒْ ثْوَاسِيثْ نّسْ إِ مَارَّا ڒْڭنْسْ ن إِسْرَائِيل. \x ◘ \xo 13:‏24 \xt مت. 3‏:‏1؛ مك. 1‏:‏2؛ لك. 3‏:‏2؛ يُوح. 3‏:‏23. \x*  
\v 25 ؤُمِي د-يِيوضْ يُوحَانَّا إِكمّڒْ ثَاسخَّارْثْ نّسْ، إِنَّا: ’مِينْ ذ أَومْ إِتّْغِيڒْ أَقَا ذ نشّْ؟ وَارْ دْجِيغْ ذ \add لْمَاسِيحْ\add*، مَاشَا، خْزَارْ، نتَّا أَذْ د-يَاسْ أَوَارْنِي أَيِي، ونِّي ؤُمِي نشّْ وَارْ سْذِيهدْجغْ أَذْ أَسْ فسْيغْ إِفِيڒَانْ ن سَانْذَالِييَاثْ نّسْ!‘ \x ◘ \xo 13:‏25 \xt مت. 3‏:‏11؛ يُوح. 1‏:‏20. \x*   
\m
\v 26 \add أَ\add* إِرْيَازنْ ثَاوْمَاثْ، ثَارْوَا ن جِّيڒْ ن إِبْرَاهِيمْ ذ يِينِّي أَكِيذْومْ إِتّڭّْوذنْ أَربِّي: إِ كنِّيوْ ؤُمِي د-إِتّْوَاسّكّْ نتَّا، ونِّي ذ أَوَاڒْ إِدَّارنْ. \x ◘ \xo 13:‏26 \xt مت. 10‏:‏6؛ ڒخ. 3‏:‏26؛ 13‏:‏46. \x*  
\v 27 مِينْزِي إِمزْذَاغْ ن ؤُرْشَالِيمْ ذ إِمقّْرَاننْ نْسنْ وَارْ ذ أَسْ فْهِيمنْ ؤُڒَا ذ إِذْلِيسنْ ن إِنَابِييّنْ إِ إِقَّارنْ كُوڒْ سّبْثْ، مَاشَا نِيثْنِي حكْمنْ خَاسْ ؤُ \add أَمُّو\add* كمّْڒنْ نِيثْنِي مِينْ يُورَانْ. \x ◘ \xo 13:‏27 \xt يُوح. 16‏:‏3؛ ڒخ. 3‏:‏17؛ 1 كُور. 2‏:‏8؛ 1 تِيم. 1‏:‏13. \x*  
\v 28 وَاخَّا وَارْ ؤُفِينْ ؤُڒَا ذ إِجّْ ن ڒسْبَابْ حِيمَا أَذْ خَاسْ حكْمنْ س ڒْموْثْ، تَّارنْ زِي بِيلَاطُوسْ \add تّسْڒِيحْ\add* حِيمَا أَذْ ث نْغنْ. \x ◘ \xo 13:‏28 \xt مت. 27‏:‏20؛ مك. 15‏:‏11؛ لك. 23‏:‏18؛ يُوح. 19‏:‏6. \x*  
\v 29 ؤُمِي كمّْڒنْ مَارَّا مِينْ خَاسْ يُورَانْ، سّهْوَانْ ث-إِ-د زِي ثحْنَاشْثْ ؤُشَا سَّارْسنْ ث ذڭْ ونْضڒْ.  
\v 30 مَاشَا أَربِّي إِسّْنكَّارْ إِ-ث-إِ-د زِي ثَادَّارْثْ ن إِمتِّيننْ. \x ◘ \xo 13:‏30 \xt مت. 28‏:‏6؛ مك. 16‏:‏6؛ لك. 24‏:‏6. \x*  
\v 31 إِضْهَارْ أَسنْ-د أَطَّاسْ ن وُوسَّانْ إِ يِينِّي أَكِيسْ إِڭعّْذنْ زِي لْجَالِيلْ غَارْ ؤُرْشَالِيمْ ؤُشَا ڒخُّو أَقَا أَثنْ ذ ڒشْهُوذْ نّسْ زَّاثْ إِ ڒْڭنْسْ. \x ◘ \xo 13:‏31 \xt مك. 16‏:‏14؛ يُوح. 20‏:‏19؛ 21‏:‏1؛ ڒخ. 1‏:‏3؛ 1 كُور. 15‏:‏5. \x*  
\v 32 خْزَارْ، ؤُڒَا ذ نشِّينْ نتّْبَارّحْ إِ كنِّيوْ س وَاوَاڒْ ن لْوَاعْذْ إِ إِتّْوَانَّانْ إِ ڒجْذُوذْ نّغْ. \x ◘ \xo 13:‏32 \xt أَمز. 3‏:‏15؛ 22‏:‏18؛ 26‏:‏4؛ 49‏:‏10؛ أَعَوذ. 18‏:‏15؛ 2 صم. 7‏:‏12؛ إِزهد. 132‏:‏11؛ إِشا. 4‏:‏2؛ 7‏:‏14؛ 9‏:‏5؛ 40‏:‏10؛ إِرْم. 23‏:‏5؛ 33‏:‏14؛ حِز. 34‏:‏23؛ 37‏:‏24؛ دَان. 9‏:‏24، 25. \x*  
\v 33 خْزَارْ، أَربِّي إِكمّڒْ \add لْوَاعْذْ\add* إِ نشِّينْ، إِنِّي إِدْجَانْ ذ ثَارْوَا نْسنْ، ؤُمِي د-إِسّْنكَّارْ يَاسُوع \add زِي ڒْموْثْ\add*. أَمْ مَامّشْ ثُورَا ذڭْ ؤُزهِّيذْ وِيسّْ ثْنَاينْ:  
\b  
\m \qt ’شكْ ذ مِّي، أَسّْ-أَ جِّيغْ-د شكْ!‘\qt* \x ◘ \xo 13:‏33 \xt إِزهد. 2‏:‏7. \x*   
\b  
\m
\v 34 س ؤُيَا إِسّْنكَّارْ إِ-ث-إِ-د أَربِّي زِي ثَادَّارْثْ ن إِمتِّيننْ أَڒَامِي وَارْ د-إِذِّيكّْوِيڒْعمَّارْصْ أَڒَامِي غَا إِكِيشُّو، أَمْ ث إِنَّا:  
\b  
\m \qt ’نشّْ أَذْ أَومْ وْشغْ\qt*  
\m \qt \+tl ثِيمڭَّا ن\+tl* أَرْضَا ن ذَاوُوذْ\qt*  
\m \qt إِ ذَايْسنْثْ ڒَامَانْ.‘\qt* \x ◘ \xo 13:‏34 \xt إِشا. 55‏:‏3. \x*   
\b  
\m
\v 35 س ؤُينِّي إِقَّارْ عَاوذْ ذڭْ إِجّْ ن ومْشَانْ نّغْنِي:  
\b  
\m \qt ’شكْ وَارْ ثتّجِّيذْ أَمْسِيزْذڭْ نّشْ\qt*  
\m \qt أَذْ إِكِيشُّو.‘\qt* \x ◘ \xo 13:‏35 \xt إِزهد. 16‏:‏10؛ إِزهد. 49‏:‏10؛ ڒخ. 2‏:‏27. \x*   
\b  
\m
\v 36 مِينْزِي ذَاوُوذْ إِسخَّارْ جَارْ جِّيڒْ نّسْ عْلَاحْسَابْ مِينْ إِخْسْ أَربِّي، ؤُشَا إِمُّوثْ، إِتّْوَاسّْمُونْ غَارْ ڒجْذُوذْ نّسْ، خنِّي إِكِيشُّو. \x ◘ \xo 13:‏36 \xt 1 إِج. 2‏:‏10؛ ڒخ. 2‏:‏29. \x*  
\v 37 مَاشَا وَانِيثَا، ونِّي د-إِسّْنكَّارْ أَربِّي، وَارْ إِتّْكِيشِّي.   
\m
\v 38 س ؤُيَا، \add أَ\add* ثَاوْمَاثْ، سْنمْ أَقَا س وَا إِتّْوَابَارّحْ س وغْفَارْ ن دّْنُوبْ إِ كنِّيوْ، \x ◘ \xo 13:‏38 \xt لك. 24‏:‏47؛ 1 يُوح. 2‏:‏12\x*  
\v 39 ؤُ \add سْنمْ\add* أَقَا زِي مَارَّا مِينْ زِي وَارْ ثْزمَّارمْ أَذْ ثتّْوَاسڭّْذمْ س شَّارِيعَا ن مُوسَا، أَقَا أَذْ تّْوَاسڭّْذنْ مَارَّا إِنِّي يُومْننْ زَّايسْ نتَّا. \x ◘ \xo 13:‏39 \xt رُوم. 3‏:‏28؛ 8‏:‏3؛ 10‏:‏4؛ ڭال. 2‏:‏16؛ عبر. 7‏:‏19. \x*  
\v 40 حْضَامْ خنِّي حِيمَا وَارْ خَاومْ د-إِوطِّي شَا ن مِينْ يُورَانْ ذڭْ \add إِذْلِيسنْ ن\add* إِنَابِييّنْ:   
\b  
\m
\v 41 \qt ’خْزَارمْ، \+tl أَ\+tl* كنِّيوْ إِنِّي إِتّْبُوصَارنْ،\qt*  
\m \qt ثْعجْبمْ ؤُ ثْودَّارمْ،\qt*  
\m \qt مِينْزِي نشّْ أَذْ ڭّغْ إِشْثْ ن ڒْخذْمثْ\qt*  
\m \qt ذڭْ وُوسَّانْ نْومْ\qt*  
\m \qt إِ وَارْ ثتِّيقِّيمْ\qt*  
\m \qt وَاخَّا إِعَاوذْ أَومْ ت شَا ن إِجّنْ.‘ “\qt* \x ◘ \xo 13:‏41 \xt إِشا. 28‏:‏14؛ حَاب. 1‏:‏5. \x*   
\b  
\m
\v 42 ڒَامِي زَّايْسنْ د-فّْغنْ، تَّارنْ زَّايْسنْ حِيمَا أَذْ كِيسنْ سِّيوْڒنْ س وَاوَاڒنْ ذ إِجّنْ ذڭْ إِجّْ ن سّبْثْ نّغْنِي.  
\v 43 ڒَامِي إِمّْسبْضَا \add ؤُمُونِي ن\add* ثمْزِيذَا، أَطَّاسْ ن وُوذَاينْ ذ وَاطَّاسْ ن إِمْعَاشَارنْ ن وُوذَاينْ إِنِّي إِتّڭّْوذنْ أَربِّي ضْفَارنْ بُولُوسْ ذ بَارْ-نَابَا. نِيثْنِي ثُوغَا كِيسنْ سَّاوَاڒنْ،عڒْمنْ أَسنْ حِيمَا أَذْ قِّيمنْ تّطّْفنْ ذڭْ أَرْضَا ن أَربِّي. \x ◘ \xo 13:‏43 \xt ڒخ. 11‏:‏23؛ 14‏:‏22. \x*   
\m
\v 44 ذِي سّبْثْ إِ د-يُوسِينْ ثُوسَا-د ثنْذِينْثْ مَارَّا حِيمَا أَذْ ثْسڒْ إِ وَاوَاڒْ ن أَربِّي.  
\v 45 أَڒَامِي ژْرِينْ وُوذَاينْ ڒْغَاشِي ذ أَمقّْرَانْ، ذوْڒنْعمَّارنْ س ڒحْسذْ،عكْسنْ مِينْ خفْ إِسِّيوڒْ بُولُوسْ، قَاشْحنْ ؤُ شقّْفنْ \add ذَايسْ\add*.  
\v 46 مَاشَا بُولُوسْ ذ بَارْ-نَابَا نَّانْ س ثرْيَاسْثْ: ”ثُوغَا إِتّْڒِيقْ أَذْ أَومْ نسِّيوڒْ ذ أَمزْوَارُو أَوَاڒْ ن أَربِّي، مَاشَا ؤُمِي ث ثُوڭِيمْ، ؤُ ثكّْسمْ أَوَاڒْ ضِيدّْ إِ يِيخفْ نْومْ بلِّي وَارْ ثسْذِيهدْجمْ ثُوذَارْثْ إِتّْذُومَانْ، خْزَارْ، أَقَا \add ڒخُّو\add* نشِّينْ أَذْ نْوجّهْ ڒڭْنُوسْ. \x ◘ \xo 13:‏46 \xt ؤُف. 32‏:‏10؛ إِشا. 55‏:‏5؛ مت. 8‏:‏12؛ 10‏:‏6؛ 21‏:‏43؛ ڒخ. 3‏:‏26؛ 13‏:‏26؛ رُوم. 10‏:‏19. \x*  
\v 47 مِينْزِي أَمُّو ذ أَنغْ إِوصَّا سِيذِيثْنغْ، إِقَّارْ:  
\b  
\m \qt ’نشّْ أَرِّيغْ شكْ ذ ثَافَاوْثْ إِ ڒڭْنُوسْ،\qt*  
\m \qt حِيمَا أَذْ ثِيڒِيذْ إِ ثُوذَارْثْ أَڒْ طّْرُوفَا ن دُّونشْثْ.‘ “\qt* \x ◘ \xo 13:‏47 \xt إِشا. 42‏:‏6؛ 49‏:‏6؛ لك. 2‏:‏32. \x*   
\b  
\m
\v 48 ؤُمِي سْڒِينْ ڒڭْنُوسْ مَانْ أَيَا، فَارْحنْ سّمْغَارنْ أَوَاڒْ ن سِيذِي ؤُشَا ؤُمْننْ مَارَّا إِنِّي ثُوغَا إِتّْوَافَارْزنْ إِ ثُوذَارْثْ إِتّْذُومَانْ.  
\v 49 ؤُشَا إِفّغْ أَوَاڒْ ن سِيذِي غَارْ جِّيهثْ نِّي مَارَّا.   
\m
\v 50 مَاشَا ؤُذَاينْ سّْحَارّْشنْ إِمْشنّْعنْ ن ثنْذِينْثْ ذ ثمْغَارِينْ ثِينِّي غَارْسنْثْ شَّانْ ؤُعبّْذنْثْ إِ أَربِّي أَكِيذْسنْ. أَمُّو سّكَّارنْ نِيثْنِي إِشْثْ ن ؤُمَارّثْ خْ بُولُوسْ ذ بَارْ-نَابَا ؤُشَا سُّوفّْغنْ ثنْ بَارَّا إِ ثمُّورْثْ نْسنْ. \x ◘ \xo 13:‏50 \xt 2 تِيم. 3‏:‏11. \x*  
\v 51 مَاشَا نِيثْنِي زّرْزنْ ثَاعجَّاجْثْ زڭْ إِضَارنْ نْسنْ خَاسنْ ؤُشَا إِوْضنْ غَارْ ثنْذِينْثْ ن إِكُونِييَا.\x ◘ \xo 13:‏51 \xt مت. 10‏:‏14؛ مك. 6‏:‏11؛ لك. 9‏:‏5؛ 10‏:‏11\x*  
\v 52 إِمحْضَارنْ ذوْڒنْ شُّورنْ س ڒفْرَاحثْ ن أَرُّوحْ إِقدّْسنْ. \x ◘ \xo 13:‏52 \xt ڒخ. 13‏:‏52؛ ڭال. 5‏:‏22؛ 1 Th. 1‏:‏6\x*   
\b  
\b  
\m  
\c 14
\s1 پُولُوسْ ذ بَارْنَابَا رُوحنْ غَارْ إِكُونِييَا ذِي لِيكَاعُونْيَا  
\m
\v 1 ذڭْ إِكُونِييَا ؤُذْفنْ نِيثْنِي جْمِيعْ غَارْ ثمْزِيذَا ن وُوذَاينْ ؤُشَا سِّيوْڒنْ أَڒَامِي ؤُمْننْ أَطَّاسْ ن ڒْغَاشِي، أَمْ وُوذَاينْ أَمْ إِيُونَانِييّنْ.  
\v 2 مَاشَا ؤُذَاينْ إِنِّي وَارْ يُومِيننْ، سّكَّارنْ \add إِرْيَازنْ ن ثنْذِينْثْ إِ يدْجَانْ زِي\add* ڒڭْنُوسْ، مَاحنْذْ أَذْ سّْعِيدْجْثنْ ثَاوْمَاثْ.  
\v 3 \add وَاخَّا أَمنِّي\add* كِّينْ ذِينِّي أَطَّاسْ نْ ڒْوقْثْ، تّْبَارّْحنْ س بْطَايْطَايْ س سِيذِي. ؤُ نتَّا ثُوغَا إِتِّيشْ شّْهَاذثْ إِ وَاوَاڒْ ن أَرْضَا نّسْ س ڒعْڒَامَاثْ ذ ڒعْجَايبْ إِ إِڭَّا س إِفَاسّنْ نْسنْ. \x ◘ \xo 14:‏3 \xt مك. 16‏:‏20؛ ڒخ. 19‏:‏11؛ عبر. 2‏:‏4. \x*  
\v 4 مَارَّا ڒْغَاشِي \add ن إِمزْذَاغْ\add* ن ثنْذِينْثْ إِمّْسبْضَا. شَا \add زَّايْسنْ\add* رُوحنْ أَكْ-ذ وُوذَاينْ ؤُ شَا نّغْنِي أَكْ-ذ رُّوسُولْ.  
\v 5 ثُوغَا ذِينْ إِشْثْ ن ثْمعْمُوتْشْ خَاسنْ زڭْ يِينِّي زِي ڒڭْنُوسْ ؤُ زڭْ وُوذَاينْ أَكْ-ذ إِمقّْرَاننْ نْسنْ، حِيمَا أَذْ خَاسنْ كَارْفْسنْ ؤُ حِيمَا أَذْ ثنْ أَرجْمنْ.  
\v 6 ڒَامِي سّْننْ مَانْ أَيَا، فّْغنْ-د ؤُشَا أَروْڒنْ غَارْ ثْندَّامْ ن لِيكَاعُونْيَا، أَقَا أَثنْ ذ لِيسْثْرَا ذ ذِيرْبِي، ؤُ غَارْ ذْشُورَاثْ إِ ذ أَسْ د-إِنّْضنْ، \x ◘ \xo 14:‏6 \xt مت. 10‏:‏23؛ ڒخ. 8‏:‏1. \x*  
\v 7 ؤُشَا تّْبَارّْحنْ ذِينِّي س ڒخْبَارْ أَصبْحَانْ.   
\b  
\m  
\s1 أَبَارّحْ ذ ؤُحجَّارْ ن بُولُوسْ ذِي لِيسْثْرَا  
\m
\v 8 ثُوغَا إِزدّغْ إِجّْ ن ورْيَازْ ذِي لِيسْثْرَا ونِّي ذ أَنعْضَابْ ذڭْ إِضَارنْ نّسْ، أَقَا-ث ذ أَقجْذَاحْ زڭْ ؤُعذِّيسْ ن يمَّاسْ، وَارْ يُويُورْعمَّارْصْ. \x ◘ \xo 14:‏8 \xt ڒخ. 3‏:‏2. \x*  
\v 9 ثُوغَا إِتّسْڒَا إِ بُولُوسْ أَمْ إِسَّاوَاڒْ نتَّا. ڒَامِي ث إِژْرَا بُولُوسْ، يُوشَا أَقَا ذَايسْ لْ-إِيمَانْ حِيمَا أَذْ إِتّْوَاسّْڭنْفَا.  
\v 10 إِنَّا أَسْ س إِشْثْ ن ثْمِيجَّا ثجْهذْ: ”أَذْ أَشْ إِنِيغْ ذڭْ يِيسمْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، كَّارْ، ثْبدّذْ نِيشَانْ خْ إِضَارنْ نّشْ!“ إِنْڭزْ، إِكَّارْ، ؤُشَا إِڭُّورْ.   
\m
\v 11 ڒَامِي إِژْرَا ڒْغَاشِي مِينْ إِڭَّا بُولُوسْ، سّْڭعّْذنْ ثْمِيجَّا نْسنْ، نَّانْ س ڒْهَارْذْ ن ثمُّورْثْ نِّي: ”أَقَا إِربِّيثنْ ذوْڒنْ أَروْسنْ ذڭْ إِوْذَانْ، هْوَانْ-د غَارْنغْ!“ \x ◘ \xo 14:‏11 \xt ڒخ. 28‏:‏6. \x*  
\v 12 نِيثْنِي سمَّانْ بَارْ-نَابَا س يِيسمْ ’سِيذِي ن إِربِّيثنْ‘، ؤُ بُولُوسْ س يِيسمْ ’هِيرْمِيسْ‘، مِينْزِي نتَّا إِزْوَارْ غَارْ وَاوَاڒْ.  
\v 13 أَكهَّانْ ن ’سِيذِي ن إِربِّيثنْ‘ ثُوغَا بَارَّا إِ ثنْذِينْثْ، يِيوِي إِينْذُوزنْ ذ ثْسذِّييِينْ ن نُّووَّاشْ غَارْ ثِيوُّورَا ن ڒمْرَاحْ مَانِي قِّيمنْ، ثُوغَا إِخْسْ أَذْ ثنْ إِقدّمْ ذ ثْغَارْصْثْ إِ نِيثْنِي.   
\m
\v 14 ڒَامِي سْڒِينْ بَارْ-نَابَا ذ بُولُوسْ خْ مَانْ أَيَا، شَارّْڭنْ أَرُّوضْ نْسنْ، نڭْزنْ، فّْغنْ غَارْ بَارَّا جَارْ ڒْغَاشِي، سْغُويُّونْ، نَّانْ:  
\v 15 ”\add أَ\add* إِرْيَازنْ، مِينْ إِ ثتّڭّمْ؟ ؤُڒَا ذ نشِّينْ ذ لْبَاشَارْ ذ إِجّنْ أَمْ كنِّيوْ، نتّْبَارّحْ كنِّيوْ حِيمَا أَذْ ثْبعّْذمْ خْ ثْمسْڒَايِينْ-أَ إِبطّْڒنْ، حِيمَا أَذْ ثُوبمْ غَارْ أَربِّي إِدَّارنْ إِ د-إِخڒْقنْ أَجنَّا ذ ثمُّورْثْ ذ ڒبْحَارْ ذ مَارَّا مِينْ ذَايْسنْ. \x ◘ \xo 14:‏15 \xt أَمز. 1‏:‏1؛ إِزهد. 33‏:‏6؛ 124‏:‏8؛ 146‏:‏6؛ ڒخ. 10‏:‏26؛ أَسَا. 14‏:‏7؛ 19‏:‏10؛ 22‏:‏9. \x*  
\v 16 ذِي ڒْوقْثْ ن ڒجْيُوڒْ إِعْذُونْ إِجَّا نتَّا مَارَّا ڒڭْنُوسْ أَذْ ؤُيُورنْ ذڭْ إِبْرِيذنْ نْسنْ، \x ◘ \xo 14:‏16 \xt إِزهد. 81‏:‏13. \x*  
\v 17 وَاخَّا وَارْ إِجِّي إِخفْ نّسْ بْڒَا شّْهَاذثْ أَمْ ذ أَسنْ إِوْشَا ثْشُونِي زڭْ ؤُجنَّا، إِسّهْوَا-د أَنْژَارْ ؤُ إِوْشَا أَطَّاسْ ن ڒْغِيدْجثْ ذِي ڒْوقْثْ نْسنْ \add إِتّْوَاڭّنْ\add* ؤُشَا إِسّْجِيونْ ؤُڒَاونْ نّغْ س مَاشَّا ذ ڒفْرَاحثْ.“ \x ◘ \xo 14:‏17 \xt رُوم. 1‏:‏19. \x*  
\v 18 وَاخَّا سَّاوَاڒنْ أَمنِّي، ثُوغَا عَاذْ إِقْسحْ خَاسنْ أَذْ سّْبدّنْ ڒْغَاشِي، مَاحنْذْ ؤُڒَا ذ إِجّْ وَارْ إِتّْقذِّيمْ ثِيغَارْصِينْ إِ نِيثْنِي.   
\m
\v 19 مَاشَا ؤُسِينْ-د وُوذَاينْ زِي إِكُونِييَا ذ أَنْثِييُوخِييَا، سّْحَارّْشنْ خَاسنْ ڒْغَاشِي ؤُشَا أَرجْمنْ بُولُوسْ، جَارّنْ ث بَارَّا إِ ثنْذِينْثْ، مِينْزِي إِتّْغِيڒْ أَسنْ أَقَا إِمُّوثْ. \x ◘ \xo 14:‏19 \xt 2 كُور. 11‏:‏25. \x*  
\v 20 مَاشَا أَمْ ذ أَسْ د-نّْضنْ إِمحْضَارنْ، إِكَّارْ ؤُشَا يُوذفْ غَارْ ثنْذِينْثْ. خنِّي ثِيوشَّا نّسْ إِفّغْ أَكْ-ذ بَارْ-نَابَا، إِوْضنْ نِيثْنِي غَارْ ثنْذِينْثْ ن ذِيرْبِي.   
\b  
\m  
\s1 أَعْقَابْ غَارْ أَنْثِييُوخِييَا ذِي سُورْيَا  
\m
\v 21 ؤُمِي بَارّْحنْ س ڒخْبَارْ أَصبْحَانْ إِ إِمزْذَاغْ ن ثنْذِينْثْ نِّي، ڭِّينْ أَطَّاسْ ن إِمحْضَارنْ. خنِّيعقْبنْ غَارْ لِيسْثْرَا ذ إِكُونِييَا ذ أَنْثِييُوخِييَا،  
\v 22 ڭِّينْ ؤُڒْ ذِي ڒعْمُورْ ن إِمحْضَارنْ،عڒْمنْ أَسنْ أَذْ شبَّارنْ ذِي لْ-إِيمَانْ، نَّانْ أَسنْ بلِّي إِتّْخصَّا أَذْ نَاذفْ غَارْ ثْڭلْذِيثْ ن أَربِّي س وَاطَّاسْ ن ڒمْحَايمْ. \x ◘ \xo 14:‏22 \xt مت. 10‏:‏38؛ 16‏:‏24؛ لك. 24‏:‏26؛ ڒخ. 11‏:‏23؛ 13‏:‏43؛ 2 تِيم. 3‏:‏12. \x*  
\v 23 أَرشّْحنْ إِمْغَارنْ ذِي كُوڒْ ثَامسْمُونْثْ أَمْ تّْژُومَانْ ؤُ تّْژَادْجَانْ أَكِيذْسنْ، ؤُشَا خنِّي سلّْمنْ ثنْ إِ سِيذِيثْنغْ إِ ذِي ؤُمْننْ نِيثْنِي.  
\v 24 خَاسْ ؤُشَا ژْوَانْ بِيسِيذِييَا، ؤُسِينْ-د غَارْ بَامْفِيلِييَا.  
\v 25 أَوَارْنِي ڒَامِي سِّيوْڒنْ س وَاوَاڒْ ن سِيذِي ذِي بِيرْخَا، هْوَانْ-د غَارْ أَتَّالْيَا.  
\v 26 سّنِّي رُوحنْ ذِي ڒبْحَارْ غَارْ أَنْثِييُوخِييَا مِينْزِي سّنِّي ثُوغَا تّْوَاسّْقبّْضنْ إِ أَرْضَا ن سِيذِي ذِي طّْوعْ ن ڒْخذْمثْ ثنِّي أَقَا كمّْڒنْ. \x ◘ \xo 14:‏26 \xt ڒخ. 13‏:‏1. \x*  
\v 27 ڒَامِي ذِينْ إِوْضنْ، ڒَاغَانْ خْ ثْمسْمُونْثْ، خبَّارنْ س مَارَّا ڒخْذَايمْ ثِيمقّْرَانِينْ إِ يڭَّا أَربِّي س إِفَاسّنْ نْسنْ ؤُ مَامّشْ يَارْزمْ ثَاوَّارْثْ ن لْ-إِيمَانْ إِ ڒڭْنُوسْ.  
\v 28 ؤُشَا قِّيمنْ ذِينْ إِشْثْ ڒْوقْثْ ذ أَزِيرَارْ أَكْ-ذ إِمحْضَارنْ. *   
\b  
\b  
\m  
\c 15
\s1 أَڭْرَاوْ ن رُّوسُولْ ذِي ؤُرْشَالِيمْ  
\m
\v 1 هْوَانْ-د يرْيَازنْ زِي يَاهُوذِييَّا \add غَارْ أَنْثِييُوخِييَا\add* ؤُشَا بْذَانْ سّڒْمَاذنْ إِ ثَاوْمَاثْ، نَّانْ: ”مَاڒَا وَارْ ثتّْوَاخثْنمْ عْلَاحْسَابْ ثْنَامِيثْ ن شَّارِيعَا \add ن مُوسَا\add*، وَارْ ثْزمَّارمْ أَذْ ثتّْوَاسّْنجْممْ.“ \x ◘ \xo 15:‏1 \xt أَمز. 17‏:‏10؛ لَاوِي 12‏:‏3؛ ڭال. 5‏:‏2. \x*  
\v 2 إِكَّارْ إِجّْ ن ؤُخَارْوضْ ذ ؤُنَاقشْ أَكِيذْسنْ زِي طَّارْفْ ن بُولُوسْ ذ بَارْ-نَابَا. إِمْسَارْ أَقَا بُولُوسْ ذ بَارْ-نَابَا، ؤُ أَكِيذْسنْ عَاذْ إِنّغْنِي، رُوحنْ غَارْ رُّوسُولْ ذ إِمْغَارنْ ذِي ؤُرْشَالِيمْ زِي سِّيبّثْ ن ؤُنَاقشْ-أَ. \x ◘ \xo 15:‏2 \xt ڭال. 2‏:‏1. \x*   
\m
\v 3 ثسّْقبّضْ ؤُ ثسّكّْ إِ-ثنْ ثْمسْمُونْثْ. نِيثْنِي شُوقنْ ذِي مَارَّا فِينِيقِييَا ذ ثمُّورْثْ ن سَامَارْيَا ؤُشَا خبَّارنْ مَامّشْ ثُوبنْ إِنِّي إِدْجَانْ زِي ڒڭْنُوسْ، سّْفَارْحنْ مَارَّا ثَاوْمَاثْ أَطَّاسْ.  
\v 4 ڒَامِي إِوْضنْ غَارْ ؤُرْشَالِيمْ، ثَارحّبْ زَّايْسنْ ثْمسْمُونْثْ ذ رُّوسُولْ ذ إِمْغَارنْ ؤُ نِيثْنِي خبَّارنْ \add إِ-ثنْ\add* س مَارَّا مِينْ زَّايْسنْ إِڭَّا أَربِّي.   
\m
\v 5 مَاشَا شَا زِي ثبْرِيذْثْ ن إِفَارِيسِييّنْ إِنِّي إِذوْڒنْ ؤُمْننْ، كَّارنْ، نَّانْ: ”إِتّْخصَّا أَذْ ثنْ ثْخثْنمْ ؤُ أَذْ ثنْ ؤُمُورنْ أَذْ شبَّارنْ ذِي شَّارِيعَا ن مُوسَا.“   
\m
\v 6 مُوننْ رُّوسُولْ ذ إِمْغَارنْ حِيمَا أَذْ مْشَاوَارنْ خْ ثْمسْڒَاشْثْ-أَ.  
\v 7 أَوَارْنِي ڒَامِي ثُوغَا تّْقَاشَاحنْ أَطَّاسْ، إِبدّْ شِيمْعُونْ، إِنَّا أَسنْ: ”أَ إِرْيَازنْ ثَاوْمَاثْ، كنِّيوْ ثسّْنمْ بلِّي أَطَّاسْ زڭْ وَامِي أَربِّي إِخْضَارْ أَقَا ڒڭْنُوسْ أَذْ سْڒنْ إِ وَاوَاڒْ ن ڒخْبَارْ أَصبْحَانْ س ؤُقمُّومْ إِنُو ؤُشَا أَذْ \add زَّايسْ\add* أَمْننْ. \x ◘ \xo 15:‏7 \xt ڒخ. 10‏:‏20؛ 11‏:‏12. \x*  
\v 8 أَربِّي، ونِّي إِسّْننْ مِينْ إِدْجَانْ ذڭْ وُوڒَاونْ، إِشْهذْ خَاسنْ أَمْ ذ أَسنْ إِوْشَا أَرُّوحْ إِقدّْسنْ أَمْ إِ نشِّينْ. \x ◘ \xo 15:‏8 \xt 1 إِم. 28‏:‏9؛ 29‏:‏17؛ إِزهد. 7‏:‏10؛ إِرْم. 11‏:‏20؛ 17‏:‏10؛ 20‏:‏12. \x*  
\v 9 نتَّا وَارْ إِتّڭّْ بُو ڒْفَارْزْ جَارْ نشِّينْ ذ نِيثْنِي، أَمْ إِسِّيزْذڭْ ؤُڒَاونْ نْسنْ س لْ-إِيمَانْ. \x ◘ \xo 15:‏9 \xt ڒخ. 10‏:‏43، 44. \x*  
\v 10 إِوَا ڒخُّو، مَايمِّي ثتّْجَارَّابمْ عَاذْ أَربِّي ؤُ ثتّڭّمْ إِجّْ ن ؤُزَايْڒُو خْ إِرَاونْ ن إِمحْضَارنْ إِ وَارْ زمَّارنْ ڒجْذُوذْ نّغْ ؤُڒَا ذ نشِّينْ أَذْ ث نَارْبُو؟ \x ◘ \xo 15:‏10 \xt مت. 23‏:‏4. \x*  
\v 11 مَاشَا س أَرْضَا ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ نُومنْ أَقَا أَذْ نطّفْ ثُوذَارْثْ أَمْ نِيثْنِي.“ \x ◘ \xo 15:‏11 \xt أَفا. 2‏:‏8؛ ثِيث. 3‏:‏4. \x*   
\m
\v 12 إِسْقَارْ ڒْغَاشِي، نِيثْنِي سْڒَانْ إِ بَارْ-نَابَا ذ بُولُوسْ تّْعَاوَاذنْ خْ ڒعْڒَامَاثْ ذ ڒعْجَايبْ ثِيمقّْرَانِينْ إِ زَّايْسنْ إِڭَّا أَربِّي جَارْ ڒڭْنُوسْ.  
\v 13 ؤُمِي قِّيمنْ سْقَارنْ، إِكَّارْ يَاعْقُوبْ، إِنَّا: ”\add أَ\add* إِرْيَازنْ ثَاوْمَاثْ، سْڒمْ-د غَارِي.  
\v 14 شِيمْعُونْ إِخبَّارْ مَامّشْ ثُوغَا إِڭَّا أَربِّي ذڭْ ؤُمزْوَارْ حِيمَا أَذْ إِخْذَارْ إِجّْ ن ڒْڭنْسْ زِي ڒڭْنُوسْ إِ يِيسمْ نّسْ.  
\v 15 مَانْ أَيَا إِتَّاسْ-د أَكْ-ذ وَاوَاڒنْ ن إِنَابِييّنْ أَمْ مَامّشْ ثُورَا:   
\b  
\m
\v 16 \qt ” ’أَوَارْنِي مَانْ أَيَا أَذْ د -عقْبغْ\qt*  
\m \qt ؤُشَا أَذْ سّْبدّغْ \+tl عَاوذْ\+tl*\qt*  
\m \qt ثَازذِّيغْثْ إِوْضَانْ ن ذَاوُوذْ،\qt*  
\m \qt ؤُ مِينْ زَّايسْ يَاردّْدْجنْ\qt*  
\m \qt أَذْ ت سّْڭعّْذغْ\qt*  
\m \qt ؤُشَا أَذْ ت أَرقّْعغْ عَاوذْ،\qt*   
\m
\v 17 \qt حِيمَا مِينْ إِقِّيمنْ ن إِوْذَانْ\qt*  
\m \qt أَذْ أَرْزُونْ خْ سِيذِي،\qt*  
\m \qt ؤُڒَا ذ مَارَّا ڒڭْنُوسْ\qt*  
\m \qt إِ خفْ إِتّْوَاڒَاغَا س يِيسمْ إِنُو!‘،\qt*  
\m \qt \+tl أَمُّو\+tl* إِ إِقَّارْ سِيذِي\qt*  
\m \qt ونِّي إِڭِّينْ مَارَّا أَيَا.“\qt* \x ◘ \xo 15:‏17 \xt عَام. 9‏:‏11، 12. \x*   
\b  
\m
\v 18 ڒخْذَايمْ ن أَربِّي أَقَا تّْوَاسّْننْثْ زِي ڒبْذَا.  
\v 19 س ؤُينِّي تّْوَاڒِيغْ إِشُووَّارْ وَارْ نسّضْقِيڒْ شَا خْ يِينِّي د-إِدَّاكّْوَاڒنْ غَارْ أَربِّي زِي ڒڭْنُوسْ،  
\v 20 مَاشَا أَذْ أَسنْ نَارِي حِيمَا أَذْ بعّْذنْ خْ ثخْمُوجِي زِي ثْغَارْصَا \add إِ لْ-أَصْنَامْ\add* ؤُ خْ فَارْقْ-شّْغڒْ ؤُ خْ جِّييْفَاثْ ؤُ خْ إِذَامّنْ. \x ◘ \xo 15:‏20 \xt أَمز. 9‏:‏4؛ ؤُف. 20‏:‏3؛ 1 كُور. 8‏:‏1؛ 10‏:‏20؛1 تس. 4‏:‏3. \x*  
\v 21 مِينْزِي مُوسَا ثُوغَا غَارسْ ذِي كُوڒْ ثَانْذِينْثْ إِمْخطَّابنْ ذِي ثمْزِيذَاوِينْ ذِي ڒجْيُوڒْ إِعْذُونْ، إِنِّي زَّايسْ قَّارنْ ذِي مَارَّا ؤُسَّانْ ن سّبْثْ.“   
\b  
\m  
\s1 ثَابْرَاثْ غَارْ ثْمسْمُونْثْ ذِي أَنْثِييُوخِييَا  
\m
\v 22 خنِّي إِخْضَارنْ رُّوسُولْ ذ إِمْغَارنْ، \add جْمِيعْ\add* أَكْ-ذ مَارَّا ثَامسْمُونْثْ، إِرْيَازنْ زِي ڒْوسْطْ نْسنْ ؤُشَا سّكّنْ يَاهُوذَا، ؤُمِي قَّارنْ عَاوذْ بَارْ-سَابَا، ذ سِيلَا أَكْ-ذ بُولُوسْ ذ بَارْ-نَابَا غَارْ أَنْثِييُوخِييَا. إِرْيَازنْ-أَ ثُوغَا أَثنْ ذ إِمقّْرَاننْ جَارْ ثَاوْمَاثْ.  
\v 23 ؤُرِينْ س ؤُفُوسْ نْسنْ أَمُّو:  
\b  
\m ”رُّوسُولْ ذ إِمْغَارنْ ذ ثَاوْمَاثْ.  
\m إِ ثَاوْمَاثْ إِ يدْجَانْ ذِي أَنْثِييُوخِييَا ذ سُورِييَا ذ كِيلِيكِييَا، إِ ثَاوْمَاثْ إِ يدْجَانْ زِي ڒڭْنُوسْ. سْڒَامْ خَاومْ!   
\m
\v 24 نسْڒَا بلِّي شَا ن يِينِّي د-يُوسِينْ زِي ڒْوسْطْ نّغْ، صذْعنْ كنِّيوْ س وَاوَاڒنْ نْسنْ، سّنْهزّنْ ثَانفْسشْثْ نْومْ، قَّارنْ: ’إِتّْخصَّا أَذْ ثتّْوَاخثْنمْ ؤُ أَذْ ثطّْفمْ ذِي شَّارِيعَا!‘، ؤُمِي نشِّينْ وَارْ ذ أَسنْ نُومُورْ س مَانْ أَيَا. \x ◘ \xo 15:‏24 \xt ڭال. 2‏:‏4. \x*  
\v 25 س ؤُيَا نمْشَاوَارْ أَوَارْنِي ڒَامِي نْمُونْ مَارَّا، ؤُشَا نْفَارْزْ شَا ن يرْيَازنْ حِيمَا أَذْ ثنْ نسّكّْ غَارْومْ أَكْ-ذ إِمْعِيزّنْ نّغْ بَارْ-نَابَا ذ بُولُوسْ.  
\v 26 نِيثْنِي ذ إِرْيَازنْ إِنِّي إِطّوّْعنْ ثُوذَارْثْ نْسنْ إِ يِيسمْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 15:‏26 \xt ڒخ. 13‏:‏50؛ 14‏:‏19. \x*  
\v 27 نسّكّْ-د أَكِيذْسنْ يَاهُوذَا ذ سِيلَا، إِنِّي كنِّيوْ إِ غَا إِخبَّارنْ مَانْ أَيَا عَاوذْ س ؤُقمُّومْ نْسنْ.  
\v 28 مِينْزِي أَقَا-ث ذِي ڒْخَاضَارْ ن أَرُّوحْ إِقدّْسنْ ؤُ ذِي ڒْخَاضَارْ نّغْ، حِيمَا وَارْ خَاومْ نسّضْقِيڒْ شَا سنّجْ إِ ثِيمسْڒَايِينْ ثِينِّي لابُودَّا زَّايْسنْثْ،  
\v 29 أَقَا أَذْ ثَاڭّْوجمْ خْ مِينْ وهّْبنْ ذ ثَاغَارْصْثْ إِ لْ-أَصْنَامْ ڒَا خْ إِذَامّنْ ڒَا خْ جِّييْفَاثْ ؤُڒَا خْ فَارْقْ-شّْغڒْ! مَاڒَا ثحْضَامْ إِخفْ نْومْ زِي مَانْ أَيَا، أَذْ ثڭّمْ مْلِيحْ. إِڒِيمْ ذ إِمْثِيقَّانْ ذِي سِيذِيثْنغْ.“ \x ◘ \xo 15:‏29 \xt أَمز. 9‏:‏4؛ ؤُف. 20‏:‏3؛ لَاوِي 17‏:‏14؛ 1 كُور. 8‏:‏1؛ 1 تس. 4‏:‏3. \x*   
\b  
\m
\v 30 إِنِّي د-إِتّْوَاسّكّنْ إِوْضنْ غَارْ أَنْثِييُوخِييَا ؤُشَا سّْمُوننْ مَارَّا إِوْذَانْ، وْشِينْ أَسنْ ثَابْرَاثْ.  
\v 31 ڒَامِي ت غْرِينْ، فَارْحنْ نِيثْنِي، تّْوَاسّْفوّْجنْ.  
\v 32 س وَاوَاڒنْ أَطَّاسْ سّْجهْذنْ نِيثْنْ ثَاوْمَاثْ ؤُشَا سّْمثْننْ إِنِّي إِدْجَانْ أَكْ-ذ يَاهُوذَا ذ سِيلَا، مَاغَارْ ؤُڒَا ذ نِيثْنِي ثُوغَا أَثنْ ذ إِنَابِييّنْ.  
\v 33 أَوَارْنِي ڒَامِي قِّيمنْ ذِينِّي شَا ن ڒْوقْثْ، سّْقبّْضنْ ثنْ وَاوْمَاثنْ س ڒهْنَا حِيمَا أَذْ د-ذوْڒنْ غَارْ رُّوسُولْ.  
\v 34 مَاشَا سِيلَا ثُوغَا إِخْسْ أَذْ إِقِّيمْ ذِينِّي.   
\m
\v 35 بُولُوسْ ذ بَارْ-نَابَا قِّيمنْ ذِي أَنْثِييُوخِييَا، سّْغَارَانْ، تّْبَارّْحنْ س وَاوَاڒْ ن أَربِّي أَكْ-ذ وَاطَّاسْ إِنّغْنِي.   
\b  
\m  
\s1 أَمْسبْضِي ن بُولُوسْ ذ بَارْنَابَا  
\m
\v 36 أَوَارْنِي شَا ن وُوسَّانْ إِنَّا بُولُوسْ إِ بَارْ-نَابَا: ”أجّْ أَنغْ أَذْ نعْقبْ غَارْ ثَاوْمَاثْ ذِي كُوڒْ ثَانْذِينْثْ مَانِي ثُوغَا نتّْبَارّحْ س وَاوَاڒْ ن أَربِّي، أَذْ نَارْڭبْ مَامّشْ غَا إِفّغْ ؤُمدُّورْ نْسنْ.“  
\v 37 بَارْ-نَابَا ثُوغَا إِخْسْ أَذْ كِيسنْ إِنْذهْ يُوحَانَّا، ونِّي إِتّْكنَّانْ مَارْكُوسْ، \x ◘ \xo 15:‏37 \xt ؤُف. 20‏:‏3. \x*  
\v 38 مَاشَا بُولُوسْ ثُوغَا وَارْ إِخْسْ أَذْ ث يِيوِي، مِينْزِي \add مَارْكُوسْ\add* إِسْمحْ ذَايْسنْ ؤُمِي ثُوغَا أَثنْ ذِي بَامْفِيلِييَا، ؤُ مِينْزِي وَارْ كِيسنْ إِرُوحْ.  
\v 39 إِكَّارْ إِجّْ ن ؤُمْشُوبّشْ ذ أَمقّْرَانْ جَارْ أَسنْ أَڒَامِي مّْسبْضَانْ إِجّنْ خْ ونّغْنِي. بَارْ-نَابَا يِيوِي مَارْكُوسْ أَكِيذسْ ؤُشَا إِبحَّارْ غَارْ ثڭْزِيرْثْ ن قُوبْرُوسْ.  
\v 40 مَاشَا بُولُوسْ إِخْضَارْ سِيلَا ؤُشَا إِفّغْ، أَوَارْنِي ڒَامِي سلّْمنْ ث وَاوْمَاثنْ غَارْ أَرْضَا ن أَربِّي.  
\v 41 إِشُوقْ ذِي سُورِييَا ذ كِيلِيكِييَا، إِتّْشجَّاعْ ثِيمسْمُونِينْ.   
\b  
\b  
\m  
\c 16
\s1 ثِيمُوثِييُو إِرُوحْ أَكْ-ذ بُولُوسْ ذ سِيلَاسْ  
\m
\v 1 \add ڒَْامِي\add* د-يُوسَا غَارْ ثْندَّامْ ن ذِيرْبِي ذ لِيسْثْرَا، ثُوغَا ذِينْ إِجّْ ن ؤُمحْضَارْ قَّارنْ أَسْ ثِيمُوثِييُو. ثُوغَا نتَّا ذ مِّيسْ ن إِشْثْ ن ثمْغَارْثْ ذ ثُوذَاشْثْ ذ ڒْمُومِينَا، مَاشَا بَابَاسْ ذ أَرَامِييُو. \f ◼ \fr 16:‏1 \ft \+bd ’أَرَامِييُو‘\+bd* - ذِي ڒْمَاخْثُوطَّاثْ س يِيڒسْ ن ثْيُونَانِيثْ أَذْ نَافْ: ’أَيُونَانِي‘.\f*  
\v 2 مَارَّا ثَاوْمَاثْ ن لِيسْثْرَا ذ إِكُونِييَا شهْذنْ خَاسْ س ڒْخَارْ.  
\v 3 بُولُوسْ ثُوغَا إِخْسْ وَا أَذْ إِسَافَارْ أَكِيذسْ. \add خنِّي\add* إِكْسِي ث ؤُشَا إِخْثنْ أَسْ، مِينْزِي ؤُذَاينْ ذِي ثنْذِينْثْ نِّي سّْننْ بلِّي بَابَاسْ ذ أَرَامِييُو. \x ◘ \xo 16:‏3 \xt 1 كُور. 9‏:‏20؛ ڭال. 2‏:‏3. \x*   
\b  
\m  
\s1 أَسَافَارْ وِيسّْ ثْنَاينْ ن بُولُوسْ: مَاسِيذُونِييَا، أَثِينَا ذ كُورِينْثُوسْ  
\m
\v 4 ؤُمِي كِّينْ خْ ثْندَّامْ، تّْبَارّْحنْ، سّڒْمَاذنْ ثنْ عَاوذْ مَاحنْذْ أَذْ طّْفنْ ذِي ثِيوصَّا إِ يُورَانْ رُّوسُولْ ذ إِمْغَارنْ ذِي ؤُرْشَالِيمْ. \x ◘ \xo 16:‏4 \xt ڒخ. 15‏:‏20. \x*   
\m
\v 5 أَمُّو ذوْڒنْثْ ثْمسْمُونِينْ بدّنْثْ مْلِيحْ ذِي لْ-إِيمَانْ ؤُشَا ثُوغَا ڒْقدّْ نْسنْثْ إِمقَّارْ كُوڒْ أَسّْ.   
\b  
\m
\v 6 ؤُمِي شُوقنْ نِيثْنِي ذِي جّْوَايهْ ن فْرِيخِييَا ذ ڭَالَاطِييَا، إِمْنعْ إِ-ثنْ أَرُّوحْ إِقدّْسنْ مَاحنْذْ أَذْ بشَّارنْ س وَاوَاڒْ ن أَربِّي ذِي أَسِييَا.  
\v 7 ڒَامِي د-ؤُسِينْ غَارْ جِّيهثْ ن مِيسْيَا، أَرْزُونْ أَذْ رَاحنْ غَارْ بِيثِينِييَا، مَاشَا أَرُّوحْ ن يَاسُوع وَارْ ثنْ إِجِّي. \x ◘ \xo 16:‏7 \xt فِيل. 1‏:‏19 \x*  
\v 8 \add خنِّي\add* فّْغنْ-د زِي مِيسْيَا، هْوَانْ غَارْ ثمُّورْثْ ن ثْرُووَاسْ. \x ◘ \xo 16:‏8 \xt 2 كُور. 2‏:‏12. \x*  
\v 9 ذڭْ إِجّْ ن ڒوْحِييْ س دْجِيڒثْ إِبَانْ-د إِجّْ ن ورْيَازْ زِي مَاكِيذُونِييَا غَارْ بُولُوسْ، إِبدّْ \add ذِينِّي\add*، إِتَّارْ زَّايسْ، إِنَّا: ’هْوَا-د غَارْ مَاكِيذُونِييَا حِيمَا أَذْ أَيِي ثوْشذْ أَفُوسْ!‘  
\v 10 أَوَارْنِي ڒَامِي إِژْرَا بُولُوسْ ڒوْحِييْ-أَ، نكَّارْ ڒخْذنِّي مَاحنْذْ أَذْ نْرَاحْ غَارْ مَاكِيذُونِييَا، مِينْزِي نفْهمْ بلِّي سِيذِيثْنغْ إِڒَاغَا أَنغْ-د حِيمَا أَذْ أَسنْ نْبَارّحْ س ڒخْبَارْ أَصبْحَانْ.   
\b  
\m  
\s1 پُولُوسْ ذِي ثنْذِينْثْ ن فِيلِيبِّي - لْ-إِمَانْ ن لِيذِييَا  
\m
\v 11 أَقَا نُويُورْ ذِي ڒبْحَارْ زِي ثْرُووَاسْ ؤُشَا نْرُوحْ نِيشَانْ غَارْ سَامُوثْرَاكِي، ؤُ ثِيوشَّا نّسْ \add نْرُوحْ\add* سّنِّي غَارْ نِيياپُولِيسْ.  
\v 12 سّنِّي \add نْرُوحْ\add* غَارْ فِيلِيبِّي، ثنِّي ذ لْعَاصِيمَا ن مَاكِيذُونِييَا، ثُوغَا طّْفنْ ت إِرُومَانِييّنْ ذ ثْزذِّيغْثْ إِ نِيثْنِي. نقِّيمْ إِجّْ ن ڒْمِيجَاڒْ ن شَا ن وُوسَّانْ ذِي ثنْذِينْثْ نِّي.  
\v 13 ذڭْ وَاسّْ ن سّبْثْ نفّغْ زِي ثوَّارْثْ ن ثنْذِينْثْ غَارْ ثْمَا ن إِغْزَارْ مِينْزِي نژْرَا ذِينْ إِشْثْ ن ثَادَّارْثْ ن ثْژَادْجِيثْ. أَوَارْنِي ڒَامِي نقِّيمْ ذِينْ، نسِّيوڒْ أَكْ-ذ ثمْغَارِينْ ثِينِّي ثُوغَا إِمُوننْ \add ذِينِّي\add*.  
\v 14 إِشْثْ ن ثمْغَارْثْ نِّي إِزّنْزنْ ڒحْرَارْ، قَّارنْثْ أَسْ لُوذِييَا زِي ثنْذِينْثْ ن ثِييَاثِيرَا، ثُوغَا ثتّڭّْوذْ أَربِّي. سِيذِيثْنغْ يَارْزمْ أَسْ ؤُڒْ نّسْ حِيمَا أَذْ ثْسڒْ مْلِيحْ مِيخفْ إِسَّاوَاڒْ بُولُوسْ.  
\v 15 تّْوَاسّغْضصْ نتَّاثْ ذ أَيْثْبَابْ ن ثَادَّارْثْ نّسْ، ؤُشَا خنِّي ثتَّارْ زَّايْنغْ، ثنَّا: ”مَاڒَا س ثِيذتّْ ثتّْوَاڒَامْ بلِّي نشّْ ؤُمْنغْ ذِي سِيذِيثْنغْ، إِوَا أَرَاحمْ-د، قِّيممْ ذِي ثَادَّارْثْ إِنُو!“ ثُوغَا ثْزَاوْڭْ أَنغْ أَطَّاسْ. \x ◘ \xo 16:‏15 \xt أَمز. 19‏:‏3؛ 33‏:‏11؛ ڒقض. 19‏:‏21؛ لك. 24‏:‏29؛ عبر. 13‏:‏2. \x*   
\b  
\m  
\s1 پُولُوسْ ذ سِيلَاسْ ذِي ڒحْبسْ  
\m
\v 16 أَمْ نڭُّورْ غَارْ ثَادَّارْثْ ن ثْژَادْجِيثْ، ثمّْسڒْقَا أَكِيذْنغْ إِشْثْ ن ثَايَّا، ذَايسْ ڒَارْيَاحْ ن ثْڭزَّانْثْ، ثِيوِي-د إِجّْ ن ڒفْضڒْ إِمْغَارْ إِ أَيْثْبَابْ نّسْ س ثْڭزَّانْثْ نِّي. \x ◘ \xo 16:‏16 \xt 1 صم. 28‏:‏7؛ ڒخ. 19‏:‏24. \x*  
\v 17 نتَّاثْ ثْضفَّارْ بُولُوسْ ذ نشِّينْ، ثسْغُويُّو، ثقَّارْ: ”إِوْذَانْ-أَ ذ إِمْسخَّارنْ ن أَربِّي، أَمْعُودْجِي خْ كُوڒْشِي، نِيثْنِي تّْبَارّْحنْ إِ كنِّيوْ س وبْرِيذْ ن ثُوذَارْثْ!“  
\v 18 أَمُّو إِ ثقِّيمْ أَطَّاسْ ن وُوسَّانْ. مَاشَا بُولُوسْ، ؤُمِي ثُوغَا إِتّْخيَّاقْ خْ مَانْ أَيَا، إِنّقْڒبْ، إِنَّا إِ ڒَارْيَاحْ: ”تُّومُورغْ شكْ س يِيسمْ ن يَاسُوع لْمَاسِيحْ، فّغْ زَّايسْ.“ ؤُشَا إِفّغْ-د \add ڒَارْيَاحْ\add* ذِي ثْسَاعّثْ نِّي. \x ◘ \xo 16:‏18 \xt مك. 16‏:‏17. \x*   
\m
\v 19 ؤُمِي ژْرِينْ أَيْثْبَابْ نّسْ بلِّي أَسِيثمْ ن ڒفْضڒْ نْسنْ إِفّغْ زَّايسْ، طّْفنْ بُولُوسْ ذ سِيلَا، جَارّنْ ثنْ، إِوْينْ ثنْ غَارْ سُّوقْ. \x ◘ \xo 16:‏19 \xt 2 كُور. 6‏:‏5. \x*  
\v 20 نِيثْنِي إِوْينْ ثنْ زَّاثْ إِ إِمْخَازْنِييّنْ ؤُ زَّاثْ إِ إِمْضبَّارنْ ن ثنْذِينْثْ، نَّانْ: ”إِوْذَانْ-أَ تّْخَارْوَاضنْ ثَانْذِينْثْ نّغْ، مِينْزِي نِيثْنِي ذ ؤُذَاينْ. \x ◘ \xo 16:‏20 \xt 1 إِج. 18‏:‏17؛ ڒخ. 17‏:‏6. \x*  
\v 21 نِيثْنِي تّْبَارْحنْ أَنغْ س تَّاقَالِيذْ نِّي وَارْ إِحدْجڒْ أَذْ ثنْثْ نقْبڒْ نِيغْ أَذْ ثنْثْ نضْفَارْ، مِينْزِي نشِّينْ ذ إِرُومَانِييّنْ!“  
\v 22 إِسّْمُونْ خَاسنْ إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ. خنِّي شَارّْڭنْ إِمْخَازْنِييّنْ أَرُّوضْ نْسنْ، ؤُمُورنْ أَذْ ثنْ هتّْكنْ س ؤُركُّوضْ. \x ◘ \xo 16:‏22 \xt 2 كُور. 11‏:‏25؛ 1 تس. 2‏:‏2. \x*  
\v 23 أَوَارْنِي ڒَامِي ثنْ هتّْكنْ أَطَّاسْ س ؤُركُّوضْ، نْضَارنْ ثنْ ذِي ڒحْبسْ، ؤُمُورنْ إِ ؤُعسَّاسْ ن ڒحْبسْ حِيمَا أَذْ خَاسنْ إِعسّْ مْلِيحْ.  
\v 24 ؤُ نتَّا، ؤُمِي إِكْسِي ثَاوْصيّثْ-أَ، إِسِّيذفْ إِ-ثنْ غَارْ ذَاخڒْ قَاعْ ن ڒحْبسْ، إِقّنْ إِ-ثنْ زڭْ إِضَارنْ نْسنْ ذڭْ إِجّْ ن ڒْقَاڒبْ ن دْجُوحْ.   
\m
\v 25 ذڭْ وزْينْ ن دْجِيڒثْ ثُوغَا بُولُوسْ ذ سِيلَا تّْژَادْجَانْ ؤُ تّْسبَّاحنْ أَربِّي أَمْ ذ أَسنْ سْڒِينْ إِمحْبَاسْ. \x ◘ \xo 16:‏25 \xt أَيُوبْ 35‏:‏10؛ إِزهد. 42‏:‏9؛ ڒخ. 4‏:‏31. \x*  
\v 26 ڒخْذنِّي إِمْسَارْ إِجّْ ن ونْهزِّي ن ثمُّورْثْ ذ أَمقّْرَانْ أَڒَامِي إِتّْوَانْهزّْ ذْسَاسْ ن ڒحْبسْ، ؤُشَا ذغْيَا نُّورْزْمنْثْ مَارَّا ثِيوُّورَا ؤُشَا ذوْڒنْ إِشذِّييّنْ ن مَارَّا \add إِمحْبَاسْ\add* فسْينْ. \x ◘ \xo 16:‏26 \xt ڒخ. 5‏:‏19؛ 12‏:‏7. \x*   
\m
\v 27 ڒَامِي ذ إِفَاقْ ؤُعسَّاسْ ن ڒحْبسْ، إِژْرَا ثِيوُّورَا أَرْزْمنْثْ، إِجْبذْ سِّيفْ نّسْ، ثُوغَا إِڭُّورْ أَذْ إِنغْ إِخفْ نّسْ، إِتّْغِيڒْ أَسْ بلِّي إِمحْبَاسْ أَروْڒنْ.  
\v 28 مَاشَا بُولُوسْ إِڒَاغَا س جّهْذْ: ”وَارْ تّْضَارَّا إِخفْ نّشْ، أَقَا أَنغْ ذَا مَارَّا!“  
\v 29 خنِّي إِسَّارغْ إِجّْ ن ڒفْنَارْ، إِنْڭزْ غَارْ ذَاخڒْ، إِتَّارْجِيجِي، إِنْضَارْ إِخفْ نّسْ غَارْ إِضَارنْ ن بُولُوسْ ذ سِيلَا.   
\m
\v 30 إِسُّوفّغْ إِ-ثنْ-د غَارْ بَارَّا، إِنَّا: ”\add أَ\add* ڒجْوَاذْ، مِينْ إِتّْخصَّا أَذْ ڭّغْ حِيمَا أَذْ طّْفغْ ثُوذَارْثْ؟“ \x ◘ \xo 16:‏30 \xt لك. 3‏:‏10؛ ڒخ. 2‏:‏37؛ 9‏:‏6. \x*  
\v 31 نِيثْنِي نَّانْ أَسْ: ”أَمنْ ذِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، أَذْ ثطّْفذْ ثُوذَارْثْ، شكْ ذ \add أَيْثْبَابْ ن\add* ثَادَّارْثْ نّشْ!“ \x ◘ \xo 16:‏31 \xt يُوح. 3‏:‏16، 36؛ 6‏:‏47؛ 1 يُوح. 5‏:‏10. \x*  
\v 32 سِّيوْڒنْ أَوَاڒْ ن سِيذِي أَكِيذسْ ؤُ أَكْ-ذ مَارَّا أَيْثْبَابْ ن ثَادَّارْثْ نّسْ.   
\m
\v 33 ذِي ثْسَاعّثْ نِّي ن دْجِيڒثْ إِوْيِي ثنْ-د \add غَارسْ\add*، إِسِّيرْذْ أَسنْ إِيزِّيمنْ نْسنْ ؤُشَا ذغْيَا إِتّْوَاسّغْضصْ نتَّا أَكْ-ذ مَارَّا أَيْثْبَابْ ن ثَادَّارْثْ نّسْ.  
\v 34 خنِّي إِوْيِي ثنْ غَارْ ثَادَّارْثْ نّسْ، إِسّوْجذْ أَسنْ طَّابْڒَا، إِفَارْحْ نتَّا ذ أَيْثْبَابْ ن ثَادَّارْثْ نّسْ، مِينْزِي طّْفنْ لْ-إِيمَانْ زِي أَربِّي. \x ◘ \xo 16:‏34 \xt لك. 5‏:‏29؛ 19‏:‏6. \x*   
\m
\v 35 ؤُمِي د-يِيوضْ ؤُزِيڒْ، سّكّنْ إِمْخَازْنِييّنْ إِوقَّافنْ خْ ڒَامَانْ، حِيمَا أَذْ إِنِينْ إِ ؤُزدْجِيفْ ن ڒحْبسْ: ”ضڒْقْ أَسنْ-د إِ إِوْذَانْ نِّي.“  
\v 36 ؤُمِي إِسْڒَا أَيَا ؤُزدْجِيفْ ن ڒحْبسْ، يُوذفْ-د غَارْ ذَاخڒْ ؤُشَا إِسِّيوضْ أَوَاڒنْ-أَ غَارْ بُولُوسْ، إِنَّا: ”إِمْخَازْنِييّنْ سكّنْ-د حِيمَا أَذْ أَومْ ضڒْقنْ. خنِّي ڒخُّو، فّْغمْ، ڒُوحمْ ذِي ڒهْنَا!“  
\v 37 مَاشَا بُولُوسْ إِنَّا أَسْ: ”وَاخَّا نشِّينْ ذ إِرُومَانِييّنْ، جِّينْ أَذْ أَنغْ هتّْكنْ س ؤُركُّوضْ س بْطَايْطَايْ أَمْ وَارْ ذَايْنغْ إِدْجِي ڒْعِيبْ، نْضَارنْ أَنغْ ذِي ڒحْبسْ، ؤُشَا ڒخُّو، مَا خْسنْ نِيثْنِي أَذْ أَنغْ ضڒْقنْ س ثْنُوفّْرَا؟ لَّ، أجّْ إِ-ثنْ أَذْ د-أَسنْ س يِيخفْ نْسنْ، حِيمَا أَذْ أَنغْ ضڒْقنْ.“  
\v 38 إِوقَّافنْ خْ ڒَامَانْ رُوحنْ، سِّيوْضنْ أَوَاڒنْ-أَ نِّي ذ أَسنْ إِتّْوَانَّانْ عَاوذْ غَارْ إِزدْجِيفنْ ن ثنْذِينْثْ. ؤُشَا نِيثْنِي ڭّْوذنْ ؤُمِي سْڒِينْ أَقَا-ثنْ ذ إِرُومَانِييّنْ.  
\v 39 \add خنِّي\add* ؤُسِينْ-د غَارْسنْ، تَّارنْ زَّايْسنْ أَذْ رُوحنْ، أَذْ فّْغنْ زِي ثنْذِينْثْ. \x ◘ \xo 16:‏39 \xt مت. 8‏:‏34. \x*  
\v 40 أَوَارْنِي ڒَامِي فّْغنْ-د زِي ڒحْبسْ،عقْبنْ غَارْ لُوذِييَا، مَانِي ژْرِينْ ثَاوْمَاثْ. سّْشجّْعنْ ثنْ ؤُشَا ؤُيُورنْ.   
\b  
\b  
\m  
\c 17
\s1 پُولُوسْ ذ سِيلَاسْ ذِي ثِيسَّالُونِيكِي  
\m
\v 1 ژْوَانْ خْ أَمْفِيپُولِيسْ ذ أَپُولُّونِييَا، إِوْضنْ غَارْ ثِيسَّالُونِيكَا مَانِي ثُوغَا إِشْثْ ن ثمْزِيذَا ن وُوذَاينْ.  
\v 2 بُولُوسْ يُوذفْ-د ذِينْ غَارْسنْ، أَمْ ثُوغَا ذ لْقَاعِيذَا نّسْ. ذِي ثْڒَاثَا \add ن وُوسَّانْ\add* ن سّبْثْ إِسِّيوڒْ أَكِيذْسنْ زِي ثِيرَا \add إِقدّْسنْ\add*.  
\v 3 إِفّسَّارْ ؤُ إِسّْبيّنْ \add أَسنْ أَمُّو\add*: ”ثُوغَا إِتّْخصَّا إِ لْمَاسِيحْ أَذْ إِتّْوَاودّبْ ؤُ أَذْ د-إِكَّارْ زِي ثَادَّارْثْ ن إِمتِّيننْ. أَقَا نتَّا ذ يَاسُوع، لْمَاسِيحْ مِينْ خفْ ذ أَومْ بَارّْحغْ.“ \x ◘ \xo 17:‏3 \xt إِزهد. 22‏:‏7؛ مت. 16‏:‏21؛ لك. 24‏:‏46. \x*  
\v 4 شَا زَّايْسنْ ؤُمْننْ، مُوننْ أَكْ-ذ بُولُوسْ ذ سِيلَا، ؤُڒَا ذ أَطَّاسْ ن إِيُونَانِييّنْ إِنِّي إِتّڭّْوذنْ أَربِّي، ؤُڒَا ذ ثِيمْغَارِينْ إِشنّْعنْ، وَارْ إِدْجِي ذْرُوسْثْ زَّايْسنْثْ، \x ◘ \xo 17:‏4 \xt ڒخ. 28‏:‏24. \x*   
\m
\v 5 مَاشَا ؤُذَاينْ ذوْڒنْ تَّاسْمنْ، نذْهنْ شَا ن يرْيَازنْ إِعفَّاننْ زڭْ إِبْرِيذنْ ن ثنْذِينْثْ، سّْڭعّْذنْ إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ غَارْسنْ، سّْهَاجَانْ ثَانْذِينْثْ ؤُشَا سّكَّارَانْ ثنْ ضِيدّْ ن ثَادَّارْثْ ن يَاسُونْ، أَرْزُونْ أَذْ ثنْ سلّْمنْ إِ ڒْغَاشِي.  
\v 6 ؤُمِي وَارْ ثنْ ؤُفِينْ ذِينْ، جَارّنْ يَاسُونْ ذ وَاوْمَاثنْ إِ ذِينْ إِدْجَانْ غَارْ إِزدْجِيفنْ ن ثنْذِينْثْ، سْغُويُّونْ: ”خْزَارْ، إِنَا، إِنِّي إِسّْغوّْغنْ ثَامُّورْثْ مَارَّا، أَقَا ؤُسِينْ-د عَاوذْ ذَا! \x ◘ \xo 17:‏6 \xt ڒخ. 16‏:‏20. \x*  
\v 7 يَاسُونْ إِسِّيذفْ إِ-ثنْ غَارسْ ذ إِنوْجِيونْ، \add وَاخَّا\add* نِيثْنِي مَارَّا تّْعكّْسنْ ثِيوْصيَّاثْ ن قَايْصَارْ، قَّارنْ أَقَا ذَا أَجدْجِيذْ نّغْنِي، أَقَا-ث ذ يَاسُوع.“ \x ◘ \xo 17:‏7 \xt لك. 23‏:‏2؛ يُوح. 19‏:‏12. \x*  
\v 8 سَّارجْفنْ إِزدْجِيفنْ ن ثنْذِينْثْ ذ ڒْڭنْسْ ؤُمِي سْڒِينْ أَيَا.  
\v 9 مَاشَا أَوَارْنِي ڒَامِي طّْفنْ ڒْعَارْبُونَاثْ زِي يَاسُونْ ذ يِينّغْنِي، أَرْخُونْ أَسنْ.   
\b  
\m  
\s1 پُولُوسْ ذ سِيلَاسْ ذِي بِيرِييَا  
\m
\v 10 ڒخْذنِّي سّكّنْ ثَاوْمَاثْ بُولُوسْ ذ سِيلَا غَارْ بِيرِييَا س دْجِيڒثْ. ؤُمِي ذِينْ إِوْضنْ، رُوحنْ غَارْ ثمْزِيذَا ن وُوذَاينْ، \x ◘ \xo 17:‏10 \xt ڒخ. 9‏:‏25. \x*  
\v 11 مِينْزِي ؤُذَاينْ ذِينِّي ثُوغَا أَثنْ خَارْ زڭْ إِنِّي إِ يدْجَانْ ذِي ثِيسَّالُونِيكَا، مِينْزِي ثُوغَا خْسنْ أَذْ سْڒنْ إِ وَاوَاڒْ كُوڒْ أَسّْ، أَرزُّونْ أَذْ سّْننْ زِي ثِيرَا إِقدّْسنْ، مَا ثِيمسْڒَايِينْ-أَ أَقَا ثنْثْ أَمنِّي. \x ◘ \xo 17:‏11 \xt إِشا. 34‏:‏16؛ لك. 16‏:‏29؛ يُوح. 5‏:‏39. \x*  
\v 12 أَطَّاسْ زَّايْسنْ ؤُمْننْ، ؤُڒَا ذ أَطَّاسْ ن ثمْغَارِينْ ذ يرْيَازنْ زڭْ إِيُونَانِييّنْ.   
\m
\v 13 مَاشَا، ؤُمِي ؤُذَاينْ ن ثِيسَّالُونِيكَا سّْننْ بلِّي بُولُوسْ ثُوغَا إِتّْبَارّحْ أَوَاڒْ ن أَربِّي ذِي بِيرِييَا، ؤُسِينْ-د نِيثْنِي عَاوذْ ذِينْ، وَارْ سّْبدّنْ زڭْ ؤُسْغوّغْ ؤُ زڭْ ؤُسْخَارْوضْ جَارْ إِمزْذَاغْ \add ن ثنْذِينْثْ\add*. \x ◘ \xo 17:‏13 \xt 1 تس. 2‏:‏14. \x*  
\v 14 \add خَاسْ ؤُشَا\add* جِّينْ وَاوْمَاثنْ أَذْ إِهْوَا بُولُوسْ ڒخْذنِّي غَارْ ڒبْحَارْ، مَاشَا سِيلَا ذ ثِيمُوثِييُو قِّيمنْ ذِينْ.  
\v 15 إِنِّي إِسّْقبْضنْ بُولُوسْ، إِوْينْ ث غَارْ ثنْذِينْثْ ن أَثِينَا. خنِّي، ؤُمِي ث جِّينْ، طّْفنْ زَّايسْ إِشْثْ ن ثبْرَاثْ إِ سِيلَا ذ ثِيمُوثِييُو مَاحنْذْ نِيثْنِي أَذْ غَارسْ د-أَسنْ ذغْيَا. \x ◘ \xo 17:‏15 \xt ڒخ. 18‏:‏5. \x*   
\b  
\m  
\s1 پُولُوسْ ذِي أَثِينَا  
\m
\v 16 أَمْ ثنْ ثُوغَا إِتّْرَاجَا بُولُوسْ ذِي أَثِينَا، ثُوغَا أَرُّوحْ نّسْ إِخيّقْ ؤُمِي إِژْرَا ثَانْذِينْثْ ثشُّورْ س \add ڒخْيَاڒَاثْ ن\add* لْ-أَصْنَامْ.  
\v 17 س ؤُينِّي ثُوغَا إِسَّاوَاڒْ ذِي ثمْزِيذَا أَكْ-ذ وُوذَاينْ ؤُ أَكْ-ذ يِينِّي إِتّڭّْوذنْ أَربِّي، ؤُ ذِي سُّوقْ ؤُڒَا أَكْ-ذ إِنِّي إِ ثُوغَا إِتّْمُوننْ ذِينِّي كُوڒْ أَسّْ.  
\v 18 عَاذْ شَا ن إِفَايْلَاسُوفنْ زِي ثمْزِيذَا ن إِبِيكُورُوسْ ؤُ شَا نّغْنِي، قَّارنْ أَسْ إِسْثُووَاكِييّنْ، مْنَاقَاشنْ أَكِيذسْ. شَا \add زَّايْسنْ\add* نَّانْ: ”مِينْ إِخْسْ أَذْ يِينِي وَانِيثَا س ڒْهَارْذْ-أَ قَاعْ؟“ مَاشَا إِنّغْنِي نَّانْ: ”إِضْهَارْ-د أَقَا-ث ذ أَمْبَارّحْ ن إِربِّيثنْ إِغْرِيبنْ، مِينْزِي ثُوغَا إِتّْبَارّحْ أَسنْ س يَاسُوع ذ ثْنُوكْرَا نّسْ \add زڭْ إِمتِّيننْ\add*.  
\v 19 ؤُشَا إِوْينْ ث، نذْهنْ ث غَارْ ڒبْنِي ن ثَادَّارْثْ ن شّْرعْ ؤُمِي قَّارنْ أَرِييُوبَاڭُوسْ، نَّانْ أَسْ: ”مَا إِعدّڒْ أَذْ نسّنْ مَانْ ثَاغُورِي ن جْذِيذْ إِ ثتّْبَارّْحذْ؟“،  
\v 20 مِينْزِي شكْ ثِيوْيذْ شَا ن ثْمسْڒَايِينْ ثِيغْرِيبِينْ إِ إِمزُّوغنْ نّغْ، ؤُ نشِّينْ نخْسْ أَذْ نسّنْ مِينْ إِخْسْ أَذْ يِينِي مَانْ أَيَا.“  
\v 21 مَارَّا إِنِّي زِي أَثِينَا ذ مَارَّا إِبَارَّانِييّنْ إِنِّي ذِينْ إِقِّيمنْ، سّعْذُونْ ڒْوقْثْ مْغِيرْ حِيمَا أَذْ خبَّارنْ ؤُ حِيمَا أَذْ سْڒنْ إِشْثْ ن ڒْحَاجّثْ ن جْذِيذْ.   
\m
\v 22 إِكَّارْ-د بُولُوسْ، إِبدّْ ذِي \add ثَادَّارْثْ ن شّْرعْ قَّارنْ أَسْ\add* ’أَرِييُوبَاڭُوسْ‘، إِنَّا: ”\add أَ\add* إِرْيَازنْ ن أَثِينَا، ؤُفِيغْ بلِّي كنِّيوْ ثتّْعمَّارمْ سنّجْ إِ طَّارْفْ س ثِيڭّْوُوذِي ن شّْوَاطنْ \add زِي كُوڒْ أَغزْذِيسْ\add*.  
\v 23 مِينْزِي ؤُمِي نّْضغْ \add ذِي ثنْذِينْثْ نْومْ\add*، ژْرِيغْ ثِيمْزِيذَاوِينْ نْومْ، ؤُفِيغْ عَاوذْ إِجّْ ن ؤُعَالْطَارْ زمّنْ خَاسْ: ’إِ أَربِّي إِ وَارْ إِتّْوَاسّْننْ‘. س ؤُينِّي ونِّي ثْعبّْذمْ كنِّيوْ، أَمْ وَارْ ث ثسِّينمْ، ذ وَا إِ زِي ذ أَومْ تّْبشَّارغْ.  
\v 24 مِينْزِي أَربِّي ونِّي د-يجِّينْ دُّونشْثْ ذ مَارَّا مِينْ ذَايسْ، ونِّي إِدْجَانْ ذ سِيذِي ن ؤُجنَّا ذ ثمُّورْثْ، وَارْ إِزدّغْ شَا ذِي ثْزَاوِييِّينْ إِ إِتّْوَاڭّنْ س إِفَاسّنْ \add ن إِوْذَانْ\add*، \x ◘ \xo 17:‏24 \xt أَمز. 1‏:‏1؛ 2 إِم. 6‏:‏30؛ إِزهد. 33‏:‏6؛ 124‏:‏8؛ 146‏:‏6؛ إِشا. 66‏:‏1؛ ڒخ. 7‏:‏48؛ 14‏:‏15؛ أَسَا. 14‏:‏7. \x*  
\v 25 ؤُڒَا وَارْ خَاسْ إِتّْوَاسخَّارْ س إِفَاسّنْ ن إِوْذَانْ أَخْمِي نتَّا إِحْوَاجْ شَا، مِينْزِي نتَّا سِيمَانْثْ نّسْ إِوْشَا إِ مْكُوڒْ بْنَاذمْ ثُوذَارْثْ ذ ثْوَارِّيثْ ن نّفْسْ. \x ◘ \xo 17:‏25 \xt أَمز. 2‏:‏7. \x*  
\v 26 زڭْ إِذَامّنْ ن يِيجّنْ إِڭَّا مَارَّا ڒڭْنُوسْ ن بْنَاذمْ حِيمَا أَذْ زذْغنْ خْ وُوذمْ ن ثمُّورْثْ مَارَّا، ؤُ س ڒُومُورْ نّسْ إِفَارْزْ أَسنْ ڒْمِيجَاڒَاثْ ن ڒْوقْثْ ؤُشَا إِڭَّا إِيْمِيرنْ ن ثْزذِّيغْثْ ن إِوْذَانْ، \x ◘ \xo 17:‏26 \xt أَعَوذ. 32‏:‏8‏:‏ كُول. 1‏:‏15، 16\x*  
\v 27 حِيمَا أَذْ أَرْزُونْ خْ أَربِّي ؤُ أَذْ \add زَّايسْ\add* تَّارنْ، أَذْ ثَاغْ أَذْ ث أَفنْ س مَارَّا مِينْ زَّايسْ إِتّْوَاڭّنْ، مَاغَارْ نتَّا وَارْ إِڭّْوِيجْ شَا أَطَّاسْ خْ كُوڒْ إِجّنْ زَّايْنغْ.  
\v 28 مِينْزِي نشِّينْ ذَايسْ إِ ندَّارْ ؤُ \add ذَايسْ إِ\add* نتّنْهزَّا ؤُ \add ذَايسْ إِ\add* ندْجْ، أَمْ مَامّشْ نَّانْ شَا ن إِمِيغِيسنْ نْومْ: ’أَقَا نقَّارْصْ زَّايسْ نتَّا!‘  
\v 29 س ؤُينِّي، أَمْ د-إِقَّارْصْ بْنَاذمْ زِي أَربِّي، إِتّْخصَّا وَارْ نْحسّبْ شَا بلِّي ؤُرغْ نِيغْ نُّوقَارْثْ نِيغْ أَژْرُو إِ إِتّْوَاڭّنْ س لْفنّْ ؤُ س ثْزمَّارْ ن بْنَاذمْ، أَقَا أَثنْ أَمْ أَربِّي إِ دْجَانْ. \x ◘ \xo 17:‏29 \xt إِشا. 40‏:‏18. \x*  
\v 30 أَربِّي إِجَّا أَذْ عْذُونْثْ زّْمَانَاثْ ن ؤُودَّارْ، \add مَاشَا ڒخُّو،\add* ذِي زّْمَانْ-أَ إِتَّامَارْ إِ مَارَّا إِوْذَانْ، أَقَا إِتّْخصَّا إِ كُوڒْ بْنَاذمْ ذِي كُوڒْ أَمْشَانْ أَذْ د-إِذْوڒْ غَارْ أَربِّي! \x ◘ \xo 17:‏30 \xt لك. 24‏:‏47. \x*  
\v 31 مِينْزِي نتَّا إِڭَّا إِجّْ ن وَاسّْ إِ ذِي إِ غَا إِحْكمْ خْ مَارَّا ثَامُّورْثْ س ڒْحقّْ س إِجّْ ن بْنَاذمْ إِ إِفَارْزْ. نتَّا إِڭَّا كُوڒْ  إِجّنْ إِتّْخصَّا أَسْ مَاحنْذْ أَذْ زَّايسْ يَامنْ، ڒَامِي ث-إِ-د-إِسّْنكَّارْ زِي ثَادَّارْثْ ن إِمتِّيننْ.“   
\m
\v 32 ؤُمِي سْڒِينْ خْ ثْنُوكْرَا زِي ثَادَّارْثْ ن إِمتِّيننْ، بْذَانْ سْثْهزَّانْ س مَانْ أَيَا، مَاشَا إِنّغْنِي نَّانْ: ”إِشْثْ ن ثْوَاڒَا نّغْنِي نخْسْ أَذْ زَّايكْ نْسڒْ كْثَارْ خْ مَانْ أَيَا.“  
\v 33 أَمُّو إِفّغْ بُولُوسْ زِي ڒْوسْطْ نْسنْ.  
\v 34 شَا زَّايْسنْ ضْفَارنْ ث، ؤُمْننْ. ثُوغَا ذِييُونِيسِييُوسْ ذ إِجّنْ زَّايْسنْ، أَقَا-ث جَارْ ڒْقُوضَاثْ ن أَرِييُوبَاڭُوسْ، ؤُڒَا ذ إِشْثْ ن ثمْغَارْثْ قَّارنْ أَسْ ذَامَارِيسْ ؤُ إِنّغْنِي أَكِيذْسنْ. *   
\b  
\b  
\m  
\c 18
\s1 پُولُوسْ ذِي كُورِينْثُوسْ  
\m
\v 1 أَوَارْنِي مَانْ أَيَا إِجَّا بُولُوسْ ثَانْذِينْثْ ن أَثِينَا، يُوسَا-د غَارْ كُورِينْثُوسْ.  
\v 2 يُوفَا \add ذِينْ\add* إِجّْ ن ورْيَازْ ذ ؤُذَايْ قَّارنْ أَسْ أَكْوِيلَا. وَانِيثَا يِيوضْ-د \add ذِينْ\add* زِي بُونْطُوسْ، يُوسَا-د زِي إِطَالْيَا ذِي ڒْوقْثْ نِّي، أَكْ-ذ بْرِيسْكِيلَّا، ثَامْغَارْثْ نّسْ، مِينْزِي \add قَايْصَارْ\add* كْلُوذِييُوسْ ثُوغَا يُومُورْ مَاحنْذْ مَارَّا ؤُذَاينْ أَذْ فّْغنْ زِي رُومَا. ؤُشَا يُوسَا-د \add بُولُوسْ\add* غَارْسنْ. \x ◘ \xo 18:‏2 \xt رُوم. 16‏:‏3؛ 1 كُور. 16‏:‏19؛ 2 تِيم. 4‏:‏19. \x*  
\v 3 ؤُمِي ثُوغَا غَارسْ صّنْعثْ ذ إِشْثنْ أَكِيذْسنْ، إِقِّيمْ غَارْسنْ، إِخدّمْ أَكِيذْسنْ، مِينْزِي نِيثْنِي ثُوغَا أَثنْ ذِي صّنْعثْ نْسنْ ذ إِمْعِيشْونْ، تّڭّنْ إِقِيضَانْ. \x ◘ \xo 18:‏3 \xt ڒخ. 20‏:‏34؛ 1 كُور. 4‏:‏12؛ 2 كُور. 11‏:‏9؛ 12‏:‏13؛ 1 تس. 2‏:‏9؛ 2 تس. 3‏:‏8. \x*  
\v 4 ثُوغَا إِتّْحدَّاثْ كُوڒْ سّبْثْ ذِي ثمْزِيذَا، يَارزُّو أَذْ إِسّقْنعْ ؤُذَاينْ ذ إِكَافْرِيونْ، \add مَاحنْذْ أَذْ أَمْننْ\add*.   
\m
\v 5 ؤُمِي د-إِهْوَا سِيلَا ذ ثِيمُوثِييُو زِي مَاكِيذُونِييَا، سّْبدّنْ نِيثْنِي بُولُوسْ زڭْ ؤُبَارّحْ ن وَاوَاڒْ، مِينْزِي ؤُذَاينْ ثُوغَا تّْضَادَّانْ ث، تّْشقّْفنْ \add ذَايسْ\add* ؤُمِي إِشْهذْ أَقَا يَاسُوع نتَّا ذ لْمَاسِيحْ. \x ◘ \xo 18:‏5 \xt ڒخ. 17‏:‏15. \x*  
\v 6 إِزّرْزْ \add ثَاعجَّاشْثْ\add* زڭْ وَارُّوضْ نّسْ، إِنَّا أَسنْ: ”زِي ڒخُّو تّْبَارِيغْ إِخفْ إِنُو زَّايْومْ، \add ؤُشَا\add* أَذْ رَاحغْ غَارْ ڒڭْنُوسْ.“ \x ◘ \xo 18:‏6 \xt مت. 10‏:‏14؛ ڒخ. 13‏:‏51. \x*  
\v 7 إِرُوحْ سّنِّي ؤُشَا يُوسَا-د غَارْ ثَادَّارْثْ ن إِجّْ ن ورْيَازْ قَّارنْ أَسْ ثِيثُوسْ ونِّي ثُوغَا إِعبّْذنْ أَربِّي. ثُوغَا ثَادَّارْثْ نّسْ ثڒْصقْ أَكْ-ذ ثمْزِيذَا.  
\v 8 ؤُ كْرِيسْپُوسْ، أَمقّْرَانْ خْ ثمْزِيذَا، يُومنْ ذِي سِيذِيثْنغْ أَكْ-ذ مَارَّا أَيْثْبَابْ ن ثَادَّارْثْ نّسْ، ؤُڒَا ذ أَطَّاسْ ن إِكُورِينْثِييّنْ ؤُمِي ذ أَسْ سْڒِينْ، ؤُمْننْ ذِي أَربِّي، تّْوَاسّْغضْصنْ. \x ◘ \xo 18:‏8 \xt 1 كُور. 1‏:‏14. \x*   
\m
\v 9 \add خنِّي\add* إِنَّا سِيذِي إِ بُولُوسْ ذڭْ إِجّْ ن ڒوْحِييْ: ”وَارْ تّڭّْوذْ، سِيوڒْ، وَارْ تّْسقَّارَا، \x ◘ \xo 18:‏9 \xt ڒخ. 23‏:‏11. \x*  
\v 10 مِينْزِي نشّْ أَكِيذكْ ؤُشَا ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ شكْ إِضَارّْ، مِينْزِي غَارِي أَطَّاسْ ن إِوْذَانْ ذِي ثنْذِينْثْ-أَ!“  
\v 11 ؤُشَا إِقِّيمْ إِجّْ ن ؤُسڭّْوَاسْ ذ ستَّا ن إِيُورنْ ذِي كُورِينْثُوسْ، إِسّڒْمَاذْ أَسنْ أَوَاڒْ ن أَربِّي.   
\b  
\m  
\s1 پُولُوسْ زَّاثْ إِ غَالِييُونْ  
\m
\v 12 مَاشَا ؤُمِي ثُوغَا غَالِييُونْ لْعَامِيلْ خْ أَخَايَا، كَّارنْ وُوذَاينْ أَمْ يِيجّْ ن ورْيَازْ خْ بُولُوسْ ؤُشَا إِوْينْ ث-إِ-د غَارْ ڒْكُورْسِي ن شّْرعْ،  
\v 13 نَّانْ: ”وَا إِسّقْنَاعْ إِوْذَانْ مَاحنْذْ أَذْعبْذنْ أَربِّي س ڒْعكْسْ ن شَّارِيعَا.“  
\v 14 ؤُمِي إِتَّارْ بُولُوسْ تّسْرِيحْ مَاحنْذْ أَذْ يَارْزمْ أَقمُّومْ نّسْ، إِنَّا غَالِييُونْ إِ وُوذَاينْ: ”مَاڒَا ثُوسِيمْ-د ذَا أَكْ-ذ إِشثْشِيينْ زِي سِّيبّثْ ن إِجّْ ن ؤُفْثُورِي نِيغْ ن إِجّْ ن ڒْغشّْ نِيغْ ن إِجّْ ن نّْعِي ن ثَاعفَّانْثْ، \add أَ\add* ؤُذَاينْ، خنِّي إِڒِي أَذْ إِڒِيقْ أَذْ كنِّيوْ قبْڒغْ س ڒْحقّْ.  
\v 15 مَاشَا مَاڒَا ذِينْ إِخَارْوِيضنْ ذِي سِّيبّثْ ن إِجّْ ن وَاوَاڒْ، نِيغْ \add ذِي سِّيبّثْ ن\add* ن شَا ن إِسْمَاونْ، نِيغْ \add ذِي سِّيبّثْ ن\add* شَّارِيعَا نْومْ، حْضَامْ ث كنِّيوْ س يِيخفْ نْومْ، مِينْزِي نشّْ وَارْ خْسغْ أَذْ إِڒِيغْ ذ ڒْقَاضِي خْ ثْمسْڒَايِينْ-أَ!“  
\v 16 ؤُشَا يُوژّڒْ خَاسنْ زِي ڒْكُورْسِي ن شّْرعْ.  
\v 17 ڒخْذنِّي طّْفنْ مَارَّا لْكُوفَّارْ سُوسْثِينِيسْ، أَمْغَارْ ن ثمْزِيذَا، وْثِينْ ث قِيبَاتْشْ إِ ڒْكُورْسِي ن شّْرعْ، \add مَاشَا\add* غَالِييُونْ وَارْ ذ أَسْ إِشْقِي مَانْ أَيَا قَاعْ.   
\b  
\m  
\s1 پُولُوسْ إِعْقبْ-د غَارْ أَنْثِييُوخِييَا  
\m
\v 18 \add أَوَارْنِي ڒَامِي\add* إِقِّيمْ بُولُوسْ ذِينْ عَاذْ أَطَّاسْ ن وُوسَّانْ، إِودّعْ ثَاوْمَاثْ ؤُشَا إِبحَّارْ غَارْ سُورِييَا ؤُ بْرِيسْكِيلَّا ذ أَكْوِيلَا رُوحنْ أَكِيذسْ. نتَّا ثُوغَا إِحفّْ أَزدْجِيفْ نّسْ ذِي كِينْخْرِييُوسْ، مِينْزِي ثُوغَا إِجَّادْجْ إِشْثْ ن ثْجَادْجِيثْ. \x ◘ \xo 18:‏18 \xt ڒخْڒ. 6‏:‏18؛ ڒخ. 21‏:‏23. \x*  
\v 19 \add ؤُمِي\add* د-إِوْضنْ غَارْ أَفَاسُوسْ، يُوذفْ بُولُوسْ غَارْ ثمْزِيذَا، ثُوغَا إِتّْحدَّاثْ ؤُذَاينْ.  
\v 20 ڒَامِي زَّايسْ تَّارنْ أَذْ كِيسنْ إِقِّيمْ كْثَارْ، وَارْ إِجِّي أَذْ ث سّْقنْعنْ.  
\v 21 نتَّا إِنَّا: ”إِتّْخصَّا نِيشَانْ أَذْعيّْذغْ ڒْعِيذْ إِ د غَا يَاسنْ ذِي ؤُرْشَالِيمْ. مَاشَا أَذْ غَارْومْ د -عقْبغْ عَاوذْ مَاڒَا إِخْسْ أَربِّي!“ ؤُشَا إِجَّا أَكْوِيلَا ذ بْرِيسْكِيلَّا ذِي أَفَاسُوسْ. \x ◘ \xo 18:‏21 \xt 1 كُور. 4‏:‏19؛ عبر. 6‏:‏3؛ يَاع. 4‏:‏15. \x*  
\v 22 إِشُوقْ ڒبْحَارْ ؤُشَا يِيوضْ-د غَارْ قَايْصَارِييَا، إِڭعّذْ \add غَارْ ڒْعِيذْ ذِي ؤُرْشَالِيمْ\add*، إِسدْجمْ س ڒهْنَا خْ ثْمسْمُونْثْ، خنِّي إِسَافَارْ غَارْ أَنْثِييُوخِييَا.   
\b  
\m  
\s1 أَسَافَارْ وِيسّْ ثْڒَاثَا ن بُولُوسْ: أَفَاسُوسْ، مَاكِيذُونِييَا ذ لْيُونَانْ  
\m
\v 23 أَڒَامِي ذِينْ إِسّعْذُو إِجّْ ن ڒْمِيجَاڒْ ن شَا ن وُوسَّانْ، إِفّغْ ؤُشَا إِشُوقْ ذِي جّْوَايهْ ن ڭَالَاطِييَا ذ فْرِيخِييَا، إِسّمْحضْ مَارَّا إِمحْضَارنْ.   
\m
\v 24 إِجّْ ن ورْيَازْ، قَّارنْ أَسْ أَپُولُّوسْ، إِجّْ ن ورْيَازْ ذ ؤُذَايْ إِ د-إِتّْوَاخڒْقنْ ذِي إِسْكَانْذَارِييَّا، يُوسَا-د غَارْ أَفَاسُوسْ. نتَّا ثُوغَا ذ إِجّْ ن ورْيَازْ إِسّنْ أَذْ إِسِّيوڒْ، إِتّْحَاكَا ذڭْ إِذْلِيسنْ إِقدّْسنْ. \x ◘ \xo 18:‏24 \xt 1 كُور. 1‏:‏12. \x*  
\v 25 وَا ثُوغَا إِتّْوَاسّڒْمذْ ذڭْ وبْرِيذْ ن سِيذِي، ثُوغَا-ث س أَرُّوحْ إِمحْضنْ. إِسَّاوَاڒْ ؤُ إِسّڒْمَاذْ زِي جِّيهثْ ن يَاسُوع س شْضَارثْ، وَاخَّا نتَّا وَارْ إِسِّينْ مْغِيرْ أَسغْضصْ ن يُوحَانَّا.  
\v 26 إِبْذَا إِسَّاوَاڒْ س بْطَايْطَايْ ذِي ثمْزِيذَا. ڒَامِي ذ أَسْ سْڒِينْ أَكْوِيلَا ذ بْرِيسْكِيلَّا، إِوْينْ ث-إِ-د غَارْسنْ ؤُشَا سّْفهْمنْ أَسْ أَبْرِيذْ ن سِيذِي مَارَّا.  
\v 27 أَڒَامِي ثُوغَا إِخْسْ أَذْ إِسَافَارْ غَارْ أَخَايَا، شجّْعنْ ث وَاوْمَاثنْ، ؤُرِينْ غَارْ إِمحْضَارنْ أَذْ ث قبْڒنْ \add مْلِيحْ\add*. ؤُمِي د-يِيوضْ وَا غَارْ ذِينْ، إِعَاونْ س أَرْضَا \add إِ ذ أَسْ إِوْشِينْ\add* مَارَّا إِنِّي ثُوغَا يُومْننْ. \x ◘ \xo 18:‏27 \xt 1 كُور. 3‏:‏6. \x*  
\v 28 مِينْزِي نتَّا ثُوغَا إِتّْقَاشَاحْ س جّهْذْ ضِيدّْ ن وُوذَاينْ زَّاثْ إِ ؤُبَارُّو \add ن إِوْذَانْ\add*، إِسّْبيّنْ أَسنْ زِي ثِيرَا \add إِقدّْسنْ\add* بلِّي يَاسُوع نتَّا ذ لْمَاسِيحْ.   
\b  
\b  
\m  
\c 19
\s1 پُولُوسْ ذِي أَفَاسُوسْ  
\m
\v 1 ڒَامِي ثُوغَا أَپُولُّوسْ ذِي كُورِينْثُوسْ، إِشُوقْ بُولُوسْ ذِي جّْوَايهْ يُوعْڒَانْ، يِيوضْ-د غَارْ أَفَاسُوسْ، ؤُشَا إِبْذَا إِتّْسقْسَا إِمحْضَارنْ إِ ذِينْ يُوفَا. \x ◘ \xo 19:‏1 \xt 1 كُور. 1‏:‏12\x*  
\v 2 \add إِسّقْسَا ثنْ:\add* ”مَا ثْقبْڒمْ أَرُّوحْ إِقدّْسنْ ڒَامِي ثُومْنمْ؟“ نِيثْنِي أَرِّينْ-د خَاسْ، نَّانْ: ”وَارْ نسْڒِي قَاعْ بلِّي ذِينْ أَرُّوحْ إِقدّْسنْ.“  
\v 3 إِنَّا أَسنْ: ”خنِّي مِينْ زِي ثتّْوَاسّْغضْصمْ؟“ نَّانْ أَسْ: ”س ؤُسغْضصْ ن يُوحَانَّا!“  
\v 4 \add خنِّي\add* إِنَّا بُولُوسْ: ”ثُوغَا يُوحَانَّا إِسّغْضَاصْ ڒْڭنْسْ س ؤُسغْضصْ ن تُّوبثْ. إِقَّارْ أَسنْ إِتّْخصَّا أَذْ أَمْننْ س ونِّي إِ د غَا يَاسنْ أَوَارْنِي أَسْ، أَقَا نتَّا ذ يَاسُوع لْمَاسِيحْ.“ \x ◘ \xo 19:‏4 \xt مت. 3‏:‏11؛ مك. 1‏:‏4؛ لك. 3‏:‏16؛ يُوح. 1‏:‏26؛ ڒخ. 1‏:‏5؛ 11‏:‏16. \x*  
\v 5 أَوَارْنِي ڒَامِي سْڒِينْ ثِيمسْڒَايِينْ أَيَا، تّْوَاسّْغضْصنْ ذڭْ يِيسمْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.  
\v 6 ؤُمِي خَاسنْ إِسَّارْسْ بُولُوسْ أَفُوسْ، إِهْوَا-د خَاسنْ أَرُّوحْ إِقدّْسنْ، ؤُشَا بْذَانْ سَّاوَاڒنْ \bd س إِجّْ ن يِيڒسْ نّغْنِي\bd* ؤُشَا \add بْذَانْ\add* تّْنَابّنْ. \x ◘ \xo 19:‏6 \xt ڒخ. 8‏:‏17؛ 11‏:‏15؛ 2 تِيم. 1‏:‏6. \x*  
\v 7 ثُوغَا-ثنْ قَاعْ ثنْعَاشْ ن يرْيَازنْ.   
\m
\v 8 يُوذفْ \add بُولُوسْ\add* غَارْ ثمْزِيذَا، إِسَّاوَاڒْ أَكِيذْسنْ ثڒْثْ ن إِيُورنْ س ثرْيَاسْثْ، إِتّْحدَّاثْ غَارْسنْ، يَارزُّو أَذْ ثنْ إِسّقْنَاعْ ذِي مِينْ إِتّْهمَّانْ ثَاڭلْذِيثْ ن أَربِّي.  
\v 9 مَاشَا ڒَامِي ذوْڒنْ شَا زَّايْسنْ قسْحنْ، تّمْشُوبُّوشنْ، شقّْفنْ ذڭْ وبْرِيذْ ن أَربِّي زَّاثْ إِ يِينِّي \add ذِينْ\add* إِمُوننْ زِي ڒڭْنُوسْ، خنِّي إِڭّْوجْ بُولُوسْ خَاسنْ، ؤُشَا إِسّْبعّذْ خَاسنْ إِمحْضَارنْ، إِبْذَا إِسَّاوَاڒْ أَكِيذْسنْ كُوڒْ أَسّْ ذِي ثمْزِيذَا ن إِجّْ ن ورْيَازْ قَّارنْ أَسْ ثِيرَانُّوسْ. \x ◘ \xo 19:‏9 \xt 2 تِيم. 1‏:‏15. \x*  
\v 10 أَمُّو إِ يڭَّا ثْنَاينْ ن إِسڭّْوُوسَا أَڒَامِي مَارَّا إِنِّي ثُوغَا إِزدّْغنْ ذِي أَسِييَا سْڒِينْ أَوَاڒْ ن سِيذِي، أَمْ ؤُذَاينْ أَمْ إِرَامِييّنْ.   
\b  
\m  
\s1 ثَارْوَا ن سْكِيوَا  
\m
\v 11 ثُوغَا أَربِّي إِتّڭّْ ڒعْجَايبْ إِمقّْرَاننْ س إِفَاسّنْ ن بُولُوسْ، \x ◘ \xo 19:‏11 \xt مك. 16‏:‏20؛ ڒخ. 14‏:‏3. \x*  
\v 12 أَڒَامِي كْسِينْ ڒمْحَامَاثْ \add ن ڒقْطنْ\add* ذ وسْثَاونْ ن إِبُويَاسْ إِ إِدْجَانْ أَرُّوضْ خْ أَرِّيمثْ نّسْ، سَّارْسنْ ثنْ خْ إِمهْڒَاشْ، ؤُشَا \add خنِّي\add* رُوحنْ خَاسنْ ڒهْڒَاشَاثْ ؤُشَا شّْوَاطنْ فّْغنْ \add زَّايْسنْ\add*.   
\m
\v 13 ثُوغَا ذِينْ عَاوذْ شَا ن وُوذَاينْ إِنِّي ثُوغَا إِڭُّورنْ ذِي ثمُّورْثْ، ثُوغَا سُّوفُّوغنْ شّْوَاطنْ. نِيثْنِي تّْعزّْمنْ خْ يِينِّي ذِي إِدْجَا ڒَارْيَاحْ أَعفَّانْ س يِيسمْ ن سِيذِيثْنغْ يَاسُوع، قَّارنْ: ”نشِّينْ نتّْعزّمْ خَاكْ س يِيسمْ ن يَاسُوع إِ زِي إِتّْبَارّحْ بُولُوسْ.“  
\v 14 إِنِّي ث إِڭِّينْ، أَقَا أَثنْ سبْعَا ن ثَارْوَا ن سْكِيوَا، ونِّي ذ إِجّْ ن ؤُمقّْرَانْ ن إِكهَّاننْ ذ ؤُذَايْ.  
\v 15 \add مَاشَا\add* شِّيطَانْ أَعفَّانْ يَارَّا-د، إِنَّا أَسنْ: ”يشُّو سّْنغْ ث ؤُڒَا ذ بُولُوسْ سّْنغْ ث، مَاشَا مِينْ ثعْنَامْ كنِّيوْ؟“  
\v 16 ؤُشَا بْنَاذمْ إِ ذِي إِدْجَا ڒَارْيَاحْ ذ أَعفَّانْ إِنْڭزْ خَاسنْ، إِغڒْبْ إِ-ثنْ، إِنْضَارْ إِ-ثنْ \add خْ ثمُّورْثْ\add*، أَڒَامِي أَروْڒنْ زِي ثَادَّارْثْ ذ إِعَارْيَاننْ ذ إِيزْمنْ.   
\m
\v 17 ڒخْبَارْ-أَ إِفّغْ-د غَارْ مَارَّا وُوذَاينْ ذ إِرَامِييّنْ إِنِّي إِزدّْغنْ ذِي أَفَاسُوسْ. ثوْضَا-د إِشْثْ ن ثِيڭّْوُوذِي ثمْغَارْ خْ مَارَّا نِيثْنِي ؤُشَا إِتّْوَاسّمْغَارْ إِسمْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.  
\v 18 أَطَّاسْ ن يِينِّي يُومْننْ ؤُسِينْ-د، سْثعْثَارفنْ خْ إِعذِّييّنْ نْسنْ، نعْمنْ س مِينْ ثُوغَا تّڭّنْ. \x ◘ \xo 19:‏18 \xt مت. 3‏:‏6. \x*  
\v 19 ؤُڒَا ذ أَطَّاسْ ن إِسحَّارنْ يَارْونْ إِذْلِيسنْ نْسنْ، سّْشمّْضنْ ثنْ زَّاثْ إِ مَارَّا. نِيثْنِي ڭِّينْ أَسنْ ڒحْسَابْ ؤُشَا ؤُفِينْ بلِّي سّكّْوَانْ خمْسِينْ-أَڒَافْ ن \add ڒْْوزْنَاثْ ن\add* نُّوقَارْثْ.  
\v 20 أَمُّو ثُوغَا لْ-إِيمَانْ ن أَربِّي إِڭَّامْ، يَارنِّي ذِي جّهْذْ. \x ◘ \xo 19:‏20 \xt إِشا. 55‏:‏11 \x*   
\b  
\m  
\s1 أَخَارْوضْ ذِي أَفَاسُوسْ  
\m
\v 21 أَوَارْنِي ڒَامِي كمّْڒنْثْ ثْمسْڒَايِينْ-أَ، إِڭَّا بُولُوسْ مَاحنْذْ أَذْ إِشُوقْ ذِي مَاكِيذُونِييَا ذ أَخَايَا مَارَّا، حِيمَا أَذْ إِسَافَارْ غَارْ ؤُرْشَالِيمْ، إِنَّا: ”خْمِي ذِينْ إِ غَا رحّْڭغْ، إِتّْخصَّا أَيِي أَذْ ژَترغْ رُومَا عَاوذْ.“ \x ◘ \xo 19:‏21 \xt رُوم. 15‏:‏25؛ ڭال. 2‏:‏1. \x*  
\v 22 إِسّكّْ ثْنَاينْ ن يِينِّي ثُوغَا إِخدّْمنْ أَكِيذسْ غَارْ مَاكِيذُونِييَا، إِنَا ذ ثِيمُوثِييُو ذ إِرَاسْثُوسْ، \add مَاشَا\add* نتَّا \add سِيمَانْثْ\add* نّسْ ثُوغَا إِقِّيمْ ذِينْ \add عَاذْ\add* شَا ن ڒْوقْثْ ذِي أَسِييَا.   
\m
\v 23 ذِي ڒْوقْثْ نِّي إِكَّارْ ذِينْ إِجّْ ن ؤُخَارْوضْ ذ أَمقّْرَانْ خْ سِّيبّثْ ن وبْرِيذْ ن أَربِّي. \x ◘ \xo 19:‏23 \xt 2 كُور. 1‏:‏8. \x*  
\v 24 مِينْزِي ثُوغَا ذِينْ إِجّْ ن ؤُسِييَاغْ ن نُّوقَارْثْ، قَّارنْ أَسْ ذِيمِيثْرِييُو، ونِّي ثُوغَا إِتّْصنَّاعْ ثِيزَاوِييِّينْ ثِيمژْيَانِينْ ن نُّوقَارْثْ ن ’أَرْثِيمِيسْ‘ \add ذِي ڒقْوَاڒبْ\add*، ؤُشَا أَمُّو إِ يَارْبحْ إِ أَيْثْ ن صّنْعثْ نّسْ إِجّْ ن أَرْبحْ ذ أَمقّْرَانْ. \x ◘ \xo 19:‏24 \xt ڒخ. 16‏:‏16. \x*  
\v 25 إِسّْمُونْ-د أَيْثْ ن صّنْعثْ نّسْ أَكْ-ذ إِنِّي إِخدّْمنْ أَكِيذْسنْ، إِنَّا أَسنْ: ”أَ إِرْيَازنْ، كنِّيوْ ثسّْنمْ بلِّي مَارَّا أَرْبحْ نّغْ يُوسَا-د أَكْ-ذ صّنْعثْ-أَ.  
\v 26 كنِّيوْ ثسْڒِيمْ ؤُ ثسّْنمْ بلِّي بُولُوسْ وَانِيثَا إِسّقْنَاعْ أَطَّاسْ ن إِوْذَانْ، وَارْ إِدْجِي إِمزْذَاغْ ن أَفَاسُوسْ وَاهَا، مَاشَا ؤُڒَا ذ إِبَارُّوثنْ ن مَارَّا أَسِييَا، أَقَا إِسّْبعّذْ إِ-ثنْ \add خْ ڒخْيَاڒَاثْ-أَ\add*، إِقَّارْ: ’\add ڒخْيَاڒَاثْ-أَ\add* إِ إِتّْوَاڭّنْ س إِفَاسّنْ وَارْ دْجِينْ شَا ذ إِربِّيثنْ!‘ \x ◘ \xo 19:‏26 \xt إِزهد. 115‏:‏4؛ إِرْم. 10‏:‏3. \x*  
\v 27 وَارْ ثدْجِي ثْسبَّابْثْ-أَ وَاهَا ذِي لْخَاطَارْ ؤُشَا ثڭُّورْ أَذْ ثذْوڒْ ذ إِشْثْ ن ثْمسْڒَاشْثْ إِبطّْڒنْ، مَاشَا ؤُڒَا ذ زَّاوشْثْ ن ’أَرْثِيمِيسْ‘، ثَاربِّيثْ ثَامقّْرَانْثْ، أَذْ ت حسْبنْ ذ وَالُو ؤُشَا أَذْ سّحْقَارنْ ثَاربِّيثْ-أَ إِ ثْعبّذْ \add ثمُّورْثْ ن\add* أَسِييَا ؤُڒَا ذ مَارَّا ڒڭْنُوسْ.“   
\m
\v 28 ؤُمِي سْڒِينْ مَانْ أَيَا، ذوْڒنْ خيْقّنْ أَطَّاسْ. سْغُويُّونْ، نَّانْ: ”ثَامقّْرَانْثْ ذ \add ثَاربِّيثْ\add* ’أَرْثِيمِيسْ‘ ن إِفَاسُوسِييّنْ!“  
\v 29 ثَانْذِينْثْ قَاعْ ثْخَارْوضْ أَمْ ثكْمڒْ ؤُشَا ؤُزّْڒنْ أَمْ يِيجّْ ن بْنَاذمْ غَارْ ثِييَاثِيرْ ن لْمسْرَاحْ، ؤُشَا خَايُوسْ ذ أَرِيسْثَارْخُوسْ، إِرْيَازنْ زِي مَاكِيذُونِييَا، إِنِّي ذ إِمْعَاشَارنْ ن بُولُوسْ ذڭْ ؤُسَافَارْ نّسْ، طّْفنْ ثنْ ؤُشَا إِوْينْ ثنْ-د أَكِيذْسنْ. \x ◘ \xo 19:‏29 \xt ڒخ. 20‏:‏4؛ 27‏:‏2؛ كُول. 4‏:‏10. \x*  
\v 30 ؤُڒَا ذ بُولُوسْ ثُوغَا إِخْسْ أَذْ يَاذفْ غَارْ ثِييَاثِيرْ ن لْمسْرَاحْ، مَاشَا إِمحْضَارنْ \add نّسْ\add* سّْبدّنْ ث.  
\v 31 إِزدْجِيفنْ \add إِمْضبَّارنْ ن جّْوَايهْ\add* ن أَسِييَا، ؤُمِي ثُوغَا أَثنْ ذ إِمدُّوكَّاڒْ نّسْ، سّكّنْ عَاوذْ \add إِرقَّاسنْ\add*، مَاحنْذْ أَذْ زَايسْ تَّارنْ حِيمَا وَارْ إِتّْسبّڒْ إِخفْ نّسْ أَذْ يَاذفْ غَارْ ثِييَاثِيرْ.   
\m
\v 32 ڒْغَاشِي إِ إِتّْوَاسّْمُوننْ ذِي ثِييَاثِيرْ، ثُوغَا سّكَّارنْ ث أَطَّاسْ. نِيثْنِي سْغُويُّونْ إِجّْ إِ ونّغْنِي، مَاغَارْ أَزْينْ أَمقّْرَانْ زَّايسْ وَارْ إِسِّينْ مِيخفْ ثُوغَا مُوننْ.  
\v 33 ڒْڭنْسْ ن وُوذَاينْ إِ ذِينْ إِدْجَانْ، نذْهنْ إِجّْ ن ورْيَازْ زَّايْسنْ غَارْ زَّاثْ، إِجّْ ن وُوذَايْ قَّارنْ أَسْ أَلِيكْسَانْذِيرْ. نتَّا إِكَّارْ، إِشيَّارْ س ؤُفُوسْ نّسْ ؤُ ثُوغَا إِخْسْ أَذْ إِسِّيوڒْ خْ ؤُذَافعْ \add ن بُولُوسْ\add* زَّاثْ إِ ڒْڭنْسْ.  
\v 34 مَاشَا ؤُمِي فهْمنْ بلِّي أَقَا-ث ذ ؤُذَايْ، سْغُوينْ مَارَّا س ثْمِيجَّا ذ إِشْثنْ عْڒَاحَاڒْ ثْنَاينْ ن ثْسَاعّثِينْ: ”ثَامقّْرَانْثْ ذ ’أَرْثِيمِيسْ‘ ن إِفَاسُوسِييّنْ!“   
\m
\v 35 أَزدْجِيفْ ن ثنْذِينْثْ إِسّْهدّنْ ڒْغَاشِي، إِنَّا: ”\add أَ\add* إِرْيَازنْ ن أَفَاسُوسْ، مَانْ ونْ وَارْ إِسِّيننْ بلِّي ثَانْذِينْثْ ن إِفَاسُوسِييّنْ ذ ثَاكهَّانْثْ ثْحطَّا نِيشَانْ خْ زَّاوشْثْ ن ’أَرْثِيمِيسْ‘ ؤُ خْ ڒخْيَاڒْ إِ د-إِوْضَانْ زڭْ ؤُجنَّا!  
\v 36 س ؤُينِّي، ؤُمِي وَارْ إِزمَّارْ ؤُڒَا ذ إِجّنْ أَذْ إِعكّسْ ثِيمسْڒَايِينْ-أَ، إِشُووَّارْ أَومْ أَذْ ثَارْسمْ، وَارْ تّڭّمْ شَا س ؤُقدْجقْ،  
\v 37 مِينْزِي ثِيوْيمْ-د إِرْيَازنْ-أَ \add ذَانِيثَا\add*، إِنِّي وَارْ إِدْجِينْ ذ إِشفَّارنْ ن ثْزَاوِييِّينْ ؤُڒَا وَارْ تّْشقَّافنْ ذِي ثْربِّيثْ نّغْ.  
\v 38 مَاشَا مَاڒَا ثُوغَا غَارْ ذِيمِيثْرِييُو ؤُ غَارْ يِينِّي إِدْجَانْ أَكِيذسْ ذِي صّنْعثْ شَا ن ؤُشثْشِي خْ يِيجّنْ، أَقَا ذِينْ إِجّْ ن لْعَامِيلْ ذِي ثنْذِينْثْ. أجّْ إِ-ثنْ أَذْ \add غَارسْ\add* د-قَارّْبنْ ؤُ أَذْ شَارّْعنْ أَكْ-ذ وَايَاوْيَا \add زَّاثسْ\add*.  
\v 39 مَاشَا مَاڒَا ثخْسمْ شَا ن ثْمسْڒَاشْثْ نّغْنِي، إِتّْخصَّا أَذْ إِتّْوَافكّْ مَانْ أَيَا ذڭْ إِجّْ ن ومْشَانْ إِ إِتّْوصَّانْ إِ ثْمسْمُونْثْ عْلَاحْسَابْ شَّارِيعَا،  
\v 40 مِينْزِي أَقَا أَنغْ ذِي لْخَاطَارْ أَذْ خَانغْ ضڒْمنْ أَسّْ-أَ زِي سِّيبّثْ ن ؤُغُووّغْ، مِينْزِي وَارْ ذِينْ بُو ڒسْبَابْ إِ زِي نْزمَّارْ أَذْ د-نَارّْ س يِيجّْ ن وَاوَاڒْ ذِي ثْمسْڒَاشْثْ ن وڭْرَاوْ-أَ، مِينْزِي نسّْمُونَا ذِي ڒْبَاطڒْ ؤُ نتّْغوّغْ أَمنِّي وَاهَا.“  
\v 41 أَوَارْنِي ڒَامِي إِنَّا أَيَا، إِسْمحْ إِ وڭْرَاوْ أَذْ يُويُورْ.   
\b  
\b  
\m  
\c 20
\s1 پُولُوسْ ذِي مَاسِيذُونِييَا ذ لْيُونَانْ  
\m
\v 1 أَوَارْنِي ڒَامِي يَارْسَا ؤُغُووّغْ، إِڒَاغَا-د بُولُوسْ خْ إِمحْضَارنْ، إِودّعْ إِ-ثنْ س ؤُسُوذمْ \add ن وَاوْمَاثنْ\add*، ؤُشَا إِفّغْ حِيمَا أَذْ إِرَاحْ غَارْ مَاكِيذُونِييَا.  
\v 2 ڒَامِي إِشُوقْ ذِي جّْوَايهْ نِّي، إِشجّعْ إِ-ثنْ س وَاطَّاسْ ن وَاوَاڒنْ، خنِّي يِيوضْ غَارْ هِيلَّاسْ، \add إِخْسْ أَذْ يِينِي غَارْ جِّيهثْ أَخَايَا\add*.  
\v 3 أَڒَامِي إِسّعْذُو ذِينْ ثْڒَاثَا ن إِيُورنْ، سّوْجْذنْ أَسْ وُوذَاينْ إِجّْ ن ڒْفخْ، ؤُمِي ثُوغَا إِڭُّورْ أَذْ إِبحَّارْ غَارْ سُورِييَا. س ؤُيَا إِڭَّا أَذْ يعْقبْ خْ وبْرِيذْ ن مَاكِيذُونِييَا.  
\v 4 سُوبَاثْرُوسْ زِي ثنْذِينْثْ ن بِيرِييَا، أَرِيسْثَارْخُوسْ ذ سِيكُونْذُوسْ زِي ثِيسَّالُونِيكَا، خَايُوسْ زِي ذِيرْبِي، ثِيمُوثِييُو زِي لِيسْثْرَا ؤُ ثِيشِيكُوسْ ذ ثْرُوفِيمُوسْ زِي أَسِييَا ؤُيُورنْ أَكِيذسْ أَڒْ أَسِييَا. \x ◘ \xo 20:‏4 \xt ڒخ. 19‏:‏29؛ 21‏:‏29؛ 27‏:‏2؛ 1 كُور. 1‏:‏14؛ أَفا. 6‏:‏21؛ كُول. 4‏:‏7، 10؛ 2 تِيم. 4‏:‏12؛ ثِيث. 3‏:‏12. \x*  
\v 5 إِنَا إِزْوَارنْ أَنغْ، تّْرَاجَانْ أَنغْ ذِي ثْرُووَاسْ.  
\v 6 مَاشَا نشِّينْ نفّغْ زِي فِيلِيبِّي، ثَانْذِينْثْ \add ثَامزْوَارُوثْ\add* ن مَاكِيذُونِييَا، أَوَارْنِي ڒَامِي كمّْڒنْ وُوسَّانْ ن \add وغْرُومْ\add* بْڒَا أَنْثُونْ، نكَّا خْ ڒبْحَارْ ؤُ ذِي خمْسَا ن وُوسَّانْ نِيوضْ-د غَارْ ثْرُووَاسْ مَانِي نقِّيمْ سبْعَا ن وُوسَّانْ.   
\b  
\m  
\s1 أَسْنكَّارْ ن ؤُثِيخُوسْ زِي ڒْموْثْ ذِي ثْرُووَاسْ  
\m
\v 7 ذڭْ وَاسّْ أَمزْوَارُو ن سِّيمَانَا ؤُمِي مُوننْ إِمحْضَارنْ مَاحنْذْ أَذْ أَرْژنْ أَغْرُومْ \add ن ثْنمِّيرْثْ\add*، إِسِّيوڒْ بُولُوسْ أَكِيذْسنْ. إِسّْزُوڭَارْ بُولُوسْ ذِي ڒْهَارْذْ نّسْ أَڒْ ڒْوسْطْ ن دْجِيڒثْ، مَاغَارْ نتَّا ثُوغَا إِنْوَا أَذْ إِسَافَارْ ثِيوشَّا نّسْ.  
\v 8 أَقَا أَرقّنْ ذِينْ أَطَّاسْ ن ڒفْنَارَاثْ ذِي ثْغُورْفثْ ن سنّجْ إِ ذِي ثُوغَا نْمُونْ.  
\v 9 ثُوغَا ذِينْ إِجّْ ن ؤُبْڒِيغْ قَّارنْ أَسْ ؤُثِيخُوسْ، إِقِّيمْ ذِي ڒْكَازِي، إِتّسْڒَا، ڒخْذنِّي إِكَّا خَاسْ يِيضصْ يُودْجغْ أَمْ ثُوغَا بُولُوسْ إِسّْزُوڭَارْ ذِي ڒْهَارْذْ نّسْ. ؤُمِي ثُوغَا إِطّصْ، إِوْضَا-د زِي طّبْقثْ وِيسّْ ثْڒَاثَا غَارْ وَادَّايْ، كْسِينْ ث إِمُّوثْ.  
\v 10 مَاشَا بُولُوسْ إِهْوَا، إِوْضَا خَاسْ، إِذَارّعْ أَسْ، إِنَّا: ”وَارْ ثنّخْڒِيعمْ شَا، أَقَا ذَايسْ ثُوذَارْثْ.“ \x ◘ \xo 20:‏10 \xt 1 إِج. 17‏:‏21؛ 2 إِج. 4‏:‏34. \x*  
\v 11 خنِّي يُوڒِي عَاوذْ، يَارْژَا أَغْرُومْ، إِشَّا \add شْوَايْثْ زَّايسْ\add*، خنِّي إِسِّيوڒْ أَكِيذْسنْ \add عَاذْ\add* أَطَّاسْ أَڒَامِي ذ ڒفْجَارْ. خَاسْ ؤُشَا إِرُوحْ إِسَافَارْ خْ ثمُّورْثْ،  
\v 12 أَمْ د-إِوْينْ نِيثْنِي أَحنْجِيرْ إِدَّارْ، فَارْحنْ أَسْ أَطَّاسْ.   
\m
\v 13 مَاشَا نشِّينْ ننْيَا ذڭْ ؤُغَارَّابُو، نْبحَّارْ غَارْ ڒْمَارْسَا ن ثِيسُّوسْ مَاحنْذْ أَذْ كِيذْنغْ د-نَاوِي بُولُوسْ سّنِّي، أَمْ مَامّشْ ثُوغَا إِتّْضبَّارْ، مَاغَارْ نتَّا س يِيخفْ نّسْ إِكَّا \add غَارْ ذِينْ\add* خْ ثمُّورْثْ.  
\v 14 أَڒَامِي زَّايسْ نَارحّبْ ذِي ثِيسُّوسْ، نكْسِي ث ذِي ثْغَارَّابُوثْ ؤُشَا نِيوضْ-ضّْ غَارْ مِيثِيلِينِي.  
\v 15 سّنِّي نعْذُو ثِيوشَّا نّسْ غَارْ ثڭْزِيرْثْ ن خِييُوسْ ؤُ فَارْوشَّا نّسْ نِيوذْ غَارْ سَامُوسْ، نقِّيمْ ذِي ثْرُوخِيلِييُونْ. ذڭْ وَاسّْ أَوَارْنِي أَسْ نِيوضْ غَارْ مِيلِيثُوسْ،  
\v 16 مِينْزِي بُولُوسْ إِڭَّا أَذْ إِعْذُو أَفَاسُوسْ خْ ڒبْحَارْ حِيمَا وَارْ إِتّْعطَّاڒْ ذِينِّي، مِينْزِي ثُوغَا إِتّْقدْجقْ حِيمَا، معْلِيكْ إِعدّڒْ، أَذْ إِعيّذْ ڒْعِيذْ ن خمْسِينْ ن وُوسَّانْ ذِي ؤُرْشَالِيمْ. \x ◘ \xo 20:‏16 \xt ڒخ. 21‏:‏4، 12. \x*   
\b  
\m  
\s1 أَمڒْقِي أَنڭَّارُو ن بُولُوسْ أَكْ-ذ إِمْغَارنْ ن ثْمسْمُونْثْ ن أَفَاسُوسْ  
\m
\v 17 زِي مِيلِيثُوسْ إِجَّا أَذْ د-أَسنْ إِمْغَارنْ ن ثْمسْمُونْثْ ذِي أَفَاسُوسْ.  
\v 18 ڒَامِي د-ؤُسِينْ غَارسْ، إِنَّا أَسنْ:  
\m ”كنِّيوْ ثسّْنمْ زڭْ وَاسّْ أَمزْوَارُو ؤُمِي د-ؤُذْفغْ غَارْ أَسِييَا، مَامّشْ دْجِيغْ أَكِيذْومْ مَارَّا ؤُسَّانْ،  
\v 19 أَمْ ثُوغَا تّْسخَّارغْ إِ أَربِّي س مَارَّا أَوَاضعْ ؤُ س إِمطَّاونْ، ؤُڒَا ذڭْ إِغكّْوَانْ إِ خَافِي إِكِّينْ زِي سِّيبّثْ ن ثْمعْمَاتْشْ ن وُوذَاينْ.  
\v 20 وَارْ جِّيغْ شَا زِي مِينْ إِنفْعنْ إِ ڒعْمُورْ نْومْ وَارْ ذ أَومْ ث بَارّْحغْ، وَارْ ث سّْڒمْذغْ ذِي ڒسْوَاقْ ؤُ ذِي ثُوذْرِينْ،  
\v 21 أَمْ سّْقنْعغْ ؤُذَاينْ ذ إِرَامِييّنْ مَاحنْذْ أَذْ د-ذوْڒنْ غَارْ أَربِّي، أَذْ أَمْننْ ذِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \f ◼ \fr 20:‏21 \ft \+bd ’إِرَامِييّنْ‘\+bd* - ذِي ڒْمَاخْثُوطَّاثْ س يِيڒسْ ن لْيُونَانْ إِتّْوَارِي ’إِيُونَانِييّنْ‘.\f*  \x ◘ \xo 20:‏21 \xt مت. 3‏:‏2؛ مك. 1‏:‏15؛ لك. 24‏:‏47. \x*  
\v 22 ؤُ ڒخُّو أَذْ رَاحغْ غَارْ ؤُرْشَالِيمْ أَمْ تّْوَاشَارْفغْ زِي أَرُّوحْ، وَارْ سِّينغْ مِينْ ذ أَيِي إِتّْرَاجَانْ ذِينْ،  
\v 23 مْغِيرْ أَقَا أَرُّوحْ إِقدّْسنْ إِشْهذْ أَيِي ذِي كُوڒْ ثَانْذِينْثْ، إِقَّارْ: ’أَقَا إِشذِّييّنْ ذ ڒمْحَايمْ تّْرَاجَانْ شكْ!‘  
\v 24 مَاشَا نشّْ وَارْ حسّْبغْ ثُوذَارْثْ إِنُو شَا ثِيغْڒَا إِ يِيخفْ إِنُو، مَاحنْذْ أَذْ كمّْڒغْ ثِيشْڒِي إِنُو ذ ڒْخذْمثْ ن ثْسخَّارْثْ إِ كْسِيغْ زِي سِيذِيثْنغْ يَاسُوع حِيمَا أَذْ شهْذغْ خْ ڒخْبَارْ أَصبْحَانْ ن أَرْضَا ن أَربِّي. \x ◘ \xo 20:‏24 \xt ڒخ. 21‏:‏13؛ ڭال. 1‏:‏1؛ ثِيث. 1‏:‏3. \x*  
\v 25 ؤُ ڒخُّو سّْنغْ، أَقَا ؤُڒَا ذ إِجّْ زَّايْومْ أَذْ إِژَارْ أَغمْبُوبْ إِنُو عَاذْ، مَارَّا كنِّيوْ إِنِّي جَارْ أَومْ ڭُّورغْ، تّْبَارّْحغْ س ثْڭلْذِيثْ ن أَربِّي.   
\m
\v 26 س ؤُينِّي أَذْ خَاومْ شهْذغْ أَسّْ-أَ، بلِّي نشّْ تّْبَارِّيغْ إِخفْ إِنُو زڭْ إِذَامّنْ نْومْ مَارَّا.  
\v 27 مِينْزِي وَارْ عْڭِيزغْ أَذْ أَومْ سّشْنغْ مَارَّا مِينْ إِتّخْسْ أَربِّي.  
\v 28 س ؤُينِّي حْضَامْ خْ يِيخفْ نْومْ ؤُ خْ ثْحِيمَارْثْ ثْمُونْ مِينْ خفْ إِڭَّا أَرُّوحْ إِقدّْسنْ كنِّيوْ ذ إِمحْضَاينْ، حِيمَا أَذْ ثَارْوسمْ ثَامسْمُونْثْ ن لْمَاسِيحْ ثنِّي ذ إِكسّبْ س إِذَامّنْ نّسْ. \x ◘ \xo 20:‏28 \xt أَفا. 1‏:‏7؛ كُول. 1‏:‏14؛ 1 بُط. 1‏:‏19؛ 5‏:‏2؛ أَسَا. 5‏:‏9. \x*   
\m
\v 29 مِينْزِي سّْنغْ بلِّي أَوَارْنِي ثْوَاحِيثْ إِنُو أَذْ غَارْومْ د-أَذْفنْ وُوشَّاننْ إِمُوزَّارنْ \add إِنِّي\add* وَارْ إِتّجِّينْ ثَاحِيمَارْثْ. \x ◘ \xo 20:‏29 \xt 2 بُط. 2‏:‏1. \x*  
\v 30 عَاذْ أَذْ زَّايْومْ د-كَّارنْ يرْيَازنْ إِنِّي إِ غَا إِسِّيوْڒنْ ڒْهَارْذْ إِعوّْجنْ حِيمَا أَذْ سُّوفّْغنْ إِمحْضَارنْ زڭْ وبْرِيذْ، أَذْ ثنْ جَارّنْ أَوَارْنِي أَسنْ. \x ◘ \xo 20:‏30 \xt إِزهد. 41‏:‏10؛ مت. 16‏:‏21؛ ڒخ. 1‏:‏17؛ 1 يُوح. 2‏:‏19. \x*  
\v 31 س ؤُينِّي فَاقمْ، ثْعقْڒمْ بلِّي ثْڒَاثَا ن إِسڭّْوُوسَا، دْجِيڒثْ ذ وَاسّْ، وَارْ بدّغْ أَذْ سّْمحْذغْ كُوڒْ إِجّنْ زَّايْومْ س إِمطَّاونْ.   
\m
\v 32 ؤُ ڒخُّو أَذْ كنِّيوْ سلّْمغْ إِ أَربِّي ؤُ إِ وَاوَاڒْ ن أَرْضَا نّسْ، إِ ونِّي غَارْ إِدْجَا ثِيزمَّارْ حِيمَا أَذْ كنِّيوْ إِبْنَا ؤُ أَذْ أَومْ إِوْشْ ڒْوَارْثْ أَكْ-ذ مَارَّا إِمْقدَّاسنْ.  
\v 33 وَارْ ضْمِيعغْ ذِي نُّوقَارْثْ نِيغْ ذڭْ وُورغْ نِيغْ ذڭْ وَارُّوضْ ؤُڒَا زڭْ إِجّنْ. \x ◘ \xo 20:‏33 \xt 1 كُور. 9‏:‏12؛ 2 كُور. 11‏:‏9؛ 12‏:‏13. \x*  
\v 34 كنِّيوْ ثسّْنمْ سِيمَانْثْ نْومْ بلِّي إِفَاسّنْ إِنُو أَقَا خذْمنْ إِ مِينْ حْوَاجغْ ؤُ إِ مِينْ حْوَاجنْ إِنِّي إِدْجَانْ أَكِيذِي. \x ◘ \xo 20:‏34 \xt ڒخ. 18‏:‏3؛ 1 كُور. 4‏:‏12؛ 1 تس. 2‏:‏9؛ 2 تس. 3‏:‏8. \x*  
\v 35 ذِي كُوڒْشِي سّشْنغْ أَومْ بلِّي إِتّْخصَّا، أَمْ نْخدّمْ أَمُّو، أَذْ نوْشْ أَفُوسْ إِ يِينِّي إِضعْفنْ ؤُشَا أَذْ نْفكَّارْ ذڭْ وَاوَاڒنْ ن سِيذِيثْنغْ يَاسُوع، بلِّي إِنَّا: ’سّعْذْ ن ونِّي إِوْشِينْ خْ ونِّي إِكْسِينْ.‘ “   
\b  
\m
\v 36 أَوَارْنِي ڒَامِي إِنَّا أَيَا، إِوْضَا خْ إِفَادّنْ نّسْ، إِژُّودْجْ ؤُ مَارَّا إِرْيَازنْ أَكِيذسْ. \x ◘ \xo 20:‏36 \xt ڒخ. 21‏:‏5. \x*  
\v 37 أَقَا ذِينْ جَارْ أَسنْ أَطَّاسْ ن إِمطَّاونْ ؤُشَا ذَارّْعنْ أَسْ، سُّوذْمنْ ث.  
\v 38 شضْننْ أَطَّاسْ، أَمزْوَارْ ن مَارَّا خْ وَاوَاڒْ إِ إِنَّا، بلِّي وَارْ ژَترّنْ شَا أَغمْبُوبْ نّسْ عَاذْ، ؤُشَا سّْقبّْضنْ ث غَارْ ؤُغَارَّابُو. *   
\b  
\b  
\m  
\c 21
\s1 أَسَافَارْ ن بُولُوسْ غَارْ ؤُرْشَالِيمْ  
\m
\v 1 أَوَارْنِي ڒَامِي خَاسنْ نمّْسبْضَا، نبْذَا نْژكّْوَا ڒبْحَارْ، نْرُوحْ نِيشَانْ ؤُشَا نِيوضْ غَارْ ثڭْزِيرْثْ ن كُوسْ. ثِيوشَّا نّسْ نِيوضْ غَارْ رُوذُوسْ ؤُ سّنِّي غَارْ بَاثَارَا.  
\v 2 نُوفَا ذِينْ إِجّْ ن ؤُغَارَّابُو إِ ثُوغَا أَذْ إِژْوَا غَارْ فِينِيقِييَا، ننْيَا ذَايسْ ؤُشَا نْرُوحْ.  
\v 3 ڒَامِي د-نِيوضْ غَارْ ثڭْزِيرْثْ ن قُوبْرُوسْ، نجَّا إِ-ت خْ ؤُزڒْمَاضْ ؤُشَا نْرُوحْ خْ ڒبْحَارْ غَارْ سُورِييَا ؤُشَا سّنِّي نِيوضْ غَارْ صُورْ، مِينْزِي أَغَارَّابُو ثُوغَا إِڭَّا أَذْ إِفَارّغْ سّڒْعثْ نّسْ ذِينْ.  
\v 4 ؤُمِي نُوفَا ذِينْ إِمحْضَارنْ، نقِّيمْ غَارْسنْ سبْعَا ن وُوسَّانْ. كُوڒْ أَسّْ نَّانْ نِيثْنِي س أَرُّوحْ إِ بُولُوسْ مَاحنْذْ وَارْ إِتّْڭعِّيذْ شَا غَارْ ؤُرْشَالِيمْ. \x ◘ \xo 21:‏4 \xt ڒخ. 20‏:‏23؛ 21‏:‏12. \x*  
\v 5 أَوَارْنِي إِ وُوسَّانْ-أَ نفّغْ، نُويُورْ. مَارَّا نِيثْنِي سّْقبْضنْ أَنغْ، نِيثْنِي ذ ثمْغَارِينْ نْسنْ ذ إِحنْجِيرنْ نْسنْ، أَڒْ بَارَّا ن ثنْذِينْثْ. خْ ثْمَا ن ڒبْحَارْ وْضَانْ خْ إِفَادّنْ نْسنْ ؤُشَا ژُّودْجنْ.  
\v 6 ؤُمِي نْودّعْ أَيَاوْيَا س ؤُسُوذمْ، ننْيَا ذڭْ ؤُغَارَّابُو، مَاشَا نِيثْنِيعقْبنْ، كُوڒْ  إِجّنْ غَارْ ثَادَّارْثْ نّسْ.   
\m
\v 7 ؤُمِي نْكمّڒْ خْ ؤُسَافَارْ زِي صُورْ نِيوضْ غَارْ بْثُولُومَايُو، نْسدْجْمنْ خْ وَاوْمَاثنْ ؤُشَا نقِّيمْ أَكِيذْسنْ إِجّْ ن وَاسّْ. \f ◼ \fr 21:‏7 \ft \+bd ’بْثُولُومَايُو‘\+bd* - نِيغْ ’أَكُّو‘.\f*  
\v 8 ثِيوشَّا نّسْ نفّغْ سّنِّي، نِيوضْ غَارْ قَايْصَارِييَا. نُوذفْ غَارْ ثَادَّارْثْ ن ؤُمْبشَّارْ فِيلِيبُّوسْ، ونِّي ثُوغَا ذ إِجّنْ زِي سبْعَا \add ن إِمْسخَّارنْ\add*، ؤُشَا نقِّيمْ \add غَارسْ\add*. \f ◼ \fr 21:‏8 \ft \+bd ’إِجّنْ زِي سبْعَا \+bdit ن إِمْسخَّارنْ\+bdit*‘\+bd* - خْزَارْ ڒخ. 6:5.\f*  \x ◘ \xo 21:‏8 \xt ڒخ. 6‏:‏5؛ 8‏:‏29. \x*  
\v 9 ثُوغَا غَارْ وَا أَربْعَا ن ثْحنْجِيرِينْ، \add عَاذْ\add* ذ ثِيعزْرِييِّينْ، ثِينِّي إِتّْنَابّنْ. \x ◘ \xo 21:‏9 \xt يُووِ. 3‏:‏1؛ ڒخ. 2‏:‏17. \x*   
\m
\v 10 ؤُمِي ننِّيوْجوْ ذِينْ أَطَّاسْ ن وُوسَّانْ، إِهْوَا-د إِجّْ ن ؤُنَابِي زِي يَاهُوذِييَّا، قَّارنْ أَسْ أَغابُوسْ. \x ◘ \xo 21:‏10 \xt ڒخ. 11‏:‏28. \x*  
\v 11 يُوسَا-د غَارْنغْ ؤُشَا إِكْسِي أَبْيَاسْ ن بُولُوسْ، إِشَارْفْ إِخفْ نّسْ إِفَاسّنْ ذ إِضَارنْ، إِنَّا: ”أَمُّو إِ إِقَّارْ أَرُّوحْ إِقدّْسنْ: ’أَرْيَازْ إِ غَارْ إِدْجَا أَبْيَاسْ-أَ، أَمُّو إِ ث غَا شَارْفنْ وُوذَاينْ ذِي ؤُرْشَالِيمْ ؤُشَا أَذْ ث سلّْمنْ ذڭْ إِفَاسّنْ ن ڒڭْنُوسْ.‘ “ \x ◘ \xo 21:‏11 \xt ڒخ. 20‏:‏23؛ 21‏:‏33. \x*  
\v 12 ؤُمِي نسْڒَا أَوَاڒنْ-أَ، نتَّارْ زَّايسْ، أَمْ نشِّينْ أَمْ يِينِّي زِي جّْوَايهْ نِّي، حِيمَا وَارْ إِتّْڭعِّيذْ غَارْ ؤُرْشَالِيمْ.  
\v 13 مَاشَا بُولُوسْ يَارَّا-د، إِنَّا: ”مِينْ كنِّيوْ يُوغِينْ، ثتّْرُومْ ؤُشَا ثسَّارضْبمْ ؤُڒْ إِنُو؟ مِينْزِي أَقَا أَيِي وجْذغْ، وَارْ إِدْجِي حِيمَا أَذْ أَيِي شَارْفنْ وَاهَا، مَاشَا عَاوذْ حِيمَا أَذْ مّْثغْ ذِي ؤُرْشَالِيمْ خْ سِّيبّثْ ن يِيسمْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.“  
\v 14 ؤُمِي وَارْ ذ أَنغْ إِجِّي أَذْ ث نسّقْنعْ، نسْقَارْ، نقَّارْ: ”أَذْ يِيڒِي مِينْ إِخْسْ سِيذِيثْنغْ.“ \x ◘ \xo 21:‏14 \xt مت. 6‏:‏10؛ لك. 11‏:‏2؛ 22‏:‏42. \x*   
\m
\v 15 أَوَارْنِي ؤُسَّانْ نِّي نسّوْجذْ ؤُشَا نْڭعّذْ غَارْ ؤُرْشَالِيمْ.  
\v 16 رُوحنْ أَكِيذْنغْ شَا ن إِرْيَازنْ، إِمحْضَارنْ زِي قَايْصَارِييَا، إِوْينْ-د إِجّْ ن ثوْمَاثْ، قَّارنْ أَسْ مْنَاسُونْ زِي قُوبْرُوسْ، أَقَا-ث ذ إِجّنْ زڭْ إِمحْضَارنْ إِمزْوُورَا، حِيمَا أَذْ غَارسْ ننِّيوْجوْ.   
\b  
\m  
\s1 أَمُونِي ن بُولُوسْ أَكْ-ذ رُّوسُولْ ذ وَاوْمَاثنْ ذِي ؤُرْشَالِيمْ  
\m
\v 17 أَڒَامِي د-نِيوضْ غَارْ ؤُرْشَالِيمْ، ثَارحّبْ زَّايْنغْ ثَاوْمَاثْ س ڒفْرَاحثْ.  
\v 18 ثِيوشَّا نّسْ يُوذفْ بُولُوسْ أَكِيذْنغْ غَارْ يَاعْقُوبْ، ؤُمِي حْضَارنْ ذِينْ أَكِيذسْ مَارَّا إِمْغَارنْ.  
\v 19 أَوَارْنِي ڒَامِي خَاسنْ نْسدْجمْ، إِبْذَا بُولُوسْ أَذْ إِعَاوذْ س ؤُستّفْ خْ مَارَّا مِينْ إِڭَّا أَربِّي جَارْ ڒڭْنُوسْ س ثْسخَّارْثْ نّسْ.  
\v 20 ؤُمِي سْڒِينْ أَيَا، سّمْغَارنْ أَربِّي، نَّانْ أَسْ: ”\add أَ\add* ؤُمَاثْنغْ، ثتّْوَاڒِيذْ مشْحَاڒْ نعشْرَا ن ڒُوڒُوفْ ذِي يَاهُوذِييَّا إِ يُومْننْ، ؤُ نِيثْنِي مَارَّا تَّاسْمنْ خْ شَّارِيعَا.  
\v 21 مَاشَا يِيوضْ أَسنْ-د ڒخْبَارْ خَاكْ بلِّي ثسّڒْمَاذذْ إِ مَارَّا ؤُذَاينْ إِنِّي إِدْجَانْ جَارْ ڒڭْنُوسْ مَاحنْذْ أَذْ سمْحنْ ذِي \add شَّارِيعَا ن\add* مُوسَا أَمْ ذ أَسنْ ثقَّارذْ إِتّْخصَّا وَارْ ختّْننْ إِحنْجِيرنْ نْسنْ وَارْ ڭُّورنْ ذڭْ وبْرِيذْ ن شَّارِيعَا.  
\v 22 س ؤُينِّي، مِينْزِي سْڒِينْ بلِّي أَقَا ثُوسِيذْ-د ذَا،  
\v 23 أڭّْ مِينْ ذ أَشْ غَا نِينِي! غَارْنغْ أَربْعَا ن يرْيَازنْ إِنِّي غَارْ إِدْجَا إِجّْ ن لْوَاعْذْ مَاهنْذْ أَذْ سِّيزْذِيڭنْ إِخفْ نْسنْ.  
\v 24 أَوِي إِنَا أَكِيذكْ، ثسِّيزْذڭذْ إِخفْ نّشْ أَكِيذْسنْ، ؤُشَا خدْجصْ خَاسنْ حِيمَا أَذْ حفّنْ إِزدْجِيفنْ نْسنْ. خنِّي أَذْ سّْننْ مَارَّا بلِّي مِينْ خَاكْ إِتّْوَانَّانْ وَارْ إِدْجِي بُو نِيشَانْ، ؤُ بلِّي شكْ ثتّْكمّْڒذْ شَّارِيعَا ؤُ ثتّطّْفذْ ذَايسْ.  
\v 25 مَاشَا زِي جِّيهثْ ن يِينِّي يُومْننْ جَارْ ڒڭْنُوسْ، أَقَا نُورَا بلِّي أَذْ بعّْذنْ خْ مِينْ إِغَارْصنْ \add إِ لْ-أَصْنَامْ\add*، خْ فَارْقْ-شّْغڒْ، خْ جِّييْفَاثْ، ؤُڒَا خْ إِذَامّنْ.“ \x ◘ \xo 21:‏25 \xt أَمز. 9‏:‏4؛ ؤُف. 20‏:‏3؛ ڒخ. 15‏:‏23؛ 1 كُور. 8‏:‏1. \x*   
\m
\v 26 خنِّي يِيوْيِي بُولُوسْ إِرْيَازنْ نِّي أَكِيذسْ ؤُشَا ثِيوشَّا نّسْ إِسِّيزْذڭْ إِخفْ نّسْ أَكِيذْسنْ. رُوحنْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ، إِسّْشنْ أَسنْ مَامّشْ إِتّْخصَّا أَذْ كمّْڒنْ وُوسَّانْ ن ؤُسِيزْذڭْ، أَڒْ ذ إِقدّمْ زِي مْكُوڒْ إِجّنْ زَّايْسنْ ثَاغَارْصْثْ \add نّسْ\add*. \x ◘ \xo 21:‏26 \xt ڒخ. 24‏:‏6. \x*   
\b  
\m  
\s1 ؤُضُوفْ ن بُولُوسْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ  
\m
\v 27 أَڒَامِي د-يِيوضْ وَاسّْ سبْعَا، ژْرِينْ ث وُوذَاينْ ن أَسِييَا ذِي زَّاوشْثْ ثَامقّْرَانْثْ، سّنْهزّنْ ڒْڭنْسْ مَارَّا ضِيدّْ نّسْ، حَارْثنْ خَاسْ س إِفَاسّنْ،  
\v 28 سْغُويُّونْ: ”أَ كنِّيوْ، \add أَ\add* أَيْثْ ن إِسْرَائِيل، غَاوْڒمْ غَارْ ثْوِيزَا! وَا ذ بْنَاذمْ نِّي إِسّڒْمَاذنْ إِوْذَانْ مَارَّا ضِيدّْ إِ ڒْڭنْسْ نّغْ ؤُ ضِيدّْ إِ شَّارِيعَا ؤُ ضِيدّْ إِ ومْشَانْ-أَ. عَاوذْ إِسِّيذفْ-د إِرَامِييّنْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ ؤُشَا إِسّخْمجْ أَمْشَانْ إِقدّْسنْ وَانِيثَا!“  
\v 29 مِينْزِي ثُوغَا إِزْوَارنْ أَكِيذسْ ژْرِينْ ثْرُوفِيمُوسْ زِي أَفَاسُوسْ ذِي ثنْذِينْثْ، إِتّْغِيڒْ أَسنْ بلِّي نتَّا يُوذفْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ أَكْ-ذ بُولُوسْ. \x ◘ \xo 21:‏29 \xt ڒخ. 20‏:‏4؛ 2 تِيم. 4‏:‏20. \x*  
\v 30 ثَانْذِينْثْ مَارَّا ثْهَاجْ ؤُشَا إِوْذَانْ دُّوقّْزنْ-د، حَارْثنْ خْ بُولُوسْ، جَارّنْ ث بَارَّا إِ زَّاوشْثْ ثَامقّْرَانْثْ، ڒخْذنِّي بلّْعنْثْ ثِيوُّورَا.   
\m
\v 31 أَمْ يَارزُّو ڒْغَاشِي أَذْ ث إِنغْ، يِيوضْ ڒخْبَارْ غَارْ ؤُكُومَانْذَارْ ن ڒْكُومْبَانِييّثْ، أَقَا ؤُرْشَالِيمْ أَمنْ ثكْمڒْ ثْخَارْوضْ.  
\v 32 ڒخْذنِّي يِيوْيِي-د إِجّْ ن ڒْقبْطَانْ خْ مْيَا ؤُڒَا ذ إِجّْ ؤُبَارُّو ن إِعسْكَارِييّنْ، ؤُشَا ؤُزّْڒنْ غَارْسنْ. أَڒَامِي ژْرِينْ نِيثْنِي أَكُومَانْذَارْ ذ ڒْعسْكَارْ، سّْبدّنْ أَذْ وْثنْ بُولُوسْ.  
\v 33 أَڒَامِي غَارسْ د-إِقَارّبْ ؤُكُومَانْذَارْ، إِطّفْ إِ-ث، يُومُورْ أَذْ ث شَارْفنْ س ثْنَاينْ ن سّْنَاسڒْ، خنِّي إِسّقْسَا مِينْ إِعْنَا نتَّا ذ مِينْ إِڭَّا. \x ◘ \xo 21:‏33 \xt ڒخ. 21‏:‏11. \x*  
\v 34 جَارْ ڒْغَاشِي أَقَا ذِينْ إِجّنْ إِتّْڒَاغَا أَمُّو ؤُ ونّغْنِي أَمُّو. ڒَامِي وَارْ إِزمَّارْ أَذْ إِسّنْ ثِيذتّْ زِي سِّيبّثْ ن لْهَارَاجْ، يُومُورْ أَذْ ث أَوْينْ غَارْ لْقشْلَا.  
\v 35 أَڒَامِي د-يِيوضْ بُولُوسْ غَارْ دّْرُوجْ، إِمْسَارْ بلِّي إِعسْكَارِييّنْ أَرْبُونْ ث خْ سّْبَابْ ن لْعُونْفْ ن ڒْڭنْسْ،  
\v 36 مِينْزِي أَطَّاسْ ن إِوْذَانْ ثُوغَا ضفَّارنْ ث، سْغُويُّونْ، نَّانْ: ”كّْسمْ ث زڭْ وبْرِيذْ!“ \x ◘ \xo 21:‏36 \xt لك. 23‏:‏18؛ يُوح. 19‏:‏15؛ ڒخ. 22‏:‏22. \x*   
\m
\v 37 أَڒَامِي د-إِقَارّبْ غَارْ لْقشْلَا، حِيمَا أَذْ يَاذفْ غَارْ ذَاخڒْ، إِنَّا بُولُوسْ إِ ؤُكُومَانْذَارْ: ”مَا إِحِيقّْ أَيِي أَذْ أَشْ إِنِيغْ شَا؟“ إِنَّا أَسْ: ”مَا ثسّْنذْ ثَايُونَانِيثْ؟  
\v 38 مَا وَارْ ثدْجِيذْ شكْ ذ أَمِيصْرِي ونِّي إِڭِّينْ أَغُووّغْ قْبڒْ ؤُسَّانْ-أَ، إِنْذهْ أَكِيذسْ أَربْعَا أَڒَافْ ن يرْيَازنْ ذ إِقتَّاڒنْ غَارْ ڒخْڒَا؟“  
\v 39 إِنَّا أَسْ بُولُوسْ: ”نشّْ ذ أَرْيَازْ ذ ؤُذَايْ زِي ثَارْسُوسْ، إِشْثْ ن ثنْذِينْثْ إِتّْوَاسّْننْ ذِي كِيلِيكِييَا مَانِي د-خڒْقغْ. نشّْ تَّارغْ زَّايكْ تّسْرِيحْ حِيمَا أَذْ سِّيوْڒغْ غَارْ ڒْڭنْسْ.“ \x ◘ \xo 21:‏39 \xt ڒخ. 9‏:‏11، 30. \x*  
\v 40 ؤُمِي ذ أَسْ إِسْمحْ، إِبدّْ بُولُوسْ خْ دّْرُوجْ، إِشيَّارْ س ؤُفُوسْ غَارْسنْ، ؤُشَا ؤُمِي أَرْسِينْ قَاعْ، إِسِّيوڒْ أَكِيذْسنْ س إِڒسْ ن ثْعِيبْرَانِيثْ، إِنَّا أَسنْ ...   
\b  
\b  
\m  
\c 22
\s1 أَذَافعْ ن بُولُوسْ خْ يِيخفْ نّسْ زَّاثْ إِ ڒْڭنْسْ  
\m
\v 1 ... ”\add أَ\add* ثَاوْمَاثْ ذ إِبَابَاثنْ، سْڒمْ إِ مِينْ ذ أَومْ غَا إِنِيغْ خْ ؤُذَافعْ إِنُو.“  
\v 2 ؤُمِي سْڒِينْ، أَقَا إِسَّاوَاڒْ أَكِيذْسنْ س \add يِيڒسْ ن\add* ثْعِيبْرَانِيثْ، قِّيمنْ سْقَارنْ عَاذْ كْثَارْ. إِنَّا أَسنْ:  
\v 3 ”نشّْ ذ إِجّْ ن بْنَاذمْ ذ ؤُذَايْ، خڒْقغْ-د ذِي ثَارْسُوسْ ذِي كِيلِيكِييَا، مَاشَا أَربِّيغْ ذِي ثنْذِينْثْ-أَ غَارْ إِضَارنْ ن ڭَامَالِييَالْ ؤُ تّْوَاسّْڒمْذغْ عْلَاحْسَابْ ثِيذتّْ نِيشَانْ ن شَّارِيعَا ن ڒجْذُوذْ نّغْ. شطَّارغْ خْ مِينْ إِدْجَانْ ن أَربِّي أَمْ مَامّشْ ؤُڒَا ذ كنِّيوْ مَارَّا. \x ◘ \xo 22:‏3 \xt ڒخ. 5‏:‏34؛ 9‏:‏11؛ 21‏:‏39؛ 2 كُور. 11‏:‏22\x*  
\v 4 نشّْ ثُوغَا ضفَّارغْ أَبْرِيذْ-أَ س ڒْموْثْ أَمْ شَارّْفغْ إِرْيَازنْ ذ ثمْغَارِينْ، تّْسلَّامغْ ثنْ غَارْ ڒحْبسْ. \x ◘ \xo 22:‏4 \xt ڒخ. 8‏:‏3؛ 9‏:‏1؛ 26‏:‏9؛ 1 كُور. 15‏:‏9؛ ڭال. 1‏:‏13؛ 1 تِيم. 1‏:‏13. \x*  
\v 5 أَرَّايْسْ ن إِكهَّاننْ ذ مَارَّا إِمْغَارنْ \add ن ڒْڭنْسْ\add* زمَّارنْ أَذْ شهْذنْ بلِّي كْسِيغْ ثِيبْرَاثِينْ إِ ثَاوْمَاثْ، مَاحنْذْ أَذْ رُوحغْ غَارْ ذِيمَاشْقْ حِيمَا أَذْ أَوْيغْ إِنِّي ذِينْ إِدْجَانْ عَاوذْ س ثْشَارْفِينْ غَارْ ؤُرْشَالِيمْ، حِيمَا أَذْ طّْفنْ لْعِيقَابْ.   
\m
\v 6 ؤُمِي ذ أَيِي ثُوغَا ذڭْ وبْرِيذْ ؤُشَا إِوْضغْ غَارْ ذِيمَاشْقْ غَارْ وزْينْ ن وَاسّْ، ثَاڒْغَا خَافِي س ڒْغفْڒثْ إِشْثْ ن ثْفَاوْثْ ثمْغَارْ زڭْ ؤُجنَّا. \x ◘ \xo 22:‏6 \xt 1 كُور. 15‏:‏8؛ 2 كُور. 12‏:‏2. \x*  
\v 7 وْضِيغْ خْ ثمُّورْثْ، سْڒِيغْ إِشْثْ ن ثْمِيجَّا، ثقَّارْ أَيِي: ’شَاوُولْ، شَاوُولْ، مَايمِّي ذ أَيِي ثْذَارّْشذْ؟‘  
\v 8 أَرِّيغْ-د خَاسْ: ’مِينْ ثعْنِيذْ شكْ، أَ سِيذِي؟‘ إِنَّا أَيِي: ’نشّْ ذ يَاسُوع، نَّاصِيرِي، ونِّي ثتّْذَارَّاشذْ!‘  
\v 9 إِرْيَازنْ نِّي ثُوغَا إِدْجَانْ أَكِيذِي، ژْرِينْ ثَافَاوْثْ، مَاشَا وَارْ سْڒِينْ شَا إِ ثْمِيجَّا ن ونِّي أَكِيذِي إِسَّاوَاڒنْ. \x ◘ \xo 22:‏9 \xt دَان. 10‏:‏7. \x*  
\v 10 نِّيغْ: ’مِينْ غَا ڭّغْ، أَ سِيذِي؟‘ إِنَّا أَيِي سِيذِيثْنغْ: ’كَّارْ، ثْرَاحذْ غَارْ ذِيمَاشْقْ، ذِينْ أَذْ أَشْ إِتّْوَانَّا خْ مَارَّا مِينْ ذ أَشْ يُورَانْ أَذْ ثڭّذْ!‘  
\v 11 ؤُمِي ذوْڒغْ وَارْ تّْوِيڒِيغْ زِي ثِيسِّيقْثْ ن ثْفَاوْثْ نِّي، ڭوّْذنْ أَيِي إِنِّي إِ ثُوغَا أَكِيذِي إِدْجَانْ زڭْ ؤُفُوسْ، ؤُشَا \add أَمُّو\add* إِ د-إِوْضغْ غَارْ ذِيمَاشْقْ.   
\m
\v 12 ثُوغَا ذِينْ إِجّْ ورْيَازْ، قَّارنْ أَسْ أَنَانِييَاسْ. نتَّا ذ أَمْسڭّذْ عْلَاحْسَابْ شَّارِيعَا، أَمْ مَامّشْ ثُوغَا خَاسْ شهّْذنْ مَارَّا ؤُذَاينْ. \x ◘ \xo 22:‏12 \xt ڒخ. 9‏:‏17. \x*  
\v 13 نتَّا يُوسَا-د غَارِي، إِنَّا أَيِي: ’\add أَ\add* ؤُمَا شَاوُولْ، أَرْزمْ ثِيطَّاوِينْ نّشْ!‘ ڒخْذنِّي ذِي ثْسَاعّثْ نِّي تّْوَارْزْمنْثْ ثِيطَّاوِينْ إِنُو، ؤُشَا ژْرِيغْ ث.  
\v 14 نتَّا إِنَّا أَيِي: ’أَقَا أَربِّي ن ڒجْذُوذْ نّغْ إِخْضَارْ إِ شكْ، حِيمَا أَذْ ثسّْنذْ مِينْ إِخْسْ نتَّا، ؤُ حِيمَا أَذْ ثْژَارذْ أَمْسڭَّاذْ، أَذْ ثسْڒذْ ثْمِيجَّا نّسْ زڭْ ؤُقمُّومْ نّسْ. \x ◘ \xo 22:‏14 \xt ڒخ. 7‏:‏52؛ رُوم. 3‏:‏26؛ 1 بُط. 3‏:‏18؛ 1 يُوح. 2‏:‏1\x*  
\v 15 شكْ أَذْ أَسْ ثِيڒِيذْ ذ أَشهَّاذْ غَارْ مَارَّا إِوْذَانْ س مَارَّا مِينْ ثژْرِيذْ ؤُ س مِينْ ثسْڒِيذْ.  
\v 16 إِوَا ڒخُّو، مَايمِّي وَارْ ثزْعِيمذْ عَاذْ؟ كَّارْ، أجّْ أَذْ شكْ سّْغضْصنْ، أَذْ ثتّْوَاسِيزذْڭذْ زِي دّْنُوبْ نّشْ أَمْ ثتّْڒَاغِيذْ خْ يِيسمْ نّسْ!‘   
\m
\v 17 أَوَارْنِي ڒَامِي د -عقْبغْ، إِوْضغْ ذَا غَارْ ؤُرْشَالِيمْ، ؤُشَا أَمْ ثُوغَا تّْژَادْجِيغْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ،  
\v 18 ژْرِيغْ ث ذڭْ إِجّْ ن ڒوْحِييْ، إِنَّا أَيِي: ’أَزّڒْ، ثفّْغذْ ذغْيَا زِي ؤُرْشَالِيمْ مِينْزِي وَارْ قبّْڒنْ شَا شّْهَاذثْ نّشْ خَافِي!‘ \x ◘ \xo 22:‏18 \xt مت. 10‏:‏14. \x*  
\v 19 نِّيغْ نشّْ: ’\add أَ\add* سِيذِي، أَقَا نِيثْنِي سّْننْ بلِّي ثُوغَا تّْحبّْسغْ إِنِّي يُومْننْ زَّايكْ، هتّْكغْ ثنْ س ؤُركُّوضْ ذِي ثمْزِيذَاوِينْ، \x ◘ \xo 22:‏19 \xt ڒخ. 22‏:‏4. \x*  
\v 20 ؤُ ڒَامِي تّْوَاسِيزّْڒنْ إِذَامّنْ ن ؤُشهَّاذْ نّشْ سْثِيفَانُوسْ، ثُوغَا بدّغْ أَكِيذْسنْ، أَرْضِيغْ خْ يِينِّي ث نْغِينْ ؤُ حْضِيغْ أَرُّوضْ ن يِينِّي ث يَارجْمنْ.‘ \x ◘ \xo 22:‏20 \xt ڒخ. 7‏:‏58؛ 8‏:‏1. \x*  
\v 21 \add خنِّي\add* إِنَّا أَيِي: ’رُوحْ، مِينْزِي أَذْ شكْ سّكّغْ غَارْ ڒَاڭّْوَاجْ حِيمَا أَذْ ثْبَارّْحذْ \add لْ-إِنْجِيلْ\add* إِ ڒڭْنُوسْ!‘ “ \x ◘ \xo 22:‏21 \xt ڒخ. 9‏:‏15؛ 13‏:‏2؛ ڭال. 1‏:‏15؛ 2‏:‏8؛ أَفا. 3‏:‏8؛ 1 تِيم. 2‏:‏7؛ 2 تِيم. 1‏:‏11. \x*   
\m
\v 22 ثُوغَا تّسْڒَانْ أَسْ أَڒْ أَوَاڒْ-أَ، خنِّي كَّارنْ سّْڭعّْذنْ ثْمِيجَّا نْسنْ، قَّارنْ: ”كّْسمْ ث زِي ثمُّورْثْ، مِينْزِي أَمْ وَانِيثَا وَارْ إِسْذِيهدْجْ أَذْ إِدَّارْ.“ \x ◘ \xo 22:‏22 \xt ڒخ. 21‏:‏36. \x*  
\v 23 أَمْ ثُوغَا سْغُويُّونْ، نطَّارنْ أَرُّوضْ نْسنْ ؤُشَا زُوزَّارَانْ ؤُشَاڒْ غَارْ ؤُجنَّا.  
\v 24 يُومُورْ ؤُكُومَانْذَارْ مَاحنْذْ أَذْ ث سِّيذْفنْ غَارْ لْقشْلَا، أَذْ ث سّقْسَانْ أَمْ ث تّْهتَّاكنْ س ؤُركُّوضْ حِيمَا أَذْ \add زَّايسْ\add* إِفْهمْ مَايمِّي خَاسْ سْغُوينْ \add أَمُّو\add*.  
\v 25 ؤُمِي ث جبْذنْ س ثْحزَّامِينْ \add إِ ؤُهتّكْ س ؤُركُّوضْ\add*، إِنَّا بُولُوسْ إِ ڒْقبْطَانْ خْ مْيَا إِ ذِينْ إِبدّنْ: ”مَا إِحدْجڒْ أَومْ عْلَاحْسَابْ شَّارِيعَا \add نْومْ\add* أَذْ ثْهتّْكمْ إِجّْ ن بْنَاذمْ ذ أَرُومَانِي س ؤُركُّوضْ أَمْ وَارْ خَاسْ ثحْكِيممْ \add عَاذْ\add*؟“   
\m
\v 26 ؤُمِي إِسْڒَا ڒْقبْطَانْ خْ مْيَا مَانْ أَيَا، إِرُوحْ غَارْ ؤُكُومَانْذَارْ، إِنَّا أَسْ: ”مِينْ غَا ثڭّذْ؟ أَقَا أَرْيَازْ-أَ ذ أَرُومَانِي!“  
\v 27 إِقَارّبْ-د غَارسْ ؤُكُومَانْذَارْ، إِنَّا أَسْ: ”إِنِي أَيِي، مَا شكْ ذ أَرُومَانِي؟“ يَارَّا-د خَاسْ بُولُوسْ: ”وَاهْ!“  
\v 28 يَارَّا-د خَاسْ ؤُكُومَانْذَارْ، إِنَّا: ”نشّْ طّْفغْ ڒْحقّْ-أَ ن ؤُمزْذَاغْ أَرُومَانِي س إِجّْ نْ ڒْقدّْ ذ أَمقّْرَانْ ن ثْمنْيَاثْ!“ بُولُوسْ إِنَّا: ”مَاشَا نشّْ خڒْقغْ-د زَّايسْ!“  
\v 29 ڒخْذنِّي، إِنِّي ثُوغَا نْوَانْ أَذْ ث هتّْكنْ س ؤُركُّوذْ، جِّينْ ث. أَكُومَانْذَارْ إِذْوڒْ إِڭّْوذْ، مِينْزِي إِفْهمْ أَقَا-ث ذ أَرُومَانِي ؤُ مِينْزِي إِجَّا إِ-ث أَذْ ث شَارْفنْ.  
\v 30 ثِيوشَّا نّسْ أَمْ ثُوغَا إِخْسْ أَذْ إِسّنْ ثِيذتّْ مِينْ خفْ ث ضڒْمنْ وُوذَاينْ، إِڭَّا أَذْ فسْينْ إِشذِّييّنْ \add نّسْ\add* ؤُشَا يُومُورْ أَذْ سّْمُوننْ إِزدْجِيفنْ ن إِكهَّاننْ ذ مَارَّا جْمَاعثْ \add ثَامقّْرَانْثْ\add* ن إِمقّْرَاننْ نْسنْ ؤُشَا إِسّهْوَا-د بُولُوسْ \add غَارْ ذِينْ\add*، إِسّْبدّْ إِ-ث ذِي ڒْوسْطْ نْسنْ.   
\b  
\b  
\m  
\c 23
\s1 پُولُوسْ زَّاثْ إِ جْمَاعثْ ثَامقّْرَانْثْ ن وُوذَاينْ  
\m
\v 1 بُولُوسْ إِقْشعْ \add ذڭْ إِنِّي إِقِّيمنْ\add* ذِي جْمَاعثْ \add ثَامقّْرَانْثْ\add*، إِنَّا: ”أَ إِرْيَازنْ ثَاوْمَاثْ! أَقَا نشّْ ؤُيُورغْ س ثْنفْسشْثْ ثصْفَا غَارْ مَارَّا \add إِغزْذِيسنْ\add* زَّاثْ إِ أَربِّي أَڒْ أَسّْ-أَ!“ \x ◘ \xo 23:‏1 \xt ڒخ. 24‏:‏16. \x*  
\v 2 أَنَانِييَاسْ، أَكهَّانْ، يُومُورْ إِنِّي إِ ثُوغَا ذِينْ أَكِيذسْ إِبدّنْ، أَذْ ث وْثنْ غَارْ ؤُقمُّومْ. \x ◘ \xo 23:‏2 \xt 1 إِج. 22‏:‏24؛ إِرْم. 20‏:‏2؛ يُوح. 18‏:‏22. \x*  
\v 3 خنِّي إِنَّا أَسْ بُولُوسْ: ”أَذْ شكْ إِوّثْ أَربِّي، شكْ ذ ڒْحِيضْ إِجِييَّارنْ! أَقَا شكْ ثقِّيمذْ ذَا مَاحنْذْ أَذْ خَافِي ثْحكْمذْ عْلَاحْسَابْ شَّارِيعَا، \add مَاشَا\add* ثْخَاڒَافذْ شَّارِيعَا س يِيخفْ نّشْ أَمْ ثُومُورذْ أَذْ أَيِي وْثنْ!“ \x ◘ \xo 23:‏3 \xt أَعَوذ. 17‏:‏9. \x*  
\v 4 إِنِّي إِ ثُوغَا كِيسْ إِبدّنْ، نَّانْ: ”مَا ثْذدْجْمذْ أَكهَّانْ ن أَربِّي؟“  
\v 5 إِنَّا بُولُوسْ: ”\add أَ\add* ثَاوْمَاثْ، وَارْ سِّينغْ أَقَا-ث ذ أَكهَّانْ، مِينْزِي ثُورَا: ’أَزدْجِيفْ ن ڒْڭنْسْ نّشْ وَارْ ث نعّڒْ!‘ “ \x ◘ \xo 23:‏5 \xt ؤُف. 22‏:‏27. \x*   
\m
\v 6 ؤُمِي إِسّنْ بُولُوسْ، أَقَا \add أَزْينْ\add* ن ڒْڭنْسْ ذ إِصَاذُوقِييّنْ ؤُ \add أَزْينْ نّغْنِي\add* زڭْ إِفَارِيسِييّنْ، إِڒَاغَا ذِي جْمَاعثْ \add ثَامقّْرَانْثْ\add*: ”أَ إِرْيَازنْ ثَاوْمَاثْ، نشّْ ذ أَفَارِيسِي، مِّيسْ ن إِفَارِيسِييّنْ، نشّْ تّتّْوَاحَاكَامغْ ذِي سِّيبّثْ ن ؤُسِيثمْ ذ ثْنُوكْرَا ن إِمتِّيننْ.“ \x ◘ \xo 23:‏6 \xt ڒخ. 24‏:‏21؛ 26‏:‏6؛ فِيل. 3‏:‏5. \x*  
\v 7 أَڒَامِي إِنَّا أَيَا، إِمْسَارْ إِجّْ ن ؤُخَارْوضْ جَارْ إِفَارِيسِييّنْ ذ إِصَاذُوقِييّنْ ؤُشَا إِتّْوَابْضَا ڒْڭنْسْ،  
\v 8 مِينْزِي إِصَاذُوقِييّنْ قَّارنْ بلِّي وَارْ ثدْجِي شَا ذ ثَانُوكْرَا نِيغْ ذ لْمَالَاكَاثْ ؤُڒَا ذ بُوحْبڒْ، مَاشَا إِفَارِيسِييّنْ شهّْذنْ خْ مَارَّا مَانْ أَيَا. \x ◘ \xo 23:‏8 \xt مت. 22‏:‏23؛ مك. 12‏:‏18؛ لك. 20‏:‏27. \x*  
\v 9 إِكَّارْ إِجّْ ن ؤُخَارْوضْ ذ أَمقّْرَانْ. شَا ن إِمْسڒْمَاذنْ ن إِذْلِيسنْ زڭْ وزْينْ ن إِفَارِيسِييّنْ كَّارنْ، تّمْنَاقَاشنْ أَكِيذْسنْ س جّهْذْ، نَّانْ: ”وَارْ نُوفِي ؤُڒَا ذ إِجّْ ن ڒْغَارْ ذِي بْنَاذمْ-أَ. مَاڒَا إِسِّيوڒْ أَكِيذسْ إِجّْ ن بُوحْبڒْ نِيغْ إِجّْ ن لْمَالَاكْ، مَانْ ڒْعِيبْ إِ يدْجَا \add خنِّي\add* ذِي مَانْ أَيَا؟“ \x ◘ \xo 23:‏9 \xt ڒخ. 25‏:‏25؛ 26‏:‏31. \x*  
\v 10 ؤُمِي إِكَّارْ إِجّْ ن ؤُخَارْوضْ ذ أَمقّْرَانْ، إِڭّْوذْ ؤُكُومَانْذَارْ أَذْ مزّْقنْ بُولُوسْ. خنِّي يُومُورْ إِعسْكَارِييّنْ إِرُومَانِييّنْ مَاحنْذْ أَذْ د-أَسنْ، أَذْ ث خضْفنْ زِي ڒْوسْطْ نْسنْ، ؤُشَا أَذْ ث أَوْينْ غَارْ لْقشْلَا.   
\m
\v 11 ذِي دْجِيڒثْ إِضْهَارْ-د سِيذِيثْنغْ إِ بُولُوسْ، إِنَّا أَسْ: ”أڭّْ ؤُڒْ، مِينْزِي أَمْ مَامّشْ خَافِي ثْشهْذذْ ذِي ؤُرْشَالِيمْ أَمُّو إِ غَا ثْشهْذذْ ؤُڒَا ذِي رُومَا!“ \x ◘ \xo 23:‏11 \xt ڒخ. 18‏:‏9. \x*   
\b  
\m  
\s1 ثَاخْشفْثْ ن وُوذَاينْ حِيمَا أَذْ نْغنْ بُولُوسْ  
\m
\v 12 أَڒَامِي ذ إِصْبحْ ڒْحَاڒْ، مُوننْ شَا زڭْ وُوذَاينْ، قّْننْ إِخفْ نْسنْ س إِشْثْ ن نّعْڒثْ مَاحنْذْ وَارْ تّتّنْ وَارْ سسّنْ أَڒْ ذ نْغنْ بُولُوسْ. \x ◘ \xo 23:‏12 \xt ڒخ. 23‏:‏21، 29، 30. \x*  
\v 13 كْثَارْ زِي أَربْعِينْ ن يرْيَازنْ كّْسنْ وَاوَاڒْ-أَ س إِشْثْ ن ثْجَادْجِيثْ.  
\v 14 إِنَا رُوحنْ غَارْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add*، نَّانْ: ”أَقَا نقّنْ إِخفْ نّغْ س إِشْثْ ن نّعْڒثْ مَاحنْذْ وَارْ نتّتّْ وَالُو أَڒْ غَا ننّغْ بُولُوسْ.  
\v 15 خنِّي ڒخُّو، \add مَاڒَا\add* كنِّيوْ ذ إِمقّْرَاننْ ن جْمَاعثْ \add ثَامقّْرَانْثْ\add* أَذْ ثتَّارمْ زڭْ ؤُكُومَانْذَارْ مَاحنْذْ أَذْ ث-إِ-د-إِنْذهْ غَارْومْ أَخْمِي ثخْسمْ أَذْ ثْخبّْشمْ ذِي ثْمسْڒَاشْثْ-أَ مْلِيحْ، أَقَا نشِّينْ نوْجذْ حِيمَا أَذْ ث ننّغْ قْبڒْ مَا أَذْ غَارْومْ د-يَاوضْ.“   
\m
\v 16 إِسْڒَا مِّيسْ ن ؤُتْشْمَاسْ ن بُولُوسْ خْ ثْحِيڒثْ-أَ. \add خنِّي\add* يُوذفْ غَارْ لْقشْلَا ؤُشَا إِخبَّارْ بُولُوسْ خْ مَانْ أَيَا.  
\v 17 إِڒَاغَا بُولُوسْ إِ يِيجّنْ زڭْ ڒْقبْطَانَاثْ خْ مْيَا، إِنَّا أَسْ: ”رُوحْ س ؤُبْڒِيغْ-أَ غَارْ ؤُكُومَانْذَارْ مِينْزِي غَارسْ شَا أَذْ أَسْ ث يِينِي.“  
\v 18 إِكْسِي ڒْقبْطَانْ خْ مْيَا أَبْڒِيغْ، ؤُشَا إِوْيِي ث غَارْ ؤُكُومَانْذَارْ، إِنَّا: ”بُولُوسْ، أَمحْبُوسْ، إِڒَاغَا أَيِي-د، إِتَّارْ أَيِي أَذْ أَشْ أَوْيغْ أَبْڒِيغْ-أَ إِ غَارْ إِدْجَا شَا أَذْ أَشْ ث إِنِي.“   
\m
\v 19 إِطّفْ ؤُكُومَانْذَارْ أَبْڒِيغْ س ؤُفُوسْ، إِدُّورْ زَّايسْ وحّْذسْ ؤُشَا إِسّقْسَا ث: ”مِينْ غَاركْ أَذْ أَيِي ث ثِينِيذْ؟“  
\v 20 إِنَّا أَسْ ؤُبْڒِيغْ: ”أَقَا ؤُذَاينْ أَرزُّونْ أَذْ زَّايكْ تَّارنْ مَاحنْذْ أَذْ د-ثسّهْوِيذْ بُولُوسْ ثِيوشَّا غَارْ جْمَاعثْ نْسنْ \add ثَامقّْرَانْثْ\add*، أَخْمِي خْسنْ أَذْ ث سّقْسَانْ عَاذْ. \x ◘ \xo 23:‏20 \xt ڒخ. 23‏:‏12. \x*  
\v 21 وَارْ تّجِّي أَذْ شكْ سّْقنْعنْ، مِينْزِي كْثَارْ زِي أَربْعِينْ ن يرْيَازنْ زَّايْسنْ ڭِّينْ أَسْ إِجّْ ن ڒْفخْ ذڭْ وبْرِيذْ، قّْننْ إِخفْ نْسنْ س إِشْثْ ن نّعْڒثْ مَاحنْذْ وَارْ تّتّنْ وَارْ سسّنْ أَڒْ ث نْغنْ. أَقَا نِيثْنِي وجْذنْ ڒخُّو، تّْرَاجَانْ أَذْ ثوْشذْ تّسْرِيحْ نّشْ.“  
\v 22 أَكُومَانْذَارْ إِجَّا أَبْڒِيغْ أَذْ إِرَاحْ، إِنَّا أَسْ: ”وَارْ تّجِّي حذْ أَذْ إِسّنْ، أَقَا ثسَّارڭْبذْ أَيِي خْ مَانْ أَيَا.“   
\m
\v 23 \add خنِّي\add* إِڒَاغَا-د غَارسْ خْ ثْنَاينْ ن إِقبْطَاننْ خْ مْيَا، إِنَّا: ”سْوجْذمْ مِيثَاينْ ن إِعسْكَارِييّنْ إِرُومَانِييّنْ مَاحنْذْ أَذْ رَاحنْ غَارْ قَايْصَارِييَا غَارْ ثْڒَاثَا ن دْجِيڒثْ، أَكِيذْسنْ سبْعِينْ ن يِينِّي إِنْيِينْ خْ يِييْسَانْ ؤُ مِيثَاينْ ن إِمْجبَّاذنْ ن ڒْقوْسْ س ؤُفُوسْ ؤُفُوسِي.  
\v 24 أجّْ إِ-ثنْ أَذْ سّْوجْذنْ إِشْثْ ن زَّايْڒثْ مَاحنْذْ أَذْ خَاسْ سّْغِيمنْ بُولُوسْ، أَذْ ث نذْهنْ غَارْ لْعَامِيلْ فِيلِيكْسْ ذِي ڒَامَانْ.“  
\v 25 \add خنِّي\add* يُورَا إِشْثْ ن ثبْرَاثْ، إِوْشَا أَسنْ ت. أَمُّو إِ ذَايسْ \add يُورَا\add*:   
\b  
\m
\v 26 ”كْلُوذِييُوسْ لِيسِييَاسْ، إِ لْعَامِيلْ يُوعْڒَانْ فِيلِيكْسْ: سْڒَامْ \add خَاكْ!\add*   
\m
\v 27 ؤُذَاينْ أَقَا طّْفنْ أَرْيَازْ-أَ ؤُ ثُوغَا خْسنْ أَذْ ث نْغنْ. وْشِيغْ \add أَسْ\add* أَفُوسْ أَكْ-ذ إِعسْكَارِييّنْ إِرُومَانِييّنْ ؤُشَا فكّغْ ث ؤُمِي سْڒِيغْ أَقَا-ث ذ أَرُومَانِي. \x ◘ \xo 23:‏27 \xt ڒخ. 21‏:‏33. \x*  
\v 28 مِينْزِي ثُوغَا خْسغْ أَذْ سّْنغْ مِينْ خفْ ث ضڒْمنْ، إِوْيغْ ث غَارْ جْمَاعثْ نْسنْ \add ثَامقّْرَانْثْ\add*.  
\v 29 ؤُفِيغْ أَقَا ضڒْمنْ ث ذِي سِّيبّثْ ن شَا ن إِخَارْوِيضنْ ن شَّارِيعَا نْسنْ، مَاشَا وَارْ ذِينْ \add ؤُفِيغْ\add* أَضْڒَامْ إِ إِسْذَاهدْجنْ إِشذِّييّنْ نِيغْ ڒْموْثْ.  
\v 30 ؤُمِي ذ أَيِي إِتّْوَانَّا، بلِّي ؤُذَاينْ ڭِّينْ أَسْ إِجّْ ن ڒْفخْ ذڭْ وبْرِيذْ س ثْنُوفّْرَا، سّكّغْ ث-إِ-د ڒخْذنِّي غَاركْ، ؤُمُورغْ إِ يِينِّي ث إِضڒْمنْ أَذْ غَاركْ رُوحنْ مَاحنْذْ أَذْ كِيذسْ سِّيوْڒنْ زَّاثكْ \add مِي خفْ ث ضڒْمنْ\add*. س تِّيسِيرْ!“   
\b  
\m
\v 31 إِعسْكَارِييّنْ إِرُومَانِييّنْ كْسِينْ بُولُوسْ، أَمْ مَامّشْ ذ أَسنْ يُومُورْ، ؤُشَا إِوْينْ ث س دْجِيڒثْ غَارْ ثنْذِينْثْ ن أَنْثِيبَاثْرِيسْ.  
\v 32 ثِيوشَّا نّسْ جِّينْ إِنِّي إِنْيِينْ خْ ييْسَانْ أَذْعقْبنْ إِعسْكَارِييّنْ إِمدُّوكَّاڒْ نْسنْ خْ إِضَارنْ غَارْ لْقشْلَا.  
\v 33 \add خنِّي\add* إِوْينْ ث غَارْ قَايْصَارِييَا، وْشِينْ ثَابْرَاثْ إِ لْعَامِيلْ ؤُشَا سّْبدّنْ بُولُوسْ زَّاثسْ.  
\v 34 أَوَارْنِي ڒَامِي إِغْرَا ثَابْرَاثْ \add نِّي\add*، إِسّقْسَا خْ مَانْ جِّيهثْ إِ زِي د-يُوسَا نتَّا، ؤُشَا ڒَامِي يُوفَا بلِّي نتَّا يُوسَا-د زِي كِيلِيكِييَا،  
\v 35 إِنَّا أَسْ: ”أَذْ أَشْ سْڒغْ مَاڒَا ؤُڒَا ذ يِينِّي إِ شكْ إِضڒْمنْ إِوْضنْ-د ذَا!“ خنِّي يُومُورْ أَذْ ثْ حْضَانْ ذِي ثَادَّارْثْ ن شّْرعْ ن هِيرُوذُوسْ، \add ؤُمِي قَّارنْ ’بْرِيثُورِييُومْ‘\add*.   
\b  
\b  
\m  
\c 24
\s1 پُولُوسْ زَّاثْ إِ لْعَامِيلْ فِيلِيكْسْ  
\m
\v 1 أَوَارْنِي خمْسَا ن وُوسَّانْ إِهْوَا أَنَانِييَاسْ، أَرَّايْسْ ن إِكهَّاننْ، أَكْ-ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add* ؤُ أَكْ-ذ إِجّْ ن ورْيَازْ سْ ڒْهَارْذْ إِصبْحنْ، قَّارنْ أَسْ ثَارْثُولُوسْ، ؤُشَا خبَّارنْ لْعَامِيلْ خْ بُولُوسْ. \x ◘ \xo 24:‏1 \xt ڒخ. 23‏:‏2. \x*  
\v 2 ؤُمِي خَاسْ د-ڒَْاغَانْ، إِقَارّبْ-د ثَارْثُولُوسْ غَارْ زَّاثْ مَاحنْذْ أَذْ ث إِضْڒمْ، إِنَّا:  
\b  
\m ”أَقَا زَّايكْ غَارْنغْ ڒهْنَا ثَامقّْرَانْثْ ؤُ سِّييَاسَا نّشْ أَقَا ثِيوِي-د أَطَّاسْ ن وعْذڒْ ذِي طّْوعْ ن ڒْڭنْسْ-أَ إِ د-يِيوْينْ سَّاهْڒَا،  
\v 3 ؤُ ذِي كُوڒْ أَمْشَانْ مَارَّا نشِّينْ نقْبڒْ ثْشُونِي نّشْ، \add أَ سِيذِي\add* فِيلِيكْسْ يُوعْڒَانْ.  
\v 4 مَاشَا حِيمَا وَارْ شكْ هكّْوڒغْ أَطَّاسْ، تَّارغْ زَّايكْ أَذْ ثسْڒِيذْ مْغِيرْ شْوَايْثْ غَارْ ثُوثْرَا نّغْ إِ \add زَّايكْ\add* نتَّارْ س ؤُوَاضعْ.  
\v 5 مِينْزِي نُوفَا بلِّي بْنَاذمْ-أَ أَقَا-ث ذ إِجّْ ن ڒحْڒَاشْ، إِتّْسبّبْ أَغُووّغْ جَارْ مَارَّا ؤُذَاينْ ذِي مْكُوڒْ ثَامُّورْثْ، مِينْزِي نتَّا ذ أَزدْجِيفْ ن ثبْرِيذْثْ ن إِنَاصِيرِييّنْ.  
\v 6 ڒَامِي نتَّا ثُوغَا يَارزُّو مَاحنْذْ أَذْ إِسّخْمجْ زَّاوشْثْ ثَامقّْرَانْثْ نّغْ، خنِّي نطّفْ إِ-ث ؤُشَا ثُوغَا نخْسْ أَذْ خَاسْ نحْكمْ س شَّارِيعَا نّغْ. \x ◘ \xo 24:‏6 \xt ڒخ. 21‏:‏28. \x*  
\v 7 مَاشَا أَكُومَانْذَارْ لِيسِييَاسْ يُوسَا-د ذِي ڒْوسْطْ س ؤُهتّكْ أَطَّاسْ، إِكْسِي ث جَارْ إِفَاسّنْ نّغْ، إِسّكّْ إِ-ث غَاركْ،  
\v 8 ؤُشَا يُومُورْ مَاحنْذْ إِنِّي إِخْسنْ أَذْ ث ضڒْمنْ، أَذْ غَاركْ د-أَسنْ. مَاڒَا ث ثسّقْسِيذْ، أَذْ ثْفهْمذْ زَّايسْ س يِيخفْ نّشْ مَارَّا ثِيمسْڒَايِينْ-أَ مِينْ خفْ ث نضْڒمْ.“   
\b  
\m
\v 9 شّثْشَانْ خَاسْ وُوذَاينْ نِّي عَاوذْ، نَّانْ: ”مَانْ أَيَا أَمُّو إِ إِدْجَا!“  
\v 10 خَاسْ ؤُشَا إِشيَّارْ لْعَامِيلْ إِ بُولُوسْ مَاحنْذْ أَذْ إِسِّيوڒْ. بُولُوسْ يَارَّا-د، إِنَّا:  
\b  
\m ”نشّْ سّْنغْ بلِّي شكْ ذ ڒْقَاضِي خْ ڒْڭنْسْ-أَ إِ يِيجّْ ن ڒْمِيجَاڒْ ن وَاطَّاسْ ن إِسڭّْوُوسَا، س ؤُينِّي أَذْ وْثغْ خْ يِيخفْ إِنُو س ثرْيَاسْثْ كْثَارْ.  
\v 11 أَمْ مَامّشْ غَا يِيڒِي ثسّْنذْ شكْ، أَقَا عْذُونْ مْغِيرْ ثنْعَاشْ ن وُوسَّانْ وَاهَا زڭْ وَامِي ڭعّْذغْ حِيمَا أَذْعبْذغْ ذِي ؤُرْشَالِيمْ.  
\v 12 نِيثْنِي وَارْ ذ أَيِي ؤُفِينْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ سَّاوَاڒغْ أَكْ-ذ شَا ن إِجّنْ نِيغْ سّْمُونغْ إِجّْ ن ؤُبَارُّو ن ڒْڭنْسْ، وَارْ إِدْجِي ذِي ثمْزِيذَاوِينْ نْسنْ، وَارْ إِدْجِي ذِي ثنْذِينْثْ. \x ◘ \xo 24:‏12 \xt ڒخ. 25‏:‏8؛ 28‏:‏17. \x*  
\v 13 نِيثْنِي وَارْ زمَّارنْ أَذْ سّْبيّْننْ مِينْ زِي ذ أَيِي ضڒْمنْ ڒخُّو.  
\v 14 مَاشَا مَانْ أَيَا أَذْ أَشْ نعْمغْ، بلِّيعبّْذغْ أَربِّي ن ڒجْذُوذْ إِنُو خْ ڒحْسَابْ ثْغُورِي نِّي خْ سَّاوَاڒنْ، مِينْزِي ؤُمْنغْ مَارَّا مِينْ يُورِينْ ذِي شَّارِيعَا ؤُ ذڭْ إِنَابِييّنْ،  
\v 15 أَمْ غَارِي سِيمَانْثْ ن ؤُسِيثمْ ذِي أَربِّي أَمْ مَامّشْ ؤُڒَا ذ نِيثْنِي غَارْسنْ، أَقَا أَذْ ذِينْ ثِيڒِي ثْنُوكْرَا زِي ثَادَّارْثْ ن إِمتِّيننْ، \add ثَانُوكْرَا\add* ن إِمْسڭَّاذنْ ؤُڒَا ذ \add ثَانُوكْرَا\add* ن يِينِّي وَارْ إِسڭّْذنْ.  
\v 16 أَمُّو ؤُڒَا ذ نشّْ تّڭّغْ ثِيزمَّارْ حِيمَا أَذْ غَارِي ثِيڒِي ڒبْذَا ثْنفْسشْثْ ثصْفَا زَّاثْ إِ أَربِّي ؤُ زَّاثْ إِ إِوْذَانْ. \x ◘ \xo 24:‏16 \xt ڒخ. 23‏:‏1. \x*   
\m
\v 17 أَوَارْنِي إِ وَاطَّاسْ ن إِسڭّْوُوسَا ؤُسِيغْ-د غَارْ ڒْڭنْسْ إِنُو مَاحنْذْ أَذْ أَوْيغْ صّْذَاقِي ذ ثْغَارْصِينْ. \x ◘ \xo 24:‏17 \xt ڒخ. 11‏:‏29؛ رُوم. 15‏:‏25. \x*  
\v 18 أَقَا إِوْذَانْ-أَ ؤُفِينْ أَيِي ذِي زَّاوشْثْ ثَامقّْرَانْثْ أَوَارْنِي ڒَامِي تّْوَاسِّيزْذڭغْ، أَمْ وَارْ ذِينْ \add غَارِي\add* ڒْغَاشِي نِيغْ ذ أَخَارْوضْ. \x ◘ \xo 24:‏18 \xt ڒخ. 21‏:‏27. \x*  
\v 19 مَاشَا ؤُذَاينْ نِّي د-يُوسِينْ زِي أَسِييَا، إِنِّي إِسّكَّارنْ إِوْذَانْ، أَقَا إِتّْخصَّا أَذْ حْضَارنْ ذَا أَكِيذِي زَّاثكْ مَاحنْذْ أَذْ أَيِي ضڒْمنْ زِي مِينْ مَا غَارْسنْ \add خَافِي\add*.  
\v 20 نِيغْ أَذْ إِنِينْ إِنَا إِ ذَا \add إِبدّنْ\add* مَانْ ڒْعِيبْ إِ ذَايِي ؤُفِينْ ؤُمِي بدّغْ زَّاثْ إِ جْمَاعثْ نْسنْ \add ثَامقّْرَانْثْ\add*،  
\v 21 مْغِيرْ أَوَاڒْ-أَ إِ ثُوغَا ڒَاغِيغْ ؤُمِي بدّغْ جَارْ أَسنْ: ’أَسّْ-أَ تّْوَاحكْمغْ زَّاثْومْ ذِي سِّيبّثْ ن ثْنُوكْرَا ن إِمتِّيننْ!‘ “ \x ◘ \xo 24:‏21 \xt ڒخ. 23‏:‏6؛ 28‏:‏20. \x*   
\b  
\m
\v 22 مَاشَا ؤُمِي إِسّنْ فِيلِيكْسْ أَبْرِيذْ-أَ مْلِيحْ، إِسّْبدّْ إِ-ثنْ، إِنَّا: ”خْمِي د غَا يَاسْ ؤُكُومَانْذَارْ، أَذْ كمّْڒغْ أَسدْجِي غَارْ مِينْ ذِينْ جَارْ أَومْ.“  
\v 23 \add خَاسْ ؤُشَا\add* يُومُورْ إِ ڒْقبْطَانْ خْ مْيَا حِيمَا أَذْ إِحْضَا بُولُوسْ س شْوَايْثْ ن لْحُورِّييَا كْثَارْ ؤُ وَارْ إِمنّعْ ؤُڒَا ذ إِجّْ زڭْ إِنِّي ث إِسّْننْ أَذْ خَاسْ سخَّارنْ. \x ◘ \xo 24:‏23 \xt ڒخ. 27‏:‏3؛ 28‏:‏16. \x*   
\m
\v 24 أَوَارْنِي شَا ن وُوسَّانْ إِجَّا فِيلِيكْسْ ذ ذْرُوسِيلَّا، ثَامْغَارْثْ نّسْ ذ ثُوذَاشْثْ، أَذْ د-أَوْينْ بُولُوسْ ؤُشَا سْڒَانْ زَّايسْ خْ لْ-إِيمَانْ ن لْمَاسِيحْ.  
\v 25 أَڒَامِي يِيوضْ ڒْهَارْذْ خْ ثْسڭْذَا ذ ضّبْطْ ن نّفْسْ ؤُ خْ لْحِيسَابْ إِ د غَا يَاسنْ، إِڭّْوذْ فِيلِيكْسْ، إِنَّا أَسْ: ”رُوحْ ڒخُّو! خْمِي غَارِي إِ غَا يِيڒِي ڒْوقْثْ، أَذْ أَشْ د-ڒَْاغِيغْ.“  
\v 26 نتَّا ثُوغَا إِسِّيثِيمْ عَاوذْ مَاحنْذْ بُولُوسْ أَذْ أَسْ إِوْشْ ثْمنْيَاثْ \add حِيمَا أَذْ أَسْ إِضْڒقْ\add*. س ؤُينِّي ثُوغَا خَاسْ د-إِڒَاغَا أَطَّاسْ ن ثْوَاڒَاوِينْ حِيمَا أَذْ كِيسْ إِسِّيوڒْ.   
\m
\v 27 مَاشَا ؤُمِي كمّْڒنْ ثْنَاينْ ن إِسڭّْوُوسَا، يُوسَا-د لْعَامِيلْ ونِّي ث إِ غَا إِخڒْفنْ، قَّارنْ أَسْ بُورْكِييُوسْ فَاسْثُوسْ. ؤُمِي ثُوغَا فِيلِيكْسْ إِخْسْ أَذْ يَارْضَا ؤُذَاينْ، إِجَّا بُولُوسْ ذِي سّْنَاسڒْ \add ذِي ڒحْبسْ\add*.   
\b  
\b  
\m  
\c 25
\s1 پُولُوسْ زَّاثْ إِ فَاسْثُوسْ  
\m
\v 1 أَڒَامِي د-يِيوضْ فَاسْثُوسْ غَارْ قَايْصَارِييَا، إِرُوحْ غَارْ ؤُرْشَالِيمْ أَوَارْنِي ڒَامِي عْذُونْ ثْڒَاثَا ن وُوسَّانْ.  
\v 2 إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْشنّْعنْ ن وُوذَاينْ سَّارڭْبنْ ث \add ذِينِّي\add* خْ مِينْ خفْ ضڒْمنْ بُولُوسْ ؤُشَا قدّْمنْ أَسْ إِشْثْ ن ثُوثْرَا.  
\v 3 تَّارنْ زَّايسْ مَاحنْذْ أَذْ \add أَسنْ\add* إِڭّْ س ڒْخَاضَارْ حِيمَا أَذْ إِنْذهْ بُولُوسْ غَارْ ؤُرْشَالِيمْ، أَڒَامِي زمَّارنْ نِيثْنِي أَذْ سّْوجْذنْ إِجّْ ن ڒْفخْ ذڭْ وبْرِيذْ مَاحنْذْ أَذْ ث نْغنْ.  
\v 4 مَاشَا فَاسْثُوسْ يَارَّا-د: ”بُولُوسْ إِتّْوَاحْضَا ذِي قَايْصَارِييَا ؤُ نشّْ سِيمَانْثْ إِنُو أَذْ ذِينْ رَاحغْ ذغْيَا.  
\v 5 أجّْ إِنِّي زَّايْومْ إِزمَّارنْ أَذْ أَفنْ ثَاوَّارْثْ أَذْ رَاحنْ أَكِيذْنغْ، ؤُشَا أجّْ إِ-ثنْ أَذْ ث ضڒْمنْ مَاڒَا ذِينْ شَا ن ڒْعِيبْ ذڭْ ورْيَازْ-أَ.“   
\m
\v 6 أَوَارْنِي ڒَامِي إِقِّيمْ ذِينْ ثْمنْيَا نِيغْعشْرَا ن وُوسَّانْ إِهْوَا غَارْ قَايْصَارِييَا ؤُ ثِيوشَّا نّسْ إِقِّيمْ خْ ڒْكُورْسِي ن شّْرعْ ؤُشَا يُومُورْ أَذْ د-أَوْينْ بُولُوسْ.  
\v 7 ؤُمِي د-يِيوضْ، نّْضنْ خَاسْ وُوذَاينْ إِنِّي ثُوغَا د-إِهْوَانْ زِي ؤُرْشَالِيمْ، ؤُشَا ڭِّينْ \add خَاسْ\add* أَطَّاسْ ن إِشثْشِيثنْ إِضقْڒنْ، وَارْ زمَّارنْ أَذْ ثنْ سّْبيّْننْ.  
\v 8 ؤُمِي إِوْثَا بُولُوسْ خْ يِيخفْ نّسْ، أَقَا وَارْ إِخْضِي نتَّا ذِي وَالُو، وَارْ ثدْجِي ذِي شَّارِيعَا ن وُوذَاينْ نِيغْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ ؤُڒَا ذِي قَايْصَارْ، \x ◘ \xo 25:‏8 \xt ڒخ. 24‏:‏12؛ 28‏:‏17. \x*  
\v 9 إِنَّا فَاسْثُوسْ إِ بُولُوسْ، أَمْ ثُوغَا إِخْسْ أَذْ إِڭّْ ڒْخَاضَارْ إِ وُوذَاينْ: ”مَا ثخْسذْ أَذْ ثْڭعّْذذْ غَارْ ؤُرْشَالِيمْ، حِيمَا أَذْ ذِينْ ثتّْوَاحَاكْمذْ زَّاثِي؟“  
\v 10 يَارَّا-د بُولُوسْ، إِنَّا: ”نشّْ أَقَا بدّغْ زَّاثْ إِ ڒْكُورْسِي ن شّْرعْ ن قَايْصَارْ مَانِي إِتّْخصَّا أَذْ خَافِي إِتّْوَاحْكمْ. وَارْ خْضِيغْ ذڭْ وُوذَاينْ س وَالُو أَمْ مَامّشْ شكْ ثسّْنذْ مْلِيحْ.  
\v 11 مَاڒَا خْضِيغْ نِيغْ مَاڒَا ڭِّيغْ مِينْ إِسْذَاهدْجنْ ڒْموْثْ، وَارْ تّْرِيكّْوِيڒغْ زِي ڒْموْثْ. مَاشَا مَاڒَا وَارْ ذِينْ بُو ثِيذتّْ نِيشَانْ إِ زِي ذ أَيِي ضڒْمنْ، خنِّي وَارْ إِزمَّارْ ؤُڒَا ذ إِجّنْ أَذْ أَيِي إِسلّمْ غَارْسنْ إِ أَرْضَا نْسنْ. نشّْ ؤُرِيغْ دّعْوثْ إِنُو غَارْ قَايْصَارْ.“ \x ◘ \xo 25:‏11 \xt ڒخ. 18‏:‏14. \x*   
\m
\v 12 أَوَارْنِي ڒَامِي ثُوغَا إِمْشَاوَارْ أَكْ-ذ وڭْرَاوْ، يَارَّا-د فَاسْثُوسْ: ”أَقَا ثسّْڭعّْذذْ دّعْوثْ نّشْ غَارْ قَايْصَارْ، \add خنِّي\add* غَارْ قَايْصَارْ إِ غَا ثْرَاحذْ!“   
\b  
\m  
\s1 ثَاوَاسِيثْ ن ؤُجدْجِيذْ أَغْرِيبَاسْ  
\m
\v 13 أَوَارْنِي ڒَامِي عْذُونْ شَا ن وُوسَّانْ يُوسَا-د ؤُجدْجِيذْ أَغْرِيبَاسْ ذ بَارْنِيكِي غَارْ قَايْصَارِييَا حِيمَا أَذْ سدْجْمنْ خْ فَاسْثُوسْ.  
\v 14 ؤُمِي نِيثْنِي سّعْذُونْ ذِينْ أَطَّاسْ ن وُوسَّانْ إِعَاوذْ فَاسْثُوسْ إِ ؤُجدْجِيذْ دّعْوثْ ن بُولُوسْ، إِنَّا: ”أَقَا ذَا إِجّْ ن ورْيَازْ ونِّي ذَا إِجَّا فِيلِيكْسْ ذ أَمحْبُوسْ. \x ◘ \xo 25:‏14 \xt ڒخ. 24‏:‏27. \x*  
\v 15 ڒَامِي ذ أَيِي ثُوغَا ذِي ؤُرْشَالِيمْ، سَّارڭْبنْ أَيِي خَاسْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْغَارنْ ن وُوذَاينْ، أَرزُّونْ زَّايِي أَذْ إِتّْوَاحَاكمْ زَّاثْسنْ.  
\v 16 نشّْ أَرِّيغْ-د خَاسنْ بلِّي إِرُومَانِييّنْ وَارْ نُّومِينْ أَذْ سلّْمنْ إِجّْ ن بْنَاذمْ حِيمَا أَذْ إِتّْوَانغْ مَاحنْذْ أَذْ ڭّنْ ڒْخَاضَارْ \add إِ إِوْذَانْ\add*. إِتّْخصَّا أَذْ حْضَارنْ زَّاثسْ إِنِّي ث إِضڒْمنْ ؤُشَا أَذْ غَارسْ يِيڒِي تَّاسِيعْ \add إِ بْنَاذمْ نِّي\add* مَاحنْذْ أَذْ إِذَافعْ خْ يِيخفْ نّسْ زِي جِّيهثْ ن تُّوهْمثْ.  
\v 17 ؤُمِي ذَا د-إِوْضغْ، وَارْ عْڭِيزغْ، ؤُشَا ثِيوشَّا نّسْ قِّيمغْ خْ ڒْكُورْسِي ن شّْرعْ، ؤُمُورغْ أَذْ د-أَوْينْ أَرْيَازْ نِّي غَارِي.  
\v 18 إِنِّي ث إِضڒْمنْ نّْضنْ أَسْ-د، مَاشَا أَمْ مَامّشْ ثُوغَا تّْرَاجِيغْ وَارْ زمَّارنْ أَذْ د-أَوْينْ ؤُڒَا ذ إِشْثْ ن تُّوهْمثْ إِ ثُوغَا زمَّارنْ أَذْ سّْبيّْننْ.  
\v 19 مَاشَا ثُوغَا غَارْسنْ خَاسْ شَا ن إِخَارْوِيضنْ ذِي سِّيبّثْ ن دِّينْ نْسنْ ؤُ زِي جِّيهثْ ن إِجّْ ن بْنَاذمْ قَّارنْ أَسْ يَاسُوع ونِّي أَقَا إِمُّوثْ، \add مَاشَا\add* ونِّي خفْ ثُوغَا بُولُوسْ إِقَّارْ بلِّي أَقَا إِدَّارْ.  
\v 20 أَمْ ثُوغَا شكّغْ ذِي ثْمسْڒَايِينْ-أَ إِ ذِي ثُوغَا أَرْزُوغْ، نِّيغْ إِ بُولُوسْ: ’مَا زعْمَا ثخْسذْ أَذْ ثْرَاحذْ غَارْ ؤُرْشَالِيمْ حِيمَا أَذْ ثتّْوَاحَاكْمذْ ذِينْ خْ ثْمسْڒَايِينْ-أَ؟‘  
\v 21 مَاشَا ؤُمِي ثُوغَا يَارزُّو أَذْ إِتّْوَاحْضَا أَڒْ خَاسْ غَا إِحْكمْ قَايْصَارْ، ؤُمُورغْ أَذْ ث حْضَانْ أَڒْ ث غَا سّكّغْ غَارْ قَايْصَارْ.“  
\v 22 إِنَّا أَغْرِيبَاسْ إِ فَاسْثُوسْ: ”ؤُڒَا ذ نشّْ خْسغْ أَذْ سْڒغْ إِ بْنَاذمْ-أَ!“ يَارَّا-د خَاسْ: ”ثِيوشَّا أَذْ أَسْ ثسْڒذْ!“   
\m
\v 23 ثِيوشَّا نّسْ يُوسَا-د أَغْرِيبَاسْ ذ بَارْنِيكِي س مَارَّا شَّانْ ؤُشَا ؤُذْفنْ غَارْ ثَادَّارْثْ ن شّْرعْ أَكْ-ذ إِكُومَانْذَارنْ ن ڒْعسْكَارْ ذ إِزدْجِيفنْ ن ثنْذِينْثْ. خنِّي يُومُورْ فَاسْثُوسْ، ؤُشَا يُوذفْ-د بُولُوسْ.  
\v 24 إِنَّا فَاسْثُوسْ: ”\add أَ\add* أَجدْجِيذْ أَغْرِيبَاسْ ؤُ كنِّيوْ مَارَّا إِرْيَازنْ إِ ذَا إِحْضَارنْ أَكِيذْنغْ: أَقَا خْ ورْيَازْ-أَ نِّي ثژْرِيمْ ذَانِيثَا، أَقَا شثْشَانْ خَاسْ غَارِي مَارَّا ڒْغَاشِي ن وُوذَاينْ ذِي ؤُرْشَالِيمْ ؤُڒَا ذَانِيثَا، سْغُويُّونْ مَاحنْذْ وَارْ إِتّْغِيمِي أَذْ إِدَّارْ عَاذْ.  
\v 25 مَاشَا ؤُفِيغْ نتَّا وَارْ إِڭِّي وَالُو مِينْ إِسْذَاهدْجنْ ڒْموْثْ، مَاشَا ؤُمِي إِسّْڭعّذْ دّعْوثْ نّسْ غَارْ قَايْصَارْ، ؤُمُورغْ أَذْ إِتّْوَاسّكّْ ذِينْ. \x ◘ \xo 25:‏25 \xt ڒخ. 23‏:‏9؛ 26‏:‏31. \x*  
\v 26 مَاشَا وَارْ غَارِي بُو ثْمسْڒَاشْثْ نِيشَانْ سّْنغْ ت زِي جِّيهثْ نّسْ حِيمَا أَذْ ت أَرِيغْ إِ قَايْصَارْ. س ؤُينِّي سّحْضَارغْ ث-إِ-د إِ كنِّيوْ، ذ أَمزْوَارُو إِ شكْ، \add أَ\add* أَجدْجِيذْ أَغْرِيبَاسْ، حِيمَا، أَوَارْنِي ڒَامِي إِ غَا نْكمّڒْ ثَارزُّوثْ، أَذْ غَارِي يِيڒِي مِينْ غَا أَرِيغْ \add إِ قَايْصَارْ\add*،  
\v 27 مِينْزِي وَارْ إِشُووَّارْ أَذْ سّكّغْ إِجّْ ن ؤُمحْبُوسْ بْڒَا مَا أَذْ أَرِيغْ إِخطَّانْ نّسْ.“   
\b  
\b  
\m  
\c 26
\s1 أَذَافعْ ن بُولُوسْ خْ يِيخفْ نّسْ زَّاثْ إِ ؤُجدْجِيذْ أَغْرِيبَاسْ  
\m
\v 1 \add خَاسْ ؤُشَا\add* إِنَّا أَغْرِيبَاسْ إِ بُولُوسْ: ”شكْ غَاركْ تّسْرِيحْ حِيمَا أَذْ ثسِّيوْڒذْ خْ يِيخفْ نّشْ!“ خنِّي إِسّْوِيژّضْ بُولُوسْ أَفُوسْ نّسْ ؤُشَا إِوْثَا خْ يِيخفْ نّسْ، إِنَّا:   
\b  
\m
\v 2 ”ذِي مَارَّا مِينْ خفْ ذ أَيِي ضڒْمنْ وُوذَاينْ، \add أَ\add* أَجدْجِيذْ أَغْرِيبَاسْ، حسّْبغْ إِخفْ إِنُو ذ \add بْنَاذمْ\add* ذ أَمِيمُونْ، أَقَا أَسّْ-أَ زمَّارغْ أَذْ وْثغْ خْ يِيخفْ إِنُو قِيبَاتْشْ نّشْ.  
\v 3 ذڭْ ؤُمزْوَارُو س مِينْزِي أَقَا شكْ ثسّْنذْ مْلِيحْ مَارَّا إِخَارْوِيضنْ ذ إِزرْفَانْ ن وُوذَاينْ. س ؤُينِّي تَّارغْ زَّايكْ أَذْ أَيِي ثسْڒذْ س تَّاسِيعْ ن ڒْخَاضَارْ.  
\v 4 مِينْزِي ؤُذَاينْ، إِوَا، مَاڒَا خْسنْ أَذْ شهْذنْ \add وَاهَا خْ مَانْ أَيَا\add*، سّْننْ أَبْرِيذْ ن ثُوذَارْثْ إِنُو مْلِيحْ زِي ثمْژِي إِنُو، أَمْ مَامّشْ ث ثُوغَا زڭْ ؤُمزْوَارُو جَارْ ڒْڭنْسْ إِنُو ؤُ ذِي ؤُرْشَالِيمْ.  
\v 5 نِيثْنِي سّْننْ أَيِي مْلِيحْ أَطَّاسْ زڭْ وَامِي، سّْننْ أَقَا ثُوغَا دَّارغْ عْلَاحْسَابْ ثَاغُورِي نِيشَانْ ن إِفَارِيسِييّنْ.  
\v 6 ؤُ ڒخُّو بدّغْ \add ذَانِيثَا\add*، تّْوَاحَاكَامغْ ذِي طّْوعْ ن ؤُسِيثمْ ن لْوَاعْذْ إِ زِي إِوَاعْذْ أَربِّي إِ ڒجْذُوذْ نّغْ. \x ◘ \xo 26:‏6 \xt أَمز. 3‏:‏15؛ 22‏:‏18؛ 26‏:‏4؛ 49‏:‏10؛ أَعَوذ. 18‏:‏15؛ 2 صم. 7‏:‏12؛ إِزهد. 132‏:‏11؛ إِشا. 4‏:‏2؛ 7‏:‏14؛ 9‏:‏5؛ 40‏:‏10؛ إِرْم. 23‏:‏5؛ 33‏:‏14؛ حِز. 34‏:‏23؛ 37‏:‏24؛ دَان. 9‏:‏24؛ مِيخَا 7‏:‏20. \x*  
\v 7 مَاغَارْ وَا ذ أَسِيثمْ نِّي تّْرَاجَانْثْ ثنْعَاشْ ن ثْقبَّاڒْ نّغْ أَذْ غَارسْ د-أَوْضنْثْ، أَمْ سّْڭعّْذنْثْ ثِيژَادْجِيثِينْ يُودْجْغنْ دْجِيڒثْ ذ وَاسّْ. ذِي طّْوعْ ن ؤُسِيثمْ-أَ، \add أَ\add* أَجدْجِيذْ أَغْرِيبَاسْ، ضڒْمنْ أَيِي وُوذَاينْ.  
\v 8 مَامّشْ ثْحكّْممْ كنِّيوْ؟ مَا وَارْ إِتّْخصَّا أَذْ نَامنْ بلِّي أَربِّي أَذْ إِسّْنكَّارْ-د إِمتِّيننْ؟   
\m
\v 9 زِيشْ ثُوغَا زعْمغْ نِيشَانْ، أَقَا إِتّْخصَّا أَذْ ڭّغْ أَطَّاسْ ن ثْمسْڒَايِينْ ضِيدّْ إِ يِيسمْ ن يَاسُوع نَّاصِيرِي. \x ◘ \xo 26:‏9 \xt ڒخ. 8‏:‏3؛ 9‏:‏1؛ 22‏:‏4؛ 1 كُور. 15‏:‏9؛ ڭال. 1‏:‏13؛ 1 تِيم. 1‏:‏13. \x*  
\v 10 ؤُشَا أَيَا إِ ڭِّيغْ عَاوذْ ذِي ؤُرْشَالِيمْ. أَمْ طّْفغْ ثِيزمَّارْ زِي جِّيهثْ ن إِمقّْرَاننْ ن إِكهَّاننْ، حبّْسغْ أَطَّاسْ ن إِمْقدَّاسنْ. ؤُشَا ڒَامِي تّْوَانْغنْ زَّايْسنْ، ثُوغَا أَرطِّيغْ س مَانْ أَيَا أَكْ-ذ إِنِّي خَاسْ إِحكْمنْ.  
\v 11 عذْبغْ ثنْ ذِي مَارَّا ثِيمْزِيذَاوِينْ، ڭِّيغْ خَاسنْ ؤُغِيڒْ مَاحنْذْ أَذْ شقّْفنْ إِسمْ ن يَاسُوع. ثُوغَا تّْهَاجغْ خَاسنْ أَطَّاسْ ؤُ ثُوغَا ڭُّورغْ غَارْ ثْندَّامْ إِنّغْنِي مَاحنْذْ أَذْ ثنْ مَارّْثغْ.   
\m
\v 12 ڒَامِي ثُوغَا ڭُّورغْ غَارْ ذِيمَاشْقْ زِي سِّيبّثْ نِّي س صُّولْطَا ذ تّسْرِيحْ زِي جِّيهثْ ن إِمقّْرَاننْ ن إِكهَّاننْ،  
\v 13 خنِّي، \add أَ\add* أَجدْجِيذْ، ؤُمِي ثُوغَا أَيِي ذڭْ وبْرِيذْ، ژْرِيغْ إِشْثْ ن ثْفَاوْثْ زڭْ ؤُجنَّا غَارْ وزْينْ ن وَاسّْ، ثتِّيسِّيقّْ كْثَارْ زِي ثْفُوشْثْ، ثنّضْ أَيِي-د ؤُ إِ يِينِّي أَكِيذِي إِمْسَافَارنْ.  
\v 14 نشِّينْ نوْضَا مَارَّا ذِي ثمُّورْثْ، سْڒِيغْ إِ إِشْثْ ن ثْمِيجَّا ثسَّاوَاڒْ-د أَكِيذِي، ثقَّارْ س ثْعِيبْرَانِيثْ: ’شَاوُولْ، شَاوُولْ، مَايمِّي خَافِي ثْذَارّْشذْ؟ أَقَا ثَارنْيذْ ثْزيَّارذْ خْ يِيخفْ نّشْ ؤُمِي شكْ ثشَّاثذْ \add أَوَارْنِي أَشْ\add* ذِي سْڒكْ ن بُويْكُوشْضَانْ.‘  
\v 15 نِّيغْ: ’مِينْ ثعْنِيذْ شكْ، أَ سِيذِي؟‘ إِنَّا سِيذِيثْنغْ: ’نشّْ ذ يَاسُوع أَنَّاصِيرِي، ونِّي ثْمَارّْثذْ.‘  
\v 16 خنِّي إِنَّا أَيِي: ’كَّارْ، ثْبدّذْ خْ إِضَارنْ نّشْ، مِينْزِي إِ ؤُيَا إِ ذ أَشْ د-ضْهَارغْ حِيمَا أَذْ شكْ أَرشْحّغْ ذ أَمْسخَّارْ ذ أَشهَّاذْ، أَقَا ؤُمِي ذ أَيِي ثژْرِيذْ ؤُ أَقَا أَذْ أَيِي ثْژَارذْ عَاوذْ.  
\v 17 أَذْ فكّغْ شكْ زڭْ ويْذُوذْ ن وُوذَاينْ ؤُ زِي ڒڭْنُوسْ نّغْنِي إِ غَارْ شكْ غَا سّكّغْ،  
\v 18 حِيمَا أَذْ ثَارزْمذْ ثِيطَّاوِينْ نْسنْ، حِيمَا أَذْ ثُوبنْ زِي ثَادْجسْثْ غَارْ ثْفَاوْثْ ؤُ زِي صُّولْطَا ن شِّيطَانْ غَارْ أَربِّي، ؤُ أَذْ طّْفنْ أَغْفَارْ ن دّْنُوبْ ذ إِشْثْ ن ثسْغَارْثْ ن ڒْوَارْثْ جَارْ إِمْقدَّاسنْ س لْ-إِيمَانْ إِ ذَايِي إِدْجَانْ.‘ \x ◘ \xo 26:‏18 \xt إِشا. 60‏:‏1. \x*   
\m
\v 19 س ؤُينِّي، \add أَ\add* أَجدْجِيذْ أَغْرِيبَاسْ، وَارْعكّْسغْ شَا ڒوْحِييْ نِّي ژْرِيغْ زڭْ ؤُجنَّا،  
\v 20 مَاشَا غَارْ ؤُمزْوَارْ بْذِيغْ أَذْ بَارّْحغْ \add س ڒخْبَارْ أَصبْحَانْ\add* إِ يِينِّي إِدْجَانْ ذِي ذِيمَاشْقْ ذ ؤُرْشَالِيمْ ؤُ إِ مَارَّا إِنِّي \add إِزدّْغنْ\add* ذِي ذْشُورَاثْ ن يَاهُوذِييَّا، ؤُشَا \add خنِّي\add* بَارّْحغْ عَاوذْ إِ ڒڭْنُوسْ حِيمَا أَذْ ثُوبنْ أَذْ ذوْڒنْ غَارْ أَربِّي، أَذْ ڭّنْ ڒخْذَايمْ إِ إِتّْڒِيقنْ إِ تُّوبثْ. \x ◘ \xo 26:‏20 \xt ڒخ. 9‏:‏19، 28؛ 22‏:‏17، 21. \x*  
\v 21 س ؤُينِّي طّْفنْ أَيِي وُوذَاينْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ ؤُشَا خْسنْ أَذْ أَيِي نْغنْ. \x ◘ \xo 26:‏21 \xt ڒخ. 21‏:‏30. \x*  
\v 22 مَاشَا أَربِّي إِوْشَا أَيِي أَفُوسْ أَڒْ أَسّْ-أَ، ؤُ خْزَارْ، أَقَا بدّغْ \add ذَا\add* زَّاثْ إِ ؤُمژْيَانْ ذ ؤُمقّْرَانْ، وَارْ قَّارغْ وَالُو إِ د-إِتّفّْغنْ زِي شَّارِيعَا ن مُوسَا ذ إِنَابِييّنْ، مْغِيرْ ثِيمسْڒَايِينْ وَاهَا نِّي زِي قَّارنْ نِيثْنِي أَقَا أَذْ إِڒِينْثْ،  
\v 23 بلِّي ثُوغَا إِتّْخصَّا إِ لْمَاسِيحْ أَذْ إِودّبْ ؤُ بلِّي نتَّا أَذْ يِيڒِي ذ أَمنْزُو ن ثْنُوكْرَا زِي ثَادَّارْثْ ن إِمتِّيننْ، أَذْ إِبَارّحْ س ثْفَاوْثْ إِ ڒْڭنْسْ\add -أَ\add* ؤُ إِ ڒڭْنُوسْ \add مَارَّا\add*.“ \x ◘ \xo 26:‏23 \xt إِشا. 60‏:‏1‏-‏3، 19، 20\x*   
\b  
\m
\v 24 أَوَارْنِي ڒَامِي إِذَافعْ بُولُوسْ س يِيخفْ نّسْ أَمُّو، إِنَّا فَاسْثُوسْ س جّهْذْ: ”أَقَا شكْ ذ أَبُوهَاڒِي، أَ بُولُوسْ. أَطَّاسْ ن ثْغُورِي ثسّْبُوهْڒِي إِ شكْ.“  
\v 25 مَاشَا بُولُوسْ إِنَّا أَسْ: ”نشّْ وَارْ تّْوَاخڒْفغْ شَا، \add أَ\add* سِيذِي فَاسْثُوسْ يُوعْڒَانْ، أَقَا قَّارغْ أَوَاڒنْ ن ثِيذتّْ، ذَايْسنْ ڒَامَانْ.  
\v 26 ؤُڒَا ذ أَجدْجِيذْ أَغْرِيبَاسْ إِسّنْ مْلِيحْ خْ ثْمسْڒَايِينْ-أَ. س ؤُينِّي سَّاوَاڒغْ س ثرْيَاسْثْ مِينْزِي إِتّْڒِيغْ أَيِي بلِّي ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ زِي ثْمسْڒَايِينْ-أَ أَقَا ثنُّوفَّارْ خَاسْ، مِينْزِي مَارَّا مَانْ أَيَا وَارْ إِمْسَارْ ذِي ثْنُوفّْرَا.  
\v 27 مَا ثُومْنذْ زڭْ إِنَابِييّنْ، \add أَ\add* أَجدْجِيذْ أَغْرِيبَاسْ؟ نشّْ سّْنغْ بلِّي ثُومْنذْ \add زَّايْسنْ\add*.“  
\v 28 مَاشَا أَغْرِيبَاسْ إِنَّا أَسْ: ”\add مْغِيرْ\add* س ذْرُوسْ ثسّْقنْعذْ أَيِي حِيمَا أَذْ ذوْڒغْ ذ أَمَاسِيحِي.“  
\v 29 إِنَّا \add أَسْ\add* بُولُوسْ: ”تَّارغْ أَربِّي بلِّي ذغْيَا ؤُ إِ وَاطَّاسْ، وَارْ إِدْجِي شكْ وَاهَا، مَاشَا ؤُڒَا ذ مَارَّا إِنِّي ذ أَيِي إِتّسْڒَانْ أَسّْ-أَ، أَذْ ذوْڒنْ أَمْ نشّْ، مَاشَا بْڒَا إِشذِّييّنْ-أَ.“ \x ◘ \xo 26:‏29 \xt 1 كُور. 7‏:‏7. \x*  
\v 30 إِكَّارْ ؤُجدْجِيذْ ذ لْعَامِيلْ ذ بَارْنِيكِي ذ \add مَارَّا\add* إِنِّي ثُوغَا أَكِيذْسنْ إِقِّيمنْ،  
\v 31 ؤُشَا فّْغنْ سّنِّي أَمْ سَّاوَاڒنْ أَكْ-ذ وَايَاوْيَا، نَّانْ جَارْ أَسنْ: ”أَرْيَازْ-أَ وَارْ إِڭِّي شَا مِينْ إِسْذَاهدْجنْ ڒْموْثْ ؤُڒَا ذ إِشذِّييّنْ.“ \x ◘ \xo 26:‏31 \xt ڒخ. 23‏:‏9؛ 25‏:‏25. \x*  
\v 32 إِنَّا أَغْرِيبَاسْ إِ فَاسْثُوسْ: ”مَاعْلِيكْ وَارْ ثُوغِي إِسّْڭعّذْ دّعْوثْ نّسْ غَارْ قَايْصَارْ، إِڒِي أَقَا إِتّْوَاضْڒقْ بْنَاذمْ-أَ.“   
\b  
\b  
\m  
\c 27
\s1 أَسَافَارْ ن بُولُوسْ غَارْ رُومَا  
\m
\v 1 خَاسْ ؤُشَا إِكّسْ فَاسْثُوسْ أَوَاڒْ، أَقَا إِتّْخصَّا أَذْ إِتّْوَاسّكّْ غَارْ إِطَالْيَا. نتَّا إِسلّمْ بُولُوسْ ذ شَا ن إِمحْبَاسْ نّغْنِي إِ يِيجّْ ن ڒْقبْطَانْ خْ مْيَا قَّارنْ أَسْ يُولِييُوسْ، ثُوغَا-ث زِي ڒْكُومْبَانِييّثْ ن قَايْصَارْ.  
\v 2 ڒَامِي ننْوَا أَذْ نْبحَّارْ، ننْيَا ذڭْ إِجّْ ن ؤُغَارَّابُو زِي أَذْرَامَانْثُوسْ، ثُوغَا أَذْ إِكّْ خْ جّْوَايهْ إِ إِدْجَانْ خْ ثْمَا ن أَسِييَا، ؤُشَا نْرُوحْ. إِنْيَا أَكِيذْنغْ ذڭْ ؤُغَارَّابُو أَرِيسْثَارْخُوسْ، إِجّْ ن ورْيَازْ زِي ثِيسَّالُونِيكَا ذِي مَاكِيذُونِييَا.  
\v 3 ثِيوشَّا نّسْ نِيوضْ غَارْ صَايْذُونْ. ڒْقبْطَانْ خْ مْيَا ثُوغَا إِدْجَا مْلِيحْ أَكْ-ذ بُولُوسْ، إِسَامْحْ أَسْ أَذْ إِرَاحْ غَارْ إِمدُّوكَّاڒْ نّسْ حِيمَا أَذْ خَاسْ سخَّارنْ. \x ◘ \xo 27:‏3 \xt ڒخ. 24‏:‏23؛ 28‏:‏16. \x*  
\v 4 سّنِّي نفّغْ، نْبحَّارْ س إِجّْ ن دُّورَا، نعْذُو خْ قُوبْرُوسْ، مِينْزِي أَسمِّيضْ ثُوغَا إِشَّاثْ ذَايْنغْ ذڭْ ؤُغمْبُوبْ.  
\v 5 نژْوَا ڒبْحَارْ ن كِيلِيكِييَا ذ بَامْفِيلِييَا، ؤُشَا نِيوضْ غَارْ مِيرَا، إِشْثْ ن ثنْذِينْثْ ذِي لِيكِييَا.  
\v 6 ڒْقبْطَانْ خْ مْيَا يُوفَا ذِينْ إِجّْ ن ؤُغَارَّابُو زِي إِسْكَانْذَارِييَّا، إِتّْرَاحْ غَارْ إِطَالْيَا، إِسّنْيَا أَنغْ ذَايسْ.  
\v 7 مَاغَارْ \add أَغَارَّابُو\add* وَارْ إِرُوحْ غَارْ زَّاثْ أَطَّاسْ ن وُوسَّانْ، نِيوضْ س ؤُغِيڒْ زَّاثْ إِ ثڭْزِيرْثْ ن كْنِيذُوسْ، ؤُ مِينْزِي وَارْ ذ أَنغْ يجِّي ؤُسمِّيضْ أَذْ نْرَاحْ \add غَارْ زَّاثْ\add*، نْبحَّارْ ذڭْ ؤُدُّورِي ن كْرِيثَا زَّاثْ إِ سَالْمُونِي.  
\v 8 \add ڒَامِي\add* ثُوغَا وَارْ نْزمَّارْ عْڒَاينْ أَذْ ننْذهْ غَارْ زَّاثْ، نِيوضْ، ڒَامِي نوْثَا إِشْثْ ن دُّورَا ثمْغَارْ، غَارْ إِجّْ ن ومْشَانْ ؤُمِي قَّارنْ ’ڒْْمُويَّاثْ إِصبْحَاننْ‘، ونِّي إِدْجَانْ طَّارْفْ إِ ثنْذِينْثْ قَّارنْ أَسْ لَاسِييَّا.   
\m
\v 9 نقِّيمْ أَطَّاسْ ن ڒْوقْثْ ذِينِّي أَڒْ د-إِعْذُو أَسّْ ن ؤُژُومِّي ن وُوذَاينْ. ؤُمِي إِذْوڒْ ؤُسَافَارْ ذِي ڒبْحَارْ يوْعَارْ، إِعْڒمْ \add أَسنْ\add* بُولُوسْ،  
\v 10 إِنَّا: ”\add أَ\add* إِرْيَازنْ، تّْوَاڒِيغْ أَسَافَارْ أَذْ يَاوِي ذْرُوشْثْ ذ ثْخسَّارْثْ \add أَطَّاسْ\add*، وَارْ ثدْجِي إِ سّڒْعثْ ذ ؤُغَارَّابُو نّغْ وَاهَا، مَاشَا ؤُڒَا إِ ثُوذَارْثْ نّغْ.“  
\v 11 مَاشَا ڒْقبْطَانْ خْ مْيَا ثُوغَا إِسْڒَا كْثَارْ غَارْ ؤُمنْذَاهْ ذ ڒْقبْطَانْ ن ؤُغَارَّابُو خْ مِينْ ثُوغَا إِتّسْڒَا غَارْ وَاوَاڒنْ ن بُولُوسْ.  
\v 12 ؤُمِي ثُوغَا أَمْشَانْ ن ڒْمُويِّي وَارْ إِحْڒِي حِيمَا أَذْ سّعْذُونْ ڒْمشْثَا ذِينْ، إِبدّْ أَرَّايْ ن وزْينْ أَمقّْرَانْ نْسنْ أَذْ فّْغنْ سّنِّي، بَالَاكْ أَذْ أَوْضنْ غَارْ فِينِيكْسْ، إِجّْ ن ڒْمُويِّي ذِي كْرِيثَا، إِوَاڒَانْ لْجَانُوبْ، حِيمَا أَذْ ذِينْ سّعْذُونْ ڒْمشْثَا. *   
\b  
\m  
\s1 ثَاحَارْيَاضْثْ  
\m
\v 13 ؤُمِي إِسَاهَا ؤُسمِّيضْ ن لْجَانُوبْ، ثُوغَا نِيثْنِي سِّيتِّيمنْ أَذْ أَوْضنْ أَمْ مَامّشْ ت خْسنْ، ؤُشَا نبْذَا تّْشُوقَانْ خْ طَّارْفْ ن ثْمَا ن كْرِيثَا.  
\v 14 مَاشَا شْوَايْثْ أَوَارْنِي مَانْ أَيَا، ثكَّارْ إِشْثْ ن ثْحَارْيَاضْثْ، قَّارنْ أَسْ تِّيفُونْ ’ؤُرُوكْلِيذُونْ‘. \f ◼ \fr 27:‏14 \ft \+bd ’تِّيفُونْ ؤُرُوكْلِيذْيُونْ‘\+bd* - أَقَا-ث ذ إِجّْ ن ؤُسمِّيضْ إِ د-يُوسِينْ زِي شَّامَالْ.\f*  
\v 15 إِتّْوَاكْسِي زَّايسْ ؤُغَارَّابُو س جّهْذْ، وَارْ إِزمَّارْ إِ ؤُسمِّيضْ. \add خنِّي\add* نسْثوْطعْ \add ؤُشَا نتّْوَانْذهْ\add*.  
\v 16 أَمْ نكَّا ذڭْ ؤُدُّورِي ن إِشْثْ ن ثڭْزِيرْثْ ذ ثَامژْيَانْثْ ؤُمِي قَّارنْ ’قَاوْذَا‘، س ؤُغِيڒْ إِ نمْنعْ ضْمَانْ ن ثْغَارَّابُوثْ ن ؤُسلّكْ \add إِ إِدْجَانْ غَارْ ضفَّارْ ن ؤُغَارَّابُو\add*.  
\v 17 نسّْڭعّذْ إِ-ت، ؤُ نسّجْهذْ أَغَارَّابُو أَمْ ث نبْيسْ سْوَادَّايْ س إِحزَّامنْ. مَاغَارْ ثُوغَا نڭّْوذْ أَقَا أَغَارَّابُو أَذْ إِمّنْضَارْ خْ إِشْثْ ن ڒْڭعّْذثْ ن إِجْذِي ذِي ڒبْحَارْ، نسّهْوَا-د ڒْبَاشّْ ؤُشَا نتّْوَانْذهْ س ؤُسمِّيضْ ؤُ أَمُّو إِ نْڒَاحْ.  
\v 18 ؤُشَا ؤُمِي ثَاحَارْيَاضْثْ ثْهَاجْ خَانغْ أَطَّاسْ، خنِّي ثِيوشَّا نّسْ ننْضَارْ سّڒْعثْ نّغْ ذِي ڒبْحَارْ.  
\v 19 ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا ننْضَارْ ڒقْشُوعْ ن ؤُغَارَّابُو س إِفَاسّنْ نّغْ.  
\v 20 ڒَامِي ثَاحَارْيَاضْثْ ثقِّيمْ ثتّْسُوضْ أَطَّاسْ ن وُوسَّانْ، وَارْ ثْبِينْ ثْفُوشْثْ ڒَا ذ ثَازِيرِي ؤُڒَا ذ إِثْرَانْ، خنِّي إِتّْوَاقْضعْ مَارَّا ڒَايَاسْ أَذْ نقِّيمْ ندَّارْ.   
\m
\v 21 ڒَامِي وَارْ إِزمَّارْ ؤُڒَا ذ إِجّْ أَذْ إِصْبَارْ عَاذْ، إِبدّْ بُولُوسْ ذِي ڒْوسْطْ نْسنْ، إِنَّا: ”أَ إِرْيَازنْ، ثُوغَا إِتّْخصَّا أَومْ أَذْ غَارِي ثسْڒمْ، خنِّي وَارْ نفِّيغْ شَا زِي كْرِيثَا ؤُ وَارْ ذ أَنغْ ثْڒقّفْ ذْرُوشْثْ-أَ ذ ڒحْصَارثْ-أَ.  
\v 22 ڒخُّو أَذْ كنِّيوْ شجّْعغْ، مِينْزِي ؤُڒَا ذ إِجّْ زَّايْومْ وَارْ إِتّْودَّارِي شَا ثُوذَارْثْ نّسْ، مْغِيرْ أَغَارَّابُو وَاهَا \add أَذْ إِغبَّاڒْ\add*.  
\v 23 مِينْزِي إِبدّْ-د غَارِي دْجِيڒثْ-أَ لْمَالَاكْ ن أَربِّي ونِّي نشّْ نّسْ ؤُ ونِّي ؤُمِيعبّْذغْ.  
\v 24 نتَّا إِنَّا أَيِي: ”وَارْ تّڭّْوذْ شَا، أَ بُولُوسْ، مِينْزِي إِتّْخصَّا أَشْ أَذْ ثْبدّذْ قِيبَاتْشْ إِ قَايْصَارْ. خْزَارْ مَارَّا إِنِّي أَكِيذكْ إِتّْبحَّارنْ، أَقَا إِوْشَا أَشْ ثنْ أَربِّي.“  
\v 25 س ؤُيَا ڭّمْ ثَارْيَاسْثْ، أَ إِرْيَازنْ، مِينْزِي تِّيقّغْ ذِي أَربِّي، بلِّي أَذْ ثفّغْ أَمْ مَامّشْ ذ أَيِي إِنَّا.  
\v 26 مَاشَا أَذْ نمّنْضَارْ خْ إِشْثْ ن ثڭْزِيرْثْ.“   
\m
\v 27 أَوَارْنِي ڒَامِي نتّْوَاعَارنْ زِي سَّا غَارْ ذِيهَا ؤُ نسِّيحڒْ إِخفْ نّغْ ذِي ڒبْحَارْ ن هَاذْرِييُوسْ، إِتّْغِيڒْ أَسنْ إِ إِبحْرِييّنْ ذِي ڒْوسْطْ ن دْجِيڒثْ، أَقَا نْقَارّبْ-د غَارْ ڒْبَارّْ.  
\v 28 نِيثْنِي نْضَارنْ أَيْڒِيزِيمْ ذِي رَادْجَاغْ ن ڒبْحَارْ،عبَّارنْ عِيشْرِينْ ن ثِيذِّيوِينْ. ؤُمِي عْذُونْ شْوَايْثْ،عبَّارنْ نِيثْنِي خمّسْطَاشْ ن ثِيذِّيوِينْ. \f ◼ \fr 27:‏28 \ft \+bd ’ثِيذِّي - ثِيذِّيوِينْ‘\+bd* - ڒْقدّْ ن إِجّْ ن بْنَاذمْ إِ إِسّْوِيژَّاذنْ إِفَاسّنْ نّسْ سنّجْ إِ ؤُزدْجِيفْ نّسْ، أَقَا-ث عْڒَاحَاڒْ 1،8 مِيثْرُو.\f*  
\v 29 أَمْ نڭّْوذْ أَذْ نڒْقفْ إِمُوشَانْ ن سّدْجَاحْ، ننْضَارْ أَربْعَا ن إِيْڒِيزَامْ زِي ضفَّارْ ن ؤُغَارَّابُو، ؤُشَا نتَّارْ أَذْ د-يَاوضْ ؤُزِيڒْ.   
\m
\v 30 ڒَامِي ثُوغَا إِبحْرِييّنْ خْسنْ أَذْ أَروْڒنْ زڭْ ؤُغَارَّابُو، سّْضَارنْ ثَاغَارَّابُوثْ ن ؤُسلّكْ غَارْ ڒبْحَارْ أَخْمِي خْسنْ أَذْ ذَايسْ نْيِينْ مَاحنْذْ أَذْ شدّنْ أَغَارَّابُو غَارْ ثمُّورْثْ.  
\v 31 ؤُمِي إِژْرَا بُولُوسْ مَانْ أَيَا، إِنَّا إِ ڒْقبْطَانْ خْ مْيَا ؤُ إِ إِعسْكَارِييّنْ: ”مَاڒَا إِنَا وَارْ قِّيمنْ ذڭْ ؤُغَارَّابُو، وَارْ ثْزمَّارمْ أَذْ تّْوَاسّْنجْممْ.“  
\v 32 خنِّي قسّنْ إِعسْكَارِييّنْ إِسغْوَانْ ن ثْغَارَّابُوثْ \add ن ؤُسلّكْ\add* ؤُشَا جِّينْ ت أَذْ ثْرُوحْ.   
\m
\v 33 أَڒَامِي د-إِقَارّبْ أَذْ إِصْبحْ ڒْحَاڒْ، إِزِييَّارْ إِ-ثنْ بُولُوسْ مَارَّا حِيمَا أَذْ شّنْ، إِنَّا: ”أَرْبعْطَاشْ ن وُوسَّانْ أَقَا وَارْ ثشِّيمْ وَالُو زِي سِّيبّثْ ن لْخَاطَارْ.  
\v 34 س ؤُينِّي شجّْعغْ كنِّيوْ أَذْ ثشّمْ، حِيمَا أَذْ ثقِّيممْ ثدَّارمْ، مِينْزِي وَارْ إِوطِّي ؤُڒَا ذ إِجّْ ن ؤُژطُّو \add ن ؤُشُووَّافْ\add* ن ؤُزدْجِيفْ ن ؤُڒَا ذ إِجّنْ زَّايْومْ.“ \x ◘ \xo 27:‏34 \xt مت. 10‏:‏30. \x*  
\v 35 أَوَارْنِي ڒَامِي إِنَّا أَيَا، إِكْسِي أَغْرُومْ، إِسّمْغَارْ أَربِّي قِيبَاتْشْ إِ مَارَّا، يَارْژَا إِ-ث، إِبْذَا أَذْ إِشّْ. \x ◘ \xo 27:‏35 \xt 1 صم. 9‏:‏13؛ يُوح. 6‏:‏11؛ 1 تِيم. 4‏:‏3. \x*  
\v 36 مَارَّا تّْوَاشجّْعنْ ؤُ كْسِينْ مَاشَّا.  
\v 37 ثُوغَا أَنغْ ذڭْ ؤُغَارَّابُو ذِي مِيثَاينْ ؤُ-ستَّا ؤُ-سبْعِينْ ن يرْيَازنْ.  
\v 38 ڒَامِي جِّيوْننْ س مَاشَّا، بْذَانْ سّفْسَاسنْ أَغَارَّابُو، أَمْ كْسِينْ ڒْحبّْ \add ن يِيرْذنْ\add*، نْضَارنْ ث ذِي ڒبْحَارْ.   
\m
\v 39 أَڒَامِي إِصْبحْ ڒْحَاڒْ، ثُوغَا إِبحْرِييّنْ وَارْ سِّيننْ مَانْ ثَامُّورْثْ \add إِ ثدْجَا\add*، مَاشَا ژْرِينْ إِجّْ ن ؤُمسْرُوقْ ن ڒبْحَارْ غَارْ ثْمَا ن ڒْبَارّْ ؤُشَا مْشَاوَارنْ، مَا زمَّارنْ أَذْ ذِينْ عَارْننْ أَغَارَّابُو.  
\v 40 ؤُمِي قضْونْ إِيْڒِيزَامْ ن ؤُغَارَّابُو، جِّينْ ثنْ ذِي ڒبْحَارْ، فسْينْ إِشدَّانْ ن ڒمْقَاذفْ، سّْڭعّْذنْ ڒْبَاشّْ ن زَّاثْ إِ ؤُسمِّيضْ إِتّْسُوضنْ، وجّْهنْ غَارْ ثْمَا ن ڒْبَارّْ.  
\v 41 مَاشَا أَغَارَّابُو إِوْثَا إِجّْ ن ؤُعَارِّيشْ ن يجْذِي مَانِي إِدْجَا ڒبْحَارْ غَارْ ثْنَاينْ ن إِغزْذِيسنْ ؤُشَا نُّوغنْ س ؤُغَارَّابُو. يَارْسَا زَّاثْ ن ؤُغَارَّابُو \add خْ ؤُعَارِّيشْ ن يجْذِي\add*، وَارْ إِزمَّارْ أَذْ إِنْهزّْ، مَاشَا ضفَّارْ ن ؤُغَارَّابُو إِقڒْعْ إِ-ث جّهْذْ ن ڒمْوَاجْ. \x ◘ \xo 27:‏41 \xt 2 كُور. 11‏:‏25. \x*   
\m
\v 42 ثُوغَا نوَّانْ إِعسْكَارِييّنْ أَذْ نْغنْ إِمحْبَاسْ حِيمَا وَارْ إِمّنْضَارْ حذْ إِخفْ نّسْ \add ذِي ڒبْحَارْ\add* مَاحنْذْ أَذْ إِعُومّْ، ؤُشَا أَذْ يَارْوڒْ.  
\v 43 مَاشَا ڒْقبْطَانْ خْ مْيَا ونِّي ثُوغَا إِخْسْ أَذْ إِسّنْجمْ بُولُوسْ، إِسّْبدّْ إِ-ثنْ، يُومُورْ بلِّي إِنِّي إِزمَّارنْ أَذْ مّنْضَارنْ إِخفْ نْسنْ \add ذڭْ وَامَانْ\add*، مَاحنْذْ أَذْ عُومّنْ، أَذْ عُومّنْ ذ أَمزْوَارُو، مَاحنْذْ أَذْ أَوْضنْ غَارْ ڒْبَارّْ.  
\v 44 وِي إِقِّيمنْ، إِجَّا إِ-ثنْ أَذْ ژْوَانْ خْ ثْفڒْوِينْ ؤُ خْ إِزيْنَانْ ن إِكشُّوضنْ ن ؤُغَارَّابُو، ؤُشَا أَمُّو إِ إِوْضنْ مَارَّا غَارْ ڒْبَارّْ، تّْوَاسّْنجْمنْ.   
\b  
\b  
\m  
\c 28
\s1 پُولُوسْ ذِي ثڭْزِيرْثْ ن مَالْثَا  
\m
\v 1 أَوَارْنِي مَانْ أَيَا نفْهمْ، بلِّي ثَاڭْزِيرْثْ-أَ قَّارنْ أَسْ مَالْثَا.  
\v 2 إِبَارَّانِييّنْ إِنِّي ذِينْ إِزذْغنْ ڭِّينْ أَكِيذْنغْ مْلِيحْ أَطَّاسْ، أَمْ سِّيغنْ إِشْثْ ن ثْمسِّي ذ ثَامقّْرَانْثْ ؤُشَا ڒَاغَانْ أَنغْ مَارَّا غَارْسنْ، حِيمَا أَذْ نژْغڒْ مِينْزِي أَنْژَارْ ثُوغَا إِشَّاثْ أَطَّاسْ ؤُ ثُوغَا ثسْمضْ.  
\v 3 \add ؤُمِي\add* ثُوغَا إِسّْمُونْ بُولُوسْ أَعُورِّيشْ ن إِكشْوَاضْ، إِسَّارْسْ إِ-ثنْ خْ ثْمسِّي، خنِّي س ڒحْمُو نِّي إِفّغْ-د إِجّْ ن ؤُفِيغَارْ ؤُشَا إِقّسْ أَسْ ذڭْ ؤُفُوسْ.  
\v 4 ؤُمِي ژْرِينْ إِبَارَّانِييّنْ أَقَا يُويڒْ \add ؤُفِيغَارْ\add* غَارْ ؤُفُوسْ نّسْ، نَّانْ: ”أَذْ ثَاغْ بْنَاذمْ-أَ ذ أَقتَّاڒْ، وَارْ ث ثجِّي ’\add لَالَّا\add* ڒْحقّْ‘ أَذْ إِدَّارْ، وَاخَّا إِنْجمْ-د زِي ڒبْحَارْ.“  
\v 5 مَاشَا بُولُوسْ إِزّرْزْ س ؤُفُوسْ نّسْ، إِمّنْضَارْ أَفِيغَارْ ذِي ثْمسِّي، بْڒَا مَا ذ أَسْ ثمْسَارْ ؤُڒَا ذ إِشْثْ ن ذْرُوشْثْ. \x ◘ \xo 28:‏5 \xt مك. 16‏:‏18؛ لك. 10‏:‏19. \x*  
\v 6 مَاشَا نِيثْنِي ثُوغَا تّْرَاجَانْ أَذْ يُوفّْ ڒخْذنِّي ؤُشَا أَذْ إِوْضَا أَذْ إِمّثْ. مَاشَا ؤُمِي ژْرِينْ، أَوَارْنِي ڒَامِي رَاجَانْ أَطَّاسْ، بلِّي وَارْ ذ أَسْ ثمْسَارْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ ثَاعفَّانْثْ، إِبدّڒْ ڒْهَارْذْ نْسنْ، نَّانْ، أَقَا-ث ذ إِجّْ ن أَربِّي. \x ◘ \xo 28:‏6 \xt ڒخ. 14‏:‏11. \x*   
\m
\v 7 ثُوغَا ذ جِّيهثْ نِّي إِيَّارنْ إِ يدْجَانْ ذ أَڭْڒَا ن إِجّْ ن ورْيَازْ ؤُمِي قَّارنْ بُوبْلِييُوسْ. نتَّا ثُوغَا ذ أَزدْجِيفْ ن ثڭْزِيرْثْ، إِسّْنوْجُو أَنغْ س ڒْخَارْ ثْڒَاثَا ن وُوسَّانْ ذِي ثَادَّارْثْ نّسْ.  
\v 8 بَابَاسْ ن بُوبْلِييُوسْ ثُوغَا ذَايسْ ثِيمسِّي ذ ڒحْرِيقْ. ذَايسْ إِجّْ ن ڒحْڒَاشْ ن ثقّْرِينْثْ. يُوذفْ بُولُوسْ غَارسْ، إِژُّودْجْ، إِسَّارْسْ خَاسْ أَفُوسْ ؤُشَا إِسّْڭنْفَا إِ-ث.  
\v 9 ؤُمِي إِمْسَارْ مَانْ أَيَا، ؤُسِينْ-د غَارسْ إِنّغْنِي ن ثڭْزِيرْثْ إِنِّي ثُوغَا غَارْ إِدْجَا إِمهْڒَاشْ ؤُشَا تّْوَاسّْڭنْفَانْ.  
\v 10 كَارْمنْ خَانغْ إِنَا س وَاطَّاسْ ن شَّانْ. ؤُمِي نْرُوحْ نْبحَّارْ سّنِّي، وْشِينْ أَنغْ مِينْ ثُوغَا نحْوَاجْ.   
\b  
\m  
\s1 أَوَاضْ ن بُولُوسْ غَارْ رُومَا  
\m
\v 11 أَوَارْنِي ثڒْثْ ن إِيُورنْ نْرُوحْ، نْبحَّارْ ذڭْ إِجّْ ن ؤُغَارَّابُو زِي إِسْكَانْذَارِييَّا إِ إِسّعْذُونْ ڒْمشْثَا ذِي ثڭْزِيرْثْ، ثُوغَا خَاسْ أَرْشَامْ ن ’ثشْنِيوِينْ‘.  
\v 12 ؤُمِي د-نِيوضْ غَارْ سِيرَاڭُوسَا، نقِّيمْ ذِينْ ثْڒَاثَا ن وُوسَّانْ.  
\v 13 سّنِّي نْذُورْ ؤُشَا نِيوضْ-د غَارْ رِيخِييُومْ. أَوَارْنِي إِجّْ ن وَاسّْ إِكَّارْ-د ؤُسمِّيضْ ن ثْشَارْمِينْ ؤُشَا نِيوضْ-د ذڭْ إِجّْ ن ڒْمِيجَاڒْ ن ثْنَاينْ ن وُوسَّانْ غَارْ بُوثِييُولِي، إِشْثْ ن ثنْذِينْثْ ذِي إِطَالْيَا.  
\v 14 ذِينِّي إِ نُوفَا ثَاوْمَاثْ نِّي زَّايْنغْ إِتَّارنْ أَذْ \add كِيذْسنْ\add* نقِّيمْ، ؤُشَا نقِّيمْ أَكِيذْسنْ سبْعَا ن وُوسَّانْ. خنِّي نْرُوحْ غَارْ رُومَا.  
\v 15 ؤُمِي سْڒِينْ ثَاوْمَاثْ \add ذِي رُومَا\add* خْ ؤُمدُّورْ نّغْ، ؤُسِينْ-د حِيمَا أَذْ كِيذْنغْ مّڒْقَانْ ذڭْ وَازَّايْ ؤُمِي قَّارنْ ’أَبِييُوسْ فُورُوسْ‘ ؤُ غَارْ ’ثْڒَاثَا ن ثْحُونَا‘. ؤُمِي ثنْ إِژْرَا بُولُوسْ، إِشكَّارْ أَربِّي ؤُشَا إِتّْوَاشجّعْ.   
\m
\v 16 ؤُمِي د-نِيوضْ غَارْ رُومَا، إِوْشَا ڒْقبْطَانْ خْ مْيَا تّسْرِيحْ إِ بُولُوسْ مَاحنْذْ أَذْ إِزْذغْ مَانِي إِخْسْ نتَّا، أَكْ-ذ إِجّْ ن ؤُعسَّاسْ ونِّي ث إِ غَا إِحْضَانْ. \x ◘ \xo 28:‏16 \xt ڒخ. 24‏:‏23؛ 27‏:‏3. \x*   
\b  
\m  
\s1 أَمڒْقِي ن بُولُوسْ أَكْ-ذ وُوذَاينْ ذِي رُومَا  
\m
\v 17 أَوَارْنِي ثْڒَاثَا ن وُوسَّانْ إِڒَاغَا بُولُوسْ إِ إِمْشنّْعنْ ن وُوذَاينْ. أَڒَامِي مُوننْ، إِنَّا أَسنْ:  
\b  
\m ”\add أَ\add* إِرْيَازنْ ثَاوْمَاثْ، وَاخَّا نشّْ وَارْ ڭِّيغْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ ضِيدّْ إِ ڒْڭنْسْ نِيغْ ضِيدّْ إِ شَّارِيعَا ن ڒجْذُوذْ إِنُو، أَقَا تّْوَاسلّْمغْ ذ أَمحْبُوسْ زِي ؤُرْشَالِيمْ ذڭْ إِفَاسّنْ ن إِرُومَانِييّنْ. \x ◘ \xo 28:‏17 \xt ڒخ. 24‏:‏12؛ 25‏:‏8. \x*  
\v 18 أَوَارْنِي ڒَامِي ذ أَيِي بقّْشنْ، ثُوغَا خْسنْ أَذْ أَيِي أَرْخُونْ مِينْزِي وَارْ ذَايِي ؤُفِينْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ ثسّْذَاهدْجْ ڒْموْثْ.  
\v 19 مَاشَا ؤُمِيعكّْسنْ وُوذَاينْ خْ مَانْ أَيَا، س ؤُغِيڒْ خَافِي أَذْ سّْڭعّْذغْ دّعْوثْ إِنُو غَارْ قَايْصَارْ، مَاشَا بْڒَا مَا أَذْ غَارِي يِيڒِي إِجّْ ن ؤُشثْشِي خْ ڒْڭنْسْ إِنُو.  
\v 20 خْ سِّيبّثْ-أَ تَّارغْ حِيمَا أَذْ كنِّيوْ ژَترغْ ؤُشَا أَذْ كِيومْ سِّيوْڒغْ. مِينْزِي ذِي سِّيبّثْ ن ؤُسِيثمْ ن إِسْرَائِيل، أَقَا أَيِي شَارْفغْ س سّْنسْڒثْ-أَ.“ \x ◘ \xo 28:‏20 \xt إِرْم. 14‏:‏8؛ 17‏:‏13؛ ڒخ. 23‏:‏6؛ 24‏:‏21. \x*  
\v 21 مَاشَا نِيثْنِي نَّانْ أَسْ: ”وَارْ خَاكْ نطِّيفْ شَا ثِيبْرَاثِينْ زِي يَاهُوذِييَّا ؤُشَا ؤُڒَا ذ إِجّْ ن ثَاوْمَاثْ وَارْ د-يُوسِي ذَا وِي إِنَّانْ نِيغْ إِسِّيوْڒنْ خَاكْ س شَا ن ڒْعِيبْ.  
\v 22 مَاشَا نشِّينْ نخْسْ أَذْ زَّايكْ نْسڒْ مِينْ ثتّْوَاڒِيذْ، مِينْزِي زِي جِّيهثْ ن ثبْرِيذْثْ-أَ، أَقَا نسّنْ بلِّي تّْعكّْسنْ ت مَانِي مَا.“   
\m
\v 23 نِيثْنِي مْعَاهَاذنْ أَكِيذسْ خْ إِجّْ ن وَاسّْ، ؤُشَا مُوننْ. أَطَّاسْ إِ-د-يُوسِينْ غَارْ ومْشَانْ مَانِي إِزدّغْ. نتَّا ثُوغَا إِتّْفسَّارْ أَسنْ ثَاڭلْذِيثْ ن أَربِّي، أَمْ إِشهّذْ ؤُ يَارزُّو أَذْ ثنْ إِسّقْنعْ زِي جِّيهثْ ن يَاسُوع، زِي شَّارِيعَا ن مُوسَا ؤُ زڭْ إِنَابِييّنْ، زِي ڒفْجَارْ أَڒَامِي ذ ثَامذِّيثْ. \x ◘ \xo 28:‏23 \xt أَمز. 3‏:‏15؛ 22‏:‏18؛ 26‏:‏4؛ 49‏:‏10؛ أَعَوذ. 18‏:‏15؛ 2 صم. 7‏:‏12؛ إِزهد. 132‏:‏11؛ إِشا. 4‏:‏2؛ 7‏:‏14؛ 9‏:‏5؛ 40‏:‏10؛ إِرْم. 23‏:‏5؛ 33‏:‏14؛ حِز. 34‏:‏23؛ 37‏:‏24؛ دَان. 9‏:‏24؛ مِيخَا 7‏:‏20. \x*  
\v 24 شَا تّْوَاسّْقنْعنْ س وَاوَاڒنْ نّسْ، \add مَاشَا\add* إِنّغْنِي وَارْ تّْوَاسّْقنْعنْ شَا. \x ◘ \xo 28:‏24 \xt ڒخ. 17‏:‏4. \x*  
\v 25 نِيثْنِي فّْغنْ خَاسْ أَمْ وَارْ د-ؤُسِينْ أَكْ-ذ وَايَاوْيَا. \add خنِّي\add* إِنَّا أَسنْ بُولُوسْ \add عَاذْ\add* أَوَاڒْ-أَ: ”س ڒْحقّْ إِسِّيوڒْ أَرُّوحْ إِقدّْسنْ خْ \add ؤُقمُّومْ ن\add* إِشَاعْيَا إِ ڒجْذُوذْ نْومْ، إِنَّا:   
\b  
\m
\v 26 \qt ’رُوحْ غَارْ ڒْڭنْسْ-أَ، إِنِي أَسنْ:\qt*  
\m \qt ’س ؤُسدْجِي أَذْ ثسْڒمْ،\qt*  
\m \qt وَارْ ثْفهّممْ،\qt*  
\m \qt س ثْمُوغْڒِي أَذْ ثخْزَارمْ،\qt*  
\m \qt وَارْ ثتّْوِيڒِيمْ،\qt* \x ◘ \xo 28:‏26 \xt إِشا. 6‏:‏9‏-‏10؛ حِز. 12‏:‏2؛ مت. 13‏:‏14؛ مك. 4‏:‏12؛ لك. 8‏:‏10؛ يُوح. 12‏:‏40؛ رُوم. 11‏:‏8. \x*   
\m
\v 27 \qt مِينْزِي ؤُڒْ ن ڒْڭنْسْ-أَ أَقَا إِذْوڒْ إِقْسحْ،\qt*  
\m \qt إِمزُّوغنْ نْسنْ سّْضقْڒنْ ثنْ إِ ؤُسدْجِي،\qt*  
\m \qt ؤُ ثِيطَّاوِينْ نْسنْ قّْننْ ثنْثْ،\qt*  
\m \qt مَاحنْذْ وَارْ تّْوِيڒِينْ س ثِيطَّاوِينْ نْسنْ،\qt*  
\m \qt وَارْ تّسْڒِينْ س إِمزُّوغنْ نْسنْ،\qt*  
\m \qt وَارْ فهّمنْ س وُوڒْ نْسنْ،\qt*  
\m \qt أَڒَامِي وَارْ غَارِي ذكّْوِيڒنْ\qt*  
\m \qt ؤُشَا أَذْ أَسنْ غْفَارغْ.‘\qt* \x ◘ \xo 28:‏27 \xt إِشا. 6‏:‏9‏-‏10. \x*   
\b  
\m
\v 28 مَانْ أَيَا إِتّْخصَّا أَذْ ثسّْنمْ: \add أَرقَّاسْ ن\add* ؤُسنْجمْ-أَ ن أَربِّي أَقَا إِتّْوَاسّكّْ-د إِ ڒڭْنُوسْ ؤُشَا ؤُڒَا ذ نِيثْنِي أَذْ غَارسْ سْڒنْ.“  
\v 29 أَوَارْنِي ڒَامِي إِنَّا مَانْ أَيَا، فّْغنْ وُوذَاينْ، أَمْ ثُوغَا تّمْشُوبُّوشنْ جَارْ أَسنْ أَطَّاسْ.   
\b  
\m
\v 30 بُولُوسْ إِشْرَا إِشْثْ ن ثَادَّارْثْ، إِخدْجصْ إِ-ت س يِيخفْ نّسْ، إِزدّغْ ذَايسْ ثْنَاينْ ن إِسڭّْوُوسَا. ثُوغَا إِتَّارحَّابْ س مَارَّا إِنِّي ثُوغَا غَارسْ د-إِتَّاسنْ،  
\v 31 إِتّْبَارّحْ س ثْڭلْذِيثْ ن أَربِّي، إِسّڒْمَاذْ خْ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ س بْطَايْطَايْ ؤُ بْڒَا مَا ثتّْوَاسّْبدّْ ؤُڒَا ذ إِشْثْ ن ثْعنْكْرِيفْثْ.   