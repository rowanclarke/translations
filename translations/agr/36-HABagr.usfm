\id HAB - Aguaruna 
\h Habacuc 
\toc1 Habacuc 
\toc2 (Habacuc) 
\toc3 Hab. 
\mt1 Habacuc 
\c 1  
\s1 Profeta Habacuc Tuke Pujuujai chichasbau 
\p  
\v 1 Profeta Habacuc aajakua nuna Apajuí nii aentsji aidaun chichama ujakti tusa iwaintukui. 
\q1  
\v 2 “Tuke Pujuuwah, yainkata tusan senchi untsuagme, 
\q1 tujash amek minak antugtatsme. 
\q1 ¿Wajutiya minash antugtuktatme? 
\q1 Pempeentuniki waitkaniamu ayá nunú 
\q1 suwimak susam emegkagta tusan segamjame, 
\q1 tujash amek makichkish duka dutikatsme. 
\q1  
\v 3 ¿Wagka minash ibau pegkegchau aidau 
\q1 iwaintugkumesh waitkajame? 
\q1 Pegkegchau takat aidau, utugchat aidau, 
\q1 yaakat tsayamu, jiyaniamu, 
\q1 maaniamu aina duka makichkish agkaatsui, 
\q1 ashí yantamnum ayawai. 
\q1  
\v 4 Amina chichamem umiktin agagbaunak 
\q1 makichkish uminatsui, 
\q1 ajantunisag shiig aneas betek yainidauk 
\q1 makichkish atsawai. 
\q1 Aents pegkegchau aidau aents pegkeg aidaun waitkainawai. 
\q1 Tsanumat, kasamat aina duka 
\q1 ashí yantamnum ayawai”, tiuwai Habacuc. 
\s1 Apajuí suwimak sukagtustin etsegkamu 
\q1  
\v 5 Tusa timatai Apajuí ayaak: 
\q1 “Tikich aents aidau batsata nuwish 
\q1 wajukeawa nunú shiig diistajum. 
\q1 Aunak dukap tsawan atsuk wi dutikattag 
\q1 nunú wainkajum anentai jegashtatjume. 
\q1 Juna tikich ujapainakuig, 
\q1 atumek dekaskeapi tumaitsugme. 
\q1  
\v 6 Caldeo aents pegkegchau magkagtin aidau 
\q1 ashí nugkanum yujasag, 
\q1 tikichi nugken atankiagtatus wakeyin aina nuna 
\q1 inajagtatjai jetepaktinme tusan. 
\q1  
\v 7 Ditak pegkegchau takatnum eemkau ainawai, 
\q1 nunin asag, dita wakegamun takau ainawai, 
\q1 nuadui makichkish tumainchau ainawai. 
\q1  
\v 8 Aents caballonum maanin aidauk shiig kuashat 
\q1 caballonum entsatkau atushat minisag 
\q1 tutugtuinawai. 
\q1 Nunú caballo aidauk ikamyawan nagkaesau senchi tupikainawai, 
\q1 tuja nuigtush uwegshunmaya lobo kajen ajankachua nuna nagkaesau ainawai. 
\q1 Iman asag atushat minisag 
\q1 dita shiwaajinak águila yutaijin wainak, 
\q1 nanaak akaetuki achiyama iman ainawai. 
\q1  
\v 9 Dita shimuinakug ashí ijina shimawai, 
\q1 imaaninak senchi uwakmakag shimawai, 
\q1 tuja aentsun achijag yajumaina duka, 
\q1 nayantsanum kayam dekapamainchauwa iman weakui. 
\q1  
\v 10 Iman asag apu aidaunak, tuja tikich aents 
\q1 eme anentsa diitai aina nunashkam dushikinawai. 
\q1 Yaakat peejamu aina nunak 
\q1 wainkauch diinak dushikinawai, 
\q1 nuninak kamatkanum batsamas yaaktanak utuinawai. 
\q1  
\v 11 Dase senchi dasentak kedegtuk nagkaemama iman ainawai. 
\q1 Iman ainakush dita senchijiya nuna 
\q1 apajuímaidau asag tunamainawai”, tiuwai. 
\s1 Profeta kajeka ataktu chichakbau 
\q1  
\v 12 “Israel aents aidaun Apajuíjiyah, 
\q1 amek pegkejam tuke pujuuwaitme; 
\q1 jinatnume tusamek idaikagtusaipa. 
\q1 Amek amina aentsjum aidau suwimak susam jintintuatag 
\q1 tusam, caldeo aents aidau ishitkaume. 
\q1  
\v 13 Amek pegkegmaitam iman asam, 
\q1 pegkegchauwa duka atsane pujuchuitme, 
\q1 tuja tudaushkam dakitnaitme. 
\q1 Nuadui ayatkek dii pujuipa, tuja aents pegkegchau aidau 
\q1 aents pegkeg aidaun maatnume tusamek 
\q1 agkan idaisaipa. 
\q1  
\v 14 ¿Wagka aents aidaush 
\q1 nayantsanmaya namak aidaujai betekash, 
\q1 tuja kuntin apugtuchu aina nujai betekash awajsaume? 
\q1  
\v 15 Nuadui caldeo aents aidau, 
\q1 aents namaka main agsean ajuntuk, 
\q1 tuja retan nená yupichuch 
\q1 kuashat namakan achiyama numamtuk 
\q1 aents aidaun achija ijumainawai, 
\q1 dutikawag nuna diisag shiig aneenawai. 
\q1  
\v 16 Nuadui nunú aents namaka main aina duka 
\q1 niina redjin, agseajijai emematuinak 
\q1 kuntinun maa apeenak, 
\q1 kugkuin inciensonashkam apeenawai, 
\q1 wagki ditak duwi maawag 
\q1 dita yuwatnujinak shiig kuashat ijumag batsatu asag, 
\q1 shiig aneas batsatui. 
\q1  
\v 17 Caldeo aents aidau wainak mau batsamtitnume 
\q1 tusamek idaikagtusaipa”, tiabiajai. 
\c 2  
\s1 Apajuí inagnak Habacukan aikbau 
\q1  
\v 1 Nuna pachisan Apajuín segau asan, 
\q1 suntag jinta niimin ekemas niimak ekemama numamtuk 
\q1 Tuke Pujuush wajinjuttig tusan dakakun pujubiajai. 
\b  
\q1  
\v 2 Nunikan pujai Tuke Pujuu mina aijak: 
\q1 “Wi amina iwaintuktatjam nunú 
\q1 tablanum paan shiig wainmain agagta, 
\q1 dutikamu asamtai, tikich aidaush yupichuch ausatnume. 
\q1  
\v 3 Nunú ame wainkattam duka 
\q1 juu tamawaikik nagkaemakchattawai, 
\q1 tujash amek waugtutsuk dakasta, 
\q1 nunú nagkaemaktinuk eke tsawan jegatsui. 
\q1 Tujash duka makichkish megkaetsuk 
\q1 tuké uminkattawai”, tujutmayi. 
\s1 Aents pegkegchau aidaush wajukatnuk ainawa 
\q1  
\v 4 “Tuja wi agagta tajam nunak juna tajai: 
\q1 ‘Aents pegkegchau emebau aidauk jinawagtinai, 
\q1 untsu aents pegkeg ima Apajuínak umijuidauk jinachagtinai.’ 
\q1  
\v 5 Aents emebau aidauk apu atag tusag wakegainawai, 
\q1 vino pegkejaitak enamkagtuwama nujai betek ainawai. 
\q1 Tikich aidau nagkaesau amí tuidau asag, 
\q1 makichkish ayámjutsuk yujajus 
\q1 aents tikich nugkanmaya aidaun amuinawai. 
\q1 Dita aidauk jaka megkaetaijai betek, 
\q1 tuja ukumatai aents jakaun dakitmaitsu nujai betek ainawai. 
\q1 Nunin asag ayatak wenawai. 
\q1  
\v 6 Tujash ditak yana waitkainawa nunú pempeentuki dushikiam agtinai. 
\q1 Dutika dushikinak: 
\q1 ‘¡Ame tikich aents aidaun wajiiji yajutkam 
\q1 wiakuch wajasum nunak wait anentagme! 
\q1 ¿Amesh wajutiya kasamtash idaisattame?’ 
\b  
\q1  
\v 7 “Ame waitkam nunú pachiachbaunum 
\q1 pempeentugmakiag waitkagmasagtinai, 
\q1 imatijamainakui sapijai kujaitnaitme, 
\q1 tuja amina wajijum aidaunak ashí atanjamjagtinai. 
\q1  
\v 8 Tikich nugkanmaya aidau ijunag chichama umikag, 
\q1 ame dita kasajauwaitam dutiksag ditashkam 
\q1 ashí kasagtamjagtinai. 
\q1 Dutik akikmaktatme ame juju nugka juwiya 
\q1 aents ijinkum yaakat aidau tsaikuitam nuadui. 
\q1  
\v 9 ¡Kasamkamu aidau, 
\q1 tikich tsanuja yajutkamu aidaujai 
\q1 amina aentsjum aina nunú wiakuch awajsaum, 
\q1 nuadui aminak wait anentagme! 
\q1 Ame anentaimsamek, 
\q1 jutikanus shiig batsasainja tamestai. 
\q1  
\v 10 Tujash ayatak datsanmain iwaintukume. 
\q1 Kuashat aents tikich nugkanmaya aidau ijinatjai 
\q1 tukamam, amek pempeentumakim amumakume. 
\q1  
\v 11 Yaakat peejamu aidau, jega ayanke aidaujai 
\q1 ame pegkegchau takamsamua nuna pachisag 
\q1 aentsjai betek senchi untsumiagtinai. 
\b  
\q1  
\v 12 “¡Amek aents aidau ijinkum, 
\q1 dita nugke atanjam nuwi yaakat najankaume, 
\q1 nuadui aminak wait anentagme! 
\q1  
\v 13 Tujash ame waittsa umikum duka wainka imatikaume, 
\q1 aunak Tuke Pujuu ashí senchigtina nunú ashí apea tsaika ajapattawai. 
\q1  
\v 14 Tuja Tuke Pujuun imanjiya duka, 
\q1 yumi nayantsan ipiamna numamtuk, 
\q1 ashí nugkanum piyaktatui. 
\q1 Nunikmatai ashí nuna dekawagtinai. 
\q1  
\v 15 ¡Aents amejai tikiju batsatu 
\q1 vino drogajai pachimja ama amakuam enamkam wisu weakui, 
\q1 nunú diisam dushiki pujam nunak wait anentagme! 
\q1  
\v 16 Tuke Pujuu aminak inastamjattawai, 
\q1 amek makichkish emematam amaitsume. 
\q1 Atum tikich aidau datsan dushikiajum dutiksag, 
\q1 atumnashkam Apajuí datsanmainun iwaintamkagtatui. 
\q1 Dutijamawagmatai emebau ainajum duka 
\q1 ememachu wajastatjume. 
\q1  
\v 17 Muja Líbanonmaya kuntin aidau 
\q1 ijinauwaitam nunú aminak bakugmattawai. 
\q1 Ame aents aidau ijinamunum, 
\q1 tuja yaakat aidau tsaikbaunum, suwimak juki waitiakum 
\q1 amina pegkegchaujum akikmaktatme. 
\q1  
\v 18-19 ¡Babilonianmaya aidaunak wait anentuinajai! 
\q1 ¿Wagka atumesh wainka apajuímtai aidaunmash 
\q1 kajintsagmesh anentaimjume? 
\q1 ¿Wagka atumesh aannush yainkata tusagmesh 
\q1 segash yujagme? 
\q1 Auk numi, kaya, atum najanamu ainawai, 
\q1 tujash duka wainak ainawai. 
\q1 Auk jiju najana orojai, platayai ukatkamu iwakuchu asa 
\q1 nigki wajamainchau, tuja chichamainchau ainawai. 
\q1  
\v 20 Tujash Tuke Pujuuk niina jee pegkegma nuwi pujawai. 
\q1 ¡Niina emtinig ashí nugkanmaya aents aidauk 
\q1 takamtak pujustinme!” tajai. 
\c 3  
\s1 Habacuc Apajuí segamu 
\p  
\v 1 Profeta Habacuc Apajuín juna aatus segauwai: 
\q1  
\v 2 Tuke Pujuuwah, 
\q1 ame ashí dutikaum nunak shiig dekajai, 
\q1 nuadui amina ishamakun kujajai. 
\q1 Wait aneasam iina apachji aidau yaigkuitam 
\q1 dutiksamek yaijatkata, 
\q1 kajegkagtukam idaikagtusu akumesh, wait anenkagtugta. 
\b  
\q1  
\v 3 Apajuík Temán nugkanmaya minawai, 
\q1 Apajuí pegkegma nunú muja Parágnumia jiinki minawai, 
\q1 Apajuín imanjiya duka ashí nayaimpin jajutua awai, 
\q1 tuja ashí nugkanum Apajuí emematku kantamtain kantamainawai. 
\q1  
\v 4 Winchamtinnum egkemak minawai, 
\q1 niina uwejenia chaajip keeka jiinui, 
\q1 nuniak niina senchiji uumak aunash iwainawai. 
\q1  
\v 5 Nii minitaik kuashat aents aidau 
\q1 jata ishamainun achiimakag jinuinawai. 
\q1 Tuja niina ukuujin tsuwemu ishamain minawai. 
\q1  
\v 6 Apajuí minau jasa wajataik, nugka uujui, 
\q1 tuja ashí aents aidaun diitaik, 
\q1 aents aidauk ishamainak kujainawai, 
\q1 muja aidauk tsainak megkagainawai, 
\q1 muja yaunchuk nagkamas aajaku aidaush yumpunainawai. 
\q1 Tujash Apajuín jintiya duka yumpunagkesh megkaekashtinun tuke atinai. 
\q1  
\v 7 Nuigtushkam Cusagnumia aents aidau 
\q1 initak makichkish jiinmainchaunum egkema 
\q1 waitmaina imanik senchi waituidaun wainkabiajai. 
\q1 Tuja Madián nugkanmaya aidaushkam 
\q1 senchi ishamainak jiintsuk ayatak kaemag 
\q1 aakchinmag batsatun wainkabiajai. 
\q1  
\v 8 Tuke Pujuuwah, aents caballonum entsatkau 
\q1 minimaina imanika minakum, 
\q1 aents maaniamunum depetmak carro maanitainum egkemag wegama 
\q1 numamtuk wajam dusha ¿wagka imanikmesh umintsaume? 
\q1 ¿Namak aidau, nayants aidau, wainka apajuímtai aina nunú kajegkamek imanikmesh umintsaum? 
\b  
\q1  
\v 9 Akentaiyai aketka iju ichimaina imatikabiume nugkak, 
\q1 amina senchigmin imatikamua nunú 
\q1 namak najaneakmayi. 
\q1  
\v 10 Muja aidauk amina waipainak, ishamjamak sunatuinawai. 
\q1 Tuja nayaimpinmaya yumi senchi yutawai, 
\q1 imanitai nayants kuna senchi tsukatu asa 
\q1 kedegtak ishamain wajawai. 
\q1  
\v 11 Ame chaajip ishamain winchamtin nagkijai betek 
\q1 ekemaka akupkaamin, 
\q1 etsak nantujai uumak megkaekaje. 
\q1  
\v 12 Ame kajekam nugka tenteame, 
\q1 dutikakum ame kajekbaugmin 
\q1 aents nugka muunnumia aidauk dajaja tsaika 
\q1 ajapmaina imatikame. 
\q1  
\v 13 Amina aentsjum aina duka ame apu etegkauwaitam nujai yayaakum miname. 
\q1 Untsu aents pegkegchau aina nuna apujig mantuam, 
\q1 inabaujiya duka ashí tsaigkam emegkatkaume. 
\q1 Dutikamu asa ditak shiig wainak juwakaje. 
\q1  
\v 14 Caballonum maanitan yacha aidau ememasag 
\q1 dase senchi dasentujai betek jetepaidau asag, 
\q1 amupaktag tiagmayi. 
\q1 Imatijamainakui ayamjumamainchau dekapmaiji, 
\q1 tujash ame dita apujig niina flechajinig depetkabiume. 
\q1  
\v 15 Amek amina caballogmin entsamkam 
\q1 nayants ishamain wajamunum wekaeme. 
\b  
\q1  
\v 16 Nuna antakun senchi ishamkabiajai. 
\q1 Nuniai mina wenujuk sunatmayi, 
\q1 imaniakun wajaschamin, ashí mina iyashjuig 
\q1 kakaumainchau dekapmaijai, 
\q1 nuniakun anentaijui tetegtimiajai. 
\q1 Tujash wika imaniaknush, 
\q1 waugtutsuk iina waitkagbau aina nuna Apajuí waitkastin tsawan jegatna nuna dakastatjai. 
\b  
\q1  
\v 17-18 Tuja higuera ajakbau nejeachkuish, 
\q1 uva nejeachkuish, olivo aceitunan nejeachkuish, 
\q1 ajanmaya aidaush, ikamia aidaukesh nejenachkuish, 
\q1 tuja baka aidaush, uwig aidaush ashí jinutjamamtaish, 
\q1 minak Tuke Pujuu uwemtijuju asamtai, 
\q1 wika shiig aneasan niina ememattatjai. 
\q1  
\v 19 Wagki Tuke Pujuu minak senchimtijawai, 
\q1 dutijak japa senchi tupikaina iman awajtus 
\q1 muja aidaunum iwajuk tikichish maumainchau kuitamjawai.