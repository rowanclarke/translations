\id 3JN Ika New Testament 2009 
\h 3 Jọnụ 
\toc1 Ẹhụhụọ-Ozi Nke Ẹtọ Jọnụ De 
\toc2 Jọnụ, Nke Ẹtọ 
\toc3 3Jn 
\mt2 Ẹhụhụọ-Ozi Nke Ẹtọ 
\mt2 Jọnụ 
\mt2 De 
\mt1 Jọnụ, Nke Ẹtọ 
\c 1  
\p  
\v 1 Mmẹ wụ onyẹ-isi de ẹkụkwọ-ozini. M rị e dejẹnni ezi nwẹnẹ ẹnyi wụ Gayọsị, hụn ihiẹn ẹ a sụọ m imẹ Ezioku. 
\p  
\v 2 Ezi nwẹnẹ m, ekpere m wụ nị ihiẹn ile rịn'ị mma lẹ ni ẹhụ rị ị ikẹn, nọkẹ kẹ ị dọn nwan rị ikẹn imẹ mmọn ị. 
\p  
\v 3 Ịghọghọ jun m obi ogẹn ndị hụ imẹ umunẹ ẹnyi gi bịa d'e ku n'ị wụ onyẹ wẹ gi e dọn ẹnya ebe Ezioku rị—ya wụ n'ị rị e bi imẹ ezioku.  
\v 4 O nwọnni ihiẹn e mẹ m a ghọghọ rịkẹ ebe m nọ nụ nị ụmụ m rị e bi imẹ Ezioku. 
\s1 Jọnụ A Ja Gayọsị Mma 
\p  
\v 5 Nwẹnẹ-onyẹ, y'e mẹkẹ onyẹ wẹ gi e dọn ẹnya imẹ ọrụn ị rị a rụn nị umunẹ-ẹnyi imẹ Jesu, ọsụọn'a nị y'a marịn ndị wẹ wụ.  
\v 6 A nọgụọ wẹ ihun ụka rị ebeni ku oku ihiẹn-ọsụsụọ i nwẹ. Dodo, yeni wẹ ụdị ẹka hụn a sụọ Osolobuẹ ụsụọ, kẹni wẹ jẹndụrụ.  
\v 7 Makẹni, ogẹn wẹ gi gi ifiri Ẹfan ahụn jẹnkọ ijẹnni, anịnị wẹ ndị kwerilẹni ni Jesu yeni wẹ ẹka.  
\v 8 O furu nwan nị ẹnyi kwandọn ndị nọ ẹrịra, kẹni ọ hụn ụzọ mẹ ni ẹnyi lẹ wẹ wụ ohu, e sọn Ezioku a rụngbama ọrụn. 
\s1 Diọtrẹfẹsị Lẹ Dẹmẹtrịọsị 
\p  
\v 9 E dejẹngụọ nị m ụka ẹhụhụọ; kanị Diọtrẹfẹsị hụn a chọ n'ọ kị a nabanhannị ọkịkị ẹnyi, o gini ihiẹn ẹnyi ku dọn.  
\v 10 Ya wụ, m bịa nwan, m k'e wepụhachanrịn ihiẹn ile ọ rị e mẹ, lẹ ọnụ ọ rị e buokinsọnmẹ ẹnyi! Ọhụn ehidẹn'ẹ, ọ jụdẹ n'ọ nabanhankọ umunẹ ẹnyi ndị hụ; ọ nịdẹni ndị ọzọ nabanhan wẹ—ọ chụpụdẹ ndị hụn rị imẹ ụka hụn chọ nị wẹ nabanhan wẹ. 
\p  
\v 11 Nwẹnẹ-onyẹ, a kịnrịnkwọlẹ ihiẹn rịlẹni mma, ka kịnrịn ihiẹn rị mma. Onyẹ ọwụlẹ hụn e mẹ ihiẹn rị mma wụ nke Osolobuẹ. Kanị, onyẹ ọwụlẹ hụn e mẹ eje-ihiẹn e ke hụntu Osolobuẹ. 
\p  
\v 12 Ịhịan ile e ku oku Dẹmẹtrịọsị ọhụnma; Ezioku lẹ enwẹn ẹ e ku oku ẹ ọhụnma. Ẹnyi nwẹn nkẹ rị a shịazịkwọn'a ẹri—bụ y'a marịnghọ nị ẹri ẹnyi a shịa wụ ezioku. 
\s1 Ekele Ịkpazụụn 
\p  
\v 13 Ihiẹn m chọ nị m gwa ị e bukẹ, kanị, edekọ m'a e de.  
\v 14 M rị a tụ ẹnya nị m jẹnkọ d'a hụn ị ẹgwa, kẹni ẹnyi kutarị elee-m, elee-i. 
\p  
\v 15 Udọn y'a rị n'ị. 
\p Ndị ọwụ ẹnyi ile e zi ekele i. Hị ndị ọwụ ẹnyi rị ebẹhụ ẹfan ohu-ohu, y'e kele wẹ.