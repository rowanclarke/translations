\id SNG - Biblica® Open New Luo Translation 2020
\h Wer Mamit
\toc1 Wer Mamit Moloyo Wende Moko Duto
\toc2 Wer Mamit
\toc3 Wer
\mt1 Wer Mamit Moloyo Wende Moko Duto
\c 1
\p 
\v 1 Wer mamit moloyo wende moko nondiki gi ruoth Solomon.
\b
\sp Nyako
\q1 
\v 2 Bi mondo inyodha gi dhogi,
\q2 nikech herani kelo mor moloyo divai.
\q1 
\v 3 Modhi miwirorigo dungʼ mamit;
\q2 kendo nyingi chalo gi mo mangʼwe ngʼar ma pukore oko.
\q2 Kare mano emomiyo nyiri duto oheri!
\q1 
\v 4 Kawa idhi koda, waret piyo waa kae!
\q2 Ruoth mondo odhi koda nyaka ei ode maiye.
\sp Osiepe
\q1 Wail kendo chunywa mor kodi;
\q2 wabiro pako herani moloyo divai.
\sp Nyako
\q1 Gitimo gima kare ka gipuoyi!
\b
\q1 
\v 5 An nyako ma dichol kendo ma jaber,
\q2 yaye nyi Jerusalem,
\q1 an dichol mana ka hembe mag Kedar,
\q2 kendo mana ka pasia molier e hembe Solomon.
\q1 
\v 6 Kik uchaya nikech an dichol,
\q2 nimar chiengʼ ema oseloko denda kamano.
\q1 Yawuot minwa nokecho koda,
\q2 mine giketa jarit puothegi mag mzabibu;
\q2 to puotha awuon mar mzabibu to ne ajwangʼo.
\q1 
\v 7 Yaye jaherana, nyisane kuma ikwayoe jambi
\q2 kod kuma iweye rombi mondo oyweyee odiechiengʼ tir.
\q1 Angʼo momiyo dachal mana gi dhako moumo wangʼe
\q2 e dier jamb osiepeni?
\sp Osiepe
\q1 
\v 8 Ka ok ingʼeyo, yaye jaber moloyo mon mamoko,
\q2 lu bangʼ rombe kuonde ma gikwayoe,
\q1 mondo ikwa nyidiek ma pod tindo
\q2 e bath hembe mag jokwath.
\sp Wuowi
\q1 
\v 9 Jaherana, apimi mana gi faras madhako
\q2 motwe but achiel kuom geche Farao.
\q1 
\v 10 Lembi nenore maber ka sitadi olierie;
\q2 ngʼuti bende nenore maber ka olierie tigo ma nengogi tek.
\q1 
\v 11 Wabiro losoni thiwni mag dhahabu,
\q2 kod tigo mag fedha.
\sp Nyako
\q1 
\v 12 Kane ruoth chiemo e mesane,
\q2 mo mangʼwe ngʼar man-gi tik mamit nopongʼo ot kadonjo.
\q1 
\v 13 Jaherana chalona gi mo mane-mane mobo matin ma nengone tek,
\q2 mantie e kind thundena.
\q1 
\v 14 Jaherana chalona maua maber mothiewo,
\q2 moa e puoth mzabibu man En Gedi.
\sp Wuowi
\q1 
\v 15 Mano kaka ijaber, jaherana!
\q2 Yaye, mano kaka ijaber!
\q2 Wengeni neno mamuol ka akuru.
\sp Nyako
\q1 
\v 16 Mano kaka iber, jaherana!
\q2 Yaye, mano kaka berni olomba!
\q2 Kendo kitandawa bende yom ka lum mangʼich.
\sp Wuowi
\q1 
\v 17 Bepe mag tat odwa gin mag sida;
\q2 kendo bede yien mokar mag obudo nobednwa tado.
\c 2
\sp Nyako
\q1 
\v 1 An maua madungʼ tik mamit mag Sharon,
\q2 bende an ondanyo madongo e holo.
\sp Wuowi
\q1 
\v 2 Mana ka ondanyo motwi e dier kuthe
\q2 e kaka jaherana chalo e dier nyiri.
\sp Nyako
\q1 
\v 3 Mana kaka yiend olemo mayom manie dier yiende mamoko mag bungu,
\q2 e kaka jaherana chalo e dier chwo matindo.
\q1 Amor ka abet e tipone,
\q2 kendo olembe milimili e dhoga.
\q1 
\v 4 Osetera e od budho mare,
\q2 kendo herane oliero e wiya ka bendera.
\q1 
\v 5 Miya jip gi olemb mzabibu mosemo e chiengʼ,
\q2 duog chunya gi olemo mayom,
\q2 nikech hera onura.
\q1 
\v 6 Bade ma koracham oteno wiya
\q2 to bade ma korachwich okwaka.
\q1 
\v 7 Un nyi Jerusalem, asiemou gi nying nyakech kod mwanda manie e thim,
\q2 ni kik utug hera kata chiewe ka sa ne pok oromo.
\b
\q1 
\v 8 Lingʼane,
\q2 awinjo dwond jaherana kabiro!
\q1 Kochikore ewi gode kobiro,
\q2 kendo obiro kolengʼore ewi gode matindo.
\q1 
\v 9 Jaherana chalo gi mwanda manie thim.
\q2 Nene kaka ochungʼ e tok ohinga,
\q1 kongʼicho gie dirise manie kor ohinga,
\q2 kendo kongʼicho gie bath dirisa.
\q1 
\v 10 Jaherana nowuoyo kendo nowachona niya,
\q2 “Aa malo jaherana, bi wadhiyo,
\q2 yaye jaber.
\q1 
\v 11 Ndalo chwiri osekalo;
\q2 koth osechok kendo oserumo.
\q1 
\v 12 Maua osechako thiewo e puothe;
\q2 kinde mag wer osechopo,
\q1 ndalo ma akuch oduglani werie mamit
\q2 koro winjore e gwengʼwa.
\q1 
\v 13 Yiend ngʼowu golo olembene mokwongo;
\q2 thiepe mag mzabibu keyo tikgi mamit.
\q1 Aa malo ibi, jaherana;
\q2 bi mondo wadhiyo, yaye jaber.”
\sp Wuowi
\q1 
\v 14 Yaye akucha manie buche manie kor lwanda;
\q2 kuonde mopondo manie kor gode,
\q1 yie aneye wangʼi,
\q2 kendo yie awinjie dwondi;
\q1 nimar dwondi mit,
\q2 kendo wangʼi ber neno.
\q1 
\v 15 Maknwauru nyithind bwe ma pod tindo,
\q2 maketho puothewa mag mzabibu;
\q1 nikech dipo ka giketho mzabibuwa mosechako thiewo.
\sp Nyako
\q1 
\v 16 Jaherana en mara kendo an mare;
\q2 odongo maber e dier ondanyo.
\q1 
\v 17 Nyaka chop piny yawre
\q2 kendo tipo mag gik moko lal,
\q1 duog ira, jaherana,
\q2 mana kaka mwanda gi le mamoko ringo kadok e gode.
\b
\c 3
\q1 
\v 1 Otieno duto kane an e kitandana,
\q2 ne amanyo ngʼat ma chunya ohero;
\q2 ne amanye to ne ok ayude.
\q1 
\v 2 Koro abiro aa malo kendo abiro wuotho koni gi koni e dala,
\q2 abiro menyo e yore kod kuonde duto mopondo mag dala;
\q1 abiro manyo ngʼat ma chunya ohero.
\q2 Omiyo ne amanye to ne ok ayude.
\q1 
\v 3 Jorito mag dala noyuda
\q2 ka girito dala,
\q2 mine apenjogi niya “Bende usenenonae ngʼat ma chunya ohero?”
\q1 
\v 4 Gikanyono, kane pok asudo mabor kodgi,
\q2 ne ayudo ngʼat ma chunya ohero.
\q1 Ne amake matek, kendo ne adagi weye thuolo mondo odhi
\q2 mine akele nyaka e od minwa, kama ne onywolae.
\q1 
\v 5 Un nyi Jerusalem, asiemou gi nying nyakech kod mwanda manie e thim,
\q2 ni kik utug hera kata chiewe ka sa ne pok oromo.
\b
\q1 
\v 6 Mano to ngʼa mabiro koa e piny motimo ongoro
\q2 machalo ka iro madhwolore,
\q1 mowirore gi modhi mangʼwe ngʼar,
\q2 kendo molosi gi gik madungʼ mangʼwe ngʼar mag jo-ohala madongo?
\q1 
\v 7 Neuru, en gach Solomon,
\q2 kikowe gi jolweny piero auchiel,
\q2 ma gin jo-Israel maroteke,
\q1 
\v 8 giduto gimanore gi ligangla,
\q2 giduto gilony e kedo,
\q1 ka ngʼato ka ngʼato nigi liganglane e bathe,
\q2 koikore ne gik mabwogo ji gotieno.
\q1 
\v 9 Ruoth Solomon noloso garino ne en owuon;
\q2 nolose gi bepe moa Lebanon.
\q1 
\v 10 Sirnige noloso gi fedha,
\q2 to pinyne noloso gi dhahabu,
\q1 kombene ne olicho gi nanga maralik,
\q2 dier iye to nyi Jerusalem noumo gihera mogundho.
\q1 
\v 11 Wuoguru oko, un nyi Sayun,
\q2 wuoguru uneye Ruoth Solomon korwako osimbone mar loch,
\q1 osimbo mar loch mane min mare osidhone,
\q2 chiengʼ mane otimo arus, chiengʼno mane chunye oil.
\c 4
\sp Wuowi
\q1 
\v 1 Mano kaka ijaber, jaherana!
\q2 Yaye, mano kaka ijaber!
\q2 Wengeni neno mamuol ka akuru.
\q1 Yie wiyi chalo gi kweth mag diek,
\q2 malor koa e Got Gilead.
\q1 
\v 2 Lekeni tar mana ka kweth mag rombe makoro eka oliel yiegi
\q2 kendo mowuok kar luok.
\q1 Moro ka moro wuotho gi nyithinde ma rude,
\q2 kendo onge moro man kende.
\q1 
\v 3 Pien dhogi chalo gi law marakwaro;
\q2 kendo dhogi ber ahinya.
\q1 Lembi moum gi law
\q2 yom machalo mana gi olemo mongʼinore.
\q1 
\v 4 Ngʼuti chalo gi osuch Daudi,
\q2 mochungʼ tir gi chia;
\q1 kuode alufu achiel oliero kuome,
\q2 ma kargi duto gin kuodi mag jokedo.
\q1 
\v 5 Thundeni chalo gi nyithi mwanda ariyo maromre
\q2 adier gichalo gi nyithind mwanda ma rude,
\q2 makwayo e kind ondanyo.
\q1 
\v 6 Ka piny oseyawore
\q2 kendo rumbi oserumo,
\q1 eka abiro dhi ewi got kuma gik madungʼ tik mangʼwe ngʼar yudoree
\q2 kendo nyaka ewi gode matindo miwangʼoe ubani.
\q1 
\v 7 Ijaber e yore duto, jaherana;
\q2 onge mbala moro amora e dendi.
\b
\q1 
\v 8 Yaye jaherana, bi wadhi kodi ka waa e got Lebanon,
\q2 adier bi koda walor ka waa Lebanon.
\q1 Lor piny ia e chuny got Amana,
\q2 lor ia ewi got mar Senir gi Hermon,
\q1 wuog e bur sibuoche
\q2 kendo wuog ewi got kama kwach oloko miechgi.
\q1 
\v 9 Yaye jaherana,
\q2 ka aneno kaka ingʼiya,
\q1 kod tigo malich miliero
\q2 e ngʼuti, to chunya rumo.
\q1 
\v 10 Mano kaka herani miya mor, yaye osiepna, ma ahero;
\q2 mano kaka herani kelo mor mangʼeny moloyo divai,
\q2 kendo ngʼwe ngʼar moloyo modhi mamoko duto!
\q1 
\v 11 Yaye jaherana, pien dhogi mit ka mor kich;
\q2 lewi chalona chak kata mor kich.
\q2 Lewni mirwako dungʼ tik mamit mana ka tik mamit mar got Lebanon.
\q1 
\v 12 Yaye jaherana, ichalo gi puodho mochiel;
\q2 kendo ka soko molor dhoge modin motegno.
\q1 
\v 13 Yiende madongo e puothi gin olembe mongʼinore,
\q2 molembegi beyo,
\q2 kendo mit kaka olemb hena kod nad.
\q2 
\v 14 Gin olembe mopogore opogore kaka nad kod safron,
\q2 gi kalmas kod sinamon,
\q2 kod yedhe mangʼwe ngʼar,
\q2 kaka ubani gi mane-mane,
\q2 kod apilo mamit mag tedo.
\q1 
\v 15 Ichalo gi puodho ma thidhna ni e iye,
\q2 bende ichalo gi soko mar pi mamol,
\q2 kendo ichalo gi aore mamol kawuok ewi gode mag Lebanon.
\sp Nyako
\q1 
\v 16 Wuogi ka ikudho, in yamb nyandwat,
\q2 bende in yamb milambo kudhi!
\q1 Kudhi e puotha,
\q2 mondo tikne okere malach.
\q1 We jaherana koro obi odonji e puothe
\q2 kendo obil olembene moyiedhi kendo mamit.
\c 5
\sp Wuowi
\q1 
\v 1 Asebiro e puotha, yaye jaherana;
\q2 asechoko ubani gi modhi madungʼ tik mangʼwe ngʼar,
\q1 asechamo pednina kaachiel kod mor kich mara;
\q2 kendo asemadho divaina kod chak.
\sp Osiepe
\q1 Yaye osiepena, chiemuru kendo methuru;
\q2 yaye joherana, methuru ma romu.
\sp Nyako
\q1 
\v 2 Ne anindo, to chunya ne neno.
\q2 Lingʼ uwinji! Jaherana dwongʼo kowacho niya,
\q1 “Yaye jaherana, yawna kendo winja maber,
\q2 yaye jaherana mamuol mana ka akuru.
\q1 Tho opongʼo wiya,
\q2 kendo yie wiya opongʼ gi ngʼich mar otieno.”
\q1 
\v 3 Aselonyo lepa,
\q2 koro idwaro ni achak arwakra kendo?
\q1 Aselwoko tienda,
\q2 koro idwaro ni achak anyon lowo kendo?
\q1 
\v 4 Jaherana nosoyo lwete e otuchi mar dhoot;
\q2 chunya nochako gwecho ka dware.
\q1 
\v 5 Ne aa malo mondo ayawne jaherana,
\q2 kendo lwetena ne ton mo mangʼwe ngʼar ma nengone tek.
\q1 Morno ma nengone tek mane ni e lith lweta nomieno
\q2 pata mar dhoot.
\q1 
\v 6 Ne ayawone jaherana,
\q2 mi ayudo ka jaherana osewuok kendo osea!
\q2 Chunya norumo kane odhi oyomba.
\q1 Ne amanye, to ne ok ayude.
\q2 Ne aluonge, to ne ok odwoka.
\q1 
\v 7 Jorito noromo koda
\q2 kane giwuotho gotieno e alwora mar dala.
\q1 Ne gigoya marach ma gihinya;
\q2 kendo jorito marichogo,
\q2 ne omaya lawa!
\q1 
\v 8 Amiyou chik, un nyi Jerusalem
\q2 ni ka uyudo jaherana,
\q1 to ubiro nyise nangʼo?
\q2 Nyiseuru ni hera ma aherego odwaro nega?
\sp Osiepe
\q1 
\v 9 Ere kaka jaherani oloyo chwo mamoko,
\q2 yaye jaber mogik e dier nyiri mabeyo duto?
\q1 Ere kaka jaherani oloyo chwo mamoko,
\q2 momiyo imiyowa chik ma kamano?
\sp Nyako
\q1 
\v 10 Jaherana rieny kendo rapudo,
\q2 oloyo chwo alufu apar.
\q1 
\v 11 Wiye chalo dhahabu maler,
\q2 yie wiye beyo kendo boyo,
\q2 bende yie wiyego ratengʼ ka yie agak.
\q1 
\v 12 Wengene chalo akuru
\q2 mopiyo but aore mamol,
\q1 moluoki gi chak,
\q2 kendo ochan kaka kite ma nengogi tek.
\q1 
\v 13 Lembe chalo gi apilo mokuogi
\q2 magolo suya mamit.
\q1 Pien dhoge chalo ondanyo,
\q2 ma mo madungʼ tik mangʼwe ngʼar tonie.
\q1 
\v 14 Bedene chalo gi luth mar dhahabu,
\q2 mokedi gi kite ma nengongi tek.
\q1 Dende chalo gi lak liech moywe maler,
\q2 mokedi gi kit safir.
\q1 
\v 15 Tiendene chalo gi sirni mag kit ombo
\q2 mochungʼ e mise mag dhahabu maler.
\q1 Onenore ka got mar Lebanon,
\q2 kendo ongʼongʼore ka bepe sida mag Lebanon.
\q1 
\v 16 Mano kaka dhoge mit nyodho,
\q2 kendo ober moloyo chwo mamoko.
\q1 Mano e jaherana, mano e osiepna,
\q2 yaye nyi Jerusalem.
\c 6
\sp Osiepe
\q1 
\v 1 Jaherani olal kune,
\q2 yaye jaber mogik e dier nyiri mabeyo?
\q1 Jaherani ne oluwo kanye,
\q2 mondo wakonyi manye?
\sp Nyako
\q1 
\v 2 Jaherana osedhi e puothe,
\q2 kama gik mangʼwe ngʼar dongoe,
\q1 mondo omeny ei puothe
\q2 kendo ochok ondanyo.
\q1 
\v 3 Jaherana en mara kendo an bende an mare;
\q2 omiyo omenyo e dier ondanyo.
\sp Wuowi
\q1 
\v 4 Jaherana, ijaber mana ka Tirza,
\q2 ilongʼo mana ka Jerusalem,
\q2 ichanori mana ka jolweny motingʼo bendeche.
\q1 
\v 5 Gol wengegi kuoma;
\q2 nikech giberna.
\q1 Yie wiyi chalo kweth mag diek,
\q2 malor koa e got Gilead.
\q1 
\v 6 Lekeni tar mana ka kweth mag rombe
\q2 mowuok kar luok.
\q1 Moro ka moro wuotho gi nyithinde ma rude
\q2 kendo onge moro man kende.
\q1 
\v 7 Lembi ma iumo gi nanga
\q2 chalo gi olemo mongʼinore mochiek makwar.
\q1 
\v 8 Ruoth nigi mon piero auchiel
\q2 gi mon mamoko piero aboro,
\q2 kod nyiri mapok ongʼeyo chwo mokadho akwana.
\q1 
\v 9 To an ahero mana nyako achiel kende,
\q2 ma jaber ka akuru, en e nyar min kende,
\q2 mohero malich.
\q1 Jotich ma nyiri konene, to luonge ni nyako mogwedhi,
\q2 to mond ruoth kod mon mamoko konene to pake.
\sp Osiepe
\q1 
\v 10 Ma to en ngʼa mabiro apoya ka piny madwa ru?
\q2 Adier, ober ka dwe kendo ongʼangʼni ka wangʼ chiengʼ,
\q2 bende ochanore ka sulwe moriedo.
\sp Wuowi
\q1 
\v 11 Ne alor mwalo nyaka e puoth mananas,
\q2 mondo ane kaka gidongo e holo,
\q1 kendo mondo ane ka mzabibu osechako golo maua
\q2 kata ka olemo mongʼinore osechako chiek makwar.
\q1 
\v 12 Apoya nono, kapok angʼeyo,
\q2 gombona notingʼa motera nyaka dier geche joka ruoth.
\sp Osiepe
\q1 
\v 13 Yie iduogi, yie iduogi, yaye nyar jo-Shulam;
\q2 yie iduogi, yie iduogi, mondo waneni!
\sp Wuowi
\q1 Ere gima omiyo ungʼiyo nyar jo-Shulam kamano,
\q2 mana ka gima omielo miend Mahanaim?
\b
\c 7
\q1 
\v 1 Mano kaka tiendeni beyo kirwako pat pat,
\q2 yaye nyar joka ruoth!
\q1 Tiendeni pichni ka kite ma nengogi tek,
\q2 ka gima jopecho molony ema opayo.
\q1 
\v 2 Pendi ogomo ka wend agwata,
\q2 ma divai moru maber ok rumie.
\q1 Nungoni chalo pidh ngano mochok kaachiel,
\q2 ma ondanyo olworo koni gi koni.
\q1 
\v 3 Thundeni chalo gi nyithind mwanda ariyo,
\q2 gichalo gi nyithind mwanda ma rude.
\q1 
\v 4 Ngʼuti chalo gi kar ngʼicho
\q2 motingʼore gi malo molos gi lak liech.
\q1 Wengeni nyawni ka pi Yawo mar Heshbon
\q2 but rangach mar Bath Rabim.
\q1 Umi chalo gi kar ngʼicho motingʼore gi malo
\q2 mar Lebanon momanyore gi Damaski.
\q1 
\v 5 Wiyi miyi duongʼ mana ka Got Karmel,
\q2 yie wiyi to ochanore ka orengo mar ruoth,
\q2 kendo omako pach ruoth.
\q1 
\v 6 Mano kaka ijaber kendo imiya mor,
\q2 mano kaka imora, yaye jaherana!
\q1 
\v 7 Dendi odongo mana ka othith,
\q2 to thundi to chalo mana ka olemo,
\q2 mogudore kanyachiel.
\q1 
\v 8 Ne awacho niya,
\q2 “Abiro lwenyo yiend othith;
\q1 nyaka amak olembe gi lweta.”
\q2 Mad thundeni chal gi olemb,
\q1 mzabibu mochokore kanyachiel,
\q2 to tik mar muchi chal gi olemo mayom,
\q1 
\v 9 kendo dhogi chal mana gi divai mamit.
\sp Nyako
\q1 Mad divai lor mos e dwond jaherana,
\q2 kamol mos e kind lewe kod lekene komadhe.
\q1 
\v 10 An mar jaherana,
\q2 kendo gombone ni kuoma.
\q1 
\v 11 Bi, jaherana, bi wadhi waba ei gwengʼ,
\q2 kendo wanind oko e bunge.
\q2 
\v 12 Bi wamondi gokinyi wadhi,
\q2 e puothe mzabibu mondo wangʼiane,
\q1 ka mzabibu oseolo,
\q2 bende wangʼiane ka gisechako thiewo,
\q1 kendo ka olembe mongʼinore oselokore makwar;
\q2 kuno, ema abiro miyie herana.
\q1 
\v 13 Kuno ema inyalo winjoe tik mar mandrake,
\q2 kendo e odwa kanyo okanni gik mamit,
\q1 motingʼo gik machon gi manyien,
\q2 ma asebedo ka akanoni, yaye jaherana.
\b
\c 8
\q1 
\v 1 Ka dine ibedna owadwa mahie,
\q2 mane wadhodhogo thuno achiel,
\q1 to dine anyodhi, kapo ni ayudi oko,
\q2 kendo onge ngʼama dine ochaya.
\q1 
\v 2 Dine amako badi, mi akeli nyaka
\q2 e od minwa kama ne opuonjae.
\q1 Dine amiyi divai moketie yedhe madungʼ tik mamit mondo imadhi;
\q2 kendo dine amiyi olemo mongʼinore makwar.
\q1 
\v 3 Bade ma koracham oteno wiya,
\q2 to bade ma korachwich okwaka.
\q1 
\v 4 Un nyi Jerusalem, asiemou ni kik
\q2 utug hera kata chiewe ka sa ne pok oromo.
\sp Osiepe
\q1 
\v 5 Mano to ngʼa mabiro koa e piny motimo ongoro
\q2 koyiengore kuom jaherane?
\sp Nyako
\q1 Ne achiewe e bwo yadh olemo mayom;
\q2 kanyo ema ne minu omake ichni,
\q2 kendo kanyo ema ngʼat mane muoch okayo nonywolie.
\q1 
\v 6 Para e chunyi kinde duto,
\q2 kendo wiyi kik wil koda;
\q1 nikech hera nigi teko mana ka tho, kendo nyiego ma
\q2 hera nigo tut mana ka bur tho.
\q1 Herano liel ka mach mabebni,
\q2 kendo mana ka ligek mach maduongʼ.
\q1 
\v 7 Pige mathoth ok nyal nego hera;
\q2 kendo kata aore maringo ok nyal ywere.
\q1 Ka dipo ni ngʼato dichiw mwandu duto mag ode
\q2 mondo oyud hera, to mano dibed fuwo maduongʼ.
\sp Osiepe
\q1 
\v 8 Wan gi nyaminwa moro matin,
\q2 kendo thundene pok obedo madongo.
\q1 Angʼo mwanyalo timone
\q2 nyaminwa chiengʼ ma wuowi obiro dware?
\q1 
\v 9 Ka dine bed ni en ohinga,
\q2 to dine wagero osuch fedha kuome.
\q1 To ka dine obed ni en dhoot,
\q2 to dine walore gi thigo mar bap sida.
\sp Nyako
\q1 
\v 10 An to an ohinga,
\q2 kendo thundena ochungʼ,
\q1 ka ohinga moger motingʼore gi malo.
\q2 Kuom mano, asebedone wangʼ monenogo,
\q2 kendo asemiyo obedo gi kwe.
\q1 
\v 11 Solomon ne nigi puoth
\q2 mzabibu kama iluongo ni Baal Hamon;
\q1 kendo ne oketo puotheno e lwet jopur.
\q2 Moro ka moro kuomgi nonego chul Solomon kilo,
\q1 apar gachiel gi nus mar fedha kuom olembene.
\q1 
\v 12 An to an gi puotha awuon mar mzabibu;
\q2 to in Solomon in to bed abeda gi kilo apar gachiel,
\q1 gi nusgo miyudo kuom jopur,
\q2 to un jopur un bende beduru abeda gi kilo,
\q2 ariyo gi nusgo moyudo kuom poku.
\sp Wuowi
\q1 
\v 13 In midak e puothe mzabibu
\q2 kaachiel gi osiepeni mabudhi,
\q2 yie awinjie dwondi gie puodho kuno!
\sp Nyako
\q1 
\v 14 Bi wadhi, jaherana,
\q2 kendo chal gi mwanda kata le,
\q1 mamoko manie thim mochungʼ
\q2 ewi gode mopongʼ gi yedhe madungʼ tik mangʼwe ngʼar.
