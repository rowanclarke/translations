\id XXD - Waskia Bible; Timeline; Fay Barker; 23-August-2013 
\h Timeline 
\toc1 MEL BIBIYA ARATU NAMARAM KO YIA TOM KOMA KOMA 
\toc2 Timeline 
\mt1 MEL BIBIYA ARATU NAMARAM KO YIA TOM KOMA KOMA  
\m Kaem mel suen la nungam  //  Genesis 1-2  //  Creation  
\m Kari ikup te dagulam  //  Genesis 3  //  The Fall  
\m Lom biya  //  Genesis 6-8  //  The Flood  
\m Kariimet gue pagam namaram  //  Genesis 10  //  List of Nations  
\m Kawam kalel biya kaloman  //  Genesis 11  //  Tower of Babel  
\pc ________________  
\m Abraham Ur beteram ale Canaan namaram (B.C. 2100 iwita)  //  Genesis 12  //  Father of faith  
\m Abraham Isaac Jacob (B.C. 2160 tai 1800 iwita)  //  Genesis 12-50  //  The Patriarchs  
\m Joseph Egypt sor te bagaram (Nu B.C. 1805 iwita te kueram)  //  Genesis 37-50  //  Joseph  
\m Jacob ko gue yia tom 430 iwita Egypt bagaman  //  Exodus  //  Egyptian period  
\pc ________________  
\m Moses Egypt sor te bilangaram (B.C.1450 mu te iwita)  //  Exodus  //  Moses born  
\m Israel alo Egypt beteman arataman (B.C. 1370 mu te iwita)  //  Exodus  //  The Exodus  
\m Israel alo Canaan ali taman (B.C. 1310-1297 mu te iwita) Joshua  //  Into Canaan  
\m Kari sinar Israel alo nunga bitarman  //  Judges ...  //  Period of judges  
\m (B.C. 1272 mu te tai kapa B.C.1050 iwita)  
\pc ________________  
\m Saul, David, Solomon king ko bagakasan  //  1 Samuel....  //  United kingdom  
\q1 (B.C. 1050 mu te tai kapa 931 iwita)  
\m Israel kelemak sanamaram se Judah kilimik  //  1 Kings 11...  //  Divided kingdom  
\q1 (B.C. 931 mu te tai kapa B.C. 586 iwita)  
\m Assyria alo Israel menawuman B.C. 722  //  2 Kings  //  Fall of Samaria  
\m Babylon alo Jerusalem maguwuman B.C. 586  //  2 Kings 25  //  Fall of Jerusalem  
\m Juda kariimet Babylon bagaman  //  Daniel...  //  Exile in Babylon  
\m Juda alo nunga wonong duap te pilakasan  //  Ezra Nehemiah  //  The Return  
\q1 (B.C. 538 mu te tai kapa B.C. 444 iwita)  
\pc ________________  
\m Yia B.C. 931 tai kapa 430 mu te iwita prophet saki Kaem ko den Judah se Israel kariimet nungarukasan:  
\m Israel: Elijah, Elisha, Jonah, Amos, se Hosea  
\m Judah: Obadiah se Joel (B.C. 835?)  
\q1 Isaiah (B.C. 730 iwita duap beteram) se Micah  
\q1 Nahum (B.C. 650?), Zephaniah, Jeremiah, se Habakkuk  
\q1 Daniel (B.C. 600 iwita duap beteram), se Ezekiel  
\q1 Haggai se Zechariah (B.C. 535 mu te tai kapa 510 iwita)  
\q1 asele mom kopa te Malachi (B.C. 435 mu te iwita)  
\pc ________________  
\m Babylon mu kingdom biya bagaram, asele Persia, asele Greece, asele Rome.  
\m Jesus bilangaram, B.C. 4 mu te iwita  //  Birth of Christ  
\m Jesus temple ningi namaram, A.D. 8 mu te  //  Jesus in the temple  
\m Pilate Judea sor bitua duap beteram, A.D. 26 mu te  //  Pilate governing Judea  
\m Jesus Galiliee sor te ura duap beteram, A.D. 29 mu te  //  Public ministry of Jesus  
\m Jesus kueram, ale aking barasam, A.D. 33 mu te  //  Death and resurrection  
\m Nu day 40 ali imi te baga duruk wonong te namaram  //  Ascension of Jesus  
\pc ________________  
\m Korang Bur olekem alo nongote tai kaparam, A.D. 33 mu te  //  Pentecost  
\m Olekem alo sor sor te geraga se Jesus ko den balukasan  //  Spread of the gospel  
\m Paul Jesus ko gomang ningi nunguning aram, A.D. 34 mu te  //  Paul's conversion  
\m Olekem James moman se kueram, A.D. 44 mu te  //  Disciple James killed  
\m Paul sor saki te geragakaso, A.D. 46 nama 49 mu te  //  Paul's first journey  
\m Jerusalem biguwura biya, Acts 15, A.D. 49 mu te  //  Council of Jerusalem  
\m Paul aking sor saki te geragakaso, A.D. 49 nama 51 mu te  //  Paul's second journey  
\m Paul kam maiya nuam sor saki te lagakaso, A.D. 52 nama 57  //  Paul's third journey  
\m Paul Jerusalem iluman, A.D. 56-57 mu te iwita  //  Paul arrested  
\m Paul Caesarea talipara ningi bagakaso, A.D. 57 nama 60  //  In prison in Caesarea  
\m Nuna Paul ilak Rome namaman, A.D. 60 mu te  //  Taken to Rome  
\m James, Jesus ko uria, moman se kueram, A.D. 62 mu te  //  James killed  
\m Paul Rome talipara la baga moman se kueram, A.D. 66-67 mu te  //  Paul killed  
\m Peter moman se kueram, A.D. 67-68 mu te iwita  //  Peter killed  
\m Rome kari Titus tairam Jerusalem temple maguwuram, A.D. 70  //  Temple destroyed  
\m Rome alo Kris alo ninguru nunga bita maguwukasan, A.D. 81-96  //  Persecution by Rome  
\m John Patmos tual te beteman se bagakaso, A.D. 93-96 mu te  //  John on Patmos  
\m John kueram, A.D. 98 mu te  //  Death of John  
\pc ________________  
\m “Ikialko. Ani pempem la nengerak bagarik nama tom nukum tai aratukko.”  