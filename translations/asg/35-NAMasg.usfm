\id NAM - Cishingini Agwara Kambari [asg] 
\toc3 Nah 
\toc2 Nahum 
\toc1 Katagarda ka Nahum 
\mt2 Keneki 
\mt1 Nahum 
\imt1 Kuɓa̱yuwa̱ 
\im Katagarda ka Nahum ka ishipa i ma̱za̱nga̱ i ɗa adama a̱ uyikpi u Niniva, likuci i gbayin i Asiriya i na yi a tsurala n Isaraila. Ugan ba a ɗana ta̱ katagarda ka a ka̱ya̱ ka (612) kafu a matsa Yesu. I ta̱ e kene uyikpi u Niniva atakaci a̱ Ka̱shila̱ a ɗa adama a ugbamukaci u ni n ka gbani-gbani ka̱ ni. Atakaci a nampa a̱ ta̱wa̱ ta̱ a ukocishi u tsumani ci cindere kafu a matsa Yesu. 
\iot Ili i na yi punu udari 
\io1 Afada adama a Niniva 1:1-15 
\io1 Uyikpi u Niniva 2:1; 3:19 
\c 1  
\p  
\v 1 Akaka adama a Niniva. Na lo va ɗaɗa katagarda ka kene ka na keneki Nahum vuza va aza a Elikoshi we enei. 
\s1 Wupa u Vuzavaguɗu adama a Niniva 
\q1  
\v 2 Vuzavaguɗu Ka̱shile vuza cisheꞋe ɗa, 
\q2 vuza na u ci yaꞋan katsupu, 
\q1 Vuzavaguɗu vuza katsupu ɗa, 
\q2 vuza va asuvu a usuɗukpi kpamu. 
\q1 Vuzavaguɗu u tsu tsupa ta̱ irala i ni, 
\q2 u tsu bonoko ta̱ wupa u ni a̱ ubuta̱ wi irala i ni. 
\q1  
\v 3 Vuzavaguɗu vuza wupa ɗa gogoꞋo ba, 
\q2 ama vuza tsu tsugbayin n utsura ɗa, 
\q2 Vuzavaguɗu wi a̱ kukpa̱ɗa̱ kutakacika vuza vu unushi ba. 
\q1 Uye u na Vuzavaguɗu u tsu wala, kabatalikpau ka gbayin ka tsu vugula̱ ta̱, 
\q2 eleshu kpamu ɗaɗa kubuta̱ ku ene a̱ ni. 
\q1  
\v 4 U tsu ɓarangu ta̱ mala ali me ɗekpe, 
\q2 u tsu zuwa ta̱ nyeneke ra̱ka̱ n ɗekpe. 
\q1 ali n ubuta̱ u kalina a Bashan nu nsasan n Kamelu dem, 
\q2 a na i n mita̱ ma̱ ta̱ku nu nɗanga n tsu ɗekpe ta̱, 
\q2 a̱pa̱lu a Lebano dem a tsu lumba ta̱. 
\q1  
\v 5 Nsasan m gbagbaꞋin n tsu gba̱ɗa̱ ta̱ e kelime ka̱ ni, 
\q2 aginda kpamu a tsu derikpe ta̱. 
\q1 Ka̱ta̱ iɗika i jengeɗe e kelime ka̱ ni, 
\q2 e, ali aduniyan koɓolo n ili i na yi punu dem. 
\q1  
\v 6 Yayi wa kufuɗa kushamgba e kelime ka̱ ni, u yaꞋan baci wupa? 
\q2 Yayi wa kufuɗa kugbama asuvu e kelime ka̱ ni, ɗa baci u yaꞋin wupa? 
\q1 Wupa u ni u tsu va̱ma̱ ta̱ tsa akina, 
\q2 akpanlai a gbagbaꞋin o tsu ɓoso ta̱ e kelime ka̱ ni. 
\q1  
\v 7 Vuzavaguɗu vuza singai ɗa, 
\q2 ubuta̱ u kusheɗeku u ɗa wi a kanna ka atakaci. 
\q1 U tsu ere ta̱ aza a na a̱ tsu sheɗeku wa̱ a̱ ni. 
\q1  
\v 8 Ama tsu mini ma na ma ayai wi ta̱ a kuniꞋwa̱nta̱ngu irala i ni ra̱ka̱, 
\q2 wi ta̱ a kuyawaka Niniva uteku, 
\q2 ka̱ta̱ u loko aza a na a iwain ni a kubana a̱ ka̱yimbi. 
\q1  
\v 9 Yiɗa̱i i zuwai ɗa yi a kushiya tsurala n Vuzavaguɗu? 
\q2 Ili ra̱ka̱ ko yiɗa̱i baci wi ta̱ a kubonoko i ɗa gbani, 
\q2 babu vuza na u kuyaꞋan tsurala n a̱yi kure. 
\q1  
\v 10 Irala i ni, 
\q2 i ta̱ ugbaɓi tsa awana, 
\q1 i ta̱ an osoꞋi a na a osoꞋi ma̱ra̱ ma makai le, 
\q2 a n nwalu n a tangalangi a maza me le, 
\q1 i ta̱ o kusongu le ra̱ka̱, 
\q2 an mita̱ me ɗekpu. 
\q1  
\v 11 Punu a̱ ka̱tsuma̱ ka Niniva, ɗa vuza yoku wu uta̱i, 
\q2 vuza na u foɓusoi ka gbani-gbani a kubana u Vuzavaguɗu, 
\q1 u nekei odoki a gbani-gbani. 
\p  
\v 12 Ili i na Vuzavaguɗu u danai i ɗaɗa na, 
\q1 <<A̱ɗa̱ aza Asuriya, ko a na wo okpoi yi ta̱ n ka̱bunda̱i, 
\q2 tukpa n utsura kpamu, 
\q2 i ta̱ kugbatya ɗa̱, ka̱ta̱ a takpa ɗa̱. 
\q1 A̱ɗa̱ aza a Yahuda, ko a na wo okpoi n neke ɗa̱ ta̱ atakaci, 
\q2 mi o kudoku ma takacika ɗa̱ kpamu ba. 
\q1  
\v 13 Gogo na mi ta̱ o kukoɗo kogboro ke eɗeku a̱ ɗa̱, 
\q2 ka na aza Niniva a zuwakai ɗa̱, 
\q1 ka̱ta̱ kpamu n kasa ikani, 
\q2 i na a shiyakai ɗa̱.>> 
\q1  
\v 14 Vuzavaguɗu u neke ta̱ kadanshi, 
\q2 adama a Niniva u danai, 
\q1 <<I o kudoku kupana kula ku nu ba. 
\q2 A̱ma̱li u sheꞋwei n uluwi a̱ nu, 
\q2 mi ta̱ a kukapa a ɗa a̱ ka̱tsuma̱ ka a̱Ꞌisa̱ a̱ma̱li a̱ nu, 
\q1 ka̱ta̱ n foɓuso ko wu kasaun, 
\q2 adama a na avu ili i ma̱riki i ɗa ba.>> 
\q1  
\v 15 La̱na̱, a gaɗi vu nsasan m gbagbaꞋin, 
\q2 ene a vuza na u tsu tuka̱ n arabali a singai a ɗa na, 
\q2 a̱yi na u tsu sala ukuna u ma̱ta̱na̱. 
\q1 Avu Yahuda, zuwa ka̱ɗiva̱ a̱ nu, 
\q2 Shatangu uzuwakpani u nu. 
\q1 Adama a na ili i gbani-gbani i nanlo Niniva, 
\q2 a takpai ta̱ ra̱ka̱. 
\q2 i ta̱ a ku una le ra̱ka̱-ra̱ka̱. 
\c 2  
\s1 Uyikpi u Niniva 
\q1  
\v 1 Vuza munuka u foɓuso ta̱, avu Niniva, 
\q2 u zuwa ta̱ osoji a mashilya ma̱ likuci ma. 
\q1 a yaꞋan kindi ku ubuta̱ u kusheɗeku wu n nshilya, 
\q2 foɓuso mayin, 
\q2 ɓolongu osoji a̱ nu ra̱ka̱. 
\q1  
\v 2 Adama a na Vuzavaguɗu wi ta̱ o kubonoko, 
\q2 n ugaꞋin u Yahuda n wa aza a Isaraila ra̱ka̱, 
\q1 ko ɗa baci aza a̱ kupura̱ uciyi, 
\q2 a̱ pura̱i uciyi u likuci u le ra̱ka̱, 
\q2 ko ɗa baci a̱ la̱nga̱sa̱i a shina a̱ nɗimbi e le. 
\q1  
\v 3 Nra̱ga̱ mo osoji ma aza a Niniva n na n fuɗai kuvon, 
\q2 n shilyamgba ta̱ ushili, 
\q1 osoji i ta̱ u uki, 
\q2 n akashi a̱ shili. 
\q1 Ekeke o doku e le a kutasa, 
\q2 tsu melentsu ma akina, 
\q2 a̱ kuɗa̱ngusa̱ nsara e kuneke le wovon. 
\q1  
\v 4 Odoku, n ekeke odoku o kuvon, 
\q2 a̱ ka̱na̱i ilaɗi i kavama a uye, 
\q1 a kubana n obonoi, 
\q2 punu asuvu a̱ ka̱ba̱nga̱ ka̱ likuci. 
\q1 ku uta̱ ku le tsu kutashi ku ma̱kuni ku ɗa, 
\q2 a nwalu a na ulaɗi. 
\q1  
\v 5 Mogono ma Niniva me ɗekei osoji a gbagbaꞋin a̱ ni, 
\q2 ɗa a̱ ka̱na̱i ku ta̱ɗa̱tsa̱ n yikpa̱i a uye a̱ kuta̱wa̱. 
\q1 A dakakai a kubana a mashilya ma̱ likuci ma, 
\q2 ɗa a̱ shikpa̱i i na i kere le. 
\q1  
\v 6 A̱ ɓa̱yuwa̱i adaɓa a̱ mini, 
\q2 ɗa kpaꞋa ku mogono ku ripula̱i. 
\q1  
\v 7 O foɗoi Egbere aminya ɗa a lazai n a̱yi, 
\q2 agbashi a nkere n ni a̱ ma̱shi, 
\q1 ma̱shi ma kpalu me le tsu ma̱shi ma moɗoi ma a, 
\q2 a zuwai ekiye e le aci. 
\q1  
\v 8 Tsu mini ma na mo ɓosoi a̱ ka̱sha̱n, 
\q2 aza a Niniva a kusuma a̱ ku uta̱ punu, 
\q1 uma a kudana le <<Shamgbai! Shamgbai!>> 
\q2 Ama babu vuza na u kpatalai wu indanai kucina̱. 
\q1  
\v 9 Pura̱ngi azurufa. 
\q2 Pura̱ngi azanariya. 
\q1 Likuci ya yi ta̱ tukpa nu uciyi kakau, 
\q2 uciyi u ni wi n uteku ba. 
\q1  
\v 10 Niniva u na̱mgba̱ ta̱, 
\q2 wo okpo ta̱ agali, 
\q2 a̱ɗu a uma a̱ ni e derikpe ta̱, 
\q2 a̱ka̱nga̱tsu e le e kujeꞋe, 
\q1 a̱kyun e le kpamu a mɓa̱la̱, 
\q2 a̱shi e le ra̱ka̱ a̱ ula̱nga̱shi. 
\q1  
\v 11 Yiɗa̱i i ciya̱i likuci i Niniva, 
\q1 i na yi tsu kpenle ki ikawu? 
\q1 Kpenle ku na a̱ tsu ɓa̱na̱ muku mi ikawu, 
\q1 ubuta̱ u na kawu n a̱ma̱ci e le a̱ tsu ka̱ra̱Ꞌa̱, 
\q2 koɓolo n muku mi ikawu babu wovon. 
\q1  
\v 12 Kawu u tsu saza ta̱ i na, 
\q2 i yawai ni koɓolo m muku n ni, 
\q1 ka̱ta̱ kpamu wu una ka vuka vu ni manama, 
\q2 u shatangu kpenle ku ni n uciyi ugbani, 
\q2 ungu a̱ ni kpamu nu nnama n kakamba. 
\q1  
\v 13 Vuzavaguɗu u danai, 
\q2 <<Mi ta̱ a tsurala n avu Niniva, 
\q1 mi ta̱ o kusongu ekeke o odoku o kuvon a̱ nu, 
\q2 ka̱ta̱ kotokobi ku una osoji a̱ nu aza a na i tsu ikawu, 
\q2 mi ta̱ a̱ kusa̱nka̱ wu vu una uduniyan. 
\q2 Ka̱ta̱ n sa̱nka̱ aza u suki a̱ nu kubanka n akaka a na e kuneke wovon.>> 
\c 3  
\s1 Niniva wi ta̱ o ko okpo agali 
\p  
\v 1 Ili ya atakaci i ɗa avu likuci i munuka, 
\q2 a̱yi na u shanai tukpa n aꞋuwa a̱bunda̱i, 
\q1 n ucanuku u na a isai. 
\q1  
\v 2 Panai, izumgbi yi nshashau n yi ekeke, 
\q2 n izumgbi ya ilaɗi yo odoku, 
\q2 n kugba̱ɗa̱ ke ekeke o odoku. 
\q1  
\v 3 Inda biꞋi akumbi odoku o kuvon, 
\q2 otokobi nu nsara a kutasa tsa akina, 
\q1 na ɗa koɓolo ka uma ka na unai, 
\q2 na ɗa kaginga ke even a uma, 
\q1 even a uma babu uteku, 
\q2 uma a̱ kuta̱ɗa̱tsa̱ a gaɗi vu even a ikyamba. 
\q1  
\v 4 Ili i nanlo ra̱ka̱ i yaꞋan ta̱ adama a tsugbani ci Niniva, 
\q2 kashakanlai kasingai ka nanlo ka una̱ wu uyoꞋo, 
\q1 ma̱ma̱ci mo tsuboci ma a, 
\q2 a̱yi na u ya̱nsa̱i uduniyan ubuta̱ u tsugbani u ni, 
\q2 uma kpamu a̱ ubuta̱ wa alaꞋwin a̱ ni. 
\q1  
\v 5 Vuzavaguɗu malaꞋimili u danai, mi ta̱ a tsurala n avu, 
\q2 mi ta̱ a̱ ku Va̱ga̱lukpa̱ ciyanpa tsu nu, ka̱ta̱ m palaka a̱shi a̱ ni. 
\q1 Ka̱ta̱ n zuwa iɗika kakau yi ene ciyampa tsu nu, 
\q2 ka̱ta̱ tsugono kpamu ce ene wono u nu. 
\q1  
\v 6 Mi ta̱ a ku vishangu wu ili yu unata, 
\q2 ka̱ta̱ n goyo wu, 
\q2 n bonoko wu ili i kugoyi. 
\q1  
\v 7 Aza a na e enei nu ra̱ka̱ i ta̱ a kusuma ka̱ta̱ a dana, 
\q2 <<Niniva wo okpo ta̱ agali, ya yi u kuyaꞋan kpalu ku ni?>> 
\q2 Te ɗai n kuciya̱ aza na e kuneke yi kadanshi ka uremi u ka̱ɗu? 
\q1  
\v 8 Niniva, avu vu laꞋa ta̱ likuci i Tebesu, 
\q2 i na yi a ka̱kina̱ ka kuyene ku Nilu, 
\q2 m mini uka̱ra̱Ꞌi u ni dem? 
\q1 Mala maꞋa ubuta̱ u kusheɗeku u ni, 
\q2 mini maꞋa mashilya ma ni. 
\q1  
\v 9 Itopiya m Masar ɗa utsura u ni, 
\q2 Futu n Libiya ele ɗa a̱ tsu ɓa̱nka̱ yi, 
\q1  
\v 10 N nannai dem a ɗikai ni, 
\q2 a bankai ugbashi, 
\q1 a minjarai aci a̱ muku n ni, 
\q2 a nsanji mu uye dem. 
\q1 A yaꞋin kazagba adama nkoshi m gba̱ra̱-gba̱ra̱ n ni 
\q2 ɗa a shiyai uma a gbagbaꞋin a̱ ni dem ni ikani. 
\q1  
\v 11 Avu a̱ ka̱ci ka̱ nu Niniva vi ta̱ o kusoꞋo ma̱ra̱ ma makau, 
\q2 ka̱ta̱ vu takacika n a̱bunda̱i, 
\q2 ali vu la̱nsa̱ ubuta̱ u kusheɗeku a̱ ubuta̱ wi irala i nu. 
\q1  
\v 12 Nshilya mu utsura u nu ra̱ka̱ mi ta̱ o ko okpo babu utsura, 
\q2 i ta̱ a kulyaꞋa le tsu umaci u ma̱biri, 
\q2 u na u geꞋwei, 
\q1 a makyan ma na baci a̱ gba̱ɗa̱i maɗanga ma, 
\q2 ka̱ta̱ umaci wa u yikpa̱ a̱ una̱ u vuza na u kulyaꞋa le. 
\q1  
\v 13 La̱na̱ biꞋi osoji a̱ nu, 
\q2 i ta̱ tsa a̱ma̱ci e mere ma̱ nu. 
\q1 Utsutsu wi iɗika i nu yi ta̱ uɓa̱yuwi, 
\q2 adama a irala i nu, 
\q2 akina e leɓece ta̱ agbaguratsu e le. 
\q1  
\v 14 Kenuku mini adama a na i ta̱ a ku kambuku wu, 
\q2 tarai mini ma̱ a̱bunda̱i kafu kuvon ku yawa. 
\q1 Doku katsura ka nshilya n nu, 
\q2 bana a kadaɓa vu na̱na̱ ciꞋin, 
\q2 ɗika ili kuyaꞋanka iputa̱. 
\q1  
\v 15 Dem n ofoɓuso a nampa, 
\q2 akina a ɗa a kulyaꞋa wu, 
\q1 kotokobi kpamu ki ta̱ a kugbatya kuɗeku ku nu. 
\q2 Ka̱ta̱ a lyaꞋa wu tsa kakyuꞋun. 
\q1 Vu doku ka̱bunda̱i ka̱ nu tsa akyuꞋun, 
\q2 ɗa vu yimkpai n ka̱bunda̱i ci ishigi. 
\q1  
\v 16 Vu doki ka̱bunda̱i ka aza a tsulaga a̱ nu, 
\q2 ali a laꞋi ka̱bunda̱i ka azangata a gaɗi, 
\q1 e le i ta̱ tsu nta̱ɗa̱ma̱ci n na n tsu ba̱ra̱kpa̱ evelyu e le, 
\q2 ka̱ta̱ a imkpa a laza. 
\q1  
\v 17 Ngono n nu i ta̱ tsu nta̱ɗa̱ma̱ci, 
\q2 nkoshi m gba̱ra̱-gba̱ra̱ n nu mi ta̱ an ka̱kuma̱ ka nta̱ɗa̱ma̱ci 
\q2 a ku tele a̱ wuya̱n 
\q1 a ayin a uta̱ni 
\q2 ka̱ta̱ makyan ma na baci kanna ku uta̱i a imkpa a laza, 
\q2 babu vuza na u yevei ubuta̱ u na a kubana. 
\q1  
\v 18 Avu mogono ma Asiriya, 
\q2 nguɓi n nu n lata ta̱, 
\q1 e yevei a̱ nu a gbaɗika ta̱. 
\q2 Uma a̱ nu a wacuwai a nsasan, 
\q2 babu vuza na u ku ɓolongu le. 
\q1  
\v 19 Babu i na i kupotsotongu untsu a̱ nu, 
\q2 untsu a̱ nu a munuka a ɗa. 
\q1 Vuza na baci de dem u panai arabali a̱ nu, 
\q2 ka̱ta̱ u ɓasa ekiye u dana, 
\q1 adama a na yayi u kpa̱ɗa̱i ku takacika, 
\q2 ekiye a̱ nu?