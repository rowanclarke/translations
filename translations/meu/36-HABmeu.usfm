\id HAB .01, Habakkuk 1, Motu, PNG, RTWP 12/92
\h HABAKUKU
\toc1 HABAKUKU
\toc2 HABAKUKU
\mt1 HABAKUKU
\c 1
\s1 Habakuku ese Dirwa e tai henia
\p 
\v 1 Dirava ena hereva metauna, peroveta tauna Habakuku ese e matahanailaia.
\q1 
\v 2 Iehova e, baina boi henimu, ba durugu totona;
\q2 bena basio kamonai ela bona edena nega ai?
\q1 Eiava baina tai henimu, bainato “Daḡedaḡe”,
\q2 bena basio hamaurigu a, ela bona edena nega ai?
\q1 
\v 3 Badina be dahaka kara kereredia o haheitalaigumu?
\q2 Dahaka dainai hekwakwanai ḡaudia o hahedinarai henigumu?
\q1 Hahebua-tari bona daḡedaḡe na vairagu ai,
\q2 heatu bona heiri-heiri na e varamu.
\q1 
\v 4 Taunabunai, taravatu e manokamu,
\q2 bona hahemaoro ḡoevaḡoeva na se hedinaraimu.
\q1 Badina be kara dika taudia ese kara maoromaoro taudia na e ḡeḡedia daemu,
\q2 bona hahemaoro ḡoevaḡoeva na e gageva-gagevamu.
\s1 Kaldea taudia ese Iuda bae habuaia tari
\q1 
\v 5 Bese bogaragidiai ba roharoha, ba itaia;
\q2 ba hoa, ba hoa dikadika.
\q1 Badina be emui nega ai kara ta na karaiamu;
\q2 ena be bama hamaorolaimui, to basioma kamonai.
\q1 
\v 6 Badina be, a itaia, Kaldea taudia na hatoredia isimu,
\q2 una kara idita bona kara heau-heau besena.
\q1 Idia ese tanobada lababana e rakaia hanaimu,
\q2 noho gabudia dia idia edia na idia ese e dadimu.
\q1 
\v 7 Idia ese gari bona kudou-hetaha e havaradiamu,
\q2 edia hahemaoro bona edia siahu na sibodia edia amo e varamu.
\q1 
\v 8 Edia hosi ese taiga e hereadiamu edia heau ai,
\q2 bona tano-ḡaḡaena uda-sisiadia e hereadiamu edia daḡedaḡe ai;
\q2 edia hosi-gui taudia na e heaumu mai heaḡidia ida.
\q1 Oibe, edia hosi-gui taudia na dauha amo e maimu,
\q2 ugava na heto e rohomu, ala-ala totona.
\q1 
\v 9 Iboudiai na kara daḡedaḡe totona e maimu;
\q2 igari-henidia na vairadiai e laomu,
\q2 e ḡuidiamu taudia na miri na heto.
\q1 
\v 10 Hanua pavapavadia na e ihi-ihiraidiamu,
\q2 bona hanua lohiadia na e kirikirilaidiamu.
\q1 Kohoro iboudiai e kirikirilaidiamu,
\q2 badina be tano na e larebamu, bena-e abidiamu.
\q1 
\v 11 Lai na heto e heau hanaimu e laomu,
\q2 kerere laudia, sibodia edia goada na edia dirava ai e halaoamu.
\s1 Habakuku ese Iehova e ḡanaḡana heniamu
\q1 
\v 12 Iehova e, egu Dirava, egu Helaḡa Diravana,
\q2 oi na o noho hanaihanaimu ani?
\q2 Ai na basia mase.
\q1 Iehova e, oi ese vada o gwauraidia,
\q2 ai ihahemaoro-henimai taudia ai baela.
\q1 Nadi-gini e, oi ese vada o haginidia,
\q2 ai matamai ihakanidia totona.
\q1 
\v 13 Oi matamu na ḡoeva-dae dainai,
\q2 kara dika basio itaia,
\q2 bona kara kerere basio raraia diba.
\q1 Dahaka dainai asi edia heabidadama taudia na o haḡerediamu?
\q2 Badina be dahaka oi na asi regeregemu, kara dika tauna ese kara maoromaoro ai ia e hereaiamu tauna e hadonoamu negana ai?
\q1 
\v 14 Badina be oi ese taunimanima na o karadiamu,
\q2 davara gwarumedia na heheto,
\q1 eiava tano ai e raumu ḡaudia na heheto,
\q2 asi biagudia.
\q1 
\v 15 Ia ese kimai ai e veridiamu,
\q2 ena reke ai e veridia lasimu,
\q1 ena ole ai e haboudiamu,
\q2 bena e moalemu bona e heaḡimu.
\q1 
\v 16 Taunabunai ia ese ena reke e bouamu,
\q2 bona muramura mai bonana na ena ole e gabu heniamu;
\q1 badina be idia daidiai ia ese digara e animu,
\q2 bena ana aniani na mai gaihona.
\q1 
\v 17 Matona, ia ese ena reke anina baine bubua loulou a?
\q2 Bese idau-idau baine habuadia tari hanaihanai a?
\c 2
\s1 Iehova ena haere
\q1 
\v 1 Lau na baina gini, baina gima,
\q1 kohoro ai baina gini,
\q2 baina roha lao, baina itaia,
\q1 ia ese ede baine hereva henigu toma,
\q2 bona ede baina haere toma,
\q1 egu maumau dainai.
\q2 
\v 2 Bena Iehova ese e haere henigu, eto:
\q1 Mata-hanai herevana ba torea,
\q2 nadi palakadia ai ba hahedinaraia,
\q1 bena iduahina tauna na baine heau.
\q2 
\v 3 Badina be mata-hanai na doini ena nega e nariamu,
\q1 dokona e heau heniamu, basine koikoi.
\q2 Ena be boma toma ia na metaira-metaira, to do ba naria;
\q1 momokani, ia na bainema, basine halahe.
\q2 
\v 4 A itaia, lalona na dia maoro tauna na baine moru,
\q1 a kara maoromaoro tauna na ena heabidadama dainai baine mauri.
\q2 
\v 5 Ina danu, vine ranuna na mai ena hekoi,
\q1 bona hekokoroku tauna na basine noho daudau.
\q2 Ena mata-ganigani na mai lababana, Mase Gabuna na heto,
\q1 mase na heto, ia na se honumu.
\q2 Basileia iboudiai na e gogodiamu, ena;
\q1 bona bese iboudiai na e haboudiamu, ia sibona ena.
\s1 Kara dika taudia iḡonaḡonalaidia
\p 
\v 6 Ini iboudiai ese ia bae ḡonaḡonalaia, ani; bae ihi-ihiraia mai kiridia ida, baeto:
\q1 Ḡau e senumu, dia iena ḡau, tauna, madi ihabaina!
\q2 Baine noho ela bona edena nega ai?
\q1 Abitorehai toadia e gogodiamu tauna danu,
\q2 madi ihabaina!
\q1 
\v 7 Emu ai e abi torehai taudia na basie tore isi taku a?
\q2 Oi kudoumu ihahetahana taudia na basie noga a?
\q2 Ena negana ai idia ese bae dadihaimu.
\q1 
\v 8 Badina be oi ese basileia momo vada o dadihaidia,
\q2 una dainai bese kwabukwabudia iboudiai ese bae dadihaimu;
\q1 taunimanima raradia bona kara daḡedaḡe daidiai,
\q2 kara daḡedaḡe tano enai bona hanua mai inoholaidia taudia ediai.
\b
\q1 
\v 9 Ena ruma na dala dikadia amo e hanamoamu tauna, madi ihabaina!
\q2 Ena ruma na atai ai e atoamu, manu rumana na heto,
\q2 dika na ienai basine kau helaoreana.
\q1 
\v 10 Emu ruma ihahemaraina dalana vada o laloa hata;
\q2 bese momo vada o negedia daure,
\q2 sibomu vada o hetao tore.
\q1 
\v 11 Badina be nadi na maḡu amo baine lolo,
\q2 bona mukuro na ruma amo baine haere.
\b
\q1 
\v 12 Rara amo hanua e haginiamu
\q2 bona kara havara amo hanua badana e hadaiamu tauna,
\q2 madi, ihabaina!
\q1 
\v 13 A itaia, ina na Iehova Sabaota ena amo, ani?
\q2 Bese idau-idau e ḡaukaramu, lahi mo iabina,
\q2 bona basileia idau-idau e hekwarahimu, asi davana.
\q1 
\v 14 Badina be tanobada na Iehova hairaina idiba-maorona amo baine honu,
\q2 davara na ranu ai e honumu na heto.
\b
\q1 
\v 15 Dekena taudia na ena badu keherena amo e ha-inudiamu
\q2 ela bona e kekeromu,
\q1 edia hemarai baine raraia helaoreana, tauna na
\q2 madi, ihabaina!
\q1 
\v 16 Dia hairai amo to hedadarai amo do ba honu;
\q2 ba inuinu, ba raraga.
\q1 Iehova imana idibana ai e miamu keherena na emu ai baine kau,
\q2 bona hemarai ese hairaimu baine habubunia.
\q1 
\v 17 Lebanon idagedaḡe henina ese baine habubunimu,
\q2 uda ḡaudia ihabua-taridia ese baine hagarimu bada,
\q1 taunimanima raradia bona kara daḡedaḡe daidiai,
\q2 kara daḡedaḡe tano enai bona hanua mai inoholaidia taudia ediai.
\b
\q1 
\v 18 Kaivakuku anina namona be dahaka,
\q2 ikarana tauna ese vada e karaia negana ai?
\q2 Ia na auri laulauna mo, koikoi ihahedibalaina ḡau.
\q1 Badina be ima karakara tauna ese sibona e karaia ḡauna na e abidadama heniamu,
\q2 asi hereva dibadia kaivakukudia e karadiamu negana ai.
\q1 
\v 19 Au ḡauna e haḡaniamu, e tomu “A noga”,
\q2 eiava asi hereva dibana nadina e hamaoroamu, e tomu “A tore isi”, tauna na
\q2 madi, ihabaina!
\q1 Ina ḡau ese lalo-diari baine havaraia a?
\q2 A itaia, \it gold\it* bona \it silver\it* ese e ḡovaiamu,
\q2 bona ia na asi laḡana.
\b
\q1 
\v 20 A Iehova na ena dubu helaḡa lalonai e nohomu;
\q2 tanobada taudia iboudiai ia vairanai bae noho, asi reḡereḡedia.
\c 3
\s1 Habakuku ena ḡuriḡuri
\p 
\v 1 Peroveta tauna Habakuku ena ḡuriḡuri anena; ane gadona ladana be Shigionoth.
\q1 
\v 2 Iehova e, oi harimu vada na kamonai;
\q2 Iehova e, oiemu ḡaukara na garilaiamu.
\q1 Laḡani bogaragidiai ba hamatamaia,
\q2 laḡani bogaragidiai ba hahedinaraia;
\q2 badu lalonai hebogahisi ba laloa tao.
\q1 
\v 3 Dirava na Teman amo ema,
\q2 Helaḡa Diravana na Paran ororona amo ema.
\q1 Ia hairaina ese guba e ḡovaia ahu,
\q2 tanobada na ia i'imodaina ai vada e honu. (Selah)
\b
\q1 
\v 4 Ia kiama-kiamana na diari na heto,
\q2 diari mamadia na ia imana amo e lasi;
\q2 unuseni ai ia ese ena siahu e ḡovaia ahu.
\q1 
\v 5 Ia vairanai dai-hanai gorerena ela,
\q2 bona ia murina amo gorere metauna.
\q1 
\v 6 Ia e gini, tanobada e hahetohoa;
\q2 ia e roha lao, basileia idau-idau e haheude-heudedia;
\q1 bena mia-hanaihanai ororodia na e heḡiḡi rohoroho,
\q2 ororo komutadia, asie idaumu gaudia, na e hevarure.
\q1 Ena kara na nega gunadia amo e hesiriumu.
\q1 
\v 7 Kusana kalagadia na hisihisidia ai na itadia,
\q2 Midian tanona ena dabua rumadia na e heude-heudeva.
\q1 
\v 8 Iehova e, emu hosi ai o gui negana ai,
\q2 emu kwalimu kariotana ai o gui kau negana ai,
\q2 sinavai na o badu henidia a?
\q1 Emu badu na sinavai latadiai
\q2 eiava davara latanai e kau a?
\q1 
\v 9 Emu peva na pauana o veria oho,
\q2 emu diba na maora ai o adai; (Selah)
\q2 tanobada na sinavai amo o hapararaia.
\q1 
\v 10 Ororo ese e itamu, bena e lagava,
\q2 abata na e aru e laova;
\q1 dobu gabuna na e herevava,
\q2 imana e dudui isiva atai ai.
\q1 
\v 11 Dina bona hua na edia ḡabu ai e gini, asie marere,
\q2 emu diba na heidodia ai e kimore-kimore dainai,
\q2 emu io kimorena dainai.
\q1 
\v 12 Mai badumu ida tanobada o dagaia tao,
\q2 emu badu ai bese idau-idau o moimoilaidia.
\q1 
\v 13 Emu bese ihamaurina totona o raka lasi,
\q2 o horodia taudia ihamauridia totona.
\q1 Kara dika tauna kwarana o moia patapata,
\q2 mamuna amo ela bona aiona o haberoa. (Selah)
\q1 
\v 14 Ena tuari taudia kwaradia o tarakidia uru;
\q2 idia na koe-hirihiri na heto igigi-rohorohogu totona ema,
\q2 idia na e moaleva, ogoḡami taudia bae ha-oredia hehuni eto.
\q1 
\v 15 Emu hosi aedia amo davara o moimoilaia,
\q2 abata badadia o moidia tao.
\b
\q1 
\v 16 Lau na kamonaimu, bena taugu e heude-heudemu,
\q2 rege bada dainai bibinagu e veverumu;
\q1 turiagu na e manoka-manokamu,
\q2 na raka mamanomu.
\q1 Asi reḡereḡegu hekwakwanai dinana baina naria,
\q2 eda tano bae tuari henia taudia latadiai baine kau dinana.
\b
\q1 
\v 17 Ena be suke auna basine burea,
\q2 bona vine audia huahuadia basie dobi,
\q1 ena be olvie auna na asi huahuana,
\q2 bona uma na asi anidia,
\q1 ena be mamoe bae mase ore edia maḡu ai,
\q2 bona boromakau rumana na asi boromakauna,
\q1 
\v 18 to lau ese Iehova baina moalelaia,
\q2 ihamaurigu Diravana baina moalelaia.
\q1 
\v 19 Ḡaubada Iehova na egu goada;
\q2 aegu na dia hahinena aena heḡereḡeredia ai e halaodiamu,
\q2 egu atai gabudia ai e harakagumu.
\b
\m (Ane-abi taudia biagudia ena: mai gitara reḡedia ida bae abia.) 
