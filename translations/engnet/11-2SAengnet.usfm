\v 19  \w Then|strong="H1696"\w* Abner \w spoke|strong="H1696"\w* privately \w with|strong="H1004"\w* \w the|strong="H3605"\w* \w Benjaminites|strong="H1144"\w*. Abner \w also|strong="H1571"\w* \w went|strong="H3212"\w* \w to|strong="H1696"\w* \w Hebron|strong="H2275"\w* \w to|strong="H1696"\w* inform \w David|strong="H1732"\w* privately \w of|strong="H1004"\w* \w all|strong="H3605"\w* \w that|strong="H3605"\w* \w Israel|strong="H3478"\w* \w and|strong="H3478"\w* \w the|strong="H3605"\w* \w entire|strong="H3605"\w* \w house|strong="H1004"\w* \w of|strong="H1004"\w* \w Benjamin|strong="H1144"\w* \w had|strong="H3478"\w* agreed \w to|strong="H1696"\w*.  
