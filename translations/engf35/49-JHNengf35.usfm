\s1 Jesus teaches in the Temple
\p 
\v 14 \w Now|strong="G1161"\w* \w when|strong="G1161"\w* \w the|strong="G2532"\w* \w feast|strong="G1859"\w* \w was|strong="G3588"\w* \w already|strong="G2235"\w* half \w over|strong="G1519"\w* \w Jesus|strong="G2424"\w* \w went|strong="G2424"\w* \w up|strong="G1519"\w* \w into|strong="G1519"\w* \w the|strong="G2532"\w* \w temple|strong="G2411"\w* \w and|strong="G2532"\w* started \w to|strong="G1519"\w* \w teach|strong="G1321"\w*.
