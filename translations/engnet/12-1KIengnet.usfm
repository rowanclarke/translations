\v 19  \w Now|strong="H6258"\w* \w send|strong="H7971"\w* \w out|strong="H7971"\w* \w messengers|strong="H6908"\w* \w and|strong="H3967"\w* \w assemble|strong="H6908"\w* \w all|strong="H3605"\w* \w Israel|strong="H3478"\w* before \w me|strong="H7971"\w* \w at|strong="H3478"\w* \w Mount|strong="H2022"\w* \w Carmel|strong="H3760"\w*, \w as|strong="H2022"\w* well \w as|strong="H2022"\w* \w the|strong="H3605"\w* 450 \w prophets|strong="H5030"\w* \w of|strong="H2022"\w* \w Baal|strong="H1168"\w* \w and|strong="H3967"\w* 400 \w prophets|strong="H5030"\w* \w of|strong="H2022"\w* Asherah whom Jezebel \w supports|strong="H7979"\w*.   
\p
