\v 15 Te \w phoeiah|strong="H9999"\w* tah \w anih|strong="H9907"\w* \w te|strong="H0853"\w* \w Amnon|strong="H0550"\w* loh lat a \w hnoel|strong="H8130"\w* tih a \w hmuhuetnah|strong="H8135"\w* \w bahoeng|strong="H1419"\w* a \w nah|strong="H3966"\w* pah. \w A|strong="H9907"\w* \w thiinah|strong="H8130"\w* vaengkah a \w hmuhuetnah|strong="H8135"\w* \w te|strong="H9998"\w* a \w lungnah|strong="H0157"\w* vaengkah \w lungnah|strong="H0160"\w* \w lakah|strong="H4480"\w* \w nah|strong="H1419"\w*. Te \w dongah|strong="H9999"\w* \w anih|strong="H9907"\w* \w te|strong="H9997"\w* \w Amnon|strong="H0550"\w* loh, “\w Thoo|strong="H6965"\w*, \w cet|strong="H1980"\w* laeh,” a \w ti|strong="H0559"\w* nah.
\p 
\v 16 \w Amnon|strong="H9909"\w* \w te|strong="H9997"\w*, “\w He|strong="H2063"\w* \w lakah|strong="H4480"\w* a \w tloe|strong="H0312"\w* \w la aka\w* \w len|strong="H1419"\w* \w boethae|strong="H7451"\w* kah a kong a \w mai|strong="H0182"\w* he a om \w moenih|strong="H0408"\w*. \w Kai|strong="H9901"\w* nan \w saii|strong="H6213"\w* tih nan \w haek|strong="H7971"\w* \w te|strong="H0834"\w*,” a \w ti|strong="H0559"\w* nah.
\p \w Tedae|strong="H9999"\w* \w anih|strong="H9907"\w* ol \w te|strong="H9997"\w* \w yaak|strong="H8085"\w* \w ngaih|strong="H0014"\w* voel \w pawh|strong="H3808"\w*.
\v 17 Te \w dongah|strong="H9999"\w* \w amah|strong="H9909"\w* aka \w khut|strong="H8334"\w* \w a|strong="H9909"\w* \w taengca|strong="H5288"\w* \w te|strong="H0853"\w*, “\w Anih|strong="H2063"\w* \w te|strong="H0853"\w* \w kai|strong="H9901"\w* \w taeng|strong="H5921"\w* \w lamloh|strong="H4480"\w* \w kawtpoeng|strong="H2351"\w* \w la|strong="H9911"\w* \w tueih|strong="H7971"\w* uh \w lamtah|strong="H9999"\w* \w anih|strong="H9907"\w* \w hnukah|strong="H0310"\w* \w thohkhaih|strong="H1817"\w* \w te|strong="H9998"\w* \w kalh|strong="H5274"\w* \w laeh|strong="H4994"\w*,” a \w ti|strong="H0559"\w* nah.
\p 
\v 18 Te \w vaengah|strong="H9999"\w* \w a|strong="H9907"\w* pum \w dongah|strong="H5921"\w* \w pendum|strong="H6446"\w* \w angkidung|strong="H3801"\w* a bai. \w Te|strong="H3651"\w* bang te \w manghai|strong="H4428"\w* \w canu|strong="H1323"\w* rhoek loh \w oila|strong="H1330"\w* kah \w hnikul|strong="H4598"\w* la a \w bai|strong="H3847"\w* uh. \w Amnon|strong="H9909"\w* aka \w khut|strong="H8334"\w* loh \w Tamar|strong="H9907"\w* \w te|strong="H0853"\w* \w vongvoel|strong="H2351"\w* la a \w thak|strong="H3318"\w* \w tih|strong="H9999"\w* \w a|strong="H9907"\w* \w hnukah|strong="H0310"\w* \w thohkhaih|strong="H1817"\w* \w te|strong="H9998"\w* kalh.
