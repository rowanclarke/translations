\b  
\c 4  
\p
\v 1 \w The|strong="H3588"\w* wife \w of|strong="H1121"\w* \w one|strong="H1121"\w* \w of|strong="H1121"\w* \w the|strong="H3588"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w the|strong="H3588"\w* \w prophets|strong="H5030"\w* \w appealed|strong="H6817"\w* \w to|strong="H4191"\w* Elisha, “\w My|strong="H3068"\w* husband, \w your|strong="H3068"\w* \w servant|strong="H5650"\w*, \w is|strong="H3068"\w* \w dead|strong="H4191"\w*, \w and|strong="H1121"\w* \w you|strong="H3588"\w* \w know|strong="H3045"\w* \w that|strong="H3588"\w* \w he|strong="H3588"\w* honored \w the|strong="H3588"\w* \w Lord|strong="H3068"\w*. \w But|strong="H3588"\w* \w now|strong="H1961"\w* \w to|strong="H4191"\w* \w pay|strong="H3045"\w* \w his|strong="H3068"\w* debts \w his|strong="H3068"\w* \w creditor|strong="H5383"\w* \w is|strong="H3068"\w* \w coming|strong="H5030"\w* \w to|strong="H4191"\w* \w take|strong="H3947"\w* \w my|strong="H3068"\w* \w two|strong="H8147"\w* \w sons|strong="H1121"\w* \w as|strong="H1961"\w* \w his|strong="H3068"\w* \w slaves|strong="H5650"\w*!”   
