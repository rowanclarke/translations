\c 10  
\p
\v 1  \w While|strong="H3588"\w* \w Ezra|strong="H5830"\w* \w was|strong="H3478"\w* \w praying|strong="H6419"\w* \w and|strong="H3478"\w* \w confessing|strong="H3034"\w*, \w weeping|strong="H1058"\w* \w and|strong="H3478"\w* throwing \w himself|strong="H6440"\w* \w to|strong="H3478"\w* \w the|strong="H6440"\w* \w ground|strong="H6440"\w* \w before|strong="H6440"\w* \w the|strong="H6440"\w* \w temple|strong="H1004"\w* \w of|strong="H1004"\w* God, \w a|strong="H3068"\w* \w very|strong="H3966"\w* \w large|strong="H7227"\w* \w crowd|strong="H6951"\w* \w of|strong="H1004"\w* \w Israelites|strong="H3478"\w* – \w men|strong="H3206"\w*, women, \w and|strong="H3478"\w* \w children|strong="H3206"\w* \w alike|strong="H6440"\w* – \w gathered|strong="H6908"\w* \w around|strong="H6440"\w* \w him|strong="H6440"\w*. \w The|strong="H6440"\w* \w people|strong="H5971"\w* \w wept|strong="H1058"\w* \w loudly|strong="H3966"\w*.  
\v 2  \w Then|strong="H6030"\w* \w Shecaniah|strong="H7935"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jehiel|strong="H3171"\w*, \w from|strong="H5921"\w* \w the|strong="H5921"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Elam|strong="H5867"\w*, addressed \w Ezra|strong="H5830"\w*:  
