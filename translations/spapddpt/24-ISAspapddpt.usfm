\toc1 Isaías
\mt1 Isaías
\c 1
\s1 Visión con respecto a Judá y Jerusalén
\p 
\v 1 \w Visión|strong="H2377"\w* \w de|strong="H5921"\w* \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Amoz, \w que|strong="H5921"\w* \w vio|strong="H2372"\w* \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* Jerusalén \w en|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* Uzías, Jotam, Acaz \w y|strong="H5921"\w* Ezequías, \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.
\p 
\v 2 ¡\w Oye|strong="H8085"\w*, \w cielo|strong="H8064"\w*, \w y|strong="H3588"\w* \w escucha|strong="H8085"\w* tú, tierra, \w porque|strong="H3588"\w* \w habla|strong="H1696"\w* \nd \w Yavé|strong="H3068"\w*\nd*! \wj \w Crié|strong="H1431"\w* \w hijos|strong="H1121"\w* \w y|strong="H3588"\w* \w los|strong="H1992"\w* desarrollé, \w pero|strong="H3588"\w* \w ellos|strong="H1992"\w* \w se|strong="H1992"\w* rebelaron contra \w Mí|strong="H1431"\w*.\wj*
\v 3 \wj El \w buey|strong="H7794"\w* \w conoce|strong="H3045"\w* \w a|strong="H3068"\w* su \w dueño|strong="H1167"\w*, \w y|strong="H7794"\w* el \w asno|strong="H2543"\w* el pesebre \w de|strong="H5971"\w* su amo, pero \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* me \w conoce|strong="H3045"\w*. Mi \w pueblo|strong="H5971"\w* \w no|strong="H3808"\w* \w tiene|strong="H7069"\w* entendimiento.\wj*
\p 
\v 4 ¡\w Oh|strong="H1945"\w* \w gente|strong="H1471"\w* \w pecadora|strong="H2398"\w*, \w pueblo|strong="H5971"\w* \w cargado|strong="H3515"\w* \w de|strong="H1121"\w* \w iniquidad|strong="H5771"\w*, \w generación|strong="H2233"\w* \w de|strong="H1121"\w* \w perversos|strong="H1121"\w*, \w hijos|strong="H1121"\w* \w depravados|strong="H7843"\w*! Abandonaron \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, despreciaron al \w Santo|strong="H6918"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w se|strong="H5971"\w* volvieron atrás.
\p 
\v 5 ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w aún|strong="H5750"\w* quieren ser castigados? ¿\w Aún|strong="H5750"\w* \w se|strong="H5921"\w* rebelarán? \w Toda|strong="H3605"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w está|strong="H5921"\w* enferma, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w corazón|strong="H3824"\w* \w doliente|strong="H1742"\w*.
\v 6 \w Desde|strong="H5704"\w* la planta del \w pie|strong="H7272"\w* \w hasta|strong="H5704"\w* la \w cabeza|strong="H7218"\w* \w nada|strong="H3808"\w* hay sano, \w sino|strong="H3808"\w* golpes, contusiones, \w y|strong="H5704"\w* \w heridas|strong="H4347"\w* supurantes. \w No|strong="H3808"\w* fueron drenadas, \w ni|strong="H3808"\w* \w vendadas|strong="H2280"\w*, \w ni|strong="H3808"\w* aliviadas \w con|strong="H5704"\w* \w ungüento|strong="H8081"\w*.
\p 
\v 7 Su tierra está \w asolada|strong="H8077"\w*, sus \w ciudades|strong="H5892"\w* incendiadas, su suelo devorado por extranjeros en presencia \w de|strong="H5048"\w* ustedes, \w asolada|strong="H8077"\w* como con desolación \w de|strong="H5048"\w* extraños.
\v 8 La \w hija|strong="H1323"\w* de \w Sion|strong="H6726"\w* \w quedó|strong="H3498"\w* como cobertizo de viñedo, como choza de melonar, como \w ciudad|strong="H5892"\w* sitiada.
\p 
\v 9 \w Si|strong="H3884"\w* \nd \w Yavé|strong="H3068"\w*\nd* de las huestes \w no|strong="H3884"\w* nos hubiera dejado un pequeño remanente, seríamos \w como|strong="H1961"\w* \w Sodoma|strong="H5467"\w*, semejantes \w a|strong="H3068"\w* \w Gomorra|strong="H6017"\w*.
\s1 Un llamado a cambiar
\p 
\v 10 ¡\w Escuchen|strong="H8085"\w* la \w Palabra|strong="H1697"\w* \w de|strong="H5971"\w* \nd \w Yavé|strong="H3068"\w*\nd*, gobernantes \w de|strong="H5971"\w* \w Sodoma|strong="H5467"\w*! ¡\w Escuchen|strong="H8085"\w* la \w Ley|strong="H8451"\w* \w de|strong="H5971"\w* nuestro \nd ʼElohim\nd*, \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* \w Gomorra|strong="H6017"\w*!
\v 11 \wj ¿\w De|strong="H1818"\w* \w qué|strong="H4100"\w* me sirve, \wj*dice \nd \w Yavé|strong="H3068"\w*\nd*, \wj \w la|strong="H7646"\w* \w multitud|strong="H7230"\w* \w de|strong="H1818"\w* sus \w sacrificios|strong="H2077"\w*? Estoy harto \w de|strong="H1818"\w* \w holocaustos|strong="H5930"\w* \w de|strong="H1818"\w* carneros y \w de|strong="H1818"\w* grasa \w de|strong="H1818"\w* ganado gordo. \w No|strong="H3808"\w* \w quiero|strong="H2654"\w* \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* \w becerros|strong="H6499"\w*, \w ni|strong="H3808"\w* \w de|strong="H1818"\w* \w corderos|strong="H3532"\w*, \w ni|strong="H3808"\w* \w de|strong="H1818"\w* machos cabríos. \wj*
\p 
\v 12 \wj ¿\w Quién|strong="H4310"\w* demanda \w esto|strong="H2063"\w* \w de|strong="H3588"\w* sus \w manos|strong="H3027"\w* \w cuando|strong="H3588"\w* \w los|strong="H3588"\w* presentan \w ante|strong="H6440"\w* \w Mí|strong="H1245"\w* \w y|strong="H3588"\w* pisotean mis \w patios|strong="H2691"\w*?\wj*
\v 13 \wj \w No|strong="H3808"\w* sigan presentando ofrendas \w vanas|strong="H7723"\w*. \w El|strong="H1931"\w* incienso me \w es|strong="H1931"\w* repugnancia, también las \w nuevas|strong="H2320"\w* lunas, \w los|strong="H1931"\w* \w sábados|strong="H7676"\w* y \w el|strong="H1931"\w* convocar asamblea. ¡\w No|strong="H3808"\w* tolero \w la|strong="H1931"\w* iniquidad junto con \w la|strong="H1931"\w* Asamblea Solemne!\wj*
\v 14 \wj \w Mi|strong="H5921"\w* \w alma|strong="H5315"\w* \w aborrece|strong="H8130"\w* sus \w nuevas|strong="H2320"\w* lunas \w y|strong="H5921"\w* sus \w solemnidades|strong="H4150"\w*. \w Me|strong="H5921"\w* \w son|strong="H1961"\w* molestas. \w Estoy|strong="H1961"\w* \w cansado|strong="H3811"\w* \w de|strong="H5921"\w* soportarlas.\wj*
\v 15 \wj \w Cuando|strong="H3588"\w* extiendan sus \w manos|strong="H3027"\w*, esconderé \w de|strong="H4480"\w* ustedes mi Presencia. \w Y|strong="H3068"\w* \w aunque|strong="H3588"\w* multipliquen sus oraciones, \w no|strong="H3588"\w* \w escucharé|strong="H8085"\w*. Sus \w manos|strong="H3027"\w* están \w llenas|strong="H4390"\w* \w de|strong="H4480"\w* \w sangre|strong="H1818"\w*.\wj*
\v 16 \wj Lávense, purifíquense, y quiten \w de|strong="H5048"\w* mi vista la \w maldad|strong="H7455"\w* \w de|strong="H5048"\w* sus \w obras|strong="H4611"\w*. \w Dejen|strong="H2308"\w* \w de|strong="H5048"\w* hacer el \w mal|strong="H7489"\w*.\wj*
\v 17 \wj Aprendan \w a|strong="H3068"\w* hacer lo bueno, busquen la \w justicia|strong="H4941"\w*. Reprendan al opresor, defiendan al \w huérfano|strong="H3490"\w*, aboguen por la viuda.\wj*
\p 
\v 18 \wj Vengan \w luego|strong="H4994"\w* y razonemos juntos, \wj*dice \nd \w Yavé|strong="H3068"\w*\nd*. \wj Aunque sus \w pecados|strong="H2399"\w* \w sean|strong="H1961"\w* \w como|strong="H1961"\w* la grana, \w como|strong="H1961"\w* la nieve \w serán|strong="H1961"\w* emblanquecidos. Aunque \w sean|strong="H1961"\w* rojos \w como|strong="H1961"\w* el carmesí, \w serán|strong="H1961"\w* \w como|strong="H1961"\w* \w lana|strong="H6785"\w* blanca.\wj*
\v 19 \wj Si ustedes quieren y \w obedecen|strong="H8085"\w*, comerán lo bueno de la tierra.\wj*
\v 20 \wj \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* rehúsan \w y|strong="H3588"\w* se rebelan, \w la|strong="H3588"\w* \w espada|strong="H2719"\w* \w los|strong="H3588"\w* devorará, \w porque|strong="H3588"\w* lo \w dijo|strong="H1696"\w* \w la|strong="H3588"\w* \w boca|strong="H6310"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \wj*
\s1 Amonestaciones y promesas
\p 
\v 21 ¡\w Cómo|strong="H1961"\w* \w se|strong="H1961"\w* convirtió en prostituta la \w Ciudad|strong="H7151"\w* Fiel! \w Estuvo|strong="H1961"\w* llena de equidad y en ella vivía la \w justicia|strong="H6664"\w*. Pero \w ahora|strong="H6258"\w* viven \w los|strong="H1961"\w* asesinos.
\v 22 Tu \w plata|strong="H3701"\w* \w se|strong="H1961"\w* volvió \w escoria|strong="H5509"\w*. Tu \w vino|strong="H1961"\w* \w está|strong="H1961"\w* \w mezclado|strong="H4107"\w* con \w agua|strong="H4325"\w*.
\v 23 Tus gobernantes \w son|strong="H3808"\w* rebeldes y cómplices \w de|strong="H8269"\w* \w ladrones|strong="H1590"\w*. \w Todos|strong="H3605"\w* aman \w el|strong="H3605"\w* \w soborno|strong="H7810"\w* y corren tras las dádivas. \w No|strong="H3808"\w* hacen justicia al \w huérfano|strong="H3490"\w* \w ni|strong="H3808"\w* llega \w a|strong="H3068"\w* \w ellos|strong="H3605"\w* \w la|strong="H3605"\w* \w causa|strong="H7379"\w* \w de|strong="H8269"\w* \w la|strong="H3605"\w* viuda.
\p 
\v 24 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* de las huestes, el Fuerte de \w Israel|strong="H3478"\w*, \w dice|strong="H5002"\w*: \wj ¡\w Ah|strong="H1945"\w*, \w tomaré|strong="H1945"\w* \w satisfacción|strong="H5162"\w* de mis \w enemigos|strong="H6862"\w*! ¡Me vengaré de mis \w enemigos|strong="H6862"\w*!\wj*
\v 25 \wj \w Volveré|strong="H7725"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*. Purificaré totalmente tus \w escorias|strong="H5509"\w* \w y|strong="H5921"\w* \w quitaré|strong="H5493"\w* \w toda|strong="H3605"\w* tu impureza.\wj*
\v 26 \wj Restauraré tus \w jueces|strong="H8199"\w* \w como|strong="H3651"\w* al principio y tus \w consejeros|strong="H3289"\w*, \w como|strong="H3651"\w* los de antaño. \w Entonces|strong="H7725"\w* te \w llamarán|strong="H7121"\w* \w Ciudad|strong="H5892"\w* de \w Justicia|strong="H6664"\w*, \w Ciudad|strong="H5892"\w* Fiel.\wj*
\p 
\v 27 \w Sion|strong="H6726"\w* será rescatada con equidad, y sus arrepentidos con \w justicia|strong="H6666"\w*.
\v 28 Pero los rebeldes y \w pecadores|strong="H2400"\w* serán \w juntamente|strong="H3162"\w* quebrantados, y los que \w abandonan|strong="H5800"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* serán consumidos.
\v 29 \w Entonces|strong="H3588"\w* se avergonzarán \w de|strong="H3588"\w* \w los|strong="H3588"\w* robles \w que|strong="H3588"\w* amaron \w y|strong="H3588"\w* tendrán afrenta \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w huertos|strong="H1593"\w* \w que|strong="H3588"\w* escogieron.
\v 30 \w Porque|strong="H3588"\w* \w serán|strong="H1961"\w* \w como|strong="H3588"\w* roble al \w cual|strong="H3588"\w* \w se|strong="H1961"\w* le \w cae|strong="H5034"\w* \w la|strong="H3588"\w* hoja \w y|strong="H3588"\w* \w como|strong="H3588"\w* huerto \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w tiene|strong="H1961"\w* \w agua|strong="H4325"\w*.
\v 31 El fuerte \w será|strong="H1961"\w* \w como|strong="H1961"\w* estopa, \w y|strong="H1197"\w* su \w obra|strong="H6467"\w* \w como|strong="H1961"\w* chispa. \w Ambos|strong="H8147"\w* arderán \w juntos|strong="H3162"\w*, \w y|strong="H1197"\w* \w no|strong="H1961"\w* \w habrá|strong="H1961"\w* quien \w los|strong="H1961"\w* apague.
\c 2
\s1 El reinado de \nd Yavé \nd*en la Tierra
\p 
\v 1 Visión \w que|strong="H5921"\w* tuvo \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Amoz, \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* Jerusalén:
\v 2 \w Acontecerá|strong="H1961"\w* en \w los|strong="H3605"\w* últimos \w días|strong="H3117"\w* \w que|strong="H3117"\w* \w la|strong="H3605"\w* Montaña de \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd \w Yavé|strong="H3068"\w*\nd* \w será|strong="H1961"\w* establecida \w como|strong="H1961"\w* cima de las montañas y \w se|strong="H1961"\w* \w alzará|strong="H5375"\w* \w sobre|strong="H1961"\w* las colinas. Acudirán \w a|strong="H3068"\w* \w ella|strong="H3605"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w*.
\p 
\v 3 \w Muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w* llegarán \w y|strong="H3588"\w* dirán: ¡\w Vengan|strong="H5927"\w*, \w subamos|strong="H5927"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* Montaña \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w Casa|strong="H1004"\w* del \nd ʼElohim\nd* \w de|strong="H3588"\w* \w Jacob|strong="H3290"\w*! \w Para|strong="H3588"\w* \w que|strong="H3588"\w* nos \w enseñe|strong="H3384"\w* \w con|strong="H3588"\w* respecto \w a|strong="H3068"\w* sus \w caminos|strong="H1870"\w*, \w y|strong="H3588"\w* nosotros caminemos \w en|strong="H3588"\w* sus sendas. \w Porque|strong="H3588"\w* \w de|strong="H3588"\w* \w Sion|strong="H6726"\w* \w saldrá|strong="H3318"\w* \w la|strong="H3588"\w* \w Ley|strong="H8451"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* Jerusalén \w la|strong="H3588"\w* \w Palabra|strong="H1697"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 4 Él \w juzgará|strong="H8199"\w* \w entre|strong="H3808"\w* las \w naciones|strong="H1471"\w*, y \w reprenderá|strong="H3198"\w* \w a|strong="H3068"\w* \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w*. \w De|strong="H5750"\w* sus \w espadas|strong="H2719"\w* forjarán rejas \w de|strong="H5750"\w* arado y \w de|strong="H5750"\w* sus lanzas, hoces. \w No|strong="H3808"\w* \w alzará|strong="H5375"\w* \w espada|strong="H2719"\w* \w nación|strong="H1471"\w* contra \w nación|strong="H1471"\w*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* adiestrarán \w más|strong="H5750"\w* \w para|strong="H5971"\w* la \w guerra|strong="H4421"\w*.
\p 
\v 5 ¡Oh \w casa|strong="H1004"\w* de \w Jacob|strong="H3290"\w*, vengan y caminemos \w a|strong="H3068"\w* la luz de \nd \w Yavé|strong="H3068"\w*\nd*!
\s1 Denuncia contra la infidelidad de Israel
\p 
\v 6 \w Porque|strong="H3588"\w* Tú abandonaste \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w*, \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Jacob|strong="H3290"\w*, \w porque|strong="H3588"\w* ellos están \w llenos|strong="H4390"\w* \w de|strong="H3588"\w* prácticas orientales. \w Son|strong="H3588"\w* \w agoreros|strong="H6049"\w* \w como|strong="H3588"\w* \w los|strong="H3588"\w* \w filisteos|strong="H6430"\w*, \w y|strong="H3588"\w* pactan \w con|strong="H3588"\w* \w los|strong="H3588"\w* \w hijos|strong="H3206"\w* \w de|strong="H3588"\w* extranjeros.
\v 7 Su tierra está \w llena|strong="H4390"\w* de \w plata|strong="H3701"\w* y \w oro|strong="H2091"\w*, y sus tesoros no tienen fin. También su tierra está \w llena|strong="H4390"\w* de \w caballos|strong="H5483"\w*, y sus carruajes son incontables.
\v 8 Su tierra también está \w llena|strong="H4390"\w* de ídolos. Se postran ante la \w obra|strong="H4639"\w* de sus \w manos|strong="H3027"\w*, ante \w lo|strong="H6213"\w* \w que|strong="H3027"\w* \w hicieron|strong="H6213"\w* sus dedos.
\v 9 Así el hombre se postró y el humano se rebajó. Pero no los \w perdones|strong="H5375"\w*.
\v 10 ¡Métete en la peña! ¡\w Escóndete|strong="H2934"\w* en el \w polvo|strong="H6083"\w* \w de|strong="H6440"\w* la terrible \w Presencia|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* y del resplandor \w de|strong="H6440"\w* su majestad!
\v 11 \w Los|strong="H1931"\w* \w ojos|strong="H5869"\w* altivos del hombre \w serán|strong="H1931"\w* abatidos y \w la|strong="H1931"\w* soberbia \w de|strong="H5869"\w* \w los|strong="H1931"\w* hombres \w será|strong="H1931"\w* humillada. \w Y|strong="H3068"\w* \w solo|strong="H1931"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w será|strong="H1931"\w* exaltado en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*.
\s1 La venida de \nd Yavé\nd* de las huestes
\p 
\v 12 \w Porque|strong="H3588"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes vendrá \w contra|strong="H5921"\w* \w todo|strong="H3605"\w* arrogante \w y|strong="H3588"\w* altivo \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w que|strong="H3588"\w* \w se|strong="H5921"\w* enalteció \w para|strong="H5921"\w* \w que|strong="H3588"\w* sea abatido,
\v 13 \w contra|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* cedros \w altos|strong="H7311"\w* \w y|strong="H5921"\w* erguidos \w del|strong="H5921"\w* \w Líbano|strong="H3844"\w* \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* robles \w de|strong="H5921"\w* \w Basán|strong="H1316"\w*,
\v 14 \w contra|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* altas montañas \w y|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* colinas \w elevadas|strong="H7311"\w*,
\v 15 \w contra|strong="H5921"\w* \w toda|strong="H3605"\w* \w torre|strong="H4026"\w* \w alta|strong="H1364"\w* \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w muro|strong="H2346"\w* fortificado,
\v 16 \w contra|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* naves \w de|strong="H5921"\w* \w Tarsis|strong="H8659"\w* \w y|strong="H5921"\w* \w toda|strong="H3605"\w* obra preciada \w de|strong="H5921"\w* arte.
\v 17 \w La|strong="H1931"\w* altivez del hombre \w será|strong="H1931"\w* \w abatida|strong="H8213"\w*. \w La|strong="H1931"\w* soberbia de \w los|strong="H1931"\w* hombres \w será|strong="H1931"\w* humillada. \w Solo|strong="H1931"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w será|strong="H1931"\w* exaltado en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*,
\v 18 y los ídolos desaparecerán por completo.
\v 19 Se meterán en las \w cuevas|strong="H4631"\w* \w de|strong="H6440"\w* las peñas y en las aberturas \w de|strong="H6440"\w* la \w tierra|strong="H6083"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* la temible \w Presencia|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* y del resplandor \w de|strong="H6440"\w* su majestad cuando Él se levante para sacudir terriblemente la \w tierra|strong="H6083"\w*.
\p 
\v 20 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w el|strong="H1931"\w* hombre echará \w a|strong="H3068"\w* \w los|strong="H1931"\w* topos y \w a|strong="H3068"\w* \w los|strong="H1931"\w* murciélagos, \w sus|strong="H1931"\w* ídolos de \w plata|strong="H3701"\w* y \w sus|strong="H1931"\w* ídolos de \w oro|strong="H2091"\w* \w que|strong="H1931"\w* \w se|strong="H1931"\w* \w hicieron|strong="H6213"\w* para adorar.
\v 21 Se meterá en las hendiduras \w de|strong="H6440"\w* las rocas y en las cavernas \w de|strong="H6440"\w* las peñas \w a|strong="H3068"\w* \w causa|strong="H6440"\w* del \w Terror|strong="H6343"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* y del resplandor \w de|strong="H6440"\w* su majestad, cuando Él se levante para sacudir poderosamente la tierra.
\p 
\v 22 \w Dejen|strong="H2308"\w* \w de|strong="H4480"\w* confiar \w en|strong="H4480"\w* \w el|strong="H1931"\w* hombre. \w Su|strong="H1931"\w* aliento \w está|strong="H1931"\w* \w en|strong="H4480"\w* \w su|strong="H1931"\w* nariz. \w Así|strong="H3588"\w* \w que|strong="H3588"\w* ¿\w de|strong="H4480"\w* \w qué|strong="H3588"\w* \w estima|strong="H2803"\w* \w es|strong="H1931"\w* digno?
\c 3
\s1 Desgracia de Judá y Jerusalén
\p 
\v 1 \w Porque|strong="H3588"\w* \w ciertamente|strong="H3588"\w* \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* \w de|strong="H3588"\w* las huestes \w aparta|strong="H5493"\w* \w de|strong="H3588"\w* Jerusalén \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w toda|strong="H3605"\w* provisión \w y|strong="H3588"\w* apoyo, \w toda|strong="H3605"\w* provisión \w de|strong="H3588"\w* \w pan|strong="H3899"\w* \w y|strong="H3588"\w* \w toda|strong="H3605"\w* provisión \w de|strong="H3588"\w* \w agua|strong="H4325"\w*,
\v 2 al \w poderoso|strong="H1368"\w* y al guerrero, al \w juez|strong="H8199"\w* y al \w profeta|strong="H5030"\w*, al \w adivino|strong="H7080"\w* y al \w anciano|strong="H2205"\w*,
\v 3 al \w capitán|strong="H8269"\w* \w de|strong="H6440"\w* 50, al honorable, al \w consejero|strong="H3289"\w*, al \w excelente|strong="H2450"\w* artesano y al práctico encantador.
\v 4 Les designaré muchachos como gobernantes, y la arbitrariedad los dominará.
\v 5 Brotará entre \w el|strong="H5065"\w* \w pueblo|strong="H5971"\w* la violencia \w de|strong="H5971"\w* unos contra otros, cada uno contra su \w compañero|strong="H7453"\w*. \w El|strong="H5065"\w* joven \w se|strong="H5971"\w* levantará contra \w el|strong="H5065"\w* \w anciano|strong="H2205"\w* y \w el|strong="H5065"\w* inferior contra \w el|strong="H5065"\w* honorable.
\p 
\v 6 \w Cuando|strong="H3588"\w* alguno tome \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* hermano \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* padre \w y|strong="H3588"\w* le diga: Tú tienes \w ropa|strong="H8071"\w*, \w sé|strong="H1961"\w* nuestro gobernante \w y|strong="H3588"\w* toma \w esta|strong="H2063"\w* ruina \w en|strong="H3588"\w* tus \w manos|strong="H3027"\w*.
\v 7 \w Él|strong="H1931"\w* \w alzará|strong="H5375"\w* \w su|strong="H1931"\w* voz en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*: \w No|strong="H3808"\w* \w seré|strong="H1961"\w* \w su|strong="H1931"\w* médico, \w porque|strong="H3808"\w* en \w mi|strong="H1961"\w* \w casa|strong="H1004"\w* \w no|strong="H3808"\w* \w hay|strong="H1961"\w* \w pan|strong="H3899"\w* \w ni|strong="H3808"\w* \w ropa|strong="H8071"\w*. \w No|strong="H3808"\w* deben designarme \w como|strong="H1961"\w* gobernador del \w pueblo|strong="H5971"\w*.
\v 8 \w Porque|strong="H3588"\w* Jerusalén se derrumbó \w y|strong="H3588"\w* \w Judá|strong="H3063"\w* \w cayó|strong="H5307"\w*, \w pues|strong="H3588"\w* sus palabras \w y|strong="H3588"\w* \w hechos|strong="H4611"\w* \w son|strong="H3588"\w* contra \nd \w Yavé|strong="H3068"\w*\nd* \w para|strong="H3588"\w* provocar \w los|strong="H3588"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* majestad.
\p 
\v 9 \w La|strong="H3588"\w* expresión \w de|strong="H3588"\w* \w sus|strong="H1992"\w* semblantes atestigua \w contra|strong="H6440"\w* \w ellos|strong="H1992"\w*, \w porque|strong="H3588"\w* \w como|strong="H3588"\w* \w Sodoma|strong="H5467"\w* despliegan \w su|strong="H1992"\w* \w pecado|strong="H2403"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* disimulan. ¡Ay \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*, \w porque|strong="H3588"\w* trajeron \w la|strong="H3588"\w* desgracia sobre \w ellos|strong="H1992"\w* \w mismos|strong="H1992"\w*!
\v 10 \wj Digan \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w justos|strong="H6662"\w* \w que|strong="H3588"\w* les irá \w bien|strong="H2896"\w*, \w porque|strong="H3588"\w* comerán del \w fruto|strong="H6529"\w* \w de|strong="H3588"\w* sus \w obras|strong="H4611"\w*.\wj*
\v 11 \wj ¡Ay \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w impíos|strong="H7563"\w*! Les irá \w mal|strong="H7451"\w*, \w porque|strong="H3588"\w* las obras \w de|strong="H3588"\w* sus \w manos|strong="H3027"\w* serán \w su|strong="H3588"\w* recompensa.\wj*
\v 12 \wj Los opresores \w de|strong="H5971"\w* mi \w pueblo|strong="H5971"\w* son muchachos, y mujeres \w se|strong="H5971"\w* enseñorean \w de|strong="H5971"\w* \w él|strong="H5065"\w*. \w Pueblo|strong="H5971"\w* \w mío|strong="H5971"\w*, los \w que|strong="H5971"\w* te guían te \w engañan|strong="H8582"\w* y tuercen \w el|strong="H5065"\w* rumbo \w de|strong="H5971"\w* tus \w caminos|strong="H1870"\w*.\wj*
\p 
\v 13 \wj \nd \w Yavé|strong="H3068"\w*\nd* \w está|strong="H5324"\w* \w en|strong="H5975"\w* \w pie|strong="H5975"\w* \w para|strong="H5971"\w* litigar, y \w para|strong="H5971"\w* juzgar \w a|strong="H3068"\w* los \w pueblos|strong="H5971"\w*.\wj*
\v 14 \wj \nd \w Yavé|strong="H3068"\w*\nd* vendrá \w a|strong="H3068"\w* \w juicio|strong="H4941"\w* \w contra|strong="H5973"\w* \w los|strong="H5973"\w* \w ancianos|strong="H2205"\w* \w y|strong="H1197"\w* gobernantes \w de|strong="H5973"\w* su \w pueblo|strong="H5971"\w*. Porque ustedes devoraron \w la|strong="H1197"\w* \w viña|strong="H3754"\w*, \w y|strong="H1197"\w* \w el|strong="H5973"\w* despojo \w para|strong="H5973"\w* \w el|strong="H5973"\w* \w pobre|strong="H6041"\w* está \w en|strong="H5973"\w* sus \w casas|strong="H1004"\w*.\wj*
\v 15 \wj ¿Cuáles motivos tienen \w para|strong="H5971"\w* aplastar \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w* y moler los semblantes \w de|strong="H6440"\w* los pobres?\wj* Palabra \w de|strong="H6440"\w* \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* \w de|strong="H6440"\w* las huestes.
\s1 Vergüenza para las hijas de Sion
\p 
\v 16 \w Además|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* dice: \wj \w Porque|strong="H3588"\w* las \w hijas|strong="H1323"\w* \w de|strong="H3588"\w* \w Sion|strong="H6726"\w* \w son|strong="H3588"\w* orgullosas \w y|strong="H3588"\w* \w caminan|strong="H1980"\w* \w con|strong="H3588"\w* cabezas altas \w y|strong="H3588"\w* \w ojos|strong="H5869"\w* seductores, \w andan|strong="H1980"\w* \w con|strong="H3588"\w* pasitos amanerados \w y|strong="H3588"\w* hacen sonar las argollas \w que|strong="H3588"\w* \w llevan|strong="H3212"\w* sobre sus \w pies|strong="H7272"\w*.\wj*
\v 17 \wj Cubrirá con costras las coronillas de las \w hijas|strong="H1323"\w* de \w Sion|strong="H6726"\w*. \nd \w Yavé|strong="H3068"\w*\nd* hará \w que|strong="H1323"\w* estén desnudas.\wj*
\p 
\v 18 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \nd ʼAdonay\nd* \w quitará|strong="H5493"\w* las argollas y las lunetas de \w sus|strong="H1931"\w* tobillos,
\v 19 los aretes, los brazaletes, las pulseras, los velos,
\v 20 las tocas, las cadenillas tobilleras, las fajas, los pomos de perfume, los amuletos,
\v 21 los \w anillos|strong="H2885"\w*, las narigueras,
\v 22 las ropas festivas, los mantos, los chales, los bolsos,
\v 23 los espejos, las capas internas de lino, las tiaras y las mantillas.
\v 24 \w Sucederá|strong="H1961"\w* \w que|strong="H1961"\w* \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* perfume \w habrá|strong="H1961"\w* \w hediondez|strong="H4716"\w*; \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* cinturón, cuerda; \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* trenza, calvicie; \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* amplio manto, tela áspera, y \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* \w hermosura|strong="H3308"\w*, cicatriz.
\s1 Otras consecuencias desastrosas
\p 
\v 25 Tus varones y tus poderosos en la \w batalla|strong="H4421"\w* \w caerán|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*.
\v 26 Sus \w puertas|strong="H6607"\w* se entristecerán y se enlutarán. Desolada se sentará en la tierra.
\c 4
\p 
\v 1 \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H3117"\w* \w siete|strong="H7651"\w* mujeres echarán \w mano|strong="H1931"\w* \w a|strong="H3068"\w* un hombre \w y|strong="H5921"\w* \w le|strong="H1931"\w* dirán: Nosotras comeremos nuestro \w pan|strong="H3899"\w* \w y|strong="H5921"\w* vestiremos nuestras \w ropas|strong="H8071"\w*. \w Solamente|strong="H7535"\w* permítenos llevar tu \w nombre|strong="H8034"\w*. Quita nuestro \w oprobio|strong="H2781"\w*.
\s1 La gloria de Jerusalén
\p 
\v 2 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w el|strong="H1931"\w* \w Renuevo|strong="H6780"\w* de \nd \w Yavé|strong="H3068"\w*\nd* \w será|strong="H1961"\w* espléndido \w y|strong="H3519"\w* \w glorioso|strong="H3519"\w*. \w El|strong="H1931"\w* \w fruto|strong="H6529"\w* de \w la|strong="H1931"\w* tierra excelente \w y|strong="H3519"\w* \w hermoso|strong="H8597"\w* \w para|strong="H1961"\w* \w los|strong="H1931"\w* salvados de \w Israel|strong="H3478"\w*.
\v 3 \w Sucederá|strong="H1961"\w* \w que|strong="H1961"\w* \w los|strong="H3605"\w* \w que|strong="H1961"\w* queden en \w Sion|strong="H6726"\w*, \w los|strong="H3605"\w* \w que|strong="H1961"\w* \w sean|strong="H1961"\w* dejados en Jerusalén, \w serán|strong="H1961"\w* llamados \w santos|strong="H6918"\w*, \w los|strong="H3605"\w* inscritos entre \w los|strong="H3605"\w* \w vivos|strong="H2416"\w* en Jerusalén.
\v 4 Cuando \nd ʼAdonay\nd* lave \w la|strong="H1197"\w* suciedad \w de|strong="H1818"\w* las \w hijas|strong="H1323"\w* \w de|strong="H1818"\w* \w Sion|strong="H6726"\w* \w y|strong="H1197"\w* limpie \w la|strong="H1197"\w* \w sangre|strong="H1818"\w* derramada \w dentro|strong="H7130"\w* \w de|strong="H1818"\w* Jerusalén con un \w viento|strong="H7307"\w* justiciero, con \w soplo|strong="H7307"\w* devastador,
\v 5 \nd \w Yavé|strong="H3068"\w*\nd* creará una \w nube|strong="H6051"\w* \w de|strong="H5921"\w* \w humo|strong="H6227"\w* \w de|strong="H5921"\w* \w día|strong="H3119"\w* \w y|strong="H3588"\w* un fuego llameante \w de|strong="H5921"\w* \w noche|strong="H3915"\w* \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w toda|strong="H3605"\w* morada \w en|strong="H5921"\w* \w la|strong="H5921"\w* Montaña \w Sion|strong="H6726"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* sus \w asambleas|strong="H4744"\w*, \w porque|strong="H3588"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* habrá una cubierta \w de|strong="H5921"\w* \w gloria|strong="H3519"\w*.
\v 6 \w Habrá|strong="H1961"\w* una cubierta \w para|strong="H1961"\w* dar \w sombra|strong="H6738"\w* \w contra|strong="H1961"\w* el calor del \w día|strong="H3119"\w*, refugio y escondedero de la tormenta, protección de la tormenta, de la inundación y del aguacero.
\c 5
\s1 La viña de \nd Yavé\nd*
\p 
\v 1 \w Cantaré|strong="H7891"\w* en Nombre \w de|strong="H1121"\w* \w mi|strong="H1961"\w* \w Amado|strong="H1730"\w* un \w canto|strong="H7891"\w* \w de|strong="H1121"\w* amor con respecto \w a|strong="H3068"\w* su \w viña|strong="H3754"\w*. \w Tuvo|strong="H1961"\w* \w mi|strong="H1961"\w* \w Amado|strong="H1730"\w* una \w viña|strong="H3754"\w* en una colina \w fértil|strong="H8081"\w*.
\v 2 \w La|strong="H1571"\w* cavó, despedregó \w y|strong="H1571"\w* \w plantó|strong="H5193"\w* una preciada cepa. Construyó una \w torre|strong="H4026"\w* \w en|strong="H8432"\w* su centro \w y|strong="H1571"\w* cavó \w en|strong="H8432"\w* ella un \w lagar|strong="H3342"\w*. \w Esperó|strong="H6960"\w* \w que|strong="H1571"\w* diera \w uvas|strong="H6025"\w*, pero dio \w uvas|strong="H6025"\w* silvestres.
\p 
\v 3 \wj \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, oh \w habitantes|strong="H3427"\w* de Jerusalén y varones de \w Judá|strong="H3063"\w*, juzguen entre \w Mí|strong="H3389"\w* y \w mi|strong="H3389"\w* \w viña|strong="H3754"\w*.\wj*
\v 4 \wj ¿\w Qué|strong="H4100"\w* \w más|strong="H5750"\w* \w se|strong="H3808"\w* \w podía|strong="H3808"\w* \w hacer|strong="H6213"\w* \w a|strong="H3068"\w* mi \w viña|strong="H3754"\w* \w que|strong="H4100"\w* \w Yo|strong="H6213"\w* \w no|strong="H3808"\w* \w hice|strong="H6213"\w* \w en|strong="H5750"\w* ella? ¿\w Por|strong="H4069"\w* \w qué|strong="H4100"\w* \w cuando|strong="H4100"\w* \w esperaba|strong="H6960"\w* \w que|strong="H4100"\w* diera \w uvas|strong="H6025"\w* dio \w uvas|strong="H6025"\w* silvestres?\wj*
\v 5 \wj Les mostraré, \w pues|strong="H4994"\w*, \w lo|strong="H6213"\w* \w que|strong="H6258"\w* \w haré|strong="H6213"\w* con \w mi|strong="H1961"\w* \w viña|strong="H3754"\w*. Le \w quitaré|strong="H5493"\w* su cerco de tierra apisonada \w para|strong="H1961"\w* \w que|strong="H6258"\w* sirva de pasto. Derribaré su cerca \w para|strong="H1961"\w* \w que|strong="H6258"\w* \w sea|strong="H1961"\w* pisoteada.\wj*
\v 6 \wj \w La|strong="H5921"\w* dejaré desolada. \w No|strong="H3808"\w* \w será|strong="H3808"\w* podada \w ni|strong="H3808"\w* labrada. \w Le|strong="H5921"\w* \w crecerán|strong="H5927"\w* \w las|strong="H5921"\w* zarzas \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w espinos|strong="H8068"\w*. \w Mandaré|strong="H6680"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w nubes|strong="H5645"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* lluevan \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w*.\wj*
\v 7 \w Ciertamente|strong="H3588"\w* \w la|strong="H3588"\w* \w viña|strong="H3754"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H3588"\w* las huestes \w es|strong="H3588"\w* \w la|strong="H3588"\w* \w Casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w y|strong="H3588"\w* \w los|strong="H3588"\w* hombres \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w su|strong="H3588"\w* \w planta|strong="H5194"\w* deliciosa. \add \nd Yavé\nd*\add* \w esperaba|strong="H6960"\w* equidad, \w pero|strong="H3588"\w* ve derramamiento \w de|strong="H3588"\w* sangre. \add Esperaba\add* \w justicia|strong="H6666"\w*, \w pero|strong="H3588"\w* oye un \w clamor|strong="H6818"\w* \w de|strong="H3588"\w* aflicción.
\s1 Seis ayes
\p 
\v 8 ¡\w Ay|strong="H1945"\w* \w de|strong="H5704"\w* \w los|strong="H3427"\w* \w que|strong="H5704"\w* juntan \w casa|strong="H1004"\w* \w con|strong="H5060"\w* \w casa|strong="H1004"\w* \w y|strong="H5704"\w* unen \w campo|strong="H7704"\w* \w con|strong="H5060"\w* \w campo|strong="H7704"\w*, \w hasta|strong="H5704"\w* ocuparlo todo \w y|strong="H5704"\w* viven ustedes solos \w en|strong="H5704"\w* \w medio|strong="H7130"\w* \w de|strong="H5704"\w* la tierra!
\v 9 \nd \w Yavé|strong="H3068"\w*\nd* de las huestes dijo \w a|strong="H3068"\w* mis oídos: \wj Sus \w muchas|strong="H7227"\w* \w casas|strong="H1004"\w* \w serán|strong="H1961"\w* arrasadas. Sus magníficos palacios \w quedarán|strong="H3427"\w* desolados.\wj*
\v 10 \wj \w Diez|strong="H6235"\w* yugadas \w de|strong="H3588"\w* \w viña|strong="H3754"\w* \w producirán|strong="H6213"\w* 22 litros, \w y|strong="H3588"\w* 220 kilogramos \w de|strong="H3588"\w* semilla producirá 22 litros \w de|strong="H3588"\w* grano.\wj*
\p 
\v 11 ¡\w Ay|strong="H1945"\w* de \w los|strong="H7291"\w* que se levantan temprano por la \w mañana|strong="H1242"\w* \w a|strong="H3068"\w* buscar \w bebida|strong="H7941"\w* fuerte y se quedan hasta la noche, hasta que \w los|strong="H7291"\w* enciende el \w vino|strong="H3196"\w*!
\v 12 Todo \w es|strong="H1961"\w* \w arpa|strong="H3658"\w* y \w salterio|strong="H5035"\w*, flauta y tamboril, y \w vino|strong="H3196"\w* en sus \w banquetes|strong="H4960"\w*, pero \w no|strong="H3808"\w* \w consideran|strong="H7200"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* dijo \nd \w Yavé|strong="H3068"\w*\nd*, \w ni|strong="H3808"\w* \w miran|strong="H5027"\w* la \w obra|strong="H4639"\w* \w de|strong="H5035"\w* sus \w manos|strong="H3027"\w*.
\v 13 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, mi \w pueblo|strong="H5971"\w* \w va|strong="H3068"\w* \w a|strong="H3068"\w* cautividad \w por|strong="H3651"\w* falta \w de|strong="H5971"\w* entendimiento. Sus \w hombres|strong="H4962"\w* honorables perecen \w de|strong="H5971"\w* \w hambre|strong="H7458"\w* \w y|strong="H3519"\w* su \w multitud|strong="H1995"\w* \w se|strong="H3651"\w* seca \w de|strong="H5971"\w* \w sed|strong="H6772"\w*.
\v 14 \w Por|strong="H3651"\w* \w eso|strong="H3651"\w* el \tl Seol\tl* \w ensancha|strong="H7337"\w* las \w partes|strong="H6310"\w* posteriores de su paladar y abre su \w boca|strong="H6310"\w* \w sin|strong="H1097"\w* medida. Allá \w baja|strong="H3381"\w* el esplendor de ellos, su \w multitud|strong="H1995"\w* y su alborozo, y el \w que|strong="H6310"\w* \w se|strong="H3651"\w* regocija en ello.
\v 15 Se \w humilla|strong="H8213"\w* el hombre. Es abatido el varón. Son bajados los \w ojos|strong="H5869"\w* altivos.
\v 16 Pero \nd \w Yavé|strong="H3068"\w*\nd* de las huestes será exaltado en el \w juicio|strong="H4941"\w*, el \w Santo|strong="H6918"\w* \nd ʼEL\nd* mostrará su \w justicia|strong="H6666"\w*.
\v 17 Los \w corderos|strong="H3532"\w* pastarán como en sus propios pastizales. Forasteros y extranjeros comerán en los campos abandonados por los ricos.
\p 
\v 18 ¡\w Ay|strong="H1945"\w* de los que arrastran la \w iniquidad|strong="H5771"\w* con \w cuerdas|strong="H5688"\w* de \w vanidad|strong="H7723"\w*, y el \w pecado|strong="H2403"\w* con \w sogas|strong="H2256"\w* de carretas!
\v 19 \w Que|strong="H3045"\w* dicen: ¡Venga ya, \w apresúrese|strong="H2363"\w* su \w obra|strong="H4639"\w* \w para|strong="H4616"\w* \w que|strong="H3045"\w* la \w veamos|strong="H7200"\w*! ¡\w Que|strong="H3045"\w* \w se|strong="H3045"\w* cumpla ya el plan del \w Santo|strong="H6918"\w* de \w Israel|strong="H3478"\w* \w para|strong="H4616"\w* \w que|strong="H3045"\w* lo comprobemos!
\v 20 ¡\w Ay|strong="H1945"\w* \w de|strong="H7451"\w* los que \w a|strong="H3068"\w* lo \w malo|strong="H7451"\w* llaman \w bueno|strong="H2896"\w*, y \w a|strong="H3068"\w* lo \w bueno|strong="H2896"\w*, \w malo|strong="H7451"\w*, que sustituyen la luz por la \w oscuridad|strong="H2822"\w* y la \w oscuridad|strong="H2822"\w* por la luz, que presentan lo \w amargo|strong="H4751"\w* como \w dulce|strong="H4966"\w* y lo \w dulce|strong="H4966"\w* como \w amargo|strong="H4751"\w*!
\v 21 ¡\w Ay|strong="H1945"\w* \w de|strong="H6440"\w* \w los|strong="H2450"\w* que se consideran \w sabios|strong="H2450"\w*, y \w de|strong="H6440"\w* \w los|strong="H2450"\w* prudentes \w ante|strong="H6440"\w* sus propios \w ojos|strong="H5869"\w*!
\v 22 ¡\w Ay|strong="H1945"\w* de los \w valientes|strong="H1368"\w* para \w beber|strong="H8354"\w* \w vino|strong="H3196"\w*, y de los \w fuertes|strong="H2428"\w* para mezclar \w bebida|strong="H7941"\w* \w fuerte|strong="H1368"\w*,
\v 23 \w de|strong="H4480"\w* los \w que|strong="H4480"\w* \w por|strong="H4480"\w* \w soborno|strong="H7810"\w* absuelven \w al|strong="H4480"\w* culpable, y \w a|strong="H3068"\w* los inocentes les \w quitan|strong="H5493"\w* sus derechos!
\p 
\v 24 \w Porque|strong="H3588"\w* \w como|strong="H3588"\w* \w la|strong="H3588"\w* \w lengua|strong="H3956"\w* \w de|strong="H3588"\w* fuego \w devora|strong="H7503"\w* \w el|strong="H3588"\w* pasto \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w rastrojo|strong="H7179"\w* \w se|strong="H1961"\w* consume \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w llama|strong="H3852"\w*, \w se|strong="H1961"\w* pudrirá \w su|strong="H3588"\w* raíz \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w flor|strong="H6525"\w* \w se|strong="H1961"\w* desvanecerá \w como|strong="H3588"\w* \w el|strong="H3588"\w* polvo, \w porque|strong="H3588"\w* \w desecharon|strong="H3988"\w* \w la|strong="H3588"\w* \w Ley|strong="H8451"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H3588"\w* las huestes \w y|strong="H3588"\w* despreciaron \w la|strong="H3588"\w* Palabra del \w Santo|strong="H6918"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.
\v 25 \w Por|strong="H5921"\w* \w esta|strong="H2063"\w* causa \w la|strong="H5921"\w* ira \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w se|strong="H1961"\w* encendió \w contra|strong="H5921"\w* su \w pueblo|strong="H5971"\w*, \w extiende|strong="H5186"\w* su \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w lo|strong="H3808"\w* \w hiere|strong="H5221"\w*. \w Las|strong="H5921"\w* montañas \w se|strong="H1961"\w* estremecen \w y|strong="H5921"\w* sus cadáveres \w están|strong="H1961"\w* tendidos \w en|strong="H5921"\w* \w la|strong="H5921"\w* calle. \w A|strong="H3068"\w* pesar \w de|strong="H5921"\w* \w todo|strong="H3605"\w*, \w no|strong="H3808"\w* \w se|strong="H1961"\w* aplaca su ira. Su \w mano|strong="H3027"\w* sigue \w extendida|strong="H5186"\w*.
\p 
\v 26 \w Alzará|strong="H5375"\w* \w pendón|strong="H5251"\w* \w a|strong="H3068"\w* una \w nación|strong="H1471"\w* distante. \w Silbará|strong="H8319"\w* para ello desde los fines de la tierra: ¡Miren cómo viene rápida y veloz!
\v 27 \w Nadie|strong="H3808"\w* \w se|strong="H3808"\w* cansa \w ni|strong="H3808"\w* tropieza. \w Ninguno|strong="H3808"\w* \w se|strong="H3808"\w* acuesta \w ni|strong="H3808"\w* \w se|strong="H3808"\w* \w duerme|strong="H3462"\w*. \w No|strong="H3808"\w* \w se|strong="H3808"\w* le afloja el cinturón de su cintura, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* le rompe la correa de su sandalia.
\v 28 Sus flechas están afiladas y \w todos|strong="H3605"\w* sus \w arcos|strong="H7198"\w* \w entesados|strong="H1869"\w*. \w Los|strong="H3605"\w* cascos de sus \w caballos|strong="H5483"\w* son pedernal, y las ruedas de sus carruajes como tempestad.
\v 29 Su rugido es de león. Ruge \w como|strong="H3715"\w* los leoncillos. Gruñe, atrapa la presa y la retiene. Nadie se la arrebata.
\v 30 Rugirá \w sobre|strong="H5921"\w* \w él|strong="H1931"\w* \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w como|strong="H5921"\w* rugido \w del|strong="H5921"\w* \w mar|strong="H3220"\w*. \w Si|strong="H1931"\w* uno \w mira|strong="H5027"\w* \w la|strong="H1931"\w* tierra, \w ciertamente|strong="H2009"\w* hay \w oscuridad|strong="H2822"\w* \w y|strong="H5921"\w* \w aflicción|strong="H6862"\w*. Aun \w la|strong="H1931"\w* luz \w es|strong="H1931"\w* oscurecida \w por|strong="H5921"\w* \w sus|strong="H1931"\w* nubes.
\c 6
\s1 Visión y comisión para Isaías
\p 
\v 1 \w El|strong="H5921"\w* \w año|strong="H8141"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w muerte|strong="H4194"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* Uzías \w vi|strong="H7200"\w* \w a|strong="H3068"\w* \nd ʼAdonay\nd* \w sentado|strong="H3427"\w* \w sobre|strong="H5921"\w* un \w trono|strong="H3678"\w* \w alto|strong="H7311"\w* \w y|strong="H5921"\w* excelso, \w y|strong="H5921"\w* sus ropas llenaban \w el|strong="H5921"\w* \w Templo|strong="H1964"\w*.
\v 2 \w Por|strong="H6440"\w* \w encima|strong="H4605"\w* \w de|strong="H6440"\w* Él \w había|strong="H5975"\w* \w serafines|strong="H8314"\w*. Cada uno tenía \w seis|strong="H8337"\w* \w alas|strong="H3671"\w*: con \w dos|strong="H8147"\w* \w cubrían|strong="H3680"\w* sus \w rostros|strong="H6440"\w*, con \w dos|strong="H8147"\w* \w cubrían|strong="H3680"\w* sus \w pies|strong="H7272"\w* y con \w dos|strong="H8147"\w* \w volaban|strong="H5774"\w*.
\v 3 \w El|strong="H3605"\w* uno proclamaba al \w otro|strong="H2088"\w*: ¡\w Santo|strong="H6918"\w*, \w Santo|strong="H6918"\w*, \w Santo|strong="H6918"\w*, \nd \w Yavé|strong="H3068"\w*\nd* de las huestes! ¡\w Toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w está|strong="H2088"\w* \w llena|strong="H4393"\w* de su \w gloria|strong="H3519"\w*!
\v 4 Los postes de las puertas se estremecían con la \w voz|strong="H6963"\w* del que proclamaba, y el \w Templo|strong="H1004"\w* se saturó de \w humo|strong="H6227"\w*.
\v 5 \w Entonces|strong="H3588"\w* dije: ¡Ay \w de|strong="H3588"\w* mí \w porque|strong="H3588"\w* estoy muerto! \w Porque|strong="H3588"\w* soy hombre \w de|strong="H3588"\w* \w labios|strong="H8193"\w* impuros. Vivo \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* un \w pueblo|strong="H5971"\w* \w que|strong="H3588"\w* tiene \w labios|strong="H8193"\w* impuros. ¡\w Y|strong="H3068"\w* mis \w ojos|strong="H5869"\w* \w vieron|strong="H7200"\w* \w al|strong="H4428"\w* \w Rey|strong="H4428"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H3588"\w* las huestes!
\p 
\v 6 Pero uno \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w serafines|strong="H8314"\w* voló \w hacia|strong="H5921"\w* \w mí|strong="H5921"\w* \w con|strong="H5921"\w* un carbón encendido \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w*, \w el|strong="H5921"\w* cual \w tomó|strong="H3947"\w* \w del|strong="H4480"\w* \w altar|strong="H4196"\w* \w con|strong="H5921"\w* unas tenazas.
\v 7 \w Tocó|strong="H5060"\w* \w mi|strong="H5921"\w* \w boca|strong="H6310"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* dijo: \w Mira|strong="H2009"\w*, \w esto|strong="H2088"\w* \w toca|strong="H5060"\w* tus \w labios|strong="H8193"\w*. Tu culpa \w es|strong="H2088"\w* quitada \w es|strong="H2088"\w* \w y|strong="H5921"\w* tu \w pecado|strong="H2403"\w* perdonado.
\v 8 Entonces \w escuché|strong="H8085"\w* la \w voz|strong="H6963"\w* de \nd ʼAdonay\nd* \w que|strong="H4310"\w* decía: \wj ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* \w enviaré|strong="H7971"\w* y \w quién|strong="H4310"\w* \w irá|strong="H3212"\w* por nosotros?\wj* Entonces dije: \w Aquí|strong="H2005"\w* estoy, \w envíame|strong="H7971"\w* \w a|strong="H3068"\w* mí.
\v 9 \w Y|strong="H3068"\w* dijo: \wj \w Vé|strong="H3212"\w* y dí \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*: \w Escuchen|strong="H8085"\w* \w bien|strong="H7200"\w*, pero no \w entiendan|strong="H3045"\w*. Miren \w ciertamente|strong="H8085"\w*, pero no comprendan.\wj*
\v 10 \wj Priva \w de|strong="H5971"\w* sensibilidad el \w corazón|strong="H3820"\w* \w de|strong="H5971"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, y \w que|strong="H6435"\w* sus \w oídos|strong="H8085"\w* \w se|strong="H5971"\w* endurezcan y sus \w ojos|strong="H5869"\w* \w se|strong="H5971"\w* cieguen, \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H6435"\w* miren con sus \w ojos|strong="H5869"\w*, \w escuchen|strong="H8085"\w* con sus \w oídos|strong="H8085"\w*, entiendan con su \w corazón|strong="H3820"\w*, \w se|strong="H5971"\w* conviertan y sean sanados.\wj*
\p 
\v 11 Entonces pregunté: ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w*, \nd ʼAdonay\nd*?
\p \w Y|strong="H3068"\w* \w Él|strong="H3427"\w* respondió: \wj \w Hasta|strong="H5704"\w* \w cuando|strong="H4970"\w* las \w ciudades|strong="H5892"\w* estén devastadas \w y|strong="H5704"\w* sin \w habitantes|strong="H3427"\w*, no haya gente \w en|strong="H5704"\w* las \w casas|strong="H1004"\w* \w y|strong="H5704"\w* la tierra esté absolutamente \w desolada|strong="H8077"\w*,\wj*
\v 12 \wj hasta cuando \nd \w Yavé|strong="H3068"\w*\nd* aleje \w a|strong="H3068"\w* los hombres y multiplique los lugares abandonados en \w medio|strong="H7130"\w* de la tierra,\wj*
\v 13 \wj aunque \w quede|strong="H1961"\w* \w en|strong="H5750"\w* ella una décima parte, \w de|strong="H5750"\w* nuevo \w será|strong="H1961"\w* consumida. Pero \w como|strong="H1961"\w* el roble \w o|strong="H3068"\w* \w la|strong="H1197"\w* encina, \w que|strong="H1961"\w* al ser talados \w aún|strong="H5750"\w* les queda el tronco, así \w será|strong="H1961"\w* el tronco \w de|strong="H5750"\w* ella, \w la|strong="H1197"\w* \w descendencia|strong="H2233"\w* \w santa|strong="H6944"\w*.\wj*
\c 7
\s1 Un mensaje para el rey Acaz
\p 
\v 1 \w Aconteció|strong="H1961"\w* \w en|strong="H5921"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* Acaz, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Jotam, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Uzías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w que|strong="H3808"\w* \w Rezín|strong="H7526"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria, \w y|strong="H5921"\w* Peca, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Remalías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w subieron|strong="H5927"\w* \w a|strong="H3068"\w* Jerusalén \w para|strong="H5921"\w* combatirla, pero \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w* conquistarla.
\v 2 Llegó noticia \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*: Siria \w se|strong="H5921"\w* confederó \w con|strong="H5921"\w* Efraín. \w Como|strong="H5921"\w* \w se|strong="H5921"\w* estremecen \w los|strong="H5921"\w* \w árboles|strong="H6086"\w* \w del|strong="H5921"\w* \w bosque|strong="H3293"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w viento|strong="H7307"\w*, \w se|strong="H5921"\w* estremeció su \w corazón|strong="H3824"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w corazón|strong="H3824"\w* \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w*.
\p 
\v 3 Entonces \nd \w Yavé|strong="H3068"\w*\nd* dijo \w a|strong="H3068"\w* \w Isaías|strong="H3470"\w*: \wj \w Sal|strong="H3318"\w* \w ahora|strong="H4994"\w* con tu \w hijo|strong="H1121"\w* Sear-jasub \w a|strong="H3068"\w* encontrarte con Acaz al \w extremo|strong="H7097"\w* del canal del \w Estanque|strong="H1295"\w* \w de|strong="H1121"\w* Arriba, \w en|strong="H3318"\w* \w el|strong="H1121"\w* \w camino|strong="H4546"\w* del \w Campo|strong="H7704"\w* del Lavador, y dile: \wj*
\v 4 \wj Ten cuidado y calma. No \w temas|strong="H3372"\w*, ni te acobardes ante esos \w dos|strong="H8147"\w* tizones humeantes, ante \w el|strong="H1121"\w* ardor \w de|strong="H1121"\w* \w la|strong="H8104"\w* ira \w de|strong="H1121"\w* \w Rezín|strong="H7526"\w*, \w de|strong="H1121"\w* Siria y del \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Remalías.\wj*
\v 5 \wj \w Pues|strong="H3588"\w* \w aunque|strong="H3588"\w* Siria trame tu ruina \w junto|strong="H5921"\w* \w con|strong="H5921"\w* Efraín, \w y|strong="H3588"\w* \w el|strong="H5921"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Remalías dijo: \wj*
\v 6 \wj \w Subamos|strong="H5927"\w* contra \w Judá|strong="H3063"\w* y aterroricémosla. Abramos una brecha \w en|strong="H8432"\w* ella, y pongamos como \w rey|strong="H4428"\w* \w al|strong="H4428"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Tabeel|strong="H2870"\w*.\wj*
\p 
\v 7 \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* dice: \wj \w No|strong="H3808"\w* \w se|strong="H1961"\w* cumplirá \w ni|strong="H3808"\w* \w sucederá|strong="H1961"\w*.\wj*
\v 8 \wj \w Porque|strong="H3588"\w* \w Damasco|strong="H1834"\w* \w es|strong="H3588"\w* \w la|strong="H3588"\w* capital \w de|strong="H3588"\w* Siria, \w Rezín|strong="H7526"\w*, \w el|strong="H3588"\w* \w jefe|strong="H7218"\w* \w de|strong="H3588"\w* \w Damasco|strong="H1834"\w*.\wj*
\v 9 \wj \w Samaria|strong="H8111"\w* \w es|strong="H3588"\w* \w la|strong="H3588"\w* capital \w de|strong="H3588"\w* Efraín, \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Remalías, \w jefe|strong="H7218"\w* \w de|strong="H3588"\w* \w Samaria|strong="H8111"\w*. Dentro \w de|strong="H3588"\w* 65 años, Efraín \w será|strong="H3808"\w* quebrantado \w y|strong="H3588"\w* dejará \w de|strong="H3588"\w* ser pueblo. \w Si|strong="H3588"\w* ustedes \w no|strong="H3808"\w* creen, \w ciertamente|strong="H3588"\w* \w no|strong="H3808"\w* permanecerán.\wj*
\p 
\v 10 \nd \w Yavé|strong="H3068"\w*\nd* \w volvió|strong="H3254"\w* \w a|strong="H3068"\w* \w hablar|strong="H1696"\w* \w a|strong="H3068"\w* Acaz:
\v 11 \wj \w Pide|strong="H7592"\w* una señal \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, \w de|strong="H5973"\w* lo profundo \w del|strong="H5973"\w* \tl Seol\tl* \w o|strong="H3068"\w* \w de|strong="H5973"\w* lo \w alto|strong="H1361"\w*.\wj*
\v 12 Pero Acaz respondió: ¡\w No|strong="H3808"\w* \w pediré|strong="H7592"\w* \w ni|strong="H3808"\w* \w tentaré|strong="H5254"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*!
\v 13 \w Entonces|strong="H3588"\w* Isaías dijo: \w Escucha|strong="H8085"\w* \w ahora|strong="H4994"\w*, \w casa|strong="H1004"\w* \w de|strong="H4480"\w* \w David|strong="H1732"\w*: ¿Les \w es|strong="H3588"\w* \w poco|strong="H4592"\w* \w el|strong="H3588"\w* ser molestos \w a|strong="H3068"\w* \w los|strong="H3588"\w* hombres, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w también|strong="H1571"\w* lo sean \w a|strong="H3068"\w* \w mi|strong="H4994"\w* \nd ʼElohim\nd*?
\p 
\v 14 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \nd ʼAdonay\nd* \w mismo|strong="H1931"\w* les \w dará|strong="H5414"\w* \w la|strong="H1931"\w* señal: \wj \w Ciertamente|strong="H2009"\w* \w la|strong="H1931"\w* virgen \w concebirá|strong="H2030"\w* y \w dará|strong="H5414"\w* \w a|strong="H3068"\w* luz un \w Hijo|strong="H1121"\w*, y \w llamará|strong="H7121"\w* \w su|strong="H1931"\w* \w Nombre|strong="H8034"\w* Emanuel.\wj*
\v 15 \wj Comerá leche cuajada y \w miel|strong="H1706"\w* hasta \w que|strong="H3045"\w* \w sepa|strong="H3045"\w* rechazar lo \w malo|strong="H7451"\w* y escoger lo \w bueno|strong="H2896"\w*.\wj*
\v 16 \wj \w Porque|strong="H3588"\w* \w antes|strong="H6440"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w niño|strong="H5288"\w* \w sepa|strong="H3045"\w* rechazar lo \w malo|strong="H7451"\w* \w y|strong="H3588"\w* escoger lo \w bueno|strong="H2896"\w*, \w la|strong="H3588"\w* tierra será \w abandonada|strong="H5800"\w* \w por|strong="H3588"\w* \w los|strong="H3588"\w* \w dos|strong="H8147"\w* \w reyes|strong="H4428"\w* \w a|strong="H3068"\w* quienes tú temes.\wj*
\v 17 \nd \w Yavé|strong="H3068"\w*\nd* traerá \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w sobre|strong="H5921"\w* tu \w pueblo|strong="H5971"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* tu padre \w días|strong="H3117"\w* \w como|strong="H5921"\w* \w nunca|strong="H3808"\w* vinieron \w desde|strong="H5921"\w* \w cuando|strong="H3117"\w* Efraín \w se|strong="H5921"\w* separó \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, esto es, \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria.
\p 
\v 18 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w silbará|strong="H8319"\w* \w al|strong="H8319"\w* tábano \w que|strong="H1931"\w* \w está|strong="H1931"\w* en \w el|strong="H1931"\w* confín de \w los|strong="H1931"\w* \w ríos|strong="H2975"\w* de \w Egipto|strong="H4714"\w* y \w a|strong="H3068"\w* \w la|strong="H1931"\w* abeja \w que|strong="H1931"\w* \w está|strong="H1931"\w* en \w la|strong="H1931"\w* tierra de Asiria,
\v 19 y vendrán. \w Todos|strong="H3605"\w* \w ellos|strong="H3605"\w* se posarán sobre las quebradas escarpadas en las hendiduras de las peñas, en \w todo|strong="H3605"\w* matorral espinoso y en \w todas|strong="H3605"\w* las corrientes de agua.
\p 
\v 20 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \nd ʼAdonay\nd* rasurará \w la|strong="H1931"\w* \w cabeza|strong="H7218"\w* \w y|strong="H1571"\w* \w el|strong="H1931"\w* \w pelo|strong="H8181"\w* de las piernas \w con|strong="H1571"\w* una \w navaja|strong="H8593"\w* alquilada de \w los|strong="H1931"\w* \w que|strong="H1931"\w* viven \w al|strong="H4428"\w* otro \w lado|strong="H5676"\w* del \w río|strong="H5104"\w*, \w esto|strong="H1931"\w* \w es|strong="H1931"\w*, \w con|strong="H1571"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* de Asiria. \w También|strong="H1571"\w* \w quitará|strong="H5595"\w* \w la|strong="H1931"\w* \w barba|strong="H2206"\w*.
\v 21 \w Acontecerá|strong="H1961"\w* en \w aquel|strong="H1931"\w* \w tiempo|strong="H3117"\w* \w que|strong="H1931"\w* un hombre criará una vaca \w y|strong="H1241"\w* \w dos|strong="H8147"\w* \w ovejas|strong="H6629"\w*.
\v 22 \w Por|strong="H3588"\w* \w la|strong="H3588"\w* \w abundancia|strong="H7230"\w* \w de|strong="H3588"\w* \w leche|strong="H2461"\w* comerá \w leche|strong="H2461"\w* cuajada, \w porque|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w quede|strong="H1961"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra comerá cuajada \w y|strong="H3588"\w* \w miel|strong="H1706"\w*.
\p 
\v 23 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w*, en un terreno \w donde|strong="H8033"\w* \w había|strong="H1961"\w* 1.000 \w vides|strong="H1612"\w*, \w que|strong="H1931"\w* en otro \w tiempo|strong="H3117"\w* valían 11 kilogramos de \w plata|strong="H3701"\w*, \w habrá|strong="H1961"\w* zarzas y \w espinos|strong="H8068"\w*.
\v 24 \w Tendrán|strong="H1961"\w* \w que|strong="H3588"\w* entrar \w en|strong="H3588"\w* \w él|strong="H3588"\w* \w con|strong="H3588"\w* flechas \w y|strong="H3588"\w* \w arco|strong="H7198"\w*, \w porque|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* tierra \w estará|strong="H1961"\w* llena \w de|strong="H3588"\w* \w espinos|strong="H8068"\w* \w y|strong="H3588"\w* \w cardos|strong="H8068"\w*.
\v 25 En \w ninguna|strong="H3605"\w* de las praderas \w que|strong="H3808"\w* hoy \w se|strong="H1961"\w* labran con \w la|strong="H3605"\w* azada \w se|strong="H1961"\w* \w podrá|strong="H3808"\w* entrar por \w temor|strong="H3374"\w* \w a|strong="H3068"\w* las zarzas \w y|strong="H7794"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w espinos|strong="H8068"\w*. \w Serán|strong="H1961"\w* pasto de ganado vacuno \w para|strong="H1961"\w* ser pisoteadas por \w el|strong="H3605"\w* ganado.
\c 8
\s1 El saqueo y el botín
\p 
\v 1 \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H5921"\w* dijo: \wj \w Toma|strong="H3947"\w* \w para|strong="H5921"\w* \w ti|strong="H5921"\w* una tabla \w grande|strong="H1419"\w* \w y|strong="H5921"\w* \w escribe|strong="H3789"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w* \w con|strong="H5921"\w* letra legible: Pronto saqueo. Rápido botín.\wj*
\p 
\v 2 Yo me tomé como \w testigos|strong="H5707"\w* fieles al \w sacerdote|strong="H3548"\w* Urías y \w a|strong="H3068"\w* \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jeberequías.
\v 3 Me uní entonces \w a|strong="H3068"\w* la \w profetisa|strong="H5031"\w*, la cual \w concibió|strong="H2029"\w* y dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*.
\p \nd \w Yavé|strong="H3068"\w*\nd* me dijo: \wj Llámalo. Pronto saqueo. Rápido botín.\wj*
\v 4 \wj \w Porque|strong="H3588"\w* \w antes|strong="H6440"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w niño|strong="H5288"\w* aprenda \w a|strong="H3068"\w* \w decir|strong="H7121"\w* papá \w y|strong="H3588"\w* mamá, \w la|strong="H3588"\w* riqueza \w de|strong="H3588"\w* \w Damasco|strong="H1834"\w* \w y|strong="H3588"\w* \w los|strong="H3588"\w* \w despojos|strong="H7998"\w* \w de|strong="H3588"\w* \w Samaria|strong="H8111"\w* serán llevados \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Asiria.\wj*
\p 
\v 5 \w Otra|strong="H5750"\w* vez \nd \w Yavé|strong="H3068"\w*\nd* \w volvió|strong="H3254"\w* \w a|strong="H3068"\w* hablarme:
\v 6 \wj \w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w desprecia|strong="H3988"\w* las \w aguas|strong="H4325"\w* \w de|strong="H3588"\w* Siloé \w que|strong="H3588"\w* corren mansamente \w y|strong="H3588"\w* \w se|strong="H5971"\w* regocija \w con|strong="H3588"\w* \w Rezín|strong="H7526"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Remalías,\wj*
\v 7 \wj \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w ciertamente|strong="H2009"\w* \nd ʼAdonay\nd* trae \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* impetuosas \w y|strong="H5921"\w* poderosas \w del|strong="H5921"\w* \w río|strong="H5104"\w*, es decir, \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria \w con|strong="H5921"\w* \w todo|strong="H3605"\w* su esplendor, \w el|strong="H5921"\w* cual \w subirá|strong="H5927"\w* \w sobre|strong="H5921"\w* \w todos|strong="H3605"\w* sus ríos \w y|strong="H5921"\w* \w pasará|strong="H1980"\w* \w sobre|strong="H5921"\w* \w todas|strong="H3605"\w* sus riberas.\wj*
\v 8 \wj \w Luego|strong="H5674"\w* \w pasará|strong="H5674"\w* \w hasta|strong="H5704"\w* \w Judá|strong="H3063"\w*, \w inundará|strong="H7857"\w* \w y|strong="H5704"\w* \w pasará|strong="H5674"\w* \w adelante|strong="H5704"\w*, \w hasta|strong="H5704"\w* la garganta, \w y|strong="H5704"\w* \w al|strong="H5704"\w* desplegar sus \w alas|strong="H3671"\w*, cubrirá la \w anchura|strong="H7341"\w* \w de|strong="H5704"\w* tu tierra, ¡oh Emanuel!\wj*
\p 
\v 9 Quebrántense, oh \w pueblos|strong="H5971"\w*, y sean destrozados. Presten oído, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H5971"\w* son \w de|strong="H5971"\w* lejanas tierras: Ármense, pero serán derrotados. ¡Prepárense \w para|strong="H5971"\w* \w la|strong="H3605"\w* guerra, pero serán vencidos!
\v 10 Tracen un plan, \w y|strong="H3588"\w* fracasará. Expresen \w palabra|strong="H1697"\w*, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* cumplirá \w por|strong="H3588"\w* \w causa|strong="H1697"\w* \w de|strong="H3588"\w* Emanuel.
\p 
\v 11 \w Así|strong="H3541"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H3588"\w* habló \w con|strong="H3588"\w* \w mano|strong="H3027"\w* fuerte \w y|strong="H3588"\w* \w me|strong="H3588"\w* instruyó \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w ande|strong="H3212"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*:
\v 12 \wj \w No|strong="H3808"\w* llames conspiración \w lo|strong="H2088"\w* \w que|strong="H3808"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* llama conspiración, \w ni|strong="H3808"\w* \w temas|strong="H3372"\w* \w a|strong="H3068"\w* \w lo|strong="H2088"\w* \w que|strong="H3808"\w* \w ellos|strong="H3605"\w* \w temen|strong="H3372"\w* y \w de|strong="H5971"\w* \w lo|strong="H2088"\w* cual \w se|strong="H3808"\w* atemorizan.\wj*
\v 13 \wj ¡\w A|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* de las huestes \w santifica|strong="H6942"\w*! ¡Sea \w Él|strong="H1931"\w* tu \w temor|strong="H4172"\w* y tu pavor!\wj*
\v 14 \wj \w Él|strong="H3427"\w* \w será|strong="H1961"\w* tu \w santuario|strong="H4720"\w*, pero \w será|strong="H1961"\w* piedra de \w tropiezo|strong="H4383"\w* y \w roca|strong="H6697"\w* de caída \w para|strong="H1961"\w* \w ambas|strong="H8147"\w* \w casas|strong="H1004"\w* de \w Israel|strong="H3478"\w*, red y trampa \w para|strong="H1961"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de Jerusalén.\wj*
\v 15 \wj \w Muchos|strong="H7227"\w* de entre ellos \w tropezarán|strong="H3782"\w*, \w caerán|strong="H5307"\w* y serán quebrantados. Se enredarán y quedarán presos.\wj*
\p 
\v 16 \w Ata|strong="H6887"\w* el testimonio y \w sella|strong="H2856"\w* la \w Ley|strong="H8451"\w* entre mis discípulos.
\v 17 \w Esperaré|strong="H2442"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, Quien \w escondió|strong="H5641"\w* su \w rostro|strong="H6440"\w* \w de|strong="H6440"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* \w Jacob|strong="H3290"\w*. \w A|strong="H3068"\w* Él \w esperaré|strong="H2442"\w*,
\v 18 \w ciertamente|strong="H2009"\w*, \w yo|strong="H2009"\w* y \w los|strong="H5973"\w* \w hijos|strong="H3206"\w* que \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H5973"\w* \w dio|strong="H5414"\w* \w como|strong="H5973"\w* señales y \w prodigios|strong="H4159"\w* \w en|strong="H5973"\w* \w Israel|strong="H3478"\w* \w de|strong="H5973"\w* parte \w de|strong="H5973"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5973"\w* las huestes, Quien \w mora|strong="H7931"\w* \w en|strong="H5973"\w* la Montaña \w Sion|strong="H6726"\w*.
\v 19 \w Si|strong="H3588"\w* les dicen: Consulten \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* evocan \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w muertos|strong="H4191"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w adivinos|strong="H3049"\w* \w que|strong="H3588"\w* hablan \w entre|strong="H3808"\w* dientes \w y|strong="H3588"\w* susurran, respondan: ¿\w No|strong="H3808"\w* \w consultará|strong="H1875"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \nd ʼElohim\nd*? ¿\w Consultará|strong="H1875"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w muertos|strong="H4191"\w* \w por|strong="H3588"\w* \w los|strong="H3588"\w* \w vivos|strong="H2416"\w*?
\v 20 ¡\w A|strong="H3068"\w* la \w Ley|strong="H8451"\w* y al testimonio! \w Si|strong="H3808"\w* \w no|strong="H3808"\w* dicen conforme \w a|strong="H3068"\w* \w esta|strong="H2088"\w* \w Palabra|strong="H1697"\w*, \w no|strong="H3808"\w* les amaneció.
\v 21 \w Pasarán|strong="H5674"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* tierra fatigados \w y|strong="H3588"\w* \w hambrientos|strong="H7457"\w*. \w Sucederá|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* tengan \w hambre|strong="H7456"\w* \w y|strong="H3588"\w* alcen \w la|strong="H3588"\w* vista, \w se|strong="H1961"\w* airarán \w y|strong="H3588"\w* maldecirán \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w rey|strong="H4428"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \nd ʼElohim\nd*.
\v 22 Mirarán la tierra. Allí habrá \w tribulación|strong="H6869"\w*, \w oscuridad|strong="H4588"\w*, \w angustia|strong="H6869"\w* y tenebrosidad. Serán sumidos en la tenebrosidad.
\c 9
\s1 Profecía con respecto al Mesías
\p 
\v 1 Pero \w no|strong="H5921"\w* habrá \w siempre|strong="H1980"\w* \w oscuridad|strong="H2822"\w* \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w que|strong="H5921"\w* \w estaba|strong="H3427"\w* \w en|strong="H5921"\w* angustia. \w Como|strong="H5921"\w* \w en|strong="H5921"\w* tiempo pasado \nd \w ʼEL|strong="H5921"\w*\nd*\f + \fr 9:1 \ft \nd ʼEL \nd*es un nombre de \nd ʼElohim\nd*.\f* despreció \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Zabulón \w y|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Neftalí, así \w en|strong="H5921"\w* \w lo|strong="H5921"\w* futuro glorificará \w el|strong="H5921"\w* \w camino|strong="H1980"\w* \w del|strong="H5921"\w* mar, \w al|strong="H5921"\w* otro lado \w del|strong="H5921"\w* Jordán, Galilea \w de|strong="H5921"\w* \w los|strong="H3427"\w* gentiles.
\p 
\v 2 El pueblo \w que|strong="H3808"\w* andaba en tinieblas verá \w gran|strong="H7235"\w* luz. \w A|strong="H3068"\w* los \w que|strong="H3808"\w* vivían en tierra \w de|strong="H6440"\w* sombra \w de|strong="H6440"\w* muerte, les resplandecerá la luz.
\v 3 Multiplicaste \w la|strong="H3588"\w* gente. Aumentaste \w la|strong="H3588"\w* alegría. Se alegrarán delante \w de|strong="H3588"\w* ti \w como|strong="H3588"\w* se alegran \w en|strong="H3588"\w* \w la|strong="H3588"\w* cosecha, \w como|strong="H3588"\w* se gozan \w cuando|strong="H3588"\w* reparten despojos.
\v 4 \w Porque|strong="H3588"\w* quebraste \w el|strong="H3588"\w* yugo \w de|strong="H3588"\w* \w su|strong="H3588"\w* carga \w y|strong="H3588"\w* \w la|strong="H3588"\w* vara \w de|strong="H3588"\w* sus hombros \w y|strong="H3588"\w* \w el|strong="H3588"\w* cetro \w de|strong="H3588"\w* \w su|strong="H3588"\w* opresor, \w como|strong="H3588"\w* \w el|strong="H3588"\w* día \w de|strong="H3588"\w* Madián.
\v 5 \w Porque|strong="H3588"\w* \w toda|strong="H5921"\w* bota \w que|strong="H3588"\w* usa \w el|strong="H5921"\w* guerrero \w en|strong="H5921"\w* \w el|strong="H5921"\w* tumulto \w y|strong="H3588"\w* \w toda|strong="H5921"\w* ropa empapada \w en|strong="H5921"\w* sangre \w serán|strong="H1961"\w* combustible \w para|strong="H5921"\w* \w el|strong="H5921"\w* fuego.
\v 6 \w Porque|strong="H5921"\w* un Niño \w nos|strong="H5921"\w* nacerá. Un Hijo \w nos|strong="H5921"\w* \w será|strong="H6213"\w* dado. \w El|strong="H5921"\w* gobierno estará \w sobre|strong="H5921"\w* su hombro, \w y|strong="H5921"\w* \w será|strong="H6213"\w* llamado: Admirable Consejero, \nd ʼElohim\nd* Fuerte, Padre \w Eterno|strong="H5769"\w*, Príncipe \w de|strong="H5921"\w* \w Paz|strong="H7965"\w*.
\v 7 \w Lo|strong="H1697"\w* dilatado \w de|strong="H1697"\w* su gobierno y la paz no tendrán límite sobre \w el|strong="H5307"\w* trono \w de|strong="H1697"\w* David y sobre su reino para disponerlo y afirmarlo en equidad y en justicia desde ahora y para siempre. ¡\w El|strong="H5307"\w* celo \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H1697"\w* las huestes hará \w esto|strong="H1697"\w*!
\s1 La mano extendida de \nd Yavé\nd* contra Israel
\p 
\v 8 \nd ʼAdonay\nd* envió Palabra contra Jacob, y \w ésta|strong="H3427"\w* cayó sobre Israel.
\v 9 Todo \w el|strong="H5307"\w* pueblo lo supo. Efraín y los habitantes de Samaria, quienes con soberbia y altivez de corazón decían:
\v 10 \w Los|strong="H5921"\w* ladrillos \w se|strong="H5921"\w* cayeron, pero edificaremos \w con|strong="H5921"\w* bloques \w de|strong="H5921"\w* piedra. \w Las|strong="H5921"\w* higueras silvestres fueron taladas, pero \w las|strong="H5921"\w* reemplazaremos \w con|strong="H5921"\w* cedros.
\v 11 \w Por|strong="H3027"\w* tanto, \nd \w Yavé|strong="H3068"\w*\nd* levanta \w a|strong="H3068"\w* Rezín, \w el|strong="H3605"\w* adversario, \w contra|strong="H3478"\w* \w ellos|strong="H3027"\w*, \w e|strong="H3068"\w* incita \w a|strong="H3068"\w* sus enemigos,
\v 12 \w a|strong="H3068"\w* los sirios \w desde|strong="H5704"\w* el oriente \w y|strong="H5704"\w* \w a|strong="H3068"\w* los filisteos \w desde|strong="H5704"\w* el occidente \w para|strong="H5704"\w* \w que|strong="H3808"\w* devoren \w a|strong="H3068"\w* Israel \w a|strong="H3068"\w* boca llena. \w A|strong="H3068"\w* pesar \w de|strong="H5704"\w* todo esto, \w no|strong="H3808"\w* \w se|strong="H3808"\w* aplaca su furor. Su mano sigue \w aún|strong="H5704"\w* extendida.
\p 
\v 13 Pero el pueblo no se vuelve al \w que|strong="H3117"\w* lo castiga, ni busca \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* de las huestes.
\v 14 \w Por|strong="H6440"\w* tanto, \nd \w Yavé|strong="H3068"\w*\nd* cortará \w cabeza|strong="H7218"\w* y \w cola|strong="H2180"\w* \w de|strong="H6440"\w* Israel, \w la|strong="H1931"\w* palmera y \w el|strong="H1931"\w* junco, en un \w mismo|strong="H1931"\w* día.
\v 15 El anciano honorable \w es|strong="H1961"\w* la cabeza, y el profeta \w que|strong="H5971"\w* enseña mentira \w es|strong="H1961"\w* la cola.
\v 16 \w Los|strong="H5921"\w* \w que|strong="H3588"\w* guían \w a|strong="H3068"\w* \w este|strong="H2063"\w* pueblo \w lo|strong="H3808"\w* extravían, \w y|strong="H3588"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* \w son|strong="H3588"\w* guiados \w por|strong="H5921"\w* \w ellos|strong="H3027"\w* \w son|strong="H3588"\w* confundidos.
\v 17 \w Por|strong="H3588"\w* tanto, \nd ʼAdonay\nd* \w no|strong="H3588"\w* se compadecerá \w de|strong="H3588"\w* sus jóvenes, ni tendrá compasión \w de|strong="H3588"\w* sus huérfanos ni \w de|strong="H3588"\w* sus viudas. \w Porque|strong="H3588"\w* todos \w son|strong="H3588"\w* impíos \w y|strong="H3588"\w* malhechores, \w y|strong="H3588"\w* toda boca habla necedad. \w A|strong="H3068"\w* pesar \w de|strong="H3588"\w* todo esto, \w no|strong="H3588"\w* se aplaca \w su|strong="H3588"\w* furor. \w Su|strong="H3588"\w* mano sigue \w aún|strong="H3588"\w* extendida.
\p 
\v 18 \w Porque|strong="H3808"\w* la perversidad arde \w como|strong="H1961"\w* fuego. Devorará las zarzas y \w los|strong="H1961"\w* espinos. Encenderá la espesura del bosque, y \w se|strong="H1961"\w* elevará \w como|strong="H1961"\w* remolinos \w de|strong="H5971"\w* humo.
\v 19 \w Por|strong="H5921"\w* \w la|strong="H5921"\w* ira \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes \w se|strong="H5921"\w* oscureció \w la|strong="H5921"\w* tierra. \w El|strong="H5921"\w* pueblo \w será|strong="H3808"\w* \w como|strong="H5921"\w* combustible \w para|strong="H5921"\w* \w el|strong="H5921"\w* fuego.
\v 20 \w Cada|strong="H3605"\w* uno roba \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w está|strong="H2063"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* \w mano|strong="H3027"\w* derecha, pero tiene hambre. Come \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w está|strong="H2063"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* izquierda, pero \w no|strong="H3808"\w* \w se|strong="H5921"\w* sacia. \w Cada|strong="H3605"\w* uno come \w la|strong="H5921"\w* carne \w de|strong="H5921"\w* \w su|strong="H1992"\w* propio brazo.
\v 21 Manasés devora \w a|strong="H3068"\w* Efraín, y Efraín \w a|strong="H3068"\w* Manasés, y ambos se levantan contra Judá. \w A|strong="H3068"\w* pesar de todo esto, no se aplaca su furor. Su mano sigue aún extendida.
\c 10
\p 
\v 1 ¡\w Ay|strong="H1945"\w* de los que dictan leyes injustas y los que registran decisiones inicuas,
\v 2 privan \w de|strong="H5971"\w* \w justicia|strong="H4941"\w* al débil y niegan el \w derecho|strong="H4941"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w pobres|strong="H1800"\w* \w de|strong="H5971"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w*, y \w tienen|strong="H1961"\w* \w a|strong="H3068"\w* las viudas \w como|strong="H1961"\w* presas y despojan \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w huérfanos|strong="H3490"\w*!
\v 3 ¿\w Qué|strong="H4100"\w* \w harán|strong="H6213"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w del|strong="H5921"\w* castigo? ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* huirán \w en|strong="H5921"\w* busca \w de|strong="H5921"\w* \w auxilio|strong="H5833"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* devastación \w que|strong="H4100"\w* vendrá \w de|strong="H5921"\w* lejos? ¿\w Dónde|strong="H5921"\w* dejarán su riqueza?
\v 4 \w Nada|strong="H3808"\w*, \w sino|strong="H3808"\w* agacharse \w entre|strong="H3808"\w* \w los|strong="H3605"\w* cautivos, \w o|strong="H3068"\w* \w caer|strong="H5307"\w* \w entre|strong="H3808"\w* \w los|strong="H3605"\w* asesinados. \w A|strong="H3068"\w* pesar \w de|strong="H8478"\w* \w todo|strong="H3605"\w* \w esto|strong="H2063"\w*, \w no|strong="H3808"\w* \w se|strong="H3808"\w* aplaca su furor. Su \w mano|strong="H3027"\w* sigue \w extendida|strong="H5186"\w*.
\s1 El destino de Asiria
\p 
\v 5 \wj ¡\w Ay|strong="H1945"\w* de Asiria, \w vara|strong="H4294"\w* de mi \w furor|strong="H2195"\w*, en \w cuyas|strong="H1931"\w* \w manos|strong="H3027"\w* puse \w el|strong="H1931"\w* \w cetro|strong="H7626"\w* de mi ira!\wj*
\v 6 \wj \w La|strong="H5921"\w* \w enviaré|strong="H7971"\w* \w contra|strong="H5921"\w* una \w nación|strong="H1471"\w* profana. \w La|strong="H5921"\w* comisionaré \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* furor, \w para|strong="H5921"\w* \w que|strong="H5921"\w* capture \w el|strong="H5921"\w* botín, tome \w el|strong="H5921"\w* \w despojo|strong="H7998"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* pisotee \w como|strong="H5921"\w* \w barro|strong="H2563"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w calles|strong="H2351"\w*.\wj*
\v 7 \wj \w Pero|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H1931"\w* entenderá \w así|strong="H3651"\w*, \w ni|strong="H3808"\w* \w serán|strong="H1931"\w* esos \w sus|strong="H1931"\w* designios. \w Su|strong="H1931"\w* propósito \w será|strong="H1931"\w* \w destruir|strong="H8045"\w* \w y|strong="H3588"\w* exterminar muchas \w naciones|strong="H1471"\w*.\wj*
\v 8 \wj \w Porque|strong="H3588"\w* dijo: ¿\w No|strong="H3808"\w* \w son|strong="H3588"\w* \w reyes|strong="H4428"\w* \w todos|strong="H3162"\w* mis ministros?\wj*
\v 9 \wj ¿\w No|strong="H3808"\w* es Calno como Carquemis? ¿\w No|strong="H3808"\w* es Hamat como Arfad? ¿\w No|strong="H3808"\w* es \w Samaria|strong="H8111"\w* como \w Damasco|strong="H1834"\w*?\wj*
\v 10 \wj Así como \w mi|strong="H3389"\w* \w mano|strong="H3027"\w* alcanzó los \w reinos|strong="H4467"\w* de los \tl ʼelohim\tl*, aunque sus imágenes eran más \w que|strong="H3027"\w* las de Jerusalén y de \w Samaria|strong="H8111"\w*,\wj*
\v 11 \wj ¿\w no|strong="H3808"\w* \w haré|strong="H6213"\w* \w así|strong="H3651"\w* \w a|strong="H3068"\w* Jerusalén y \w a|strong="H3068"\w* sus \tl ʼelohim\tl*, \w como|strong="H3651"\w* \w hice|strong="H6213"\w* \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w* y \w a|strong="H3068"\w* sus \tl ʼelohim\tl*?\wj*
\p 
\v 12 \wj \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w acontecerá|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \nd ʼAdonay\nd* acabe \w toda|strong="H3605"\w* \w su|strong="H3588"\w* \w obra|strong="H4639"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* Montaña \w Sion|strong="H6726"\w* \w y|strong="H3588"\w* \w en|strong="H5921"\w* Jerusalén, castigará \w el|strong="H5921"\w* \w fruto|strong="H6529"\w* \w del|strong="H5921"\w* \w corazón|strong="H3824"\w* arrogante \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, \w y|strong="H3588"\w* \w la|strong="H5921"\w* arrogancia altiva \w de|strong="H5921"\w* sus \w ojos|strong="H5869"\w*.\wj*
\v 13 \wj \w Porque|strong="H3588"\w* dijo: \w Con|strong="H3588"\w* \w la|strong="H3588"\w* \w fuerza|strong="H3581"\w* \w de|strong="H3588"\w* mi \w mano|strong="H3027"\w* \w hice|strong="H6213"\w* \w esto|strong="H6213"\w*, \w con|strong="H3588"\w* mi talento, \w porque|strong="H3588"\w* soy entendido. \w Así|strong="H3588"\w* \w quité|strong="H5493"\w* \w los|strong="H3427"\w* territorios \w de|strong="H3588"\w* \w los|strong="H3427"\w* \w pueblos|strong="H5971"\w*. \w Me|strong="H3588"\w* apoderé \w de|strong="H3588"\w* sus tesoros, \w y|strong="H3588"\w* \w como|strong="H3588"\w* valiente derribé \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w estaban|strong="H3427"\w* entronizados.\wj*
\v 14 \wj \w Como|strong="H1961"\w* \w se|strong="H1961"\w* recogen \w de|strong="H5971"\w* un \w nido|strong="H7064"\w* \w los|strong="H3605"\w* huevos abandonados, \w mi|strong="H1961"\w* \w mano|strong="H3027"\w* tomó \w la|strong="H3605"\w* riqueza \w de|strong="H5971"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w*. Así me apoderé yo \w de|strong="H5971"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra, y \w no|strong="H3808"\w* \w hubo|strong="H1961"\w* \w quien|strong="H3605"\w* abriera su pico \w o|strong="H3068"\w* gorjeara.\wj*
\p 
\v 15 ¿\w Se|strong="H5921"\w* enaltecerá \w el|strong="H5921"\w* hacha \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H3808"\w* \w la|strong="H5921"\w* empuña? ¿\w Se|strong="H5921"\w* engrandecerá \w la|strong="H5921"\w* sierra \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H3808"\w* \w la|strong="H5921"\w* maneja? ¡\w Como|strong="H5921"\w* \w si|strong="H3808"\w* \w el|strong="H5921"\w* \w cetro|strong="H7626"\w* \w levantara|strong="H7311"\w* \w al|strong="H5921"\w* \w que|strong="H3808"\w* \w lo|strong="H3808"\w* \w levanta|strong="H7311"\w*, \w o|strong="H3068"\w* \w la|strong="H5921"\w* \w vara|strong="H4294"\w* \w levantara|strong="H7311"\w* \w al|strong="H5921"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* es \w madera|strong="H6086"\w*!
\v 16 \w Por|strong="H8478"\w* \w eso|strong="H3651"\w* \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* \w de|strong="H8478"\w* las huestes \w enviará|strong="H7971"\w* una enfermedad exterminante \w entre|strong="H8478"\w* sus robustos guerreros, \w y|strong="H3519"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* su \w gloria|strong="H3519"\w* \w encenderá|strong="H3344"\w* una hoguera \w de|strong="H8478"\w* fuego ardiente.
\v 17 \w La|strong="H1197"\w* luz de \w Israel|strong="H3478"\w* \w se|strong="H1961"\w* convertirá en fuego, su \w Santo|strong="H6918"\w* en \w llama|strong="H3852"\w* de fuego \w que|strong="H3117"\w* \w arderá|strong="H1197"\w* \w y|strong="H1197"\w* consumirá sus zarzas \w y|strong="H1197"\w* sus \w espinos|strong="H8068"\w* en un solo \w día|strong="H3117"\w*.
\v 18 Él \w consumirá|strong="H3615"\w* totalmente \w alma|strong="H5315"\w* \w y|strong="H5704"\w* cuerpo, la \w gloria|strong="H3519"\w* \w de|strong="H5704"\w* su \w bosque|strong="H3293"\w* \w y|strong="H5704"\w* \w de|strong="H5704"\w* su campo fértil. \w Será|strong="H1961"\w* \w como|strong="H1961"\w* \w cuando|strong="H5704"\w* un enfermo languidece.
\v 19 \w Los|strong="H1961"\w* \w árboles|strong="H6086"\w* \w que|strong="H1961"\w* queden en el \w bosque|strong="H3293"\w* \w serán|strong="H1961"\w* tan \w pocos|strong="H4557"\w* \w que|strong="H1961"\w* hasta un \w niño|strong="H5288"\w* \w los|strong="H1961"\w* podrá contar.
\p 
\v 20 \w Acontecerá|strong="H1961"\w* \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w que|strong="H1931"\w* \w el|strong="H1931"\w* remanente \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Jacob|strong="H3290"\w* \w ya|strong="H3254"\w* \w no|strong="H3808"\w* \w se|strong="H1961"\w* apoyarán \w en|strong="H5921"\w* \w su|strong="H1931"\w* agresor, \w sino|strong="H3808"\w* verdaderamente \w se|strong="H1961"\w* apoyarán \w en|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w el|strong="H1931"\w* \w Santo|strong="H6918"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
\v 21 Un remanente \w volverá|strong="H7725"\w*, el remanente de \w Jacob|strong="H3290"\w*, al \nd ʼEL\nd* \w poderoso|strong="H1368"\w*.
\v 22 \w Pues|strong="H3588"\w* \w aunque|strong="H3588"\w* tu \w pueblo|strong="H5971"\w*, oh \w Israel|strong="H3478"\w*, \w sea|strong="H1961"\w* \w como|strong="H3588"\w* \w la|strong="H3588"\w* arena del \w mar|strong="H3220"\w*, solo un remanente \w de|strong="H3588"\w* ellos \w volverá|strong="H7725"\w*. ¡\w La|strong="H3588"\w* destrucción decretada \w rebosará|strong="H7857"\w* \w de|strong="H3588"\w* \w justicia|strong="H6666"\w*!
\v 23 \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* \w de|strong="H3588"\w* las huestes \w ejecutará|strong="H6213"\w* \w la|strong="H3588"\w* completa destrucción decretada \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* tierra.
\p 
\v 24 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes dice: \wj \w Pueblo|strong="H5971"\w* \w mío|strong="H5971"\w* \w que|strong="H5921"\w* vive \w en|strong="H5921"\w* \w Sion|strong="H6726"\w*, \w no|strong="H5921"\w* \w temas|strong="H3372"\w* \w a|strong="H3068"\w* Asiria. \w Te|strong="H5921"\w* \w herirá|strong="H5221"\w* \w con|strong="H5921"\w* \w vara|strong="H4294"\w* \w y|strong="H5921"\w* \w alzará|strong="H5375"\w* su \w cetro|strong="H7626"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* manera \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*.\wj*
\v 25 \wj \w Porque|strong="H3588"\w* \w dentro|strong="H5750"\w* \w de|strong="H5921"\w* muy \w poco|strong="H4592"\w* \w tiempo|strong="H4213"\w* \w mi|strong="H5921"\w* \w furor|strong="H2195"\w* \w y|strong="H3588"\w* \w mi|strong="H5921"\w* enojo \w se|strong="H5921"\w* aplicarán \w a|strong="H3068"\w* \w la|strong="H5921"\w* destrucción \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.\wj*
\v 26 \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes levantará látigo \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w como|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* matanza \w de|strong="H5921"\w* \w Madián|strong="H4080"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* peña \w de|strong="H5921"\w* Horeb. \w Alzará|strong="H5375"\w* su \w vara|strong="H4294"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w*, \w como|strong="H5921"\w* hizo \w en|strong="H5921"\w* \w Egipto|strong="H4714"\w*.
\v 27 \w Acontecerá|strong="H1961"\w* \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H3117"\w* \w que|strong="H1931"\w* \w su|strong="H1931"\w* \w carga|strong="H5448"\w* \w será|strong="H1961"\w* quitada \w de|strong="H5921"\w* tu \w hombro|strong="H7926"\w* \w y|strong="H5921"\w* \w su|strong="H1931"\w* \w yugo|strong="H5923"\w* \w de|strong="H5921"\w* tu nuca. \w El|strong="H1931"\w* \w yugo|strong="H5923"\w* \w se|strong="H1961"\w* pudrirá \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* tu unción.
\p 
\v 28 Viene \w contra|strong="H5921"\w* Ajat, \w pasa|strong="H5674"\w* \w por|strong="H5921"\w* \w Migrón|strong="H4051"\w*, \w y|strong="H5921"\w* \w en|strong="H5921"\w* Micmas \w pasará|strong="H5674"\w* revista \w a|strong="H3068"\w* sus \w armas|strong="H3627"\w*.
\v 29 \w Pasan|strong="H5674"\w* \w el|strong="H5674"\w* vado y dicen: Geba será nuestro \w alojamiento|strong="H4411"\w*. \w Ramá|strong="H7414"\w* está aterrada, \w Gabaa|strong="H1390"\w* de \w Saúl|strong="H7586"\w* \w huyó|strong="H5127"\w*.
\v 30 ¡Clama \w a|strong="H3068"\w* gran \w voz|strong="H6963"\w*, \w hija|strong="H1323"\w* de Galim! ¡\w Escucha|strong="H7181"\w*, \w Lais|strong="H3919"\w*! ¡\w Pobrecita|strong="H6041"\w* Anatot!
\v 31 \w Madmena|strong="H4088"\w* huyó, y \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de Gebim buscan refugio.
\v 32 \w Hoy|strong="H3117"\w* mismo hace alto \w en|strong="H5750"\w* \w Nob|strong="H5011"\w*. \w Ya|strong="H3068"\w* agita la \w mano|strong="H3027"\w* contra la Montaña \w de|strong="H5750"\w* la \w hija|strong="H1323"\w* \w de|strong="H5750"\w* Sion, la Montaña \w de|strong="H5750"\w* Jerusalén.
\v 33 ¡Miren! El \nd ʼAdón \w Yavé|strong="H3068"\w*\nd* de las huestes desgaja el ramaje con violencia. Los de gran \w altura|strong="H6967"\w* son talados. Los más \w altos|strong="H1364"\w* serán abatidos.
\v 34 Cortará con \w hierro|strong="H1270"\w* la espesura del \w bosque|strong="H3293"\w*. \w El|strong="H5307"\w* \w Líbano|strong="H3844"\w* \w caerá|strong="H5307"\w* por causa del Poderoso.
\c 11
\s1 Un Retoño brotará
\p 
\v 1 Brotará un Retoño del tronco de \w Isaí|strong="H3448"\w*, y una Rama de sus \w raíces|strong="H8328"\w* dará fruto.
\v 2 \w El|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w reposará|strong="H5117"\w* \w sobre|strong="H5921"\w* \w Él|strong="H5921"\w*: \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w sabiduría|strong="H2451"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* inteligencia, \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w consejo|strong="H6098"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* poder, \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w conocimiento|strong="H1847"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w temor|strong="H3374"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 3 \w Se|strong="H3808"\w* deleitará en el \w temor|strong="H3374"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w No|strong="H3808"\w* \w juzgará|strong="H8199"\w* por \w lo|strong="H3808"\w* \w que|strong="H3808"\w* vean sus \w ojos|strong="H5869"\w*, \w ni|strong="H3808"\w* por \w lo|strong="H3808"\w* \w que|strong="H3808"\w* oigan sus oídos,
\v 4 sino \w juzgará|strong="H8199"\w* con \w justicia|strong="H6664"\w* \w a|strong="H3068"\w* los \w pobres|strong="H1800"\w*. Resolverá con equidad \w a|strong="H3068"\w* favor de los mansos de la tierra. \w Herirá|strong="H5221"\w* la tierra con la \w vara|strong="H7626"\w* de su \w boca|strong="H6310"\w*, y con el \w soplo|strong="H7307"\w* de sus \w labios|strong="H8193"\w* \w matará|strong="H4191"\w* al \w impío|strong="H7563"\w*.
\v 5 La \w justicia|strong="H6664"\w* \w será|strong="H1961"\w* el cinto de sus órganos internos, y la fidelidad, el cinturón de su cintura.
\p 
\v 6 Entonces \w el|strong="H5973"\w* \w lobo|strong="H2061"\w* vivirá \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w cordero|strong="H3532"\w*, y \w el|strong="H5973"\w* leopardo se recostará \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w cabrito|strong="H1423"\w*. \w El|strong="H5973"\w* \w becerro|strong="H5695"\w*, \w el|strong="H5973"\w* cachorro \w de|strong="H5973"\w* león y la bestia doméstica andarán \w juntos|strong="H3162"\w* y \w un|strong="H3162"\w* \w niño|strong="H5288"\w* \w pequeño|strong="H6996"\w* \w los|strong="H5973"\w* pastoreará.
\v 7 La vaca \w y|strong="H1241"\w* la osa comerán hierbas, \w y|strong="H1241"\w* sus crías se echarán \w juntas|strong="H3162"\w*. El león comerá pasto como el buey.
\v 8 \w El|strong="H5921"\w* niño \w de|strong="H5921"\w* pecho jugará \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* guarida \w de|strong="H5921"\w* \w la|strong="H5921"\w* cobra, \w y|strong="H5921"\w* \w el|strong="H5921"\w* recién destetado meterá su \w mano|strong="H3027"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* guarida \w de|strong="H5921"\w* \w la|strong="H5921"\w* víbora.
\v 9 \w No|strong="H3808"\w* harán \w mal|strong="H7489"\w* \w ni|strong="H3808"\w* \w dañarán|strong="H7843"\w* \w en|strong="H3588"\w* \w todo|strong="H3605"\w* mi \w Santa|strong="H6944"\w* Montaña, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w será|strong="H3808"\w* \w llena|strong="H4390"\w* del \w conocimiento|strong="H1844"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w como|strong="H3588"\w* \w el|strong="H3588"\w* \w agua|strong="H4325"\w* \w cubre|strong="H3680"\w* \w el|strong="H3588"\w* \w mar|strong="H3220"\w*.
\p 
\v 10 \w Acontecerá|strong="H1961"\w* \w en|strong="H5975"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H3117"\w* \w que|strong="H1931"\w* las \w naciones|strong="H1471"\w* buscarán \w a|strong="H3068"\w* \w Aquél|strong="H1931"\w* \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* raíz \w de|strong="H5971"\w* \w Isaí|strong="H3448"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w estará|strong="H1961"\w* \w en|strong="H5975"\w* \w pie|strong="H5975"\w* \w como|strong="H1961"\w* un \w pendón|strong="H5251"\w* \w para|strong="H1961"\w* todos \w los|strong="H1931"\w* \w pueblos|strong="H5971"\w*. \w Su|strong="H1931"\w* lugar \w de|strong="H5971"\w* \w reposo|strong="H4496"\w* \w será|strong="H1961"\w* \w glorioso|strong="H3519"\w*.
\p 
\v 11 También \w acontecerá|strong="H1961"\w* en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w que|strong="H1931"\w* \nd ʼAdonay\nd* \w volverá|strong="H3254"\w* \w a|strong="H3068"\w* levantar \w su|strong="H1931"\w* \w mano|strong="H3027"\w* \w para|strong="H1961"\w* recuperar \w el|strong="H1931"\w* remanente \w de|strong="H5971"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w que|strong="H1931"\w* \w aún|strong="H3254"\w* \w esté|strong="H1931"\w* en Asiria, \w Egipto|strong="H4714"\w*, Patros, \w Etiopía|strong="H3568"\w*, Persia, Caldea, Hamat y en las islas del \w mar|strong="H3220"\w*.
\v 12 \w Levantará|strong="H5251"\w* \w pendón|strong="H5251"\w* \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w* para reunir \w a|strong="H3068"\w* los desterrados de \w Israel|strong="H3478"\w*, y congregar \w a|strong="H3068"\w* los esparcidos de \w Judá|strong="H3063"\w* de los cuatro puntos cardinales de la tierra.
\v 13 \w Entonces|strong="H5493"\w* \w será|strong="H3808"\w* quitada la \w envidia|strong="H7065"\w* de Efraín, y los \w que|strong="H3808"\w* hostigan \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* serán destruidos. Efraín \w no|strong="H3808"\w* tendrá \w envidia|strong="H7065"\w* de \w Judá|strong="H3063"\w*, \w ni|strong="H3808"\w* \w Judá|strong="H3063"\w* \w afligirá|strong="H6862"\w* \w a|strong="H3068"\w* Efraín.
\v 14 Desde \w el|strong="H1121"\w* occidente volarán sobre \w los|strong="H1121"\w* \w hombros|strong="H3802"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w*, y \w unidos|strong="H3162"\w* despojarán \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w oriente|strong="H6924"\w*. Edom y \w Moab|strong="H4124"\w* caerán bajo sujeción, y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón les obedecerán.
\v 15 \nd \w Yavé|strong="H3068"\w*\nd* secará \w la|strong="H5921"\w* \w lengua|strong="H3956"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*. \w Con|strong="H5921"\w* \w el|strong="H5921"\w* \w poder|strong="H3027"\w* \w de|strong="H5921"\w* su aliento alzará su \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w río|strong="H5104"\w*. \w Lo|strong="H5921"\w* partirá \w en|strong="H5921"\w* \w siete|strong="H7651"\w* \w brazos|strong="H5158"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* pasen \w por|strong="H5921"\w* \w él|strong="H5921"\w* \w en|strong="H5921"\w* sandalias.
\v 16 \w Habrá|strong="H1961"\w* un \w camino|strong="H4546"\w* \w para|strong="H1961"\w* el remanente \w de|strong="H5971"\w* su \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w quede|strong="H7604"\w* en Asiria, \w como|strong="H1961"\w* lo \w tuvo|strong="H1961"\w* \w Israel|strong="H3478"\w* \w cuando|strong="H3117"\w* \w subió|strong="H5927"\w* \w de|strong="H5971"\w* la tierra \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w*.
\c 12
\s1 La adoración en el reino de \nd Yavé\nd*
\p 
\v 1 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* dirás: \w Te|strong="H3588"\w* doy las gracias, oh \nd \w Yavé|strong="H3068"\w*\nd*, \w porque|strong="H3588"\w* \w aunque|strong="H3588"\w* estuviste airado contra mí, \w la|strong="H1931"\w* ira \w se|strong="H1931"\w* apartó \w y|strong="H3588"\w* \w me|strong="H3588"\w* consolaste.
\v 2 \w Ciertamente|strong="H3588"\w* \nd \w ʼEL|strong="H3588"\w*\nd* \w es|strong="H1961"\w* \w mi|strong="H2009"\w* salvación. Confiaré \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w temeré|strong="H6342"\w*, \w porque|strong="H3588"\w* \w mi|strong="H2009"\w* \w fortaleza|strong="H5797"\w* \w y|strong="H3588"\w* \w mi|strong="H2009"\w* cántico \w es|strong="H1961"\w* \nd \w YA|strong="H3068"\w* \w Yavé|strong="H3068"\w*\nd*, quien \w es|strong="H1961"\w* \w mi|strong="H2009"\w* salvación.
\v 3 Sacarán \w agua|strong="H4325"\w* con alegría \w de|strong="H4325"\w* las fuentes \w de|strong="H4325"\w* la salvación.
\v 4 \w Y|strong="H3068"\w* dirán \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*: Den gracias \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w Invoquen|strong="H7121"\w* \w su|strong="H1931"\w* \w Nombre|strong="H8034"\w*. Proclamen \w entre|strong="H3588"\w* \w los|strong="H1931"\w* \w pueblos|strong="H5971"\w* \w sus|strong="H1931"\w* proezas. \w Que|strong="H3588"\w* \w reconozcan|strong="H3045"\w* \w que|strong="H3588"\w* \w su|strong="H1931"\w* \w Nombre|strong="H8034"\w* \w es|strong="H1931"\w* excelso.
\v 5 ¡Canten \w salmos|strong="H2167"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w porque|strong="H3588"\w* \w hizo|strong="H6213"\w* proezas! ¡Sea \w conocido|strong="H3045"\w* \w esto|strong="H2063"\w* \w en|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* tierra!
\v 6 ¡\w Regocíjate|strong="H6670"\w* \w y|strong="H3588"\w* \w canta|strong="H7442"\w*, oh habitante \w de|strong="H3588"\w* \w Sion|strong="H6726"\w*, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w Santo|strong="H6918"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w es|strong="H3588"\w* \w grande|strong="H1419"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* ti!
\c 13
\s1 Profecía contra Babilonia
\p 
\v 1 Visión \w que|strong="H1121"\w* tuvo \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amoz, como una \w carga|strong="H4853"\w* contra Babilonia.
\v 2 \wj ¡Levanten \w bandera|strong="H5251"\w* \w sobre|strong="H5921"\w* una montaña desolada! ¡Proclamen \w y|strong="H5921"\w* agiten \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* entren \w por|strong="H5921"\w* \w las|strong="H5921"\w* \w puertas|strong="H6607"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* nobles!\wj*
\v 3 \wj Di órdenes \w a|strong="H3068"\w* mis consagrados. Recluté \w a|strong="H3068"\w* los \w valientes|strong="H1368"\w*, \w a|strong="H3068"\w* los \w que|strong="H1571"\w* se alegran en mi triunfo.\wj*
\p 
\v 4 \w Ruido|strong="H6963"\w* \w de|strong="H5971"\w* tumulto hay en las montañas, \w como|strong="H1823"\w* \w de|strong="H5971"\w* un \w ejército|strong="H6635"\w* \w numeroso|strong="H7227"\w*, \w estruendo|strong="H6963"\w* \w de|strong="H5971"\w* \w reinos|strong="H4467"\w* y \w naciones|strong="H1471"\w* congregados. ¡\nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5971"\w* las huestes alista su \w ejército|strong="H6635"\w* \w para|strong="H5971"\w* la \w batalla|strong="H4421"\w*!
\v 5 \nd \w Yavé|strong="H3068"\w*\nd* viene de tierra \w lejana|strong="H4801"\w*, del \w extremo|strong="H7097"\w* del \w cielo|strong="H8064"\w*, con las \w armas|strong="H3627"\w* de su ira para asolar \w la|strong="H3605"\w* tierra.
\p 
\v 6 Giman \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* está \w cercano|strong="H7138"\w*. Vendrá \w como|strong="H3588"\w* \w destrucción|strong="H7701"\w* \w de|strong="H3588"\w* \nd ʼEL-Shadday\nd*.
\v 7 \w Toda|strong="H3605"\w* \w mano|strong="H3027"\w* será debilitada. \w Todo|strong="H3605"\w* \w corazón|strong="H3824"\w* humano desfallecerá.
\v 8 Se llenarán \w de|strong="H6440"\w* terror. Se apoderarán \w de|strong="H6440"\w* ellos \w angustias|strong="H6735"\w* y \w dolores|strong="H2256"\w*. Tendrán \w dolores|strong="H2256"\w* como parturienta. Se asombrará cada uno al mirar \w a|strong="H3068"\w* su \w compañero|strong="H7453"\w*. Sus semblantes arden como con llamas.
\p 
\v 9 \w Ciertamente|strong="H2009"\w* el \w día|strong="H3117"\w* \w de|strong="H4480"\w* \nd \w Yavé|strong="H3068"\w*\nd* viene sin misericordia, \w con|strong="H4480"\w* \w furor|strong="H2740"\w* y ardiente \w ira|strong="H2740"\w*, \w para|strong="H4480"\w* dejar la tierra desolada y extirpar \w de|strong="H4480"\w* \w ella|strong="H4480"\w* \w a|strong="H3068"\w* los \w pecadores|strong="H2400"\w*.
\v 10 Las \w estrellas|strong="H3556"\w* del \w cielo|strong="H8064"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* constelación \w de|strong="H3588"\w* Orión \w no|strong="H3808"\w* darán \w su|strong="H3588"\w* luz. \w El|strong="H3588"\w* \w sol|strong="H8121"\w* \w se|strong="H3808"\w* oscurecerá al \w salir|strong="H3318"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w luna|strong="H3394"\w* \w no|strong="H3808"\w* dará \w su|strong="H3588"\w* resplandor.
\p 
\v 11 \wj Castigaré \w al|strong="H5921"\w* \w mundo|strong="H8398"\w* \w por|strong="H5921"\w* su perversidad \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* inicuos \w por|strong="H5921"\w* su culpa. Haré cesar \w la|strong="H5921"\w* arrogancia \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w soberbios|strong="H2086"\w* \w y|strong="H5921"\w* humillaré \w la|strong="H5921"\w* altivez \w de|strong="H5921"\w* \w los|strong="H5921"\w* tiranos.\wj*
\v 12 \wj Haré al humano más preciado que el \w oro|strong="H6337"\w* y \w a|strong="H3068"\w* la humanidad más que el \w oro|strong="H6337"\w* de Ofir.\wj*
\v 13 \wj \w Porque|strong="H5921"\w* haré estremecer \w el|strong="H5921"\w* \w cielo|strong="H8064"\w*. \w La|strong="H5921"\w* tierra será removida \w de|strong="H5921"\w* su \w sitio|strong="H4725"\w* \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ira|strong="H2740"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w del|strong="H5921"\w* ardor \w de|strong="H5921"\w* su \w ira|strong="H2740"\w*.\wj*
\p 
\v 14 \wj Entonces, \w como|strong="H1961"\w* gacela acosada, \w o|strong="H3068"\w* \w como|strong="H1961"\w* \w rebaño|strong="H6629"\w* \w que|strong="H5971"\w* \w no|strong="H1961"\w* \w tiene|strong="H1961"\w* quién \w lo|strong="H6908"\w* recoja, cada uno \w mirará|strong="H6437"\w* hacia su \w pueblo|strong="H5971"\w*, y cada uno \w huirá|strong="H5127"\w* \w a|strong="H3068"\w* su tierra.\wj*
\v 15 \wj \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H3605"\w* sea \w hallado|strong="H4672"\w*, será traspasado, y \w el|strong="H3605"\w* \w que|strong="H3605"\w* sea capturado \w caerá|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*.\wj*
\v 16 \wj Sus \w niños|strong="H5768"\w* serán estrellados \w delante|strong="H5869"\w* \w de|strong="H5869"\w* ellos, sus \w casas|strong="H1004"\w* saqueadas y sus esposas violadas.\wj*
\p 
\v 17 \wj \w Ciertamente|strong="H2005"\w* Yo incito \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* medos, \w los|strong="H5921"\w* cuales \w no|strong="H3808"\w* estiman \w la|strong="H5921"\w* \w plata|strong="H3701"\w* \w ni|strong="H3808"\w* codician \w el|strong="H5921"\w* \w oro|strong="H2091"\w*.\wj*
\v 18 \wj Derribarán \w a|strong="H3068"\w* \w los|strong="H1121"\w* jóvenes \w con|strong="H5921"\w* sus \w arcos|strong="H7198"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* tendrán compasión \w del|strong="H5921"\w* \w fruto|strong="H6529"\w* \w del|strong="H5921"\w* vientre, \w ni|strong="H3808"\w* su \w ojo|strong="H5869"\w* perdonará \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w niños|strong="H5288"\w*.\wj*
\v 19 \wj Babilonia, \w hermosura|strong="H6643"\w* de \w los|strong="H1961"\w* \w reinos|strong="H4467"\w* y ornamento de la grandeza de \w los|strong="H1961"\w* \w caldeos|strong="H3778"\w*, \w será|strong="H1961"\w* \w como|strong="H1961"\w* \w cuando|strong="H1961"\w* \nd ʼElohim\nd* arrasó \w a|strong="H3068"\w* \w Sodoma|strong="H5467"\w* y \w Gomorra|strong="H6017"\w*.\wj*
\v 20 \wj \w Nunca|strong="H3808"\w* \w más|strong="H5704"\w* \w será|strong="H3808"\w* \w habitada|strong="H3427"\w*, \w ni|strong="H3808"\w* vivirán \w en|strong="H5704"\w* \w ella|strong="H8033"\w* \w de|strong="H5704"\w* \w generación|strong="H1755"\w* \w en|strong="H5704"\w* \w generación|strong="H1755"\w*. \w El|strong="H3427"\w* árabe \w no|strong="H3808"\w* plantará su tienda \w allí|strong="H8033"\w*, \w ni|strong="H3808"\w* harán \w allí|strong="H8033"\w* aprisco \w los|strong="H3427"\w* \w pastores|strong="H7462"\w*.\wj*
\v 21 \wj Sino las fieras del desierto descansarán \w allí|strong="H8033"\w*, y sus \w casas|strong="H1004"\w* se llenarán de lechuzas. Los avestruces \w habitarán|strong="H7931"\w* \w allí|strong="H8033"\w*, y las cabras salvajes \w saltarán|strong="H7540"\w*.\wj*
\v 22 \wj Las hienas aullarán en sus palacios, y los chacales\wj*\f + \fr 13:22 \ft Hiena: Animal carroñero de África y Asia parecido al zorro y muy hediondo. Chacal: Carnívoro carroñero de tamaño medio entre el lobo y la zorra. Vive en África y Asia.\f* \wj en sus lujosas mansiones. Su \w hora|strong="H6256"\w* está \w a|strong="H3068"\w* punto \w de|strong="H6256"\w* llegar, y sus \w días|strong="H3117"\w* \w no|strong="H3808"\w* serán prolongados.\wj*
\c 14
\s1 Contra el rey de Babilonia
\p 
\v 1 \w Porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tendrá compasión \w de|strong="H5921"\w* \w Jacob|strong="H3290"\w*. Volverá \w a|strong="H3068"\w* escoger \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w los|strong="H5921"\w* establecerá \w en|strong="H5921"\w* \w su|strong="H3588"\w* propia tierra. \w Los|strong="H5921"\w* \w extranjeros|strong="H1616"\w* \w se|strong="H5921"\w* unirán \w a|strong="H3068"\w* \w ellos|strong="H5921"\w*, \w y|strong="H3588"\w* \w se|strong="H5921"\w* adherirán \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Jacob|strong="H3290"\w*.
\v 2 \w Las|strong="H5921"\w* naciones \w los|strong="H5921"\w* \w tomarán|strong="H3947"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* llevarán \w a|strong="H3068"\w* su \w lugar|strong="H4725"\w*. \w Y|strong="H3068"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w los|strong="H5921"\w* \w poseerá|strong="H5157"\w* \w como|strong="H1961"\w* esclavos \w y|strong="H5921"\w* esclavas \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*. Cautivarán \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* cautivaron, \w y|strong="H5921"\w* señorearán \w sobre|strong="H5921"\w* sus opresores.
\p 
\v 3 Aquel \w día|strong="H3117"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w te|strong="H4480"\w* dará descanso \w de|strong="H4480"\w* tu \w labor|strong="H5656"\w*, \w de|strong="H4480"\w* tu tribulación y \w de|strong="H4480"\w* la \w dura|strong="H7186"\w* esclavitud \w en|strong="H4480"\w* la cual \w los|strong="H1961"\w* obligaron \w a|strong="H3068"\w* \w servir|strong="H5647"\w*.
\v 4 Entonces \w se|strong="H5921"\w* mofarán \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia: ¡\w Cómo|strong="H5921"\w* terminó \w el|strong="H5921"\w* opresor \w y|strong="H5921"\w* \w cesó|strong="H7673"\w* \w la|strong="H5921"\w* furia!
\v 5 \nd \w Yavé|strong="H3068"\w*\nd* \w quebró|strong="H7665"\w* la \w vara|strong="H4294"\w* de los perversos, el \w cetro|strong="H7626"\w* de los gobernantes,
\v 6 \w que|strong="H5971"\w* \w sin|strong="H1097"\w* tregua golpeaba \w a|strong="H3068"\w* los \w pueblos|strong="H5971"\w* con furor, \add que\add* oprimía \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w* con incontrolable persecución.
\v 7 \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra está en \w reposo|strong="H5117"\w* y en paz. Prorrumpe en gritos de júbilo.
\v 8 \w Aun|strong="H1571"\w* \w los|strong="H5921"\w* cipreses \w y|strong="H1571"\w* \w los|strong="H5921"\w* cedros \w del|strong="H5921"\w* \w Líbano|strong="H3844"\w* \w se|strong="H3808"\w* \w alegran|strong="H8055"\w* \w por|strong="H5921"\w* \w ti|strong="H5921"\w* \add y dicen\add*: ¡\w Desde|strong="H5921"\w* \w cuando|strong="H1571"\w* fuiste derribado, \w ya|strong="H1571"\w* \w no|strong="H3808"\w* \w sube|strong="H5927"\w* \w el|strong="H5921"\w* talador \w contra|strong="H5921"\w* \w nosotros|strong="H5921"\w*!
\v 9 \w El|strong="H3605"\w* \tl Seol\tl* \w abajo|strong="H8478"\w* se estremeció \w a|strong="H3068"\w* causa \w de|strong="H8478"\w* ti. \w Despertó|strong="H5782"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* potentados \w muertos|strong="H7496"\w* \w de|strong="H8478"\w* \w la|strong="H3605"\w* tierra para \w que|strong="H3605"\w* \w en|strong="H8478"\w* tu llegada salieran \w a|strong="H3068"\w* recibirte. \w Levantó|strong="H6965"\w* \w de|strong="H8478"\w* sus tronos \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* \w de|strong="H8478"\w* las \w naciones|strong="H1471"\w*.
\v 10 \w Todos|strong="H3605"\w* \w ellos|strong="H3605"\w* te \w responderán|strong="H6030"\w* \w y|strong="H1571"\w* dirán: ¡\w También|strong="H1571"\w* tú fuiste debilitado \w como|strong="H1571"\w* \w nosotros|strong="H3605"\w*, \w y|strong="H1571"\w* fuiste \w como|strong="H1571"\w* \w nosotros|strong="H3605"\w*!
\v 11 Tu \w soberbia|strong="H1347"\w* y el sonido \w de|strong="H8478"\w* tus arpas \w descendieron|strong="H3381"\w* \w al|strong="H8478"\w* \tl Seol\tl*. Los \w gusanos|strong="H8438"\w* hacen cama \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* ti y te cubrirán.
\p 
\v 12 ¡\w Cómo|strong="H5921"\w* \w caíste|strong="H5307"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w oh|strong="H1121"\w* Lucero \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w mañana|strong="H7837"\w*! ¡Tú, \w que|strong="H5921"\w* debilitabas \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*, fuiste derribado \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra!
\v 13 Tú que decías en tu \w corazón|strong="H3824"\w*: \w Subiré|strong="H5927"\w* al \w cielo|strong="H8064"\w*, en lo \w alto|strong="H7311"\w*. Junto \w a|strong="H3068"\w* las \w estrellas|strong="H3556"\w* de \nd ʼElohim\nd* \w levantaré|strong="H7311"\w* mi \w trono|strong="H3678"\w*, y me sentaré en la Montaña del Testimonio, \w a|strong="H3068"\w* \w los|strong="H3427"\w* lados del \w norte|strong="H6828"\w*.
\v 14 \w Subiré|strong="H5927"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* alturas \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w nubes|strong="H5645"\w*, \w y|strong="H5921"\w* seré semejante \w a|strong="H3068"\w* \nd Elyón\nd*.
\v 15 ¡Pero fuiste derribado hasta el \tl Seol\tl*, \w a|strong="H3068"\w* las partes más profundas de la fosa!
\v 16 Los \w que|strong="H2088"\w* te \w vean|strong="H7200"\w* se inclinarán hacia ti. Reflexionarán ante ti y dirán: ¿\w Es|strong="H2088"\w* \w éste|strong="H2088"\w* \w aquel|strong="H2088"\w* varón \w que|strong="H2088"\w* hacía \w temblar|strong="H7493"\w* la tierra, \w que|strong="H2088"\w* sacudía los \w reinos|strong="H4467"\w*,
\v 17 \w que|strong="H3808"\w* convirtió el \w mundo|strong="H8398"\w* en un \w desierto|strong="H4057"\w*, \w que|strong="H3808"\w* \w asoló|strong="H7760"\w* sus \w ciudades|strong="H5892"\w* y \w nunca|strong="H3808"\w* les \w abrió|strong="H6605"\w* la cárcel \w a|strong="H3068"\w* sus presos?
\v 18 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* de \w la|strong="H3605"\w* tierra están tendidos con \w honra|strong="H3519"\w*, \w cada|strong="H3605"\w* uno en su propia morada.
\v 19 Pero tú eres \w echado|strong="H7993"\w* de tu \w sepulcro|strong="H6913"\w* como rama repugnante, como ropa de asesinados \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, que bajan al fondo de la fosa como uno que fue hallado muerto.
\v 20 \w No|strong="H3808"\w* serás unido \w a|strong="H3068"\w* ellos \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w sepultura|strong="H6900"\w*, \w porque|strong="H3588"\w* tú destruiste tu tierra \w y|strong="H3588"\w* \w mataste|strong="H2026"\w* \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w*. \w Para|strong="H3588"\w* \w siempre|strong="H5769"\w* \w no|strong="H3808"\w* \w será|strong="H3808"\w* nombrada \w la|strong="H3588"\w* \w descendencia|strong="H2233"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w malignos|strong="H7489"\w*.
\v 21 Preparen la matanza \w de|strong="H6440"\w* sus \w hijos|strong="H1121"\w* \w por|strong="H6440"\w* la perversidad \w de|strong="H6440"\w* sus padres, \w no|strong="H1077"\w* sea \w que|strong="H1121"\w* se levanten, \w posean|strong="H3423"\w* la tierra y llenen \w de|strong="H6440"\w* \w ciudades|strong="H5892"\w* la superficie del \w mundo|strong="H8398"\w*.
\p 
\v 22 \wj \w Porque|strong="H5921"\w* \w me|strong="H5921"\w* \w levantaré|strong="H6965"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*,\wj* \w dice|strong="H5002"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes, \wj \w y|strong="H5921"\w* extirparé \w de|strong="H5921"\w* Babilonia \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* sobrevivientes, \w los|strong="H5921"\w* descendientes \w y|strong="H5921"\w* \w las|strong="H5921"\w* futuras generaciones,\wj* \w dice|strong="H5002"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 23 \wj La convertiré en posesión \w de|strong="H4325"\w* erizos y en pantanos, y la barreré con la escoba del exterminio,\wj* \w dice|strong="H5002"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H4325"\w* las huestes.
\s1 Contra Asiria
\p 
\v 24 \nd \w Yavé|strong="H3068"\w*\nd* de las huestes \w juró|strong="H7650"\w*: \wj Ciertamente \w lo|strong="H1931"\w* \w que|strong="H1931"\w* pensé \w sucederá|strong="H1961"\w* y \w lo|strong="H1931"\w* \w que|strong="H1931"\w* decidí \w se|strong="H1961"\w* realizará.\wj*
\v 25 \wj \w Quebrantaré|strong="H7665"\w* \w al|strong="H5921"\w* asirio \w en|strong="H5921"\w* \w mi|strong="H5921"\w* tierra \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* mis montañas \w lo|strong="H5921"\w* pisotearé. Su \w yugo|strong="H5923"\w* \w será|strong="H7665"\w* quitado \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w carga|strong="H5448"\w* removida \w de|strong="H5921"\w* sus \w hombros|strong="H7926"\w*.\wj*
\v 26 \w Éste|strong="H2063"\w* \w es|strong="H3027"\w* \w el|strong="H5921"\w* designio acordado \w para|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w ésta|strong="H2063"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w extendida|strong="H5186"\w* \w sobre|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*,
\v 27 \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H3588"\w* las huestes lo determinó. ¿\w Quién|strong="H4310"\w* podrá impedirlo? ¿\w Quién|strong="H4310"\w* puede \w volver|strong="H7725"\w* atrás \w su|strong="H3588"\w* \w mano|strong="H3027"\w* \w extendida|strong="H5186"\w*?
\s1 Contra Filistea
\p 
\v 28 El \w año|strong="H8141"\w* \w cuando|strong="H1961"\w* murió el \w rey|strong="H4428"\w* Acaz \w vino|strong="H1961"\w* \w esta|strong="H2088"\w* profecía:
\v 29 \w No|strong="H3588"\w* \w te|strong="H3588"\w* alegres tú, \w toda|strong="H3605"\w* \w Filistea|strong="H6429"\w*, \w porque|strong="H3588"\w* se rompió \w la|strong="H3605"\w* \w vara|strong="H7626"\w* del \w que|strong="H3588"\w* \w te|strong="H3588"\w* \w hería|strong="H5221"\w*, \w y|strong="H3588"\w* \w saldrá|strong="H3318"\w* una víbora \w de|strong="H3588"\w* \w la|strong="H3605"\w* raíz \w de|strong="H3588"\w* \w la|strong="H3605"\w* \w serpiente|strong="H5175"\w*. \w Su|strong="H3588"\w* \w fruto|strong="H6529"\w* \w será|strong="H7665"\w* una feroz \w serpiente|strong="H5175"\w* alada.
\v 30 Entonces los \w primogénitos|strong="H1060"\w* de los \w pobres|strong="H1800"\w* serán \w apacentados|strong="H7462"\w* y los necesitados descansarán confiadamente. Pero hará \w morir|strong="H4191"\w* de \w hambre|strong="H7458"\w* \w a|strong="H3068"\w* tu raíz y \w matará|strong="H4191"\w* de \w hambre|strong="H7458"\w* \w a|strong="H3068"\w* tus sobrevivientes.
\v 31 ¡\w Aúlla|strong="H3213"\w*, \w puerta|strong="H8179"\w*! ¡Grita, \w ciudad|strong="H5892"\w*! ¡Desfallece, oh \w Filistea|strong="H6429"\w*, \w toda|strong="H3605"\w* tú! \w Porque|strong="H3588"\w* un \w humo|strong="H6227"\w* viene del \w norte|strong="H6828"\w*, \w y|strong="H3588"\w* \w no|strong="H3588"\w* hay rezagado \w en|strong="H3588"\w* sus huestes.
\v 32 ¿\w Qué|strong="H3588"\w* \w se|strong="H4100"\w* \w responderá|strong="H6030"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w mensajeros|strong="H4397"\w* \w de|strong="H3588"\w* las \w naciones|strong="H1471"\w*? \w Que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* cimentó \w a|strong="H3068"\w* \w Sion|strong="H6726"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* ella \w se|strong="H4100"\w* refugian \w los|strong="H3588"\w* afligidos \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w*.
\c 15
\s1 Profecía contra Moab
\p 
\v 1 Profecía \w que|strong="H3588"\w* vino \w como|strong="H3588"\w* una \w carga|strong="H4853"\w* contra \w Moab|strong="H4124"\w*: \w Ciertamente|strong="H3588"\w* \w en|strong="H3588"\w* una \w noche|strong="H3915"\w* \w Ar|strong="H6144"\w* \w y|strong="H3588"\w* Quir \w de|strong="H3588"\w* \w Moab|strong="H4124"\w* serán destruidas \w y|strong="H3588"\w* silenciadas.
\v 2 \w Subirán|strong="H5927"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* lugares \w altos|strong="H1116"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w Dibón|strong="H1769"\w* \w para|strong="H5921"\w* llorar. \w Moab|strong="H4124"\w* gime \w sobre|strong="H5921"\w* \w Nebo|strong="H5015"\w* \w y|strong="H5921"\w* \w Medeba|strong="H4311"\w*. \w La|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w todos|strong="H3605"\w* será rapada, \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w barba|strong="H2206"\w* será rasurada.
\v 3 \w Se|strong="H5921"\w* cubrirán \w de|strong="H5921"\w* tela áspera \w en|strong="H5921"\w* sus \w plazas|strong="H7339"\w*. \w Todos|strong="H3605"\w* lanzan alaridos \w sobre|strong="H5921"\w* sus azoteas \w y|strong="H5921"\w* \w en|strong="H5921"\w* sus \w calles|strong="H2351"\w*. \w Se|strong="H5921"\w* deshacen \w en|strong="H5921"\w* \w llanto|strong="H1065"\w*.
\p 
\v 4 \w Hesbón|strong="H2809"\w* \w y|strong="H5921"\w* Eleale gimen \w y|strong="H5921"\w* su clamor llega \w hasta|strong="H5704"\w* Jahaza. Gimen \w los|strong="H5921"\w* guerreros \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w alma|strong="H5315"\w* \w de|strong="H5921"\w* cada uno desfallece.
\p 
\v 5 Mi \w corazón|strong="H3820"\w* lamenta \w por|strong="H3588"\w* \w Moab|strong="H4124"\w*. Sus fugitivos huyen \w hasta|strong="H5704"\w* \w Zoar|strong="H6820"\w* \w como|strong="H3588"\w* una \w novilla|strong="H5697"\w* \w de|strong="H3588"\w* tres años. \w Porque|strong="H3588"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* cuesta \w de|strong="H3588"\w* Luhit \w subirán|strong="H5927"\w* \w llorando|strong="H1065"\w*. \w Levantarán|strong="H5927"\w* \w gritos|strong="H2201"\w* \w de|strong="H3588"\w* \w quebrantamiento|strong="H7667"\w* \w en|strong="H5704"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w a|strong="H3068"\w* \w Horonaim|strong="H2773"\w*
\v 6 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w agua|strong="H4325"\w* \w de|strong="H3588"\w* Nimrim \w se|strong="H1961"\w* \w secó|strong="H3001"\w*. \w La|strong="H3588"\w* \w hierba|strong="H2682"\w* \w está|strong="H1961"\w* \w seca|strong="H3001"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w hay|strong="H1961"\w* verdor.
\v 7 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w las|strong="H5921"\w* riquezas \w que|strong="H5921"\w* adquirieron \w y|strong="H5921"\w* acumularon \w las|strong="H5921"\w* \w llevan|strong="H5375"\w* \w al|strong="H5921"\w* otro lado \w del|strong="H5921"\w* \w arroyo|strong="H5158"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* Sauces.
\v 8 \w El|strong="H3588"\w* \w clamor|strong="H2201"\w* se extendió \w a|strong="H3068"\w* las fronteras \w de|strong="H3588"\w* \w Moab|strong="H4124"\w*. \w Hasta|strong="H5704"\w* Eglaim se oye \w su|strong="H3588"\w* lamento \w y|strong="H3588"\w* \w hasta|strong="H5704"\w* Beer-elim \w su|strong="H3588"\w* \w clamor|strong="H2201"\w*.
\v 9 \w Las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w de|strong="H5921"\w* \w Dimón|strong="H1775"\w* \w se|strong="H5921"\w* ensangrentaron. Reservo \w para|strong="H5921"\w* \w Dimón|strong="H1775"\w* males mayores: Un león \w contra|strong="H5921"\w* \w los|strong="H5921"\w* fugitivos \w de|strong="H5921"\w* \w Moab|strong="H4124"\w* \w y|strong="H3588"\w* \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* queden \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra.
\c 16
\s1 Las mujeres de Moab
\p 
\v 1 Envíen \w corderos|strong="H3733"\w* al Soberano de la tierra desde Petra por el \w desierto|strong="H4057"\w* \w a|strong="H3068"\w* la Montaña de la \w hija|strong="H1323"\w* de \w Sion|strong="H6726"\w*.
\v 2 \w Como|strong="H1961"\w* \w ave|strong="H5775"\w* \w espantada|strong="H7971"\w* \w que|strong="H1961"\w* huye de su \w nido|strong="H7064"\w* \w serán|strong="H1961"\w* las \w hijas|strong="H1323"\w* de \w Moab|strong="H4124"\w* en \w los|strong="H1961"\w* vados del Arnón.
\v 3 ¡Den \w consejo|strong="H6098"\w*, \w hagan|strong="H6213"\w* \w lo|strong="H6213"\w* justo! \w Haz|strong="H6213"\w* que \w tu|strong="H6213"\w* \w sombra|strong="H6738"\w* sea grata como la \w noche|strong="H3915"\w* \w en|strong="H8432"\w* \w el|strong="H6213"\w* ardor del mediodía. ¡\w Esconde|strong="H5641"\w* \w a|strong="H3068"\w* los desterrados, y \w no|strong="H6213"\w* \w descubras|strong="H1540"\w* al fugitivo!
\v 4 \w Moren|strong="H1481"\w* \w contigo|strong="H6440"\w* mis fugitivos \w de|strong="H4480"\w* \w Moab|strong="H4124"\w*. \w Sé|strong="H4480"\w* \w para|strong="H3588"\w* \w ellos|strong="H4480"\w* refugio \w ante|strong="H6440"\w* \w el|strong="H3588"\w* destructor hasta \w que|strong="H3588"\w* cese \w el|strong="H3588"\w* opresor, hasta \w que|strong="H3588"\w* \w acabe|strong="H3615"\w* \w el|strong="H3588"\w* devastador \w y|strong="H3588"\w* \w el|strong="H3588"\w* agresor desaparezca \w de|strong="H4480"\w* \w la|strong="H3588"\w* tierra.
\v 5 Será \w establecido|strong="H3559"\w* un \w trono|strong="H3678"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* Tabernáculo \w de|strong="H5921"\w* \w David|strong="H1732"\w* fundado \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w misericordia|strong="H2617"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* verdad. \w En|strong="H5921"\w* \w él|strong="H5921"\w* \w se|strong="H5921"\w* sentará un \w Juez|strong="H8199"\w* celoso \w del|strong="H5921"\w* justo \w juicio|strong="H4941"\w*, \w solícito|strong="H4106"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w justicia|strong="H6664"\w*.
\p 
\v 6 Hemos \w oído|strong="H8085"\w* del orgullo de \w Moab|strong="H4124"\w*, su \w gran|strong="H3966"\w* orgullo, su \w soberbia|strong="H1347"\w*, su arrogancia y su insolencia. Pero su jactancia es vana,
\v 7 porque \w Moab|strong="H4124"\w* gemirá. \w Toda|strong="H3605"\w* \w ella|strong="H3605"\w* \w se|strong="H3651"\w* lamentará \w por|strong="H3651"\w* las tortas de pasas de Kir-hareset. Sí, gemirán completamente desconsolados.
\p 
\v 8 \w Los|strong="H1167"\w* campos \w de|strong="H3588"\w* \w Hesbón|strong="H2809"\w* se marchitarán \w como|strong="H3588"\w* las \w vides|strong="H1612"\w* \w de|strong="H3588"\w* Sibma. \w Los|strong="H1167"\w* jefes \w de|strong="H3588"\w* las \w naciones|strong="H1471"\w* pisotearán \w sus|strong="H1986"\w* mejores \w vides|strong="H1612"\w*. Las ramas llegaban \w hasta|strong="H5704"\w* \w Jazer|strong="H3270"\w* \w y|strong="H3588"\w* se desviaban \w al|strong="H5704"\w* \w desierto|strong="H4057"\w*. Se extendían \w y|strong="H3588"\w* cruzaban \w el|strong="H3588"\w* agua.
\v 9 \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w lloro|strong="H1058"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w llanto|strong="H1065"\w* \w de|strong="H5921"\w* \w Jazer|strong="H3270"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w viña|strong="H1612"\w* \w de|strong="H5921"\w* Sibma. \w Te|strong="H5921"\w* regaré \w con|strong="H5921"\w* mis \w lágrimas|strong="H1832"\w*, \w Hesbón|strong="H2809"\w*, \w y|strong="H3588"\w* \w también|strong="H3651"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*, Eleale, \w porque|strong="H3588"\w* \w sobre|strong="H5921"\w* tus \w frutos|strong="H7019"\w* \w de|strong="H5921"\w* \w verano|strong="H7019"\w* \w y|strong="H3588"\w* \w sobre|strong="H5921"\w* tu cosecha \w caerán|strong="H5307"\w* clamores \w de|strong="H5921"\w* guerra.
\v 10 Retirarán el \w gozo|strong="H8057"\w* y la \w alegría|strong="H8057"\w* \w del|strong="H4480"\w* campo. \w No|strong="H3808"\w* \w cantarán|strong="H7442"\w* jubilosos \w en|strong="H4480"\w* las \w viñas|strong="H3754"\w*, \w ni|strong="H3808"\w* \w pisarán|strong="H1869"\w* el \w vino|strong="H3196"\w* \w en|strong="H4480"\w* el \w lagar|strong="H3342"\w*, \w porque|strong="H3808"\w* \w cesarán|strong="H7673"\w* los cánticos.
\v 11 \wj \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* mis órganos internos vibran \w como|strong="H5921"\w* un \w arpa|strong="H3658"\w* \w por|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w y|strong="H5921"\w* \w mi|strong="H5921"\w* pecho, \w por|strong="H5921"\w* Kir-hareset.\wj*
\v 12 \wj \w Cuando|strong="H3588"\w* \w Moab|strong="H4124"\w* \w se|strong="H1961"\w* muestre \w cansado|strong="H3811"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* lugares \w altos|strong="H1116"\w*, \w cuando|strong="H3588"\w* \w entre|strong="H5921"\w* \w a|strong="H3068"\w* orar \w en|strong="H5921"\w* \w su|strong="H3588"\w* \w santuario|strong="H4720"\w*, \w de|strong="H5921"\w* \w nada|strong="H3808"\w* \w le|strong="H5921"\w* \w servirá|strong="H1961"\w*. \wj*
\p 
\v 13 \w Ésta|strong="H2088"\w* \w es|strong="H2088"\w* la \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd* predijo con respecto \w a|strong="H3068"\w* \w Moab|strong="H4124"\w*.
\v 14 Pero \w ahora|strong="H6258"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w habla|strong="H1696"\w*: \wj Dentro de \w tres|strong="H7969"\w* \w años|strong="H8141"\w* de jornalero \w el|strong="H3605"\w* esplendor de \w Moab|strong="H4124"\w* \w será|strong="H3808"\w* abatida con \w toda|strong="H3605"\w* su \w gran|strong="H7227"\w* \w multitud|strong="H1995"\w*. \w Los|strong="H3605"\w* \w que|strong="H3808"\w* queden serán \w pocos|strong="H4592"\w*, escasos \w y|strong="H3519"\w* \w sin|strong="H3808"\w* algún valor.\wj*
\c 17
\s1 Profecía contra Damasco
\p 
\v 1 Profecía \w que|strong="H1961"\w* \w vino|strong="H1961"\w* \w como|strong="H1961"\w* una \w carga|strong="H4853"\w* \w sobre|strong="H1961"\w* \w Damasco|strong="H1834"\w*: \wj \w Ciertamente|strong="H2009"\w* \w Damasco|strong="H1834"\w* dejará de ser \w ciudad|strong="H5892"\w* y \w será|strong="H1961"\w* un \w montón|strong="H4596"\w* de ruinas.\wj*
\v 2 \wj Las \w ciudades|strong="H5892"\w* de \w Aroer|strong="H6177"\w* \w están|strong="H1961"\w* abandonadas. \w Serán|strong="H1961"\w* \w para|strong="H1961"\w* \w que|strong="H1961"\w* \w se|strong="H1961"\w* echen \w los|strong="H1961"\w* \w rebaños|strong="H5739"\w* sin \w que|strong="H1961"\w* alguien \w los|strong="H1961"\w* espante.\wj*
\v 3 \wj La \w fortaleza|strong="H4013"\w* \w de|strong="H1121"\w* Efraín, la soberanía \w de|strong="H1121"\w* \w Damasco|strong="H1834"\w* \w y|strong="H3519"\w* \w el|strong="H1121"\w* resto \w de|strong="H1121"\w* Siria dejará \w de|strong="H1121"\w* existir. \w Serán|strong="H1961"\w* \w como|strong="H1961"\w* \w el|strong="H1121"\w* resplandor \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*,\wj* \w dice|strong="H5002"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H1121"\w* las huestes.
\s1 Profecía con respecto a Israel
\p 
\v 4 \wj En \w aquel|strong="H1931"\w* \w tiempo|strong="H3117"\w* menguará \w el|strong="H1931"\w* resplandor de \w Jacob|strong="H3290"\w* \w y|strong="H3519"\w* enflaquecerá \w la|strong="H1931"\w* gordura de \w su|strong="H1931"\w* \w carne|strong="H1320"\w*.\wj*
\v 5 \wj \w Será|strong="H1961"\w* \w como|strong="H1961"\w* \w cuando|strong="H1961"\w* el \w que|strong="H7105"\w* cosecha recoge el trigo y su \w brazo|strong="H2220"\w* recoge las \w espigas|strong="H7641"\w*, \w como|strong="H1961"\w* el \w que|strong="H7105"\w* recoge \w espigas|strong="H7641"\w* de grano en el \w valle|strong="H6010"\w* de Rafaím.\wj*
\v 6 \wj \w Y|strong="H3068"\w* quedarán en él rebuscos, como cuando sacuden el olivo. \w Dos|strong="H8147"\w* \w o|strong="H3068"\w* \w tres|strong="H7969"\w* \w olivas|strong="H2132"\w* en la punta \w de|strong="H2568"\w* la rama, cuatro \w o|strong="H3068"\w* \w cinco|strong="H2568"\w* en sus ramas más productivas,\wj* \w dice|strong="H5002"\w* \nd \w Yavé|strong="H3068"\w*\nd*, el \nd ʼElohim\nd* \w de|strong="H2568"\w* \w Israel|strong="H3478"\w*.
\p 
\v 7 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w el|strong="H1931"\w* hombre \w mirará|strong="H7200"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w Hacedor|strong="H6213"\w*. \w Sus|strong="H1931"\w* \w ojos|strong="H5869"\w* \w contemplarán|strong="H7200"\w* \w al|strong="H5921"\w* \w Santo|strong="H6918"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
\v 8 \w No|strong="H3808"\w* \w mirará|strong="H7200"\w* los \w altares|strong="H4196"\w* \w que|strong="H3808"\w* sus propias \w manos|strong="H3027"\w* construyeron, \w ni|strong="H3808"\w* \w mirará|strong="H7200"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w hicieron|strong="H6213"\w* sus dedos, \w ni|strong="H3808"\w* los símbolos de Asera, \w ni|strong="H3808"\w* las imágenes \w del|strong="H4196"\w* sol.
\v 9 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w sus|strong="H1931"\w* plazas \w fuertes|strong="H1121"\w* \w serán|strong="H1961"\w* \w como|strong="H1961"\w* ruinas abandonadas \w ante|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* y quedarán desoladas.
\v 10 \w Porque|strong="H3588"\w* \w olvidaste|strong="H7911"\w* \w al|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* tu salvación \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* acordaste \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Roca|strong="H6697"\w* \w de|strong="H5921"\w* tu refugio. \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w aunque|strong="H3588"\w* siembres \w plantas|strong="H5193"\w* \w hermosas|strong="H5282"\w*, \w e|strong="H3068"\w* injertes vides importadas,
\v 11 el \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* las plantes, logres \w que|strong="H3117"\w* germinen y \w que|strong="H3117"\w* florezcan de \w mañana|strong="H1242"\w*, no obstante la cosecha se malogrará el \w día|strong="H3117"\w* funesto de dolor incurable.
\p 
\v 12 ¡\w Ay|strong="H1945"\w*! ¡\w Multitud|strong="H1995"\w* \w de|strong="H5971"\w* \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w* rugen \w como|strong="H1993"\w* el \w mar|strong="H3220"\w*! ¡Murmullo \w de|strong="H5971"\w* naciones resuena \w como|strong="H1993"\w* el \w de|strong="H5971"\w* \w aguas|strong="H4325"\w* impetuosas!
\v 13 Las naciones rugirán como el rugido \w de|strong="H6440"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w*, pero Él las reprenderá y huirán lejos. Serán como cáscara \w de|strong="H6440"\w* grano trillado arrebatada \w por|strong="H6440"\w* el \w viento|strong="H7307"\w* en la montaña y como remolino \w de|strong="H6440"\w* polvo \w ante|strong="H6440"\w* una tormenta.
\v 14 \w Ciertamente|strong="H2009"\w* \w al|strong="H6256"\w* llegar la noche, ahí \w está|strong="H2088"\w* el terror repentino, pero \w antes|strong="H2962"\w* del amanecer \w ya|strong="H2088"\w* no existen. \w Tal|strong="H2088"\w* \w es|strong="H2088"\w* el destino \w de|strong="H6256"\w* los \w que|strong="H2088"\w* nos despojan, \w lo|strong="H2088"\w* \w que|strong="H2088"\w* corresponde \w a|strong="H3068"\w* los \w que|strong="H2088"\w* nos saquean.
\c 18
\s1 Un Ay contra Etiopía
\p 
\v 1 \w Ay|strong="H1945"\w* de la tierra del zumbido de las \w alas|strong="H3671"\w* que está más allá de los ríos de \w Etiopía|strong="H3568"\w*,
\v 2 \w que|strong="H4480"\w* \w envía|strong="H7971"\w* \w embajadores|strong="H4397"\w* \w por|strong="H5921"\w* \w el|strong="H1931"\w* \w mar|strong="H3220"\w*, \w los|strong="H5921"\w* cuales van \w en|strong="H5921"\w* naves \w de|strong="H4480"\w* papiro \w sobre|strong="H5921"\w* \w la|strong="H1931"\w* superficie \w del|strong="H4480"\w* \w agua|strong="H4325"\w* \w y|strong="H5921"\w* dicen: \w Vayan|strong="H3212"\w*, veloces \w mensajeros|strong="H4397"\w*, \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w nación|strong="H1471"\w* \w de|strong="H4480"\w* elevada estatura \w y|strong="H5921"\w* piel brillante, \w a|strong="H3068"\w* un \w pueblo|strong="H5971"\w* \w terrible|strong="H3372"\w* \w desde|strong="H4480"\w* \w el|strong="H1931"\w* principio, \w a|strong="H3068"\w* una \w nación|strong="H1471"\w* poderosa \w y|strong="H5921"\w* humilladora, \w cuya|strong="H1931"\w* tierra \w los|strong="H5921"\w* ríos dividen.
\v 3 Ustedes, \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* del \w mundo|strong="H8398"\w* y \w habitantes|strong="H3427"\w* de \w la|strong="H3605"\w* tierra: Cuando se levante \w la|strong="H3605"\w* \w bandera|strong="H5251"\w* en las montañas, miren. Cuando se toque \w la|strong="H3605"\w* \w corneta|strong="H7782"\w*, \w escuchen|strong="H8085"\w*.
\p 
\v 4 \w Porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H5921"\w* dijo: \wj \w Yo|strong="H3588"\w* estaré \w quieto|strong="H8252"\w* \w y|strong="H3588"\w* observaré \w desde|strong="H5921"\w* \w mi|strong="H5921"\w* morada, \w como|strong="H3588"\w* \w el|strong="H5921"\w* calor vibrante \w de|strong="H5921"\w* \w la|strong="H5921"\w* luz \w del|strong="H5921"\w* sol, \w como|strong="H3588"\w* una \w nube|strong="H5645"\w* \w de|strong="H5921"\w* \w rocío|strong="H2919"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* calor \w de|strong="H5921"\w* \w la|strong="H5921"\w* cosecha.\wj*
\v 5 \w Pues|strong="H3588"\w* \w antes|strong="H6440"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* cosecha, \add lo cual\add* sucede tan pronto \w como|strong="H3588"\w* brota \w el|strong="H3588"\w* botón \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w flor|strong="H6525"\w* \w se|strong="H1961"\w* convierte \w en|strong="H3588"\w* una fruta madura, \add el viñador\add* aplica \w la|strong="H3588"\w* podadera \w a|strong="H3068"\w* las \w ramas|strong="H7105"\w*. Las poda \w con|strong="H3588"\w* cuchillos, remueve \w y|strong="H3588"\w* corta las \w ramas|strong="H7105"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* extienden.
\v 6 \w Todos|strong="H3605"\w* serán dejados \w a|strong="H3068"\w* \w los|strong="H5921"\w* buitres \w de|strong="H5921"\w* \w la|strong="H5921"\w* montaña \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* fieras \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra. \w Las|strong="H5921"\w* \w aves|strong="H5861"\w* \w de|strong="H5921"\w* rapiña pasarán \w el|strong="H5921"\w* verano \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* fieras \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra invernarán \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*.
\p 
\v 7 \w En|strong="H4480"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w será|strong="H1931"\w* traído un \w presente|strong="H7862"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H4480"\w* las huestes \w de|strong="H4480"\w* \w parte|strong="H4725"\w* \w de|strong="H4480"\w* \w la|strong="H1931"\w* \w nación|strong="H1471"\w* \w de|strong="H4480"\w* elevada estatura y piel brillante, un \w pueblo|strong="H5971"\w* \w terrible|strong="H3372"\w* \w desde|strong="H4480"\w* \w el|strong="H1931"\w* principio, una \w nación|strong="H1471"\w* poderosa y humilladora, \w cuya|strong="H1931"\w* tierra dividen \w los|strong="H1931"\w* ríos. \w El|strong="H1931"\w* \w presente|strong="H7862"\w* \w será|strong="H1931"\w* traído \w al|strong="H4480"\w* \w lugar|strong="H4725"\w* dedicado \w al|strong="H4480"\w* \w Nombre|strong="H8034"\w* \w de|strong="H4480"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H4480"\w* las huestes, \w a|strong="H3068"\w* \w la|strong="H1931"\w* Montaña \w Sion|strong="H6726"\w*.
\c 19
\s1 Profecía contra Egipto
\p 
\v 1 \w Carga|strong="H4853"\w* \w sobre|strong="H5921"\w* \w Egipto|strong="H4714"\w*. ¡Miren, \nd \w Yavé|strong="H3068"\w*\nd* \w cabalga|strong="H7392"\w* \w sobre|strong="H5921"\w* \w nube|strong="H5645"\w* veloz \w y|strong="H5921"\w* entra \w en|strong="H5921"\w* \w Egipto|strong="H4714"\w*! \w Ante|strong="H6440"\w* \w Él|strong="H5921"\w* \w se|strong="H5921"\w* estremecen \w los|strong="H5921"\w* ídolos \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*. \w El|strong="H5921"\w* \w corazón|strong="H3824"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4714"\w* desfallece.
\v 2 \wj Incitaré \w a|strong="H3068"\w* \w egipcios|strong="H4714"\w* contra \w egipcios|strong="H4714"\w*, cada uno \w peleará|strong="H3898"\w* contra su hermano, cada uno contra su \w prójimo|strong="H7453"\w*: \w ciudad|strong="H5892"\w* contra \w ciudad|strong="H5892"\w* y \w reino|strong="H4467"\w* contra \w reino|strong="H4467"\w*.\wj*
\v 3 \wj El \w espíritu|strong="H7307"\w* de \w Egipto|strong="H4714"\w* se trastornará \w dentro|strong="H7130"\w* de ellos, y confundiré sus planes. Consultarán \w a|strong="H3068"\w* los ídolos, hechiceros, nigromantes y \w adivinos|strong="H3049"\w*.\wj*
\v 4 \wj Entregaré \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* en \w mano|strong="H3027"\w* de un déspota. Un \w rey|strong="H4428"\w* cruel los dominará,\wj* \w dice|strong="H5002"\w* \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* de las huestes.
\p 
\v 5 Las \w aguas|strong="H4325"\w* del \w mar|strong="H3220"\w* fallarán. El \w río|strong="H5104"\w* quedará \w seco|strong="H3001"\w* y árido.
\v 6 Los \w brazos|strong="H7070"\w* del \w río|strong="H5104"\w* hederán. Menguarán y se secarán las corrientes del delta, las \w cañas|strong="H7070"\w* y los juncos se marchitarán.
\v 7 \w Los|strong="H5921"\w* cañaverales \w de|strong="H5921"\w* papiro \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w del|strong="H5921"\w* Nilo \w y|strong="H5921"\w* \w todo|strong="H3605"\w* sembradío \w junto|strong="H5921"\w* \w al|strong="H5921"\w* Nilo \w se|strong="H5921"\w* secarán. \w Se|strong="H5921"\w* perderán \w y|strong="H5921"\w* desaparecerán.
\v 8 \w Los|strong="H5921"\w* pescadores \w se|strong="H5921"\w* lamentarán. \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* echan anzuelo \w en|strong="H5921"\w* \w el|strong="H5921"\w* Nilo harán duelo, \w y|strong="H5921"\w* desfallecerán \w los|strong="H5921"\w* \w que|strong="H5921"\w* extienden su red \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w río|strong="H2975"\w*.
\v 9 Los que tejen el \w lino|strong="H6593"\w* cardado\f + \fr 19:9 \ft Carda: Cepillo con púas de alambre para separar fibras. Lino cardado: el que pasó por este proceso.\f* serán confundidos, y palidecerán los que tejen el \w lino|strong="H6593"\w* \w fino|strong="H8305"\w*.
\v 10 \w Los|strong="H3605"\w* tejedores \w estarán|strong="H1961"\w* consternados, \w los|strong="H3605"\w* jornaleros, apesadumbrados.
\p 
\v 11 Ciertamente \w los|strong="H1121"\w* magistrados \w de|strong="H1121"\w* Zoán son necios. \w Los|strong="H1121"\w* \w sabios|strong="H2450"\w* \w de|strong="H1121"\w* \w Faraón|strong="H6547"\w* dieron un desatinado \w consejo|strong="H6098"\w*. ¿Cómo dirán \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*: Soy \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w sabios|strong="H2450"\w* \w e|strong="H3068"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w antiguos|strong="H6924"\w* \w reyes|strong="H4428"\w*?
\v 12 ¿\w Dónde|strong="H5921"\w* están tus \w sabios|strong="H2450"\w*? ¡\w Que|strong="H4100"\w* \w te|strong="H5921"\w* digan \w qué|strong="H4100"\w* decidió \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*!
\v 13 Se desvanecieron los magistrados \w de|strong="H8269"\w* Zoán. Los magistrados \w de|strong="H8269"\w* Menfis fueron engañados. Los \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* sus \w tribus|strong="H7626"\w* extraviaron \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*.
\v 14 \nd \w Yavé|strong="H3068"\w*\nd* \w mezcló|strong="H4537"\w* un \w espíritu|strong="H7307"\w* de vértigo en \w medio|strong="H7130"\w* de \w ellos|strong="H3605"\w*, \w e|strong="H3068"\w* hicieron \w errar|strong="H8582"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* en \w toda|strong="H3605"\w* su \w obra|strong="H4639"\w*. Como \w el|strong="H3605"\w* borracho da traspiés y vomita, sus consejeros descarrían \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* en \w toda|strong="H3605"\w* su \w obra|strong="H4639"\w*.
\v 15 \w Nada|strong="H3808"\w* de \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w haga|strong="H6213"\w* la \w cabeza|strong="H7218"\w* \w o|strong="H3068"\w* la \w cola|strong="H2180"\w*, la palma \w o|strong="H3068"\w* \w el|strong="H6213"\w* junco, \w aprovechará|strong="H1961"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*.
\p 
\v 16 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4714"\w* \w serán|strong="H1961"\w* \w como|strong="H1961"\w* mujeres: Temblarán \w y|strong="H5921"\w* \w estarán|strong="H1961"\w* aterrorizados \w por|strong="H5921"\w* \w el|strong="H1931"\w* movimiento \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes \w contra|strong="H5921"\w* \w ellos|strong="H3027"\w*.
\v 17 \w La|strong="H1931"\w* tierra \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w será|strong="H1961"\w* espanto \w para|strong="H5921"\w* \w Egipto|strong="H4714"\w*. \w Su|strong="H1931"\w* sola mención \w le|strong="H1931"\w* producirá terror, \w por|strong="H5921"\w* \w el|strong="H1931"\w* designio \w que|strong="H1931"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes determinó \w contra|strong="H5921"\w* \w Egipto|strong="H4714"\w*.
\p 
\v 18 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w habrá|strong="H1961"\w* \w cinco|strong="H2568"\w* \w ciudades|strong="H5892"\w* en \w la|strong="H1931"\w* tierra \w de|strong="H2568"\w* \w Egipto|strong="H4714"\w* \w que|strong="H1931"\w* \w hablarán|strong="H1696"\w* \w la|strong="H1931"\w* \w lengua|strong="H8193"\w* \w de|strong="H2568"\w* \w Canaán|strong="H3667"\w*, y jurarán por \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H2568"\w* las huestes. Una \w de|strong="H2568"\w* \w ellas|strong="H1931"\w* \w será|strong="H1961"\w* llamada \w Ciudad|strong="H5892"\w* \w Herez|strong="H2041"\w*.
\p 
\v 19 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w habrá|strong="H1961"\w* un \w altar|strong="H4196"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de \w la|strong="H1931"\w* tierra de \w Egipto|strong="H4714"\w*, y una columna dedicada \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* cerca de \w su|strong="H1931"\w* frontera.
\v 20 \w Será|strong="H1961"\w* señal \w y|strong="H3588"\w* \w testimonio|strong="H5707"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H3588"\w* las huestes \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*. \w Cuando|strong="H3588"\w* clamen \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* opresor, \w Él|strong="H3588"\w* les \w enviará|strong="H7971"\w* un \w Salvador|strong="H3467"\w* \w y|strong="H3588"\w* Defensor, \w y|strong="H3588"\w* \w los|strong="H1961"\w* \w librará|strong="H5337"\w*.
\v 21 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w se|strong="H3045"\w* \w dará|strong="H7999"\w* \w a|strong="H3068"\w* conocer en \w Egipto|strong="H4714"\w*, y \w los|strong="H1931"\w* \w egipcios|strong="H4714"\w* \w conocerán|strong="H3045"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*. Presentarán \w sacrificios|strong="H2077"\w* y ofrendas vegetales. \w Harán|strong="H5647"\w* \w votos|strong="H5087"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* y \w los|strong="H1931"\w* \w cumplirán|strong="H7999"\w*.
\v 22 \nd \w Yavé|strong="H3068"\w*\nd* \w herirá|strong="H5062"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*. \w Lo|strong="H5704"\w* \w herirá|strong="H5062"\w*, \w lo|strong="H5704"\w* sanará, \w y|strong="H5704"\w* ellos se convertirán \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w Y|strong="H3068"\w* Él les responderá \w y|strong="H5704"\w* los sanará.
\p 
\v 23 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w habrá|strong="H1961"\w* un amplio \w camino|strong="H4546"\w* desde \w Egipto|strong="H4714"\w* \w a|strong="H3068"\w* Asiria. \w Los|strong="H1931"\w* asirios entrarán en \w Egipto|strong="H4714"\w* y \w los|strong="H1931"\w* \w egipcios|strong="H4714"\w* en Asiria. \w Entonces|strong="H3117"\w* \w los|strong="H1931"\w* \w egipcios|strong="H4714"\w* y \w los|strong="H1931"\w* asirios \w servirán|strong="H5647"\w* juntos \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*.\nd*
\p 
\v 24 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w Israel|strong="H3478"\w* \w será|strong="H1961"\w* \w tercero|strong="H7992"\w* con \w Egipto|strong="H4714"\w* y con Asiria, \w para|strong="H1961"\w* \w bendición|strong="H1293"\w* en \w medio|strong="H7130"\w* de \w la|strong="H1931"\w* tierra.
\v 25 Porque \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5971"\w* las huestes los \w bendecirá|strong="H1288"\w*: \wj ¡\w Bendito|strong="H1288"\w* sea mi \w pueblo|strong="H5971"\w*, \w Egipto|strong="H4714"\w*, y Asiria, \w obra|strong="H4639"\w* \w de|strong="H5971"\w* mis \w manos|strong="H3027"\w* y mi \w heredad|strong="H5159"\w*, \w Israel|strong="H3478"\w*!\wj*
\c 20
\s1 Derrota de Egipto y Etiopía
\p 
\v 1 El \w año|strong="H8141"\w* cuando el \tl Tartán\tl* vino \w a|strong="H3068"\w* Asdod \w enviado|strong="H7971"\w* \w por|strong="H4428"\w* \w Sargón|strong="H5623"\w*, \w rey|strong="H4428"\w* \w de|strong="H3898"\w* Asiria, la atacó y la conquistó.
\v 2 \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w habló|strong="H1696"\w* \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Amoz: \wj \w Vé|strong="H3212"\w*, despójate \w de|strong="H5921"\w* \w la|strong="H1931"\w* tela áspera \w que|strong="H1931"\w* tienes \w en|strong="H5921"\w* \w la|strong="H1931"\w* cintura \w y|strong="H5921"\w* quita \w las|strong="H5921"\w* sandalias \w de|strong="H5921"\w* tus \w pies|strong="H7272"\w*.\wj* \w Lo|strong="H1931"\w* \w hizo|strong="H6213"\w* \w así|strong="H3651"\w* \w y|strong="H5921"\w* \w andaba|strong="H1980"\w* \w desnudo|strong="H6174"\w* \w y|strong="H5921"\w* descalzo.
\p 
\v 3 \w Después|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* dijo: \wj Así \w como|strong="H5921"\w* \w mi|strong="H5921"\w* esclavo \w Isaías|strong="H3470"\w* \w anduvo|strong="H1980"\w* \w desnudo|strong="H6174"\w* \w y|strong="H5921"\w* descalzo \w tres|strong="H7969"\w* \w años|strong="H8141"\w* \w como|strong="H5921"\w* señal \w y|strong="H5921"\w* pronóstico \w contra|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w y|strong="H5921"\w* \w Etiopía|strong="H3568"\w*,\wj*
\v 4 \wj el \w rey|strong="H4428"\w* de Asiria conducirá \w a|strong="H3068"\w* los \w cautivos|strong="H7628"\w* de \w Egipto|strong="H4714"\w* y \w a|strong="H3068"\w* los desterrados de \w Etiopía|strong="H3568"\w*, jóvenes y \w ancianos|strong="H2205"\w*, \w desnudos|strong="H6174"\w* y descalzos, con las nalgas descubiertas, para \w vergüenza|strong="H6172"\w* de \w Egipto|strong="H4714"\w*.\wj*
\v 5 \wj Entonces serán atemorizados y avergonzados \w por|strong="H4480"\w* causa \w de|strong="H4480"\w* \w Etiopía|strong="H3568"\w*, su \w esperanza|strong="H4007"\w*, y \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w*, su jactancia.\wj*
\v 6 \wj \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w el|strong="H1931"\w* habitante \w de|strong="H6440"\w* \w esta|strong="H2088"\w* costa dirá: ¡Miren! ¡\w Esto|strong="H2088"\w* \w es|strong="H1931"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* sucedió \w a|strong="H3068"\w* aquellos en \w los|strong="H3427"\w* cuales confiábamos \w y|strong="H3541"\w* esperábamos, \w a|strong="H3068"\w* \w los|strong="H3427"\w* cuales huiríamos en busca \w de|strong="H6440"\w* \w auxilio|strong="H5833"\w* para \w que|strong="H1931"\w* nos libraran del \w rey|strong="H4428"\w* \w de|strong="H6440"\w* Asiria! \add Ahora\add*, ¿\w cómo|strong="H1931"\w* \w escaparemos|strong="H4422"\w*?\wj*
\c 21
\s1 Profecía contra el Desierto del Mar
\p 
\v 1 \w Carga|strong="H4853"\w* sobre el \w Desierto|strong="H4057"\w* del \w Mar|strong="H3220"\w*: Como la tempestad del Neguev, así viene del \w desierto|strong="H4057"\w*, \w de|strong="H3372"\w* una tierra aterradora.
\v 2 Una \w visión|strong="H2380"\w* \w dura|strong="H7186"\w* me fue mostrada: \w El|strong="H3605"\w* traidor traiciona, \w el|strong="H3605"\w* destructor \w destruye|strong="H7703"\w*. ¡\w Sube|strong="H5927"\w*, \w Elam|strong="H5867"\w*! ¡Asedia, \w Media|strong="H4074"\w*! ¡Aplaqué \w todo|strong="H3605"\w* gemido!
\v 3 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w* \w mi|strong="H5921"\w* cintura \w se|strong="H5921"\w* \w llenó|strong="H4390"\w* \w de|strong="H5921"\w* dolor. \w Me|strong="H5921"\w* vinieron \w angustias|strong="H6735"\w*, \w como|strong="H5921"\w* \w angustias|strong="H6735"\w* \w de|strong="H5921"\w* parturienta. \w Me|strong="H5921"\w* agita oírlo, \w me|strong="H5921"\w* espanta mirarlo.
\v 4 Se me turba el \w corazón|strong="H3824"\w* y el terror se apoderó de mí. El crepúsculo anhelado se me convirtió en espanto.
\p 
\v 5 Disponen la \w mesa|strong="H7979"\w* y extienden el mantel: Comen y \w beben|strong="H8354"\w*. ¡\w Levántense|strong="H6965"\w*, \w capitanes|strong="H8269"\w*! Aceiten los \w escudos|strong="H4043"\w*,
\v 6 \w porque|strong="H3588"\w* \nd ʼAdonay\nd* \w me|strong="H3588"\w* dice: \wj \w Vé|strong="H3212"\w*, \w pon|strong="H5975"\w* un \w centinela|strong="H6822"\w*, \w que|strong="H3588"\w* informe lo \w que|strong="H3588"\w* \w ve|strong="H3212"\w*: \wj*
\v 7 \wj Si \w ve|strong="H7200"\w* \w hombres|strong="H6571"\w* \w montados|strong="H7393"\w*, parejas de \w jinetes|strong="H6571"\w* en \w asnos|strong="H2543"\w*, \w jinetes|strong="H6571"\w* en \w camellos|strong="H1581"\w*, que preste atención, muy fija atención.\wj*
\p 
\v 8 Entonces \w el|strong="H5921"\w* centinela \w clamó|strong="H7121"\w*: ¡Oh \nd ʼAdonay\nd*, \w estoy|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H5975"\w* \w continuamente|strong="H8548"\w* \w de|strong="H5921"\w* \w día|strong="H3119"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* torre \w del|strong="H5921"\w* centinela, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* puesto \w de|strong="H5921"\w* guardia sigo firme \w cada|strong="H3605"\w* \w noche|strong="H3915"\w*!
\v 9 ¡\w Ciertamente|strong="H2009"\w* vienen \w hombres|strong="H6571"\w* \w montados|strong="H7393"\w*, parejas de \w jinetes|strong="H6571"\w*! Después \w habló|strong="H6030"\w*: ¡\w Cayó|strong="H5307"\w*, \w cayó|strong="H5307"\w* Babilonia, y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ídolos|strong="H6456"\w* de sus \tl ʼelohim\tl* \w quebrantó|strong="H7665"\w* en tierra!
\v 10 Pueblo mío, trillado en mi \w era|strong="H1121"\w*, te \w anuncio|strong="H5046"\w* lo \w que|strong="H1121"\w* \w oí|strong="H8085"\w* \w de|strong="H1121"\w* parte \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H1121"\w* las huestes, \w el|strong="H1121"\w* \nd ʼElohim\nd* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.
\s1 Carga Sobre Duma
\p 
\v 11 \w Carga|strong="H4853"\w* sobre \w Duma|strong="H1746"\w*: De \w Seir|strong="H8165"\w* alguien me grita: ¡Centinela! ¿\w Cuánto|strong="H4100"\w* queda de \w la|strong="H8104"\w* \w noche|strong="H3915"\w*? ¡Centinela! ¿\w Cuánto|strong="H4100"\w* queda de \w la|strong="H8104"\w* \w noche|strong="H3915"\w*?
\v 12 Responde \w el|strong="H1571"\w* centinela: Viene \w la|strong="H1571"\w* \w mañana|strong="H1242"\w* \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w la|strong="H1571"\w* \w noche|strong="H3915"\w*. \w Si|strong="H1571"\w* quieren preguntar, pregunten. Regresen, \w vuelvan|strong="H7725"\w* otra vez.
\s1 Carga sobre Arabia
\p 
\v 13 \w Carga|strong="H4853"\w* sobre \w Arabia|strong="H6152"\w*: En \w el|strong="H3885"\w* \w bosque|strong="H3293"\w* de \w Arabia|strong="H6152"\w* pasarán la noche, oh caminantes de Dedán.
\v 14 Oh \w habitantes|strong="H3427"\w* \w de|strong="H4325"\w* Tema, salgan con \w agua|strong="H4325"\w* \w a|strong="H3068"\w* encontrar al sediento. Socorran con \w pan|strong="H3899"\w* al \w que|strong="H4325"\w* huye.
\v 15 \w Porque|strong="H3588"\w* huyen \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w espada|strong="H2719"\w* desenvainada, del \w arco|strong="H7198"\w* \w entesado|strong="H1869"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* presión \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w batalla|strong="H4421"\w*.
\p 
\v 16 \w Porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H3588"\w* dijo: \wj \w Dentro|strong="H5750"\w* \w de|strong="H3588"\w* un \w año|strong="H8141"\w* \w de|strong="H3588"\w* jornalero, \w todo|strong="H3605"\w* \w el|strong="H3588"\w* esplendor \w de|strong="H3588"\w* \w Cedar|strong="H6938"\w* terminará.\wj*
\v 17 \wj \w El|strong="H3588"\w* resto del \w número|strong="H4557"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* arqueros, \w los|strong="H1121"\w* \w hombres|strong="H1368"\w* \w poderosos|strong="H1368"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Cedar|strong="H6938"\w* serán \w pocos|strong="H4557"\w*.\wj* Lo \w dijo|strong="H1696"\w* \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.
\c 22
\s1 El Valle de la Visión
\p 
\v 1 \w Carga|strong="H4853"\w* sobre \w el|strong="H3588"\w* \w Valle|strong="H1516"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w Visión|strong="H2384"\w*: ¿\w Qué|strong="H3588"\w* pasa \w que|strong="H3588"\w* \w todos|strong="H3605"\w* ustedes \w subieron|strong="H5927"\w* \w a|strong="H3068"\w* las azoteas?
\v 2 Tú, llena de bullicio, pueblo turbulento, \w ciudad|strong="H5892"\w* regocijada. Tus caídos \w no|strong="H3808"\w* fueron asesinados \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w ni|strong="H3808"\w* \w murieron|strong="H4191"\w* en combate.
\v 3 \w Todos|strong="H3605"\w* tus comandantes \w huyeron|strong="H5074"\w* \w juntos|strong="H3162"\w*. \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* tuyos fueron capturados sin \w arco|strong="H7198"\w*, aunque \w huyeron|strong="H5074"\w* \w lejos|strong="H7350"\w*.
\v 4 \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* dije: \w Déjame|strong="H8159"\w* llorar amargamente. \w No|strong="H5921"\w* \w se|strong="H5921"\w* afanen \w en|strong="H5921"\w* \w consolarme|strong="H5162"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w destrucción|strong="H7701"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w hija|strong="H1323"\w* \w de|strong="H4480"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*.
\p 
\v 5 \w Porque|strong="H3588"\w* éste \w es|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* alboroto, angustia \w y|strong="H3588"\w* confusión \w de|strong="H3588"\w* parte \w de|strong="H3588"\w* \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* \w de|strong="H3588"\w* las huestes \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w Valle|strong="H1516"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w Visión|strong="H2384"\w*, \w día|strong="H3117"\w* \w de|strong="H3588"\w* derribar \w los|strong="H3588"\w* muros \w y|strong="H3588"\w* clamar \w a|strong="H3068"\w* \w la|strong="H3588"\w* montaña.
\v 6 \w Elam|strong="H5867"\w* \w toma|strong="H5375"\w* la caja portátil de flechas, Siria irrumpe con carruajes y Quir saca el \w escudo|strong="H4043"\w*.
\v 7 Tus mejores \w valles|strong="H6010"\w* \w se|strong="H1961"\w* \w llenaron|strong="H4390"\w* de carruajes, y \w los|strong="H1961"\w* \w jinetes|strong="H6571"\w* \w acamparon|strong="H7896"\w* frente \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w*.
\v 8 \w Fue|strong="H1931"\w* quitada \w la|strong="H1931"\w* defensa de \w Judá|strong="H3063"\w*. \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* fijan \w su|strong="H1931"\w* mirada en las \w armas|strong="H5402"\w* de \w la|strong="H1931"\w* \w Casa|strong="H1004"\w* del \w Bosque|strong="H3293"\w*.
\v 9 \w Ven|strong="H7200"\w* \w muchas|strong="H7235"\w* brechas \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w Ciudad|strong="H5892"\w* \w de|strong="H3588"\w* \w David|strong="H1732"\w*, \w y|strong="H3588"\w* recogen las \w aguas|strong="H4325"\w* del \w estanque|strong="H1295"\w* \w de|strong="H3588"\w* abajo.
\v 10 \w Cuentan|strong="H5608"\w* las \w casas|strong="H1004"\w* de Jerusalén, y demuelen \w casas|strong="H1004"\w* para reforzar el \w muro|strong="H2346"\w*.
\v 11 \w Entre|strong="H3808"\w* los dos \w muros|strong="H2346"\w* \w hacen|strong="H6213"\w* una represa para las \w aguas|strong="H4325"\w* del \w estanque|strong="H1295"\w* antiguo, pero \w no|strong="H3808"\w* \w miran|strong="H5027"\w* \w hacia|strong="H6213"\w* \w el|strong="H6213"\w* \w que|strong="H3808"\w* \w hace|strong="H6213"\w* \w esto|strong="H6213"\w*, \w ni|strong="H3808"\w* \w ven|strong="H7200"\w* \w hacia|strong="H6213"\w* \w el|strong="H6213"\w* \w que|strong="H3808"\w* \w lo|strong="H3808"\w* produjo \w hace|strong="H6213"\w* mucho tiempo.
\p 
\v 12 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* de las huestes \w los|strong="H1931"\w* convoca al \w llanto|strong="H1065"\w* y lamento, \w a|strong="H3068"\w* raparse \w el|strong="H1931"\w* cabello y \w a|strong="H3068"\w* cubrirse de tela áspera.
\v 13 \w Pero|strong="H3588"\w* \w ciertamente|strong="H3588"\w* hay \w gozo|strong="H8057"\w* \w y|strong="H3588"\w* \w alegría|strong="H8057"\w*, matanza \w de|strong="H3588"\w* \w bueyes|strong="H1241"\w* \w y|strong="H3588"\w* degüello \w de|strong="H3588"\w* \w ovejas|strong="H6629"\w*. Se come \w carne|strong="H1320"\w*, se \w bebe|strong="H8354"\w* \w vino|strong="H3196"\w* \w y|strong="H3588"\w* dicen: ¡Comamos \w y|strong="H3588"\w* bebamos, \w porque|strong="H3588"\w* \w mañana|strong="H4279"\w* \w moriremos|strong="H4191"\w*!
\v 14 \w Por|strong="H2088"\w* eso \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5704"\w* las huestes reveló \w a|strong="H3068"\w* mis oídos: \wj \w Ciertamente|strong="H4191"\w* \w este|strong="H2088"\w* \w pecado|strong="H5771"\w* no les será perdonado \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w mueran|strong="H4191"\w*,\wj* dice \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5704"\w* las huestes.
\s1 Profetizada destitución del administrador Sebna
\p 
\v 15 \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes dice: \wj \w Anda|strong="H3212"\w*, \w vé|strong="H3068"\w* \w a|strong="H3068"\w* \w Sebna|strong="H7644"\w*, administrador \w del|strong="H5921"\w* palacio, \w y|strong="H5921"\w* dile: \wj*
\v 16 \wj ¿\w Qué|strong="H3588"\w* tienes \w aquí|strong="H6311"\w* \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w quién|strong="H4310"\w* tienes \w aquí|strong="H6311"\w* \w por|strong="H3588"\w* \w lo|strong="H4100"\w* \w cual|strong="H4100"\w* \w te|strong="H3588"\w* labras un \w sepulcro|strong="H6913"\w* \w como|strong="H4100"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* labra \w su|strong="H3588"\w* \w sepultura|strong="H6913"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w peña|strong="H5553"\w*?\wj*
\v 17 \wj \w Ciertamente|strong="H2009"\w*, oh \w hombre|strong="H1397"\w*, \nd \w Yavé|strong="H3068"\w*\nd* te lanzará lejos con fuerza y está \w a|strong="H3068"\w* punto de atraparte.\wj*
\v 18 \wj Te enrollará como un ovillo para lanzarte sobre una tierra \w espaciosa|strong="H7342"\w*. \w Allí|strong="H8033"\w* \w morirás|strong="H4191"\w* \w y|strong="H3519"\w* \w allí|strong="H8033"\w* pararán tus espléndidos carruajes, como vergüenza de la \w casa|strong="H1004"\w* de tu amo.\wj*
\v 19 \wj Te privaré de tu cargo y te eliminaré de tu posición.\wj*
\s1 Profetizada exaltación sacerdotal de Eliaquim
\p 
\v 20 \wj \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w llamaré|strong="H7121"\w* \w a|strong="H3068"\w* \w mi|strong="H1961"\w* esclavo Eliaquim, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hilcías|strong="H2518"\w*.\wj*
\v 21 \wj Lo \w vestiré|strong="H3847"\w* con tu túnica y le ataré tu cinturón. \w Entregaré|strong="H5414"\w* tu \w poder|strong="H3027"\w* en su \w mano|strong="H3027"\w*. \w Será|strong="H1961"\w* padre \w para|strong="H5414"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H3847"\w* Jerusalén y la \w Casa|strong="H1004"\w* \w de|strong="H3847"\w* \w Judá|strong="H3063"\w*.\wj*
\v 22 \wj \w Pondré|strong="H5414"\w* \w la|strong="H5921"\w* llave \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w sobre|strong="H5921"\w* su \w hombro|strong="H7926"\w*: cuando abra, nadie \w cerrará|strong="H5462"\w*, \w y|strong="H5921"\w* cuando cierre, nadie \w abrirá|strong="H6605"\w*.\wj*
\v 23 \wj Lo clavaré \w como|strong="H1961"\w* estaca en \w lugar|strong="H4725"\w* firme. \w Será|strong="H1961"\w* un \w trono|strong="H3678"\w* de \w honra|strong="H3519"\w* \w para|strong="H1961"\w* la \w casa|strong="H1004"\w* de su padre.\wj*
\v 24 \wj Dependerá \w de|strong="H5921"\w* \w él|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* esplendor \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* su padre, \w la|strong="H5921"\w* prole \w y|strong="H5921"\w* \w las|strong="H5921"\w* futuras generaciones, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* utensilios \w hasta|strong="H5704"\w* \w los|strong="H5921"\w* \w más|strong="H5921"\w* \w pequeños|strong="H6996"\w*, \w desde|strong="H5704"\w* \w los|strong="H5921"\w* tazones \w hasta|strong="H5704"\w* \w los|strong="H5921"\w* cántaros.\wj*
\v 25 \wj \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w*, \wj*\w dice|strong="H5002"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes, \wj \w la|strong="H1931"\w* estaca clavada \w en|strong="H5921"\w* \w lugar|strong="H4725"\w* firme cederá. \w La|strong="H1931"\w* \w carga|strong="H4853"\w* \w que|strong="H3588"\w* dependía \w de|strong="H5921"\w* \w ella|strong="H1931"\w* \w caerá|strong="H5307"\w* \w y|strong="H3588"\w* \w se|strong="H1931"\w* romperá, \wj*\w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w habló|strong="H1696"\w*.
\c 23
\s1 Profecía contra Tiro y Sidón
\p 
\v 1 \w Carga|strong="H4853"\w* sobre \w Tiro|strong="H6865"\w*: ¡Lamenten, naves \w de|strong="H3588"\w* \w Tarsis|strong="H8659"\w*, \w porque|strong="H3588"\w* \w Tiro|strong="H6865"\w* \w es|strong="H3588"\w* \w destruida|strong="H7703"\w* hasta \w no|strong="H3588"\w* quedar \w casa|strong="H1004"\w* ni lugar \w para|strong="H3588"\w* entrar! Se les informó desde \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* Quitim.
\v 2 ¡Callen, oh \w habitantes|strong="H3427"\w* de la costa y \w mercaderes|strong="H5503"\w* de \w Sidón|strong="H6721"\w* quienes cruzaban \w el|strong="H5674"\w* \w mar|strong="H3220"\w*!
\v 3 \w El|strong="H2975"\w* grano \w de|strong="H4325"\w* \w Sihor|strong="H7883"\w* y la cosecha del \w río|strong="H2975"\w* \add Nilo\add* \w eran|strong="H1961"\w* su ganancia. Ella \w era|strong="H1961"\w* \w el|strong="H2975"\w* mercado \w de|strong="H4325"\w* las \w naciones|strong="H1471"\w*.
\v 4 Avergüénzate, oh \w Sidón|strong="H6721"\w*, \w fortaleza|strong="H4581"\w* del \w mar|strong="H3220"\w*, \w porque|strong="H3588"\w* dijo \w el|strong="H3588"\w* \w mar|strong="H3220"\w*: \w Nunca|strong="H3808"\w* estuve \w con|strong="H3588"\w* dolores \w de|strong="H3588"\w* parto, \w ni|strong="H3808"\w* di \w a|strong="H3068"\w* luz, \w ni|strong="H3808"\w* \w crié|strong="H1431"\w* jóvenes, \w ni|strong="H3808"\w* desarrollé \w vírgenes|strong="H1330"\w*.
\v 5 Cuando la noticia llegue \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, se estremecerán por los informes con respecto \w a|strong="H3068"\w* \w Tiro|strong="H6865"\w*.
\v 6 ¡Oh \w habitantes|strong="H3427"\w* de la costa, pasen \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w* y lamenten!
\v 7 ¿\w Es|strong="H2063"\w* \w ésta|strong="H2063"\w* su ciudad divertida de mucha antigüedad, cuyos \w pies|strong="H7272"\w* \w la|strong="H2063"\w* llevaban \w a|strong="H3068"\w* lugares \w lejanos|strong="H7350"\w*?
\v 8 ¿\w Quién|strong="H4310"\w* \w decretó|strong="H3289"\w* \w esto|strong="H2063"\w* \w contra|strong="H5921"\w* \w Tiro|strong="H6865"\w*, \w la|strong="H5921"\w* \w cual|strong="H4310"\w* regalaba coronas, \w cuyos|strong="H5921"\w* comerciantes eran \w príncipes|strong="H8269"\w* \w y|strong="H5921"\w* sus \w mercaderes|strong="H5503"\w* \w los|strong="H5921"\w* \w honorables|strong="H3513"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra?
\p 
\v 9 \nd \w Yavé|strong="H3068"\w*\nd* de las huestes \w lo|strong="H3605"\w* \w decretó|strong="H3289"\w* para abatir \w la|strong="H3605"\w* \w soberbia|strong="H1347"\w* de \w todo|strong="H3605"\w* esplendor y humillar \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w honorables|strong="H3513"\w* de \w la|strong="H3605"\w* tierra.
\v 10 Inunda tu tierra \w como|strong="H5750"\w* \w el|strong="H2975"\w* Nilo, oh \w hija|strong="H1323"\w* \w de|strong="H5750"\w* \w Tarsis|strong="H8659"\w*, porque ya no existe la restricción \add de tu puerto\add*.
\v 11 \w Él|strong="H5921"\w* \w extendió|strong="H5186"\w* su \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w y|strong="H5921"\w* sacudió \w los|strong="H5921"\w* \w reinos|strong="H4467"\w*. \nd \w Yavé|strong="H3068"\w*\nd* \w ordenó|strong="H6680"\w* \w destruir|strong="H8045"\w* \w las|strong="H5921"\w* fortalezas \w de|strong="H5921"\w* \w Canaán|strong="H3667"\w*:
\v 12 \wj \w No|strong="H3808"\w* volverás \w a|strong="H3068"\w* regocijarte, oh doncella \w oprimida|strong="H6231"\w*, \w hija|strong="H1323"\w* \w de|strong="H5750"\w* \w Sidón|strong="H6721"\w*. \w Levántate|strong="H6965"\w* para \w pasar|strong="H5674"\w* \w a|strong="H3068"\w* Quitim, \w y|strong="H1571"\w* \w aun|strong="H5750"\w* \w allí|strong="H8033"\w* \w no|strong="H3808"\w* tendrás \w reposo|strong="H5117"\w*.\wj*
\p 
\v 13 Ahí \w está|strong="H2088"\w* la tierra \w de|strong="H5971"\w* \w los|strong="H1961"\w* \w caldeos|strong="H3778"\w*. \w Ese|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w no|strong="H3808"\w* \w existía|strong="H1961"\w*. Asiria \w lo|strong="H2088"\w* destinó \w para|strong="H1961"\w* las bestias del desierto. La sitiaron y destruyeron sus palacios. \w Se|strong="H1961"\w* convirtió en escombros.
\v 14 Lamenten, oh naves \w de|strong="H3588"\w* \w Tarsis|strong="H8659"\w*, \w pues|strong="H3588"\w* \w su|strong="H3588"\w* baluarte fue \w destruido|strong="H7703"\w*.
\v 15 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w Tiro|strong="H6865"\w* \w quedará|strong="H1961"\w* en \w el|strong="H1931"\w* \w olvido|strong="H7911"\w* 70 \w años|strong="H8141"\w*, \w como|strong="H1961"\w* \w los|strong="H1931"\w* \w años|strong="H8141"\w* \w de|strong="H7911"\w* un \w rey|strong="H4428"\w*. \w Al|strong="H4428"\w* terminar \w los|strong="H1931"\w* 70 \w años|strong="H8141"\w*, \w sucederá|strong="H1961"\w* \w a|strong="H3068"\w* \w Tiro|strong="H6865"\w* \w lo|strong="H1931"\w* del canto \w de|strong="H7911"\w* \w la|strong="H1931"\w* prostituta.
\v 16 \w Toma|strong="H3947"\w* el \w arpa|strong="H3658"\w* y rodea la \w ciudad|strong="H5892"\w*, oh prostituta \w olvidada|strong="H7911"\w*. \w Haz|strong="H3190"\w* buena \w melodía|strong="H5059"\w*. Repite la \w canción|strong="H7892"\w* \w para|strong="H4616"\w* \w que|strong="H4616"\w* seas recordada.
\p 
\v 17 \w Al|strong="H5921"\w* \w fin|strong="H7093"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* 70 \w años|strong="H8141"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w visitará|strong="H6485"\w* \w a|strong="H3068"\w* \w Tiro|strong="H6865"\w*. \w Ella|strong="H5921"\w* \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* su salario \w de|strong="H5921"\w* prostituta \w y|strong="H5921"\w* \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* fornicar \w con|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* \w del|strong="H5921"\w* mundo \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.
\v 18 \w Pero|strong="H3588"\w* \w su|strong="H3588"\w* paga \w estará|strong="H1961"\w* \w consagrada|strong="H6944"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w No|strong="H3808"\w* \w se|strong="H1961"\w* atesorará \w ni|strong="H3808"\w* \w se|strong="H1961"\w* acumulará, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* ganancia \w será|strong="H1961"\w* \w para|strong="H3588"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w estén|strong="H1961"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* coman hasta saciarse \w y|strong="H3588"\w* \w se|strong="H1961"\w* cubran \w con|strong="H3588"\w* esplendidez.
\c 24
\s1 Juicio contra toda la Tierra
\p 
\v 1 \w Ciertamente|strong="H2009"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w vacía|strong="H1238"\w* la tierra y la deja desolada. Trastorna su superficie y \w esparce|strong="H6327"\w* \w a|strong="H3068"\w* sus \w habitantes|strong="H3427"\w*,
\v 2 tanto al \w pueblo|strong="H5971"\w* \w como|strong="H1961"\w* al \w sacerdote|strong="H3548"\w*, al esclavo \w como|strong="H1961"\w* \w a|strong="H3068"\w* su amo, \w a|strong="H3068"\w* la esclava \w como|strong="H1961"\w* \w a|strong="H3068"\w* su ama, al comprador \w como|strong="H1961"\w* al vendedor, al prestamista \w como|strong="H1961"\w* al \w que|strong="H5971"\w* toma prestado, al acreedor \w como|strong="H1961"\w* al deudor.
\v 3 \w La|strong="H3588"\w* tierra será completamente vaciada, totalmente saqueada.
\p \nd \w Yavé|strong="H3068"\w*\nd* \w pronunció|strong="H1696"\w* \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w*:
\v 4 \wj La tierra \w se|strong="H5971"\w* lamenta y \w se|strong="H5971"\w* marchita. Languidece el \w mundo|strong="H8398"\w*, \w se|strong="H5971"\w* debilita. Los exaltados del \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* la tierra desfallecen.\wj*
\v 5 \wj \w La|strong="H3588"\w* tierra fue contaminada \w por|strong="H3588"\w* sus \w habitantes|strong="H3427"\w*, \w porque|strong="H3588"\w* transgredieron las \w Leyes|strong="H8451"\w*, violaron las \w Ordenanzas|strong="H2706"\w* \w y|strong="H3588"\w* quebrantaron \w el|strong="H3588"\w* \w Pacto|strong="H1285"\w* \w eterno|strong="H5769"\w*.\wj*
\v 6 \wj \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w* \w la|strong="H5921"\w* maldición devora \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w los|strong="H3427"\w* \w que|strong="H5921"\w* viven \w en|strong="H5921"\w* \w ella|strong="H5921"\w* son culpables. \w Como|strong="H5921"\w* resultado \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra son consumidos, \w y|strong="H5921"\w* quedan pocos hombres.\wj*
\p 
\v 7 \w El|strong="H3605"\w* \w vino|strong="H8492"\w* nuevo languidece, se marchita \w la|strong="H3605"\w* \w vid|strong="H1612"\w* y gimen \w los|strong="H3605"\w* \w que|strong="H3605"\w* eran de \w corazón|strong="H3820"\w* \w alegre|strong="H8056"\w*.
\v 8 Se acaba el júbilo de los panderos. \w Cesa|strong="H2308"\w* el bullicio de los que se divierten. Se suspende la alegría del \w arpa|strong="H3658"\w*.
\v 9 \w No|strong="H3808"\w* \w beben|strong="H8354"\w* \w vino|strong="H3196"\w* \w entre|strong="H3808"\w* \w canciones|strong="H7892"\w*. El licor es amargo para los \w que|strong="H3808"\w* \w lo|strong="H3808"\w* \w beben|strong="H8354"\w*.
\v 10 \w La|strong="H3605"\w* \w ciudad|strong="H7151"\w* está \w quebrantada|strong="H7665"\w* por \w el|strong="H3605"\w* caos. \w Toda|strong="H3605"\w* \w casa|strong="H1004"\w* está \w cerrada|strong="H5462"\w* para \w que|strong="H3605"\w* \w nadie|strong="H3605"\w* entre.
\v 11 Hay lamentos \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w calles|strong="H2351"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* falta \w de|strong="H5921"\w* \w vino|strong="H3196"\w*. \w Todo|strong="H3605"\w* \w gozo|strong="H8057"\w* \w se|strong="H5921"\w* oscurece. \w La|strong="H5921"\w* \w alegría|strong="H8057"\w* salió \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.
\v 12 La \w ciudad|strong="H5892"\w* \w quedó|strong="H7604"\w* desolada. Su \w puerta|strong="H8179"\w* fue golpeada con destrucción.
\p 
\v 13 \w Sucederá|strong="H1961"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w y|strong="H3588"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w pueblos|strong="H5971"\w* \w como|strong="H3588"\w* \w cuando|strong="H3588"\w* \w se|strong="H1961"\w* sacude \w el|strong="H3588"\w* olivo \w o|strong="H3068"\w* \w en|strong="H8432"\w* \w el|strong="H3588"\w* rebusco \w después|strong="H1961"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* cosecha.
\v 14 \w A|strong="H3068"\w* causa de la majestad de \nd \w Yavé|strong="H3068"\w*\nd*, \w alzarán|strong="H5375"\w* la \w voz|strong="H6963"\w* desde \w el|strong="H1992"\w* occidente y dirán:
\v 15 ¡Aclamen \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w desde|strong="H5921"\w* \w el|strong="H5921"\w* oriente, \w desde|strong="H5921"\w* \w las|strong="H5921"\w* costas \w del|strong="H5921"\w* \w mar|strong="H3220"\w*, \w al|strong="H5921"\w* \w Nombre|strong="H8034"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w el|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*!
\v 16 \w Oímos|strong="H8085"\w* \w cánticos|strong="H2158"\w* desde el extremo \w de|strong="H6662"\w* la tierra: ¡\w Gloria|strong="H6643"\w* al \w Justo|strong="H6662"\w*! Pero yo digo: ¡Qué dolor! ¡Qué dolor! ¡Ay \w de|strong="H6662"\w* mí! Los traidores traicionan. Los traidores traicionan con gran traición.
\v 17 ¡\w Terror|strong="H6343"\w*, fosa \w y|strong="H5921"\w* trampa hay \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, oh habitante \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra!
\p 
\v 18 \w Acontecerá|strong="H1961"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* huya del informe del desastre \w caerá|strong="H5307"\w* \w en|strong="H8432"\w* \w la|strong="H3588"\w* fosa. \w El|strong="H3588"\w* \w que|strong="H3588"\w* salga \w de|strong="H3588"\w* \w la|strong="H3588"\w* fosa \w será|strong="H1961"\w* atrapado \w en|strong="H8432"\w* \w la|strong="H3588"\w* red. Las ventanas \w de|strong="H3588"\w* lo \w alto|strong="H4791"\w* \w están|strong="H1961"\w* \w abiertas|strong="H6605"\w*. \w Los|strong="H1961"\w* cimientos \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w se|strong="H1961"\w* conmueven.
\v 19 La tierra será completamente destrozada, completamente \w desmenuzada|strong="H6565"\w*. Se deshace en pedazos. En gran manera será derrumbada.
\v 20 \w La|strong="H5921"\w* tierra \w se|strong="H5921"\w* tambalea \w como|strong="H5921"\w* un ebrio \w y|strong="H5921"\w* \w será|strong="H3808"\w* removida \w como|strong="H5921"\w* una choza. ¡\w Tanto|strong="H5921"\w* \w le|strong="H5921"\w* pesa su \w pecado|strong="H6588"\w*! \w Se|strong="H5921"\w* desploma \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w volverá|strong="H3254"\w* \w a|strong="H3068"\w* \w levantarse|strong="H6965"\w*.
\p 
\v 21 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \nd \w Yavé|strong="H3068"\w*\nd* castigará \w en|strong="H5921"\w* \w lo|strong="H1931"\w* \w alto|strong="H4791"\w* \w al|strong="H5921"\w* \w ejército|strong="H6635"\w* \w de|strong="H5921"\w* \w lo|strong="H1931"\w* \w alto|strong="H4791"\w*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w la|strong="H1931"\w* tierra \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* tierra.
\v 22 Serán agrupados \w como|strong="H5921"\w* \w se|strong="H5921"\w* agrupa \w a|strong="H3068"\w* \w los|strong="H5921"\w* prisioneros \w en|strong="H5921"\w* prisiones subterráneas. Quedarán encerrados, \w y|strong="H5921"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w muchos|strong="H7230"\w* \w días|strong="H3117"\w* serán castigados.
\v 23 \w La|strong="H3588"\w* luna se avergonzará, \w y|strong="H3588"\w* \w el|strong="H3588"\w* sol se confundirá, \w cuando|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H3588"\w* las huestes \w reine|strong="H4427"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* Montaña \w Sion|strong="H6726"\w* \w y|strong="H3588"\w* \w en|strong="H3588"\w* Jerusalén, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w gloria|strong="H3519"\w* esté ante sus \w ancianos|strong="H2205"\w*.
\c 25
\p 
\v 1 Oh \nd \w Yavé|strong="H3068"\w*\nd*, \w Tú|strong="H6213"\w* eres mi \nd ʼElohim\nd*. \w Te|strong="H3588"\w* exaltaré. \w Alabaré|strong="H3034"\w* \w tu|strong="H6213"\w* \w Nombre|strong="H8034"\w*, \w porque|strong="H3588"\w* \w hiciste|strong="H6213"\w* \w maravillas|strong="H6382"\w*, tus designios \w antiguos|strong="H7350"\w*, \w con|strong="H3588"\w* perfecta fidelidad.
\v 2 \w Porque|strong="H3588"\w* convertiste \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w* \w en|strong="H3588"\w* una pila \w de|strong="H3588"\w* escombros. \w La|strong="H3588"\w* \w ciudad|strong="H5892"\w* fortificada \w en|strong="H3588"\w* ruinas. \add El\add* palacio \w de|strong="H3588"\w* extranjeros ya \w no|strong="H3808"\w* existe. \w Nunca|strong="H3808"\w* \w será|strong="H3808"\w* reconstruido.
\v 3 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w* un \w pueblo|strong="H5971"\w* \w fuerte|strong="H5794"\w* \w te|strong="H5921"\w* glorifica. \w Las|strong="H5921"\w* ciudades \w de|strong="H5921"\w* \w naciones|strong="H1471"\w* crueles \w te|strong="H5921"\w* \w temen|strong="H3372"\w*.
\v 4 \w Porque|strong="H3588"\w* \w fuiste|strong="H1961"\w* \w fortaleza|strong="H4581"\w* \w para|strong="H3588"\w* \w el|strong="H3588"\w* \w pobre|strong="H1800"\w*, \w fortaleza|strong="H4581"\w* \w para|strong="H3588"\w* \w el|strong="H3588"\w* necesitado \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w aflicción|strong="H6862"\w*, refugio \w de|strong="H3588"\w* \w la|strong="H3588"\w* tormenta, \w sombra|strong="H6738"\w* \w contra|strong="H1961"\w* \w el|strong="H3588"\w* calor. \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* aliento \w de|strong="H3588"\w* \w los|strong="H1961"\w* tiranos \w es|strong="H1961"\w* \w como|strong="H3588"\w* una tormenta \w contra|strong="H1961"\w* un muro.
\v 5 \w Como|strong="H5645"\w* el calor en un sequedal, así abates el tumulto de los extranjeros. \w Como|strong="H5645"\w* el calor bajo la \w sombra|strong="H6738"\w* de una \w nube|strong="H5645"\w*, silencias el cántico de los tiranos.
\p 
\v 6 En \w esta|strong="H2088"\w* Montaña \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5971"\w* las huestes \w ofrecerá|strong="H6213"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w* un \w banquete|strong="H4960"\w* con manjares suculentos, un \w banquete|strong="H4960"\w* con vinos añejos, con presas escogidas llenas \w de|strong="H5971"\w* médula y con vino añejo purificado.
\v 7 \w En|strong="H5921"\w* \w esta|strong="H2088"\w* Montaña \w destruirá|strong="H1104"\w* \w la|strong="H5921"\w* ropa \w que|strong="H5921"\w* cubre \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* velo \w que|strong="H5921"\w* envuelve \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*.
\v 8 ¡\w Él|strong="H5921"\w* sorberá \w la|strong="H5921"\w* \w muerte|strong="H4194"\w* \w para|strong="H5921"\w* \w siempre|strong="H3605"\w*! \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* enjugará \w las|strong="H5921"\w* \w lágrimas|strong="H1832"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* semblante \w y|strong="H3588"\w* \w quitará|strong="H5493"\w* \w el|strong="H5921"\w* \w oprobio|strong="H2781"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w en|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w habló|strong="H1696"\w*.
\p 
\v 9 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w se|strong="H1931"\w* dirá: \w Ciertamente|strong="H2009"\w* \w Éste|strong="H2088"\w* \w es|strong="H1931"\w* nuestro \nd ʼElohim\nd*. \w Lo|strong="H1931"\w* \w esperamos|strong="H6960"\w*, y nos \w salvó|strong="H3467"\w*. \w Éste|strong="H2088"\w* \w es|strong="H1931"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w a|strong="H3068"\w* \w Quien|strong="H1931"\w* \w esperamos|strong="H6960"\w*. Regocijémonos y alegrémonos \w por|strong="H2088"\w* \w su|strong="H1931"\w* salvación.
\p 
\v 10 \w La|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w reposará|strong="H5117"\w* sobre \w esta|strong="H2088"\w* Montaña. \w Moab|strong="H4124"\w* será pisoteado \w en|strong="H3588"\w* \w su|strong="H3588"\w* sitio, \w como|strong="H3588"\w* se pisa \w el|strong="H3588"\w* pasto \w en|strong="H3588"\w* \w el|strong="H3588"\w* agua \w de|strong="H3588"\w* una pila \w de|strong="H3588"\w* estiércol.
\v 11 Extenderá sus \w manos|strong="H3027"\w* \w en|strong="H5973"\w* \w medio|strong="H3027"\w* \w de|strong="H5973"\w* \w él|strong="H5973"\w* \w como|strong="H5973"\w* \w el|strong="H5973"\w* nadador \w al|strong="H7130"\w* nadar, pero \w Él|strong="H5973"\w* abatirá su \w soberbia|strong="H1346"\w* y \w el|strong="H5973"\w* esfuerzo \w de|strong="H5973"\w* sus \w manos|strong="H3027"\w*,
\v 12 \w y|strong="H5704"\w* derribará la \w fortaleza|strong="H4013"\w* \w de|strong="H5704"\w* sus altos \w muros|strong="H2346"\w*. \w Lo|strong="H5704"\w* humillará \w y|strong="H5704"\w* \w lo|strong="H5704"\w* echará \w a|strong="H3068"\w* \w tierra|strong="H6083"\w* \w hasta|strong="H5704"\w* el \w polvo|strong="H6083"\w*.
\c 26
\s1 El castigo de \nd Yavé\nd* para los perversos
\p 
\v 1 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w se|strong="H1931"\w* \w cantará|strong="H7891"\w* \w este|strong="H2088"\w* \w cántico|strong="H7892"\w* en \w la|strong="H1931"\w* tierra de \w Judá|strong="H3063"\w*: \w Ciudad|strong="H5892"\w* \w fuerte|strong="H5794"\w* tenemos. \w Le|strong="H1931"\w* \w puso|strong="H7896"\w* salvación \w como|strong="H1931"\w* \w muro|strong="H2346"\w* y antemuro.
\v 2 Abran las \w puertas|strong="H8179"\w* y entrará un pueblo \w justo|strong="H6662"\w* Que \w guarda|strong="H8104"\w* \w la|strong="H8104"\w* fidelidad.
\v 3 Tú \w guardarás|strong="H5341"\w* \w en|strong="H3588"\w* completa \w paz|strong="H7965"\w* \w a|strong="H3068"\w* aquel cuyo \w pensamiento|strong="H3336"\w* \w persevera|strong="H5564"\w* \w en|strong="H3588"\w* ti, \w porque|strong="H3588"\w* \w en|strong="H3588"\w* Ti confió.
\v 4 Confíen \w en|strong="H5704"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w perpetuamente|strong="H5769"\w*, \w porque|strong="H3588"\w* \nd \w YA|strong="H3068"\w*\nd* \nd \w Yavé|strong="H3068"\w*\nd* \w es|strong="H3588"\w* \w la|strong="H3588"\w* \w Roca|strong="H6697"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w siglos|strong="H5769"\w*.
\v 5 \w Derribó|strong="H7817"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w vivían|strong="H3427"\w* \w en|strong="H5704"\w* las \w alturas|strong="H4791"\w*. Humilló \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w ciudad|strong="H7151"\w* exaltada. \w La|strong="H3588"\w* abatió \w hasta|strong="H5704"\w* \w la|strong="H3588"\w* \w tierra|strong="H6083"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w derribó|strong="H7817"\w* \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w polvo|strong="H6083"\w*.
\v 6 Será pisoteada por los \w pies|strong="H7272"\w* del \w afligido|strong="H6041"\w*, por las pisadas de los necesitados.
\p 
\v 7 La senda del \w justo|strong="H6662"\w* es \w recta|strong="H3477"\w*. Tú allanas la senda del \w justo|strong="H6662"\w*.
\v 8 Oh \nd \w Yavé|strong="H3068"\w*\nd*, en la senda de tus \w juicios|strong="H4941"\w* \w te|strong="H5315"\w* \w esperamos|strong="H6960"\w*. Tu \w Nombre|strong="H8034"\w* y tu \w memoria|strong="H2143"\w* son el anhelo de nuestra \w alma|strong="H5315"\w*.
\v 9 \w Mi|strong="H5315"\w* \w alma|strong="H5315"\w* \w te|strong="H3588"\w* anhela \w de|strong="H3588"\w* \w noche|strong="H3915"\w*, \w mientras|strong="H3588"\w* haya aliento \w en|strong="H3588"\w* \w mí|strong="H5315"\w* madrugaré \w a|strong="H3068"\w* buscarte. \w Porque|strong="H3588"\w* \w cuando|strong="H3588"\w* hay \w juicios|strong="H4941"\w* tuyos \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* del \w mundo|strong="H8398"\w* \w aprenden|strong="H3925"\w* \w justicia|strong="H6664"\w*.
\v 10 Aunque se muestre \w compasión|strong="H2603"\w* al perverso, \w no|strong="H1077"\w* \w aprenderá|strong="H3925"\w* \w justicia|strong="H6664"\w*. Aunque esté en tierra de rectitud, él hace iniquidad y \w no|strong="H1077"\w* considera la majestad de \nd \w Yavé|strong="H3068"\w*\nd*.
\v 11 Oh \nd \w Yavé|strong="H3068"\w*\nd*, tu \w mano|strong="H3027"\w* está levantada, pero \w ellos|strong="H3027"\w* \w no|strong="H1077"\w* la miran. La mirarán al fin y los \w que|strong="H5971"\w* envidian \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* avergonzarán. Fuego consumirá \w a|strong="H3068"\w* tus \w enemigos|strong="H6862"\w*.
\v 12 Tú, oh \nd \w Yavé|strong="H3068"\w*\nd*, estableces \w paz|strong="H7965"\w* \w para|strong="H3588"\w* \w nosotros|strong="H3605"\w*, \w porque|strong="H3588"\w* \w también|strong="H1571"\w* \w todas|strong="H3605"\w* nuestras \w obras|strong="H4639"\w* las realizas \w por|strong="H3588"\w* \w nosotros|strong="H3605"\w*.
\v 13 Oh \nd \w Yavé|strong="H3068"\w* ʼElohim\nd* nuestro, otros amos aparte \w de|strong="H2108"\w* Ti nos dominaron, aunque solo confesamos tu \w Nombre|strong="H8034"\w*.
\v 14 Están \w muertos|strong="H4191"\w*, \w no|strong="H1077"\w* \w vivirán|strong="H2421"\w*. \w Murieron|strong="H4191"\w*, \w no|strong="H1077"\w* \w se|strong="H3651"\w* levantarán, porque \w los|strong="H3605"\w* castigaste. \w Los|strong="H3605"\w* destruiste y deshiciste su recuerdo.
\v 15 Multiplicaste \w el|strong="H3605"\w* pueblo, oh \nd \w Yavé|strong="H3068"\w*\nd*. Aumentaste \w el|strong="H3605"\w* pueblo y \w lo|strong="H3605"\w* hiciste \w glorioso|strong="H3513"\w*. Ensanchaste \w todas|strong="H3605"\w* las fronteras de \w la|strong="H3605"\w* tierra.
\p 
\v 16 Oh \nd \w Yavé|strong="H3068"\w*\nd*, en la \w tribulación|strong="H6862"\w* te buscaron. Solo pudieron susurrar una oración. Tu castigo estaba sobre ellos.
\v 17 \w Como|strong="H3644"\w* la mujer embarazada \w que|strong="H1961"\w* \w se|strong="H1961"\w* acerca al parto \w se|strong="H1961"\w* retuerce y grita \w de|strong="H6440"\w* \w dolor|strong="H2342"\w*, \w así|strong="H3651"\w* estuvimos en tu \w Presencia|strong="H6440"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*.
\v 18 \w Concebimos|strong="H2029"\w*, tuvimos dolores de parto, pero dimos \w a|strong="H3068"\w* luz \w viento|strong="H7307"\w*. \w No|strong="H1077"\w* logramos liberación para la tierra, \w ni|strong="H1077"\w* \w nacieron|strong="H3205"\w* \w habitantes|strong="H3427"\w* del \w mundo|strong="H8398"\w*.
\v 19 Tus \w muertos|strong="H4191"\w* \w vivirán|strong="H2421"\w*. Tus cadáveres \w resucitarán|strong="H6965"\w*. Ustedes \w los|strong="H3588"\w* \w que|strong="H3588"\w* están \w tendidos|strong="H5307"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w polvo|strong="H6083"\w* despierten \w y|strong="H3588"\w* \w canten|strong="H7442"\w* jubilosos. \w Porque|strong="H3588"\w* tu \w rocío|strong="H2919"\w* \w es|strong="H3588"\w* \w como|strong="H3588"\w* \w rocío|strong="H2919"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* aurora. \w La|strong="H3588"\w* \w tierra|strong="H6083"\w* dará \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* sus fallecidos.
\p 
\v 20 \w Anda|strong="H3212"\w*, \w pueblo|strong="H5971"\w* \w mío|strong="H5971"\w*, entra \w en|strong="H5704"\w* tus aposentos. \w Cierra|strong="H5462"\w* \w tras|strong="H1157"\w* ti tus \w puertas|strong="H1817"\w*. \w Escóndete|strong="H2247"\w* \w por|strong="H1157"\w* un breve \w momento|strong="H7281"\w* \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w pase|strong="H5674"\w* la \w ira|strong="H3212"\w*.
\v 21 \w Ciertamente|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w sale|strong="H3318"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w morada|strong="H3427"\w* \w para|strong="H5921"\w* castigar \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w por|strong="H5921"\w* \w su|strong="H3588"\w* \w iniquidad|strong="H5771"\w*. \w La|strong="H5921"\w* tierra mostrará \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* derramada \w y|strong="H3588"\w* ya \w no|strong="H3808"\w* \w encubrirá|strong="H3680"\w* \w a|strong="H3068"\w* sus asesinados.
\c 27
\s1 El regreso de Israel a su tierra
\p 
\v 1 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \nd \w Yavé|strong="H3068"\w*\nd* castigará \w con|strong="H5921"\w* \w su|strong="H1931"\w* \w espada|strong="H2719"\w* \w dura|strong="H7186"\w*, \w grande|strong="H1419"\w* \w y|strong="H5921"\w* \w poderosa|strong="H2389"\w* \w al|strong="H5921"\w* cocodrilo, \w serpiente|strong="H5175"\w* veloz, \w al|strong="H5921"\w* Cocodrilo, \w serpiente|strong="H5175"\w* \w tortuosa|strong="H1281"\w*, \w y|strong="H5921"\w* \w matará|strong="H2026"\w* \w al|strong="H5921"\w* \w dragón|strong="H8577"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w*.
\p 
\v 2 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* elevarán \w el|strong="H1931"\w* cántico de \w la|strong="H1931"\w* \w viña|strong="H3754"\w* deleitosa:
\v 3 \wj Yo, \nd \w Yavé|strong="H3068"\w*\nd*, soy su Guardián. \w La|strong="H5921"\w* riego \w en|strong="H5921"\w* todo \w momento|strong="H7281"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* nadie \w la|strong="H5921"\w* dañe. \w La|strong="H5921"\w* cuido \w noche|strong="H3915"\w* \w y|strong="H5921"\w* \w día|strong="H3117"\w*.\wj*
\v 4 \wj No \w hay|strong="H4310"\w* \w ira|strong="H2534"\w* en Mí. ¿\w Quién|strong="H4310"\w* \w pondrá|strong="H5414"\w* contra Mí \w cardos|strong="H8068"\w* y \w espinos|strong="H8068"\w*? \w Me|strong="H4310"\w* lanzaría sobre ellos y los quemaría \w de|strong="H5414"\w* inmediato.\wj*
\v 5 \wj \w O|strong="H3068"\w* que \w él|strong="H6213"\w* se acoja \w a|strong="H3068"\w* mi amparo y \w haga|strong="H6213"\w* la \w paz|strong="H7965"\w* \w conmigo|strong="H6213"\w*. \w Él|strong="H6213"\w* puede \w hacer|strong="H6213"\w* la \w paz|strong="H7965"\w* \w conmigo|strong="H6213"\w*.\wj*
\p 
\v 6 Días vendrán cuando \w Jacob|strong="H3290"\w* echará raíz y \w florecerá|strong="H6524"\w*. Le saldrán nuevas ramas y llenarán la superficie del \w mundo|strong="H8398"\w* con su \w fruto|strong="H8570"\w*.
\v 7 ¿Él fue herido como \w hirió|strong="H5221"\w* al que lo \w hería|strong="H5221"\w*, \w o|strong="H3068"\w* él murió como murieron sus asesinos?
\v 8 Tú contendiste contra ella. Los \w enviaste|strong="H7971"\w* lejos. Con tu fuerte \w viento|strong="H7307"\w* los expulsaste el \w día|strong="H3117"\w* del \w viento|strong="H7307"\w* del este.
\v 9 De \w esta|strong="H2063"\w* manera \w será|strong="H3808"\w* perdonada \w la|strong="H2063"\w* \w iniquidad|strong="H5771"\w* de \w Jacob|strong="H3290"\w*. \w Éste|strong="H2088"\w* \w será|strong="H3808"\w* \w el|strong="H3605"\w* precio completo de perdonar su \w pecado|strong="H2403"\w*, cuando \w él|strong="H3605"\w* convierta \w todas|strong="H3605"\w* las piedras \w del|strong="H4196"\w* \w altar|strong="H4196"\w* \w en|strong="H5493"\w* piedras de cal pulverizadas, y \w no|strong="H3808"\w* \w se|strong="H3808"\w* levanten \w los|strong="H3605"\w* símbolos de Asera, \w ni|strong="H3808"\w* las imágenes \w del|strong="H4196"\w* sol.
\v 10 \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w* fortificada será desolada. \w La|strong="H3588"\w* \w ciudad|strong="H5892"\w* habitada será \w abandonada|strong="H5800"\w* \w y|strong="H3588"\w* \w dejada|strong="H7971"\w* desierta. \w Allí|strong="H8033"\w* pastará \w el|strong="H3588"\w* \w becerro|strong="H5695"\w*. \w Allí|strong="H8033"\w* tendrá \w su|strong="H3588"\w* corral \w y|strong="H3588"\w* acabará sus ramas.
\v 11 \w Cuando|strong="H3588"\w* \w sus|strong="H1931"\w* \w ramas|strong="H7105"\w* \w se|strong="H1931"\w* sequen \w serán|strong="H1931"\w* quebradas. Mujeres llegarán \w a|strong="H3068"\w* encenderlas. \w Porque|strong="H3588"\w* \w aquél|strong="H1931"\w* \w no|strong="H3808"\w* \w es|strong="H1931"\w* un \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* entendimiento. \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w su|strong="H1931"\w* \w Hacedor|strong="H6213"\w* \w no|strong="H3808"\w* tendrá \w misericordia|strong="H7355"\w* \w de|strong="H5921"\w* \w él|strong="H1931"\w*. \w El|strong="H1931"\w* \w que|strong="H3588"\w* \w lo|strong="H1931"\w* \w formó|strong="H3335"\w* \w no|strong="H3808"\w* \w se|strong="H1931"\w* compadecerá.
\p 
\v 12 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \nd \w Yavé|strong="H3068"\w*\nd* golpeará \w con|strong="H5704"\w* vara, \w desde|strong="H5704"\w* \w el|strong="H1931"\w* Gran \w Río|strong="H5104"\w* \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* \w arroyo|strong="H5158"\w* \w de|strong="H5704"\w* \w Egipto|strong="H4714"\w*. \w Y|strong="H3068"\w* ustedes, \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*, \w serán|strong="H1961"\w* recogidos uno \w por|strong="H5704"\w* uno.
\v 13 \w Acontecerá|strong="H1961"\w* también \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w que|strong="H1931"\w* \w se|strong="H1961"\w* \w tocará|strong="H8628"\w* \w la|strong="H1931"\w* \w gran|strong="H1419"\w* \w trompeta|strong="H7782"\w*. Vendrán \w los|strong="H1931"\w* \w que|strong="H1931"\w* \w fueron|strong="H1961"\w* dispersados en \w la|strong="H1931"\w* tierra de Asiria y \w los|strong="H1931"\w* dispersados en \w la|strong="H1931"\w* tierra de \w Egipto|strong="H4714"\w*. \w Se|strong="H1961"\w* postrarán ante \nd \w Yavé|strong="H3068"\w*\nd* en \w la|strong="H1931"\w* Montaña \w Santa|strong="H6944"\w*, en Jerusalén.
\c 28
\s1 Profecía contra Efraín
\p 
\v 1 ¡\w Ay|strong="H1945"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* arrogante \w corona|strong="H5850"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* ebrios \w de|strong="H5921"\w* Efraín \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* flor marchita \w de|strong="H5921"\w* su gloriosa \w hermosura|strong="H6643"\w* \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* jactan \w en|strong="H5921"\w* \w la|strong="H5921"\w* abundancia, aturdidos \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w vino|strong="H3196"\w*!
\v 2 \w Ciertamente|strong="H2009"\w* \nd ʼAdonay\nd* tiene uno \w que|strong="H4325"\w* \w es|strong="H3027"\w* \w fuerte|strong="H2389"\w* y poderoso, como aguacero \w de|strong="H4325"\w* \w granizo|strong="H1259"\w*, como tormenta trastornadora, y como aguacero \w de|strong="H4325"\w* recias \w aguas|strong="H4325"\w* desbordantes \w que|strong="H4325"\w* derriban la tierra con fuerza.
\v 3 Con los \w pies|strong="H7272"\w* pisoteará la arrogante \w corona|strong="H5850"\w* de los ebrios de Efraín
\v 4 \w y|strong="H5921"\w* \w la|strong="H5921"\w* flor marchita \w de|strong="H5921"\w* su gloriosa \w hermosura|strong="H6643"\w* \w que|strong="H5921"\w* \w está|strong="H1961"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H1961"\w* jactan \w de|strong="H5921"\w* \w la|strong="H5921"\w* abundancia. \w Será|strong="H1961"\w* \w como|strong="H1961"\w* \w la|strong="H5921"\w* fruta temprana \w que|strong="H5921"\w* llega \w antes|strong="H2962"\w* \w del|strong="H5921"\w* \w verano|strong="H7019"\w*, \w la|strong="H5921"\w* cual \w cuando|strong="H1961"\w* \w alguno|strong="H5750"\w* \w la|strong="H5921"\w* \w mira|strong="H7200"\w*, \w se|strong="H1961"\w* \w la|strong="H5921"\w* traga tan pronto \w como|strong="H1961"\w* \w la|strong="H5921"\w* \w tiene|strong="H1961"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3709"\w*.
\p 
\v 5 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5971"\w* las huestes \w será|strong="H1961"\w* \w corona|strong="H5850"\w* \w de|strong="H5971"\w* \w gloria|strong="H6643"\w* y diadema \w de|strong="H5971"\w* \w hermosura|strong="H6643"\w* al remanente \w de|strong="H5971"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*,
\v 6 \w y|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w justicia|strong="H4941"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* sienta \w a|strong="H3068"\w* juzgar, valor \w para|strong="H5921"\w* \w los|strong="H3427"\w* \w que|strong="H5921"\w* repelen \w el|strong="H5921"\w* asalto \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w*.
\p 
\v 7 \w Éstos|strong="H1571"\w* \w también|strong="H1571"\w* \w erraron|strong="H7686"\w* \w a|strong="H3068"\w* causa \w del|strong="H4480"\w* \w vino|strong="H3196"\w* \w y|strong="H1571"\w* \w se|strong="H4480"\w* entontecieron \w con|strong="H4480"\w* \w el|strong="H5030"\w* licor. \w Sacerdotes|strong="H3548"\w* \w y|strong="H1571"\w* \w profetas|strong="H5030"\w* \w se|strong="H4480"\w* tambalean \w por|strong="H4480"\w* \w el|strong="H5030"\w* licor. Los aturde \w el|strong="H5030"\w* \w vino|strong="H3196"\w*. Dan traspiés \w por|strong="H4480"\w* \w el|strong="H5030"\w* licor. \w El|strong="H5030"\w* \w sacerdote|strong="H3548"\w* \w y|strong="H1571"\w* \w el|strong="H5030"\w* \w profeta|strong="H5030"\w* \w erraron|strong="H7686"\w* \w por|strong="H4480"\w* \w el|strong="H5030"\w* licor. Fueron trastornados \w por|strong="H4480"\w* \w el|strong="H5030"\w* \w vino|strong="H3196"\w*. \w Erraron|strong="H7686"\w* \w en|strong="H4480"\w* \w la|strong="H1571"\w* visión. Titubean \w en|strong="H4480"\w* \w la|strong="H1571"\w* sentencia.
\v 8 \w Todas|strong="H3605"\w* las \w mesas|strong="H7979"\w* están \w llenas|strong="H4390"\w* \w de|strong="H3588"\w* \w vómito|strong="H6892"\w* \w y|strong="H3588"\w* suciedad, \w y|strong="H3588"\w* \w no|strong="H1097"\w* queda \w sitio|strong="H4725"\w* limpio.
\v 9 ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* \w enseñará|strong="H3384"\w* \w conocimiento|strong="H1844"\w*? ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* interpretará \w el|strong="H4310"\w* mensaje? ¿\w A|strong="H3068"\w* los \w que|strong="H4310"\w* acaban de ser destetados? ¿\w A|strong="H3068"\w* los \w que|strong="H4310"\w* acaban de ser quitados del pecho materno?
\v 10 \w Porque|strong="H3588"\w* \w es|strong="H3588"\w* precepto \w a|strong="H3068"\w* precepto, \w mandamiento|strong="H6673"\w* \w a|strong="H3068"\w* \w mandamiento|strong="H6673"\w*, \w renglón|strong="H6957"\w* \w por|strong="H3588"\w* \w renglón|strong="H6957"\w*, \w línea|strong="H6957"\w* \w por|strong="H3588"\w* \w línea|strong="H6957"\w*, un \w poquito|strong="H2191"\w* \w allí|strong="H8033"\w*, otro \w poquito|strong="H2191"\w* \w allá|strong="H8033"\w*.
\v 11 \w En|strong="H3588"\w* verdad, \w en|strong="H3588"\w* \w lenguaje|strong="H8193"\w* humillante, \w en|strong="H3588"\w* \w lengua|strong="H3956"\w* extraña \w Él|strong="H3588"\w* \w hablará|strong="H1696"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*,
\v 12 el \w que|strong="H3808"\w* les dijo: \wj Aquí \w está|strong="H2063"\w* el \w reposo|strong="H4496"\w*. Den \w reposo|strong="H4496"\w* al \w cansado|strong="H5889"\w*. \w Esto|strong="H2063"\w* \w es|strong="H2063"\w* lugar de \w descanso|strong="H4496"\w*.\wj* Pero \w no|strong="H3808"\w* quisieron \w escuchar|strong="H8085"\w*.
\v 13 \w Por|strong="H4616"\w* \w lo|strong="H1697"\w* cual, la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w para|strong="H4616"\w* \w ellos|strong="H1992"\w* \w será|strong="H1961"\w* precepto \w por|strong="H4616"\w* precepto, \w mandamiento|strong="H6673"\w* \w por|strong="H4616"\w* \w mandamiento|strong="H6673"\w*, \w renglón|strong="H6957"\w* \w por|strong="H4616"\w* \w renglón|strong="H6957"\w*, \w línea|strong="H6957"\w* \w por|strong="H4616"\w* \w línea|strong="H6957"\w*, un \w poquito|strong="H2191"\w* \w allí|strong="H8033"\w*, \w otro|strong="H4616"\w* \w poquito|strong="H2191"\w* \w allá|strong="H8033"\w*, hasta \w que|strong="H1697"\w* \w vayan|strong="H3212"\w* y caigan \w de|strong="H1697"\w* espalda, \w sean|strong="H1961"\w* quebrantados, enredados y llevados cautivos.
\s1 Mensaje para los escarnecedores de Jerusalén
\p 
\v 14 \w Por|strong="H1697"\w* \w tanto|strong="H3651"\w*, oh varones burlones \w que|strong="H5971"\w* gobiernan \w a|strong="H3068"\w* \w ese|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* Jerusalén: \w Escuchen|strong="H8085"\w* la \w Palabra|strong="H1697"\w* \w de|strong="H5971"\w* \nd \w Yavé|strong="H3068"\w*\nd*:
\v 15 \wj \w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* dijeron: \w Hicimos|strong="H6213"\w* un \w pacto|strong="H1285"\w* \w con|strong="H5973"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w* \w y|strong="H3588"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* \tl Seol\tl* tenemos convenio. \w Cuando|strong="H3588"\w* \w pase|strong="H5674"\w* \w el|strong="H5973"\w* aguacero \w como|strong="H3588"\w* torrente, \w no|strong="H3808"\w* llegará \w a|strong="H3068"\w* \w nosotros|strong="H5973"\w*, \w porque|strong="H3588"\w* designamos \w la|strong="H3588"\w* \w mentira|strong="H8267"\w* \w como|strong="H3588"\w* nuestro refugio \w y|strong="H3588"\w* \w la|strong="H3588"\w* falsedad \w como|strong="H3588"\w* nuestro escondrijo.\wj*
\p 
\v 16 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* dice: \wj \w Ciertamente|strong="H2005"\w* Yo pongo \w como|strong="H3651"\w* \w Cimiento|strong="H3245"\w* en \w Sion|strong="H6726"\w*, una Piedra, Piedra probada, \w angular|strong="H6438"\w*, \w preciosa|strong="H3368"\w*, de \w cimiento|strong="H3245"\w* \w estable|strong="H4143"\w*. El \w que|strong="H3808"\w* cree, \w no|strong="H3808"\w* \w será|strong="H3808"\w* conturbado.\wj*
\v 17 \wj \w Pondré|strong="H7760"\w* la \w justicia|strong="H6666"\w* como cordel y la rectitud como plomada. El \w granizo|strong="H1259"\w* arrasará su refugio \w de|strong="H4325"\w* \w mentiras|strong="H3577"\w*, y las \w aguas|strong="H4325"\w* inundarán su escondrijo.\wj*
\v 18 \wj \w Su|strong="H3588"\w* \w pacto|strong="H1285"\w* \w con|strong="H3588"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w* \w será|strong="H1961"\w* anulado, \w y|strong="H3588"\w* \w su|strong="H3588"\w* convenio \w con|strong="H3588"\w* \w el|strong="H3588"\w* Seol \w no|strong="H3808"\w* \w será|strong="H1961"\w* estable. \w Cuando|strong="H3588"\w* \w pase|strong="H5674"\w* \w el|strong="H3588"\w* aguacero arrollador \w serán|strong="H1961"\w* aplastados \w por|strong="H3588"\w* \w él|strong="H3588"\w*.\wj*
\v 19 \wj \w Cada|strong="H3117"\w* vez \w que|strong="H3588"\w* \w pase|strong="H5674"\w*, \w los|strong="H1961"\w* arrollará, \w y|strong="H3588"\w* \w pasará|strong="H5674"\w* \w mañana|strong="H1242"\w* tras \w mañana|strong="H1242"\w*, \w de|strong="H3588"\w* \w día|strong="H3117"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w noche|strong="H3915"\w*. \w Entonces|strong="H3117"\w* entender \w el|strong="H3588"\w* mensaje \w solo|strong="H7535"\w* \w traerá|strong="H3947"\w* terror.\wj*
\v 20 \wj \w La|strong="H3588"\w* cama será corta \w para|strong="H3588"\w* estirarse \w y|strong="H3588"\w* \w la|strong="H3588"\w* manta estrecha \w para|strong="H3588"\w* envolverse. \wj*
\p 
\v 21 \nd \w Yavé|strong="H3068"\w*\nd* se \w levantará|strong="H6965"\w* \w como|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* montaña Perazim. Se enardecerá \w como|strong="H3588"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w valle|strong="H6010"\w* \w de|strong="H3588"\w* \w Gabaón|strong="H1391"\w* \w para|strong="H3588"\w* \w hacer|strong="H6213"\w* \w su|strong="H3588"\w* trabajo, \w su|strong="H3588"\w* \w extraño|strong="H2114"\w* trabajo.
\v 22 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w no|strong="H6435"\w* \w se|strong="H5921"\w* burlen, \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H3588"\w* \w se|strong="H5921"\w* aprieten \w más|strong="H3588"\w* sus \w ataduras|strong="H4147"\w*. \w Porque|strong="H3588"\w* \w escuché|strong="H8085"\w* \w de|strong="H5921"\w* parte \w de|strong="H5921"\w* \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes \w la|strong="H5921"\w* destrucción decretada \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra.
\p 
\v 23 Estén \w atentos|strong="H7181"\w* y \w escuchen|strong="H8085"\w* mi \w voz|strong="H6963"\w*. Atiendan y \w escuchen|strong="H8085"\w* mi palabra:
\v 24 \w El|strong="H3605"\w* \w que|strong="H3117"\w* \w ara|strong="H2790"\w* para sembrar, ¿\w arará|strong="H2790"\w* \w día|strong="H3117"\w* tras \w día|strong="H3117"\w*? ¿\w Romperá|strong="H6605"\w* y deshará \w los|strong="H3605"\w* terrones \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w*?
\v 25 Tan pronto como el campo esté allanado, ¿\w no|strong="H3808"\w* siembra el eneldo, \w esparce|strong="H6327"\w* el comino, echa el \w trigo|strong="H2406"\w* en sus surcos \w o|strong="H3068"\w* la \w cebada|strong="H8184"\w* en la parcela determinada y centeno en su borde?
\p 
\v 26 Porque su \nd ʼElohim\nd* lo instruye y le \w enseña|strong="H3384"\w* lo conveniente:
\v 27 \w Que|strong="H3588"\w* \w el|strong="H5921"\w* eneldo \w no|strong="H3808"\w* \w se|strong="H5921"\w* trilla \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w trillo|strong="H2742"\w*, \w ni|strong="H3808"\w* \w se|strong="H5921"\w* debe pasar \w la|strong="H5921"\w* rueda \w de|strong="H5921"\w* \w la|strong="H5921"\w* carreta \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* comino, \w pero|strong="H3588"\w* \w el|strong="H5921"\w* eneldo \w se|strong="H5921"\w* golpea \w con|strong="H5921"\w* un palo \w y|strong="H3588"\w* \w el|strong="H5921"\w* comino \w con|strong="H5921"\w* una \w vara|strong="H4294"\w*.
\v 28 \w El|strong="H3588"\w* grano \w se|strong="H3808"\w* trilla, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* indefinidamente, \w ni|strong="H3808"\w* \w lo|strong="H3808"\w* comprime \w con|strong="H3588"\w* \w la|strong="H3588"\w* rueda \w de|strong="H3588"\w* \w la|strong="H3588"\w* carreta, \w ni|strong="H3808"\w* \w lo|strong="H3808"\w* quiebra \w con|strong="H3588"\w* \w los|strong="H3588"\w* dientes \w de|strong="H3588"\w* \w su|strong="H3588"\w* trillo.
\v 29 \w También|strong="H1571"\w* \w esto|strong="H2063"\w* viene \w de|strong="H5973"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5973"\w* las huestes, Quien hace maravilloso su \w consejo|strong="H6098"\w* \w y|strong="H1571"\w* \w grande|strong="H1431"\w* su \w sabiduría|strong="H8454"\w*.
\c 29
\s1 Lamento sobre Jerusalén
\p 
\v 1 \wj ¡\w Ay|strong="H1945"\w* Ariel, Ariel, \w ciudad|strong="H7151"\w* \w donde|strong="H5921"\w* acampó \w David|strong="H1732"\w*! Añadan un \w año|strong="H8141"\w* \w a|strong="H3068"\w* \w otro|strong="H8141"\w*, sigan su curso \w las|strong="H5921"\w* \w solemnidades|strong="H2282"\w*.\wj*
\v 2 \wj Pero Yo pondré \w a|strong="H3068"\w* Ariel en apuro. \w Será|strong="H1961"\w* una ciudad de lamento y llanto, y me \w será|strong="H1961"\w* \w como|strong="H1961"\w* Ariel.\wj*
\v 3 \wj \w Porque|strong="H5921"\w* acamparé \w alrededor|strong="H5921"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*. \w Te|strong="H5921"\w* sitiaré \w con|strong="H5921"\w* campamentos \w y|strong="H5921"\w* \w levantaré|strong="H6965"\w* empalizadas \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*.\wj*
\v 4 \wj Entonces \w serás|strong="H1961"\w* humillada. \w Hablarás|strong="H1696"\w* desde el suelo, y tu \w voz|strong="H6963"\w* también \w será|strong="H1961"\w* \w como|strong="H1961"\w* \w si|strong="H1961"\w* \w fuera|strong="H1961"\w* de un espíritu \w que|strong="H1961"\w* \w habla|strong="H1696"\w* desde el \w polvo|strong="H6083"\w*. Tu lenguaje \w susurrará|strong="H6850"\w* desde el \w polvo|strong="H6083"\w*.\wj*
\p 
\v 5 \wj La \w multitud|strong="H1995"\w* de tus enemigos \w será|strong="H1961"\w* \w como|strong="H1961"\w* granos de polvo fino, la \w multitud|strong="H1995"\w* de tus agresores, \w como|strong="H1961"\w* nube de pasto seco. Pero de repente, en un momento, \wj*
\v 6 \wj serás castigada \w de|strong="H5973"\w* parte \w de|strong="H5973"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5973"\w* las huestes \w con|strong="H5973"\w* terremotos y \w el|strong="H5973"\w* \w estruendo|strong="H6963"\w* \w de|strong="H5973"\w* \w grandes|strong="H1419"\w* \w truenos|strong="H6963"\w*, \w gran|strong="H1419"\w* \w ruido|strong="H6963"\w*, huracán, \w tempestad|strong="H5591"\w* y \w llama|strong="H3851"\w* \w de|strong="H5973"\w* fuego consumidor. \wj*
\v 7 \wj Entonces \w la|strong="H5921"\w* \w multitud|strong="H1995"\w* \w de|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w que|strong="H5921"\w* combaten \w contra|strong="H5921"\w* Ariel, \w que|strong="H5921"\w* pelean \w contra|strong="H5921"\w* \w ella|strong="H3605"\w* \w y|strong="H5921"\w* su fortaleza \w y|strong="H5921"\w* \w la|strong="H5921"\w* afligen, \w serán|strong="H1961"\w* \w como|strong="H1961"\w* un \w sueño|strong="H2472"\w*, \w como|strong="H1961"\w* una \w visión|strong="H2377"\w* \w nocturna|strong="H3915"\w*,\wj*
\v 8 \wj \w como|strong="H1961"\w* \w el|strong="H5921"\w* \w hambriento|strong="H8264"\w* sueña \w que|strong="H5921"\w* come \w y|strong="H5921"\w* \w se|strong="H1961"\w* \w despierta|strong="H6974"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* estómago vacío, \w o|strong="H3068"\w* \w como|strong="H1961"\w* \w el|strong="H5921"\w* sediento sueña \w que|strong="H5921"\w* \w bebe|strong="H8354"\w*. Pero \w cuando|strong="H1961"\w* \w despierta|strong="H6974"\w* \w está|strong="H1961"\w* \w cansado|strong="H5889"\w* \w y|strong="H5921"\w* \w tiene|strong="H1961"\w* \w sed|strong="H1961"\w*. \w Así|strong="H3651"\w* \w será|strong="H1961"\w* \w la|strong="H5921"\w* \w multitud|strong="H1995"\w* \w de|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w que|strong="H5921"\w* pelean \w contra|strong="H5921"\w* \w la|strong="H5921"\w* Montaña \w Sion|strong="H6726"\w*. \wj*
\s1 Ceguera de los profetas y videntes
\p 
\v 9 ¡Asómbrense y maravíllense! ¡Deslúmbrense y queden ciegos! Embriáguense, pero \w no|strong="H3808"\w* con \w vino|strong="H3196"\w*. Tambaléense, pero \w no|strong="H3808"\w* por el licor.
\v 10 \w Porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* derramó \w sobre|strong="H5921"\w* ustedes, oh \w profetas|strong="H5030"\w*, un \w espíritu|strong="H7307"\w* \w de|strong="H5921"\w* letargo. Cerró sus \w ojos|strong="H5869"\w*, oh \w videntes|strong="H2374"\w*, \w y|strong="H3588"\w* \w cubrió|strong="H3680"\w* sus \w cabezas|strong="H7218"\w*.
\v 11 \w Así|strong="H2088"\w*, \w toda|strong="H3605"\w* \w visión|strong="H2380"\w* les \w es|strong="H1931"\w* \w como|strong="H3588"\w* \w palabras|strong="H1697"\w* \w de|strong="H3588"\w* un rollo \w sellado|strong="H2856"\w*. \w Si|strong="H3588"\w* \w se|strong="H3045"\w* \w da|strong="H5414"\w* \w a|strong="H3068"\w* uno \w que|strong="H3588"\w* \w sabe|strong="H3045"\w* \w leer|strong="H5612"\w* \w y|strong="H3588"\w* \w se|strong="H3045"\w* \w le|strong="H1931"\w* \w dice|strong="H1697"\w*: \w Lee|strong="H7121"\w* \w ahora|strong="H4994"\w* \w esto|strong="H2088"\w*, \w él|strong="H1931"\w* responde: \w No|strong="H3808"\w* \w puedo|strong="H3201"\w*, \w porque|strong="H3588"\w* \w está|strong="H2088"\w* \w sellado|strong="H2856"\w*.
\v 12 \w Luego|strong="H4994"\w* \w se|strong="H3045"\w* \w da|strong="H5414"\w* \w el|strong="H5921"\w* rollo \w al|strong="H5921"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w sabe|strong="H3045"\w* \w leer|strong="H5612"\w* \w y|strong="H5921"\w* \w se|strong="H3045"\w* \w le|strong="H5921"\w* dice: \w Lee|strong="H7121"\w* \w ahora|strong="H4994"\w* \w esto|strong="H2088"\w*. \w Y|strong="H3068"\w* \w él|strong="H5921"\w* responde: \w No|strong="H3808"\w* \w sé|strong="H3045"\w* \w leer|strong="H5612"\w*.
\p 
\v 13 \nd ʼAdonay\nd* dice: \wj \w Ya|strong="H3068"\w* \w que|strong="H3588"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w se|strong="H1961"\w* \w me|strong="H4480"\w* \w acerca|strong="H5066"\w* \w con|strong="H4480"\w* \w la|strong="H3588"\w* \w boca|strong="H6310"\w* \w y|strong="H3588"\w* \w me|strong="H4480"\w* \w honra|strong="H3513"\w* \w con|strong="H4480"\w* sus \w labios|strong="H8193"\w*, \w pero|strong="H3588"\w* \w su|strong="H3588"\w* \w corazón|strong="H3820"\w* \w está|strong="H2088"\w* \w lejos|strong="H7368"\w* \w de|strong="H4480"\w* \w Mí|strong="H1961"\w*. \w Su|strong="H3588"\w* temor \w hacia|strong="H4480"\w* \w Mí|strong="H1961"\w* \w no|strong="H3588"\w* \w es|strong="H1961"\w* \w más|strong="H3588"\w* \w que|strong="H3588"\w* un \w mandamiento|strong="H6310"\w* \w de|strong="H4480"\w* hombres \w que|strong="H3588"\w* les \w fue|strong="H1961"\w* enseñado.\wj*
\v 14 \wj \w Por|strong="H2088"\w* \w tanto|strong="H3651"\w* Yo \w ciertamente|strong="H2005"\w* \w volveré|strong="H3254"\w* \w a|strong="H3068"\w* excitar \w la|strong="H2451"\w* admiración \w de|strong="H5971"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* con un prodigio grande y espantoso. Porque perecerá \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* \w de|strong="H5971"\w* sus \w sabios|strong="H2450"\w* y \w se|strong="H3651"\w* desvanecerá \w la|strong="H2451"\w* inteligencia \w de|strong="H5971"\w* sus entendidos.\wj*
\p 
\v 15 ¡\w Ay|strong="H1945"\w* de \w los|strong="H1961"\w* \w que|strong="H4310"\w* esconden sus planes profundamente de \nd \w Yavé|strong="H3068"\w*\nd*! Hacen sus \w obras|strong="H4639"\w* en la oscuridad y dicen: ¿\w Quién|strong="H4310"\w* nos \w ve|strong="H7200"\w*? ¿\w Quién|strong="H4310"\w* nos \w conoce|strong="H3045"\w*?
\v 16 \w Su|strong="H3588"\w* perversidad \w ciertamente|strong="H3588"\w* \w será|strong="H3808"\w* estimada \w como|strong="H3588"\w* \w la|strong="H3588"\w* arcilla del alfarero. ¿Dirá \w la|strong="H3588"\w* \w obra|strong="H4639"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w hacedor|strong="H6213"\w*: \w No|strong="H3808"\w* \w me|strong="H3588"\w* \w hiciste|strong="H6213"\w*? ¿Dirá \w la|strong="H3588"\w* vasija al \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w formó|strong="H3335"\w*: \w No|strong="H3808"\w* \w me|strong="H3588"\w* entendiste?
\s1 Bendición para Israel
\p 
\v 17 ¿\w No|strong="H3808"\w* \w se|strong="H3808"\w* convertirá el \w Líbano|strong="H3844"\w* \w en|strong="H5750"\w* un campo fructífero \w dentro|strong="H5750"\w* \w de|strong="H5750"\w* \w poco|strong="H4592"\w* \w tiempo|strong="H4213"\w*, y el campo fructífero \w será|strong="H3808"\w* considerado \w como|strong="H5750"\w* un \w bosque|strong="H3293"\w*?
\v 18 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w los|strong="H1931"\w* \w sordos|strong="H2795"\w* \w oirán|strong="H8085"\w* las \w Palabras|strong="H1697"\w* del Rollo, y \w los|strong="H1931"\w* \w ojos|strong="H5869"\w* \w de|strong="H1697"\w* \w los|strong="H1931"\w* \w ciegos|strong="H5787"\w* \w verán|strong="H7200"\w* desde \w su|strong="H1931"\w* neblina y \w oscuridad|strong="H2822"\w*.
\v 19 Los humildes \w crecerán|strong="H3254"\w* en \w alegría|strong="H8057"\w* de \nd \w Yavé|strong="H3068"\w*\nd*, y los necesitados de la humanidad se regocijarán con el \w Santo|strong="H6918"\w* de \w Israel|strong="H3478"\w*.
\v 20 \w Porque|strong="H3588"\w* \w no|strong="H3588"\w* quedarán tiranos, \w y|strong="H3588"\w* \w el|strong="H3588"\w* burlador será exterminado. \w Ciertamente|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* intentan \w hacer|strong="H3772"\w* \w el|strong="H3588"\w* mal serán destruidos.
\v 21 Los \w que|strong="H1697"\w* inducen al hombre \w a|strong="H3068"\w* \w pecar|strong="H2398"\w* con \w palabras|strong="H1697"\w*, ponen trampas al \w que|strong="H1697"\w* \w reprende|strong="H3198"\w* en la \w puerta|strong="H8179"\w* y pervierten la \w causa|strong="H1697"\w* del \w justo|strong="H6662"\w* con falsos argumentos.
\p 
\v 22 \w Por|strong="H6440"\w* \w tanto|strong="H3651"\w* \nd \w Yavé|strong="H3068"\w*\nd*, Quien \w redimió|strong="H6299"\w* \w a|strong="H3068"\w* Abraham, dice \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* \w Jacob|strong="H3290"\w*: \wj \w Ya|strong="H3068"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* avergonzará \w Jacob|strong="H3290"\w*. \w Tampoco|strong="H3808"\w* volverá \w a|strong="H3068"\w* palidecer su semblante.\wj*
\v 23 \wj \w Porque|strong="H3588"\w* \w verá|strong="H7200"\w* \w en|strong="H3588"\w* \w medio|strong="H3027"\w* \w de|strong="H3588"\w* \w ellos|strong="H3027"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H3206"\w*, \w obra|strong="H4639"\w* \w de|strong="H3588"\w* mis \w manos|strong="H3027"\w*, quienes \w santificarán|strong="H6942"\w* mi \w Nombre|strong="H8034"\w*. \w Sí|strong="H3588"\w*, \w santificarán|strong="H6942"\w* \w al|strong="H7130"\w* \w Santo|strong="H6918"\w* \w de|strong="H3588"\w* \w Jacob|strong="H3290"\w*, \w y|strong="H3588"\w* temerán \w al|strong="H7130"\w* \nd ʼElohim\nd* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.\wj*
\v 24 \wj Los extraviados de \w espíritu|strong="H7307"\w* tendrán entendimiento, y los murmuradores \w aprenderán|strong="H3925"\w* la lección.\wj*
\c 30
\s1 Advertencia con respecto a Egipto
\p 
\v 1 \wj ¡\w Ay|strong="H1945"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* rebeldes, \wj*\w dice|strong="H5002"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \wj \w que|strong="H4480"\w* ejecutan un plan, pero \w no|strong="H3808"\w* \w mío|strong="H5921"\w*, \w y|strong="H5921"\w* \w hacen|strong="H6213"\w* un pacto, pero \w no|strong="H3808"\w* \w de|strong="H4480"\w* \w mi|strong="H5921"\w* \w Espíritu|strong="H7307"\w*, \w con|strong="H5921"\w* \w el|strong="H5921"\w* fin \w de|strong="H4480"\w* añadir \w pecado|strong="H2403"\w* \w con|strong="H5921"\w* \w pecado|strong="H2403"\w*,\wj*
