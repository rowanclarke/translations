\s2 Agabus, again
\p 
\v 10 \w Now|strong="G1161"\w* \w as|strong="G1161"\w* \w we|strong="G1161"\w* \w stayed|strong="G1961"\w* \w there|strong="G1161"\w* \w a|strong="G1161"\w* number \w of|strong="G2250"\w* \w days|strong="G2250"\w*, \w a|strong="G1161"\w* \w certain|strong="G5100"\w* \w prophet|strong="G4396"\w* \w named|strong="G3686"\w* Agabus \w came|strong="G2718"\w* \w down|strong="G2718"\w* \w from|strong="G3588"\w* \w Judea|strong="G2449"\w*.
