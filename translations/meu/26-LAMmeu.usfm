\id LAM .01, Lamentations 1, Motu, PNG, RTWP 11/92
\h ROHE-AHU BUKANA
\toc1 ROHE-AHU BUKANA
\toc2 ROHE-AHU BUKANA
\mt1 ROHE-AHU BUKANA
\c 1
\q1 
\v 1 Hanua badana madi ihabaina!
\q2 Gunaguna taunimanima ai e honu honu dae;
\q2 harihari ia na gabu degedegena rahu.
\q1 Gunaguna ia na bada, bese idau-idau bogaragidiai;
\q2 harihari ia na vabu heḡereḡerena ai vada ela.
\q1 Gunaguna ia na pavapava natuna hahinena hanua idau-idau bogaragidiai;
\q2 harihari ia na hesiai hahinena ai vada ela.
\b
\q1 
\v 2 Hanuaboi ai e tai dikadikamu,
\q2 irurumatana na vahana ai mimia;
\q1 e ura heniamu taudia iboudiai bogaragidia amo
\q2 ta ese tauna se haloamu;
\q1 ia turana iboudiai ese vada e koia,
\q2 inaina ai vada e hahelao.
\b
\q1 
\v 3 Iuda na dauhai vada e hanohoa,
\q2 e hisihisimu bona hesiai ḡaukaradia aukadia e karamu;
\q1 bese idau-idau bogaragidiai e nohomu,
\q2 a ena laḡa-ani gabuna ta se davariamu;
\q1 e hahavaia taudia iboudiai ese vada e lasia tao,
\q2 ena lalo-hisihisi negana ai.
\b
\q1 
\v 4 Siona e lao heniamu daladia na mai hebogahisidia,
\q2 badina be aria e gwauraimu negadia ai na ta se maimu;
\q1 ena ikoukou iboudiai vada e vahu,
\q2 ena helaḡa taudia e ganaḡanamu;
\q1 ena ulato vada e dabuidia oho,
\q2 ia na e hisihisi dikadikamu.
\b
\q1 
\v 5 Ia inaina na ikwarana ai vada ela,
\q2 ana inai taudia edia namo e bada e laomu;
\q1 badina be Iehova ese vada e hahisia,
\q2 ena kara kerere momo herea daidiai;
\q1 ia natuna na dauha vada ela,
\q2 inai taudia vairadiai vada e ḡuidia.
\b
\q1 
\v 6 Siona kekenina na hairaina idoinai ese
\q2 vada e rakatania;
\q1 ena lohia na dia mamaruanedia na heheto,
\q2 rei gabudia asie davarimu;
\q1 e hahavadia taudia vairadiai e heau,
\q2 to asi goadadia.
\b
\q1 
\v 7 Ierusalem na e helalo unemu,
\q2 ena hisihisi bona ena lalo-idita lalodiai;
\q1 ena ḡau herea-daedia iboudiai nega gunadia ai e abiva
\q2 na e lalolaidia unemu.
\q1 Ena taunimanima na inaidia imadia ai e heato
\q2 bona asi ikahana ta negana ai,
\q1 inai tauna ese e ḡonaḡonalaia,
\q2 ena keto e kirikirilaia.
\b
\q1 
\v 8 Ierusalem na e kara dika badava,
\q2 una dainai vada e miro dikadika;
\q1 e imodaiava taudia ese e dadaraiamu,
\q2 badina be ḡaḡaena ai vada e itaia;
\q2 oibe, ia sibona e ḡanaganamu,
\q2 e roha daudaumu.
\b
\q1 
\v 9 Mirona na ramina ai,
\q2 baine dika na se laloa;
\q1 una dainai ena keto na bada herea,
\q2 asi tauna ihalona tauna ta.
\q1 Iehova e, egu hisihisi a itaia,
\q2 badina be inai tauna vada e kwalimu.
\b
\q1 
\v 10 Inai tauna ese vada e toi roro,
\q2 ena ḡau herea-daedia iboudiai daediai;
\q1 oibe, ia ese bese idau-idau vada e itadia,
\q2 ena gabu helaḡana ai vada e raka vareai;
\q1 unu na oi ese o gwaudia tao taudia,
\q2 emu bese edia hebou lalonai basie vareai oto.
\b
\q1 
\v 11 Ena taunimanima iboudiai ese adia e tahuamu,
\q2 mai ḡanaḡanadia ida;
\q1 edia kohu herea-daedia amo adia e hoimu,
\q2 edia goada ihamatamatana totona.
\q1 Iehova e, a gaga isi, a itaia,
\q2 badina be vada e dadaraigumu.
\b
\q1 
\v 12 O raka hanaimu taumui iboumui ai, ina na asio laloamu a?
\q2 A gaga isi, a itaia,
\q1 hisihisi ta na mia lauegu hisihisi heḡereḡerena eiava,
\q2 lau latagu ai vada e kau hisina,
\q1 Iehova ese ena badu ḡaraḡara dinana ai
\q2 e hahisilaigu ḡauna.
\b
\q1 
\v 13 Atai amo ia ese lahi e siaia dobi,
\q2 lau turiagu lalodiai e hadihoa;
\q1 huo e otoa, lau aegu iabidia,
\q2 ia ese e halougu;
\q1 mase-reagu ai e rakatanigu,
\q2 taugu na e manorimu dina idoinai.
\b
\q1 
\v 14 Egu kara kerere na maduna auna ai e halaoa,
\q2 ia imana ese e gui bou;
\q1 aiogu ai e ato kau,
\q2 ia ese egu goada na e hamanokaia;
\q1 lau ese asina laodia ahu diba taudia imadia ai
\q2 Ḡaubada ese vada e atogu.
\b
\q1 
\v 15 Ḡaubada ese egu goada-herea taudia iboudiai na
\q2 bogaragigu ai e dadaraidia;
\q1 hegogo ta e gwauraia, lau ihadikagu,
\q2 egu eregabe taudia imoi-taodia;
\q1 Iuda ena rami-hebou ulatona na Ḡaubada ese vada e moia tao,
\q2 vine imoilaina gabuna ai bema moimoilaia na heto.
\b
\q1 
\v 16 Ini ḡau daidiai na taitaimu,
\q2 iruru-matagu na e dihomu;
\q1 badina be tauhalo tauna na dauhai,
\q2 egu haheauka ihamatamatana tauna na dauhai;
\q1 natugu na vada e baia,
\q2 badina be inai tauna na vada e kwalimu.
\b
\q1 
\v 17 Siona ese imana e toi roromu,
\q2 a asi tauna ta ese ia tauna e haloamu;
\q1 Iehova ese ena haheḡani na Iakob latanai vada e gwauraia,
\q2 ia dekena taudia na inaina ai baela eto;
\q1 Ierusalem na ḡau miro-hereana ai vada ela
\q2 idia bogaragidiai.
\b
\q1 
\v 18 Iehova na maoromaoro,
\q2 badina be vada na gwau edeede henia;
\q1 a umui bese idau-idau taumui iboumui ai, a kamonai,
\q2 bona egu hisihisi ba itaia;
\q1 egu ulato bona egu uhau na
\q2 mai iḡuidia ida vada e laohaidia.
\b
\q1 
\v 19 E ura henigu taudia na boiridia,
\q2 a idia ese e koigu;
\q1 egu hahelaḡa taudia bona egu tau-badadia
\q2 na hanua ai e mase ore,
\q1 edia goada ihamatamatana anianina
\q2 e tahuava negana ai.
\b
\q1 
\v 20 Iehova e, a itaia, badina be na hisihisimu,
\q2 laumagu na e dauremu;
\q1 lalogu na e gugubaiamu,
\q2 badina be vada na gwau edeede dikadika;
\q1 ariara ai dare na e ala-alamu,
\q2 ruma na variha rumana na heto.
\b
\q1 
\v 21 Egu ḡanaḡana a kamonai,
\q2 asi taugu ihalona tauna ta;
\q1 inaigu iboudiai ese egu hekwakwanai sivaraina vada e kamonai,
\q2 idia na e moalemu, oi ese vada o karaia dainai;
\q1 vada o gwauraia dinana a halasia,
\q2 idia na lau heḡereḡeregu ai baela.
\b
\q1 
\v 22 Edia kara dika idoinai na oi vairamu ai baine hedinarai,
\q2 bena ba kara henidia,
\q1 lauegu kara kereredia iboudiai daidiai
\q2 vada o kara henigu heḡereḡerena;
\q1 badina be na ḡanaḡana momomu,
\q2 bona lalogu na e manoka:manokamu.
\c 2
\q1 
\v 1 Ḡaubada ese ena badu ai
\q2 Siona kekenina na dagadaga henunai vada e atoa;
\q1 Israel hairaina na guba amo
\q2 vada e tahoa dobi tanobada ai;
\q1 ena badu dinana ai na
\q2 ia aena ihadaidia ḡauna se laloa tao.
\b
\q1 
\v 2 Ḡaubada ese Iakob ena noho gabudia iboudiai
\q2 vada e habuadia tari, se bogadia hisi;
\q1 Iuda kekenina ena gabu aukadia na
\q2 ena badu ai vada e gigidia dobi;
\q1 basileia mai ikwarana taudia ida
\q2 vada e haketodia tano ai, mai hemaradia ida.
\b
\q1 
\v 3 Israel ena goada idoinai na
\q2 ena badu ḡaraḡarana ai vada e utua dobi;
\q1 ia imana idibana na edia amo e abia oho,
\q2 inai taudia vairadiai;
\q1 Iakob enai vada e ara, lahi hururu-hururuna na heto,
\q2 heḡeḡemadai ḡaudia iboudiai vada e aradia ore.
\b
\q1 
\v 4 Ena peva vada e marea, inai tauna na heto;
\q2 imana vada e ha-aukaia, tuari tauna na heto;
\q1 ta matarealaimu taudia na ia ese vada e aladia mase,
\q2 Siona kekenina ena kalaga ai;
\q1 ena badu ḡaraḡara vada e bubua dobi,
\q2 lahi na heto.
\b
\q1 
\v 5 Ḡaubada na inai tauna heḡereḡerena ai vada ela,
\q2 ia ese Israel vada e habuaia tari;
\q1 ena lohia rumadia iboudiai ia ese vada e habuadia tari,
\q2 ena gabu aukadia vada e ḡiḡidia dobi;
\q1 Iuda kekenina ena taitai bona ena rohe-ahu
\q2 ia ese vada e habada.
\b
\q1 
\v 6 Ia ese ena kalaga vada e rohoa, uma kalagana na heto,
\q2 e gwaurai ariadia gabuna vada e ḡiḡia dobi;
\q1 e gwauraia ariana bona dina helaḡana
\q2 Iehova ese vada e hadokodia Siona ai;
\q1 bona ena badu garagarana ai
\q2 pavapava bona hahelaḡa tauna vada e dadaraidia.
\b
\q1 
\v 7 Ḡaubada ese ena ihaboulaina patana vada e uduguiraia,
\q2 bona ena gabu helaḡana vada e dadaraia;
\q1 ena lohia rumadia maḡudia na
\q2 inai tauna imana ai vada e atodia;
\q1 Iehova ena dubu ai heloḡo-heloḡo e vara,
\q2 e gwauraia ariana dinana ai na heto.
\b
\q1 
\v 8 Iehova ese lalona vada e ha-aukaia,
\q2 Siona kekenina ena magu baine ḡiḡia dobi;
\q1 hahetoho varona amo vada e hahetohoa,
\q2 imana na ihabua-tarina amo se veria dua;
\q1 kohoro bona maḡu vada e hahisidia,
\q2 idia na e manoka heboumu.
\b
\q1 
\v 9 Ena ikoukou na tano ai vada e hepuni,
\q2 ena auri vada e hadikadia, vada e hakwaidudia;
\q1 ena pavapava bona-ena lohia na bese idau-idau bogaragidiai,
\q2 taravatu na vada e ore,
\q1 bona ena peroveta taudia ese mata-hanai ta se abiamu,
\q2 Iehova ena amo.
\b
\q1 
\v 10 Siona ena tau-badadia na
\q2 tano ai e helaimu, asi reḡereḡedia;
\q1 kahu na tubuadia ai vada e ḡiḡi kau,
\q2 bona puse dabuadia vada e hahedokilai;
\q1 Ierusalem ulatodia ese
\q2 tano vada e igo henia.
\b
\q1 
\v 11 Matagu na taitai ai vada e malaka-malaka,
\q2 laumagu na e dauremu;
\q1 Ialogu na hisihisi ese e gugubaiamu,
\q2 egu bese ihabua-tarina dainai;
\q1 badina be natudia karukarudia bona memero-memero na
\q2 hanua ariarana lalodiai e manoridiamu.
\b
\q1 
\v 12 Idia ese sinadia e tai henidiamu, e tomu
\q2 “Aniani bona vine ranuna na edeseni ai?”
\q1 Vada e bero taudia heḡereḡeredia ai e mase reamu,
\q2 hanua ariarana lalodiai;
\q1 sinadia kemedia ai
\q2 edia mauri e oremu.
\b
\q1 
\v 13 Ierusalem kekenimu e,
\q2 ede baina gwauraimu toma bona dahaka ida baina haheḡereḡeremu?
\q1 Siona rami-hebou ulatona e,
\q2 dahaka ida baina haheḡereḡeremu, oi taumu ihalona totona?
\q1 Badina be ihabua-tarimu na bada herea, davara na heto;
\q2 daika ese baine hamaurimu lou?
\b
\q1 
\v 14 Emu peroveta taudia ese oi daimu ai
\q2 mata-hanai koikoidia bona kavakavadia vada e itadia;
\q1 emu kara havara asie gwaurai hedinarai,
\q2 ihanamo-loumu totona,
\q1 a daimu ai peroveta herevadia koikoidia vada e itadia,
\q2 unu amo vada e hakaumu kerere.
\b
\q1 
\v 15 Dala ai e raka hanaimu taudia iboudiai ese
\q2 imadia na e patapata henimumu;
\q1 e si dagumu, kwaradia na Ierusalem kekenina
\q2 e ladolado heniamu, e tomu,
\q1 E gwauraia “hairai herea-daena” bona “tanobada idoinai ihamoalena”
\q2 hanuana binai a?
\b
\q1 
\v 16 Oi inaimu iboudiai ese
\q2 e ihi-ihiraimumu;
\q1 e si dagumu, gadigadidia e hahedaimu,
\q2 e lolomu, e tomu: Vada ta habuaia tari;
\q1 ta uralaia lalo-dikava dinana binai,
\q2 harihari vada ta davaria, vada ta itaia.
\b
\q1 
\v 17 Iehova ese e laloa hata karana vada e karaia,
\q2 e gwau guna, bena vada e hamomokania;
\q1 idau nega ai e gwauraia heḡereḡerena ai
\q2 vada e hahegigia dobi, asi ena hebogahisi;
\q1 inai tauna vada e hamoalea oi latamu ai,
\q2 amu inai taudia edia siahu vada e habadaia.
\b
\q1 
\v 18 Siona kekenimu e
\q2 Ḡaubada ba tai lolo henia!
\q1 Iruru-mata na bae aru abata na heto,
\q2 dina ai bona hanuaboi ai;
\q1 laḡamu basio ania,
\q2 matamu danu basie laḡa ani.
\b
\q1 
\v 19 A tore isi, hanuaboi ai ba tai lolo,
\q2 hegima negadia ta ta imatamadia ai;
\q1 lalomu anina ba bubua nege ranu na heto,
\q2 Ḡaubada vairanai;
\q1 imamu na ba dudui dae henia,
\q2 natumu edia mauri daidiai;
\q1 badina be idia na hitolo dainai e mase reamu,
\q2 ariara iboudiai dokodia ai.
\b
\q1 
\v 20 Iehova e, a hageremai, a itaia,
\q2 daidia na unu vada o kara henidia toma?
\q1 Hahine ese natudia bae anidia,
\q2 e dosidia memerodia bae anidia, a?
\q1 Hahelaḡa tauna bona peroveta tauna na
\q2 Ḡaubada ena gabu helaḡana ai bae aladia mase a?
\b
\q1 
\v 21 Ariara ḡahudia ai
\q2 memero bona iahu e hekida boumu;
\q1 egu ulato bona egu uhau
\q2 na dare ai vada e mase;
\q1 emu badu dinana ai vada o aladia,
\q2 vada o aladia mase, so bogadia hisi.
\b
\q1 
\v 22 E hagarigumu ḡaudia na kaha iboudiai amo o boiridia,
\q2 e gwauraia ariana dinana ai na heto;
\q1 Iehova ena badu dinana ai
\q2 ta se heau, ta se mauri;
\q1 na hadorodia bona na ubudia memerodia na
\q2 agu inai tauna ese vada e habuadia tari.
\c 3
\q1 
\v 1 Ena badu hekwadi-auna hisihisina lalonai,
\q2 hisi vada na ani;
\q1 
\v 2 dibura ai vada e lulugu vareai,
\q2 asi diarina gabuna ai;
\q1 
\v 3 momokani, ia imana na lau ihadikagu totona
\q2 vada e abia isi loulou, dina idoinai.
\b
\q1 
\v 4 Hidiogu bona kopigu vada e ha-oredia,
\q2 bona turiagu vada e hakwaidudia;
\q1 
\v 5 vada e kougu ahu, vada e govagu ahu,
\q2 lalo-idita ai bona lalo-hisihisi ai;
\q1 
\v 6 dibura ai vada e hanohogu,
\q2 idau nega ai e mase taudia na heheto.
\b
\q1 
\v 7 Vada e magugu heḡeḡe, asi egu roho-mauri dalana,
\q2 auri metaudia ai vada e ḡuigu;
\q1 
\v 8 na boiboimu, na tai lolomu, ta ese baine kahagu totona,
\q2 a ia ese egu ḡuriḡuri e laoa ahumu;
\q1 
\v 9 e utu nadidia amo egu dala vada e koudia,
\q2 egu raka daladia vada e hagagevadia.
\b
\q1 
\v 10 Egu ai ia na e banimu beana na heto,
\q2 e komumu, leona na heto;
\q1 
\v 11 egu dala amo e hakaugu siri, e daregu patapata,
\q2 vada e habaiagu;
\q1 
\v 12 ena peva e marea,
\q2 baine tarakia ḡauna ai e halaogu.
\b
\q1 
\v 13 Ena diba pauana dibadia amo,
\q2 nadinadigu na e tarakidia;
\q1 
\v 14 bese iboudiai ese e kirikirilaigumu,
\q2 edia ane ai e hevasehalaigumu dina idoinai;
\q1 
\v 15 lalogu na vada e ha-iditaia ḡuḡuru,
\q2 ava iditana amo vada e hahonugu.
\b
\q1 
\v 16 Isegu na nadinadi e hagaualaidia,
\q2 kahu ai vada e hagorugu diho;
\q1 
\v 17 laumagu na maino ai e dabumu,
\q2 moale vada na reaia;
\q1 
\v 18 taunabunai lau na tomamu: Hairaigu vada e boio
\q2 bona egu helaro Iehova ena amo danu.
\b
\q1 
\v 19 Egu hisihisi bona egu lalo-idita ba ialo tao,
\q2 ava iditana bona muramura iditana danu;
\q1 
\v 20 laumagu ese e haeroa louloumu,
\q2 bona lalogu ai e igo dihomu;
\q1 
\v 21 a ina na na laloa unemu,
\q2 taunabunai na helaromu.
\b
\q1 
\v 22 Iehova ena mia-hanaihanai lalokauna na se oremu
\q2 ena hebogahisi karadia na asie dokomu;
\q1 
\v 23 daba iboudiai idia na mamatamata;
\q2 emu heabidadama na bada herea.
\q1 
\v 24 Laumagu na e tomu: Iehova na lau ahugu;
\q2 una dainai ia baina laroa.
\b
\q1 
\v 25 E nariamu taudia na Iehova ese e hanamodiamu,
\q2 bona e tahuamu taudia danu.
\q1 
\v 26 Iehova ena hahemauri baita naria, asi reḡereḡeda,
\q2 una na namo;
\q1 
\v 27 tau ta ese eregabena ai maduna baine huaia,
\q2 una danu namo.
\b
\q1 
\v 28 Maduna na pagana ai vada e atoa negana ai,
\q2 ia na sibona baine helai, asi reḡereḡena;
\q1 
\v 29 uduna na ḡahu ai baine atoa,
\q2 reana helaro do baine vara;
\q1 
\v 30 vahana na hebota tauna baine mede henia,
\q2 ḡonaḡona herevadia ai baine honu.
\b
\q1 
\v 31 Badina be Ḡaubada ese basine negea daure
\q2 ela bona hanaihanai;
\q1 
\v 32 ena be lalona baine hahisia, to baine bogaia hisi,
\q2 ena hebogahisi bada-hereana heḡereḡerena;
\q1 
\v 33 badina be taunimanima natudia tau-anidia eiava lalodia
\q2 ihahisihisidia na se uramu.
\b
\q1 
\v 34 E ḡuidia taudia iboudiai tanobada ai
\q2 bae moidia tao,
\q1 
\v 35 eiava tau ta igwaurai-maorona bae laoa ahu
\q2 Dirava Herea-Mikamika vairanai,
\q1 
\v 36 eiava tau ta ena gini-kau dalana bae hagagevaia;
\q2 una kara na Ḡaubada ese se abi daemu.
\b
\q1 
\v 37 Daika na e haheḡani bena anina e vara,
\q2 Ḡaubada na se gwau maoro negana ai?
\q1 
\v 38 Dirava Herea-Mikamika uduna amo
\q2 namo bona dika na e maimu ani?
\q1 
\v 39 Mauri tauna baine maumau badina be dahaka?
\q2 Ena dika davana iabina baine maumauraia anina be dahaka?
\b
\q1 
\v 40 Eda dala baita tohodia bona baita tahudia,
\q2 bena Iehova baita lou henia;
\q1 
\v 41 laloda bona imada baita abidia isi,
\q2 guba ai e nohomu Diravana enai, baitato,
\q1 
\v 42 Ai na vada a kerere bona vada a gwau edeede,
\q2 bena oi ese emai dika so gwau tao.
\b
\q1 
\v 43 Badu vada o rioa, vada o hahavamai,
\q2 vada o alamai mase, so bogamai hisi;
\q1 
\v 44 ori vada o rioa,
\q2 ḡuriḡuri ta basine hanai helaoreana.
\q1 
\v 45 Oi ese kopikopi bona momoru ai vada o halaomai,
\q2 bese idau-idau bogaragidiai.
\b
\q1 
\v 46 Ai inaimai iboudiai ese
\q2 e ḡonaḡonalaimaimu;
\q1 
\v 47 gari bada bona hekwakwanai na latamai ai vada e kau,
\q2 hahevahu bona hahebua-tari danu;
\q1 
\v 48 iruru-matagu na e arumu sinavai na heto,
\q2 egu bese kekenina ena mase dainai.
\b
\q1 
\v 49 Iruru-matagu bae diho asi dokona,
\q2 bona asi komadana,
\q1 
\v 50 ela bona Iehova na guba amo baine roha dobi,
\q2 bena baine itagu;
\q1 
\v 51 matagu ese e hahisihisigu,
\q2 egu hanua ulatodia iboudiai vada e dika dainai.
\b
\q1 
\v 52 Asi badina e inai henigu taudia ese e tahugu,
\q2 labana tauna ese manu e tahuamu na heto;
\q1 
\v 53 maurigu ai guri lalonai e tahogu dobi,
\q2 bona nadi na latagu ai e taho kau;
\q1 
\v 54 ranu ai na mutu, nato
\q2 “Vada name boio”.
\b
\q1 
\v 55 Iehova e, oi ladamu na hahanea,
\q2 guri dobudobu amo;
\q1 
\v 56 egu noinoi, nato “Hekaha na noiamu, taiamu na egu ai basio koua ahu” na
\q2 oi ese vada o kamonai;
\q1 
\v 57 na boi henimu negana ai o raka kahira,
\q2 oto “Basio gari”.
\b
\q1 
\v 58 Ḡaubada e, oi ese egu ginikau gabuna vada o lailaia,
\q2 oi ese egu mauri vada o rauaia.
\q1 
\v 59 Iehova e, oi ese vada o itaia, e kara dika henigu;
\q2 ba hahemaoro henigu.
\q1 
\v 60 Oi ese edia dava-heni idoinai vada o itaia,
\q2 lau ihadikagu karadia e lalo-hadailaimu ḡaudia iboudiai.
\b
\q1 
\v 61 Iehova e, edia heḡonaḡonalai herevadia vada o kamonai,
\q2 lau ihadikagu karadia e lalo-hadailaimu ḡaudia iboudiai;
\q1 
\v 62 e ala-ala henigumu taudia ududia bona edia lalo-hadai ese
\q2 lau e hadikalaigumu dina idoinai.
\q1 
\v 63 Edia helai diho bona edia tore isi a itaia;
\q2 edia ane ai e hevasehalaigu.
\b
\q1 
\v 64 Iehova e, oi ese davadia ba henidia,
\q2 idia imadia ḡaukaradia heḡereḡeredia;
\q1 
\v 65 oi ese lalodia ba haduhudia,
\q2 emu heuduguirai na latadiai baine kau.
\q1 
\v 66 Iehova e, oi ese badu ai ba hahavadia,
\q2 emu guba henuna amo ba habuadia tari.
\c 4
\q1 
\v 1 \it Gold\it* vada e hoḡohoḡo,
\q2 \it gold\it* ḡoeva-daena vada e idau;
\q1 nadi helagadia vada eme heḡiḡi rohoroho,
\q2 ariara iboudiai dokodia ai.
\b
\q1 
\v 2 Siona natuna mamaruanedia herea-daedia,
\q2 davildia na \it gold\it* ḡoevaḡoevana metaudia heḡereḡeredia ai,
\q1 madi, ihabaidia, raro urodia ida vada e haheḡereḡeredia,
\q2 uro ikarana tauna imana ese e kara ḡaudia na heheto.
\b
\q1 
\v 3 Uda sisiadia ese natudia e ubudi unu,
\q2 rata na e henidiamu;
\q1 a egu bese natuna hahinena vada e daḡedaḡe,
\q2 uda kokokokodia na heheto.
\b
\q1 
\v 4 Rata e topoamu merona malana na
\q2 ranu mase dainai uduna atai maona ai e kape daemu;
\q1 memero na aniani dainai e noinoimu,
\q2 a ta ese adia se henidiamu.
\b
\q1 
\v 5 Aniani manoka-manokadia e aniva taudia na
\q2 ariara ai e masemu;
\q1 dabua kakakakadia idokilaidia e manadava taudia na
\q2 kahu e negeamu gabudia ai e hekuremu.
\b
\q1 
\v 6 Badina be egu bese natuna hahinena ena kara dika davana ese
\q2 Sodoma ena kara dika davana vada e hereaia;
\q1 una hanua na e heḡiḡi dobi haraga-haraga,
\q2 tau ta ese se daua toho negana ai.
\b
\q1 
\v 7 Ena lohia taudia na ḡoḡoeva-ḡoḡoeva, \it snow\it* ena ḡoevaḡoeva e hereaiamu;
\q2 idia na kukuroka-kukuroka, rata ena kurokuro e hereaiamu;
\q1 tau-anidia na kakakaka, ḡiriḡi ena kakakaka e hereaiamu;
\q2 oromadia na mai hairaidia, sapairo nadidia na heheto.
\b
\q1 
\v 8 Harihari idia vairadia na korema-korema, guma ena korema e hereaiamu;
\q2 ariara ai bae itadia taudia basie diba idia na daidia;
\q1 kopidia na e makuku turiadia ai,
\q2 vada e kakoro au na heto.
\b
\q1 
\v 9 Dare ai e mase taudia edia moale ese
\q2 hitolo ai e mase taudia edia moale e hereaia;
\q1 idia na e varoda-varodava,
\q2 uma na asi anidia dainai e maseva.
\b
\q1 
\v 10 Hebogahisi hahinedia imadia ese
\q2 natudia adoradia vada e nadudia;
\q1 adia vamu ai vada e halaodia,
\q2 egu bese natuna hahinena ihabua-tarina ai.
\b
\q1 
\v 11 Iehova ese ena badu e hasiahua,
\q2 ena badu fiaraḡarana e bubua dobi;
\q1 Siona ai lahi e ha-araia,
\q2 hanua badidia e aradia ore.
\b
\q1 
\v 12 Tanobada pavapavadia ese asie abia dae,
\q2 tanobada taudia iboudiai ese danu,
\q1 tuari tauna ta eiava inai tauna ta ese
\q2 Ierusalem ikoukoudia lalodiai baine raka vareai diba.
\b
\q1 
\v 13 Ina na ena peroveta taudia edia kara dika
\q2 bona ena hahelaḡa taudia edia kara havara daidiai,
\q1 idia ese kara maoromaoro taudia raradia e hahebubu
\q2 ia bogaraginai.
\b
\q1 
\v 14 Idia na mata-kepuludia ai ariara ai e loava,
\q2 rara ese vada e hamirodia,
\q1 bona tau ta ese
\q2 edia dabua na basine dau toho diba.
\b
\q1 
\v 15 Taunimanima ese e boi henidia, eto,
\q2 A siri! Mai miromui!
\q2 A siri! A siri! Basio hedau toho!
\q1 Bena idia na heau bona loa-evaeva taudia ai ela;
\q2 bese idau-idau bogaragidiai taunimanima eto:
\q2 Ai dekemai ai basie noho lou.
\b
\q1 
\v 16 Iehova sibona ese e hakarohodia rohoroho,
\q2 ia ese basine haḡeredia lou;
\q1 hahelaḡa taudia na asie matauraidia,
\q2 bona hanua tau-badadia na asie lalo namo henidia.
\b
\q1 
\v 17 Matamai e valahu-valahu, hekaha inarina ai,
\q2 a gima kava hanaihanaiva dainai;
\q1 emai hegima lalonai
\q2 hahemauri asi dibana besena a nariava.
\b
\q1 
\v 18 Taunimanima na ae-gedumai ai e raka dainai
\q2 emai ariara ai asia raka diba;
\q1 dokomai vada e kahikahi, emai mauri dinadia vada e duahi,
\q2 badina be dokomai vada e kau.
\b
\q1 
\v 19 E hahavamai taudia edia heau ese
\q2 guba ugavadia edia roho e hereaia;
\q1 ororo ai e hahavamai,
\q2 tano ḡaḡaena ai e bani henimai.
\b
\q1 
\v 20 Iehova ese e horoa tauna, emai mauri laḡana, na
\q2 edia guri ai e abia;
\q1 a ai ese vada a herevalaia, ato,
\q2 Bese idau-idau bogaragidiai ia ikerukeruna ai baia noho.
\b
\q1 
\v 21 Edom kekenimu e, Usu tanona ai o nohomu,
\q2 ba moale, ba hisi dae!
\q1 A oiemu ai danu kehere baine kau,
\q2 ba kekero, emu dabua ba doki oho, ḡaḡaemu ai ba noho.
\b
\q1 
\v 22 Siona kekenimu e, emu kara havara davana vada o abia ḡuḡuru,
\q2 ma dauhai basine hanohomu;
\q1 a Edom kekenimu e, emu kara havara davana baine henimu,
\q2 emu kara dika baine hulalai.
\c 5
\q1 
\v 1 Iehova e, emai ai vada e vara ḡaudia ba lalo tao;
\q1 a haḡeremai, e hahemaraimaimu ḡaudia ba itadia.
\q2 
\v 2 Emai tano na idau taudia vada e henidia;
\q1 emai ruma na idau bese taudia vada e henidia.
\b
\q1 
\v 3 Ai na vada a ihareha, asi tamamai;
\q2 sinamai na vabu heḡereḡeredia.
\q1 
\v 4 Emai inuinu ranuna na a hoimu;
\q2 au a abimu na mai davadia.
\q1 
\v 5 Paḡamai mai madunadia ai a hekwarahimu;
\q2 taumai e boeramu, Isie halaga-animaimu.
\q1 
\v 6 Imamai na Aigupto bona Asuria vada e toi roro henidia,
\q2 amai na baine davana totona.
\q1 
\v 7 Tamamai e kara dika, bena vada e mase;
\q2 bena ai ese edia kara havara a huamu.
\q1 
\v 8 Hesiai tauna ese e lohiamaimu,
\q2 asi tauna ta ese idia imadia amo e hamaurimaimu.
\q1 
\v 9 Amai a tahumu mai garimai ida,
\q2 tano ḡaḡaena ai dare ese baine alamai mase na garina.
\q1 
\v 10 Kopimai e siahumu, amu siahuna na heto,
\q2 doe heḡaraḡarana dainai.
\q1 
\v 11 Siona ai hahine na e dadidiamu,
\q2 bona rami-hebou ulatodia Iuda ai.
\q1 
\v 12 Hanua lohiadia na imadia amo e taudia daemu,
\q2 hanua tau-badadia na asie matauraidiamu.
\q1 
\v 13 Eregabe taudia na e haḡaukaradiamu, flaoa iririlaina gabuna ai;
\q2 memero na e raragamu, au metaudia e huadiamu dainai.
\q1 
\v 14 Iahu ese hanua ikoukouna vada e rakatania;
\q2 eregabe taudia ese edia hatai-hatai ḡaudia na vada e atodia diho.
\q1 
\v 15 Moale vada e doko lalomai ai,
\q2 bona emai mavaru na taitai ai vada e hahelao.
\q1 
\v 16 Havava ḡauna na kwaramai amo vada e moru;
\q2 madi ihabaimai, vada a kara dika dainai.
\q1 
\v 17 Ina dainai Ialomai vada e manoka-manoka,
\q2 ini ḡau daidiai matamai vada e valahu-valahu.
\q1 
\v 18 Siona ororona vada e vahu dainai;
\q2 uda sisiadia na ia latanai e loamu.
\b
\q1 
\v 19 A oi, Iehova e, o lohia hanaihanaimu;
\q2 emu terono na e miamu, uru iboudiai lalodiai.
\q1 
\v 20 Badina be dahaka o lalomai boio hanaihanaimu;
\q2 Dahaka dainai nega daudau vada o rakatanimai?
\q1 
\v 21 Iehova e, bavabimai dae lou, bena baia namo lou;
\q2 emai dina ba hamatamatadia, nega gunadia heḡereḡeredia.
\q1 
\v 22 Eiava, vada o dadaraimai vaitani a?
\q2 Vada o badu henimai vaitani a? 
