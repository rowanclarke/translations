\v 59 La esposa de \w Amram|strong="H6019"\w* se \w llamaba|strong="H8034"\w* Jocabed, \w hija|strong="H1323"\w* de \w Leví|strong="H3878"\w*, \w que|strong="H1323"\w* le \w nació|strong="H3205"\w* \w a|strong="H3068"\w* \w Leví|strong="H3878"\w* en \w Egipto|strong="H4714"\w*. Ésta dio \w a|strong="H3068"\w* luz para \w Amram|strong="H6019"\w* \w a|strong="H3068"\w* Aarón, \w Moisés|strong="H4872"\w* y Miriam su hermana.  
\v 60 \w A|strong="H3068"\w* Aarón le \w nacieron|strong="H3205"\w* \w Nadab|strong="H5070"\w*, Abiú, Eleazar \w e|strong="H3068"\w* Itamar.  
\v 61 Pero \w Nadab|strong="H5070"\w* y Abiú \w murieron|strong="H4191"\w* cuando ofrecieron fuego \w extraño|strong="H2114"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 62 \w Los|strong="H1992"\w* levitas contados \w fueron|strong="H1961"\w* 23.000, \w todos|strong="H3605"\w* \w varones|strong="H2145"\w* \w de|strong="H3588"\w* un \w mes|strong="H2320"\w* \w para|strong="H3588"\w* \w arriba|strong="H4605"\w*. \w No|strong="H3808"\w* \w fueron|strong="H1961"\w* empadronados \w con|strong="H3588"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H1961"\w* \w les|strong="H1992"\w* \w dio|strong="H5414"\w* \w heredad|strong="H5159"\w* \w entre|strong="H8432"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.   
\p
\v 63 Estos son \w los|strong="H1121"\w* empadronados \w por|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* Eleazar, quienes empadronaron \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w los|strong="H1121"\w* campos \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w* frente \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w*.  
\v 64 \w Entre|strong="H3808"\w* ellos ya \w no|strong="H3808"\w* \w existía|strong="H1961"\w* \w ninguno|strong="H3808"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* empadronados por \w Moisés|strong="H4872"\w* y \w el|strong="H1121"\w* \w sacerdote|strong="H3548"\w* Aarón, quienes hicieron \w el|strong="H1121"\w* censo \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* en \w el|strong="H1121"\w* \w desierto|strong="H4057"\w* \w de|strong="H1121"\w* \w Sinaí|strong="H5514"\w*.  
\v 65 \w Porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*: \wj \+w Morirán|strong="H4191"\+w* \+w en|strong="H3588"\+w* \+w el|strong="H3588"\+w* \+w desierto|strong="H4057"\+w*.\wj* \w No|strong="H3808"\w* \w quedó|strong="H3498"\w* \w ningún|strong="H3808"\w* varón \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*, excepto \w Caleb|strong="H3612"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Jefone, \w y|strong="H3588"\w* \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Nun|strong="H5126"\w*.   
\c 27  
\s1 Herencia de las hijas  
\p
\v 1 Entonces llegaron las \w hijas|strong="H1323"\w* \w de|strong="H1121"\w* Zelofejad, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Hefer, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Maquir, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, \w de|strong="H1121"\w* las \w familias|strong="H4940"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*, \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* cuales eran \w Maala|strong="H4244"\w*, \w Noa|strong="H5270"\w*, \w Hogla|strong="H2295"\w*, \w Milca|strong="H4435"\w* y Tirsa.  
\v 2 Ellas se presentaron \w ante|strong="H6440"\w* \w Moisés|strong="H4872"\w*, \w el|strong="H3605"\w* \w sacerdote|strong="H3548"\w* Eleazar, \w los|strong="H3605"\w* jefes y \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación, \w en|strong="H5975"\w* \w la|strong="H3605"\w* entrada del Tabernáculo \w de|strong="H6440"\w* Reunión, y dijeron:  
