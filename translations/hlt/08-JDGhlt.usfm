\v 11 Te \w dongah|strong="H9999"\w*, “\w Kai|strong="H9901"\w* he \w bitat|strong="H4399"\w* a \w saii|strong="H6213"\w* nah \w mueh|strong="H3808"\w* \w rhuivaeh|strong="H5688"\w* a \w thai|strong="H2319"\w* \w neh|strong="H9996"\w* n'\w khih|strong="H0631"\w* la n'\w khih|strong="H0631"\w* uh \w atah|strong="H0518"\w* ka \w kha|strong="H2470"\w* sut \w vetih|strong="H9999"\w* \w hlang|strong="H0120"\w* \w mailai|strong="H0259"\w* \w banglam|strong="H9995"\w* ni ka \w om|strong="H1961"\w* eh?,” a \w ti|strong="H0559"\w* nah.   
\p
\v 12 Te \w dongah|strong="H9999"\w* \w Delilah|strong="H1807"\w* loh \w rhuivaeh|strong="H5688"\w* a \w thai|strong="H2319"\w* te a \w loh|strong="H3947"\w* \w tih|strong="H9999"\w* \w Samson|strong="H9909"\w* a \w khih|strong="H0631"\w*. Te \w phoeiah|strong="H9999"\w*, “\w Samson|strong="H8123"\w* \w na|strong="H9905"\w* pum \w dongkah|strong="H5921"\w* \w Philisti|strong="H6430"\w* rhoek te,” a \w ti|strong="H0559"\w* nah.  
\p Te \w vaengah|strong="H9999"\w* \w imkhui|strong="H2315"\w* \w ah|strong="H9996"\w* aka \w rhongngol|strong="H0693"\w* thil khaw \w om|strong="H3427"\w* coeng \w dae|strong="H9999"\w* \w a|strong="H9909"\w* \w ban|strong="H2220"\w* \w dongkah|strong="H5921"\w* te \w rhuihet|strong="H2339"\w* \w bangla|strong="H9995"\w* but a \w bawt|strong="H5423"\w*.   
