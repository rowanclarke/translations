\v 17 \wj Ataquen \+w a|strong="H3068"\+w* los madianitas y destrúyanlos,\wj*  
\v 18 \wj \+w pues|strong="H3588"\+w* \+w ellos|strong="H1992"\+w* \+w son|strong="H3588"\+w* \+w sus|strong="H1992"\+w* enemigos \+w por|strong="H5921"\+w* \+w las|strong="H1992"\+w* astucias \+w con|strong="H5921"\+w* \+w las|strong="H1992"\+w* cuales \+w los|strong="H1992"\+w* engañaron \+w en|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w asunto|strong="H1697"\+w* \+w de|strong="H5921"\+w* Peor \+w y|strong="H3588"\+w* \+w en|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w asunto|strong="H1697"\+w* \+w de|strong="H5921"\+w* Cozbi, \+w hija|strong="H1323"\+w* \+w del|strong="H5921"\+w* \+w jefe|strong="H5387"\+w* \+w de|strong="H5921"\+w* \+w Madián|strong="H4080"\+w*, hermana \+w de|strong="H5921"\+w* \+w ellos|strong="H1992"\+w*, \+w que|strong="H3588"\+w* fue asesinada \+w el|strong="H5921"\+w* \+w día|strong="H3117"\+w* \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w mortandad|strong="H4046"\+w* \+w a|strong="H3068"\+w* \+w causa|strong="H1697"\+w* \+w de|strong="H5921"\+w* Peor.\wj*   
\c 26  
\s1 Segundo censo  
\p
\v 1 Después \w de|strong="H1121"\w* aquella mortandad, sucedió \w que|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* habló \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Eleazar, \w hijo|strong="H1121"\w* del \w sacerdote|strong="H3548"\w* Aarón:  
\v 2 \wj \+w Tomen|strong="H5375"\+w* un censo \+w de|strong="H1121"\+w* \+w toda|strong="H3605"\+w* \+w la|strong="H3605"\+w* congregación \+w de|strong="H1121"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*, \+w de|strong="H1121"\+w* 20 \+w años|strong="H8141"\+w* para \+w arriba|strong="H4605"\+w*, según sus \+w casas|strong="H1004"\+w* paternas, \+w todos|strong="H3605"\+w* \+w los|strong="H1121"\+w* \+w que|strong="H1121"\+w* puedan \+w salir|strong="H3318"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H3605"\+w* \+w guerra|strong="H6635"\+w* \+w en|strong="H3318"\+w* \+w Israel|strong="H3478"\+w*.\wj*  
\v 3 Entonces \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* Eleazar \w hablaron|strong="H1696"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w*, frente \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* campos \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w dijeron|strong="H1696"\w*:  
\v 4 \wj ¡\+w De|strong="H1121"\+w* 20 \+w años|strong="H8141"\+w* para \+w arriba|strong="H4605"\+w*\wj*, como \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*! \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w que|strong="H1121"\w* \w salieron|strong="H3318"\w* \w de|strong="H1121"\w* la tierra \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w* fueron:  
\v 5 \w Rubén|strong="H7205"\w*, \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w* fueron: \w de|strong="H1121"\w* Enoc, la \w familia|strong="H4940"\w* del enoquita, y \w de|strong="H1121"\w* Falú, la \w familia|strong="H4940"\w* del faluita.  
\v 6 De \w Hezrón|strong="H2696"\w*, la \w familia|strong="H4940"\w* del hezronita, y de \w Carmi|strong="H3756"\w*, la \w familia|strong="H4940"\w* del carmita.   
\p
\v 7 Estas \w son|strong="H1961"\w* las \w familias|strong="H4940"\w* de \w los|strong="H1961"\w* rubenitas. \w Los|strong="H1961"\w* empadronados de ellas \w fueron|strong="H1961"\w* 43.730.   
\p
\v 8 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* Falú: Eliab.  
\v 9 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Eliab: \w Nemuel|strong="H5241"\w*, Datán \w y|strong="H5921"\w* Abiram. Datán \w y|strong="H5921"\w* Abiram fueron \w los|strong="H1121"\w* jefes \w de|strong="H5921"\w* \w la|strong="H1931"\w* congregación \w que|strong="H1931"\w* \w se|strong="H1931"\w* rebelaron \w contra|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* Aarón \w con|strong="H5921"\w* \w el|strong="H1931"\w* grupo \w de|strong="H5921"\w* \w Coré|strong="H7141"\w* cuando \w se|strong="H1931"\w* rebelaron \w contra|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
