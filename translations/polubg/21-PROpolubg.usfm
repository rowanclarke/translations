\id PRO
\h Przysłów
\toc1 Księga Przysłów
\toc2 Przysłów
\toc3 Prz
\mt1 Księga Przysłów
\c 1
\m 
\v 1 Przysłowia Salomona, syna Dawida, króla Izraela;
\m 
\v 2 Do poznania mądrości i karności, do zrozumienia słów roztropnych;
\m 
\v 3 Do zdobycia pouczenia w mądrości, w sprawiedliwości, w sądzie i w prawości;
\m 
\v 4 Do udzielenia prostym rozwagi, a młodemu – wiedzy i roztropności.
\m 
\v 5 Mądry posłucha i przybędzie mu wiedzy, a rozumny nabędzie rad;
\m 
\v 6 Aby rozumieć przysłowia i \add ich\add* wykładnię, słowa mądrych i ich zagadki.
\m 
\v 7 Bojaźń PANA jest początkiem wiedzy, ale głupcy gardzą mądrością i karnością.
\m 
\v 8 Synu mój, słuchaj pouczenia swego ojca i nie odrzucaj nauki swojej matki;
\m 
\v 9 Bo one będą wdzięczną ozdobą na twojej głowie i \add kosztownym\add* łańcuchem na szyi.
\m 
\v 10 Synu mój, jeśli grzesznicy cię namawiają, nie pozwalaj.
\m 
\v 11 Jeśli mówią: Chodź z nami, czyhajmy na krew, zaczajmy się na niewinnego bez powodu;
\m 
\v 12 Pożremy ich żywcem jak grób, całych, jak zstępujących do dołu;
\m 
\v 13 Znajdziemy wszelkie kosztowności, napełnimy swoje domy łupem;
\m 
\v 14 Dziel z nami swój los; miejmy wszyscy jedną sakiewkę.
\m 
\v 15 Synu mój, nie wyruszaj z nimi w drogę; powstrzymaj swoją nogę od ich ścieżki.
\m 
\v 16 Ich nogi bowiem biegną do zła i spieszą się do przelania krwi.
\m 
\v 17 Na próżno zastawia się sieci na oczach wszelkiego ptactwa.
\m 
\v 18 Oni też czyhają na własną krew, czają się na własne życie.
\m 
\v 19 Takie są ścieżki każdego, który jest chciwy zysku; swojemu właścicielowi \add taki zysk\add* odbiera życie.
\m 
\v 20 Mądrość woła na dworze, podnosi swój głos na ulicach.
\m 
\v 21 Woła w największym zgiełku, u wrót bram, w mieście wygłasza swoje słowa:
\m 
\v 22 Jak długo, prości, będziecie kochać głupotę, szydercy – lubować się w swoim szyderstwie, a głupi – nienawidzić wiedzy?
\m 
\v 23 Nawróćcie się na moje upomnienie; oto wyleję na was mojego ducha, oznajmię wam moje słowa.
\m 
\v 24 Ponieważ wołałam, a odmawialiście; wyciągałam rękę, a nikt nie zważał;
\m 
\v 25 Owszem, odrzuciliście całą moją radę i nie chcieliście \add przyjąć\add* mojego upomnienia;
\m 
\v 26 Dlatego będę się śmiać z waszego nieszczęścia, będę szydzić z was, gdy przyjdzie to, czego się boicie.
\m 
\v 27 Gdy nadejdzie jak spustoszenie to, czego się boicie, i \add gdy\add* wasze nieszczęście nadciągnie jak wicher, gdy nadejdzie na was ucisk i cierpienie;
\m 
\v 28 Wtedy będą mnie wzywać, a nie wysłucham; będą mnie szukać pilnie, lecz mnie nie znajdą.
\m 
\v 29 Bo znienawidzili wiedzę i nie wybrali bojaźni PANA;
\m 
\v 30 Ani nie chcieli mojej rady, \add ale\add* gardzili każdym moim upomnieniem.
\m 
\v 31 Dlatego spożyją owoc swoich dróg i będą nasyceni swymi radami.
\m 
\v 32 Bo odstępstwo prostych zabije ich i szczęście głupich zgubi ich.
\m 
\v 33 \add Ale\add* kto mnie słucha, będzie mieszkać bezpiecznie i będzie wolny od strachu przed złem.
\c 2
\m 
\v 1 Synu mój, jeśli przyjmiesz moje słowa i zachowasz u siebie moje przykazania;
\m 
\v 2 Nadstawiając swego ucha na mądrość i nakłaniając swe serce ku rozumowi;
\m 
\v 3 Tak, jeśli przywołasz roztropność i swoim głosem wezwiesz rozum;
\m 
\v 4 Jeśli będziesz jej szukać jak srebra i poszukiwać jej jak ukrytych skarbów;
\m 
\v 5 Wtedy zrozumiesz bojaźń PANA i dojdziesz do poznania Boga.
\m 
\v 6 PAN bowiem daje mądrość, z jego ust \add pochodzi\add* wiedza i rozum.
\m 
\v 7 On \add zachowuje\add* prawdziwą mądrość dla prawych; \add on jest\add* tarczą dla tych, którzy postępują uczciwie;
\m 
\v 8 Strzeże ścieżek sądu i chroni drogę swoich świętych.
\m 
\v 9 Wtedy zrozumiesz sprawiedliwość, sąd, prawość i wszelką dobrą ścieżkę.
\m 
\v 10 Gdy mądrość wejdzie do twojego serca i wiedza będzie miła twojej duszy;
\m 
\v 11 \add Wtedy\add* rozwaga będzie cię strzegła i rozum cię zachowa.
\m 
\v 12 By uwolnić cię od złej drogi \add i\add* od człowieka, który mówi przewrotnie;
\m 
\v 13 \add Od tych\add*, którzy opuszczają ścieżki prawości, żeby chodzić drogami ciemności;
\m 
\v 14 \add Którzy\add* się radują, gdy czynią zło, a cieszą się w złośliwej przewrotności;
\m 
\v 15 Których ścieżki są kręte i \add sami\add* są przewrotni na swoich drogach;
\m 
\v 16 Aby cię uwolnić od cudzej kobiety, od obcej, która pochlebia łagodnymi słowami;
\m 
\v 17 Która opuszcza przewodnika swojej młodości i zapomina o przymierzu swojego Boga;
\m 
\v 18 Bo jej dom chyli się ku śmierci, a jej ścieżki ku umarłym;
\m 
\v 19 Nikt z tych, którzy do niej wchodzą, nie wraca ani nie trafia na ścieżkę życia;
\m 
\v 20 Abyś chodził drogą dobrych i przestrzegał ścieżek sprawiedliwych.
\m 
\v 21 Prawi bowiem będą mieszkali na ziemi i nienaganni na niej pozostaną;
\m 
\v 22 Ale niegodziwi będą wykorzenieni z ziemi i przewrotni będą z niej wyrwani.
\c 3
\m 
\v 1 Synu mój, nie zapominaj mego prawa, a niech twoje serce strzeże moich przykazań;
\m 
\v 2 Bo przyniosą ci długie dni i lata życia oraz pokoju.
\m 
\v 3 Niech cię nie opuszczają miłosierdzie i prawda, przywiąż je do swojej szyi, wypisz je na tablicy swojego serca.
\m 
\v 4 Wtedy znajdziesz łaskę i uznanie w oczach Boga i ludzi.
\m 
\v 5 Ufaj PANU z całego swego serca i nie polegaj na swoim rozumie.
\m 
\v 6 Zważaj na niego we wszystkich swoich drogach, a on będzie prostować twoje ścieżki.
\m 
\v 7 Nie bądź mądrym we własnych oczach, \add ale\add* bój się PANA i odstąp od zła.
\m 
\v 8 \add To\add* da twemu ciału zdrowie i pokrzepienie twoim kościom.
\m 
\v 9 Czcij PANA swoim majątkiem i pierwocinami wszystkich twoich dochodów.
\m 
\v 10 A twoje spichrze będą napełnione dostatkiem i twoje prasy będą przelewać się od nowego wina.
\m 
\v 11 Synu mój, nie gardź karceniem PANA i nie zniechęcaj się jego upomnieniem.
\m 
\v 12 Bo kogo PAN miłuje, tego karze, jak ojciec syna, \add którego\add* kocha.
\m 
\v 13 Błogosławiony człowiek, który znajduje mądrość, i człowiek, który nabiera rozumu;
\m 
\v 14 Gdyż jego nabycie jest lepsze niż nabycie srebra, jego zdobycie \add bardziej pożyteczne\add* niż złoto.
\m 
\v 15 Jest droższa nad perły i żadna rzecz, której pragniesz, nie dorówna jej.
\m 
\v 16 Długie dni są w jej prawej ręce, a w lewej bogactwa i chwała.
\m 
\v 17 Jej drogi są drogami rozkoszy i wszystkie jej ścieżki spokojne.
\m 
\v 18 Jest drzewem życia dla tych, którzy się jej chwycą; a ci, którzy się jej trzymają, są błogosławieni.
\m 
\v 19 PAN ugruntował ziemię mądrością, a niebiosa umocnił rozumem.
\m 
\v 20 Dzięki jego wiedzy rozstąpiły się głębiny, a obłoki spuszczają rosę.
\m 
\v 21 Synu mój, niech \add one\add* ci \add z\add* oczu nie schodzą; strzeż prawdziwej mądrości i roztropności;
\m 
\v 22 A będą życiem twojej duszy i ozdobą twojej szyi.
\m 
\v 23 Wtedy będziesz bezpiecznie chodził swoją drogą, a noga twoja się nie potknie.
\m 
\v 24 Gdy się położysz, nie będziesz się lękał; a gdy zaśniesz, twój sen będzie przyjemny.
\m 
\v 25 Nie lękaj się nagłego strachu ani spustoszenia niegodziwych, gdy przyjdzie.
\m 
\v 26 PAN bowiem będzie twoją ufnością i twojej nogi będzie strzegł od sideł.
\m 
\v 27 Nie wzbraniaj się dobrze czynić potrzebującemu, gdy stać cię na to, aby \add dobrze\add* czynić.
\m 
\v 28 Nie mów bliźniemu: Idź i przyjdź znowu, dam ci jutro, gdy masz to u siebie.
\m 
\v 29 Nie knuj zła przeciwko swemu bliźniemu, gdy spokojnie mieszka obok ciebie.
\m 
\v 30 Nie spieraj się z człowiekiem bez przyczyny, jeśli ci nic złego nie wyrządził.
\m 
\v 31 Nie zazdrość ciemięzcy i nie wybieraj żadnej z jego dróg.
\m 
\v 32 Przewrotny bowiem budzi w PANU odrazę, ale jego tajemnica \add jest\add* z prawymi.
\m 
\v 33 Przekleństwo PANA \add jest\add* w domu niegodziwego, lecz \add PAN\add* błogosławi mieszkanie sprawiedliwych.
\m 
\v 34 On szydzi z szyderców, ale daje łaskę pokornym.
\m 
\v 35 Mądrzy odziedziczą chwałę, a głupi poniosą hańbę.
\c 4
\m 
\v 1 Słuchajcie, synowie, pouczenia ojca i zważajcie na to, abyście poznali roztropność;
\m 
\v 2 Bo daję wam dobrą naukę, nie porzucajcie mego prawa.
\m 
\v 3 Byłem bowiem synem mego ojca i \add miłym\add* jedynakiem w oczach mojej matki.
\m 
\v 4 On mnie uczył, mówiąc mi: Niech twoje serce zachowa moje słowa; strzeż moich przykazań, a będziesz żył.
\m 
\v 5 Zdobywaj mądrość, zdobywaj roztropność; nie zapominaj i nie odstępuj od słów moich ust.
\m 
\v 6 Nie opuszczaj jej, a będzie cię strzegła; ukochaj ją, a zachowa cię.
\m 
\v 7 Podstawą \add wszystkiego jest\add* mądrość; zdobywaj mądrość i za cały swój majątek zdobywaj roztropność.
\m 
\v 8 Wywyższaj ją, a ona wywyższy ciebie, rozsławi cię, gdy ją przyjmiesz.
\m 
\v 9 Wdzięczną ozdobę włoży ci na głowę, obdarzy cię koroną chwały.
\m 
\v 10 Słuchaj, synu mój, i przyjmij moje słowa, a pomnożą się lata twojego życia.
\m 
\v 11 Nauczyłem cię drogi mądrości, po ścieżkach prawości cię wiodłem;
\m 
\v 12 Gdy \add nimi\add* pójdziesz, twoje kroki nie będą skrępowane; a jeśli pobiegniesz, nie potkniesz się.
\m 
\v 13 Trzymaj się karności, nie opuszczaj \add jej\add*, strzeż jej, bo ona jest twoim życiem.
\m 
\v 14 Nie chodź ścieżką niegodziwych i nie wchodź na drogę złych ludzi.
\m 
\v 15 Unikaj jej, nie chodź po niej; odwróć się od niej i omiń \add ją\add*;
\m 
\v 16 Bo \add oni\add* nie zasną, dopóki nie zrobią czegoś złego; sen ich odleci, aż przywiodą \add kogoś\add* do upadku;
\m 
\v 17 Jedzą bowiem chleb nieprawości i piją wino przemocy.
\m 
\v 18 Ale ścieżka sprawiedliwych \add jest\add* jak jasne światło, które świeci coraz jaśniej aż do dnia doskonałego.
\m 
\v 19 Droga niegodziwych \add jest\add* jak ciemność; nie wiedzą, o co mogą się potknąć.
\m 
\v 20 Synu mój, zważaj na moje słowa; ku moim naukom nakłoń swe ucho.
\m 
\v 21 Niech nie schodzą ci z oczu, zachowaj je w głębi twego serca.
\m 
\v 22 \add Są\add* bowiem życiem dla tych, którzy je znajdują, i lekarstwem dla całego ich ciała.
\m 
\v 23 Strzeż twego serca z całą pilnością, bo z niego tryska życie.
\m 
\v 24 Odsuń od siebie przewrotność ust, oddal od siebie złośliwe wargi.
\m 
\v 25 Niech twoje oczy patrzą na wprost, a twoje powieki niech będą zwrócone przed siebie.
\m 
\v 26 Uważaj na ścieżkę twoich nóg, aby wszystkie twoje drogi były pewne.
\m 
\v 27 Nie zbaczaj ani na prawo, ani na lewo; odwróć twoją nogę od zła.
\c 5
\m 
\v 1 Synu mój, zważaj na moją mądrość i nakłoń twego ucha ku mojemu rozumowi;
\m 
\v 2 Abyś zachował rozwagę i \add aby\add* twoje wargi strzegły wiedzy.
\m 
\v 3 Bo wargi obcej kobiety ociekają miodem, a jej usta gładsze są niż oliwa;
\m 
\v 4 Lecz jej koniec jest gorzki jak piołun, ostry jak miecz obosieczny.
\m 
\v 5 Jej nogi zstępują do śmierci, jej kroki prowadzą do piekła.
\m 
\v 6 Abyś nie rozważał ścieżki życia, jej drogi są \add tak\add* niestałe, \add że\add* nie poznasz \add ich\add*.
\m 
\v 7 Teraz więc, synowie, słuchajcie mnie i nie odstępujcie od słów moich ust.
\m 
\v 8 Oddal od niej swą drogę i nie zbliżaj się do drzwi jej domu;
\m 
\v 9 Abyś nie oddał obcym twojej sławy, a twoich lat okrutnikowi;
\m 
\v 10 Aby obcy nie nasycili się twoim dobytkiem, a twój dorobek \add nie został\add* w cudzym domu;
\m 
\v 11 I abyś nie jęczał u kresu swych dni, gdy twoja skóra i ciało będą zniszczone;
\m 
\v 12 I nie musiał powiedzieć: O, jakże nienawidziłem karności i moje serce gardziło upomnieniem!
\m 
\v 13 Nie słuchałem głosu moich wychowawców i nie nakłaniałem ucha ku tym, którzy mnie nauczali!
\m 
\v 14 O mało co nie wpadłem we wszelkie nieszczęście wśród zebrania i zgromadzenia.
\m 
\v 15 Pij wodę z własnego zdroju i wody płynące z twojego źródła!
\m 
\v 16 Niech rozproszą się twoje źródła, a po ulicach strumienie wód.
\m 
\v 17 Niech należą tylko do ciebie, a nie do obcych wraz z tobą.
\m 
\v 18 Niech twój zdrój będzie błogosławiony i ciesz się żoną twojej młodości.
\m 
\v 19 \add Niech będzie jak\add* wdzięczna łania i rozkoszna sarna; niech jej piersi zawsze cię nasycają, nieustannie zachwycaj się jej miłością.
\m 
\v 20 Dlaczego, synu mój, masz zachwycać się obcą kobietą i obejmować piersi cudzej?
\m 
\v 21 Gdyż drogi człowieka są przed oczami PANA \add i\add* waży \add on\add* wszystkie jego ścieżki.
\m 
\v 22 Niegodziwego schwytają jego własne nieprawości i uwikła się w powrozy swego grzechu.
\m 
\v 23 Umrze z braku karności i będzie błądził z powodu swojej wielkiej głupoty.
\c 6
\m 
\v 1 Synu mój, jeśli poręczyłeś za swego bliźniego i dałeś porękę za obcego;
\m 
\v 2 Związałeś się słowami ust twoich, schwytany jesteś mową twoich ust.
\m 
\v 3 Uczyń więc tak, synu mój, uwolnij się, gdy wpadłeś w ręce swego bliźniego; idź, upokórz się i nalegaj na twego bliźniego.
\m 
\v 4 Nie daj snu swoim oczom i nie pozwól powiekom drzemać.
\m 
\v 5 Uwolnij się jak sarna z rąk \add myśliwego\add* i jak ptak z ręki ptasznika.
\m 
\v 6 Idź do mrówki, leniwcze, przypatrz się jej drogom i bądź mądry;
\m 
\v 7 Chociaż nie ma ona wodza ani przełożonego, ani pana;
\m 
\v 8 To w lecie przygotowuje swój pokarm i gromadzi w żniwa swą żywność.
\m 
\v 9 Jak długo będziesz leżał, leniwcze? Kiedy wstaniesz ze swego snu?
\m 
\v 10 Jeszcze trochę snu, trochę drzemania, trochę założenia rąk, aby zasnąć;
\m 
\v 11 A twoje ubóstwo przyjdzie jak podróżny i twój niedostatek jak mąż uzbrojony.
\m 
\v 12 Człowiek nikczemny i niegodziwy chodzi z przewrotnością na ustach;
\m 
\v 13 Mruga swymi oczyma, mówi swymi nogami, wskazuje swymi palcami;
\m 
\v 14 Przewrotność \add jest\add* w jego sercu, stale knuje zło \add i\add* sieje niezgodę.
\m 
\v 15 Dlatego nagle spadnie na niego nieszczęście; nagle zostanie złamany i pozbawiony ratunku.
\m 
\v 16 Jest sześć rzeczy, których nienawidzi PAN, siedem budzi w nim odrazę:
\m 
\v 17 Wyniosłe oczy, kłamliwy język i ręce, które przelewają krew niewinną;
\m 
\v 18 Serce, które knuje złe myśli; nogi, które spiesznie biegną do zła;
\m 
\v 19 Fałszywy świadek, który mówi kłamstwa, i ten, który sieje niezgodę między braćmi.
\m 
\v 20 Synu mój, strzeż przykazania twego ojca i nie odrzucaj prawa twojej matki.
\m 
\v 21 Przywiąż je na zawsze do serca twego i zawieś je sobie na szyi.
\m 
\v 22 Gdy będziesz chodził, poprowadzi cię; gdy zaśniesz, strzec cię będzie, a gdy się obudzisz, będzie mówić do ciebie;
\m 
\v 23 Bo przykazanie \add jest\add* pochodnią, prawo światłością, a upomnienia do karności są drogą życia;
\m 
\v 24 Aby cię strzegły przed złą kobietą \add i\add* przed gładkim językiem obcej kobiety.
\m 
\v 25 Nie pożądaj w twoim sercu jej piękności i niech cię nie łowi swymi powiekami.
\m 
\v 26 Bo dla kobiety nierządnej \add zubożeje człowiek\add* o kawałek chleba, a żona cudzołożna czyha na cenne życie.
\m 
\v 27 Czy może ktoś wziąć ogień w zanadrze, a jego szaty się nie spalą?
\m 
\v 28 Czy może ktoś chodzić po rozżarzonych węglach, a jego nogi się nie poparzą?
\m 
\v 29 Tak ten, kto wchodzi do żony swego bliźniego; ktokolwiek ją dotknie, nie będzie bez winy.
\m 
\v 30 Nie pogardza się złodziejem, jeśli kradnie, by nasycić swoją duszę, będąc głodnym;
\m 
\v 31 Ale \add jeśli\add* go złapią, zwróci siedmiokrotnie \add albo\add* odda cały dobytek swego domu.
\m 
\v 32 Lecz kto cudzołoży z kobietą, jest pozbawiony rozsądku; kto tak robi, gubi swoją duszę.
\m 
\v 33 Znajdzie chłostę i wstyd, a jego hańba nie będzie zmazana.
\m 
\v 34 Bo zazdrość rozpala gniew mężczyzny i nie będzie pobłażał w dniu zemsty.
\m 
\v 35 Nie będzie miał względu na żaden okup i nie przyjmie darów, choćbyś najwięcej mu dawał.
\c 7
\m 
\v 1 Synu mój, strzeż moich słów i przechowuj u siebie moje przykazania.
\m 
\v 2 Strzeż moich przykazań, a będziesz żył; \add strzeż\add* mojego prawa jak źrenicy swych oczu.
\m 
\v 3 Przywiąż je do swoich palców, wypisz je na tablicy twego serca.
\m 
\v 4 Mów do mądrości: Jesteś moją siostrą, a roztropność nazywaj przyjaciółką;
\m 
\v 5 Aby cię strzegły przed cudzą żoną i przed obcą, \add która\add* mówi gładkie słowa.
\m 
\v 6 Bo z okna swego domu wyglądałem przez kratę;
\m 
\v 7 I zobaczyłem wśród prostych, zauważyłem wśród chłopców nierozumnego młodzieńca;
\m 
\v 8 Który przechodził ulicą blisko jej narożnika, idąc drogą do jej domu.
\m 
\v 9 O zmierzchu, pod wieczór, w ciemności nocnej i w mroku.
\m 
\v 10 A oto spotkała go kobieta w stroju nierządnicy, chytrego serca;
\m 
\v 11 Wrzaskliwa i nieopanowana, której nogi nie mogą pozostać w domu:
\m 
\v 12 Raz na dworze, raz na ulicach i czyha na każdym rogu.
\m 
\v 13 Chwyciła go i pocałowała, z bezczelną miną powiedziała do niego:
\m 
\v 14 U mnie są ofiary pojednawcze; spełniłam dzisiaj swoje śluby.
\m 
\v 15 Dlatego wyszłam ci naprzeciw, szukałam pilnie twojej twarzy i znalazłam cię.
\m 
\v 16 Obiłam kobiercami swoje łoże, \add przystrojone\add* rzeźbieniem i prześcieradłami z Egiptu.
\m 
\v 17 Skropiłam swoje posłanie mirrą, aloesem i cynamonem.
\m 
\v 18 Chodź, upójmy się miłością aż do rana, nacieszmy się miłością.
\m 
\v 19 Bo \add mojego\add* męża nie ma w domu; pojechał w daleką drogę.
\m 
\v 20 Wziął ze sobą worek pieniędzy; umówionego dnia wróci do domu.
\m 
\v 21 Nakłoniła go mnóstwem swoich słów i zniewoliła go pochlebstwem swoich warg.
\m 
\v 22 Wnet poszedł za nią jak wół prowadzony na rzeź i jak głupi na karę pęt.
\m 
\v 23 Aż strzała przebije mu wątrobę; spieszy jak ptak w sidła, nie wiedząc, że \add chodzi\add* o jego życie.
\m 
\v 24 Więc teraz słuchajcie mnie, synowie, i zważajcie na słowa moich ust.
\m 
\v 25 Niech twoje serce nie zbacza na jej drogi i nie tułaj się po jej ścieżkach.
\m 
\v 26 Bo wielu zranionych strąciła i wielu mocarzy pozabijała.
\m 
\v 27 Jej dom \add jest\add* drogą do piekła, która wiedzie do komnat śmierci.
\c 8
\m 
\v 1 Czy mądrość nie woła i rozum nie wydaje swego głosu?
\m 
\v 2 Stoi na szczycie wysokich miejsc, przy drodze, na rozstajach dróg.
\m 
\v 3 Przy bramach, przy wjeździe do miasta, przy wejściu, u drzwi woła:
\m 
\v 4 Do was wołam, o mężowie, mój głos \add kieruję\add* do synów ludzkich.
\m 
\v 5 Prości, uczcie się rozwagi, a wy, głupi, bądźcie rozumnego serca.
\m 
\v 6 Słuchajcie, bo będę mówił o rzeczach wzniosłych, a wargi moje otworzą się, aby \add głosić\add* prawość.
\m 
\v 7 Moje usta bowiem mówią prawdę, a niegodziwością brzydzą się moje wargi.
\m 
\v 8 Sprawiedliwe są wszystkie słowa moich ust; nie ma w nich nic fałszywego ani przewrotnego.
\m 
\v 9 Wszystkie są jasne dla rozumnego i prawe dla tych, którzy znajdują wiedzę.
\m 
\v 10 Przyjmijcie moje pouczenie zamiast srebra i wiedzę \add raczej\add* niż wyborne złoto.
\m 
\v 11 Lepsza bowiem jest mądrość niż perły i żadna rzecz, której pragniesz, nie dorówna jej.
\m 
\v 12 Ja, mądrość, mieszkam z rozwagą i odkrywam wiedzę roztropności.
\m 
\v 13 Bojaźń PANA to nienawidzić zła. Ja nienawidzę pychy, wyniosłości, złej drogi i ust przewrotnych.
\m 
\v 14 Moja \add jest\add* rada i prawdziwa mądrość, ja \add jestem\add* roztropnością i moja jest moc.
\m 
\v 15 Dzięki mnie królowie rządzą i władcy stanowią sprawiedliwość.
\m 
\v 16 Dzięki mnie panują władcy i dostojnicy, wszyscy sędziowie ziemi.
\m 
\v 17 Miłuję tych, którzy mnie miłują, a ci, którzy szukają mnie pilnie, znajdą mnie.
\m 
\v 18 Przy mnie \add jest\add* bogactwo i chwała, trwałe bogactwo i sprawiedliwość.
\m 
\v 19 Mój owoc \add jest\add* lepszy niż złoto, nawet najczystsze złoto, a moje plony \add lepsze\add* niż wyborne srebro.
\m 
\v 20 Prowadzę ścieżką sprawiedliwości, pośród ścieżek sądu;
\m 
\v 21 Aby tym, którzy mnie miłują, dać w dziedzictwo majątek wieczny i napełnić ich skarbce.
\m 
\v 22 PAN posiadł mnie na początku swej drogi, przed swymi dziełami, przed wszystkimi czasy.
\m 
\v 23 Przed wiekami zostałam ustanowiona, od początku; zanim powstała ziemia;
\m 
\v 24 Gdy jeszcze nie było głębin, zostałam zrodzona, kiedy jeszcze nie było źródeł obfitujących w wody.
\m 
\v 25 Zanim góry zostały założone, nim były pagórki, zostałam zrodzona.
\m 
\v 26 Gdy jeszcze nie stworzył ziemi ani pól, ani początku prochu okręgu ziemskiego;
\m 
\v 27 Kiedy przygotowywał niebiosa, byłam tam; gdy odmierzał okrąg nad powierzchnią głębi;
\m 
\v 28 Gdy w górze utwierdzał obłoki i umacniał źródła głębin;
\m 
\v 29 Gdy wyznaczał morzu jego granice, by wody nie przekraczały jego rozkazu, kiedy ustalał fundamenty ziemi;
\m 
\v 30 Byłam wtedy przy nim \add jak\add* wychowanka i byłam \add jego\add* radością każdego dnia, ciesząc się zawsze przed nim;
\m 
\v 31 Radując się na okręgu jego ziemi, rozkoszując się synami ludzkimi.
\m 
\v 32 Teraz więc, synowie, słuchajcie mnie, bo błogosławieni są ci, którzy strzegą moich dróg.
\m 
\v 33 Słuchajcie pouczeń, nabądźcie mądrości i nie odrzucajcie jej.
\m 
\v 34 Błogosławiony człowiek, który mnie słucha, czuwając u moich wrót każdego dnia i strzegąc odrzwi moich bram.
\m 
\v 35 Bo kto mnie znajduje, znajduje życie i otrzyma łaskę od PANA.
\m 
\v 36 Ale kto grzeszy przeciwko mnie, wyrządza krzywdę swojej duszy; wszyscy, którzy mnie nienawidzą, miłują śmierć.
\c 9
\m 
\v 1 Mądrość zbudowała sobie dom \add i\add* wyciosała siedem słupów;
\m 
\v 2 Zabiła swoje bydło, zmieszała wino i zastawiła stół;
\m 
\v 3 Rozesłała swoje służące, woła na szczytach najwyższych miejsc miasta:
\m 
\v 4 Ktokolwiek jest prostym, niech wstąpi; \add a\add* do nierozumnego mówi:
\m 
\v 5 Chodźcie, jedzcie mój chleb i pijcie wino, które zmieszałam.
\m 
\v 6 Porzućcie głupotę, a będziecie żyli, i chodźcie drogą roztropności.
\m 
\v 7 Kto upomina szydercę, ściąga na siebie hańbę, a kto strofuje niegodziwego, ten się plami.
\m 
\v 8 Nie strofuj szydercy, aby cię nie znienawidził; strofuj mądrego, a będzie cię miłował.
\m 
\v 9 Upomnij mądrego, a będzie mądrzejszy; poucz sprawiedliwego, a pomnoży swą wiedzę.
\m 
\v 10 Początkiem mądrości \add jest\add* bojaźń PANA, a wiedza o tym, co święte, to rozum.
\m 
\v 11 Bo dzięki mnie rozmnożą się twoje dni i przedłużą się lata \add twojego\add* życia.
\m 
\v 12 Jeśli będziesz mądry, tobie samemu będzie \add służyła\add* twoja mądrość; a jeśli szydercą, sam poniesiesz szkodę.
\m 
\v 13 Głupia kobieta \add jest\add* wrzaskliwa, prosta i nic nie rozumie;
\m 
\v 14 Siedzi u drzwi swego domu, na krześle, na wysokich miejscach w mieście;
\m 
\v 15 Aby wołać na przechodzących, którzy idą prosto swoimi ścieżkami:
\m 
\v 16 Ktokolwiek jest prosty, niech wstąpi; a do nierozumnego mówi:
\m 
\v 17 Kradzione wody są słodkie, a chleb jedzony pokątnie smaczny.
\m 
\v 18 Ale \add on\add* nie wie, że tam są umarli, że jej zaproszeni \add są\add* w głębinach piekła.
\c 10
\m 
\v 1 Przysłowia Salomona. Mądry syn sprawia ojcu radość, a głupi syn \add jest\add* zgryzotą swojej matki.
\m 
\v 2 Skarby niegodziwości nie przynoszą pożytku, lecz sprawiedliwość uwalnia od śmierci.
\m 
\v 3 PAN nie pozwoli, by dusza sprawiedliwego cierpiała głód, a rozproszy majątek niegodziwych.
\m 
\v 4 Leniwa ręka prowadzi do nędzy, a ręka pracowita ubogaca.
\m 
\v 5 Kto zbiera w lecie, jest synem roztropnym; syn, który śpi w czasie żniwa, przynosi hańbę.
\m 
\v 6 Błogosławieństwa \add są\add* na głowie sprawiedliwego, a usta niegodziwych kryją nieprawość.
\m 
\v 7 Pamięć sprawiedliwego jest błogosławiona, a imię niegodziwych zgnije.
\m 
\v 8 \add Człowiek\add* mądrego serca przyjmuje przykazania, a gadatliwy głupiec upadnie.
\m 
\v 9 Kto postępuje uczciwie, postępuje bezpiecznie, a kto jest przewrotny w swoich drogach, zostanie ujawniony.
\m 
\v 10 Kto mruga okiem, przynosi cierpienie, a gadatliwy głupiec upadnie.
\m 
\v 11 Usta sprawiedliwego są źródłem życia, a usta niegodziwych kryją nieprawość.
\m 
\v 12 Nienawiść wznieca kłótnie, a miłość zakrywa wszystkie grzechy.
\m 
\v 13 Na wargach rozumnego znajduje się mądrość, a kij na grzbiecie nierozumnego.
\m 
\v 14 Mądrzy gromadzą wiedzę, a usta głupiego grożą zniszczeniem.
\m 
\v 15 Majątek bogacza \add jest\add* jego warownym miastem, a zniszczeniem ubogich jest ich nędza.
\m 
\v 16 Praca sprawiedliwego \add prowadzi\add* do życia, a dochód niegodziwych do grzechu.
\m 
\v 17 Kto przestrzega karności, \add idzie\add* ścieżką życia, a kto gardzi upomnieniem, błądzi.
\m 
\v 18 Kto kryje nienawiść kłamliwymi wargami i kto rozgłasza oszczerstwo, jest głupcem.
\m 
\v 19 Wielomówność nie bywa bez grzechu, a kto powściąga swoje wargi, jest roztropny.
\m 
\v 20 Język sprawiedliwego jest wybornym srebrem, \add a\add* serce niegodziwych jest mało warte.
\m 
\v 21 Wargi sprawiedliwego żywią wielu, a głupi umierają przez brak rozumu.
\m 
\v 22 Błogosławieństwo PANA wzbogaca i nie przynosi z sobą zmartwień.
\m 
\v 23 Dla głupiego popełnić haniebny czyn to zabawa, a człowiek roztropny \add trzyma się\add* mądrości.
\m 
\v 24 Niegodziwego spotka to, czego się boi, a sprawiedliwym \add Bóg\add* daje to, czego pragną.
\m 
\v 25 Jak wicher przemija, \add tak\add* niegodziwy \add nie przetrwa\add*, a sprawiedliwy \add ma\add* wieczny fundament.
\m 
\v 26 Czym ocet dla zębów i dym dla oczu, tym \add jest\add* leniwy dla tych, którzy go posyłają.
\m 
\v 27 Bojaźń PANA przedłuża dni, a lata niegodziwego będą skrócone.
\m 
\v 28 Oczekiwanie sprawiedliwych przynosi radość, a nadzieja niegodziwych zginie.
\m 
\v 29 Droga PANA jest mocą dla prawego, a zgubą dla czyniących nieprawość.
\m 
\v 30 Sprawiedliwy nigdy się nie zachwieje, a niegodziwi nie będą mieszkać na ziemi.
\m 
\v 31 Usta sprawiedliwego wydają mądrość, a język przewrotny będzie wycięty.
\m 
\v 32 Wargi sprawiedliwego wiedzą, co wypada, a usta niegodziwych są przewrotne.
\c 11
\m 
\v 1 Fałszywa waga budzi odrazę w PANU, ale podobają mu się uczciwe odważniki.
\m 
\v 2 Za pychą przychodzi hańba, a u pokornych jest mądrość.
\m 
\v 3 Uczciwość prawych poprowadzi ich, lecz grzeszników zgubi ich przewrotność.
\m 
\v 4 Bogactwa nie pomogą w dniu gniewu, ale sprawiedliwość ocala od śmierci.
\m 
\v 5 Sprawiedliwość nienagannego toruje mu drogę, a niegodziwy upadnie przez swoją niegodziwość.
\m 
\v 6 Sprawiedliwość prawych ocali ich, a przewrotni będą schwytani w swojej przewrotności.
\m 
\v 7 Gdy umiera niegodziwy, ginie \add jego\add* nadzieja, a oczekiwanie niesprawiedliwych znika.
\m 
\v 8 Sprawiedliwy bywa wybawiony z ucisku, a na jego miejsce przychodzi niegodziwy.
\m 
\v 9 Obłudnik ustami niszczy swego bliźniego, a sprawiedliwi bywają wybawieni dzięki wiedzy.
\m 
\v 10 Gdy sprawiedliwym się powodzi, miasto się cieszy, a gdy giną niegodziwi, panuje radość.
\m 
\v 11 Dzięki błogosławieństwu prawych wznosi się miasto, a usta niegodziwych je burzą.
\m 
\v 12 Nierozumny gardzi swym bliźnim, a człowiek roztropny milczy.
\m 
\v 13 Plotkarz wyjawia tajemnice, ale człowiek wiernego serca ukrywa \add powierzoną\add* sprawę.
\m 
\v 14 Gdzie nie ma dobrej rady, lud upada, a gdzie wielu radców, tam jest wybawienie.
\m 
\v 15 Bardzo sobie szkodzi, kto ręczy za obcego, a kto nienawidzi poręki, jest bezpieczny.
\m 
\v 16 Miła kobieta dostępuje chwały, a mocarze zdobywają bogactwa.
\m 
\v 17 Człowiek miłosierny czyni dobrze swej duszy, a okrutnik dręczy własne ciało.
\m 
\v 18 Niegodziwy czyni zwodnicze dzieło, a kto sieje sprawiedliwość, \add ma\add* zapłatę pewną.
\m 
\v 19 Jak sprawiedliwość \add prowadzi\add* do życia, tak do śmierci \add zmierza\add* ten, kto naśladuje zło.
\m 
\v 20 Ludzie przewrotnego serca budzą odrazę w PANU, a podobają mu się ci, których droga jest prawa.
\m 
\v 21 Zły nie uniknie kary, choćby \add innych\add* wezwał na pomoc, a potomstwo sprawiedliwych będzie ocalone.
\m 
\v 22 \add Czym\add* złoty kolczyk w ryju świni, \add tym\add* piękna kobieta pozbawiona roztropności.
\m 
\v 23 Pragnieniem sprawiedliwych jest tylko dobro, oczekiwaniem zaś niegodziwych – gniew.
\m 
\v 24 Jeden hojnie rozdaje, a jednak mu przybywa, \add drugi\add* nad miarę skąpi, a ubożeje.
\m 
\v 25 Człowiek szczodry będzie bogatszy, a kto \add innych\add* syci, sam też będzie nasycony.
\m 
\v 26 Kto zatrzymuje zboże, tego lud przeklnie, a błogosławieństwo \add będzie\add* nad głową tego, który je sprzedaje.
\m 
\v 27 Kto pilnie szuka dobrego, zdobędzie przychylność, lecz kto szuka zła, przyjdzie ono na niego.
\m 
\v 28 Kto ufność pokłada w swych bogactwach, ten upadnie, a sprawiedliwi będą zielenić się jak latorośl.
\m 
\v 29 Kto niepokoi swój dom, odziedziczy wiatr, a głupi będzie sługą mądrego.
\m 
\v 30 Owoc sprawiedliwego \add jest\add* drzewem życia; a kto zyskuje dusze, jest mądry.
\m 
\v 31 \add Jeśli\add* sprawiedliwy otrzyma zapłatę na ziemi, to tym bardziej niegodziwy i grzesznik.
\c 12
\m 
\v 1 Kto kocha karność, kocha wiedzę, a kto nienawidzi upomnienia, jest głupi.
\m 
\v 2 Dobry \add człowiek\add* zdobędzie łaskę PANA, ale \add PAN\add* potępi podstępnego.
\m 
\v 3 Człowiek nie umocni się niegodziwością, lecz korzeń sprawiedliwych nie będzie poruszony.
\m 
\v 4 Żona cnotliwa \add jest\add* koroną swego męża, ale ta, która go hańbi, \add jest\add* jak zgnilizna w jego kościach.
\m 
\v 5 Myśli sprawiedliwych są prawe, a rady niegodziwych zdradliwe.
\m 
\v 6 Słowa niegodziwych czyhają na krew, lecz usta prawych ocalą ich.
\m 
\v 7 Niegodziwi zostają powaleni i już ich nie ma, a dom sprawiedliwych się ostoi.
\m 
\v 8 Człowiek będzie chwalony za jego mądrość, a kto jest przewrotnego serca, zostanie wzgardzony.
\m 
\v 9 Lepszy \add jest człowiek\add* wzgardzony, który ma sługę, niż ten, kto się chwali, a któremu brak chleba.
\m 
\v 10 Sprawiedliwy dba o życie swego bydła, a serce niegodziwych jest okrutne.
\m 
\v 11 Kto uprawia swoją ziemię, nasyci się chlebem, a kto naśladuje próżnujących, jest nierozumny.
\m 
\v 12 Niegodziwy pragnie sieci złych, a korzeń sprawiedliwych wydaje \add owoc\add*.
\m 
\v 13 Zły zostaje usidlony przez grzech swoich warg, a sprawiedliwy wyjdzie z ucisku.
\m 
\v 14 Człowiek nasyci się dobrem z owocu swoich ust, a za \add dzieła\add* swoich rąk otrzyma zapłatę.
\m 
\v 15 Droga głupiego \add wydaje się\add* słuszna w jego oczach, ale kto słucha rady, jest mądry.
\m 
\v 16 Gniew głupiego objawia się od razu, a roztropny skrywa hańbę.
\m 
\v 17 Kto mówi prawdę, wyraża sprawiedliwość, ale fałszywy świadek – oszustwo.
\m 
\v 18 Znajdzie się taki, którego \add słowa\add* są jak miecz przeszywający, lecz język mądrych \add jest\add* lekarstwem.
\m 
\v 19 Prawdomówne wargi będą trwać na wieki, ale język kłamliwy \add trwa\add* króciutko.
\m 
\v 20 Podstęp \add jest\add* w sercu tych, którzy knują zło, lecz u doradzających pokój \add jest\add* radość.
\m 
\v 21 Sprawiedliwego nie spotka żadne zło, ale niegodziwi będą pełni nieszczęścia.
\m 
\v 22 Wargi kłamliwe budzą odrazę w PANU, a ci, którzy postępują w prawdzie, podobają mu się.
\m 
\v 23 Człowiek roztropny ukrywa wiedzę, a serce głupich rozgłasza głupotę.
\m 
\v 24 Ręka pracowitych będzie panowała, a leniwa będzie płaciła daninę.
\m 
\v 25 Troska w sercu człowieka przygnębia je, a dobre słowo je rozwesela.
\m 
\v 26 Sprawiedliwy jest zacniejszy od swego bliźniego, a droga niegodziwych prowadzi ich na manowce.
\m 
\v 27 Leniwy nie upiecze tego, co upolował, ale mienie człowieka pracowitego \add jest\add* cenne.
\m 
\v 28 Na ścieżce sprawiedliwości jest życie, na jej drodze nie ma śmierci.
\c 13
\m 
\v 1 Mądry syn \add przyjmuje\add* pouczenie ojca, a szyderca nie słucha strofowania.
\m 
\v 2 Człowiek będzie spożywać dobro z owocu swoich ust, a dusza przewrotnych \add będzie spożywać\add* przemoc.
\m 
\v 3 Kto strzeże swych ust, strzeże swojej duszy; kto \add szeroko\add* otwiera swe wargi, będzie zniszczony.
\m 
\v 4 Dusza leniwego pragnie, a nic nie ma, a dusza pracowitych zostanie obficie nasycona.
\m 
\v 5 Sprawiedliwy nienawidzi kłamliwego słowa, a niegodziwy staje się obrzydliwy i zhańbiony.
\m 
\v 6 Sprawiedliwość strzeże tego, który postępuje uczciwie, a niegodziwość powala grzesznika.
\m 
\v 7 Znajduje się taki, który czyni siebie bogatym, a nie ma nic; inny czyni siebie ubogim, choć ma wiele bogactw.
\m 
\v 8 Okupem za życie człowieka jest jego bogactwo, a ubogi nie słucha strofowania.
\m 
\v 9 Radośnie błyszczy światło sprawiedliwych, a pochodnia niegodziwych zgaśnie.
\m 
\v 10 Spór powstaje tylko dzięki pysze, a mądrość jest przy tych, co przyjmują radę.
\m 
\v 11 Łatwo zdobyte bogactwo zmniejsza się, a kto je gromadzi \add swą\add* ręką, pomnaża je.
\m 
\v 12 Przedłużająca się nadzieja sprawia ból sercu, a spełnione pragnienie \add jest\add* drzewem życia.
\m 
\v 13 Kto gardzi słowem \add Bożym\add*, ten zginie, a kto się boi przykazania, dostanie nagrodę.
\m 
\v 14 Prawo mądrego jest źródłem życia, by uniknąć sideł śmierci.
\m 
\v 15 Prawdziwy rozum daje łaskę, a droga przewrotnych jest ciężka.
\m 
\v 16 Każdy roztropny postępuje rozważnie, a głupi ujawnia głupotę.
\m 
\v 17 Niegodziwy posłaniec popada w zło, a wierny wysłannik jest lekarstwem.
\m 
\v 18 Ubóstwo i hańba \add spadną na\add* tego, który odrzuca karność, a kto szanuje upomnienia, dozna czci.
\m 
\v 19 Spełnione pragnienie jest słodkie dla duszy, a odwrócenie się od zła budzi odrazę w głupcach.
\m 
\v 20 Kto przestaje z mądrymi, będzie mądry, a towarzysz głupców będzie zniszczony.
\m 
\v 21 Nieszczęście ściga grzeszników, a sprawiedliwych \add Bóg\add* nagrodzi dobrem.
\m 
\v 22 Dobry \add człowiek\add* zostawia dziedzictwo dzieciom \add swoich\add* dzieci, a majątek grzesznika jest zachowany dla sprawiedliwego.
\m 
\v 23 Obfita żywność jest na roli ubogich, lecz i ta może niszczeć przez nieroztropność.
\m 
\v 24 Kto oszczędza swą rózgę, nienawidzi swego syna, a kto go kocha, karze w porę.
\m 
\v 25 Sprawiedliwy je i syci swoją duszę, a żołądek niegodziwych cierpi niedostatek.
\c 14
\m 
\v 1 Mądra kobieta buduje swój dom, a głupia burzy go własnymi rękami.
\m 
\v 2 Kto postępuje w sposób prawy, boi się PANA, a przewrotny na swoich drogach gardzi nim.
\m 
\v 3 W ustach głupiego jest rózga pychy, a mądrych strzegą ich wargi.
\m 
\v 4 Gdzie nie ma wołów, żłób jest pusty, lecz dzięki sile wołów mnoży się obfitość zboża.
\m 
\v 5 Wierny świadek nie kłamie, a fałszywy świadek mówi kłamstwa.
\m 
\v 6 Szyderca szuka mądrości, a nie \add znajduje\add*, lecz rozumnemu wiedza \add przychodzi\add* łatwo.
\m 
\v 7 Odsuń się od głupiego, gdyż nie znajdziesz \add u niego\add* warg rozumnych.
\m 
\v 8 Mądrość roztropnego \add to\add* poznanie swojej drogi, a głupotą głupich \add jest\add* oszustwo.
\m 
\v 9 Głupcy szydzą z grzechu, a u prawych \add jest\add* przychylność.
\m 
\v 10 Serce zna własną gorycz, a obcy nie wtrąca się w jego radość.
\m 
\v 11 Dom niegodziwych będzie zgładzony, a mieszkanie prawych zakwitnie.
\m 
\v 12 Jest droga, która człowiekowi wydaje się słuszna, lecz końcem jej jest droga do śmierci.
\m 
\v 13 Nawet w śmiechu serce boleje, a końcem \add takiej\add* wesołości \add jest\add* smutek.
\m 
\v 14 Serce odstępcy nasyci się jego drogami, a dobry człowiek – swoimi.
\m 
\v 15 Prosty wierzy każdemu słowu, a roztropny zważa na swoje kroki.
\m 
\v 16 Mądry boi się i odwraca się od zła, ale głupi w swym szaleństwie jest pewny siebie.
\m 
\v 17 \add Człowiek\add* porywczy popełnia głupstwa, a podstępny jest znienawidzony.
\m 
\v 18 Prości ludzie dziedziczą głupotę, a roztropni są koronowani wiedzą.
\m 
\v 19 Źli kłaniają się przed dobrymi, a niegodziwi u bram sprawiedliwego.
\m 
\v 20 Ubogi jest znienawidzony nawet przez swego bliźniego, a bogaty ma wielu przyjaciół.
\m 
\v 21 Kto gardzi swym bliźnim, ten grzeszy, a kto lituje się nad ubogimi, jest błogosławiony.
\m 
\v 22 Czyż nie błądzą ci, którzy obmyślają zło? Ale miłosierdzie i prawda są z tymi, którzy obmyślają dobro.
\m 
\v 23 Każda praca \add przynosi\add* pożytek, a \add puste\add* słowa \add prowadzą\add* do nędzy.
\m 
\v 24 Koroną mądrych \add jest ich\add* bogactwo, ale głupota głupich \add pozostaje\add* głupotą.
\m 
\v 25 Prawdomówny świadek ocala dusze, a fałszywy mówi kłamstwa.
\m 
\v 26 W bojaźni PANA jest mocne zaufanie, a jego synowie będą mieć ucieczkę.
\m 
\v 27 Bojaźń PANA jest źródłem życia, by uniknąć sideł śmierci.
\m 
\v 28 Liczny lud to chwała króla, a brak ludu to zguba władcy.
\m 
\v 29 Nieskory do gniewu jest bardzo roztropny, lecz porywczy wywyższa głupotę.
\m 
\v 30 Zdrowe serce jest życiem ciała, a zazdrość jest zgnilizną kości.
\m 
\v 31 Kto gnębi ubogiego, uwłacza jego Stwórcy, a czci go ten, kto lituje się nad ubogim.
\m 
\v 32 Niegodziwy zostaje wygnany z powodu swojego zła, a sprawiedliwy ma nadzieję \add nawet\add* w \add czasie\add* swojej śmierci.
\m 
\v 33 Mądrość spoczywa w sercu rozumnego, a \add co jest\add* w sercu głupich, wychodzi na jaw.
\m 
\v 34 Sprawiedliwość wywyższa naród, a grzech jest hańbą narodów.
\m 
\v 35 Król jest przychylny dla roztropnego sługi, lecz gniewa się \add na tego\add*, który \add przynosi\add* hańbę.
\c 15
\m 
\v 1 Łagodna odpowiedź uśmierza zapalczywość, a przykre słowa wzniecają gniew.
\m 
\v 2 Język mądrych zdobi wiedzę, ale usta głupich tryskają głupotą.
\m 
\v 3 Oczy PANA są na każdym miejscu, upatrują złych i dobrych.
\m 
\v 4 Zdrowy język \add jest\add* drzewem życia, a jego przewrotność \add jest\add* zniszczeniem dla ducha.
\m 
\v 5 Głupi gardzi pouczeniem swego ojca, a kto przyjmuje upomnienia, jest roztropny.
\m 
\v 6 W domu sprawiedliwego \add jest\add* wielki dostatek, a w dochodach niegodziwego jest zamieszanie.
\m 
\v 7 Wargi mądrych szerzą wiedzę, a serce głupich nie.
\m 
\v 8 Ofiara niegodziwych budzi odrazę w PANU, \add a\add* modlitwa prawych mu się podoba.
\m 
\v 9 Droga niegodziwego wzbudza odrazę w PANU, a miłuje on tego, kto podąża za sprawiedliwością.
\m 
\v 10 Sroga kara \add należy się\add* temu, kto zbacza z drogi, a kto nienawidzi upomnień, umrze.
\m 
\v 11 Piekło i zatracenie \add są\add* przed PANEM; o ileż bardziej serca synów ludzkich.
\m 
\v 12 Szyderca nie miłuje tego, który go strofuje, ani nie pójdzie do mądrych.
\m 
\v 13 Radosne serce rozwesela twarz, \add ale\add* gdy smutek w sercu, duch jest przygnębiony.
\m 
\v 14 Serce rozumne szuka wiedzy, a usta głupich karmią się głupotą.
\m 
\v 15 Wszystkie dni strapionego \add są\add* złe, ale kto jest wesołego serca, ma nieustanną ucztę.
\m 
\v 16 Lepiej \add mieć\add* mało z bojaźnią PANA niż wielki skarb z kłopotem.
\m 
\v 17 Lepsza jest potrawa z jarzyn, gdzie miłość, niż tuczny wół, gdzie panuje nienawiść.
\m 
\v 18 Człowiek gniewny wszczyna kłótnie, a nieskory do gniewu łagodzi spory.
\m 
\v 19 Droga leniwego jest jak płot cierniowy, a ścieżka prawych jest wyrównana.
\m 
\v 20 Mądry syn jest radością ojca, a człowiek głupi gardzi własną matką.
\m 
\v 21 Głupota \add jest\add* radością dla nierozumnego, a człowiek roztropny postępuje uczciwie.
\m 
\v 22 Gdzie nie ma rady, nie udają się zamysły; powiodą się zaś przy mnóstwie doradców.
\m 
\v 23 Człowiek cieszy się z odpowiedzi swoich ust, a słowo powiedziane we właściwym czasie jakże jest dobre!
\m 
\v 24 Droga życia dla mądrego \add jest\add* w górze, aby uniknął głębokiego piekła.
\m 
\v 25 PAN zniszczy dom pysznych, a utwierdzi granicę wdowy.
\m 
\v 26 Myśli złego budzą odrazę w PANU, a słowa czystych \add są\add* przyjemne.
\m 
\v 27 Kto jest chciwy zysku, ściąga kłopoty na własny dom, a kto nienawidzi darów, będzie żył.
\m 
\v 28 Serce sprawiedliwego rozmyśla nad odpowiedzią, a usta niegodziwych tryskają złymi rzeczami.
\m 
\v 29 PAN jest daleko od niegodziwych, ale wysłuchuje modlitwy sprawiedliwych.
\m 
\v 30 Światło oczu rozwesela serce, a dobra wieść tuczy kości.
\m 
\v 31 Ucho, które słucha upomnienia życia, będzie mieszkać pośród mądrych.
\m 
\v 32 Kto odrzuca karność, gardzi własną duszą, a kto przyjmuje upomnienie, nabiera rozumu.
\m 
\v 33 Bojaźń PANA \add jest\add* pouczeniem w mądrości, a pokora poprzedza chwałę.
\c 16
\m 
\v 1 W człowieku są zamysły serca, ale odpowiedź języka jest od PANA.
\m 
\v 2 Wszystkie drogi człowieka są czyste w jego oczach, ale PAN waży duchy.
\m 
\v 3 Powierz PANU swe dzieła, a twoje zamysły będą utwierdzone.
\m 
\v 4 PAN uczynił wszystko dla samego siebie, nawet niegodziwego na dzień zła.
\m 
\v 5 Każdy, który jest wyniosłego serca, budzi odrazę w PANU; choć weźmie innych do pomocy, nie uniknie kary.
\m 
\v 6 Dzięki miłosierdziu i prawdzie oczyszcza się nieprawość, a w bojaźni PANA oddalamy się od zła.
\m 
\v 7 Gdy drogi człowieka podobają się PANU, to godzi z nim nawet jego nieprzyjaciół.
\m 
\v 8 Lepiej mieć mało ze sprawiedliwością niż wiele dochodów nieprawnych.
\m 
\v 9 Serce człowieka obmyśla swe drogi, ale PAN kieruje jego krokami.
\m 
\v 10 Wyrok Boży \add jest\add* na wargach króla; jego usta nie błądzą w sądzie.
\m 
\v 11 Sprawiedliwa waga i szale \add należą do\add* PANA i wszystkie odważniki w worku są jego dziełem.
\m 
\v 12 Popełnienie niegodziwości budzi odrazę w królach, bo sprawiedliwością tron jest umocniony.
\m 
\v 13 Wargi sprawiedliwe są rozkoszą królów, kochają oni tego, który mówi to, co słuszne.
\m 
\v 14 Gniew króla jest posłańcem śmierci, ale mądry człowiek przebłaga go.
\m 
\v 15 W jasności twarzy króla \add jest\add* życie, a jego przychylność jest jak obłok z późnym deszczem.
\m 
\v 16 O wiele lepiej jest nabyć mądrość niż złoto; a nabyć rozum lepiej niż srebro.
\m 
\v 17 Droga prawych \add to\add* odstąpić od zła; kto strzeże swojej drogi, strzeże swej duszy.
\m 
\v 18 Pycha poprzedza zgubę, a wyniosły duch – upadek.
\m 
\v 19 Lepiej być uniżonego ducha z pokornymi, niż dzielić łup z pysznymi.
\m 
\v 20 Kto zważa na słowo, znajdzie dobro, a kto ufa PANU, \add jest\add* błogosławiony.
\m 
\v 21 Kto \add jest\add* mądrego serca, zwie się rozumnym, a słodycz warg pomnaża wiedzę.
\m 
\v 22 Rozum \add jest\add* zdrojem życia dla tych, którzy go mają, a pouczenie głupich jest głupotą.
\m 
\v 23 Serce mądrego czyni jego usta roztropnymi i dodaje nauki jego wargom.
\m 
\v 24 Miłe słowa są \add jak\add* plaster miodu, słodycz dla duszy i lekarstwo dla kości.
\m 
\v 25 Jest droga, która \add wydaje się\add* człowiekowi słuszna, ale jej końcem jest droga do śmierci.
\m 
\v 26 Robotnik pracuje dla siebie, bo usta pobudzają go \add do tego\add*.
\m 
\v 27 Człowiek nikczemny wykopuje zło, a na jego wargach jakby ogień płonący.
\m 
\v 28 Człowiek przewrotny rozsiewa spory, a plotkarz rozdziela przyjaciół.
\m 
\v 29 Człowiek gwałtowny zwabia swego bliźniego i wprowadza go na drogę niedobrą.
\m 
\v 30 Mruga swymi oczami, by knuć podstępy; rusza wargami i popełnia zło.
\m 
\v 31 Siwa głowa \add jest\add* koroną chwały, zdobywa się ją na drodze sprawiedliwości.
\m 
\v 32 Lepszy jest nieskory do gniewu niż mocarz, a kto panuje nad swym duchem, \add jest lepszy\add* niż ten, kto zdobywa miasto.
\m 
\v 33 Losy wrzuca się w zanadrze, ale całe rozstrzygnięcie ich zależy od PANA.
\c 17
\m 
\v 1 Lepszy \add jest\add* kęs suchego \add chleba\add*, a przy tym spokój, niż dom pełen bydła ofiarnego z kłótnią.
\m 
\v 2 Sługa roztropny będzie panował nad synem, który przynosi hańbę, i wraz z \add jego\add* braćmi będzie miał udział w dziedzictwie.
\m 
\v 3 Tygiel dla srebra, piec dla złota, ale serca bada PAN.
\m 
\v 4 Zły zważa na wargi fałszywe, a kłamca słucha przewrotnego języka.
\m 
\v 5 Kto naśmiewa się z ubogiego, uwłacza jego Stwórcy, a kto się cieszy z nieszczęścia, nie uniknie kary.
\m 
\v 6 Koroną starców są synowie synów, a chlubą synów są ich ojcowie.
\m 
\v 7 Poważna mowa nie przystoi głupiemu, tym mniej kłamliwe usta dostojnikowi.
\m 
\v 8 Dar jest \add jak\add* drogocenny kamień w oczach tego, kto go posiada; gdziekolwiek \add z nim\add* zmierza, ma powodzenie.
\m 
\v 9 Kto kryje grzech, szuka miłości, a kto wyjawia sprawę, rozdziela przyjaciół.
\m 
\v 10 Nagana lepiej działa na rozumnego niż sto razów na głupiego.
\m 
\v 11 Zły szuka jedynie buntu; dlatego zostanie wysłany przeciw niemu okrutny posłaniec.
\m 
\v 12 \add Lepiej\add* człowiekowi spotkać się z niedźwiedzicą, której zabrano młode, niż z głupim w jego głupocie.
\m 
\v 13 Kto odpłaca złem za dobro, temu zło z domu nie ustąpi.
\m 
\v 14 Kto zaczyna kłótnię, \add jest jak\add* ten, co puszcza wodę; \add dlatego\add* zaniechaj sporu, zanim wybuchnie.
\m 
\v 15 Kto usprawiedliwia niegodziwego i kto potępia sprawiedliwego, obaj budzą odrazę w PANU.
\m 
\v 16 Na cóż w ręku głupiego pieniądze, by zdobyć mądrość, \add skoro\add* nie ma rozumu?
\m 
\v 17 Przyjaciel kocha w każdym czasie, a brat rodzi się w nieszczęściu.
\m 
\v 18 Nierozumny człowiek daje porękę i ręczy na oczach przyjaciela.
\m 
\v 19 Kto kocha grzech, kocha spór, a kto podwyższa swoją bramę, szuka zagłady.
\m 
\v 20 Przewrotny w sercu nie znajduje dobra, a kto ma przewrotny język, wpadnie w zło.
\m 
\v 21 Kto spłodzi głupca, \add zrobi to\add* na swój smutek, a ojciec głupiego nie doznaje radości.
\m 
\v 22 Wesołe serce działa dobrze \add jak\add* lekarstwo, a przygnębiony duch wysusza kości.
\m 
\v 23 Niegodziwy bierze dar z zanadrza, aby wypaczać ścieżki sądu.
\m 
\v 24 Mądrość \add jest\add* przed obliczem rozumnego, a oczy głupca są aż na krańcu ziemi.
\m 
\v 25 Głupi syn jest zmartwieniem dla ojca i goryczą dla rodzicielki.
\m 
\v 26 Zaprawdę to niedobrze wymierzyć karę sprawiedliwemu ani bić władców za prawość.
\m 
\v 27 Kto ma wiedzę, powściąga swoje słowa, człowiek roztropny \add jest\add* zacnego ducha.
\m 
\v 28 Nawet głupi, gdy milczy, uchodzi za mądrego, \add a\add* kto zamyka swoje wargi – za rozumnego.
\c 18
\m 
\v 1 Samolub szuka tego, co mu się podoba, i wtrąca się w każdą sprawę.
\m 
\v 2 Głupi nie ma upodobania w rozumie, lecz w tym, co serce mu objawia.
\m 
\v 3 Gdy przychodzi niegodziwy, przychodzi też pogarda, a z hańbą urąganie.
\m 
\v 4 Słowa ust człowieka są jak głębokie wody, a źródło mądrości jak płynący potok.
\m 
\v 5 Niedobrze przez wzgląd na osobę niegodziwą krzywdzić sprawiedliwego w sądzie.
\m 
\v 6 Wargi głupiego wchodzą w spór, a jego usta wołają o razy.
\m 
\v 7 Usta głupiego \add są\add* jego zgubą, a jego wargi sidłem jego duszy.
\m 
\v 8 Słowa plotkarza są jak rany i przenikają do głębi wnętrzności.
\m 
\v 9 Kto jest niedbały w pracy, jest bratem marnotrawcy.
\m 
\v 10 Imię PANA \add jest\add* potężną wieżą, sprawiedliwy ucieka do niej i jest bezpieczny.
\m 
\v 11 Zamożność bogacza \add jest\add* jego warownym miastem i jak wysoki mur w jego wyobrażeniu.
\m 
\v 12 Przed upadkiem serce człowieka jest wyniosłe, a chwałę poprzedza pokora.
\m 
\v 13 Kto odpowiada, zanim wysłucha, \add ujawnia\add* głupotę i \add ściąga na\add* siebie hańbę.
\m 
\v 14 Duch człowieka zniesie jego chorobę, ale któż zniesie strapionego ducha?
\m 
\v 15 Serce rozumnego zdobywa wiedzę, a ucho mądrych szuka wiedzy.
\m 
\v 16 Dar człowieka toruje mu drogę i prowadzi go przed wielkich.
\m 
\v 17 Ten, który jest pierwszy w swojej sprawie, \add zdaje się\add* sprawiedliwy, ale przychodzi jego bliźni i sprawdza go.
\m 
\v 18 Los kładzie kres sporom i rozstrzyga między możnymi.
\m 
\v 19 Brat obrażony \add trudniejszy do zdobycia\add* niż warowne miasto, a spory są jak rygle w zamku.
\m 
\v 20 Owocem swoich ust nasyci człowiek swoje wnętrze, nasyci się plonem swych warg.
\m 
\v 21 Śmierć i życie są w mocy języka, a kto go miłuje, spożyje jego owoc.
\m 
\v 22 Kto znalazł żonę, znalazł coś dobrego i dostąpił łaski od PANA.
\m 
\v 23 Ubogi prosi pokornie, ale bogaty odpowiada surowo.
\m 
\v 24 Człowiek, który ma przyjaciół, musi obchodzić się z nimi po przyjacielsku, a jest przyjaciel, który przylgnie bardziej niż brat.
\c 19
\m 
\v 1 Lepszy jest ubogi, który postępuje uczciwie, niż człowiek o przewrotnych wargach, który jest głupcem.
\m 
\v 2 Nie jest też dobrze, by dusza nie miała wiedzy, a kto jest prędkich nóg, grzeszy.
\m 
\v 3 Głupota człowieka wypacza jego drogę, a jego serce zapala się gniewem przeciwko PANU.
\m 
\v 4 Bogactwo przyciąga wielu przyjaciół, ale ubogi zostaje odłączony od przyjaciela.
\m 
\v 5 Fałszywy świadek nie uniknie kary, a \add kto\add* mówi kłamstwa, nie ujdzie.
\m 
\v 6 Wielu uprasza o przychylność dostojnika i każdy jest przyjacielem człowieka hojnego.
\m 
\v 7 Wszyscy bracia ubogiego nienawidzą go, tym bardziej oddalają się od niego \add jego\add* przyjaciele; ściga ich słowami, ale ich nie ma.
\m 
\v 8 Kto zdobywa rozum, miłuje swoją duszę, a \add kto\add* strzeże roztropności, znajdzie dobro.
\m 
\v 9 Fałszywy świadek nie uniknie kary, a kto mówi kłamstwa, zginie.
\m 
\v 10 Głupiemu nie przystoi życie w rozkoszach, tym mniej słudze panować nad książętami.
\m 
\v 11 Roztropność człowieka powściąga jego gniew, a jego chwałą \add jest\add* darować wykroczenie.
\m 
\v 12 Gniew króla jest jak ryk lwa, a jego przychylność jak rosa na trawie.
\m 
\v 13 Głupi syn jest utrapieniem dla swego ojca, a kłótliwa żona jest jak nieustanne kapanie z dachu.
\m 
\v 14 Dom i bogactwo \add są\add* dziedzictwem po ojcach, ale roztropna żona jest od PANA.
\m 
\v 15 Lenistwo pogrąża w twardym śnie, a leniwa dusza będzie cierpieć głód.
\m 
\v 16 Kto przestrzega przykazania, zachowuje swoją duszę, \add ale\add* kto gardzi swymi drogami, zginie.
\m 
\v 17 Kto lituje się nad ubogim, pożycza PANU, a on mu odpłaci za jego dobrodziejstwo.
\m 
\v 18 Karz swego syna, dopóki jest nadzieja, i niech twoja dusza mu nie pobłaża z powodu jego płaczu.
\m 
\v 19 \add Człowiek\add* wielkiego gniewu poniesie karę, a jeśli \add go\add* uwolnisz, znowu będziesz musiał \add to zrobić\add*.
\m 
\v 20 Posłuchaj rady i przyjmij pouczenie, abyś był mądry u kresu swych dni.
\m 
\v 21 Wiele jest zamysłów w sercu człowieka, ale rada PANA się ostoi.
\m 
\v 22 Pragnienie człowieka to jego dobroczynność i lepszy jest ubogi niż kłamca.
\m 
\v 23 Bojaźń PANA \add prowadzi\add* do życia, a kto ją ma, spocznie syty i nie nawiedzi go zło.
\m 
\v 24 Leniwy kryje swą rękę pod pachę i do ust jej nie podnosi.
\m 
\v 25 Uderz szydercę, a prosty będzie roztropniejszy; strofuj rozumnego, a pojmie wiedzę.
\m 
\v 26 Kto trwoni \add dobra\add* ojca i wypędza matkę, ten jest synem, który przynosi wstyd i hańbę.
\m 
\v 27 Synu mój, przestań słuchać pouczeń, które cię odwodzą od słów rozumnych.
\m 
\v 28 Nikczemny świadek naśmiewa się z sądu, a usta niegodziwych pożerają nieprawość.
\m 
\v 29 Sądy są przygotowane dla szyderców, a razy na grzbiet głupców.
\c 20
\m 
\v 1 Wino \add jest\add* szydercą, mocny trunek – wrzaskliwy, a każdy, kto zostaje zwiedziony przez nie, jest niemądry.
\m 
\v 2 Strach, \add który budzi\add* król, jest jak ryk lwa; kto go rozgniewa, grzeszy przeciwko swojej duszy.
\m 
\v 3 Zaprzestać sporu jest zaszczytem dla człowieka, ale \add każdy\add* głupiec się w niego wdaje.
\m 
\v 4 Leniwy nie orze z powodu zimna; dlatego będzie żebrać we żniwa, ale nic nie \add otrzyma\add*.
\m 
\v 5 Rada w sercu człowieka jest jak głęboka woda, lecz człowiek roztropny zaczerpnie jej.
\m 
\v 6 Większość ludzi przechwala się swoją dobrocią, ale wiernego człowieka któż znajdzie?
\m 
\v 7 Sprawiedliwy postępuje uczciwie, błogosławione \add są\add* po nim jego dzieci.
\m 
\v 8 Król siedzący na swoim sędziowskim tronie rozprasza swoimi oczami wszelkie zło.
\m 
\v 9 Któż może powiedzieć: Oczyściłem swoje serce, jestem czysty od swego grzechu?
\m 
\v 10 Dwojakie odważniki i dwojaka miara – obydwa budzą odrazę w PANU.
\m 
\v 11 Nawet dziecko poznaje się po uczynkach, czy jego czyn jest czysty i prawy.
\m 
\v 12 Ucho, które słyszy, i oko, które widzi, oba uczynił PAN.
\m 
\v 13 Nie kochaj spania, byś nie zubożał; otwórz oczy, a nasycisz się chlebem.
\m 
\v 14 \add To\add* liche, \add to\add* liche, mówi kupujący, ale chwali się, gdy odchodzi.
\m 
\v 15 Istnieje złoto i obfitość pereł, ale wargi rozumne są kosztownym klejnotem.
\m 
\v 16 Zabierz szatę tego, \add który ręczył\add* za obcego, a od tego, \add który ręczył\add* za cudzą kobietę, zabierz zastaw.
\m 
\v 17 Chleb oszustwa smakuje człowiekowi, ale potem jego usta będą napełnione piaskiem.
\m 
\v 18 Zamysły są utwierdzone dzięki radzie, a wojnę prowadź z rozwagą.
\m 
\v 19 Plotkarz zdradza tajemnice; dlatego nie zadawaj się z tym, który pochlebia wargami.
\m 
\v 20 Kto złorzeczy swemu ojcu albo matce, tego pochodnia zgaśnie w gęstych ciemnościach.
\m 
\v 21 Dziedzictwo prędko nabyte na początku nie będzie błogosławione na końcu.
\m 
\v 22 Nie mów: Odpłacę złem. Czekaj na PANA, a wybawi cię.
\m 
\v 23 Dwojakie odważniki budzą odrazę w PANU, a fałszywa waga nie jest dobra.
\m 
\v 24 Od PANA pochodzą drogi człowieka; jakże może człowiek zrozumieć własną drogę?
\m 
\v 25 Sidłem dla człowieka jest pożreć to, co święte, i zastanowić się dopiero po złożeniu ślubów.
\m 
\v 26 Mądry król rozprasza niegodziwych i wywiera na nich zemstę.
\m 
\v 27 Duch człowieka \add jest\add* pochodnią PANA, \add która\add* bada wszystkie skrytości wnętrza.
\m 
\v 28 Miłosierdzie i prawda strzegą króla, a jego tron oparty jest na miłosierdziu.
\m 
\v 29 Chlubą młodzieńców jest ich siła, a ozdobą starców – sędziwość.
\m 
\v 30 Siność ran oczyszcza zło, a razy – głębię wnętrza.
\c 21
\m 
\v 1 Serce króla \add jest\add* w ręku PANA \add jak\add* potoki wód; kieruje je, dokąd chce.
\m 
\v 2 Wszelka droga człowieka jest słuszna w jego oczach, ale PAN waży serca.
\m 
\v 3 Czynienie sprawiedliwości i sądu bardziej się podobają PANU niż ofiara.
\m 
\v 4 Wyniosłe oczy, pyszne serce \add i\add* praca niegodziwych są grzechem.
\m 
\v 5 Myśli pracowitego \add przynoszą\add* pewny dostatek, a \add myśli\add* każdego spieszącego się – niedostatek.
\m 
\v 6 Gromadzenie skarbów kłamliwym językiem jest przemijającą marnością tych, którzy szukają śmierci.
\m 
\v 7 Grabież niegodziwych zniszczy ich, bo nie chcą czynić tego, co sprawiedliwe.
\m 
\v 8 Droga człowieka jest przewrotna i obca, ale dzieło czystego jest prawe.
\m 
\v 9 Lepiej mieszkać w kącie dachu niż z kłótliwą żoną w przestronnym domu.
\m 
\v 10 Dusza niegodziwego pragnie zła, a jego bliźni nie znajduje łaski w jego oczach.
\m 
\v 11 Gdy się karze szydercę, prosty mądrzeje, a gdy uczą mądrego, przyjmuje wiedzę.
\m 
\v 12 Sprawiedliwy zważa na dom niegodziwego, ale \add Bóg\add* powala niegodziwych za \add ich\add* nieprawość.
\m 
\v 13 Kto zatyka swe ucho na wołanie ubogiego, ten sam będzie wołał, a nie zostanie wysłuchany.
\m 
\v 14 \add Potajemny\add* dar łagodzi zapalczywość i upominek w zanadrzu uspokaja wielki gniew.
\m 
\v 15 Radością jest dla sprawiedliwego czynić sąd, a na czyniących nieprawość przyjdzie zniszczenie.
\m 
\v 16 Człowiek, który zbacza z drogi mądrości, odpocznie w zgromadzeniu umarłych.
\m 
\v 17 Kto kocha zabawę, zubożeje, a kto kocha wino i olejek, nie wzbogaci się.
\m 
\v 18 Niegodziwy \add będzie\add* okupem za sprawiedliwego, a przewrotny – za prawych.
\m 
\v 19 Lepiej mieszkać na pustyni niż z kłótliwą i gniewliwą żoną.
\m 
\v 20 Pożądany skarb i olej \add są\add* w mieszkaniu mądrego, ale głupiec je trwoni.
\m 
\v 21 Kto podąża za sprawiedliwością i miłosierdziem, znajduje życie, sprawiedliwość i chwałę.
\m 
\v 22 Mądry wdziera się do miasta mocarzy i burzy potęgę ich ufności.
\m 
\v 23 Kto strzeże swoich ust i języka, strzeże swojej duszy przed utrapieniem.
\m 
\v 24 Hardy i pyszny szyderca – oto imię tego, kto działa w pysznym gniewie.
\m 
\v 25 Pragnienie leniwego zabija \add go\add*, bo jego ręce nie chcą pracować.
\m 
\v 26 Przez cały dzień pożąda on zachłannie, a sprawiedliwy daje i nie szczędzi.
\m 
\v 27 Ofiara niegodziwych budzi odrazę, a cóż dopiero, gdy ją w niegodziwości ofiarują.
\m 
\v 28 Fałszywy świadek zginie, lecz kto słucha, będzie mówił nieustannie.
\m 
\v 29 Niegodziwy ma upór na twarzy, ale prawy wytycza swoją drogę.
\m 
\v 30 Nie ma mądrości ani rozumu, ani rady przeciwko PANU.
\m 
\v 31 Konia przygotowują na dzień bitwy, ale wybawienie zależy od PANA.
\c 22
\m 
\v 1 Cenniejsze \add jest\add* dobre imię niż wielkie bogactwa, a przychylność lepsza niż srebro i złoto.
\m 
\v 2 Bogaty i ubogi spotykają się, PAN jest stwórcą obydwu.
\m 
\v 3 Roztropny dostrzega zło i ukrywa się, ale prości idą dalej i ponoszą karę.
\m 
\v 4 Owocem pokory i bojaźni PANA jest bogactwo, chwała i życie.
\m 
\v 5 Ciernie i sidła \add są\add* na drodze przewrotnego; kto strzeże swej duszy, trzyma się z dala od nich.
\m 
\v 6 Pouczaj dziecko w drodze, którą ma iść, a gdy się zestarzeje, nie odstąpi od niej.
\m 
\v 7 Bogaty panuje nad ubogimi, a ten, co pożycza, jest sługą tego, który mu pożycza.
\m 
\v 8 Kto sieje nieprawość, będzie żąć cierpienie, a rózga jego gniewu przepadnie.
\m 
\v 9 Kto ma dobrotliwe oko, będzie błogosławiony, bo dzieli się swym chlebem z ubogim.
\m 
\v 10 Wyrzuć szydercę, a ustanie spór, owszem, zakończy się kłótnia i zniewaga.
\m 
\v 11 Kto kocha czystość serca, tego wdzięk warg sprawi, że król \add będzie\add* jego przyjacielem.
\m 
\v 12 Oczy PANA strzegą wiedzy, a on obala słowa przewrotnego.
\m 
\v 13 Leniwy mówi: Lew jest na dworze, będę zabity na środku ulicy.
\m 
\v 14 Usta obcych \add kobiet są\add* głębokim dołem; wpadnie tam ten, na kogo PAN się gniewa.
\m 
\v 15 Głupota jest przywiązana do serca dziecka, ale rózga karności wypędzi ją z niego.
\m 
\v 16 Kto ciemięży ubogiego, aby przysporzyć sobie \add bogactwa, i\add* kto daje bogatemu, pewnie zubożeje.
\m 
\v 17 Nadstaw ucha i słuchaj słów mędrców, i skłoń swe serce do mojej wiedzy;
\m 
\v 18 Bo to miło, jeśli zachowasz je w swoim sercu, będą razem ułożone na wargach.
\m 
\v 19 Oznajmiłem to dzisiaj właśnie tobie, abyś pokładał ufność w PANU.
\m 
\v 20 Czy nie napisałem ci znamienitych rzeczy zawierających rady i wiedzę;
\m 
\v 21 Aby dać ci poznać pewność słów prawdy; abyś umiał odpowiedzieć słowami prawdy tym, którzy do ciebie posyłają?
\m 
\v 22 Nie okradaj nędzarza, ponieważ jest ubogi, ani nie uciskaj w bramie biednego.
\m 
\v 23 PAN bowiem będzie bronił ich sprawy i wydrze duszę tym, którzy im wydzierają.
\m 
\v 24 Nie przyjaźnij się z człowiekiem gniewliwym i nie obcuj z człowiekiem porywczym.
\m 
\v 25 Byś nie przywykł do jego dróg i nie zastawił sideł na swą duszę.
\m 
\v 26 Nie bądź z tych, którzy dają porękę, ani z tych, którzy ręczą za długi;
\m 
\v 27 Jeśli nie masz czym zapłacić, dlaczego miałby ktoś zabrać spod ciebie posłanie?
\m 
\v 28 Nie przesuwaj dawnej granicy, którą ustalili twoi ojcowie.
\m 
\v 29 Widzisz człowieka pilnego w swoich sprawach? On będzie stał przed królami, nie będzie stał przed podłymi.
\c 23
\m 
\v 1 Gdy usiądziesz do posiłku z władcą, zważaj pilnie, co jest przed tobą;
\m 
\v 2 I przyłóż nóż do gardła, jeśli jesteś łakomy.
\m 
\v 3 Nie pragnij jego przysmaków, bo to pokarm zwodniczy.
\m 
\v 4 Nie zabiegaj o bogactwo, porzuć swoją mądrość.
\m 
\v 5 Czy obrócisz swoje oczy na to, co jest niczym? Bo bogactwa robią sobie skrzydła i ulatują do nieba jak orzeł.
\m 
\v 6 Nie jedz chleba człowieka, który ma złe oko, ani nie pożądaj jego przysmaków.
\m 
\v 7 Bo jak myśli w swym sercu, taki \add on jest\add*. Jedz i pij – mówi do ciebie, ale jego serce nie jest z tobą.
\m 
\v 8 Kęs, który zjadłeś, zwrócisz i utracisz swoje wdzięczne słowa.
\m 
\v 9 Nie mów do uszu głupca, bo wzgardzi mądrością twoich słów.
\m 
\v 10 Nie przesuwaj dawnej granicy i nie wchodź na pole sierot.
\m 
\v 11 Bo ich obrońca jest mocny, przeprowadzi ich sprawę przeciwko tobie.
\m 
\v 12 Nakłoń swoje serce na pouczenie, a swe uszy na słowa rozumne.
\m 
\v 13 Nie szczędź dziecku karcenia, \add bo\add* jeśli je bijesz rózgą, nie umrze.
\m 
\v 14 Będziesz je bił rózgą, a jego duszę ocalisz od piekła.
\m 
\v 15 Synu mój, jeśli twoje serce będzie mądre, moje serce będzie się radowało, właśnie moje;
\m 
\v 16 I moje nerki będą się weselić, gdy twoje usta będą mówiły to, co jest prawe.
\m 
\v 17 Niech twoje serce nie zazdrości grzesznikom, lecz każdego dnia \add postępuj\add* w bojaźni PANA;
\m 
\v 18 Bo koniec jest pewny i twoja nadzieja nie będzie zawiedziona.
\m 
\v 19 Słuchaj, synu mój, i bądź mądry, i skieruj swoje serce na drogę.
\m 
\v 20 Nie bywaj wśród pijaków ani wśród obżerających się mięsem;
\m 
\v 21 Bo pijak i żarłok zubożeją, a ospały będzie chodził w łachmanach.
\m 
\v 22 Słuchaj ojca, który cię spłodził, a nie gardź matką, gdy się zestarzeje.
\m 
\v 23 Kupuj prawdę i nie sprzedawaj \add jej\add*; \add kupuj\add* mądrość, karność i rozum.
\m 
\v 24 Ojciec sprawiedliwego będzie się wielce radował, a kto spłodzi mądrego, będzie się z niego cieszył.
\m 
\v 25 Niech się weseli twój ojciec i matka i niech się raduje ta, która cię rodziła.
\m 
\v 26 Synu mój, daj mi swoje serce, a niech twoje oczy strzegą moich dróg.
\m 
\v 27 Bo nierządnica \add jest\add* głębokim dołem, a cudza \add kobieta jest\add* ciasną studnią.
\m 
\v 28 Ona też czyha jak zbój i pomnaża przewrotnych wśród ludzi.
\m 
\v 29 U kogo biada? U kogo żal? U kogo kłótnie? U kogo szemranie? Kto ma rany bez powodu? Kto ma zaczerwienione oczy?
\m 
\v 30 Ci, którzy przesiadują przy winie; ci, którzy idą szukać zmieszanego wina.
\m 
\v 31 Nie patrz na wino, gdy się czerwieni; gdy wydaje łunę swą w kielichu, a samo się przesuwa.
\m 
\v 32 Na koniec ugryzie jak wąż i ukąsi jak żmija;
\m 
\v 33 Twoje oczy będą patrzeć na cudze kobiety, a twoje serce będzie mówiło rzeczy przewrotne;
\m 
\v 34 I będziesz jak ten, który leży na środku morza, i jak ten, który śpi na szczycie masztu;
\m 
\v 35 \add Powiesz\add*: Bili mnie, a nie bolało, uderzyli mnie, a \add nic\add* nie czułem. Gdy się obudzę, znów go poszukam.
\c 24
\m 
\v 1 Nie zazdrość złym ludziom ani nie pragnij z nimi przebywać;
\m 
\v 2 Ich serce bowiem obmyśla przemoc, a ich wargi mówią o krzywdzie.
\m 
\v 3 Dom buduje się mądrością, a umacnia się rozumem.
\m 
\v 4 Dzięki wiedzy komory będą napełnione wszelkimi kosztownymi i przyjemnymi bogactwami.
\m 
\v 5 Mądry człowiek jest silny, a mąż, który ma wiedzę, dodaje siły.
\m 
\v 6 Bo dzięki mądrej radzie poprowadzisz wojnę, a mnóstwo doradców \add da ci\add* wybawienie.
\m 
\v 7 Mądrość jest dla głupca zbyt wzniosła; nie otwiera ust swoich w bramie.
\m 
\v 8 Kto knuje zło, będzie zwany złośliwym.
\m 
\v 9 Obmyślanie głupoty \add jest\add* grzechem, a szyderca budzi odrazę w ludziach.
\m 
\v 10 Jeśli w dniu ucisku ustaniesz, twoja siła jest słaba.
\m 
\v 11 \add Jeśli\add* odmówisz ratunku prowadzonym na śmierć i tym, którzy idą na stracenie;
\m 
\v 12 Jeśli powiesz: Nie wiedzieliśmy o tym; czy ten, który waży serca, nie rozumie? A ten, który strzeże twojej duszy, nie pozna? I czy nie odda człowiekowi według jego uczynków?
\m 
\v 13 Synu mój, jedz miód, bo jest dobry, i plaster miodu słodki dla twojego podniebienia.
\m 
\v 14 Tak \add będzie\add* poznanie mądrości dla twojej duszy; jeśli ją znajdziesz, będzie nagroda, a twoja nadzieja nie będzie zawiedziona.
\m 
\v 15 Nie czyhaj, niegodziwcze, przed mieszkaniem sprawiedliwego, nie burz miejsca jego odpoczynku;
\m 
\v 16 Bo sprawiedliwy upada siedem razy, jednak znowu powstaje; a niegodziwi popadną w nieszczęście.
\m 
\v 17 Nie ciesz się, gdy twój nieprzyjaciel upadnie, i niech twoje serce się nie raduje, gdy się potknie;
\m 
\v 18 Aby PAN tego nie widział i nie uznał za zło, i nie odwrócił od niego swojego gniewu.
\m 
\v 19 Nie gniewaj się z powodu złoczyńców ani nie zazdrość niegodziwym;
\m 
\v 20 Bo zły nie otrzyma nagrody, pochodnia niegodziwych zostanie zgaszona.
\m 
\v 21 Synu mój, bój się PANA i króla, a nie przestawaj z chwiejnymi;
\m 
\v 22 Bo ich nieszczęście nastąpi nagle, a któż zna upadek obydwóch?
\m 
\v 23 I to też \add należy\add* do mądrych. Niedobrze jest mieć wzgląd na osobę w sądzie.
\m 
\v 24 Kto mówi niegodziwemu: Jesteś sprawiedliwy, tego będą ludzie przeklinać, a narody będą się nim brzydzić.
\m 
\v 25 A ci, którzy \add go\add* strofują, będą szczęśliwi i przyjdzie na nich obfite błogosławieństwo.
\m 
\v 26 Pocałują wargi tego, który daje słuszną odpowiedź.
\m 
\v 27 Przygotuj swoją pracę na zewnątrz, a wykonuj ją na swoim polu, a potem buduj swój dom.
\m 
\v 28 Nie bądź bez powodu świadkiem przeciw swemu bliźniemu ani nie oszukuj swymi wargami.
\m 
\v 29 Nie mów: Zrobię mu, jak on mi zrobił, oddam temu człowiekowi według jego uczynku.
\m 
\v 30 Szedłem koło pola leniwego i koło winnicy nierozumnego;
\m 
\v 31 A oto wszystko zarosło cierniem, pokrzywy pokryły wszystko, a kamienny mur był zburzony.
\m 
\v 32 Spojrzałem i rozważałem w sercu; obejrzałem i wyciągnąłem naukę.
\m 
\v 33 Trochę snu, trochę drzemania, trochę założenia rąk, by odpocząć;
\m 
\v 34 A twoje ubóstwo przyjdzie jak podróżny, a niedostatek – jak mąż uzbrojony.
\c 25
\m 
\v 1 To również są przysłowia Salomona, które przepisali mężowie Ezechiasza, króla Judy.
\m 
\v 2 Chwałą Boga jest sprawę taić, ale chwałą królów – dociekać sprawy.
\m 
\v 3 Wysokość niebios i głębia ziemi, i serca królów są niezbadane.
\m 
\v 4 Usuń żużel ze srebra, a wyjdzie naczynie dla złotnika.
\m 
\v 5 Usuń niegodziwego sprzed króla, a jego tron umocni się w sprawiedliwości.
\m 
\v 6 Nie wywyższaj się przed królem i nie stawaj na miejscu wielkich;
\m 
\v 7 Bo lepiej, żeby ci powiedziano: Podejdź tu, niż żeby cię poniżono przed księciem, którego twoje oczy widziały.
\m 
\v 8 Nie spiesz się do kłótni, bo na końcu \add nie będziesz wiedział\add*, co zrobić, gdy cię zawstydzi twój bliźni.
\m 
\v 9 Załatw sprawę ze swoim bliźnim i nie zdradzaj tajemnicy drugiemu;
\m 
\v 10 By ten, który słucha, nie zawstydził cię, a twoja niesława nie przylgnęła do ciebie.
\m 
\v 11 Odpowiednio wypowiedziane słowo \add jest jak\add* złote jabłko w srebrnych rzeźbach.
\m 
\v 12 Jak złoty kolczyk i klejnot ze szczerego złota tak jest dla uszu posłusznego ten, który mądrze strofuje.
\m 
\v 13 Czym chłód śniegu w czasie żniwa, \add tym\add* wierny posłaniec dla tych, którzy go posyłają, bo pokrzepia dusze swych panów.
\m 
\v 14 Człowiek, który się chlubi zmyślonym darem, jest jak chmury i wiatr bez deszczu.
\m 
\v 15 Cierpliwością można przekonać władcę, a łagodny język łamie kości.
\m 
\v 16 Czy znalazłeś miód? Zjedz tyle, ile trzeba, byś objadłszy się, nie zwrócił go.
\m 
\v 17 Oddal nogę od domu bliźniego, by nie miał cię dość i cię nie znienawidził.
\m 
\v 18 Kto mówi fałszywe świadectwo przeciw swemu bliźniemu, \add jest\add* młotem i mieczem, i ostrą strzałą.
\m 
\v 19 Ufność w człowieka niewiernego w dniu ucisku jest \add jak\add* złamany ząb i zwichnięta noga.
\m 
\v 20 \add Jak\add* ten, kto zabiera odzienie w czasie zimy i jak ocet na saletrze taki \add jest ten\add*, kto śpiewa pieśni smutnemu sercu.
\m 
\v 21 Jeśli twój nieprzyjaciel jest głodny, nakarm go chlebem, a jeśli jest spragniony, napój go wodą;
\m 
\v 22 Bo zgarniesz rozżarzone węgle na jego głowę, a PAN cię nagrodzi.
\m 
\v 23 \add Jak\add* północny wiatr przepędza deszcz, tak gniewna twarz \add przepędza\add* plotkarski język.
\m 
\v 24 Lepiej mieszkać w kącie pod dachem niż z kłótliwą żoną w przestronnym domu.
\m 
\v 25 \add Jak\add* zimna woda dla pragnącej duszy, \add tak\add* dobra wieść z dalekiej ziemi.
\m 
\v 26 \add Jak\add* zmącone źródło i zepsuty zdrój, \add tak\add* sprawiedliwy, który upada przed niegodziwym.
\m 
\v 27 Niedobrze jest jeść za dużo miodu, a szukanie własnej chwały nie jest chwałą.
\m 
\v 28 Człowiek, który nie panuje nad swoim duchem, jest \add jak\add* miasto zburzone \add i\add* bez muru.
\c 26
\m 
\v 1 Jak śnieg w lecie i jak deszcz we żniwa, tak głupiemu nie przystoi chwała.
\m 
\v 2 Jak ptak się tuła \add i\add* jak jaskółka lata, tak nie przyjdzie niezasłużone przekleństwo.
\m 
\v 3 Bicz na konia, wędzidło na osła, a kij na grzbiet głupiego.
\m 
\v 4 Nie odpowiadaj głupiemu według jego głupoty, abyś i ty nie był do niego podobny.
\m 
\v 5 Odpowiedz głupiemu według jego głupoty, aby nie był mądry we własnych oczach.
\m 
\v 6 Kto powierza głupiemu posłannictwo, odcina sobie nogi i pije na własną szkodę.
\m 
\v 7 \add Jak\add* nierówne są nogi chromego, tak przysłowie w ustach głupich.
\m 
\v 8 Jaki jest ten, kto przywiązuje kamień do procy, taki ten, kto oddaje cześć głupiemu.
\m 
\v 9 Jak cierń wbija się w rękę pijaka, tak przysłowie w ustach głupców.
\m 
\v 10 Wielki \add Bóg\add* stworzył wszystko i odpłaca głupiemu, odpłaca również przestępcom.
\m 
\v 11 \add Jak\add* pies powraca do swoich wymiocin, tak głupi powtarza swoją głupotę.
\m 
\v 12 Widzisz człowieka, co mądry w swoich oczach? Więcej nadziei dla głupca niż dla niego.
\m 
\v 13 Leniwy mówi: Lew na drodze, lew na ulicach.
\m 
\v 14 Jak drzwi się obracają na swoich zawiasach, tak leniwy na swoim łóżku.
\m 
\v 15 Leniwy kryje rękę pod pachę, a ciężko mu ją podnosić do ust.
\m 
\v 16 Leniwy uważa się za mądrzejszego niż siedmiu odpowiadających rozsądnie.
\m 
\v 17 Kto przechodzi i wtrąca się w cudzy spór, jest jak ten, który łapie psa za uszy.
\m 
\v 18 Jak szalony wypuszcza iskry, strzały i śmierć;
\m 
\v 19 Taki jest każdy, kto zwodzi swego bliźniego i mówi: Czy nie żartowałem?
\m 
\v 20 Gdy nie ma drew, ogień gaśnie; tak gdy nie ma plotkarza, ustaje spór.
\m 
\v 21 Jak węgiel dla żaru i drwa do ognia, tak kłótliwy człowiek do wzniecenia sporu.
\m 
\v 22 Słowa plotkarzy są \add jak\add* rany; przenikają do głębi wnętrzności.
\m 
\v 23 Palące wargi i złe serce \add są jak\add* gliniana skorupa pokryta żużlem srebrnym.
\m 
\v 24 Ten, kto nienawidzi, udaje wargami, lecz w sercu knuje podstęp.
\m 
\v 25 Gdy mówi miłym głosem, nie wierz mu, bo siedem obrzydliwości ma w swoim sercu.
\m 
\v 26 Nienawiść \add człowieka\add* bywa pokryta podstępem, \add ale\add* jego niegodziwość będzie odkryta na zgromadzeniu.
\m 
\v 27 Kto kopie dół, wpadnie w niego; kto kamień toczy, na niego się on obróci.
\m 
\v 28 Kłamliwy język nienawidzi \add tych, których\add* uciska, a usta pochlebcze prowadzą do zguby.
\c 27
\m 
\v 1 Nie chlub się dniem jutrzejszym, bo nie wiesz, co dzień przyniesie.
\m 
\v 2 Niech inny cię chwali, a nie twoje usta; ktoś obcy, a nie twoje wargi.
\m 
\v 3 Ciężki jest kamień i piasek waży, ale gniew głupca cięższy od obu.
\m 
\v 4 Okrutny jest gniew i straszliwa zapalczywość, lecz któż się ostoi przed zazdrością?
\m 
\v 5 Lepsza jest jawna nagana niż skryta miłość.
\m 
\v 6 Rany przyjaciela \add są\add* wierne, ale pocałunki wroga \add są\add* zwodnicze.
\m 
\v 7 Dusza nasycona podepcze plaster miodu, a dla głodnej duszy wszystko, co gorzkie, jest słodkie.
\m 
\v 8 Jak ptak odlatuje od swego gniazda, tak człowiek odchodzi od swego miejsca.
\m 
\v 9 Maść i kadzidło radują serce, tak słodycz przyjaciela dzięki radzie od serca.
\m 
\v 10 Nie opuszczaj swego przyjaciela ani przyjaciela twego ojca, a w dniu twego nieszczęścia nie wchodź do domu twego brata, bo lepszy \add jest\add* sąsiad bliski niż brat daleki.
\m 
\v 11 Bądź mądrym, synu mój, rozwesel moje serce, abym mógł odpowiedzieć temu, który mi urąga.
\m 
\v 12 Roztropny dostrzega zło i ukrywa się, a prości idą dalej i ponoszą karę.
\m 
\v 13 Zabierz szatę temu, kto \add ręczył za\add* obcego, i od tego, który ręczył za cudzą kobietę, weź zastaw.
\m 
\v 14 Kto wczesnym rankiem błogosławi swemu przyjacielowi donośnym głosem, temu będzie to poczytane za przekleństwo.
\m 
\v 15 Nieustające kapanie w dniu rzęsistego deszczu i kłótliwa żona są sobie podobne;
\m 
\v 16 Kto ją ukrywa, ukrywa wiatr i w prawej ręce \add wonny\add* olejek, który sam siebie wydaje.
\m 
\v 17 Żelazo ostrzy się żelazem, tak człowiek zaostrza oblicze swego przyjaciela.
\m 
\v 18 Kto strzeże drzewa figowego, spożyje jego owoc; tak kto posługuje swemu panu, dozna czci.
\m 
\v 19 Jak w wodzie odbija się twarz, tak w sercu człowieka – człowiek.
\m 
\v 20 Piekło i zatracenie są nienasycone, tak oczy człowieka są niesyte.
\m 
\v 21 Czym dla srebra jest tygiel, a dla złota piec, tym dla człowieka pochwała.
\m 
\v 22 Choćbyś zmiażdżył głupca w moździerzu tłuczkiem razem z ziarnami, nie opuści go głupota.
\m 
\v 23 Doglądaj pilnie swego dobytku \add i\add* troszcz się o \add swe\add* stada.
\m 
\v 24 Bo bogactwo nie \add trwa\add* na wieki ani korona przez wszystkie pokolenia.
\m 
\v 25 Trawa wyrasta, pojawia się zieleń, z gór zioła zbierają.
\m 
\v 26 Owce są na twoje szaty, a kozły \add są\add* zapłatą za pole.
\m 
\v 27 I dosyć mleka koziego na pokarm dla ciebie, na wyżywienie twego domu i na utrzymanie twoich służebnic.
\c 28
\m 
\v 1 Niegodziwi uciekają, choć nikt ich nie goni, ale sprawiedliwi są dzielni jak lew.
\m 
\v 2 Z powodu grzechu ziemi wielu \add jest\add* jej władców, ale dzięki człowiekowi roztropnemu i rozumnemu będzie trwała.
\m 
\v 3 Ubogi człowiek, który gnębi biednych, \add jest jak\add* gwałtowny deszcz, po którym nie ma chleba.
\m 
\v 4 Ci, którzy odstępują od prawa, chwalą niegodziwych, lecz ci, którzy przestrzegają prawa, zwalczają ich.
\m 
\v 5 Źli ludzie nie rozumieją sądu, ale ci, którzy szukają PANA, rozumieją wszystko.
\m 
\v 6 Lepszy jest ubogi, który postępuje uczciwie, niż człowiek przewrotny w \add swych\add* drogach, chociaż jest bogaty.
\m 
\v 7 Kto przestrzega prawa, jest rozumnym synem, a towarzysz rozwiązłych hańbi swego ojca.
\m 
\v 8 Kto pomnaża swój majątek lichwą i odsetkami, zbiera go dla tego, kto zlituje się nad ubogimi.
\m 
\v 9 Kto odwraca swe ucho, aby nie słyszeć prawa, nawet jego modlitwa budzi odrazę.
\m 
\v 10 Kto sprowadza prawych na złą drogę, sam wpadnie we własny dół, ale nienaganni odziedziczą dobro.
\m 
\v 11 Bogacz jest mądry w swoich oczach, ale rozumny biedak go bada.
\m 
\v 12 Gdy sprawiedliwi się radują, jest wielka chwała, a gdy niegodziwi powstają, człowiek się kryje.
\m 
\v 13 Kto ukrywa swe grzechy, nie będzie miał szczęścia, ale kto \add je\add* wyznaje i porzuca, dostąpi miłosierdzia.
\m 
\v 14 Błogosławiony człowiek, który się zawsze boi, ale kto zatwardza swoje serce, wpada w nieszczęście.
\m 
\v 15 Jak lew ryczący i zgłodniały niedźwiedź, tak niegodziwy władca panujący nad ubogim ludem.
\m 
\v 16 Władca bezrozumny jest wielkim ciemięzcą, \add a\add* kto nienawidzi chciwości, przedłuży swoje dni.
\m 
\v 17 Człowiek, który przeleje krew ludzką, ucieknie aż do dołu; \add niech\add* nikt go nie zatrzymuje.
\m 
\v 18 Kto postępuje uczciwie, będzie wybawiony, a przewrotny na \add swoich\add* drogach nagle upadnie.
\m 
\v 19 Kto uprawia swoją ziemię, nasyci się chlebem, a kto naśladuje próżniaków, nasyci się nędzą.
\m 
\v 20 Wierny człowiek będzie opływał w błogosławieństwa, a kto chce się szybko wzbogacić, nie będzie bez winy.
\m 
\v 21 Niedobrze jest mieć wzgląd na osobę, bo dla kęsa chleba niejeden popełni przestępstwo.
\m 
\v 22 Kto chce szybko się wzbogacić, ma złe oko, a nie wie, że przyjdzie na niego bieda.
\m 
\v 23 Kto strofuje człowieka, znajdzie potem \add więcej\add* przychylności niż ten, który pochlebia językiem.
\m 
\v 24 Kto kradnie ojcu lub matce i mówi: To nie grzech, jest towarzyszem zbójcy.
\m 
\v 25 Człowiek wyniosły wszczyna spór, ale kto pokłada ufność w PANU, będzie nasycony.
\m 
\v 26 Kto ufa własnemu sercu, jest głupi, a kto mądrze postępuje, będzie ocalony.
\m 
\v 27 Kto daje ubogiemu, nie zazna braku, a \add na tego\add*, kto odwraca swe oczy \add od niego\add*, spadnie wiele przekleństw.
\m 
\v 28 Gdy niegodziwi powstają, ludzie się kryją, ale gdy giną, sprawiedliwi się mnożą.
\c 29
\m 
\v 1 Człowiek, który czyni twardym \add swój\add* kark mimo częstych nagan, zostanie nagle zniszczony i pozbawiony ratunku.
\m 
\v 2 Gdy sprawiedliwi są u władzy, lud się weseli, a gdy panują niegodziwi, lud wzdycha.
\m 
\v 3 Kto miłuje mądrość, raduje swego ojca, a kto zadaje się z nierządnicami, trwoni majątek.
\m 
\v 4 Król utwierdza ziemię sądem, ale kto przyjmuje dary, burzy ją.
\m 
\v 5 Człowiek, który pochlebia swemu bliźniemu, rozciąga sieć przed jego nogami.
\m 
\v 6 Grzech złego człowieka jest jego sidłem, ale sprawiedliwy śpiewa i weseli się.
\m 
\v 7 Sprawiedliwy zważa na sprawę ubogich, \add a\add* niegodziwemu nie zależy na jej poznawaniu.
\m 
\v 8 Szydercy prowadzą miasto w sidła, ale mądrzy odwracają gniew.
\m 
\v 9 Jeśli mądry człowiek spiera się z głupim, czy się gniewa, czy się śmieje, nie \add ma\add* pokoju.
\m 
\v 10 Krwiożercy nienawidzą prawego, ale sprawiedliwi szukają jego duszy.
\m 
\v 11 Głupi ujawnia cały swój umysł, a mądry zachowuje go na później.
\m 
\v 12 Jeśli władca słucha kłamstw, to wszyscy jego słudzy są niegodziwi.
\m 
\v 13 Ubogi i zdzierca spotykają się, a PAN obu oświeca oczy.
\m 
\v 14 Tron króla, który sądzi ubogich według prawdy, będzie umocniony na wieki.
\m 
\v 15 Rózga i upomnienia dają mądrość, a samowolne dziecko przynosi wstyd swojej matce.
\m 
\v 16 Gdy niegodziwi się mnożą, to mnoży się i przestępstwo, lecz sprawiedliwi ujrzą ich upadek.
\m 
\v 17 Karć swego syna, a da ci odpocząć i przyniesie rozkosz twojej duszy.
\m 
\v 18 Gdy nie ma proroctwa, lud ginie, a kto przestrzega prawa, jest błogosławiony.
\m 
\v 19 Sługi nie poprawi się słowami, bo choć rozumie, jednak nie odpowiada.
\m 
\v 20 Widzisz człowieka, który jest pochopny w swoich słowach? Więcej nadziei dla głupca niż dla niego.
\m 
\v 21 Kto czule wychowuje sługę od młodości, na ostatek będzie go miał za syna.
\m 
\v 22 Człowiek gniewliwy wszczyna spór, a człowiek porywczy mnoży grzechy.
\m 
\v 23 Pycha człowieka poniża go, ale pokorny w duchu dostąpi chwały.
\m 
\v 24 Wspólnik złodzieja nienawidzi swojej duszy; słyszy przekleństwa, a nie wydaje \add go\add*.
\m 
\v 25 Strach przed człowiekiem zastawia sidła, ale kto ufa PANU, będzie bezpieczny.
\m 
\v 26 Wielu zabiega o względy władcy, ale sąd każdego człowieka pochodzi od PANA.
\m 
\v 27 Bezbożny budzi odrazę w sprawiedliwych, a kto postępuje uczciwie, budzi odrazę w niegodziwych.
\c 30
\m 
\v 1 Słowa Agura, syna Jake, proroctwo tego człowieka do Itiela, do Itiela i Ukala.
\m 
\v 2 Zaprawdę jestem najgłupszym z ludzi i nie mam ludzkiego rozumu.
\m 
\v 3 Ani nie nauczyłem się mądrości, ani nie mam wiedzy o tym, co święty.
\m 
\v 4 Któż wstąpił do nieba i zstąpił? Któż zebrał wiatr w swoje garście? Któż zgarnął wody do \add swej\add* szaty? Któż utwierdził wszystkie krańce ziemi? Jakie \add jest\add* jego imię? A jakie \add jest\add* imię jego syna? Czy wiesz?
\m 
\v 5 Każde słowo Boga jest czyste; on \add jest\add* tarczą dla tych, którzy mu ufają.
\m 
\v 6 Nie dodawaj nic do jego słów, aby cię nie strofował i abyś nie okazał się kłamcą.
\m 
\v 7 Proszę cię o dwie rzeczy; nie odmawiaj mi \add ich\add*, zanim umrę.
\m 
\v 8 Oddal ode mnie marność i słowo kłamliwe; nie dawaj mi ani ubóstwa, ani bogactwa; żyw mnie odpowiednim dla mnie pokarmem;
\m 
\v 9 Abym będąc syty, nie zaparł się \add ciebie\add* i nie mówił: Kim jest PAN? Albo zubożawszy, nie kradł i nie brał imienia mego Boga \add nadaremnie\add*.
\m 
\v 10 Nie oczerniaj sługi przed jego panem, aby ci nie złorzeczył i byś nie okazał się winny.
\m 
\v 11 \add Jest\add* pokolenie, które złorzeczy swemu ojcu i nie błogosławi swojej matce.
\m 
\v 12 \add Jest\add* pokolenie, które we własnych oczach jest czyste, lecz nie jest obmyte ze swego plugastwa.
\m 
\v 13 \add Jest\add* pokolenie, którego oczy są wyniosłe i powieki wzniesione.
\m 
\v 14 \add Jest\add* pokolenie, którego zęby \add są jak\add* miecze, a zęby trzonowe \add jak\add* noże, by pożreć ubogich na ziemi i nędzarzy spośród ludzi.
\m 
\v 15 Pijawka ma dwie córki, \add które mówią\add*: Daj, daj. Trzy są rzeczy, które nie mogą się nasycić; cztery, które nie mówią: Dość.
\m 
\v 16 Grób, niepłodne łono, ziemia niesyta wody i ogień, \add który\add* nie mówi: Dość.
\m 
\v 17 Oko, \add które\add* wyśmiewa ojca i gardzi posłuszeństwem matce, wydziobią kruki \add nad\add* potokami i wyjedzą orlęta.
\m 
\v 18 Trzy \add są\add* rzeczy dla mnie zbyt zdumiewające, czterech nie znam:
\m 
\v 19 Drogi orła w powietrzu, drogi węża na skale, drogi okrętu na środku morza i drogi mężczyzny z młodą kobietą.
\m 
\v 20 Taka \add jest\add* droga kobiety cudzołożnej: je i obciera swoje usta, i mówi: Nie zrobiłam nic złego.
\m 
\v 21 Pod trzema rzeczami drży ziemia, czterech nie może znieść:
\m 
\v 22 Sługi, kiedy panuje, głupca, kiedy syci się chlebem;
\m 
\v 23 Obmierzłej \add kobiety\add*, kiedy wychodzi za mąż, \add i\add* służącej, kiedy dziedziczy po swojej pani.
\m 
\v 24 Cztery są rzeczy najmniejsze na ziemi, jednak mędrsze nad mędrców:
\m 
\v 25 Mrówki, lud słaby, a jednak w lecie przygotowują pokarm;
\m 
\v 26 Króliki, lud słaby, a jednak budują swój dom w skale;
\m 
\v 27 Szarańcze nie mają króla, a jednak wszystkie wyruszają chmarą;
\m 
\v 28 Pająk pracuje rękoma, a bywa w pałacach królewskich.
\m 
\v 29 Trzy są rzeczy, które poruszają się wspaniale, cztery kroczą dostojnie:
\m 
\v 30 Lew, najsilniejszy wśród zwierząt, który przed nikim nie ustępuje;
\m 
\v 31 Chart i kozioł, i król, przeciw któremu nikt nie powstaje.
\m 
\v 32 Jeśli głupio postąpiłeś, wynosząc się, albo jeśli pomyślałeś źle, \add połóż\add* rękę na ustach.
\m 
\v 33 Jak ubijanie mleka daje masło i wycieranie nosa wywołuje krew, tak kto wzbudza gniew, wszczyna kłótnię.
\c 31
\m 
\v 1 Słowa króla Lemuela, proroctwo, którego nauczyła go jego matka.
\m 
\v 2 Cóż, synu mój? Cóż, synu mojego łona? I cóż, synu moich ślubów?
\m 
\v 3 Nie oddawaj kobietom swej siły ani twoich dróg temu, co \add prowadzi\add* do zguby królów.
\m 
\v 4 Nie królom, o Lemuelu, nie królom wypada pić wina i nie książętom bawić się mocnym napojem;
\m 
\v 5 By pijąc, nie zapomnieli praw i nie wypaczyli sprawy wszystkich ludzi uciśnionych.
\m 
\v 6 Dajcie mocny napój ginącym, a wino strapionym na duchu.
\m 
\v 7 Niech się napiją i zapomną o swoim ubóstwie, i niech nie pamiętają więcej swego utrapienia.
\m 
\v 8 Otwórz swe usta dla niemych w sprawie wszystkich osądzonych na śmierć.
\m 
\v 9 Otwórz swe usta, sądź sprawiedliwie i broń sprawy ubogiego i nędzarza.
\m 
\v 10 Któż znajdzie kobietę cnotliwą? Jej wartość przewyższa perły.
\m 
\v 11 Serce męża jej ufa i zysku mu nie zabraknie.
\m 
\v 12 Dobro mu będzie wyświadczać, a nie zło, po wszystkie dni swego życia.
\m 
\v 13 Szuka wełny i lnu i chętnie pracuje swymi rękami.
\m 
\v 14 Podobna jest do okrętów handlowych; przywozi żywność z daleka.
\m 
\v 15 Wstaje, gdy jeszcze jest noc, i daje pokarm swoim domownikom i odpowiednią porcję swym służącym.
\m 
\v 16 Myśli o polu i kupuje je; z zarobku swych rąk sadzi winnice.
\m 
\v 17 Przepasuje swe biodra siłą i umacnia swoje ramiona.
\m 
\v 18 Dostrzega, że jej dorobek jest dobry, a jej pochodnia w nocy nie gaśnie.
\m 
\v 19 Wyciąga ręce po kądziel, a dłonią chwyta wrzeciono.
\m 
\v 20 Otwiera dłoń przed ubogim i wyciąga swe ręce do nędzarza.
\m 
\v 21 Nie boi się śniegu dla swych domowników, bo wszyscy jej domownicy są ubrani w szkarłat.
\m 
\v 22 Robi sobie kobierce; jej ubiór jest z jedwabiu i purpury.
\m 
\v 23 Jej mąż jest znany w bramach, gdy siedzi wśród starszyzny ziemi.
\m 
\v 24 Wyrabia płótno i sprzedaje je, dostarcza pasy kupcowi.
\m 
\v 25 Siła i godność są jej strojem; będzie się cieszyła jeszcze w przyszłości.
\m 
\v 26 Otwiera swe usta mądrze i na jej języku \add jest\add* prawo miłosierdzia.
\m 
\v 27 Dogląda spraw swego domu i nie je chleba próżniactwa.
\m 
\v 28 Jej dzieci powstają i błogosławią jej, mąż także ją chwali:
\m 
\v 29 Wiele kobiet poczynało sobie cnotliwie, ale ty przewyższasz je wszystkie.
\m 
\v 30 Wdzięk \add jest\add* zwodniczy i piękność próżna, \add lecz\add* kobieta, która się boi PANA, jest godna pochwały.
\m 
\v 31 Dajcie jej z owocu jej rąk i niech jej czyny chwalą ją w bramach. 
