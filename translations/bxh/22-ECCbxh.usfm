\id ECC
\h Tau Guguya 
\toc1 Lau Guguya Bukana (Ekelesiyasiti) 
\toc2 Lau Guguya 
\toc3 Lau Guguya 
\mt1 Tau Guguya  
\mt2 (Ekelesiyasiti)  
\c 1
\s1 Ginauli Mahudoꞌina Hige Aniyodi  
\sr Tau Guguya 1:1-11  
\q1
\v 1 Tanuwaga hesa Deiwidi natuna in Yelusalem edi kin ena gaimumu.   
\q1
\v 2 Iyen,  
\pi1 Hige aniyona!  
\q2 Wananaha hige aniyona!  
\q2 Ginauli mahudoꞌina hige aniyona.   
\q1
\v 3 Taumoho paisowa mahudoꞌina ya ginauli tanohi yai,  
\q2 mate lisina yai somo ya lobahi?   
\q1
\v 4 Hitina ya laoma yo ya lau  
\q2 in moho tanoꞌubu otaꞌotana.   
\q1
\v 5 Maihala ya kepa na ya sina ee–, ya bulu  
\q2 na feula ya fuyo ena aba kepama yai  
\q2 be haba bobon ya sina boda.   
\q1
\v 6 Hwayahwayau ya towa hasa  
\q2 na ya bui be ya towa lidi,  
\q1 ya taꞌitaꞌiꞌili be ya fuyo ena aba towa bwaꞌibwaꞌina yai.   
\q1
\v 7 Hoꞌowa mahudoꞌidi sa didi lidi be gabogabo yai sa pei taluhidi.  
\q2 In moho gabogabo hige i mohafu. Haba sa fuyo ai ulu  
\q2 be ainiya sa didi fuyo lidi gabogabo.   
\q1
\v 8 Haba sai somo ya libaen?  
\q1 Ginauli mahudoꞌidi tanoꞌubu yai nenedi eseꞌesegadi,  
\q2 hige ti buidi,  
\q2 yo sa fakamna heyaheyaya.  
\q1 Ginauli boludi te itadi yo liba hudohudoꞌi te atahiyedi  
\q2 in moho hige gonogonowada.  
\q1 Te gado bena te itaꞌita,  
\q2 yo te ataꞌatahi ya laulaui moho.   
\q1
\v 9 Beyabeyana somo sa tubu  
\q2 haba sa lau boda fuyo.  
\q1 Dodoga somo beyabeyana sa ginaulidi  
\q2 haba sa ginauli fuyoꞌidi.  
\q1 Tanohi yai hige ginauli hesa falifalihuna.   
\q1
\v 10 Doga haba sidohana iyen,  
\q2 “Hola au ita! Ite ginauli falifalihuna.”  
\q1 Higeꞌe! Ginauli te, haꞌa beyabeyana amaiteꞌi;  
\q2 ita hola hige ta tubu. In, haꞌa amaiteꞌi.   
\q1
\v 11 Hige gonowana sai laꞌi hiti halo dodogadi i nuwatuhuidi,  
\q2 yo hiti hesa ai mulida sa tubu,  
\q1 ibege hiti ai mulidi sa tubu,  
\q2 ti nuwatuhuidi hinaga.   
\s1 Sibasiba Hige Aniyona  
\sr Tau Guguya 1:12-18  
\q1
\v 12 Yau tanuwaga yo yau beyabeyana \w Isalaela\w* edi kin, Yelusalem yai.   
\p
\v 13 Sibasiba yoꞌoyoꞌoina yai egu fuya E pei, bena sidohana ginauli mahudoꞌidi tanoꞌubu yai sa tubu te, paꞌana wananahana E yoꞌoi be E sibai. Yaubada mwahu laꞌilaꞌi dodoga lisidi yai ya tole.   
\p
\v 14 Ginauli mahudoꞌidi sa ginaulidi maihala yai haꞌa E itadi, mahudoꞌidi hige aniyodi. E tafotafo watanidi, mate hige aniyodi, doha hwayau E tafotafo watan.   
\q1
\v 15 Somo haꞌa sa filisi hige gonowana ti fadudulai fuyoi.  
\q2 Somo hige amainiya, hige gonowana ti fatili.   
\pi1
\v 16 Nuwagu yai yawa, “Yau E sibasiba wananaha, habahim kin hahaisa beyabeyana haꞌa Yelusalem yai. Ami ita! Yau sibasiba yo sonoga haꞌa E abidi.”   
\b  
\p
\v 17 Sibasibana ena aba laoma somo yai, yo laulau yauyauledi E anpate bena E yoꞌoidi. In moho, E lobahi mate doha hwayahwayau E weꞌaweꞌai.   
\p
\v 18 Sibasiba ya ouli, mate nuwa dubu hinaga ya laꞌi wananaha. Sibasiba ya laꞌi wananaha, mate nuwa heyaya hinaga doha.   
\c 2
\s1 Kwade Gaibu Hige Aniyona  
\sr Tau Guguya 2:1-11  
\q1
\v 1 Nuwagu yai yawa, “Haga nuwagu ya lau watan,  
\q1 ya lau ya kwadekwade gaibu  
\q2 be loholoho sidohana haba E lobahi.”  
\q2 In moho laulau te, hige aniyona.   
\q1
\v 2 E ita lobahi mate, liuliuhwa gaibu, laulau yauyaulena.  
\q2 Na kwade gaibu lisina yai, ibege loholoho ya lobahi.   
\q1
\v 3 Hola loholoho aniyona E yoꞌoi.  
\q1 Logena be nomnom yauyaule yo kwade hesa - hesa E anpateidi.  
\q2 E gado bena E siba somo ya loholoho dodoga lisidi yai,  
\q2 ai maihala tupotupona tanoꞌubu yai te.   
\q1
\v 4 Ginauli mahudoꞌina E ginauli.  
\q2 Egu luma E ginaulidi  
\q2 yo wain E umahidi gabudi yai.   
\q1
\v 5 Gabu E lau ginauli be ganahewadi yai  
\q2 fuwafuwa nene hesa - hesa E umahidi.   
\q1
\v 6 Hoꞌowa ipuna E ginauli,  
\q2 ainiya haba hoꞌowa E yahi  
\q2 be umaꞌuma laulau idahedi E fanom hoꞌowadi.   
\q1
\v 7 Egu tau lau fayofayo tatau yo wawahin E unedi,  
\q2 yo egu tau lau fayofayo haisa mate egu luma yai sa tubu.  
\q1 Egu bulumakau yo sipi baiwadi sa ouli,  
\q2 habahim dodoga haisa Yelusalem yai.   
\q1
\v 8 Siluba yo gole aiʼegu E abidi. Babaꞌisa yo nuʼu boludi edi gogo loholohodi hinaga E abidi. Tau wana tatau yo wawahin E fasinabodi hinaga. Tau lau fayofayo wawahin boludi E faidi sa famala doha lalahugu.   
\q1
\v 9 Yau E hasai wananaha habahim dodoga haisa Yelusalem yai.   
\q1
\v 10 Matagu yai somo E ita mate E fanuha bena E abi,  
\q2 yo nuwagu moho tanoꞌubu kwadena.  
\q1 In moho nuwagu ya loholoho egu paisowa lisina yai  
\q2 paꞌana egu abi peꞌipeꞌi logena maisagu.   
\p
\v 11 Fuyanna ginauli mahudoꞌina nimagu yai E ginauli yo somo E ankamkamnaꞌen be loholoho E abi, E mainene sipoi be E lobahi mate ginauli mahudoꞌina te, hige aniyodi. Doha hwayau E tafotafo watan, hige agu loge. Maihala yai hige somo laꞌi ya abi. Ginauli mahudoꞌina ganahewana yai te mate E sibasiba wananaha.   
\s1 Sibasiba yo Yauyaule Hige Aniyodi  
\sr Tau Guguya 2:12-16  
\q1
\v 12 Habahim egu nuwanuwatuhu E bui be sibasiba E ita sipoi.  
\q2 Kabakabaleya yo gelogeloma hinaga E nuwatuhu fadosidi.  
\q1 Kin, somo haꞌa ya ginauli mate,  
\q2 tau lau fadamahina haba somo hesa ya ginauli?   
\q1
\v 13 E nuwatuhu lobahi mate sibasiba ya loholoho wananaha,  
\q2 habahim yauyaule,  
\q1 doha mala ya loholoho wananaha,  
\q2 habahim kamumu.   
\q1
\v 14 Tau sibasiba ena aba lau ya sibai  
\q2 na yauyaulena higeꞌe.  
\q1 In moho E nuwatuhu lobahi mate,  
\q2 luwaluwagadi edi fuya ofi nenena esega.   
\q1
\v 15 Habahim nuwagu yai yawa,  
\q2 “Yau haba E peꞌi doha  
\q2 doga yauyaulena.”  
\q1 Be sibasiba lebena yai somo haba E abi?  
\q2 Ite hinaga hige aniyona.   
\q1
\v 16 Logena doga sibasibana haba doha yauyaulena,  
\q2 sa nuwa fuiyen maꞌamaꞌaen.  
\q1 Lahaidi sa laolaoma ibege ti nuwatuhuidi.  
\q2 Doga sibasibana hinaga bena ya peꞌi,  
\q2 doha doga yauyaulena!   
\s1 Paisowa Hige Aniyona  
\sr Tau Guguya 2:17-26  
\q1
\v 17 Logena mwahuli te, E ꞌwaiyoꞌoꞌen,  
\q2 paꞌana paisowa maihala yai ya faꞌankamkamnagu.  
\q1 Mahudoꞌina hige aniyona doha hwayau E tafotafo watan,  
\q2 na hige agu loge.   
\q1
\v 18 Ginauli mahudoꞌidi E ginaulidi maihala yai mate,  
\q2 E waiyoꞌoꞌedi wananahaidi,  
\q1 paꞌana ibe E lau afuledi,  
\q2 mate doga hesa muligu yai haba aiꞌena.   
\q1
\v 19 Doga sibasibana e yauyaulena, sai ya sibai?  
\q2 Ma adidiligu yai, egu sibasiba yo adidili yai,  
\q2 paisowa mahudoꞌidi E ginaulidi maihala yai.  
\q1 In moho haba ya tanuwagaidi.  
\q1 Ite hinaga hige aniyona.   
\q1
\v 20 Paisowa yai E abi peꞌipeꞌi,  
\q2 E nuwatuhui be nuwagu ya kuꞌu.   
\q1
\v 21 Doga gonowana ena sibasiba yai ena paisowa ya ginauli,  
\q2 na habahim ya lau afulen, be sai hige i kamna heyayaꞌen, aiꞌena.  
\q2 Ite ya heyaya wananaha yo hinaga hige aniyona.   
\q1
\v 22 Maihala yai taumoho ya paisowa peꞌipeꞌi,  
\q2 na lisina yai somo ya lobahi?   
\q1
\v 23 Ena mwahuli fuyadi yai mate ena paisowa ya fakamna heyaya.  
\q2 Ai iꞌipadi ya nuwanuwatuhu hinaga hige i anyawasi.  
\q2 Ite hinaga hige aniyona.   
\q1
\v 24 Doga hige gonowana somo loholohona i ginauli,  
\q2 na bena moho ya nom yo ya an,  
\q2 yo hinaga bena nuwana ya loholoho ena paisowa lisidi yai.  
\q1 Ite hinaga E ita mate, Yaubada ena gigibwali yai ya ginaulidi.   
\q1
\v 25 Paꞌana ibe in higeꞌe, haba somo ya an?  
\q2 E haba sidohana nuwana ya loholoho?   
\q1
\v 26 Sai Yaubada nuwana ya fafaloholoho,  
\q2 mate sibasiba, sonoga yo kwade ya felen,  
\q1 in moho, tau heyaya mate Yaubada gogo loholohodi,  
\q2 fafatabudi paisowadi lisidi yai ya fakamna heyayadi,  
\q2 na ai mulina haba sa fele lawen Yaubada nuwana tau faloholohona lisidi.  
\q1 Ite hinaga hige aniyona,  
\q1 doha hwayahwayau ya tafotafo watan,  
\q2 na hige adi loge.   
\c 3
\s1 Ginauli Mahudoꞌina Ana Lahai  
\sr Tau Guguya 3:1-11  
\q1
\v 1 Ginauli mahudoꞌina maꞌana lahai;  
\q2 galewa ubuna yai maꞌana fuya.   
\q1
\v 2 Tubu fuyana yo peꞌi fuyana,  
\q2 uma fuyana yo lau gabu fuyana.   
\q1
\v 3 Aiyunu fuyana yo faloholoho fuyana,  
\q2 lau lopa fuyana yo ginauli fuyo fuyana,   
\q1
\v 4 Tantan fuyana yo kwade fuyana,  
\q2 nuwa heyaya ana fuya yo leꞌi ana fuya.   
\q1
\v 5 Umeꞌehu fafapei fuyana yo pei gogonidi fuyana,  
\q2 fagado bainewa fuyana, yo fagado bainewa haꞌasi.   
\q1
\v 6 Yoꞌo fuyana, yo yoꞌo sa fatautau,  
\q2 ita wata fuyana, yo fapei fuyana.   
\q1
\v 7 Kampuliti fuyana yo bodibodi fuyana,  
\q2 moꞌa pwakum fuyana yo libaliba fuyana,   
\q1
\v 8 Gadosisi fuyana yo fawaiyunu fuyana,  
\q2 Hiyala fuyana yo miya daumwali fuyana.   
\q1
\v 9 Tau paisowa ena paisowa yai, somo ya lobahi?   
\q1
\v 10 Yaubada mwahu ya tole dodoga lebedi yai mate E ita.   
\p
\v 11 Ginauli mahudoꞌina ya ginauli komakomaniꞌidi adi maihala yai.  
\q1 Fuya hige ana siga \nd Guyau\nd* ya tole dodoga nuwadi yai,  
\q2 in moho somo Yaubada ya ginauli fuya bwaꞌibwaꞌina yai ya lau ee–, ofiꞌofina yai,  
\q2 mate hige gonowana ta nuwatuhu lobahi.   
\c 4
\q1
\v 9 Dodoga luwaga sa loholoho wananaha, habahim doga esega,  
\q2 paꞌana edi paisowa yai haba sa faisagusagu fuyoꞌidi,  
\q2 be loholoho sa lobahi.   
\q1
\v 10 Ibe esega ya beꞌu,  
\q2 haba hesa ya faꞌobiyo fuyoi, na doga ibona mate ya fanuwatohatoha, hige tau saguhina.   
\q1
\v 11 Doha dodoga luwaga sa eno luwaluwaga  
\q2 be ibege ti waꞌoꞌo,  
\q1 na doga ibona haba ya waꞌoꞌo.   
\q1
\v 12 Doga ibona gonowana sa dulu mahanoi be sa lei hafihafiti,  
\q2 na dodoga luwaga haba sa faisagusagu fuyoꞌidi.  
\q1 Dodoga faihona mate sa fuluga wananaha doha balawa,  
\q2 mahina faihona yai sa ginauli  
\q2 hige gonowana i tamotu maꞌamaꞌai.   
\c 5
\s1 Angwala Gaibu \nd Guyau\nd* Lisina yai, Hige i Loholoho  
\sr Eccles 5:10-15  
\q1
\v 10 Sai moni gadosisina lebena yai haba fuya ouꞌouli ya gadogado moni.  
\q2 Ite hinaga hige aniyona.   
\q1
\v 11 Yena em moni sa ouli,  
\q2 dodoga boludi haba sa laowa,  
\q2 sa saguhim be ami fapaisowa ofina.  
\q1 Doga fafamonina ena moni ya ita  
\q2 yo monina ena lau hinaga ya ita.   
\q1
\v 12 Dodoga sa paisowa adidili haba sa eno komakoman,  
\q1 anꞌan begana e laꞌilaꞌi sa an, in moho haba sa eno.  
\q2 Na dodoga fafamonidi,  
\q2 haba sa modemodeꞌen be ibege ti eno komakoman.   
\q1
\v 13 Heyaya laꞌilaꞌina hesa E ita tanoꞌubu yai te mate doha ite:  
\q2 Doga hesa haba moni laꞌilaꞌi ya abi,  
\q2 na yena ya oihalayen haba ya faheyaya fuyoi.   
\q1
\v 14 Doha ibe haisa edi moni na sa kai wegowegogoꞌen  
\q2 be moni ya ofi.  
\q1 Yena sa peʼi nanatudi ibege edi moni.\f + \fr 5:14 \ft Doha ibe haisa edi moni sa abi be seya ya une company lebedi yai\f*  
\q2 Be yena sa peꞌi, nanatudi ibege edi moni.   
\q1
\v 15 Mahudoꞌida haba doha ite, te tubuma ma tau afaꞌafada,  
\q2 na yena te peꞌi, ginauli mahudoꞌina te paisowai  
\q2 haba te lau afulen, ibege laꞌi ta lawen.   
\c 7
\s1 Sonoga  
\sr Tau Guguya 7:15-20  
\q1
\v 15 Egu mwahuli kufakufana yai te, ginauli luwaga E itadi:  
\q2 doga dudulaina ena miya hige i lofa, in moho ya peꞌi,  
\q1 na doga heyaheyayana ya miya lofalofa ena heyaya yai.   
\q1
\v 16 Tabu dudulai u diꞌoi be u dudulai wanawananaha,  
\q2 yo sibasiba u diꞌoi be u sibasiba wanawananaha.  
\q1 Doꞌata wa faheyaya fuyoim.   
\q1
\v 17 Tabu hinaga heyaya u diꞌoi, be u heyaya wanawananaha,  
\q2 yo tabu u yauyaule.  
\q1 Hola hige em peꞌi fuyana na sidohana wa gado peꞌi feula?   
\q1
\v 18 Ya loholoho ibe fanuwatagu libadi te ami nuwa nuwatuhuidi;  
\q2 sai \nd Guyau\nd* ya faꞌatitiyen  
\q2 haba laulau heyaheyayadi luwaga te, ya gebaedi.   
\q1
\v 19 Tau sibasiba esega mate ya adidili wananaha,  
\q2 habahim babaꞌisa safuhudohudoꞌi ma adiꞌadidilidi, taon yai.   
\q1
\v 20 Tanoꞌubu yai te hige sai i dudulai.  
\q2 Doga laulau loholohodi ya ginaginaulidi,  
\q2 in moho heyaya ya ginauli hinaga.   
\c 8
\q1
\v 16 Fuyanna E nuwatuhui mate:  
\q2 sidohana sibasiba haba E abi,  
\q2 na iꞌipa yo lahai, paisowa somo sa laulau tanoꞌubu yai,  
\q1 E tuhutuhuli moho. Hige gonowana ya eno.   
\q1
\v 17 In moho Yaubada somo ya ginaginauli tanoꞌubu yai  
\q2 ibege au nuwatuhu lobahi.  
\q2 Haba ami anpate adidili bena ami yoꞌoi  
\q1 be aniyona ami sibai  
\q2 in moho hige gonowamiu.  
\q2 Tau sibasiba haba iye, “E siba.” In moho higeꞌe.   
\c 11
\s1 Ma Hewahewalimiu yo Ma Hasahasalamiu \nd Guyau\nd* au Nuwatuhui.  
\sr Tau Guguya 11:9-10  
\p
\v 9 Hewahewali yo hasahasala! Ma tubu loholohomiu emi kwade au kwadeyedi, yo emi fanufanuha au lau watanidi. In moho, somo ami ginaulidi, Yaubada haba ya fakasamiu.  
\v 10 Tabu ginauli hesa i famodemiu, yo kamkamna i felemiu. Haba hewalimiu yo hasalamiu, ibege ti ota lofalofa.   
\c 12
\s1 Eccles 12:1-14  
\q1
\v 1 Ma hewahewalimiu yo ma hasahasalamiu,  
\q2 tabu Tau Ginaulimiu au nuwa fuiyen,  
\q1 doꞌata emi fuya tautaulaꞌi yo tinatinalaꞌi yai auwe,  
\q1 “Hige amna hesa loholohona ai lobahi.”   
\q1
\v 2 Bena ami nuwatuhui, doꞌata emi fuya tautaulaꞌi yo tinatinalaꞌi yai,  
\q2 matamiu sa gafu doha maihala,  
\q2 nawalahi yo kipwala sa ꞌwahuꞌwahuhuli  
\q1 yo doha usa yadadi galewa sa fafakamumu.   
\q1
\v 3 Nimamiu, aba bobodiyemiu hola hige ti tabutabubu,  
\q2 yo ahemiu sa fafaꞌadidilimiu hola hige ti belubelu,  
\q1 moꞌamiu hola hige ti gabo  
\q1 lisina yai ami anꞌan aba mamaina,  
\q2 matamiu ma loholohodi lisina yai ami itaꞌita,  
\q2 mate bena Tau Ginaulimiu, ami nuwatuhui.   
\q1
\v 4 Beyamiu lisina yai dagugu edaꞌeda yai emi aba atahiyenna. Hola hige ti doꞌo,  
\q1 yo wawahin sa paipaisowa dagugudi, wana yo dagugu hesa - hesa,  
\q2 hola ami ataꞌatahiyedi mate,  
\q2 bena Yaubada ami nuwatuhui.  
\q1 Ataiꞌa edi gwane yai haba sa fanohimiu  
\q2 in moho ibege au atahi komakoman.   
\q1
\v 5 Tau Ginaulimiu bena ami nuwatuhui,  
\q2 yo edaꞌeda launa ami ꞌwasabuwedi, doꞌata ami beꞌu.  
\q1 Kulumiu hola hige ti fou ofi doha didiyali tayadi,  
\q2 yo hola hige au lau welawelai.  
\q2 Doha kupati hanahanau haba ya peꞌi,  
\q1 yo emi amna hola hige ti tomatoma,  
\q2 mate bena ami nuwatuhui.  
\q1 Ma mwahumwahulimiu bena ami nuwatuhui.  
\q2 Tabu au bagibagi ee–, peꞌi fuyana,  
\q2 yena ami peꞌi,  
\q2 haba ami lau \em Biula.\em* \f + \fr 12:5 \fq Siyola \ft Alina Hebelu yai, mate doha \fq Biula\ft  e \fq Tanolai\ft  amaiteꞌi.\f*  
\q1 Na dodoga haba halamiu sa tan eloꞌelolosi.   
\q1
\v 6 Aho te, au nuwatuhui paꞌana haba ami peꞌi  
\q2 doha mahina pwalana ya tamotu,  
\q2 yo gulewa ya tamo golugolu  
\q1 yo doha hoꞌowa aba yahiyahi ya tamo golugolu,  
\q2 yo balawa, hoꞌowa aba yahiyahina ya tamotu.   
\q1
\v 7 Ami peꞌi, haba ami fuyo tanohi,  
\q2 na yaluwamiu haba sa fuyo Yaubada lisina.   
\q1
\v 8 Yau, Tau lau faꞌata, yawa, “Ginauli mahudoꞌidi hige aniyona! Kufana!”   
\p
\v 9 Yau, Tau lau faꞌata mate, E sibasiba wananaha be E anfatalahaen dodoga lebedi yai be haba sa sibasiba hinaga. Nuwatuhu te, E fadosi komakomanidi, wananaha e higeꞌe? Be gaimumu te E pei dailidi.  
\v 10 E anpate be E liba fadudulaidi, habahim E ulidi be sa famala gaimumu wananahadi.   
\p
\v 11 Doga sibasibana ena liba sa faꞌankamkamna in moho ya fafadudulai doha tuꞌe, tau paisowa ya abi doha tuꞌe tau paisowa ya eliꞌeliyen bulumakau yai be haba ya foya dudulaiꞌi. Ibe ena gaimumu loholohona ya pei gogondi buka yai, haba ya ota hige anadan. Ibege i fatautau doha powati tau paisowa ya tutu fapatu lawen oyagi yai be ya abi didin.  
\v 12 Natugu, u itaꞌita komakoman! Ginauli hahaisa u lau afuledi.  
\p Uliꞌuli paisowana ibege i ofi, na sibasiba anpatena ya faꞌamna heyaheyaya!   
\p
\v 13 Gaimumu mahudoꞌidi haꞌa ami atahidi be egu liba E falafusofa doha ite:   
\p
\v 14 \nd Guyau\nd* emi laulau simosimodi haba ya fakasadi, loholohodi yo heyaheyayadi, be Yaubada au faꞌatitiyen yo ena laugagayo au famuli watanidi paꞌana ya ginaulimiu.   