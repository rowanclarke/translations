\id MIC - Tsikimba
\h Mika
\toc1 Tagara̱da u Mika
\toc2 Mika
\toc3 Mik
\mt2 Tagara̱da u
\mt1 Mika
\c 1
\p 
\v 1 Kadyanshi ka Magono ma Zuba ka tuwa̱i ara Mika matsumate vuma u Moreshetu a kaci ka kuwene ka u wenei a kaci ka ilyuci i Samariya n Urishelima, a'ayin a ɗa Jotam n Ahazu n Hazakaya a ka lya tsugono tsu Yahuda.\f + \fr 1:1 \ft Kondo: \xt 2 Ngo 15:32-38; 2 Alb 27:1-9; 2 Ngo 16:1-20; 2 Alb 28:1-27; 2 Ngo 18:1--20:21; 2 Alb 29:1--32:33\xt*\f*
\s1 Ushipa u ulapa u una̱ adama a Samariya n Urishelima
\q1 
\v 2 Panai na gba̱ ɗe, kakuma̱ ka ama,
\q2 panai na, gba̱ aza ɗa a'a̱ri a likimba!
\q1 A̱sa̱ka̱ Magono ma Zuba Uzapige
\q2 n kaci ne u woko uza ɗa
\q2 wenei ukuna vi a kaci ka ɗe,
\q1 panai kadyanshi ka ne ka ka wuta̱
\q2 a kuwa ka uwulukpi ka ne.
\q1 
\v 3 Weɓelei! Magono ma Zuba ma wuta̱
\q2 a asu u ndishi n ne wa tuwa̱,
\q1 wa tuwa̱ ta̱ iyamba
\q2 u wala a bilibili u nsasa n likimba.
\q1 
\v 4 Nsasa ma dara̱kpa ta̱ a kere ku ne
\q2 ara̱ra̱ kpam a ka ɓatsa ta̱ kure.
\q1 Nsasa kpam ma dara̱kpa ta̱
\q2 yavu akawa a ishigi a asuvu a akina,
\q1 yavu mini ma ma yene
\q2 a kakonguro ubana a asu u ara̱ra̱.
\q1 
\v 5 Gba̱ nala vi wa gita̱ ta̱
\q2 na̱ mmuku n tsikaya n Yakubu,
\q1 wata, aza a Isara'ila an a yain
\q2 unyushi u cingi kpam a 'ya̱nga̱sa̱ka̱i Kashila̱.
\q1 Ya zuwai Yakubu yain unyushi u cingi?
\q2 Aza a Samariya a ɗa, ilyuci i pige i ne!
\q1 Nte ɗa a asu u ulyasa̱ka ameli kayala a Yahuda?
\q2 Urishelima ɗa n kaci ka ne!
\b
\q1 
\v 6 Magono ma Zuba ma danai,
\q2 <<Adama a nala ma wacinsa ta̱ Samariya
\q2 u woko akpongo hal u woko agbaji,
\q2 asu u ɗa a ka shigbusa̱ ashina a cinwi.
\q1 Ma wacinsa ta̱ atali a kuma ki a asuvu a kara̱ra̱,
\q2 n muɗa̱gbusa̱ kpam atali a kami ka kuma ku ne.
\q1 
\v 7 Gba̱ ameli a ne a ka ta̱sa̱sa̱ ta̱ a ɗa yuku-yuku;
\q2 gba̱ kune ka a tukusoi a kuwa ku ameli ku ne
\q2 a ka runukpa ta̱ ka n akina;
\q2 ma wacinsa ta̱ gba̱ a'ulu a ne.
\q1 An u wokoi u ɓolomgbonoi kune ku ne
\q2 a asu u katsupi ka tsu tsishankala,
\q2 a asu u tsishankala ɗa kpam ka kotso.>>
\s1 Kushen ku Mika adama aza a Isara'ila n Yakubu
\q1 
\v 8 Adama a nala ma sa̱ ta̱,
\q2 n yain ndishi ma ulapa una̱;
\q2 ma foɗo ta̱ aminya
\q2 n tambi kataɓa kpam bawu akpata.
\q1 Ma wura̱ ta̱ yavu nshe n kakamba
\q2 n sa̱i yavu makuɓi.
\q1 
\v 9 Kpaci usa̱n u Samariya
\q2 usa̱n u ɗa bawu wa ta̱na̱.
\q1 U tambura ɗe hal a Yahuda,
\q2 u rawa ɗe a ilyuci i ama a va̱,
\q2 wata Urishelima dem.
\b
\q1 
\v 10 Kotsu i tonuko atokulalu a tsunu a Gatu wa;
\q2 kotsu kpam i sa̱i wa ko kenu.
\q1 A Bete-leyafara ɗa ya gandala̱sa a iyamba.\f + \fr 1:10 \ft Mika matsumate u yan ta̱ kadyanshi a kaci ka ilyuci ushani i'ya atokulalu a ka lya a ka tuwa̱ baci a Urishelima a lyai u ɗa. A makpa̱nda̱ ma na mi (10-15), Mika yanka ta̱ idyani i'ya i'a̱ri evu n a'ala a ilyuci yi tsa̱ra̱ u wenike ilyuci i'ya atokulalu yi a ka lya n kuvon.\f*
\q1 
\v 11 Aza a Shafiru, banai tsuwula̱,
\q2 i wala kataɓa n uwono.
\q1 Aza a ɗa i'a̱ri ndishi a Za'ana a ka wuta̱ wa.
\q2 Aza a Bete-ezelu a'a̱ ta̱ a asuvu a ulapa u una̱
\q2 kpaci a tsa̱ra̱ u ɓa̱nga̱ a asu u le wa.
\q1 
\v 12 Aza a ɗa a'a̱ri ndishi a Marotu
\q2 a ka vana tsa̱ra̱ a tsa̱ra̱ ili i shinga,
\q1 shegai Magono ma Zuba
\q2 ma zuwai mada̱ka̱ ma rukpa̱i a utsutsu u Urishelima.
\q1 
\v 13 Eɗa̱ aza a ɗa i'a̱ri ndishi a Lakishi,
\q2 foɓusoi nringongo ma adoki n ɗe, tsa̱ra̱ i suma.
\q1 Kpaci eɗa ilyuci i kagita̱ a Yahuda
\q2 i tonoi aza a Isara'ila a asu u 'ya̱nga̱sa̱ka̱ u le,
\q2 i zuwai kpam aza a Sihiyona a yain unyushi u cingi.
\q1 
\v 14 Adama a nala, aza a Yahuda
\q2 tonukoi aza a Moreshetu-gatu
\q2 u yan tsu ben i na̱ka̱ le kune.
\q1 Ngono ma Isara'ila a ka pityanangu ta̱
\q2 n ilyuci i Akiziba
\q2 shegai a ka tsa̱ra̱ u ɓa̱nga̱ wa.
\q1 
\v 15 Mpa Magono ma Zuba n danai,
\q2 eɗa̱ aza ɗa i'a̱ri ndishi a Maresha
\q2 ma doku ta̱ ma tuko uza ɗa wa lya ɗa̱ n kuvon.
\q1 Azapige a Isara'ila
\q2 a ka suma ta̱ ubana a Adulam.
\q1 
\v 16 Punai a'aci a ɗe asuvu a ulapa u una̱
\q2 adama a mmuku n ɗe aza ɗa ya ciga;
\q1 gonukoi kaci ka ɗe yavu kukpani ka kasakali,
\q2 kpaci mmuku n ɗe a ka laza ta̱ tsuwula̱.
\c 2
\s1 Ter ɗe aza u 'yankusu aza a unambi
\q1 
\v 1 Ter ɗe aza ɗa a tsu foɓuso tsicingi,
\q2 aza ɗa kpam a tsu foɓuso
\q2 ukuna u cingi a ivamkpatsu i le!
\q1 Kain ka wansa baci a tsu yan ta̱ i'ya a foɓusoi vi,
\q2 kpaci n ucira u le ɗa a tsu fuɗa ta̱ yain i'ya.
\q1 
\v 2 A tsu yan ta̱ maluwa ma gbani
\q2 n ashina n ama, a wusa a ɗa.
\q1 A tsu yan ta̱ kpam maluwa ma gbani
\q2 n a'uwa a ama, a wusa a ɗa.
\q2 A tsu ryafa ta̱ ama tsa̱ra̱ a wusa a'uwa a le n iyamba i le.
\p 
\v 3 Adama a nala ili i'ya Magono ma Zuba ma danai i'ya na:
\q1 <<Ma foɓuso ta̱ uwacinsa a kaci ka ama yi,
\q2 ucun u ɗa bawu ya fuɗa ya wauwa kaci ka ɗe.
\q1 Ya doku ya wala n i yanyi ara̱ɗi wa,
\q2 kpaci wa woko ɗa̱ ta̱ a'ayin a mada̱ka̱.
\q1 
\v 4 A kain ka nala ki, ama a ka yanka ɗa̱ ta̱ majari,
\q2 a ka yanka ɗa̱ ta̱ majari a shipuka ɗa̱
\q2 ushipa u unamgbukatsuma̱, a dana,
\q1 <A nangasa tsu ɗe gba̱!
\q2 Magono ma Zuba ma wusa ɗe uyamba u tsunu!
\q2 U na̱ka̱i ashina a tsunu a asu u aza a ɗa a yinsa̱ tsu.> >>
\b
\q1 
\v 5 Adama a nala, a'ayin a tuwa̱ baci
\q2 a ɗa a ka gonuko uyamba vi
\q2 a asu u ama a Magono ma Zuba,
\q1 ko uza u te asuvu a ɗe
\q2 wa̱ri n kapeci pini wa.
\b
\q1 
\v 6 Ama ushani a danai,
\q2 <<Kotsu i yain kuɓari wa!
\q1 A̱sa̱ka̱ uyan kuɓari a kaci ka ili i nala yi,
\q2 ili i uwono i roku i'a̱ la ya gita̱ n a̱tsu wa.>>
\q1 
\v 7 Dere ɗa a dana nala, mmuku n tsikaya n Yakubu?
\q2 Ahankuri a Kulu ku Magono ma Zuba a gusa̱ ɗa?
\q2 Ko aya u yain ili i nala yi?
\b
\q1 Kadyanshi ka Magono ma Zuba ka̱ri n kalen
\q2 a asu u uza ɗa wa tono yi n ukuna u maci wa?
\q1 
\v 8 Magono ma Zuba ma danai,
\q2 <<Shegai i tsu 'ya̱nga̱ ta̱ yavu atokulalu a asu u ama a va̱.
\q1 I tsu foɗo ta̱ ntogo ma aza ɗa a ka wura yaa,
\q2 aza ɗa a ka gono a asu u kuvon.
\q1 
\v 9 I tsu loko ta̱ aka a ama va̱
\q2 a wuta̱ a a'uwa a shinga a le.
\q1 I takpa kpam una̱ u shinga u va̱
\q2 a asu u mmuku n le ubana.
\q1 
\v 10 'Ya̱nga̱i, i laza!
\q2 Asu u na vi asu u uwunvuga u ɗe ɗa wa,
\q1 kpaci a zuwa ɗe asu vi u wokoi na̱ nshinda̱,
\q2 i nangasai u ɗa gba̱ gba̱.
\q1 
\v 11 Uza u kaɓan n uyinsa̱ u tuwa̱ baci u danai,
\q2 <Ma yan ta̱ kuɓari a kaci ka mini ma cinwi
\q2 n ili i'ya ya zuwa ugutukpa ushani,>
\q2 icun i uza u kuɓari u ɗa ama a ka ciga ɗa la vi!>>
\s1 Kazuwamgbani ka uzuwa uma
\q1 
\v 12 Magono ma Zuba ma danai,
\q2 <<Mayun ma ɓolomgbono ɗa̱ ta̱ gba̱ ɗe,
\q2 mmuku n tsikaya n Yakubu;
\q2 ma ɓolomgbono ta̱ aza ɗa a buwai a Isara'ila.
\q1 Ma ɓolomgbono le ta̱ asu u te
\q2 yavu ncon a asu u ɗa a kanzai,
\q2 yavu ushiga u ncon a asu u kalina;
\q2 a woko kaɓolo ka pige ka ama.
\q1 
\v 13 Uza ɗa wa ɗapa kafon a kasaga, aya wa tono ta̱ n ele;
\q2 a ka ɓa̱tsa̱ ta̱ a utsutsu a laza.
\q1 Magono ma le ma uwa ta̱ a kapala ka le,
\q2 Magono ma Zuba ma ma tono n ele n kaci ka ne.>>
\c 3
\s1 Azapige a cingi n atsumate a kaɓan
\q1 
\v 1 Aku n danai,
\q2 <<Eɗa̱ azapige a mmuku n tsikaya n Yakubu, panai na,
\q2 aza ɗa ya lya tsugono tsu Isara'ila.
\q1 U gan ta̱ i reve n afada a a'a̱ri dere,
\q2 
\v 2-3 eɗa̱ aza ɗa ya kovo ili i shinga aku ya ciga ukuna u cingi.
\q1 Ya muna ukpan u ikyamba u ama a va̱
\q2 n i kiɗa̱si inyama i ikyamba i le asuvu atele a le.
\q1 I koɗomgbonusoi kpam atele a le yuku-yuku,
\q2 i kiɗa̱sa i'ya yavu inyama aku i tsungu i'ya a magbodo
\q2 i takuma inyama i ama a va̱.
\q1 
\v 4 Pini nala ya sa̱ka̱ ta̱ Magono ma Zuba tsa̱ra̱ u ɓa̱nga̱ ɗa̱,
\q2 shegai wa wushunku ɗa̱ wa.
\q1 A'ayin a nala ɗa wa sokongu upetiwa'eshi a ne a asu ɗe
\q2 adama ukuna u cingi u ɗa i yain.>>
\b
\q1 
\v 5 Ili i'ya Magono ma Zuba ma danai i'ya na:
\q1 <<A kaci ka ntsumate
\q2 n ɗa ma puwusa̱n ama a va̱,
\q1 a tsu 'ya̱nga̱sa̱ ta̱ ala̱ga̱tsu a le a dansa <Ukuna u ndishi n shinga,>
\q2 a'a̱ baci n ilikulya i'ya a ka lya.
\q1 Shegai a tsu foɓuso ta̱ kuvon
\q2 a asu a aza ɗa bawu a na̱ka̱ le ili i roku.
\q1 
\v 6 Adama a nala, kayin ka tuwa̱ ɗa̱ ta̱, bawu kuwene,
\q2 n karimbi ka aza a ukonduso bawu a ka wene ili.
\q1 Eɗa̱ ntsumate, a'ayin a ɗe a ka kotsu ta̱ kpaci kaara ka rukpa̱ ɗa̱ ta̱,
\q2 kaara ka woko ɗa̱ ta̱ karimbi cika.
\q1 
\v 7 Aza a kuwene a ka yan ta̱ uwono
\q2 n aza a ukonduso a ka pana ta̱ uwono.
\q1 A ka kimba̱ ta̱ upetiwa'eshi a le
\q2 kpaci Kashila̱ ka wushunku le wa.>>
\q1 
\v 8 Shegai mpa, n ma̱ ta̱ ushaɗangi n ucira,
\q2 n Kulu ku Magono ma Zuba,
\q2 u yain afada a maci n ucira.
\q1 Ma tonuko ta̱ mmuku n tsikaya n Yakubu unyushi u cingi u le,
\q2 aza a Isara'ila kpam unyushi u le.
\b
\q1 
\v 9 Panai na, eɗa̱ azapige a mmuku n tsikaya n Yakubu,
\q2 eɗa̱ aza ɗa ya lya tsugono tsu Isara'ila,
\q1 aza ɗa i ꞌyuwain afada a maci
\q2 i gonukoi ili i'ya i'a̱ri dere i wokoi i cingi.
\q1 
\v 10 I yain uboku n mawunuka i tsa̱ra̱i ikebe i i'ya i mai Sihiyona,
\q2 i mai kpam Urishelima n ukuna u cingi.
\q1 
\v 11 Eɗa̱ azapige a Urishelima i tsu wusha ta̱ ukimba̱ u una̱ adama a afada.
\q2 Eɗa̱ aɗara̱kpi ya wenishike mele ma Kashila̱ adama u zami ikebe,
\q1 eɗa̱ kpam ntsumate ya konduso ili i'ya ya tuwa̱ ya gita̱ adama ikebe.
\q2 Gba̱ n nala i pityanangi n Magono ma Zuba wa, i danai,
\q1 <<Mada̱ka̱ ma tuwa̱ a asu tsunu wa
\q2 kpaci Magono ma Zuba ma̱ ta̱ kaɓolo n a̱tsu.>>
\q1 
\v 12 Adama a nala
\q2 a ka lima ta̱ Sihiyona u woko kashina adama a ɗe,
\q1 Urishelima wa woko ta̱ akpongo,
\q2 masasa ma Kuwa ku Kashila̱ ka̱ri ma woko ta̱ kutsu.\f + \fr 3:12 \ft Kondo: \xt Iri 26:18\xt*\f*
\c 4
\s1 Masasa ma Magono ma Zuba
\r (Isha 2:2-4)
\q1 
\v 1 A a'ayin a ɗa a ka tuwa̱
\q2 masasa ma Kuwa ku Kashila̱ ku Magono ma Zuba
\q2 ma woko ta̱ masasa ma ma lai karinga̱;
\q1 a ka ra̱ɗugba̱ ta̱ ma ma lai aga̱la̱la̱.
\q2 Ama a ushani a ka ta̱sa̱ ta̱ ubana pini tyoku u aga̱ta̱ a ɗa a ka yene.
\p 
\v 2 Kakuma̱ ka ama ushani a ka tuwa̱ ta̱ a dana,
\q1 <<Tuwa̱i tsu banai a masasa ma Magono ma Zuba,
\q2 ubana a Kuwa ku Kashila̱ ku Yakubu.
\q1 Wa wenishike tsu ta̱ ire i ne,
\q2 tsu wala kpam a ure u ne.>>
\q1 Kpaci mele ma wuta̱ ta̱ a Sihiyona,
\q2 a Urishelima kpam kadyanshi ka
\q2 Magono ma Zuba ka tambura a ubana a asu u ama.
\q1 
\v 3 Wa yanka ta̱ ama ushani afada
\q2 kpam wa tuko ta̱ makorishi ma ibili
\q2 ma uyamba u ucira u ɗa wa̱ri mɓa̱ri.
\q1 A gonuko iburundu i le mberu ma ucimba,
\q2 asovu a le kpam mmuwun ma ugyara nɗanga.
\q1 Uyamba wa doku wa ra̱ɗugba̱ burundu
\q2 u ne a uyamba u roku wa,
\q2 kpam a ka doku a rotsongusu ure u kuvon wa.\f + \fr 4:3 \ft Kondo: \xt Isha 2:4; Juw 3:10\xt*\f*
\q1 
\v 4 Ya dem wa dusuku ta̱ yaa
\q2 u lyai ilimaci i katyaci ka cinwi
\q2 n maɗanga ma kapopi a kuwa ku ne.
\q1 Uza wa̱ la wa giruwusa̱ yi wa,
\q2 kpaci Magono ma Zuba ma Ucira Gba̱ aya u danai nala.
\q1 
\v 5 Ko an u wokoi gba̱ ama
\q2 ya dem wa tono ta̱ ameli a ne;
\q2 shegai a̱tsu tsa tono ta̱ Magono ma Zuba
\q2 Kashila̱ ka tsunu a ubana.
\s1 Magono ma Zuba ma gonuko ta̱ ama a ne a kuwa
\q1 
\v 6 Magono ma Zuba ma danai, <<A kain ka nala ki,
\q2 ma ɓolomgbono ta̱ awunu,
\q1 aza ɗa n bankai tsuwula̱,
\q2 wata, aza ɗa n yain mavura.
\q1 
\v 7 Ma gonuko ta̱ awunu ama va̱ aza ɗa a buwai,
\q2 aza ɗa a lokoi kpam a woko kakuma̱ ka ama ka ucira.
\q1 Magono ma Zuba ma lya ta̱ tsugono
\q2 a kaci ka le a masasa ma Sihiyona
\q2 ili i'ya i bidyai a kain kala ki ubana.
\q1 
\v 8 Avu Urishelima, kunukuzuba ku uza u uwundya ushiga,
\q2 asu u kpawan u aza a Sihiyona,
\q1 asu u ɗe ɗa tsugono tsu cau tsa gono,
\q2 tsugono tsu nala tsi tsu ɗe tsa aza a Urishelima.>>
\b
\q1 
\v 9 Ndya i zuwai gogo-na ya sa̱ cika,
\q2 i'a̱ri n magono wa ɗa?
\q2 Uza u na̱ka̱ adooki u ɗe u kuwa̱ ɗe ɗa?
\q1 Adama a nala ɗa i'a̱ri a asuvu a upana u ikyamba
\q2 yavu uka ɗa wa̱ri asuvu mɓa̱la̱ ma ilimaci.
\q1 
\v 10 Aza a Sihiyona, ikai n ucira,
\q2 yavu uka u ɗa wa̱ri nkuɗi ma ilimaci,
\q1 kpaci gogo-na u ka̱na̱ ta̱ i a̱sa̱ka̱ a ilyuci yi,
\q2 i bana i dusuku a kakura̱.
\q1 Ya bana ta̱ a Babila,
\q2 ɗe ɗa a ka wauwa ɗa̱.
\q1 Ɗe ɗa Magono ma Zuba ma wusa ɗa
\q2 a kukere ku atokulalu a ɗe.
\b
\q1 
\v 11 Shegai gogo-na uyamba ushani
\q2 a ɓolomgbono ɗe a ka yan tsilala n a̱ɗa̱.
\q1 A dana, <<U ka̱na̱ ta̱ Urishelima u woko n nshinda̱!
\q2 A̱sa̱ka̱ tsu wene uwono u ilyuci yi.>>
\q1 
\v 12 Shegai a reve
\q2 uyanwusa u Magono ma Zuba n afoɓi a ne wa,
\q1 kpaci u ɓolomgbono le ta̱ yavu ndolu ma ilya,
\q2 ilya i'ya a bankai asu u ulapa u ilya.
\q1 
\v 13 Magono ma Zuba ma danai,
\q2 <<'Ya̱nga̱i i kpatsa uyamba, aza a Sihiyona!
\q2 Kpaci ma na̱ka̱ ɗa̱ ta̱ avana a urim,
\q1 a'ene a ɗe kpam a urim u shili,
\q2 adama ɗa i kpatsa uyamba ushani yuku-yuku.
\q1 Pini nala utsa̱ri u le u ɗa a bokoi
\q2 ya neke ta̱ u ɗa gba̱ a asu u Magono ma Zuba,
\q2 udukuyan u le kpam asu u Uzapige u likimba gba̱.>>
\c 5
\q1 
\v 1 Ɓolomgbono asoje a vunu, ilyuci i asoje,
\q2 kpaci a kyawan tsu ɗe n kuvon.
\q1 A ka lapa ta̱ tsugono tsa aza a Isara'ila
\q2 a kagbaguzu ka a ka lapa yi n kalangu.
\s1 Kashila̱ ka yain kazuwamgbani a kaci ka magono ma ma wuta̱ a Batalami
\b
\q1 
\v 2 Magono ma Zuba ma danai, <<Batalami Efurata,
\q2 avu ilyuci i kenu i'ya a asuvu a kumaci ku Yahuda.
\q1 Ma ɗanga̱sa ta̱ uza u te
\q2 a asuvu a ama a vunu u lyai tsugono tsu Isara'ila,
\q2 uza ɗa kagali ka ne ka̱ri tun caupa.>>\f + \fr 5:2 \ft Kondo: \xt Mat 2:6; Yah 7:42\xt*\f*
\b
\q1 
\v 3 Adama a nala, Magono ma Zuba ma neke ta̱
\q2 aza a Isara'ila a asu u atokulalu a le,
\q1 hal she a'ayin a ɗa uka ɗa wa̱ri
\q2 asuvu nkuɗi ma ilimaci u matsai maku ma vali.
\q1 Aku atoku a ne aza ɗa a buwai
\q2 a ka gono a asu u aza a Isara'ila.
\b
\q1 
\v 4 Wa shamgba ta̱ ulina̱ka ushiga u ne,
\q2 n ucira n kala ka tsupige ka
\q2 Magono ma Zuba Kashila̱ ka ne.
\q1 Ama a ne a ka rongo ta̱ mai,
\q2 kpaci ureve u tsupige tsu ne wa rawa ta̱
\q2 hal a makorishi ma likimba.
\b
\q1 
\v 5 Wa zuwa ta̱ tsu tsa̱ra̱ ndishi n shinga,
\q2 a'ayin a ɗa baci aza a Asiriya a uwai asuvu
\q2 a uyamba u tsunu n kuvon,
\q2 a ka wala ta̱ asu u ukpawan u asaga a pige.
\q1 Tsa ɗanga̱sa ta̱ azapige a asoje ama shindere
\q2 hal gba̱m kulla̱ a yain tsilala n ele.
\q1 
\v 6 A ka lya ta̱ tsugono tsu Asiriya n burundu,
\q2 uyamba u Nimurodu kpam n iburundu i le ufoɓusi.
\q1 Wa wauwa tsu ta̱ a asu u aza a Asiriya
\q2 a'ayin a ɗa baci a pasai karen ka tsunu
\q2 a tukoi uyamba u tsunu kuvon\f + \fr 5:6 \ft Kondo: \xt Kag 10:8-11\xt*\f*.
\b
\q1 
\v 7 Pini nala ama a Yakubu a ɗa buwai
\q2 a ka dusuku ta̱ asuvu a kakuma̱ ka ama
\q1 yavu cinza tsa tsu wuta̱i a asu u Magono ma Zuba
\q2 yavu mini ma zuba ma ma rukpusa̱ a mete,
\q1 ma bawu ma vana uza
\q2 ko kpam u pityanangu n vuma.
\q1 
\v 8 Ama a Yakubu a ɗa buwai a ka dusuku ta̱ a asuvu a kakuma̱ ka ama,
\q2 a mere ma ama ushani
\q1 a ka woko ta̱ n ucira yavu gabako a mere ma nnama a kutsu,
\q2 yavu gabako asuvu a ishiga i nlala,
\q1 a'ayin a ɗa baci u raɗugi u uwai a mere ma le
\q2 uza wa̱ la wa wauwa le wa.
\q1 
\v 9 A ka 'ya̱nga̱sa̱ ta̱ akere a ɗe a kaci ka atokulalu a ɗe.
\q2 kpam atokulalu a ɗe a ka wacinsa le ta̱.
\b
\q1 
\v 10 Magono ma Zuba ma danai, <<A kain ka nala ki,
\q1 ma wacinsa ta̱ adoki a ɗe
\q2 n nangasa kpam nringongo ma adoki a ɗe.
\q1 
\v 11 Ma wacinsa ta̱ ilyuci i uyamba u ɗe,
\q2 n wa̱sa̱sa̱ asaga ɗa a'a̱ri ukyawin n ilyuci i ɗe.
\q1 
\v 12 Ma tuko ta̱ makorishi ma aza a ada̱bu a uyamba u ɗe,
\q2 ya doku ya tsa̱ra̱ aza a ukonduso wa.
\q1 
\v 13 Ma wacinsa ta̱ ameli a ɗe
\q2 n atali a ulyasa̱ka ameli kayala a ɗe.
\q1 Ya doku ya kuɗa̱nku
\q2 ili i'ya i yain n akere a ɗe i lyaka le kayala wa.
\q1 
\v 14 Ma muɗusa̱ ta̱ ashamkpatsu a ameli a Ashera asuvu a ɗe,
\q2 n wacinsa kpam ilyuci i ɗe.
\q1 
\v 15 Ma yan ta̱ katsupi ka va̱ n asuvu a shen n upan
\q2 a asu u kakuma̱ ka ama a ɗa gba̱ a tsu ꞌyuwain ugorimuko mu.>>
\c 6
\s1 Magono ma Zuba ma sapulai aza a Isara'ila
\p 
\v 1 Aza a Isara'ila, panai ili i'ya Magono ma Zuba ma danai:
\q1 <<'Ya̱nga̱i, i dana usapula ɗe
\q2 a kapala ka nsasa,
\q2 a̱sa̱ka̱ aga̱la̱la̱ a pana ala̱ga̱tsu a ɗe.
\q1 
\v 2 Nsasa, panai usapula u Magono ma Zuba a kaci ka Isara'ila;
\q2 zuwai atsuvu i pana, eɗa̱ kami ka likimba tun caupa.
\q1 Panai! Kpaci Magono ma Zuba ma sapulai ama a ne,
\q2 wa̱ ta̱ n kadyanshi n Isara'ila.
\b
\q1 
\v 3 <<Ama a va̱, ndya n yanka ɗa̱?
\q2 Niɗa n wokoi kala̱nda̱m a asu u ɗe? Tonuko na̱ mu!
\q1 
\v 4 N wutukpa̱ ɗa̱ a uyamba u Masar
\q2 a asuvu a tsugbashi, n wusa ɗa̱ kpam.
\q1 N suki Musa utuwa̱ u toni n a̱ɗa̱,
\q2 hal n Haruna n Mariya.\f + \fr 6:4 \ft Kondo: \xt Uwt 12:50-51; Uwt 4:14-16; Uwt 15:20\xt*\f*
\q1 
\v 5 Ama a va̱, ciɓai
\q2 ili i'ya Balaku magono ma Muwabu ma foɓusoi ma yain,
\q2 ciɓai kpam ili i'ya Bala'am kalobo ka Beyo u wushunki yi.
\q1 Ciɓai na̱ nwalu n ɗe a Shitim ubana a Giligal,
\q2 adama i reve manyan ma maci ma Magono ma Zuba.>>\f + \fr 6:5 \ft Kondo: \xt Mkc 22:2--24:25; Jos 3:1--4:19\xt*\f*
\s1 Ili i i'ya Magono ma Zuba ma ciga
\q1 
\v 6 Ndya ma tuwa̱ n i'ya a kapala ka Magono ma Zuba
\q2 n kuɗa̱ngu n lyai kayala a kapala ka Kashila̱ ka zuba?
\q1 N tuwa̱ a kapala ka ne n uɗara̱kpa u urunukpa
\q2 na̱ ndyondyom ka kayen ka te ɗa?
\q1 
\v 7 Magono ma Zuba ma pana kayanyan ka a'ondom azu azu,
\q2 n ayenete a manivi ma zayitum azu kupa (10,000)?
\q1 N yain uɗara̱kpa n maku ma kagita̱ ma va̱ adama a unyushi u va̱,
\q2 mmuku n va̱ kpam adama a unyushi u cingi u va̱?
\q1 
\v 8 Nala wa, vuma, Magono ma Zuba
\q2 ma wenike vu ɗe ili i'ya i'a̱ri i shinga,
\q2 Ili i'ya va yan i'ya na:
\q1 Vu yain afada a maci n uciga u wenike asuvayali,
\q2 vu vakunku kpam kaci ka vunu a asu u tono Kashila̱ ka vunu.
\q1 
\v 9 Zuwai atsuvu i pana, Magono ma Zuba
\q2 ma isa̱ ama i ilyuci i Urishelima.
\q2 Kakiri ka, a pana uwonvo u Magono ma Zuba.
\q1 Magono ma Zuba ma danai,
\q2 <<Kakuma̱ ka ama n aza a ɗa a ɓolomgbonoi a ilyuci,
\q2 zuwai atsuvu i pana!
\q1 
\v 10 Ama a cingi, hal ma a̱sa̱nsa̱ n udukuyan u ɗa i tsa̱ra̱i a ure u cingi?
\q2 Ko ma a̱sa̱nsa̱ n kakundatsu ka i doi ka n kovoi?
\q1 
\v 11 Shegai mpa, Magono ma Zuba, ma kpa̱ɗa̱ ɗa̱ uyan mavura wa
\q2 adama kakundatsu ka kaɓan n maryafuka.
\q1 
\v 12 Aza a utsa̱ri a ɗe a tsu 'yankusu ta̱ ama;
\q2 ama a ɗe a ɗa a'a̱ri na̱ ndishi ɗe a tsu yansa kaɓan,
\q2 n una̱ u le ɗa a tsu yinsa̱ ama.
\q1 
\v 13 Adama a nala ma lapa ɗa̱ ta̱ na̱ mɓa̱la̱,
\q2 n wacinsa ɗa̱ adama a unyushi u cingi u ɗe.
\q1 
\v 14 Ya lya ta̱ ilikulya shegai ya ciwa̱ wa,
\q2 katsuma̱ ka ɗe ka rongo ta̱ n kambulu.
\q1 Ya ɓolomgbono ta̱ ucanga u ɗe, shegai ko ili ya zuwa wa,
\q2 i'ya kpam i zuwai kenu ma wacinsa ta̱ i'ya a asu u kuvon.
\q1 
\v 15 Ya ce ta̱, shegai ko ili ya kapa wa.
\q2 Ya pisha ta̱ ilimaci i zayitum shegai ya yan manyan n manivi ma ne wa.
\q2 Ya pisha ta̱ ilimaci i cinwi, shegai ya so mini ma cinwi mi wa.
\q1 
\v 16 Kpaci i tono ta̱ mele ma cingi ma Omiri,
\q2 n gba̱ manyan ma kuwa ku Ahabu;\f + \fr 6:16 \ft Kondo: \xt 1 Ngo 16:25-28; 1 Ngo 16:29-34; 1 Ngo 21:25-26\xt*\f*
\q2 i tonoi afoɓi a cingi a le.
\q1 Adama a nala ma gonuko ɗa̱ ta̱ akpongo
\q2 aza ɗa a'a̱ri ndishi ɗe a ka woko ta̱ ili i magori.
\q2 Nala ya woko, eɗa̱ ama a va̱, ko n te wa a ka goro ɗa̱ ta̱.>>
\c 7
\s1 Vanai Kashila̱ ka iwauwi
\q1 
\v 1 Ter va̱! Kpaci n woko ɗe
\q2 yavu uza ɗa wa pana kambulu,
\q1 uza ɗa bawu u tsa̱ra̱i ili an u ɓolomgbonoi ilimaci i kashina.
\q2 An a 'yarai kashina ka cinwi,
\q1 ilimaci i cinwi i'a̱ la i'ya ka kasa a lyai wa,
\q2 kpam bawu ilimaci i kapopi i gewi
\q2 i'ya ma ciga.
\q1 
\v 2 Ama a maci a kotsu ɗe a uyamba vi;
\q2 aza a ukuna u mayun a buwa wa.
\q1 Ya dem wa putsa̱ utoku u ne tsa̱ra̱ u wuna,
\q2 ya dem u wanda̱ga ta̱ utoku u ne utyangi.
\q1 
\v 3 Ya dem wa̱ ta̱ n ureve a asu u uyan ukuna u cingi n akere a ne,
\q2 azapige a ka ciga a na̱ka̱ le kune,
\q1 aza a afada kpam a ka wusha ukimba̱ u una̱,
\q2 uzapige u tsu zuwa ta̱ a yain ili i cingi i'ya katakasuvu ka ne ka ciga,
\q2 nala a tsu kpatala̱sa ukuna u mayun.
\q1 
\v 4 Vuma ɗa lai uyansa ili i shinga a asuvu a ɗe,
\q2 wa̱ ta̱ yavu maɗanga ma kaworo,
\q1 vuma ɗa lai u ukuna u maci asuvu a le
\q2 wa̱ ta̱ yavu maɗanga ma kawana.
\q1 Kain ka mavura ma ɗe ka tuwa̱ ɗe
\q2 kain ka a ka ɓara ɗa̱ a una̱ u ntsumate,
\q2 gogo-na ɗa ya dem wa la̱pa̱na̱.
\q1 
\v 5 Kotsu i pityanangu n aza a karen a ɗe wa,
\q2 kotsu i wushuku n aje a ɗe wa.
\q1 Ko aka a ɗe a ɗa ya ciga,
\q2 i kirana n kadyanshi ka una̱ u ɗe.
\q1 
\v 6 Kpaci maku ma vali u tsu goro ta̱ tata u ne,
\q2 maku ma uka kpam u tsu 'ya̱nga̱sa̱ka̱ ta̱ mma u ne,
\q1 kajene n anuku a ne kpam u tsu yan ta̱ tsilala.
\q2 Atokulalu a vuma, a'a̱ ta̱ a kuwa ku te.\f + \fr 7:6 \ft Kondo: \xt Mat 10:35-36; Luk 12:53\xt*\f*
\q1 
\v 7 Shegai mpa, ma zuwa ta̱ a'eshi
\q2 a asu u Magono ma Zuba u ɓa̱nga̱ mu,
\q1 ma vana ta̱ Kashila̱ ka iwauwi ka va̱;
\q2 Kashila̱ ka va̱ wa pana̱ka mu ta̱.
\b
\q1 
\v 8 Atokulalu a va̱, kotsu i yain maza̱nga̱ a kaci ka va̱ wa!
\q2 Ko n rukpa̱i baci, ma 'ya̱nga̱ ta̱.
\q1 Ko n dusuku baci a karimbi,
\q2 Magono ma Zuba ma woko ta̱ katyashi ka va̱.
\q1 
\v 9 N yan ta̱ unyushi u cingi a asu u Magono ma Zuba
\q2 adama a nala ma kawunku ta̱ adama upan u ne,
\q1 shegai a makorishi wa shamkpa mu ta̱,
\q2 kpaci u pana ta̱ usapula u va̱, u yanka mu afada ɗa a'a̱ri dere.
\q1 Wa tuko mu ta̱ a asu u katyashi,
\q2 n wene ukuna u maci u ne.
\q1 
\v 10 Pini nala ɗa atokulalu a va̱ a ka wene,
\q2 aku uwono u kimba̱ aza ɗa a tonuko mu,
\q2 <<Nte Magono ma Zuba Kashila̱ ka vunu?>>
\q1 A'eshi a va̱ a ka wene ta̱ urukpa̱ u le,
\q2 gogo-na a ka kpatsa le ta̱ yavu cin a ure.
\b
\q1 
\v 11 Kain ka a ka lapula a mai asaga a ɗe ka tuwa̱ ta̱,
\q2 kain ka a ka doku upeti u karen u ɗe.
\q1 
\v 12 A kain ka nala ki, ama ushani a ka tuwa̱ ta̱ a asu u ɗe,
\q2 a wuta̱ a Asiriya n ilyuci i Masar,
\q1 hal gba̱m ili i'ya bidyai a Masar hal Aga̱ta̱ a Yufiriti,
\q2 n mala ubana a mala
\q2 n masasa ubana a masasa.
\q1 
\v 13 Likimba wa woko ta̱ akpongo
\q2 adama tsicingi tsa aza a ɗa dusuki pini a yansai.
\s1 Kavasu ka Mika ubana ara Magono ma Zuba
\q1 
\v 14 Magono ma Zuba, kirana n ama a vunu
\q2 tyoku ɗa kaliniki ka tsu yan n kalangu ka ne,
\q1 ushiga u nlala u agadu u vunu,
\q2 u ɗa wa̱ri ndishi utyoku u ne
\q2 a kutsu ka ka̱ri n asu u kalina u tsishinda̱.
\q1 A̱sa̱ka̱ a wuta̱ a lina a kaɓon ka Bashan n kaɓon ka Giliyadu
\q2 yavu a'ayin a cau.
\b
\q1 
\v 15 Magono ma Zuba ma danai,
\q2 <<Ma yanka ɗa̱ ta̱ manyan ma ikunesavu
\q2 tyoku ɗa n yain an n wutukpa̱ ɗa̱ a asu u tsugbashi a Masar.>>
\b
\q1 
\v 16 Kakuma̱ ka ama a ka wene ta̱ kpam a pana uwono
\q2 ko an u wokoi a'a̱ri n ucira.
\q1 A ka kimba̱ ta̱ una̱ u le a paɗa bini
\q2 a woko kpam yavu agulani.
\q1 
\v 17 A ka woko ta̱ yavu ili i'ya ya ka̱bura̱ a iyamba,
\q2 a ka lya ta̱ kabuta̱ yavu a'ali.
\q1 A ka wuta̱ ta̱ n a jeki ikyamba,
\q2 a asu u ukpawunsa u le.
\q1 A ka giruwa̱ ta̱ a kapala ka vunu
\q2 Magono ma Zuba Kashila̱ ka tsunu;
\q2 a ka pana vu ta̱ uwonvo.
\s1 Vuma wa̱ la tyoku u Kashila̱ wa
\q1 
\v 18 Kashila̱ ka roku ka̱ la tyoku u vunu wa,
\q2 uza ɗa u tsu cimbusa̱ unyushi u cingi n unyushi u ama a ne
\q2 a ɗa a buwai a aza a agadu a vunu.
\q1 Vu tsu ka̱na̱ upan u vunu hal ubana wa,
\q2 kpaci vu tsu pana ta̱ kayanyan ka uwenike
\q2 uciga u vunu u ɗa bawu wa savaɗa.
\q1 
\v 19 Va doku ta̱ va wenike tsu asuvayali a vunu.
\q2 Va lya ta̱ kaci ka unyushi u tsunu
\q2 vu vuta̱la̱ kpam unyushi u cingi u tsunu a mala ma ma̱ri lyungu-lyungu.
\q1 
\v 20 Va wenike ta̱ ukuna u mayun u vunu
\q2 n uciga u vunu u ɗa bawu wa savaɗa,
\q2 a asu u mmuku n tsikaya ma Ibirahi n Yakubu
\q1 tyoku ɗa vu yain kazuwamgbani n ikaya i tsunu a'ayin a cau.
