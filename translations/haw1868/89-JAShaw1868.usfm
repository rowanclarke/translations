\id JAS
\h Iakobo
\toc1 Iakobo
\toc2 Iakobo
\toc3 Iakobo
\mt1 Iakobo
\c 1
\s1 O KA EPISETOLE
\q1 
\v 1 NA lakobo, he kauwa na ke Akua, a me ka Haku o Iesu Kristo, i ka poe ohana he umi a me kumamalua i hoopuehuia, Aloha oukou.
\b
\q1 
\v 2 E na hoahanau o'u, e manao oukou, he mea olioli wale no, ke loohia oukou e kela mea keia mea e hoao mai ai;
\q1 
\v 3 Ua ike no hoi oukou, o ka hoao ana mai i ko oukou manaoio, oia ka mea e mahuahua'i ke ahonui.
\q1 
\v 4 E hoomau oukou ma ka mea ku pono i ke ahonui, i lako oukou, a i hemolele hoi, aole wahi hemahema iki.
\b
\q1 
\v 5 Ina i nele kekahi o oukou i ke akamai, e noi aku oia i ke Akua i ka mea i haawi lokomaikai mai no na mea a pau me ka hoino ole mai, a e haawiia mai no ia nona.
\q1 
\v 6 Aka, e noi aku oia me ka manaoio, aole me ke kanalua; no ka mea, o ka mea e kanalua ana, ua like no ia me ka ale o ke kai i puhiia e ka makani a kupikipikio.
\q1 
\v 7 Mai manao ia kanaka, e loaa mai ia ia kekahi mea na ka Haku mai.
\q1 
\v 8 O ke kanaka i lolelua ka naau, ua lauwili oia i kona mau aoao a pau.
\b
\q1 
\v 9 O ka hoahanau haahaa, e hauoli ia i kona hookiekieia.
\q1 
\v 10 A o ka mea waiwai hoi, i kona hoohaahaaia; no ka mea, e like me ka pua o ka nahelehele e mae wale ana ia.
\q1 
\v 11 No ka mea, i ke kau ana mai o ka la me ka wela nui, aole emo a hoomaloo iho la no ia i ka nahelehele, a haule iho la kona pua, a pau ae la ka nani o kona ano: pela no e mae ai ka mea waiwai i kona aoao iho.
\b
\q1 
\v 12 Pomaikai wale ke kanaka, ke ku paa ia i ka hoowalewaleia mai; no ka mea, a pau kona hoaoia mai, e loaa auanei ia ia ka lei o ke ola i oleloia mai ai e ka Haku no ka poe e aloha aku ana ia ia.
\q1 
\v 13 A o ka mea i hoowalewaleia mai, mai olelo ae ia, ua hoowalewaleia mai au e ke Akua; no ka mea, aole i hoowalewaleia ke Akua e ka hewa, aole loa hoi oia i hoowalewale mai i kekahi.
\q1 
\v 14 Aka, ua hoowalewaleia kela mea keia mea ma kona kuko iho no, i ke alakaiia'ku a puni ia.
\q1 
\v 15 Aia hapai ke kuko, alaila, hanau mai ka hewa; a oo ka hewa, alaila, hoopukaia mai ka make.
\q1 
\v 16 Mai kuhihewa, e o'u poe hoahanau aloha:
\q1 
\v 17 O na haawina maikai a pau a me na makana hemolele a pau, noluna mai ia i iho mai ai no ka Makua mai o ka malamalama, aole ona ano hou, aole loa ia e luli iki.
\q1 
\v 18 No kona makemake iho i hoohanau mai ai oia ia kakou ma ka olelo oiaio, i lilo ae kakou i mau hua mua o ka poe ana i hana'i.
\b
\q1 
\v 19 No ia mea, e o'u poe hoahanau aloha, e hiki wawe oukou ma ka lohe, e akahele hoi ma ka olelo ana aku, a e hoolohi hoi ma ka inaina aku:
\q1 
\v 20 No ka mea, o ka inaina o ke kanaka, aole ia e hana ana i ka pono o ke Akua.
\q1 
\v 21 No ia mea la, e pale aku oukou i ka haumia a pau, a me ka hu wale ana o ka ino, a e apo mai oukou me ke akahai i ka olelo i pakuiia, oia ka mea e hiki ai ke hoola i ko oukou poe uhane.
\q1 
\v 22 E lilo hoi oukou i poe malama i ka olelo, aole i poe lohe wale no, e hoopunipuni ana ia oukou iho:
\q1 
\v 23 No ka mea, ina i lohe wale kekahi i ka olelo, aole oia i malama aku, ua like no ia me ke kanaka e nana ana i kona helehelena iho ma ke aniani;
\q1 
\v 24 Nana no oia ia ia iho, a i ka hoi ana'ku, poina koke iho no ia i kona ano iho.
\q1 
\v 25 O ka mea e nana ae i ke kanawai hemolele o ke ola, a e ku paa malaila, aole e hoopoina wale i kana mea i lohe ai, aka, ua malama no ia i ka oihana; oia ka mea e pomaikai aua i kana hana ana.
\q1 
\v 26 Ina i manaoia kekahi he haipule ia, aole hoi oia e kaulawaha i kona alelo, aka, e hoopunipuni i kona naau iho, ua lapuwale kona haipule ana.
\q1 
\v 27 O ka haipule io a me ka haumia ole imua i ke alo o ke Akua o ka Makua, eia no ia; e ike i ka poe makua ole, a me ka poe wahinekanemake i ko lakou wa e pihkia ai, a e malama hoi ia ia iho i haumia ole ia i ko ke ao nei.
\c 2
\b
\q1 
\v 1 E NA hoahanau o'u, i ko oukou manaoio ana ia Iesu Kristo i ko kakou Haku nani, mai manao aku ma ko ke kanaka helehelena.
\q1 
\v 2 No ka mea, ina e komo kekahi kanaka iloko o ko oukou halehalawai me ke komolima gula, a nani hoi kona kapa, a komo mai no hoi kekahi mea ilihune, inoino hoi kona kapa;
\q1 
\v 3 A manao aku oukou ma ka mea i kahiko i ke kapa nani, a e olelo ae oukou, Maanei oe e noho ai ma kahi maikai; a e olelo aku hoi i ka mea ilihune, E ku oe malaila, a e noho paha oe maanei ma kuu paepae wawae;
\q1 
\v 4 Aole anei oukou i lilo i poe paewaewa aku, e manao hewa wale aku ana?
\q1 
\v 5 E hoolohe oukou, e na hoahanau aloha o'u, aole anei ke Akua i wae ae i ka poe ilihune o ke ao nei e lako i ka manaoio, a e lilo i poe hooilina o ke aupuni ana i olelo mai ai i ka poe e aloha aku ana ia ia?
\q1 
\v 6 Aka, ua hoowahawaha oukou i ka poe ilihune. Aole anei i hooluhi mai ka poe waiwai ia oukou, a i alakai hoi ia oukou ma kahi e hookolokolo ai?
\q1 
\v 7 Aole anei lakou i hoino i kela inoa maikai i kapaia aku ai oukou?
\q1 
\v 8 Ina oukou e malama i ke kanawai hemolele me ia ma ka palapala, E aloha aku oe i kou hoalauna e like me oe iho, ina ua pono ka oukou hana ana;
\q1 
\v 9 Aka, ina e manao oukou ma ko ka helehelena, ua hana hewa oukou, a ua hoohewaia oukou e ke kanawai he poe lawehala.
\q1 
\v 10 O ka mea malama i ke kanawai a pau, a i haule nae ia ma ka mea hookahi, ua hewa no ia i ke kanawai a pau.
\q1 
\v 11 No ka mea, o ka mea nana i kauoha mai, Mai moe kolohe oe, kauoha mai la no hoi, Mai pepehi kanaka oe. Ano, ina aole oe i moe kolohe aku, aka, ua pepehi i ke kanaka, ua lilo oe i mea haihai i ke kanawai.
\q1 
\v 12 E olelo aku oukou, a e hana aku hoi, e like me ka poe e hookolokoloia ana ma ke kanawai o ke ola.
\q1 
\v 13 O ka mea i hana me ke aloha ole aku, e hoahewaia auanei oia me ke aloha ole ia mai; aole makau ka lokomaikai i ka hoohewaia.
\b
\q1 
\v 14 E na hoahanau o'u, heaha ka waiwai, ke olelo kekahi, he manaoio kona, aole hoi ana hana? E hiki anei i ka manaoio ke hoola ia ia?
\q1 
\v 15 Ina he kapa ole ko ke kaikaina paha, ke kaikuwahine paha, a i nele hoi i ka ai i kela la i keia la;
\q1 
\v 16 A i i aku kekahi o oukou ia laua, O hele olua me ka pomaikai, a e hoopumahanaia, a e maona no hoi; aole nae oukou e haawi io aku ia laua i ka mea e pono ai ke kino; heaha la ka waiwai?
\q1 
\v 17 Pela no hoi ka manaoio, ina oia wale no aole ana hana, ua make ia.
\q1 
\v 18 A e i mai kekahi, O ka manaoio kou, a na'u hoi ka hana ana; e hoike mai oe ia'u i kou manaoio me kau hana ole, a ma ka'u hana ana e hoike aku ai au ia oe i kuu manaoio.
\q1 
\v 19 Ke manaoio nei oe, aia hookahi Akua; ua pono oe: pela no ka poe daimonio i manaoio ai, me ka haalulu hoi.
\q1 
\v 20 E ke kanaka lapuwale, ke makemake nei anei oe e ike aku, ua make ka manaoio ke ole kana haua ana?
\q1 
\v 21 Aole anei i hoaponoia mai o Aberahama ko kakou kupuna ma ka hana ana, i kona wa i mohai aku ai i kana keiki ia Isaaka maluna o ke kuahu?
\q1 
\v 22 Ke ike nei oe, i hooikaika pu ka manaoio me kana hana ana, a ma ka hana ana i pouo ai ka manaoio.
\q1 
\v 23 A ua hookoia hoi ka palapala, i i mai ai, Ua manaoio Aberahama i ke Akua, a ua hooiliia'e ia i pono nona; a ua kapaia iho la oia he hoaaloha no ke Akua.
\q1 
\v 24 Ke ike ae nei oukou, ua hoaponoia mai no ke kanaka ma na hana, aole ma ka manaoio wale no.
\q1 
\v 25 Aole anei i hoaponoia o Rahaba ka wahine hookamakama ma ka hana ana i ka wa ana i hookipa ai i na elele, a hoouna aku la ma ke ala e?
\q1 
\v 26 Oiaio no, o ke kino uhane ole, ua make no ia, pela hoi ka manaoio hana ole, ua make no ia.
\c 3
\b
\q1 
\v 1 E NA hoahanau o'u, aole make lilo na mea o oukou he nui i poe kumu, o loaa auanei ia kakou ka hoohewa nui ia mai.
\q1 
\v 2 No ka mea, ma na mea he nui ua hewa kakou a pau: i hewa ole kekahi ma kana olelo, oia ke kanaka hemolele, e hiki hoi ia ia ke hoopaa i kona kino iho a pau i ke kaulawaha.
\q1 
\v 3 Aia hoi, ke hookomo nei kakou i na kaulawaha iloko o ka waha o na lio i hoolohe mai lakou ia kakou; hoohuli ae hoi kakou i ko lakou kino a pau.
\q1 
\v 4 Aia hoi, o na moku nui, ua hooholoia ae i na makani ikaika loa, a ua hoohuliia ae hoi e ka hoeuli uuku loa, ma kahi e makemake ai o ke kahu moku.
\q1 
\v 5 Pela hoi, he lala unku ke alelo, a kaena nui ae la ia. Aia hoi, ua hoaaia he puu wahie nui e ka huna ahi!
\q1 
\v 6 He ahi no ke alelo, he ao okoa ia o ka hewa; pela hoi ua kauia ke alelo iwaena o ko kakou mau lala, e hoohaumia ana i ke kino a pau, hoaa ae la ia i ko ke ao nei, a ua hoaaia mai ia e ka luaahi.
\q1 
\v 7 Ua hoolakaia kela a me keia ano o na holoholona hihiu, a me na manu, a me na mea kolo, a me na mea hoi o ke kai, ua hoolakaia mai lakou e kanaka;
\q1 
\v 8 Aka, o ke alelo, aole loa e hiki i ke kanaka ke hoolakalaka ia mea; he mea ino laka ole ia, ua piha i ka mea awahia e make ai.
\q1 
\v 9 Oia ko kakou mea e hoomaikai aku ai i ke Akua i ka Makua; oia hoi ko kakou mea e hoino aku ai i kanaka i hanaia'i ma ke ano o ke Akua.
\q1 
\v 10 Ua puka mai la ka hoomaikai a me ka hoino noloko mai o ka waha hookahi. E na hoahanau o'u, aole loa e pono keia mau mea pela.
\q1 
\v 11 E puapuai mai anei ka wai ono a me ka wai awaawa noloko mai o ka punawai hookahi?
\q1 
\v 12 E na hoahanau o'u, e hiki anei i ka laau fiku ke hua mai i ka hua oliva, a o ke kumu waina hoi i ka fiku? Oiaio hoi, aole e hiki i ka punawai hookahi ke kahe mai i ka wai awaawa a me ka wai ono.
\b
\q1 
\v 13 Owai la ka mea akamai a me ka naauao iwaena o oukou? E hoike mai no ia ma ka noho maikai ana, i kana hana ana me ke akahai o ka naauao.
\q1 
\v 14 Ina ia oukou ka huahuwa ikaika a me ka manao hakaka iloko o ko oukou naau; mai haanui oukou, a wahahee aku i ka oiaio.
\q1 
\v 15 Aole oia ke akamai i iho mai mai luna mai, aka, no ka honua ia, a no ke kino, a no na daimonio hoi.
\q1 
\v 16 No ka mea, ma kahi e huahuwa ai a e hakaka ai hoi, aia malaila ka haunaele a me na hana ino a pau.
\q1 
\v 17 Aka, o ke akamai noluna mai, he maemae no ia mamua, alaila he noho malie, he akahai, he oluolu, he piha hoi i ka lokomaikai a me ka hua maikai, aole loa e manao ino aku, aole hoi he hookamani.
\q1 
\v 18 A o ka hua o ka pono ua luluia me ke kuikahi e ka poe e hana ana ma ke kuikahi.
\c 4
\b
\q1 
\v 1 NOHEA mai la na kaua a me na hakaka ana iwaena o oukou? Aole anei no na kuko o oukou e kaua ana iloko o ko oukou mau lala?
\q1 
\v 2 Ua kuko hoi oukou, aole i loaa; ua huahuwa ae la oukou me ka pepehi aku, aole e hiki ia oukou ke loaa mai; ua hakaka oukou me ke kaua aku, aole nae i loaa, no ko oukou noi ole aku:
\q1 
\v 3 Ke noi nei oukou, me ka loaa ole, no ka mea, ua noi pono ole oukou, i pau ai ia mea ma ko oukou mau kuko.
\q1 
\v 4 E na kane moe kolohe a me na wahine moe kolohe, aole anei oukou i ike, o ka hoolauna ana me ko ke ao nei, he ku e aku ia i ke Akua? O ka mea e makemake e hoolauna pu me ko ke ao nei, ua lilo ia i enemi no ke Akua.
\q1 
\v 5 Ke manao nei anei oukou ua olelo wale mai ka palapala, Ua kuko no ka uhane e noho ana iloko o kakou me ka huahuwa?
\q1 
\v 6 Haawi mai la ia i ka lokomaikai mahuahua ae; no ia hoi, i mai la ia, Ku e aku la ke Akua i ka poe haaheo, a haawi mai la hoi i ka lokomaikai i ka poe hoohaahaa.
\q1 
\v 7 Nolaila, e hoolohe oukou i ke Akua; e pale aku hoi i ka diabolo, alaila e holo aku ia mai o oukou aku.
\q1 
\v 8 E hookokoke aku oukou i ke Akua, a e hookokoke mai kela ia oukou. E ka poe hewa, e hoomaemae i ko oukou mau lima, e huikala hoi i ko oukou mau naau, e ka poe naau lolelua.
\q1 
\v 9 E ehaeha oukou, e u aku hoi me ka uwe; e hoolilo i ko oukou akaaka i uwe ana, a me ko oukou olioli i kaumaha.
\q1 
\v 10 E hoohaahaa oukou ia oukou iho imua o ka Haku, a nana oukou e hookiekie ae.
\b
\q1 
\v 11 E na hoahanau, mai olelo ino oukou i kekahi i kekahi. O ka mea e olelo ino aku no kona hoahanau, me ka hoohewa aku i kona hoahanau, oia ka i olelo ino aku no ke kanawai me ka hoohewa hoi i ke kanawai; ina oe i hoohewa aku i ke kanawai, aole loa oe i malama aku i ke kanawai, aka, ua lilo oe i mea kau kanawai.
\q1 
\v 12 Hookahi no mea nana i haawi i ke kanawai, e hiki no ia ia ke hoola a me ka luku aku hoi. Owai la hoi oe e hoohewa aku nei ia hai?
\b
\q1 
\v 13 E hele oukou, e ka poe e olelo ana, E hele makou i keia la paha, apopo paha i kahi kulanakauhale, a malaila makou e noho ai i hookahi makahiki, a e kuai aku, kuai mai, a e loaa ka waiwai;
\q1 
\v 14 Oiai aole oukou i ike i ka ka la apopo. No ka mea, heaha ko oukou ola? Kainoa he wahi mahu no ia, i pua iki ae, alaila nalo ae la.
\q1 
\v 15 Eia ko oukou pono e olelo ae, Ina e makemake mai ka Haku, alaila o ola makou, a e hana i kela mea, i keia mea.
\q1 
\v 16 Ano la, ua lealea oukou i ko oukou kaena ana; a o ia lealea a pau ua hewa ia.
\q1 
\v 17 Nolaila, o ka mea i ike i ka hana pono, aole nae i hana, he hewa no ia nona.
\c 5
\b
\q1 
\v 1 E HELE oukou, e ka poe waiwai, e uwe oukou me ka aoa aku no na ehaeha e kau mai ana maluna o oukou.
\q1 
\v 2 Ua popopo ko oukou waiwai, ua pau hoi ko oukou kapa aahu i ka mu.
\q1 
\v 3 Ua aiia e ka popo ko oukou gula, a me ko oukou kala; he hoike ka popo o ia mau mea no oukou, a e ai aku i ko oukou io me he ahi la. Ua hoiliili oukou no na la mahope.
\q1 
\v 4 Aia hoi, o ka uku o ka poe hana nana i hoiliili ai ma ka oukou mau mahinaai i paa hewa ia oukou, ke kahea aku nei ia; a o ke kahea ana o ka poe hoiliili, komo ae la ia iloko o na pepeiao o ka Haku Sabaota.
\q1 
\v 5 Ua noho lealea oukou ma ka honua me ke kuulala loa: ua kupalu oukou i ko oukou naau no ka la e make ai.
\q1 
\v 6 Ua hoohewa oukou me ka pepehi aku hoi i ka mea pono; aole oia i pale aku ia oukou.
\b
\q1 
\v 7 I nui ke aho, e na hoahanau, a hiki mai ka Haku. Eia hoi, ke kakali nei ka mahiai i ka hua ohaha o ka honua, e hoomanawanui ana ma ia mea a hiki mai ke kuaua mua a me ke kuaua hope.
\q1 
\v 8 E ahonui no hoi oukou, e hooikaika i ko oukou naau; no ka mea, ua kokoke mai ka hiki ana mai o ka Haku.
\q1 
\v 9 E na hoahanau, mai ohumu aku kekahi i kekahi, o hoohewaia mai oukou. Eia hoi, ke ku mai nei ka lunakanawai ma ka puka.
\q1 
\v 10 E na hoahanau o'u, e hoomanao oukou i ka poe kaula i olelo mai ai ma ka inoa o ka Haku, ia lakou no ka hoomaewaewaia, a me ke ahonui.
\q1 
\v 11 Aia hoi, ke kapa nei kakou i ka poe hoomanawanui, he pomaikai. Ua lohe oukou i ka hoomanawanui ana o Ioba, a ua ike oukou i ka ka Haku hope; ua lokomaikai nui ka Haku me ke aloha mai.
\b
\q1 
\v 12 He oiaio hoi, e na hoahanau o'u, mai hoohiki ino iki, aole i ka lani, aole i ka honua, aole hoi ma na hoohiki e ae: aka, e hoolilo i ko oukou ae i ae io, a me ko oukou hoole, i ole io; o haule oukou i ka hoohewaia mai.
\b
\q1 
\v 13 I ehaeha anei kekahi o oukou? e pule oia; a i hauoli anei kekahi? e himeni aku ia.
\q1 
\v 14 Ina he mai ko kekahi o oukou, e kii aku oia i ka poe lunakahiko o ka ekalesia; a e pule lakou maluna ona, me ka hamo ana ia ia i ka aila ma ka inoa o ka Haku,
\q1 
\v 15 A o ka pule o ka mauaoio, e hoola no ia i ka mea mai, a na ka Haku e hoala mai ia ia; a ina i hana hewa oia, e kalaia mai ia.
\q1 
\v 16 E hai aku i ko oukou mau hewa kekahi i kekahi, a e pule hoi kekahi no kekahi, i pohala ai oukou. O ka pule ikaika a ke kanaka pono e lanakila nui ia.
\q1 
\v 17 He kanaka no o Elia, ua like kona ano me ko kakou, a pule ikaika aku ia, i ua ole mai; aole loa i ua mai ma ka honua i na makahiki ekolu a me na malama keu eono.
\q1 
\v 18 A pule hou aku ia, a haawi mai no ka lani i ka ua, a hooulu mai ka honua i kona hua.
\b
\q1 
\v 19 E na hoahanau, ina e hele hewa kekahi o oukou, mai ka oiaio ae, a e hoohuli mai kekahi ia ia;
\q1 
\v 20 E ike pono oia, o ka mea e hoohuli mai ana i ka mea hewa, mai kona hele hewa ana mai, nana no i hoopakele ae ka uhane i ka make, a nana hoi i hooki i ka hewa he nui loa. 
