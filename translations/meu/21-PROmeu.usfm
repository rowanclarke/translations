\id PRO .01 (MOTU Proverbs: Chapter 1) RTWP 6/'91
\h HEREVA LADA-ISIDIA
\toc1 HEREVA LADA-ISIDIA
\toc2 HEREVA LADA-ISIDIA
\mt1 HEREVA LADA-ISIDIA
\c 1
\p 
\v 1 Solomon, David natuna, Israel pavapavana, ena hereva lada-isidia bini:
\q1 
\v 2 Taunimanima na aonega bona hahediba herevadia
\q2 bona lalo-parara herevadia bae diba totona;
\q1 
\v 3 aonega karadia, kara maoromaoro,
\q2 hahemaoro ḡoevaḡoeva bona ahu korikorina daladia,
\q2 bae hadibadia totona;
\q1 
\v 4 asi aonegadia taudia na bae henahua toho
\q2 bona eregabe taudia na aonega bona karabalaheni bae abi totona.
\q1 
\v 5 Aonega tauna danu baine kamonai, bena ena diba baine habadaia;
\q2 bona lalo-parara tauna na baine ḡaukara mai dibana ida;
\q1 
\v 6 hereva lada-isina bona haheḡereḡere anidia bae diba,
\q2 aonega taudia edia hereva bona edia sivarai hehuni-hehunidia danu.
\b
\q1 
\v 7 Iehova igari-henina na lalo-parara matamana;
\q2 kavakava taudia ese aonega bona hahediba e dadaraimu.
\b
\q1 
\v 8 Natugu e, tamamu ena hahediba ba kamonai,
\q2 bona sinamu ena hahediba herevadia basio dadaraidia;
\q1 
\v 9 badina be idia be kwaramu ihaheralaina heraheradia
\q2 bona aiomu agevana na heheto.
\q1 
\v 10 Natugu e, kara dika taudia ese lalomu bae ania negana ai,
\q2 edia ura basio abia dae.
\q1 
\v 11 Idia na bema toma: Aoma, aitala,
\q2 rara ihahebubuna totona baita bani;
\q2 asi edia kerere taudia na asi badina baita bani henidia;
\q1 
\v 12 mai mauridia ida baita hadonodia, mase gabuna ese bema hadonodia heḡereḡerena;
\q2 baita hadonodia idoi, mase gurina ai e dihomu taudia na heheto;
\q1 
\v 13 bena kohu namo-hereadia iboudiai baita davari,
\q2 dadidadi kohudia amo eda ruma baita hahonu;
\q1 
\v 14 oi na ai ida baita ḡaukara hebou,
\q2 bena iboudai na moni modana tamona baita abia hebou.
\q1 
\v 15 Natugu e, idia ida basio raka hebou edia dala ai,
\q2 aemu na edia dala irakalaina ai ba rudia;
\q1 
\v 16 badina be aedia na kara dika e heau heniamu,
\q2 rara ihahebubuna totona e lao haraḡamu.
\q1 
\v 17 Badina be manu vairadiai
\q2 huo iotona na asi anina;
\q1 
\v 18 to ini taunimanima ese sibodia raradia ihahebubudia totona e banimu,
\q2 sibodia edia mauri e bani henidiamu.
\q1 
\v 19 Daḡedaḡe amo kohu e dadimu taudia iboudiai edia dala be unu heheto;
\q2 unu kara ese edia mauri e abi ohomu.
\b
\q1 
\v 20 Aonega na ariara ai e boi lolomu,
\q2 hoinoi gabudia ai gadona e habadaiamu;
\q1 
\v 21 maḡu latadiai e lolomu,
\q2 hanua ikoukoudia ai e herevamu, e tomu:
\q1 
\v 22 Asi aonegamui taumui e,
\q2 kware-kware ba ura henia ela bona edena nega ai;
\q1 Ḡonaḡona taudia na edia ḡonaḡona bae moalelaia,
\q2 bona kavakava taudia na aonega bae inai henia,
\q2 ela bona edena nega ai?
\q1 
\v 23 Egu sisiba herevadia ba hakala henidia;
\q2 a itaia, egu lalo-hadai na emui ai baina seia dobi;
\q2 egu hereva baina hadibalaimui.
\q1 
\v 24 Badina be lau na boiboi, to umui na asio ura ba kamonai;
\q2 imagu na toia roro, a ta ese se laloa;
\q1 
\v 25 egu hahealo idoinai vada o dadaraia,
\q2 egu sisiba herevadia ta asio abia dae.
\q1 
\v 26 Lau ese danu emui hahehisi baina kirikirilaia,
\q2 gari ese baine butumui tao negana ai baina ḡonaḡonalaimui;
\q1 
\v 27 gari ese baine butumui tao lai gubana na heto,
\q2 bona emui hahehisi ḡaudia bae kau koehirihiri na heto, negadia ai,
\q2 bona lalomui bae hisihisi bona daramui bae doko negadia ai.
\q1 
\v 28 Unu negadia ai bae boi henigu, to basina haere;
\q2 bae tahugu malaka-malaka, to basie davarigu.
\q1 
\v 29 Badina be idia ese aonega e inai heniava,
\q2 bona Iehova igari-henina asie abia hidiva;
\q1 
\v 30 egu hahealo herevadia ta asie abia daeva,
\q2 bona egu sisiba herevadia iboudiai e dadaraidiava;
\q1 
\v 31 taunabunai edia kara huahuadia bae ani,
\q2 bona lalodia na lalo-hadai ese e hahonudia vaitani.
\q1 
\v 32 Badina be asi aonegadia taudia na edia raka-muri ese e hamasediamu,
\q2 bona kavakava taudia na edia mata-lahui ese e habuadia tarimu;
\q1 
\v 33 to e hakala henigumu tauna baine noho hedai;
\q2 baine noho namonamo, dika garina basine gari.
\c 2
\q1 
\v 1 Natugu e, egu hereva boma abi dae,
\q2 egu haheḡani boma lalodia bada;
\v 2 taiamu ese aonega bema hakede henia,
\q2 bona lalomu ese lalo-parara bema ura henia;
\q1 
\v 3 oibe, lalo-dobu boma noilaia,
\q2 bona lalo-parara boma boilaia;
\q1 
\v 4 boma tahua, \it silver\it* na heto;
\q2 boma tahua goada, e hehunimu kohudia namodia na heheto;
\q1 
\v 5 bena Iehova igari-henina ba diba,
\q2 bona Dirava idibana ba davaria.
\q1 
\v 6 Badina be Iehova ese aonega e henimu,
\q2 ia uduna amo aonega bona lalo-parara na e maimu;
\q1 
\v 7 ia ese aonega namona e habouamu, kara maoromaoro taudia edia;
\q2 ia na dala momokanina ai e rakamu taudia edia kesi;
\q1 
\v 8 hahemaoro ḡoevaḡoeva daladia e gimadiamu,
\q2 bona ena helaḡa taudia edia dala e nariamu.
\q1 
\v 9 Bena kara maoromaoro bona hahemaoro ḡoevaḡoeva ba diba,
\q2 bona ahu korikori ihenina bona dala namodia iboudiai danu
\q1 
\v 10 badina be aonega na oi lalomu ai baine vareai,
\q2 bona laumamu ese lalo-parara baine moalelaia;
\q1 
\v 11 kara-balaheni ese baine narimu,
\q2 lalo-parara ese baine gimamu,
\q1 
\v 12 dala dikana amo baine hamaurimu,
\q2 hereva gageva-gageva taudia edia amo danu.
\q1 
\v 13 Idia ese kara maoromaoro daladia e rakatanimu,
\q2 dibura daladia ai e rakamu;
\q1 
\v 14 kara dika ikaradia e moalelaiamu,
\q2 bona kara dika ena dala gageva-gagevana e lalo namo heniamu;
\q1 
\v 15 idia na dala gagevadia ai e rakamu taudia,
\q2 edia raka daladia na dia mamaoro-mamaoro.
\b
\q1 
\v 16 Lebulebu hahinena ena amo baine harohomu mauri,
\q2 bona ariara hahinena ena hedibaḡani herevadia amo danu.
\q1 
\v 17 Ia ese eregabena ai e bamoava tauna na e rakataniamu,
\q2 bona ena Dirava ena taravatu e reaiamu;
\q1 
\v 18 badina be ena ruma na mase idiho-henina gabuna,
\q2 bona ena dala na mase laumadia edia gabu ai e dihomu;
\q1 
\v 19 e lao heniamu taudia na ta se lou maimu,
\q2 mauri daladia asie davaridia loumu.
\b
\q1 
\v 20 Taunabunai taunimanima namodia edia dala ai ba raka,
\q2 bona kara maoromaoro taudia edia dala ba badinadia.
\q1 
\v 21 Badina be kara maoromabro taudia na tano bae noholaia,
\q2 bona lalo-maoromaoro taudia na ia lalonai bae noho;
\q1 
\v 22 a kara dika taudia na tano amo bae henege daure,
\q2 bona kara hegui-hegui taudia na tano amo bae heraḡa oho.
\c 3
\q1 
\v 1 Natugu e, egu hahediba herevadia basio lalodia boio,
\q2 lalomu ese egu haheḡani baine badinadia;
\q1 
\v 2 badina be idia ese emu mauri dinadia bae hadaudaudia,
\q2 bona idia ese emu mauri laḡanidia bae hahohodia,
\q2 bona ḡau namodia momo bae henimu.
\q1 
\v 3 Hebogahisi bona heabidadama basio negedia,
\q2 a aiomu ba ḡeḡelaia
\q2 bona lalomu ai ba toredia.
\q1 
\v 4 Unu amo lalo-namo bona lalo-parara ba davaridia,
\q2 Dirava bona taunimanima vairadiai.
\b
\q1 
\v 5 Iehova bavabidadama henia mai lalomu idoinai;
\q2 sibomu emu lalo-parara basio abidadama henia.
\q1 
\v 6 Emu dala iboudiai lalodiai ia bavabia dae,
\q2 bena ia ese emu dala baine hamaoromaorodia.
\q1 
\v 7 Sibomu emu aonega basio heaḡilaia;
\q2 Iehova garina ba gari,
\q2 bona dika amo ba raka oho.
\q1 
\v 8 Una na hidiomu ihamaurina,
\q2 bona turiamu ihagoadadia.
\b
\q1 
\v 9 Emu kohu amo Iehova ba hanamoa,
\q2 bona emu uma ḡaudia iboudiai anidia roboadia amo danu;
\q1 
\v 10 bena emu roge na bae honu honu dae,
\q2 bona vine ranuna na emu vine ibulolaina urodia amo baine hepurai dobi.
\b
\q1 
\v 11 Natugu e, Iehova ena mata-hakani basio dadaraia,
\q2 bona ena sisiba basio hesikulaia;
\q1 
\v 12 badina be Iehova ese e lalokau heniamu tauna na e sisiba heniamu,
\q2 tama ta ese natuna, e lalo namo heniamu merona, na e sisiba heniamu heḡereḡerena.
\b
\q1 
\v 13 Aonega e davariamu tauna na namo,
\q2 bona lalo-parara e abiamu tauna danu;
\q1 
\v 14 badina be aonega ena amo e heabimu ahuna ese
\q2 \it silver\it* ena amo e heabimu ahuna na e hereaiamu,
\q2 bona davana ese \it gold\it* e hereaiamu.
\q1 
\v 15 Ia davana ese herahera nadidia davadia e hereadiamu,
\q2 bona o ura henimu ḡaudia ta na ia ida basie heḡereḡere.
\q1 
\v 16 Mauri daudauna na ia imana idibana ai;
\q2 taḡa bona heimodai na ia imana laurina ai.
\q1 
\v 17 Ena dala na moale daladia;
\q2 ena dala iboudiai na maino daladia.
\q1 
\v 18 Ia na mauri auna, e dabaia taomu taudia ediai;
\q2 e dogoa taomu taudia na moale taudia e gwauraidiamu.
\b
\q1 
\v 19 Iehova ese aonega amo tanobada e hadaia,
\q2 lalo-parara amo guba e karaia;
\q1 
\v 20 iena diba-bada dainai gadobada na e aru dae,
\q2 bona ori ese hunu e hadihoamu.
\b
\q1 
\v 21 Natugu e, aonega namona bona kara balaheni ba badinadia;
\q2 oi matamu ese basie readia;
\q1 
\v 22 bena idia ese laumamu bae hamauria,
\q2 bona aiomu bae heralaia,
\q1 
\v 23 bena emu dala ai ba raka mai namomu ida,
\q2 bona aemu na basine hetutuhi.
\q1 
\v 24 Boma helai diho, basioma gari;
\q2 boma hekure diho, emu mahuta bema gaiho.
\q1 
\v 25 Hahetaku ḡauna garina basio gari,
\q2 eiava kara dika taudia ihabua-taridia baine kau negana ai danu basio gari;
\q1 
\v 26 badina be Iehova na emu abidadama,
\q2 ia ese oi aemu baine naria, basine heidoa.
\q1 
\v 27 Ihanamona na mai badina bae abia taudia edia amo basio rua,
\q2 ba henidia diba negana ai.
\b
\q1 
\v 28 Dekemu tauna basio hamaoroa, basioto
\q2 “Aola, ma ba lou mai, kerukeru baina henimu”,
\q2 a ḡau be dekemu ai e miamu.
\q1 
\v 29 Dekemu tauna ihadikana dalana basio laloa hata,
\q2 ia na badibadimu ai e nohomu,
\q2 bona e abidadama henimumu.
\q1 
\v 30 Tau ta basio lodu henia kava,
\q2 ia ese se hadikamu negana ai.
\q1 
\v 31 Taiḡa dika tauna basio vaḡeḡe henia,
\q2 ena dala ta basio abia hidi;
\q1 
\v 32 badina be kara heḡui-heḡui tauna na Iehova ese e inai henia badamu,
\q2 a kara maoromaoro taudia na ia ese e abidadama henidiamu.
\q1 
\v 33 Iehova ese kara dika tauna ena ruma e uduguiraiamu;
\q2 a kara maoromaoro tauna ena ruma ia ese e hanamoamu.
\q1 
\v 34 Heihi-ihirai taudia na ia ese e ihi-ihiraidiamu;
\q2 a manau taudia na ia ese e lalo namo henidiamu.
\q1 
\v 35 Aonega taudia davadia na heimodai,
\q2 a kavakava taudia na bae hahemaraidia.
\c 4
\q1 
\v 1 Natu e, tama ena hahediba herevadia ba kamonai;
\q2 ba hakede henia, bena lalomui bae parara;
\q1 
\v 2 badina be hahediba herevadia namodia vada na henimui;
\q2 egu hahediba na basio rakatania.
\q1 
\v 3 Merogu ai lau danu mai tamagu,
\q2 maraḡigu ai sinagu ese e lalokau henigu bada;
\q1 
\v 4 una negana ai tamagu ese e hadibagu, eto:
\q2 Egu hereva na lalomu ai ba dogodia tao tarika-tarika;
\q2 egu haheḡani ba badinadia, bena ba mauri.
\q1 
\v 5 Basio helalo boio; udugu herevadia amo
\q2 basio raka muri.
\q1 Aonega bavabia, lalo-parara bavabia;
\q2 
\v 6 basio rakatania, bena ia ese baine narimu;
\q2 ba ura henia, bena ia ese baine gimamu.
\q1 
\v 7 Aonega matamana binai: aonega bavabia;
\q2 dahaka dahaka bavabi, to lalo-parara basio reaia.
\q1 
\v 8 Ba laloa bada, bena ia ese baine heatolaimu;
\q2 ba rosia, bena ia ese baine imodaimu.
\q1 
\v 9 Herahera ḡauna namona na oi kwaramu baine havavalaia;
\q2 havava ḡauna mai hairaina baine henimu.
\b
\q1 
\v 10 Natugu e, a kamonai; egu hereva bavabi dae,
\q2 bena emu mauri laḡanidia bae hoho.
\q1 
\v 11 Aonega dalana vada na hadibalaimu;
\q2 kara maoromaoro daladia ai vada na hakaumu.
\q1 
\v 12 Ba raka negana ai aemu basine hekwakwanai;
\q2 boma heau, basioma hetutuhi.
\q1 
\v 13 Hahediba ba dogoa tao, basio kahua nege;
\q2 ba gimaia, badina be ia na emu mauri.
\q1 
\v 14 Kara dika taudia edia dala ai basio raka vareai,
\q2 kara havara taudia edia dala ai basio raka;
\q1 
\v 15 ena amo ba siri, basio rakalaia;
\q2 ena amo ba raka oho, ba rakaia hanai.
\q1 
\v 16 Badina be basie mahuta diba ela bona kara kerere tavada bae karaia;
\q2 mahuta ai bae dabu ela bona tau ta vada bae hahekwakwanaia.
\q1 
\v 17 Badina be e aniamu ḡauna na kara dika,
\q2 bona e inuamu ḡauna na daḡedaḡe.
\q1 
\v 18 A kara maoromaoro taudia edia dala na daba matana na heto;
\q2 diarina na e bada e laomu ela bona dina e taramu.
\q1 
\v 19 Kara dika taudia edia dala na dibura masemase na heto,
\q2 asi dibadia dahaka ḡau ai e hetutuhimu.
\b
\q1 
\v 20 Natugu e, egu hereva ba hakede henidia;
\q2 taiamu a hakala, egu hereva ba kamonai.
\q1 
\v 21 Oi vairamu amo basie boio,
\q2 oi lalomu ai ba baladia heni.
\q1 
\v 22 Badina be idia na mauri, e davaridiamu tauna enai;
\q2 idia na ia hidiona idoinai ihamaurina.
\q1 
\v 23 Lalomu ba gimaia tarika-tarika,
\q2 badina be iena amo mauri e lohilohiamu.
\q1 
\v 24 Hereva gageva-gagevadia na emu amo bavato siri;
\q2 hereva koikoidia na emu amo ba nege daure.
\q1 
\v 25 Matamu na vairamu kahana bae roha henia;
\q2 vairamu kahana do ba raraia tao.
\q1 
\v 26 Aemu daladia nahuadia ba toho,
\q2 bena emu dala iboudiai bae momokani.
\q1 
\v 27 Basio heau mageva, idiba kahana amo eiava lauri kahana amo;
\q2 aemu na kara dika amo bae raka siri.
\c 5
\q1 
\v 1 Natugu e, egu aonega ba hakede henia,
\q2 taiamu ba hakala, egu lalo-parara enai;
\q1 
\v 2 kara balaheni ba badinaia
\q2 bona bibinamu ese aonega bae gimaia totona.
\q1 
\v 3 Badina be bada-ranuna na lebulebu hahinena bibinana amo e hetuturu dobimu,
\q2 bona ena hereva digarana ese dehoro digarana e hereaiamu;
\q1 
\v 4 a dokona ai ia na idita, muramura iditana na heto;
\q2 bona mai ganona, isena ruaosi e segedia darena na heto.
\q1 
\v 5 Aena ese mase e diho heniamu,
\q2 mase gabuna e lao heniamu dalana ai e rakamu;
\q1 
\v 6 mauri dalana nahuana na se tohoamu;
\q2 e raka kava raka kavamu, to ena dala asi dibana.
\b
\q1 
\v 7 Natu e, a kamonai henigu;
\q2 udugu herevadia basio rakatanidia.
\q1 
\v 8 Hahine unuhetomana na dauhai ba rakaia hanai,
\q2 ena ruma iduarana basio raka henia kahi;
\q1 
\v 9 ikwahimu na haida ese bae abi
\q2 bona emu mauri laḡanidia na asi edia hebogahisi taudia ese bae abi oho na garina;
\q1 
\v 10 idau taudia ese oi goadamu amo bae goada
\q2 bona emu hekwarahi anina ese idau tauna ena ruma baine hanamoa na garina;
\q1 
\v 11 ela bona emu mauri dokona ai ba ḡanaḡana,
\q2 gorere ese hidiomu bona tau-animu baine ha-ore negana ai.
\q1 
\v 12 Una negana ai baoto: Mata-hakani na inai heniava,
\q2 bona lalogu ese sisiba herevadia e dadaraidiava;
\q1 
\v 13 e hadibagu taudia eredia asina kamonaiva,
\q2 bona egu hahediba taudia asina hakala henidiava;
\q1 
\v 14 mokona na dika vaitani
\q2 hebou taudia bogaragidiai.
\b
\q1 
\v 15 Sibomu emu ranu gabuna amo,
\q2 sibomu emu ranu gurina amo,
\q2 ranu ba inua.
\q1 
\v 16 Emu ranu baine lohilohi rohoroho
\q2 eiava ariara ai baine aru lao a?
\q1 
\v 17 Lasi, baine mia sibomu emu;
\q2 idau taudia ida basie inua hebou.
\q1 
\v 18 Emu ranu lohilohina baine namo;
\q2 eregabemu ai o adavaia hahinena na ba moalelaia.
\q1 
\v 19 Ia na dia hahinena namo-hereana na heto,
\q2 eiava-miara raho-namona na heto.
\q1 Ena lalokau ba moalelaia nega iboudiai;
\q2 ena uraheni ese lalomu baine hahonua hanaihanai.
\q1 
\v 20 Natugu e, anina be dahaka lebulebu hahinena boma ura henia lalo-dika?
\q2 Badina be dahaka anara hahinena ba rosia?
\q1 
\v 21 Badina be tau ta ena kara na Iehova ese e itadiamu;
\q2 Iehova ese ena dala iboudiai e itadia taomu.
\q1 
\v 22 Kara havara tauna na ena kara havara ese e idoaiamu,
\q2 ena kara dika ese e ḡuiamu.
\q1 
\v 23 Matana asi ihakanina dainai e masemu;
\q2 ena kavakava bada-herea dainai e boiomu.
\c 6
\q1 
\v 1 Natugu e, dekemu tauna dainai boma gwau hamata,
\q2 eiava idau tauna dainai boma gwau guna,
\q1 
\v 2 eiava bibinamu reḡedia ese bema idoamu,
\q2 eiava udumu herevadia ese bema hahekwakwanaimu,
\q1 
\v 3 natugu e, ini boma kara toma, sibomu boma hahemauri,
\q2 badina be oi na dekemu tauna imana ai:
\q2 aola haraḡa, dekemu tauna ba noia.
\q1 
\v 4 Matamu basie mahuta,
\q2 matamu kopidia basie kapu;
\q1 
\v 5 ba roho mauri, uda nanina ese labana tauna imana amo
\q2 eiava manu ese manu-tahu tauna imana amo
\q2 e roho maurimu na heto.
\b
\q1 
\v 6 Lahedo taumu e, dimairi ba lao henia;
\q2 ena kaura ba laloa, bena aonega ba davaria.
\q1 
\v 7 Ia na asi lohiana, asi biaguna, asi pavapavana,
\q2 
\v 8 to lahara negana ai ana aniani e abimu,
\q2 bona taboro negana ai e haboumu.
\q1 
\v 9 Lahedo taumu e, ba hekure ela bona edena nega ai?
\q2 Edena nega ai emu mahuta amo ba noga?
\q1 
\v 10 Matamu ba taia, ba laḡa ani sisina,
\q2 nega sisina kwaramu na imamu ai ba hahekwinaia;
\q1 
\v 11 bena ogoḡami ese baine abimu, dadidadi tauna na heto,
\q2 bona dabu na emu ai baine kau, tuari tauna na heto.
\b
\q1 
\v 12 Kara kava tauna, kara dika tauna,
\q2 e loa eva-evamu mai hereva gageva-gagevana ida;
\q1 
\v 13 matana e hakunumaiamu, aena amo tano e dadaroamu,
\q2 bona dodoriana e duduiamu;
\q1 
\v 14 lalona gageva-gagevana amo kara dika e laloa hatamu,
\q2 heiriheiri e havaraia louloumu.
\q1 
\v 15 Taunabunai hahedika ese baine halahuia;
\q2 mata-kunumai tamona ai baine dika,
\q2 ta basine hamauria diba.
\b
\q1 
\v 16 Ḡau tauratoi Iehova ese e inai henidiamu,
\q2 ḡau hitu ia ese e badulaidiamu:
\q1 
\v 17 hekokoroku matadia, koikoi malana,
\q2 bona asi ena kerere tauna rarana e hahebubuamu imadia;
\q1 
\v 18 lalo-hadai dikadia e lalo hatamu lalona,
\q2 bona kara dika e heau heniamu aedia;
\q1 
\v 19 hahebade koikoi tauna, koikoi herevadia mo e gwauraimu,
\q2 bona heiri-heiri na tadikaka bogaragidiai e havaraiamu tauna.
\b
\q1 
\v 20 Natugu e, tamamu ena haheḡani ba badinaia,
\q2 bona sinamu ena hahediba herevadia basio rakatanidia.
\q1 
\v 21 Nega idoinai lalomu ai ba ḡuidia,
\q2 bona aiomu ai ba taudia dae.
\q1 
\v 22 Ba raka negana ai bae hakaumu;
\q2 ba hekure negana ai bae gimamu;
\q2 ba noga negana ai bae hereva henimu.
\q1 
\v 23 Badina be haheḡani na lamepa,
\q2 bona hahediba na diari,
\q2 bona mata-hakani na mauri dalana.
\q1 
\v 24 Idia ese hahine dikana ena amo bae hamaurimu,
\q2 bona ariara hahinena malana gaihona amo danu.
\q1 
\v 25 Ia hairaina na lalomu ai basio ḡahusia,
\q2 bona nahuamu ba tohoa, matana rauna ese baine idoamu na garina;
\q1 
\v 26 badina be ariara hahinena na flaoa igabu ta bae davalaia,
\q2 a heuda-hanai hahinena ese tau ta ena mauri e rau heniamu.
\q1 
\v 27 Tau ta ese lahi na kemena ai bema abia loaloa,
\q2 ena dabua basinema ara a?
\q1 
\v 28 Eiava tau ta ese gida latadiai bema raka,
\q2 aena basinema haraka a?
\q1 
\v 29 Dekena tauna adavana dekenai e raka vareaimu tauna na unuheto;
\q2 enai e daukaumu tauna ta na mata-hakani amo basine roho mauri.
\q1 
\v 30 Hitolo dainai aniani baine henaoa tauna na
\q2 taunimanima ese bae ihi-ihiraia ani?
\q1 
\v 31 A bema davaria, ia na dava baine heni hahitu;
\q2 ena ruma kohuna idoinai baine heni.
\q1 
\v 32 E heuda hanaimu tauna na asi darana;
\q2 ia na sibona e healamu;
\q1 
\v 33 bero bona hedadarai baine abi,
\q2 ena hemarai na basine heroho.
\q1 
\v 34 Badina be mama ese tau ta lalona e habaduamu;
\q2 dava iabina negana ai, ia na asi ibogahisina.
\q1 
\v 35 Heaiva kohuna basine abia;
\q2 bona herahia momo amo ia lalona basio hakerua diba.
\c 7
\q1 
\v 1 Natugu e, egu hereva ba badinadia,
\q2 bona egu haheḡani na emu kohu ai ba halaodia.
\q1 
\v 2 Egu haheḡani ba badinadia, bena ba mauri;
\q2 egu hahediba herevadia ba naridia,
\q2 matamu nadinadina o nariamu na heto;
\q1 
\v 3 kwakikwakimu ai ba hiridia kau;
\q2 lalomu ai ba toredia.
\q1 
\v 4 Aonega ba hamaoroa, baoto “Oi na taihugu”;
\q2 lalo-parara na turamu korikori ai ba halaoa.
\q1 
\v 5 Ia ese lebulebu hahinena ena amo baine hamaurimu,
\q2 bona ariara hahinena ena hereva gaihodia amo danu.
\q1 
\v 6 Egu ruma gaba-mauruna badibadinai na gini,
\q2 maka-maka amo na igo lasi;
\q1 
\v 7 asi aonegadia taudia bogaragidiai, eregabe bogaragidiai,
\q2 eregabe tauna ta na itaia, asi darana;
\q1 
\v 8 una hahine ena ariara daigunina e raka heniava,
\q2 ena ruma lao dalana ai e rakava,
\q1 
\v 9 dina e kerekereva ai, dina e dihova ai,
\q2 hanua e boiva ai, dibura e kauva ai.
\b
\q1 
\v 10 A itaia, hahine ta ia ida e hedavarimu;
\q2 ita-itana na ariara hahinena, lalona na gageva-gageva;
\q1 
\v 11 e hereva momomu, e kara kavamu,
\q2 e loa eva-evamu;
\q1 
\v 12 nega haida ariara ai, ma nega haida hoihoi gabuna ai,
\q2 ariara daigunidia iboudiai e banimu.
\q1 
\v 13 Ia ese una eregabe tauna e rosiamu, e harahuamu,
\q2 mai kirina ida e hereva heniamu, e tomu:
\q1 
\v 14 Egu boubou ḡaudia vada na hahelagadia,
\q2 hari dina ai egu gwauhamata davadia vada na heni;
\q1 
\v 15 taunabunai vada na raka lasi, ihedavari-henimu totona,
\q2 mai moalegu ida baina tahumu totona;
\q2 bona vada name davarimu.
\q1 
\v 16 Egu mahuta patana ai dabua vada na tahoa,
\q2 dabua aukadia Aigupto amo, mai hairaidia;
\q1 
\v 17 egu mahuta ḡauna na muramura mai bonadia amo vada na kwadia,
\q2 muro bona aloe bona kinamono.\f + \fr 7:17 \ft Muro; Aloe; Kinamono. Ini na Heheru taudia edia muramura mai bonadia haida iadadia.\f*
\q1 
\v 18 Aoma, baita eno bou rani,
\q2 baita heura heheni mai moaleda ida.
\q1 
\v 19 Badina be adavagu na lasihia,
\q2 ia na dala daudauna ai vada e halaolao;
\q1 
\v 20 ia ese moni vainana ta e abia kau,
\q2 hua baine idoi negana ai baine lou mai.
\b
\q1 
\v 21 Hedibaḡani herevadia momo amo lalona e aniamu,
\q2 ena hereva gaihodia amo lalona e ha-uraiamu.
\q1 
\v 22 Vadaeni, ia murina amo e laomu,
\q2 boromakau na ialana gabuna e laomu na heto;
\q2 eiava dia na heto, idoa ese e idoaiamu,
\q1 
\v 23 ela bona diba ese bogana e gwadaiamu;
\q1 eiava manu na heto, rikiriki e roho heniamu,
\q2 asi dibana ena mauri e negeamu.
\b
\q1 
\v 24 Natu e, a kamonai henigu;
\q2 udugu herevadia ba hakala henidia.
\q1 
\v 25 Lalomu na basine raka siri una hahine ena dala ai,
\q2 ena dala lalodiai basio raka lao;
\q1 
\v 26 badina be vada e aladia taudia na hutuma;
\q2 oibe, vada e aladia mase taudia iboudiai na hutuma herea.
\q1 
\v 27 Ena ruma na mase gabuna dalana,
\q2 bona mase rumadia e diho henidia laomu.
\c 8
\q1 
\v 1 Aonega na se boiboimu a?
\q2 Lalo-parara ese gadona se habadaiamu a?
\q1 
\v 2 Dala badina ororodia ai bona dala lalodiai e ginimu;
\q2 
\v 3 hanua ikoukoudia badibadidiai
\q2 bona ruma iduaradia ai e boiboimu, e tomu:
\q1 
\v 4 Taunimanima e, na boi henimuimu;
\q2 taunimanima natudia e, na tai henimuimu.
\q1 
\v 5 Asi aonegamui taumui e, nahuamui ba toho;
\q2 kavakava taumui e, a hakala.
\q1 
\v 6 A kamonai, badina be ḡau herea-daedia baina herevalai,
\q2 udugu bibinadia herevadia bae maoromaoro;
\q1 
\v 7 badina be udugu na hereva momokanidia baine gwaurai,
\q2 udugu bibinadia ese kara dika e inai heniamu.
\q1 
\v 8 Udugu herevadia iboudiai na mamaoro-mamaoro;
\q2 ta se hepui, ta se gageva-gageva.
\q1 
\v 9 Iboudiai na hehedinararai, lalona e pararamu tauna enai,
\q2 bona mamaoro-mamaoro, aonega e davariamu taudia ediai.
\q1 
\v 10 Egu hahediba herevadia bavabi dae, a dia \it silver\it*;
\q2 aonega bavabia dae, a dia \it gold\it* namo-hereana;
\q1 
\v 11 badina be aonega ena namo ese herahera nadinadidia edia namo e hereaiamu,
\q2 o ura henimu ḡaudia iboudiai na ia ida basie heḡereḡere.
\q1 
\v 12 Lau, aonega, na henahua tohomu,
\q2 bena lalo-parara bona kara-balaheni na davaridiamu.
\q1 
\v 13 Iehova igari-henina na dika i'inai-henina;
\q2 hekokoroku bona heaḡi bona kara dika dalana
\q2 bona hereva gageva-agevadia na inai henidiamu.
\q1 
\v 14 Hahealo bona aonega namodia na egu ai,
\q2 lalo-parara bona goada danu.
\q1 
\v 15 Lau daigu ai pavapava e lohiamu,
\q2 bona hanua lohiadia ese taravatu maoromaorodia e gwauraimu
\q1 
\v 16 lau daigu ai pavapava e lohiamu,
\q2 bona lohia taudia ese tanobada e biaguamu.
\q1 
\v 17 E ura henigumu taudia na na ura henidiamu,
\q2 bona mai gadodia ida e tahugumu taudia ese e davarigumu.
\q1 
\v 18 Taḡa bona hemataurai na egu ai,
\q2 mia-hanaihanai kohudia bona ima-lalo-ani negadia danu.
\q1 
\v 19 Lau huahuagu ese \it gold\it* e hereaiamu,
\q2 \it gold\it* namo-hereana e hereaiamu;
\q2 lau anigu ese \it silver\it* ḡoeva-daena e hereaiamu.
\q1 
\v 20 Kara maoromaoro daladia ai na rakamu,
\q2 bona hahemaoro ḡoevaḡoevana ai danu;
\q1 
\v 21 e ura henigumu taudia na hataḡadiamu,
\q2 edia habou-habou rumadia na hahonudiamu.
\b
\q1 
\v 22 Ena ḡaukara matamana ai Iehova ese e karagu,
\q2 ena kara gunadia matamana.
\q1 
\v 23 Gunaguna negana ai e haginigu,
\q2 matamana negana ai, tanobada do se vara negana ai.
\q1 
\v 24 Gadobada na do lasi negana ai, ia ese e havaragu,
\q2 ranu gabudia ai ranu do se lohilohiva negana ai.
\q1 
\v 25 Ororo badadia na oromadia do asie abi,
\q2 ororo maraḡidia na do lasi negana ai,
\q2 lau e havaragu;
\q1 
\v 26 tanobada mai ena rei gabudia ida do se kara
\q2 bona tano ḡahuna do se karaia matama negana ai.
\q1 
\v 27 Guba e karaia negana ai, lau na unuseni ai,
\q2 gadobada hetoadia e karadia heḡeḡe negana ai;
\q1 
\v 28 atai ai guba e ha-aukaia
\q2 bona gadobada e halohilohia daeva negana ai;
\q1 
\v 29 davara hetoana e henia,
\q2 ranuna ese iena haheḡani basie tataia utu helaoreana,
\q2 bona tanobada badidia toadia e kara negana ai.
\q1 
\v 30 Una negana ai lau na ia badibadinai,
\q2 ḡaukara idibaka tauna na heto;
\q1 dina iboudiai ia ese e moalelaiguva,
\q2 bona lau na ia vairanai na moaleva nega idoinai;
\q1 
\v 31 ena tanobada mai inoholaina taudia ida,
\q2 taunimanima natudia iboudiai na moalelaidiava.
\b
\q1 
\v 32 Natugu e, ina harihari a kamonai henigu:
\q2 Egu dala e badinadiamu taudia be nanamo.
\q1 
\v 33 Hahediba herevadia ba hakala henidia, bena ba aonega;
\q2 basio laloa nege.
\q1 
\v 34 E kamonai henigumu tauna na namo;
\q2 dina iboudiai ia ese egu ikoukou ai e gimamu,
\q2 egu iduara ai e henarimu.
\q1 
\v 35 Badina be lau e davarigumu tauna ese mauri e davariamu,
\q2 bona lalo-namo na Iehova ena amo e abiamu;
\q1 
\v 36 a e reagumu tauna na sibona e healamu,
\q2 lau e inai henigumu taudia iboudiai ese mase e ura heniamu.
\c 9
\q1 
\v 1 Aonega ese ena ruma vada e hadaia,
\q2 ena au-tubua hituosi vada e haginidia.
\q1 
\v 2 Ena vamu vada e aladia mase,
\q2 ena vine ranuna vada e buloa,
\q2 ena pata vada e dabaraia.
\q1 
\v 3 Ena hesiai kekenidia vada e siaidia lao,
\q2 hanua lalonai atai gabudia amo bae boiboi, baeto:
\q1 
\v 4 Daika na asi aonegana,
\q2 ia na iniseni ai baine raka vareai.
\q1 Bona asi darana tauna na ia ese e hereva heniamu, e tomu:
\q2 
\v 5 Aoma, egu dabara bavania;
\q2 vine ranuna vada na buloa ba inua;
\q1 
\v 6 lalo-duhu ba rakatania bena ba mauri;
\q2 lalo-parara dalana ai ba raka.
\b
\q1 
\v 7 Ḡonaḡona tauna e sisiba heniamu tauna na bae ihi-ihiraia,
\q2 bona kara dika tauna e gwau heniamu tauna na bae haberoa.
\q1 
\v 8 Ḡonaḡona tauna basio gwau henia,
\q2 badina be baine inai henimu;
\q1 a aonega tauna ba gwau henia
\q2 bena baine lalokau henimu.
\q1 
\v 9 Aonega tauna ba hadibaia, bena ena aonega ma baine bada;
\q2 kara maoromaoro tauna ba hadibaia, bena baine diba herea.
\q1 
\v 10 Iehova igari-henina na aonega matamana;
\q2 Helaḡa Diravana idibana na lalo-parara.
\b
\q1 
\v 11 Badina be lau ese emu mauri dinadia baina hahohodia;
\q2 emu mauri laḡanidia baina hadaudaudia.
\q1 
\v 12 Boma aonega, emu aonega ese baine hanamomu;
\q2 boma ḡonaḡona, sibomu metauna ba huaia.
\q1 
\v 13 Kavakava hahinena na e udu maurimu;
\q2 ia na mai lebulebuna, asi hemarai dibana.
\q1 
\v 14 Ena ruma iduarana ai e helaimu,
\q2 hanua ena atai gabudia ai e helaimu,
\q1 
\v 15 raka-hanai taudia, edia dala ai e raka maoromaoromu taudia,
\q2 na e boi henidiamu, e tomu:
\q1 
\v 16 Daika na asi aonegana,
\q2 ia na iniseni ai baine raka vareai.
\q1 Bona asi darana tauna na ia ese e hereva heniamu, e tomu:
\q2 
\v 17 E henaoa ranuna na mai gaihona,
\q2 bona e ania hehunimu anianina mamula na namo.
\q1 
\v 18 A tauna na asi dibana mase taudia na unuseni ai,
\q2 asi dibana una hahine vadivadina na mase ena dobu gabudia ai.
\c 10
\p 
\v 1 Solomon ena hereva lada-isidia:
\q1 Aonega merona ese tamana e hamoaleamu,
\q2 a kavakava merona ese sinana lalona e hahisihisiamu.
\q1 
\v 2 Kara dika amo e abimu kohudia ese namo se habadaiamu,
\q2 a kara maoromaoro ese mase amo e haherauamu.
\q1 
\v 3 Iehova ese kara maoromaoro taudia na edia hitolo ai se rakatanidia,
\q2 a kara dika taudia edia ura dikadika e laodia ahumu.
\q1 
\v 4 Ima manokana ese ogoḡami e havaraiamu,
\q2 a ima-lalo-ani tauna imana ese taḡa e habadaiamu.
\q1 
\v 5 Ḡeiḡei negana ai aniani e habouamu merona na lalo-parara merona,
\q2 a taboro negana ai e mahuta hedavauhemu merona ese hemarai e havaraiamu.
\q1 
\v 6 Kara maoromaoro tauna kwarana ai hahenamo na e kaumu,
\q2 a kara dika tauna uduna ai daḡedaḡe e mia hehunimu.
\q1 
\v 7 Kara maoromaoro tauna ilalo-taona na mai hahenamona,
\q2 a kara dika tauna ladana baine hogohogo.
\q1 
\v 8 Lalona e aonegamu tauna ese haheḡani baine badinadia,
\q2 a udu-mauri tauna baine dika vaitani.
\q1 
\v 9 E raka momokanimu tauna na e rakamu mai namona ida,
\q2 a e raka gageva-gagevamu tauna na ena kerere baine hedinarai.
\q1 
\v 10 Matana e kunumaiamu tauna ese hekwakwanai e havaraiamu,
\q2 a sisiba herevadia igwauraidia se garimu tauna ese maino e havaraiamu.
\q1 
\v 11 Kara maoromaoro tauna uduna amo mauri e lohilohiamu,
\q2 a kara dika tauna uduna ai daḡedaḡe e mia hehunimu.
\q1 
\v 12 Inai ese heiri-heiri e havaraiamu,
\q2 a lalokau ese kerere iboudiai e ḡovadiamu.
\q1 
\v 13 Lalo-parara tauna bibinana ai aonega e hedinaraimu,
\q2 a lalo-duhu tauna doruna ai na hekwadi auna mia.
\q1 
\v 14 Aonega taudia ese edia diba e habadaiamu,
\q2 a kavakava tauna ena udu-mauri ese hahedika e mailaiamu.
\q1 
\v 15 Taḡa tauna ena taḡa na ena hanua aukana,
\q2 a ogoḡami taudia na edia ogoḡami ese e hadikadiamu.
\q1 
\v 16 Kara maoromaoro tauna davana be mauri e davariamu,
\q2 a kara dika tawla ahuna be ena dika e habadaiamu.
\q1 
\v 17 Hahediba herevadia e kamonaimu tauna na mauri dalana ai e rakamu,
\q2 a sisiba herevadia e dadaraidiamu tauna na e raka kereremu.
\q1 
\v 18 Inai e huniamu tauna bibinana na e koikoimu,
\q2 bona hahebade herevadia e gwauraimu tauna na kavakava tauna.
\q1 
\v 19 Hereva momo ese kara kerere e havaradiamu,
\q2 a uduna bibinadia e rudiamu tauna na mai aonegana.
\q1 
\v 20 Kara maoromaoro tauna malana na \it silver\it* namo-hereana,
\q2 a kara dika tauna darana na negenege ḡauna.
\q1 
\v 21 Kara maoromaoro tauna bibinana ese hutuma e ubudiamu,
\q2 a kavakava taudia na asi daradia dainai e masemu.
\q1 
\v 22 Iehova ena hahenamo ese taḡa e habadaiamu,
\q2 bona lalo-hisihisi sina taina se atoa kaumu.
\q1 
\v 23 Kavakava tauna ese kara dika na ena gadara ai e halaoamu,
\q2 a lalo-parara tauna ese aonega karadia e moalelaimu.
\q1 
\v 24 Kara dika tauna ese e garilaiamu ḡauna na ienai baine kau,
\q2 a kara maoromaoro tauna ena ura na baine abia.
\q1 
\v 25 Lai gubana e toamu, murinai kara dika tauna na lasihia,
\q2 a kara maoromaoro tauna na e gini hanaihanaimu.
\q1 
\v 26 Inuinu ḡauna iditana mamina taunimanima isedia ai,
\q2 eiava kwalahu heḡarana matadia ai,
\q1 kunu-metau tauna na unuheto,
\q2 e siaiamu taudia ediai.
\q1 
\v 27 Iehova igari-henina ese mauri e hadaudauamu,
\q2 a kara dika tauna ena mauri laḡanidia bae gadoi.
\q1 
\v 28 Kara maoromaoro tauna ena helaro na moale ai e gugurumu,
\q2 a kara dika tauna na ena helaro ai baine baia.
\q1 
\v 29 Iehova na goada gabuna, kara maoromaoro tauna enai,
\q2 a ia na hahebua-tari, kara dika taudia ediai.
\q1 
\v 30 Kara maoromaoro tauna na basine heabi oho,
\q2 a kara dika taudia na tano ai basie noho.
\q1 
\v 31 Kara maoromaoro tauna uduna amo aonega e lasimu,
\q2 a mala gageva-gagevana na baine heutu oho.
\q1 
\v 32 Kara maoromaoro tauna bibinana na heabi-dae herevadia mai dibana,
\q2 a kara dika taudia ududia na gagageva-gagageva.
\c 11
\q1 
\v 1 Metau ihahetohona e hakoikoiamu ḡauna na ḡau dika-hereana Iehova enai,
\q2 a hahetoho aurina mai momokanina na ia ese e moalelaiamu.
\q1 
\v 2 Hekokoroku e kaumu negana ai, hemarai danu e kaumu,
\q2 aonega na manau taudia ediai.
\q1 
\v 3 Kara maoromaoro taudia na edia lalo-maoromaoro ese ehakaudiamu,
\q2 a kara heḡuiheḡui taudia na edia lalo-gagevagageva ese e habuadia tarimu
\q1 
\v 4 Badu dinana ai taḡa na asi hahenamona,
\q2 a kara maoromaoro ese mase amo e hahemaurimu.
\q1 
\v 5 Asi ena kerere tauna na ena kara maoromaoro ese ena dala e hamaoromaoroamu,
\q2 a kara dika tauna na sibona ena dika ese e hahekwakwanaiamu.
\q1 
\v 6 Kara maoromaoro taudia na edia kara maoromaoro ese e hamauridiamu,
\q2 a kara heḡuihegui taudia na edia ura dikadia ese e dabaidia taomu.
\q1 
\v 7 Kara dika tauna e masemu negana ai, ena helaro danu e masemu,
\q2 bona Dirava asie matauraiamu taudia na edia helaro ai e baiamu.
\q1 
\v 8 Kara maoromaoro tauna na ena hekwakwanai amo e roho maurimu,
\q2 bena ia gabuna ai kara dika tauna na hekwakwanai lalonai e vareaimu.
\q1 
\v 9 Dirava se matauraiamu tauna ese ia uduna amo ia dekena tauna bema habuaia tari;
\q2 a aonega dainai kara maoromaoro taudia na e roho maurimu.
\q1 
\v 10 Kara maoromaoro taudia e noho namonamomu negadia ai,
\q2 hanua na e moalemu;
\q1 a kara dika taudia e masemu negadia ai,
\q2 hanua na e moale hisi daemu.
\q1 
\v 11 Kara maoromaoro tauna ena hahenamo herevadia ese hanua e hanamoamu,
\q2 a kara dika tauna uduna ese e haheḡiḡia dobimu.
\q1 
\v 12 Ia dekena tauna e ihi-ihiraiamu tauna na asi darana,
\q2 a lalo-parara tauna na asi reḡereḡerena.
\q1 
\v 13 Hesivarai loaloa tauna ese hereva hehunidia e hahedinaraimu,
\q2 a lalo-ihunu tauna ese ḡau e moia taomu.
\q1 
\v 14 Bema asi ihakaudia, taunimanima na bae keto,
\q2 a hahealo taudia bema hoho, taunimanima edia noho baine namo.
\q1 
\v 15 Idau tauna dainai e gwau hamatamu tauna ese hisina baine ani,
\q2 a gwauhamata unuhetomadia e inai henimu tauna na basine dika.
\q1 
\v 16 Harihari-bada hahinena na bae matauraia;
\q2 daḡedaḡe taudia na bae taḡa.
\q1 
\v 17 Hebogahisi tauna na sibona ena namo e havaraiamu,
\q2 a daḡedaḡe tauna na sibona e hahehisimu.
\q1 
\v 18 Kara dika tauna ese dava koikoina e abiamu,
\q2 a kara maoromaoro e hadoamu tauna ese dava momokanina e davariamu.
\q1 
\v 19 Kara maoromaoro ai e gini tutuka-tutukamu tauna na baine mauri,
\q2 a kara dika e ḡavaiamu tauna na baine mase.
\q1 
\v 20 Lalo-gagevagageva taudia na Iehova ese e inai henidia hereamu,
\q2 a asi edia kerere taudia na ia ese e moalelaidiamu.
\q1 
\v 21 Ba diba momokani, kara dika tauna na mata-hakani amo basineroho mauri diba;
\q2 a kara maoromaoro taudia hari bae roho mauri.
\q1 
\v 22 Hane-namo asi lalona na
\q2 \it gold\it* gadeina boroma kurukuruna ai na heto.
\q1 
\v 23 Kara maoromaoro tauna ena ura na namo ai e ḡuḡurumu,
\q2 a kara dika tauna ena helaro ese badu e havaraiamu.
\q1 
\v 24 Tau ta ese e heni dudukaumu, to ena taḡa na e bada e laomu;
\q2 ma ta ese bema heni ḡaudia na se henimu, to ia na e ogoḡamimu.
\q1 
\v 25 Harihari-bada tauna na ena taḡa ma e badamu,
\q2 bona e dairi-dairimu tauna na bae dairia.
\q1 
\v 26 Uit e ruamu tauna na taunimanima ese e uduguiraiamu,
\q2 a e hoiamu tauna latanai hahenamo herevadia bae gwaurai.
\q1 
\v 27 Namo e tahua malaka-malakamu tauna ese harihari-bada danu etahuamu,
\q2 a dika e tahuamu tauna ese dika e davariamu.
\q1 
\v 28 Ena taḡa e abidadama heniamu tauna na baine marai,
\q2 a kara maoromaoro tauna na baine tubu, rau matamatana na heto.
\q1 
\v 29 Ena ruma taudia e hahekwarahidiamu tauna ahuna na lai;
\q2 kavakava tauna na aonega tauna ena hesiai tauna ai bainela.
\q1 
\v 30 Kara maoromaoro huahuana na mauri auna,
\q2 a taravatu itata-utuna ese mauri e abia ohomu.
\q1 
\v 31 Kara maoromaoro tauna ese davana baine abia ina tanobada ai;
\q2 benaini, kara dika tauna bona kara havara tauna edia kara davadia na daka bada.
\c 12
\q1 
\v 1 Mata-hakani e ura heniamu tauna ese aonega e ura heniamu,
\q2 a sisiba e inai heniamu tauna na kavakava.
\q1 
\v 2 Tau namona ese harihari-bada na Iehova ena amo e abiamu,
\q2 a lalo-hadai dikadia tauna na Iehova ese dikana e gwauraimu.
\q1 
\v 3 Kara dika ese tau ta se haginia tutukamu,
\q2 a kara maoromaoro tauna na ramuna basine heraḡa.
\q1 
\v 4 Hahine namona na adavana kwarana ihavavalaina,
\q2 a adavana e hahemaraiamu hahinena na ia turiana ihamanokana gorerena na heto.
\q1 
\v 5 Kara maoromaoro taudia edia lalo-hadai na mamaoro-mamaoro;
\q2 kara dika taudia edia hahealo na mai hedibaḡanidia.
\q1 
\v 6 Kara dika taudia edia hereva na rara ihahebubuna totona e banimu,
\q2 a kara maoromaoro taudia ududia ese taunimanima e hamauridiamu.
\q1 
\v 7 Kara dika taudia na e dareremu bena e pukimu,
\q2 a kara maoromaoro tauna ena ruma na baine hedai.
\q1 
\v 8 Tau ta bae hanamoa ena lalo-maoromaoro dainai,
\q2 a lalo-gagevagageva tauna na bae dadaraia.
\q1 
\v 9 Dagi maraḡi tauna sibona dainai e hekwarahimu na namo,
\q2 a sibona lohia e hegwauraimu to e hitoloamu tauna na dia namo.
\q1 
\v 10 Kara maoromaoro tauna ese ena boromakau e bogaia hisimu,
\q2 a kara dika tauna ena hebogahisi na mai daḡedaḡena.
\q1 
\v 11 Ena tano e ruaiamu tauna ese aniani momo baine abia,
\q2 a kara asi anidia e karamu tauna na asi darana.
\q1 
\v 12 Kara dika tauna ena kohoro aukana e heḡiḡi dobimu,
\q2 a kara maoromaoro tauna ramuna e hedaimu.
\q1 
\v 13 Kara dika tauna na bibinana edia kerere ese bae idoaia,
\q2 a kara maoromaoro tauna na hekwakwanai amo e roho maurimu.
\q1 
\v 14 Ena hereva anidia amo tau ta e namo ḡuḡurumu,
\q2 bona tau ta imana ḡaukarana ese e lou heniamu.
\q1 
\v 15 Kavakava tauna ena dala na maoro, ia sibona ena ita-ita ai,
\q2 a aonega tauna ese hahealo herevadia e hakala henidiamu.
\q1 
\v 16 Kavakava tauna ena badu e hedinarai haraḡamu,
\q2 a lalo-parara tauna ese heiri-heiri herevadia se lalodiamu.
\q1 
\v 17 E hereva momokanimu tauna ese hereva maoromaorodia e gwaurai hedinaraiamu,
\q2 a gwaurai-hedinarai koikoi tauna ese hereva koikoidia mo e gwauraimu.
\q1 
\v 18 E hereva haraḡa-haraḡamu tauna ena hereva na dare e hegwadamuna heto,
\q2 a aonega tauna malana ese hahemauri e mailaiamu.
\q1 
\v 19 Momokani bibinadia na e mia hanaihanaimu,
\q2 a koikoi malana na asine mia vanahamu.
\q1 
\v 20 Koikoi na dala dikana, e laloa hatamu taudia lalodia ai;
\q2 a namo e laloa hatamu taudia ese moale e davariamu.
\q1 
\v 21 Hahedika ta se kaumu, kara maoromaoro taudia ediai,
\q2 a kara dika taudia e hekwakwanai momomu.
\q1 
\v 22 Hereva koikoidia e gwauraimu bibinadia na Iehova ese e inai henidia badamu,
\q2 a e kara momokanimu taudia na ia ese e moalelaidiamu.
\q1 
\v 23 Lalo-parara tauna ese ena diba e huniamu,
\q2 a kavakava taudia ese edia kavakava e gwauraia hedinaraimu.
\q1 
\v 24 E ḡaukara malaka-malakamu tauna baine lohia,
\q2 a lahedo tauna na bae haḡaukaraia.
\q1 
\v 25 Lalo-hekwarahi ese tau ta e hametauamu,
\q2 a hereva namona ese e hamoaleamu.
\q1 
\v 26 Kara maoromaoro tauna na dika ena amo e raka sirimu,
\q2 a kara dika taudia na edia dala ese e hakaudia kereremu.
\q1 
\v 27 Lahedo tauna ese dinana basine abia,
\q2 a e ḡaukara malaka-malakamu tauna ese taḡa namo-hereana baine abia.
\q1 
\v 28 Kara maoromaoro dalana na mauri,
\q2 a kerere dalana na mase e lao heniamu dalana.
\c 13
\q1 
\v 1 Aonega merona ese tamana ena hahediba herevadia e kamonai henidiamu,
\q2 a ḡonaḡona tawla ese sisiba herevadia se kamonaidiamu.
\q1 
\v 2 Uduna anina amo tau namona ese namo e aniamu,
\q2 a kara heḡui-heḡui tauna ena ura be daḡedaḡe.
\q1 
\v 3 Uduna e nariamu tauna ese ena mauri nahuana e tohoamu,
\q2 a uduna e haḡaia badabadamu tauna na sibona e hahedikamu.
\q1 
\v 4 Lahedo tauna lalona e ura dikadikamu, to ḡau ta se abiamu;
\q2 a e ḡaukara malaka-malakamu tauna na ḡau e henia momomu.
\q1 
\v 5 Kara maoromaoro tauna ese koikoi e inai heniamu,
\q2 a kara dika tauna na ena hemarai karadia daidiai e dadaraiamu.
\q1 
\v 6 Kara maoromaoro ese dala maoromaorona ai e rakamu tauna e gimaiamu,
\q2 a dika ese kara dika tauna e hadarereamu.
\q1 
\v 7 Tau ta sibona taḡa tauna e hegwauraimu, to asi ena ḡau ta;
\q2 ma ta sibona ogoḡami tauna e hegwauraimu, to ena taḡa na bada.
\q1 
\v 8 Tau ta ena mauri ibodohilaina na ena taḡa,
\q2 a ogoḡami tauna na asi ena mauri ibodohilaina ḡauna.
\q1 
\v 9 Kara maoromaoro tauna diarina na mai moalena,
\q2 a kara dika tauna lamepana na baine bodo.
\q1 
\v 10 Se henahua tohomu tauna ena ḡadeḡade ese heiri-heiri e havaraiamu,
\q2 a aonega na sisiba e abia daemu taudia ediai.
\q1 
\v 11 E abi kava kohudia na bae ore haraḡa-haraḡa,
\q2 a ena kohu taidia taidia amo e haboumu tauna ese ena taḡa baine habadaia.
\q1 
\v 12 Helaro mai halahena ese lalo-hisihisi e havaraiamu,
\q2 a e haḡuḡurua urana na mauri auna.
\q1 
\v 13 Hereva e dadaraiamu tauna na sibona e hahedikamu,
\q2 a haheḡani e matauraiamu tauna ese davana baine abia.
\q1 
\v 14 Aonega tauna ena hahediba herevadia na e lohilohia dae maurina,
\q2 mase ena idoa ai basita kau helaoreana.
\q1 
\v 15 Lalo-parara ese lalo-namo e havaraiamu,
\q2 a asi edia heabidadama taudia edia dala na e dika vaitanimu.
\q1 
\v 16 Lalo-parara tauna ese ḡau iboudiai mai aonegana ida e karamu,
\q2 a kavakava tauna ese ena kavakava e heaḡilaiamu.
\q1 
\v 17 Gwaukau tauna dikana ese taunimanima na e hahekwakwanaidia dikadikamu,
\q2 a gwaukau tauna mai momokanina ese hahemauri e mailaiamu.
\q1 
\v 18 Hahediba herevadia se kamonaimu tauna na e ogoḡamunu bona e hemaraimu,
\q2 a sisiba herevadia e abi daemu tauna na e matauraiamu.
\q1 
\v 19 Ura ta anina idavarina na mai gaihona, tau lalona ai;
\q2 a dika irakatanina na kavakava taudia ese e inai henia badamu.
\q1 
\v 20 Aonega taudia ida e raka heboumu tauna na e heaonegamu,
\q2 a kavakava taudia e bamodiamu tauna na baine hekwakwanai.
\q1 
\v 21 Hahedika ese kara dika taudia e ḡavadiamu,
\q2 a kara maoromaoro taudia ahudia na taḡa.
\q1 
\v 22 Tau namona ese garana ahudia e masetanimu;
\q2 a kara dika tauna ena taḡa baine mia, kara maoromaoro tauna ena.
\q1 
\v 23 Ogoḡami tauna ena vahu gunana ese aniani momo e havaraiamu
\q2 a hahemaoro gageva-gagevana ese iena amo e daroa ohomu.
\q1 
\v 24 Se hekwadi momomu tauna ese natuna e inai heniamu,
\q2 a natuna e ura heniamu tauna ese ia matana e hakania balahenimu.
\q1 
\v 25 Kara maoromaoro tauna na bogana e kunumu,
\q2 a kara dika tauna na e hitoloamu.
\c 14
\q1 
\v 1 Aonega ese ena ruma e haginiamu,
\q2 a kavakava ese sibona imana amo e veria garimu.
\q1 
\v 2 Kara maoromaoro ai e rakamu tauna ese Iehova garina egarimu,
\q2 a e raka gageva-gagevamu tauna ese e dadaraiamu.
\q1 
\v 3 Kavakava tauna ena hereva na ia sibona doruna ikwadilaina auna,
\q2 a aonega taudia bibinadia ese bae hamauridia.
\q1 
\v 4 Asi boromakauna gabuna ai, roge na asi anina;
\q2 a boromakau maruanena ena goada ese uma anidia e hahohodiamu.
\q1 
\v 5 Sivarai momokanina e gwauraia hedinaraimu tauna na se koikoimu,
\q2 a sivarai koikoina e gwauraia hedinaraimu tauna na e koikoi momomu.
\q1 
\v 6 Ḡonaḡona tauna ese aonega e tahua kavamu,
\q2 a lalo-parara tauna enai aonega idavarina na haraḡa.
\q1 
\v 7 Kavakava tauna vairana amo ba raka oho,
\q2 badina be unuseni ai aonega herevadia basio davaridia.
\q1 
\v 8 Lalo-parara tauna ena aonega ese ena dala e hahedinarai heniamu,
\q2 a kavakava taudia edia kavakava na e hekoimu.
\q1 
\v 9 Dirava ese kara dika taudia e dadaraidiamu,
\q2 a kara maoromaoro taudia ese ena lalo-namo e moalelaiamu.
\q1 
\v 10 Lalo sibona ese ena idita mamina e dibaiamu,
\q2 bona idau tauna ta na ia ida basie moale hebou.
\q1 
\v 11 Kara dika tauna ena ruma baine heḡiḡi dobi,
\q2 a kara maoromaoro tauna ena kalaga baine namo bada.
\q1 
\v 12 Tau ta vairanai dala ita-itana na maoro,
\q2 a dokona na mase e lao heniamu dalana.
\q1 
\v 13 Kiri lalonai tau ta lalona e hisihisimu,
\q2 bona moale dokona na lalo-hisihisi.
\q1 
\v 14 Raka-muri tauna na sibona ena kara hualIuadia amo bogana baine kunu,
\q2 bona tau namona na ena kara huahuadia amo danu.
\q1 
\v 15 Lalo-duhu tauna ese hereva iboudiai e abi daemu,
\q2 alalo-parara tauna ese e rakalaiamu dalana na e raraia taomu.
\q1 
\v 16 Aonega tauna na sibona nahuana e tohoamu,
\q2 bona kara dika amo e raka sirimu;
\q2 a kavakava tauna ese haheauka e negeamu,
\q2 bona e mata lahuimu.
\q1 
\v 17 Badu haraḡa tauna na e kara kava kara kavamu,
\q2 a mai darana tauna na e haheaukamu.
\q1 
\v 18 Lalo-duhu taudia ahudia na kavakava,
\q2 a lalo-parara taudia kwaradia na aonega ai e havavalaidiamu.
\q1 
\v 19 Kara dika taudia ese kara namo taudia vairadiai e igo dihomu;
\q2 bona kara havara taudia danu, kara maoromaoro taudia ikoukou ai.
\q1 
\v 20 Ogoḡami tauna na ia dekena tauna ese danu se ura heniamu,
\q2 a taḡa tauna turana na hutuma.
\q1 
\v 21 Ia dekena tauna e dadaraiamu tauna na tau dikana,
\q2 a ogoḡami taudia e bogadia hisimu tauna na e moalemu.
\q1 
\v 22 Kara dika e lalo hatamu taudia na kekerere ani?
\q2 Kara namo e lalo hatamu taudia ese hebogahisi bona heabidadama bae davari.
\q1 
\v 23 Hekwarahi iboudiai na mai ahudia,
\q2 a hereva kava ese dabu e havaraiamu.
\q1 
\v 24 Aonega na aonega taudia kwaradia ivavalaidia ḡauna,
\q2 a kavakava na kavakava taudia ihaheralaidia ḡauna.
\q1 
\v 25 Hereva momokani e gwaurai hedinaraimu tauna ese mauri e havaraiamu,
\q2 a hereva koikoi e gwauraimu tauna na tao-tore tauna.
\q1 
\v 26 Iehova igari-henina ese kamonai lava-dae e havaraiamu;
\q2 bona kamonai lava-dae tauna natuna ese roho-mauri gabuna baedavaria.
\q1 
\v 27 Iehova igari-henina na e lohilohimu maurina;
\q2 unu amo masc ena idoa ai basita kau.
\q1 
\v 28 Taunimanima hutuma na pavapava hairaina,
\q2 a lohia asi ena orea taudia na vada e baia.
\q1 
\v 29 Ena badu e halahemu tauna na lalo-parara hereana tauna,
\q2 a badu haraḡa tauna cse kavakava e habadaiamu.
\q1 
\v 30 Lalo-manau ese tau-anina e hamauriamu,
\q2 a vaḡeḡe ese turia e hamanokaiamu.
\q1 
\v 31 Ogoḡami tauna e hahisiamu tauna ese ia ikarana Diravana e ḡonaḡonalaiamu,
\q2 a dabu tauna e bogaia hisimu tauna ese Dirava e matauraiamu.
\b
\q1 
\v 32 Kara dika tauna na ena kara dika ese e hahekwakwanaiamu,
\q2 a kara maoromaoro tauna na ena lalo-maoromaoro ese baineharohoa mauri.
\q1 
\v 33 Aonega na lalo-parara tauna lalonai e miamu,
\q2 a kavakava taudia lalodia ese asie dibaiamu.
\q1 
\v 34 Kara maoromaoro ese bese ta e hanamoamu,
\q2 a kara dika ese orea ta e hahemaraiamu.
\q1 
\v 35 E kara aonegamu hesiai tauna na hanua pavapavana ese e lalo-namo heniamu;
\q2 a ena badu na hemarai karadia e karamu tauna latanai e kaumu.
\c 15
\q1 
\v 1 Haere manauna ese badu e laoa ahumu,
\q2 a gwau turianki ese badu e havaraiamu.
\q1 
\v 2 Aonega tauna malana amo aonega herevadia na e hetuturumu,
\q2 a kavakava taudia ududia amo kavakava herevadia na e aru lasimu.
\q1 
\v 3 Iehova matana ese gabu iboudiai e nenediamu,
\q2 dika taudia bona namo taudia e itadia taomu.
\q1 
\v 4 Mala manadana na mauri auna ta,
\q2 a mala gageva-gagevana ese dara doko e havaraiamu.
\q1 
\v 5 Kavakava tauna ese tamana ena hahediba e dadaraiamu,
\q2 a sisiba herevadia e hakala henidiamu tauna na lalo-parara tauna.
\q1 
\v 6 Kara maoromaoro tauna ena ruma ai na kohu momo,
\q2 a kara dika tauna ena davari-davari ḡaudia ese ena hekwakwanai e havaraiamu.
\q1 
\v 7 Aonega na aonega taudia bibinadia ese e piuamu,
\q2 a kavakava taudia lalodia na unu asie kara tomamu.
\q1 
\v 8 Kara dika tauna ena boubou ḡauna na Iehova ese e ihi-ihiraiamu,
\q2 a kara maoromaoro tauna ena ḡuriḡuri na ia ese e moalelaiamu.
\q1 
\v 9 Kara dika tauna ena dala na Iehova ese e ihi-ihiraiamu,
\q2 a kara maoromaoro e ḡavaiamu tauna na ia ese e lalokau heniamu,
\q1 
\v 10 Mata-hakani auka-hereana na dala e rakataniamu tauna enai;
\q2 sisiba e inai heniamu tauna na baine mase.
\q1 
\v 11 Mase gabuna bona dobu masemase gabuna na hehedina-rarai, Iehova vairanai;
\q2 matona, taunimanima lalodia na ienai eme hedinarai ḡuḡuru.
\q1 
\v 12 Ḡonaḡona tauna na se uramu bae sisiba henia;
\q2 ia na aonega tawla dekena basinela.
\q1 
\v 13 Lalo moale na vaira namo ai e hedinaraimu,
\q2 a lalo hisihisi ese dara doko e havaraiamu.
\q1 
\v 14 Lalo-parara tauna lalona ese aonega e tahuamu,
\q2 a kavakava taudia ududia ese kavakava e aniamu.
\q1 
\v 15 Hisi e animu tauna ena mauri dinadia iboudiai na didika,
\q2 a lalo-moale tauna na bogana e kunu hanaihanaimu.
\q1 
\v 16 Ḡau maraḡi-maraḡina Iehova igari-henina ida ese
\q2 taḡa badana mai hekwakwanaina ida e hereaiamu.
\q1 
\v 17 Aniani asi ianimaina lalokau e miamu gabuna ai ese
\q2 vamu manoka-manokana heinai-hehenina ai e animu na e hereaiamu.
\q1 
\v 18 Badu haraḡa tauna ese heiri-heiri e havaraiamu,
\q2 a badu ai e halahemu tauna ese heiri-heiri e haumaia tarimu.
\q1 
\v 19 Lahedo tauna ena dala na au ḡiniḡini ai e bubunimu,
\q2 a kara maoromaoro tauna ena dala na dala avohana.
\q1 
\v 20 Aonega merona ese tamana e hamoaleamu,
\q2 a kavakava tauna ese sinana e dadaraiamu.
\q1 
\v 21 Asi darana tauna ese kavakava e moalelaiamu,
\q2 a lalo-parara tauna na e raka maoromaoromu.
\q1 
\v 22 Ta se hahealomu negana ai, taunimanima edia lalo-hata ḡaudia asie tubu namonamomu;
\q2 a hahealo taudia na hoho negana ai na e tubu ḡoevaḡoevamu.
\q1 
\v 23 Haere maorona ese taunimanima e hamoaleamu,
\q2 bona nega korikorina ai e gwauraiamu herevana be daka namo!
\q1 
\v 24 Aonega tauna ena dala ese mauri e dae heniamu,
\q2 mase ena dobu gabuna ai basine kau helaoreana.
\q1 
\v 25 Iehova ese hekokoroku tauna ena ruma e veria garimu,
\q2 a vabu ena tano hetoadia e gimadiamu.
\q1 
\v 26 Kara dika taudia edia lalo-hadai na Iehova ese e inai henidiamu,
\q2 a lalo-ḡoevaḡoeva taudia edia hereva na ia ese e moalelaimu.
\q1 
\v 27 Mata-ḡaniḡani tauna ese hekwakwanai e havaraiamu ena ruma taudia ediai,
\q2 a henitao dikadia e inai henimu tauna na baine mauri.
\q1 
\v 28 Kara maoromaoro tauna ese lalona e hadaia namonamomu ede baine haere toma,
\q2 a kara dika tauna uduna amo hereva dikadia na e aru lasimu.
\q1 
\v 29 Iehova bona kara dika taudia padadia na daudau,
\q2 a kara maoromaoro tauna ena ḡuriḡuri ia ese e kamonaiamu.
\q1 
\v 30 Mata diaridia ese tau lalona e hamoaleamu,
\q2 bona hari namodia ese turia e ha-aukadiamu.
\q1 
\v 31 Sisiba herevadia namodia e hakala henimu tauna na
\q2 aonega taudia bogaragidiai baine noho.
\q1 
\v 32 Hahediba se abi daemu tauna na sibona e hedadaraimu,
\q2 a sisiba herevadia e kamonaimu tauna lalona na e pararamu.
\q1 
\v 33 Iehova igari-henina na aonega idavarina badina,
\q2 bona manau ese heimodai e gunalaiamu.
\c 16
\q1 
\v 1 Lalo-hadai be taunimanima edia,
\q2 a mala ena haere na Iehova ena amo.
\q1 
\v 2 Tau ta ena dala iboudiai na ḡoḡoeva, ia sibona vairanai;
\q2 a Iehova ese lalo e tohodiamu.
\q1 
\v 3 Emu ḡaukara idounai na Iehova imana ai bavatoa,
\q2 bena emu lalo-hata ḡaudia bae gini hedai.
\q1 
\v 4 Iehova ese ḡau iboudiai vada e kara, ta ta mai badidia;
\q2 kara dika tauna danu vada e karaia, hekwakwanai negana ena.
\q1 
\v 5 Hekokoroku taudia iboudiai na Iehova ese e inai henidia badamu;
\q2 ba diba momokani, idia ta na mata-hakani amo basine roho mauri.
\q1 
\v 6 Hebogahisi bona heabidadama daidiai kara dika na e herohomu,
\q2 bona Iehova igari-henina ai tau ta na kara dika amo e raka ohomu.
\q1 
\v 7 Tau ta ena kara ese Iehova e hamoaleamu negana ai,
\q2 ia na inaina ida e herohemainomu.
\q1 
\v 8 Kohu maraḡina mai kara maoromaorona ida be namo;
\q2 kohu bada-hereadia kara gageva-gagevadia ida na dika.
\q1 
\v 9 Tau ta lalona ese ena dala e laloa hatamu,
\q2 a Iehova ese ia aena e hakaudiamu.
\q1 
\v 10 Oru edia hereva na pavapava uduna amo e lasimu;
\q2 hahemaoro ai ia uduna na se kereremu.
\q1 
\v 11 Hahetoho ḡauna bona metau idavarina ḡauna maoromaorodia na Iehova ena;
\q2 hahetoho auridia moda ai mimia iboudiai na iena ḡaukara.
\q1 
\v 12 Pavapava ese kara dika ikarana e inai henia badamu,
\q2 badina be terono na kara maoromaoro ai e ginimu.
\q1 
\v 13 Hereva maoromaoro bibinadia na hanua pavapavana ese e moalelaidiamu;
\q2 ia ese hereva maoromaorodia e gwauraimu tauna na e lalokau heniamu.
\q1 
\v 14 Pavapava ena badu na mase ena gwaukau tauna;
\q2 aonega tauna ese lalona baduna baine hakerua.
\q1 
\v 15 Pavapava vairana diarina ai na mauri;
\q2 ena lalo-namo na medu gabedia e hadihodiamu dagadagadia na heheto.
\q1 
\v 16 Aonega iabina ese \it gold\it* iabina e hereaiamu;
\q2 lalo-parara abi-hidina ese \it silver\it* iabi-hidula e hereaiamu.
\q1 
\v 17 Kara maoromaoro tauna ena dala avohana na kara dika amo e raka sirimu;
\q2 ena dala nahuana e tohoamu tauna na sibona e hahemaurimu.
\q1 
\v 18 Heaḡi ese hahebuatari dalana e lailaiamu;
\q2 hekokoroku ese moru dalana e lailaiamu.
\q1 
\v 19 Ogoḡami taudia ida manau ai ba noho be namo;
\q2 heaḡi taudia ida dadidadi kohudia ba haridia na dika.
\q1 
\v 20 Hereva e kamonaimu tauna ena namo baine bada;
\q2 Iehova e abidadama heniamu tauna na e moalemu.
\q1 
\v 21 Lalona e aonegamu tauna na lalo-parara tauna e gwauraiamu,
\q2 bona hereva namodia ese lalo-ani e habadaiamu.
\q1 
\v 22 Aonega na e lohilohiamu maurina, aonega tauna enai;
\q2 a kavakava na mata-hakani ḡauna, kavakava taudia ediai.
\q1 
\v 23 Aonega tauna lalona ese ena hereva e hamaoromaorodiamu,
\q2 bona bibinana na lalo-ani herevadia e hadibadiamu.
\q1 
\v 24 Hereva manadadia na bada-ranuna na heto;
\q2 gaihona na lauma enai, bona goadana na tau-anina enai.
\q1 
\v 25 Tau ta ese dala ta baine haeroa, dala namona na heto;
\q2 a ḡau be dokona na mase dalana.
\q1 
\v 26 Ḡaukara tauna na bogana helaoreana e ḡaukara goadamu;
\q2 ia uduna ese e ha-uraiamu.
\q1 
\v 27 Bonegita tauna ese kara dika e laloa hatamu;
\q2 ena hereva na lahi ḡaraḡara na heto.
\q1 
\v 28 Lalo gageva-gageva tauna ese heiri-heiri e havaraia rohorohomu;
\q2 hemaunu tauna ese e hetura hehenimu taudia na e hapararadiamu.
\q1 
\v 29 Daḡedaḡe tauna ese ia dekena tauna e koiamu,
\q2 bona dala dia namo ai e hakauamu.
\q1 
\v 30 Matana e hakunumaiamu tauna ese kara gageva-gagevadia e lalo hatamu;
\q2 bibinana e hakapumu tauna ese kara dika e havaraiamu.
\q1 
\v 31 Hui buruka na havava ḡauna mai hairaina;
\q2 noho maoromaoro dainai e varamu.
\q1 
\v 32 Badu ai e halahemu tauna ese goada tauna e hereaiamu,
\q2 bona sibona lalona e biaguamu tauna ese hanua ta e hadarereamu tauna na e hereaiamu.
\q1 
\v 33 Mari na taunimanima ese e karaiamu,
\q2 a Iehova ese anina e havaraiamu.
\c 17
\q1 
\v 1 Aniani kakorona asi reḡereḡe gabuna ai ese
\q2 aria badana mai heiri-heirina na e hereaiamu.
\q1 
\v 2 Hesiai tauna e kara aonegamu ese
\q2 ruma biaguna natuna hemarai karadia e karamu na baine biagua,
\q2 bona ahuna baine abia, tadikaka ta na heto.
\q1 
\v 3 Keikei na \it silver\it* ena, bona lahi na \it gold\it* ena,
\q2 bona Iehova ese taunimanima lalodia e tohodiamu.
\q1 
\v 4 Kara dika tauna ese dika bibinadia e kamonai henidiamu;
\q2 bona koikoi tauna ese mala gageva-gagevana e hakala heniamu.
\q1 
\v 5 Ogoḡami taudia e ḡonaḡonalaidiamu tauna ese ia ikarana Diravana na e ihi-ihiraiamu;
\q2 hahehisi karadia e moalelaiamu tauna ese mata-hakani amo basine roho mauri.
\q1 
\v 6 lahu kwaradia ihavavalaidia na tubudia;
\q2 bona memero ihahairaidia na tamadia.
\q1 
\v 7 Hereva ḡoevadia na asie heḡeregere kavakava tauna uduna ai,
\q2 bona koikoi herevadia danu lohia uduna ai.
\q1 
\v 8 Koikoi henitaona na mea nadina na heto, e henimu tauna ese unu e laloa tomamu;
\q2 ena kara iboudiai anidia e varamu.
\q1 
\v 9 Dika e gwau taomu tauna ese lalokau e tahuamu,
\q2 a sivarai e piuamu tauna ese hetura e hadikaiamu.
\q1 
\v 10 Sisiba herevana tamona ese lalo-parara tauna lalona e gwadaia dobumu,
\q2 a hekwadi sinahu-ta ese kavakava tauna asie haberoamu.
\q1 
\v 11 Kara dika tauna ese daḡedaḡe e tahuamu;
\q2 gwaukau tauna mai daḡedaḡena ida na ia bae siai henia.
\q1 
\v 12 Tau ta ese bea hahinena, natuna vada e dadidia ḡauna, ida bae hedavari na sisina namo,
\q2 a kavakava tauna ida bae hedavari na dika herea.
\q1 
\v 13 Tau ta ese dika bema haloua, namo davana,
\q2 dika ese iena ruma basine rakatania.
\q1 
\v 14 Heatu matamana na ranu ikehona na heto;
\q2 taunabunai heai do basine vara ai ba raka oho.
\q1 
\v 15 Kara dika tauna maorona baine gwauraia tauna
\q2 bona kara maoromaoro tauna dikana baine gwauraia tauna
\q2 raruosi na Iehova ese e inai henidia badamu.
\q1 
\v 16 Badina be dahaka kavakava tauna imana ai aonega ihoilaina davana baine mia,
\q2 a ia be asi darana?
\q1 
\v 17 Tau ta turana ese nega iboudiai e lalokau heniamu;
\q2 bona tadikakana ena lalokau na dika negana ai e hedinaraimu.
\q1 
\v 18 Asi darana tauna ese gwauhamata ḡauna e henimu;
\q2 ia dekena tauna vairanai gwauhamata toana ai e laomu.
\q1 
\v 19 Kara dika e ura heniamu tauna ese heiri-heiri danu e ura heniamu;
\q2 bona ena iduara atai ai e karaiamu tauna ese hahebua-tari e tahuamu.
\q1 
\v 20 Lalo-gagevagageva tauna na ena ḡaukara anidia asie varamu,
\q2 bona malana mai koikoina tauna na hahehisi ai e morumu.
\q1 
\v 21 Lalo-duhu merona ese tamana lalona e hahisihisiamu;
\q2 kavakava merona tamana na se moalemu.
\q1 
\v 22 Lalo-moale na muramura namona,
\q2 a lalo-metau ese turia e hamanokadiamu.
\q1 
\v 23 Kara dika tauna ese koikoi henitaona e abia hehunimu,
\q2 hahemaoro ihagagevana totona.
\q1 
\v 24 Lalo-parara tauna ese aonega e haḡereamu,
\q2 a kavakava tauna ese tanobada dokodia e roha henia laomu.
\q1 
\v 25 Kavakava merona ese tamana lalona e hahisihisiamu,
\q2 bona e havaraia hahinena lalona e hadikaiamu.
\q1 
\v 26 Kara maoromaoro tauna matana ihakanina na dia namo;
\q2 lalo-ihunu taudia bae dadabadia na dika.
\q1 
\v 27 Se hereva momomu tauna na mai aonegana;
\q2 se badu-haraḡamu tauna na mai ena lalo-parara.
\q1 
\v 28 Kavakava tauna basine hereva negana ai, bae laloa ia na aonega tauna;
\q2 uduna baine hakapua negana ai, baeto ia na lalo-parara tauna.
\c 18
\q1 
\v 1 E haheidaumu tauna ese sibona ena ura e tahuamu;
\q2 lalo-hadai namodia iboudiai e inai henimu.
\q1 
\v 2 Kavakava tauna ese lalo-parara se moalelaiamu;
\q2 ia sibona ena lalo-hadai igwauraina mo e moalelaiamu.
\q1 
\v 3 Kara dika e maimu negana ai, heihi-ihirai danu e maimu;
\q2 heḡonaḡonalai amo hedadarai e varamu.
\q1 
\v 4 Tau ta uduna herevadia na ranu dobudia na heheto;
\q2 aonega na e lohilohiamu, e aru goadagoadamu.
\q1 
\v 5 Kara dika tauna ibeiana na dia namo,
\q2 bona kara maoromaoro tauna idadaraina danu dia namo.
\q1 
\v 6 Kavakava tauna bibinana ese heiri-heiri e havaraiamu,
\q2 bona uduna ese hedadaba e vaveamu.
\q1 
\v 7 Kavakava tauna uduna na ia ihabua-tarina,
\q2 bona bibinana na ia sibona idoalaina ḡau.
\q1 
\v 8 Hemaunu tauna ena hereva na aniani mai gaihodia na heheto;
\q2 idia na boga lalonai e laomu.
\q1 
\v 9 Ena ḡaukara ai e lahedomu tauna na
\q2 hahebua-tari tauna tadikakana.
\q1 
\v 10 Iehova ladana na kohoro aukana;
\q2 kara maoromaoro tauna na ia lalonai e heau vareaimu bena e maurimu.
\q1 
\v 11 Taḡa tauna ena taḡa na hanua aukana na heto ia ena,
\q2 bona maḡu badana na heto, ia igimana.
\q1 
\v 12 Tau lalona ena heaḡi ese hahebua-tari e gunalaiamu,
\q2 a lalo-manau ese heimodai e gunalaiamu.
\q1 
\v 13 Tau ta do se kamonai negana ai na e haeremu,
\q2 una na ena kavakava bona ena hemarai.
\q1 
\v 14 Tau ta lalona na gorere ai baine haheauka;
\q2 a dara-doko ai daika baine haheauka?
\q1 
\v 15 Mai darana tauna lalona ese lalo-parara e davariamu,
\q2 bona aonega tauna taiana ese lalo-parara e tahuamu.
\q1 
\v 16 Tau ta ena herahia ḡauna ese ena dala e lailaiamu,
\q2 lohia vairadiai e hakaudia vareaimu.
\q1 
\v 17 E hereva gunamu tauna ena hereva mamina na momokani,
\q2 ela bona ta ma bainema, anina baine tahu henia.
\q1 
\v 18 Mari ese hepapahuahu e hadokodiamu,
\q2 bona hahemaoro na siahu taudia padadiai e karaiamu.
\q1 
\v 19 Tadikakana ese e kahaiamu tauna na hanua aukana na heto,
\q2 a heiri-heiri na ruma aukana auridia na heheto.
\q1 
\v 20 Tau ta uduna huahuana amo e hahehonumu;
\q2 bibinana anina amo e hahehonumu.
\q1 
\v 21 Mase bona mauri na mala siahuna lalonai mimia;
\q2 e ura heniamu taudia ese huahuana bae ani.
\q1 
\v 22 Hahine e adavaiamu tauna ese namo e davariamu,
\q2 Iehova ena hahenamo e abiamu.
\q1 
\v 23 Ogoḡami taudia na e noinoimu,
\q2 a taḡa taudia na hereva aukadia amo e haeremu.
\q1 
\v 24 Haida na e hetura koikoimu,
\q2 a hetura korikori tauna ena hedaro-boubou ese tadikaka ena hedaro-boubou e hereaiamu.
\c 19
\q1 
\v 1 Ogoḡami tauna ena lalo-maoromaoro ai e rakamu ese
\q2 kavakava tauna mai ena hereva gageva-gagevadia na e hereaiamu.
\q1 
\v 2 Tau ta asi aonegana baine noho na dia namo;
\q2 e raka haraḡa-haragamu tauna ese ena dala e reaiamu.
\q1 
\v 3 Tau ta ena kavakava ese ena dala e hakererea vaitanimu negana ai,
\q2 ia ese Iehova e lalo dika heniamu.
\q1 
\v 4 Taḡa ese hetura taudia matamatadia momo e mailaidiamu,
\q2 a ogoḡami tauna na turana ese e rakataniamu.
\q1 
\v 5 Gwaurai-hedinarai koikoi tauna ese mata-hakani basine reaia;
\q2 hereva koikoi tauna na basine roho mauri.
\q1 
\v 6 Hutuma ese harihari-bada tauna ena lalo-namo e tahuamu,
\q2 bona taunimanima iboudiai na herahia e henimu tauna turana.
\q1 
\v 7 Ogoḡami tauna na tadikakana iboudiai ese e inai heniamu;
\q2 benaini, turana ese e heautaniamu, dauha e laomu;
\q2 e boi henidiamu, to idia na lasihidia.
\q1 
\v 8 Aonega e abiamu tauna na sibona e heura-henimu;
\q2 lalo-parara e abia tarika-tarikamu tauna na ena namo baine bada.
\q1 
\v 9 Hahebade koikoi tauna ese mata-hakani basine reaia;
\q2 bona hereva koikoi tauna na baine mase.
\q1 
\v 10 Kavakava tauna baine noho loḡea na dia namo;
\q2 bona hesiai tauna ese lohia baine biagudia na dika herea.
\q1 
\v 11 Lalo-maoromaoro dainai tau ta na badu ai baine halahe,
\q2 bona kara dika ilalo-negena na ia hairaina.
\q1 
\v 12 Pavapava ena badu na leona e ḡoumu na heto;
\q2 ena lalo-namo na hunu rei latanai na heto.
\q1 
\v 13 Kavakava merona ese tamana e hadikaia vaitanimu;
\q2 bona hahine ena hepapahuahu na medu e hetuturu hanaihanaimu na heto.
\q1 
\v 14 Ruma bona taḡa na tamada edia amo ta abimu;
\q2 a mai darana hahinena na Iehova ena amo.
\q1 
\v 15 Lahedo ese taunimanima e hamahutadia hedavauhemu,
\q2 bona lahedo tauna na baine hitolo.
\q1 
\v 16 Haheḡani e badinaiamu tauna na baine mauri,
\q2 a hereva e dadaraiamu tauna na baine mase.
\q1 
\v 17 Ogoḡami taudia e bogadia hisimu tauna ese Iehova enai e heni torehaimu;
\q2 Iehova ese ena kara davana do baine henia.
\q1 
\v 18 Natumu matana ba hakania, helaro na doini e miamu negana ai;
\q2 lalomu basio hadaia ia baine dika.
\q1 
\v 19 Badu dikadika tauna ese davana baine abia;
\q2 badina be boma hamauria, to ma boma karaia lou.
\q1 
\v 20 Hahealo herevadia ba kamonaidia, hahediba herevadia bavabidia dae;
\q2 unu amo aonega bavabia, nega gabena ena.
\q1 
\v 21 Tau ta ena lalo-hadai na momo,
\q2 a Iehova ena ura mo baine gini.
\q1 
\v 22 Tau ta enai ta ura heniamu ḡauna na heabidadama;
\q2 ogoḡami tauna ena namo ese koikoi tauna ena e hereaiamu.
\q1 
\v 23 Iehova igari-henina ese mauri dalana ai e hakauda laomu;
\q2 ienai e miamu tauna na lalona baine heḡereḡere,
\q2 hahedika ta ienai basine kau.
\q1 
\v 24 Lahedo tauna ese imana na dihu ai e dau dobimu,
\q2 bona basine abia isi uduna ai.
\q1 
\v 25 Ḡonaḡona tauna ba botaia, bena lalo-duhu taudia lalodia bae parara;
\q2 lalo-parara tauna ba sisiba henia, bena ena aonega baine bada.
\q1 
\v 26 Tamana e daḡedaḡe heniamu bona sinana e luluamumerona ese
\q2 hemarai bona gwaugwau e havaradiamu.
\q1 
\v 27 Natugu e, hahediba herevadia ikamonaina boma hadokoa,
\q2 bena aonega herevadia amo ba raka oho danu.
\q1 
\v 28 Gwaurai-hedinarai asi anina tauna ese hahemaoro e ḡonaḡonalaiamu,
\q2 bona kara dika tauna uduna ese dika badana e hadonoamu.
\q1 
\v 29 Ḡonaḡona taudia davadia na vada e heḡaeḡaelai;
\q2 bona kavakava taudia dorudia danu bae kwadidia hiruka-hiruka.
\c 20
\q1 
\v 1 Vine ranuna na ḡonaḡona ḡauna, kekero muramurana na heai ḡauna:
\q2 ediai e kereremu tauna na asi aonegana.
\q1 
\v 2 Pavapava ena badu mai garina na leona e ḡoumu na heto;
\q2 e habaduamu tauna ese ena mauri e negeamu.
\q1 
\v 3 Heatu amo e raka sirimu tauna na bae imodaia,
\q2 a kavakava taudia iboudiai bae heai.
\q1 
\v 4 Lahedo tauna ese hadohado negana ai tano se ruaiamu;
\q2 taboro negana ai baine hetahu, a ḡau ta basine davaria.
\q1 
\v 5 Taunimanima ta ena lalo-hadai na ranu dobuna na heto;
\q2 a lalo-parara tauna ese baine veria lasi.
\q1 
\v 6 Taunimanima hutuma ese sibodia edia heabidadama egwauraimu,
\q2 a kara momokani tauna na daika ese baine davaria diba?
\q1 
\v 7 Kara maorormaoro tauna na ena lalo-maoromaoro ai e rakamu;
\q2 ia murinai natuna danu bae namo.
\q1 
\v 8 Hanua pavapavana na hahemaoro gabuna ai helaina ai
\q2 ia matana ese dika baine tapoa hidi.
\q1 
\v 9 Daika baine hereva diba, baineto:
\q2 Lalogu vada na haḡoevaia,
\q2 egu dika amo vada name ḡoeva.
\q1 
\v 10 Metau auridia mai koikoidia bona hahetoho ḡaudia mai koikoidia,
\q2 ruaosi Iehova ese e inai henidia badamu.
\q1 
\v 11 Mero maraḡina ena kara amo sibona e hahedinaraimu,
\q2 ena kara na ḡoḡoeva-ḡoḡoeva bona mamaoro-mamaoro eiava?
\q1 
\v 12 E hakalamu taiana bona e roharohamu matana na
\q2 Iehova ese ruaosi vada e karadia.
\q1 
\v 13 Mahuta basio ura henia, ba ogoḡami na garina;
\q2 matamu a hapapadia, bena aniani momo bavabia.
\q1 
\v 14 Hoihoi tauna na e tomu “Ina na dika, ina na dika”,
\q2 bena e raka ohomu mai heaḡina ida.
\q1 
\v 15 \it Gold\it* bona dava-bada nadidia na mimia;
\q2 a aonega bibinadia na herahera nadina namo-hereana.
\q1 
\v 16 Tau ta ese idau tauna dainai bema gwau hamata, ena hahedoki na bavabia;
\q2 bona idau bese taudia daidiai bema gwau hamata, iena amo gwauhamata toana bavabia.
\q1 
\v 17 Koikoi amo e abiamu anianina na mai gaihona, iabina tauna uduna ai;
\q2 a gabeamo ia uduna na miri ai baine honu.
\q1 
\v 18 Hahealo amo lalo-hata e ginimu;
\q2 hahekau mai aonegana amo ba tuari.
\q1 
\v 19 E hesivarai loaloamu tauna ese hereva hehunidia e hahedinaraimu;
\q2 taunabunai hereva kavakavadia e gwauraimu tauna ida basio hetura.
\q1 
\v 20 Ta ese tamana eiava sinana bema uduguiraia,
\q2 ena lamepa baine bodo, baine dibura masemase.
\q1 
\v 21 Matamana ai e abia haraḡamu ahuna na
\q2 dokona ai anina namona basine vara.
\q1 
\v 22 Basioto “Dika baina davalaia”;
\q2 Iehova ba naria, ia ese baine durumu.
\q1 
\v 23 Metau auridia mai koikoidia na Iehova ese e inai henidia badamu:
\q2 bona hahetoho ḡaudia mai koikoidia na dia nanamo.
\q1 
\v 24 Taunimanima ena raka na Iehova ese e reḡuamu;
\q2 benaini, ena dala ede baine dibaia toma?
\q1 
\v 25 Tau ta baine hereva haraḡa, baineto “Ina na helaḡa”,
\q2 bena baine gwau hamata murinai baine haeroa,
\q2 una na idoa ienai.
\q1 
\v 26 Pavapava mai aonegana ese dika taudia na e tapodia hidimu,
\q2 bona edia dika davadia e henidiamu.
\q1 
\v 27 Taunimanima laumana na Iehova ena lamepa,
\q2 ia lalona idoinai itahuna.
\q1 
\v 28 Heabidadama bona kara maoromaoro ese hanua pavapavana na e hamauriamu;
\q2 ena terono na hahemaoro ḡoevaḡoeva ese e ha-aukaiamu.
\q1 
\v 29 Eregabe taudia hairaidia na edia goada,
\q2 a iahu hairaidia na huidia burukadia.
\q1 
\v 30 Hekwadi berodia ese dika e abi ohomu;
\q2 bona hedadaba ese taunimanima lalodia e haḡoevadiamu.
\c 21
\q1 
\v 1 Hanua pavapavana lalona na sinavai na heto, Iehova imana ai:
\q2 ena ura gabuna e ha-arua laomu.
\q1 
\v 2 Tau ta ena dala iboudiai na mamaoro-mamaoro ena ita-ita ai;
\q2 a Iehova ese ia lalona e dibaiamu.
\q1 
\v 3 Kara maoromaoro bona hahemaoro ḡoevaḡoeva na Iehova ese e abidia dae badamu,
\q2 a boubou ḡaudia na e abidia dae maraḡimu.
\q1 
\v 4 Heaḡi matadia bona hekokoroku lalona,
\q2 kara dika taudia edia lamepa,
\q2 unu na didika.
\q1 
\v 5 Ḡaukara malaka-malaka tauna ena lalo-hadai ese anidia e havara badamu,
\q2 a lalo-haraga taudia iboudiai na bae dabu.
\q1 
\v 6 Koikoi malana amo e abimu kohudia na
\q2 ninoa lai ese e odaia ohomu na heto;
\q2 una na mase idoana.
\q1 
\v 7 Kara dika taudia na edia daḡedaḡe ese baine darodia oho,
\q2 badina be kara maoromaoro ikarana asie uramu.
\q1 
\v 8 Kerere tauna ena dala na gageva-gageva,
\q2 a lalo-ḡoevaḡoeva tauna ena kara na maoromaoro.
\q1 
\v 9 Tau ta abikau ai baine noho be namo;
\q2 a hereva momo hahinena ida ruma ai bae noho bou na dika.
\q1 
\v 10 Kara dika tauna laumana ese dika e ura heniamu,
\q2 bona dekena tauna se bogaia hisimu.
\q1 
\v 11 Ḡonaḡona tauna matana e hakaniamu negana ai,
\q2 lalo-duhu tauna lalona e heaonegamu;
\q1 aonega tauna e hadibaiamu negana ai,
\q2 ena lalo-parara e habadamu.
\q1 
\v 12 Kara maoromaoro tauna ese kara dika tauna ena ruma e itaia taomu;
\q2 kara dika taudia na e hahebua tarimu.
\q1 
\v 13 Ogoḡami taudia edia taitai se hakala henimu tauna na
\q2 sibona baine tai lolololo a ta basine kamonai.
\q1 
\v 14 Herahia ḡauna e heni hehunimu ese badu e laoa ahumu;
\q2 bona koikoi henitaona e heni hehunimu ese badu aukana e hamanokaiamu.
\q1 
\v 15 Hahemaoro ḡoevaḡoevana ese kara maoromaoro taudia na e hamoalediamu,
\q2 a kara dika taudia na kudoudia e hahetahadiamu.
\q1 
\v 16 Lalo-parara dalana amo e raka ohomu tauna ese
\q2 mase taudia edia hebou ai baine noho.
\q1 
\v 17 Moale-kava e ura heniamu tauna na baine ogoḡami;
\q2 bona vine ranuna bona dehoro e ura henidiamu tauna na basine taḡa.
\q1 
\v 18 Kara dika tauna na kara maoromaoro tauna ibodohilaina,
\q2 bona kara koikoi tauna ese kara momokani tauna e bodohiamu.
\q1 
\v 19 Tau ta tano ḡaḡaena ai baine noho be namo,
\q2 a e hereva momomu bona e maumaumu hahinena ida baine noho na dika.
\q1 
\v 20 Kohu namo-hereadia bona dehoro na aonega tauna ena ruma ai mimia,
\q2 a kavakava tauna ese e ha-orediamu.
\q1 
\v 21 Kara maoromaoro bona hebogahisi e ḡavamu tauna ese
\q2 mauri bona kara maoromaoro bona heimodai e davarimu.
\q1 
\v 22 Aonega tauna ese goada taudia edia hanua maḡuna amo e dada daemu;
\q2 bona edia ruma aukana, e abidadama heniamu ḡauna, e ḡiḡia dobimu.
\q1 
\v 23 Uduna bona malana e naridiamu tauna na
\q2 hekwakwanai amo e roho maurimu.
\q1 
\v 24 Heaḡi bona hekokoroku tauna na “gonaḡona tauna” e gwauraiamu;
\q2 ia na e kara heaḡi-heaḡimu.
\q1 
\v 25 Lahedo tauna ena ura ese e hamaseamu,
\q2 badina be ia imana na se uramu ḡaukara.
\q1 
\v 26 Dina idoinai kara dika tauna na e heḡahusimu,
\q2 a kara maoromaoro tauna ese ḡau e henimu, se rumu.
\q1 
\v 27 Kara dika tauna ena boubou ḡauna na dika rohoroho,
\q2 a mai ena lalo-hadai dikana ida e mailaiamu negana ai ena dikana bada herea.
\q1 
\v 28 Gwaurai-hedinarai koikoi tauna na baine mase,
\q2 a kamonai tauna ena hereva do baine hesiriu.
\q1 
\v 29 Kara dika tauna ese vairana e ha-aukaiamu;
\q2 a kara maoromaoro tauna ese ena dala e haerodiamu.
\q1 
\v 30 Asi aonega ta, asi lalo-parara ta, asi lalo-hadai ta ese
\q2 Iehova baine laoa ahu diba.
\q1 
\v 31 Hosi e heḡaeḡaelaiamu, tuari dinana inanatalaina;
\q2 a kwalimu na Iehova enai.
\c 22
\q1 
\v 1 Lada namona iabi-hidina ese taḡa badadia iabi-hididia e hereadiamu,
\q2 bona lalo-namo ese\it silver\it* eiava \it gold\it* e hereadiamu.
\q1 
\v 2 Taga taudia bona ogoḡami taudia na e hegogo heboumu;
\q2 Iehova ese iboudiai e karadia.
\q1 
\v 3 Lalo-parara tauna ese dika e itaiamu, bena e komumu;
\q2 a lalo-duhu taudia na e raka e laomu, bena e hekwakwanaimu.
\q1 
\v 4 Manau bona Iehova igari-henina davadia na
\q2 taḡa bona heimodai bona mauri.
\q1 
\v 5 Ginigini bona idoa na lalo-gagevagageva tauna ena dala ai mimia;
\q2 a sibona e hegimamu tauna na dauhai baine noho.
\q1 
\v 6 Meromero bema rakalaia dalana na ba hadibalaia;
\q2 bena baine buruka negana ai basine rakatania.
\q1 
\v 7 Taga tauna ese ogoḡami tauna e biaguamu,
\q2 bona abi-torehai tauna ese e henia torehai tauna isiaina e lao heniamu.
\q1 
\v 8 Hahemaoro gageva-gageva e hadoamu tauna ese hahehisi anina baine abia,
\q2 bona ena badu auna na baine kwaidu.
\q1 
\v 9 Ani gaga-isi tauna na bae hanamoa,
\q2 badina be ana aniani na ogoḡami taudia ida e ania heboumu.
\q1 
\v 10 Ḡonaḡona tauna ba lulua lasi, bena heiri-heiri na baine ore,
\q2 bona heai bona gwaugwau bae doko.
\q1 
\v 11 Lalo-ḡoevaḡoeva e ura heniamu bona e hereva manadamu tauna na hanua pavapavana turana ai bainela.
\q1 
\v 12 Iehovas matana ese lalo-parara e itaia taomu;
\q2 a koikoi tauna ena hereva na ia ese e ḡiḡi dobimu.
\q1 
\v 13 Lahedo tauna na e tomu “Leona ta na murimuri ai;
\q2 ariara ai baine alagu mase”.
\q1 
\v 14 Ariara hahinena uduna na guri dobu-hereana;
\q2 Iehova ese e badu heniamu tauna na ia lalonai baine moru dobi.
\q1 
\v 15 Kavakava na meromero lalonai mia;
\q2 a mata-hakani auna ese baine lulua lasi dauhai.
\q1 
\v 16 Ogoḡami taudia edia amo e dadidadimu, sibona ena taḡa ihabadana totona,
\q2 eiava taḡa taudia e harihari henidiamu,
\q2 tauna na do baine dabu mo.
\b
\q1 
\v 17 Taiamu a hakala, aonega taudia edia hereva ba kamonaidia,
\q2 egu diba na lalomu ai bavabia dae;
\q1 
\v 18 badina be lalomu ai ba dogodia tao,
\q2 bona bibinamu ai bavabidia hata,
\q2 una na moale ḡauna.
\q1 
\v 19 Hari dina ai oi vada na hadibalaimumu,
\q2 Iehova bavabidadama henia helaoreana.
\q1 
\v 20 Sisiba bona lalo-parara herevadia
\q2 toi-ahui vada na tore henimu ani,
\q1 
\v 21 kara maoromaoro bona kara momokani ihadibalaimu totona,
\q2 bona haere maorona na e siaimu taudia ba henidia helaoreana?
\b
\q1 
\v 22 Ogoḡami tauna basio dadia, badina be ia na ogoḡami;
\q2 hisi e animu taudia na hahemaoro gabuna ai basio taodia tao;
\q1 
\v 23 badina be Iehova ese edia gini-kau gabuna ai baine durudia,
\q2 bona edia kohu e dadi ohomu taudia na edia mauri baine dadi oho.
\q1 
\v 24 Badu haraḡa tauna ida basio hetura,
\q2 bona badu ḡaraḡara tauna ida basiola;
\q1 
\v 25 ena dala ba manadalaidia,
\q2 bona sibomu idoa ai ba heidoa na garina.
\q1 
\v 26 Tau ta dainai e gwau hamatamu tauna ai basiola,
\q2 bona ta ena abitorehai toana basio heni.
\q1 
\v 27 Idavalaina monina ai boma dabu negana ai
\q2 emu mahuta patana na henumu amo bema heabi oho,
\q2 namona be dahaka?
\q1 
\v 28 Tano hetoana gunana, senemu ese e holoa ḡauna,
\q2 basio raḡaia oho.
\q1 
\v 29 Ena ḡaukara ikarana mai dibana tauna o itaiamu a?
\q2 Ia na pavapava vairadiai baine gini;
\q2 asi haridia taudia vairadiai basine gini.
\c 23
\q1 
\v 1 Pavapava ida bavaniani hebou negana ai,
\q2 vairamu ai ḡaudia ba itadia namonamo;
\q1 
\v 2 bema aniani dika taumu,
\q2 bavani heita heni.
\q1 
\v 3 Ena aniani manokadia basio hekise-hekise henidia,
\q2 badina be idia na hedibaḡani anianidia.
\q1 
\v 4 Taḡa iabina basio hekwarahilaia;
\q2 a iabina boma hadokoa, boma aonega.
\q1 
\v 5 O roha heniamu negana ai na e pukimu;
\q2 badina be asi kaimana hanina e hekaramu,
\q2 bena guba e roho dae heniamu, ugava na heto.
\q1 
\v 6 Asi mata-henina tauna ana basio ania,
\q2 ena aniani manokadia basio hekise-hekise henidia;
\q1 
\v 7 badina be ia na e helalomu tauna na heto;
\q2 e tomu “Bavaniani, ba inuinu”,
\q2 to lalona na dia oiemu ai.
\q1 
\v 8 Aniani ḡaudia vada o ani na ba mumuta nege,
\q2 bona emu lalo-namo herevadia na ba hapetapetalai.
\q1 
\v 9 Kavakava tauna vairanai basio hereva,
\q2 badina be emu hereva aonegadia na ia ese baine dadarai.
\q1 
\v 10 Tano hetoana gunana basio raḡaia oho,
\q2 bona ihareha edia tano ai basio raka vareai;
\q1 
\v 11 badina be Ihamauridia Diravana na mai goadana;
\q2 edia gini-kau gabuna ai baine durudia,
\q2 oi baine laomu ahu.
\q1 
\v 12 Lalomu ese hahediba baine tahua,
\q2 bona taiamu ese aonega herevadia bae hakala henidia.
\q1 
\v 13 Mero ta matana ihakanina ai basio daradara;
\q2 au amo boma kwadia, ia na basinema mase.
\q1 
\v 14 Au amo boma kwadia,
\q2 bena ia laumana na mase gabuna amo do ba rauaia.
\q1 
\v 15 Natugu e, lalomu bema aonega,
\q2 bena lau lalogu danu bema moale.
\q1 
\v 16 Udumu bibinadia na hereva maoromaorodia bae gwaurai negana ai,
\q2 lau laumagu do baine moale.
\q1 
\v 17 Lalomu ese kara dika taudia basine vaḡeḡe henidia,
\q2 a dina idoinai Iehova garina ai ba noho.
\q1 
\v 18 Momokani, vaira dinadia dounu,
\q2 bona emu helaro na basine doko.
\b
\q1 
\v 19 Natugu e, a kamonai, bena ba aonega;
\q2 lalomu na dala namona ai ba hakaua.
\q1 
\v 20 Vine ranuna e inu momomu taudia ida basio inu hebou,
\q2 bona e ani lavadaemu taudia ida basio aniani hebou;
\q1 
\v 21 badina be kekero tauna bona ani-lavadae tauna na bae ogoḡami;
\q2 bona mahuta momo ese tau ta dabua hedaredia baine hadabualaia.
\b
\q1 
\v 22 Tamamu, e havaramu tauna, na ba kamonai henia;
\q2 bona sinamu na e burukamu negana ai basio dadaraia.
\q1 
\v 23 Hereva momokani ba hoia emu, bona haida ediai ma basio hoihoilaia;
\q2 aonega bona hahediba bona lalo-parara na ba hoidia emu.
\q1 
\v 24 Kara maoromaoro tauna tamana baine moale hisi dae;
\q2 bona natuna mai aonegana e havaraiamu tauna ese baine moalelaia.
\q1 
\v 25 Tamamu bona sinamu na ba hamoaledia;
\q2 e havaramu hahinena ba hamoalea hisi dae.
\b
\q1 
\v 26 Natugu e, lalomu ba henigu;
\q2 matamu ese egu dala do bae ita.
\q1 
\v 27 Badina be anara hahinena na guri dobuna;
\q2 lebulebu hahinena na ranu gurina hekahi-hekahina.
\q1 
\v 28 E bani taomu, dadidadi tauna na heto;
\q2 koikoi taudia e hahutumadiamu.
\b
\q1 
\v 29 Daika etomu “Inaio”? Daika e tomu “Madi ihabaigu”?
\q2 Daika e heaimu? Daika e maumaumu?
\q1 Daika na asi badina vada e bero?
\q2 Daika matana eme kakakaka?
\q1 
\v 30 Vine ranuna e inu daudaumu taudia,
\q2 bona vine ranudia idau-idau e bulodiamu bena e inu tohomuta udia.
\q1 
\v 31 Vine ranuna e kakakakamu negana ai,
\q2 kehere ai e kimore-kimoremu bona inuna ai e manada-manadamu negana ai,
\q2 basio raraia.
\q1 
\v 32 Dokona ai ia na e hekorimu, gaigai na heto;
\q2 duba na heto e hekorimu.
\q1 
\v 33 Matamu ese ḡau idaudia bae ita,
\q2 bona lalomu amo hereva gageva-gagevadia bae dae.
\q1 
\v 34 Oi na davara nuana ai e hekuremu tauna
\q2 eiava lagatoi au-tubuana dorina ai e helaimu tauna
\q2 heḡereḡerena ai ba hahelao.
\q1 
\v 35 Baoto: E botagu, to asina hisihisi;
\q2 e dadabagu, to mamina asina abia.
\q1 Edena nega ai baina noga?
\q2 Inuinu ḡauna ma ta baina tahua.
\c 24
\q1 
\v 1 Kara dika taudia basio vaḡeḡe henidia,
\q2 ibamodia basio ura;
\q1 
\v 2 badina be lalodia ese daḡedaḡe karadia e lalo hatamu,
\q2 bona bibinadia ese hahedika karadia e herevalaimu.
\q1 
\v 3 Aonega ai ruma e hadaiamu;
\q2 lalo-parara ai e haginiamu;
\q1 
\v 4 aonega ai ena daiutu na dava bada kohudia
\q2 bona kohu namodia iboudiai amo e honumu.
\q1 
\v 5 Aonega tauna ese goada tauna e hereaiamu,
\q2 bona mai dibana tauna ese mai goadana tauna e hereaiamu;
\q1 
\v 6 badina be hahekau mai aonegana amo emu tuari ba goadalaia,
\q2 bona hahealo taudia hutuma daidiai ba kwalimu.
\q1 
\v 7 Aonega na atai ai, kavakava tauna na basine davaria diba;
\q2 hanua ikoukouna ai ia na se herevamu.
\q1 
\v 8 Kara dika ikarana e laloa hatamu tauna na
\q2 hahedika tauna bae gwauraia.
\q1 
\v 9 Kara kavakavadia ilalo-hatadia na kerere,
\q2 bona ḡonaḡona tauna na taunimanima ese bae inai henia bada.
\b
\q1 
\v 10 Hekwakwanai dinana ai boma manoka-manoka,
\q2 emu goada na maraḡi-maraḡi.
\q1 
\v 11 Mase dalana ai e laohaidiamu taudia na ba hamauridia;
\q2 mase gabuna ai e dedi dobimu taudia na ma ba veridia lou.
\q1 
\v 12 Boma toma “A itaia, ina na do asia dibaia”,
\q2 lalo e dibaiamu Diravana ese se itaiamu a?
\q1 Laumamu e gimaiamu Diravana na asi dibana a?
\q2 Ia ese taunimanima davadia na edia ḡaukara heḡereḡeredia ai baine henidia, ani?
\b
\q1 
\v 13 Natugu e, bada-ranuna bavania, badina be ia na namo;
\q2 labolabo edia ruma amo e hetuturumu ḡauna na mai gaihona udumu ai.
\q1 
\v 14 Ba diba, aonega na unuheto, laumamu enai;
\q2 boma davaria, vaira dinadia be dounu,
\q2 bona emu helaro na basine doko.
\b
\q1 
\v 15 Basio bani tao, kara dika tauna ese kara maoromaoro tauna ena ruma e bani henia taomu na heto;
\q2 ena ruma na basio ḡiḡia dobi.
\q1 
\v 16 Badina be kara maoromaoro tauna na nega hitu e ketomu, ma e tore isimu;
\q2 a kara dika taudia na hahehisi karadia ese e doridia dobimu.
\b
\q1 
\v 17 Oi inaimu e ketomu negana ai na basio hisi dae;
\q2 e hetutuhimu negana ai na lalomu basine moale;
\q1 
\v 18 Iehova ese baine itaia, bena baine badu,
\q2 bona ena badu na iena amo baine abia oho na garina.
\b
\q1 
\v 19 Lalomu basine hekwarahi kara dika taudia daidiai,
\q2 bona kara havara taudia basio vaḡeḡe henidia;
\q1 
\v 20 badina be kara dika tauna enai vaira dinadia na dia mimia;
\q2 bona kara havara tauna ena lamepa na baine bodo.
\b
\q1 
\v 21 Natugu e, Iehova bona hanua pavapavana na garidia ba gari,
\q2 bona idia ta basio gwau edeede henia;
\q1 
\v 22 baduna be idia edia amo hahebua-tari baine hedinarai taku.
\q2 Daika dibana dahaka hahedika na idia raruosi edia amo bainema?
\b
\q1 
\v 23 Aonega taudia edia hereva haida bini:
\q2 Hahemaoro gageva-gageva na dia namo.
\q1 
\v 24 Kara dika tauna baine hamaoroa, baineto “Asi emu kerere”, tauna na
\q2 bese idau-idau ese bae uduguiraia;
\q2 orea idau-idau ese bae inai henia bada.
\q1 
\v 25 A kara dika tauna e sisiba heniamu taudia na moale bae davaria,
\q2 bona hahenamo badana na latadiai baine kau.
\q1 
\v 26 Haere maorona e henimu tauna na
\q2 bibinana amo e haherahumu tauna na heto.
\b
\q1 
\v 27 Murimuri ai emu ḡaukara ba heḡaeḡaelaia,
\q2 tano paka ai emu ruma dagana bavabi heḡaeḡae;
\q2 una murinai emu ruma ba haginia.
\b
\q1 
\v 28 Dekemu tauna basio habadelaia kava;
\q2 bibinamu amo basio koikoi.
\q1 
\v 29 Basioto: Ia vada e kara henigu heḡereḡerena baina kara henia;
\q2 una tau ena kara do baina hadavaia.
\q1 
\v 30 Lahedo tauna ena uma na rakaia hanai,
\q2 bona asi darana tauna ena vine imeana danu.
\q1 
\v 31 Bena na itaia, au ḡinigini ese vada e habubunia,
\q2 ava ḡiniḡini ese tano e lahea tao,
\q2 ena nadi maḡuna vada e hegiḡi dobi.
\q1 
\v 32 Na itaia, bena na haeroa;
\q2 na raraia, bena lalogu e parara.
\q1 
\v 33 Matamu ba taia, ba laḡa ani sisina,
\q2 nega sisina kwaramu na imamu ai ba hahekwinaia;
\q1 
\v 34 bena ogoḡami ese baine abimu, dadidadi tauna na heto,
\q2 bona dabu na emu ai baine kau, tuari tauna na heto.
\c 25
\p 
\v 1 Ini danu na Solomon ena hereva lada-isidia haida, Hesekia, Iuda pavapavana, ena orea taudia ese e tore hanai.
\b
\q1 
\v 2 Dirava hairaina na ḡau ihunidia ai,
\q2 a pavapava hairaidia na ḡau anidia itahudia ai.
\q1 
\v 3 Guba na atai ai e daemu bona tanobada na dobu gabudia ai e dihomu heḡereḡeredia,
\q2 pavapava lalodia na basita tahudia diba.
\q1 
\v 4 Miro na e havevea \it silver\it*-na amo ba kakaroa oho,
\q2 bena \it silver\it* iḡaukaralaina tauna na kehere ta baine karaia diba;
\q1 
\v 5 kara dika taudia na pavapva vairana amo bavabidia oho,
\q2 bena ena terono na kara maoromaoro ai baine hedai.
\q1 
\v 6 Pavapava vairanai basio hekokoroku,
\q2 eiava lohia ida basio gini bou;
\q1 
\v 7 badina be bae hamaoromu, baeto “Ini a dae mai”, be namo,
\q2 a pavapava vairanai henu bae siaimu lao na dika.
\b
\q1 Matamu vada e ita karadia na
\q2 
\v 8 hahemaoro gabuna ai basio vareailai haraḡa;
\q1 badina be dokona ai ede ba kara toma,
\q2 dekemu tauna ese baine hahemaraimu negana ai?
\q1 
\v 9 Dekemu tauna sibona ida emu lalo-hadai ba herevalaia,
\q2 tau ta ena lalo-hadai hehunina basio hahedinaraia;
\q1 
\v 10 emu hereva baine kamonai tauna ese baine hahemaraimu
\q2 bona harimu dikana basine doko na garina.
\b
\q1 
\v 11 Hereva maorona ig vauraina na
\q2 \it gold\it* apolodia \it silver\it* boseadia lalodiai na heheto;
\q1 
\v 12 sisiba tauna mai aonegana ena hereva taia kirara tauna enai e gwauraiamu na
\q2 \it gold\it* gadeina eiava \it gold\it* heraherana ta na heto.
\q1 
\v 13 E siaia taudia ediai gwaukau tauna namona na
\q2 ninoa parakana taboro negana ai na heto;
\q2 ia ese biagudia lalodia e hamatamatadiamu.
\q1 
\v 14 Se henimu herahiana e heaḡilaiamu tauna na
\q2 ori bona lai asi medudia na heheto.
\b
\q1 
\v 15 Haheauka ese lohia lalona baine ania,
\q2 bona mala manadana ese turia baine hakwaidua.
\q1 
\v 16 Bada-ranuna boma davaria, dodinai boma ania,
\q2 ianina ai lalomu baine aru bena ba mumuta na garina.
\q1 
\v 17 Dekemu tauna ena ruma ai basio dae kau momo,
\q2 baine hesiku bena baine inai henimu na garina.
\q1 
\v 18 Dekena tauna e habadelaia koikoimu tauna na
\q2 gahi eiava dare eiava diba mai matana na heto.
\q1 
\v 19 Hekwakwanai negana ai koikoi tauna iabidadama-henina na
\q2 isi e hisihisimu eiava ae e dedimu na heto.
\q1 
\v 20 Lalo-metau tauna enai ane e abimu tauna na
\q2 keru dinana ai hahedoki e doki ohomu tauna na heto,
\q2 eiava heḡara muramurana bero ai na heto.
\q1 
\v 21 Inaimu bema hitolo, ana boma henia,
\q2 bona ranu bema masea, ranu boma henia;
\q1 
\v 22 badina be unu amo lahi gidadia na kwarana ai ba senu kau,
\q2 bena Iehova ese davamu baine henimu.
\q1 
\v 23 Lahara ese medu e mailaiamu,
\q2 bona udu mauri ese vaira hua e havaraiamu.
\q1 
\v 24 Tau ta abikau ai baine noho be namo,
\q2 a hereva momo hahinena ida ruma ai bae noho bou na dika.
\q1 
\v 25 Hari namona gabu daudau amo na
\q2 ranu keruma-keruma ranu-mase tauna enai na heto.
\q1 
\v 26 Kara maoromaoro tauna ese kara dika taudia edia dala se laoa ahumu na
\q2 guri ranuna e duhumu eiava ranu bodaga e lohilohiamu na heto.
\q1 
\v 27 Bada-ranuna momo bavania na dia namo;
\q2 unuhetomana danu heimodai herevadia momo basio gwaurai.
\q1 
\v 28 Asi ena haheauka tauna na
\q2 vada e habuaia tari bona asi maḡuna vada e rakatania hanuana na heto.
\c 26
\q1 
\v 1 Kavakava tauna bae matauraia na dia namo;
\q2 una na \it snow\it* siahu negana ai eiava medu taboro negana ai na heto.
\q1 
\v 2 Bisini e roho loaloamu eiava aibisi e roho laomu na heto,
\q2 heuduguirai asi badina na gabu ta ai se roho kaumu.
\q1 
\v 3 Hekwadi varona na hosi ena, hahekau varona na doniki ena,
\q2 bona hekwadi auna na kavakava tauna doruna ena.
\q1 
\v 4 Kavakava tauna na ena kavakava heḡereḡerena ai basio haere henia,
\q2 ia ida ba heḡereḡere na garina.
\q1 
\v 5 Kavakava tauna na ena kavakava heḡereḡerena ai ba haere henia,
\q2 ia sibona ena ita-ita ai baine aonega na garina.
\q1 
\v 6 Gwaukau herevana na kavakava tauna imana ai e siaia laomu tauna ese
\q2 sibona aena e utu ohomu bona daḡedaḡe e inuamu.
\q1 
\v 7 Hereva lada-isina kavakava taudia ududia ai na
\q2 ae-hedairike tauna aena e heveriverimu na heto.
\q1 
\v 8 Kavakava tauna e matauraiamu tauna be
\q2 nadi na vilipopo ai e kwatua kaumu tauna na heto.
\q1 
\v 9 Hereva lada-isina kavakava taudia ududia ai na
\q2 kekero tauna imana e gwadaiamu giniginina na heto.
\q1 
\v 10 Kavakava tauna eiava kekero tauna raka-hanaina ai e vatuamu tauna na
\q2 peva tauna taunimanima iboudiai e haberodiamu na heto.
\q1 
\v 11 Kavakava tauna ena kara kava ma e karaia loumu na
\q2 mumutana e lou heniamu sisiana na heto.
\q1 
\v 12 Tau ta o itaiamu, ia sibona namona e gwauraiamu?
\q2 Kavakava tauna na sisina baine namo,
\q2 a una tau na basine namo diba.
\q1 
\v 13 Lahedo tauna na e tomu “Leona ta na dala ai;
\q2 leona ta na ariara ai”.
\q1 
\v 14 Iduara na garugaruna ai e davedavemu na heto,
\q2 lahedo tauna na ena mahuta patana ai unu e davedave tomamu.
\q1 
\v 15 Lahedo tauna ese imana na dihu ai e dau dobimu;
\q2 ma baine abia isi uduna ai na e hesikulaiamu.
\q1 
\v 16 Lahedo tauna sibona ena ita-ita ai ena aonega ese
\q2 mai lalo-pararadia ida e haeremu taudia hahitu e hereadiamu.
\q1 
\v 17 Haida edia heai lalonai e vareaimu tauna be
\q2 sisia na raka-hanaina ai taiana ai e abiamu tauna na heto.
\q1 
\v 18-19 Dekena tauna e koiamu, bena e tomu
\q2 “Lau be na hevaseha mo” tauna na
\q1 kava tauna lahi tutudia bona diba bona mase
\q2 e tahodiamu na heto.
\q1 
\v 20 Asi rakuraku audia dainai lahi na e bodomu;
\q2 bona asi hemaunu tauna gabuna ai heai e dokomu.
\q1 
\v 21 Badu haraḡa tauna ese heai e havaraiamu,
\q2 guma gida latanai eiava au lahi latanai na heto.
\q1 
\v 22 Hemaunu tauna ena hereva na aniani namodia taidia na heheto,
\q2 boga ai e dihomu.
\q1 
\v 23 Bibinana e manada-manadamu a lalona e dikamu tauna na
\q2 uro mai kopina kavari-kavarina na heto.
\q1 
\v 24 E heinaimu tauna na bibinana amo e helao ahumu,
\q2 bona koikoi na lalona ai e huniamu danu;
\q1 
\v 25 hereva manadadia e gwauraimu negana ai basio kamonai henia,
\q2 badina be lalo-hadai dika-rohorohodia hitu na ia lalona ai mimia.
\q1 
\v 26 Ena be ena heinai na koikoi ai e heḡova ahumu,
\q2 to ena dika na hebou ai baine hedinarai.
\q1 
\v 27 Guri e ḡeiamu tauna na lalonai baine moru dobi,
\q2 bona e hekeimu nadina ese e keiamu tauna na baine keia tao.
\q1 
\v 28 Koikoi malana ese e koidiamu taudia na e inai henidiamu,
\q2 bona hahenamo koikoi herevadia e gwauraimu uduna ese hahebuatari e havaraiamu.
\c 27
\q1 
\v 1 Kerukeru ḡaudia basio heaḡilaidia;
\q2 badina be asi dibamu dina ta ai dahaka baine vara.
\q1 
\v 2 Ta ese baine hanamomu, dia oi sibomu udumu;
\q2 idau tauna ta ese, dia oi sibomu bibinamu.
\q1 
\v 3 Nadi na metau, miri danu metau;
\q2 a kavakava tauna ena hahebadu daladia na metau herea.
\q1 
\v 4 Badu na mai dagedaḡena; ia na abata na heto;
\q2 a vaḡeḡe na daika ese baine ginia ahu?
\q1 
\v 5 Sisiba baine hedinarai na namo;
\q2 lalokau baine hehuni na dika.
\q1 
\v 6 Hetura ai e henimu berodia na mai heabidadamadia ida,
\q2 a inai tauna ena haherahu momo na mai koikoidia.
\q1 
\v 7 Boga-kunu tauna ese bada-ranuna e dadaraiamu,
\q2 a hitolo tauna enai ḡau iditadia iboudiai na mai gaihodia.
\q1 
\v 8 Ena noho gabuna e rakataniamu tauna na
\q2 ena ruma e rohotaniamu manuna na heto.
\q1 
\v 9 Dehoro bona muramura mai bonana ese lalo e hamoaleamu;
\q2 a hekwakwanai ese lalo e hadikaiamu.
\q1 
\v 10 Turamu bona tamamu turana basio rakatanidia;
\q2 bona hahehisi karana emu ai e kaumu dinana ai
\q2 tadikakamu ena ruma basiola.
\q1 Dekemu tauna ena noho kahi ese
\q2 tadikakamu ena noho daudau e hereaiamu.
\q1 
\v 11 Natugu e, ba aonega, lalogu na ba hamoalea,
\q2 e gwau henigumu tauna baina haere henia totona.
\q1 
\v 12 Lalo-parara tauna ese hahedika e itaiamu, bena e komumu;
\q2 a lalo-duhu taudia na e raka laomu, unu amo e hisihisimu.
\q1 
\v 13 Idau tauna dainai e gwau hamatamu tauna na ena dabua bavabia;
\q2 bona idau taudia daidiai e gwau hamatamu negana ai,
\q2 iena amo gwauhamata toana do bavabia.
\q1 
\v 14 Daba matana ai e tore isimu, dekena tauna e hanamoa badabadamu,
\q2 tauna na heuduguirai tauna bae gwauraia.
\q1 
\v 15 Ḡadeḡade hahinena na
\q2 medu e hetuturumu na heto;
\q1 
\v 16 ia igwau-taona na lai igwau-taona na heto,
\q2 eiava ima idibana ai dehoro ikahu-taona na heto.
\q1 
\v 17 Auri ese auri e segeamu;
\q2 bona tau ta ese ma tau ta e segeamu.
\q1 
\v 18 Suke auna e reḡuamu tauna ese huahuana baine ania,
\q2 bona biaguna e gimaiamu tauna na bae imodaia.
\q1 
\v 19 Tau ta lalona na tau ta lalona ai e heitamu,
\q2 ia vairana laulauna na ranu ai e heitamu na heto.
\q1 
\v 20 Mase gabuna bona dobu masemase gabuna asie honumu;
\q2 bona tau ta matana ese ḡau se ita davanamu.
\q1 
\v 21 Uro na \it silver\it* ena, lahi \it gold\it* ena,
\q2 a tau ta itohona na heimodai ai e hedinaraimu.
\q1 
\v 22 Kavakava tauna na uit ida ba gwadaia hebou,
\q2 to ena kavakava na iena amo basine hekoki oho.
\q1 
\v 23 Emu mamoe seridia ede e noho tomamu na ba diba,
\q2 bona emu nani seridia ba reḡudia;
\q1 
\v 24 badina be taḡa na se mia hanaihanaimu.
\q2 Kwara ivavalaina ḡau na uru iboudiai lalodiai baine mia a?
\q1 
\v 25 Rei baine marai, ma rei matamata baine vara,
\q2 bona ororo avadia bae habou;
\q1 
\v 26 una negana ai mamoe natudia amo emu hahedoki ḡaudia bavabi,
\q2 bona nani na emu tano davana ai baela;
\q1 
\v 27 nani ratana na baine davana oi amu,
\q2 bona emu ruma taudia adia,
\q2 bona emu hesiai kekenidia adia.
\c 28
\q1 
\v 1 Kara dika taudia be ta ese se havadiamu negadia ai e heau kavamu,
\q2 a kara maoromaoro taudia na e haheaukamu, leona na heto.
\q1 
\v 2 Basileia ta ai e kara havaramu negadia ai,
\q2 ena pavapava na hoho;
\q1 a aonega bona lalo-parara taudia daidiai,
\q2 ia na nega daudau baine gini tutuka-tutuka.
\q1 
\v 3 Ogoḡami tauna ese ogoḡami tauna e hahisiamu na
\q2 medu baroko ese aniani ḡaudia e hadikadia oremu na heto.
\q1 
\v 4 Taravatu e rakataniamu taudia ese kara dika taudia na e imodaidiamu,
\q2 a taravatu e badinaiamu taudia ese e biridia ahumu.
\q1 
\v 5 Kara dika taudia na hahemaoro ḡoevaḡoeva asi dibadia,
\q2 a Iehova e tahuamu taudia na dibadia vaitani.
\q1 
\v 6 Ogoḡami tauna ena lalo-momokani ai e rakamu be namo;
\q2 taḡa tauna mai ena kara gageva-gageva na dika.
\q1 
\v 7 Taravatu e badinaiamu merona na aonega merona;
\q2 a ani-lavadae taudia e bamodiamu merona ese tamana e hahemaraiamu.
\q1 
\v 8 Ena taḡa na heato-kau kohudia amo e habadaiamu tauna ese egogomu,
\q2 ogoḡami taudia e bogadia hisimu tauna ena.
\q1 
\v 9 Taravatu ikamonaina amo taiana e daro kepokepomu tauna
\q2 ena ḡuriḡuri na ḡau dika-rohorohona.
\q1 
\v 10 Kara maoromaoro taudia kara dika dalana ai e hakaudia kereremu tauna na
\q2 sibona ena guri ai baine moru dobi;
\q1 a asi edia kerere taudia ese
\q2 ahudia namodia bae abi.
\q1 
\v 11 Taḡa tauna na mai aonegana, sibona ena ita-ita ai;
\q2 a ogoḡami tauna mai lalo-pararana ese ena koikoi baine davaria.
\q1 
\v 12 Kara maoromaoro e kwalimumu negana ai heimodai na bada;
\q2 a kara dika taudia e tore isimu negana ai taunimanima bae komu.
\q1 
\v 13 Ena kara dika e hunidiamu tauna basine namo,
\q2 a ena kara dika e gwaurai hedinaraimu bona e rakatanimu tauna na ena dika baine hegwau tao.
\q1 
\v 14 Nega idoinai Iehova garina e garimu tauna na namo,
\q2 a lalona e ha-aukaiamu tauna na hahehisi lalonai baine moru.
\q1 
\v 15 Pavapava dikana ese ogoḡami taudia e biagudia na
\q2 leona e ḡoumu eiava bea e daḡedaḡemu na heto.
\q1 
\v 16 Pavapava asi lalo-pararana ese taunimanima e hahisidia badamu;
\q2 a taḡa iabi-koikoina e inai heniamu tauna ese ena mauri dinadia baine hahohodia.
\q1 
\v 17 Taunimanima rarana e hahebubua tauna na
\q2 heau tauna ai bainela ela bona mase;
\q2 tau ta ese basine durua.
\q1 
\v 18 Kara maoromaoro ai e rakamu tauna na baine roho mauri,
\q2 a kara gageva-gageva tauna na guri ai baine moru dobi.
\q1 
\v 19 Ena tano e ruaiamu tauna ese aniani momo baine abi,
\q2 a kara asi anidia e karamu tauna na baine ogoḡami herea.
\q1 
\v 20 Heabidadama tauna ese ḡau namodia momo baine abi,
\q2 a taḡa e ḡavalaiamu tauna ese mata-hakani basine reaia.
\q1 
\v 21 Kaha ta ai mo e taomu karana na dia namo;
\q2 a aniani taina helaoreana ai tau ta baine kerere.
\q1 
\v 22 Taga e ura heniamu tauna eseltaḡa e ḡava heniamu;
\q2 asi dibana ia na do baine ogoḡami.
\q1 
\v 23 Tau ta e sisiba heniamu tauna ese gabeai lalo-namo bada baine abia;
\q2 a malana amo e hanamoa koikoimu tauna ese lalo-namo maragi baine abia.
\q1 
\v 24 Tamana eiava sinana ena ḡau e henaomu
\q2 bena e tomu “Una na dia kerere” tauna na
\q2 hahebua-tari tauna bamona.
\q1 
\v 25 Mata ḡaniḡani tauna ese heiri-heiri e havaraiamu;
\q2 a Iehova e abidadama heniamu tauna ena taḡa do baine bada.
\q1 
\v 26 Sibona lalona e abidadama heniamu tauna na kavakava tauna;
\q2 a aonega ai e rakamu tauna na do baine roho mauri.
\q1 
\v 27 Ogoḡami taudia e harihari henidiamu tauna na basine dabu,
\q2 a matana e hakapuamu tauna na bae uduguiraia bada.
\q1 
\v 28 Kara dika taudia e tore isimu negadia ai, taunimanima na e komumu;
\q2 a e masemu negadia ai, kara maoromaoro taudia na e hutumamu.
\c 29
\q1 
\v 1 E sisiba henia momomu to aiona e ha-aukaiamu tauna na baine dika taku,
\q2 asi ihanamona dalana ta.
\q1 
\v 2 Kara maoromaoro taudia e lohiamu negadia ai na taunimanima e moalemu;
\q2 a kara dika taudia e lohiamu negadia ai na taunimanima e ḡanaḡanamu.
\q1 
\v 3 Aonega e ura heniamu tauna ese tamana e hamoaleamu,
\q2 a ariara hahinedia ida e heboumu tauna ese ena kohu e hapetapetalaiamu.
\q1 
\v 4 Hahemaoro ḡoevaḡoeva amo hanua pavapavana ese basileia e haginia tutuka-tutukamu,
\q2 a harihari ḡaudia igwaurai-bagubagudia amo e havahuamu.
\q1 
\v 5 Dekena tauna e hanamoa koikoimu tauna ese huo e otoamu,
\q2 ia sibona ihatoalaina.
\q1 
\v 6 Kara dika tauna na ena kara dika ese e idoaiamu,
\q2 a kara maoromaoro tauna na ane e abimu bona e moale hisi daemu.
\q1 
\v 7 Kara maoromaoro tauna na ogoḡami taudia ahudia korikori mai dibana,
\q2 a kara dika tauna na lalo-parara unuhetomana asi dibana.
\q1 
\v 8 Heḡonaḡonalai taudia ese hanua e ha-araiamu,
\q2 a aonega taudia ese badu e laoa ahumu.
\q1 
\v 9 Aonega tauna na kavakava tauna ida bema hepapahuahu negana ai,
\q2 kavakava tauna na e badumu bona e kirimu mo,
\q2 a asie mainomu.
\q1 
\v 10 Rara ihahebubuna e uramu taudia ese asi ena kerere tauna e inai heniamu,
\q2 a kara maoromaoro taudia ese ia ihamaurina dalana e tahuamu.
\q1 
\v 11 Kavakava tauna ese ena badu e halasiamu,
\q2 a aonega tauna na badu ai e haheaukamu.
\q1 
\v 12 Pavapava ese hereva koikoidia bema abidia dae negana ai,
\q2 ia henuna taudia iboudiai na bae kara dika.
\q1 
\v 13 Ogoḡami tauna bona ia e hahisiamu tauna raruosi e hevaira hehenimu,
\q2 bena Iehova ese raruosi matadia e hadiaridiamu.
\q1 
\v 14 Pavapava ese ogoḡami taudia bema hahemaoro henidia mai maoromaorona ida;
\q2 ena terono baine gini hanaihanai.
\q1 
\v 15 Hekwadi auna bona sisiba herevadia ese aonega e havaraiamu,
\q2 a sibona ena ura e karamu merona ese sinana e hahemaraiamu.
\q1 
\v 16 Kara dika taudia e lohiamu negadia ai na kara havara e bada e laomu,
\q2 a kara maoromaoro taudia ese edia moru bae itaia.
\q1 
\v 17 Natumu matana ba hakania, bena ia ese laḡa-ani baine henimu,
\q2 bona lalomu do baine hamoalea.
\q1 
\v 18 Lalo-diari lasi negana ai, taunimanima e kara havaramu,
\q2 a taravatu e badinaiamu tauna na namo.
\q1 
\v 19 Hesiai tauna na hereva amo mo matana se hakaniamu;
\q2 badina be lalona e pararamu, a nahuana se tohoamu.
\q1 
\v 20 Hereva takutaku tauna ta o itaiamu a?
\q2 Kavakava tauna na reana baine namo, a una tau basine namo diba.
\q1 
\v 21 Ena hesiai tauna na merona ai e hagabuḡabua tauna na
\q2 dokona ai baine hekwarahi ia dainai.
\q1 
\v 22 Badu tauna ese heiri-heiri e havaraiamu,
\q2 bona badu momo tauna ese kara dika momo e havaramu.
\q1 
\v 23 Tau ta ena hekokoroku ese baine hahekwakwanaia,
\q2 a manau tauna na bae imodaia.
\q1 
\v 24 Henao tauna bamona ese sibona ena mauri e inai heniamu;
\q2 heuduguirai herevana e kamonaimu, to dibana ḡaudia se herevalaidiamu.
\q1 
\v 25 Taunimanima igari-henidia ese idoa e atoamu,
\q2 a Iehova e abidadama heniamu tauna na basine dika.
\q1 
\v 26 Hutuma ese pavapava ena lalo-namo e tahuamu,
\q2 a Iehova enai tau ta ese hahemaoro goevaḡoeva e abiamu.
\q1 
\v 27 Kara gageva-gageva tauna na kara maoromaoro taudia ese e inai henia badamu,
\q2 a dala maoromaoro ai e rakamu tauna na kara dika taudia ese e inai henia badamu.
\c 30
\p 
\v 1 Aguru Iake, tau Masa, ena hereva bini. Hari tau eto:
\q1 Na hesikumu, Dirava e, na hesikumu;
\q2 Dirava e, egu goada vada e ore.
\q1 
\v 2 Momokani, lau na kavakava herea, dia taunimanima na heto;
\q2 asi daragu taunimanima darana na heto.
\q1 
\v 3 Aonega asina davaria;
\q2 Helaḡa Diravana na asi dibagu.
\q1 
\v 4 Daika na guba ai vada e dae, bona ma e diho?
\q2 Daika ese lai na imana ai vada e kahua tao?
\q1 Daika ese davara na dabua ai vada e kumia?
\q2 Daika ese tanobada dokodia iboudiai vada e hadai?
\q1 Ia ladana be daika, bona natuna ladana be daika?
\q2 Vada o diba, ani!
\b
\q1 
\v 5 Dirava ena hereva iboudiai na momomo-kakani;
\q2 enai e roho maurimu taudia edia kesi na ia.
\q1 
\v 6 lena hereva latadiai hereva ta basio atoa kau,
\q2 baine gwau henimu bena emu koikoi baine hedinarai na garina.
\q1 
\v 7 Ḡau rua emu ai na noimu;
\q2 do asina mase ai basio rudia.
\q1 
\v 8 Koikoi karadia bona herevadia egu amo bavabidia daudau;
\q2 ogoḡami eiava taḡa basio henigu,
\q2 a egu hitolo heḡereḡerena ai mo ba ubugu;
\q1 
\v 9 bogagu baine kunu bena baina ḡoremu,
\q2 bainato “Iehova be daika?” na garina;
\q1 eiava baina ogoḡami, bena baina henao-henao,
\q2 bona egu Dirava ladana baina ḡonaḡonalaia na garina.
\b
\q1 
\v 10 Hesiai tauna na biaguna enai basio habadelaia koikoi;
\q2 baine uduguiraimu, bena kereremu bae gwauraia na garina.
\b
\q1 
\v 11 Haida ese tamadia e uduguiraidiamu,
\q2 bona sinadia asie hanamodiamu.
\q1 
\v 12 Haida na sibodia edia ita-ita ai ḡoḡoeva-ḡoḡoeva etomamu,
\q2 a ḡau be edia miro amo do asie ḡoeva.
\q1 
\v 13 Haida be matadia e heaḡimu,
\q2 bona ibunidia e haroroka-rorokamu.
\q1 
\v 14 Haida na isedia be dare,
\q2 bona gadigadidia be kaia;
\q1 idia ese ogoḡami taudia tanobada amo e anidia oremu,
\q2 bona e dabumu taudia taunimanima bogaragidia amo danu.
\q1 
\v 15 Doma na mai natuna hahinedia rua;
\q2 “A henimai, a henimai” e tomu.
\q1 Ḡau toi bogadia asie kunumu;
\q2 ḡau hani nega ta asie tomu “Vadaeni”.
\q1 
\v 16 Gaudia be mase gabuna, bona gabani hahinena bogana,
\q2 bona tanobada, nega idoinai ranu e maseamu,
\q2 bona lahi, nega ta asine tomu “Vadaeni”.
\q1 
\v 17 Tamana e ḡonaḡonalaiamu bona sinana e gwau edeede heniamu tauna matana na
\q2 koura galodia ese bae giboa lasi,
\q2 bona ugava ese bae ania.
\b
\q1 
\v 18 Ḡau toi na mai hoadia bada egu ai;
\q2 ḡau hani be asi dibagu.
\q1 
\v 19 Ḡaudia be ugava ena dala guba ai,
\q2 bona gaigai ena dala hagahaga nadina ai,
\q1 bona lagatoi ena dala gadobada ai,
\q2 bona tauhau ena dala hane-ulato enai.
\b
\q1 
\v 20 Heuda-hanai hahinena ena dala binai:
\q2 e anianimu, bena uduna e dahuamu,
\q2 bena e tomu “Asina kerere”.
\b
\q1 
\v 21 Ḡau toi henudiai tanobada e heude-heudemu;
\q2 ḡau hani henudiai basine gini auka.
\q1 
\v 22 Ḡaudia be hesiai tauna, pavapava ai e hahelaomu negana ai;
\q2 bona kavakava tauna, bogana e kunumu negana ai;
\q1 
\v 23 bona ta ese se lalokau heniamu hahinena, e headavamu negana ai;
\q2 bona hesiai kekenina, biaguna gabuna e abiamu negana ai.
\b
\q1 
\v 24 Ḡau hani tanobada ai na mamaraḡi,
\q2 a idia na a'aonega heherea:
\q1 
\v 25 dimairi na asi goadadia,
\q2 to taboro negana ai adia e haboumu;
\q1 
\v 26 miḡu danu asi goadadia,
\q2 to edia ruma na tano lalonai e karamu;
\q1 
\v 27 kwadi na asi edia pavapava,
\q2 to e raka ere-eremu, tuari oreana na heto;
\q1 
\v 28 vaboha na imamu ai bavabia diba,
\q2 to ia na pavapava edia ruma ai e nohomu.
\b
\q1 
\v 29 Ḡau toi e raka ruturutumu;
\q2 ḡau hani e raka turiaturiamu.
\q1 
\v 30 Ḡaudia be leona, uda ḡaudia bogaragidiai ia mo herea,
\q2 bona ḡau ta vairanai ia na se raka murimu;
\q1 
\v 31 bona kokoroku maruanena; bona nani maruanena;
\q2 bona hanua pavapavana, ena orea matana ai e rakamu.
\b
\q1 
\v 32 Boma kavakava, sibomu boma heaḡi,
\q2 eiava kara dika boma laloa hata,
\q2 bena udumu na imamu amo ba koua.
\q1 
\v 33 Badina be rata ba taoa, rata-hetarina digarana ba davaria;
\q2 bona udu baubauna ba taoa tari, bena rara baine aru;
\q2 bona badu ba taoa, bena heiri-heiri baine vara.
\c 31
\p 
\v 1 Lemuele, Masa pavapavana, ena hereva bini, sinana ese e hadibalaia herevadia.
\q1 
\v 2 Natugu e, bogagu amo o vara merona,
\q2 natugu e, egu gwauhamata amo o vara merona,
\q2 ede baina hereva henimu toma?
\b
\q1 
\v 3 Emu goada na hahine basio henidia;
\q2 emu dala na pavapava iala-masedia taudia basio henidia.
\q1 
\v 4 Dia namo, Lemuele e,
\q2 dia namo pavapava ese vine ranuna bae inua;
\q2 dia namo hanua lohiadia ese kekero muramurana bae ura henia;
\q1 
\v 5 bae inu bena taravatu bae readia,
\q2 bona hisi e animu taudia iboudiai ahudia korikori bae ha-idau na garina.
\q1 
\v 6 Kekero muramurana na mokona e masemu tauna ba henia,
\q2 bona vine ranuna na lalodia e hisihisi hereamu taudia ba henidia;
\q1 
\v 7 do bae inu, bena edia ogoḡami bae laloa boio,
\q2 bona edia hisihisi basie laloa une.
\q1 
\v 8 Udumu ba hapapaia, mu taudia daidiai,
\q2 bona ihareha iboudiai ahudia korikori daidiai.
\q1 
\v 9 Udumu ba hapapaia, ba hahemaoro mai maoromaoromu ida,
\q2 ogogami taudia bona e dabumu taudia ahudia korikori inanatalaidia.
\b
\q1 
\v 10 Hahine namona na daika ese baine davaria?
\q2 Ia ese herahera nadinadidia namo-heredia e hereadiamu.
\q1 
\v 11 Adavana lalona ese ia e abidadama heniamu,
\q2 bona ḡau namodia ai basine dabu.
\q1 
\v 12 Hahine unuhetomana ese adavana e hanamoamu, se hadikaiamu,
\q2 ena mauri dinadia iboudiai lalodiai.
\q1 
\v 13 Mamoe huina bona lagwa varona e tahudiamu;
\q2 ia imana na gaukara e uramu.
\q1 
\v 14 Ia na hoihoi taudia edia lagatoi na heheto,
\q2 ana aniani na dauha amo e mailaimu.
\q1 
\v 15 Daba vaburana ai e tore isimu,
\q2 ena ruma taudia adia e nadu hatamu,
\q2 bona ena hesiai kekenidia edia ḡaukara e henidiamu.
\q1 
\v 16 Tano ta ihoina e lalo-hadailaiamu, bena e hoiamu;
\q2 ena ḡaukara anina amo vine imeana e hadoamu.
\q1 
\v 17 Goada e rioamu,
\q2 bona imana e ha-aukadiamu.
\q1 
\v 18 Ena hoihoi anidia namodia e itamu;
\q2 hanuaboi ai ena lamepa na se bodomu.
\q1 
\v 19 Dabua ihatuna auna na imana ai e abiamu,
\q2 bona igirolaina gau na imana amo e dogoa taomu.
\q1 
\v 20 Ia ese imana e kehoamu ogogami taudia ediai;
\q2 bona imana ruaosi e toi roromu, e dabumu taudia ediai.
\q1 
\v 21 Keru negana ai ena ruma taudia se kudou hetahalaidiamu,
\q2 badina be iboudiai na mai edia dabua kakakakadia.
\q1 
\v 22 Ia ese hetaru e karamu;
\q2 ena dabua na \it linen\it* namo-hereana bona dabua kakakaka miakoremana.
\q1 
\v 23 Hanua ikoukoudia lalodiai taunimanima ese ia adavana e dibaiamu;
\q2 ia na hanua tau-badadia bogaragidiai e helaimu.
\q1 
\v 24 Ia ese \it linen\it* dabuadia e karadiamu, bena e hoidiamu;
\q2 gaba ḡaudia danu hoihoi taudia dekedia e siaidia laomu.
\q1 
\v 25 Goada bona ninina-namo e hahedokilaidiamu;
\q2 nega vaira dinadia ia ese e kiri henidiamu.
\q1 
\v 26 Uduna e hapapaiamu mai aonegana ida,
\q2 bona hebogahisi ihahedibalaina na matana ai.
\q1 
\v 27 Ena ruma taudia edia kara e ita taomu;
\q2 bona aniani inonogadia se animu.
\q1 
\v 28 Natuna e tore isimu, namona e gwauraiamu;
\q2 adavana ese e imodaiamu danu, e tomu:
\q1 
\v 29 Hahine hutuma vada e kara namo herea,
\q2 to oi ese iboudiai o hereadiamu.
\q1 
\v 30 Kara laloa-laloa na koikoi, bona hairai na asi anina;
\q2 a Iehova garina e garimu hahinena na bae imodaia.
\q1 
\v 31 Ena gaukara anina ba henia,
\q2 bona ena kara na hanua ikoukouna ai do bae imodaia. 
