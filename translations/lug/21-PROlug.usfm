\id PRO - Biblica® Open Luganda Contemporary Bible 2014 
\h Engero 
\toc1 Engero 
\toc2 Engero 
\toc3 Nge 
\mt2 Ekitabo Ekiyitibwa 
\mt1 Engero 
\c 1  
\p  
\v 1 Engero za Sulemaani, mutabani wa Dawudi, kabaka wa Isirayiri. 
\q1  
\v 2 Yaziwandiika okuyigiriza abantu okuba n’amagezi n’okuyiga, 
\q2 era n’okutegeera ebigambo eby’obulabufu; eby’obulamu eby’amagezi n’empisa. 
\q1  
\v 3 Sulemaani yayagala abantu okuba n’empisa, n’obulamu obw’amagezi, 
\q2 okukolanga ebituufu, n’okubeera abenkanya n’okugobereranga ensonga; 
\q1  
\v 4 okuyigiriza amagezi abatalina bumanyirivu, 
\q2 n’abavubuka okufuna okumanya n’okutegeera. 
\q1  
\v 5 N’abantu ab’amagezi nabo bwe bawulira beeyongere okuyiga 
\q2 n’abategeevu beeyongere okubangulwa. 
\q1  
\v 6 Era engero zino zaawandiikibwa okutegeera engero, 
\q2 enjogera n’ebikokyo. 
\b  
\q1  
\v 7 Kale mu kutya \nd Mukama\nd* amagezi mwe gasookera, 
\q2 naye abasirusiru banyooma amagezi n’okulagirirwa. 
\s1 Amagezi eri Abavubuka 
\q1  
\v 8 Mwana wange ossangayo omwoyo eri ebiragiro bya kitaawo, 
\q2 era tolekanga kukuutira kwa maama wo; 
\q1  
\v 9 bijja kuba ngule eneeweesanga omutwe gwo ekitiibwa, 
\q2 n’emikuufu mu bulago bwo. 
\b  
\q1  
\v 10 Mwana wange abakozi b’ebibi bwe bakusendasendanga, 
\q2 tokkirizanga. 
\q1  
\v 11 Bwe bakugambanga nti, “Tugende ffenna twesanyuse, 
\q2 tunyage, tubbe n’okutta; 
\q2 tokkirizanga; 
\q1  
\v 12 ng’entaana bw’emira abantu, naffe tubamire tutyo nga bakyali balamu, 
\q2 era nga balamba, ng’abagenda mu bunnya obuwanvu; 
\q1  
\v 13 nga twefunira eby’obugagga bye tutakoleredde, 
\q2 ne tujjuza amayumba gaffe obugagga obubbe; 
\q1  
\v 14 ng’ababi batuyita tubeegatteko, 
\q2 tugabane kyenkanyi ebibbe n’ebinyage.” 
\q1  
\v 15 Mwana wange totambuliranga wamu nabo, 
\q2 era ekigere kyo kiziyize okukwatanga ekkubo lyabwe: 
\q1  
\v 16 Kubanga ebigere byabwe bidduka bunnambiro okukola ebibi, 
\q2 era kibanguyira okuyiwa omusaayi. 
\q1  
\v 17 Nga kuba kumala biseera okutega omutego, 
\q2 ng’ekinyonyi ky’oyagala okukwata kikulaba, 
\q1  
\v 18 naye abantu ng’abo baba beetega bokka, 
\q2 baba beetega omutego ogunaabakwasa bo bennyini. 
\q1  
\v 19 Bwe lityo bwe libeera ekkubo lya buli muntu anoonya okugaggawalira mu bukyamu. 
\q2 Obugagga obw’engeri eyo busaanyaawo obulamu bw’abo ababufuna. 
\s1 Okulabula Eri Abanyooma Amagezi 
\q1  
\v 20 Amagezi galeekaanira waggulu mu nguudo; 
\q2 gayimusa amaloboozi gaago, mu bifo ebigazi eby’omu bibuga. 
\q1  
\v 21 Ne galeekaanira waggulu, mu kifo enguudo ennene we zisisinkanira, 
\q2 era gasinzira mu miryango gy’ekibuga ne googera: 
\b  
\q1  
\v 22 Mulituusa ddi mmwe ab’amagezi amatono obutayagala kweyongera kuyiga by’amagezi, 
\q2 nammwe ab’amalala okunyoomanga eby’amagezi n’abasirusiru okukyawanga okumanya? 
\q1  
\v 23 Kale singa muwuliriza okunenya kwange, 
\q2 laba, ndifuka omutima gwange 
\q2 n’ebirowoozo byange mu mmwe. 
\q1  
\v 24 Kubanga na bayita ne mugaana okuwuliriza, 
\q2 ne ngolola omukono ne wataba n’omu afaayo, 
\q1  
\v 25 era ne mutafaayo ku magezi ge nabawa, 
\q2 era ne mugaana okubuulirira kwange kwonna, 
\q1  
\v 26 kale nange ndibasekerera nga muli mu nnaku, 
\q2 era mbakudaalire ng’entiisa ebagwiridde. 
\q1  
\v 27 Entiisa bw’eribajjira ng’omuyaga omungi, 
\q2 ennaku n’okubonaabona, okulumwa n’obubalagaze, 
\q1  
\v 28 kale balinkoowoola, naye siriyitaba; 
\q2 balinnoonya obutaweera naye ne batandaba. 
\q1  
\v 29 Kubanga baakyawa okuyigirizibwa, n’okumanya, 
\q2 era ne bamalirira obutatya \nd Mukama\nd*. 
\q1  
\v 30 Ne bagaana okuwuliriza amagezi gange; 
\q2 ne banyooma okunenya kwange kwonna. 
\q1  
\v 31 Kyebaliva balya ebibala eby’ekkubo lyabwe ebbi, 
\q2 era ne bajjula ebibala eby’enkwe zaabwe. 
\q1  
\v 32 Obusirusiru bulitta ab’amagezi amatono 
\q2 n’obutafaayo bulizikiriza abasirusiru, 
\q1  
\v 33 naye buli ampuliriza anaabeeranga mirembe, 
\q2 ng’agumye nga talina kutya kwonna. 
\c 2  
\s1 Empeera y’Okunoonya Amagezi 
\q1  
\v 1 Mwana wange, bw’onookwatanga ebigambo byange, 
\q2 n’otereka ebiragiro byange mu bulamu bwo, 
\q1  
\v 2 era n’ossaayo omwoyo eri amagezi, 
\q2 era n’ossa omutima gwo eri okutegeera, 
\q1  
\v 3 ddala ddala singa oyaayaanira okumanya 
\q2 era n’oyimusa eddoboozi lyo osabe okutegeera, 
\q1  
\v 4 bw’onooganoonyanga nga ffeeza, 
\q2 era n’oganoonyanga ng’ekyobugagga ekyakwekebwa, 
\q1  
\v 5 awo w’olitegeerera okutya \nd Mukama\nd*, 
\q2 era n’ovumbula okumanya Katonda. 
\q1  
\v 6 Kubanga \nd Mukama\nd* awa amagezi; 
\q2 era mu kamwa ke muvaamu okumanya n’okutegeera. 
\q1  
\v 7 \nd Mukama\nd* aterekera abatuukirivu amagezi amalungi, 
\q2 era aba ngabo y’abo abatambulira mu bugolokofu. 
\q1  
\v 8 Abatambuliza mu makubo ag’obwenkanya, 
\q2 era bw’atyo \nd Mukama\nd* akuuma ekkubo ly’abatukuvu be. 
\b  
\q1  
\v 9 Olwo lw’olitegeera obutuukirivu, amazima n’obwenkanya; 
\q2 weewaawo buli kkubo eddungi. 
\q1  
\v 10 Kubanga amagezi galiyingira mu mutima gwo, 
\q2 n’okumanya kulisanyusa omwoyo gwo. 
\q1  
\v 11 Okwesalirawo obulungi kunaakulabiriranga 
\q2 n’okutegeera kunaakukuumanga: 
\b  
\q1  
\v 12 Amagezi ganaakuwonyanga ekkubo ly’omubi, 
\q2 n’abantu aboogera eby’obugwagwa, 
\q1  
\v 13 abaleka amakubo ag’obutuukirivu 
\q2 ne batambulira mu makubo ag’ekizikiza, 
\q1  
\v 14 abasanyukira okukola ebikolwa ebibi, 
\q2 abanyumirwa eby’obusirusiru, 
\q1  
\v 15 abantu abo be b’amakubo amakyamu, 
\q2 era abakujjukujju mu ngeri zaabwe. 
\b  
\q1  
\v 16 Amagezi \nd Mukama\nd* g’awa ge gokka agajja okukuwonya ekkubo ly’omukazi omwenzi, 
\q2 n’okukuwonya ebigambo bye ebisendasenda, 
\q1  
\v 17 eyaleka bba ow’omu buvubuka bwe 
\q2 era eyeerabira endagaano gye yakola mu maaso ga Katonda we. 
\q1  
\v 18 Kubanga ennyumba ye ekka mu kufa, 
\q2 n’amakubo ge galaga eri abafu. 
\q1  
\v 19 Tewali n’omu agenda ewuwe adda 
\q2 wadde okufunirayo amakubo g’obulamu. 
\b  
\q1  
\v 20 Kale tambuliranga mu kkubo ly’abo abatya Katonda 
\q2 era onywerere mu makubo g’abatuukirivu. 
\q1  
\v 21 Kubanga abatuukirivu balituula mu nsi, 
\q2 era abo abagolokofu baligisigalamu. 
\q1  
\v 22 Naye abakozi b’ebibi balifiirwa ebirungi eby’ensi, 
\q2 n’abatali beesigwa balizikirizibwa. 
\c 3  
\s1 Emikisa Egiva mu kuba n’Amagezi 
\q1  
\v 1 Mwana wange, teweerabiranga bintu bye nakuyigiriza, 
\q2 era okuumanga ebiragiro byange mu mutima gwo, 
\q1  
\v 2 kubanga bijja kuwangaaza obulamu bwo ku nsi, 
\q2 era bikukulaakulanye. 
\b  
\q1  
\v 3 Amazima n’ekisa tobyerabiranga; 
\q2 byesibe mu bulago bwo, 
\q2 obiwandiike ku mutima gwo. 
\q1  
\v 4 Bw’otyo bw’onoofuna okuganja n’okusiimibwa 
\q2 eri Katonda n’eri abantu. 
\b  
\q1  
\v 5 Weesige \nd Mukama\nd* n’omutima gwo gwonna, 
\q2 so teweesigamanga ku magezi go gokka. 
\q1  
\v 6 \nd Mukama\nd* mukulembezenga mu by’okola byonna, 
\q2 naye anaakuluŋŋamyanga n’owangula. 
\b  
\q1  
\v 7 Amagezi go tegakusigulanga, 
\q2 naye otyanga \nd Mukama\nd*, era weewale okukola ebibi. 
\q1  
\v 8 Onoofunanga obulamu mu mubiri gwo 
\q2 n’amagumba go ne gadda buggya. 
\s1 Amagezi n’Obugagga 
\q1  
\v 9 \nd Mukama\nd* mugulumizenga n’eby’obugagga byo; n’ebibala ebisooka eby’ebintu byo byonna eby’omu nnimiro yo, 
\q1  
\v 10 olwo amaterekero go lwe ganajjulanga ebintu enkumu, 
\q2 era n’amasenero go ne gajjula ne gabooga omwenge omusu. 
\b  
\q1  
\v 11 Mwana wange tonyoomanga kukangavvula kwa \nd Mukama\nd*, 
\q2 n’okunenya kwe kulemenga okukukooya, 
\q1  
\v 12 kubanga \nd Mukama\nd* anenya oyo gw’ayagala, 
\q2 nga kitaawe w’omwana bw’anenya mutabani we gwe yeenyumiririzaamu. 
\b  
\q1  
\v 13 Aweereddwa omukisa oyo afuna amagezi, 
\q2 omuntu oyo afuna okutegeera, 
\q1  
\v 14 kubanga amagezi gasinga ffeeza 
\q2 era galimu amagoba okusinga zaabu. 
\q1  
\v 15 Amagezi ga muwendo mungi okusinga amayinja ag’omuwendo omungi: 
\q2 era tewali kyegombebwa kiyinza kugeraageranyizibwa nago. 
\q1  
\v 16 Mu mukono gwago ogwa ddyo mwe muli obuwanguzi; 
\q2 ne mu mukono gwago ogwa kkono ne mubaamu obugagga n’ekitiibwa. 
\q1  
\v 17 Mu magezi mulimu essanyu, 
\q2 era n’amakubo gaago ga mirembe. 
\q1  
\v 18 Amagezi muti gwa bulamu eri abo abagakwata ne baganyweza; 
\q2 abo abagakwata ne baganyweza baliweebwa omukisa. 
\b  
\q1  
\v 19 Amagezi, \nd Mukama\nd* ge yakozesa okuteekawo emisingi gy’ensi; 
\q2 n’okutegeera kwe yakozesa okuteekawo eggulu; 
\q1  
\v 20 n’okumanya kwe, kwe yakozesa okwawula obuziba bw’ennyanja, 
\q2 era n’ebire ne bivaamu omusulo. 
\s1 Ab’amagezi Baweebwa Ekitiibwa 
\q1  
\v 21 Mwana wange, beeranga n’okuteesa okulungi n’okusalawo ebisaana, 
\q2 ebyo biremenga okukuvaako, 
\q1  
\v 22 binaabeeranga obulamu eri emmeeme yo, 
\q2 era ekyokwambala ekirungi ekinaawoomesanga obulago bwo. 
\q1  
\v 23 Bw’otyo bw’onootambulanga nga onyweredde mu kkubo lyo, 
\q2 era ekigere kyo tekijjanga kwesittala. 
\q1  
\v 24 Bw’onoogalamiranga toobenga na kutya, 
\q2 weewaawo bw’oneebakanga otulo tunaakuwoomeranga. 
\b  
\q1  
\v 25 Totyanga kabenje kootomanyiridde, 
\q2 wadde okuzikirira okujjira abakozi b’ebibi, 
\q1  
\v 26 Kubanga \nd Mukama\nd* y’anaabeeranga obwesigwa bwo, 
\q2 era anaalabiriranga ekigere kyo ne kitakwatibwa mu mutego. 
\b  
\q1  
\v 27 Tommanga birungi abo be bisaanira 
\q2 bwe kibeera mu buyinza bwo okukikola. 
\q1  
\v 28 Togambanga muliraanwa wo nti, 
\q2 “Genda, onodda enkya ne nkuwa,” 
\q2 ate nga kye yeetaaga okirina. 
\b  
\q1  
\v 29 Totegekanga kukola bulabe ku muliraanwa wo, 
\q2 atudde emirembe ng’akwesiga. 
\q1  
\v 30 Tovunaananga muntu n’omu awatali nsonga 
\q2 nga talina kabi k’akukoze. 
\b  
\q1  
\v 31 Tokwatirwanga obuggya omuntu ayigganya abalala, 
\q2 era tokolanga nga ye bw’akola, 
\q1  
\v 32 kubanga omuntu omugwagwa wa muzizo eri \nd Mukama\nd*, 
\q2 naye abo abagolokofu abalinamu obwesige. 
\b  
\q1  
\v 33 Ekikolimo kya \nd Mukama\nd* kiri ku nnyumba y’ababi, 
\q2 naye awa omukisa ennyumba y’abatuukirivu. 
\q1  
\v 34 Ddala ddala, \nd Mukama\nd* anyooma abanyoomi, 
\q2 naye abeetoowaza abawa ekisa. 
\q1  
\v 35 Ab’amagezi balisikira ekitiibwa, 
\q2 naye abasirusiru baliswazibwa. 
\c 4  
\s1 Amagezi ge gali ku Ntikko 
\q1  
\v 1 Muwulirize baana bange okuyigiriza kwange ng’okwa kitammwe, 
\q2 era musseeyo omwoyo mufune okutegeera. 
\q1  
\v 2 Kubanga mbawa okuyigiriza okulungi; 
\q2 temulekanga biragiro byange. 
\q1  
\v 3 Bwe nnali omuvubuka nga ndi ne kitange, 
\q2 omwana omu yekka omwagalwa, owa mmange, 
\q1  
\v 4 yanjigiriza n’aŋŋamba nti, “Ebigambo byange bikuumenga ku mutima gwo, 
\q2 kuuma ebiragiro byange obeere mulamu. 
\q1  
\v 5 Funa amagezi; funa okutegeera, 
\q2 teweerabiranga era tovanga ku bigambo bya mu kamwa kange. 
\q1  
\v 6 Togalekanga, nago ganaakukuumanga, 
\q2 gaagale nago ganaakulabiriranga. 
\q1  
\v 7 Ddala amagezi kye kintu ekisingira ddala obukulu; 
\q2 noolwekyo fuba ofune amagezi, era fubira ddala nnyo ofune okutegeera. 
\q1  
\v 8 Amagezi gagulumize, nago gajja kukuyimusa, 
\q2 gaanirize, nago gajja kukuweesa ekitiibwa. 
\q1  
\v 9 Amagezi gajja kukutikkira engule ey’ekisa, 
\q2 era gakuwe n’engule ey’ekitiibwa.” 
\s1 Enjawulo wakati w’Ab’amagezi n’Abagwenyufu 
\q1  
\v 10 Wuliriza ggwe, mutabani, era okkirize ebigambo byange 
\q2 olyoke owangaalire ku nsi n’essanyu eringi. 
\q1  
\v 11 Nkuluŋŋamya mu kkubo ery’amagezi, 
\q2 ne nkukulembera mu makubo ag’obutuukirivu. 
\q1  
\v 12 Bw’onootambulanga, ekigere kyo kireme okuziyizibwa; 
\q2 era bw’onoddukanga, tojjanga kwesittala. 
\q1  
\v 13 Nywerezanga ddala okuyigirizibwa, tokutanga: 
\q2 kukuumenga kubanga bwe bulamu bwo. 
\q1  
\v 14 Toyingiranga mu kkubo ly’abakozi b’ebibi, 
\q2 wadde okutambulira mu kkubo ly’abantu aboonoonyi. 
\q1  
\v 15 Lyewalenga, tolitambulirangamu, 
\q2 liveeko okwate ekkubo lyo. 
\q1  
\v 16 Kubanga abakozi b’ebibi tebayinza kwebaka okuggyako nga bakoze ebibi, 
\q2 era otulo tubabulira ddala bwe baba tebalina gwe bakozeeko bulabe. 
\q1  
\v 17 Okukola ebibi y’emmere yaabwe, 
\q2 n’okukozesa eryanyi kye kyokunywa kyabwe. 
\b  
\q1  
\v 18 Ekkubo ly’abatuukirivu liri ng’enjuba eyakavaayo, 
\q2 eyeeyongera okwaka okutuusa obudde lwe butangaalira ddala. 
\q1  
\v 19 Naye ekkubo ly’ababi liri ng’ekizikiza ekikutte, 
\q2 tebamanyi kibaleetera kwesittala. 
\b  
\q1  
\v 20 Mutabani wange wuliriza n’obwegendereza ebigambo byange; 
\q2 osseeyo omwoyo eri bye nkutegeeza; 
\q1  
\v 21 ebigambo bino tebikuvangako, 
\q2 bikuumire ddala mu mutima gwo, 
\q1  
\v 22 kubanga bya bulamu eri abo ababifuna, 
\q2 era biwonya omubiri gwabwe gwonna. 
\q1  
\v 23 Ekisinga byonna kuuma omutima gwo, 
\q2 kubanga y’ensulo y’obulamu bwo. 
\q1  
\v 24 Weewalire ddala eby’obubambavu 
\q2 era n’okwogera ebya swakaba. 
\q1  
\v 25 Amaaso go gatunulenga butereevu, 
\q2 era otunulenga n’obumalirivu eyo gy’olaga. 
\q1  
\v 26 Ttereeza bulungi amakubo go; 
\q2 okwate amakubo ageesigika gokka. 
\q1  
\v 27 Tokyamanga ku mukono ogwa ddyo oba ogwa kkono; 
\q2 ebigere byo byewalenga ekkubo ekyamu. 
\c 5  
\s1 Okulabula ku Bwenzi 
\q1  
\v 1 Mutabani, ossangayo omwoyo eri ebiragiro byange, 
\q2 era owulirizanga bulungi ebigambo byange eby’amagezi, 
\q1  
\v 2 olyoke oyige okusalawo okw’amagezi, 
\q2 era akamwa ko kavengamu eby’obutegevu. 
\q1  
\v 3 Kubanga emimwa gy’omukazi omwenzi gitonnya omubisi gw’enjuki, 
\q2 n’ebigambo bye biweweevu okusinga omuzigo; 
\q1  
\v 4 naye enkomerero ya byonna, akaawa ng’omususa 
\q2 era asala ng’ekitala eky’obwogi obubiri. 
\q1  
\v 5 Ebigere bye bituuka mu kufa, 
\q2 ebisinde bye biraga emagombe. 
\q1  
\v 6 Tafaayo ku kkubo lya bulamu, 
\q2 amakubo ge gaakyamakyama dda, naye nga takimanyi. 
\b  
\q1  
\v 7 Kaakano, batabani bange mumpulirize, 
\q2 temuvanga ku bigambo bya kamwa kange. 
\q1  
\v 8 Mwewalenga omukazi oyo 
\q2 era temusembereranga luggi lwa nnyumba ye; 
\q1  
\v 9 si kulwa nga mufiirwa ekitiibwa kyammwe, 
\q2 n’okumalira ebiseera byammwe ku oyo alina ettima, 
\q1  
\v 10 ate si kulwa nga b’otolina ky’obamanyiiko bakwavuwaza, 
\q2 n’amaanyi go n’ogamalira ku maka g’omulala. 
\q1  
\v 11 Ku nkomerero y’obulamu bwo olisinda, 
\q2 ennyama yo n’omubiri gwo nga biweddewo. 
\q1  
\v 12 Oligamba nti, “Nga nakyawa okulabulwa, 
\q2 n’omutima gwange ne gukyawa okunenyezebwa, 
\q1  
\v 13 era ne sigondera ddoboozi ly’abasomesa bange, 
\q2 wadde okussaayo omwoyo eri abo abampanga amagezi. 
\q1  
\v 14 Ntuuse ku njegoyego z’okuzikirira 
\q2 nga ndi wakati mu kuŋŋaaniro ly’ekibiina.” 
\s1 Obuvunaanyizibwa n’Essanyu mu Bufumbo 
\q1  
\v 15 Onoonywanga amazzi ag’omu kidiba kyo, 
\q2 n’amazzi agava mu luzzi lwo goonoonywanga. 
\q1  
\v 16 Ensulo zo zisaanye okukulukutira mu nguudo, 
\q2 n’enzizi zo mu bifo ebigazi eby’omu kibuga? 
\q1  
\v 17 Leka bibeere bibyo wekka, 
\q2 bireme kugabanibwako b’otomanyiiko n’akamu. 
\q1  
\v 18 Kale leka ensulo yo ebeere n’omukisa, 
\q2 era osanyuke ne mukazi wo ow’omu buvubuka bwo. 
\q1  
\v 19 Ng’ennangaazi eyeeyagaza n’empeewo esanyusa, 
\q2 leka okusuuta kwe kukumalenga ennaku zonna era naye akwetoloozenga okwagala kwe. 
\q1  
\v 20 Lwaki mwana wange osendebwasendebwa omukazi omwenzi, 
\q2 n’ogwa mu kifuba ky’omukazi w’omusajja omulala? 
\b  
\q1  
\v 21 Kubanga \nd Mukama\nd* alaba amakubo g’omuntu gonna, 
\q2 era n’akebera n’amakubo ge gonna. 
\q1  
\v 22 Ebikolwa by’omukozi w’ebibi bimufuukira omutego, 
\q2 era emiguwa gy’ebikolwa bye ebibi girimusibira ddala. 
\q1  
\v 23 Alifa, kubanga yagaana okwekuuma, 
\q2 era alizikirira olw’obusirusiru bwe obungi. 
\c 6  
\s1 Okulabula ku Butamanya n’Obusirusiru 
\q1  
\v 1 Mutabani obanga weeyimirira muliraanwa wo, 
\q2 ne weeyama okuyamba omuntu gw’otomanyi, oli mu katyabaga. 
\q1  
\v 2 Obanga weesibye n’ebigambo ggwe kennyini bye wayogera, 
\q2 ng’ebigambo by’omu kamwa ko bikusibye, 
\q1  
\v 3 kino mwana wange ky’oba okola okusobola okwewonya, 
\q2 kubanga kaakano oli mu buyinza bwa muliraanwa wo: 
\q1 Yanguwa, ogende weetoowaze, 
\q2 weegayirire muliraanwa wo. 
\q1  
\v 4 Amaaso go togaganya kwebaka, 
\q2 wadde ebikowe byo okubongoota. 
\q1  
\v 5 Onunule obulamu bwo ng’empeewo bw’edduka okuva mu ngalo z’omuyizzi, 
\q2 era ng’ekinyonyi, bwe kiva mu mutego gw’omutezi. 
\b  
\q1  
\v 6 Yigira ku biwuka, mugayaavu ggwe; 
\q2 fumiitiriza engeri gye bikolamu obiyigireko. 
\q1  
\v 7 Tebirina mukulembeze, 
\q2 mukungu oba mufuzi yenna abikulembera, 
\q1  
\v 8 kyokka byekuŋŋaanyiza emmere mu biseera eby’amakungula, 
\q2 ne bitereka emmere mu biseera ebituufu mu mwaka. 
\b  
\q1  
\v 9 Olituusa ddi okwebaka mugayaavu ggwe? 
\q2 Oligolokoka ddi n’ova mu tulo two? 
\q1  
\v 10 Otulo otutonotono, n’okusumagira akatono, 
\q2 n’okufunya emikono okuwummulako, 
\q1  
\v 11 obwavu bulikutuukako ng’omutemu, 
\q2 era n’obwetaavu ng’omutemu. 
\s1 Okulabula eri Omuntu Omutabuzitabuzi 
\q1  
\v 12 Omuntu ataliiko ky’agasa, omusajja omubi 
\q2 agenda ayogera ebigambo ebitabulatabula, 
\q1  
\v 13 agenda atemyatemya ku liiso, 
\q2 nga bw’akuba ebigere 
\q2 ate nga bw’asongasonga olunwe, 
\q2  
\v 14 olw’omutima omukyamu, ateekateeka okukola ebibi, 
\q2 bulijjo aleeta obutakkaanya mu bantu! 
\q1  
\v 15 Noolwekyo okuzikirira kulimujjira mbagirawo, 
\q2 mu kaseera buseera alibetentebwa awatali kuwona. 
\s1 Okulabula ku Bibi Omusanvu 
\li1  
\v 16 Waliwo ebintu mukaaga \nd Mukama\nd* by’akyawa, 
\li2 weewaawo musanvu eby’omuzizo gy’ali. 
\li3  
\v 17 Amaaso ag’amalala, 
\li3 emimwa egirimba, 
\li3 okuttira abantu obwereere; 
\li3  
\v 18 omutima ogutegeka okukola ebibi, 
\li3 ebigere ebyanguwa okukola ebibi, 
\li3  
\v 19 obujulizi obw’obulimba, 
\li3 n’omuntu aleeta obutakkaanya mu booluganda. 
\s1 Okulabula Ku Bwenzi 
\q1  
\v 20 Mwana wange nyweza ebiragiro bya kitaawo, 
\q2 era togayaalirira kuyigiriza kwa maama wo. 
\q1  
\v 21 Bisibenga ku mutima gwo ennaku zonna 
\q2 era obisibe binywerere mu bulago bwo. 
\q1  
\v 22 Bijja kukuluŋŋamyanga buli gy’onoolaganga, 
\q2 ne bw’onoobanga weebase binaakukuumanga, 
\q2 ate ng’ozuukuse binaabanga naawe. 
\q1  
\v 23 Kubanga amateeka ttabaaza, 
\q2 era n’okuyigiriza kitangaala, 
\q1 okukulabula olw’okukuluŋŋamya, 
\q2 ly’ekkubo ery’obulamu, 
\q1  
\v 24 okukuwonya omukazi ow’ebibi, 
\q2 okukuggya mu kunyumiikiriza kw’omukazi omwenzi. 
\q1  
\v 25 Teweegombanga bulungi bwe mu mutima gwo, 
\q2 wadde okumukkiriza okukuwamba n’amaaso ge, 
\q1  
\v 26 kubanga malaaya akussa ku muwendo ogugula omugaati, 
\q2 era omukazi omwenzi anoonya kuzikiririza ddala bulamu bwo. 
\q1  
\v 27 Omuntu ayinza okuwambaatira omuliro mu kifuba kye, 
\q2 ebyambalo bye ne bitaggya? 
\q1  
\v 28 Oba omuntu ayinza okutambulira ku manda agookya, 
\q2 ebigere bye ne bitasiriira? 
\q1  
\v 29 Bwe kityo bwe kiri eri omusajja agenda ne muka muliraanwa we, 
\q2 buli akwata ku mukazi ng’oyo talirema kubonerezebwa olw’ekibi kye. 
\b  
\q1  
\v 30 Abantu tebasekerera muntu bw’abba, 
\q2 olw’okwewonya enjala. 
\q1  
\v 31 Naye bwe bamukwata aba alina okuwa engassi ya mirundi musanvu; 
\q2 ne bwe kiba nga kimumalako ebintu bye byonna eby’omu nju ye. 
\q1  
\v 32 Naye buli ayenda ku mukazi talina magezi; 
\q2 kubanga azikiririza ddala emmeeme ye ye. 
\q1  
\v 33 Alifuna ebiwundu n’okunyoomebwa; 
\q2 n’obuswavu tebulimusangulibwako. 
\b  
\q1  
\v 34 Kubanga obuggya buleetera omusajja okuswakira, 
\q2 era taliba na kisa n’akatono nga yeesasuza. 
\q1  
\v 35 Talikkiriza mutango gwonna, 
\q2 wadde okuwooyawooyezebwa enguzi ennene. 
\c 7  
\s1 Emitawaana Egiva mu Kukwana Omukazi Omwenzi 
\q1  
\v 1 Mutabani nyweeza ebigambo byange, 
\q2 era okuumenga ebiragiro byange. 
\q1  
\v 2 Kwata ebiragiro byange obeere mulamu, 
\q2 n’amateeka gange ogakuume ng’emmunye y’eriiso lyo; 
\q1  
\v 3 togalekanga kuva mu ngalo zo, 
\q2 gawandiike ku mutima gwo. 
\q1  
\v 4 Amagezi gatwalire ddala nga mwannyoko, 
\q2 n’okutegeera, ng’owooluganda ow’omu kika kyo. 
\q1  
\v 5 Binaakuwonyanga omukazi omwenzi, 
\q2 omukazi omutambuze awaanawaana n’ebigambo ebisendasenda. 
\b  
\q1  
\v 6 Lumu nnali nnyimiridde 
\q2 ku ddirisa ly’ennyumba yange. 
\q1  
\v 7 Ne ndaba mu bavubuka abatoototo, 
\q2 omulenzi atalina magezi, 
\q1  
\v 8 ng’ayita mu luguudo okumpi n’akafo k’omukazi omwenzi, 
\q2 n’akwata ekkubo eridda ku nnyumba y’omukazi oyo, 
\q1  
\v 9 olw’eggulo ng’obudde buzibye, 
\q2 ekizikiza nga kikutte. 
\b  
\q1  
\v 10 Awo omukazi n’ajja okumusisinkana 
\q2 ng’ayambadde nga malaaya, ng’ajjudde ebirowoozo eby’obukaba mu mutima gwe. 
\q1  
\v 11 Omukazi omukalukalu, 
\q2 atambulatambula ennyo atabeerako waka, 
\q1  
\v 12 wuuyo mu luguudo, wuuyo mu bifo ebikuŋŋaanirwamu, 
\q2 mu buli kafo konna ng’ateega! 
\q1  
\v 13 N’amuvumbagira, n’amunywegera 
\q2 era ng’amutunuulidde nkaliriza n’amaaso agatatya n’amugamba nti: 
\b  
\q1  
\v 14 “Nnina ssaddaaka ez’ebiweebwayo olw’emirembe, 
\q2 leero ntukiriza obweyamo bwange. 
\q1  
\v 15 Noolwekyo nzize okukusisinkana, 
\q2 mbadde njagala nnyo okukulaba, era kaakano nkusanze. 
\q1  
\v 16 Obuliri bwange mbwaze bulungi 
\q2 n’engoye eza linena ava mu Misiri. 
\q1  
\v 17 Mbukubye n’akaloosa, 
\q2 n’omugavu, n’obubaane, ne kinamoni, ne kalifuuwa. 
\q1  
\v 18 Jjangu tuwoomerwe omukwano okutuusa obudde okukya; 
\q2 leka twesanyuse ffembi mu mukwano. 
\q1  
\v 19 Kubanga baze taliiyo eka; 
\q2 yatambula olugendo luwanvu: 
\q1  
\v 20 Yagenda n’ensawo y’ensimbi; 
\q2 era alikomawo nga wayiseewo wiiki bbiri.” 
\b  
\q1  
\v 21 Yamusendasenda n’ebigambo ebisikiriza; 
\q2 n’amuwabya n’ebigambo ebiwoomerera. 
\q1  
\v 22 Amangwago omuvubuka n’amugoberera 
\q2 ng’ente etwalibwa okuttibwa 
\q1 obanga empeewo egwa mu mutego, 
\q2  
\v 23 okutuusa akasaale lwe kafumita ekibumba kyayo, 
\q1 ng’akanyonyi bwe kanguwa okugwa mu mutego, 
\q2 so tamanyi ng’alifiirwa obulamu bwe. 
\b  
\q1  
\v 24 Kaakano nno batabani bange mumpulirize, 
\q2 era musseeyo nnyo omwoyo eri ebigambo byange. 
\q1  
\v 25 Temukkiriza mitima gyammwe kugoberera bigambo bye; 
\q2 temukkiriza bigere byammwe kukyamira mu makubo ge. 
\q1  
\v 26 Kubanga bangi bazikiridde, 
\q2 ddala ab’amaanyi bangi bagudde. 
\q1  
\v 27 Ennyumba ye, lye kkubo eridda emagombe, 
\q2 nga likka mu bisenge eby’okufa. 
\c 8  
\s1 Amagezi Gakoowoola 
\q1  
\v 1 Amagezi tegakoowoolera waggulu, 
\q2 n’okutegeera ne kuyimusa eddoboozi lyakwo? 
\q1  
\v 2 Ku ntikko y’ebifo ebigulumivu okumpi n’ekkubo, 
\q2 mu masaŋŋanzira, amagezi we gayimirira butengerera, 
\q1  
\v 3 ku mabbali g’enzigi eziyingira mu kibuga, 
\q2 ku miryango, gakoowoolera waggulu nga gagamba nti, 
\q1  
\v 4 Mmwe abantu, mmwe b’empita; 
\q2 nnyimusa eddoboozi lyange eri buli omu ali ku nsi. 
\q1  
\v 5 Mmwe abatategeera mufune okutegeera; 
\q2 nammwe abasirusiru mufune amagezi. 
\q1  
\v 6 Muwulirize kubanga nnina ebintu ebikulu eby’okubagamba, 
\q2 era mu kamwa kange muvaamu ebituufu. 
\q1  
\v 7 Akamwa kange koogera bituufu byereere; 
\q2 kubanga emimwa gyange gikyawa ebitali bya butuukirivu. 
\q1  
\v 8 Ebigambo by’emimwa gyange byonna bya bwenkanya 
\q2 tewali na kimu kikyamu oba kya bukuusa. 
\q1  
\v 9 Ebigambo byange byonna bitegeerekeka eri oyo ategeera, 
\q2 era tebirina kabi eri oyo alina amagezi. 
\q1  
\v 10 Mu kifo kya ffeeza, londawo okuyigiriza kwange, 
\q2 era n’okumanya mu kifo kya zaabu ennongoose obulungi, 
\q1  
\v 11 kubanga amagezi gasinga amayinja ag’omuwendo omungi, 
\q2 era n’ebyo byonna bye weegomba tebiyinza kugeraageranyizibwa nago. 
\b  
\q1  
\v 12 Nze Magezi, mbeera wamu n’okuteesa okulungi, 
\q2 era mu nze mulimu okumanya n’okwawula ekirungi n’ekibi. 
\q1  
\v 13 Okutya \nd Mukama\nd* kwe kukyawa ekibi; 
\q2 nkyawa amalala n’okwemanya, 
\q2 n’obuteeyisa bulungi n’enjogera ey’obubambaavu. 
\q1  
\v 14 Okuteesa okulungi n’okusalawo okw’amagezi bye byange; 
\q2 ntegeera era ndi wa buyinza. 
\q1  
\v 15 Ku bwange, Magezi, bakabaka bafuga, 
\q2 abafuzi ne bakola amateeka ag’obwenkanya. 
\q1  
\v 16 Abalangira bafuga ku bwange, 
\q2 n’abakungu bonna abafuga ku nsi. 
\q1  
\v 17 Njagala abo abanjagala, 
\q2 n’abo abanyiikira okunnoonya bandaba. 
\q1  
\v 18 Obugagga n’ekitiibwa biri mu nze, 
\q2 obugagga obutakoma n’okukulaakulana. 
\q1  
\v 19 Ekibala kyange kisinga zaabu ennongoose, 
\q2 n’ebinvaamu bisinga ffeeza ey’omuwendo omungi. 
\q1  
\v 20 Ntambulira mu kkubo ery’obutuukirivu, 
\q2 mu kkubo ery’obwenkanya, 
\q1  
\v 21 n’abo abanjagala mbagaggawaza 
\q2 era nzijuza amawanika gaabwe. 
\b  
\q1  
\v 22 \nd Mukama\nd* nze gwe yasooka okwoleka 
\q2 nga tannabaako kirala ky’akola. 
\q1  
\v 23 Nateekebwawo dda nnyo, 
\q2 ku lubereberye ng’ensi tennabaawo. 
\q1  
\v 24 Nateekebwawo ng’obuziba bw’ennyanja tebunnateekebwawo, 
\q2 nga n’emigga egireeta amazzi teginnabaawo, 
\q1  
\v 25 ng’ensozi tezinnateekebwa mu bifo byazo, 
\q2 nga n’obusozi tebunnabaawo; 
\q1  
\v 26 nga tannakola nsi newaakubadde amalundiro gaakwo, 
\q2 wadde enfuufu eyasooka ey’oku nsi. 
\q1  
\v 27 Naliwo ng’ateekawo eggulu mu kifo kyalyo, 
\q2 ne bwe yakola enkulungo kungulu ku buziba, 
\q1  
\v 28 ate ne bwe yawanika ebire n’abinywereza waggulu mu bbanga, 
\q2 n’anywereza ddala ensulo z’amazzi, 
\q1  
\v 29 bwe yawa ennyanja ensalo zaazo we zikoma, 
\q2 amazzi galeme kusukka we yagalagira, 
\q2 ne bwe yali ng’alamba emisingi gy’ensi. 
\q1  
\v 30 Nnali naye ng’omukozi omukugu, 
\q2 nga nzijudde essanyu lye erya buli lunaku, 
\q2 nga nsanyukira mu maaso ge bulijjo, 
\q1  
\v 31 nga nsanyukira mu nsi ye yonna, 
\q2 era nga ne nesiima olw’abaana b’abantu. 
\b  
\q1  
\v 32 Kale nno, batabani bange mumpulirize; 
\q2 balina omukisa abo abakwata amakubo gange! 
\q1  
\v 33 Muwulirizenga okuyigirizibwa, mubenga n’amagezi, 
\q2 so temugalekanga. 
\q1  
\v 34 Alina omukisa omuntu ampuliriza, 
\q2 alindirira nga bw’akuuma ku nzigi zange 
\q2 buli lunaku. 
\q1  
\v 35 Kubanga buli andaba afuna obulamu, 
\q2 era afuna okuganja eri \nd Mukama\nd*. 
\q1  
\v 36 Oyo atannoonya yeerumya yekka, 
\q2 era n’abo bonna abankyawa banoonya kufa. 
\c 9  
\s1 Empagi z’Amagezi Omusanvu 
\q1  
\v 1 Amagezi gazimbye ennyumba yaago, 
\q2 gagizimbidde ku mpagi musanvu. 
\q1  
\v 2 Gategese ennyama yaago ne wayini\f + \fr 9:2 \ft Wayini yatabulwangamu ebyakaloosa aka mooli, yeeyongere okuwoomerera.\f* waago; 
\q2 gategese ekijjulo. 
\q1  
\v 3 Gatumye abawala abaweereza bakoowoolere 
\q2 mu bifo ebigulumivu nti, 
\q1  
\v 4 “Buli atalina kutegeera akyameko wano!” 
\q2 Eri abo abatalina magezi gabagamba nti, 
\q1  
\v 5 “Mujje mulye ku mmere yange 
\q2 era munywe ne ku nvinnyo gwe ntabudde. 
\q1  
\v 6 Mulekeraawo obutaba na kutegeera mubeere balamu, 
\q2 era mutambulire mu kkubo ly’okumanya.” 
\b  
\q1  
\v 7 Oyo anenya omunyoomi ayolekera kuvumwa, 
\q2 n’oyo abuulirira omukozi w’ebibi yeeretera kuvumibwa. 
\q1  
\v 8 Tonenyanga munyoomi, aleme okukukyawa, naye 
\q2 nenya ow’amagezi naye anaakwagalanga. 
\q1  
\v 9 Yigirizanga ow’amagezi naye aneeyongeranga okuba n’amagezi, 
\q2 yigirizanga omutuukirivu, aneeyongerangako okuyiga. 
\b  
\q1  
\v 10 “Mu kutya \nd Mukama\nd* amagezi mwe gasookera, 
\q2 era n’okumanya oyo Omutukuvu Katonda, kwe kutegeera. 
\q1  
\v 11 Ku lwange oliwangaala emyaka mingi nnyo, 
\q2 era olyongerwako emyaka. 
\q1  
\v 12 Bw’obeera omugezi, amagezi go gakuyamba, 
\q2 naye bw’onyooma amagezi weerumya wekka.” 
\b  
\q1  
\v 13 Omukazi omusirusiru aleekaana, 
\q2 taba na mpisa era taba na magezi! 
\q1  
\v 14 Era atuula mu mulyango gw’ennyumba ye, 
\q2 ne ku ntebe mu bifo eby’ekibuga ebisinga obugulumivu, 
\q1  
\v 15 ng’akoowoola abo abayitawo, 
\q2 ababa batambula amakubo gaabwe abali ku byabwe. 
\q1  
\v 16 Abagamba nti, “Buli alina okumanya okutono ajje muno.” 
\q2 Era eri oyo atalina kutegeera agamba nti, 
\q1  
\v 17 “Amazzi amabbe nga gawooma! 
\q2 emmere eriibwa mu kyama ng’ewooma!” 
\q1  
\v 18 Naye oyo agwa mu kitimba kye tamanya nti nnyumba yakuzikirira, 
\q2 era nti abagenyi be bali mu buziba obw’emagombe. 
\c 10  
\s1 Engero za Sulemaani 
\p  
\v 1 Engero za Sulemaani: 
\q1 Omwana ow’amagezi asanyusa kitaawe; 
\q2 naye omwana omusirusiru anakuwaza nnyina. 
\b  
\q1  
\v 2 Eby’obugagga ebifuniddwa mu makubo amakyamu tebirina kye bigasa, 
\q2 naye abatuukirivu banunulwa okuva mu kufa. 
\b  
\q1  
\v 3 \nd Mukama\nd* taalekenga mutuukirivu we kufa njala, 
\q2 naye aziyiza abakozi b’ebibi okufuna bye beetaaga. 
\b  
\q1  
\v 4 Emikono emigayaavu gyavuwaza, 
\q2 naye emikono eminyiikivu gireeta obugagga. 
\b  
\q1  
\v 5 Omuvubuka ow’amagezi akungulira mu biseera ebituufu, 
\q2 naye oyo eyeebakira mu biro eby’okukunguliramu mwana aswaza ennyo. 
\b  
\q1  
\v 6 Omukisa gubeera ku mutwe gw’omutuukirivu, 
\q2 naye akamwa k’omukozi w’ebibi kajjula obukambwe. 
\b  
\q1  
\v 7 Omutuukirivu anajjukirwanga n’essanyu, 
\q2 naye erinnya ly’omubi linaavundanga. 
\b  
\q1  
\v 8 Alina omutima ogw’amagezi agondera ebiragiro, 
\q2 naye omusirusiru ayogerayogera, azikirizibwa. 
\b  
\q1  
\v 9 Atambulira mu bwesimbu y’atambula emirembe, 
\q2 naye akwata amakubo amakyamu alitegeerebwa. 
\b  
\q1  
\v 10 Oyo atta ku liiso ng’akweka amazima aleeta ennaku, 
\q2 n’omusirusiru ayogerayogera alizikirizibwa. 
\b  
\q1  
\v 11 Akamwa ak’omutuukirivu nsulo ya bulamu, 
\q2 naye akamwa k’omukozi w’ebibi kajjula bulabe. 
\b  
\q1  
\v 12 Obukyayi buleeta enjawukana, 
\q2 naye okwagala kubikka ku bibi bingi. 
\b  
\q1  
\v 13 Amagezi gasangibwa ku mimwa gy’oyo alina okutegeera, 
\q2 naye omuggo gukangavvula oyo atamanyi kusalawo bulungi. 
\b  
\q1  
\v 14 Abantu ab’amagezi batereka okumanya, 
\q2 naye akamwa k’omusirusiru kaaniriza kuzikirira. 
\b  
\q1  
\v 15 Obugagga bw’omugagga kye kibuga kye ekiriko ebigo, 
\q2 naye obwavu kwe kuzikirira kw’omwavu. 
\b  
\q1  
\v 16 Empeera y’omutuukirivu bulamu, 
\q2 naye empeera y’omukozi w’ebibi emuleetera kubonerezebwa. 
\b  
\q1  
\v 17 Oyo assaayo omwoyo eri okubuulirirwa aba mu kkubo ery’obulamu, 
\q2 naye oyo atassaayo mwoyo ku kunenyezebwa aleetera abalala okuwaba. 
\b  
\q1  
\v 18 Oyo akisa obukyayi alina emimwa egirimba, 
\q2 era omuntu akonjera, musirusiru. 
\b  
\q1  
\v 19 Mu bigambo ebingi temubula kwonoona, 
\q2 naye akuuma olulimi lwe aba wa magezi. 
\b  
\q1  
\v 20 Olulimi lw’omutuukirivu ffeeza ya muwendo, 
\q2 naye omutima gw’omukozi w’ebibi gugasa katono. 
\b  
\q1  
\v 21 Ebigambo by’omutuukirivu biriisa abantu bangi, 
\q2 naye abasirusiru bazikirira olw’okubulwa amagezi. 
\b  
\q1  
\v 22 Omukisa gwa \nd Mukama\nd* guleeta obugagga 
\q2 era tagwongerako buyinike. 
\s1 Okuwangaala Okuli mu Kutya \nd Mukama\nd* 
\b  
\q1  
\v 23 Omusirusiru asanyukira okukola ebibi, 
\q2 naye omuntu alina okutegeera asanyukira eby’amagezi. 
\b  
\q1  
\v 24 Omukozi w’ebibi ky’atayagala kirimutuukako, 
\q2 naye abatuukirivu bye baagala biribaweebwa. 
\b  
\q1  
\v 25 Embuyaga bw’ejja, abakozi b’ebibi batwalibwa, 
\q2 naye abatuukirivu banywera emirembe gyonna. 
\b  
\q1  
\v 26 Ng’omususa bwe gunyeenyeza amannyo, n’omukka nga bwe gubalagala mu maaso, 
\q2 n’omugayaavu bw’abeera bw’atyo eri abamutuma. 
\b  
\q1  
\v 27 Okutya \nd Mukama\nd* kuwangaaza omuntu, 
\q2 naye emyaka gy’ababi girisalibwako. 
\b  
\q1  
\v 28 Essuubi ly’abatuukirivu livaamu ssanyu, 
\q2 naye okusuubira kw’abakozi b’ebibi tekulivaamu kantu. 
\b  
\q1  
\v 29 Ekkubo lya \nd Mukama\nd* kye kiddukiro ky’abatuukirivu, naye abakozi b’ebibi libasaanyaawo. 
\b  
\q1  
\v 30 Abatuukirivu tebajjululwenga ennaku zonna, 
\q2 naye abakozi b’ebibi tebalisigala mu nsi. 
\b  
\q1  
\v 31 Akamwa k’omutuukirivu koogera eby’amagezi, 
\q2 naye olulimi olwogera eby’obubambavu lulisalibwamu. 
\b  
\q1  
\v 32 Emimwa gy’omutuukirivu gyogera ebisaanidde; 
\q2 naye emimwa gy’omukozi w’ebibi gyogera eby’obubambavu. 
\b  
\c 11  
\q1  
\v 1 Minzaani eteri ya mazima ya muzizo eri \nd Mukama\nd*, 
\q2 naye ebipimo ebituufu bye bimusanyusa. 
\b  
\q1  
\v 2 Amalala bwe gajja, ng’obuswavu butuuse, 
\q2 naye obwetoowaze buleeta amagezi. 
\b  
\q1  
\v 3 Obwesimbu bw’abatuukirivu bubaluŋŋamya, 
\q2 naye enkwe z’abatali beesigwa zibazikirizisa. 
\b  
\q1  
\v 4 Obugagga tebugasa ku lunaku olw’okusalirwako omusango, 
\q2 naye obutuukirivu buwonya okufa. 
\b  
\q1  
\v 5 Obutuukirivu bw’abalongoofu bubatambuliza mu kkubo eggolokofu 
\q2 naye abakozi b’ebibi bagwa olw’ebikolwa byabwe ebibi. 
\b  
\q1  
\v 6 Obutuukirivu bw’abagolokofu bubawonya, 
\q2 naye abatali beesigwa bagwa mu mutego olw’okwegomba ebibi. 
\b  
\q1  
\v 7 Omukozi w’ebibi bw’afa, essuubi lye libula, 
\q2 ne byonna bye yasuubira mu maanyi bikoma. 
\b  
\q1  
\v 8 Omutuukirivu aggyibwa mu mitawaana, 
\q2 naye jjijjira omukozi w’ebibi. 
\b  
\q1  
\v 9 Akamwa k’oyo atatya Katonda, kazikiriza muliraanwa, 
\q2 naye olw’okumanya, abatuukirivu bawona. 
\b  
\q1  
\v 10 Abatuukirivu bwe bakulaakulana ekibuga kijaguza; 
\q2 abakozi b’ebibi bwe bazikirira wawulirwawo amaloboozi ag’essanyu. 
\b  
\q1  
\v 11 Omukisa gw’abatuukirivu gukulaakulanya ekibuga: 
\q2 naye olw’akamwa k’abakozi b’ebibi, ekibuga kizikirizibwa. 
\s1 Abeesigwa n’Abatambuza Eŋŋambo 
\b  
\q1  
\v 12 Omuntu atalina magezi anyooma muliraanwa we, 
\q2 naye omuntu ategeera akuuma olulimi lwe. 
\b  
\q1  
\v 13 Aseetula olugambo atta obwesigwa, 
\q2 naye omuntu omwesigwa akuuma ekyama. 
\b  
\q1  
\v 14 Awatali kuluŋŋamizibwa eggwanga lidobonkana, 
\q2 naye abawi b’amagezi abangi baleeta obuwanguzi. 
\b  
\q1  
\v 15 Eyeeyimirira omuntu gw’atamanyiko alibonaabona, 
\q2 naye oyo akyawa okweyimirira aliba bulungi. 
\b  
\q1  
\v 16 Omukazi ow’ekisa aweebwa ekitiibwa, 
\q2 naye abasajja ab’amawaggali bakoma ku bugagga bwokka. 
\b  
\q1  
\v 17 Omusajja alina ekisa aganyulwa, 
\q2 naye alina ettima yeereetako akabi. 
\b  
\q1  
\v 18 Omukozi w’ebibi afuna empeera ey’obukuusa, 
\q2 naye oyo asiga eby’obutuukirivu akungula empeera eya nnama ddala. 
\b  
\q1  
\v 19 Omuntu omutuukirivu ddala alifuna obulamu, 
\q2 naye oyo akola ebitali bya butuukirivu alifa. 
\b  
\q1  
\v 20 \nd Mukama\nd* akyawa abantu abalina emitima emikyamu, 
\q2 naye ab’amakubo amagolokofu be bamusanyusa. 
\b  
\q1  
\v 21 Mutegeerere ddala ng’abakozi b’ebibi tebalirema kubonerezebwa, 
\q2 naye bazzukulu b’abatuukirivu tebalibaako musango. 
\b  
\q1  
\v 22 Ng’empeta ya zaabu mu nnyindo y’embizzi, 
\q2 bw’atyo bw’abeera omukazi omulungi atalaba njawulo wakati w’ekirungi n’ekibi. 
\b  
\q1  
\v 23 Abatuukirivu bye beegomba bivaamu birungi byereere, 
\q2 naye abakozi b’ebibi bye bakola bisunguwaza. 
\s1 Omuntu Omugabi 
\b  
\q1  
\v 24 Omuntu agaba obuteerekereza, yeeyongera bweyongezi kugaggawala; 
\q2 naye akwatirira kye yandigabye, yeeyongera kwavuwala. 
\b  
\q1  
\v 25 Omuntu agaba anagaggawalanga, 
\q2 n’oyo ayamba talibulako amuyamba. 
\b  
\q1  
\v 26 Abantu bakolimira oyo akweka eŋŋaano mu kiseera eky’obwetaavu, 
\q2 naye oyo agitunda mu kiseera ekyo afuna emikisa. 
\b  
\q1  
\v 27 Oyo anyiikira okukola obulungi afuna okuganja, 
\q2 naye oyo anoonya ekibi, kimujjira. 
\b  
\q1  
\v 28 Oyo eyeesiga obugagga bwe aligwa, 
\q2 naye abatuukirivu banaakulaakulananga ne baba ng’amalagala amalamu. 
\b  
\q1  
\v 29 Omuntu aleeta emitawaana mu maka g’ewaabwe, alisikira mpewo; 
\q2 era n’omusirusiru aliba muddu w’oyo alina omutima ogw’amagezi. 
\b  
\q1  
\v 30 Ekibala ky’omutuukirivu muti gwa bulamu, 
\q2 era n’oyo asikiriza emyoyo gy’abantu ne balokoka wa magezi. 
\b  
\q1  
\v 31 Obanga omutuukirivu alifuna ekimusaanidde ku nsi kuno, 
\q2 oyo atatya Katonda n’omwonoonyi balirema obutafuna ekibasaanidde? 
\b  
\c 12  
\q1  
\v 1 Buli asanyukira okukangavvulwa ayagala amagezi; 
\q2 naye oyo akyawa okunenyezebwa musirusiru. 
\b  
\q1  
\v 2 Omuntu omulungi aganja mu maaso ga \nd Mukama\nd*, 
\q2 naye \nd Mukama\nd* asalira omusango omuntu ow’enkwe. 
\b  
\q1  
\v 3 Omuntu tanywezebwa lwa kukola bitali bya butuukirivu, 
\q2 naye omulandira gw’omutuukirivu tegulisigulwa. 
\b  
\q1  
\v 4 Omukyala ow’empisa ennungi ssanyu era ngule ya mwami we, 
\q2 naye omukazi eyeeyisa obubi ali nga kookolo mu magumba ga bba. 
\b  
\q1  
\v 5 Enteekateeka z’omutuukirivu ziba za mazima, 
\q2 naye amagezi g’abakozi b’ebibi ge bawa gaba ga bulimba. 
\b  
\q1  
\v 6 Ebiteeso by’abakozi b’ebibi kuyiwa musaayi, 
\q2 naye ebigambo by’abatuukirivu bye bibawonya. 
\b  
\q1  
\v 7 Abakozi b’ebibi bagwa ne basaanirawo ddala, 
\q2 naye ennyumba y’omutuukirivu teesagaasaganenga emirembe gyonna. 
\b  
\q1  
\v 8 Ebigambo by’omugezi bimuleetera okusiimibwa, 
\q2 naye eby’omusirusiru bimunyoomesa. 
\b  
\q1  
\v 9 Omuntu eyeetoowaza ne yeekolera, 
\q2 asinga oyo eyeegulumiza n’abulwa ky’alya. 
\b  
\q1  
\v 10 Omutuukirivu afaayo ku bisolo bye, 
\q2 naye omukozi w’ebibi abiraga bukambwe bwereere. 
\b  
\q1  
\v 11 Oyo eyeerimira aliba n’emmere nnyingi, 
\q2 naye oyo anoonya ebitaliimu talina magezi. 
\b  
\q1  
\v 12 Abakozi b’ebibi baagala okubba omunyago gwa babbi bannaabwe, 
\q2 naye omulandira gw’abatuukirivu gunywera. 
\b  
\q1  
\v 13 Ebigambo by’omukozi w’ebibi bimusuula mu mitawaana, 
\q2 naye omutuukirivu awona akabi. 
\b  
\q1  
\v 14 Omuntu ajjuzibwa ebirungi okuva mu bibala bye bigambo by’akamwa ke, 
\q2 n’emirimu gy’emikono gye gimusasula bulungi. 
\b  
\q1  
\v 15 Ekkubo ly’omusirusiru ddungi mu kulaba kwe ye, 
\q2 naye omugezi assaayo omwoyo ku magezi agamuweebwa. 
\b  
\q1  
\v 16 Omusirusiru alaga mangu obusungu bwe, 
\q2 naye omutegeevu tassa mwoyo ku kivume. 
\b  
\q1  
\v 17 Omujulizi ow’amazima awa obujulizi obutuufu, 
\q2 naye omujulizi ow’obulimba ayogera bya bulimba. 
\b  
\q1  
\v 18 Ebigambo ebyanguyirize bisala ng’ekitala ekyogi, 
\q2 naye olulimi lw’omuntu omugezi luwonya. 
\b  
\q1  
\v 19 Emimwa egyogera amazima gibeerera emirembe gyonna, 
\q2 naye olulimi olulimba lwa kiseera buseera. 
\b  
\q1  
\v 20 Obulimba buli mu mitima gyabo abategeka okukola ebibi, 
\q2 naye essanyu liri n’abo abakolerera emirembe. 
\b  
\q1  
\v 21 Tewali kabi konna kagwa ku batuukirivu, 
\q2 naye abakozi b’ebibi tebaggwaako mitawaana. 
\b  
\q1  
\v 22 \nd Mukama\nd* akyawa emimwa egirimba, 
\q2 naye asanyukira ab’amazima. 
\b  
\q1  
\v 23 Omuntu omutegeevu talaga nnyo by’amanyi, 
\q2 naye abasirusiru balaga obutamanya bwabwe. 
\b  
\q1  
\v 24 Omukono gw’omunyiikivu gulimufuula omufuzi, 
\q2 naye obugayaavu bufuula omuntu omuddu. 
\b  
\q1  
\v 25 Omutima ogweraliikirira guleetera omuntu okwennyika, 
\q2 naye ekigambo eky’ekisa kimusanyusa. 
\b  
\q1  
\v 26 Omutuukirivu yeegendereza mu mikwano gye, 
\q2 naye ekkubo ly’ababi libabuza. 
\b  
\q1  
\v 27 Omuntu omugayaavu tayokya muyiggo gwe, 
\q2 naye omunyiikivu kyayizze, kiba kya muwendo gyali. 
\b  
\q1  
\v 28 Mu kkubo ery’obutuukirivu mulimu obulamu, 
\q2 era mu kkubo eryo temuli kufa. 
\c 13  
\s1 Ensibuko y’Obugagga Obungi 
\q1  
\v 1 Omwana omugezi assaayo omwoyo eri ebiragiro bya kitaawe, 
\q2 naye omunyoomi tafaayo ku kunenyezebwa. 
\b  
\q1  
\v 2 Omuntu asanyuka olw’ebirungi ebiva mu bibala bya kamwa ke, 
\q2 naye atali mwesigwa yeegomba kuleeta ntalo. 
\b  
\q1  
\v 3 Oyo eyeegendereza by’ayogera akuuma obulamu bwe, 
\q2 naye oyo amala googera, alizikirira. 
\b  
\q1  
\v 4 Omuntu omugayaavu yeegomba kyokka n’atabaako ky’afuna, 
\q2 naye omunyiikivu byayagala byonna abifuna. 
\b  
\q1  
\v 5 Omuntu omutuukirivu akyawa obulimba, 
\q2 naye omukozi w’ebibi yeereetera kunyoomebwa. 
\b  
\q1  
\v 6 Obutuukirivu bukuuma omuntu omwesimbu, 
\q2 naye okukola ebibi kuzikiriza omwonoonyi. 
\b  
\q1  
\v 7 Omuntu omu ayinza okwefuula omugagga ate nga taliiko ky’alina, 
\q2 ate omulala ne yeefuula okuba omwavu so nga mugagga nnyo. 
\b  
\q1  
\v 8 Obugagga bw’omuntu buyinza okumununula, 
\q2 naye omwavu talina ky’atya. 
\b  
\q1  
\v 9 Ekitangaala ky’abatuukirivu kyaka nnyo, 
\q2 naye ettaala y’abakozi b’ebibi ezikira. 
\b  
\q1  
\v 10 Amalala gazaala buzaazi nnyombo, 
\q2 naye amagezi gasangibwa mu abo abakkiriza okulabulwa. 
\b  
\q1  
\v 11 Ensimbi enkumpanye ziggwaawo, 
\q2 naye ezijja empolampola zeeyongera obungi. 
\b  
\q1  
\v 12 Essuubi erirwawo okutuukirira lirwaza omutima, 
\q2 naye ekyegombebwa bwe kituukirira kiba muti gwa bulamu. 
\b  
\q1  
\v 13 Omuntu anyooma ebiragiro aligwa mu mitawaana, 
\q2 naye oyo awuliriza ebimulagirwa aliweebwa empeera. 
\b  
\q1  
\v 14 Okuyigiriza kw’omuntu alina amagezi nsulo ya bulamu, 
\q2 era kuggya omuntu mu mitego gy’okufa. 
\b  
\q1  
\v 15 Okutegeera okulungi kuleeta okuganja, 
\q2 naye ekkubo ly’abateesigibwa liba zzibu. 
\b  
\q1  
\v 16 Omuntu omwegendereza akola amaze kulowooza, 
\q2 naye omusirusiru alaga obutamanya bwe. 
\b  
\q1  
\v 17 Omubaka omubi yeesuula mu mitawaana, 
\q2 naye omubaka omwesigwa aleeta kuwonyezebwa. 
\b  
\q1  
\v 18 Anyooma okukangavvulwa yeereetako obwavu n’obuswavu, 
\q2 naye oyo assaayo omwoyo ku kunenyezebwa aweebwa ekitiibwa. 
\b  
\q1  
\v 19 Ekyegombebwa bwe kituukirira kisanyusa omutima, 
\q2 naye okulekayo okukola ebibi kya muzizo eri abasirusiru. 
\b  
\q1  
\v 20 Oyo atambula n’abantu abagezi ageziwala, 
\q2 naye oyo atambula n’abasirusiru alaba ennaku. 
\b  
\q1  
\v 21 Emitawaana gigoberera aboonoonyi, 
\q2 naye okukulaakulana y’empeera y’abatuukirivu. 
\b  
\q1  
\v 22 Omuntu omulungi alekera bazzukulu be ebyobusika, 
\q2 naye obugagga bw’omwonoonyi buterekerwa omutuukirivu. 
\b  
\q1  
\v 23 Ennimiro z’abaavu ziyinza okuvaamu emmere nnyingi, 
\q2 naye obutali bwenkanya ne bugyera yonna. 
\b  
\q1  
\v 24 Atakozesa kaggo akyawa omwana we, 
\q2 naye oyo amwagala afaayo okumukangavvula. 
\b  
\q1  
\v 25 Omutuukirivu alya emmere ye n’akkuta, 
\q2 naye abakozi b’ebibi basigala nga bayala. 
\b  
\c 14  
\q1  
\v 1 Omukazi ow’amagezi yeezimbira ennyumba ye, 
\q2 naye omusirusiru eyiye agyemenyera n’emikono gye. 
\b  
\q1  
\v 2 Omuntu atambulira mu bugolokofu atya \nd Mukama\nd*, 
\q2 naye ow’amakubo amakyamu anyooma \nd Mukama\nd*. 
\b  
\q1  
\v 3 Ebigambo by’omusirusiru bye bimuviirako okukubwa, 
\q2 naye eby’abatuukirivu binaabakuumanga. 
\b  
\q1  
\v 4 Awataba nte nnume ezirima ebyagi biba bikalu, 
\q2 naye emmere ennyingi eva mu maanyi gaazo. 
\b  
\q1  
\v 5 Omujulizi ow’amazima talimba, 
\q2 naye ow’obulimba ayogera bya bulimba. 
\b  
\q1  
\v 6 Omukudaazi anoonya amagezi n’atagalaba, 
\q2 naye okumanya kwanguyira omuntu ategeera. 
\b  
\q1  
\v 7 Teweeretereza muntu musirusiru, 
\q2 kubanga tewali by’amagezi biva mu kamwa ke. 
\b  
\q1  
\v 8 Omutegeevu mugezi kubanga afaayo okutegeera by’akola, 
\q2 naye atalina magezi musirusiru kubanga yeerimba nti amanyi. 
\b  
\q1  
\v 9 Abasirusiru banyooma okugololwa nga bakoze ensobi, 
\q2 naye abalongoofu baagala emirembe. 
\b  
\q1  
\v 10 Buli mutima gumanya okulumwa kwagwo, 
\q2 tewali ayinza kugusanyukirako. 
\b  
\q1  
\v 11 Ennyumba y’abakozi b’ebibi erizikirizibwa, 
\q2 naye eweema y’abatuukirivu erikulaakulana. 
\b  
\q1  
\v 12 Waliwo ekkubo erirabika nga ttuufu eri omuntu, 
\q2 naye ng’enkomerero yaalyo kufa. 
\b  
\q1  
\v 13 Enseko zandibaawo naye ng’omutima gujjudde ennaku, 
\q2 era n’enkomerero y’essanyu eyinza okufuuka obuyinike. 
\b  
\q1  
\v 14 Omuntu atalina kukkiriza alisasulwa empeera emusaanira olw’ebikolwa bye, 
\q2 n’omuntu omulungi naye alisasulwa eyiye. 
\b  
\q1  
\v 15 Ow’amagezi amatono amala gakkiriza buli kigambo ky’awulira, 
\q2 naye omuntu omutegeevu yeegendereza amakubo ge. 
\b  
\q1  
\v 16 Omuntu ow’amagezi atya \nd Mukama\nd* n’aleka okukola ebibi, 
\q2 naye omusirusiru yeepankapanka era teyeegendereza. 
\b  
\q1  
\v 17 Omuntu asunguwala amangu akola eby’obusirusiru, 
\q2 n’omukalabakalaba akyayibwa. 
\b  
\q1  
\v 18 Abatalina magezi basikira butaliimu, 
\q2 naye abategeevu batikkirwa engule ey’okumanya. 
\b  
\q1  
\v 19 Abakozi b’ebibi balivuunamira abatuukirivu, 
\q2 n’aboonoonyi ne bavuunama mu miryango gy’abatuukirivu. 
\s1 Omugagga n’Omwavu 
\b  
\q1  
\v 20 Omwavu alagajjalirwa abantu nga ne muliraanwa we omutwaliddemu, 
\q2 naye abagagga baba n’emikwano mingi. 
\b  
\q1  
\v 21 Anyooma muliraanwa we akola kibi, 
\q2 naye alina omukisa oyo asaasira abaavu. 
\b  
\q1  
\v 22 Abateekateeka okukola ebibi, tebawaba? 
\q2 Naye okwagala n’amazima binaabeeranga n’abo abateesa okukola obulungi. 
\b  
\q1  
\v 23 Buli mulimu ogukolebwa n’amaanyi gubaako amagoba, 
\q2 naye okwogera obwogezi kireeta bwavu bwokka. 
\b  
\q1  
\v 24 Abagezi bafuna engule ey’obugagga, 
\q2 naye obusirusiru bw’abatalina magezi buzaala busirusiru. 
\b  
\q1  
\v 25 Omujulizi ow’amazima awonya obulamu bw’abantu, 
\q2 naye omujulizi ow’obulimba aba mulimba. 
\b  
\q1  
\v 26 Atya \nd Mukama\nd* alina ekiddukiro eky’amaanyi, 
\q2 era n’abaana be balibeera n’obuddukiro. 
\b  
\q1  
\v 27 Okutya \nd Mukama\nd* ye nsulo y’obulamu, 
\q2 kuleetera omuntu okwewala emitego gy’okufa. 
\b  
\q1  
\v 28 Ekitiibwa kya kabaka kiri mu kuba n’abantu bangi, 
\q2 naye omukulembeze ataba n’abantu abeera mu kabi. 
\b  
\q1  
\v 29 Omuntu omugumiikiriza aba n’okutegeera kungi, 
\q2 naye oyo asunguwala amangu ayolesa obusirusiru. 
\b  
\q1  
\v 30 Omutima ogulina emirembe guwangaaza omuntu, 
\q2 naye obuggya buvunza amagumba ge. 
\b  
\q1  
\v 31 Omuntu atulugunya abaavu anyooma oyo eyabatonda, 
\q2 naye buli abakwatirwa ekisa, agulumiza Katonda. 
\b  
\q1  
\v 32 Akacwano bwe kajja, omukozi w’ebibi agwa, 
\q2 naye omutuukirivu ne mu kufa aba n’obuddukiro. 
\b  
\q1  
\v 33 Amagezi gabeera mu mutima gw’omuntu alina okutegeera, 
\q2 era yeeyoleka ne mu basirusiru. 
\b  
\q1  
\v 34 Obutuukirivu buzimba eggwanga, 
\q2 naye ekibi kiswaza abantu ab’engeri zonna. 
\b  
\q1  
\v 35 Kabaka asanyukira omuddu akola eby’amagezi, 
\q2 naye obusungu bwa kabaka bunaabuubuukiranga ku oyo akola ebiswaza. 
\b  
\c 15  
\q1  
\v 1 Okuddamu n’eggonjebwa kumalawo ekiruyi, 
\q2 naye ekigambo eky’obukambwe kisaanuula obusungu. 
\b  
\q1  
\v 2 Olulimi lw’omugezi lwogera by’amagezi, 
\q2 naye akamwa k’abasirusiru kafukumula busirusiru bwereere. 
\b  
\q1  
\v 3 Amaaso ga \nd Mukama\nd* galaba buli wantu, 
\q2 alaba abatuukirivu n’abakozi b’ebibi. 
\b  
\q1  
\v 4 Olulimi oluzimba muti gwa bulamu, 
\q2 naye olulimi olulimba lubetenta omutima. 
\b  
\q1  
\v 5 Omusirusiru anyooma okubuulirirwa kwa kitaawe, 
\q2 naye omutegeevu assaayo omwoyo eri okunenyezebwa. 
\b  
\q1  
\v 6 Mu nnyumba y’omutuukirivu mubaamu obugagga bungi, 
\q2 naye omukozi w’ebibi by’afuna, bimuleetera emitawaana. 
\b  
\q1  
\v 7 Akamwa k’amagezi kabunyisa okumanya, 
\q2 naye omutima gw’abasirusiru si bwe gukola. 
\b  
\q1  
\v 8 Ssaddaaka y’aboonoonyi ya muzizo eri \nd Mukama\nd*, 
\q2 naye okusaba kw’abalongoofu lye ssanyu lye. 
\b  
\q1  
\v 9 Ekkubo ly’omwonoonyi lya muzizo eri \nd Mukama\nd*, 
\q2 naye \nd Mukama\nd* ayagala oyo anoonya obutuukirivu. 
\b  
\q1  
\v 10 Oyo aleka ekkubo ettuufu alikangavvulwa n’amaanyi, 
\q2 n’oyo akyawa okunenyezebwa alifa. 
\b  
\q1  
\v 11 Okufa n’okuzikirira biri mu maaso ga \nd Mukama\nd*, 
\q2 n’okulaba alaba nnyo emitima gy’abaana b’abantu! 
\b  
\q1  
\v 12 Omunyoomi tayagala kunenyezebwa, 
\q2 era teeyeebuuza ku b’amagezi. 
\b  
\q1  
\v 13 Omutima omusanyufu guleeta essanyu ku maaso, 
\q2 naye omutima omunyiikaavu gunafuya emmeeme. 
\b  
\q1  
\v 14 Omutima omutegeevu gunoonya okumanya, 
\q2 naye akamwa k’abasirusiru kalya busirusiru. 
\b  
\q1  
\v 15 Omuntu bw’aba omunyiikaavu, buli kimu kimwononekera, 
\q2 naye omutima omusanyufu gujaguza buli kaseera. 
\b  
\q1  
\v 16 Okuba n’akatono ng’otya \nd Mukama\nd*, 
\q2 kusinga okuba n’ebingi naye ng’oli mu mitawaana. 
\b  
\q1  
\v 17 Okulya emmere ng’eriko enva endiirwa awali okwagalana, 
\q2 kisinga okuliirako ebyassava awali obukyayi. 
\b  
\q1  
\v 18 Omuntu asunguwala amangu asaanuula oluyombo, 
\q2 naye omugumiikiriza akakkanya embeera. 
\b  
\q1  
\v 19 Ekkubo ly’omugayaavu lijjula amaggwa, 
\q2 naye ekkubo ly’omutuukirivu golokofu. 
\b  
\q1  
\v 20 Omwana omugezi asanyusa kitaawe, 
\q2 naye omuntu omusirusiru anyooma nnyina. 
\b  
\q1  
\v 21 Obusirusiru ssanyu eri oyo atalina magezi, 
\q2 naye omuntu ategeera atambulira mu kkubo eggolokofu. 
\b  
\q1  
\v 22 Awatali kuluŋŋamizibwa entegeka zifa, 
\q2 naye awali abawi b’amagezi abangi ziyitamu. 
\b  
\q1  
\v 23 Okuddamu obulungi kisanyusa, 
\q2 era kirungi ekigambo ekirungi okujjira mu kiseera ekituufu. 
\b  
\q1  
\v 24 Ekkubo ery’obulamu liyimusa omugezi, 
\q2 ne limuziyiza okukka emagombe. 
\b  
\q1  
\v 25 \nd Mukama\nd* azikiriza ennyumba y’ab’amalala, 
\q2 kyokka akuuma ensalo za nnamwandu. 
\b  
\q1  
\v 26 Enkwe za muzizo eri \nd Mukama\nd*, 
\q2 naye ebigambo ebisaanidde, bimusanyusa. 
\b  
\q1  
\v 27 Oyo anoonya okugaggawalira mu bukyamu aleetera ennyumba ye emitawaana, 
\q2 naye oyo akyawa enguzi aliba mulamu. 
\b  
\q1  
\v 28 Omutima gw’omutuukirivu gufumiitiriza bye gunaayanukula, 
\q2 naye akamwa k’omwonoonyi kafubutula ebitasaana. 
\b  
\q1  
\v 29 \nd Mukama\nd* ali wala n’aboonoonyi, 
\q2 naye awulira okusaba kw’abatuukirivu. 
\b  
\q1  
\v 30 Amaaso agajjudde essanyu gasanyusa omutima, 
\q2 n’amawulire amalungi galeetera amagumba obulamu. 
\b  
\q1  
\v 31 Oyo assaayo omwoyo eri okunenyezebwa okuleeta obulamu, 
\q2 alituula wamu n’abagezi. 
\b  
\q1  
\v 32 Agayaalirira okubuulirirwa yeerumya yekka, 
\q2 naye oyo assaayo omwoyo eri okunenyezebwa afuna okutegeera. 
\b  
\q1  
\v 33 Okutya \nd Mukama\nd* kuyigiriza omuntu amagezi, 
\q2 n’obwetoowaze kye kitiibwa ky’omuntu oyo. 
\c 16  
\s1 \nd Mukama\nd* Agera Ekkubo ly’Omuntu 
\q1  
\v 1 Omuntu ateekateeka by’ayagala okukola mu mutima gwe, 
\q2 Naye okuddamu kuva eri \nd Mukama\nd*. 
\b  
\q1  
\v 2 Amakubo g’omuntu gonna gaba matuufu mu maaso ge ye, 
\q2 naye \nd Mukama\nd* y’apima ebigendererwa. 
\b  
\q1  
\v 3 Emirimu gyo gyonna gikwasenga \nd Mukama\nd*, 
\q2 naye anaatuukirizanga entegeka zo. 
\b  
\q1  
\v 4 \nd Mukama\nd* buli kimu akikola ng’alina ekigendererwa, 
\q2 n’abakozi b’ebibi y’abakolera olunaku lwe batuukibwako ebizibu. 
\b  
\q1  
\v 5 Buli muntu alina omutima ogw’amalala wa muzizo eri \nd Mukama\nd*; 
\q2 weewaawo talirema kubonerezebwa. 
\b  
\q1  
\v 6 Olw’okwagala n’olw’obwesigwa, ekibi kisasulibwa, 
\q2 n’okutya \nd Mukama\nd* kuleetera omuntu okwewala okukola ebibi. 
\b  
\q1  
\v 7 Amakubo g’omuntu bwe gaba gasanyusa \nd Mukama\nd*, 
\q2 aleetera abalabe b’omuntu oyo okubeera naye mu mirembe. 
\b  
\q1  
\v 8 Akatono akafune mu butuukirivu, 
\q2 kasinga obugagga obungi obufune mu bukyamu. 
\b  
\q1  
\v 9 Omutima gw’omuntu guteekateeka ekkubo lye, 
\q2 naye \nd Mukama\nd* y’aluŋŋamya bw’anaatambula. 
\b  
\q1  
\v 10 Kabaka ky’ayogera kiba ng’ekiva eri Katonda, 
\q2 n’akamwa ke tekasaanye kwogera bitali bya bwenkanya. 
\b  
\q1  
\v 11 Ebipimo ne minzaani ebituufu bya \nd Mukama\nd*, 
\q2 ebipimo byonna ebikozesebwa y’abikola. 
\b  
\q1  
\v 12 Kya muzizo bakabaka okukola ebibi, 
\q2 kubanga entebe ye ey’obwakabaka enywezebwa butuukirivu. 
\b  
\q1  
\v 13 Akamwa akogera eby’amazima bakabaka ke basanyukira, 
\q2 era baagala oyo ayogera amazima. 
\b  
\q1  
\v 14 Obusungu bwa kabaka buli ng’ababaka abaleese okufa, 
\q2 omusajja ow’amagezi alibukkakkanya. 
\b  
\q1  
\v 15 Kabaka bw’asanyuka kireeta obulamu; 
\q2 n’okuganza kwe, kuli nga ekire eky’enkuba\f + \fr 16:15 \ft Ekire ky’enkuba mu biseera ebya ttoggo etegeeza kujimuka, era kabonero ka kukulaakulana na ssanyu\f* mu biseera ebya ttoggo. 
\b  
\q1  
\v 16 Okufuna amagezi nga kusinga nnyo okufuna zaabu, 
\q2 era n’okufuna okutegeera kikira ffeeza! 
\b  
\q1  
\v 17 Ekkubo ly’abagolokofu kwe kwewala ebibi, 
\q2 n’oyo eyeekuuma mu kutambula kwe, awonya emmeeme ye. 
\b  
\q1  
\v 18 Amalala gakulembera okuzikirira, 
\q2 n’omwoyo ogwegulumiza gukulembera ekigwo. 
\b  
\q1  
\v 19 Okubeera n’omwoyo ogwetoowaza era n’okubeera n’abaavu, 
\q2 kisinga okugabana omunyago n’ab’amalala. 
\b  
\q1  
\v 20 Oyo assaayo omwoyo ku kuyigirizibwa alikulaakulana, 
\q2 era alina omukisa oyo eyeesiga \nd Mukama\nd*. 
\b  
\q1  
\v 21 Abalina emitima egy’amagezi baliyitibwa bategeevu, 
\q2 n’enjogera ennungi eyongera okuyamba okutegeera. 
\b  
\q1  
\v 22 Amagezi nsulo ya bulamu eri oyo agalina, 
\q2 naye obusirusiru buleetera abasirusiru okubonerezebwa. 
\b  
\q1  
\v 23 Omutima gw’omuntu ow’amagezi gumuwa enjogera ennungi, 
\q2 era akamwa ke kayigiriza abalala. 
\b  
\q1  
\v 24 Ebigambo ebirungi biri ng’ebisenge by’omubisi gw’enjuki, 
\q2 biwoomera emmeeme, ne biwonya n’amagumba. 
\b  
\q1  
\v 25 Wabaawo ekkubo erirabika ng’ettuufu eri omuntu, 
\q2 naye ku nkomerero limutuusa mu kufa. 
\b  
\q1  
\v 26 Okwagala okulya kuleetera omuntu okukola n’amaanyi, 
\q2 kubanga enjala emukubiriza okweyongera okukola. 
\b  
\q1  
\v 27 Omuntu omusirusiru ategeka okukola ebitali bya butuukirivu, 
\q2 era n’ebigambo bye, biri ng’omuliro ogwokya ennyo. 
\b  
\q1  
\v 28 Omuntu omubambaavu asiikuula entalo, 
\q2 n’ow’olugambo ayawukanya ab’omukwano enfirabulago. 
\b  
\q1  
\v 29 Omuntu omukyamu asendasenda muliraanwa we 
\q2 n’amutwala mu kkubo eritali ttuufu. 
\b  
\q1  
\v 30 Omuntu atemya ku liiso ateekateeka kwonoona, 
\q2 n’oyo asongoza emimwa ategeka kukola bitali birungi. 
\b  
\q1  
\v 31 Omutwe ogw’envi ngule ya kitiibwa, 
\q2 gufunibwa abo abatambulira mu bulamu obutuukirivu. 
\b  
\q1  
\v 32 Omuntu omugumiikiriza asinga omutabaazi, 
\q2 n’oyo afuga obusungu bwe akira awamba ekibuga. 
\b  
\q1  
\v 33 Akalulu kayinza okukubibwa, 
\q2 naye okusalawo kwa byonna kuva eri \nd Mukama\nd*. 
\b  
\c 17  
\q1  
\v 1 Okulya akamere akaluma awali emirembe, 
\q2 kisinga okuba mu nnyumba ejjudde ebyassava nga mulimu entalo. 
\b  
\q1  
\v 2 Omuddu omugezi alifuga omwana wa bowo akwasa ensonyi, 
\q2 era alifuna ebyobusika ng’omu ku baana b’awaka. 
\b  
\q1  
\v 3 Entamu erongoosa yakolebwa lwa ffeeza, n’ekikoomi ky’okulongoosa lwa zaabu, 
\q2 naye \nd Mukama\nd* agezesa emitima. 
\b  
\q1  
\v 4 Omubi assaayo omwoyo eri eby’obulimba, 
\q2 era n’omulimba awuliriza olulimi olukuusa. 
\b  
\q1  
\v 5 Oyo akudaalira omwavu avvoola eyamutonda, 
\q2 n’oyo asanyukira obuyinike bw’abalala talirema kubonerezebwa. 
\b  
\q1  
\v 6 Abazzukulu ngule ya bajjajjaabwe, 
\q2 era n’abaana beenyumiririza mu bakadde baabwe. 
\b  
\q1  
\v 7 Enjogerannungi teba ya musirusiru, 
\q2 ng’oweekitiibwa bw’atasaana kwogera bya bulimba. 
\b  
\q1  
\v 8 Enguzi eri ng’ejjinja ery’omufuusa mu maaso g’oyo agigaba, 
\q2 alowooza nti buli gy’akyukira eneemuyamba. 
\b  
\q1  
\v 9 Okwagala tekulondoola nsobi, 
\q2 naye oyo atasonyiwa nsobi akyawaganya ab’omukwano enfirabulago. 
\b  
\q1  
\v 10 Okunenya kuyamba nnyo omuntu ategeera, 
\q2 okusinga okukuba omusirusiru embooko ekikumi. 
\b  
\q1  
\v 11 Omukozi w’ebibi anoonya bujeemu bwereere, 
\q2 era kyaliva asindikirwa omubaka omukambwe. 
\b  
\q1  
\v 12 Okusisinkana eddubu enyagiddwako abaana baayo, 
\q2 kisinga okusisinkana omusirusiru mu busirusiru bwe. 
\s1 Ebbeeyi y’Amagezi 
\q1  
\v 13 Omuntu bw’asasula ekibi olw’obulungi, 
\q2 ekibi tekiriva mu nnyumba ye. 
\b  
\q1  
\v 14 Okutandika oluyombo kuli ng’omuntu bw’asumulula omudumu gw’amazzi, 
\q2 noolwekyo vvaawo ng’oluyombo terunnatandika. 
\b  
\q1  
\v 15 Eyejjeereza omukozi w’ebibi n’oyo avumirira omutuukirivu, 
\q2 bombi ba muzizo eri \nd Mukama\nd*. 
\b  
\q1  
\v 16 Omusirusiru agasibwa ki okuba ne ssente ezisasulibwa amagezi, 
\q2 ng’ate ye talina mutima gwegomba magezi? 
\b  
\q1  
\v 17 Omukwano ogw’amagezi guba gwa lubeerera, 
\q2 era owooluganda yeesigibwa mu biro eby’ennaku. 
\b  
\q1  
\v 18 Omuntu atalina magezi awa obweyamo 
\q2 ne yeetema okusasula amabanja ga muliraanwa we. 
\b  
\q1  
\v 19 Oyo ayagala ekibi anyumirwa ennyombo, 
\q2 n’oyo akola omulyango omunene ogw’omu maaso gwa bbugwe ye nga guyitiridde obunene gulimuteganya nnyo. 
\b  
\q1  
\v 20 Omuntu ow’omutima omubambaavu takulaakulana, 
\q2 n’oyo ow’olulimi olulimba agwa mu katyabaga. 
\b  
\q1  
\v 21 Omwana omusirusiru aleetera kitaawe obuyinike, 
\q2 kitaawe w’omusirusiru taba na ssanyu. 
\b  
\q1  
\v 22 Omutima ogw’essanyu ddagala ddungi, 
\q2 naye omwoyo omunyiikaavu gukozza omubiri. 
\b  
\q1  
\v 23 Omuntu omubi alya enguzi mu kyama, 
\q2 alyoke aziyize amazima okweyoleka. 
\b  
\q1  
\v 24 Omuntu omutegeevu, ebirowoozo abissa eri amagezi, 
\q2 naye amaaso g’omusirusiru gasamaalirira ensi gy’ekoma. 
\b  
\q1  
\v 25 Omwana omusirusiru buyinike eri kitaawe, 
\q2 era aleeta ennaku eri nnyina eyamuzaala. 
\b  
\q1  
\v 26 Si kirungi okuweesa omutuukirivu engassi ey’obwereere 
\q2 wadde okukuba ab’ekitiibwa embooko olw’obwesimbu bwabwe. 
\b  
\q1  
\v 27 Omuntu omwegendereza mu bigambo bye abeera n’okutegeera, 
\q2 n’oyo alina omwoyo omuteefu aba muntu wa magezi. 
\b  
\q1  
\v 28 Omusirusiru bw’asirika alowoozebwa okuba n’amugezi, 
\q2 era aba mutegeevu bw’afuga akamwa ke. 
\c 18  
\s1 Ebigambo by’Abagezi n’Abasirusiru 
\q1  
\v 1 Eyeggya ku banne aba yeerowoozako yekka, 
\q2 era tawuliriza magezi gamuweebwa. 
\b  
\q1  
\v 2 Omusirusiru tasanyukira kutegeera, 
\q2 ky’asanyukira kyokka kwe kwogera by’alowooza. 
\b  
\q1  
\v 3 Okukola ekibi bwe kujja n’okunyooma kujjirako, 
\q2 era awali okuyisaamu omuntu amaaso wabaawo okunyoomoola. 
\b  
\q1  
\v 4 Ebigambo by’omu kamwa k’omuntu mazzi ga buziba, 
\q2 naye ensulo ey’amagezi mugga ogukulukuta. 
\b  
\q1  
\v 5 Si kirungi kuttira mubi ku liiso, 
\q2 oba okusaliriza omutuukirivu. 
\b  
\q1  
\v 6 Akamwa k’omusirusiru kamuleetera entalo 
\q2 era akamwa ke kamuleetera okukubwa emiggo. 
\b  
\q1  
\v 7 Akamwa k’omusirusiru ke kamuleetera okuzikirira, 
\q2 era n’emimwa gye mutego eri emmeeme ye. 
\b  
\q1  
\v 8 Ebigambo by’omuntu ageya biri ng’emmere ewoomerera, 
\q2 bigenda mu bitundu by’omubiri eby’ewala. 
\b  
\q1  
\v 9 Omuntu omugayaavu mu mirimu gy’akola, 
\q2 waluganda n’oyo azikiriza. 
\b  
\q1  
\v 10 Erinnya lya \nd Mukama\nd* kigo ky’amaanyi, 
\q2 omutuukirivu addukira omwo n’afuna emirembe. 
\b  
\q1  
\v 11 Obugagga bw’omugagga, kye kibuga kye ekiriko bbugwe ow’amaanyi, 
\q2 era mu kulaba kwe, kigo kye ekigumu ekitarinnyika. 
\b  
\q1  
\v 12 Omuntu nga tannagwa, omutima gwe gwegulumiza, naye okwetoowaza kumuweesa ekitiibwa. 
\b  
\q1  
\v 13 Oyo addamu amangu mu nsonga gy’ateetegerezza, 
\q2 buba busirusiru bwe era buswavu. 
\b  
\q1  
\v 14 Omwoyo gw’omuntu gumuwanirira mu bulwadde, 
\q2 naye emmeeme eyennyise ani ayinza okugigumiikiriza? 
\b  
\q1  
\v 15 Omutima gw’omwegendereza guyiga okumanya, 
\q2 amatu g’omuntu omugezi gawuliriza. 
\b  
\q1  
\v 16 Ekirabo ky’omuntu kimuseguliza, 
\q2 era kimutuusa ne mu maaso g’abeekitiibwa. 
\b  
\q1  
\v 17 Asooka okweyogerako y’afaanana ng’omutuufu, 
\q2 okutuusa omulala lw’amubuuza ebibuuzo. 
\b  
\q1  
\v 18 Okukuba akalulu kimalawo empaka, 
\q2 era kisalawo eggoye wakati w’abawakana ab’amaanyi. 
\b  
\q1  
\v 19 Kyangu okuwamba ekibuga ekiriko bbugwe ow’amaanyi, okusinga okukomyawo owooluganda anyiize, 
\q2 era ennyombo ziba ng’empagi z’ekigo. 
\b  
\q1  
\v 20 Omuntu anakkutanga ebigambo ebiva mu kamwa ke; 
\q2 ebibala ebijjula akamwa ke bye binamukkusanga. 
\b  
\q1  
\v 21 Olulimi lulina obuyinza okuwa obulamu oba okutta, 
\q2 era n’abo abalwagala balirya ebibala byalwo. 
\b  
\q1  
\v 22 Azuula omukazi omulungi ow’okuwasa aba azudde ekirungi, 
\q2 era aganja eri \nd Mukama\nd*. 
\b  
\q1  
\v 23 Omwavu yeegayirira, 
\q2 naye omugagga addamu na bbogo. 
\b  
\q1  
\v 24 Akwana emikwano emingi yeereetera okuzikirira, 
\q2 naye wabaawo ow’omukwano akwagala ennyo okusinga owooluganda. 
\b  
\c 19  
\q1  
\v 1 Omuntu omwavu atambulira mu butuukirivu, 
\q2 asinga akamwa ak’omusirusiru akaweebuula. 
\b  
\q1  
\v 2 Si kirungi okuba omujjumbize naye nga tolina kumanya, 
\q2 n’okwanguyiriza okukola ekintu kuleetera omuntu okukwata ekkubo ekyamu. 
\b  
\q1  
\v 3 Obusirusiru bw’omuntu bwe bwonoona obulamu bwe, 
\q2 kyokka omutima gwe ne gunenya \nd Mukama\nd*. 
\b  
\q1  
\v 4 Obugagga buleeta emikwano mingi, 
\q2 naye emikwano gy’omwavu gimuddukako. 
\b  
\q1  
\v 5 Omujulizi ow’obulimba talirema kubonerezebwa, 
\q2 era oyo ayogera eby’obulimba taliba na buddukiro. 
\b  
\q1  
\v 6 Bangi banoonya okuganja mu maaso g’omufuzi, 
\q2 era buli muntu aba mukwano gw’oyo agaba ebirabo. 
\b  
\q1  
\v 7 Baganda b’omwavu bonna bamwewala, 
\q2 mikwano gye tebaasingewo nnyo okumwewala? 
\b  
\q1 Wadde abagoberera ng’abeegayirira, 
\q2 naye tabalaba. 
\b  
\q1  
\v 8 Oyo afuna amagezi ayagala emmeeme ye, 
\q2 n’oyo asanyukira okutegeera, akulaakulana. 
\b  
\q1  
\v 9 Omujulizi ow’obulimba talirema kubonerezebwa, 
\q2 n’oyo ayogera eby’obulimba alizikirira. 
\b  
\q1  
\v 10 Omusirusiru tasaana kubeera mu bulamu bwa kwejalabya, 
\q2 kale kiwulikika kitya ng’omuddu afuga abalangira? 
\b  
\q1  
\v 11 Omuntu omutegeevu alwawo okusunguwala, 
\q2 era kiba kya kitiibwa obutafa ku bye bamusobezza. 
\b  
\q1  
\v 12 Obusungu bwa kabaka buli ng’okuwuluguma kw’empologoma, 
\q2 naye ekisa kye kiri ng’omusulo ku ssubi. 
\b  
\q1  
\v 13 Omwana omusirusiru aleetera kitaawe okuzikirira, 
\q2 n’omukazi omuyombi ali ng’enkuba etonnya olutata. 
\b  
\q1  
\v 14 Ennyumba n’obugagga bisikirwa okuva ku bazadde, 
\q2 naye omukazi omutegeevu ava eri \nd Mukama\nd*. 
\b  
\q1  
\v 15 Obugayaavu buleeta otulo tungi, 
\q2 n’omuntu atakola mirimu alirumwa enjala. 
\b  
\q1  
\v 16 Oyo akwata ebiragiro akuuma obulamu bwe, 
\q2 naye oyo eyeeyisa mu ngeri embi alifa. 
\b  
\q1  
\v 17 Oyo akwatirwa omwavu ekisa awola \nd Mukama\nd*, 
\q2 era \nd Mukama\nd* alimusasula olw’ekikolwa kye ekyo. 
\b  
\q1  
\v 18 Kangavvulanga omwana wo kubanga mu ekyo mulimu essuubi, 
\q2 oleme kumuwaayo mu kuzikirira. 
\b  
\q1  
\v 19 Omuntu omukambwe ennyo alisasula ebiriva mu bukambwe bwe, 
\q2 kubanga ne bw’omununula ogusooka era oteekwa okukiddiŋŋaana. 
\b  
\q1  
\v 20 Ssangayo omwoyo ku magezi agakuweebwa ne ku kuyigirizibwa, 
\q2 oluvannyuma lwa byonna oliba n’amagezi. 
\b  
\q1  
\v 21 Enteekateeka z’omuntu ziba nnyingi mu mutima gwe; 
\q2 byo ebigendererwa bya \nd Mukama\nd* bituukirira. 
\b  
\q1  
\v 22 Ekintu omuntu kye yeegomba kwe kwagala okutaggwaawo, 
\q2 okuba omwavu kisinga okuba omulimba. 
\b  
\q1  
\v 23 Okutya \nd Mukama\nd* kutuusa mu bulamu; 
\q2 olwo omuntu n’awummula nga mumativu nga tatuukiddwako kabi. 
\b  
\q1  
\v 24 Omugayaavu annyika omukono gwe mu kibya, 
\q2 n’atagukomyawo nate ku mumwa gwe. 
\b  
\q1  
\v 25 Kangavvula omunyoomi, abatamanyi bayigire ku ye, 
\q2 buulirira ategeera, ajja kweyongera okutegeera. 
\b  
\q1  
\v 26 Omwana abba ebya kitaawe n’agobaganya ne nnyina, 
\q2 aleeta obuswavu n’obuyinike. 
\b  
\q1  
\v 27 Mwana wange konoolekayo okuyigirizibwa, 
\q2 onoowaba okuva ku bigambo by’okumanya. 
\b  
\q1  
\v 28 Omujulizi omulimba atyoboola ensala ey’amazima, 
\q2 n’akamwa k’ababi, kavaabira ebitali bya butuukirivu. 
\b  
\q1  
\v 29 Ebibonerezo bitekebwawo kukangavvula banyoomi, 
\q2 n’embooko zaakolebwa lwa migongo gy’abasirusiru. 
\b  
\c 20  
\q1  
\v 1 Omwenge mukudaazi, ekitamiiza muleekaanyi, 
\q2 era buli alaga mu kkubo ekyamu olw’ebyo talina magezi. 
\b  
\q1  
\v 2 Obusungu bwa kabaka buli ng’okuwuluguma kw’empologoma, 
\q2 n’oyo amusunguwaza yeefiiriza bulamu bwe. 
\b  
\q1  
\v 3 Kya kitiibwa omuntu okwewala entalo, 
\q2 naye buli musirusiru ayagala okuyomba. 
\b  
\q1  
\v 4 Omugayaavu talima mu budde butuufu, 
\q2 kyanaavanga anoonya eby’amakungula nga talina kantu. 
\b  
\q1  
\v 5 Ebigendererwa ebiba mu mutima gw’omuntu biba ng’amazzi ag’ebuziba, 
\q2 naye omuntu alina okutegeera alibiggyayo. 
\b  
\q1  
\v 6 Abantu bangi bagamba nti balina okwagala okutaggwaawo, 
\q2 naye ani ayinza okuzuula omuntu omwesigwa? 
\b  
\q1  
\v 7 Omuntu omutuukirivu, atambulira mu bulamu obutaliiko kyakunenyezebwa; 
\q2 ba mukisa abaana be abalimuddira mu bigere. 
\b  
\q1  
\v 8 Kabaka bw’atuula ku ntebe ye ey’obwakabaka ng’asala emisango, 
\q2 amaaso ge gasunsulamu ne gaggyamu ebibi byonna. 
\b  
\q1  
\v 9 Ani ayinza okugamba nti, “Ntukuzza omutima gwange, 
\q2 ndi mulongoofu era sirina kibi?” 
\b  
\q1  
\v 10 Ebipima obuzito ebitatuuka n’ebigera ebikyamu, 
\q2 byombi bya muzizo eri \nd Mukama\nd*. 
\b  
\q1  
\v 11 Omuvubuka naye amanyibwa olw’ebikolwa bye, 
\q2 obanga birongoofu era nga birungi. 
\b  
\q1  
\v 12 Okutu okuwulira n’eriiso eriraba 
\q2 byombi \nd Mukama\nd* ye y’abikola. 
\b  
\q1  
\v 13 Toyagalanga kwebaka oleme kwavuwala, 
\q2 tunula, obeerenga n’ebyokulya bingi. 
\b  
\q1  
\v 14 “Si kirungi, si kirungi,” bw’ayogera agula; 
\q2 naye bw’agenda n’alyoka yeenyumiririza mu ky’aguze. 
\b  
\q1  
\v 15 Zaabu n’amayinja ag’omuwendo weebiri, 
\q2 naye emimwa egyogera eby’amagezi kye ky’omuwendo ekisingako. 
\b  
\q1  
\v 16 Omuntu bw’aleeta ekyambalo kye ne yeeyimiririra gw’atamanyi, 
\q2 kitwalire ddala, na ddala bw’abanga yeeyimiririra omukazi omubambaavu. 
\b  
\q1  
\v 17 Emmere enfune mu bukyamu ewooma mu kulya, 
\q2 naye emufuukira amayinja mu kamwa. 
\b  
\q1  
\v 18 Kola entegeka nga weebuuza ku magezi, 
\q2 bw’oba onoolangirira olutalo sooka weebuuze. 
\b  
\q1  
\v 19 Oyo agenda ng’asaasaanya olugambo abotola ebyama, 
\q2 noolwekyo weewale omuntu ayogerayogera ennyo ebitaliimu. 
\b  
\q1  
\v 20 Omuntu akolimira kitaawe oba nnyina, 
\q2 ettabaaza ye erizikizibwa n’asigala mu kizikiza ekikutte ennyo. 
\b  
\q1  
\v 21 Eby’obusika ebifune ng’ekiseera kyabyo tekinnatuuka, 
\q2 ku nkomerero tebiba na mukisa. 
\b  
\q1  
\v 22 Toyogera nti, “Nzija kukusasula olw’ekibi kino!” 
\q2 Lindirira \nd Mukama\nd* alikuyamba. 
\b  
\q1  
\v 23 Ebipima ebikyamu bya muzizo eri \nd Mukama\nd*, 
\q2 ne minzaani ez’obulimba tezisanyusa. 
\b  
\q1  
\v 24 Amakubo g’omuntu gategekebwa \nd Mukama\nd*, 
\q2 omuntu ayinza atya okutegeera ekkubo lya \nd Mukama\nd*? 
\b  
\q1  
\v 25 Kyambika eri omuntu okwanguyiriza okweyama eri \nd Mukama\nd*, 
\q2 naye oluvannyuma n’afumiitiriza ku bye yeeyamye. 
\b  
\q1  
\v 26 Kabaka omugezi asengejja n’aggyamu abakozi b’ebibi, 
\q2 n’ababonereza awatali kusaasira. 
\b  
\q1  
\v 27 Ettabaaza ya \nd Mukama\nd* ekebera omwoyo gw’omuntu, 
\q2 n’enoonya mu bitundu eby’omunda ennyo. 
\b  
\q1  
\v 28 Okwagala n’obwesigwa bikuuma kabaka mu butebenkevu, 
\q2 era obufuzi bwe bunywezebwa na kwagala. 
\b  
\q1  
\v 29 Amaanyi kye kitiibwa ky’abavubuka, 
\q2 envi kye kitiibwa ky’abakadde. 
\b  
\q1  
\v 30 Emiggo n’ebiwundu biggyawo ebibi, 
\q2 n’embooko zitereeza ebifo eby’omunda ennyo. 
\b  
\c 21  
\q1  
\v 1 Omutima gwa kabaka guli ng’amazzi agakulukutira mu mukono gwa \nd Mukama\nd*, 
\q2 era agukyusiza gy’ayagala yonna. 
\b  
\q1  
\v 2 Buli kkubo lya muntu liba ng’ettuufu mu maaso ge, 
\q2 naye \nd Mukama\nd* apima omutima. 
\b  
\q1  
\v 3 Okukola ebituufu n’eby’amazima 
\q2 kisanyusa \nd Mukama\nd* okusinga ssaddaaka. 
\b  
\q1  
\v 4 Amaaso ageegulumiza, n’omutima ogw’amalala, 
\q2 ye ttabaaza y’ababi, era ebyo kwonoona. 
\b  
\q1  
\v 5 Enteekateeka z’omunyiikivu zivaamu magoba meereere, 
\q2 naye okwanguyiriza okutalina nteekateeka kuvaamu bwavu. 
\b  
\q1  
\v 6 Okufuna obugagga n’olulimi olulimba, 
\q2 mpewo buwewo etwalibwa eruuyi n’eruuyi era mutego gwa kufa. 
\b  
\q1  
\v 7 Obukambwe bw’ababi bulibamalawo, 
\q2 kubanga bagaana okukola eby’ensonga. 
\b  
\q1  
\v 8 Ekkubo ly’abazza emisango liba kyamu, 
\q2 naye ery’abataliiko musango liba golokofu. 
\b  
\q1  
\v 9 Okusula ku kasolya k’ennyumba, 
\q2 kisinga okubeera mu nnyumba n’omukazi omuyombi. 
\b  
\q1  
\v 10 Emmeeme y’omubi yeegomba okukola ebibi; 
\q2 talaga muliraanwa we kisa n’akatono. 
\b  
\q1  
\v 11 Omukudaazi bw’abonerezebwa, atalina magezi agafuna; 
\q2 n’ow’amagezi bw’ayigirizibwa afuna okutegeera. 
\b  
\q1  
\v 12 Katonda alaba ebifa mu nnyumba y’omubi, 
\q2 era abakozi b’ebibi abazikkiririza ddala. 
\b  
\q1  
\v 13 Oyo aziba amatu ge eri okulaajana kw’omwavu, 
\q2 naye alikoowoola nga talina amwanukula. 
\b  
\q1  
\v 14 Ekirabo ekigabire mu kyama kikakkanya obusungu obungi, 
\q2 n’enguzi ebikiddwa mu munagiro eggyawo ekiruyi ekingi. 
\b  
\q1  
\v 15 Ensonga bwe zisalibwa mu bwenkanya, lye ssanyu eri abatuukirivu, 
\q2 naye kiba kyekango eri abakozi b’ebibi. 
\b  
\q1  
\v 16 Omuntu awaba okuva mu kkubo ly’okutegeera, 
\q2 agukira mu bafu. 
\b  
\q1  
\v 17 Aganza eby’amasanyu anaabanga mwavu, n’oyo 
\q2 ayagala omwenge n’amafuta taligaggawala. 
\b  
\q1  
\v 18 Abakozi b’ebibi batuukibwako emitawaana egyandigudde ku balungi, 
\q2 n’ekyandituuse ku b’amazima kituuka ku batali beesigwa. 
\b  
\q1  
\v 19 Okubeera mu ddungu, 
\q2 kisinga okubeera n’omukazi omuyombi anyiiganyiiga. 
\b  
\q1  
\v 20 Mu nnyumba y’omutuukirivu mubaamu eby’obugagga eby’omuwendo, 
\q2 naye omusirusiru ebibye byonna abyonoona. 
\b  
\q1  
\v 21 Agoberera obutuukirivu n’ekisa, 
\q2 alibeera n’obulamu obukulaakulana n’ekitiibwa. 
\b  
\q1  
\v 22 Omuntu ow’amagezi alumba ekibuga eky’abazira nnamige, 
\q2 era n’asesebbula enfo yaabwe gye beesiga. 
\b  
\q1  
\v 23 Afuga akamwa ke n’olulimi lwe, 
\q2 yeewoonya emitawaana. 
\b  
\q1  
\v 24 “Mukudaazi,” lye linnya ly’ab’amalala abeeraga, 
\q2 abeetwalira mu kwemanya okw’ekitalo mwe batambulira. 
\b  
\q1  
\v 25 Okwetaaga kw’omugayaavu lwe luliba olumbe lwe, 
\q2 kubanga emikono gye tegyagala kukola. 
\b  
\q1  
\v 26 Olunaku lwonna aba yeegomba kweyongezaako, 
\q2 naye omutuukirivu agaba awatali kwebalira. 
\b  
\q1  
\v 27 Ssaddaaka y’omubi ya muzizo, 
\q2 na ddala bw’agireeta ng’alina ekigendererwa ekitali kirungi. 
\b  
\q1  
\v 28 Omujulizi ow’obulimba alizikirira, 
\q2 naye ekigambo ky’oyo ayogera eby’amazima kiribeerera emirembe gyonna. 
\b  
\q1  
\v 29 Omuntu omubi yeekazaakaza, 
\q2 naye omuntu ow’amazima yeegendereza amakubo ge. 
\b  
\q1  
\v 30 Tewali magezi, newaakubadde okutegeera, wadde ebiteeso 
\q2 ebiyinza okulemesa \nd Mukama\nd*. 
\b  
\q1  
\v 31 Embalaasi etegekerwa olunaku olw’olutalo, 
\q2 naye obuwanguzi buva eri \nd Mukama\nd*. 
\c 22  
\s1 Omugaso gw’Erinnya Eddungi 
\q1  
\v 1 Erinnya eddungi lyagalibwa okusinga eby’obugagga ebingi, 
\q2 n’okuganja kusinga ffeeza oba zaabu. 
\b  
\q1  
\v 2 Abagagga n’abaavu balina kimu ekibagatta, 
\q2 \nd Mukama\nd* ye Mutonzi waabwe bonna. 
\b  
\q1  
\v 3 Omuntu omutegeevu bw’alaba akabi yeekweka, 
\q2 naye abatalina magezi bagenda bugenzi mu maaso ne balumizibwa. 
\b  
\q1  
\v 4 Obugagga n’ekitiibwa n’obulamu 
\q2 y’empeera ey’okwetoowazanga n’okutyanga \nd Mukama\nd*. 
\b  
\q1  
\v 5 Amaggwa n’emitego biri mu kkubo ly’omubambaavu; 
\q2 naye oyo akuuma emmeeme ye anaabyewalanga. 
\b  
\q1  
\v 6 Manyiiriza omwana mu kkubo erimugwanira okutambulirangamu, 
\q2 ne bw’alikula talirivaamu. 
\b  
\q1  
\v 7 Omugagga afuga abaavu, 
\q2 naye eyeewola aba muddu w’oyo amuwola. 
\b  
\q1  
\v 8 Asiga obutali butuukirivu akungula mitawaana, 
\q2 n’oluga olw’obusungu bwe lulizikirizibwa. 
\b  
\q1  
\v 9 Omuntu omugabi anaabanga n’omukisa, 
\q2 kubanga emmere ye agirya n’abaavu. 
\b  
\q1  
\v 10 Goba omunyoomi, entalo zinaagenda, 
\q2 ennyombo n’okuvumagana binaakoma. 
\b  
\q1  
\v 11 Omuntu eyeegomba omutima omulongoofu 
\q2 era ayogera n’eggonjebwa, talirema kuganja ewa kabaka. 
\b  
\q1  
\v 12 Amaaso ga \nd Mukama\nd* galabirira amazima, 
\q2 era adibya entegeka z’abatali beesigwa. 
\b  
\q1  
\v 13 Omugayaavu ayogera nti, “Ebweru eriyo empologoma,” 
\q2 oba nti, “Nnyinza okutemulirwa mu kkubo.” 
\b  
\q1  
\v 14 Malaaya mutego gwa kabi, 
\q2 akolimiddwa \nd Mukama\nd* mw’afiira. 
\b  
\q1  
\v 15 Obusirusiru busibiddwa ku mutima gw’omwana omuto, 
\q2 naye omuggo ogukangavvula gulimuwonyeza ddala. 
\b  
\q1  
\v 16 Omuntu atulugunya abaavu ne yeeyongera okugaggawala, 
\q2 n’oyo agabira omugagga awa abagagga enguzi, enkomerero ya bombi bwavu. 
\b  
\q1  
\v 17 Ossangayo omwoyo okuwuliriza ebigambo by’omugezi, 
\q2 n’omutima gwo eri ebyo bye njigiriza. 
\q1  
\v 18 Kibeera kya ssanyu bw’obikwata ku mutima gwo, 
\q2 n’oba mwetegefu okubiddamu byonna. 
\q1  
\v 19 Mbikumanyisa leero ggwe, 
\q2 obwesige bwo bubeerenga mu \nd Mukama\nd*. 
\q1  
\v 20 Kale sikuwandiikidde ebintu amakumi asatu ebikuwabula 
\q2 era ebikuwa okumanya? 
\q1  
\v 21 Sikulaze ekirungi n’ekituufu, 
\q2 olyoke obe n’eky’okuddamu eri oyo eyakutuma? 
\b  
\q1  
\v 22 Tonyaganga mwavu, kubanga mwavu, 
\q2 oba okutulugunyanga aleeteddwa mu mbuga. 
\q1  
\v 23 Kubanga \nd Mukama\nd* alibawolereza, 
\q2 n’abo ababanyaga alibanyaga. 
\b  
\q1  
\v 24 Tokwananga muntu wa busungu, 
\q2 oba okuyitanga n’omuntu anyiiganyiiga amangu, 
\q1  
\v 25 oleme okuyiga amakubo ge 
\q2 ne weesuula mu mitawaana. 
\b  
\q1  
\v 26 Teweegattanga ku abo abeeyama, 
\q2 newaakubadde ku abo abeeyimirira ab’amabanja. 
\q1  
\v 27 Bw’oliba nga tolina kya kusasula 
\q2 ekitanda kyo kyennyini kye kirikuggyibwako. 
\b  
\q1  
\v 28 Tojjululanga nsalo 
\q2 bajjajjaabo gye bassaawo edda. 
\b  
\q1  
\v 29 Omanyi omuntu omunyiikivu era omukugu mu mulimu gwe? 
\q2 Aliweereza bakabaka; taliweereza bantu batamanyiddwa. 
\c 23  
\q1  
\v 1 Bw’otuulanga okulya n’omufuzi, 
\q2 weetegerezanga ebiri mu maaso go; 
\q1  
\v 2 era weegendereze 
\q2 bw’obanga omanyi ng’olulunkanira ebyokulya. 
\q1  
\v 3 Tolulunkanira mmere ye ennungi, 
\q2 kubanga erimbalimba. 
\b  
\q1  
\v 4 Teweemalangako mirembe ng’oyaayaanira obugagga; 
\q2 weefuge obeere mukkakkamu. 
\q1  
\v 5 Eby’obugagga obikubako eriiso limu nga by’agenze dda, 
\q2 kubanga ddala bimera ebiwaawaatiro 
\q2 ne bibuuka mu bbanga ng’empungu. 
\b  
\q1  
\v 6 Tolyanga mmere ya muntu mukodo, 
\q2 wadde okwegomba ebirungi by’alya. 
\q1  
\v 7 Kubanga ye muntu 
\q2 abalirira ensimbi z’asaasaanyizza, 
\q2 n’akugamba nti, “Weeriire, weenywere,” 
\q2 naye ng’omutima gwe tegukusanyukira. 
\q1  
\v 8 Akatono k’onooba olidde onookasesema, 
\q2 ebigambo byo ebirungi eby’okwebaza bibe bya bwereere. 
\b  
\q1  
\v 9 Totegana kubuulirira musirusiru, 
\q2 kubanga ajja kunyooma ebigambo byo eby’amagezi. 
\b  
\q1  
\v 10 Tojjululanga nsalo ey’edda, 
\q2 so toyingiriranga nnimiro za bamulekwa, 
\q1  
\v 11 kubanga abalwanirira w’amaanyi, 
\q2 alikuggulako omusango. 
\b  
\q1  
\v 12 Ossangayo omwoyo eri okuyigirizibwa, 
\q2 n’amatu go eri ebigambo by’okutegeera. 
\b  
\q1  
\v 13 Tolekangayo kukangavvula mwana, 
\q2 bw’omubonereza n’akaggo tekimutta. 
\q1  
\v 14 Mubonerezenga n’akaggo, 
\q2 kiwonye emmeeme ye okufa. 
\b  
\q1  
\v 15 Mwana wange, bw’oba n’omutima ogw’amagezi, 
\q2 kinsanyusa. 
\q1  
\v 16 Nnaajjaguzanga okuva ku ntobo y’omutima gwange, 
\q2 bw’onooyogeranga ebituufu. 
\b  
\q1  
\v 17 Omutima gwo gulemenga okukwatirwa aboonoonyi obuggya, 
\q2 kyokka nyiikira okutya \nd Mukama\nd* ebbanga lyonna. 
\q1  
\v 18 Mazima ddala onoobanga n’essuubi mu biseera eby’omu maaso, 
\q2 n’essuubi lyo eryo teririggwaawo. 
\b  
\q1  
\v 19 Mwana wange wulirizanga, obeerenga n’amagezi, 
\q2 okumenga omutima gwo mu kkubo ettuufu. 
\q1  
\v 20 Teweegattanga ku abo abeekamirira omwenge, 
\q2 n’abalulunkanira ennyama: 
\q1  
\v 21 Kubanga omutamiivu n’omuluvu baavuwala, 
\q2 n’okubongoota olutata kubambaza enziina. 
\b  
\q1  
\v 22 Wulirizanga kitaawo eyakuzaala, 
\q2 so togayanga nnyoko ng’akaddiye. 
\q1  
\v 23 Gula amazima so togatunda, 
\q2 ffuna amagezi, n’okuyigirizibwa n’okutegeera. 
\q1  
\v 24 Kitaawe w’omutuukirivu alina essanyu lingi, 
\q2 n’oyo azaala omwana ow’amagezi amwenyumiririzaamu. 
\q1  
\v 25 Leka kitaawo ne nnyoko basanyuke, 
\q2 omukazi eyakuzaala ajaguzenga. 
\b  
\q1  
\v 26 Mwana wange mpa omutima gwo, 
\q2 n’amaaso go geekalirize amakubo gange, 
\q1  
\v 27 kubanga omukazi omwenzi lukonko luwanvu, 
\q2 n’omukazi omubambaavu luzzi lufunda. 
\q1  
\v 28 Ateega ng’omutemu, 
\q2 n’ayongera ku muwendo gw’abasajja abatali beesigwa eri bakazi baabwe. 
\b  
\q1  
\v 29 Ani alina obuyinike? Ani alina ennaku? 
\q2 Ani alina ennyombo? Ani alina okwemulugunya? 
\q2 Ani alina ebiwundu eby’obwereere? Ani amyuse amaaso? 
\q1  
\v 30 Abo abatava ku mwenge, 
\q2 nga bagenda baloza ku mwenge omutabule. 
\q1  
\v 31 Totunuulira wayini ng’amyuse, 
\q2 bw’atemaganira mu ggiraasi 
\q2 ng’akka empolampola; 
\q1  
\v 32 ku nkomerero aluma ng’omusota, 
\q2 wa busagwa ng’essalambwa. 
\q1  
\v 33 Amaaso go galiraba ebyewuunyo, 
\q2 n’omutwe gwo ne gulowooza ebitategeerekeka. 
\q1  
\v 34 Oliba ng’omuntu eyeebase wakati mu nnyanja, 
\q2 obanga oyo alengejjera waggulu ku mulongooti. 
\q1  
\v 35 Olyogera nti, “Bankubye, naye sirumiddwa. 
\q2 Bankubye naye sirina kye mpuliddemu. 
\q1 Nnaazuukuka ddi, 
\q2 neeyongere okunywa?” 
\b  
\c 24  
\q1  
\v 1 Teweegombanga bakozi ba bibi 
\q2 era tobeesemberezanga. 
\q1  
\v 2 Kubanga emitima gyabwe giteesa kukola bya butemu, 
\q2 era akamwa kaabwe koogera ku kukola bya ffujjo. 
\b  
\q1  
\v 3 Amagezi ge gazimba ennyumba, 
\q2 n’okutegeera kwe kugiggumiza. 
\q1  
\v 4 Olw’amagezi ebisenge by’ayo bijjula ebintu ebirungi, 
\q2 eby’obugagga ebitalabikalabika eby’omuwendo omungi. 
\b  
\q1  
\v 5 Omuntu ow’amagezi aba n’obuyinza, 
\q2 n’omuntu alina okumanya yeeyongera amaanyi. 
\q1  
\v 6 Kubanga okulwana olutalo weetaaga okuluŋŋamizibwa, 
\q2 n’okuluwangula, weetaaga abawi b’amagezi bangi. 
\b  
\q1  
\v 7 Amagezi gasukkirira nnyo omusirusiru, 
\q2 talina ky’asobola kwogera mu lukuŋŋaana olw’oku wankaaki. 
\b  
\q1  
\v 8 Oyo asala enkwe ez’okukola ebibi, 
\q2 aliyitibwa mukujjukujju. 
\q1  
\v 9 Entegeka ez’obusirusiru muvaamu kwonoona, 
\q2 abantu beetamwa omukudaazi. 
\b  
\q1  
\v 10 Bw’oyongobera mu kiseera eky’ebizibu, 
\q2 olwo ng’olina amaanyi matono! 
\q1  
\v 11 Odduukiriranga n’owonya abo abatwalibwa okuttibwa, 
\q2 n’abo abali ku njegoyego z’okuttibwa, obawonye okuttirwa obwemage. 
\q1  
\v 12 Bw’ogambanga nti, “Laba kino twali tetukimanyi,” 
\q2 oyo akebera emitima aba talaba? 
\q1 Oyo akuuma obulamu bwo takimanyi? 
\q2 Talisasula buli muntu ng’omulimu gwe bwe guli? 
\b  
\q1  
\v 13 Mwana wange olyanga omubisi gw’enjuki kubanga mulungi, 
\q2 omubisi oguva mu bisenge byagwo guwoomerera. 
\q1  
\v 14 Era manya nti amagezi gawoomera emmeeme yo, 
\q2 bw’onoogafuna onoobeera n’essuubi mu bulamu obw’omu maaso, 
\q2 n’essuubi lyo teririkoma. 
\b  
\q1  
\v 15 Toteeganga, ng’omunyazi bw’akola ku nnyumba y’omutuukirivu, 
\q2 tonyaganga maka ge. 
\q1  
\v 16 Omuntu omutuukirivu ne bw’agwa emirundi omusanvu, addamu n’ayimuka, 
\q2 naye abakozi b’ebibi basuulibwa mu mitawaana. 
\b  
\q1  
\v 17 Tosanyukanga ng’omulabe wo agudde, 
\q2 bwe yeesittalanga omutima gwo gulemenga okujaguza. 
\q1  
\v 18 Si kulwa nga \nd Mukama\nd* akiraba ne kitamusanyusa, 
\q2 n’amusunguwalira. 
\b  
\q1  
\v 19 Teweeraliikiriranga olw’abo abakola ebibi, 
\q2 so abakozi b’ebibi tobakwatirwanga buggya. 
\q1  
\v 20 Kubanga omuntu omubi talina ssuubi mu maaso, 
\q2 ettabaaza y’abakozi b’ebibi erizikizibwa. 
\b  
\q1  
\v 21 Mwana wange otyanga \nd Mukama\nd*, ne kabaka, 
\q2 era teweetabanga na bajeemu. 
\q1  
\v 22 Kubanga obusungu bwabwe bulibuubuukira ku bajeemu 
\q2 era ani amaanyi akabi akalibatuukako? 
\s1 Ebigambo Eby’amagezi 
\q1  
\v 23 Bino nabyo era bigambo by’abalina amagezi. 
\q2 Okwekubiira ng’osala emisango si kirungi. 
\q1  
\v 24 Kale oyo agamba azizza omusango nti, “Toliiko ky’ovunaanibwa,” 
\q2 abantu banaamukolimiranga, n’amawanga ganaamwetamwanga. 
\q1  
\v 25 Naye abo abasalira omusobya omusango ne gumusinga banaabanga n’essanyu, 
\q2 n’omukisa omulungi gulibatuukako. 
\b  
\q1  
\v 26 Eky’okuddamu eky’amazima, 
\q2 kiri ng’okunywegerwa. 
\b  
\q1  
\v 27 Malirizanga omulimu gwo ogw’ebweru, 
\q2 oteeketeeke ennimiro zo, 
\q2 n’oluvannyuma olyoke weezimbire ennyumba yo. 
\b  
\q1  
\v 28 Towanga bujulizi bwa bulimba ku muliraanwa wo, 
\q2 so akamwa ko tekalimbanga. 
\q1  
\v 29 Toyogeranga nti, “Omuntu oyo ndimukola nga bw’ankoze, 
\q2 era ndimusasuza nga bw’ampisizza.” 
\b  
\q1  
\v 30 Nayita ku nnimiro ey’omugayaavu, 
\q2 ne mpita ne ku nnimiro y’emizabbibu ey’oyo atalina kutegeera. 
\q1  
\v 31 Kale laba, ng’ennimiro eyo ebunye amaggwa, 
\q2 wansi wonna nga wabikkiddwa omuddo, 
\q2 n’olukomera lwayo olw’amayinja nga lugudde. 
\q1  
\v 32 Ne neekaliriza ne ntegeera 
\q2 ne nfuna ekyokuyiga mu bye nalaba. 
\q1  
\v 33 Otulo otutonotono, n’okusumagira akatono, 
\q2 n’okufunya emikono okuwummulako, 
\q1  
\v 34 obwavu bulikutuukako ng’omutemu, 
\q2 era n’obwetaavu ng’omutemu. 
\c 25  
\s1 Engero Endala Eza Sulemaani 
\p  
\v 1 Zino nazo ngero za Sulemaani abasajja ba Keezeekiya kabaka wa Yuda ze baakoppolola. 
\q1  
\v 2 Okukisa ensonga kitiibwa kya Katonda, 
\q2 naye okunoonyereza ensonga kitiibwa kya bakabaka. 
\b  
\q1  
\v 3 Ng’eggulu bwe lyewanise waggulu ennyo n’ensi bw’ekka ennyo wansi, 
\q2 bwe gityo n’emitima gya bakabaka bwe gitategeerekeka. 
\b  
\q1  
\v 4 Effeeza giggyeemu ebisejja, 
\q2 olyoke ofune omuweesi ky’anaakozesa. 
\q1  
\v 5 Ggyawo abakozi b’ebibi mu maaso ga kabaka, 
\q2 entebe ye ey’obwakabaka eryoke enywezebwe mu butuukirivu. 
\b  
\q1  
\v 6 Teweekuzanga mu maaso ga kabaka, 
\q2 wadde okwewa ekifo mu bantu ab’ekitiibwa. 
\q1  
\v 7 Kubanga okukugamba nti, “Jjangu wano mu maaso,” 
\q2 kisingako okukuswaza mu maaso g’ow’ekitiibwa. 
\b  
\q1  
\v 8 Amaaso go bye galabye 
\q2 tobyanguyirizanga kubireeta mu mbuga, 
\q1 kubanga oluvannyuma onookola otya 
\q2 munno bw’anaakuswaza? 
\b  
\q1  
\v 9 Bw’owozanga ne muliraanwa wo, 
\q2 tobikkulanga kyama kya muntu mulala, 
\q1  
\v 10 akiwulira aleme okukuswaza; 
\q2 n’onyoomebwa ebbanga lyonna. 
\b  
\q1  
\v 11 Ekigambo ekyogere nga bwe kisaanidde, 
\q2 kiba kya muwendo nnyo nga zaabu gwe batonye mu bintu bye bakoze mu ffeeza. 
\b  
\q1  
\v 12 Ng’empeta ey’omu kutu eya zaabu, oba akakomo aka zaabu ennungi, 
\q2 bw’atyo omuntu ow’amagezi anenya, bw’abeera eri okutu okuwuliriza. 
\b  
\q1  
\v 13 Ng’obunnyogovu bw’omuzira bwe bubeera mu biseera eby’okukunguliramu, 
\q2 bw’atyo bw’abeera omubaka omwesigwa eri abo abamutuma, 
\q2 aweweeza emmeeme ya bakama be. 
\b  
\q1  
\v 14 Ng’ebire n’empewo omutali nkuba, 
\q2 omuntu asuubiza ebirabo by’atagaba bw’abeera. 
\s1 Muliraanwa n’Omulabe 
\b  
\q1  
\v 15 Okugumiikiriza okungi kuyinza okukkirizisa omufuzi, 
\q2 n’olulimi olw’eggonjebwa lumenya eggumba. 
\b  
\q1  
\v 16 Bw’ozuula omubisi gw’enjuki, lyako ogwo gwokka ogukumala, 
\q2 si kulwa ng’ogukkuta nnyo n’ogusesema. 
\q1  
\v 17 Tokyalanga lunye ewa muliraanwa wo, 
\q2 si kulwa ng’akwetamwa n’akukyawa. 
\b  
\q1  
\v 18 Omuntu awa obujulizi obw’obulimba ku muliraanwa we, 
\q2 ali ng’embuukuuli, oba ekitala, oba akasaale akoogi. 
\b  
\q1  
\v 19 Okwesiga omuntu ateesigika, 
\q2 kiri ng’oli alina erinnyo eddwadde oba ekigere ekirema. 
\b  
\q1  
\v 20 Ng’omuntu eyeeyambula engoye mu kiseera eky’obutiti, 
\q2 era ng’omwenge omukaatuufu bwe guteekebwako oluvu, 
\q2 bw’atyo bw’abeera ayimbira oyo ali mu buyinike. 
\b  
\q1  
\v 21 Omulabe wo bw’aba alumwa enjala, muwe emmere alye, 
\q2 bw’aba alumwa ennyonta muwe amazzi anywe. 
\q1  
\v 22 Kubanga oliba otuuma amanda g’omuliro ku mutwe gwe, 
\q2 era \nd Mukama\nd* alikuwa empeera. 
\b  
\q1  
\v 23 Ng’empewo ey’obukiikakkono bwereeta enkuba, 
\q2 n’olulimi oluyomba bwe luleetera omuntu obusungu. 
\b  
\q1  
\v 24 Okusulanga mu kasonda waggulu ku nnyumba, 
\q2 kisinga okubeera n’omukazi omuyombi mu nnyumba. 
\b  
\q1  
\v 25 Ng’amazzi amannyogovu bwe gaba eri emmeeme erumwa ennyonta, 
\q2 bwe gatyo bwe gaba amawulire amalungi agava mu nsi ey’ewala. 
\b  
\q1  
\v 26 Ng’oluzzi olusiikuuse, oba ensulo eyonoonese, 
\q2 bw’atyo bw’abeera omutuukirivu eyeewaayo eri omukozi w’ebibi. 
\b  
\q1  
\v 27 Si kirungi kulya mubisi gwa njuki mungi, 
\q2 bwe kityo si kirungi omuntu okwenoonyeza ekitiibwa. 
\b  
\q1  
\v 28 Omuntu ateefuga 
\q2 ali ng’ekibuga ekimenyeemenye ne kirekebwa nga tekirina bbugwe. 
\c 26  
\s1 Omusirusiru n’Obusirusiru bwe 
\q1  
\v 1 Ng’omuzira bwe gutasaana mu biseera bya kusiga oba enkuba mu makungula, 
\q2 n’ekitiibwa bwe kitasaanira musirusiru. 
\b  
\q1  
\v 2 Ng’enkazaluggya ewabye, ng’akataayi akabuukabuuka, 
\q2 ekikolimo ekitasaanidde tekibaako kye kikola. 
\b  
\q1  
\v 3 Embooko ya mbalaasi, n’olukoba lwa ndogoyi, 
\q2 n’omuggo gusaanira migongo gya basirusirusiru. 
\b  
\q1  
\v 4 Toyanukulanga musirusiru ng’obusirusiru bwe, bwe buli, 
\q2 oleme kubeera nga ye. 
\b  
\q1  
\v 5 Omusirusiru omuddangamu ng’obusirusiru bwe, bwe buli, 
\q2 si kulwa nga yeerowooza nti mugezi. 
\b  
\q1  
\v 6 Omuntu atuma omusirusiru, 
\q2 aba ng’eyeetemyeko ebigere n’anywa obusungu. 
\b  
\q1  
\v 7 Ng’amagulu g’omulema bwe galengejja obulengezzi, 
\q2 bwe lutyo n’olugero bwe lubeera mu kamwa k’omusirusiru. 
\b  
\q1  
\v 8 Ng’atadde ejjinja mu nvuumuulo bw’aba, 
\q2 n’oyo awa omusirusiru ekitiibwa bw’atyo bw’abeera. 
\b  
\q1  
\v 9 Ng’eriggwa bwe lifumita mu mukono gw’omutamiivu, 
\q2 bwe lutyo n’olugero bwe lubeera mu kamwa k’abasirusiru. 
\b  
\q1  
\v 10 Ng’omulasi w’akasaale, amala galasa buli gw’asanze, 
\q2 bw’abeera bw’atyo apangisa omusirusiru oba omuyise yenna gw’asanze. 
\b  
\q1  
\v 11 Ng’embwa bw’eddira ebisesemye by’ayo, 
\q2 bw’atyo bw’abeera omusirusiru adda mu nsobi ze. 
\b  
\q1  
\v 12 Olaba omuntu omugezi mu maaso ge ye? 
\q2 Omusirusiru alina essuubi okumusinga. 
\b  
\q1  
\v 13 Omugayaavu agamba nti, “Mu kkubo eriyo empologoma, 
\q2 empologoma enkambwe eyita mu luguudo!” 
\b  
\q1  
\v 14 Ng’oluggi bwe lukyukira ku ppata zaalwo, 
\q2 bw’atyo omugayaavu bw’akyukira ku kitanda kye. 
\b  
\q1  
\v 15 Omugayaavu akoza n’engalo ze mu kibya, 
\q2 naye olw’obunafu bwe n’atasobola kuzizza mu kamwa. 
\b  
\q1  
\v 16 Omugayaavu alowooza nti mugezi, 
\q2 okusinga abantu omusanvu abaddamu ebibuuzo mu butuufu. 
\b  
\q1  
\v 17 Ng’asika embwa amatu, 
\q2 omuyise bw’abeera eyeeyingiza mu luyombo olutali lulwe. 
\b  
\q1  
\v 18 Ng’omulalu akasuka 
\q2 emmuli ez’omuliro oba obusaale obutta, 
\q1  
\v 19 bw’abeera omuntu alimba munne, 
\q2 n’agamba nti, “Mbadde nsaaga busaazi.” 
\b  
\q1  
\v 20 Enku bwe zibula omuliro guzikira, 
\q2 awatali lugambo ennyombo ziggwaawo. 
\b  
\q1  
\v 21 Ng’amanda ku gannaago agaliko omuliro, oba enku ku muliro, 
\q2 bw’abeera omusajja omuyombi mu kuwakula entalo. 
\b  
\q1  
\v 22 Ebigambo by’omuntu ageya biri ng’emmere ewoomerera, 
\q2 bigenda mu bitundu by’omubiri eby’ewala. 
\b  
\q1  
\v 23 Ng’ekintu eky’ebbumba ekibikkiddwako amasengere, 
\q2 bwe gibeera emimwa eminyiikivu egisibuka ku mutima omubi. 
\b  
\q1  
\v 24 Omuntu ow’enkwe alimbalimba n’emimwa gye 
\q2 naye ng’aterese obulimba mu mutima gwe. 
\q1  
\v 25 Wadde nga by’ayogera bisanyusa, tomukkiririzaamu 
\q2 kubanga eby’emizizo musanvu bijjuza mu mutima gwe. 
\q1  
\v 26 Enkwe ze ziyinza okubikkibwa mu kubuzaabuuza, 
\q2 naye obutali butuukirivu bwe buliggyibwayo mu lukuŋŋaana. 
\b  
\q1  
\v 27 Buli asima ekinnya y’alikigwamu, 
\q2 n’oyo aliyiringisa ejjinja gwe liriddira. 
\b  
\q1  
\v 28 Olulimi olulimba lukyawa abo be lufumita, 
\q2 n’akamwa akawaanawaana kaleeta okuzikirira. 
\c 27  
\s1 Amagezi aga Leero n’Ebiseera eby’omu mu Maaso 
\q1  
\v 1 Teweenyumirizanga mu bya nkya, 
\q2 kubanga olunaku bye lunaaleeta tobimanyi. 
\b  
\q1  
\v 2 Leka omulala akutenderezenga so si kamwa ko ggwe, 
\q2 omuntu omulala so si mimwa gyo. 
\b  
\q1  
\v 3 Ejjinja lizitowa, n’omusenyu muzito, 
\q2 naye obulumbaganyi bw’omusirusiru businga byonna okuzitowa. 
\b  
\q1  
\v 4 Obusungu bwa ttima, n’ekiruyi kifugira ddala nnyo, 
\q2 naye ani ayinza okwolekera amaaso g’obuggya? 
\b  
\q1  
\v 5 Okunenya mu lwatu, 
\q2 kisinga okwagala okukisibbwa. 
\b  
\q1  
\v 6 Okunywegera kw’omulabe kwandiba okungi, 
\q2 naye ebiwundu by’okunenya kw’owoomukwano tebitiisa. 
\b  
\q1  
\v 7 Oyo akkuse akyawa omubisi gw’enjuki, 
\q2 naye eri omuyala n’ekikaawa kiba kiwoomerera. 
\b  
\q1  
\v 8 Ng’akanyonyi akadduka mu kisu kyako, 
\q2 bw’atyo bw’abeera omuntu abula mu maka ge. 
\b  
\q1  
\v 9 Ebyakaloosa bisanyusa omutima, 
\q2 n’obuwoomerevu bw’omukwano gw’omuntu bwe butyo bwe buvaamu okubuulirira okw’amazima. 
\b  
\q1  
\v 10 Mukwano gwo ne mukwano gwa kitaawo tobaabuuliranga, 
\q2 olemenga okutawaana okuswala ewa muganda wo ng’ogudde mu mitawaana. 
\q2 Muliraanwa wo akira muganda wo akuli ewala. 
\b  
\q1  
\v 11 Beeranga n’amagezi mwana wange, osanyusenga omutima gwange, 
\q2 ndyoke nyanukule oyo yenna ansekerera. 
\b  
\q1  
\v 12 Omuntu omutegeevu alaba akabenje ne yeekweka, 
\q2 naye abatalina magezi batambula butambuzi ne bagwa mu kabi. 
\b  
\q1  
\v 13 Twalanga ekyambalo ky’oyo eyeeyimirira gw’atamanyi, 
\q2 era kwatanga eky’oyo eyeeyimirira omukazi omwenzi kye yeeyamye. 
\b  
\q1  
\v 14 Okulamusa ku muliraanwa wo mu makya ennyo, ng’oleekaana, 
\q2 obanga amukolimidde. 
\b  
\q1  
\v 15 Omukazi omuyombi ali ng’enkuba etonnya olutata, 
\q2 ku lunaku olw’enkuba ennyingi. 
\q1  
\v 16 Okumuziyiza obanga aziyiza empewo oba 
\q2 ng’anyweza omuzigo mu ngalo. 
\b  
\q1  
\v 17 Ng’ekyuma bwe kiwagala ekyuma, 
\q2 n’omuntu bw’abangula muntu munne. 
\b  
\q1  
\v 18 Buli alabirira omutiini alirya ku bibala byagwo, 
\q2 n’oyo aweereza mukama we alissibwamu ekitiibwa. 
\b  
\q1  
\v 19 Ng’amazzi bwe galaga omuntu bw’afaanana mu maaso, 
\q2 bwe gutyo omutima gw’omuntu bwe gulaga omuntu bw’afaanana. 
\b  
\q1  
\v 20 Amagombe ne ggeyeena tebikkuta, 
\q2 n’amaaso g’abantu nago bwe gatyo tegakkuta. 
\b  
\q1  
\v 21 Entamu erongoosa ya ffeeza n’ekikoomi kikola ku zaabu, 
\q2 naye omuntu ekimugezesa kutenderezebwa. 
\b  
\q1  
\v 22 Ne bw’osekula omusirusiru mu kinu, 
\q2 nga bw’osekula emmere y’empeke mu kinu, 
\q2 obusirusiru bwe tobumuggyaamu. 
\b  
\q1  
\v 23 Okakasanga nti omanyi bulungi embeera z’ekisibo kyo, 
\q2 ossangayo omwoyo ku ggana lyo. 
\q1  
\v 24 Kubanga eby’obugagga tebibeerera mirembe gyonna, 
\q2 n’engule tebeerera mirembe gyonna. 
\q1  
\v 25 Ng’omuddo gw’ensolo omukulu gumaze okusalibwawo, ng’omutoototo gutandise okusibukawo, 
\q2 nga n’omuddo ogw’omu busozi guleeteddwa, 
\q1  
\v 26 abaana b’endiga balikuwa engoye ez’okwambala, 
\q2 n’embuzi ziritundibwa ne zivaamu ensimbi. 
\q1  
\v 27 Olibeera n’amata mangi g’onoggyanga mu mbuzi, okukuliisa ggwe n’ab’omu nnyumba yo, 
\q2 n’okuliisa abaweereza bo abawala. 
\c 28  
\q1  
\v 1 Abakozi b’ebibi badduka nga tewali abagoba, 
\q2 naye abatuukirivu babeera n’obuvumu ng’empologoma. 
\b  
\q1  
\v 2 Eggwanga bwe lijeema, liba n’abafuzi bangi, 
\q2 naye olw’omuntu alina okutegeera n’okumanya obutebenkevu budda nate mu nsi. 
\b  
\q1  
\v 3 Omufuzi anyigiriza abaavu, 
\q2 afaanana nga enkuba etonnya ezikiriza n’eterekaawo birime. 
\b  
\q1  
\v 4 Abo abava ku mateeka ga \nd Mukama\nd* batendereza aboonoonyi, 
\q2 naye abo abagakuuma babawakanya. 
\b  
\q1  
\v 5 Abantu abakozi b’ebibi tebategeera bwenkanya, 
\q2 naye abo abanoonya \nd Mukama\nd* babutegeerera ddala bulungi. 
\b  
\q1  
\v 6 Omuntu omwavu atambulira mu butuukirivu, 
\q2 asinga omugagga ow’amakubo amakyamu. 
\b  
\q1  
\v 7 Oyo akuuma amateeka ga \nd Mukama\nd* mwana eyeegendereza, 
\q2 naye mukwano gw’ab’omululu akwasa kitaawe ensonyi. 
\b  
\q1  
\v 8 Ayongera ku bugagga bwe mu bukumpanya, 
\q2 abukuŋŋaanyiza omulala anaayinza okuba ow’ekisa eri abaavu. 
\b  
\q1  
\v 9 Atassaayo mwoyo kuwulira mateeka ga \nd Mukama\nd*, 
\q2 n’okusaba kwe tekukkirizibwa. 
\b  
\q1  
\v 10 Buli akyamya abatuukirivu mu kkubo ebbi, 
\q2 aligwa mu katego ke ye, 
\q2 naye abatuukirivu balisikira ebirungi. 
\b  
\q1  
\v 11 Omugagga alowooza nti mugezi, 
\q2 naye omwavu alina okutegeera, amunyooma. 
\b  
\q1  
\v 12 Abatuukirivu bwe bawangula wabaawo okujaguza okw’amaanyi, 
\q2 naye abakakanyalira mu kukola ebikyamu bwe bafuna obuyinza abantu beekweka. 
\b  
\q1  
\v 13 Oyo akweka ebibi bye, talifuna mukisa kukulaakulana, 
\q2 naye buli abyatula n’abireka, alisaasirwa. 
\b  
\q1  
\v 14 Alina omukisa omuntu atya \nd Mukama\nd* ebbanga lyonna, 
\q2 naye oyo akakanyaza omutima gwe abonaabona. 
\b  
\q1  
\v 15 Ng’empologoma ewuluguma oba eddubu eritiisatiisa, 
\q2 bw’abeera omufuzi omubi atulugunya abateesobola. 
\b  
\q1  
\v 16 Omufuzi nantagambwako tafuga na bwenkanya, 
\q2 naye oyo akyawa amagoba agafuniddwa mu bukyamu alibeera n’essanyu ery’obulamu obuwangaazi. 
\b  
\q1  
\v 17 Omuntu alumirizibwa olw’okutta munne, 
\q2 alibeera mu kutegana okutuusa okufa, 
\q2 tewabanga n’omu amuyamba. 
\b  
\q1  
\v 18 Omuntu atambulira mu bugolokofu alinunulibwa talibeerako kabi, 
\q2 naye oyo ow’amakubo amabi aligwa mbagirawo. 
\b  
\q1  
\v 19 Omuntu alima ennimiro ye aliba n’emmere nnyingi, 
\q2 naye oyo ali mu birowoozo ebitaliimu alifa bwavu. 
\b  
\q1  
\v 20 Omusajja omwesigwa aliweebwa emikisa mingi, 
\q2 naye oyo ayanguyiriza okugaggawala talirema kubonerezebwa. 
\b  
\q1  
\v 21 Okuttira abantu ku liiso ng’osala emisango si kirungi, 
\q2 naye ate olw’okunoonya akookulya omuntu ayinza okuzza omusango. 
\b  
\q1  
\v 22 Omusajja omukodo yeegomba okugaggawala, 
\q2 naye nga tamanyi nti obwavu bumulindiridde. 
\b  
\q1  
\v 23 Oyo anenya omuntu, oluvannyuma aliganja, 
\q2 okusinga oyo awaaniriza n’olulimi. 
\b  
\q1  
\v 24 Buli anyaga kitaawe, oba nnyina, 
\q2 n’agamba nti, “Si nsonga,” afaanana n’oyo azikiriza. 
\b  
\q1  
\v 25 Omuntu ow’omululu aleeta oluyombo, 
\q2 naye oyo eyeesiga \nd Mukama\nd* aligaggawazibwa. 
\b  
\q1  
\v 26 Eyeesiga omutima gwe, musirusiru, 
\q2 naye oyo atambulira mu magezi alifuna emirembe. 
\b  
\q1  
\v 27 Agabira abaavu talibaako ne kye yeetaaga, 
\q2 naye abakodowalira anaabanga n’ebikolimo bingi. 
\b  
\q1  
\v 28 Abakozi b’ebibi bwe babeera mu buyinza, abantu beekweka, 
\q2 naye abakozi b’ebibi bwe bazikirira, abatuukirivu bakulaakulana. 
\c 29  
\s1 Obukulembeze bw’Abatuukirivu 
\q1  
\v 1 Omuntu akakanyaza omutima gwe oluvannyuma lw’okunenyezebwa emirundi emingi, 
\q2 alizikirira ng’atamanyiridde awatali kuwona. 
\b  
\q1  
\v 2 Abatuukirivu bwe bakulaakulana, abantu basanyuka, 
\q2 naye abakakanyalira mu kukola ebikyamu bwe bafuga abantu babeera mu kusinda. 
\b  
\q1  
\v 3 Ayagala amagezi asanyusa kitaawe, 
\q2 naye munne w’abamalaaya ayiwaayiwa obugagga bwe. 
\b  
\q1  
\v 4 Kabaka afuga n’obwenkanya, abantu be baba mu butebenkevu, 
\q2 naye oyo alulunkanira enguzi, ensi agyonoona. 
\b  
\q1  
\v 5 Omuntu awaanawaana munne, 
\q2 aba yeetega yekka ekitimba. 
\b  
\q1  
\v 6 Ebibi by’omwonoonyi bye bimutega, 
\q2 naye omutuukirivu abeera mu kuyimba na kusanyuka. 
\b  
\q1  
\v 7 Omutuukirivu afaayo ku nsonga z’abaavu, 
\q2 naye abakozi b’ebibi tebakola bwe batyo. 
\b  
\q1  
\v 8 Abakudaazi basasamaza ekibuga, 
\q2 naye abantu abalina amagezi baziyiza entalo. 
\b  
\q1  
\v 9 Omuntu ow’amagezi bw’awoza n’omusirusiru, 
\q2 omusirusiru ayongera kusunguwala, n’okujerega ne wataba mirembe. 
\b  
\q1  
\v 10 Abeegomba okuyiwa omusaayi bakyawa omuntu ow’amazima, 
\q2 era banoonya okusaanyaawo obulamu bwe. 
\b  
\q1  
\v 11 Omusirusiru alaga obusungu bwe bwonna, 
\q2 naye omuntu ow’amagezi abuziyiza n’abukkakkanya. 
\b  
\q1  
\v 12 Omufuzi bw’awuliriza eby’obulimba, 
\q2 abakungu be bonna bafuuka babi. 
\b  
\q1  
\v 13 Omwavu n’oyo amubonyaabonya balina ekibagatta: 
\q2 \nd Mukama\nd* bombi ye yabawa amaaso. 
\b  
\q1  
\v 14 Kabaka bw’asalira abaavu emisango n’obwesigwa, 
\q2 obufuzi bwe bubeerera emirembe gyonna. 
\b  
\q1  
\v 15 Akaggo akakangavvula, kaleeta amagezi, 
\q2 naye omwana alekeddwa awo, aswaza nnyina. 
\b  
\q1  
\v 16 Abakozi b’ebibi bwe beeyongera obungi, okumenya amateeka kweyongera, 
\q2 naye abatuukirivu baliraba okugwa kwabwe. 
\b  
\q1  
\v 17 Kangavvula omwana wo, alikuwa emirembe, 
\q2 alireetera emmeeme yo essanyu. 
\b  
\q1  
\v 18 Awatali kwolesebwa abantu tebaba beegendereza, 
\q2 naye wa mukisa oyo akuuma amateeka ga \nd Mukama\nd*. 
\b  
\q1  
\v 19 Omuweereza tayinza kubuulirirwa na bigambo byokka; 
\q2 ne bw’aba ategedde tafaayo. 
\b  
\q1  
\v 20 Olaba omuntu ayanguyiriza ebigambo bye? 
\q2 Omusirusiru alina essuubi okumusinga. 
\b  
\q1  
\v 21 Atiitiibya omuweereza we ekiyitiridde ng’akyali mwana muto, 
\q2 oluvannyuma omuweereza aleetera mukama we obuyinike. 
\b  
\q1  
\v 22 Omuntu ow’obusungu aleeta ennyombo, 
\q2 n’omuntu asunguwala amangu ayonoona nnyo. 
\b  
\q1  
\v 23 Amalala g’omuntu galimuleetera okugwa, 
\q2 naye omuntu ow’omwoyo ogwetoowaza alifuna ekitiibwa. 
\b  
\q1  
\v 24 Buli assa ekimu n’omubbi akyawa obulamu bwe ye, 
\q2 era ne bw’alayizibwa tasaanira kubaako ky’ayogera. 
\b  
\q1  
\v 25 Okutya omuntu kuleeta ekyambika, 
\q2 naye buli eyeesiga \nd Mukama\nd* anaabanga mirembe. 
\b  
\q1  
\v 26 Bangi abanoonya okuganja mu maaso g’omufuzi, 
\q2 naye obwenkanya obwa nnama ddala buva eri \nd Mukama\nd*. 
\b  
\q1  
\v 27 Atali mutuukirivu wa muzizo eri abatuukirivu; 
\q2 era omwesimbu wa muzizo eri abakozi b’ebibi. 
\c 30  
\s1 Ebigambo ba Aguli 
\p  
\v 1 Bino bye bigambo bya Aguli mutabani wa Yake; obubaka bwe yawa bwe buno: 
\q1 Bw’ati omusajja ono bwe yagamba Isiyeri, Isyeri ono ne Ukali. 
\q1  
\v 2 Ddala Ayi Katonda wange nze nsinga obutategeera, 
\q2 sirina kutegeera kwa bantu. 
\q1  
\v 3 Siyize magezi, 
\q2 so n’oyo Omutukuvu simumanyi. 
\q1  
\v 4 Ani eyali alinnye mu ggulu n’akka? 
\q2 Ani eyali akuŋŋaanyiza empewo mu kibatu ky’engalo ze? 
\q1 Ani eyali asibye amazzi mu kyambalo kye? 
\q2 Ani eyatonda enkomerero zonna ez’ensi? 
\q1 Erinnya lye y’ani, ne mutabani we y’ani? 
\q2 Mbulira obanga obimanyi. 
\b  
\q1  
\v 5 Buli kigambo kya Katonda kya mazima, 
\q2 era aba ngabo eri abo abamwesiga. 
\q1  
\v 6 Toyongeranga ku bigambo bye, 
\q2 alemenga okukunenya naawe olabike ng’omulimba. 
\b  
\q1  
\v 7 Ebintu bibiri bye nkusaba; Ayi \nd Mukama\nd*, 
\q2 tobinnyimanga nga sinnafa: 
\q1  
\v 8 Ebigambo eby’obutaliimu n’eby’obulimba binteeke wala, 
\q2 ate era tonjavuwazanga wadde okungaggawaza, 
\q2 naye ndiisanga emmere eya buli lunaku. 
\q1  
\v 9 Nneme okukkutanga ne nkwegaana 
\q2 ne njogera nti, “\nd Mukama\nd* ye y’ani?” 
\q1 Era nnemenga okuba omwavu ne nziba, 
\q2 ne nvumisa erinnya lya Katonda wange. 
\b  
\q1  
\v 10 Tosekeetereranga muweereza eri mukama we, 
\q2 alemenga okukukolimira, naawe omusango ne gukusinga. 
\b  
\q1  
\v 11 Waliwo abo abakolimira bakitaabwe 
\q2 ne batasabira na bannyaabwe mukisa; 
\q1  
\v 12 abo abeeraba ng’abatuukirivu bo mu maaso gaabwe, 
\q2 ate nga tebanaazibwangako bibi byabwe. 
\q1  
\v 13 Waliwo abo ab’amalala amayitirivu, 
\q2 abatunuza okwemanya okw’ekitalo, 
\q1  
\v 14 n’ebeerayo abo abalina amannyo agali ng’ebitala, 
\q2 n’emba zaabwe nga zirimu ebiso, 
\q1 okusaanyaawo abaavu mu nsi, 
\q2 n’abo abali mu kwetaaga. 
\b  
\q1  
\v 15 Ekinoso kirina bawala baakyo babiri 
\q2 abaleekaana nti, “Mpa! mpa!” 
\b  
\li1 Waliwo ebintu bisatu ebitakkuta, 
\li2 weewaawo bina ebitagamba nti, “Matidde,” 
\li3  
\v 16 Amagombe, 
\li3 olubuto olugumba, 
\li3 ettaka eritakutta mazzi, 
\li3 n’omuliro ogutayogera nti, “Ebyo binaamala!” 
\b  
\q1  
\v 17 Eriiso ly’oyo anyooma kitaawe, 
\q2 era n’atagondera nnyina, 
\q1 liriggibwamu bannamuŋŋoona ab’omu kiwonvu, 
\q2 ne liriibwa ensega. 
\b  
\li1  
\v 18 Waliwo ebigambo bisatu eby’ekitalo ennyo gye ndi, 
\li2 weewaawo bina bye sitegeera: 
\li3  
\v 19 Empungu engeri gye yeeyisaamu mu bbanga, 
\li3 n’omusota engeri gye gwewalulamu wakati mu mayinja, 
\li3 n’ekyombo gye kiseeyeeyamu ku nnyanja, 
\li3 n’engeri omusajja gye yeeyisaamu ng’ali n’embeerera. 
\b  
\q1  
\v 20 Bw’ati bwe yeeyisa omukazi omwenzi: 
\q2 alya n’asiimuula emimwa gye 
\q2 n’agamba nti, “Sirina kibi kye nkoze.” 
\b  
\li1  
\v 21 Ensi ekankanira wansi w’ebintu bisatu 
\li2 weewaawo bina: 
\li3  
\v 22 omuweereza bw’afuuka kabaka, 
\li3 n’omusirusiru bw’akutta emmere; 
\li3  
\v 23 n’omukazi eyadibira mu ddya; 
\li3 n’omuweereza omuwala bw’afumbirwa bba wa mugole we. 
\b  
\li1  
\v 24 Waliwo ebintu ebitono bina ku nsi, 
\li2 ebirina amagezi amangi ennyo. 
\li2  
\v 25 Enkolooto bye biwuka ebitalina maanyi mangi, 
\li3 naye byeterekera emmere yaabyo mu kyeya; 
\li2  
\v 26 obumyu busolo bunafu 
\li3 naye bwezimbira ennyumba zaabwo mu mayinja; 
\li2  
\v 27 enzige tezirina kabaka, 
\li3 kyokka zitabaala zonna mu bibiina byazo; 
\li2  
\v 28 omunya oyinza okugukwasa engalo, 
\li3 naye mu mbiri za bakabaka gusangibwamu. 
\b  
\li1  
\v 29 Waliwo ebintu bisatu ebyesimba obulungi mu kitiibwa nga bitambula, 
\li2 weewaawo bina ebitambulira mu kitiibwa: 
\li3  
\v 30 empologoma esinga ensolo zonna amaanyi era kabaka waazo, so tewali gy’esegulira yonna; 
\li3  
\v 31 sseggwanga, 
\li3 n’embuzi ennume, 
\li3 ne kabaka eyeetooloddwa eggye lye. 
\b  
\q1  
\v 32 Bw’oba ng’obadde okoze eby’obusirusiru ne weegulumiza, 
\q2 obanga obadde oteekateeka okukola ebibi, 
\q2 weekomeko weekwate ku mumwa. 
\q1  
\v 33 Kubanga okusunda amata kuzaala omuzigo, 
\q2 n’okunyiga ennyindo kuleeta omusaayi, 
\q2 okutankuula obusungu, bwe kutyo kuleeta entalo. 
\c 31  
\s1 Okulabula ku Kunywa Ekitamiiza 
\p  
\v 1 Ebigambo bya kabaka Lemweri bye yayogera, nnyina bye yamuyigiriza. 
\q1  
\v 2 Ggwe mutabani wange, ggwe mutabani w’enda yange, 
\q2 ggwe mutabani w’obweyamo bwange. 
\q1  
\v 3 Tomaliranga maanyi go ku bakazi,\f + \fr 31:3 \ft Abakazi aboogerwako wano be baweereza abakazi abangi ababeera mu lubiri; batabulatabula kabaka ng’akola emirimu gye\f* 
\q2 newaakubadde amaanyi go ku abo abazikiriza bakabaka. 
\b  
\q1  
\v 4 Ggwe Lemweri, si kya bakabaka, 
\q2 si kya bakabaka okunywanga omwenge, 
\q2 so si kya balangira okwegombanga omwenge, 
\q1  
\v 5 si kulwa nga bagunywa ne beerabira amateeka, 
\q2 ne batalamula mu bwenkanya abantu baabwe abatulugunyizibwa. 
\q1  
\v 6 Ekitamiiza mukiwenga oyo ayagala okufa, 
\q2 n’omwenge oyo alina emmeeme eriko obuyinike. 
\q1  
\v 7 Mumuleke anywenga yeerabire obwavu bwe, 
\q2 alemenga kujjukira nate buyinike bwe. 
\b  
\q1  
\v 8 Yogereranga abo abatasobola kweyogerera, 
\q2 otunulenga mu nsonga z’abo bonna abaasigala ettayo. 
\q1  
\v 9 Yogera olamulenga n’obwenkanya, 
\q2 olwanirirenga abaavu n’abali mu bwetaavu. 
\s1 Omukazi ow’Amagezi 
\q1  
\v 10 Omukazi omwegendereza ani ayinza okumulaba? 
\q2 Wa muwendo nnyo okusinga amayinja ag’omuwendo ennyo. 
\q1  
\v 11 Bba amwesiga n’omutima gwe gwonna, 
\q2 era bba talina kyonna kya muwendo ky’abulwa. 
\q1  
\v 12 Aleetera bba essanyu so tamukola kabi, 
\q2 obulamu bwe bwonna. 
\q1  
\v 13 Anoonya ebyoya by’endiga n’anoonya ne ppamba, 
\q2 n’akola emirimu gye mu ssanyu eritayogerekeka. 
\q1  
\v 14 Ali ng’ebyombo by’abasuubuzi, 
\q2 aleeta emmere okuva mu nsi ezeewala. 
\q1  
\v 15 Agolokoka tebunnakya, 
\q2 n’awa ab’omu nnyumba ye ebyokulya, 
\q2 n’agabira abaweereza be abawala be abaweereza emirimu egy’okukola. 
\q1  
\v 16 Alowooza ku nnimiro n’agigula; 
\q2 asimba ennimiro ey’emizabbibu n’ebibala by’emikono gye. 
\q1  
\v 17 Omukazi oyo akola n’amaanyi omulimu gwe, 
\q2 emikono gye gikwata n’amaanyi emirimu gye. 
\q1  
\v 18 Ayiiya ebyamaguzi ebirimu amagoba n’abisuubula, 
\q2 era n’ettabaaza ye ekiro tezikira. 
\q1  
\v 19 Anyweza omuti oguluka ppamba mu mukono gwe, 
\q2 engalo ze ne zikwata akati akalanga. 
\q1  
\v 20 Ayanjululiza abaavu omukono gwe, 
\q2 n’agololera omukono gwe oyo ali mu bwetaavu. 
\q1  
\v 21 Mu biseera by’obutiti taba na kutya, 
\q2 kubanga ab’omu nnyumba ye bonna baba n’engoye ez’okwambala. 
\q1  
\v 22 Yeekolera ebibikka obuliri bwe, 
\q2 era engoye ze za linena omulungi, za ffulungu.\f + \fr 31:22 \ft Engoye za ffulungu zaali za bbeeyi era nga kabonero ka kikungu\f* 
\q1  
\v 23 Bba amanyibbwa, 
\q2 y’omu ku bakulu abakulembera ensi, era ateeseza mu nkiiko enkulu. 
\q1  
\v 24 Omukazi atunga ebyambalo ebya linena n’abitunda, 
\q2 n’aguza abasuubuzi enkoba. 
\q1  
\v 25 Amaanyi n’ekitiibwa bye byambalo bye, 
\q2 era tatya ebiro ebigenda okujja. 
\q1  
\v 26 Ayogera n’amagezi, 
\q2 era ayigiriza ebyekisa. 
\q1  
\v 27 Alabirira nnyo empisa z’ab’omu nnyumba ye, 
\q2 era talya mmere ya bugayaavu. 
\q1  
\v 28 Abaana be bagolokoka ne bamuyita wa mukisa, 
\q2 ne bba n’amutendereza ng’ayogera nti, 
\q1  
\v 29 “Abakazi bangi abakola eby’ekitiibwa 
\q2 naye bonna ggwe obasinga.” 
\q1  
\v 30 Obubalagavu bulimba n’endabika ennungi teriiko kyegasa, 
\q2 naye omukazi atya \nd Mukama\nd* anaatenderezebwanga. 
\q1  
\v 31 Mumusasule empeera gy’akoleredde, 
\q2 n’emirimu gye gimuweesenga ettendo ku miryango gy’ekibuga.