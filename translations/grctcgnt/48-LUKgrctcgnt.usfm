\c 22  
\s1 The Plot to Kill Jesus  
\m
\v 1 Ἤγγιζε \w δὲ|strong="G1161"\w* \w ἡ|strong="G3588"\w* \w ἑορτὴ|strong="G1859"\w* \w τῶν|strong="G3588"\w* \w ἀζύμων|strong="G0106"\w*, \w ἡ|strong="G3588"\w* \w λεγομένη|strong="G3004"\w* \w Πάσχα|strong="G3957"\w*.  
\v 2 \w καὶ|strong="G2532"\w* \w ἐζήτουν|strong="G2212"\w* \w οἱ|strong="G3588"\w* \w ἀρχιερεῖς|strong="G0749"\w* \w καὶ|strong="G2532"\w* \w οἱ|strong="G3588"\w* \w γραμματεῖς|strong="G1122"\w* \w τὸ|strong="G3588"\w* \w πῶς|strong="G4459"\w* \w ἀνέλωσιν|strong="G0337"\w* \w αὐτόν|strong="G0846"\w*· \w ἐφοβοῦντο|strong="G5399"\w* \w γὰρ|strong="G1063"\w* \w τὸν|strong="G3588"\w* \w λαόν|strong="G2992"\w*.   
\p
