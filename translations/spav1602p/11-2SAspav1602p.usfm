\v 2 \w Y|strong="H3068"\w* \w al|strong="H5921"\w* tercer \w día|strong="H3117"\w* \w acaeció|strong="H1961"\w*, \w que|strong="H4480"\w* \w vino|strong="H1961"\w* uno \w del|strong="H4480"\w* \w campo|strong="H4264"\w* \w de|strong="H4480"\w* \w Saúl|strong="H7586"\w*, rotas sus vestiduras, \w y|strong="H5921"\w* tierra \w sobre|strong="H5921"\w* su \w cabeza|strong="H7218"\w*: \w y|strong="H5921"\w* llegando \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w postróse|strong="H5307"\w* \w en|strong="H5921"\w* tierra, \w e|strong="H3068"\w* \w hizo|strong="H5307"\w* reveren­cia.   
\m
\v 3 \w Y|strong="H3068"\w* preguntóle \w David|strong="H1732"\w*: ¿De dónde vienes? \w Y|strong="H3068"\w* \w él|strong="H4264"\w* respondió: Heme escapado del \w campo|strong="H4264"\w* de \w Israel|strong="H3478"\w*.   
\m
\v 4 \w Y|strong="H3068"\w* \w David|strong="H1732"\w* le \w dijo|strong="H5046"\w*: ¿\w Qué|strong="H4100"\w* ha acon­tecido? \w ruégote|strong="H4994"\w* \w que|strong="H4100"\w* \w me|strong="H4480"\w* \w lo|strong="H1697"\w* digas. \w Y|strong="H3068"\w* \w él|strong="H5307"\w* respondió: \w El|strong="H5307"\w* \w pueblo|strong="H5971"\w* \w huyó|strong="H5127"\w* \w de|strong="H4480"\w* \w la|strong="H1571"\w* \w batalla|strong="H4421"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w muchos|strong="H7235"\w* \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w cayeron|strong="H5307"\w* \w y|strong="H1571"\w* \w son|strong="H1961"\w* muer­tos: \w también|strong="H1571"\w* \w Saúl|strong="H7586"\w* \w y|strong="H1571"\w* Jonatán su \w hijo|strong="H1121"\w* \w murieron|strong="H4191"\w*.   
