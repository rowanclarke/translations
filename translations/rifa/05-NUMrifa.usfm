\id NUM
\h ذِي ڒخْڒَا 
\toc1 ذِي ڒخْڒَا 
\toc2 ذِي ڒخْڒَا 
\toc3 ڒخْڒ. 
\mt1 ذِي ڒخْڒَا  
\c 1
\s1 لْعَاذَاذْ ن ڒْعسْكَارْ ن إِسْرَائِيل  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذِي ڒخْڒَا ن سِينَا، ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، ذڭْ \add وَاسّْ\add* أَمزْوَارُو ن ؤُيُورْ وِيسّْ ثْنَاينْ، ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ أَوَارْنِي ڒَامِي د-فّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، إِنَّا:   
\m
\v 2 ”كْسِيمْ ڒْقدّْ ن إِسْمَاونْ ن مَارَّا إِرْيَازنْ ن مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل، أَزدْجِيفْ أَزدْجِيفْ، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ. \x ◘ \xo 1:‏2 \xt ؤُف. 30‏:‏12\x*  
\v 3 إِتّْخصَّا شكْ ذ هَارُونْ أَذْ ثْحسْبمْ كُوڒْ إِجّْ ذِي إِسْرَائِيل زِي عِيشْرِينْ ن إِسڭّْوُوسَا سنّجْ، \add مَارَّا\add* إِنِّي د-إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ، عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ.  
\v 4 أَذْ أَومْ إِوْشْ أَفُوسْ إِجّْ ن ورْيَازْ زِي \add كُوڒْ\add* ثَاقْبِيتْشْ، أَرْيَازْ إِ إِدْجَانْ ذ أَزدْجِيفْ ن ثَادَّارْثْ ن بَابَاسْ.  
\v 5 أَقَا ذ إِنَا ذ إِسْمَاونْ ن يرْيَازنْ نِّي ذ أَومْ غَا إِوْشنْ أَفُوسْ:  
\m إِ رُوبِينْ، إِلِيصُورْ مِّيسْ ن شَاذَايُورْ،   
\m
\v 6 إِ شِيمْعُونْ، شَالُومِييِيلْ، مِّيسْ ن صُورِييْشَادَّايْ،   
\m
\v 7 إِ يَاهُوذَا، نَاحْشُونْ، مِّيسْ ن عَامِّينَاذَابْ،   
\m
\v 8 إِ إِسَّاكَارْ، نَاثَانَايِيلْ، مِّيسْ ن صُوغَارْ.   
\m
\v 9 إِ زابُولُونْ، إِلِييَابْ، مِّيسْ ن حِيلُونْ،   
\m
\v 10 إِ أَيْثْ ن يُوسُوفْ:  
\m إِ إِفْرَايِيمْ، إِلِيشَامَاعْ، مِّيسْ ن أَمِّيهُوذْ،  
\m إِ مَانَاسَّا، جَامْلِييِيلْ، مِّيسْ ن فَاذَاهْصُورْ،   
\m
\v 11 إِ بِينْيَامِينْ، أَبِيذَانْ مِّيسْ ن جِيذْعُونِي،   
\m
\v 12 إِ ذَانْ، أَخِيعَازَارْ، مِّيسْ ن عَامِّيشَادَّايْ،   
\m
\v 13 إِ أَشِيرْ، فَاجْعِييِيلْ، مِّيسْ ن عُوكْرَانْ،   
\m
\v 14 إِ جَاذْ، إِلِييَاسَافْ، مِّيسْ ن ذَاعُويِيلْ،   
\m
\v 15 إِ نَافْثَالِي، أَخِيرَاعْ، مِّيسْ ن عِينَانْ.“   
\m
\v 16 إِنَا ثُوغَا ذ إِنِّي إِتّْوَاڒَاغَانْ زِي ثْمسْمُونْثْ، \add نِيثْنِي\add* ذ ڒْحُوكَّامْ ن ثْقبَّاڒْ ن إِبَابَاثنْ نْسنْ، إِزدْجِيفنْ خْ ڒُوڒُوفْ ن إِسْرَائِيل.  
\v 17 كْسِينْ مُوسَا ذ هَارُونْ إِرْيَازنْ نِّي ثُوغَا إِتّْوَارشْمنْ س إِسْمَاونْ نْسنْ  
\v 18 ؤُشَا سّْمُوننْ ثَامسْمُونْثْ مَارَّا ذڭْ وَاسّْ أَمزْوَارُو ن ؤُيُورْ وِيسّْ ثْنَاينْ ؤُشَا نِيثْنِي خبَّارنْ جّْذِيرَا نْسنْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، أَمْ تّْوَازمّمنْ إِسْمَاونْ ن يِينِّي غَارْ إِدْجَا عِيشْرِينْ ن إِسڭّْوُوسَا سنّجْ، أَزدْجِيفْ أَزدْجِيفْ.   
\b  
\m
\v 19 أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي إِ مُوسَا، أَقَا إِحْسبْ إِ-ثنْ ذِي ڒخْڒَا ن سِينَا.   
\b  
\m
\v 20 \bd أَيْثْ ن رُوبِينْ\bd*، أَمنْزُو ن إِسْرَائِيل: ثَارْوَا نْسنْ - \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ - إِنِّي زَّايسْ إِتّْوَاحسْبنْ عْلَاحْسَابْ إِسْمَاونْ \add نْسنْ\add* أَزدْجِيفْ أَزدْجِيفْ، كُوڒْ أَرْيَازْ زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ، مَارَّا ونِّي إِ غَا إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ،  
\v 21 \add وَاهْ،\add* إِنِّي إِتّْوَاحسْبنْ \add أَمُّو\add* إِ ثقْبِيتْشْ ن رُوبِينْ، ثُوغَا أَثنْ ذِي ستَّا ؤُ-ربْعِينْ-أَڒفْ ؤُ-خمْسَا مْيَا.   
\m
\v 22 \bd أَيْثْ ن شِيمْعُونْ:\bd* ثَارْوَا نْسنْ - \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ - إِنِّي زَّايسْ إِتّْوَاحسْبنْ عْلَاحْسَابْ لْعَاذَاذْ ن إِسْمَاونْ \add نْسنْ\add*، أَزدْجِيفْ أَزدْجِيفْ، كُوڒْ أَرْيَازْ زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ، مَارَّا ونِّي إِ غَا إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ،  
\v 23 \add وَاهْ،\add* إِنِّي إِتّْوَاحسْبنْ \add أَمُّو\add* إِ ثقْبِيتْشْ ن شِيمْعُونْ ثُوغَا أَثنْ ذِي ثسْعَا ؤُ-خمْسِينْ-أَڒفْ ؤُ-ثڒْثْ-مْيَا.   
\m
\v 24 \bd أَيْثْ ن جَاذْ:\bd* ثَارْوَا نْسنْ - \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ - إِنِّي زَّايسْ إِتّْوَاحسْبنْ عْلَاحْسَابْ إِسْمَاونْ ن \add مَارَّا إِرْيَازنْ\add* زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ، مَارَّا ونِّي إِ غَا إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ،  
\v 25 \add وَاهْ،\add* إِنِّي إِتّْوَاحسْبنْ \add أَمُّو\add* إِ ثقْبِيتْشْ ن جَاذْ ثُوغَا أَثنْ ذِي خمْسَا ؤُ-ربْعِينْ-أَڒفْ ؤُ-ستَّا-مْيَا ؤُ-خمْسِينْ.   
\m
\v 26 \bd أَيْثْ ن يَاهُوذَا:\bd* ثَارْوَا نْسنْ - \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ - إِنِّي زَّايسْ إِتّْوَاحسْبنْ عْلَاحْسَابْ إِسْمَاونْ ن \add مَارَّا إِرْيَازنْ\add* زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ، كُوڒْ إِجّنْ إِ د-إِتّفّْغنْ أَكْ-ذ ڒْعسْكَارْ،  
\v 27 \add وَاهْ،\add* إِنِّي إِتّْوَاحسْبنْ \add أَمُّو\add* إِ ثقْبِيتْشْ ن يَاهُوذَا ثُوغَا أَثنْ ذِي أَربْعَا ؤُ-سبْعِينْ-أَڒفْ ؤُ-ستَّا-مْيَا.   
\m
\v 28 \bd أَيْثْ ن إِسَّاكَارْ:\bd* ثَارْوَا نْسنْ - \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ - إِنِّي زَّايسْ إِتّْوَاحسْبنْ عْلَاحْصَابْ إِسْمَاونْ ن \add مَارَّا إِرْيَازنْ\add* زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ، مَارَّا ونِّي إِ غَا إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ،  
\v 29 \add وَاهْ،\add* إِنِّي إِتّْوَاحسْبنْ \add أَمُّو\add* إِ ثقْبِيتْشْ ن إِسَّاكَارْ ثُوغَا أَثنْ ذِي أَربْعَا ؤُ-خمْسِينْ-أَڒفْ ؤُ-أَربْعَا-مْيَا.   
\m
\v 30 \bd أَيْثْ ن زابُولُونْ:\bd* ثَارْوَا نْسنْ - \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ - إِنِّي زَّايسْ إِتّْوَاحسْبنْ عْلَاحْسَابْ إِسْمَاونْ ن \add مَارَّا إِرْيَازنْ\add* زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ، مَارَّا ونِّي إِ غَا إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ،  
\v 31 \add وَاهْ،\add* إِنِّي إِتّْوَاحسْبنْ \add أَمُّو\add* إِ ثقْبِيتْشْ ن زابُولُونْ ثُوغَا أَثنْ ذِي سبْعَا ؤُ-خمْسِينْ-أَڒفْ ؤُ-أَربْعَا-مْيَا.   
\m
\v 32 \bd أَيْثْ ن يُوسُوفْ:\bd*  
\m \bd أَيْثْ ن إِفْرَايِيمْ:\bd* ثَارْوَا نْسنْ - \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، إِنِّي زَّايسْ إِتّْوَاحسْبنْ عْلَاحْسَابْ إِسْمَاونْ ن \add مَارَّا إِرْيَازنْ\add* زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ، مَارَّا ونِّي إِ غَا إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ،  
\v 33 \add وَاهْ،\add* إِنِّي إِتّْوَاحسْبنْ \add أَمُّو\add* إِ ثقْبِيتْشْ ن إِفْرَايِيمْ ثُوغَا أَثنْ ذِي أَربْعِينْ-أَڒفْ ؤُ-خمْسَا-مْيَا.   
\m
\v 34 \bd أَيْثْ ن مَانَاسَّا:\bd* ثَارْوَا نْسنْ - \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، إِنِّي زَّايسْ إِتّْوَاحسْبنْ عْلَاحْسَابْ إِسْمَاونْ ن \add مَارَّا إِرْيَازنْ\add* زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ، مَارَّا ونِّي إِ غَا إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ،  
\v 35 \add وَاهْ،\add* إِنِّي إِتّْوَاحسْبنْ \add أَمُّو\add* إِ ثقْبِيتْشْ ن مَانَاسَّا ثُوغَا أَثنْ ذِي ثْنَاينْ ؤُ-ثْڒَاثِينْ-أَڒفْ ؤُ-مِيثَاينْ.   
\m
\v 36 \bd أَيْثْ ن بِينْيَامِينْ:\bd* ثَارْوَا نْسنْ - \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، إِنِّي زَّايسْ إِتّْوَاحسْبنْ عْلَاحْسَابْ إِسْمَاونْ ن \add مَارَّا إِرْيَازنْ\add* زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ، مَارَّا ونِّي إِ غَا إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ،  
\v 37 \add وَاهْ،\add* إِنِّي إِتّْوَاحسْبنْ \add أَمُّو\add* إِ ثقْبِيتْشْ ن بِينْيَامِينْ ثُوغَا أَثنْ ذِي خمْسَا ؤُ-ثْڒَاثِينْ-أَڒفْ ؤُ-أَربْعَا-مْيَا.   
\m
\v 38 \bd أَيْثْ ن ذَانْ:\bd* ثَارْوَا نْسنْ - \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، إِنِّي زَّايسْ إِتّْوَاحسْبنْ عْلَاحْسَابْ إِسْمَاونْ ن \add مَارَّا إِرْيَازنْ\add* زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ، مَارَّا ونِّي إِ غَا إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ،  
\v 39 \add وَاهْ،\add* إِنِّي إِتّْوَاحسْبنْ \add أَمُّو\add* إِ ثقْبِيتْشْ ن ذَانْ ثُوغَا ثنْ ذِي ثْنَاينْ ؤُ-ستِّينْ-أَڒفْ ؤُ-سبْعَا-مْيَا.   
\m
\v 40 \bd أَيْثْ ن أَشِيرْ:\bd* ثَارْوَا نْسنْ - \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، إِنِّي زَّايسْ إِتّْوَاحسْبنْ عْلَاحْسَابْ إِسْمَاونْ ن \add مَارَّا إِرْيَازنْ\add* زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ، مَارَّا ونِّي إِ غَا إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ،  
\v 41 \add وَاهْ،\add* إِنِّي إِتّْوَاحسْبنْ \add أَمُّو\add* إِ ثقْبِيتْشْ ن أَشِيرْ ثُوغَا ثنْ ذِي وَاحِيثْ ؤُ-ربْعِينْ-أَڒفْ ؤُ-خمْسَا-مْيَا.   
\m
\v 42 \bd أَيْثْ ن نَافْثَالِي:\bd* ثَارْوَا نْسنْ - \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، إِنِّي زَّايسْ إِتّْوَاحسْبنْ عْلَاحْسَابْ إِسْمَاونْ ن \add مَارَّا إِرْيَازنْ\add* زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ، مَارَّا ونِّي إِ غَا إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ،  
\v 43 \add وَاهْ،\add* إِنِّي إِتّْوَاحسْبنْ \add أَمُّو\add* إِ ثقْبِيتْشْ ن نَافْثَالِي ثُوغَا أَثنْ ذِي ثْڒَاثَا ؤُ-خمْسِينْ-أَڒفْ ؤُ-أَربْعَا-مْيَا.   
\m
\v 44 إِنَا ذ إِنِّي إِتّْوَاحسْبنْ، إِنِّي تّْوَاحسْبنْ س \add ؤُفُوسْ\add* ن مُوسَا ذ هَارُونْ ذ ڒْحُوكَّامْ ن إِسْرَائِيل، ثنْعَاشْ ن يرْيَازنْ، إِجّنْ ورْيَازْ إِ ثَادَّارْثْ ن بَابَاسْ. \f ◼ \fr 1:‏44 \ft \+bd ’ثَادَّارْثْ ن بَابَاسْ‘\+bd* - إِخْسْ أَذْ يِينِي ’رَادْجْ إِ د-إِتّفّْغنْ زڭْ إِشْثْ ن ثْبَابَاثْ أَكْ-ذ ثْوَاشُونِينْ إِ ذَايسْ ذ جِّيڒَاثْ نّسْ‘.\f*  
\v 45 \bd مَارَّا إِنِّي إِتّْوَاحسْبنْ زڭْ أَيْثْ ن إِسْرَائِيل\bd* - \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ثَادَّارْثْ ن إِبَابَاثنْ نْسنْ - مَارَّا إِنِّي غَارْ إِدْجَا عِيشْرِينْ ن إِسڭّْوُوسَا سنّجْ، كُوڒْ  إِجّْ ونِّي د-إِتّفّْغنْ أَكْ-ذ ڒْعسْكَارْ،  
\v 46 \add وَاهْ،\add* مَارَّا إِنِّي إِتّْوَاحسْبنْ ثُوغَا أَثنْ ذِي ستَّا-مْيَا ؤُ-طڒْثْ-أَڒَافْ ؤُ-خمْسَا-مْيَا ؤُ-خمْسِينْ. \x ◘ \xo 1:‏46 \xt ؤُف. 38‏:‏26\x*   
\m
\v 47 \bd إِلَاوِييّنْ\bd* وَارْ شَارْشنْ شَا جَارْ أَسنْ ذِي ڒحْسَابْ ذِي طّْوعْ ن ثقْبِيتْشْ ن إِبَابَاثنْ نْسنْ،  
\v 48 مِينْزِي سِيذِي ثُوغَا إِسِّيوڒْ أَكْ-ذ مُوسَا، إِنَّا:  
\v 49 ”مْغِيرْ ثَاقْبِيتْشْ ن لَاوِي وَارْ ت تّحْسبْ شَا ؤُ وَارْ ت زمِّي شَا \add أَزدْجِيفْ\add* أَزدْجِيفْ جَارْ أَيْثْ ن إِسْرَائِيل.  
\v 50 \add مَاشَا\add* إِتّْخصَّا شكْ س يِيخفْ نّشْ، أَذْ ثڭّذْ إِلَاوِييّنْ خْ ثْزذِّيغْثْ ن شّْهَاذثْ ؤُ خْ مَارَّا ڒقْشُوعْ نّسْ ؤُ خْ مَارَّا مِينْ ذ أَسْ د-يُوسِينْ. نِيثْنِي أَذْ أَرْبُونْ ثَازذِّيغْثْ أَكْ-ذ ڒقْشُوعْ نّسْ مَارَّا، ؤُشَا أَذْ ذَايسْ سخَّارنْ. إِتّْخصَّا أَذْ وْثنْ إِقِيضَانْ نْسنْ مِينْ د-إِنّْضنْ إِ ثْزذِّيغْثْ.  
\v 51 مَاڒَا أَذْ ثتّْوَافْسِي ثْزذِّيغْثْ، أَذْ ت هذْمنْ إِلَاوِييّنْ ؤُشَا مَاڒَا ثِيوضْ ثْزذِّيغْثْ غَارْ ڒْمَارْڭهْ \add أَنضْفَارْ\add*، \add خنِّي\add* أَذْ ت سّْبدّنْ إِلَاوِييّنْ \add عَاوذْ\add*. مَاڒَا د-إِقَارّبْ شَا ن ؤُبَارَّانِي، خنِّي نتَّا أَذْ إِتّْوَانغْ.  
\v 52 أَيْثْ ن إِسْرَائِيل أَذْ وْثنْ إِقِيضَانْ ن ڒْمَارْڭحْ نْسنْ، كُوڒْ إِجّْ غَارْ ثْعدْجَانْثْ نّسْ، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ.  
\v 53 إِلَاوِييّنْ أَذْ وْثنْ إِقِيضَانْ نْسنْ غَارْ كُوڒْ جِّيهثْ ن ثْزذِّيغْثْ ن شّْهَاذثْ، حِيمَا وَارْ إِتِّيڒِي ؤُذُوقّزْ \add ن وغْضَابْ\add* خْ ثْمسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل. إِتّْخصَّا إِ إِلَاوِييّنْ أَذْ حْضَانْ خْ ثْزذِّيغْثْ ن شّْهَاذثْ.“   
\m
\v 54 ؤُشَا ڭِّينْ أَيْثْ ن إِسْرَائِيل س مَارَّا مِينْ يُومُورْ سِيذِي إِ مُوسَا، \add وَاهْ،\add* أَمُّو \add إِ-ث\add* ڭِّينْ.   
\b  
\b  
\m  
\c 2
\s1 أَستّفْ ن ثْقبَّاڒْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ هَارُونْ، إِنَّا:   
\m
\v 2 ”أَيْثْ ن إِسْرَائِيل أَذْ وْثنْ إِقِيضَانْ نْسنْ كُوڒْ إِجّْ غَارْ ثْعدْجَانْثْ نّسْ، غَارْ ڒعْڒَامَاثْ ن ثَادَّارْثْ ن إِبَابَاثنْ نْسنْ. أَذْ وْثنْ إِقِيضَانْ نْسنْ شْوَايْثْ غَارْ ڒَاڭّْوَاجْ غَارْ مَارَّا إِغزْذِيسنْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.“   
\m
\v 3 إِنِّي إِدْجَانْ سَاذُو ن ثْعدْجَانْثْ ن \bd ڒْمَارْڭحْ ن ڒْعسْكَارْ ن يَاهُوذَا\bd* أَذْ وْثنْ إِقِيضَانْ نْسنْ، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ \bd غَارْ شَّارْقْ\bd*، غَارْ مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ. نَاحْشُونْ، مِّيسْ ن عَامِّينَاذَابْ، \add أَذْ يِيڒِي\add* ذ ڒْحَاكمْ ن أَيْثْ ن يَاهُوذَا.  
\v 4 إِنِّي إِتّْوَاحسْبنْ إِ ڒْعسْكَارْ نّسْ، ثُوغَا أَثنْ ذِي أَربْعَا ؤُ-سبْعِينْ-أَڒفْ ؤُ-ستَّا-مْيَا.   
\m
\v 5 زَّاثسْ أَذْ ثوّثْ \bd ثقْبِيتْشْ ن إِسَّاكَارْ\bd* إِقِيضَانْ نّسْ. نَاثَانَايِيلْ، مِّيسْ ن صُوغَارْ، \add أَذْ يِيڒِي\add* ذ ڒْحَاكمْ ن أَيْثْ ن إِسَّاكَارْ.  
\v 6 إِنِّي إِتّْوَاحسْبنْ إِ ڒْعسْكَارْ نّسْ، ثُوغَا أَثنْ ذِي أَربْعَا ؤُ-خمْسِينْ-أَڒفْ ؤُ-أَربْعَا-مْيَا.   
\m
\v 7 \add خنِّي\add* \bd ثَاقْبِيتْشْ ن زابُولُونْ\bd*. إِلِييَابْ، مِّيسْ ن هِيلُونْ، \add أَذْ يِيڒِي\add* ذ ڒْحَاكمْ ن أَيْثْ ن زابُولُونْ.  
\v 8 إِنِّي إِتّْوَاحسْبنْ إِ ڒْعسْكَارْ نّسْ، ثُوغَا أَثنْ ذِي سبْعَا ؤُ-خمْسِينْ-أَڒفْ ؤُ-أَربْعَا-مْيَا.   
\m
\v 9 إِنِّي إِتّْوَاحسْبنْ إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ ن يَاهُوذَا ثُوغَا أَثنْ مَارَّا \add جْمِيعْ\add* ذِي مْيَا ؤُ-ستَّا ؤُ-ثْمَانِينْ-أَڒفْ ؤُ-أَربْعَا-مْيَا \add ن يرْيَازنْ\add*، \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ. نِيثْنِي أَذْ فسْينْ إِقِيضَانْ نْسنْ أَمزْوَارُو.   
\b  
\m
\v 10 \bd غَارْ لْجَانُوبْ\bd* أَذْ ثِيڒِي ثْعدْجَانْثْ ن \bd ڒْمَارْڭحْ ن ڒْعسْكَارْ ن رُوبِينْ\bd*. \add نِيثْنِي أَذْ إِڒِينْ تّْوَاستّْفنْ\add* عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ. إِلِيصُورْ، مِّيسْ ن شَاذَايُّورْ، \add أَذْ يِيڒِي\add* ذ ڒْحَاكمْ ن أَيْثْ ن رُوبِينْ. \f ◼ \fr 2:‏10 \ft \+bd ’غَارْ ؤُژڒْمَاضْ‘\+bd* - نِيغْ ’غَارْ لْجَانُوبْ‘.\f*  
\v 11 إِنِّي إِتّْوَاحسْبنْ إِ ڒْعسْكَارْ نّسْ، ثُوغَا أَثنْ ذِي ستَّا ؤُ-ربْعِينْ-أَڒفْ ؤُ-خمْسَا-مْيَا.   
\m
\v 12 زَّاثسْ أَذْ ثوّثْ \bd ثقْبِيتْشْ ن شِيمْعُونْ\bd* إِقِيضَانْ نّسْ. شَالُومِييِيلْ، مِّيسْ ن صُورِييْشَادَّايْ، \add أَذْ يِيڒِي\add* ذ ڒْحَاكمْ ن أَيْثْ ن شِيمْعُونْ.  
\v 13 إِنِّي إِتّْوَاحسْبنْ إِ ڒْعسْكَارْ نّسْ، ثُوغَا أَثنْ ذِي ثسْعَا ؤُ-خمْسِينْ-أَڒفْ ؤُ-ثڒْثْ-مْيَا.   
\m
\v 14 \add خنِّي\add* \bd ثَاقْبِيتْشْ ن جَاذْ\bd*. إِلْيَاسَافْ، مِّيسْ ن رَاعُويِيلْ، \add أَذْ يِيڒِي\add* ذ ڒْحَاكمْ ن أَيْثْ ن جَاذْ.  
\v 15 إِنِّي إِتّْوَاحسْبنْ إِ ڒْعسْكَارْ نّسْ، ثُوغَا أَثنْ ذِي خمْسَا ؤُ-ربْعِينْ-أَڒفْ ؤُ-ستَّا-مْيَا ؤُ-خمْسِينْ.   
\m
\v 16 إِنِّي إِتّْوَاحسْبنْ إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ ن رُوبِينْ، ثُوغَا أَثنْ مَارَّا ذِي مْيَا ؤُ-وَاحِيثْ ؤُ-خمْسِينْ-أَڒفْ ؤُ-أَربْعَا-مْيَا ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*، \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ. نِيثْنِي أَذْ فسْينْ إِقِيضَانْ نْسنْ وِيسّْ ثْنَاينْ.   
\b  
\m
\v 17 \add خنِّي\add* أَذْ إِتّْوَافْسِي \bd ؤُقِيضُونْ ن ؤُمْسَاڭَارْ \+bdit أَكْ-ذ\+bdit* ڒْمَارْڭحْ ن إِلَاوِييّنْ، ذِي ڒْوسْطْ ن \+bdit مَارَّا\+bdit* ڒْعسْكَارْ\bd*. أَمْ مَامّشْ غَا وْثنْ إِقِيضَانْ نْسنْ، أَمُّو إِتّْخصَّا أَذْ مُّوطِّيينْ \add عَاوذْ\add*، كُوڒْ إِجّْ ذڭْ ومْشَانْ نّسْ، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ثِيعدْجَانِينْ نْسنْ.   
\b  
\m
\v 18 \bd غَارْ ڒْغَارْبْ\bd* أَذْ ثِيڒِي ثْعدْجَانْثْ ن \bd ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِفْرَايِيمْ\bd*. \add نِيثْنِي أَذْ إِڒِينْ تّْوَاستّْفنْ\add* عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ. إِلِيشَامَاعْ، مِّيسْ ن عَامِّيهُوذْ، \add أَذْ يِيڒِي\add* ذ ڒْحَاكمْ ن أَيْثْ ن إِفْرَايِيمْ.  
\v 19 إِنِّي إِتّْوَاحسْبنْ إِ ڒْعسْكَارْ نّسْ، ثُوغَا أَثنْ ذِي أَربْعِينْ-أَڒفْ ؤُ-خمْسَا-مْيَا.   
\m
\v 20 زَّاثسْ \add أَذْ ثِيڒِي\add* \bd ثقْبِيتْشْ ن مَانَاسَّا\bd*. جَامْلِييِيلْ، مِّيسْ ن فَاذَاهْصُورْ \add أَذْ يِيڒِي\add* ذ ڒْحَاكمْ ن أَيْثْ ن مَانَاسَّا.  
\v 21 إِنِّي إِتّْوَاحسْبنْ إِ ڒْعسْكَارْ نّسْ، ثُوغَا أَثنْ ذِي ثْنَاينْ ؤُ-ثْڒَاثِينْ-أَڒفْ ؤُ-مِيثَايْنْ.   
\m
\v 22 \add خنِّي\add* \bd ثَاقْبِيتْشْ ن بِينْيَامِينْ\bd*. أَبِيذَانْ، مِّيسْ ن جِيذْعُونِي، \add أَذْ يِيڒِي\add* ذ ڒْحْكامْ ن أَيْثْ ن بِينْيَامِينْ.  
\v 23 إِنِّي إِتّْوَاحسْبنْ إِ ڒْعسْكَارْ نّسْ، ثُوغَا أَثنْ ذِي خمْسَا ؤُ-طْڒَاثِينْ-أَڒفْ ؤُ-أَربْعَا-مْيَا.   
\m
\v 24 إِنِّي إِتّْوَاحسْبنْ إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِفْرَايِيمْ، ثُوغَا أَثنْ ذِي مْيَا ؤُ-ثْمنْيَا-أَڒفْ ؤُ-مْيَا \add ن يرْيَازنْ\add*، \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ. نِيثْنِي أَذْ فسْينْ إِقِيضَانْ نْسنْ وِيسّْ ثْڒَاثَا.   
\b  
\m
\v 25 \bd غَارْ شّْمَالْ\bd* أَذْ ثِيڒِي ثْعدْجَانْثْ ن \bd ڒْمَارْڭحْ ن ڒْعسْكَارْ ن ذَانْ\bd*. \add نِيثْنِي أَذْ إِڒِينْ تّْوَاستّْفنْ\add* عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ. أَخِيعَازَارْ، مِّيسْ ن عَامِّيشَادَّايْ، \add أَذْ يِيڒِي\add* ذ ڒْحَاكمْ ن أَيْثْ ن دَان.  
\v 26 إِنِّي إِتّْوَاحسْبنْ إِ ڒْعسْكَارْ نّسْ، ثُوغَا أَثنْ ذِي ثْنَاينْ ؤُ-ستِّينْ-أَڒفْ ؤُ-سبْعَا-مْيَا.   
\m
\v 27 زَّاثسْ أَذْ ثوّثْ \bd ثقْبِيتْشْ ن أَشِيرْ\bd* إِقِيضَانْ نّسْ. فَاجْعِييِيلْ، مِّيسْ ن عُوكْرَانْ، \add أَذْ يِيڒِي\add* ذ ڒْحَاكمْ ن أَيْثْ ن أَشِيرْ.  
\v 28 إِنِّي إِتّْوَاحسْبنْ إِ ڒْعسْكَارْ نّسْ، ثُوغَا أَثنْ ذِي وَاحِيثْ ؤُ-ربْعِينْ-أَڒفْ ؤُ-خمْسَا-مْيَا.   
\m
\v 29 \add خنِّي\add* \bd ثَاقْبِيتْشْ ن نَافْثَالِي\bd*. أَخِيرَاعْ، مِّيسْ ن عِينَانْ، \add أَذْ يِيڒِي\add* ذ ڒْحَاكمْ ن أَيْثْ ن نَافْثَالِي.  
\v 30 إِنِّي إِتّْوَاحسْبنْ إِ ڒْعسْكَارْ نّسْ، ثُوغَا أَثنْ ذِي ثْڒَاثَا ؤُ-خمْسِينْ-أَڒفْ ؤُ-أَربْعَا-مْيَا.   
\m
\v 31 إِنِّي إِتّْوَاحسْبنْ إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ ن ذَانْ، ثُوغَا أَثنْ ذِي مْيَا ؤُ-سبْعَا ؤُ-خمْسِينْ-أَڒفْ ؤُ-ستَّا-مْيَا \add ن يرْيَازنْ\add*. نِيثْنِي أَذْ فسْينْ إِقِيضَانْ نْسنْ ذ أَنڭَّارُو، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ثِيعدْجَانِينْ نْسنْ.   
\b  
\m
\v 32 \bd إِنَا ذ إِنِّي إِتّْوَاحسْبنْ ن أَيْثْ ن إِسْرَائِيل\bd*، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ثَادَّارْثْ ن إِبَابَاثنْ نْسنْ. مَارَّا إِنِّي إِتّْوَاحسْبنْ ذِي ڒمْرَاڭحْ ن ڒْعسْكَارْ، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ، \add ثُوغَا أَثنْ\add* ذِي ستَّا-مْيَا ؤُ-ثڒْثْ-أَڒَافْ ؤُ-خمْسَا-مْيَا ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.“ \x ◘ \xo 2:‏32 \xt ؤُف. 38‏:‏26؛ ڒخْڒ. 1‏:‏46\x*   
\m
\v 33 \bd إِلَاوِييّنْ\bd* جَارْ أَيْثْ ن إِسْرَائِيل وَارْ تّْوَاحسْبنْ شَا، \add نِيشَانْ\add* أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي إِ مُوسَا. \x ◘ \xo 2:‏33 \xt ڒخْڒ. 1‏:‏48، 49\x*   
\m
\v 34 ؤُشَا ڭِّينْ أَيْثْ ن إِسْرَائِيل أَمْ مَامّشْ مَارَّا مِينْ ذ أَسْ يُومُورْ سِيذِي إِ مُوسَا: أَمْ مَامّشْ وْثِينْ إِقِيضَانْ نْسنْ س ؤُستّفْ غَارْ ثْعدْجَانِينْ نْسنْ، أَمُّو إِ غَا فسْينْ إِقِيضَانْ نْسنْ \add عَاوذْ\add*، كُوڒْ إِجّنْ \add إِتّْوَاستّفْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نّسْ، غَارْ ثَادَّارْثْ ن إِبَابَاثنْ نّسْ.   
\b  
\b  
\m  
\c 3
\s1 أَيْثْ ن هَارُونْ  
\m
\v 1 \bd أَقَا إِنَا ذ ثَارْوَا ن هَارُونْ ذ مُوسَا\bd* ذڭْ وُوسَّانْ نِّي إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا خْ وذْرَارْ ن سِينَا.  
\v 2 أَقَا إِنَا ذ إِسْمَاونْ ن وَارَّاوْ ن هَارُونْ: نَاذَابْ ذ أَمنْزُو، \add خنِّي\add* أَبِيهُو، أَلِيعَازَارْ ذ إِثَامَارْ. \x ◘ \xo 3:‏2 \xt ؤُف. 6‏:‏23؛ ڒخْڒ. 3‏:‏4 4‏:‏28\x*  
\v 3 أَقَا إِنَا ذ إِسْمَاونْ ن وَارَّاوْ ن هَارُونْ، إِكهَّاننْ إِنِّي إِتّْوَاذهْننْ ؤُ إِنِّي إِتّْوَاڒقّْمنْ أَمْ يِيكهَّاننْ.  
\v 4 \add مَاشَا\add* نَاذَابْ ذ أَبِيهُو مُّوثنْ زَّاثْ إِ وُوذمْ ن سِيذِي، ؤُمِي قدّْمنْ ثِيمسِّي ثَاڒْغِيبْثْ زَّاثْ إِ وُوذمْ ن سِيذِي ذِي ڒخْڒَا ن سِينَا. وَارْ ثُوغِي غَارْسنْ أَرَّاوْ. \add س ؤُيَا\add* ثُوغَا أَلِيعَازَارْ ذ إِثَامَارْ سخَّارنْ \add أَمْ\add* ؤُكهَّانْ زَّاثْ إِ وُوذمْ ن بَابَاثْسنْ هَارُونْ. \x ◘ \xo 3:‏4 \xt لَاوِي 10‏:‏1‏-‏7؛ ڒخْڒ. 26‏:‏61؛ 1 إِم. 24‏:‏2\x*   
\b  
\m  
\s1 ثَاسخَّارْثْ ن أَيْثْ ن لَاوِي  
\m
\v 5 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 6 ”سْقَارّبْ-د ثَاقْبِيتْشْ ن لَاوِي ؤُشَا أڭّْ إِ-ثنْ زَّاثْ إِ وُوذمْ ن ؤُكهَّانْ هَارُونْ، حِيمَا أَذْ خَاسْ سخَّارنْ. \x ◘ \xo 3:‏6 \xt ڒخْڒ. 16‏:‏9؛ 18‏:‏2\x*  
\v 7 أجّْ إِ-ثنْ أَذْ ڒْهَانْ ثَاسخَّارْثْ نّسْ ذ ثْسخَّارْثْ ن مَارَّا ثَامسْمُونْثْ زَّاثْ إِ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، مَاحنْذْ أَذْ كمّْڒنْ ڒْخذْمثْ ن ثْزذِّيغْثْ.  
\v 8 أَذْ حْضَانْ خْ مَارَّا ڒقْشُوعْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا أَذْ طّْفنْ أَحطُّو ن أَيْثْ ن إِسْرَائِيل مَاحنْذْ أَذْ سخَّارنْ ذِي ثْسخَّارْثْ ن ثْزذِّيغْثْ.  
\v 9 شكْ أَذْ ثوْشذْ إِلَاوِييّنْ إِ هَارُونْ ؤُ إِ وَارَّاونْ نّسْ. أَقَا ذ يِينَا إِ ذ أَسْ إِمّوْشنْ إِ نتَّا وَاهَا زڭْ أَيْثْ ن إِسْرَائِيل.  
\v 10 أَذْ ثْڒقّْمذْ هَارُونْ ذ وَارَّاوْ نّسْ مَاحنْذْ أَذْ حْضَانْ خْ ثُوكهَّانْثْ. أَبَارَّانِي نِّي إِ دّْ غَا إِقَارّْبنْ أَذْ إِتّْوَانغْ.“   
\m
\v 11 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 12 ”خْزَارْ، نشّْ كْسِيغْ إِلَاوِييّنْ زِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل ذڭْ ومْشَانْ ن إِمنْزَا، مَارَّا إِنِّي يَارزْمنْ ڒمْڒَاوثْ \add ذ أَمزْوَارُو\add* جَارْ أَيْثْ ن إِسْرَائِيل. إِلَاوِييّنْ أَذْ إِڒِينْ إِنُو، \x ◘ \xo 3:‏12 \xt ؤُف. 13‏:‏2\x*  
\v 13 مِينْزِي كُوڒْ أَمنْزُو أَقَا إِنُو. ذڭْ وَاسّْ مِينْ ذِي وْثِيغْ مَارَّا إِمنْزَا ذِي ثمُّورْثْ ن مِيصْرَا، أَقَا سّْقدّْسغْ إِ يِيخفْ إِنُو مَارَّا إِمنْزَا ذِي إِسْرَائِيل، زِي بْنَاذمْ أَڒْ ڒْمَاڒْ. نِيثْنِي أَذْ إِڒِينْ إِنُو، نشّْ ذ سِيذِي!“ \x ◘ \xo 3:‏13 \xt ؤُف. 13‏:‏2؛ 22‏:‏29؛ 34‏:‏19؛ لَاوِي 27‏:‏26؛ ڒخْڒ. 8‏:‏16؛ لك. 2‏:‏22\x*   
\b  
\m  
\s1 ڒْقدّْ ن إِلَاوِييّنْ  
\m
\v 14 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذِي ڒخْڒَا ن سِينَا، إِنَّا:   
\m
\v 15 ”حْسبْ أَيْثْ ن لَاوِي، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ. مَارَّا إِوثْمَانْ نِّي إِدْجَانْ ذ \add إِجّْ ن\add* ؤُيُورْ سنّجْ، أَذْ ثنْ ثحْسبْ.“  
\v 16 ؤُشَا مُوسَا إِحْسبْ إِ-ثنْ خْ ڒُومُورْ ن سِيذِي، أَمْ مَامّشْ \add ذ أَسْ\add* إِوصَّا.   
\b  
\m
\v 17 \bd \+bdit ثُوغَا\+bdit* إِنَا ذ أَيْثْ ن لَاوِي أَكْ-ذ إِسْمَاونْ نْسنْ: جَارْشُونْ، ذ قَاهَاثْ ذ مَارَارِي.\bd* \x ◘ \xo 3:‏17 \xt ؤُف. 6‏:‏16، 17، 18؛ ڒخْڒ. 26‏:‏57؛ 1 إِم. 6‏:‏1، 16؛ 23‏:‏6\x*   
\m
\v 18 \add ثُوغَا\add* إِنَا ذ إِسْمَاونْ ن أَيْثْ ن جَارْشُونْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ: لِيبْنِي ذ شِيمْعِي.   
\m
\v 19 أَيْثْ ن قَاهَاثْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ: عَامْرَامْ ذ يِيصْهَارْ ذ حَابْرُونْ ذ عُوزِّييِيلْ.   
\m
\v 20 أَيْثْ ن مَارَارِي، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ: مَاحْلِي ذ مُوشِي. \add ثُوغَا\add* إِنَا ذ ڒَادْجَاثْ ن إِلَاوِييّنْ، \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ.   
\b  
\m
\v 21 \bd غَارْ جَارْشُونْ\bd* \add ثُوغَا ثدْجَا\add* ڒَادْجْ ن إِلِيبْنِييّنْ ذ ڒَادْجْ ن إِشِيمْعِييّنْ. \add ثُوغَا\add* ثِينَا ذ ڒَادْجَاثْ ن إِجَارْشُونِييّنْ.  
\v 22 ڒْقدّْ ن يِينِّي زَّايْسنْ إِتّْوَاحسْبنْ، ن مَارَّا إِوثْمَانْ زڭْ \add إِجّْ ن\add* ؤُيُورْ سنّجْ، \add أَقَا ڒْقدّْ نِّي ن\add* يِينِّي زَّايْسنْ إِتّْوَاحسْبنْ ثُوغَا ذِي سبْعَا-أَڒَافْ ؤُ-خمْسَا-مْيَا.  
\v 23 وْثِينْثْ ڒَادْجَاثْ ن إِجَارْشُونِييّنْ إِقِيضَانْ نْسنْ غَارْ ضفَّارْ ن ثْزذِّيغْثْ، \bd غَارْ ڒْغَارْبْ\bd*.  
\v 24 \add ثُوغَا\add* إِلْيَاسَافْ، مِّيسْ ن لَايِيلْ، ذ ڒْحَاكمْ ن ثَادَّارْثْ ن بَابَاثْسنْ ن إِجَارْشُونِييّنْ.  
\v 25 زِي جِّيهثْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ حْضَانْ أَيْثْ ن جَارْشُونْ خْ ثْزذِّيغْثْ، خْ ؤُقِيضُونْ أَكْ-ذ ثْسقَّافِينْ نّسْ، خْ وَارْوَاقْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ،  
\v 26 خْ ڒِيزَارَاثْ ن ڒمْرَاحْ ذ وَارْوَاقْ غَارْ وَاذَافْ ن ڒمْرَاحْ إِ زِي ثتّْوَانّضْ ثْزذِّيغْثْ ذ ؤُعَالْطَارْ، ؤُ خْ إِفِيڒَانْ نّسْ، ؤُڒَا خْ مَارَّا \add مِينْ د-إِتَّاسنْ أَكْ-ذ\add* ثْسخَّارْثْ نِّي.   
\b  
\m
\v 27 \bd زِي قَاهَاثْ\bd* \add ثُوغَا إِقَّارْصْ-د\add* ڒَادْجْ ن إِعَامْرَامِييّنْ ذ ڒَادْجْ ن إِصْهَارِييّنْ ذ ڒَادْجْ ن إِحِيبْرُونِييّنْ ذ ڒَادْجْ ن إِعَازِييِيلِييّنْ. \add ثُوغَا\add* ثِينَا ذ ڒَادْجَاثْ ن إِقَاهَاثِييّنْ.  
\v 28 \add ثُوغَا\add* ڒْقدّْ ن مَارَّا إِوثْمَانْ زڭْ \add إِجّْ ن\add* ؤُيُورْ سنّجْ ثمْنْ-أَڒَافْ ؤُ-ستَّا-مْيَا. نِيثْنِي حْضَانْ خْ زَّاوشْثْ إِقدّْسنْ.  
\v 29 وْثِينْثْ ڒَادْجَاثْ ن أَيْثْ ن قَاهَاثْ إِقِيضَانْ نْسنْ غَارْ ؤُغزْذِيسْ ن ثْزذِّيغْثْ، \bd غَارْ لْجَانُوبْ\bd*.  
\v 30 إِلِيصَافَانْ، مِّيسْ ن عُوزِّييِيلْ، \add ثُوغَا\add* ذ ڒْحَاكمْ ن ثَادَّارْثْ ن بَابَاثْسنْ ن ڒَادْجَاثْ ن إِقُوهَاثِييّنْ.  
\v 31 نِيثْنِي ثُوغَا حطَّانْ خْ تَّابُوثْ ذ ثْزوْضَا ذ ڒْقنْذِيڒْ ذ إِعَالْطَارنْ ؤُ خْ ڒقْشُوعْ ن زَّاوشْثْ إِقدّْسنْ إِ سّْخذْمنْ ؤُ خْ ؤُڒحَّافْ، \add وَاهْ،\add* خْ مَارَّا \add إِ د-إِتَّاسنْ أَكْ-ذ\add* ثْسخَّارْثْ نِّي.   
\m
\v 32 \add ثُوغَا\add* أَلِيعَازَارْ، مِّيسْ ن ؤُكهَّانْ هَارُونْ، ذ ڒْحَاكمْ أَمزْوَارُو قَاعْ خْ \add مَارَّا\add* ڒْحُوكَّامْ ن لَاوِي. نتَّا إِطّفْ أَشْبَارْ خْ يِينِّي ثُوغَا إِحطَّانْ خْ زَّاوشْثْ إِقدّْسنْ.   
\b  
\m
\v 33 \bd زِي مَارَارِي\bd* \add ثُوغَا إِقَّارْصْ\add* ڒَادْجْ ن إِمَاحْلِييّنْ ذ ڒَادْجْ ن إِمُوشِييّنْ. \add ثُوغَا\add* ثِينَا ذ ڒَادْجَاثْ ن مَارَارِي.  
\v 34 \add ثُوغَا\add* ڒْقدّْ ن يِينِّي زَّايْسنْ إِتّْوَاحسْبنْ، ن مَارَّا إِوثْمَانْ زڭْ \add إِجّْ ن\add* ؤُيُورْ سنّجْ، ذِي ستَّا-أَڒَافْ ؤُ-مِيثَايْنْ.  
\v 35 \add ثُوغَا\add* سُورِييِيلْ، مِّيسْ ن أَبِيخَايِيلْ، ذ ڒْحَاكمْ ن ثَادَّارْثْ ن بَابَاثْسنْ ن ڒَادْجَاثْ ن مَارَارِي. نِيثْنِي وْثِينْ إِقِيضَانْ نْسنْ غَارْ ؤُغزْذِيسْ ن ثْزذِّيغْثْ، \bd غَارْ شَّامَالْ\bd*.  
\v 36 أَيْثْ ن مَارَارِي ثُوغَا ثطّْفنْ أَشْبَارْ مَاحنْذْ أَذْ وْشنْ ثَايْنِيثْ إِ مَارَّا ثِيفڒْوِينْ ن ثْزذِّيغْثْ، إِ ثْحنْيَا ن ؤُعَارّضْ، إِ إِپِيلَارنْ نّسْ، إِ ثْيَارْسَاوِينْ نّسْ ؤُ إِ مَارَّا ڒقْشُوعْ نّسْ، \add وَاهْ.\add* إِ مَارَّا \add مِينْ د-إِتَّاسنْ أَكْ-ذ\add* ثْسخَّارْثْ نِّي،  
\v 37 ؤُڒَا إِ إِپِيلَارنْ نِّي د-إِنّْضنْ إِ ڒمْرَاحْ أَكْ-ذ ثْيَارْسَاوِينْ نْسنْ ذ ڒوْثَاذْ نْسنْ ذ إِفِيڒَانْ نْسنْ.   
\b  
\m
\v 38 \bd مُوسَا ذ هَارُونْ أَكْ-ذ وَارَّاوْ نّسْ\bd* وْثِينْ إِقِيضَانْ نْسنْ زَّاثْ إِ وُوذمْ ن ثْزذِّيغْثْ، زَّاثْ إِ وُوذمْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، \bd غَارْ شَّارْقْ\bd* مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ. نِيثْنِي حْضَانْ خْ زَّاوشْثْ إِقدّْسنْ ذِي طّْوعْ ن أَيْثْ ن إِسْرَائِيل. أَبَارَّانِي نِّي د-إِقَارّْبنْ، ثُوغَا إِتّْخصَّا أَذْ إِتّْوَانغْ. \x ◘ \xo 3:‏38 \xt ڒخْڒ. 3‏:‏10؛ 16‏:‏40\x*   
\m
\v 39 \bd مَارَّا إِنِّي إِتّْوَاحسْبنْ ن إِلَاوِييّنْ،\bd* إِنِّي إِحْسبْ مُوسَا أَكْ-ذ هَارُونْ عْلَاحْسَابْ ڒُومُورْ ن سِيذِي، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، مَارَّا إِوثْمَانْ زڭْ \add إِجّْ ن\add* ؤُيُورْ سنّجْ، ثُوغَا أَثنْ ذِي ثْنَاينْ ؤُ-عِيشْرِينْ-أَڒفْ.   
\m
\v 40 إِنَّا سِيذِي إِ مُوسَا: ”حْسبْ مَارَّا إِمنْزَا ن إِوثْمَانْ ن أَيْثْ ن إِسْرَائِيل، زڭْ \add إِجّْ ن\add* ؤُيُورْ سنّجْ، ؤُشَا كْسِي ڒْقدّْ ن إِسْمَاونْ نْسنْ.  
\v 41 أَذْ ثكْسِيذْ إِلَاوِييّنْ إِ نشّْ - نشّْ ذ سِيذِي! - ذڭْ ومْشَانْ ن مَارَّا إِمنْزَا جَارْ أَيْثْ ن إِسْرَائِيل ؤُڒَا ذ ڒبْهَايمْ ن إِلَاوِييّنْ ذڭْ ومْشَانْ ن مَارَّا إِمنْزَا جَارْ ڒبْهَايمْ ن أَيْثْ ن إِسْرَائِيل.“  
\v 42 ؤُشَا إِحْسبْ مُوسَا مَارَّا إِمنْزَا جَارْ أَيْثْ ن إِسْرَائِيل أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي.  
\v 43 ڒْقدّْ ن إِسْمَاونْ ن مَارَّا إِمنْزَا إِوثْمَانْ ن \add إِجّْ ن\add* ؤُيُورْ سنّجْ، ن يِينِّي زَّايْسنْ إِتّْوَاحسْبنْ، ثُوغَا أَثنْ ذِي ثْنَاينْ ؤُ-عِيشْرِينْ-أَڒفْ ؤُ-مِيثَايْنْ ؤُ-ثْڒَاثَا ؤُ-سبْعِينْ.   
\b  
\m
\v 44 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 45 ”كْسِي إِلَاوِييّنْ ذڭْ ومْشَانْ ن مَارَّا إِمنْزَا جَارْ أَيْثْ ن إِسْرَائِيل ؤُڒَا ذ ڒبْهَايمْ ن إِلَاوِييّنْ ذڭْ ومْشَانْ ن ڒبْهَايمْ نْسنْ، مِينْزِي إِلَاوِييّنْ أَذْ إِڒِينْ إِنُو. أَقَا نشّْ ذ سِيذِي.  
\v 46 زِي جِّيهثْ ن مِيثَاينْ ؤُ-ثْڒَاثَا ؤُ-سبْعِينْ، إِنِّي إِتّْخصَّا أَذْ تّْوَافْذِينْ، مَاغَارْ نِيثْنِي قِّيمنْ سنّجْ إِ إِلَاوِييّنْ ن إِمنْزَا ن أَيْثْ ن إِسْرَائِيل،  
\v 47 إِتّْخصَّا أَذْ ثكْسِيذْ خمْسَا شِيقْلُو إِ \add كُوڒْ إِجّْ ن\add* ؤُزدْجِيفْ. أَذْ ث ثكْسِيذْ أَنشْثْ ن شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. شِيقْلُو \add وَانِيثَا\add* أَقَا ذَايسْ عِيشْرِينْ جِيرَا. \x ◘ \xo 3:‏47 \xt ؤُف. 30‏:‏31؛ لَاوِي 27‏:‏25؛ ڒخْڒ. 18‏:‏16؛ حِز. 45‏:‏12\x*  
\v 48 أَذْ ثوْشذْ نُّوقَارْثْ نِّي إِ هَارُونْ ؤُ إِ وَارَّاوْ نّسْ، أَقَا-ت إِ تَّامَانْ ن ؤُفكِّي ن يِينِّي إِقِّيمنْ \add سنّجْ إِ ڒْقدّْ ن إِلَاوِييّنْ\add*.“   
\m
\v 49 \add خنِّي\add* إِكْسِي مُوسَا نُّوقَارْثْ ن تَّامَانْ ن ؤُفكِّي ن يِينِّي إِقِّيمنْ سنّجْ ن يِينِّي إِتّْوَافْذِينْ س إِلَاوِييّنْ.  
\v 50 ؤُشَا إِطّفْ نُّوقَارْثْ \add نِّي\add* زڭْ إِمنْزَا ن أَيْثْ ن إِسْرَائِيل: أَڒفْ ؤُ-ثڒْثْ-مْيَا ؤُ-خمْسَا ؤُ-ستِّينْ \add شِيقْلُو\add*، عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ.  
\v 51 ؤُ مُوسَا إِوْشَا نُّوقَارْثْ ن يِينِّي إِوْشِينْ تَّامَانْ ن ؤُفكِّي إِ هَارُونْ ؤُ إِ وَارَّاوْ نّسْ، عْلَاحْسَابْ \add أَوَاڒْ ن\add* ؤُقمُّومْ ن سِيذِي، أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي إِ مُوسَا.   
\b  
\b  
\m  
\c 4
\s1 ثَاسخَّارْثْ ن إِقَاهَاثِييّنْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ هَارُونْ، إِنَّا:   
\m
\v 2 ”\bd حْسبْ أَيْثْ ن قَاهَاثْ\bd* أَزدْجِيفْ \add أَزدْجِيفْ\add* جَارْ أَيْثْ ن لَاوِي، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ،  
\v 3 زِي ثْڒَاثِينْ ن إِسڭّْوُوسَا سنّجْ أَڒْ خمْسِينْ ن إِسڭّْوُوسَا، مَارَّا ونِّي إِ غَا يَاذْفنْ غَارْ ڒْعسْكَارْ مَاحنْذْ أَذْ يڭّْ ڒْخذْمثْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.   
\m
\v 4 ذ ثَا \add إِ غَا يِيڒِينْ\add* ذ \bd ثَاسخَّارْثْ ن أَيْثْ ن قَاهَاثْ\bd* ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ: \add أَحطُّو خْ\add* وقْذَاسْ خْ ؤُقدَّاسْ.  
\v 5 خْمِي د غَا فسْينْ ڒْمَارْڭحْ، أَذْ د-يَاسْ هَارُونْ ذ وَارَّاوْ نّسْ ؤُشَا أَذْ كّْسنْ أَڒحَّافْ إِ إِدْجَانْ إِ دُّورِي ؤُشَا أَذْ زَّايسْ سّْذُورْينْ تَّابُوثْ ن شّْهَاذثْ.   
\m
\v 6 إِتّْخصَّا أَذْ خَاسْ ڭّنْ إِجّْ ن دُّورِي ن إِڒْمَاونْ ن دّنْفِيڒَاثْ ؤُشَا أَذْ خَاسْ بزّْعنْ إِجّْ ن دُّورِي مَارَّا ذ أَذحْمِي ؤُشَا أَذْ أَسْ ڭّنْ إِعُومَاذْ نّسْ \add إِ ثَاربُّوثْ\add*.  
\v 7 أَذْ بزّْعنْ إِشْثْ ن ثْجَارْثِيڒْطْ ثَاذحْمِيثْ خْ ثْزوْضَا إِ وغْرُومْ ن وسْشَانْ ؤُشَا أَذْ خَاسْ ڭّنْ طّْبَاصِي، ثِيغنْجَايِينْ ذ ڒْكِيسَانْ ذ إِغَارَّافنْ س إِنِّي إِ غَا كبّنْ. ؤُشَا إِتّْخصَّا أَذْ خَاسْ يِيڒِي وغْرُومْ ن ڒبْذَا. \x ◘ \xo 4:‏7 \xt ؤُف. 25‏:‏30\x*  
\v 8 \add أَوَارْنِي ؤُيَا\add* أَذْ خَاسْ بزّْعنْ إِجّْ ن دُّورِي أَزڭّْوَاغْ إِحذْقنْ ؤُشَا أَذْ ت ذْڒنْ \add عَاوذْ\add* س إِجّْ ن دُّورِي ن إِڒْمَاونْ ن دّنْفِيڒَاثْ ؤُشَا أَذْ أَسْ ڭّنْ إِعُومَاذْ نّسْ \add إِ ثَاربُّوثْ\add*.  
\v 9 \add خنِّي\add* أَذْ كْسِينْ إِشْثْ ن ثْجَارْثِيڒْثْ ثَاذحْمَانِيثْ ؤُشَا أَذْ زَّايسْ ذْڒنْ ڒْقنْذِيڒْ إِ ثْفَاوْثْ ؤُڒَا ذ ڒفْنَارَاثْ نّسْ ذ ثْجقَّاضِينْ \add ن ثفْثِيتْشْ\add* نّسْ ذ ثْمجْمَارِينْ نّسْ ذ مَارَّا ڒقْشُوعْ نّسْ إِ زّشْثْ ذِي طّْوعْ ن ثْسخَّارْثْ إِ \add ڒْقنْذِيڒْ\add*. \x ◘ \xo 4:‏9 \xt ؤُف. 25‏:‏31، 38\x*  
\v 10 أَذْ ڭّنْ \add ڒْْقنْذِيڒْ-أَ\add* ذ مَارَّا ڒقْشُوعْ نّسْ ذڭْ إِجّْ ن دُّورِي ن إِڒْمَاونْ ن دّنْفِيڒَاثْ ؤُشَا أَذْ ث سَّارْسنْ خْ دْجُوحْ ن ثْكسِّيثْ.  
\v 11 أَذْ بزّْعنْ إِجّْ ن دُّورِي أَذحْمَانِي خْ ؤُعَالْطَارْ \add ن ڒبْخُورْ\add* ؤُشَا أَذْ ث ذْڒنْ \add عَاوذْ\add* س يِيجّْ ن دُّورِي ن إِڒْمَاونْ ن دّنْفِيڒَاثْ ؤُشَا أَذْ أَسْ ڭّنْ إِعُومَاذْ نّسْ \add إِ ثَاربُّوثْ\add*.  
\v 12 ؤُشَا أَذْ كْسِينْ مَارَّا ڒقْشُوعْ إِ ثْسخَّارْثْ إِ سّْخدّْمنْ ذِي زَّاوشْثْ إِقدّْسنْ ؤُشَا أَذْ ثنْ ڭّنْ ذڭْ إِجّْ ن دُّورِي أَذحْمَانِي ؤُشَا أَذْ ث ذْڒنْ س يِيجّْ ن دُّورِي ن إِڒْمَاونْ ن دّنْفِيڒَاثْ، \add خنِّي\add* أَذْ سَّارْسنْ أَيَا خْ دْجُوحْ ن ثْكسِّيثْ.  
\v 13 أَذْ كّْسنْ مِينْ إِقِّيمنْ ن ثَاذُونْثْ ن ؤُعَالْطَارْ ؤُشَا أَذْ خَاسْ بزّْعنْ إِشْثْ ن ثْجَارْثِيڒْثْ ثَارْجُووَانِيثْ.  
\v 14 أَذْ خَاسْ سَّارْسنْ مَارَّا ڒقْشُوعْ إِ سّْخذْمنْ إِ ثْسخَّارْثْ: ثِيمجْمَارِينْ، فُورْشَايَاثْ، إِغنْجَاينْ، طَّاوْيَاثْ إِ ؤُرُوشِّي ذ مَارَّا دُّوزَانْ ن ؤُعَالْطَارْ. ثِيوَّا نّسْ أَذْ بزّْعنْ إِجّْ ن دُّورِي ن إِڒْمَاونْ ن دّنْفِيڒَاثْ ؤُشَا أَذْ أَسْ ڭّنْ إِعُومَاذْ نّسْ \add إِ ثَاربُّوثْ\add*.   
\m
\v 15 خْمِي غَا إِكمّڒْ هَارُونْ ذ وَارَّاوْ نّسْ دُّورِي ن زَّاوشْثْ إِقدّْسنْ ذ مَارَّا ڒقْشُوعْ ن زَّاوشْثْ إِقدّْسنْ خْمِي غَا فسْينْ إِقِيضَانْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ، \add خنِّي\add* أَذْ د-أَسنْ وَارَّاوْ ن قُوهَاثْ حِيمَا أَذْ أَرْبُونْ \add مَارَّا\add*، مَاشَا إِتّْخصَّا وَارْ تّْحِيذِينْ مِينْ إِدْجَانْ إِقدّْسنْ، مِينْزِي مَاڒَا لَّا أَذْ مّْثنْ. مَانْ أَيَا ذ مِينْ إِتّْخصَّا أَذْ أَرْبُونْ وَارَّاوْ ن قَاهَاثْ ذِي ثْمسْڒَاشْثْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.   
\m
\v 16 أَلِيعَازَارْ، مِّيسْ ن ؤُكهَّانْ هَارُونْ، أَذْ إِطّفْ أَشْبَارْ خْ زّشْثْ إِ ثْفَاوْثْ ذ ڒبْخُورْ إِتّْفُوحنْ ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ن ڒبْذَا ذ زّشْثْ إِ وذْهَانْ، \add وَاهْ، هَارُونْ أَذْ إِطّفْ أَشْبَارْ\add* خْ ثْزذِّيغْثْ مَارَّا ؤُ خْ مَارَّا مِينْ ذَايسْ، ڒَا خْ مِينْ إِدْجَانْ ذِي زَّاوشْثْ إِقدّْسنْ ؤُڒَا خْ ڒقْشُوعْ نّسْ.“ \x ◘ \xo 4:‏16 \xt ؤُف. 29‏:‏40؛ 30‏:‏23، 24، 34، 35\x*   
\m
\v 17 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ هَارُونْ، إِنَّا:   
\m
\v 18 ”غَارْومْ أَذْ ثْقضْعمْ ثَاقْبِيتْشْ ن ڒَادْجَاثْ ن إِقَاهَاثِييّنْ زِي ڒْوسْطْ ن إِلَاوِييّنْ.  
\v 19 ڭّمْ كِيسنْ أَمُّو حِيمَا أَذْ دَّارنْ، وَارْ تّْمتِّينْ خْمِي د غَا قَارّْبنْ غَارْ وقْذَاسْ خْ ؤُقدَّاسْ: إِتّْخصَّا أَسْ إِ هَارُونْ ذ وَارَّاوْ نّسْ أَذْ د-أَذْفنْ ؤُشَا أَذْ ڭّنْ كُوڒْ أَرْيَازْ ذِي ڒْخذْمثْ نّسْ ؤُ ذِي دّْقڒْ إِ إِتّْخصَّا أَذْ يَارْبُو.  
\v 20 وَارْ إِعدّڒْ أَذْ أَذْفنْ مَاحنْذْ أَذْ ژَترنْ زَّاوشْثْ إِقدّْسنْ، مْغِيرْ إِ يِيشْثْ ن ورْمَاشْ ن وَابْڒِيونْ وَاهَا، \add مَاغَارْ خنِّي\add* أَذْ مّْثنْ.“   
\b  
\m  
\s1 ثَاسخَّارْثْ ن إِجَارْشُونِييّنْ  
\m
\v 21 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 22 ”\bd حْسبْ عَاوذْ أَيْثْ ن جَارْشُونْ\bd* أَزدْجِيفْ \add أَزدْجِيفْ\add*، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.  
\v 23 أَذْ ثنْ ثْحسْبذْ زِي ثْڒَاثِينْ ن إِسڭّْوُوسَا سنّجْ، أَڒْ خمْسِينْ ن إِسڭّْوُوسَا، كُوڒْ إِجّْ إِ غَا يَاذْفنْ غَارْ ڒْعسْكَارْ حِيمَا أَذْ يڭّْ ثَاسخَّارْثْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 24 ذ ثَا ذ \bd ثَاسخَّارْثْ ن ڒَادْجَاثْ ن جَارْشُونْ\bd* ذِي ثْمسْڒَاشْثْ ن ثْسخَّارْثْ ذ ثَاربُّوثْ.  
\v 25 أَذْ أَرْبُونْ ثِيجَارْثِيڒِينْ ن ثْزذِّيغْثْ ذ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ: ثَاسقَّافْثْ نّسْ ذ ثْسقَّافْثْ نّسْ ن إِڒْمَاونْ ن دّنْفِيڒَاثْ نِّي إِ غَا يِيڒِينْ ثِيوَّا نّسْ، ذ وَارْوَاقْ ن وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ،  
\v 26 ذ ڒِيزَارَاثْ ن ڒمْرَاحْ ذ أَرْوَاقْ إِ ثوَّارْثْ ن وَاذَافْ غَارْ ڒمْرَاحْ إِ د-إِنّْضنْ إِ ثْزذِّيغْثْ ذ ؤُعَالْطَارْ ذ \add مَارَّا\add* إِفِيڒَانْ نْسنْ ذ مَارَّا ڒقْشُوعْ \add إِ د-إِتَّاسنْ أَكْ-ذ\add* ثْسخَّارْثْ نْسنْ ؤُ مَارَّا مِينْ ذ أَسْ صنّْعنْ، \add ذ مَانْ أَيَا\add* أَذْ ثِيڒِي ڒْخذْمثْ نْسنْ.   
\m
\v 27 مَارَّا ڒْخذْمثْ ن أَيْثْ ن جَارْشُونْ ذِي ثْمسْڒَاشْثْ ن مَارَّا ثَاربُّوثْ ذ مَارَّا ثَاسخَّارْثْ نْسنْ، أَذْ ثِيڒِي عْلَاحْسَابْ ڒُومُورْ ن هَارُونْ ذ وَارَّاوْ نّسْ. إِتّْخصَّا أَومْ أَذْ ثنْ ثسّشْنمْ س \add ؤُ\add*حطُّو مَارَّا مِينْ إِتّْخصَّا أَذْ أَرْبُونْ.  
\v 28 ثَا ذ ثَاسخَّارْثْ ن ڒَادْجَاثْ ن أَيْثْ ن جَارْشُونْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. نِيثْنِي أَذْ كْسِينْ أَمْنُوسْ \add إِ ؤُيَا\add* سَاذُو ؤُفُوسْ ن إِثَامَارْ، مِّيسْ ن هَارُونْ، أَكهَّانْ.   
\b  
\m  
\s1 ثَاسخَّارْثْ ن أَيْثْ ن مَارَارِي  
\m
\v 29 أَذْ ثْحسْبذْ \bd أَيْثْ ن مَارَارِي\bd*، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ.  
\v 30 أَذْ ثنْ ثْحسْبذْ زِي ثْڒَاثِينْ ن إِسڭّْوُوسَا سنّجْ، أَڒْ خمْسِينْ ن إِسڭّْوُوسَا، مَارَّا ونِّي إِ غَا يَاذْفنْ غَارْ ڒْعسْكَارْ مَاحنْذْ أَذْ إِسخَّارْ ذِي ثْسخَّارْثْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 31 ذ ثَا ذ ثَاسْغَارْثْ نْسنْ ذِي ثْربُّوثْ غَارْ مَارَّا \bd ثَاسخَّارْثْ نْسنْ\bd* ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ: ثِيفڒْوِينْ ن ثْزذِّيغْثْ ذ ثْحنْيَا ن ؤُعَارّضْ ذ إِپِيلَارنْ نّسْ ذ ثْيَارْسَاوِينْ نّسْ،  
\v 32 ذ إِپِيلَارنْ ن ڒمْرَاحْ إِ ذ أَسْ د-إِنّْضنْ أَكْ-ذ ثْيَارْسَاوِينْ نْسنْ ذ ڒوْثَاذْ نْسنْ ذ إِسغْوَانْ نْسنْ، \add أَقَا ذ ثَا ذ ثَاسْغَارْثْ نْسنْ ذِي ثْربُّوثْ\add* ن مَارَّا ڒقْشُوعْ نْسنْ ؤُ ذِي مَارَّا ثَاسخَّارْثْ \add إِ د-إِتَّاسنْ أَكْ-ذ مَارَّا مَانْ أَيَا\add*. ڒقْشُوعْ إِ إِتّْخصَّا أَذْ ثنْ أَرْبُونْ، إِتّْخصَّا كنِّيوْ أَذْ ثنْ ثْزمّذْ س إِسْمَاونْ نْسنْ.  
\v 33 ذ ثَا ذ \bd ثَاسخَّارْثْ ن ڒَادْجَاثْ ن أَيْثْ ن مَارَارِي\bd* غَارْ مَارَّا ثَاسخَّارْثْ نْسنْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ سَاذُو ؤُفُوسْ ن إِثَامَارْ، مِّيسْ ن هَارُونْ، أَكهَّانْ.“   
\b  
\m  
\s1 إِمْسخَّارنْ ن إِلَاوِييّنْ  
\m
\v 34 مُوسَا ذ هَارُونْ ذ ڒْحُوكَّامْ ن ثْمسْمُونْثْ حسْبنْ \bd أَيْثْ ن قَاهَاثْ\bd*، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ ؤُ عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ،  
\v 35 زڭْ \add ونِّي غَارْ إِدْجَا\add* ثْڒَاثِينْ ن إِسڭّْوُوسَا سنّجْ، أَڒْ \add ونِّي غَارْ إِدْجَا\add* خمْسِينْ ن إِسڭّْوُوسَا، كُوڒْ إِجّْ إِ غَا يَاذْفنْ مَاحنْذْ أَذْ إِسخَّارْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 36 إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، ثُوغَا أَثنْ ذِي أَڒْفَاينْ ؤُ-سبْعَا-مْيَا ؤُ-خمْسِينْ.  
\v 37 إِنَا ذ إِنِّي إِتّْوَاحسْبنْ زِي ڒَادْجَاثْ ن إِقَاهَاثِييّنْ، مَارَّا وِي إِتّْسخَّارنْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، إِنِّي حسْبنْ مُوسَا ذ هَارُونْ خْ ڒُومُورْ ن سِيذِي سَاذُو ؤُفُوسْ ن مُوسَا.   
\b  
\m
\v 38 إِنِّي إِتّْوَاحسْبنْ زڭْ \bd أَيْثْ ن جَارْشُونْ\bd*، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ ؤُ عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ،  
\v 39 زڭْ \add ونِّي غَارْ إِدْجَا\add* ثْڒَاثِينْ ن إِسڭّْوُوسَا سنّجْ، أَڒْ \add ونِّي غَارْ إِدْجَا\add* خمْسِينْ ن إِسڭّْوُوسَا، كُوڒْ إِجّْ إِ غَا يَاذْفنْ مَاحنْذْ أَذْ إِسخَّارْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ،  
\v 40 أَقَا إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، ثُوغَا أَثنْ ذِي أَڒْفَاينْ ؤُ-ستَّا-مْيَا ؤُ-ثْڒَاثِينْ،  
\v 41 إِنَا ذ إِنِّي إِتّْوَاحسْبنْ ن ڒَادْجَاثْ ن أَيْثْ ن جَارْشُونْ، مَارَّا وِي إِتّْسخَّارنْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، إِنِّي حسْبنْ مُوسَا ذ هَارُونْ خْ ڒُومُورْ ن سِيذِي.   
\b  
\m
\v 42 إِنَا ذ إِنِّي إِتّْوَاحسْبنْ ن ڒَادْجَاثْ ن \bd أَيْثْ ن مَارَارِي\bd*، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ،  
\v 43 زڭْ \add ونِّي غَارْ إِدْجَا\add* ثْڒَاثِينْ ن إِسڭّْوُوسَا سنّجْ، أَڒْ \add ونِّي غَارْ إِدْجَا\add* خمْسِينْ ن إِسڭّْوُوسَا، كُوڒْ إِجّْ إِ غَا يَاذْفنْ ذِي ڒْعسْكَارْ مَاحنْذْ أَذْ إِسخَّارْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ،  
\v 44 أَقَا إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، ثُوغَا أَثنْ ذِي ثڒْثْ-أَڒَافْ ؤُ-مِيثَاينْ.  
\v 45 إِنَا ذ إِنِّي إِتّْوَاحسْبنْ ن ڒَادْجَاثْ ن مَارَارِي، إِنِّي حسْبنْ مُوسَا ذ هَارُونْ خْ ڒُومُورْ ن سِيذِي سَاذُو ؤُفُوسْ ن مُوسَا.   
\m
\v 46 مَارَّا إِنِّي إِتّْوَاحسْبنْ، إِنِّي حسْبنْ مُوسَا ذ هَارُونْ ذ ڒْحُوكَّامْ ن إِسْرَائِيل زڭْ إِلَاوِييّنْ، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ ؤُ عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ،  
\v 47 زڭْ \add ونِّي غَارْ إِدْجَا\add* ثْڒَاثِينْ ن إِسڭّْوُوسَا سنّجْ أَڒْ \add ونِّي غَارْ إِدْجَا\add* خمْسِينْ ن إِسڭّْوُوسَا، مَارَّا ونِّي إِ غَا يَاذْفنْ مَاحنْذْ أَذْ إِڭّْ ڒْخذْمثْ ن ثْسخَّارْثْ ؤُ ڒْخذْمثْ ن \add ثْربُّوثْ\add* ن دّْقُوڒَاثْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ،  
\v 48 أَقَا إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ ثُوغَا أَثنْ ذِي ثمْنْ-أَڒَافْ ؤُ-خمْسَا-مْيَا ؤُ-ثْمَانِينْ.  
\v 49 نِيثْنِي تّْوَاحسْبنْ خْ ڒُومُورْ ن سِيذِي سَاذُو ؤُفُوسْ ن مُوسَا، كُوڒْ أَرْيَازْ \add إِتّْوَاڒقّمْ\add* ذِي ثْسخَّارْثْ نّسْ ؤُ خْ دّْقڒْ نّسْ. نِيثْنِي تّْوَاحسْبنْ زَّايسْ أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي إِ مُوسَا.   
\b  
\b  
\m  
\c 5
\s1 إِزرْفَانْ نّغْنِي  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”ؤُمُورْ أَيْثْ ن إِسْرَائِيل أَذْ سُّوفّْغنْ مَارَّا أَيْثْ ن ڒْبَارْصْ زِي ڒْمَارْڭحْ ن ڒْعسْكَارْ، ؤُڒَا ذ مَارَّا إِنِّي غَارْ إِدْجَا ؤُسيّڒْ ذ مَارَّا إِنِّي إِتّْوَاسّْخمْجنْ زڭْ إِشْثْ ن ڒْخشْبثْ. \x ◘ \xo 5:‏2 \xt لَاوِي 13‏:‏3، 46؛ 15‏:‏2؛ 21‏:‏1 \x*  
\v 3 أَذْ ثنْ ثسُّوفّْغمْ، أَمْ يرْيَازنْ أَمْ ثمْغَارِينْ. كنِّيوْ أَذْ ثنْ ثسُّوفّْغمْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ حِيمَا وَارْ سّْخمَّاجنْ ڒمْرَاڭحْ نْسنْ مَانِي زدّْغغْ نشّْ ذِي ڒْوسْطْ نْسنْ.“   
\m
\v 4 ؤُشَا ڭِّينْ أَيْثْ ن إِسْرَائِيل أَمُّو. نِيثْنِي سُّوفّْغنْ ثنْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ. أَيْثْ ن إِسْرَائِيل ڭِّينْ أَمْ مَامّشْ إِ إِنَّا سِيذِي إِ مُوسَا.   
\b  
\m
\v 5 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 6 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل: ’مَاڒَا إِجّْ ن ورْيَازْ نِيغْ إِشْثْ ن ثمْغَارْثْ إِ إِڭِّينْ شَا ن دّنْبْ ن بْنَاذمْ إِ زِي إِغْذَارْ ذِي سِيذِي، \add خنِّي\add* أَذْ يِيڒِي ڒعْمَارْ نِّي ذ بُو-ؤُمَارْوَاسْ. \x ◘ \xo 5:‏6 \xt لَاوِي 5‏:‏21، 22\x*  
\v 7 أَذْ نعْمنْ خْ دّنْبْ نْسنْ إِ ڭِّينْ. نتَّا أَذْ إِخدْجصْ أَمَارْوَاسْ نّسْ مَارَّا ؤُ أَذْ أَسْ يَارْنِي إِشْثْ ن ثسْغَارْثْ ثخْمُوسشْثْ ؤُشَا أَذْ إِوْشْ أَيَا إِ ونِّي إِذوْڒنْ إِتُّورْسْ أَسْ نتَّا. \x ◘ \xo 5:‏7 \xt لَاوِي 5‏:‏24\x*   
\m
\v 8 \add مَاشَا\add* مَاڒَا وَارْ ذِينْ إِدْجِي ؤُمفْذِي إِ ورْيَازْ \add نِّي\add*، مَاحنْذْ أَذْ أَسْ إِخدْجصْ أَمَارْوَاسْ، \add خنِّي\add* أَذْ يِيڒِي ؤُمَارْوَاسْ، إِ إِتّْخصَّا أَذْ إِخدْجصْ إِ سِيذِي، إِ ؤُكهَّانْ، أَكْ-ذ ذْ إِشَارِّي ن وصْڒَاحْ إِ زَّايسْ ث غَا إِسّصْڒحْ. \f ◼ \fr 5:‏8 \ft \+bd ’أَمفْذِي ... إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  \x ◘ \xo 5:‏8 \xt لَاوِي 5‏:‏21‏-‏26\x*  
\v 9 كُوڒْ ثَاوْهِيبْثْ نِّي سّْڭعّْذنْ أَيْثْ ن إِسْرَائِيل ن ثوْهِيبِينْ إِقدّْسنْ نِّي د-إِتَّاوْينْ غَارْ ؤُكهَّانْ أَذْ ثِيڒِي نّسْ.  
\v 10 مَارَّا \add ثِيوْهِيبِينْ\add* إِقدّْسنْ ن شَا ن ورْيَازْ أَذْ إِڒِينْثْ إِ نتَّا، مِينْ مَا إِ غَا إِوْشْ إِجّْ ن ورْيَازْ إِ ؤُكهَّانْ، \add ذ مَانْ أَيَا\add* أَذْ يِيڒِي إِ نتَّا.‘ “ \x ◘ \xo 5:‏10 \xt لَاوِي 10‏:‏12\x*   
\b  
\m  
\s1 أَزرْفْ خْ ثُوسْمِي  
\m
\v 11 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 12 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ: ’مَاڒَا ثَامْغَارْثْ ن شَا ن ورْيَازْ ثفّغْ ؤُ ثغْذَارْ إِ-ث،  
\v 13 ؤُ شَا ن ورْيَازْ إِسّنْ إِ-ت، ؤُشَا مَانْ أَيَا إِنُّوفَارنْ إِ ثِيطَّاوِينْ ن ورْيَازْ نّسْ ؤُ نتَّاثْ ثسّْنُوفَّارْ إِ-ث ؤُشَا \add أَمُّو\add* ثسّخْمجْ إِخفْ نّسْ ؤُ وَارْ ذِينْ وِي خَاسْ غَا إِشهْذنْ ؤُ نتَّاثْ \add عمَّارْصْ\add* وَارْ ثتّْوَاطّفْ،  
\v 14 ؤُشَا \add خنِّي\add* يُوسَا-د خَاسْ بُوحْبڒْ ن ثُوسْمِي ؤُشَا يُوسمْ خْ ثمْغَارْثْ نّسْ ؤُمِي نتَّاثْ ثتّْوَاسّخْمجْ، نِيغْ يُوسَا-د خَاسْ بُوحْبڒْ ن ثُوسْمِي ؤُشَا يُوسمْ خْ ثمْغَارْثْ نّسْ ؤُمِي نتَّاثْ وَارْ ثتّْوَاسّخْمِيجْ شَا،  
\v 15 \add خنِّي\add* أَرْيَازْ أَذْ يَاوِي ثَامْغَارْثْ نّسْ غَارْ ؤُكهَّانْ ؤُشَا أَذْ يَاوِي ثَاوْهِيبْثْ نّسْ إِ نتَّاثْ، أَقَا-ت ذ ثَاعْشَارْثْ ن إِجّْ ن إِفَا ن وَارنْ ن إِمنْذِي. وَارْ خَاسْ إِفَارّغْ زّشْثْ نِيغْ أَذْ خَاسْ إِسَّارْسْ جَّاوِي، مِينْزِي أَقَا-ت ذ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذِي سِّيبّثْ ن ثُوسْمِي، إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِ ڒِيذَارثْ، \add ثنِّي\add* د غَا يَاوْينْ أَخَارّصْ ذِي ڒْمُوعْصِييّثْ.   
\m
\v 16 أَذْ ت-إِ-د-إِسّْقَارّبْ ؤُكهَّانْ ؤُشَا أَذْ ت إِسَّارْسْ زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 17 أَذْ إِكْسِي ؤُكهَّانْ أَمَانْ إِقدّْسنْ ذڭْ إِشْثْ ن ڒْقشْعثْ ن ثْڒَاخْثْ ؤُشَا أَذْ إِكْسِي \add شَا\add* زڭْ ؤُشَاڒْ إِ إِدْجَانْ ذِي ثمُّورْثْ ن ثْزذِّيغْثْ، أَذْ يڭّْ \add أَيَا\add* ذڭْ وَامَانْ.  
\v 18 \add خنِّي\add* أَذْ إِڭّْ ؤُكهَّانْ ثَامْغَارْثْ \add نِّي\add* زَّاثْ إِ وُوذمْ ن سِيذِي، أَذْ إِفكّْ \add أَشُوَّافْ ن\add* ؤُزدْجِيفْ ن ثمْغَارْثْ ؤُشَا أَذْ إِڭّْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِ ڒِيذَارثْ ذڭْ إِفَاسّنْ نّسْ، أَقَا ذ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ن ثُوسْمِي. أَكهَّانْ أَذْ إِطّفْ ذڭْ ؤُفُوسْ نّسْ أَمَانْ إِمرْزَاڭنْ نِّي د-إِتَّاوْينْ نّعْڒثْ.  
\v 19 أَكهَّانْ أَذْ ت يجّْ أَذْ ثجَّادْجْ ؤُشَا أَذْ يِينِي إِ ثمْغَارْثْ: مَاڒَا وَارْ كِيمْ إِطِّيصْ حذْ ؤُ وَارْ ثوْضِيذْ زڭْ ورْيَازْ نّمْ ذِي ثخْمُوجِي، أَقَا أَذْ ثِيڒِيذْ ثتّْوَاصْفِيذْ زڭْ وَامَانْ-أَ إِمرْزَاڭنْ إِنِّي د-إِتَّاوْينْ نّعْڒثْ.  
\v 20 \add مَاشَا ؤُشْثْ خَامْ،\add* مَاڒَا ثوْضِيذْ زڭْ ورْيَازْ نّمْ ؤُشَا ثتّْوَاسّْخمْجذْ ؤُشَا إِجّْ ن ورْيَازْ مْغِيرْ أَرْيَازْ نّمْ إِطّصْ أَكِيمْ!  
\v 21 \add خنِّي\add* أَذْ يجّْ ؤُكهَّانْ ثَامْغَارْثْ أَذْ ثجَّادْجْ ثَاجَادْجِيثْ ن نّعْڒثْ. أَذْ يِينِي ؤُكهَّانْ إِ ثمْغَارْثْ: سِيذِي أَذْ شمْ يَارّْ ذ \add إِجّْ ن ؤُمذْيَا\add* ن نّعْڒثْ\add -أَ\add* ذ ثْجَادْجِيثْ\add -أَ\add* ذِي ڒْوسْطْ ن ڒْڭنْسْ نّمْ، خْمِي غَا يجّْ سِيذِي أَذْ إِوْضَا ؤُمصَّاضْ نّمْ ؤُشَا أَذْ يَارّْ أَعذِّيسْ نّمْ يُوفّْ،  
\v 22 ؤُشَا أَمَانْ-أَ إِ د-إِتَّاوْينْ نّعْڒثْ أَذْ أَذْفنْ غَارْ وَاذَانْ نّمْ مَاحنْذْ أَذْ سُّوفّنْ أَعذِّيسْ نّمْ ؤُشَا أَذْ سّْغضْڒنْ أَمصَّاضْ نّمْ! ؤُشَا أَذْ ثِينِي ثمْغَارْثْ: أَمِينْ أَمِينْ!   
\m
\v 23 أَذْ يَارِي ؤُكهَّانْ نّْعَاڒِي-يَا خْ إِشْثْ ن ثوْرِيقْثْ إِتّْوَانّْضنْ ؤُشَا \add خنِّي\add* أَذْ \add ثنْثْ\add* إِمْحَا ذڭْ وَامَانْ إِمرْزَاڭنْ.  
\v 24 أَذْ إِوْشْ أَمَانْ إِمرْزَاڭنْ إِ د-إِتَّاوْينْ نّعْڒثْ إِ ثمْغَارْثْ ؤُ نتَّاثْ أَذْ ثْسُو أَڒَامِي أَمَانْ إِ د-إِتَّاوْينْ نّعْڒثْ أَذْ ذَايسْ أَذْفنْ ذَاخڒْ ؤُشَا أَذْ ذوْڒنْ ذ إِمرْزَاڭنْ.  
\v 25 أَكهَّانْ أَذْ إِكْسِي ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ن ثُوسْمِي زڭْ ؤُفُوسْ ن ثمْغَارْثْ ؤُشَا أَذْ إِسّنْهزّْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَا أَذْ ت-إِ-د إِسّْقَارّبْ غَارْ ؤُعَالْطَارْ.  
\v 26 أَذْ إِكْسِي ؤُكهَّانْ إِجّْ ن وُورُو زِي ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*، أَقَا-ت ذ ثَاوْهِيبْثْ نْ ڒِيذَارثْ، ؤُشَا أَذْ إِسّْبخَّارْ أَيَا خْ ؤُعَالْطَارْ ؤُشَا خنِّي أَذْ إِوْشْ أَمَانْ إِ ثمْغَارْثْ أَذْ ثْسُو.  
\v 27 مَاڒَا إِوْشَا أَسْ أَمَانْ أَذْ ثْسُو، \add خنِّي\add*، مَاڒَا ثتّْوَاسّخْمجْ ؤُشَا نتَّاثْ ثغْذَارْ أَرْيَازْ نّسْ، أَمَانْ إِ د-إِتَّاوْينْ نّعْڒثْ أَذْ ذَايسْ ذوْڒنْ ذ إِمرْزَاڭنْ ؤُشَا أَعذِّيسْ نّسْ أَذْ يُوفّْ ؤُشَا أَمصَّاضْ نّسْ أَذْ إِتّْوَاغْضڒْ ؤُ ثَامْغَارْثْ أَذْ ثذْوڒْ ذ نّعْڒثْ ذِي ڒْوسْطْ ن ڒْڭنْسْ نّسْ.  
\v 28 \add مَاشَا\add* مَاڒَا وَارْ ثخْمِيجْ شَا ثمْغَارْثْ، \add مَاشَا\add* ثزْذڭْ، \add خنِّي\add* أَذْ ثِيڒِي وَارْ خَاسْ شَا، أَذْ ثِيڒِي ثتَّارُو.‘ “   
\m
\v 29 \bd وَا ذ أَزرْفْ زِي جِّيهثْ ن ثُوسْمِي\bd*، خْمِي ثوْضَا إِشْثْ ن ثمْغَارْثْ زڭْ ورْيَازْ نّسْ ؤُشَا ثتّْوَاسّخْمجْ  
\v 30 نِيغْ خْمِي د يُوسَا بُوحْبڒْ ن ثُوسْمِي خْ ورْيَازْ ؤُشَا نتَّا يُوسمْ خْ ثمْغَارْثْ نّسْ. \add خنِّي\add* أَذْ يَارَّا ثَامْغَارْثْ أَذْ ثْبدّْ زَّاثْ إِ وُوذمْ ن سِيذِي ؤُ أَكهَّانْ أَذْ أَسْ إِكمّڒْ مَارَّا أَزرْفْ-أَ وَا.  
\v 31 أَرْيَازْ أَذْ يِيڒِي ذ أَمزْذَاڭْ زِي سِّيبّثْ ن ڒْمُوعْصِييّثْ، ثَامْغَارْثْ-أَ أَذْ ثَارْبُو ڒْمُوعْصِييّثْ نّسْ.   
\b  
\b  
\m  
\c 6
\s1 لْوَاعْذْ ن ثمْرِيسْثْ ن وعْزَاڒْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ: ’مَاڒَا إِجّْ ن ورْيَازْ نِيغْ إِشْثْ ن ثمْغَارْثْ إِ إِوجْذنْ مَاحنْذْ أَذْ إِوْشْ أَوَاڒْ ن تَّاجْ \add ن ؤُشُوَّافْ ن لْوَاعْذْ\add*، مَاحنْذْ أَذْ إِعْزڒْ إِخفْ نّسْ \add س تَّاجْ نِّي\add* إِ سِيذِي،  
\v 3 \add خنِّي\add* أَذْ إِڭّْوجْ خْ بِينُو ذ شّْرَابْ. وَارْ إِسسّْ ڒْخدْجْ زِي بِينُو نِيغْ ڒْخدْجْ زِي شّْرَابْ ؤُ وَارْ إِسسّْ أَمَانْ ن ؤُضِيڒْ، ؤُ وَارْ إِتّتّْ زڭْ ؤُضِيڒْ أَزيْزَا نِيغْ زڭْ ؤُضِيڒْ يُوژْغنْ. \f ◼ \fr 6:‏3 \ft \+bd ’أَمَانْ ن ؤُضِيڒْ‘\+bd* - نِيغْ: ’أَژمِّي ن ؤُضِيڒْ‘.\f*  
\v 4 مَارَّا ؤُسَّانْ ن تَّاجْ نّسْ \add ن وعْزَاڒْ\add* وَارْ إِتّتّْ شَا مِينْ د-إِفّْغنْ زِي ثْزَايَارْثْ، زڭْ ؤُعقَّا \add نّسْ\add* أَڒْ ثَاقْشُورْثْ \add نّسْ\add*.‘ “   
\m
\v 5 ”مَارَّا ؤُسَّانْ ن وَاوَاڒْ إِ د تَّاسنْ أَكْ-ذ تَّاجْ نّسْ \add ن وعْزَاڒْ\add* وَارْ إِتّكّْ ڒْمُوسْ خْ ؤُزدْجِيفْ نّسْ أَڒْ غَا كمّْڒنْ وُوسَّانْ نِّي إِعْزڒْ إِ سِيذِي ؤُشَا أَذْ يِيڒِي إِقدّسْ ؤُشَا أَذْ يجّْ إِعيَّاشنْ ن ؤُشُوَّافْ ن ؤُزدْجِيفْ نّسْ أَذْ مْغَارنْ. \x ◘ \xo 6:‏5 \xt ڒقض. 13‏:‏5؛ 1 صم. 1‏:‏11\x*  
\v 6 مَارَّا ؤُسَّانْ إِ إِسّْحُوزّْ إِ سِيذِي، وَارْ د-إِتّْقَارِّيبْ شَا غَارْ ڒعْمَارْ ن إِجّْ ن ؤُمتِّينْ. \f ◼ \fr 6:‏6 \ft \+bd ’أَرِّيمثْ‘\+bd* - س ثْعِيبْرَانِيثْ ’غَارْ ڒعْمَارْ‘.\f*  
\v 7 وَارْ إِسّْخمِّيجْ إِخفْ نّسْ خْ بَابَاسْ نِيغْ خْ يمَّاسْ نِيغْ خْ ؤُمَاسْ نِيغْ خْ ؤُتْشْمَاسْ مَاڒَا ڭُّورنْ أَذْ مّْثنْ، مِينْزِي تَّاجْ \add ن وعْزَاڒْ\add* ن أَربِّي نّسْ أَقَا-ت خْ ؤُزدْجِيفْ نّسْ.“   
\m
\v 8 ”مَارَّا ؤُسَّانْ ن تَّاجْ نّسْ \add ن وعْزَاڒْ\add* أَذْ يِيڒِي إِقدّسْ إِ سِيذِي.  
\v 9 مَاڒَا ونِّي إِتّْمتَّانْ أَذْ إِمّثْ ذغْيَا ذڭْ ورْمَاشْ ن وَابْڒِيونْ ؤُشَا إِسّخْمجْ أَزدْجِيفْ \add نّسْ\add* س تَّاجْ نّسْ \add ن وعْزَاڒْ\add*، \add خنِّي\add* أَذْ إِحفّْ أَزدْجِيفْ نّسْ ذڭْ وَاسّْ ن ؤُسِيزْذڭْ نّسْ. ذڭْ وَاسّْ وِيسّْ سبْعَا إِتّْخصَّا أَذْ ث إِحفّْ.  
\v 10 ذڭْ وَاسّْ وِيسّْ ثْمنْيَا أَذْ يَاوِي ثْنَاينْ ن ثجْلِيلِّيحِينْ نِيغْ ثْنَاينْ ن إِضْبِيرنْ غَارْ ؤُكهَّانْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 11 أَكهَّانْ أَذْ إِسّوْجذْ إِشْثْ ذ ثَاغَارْصْثْ ن دّنْبْ ذ إِشْثْ ذ ثَاغَارْصْثْ ن وشْمَاضْ ؤُشَا أَذْ ث إِسّصْڒحْ، مِينْزِي نتَّا أَقَا إِخْضَا ذِي سِّيبّثْ ن ؤُمتِّينْ. نتَّا أَذْ إِسّْقدّسْ أَزدْجِيفْ نّسْ \add عَاوذْ\add* ذڭْ وَاسّْ نِّي \f ◼ \fr 6:‏11 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  
\v 12 ؤُشَا \add ثْوَاڒَا نّغْنِي\add* أَذْ إِنيّشْ نتَّا ؤُسَّانْ ن تَّاجْ نّسْ \add ن وعْزَاڒْ\add* إِ سِيذِي ؤُشَا أَذْ إِقدّمْ إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ ذ ثَاغَارْصْثْ ن ؤُمَارْوَاسْ. ؤُسَّانْ إِعْذُونْ أَذْ إِڒِينْ وْضَانْ مِينْزِي أَقَا ثتّْوَاسّخْمجْ تَّاجْ نّسْ \add ن وعْزَاڒْ\add*.“   
\m
\v 13 ”وَا ذ أَزرْفْ ن ونِّي يَاربُّونْ تَّاجْ \add ن وعْزَاڒْ\add*: ذڭْ وَاسّْ مِينْ ذِي تّْوَاكمّْڒنْ وُوسَّانْ ن تَّاجْ نّسْ \add ن وعْزَاڒْ\add*، أَذْ ث أَوْينْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 14 \add خنِّي\add* أَذْ د-إِسّْقَارّبْ ثَاوْهِيبْثْ نّسْ غَارْ سِيذِي، إِجّْ ن إِزْمَارْ إِشْنَانْ قَاعْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ ذ إِشْثْ ن ثخْسِي إِشْنَانْ قَاعْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن دّنْبْ ذ إِجّْ ن إِشَارِّي إِشْنَانْ قَاعْ أَمْ ثْغَارْصْثْ ن ڒهْنَا  
\v 15 ذ إِشْثْ ن ثْسُودْجثْ أَكْ-ذ وغْرُومْ بْڒَا أَنْثُونْ ذ ڒمْسمْنَاثْ ن وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ ذ ثڒْفَافْ ن وغْرُومْ بْڒَا أَنْثُونْ تّْوَاذهْننْثْ س زّشْثْ ؤُڒَا ذ ثَاوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نّسْ ن ؤُسيّبْ.“   
\m
\v 16 ”أَكهَّانْ أَذْ يَاوِي \add مَانْ أَيَا\add* زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَا أَذْ إِسّوْجذْ ثَاغَارْصْثْ نّسْ ن دّنْبْ ذ ثْغَارْصْثْ نّسْ ن وشْمَاضْ.  
\v 17 أَذْ إِسّوْجذْ إِشَارِّي أَمْ ثْغَارْصْثْ ن ڒهْنَا إِ سِيذِي ؤُڒَا ذ ثَاسُودْجثْ أَكْ-ذ ثشْنِيفِينْ بْڒَا أَنْثُونْ ؤُشَا أَكهَّانْ أَذْ إِسّوْجذْ \add عَاوذْ\add* ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* نّسْ ذ ثوْهِيبِينْ ن ؤُسيّبْ نّسْ.“   
\m
\v 18 ”\add خنِّي\add* ونِّي يَاربُّونْ تَّاجْ \add ن وعْزَاڒْ\add* أَذْ إِحفّْ أَزدْجِيفْ ن تَّاجْ نّسْ \add ن وعْزَاڒْ\add* غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا أَذْ إِكْسِي أَشُوَّافْ ن ؤُزدْجِيفْ ن تَّاجْ نّسْ \add ن وعْزَاڒْ\add* ؤُشَا أَذْ يڭّْ أَيَا خْ ثْمسِّي \add إِ إِدْجَانْ\add* سَاذُو ثْغَارْصْثْ ن ڒهْنَا. \x ◘ \xo 6:‏18 \xt ڒخ. 21‏:‏24\x*  
\v 19 \add خنِّي\add* أَذْ إِكْسِي ؤُكهَّانْ ثَامصَّاضْثْ ن زَّاثْ ينْڭّْوَانْ ن إِشَارِّي ذ إِشْثْ ن ثمْسمّنْثْ بْڒَا أَنْثُونْ زِي ثْسُودْجثْ ذ إِشْثْ ن ثڒْففْثْ بْڒَا أَنْثُونْ ؤُشَا أَذْ ثنْثْ إِسَّارْسْ خْ إِفَاسّنْ ن ونِّي يَاربُّونْ تَّاجْ \add ن وعْزَاڒْ\add* أَوَارْنِي مَا إِحفّْ تَّاجْ نّسْ \add ن وعْزَاڒْ\add*.  
\v 20 أَكهَّانْ أَذْ ثنْثْ إِسّنْهزّْ زِي سَّا غَارْ ذَا زَّاثْ إِ وُوذمْ ن سِيذِي. أَقَا-ت ذ إِشْثْ ن ثْمسْڒَاشْثْ ثَامْقدَّاسْثْ إِ ؤُكهَّانْ، أَكْ-ذ إِذْمَارنْ ن ونْهزِّي ؤُ أَكْ-ذ ؤُشكْرُوذْ ن ثوْهِيبْثْ إِتّْوَاسّْڭعّْذنْ. أَوَارْنِي أَيَا إِعدّڒْ إِ ونِّي يَاربُّونْ تَّاجْ \add ن وعْزَاڒْ\add* مَاحنْذْ أَذْ إِسُو بِينُو.“ \x ◘ \xo 6:‏20 \xt ؤُف. 29‏:‏27\x*   
\m
\v 21 ”وَا ذ أَزرْفْ ن ونِّي يَاربُّونْ تَّاجْ \add ن وعْزَاڒْ\add*، ونِّي ثُوغَا إِوَاعْذنْ إِ سِيذِي ثَاوْهِيبْثْ نّسْ ذِي سِّيبّثْ ن تَّاجْ \add ن وعْزَاڒْ\add* نّسْ، بَارَّا مِينْ إِزمَّارْ ؤُفُوسْ نّسْ \add عَاذْ\add* أَذْ إِسِّيوضْ. إِتّْخصَّا أَسْ أَذْ يڭّْ عْلَاحْسَابْ أَوَاڒْ إِ إِوْشِينْ، \add عْلَاحْسَابْ\add* أَزرْفْ ن تَّاجْ \add ن وعْزَاڒْ\add* نّسْ.“   
\b  
\m  
\s1 لْبَارَاكَا س ؤُفُوسْ ن إِكهَّاننْ  
\m
\v 22 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 23 ”سِيوڒْ أَكْ-ذ هَارُونْ ذ وَارَّاوْ نّسْ ؤُشَا إِنِي: ’أَمُّو أَذْ ثْبَارْكمْ أَيْثْ ن إِسْرَائِيل ؤُشَا أَذْ أَسنْ ثِينِيمْ:   
\b  
\m
\v 24 \qt سِيذِي أَذْ أَشْ إِبَاركْ ؤُشَا أَذْ شكْ إِحْضَا!\qt*   
\m
\v 25 \qt سِيذِي أَذْ يَارّْ ؤُذمْ نّسْ\qt*  
\m \qt أَذْ خَاكْ يڭّْ ثْفَاوْثْ ؤُشَا أَذْ خَاكْ إِحِينّْ.\qt*   
\m
\v 26 \qt سِيذِي أَذْ غَاركْ د-إِنّقْڒبْ ؤُذمْ نّسْ\qt*  
\m \qt ؤُشَا أَذْ أَشْ إِوْشْ ڒهْنَا!‘\qt*   
\b  
\m
\v 27 أَذْ سِّيوْضنْ إِسمْ إِنُو خْ أَيْثْ ن إِسْرَائِيل ؤُ نشّْ أَذْ ثنْ بَارْكغْ.‘ “   
\b  
\b  
\m  
\c 7
\s1 ثِيوْهِيبِينْ ن إِزدْجِيفنْ ن أَيْثْ ن إِسْرَائِيل  
\m
\v 1 إِمْسَارْ ذڭْ وَاسّْ مِينْ ذِي إِكمّڒْ مُوسَا أَسْبذِّي ن ثْزذِّيغْثْ، إِذْهنْ ؤُ إِسّْقدّسْ إِ-ت أَكْ-ذ ڒقْشُوعْ نّسْ ؤُڒَا ذ مَارَّا أَعَالْطَارْ أَكْ-ذ ڒقْشُوعْ نّسْ. أَقَا إِذْهنْ إِ-ثنْ ؤُشَا إِسّْقدّسْ إِ-ثنْ. \x ◘ \xo 7:‏1 \xt ؤُف. 40‏:‏18\x*  
\v 2 \add خنِّي\add* قَارّْبنْ-د ڒْحُوكَّامْ ن إِسْرَائِيل، إِزدْجِيفنْ ن ثُوذْرِينْ ن ڒجْذُوذْ نْسنْ. نِيثْنِي ذ ڒْحُوكَّامْ ن ثْقبَّاڒْ، نِيثْنِي ثُوغَا خْ يِينِّي إِتّْوَاحسْبنْ.  
\v 3 نِيثْنِي إِوْينْ-د ثَاوْهِيبْثْ نْسنْ زَّاثْ إِ وُوذمْ ن سِيذِي: ستَّا ن إِكَارُّوثنْ أَكْ-ذ ثْسقِّيفْثْ ذ ثنْعَاشْ ن إِفُونَاسنْ، أَقَا ذ إِجّْ ن ؤُكَارُّو إِ ثْنَاينْ ن ڒْحُوكَّامْ ذ إِجّْ ن ؤُفُونَاسْ إِ كُوڒْ إِجّْ \add ن ڒْحَاكمْ\add* ؤُشَا إِوْينْ ثنْ زَّاثْ إِ وُوذمْ ن ثْزذِّيغْثْ.   
\m
\v 4 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 5 ”كْسِي أَيَا زَّايْسنْ، حِيمَا أَذْ إِڒِينْ إِ ڒْخذْمثْ ن ثْسخَّارْثْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. إِتّْخصَّا أَذْ ثنْ ثوْشذْ إِ إِلَاوِييّنْ، \add إِ كُوڒْ أَرْيَازْ\add* أَمْ مَامّشْ د-إِتَّاسْ أَكْ-ذ ثْسخَّارْثْ نّسْ.“  
\v 6 \bd ؤُشَا مُوسَا إِطّفْ إِكَارُّوثنْ ذ إِفُونَاسنْ ؤُشَا إِوْشَا إِ-ثنْ إِ إِلَاوِييّنْ.\bd*  
\v 7 ثْنَاينْ ن إِكَارُّوثنْ ذ أَربْعَا ن إِفُونَاسنْ إِ إِوْشَا \bd إِ أَيْثْ ن جَارْشُونْ\bd*، أَمْ مَامّشْ د-إِتَّاسْ أَكْ-ذ ثْسخَّارْثْ نْسنْ،  
\v 8 ؤُ \bd إِ أَيْثْ ن مَارَارِي\bd* إِوْشَا أَسنْ أَربْعَا ن إِكَارُّوثنْ ذ ثْمنْيَا ن إِفُونَاسنْ، أَمْ مَامّشْ د-إِتَّاسْ أَكْ-ذ ثْسخَّارْثْ نْسنْ سَاذُو ؤُفُوسْ ن إِثَامَارْ، مِّيسْ ن ؤُكهَّانْ هَارُونْ.  
\v 9 \bd إِ أَيْثْ ن قَاهَاثْ\bd* وَارْ ذ أَسنْ إِوْشِي وَالُو، مِينْزِي ثُوغَا خَاسنْ ثَاسخَّارْثْ ن زَّاوشْثْ إِقدّْسنْ، نِيثْنِي أَرْبُونْ \add زَّاوشْثْ\add* خْ ثْغَارْوَاضْ \add نْسنْ\add*.   
\b  
\m
\v 10 \add خنِّي\add* قَارّْبنْ-د ڒْحُوكَّامْ أَكْ-ذ ثوْهِيبْثْ إِ ؤُذشّنْ ن ؤُعَالْطَارْ ذڭْ وَاسّْ مِينْ ذِي إِتّْوَاذْهنْ \add ؤُعَالْطَارْ\add*. إِوْينْ ڒْحُوكَّامْ ثِيوْهِيبِينْ نْسنْ زَّاثْ إِ وُوذمْ ن ؤُعَالْطَارْ.  
\v 11 إِنَّا سِيذِي إِ مُوسَا: ”إِجّْ ن ڒْحَاكمْ ذڭْ \add إِجّْ ن\add* وَاسّْ، \add خنِّي عَاوذْ\add* إِجّْ ن ڒْحَاكمْ ذڭْ وَاسّْ \add أَوَارْنِي أَسْ\add*، \add أَمُّو\add* إِ غَا قدّْمنْ نِيثْنِي ثِيوْهِيبِينْ نْسنْ إِ ؤُذشّنْ ن ؤُعَالْطَارْ.“   
\m
\v 12 \bd ذڭْ وَاسّْ أَمزْوَارُو\bd* إِقدّمْ نَاحْشُونْ، مِّيسْ ن عَامِّينَاذَابْ، زِي ثقْبِيتْشْ ن \bd يَاهُوذَا\bd*، ثَاوْهِيبْثْ نّسْ.  
\v 13 ثُوغَا-ت ثَاوْهِيبْثْ نّسْ: إِجّنْ طّبْصِي ن نُّوقَارْثْ ن مْيَا ؤُ-ثْڒَاثِينْ شِيقْلُو \add ن دّْقڒْ\add*، ذ إِشْثنْ طَّاوْيَا إِ ؤُرُوشِّي ن نُّوقَارْثْ ن سبْعِينْ شِيقْلُو، عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. ثُوغَا-ثنْ س ثْنَاينْ شُّورنْ س وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.  
\v 14 \add خنِّي\add* إِشْثْ ن ثْغنْجَاشْثْ ن وُورغْ نعشْرَا \add شِيقْلُو\add* ثشُّورْ س ڒبْخُورْ،  
\v 15 إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ثْفُونَاسْثْ - إِجّْ ن إِشَارِّي، إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ،  
\v 16 إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ إِ ثْغَارْصْثْ ن دّنْبْ  
\v 17 ؤُ إِ ثْغَارْصْثْ ن ڒهْنَا: ثْنَاينْ ن إِفُونَاسنْ ذ خمْسَا ن إِشَارِّييّنْ ذ خمْسَا ن إِغَايْضنْ ذ خمْسَا ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. أَقَا ثَا ذ ثَاوْهِيبْثْ ن نَاحْشُونْ، مِّيسْ ن عَامِّينَاذَابْ.   
\m
\v 18 \bd ذڭْ وَاسّْ وِيسّْ ثْنَاينْ\bd* إِقدّمْ نَاثَانَايِيلْ، مِّيسْ ن صُوغَارْ، ونِّي ذ ڒْحَاكمْ ن \bd إِسَّاكَارْ\bd*، ثَاوْهِيبْثْ نّسْ.  
\v 19 ثُوغَا-ت ثَاوْهِيبْثْ نّسْ: إِجّنْ طّبْصِي ن نُّوقَارْثْ ن مْيَا ؤُ-ثْڒَاثِينْ شِيقْلُو \add ن دّْقڒْ\add*، ذ إِشْثنْ طَّاوْيَا إِ ؤُرُوشِّي ن نُّوقَارْثْ ن سبْعِينْ شِيقْلُو، عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. ثُوغَا-ثنْ س ثْنَاينْ شُّورنْ س وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.  
\v 20 \add خنِّي\add* إِشْثْ ن ثْغنْجَاشْثْ ن وُورغْ نعشْرَا \add شِيقْلُو\add* ثشُّورْ س ڒبْخُورْ،  
\v 21 إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ثْفُونَاسْثْ - إِجّْ ن إِشَارِّي ذ إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ،  
\v 22 إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ إِ ثْغَارْصْثْ ن دّنْبْ  
\v 23 ؤُ إِ ثْغَارْصْثْ ن ڒهْنَا: ثْنَاينْ ن إِفُونَاسنْ، خمْسَا ن إِشَارِّييّنْ، خمْسَا ن إِغَايْضنْ ذ خمْسَا ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. أَقَا ثَا ذ ثَاوْهِيبْثْ ن نَاثَانَايِيلْ، مِّيسْ ن صُوغَارْ.   
\m
\v 24 \bd ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا\bd* إِقدّمْ ڒْحَاكمْ ن أَيْثْ ن \bd زابُولُونْ\bd*، إِلِييَابْ، مِّيسْ ن حِيلُونْ، ثَاوْهِيبْثْ نّسْ.  
\v 25 ثُوغَا-ت ثَاوْهِيبْثْ نّسْ: إِجّنْ طّبْصِي ن نُّوقَارْثْ ن مْيَا ؤُ-ثْڒَاثِينْ شِيقْلُو \add ن دّْقڒْ\add*، ذ إِشْثنْ طَّاوْيَا إِ ؤُرُوشِّي ن نُّوقَارْثْ ن سبْعِينْ شِيقْلُو، عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. ثُوغَا-ثنْ س ثْنَاينْ شُّورنْ س وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.  
\v 26 \add خنِّي\add* إِشْثْ ن ثْغنْجَاشْثْ ن وُورغْ نعشْرَا \add شِيقْلُو\add* ثشُّورْ س ڒبْخُورْ،  
\v 27 إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ثْفُونَاسْثْ - إِجّْ ن إِشَارِّي ذ إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ،  
\v 28 إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ إِ ثْغَارْصْثْ ن دّنْبْ  
\v 29 ؤُ إِ ثْغَارْصْثْ ن ڒهْنَا: ثْنَاينْ ن إِفُونَاسنْ، خمْسَا ن إِشَارِّييّنْ، خمْسَا ن إِغَايْضنْ ذ خمْسَا ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. أَقَا ثَا ذ ثَاوْهِيبْثْ ن إِلِييَابْ، مِّيسْ ن حِيلُونْ.   
\m
\v 30 \bd ذڭْ وَاسّْ وِيسّْ أَربْعَا\bd* إِقدّمْ ڒْحَاكمْ ن أَيْثْ ن \bd رُوبِينْ\bd*، أَلِيصُورْ، مِّيسْ ن شَاذَايُّورْ، ثَاوْهِيبْثْ نّسْ.  
\v 31 ثُوغَا-ت ثَاوْهِيبْثْ نّسْ: إِجّنْ طّبْصِي ن نُّوقَارْثْ ن مْيَا ؤُ-ثْڒَاثِينْ شِيقْلُو \add ن دّْقڒْ\add*، ذ إِشْثنْ طَّاوْيَا إِ ؤُرُوشِّي ن نُّوقَارْثْ ن سبْعِينْ شِيقْلُو، عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. ثُوغَا-ثنْ س ثْنَاينْ شُّورنْ س وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.  
\v 32 \add خنِّي\add* إِشْثْ ن ثْغنْجَاشْثْ ن وُورغْ نعشْرَا \add شِيقْلُو\add* ثشُّورْ س ڒبْخُورْ،  
\v 33 إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ثْفُونَاسْثْ - إِجّْ ن إِشَارِّي ذ إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ،  
\v 34 إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ إِ ثْغَارْصْثْ ن دّنْبْ  
\v 35 ؤُ إِ ثْغَارْصْثْ ن ڒهْنَا: ثْنَاينْ ن إِفُونَاسنْ، خمْسَا ن إِشَارِّييّنْ، خمْسَا ن إِغَايْضنْ ذ خمْسَا ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. أَقَا ثَا ذ ثَاوْهِيبْثْ ن أَلِيصُورْ، مِّيسْ ن شَاذَايُّورْ.   
\m
\v 36 \bd ذڭْ وَاسّْ وِيسّْ خمْسَا\bd* إِقدّمْ ڒْحَاكمْ ن أَيْثْ ن \bd شِيمْعُونْ\bd*، شَالُومِييِيلْ، مِّيسْ ن صُورِيشَادَّايْ، ثَاوْهِيبْثْ نّسْ.  
\v 37 ثُوغَا-ت ثَاوْهِيبْثْ نّسْ: إِجّنْ طّبْصِي ن نُّوقَارْثْ ن مْيَا ؤُ-ثْڒَاثِينْ شِيقْلُو \add ن دّْقڒْ\add*، ذ إِشْثنْ طَّاوْيَا إِ ؤُرُوشِّي ن نُّوقَارْثْ ن سبْعِينْ شِيقْلُو، عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. ثُوغَا-ثنْ س ثْنَاينْ شُّورنْ س وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.  
\v 38 \add خنِّي\add* إِشْثْ ن ثْغنْجَاشْثْ ن وُورغْ نعشْرَا \add شِيقْلُو\add* ثشُّورْ س ڒبْخُورْ،  
\v 39 إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ثْفُونَاسْثْ - إِجّْ ن إِشَارِّي ذ إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ،  
\v 40 إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ إِ ثْغَارْصْثْ ن دّنْبْ  
\v 41 ؤُ إِ ثْغَارْصْثْ ن ڒهْنَا: ثْنَاينْ ن إِفُونَاسنْ، خمْسَا ن إِشَارِّييّنْ، خمْسَا ن إِغَايْضنْ ذ خمْسَا ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. أَقَا ثَا ذ ثَاوْهِيبْثْ ن شَالُومِييِيلْ، مِّيسْ ن صُورِيشَادَّايْ.   
\m
\v 42 \bd ذڭْ وَاسّْ وِيسّْ ستَّا\bd* إِقدّمْ ڒْحَاكمْ ن أَيْثْ ن \bd جَاذْ\bd*، أَلِييَاسَافْ، مِّيسْ ن ذَاعُويِيلْ، ثَاوْهِيبْثْ نّسْ.  
\v 43 ثُوغَا-ت ثَاوْهِيبْثْ نّسْ: إِجّنْ طّبْصِي ن نُّوقَارْثْ ن مْيَا ؤُ-ثْڒَاثِينْ شِيقْلُو \add ن دّْقڒْ\add*، ذ إِشْثنْ طَّاوْيَا إِ ؤُرُوشِّي ن نُّوقَارْثْ ن سبْعِينْ شِيقْلُو، عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. ثُوغَا-ثنْ س ثْنَاينْ شُّورنْ س وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.  
\v 44 \add خنِّي\add* إِشْثْ ن ثْغنْجَاشْثْ ن وُورغْ نعشْرَا \add شِيقْلُو\add* ثشُّورْ س ڒبْخُورْ،  
\v 45 إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ثْفُونَاسْثْ - إِجّْ ن إِشَارِّي ذ إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ،  
\v 46 إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ إِ ثْغَارْصْثْ ن دّنْبْ  
\v 47 ؤُ إِ ثْغَارْصْثْ ن ڒهْنَا: ثْنَاينْ ن إِفُونَاسنْ، خمْسَا ن إِشَارِّييّنْ، خمْسَا ن إِغَايْضنْ ذ خمْسَا ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. أَقَا ثَا ذ ثَاوْهِيبْثْ ن أَلِييَاسَافْ، مِّيسْ ن ذَاعُويِيلْ.   
\m
\v 48 \bd ذڭْ وَاسّْ وِيسّْ سبْعَا\bd* إِقدّمْ ڒْحَاكمْ ن أَيْثْ ن \bd إِفْرَايِيمْ\bd*، إِلِيشَامَاعْ، مِّيسْ ن عَامِّيهُوذْ، ثَاوْهِيبْثْ نّسْ.  
\v 49 ثُوغَا-ت ثَاوْهِيبْثْ نّسْ: إِجّنْ طّبْصِي ن نُّوقَارْثْ ن مْيَا ؤُ-ثْڒَاثِينْ شِيقْلُو \add ن دّْقڒْ\add*، ذ إِشْثنْ طَّاوْيَا إِ ؤُرُوشِّي ن نُّوقَارْثْ ن سبْعِينْ شِيقْلُو، عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. ثُوغَا-ثنْ س ثْنَاينْ شُّورنْ س وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.  
\v 50 \add خنِّي\add* إِشْثْ ن ثْغنْجَاشْثْ ن وُورغْ نعشْرَا \add شِيقْلُو\add* ثشُّورْ س ڒبْخُورْ،  
\v 51 إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ثْفُونَاسْثْ - إِجّْ ن إِشَارِّي ذ إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ،  
\v 52 إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ إِ ثْغَارْصْثْ ن دّنْبْ  
\v 53 ؤُ إِ ثْغَارْصْثْ ن ڒهْنَا: ثْنَاينْ ن إِفُونَاسنْ، خمْسَا ن إِشَارِّييّنْ، خمْسَا ن إِغَايْضنْ ذ خمْسَا ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. أَقَا ثَا ذ ثَاوْهِيبْثْ ن إِلِيشَامَاعْ، مِّيسْ ن عَامِّيهُوذْ.   
\m
\v 54 \bd ذڭْ وَاسّْ وِيسّْ ثْمنْيَا\bd* إِقدّمْ ڒْحَاكمْ ن أَيْثْ ن \bd مَانَاسَّا\bd*، جَامَالِييِيلْ، مِّيسْ ن فَاذَاهْصُورْ، ثَاوْهِيبْثْ نّسْ.  
\v 55 ثُوغَا-ت ثَاوْهِيبْثْ نّسْ: إِجّنْ طّبْصِي ن نُّوقَارْثْ ن مْيَا ؤُ-ثْڒَاثِينْ شِيقْلُو \add ن دّْقڒْ\add*، ذ إِشْثنْ طَّاوْيَا إِ ؤُرُوشِّي ن نُّوقَارْثْ ن سبْعِينْ شِيقْلُو، عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. ثُوغَا-ثنْ س ثْنَاينْ شُّورنْ س وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.  
\v 56 \add خنِّي\add* إِشْثْ ن ثْغنْجَاشْثْ ن وُورغْ نعشْرَا \add شِيقْلُو\add* ثشُّورْ س ڒبْخُورْ،  
\v 57 إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ثْفُونَاسْثْ - إِجّْ ن إِشَارِّي ذ إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ،  
\v 58 إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ إِ ثْغَارْصْثْ ن دّنْبْ  
\v 59 ؤُ إِ ثْغَارْصْثْ ن ڒهْنَا: ثْنَاينْ ن إِفُونَاسنْ، خمْسَا ن إِشَارِّييّنْ، خمْسَا ن إِغَايْضنْ ذ خمْسَا ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. أَقَا ثَا ذ ثَاوْهِيبْثْ ن جَامَالِييِيلْ، مِّيسْ ن فَاذَاهْصُورْ.   
\m
\v 60 \bd ذڭْ وَاسّْ وِيسّْ ثسْعَا\bd* إِقدّمْ ڒْحَاكمْ ن أَيْثْ ن \bd بِينْيَامِينْ\bd*، أَبِيذَانْ، مِّيسْ ن جِيذْعُونِي، ثَاوْهِيبْثْ نّسْ.  
\v 61 ثُوغَا-ت ثَاوْهِيبْثْ نّسْ: إِجّنْ طّبْصِي ن نُّوقَارْثْ ن مْيَا ؤُ-ثْڒَاثِينْ شِيقْلُو \add ن دّْقڒْ\add*، ذ إِشْثنْ طَّاوْيَا إِ ؤُرُوشِّي ن نُّوقَارْثْ ن سبْعِينْ شِيقْلُو، عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. ثُوغَا-ثنْ س ثْنَاينْ شُّورنْ س وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.  
\v 62 \add خنِّي\add* إِشْثْ ن ثْغنْجَاشْثْ ن وُورغْ نعشْرَا \add شِيقْلُو\add* ثشُّورْ س ڒبْخُورْ،  
\v 63 إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ثْفُونَاسْثْ - إِجّْ ن إِشَارِّي ذ إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ،  
\v 64 إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ إِ ثْغَارْصْثْ ن دّنْبْ  
\v 65 ؤُ إِ ثْغَارْصْثْ ن ڒهْنَا: ثْنَاينْ ن إِفُونَاسنْ، خمْسَا ن إِشَارِّييّنْ، خمْسَا ن إِغَايْضنْ ذ خمْسَا ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. أَقَا ثَا ذ ثَاوْهِيبْثْ ن أَبِيذَانْ، مِّيسْ ن جِيذْعُونِي.   
\m
\v 66 \bd ذڭْ وَاسّْ وِيسّْعشْرَا\bd* إِقدّمْ ڒْحَاكمْ ن أَيْثْ ن \bd ذَانْ\bd*، أَخِيعَازَارْ، مِّيسْ ن عَامِيشَادَّايْ، ثَاوْهِيبْثْ نّسْ.  
\v 67 ثُوغَا-ت ثَاوْهِيبْثْ نّسْ: إِجّنْ طّبْصِي ن نُّوقَارْثْ ن مْيَا ؤُ-ثْڒَاثِينْ شِيقْلُو \add ن دّْقڒْ\add*، ذ إِشْثنْ طَّاوْيَا إِ ؤُرُوشِّي ن نُّوقَارْثْ ن سبْعِينْ شِيقْلُو، عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. ثُوغَا-ثنْ س ثْنَاينْ شُّورنْ س وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.  
\v 68 \add خنِّي\add* إِشْثْ ن ثْغنْجَاشْثْ ن وُورغْ نعشْرَا \add شِيقْلُو\add* ثشُّورْ س ڒبْخُورْ،  
\v 69 إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ثْفُونَاسْثْ - إِجّْ ن إِشَارِّي ذ إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ،  
\v 70 إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ إِ ثْغَارْصْثْ ن دّنْبْ  
\v 71 ؤُ إِ ثْغَارْصْثْ ن ڒهْنَا: ثْنَاينْ ن إِفُونَاسنْ، خمْسَا ن إِشَارِّييّنْ، خمْسَا ن إِغَايْضنْ ذ خمْسَا ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. أَقَا ثَا ذ ثَاوْهِيبْثْ ن أَخِيعَازَارْ، مِّيسْ ن عَامِيشَادَّايْ.   
\m
\v 72 \bd ذڭْ وَاسّْ وِيسّْ حِيطَاشْ\bd* إِقدّمْ ڒْحَاكمْ ن أَيْثْ ن \bd أَشِيرْ\bd*، فَاجْعِييِيلْ، مِّيسْ ن عُوكْرَانْ، ثَاوْهِيبْثْ نّسْ.  
\v 73 ثُوغَا-ت ثَاوْهِيبْثْ نّسْ: إِجّنْ طّبْصِي ن نُّوقَارْثْ ن مْيَا ؤُ-ثْڒَاثِينْ شِيقْلُو \add ن دّْقڒْ\add*، ذ إِشْثنْ طَّاوْيَا إِ ؤُرُوشِّي ن نُّوقَارْثْ ن سبْعِينْ شِيقْلُو، عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. ثُوغَا-ثنْ س ثْنَاينْ شُّورنْ س وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.  
\v 74 \add خنِّي\add* إِشْثْ ن ثْغنْجَاشْثْ ن وُورغْ نعشْرَا \add شِيقْلُو\add* ثشُّورْ س ڒبْخُورْ،  
\v 75 إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ثْفُونَاسْثْ - إِجّْ ن إِشَارِّي ذ إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ،  
\v 76 إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ إِ ثْغَارْصْثْ ن دّنْبْ  
\v 77 ؤُ إِ ثْغَارْصْثْ ن ڒهْنَا: ثْنَاينْ ن إِفُونَاسنْ، خمْسَا ن إِشَارِّييّنْ، خمْسَا ن إِغَايْضنْ ذ خمْسَا ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. أَقَا ثَا ذ ثَاوْهِيبْثْ ن فَاجْعِييِيلْ، مِّيسْ ن عُوكْرَانْ.   
\m
\v 78 \bd ذڭْ وَاسّْ وِيسّْ ثنْعَاشْ\bd* إِقدّمْ ڒْحَاكمْ ن أَيْثْ ن \bd نَافْثَالِي\bd*، أَخِيرَاعْ، مِّيسْ ن عِييْنَانْ، ثَاوْهِيبْثْ نّسْ.  
\v 79 ثُوغَا-ت ثَاوْهِيبْثْ نّسْ: إِجّنْ طّبْصِي ن نُّوقَارْثْ ن مْيَا ؤُ-ثْڒَاثِينْ شِيقْلُو \add ن دّْقڒْ\add*، ذ إِشْثنْ طَّاوْيَا إِ ؤُرُوشِّي ن نُّوقَارْثْ ن سبْعِينْ شِيقْلُو، عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. ثُوغَا-ثنْ س ثْنَاينْ شُّورنْ س وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.  
\v 80 \add خنِّي\add* إِشْثْ ن ثْغنْجَاشْثْ ن وُورغْ نعشْرَا \add شِيقْلُو\add* ثشُّورْ س ڒبْخُورْ،  
\v 81 إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ثْفُونَاسْثْ - إِجّْ ن إِشَارِّي ذ إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ،  
\v 82 إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ إِ ثْغَارْصْثْ ن دّنْبْ  
\v 83 ؤُ إِ ثْغَارْصْثْ ن ڒهْنَا: ثْنَاينْ ن إِفُونَاسنْ، خمْسَا ن إِشَارِّييّنْ، خمْسَا ن إِغَايْضنْ ذ خمْسَا ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. أَقَا ثَا ذ ثَاوْهِيبْثْ ن أَخِيرَاعْ، مِّيسْ ن عِييْنَانْ.   
\b  
\m
\v 84 ثُوغَا ثَا ذ ثَاوْهِيبْثْ إِ ؤُذشّنْ ن ؤُعَالْطَارْ زِي ڒْحُوكَّامْ ن إِسْرَائِيل ذڭْ وَاسّْ نِّي ذِي إِتّْوَاذْهنْ \add ؤُعَالْطَارْ\add*: ثنْعَاشْ ن طّْبَاصِي ن نُّوقَارْثْ ذ ثنْعَاشْ ن طَّاوْيَاثْ إِ ؤُرُوشِّي ن نُّوقَارْثْ ذ ثنْعَاشْ ن ثْغنْجَايِينْ ن وُورغْ.   
\m
\v 85 إِجّنْ طّبْصِي ن نُّوقَارْثْ \add إِوْزنْ\add* مْيَا ؤُ-ثْڒَاثِينْ \add شِيقْلُو\add* ذ إِشْثنْ طَّاوْيَا إِ ؤُرُوشِّي \add إِوْزنْ\add* سبْعِينْ \add شِيقْلُو\add*. مَارَّا نُّوقَارْثْ ن ڒقْشُوعْ \add نِّي ثوْزنْ\add* أَڒْفَاينْ ؤُ-أَربْعَا-مْيَا \add شِيقْلُو\add* عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ.   
\m
\v 86 ثنْعَاشْ ن ثْغنْجَايِينْ ن وُورغْ شُّورنْثْ س ڒبْخُورْ. كُوڒْ ثَاغنْجَايْثْ \add ثوْزنْ\add*عشْرَا شِيقْلُو، عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. مَارَّا ؤُرغْ ن ثْغنْجَايِينْ \add إِوْزنْ\add* مْيَا ؤُ-عِيشْرِينْ \add شِيقْلُو\add*.   
\m
\v 87 مَارَّا ڒبْهَايمْ إِ ثْغَارْصْثْ ن وشْمَاضْ أَقَا ذَايْسنْثْ ثنْعَاشْ ن إِفُونَاسنْ إِمژْيَاننْ، ثنْعَاشْ ن إِشَارِّييّنْ، ثنْعَاشْ ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ أَكْ-ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* نْسنْ، ؤُ ثنْعَاشْ إِمْيَاننْ زڭْ إِغَايْضنْ إِ ثْغَارْصْثْ ن دّنْبْ.   
\m
\v 88 مَارَّا ڒبْهَايمْ ن ثْغَارْصْثْ ن ڒهْنَا أَقَا ذَايْسنْثْ أَربْعَا ؤُ-عِيشْرِينْ ن إِفُونَاسنْ إِمژْيَاننْ، ستِّينْ ن إِشَارِّييّنْ ذ ستِّينْ ن إِغَايْضنْ ذ ستِّينْ ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. مَانْ أَيَا ذ ثَاوْهِيبْثْ إِ ؤُذشّنْ ن ؤُعَالْطَارْ أَوَارْنِي إِتّْوَاذْهنْ.   
\b  
\m
\v 89 \add ؤُمِي\add* يُوذفْ مُوسَا غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، حِيمَا أَذْ كِيذسْ إِسِّيوڒْ، إِسْڒَا ثْمِيجَّا ثسِّيوڒْ أَكِيذسْ زِي سنّجْ ن ثْقبَّارْثْ ن وصْڒَاحْ إِ إِدْجَانْ خْ تَّابُوثْ ن شّْهَاذثْ، زِي جَارْ ثْنَاينْ ن إِكِيرُوبنْ. \add أَمُّو إِ\add* إِسِّيوڒْ \add سِيذِي\add* أَكِيذسْ. \f ◼ \fr 7:‏89 \ft \+bd ’إِكِيرُوبنْ‘\+bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*   
\b  
\b  
\m  
\c 8
\s1 أَسْبذِّي ن ڒْقنْذِيڒْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ هَارُونْ، إِنِي أَسْ: ’خْمِي غَا ثسَّارْسذْ ثِيفَاوِينْ \add خْ ڒْقنْذِيڒْ\add*، إِتّْخصَّا سبْعَا ن ثْفَاوِينْ أَذْ وْشنْثْ ثَافَاوْثْ غَارْ زَّاثْ ن ڒْقنْذِيڒْ.‘ “ \x ◘ \xo 8:‏2 \xt ؤُف. 25‏:‏37\x*   
\m
\v 3 ؤُشَا أَمُّو إِ إِڭَّا هَارُونْ. إِسَّارْسْ ثِيفَاوِينْ نّسْ غَارْ زَّاثْ ن ڒْقنْذِيڒْ، أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي إِ مُوسَا.  
\v 4 ثُوغَا ڒْقنْذِيڒْ ذ إِشْثْ ن صّنْعثْ ن وُورغْ يعْذڒْ س وفْضِيسْ. زڭْ ؤُفُوضْ خْ ؤُضَارْ نّسْ أَڒْ نُّووَّارَاثْ نّسْ ثُوغَا إِتّْوَاڭّْ س وفْضِيسْ. عْلَاحْسَابْ أَمذْيَا إِ ذ أَسْ إِسْشّنْ سِيذِي، أَمُّو إِ إِصنّعْ ڒْقنْذِيڒْ. \x ◘ \xo 8:‏4 \xt ؤُف. 25‏:‏31\x*   
\b  
\m  
\s1 ثَاموْشِي ن إِلَاوِييّنْ ذ ڒْخذْمثْ نْسنْ  
\m
\v 5 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 6 ”كْسِي إِلَاوِييّنْ زِي جَارْ ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل ؤُشَا سِيزْذڭْ إِ-ثنْ.  
\v 7 أَمُّو إِ ذ أَسنْ غَا ثڭّذْ حِيمَا أَذْ ثنْ ثسِّيزذْڭذْ: رُوشّْ إِ-ثنْ س وَامَانْ ن ؤُسِيزْذڭْ. إِتّْخصَّا أَسنْ أَذْ حفّنْ مَارَّا أَرِّيمثْ نْسنْ ؤُشَا أَذْ سِّيرْذنْ أَرُّوضْ نْسنْ ؤُشَا أَذْ سِّيزْذڭنْ إِخفْ نْسنْ.  
\v 8 خنِّي أَذْ كْسِينْ إِجّْ ن ؤُفُونَاسْ، أَمژْيَانْ ن ثْفُونَاسْثْ، أَكْ-ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* نّسْ ن وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ ؤُ \add عَاوذْ\add* إِجّْ ن ؤُفُونَاسْ وِيسّْ ثْنَاينْ، أَمژْيَانْ ن ثْفُونَاسْثْ، أَمْ ثْغَارْصْثْ ن دّنْبْ.  
\v 9 أَذْ ثَاوْيذْ إِلَاوِييّنْ زَّاثْ إِ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا أَذْ ثسّْمُونذْ مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل.  
\v 10 أَذْ د-ثسّْقَارّْبذْ إِلَاوِييّنْ زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَا أَيْثْ ن إِسْرَائِيل أَذْ سَّارْسنْ إِفَاسّنْ نْسنْ خْ إِلَاوِييّنْ.  
\v 11 أَذْ يجّْ هَارُونْ أَذْ هزّنْ إِلَاوِييّنْ زِي سَّا غَارْ ذَا زَّاثْ إِ وُوذمْ ن سِيذِي أَمْ يِيشْثْ ن ثوْهِيبْثْ ن ونْهزِّي ذِي طّْوعْ ن أَيْثْ ن إِسْرَائِيل. نِيثْنِي أَذْ ذوْڒنْ تّْسخَّارنْ ذِي ثْسخَّارْثْ ن سِيذِي.  
\v 12 إِلَاوِييّنْ أَذْ سَّارْسنْ إِفَاسّنْ نْسنْ خْ إِزدْجِيفنْ ن إِفُونَاسنْ إِمژْيَاننْ ؤُشَا أَذْ ثسّْوجْذذْ إِجّْ إِ ثْغَارْصْثْ ن دّنْبْ ذ يِيجّْ إِ ثْغَارْصْثْ ن وشْمَاضْ إِ سِيذِي، حِيمَا أَذْ زَّايْسنْ إِتّْوَاڭّْ وصْڒَاحْ إِ إِلَاوِييّنْ.  
\v 13 أَذْ ثڭّذْ إِلَاوِييّنْ أَذْ بدّنْ زَّاثْ إِ وُوذمْ ن هَارُونْ ؤُ زَّاثْ إِ وُوذمْ ن وَارَّاوْ نّسْ ؤُشَا \add أَذْ ثنْ ثَارّذْ\add* أَذْ هزّنْ زِي سَّا غَارْ ذَا أَمْ يِيشْثْ ن ثوْهِيبْثْ ن ونْهزِّي زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 14 \add أَمُّو\add* إِ غَا ثْحُوزّذْ إِلَاوِييّنْ زِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل حِيمَا إِلَاوِييّنْ أَذْ إِڒِينْ إِنُو. \x ◘ \xo 8:‏14 \xt ڒخْڒ. 3‏:‏45\x*   
\m
\v 15 أَوَارْنِي مَانْ أَيَا أَذْ د-أَسنْ إِلَاوِييّنْ حِيمَا أَذْ سخَّارنْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. أَذْ ثنْ ثسِّيزذْڭذْ ؤُشَا أَذْ ثنْ ثَارّذْ أَذْ هزّنْ زِي سَّا غَارْ ذَا أَمْ يِيشْثْ ن ثوْهِيبْثْ ن ونْهزِّي،  
\v 16 مِينْزِي نِيثْنِي تّْوَامّوْشنْ أَيِي نِيشَانْ زِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل، ؤُشَا نشّْ كْسِيغْ ثنْ إِ يِيخفْ إِنُو ذڭْ ومْشَانْ ن مَارَّا مِينْ يَارزْمنْ ڒمْڒَاوثْ \add ذ أَمزْوَارُو\add*، \add ذڭْ ومْشَانْ ن\add* ؤُمنْزُو ن مَارَّا أَيْثْ ن إِسْرَائِيل.  
\v 17 مِينْزِي مَارَّا أَمنْزُو جَارْ أَيْثْ ن إِسْرَائِيل أَقَا-ث إِنُو، زڭْ إِوْذَانْ، أَمُّو زِي ڒْمَاڒْ، زڭْ وَاسّْ إِ ذِي نْغِيغْ نشّْ مَارَّا إِمنْزَا ذِي ثمُّورْثْ ن مِيصْرَا، سّْقدّْسغْ ثنْ إِ نشّْ. \x ◘ \xo 8:‏17 \xt ؤُف. 13‏:‏2؛ 22‏:‏29؛ 34‏:‏19؛ لَاوِي 27‏:‏26؛ ڒخْڒ. 3‏:‏13؛ لك. 2‏:‏23\x*  
\v 18 نشّْ كْسِيغْ إِلَاوِييّنْ ذڭْ ومْشَانْ ن مَارَّا إِمنْزَا جَارْ أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 8:‏18 \xt ڒخْڒ. 3‏:‏12\x*  
\v 19 نشّْ وْشِيغْ إِلَاوِييّنْ إِ هَارُونْ ؤُ إِ وَارَّاوْ نّسْ أَمْ يِيجّْ ن ؤُرِيغَالُو زِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل، مَاحنْذْ أَذْ ڭّنْ ثَاسخَّارْثْ ن أَيْثْ ن إِسْرَائِيل ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُ مَاحنْذْ أَذْ إِتّْوَاڭّْ وصْڒَاحْ ذِي طّْوعْ ن أَيْثْ ن إِسْرَائِيل، حِيمَا وَارْ ثتِّيڒِي جّْرِيحشْثْ خْ أَيْثْ ن إِسْرَائِيل خْمِي د غَا قَارّْبنْ أَيْثْ ن إِسْرَائِيل غَارْ زَّاوشْثْ إِقدّْسنْ.“   
\m
\v 20 مُوسَا ذ هَارُونْ ذ مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل ڭِّينْ أَكْ-ذ إِلَاوِييّنْ عْلَاحْسَابْ مَارَّا مِينْ ذ أَسْ يُومُورْ سِيذِي إِ مُوسَا زِي جِّيهثْ ن إِلَاوِييّنْ، أَمُّو إِ ڭِّينْ أَيْثْ ن إِسْرَائِيل أَكِيذْسنْ.  
\v 21 إِلَاوِييّنْ سِّيزْذِيڭنْ إِخفْ نْسنْ زِي دّنْبْ نْسنْ ؤُشَا صبّْننْ أَرُّوضْ نْسنْ ؤُشَا هَارُونْ يَارَّا إِ-ثنْ أَذْ نْهزّنْ زِي سَّا غَارْ ذَا أَمْ يِيشْثْ ن ثوْهِيبْثْ ن ونْهزِّي زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَا هَارُونْ إِسّصْڒحْ إِ-ثنْ إِ ؤُسِيزْذڭْ نْسنْ. \f ◼ \fr 8:‏21 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  
\v 22 أَوَارْنِي مَانْ أَيَا ؤُسِينْ-د إِلَاوِييّنْ حِيمَا أَذْ سخَّارنْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ زَّاثْ إِ وُوذمْ ن هَارُونْ ؤُ زَّاثْ إِ وُوذمْ ن وَارَّاوْ نّسْ أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي إِ مُوسَا زِي جِّيهثْ ن إِلَاوِييّنْ، أَمُّو إِ كِيذْسنْ ڭِّينْ.   
\b  
\m
\v 23 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 24 ”ثَا زِي جِّيهثْ ن إِلَاوِييّنْ: \add أَقَا\add* إِتّْخصَّا إِ \add كُوڒْ\add* مِّيسْ ن خمْسَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا سنّجْ أَذْ د-يَاسْ، حِيمَا أَذْ إِسخَّارْ ذِي طّْوعْ ن ثْسخَّارْثْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ  
\v 25 ؤُ خْمِي إِ غَا يِيوضْ غَارْ خمْسِينْ ن إِسڭّْوُوسَا أَذْ إِفّغْ زِي ڒْعسْكَارْ ن ثْسخَّارْثْ ؤُ وَارْ إِقِّيمْ إِتّْسخَّارْ عَاذْ كْثَارْ.  
\v 26 أَذْ إِوْشْ أَفُوسْ إِ يَايْثْمَاسْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ حِيمَا أَذْ \add خَاسْ\add* حْضَانْ، \add مَاشَا\add* نتَّا \add س يِيخفْ نّسْ\add* وَارْ إِزمَّارْ أَذْ إِسخَّارْ. أَمُّو إِ غَا ثڭّذْ أَكْ-ذ إِلَاوِييّنْ زِي جِّيهثْ ن ؤُحطُّو إِ خَاسنْ إِتّْوَاڭّنْ.“   
\b  
\b  
\m  
\c 9
\s1 ثِيوصَّا إِ ثْغَارْصْثْ ن ؤُسعْذُو  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذِي ڒخْڒَا ن سِينَا ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ أَوَارْنِي ڒَامِي د-فّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، ذڭْ ؤُيُورْ أَمزْوَارُو، إِنَّا:   
\m
\v 2 ”جّمْ أَيْثْ ن إِسْرَائِيل أَذْ سّْوجْذنْ \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو ذِي ڒْوقْثْ نّسْ إِتّْوَاڭّنْ. \x ◘ \xo 9:‏2 \xt ؤُف. 12‏:‏1‏-‏28؛ لَاوِي 23‏:‏5؛ ڒخْڒ. 28‏:‏16؛ أَعَوذ. 16‏:‏2\x*  
\v 3 ذڭْ وَاسّْ وِيسّْ أَرْبعْطَاشْ ن ؤُيُورْ-أَ، جَارْ بدُّو ن وزْينْ ن وَاسّْ أَڒْ د-ثوْضَا ثْمذِّيثْ، إِتّْخصَّا أَذْ ت ثسّْوجْذمْ ذِي ڒْوقْثْ نّسْ إِتّْوَاڭّنْ. إِتّْخصَّا أَذْ ت ثسّْوجْذمْ عْلَاحْسَابْ مَارَّا ثِيوصَّا ذ لْفَارَايِيضْ نّسْ.“   
\m
\v 4 إِسِّيوڒْ مُوسَا أَكْ-ذ أَيْثْ ن إِسْرَائِيل، \add إِنَّا\add* إِتّْخصَّا أَسنْ أَذْ سّْوجْذنْ \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو.  
\v 5 ؤُشَا نِيثْنِي سّْوجْذنْ \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو ذڭْ وَاسّْ وِيسّْ أَرْبعْطَاشْ ن \add ؤُيُورْ\add* أَمزْوَارُو ذِي ڒخْڒَا ن سِينَا، جَارْ بدُّو ن وزْينْ ن وَاسّْ أَڒْ د-ثوْضَا ثْمذِّيثْ، عْلَاحْسَابْ مَارَّا مِينْ ذ أَسْ يُومُورْ سِيذِي إِ مُوسَا، أَمُّو إِ ت سّْوجْذنْ أَيْثْ ن إِسْرَائِيل.   
\m
\v 6 شَا ن يرْيَازنْ تّْوَاسّْخمْجنْ س ڒْخشْبثْ ن إِجّْ ن بْنَاذمْ \add إِمُّوثنْ\add* ؤُشَا وَارْ زمَّارنْ أَذْ سّْوجْذنْ \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو. \add خْ ؤُيَا\add* قَارّْبنْ-د نِيثْنِي ذڭْ وَاسّْ نِّي زَّاثْ إِ وُوذمْ ن مُوسَا ؤُ زَّاثْ إِ وُوذمْ ن هَارُونْ  
\v 7 ؤُشَا نَّانْ أَسْ يرْيَازنْ نِّي: ”نشِّينْ نخْمجْ س ڒْخشْبثْ ن إِجّْ ن بْنَاذمْ \add إِمُّوثنْ\add*. مَايمِّي إِ نتّْوَاسّْبدّْ أَڒَامِي وَارْ نْزمَّارْ أَذْ د-نسّْقَارّبْ ثَاوْهِيبْثْ ن سِيذِي ذڭْ وَاسّْ نّسْ إِتّْوَاڭّنْ ذِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل؟“  
\v 8 مُوسَا إِنَّا أَسنْ: ”قِّيممْ ثْبدّمْ، \add حِيمَا\add* أَذْ سْڒغْ مِينْ ذ أَومْ غَا إِوصَّا سِيذِي.“   
\m
\v 9 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 10 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي: ’مَاڒَا حذْ زَّايْومْ نِيغْ زِي جِّيڒَاثْ نْومْ \add إِ د غَا يَاسنْ\add* إِتّْوَاسّخْمجْ زِي ڒْخشْبثْ \add ن يِيجّْ ن ؤُمتِّينْ\add*، نِيغْ نتَّا ذڭْ وبْرِيذْ ذ أَزِيرَارْ، \add خنِّي\add* أَذْ إِسّوْجذْ \add عَاذْ\add* \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو إِ سِيذِي.  
\v 11 ذڭْ ؤُيُورْ وِيسّْ ثْنَاينْ، ذڭْ وَاسّْ وِيسّْ أَرْبعْطَاشْ، جَارْ بدُّو ن وزْينْ ن وَاسّْ أَڒْ د-ثوْضَا ثْمذِّيثْ، أَذْ ت سّْوجْذنْ. \add خنِّي\add* أَذْ ت شّنْ أَكْ-ذ وغْرُومْ بْڒَا أَنْثُونْ ؤُ أَكْ-ذ ڒبْزَارْ يَارزْڭنْ.  
\v 12 وَارْ تّجِّينْ زَّايسْ وَالُو أَڒْ صّْبحْ ؤُشَا وَارْ زَّايسْ تَّارژَّانْ إِغسْ. إِتّْخصَّا أَذْ ت سّْوجْذنْ عْلَاحْسَابْ مَارَّا ثِيوصَّا ن \add ثْغَارْصْثْ ن\add* ؤُسعْذُو.‘ “ \x ◘ \xo 9:‏12 \xt ؤُف. 12‏:‏46؛ يُوح. 19‏:‏33، 36\x*   
\m
\v 13 ”مَاڒَا إِجّْ ن ورْيَازْ ذ أَمزْذَاڭْ إِ وَارْ إِدْجِينْ ذڭْ وبْرِيذْ، أَذْ يجّْ أَذْ إِسّوْجذْ \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو، \add خنِّي\add* أَذْ إِتّْوَاقسّْ ڒعْمَارْ نِّي زِي ڒْڭنْسْ نّسْ، مِينْزِي نتَّا وَارْ د-إِسّْقَارّبْ شَا ثَاوْهِيبْثْ ن سِيذِي ذِي ڒْوقْثْ نّسْ إِتّْوَاڭّنْ. أَرْيَازْ نِّي أَذْ يَارْبُو دّنْبْ نّسْ.  
\v 14 مَاڒَا إِزْذغْ أَكِيذْومْ إِجّْ ن ؤُبَارَّانِي، ونِّي إِ غَا إِسّْوجْذنْ \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو ن سِيذِي، \add خنِّي\add* أَذْ إِسّوْجذْ \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو عْلَاحْسَابْ ثَاوْصيّثْ ن \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو ؤُ عْلَاحْسَابْ لْفَارَايِيضْ نّسْ. أَذْ ذِينْ ثِيڒِي إِشْثْ ن ثوْصيّثْ إِ كنِّيوْ، إِ ؤُبَارَّانِي أَمُّو إِ ونِّي د-إِخڒْقنْ ذِي ثمُّورْثْ.“ \x ◘ \xo 9:‏14 \xt ؤُف. 12‏:‏49\x*   
\b  
\m  
\s1 أَڭوّذْ ن سِيذِي س ؤُسيْنُو  
\m
\v 15 ذڭْ وَاسّْ مِينْ ذِي ثتّْوَاسّْڭعّذْ ثْزذِّيغْثْ، إِذْڒَا ؤُسيْنُو ثَازذِّيغْثْ أَكْ-ذ ؤُقِيضُونْ ن شّْهَاذثْ ؤُ ذِي دْجِيڒثْ إِضْهَارْ-د خْ ثْزذِّيغْثْ أَمْ ثْمسِّي أَڒْ صّْبحْ. \x ◘ \xo 9:‏15 \xt ؤُف. 40‏:‏34\x*  
\v 16 أَمُّو إِ ثُوغَا ڒبْذَا، أَسيْنُو إِذْڒَا إِ-ت ؤُ ذِي دْجِيڒثْ إِضْهَارْ-د أَمْ ثْمسِّي.  
\v 17 ڒَامِي د-إِڭعّذْ ؤُسيْنُو زِي سنّجْ ن ؤُقِيضُونْ، \add خنِّي\add* أَوَارْنِي أَيَا فسْينْ أَيْثْ ن إِسْرَائِيل إِقِيضَانْ نْسنْ ؤُ ذڭْ ومْشَانْ مَانِي ثُوغَا د-إِبدّْ ؤُسيْنُو، ذِينْ إِ وْثِينْ أَيْثْ ن إِسْرَائِيل إِقِيضَانْ نْسنْ.  
\v 18 فسْينْ أَيْثْ ن إِسْرَائِيل إِقِيضَانْ نْسنْ عْلَاحْسَابْ ڒُومُورْ ن سِيذِي ؤُشَا خْ ڒُومُورْ ن سِيذِي وْثِينْ إِقِيضَانْ نْسنْ. مَارَّا ؤُسَّانْ ثُوغَا أَسيْنُو إِقِّيمْ سنّجْ إِ ثْزذِّيغْثْ، قِّيمنْ نِيثْنِي زدّْغنْ \add ذِينْ\add*. \x ◘ \xo 9:‏18 \xt 1 كُور. 10‏:‏1\x*  
\v 19 ڒَامِي د-إِبدّْ ؤُسيْنُو أَطَّاسْ ن وُوسَّانْ سنّجْ إِ ثْزذِّيغْثْ، حْضَانْ أَيْثْ ن إِسْرَائِيل ثَاسخَّارْثْ ن سِيذِي ؤُشَا وَارْ فسْينْ شَا إِقِيضَانْ نْسنْ.   
\m
\v 20 ؤُمِي إِقِّيمْ ؤُسيْنُو شْوَايْثْ ن وُوسَّانْ سنّجْ إِ ثْزذِّيغْثْ، \add خنِّي\add* وْثِينْ نِيثْنِي إِقِيضَانْ نْسنْ عْلَاحْسَابْ ڒُومُورْ ن سِيذِي ؤُ خْ ڒُومُورْ ن سِيذِي فسْينْ إِقِيضَانْ نْسنْ \add عَاوذْ\add*.  
\v 21 مَاڒَا إِمْسَارْ بلِّي أَسيْنُو إِبدّْ ذِينْ زِي دْجِيڒثْ أَڒْ صّْبحْ ؤُشَا إِڭعّذْ ؤُسيْنُو ذِي صّْبحْ، \add خنِّي\add* فسْينْ نِيثْنِي إِقِيضَانْ نْسنْ. مَا ذڭْ وَاسّْ \add إِ إِدْجَا\add* نِيغْ ذِي دْجِيڒثْ، خْمِي د-إِڭعّذْ ؤُسيْنُو، فسْينْ نِيثْنِي إِقِيضَانْ نْسنْ.  
\v 22 ؤُشَا مَاڒَا إِقِّيمْ ؤُسيْنُو إِبدّْ سنّجْ إِ ثْزذِّيغْثْ ثْنَاينْ ن وُوسَّانْ، نِيغْ إِجّْ ن ؤُيُورْ، نِيغْ أَطَّاسْ ن وُوسَّانْ، أَڒَامِي خَاسْ غَا يَارْسَا، \add خنِّي\add* قِّيمنْ أَيْثْ ن إِسْرَائِيل تّْخيّْمنْ \add ذِينِّي\add*، وَارْ فسْينْ شَا إِقِيضَانْ نْسنْ. مَاڒَا إِڭعّذْ ؤُسيْنُو، \add خنِّي\add* فسْينْ نِيثْنِي إِقِيضَانْ نْسنْ. \x ◘ \xo 9:‏22 \xt ؤُف. 40‏:‏36، 37\x*  
\v 23 خْ ڒُومُورْ ن سِيذِي وْثِينْ إِقِيضَانْ نْسنْ ؤُ خْ ڒُومُورْ ن سِيذِي فسْينْ إِقِيضَانْ نْسنْ. أَقَا حْضَانْ مِينْ ذ أَسنْ يُومُورْ سِيذِي، خْ ڒُومُورْ ن سِيذِي، س ثْسخَّارْثْ ن مُوسَا.   
\b  
\b  
\m  
\c 10
\s1 أَشَّاونْ ن إِشَارِّي إِ ؤُسُوضِي  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”أڭّْ إِ يِيخفْ نّشْ ثْنَاينْ ن ڒبْوَاقْ \add إِزِيرَارنْ\add* ن نُّوقَارْثْ، \add س يِيجّْ ن ؤُمَارْسُو\add* س وفْضِيسْ أَذْ ثنْ ثڭّذْ ؤُشَا أَذْ إِڒِينْ إِ ؤُبَارّحْ ن ثْمسْمُونْثْ ؤُ إِ ؤُسْمُوطِّي ن ڒمْرَاڭحْ ن ڒْعسْكَارْ.   
\m
\v 3 \add خْمِي\add* ذَايْسنْ غَا سُوضنْ، أَذْ غَاركْ ثْمُونْ ثْمسْمُونْثْ مَارَّا غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 4 خْمِي غَا سُوضنْ ذڭْ إِجّْ \add زِي ثْنَاينْ نِّي\add*، \add خنِّي\add* \add مْغِيرْ\add* ڒْحُوكَّامْ، إِزدْجِيفنْ خْ ڒُوڒُوفْ ن إِسْرَائِيل، إِ خَاكْ د غَا إِمُوننْ.  
\v 5 خْمِي غَا ثْسُوضمْ س وسْرُودّحْ \add ذِي ڒْبُوقْ\add*، \add خنِّي\add* أَذْ مُّوطِّيينْثْ ڒمْرَاڭحْ نِّي إِمَّارْسنْ غَارْ شَّارْقْ.  
\v 6 خْمِي غَا ثْسُوضمْ س وسْرُودّحْ \add ذِي ڒْبُوقْ\add* ثْنَاينْ ن ثْوَاڒَاوِينْ، \add خنِّي\add* أَذْ مُّوطِّيينْثْ ڒمْرَاڭحْ نِّي إِمَّارْسنْ غَارْ ؤُغزْذِيسْ ن لْجَانُوبْ. أَذْ سُوضنْ س وسْرُودّحْ ؤُمِي غَا مُوطِّيينْ زڭْ ومْشَانْ غَارْ ومْشَانْ \add نّغْنِي\add*.  
\v 7 إِ ثْمسْمُونْثْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add* إِتّْخصَّا أَذْ ثْسُوضمْ \add ذِي ڒبْوَاقْ\add*، \add مَاشَا\add* بْڒَا أَسْرُودّحْ.  
\v 8 أَذْ سُوضنْ وَارَّاوْ ن هَارُونْ، إِكهَّاننْ، ذِي ڒبْوَاقْ. أَذْ ثِيڒِي ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ.“   
\m
\v 9 ”خْمِي د غَا ثفّْغمْ غَارْ ڭَارَّا ذِي ثمُّورْثْ نْومْ، حِيمَا أَذْ ثْمنْغمْ أَكْ-ذ وغْرِيمْ نِّي كنِّيوْ د-إِهكّْوڒنْ، \add خنِّي\add* أَذْ ثْسُوضمْ س وسْرُودّحْ ذِي ڒبْوَاقْ ؤُشَا كنِّيوْ أَذْ ثتّْوَاثِيذَارمْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نْومْ، ؤُشَا أَذْ ثْنجْممْ زِي ڒْعذْيَانْ نْومْ.  
\v 10 \add أَمُّو\add* ذِي كُوڒْ إِجّْ ن وَاسّْ ن ڒفْرَاحثْ ؤُ ذِي ڒعْيُوذَاثْ إِتّْوَاڭّنْ ؤُ ذڭْ ؤُمزْوَارُو ن إِيُورنْ نْومْ أَذْ ثْسُوضمْ ذِي ڒبْوَاقْ خْمِي \add غَا ثَاوْيمْ\add* ثِيغَارْصَا ن وشْمَاضْ نْومْ ذ ثْغَارْصَا ن ؤُقَاذِي نْومْ ؤُشَا \add أَمُّو إِ\add* غَا إِڒِينْثْ ذِي طّْوعْ نْومْ إِ ڒِيذَارثْ زَّاثْ إِ وُوذمْ ن أَربِّي، نشّْ ذ سِيذِي، أَربِّي نْومْ.“ \x ◘ \xo 10:‏10 \xt إِزهد. 68‏:‏\x*   
\b  
\m  
\s1 أَڭّْوجِّي زِي ڒخْڒَا ن سِينَا  
\m
\v 11 إِمْسَارْ ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ، ذڭْ ؤُيُورْ وِيسّْ ثْنَاينْ، ذڭْ \add وَاسّْ\add* وِيسّْ عِيشْرِينْ ن ؤُيُورْ، أَقَا إِتّْوَاسّْڭعّذْ ؤُسيْنُو زِي سنّجْ ن ثْزذِّيغْثْ ن شّْهَاذثْ.  
\v 12 ؤُشَا فسْينْ أَيْثْ ن إِسْرَائِيل إِقِيضَانْ نْسنْ، مُّوطِّيينْ زڭْ ومْشَانْ غَارْ ومْشَانْ زِي ڒخْڒَا ن سِينَا ؤُشَا إِبدّْ-د ؤُسيْنُو ذِي ڒخْڒَا ن فَارَانْ.  
\v 13 \add أَمُّو\add* فسْينْ إِقِيضَانْ نْسنْ ثْوَاڒَا ثَامزْوَارُوثْ، خْ ڒُومُورْ ن سِيذِي، خْ ؤُفُوسْ ن مُوسَا.   
\m
\v 14 \bd ذ أَمزْوَارُو ثتّْوَاكّسْ ثْعدْجَانْثْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ ن أَيْثْ ن يَاهُوذَا\bd*، \add ؤُيُورنْ أَمْ تّْوَاستّْفنْ\add* عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ. نَاحْشُونْ، مِّيسْ ن عَامِّينَاذَابْ، ثُوغَا \add ذ أَزدْجِيفْ\add* خْ ڒْعسْكَارْ. \x ◘ \xo 10:‏14 \xt ڒخْڒ. 1‏:‏7؛ 2‏:‏3 \x*  
\v 15 نَاثَانَايِيلْ، مِّيسْ ن صُوغَارْ، ثُوغَا \add ذ أَزدْجِيفْ\add* خْ ڒْعسْكَارْ ن ثقْبِيتْشْ ن أَيْثْ ن إِسَّاكَارْ.  
\v 16 إِلِييَابْ، مِّيسْ ن حِيلُونْ، ثُوغَا \add ذ أَزدْجِيفْ\add* خْ ڒْعسْكَارْ ن ثقْبِيتْشْ ن أَيْثْ ن زِيبُولُونْ.   
\m
\v 17 أَوَارْنِي مَانْ أَيَا هذْمنْ ثْزذِّيغْثْ ؤُشَا فسْينْ أَيْثْ ن جَارْشُونْ ذ أَيْثْ ن مَارَارِي إِقِيضَانْ نْسنْ ؤُشَا أَرْبُونْ ثَازذِّيغْثْ.   
\m
\v 18 \bd \+bdit خنِّي\+bdit* ثتّْوَاكّسْ ثْعدْجَانْثْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ ن رُوبِينْ\bd* \add ؤُيُورنْ، تّْوَاستّْفنْ\add* عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ. إِلِيصُورْ، مِّيسْ ن شَاذَايُورْ، ثُوغَا \add ذ أَزدْجِيفْ\add* خْ ڒْعسْكَارْ نّسْ.  
\v 19 شَالُومِييِيلْ، مِّيسْ ن صُورِيشَادَّايْ، ثُوغَا \add ذ أَزدْجِيفْ\add* خْ ڒْعسْكَارْ ن ثقْبِيتْشْ ن أَيْثْ ن شِيمْعُونْ.  
\v 20 إِلْيَاسَافْ، مِّيسْ ن ذَاعُويِيلْ، ثُوغَا \add ذ أَزدْجِيفْ\add* خْ ڒْعسْكَارْ ن ثقْبِيتْشْ ن أَيْثْ ن جَاذْ.   
\m
\v 21 \add خنِّي\add* فسْينْ أَيْثْ ن قَاهَاثْ إِقِيضَانْ نْسنْ، أَرْبُونْ زَّاوشْثْ إِقدّْسنْ. ؤُشَا \add أَيْثْ ن جَارْشُونْ ذ أَيْثْ ن مَارَارِي\add* بْنَانْ ثَازذِّيغْثْ قْبڒْ ثْوَاسِيثْ نْسنْ. \x ◘ \xo 10:‏21 \xt ڒخْڒ. 4‏:‏4\x*   
\m
\v 22 \bd \+bdit أَوَارْنِي أَسْ\+bdit* ثتّْوَاكّسْ ثْعدْجَانْثْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ ن أَيْثْ ن إِفْرَايِيمْ\bd*، \add ؤُيُورنْ، تّْوَاستّْفنْ\add* عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ. إِلِيشَامَاعْ، مِّيسْ ن عَامِّيهُوذْ، ثُوغَا \add ذ أَزدْجِيفْ\add* خْ ڒْعسْكَارْ نّسْ.  
\v 23 جَامَالِييِيلْ، مِّيسْ ن فَاذَاهْصُورْ، ثُوغَا \add ذ أَزدْجِيفْ\add* خْ ڒْعسْكَارْ ن ثقْبِيتْشْ ن أَيْثْ ن مَانَاسَّا.  
\v 24 أَبِيذُونْ، مِّيسْ ن جِيذْعُونِي، ثُوغَا \add ذ أَزدْجِيفْ\add* خْ ڒْعسْكَارْ ن ثقْبِيتْشْ ن أَيْثْ ن بِينْيَامِينْ.   
\m
\v 25 \bd \+bdit خنِّي\+bdit* ثتّْوَاكّسْ ثْعدْجَانْثْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ ن أَيْثْ ن ذَانْ\bd*، أَمْ ؤُغزْذِيسْ ؤُنڭَّارْ ن مَارَّا ڒمْرَاڭحْ، \add ؤُشَا ؤُيُورنْ، تّْوَاستّْفنْ\add* عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ. أَخِيعَازَارْ، مِّيسْ ن عَامِّيشَادَّايْ، ثُوغَا \add ذ أَزدْجِيفْ\add* خْ ڒْعسْكَارْ نّسْ.  
\v 26 فَاجْعِييِيلْ، مِّيسْ ن عُوكْرَانْ، ثُوغَا \add ذ أَزدْجِيفْ\add* خْ ڒْعسْكَارْ ن ثقْبِيتْشْ ن أَيْثْ ن أَشِيرْ.  
\v 27 أَخِيرَاعْ، مِّيسْ ن عِينَانْ، ثُوغَا \add ذ أَزدْجِيفْ\add* خْ ڒْعسْكَارْ ن ثقْبِيتْشْ ن أَيْثْ ن زِيبُولُونْ.   
\m
\v 28 \add أَمُّو إِ\add* سّْمُوطِّيينْ أَيْثْ ن إِسْرَائِيل إِقِيضَانْ نْسنْ \add زڭْ ومْشَانْ غَارْ ومْشَانْ\add*، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ڒْعسْكَارَاثْ نْسنْ، \add أَمُّو إِ\add* فسْينْ نِيثْنِي إِقِيضَانْ نْسنْ.   
\b  
\m
\v 29 إِنَّا مُوسَا إِ \bd حُوبَابْ، مِّيسْ ن رَاعُويِيلْ، أَمِيذْيَانِي، أَضڭّْوَاڒْ ن مُوسَا:\bd* ”نشِّينْ أَذْ نمُّوطِّي غَارْ ومْشَانْ إِ ذ أَنغْ إِنَّا سِيذِي: ’نشّْ أَذْ أَومْ ث-إِ-د وْشغْ!‘ أَسْ-د أَكِيذْنغْ، أَذْ أَشْ نڭّْ ثْشُونِي، مِينْزِي سِيذِي إِسِّيوڒْ خْ إِسْرَائِيل س ڒْخِيرْ.“  
\v 30 نتَّا إِنَّا أَسْ: ”نشّْ وَارْ تّْرِيحغْ، مَاغَارْ أَذْ ؤُيُورغْ غَارْ ثمُّورْثْ إِنُو ؤُ غَارْ ڒَادْجْ إِنُو.“  
\v 31 ؤُشَا نتَّا إِنَّا أَسْ: ”تّْزَاوْڭغْ شكْ، وَارْ ذ أَنغْ تّجِّي، مِينْزِي شكْ ثسّْنذْ مَامّشْ إِشُووَّارْ أَذْ نوّثْ إِقِيضَانْ نّغْ. شكْ أَقَا ثْذوْڒذْ أَنغْ \add - أَمْ مَامّشْ نقَّارْ -\add* أَمْ ثِيطَّاوِينْ.  
\v 32 خْمِي غَا ثْرَاحذْ أَكِيذْنغْ ؤُشَا أَذْ أَنغْ د-يَاسْ ڒْخِيرْ إِ ذَايْنغْ غَا إِڭّْ سِيذِي، أَقَا نشِّينْ أَذْ أَشْ نڭّْ ثْشُونِي \add عَاوذْ\add*.“   
\b  
\m
\v 33 ؤُشَا فسْينْ إِقِيضَانْ نْسنْ، \add ؤُيُورنْ\add* زڭْ وذْرَارْ ن سِيذِي ثِيشْڒِي ن ثْڒَاثَا ن وُوسَّانْ. تَّابُوثْ ن ڒْعَاهْذْ ثُويُورْ زَّاثْ إِ وُوذمْ نْسنْ ثِيشْڒِي ن ثْڒَاثَا ن وُوسَّانْ، حِيمَا أَذْ يَارْزُو خْ إِجّْ ن ومْشَانْ إِ أَرَّاحثْ.  
\v 34 ذڭْ ؤُزِيڒْ ثُوغَا أَسيْنُو ن سِيذِي سنّجْ نْسنْ ؤُمِي كّْسنْ إِقِيضَانْ نْسنْ زِي ڒْمَارْڭحْ ن ڒْعسْكَارْ.  
\v 35 ڒَامِي ثتّْوَاسّْمُوطِّي تَّابُوثْ، ثمْسَارْ \add ڒبْذَا\add* بلِّي مُوسَا إِنَّا: ”كَّارْ، \add أَ\add* سِيذِي، أجّْ ڒعْذْيَانْ نّشْ أَذْ مّْزدْجَاعنْ ؤُ إِنِّي كنِّيوْ إِشَارّْهنْ أَذْ أَروْڒنْ زڭْ وُوذمْ نّشْ!“ \x ◘ \xo 10:‏35 \xt إِزهد. 68‏:‏2\x*  
\v 36 غَارْ ؤُبذِّي \add ن تَّابُوثْ\add*، إِنَّا: ”ذْوڒْ-د، \add أَ\add* سِيذِي، غَارْعشْرَا ن ڒُوڒُوفْ ن ڒُوڒُوفْ ن إِسْرَائِيل!“   
\b  
\b  
\m  
\c 11
\s1 ثِيمسِّي ن سِيذِي  
\m
\v 1 إِمْسَارْ ؤُمِي إِذْوڒْ ڒْڭنْسْ أَمْ يِيجّْ ن ؤُبَارُّو إِتّْشثْشَانْ، ثُوغَا مَانْ أَيَا ذ ڒحْرِيقْ إِ إِمزُّوغنْ ن سِيذِي. \add ڒَْامِي\add* إِسْڒَا سِيذِي أَيَا، يَارْغَا وغْضَابْ نّسْ ؤُ ثِيمسِّي ن سِيذِي ثَارْغَا ذِي ڒْوسْطْ نْسنْ ؤُشَا ثشَّا ڒضْرُوفْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ. \x ◘ \xo 11:‏1 \xt أَعَوذ. 9‏:‏22؛ إِزهد. 78‏:‏21 \x*  
\v 2 \add خنِّي\add* إِڒَاغَا-د ڒْڭنْسْ خْ مُوسَا ؤُشَا مُوسَا إِژُّودْجْ إِ سِيذِي ؤُشَا ثخْسِي ثْمسِّي.  
\v 3 ؤُشَا إِڒَاغَا أَسْ إِ ومْشَانْ نِّي ’ثَابْعِيرَا‘، مِينْزِي ثِيمسِّي ن سِيذِي ثُوغَا ثَارْغَا ذِي ڒْوسْطْ نْسنْ.   
\b  
\m  
\s1 سبْعِينْ ن إِمْغَارنْ - ثِيسكْرِينْ  
\m
\v 4 أَبَارُّو إِمْخدْجَاضنْ \add ن إِبَارَّانِييّنْ نِّي إِدْجَانْ\add* ذِي ڒْوسْطْ نْسنْ، ذوْڒنْ شُورّنْ س ؤُمژْرِي ؤُ بْذَانْ أَيْثْ ن إِسْرَائِيل عَاوذْ أَذْ شتّْشَانْ، نَّانْ: ”وِي ذ أَنغْ غَا إِوْشِينْ أَيْسُومْ؟ \x ◘ \xo 11:‏4 \xt ؤُف. 12‏:‏38؛ 16‏:‏3؛ إِزهد. 106‏:‏14؛ 1 كُور. 10‏:‏6\x*  
\v 5 نْعقّڒْ عَاذْ خْ إِسڒْمَانْ نِّي نشَّا ذِي مِيصْرَا بَاطڒْ ؤُ خْ ڒخْيَارْ ذ دّلَّاعْ ذ ڒبْصڒْ يُوژْغنْ ذ ڒبْصڒْ ذ ثِيشَّارْثْ.  
\v 6 ڒخُّو ڒعْمُورْ نّغْ ؤُژْغنْ ؤُشَا وَارْ ذِينْ وَالُو مْغِيرْ ’مَانَّا‘-يَا زَّاثْ إِ ثِيطَّاوِينْ نّغْ!“  
\v 7 ثُوغَا ’مَانَّا‘ إِتّمْشَابهْ ذِي زَّارِيعثْ ن ڒْقصْبُورْ ؤُشَا شُّوفْ نّسْ أَمشْنَاوْ شُّوفْ ن \add ؤُسرْغَاغْ أَشمْڒَاڒْ قَّارنْ أَسْ\add* ’بذُولَا‘. \x ◘ \xo 11:‏7 \xt ؤُف. 16‏:‏14، 31؛ إِزهد. 78‏:‏24؛ يُوح. 6‏:‏31، 49\x*  
\v 8 ڒْڭنْسْ إِفّغْ، إِمّْسبْضَا ؤُشَا يْرُونْ \add ت\add* ؤُشَا حَارْينْ \add ت\add* سَاذُو ثْسِيرْثْ نِيغْ دّْزنْ \add ت\add* س وزْذُوزْ ؤُشَا \add خنِّي\add* سّنْڭّْونْ ت ذِي أَرْوَا ؤُشَا ڭِّينْ زَّايسْ ثِيفْضِيرِينْ. ثُوغَا أَڒذِّي نّسْ أَمْ مِينْ إِنْڭّْوَانْ س زّشْثْ.  
\v 9 خْمِي د-إِهكّْوَا نّْذَا خْ ڒْمَارْڭحْ ن ڒْعسْكَارْ، \add خنِّي\add* ثْهكّْوَا-د خَاسْ ’مَانَّا‘ \add عَاوذْ\add*.  
\v 10 ؤُشَا إِسْڒَا مُوسَا أَقَا ڒْڭنْسْ إِسْغُويْ، ڒَادْجْ أَوَارْنِي إِنّغْنِي، كُوڒْ إِجّْ غَارْ وَاذَافْ ن ؤُقِيضُونْ نّسْ. يَارْغَا وغْضَابْ ن سِيذِي أَطَّاسْ، ؤُشَا ثُوغَا مَانْ أَيَا ؤُڒَا ذ ثُوعفّْنَا ذِي ثِيطَّاوِينْ ن مُوسَا.  
\v 11 إِنَّا مُوسَا إِ سِيذِي: ”مَايمِّي ثڭِّيذْ ڒْغَارْ ذڭْ ؤُمْسخَّارْ نّشْ ؤُ مَايمِّي وَارْ ؤُفِيغْ ڒْخَاضَارْ ذِي ثِيطَّاوِينْ نّشْ، ؤُمِي خَافِي د-ثسَّارْسذْ دّْقڒْ ن مَارَّا ڒْڭنْسْ-أَ؟  
\v 12 مَا نشّْ ذيْسغْ \add بَالَاكْ\add* س مَارَّا ڒْڭنْسْ-أَ؟ نِيغْ نشّْ إِ-ث-إِ-د يُورْونْ، مَاحنْذْ ثْزمَّارذْ أَذْ أَيِي ثِينِيذْ: ’أَوْيِي ث ذڭْ وشْيُونْ نّشْ!‘، أَمْ ونِّي إِسُّوطُّوضنْ يَاربُّو أَسيْمِي، غَارْ ثمُّورْثْ مِينْ خفْ ثجُّودْجذْ شكْ إِ ڒجْذُوذْ نّسْ.  
\v 13 زِي مَانِيسْ \add ذ أَسنْ-د\add* غَا يَاوْيغْ أَيْسُومْ إِ غَا وْشغْ \add ذ مَاشَّا\add* إِ مَارَّا ڒْڭنْسْ-أَ؟ مِينْزِي نِيثْنِي سْغُويُّونْ-د غَارِي، قَّارنْ: ’أوْشْ أَنغْ أَيْسُومْ إِ غَا نشّْ!‘  
\v 14 نشّْ وحّْذِي وَارْ زمَّارغْ أَذْ أَرْبُوغْ ڒْڭنْسْ-أَ مَارَّا، أَقَا مَانْ أَيَا إِذْقڒْ خَافِي أَطَّاسْ.  
\v 15 مَاڒَا ذَايِي ثڭِّيذْ أَمُّو، نشّْ تّْزَاوَاڭغْ أَذْ أَيِي ثنْغذْ \add حْسنْ\add*، مَاڒَا ؤُفِيغْ أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، \add خنِّي\add* نشّْ وَارْ ژَترّغْ ڒغْبنْ إِنُو \add عَاذْ\add* كْثَارْ!“   
\m
\v 16 خنِّي إِنَّا سِيذِي إِ مُوسَا: ”سْمُونْ أَيِي-د سبْعِينْ ن يرْيَازنْ زڭْ إِمْغَارنْ ن إِسْرَائِيل، إِنِّي ثسّْنذْ شكْ ذ إِمْغَارنْ ن ڒْڭنْسْ ؤُ ذ إِمحْضَاينْ. أَوْيِي ثنْ-د غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا أجّْ إِثنْ أَذْ ذِينْ بدّنْ زَّاثكْ.  
\v 17 \add خنِّي\add* نشّْ أَذْ هْوِيغْ ؤُشَا أَذْ كِيكْ سِّيوْڒغْ. أَذْ كْسِيغْ زِي أَرُّوحْ إِ خَاكْ إِدْجَانْ ؤُشَا أَذْ خَاسنْ ث سَّارْسغْ. \add أَمُّو إِ كِيكْ غَا\add* أَرْبُونْ دّْقڒْ ن ڒْڭنْسْ-أَ، مَاحنْذْ وَارْ ث ثَاربُّوذْ شَا وحّْذكْ.  
\v 18 أَذْ ثِينِيذْ إِ ڒْڭنْسْ: ’سْقدّْسمْ إِخفْ نْومْ إِ ثِيوشَّا، \add خنِّي\add* أَذْ ثشّمْ أَيْسُومْ، مِينْزِي أَقَا ثْرُومْ ذڭْ إِمزُّوغنْ ن سِيذِي، ثنَّامْ: وِي ذ أَنغْ غَا إِوْشنْ أَذْ نشّْ أَيْسُومْ؟ ثُوغَا-نغْ مْلِيحْ ذِي مِيصْرَا! \add س ؤُيَا\add* إِ ذ أَومْ غَا إِوْشْ سِيذِي أَيْسُومْ أَذْ ثشّمْ.  
\v 19 وَارْ ث ثتّتّمْ إِجّْ ن وَاسّْ \add وَاهَا\add* ؤُڒَا ذ ثْنَاينْ ن وُوسَّانْ، نِيغْ خمْسَا ن وُوسَّانْ، نِيغْعشْرَا ن وُوسَّانْ، نِيغْ عِيشْرِينْ ن وُوسَّانْ،  
\v 20 \add مَاشَا\add* \add مَارَّا\add* ؤُسَّانْ ن ؤُيُورْ أَڒْ ذ أَومْ د-إِفّغْ زڭْ ونْزَارنْ نْومْ ؤُشَا أَذْ زَّايسْ ثْعِيفّمْ، ؤُمِي ثنْضَارمْ سِيذِي ونِّي إِدْجَانْ ذِي ڒْوسْطْ نْومْ، ؤُشَا ثْرُومْ زَّاثْ إِ ؤُغمْبُوبْ نّسْ، ثنَّامْ: مَايمِّي \add عَاذْ\add* د-نفّغْ زِي مِيصْرَا؟‘ “ \x ◘ \xo 11:‏20 \xt ڒخْڒ. 21‏:‏5 \x*   
\m
\v 21 ؤُشَا مُوسَا إِنَّا: ”ڒْڭنْسْ-يَا، ذِي ڒْوسْطْ نْسنْ إِ دْجِيغْ، أَقَا-ث ذِي ستَّا-أَڒَافْ ن يرْيَازنْ خْ إِضَارنْ ؤُشَا شكْ ثقَّارذْ: ’أَذْ أَسنْ وْشغْ أَيْسُومْ ؤُشَا أَذْ \add زَّايسْ\add* شّنْ إِجّْ ن ؤُيُورْ أَمنْ إِكْمڒْ!‘  
\v 22 \add مَاڒَا\add* غَارْصنْ أَسنْ إِ \add مَارَّا\add* وُودْجِي ذ إِفُونَاسنْ، مَا أَذْ يِيڒِي شْفَا أَسنْ؟ \add نِيغْ مَاڒَا\add* سّْمُوننْ أَسنْ مَارَّا إِسڒْمَانْ ن ڒبْحَارْ، مَا أَذْ يِيڒِي شْفَا أَسنْ؟“ \x ◘ \xo 11:‏22 \xt يُوح. 6‏:‏7 \x*  
\v 23 إِنَّا سِيذِي إِ مُوسَا: ”مَا \add خنِّي\add* يبْرِي ؤُفُوسْ ن سِيذِي؟ ڒخُّو \add خنِّي\add*، أَذْ ثْژَارذْ مَا أَذْ إِقْفڒْ أَوَاڒْ نّسْ نِيغْ لَّا!“ \x ◘ \xo 11:‏23 \xt إِشا. 50‏:‏2؛ 59‏:‏1\x*   
\m
\v 24 إِفّغْ-د مُوسَا ؤُشَا إِنَّا أَوَاڒنْ ن سِيذِي إِ ڒْڭنْسْ ؤُشَا إِسّْمُونْ سبْعِينْ ن يرْيَازنْ زڭْ إِمْغَارنْ ن ڒْڭنْسْ ؤُشَا إِسّْبدّْ إِ-ثنْ أَمْ د-نّْضنْ إِ ؤُقِيضُونْ.  
\v 25 \add خنِّي\add* إِهْوَا-د سِيذِي ذڭْ ؤُسيْنُو ؤُشَا إِسِّيوڒْ أَكِيذسْ ؤُشَا إِكْسِي زِي أَرُّوحْ نِّي ثُوغَا خَاسْ ؤُشَا إِسَّارْسْ إِ-ث خْ سبْعِينْ ن يرْيَازنْ، \add خْ\add* إِمْغَارنْ. ؤُشَا إِمْسَارْ، ؤُمِي ثُوغَا خَاسنْ أَرُّوحْ، \add بْذَانْ\add* أَذْ نبَّانْ، مَاشَا أَوَارْنِي إِ ؤُيَا وَارْ إِقِّيمْ عَاذْ.   
\m
\v 26 ؤُشَا قِّيمنْ ثْنَاينْ ن يرْيَازنْ ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ، إِجّنْ قَّارنْ أَسْ إِلْذَاذْ ؤُ ونّغْنِي قَّارنْ أَسْ مِيذَاذْ ؤُشَا أَرُّوحْ ن سِيذِي ثُوغَا-ث خَاسنْ، \add مِينْزِي\add* نِيثْنِي أَقَا أَثنْ زڭْ إِنِّي يُورَانْ، \add مَاشَا\add* وَارْ د-فِّيغنْ غَارْ ؤُقِيضُونْ ؤُشَا ثُوغَا تّْنبَّانْ ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ.  
\v 27 يُوزّڒْ-د إِجّْ ن ؤُحنْجِيرْ ؤُشَا إِخبَّارْ مَانْ أَيَا إِ مُوسَا، إِنَّا: ”إِلْذَاذْ ذ مِيذَاذْ تّْنبَّانْ ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ.“  
\v 28 يَارَّا-د يَاشُووَا، مِّيسْ ن نُونْ، \add إِجّنْ\add* زڭْ إِبْڒِيغنْ إِتّْفَارْزنْ، إِنَّا: ”سِيذِي إِنُو، مُوسَا، حَارّمْ إِ-ثنْ!“  
\v 29 إِنَّا أَسْ مُوسَا: ”مَا شكْ ثشْضَارذْ ذِي طّْوعْ إِنُو؟ مْڒِي مَارَّا ڒْڭنْسْ ن سِيذِي ثُوغَا-ث مَارَّا ذ إِنَابِييّنْ، إِڒِي إِڭَّا خَاسنْ سِيذِي أَرُّوحْ نّسْ!“   
\m
\v 30 إِذْوڒْ-د مُوسَا غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ، نتَّا ذ إِمْغَارنْ ن إِسْرَائِيل.   
\m
\v 31 \add خنِّي\add* يُوسَا-د إِجّْ ن ؤُسمِّيضْ، \add إِسّكَّارْ إِ-ث\add* سِيذِي، إِنْذهْ-د إِجْضَاضْ قَّارنْ أَسْ ’ثْسَالْوَا‘ زِي ڒبْحَارْ ؤُشَا إِنْضَارْ إِ-ثنْثْ خْ ڒْمَارْڭحْ ن ڒْعسْكَارْ، ثِيشْڒِي ن وبْرِيذْ ن إِجّْ ن وَاسّْ غَارْ إِجّْ ن ثْمَا ذ ثِيشْڒِي ن وبْرِيذْ غَارْ ثْمَا نّغْنِي، ذڭْ ونّضْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ، أَڒْ عْڒَاينْ ثْنَاينْ ن إِغَادْجنْ خْ وُوذمْ ن ثمُّورْثْ. \x ◘ \xo 11:‏31 \xt ؤُف. 16‏:‏13؛ إِزهد. 78‏:‏26\x*  
\v 32 إِكَّارْ ڒْڭنْسْ ؤُشَا أَسّْ \add نِّي\add* إِكْمڒْ ذ دْجِيڒثْ \add نِّي\add* ثكْمڒْ ذ مَارَّا أَسّْ إِ ث-إِ-د إِضْفَارنْ يْرُونْ نِيثْنِي إِجْضَاضْ قَّارنْ أَسْ ’ثْسَالْوَا‘. ونِّي غَارسْ ذْرُوسْ، إِكْسِيعشْرَا إِحُومِيرنْ. بزّْعنْ ثنْثْ قِيبَاتْشْ نْسنْ خْ ثِيرُو إِ إِنّْضنْ إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ.  
\v 33 مِينْثْرَا أَيْسُومْ عَاذْ جَارْ ثغْمَاسْ نْسنْ، قْبڒْ مَا أَذْ ث فّْژنْ، يَارْغَا وغْضَابْ ن سِيذِي خْ ڒْڭنْسْ ؤُشَا سِيذِي إِوْثَا ڒْڭنْسْ س إِشْثْ ن ثشْثِي ثمْغَارْ أَطَّاسْ. \x ◘ \xo 11:‏33 \xt إِزهد. 78‏:‏30، 31 \x*  
\v 34 إِسمَّا \add مُوسَا\add* أَمْشَانْ نِّي ’قَابَارُوثْ-هَاثَاآوَاثْ‘، مِينْزِي ذِينِّي إِ نضْڒنْ ڒْڭنْسْ إِ ثُوغَا إِمّژْرنْ \add أَمُّو\add*.  
\v 35 زِي قَابَارُوثْ-هَاثَاآوَاثْ إِفْسِي ڒْڭنْسْ إِقِيضَانْ \add نّسْ\add*، \add ؤُيُورنْ\add* غَارْ حَاضَايْرُوثْ ؤُشَا قِّيمنْ ذِي حَاضَايْرُوثْ.   
\b  
\b  
\m  
\c 12
\s1 ڒْبَارْصْ ن مَارْيَامْ  
\m
\v 1 ثسِّيوڒْ مَارْيَامْ أَكْ-ذ هَارُونْ خْ مُوسَا ذِي سِّيبّثْ ن ثمْغَارْثْ ثَاكُوشِيثْ نِّي ثُوغَا د-يِيوِي، مِينْزِي نتَّا يِيوِي-د إِشْثْ ن ثمْغَارْثْ ثَاكُوشِيثْ. \f ◼ \fr 12:‏1 \ft \+bd ’ثَاكُوشِيثْ‘\+bd* - إِخْسْ أَذْ يِينِي ’ثَامْغَارْثْ زِي ثمُّورْثْ ن كُوشْ‘. ثَامُّورْثْ ن كُوشْ ثُوغَا-ت ذِي إِفْرِيقِييَّا مَانِي ثدْجْ إِضَا ثَامُّورْثْ ن سُّوذَانْ ذ ثمُّورْثْ ن إِثِييُوبِييَّا (أَلْ-هَابَاشْ).\f*  
\v 2 ؤُشَا نَّانْ: ”مَا إِسِّيوڒْ سِيذِي زِي مُوسَا وَاهَا؟ مَا وَارْ زَّايْنغْ إِسِّيوڒْ عَاوذْ؟“ ؤُشَا إِسْڒَا سِيذِي \add مَانْ أَيَا\add*.  
\v 3 ثُوغَا مُوسَا ذ أَرْيَازْ أَمْوَاضعْ أَطَّاسْ، كْثَارْ زِي مَارَّا إِوْذَانْ إِ إِدَّارنْ خْ ثمُّورْثْ.  
\v 4 ذغْيَا إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ هَارُونْ ذ مَارْيَامْ: ”فّْغمْ كنِّيوْ س ثْڒَاثَا، \add ؤُيُورمْ\add* غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ!“ ؤُشَا فّْغنْ-د س ثْڒَاثَا.  
\v 5 \add خنِّي\add* إِهْوَا-د سِيذِي ذڭْ ؤُقلِّيجْ ن ؤُسيْنُو ؤُشَا إِبدّْ غَارْ وَاذَافْ ن ؤُقِيضُونْ، إِڒَاغَا إِ هَارُونْ ذ مَارْيَامْ. فّْغنْ-د نِيثْنِي س ثْنَاينْ.  
\v 6 ؤُشَا إِنَّا أَسنْ نتَّا: ”سْڒمْ خنِّي إِ وَاوَاڒنْ إِنُو! مَاڒَا ذِينْ جَارْ أَومْ إِجّْ ن ؤُنَابِي، أَذْ أَسْ سّشْنغْ إِخفْ إِنُو، نشّْ، سِيذِي، س إِجْ ن ڒوْحِييْ \add ؤُشَا\add* أَذْ كِيسْ سِّيوْڒغْ س إِشْثْ ن ثَارْجِيثْ.  
\v 7 \add مَاشَا\add* وَارْ تّڭّغْ \add أَمنِّي\add* س ؤُمْسخَّارْ إِنُو مُوسَا، أَقَا نتَّا ذ أَمْثِيقِّي ذِي ثَادَّارْثْ إِنُو ثكْمڒْ. \x ◘ \xo 12:‏7 \xt عبر. 3‏:‏2\x*  
\v 8 نشّْ سِّيوْڒغْ أَكِيذسْ زڭْ ؤُقمُّومْ غَارْ ؤُقمُّومْ، وَارْ إِدْجِي س ڒمْعَانِي إِنُّوفَارنْ. أَقَا إِژْرَا أَدُّوذْ ن سِيذِي. مَايمِّي وَارْ ثڭّْوِيذمْ زڭْ ؤُمْسخَّارْ إِنُو ؤُ \add مَايمِّي\add* إِ ثسِّيوْڒمْ \add أَمُّو\add* خْ مُوسَا؟“ \x ◘ \xo 12:‏8 \xt ؤُف. 33‏:‏11؛ أَعَوذ. 34‏:‏10 \x*   
\m
\v 9 \add خنِّي\add* يَارْغَا خَاسنْ وغْضَابْ ن سِيذِي ؤُشَا إِرُوحْ.  
\v 10 ؤُشَا أَسيْنُو إِفّغْ خْ ؤُقِيضُونْ، ؤُشَا خْزَارْ، مَارْيَامْ ذَايسْ ڒهْڒَاشْ ن ڒْبَارْصْ، أَقَا-ت ذ ثَاشمْڒَاڒْثْ أَمْ وذْفڒْ. ؤُشَا هَارُونْ إِنّقْڒبْ-د غَارْ مَارْيَامْ، ؤُ خْزَارْ، أَقَا نتَّاثْ ذَايسْ ڒْبَارْصْ.   
\m
\v 11 ؤُشَا إِنَّا هَارُونْ إِ مُوسَا: ”أَ، سِيذِي إِنُو، وَارْ خَانغْ سْرُوسِّي دّنْبْ إِ نڭَّا س ثفْغُورِي ؤُمِي ذَايسْ نخْضَا!  
\v 12 وَارْ ت تّجِّي أَذْ ثذْوڒْ أَمْ ؤُمتِّينْ إِ زِي إِتّْوَاشّْ وزْينْ ن أَرِّيمثْ نّسْ أَمْ د-ثفّغْ زِي ڒمْڒَاوثْ ن يمَّاسْ.“  
\v 13 إِڒَاغَا مُوسَا إِ سِيذِي، إِنَّا: ”\add أَ\add* أَربِّي، تّْزَاوَاڭغْ أَذْ ت ثسّْڭنْفِيذْ!“  
\v 14 إِنَّا سِيذِي إِ مُوسَا: ”مَا مَاڒَا بَابَاسْ أَقَا إِنْخَارْ ذڭْ وُوذمْ نّسْ، مَا وَارْ ثسضْحِي سبْعَا ن وُوسَّانْ؟ أجّْ إِ-ت أَذْ ثتّْوَاسُّوفّغْ زِي ڒْمَارْڭحْ ن ڒْعسْكَارْ سبْعَا ن وُوسَّانْ ؤُشَا أَوَارْنِي أَسْ أَذْ ثتّْوَاقْبڒْ \add عَاوذْ\add*.“  
\v 15 ثتّْوَاسُّوفّغْ مَارْيَامْ سبْعَا ن وُوسَّانْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ ؤُشَا ڒْڭنْسْ وَارْ إِكِّيسْ إِقِيضَانْ نّسْ أَڒَامِي ثتّْوَاقْبڒْ مَارْيَامْ \add عَاوذْ\add*.  
\v 16 أَوَارْنِي مَانْ أَيَا إِفْسِي ڒْڭنْسْ إِقِيضَانْ نّسْ، \add يُويُورْ\add* زِي حَاضَايْرُوثْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ڒخْڒَا ن فَارَانْ.   
\b  
\b  
\m  
\c 13
\s1 ثنْعَاشْ ن إِبرْڭَاڭنْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”سكّْ إِرْيَازنْ زَّاثكْ حِيمَا أَذْ برْڭَاڭنْ ثَامُّورْثْ ن كنْعَانْ، ثنِّي إِ غَا وْشغْ إِ أَيْثْ ن إِسْرَائِيل. إِ كُوڒْ ثَاقْبِيتْشْ ن ڒجْذُوذْ أَذْ ثسّكّمْ إِجّْ ن ورْيَازْ، كُوڒْ إِجّْ \add أَذْ يِيڒِي\add* ذ ڒْحَاكمْ جَارْ أَسنْ.“ \f ◼ \fr 13:‏2 \ft \+bd ’كُوڒْ ثَاقْبِيتْشْ ن إِبَابَاثنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’كُوڒْ ثَاقْبِيتْشْ ن إِبَابَاثنْ نّسْ‘.\f*  
\v 3 مُوسَا إِسّكّْ إِ-ثنْ زِي ڒخْڒَا ن فَارَانْ، خْ ڒُومُورْ ن سِيذِي. ثُوغَا مَارَّا إِرْيَازنْ \add نِّي\add* ذ إِزدْجِيفنْ ن أَيْثْ ن إِسْرَائِيل.  
\v 4 أَقَا ذ إِنَا ذ إِسْمَاونْ نْسنْ:  
\b  
\m زِي ثقْبِيتْشْ ن رُوبِينْ، شَامُّوعْ، مِّيسْ ن زَاكُّورْ،   
\m
\v 5 زِي ثقْبِيتْشْ ن شِيمْعُونْ، شَافَاثْ، مِّيسْ ن أَخُورِي،   
\m
\v 6 زِي ثقْبِيتْشْ ن يَاهُوذَا، كَالِيبْ، مِّيسْ ن يَافُونِّي،   
\m
\v 7 زِي ثقْبِيتْشْ ن إِسَّاكَارْ، يِيجْعَالْ، مِّيسْ ن يُوسُوفْ،   
\m
\v 8 زِي ثقْبِيتْشْ ن إِفْرَايِيمْ، هُوشَاعْ، مِّيسْ ن نُونْ، \f ◼ \fr 13:‏8 \ft \+bd ’هُوشَاعْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَسنْجمْ‘. ثُوغَا إِسمْ وَانِيثَا ذ يِيسمْ أَمزْوَارُو ن يَاشُووَا ونِّي إِسِّيذْفنْ ڒْڭنْسْ ن إِسْرَائِيل ذِي ثمُّورْثْ ن كنْعَانْ.\f*   
\m
\v 9 زِي ثقْبِيتْشْ ن بِينْيَامِينْ، فَالْطِي، مِّيسْ ن رَافُو،   
\m
\v 10 زِي ثقْبِيتْشْ ن زابُولُونْ، جَاذِّييِيلْ، مِّيسْ ن سُوذِي،   
\m
\v 11 زِي ثقْبِيتْشْ ن يُوسُوفْ، إِ ثقْبِيتْشْ ن مَانَاسَّا، جَاذِّي، مِّيسْ ن سُوسِي،   
\m
\v 12 زِي ثقْبِيتْشْ ن ذَانْ، عَامِّييِيلْ، مِّيسْ ن جَامَالِّي،   
\m
\v 13 زِي ثقْبِيتْشْ ن أَشِيرْ، سَاثُورْ، مِّيسْ ن مِيخَايِيلْ،   
\m
\v 14 زِي ثقْبِيتْشْ ن نَافْثَالِي، نَاحْبِي، مِّيسْ ن وَافْسِي،   
\m
\v 15 زِي ثقْبِيتْشْ ن جَاذْ، جَا‘ؤُيِيلْ، مِّيسْ ن مَاكِي.   
\b  
\m
\v 16 أَقَا إِنَا ذ إِسْمَاونْ ن يرْيَازنْ نِّي إِسّكّْ مُوسَا حِيمَا أَذْ برْڭَاڭنْ ثَامُّورْثْ ؤُشَا مُوسَا إِڒَاغَا إِ هُوشِيعَا، مِّيسْ ن نُونْ، س يِيسمْ ن يَاشُووَا.  
\v 17 إِسّكّْ إِ-ثنْ مُوسَا حِيمَا أَذْ برْڭَاڭنْ ثَامُّورْثْ ن كنْعَانْ، إِنَّا أَسنْ: ”أَڒْيمْ سِّيهَا أَڒْ \add ثَامُّورْثْ ن\add* لْجَانُوبْ ؤُشَا أَڒْيمْ خنِّي غَارْ إِذُورَارْ،  
\v 18 ؤُشَا خْزَارمْ مَامّشْ ثدْجَا ثمُّورْثْ ذ ڒْڭنْسْ إِ ذَايسْ إِزدّْغنْ، مَا إِجْهذْ نِيغْ إِضْعفْ \add إِ يدْجَا\add*، مَا \add أَقَا ذِينْ\add* ذْرُوسْ نِيغْ أَطَّاسْ.  
\v 19 \add خْزَارمْ عَاوذْ\add* مَامّشْ ثدْجَا ثمُّورْثْ إِ ذِي إِزدّغْ \add ڒْْڭنْسْ\add*، مَا \add ثَامُّورْثْ\add* ذ ثَاصبْحَانْثْ نِيغْ ذ ثَاعفَّانْثْ إِ \add ثدْجَا\add*، ؤُ مَامّشْ دْجَانْثْ ثْندَّامْ إِ ذِي إِزدّغْ \add ڒْْڭنْسْ\add*، مَا \add زدّْغنْ ذِي\add* ڒمْرَاڭحْ ن إِقِيضَانْ نِيغْ \add ذِي\add* ثْندَّامْ إِفَارْينْ \add س إِغبْڒَاونْ\add*.  
\v 20 \add ؤُ عَاوذْ\add* مَامّشْ ثدْجَا ثمُّورْثْ، مَا ثسّْغمِّي نِيغْ ثُوژغْ، مَا أَقَا ذِينْ ثِيشجُّورَا نِيغْ لَّا. ڭّمْ ثَارْيَاسْثْ ؤُشَا كْسِيمْ \add شَا\add* زِي ڒْغِيدْجثْ ن ثمُّورْثْ. ؤُسَّانْ نِّي ثُوغَا أَثنْ ذ ؤُسَّانْ ن ثْمنْزُوثْ ن ؤُضِيڒْ.“  
\v 21 ؤُشَا نِيثْنِي ڭعّْذنْ ؤُشَا برْڭَاڭنْ ثَامُّورْثْ زِي ڒخْڒَا ن صِينْ أَڒْ رَاحُوبْ، مَانِي غَا ثِيوْضذْ غَارْ حَامَاثْ.  
\v 22 ڭعّْذنْ \add عَاذْ كْثَارْ\add* غَارْ \add ثمُّورْثْ ن\add* لْجَانُوبْ ؤُشَا إِوْضنْ غَارْ حَابْرُونْ. ذِينِّي إِ ثُوغَا أَخِيمَانْ، شِيشَايْ ذ ثَالْمَايْ، \add نِيثْنِي\add* ذ إِحنْجِيرنْ ن عَانَاقْ. حَابْرُونْ ثُوغَا ثتّْوَابْنَا سبْعَا ن إِسڭّْوُوسَا قْبڒْ صُوعَانْ ذِي مِيصْرَا.  
\v 23 \add خنِّي\add* إِوْضنْ أَڒْ ثَاغْزُورْثْ ن أَشْكُولْ ؤُشَا سّنِّي كّْسنْ إِشْثْ ن ثزْرمْثْ س يِيجّْ ن ؤُزكُّونْ ن ؤُضِيڒْ ونِّي د-إِوْينْ س ثْنَاينْ س يِيجّْ ن ؤُزدْجَاضْ ن ثْربُّوثْ. \add كّْسنْ عَاوذْ\add* زڭْ أَرمَّامْ ؤُ زِي ثَازَارْثْ. \f ◼ \fr 13:‏23 \ft \+bd ’أَشْكُولْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَزكُّونْ‘.\f*  
\v 24 قَّارنْ أَسْ إِ ومْشَانْ نِّي ثَاغْزُورْثْ ن إِشْكُولْ، \add إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي\add* ’ثَاغْزُورْثْ ن ؤُزكُّونْ‘، ذِي سِّيبّثْ ن ؤُزكُّونْ \add ن ؤُضِيڒْ\add* نِّي قسّنْ أَيْثْ ن إِسْرَائِيل ذِينْ.   
\b  
\m
\v 25 ؤُمِي كمّْڒنْ أَربْعِينْ ن وُوسَّانْ، ذوْڒنْ-د زڭْ ؤُبرْڭَاڭْ ن ثمُّورْثْ.  
\v 26 عقْبنْ نِيثْنِي ؤُشَا ؤُسِينْ-د غَارْ مُوسَا ذ هَارُونْ ؤُ غَارْ مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل ذِي ڒخْڒَا ن فَارَانْ، غَارْ قَاذَاشْ، ؤُشَا وْشِينْ ڒخْبَارْ إِ مَارَّا ثَامسْمُونْثْ ؤُشَا سّشْننْ أَسنْ ڒْغِيدْجثْ ن ثمُّورْثْ. \f ◼ \fr 13:‏26 \ft \+bd  %عقْبنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ؤُيُورنْ‘.\f*  
\v 27 حَاجَانْ أَسْ، نَّانْ: ”أَقَا نُوذفْ غَارْ ثمُّورْثْ نِّي مَانِي ذ أَنغْ ثسّكّذْ. س ثِيذتّْ ثْفيّضْ س ؤُغِي ذ ثَامّنْثْ ؤُ ثَانِيثَا ذ ڒْغِيدْجثْ نّسْ. \x ◘ \xo 13:‏27 \xt ؤُف. 3‏:‏8؛ 33‏:‏3\x*  
\v 28 مَاشَا ڒْڭنْسْ، ونِّي إِزدّْغنْ ذِي ثمُّورْثْ، إِجْهذْ ؤُ ثِيندَّامْ غَارْسنْثْ إِغبْرَاونْ مْغَارنْثْ أَطَّاسْ، ؤُ نژْرَا عَاوذْ أَرَّاونْ ن عَانَاقْ.  
\v 29 أَيْثْ ن عَامَالِيقْ زدّْغنْ ذِي ثمُّورْثْ ن لْجَانُوبْ، ؤُ إِحِيتِّييّنْ ذ إِيابُوسِييّنْ ذ إِمُورِييّنْ زدّْغنْ ذڭْ إِذُورَارْ ؤُ أَيْثْ ن كنْعَانْ زدّْغنْ غَارْ ڒبْحَارْ ؤُ خْ ثْمَا ن لْ-ؤُرْذُونْ.“  
\v 30 خنِّي إِسّسْقَارْ كَالِيبْ ڒْڭنْسْ زَّاثْ إِ مُوسَا، إِنَّا: ”أجّْ أَنغْ أَذْ نْڭعّذْ س جّهْذْ ؤُشَا أَذْ ت نطّفْ ذ ڒْوَارْثْ، \add مِينْزِي\add* نْزمَّارْ أَسْ نشِّينْ!“  
\v 31 \add مَاشَا\add* إِرْيَازنْ نِّي ڭعّْذنْ أَكِيذسْ، نَّانْ: ”وَارْ نْزمَّارْ أَذْ نْڭعّذْ ضِيدّْ إِ ڒْڭنْسْ نِّي، مِينْزِي أَقَا إِجْهذْ خَانغْ أَطَّاسْ.“  
\v 32 \add أَمُّو\add* إِ د-إِوْينْ إِجّْ ن ڒخْبَارْ وَارْ إِحْڒِينْ إِ أَيْثْ ن إِسْرَائِيل خْ ثمُّورْثْ نِّي خْ ثُوغَا تّْبرْڭَاڭنْ، نَّانْ: ”ثَامُّورْثْ خْ مَانِيسْ نكَّا حِيمَا أَذْ ت نْبرْڭڭْ، أَقَا ذ إِشْثْ ن ثمُّورْثْ ثْسَارّضْ إِمزْذَاغْ نّسْ ؤُشَا مَارَّا إِوْذَانْ نِّي نژْرَا، أَقَا أَثنْ ذ إِرْيَازنْ ن وَادَّاذْ إِمْغَارْ.  
\v 33 أَقَا نژْرَا ذِينْ ’نِيفِيلِيمْ‘، \add إِخْسْ أَذْ يِينِي\add* ’جّْوَاهڒْ إِوْضَانْ‘، أَيْثْ ن عَانَاقْ، أَرَّاسَا ن جّْوَاهڒْ إِوْضَانْ. ثُوغَا نشِّينْ ذِي ثِيطَّاوِينْ نّغْ أَمشْنَاوْ ثَامُورْغِي ؤُشَا أَمُّو إِ د أَسنْ نتّْبَانْ ذِي ثِيطَّاوِينْ نْسنْ.“ \f ◼ \fr 13:‏33 \ft \+bd ’نِيفِيلِيمْ‘\+bd* - أَقَا-ثنْ لْمَالَاكَاثْ إِ إِوْضَانْ زڭْ ومْشَانْ نْسنْ ذڭْ ؤُجنَّا ؤُمِي دّنْبنْ ضِيدّْ إِ سِيذِي. خْزَارْ أَمز. 6:4. \+bd ’ثَامُوغْرِي‘\+bd* - س ثْعِيبْرَانِيثْ ’ثَامُوغْرِي إِڒحّْفنْ‘.\f*   
\b  
\b  
\m  
\c 14
\s1 ثِيڭّْوُوذِي ن ڒْڭنْسْ زِي ڒْعذْيَانْ  
\m
\v 1 مَارَّا ثَامسْمُونْثْ ثبْذَا ثسْغُويُّو س جّهْذْ ؤُشَا ڒْڭنْسْ إِرُو مَارَّا دْجِيڒثْ نِّي.  
\v 2 مَارَّا أَيْثْ ن إِسْرَائِيل ثُوغَا تّْنذْقَامنْ ضِيدّْ إِ مُوسَا ؤُ ضِيدّْ إِ هَارُونْ ؤُشَا ثنَّا أَسْ مَارَّا ثْمسْمُونْثْ: ”معْلِيكْ قَاعْ نمُّوثْ ذِي ثمُّورْثْ ن مِيصْرَا!“ نِيغْ: ”معْلِيكْ قَاعْ نمُّوثْ ذِي ڒخْڒَا-يَا!“  
\v 3 ”مَايمِّي ذ أَنغْ د-يِيوِي سِيذِي غَارْ ثمُّورْثْ-أَ حِيمَا أَذْ نوْضَا س سِّيفْ ؤُ \add خنِّي\add* أَذْ ذوْڒنْثْ ثمْغَارِينْ نّغْ ذ ثَارْوَا نّغْ ذ ثَاكشَّاضْثْ؟ مَا وَارْ يدْجِي حْسنْ زعْمَا أَذْ نعْقبْ غَارْ مِيصْرَا؟“  
\v 4 ؤُشَا نَّانْ إِجّْ إِ ونّغْنِي: ”أجّْ أَنغْ أَذْ نڭّْ إِجّْ ذ أَزدْجِيفْ \add خَانغْ\add* ؤُشَا أَذْ نعْقبْ غَارْ مِيصْرَا!“   
\m
\v 5 \add ڒخْذنِّي\add* وْضَانْ مُوسَا ذ هَارُونْ خْ ؤُغمْبُوبْ نْسنْ زَّاثْ إِ وُوذمْ ن مَارَّا أَڭْرَاوْ ن ثْمسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل.  
\v 6 يَاشُووَا، مِّيسْ ن نُونْ، ذ كَالِيبْ، مِّيسْ ن يَافُونِّي، إِنِّي ثُوغَا زڭْ إِنِّي ثُوغَا إِتّْبرْڭَاڭنْ خْ ثمُّورْثْ، شَارّْڭنْ أَرُّوضْ نْسنْ.  
\v 7 نِيثْنِي سِّيوْڒنْ غَارْ مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل، نَّانْ: ”ثَامُّورْثْ نِّي خْ نكَّا مَاحنْذْ أَذْ ت نْبرْڭڭْ، أَقَا-ت ذ إِشْثْ ن ثمُّورْثْ مْلِيحْ أَطَّاسْ.  
\v 8 مَاڒَا سِيذِي إِسّْفَارْننْ غَارْنغْ، نتَّا أَذْ أَنغْ د-يَاوِي غَارْ ثمُّورْثْ-أَ ؤُشَا أَذْ أَنغْ ت إِوْشْ، إِشْثْ ن ثمُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ.  
\v 9 مَاشَا وَارْ تِّيڒِيمْ ذ إِمْغوّْغنْ ضِيدّْ إِ سِيذِي ؤُشَا وَارْ تّڭّْوذمْ شَا زِي ڒْڭنْسْ ن ثمُّورْثْ-أَ، مِينْزِي أَقَا أَثنْ ذ أَغْرُومْ نّغْ. ثِيڒِي نْسنْ ثفّغْ-د سنّجْ نْسنْ، أَقَا سِيذِي أَكِيذْنغْ، وَارْ زَّايْسنْ تّڭّْوْذمْ شَا!“ \x ◘ \xo 14:‏9 \xt أَعَوذ. 20‏:‏3\x*   
\m
\v 10 \add مَاشَا ڒَامِي\add* ثسِّيوڒْ مَارَّا ثَامسْمُونْثْ بلِّي إِتّْخصَّا أَذْ ثنْ أَرجْمنْ، إِبَانْ-د ؤُعُودْجِي ن سِيذِي ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ زَّاثْ إِ مَارَّا أَيْثْ ن إِسْرَائِيل.   
\m
\v 11 إِنَّا سِيذِي إِ مُوسَا: ”أَڒْ مڒْمِي ذ أَيِي غَا إِسْعَارْ ڒْڭنْسْ-أَ؟ أَڒْ مڒْمِي وَارْ ذ أَيِي تِّيمْننْ س مَارَّا ڒعْڒَامَاثْ نِّي ڭِّيغْ ذِي ڒْوسْطْ نْسنْ؟  
\v 12 نشّْ أَذْ ثنْ وْثغْ س طَّاعُونْ ؤُشَا أَذْ خَاسنْ كّْسغْ ڒْوَارْثْ ؤُشَا أَذْ شكْ ڭّغْ ذ إِجّْ ن ڒْڭنْسْ ذ أَمقّْرَانْ، إِجْهذْ خَاسنْ.“  
\v 13 إِنَّا مُوسَا إِ سِيذِي: ”أَذْ سْڒنْ إِمِيصْرِييّنْ مَانْ أَيَا، مِينْزِي شكْ ثسُّوفّْغذْ ڒْڭنْسْ-أَ س جّهْذْ نّشْ زِي ڒْوسْطْ نْسنْ. \x ◘ \xo 14:‏13 \xt ؤُف. 32‏:‏12\x*  
\v 14 ؤُشَا أَذْ ث إِنِينْ إِ إِمزْذَاغْ ن ثمُّورْثْ-أَ، إِنِّي إِسْڒِينْ بلِّي شكْ، \add أَ\add* سِيذِي، ذِي ڒْوسْطْ ن ڒْڭنْسْ-أَ، بلِّي شكْ، أَ سِيذِي، ثْبَانذْ-د \add أَمشْنَاوْ\add* ؤُذمْ ذڭْ وُوذمْ، بلِّي أَسيْنُو نّشْ إِتّْبدَّا سنّجْ نْسنْ ؤُ بلِّي شكْ ثڭُّورذْ زَّاثْ إِ وُوذمْ نْسنْ ذڭْ إِجّْ ن ؤُقلِّيجْ ن ؤُسيْنُو س ؤُزِيڒْ ؤُشَا س دْجِيڒثْ ذڭْ إِجّْ ن ؤُقلِّيجْ ن ثْمسِّي. \f ◼ \fr 14:‏14 \ft \+bd ’ؤُذمْ ذڭْ وُوذمْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ثِيطّْ ذِي ثِيطّْ‘.\f*  \x ◘ \xo 14:‏14 \xt ؤُف. 13‏:‏21؛ 40‏:‏38\x*  
\v 15 مَاڒَا ثنْغِيذْ ڒْڭنْسْ-أَ أَمْ يِيجّْ ن ورْيَازْ، خنِّي ڒڭْنُوسْ نِّي إِسْڒِينْ خْ ؤُسمْغَارْ نّشْ أَذْ سِّيوْڒنْ أَذْ إِنِينْ:  
\v 16 ’مِينْزِي سِيذِي وَارْ إِزمَّارْ أَذْ إِسِّيذفْ ڒْڭنْسْ-أَ ذِي ثمُّورْثْ نِّي خْ إِجُّودْجْ \add أَذْ أَسنْ ت إِوْشْ\add*، أَقَا س ؤُينِّي ذ أَسنْ إِغَارْصْ ذِي ڒخْڒَا!‘ \x ◘ \xo 14:‏16 \xt أَعَوذ. 9‏:‏28 \x*  
\v 17 ڒخُّو خنِّي، أجّْ أَذْ يِيڒِي جّهْذْ ن سِيذِي إِنُو إِمْغَارْ أَمْ مَامّشْ ثُوغَا ثسِّيوْڒذْ، ثنِّيذْ:  
\v 18 ’سِيذِي غَارسْ تَّاسِيعْ ن ڒْخَاضَارْ ؤُڒَا ذ أَطَّاسْ ن ثْمخْسِيوْثْ إِشوَّارنْ. أَقَا يَاربُّو ڒْمُوعْصِييّثْ ذ ؤُخطُّو \add نّغْ\add* ؤُ نتَّا وَارْ إِتّْبَارِّي ونِّي إِتّڭّنْ دّنْبْ \add ؤُ\add* إِسّعّْذُو ڒْمُوعْصِييّثْ ن إِبَابَاثنْ غَارْ إِحنْجِيرنْ \add نّسْ\add* أَڒْ \add جِّيڒْ\add* وِيسّْ ثْڒَاثَا ذ \add جِّيڒْ\add* وِيسّْ أَربْعَا.‘ \x ◘ \xo 14:‏18 \xt ؤُف. 20‏:‏5؛ 34‏:‏6؛ أَعَوذ. 5‏:‏9؛ إِزهد. 86‏:‏15؛ 103‏:‏8؛ 145‏:‏8؛ يُون. 4‏:‏2\x*  
\v 19 غْفَارْ إِ ڒْڭنْسْ-أَ ڒْمُوعْصِييّثْ نّسْ عْلَاحْسَابْ ڒمْغَارثْ ن ثْمخْسِيوْثْ نّشْ إِشوَّارنْ ؤُ أَمْ مَامّشْ ثْهمْڒذْ أَكْ-ذ ڒْڭنْسْ-أَ زِي ثمُّورْثْ ن مِيصْرَا أَڒْ ذَانِيثَا!“   
\m
\v 20 إِنَّا سِيذِي: ”نشّْ غْفَارغْ أَسنْ عْلَاحْسَابْ أَوَاڒْ نّشْ.  
\v 21 س ثِيذتّْ \add أَمْ\add* دَّارغْ نشّْ، أَقَا مَارَّا ثَامُّورْثْ أَذْ ثتّْوَاشُّورْ س ؤُعُودْجِي ن سِيذِي!  
\v 22 مِينْزِي مَارَّا إِرْيَازنْ نِّي إِژْرِينْ أَعُودْجِي إِنُو ذ ڒعْڒَامَاثْ إِنُو إِ ڭِّيغْ ذِي مِيصْرَا ؤُ ذِي ڒخْڒَا، ذ يِينِّي ذ أَيِي إِقدْجْبنْ ذِي ڒخْڒَا \add عَاذْ\add*عشْرَا ن ثْوَاڒَاوِينْ ؤُ وَارْ سْڒِينْ إِ ثْمِيجَّا إِنُو،  
\v 23 وَارْ ژَترّنْ ثَامُّورْثْ نِّي خْ جُّودْجغْ إِ ڒجْذُوذْ نْسنْ \add أَذْ أَسنْ ت وْشغْ\add*، \add وَاهْ،\add* مَارَّا إِنِّي ذ أَيِي إِسّْدُّوقّْزنْ \add أَمُّو\add*، وَارْ ت ژَترّنْ. \x ◘ \xo 14:‏23 \xt أَعَوذ. 1‏:‏35، 36 \x*  
\v 24 \add مَاشَا\add* أَذْ سِّيوْضغْ أَمْسخَّارْ إِنُو كَالِيبْ غَارْ ثمُّورْثْ مَانِي ثُوغَا يُوذفْ \add قْبڒْ\add* ؤُشَا أَذْ ت وَارْثنْ ثَارْوَا نّسْ، مِينْزِي ثُوغَا أَكِيذسْ إِجّْ ن أَرُّوحْ نّغْنِي ؤُشَا نتَّا إِضْفَارْ أَيِي نِيشَانْ. \x ◘ \xo 14:‏24 \xt ياش. 14‏:‏8، 9\x*  
\v 25 أَقَا أَيْثْ ن عَامَالِيقْ ذ أَيْثْ ن كنْعَانْ زدّْغنْ ذِي ڒوْضَا ن ثغْزُورْثْ. أَذْ د-ثْذوْڒمْ ثِيوشَّا ؤُشَا أَذْ ثكّْسمْ إِقِيضَانْ نْومْ \add سَّا\add*، فّْغمْ غَارْ ڒخْڒَا، \add ؤُيُورمْ\add* ذڭْ وبْرِيذْ غَارْ ڒبْحَارْ ن ثلْڭَا.“   
\b  
\m
\v 26 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ هَارُونْ، إِنَّا:   
\m
\v 27 ”أَڒْ مڒْمِي غَا ثقِّيمْ ثْمسْمُونْثْ-أَ ثَاعفَّانْثْ ثتّْنذْقَامْ خَافِي؟ أَنذْقمْ ن أَيْثْ ن إِسْرَائِيل إِ زِي خَافِي تّْنذْقَامنْ، أَقَا سْڒِيغْ ث. \x ◘ \xo 14:‏27 \xt إِزهد. 106‏:‏26 \x*  
\v 28 إِنِي أَسنْ: ’س ثِيذتّْ أَمْ دَّارغْ نشّْ، إِقَّارْ سِيذِي، مَاڒَا وَارْ ذ أَومْ تّڭّغْ أَمْ مَامّشْ ذ أَومْ سْڒِيغْ س إِمزُّوغنْ إِنُو مِينْ ثنَّامْ كنِّيوْ. \x ◘ \xo 14:‏28 \xt ڒخْڒ. 26‏:‏65؛ 32‏:‏11 \x*  
\v 29 ڒْخشْبَاثْ نْومْ أَذْ وْضَانْثْ ذِي ڒخْڒَا-يَا، \add ڒْخشْبَاثْ ن\add* مَارَّا إِنِّي إِتّْوَاحسْبنْ \add ن ڒْڭنْسْ\add*، مَارَّا ڒْقدّْ ن إِحنْجِيرنْ نْومْ زِي عِيشْڒِينْ إِسڭّْوُوسَا سنّجْ إِ ثُوغَا خَافِي إِتّْنذْقَامنْ. \x ◘ \xo 14:‏29 \xt أَعَوذ. 1‏:‏35؛ عبر. 3‏:‏17 \x*  
\v 30 كنِّيوْ وَارْ ثتِّيذْفمْ شَا غَارْ ثمُّورْثْ مِينْ خفْ سّْڭعّْذغْ أَفُوسْ إِنُو \add مَاحنْذْ أَذْ جَّادْجغْ\add* أَذْ كنِّيوْ ڭّغْ أَذْ ذَايسْ ثْزذْغمْ، مْغِيرْ كَالِيبْ، مِّيسْ ن يَافُونِّي، ذ يَاشُووَا، مِّيسْ ن نُونْ. \x ◘ \xo 14:‏30 \xt ياش. 14‏:‏6 \x*  
\v 31 ثَارْوَا نْومْ إِ خفْ ثنَّامْ: ’أَذْ تّْوَاكشّْضنْ!‘، نشّْ أَذْ ثنْ سِّيذْفغْ ذَايسْ ؤُشَا نِيثْنِي أَذْ سّْننْ ثَامُّورْثْ نِّي ثنْضَارمْ كنِّيوْ أَمُّو س ؤُسحْقَارْ.  
\v 32 \add مَاشَا\add* ڒْخشْبَاثْ نْومْ، \add وَاهْ،\add* كنِّيوْ \add سِيمَانْثْ نْومْ\add*، أَذْ ثوْضَامْ ذِي ڒخْڒَا-يَا،  
\v 33 ؤُشَا إِحنْجِيرنْ نْومْ أَذْ ثلّْعنْ ذِي ڒخْڒَا-يَا ڒْمِيجَاڒْ ن أَربْعِينْ ن إِسڭّْوُوسَا ؤُشَا كنِّيوْ أَذْ \add كِيومْ\add* ثَارْبُومْ فَارْقْ-شّْغڒْ نْومْ أَڒْ غَا فْنَانْثْ ڒْخشْبَاثْ نْومْ ذِي ڒخْڒَا.  
\v 34 أَنشْثْ إِ ڒْقدّْ ن وُوسَّانْ إِ ثُوغَا ثتّْبرْڭَاڭمْ ثَامُّورْثْ، \add إِقَّارْ\add* أَربْعِينْ ن وُوسَّانْ - أَقَا إِجّْ ن وَاسّْ ذ إِجّْ ن ؤُسڭّْوَاسْ - أَذْ ثَارْبُومْ ڒْمُوعْصِييّثْ نْومْ، ڒْمِيجَاڒْ ن أَربْعِينْ ن إِسڭّْوُوسَا. كنِّيوْ أَذْ ثسّْنمْ أَقَا نشّْ بعّْذغْ \add خَاومْ\add*. \x ◘ \xo 14:‏34 \xt إِزهد. 95‏:‏1 \x*  
\v 35 نشّْ \add ذ\add* سِيذِي سِّيوْڒغْ: مَاڒَا وَارْ تّڭّغْ أَمُّو أَكْ-ذ مَارَّا ثَامسْمُونْثْ-أَ ثَاعفَّانْثْ ثنِّي إِكّْسنْ أَوَاڒْ خَافِي: أَذْ مّْثنْ ذِي ڒخْڒَا-يَا، أَذْ مّْثنْ ذِينْ!“   
\m
\v 36 إِرْيَازنْ نِّي إِسّكّْ مُوسَا مَاحنْذْ أَذْ برْڭَاڭنْ ثَامُّورْثْ، \add ڒَْامِي\add* د-ذوْڒنْ، ثَامسْمُونْثْ أَمْ ثكْمڒْ ثذْوڒْ ضِيدّْ نّسْ ؤُمِي نِيثْنِي سِّيوْڒنْ س ڒْغَارْ خْ ثَامُّورْثْ،  
\v 37 أَقَا إِرْيَازنْ نِّي إِبهْذْڒنْ ثَامُّورْثْ، مُّوثنْ س إِشْثْ ن جّْرِيحشْثْ زَّاثْ إِ وُوذمْ ن سِيذِي. \x ◘ \xo 14:‏37 \xt 1 كُور. 10‏:‏10؛ يَاه. 5\x*  
\v 38 \add مَاشَا\add* يَاشُووَا، مِّيسْ ن نُونْ، ذ كَالِيبْ، مِّيسْ ن يَافُونِّي، قِّيمنْ دَّارنْ جَارْ إِرْيَازنْ نِّي إِرُوحنْ أَذْ برْڭَاڭنْ ثَامُّورْثْ.   
\b  
\m
\v 39 إِسِّيوڒْ مُوسَا أَوَاڒنْ-أَ غَارْ مَارَّا أَيْثْ ن إِسْرَائِيل. إِحْزنْ \add خنِّي\add* ڒْڭنْسْ أَطَّاسْ.  
\v 40 ؤُشَا نِيثْنِي كَّارنْ زِيشْ ؤُشَا ؤُڒْينْ أَڒْ ثَاقِيشَّاثْ ن وذْرَارْ، نَّانْ: ”أَقَا-نغْ ذَا ؤُشَا أَذْ نْڭعّذْ غَارْ ومْشَانْ مِينْ خفْ إِسِّيوڒْ سِيذِي، مِينْزِي نشِّينْ أَقَا نخْضَا!“  
\v 41 مَاشَا مُوسَا إِنَّا: ”مَايمِّي ثتّْعدَّامْ أَمُّو ڒُومُورْ ن سِيذِي؟ مَانْ أَيَا وَارْ إِعدُّو! \x ◘ \xo 14:‏41 \xt أَعَوذ. 1‏:‏41\x*  
\v 42 وَارْ تّْڭعِّيذمْ شَا مِينْزِي سِيذِي وَارْ إِتِّيڒِي ذِي ڒْوسْطْ نْومْ. وَارْ تّجِّيمْ إِخفْ نْومْ أَذْ ثخْسَارمْ زَّاثْ إِ وُوذمْ ن ڒْعذْيَانْ نْومْ.  
\v 43 مِينْزِي أَيْثْ ن عَامَالِيقْ ذ أَيْثْ ن كنْعَانْ أَقَا أَثنْ ذِينْ زَّاثْ نْومْ ؤُشَا أَذْ ثوْضَامْ كنِّيوْ س سِّيفْ مِينْزِي كنِّيوْ ثِيڭّْوجمْ خْ سِيذِي. س ؤُيَا سِيذِي وَارْ كِيومْ إِتِّيڒِي.“  
\v 44 مَاشَا نِيثْنِي ثُوغَا تُّوفّنْ مَاحنْذْ أَذْ د-أَڒْينْ أَڒْ ثَاقِيشَّاثْ ن وذْرَارْ. \add مَاشَا\add* تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي ذ مُوسَا وَارْ فِّيغنْ زِي ڒْوسْطْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ.  
\v 45 \add خنِّي\add* هْوَانْ-د أَيْثْ ن عَامَالِيقْ ذ أَيْثْ ن كنْعَانْ نِّي ثُوغَا إِزدّْغنْ ذڭْ وذْرَارْ نِّي ؤُشَا أَرنْينْ ثنْ ؤُ ڒبْزنْ ثنْ أَڒْ حُورْمَا.   
\b  
\b  
\m  
\c 15
\s1 ثِيغَارْصَا ن ثْمسِّي  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، إِنِي أَسنْ: ’خْمِي غَا ثَاذْفمْ غَارْ ثمُّورْثْ \add مَانِي غَا\add* ثْزدّْغمْ، \add ثَامُّورْثْ\add* نِّي ذ أَومْ غَا وْشغْ،  
\v 3 ؤُشَا أَذْ ثسّْوجْذمْ \add ذِينْ\add* إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي، إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ نِيغْ إِشْثْ ن ثوْهِيبْثْ إِ ثْغَارْصْثْ إِ ؤُكمّڒْ ن إِجّْ ن لْوَاعْذْ نِيغْ إِشْثْ ن ثوْهِيبْثْ س ڒْخَاضَارْ نِيغْ \add إِشْثْ ن ثوْهِيبْثْ\add* إِ ڒعْيُوذَاثْ نْومْ إِتّْوَاڭّنْ، مَاحنْذْ أَذْ ثِيڒِي ذ إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي، زِي ڒبْهَايمْ نِيغْ زڭْ وُودْجِي،  
\v 4 \add خنِّي\add* ونِّي د غَا إِقدّْمنْ ثَاوْهِيبْثْ نّسْ إِ سِيذِي، أَذْ يَاوِي \add عَاوذْ\add* إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* زڭْ إِشْثْ ن ثعْشَارْثْ \add ن يِيجّْ ن إِفَا\add* ن وَارنْ أَزْذَاذْ إِخدْجْضنْ س يِيجّْ ن أَرْبعْ ن إِجّْ ن ؤُهِينُو ن زّشْثْ. \x ◘ \xo 15:‏4 \xt لَاوِي 2‏:‏1؛ 6‏:‏14\x*  
\v 5 أَذْ ثسّْوجْذذْ \add أَكْ-ذ مَانْ أَيَا\add* إِجّْ ن أَرْبعْ ن إِجّْ ن ؤُهِينُو ن بِينُو أَمْ ثوْهِيبْثْ ن ؤُسيّبْ إِ كُوڒْ إِجّْ ن إِزْمَارْ، \add مَاحنْذْ أَذْ ثِيڒِي\add* خْ ثْغَارْصْثْ ن وشْمَاضْ نِيغْ خْ ثوْهِيبْثْ إِ ثْغَارْصْثْ،  
\v 6 نِيغْ، \add مَاڒَا أَذْ ثِيڒِي\add* إِ يِيجّْ ن إِشَارِّي، \add خنِّي\add* إِتّْخصَّا أَذْ ثسّْوجْذذْ إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* زِي ثْنَاينْ ن ثعْشُورَايْ ن إِجّْ ن إِفَا ن وَارنْ أَزْذَاذْ إِخدْجْضنْ س إِشْثْ ن تُّوڒُوثْ ن إِجّْ ن ؤُهِينُو ن زّشْثْ،  
\v 7 ؤُشَا أَذْ ثْقدّْمذْ \add عَاوذْ\add* إِشْثْ ن تُّوڒُوثْ ن إِجّْ ن ؤُهِينُو ن بِينُو أَمْ ثوْهِيبْثْ ن ؤُسيّبْ، أَمْ يِيشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي.‘ “   
\m
\v 8 ”خْمِي غَا ثسّْوجْذذْ أَمژْيَانْ ن ؤُفُونَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ نِيغْ أَمْ ثوْهِيبْثْ إِ ثْغَارْصْثْ \add مَاحنْذْ أَذْ يِيڒِي\add* إِ ؤُكمّڒْ ن إِجّْ ن لْوَاعْذْ نِيغْ أَمْ ثْغَارْصْثْ ن ڒهْنَا إِ سِيذِي،  
\v 9 \add خنِّي\add* إِتّْخصَّا أَذْ ثْقدّْمذْ أَكْ-ذ ؤُمژْيَانْ ن ؤُفُونَاسْ \add عَاوذْ\add* إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ن ثْڒَاثَا ن ثعْشُورَايْ ن إِجّْ ن \add إِفَا\add* ن وَارنْ أَزْذَاذْ إِخدْجْضنْ ذڭْ وزْينْ ن ؤُهِينُو ن زّشْثْ،  
\v 10 ؤُشَا إِتّْخصَّا \add عَاوذْ\add* أَذْ د-ثَاوْيذْ أَزْينْ ن ؤُهِينُو ن بِينُو أَمْ ثوْهِيبْثْ ن ؤُسيّبْ، \add أَمْ\add* ثوْهِيبْثْ ن ثْمسِّي، إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي.  
\v 11 أَمُّو إِ إِتّْخصَّا أَذْ ڭّنْ إِ \add كُوڒْ\add* أَفُونَاسْ، نِيغْ إِ \add كُوڒْ\add* إِشَارِّي، نِيغْ إِ \add كُوڒْ\add* إِجّْ زڭْ وُودْجِي، زڭْ إِحُوڒِييّنْ نِيغْ زڭْ إِغَايْضنْ.  
\v 12 عْلَاحْسَابْ ڒْقدّْ \add ن إِمُودَّارنْ إِ ثْغَارْصْثْ\add* إِ غَا ثسّْوجْذمْ، أَذْ ثڭّمْ أَمُّو إِ كُوڒْ إِجّْ \add ن ؤُمُودَّارْ\add*، عْلَاحْسَابْ ڒْقدّْ إِكمّْڒنْ \add ن إِمُودَّارنْ\add*.  
\v 13 مَارَّا إِنِّي د-إِتّْوَاخڒْقنْ ذِي ثمُّورْثْ أَذْ ڭّنْ ثِيمسْڒَايِينْ-أَ أَمُّو، خْمِي د غَا قدّْمنْ نِيثْنِي إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي، إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي.  
\v 14 خْمِي غَا ثَافذْ جَارْ \add مَارَّا\add* جِّيڒَاثْ نْومْ إِجّْ ن ؤُبَارَّانِي إِ إِقِّيمنْ أَكِيذْومْ، نِيغْ إِجّنْ ونِّي \add إِزدّْغنْ\add* ذِي ڒْوسْطْ نْومْ، أَقَا نتَّا أَذْ إِسّوْجذْ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي، إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي، \add خنِّي\add* أَذْ \add ت\add* إِڭّْ أَمْ مَامّشْ \add ت\add* ثتّڭّمْ كنِّيوْ.“   
\m
\v 15 \add أَيْ،\add* أَڭْرَاوْ \add ن ڒْڭنْسْ\add*، أَذْ ذِينْ ثِيڒِي إِشْثْ ن ثوْصيّثْ، إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ كنِّيوْ ؤُ إِ ؤُبَارَّانِي نِّي \add أَكِيذْومْ\add* إِقِّيمنْ إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ. أَذْ يِيڒِي ؤُبَارَّانِي أَمْ مَامّشْ \add ثدْجَامْ\add* كنِّيوْ زَّاثْ إِ وُوذمْ ن سِيذِي. \x ◘ \xo 15:‏15 \xt ؤُف. 12‏:‏49؛ ڒخْڒ. 9‏:‏14 \x*  
\v 16 أَذْ يِيڒِي إِجّْ ن ؤُزرْفْ ذ إِشْثْ ن لْفَارِيضَا إِ كنِّيوْ ؤُ إِ ؤُبَارَّانِي نِّي أَكِيذْومْ إِقِّيمنْ.“   
\b  
\m  
\s1 إِمزْوُورَا ن وَارنْ  
\m
\v 17 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 18 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ: ’خْمِي غَا ثَاذْفمْ غَارْ ثَامُّورْثْ مَانِي كنِّيوْ غَا \add يْ\add*أَوْيغْ،  
\v 19 \add خنِّي\add* أَذْ إِمْسَارْ، ؤُمِي غَا ثشّمْ أَغْرُومْ \add زِي ڒْغِيدْجثْ\add* ن ثمُّورْثْ، أَقَا كنِّيوْ أَذْ ثسّْڭعّْذمْ إِشْثْ ن ثوْهِيبْثْ ن ؤُسْڭعّذْ إِ سِيذِي.  
\v 20 زِي ثْمزْوَارُوثْ ن وَارشْثِي نْومْ أَذْ ثسّْڭعّْذمْ إِشْثْ ن ثمْسمّنْثْ \add أَمْ\add* ثوْهِيبْثْ ن ؤُسْڭعّذْ. أَذْ ت ثسّْڭعّْذمْ أَمْ مَامّشْ ثسّْڭعّْذمْ ثَاوْهِيبْثْ ن ؤُسْڭعّذْ ن ؤُنذْرَارْ.  
\v 21 زِي ثْمزْوَارُوثْ ن وَارشْثِي نْومْ أَذْ ثْقدّْممْ إِشْثْ ن ثوْهِيبْثْ ن ؤُسْڭعّذْ إِ سِيذِي ذِي \add مَارَّا\add* جِّيڒَاثْ نْومْ.‘ “   
\b  
\m  
\s1 دّنْبْ وَارْ إِدْجِي نعْمَاذَا  
\m
\v 22 ”مَاڒَا ثْودَّارمْ ؤُ وَارْ ثتّڭّمْ مَارَّا ڒُومُورَاثْ-أَ إِ ثُوغَا إِسَّاوَاڒْ سِيذِي أَكْ-ذ مُوسَا  
\v 23 - مَارَّا مِينْ ذ أَومْ يُومُورْ سِيذِي س ثْسخَّارْثْ ن مُوسَا زڭْ وَاسّْ مِينْ زِي \add ث\add* يُومُورْ سِيذِي، سّنِّي ذ ثْسَاونْثْ، ذِي \add مَارَّا\add* رجْيُوڒْ نْومْ -  
\v 24 \add خنِّي\add* أَذْ إِمْسَارْ، \bd مَاڒَا إِتّْوَاڭّْ س ؤُودَّارْ\bd* بَارَّا إِ ثِيطَّاوِينْ ن ثْمسْمُونْثْ، أَقَا ثَامسْمُونْثْ مَارَّا أَذْ ثسّوْجذْ إِجّْ ن ؤُفُونَاسْ، أَمژْيَانْ ن ثْفُونَاسْثْ، أَمْ ثْغَارْصْثْ ن وشْمَاضْ، \add أَمْ\add* إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي أَكْ-ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبْثْ نّسْ ن ؤُسيّبْ عْلَاحْسَابْ لْفَارِيضَا ؤُ أَكْ-ذ يِيجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ أَمْ ثْغَارْصْثْ ن دّنْبْ.  
\v 25 \add خنِّي\add* أَذْ إِڭّْ ؤُكهَّانْ أَسْڒَاحْ إِ مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل ؤُشَا أَذْ أَسنْ إِتّْوَاغْفَارْ، مِينْزِي مَانْ أَيَا إِمْسَارْ زڭْ ؤُودَّارْ، ؤُشَا نِيثْنِي قدّْمنْ ثَاوْهِيبْثْ نْسنْ، إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي، ؤُڒَا ذ ثَاغَارْصْثْ نْسنْ ن دّنْبْ، زَّاثْ إِ وُوذمْ ن سِيذِي. \f ◼ \fr 15:‏25 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  
\v 26 مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل أَذْ ثتّْوَاغْفَارْ، ؤُڒَا ذ أَبَارَّانِي نِّي إِزدّْغنْ ذِي ڒْوسْطْ نْومْ، خْ ؤُمِي إِمْسَارْ أَمْ إِودَّارْ مَارَّا ڒْڭنْسْ.“   
\m
\v 27 ”مَاڒَا إِجّنْ بْنَاذمْ إِخْضَا أَمْ نتَّا إِودَّارْ، \add خنِّي\add* أَذْ د-إِسّْقَارّبْ إِشْثْ ن ثْغَايْضثْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن دّنْبْ. \f ◼ \fr 15:‏27 \ft \+bd ’بْنَاذمْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ‘. أَمُّو ؤُڒَا ذِي أَيَاثْ وِيسّْ 28 ذ 30.\f*  \x ◘ \xo 15:‏27 \xt لَاوِي 4‏:‏27 \x*  
\v 28 أَكهَّانْ أَذْ إِڭّْ أَصْڒَاحْ زَّاثْ إِ وُوذمْ ن سِيذِي خْ بْنَاذمْ نِّي ثُوغَا إِودَّارْ، أَمْ ثُوغَا إِخْضَا س ؤُودَّارْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَمْ خَاسْ إِ غَا يڭّْ أَسْڒَاحْ ؤُشَا \add خنِّي\add* أَذْ أَسْ إِتّْوَاغْفَارْ.   
\m
\v 29 أَذْ \add ذِينْ\add* يِيڒِي إِجّْ ن ؤُزرْفْ إِ ونِّي إِڭِّينْ \add شَا\add* س ؤُودَّارْ، إِ ونِّي د-إِخڒْقنْ ذِي ثمُّورْثْ ؤُڒَا إِ ؤُبَارَّانِي نِّي إِزدّْغنْ ذِي ڒْوسْطْ نْومْ.“   
\m  
\s1 دّنْبْ س ؤُفُوسْ إِڭعّْذنْ  
\m
\v 30 ”مَاشَا بْنَاذمْ نِّي إِڭِّينْ شَا \bd س ؤُفُوسْ إِڭعّْذنْ\bd*، مَا نتَّا إِتّْوَاخْڒقْ-د ذِي ثمُّورْثْ نِيغْ نتَّا ذ أَبَارَّانِي، أَقَا نتَّا إِشقّفْ ذِي سِيذِي ؤُشَا بْنَاذمْ نِّي أَذْ إِتّْوَاقسّْ زِي ڒْوسْطْ ن ڒْڭنْسْ نّسْ، \f ◼ \fr 15:‏30 \ft \+bd ’س ؤُفُوسْ إِسّْڭعّْذنْ‘\+bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي أَقَا إِڭَّا إِ-ث س نعْمَاذَا.\f*  
\v 31 ؤُمِي إِسّحْقَارْ أَوَاڒْ ن سِيذِي ؤُ يَارْژَا ڒُومُورْ نّسْ. بْنَاذمْ نِّي أَذْ إِتّْوَاقسّْ قَاعْ \add زِي ڒْڭنْسْ نّسْ\add*، ڒْمُوعْصِييّثْ نّسْ أَذْ ثِيڒِي خَاسْ.“   
\b  
\m
\v 32 \add ڒَْامِي\add* ثُوغَا أَيْثْ ن إِسْرَائِيل ذِي ڒخْڒَا، ؤُفِينْ إِجّْ ن ورْيَازْ إِتّْحَارْوَاشْ أَكشُّوضْ ذڭْ وَاسّْ ن سّبْثْ.  
\v 33 إِنِّي ث يُوفِينْ أَمْ ثُوغَا إِتّْحَارْوَاشْ أَكشُّوضْ، إِوْينْ ث غَارْ مُوسَا ذ هَارُونْ ذ مَارَّا ثَامسْمُونْثْ.  
\v 34 ڭِّينْ ث ذِي ثْحطُّوثْ، مِينْزِي ثُوغَا وَارْ د-إِبِينْ مِينْ زَّايسْ غَا ڭّنْ. \x ◘ \xo 15:‏34 \xt لَاوِي 24‏:‏12 \x*  
\v 35 \add خنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”أَرْيَازْ \add نِّي\add* أَذْ إِتّْوَانغْ نِيشَانْ. مَارَّا ثَامسْمُونْثْ أَذْ ث ثَارْجمْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ.“  
\v 36 \add خنِّي\add* ثسُّوفّغْ إِ-ث مَارَّا ثْمسْمُونْثْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ ؤُشَا نِيثْنِي أَرجْمنْ ث أَڒَامِي إِمُّوثْ، أَمْ مَامّشْ \add ث\add* يُومُورْ سِيذِي إِ مُوسَا.   
\b  
\m  
\s1 ثِيشَارْشِيفَا ن ڒِْيذَارثْ  
\m
\v 37 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 38 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ، أَذْ ڭّنْ إِ يِيخفْ نْسنْ ثِيشَارْشِيفَا غَارْ ثْغمُّورَا ن وَارُّوضْ نْسنْ ذِي \add مَارَّا\add* جِّيڒَاثْ نْسنْ ؤُشَا أَذْ ڭّنْ إِجّْ ن ؤُفِيڒُو ذ أَذحْمِي غَارْ ثْشَارْشِيفَا، ثِينِّي غَارْ ثْغمُّورَا. \x ◘ \xo 15:‏38 \xt أَعَوذ. 22‏:‏12؛ مت. 23‏:‏5 \x*  
\v 39 أَذْ يِيڒِي \add ؤُفِيڒُو\add* غَارْ ثْشَارْشِيفْثْ، حِيمَا أَذْ ثْوَاڒَامْ أَفِيڒُو نِّي ؤُشَا أَذْ ثِيذَارمْ ذِي مَارَّا ڒُومُورَاثْ ن سِيذِي ؤُشَا أَذْ ثنْثْ ثڭّمْ ؤُ وَارْ ثْضفَّارمْ \add شّهْوَاثْ ن\add* وُوڒَاونْ نْومْ ذ ثِيطَّاوِينْ نْومْ، إِنِّي أَوَارْنِي أَسنْثْ ثنُّوممْ أَذْ ثسّفْسذمْ إِخفْ نْومْ،  
\v 40 \add ؤُ\add* حِيمَا أَذْ ثْخَارّْصمْ ذِي ڒُومُورَاثْ إِنُو، أَذْ \add زَّايْسنْثْ\add* ثڭّمْ، \add مَاحنْذْ\add* أَذْ ثِيڒِيمْ ثتّْوَاقدّْسمْ زَّاثْ إِ أَربِّي نْومْ.  
\v 41 نشّْ ذ سِيذِي، أَربِّي نْومْ ونِّي كنِّيوْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا حِيمَا أَذْ إِڒِيغْ ذ أَربِّي نْومْ. نشّْ ذ سِيذِي، أَربِّي نْومْ!“   
\b  
\b  
\m  
\c 16
\s1 أَغوّغْ ن قُورَاحْ ذ ذَاثَانْ ذ أَبِيرَامْ  
\m
\v 1 قُورَاحْ، مِّيسْ ن يِيصْهَارْ، مِّيسْ ن قَاهَاثْ، مِّيسْ ن لَاوِي، أَكْ-ذ ذَاثَانْ ذ أَبِيرَامْ، ثْنَاينْ ن إِحنْجِيرنْ ن إِلِييَابْ، ذ ؤُنْ، مِّيسْ ن فَالَاثْ، إِحنْجِيرنْ ن رُوبِينْ، إِوْينْ \add إِرْيَازنْ\add*، \x ◘ \xo 16:‏1 \xt ڒخْڒ. 26‏:‏9؛ 27‏:‏3؛ يَاه. 11\x*  
\v 2 ؤُشَا كَّارنْ ضِيدّْ إِ مُوسَا، \add جْمِيعْ\add* أَكْ-ذ إِرْيَازنْ \add نّغْنِي\add* زڭْ أَيْثْ ن إِسْرَائِيل، مِيثَاينْ ؤُ-خمْسِينْ ن ڒْحُوكَّامْ ن ثْمسْمُونْثْ، أَقَا أَثنْ زڭْ إِنِّي د-إِتّْوَاڒَاغَانْ غَارْ ؤُمُونِي، إِرْيَازنْ س شَّانْ.  
\v 3 نِيثْنِي مُوننْ ضِيدّْ إِ مُوسَا ذ هَارُونْ، نَّانْ أَسنْ: ”شْفَا أَومْ كنِّيوْ! مِينْزِي مَارَّا ثَامسْمُونْثْ، \add وَاهْ،\add* مَارَّا نِيثْنِي ذ إِمْقدَّاسنْ ؤُشَا سِيذِي ذِي ڒْوسْطْ نْسنْ. مَايمِّي ثسُّوعْڒَامْ إِخفْ نْومْ سنّجْ إِ وڭْرَاوْ \add ن ڒْڭنْسْ\add* ن سِيذِي؟“   
\m
\v 4 ؤُمِي إِسْڒَا مُوسَا \add إِ مَانْ أَيَا\add*، إِوْضَا خْ وُوذمْ نّسْ.  
\v 5 ؤُشَا إِسِّيوڒْ أَكْ-ذ قُورَاحْ ذ مَارَّا أَبَارُّو نّسْ، إِنَّا: ”ثِيوشَّا أَذْ إِسّْشنْ سِيذِي ونِّي إِدْجَانْ نّسْ ذ ونِّي \add إِدْجَانْ\add* ذ أَمْقدَّاسْ ذ ونِّي إِ غَارسْ د غَا إِسّْقَارّبْ. ونِّي إِفَارْزْ نتَّا، ذ ونِّي إِ د غَا إِسّْقَارّبْ نتَّا غَارسْ.  
\v 6 ڭّمْ أَيَا! أجّْ قُورَاحْ ذ مَارَّا أَبَارُّو نّسْ أَذْ أَوْينْ ثِيمجْمَارِينْ.  
\v 7 ثِيوشَّا ڭّمْ خَاسنْثْ \add ڒفْحمْ إِ\add* ثْمسِّي، سَارْسمْ خَاسْ ڒبْخُورْ زَّاثْ إِ وُوذمْ ن سِيذِي. \add خنِّي\add* أَذْ إِمْسَارْ بلِّي أَرْيَازْ نِّي إِخْضَارْ سِيذِي، أَذْ يِيڒِي ذ أَمْقدَّاسْ. أَقَا ثْرُوحمْ ثِيڭّْوِيجمْ، أَيْثْ ن لَاوِي!“  
\v 8 إِنَّا مُوسَا إِ قُورَاحْ: ”سْڒمْ ڒخُّو، تّْزَاوَاڭغْ، كنِّيوْ، أَيْثْ ن لَاوِي!  
\v 9 مَا وَارْ خَاومْ إِشْفِي ؤُمِي كنِّيوْ إِسّْفَارْزْ أَربِّي ن إِسْرَائِيل خْ ثْمسْمُونْثْ ن إِسْرَائِيل مَاحنْذْ أَذْ كنِّيوْ غَارسْ د-إِسّْقَارّبْ، حِيمَا أَذْ ثْسخَّارمْ ذِي ثْزذِّيغْثْ ن سِيذِي ؤُشَا \add حِيمَا\add* أَذْ ثْبدّمْ زَّاثْ إِ وُوذمْ ن ثْمسْمُونْثْ مَاحنْذْ أَذْ ثنْ ثْسخَّارمْ؟  
\v 10 نتَّا إِسّْقَارّبْ إِ شكْ-د \add غَارسْ\add*، شكْ ذ مَارَّا أَيْثْمَاشْ، أَيْثْ ن لَاوِي، \add جْمِيعْ\add* أَكِيذكْ. مَا ثَارزُّومْ \add ڒخُّو\add* عَاوذْ ثُوكهَّانْثْ؟  
\v 11 س ؤُيَا، شكْ ذ مَارَّا أَبَارُّو نّشْ، أَقَا كنِّيوْ ثْمُونمْ ضِيدّْ ن سِيذِي، مِينْزِي مِينْ إِعْنَا هَارُونْ، مِينْ إِعْنَا حِيمَا أَذْ خَاسْ ثنّذْقمْ؟“   
\m
\v 12 ؤُشَا إِسّكّْ مُوسَا أَذْ ڒَاغَانْ خْ ذَاثَانْ ذ أَبِيرَامْ، إِحنْجِيرنْ ن إِلِييَابْ، مَاشَا نِيثْنِي نَّانْ: ”وَارْ د-نتِّيسْ شَا!“  
\v 13 مَا وَارْ إِدْجِي إِشْفَا أَومْ ؤُمِي ذ أَنغْ د-ثْسُّوفّْغمْ زڭْ إِشْثْ ن ثمُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ، حِيمَا أَذْ أَنغْ ثسّْهلّكذْ ذِي ڒخْڒَا ؤُشَا \add خنِّي\add* عَاوذْ ثڭّذْ إِخفْ نّشْ ذ ڒْحَاكمْ خَانغْ؟  
\v 14 ؤُڒَا ذ شكْ وَارْ ذ أَنغْ د-ثسِّيذْفذْ شَا ذڭْ إِشْثْ ن ثمُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ، ؤُ وَارْ ذ أَنغْ ثوْشِيذْ إِيَّارْ\add أنْ\add* ذ إِمَارْجَاعنْ ن ؤُضِيڒْ ذ ڒْوَارْثْ. مَا إِتّْغِيڒْ أَشْ ثْزمَّارذْ أَذْ ثسّْذَاغْڒذْ ثِيطَّاوِينْ ن يرْيَازنْ-أَ؟ نشِّينْ وَارْ د-نتِّيسْ شَا!“   
\m
\v 15 \add خنِّي\add* إِتّْوَاسَّارْغْ ؤُفُوڭمْ ن مُوسَا، إِنَّا إِ سِيذِي: ”وَارْ خزَّارْ غَارْ ثوْهِيبْثْ نْسنْ! نشّْ وَارْ زَّايْسنْ كسِّيغْ قَاعْ إِجّْ ن ؤُغْيُوڒْ ؤُشَا وَارْ ڭِّيغْ ڒْغَارْ ؤُڒَا إِ يِيجّْ زَّايْسنْ.“ \x ◘ \xo 16:‏15 \xt 1 صم. 12‏:‏3\x*   
\m
\v 16 إِنَّا مُوسَا إِ قُورَاحْ: ”شكْ ذ مَارَّا أَبَارُّو نّشْ، \add أَسمْ-د\add* ثِيوشَّا زَّاثْ إِ وُوذمْ ن سِيذِي، شكْ ذ نِيثْنِي، ذ هَارُونْ.  
\v 17 كْسِيمْ كُوڒْ إِجّْ \add زَّايْومْ\add* إِجّْ ن ڒْمجْمَارْ، ڭّمْ ذَايسْ ڒبْخُورْ ؤُشَا قَارّْبمْ-د أَكِيذسْ زَّاثْ إِ وُوذمْ ن سِيذِي. كُوڒْ أَرْيَازْ أَكْ-ذ ڒْمجْمَارْ نّسْ، مِيثَاينْ ؤُ-خمْسِينْ ن ثْمجْمَارِينْ، ؤُشَا \add عَاوذْ\add* شكْ ذ هَارُونْ، كُوڒْ إِجّْ \add أَكْ-ذ\add* ڒْمجْمَارْ نّسْ.“  
\v 18 إِكْسِي كُوڒْ إِجّْ ڒْمجْمَارْ نّسْ ؤُشَا ڭِّينْ ذَايسْ ثِيمسِّي ؤُ سَّارْسنْ خَاسْ ڒبْخُورْ ؤُشَا ؤُيُورنْ أَذْ بدّنْ زَّاثْ إِ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، ؤُڒَا ذ مُوسَا ذ هَارُونْ.  
\v 19 قُورَاحْ إِغوّغْ خَاسنْ مَارَّا أَبَارُّو \add نّسْ\add* غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. \add ڒخْذنِّي\add* إِبَانْ-د ؤُعُودْجِي ن سِيذِي غَارْ مَارَّا ثَامسْمُونْثْ.   
\b  
\m
\v 20 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ هَارُونْ، إِنَّا:   
\m
\v 21 ”حيْذمْ إِخفْ نْومْ زڭْ ؤُبَارُّو-يَا، \add خنِّي\add* أَذْ ثنْ هلّْكغْ ذڭْ ورْمَاشْ ن وَابْڒِيونْ!“  
\v 22 \add مَاشَا\add* نِيثْنِي وْضَانْ خْ وُوذمْ نْسنْ، نَّانْ: ”\add أَ\add* أَربِّي، أَربِّي ن مَارَّا بُوحْبڒَاثْ ن مَارَّا دَّاثْ! \add مَاڒَا\add* إِخْضَا إِجّْ ن ورْيَازْ، مَا \add خنِّي\add* أَذْ ثڭّذْ أَغْضَابْ نّشْ أَذْ إِدُّوقّزْ خْ مَارَّا ثَامسْمُونْثْ؟“ \x ◘ \xo 16:‏22 \xt ڒخْڒ. 27‏:‏16؛ عبر. 12‏:‏9 \x*   
\m
\v 23 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 24 ”سِيوڒْ أَكْ-ذ ثْمسْمُونْثْ، إِنِي: ’بعّْذمْ خْ ثْزذِّيغْثْ ن قُورَاحْ ذ ذَاثَانْ ذ أَبِيرَامْ ذ مِينْ ذ أَسْ د-إِنّْضنْ.‘ “  
\v 25 \add خنِّي\add* مُوسَا إِكَّارْ ؤُشَا إِرُوحْ غَارْ ذَاثَانْ ذ أَبِيرَامْ ؤُشَا ؤُيُورنْ إِمْغَارنْ ن إِسْرَائِيل أَوَارْنِي أَسْ.  
\v 26 ؤُشَا إِسِّيوڒْ نتَّا أَكْ-ذ ثْمسْمُونْثْ، إِنَّا: ”تّْزَاوْڭغْ، بعّْذمْ خْ إِقِيضَانْ ن يرْيَازنْ-أَ إِقجْحنْ ؤُ وَارْ تّْحَاذَامْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ ن مِينْ إِدْجَانْ نْسنْ، حِيمَا كنِّيوْ وَارْ ثتّْوَاهلِّيكمْ شَا س دّْنُوبْ نْسنْ!“  
\v 27 كَّارنْ نِيثْنِي ؤُشَا بعّْذنْ خْ إِقِيضَانْ ن قُورَاحْ ذ ذَاثَانْ ذ أَبِيرَامْ ذ مِينْ ذ أَسْ د-إِنّْضنْ. ذَاثَانْ ذ أَبِيرَامْ فّْغنْ-د، بدّنْ غَارْ وَاذَافْ ن إِقِيضَانْ نْسنْ أَكْ-ذ ثمْغَارِينْ نْسنْ ذ إِحنْجِيرنْ نْسنْ ذ إِحنْجِيرنْ نْسنْ إِمژْيَاننْ.  
\v 28 \add خنِّي\add* إِنَّا مُوسَا: ”س مَانْ أَيَا إِ غَا ثسّْنمْ بلِّي سِيذِي إِسّكّْ أَيِي-د، حِيمَا أَذْ ڭّغْ مَارَّا ثِيمڭَّا-يَا، مِينْزِي وَارْ د-فِّيغنْثْ شَا زڭْ وُوڒْ إِنُو.  
\v 29 مَاڒَا إِنَا أَذْ مّْثنْ أَمْ مَامّشْ \add مُّوثنْ\add* إِوْذَانْ مَارَّا ؤُ أَذْ ثنْ إِڒْقفْ مِينْ إِڒقْفنْ مَارَّا إِوْذَانْ، \add خنِّي\add* أَذْ ثَافْ سِيذِي وَارْ ذ أَيِي د-إِسّكّْ.  
\v 30 \add مَاشَا\add* مَاڒَا سِيذِي إِخْڒقْ-د شَا ن ڒْحَاجّثْ ذ ثَامَايْنُوثْ قَاعْ ؤُشَا ثَامُّورْثْ أَذْ ثَارْزمْ أَقمُّومْ نّسْ، أَذْ ثنْ ثْسَارْضْ أَكْ-ذ مَارَّا \add مِينْ إِدْجَانْ\add* نْسنْ ؤُشَا أَذْ هْوَانْ دَّارنْ ذِي ڒَاخَارْثْ، خنِّي إِ غَا ثسّْنمْ بلِّي إِرْيَازنْ-أَ أَقَا سّْذُوقّْزنْ سِيذِي.“   
\m
\v 31 ؤُشَا إِمْسَارْ، ؤُمِي إِكمّڒْ أَوَاڒنْ-أَ، ثْفدْجقْ ثمُّورْثْ نِّي سْوَادَّايْ نْسنْ.  
\v 32 ثَارْزمْ ثمُّورْثْ أَقمُّومْ نّسْ ؤُشَا ثْسَارْضْ إِ-ثنْ أَكْ-ذ أَيْثْبَابْ ن ثَادَّارْثْ نْسنْ ؤُ أَكْ-ذ مَارَّا إِوْذَانْ ن قُورَاحْ ذ مَارَّا أَڭْڒَا \add نْسنْ\add*. \x ◘ \xo 16:‏32 \xt ڒخْڒ. 26‏:‏10؛ 27‏:‏3؛ أَعَوذ. 11‏:‏6؛ إِزهد. 106‏:‏17\x*  
\v 33 هْوَانْ-د دَّارنْ ذِي ڒَاخَارْثْ أَكْ-ذ مَارَّا \add مِينْ إِدْجَانْ\add* نْسنْ ؤُشَا ثَامُّورْثْ ثسّْذُورِييْ إِ-ثنْ ؤُ تّْوَاثحَّانْ زِي ڒْوسْطْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add*.  
\v 34 مَارَّا إِسْرَائِيل، إِنِّي ثُوغَا د-إِنّْضنْ، أَروْڒنْ \add ؤُمِي سْڒِينْ\add* إِ ثْغُويِّيثْ نْسنْ، مِينْزِي نَّانْ: ”نِيغْ أَذْ ثَافْ \add ؤُڒَا ذ نشِّينْ\add* أَذْ أَنغْ ثْصَارْضْ ثمُّورْثْ.“  
\v 35 ؤُشَا ثفّغْ-د ثْمسِّي زِي سِيذِي، ثشَّا مِيثَاينْ ؤُ-خمْسِينْ ن يرْيَازنْ نِّي د-يِيوْينْ ڒبْخُورْ.   
\b  
\b  
\m  
\c 17
\s1 جّْرِيحشْثْ إِنقّنْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”إِنِي إِ أَلِيعَازَارْ، مِّيسْ ن ؤُكهَّانْ هَارُونْ، بلِّي أَذْ إِكْسِي ثِيمجْمَارِينْ زڭْ ؤُحَاذُوقْ ن ثْمسِّي ؤُشَا أَذْ إِسُّويسْ \add مِينْ إِقِّيمنْ ن\add* ثْمسِّي ذِي ڒَاڭّْوَاجْ، مِينْزِي أَقَا ثِيمجْمَارِينْ نِّي، قدّْسنْثْ إِ دْجَانْثْ!  
\v 3 جّمْ ثنْ أَذْ ڭّنْ زِي ثْمجْمَارِينْ ن \add يرْيَازنْ-أَ\add*، إِنِّي ثُوغَا إِخطَّانْ ضِيدّْ إِ ڒعْمُورْ نْسنْ، ثِيڒْوِيحِينْ ذ ثِيزِيرَارِينْ إِ دُّورِي إِ ؤُعَالْطَارْ، مِينْزِي إِوْينْ ثنْثْ زَّاثْ إِ وُوذمْ ن سِيذِي، س ؤُيَا تّْوَاقدّْسنْثْ ثِينَا. أَذْ إِڒِينْثْ ذ إِجّْ ن ؤُشيَّارْ إِ أَيْثْ ن إِسْرَائِيل.“  
\v 4 \add خنِّي\add* إِكْسِي ؤُكهَّانْ أَلِيعَازَارْ ثِيمجْمَارِينْ ن نّْحَاسْ نِّي د-إِوْينْ يِينِّي إِتّْوَاشمْضنْ \add إِ ثوْهِيبْثْ\add*، ؤُشَا ثْكثْكنْ ثنْثْ حِيمَا أَذْ \add زَّايْسنْثْ\add* ذْڒنْثْ أَعَالْطَارْ  
\v 5 إِ ڒِيذَارثْ إِ أَيْثْ ن إِسْرَائِيل، حِيمَا ؤُڒَا ذ إِجّْ ن ورْيَازْ وَارْ إِدْجِينْ زِي زَّارِيعثْ ن هَارُونْ، وَارْ د-إِتّْقَارِّيبْ شَا بْڒَا تّسْرِيحْ زَّاثْ إِ وُوذمْ ن سِيذِي، حِيمَا أَذْ إِسّْبخَّارْ ڒبْخُورْ، مَاحنْذْ وَارْ ذ أَسْ إِڒْقفْ مِينْ إِڒقْفنْ قُورَاحْ ذ ؤُبَارُّو نّسْ، أَمْ مَامّشْ ثُوغَا إِسِّيوڒْ سِيذِي س ؤُقمُّومْ ن مُوسَا.   
\m
\v 6 ثِيوشَّا نّسْ ثُوغَا مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل ثتّْنذْقَامْ ضِيدّْ إِ مُوسَا ذ هَارُونْ، نَّانْ: ”كنِّيوْ ثنْغِيمْ ڒْڭنْسْ ن سِيذِي!“  
\v 7 ؤُشَا \add ؤُمِي\add* ثْمُونْ ثْمسْمُونْثْ ضِيدّْ إِ مُوسَا ذ هَارُونْ ؤُشَا بْذَانْ نِيثْنِي ڭُّورنْ غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، خْزَارْ، أَقَا ذِينْ أَسيْنُو نِّي ث إِذْڒِينْ ؤُشَا إِبَانْ-د ؤُعُودْجِي ن سِيذِي.  
\v 8 يُوسَا-د مُوسَا أَكْ-ذ هَارُونْ، \add بدّنْ\add* زَّاثْ إِ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 9 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 10 ”كَّارمْ، \add أَڭّْوجمْ\add* زِي ڒْوسْطْ ن ثْمسْمُونْثْ ؤُ نشّْ أَذْ ثنْ مْحِيغْ ذڭْ إِجّْ ن ورْمَاشْ ن وَابْڒِيونْ!“ \add خنِّي\add* وْضَانْ خْ وُوذمْ نْسنْ.  
\v 11 إِنَّا مُوسَا إِ هَارُونْ: ”كْسِي \add ذغْيَا\add* إِجّْ ن ڒْمجْمَارْ، أڭّْ خَاسْ ثِيمسِّي ن ؤُعَالْطَارْ ؤُشَا سَارْسْ خَاسْ ڒبْخُورْ. أَزّڒْ غَارْ ثْمسْمُونْثْ ؤُشَا أڭّْ أَصْڒَاحْ ذِي طّْوعْ نْسنْ، مِينْزِي إِفّغْ-د ؤُذُوقّزْ \add ن وغْضَابْ\add* زِي زَّاثْ إِ وُوذمْ ن سِيذِي. أَقَا ذَا جّْرِيحشْثْ أَمْ ثبْذَا \add عَاذْ\add*.“  
\v 12 إِكْسِي هَارُونْ \add ڒْمجْمَارْ\add*، أَمْ مَامّشْ إِنَّا مُوسَا، ؤُشَا يُوزّڒْ غَارْ ڒْوسْطْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add*، ؤُشَا خْزَارْ، جّْرِيحشْثْ ثُوغَا أَمْ ثبْذَا \add عَاذْ\add* جَارْ ڒْڭنْسْ، ؤُشَا نتَّا إِسَّارْسْ ذَايسْ ڒبْخُورْ ؤُشَا إِڭَّا أَصْڒَاحْ ذِي طّْوعْ ن ڒْڭنْسْ. \f ◼ \fr 17:‏12 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  
\v 13 ثُوغَا إِبدّْ جَارْ إِمتَّانْ ذ إِمُودَّارنْ ؤُشَا ثتّْوَاسّْبدّْ جّْرِيحشْثْ.  
\v 14 وِي إِمُّوثنْ زِي جّْرِيحشْثْ ثُوغَا أَثنْ ذِي أَرْبعْطَاشْ-أَڒفْ ؤُ-سبْعَا-مْيَا، بْڒَا إِنِّي إِمُّوثنْ ذِي سِّيبّثْ ن قُورَاحْ.  
\v 15 إِذْوڒْ هَارُونْ غَارْ مُوسَا غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. أَقَا ثتّْوَاسّْبدّْ جّْرِيحشْثْ.   
\b  
\m  
\s1 ثَاغَّارْشْثْ إِزّيْزُوينْ ن هَارُونْ  
\m
\v 16 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 17 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا كْسِي زَّايْسنْ إِشْثْ ن ثغَّارْشْثْ إِ كُوڒْ ثَادَّارْثْ ن إِبَابَاثنْ \add نْسنْ\add*، زِي مَارَّا ڒْحُوكَّامْ نْسنْ، عْلَاحْسَابْ \add لْعَاذَاذْ ن\add* ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، ثنْعَاشْ ن ثغَّارْينْ. إِتّْخصَّا أَذْ ثَارِيذْ إِسمْ ن كُوڒْ إِجّْ \add زَّايْسنْ\add* خْ ثغَّارْشْثْ نّسْ.  
\v 18 أَذْ ثَارِيذْ إِسمْ ن هَارُونْ خْ ثغَّارْشْثْ ن لَاوِي، مِينْزِي \add أَذْ ذِينْ ثِيڒِي\add* إِشْثْ ن ثغَّارْشْثْ إِ يِيجّْ ن ؤُزدْجِيفْ ن ثَادَّارْثْ ن ڒجْذُوذْ نْسنْ.  
\v 19 أَذْ ثنْثْ ثڭّذْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، زَّاثْ إِ شّْهَاذثْ، مَانِي كِيذْومْ غَا مْسَاڭَارغْ. \x ◘ \xo 17:‏19 \xt ؤُف. 25‏:‏22 \x*  
\v 20 \add خنِّي\add* أَذْ إِمْسَارْ، أَقَا أَذْ ثْنُووَّارْ ثغَّارْشْثْ ن ورْيَازْ نِّي إِخْضَارغْ نشّْ ؤُشَا أَذْ سّْبدّغْ أَنذْقمْ ضِيدّْ إِنُو إِ زِي خَاومْ نّْذقْمنْ أَيْثْ ن إِسْرَائِيل.“   
\m
\v 21 إِسِّيوڒْ مُوسَا أَكْ-ذ أَيْثْ ن إِسْرَائِيل، ؤُشَا مَارَّا ڒْحُوكَّامْ نْسنْ وْشِينْ إِشْثْ ن ثغَّارْشْثْ إِ مْكُوڒْ إِجّْ ن ڒْحَاكمْ، عْلَاحْسَابْ \add ڒْقدّْ ن\add* ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، ثنْعَاشْ ن ثغَّارْينْ. ؤُشَا ثَاغَّارْشْثْ ن هَارُونْ ثُوغَا-ث جَارْ ثغَّارْينْ نْسنْ.  
\v 22 مُوسَا إِسَّارْسْ ثِيغَّارْينْ \add نِّي\add* زَّاثْ إِ وُوذمْ ن سِيذِي ذڭْ ؤُقِيضُونْ ن شّْهَاذثْ.  
\v 23 ثِيوشَّا نّسْ يُوذفْ مُوسَا غَارْ ؤُقِيضُونْ ن شّْهَاذثْ، ؤُشَا خْزَارْ، ثَاغَّارْشْثْ ن هَارُونْ ذِي طّْوعْ ن ثَادَّارْثْ ن لَاوِي ثُوغَا ثڭَّا ثَاشْڒَاڒْثْ ؤُشَا ثَاعبُّوزْثْ ثسُّوفّغْ-د ؤُشَا نُّووَّارْ \add نّسْ\add* يَارْزمْ ؤُشَا يِيوِي-د دْجُوزْ يِيوْضنْ.  
\v 24 خنِّي إِسُّوفّغْ مُوسَا مَارَّا ثِيغَّارْينْ زِي زَّاثْ إِ وُوذمْ ن سِيذِي غَارْ مَارَّا أَيْثْ ن إِسْرَائِيل. ژْرِينْ أَيَا ؤُشَا طّْفنْ كُوڒْ إِجّْ ثَاغَّارْشْثْ نّسْ.   
\m
\v 25 \add خنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”أَرّْ ثَاغَّارْشْثْ ن هَارُونْ زَّاثْ إِ شّْهَاذثْ، أَذْ ت ثحْضِيذْ أَمْ يِيجّْ ن ؤُشيَّارْ ضِيدّْ إِ يِينِّي إِغوّْغنْ. \add أَمُّو\add* إِ غَا ثسّْبدّذْ أَنذْقمْ نْسنْ ضِيدّْ إِنُو مَاحنْذْ نِيثْنِي وَارْ تّْمتِّينْ شَا.“ \x ◘ \xo 17:‏25 \xt عبر. 9‏:‏4\x*  
\v 26 ؤُشَا إِڭَّا مُوسَا أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي، أَمُّو إِ إِڭَّا نتَّا.  
\v 27 \add خنِّي\add* سِّيوْڒنْ أَيْثْ ن إِسْرَائِيل أَكْ-ذ مُوسَا، نَّانْ: ”خْزَارْ، أَذْ زَّايْنغْ إِفّغْ بُوحْبڒْ، أَذْ نتّْوَاهلّكْ، أَذْ نتّْوَاهلّكْ مَارَّا نشِّينْ!  
\v 28 مَانْ ونْ مَا إِ د غَا إِقَارّْبنْ غَارْ ؤُقِيضُونْ ن سِيذِي، أَذْ إِمّثْ. مَا أَذْ نتّْوَاثحَّا أَڒْ زَّايْنغْ إِفّغْ بُوحْبڒْ؟“   
\b  
\b  
\m  
\c 18
\s1 ڒحْمڒْ ذ ڒْمُونثْ ن إِكهَّاننْ ذ إِلَاوِييّنْ  
\m
\v 1 إِنَّا سِيذِي إِ هَارُونْ:  
\m ”شكْ ذ وَارَّاوْ نّشْ ذ ثَادَّارْثْ ن بَابَاشْ أَكِيذكْ، أَذْ ثَارْبُومْ ڒْمُوعْصِييّثْ ن زَّاوشْثْ إِقدّْسنْ نْومْ. شكْ ذ وَارَّاوْ نّشْ أَكِيذكْ أَذْ أَرْبُونْ ڒْمُوعْصِييّثْ ن ثُوكهَّانْثْ نْومْ.  
\v 2 أَذْ د-ثِيوْيذْ أَكِيذكْ ؤُڒَا ذ أَيْثْمَاشْ، ثَاقْبِيتْشْ ن لَاوِي، ثَاقْبِيتْشْ ن بَابَاشْ. نِيثْنِي أَذْ د-مَّارنْينْ غَاركْ، أَذْ أَشْ سخَّارنْ، \add مَاشَا\add* شكْ، جْمِيعْ أَكْ-ذ إِحنْجِيرنْ نّشْ، \add أَذْ ثْسخَّارذْ\add* زَّاثْ إِ وُوذمْ ن ؤُقِيضُونْ ن شّْهَاذثْ.  
\v 3 أَذْ طّْفنْ أَشْبَارْ نّشْ ؤُشَا أَذْ حْضَانْ خْ مَارَّا أَقِيضُونْ، مَاشَا وَارْ زمَّارنْ أَذْ د-قَارّْبنْ غَارْ ڒقْشُوعْ ن زَّاوشْثْ إِقدّْسنْ ؤُ غَارْ ؤُعَالْطَارْ حِيمَا وَارْ تّتّْمتِّينْ، وَارْ إِدْجِي ڒَا ذ نِيثْنِي ؤُڒَا ذ كنِّيوْ.  
\v 4 إِتّْخصَّا أَسنْ أَذْ مَّارنْينْ غَاركْ ؤُشَا أَذْ طّْفنْ أَشْبَارْ خْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُ خْ مَارَّا ثَاسخَّارْثْ ن ؤُقِيضُونْ. ونِّي وَارْ غَارْ إِدْجِي تّسْرِيحْ وَارْ إِزمَّارْ أَذْ غَارْومْ د-إِقَارّبْ.  
\v 5 أَذْ ثطّْفمْ أَشْبَارْ خْ زَّاوشْثْ إِقدّْسنْ ؤُڒَا خْ ؤُعَالْطَارْ، حِيمَا وَارْ د-إِتِّيسْ \add عَاذْ\add* ؤُذُوقّزْ \add ن وغْضَابْ\add* خْ أَيْثْ ن إِسْرَائِيل.  
\v 6 نشّْ، أَقَا ذَا نشّْ، كْسِيغْ أَوْمَاثنْ نْومْ، إِلَاوِييّنْ، زِي جَارْ ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل. أَقَا نِيثْنِي أَمْ يِيشْثْ ن ثوْهِيبْثْ إِ كنِّيوْ ثنِّي إِتّْخصَّا أَذْ ثْوهّْبمْ إِ سِيذِي مَاحنْذْ أَذْ سخَّارنْ نِيثْنِي ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. \x ◘ \xo 18:‏6 \xt ڒخْڒ. 3‏:‏45 \x*  
\v 7 \add مَاشَا\add* شكْ ذ إِحنْجِيرنْ نّشْ أَكِيذكْ أَذْ ثطّْفمْ ثُوكهَّانْثْ نْومْ ذِي مَارَّا مِينْ إِقّْننْ أَكْ-ذ ؤُعَالْطَارْ ذ مِينْ إِدْجَانْ ذَاخڒْ إِ ؤُڒحَّافْ ؤُشَا \add أَمُّو\add* أَذْ ثْسخَّارمْ كنِّيوْ. نشّْ أَذْ أَومْ وْشغْ ثُوكهَّانْثْ ذ ثْسخَّارْثْ أَمْ يِيشْثْ ن ثرْزفْثْ. أَبَارَّانِي نِّي د غَا إِقَارّْبنْ، أَذْ إِتّْوَانغْ.“   
\m
\v 8 إِسِّيوڒْ سِيذِي أَكْ-ذ هَارُونْ:  
\m ”نشّْ، خْزَارْ، أَقَا ذ نشّْ إِ ذ أَشْ إِوْشِينْ \add أَ\add*حطُّو خْ \add ثوْهِيبِينْ ن\add* ؤُسْڭعّذْ \add إِ قدّْمنْ نِيثْنِي\add* إِ نشّْ. نشّْ وْشِيغْ ثنْثْ أَكْ-ذ مَارَّا \add ثِيوْهِيبِينْ\add* إِقدّْسنْ ن أَيْثْ ن إِسْرَائِيل أَمْ ثسْغَارْثْ إِ خْ إِتّْوَاڭّْ وذْهَانْ، إِ شكْ ؤُ إِ وَارَّاوْ نّشْ، أَمْ يِيشْثْ ن ثوْصيّثْ إِ ڒبْذَا.  
\v 9 زِي \add ثوْهِيبِينْ\add* إِقدّْسنْ أَذْ إِڒِينْثْ إِزِييْنَاثْ إِ وَارْ يُوذِيفنْ غَارْ ثْمسِّي إِ شكْ: مَارَّا ثِيوْهِيبِينْ نْسنْ أَكْ-ذ مَارَّا ثِيوْهِيبِينْ نْسنْ \add ن ڒْغِيدْجثْ\add*، أَكْ-ذ مَارَّا ثِيغَارْصَا نْسنْ ن دّنْبْ ؤُ أَكْ-ذ مَارَّا ثِيغَارْصَا نْسنْ ن ؤُمَارْوَاسْ نِّي ذ أَيِي د غَا يَارّنْ \add أَمْ ثخْرِيصْثْ\add*. \add مَانْ أَيَا مَارَّا\add* أَذْ يِيڒِي ذ أَمْقدَّاسْ قَاعْ إِ شكْ ؤُ إِ إِحنْجِيرنْ نّشْ.  
\v 10 أَذْ ثشّذْ أَيَا ذڭْ إِجّْ ن ومْشَانْ إِقدّْسنْ قَاعْ. كُوڒْ أَوْثمْ أَذْ زَّايسْ يشّْ. أَيَا أَذْ يِيڒِي ذ أَمْقدَّاسْ إِ كنِّيوْ.“   
\m
\v 11 ”\add عَاوذْ\add* ذ مَانْ أَيَا \add أَذْ يِيڒِي\add* إِ شكْ: ثَاوْهِيبْثْ ن ؤُسْڭعّذْ ن ثوْهِيبْثْ نْسنْ أَكْ-ذ مَارَّا ثِيوْهِيبِينْ ن ونْهزِّي ن أَيْثْ ن إِسْرَائِيل. وْشِيغْ ثنْثْ إِ شكْ ؤُ إِ وَارَّاونْ نّشْ ذ ثَارَّاوِينْ نّشْ نِّي كِيذكْ \add إِدْجَانْ\add*. \add أَقَا-ت\add* ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا. كُوڒْ إِجّنْ ذِي ثَادَّارْثْ نّشْ نِّي إِدْجَانْ ذ أَمزْذَاڭْ، أَذْ زَّايْسنْثْ يشّْ.“ \x ◘ \xo 18:‏11 \xt لَاوِي 10‏:‏14\x*   
\m
\v 12 ”مِينْ إِدْجَانْ ڒمْخيَّارْ ن زّشْثْ ذ مِينْ إِدْجَانْ ڒمْخيَّارْ ن بِينُو ن جْذِيذْ ؤُ زڭْ إِرْذنْ، أَقَا ذ ثَامزْوَارُوثْ إِ زَّايْسنْ أَذْ وْشنْ إِ سِيذِي، أَقَا وْشِيغْ أَشْ ت.  
\v 13 ثَامنْزُوثْ ن مَارَّا مِينْ إِدْجَانْ خْ ثمُّورْثْ نْسنْ، نِّي د غَا يَاوْينْ غَارْ سِيذِي، أَقَا \add مَارَّا\add* مَانْ أَيَا أَذْ يِيڒِي إِ شكْ. كُوڒْ إِجّنْ ونِّي إِدْجَانْ ذ أَمزْذَاڭْ ذِي ثَادَّارْثْ نّشْ، إِزمَّارْ أَذْ زَّايسْ يشّْ.“   
\m
\v 14 ”مَارَّا مِينْ إِتّْوَاحَارّْمنْ ذِي إِسْرَائِيل، أَذْ يِيڒِي نّشْ. \x ◘ \xo 18:‏14 \xt لَاوِي 27‏:‏28\x*  
\v 15 مَارَّا مِينْ يَارزْمنْ ڒمْڒَاوَاثْ \add ذ أَمزْوَارُو\add* جَارْ مَارَّا أَيْسُومْ إِ غَا قدّْمنْ إِ سِيذِي، زِي بْنَاذمْ نِيغْ زِي ڒبْهِيمثْ، أَذْ يِيڒِي نّشْ. مَاشَا أَذْ ثفْذِيذْ قَاعْ أَمنْزُو ن إِوْذَانْ ؤُشَا إِتّْخصَّا \add عَاوذْ\add* أَذْ ثفْذِيذْ أَمنْزُو ن ڒبْهَايمْ إِخمْجنْ. \x ◘ \xo 18:‏15 \xt ؤُف. 13‏:‏2؛ 22‏:‏29؛ لَاوِي 27‏:‏26؛ ڒخْڒ. 3‏:‏13\x*  
\v 16 وِي زَّايْسنْ غَا تّْوَافْذِينْ نِيثْنِي، أَذْ تّْوَافْذِينْ ذ مِّيسْ ن إِجّْ ن ؤُيُورْ عْلَاحْسَابْ ڒْقِيمثْ إِ ثْقدَّارذْ شكْ ذِي نُّوقَارْثْ، خمْسَا شِيقْلُو عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ، ونِّي \add إِدْجَانْ\add* عِيشْرِينْ جِيرَا. \x ◘ \xo 18:‏16 \xt ؤُف. 30‏:‏13؛ لَاوِي 27‏:‏25؛ ڒخْڒ. 3‏:‏47؛ حِز. 45‏:‏12\x*  
\v 17 مَاشَا أَمنْزُو ن ؤُفُونَاسْ ذ ؤُمنْزُو ن ؤُحُوڒِي ذ ؤُمنْزُو ن إِغَايْضْ، وَارْ ث ثْفذِّيمْ شَا. أَقَا أَثنْ قدّْسنْ \add إِ دْجَانْ\add*. أَذْ ثْزدْجْعذْ إِذَامّنْ نْسنْ خْ ؤُعَالْطَارْ ؤُ ثَاذُونْثْ نْسنْ أَذْ ت ثسّْبخَّارذْ أَمْ ثوْهِيبْثْ ن ثْمسِّي، أَمْ يِيشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي.  
\v 18 أَيْسُومْ نّسْ أَذْ يِيڒِي نّشْ، أَمْ يِيذْمَارنْ ن ونْهزِّي أَمْ ؤُشكْرُوذْ أَفُوسِي أَذْ إِڒِينْ نّشْ.  
\v 19 مَارَّا \add ثِيوْهِيبِينْ ن\add* ؤُسْڭعّذْ زِي \add ثوْهِيبِينْ\add* إِقدّْسنْ نِّي غَا سّْڭعّْذنْ أَيْثْ ن إِسْرَائِيل إِ سِيذِي، وْشِيغْ ثنْثْ إِ شكْ ؤُ إِ إِحنْجِيرنْ نّشْ ذ ثْحنْجِيرِينْ نّشْ \add إِنِّي\add* أَكِيذكْ \add إِدْجَانْ\add*. \add أَقَا\add* ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا، أَذْ يِيڒِي ذ إِجّْ ن ڒْعَاهْذْ س ڒمْڒَاحثْ إِ ڒبْذَا زَّاثْ إِ وُوذمْ ن سِيذِي، إِ شكْ ؤُ إِ زَّارِيعثْ نّشْ نِّي أَكِيذكْ \add إِدْجَانْ\add*.“   
\m
\v 20 إِنَّا سِيذِي إِ هَارُونْ:  
\m ”وَارْ ثتّطّْفذْ ڒْوَارْثْ ذِي ثمُّورْثْ نْسنْ ؤُ وَارْ غَاركْ ثتِّيڒِي بُو ثسْغَارْثْ ذِي ڒْوسْطْ نْسنْ. نشّْ ذ ثَاسْغَارْثْ نّشْ ذ ڒْوَارْثْ نّشْ ذِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 18:‏20 \xt أَعَوذ. 10‏:‏9؛ 18‏:‏2؛ حِز. 44‏:‏28 \x*  
\v 21 خْزَارْ، نشّْ وْشِيغْ إِ أَيْثْ ن لَاوِي مَارَّا ڒعْشُورْ ذِي إِسْرَائِيل ذ ڒْوَارْثْ ذِي طّْوعْ ن ثْسخَّارْثْ نِّي ڭِّينْ نِيثْنِي، ثَاسخَّارْثْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 22 أَيْثْ ن إِسْرَائِيل وَارْ د-تّْقَارِّيبنْ عَاذْ غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، حِيمَا وَارْ د-تِّيوْينْ \add أَمُّو\add* دّنْبْ خْ يِيخفْ نْسنْ ؤُشَا أَذْ مّْثنْ.  
\v 23 \add مَاشَا\add* إِلَاوِييّنْ أَذْ سخَّارنْ ذِي ثْسخَّارْثْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا أَذْ أَرْبُونْ ڒْمُوعْصِييّثْ نْسنْ. \add أَقَا-ت\add* ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ، أَقَا نِيثْنِي وَارْ تّطّْفنْ ڒْوَارْثْ ذِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل،  
\v 24 مِينْزِي ڒعْشُورْ ن أَيْثْ ن إِسْرَائِيل نِّي سّْڭعّْذنْ نِيثْنِي إِ سِيذِي أَمْ ثوْهِيبْثْ ن ؤُسْڭعّذْ، وْشِيغْ ثنْ إِ إِلَاوِييّنْ. خْ ؤُيَا نِّيغْ أَسنْ: وَارْ وَارّْثنْ ذِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل!“   
\m
\v 25 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 26 ”أَمُّو إِ غَا ثسِّيوْڒذْ أَكْ-ذ إِلَاوِييّنْ ؤُشَا أَذْ أَسنْ ثِينِيذْ: ’خْمِي ثكْسِيمْ ڒعْشُورْ ن أَيْثْ ن إِسْرَائِيل نِّي وْشِيغْ كنِّيوْ ذ ڒْوَارْثْ، \add خنِّي\add* أَذْ زَّايْسنْ ثسّْڭعّْذمْ إِشْثْ ن ثوْهِيبْثْ ن ؤُسْڭعّذْ إِ سِيذِي، ڒعْشُورْ زِي ڒعْشُورْ.  
\v 27 أَذْ أَومْ د-ثتّْوَاحْسبْ أَمْ ثوْهِيبْثْ ن ؤُسْڭعّذْ، أَمْ يِيرْذنْ ن ؤُنذْرَارْ ؤُ أَمْ ثشُّورثْ ن ثْسِيرْثْ \add ن ؤُضِيڒْ\add*.  
\v 28 أَمُّو إِ ذ أَومْ إِتّْخصَّا أَذْ ثسّْڭعّْذمْ إِشْثْ ن ثوْهِيبْثْ ن ؤُسْڭعّذْ إِ سِيذِي زِي مَارَّا ڒعْشُورْ نْومْ نِّي غَا ثكْسِيمْ زڭْ أَيْثْ ن إِسْرَائِيل. إِتّْخصَّا أَذْ ثوْشمْ ثَاوْهِيبْثْ، ثنِّي ثسّْڭعّْذمْ زَّايْسنْ إِ سِيذِي، غَارْ ؤُكهَّانْ هَارُونْ.  
\v 29 زِي مَارَّا مِينْ ذ أَومْ غَا وْشنْ، أَذْ ثسّْڭعّْذمْ ثَاوْهِيبْثْ ن ؤُسْڭعّذْ ثْمُونْ إِ سِيذِي، زِي ڒمْخيَّارْ نّسْ، ثَاسْغَارْثْ نّسْ إِقدّْسنْ زَّايسْ.‘   
\m
\v 30 ؤُشَا إِتّْخصَّا أَشْ أَذْ أَسنْ ثِينِيمْ: ’مَاڒَا ثكْسِيمْ زَّايسْ ڒمْخيَّارْ نّسْ، \add أَقَا\add* أَيَا أَذْ د-إِتّْوَاحْسبْ ذ ڒْغِيدْجثْ ن ؤُنذْرَارْ ذ ڒْغِيدْجثْ ن ثْسِيرْثْ \add ن ؤُضِيڒْ\add* إِ إِلَاوِييّنْ.  
\v 31 أَذْ ثشّمْ أَيَا ذِي كُوڒْ أَمْشَانْ، كنِّيوْ ذ \add أَيْثْبَابْ ن\add* ثَادَّارْثْ نْومْ، مِينْزِي ثَا ذ ڒْمُونثْ إِ ثْسخَّارْثْ نْومْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 32 مَاڒَا أَذْ زَّايسْ ثكْسِيمْ مِينْ إِدْجَانْ حْسنْ، \add خنِّي\add* وَارْ خَاومْ ثَاربُّومْ دّنْبْ. وَارْ إِعدّڒْ أَذْ ثْفسْذمْ \add ثِيوْهِيبِينْ\add* إِقدّْسنْ ن أَيْثْ ن إِسْرَائِيل، \add حِيمَا\add* وَارْ ثتّْمتِّيمْ شَا.‘ “   
\b  
\b  
\m  
\c 19
\s1 أَمَانْ ن ؤُسِيزْذڭْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ هَارُونْ، إِنَّا:   
\m
\v 2 ”ثَا ذ ثَاوْصيّثْ ن شَّارِيعَا نِّي يُومُورْ سِيذِي، \add ؤُمِي\add* إِنَّا: ’سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل أَذْ أَشْ د-أَوْينْ \bd إِشْثْ ن ثْفُونَاسْثْ ثَازڭّْوَاغْثْ\bd*، ثنِّي إِشْنَانْ ؤُ ثنِّي وَارْ ذِي إِدْجِي ؤُنعْضَابْ ؤُشَا وَارْ خَاسْ سَّارْسنْ عَاذْ أَزَايْڒُو.  
\v 3 أَذْ ت ثوْشمْ إِ ؤُكهَّانْ أَلِيعَازَارْ ؤُ نتَّا أَذْ ت إِسُّوفّغْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ ؤُ أَذْ أَسْ غَارْصنْ زَّاثْ إِ وُوذمْ نّسْ. \x ◘ \xo 19:‏3 \xt عبر. 13‏:‏11، 12 \x*  
\v 4 أَكهَّانْ أَلِيعَازَارْ أَذْ إِكْسِي \add شْوَايْثْ\add* ن إِذَامّنْ نّسْ س ؤُضَاضْ نّسْ ؤُشَا أَذْ إِرُوشّْ سبْعَا ن ثْوَاڒَاوِينْ \add شْوَايْثْ\add* زڭْ إِذَامّنْ نّسْ جِّيهثْ ن وُوذمْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. \x ◘ \xo 19:‏4 \xt عبر. 9‏:‏13\x*  
\v 5 أَذْ سّْشمْضنْ ثَافُونَاسْثْ زَّاثْ إِ ثِيطَّاوِينْ نّسْ. ثِيڒْمشْثْ نّسْ، أَيْسُومْ نّسْ ذ إِذَامّنْ نّسْ أَذْ ثنْ سّْشمْضنْ \add جْمِيعْ\add* أَكْ-ذ ؤُمسَّاڒْ نّسْ. \x ◘ \xo 19:‏5 \xt ؤُف. 29‏:‏14؛ لَاوِي 4‏:‏11، 12 \x*  
\v 6 أَذْ إِكْسِي ؤُكهَّانْ أَكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ ذ ثْعلْدْجثْ ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُشَا أَذْ إِنْضَارْ أَيَا ذِي ڒْوسْطْ ن ثْمسِّي \add إِ ذِي ثتّْوَاشْمضْ\add* ثْفُونَاسْثْ. \f ◼ \fr 19:‏6 \ft \+bd ’ثْعلْدْجثْ‘\+bd* - نِيغْ ’هِيسُوبْ‘\f*  
\v 7 خنِّي أَذْ إِصبّنْ ؤُكهَّانْ أَرُّوضْ نّسْ، أَذْ إِسِّيرْذْ أَرِّيمثْ نّسْ ذڭْ وَامَانْ، ؤُشَا أَوَارْنِي أَسْ أَذْ يَاذفْ غَارْ ڒْمَارْڭحْ. أَكهَّانْ أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 8 ذ ونِّي ت إِسّْشمْضنْ، أَذْ إِصبّنْ \add عَاوذْ\add* أَرُّوضْ نّسْ ذڭْ وَامَانْ ؤُشَا أَذْ إِسِّيرْذْ أَرِّيمثْ نّسْ س وَامَانْ. نتَّا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 9 أَرْيَازْ أَمزْذَاڭْ أَذْ إِيْرُو إِغّضْ ن ثْفُونَاسْثْ ؤُشَا أَذْ ثنْ إِڭّْ بَارَّا إِ ڒْمَارْڭحْ ذڭْ إِجّْ ن ومْشَانْ إِزْذِيڭْ. أَقَا خْ ثْمسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل مَاحنْذْ أَذْ ثحْضَا خْ وَامَانْ ن وعْزَاڒْ، أَقَا أَثنْ إِ ؤُسِيزْذڭْ ن دّنْبْ.  
\v 10 ونِّي إِيْرُونْ إِغّضْ ن ثْفُونَاسْثْ أَذْ إِصبّنْ أَرُّوضْ نّسْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ. \add أَقَا\add* ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ أَيْثْ ن إِسْرَائِيل ؤُ إِ ؤُبَارَّانِي نِّي إِزدّْغنْ ذِي ڒْوسْطْ نْسنْ.‘ “   
\b  
\m
\v 11 ”وِي غَا إِحَاذَانْ شَا ن ؤُمتِّينْ، مَامّشْ مَا \add ثڭَّا\add* شَا ن ڒْخشْبثْ ن بْنَاذمْ، أَذْ يِيڒِي إِخْمجْ سبْعَا ن وُوسَّانْ. \x ◘ \xo 19:‏11 \xt ڒخْڒ. 31‏:‏19؛ Ḥag. 2‏:‏13\x*  
\v 12 ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا أَذْ إِكّسْ دّنْبْ خْ يِيخفْ نّسْ \add س وَامَانْ ن وعْزَاڒْ\add*. \add خنِّي\add* أَذْ يِيڒِي إِزْذِيڭْ ذڭْ وَاسّْ وِيسّْ سبْعَا. مَاڒَا وَارْ إِكِّيسْ دّنْبْ خْ يِيخفْ نّسْ ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا، وَارْ إِتِّيڒِي إِزْذِيڭْ ذڭْ وَاسّْ وِيسّْ سبْعَا.  
\v 13 مَارَّا وِي إِحَاذَانْ إِجّْ ن ؤُمتِّينْ، ڒعْمَارْ ن إِجّْ ن بْنَاذمْ إِمُّوثْ، ؤُشَا وَارْ إِكِّيسْ دّنْبْ خْ يِيخفْ نّسْ، أَقَا إِسّخْمجْ ثَازذِّيغْثْ ن سِيذِي. ڒعْمَارْ نِّي أَذْ إِتّْوَاقسّْ زِي إِسْرَائِيل. مِينْزِي وَارْ خَاسْ زُّوزَارنْ شَا أَمَانْ ن وعْزَاڒْ، أَذْ يِيڒِي إِخْمجْ. ڒخْمجْ نّسْ \add أَقَا-ث\add* خَاسْ عَاذْ.“   
\m
\v 14 ”وَا ذ أَزرْفْ خْ إِجّْ ن بْنَاذمْ نِّي إِمُّوثنْ ذڭْ إِجّْ ن ؤُقِيضُونْ. مَارَّا وِي غَا يَاذْفنْ غَارْ ؤُقِيضُونْ نِّي ؤُ مَارَّا وِي \add غَا إِقِّيمنْ\add* ذڭْ ؤُقِيضُونْ نِّي، أَذْ يِيڒِي إِخْمجْ سبْعَا ن وُوسَّانْ.  
\v 15 \add عَاوذْ\add* كُوڒْ ڒْقشْعثْ يَارزْمنْ، وَارْ خَاسْ ثَاقبَّارْثْ ثقّنْ س ثسْغُونْثْ، أَذْ ثِيڒِي ثخْمجْ،  
\v 16 مَارَّا وِي إِحَاذَانْ حذْ إِتّْوَاسّْنُوقّْبنْ س سِّيفْ ذڭْ إِيَّارْ، نِيغْ شَا ن ؤُمتِّينْ نِيغْ إِغْسَانْ ن إِجّْ ن بْنَاذمْ، نِيغْ إِجّْ ن ونْضڒْ، أَذْ يِيڒِي إِخْمجْ سبْعَا ن وُوسَّانْ.  
\v 17 إِ يِيجّْ ن ؤُمخْمُوجْ إِتّْخصَّا أَذْ كْسِينْ \add شْوَايْثْ\add* ن إِغّضْ ن \add ثْغَارْصْثْ ن\add* دّنْبْ إِشمْضنْ ؤُشَا أَذْ خَاسْ سّْفَارّْغنْ أَمَانْ إِدَّارنْ ذڭْ إِشْثْ ن ڒْقشْعثْ.  
\v 18 إِجّْ ن ورْيَازْ ذ أَمزْذَاڭْ أَذْ إِكْسِي ثْعلْدْجثْ، أَذْ \add ت\add* إِسُّوفْ ذڭْ وَامَانْ ؤُشَا \add خنِّي\add* أَذْ ت إِرُوشّْ خْ ؤُقِيضُونْ ؤُ خْ مَارَّا ڒقْشُوعْ ؤُ خْ ڒعْمُورْ نِّي ثُوغَا ذِينْ إِدْجَانْ، ؤُشَا \add أَمُّو عَاوذْ\add* خْ وِي إِحَاذَانْ إِغْسَانْ نِيغْ شَا ن يِيجّنْ نِّي إِتّْوَاسّْنُوقّْبنْ نِيغْ شَا ن ؤُمتِّينْ نِيغْ شَا ن ونْضڒْ. \x ◘ \xo 19:‏18 \xt إِزهد. 51‏:‏9 \x*  
\v 19 أَمزْذَاڭْ أَذْ إِرُوشّْ خْ ؤُمخْمُوجْ ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا ؤُ ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ خَاسْ إِرُوشّْ ؤُ ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ خَاسْ إِكّسْ دّنْبْ. أَذْ إِصبّنْ أَرُّوضْ نّسْ أَذْ إِسِّيرْذْ إِخفْ نّسْ س وَامَانْ ؤُشَا أَذْ يِيڒِي إِزْذڭْ أَڒْ ثَامذِّيثْ.  
\v 20 أَرْيَازْ إِخمْجنْ إِ وَارْ إِتّجِّينْ أَذْ إِكّسْ دّنْبْ خْ يِيخفْ نّسْ، ڒعْمَارْ نِّي أَذْ إِتّْوَاقسّْ زِي ڒْوسْطْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add*، مِينْزِي أَقَا إِسّخْمجْ زَّاوشْثْ إِقدّْسنْ ن سِيذِي. وَارْ خَاسْ رُوشّنْ أَمَانْ ن وعْزَاڒْ، أَقَا إِخْمجْ.  
\v 21 ثَا ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ نِيثْنِي. ونِّي إِرُوشّنْ أَمَانْ ن وعْزَاڒْ أَذْ إِصبّنْ أَرُّوضْ نّسْ ؤُ وِي غَا إِحَاذَانْ أَمَانْ ن وعْزَاڒْ، أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 22 مَارَّا مِينْ إِتّْوَاحَاذَانْ زڭْ ؤُمخْمُوجْ، أَذْ يِيڒِي إِخْمجْ، ؤُشَا بْنَاذمْ نِّي إِ غَا إِحَاذَانْ أَيَا، أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.“   
\b  
\b  
\m  
\c 20
\s1 ڒْموْثْ ن مَارْيَامْ  
\m
\v 1 ذڭْ ؤُيُورْ أَمزْوَارُو ثِيوضْ مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل غَارْ ڒخْڒَا ن صِينْ. ڒْڭنْسْ إِقِّيمْ ذِي قَاذَاشْ. ذِينْ إِ ثمُّوثْ مَارْيَامْ ؤُشَا نضْڒنْ ت ذِينْ.   
\b  
\m  
\s1 أَمَانْ ن مِيرِيبَا  
\m
\v 2 وَارْ ثُوغِي ذِينْ شَا أَمَانْ إِ ثْمسْمُونْثْ. \add خنِّي\add* مُوننْ ضِيدّْ إِ مُوسَا ذ هَارُونْ.  
\v 3 ثُوغَا ڒْڭنْسْ إِمْشُوبّشْ أَكْ-ذ مُوسَا، نَّانْ: ”مْڒِي ثُوغَا زَّايْنغْ إِفّغْ بُوحْبڒْ ؤُمِي ثُوغَا إِفّغْ بُوحْبڒْ زڭْ أَيْثْمَاثْنغْ زَّاثْ إِ وُوذمْ ن سِيذِي! \x ◘ \xo 20:‏3 \xt ڒخْڒ. 16‏:‏32، 49\x*  
\v 4 مَايمِّي ثسِّيذْفمْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* ن سِيذِي ذِي ڒخْڒَا-يَا مَاحنْذْ أَذْ مّْثنْ ذِينْ، نشِّينْ ذ ڒبْهَايمْ نّغْ؟  
\v 5 ؤُ مَايمِّي ذ أَنغْ د-ثسِّيڒْيمْ زِي مِيصْرَا حِيمَا أَذْ أَنغْ ثسِّيوْضمْ غَارْ ومْشَانْ-أَ أَعفَّانْ؟ ذڭْ ومْشَانْ-أَ وَارْ \add ذِينْ\add* زَّارِيعثْ نِيغْ ثَازَارْثْ نِيغْ ثْزَايَارْثْ نِيغْ أَرمَّامْ ؤُ وَارْ ذِينْ عَاذْ أَمَانْ حِيمَا أَذْ نْسُو.“   
\m
\v 6 \add خنِّي\add* يِيوضْ مُوسَا أَكْ-ذ هَارُونْ زِي زَّاثْ ن وُوذمْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add* غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا وْضَانْ خْ وُوذْمَاونْ نْسنْ ؤُشَا إِبَانْ أَسنْ-د ؤُعُودْجِي ن سِيذِي.  
\v 7 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 8 ”كْسِي ثَاغَّارْشْثْ ؤُشَا سْمُونْ ثَامسْمُونْثْ، شكْ ذ هَارُونْ، ؤُمَاشْ. إِتّْخصَّا أَذْ ثسِّيوْڒمْ أَكْ-ذ ثصْضَارْثْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ ؤُشَا \add خنِّي\add* أَذْ ثوْشْ أَمَانْ نّسْ. \add أَمُّو\add* إِ غَا ثسُّوفّْغمْ أَمَانْ إِ نِيثْنِي زِي ثصْضَارْثْ ؤُشَا أَذْ ثسّسُّوذْ ثَامسْمُونْثْ ذ ڒبْهَايمْ.“ \x ◘ \xo 20:‏8 \xt نَاح. 9‏:‏15؛ إِزهد. 78‏:‏15، 16؛ 105‏:‏41؛ 114‏:‏8\x*   
\m
\v 9 \add خنِّي\add* إِكْسِي مُوسَا ثَاغَّارْشْثْ زِي زَّاثْ ن وُوذمْ ن سِيذِي أَمْ مَامّشْ ذ أَسْ يُومُورْ نتَّا،  
\v 10 ؤُشَا إِسّْمُونْ مُوسَا ذ هَارُونْ أَڭْرَاوْ \add ن ڒْڭنْسْ\add* زَّاثْ إِ وُوذمْ ن ثصْضَارْثْ. نتَّا إِنَّا أَسنْ: ”سْڒمْ \add ڒخُّو\add*، \add أَ كنِّيوْ\add* إِنِّي إِغوّْغنْ، مَا إِتّْخصَّا أَنغْ أَذْ د-نسُّوفّغْ أَمَانْ زِي ثصْضَارْثْ-أَ؟“ \x ◘ \xo 20:‏10 \xt أَعَوذ. 32‏:‏51؛ إِزهد. 106‏:‏32، 33 \x*  
\v 11 ؤُشَا إِسّْڭعّذْ مُوسَا أَفُوسْ نّسْ ؤُشَا إِوْثَا ثَاصْضَارْثْ ثْنَاينْ ن ثْوَاڒَاوِينْ س ثَاغَّارْشْثْ نّسْ ؤُشَا فّْغنْ-د زَّايسْ أَطَّاسْ ن وَامَانْ ؤُشَا ثسْوَا ثْمسْمُونْثْ ذ ڒبْهَايمْ نْسنْ. \x ◘ \xo 20:‏11 \xt إِزهد. 78‏:‏15؛ 105‏:‏41؛ إِشا. 43‏:‏20؛ 48‏:‏21؛ 1 كُور. 10‏:‏4\x*   
\m
\v 12 \add خنِّي\add* إِنَّا سِيذِي إِ مُوسَا ذ هَارُونْ: ”مِينْزِي كنِّيوْ وَارْ ذ أَيِي ثتّشْڒمْ زَّاثْ إِ ثِيطَّاوِينْ ن أَيْثْ ن إِسْرَائِيل أَڒَامِي ذ أَيِي ثْوقَّارمْ س ؤُوقَّارْ إِقدّْسنْ، س ؤُيَا وَارْ ثسِّيذِيفمْ أَڭْرَاوْ-أَ \add ن ڒْڭنْسْ\add* ذِي ثمُّورْثْ نِّي ذ أَسنْ وْشِيغْ.“ \x ◘ \xo 20:‏12 \xt ڒخْڒ. 27‏:‏14؛ أَعَوذ. 1‏:‏37\x*   
\m
\v 13 إِنَا أَقَا ذ أَمَانْ ن مَارِيبَا مِينْ خفْ أَرزُّونْ أَيْثْ ن إِسْرَائِيل أَذْ مْشُوبّْشنْ أَكْ-ذ سِيذِي ؤُ \add مَانِي\add* نتَّا إِبَانْ-د ذ أَمْقدّسْ جَارْ أَسنْ.   
\b  
\m  
\s1 إِذُومْ يُوڭِي أَژْوِي ن ڒْڭنْسْ  
\m
\v 14 إِسّكّْ مُوسَا إِرقَّاسنْ زِي قَاذَاشْ غَارْ ؤُجدْجِيذْ ن إِذُومْ، نَّانْ: ”أَمُّو إِ إِقَّارْ إِسْرَائِيل، ؤُمَاشْ: ’شكْ ثسّْنذْ مَارَّا ثَامَارَا نِّي خَانغْ إِكِّينْ، \x ◘ \xo 20:‏14 \xt أَعَوذ. 23‏:‏6؛ عُوب. 10، 12 \x*  
\v 15 أَقَا ڒجْذُوذْ نّغْ هْوَانْ-د غَارْ مِيصْرَا ؤُ ثُوغَا نْزدّغْ أَطَّاسْ ن إِسڭّْوُوسَا ذِي مِيصْرَا ؤُ إِمِيصْرِييّنْ ڭِّينْ ذَايْنغْ ؤُ ذِي ڒجْذُوذْ نّغْ أَطَّاسْ ن ڒْغَارْ.  
\v 16 نْڒَاغَا خْ سِيذِي ؤُشَا نتَّا إِسْڒَا ثْمِيجَّا نّغْ ؤُشَا إِسّكّْ-د لْمَالَاكْ ؤُشَا إِسُّوفّغْ أَنغْ-د زِي مِيصْرَا. خْزَارْ، أَقَا أَنغْ ذِي قَاذَاشْ، إِشْثْ ن ثنْذِينْثْ غَارْ طَّارْفْ ن جِّيهثْ نّشْ. \x ◘ \xo 20:‏16 \xt ؤُف. 2‏:‏23؛ 14‏:‏19 \x*  
\v 17 أجّْ أَنغْ، مَاڒَا ثخْسذْ، أَذْ نژْوَا خْ ثمُّورْثْ نّشْ. وَارْ نْژكّْوِي خْ إِيَّارنْ نِيغْ خْ إِمَارْجَاعنْ نّشْ ن ؤُضِيڒْ ؤُ وَارْ نسسّْ أَمَانْ زڭْ وَانُوثنْ. خْ وبْرِيذْ إِڭلّْذنْ أَذْ نعْذُو بْڒَا مَا أَذْ نْحيّذْ \add غَارْ\add* يفُوسْ ؤُڒَا \add غَارْ\add* ؤُزڒْمَاضْ، أَڒْ غَا نعْذُو \add عَاوذْ\add* إِيْمِيرنْ \add ن ثمُّورْثْ\add* نّشْ.‘ “   
\m
\v 18 إِنَّا أَسْ إِذُومْ: ”وَارْ تّْژكّْوِيذْ خَافِي، نِيغْ أَكْ كِيشْ مّْسَاڭَارغْ س سِّيفْ بَالَاكْ!“  
\v 19 \add خنِّي\add* نَّانْ أَسْ أَيْثْ ن إِسْرَائِيل: ”أَذْ نضْفَارْ أَبْرِيذْ أَمقّْرَانْ ؤُ مَاڒَا أَذْ سْوغْ أَمَانْ نّشْ، نشّْ ذ ڒبْهَايمْ إِنُو، أَذْ ثنْ خدْجْصغْ. أَذْ ژْوِيغْ \add ثَامُّورْثْ\add* خْ إِضَارنْ ذ ونِّي نتَّا وَاهَا.“   
\m
\v 20 \add مَاشَا\add* نتَّا إِنَّا: ”وَارْ خَاسْ ثْژكّْوِيذْ!“ ؤُشَا إِفّغْ إِذُومْ مَاحنْذْ أَذْ كِيسْ إِمْسَاڭَارْ س يِيجّْ ن ؤُبَارُّو ذ أَمقّْرَانْ ذ ؤُفُوسْ إِجهْذنْ.  
\v 21 \add أَمُّو\add* يُوڭِي إِذُومْ أَذْ إِوْشْ تّسْرِيحْ إِ إِسْرَائِيل مَاحنْذْ أَذْ إِژْوَا أَيْمِيرْ نّسْ. س ؤُينِّي إِ إِجَّا إِسْرَائِيل أَبْرِيذْ ذِي سِّيبّثْ نّسْ. \x ◘ \xo 20:‏21 \xt ڒقض. 11‏:‏18 \x*   
\b  
\m  
\s1 ڒْموْثْ ن هَارُونْ  
\m
\v 22 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي قَاذَاشْ، ؤُشَا \add خنِّي\add* إِوْضنْ أَيْثْ ن إِسْرَائِيل غَارْ وذْرَارْ ن هُورْ، ثَامسْمُونْثْ مَارَّا. \x ◘ \xo 20:‏22 \xt ڒخْڒ. 33‏:‏37 \x*  
\v 23 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ هَارُونْ غَارْ وذْرَارْ ن هُورْ، غَارْ ويْمِيرْ ن ثمُّورْثْ ن إِذُومْ، إِنَّا:   
\m
\v 24 ”أَذْ إِمَّارْنِي هَارُونْ غَارْ ڒْڭنْسْ نّسْ، مِينْزِي وَارْ إِتِّيذفْ غَارْ ثمُّورْثْ نِّي وْشِيغْ إِ أَيْثْ ن إِسْرَائِيل، مِينْزِي كنِّيوْ ثْغنَّانمْ خْ ڒُومُورْ إِنُو غَارْ وَامَانْ ن مَارِيبَا.  
\v 25 كْسِي هَارُونْ ذ أَلِيعَازَارْ، مِّيسْ، ؤُشَا أَرّْ إِ-ثنْ أَذْ ڭعّْذنْ خْ وذْرَارْ ن هُورْ. \x ◘ \xo 20:‏25 \xt ڒخْڒ. 33‏:‏38؛ أَعَوذ. 32‏:‏50 \x*  
\v 26 عَارَّا هَارُونْ زڭْ وَارُّوضْ نّسْ ؤُشَا سْيَارْضْ إِ-ث إِ أَلِيعَازَارْ، مِّيسْ. \add خنِّي\add* أَذْ إِتّْوَاكْسِي هَارُونْ ؤُشَا أَذْ إِمّثْ ذِينْ.“   
\m
\v 27 مُوسَا إِڭَّا أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي. ؤُڒْينْ أَذْرَارْ ن هُورْ زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا ثَامسْمُونْثْ.  
\v 28 مُوسَا إِعَارَّا هَارُونْ زڭْ وَارُّوضْ نّسْ ؤُشَا إِسّْيَارْضْ إِ-ث إِ أَلِيعَازَارْ، مِّيسْ. ؤُشَا إِمُّوثْ هَارُونْ ذِينْ خْ ثْقِيشَّاثْ ن وذْرَارْ. \add خنِّي\add* إِهْوَا-د مُوسَا زڭْ وذْرَارْ أَكْ-ذ أَلِيعَازَارْ. \x ◘ \xo 20:‏28 \xt أَعَوذ. 10‏:‏6؛ 32‏:‏50 \x*  
\v 29 مَارَّا ثَامسْمُونْثْ ثژْرَا بلِّي هَارُونْ إِضْڒقْ إِ بُوحْبڒْ نّسْ ؤُشَا رُونْ ثْڒَاثِينْ ن وُوسَّانْ ذِي سِّيبّثْ ن هَارُونْ، مَارَّا ثَادَّارْثْ ن إِسْرَائِيل.   
\b  
\b  
\m  
\c 21
\s1 ثَاسخَّارْثْ ن ؤُجدْجِيذْ ن عَارَاذْ  
\m
\v 1 \add ؤُمِي\add* إِسْڒَا أَكنْعَانِي، أَجدْجِيذْ ن عَارَاذْ نِّي إِزدّْغنْ ذِي \add ثمُّورْثْ ن\add* لْجَانُوبْ، بلِّي يُوسَا-د إِسْرَائِيل خْ وبْرِيذْ ن إِبرْڭَاڭنْ، إِمّْنغْ ضِيدّْ إِ إِسْرَائِيل ؤُشَا إِطّفْ \add شَا\add* زَّايْسنْ ذ إِمحْبَاسْ.   
\m
\v 2 \add خنِّي\add* إِوْشَا إِسْرَائِيل إِجّْ ن وَاوَاڒْ إِ سِيذِي ؤُشَا إِنَّا: ”مَاڒَا ذ ثِيذتّْ ثْعَارّْنذْ ڒْڭنْسْ-أَ ذڭْ ؤُفُوسْ إِنُو، نشّْ أَذْ حَارّْمغْ ثِيندَّامْ نْسنْ \add إِ ؤُثحِّي\add*.“  
\v 3 سِيذِي إِسْثَاجبْ إِ إِسْرَائِيل ؤُشَا إِسلّمْ أَسْ أَيْثْ ن كنْعَانْ ؤُشَا نِيثْنِي حَارّْمنْ إِ-ثنْ إِ ؤُثحِّي ؤُڒَا ذ مَارَّا ثِيندَّامْ نْسنْ ؤُشَا إِڒَاغَا أَمْشَانْ نِّي س يِيسمْ ن حُورْمَا. \f ◼ \fr 21:‏3 \ft \+bd ’إِسْثَاجبْ إِ إِسْرَائِيل‘\+bd* - س ثْعِيبْرَانِيثْ ’إِسْڒَا إِ ثْمِيجَّا ن إِسْرَائِيل‘.\f*   
\b  
\m  
\s1 أَفِيغَارْ ن نّْحَاسْ  
\m
\v 4 \add خنِّي\add* فسْينْ إِقِيضَانْ نْسنْ زڭْ وذْرَارْ ن هُورْ، \add رُوحنْ\add* خْ وبْرِيذْ غَارْ ڒبْحَارْ ن ثلْڭَا ؤُشَا س مَانْ أَيَا \add ثُوغَا إِتّْخصَّا\add* أَذْ نّْضنْ إِ ثمُّورْثْ ن إِذُومْ. ؤُشَا ڒْڭنْسْ وَارْ إِصْبِيرْ ذڭْ وبْرِيذْ.  
\v 5 أَقَا إِقَاشحْ ڒْڭنْسْ ضِيدّْ إِ أَربِّي ذ مُوسَا: ”مَايمِّي ذ أَنغْ د-ثسُّوفّْغمْ زِي مِيصْرَا، مَاحنْذْ أَذْ نمّثْ ذِي ڒخْڒَا-يَا؟ وَارْ ذَا إِدْجِي وغْرُومْ ؤُڒَا ذ أَمَانْ. ڒعْمَارْ نّغْ إِعِيفّْ زڭْ وغْرُومْ-أَ إِ وَارْ إِسكّْوِينْ!“   
\m
\v 6 \add خنِّي\add* إِضْڒقْ سِيذِي إِفِيغْرَانْ يَارقّنْ جَارْ ڒْڭنْسْ، إِنِّي إِزعْفنْ ڒْڭنْسْ ؤُشَا إِمُّوثْ وَاطَّاسْ ن ڒْڭنْسْ ن إِسْرَائِيل. \x ◘ \xo 21:‏6 \xt 1 كُور. 10‏:‏9 \x*  
\v 7 يُوسَا-د ڒْڭنْسْ غَارْ مُوسَا، نَّانْ: ”أَقَا نخْضَا، مِينْزِي نْقَاشحْ أَكْ-ذ سِيذِي ؤُ أَكِيذكْ. ژَتدْجْ إِ سِيذِي مَاحنْذْ أَذْ خَانغْ إِكّسْ إِفِيغْرَانْ-أَ.“ \add خنِّي\add* إِژُودْجْ مُوسَا ذِي طّْوعْ ن ڒْڭنْسْ. \f ◼ \fr 21:‏7 \ft \+bd ’إِفِيغْرَانْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَفِيغَارْ‘.\f*   
\m
\v 8 إِنَّا سِيذِي إِ مُوسَا: ”أڭّْ إِجّْ ن ؤُفِيغَارْ يَارقّنْ ؤُشَا سَارْسْ إِ-ث خْ إِشْثْ ن ثحْنَاشْثْ ؤُشَا مَانْ ونْ مَا إِتّْوَازعْفنْ ؤُ أَذْ غَارسْ إِخْزَارْ، أَذْ إِدَّارْ.“ \x ◘ \xo 21:‏8 \xt يُوح. 3‏:‏14\x*  
\v 9 ؤُشَا إِڭَّا مُوسَا إِجّْ ن ؤُفِيغَارْ ن نّْحَاسْ ؤُشَا إِسَّارْسْ إِ-ث خْ ثحْنَاشْثْ ؤُشَا خْمِي إِزعّفْ شَا ن ؤُفِيغَارْ شَا ن يِيجّنْ، ؤُشَا وَانِيثَا إِخزَّارْ غَارْ ؤُفِيغَارْ ن نّْحَاسْ، \add خنِّي\add* أَذْ إِقِّيمْ إِدَّارْ. \x ◘ \xo 21:‏9 \xt 2 إِج. 18‏:‏4؛ يُوح. 3‏:‏14\x*   
\b  
\m  
\s1 زِي ؤُپُوثْ غَارْ فِيسْجَا  
\m
\v 10 \add خنِّي\add* فسْينْ أَيْثْ ن إِسْرَائِيل إِقِيضَانْ نْسنْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ؤُبُوثْ. \x ◘ \xo 21:‏10 \xt ڒخْڒ. 33‏:‏43 \x*  
\v 11 \add خنِّي\add* كّْسنْ إِقِيضَانْ نْسنْ زِي ؤُبُوثْ، وْثِينْ إِقِيضَانْ نْسنْ غَارْ أَرْوِينَاثْ ن عَابَارِيمْ ذِي ڒخْڒَا إِ \add إِدْجَانْ\add* زَّاثْ إِ وُوذمْ ن مُوآبَ مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ.  
\v 12 سّنِّي كّْسنْ إِقِيضَانْ نْسنْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ثغْزُورْثْ ن زَارَاذْ.  
\v 13 سّنِّي كّْسنْ إِقِيضَانْ نْسنْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ خْ ؤُجمَّاضْ ن \add يغْزَارْ ن\add* أَرْنُونْ، ونِّي \add إِسِّيزْڒنْ\add* ذِي ڒخْڒَا، إِفّغْ زِي جِّيهثْ ن ويْمِيرْ ن إِمُورِييّنْ، مِينْزِي أَقَا أَرْنُونْ ذ أَيْمِيرْ أَكْ-ذ مُوآبَ، جَارْ مُوآبَ ذ إِمُورِييّنْ. \x ◘ \xo 21:‏13 \xt ڒقض. 11‏:‏18\x*  
\v 14 خْ ؤُيَا قَّارنْ ذڭْ وذْلِيسْ إِتّْوَانّْضنْ ن ڭَارَّاثْ ن سِيذِي:  
\b  
\m \qt ”وَاهِيبْ ذِي سُوفَا ذ ثْغزْرَاثِينْ ن أَرْنُونْ،\qt*   
\m
\v 15 \qt ؤُ ثِيغزْرَاثِينْ إِ د-إِهكّْوَانْ،\qt*  
\m \qt أَڒَامِي ميّْڒنْثْ غَارْ ثْزذِّيغْثْ ن عَارْ،\qt*  
\m \qt ذ ثنِّي إِسنّْذنْ خْ ويْمِيرْ ن مُوآبَ.“\qt* \x ◘ \xo 21:‏15 \xt أَعَوذ. 2‏:‏36؛ ياش. 13‏:‏9، 16؛ 2 صم. 24‏:‏5\x*   
\b  
\m
\v 16 سّنِّي \add رُوحنْ\add* غَارْ بِي‘رْ، \add ’أَنُو‘\add*. وَا أَقَا ذ أَنُو مِينْ خفْ إِنَّا سِيذِي إِ مُوسَا: ”سْمُونْ ڒْڭنْسْ، \add خنِّي\add* أَذْ أَسنْ وْشغْ أَمَانْ.“  
\v 17 خنِّي إِغنّجْ إِسْرَائِيل إِزْڒِي-يَا:  
\b  
\m \qt ”نْڭزْ، \+tl أَ\+tl* أَنُو!“\qt*  
\m \qt أَرِّيمْ-د خَاسْ س إِجّْ ن إِزْڒِي:\qt*   
\m
\v 18 \qt ”\+tl شكْ\+tl* أَنُو، ونِّي غْزِينْ ڒْحُوكَّامْ،\qt*  
\m \qt ونِّي إِنقْشنْ ثَارْوَا ن ثَاصِيڒثْ ن ڒْڭنْسْ\qt*  
\m \qt أَكْ-ذ ؤُمْڭوَّاذْ نْسنْ\qt*  
\m \qt س إِزدْجَاضنْ نْسنْ \+tl ن ڒحْكَامثْ\+tl*.“\qt*  
\b  
\m زِي ڒخْڒَا \tl رُوحنْ\tl* غَارْ مَاتَّانَا،  
\v 19 ؤُشَا زِي مَاتَّانَا غَارْ نَاحْلِييِيلْ، زِي نَاحْلِييِيلْ غَارْ بَامُوثْ،  
\v 20 ؤُشَا زِي بَامُوثْ غَارْ ثغْزُورْثْ نِّي \add إِدْجَانْ\add* ذڭْ إِيَّارْ ن مُوآبَ، خْ ثْقِيشَّاثْ ن فِيسْجَا نِّي إِتّْسِيجَّانْ غَارْ ثْنزْرُوفْثْ.   
\b  
\m  
\s1 أَغلّبْ خْ سِيحُونْ ذ عُوجْ  
\m
\v 21 \add خنِّي\add* إِسّكّْ إِسْرَائِيل إِرقَّاسنْ غَارْ سِيحُونْ، أَجدْجِيذْ ن إِمُورِييّنْ، إِنَّا: \x ◘ \xo 21:‏21 \xt أَعَوذ. 2‏:‏26؛ ڒقض. 11‏:‏19 \x*   
\m
\v 22 ”أجّْ أَيِي أَذْ شُوقغْ ذِي ثمُّورْثْ نّشْ. وَارْ نتّْميِّيڒْ شَا غَارْ إِيَّارنْ نِيغْ غَارْ إِمَارْجَاعنْ \add نّشْ\add* ن ؤُضِيڒْ ؤُ وَارْ نْسسّْ أَمَانْ زڭْ وَانُوثنْ. أَذْ نعْذُو خْ وبْرِيذْ إِڭلّْذنْ، أَڒْ غَا نعْذُو خْ ثمُّورْثْ نّشْ.“ \x ◘ \xo 21:‏22 \xt ڒخْڒ. 20‏:‏17 \x*  
\v 23 \add مَاشَا\add* سِيحُونْ وَارْ يجِّي أَذْ إِژْوَا إِسْرَائِيل خْ جّْوَايهْ نّسْ. إِسّْمُونْ سِيحُونْ مَارَّا ڒْڭنْسْ نّسْ ؤُشَا إِفّغْ، حِيمَا أَذْ إِمْسَاڭَارْ أَكْ-ذ إِسْرَائِيل، غَارْ ڒخْڒَا، ؤُشَا يُوسَا-د ذِي يَاهَاصْ ؤُشَا إِمّْنغْ أَكْ-ذ إِسْرَائِيل. \x ◘ \xo 21:‏23 \xt أَعَوذ. 2‏:‏30؛ 29‏:‏7؛ ياش. 24‏:‏8؛ ڒقض. 11‏:‏20 \x*  
\v 24 ؤُشَا إِسْرَائِيل إِوْثَا إِ-ث س ڒقْضعْ ن سِّيفْ ؤُشَا إِكْسِي ثمُّورْثْ نّسْ ذ ڒْوَارْثْ، زِي أَرْنُونْ أَڒْ يَابُّوقْ، أَڒْ أَيْثْ ن عَامُّونْ، مِينْزِي جِّيهثْ ن أَيْثْ ن عَامُّونْ أَقَا-ث ذ \add إِجّْ ن لْبُورْجْ\add* إِجهْذنْ. \x ◘ \xo 21:‏24 \xt أَعَوذ. 2‏:‏33، 37؛ 29‏:‏7؛ ياش. 12‏:‏2؛ 24‏:‏8؛ ڒقض. 11‏:‏2؛ إِزهد. 135‏:‏11، 12؛ 136‏:‏19؛ عَام. 2‏:‏9 \x*  
\v 25 إِكْسِي إِسْرَائِيل مَارَّا ثِيندَّامْ-أَ ؤُشَا إِزْذغْ إِسْرَائِيل ذِي مَارَّا ثِيندَّامْ ن إِمُورِييّنْ، ذِي حَاشْبُونْ ؤُ ذِي مَارَّا ثْندَّامْ إِ غَارسْ د-إِقّْننْ. \x ◘ \xo 21:‏25 \xt أَعَوذ. 2‏:‏34، 35\x*  
\v 26 مِينْزِي حَاشْبُونْ ثُوغَا ذ ثَانْذِينْثْ ن سِيحُونْ، أَجدْجِيذْ ن إِمُورِييّنْ، ؤُشَا نتَّا ثُوغَا إِمّْنغْ أَكْ-ذ ؤُجدْجِيذْ إِ ذ أَسْ د-إِزْوَارنْ ن مُوآبَ ؤُشَا إِكْسِي زَّايسْ مَارَّا ثَامُّورْثْ نّسْ أَڒْ أَرْنُونْ.  
\v 27 خْ ؤُيَا قَّارنْ إِنِّي إِسَّاوَاڒنْ س وَاوَاڒنْ إِوزْننْ:  
\b  
\m \qt ”أَسمْ-د غَارْ حَاشْبُونْ،\qt*  
\m \qt أَذْ ثتّْوَابْنَا ؤُ أَذْ ثتّْوَاعْذڒْ\qt*  
\m \qt ثنْذِينْثْ ن سِيحُونْ!\qt*   
\m
\v 28 \qt مِينْزِي ثفّغْ-د ثْمسِّي زِي حَاشْبُونْ\qt*  
\m \qt ذ إِجّْ ن ؤُعشَّاڒْ زِي ثنْذِينْثْ ن سِيحُونْ،\qt*  
\m \qt \+tl أَشعَّاڒْ\+tl* نِّي إِشَّا عَارْ ن أَيْثْ ن مُوآبَ\qt*  
\m \qt ڒْْحُوكَّامْ ن ڒُوعْڒَاثْ ن أَرْنُونْ.\qt* \x ◘ \xo 21:‏28 \xt إِشا. 48‏:‏45\x*   
\m
\v 29 \qt ؤُشْثْ خَاكْ، مُوآبَ!\qt*  
\m \qt أَقَا إِتّْوَاهلّكْ ڒْڭنْسْ ن كَامُوشْ.\qt*  
\m \qt إِحنْجِيرنْ نّسْ إِ ثُوغَا يَاروْڒنْ\qt*  
\m \qt ذ ثْحنْجِيرِينْ نّسْ،\qt*  
\m \qt أَقَا إِسلّمْ إِ-ثنْ ذ إِمحْبَاسْ إِ سِيحُونْ،\qt*  
\m \qt أَجدْجِيذْ ن إِمُورِييّنْ.\qt* \x ◘ \xo 21:‏29 \xt 1 إِج. 11‏:‏7، 33 \x*   
\m
\v 30 \qt أَقَا نوّثْ إِ-ثنْ \+tl س فْڒِيثْشَاثْ\+tl*.\qt*  
\m \qt حَاشْبُونْ إِتّْوَاهلّكْ أَڒْ ذِيبُونْ.\qt*  
\m \qt نَاردّدْجْ إِ-ثنْ أَڒْ نُوفَاحْ\qt*  
\m \qt ثنِّي \+tl إِدْجَانْ\+tl* أَڒْ مِيذَابَا.“\qt*   
\b  
\m
\v 31 أَمُّو إِ إِذْوڒْ إِسْرَائِيل أَذْ إِزْذغْ ذِي ثمُّورْثْ ن إِمُورِييّنْ.  
\v 32 ؤُشَا إِسّكّْ مُوسَا إِبرْڭَاڭنْ غَارْ يَاعْزِيرْ ؤُشَا كْسِينْ ثِيندَّامْ إِ غَارسْ د-إِقّْننْ ؤُشَا كّْسنْ ثَاسْغَارْثْ ن إِمُورِييّمْ نِّي ثُوغَا ذِينْ \add إِزدّْغنْ\add*.   
\m
\v 33 \add خنِّي\add* ميّْڒنْ زڭْ وبْرِيذْ نْسنْ، ؤُڒْينْ أَبْرِيذْ غَارْ بَاشَانْ. \add خنِّي\add* إِفّغْ-د عُوجْ، أَجدْجِيذْ ن بَاشَانْ، نتَّا ذ مَارَّا ڒْڭنْسْ نّسْ، مَاحنْذْ أَذْ كِيذْسنْ إِمْسَاڭَارْ إِ ؤُمنْغِي ذِي إِذْرَاعِي. \x ◘ \xo 21:‏33 \xt أَعَوذ. 3‏:‏1؛ 29‏:‏7\x*  
\v 34 إِنَّا سِيذِي إِ مُوسَا: ”وَارْ زَّايسْ تّڭّْوذْ شَا، مِينْزِي نشّْ ڭِّيغْ ث ذڭْ ؤُفُوسْ نّشْ، أَكْ-ذ مَارَّا ڒْڭنْسْ نّسْ ذ ثمُّورْثْ نّسْ ؤُشَا أَذْ زَّايسْ ثڭّذْ أَمْ مَامّشْ ثڭِّيذْ زِي سِيحُونْ أَجدْجِيذْ ن إِمُورِييّنْ، ونِّي ثُوغَا إِزدّْغنْ ذِي حَاشْبُونْ.“ \x ◘ \xo 21:‏34 \xt إِزهد. 136‏:‏20\x*  
\v 35 ؤُشَا أَردّْدْجنْ ث، نتَّا ذ إِحنْجِيرنْ نّسْ ذ مَارَّا ڒْڭنْسْ نّسْ، أَڒْ مَانِي وَارْ إِقِّيمْ ؤُڒَا ذ إِجّْ ن ؤُمَاڒْوَارْ زَّايسْ ؤُشَا كْسِينْ ثَامُّورْثْ نّسْ ذ ڒْوَارْثْ. \x ◘ \xo 21:‏35 \xt إِزهد. 136‏:‏20، 21، 22\x*   
\b  
\b  
\m  
\c 22
\s1 بَالْعَامْ إِتّْوَاڒَاغَا زِي بَالَاكْ  
\m
\v 1 \add خنِّي\add* فسْينْ أَيْثْ ن إِسْرَائِيل إِقِيضَانْ نْسنْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ڒوْضَاثْ ن مُوآبَ، أَرنْذَاذْ ن أَرِيحَا نِّي إِدْجَانْ خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ.  
\v 2 ؤُشَا إِژْرَا بَالَاقْ، مِّيسْ ن صِيفُّورْ، مَارَّا مِينْ إِڭَّا إِسْرَائِيل ذڭْ إِمُورِييّنْ.  
\v 3 مُوآبَ ثُوغَا إِتّڭّْوذْ أَطَّاسْ زِي ڒْڭنْسْ-أَ، مِينْزِي ثُوغَا أَثنْ ذڭْ وَاطَّاسْ. مُوآبَ ثُوغَا إِتّْنخْڒَاعْ زڭْ أَيْثْ ن إِسْرَائِيل.   
\m
\v 4 \add خنِّي\add* إِنَّا مُوآبَ إِ إِمْغَارنْ ن مِيذْيَانْ: ”ڒخُّو ڒْغَاشِي-يَا أَذْ إِڒْسحْ مَارَّا مِينْ ذ أَنغْ-د إِنّْضنْ، أَمْ مَامّشْ إِڒسّحْ ؤُفُونَاسْ ثَازِييْزَاوْثْ ن ييَّارْ.“ \add ثُوغَا\add* بَالَاقْ، مِّيسْ ن صِيفُّورْ، أَجدْجِيذْ ن مُوآبَ.  
\v 5 إِسّكّْ إِرقَّاسنْ غَارْ بَالْعَامْ، مِّيسْ ن بَاعُورْ، غَارْ \add ثنْذِينْثْ ن\add* فَاثُورْ غَارْ يغْزَارْ \add ن لْفُورَاطْ\add*، \add ذِي\add* ثمُّورْثْ ن أَيْثْ ن ڒْڭنْسْ نّسْ، مَاحنْذْ أَذْ أَسْ د-ڒَْاغَانْ ؤُشَا \add نتَّا\add* إِنَّا: ”خْزَارْ، إِفّغْ-د إِجّْ ن ڒْڭنْسْ زِي مِيصْرَا ؤُشَا خْزَارْ، أَقَا إِذْڒَا ؤُذمْ ن ثمُّورْثْ ؤُشَا أَقَا نِيثْنِي زدّْغنْ نِيشَانْ أَرنْذَاذْ إِنُو. \x ◘ \xo 22:‏5 \xt ياش. 24‏:‏9 \x*  
\v 6 أَسْ-د ڒخُّو، نْعڒْ ڒْڭنْسْ ذِي طّْوعْ إِنُو، مِينْزِي أَقَا إِجْهذْ خَافِي. أَذْ ثَاغْ نشّْ زمَّارغْ أَذْ ثغڒْبغْ نِيغْ أَذْ ث سُّوفّْغغْ زِي ثمُّورْثْ، مِينْزِي نشّْ سّْنغْ بلِّي وِي غَا ثْبَارْكذْ شكْ، أَذْ إِتّْوَابَاركْ ؤُ وِي غَا ثْنعْڒذْ، أَذْ إِتّْوَانْعڒْ.“   
\m
\v 7 \add خنِّي\add* رُوحنْ إِمْغَارنْ ن مُوآبَ ذ إِمْغَارنْ ن مِيذْيَانْ أَكْ-ذ ڒْمُونثْ ن ؤُعزّمْ ذڭْ ؤُفُوسْ نْسنْ، إِوْضنْ غَارْ بَالْعَامْ ؤُشَا سِّيوْڒنْ أَكِيذسْ \add س\add* وَاوَاڒنْ ن بَالَاكْ.  
\v 8 نتَّا إِنَّا أَسنْ: ”سنْسمْ ذَا دْجِيڒثْ-أَ، \add خنِّي\add* نشّْ أَذْ خَاومْ د-أَرّغْ أَمْ مَامّشْ غَارِي غَا إِسِّيوڒْ سِيذِي.“ \add خنِّي\add* قِّيمنْ ڒْحُوكَّامْ ن مُوآبَ غَارْ بَالْعَامْ.  
\v 9 يُوسَا-د أَربِّي غَارْ بَالْعَامْ، إِنَّا: ”مِينْ عْنَانْ إِرْيَازنْ نِّي إِدْجَانْ أَكِيذكْ؟“  
\v 10 إِنَّا بَالْعَامْ إِ أَربِّي: ”بَالَاكْ، مِّيسْ ن صِيفُّورْ، أَجدْجِيذْ ن مُوآبَ، إِسّكّْ إِ-ثنْ-د غَارِي، \add إِنَّا\add*:  
\v 11 ’خْزَارْ، إِجّْ ن ڒْڭنْسْ إِفّغْ-د زِي مِيصْرَا ؤُ أَقَا إِذْڒَا ؤُذمْ ن ثمُّورْثْ. أَسْ-د، نْعڒْ إِ-ث ذِي طّْوعْ إِنُو. أَذْ ثَاغْ زمَّارغْ \add خنِّي\add* أَذْ كِيسنْ منْغغْ نِيغْ أَذْ ثنْ سُّوفّْغغْ.‘ “  
\v 12 إِنَّا أَربِّي إِ بَالْعَامْ: ”وَارْ تّْرِيحْ كِيسنْ نِيغْ أَذْ ثْنعْڒذْ ڒْڭنْسْ نِّي، مِينْزِي ڒْڭنْسْ أَقَا إِتّْوَابَاركْ.“   
\m
\v 13 \add خنِّي\add* إِكَّارْ بَالْعَامْ ذِي صّْبحْ ؤُشَا إِنَّا إِ ڒْحُوكَّامْ ن بَالَاكْ: ”ذوْڒمْ-د غَارْ ثمُّورْثْ نْومْ، مِينْزِي سِيذِي وَارْ ذ أَيِي إِسْمِيحْ حِيمَا أَذْ رَاحغْ أَكِيذْومْ.“  
\v 14 \add خنِّي\add* كَّارنْ ڒْحُوكَّامْ ن مُوآبَ ؤُشَا ذوْڒنْ-د غَارْ بَالَاكْ ؤُشَا نَّانْ: ”بَالْعَامْ يُوڭِي أَذْ د-يَاسْ أَكِيذْنغْ.“   
\b  
\m
\v 15 إِسّكّْ بَالَاكْ عَاوذْ ڒْحُوكَّامْ، \add عَاذْ\add* كْثَارْ ؤُ \add عَاذْ\add* ونِّي إِشنّْعنْ كْثَارْ خْ يِينَا \add إِمزْوُورَا\add*.  
\v 16 ؤُسِينْ-د غَارْ بَالْعَامْ، نَّانْ: ”أَمُّو إِ إِقَّارْ بَالَاكْ، مِّيسْ ن صِيفُّورْ: ’تّْزَاوْڭغْ شكْ، وَارْ تّجِّي إِخفْ نّشْ مَاحنْذْ وَارْ غَارِي د-تَّاسذْ،  
\v 17 مِينْزِي أَذْ شكْ كَارّْمغْ س وَاطَّاسْ ؤُشَا أَذْ ڭّغْ مَارَّا مِينْ ذ أَيِي غَا ثِينِيذْ. تّْزَاوْڭغْ شكْ، أَسْ-د ؤُشَا نْعڒْ ڒْڭنْسْ-أَ ذِي طّْوعْ إِنُو!“   
\m
\v 18 يَارَّا-د بَالْعَامْ ؤُشَا إِنَّا إِ إِمْسخَّارنْ ن بَالَاكْ: ”وَاخَّا بَالَاكْ أَذْ أَيِي إِوْشْ ثَادَّارْثْ نّسْ ثشُّورْ س نُّوقَارْثْ ذ وُورغْ، \add عَاذْ\add* وَارْ زْمِيرغْ أَذْ فّْغغْ خْ ڒُومُورْ ن سِيذِي، أَربِّي إِنُو، \add مَاحنْذْ أَذْ ڭّغْ\add* شَا ن ڒْحَاجّثْ ذ ثَامژْيَانْثْ نِيغْ شَا ن ڒْحَاجّثْ ذ ثَامقّْرَانْثْ. \x ◘ \xo 22:‏18 \xt ڒخْڒ. 24‏:‏13 \x*  
\v 19 \add خنِّي\add* ڒخُّو، تّْزَاوَاڭغْ كنِّيوْ، قِّيممْ ذَانِيثَا دْجِيڒثْ-أَ حِيمَا أَذْ سّْنغْ مِينْ ذ أَيِي غَا يِينِي سِيذِي عَاذْ كْثَارْ.“  
\v 20 ذِي دْجِيڒثْ يُوسَا-د أَربِّي غَارْ بَالْعَامْ، إِنَّا أَسْ: ”مَاڒَا ذوْڒنْ-د يرْيَازنْ نِّي مَاحنْذْ أَذْ أَشْ د-ڒَْاغَانْ، كَّارْ \add خنِّي\add* ؤُشَا رُوحْ أَكِيذْسنْ. مَاشَا وَارْ تّڭّْ مْغِيرْ مِينْ ذ أَشْ غَا إِنِيغْ.“  
\v 21 إِكَّارْ بَالْعَامْ غَارْ صّْبحْ ؤُشَا إِحزّمْ إِ ثغْيُوتْشْ نّسْ ؤُشَا يُويُورْ أَكْ-ذ ڒْحُوكَّامْ ن مُوآبَ.   
\b  
\m
\v 22 \add خنِّي\add* يَارْغَا وغْضَابْ ن أَربِّي، مِينْزِي نتَّا إِرُوحْ ؤُشَا لْمَالَاكْ ن سِيذِي إِبدّْ ذڭْ وبْرِيذْ \add أَمْ\add* شِّيطَانْ ضِيدّْ نّسْ. نتَّا إِنْيَا خْ ثغْيُوتْشْ نّسْ ؤُشَا ثْنَاينْ ن إِمْسخَّارنْ ثُوغَا أَثنْ أَكِيذسْ.  
\v 23 ؤُشَا ثَاغْيُوتْشْ ثژْرَا لْمَالَاكْ ن سِيذِي إِبدّْ ذڭْ وبْرِيذْ س سِّيفْ نّسْ إِتّْوَاجبْذنْ ذڭْ ؤُفُوسْ نّسْ. س ؤُينِّي ثڒْحمْ ثغْيُوتْشْ زڭْ وبْرِيذْ ؤُشَا ثُويُورْ ذڭْ إِيَّارْ. \add خنِّي\add* إِوْثَا بَالْعَامْ ثَاغْيُوتْشْ حِيمَا أَذْ ت يَارّْ غَارْ وبْرِيذْ. \x ◘ \xo 22:‏23 \xt 2 بُط. 2‏:‏16؛ يَاه. 11\x*   
\m
\v 24 مَاشَا لْمَالَاكْ ن سِيذِي إِبدّْ ذڭْ إِشْثْ ن ثبْرِيذْثْ ثحْصَارْ جَارْ إِمَارْجَاعنْ ن ؤُضِيڒْ س يِيجّْ ن وغْبَارْ غَارْ طَّارْفْ ذ إِجّْ ن وغْبَارْ غَارْ طَّارْفْ نّغْنِيثْ.  
\v 25 ؤُمِي ثژْرَا ثغْيُوتْشْ لْمَالَاكْ ن سِيذِي، ثڒْصقْ غَارْ وغْبَارْ ؤُشَا إِتّْوَاحْصَارْ ؤُضَارْ ن بَالْعَامْ أَكْ-ذ وغْبَارْ ؤُشَا نتَّا إِقِّيمْ إِشَّاثْ إِ-ت.   
\m
\v 26 \add ؤُشَا\add* إِرُوحْ لْمَالَاكْ ن سِيذِي غَارْ زَّاثْ ؤُشَا إِبدّْ ذڭْ إِجّْ ن ومْشَانْ إِحْصَارْ أَطَّاسْ أَڒْ مَانِي وَارْ إِتّْوِيفْ تَّاسِيعْ مَاحنْذْ أَذْ إِحيّذْ \add غَارْ\add* يفُوسْ ؤُڒَا \add غَارْ\add* ؤُزڒْمَاضْ.  
\v 27 ؤُمِي ثژْرَا ثغْيُوتْشْ لْمَالَاكْ ن سِيذِي، ثْبَارْشْ سَاذُو بَالْعَامْ ؤُشَا بَالْعَامْ إِخيّقْ أَطَّاسْ ؤُشَا إِفَارْشْ ثَاغْيُوتْشْ س يِيجّْ ن ؤُكشُّوضْ.   
\m
\v 28 \add خنِّي\add* يَارْزمْ سِيذِي أَقمُّومْ ن ثغْيُوتْشْ ؤُشَا ثنَّا إِ بَالْعَامْ: ”مِينْ ذ أَشْ ڭِّيغْ ؤُمِي ذ أَيِي ثْفَارْشذْ \add ڒخُّو عَاذْ\add* ثْڒَاثَا ن إِمُورنْ؟“ \x ◘ \xo 22:‏28 \xt 2 بُط. 2‏:‏16؛ يَاه. 11\x*  
\v 29 \add خنِّي\add* إِنَّا بَالْعَامْ إِ ثغْيُوتْشْ: ”مِينْزِي شمْ ثْبُوصَارذْ خَافِي. مْڒِي غَارِي سِّيفْ ذڭْ ؤُفُوسْ إِنُو، أَذْ ثِيڒِي خنِّي نْغِيغْ شمْ!“  
\v 30 ثنَّا ثغْيُوتْشْ إِ بَالْعَامْ: ”مَا وَارْ دْجِيغْ نشّْ ثَاغْيُوتْشْ نّشْ إِ خفْ ثنْيِيذْ زڭْ وَامِي نشّْ غَاركْ دْجِيغْ أَڒْ أَسّْ-أَ؟ مَا أَقَا نشّْ نُّومغْ تّڭّغْ أَكْ كِيكْ أَمُّو؟“ ؤُشَا يَارَّا-د \add خَاسْ\add*: ”لَّ!“  
\v 31 خنِّي يَارْزمْ سِيذِي ثِيطَّاوِينْ ن بَالْعَامْ أَڒَامِي إِژْرَا لْمَالَاكْ ن سِيذِي إِبدّْ ذڭْ وبْرِيذْ س سِّيفْ نّسْ إِتّْوَاجبْذنْ ذڭْ ؤُفُوسْ نّسْ. \add خنِّي\add* يُوضَارْ بَالْعَامْ، إِبنْذقْ س ؤُغمْبُوبْ نّسْ \add غَارْ ثمُّورْثْ\add*.  
\v 32 إِنَّا أَسْ لْمَالَاكْ ن سِيذِي: ”مَايمِّي ثوْثِيذْ ثَاغْيُوتْشْ نّشْ ثْڒَاثَا ن إِمُورنْ؟ خْزَارْ، أَقَا نشّْ فّْغغْ-د \add أَمْ\add* إِجّْ ن وغْرِيمْ، مِينْزِي أَبْرِيذْ-أَ إِتّْضَارَّا أَيِي نشّْ نِيشَانْ. \x ◘ \xo 22:‏32 \xt 2 بُط. 2‏:‏15\x*  
\v 33 ثژْرَا أَيِي ثغْيُوتْشْ ؤُشَا ثڒْحمْ خنِّي زِي زَّاثْ إِ وُوذمْ إِنُو ثْڒَاثَا ن إِمُورنْ. مَاڒَا وَارْ ثڒْحِيمْ زِي زَّاثْ إِ وُوذمْ إِنُو، \add خنِّي\add* نشّْ أَذْ يِيڒِي أَقَا ڒخُّو نْغِيغْ شكْ ؤُ نتَّاثْ أَذْ ت جّغْ أَذْ ثدَّارْ.“  
\v 34 \add خنِّي\add* إِنَّا بَالْعَامْ إِ لْمَالَاكْ ن سِيذِي: ”أَقَا نشّْ خْضِيغْ، مِينْزِي وَارْ سِّينغْ بلِّي شكْ ثْبدّذْ زَّاثِي ذڭْ وبْرِيذْ. عَاذْ ڒخُّو، مَاڒَا أَيَا ذ ڒْعِيبْ ذِي ثِيطَّاوِينْ نّشْ، نشّْ أَذْ د-ذوْڒغْ.“  
\v 35 إِنَّا لْمَالَاكْ ن سِيذِي إِ بَالْعَامْ: ”رُوحْ أَكْ-ذ إِوْذَانْ-أَ، مَاشَا سِيوڒْ وَاهَا مِينْ ذ أَشْ غَا إِنِيغْ نشّْ.“ \add أَمُّو\add* إِرُوحْ بَالْعَامْ أَكْ-ذ ڒْحُوكَّامْ ن بَالَاكْ.   
\b  
\m
\v 36 \add ؤُمِي\add* بَالَاكْ إِسْڒَا، أَقَا بَالْعَامْ يُوسَا-د، إِرُوحْ حِيمَا أَذْ ث إِمّڒْقَا غَارْ ثَانْذِينْثْ ن مُوآبَ إِ إِدْجَانْ غَارْ جِّيهثْ ن ويْمِيرْ ن أَرْنُونْ، غَارْ طَّارْفْ ن جِّيهثْ ن ويْمِيرْ.  
\v 37 ؤُشَا بَالَاكْ إِنَّا إِ بَالْعَامْ: ”مَا وَارْ سّكّغْ نشّْ \add إِوْذَانْ\add* أَذْ أَشْ د-ڒَْاغَانْ؟ مَايمِّي وَارْ غَارِي د-ثُوسِيذْ؟ مَا وَارْ زمَّارغْ نشّْ أَذْ شكْ كَارْمغْ؟“  
\v 38 \add خنِّي\add* يَارَّا-د بَالْعَامْ خْ بَالَاكْ: ”خْزَارْ، نشّْ ؤُسِيغْ-د غَاركْ، \add مَاشَا\add* مَا زمَّارغْ نشّْ ڒخُّو أَذْ سِّيوْڒغْ خْ شَا؟ أَوَاڒْ نِّي إِ غَا يڭّْ سِيذِي ذڭْ ؤُقمُّومْ إِنُو، أَذْ ث إِنِيغْ.“ \f ◼ \fr 22:‏38 \ft \+bd ’يَارَّا-د‘\+bd* - س ثْعِيبْرَانِيثْ ’إِنَّا‘.\f*  
\v 39 ؤُشَا إِرُوحْ بَالْعَامْ أَكْ-ذ بَالَاكْ ؤُشَا ؤُسِينْ-د غَارْ قَارْيَاثْ-حَاصُوثْ.  
\v 40 \add خنِّي\add* إِغَارْصْ بَالَاكْ إِ إِفُونَاسنْ ذ وُودْجِي، إِسّكّْ \add زَّايْسنْ\add* غَارْ بَالْعَامْ ؤُ غَارْ ڒْحُوكَّامْ نِّي ثُوغَا أَكِيذسْ.  
\v 41 غَارْ صّْبحْ إِمْسَارْ بلِّي بَالَاكْ يِيوِي أَكِيسْ بَالْعَامْ ؤُشَا إِسِّيڒِي إِ-ث خْ ڒُوعْڒَاثْ ن بَاعْلْ مَانِي ثُوغَا إِزمَّارْ أَذْ إِژَارْ ڒْڭنْسْ أَڒْ طَّارْفْ إِڭّْوجنْ قَاعْ.   
\b  
\b  
\m  
\c 23
\s1 بَالْعَامْ إِبَاركْ إِسْرَائِيل  
\m
\v 1 \add خنِّي\add* إِنَّا بَالْعَامْ إِ بَالَاكْ: ”بْنَا سبْعَا ن إِعَالْطَارنْ ذَانِيثَا إِ نشّْ ؤُشَا سوْجذْ أَيِي سبْعَا ن إِفُونَاسنْ إِمژْيَاننْ ذ سبْعَا ن إِشَارِّييّنْ.“  
\v 2 بَالَاكْ إِڭَّا أَمْ مَامّشْ ذ أَسْ إِنَّا بَالْعَامْ ؤُشَا بَالَاكْ ذ بَالْعَامْ قدّْمنْ إِجّْ ن ؤُفُونَاسْ أَمژْيَانْ ذ إِجّْ ن إِشَارِّي خْ \add كُوڒْ إِجّْ ن\add* ؤُعَالْطَارْ.  
\v 3 \add خنِّي\add* بَالْعَامْ إِنَّا إِ بَالَاكْ: ”بدّْ \add ذِينْ\add* زَّاثْ إِ ثْغَارْصْثْ ن وشْمَاضْ نّشْ، \add خنِّي\add* نشّْ أَذْ رَاحغْ. أَذْ ثَاغْ أَذْ كِيذِي إِمْسَاڭَارْ سِيذِي ؤُشَا مَامّشْ مَا إِڭَّا وَاوَاڒْ نِّي ذ أَيِي غَا إِسّْشنْ، نشّْ أَذْ أَشْ ث-إِ-د-سَّارْڭْبغْ.“ \add خنِّي\add* إِرُوحْ \add بَالْعَامْ\add* غَارْ \add ثْقِيشَّاثْ\add* ذ ثَاقشَّارْثْ \add ن وذْرَارْ\add*.   
\m
\v 4 ؤُ إِمّڒْقَا أَربِّي أَكْ-ذ بَالْعَامْ ؤُشَا \add نتَّا\add* إِنَّا أَسْ: ”أَقَا سّْوجْذغْ سبْعَا ن إِعَالْطَارنْ ؤُشَا قدّْمغْ إِجّْ ن ؤُفُونَاسْ أَمژْيَانْ ذ إِجّْ ن إِشَارِّي خْ \add كُوڒْ إِجّْ ن\add* ؤُعَالْطَارْ.“  
\v 5 \add خنِّي\add* إِڭَّا سِيذِي إِجّْ ن وَاوَاڒْ ذڭْ ؤُقمُّومْ ن بَالْعَامْ ؤُشَا إِنَّا: ”ذْوڒْ غَارْ بَالَاكْ ؤُشَا سِيوڒْ \add أَكِيذسْ\add* أَمُّو.“   
\m
\v 6 ؤُشَا \add ؤُمِي\add* غَارسْ-د إِذْوڒْ، خْزَارْ، إِبدّْ زَّاثْ إِ ثْغَارْصْثْ ن وشْمَاضْ نّسْ، \add جْمِيعْ\add* أَكْ-ذ مَارَّا ڒْحُوكَّامْ ن مُوآبَ.  
\v 7 \add خنِّي\add* إِبْذَا إِقَّارْ أَوَاڒْ نّسْ إِوزْننْ، إِنَّا:  
\b  
\m \qt ”زِي أَرَامْ إِنْذهْ أَيِي-د بَالَاكْ، أَجدْجِيذْ ن مُوآبَ،\qt*  
\m \qt زڭْ إِذُورَارْ ن شَّارْقْ، إِنَّا:\qt*  
\m \qt ’أَسْ-د، نْعڒْ أَيِي يَاعْقُوبْ،\qt*  
\m \qt أَسْ-د، زَاوَارْ إِسْرَائِيل!‘\qt*   
\m
\v 8 \qt \+tl مَاشَا\+tl* مَامّشْ غَا نعْڒغْ،\qt*  
\m \qt ونِّي وَارْ إِتّْوَانعْڒنْ زِي أَربِّي،\qt*  
\m \qt ؤُ مَامّشْ غَا زَاوَارغْ\qt*  
\m \qt ونِّي وَارْ إِزَاوَارْ سِيذِي؟\qt*   
\m
\v 9 \qt مِينْزِي زِي ثْقِيشَّاثْ ن ثْصُوضَارْ ثْوَاڒِيغْ ث،\qt*  
\m \qt ؤُشَا زِي ثِيوْرِيرِينْ خزَّارغْ ذَايسْ.\qt*  
\m \qt أَقَا وَا ذ إِجّْ ن ڒْڭنْسْ إِزدّْغنْ وحّْذسْ\qt*  
\m \qt ؤُ وَارْ إِحسّبْ إِخفْ نّسْ جَارْ ڒڭْنُوسْ.\qt* \x ◘ \xo 23:‏9 \xt أَعَوذ. 33‏:‏28\x*   
\m
\v 10 \qt وِي غَا إِحسْبنْ أَشَاڒْ ن يَاعْقُوبْ\qt*  
\m \qt نِيغْ \+tl وِي إِ غَا إِحسْبنْ\+tl* ڒْقدّْ ن إِجّْ ن أَرْبعْ زِي إِسْرَائِيل؟\qt*  
\m \qt أجّْ أَذْ إِمّثْ ڒعْمَارْ إِنُو\qt*  
\m \qt ڒْموْثْ ن إِمْسڭَّاذنْ\qt*  
\m \qt ؤُ أجّْ عَاوذْ أَذْ يِيڒِي ؤُنڭَّارْ \+tl ن ثُوذَارْثْ\+tl* إِنُو\qt*  
\m \qt أَذْ إِمْقُودَّا أَكِيذسْ!“\qt*   
\b  
\m
\v 11 \add خنِّي\add* إِنَّا بَالَاكْ إِ بَالْعَامْ: ”مِينْ ذ أَيِي ثڭِّيذْ؟ نشّْ إِوْيغْ شكْ حِيمَا أَذْ ثْنعْڒذْ ڒْعذْيَانْ إِنُو، \add مَاشَا\add* خْزَارْ، أَقَا نِيشَانْ ثْبَارْكذْ إِ-ثنْ!“  
\v 12 نتَّا يَارَّا-د، إِنَّا: ”مَا وَارْ إِتّْخصِّي أَذْ حْضِيغْ مَاحنْذْ أَذْ سِّيوْڒغْ مِينْ إِڭَّا سِيذِي ذڭْ ؤُقمُّومْ إِنُو؟“  
\v 13 \add خنِّي\add* إِنَّا بَالَاكْ: ”تّْزَاوْڭغْ شكْ أَذْ د-ثَاسذْ أَكِيذِي غَارْ إِجّْ ن ومْشَانْ نّغْنِي زِي مَانِيسْ غَا ثْژَارذْ ڒْڭنْسْ \add عَاوذْ\add*. أَذْ ثْژَارذْ طّْرُوفَا نّسْ وَاهَا، وَارْ ث ثْژَارّذْ مَارَّا. سّنِّي أَذْ ث ثْنعْڒذْ ذِي طّْوعْ إِنُو!“   
\m
\v 14 ؤُشَا يِيوْيِي إِ-ث غَارْ ڒوْضَا ن صُوفِيمْ خْ ثْقِيشَّاثْ ن فِيسْجَا ؤُشَا إِبْنَا \add ذِينْ\add* سبْعَا ن إِعَالْطَارنْ ؤُشَا خْ \add كُوڒْ إِجّْ ن\add* ؤُعَالْطَارْ إِقدّمْ إِجّْ ن ؤُفُونَاسْ أَمژْيَانْ ذ إِجّْ ن إِشَارِّي.  
\v 15 نتَّا إِنَّا إِ بَالَاكْ: ”مَاڒَا شكْ أَذْ ثْبدّذْ ذَا زَّاثْ إِ ثْغَارْصْثْ نّشْ ن وشْمَاضْ، خنِّي نشّْ أَذْ \add كِيسْ\add* مّْسَاڭَارغْ ذِينْ.“  
\v 16 ؤُشَا إِمْسَاڭَارْ سِيذِي أَكْ-ذ بَالْعَامْ ؤُشَا إِڭَّا إِجّْ ن وَاوَاڒْ ذڭْ ؤُقمُّومْ نّسْ، إِنَّا: ”ذْوڒْ غَارْ بَالَاكْ ؤُشَا إِنِي أَسْ أَمُّو.“ \x ◘ \xo 23:‏16 \xt ڒخْڒ. 22‏:‏35\x*  
\v 17 ؤُشَا نتَّا يُوسَا-د غَارسْ، ؤُ خْزَارْ، نتَّا ثُوغَا إِبدّْ زَّاثْ إِ ثْغَارْصْثْ ن وشْمَاضْ نّسْ ؤُشَا ڒْحُوكَّامْ ن مُوآبَ بدّنْ زَّاثسْ. إِنَّا أَسْ بَالَاكْ: ”مِينْ إِنَّا سِيذِي؟“   
\m
\v 18 \add خنِّي\add* إِبْذَا نتَّا أَوَاڒْ نّسْ إِوزْننْ، إِنَّا:  
\b  
\m \qt ”كَّارْ، بَالَاكْ، سْحسّْ!\qt*  
\m \qt سڒْ غَارِي، \+tl شكْ\+tl*، مِّيسْ ن صِيفُّورْ!\qt*   
\m
\v 19 \qt أَربِّي وَارْ إِدْجِي ذ مِّيسْ ن بْنَاذمْ،\qt*  
\m \qt مَاحنْذْ زعْمَا أَذْ إِسّْخَارِّيقْ،\qt*  
\m \qt نِيغْ ذ مِّيسْ ن بْنَاذمْ\qt*  
\m \qt مَاحنْذْ زعْمَا أَذْ ث إِڒْقفْ ونْذَامْ.\qt*  
\m \qt مَا أَذْ يِينِي ؤُشَا وَارْ ت إِتّڭّْ،\qt*  
\m \qt نِيغْ أَذْ إِسِّيوڒْ ؤُشَا وَارْ ت إِتّْكمِّيڒْ؟\qt* \x ◘ \xo 23:‏19 \xt 1 صم. 15‏:‏29؛ يَاع. 1‏:‏17\x*   
\m
\v 20 \qt خْزَارْ، أَقَا طّْفغْ \+tl ڒُْومُورْ\+tl* حِيمَا أَذْ بَارْكغْ.\qt*  
\m \qt ؤُمِي إِبَاركْ نتَّا،\qt*  
\m \qt نشّْ وَارْ زمَّارغْ أَذْ د-أَرّغْ أَيَا.\qt*   
\m
\v 21 \qt وَارْ إِتّْوِيڒِي ڒْمُوعْصِييّثْ ن يَاعْقُوبْ\qt*  
\m \qt ؤُ ڒغْبنْ ن إِسْرَائِيل وَارْ ث إِژَارْ.\qt*  
\m \qt سِيذِي، أَربِّي نّسْ، أَقَا-ث أَكِيذسْ\qt*  
\m \qt ؤُشَا أَسُوضِي سْ وسْرُودّحْ \+tl ذِي ڒْبُوقْ\+tl*\qt*  
\m \qt ذِي طّْوعْ ن ؤُجدْجِيذْ أَقَا-ث ذَايسْ.\qt* \x ◘ \xo 23:‏21 \xt إِزهد. 32‏:‏1، 2؛ 51‏:‏11؛ إِرْم. 50‏:‏20؛ رُوم. 4‏:‏7\x*   
\m
\v 22 \qt أَربِّي إِسُّوفّغْ إِ-ثنْ-د زِي مِيصْرَا.\qt*  
\m \qt نتَّا إِ نِيثْنِي أَمْ وَاشَّاونْ \+tl إِزِيرَارنْ\+tl*\qt*  
\m \qt ن إِغَايْضْ ن ڒخْڒَا.\qt* \x ◘ \xo 23:‏22 \xt ڒخْڒ. 24‏:‏8\x*   
\m
\v 23 \qt أَقَا زعْمَا وَارْ ذِينْ أَعزّمْ ذِي يَاعْقُوبْ\qt*  
\m \qt ؤُ وَارْ ذِينْ ثَاڭزَّانْثْ ذِي إِسْرَائِيل.\qt*  
\m \qt ثَا ذ ڒْوقْثْ إِ ذِي ثتّْوَانَّا خْ يَاعْقُوبْ ذ إِسْرَائِيل:\qt*  
\m \qt ’\+tl أَقَا خْزَارْ\+tl*، مِينْ إِڭَّا أَربِّي!‘\qt*   
\b  
\m
\v 24 \qt أَقَا ذَا، ڒْڭنْسْ أَذْ إِكَّارْ أَمْ ثيْرَاذْثْ\qt*  
\m \qt ؤُ أَذْ د-إِڭعّذْ أَمْ ويْرَاذْ.\qt*  
\m \qt وَارْ إِسّزّڒْ إِخفْ نّسْ\qt*  
\m \qt أَڒْ غَا يشّْ ثَايْمَارْثْ نّسْ\qt*  
\m \qt ؤُشَا أَذْ إِسُّو إِذَامّنْ ن مِينْ إِمزّقْ.“\qt* \f ◼ \fr 23:‏24 \ft \+bd ’مِينْ إِمزّقْ‘\+bd* - نِيشَانْ زِي ثْعِيبْرَانِيثْ ’مِينْ إِسّْنُوقّبْ‘ نِيغْ ’مِينْ إِسّيْزمْ‘.\f*   
\b  
\m
\v 25 \add خنِّي\add* إِنَّا بَالَاكْ إِ بَالْعَامْ: ”مَاڒَا \add خنِّي\add* وَارْ ثخْسذْ قَاعْ أَذْ ث ثْنعْڒذْ، وَارْ ث تّْبَارَاكْ شَا عَاوذْ.“   
\m
\v 26 بَالْعَامْ يَارَّا-د، إِنَّا إِ بَالَاكْ: ”مَا وَارْ ذ أَشْ نِّيغْ: ’مَارَّا مِينْ ذ أَيِي غَا يِينِي سِيذِي، أَذْ ث ڭّغْ؟‘ “   
\m
\v 27 \add خنِّي\add* إِنَّا بَالَاكْ إِ بَالْعَامْ: ”تّْزَاوْڭغْ شكْ أَذْ د-ثَاسذْ، أَذْ شكْ أَوْيغْ غَارْ إِجّْ ن ومْشَانْ نّغْنِي. أَذْ ثَاغْ أَذْ يِيڒِي نِيشَانْ ذِي ثِيطَّاوِينْ ن أَربِّي مَاڒَا أَذْ ث ثْنعْڒذْ سّنِّي ذِي طّْوعْ إِنُو.“  
\v 28 ؤُشَا بَالَاكْ إِنْذهْ بَالْعَامْ غَارْ ثْقِيشَّاثْ ن فَاغُورْ نِّي إِخزَّارنْ غَارْ ثْنزْرُوفْثْ.  
\v 29 \add خنِّي\add* إِنَّا بَالْعَامْ إِ بَالَاكْ: ”بْنَا ذَانِيثَا سبْعَا ن إِعَالْطَارنْ ؤُشَا سوْجذْ أَيِي ذَانِيثَا سبْعَا ن إِفُونَاسنْ إِمژْيَاننْ ذ سبْعَا ن إِشَارِّييّنْ.“  
\v 30 بَالَاكْ إِڭَّا أَمْ مَامّشْ ذ أَسْ إِنَّا بَالْعَامْ ؤُشَا خْ كُوڒْ إِجّْ ن ؤُعَالْطَارْ إِقدّمْ \add ذِينْ\add* إِجّْ ن ؤُفُونَاسْ أَمژْيَانْ ذ إِجّْ ن إِشَارِّي.   
\b  
\b  
\m  
\c 24
\s1 أَوَاڒنْ إِوزْننْ ن بَالْعَامْ  
\m
\v 1 إِژْرَا بَالْعَامْ بلِّي أَقَا يَارْضَا إِ ثِيطَّاوِينْ ن سِيذِي ؤُمِي إِبَاركْ إِسْرَائِيل ؤُشَا \add خنِّي\add* وَارْ يَارزُّو، أَمْ ؤُمُورْ \add أَمزْوَارُو\add* ذ ؤُمُورْ \add وِيسّْ ثْنَاينْ\add*، حِيمَا \add أَذْ إِعزّمْ\add* س إِفِيغْرَانْ، مَاشَا يَارَّا ؤُذمْ نّسْ غَارْ ڒخْڒَا.  
\v 2 \add ؤُمِي\add* إِسّْڭعّذْ ثَامُوغْڒِي نّسْ، إِژْرَا إِسْرَائِيل إِزْذغْ \add ذِينْ\add*، \add ثتّْوَاستّفْ\add* عْلَاحْسَابْ ثِيقبَّاڒْ نّسْ، \add خنِّي\add* يُوسَا-د أَرُّوحْ ن أَربِّي خَاسْ.  
\v 3 إِبْذَا نتَّا أَوَاڒْ نّسْ إِوزْننْ، إِنَّا:  
\b  
\m \qt ”أَوَاڒْ ن بَالْعَامْ، مِّيسْ ن بَاعُورْ،\qt*  
\m \qt أَوَاڒْ ن ورْيَازْ إِجهْذنْ، ونِّي ؤُمِي ثقّنْ ثِيطّْ،\qt*   
\m
\v 4 \qt إِجّْ ن وَاوَاڒْ ن ونِّي إِسْڒِينْ أَوَاڒنْ ن أَربِّي،\qt*  
\m \qt ذ ونِّي إِخزَّارنْ ڒوْحِييْ\qt*  
\m \qt ن ؤُمْزمَّارْ خْ كُوڒْشِي،\qt*  
\m \qt \+tl أَمْ\+tl* د-إِوْضَا س ثِيطَّاوِينْ يَارزْمنْ.\qt*   
\m
\v 5 \qt \+tl أَ\+tl* يَاعْقُوبْ، مشْحَاڒْ صبْحنْ إِقِيضَانْ نّشْ،\qt*  
\m \qt ذ ثْزذِّيغِينْ نّشْ، \+tl أَ\+tl* إِسْرَائِيل!،\qt*   
\m
\v 6 \qt أَقَا سّْوِيژَّاضنْ أَمشْنَاوْ ثِيغْزُورِينْ،\qt*  
\m \qt أَمشْنَاوْ أَغمُّويْ إِشوَّارنْ أَكْ-ذ يغْزَارْ،\qt*  
\m \qt أَمشْنَاوْ أَشْفِيڒْ نِّي إِژُّو سِيذِي،\qt*  
\m \qt أَمشْنَاوْ ثِيشجُّورَا ن ثنْڭلْثْ\qt*  
\m \qt زَّاثْ إِ وَامَانْ.\qt* \f ◼ \fr 24:‏6 \ft \+bd ’أَشْفِيڒْ‘\+bd* - إِخْسْ أَذْ يِينِي ’أَلُووِي‘ (’أَلُووِيسْ‘)\f*   
\m
\v 7 \qt زڭْ إِبُوقَاڒنْ نّسْ أَذْ سِّيزّْڒنْ وَامَانْ\qt*  
\m \qt ؤُشَا زَّارِيعثْ نّسْ \+tl أَذْ ثِيڒِي\+tl* ذِي ثُوفّثْ.\qt*  
\m \qt أَجدْجِيذْ نّسْ أَذْ إِتّْوَاسّْڭعّذْ خْ أَجَاجْ\qt*  
\m \qt ؤُ ثَاڭلْذِيثْ نّسْ أَذْ ثتّْوَاسُّوعْڒَا.\qt*   
\m
\v 8 \qt أَربِّي إِسُّوفّغْ إِ-ث-إِ-د زِي مِيصْرَا.\qt*  
\m \qt جّهْذْ نّسْ أَمْ وَاشَّاونْ \+tl إِزِيرَارنْ\+tl*\qt*  
\m \qt ن إِغَايْضْ ن ڒخْڒَا.\qt*  
\m \qt أَذْ يشّْ ڒڭْنُوسْ، إِغْرِيمنْ نّسْ،\qt*  
\m \qt أَذْ إِڒْبزْ إِغُوسَّانْ نْسنْ\qt*  
\m \qt ؤُشَا أَذْ \+tl ثنْ\+tl* إِسّْنُوقّبْ س فْڒِيثْشَاثْ نّسْ.\qt* \x ◘ \xo 24:‏8 \xt ڒخْڒ. 23‏:‏22\x*   
\m
\v 9 \qt أَقَا إِغْنسْ،\qt*  
\m \qt إِسّزّڒْ إِخفْ نّسْ أَمْ ويْرَاذْ،\qt*  
\m \qt أَمْ ثيْرَاذْثْ.\qt*  
\m \qt وِي ث إِ د غَا إِسّكَّارنْ؟\qt*  
\m \qt ونِّي شكْ إِتّْبَارْكنْ، أَذْ إِتّْوَابَاركْ\qt*  
\m \qt ؤُ ونِّي شكْ إِنعّْڒنْ، أَذْ يِيڒِي إِتّْوَانْعڒْ!‘ “\qt* \x ◘ \xo 24:‏9 \xt أَمز. 49‏:‏9؛ ڒخْڒ. 23‏:‏24\x*   
\b  
\m
\v 10 \add خنِّي\add* يَارْغَا ؤُخيّقْ ن بَالَاكْ خْ بَالْعَامْ. إِوْثَا نتَّا ذڭْ إِفَاسّنْ نّسْ ؤُشَا بَالَاكْ إِنَّا إِ بَالْعَامْ: ”أَقَا ڒَاغِيغْ-د شكْ مَاحنْذْ أَذْ ثْنعْڒذْ ڒْعذْيَانْ إِنُو، \add مَاشَا\add* خْزَارْ، أَقَا ثْبَارْكذْ \add إِ-ثنْ\add* عَاذْ نِيشَانْ ثْڒَاثَا ن إِمُورنْ!  
\v 11 خنِّي ڒخُّو، أَرْوڒْ غَارْ ومْشَانْ مَانِي ثْزدّْغذْ! نشّْ نِّيغْ أَشْ ث، أَذْ شكْ شنْعغْ أَطَّاسْ، \add مَاشَا\add* خْزَارْ، سِيذِي إِمْنعْ خَاكْ شّنْعثْ نِّي!“   
\m
\v 12 \add خنِّي\add* إِنَّا بَالْعَامْ إِ بَالَاكْ: ”مَا وَارْ سِّيوْڒغْ أَكْ-ذ إِرقَّاسنْ نِّي ذ أَيِي د-ثسّكّذْ ؤُشَا نِّيغْ:  
\v 13 ’وَاخَّا بَالَاكْ أَذْ أَيِي إِوْشْ ثَادَّارْثْ نّسْ ثشُّورْ س نُّوقَارْثْ ذ وُورغْ، \add خنِّي\add* نشّْ \add عَاذْ\add* وَارْ زْمِيرغْ أَذْعذِّيغْ خْ ڒُومُورْ ن سِيذِي، مَاحنْذْ أَذْ ڭّغْ شَا ن ڒْحَاجّثْ ن ڒْخَارْ نِيغْ ن ڒْغَارْ \add إِ د-إِتّفّْغنْ\add* زڭْ وُوڒْ إِنُو. مِينْ غَا يِينِي سِيذِي، أَذْ ث إِنِيغْ.‘ \x ◘ \xo 24:‏13 \xt ڒخْڒ. 22‏:‏18\x*  
\v 14 ڒخُّو خنِّي، خْزَارْ، نشّْ أَذْ د-ذوْڒغْ غَارْ ڒْڭنْسْ إِنُو. أَسْ-د، نشّْ أَذْ شكْ سَّارڭْبغْ خْ ڒفْهَامثْ ؤُشَا أَذْ أَشْ إِنِيغْ مِينْ ذ أَشْ غَا يڭّْ ڒْڭنْسْ-أَ ذڭْ ؤُنڭَّارْ ن وُوسَّانْ.“   
\m
\v 15 \add خنِّي\add* إِبْذَا نتَّا أَوَاڒْ إِوزْننْ نّسْ، إِنَّا:  
\b  
\m \qt ”أَوَاڒْ ن بَالْعَامْ، مِّيسْ ن بَاعُورْ،\qt*  
\m \qt أَوَاڒْ ن ورْيَازْ إِجهْذنْ،\qt*  
\m \qt ونِّي ؤُمِي ثقّنْ ثِيطّْ!\qt*   
\b  
\m
\v 16 \qt ثَاوَاڒْثْ ن ونِّي إِسْڒِينْ أَوَاڒنْ ن أَربِّي،\qt*  
\m \qt ذ ونِّي إِسّْننْ زِي ثُوسّْنَا\qt*  
\m \qt ن ونِّي ذ أَمْعُودْجِي خْ كُوڒْشِي،\qt*  
\m \qt ذ ونِّي إِخزَّارنْ ڒوْحِييْ\qt*  
\m \qt ن ؤُمْزمَّارْ خْ كُوڒْشِي،\qt*  
\m \qt \+tl أَمْ\+tl* د-إِوْضَا س ثِيطَّاوِينْ يَارزْمنْ.\qt*   
\m
\v 17 \qt أَذْ ث ژَترْغْ، وَارْ إِدْجِي ڒخُّو،\qt*  
\m \qt أَذْ ث ثْوَاڒِيغْ، \+tl مَاشَا\+tl* وَارْ إِدْجِي زِي ڒَاذَاسثْ.\qt*  
\m \qt أَذْ د-إِفّغْ إِثْرِي زِي يَاعْقُوبْ\qt*  
\m \qt ؤُشَا أَذْ ثكَّارْ ؤُزدْجَاضْ\qt*  
\m \qt \+tl ن ڒْحَاكمْ\+tl* زِي إِسْرَائِيل،\qt*  
\m \qt ونِّي إِ غَا إِڒبْزنْ لْحنْكَاثْ\qt*  
\m \qt \+tl ن ؤُزدْجِيفْ\+tl* ن مُوآبَ\qt*  
\m \qt ؤُشَا أَذْ إِڒْبزْ مَارَّا ثَارْوَا ن سّْذعْ\qt* \x ◘ \xo 24:‏17 \xt إِرْم. 48‏:‏45\x*   
\m
\v 18 \qt ؤُشَا أَذْ إِتّْوَاطّفْ إِذُومْ ذ ڒْوَارْثْ\qt*  
\m \qt ؤُ سَاعِيرْ، \+tl ونِّي\+tl* ذ ڒعْذُو نّسْ،\qt*  
\m \qt أَذْ ث طّْفنْ ذ ڒْوَارْثْ \+tl عَاوذْ\+tl*،\qt*  
\m \qt ؤُشَا \+tl أَمُّو\+tl* إِ غَا يڭّْ إِسْرَائِيل س ثَارْيَاسْثْ.\qt*   
\m
\v 19 \qt ؤُ \+tl ونِّي إِ د غَا إِفّْغنْ\+tl* زِي يَاعْقُوبْ أَذْ إِحْكمْ\qt*  
\m \qt ؤُ نتَّا أَذْ إِسّْهلّكْ\qt*  
\m \qt ونِّي يَاروْڒنْ زِي ثنْذِينْثْ.“\qt* \x ◘ \xo 24:‏19 \xt 2 صم. 8‏:‏14\x*   
\b  
\m
\v 20 \add ؤُمِي\add* نتَّا إِژْرَا عَامَالِيقْ، إِبْذَا أَوَاڒْ إِوزْننْ نّسْ، إِنَّا:  
\b  
\m \qt ”عَامَالِيقْ ذ أَمزْوَارُو ن ڒڭْنُوسْ،\qt*  
\m \qt مَاشَا أَنڭَّارُو نّسْ أَذْ إِذْوڒْ ذ أَهلّكْ!“\qt*   
\b  
\m
\v 21 \add ڒَْامِي\add* إِژْرَا إِقِينِييّنْ، إِبْذَا نتَّا أَوَاڒْ إِوزْننْ نّسْ، إِنَّا:  
\b  
\m \qt ”ثَازذِّيغْثْ نّشْ ثمْثنْ\qt*  
\m \qt ؤُشَا ثڭِّيذْ ڒْعُوشّْ نّشْ ذِي ثصْضَارْثْ.\qt*   
\m
\v 22 \qt عَاذْ قَايِينْ أَذْ إِتّْوَاسّشْمضْ.\qt*  
\m \qt أَڒْ مڒْمِي إِزمَّارْ أَشُّورْ\qt*  
\m \qt أَذْ أَشْ د-يَاوِي ذ أَمحْبُوسْ؟“\qt*   
\b  
\m
\v 23 ؤُشَا إِبْذَا نتَّا أَوَاڒْ إِوزْننْ نّسْ، إِنَّا:  
\b  
\m \qt ”أَيْ، وِي غَا إِقِّيمنْ إِدَّارنْ\qt*  
\m \qt خْمِي خَاسْ إِ غَا إِسَّارْسْ أَربِّي مَانْ أَيَا؟\qt*   
\m
\v 24 \qt إِغَارُّوبَا زِي جّْوَايهْ ن كِيتِّيمْ\qt*  
\m \qt أَذْغزَّانْ أَشُّورْ\qt*  
\m \qt ؤُشَا أَذْغزَّانْ \+tl عَاوذْ\+tl* عَابِيرْ\qt*  
\m \qt ؤُ نتَّا أَذْ إِتّْوَاثحَّا.“\qt* \f ◼ \fr 24:‏24 \ft \+bd ’كِيتِّيمْ‘\+bd* - إِخْسْ أَذْ يِينِي ’قُوبْرُوسْ‘.\f*   
\b  
\m
\v 25 إِكَّارْ بَالْعَامْ، يُويُورْ ؤُشَا إِذْوڒْ غَارْ ومْشَانْ نّسْ \add ن ثْزذِّيغْثْ\add*. ؤُڒَا ذ بَالَاكْ إِطّفْ أَبْرِيذْ نّسْ.   
\b  
\b  
\m  
\c 25
\s1 إِسْرَائِيل ذ لْ-أَصْنَامْ ن يسِّيسْ ن مُوآبَ  
\m
\v 1 إِزْذغْ إِسْرَائِيل ذِي شِيطِّيمْ ؤُشَا إِبْذَا ڒْڭنْسْ أَذْ إِسّفْسذْ إِخفْ نّسْ أَكْ-ذ يسِّيسْ ن مُوآبَ. \x ◘ \xo 25:‏1 \xt ڒخْڒ. 31‏:‏16؛ 33‏:‏49\x*  
\v 2 عَارْضنْ-د ڒْڭنْسْ غَارْ ثْغَارْصِي ن إِربِّيثنْ نْسنْثْ ؤُشَا ڒْڭنْسْ إِشَّا \add زَّايْسنْثْ\add*، ؤُشَا نِيثْنِي بنْذْقنْ إِ إِربِّيثنْ نْسنْثْ. \x ◘ \xo 25:‏2 \xt إِزهد. 106‏:‏28؛ حُوش. 9‏:‏10\x*  
\v 3 \add أَمُّو\add* إِمُونْ ڒْڭنْسْ أَكْ-ذ بَاعْلْ-فَاغُورْ ؤُشَا يَارْغَا وغْضَابْ ن سِيذِي خْ إِسْرَائِيل. \x ◘ \xo 25:‏3 \xt إِزهد. 106‏:‏29\x*   
\m
\v 4 إِنَّا سِيذِي إِ مُوسَا: ”كْسِي مَارَّا \add إِرْيَازنْ نِّي إِدْجَانْ\add* ذ إِزدْجِيفنْ نْ ڒْڭنْسْ ؤُشَا أَيڒْ إِ-ثنْ زَّاثْ إِ سِيذِي ذِي ثْفُوشْثْ \add إِحَارّنْ\add*، \add خنِّي\add* أَذْ إِڭّْوجْ ڒْحَاذُوقْ ن وغْضَابْ ن سِيذِي خْ إِسْرَائِيل.“ \x ◘ \xo 25:‏4 \xt أَعَوذ. 4‏:‏3؛ ياش. 22‏:‏17\x*  
\v 5 \add خنِّي\add* إِنَّا مُوسَا إِ ڒْقُوضَاثْ ن إِسْرَائِيل: ”أجّْ كُوڒْ إِجّْ أَذْ إِنغْ \add إِنِّي\add* زِي جَارْ يرْيَازنْ نّسْ إِ إِمُوننْ أَكْ-ذ بَاعْلْ-فَاغُورْ!“   
\m
\v 6 ؤُشَا خْزَارْ، إِجّْ ن ورْيَازْ زڭْ أَيْثْ ن إِسْرَائِيل يُوسَا-د ؤُشَا نتَّا يِيوِي-د إِشْثْ ن \add ثمْغَارْثْ\add* ثْمِيذِييَانشْثْ غَارْ أَيْثْمَاسْ زَّاثْ إِ ثِيطَّاوِينْ ن مُوسَا ؤُ زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل، أَمْ تّْرُونْ نِيثْنِي غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 7 إِژْرَا إِ-ث فِينَاحَاسْ، مِّيسْ ن أَلِيعَازَارْ، مِّيسْ ن هَارُونْ. نتَّا إِكَّارْ زِي ڒْوسْطْ ن ثْمسْمُونْثْ، إِكْسِي إِجّْ ن ؤُحْرِيشْ ذڭْ ؤُفُوسْ نّسْ \x ◘ \xo 25:‏7 \xt إِزهد. 106‏:‏30\x*  
\v 8 ؤُشَا إِرُوحْ أَوَارْنِي إِ ورْيَازْ زِي إِسْرَائِيل غَارْ ؤُقِيضُونْ س ڒْقُوبّثْ ؤُشَا إِسّْنُوقّبْ إِ-ثنْ س ثْنَاينْ، \add أَمْ\add* ورْيَازْ نِّي زِي إِسْرَائِيل، أَمْ ثمْغَارْثْ س ؤُعذِّيسْ نّسْ. \add خنِّي\add* ثْبدّْ جّْرِيحشْثْ خْ أَيْثْ ن إِسْرَائِيل.  
\v 9 ؤُشَا مُّوثنْ ذِي جّْرِيحشْثْ أَربْعَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن إِوْذَانْ\add*. \x ◘ \xo 25:‏9 \xt 1 كُور. 10‏:‏8\x*   
\m
\v 10 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 11 ”فِينحَاسْ، مِّيسْ ن أَلِيعَازَارْ، مِّيسْ ن هَارُونْ، أَكهَّانْ، إِسّڭّْوجْ أَسْعَارْ إِنُو خْ أَيْثْ ن إِسْرَائِيل، مِينْزِي نتَّا ثُوغَا إِمْحضْ \add أَطَّاسْ\add* ذِي ڒْوسْطْ نْسنْ ذِي طّْوعْ ن ثُوسْمِي إِنُو \add إِقدّْسنْ\add*، أَڒَامِي نشّْ وَارْ \add هْذِيجغْ عَاذْ\add* أَذْ ثحِّيغْ أَيْثْ ن إِسْرَائِيل ذِي \add ڒْوقْثْ ن\add* ثُوسْمِي إِنُو \add إِقدّْسنْ\add*. \x ◘ \xo 25:‏11 \xt 2 كُور. 11‏:‏2\x*  
\v 12 س ؤُيَا إِنِي: ’خْژَارْ، نشّْ أَذْ أَسْ وْشغْ ڒْعَاهْذْ إِنُو ن ڒهْنَا. \x ◘ \xo 25:‏12 \xt 106‏:‏31\x*  
\v 13 إِ نتَّا ؤُ إِ زَّارِيعثْ نّسْ أَوَارْنِي أَسْ أَذْ غَارْسنْ يِيڒِي ڒْعَاهْذْ ن ثُوكهَّانْثْ إِ ڒبْذَا، مِينْزِي نتَّا ثُوغَا إِمْحضْ ذِي طّْوعْ ن أَربِّي نّسْ ؤُشَا إِڭَّا أَصْڒَاحْ ذِي طّْوعْ ن أَيْثْ ن إِسْرَائِيل.‘ “   
\m
\v 14 إِسمْ ن ورْيَازْ ن إِسْرَائِيل نِّي إِنْغَا فِينحَاسْ، إِ ثُوغَا إِتّْوَانغْ \add جْمِيعْ\add* أَكْ-ذ ثمْغَارْثْ ثَامِيذْيَانشْثْ، \add ثُوغَا-ث\add* ذ زِيمْرِي، مِّيسْ ن سَالُو، إِجّْ ن ڒْحَاكمْ خْ ثَادَّارْثْ ن بَابَاثْسنْ، خْ إِشِيمْعُونِييّنْ.  
\v 15 إِسمْ ن ثمْغَارْثْ ثَامِيذْيَانِيشْثْ إِ ثُوغَا إِتّْوَانْغنْ \add ثُوغَا-ت\add* كُوزْبِي، يدْجِيسْ ن صُورْ، ونِّي ذ إِجّْ ن ؤُزدْجِيفْ خْ ثْقبَّاڒْثْ ن ثَادَّارْثْ ن إِجّْ ن ثْبَابَاثْ ن إِمِيذْيَانِييّنْ.   
\b  
\m
\v 16 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 17 ”حْصَارمْ خْ إِمِيذْيَانِييّنْ ؤُشَاغلّْبمْ خَاسنْ، \x ◘ \xo 25:‏17 \xt ڒخْڒ. 31‏:‏2\x*  
\v 18 مِينْزِي نِيثْنِي حْصَارنْ كنِّيوْ س ثحْرَايْمشْثْ نْسنْ س مِينْزِي كنِّيوْ زڒْغنْ زِي جِّيهثْ ن فَاغُورْ ذ كُوزْبِي، يدْجِيسْ ن ڒْحَاكمْ ن مِيذْيَانْ، ؤُتْشْمَاثْسنْ، ثنِّي إِتّْوَانْغنْ ذڭْ وَاسّْ ن جّْرِيحشْثْ ذِي سِّيبّثْ ن فَاغُورْ.“ \x ◘ \xo 25:‏18 \xt أَسَا. 18‏:‏6\x*   
\m
\v 19 ؤُشَا أَوَارْنِي إِ جّْرِيحشْثْ إِمْسَارْ \add مِينْ د-إِڭُّورنْ.\add*   
\b  
\b  
\m  
\c 26
\s1 إِتّْوَاحْسبْ إِسْرَائِيل إِ ثْوَاڒَا وِيسّْ ثْنَاينْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ أَلِيعَازَارْ، مِّيسْ ن هَارُونْ، أَكهَّانْ، إِنَّا:   
\m
\v 2 ”حسْبمْ مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل، أَزدْجِيفْ \add أَزدْجِيفْ\add*، زِي عِيشْڒِينْ ن إِسڭّْوُوسَا سنّجْ، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ ثَادَّارْثْ ن إِبَابَاثنْ نْسنْ، مَارَّا ونِّي د-إِتّفّْغنْ ذِي إِسْرَائِيل أَكْ-ذ ڒْعسْكَارْ.“ \x ◘ \xo 26:‏2 \xt ڒخْڒ. 1‏:‏3\x*  
\v 3 مُوسَا ذ أَلِيعَازَارْ، أَكهَّانْ، سِّيوْڒنْ أَكِيذْسنْ ذِي ڒوْضَاثْ ن مُوآبَ، غَارْ لْ-ؤُرْذُونْ \add أَرنْذَاذْ ن\add* أَرِيحَا ؤُشَا نَّانْ:  
\v 4 ”زِي عِيشْڒِينْ ن إِسڭّْوُوسَا سنّجْ!“ أَمْ مَامّشْ \add ث\add* يُومُورْ سِيذِي إِ مُوسَا.  
\b  
\m \add إِنَا ذ\add* أَيْثْ ن إِسْرَائِيل نِّي ثُوغَا د-إِفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا: \x ◘ \xo 26:‏4 \xt ڒخْڒ. 1‏:‏1، 2، 3\x*   
\b  
\m
\v 5 \bd رُوبِينْ \+bdit ثُوغَا\+bdit* ذ أَمنْزُو ن إِسْرَائِيل.\bd*  
\m \bd أَقَا إِنَا ذ إِحنْجِيرنْ ن رُوبِينْ\bd*: \add زِي\add* حَانُوكْ ڒَادْجْ ن إِحَانُوكِييّنْ، زِي فَالُّو ڒَادْجْ ن إِفَالُّووِييّنْ، \x ◘ \xo 26:‏5 \xt أَمز. 46‏:‏9؛ ؤُف. 6‏:‏14؛ 1 إِم. 5‏:‏1\x*   
\m
\v 6 زِي حَاصْرُونْ ڒَادْجْ ن إِحَاصْرُونِييّنْ، زِي كَارْمِي ڒَادْجْ ن إِكَارْمِييّنْ.   
\m
\v 7 ثِينَا \add ثُوغَا\add* ذ ڒَادْجَاثْ ن إِرُوبِينِييّنْ ؤُشَا إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ ثُوغَا أَثنْ ذِي ثْڒَاثَا ؤُ-ربْعِينْ-أَڒفْ ؤُ-سبْعَا-مْيَا ؤُ-ثْڒَاثِينْ \add ن يرْيَازنْ\add*.   
\m
\v 8 ثَارْوَا ن فَالُّو \add ثُوغَا أَثنْ\add*: \add مْغِيرْ\add* إِلِييَابْ.   
\m
\v 9 \add ثُوغَا\add* أَرَّاوْ ن إِلِييَابْ: نِيمُويِيلْ، ذَاثَانْ ذ أَبِيرَامْ. إِنَا، ذَاثَانْ ذ أَبِيرَامْ، ثُوغَا أَثنْ ذ إِمْڒَاغَانْ ن ثْمسْمُونْثْ إِنِّي إِغوّْغنْ ضِيدّْ إِ مُوسَا ذ هَارُونْ، \add جْمِيعْ\add* أَكْ-ذ ؤُبَارُّو ن قُورَاحْ، ؤُمِيغوّْغنْ ضِيدّْ إِ سِيذِي. \f ◼ \fr 26:‏9 \ft \+bd ’إِمْڒَاغَانْ‘\+bd* - إِخْسْ أَذْ يِينْ ’إِنِّي إِتّْوَاڒَاغَانْ‘.\f*  \x ◘ \xo 26:‏9 \xt ڒخْڒ. 16‏:‏12\x*  
\v 10 ثَامُّورْثْ ثَارْزمْ أَقمُّومْ نّسْ ؤُشَا ثْسَارْضْ إِ-ثنْ، \add جْمِيعْ\add* أَكْ-ذ قُورَاحْ، ڒَامِي إِمُّوثْ ؤُبَارُّو نِّي ؤُمِي ثِيمسِّي ثشَّا مِيثَاينْ ؤُ-خمْسِينْ ن يرْيَازنْ. ذوْڒنْ نِيثْنِي ذ إِجّْ ن وعْڒَامْ \add إِسِّيڭّْوِيذنْ\add*.  
\v 11 مَاشَا إِحنْجِيرنْ ن قُورَاحْ وَارْ مُّوثنْ شَا.   
\b  
\m
\v 12 \bd \+bdit إِنَا ثُوغَا\+bdit* ذ إِحنْجِيرنْ ن شِيمْعُونْ عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ:\bd* \add زِي\add* نِيمُويِيلْ \add إِقَّارْصْ\add* ڒَادْجْ ن إِنِيمُويِيلِييّنْ، زِي يَامِينْ ڒَادْجْ ن إِيَامِينِييّنْ، زِي يَاكِينْ ڒَادْجْ ن إِيَاكِينِييّنْ،  
\v 13 زِي زَارَاحْ ڒَادْجْ ن إِزَارَاحِييّنْ، زِي شَاوُولْ ڒَادْجْ ن إِشَاوُولِييّنْ.  
\v 14 ثِينَا \add ثُوغَا\add* ذ ڒَادْجَاثْ ن إِشِيمْعُونِييّنْ: ثْنَاينْ ؤُ-عِيشْرِينْ-أَڒفْ ؤُ-مِيثَايْنْ \add ن يرْيَازنْ\add*.   
\b  
\m
\v 15 \bd \+bdit إِنَا ثُوغَا\+bdit* ذ إِحنْجِيرنْ ن جَاذْ عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ:\bd* \add زِي\add* صِيفُونْ \add إِقَّارْصْ\add* ڒَادْجْ ن إِصِيفُونِييّنْ، زِي حَاجِّي ڒَادْجْ ن إِحَاجِّيوِييّنْ، زِي شُونِي ڒَادْجْ ن إِشُونِييّنْ،  
\v 16 زِي ؤُزْنِي ڒَادْجْ ن إِيُوزْنِييّنْ، زِي عِيرِي ڒَادْجْ ن إِعِيرِييّنْ،  
\v 17 زِي أَرُوذْ ڒَادْجْ ن إِرُوذِييّنْ، زِي أَرِييِيلِي ڒَادْجْ ن إِرِييِيلِييّنْ.  
\v 18 ثِينَا \add ثُوغَا أَثنْثْ ذ\add* ڒَادْجَاثْ ن جَاذْ ؤُشَا إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ ثُوغَا أَثنْ ذِي أَربْعِينْ-أَڒفْ ؤُ-خمْسَا-مْيَا.   
\b  
\m
\v 19 \bd أَيْثْ ن يَاهُوذَا\bd* \add ثُوغَا أَثنْ ذ\add* عِيرْ ذ ؤُنَانْ. \add مَاشَا\add* مُّوثنْ عِيرْ ذ ؤُنَانْ ذِي ثمُّورْثْ ن كنْعَانْ. \x ◘ \xo 26:‏19 \xt أَمز. 38‏:‏7، 10؛ 46‏:‏12\x*  
\v 20 \bd \+bdit إِنَا ثُوغَا أَثنْ\+bdit* ذ إِحنْجِيرنْ ن يَاهُوذَا عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ\bd*: \add زِي\add* شَايْلَا \add إِقَّارْصْ\add* ڒَادْجْ ن إِشِيلَايّنْ، زِي فَارِيصْ ڒَادْجْ ن إِفَارَاصِييّنْ، زِي زَارَاحْ ڒَادْجْ ن إِزَارَاحِييّنْ.   
\m
\v 21 \bd \+bdit إِنَا ثُوغَا أَثنْ\+bdit* ذ إِحنْجِيرنْ ن فَارِيصْ\bd*: \add زِي\add* حَاصْرُونْ \add إِقَّارْصْ\add* ڒَادْجْ ن إِحَاصْرُونِييّنْ، زِي حَامُولْ ڒَادْجْ ن إِحَامُولِييّنْ. \x ◘ \xo 26:‏21 \xt أَمز. 46‏:‏12\x*  
\v 22 ثِينَا \add ثُوغَا أَثنْثْ ذ\add* ڒَادْجَاثْ ن يَاهُوذَا ؤُشَا إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ ثُوغَا أَثنْ ذِي ستَّا ؤُ-سبْعِينْ-أَڒفْ ؤُ-خمْسَا-مْيَا \add ن يرْيَازنْ\add*.   
\b  
\m
\v 23 \bd \+bdit إِنَا ثُوغَا أَثنْ\+bdit* ذ إِحنْجِيرنْ ن إِسَّاكَارْ عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ:\bd* \add زِي\add* ثُولَاعْ \add إِقَّارْصْ\add* ڒَادْجْ ن إِثُولَاعِييّنْ، زِي بُووَا ڒَادْجْ ن إِپُووَانِييّنْ،  
\v 24 زِي يَاشُوبْ ڒَادْجْ ن إِيَاشُوبِييّنْ، زِي شِيمْرُونْ ڒَادْجْ ن إِشِيمْرُونِييّنْ.  
\v 25 ثِينَا \add ثُوغَا أَثنْثْ ذ\add* ڒَادْجَاثْ ن إِسَّاكَارْ ؤُشَا إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ ثُوغَا أَثنْ ذِي أَربْعَا ؤُ-ستِّينْ-أَڒفْ ؤُ-ثڒْثْ-مْيَا \add ن يرْيَازنْ\add*.   
\b  
\m
\v 26 \bd \+bdit إِنَا ثُوغَا أَثنْ\+bdit* ذ إِحنْجِيرنْ ن زابُولُونْ عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ:\bd* \add زِي\add* سَارِيذْ \add إِقَّارْصْ\add* ڒَادْجْ ن إِسَارِيذِييّنْ، زِي إِلُونْ ڒَادْجْ ن إِلُونِييّنْ، زِي يَاحْلِييِيلْ ڒَادْجْ ن إِيَاحْلِييِيلِييّنْ.  
\v 27 ثِينَا \add ثُوغَا أَثنْثْ ذ\add* ڒَادْجَاثْ ن إِزابُولُونِييّنْ ؤُشَا إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ ثُوغَا أَثنْ ذِي ستِّينْ-أَڒفْ ؤُ-خمْسَا-مْيَا \add ن يرْيَازنْ\add*.   
\b  
\m
\v 28 \bd \+bdit إِنَا ثُوغَا أَثنْ\+bdit* ذ إِحنْجِيرنْ ن يُوسُوفْ عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ:\bd* مَانَاسَّا ذ إِفْرَايِيمْ.   
\m
\v 29 \bd \+bdit إِنَا ثُوغَا أَثنْ\+bdit* ذ إِحنْجِيرنْ ن مَانَاسَّا:\bd* \add زِي\add* مَاكِيرْ \add إِقَّارْصْ\add* ڒَادْجْ ن إِمَاكِيرِييّنْ. مَاكِيرْ يجّْ-د جِيلْعَاذْ. زِي جِيلْعَاذْ \add إِقَّارْصْ\add* ڒَادْجْ ن إِجِيلْعَاذِييّنْ. \x ◘ \xo 26:‏29 \xt ياش. 17‏:‏1\x*   
\m
\v 30 \bd \+bdit إِنَا ثُوغَا أَثنْ\+bdit* ذ إِحنْجِيرنْ ن جِيلْعَاذْ\bd*: \add زِي\add* إِعَازَارْ \add إِقَّارْصْ\add* ڒَادْجْ ن إِعَازَارِييّنْ، زِي حَالَاقْ ڒَادْجْ ن إِحَالَاقِييّنْ،  
\v 31 زِي أَسْرِييِيلْ ڒَادْجْ ن إِسْرِييِيلِييّنْ، زِي شَاكَامْ ڒَادْجْ ن إِشَاكَامِييّنْ،  
\v 32 زِي شِيمِيذَاعْ ڒَادْجْ ن إِشِيمْذَاعِييّنْ، زِي حَافَارْ ڒَادْجْ ن إِحَافَارِييّنْ.   
\m
\v 33 صَالُوفْحَاذْ، مِّيسْ ن حَافَارْ، وَارْ ثُوغِي غَارسْ شَا إِحنْجِيرنْ، مْغِيرْ ثِيحنْجِيرِينْ. \add إِنَا ثُوغَا أَثنْ\add* ذ إِسْمَاونْ ن يسِّيسْ ن صَالُوفْحَاذْ: مَاحْلَا، نُوعَا، حُوجْلَا، مِيلْكَا ذ ثِيرْصَا. \x ◘ \xo 26:‏33 \xt ڒخْڒ. 27‏:‏1\x*   
\m
\v 34 ثِينَا \add ثُوغَا أَثنْثْ ذ\add* ڒَادْجَاثْ ن مَانَاسَّا ؤُشَا إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ ثُوغَا أَثنْ ذِي ثْنَاينْ ؤُ-خمْسِينْ-أَڒفْ ؤُ-سبْعَا-مْيَا \add ن يرْيَازنْ\add*.   
\b  
\m
\v 35 \bd إِنَا \+bdit ثُوغَا أَثنْ ذ\+bdit* إِحنْجِيرنْ ن إِفْرَايِيمْ\bd*، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ: \add زِي\add* شُوثَالَاحْ \add إِقَّارْصْ\add* ڒَادْجْ ن إِشُوثَالَاحِييّنْ، زِي بَاكَارْ ڒَادْجْ ن إِبَاكَارِييّنْ، زِي ثَاحَانْ ڒَادْجْ ن إِثَاحَانِييّنْ.   
\m
\v 36 إِنَا \add ثُوغَا أَثنْ ذ\add* إِحنْجِيرنْ ن شُوثَالَاحْ: زِي عِيرَانْ ڒَادْجْ ن إِعِيرَانِييّنْ.   
\m
\v 37 ثِينَا \add ثُوغَا أَثنْثْ ذ\add* ڒَادْجَاثْ ن وَارَّاونْ ن إِفْرَايِيمْ ؤُشَا إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ ثُوغَا أَثنْ ذِي ثْنَاينْ ؤُ-ثْڒَاثِينْ-أَڒفْ ؤُ-خمْسَا-مْيَا \add ن يرْيَازنْ\add*.  
\m إِنَا ثُوغَا أَثنْ ذ أَرَّاونْ ن يُوسُوفْ، \add تّْوَاستّْفنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.   
\b  
\m
\v 38 \bd \+bdit إِنَا ثُوغَا أَثنْ\+bdit* ذ إِحنْجِيرنْ ن بِينْيَامِينْ عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ:\bd* \add زِي\add* بِيلَاعْ \add إِقَّارْصْ\add* ڒَادْجْ ن إِبِيلَاعِييّنْ، زِي أَشْبِيلْ ڒَادْجْ ن إِشْبِيلِييّنْ، زِي أَحِيرَامْ ڒَادْجْ ن إِحِيرَامِييّنْ،  
\v 39 زِي شَافُوفَامْ ڒَادْجْ ن إِشَافُوفَامِييّنْ، زِي حُوفَامْ ڒَادْجْ ن إِحُوفَامِييّنْ.   
\m
\v 40 \bd \+bdit إِنَا ثُوغَا أَثنْ\+bdit* ذ إِحنْجِيرنْ ن بَالَاعْ\bd*: أَرْذْ ذ نُوعْمَانْ. \add زِي\add* أَرْذْ \add إِقَّارْصْ\add* ڒَادْجْ ن إِرْذِييّنْ، زِي نُوعْمَانْ ڒَادْجْ ن إِنُوعْمَانِييّنْ.   
\m
\v 41 إِنَا \add ثُوغَا أَثنْ ذ\add* إِحنْجِيرنْ ن بِينْيَامِينْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ ؤُشَا إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ ثُوغَا أَثنْ ذِي خمْسَا ؤُ-ربْعِينْ-أَڒفْ ؤُ-ستَّا-مْيَا \add ن يرْيَازنْ\add*.   
\b  
\m
\v 42 \bd \+bdit إِنَا ثُوغَا أَثنْ\+bdit* ذ إِحنْجِيرنْ ن ذَانْ عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ:\bd* \add زِي\add* شُوحَامْ \add إِقَّارْصْ\add* ڒَادْجْ ن إِشُوحَامِييّنْ. ثِينَا \add ثُوغَا\add* ذ ڒَادْجَاثْ ن ذَانْ، \add تّْوَاستّْفنْثْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.   
\m
\v 43 مَارَّا ڒَادْجَاثْ ن إِشُوحَامِييّنْ، أَقَا إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ ثُوغَا أَثنْ ذِي أَربْعَا ؤُ-ستِّينْ-أَڒفْ ؤُ-أَربْعَا-مْيَا \add ن يرْيَازنْ\add*.   
\b  
\m
\v 44 \bd \+bdit إِنَا ثُوغَا أَثنْ\+bdit* ذ إِحنْجِيرنْ ن أَشِيرْ عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ:\bd* \add زِي\add* يِيمْنَا \add إِقَّارْصْ\add* ڒَادْجْ ن إِيِيمْنِييّنْ، زِي يِيشْوِي ڒَادْجْ ن إِيِيشْوِييّنْ، زِي برِيعَا ڒَادْجْ ن إِبَارِيعِييّنْ.   
\m
\v 45 \bd \+bdit إِنَا ثُوغَا أَثنْ\+bdit* ذ إِحنْجِيرنْ ن برِيعَا:\bd* \add زِي\add* حَابِيرْ \add إِقَّارْصْ\add* ڒَادْجْ ن إِحَابِيرِييّنْ، زِي مَالْكِييِيلْ ڒَادْجْ ن إِمَالْكِييِيلِييّنْ.  
\v 46 إِسمْ ن يدْجِيسْ ن أَشِيرْ ثُوغَا-ت ذ سَارَاحْ.   
\m
\v 47 إِنَا \add ثُوغَا أَثنْ\add* ذ إِحنْجِيرنْ ن أَشِيرْ ؤُشَا إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ ثُوغَا أَثنْ ذِي ثْڒَاثَا ؤُ-خمْسِينْ-أَڒفْ ؤُ-أَربْعَا-مْيَا \add ن يرْيَازنْ\add*.   
\b  
\m
\v 48 \bd \+bdit إِنَا ثُوغَا أَثنْ\+bdit* ذ إِحنْجِيرنْ ن نَافْثَالِي عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ:\bd* \add زِي\add* يَاحَاسْيِيلْ \add إِقَّارْصْ\add* ڒَادْجْ ن إِيَاحَاسْلِييّنْ، زِي جُونِي ڒَادْجْ ن إِجُونِييّنْ،  
\v 49 زِي يَاصِيرْ ڒَادْجْ ن إِيَاصِيرِييّنْ، زِي شِيلِّيمْ ڒَادْجْ ن إِشِيلِّيمِييّنْ.   
\m
\v 50 ثِينَا \add ثُوغَا أَثنْثْ\add* ذ ڒَادْجَاثْ ن نَافْثَالِي، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ ؤُشَا إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ ثُوغَا أَثنْ ذِي خمْسَا ؤُ-ربْعِينْ أَڒَافْ ؤُ-أَربْعَا-مْيَا \add ن يرْيَازنْ\add*.   
\b  
\m
\v 51 \bd إِنَا ذ إِنِّي إِتّْوَاحسْبنْ زڭْ أَيْثْ ن إِسْرَائِيل: ستَّا-مْيَا ؤُ-وَاحِيثْ-أَڒفْ ؤُ-سبْعَا-مْيَا ؤُ-ثْڒَاثِينْ \+bdit ن يرْيَازنْ\+bdit*\bd*.   
\b  
\m
\v 52 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 53 ”جَارْ إِنَا أَذْ ثتّْوَابْضَا ثمُّورْثْ ذ ڒْوَارْثْ، عْلَاحْسَابْ ڒْقدّْ ن إِسْمَاونْ \add نْسنْ\add*.  
\v 54 إِ ونِّي ؤُمِي غَارْ إِدْجَا أَطَّاسْ \add ن إِوْذَانْ\add*، أَذْ ثوْشذْ كْثَارْ ذ ڒْوَارْثْ ؤُشَا إِ ونِّي ؤُمِي غَارْ إِدْجَا ذْرُوسْ \add ن إِوْذَانْ\add*، أَذْ ثوْشذْ قلّْ ذ ڒْوَارْثْ. كُوڒْ إِجّنْ عْلَاحْسَابْ إِنِّي إِتّْوَاحسْبنْ أَذْ أَسْ ثمّوْشْ ثَاسْغَارْثْ نّسْ. \x ◘ \xo 26:‏54 \xt ڒخْڒ. 33‏:‏54\x*  
\v 55 ثَامُّورْثْ أَذْ ثتّْوَابْضَا س ثْقدُّوحْثْ. نِيثْنِي أَذْ وَارْثنْ عْلَاحْسَابْ إِسْمَاونْ ن ثْقبَّاڒْ ن ڒجْذُوذْ نْسنْ. \x ◘ \xo 26:‏55 \xt ڒخْڒ. 33‏:‏54؛ ياش. 11‏:‏23؛ 14‏:‏2\x*  
\v 56 أَذْ ثتّْوَابْضَا ثسْغَارْثْ ن كُوڒْ إِجّْ س ثْقدُّوحْثْ جَارْ \add إِنِّي إِدْجَانْ س\add* وَاطَّاسْ ذ \add إِنِّي إِدْجَانْ\add* ذْرُوسْ.“   
\b  
\m
\v 57 \bd \+bdit إِنَا ثُوغَا أَثنْ\+bdit* ذ إِنِّي إِتّْوَاحسْبنْ زِي لَاوِي عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ:\bd* زِي جَارْشُونْ ڒَادْجْ ن إِجَارْشُونِييّنْ، زِي قَاهَاثْ ڒَادْجْ ن إِقَاهَاثِييّنْ، زِي مَارَارِي ڒَادْجْ ن إِمَارَارِييّنْ. \x ◘ \xo 26:‏57 \xt ؤُف. 6‏:‏17، 18، 19، 20\x*  
\v 58 \add ثُوغَا\add* ثِينَا ذ ڒَادْجَاثْ ن إِلَاوِييّنْ: ڒَادْجْ ن إِلِيبْنِييّنْ، ڒَادْجْ ن إِحِيبْرُونِييّنْ، ڒَادْجْ ن إِمَاهْلِييّنْ، ڒَادْجْ ن إِمُوشِييّنْ، ڒَادْجْ ن إِقُورَاحِييّنْ. ؤُشَا قَاهَاثْ يجّْ-د عَامْرَامْ.  
\v 59 ثَامْغَارْثْ ن عَامْرَامْ قَّارنْثْ أَسْ جُوكَابَاذْ، يدْجِيسْ ن لَاوِي، ثنِّي د-إِتّْوَارْونْ إِ لَاوِي ذِي مِيصْرَا. ذ نتَّاثْ ثُورُووْ-د هَارُونْ ذ مُوسَا ذ مَارْيَامْ، ؤُتْشْمَاثْسنْ، إِ عَامْرَامْ. \x ◘ \xo 26:‏59 \xt ؤُف. 2‏:‏1، 2؛ 6‏:‏19\x*  
\v 60 إِ هَارُونْ تّْوَارْونْ أَسْ-د نَاذَابْ ذ أَبِيهُو، أَلِيعَازَارْ ذ إِثَامَارْ.  
\v 61 مَاشَا نَاذَابْ ذ أَبِيهُو مُّوثنْ، ؤُمِي د-إِوْينْ ثِيمسِّي ثَاغْرِيبْثْ زَّاثْ إِ وُوذمْ ن سِيذِي. \x ◘ \xo 26:‏61 \xt لَاوِي 10‏:‏2؛ ڒخْڒ. 3‏:‏4؛ 1 إِم. 24‏:‏2\x*  
\v 62 إِنِّي زَّايْسنْ إِتّْوَاحسْبنْ، زڭْ إِلَاوِييّنْ، مَارَّا إِوثْمَانْ ن إِجّْ ن ؤُيُورْ سنّجْ، ثُوغَا أَثنْ ذِي ثْڒَاثَا ؤُ-عِيشْرِينْ-أَڒفْ. إِنَا مَاشَا وَارْ تّْوَاحسْبنْ شَا أَكْ-ذ أَيْثْ ن إِسْرَائِيل، مِينْزِي وَارْ ذ أَسنْ ثمّوْشْ ثسْغَارْثْ ذ ڒْوَارْثْ جَارْ أَيْثْ ن إِسْرَائِيل.   
\b  
\m
\v 63 إِنَا \add ثُوغَا أَثنْ ذ\add* إِنِّي إِتّْوَاحسْبنْ س \add ؤُفُوسْ ن\add* مُوسَا ذ أَلِيعَازَارْ، أَكهَّانْ. نِيثْنِي حسْبنْ أَيْثْ ن إِسْرَائِيل ذِي ڒوْضَاثْ ن مُوآبَ، غَارْ لْ-ؤُرْذُونْ أَرنْذَاذْ ن أَرِيحَا.  
\v 64 وَارْ ثُوغِي جَارْ أَسنْ ؤُڒَا ذ إِجّْ زڭْ إِنِّي إِتّْوَاحسْبنْ ن مُوسَا ذ هَارُونْ، أَكهَّانْ، ؤُمِي حسْبنْ نِيثْنِي أَيْثْ ن إِسْرَائِيل ذِي ڒخْڒَا ن سِينَا.  
\v 65 مِينْزِي خَاسنْ ثُوغَا إِنَّا سِيذِي أَذْ مّْثنْ س ثِيذتّْ ذِي ڒخْڒَا. وَارْ زَّايْسنْ إِقِّيمْ ؤُڒَا ذ إِجّْ، مْغِيرْ كَالِيبْ، مِّيسْ ن يَافُونِّي، ذ يَاشُووَا، مِّيسْ ن نُونْ. \x ◘ \xo 26:‏65 \xt ڒخْڒ. 14‏:‏28، 29، 34، 35؛ 1 كُور. 10‏:‏5، 6\x*   
\b  
\b  
\m  
\c 27
\s1 يسِّيسْ ن صَالُوفْحَاذْ  
\m
\v 1 \add خنِّي\add* ؤُسِينْثْ-إِ-د يسِّيسْ ن صَالُوفْحَاذْ، مِّيسْ ن حَافَارْ، مِّيسْ ن جِيلْعَاذْ، مِّيسْ ن مَاكِيرْ، مِّيسْ ن مَانَاسَّا، \add إِنِّي إِدْجَانْ\add* ن ڒَادْجَاثْ ن مَانَاسَّا، مِّيسْ ن يُوسُوفْ. إِنَا ذ إِسْمَاونْ ن يسِّيسْ: مَاحْلَا، نُوعَا، حُوجْلَا، مِيلْكَا ذ ثِيرْصَا. \x ◘ \xo 27:‏1 \xt ڒخْڒ. 26‏:‏33؛ 36‏:‏2؛ ياش. 17‏:‏3\x*  
\v 2 ثُوغَا بدّنْثْ زَّاثْ إِ وُوذمْ ن مُوسَا ؤُ زَّاثْ إِ وُوذمْ ن أَلِيعَازَارْ، أَكهَّانْ، ؤُ زَّاثْ إِ وُوذمْ ن ڒْحُوكَّامْ ؤُ زَّاثْ إِ وُوذمْ ن مَارَّا ثَامسْمُونْثْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، نَّانْثْ:  
\v 3 ”بَابَاثْنغْ إِمُّوثْ ذِي ڒخْڒَا ؤُ وَارْ ث ثُوغِي جَارْ ؤُبَارُّو ن يِينِّي إِمُوننْ ضِيدّْ إِ سِيذِي، ذڭْ ؤُبَارُّو ن قُورَاحْ \add وَارْ ذِينْ ث ثُوغِي نتَّا\add*، مِينْزِي إِمُّوثْ ذِي دّْنُوبْ نّسْ ؤُ وَارْ غَارسْ ثُوغِي إِحنْجِيرنْ. \f ◼ \fr 27:‏3 \ft \+bd ’جَارْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ذِي ڒْوسْثْ ن‘.\f*  \x ◘ \xo 27:‏3 \xt ڒخْڒ. 14‏:‏35؛ 16‏:‏1؛ 26‏:‏64\x*  
\v 4 مَايمِّي غَا إِكّسْ إِسمْ ن بَابَاثْنغْ زِي جَارْ ڒَادْجْ نّسْ، مَا مِينْزِي وَارْ غَارسْ ثُوغِي بُو ؤُحنْجِيرْ؟ أوْشْ أَنغْ أَڭْڒَا ذِي ڒْوسْطْ ن أَيْثْمَاسْ ن بَابَاثْنغْ.“   
\m
\v 5 مُوسَا يِيوِي دّعْوَا نْسنْثْ زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 6 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 7 ”\add أَقَا أَيَا\add* أَمْ مَامّشْ ث نَّانْثْ يسِّيسْ ن صَالُوفْحَاذْ. إِتّْخصَّا أَذْ أَسنْثْ ثوْشذْ ثَاسْغَارْثْ ن ڒْوَارْثْ ذِي  ڒْوسْثْ ن أَيْثْمَاسْ ن بَابَاثْسنْ ؤُشَا أَذْ خَاسنْثْ ثسّعْذُوذْ ڒْوَارْثْ ن بَابَاثْسنْثْ. \x ◘ \xo 27:‏7 \xt ڒخْڒ. 36‏:‏2\x*  
\v 8 ؤُشَا أَذْ ثسِّيوْڒذْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، أَذْ ثِينِيذْ: ’مَاڒَا شَا ن يِيجّنْ إِمُّوثْ بْڒَا مِّيسْ، \add خنِّي\add* أَذْ ثسّعْذُومْ ڒْوَارْثْ نّسْ غَارْ يدْجِيسْ،  
\v 9 ؤُ مَاڒَا وَارْ غَارسْ يدْجِيسْ، أَذْ ثوْشمْ ڒْوَارْثْ نّسْ إِ يَايْثْمَاسْ.  
\v 10 مَاڒَا وَارْ غَارسْ أَيْثْمَاسْ \add عَاوذْ\add*، أَذْ ثوْشمْ ڒْوَارْثْ نّسْ إِ يَايْثْمَاسْ ن بَابَاسْ.  
\v 11 مَاڒَا بَابَاسْ وَارْ غَارسْ أَيْثْمَاسْ \add عَاوذْ\add*، أَذْ ثوْشمْ ڒْوَارْثْ نّسْ إِ رَادْجْ نّسْ، \add إِ\add* ونِّي \add إِ ذ أَسْ د-\add*يُوذْسنْ زِي ڒَادْجْ نّسْ، حِيمَا أَذْ ت إِوَارْثْ نتَّا.‘ مَانْ أَيَا أَذْ ثِيڒِي ذ إِشْثْ ن ثوْصيّثْ ن ؤُزرْفْ إِ ڒبْذَا إِ أَيْثْ ن إِسْرَائِيل، أَمْ مَامّشْ \add ث\add* يُومُورْ سِيذِي إِ مُوسَا.“   
\b  
\m  
\s1 أَڒقّمْ ن يَاشُووَا  
\m
\v 12 \add خنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”ڭعّذْ-د أَذْرَارْ-أَ أَبَارِيمْ ؤُشَا خْزَارْ ثَامُّورْثْ نِّي وْشِيغْ إِ أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 27:‏12 \xt أَعَوذ. 32‏:‏48، 49\x*  
\v 13 خْمِي ت غَا ثْژَارذْ، أَذْ ثمَّارْنِيذْ غَارْ ڒْڭنْسْ نّشْ، ؤُڒَا ذ شكْ، أَمْ مَامّشْ ؤُڒَا ذ ؤُمَاشْ هَارُونْ إِمَّارْنِي غَارْ ڒْڭنْسْ نّسْ، \x ◘ \xo 27:‏13 \xt ڒخْڒ. 20‏:‏24\x*  
\v 14 مِينْزِي كنِّيوْ ثْغوّْغمْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ ضِيدّْ إِ ڒُومُورْ إِنُو مَاحنْذْ أَذْ أَيِي ثسّْقدّْسمْ ذِي ڒخْڒَا ن صِينْ، ڒَامِي ذِينْ \add ثُوغَا\add* أَمْشُوبّشْ ذِي ثْمسْمُونْثْ. أَقَا ذ إِنَا ذ أَمَانْ ن مَارِيبَا، غَارْ قَاذَاشْ ذِي ڒخْڒَا ن صِينْ.“ \x ◘ \xo 27:‏14 \xt ڒخْڒ. 20‏:‏12\x*  
\v 15 إِسِّيوڒْ مُوسَا أَكْ-ذ سِيذِي، إِنَّا:   
\m
\v 16 ”أَذْ إِڭّْ سِيذِي، أَربِّي ن بُوحْبڒَاثْ ن مَارَّا دَّاثْ، أَحطُّو خْ ثْمسْمُونْثْ \add ذڭْ ؤُفُوسْ ن\add* إِجّْ ن ورْيَازْ، \x ◘ \xo 27:‏16 \xt ڒخْڒ. 16‏:‏22؛ عبر. 12‏:‏9\x*  
\v 17 \add حِيمَا\add* نتَّا أَذْ إِفّغْ زَّاثْ إِ وُوذمْ نْسنْ ؤُشَا أَذْ يَاذفْ زَّاثْ إِ وُوذمْ نْسنْ ؤُشَا أَذْ ثنْ إِنْذهْ غَارْ بَارَّا، أَذْ ثنْ إِسِّيذفْ غَارْ ذَاخڒْ، مَاحنْذْ ثَامسْمُونْثْ ن سِيذِي وَارْ ثتِّيڒِي أَمْ وُودْجِي بْڒَا أَمكْسَاوْ.“ \f ◼ \fr 27:‏17 \ft \+bd ’أَمكْسَاوْ‘\+bd* - نِيغْ ’ذ‘.\f*  \x ◘ \xo 27:‏17 \xt 1 إِج. 22‏:‏17؛ مت. 9‏:‏36؛ مك. 6‏:‏34\x*   
\m
\v 18 \add خنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”كْسِي يَاشُووَا، مِّيسْ ن نُونْ، إِجّْ ن ورْيَازْ إِ ذِي إِدْجَا أَرُّوحْ، ؤُشَا سَارْسْ خَاسْ أَفُوسْ نّشْ \x ◘ \xo 27:‏18 \xt أَعَوذ. 3‏:‏21؛ 34‏:‏9 \x*  
\v 19 ؤُشَا أَذْ ث ثڭّذْ زَّاثْ إِ وُوذمْ ن ؤُكهَّانْ أَلِيعَازَارْ ؤُ زَّاثْ إِ مَارَّا ثَامسْمُونْثْ، أَذْ أَسْ ثوْشذْ ڒُومُورْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ.  
\v 20 أوْشْ أَسْ \add شَا\add* زڭْ ؤُوقَّارْ نّشْ حِيمَا أَذْ \add أَسْ\add* ثْسڒْ مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل.  
\v 21 نتَّا أَذْ إِبدّْ زَّاثْ إِ ؤُكهَّانْ أَلِيعَازَارْ، ونِّي إِ غَا إِشَاوَارْ زَّاثْ إِ وُوذمْ ن سِيذِي عْلَاحْسَابْ ڒحْكَامْ ن ؤُرِيمْ. خْ ڒُومُورْ نّسْ أَذْ د-فّْغنْ غَارْ بَارَّا ؤُ خْ ڒُومُورْ نّسْ أَذْ أَذْفنْ غَارْ ذَاخڒْ، نتَّا ذ مَارَّا أَيْثْ ن إِسْرَائِيل ؤُڒَا ذ مَارَّا ثَامسْمُونْثْ.“ \x ◘ \xo 27:‏21 \xt ؤُف. 28‏:‏30؛ لَاوِي 8‏:‏8\x*   
\m
\v 22 ؤُشَا مُوسَا إِڭَّا أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي. يِيوِي يَاشُووَا ؤُشَا إِسّْبدّْ إِ-ث زَّاثْ إِ ؤُكهَّانْ أَلِيعَازَارْ ؤُ زَّاثْ إِ وُوذمْ ن مَارَّا ثَامسْمُونْثْ.  
\v 23 إِسَّارْسْ خَاسْ إِفَاسّنْ نّسْ ؤُشَا إِسّعْذُو أَسْ ڒُومُورْ أَمْ مَامّشْ ذ أَسْ إِنَّا سِيذِي س ثْسخَّارْثْ ن مُوسَا.   
\b  
\b  
\m  
\c 28
\s1 ثِيغَارْصَا ن كُوڒْ أَسّْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”ؤُمُورْ أَيْثْ ن إِسْرَائِيل، إِنِي أَسنْ: ’إِتّْخصَّا كنِّيوْ أَذْ ثحْضَامْ خْ ثْغَارْصْطْ إِنُو، مَاشَّا إِنُو إِ ثوْهِيبِينْ إِنُو ن ثْمسِّي، إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ نشّْ، مَاحنْذْ أَذْ أَيِي ثنْثْ ثْقدّْممْ ذِي ڒْوقْثْ نّسْ إِتّْوَاڭّنْ.‘  
\v 3 أَذْ أَسنْ ثِينِيذْ: ’أَقَا ثَا ذ ثَاوْهِيبْثْ ن ثْمسِّي إِ إِتّْخصَّانْ أَذْ ثْقدّْممْ: ثْنَاينْ ن إِزْمَارنْ إِشْنَانْ ن إِجّْ ن ؤُسڭّْوَاسْ، \add أَمْ\add* ثْغَارْصْثْ ن وشْمَاضْ ڒبْذَا. \x ◘ \xo 28:‏3 \xt ؤُف. 29‏:‏38\x*  
\v 4 إِجّْ ن إِزْمَارْ أَذْ ث ثسّْوجْذذْ ذِي صّْبحْ ؤُشَا إِزْمَارْ نّغْنِي أَذْ ث ثسّْوجْذذْ جَارْ بدُّو ن وزْينْ ن وَاسّْ أَڒْ د-ثوْضَا ثْمذِّيثْ  
\v 5 ؤُشَا \add أَكْ-ذ مَانْ أَيَا\add* أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِشْثْ ن ثعْشَارْثْ \add ن يِيجّْ ن إِفَا\add* ن وَارنْ أَزْذَاذْ إِخدْجْضنْ س يِيجّْ ن أَرْبعْ ن إِجّْ ن ؤُهِينُو ن زّشْثْ، تّْوَادّْزنْ ث-إِ-د \add زِي زِّيثُونْ\add*. \x ◘ \xo 28:‏5 \xt ؤُف. 16‏:‏36؛ 29‏:‏40؛ لَاوِي 2‏:‏1 \x*  
\v 6 أَقَا-ت ذ ثَاغَارْصْطْ ن وشْمَاضْ ن ڒبْذَا، ثنِّي ثُوغَا إِتّْوَاڭّنْ ذڭْ وذْرَارْ ن سِينَا أَمْ يِيشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ، \add أَقَا-ت\add* ذ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي.  
\v 7 ثَاوْهِيبْثْ نّسْ ن ؤُسيّبْ أَذْ ثِيڒِي ذ إِجّْ ن أَرْبعْ ن إِجّْ ن ؤُهِينُو إِ يِيجّْ ن إِزْمَارْ. سيّبْ ثَاوْهِيبْثْ ن ؤُسيّبْ ن شّْرَابْ ذِي زَّاوشْثْ إِقدّْسنْ زَّاثْ إِ سِيذِي.  
\v 8 أَذْ ثسّْوجْذذْ إِزْمَارْ نّغْنِي جَارْ بدُّو ن وزْينْ ن وَاسّْ أَڒْ د-ثوْضَا ثْمذِّيثْ. أَذْ ث ثسّْوجْذذْ أَمْ مَامّشْ \add ثسّْوجْذذْ\add* ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذِي صّْبحْ ؤُ أَمْ مَامّشْ \add ثسّْوجْذذْ\add* ثَاوْهِيبْثْ ن ؤُسيّبْ نّسْ، \add أَمْ\add* إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي، إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي.‘ “   
\b  
\m  
\s1 ثِيغَارْصَا ن كُوڒْ سِّيمَانَا  
\m
\v 9 ”ذڭْ وَاسّْ ن سّبْثْ \add أَذْ ثسّْوجْذذْ\add* ثْنَاينْ ن إِزْمَارنْ إِشْنَانْ ن إِجّْ ن ؤُسڭّْوَاسْ ذ ثْنَاينْ ن ثعْشُورِينْ \add ن يِيجّْ ن إِفَا\add* ن وَارنْ أَزْذَاذْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِخدْجْضنْ س زّشْثْ أَكْ-ذ ثوْهِيبْثْ نّسْ ن ؤُسيّبْ.  
\v 10 أَقَا-ت ذ ثَاغَارْصْطْ ن وشْمَاضْ ن سّبْثْ إِ مْكُوڒْ سّبْثْ، أَذْ ت ثَارْنِيذْ إِ ثْغَارْصْثْ ن وشْمَاضْ ن ڒبْذَا ذ ثوْهِيبْثْ نّسْ ن ؤُسيّبْ.“   
\b  
\m  
\s1 ثِيغَارْصَا ن كُوڒْ ؤُيُورْ  
\m
\v 11 ”ذڭْ ؤُمزْوَارْ ن \add كُوڒْ إِجّْ ن\add* إِيُورنْ نْومْ إِتّْخصَّا أَذْ ثْقدّْممْ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ إِ سِيذِي: ثْنَاينْ ن إِفُونَاسنْ - إِمژْيَاننْ ن إِشْثْ ن ثْفُونَاسْثْ - إِجّْ ن إِشَارِّي، سبْعَا ن إِزْمَارنْ إِشْنَانْ قَاعْ ن إِجّْ ن ؤُسڭّْوَاسْ  
\v 12 ؤُشَا \add أَكْ-ذ مَانْ أَيَا\add* ثْڒَاثَا ن ثعْشُورِينْ ن \add إِجّْ ن إِفَا ن\add* وَارنْ أَزْذَاذْ \add أَمْ\add* ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِخدْجْضنْ س زّشْثْ إِ يِيجّْ ن ؤُفُونَاسْ أَمژْيَانْ ؤُ ثْنَاينْ ن ثعْشُورِينْ ن \add يِيجّْ ن إِفَا ن\add* وَارنْ أَزْذَاذْ \add أَمْ\add* ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِخدْجْضنْ س زّشْثْ إِ يِيجّْ ن إِشَارِّي  
\v 13 \add ؤُشَا أَرْنِي\add* إِشْثْ ن ثعْشَارْثْ ن \add يِيجّْ ن إِفَا\add* ن وَارنْ أَزْذَاذْ \add أَمْ\add* ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِخدْجْضنْ س زّشْثْ إِ يِيجّْ ن إِزْمَارْ. \add أَقَا-ت\add* ذ ثَاغَارْصْثْ ن وشْمَاضْ س إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ، \add أَقَا-ت\add* ذ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي.  
\v 14 ثِيوْهِيبِينْ نْسنْ ن ؤُسيّبْ أَذْ إِڒِينْثْ ذ أَزْينْ ن ؤُهِينُو ن بِينُو أَكْ-ذ ؤُفُونَاسْ أَمژْيَانْ ذ إِشْثْ ن تُّوڒُوثْ ن إِجّْ ن ؤُهِينُو أَكْ-ذ إِشَارِّي ذ يِيجّْ ن أَرْبعْ ن إِجّْ ن ؤُهِينُو أَكْ-ذ إِزْمَارْ. ثَا ذ ثَاغَارْصْثْ ن وشْمَاضْ ن كُوڒْ أَيُورْ، إِ كُوڒْ أَيُورْ زڭْ إِيُورنْ ن ؤُسڭّْوَاسْ.  
\v 15 إِتّْخصَّا أَذْ ثسّْوجْذذْ إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ ذ ثَاغَارْصْثْ ن دّنْبْ إِ سِيذِي، أَذْ ت ثَارْنِيذْ إِ ثْغَارْصْثْ ن وشْمَاضْ نْ ڒبْذَا أَكْ-ذ ثوْهِيبْثْ نّسْ ن ؤُسيّبْ.“   
\b  
\m  
\s1 ثِيغَارْصَا ذڭْ وُوسَّانْ ن ڒْعِيذْ ن ؤُسعْذُو  
\m
\v 16 ذڭْ ؤُيُورْ أَمزْوَارُو، ذڭْ وَاسّْ وِيسّْ أَرْبعْطَاشْ ن ؤُيُورْ، أَذْ ثِيڒِي \add ثْغَارْصْثْ ن\add* ؤُسعْذُو ن سِيذِي. \x ◘ \xo 28:‏16 \xt ؤُف. 12‏:‏18؛ 23‏:‏15؛ لَاوِي 23‏:‏5\x*  
\v 17 ذڭْ وَاسّْ وِيسّْ خمّسْطَاشْ ن سِيمَانْثْ ن ؤُيُورْ \add أَذْ يِيڒِي\add* ڒْعِيذْ. سبْعَا ن وُوسَّانْ أَذْ شّنْ أَغْرُومْ بْڒَا أَنْثُونْ.  
\v 18 ذڭْ وَاسّْ أَمزْوَارُو \add ن ڒْعِيذْ\add* أَذْ يِيڒِي يِيجّْ ن ؤُمُونِي إِقدّْسنْ. وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ڒْخذْمثْ إِ إِتّْخصَّانْ أَذْ ثتّْوَاڭّْ. \x ◘ \xo 28:‏18 \xt لَاوِي 23‏:‏7\x*   
\m
\v 19 أَذْ ثْقدّْممْ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي \add أَمْ\add* ثْغَارْصْثْ ن وشْمَاضْ إِ سِيذِي: ثْنَاينْ ن إِفُونَاسنْ إِمژْيَاننْ ذ إِجّْ ن إِشَارِّي ذ سبْعَا ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. إِتّْخصَّا أَذْ إِڒِينْ شْنَانْ قَاعْ.  
\v 20 \add أَذْ ثِيڒِي\add* ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ن وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ. أَذْ \add زَّايسْ\add* ثسّْوجْذمْ ثْڒَاثَا ن ثعْشُورِينْ \add ن يِيجّْ ن إِفَا\add* إِ يِيجّْ ن ؤُفُونَاسْ أَمژْيَانْ ذ ثْنَاينْ ن ثعْشُورِينْ \add ن يِيجّْ ن إِفَا\add* إِ يِيجّْ ن إِشَارِّي.  
\v 21 أَذْ ثسّْوجْذذْ إِشْثْ ن ثعْشَارْثْ \add ن يِيجّْ ن إِفَا\add* إِ يِيجّْ ن إِزْمَارْ، \add ؤُشَا أَمُّو\add* إِ \add مَارَّا\add* سبْعَا ن إِزْمَارنْ \add نِّي\add*.  
\v 22 \add سوْجذْ عَاوذْ\add* إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ ذ ثَاغَارْصْثْ ن دّنْبْ مَاحنْذْ أَذْ إِتّْوَاڭّْ وصْڒَاحْ إِ كنِّيوْ.  
\v 23 أَذْ ثسّْوجْذمْ مَانْ أَيَا سنّجْ إِ \add ؤُسوْجذْ ن\add* ثْغَارْصْثْ وشْمَاضْ ذِي صّْبحْ نِّي \add إِدْجَانْ\add* ذ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ إِ ڒبْذَا.  
\v 24 أَمْ مَامّشْ ؤُيَا أَذْ ثسّْوجْذمْ مَاشَّا ن ثوْهِيبِينْ ن ثْمسِّي سبْعَا ن وُوسَّانْ، ذِي كُوڒْ أَسّْ \add زَّايْسنْ\add*، \add أَمْ\add* إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي. أَذْ إِتّْوَاسّوْجذْ سنّجْ إِ \add ؤُسوْجذْ ن\add* ثْغَارْصْثْ ن وشْمَاضْ ن ڒبْذَا أَكْ-ذ ثوْهِيبْثْ نّسْ ن ؤُسيّبْ.  
\v 25 ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ ثڭّمْ إِجّْ ن ؤُمُونِي إِقدّْسنْ. وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ڒْخذْمثْ إِ إِتّْخصَّانْ أَذْ ثتّْوَاڭّْ.“   
\b  
\m  
\s1 إِمزْوُورَا ن ڒْغِيدْجثْ  
\m
\v 26 ”ذڭْ وَاسّْ ن ثْمنْزُوثْ \add ن صَّابثْ\add* ذِي ڒْعِيذْ ن سِّيمَانَاثْ، خْمِي د غَا ثْقدّْممْ إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ن جْذِيذْ غَارْ سِيذِي، أَذْ ثڭّمْ إِجّْ ن ؤُمُونِي إِقدّْسنْ. وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ إِ إِتّْخصَّانْ أَذْ ثتّْوَاڭّْ.  
\v 27 أَذْ ثْقدّْممْ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ أَمْ يِيشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي: ثْنَاينْ ن إِفُونَاسنْ إِمژْيَاننْ إِ يِيجّْ ن إِشَارِّي ذ سبْعَا ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ  
\v 28 أَكْ-ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ن وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ: ثْڒَاثَا ن ثعْشُورِينْ \add ن يِيجّْ ن إِفَا\add* إِ يِيجّْ ن ؤُفُونَاسْ أَمژْيَانْ ذ ثْنَاينْ ن ثعْشُورِينْ \add ن يِيجّْ ن إِفَا\add* إِ يِيجّْ ن إِشَارِّي  
\v 29 ؤُڒَا ذ إِشْثْ ن ثعْشَارْثْ \add ن يِيجّْ ن إِفَا\add* إِ كُوڒْ إِزْمَارْ، \add ؤُشَا أَمُّو\add* إِ \add مَارَّا\add* سبْعَا ن إِزْمَارنْ \add نِّي\add*.  
\v 30 \add سْوجْذمْ عَاوذْ\add* إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ أَمْ ثْغَارْصْثْ ن دّنْبْ مَاحنْذْ أَذْ إِتّْوَاڭّْ وصْڒَاحْ إِ كنِّيوْ.  
\v 31 أَذْ ثنْ ثسّْوجْذمْ سنّجْ إِ \add ؤُسوْجذْ ن\add* ثْغَارْصْثْ ن وشْمَاضْ ن ڒبْذَا ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add*. أَذْ إِڒِينْ شْنَانْ قَاعْ إِ كنِّيوْ أَكْ-ذ ثوْهِيبِينْ نْسنْ ن ؤُسيّبْ.“   
\b  
\b  
\m  
\c 29
\s1 ثَاغَارْصْثْ ن وَاسّْ ؤُمزْوَارُو ن ؤُيُورْ وِيسّْ سبْعَا  
\m
\v 1 ”ذڭْ ؤُيُورْ وِيسّْ سبْعَا، ذڭْ \add وَاسّْ\add* أَمزْوَارُو ن ؤُيُورْ، أَذْ ثڭّمْ إِجّْ ن ؤُمُونِي إِقدّْسنْ. وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ إِ إِتّْخصَّانْ أَذْ ثتّْوَاڭّْ. أَذْ أَومْ يِيڒِي ذ إِجّْ ن وَاسّْ ن ؤُسُوضِي س وسْرُودّحْ \add ذڭْ ؤُيِيشّْ ن إِشَارِّي\add*. \x ◘ \xo 29:‏1 \xt لَاوِي 23‏:‏24\x*  
\v 2 أَذْ ثسّْوجْذمْ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ أَمْ يِيشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي: إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن إِشْثْ ن ثْفُونَاسْثْ - ذ يِيجّْ ن إِشَارِّي ذ سبْعَا ن إِزْمَارنْ إِشْنَانْ قَاعْ ن إِجّْ ن ؤُسڭّْوَاسْ  
\v 3 أَكْ-ذ ثوْهِيبْثْ نْسنْ \add ن ڒْغِيدْجثْ\add* زڭْ وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ: ثْڒَاثَا ن ثعْشُورِينْ \add ن يِيجّْ ن إِفَا\add* إِ ؤُفُونَاسْ أَمژْيَانْ ذ ثْنَاينْ ن ثعْشُورِينْ \add ن يِيجّْ ن إِفَا\add* إِ إِشَارِّي  
\v 4 أَكْ-ذ إِشْثْ ن ثعْشَارْثْ \add ن يِيجّْ ن إِفَا\add* إِ كُوڒْ إِزْمَارْ، \add ؤُشَا أَمُّو\add* إِ سبْعَا ن إِزْمَارنْ \add مَارَّا\add*.  
\v 5 \add سْوجْذمْ عَاوذْ\add* إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ أَمْ ثْغَارْصْثْ ن دّنْبْ مَاحنْذْ أَذْ إِتّْوَاڭّْ وصْڒَاحْ إِ كنِّيوْ.  
\v 6 سنّجْ إِ \add ؤُسوْجذْ ن\add* ثْغَارْصْثْ ن وشْمَاضْ أَكْ-ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ \add سنّجْ إِ ؤُسوْجذْ ن\add* ثْغَارْصْثْ ن وشْمَاضْ ن ڒبْذَا أَكْ-ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نْسنْ ن ؤُسيّبْ، عْلَاحْسَابْ لْفَارِيضَا نْسنْثْ، أَمْ يِيشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ، إِشْثْ ن ثْغَارْصْثْ ن ثْمسِّي إِ سِيذِي.   
\b  
\m  
\s1 ثِيغَارْصَا ذڭْ وَاسّْ ن وصْڒَاحْ  
\m
\v 7 ذڭْ \add وَاسّْ\add* وِيسّْعشْرَا أَذْ ثڭّمْ إِجّْ ن ؤُمُونِي إِقدّْسنْ ؤُشَا أَذْ ثسّْوَاضْعمْ إِخفْ نْومْ. وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ إِ إِتّْخصَّانْ أَذْ ثتّْوَاڭّْ. \x ◘ \xo 29:‏7 \xt لَاوِي 16‏:‏29، 31؛ 23‏:‏27\x*  
\v 8 أَذْ ثْقدّْممْ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ أَمْ يِيشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي: إِجّْ ن ؤُفُونَاسْ أَمژْيَانْ ذ يِيجّْ ن إِشَارِّي ذ سبْعَا ن إِزْمَارنْ إِشْنَانْ قَاعْ ن إِجّْ ن ؤُسڭّْوَاسْ. إِتّْخصَّا أَذْ أَومْ إِڒِينْ شْنَانْ \add أَطَّاسْ\add*. \x ◘ \xo 29:‏8 \xt ڒخْڒ. 28‏:‏19\x*  
\v 9 \add عَاوذْ\add* ثَاوْهِيبْثْ نْسنْ \add ن ڒْغِيدْجثْ\add* ن وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ: ثْڒَاثَا ن ثعْشُورِينْ \add ن يِيجّْ ن إِفَا\add* إِ يِيجّْ ن ؤُفُونَاسْ أَمژْيَانْ، ثْنَاينْ ن ثعْشُورِينْ \add ن يِيجّْ ن إِفَا\add* إِ يِيجّْ ن إِشَارِّي  
\v 10 ؤُ إِشْثْ ن ثعْشَارْثْ \add ن يِيجّْ ن إِفَا\add* إِ كُوڒْ إِزْمَارْ، \add ؤُشَا أَمُّو\add* إِ سبْعَا ن إِزْمَارنْ \add مَارَّا\add*.  
\v 11 \add سْوجْذمْ عَاوذْ\add* إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ أَمْ ثْغَارْصْثْ ن دّنْبْ، سنّجْ إِ \add ؤُسوْجذْ ن\add* ثْغَارْصْثْ ن دّنْبْ إِ زِي ثتّْوَاڭّْ وصْڒَاحْ ؤُشَا ؤُڒَا ذ ثَاغَارْصْثْ ن وشْمَاضْ ن ڒبْذَا أَكْ-ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نْسنْ ن ؤُسيّبْ.   
\b  
\m  
\s1 ثِيغَارْصَا ن ڒْعِيذْ ن إِعُوشُّوثنْ  
\m
\v 12 ذڭْ وَاسّْ وِيسّْ خمّسْطَاشْ ن ؤُيُورْ وِيسّْ سبْعَا أَذْ ثڭّمْ إِجّْ ن ؤُمُونِي إِقدّْسنْ. وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ إِ إِتّْخصَّانْ أَذْ ثتّْوَاڭّْ. سبْعَا ن وُوسَّانْ أَذْ ثْعيّْذمْ ڒْعِيذْ إِ سِيذِي.  
\v 13 أَذْ ثْقدّْممْ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ \add أَمْ\add* ثوْهِيبْثْ ن ثْمسِّي، \add أَمْ\add* إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي: ثْڒطَّاشْ ن إِفُونَاسنْ - إِمژْيَاننْ ن إِشْثْ ن ثْفُونَاسْثْ - ثْنَاينْ ن إِشَارِّييّنْ \add ؤُ\add* أَرْبعْطَاشْ ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ. إِتّْخصَّا أَذْ إِڒِينْ شْنَانْ \add قَاعْ\add*.  
\v 14 \add عَاوذْ\add* ثَاوْهِيبْثْ نْسنْ \add ن ڒْغِيدْجثْ\add* ن وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ: ثْڒَاثَا ن ثعْشُورِينْ \add ن يِيجّْ ن إِفَا\add* إِ يِيجّْ ن ؤُفُونَاسْ أَمژْيَانْ، إِ \add مَارَّا\add* ثْڒطَّاشْ ن إِفُونَاسنْ إِمژْيَاننْ، ؤُ ثْنَاينْ ن ثعْشُورِينْ \add ن يِيجّْ ن إِفَا\add* إِ يِيجّْ ن ؤُشَارِّي، إِ ثْنَاينْ ن إِشَارِّييّنْ \add نِّي\add*  
\v 15 ؤُڒَا ذ إِشْثْ ن ثعْشَارْثْ \add ن يِيجّْ ن إِفَا\add* إِ كُوڒْ إِزْمَارْ، \add ؤُشَا أَمُّو\add* إِ \add مَارَّا\add* أَرْبعْطَاشْ ن إِزْمَارنْ \add نِّي\add*.  
\v 16 \add سْوجْذمْ عَاوذْ\add* إِجّْ ن إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ أَمْ ثْغَارْصْثْ ن دّنْبْ، سنّجْ إِ \add ؤُسوْجذْ ن\add* ثْغَارْصْثْ ن وشْمَاضْ ن ڒبْذَا \add أَكْ-ذ\add* ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبْثْ نّسْ ن ؤُسيّبْ.   
\m
\v 17 ذڭْ وَاسّْ وِيسّْ ثْنَاينْ: ثنْعَاشْ ن إِفُونَاسنْ إِمژْيَاننْ ذ ثْنَاينْ ن إِشَارِّييّنْ ذ أَرْبعْطَاشْ ن إِزْمَارنْ إِشْنَانْ ن إِجّْ ن ؤُسڭّْوَاسْ،  
\v 18 أَكْ-ذ ثوْهِيبْثْ نْسنْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نْسنْ ن ؤُسيّبْ إِ إِفُونَاسنْ إِمژْيَاننْ، إِ إِشَارِّييّنْ ؤُ إِ إِزْمَارنْ، عْلَاحْسَابْ ڒْقدّْ نْسنْ، عْلَاحْسَابْ لْفَارِيضَا.  
\v 19 \add سْوجْذمْ عَاوذْ\add* إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ أَمْ ثْغَارْصْثْ ن دّنْبْ، سنّجْ إِ \add ؤُسوْجذْ ن\add* ثْغَارْصْثْ ن وشْمَاضْ ن ڒبْذَا أَكْ-ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نْسنْ ن ؤُسيّبْ.   
\m
\v 20 ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا: حِيطَاشْ ن إِفُونَاسنْ إِمژْيَاننْ ذ ثْنَاينْ ن إِشَارِّييّنْ ذ أَرْبعْطَاشْ ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ، إِشَانْ \add قَاعْ\add*،  
\v 21 أَكْ-ذ ثوْهِيبْثْ نْسنْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نْسنْ ن ؤُسيّبْ إِ إِفُونَاسنْ إِمژْيَاننْ، إِ إِشَارِّييّنْ ؤُ إِ إِزْمَارنْ، عْلَاحْسَابْ ڒْقدّْ نْسنْ، عْلَاحْسَابْ لْفَارِيضَا.  
\v 22 \add سْوجْذمْ عَاوذْ\add* إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ أَمْ ثْغَارْصْثْ ن دّنْبْ، سنّجْ إِ \add ؤُسوْجذْ ن\add* ثْغَارْصْثْ ن وشْمَاضْ ن ڒبْذَا أَكْ-ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبْثْ نّسْ ن ؤُسيّبْ.   
\m
\v 23 ذڭْ وَاسّْ وِيسّْ أَربْعَا:عشْرَا ن إِفُونَاسنْ إِمژْيَاننْ ذ ثْنَاينْ ن إِشَارِّييّنْ ذ أَرْبعْطَاشْ ن إِزْمَارنْ إِشْنَانْ ن إِجّْ ن ؤُسڭّْوَاسْ،  
\v 24 أَكْ-ذ ثوْهِيبْثْ نْسنْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نْسنْ ن ؤُسيّبْ إِ إِفُونَاسنْ إِمژْيَاننْ، إِ إِشَارِّييّنْ ؤُ إِ إِزْمَارنْ، عْلَاحْسَابْ ڒْقدّْ نْسنْ، عْلَاحْسَابْ لْفَارِيضَا.  
\v 25 \add سْوجْذمْ عَاوذْ\add* إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ أَمْ ثْغَارْصْثْ ن دّنْبْ، سنّجْ إِ \add ؤُسوْجذْ ن\add* ثْغَارْصْثْ ن وشْمَاضْ ن ڒبْذَا أَكْ-ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبْثْ نّسْ ن ؤُسيّبْ.   
\m
\v 26 ذڭْ وَاسّْ وِيسّْ خمْسَا: ثسْعَا ن إِفُونَاسنْ إِمژْيَاننْ ذ ثْنَاينْ ن إِشَارِّييّنْ ذ أَرْبعْطَاشْ ن إِزْمَارنْ إِشْنَانْ ن إِجّْ ن ؤُسڭّْوَاسْ،  
\v 27 أَكْ-ذ ثوْهِيبْثْ نْسنْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نْسنْ ن ؤُسيّبْ إِ إِفُونَاسنْ إِمژْيَاننْ، إِ إِشَارِّييّنْ ؤُ إِ إِزْمَارنْ، عْلَاحْسَابْ ڒْقدّْ نْسنْ، عْلَاحْسَابْ لْفَارِيضَا.  
\v 28 \add سْوجْذمْ عَاوذْ\add* إِجّْ ن ؤُمْيَانْ \add زڭْ إِغَايْضنْ\add* أَمْ ثْغَارْصْثْ ن دّنْبْ، سنّجْ إِ \add ؤُسوْجذْ ن\add* ثْغَارْصْثْ ن وشْمَاضْ ن ڒبْذَا أَكْ-ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبْثْ نّسْ ن ؤُسيّبْ.   
\m
\v 29 ذڭْ وَاسّْ وِيسّْ ستَّا: ثْمنْيَا ن إِفُونَاسنْ إِمژْيَاننْ ذ ثْنَاينْ ن إِشَارِّييّنْ ذ أَرْبعْطَاشْ ن إِزْمَارنْ إِشْنَانْ ن إِجّْ ن ؤُسڭّْوَاسْ،  
\v 30 أَكْ-ذ ثوْهِيبْثْ نْسنْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نْسنْ ن ؤُسيّبْ إِ إِفُونَاسنْ إِمژْيَاننْ، إِ إِشَارِّييّنْ ؤُ إِ إِزْمَارنْ، عْلَاحْسَابْ ڒْقدّْ نْسنْ، عْلَاحْسَابْ لْفَارِيضَا.  
\v 31 \add سْوجْذمْ عَاوذْ\add* إِجّْ ن ؤُمْيَانْ \add زڭْ إِغَايْضنْ\add* أَمْ ثْغَارْصْثْ ن دّنْبْ، سنّجْ إِ \add ؤُسوْجذْ ن\add* ثْغَارْصْثْ ن وشْمَاضْ ن ڒبْذَا أَكْ-ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نّسْ ن ؤُسيّبْ.   
\m
\v 32 ذڭْ وَاسّْ وِيسّْ سبْعَا: سبْعَا ن إِفُونَاسنْ إِمژْيَاننْ ذ ثْنَاينْ ن إِشَارِّييّنْ ذ أَرْبعْطَاشْ ن إِزْمَارنْ إِشْنَانْ ن إِجّْ ن ؤُسڭّْوَاسْ،  
\v 33 أَكْ-ذ ثوْهِيبْثْ نْسنْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نْسنْ ن ؤُسيّبْ إِ إِفُونَاسنْ إِمژْيَاننْ، إِ إِشَارِّييّنْ ؤُ إِ إِزْمَارنْ، عْلَاحْسَابْ ڒْقدّْ نْسنْ، عْلَاحْسَابْ لْفَارِيضَا.  
\v 34 \add سْوجْذمْ عَاوذْ\add* إِجّْ ن ؤُمْيَانْ \add زڭْ إِغَايْضنْ\add* أَمْ ثْغَارْصْثْ ن دّنْبْ، سنّجْ إِ \add ؤُسوْجذْ ن\add* ثْغَارْصْثْ ن وشْمَاضْ ن ڒبْذَا أَكْ-ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبْثْ نّسْ ن ؤُسيّبْ.   
\m
\v 35 ذڭْ وَاسّْ وِيسّْ ثْمنْيَا أَذْ ثڭّمْ إِجّْ ن ؤُمُونِي إِفَارْزنْ. وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ڒْخذْمثْ إِ إِتّْخصَّانْ أَذْ ثتّْوَاڭّْ. \x ◘ \xo 29:‏35 \xt لَاوِي 23‏:‏36\x*  
\v 36 أَذْ ثْقدّْممْ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ \add أَمْ\add* ثوْهِيبْثْ ن ثْمسِّي، \add أَمْ\add* إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي: إِجّْ ن ؤُفُونَاسْ أَمژْيَانْ ذ يِيجّْ ن إِشَارِّي ذ سبْعَا ن إِزْمَارنْ إِشْنَانْ ن إِجّْ ن ؤُسڭّْوَاسْ  
\v 37 أَكْ-ذ ثوْهِيبْثْ نْسنْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نْسنْ ن ؤُسيّبْ إِ ؤُفُونَاسْ أَمژْيَانْ، إِ إِشَارِّي ؤُ إِ إِزْمَارنْ، عْلَاحْسَابْ ڒْقدّْ نْسنْ، عْلَاحْسَابْ لْفَارِيضَا.  
\v 38 \add سْوجْذمْ عَاوذْ\add* إِجّْ ن ؤُمْيَانْ \add زڭْ إِغَايْضنْ\add* أَمْ ثْغَارْصْثْ ن دّنْبْ، سنّجْ إِ \add ؤُسوْجذْ ن\add* ثْغَارْصْثْ ن وشْمَاضْ ن ڒبْذَا أَكْ-ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبْثْ نّسْ ن ؤُسيّبْ.   
\m
\v 39 أَذْ ثڭّمْ ثِيمسْڒَايِينْ-أَ إِ سِيذِي ذِي ڒعْيُوذَاثْ نْومْ إِتّْوَاڭّنْ سنّجْ إِ ثوْهِيبِينْ ن ڒوْعُوذْ نْومْ ذ ثوْهِيبِينْ نْومْ س ڒْخَاضَارْ إِ إِتّْرَاحنْ أَكْ-ذ ثْغَارْصَا ن وشْمَاضْ نْومْ ذ ثوْهِيبِينْ نْومْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نْومْ ن ؤُسيّبْ ذ ثوْهِيبِينْ نْومْ ن ڒهْنَا.“   
\b  
\b  
\m  
\c 30
\s1 ثِيجُودْجْ  
\m
\v 1 ؤُشَا إِسِّيوڒْ مُوسَا أَكْ-ذ أَيْثْ ن إِسْرَائِيل عْلَاحْسَابْ مَارَّا مِينْ يُومُورْ سِيذِي إِ مُوسَا.  
\v 2 إِسِّيوڒْ مُوسَا أَكْ-ذ إِزدْجِيفنْ ن ثْقبَّاڒْ ن أَيْثْ ن إِسْرَائِيل، إِنَّا: ”أَقَا ذ ثَا مِينْ خفْ يُومُورْ سِيذِي:   
\m
\v 3 ’خْمِي غَا ثَافذْ \bd إِجّْ ن ورْيَازْ\bd* إِوْشَا أَوَاڒْ نِيغْ إِجُّودْجْ إِشْثْ ن ثْجَادْجِيثْ حِيمَا أَذْ إِقّنْ إِخفْ نّسْ س يِيجّْ ن ڒْعَاهْذْ، \add خنِّي\add* وَارْ إِتَّارژِّي أَوَاڒْ نّسْ. إِتّْخصَّا أَسْ أَذْ إِڭّْ عْلَاحْسَابْ مِينْ د-إِفّْغنْ زڭْ ؤُقمُّومْ نّسْ. \x ◘ \xo 30:‏3 \xt أَعَوذ. 23‏:‏20\x*   
\m
\v 4 خْمِي غَا ثَافذْ \bd إِشْثْ ن ثمْغَارْثْ\bd* ثوْشَا أَوَاڒْ نّسْ إِ سِيذِي ؤُشَا أَذْ ثقّنْ إِخفْ نّسْ س يِيجّْ ن ڒْعَاهْذْ ذِي ثمْژِي نّسْ ذِي ثَادَّارْثْ ن بَابَاسْ،  
\v 5 ؤُشَا بَابَاسْ إِسْڒَا إِ وَاوَاڒْ ن لْوَاعْذْ نّسْ ذ ڒْعَاهْذْ نّسْ إِ زِي ثقّنْ إِخفْ نّسْ، ؤُشَا بَابَاسْ إِسْقَارْ زَّاثسْ، \add خنِّي\add* مَارَّا لْوُوعُوذْ نّسْ أَذْ إِڒِينْ صڒْحنْ ذ كُوڒْ أَقَّانْ نّسْ أَذْ يِيڒِي إِصْڒحْ.  
\v 6 \add مَاشَا\add* مَاڒَا بَابَاسْ إِسّْبدّْ إِ-ت \add زِي مَانْ أَيَا\add* ذڭْ وَاسّْ نِّي ذِي إِسْڒَا أَيَا، \add خنِّي\add* ؤُڒَا ذ إِجّْ زِي لْوُوعُوذْ نّسْ ؤُ ؤُڒَا ذ إِجّْ زڭْ وَاقَّانْ نّسْ إِ زِي ثقّنْ إِخفْ نّسْ، وَارْ إِصدْجحْ شَا. سِيذِي أَذْ أَسْ إِغْفَارْ، مِينْزِي بَابَاسْ إِسّْبدّْ إِ-ت \add خْ مَانْ أَيَا\add*.   
\m
\v 7 مَاڒَا ثُوغَا-ت ثمْڒشْ أَكْ-ذ يِيجّْ ن ورْيَازْ ؤُشَا خَاسْ لْوُوعُوذْ نِيغْ نتَّاثْ ثُوغَا ثقّنْ إِخفْ نّسْ س يِيجّْ ن وَاوَاڒْ إِفّغْ-د س ثْشَارْفَايحْ زڭْ إِينْشِيشنْ نّسْ،  
\v 8 ؤُشَا أَرْيَازْ نّسْ إِسْڒَا أَسْ ؤُشَا إِسْقَارْ زَّاثسْ ذڭْ وَاسّْ إِ ذِي إِسْڒَا \add أَيَا\add*، \add خنِّي\add* أَذْ سڒْحنْ لْوُوعُوذْ نّسْ ذ كُوڒْ أَقَّانْ نّسْ أَذْ يِيڒِي إِصْڒحْ.  
\v 9 \add مَاشَا\add* مَاڒَا أَرْيَازْ نّسْ ذڭْ وَاسّْ نِّي ذِي إِسْڒَا \add أَيَا\add*، إِنْهَارْ إِ-ت، \add خنِّي\add* نتَّا إِسّبْضڒْ لْوَاعْذْ نِّي خَاسْ ؤُڒَا ذ أَوَاڒْ س ثْشَارْفَايحْ زڭْ إِينْشِيشنْ نّسْ إِ زِي ثُوغَا ثقّنْ إِخفْ نّسْ ؤُشَا أَربِّي أَذْ أَسْ إِغْفَارْ \add أَيَا\add*.‘ “   
\b  
\m
\v 10 ”\bd خْ لْوَاعْذْ ن ثَاجَّاتْشْ نِيغْ ن ثنِّي إِتّْوَادْجْفنْ\bd*: مَارَّا مِينْ زِي ثُوغَا ثقّنْ إِخفْ نّسْ، أَذْ يِيڒِي إِصدْجحْ.  
\v 11 مَاڒَا ثُوغَا ثوْشَا أَوَاڒْ نِيغْ ثقّنْ إِخفْ نّسْ س إِشْثْ ن ثْجَادْجِيثْ إِ يِيجّْ ن ڒْعَاهْذْ ذِي ثَادَّارْثْ ن ورْيَازْ نّسْ،  
\v 12 ؤُشَا أَرْيَازْ نّسْ إِسْڒَا \add إِ ؤُيَا\add* ؤُشَا إِسْقَارْ زَّاثسْ ؤُشَا وَارْ ت إِسّْبدّْ خْ مَانْ أَيَا، \add خنِّي\add* أَذْ صڒْحنْ مَارَّا لْوُوعُوذْ نّسْ ؤُ كُوڒْ أَقَّانْ نّسْ إِ زِي ثُوغَا ثقّنْ إِخفْ نّسْ أَذْ يِيڒِي إِصْڒحْ.  
\v 13 \add مَاشَا\add* مَاڒَا أَرْيَازْ نّسْ إِسّبْضڒْ أَيَا قَاعْ ذڭْ وَاسّْ إِ ذِي إِسْڒَا، \add خنِّي\add* وَارْ إِتِّيڒِي إِصدْجحْ شَا قَاعْ زِي مِينْ د-إِفّْغنْ زڭْ إِينْشِيشنْ نّسْ ن لْوُوعُوذْ نِيغْ ن وَاقَّانْ. أَرْيَازْ نّسْ إِسّبْضڒْ أَيَا ؤُشَا أَربِّي أَذْ أَسْ إِغْفَارْ.   
\m
\v 14 كُوڒْ لْوَاعْذْ ذ كُوڒْ أَقَّانْ س إِشْثْ ن ثْجَادْجِيثْ إِ ؤُمِي غَا ثسّْوَاضعْ إِخفْ نّسْ، أَرْيَازْ نّسْ إِزمَّارْ أَذْ ث إِسّمْثنْ نِيغْ أَرْيَازْ نّسْ إِزمَّارْ أَذْ ث إِسّبْضڒْ.  
\v 15 مَاڒَا أَرْيَازْ نّسْ إِسْقَارْ قَاعْ زڭْ وَاسّْ خْ وَاسّْ، \add خنِّي\add* إِسّمْثنْ مَارَّا لْوُوعُوذْ نّسْ نِيغْ كُوڒْ أَقَّانْ نّسْ إِ خَاسْ إِدْجَانْ. أَقَا إِسّمْثنْ إِ-ثنْ مِينْزِي إِسْقَارْ زَّاثسْ ذڭْ وَاسّْ إِ ذِي \add ثنْ\add* إِسْڒَا.  
\v 16 مَاڒَا نتَّا، أَوَارْنِي ڒَامِي \add ذ أَسنْ\add* إِسْڒَا، أَذْ ثنْ إِسّبْضڒْ، \add خنِّي\add* أَذْ يَارْبُو نتَّا ڒْمُوعْصِييّثْ ن \add ثمْغَارْثْ\add* نّسْ.“   
\m
\v 17 أَقَا ذ ثِينَا ذ ثِيوصَّا إِ زِي يُومُورْ سِيذِي إِ مُوسَا، \add إِ إِدْجَانْ\add* جَارْ ورْيَازْ ذ ثمْغَارْثْ، جَارْ بَابَاسْ ذ يسِّيسْ، \add ثنِّي إِقِّيمنْ\add* ذِي ثَادَّارْثْ ن بَابَاسْ ذِي ثمْژِي نّسْ.   
\b  
\b  
\m  
\c 31
\s1 ڭَارَّا أَكْ-ذ مِيذْيَانْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”نْثَاقمْ ذِي طّْوعْ ن أَيْثْ ن إِسْرَائِيل خْ إِمِيذْيَانِييّنْ. أَوَارْنِي أَسْ أَذْ ثمَّارْنِيذْ غَارْ ڒْڭنْسْ نّشْ.“ \x ◘ \xo 31:‏2 \xt ڒخْڒ. 25‏:‏17؛ 27‏:‏13 \x*   
\m
\v 3 إِسِّيوڒْ مُوسَا أَكْ-ذ ڒْڭنْسْ، إِنَّا: ”سْوجْذمْ زِي غَارْومْ إِرْيَازنْ إِ ؤُمنْغِي ضِيدّْ إِ مِيذْيَانْ ؤُ نِيثْنِي أَذْ إِڒِينْ ضِيدّْ إِ مِيذْيَانْ مَاحنْذْ أَذْ سِّيوْضنْ نّقْمثْ ن سِيذِي خْ مِيذْيَانْ.  
\v 4 إِتّْخصَّا أَومْ أَذْ ثسّكّمْ أَڒفْ \add ن يرْيَازنْ\add* زِي كُوڒْ ثَاقْبِيتْشْ غَارْ ؤُمنْغِي، \add زِي كُوڒْ إِشْثْ زِي\add* مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل.“  
\v 5 \add أَمُّو\add* إِ تّْوَافَارْزنْ زِي ڒُوڒُوفْ ن إِسْرَائِيل أَڒفْ \add ن يرْيَازنْ\add* زِي كُوڒْ ثَاقْبِيتْشْ، أَقَا أَثنْ \add جْمِيعْ\add* ثنْعَاشْ-ن-ڒُوڒُوفْ \add ن يرَازنْ\add* إِوجْذنْ إِ ؤُمنْغِي.   
\m
\v 6 مُوسَا إِسّكّْ إِ-ثنْ غَارْ ؤُمنْغِي، أَڒفْ \add ن يرْيَازنْ\add* زِي كُوڒْ ثَاقْبِيتْشْ. \add نتَّا إِسّكّْ\add* إِ-ثنْ غَارْ ؤُمنْغِي أَكْ-ذ فِينَاحَاسْ، مِّيسْ ن ؤُكهَّانْ أَلِيعَازَارْ، ؤُ \add نتَّا غَارسْ\add* ڒقْشُوعْ إِقدّْسنْ ذ ڒبْوَاقْ إِ ؤُسُوضِي س وسْرُودّحْ \add إِ ؤُمنْغِي\add* ذڭْ ؤُفُوسْ نّسْ  
\v 7 ؤُشَا مّنْغنْ ضِيدّْ إِ إِمِيذْيَانِييّنْ، أَمْ مَامّشْ \add ث\add* يُومُورْ سِيذِي إِ مُوسَا ؤُشَا نْغِينْ مَارَّا مِينْ إِدْجَانْ ذ أَوْثمْ.  
\v 8 سنّجْ إِ يِينِّي \add زَّايْسنْ\add* إِتّْوَاسّْنُوقّْبنْ، نْغِينْ عَاوذْ إِجدْجِيذنْ ن مِيذْيَانْ: إِوِي، رَاقِيمْ، صُورْ، حُورْ ذ رَابَاعْ، خمْسَا ن إِجدْجِيذنْ ن مِيذْيَانْ، \add ؤُڒَا\add* بَالْعَامْ، مِّيسْ ن بَاعُورْ، نْغِينْ ث س سِّيفْ. \x ◘ \xo 31:‏8 \xt ياش. 13‏:‏21، 22\x*   
\m
\v 9 أَيْثْ ن إِسْرَائِيل حبّْسنْ ثِيمْغَارِينْ ن مِيذْيَانْ ذ ثَارْوَا نْسنْ، ؤُ كشّْضنْ ڒبْهَايمْ نْسنْ ذ ثْحِيمْرِيوِينْ نْسنْ ذ مَارَّا مِينْ غَارْسنْ.  
\v 10 سّْشمْضنْ س ثْمسِّي مَارَّا ثِيندَّامْ نْسنْ مَانِي ثُوغَا زدّْغنْ ذ مَارَّا لْقلْعَاثْ نْسنْ.  
\v 11 كْسِينْ مَارَّا مِينْ كشّْضنْ، مَارَّا ثَاكشَّاضْثْ ن إِوْذَانْ ذ ڒبْهَايمْ \x ◘ \xo 31:‏11 \xt أَعَوذ. 20‏:‏14\x*  
\v 12 ؤُشَا إِوْينْ-د إِمحْبَاسْ ذ مَارَّا ثَاكشَّاضْثْ غَارْ مُوسَا ؤُ غَارْ ؤُكهَّانْ أَلِيعَازَارْ ؤُ غَارْ ثْمسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل، ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ، ذِي ڒوْضَاثْ ن مُوآبَ، غَارْ لْ-ؤُرْذُونْ، \add أَرنْذَاذْ ن\add* أَرِيحَا.  
\v 13 ؤُشَا إِفّغْ-د مُوسَا أَكْ-ذ ؤُكهَّانْ أَلِيعَازَارْ ذ مَارَّا ڒْحُوكَّامْ ن ثْمسْمُونْثْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ مَاحنْذْ أَذْ ثنْ مّْسَاڭَارنْ.   
\m
\v 14 إِفُّوڭمْ مُوسَا أَطَّاسْ خْ إِمْڭوَّاذنْ ن ڒْعسْكَارْ، خْ إِمقّْرَاننْ خْ وَاڒفْ ؤُ خْ إِمقّْرَاننْ خْ مْيَا، إِنِّي د-إِعقْبنْ زڭْ ؤُمنْغِي.  
\v 15 إِنَّا أَسنْ مُوسَا: ”مَا ثجِّيمْ مَارَّا مِينْ إِدْجَانْ ذ ثَاوْثنْثْ إِدَّارْ؟  
\v 16 خْزَارْ، س وسْشَانْ ن بَالْعَامْ، \add ثِيمْغَارِينْ-أَ\add* ثُوغَا أَثنْثْ ذ ڒسْبَابْ أَقَا أَيْثْ ن إِسْرَائِيل غْذَارنْ سِيذِي ذِي ثْمسْڒَاشْثْ ن فَاغُورْ ؤُشَا ثوْضَا-د جّْرِيحشْثْ خْ ثْمسْمُونْثْ ن سِيذِي. \x ◘ \xo 31:‏16 \xt ڒخْڒ. 25‏:‏1، 2، 18؛ 2 بُط. 2‏:‏15؛ أَسَا. 2‏:‏14 \x*  
\v 17 ڒخُّو \add خنِّي\add*، نْغمْ مَارَّا إِوثْمَانْ نِّي جَارْ إِحنْجِيرنْ إِمژْيَاننْ ؤُشَا نْغمْ مَارَّا ثَامْغَارْثْ نِّي إِمُوننْ أَكْ-ذ إِجّْ ن ورْيَازْ أَمْ ثطّصْ نتَّاثْ أَكْ-ذ إِجّْ ن ورْيَازْ. \x ◘ \xo 31:‏17 \xt ڒقض. 21‏:‏11\x*  
\v 18 مَاشَا مَارَّا ثِيحنْجِيرِينْ جَارْ ثمْغَارِينْ نِّي وَارْ إِمُوننْ أَكْ-ذ إِجّْ ن ورْيَازْ أَمْ \add أَكِيذسْ\add* طّْصنْثْ، جّمْ ثنْثْ إِ يِيخفْ نْومْ أَذْ دَّارنْثْ.   
\m
\v 19 إِتّْخصَّا أَومْ أَذْ ثوْثمْ إِقِيضَانْ نْومْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ ڒْمِيجَاڒْ ن سبْعَا ن وُوسَّانْ. كُوڒْ إِجّنْ، ونِّي إِنْغِينْ إِجّْ ن ڒعْمَارْ \add ن بْنَاذمْ\add*، ؤُ كُوڒْ إِجّنْ، ونِّي إِحَاذَانْ إِجّنْ إِ إِتّْوَاسّْنُوقّْبنْ، أَذْ يجّْ أَذْ كّْسنْ دّنْبْ خْ يِيخفْ نّسْ ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا ؤُ ذڭْ وَاسّْ وِيسْ سبْعَا، \add أَمُّو\add* إِ غَا ثڭّمْ كنِّيوْ ؤُڒَا ذ إِمحْبَاسْ نْومْ.   
\m
\v 20 إِتّْخصَّا أَذْ ثكّْسمْ دّنْبْ عَاوذْ خْ مَارَّا أَرُّوضْ ذ مَارَّا ڒقْشُوعْ ن إِڒْمَاونْ ذ مَارَّا مِينْ إِتّْوَاڭّنْ س ثْهِيضُورْثْ ن إِغَايْضْ ذ مَارَّا ڒقْشُوعْ ن ؤُكشُّوضْ.“   
\m
\v 21 أَلِيعَازَارْ، أَكهَّانْ، إِنَّا إِ إِعسْكَارِييّنْ نِّي د-إِفّْغنْ غَارْ ؤُمنْغِي: ”ثَا ذ ثَاوْصيّثْ زِي شَّارِيعَا نِّي يُومُورْ سِيذِي إِ مُوسَا:  
\v 22 مْغِيرْ ؤُرغْ ذ نُّوقَارْثْ ذ نّْحَاسْ ذ ؤُزَّاڒْ ذ إِسْثَانْيُو ذ ڒخْفِيفْ،  
\v 23 مَارَّا مِينْ إِزمَّارنْ إِ ثْمسِّي، خْ ثْمسِّي أَذْ ث ثسّكّمْ، \add خنِّي\add* أَذْ يِيڒِي إِزْذِيڭْ، \add مَاشَا\add* إِتّْخصَّا أَذْ زَّايسْ ثكّْسمْ دّنْبْ س وَامَانْ ن وعْزَاڒْ. مَارَّا مِينْ وَارْ إِزمَّارنْ إِ ثْمسِّي، أَذْ ث ثسّكّمْ خْ وَامَانْ. \x ◘ \xo 31:‏23 \xt ڒخْڒ. 19‏:‏9\x*  
\v 24 ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ ثْصبّْنمْ أَرُّوضْ نْومْ، \add خنِّي\add* أَذْ ثِيڒِيمْ ذ إِمزْذَاڭنْ. أَوَارْنِي ؤُيَا ثْزمَّارمْ أَذْ ثَاذْفمْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ.“   
\b  
\m
\v 25 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 26 ”طّفْ ڒعْبَارْ ن ثْكشَّاضْثْ ن إِوْذَانْ ذ ڒبْهَايمْ نِّي ثتّْوَاحبّسْ، شكْ \add جْمِيعْ\add* أَكْ-ذ ؤُكهَّانْ أَلِيعَازَارْ ؤُ أَكْ-ذ إِزدْجِيفنْ ن \add ثُوذْرِينْ ن\add* إِبَابَاثنْ ن ثْمسْمُونْثْ.  
\v 27 بْضَا ثَاكشَّاضْثْ خْ ثْنَاينْ جَارْ إِنِّي إِشَارْشنْ ذڭْ ؤُمنْغِي ذ يِينِّي إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ \add زڭْ إِشْثْ ن جِّيهثْ\add* ذ مَارَّا ثَامسْمُونْثْ \add زِي جِّيهثْ نّغْنِيثْ\add*. \x ◘ \xo 31:‏27 \xt 1 صم. 30‏:‏24\x*  
\v 28 سْڭعّْذثْ إِشْثْ ن صّذْقثْ إِ سِيذِي زڭْ إِعسْكَارِييّنْ نِّي د-إِفّْغنْ غَارْ ؤُمنْغِي أَكْ-ذ ڒْعسْكَارْ: إِجّْ ن ڒعْمَارْ زِي خمْسَا مْيَا ن إِوْذَانْ ؤُشَا \add أَمنِّي\add* زڭْ إِفُونَاسنْ ذ ثْفُونَاسِينْ ؤُ زڭْ إِغْيَاڒْ ؤُ زڭْ وُودْجِي.  
\v 29 زڭْ وزْينْ نْسنْ ن \add ثْكشَّاضْثْ\add* أَذْ ثكْسِيذْ \add صّذْقثْ-أَ\add* ؤُشَا أَذْ ت ثوْشذْ إِ ؤُكهَّانْ أَلِيعَازَارْ \add أَمْ\add* إِشْثْ ن ثوْهِيبْثْ ن ؤُسْڭعّذْ إِ سِيذِي.  
\v 30 زڭْ وزْينْ \add ن ثْكشَّاضْثْ\add* ن أَيْثْ ن إِسْرَائِيل أَذْ ثكْسِيذْ إِجّْ زِي كُوڒْ خمْسِينْ: زڭْ إِوْذَانْ، زڭْ إِفُونَاسنْ ذ ثْفُونَاسِينْ، زڭْ إِغْيَاڒْ ؤُ زڭْ وُودْجِي، \add وَاهْ،\add* زِي مَارَّا ڒبْهَايمْ. أَذْ ثوْشذْ أَيَا إِ إِلَاوِييّنْ نِّي إِطّْفنْ أَشْبَارْ خْ ثْزذِّيغْثْ ن سِيذِي.“ \f ◼ \fr 31:‏30 \ft \+bd ’إِفُونَاسنْ ذ ثْفُونَاسِينْ‘\+bd* - س ثْعِيبْرَانِيثْ أَقَا ذِينْ إِجّْ ن وَاوَاڒْ وَاهَا، وَارْ إِدْجِي ثْنَاينْ.\f*   
\m
\v 31 ؤُشَا إِڭَّا مُوسَا ذ ؤُكهَّانْ أَلِيعَازَارْ أَمْ مَامّشْ \add ث\add* يُومُورْ سِيذِي إِ مُوسَا.  
\v 32 \add أَوَارْنِي أَسْ\add* ثُوغَا ڒكْسِيبثْ نِّي إِقِّيمنْ ن ثْكشَّاضْثْ نِّي إِكشّضْ ڒْڭنْسْ ن ڒْعسْكَارْ ستَّا-مْيَا ؤُ-خمْسَا ؤُ-سبْعِينْ-أَڒفْ ن وُودْجِي. \f ◼ \fr 31:‏32 \ft \+bd ’إِعسْكَارِييّنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒْڭنْسْ ن ڒْعسْكَارْ‘.\f*  
\v 33 ثْنَاينْ ؤُ-سبْعِينْ-أَڒفْ ن إِفُونَاسنْ ذ ثْفُونَاسِينْ،  
\v 34 وَاحِيثْ ؤُ-ستِّينْ-أَڒفْ ن إِغْيَاڒْ  
\v 35 ؤُشَا \add زِي جِّيهثْ ن\add* ڒعْمَارْ ن بْنَاذمْ، زِي ثمْغَارِينْ نِّي وَارْ إِطِّيصنْ ذِي قَامَا أَكْ-ذ إِجّْ ن ورْيَازْ، أَقَا أَثنْثْ مَارَّا ثْنَاينْ ؤُ-ثْڒَاثِينْ-أَڒفْ.   
\m
\v 36 إِجّْ ن وزْينْ، \bd ثَاسْغَارْثْ ن يِينِّي د-إِفّْغنْ أَكْ-ذ ڒْعسْكَارْ\bd*، أَقَا-ث ذِي ثڒْثْ-مْيَا ؤُ-سبْعَا ؤُ-ثْڒَاثِينْ-أَڒفْ ن وُودْجِي.  
\v 37 صّذْقثْ إِ سِيذِي ن وُودْجِي \add ثُوغَا-ت ذِي\add* ستَّا-مْيَا ؤُ-خمْسَا ؤُ-سبْعِينْ.  
\v 38 ؤُشَا \add ثُوغَا ذِينْ\add* ستَّا ؤُ-ثْڒَاثِينْ-أَڒفْ ن إِفُونَاسنْ ذ ثْفُونَاسِينْ ؤُشَا صّذْقثْ \add زَّايْسنْ\add* إِ سِيذِي \add ثُوغَا-ت\add* ذِي ثْنَاينْ ؤُ-سبْعِينْ.  
\v 39 ؤُشَا \add ثُوغَا ذِينْ\add* ثْڒَاثِينْ-أَڒفْ ؤُ-خمْسَا-مْيَا ن إِغْيَاڒْ ؤُشَا صّذْقنْ زَّايْسنْ إِ سِيذِي، وَاحِيثْ ؤُ-ستِّينْ.  
\v 40 ؤُشَا \add زِي جِّيهثْ ن\add* ڒعْمُورْ ن بْنَاذمْ \add ثُوغَا ذِينْ\add* سطَّاشْ-أَڒفْ \add ن ثمْغَارِينْ\add* ؤُ أَصدّقْ زَّايْسنْثْ إِ سِيذِي أَقَا ثْنَاينْ ؤُ-ثْڒَاثِينْ \add ن ثمْغَارِينْ\add*.   
\m
\v 41 إِوْشَا مُوسَا صّذْقثْ، ثنِّي ذ ثَاوْهِيبْثْ ن ؤُسْڭعّذْ إِ سِيذِي، إِ ؤُكهَّانْ أَلِيعَازَارْ، أَمْ مَامّشْ \add ث\add* يُومُورْ سِيذِي إِ مُوسَا. \x ◘ \xo 31:‏41 \xt ڒخْڒ. 18‏:‏8، 19\x*   
\b  
\m
\v 42 زڭْ وزْينْ \add نّغْنِي\add* إِ أَيْثْ ن إِسْرَائِيل، ونِّي إِفَارْزْ مُوسَا \add ذِي طّْوعْ نْسنْ\add* زڭْ يرْيَازنْ نِّي ثُوغَا إِمّنْغنْ،  
\v 43 \bd - أَزْينْ \+bdit نِّي ن ثسْغَارْثْ\+bdit* إِ ثْمسْمُونْثْ\bd* ثُوغَا-ث ذِي ثڒْثْ-مْيَا ؤُ-سبْعَا ؤُ-ثْڒَاثِينْ-أَڒفْ ؤُ-خمْسَا مْيَا ن وُودْجِي،  
\v 44 ستَّا ؤُ-ثْڒَاثِينْ-أَڒفْ ن إِفُونَاسنْ ذ ثْفُونَاسِينْ،  
\v 45 ثْڒَاثِينْ-أَڒفْ ؤُ-خمْسَا-مْيَا ن يغْيَاڒْ  
\v 46 ؤُشَا سطَّاشْ-أَڒفْ ن ڒعْمُورْ ن إِوْذَانْ -  
\v 47 زڭْ وزْينْ نِّي إِ أَيْثْ ن إِسْرَائِيل إِكْسِي مُوسَا إِجّْ زِي كُوڒْ خمْسِينْ، \add أَمُّو\add* زڭْ إِوْذَانْ \add أَمْ\add* زِي ڒبْهَايمْ، ؤُشَا إِوْشَا أَيَا إِ إِلَاوِييّنْ، إِنِّي إِطّْفنْ أَشْبَارْ خْ ثْزذِّيغْثْ ن سِيذِي، أَمْ مَامّشْ \add ث\add* يُومُورْ سِيذِي إِ مُوسَا.   
\b  
\m
\v 48 \add خنِّي\add* ؤُسِينْ-د إِكُومَانْذَارنْ خْ ڒُوڒُوفْ ن ڒْعسْكَارْ، إِمقّْرَاننْ خْ وَاڒفْ ذ إِمقّْرَاننْ خْ مْيَا، غَارْ مُوسَا،  
\v 49 نَّانْ إِ مُوسَا: ”إِمْسخَّارنْ نّشْ أَقَا حسْبنْ مَارَّا إِعسْكَارِييّنْ نِّي سَاذُو ؤُفُوسْ نّغْ ؤُ وَارْ ذ أَنغْ إِرُوحْ ؤُڒَا ذ \add إِجّْ ن\add* ورْيَازْ.  
\v 50 س ؤُيَا نِيوِي ثَاوْهِيبْثْ ن سِيذِي، كُوڒْ  إِجّْ مِينْ يُوفَا: إِشْثْ ن ڒْقشْعثْ ن وُورغْ، إِشْثْ ن ثْخڒْخَاڒْثْ، إِشْثْ ن ثْمقْيَاسْثْ، إِشْثْ ن ثْخَاثنْثْ \add ن ؤُشمِّيعْ\add*، إِشْثْ ن ثخْرَازْثْ نِيغْ إِشْثْ ن ثْسدّشْثْ س وذْمَامْ ن وُورغْ، حِيمَا أَذْ زَّايْسنْثْ إِتّْوَاڭّْ وصْڒَاحْ خْ ڒعْمُورْ نّغْ زَّاثْ إِ وُوذمْ ن سِيذِي.“  
\v 51 مُوسَا ذ ؤُكهَّانْ أَلِيعَازَارْ كْسِينْ زَّايْسنْ ؤُرغْ نْسنْ، مَارَّا ڒقْشُوعْ إِ ڭِّينْ \add س لْفنّْ\add*.  
\v 52 مَارَّا ؤُرغْ ن ثوْهِيبْثْ نِّي سّْڭعّْذنْ إِ سِيذِي زڭْ إِمقّْرَاننْ خْ وَاڒفْ ؤُ زڭْ إِمقّْرَاننْ خْ مْيَا ثُوغَا ذِي سطَّاشْ-أَڒفْ ؤُ-سبْعَا-مْيَا ؤُ-خمْسِينْ شِيقْلُو.  
\v 53 إِعسْكَارِييّنْ أَقَا كشّْضنْ كُوڒْ إِجّْ إِ يِيخفْ نّسْ \add مِينْ خْسنْ\add*. \x ◘ \xo 31:‏53 \xt أَعَوذ. 20‏:‏14\x*  
\v 54 مُوسَا ذ ؤُكهَّانْ أَلِيعَازَارْ طّْفنْ ؤُرغْ \add نِّي\add* ن إِمقّْرَاننْ خْ وَاڒفْ ؤُ خْ مْيَا ؤُشَا إِوْينْ ث غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، أَمْ يِيشْثْ ن ڒِيذَارثْ إِ أَيْثْ ن إِسْرَائِيل زَّاثْ إِ وُوذنْ ن سِيذِي.   
\b  
\b  
\m  
\c 32
\s1 ثُوثْرَا ن ثقْبِيتْشْ ن رُوبِينْ ذ ثقْبِيتْشْ ن جَاذْ  
\m
\v 1 أَيْثْ ن رُوبِينْ غَارْسنْ أَطَّاسْ ن ڒبْهَايمْ ؤُ أَيْثْ ن جَاذْ غَارْسنْ أَطَّاسْ س وَاطَّاسْ \add ن ڒبْهَايمْ\add* ؤُشَا نِيثْنِي ژْرِينْ ثَامُّورْثْ ن يَاعْزِيرْ ذ ثمُّورْثْ ن جِيلْعَاذْ، ؤُشَا خْزَارْ، جِّيهثْ \add نِّي\add* \add ثشْنَا\add* إِ ڒبْهَايمْ.  
\v 2 ؤُسِينْ-د أَيْثْ ن جَاذْ ؤُ أَيْثْ ن رُوبِينْ، سِّيوْڒنْ أَكْ-ذ مُوسَا ذ ؤُكهَّانْ أَلِيعَازَارْ ؤُ أَكْ-ذ ڒْحُوكَّامْ ن ثْمسْمُونْثْ، نَّانْ:  
\v 3 ”عَاطَارُوثْ، ذِيبُونْ، يَاعْزِيرْ، نِيمْرَا، حَاشْبُونْ، أَلِيعَالَا، شَابَامْ، نابُو ذ بَاعُونْ،  
\v 4 ثَامُّورْثْ نِّي خْ إِغْڒبْ سِيذِي زَّاثْ إِ وُوذمْ ن ثْمسْمُونْثْ ن إِسْرَائِيل، أَقَا-ت ذ إِشْثْ ن ثمُّورْثْ \add ثشْنَا\add* إِ ڒبْهَايمْ ؤُ \add نشِّينْ\add*، إِمْسخَّارنْ نّشْ غَارْسنْ ڒبْهَايمْ.“  
\v 5 نَّانْ: ”مَاڒَا نُوفَا أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، مَا زعْمَا أَذْ ثمّوْشْ ثمُّورْثْ-أَ ذ أَڭْڒَا إِ إِمْسخَّارنْ نّشْ ؤُ وَارْ ذ أَنغْ تّجِّي أَذْ نژْوَا لْ-ؤُرْذُونْ.“   
\m
\v 6 يَارَّا-د مُوسَا خْ أَيْثْ ن جَاذْ ؤُ خْ أَيْثْ ن رُوبِينْ: ”مَاڒَا أَيْثْمَاثْومْ أَذْ د-فّْغنْ غَارْ ڭَارَّا، مَا خنِّي كنِّيوْ أَذْ ثقِّيممْ ذَا؟  
\v 7 مَايمِّي غَا ثسّْعڭْزمْ ؤُڒْ ن أَيْثْ ن إِسْرَائِيل مَاحنْذْ وَارْ ژكّْوِينْ غَارْ ثمُّورْثْ إِ ذ أَسنْ إِوْشَا سِيذِي؟  
\v 8 أَمُّو إِ ڭِّينْ ڒجْذُوذْ نْومْ ؤُمِي ثنْ سّكّغْ زِي قَاذَاشْ-بَارْنِيعْ حِيمَا خنِّي أَذْ ژَترنْ ثَامُّورْثْ. \x ◘ \xo 32:‏8 \xt ڒخْڒ. 13‏:‏3؛ أَعَوذ. 1‏:‏22 \x*  
\v 9 إِوْضنْ نِيثْنِي غَارْ ثغْزُورْثْ \add ن ثغْزَارْثْ\add* ن إِشْكُولْ ؤُشَا ژْرِينْ ثَامُّورْثْ ؤُشَا قڒْبنْ ؤُڒَاونْ ن أَيْثْ ن إِسْرَائِيل، مَاحنْذْ وَارْ تِّيذْفنْ شَا ذِي ثمُّورْثْ إِ ذ أَسنْ إِوْشَا سِيذِي.  
\v 10 ذڭْ وَاسّْ نِّي يَارْغَا وغْضَابْ ن سِيذِي ؤُشَا إِجِّيدْجْ، إِنَّا:  
\v 11 ’إِرْيَازنْ نِّي د-إِفّْغنْ زِي مِيصْرَا، زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ، وَارْ ژَترّنْ ثَامُّورْثْ نِّي خْ جُّودْجغْ أَذْ ت وْشغْ إِ إِبْرَاهِيمْ ذ إِسْحَاقْ ذ يَاعْقُوبْ، مِينْزِي نِيثْنِي وَارْ ذ أَيِي ضْفَارنْ نِيشَانْ، \x ◘ \xo 32:‏11 \xt ڒخْڒ. 14‏:‏28؛ أَعَوذ. 1‏:‏35\x*  
\v 12 مْغِيرْ كَالِيبْ، مِّيسْ ن يَافُونِّي، أَقِينِيزِي، ذ يَاشُووَا، مِّيسْ ن نُونْ، مِينْزِي نِيثْنِي ضْفَارنْ نِيشَانْ إِ سِيذِي.‘  
\v 13 ؤُشَا \add أَمُّو\add* يَارْغَا وغْذَابْ ن سِيذِي خْ إِسْرَائِيل ؤُشَا إِڭَّا إِ-ثنْ أَذْ ثلّْعنْ ذِي ڒخْڒَا أَربْعِينْ ن إِسڭّْوُوسَا، أَڒَامِي إِفْنَا مَارَّا جِّيڒْ نِّي إِڭِّينْ ڒْغَارْ ذِي ثِيطَّاوِينْ ن سِيذِي،  
\v 14 ؤُشَا خْزَارْ، كنِّيوْ ثْغوّْغمْ أَمْ ڒجْذُوذْ نْومْ، \add كنِّيوْ\add* ذ إِجّْ ن ؤُبَارُّو ن يرْيَازنْ ذ إِمذْنَابْ، \add ؤُشَا أَمُّو\add* إِ غَا ثَارْنِيمْ عَاذْ ڒْحَاذُوقْ ن وغْضَابْ ن سِيذِي خْ إِسْرَائِيل.  
\v 15 مَاڒَا ثْذوْڒمْ-د كنِّيوْ زِي ضفَّارْ نّسْ، نتَّا أَذْ يجّْ \add ڒْڭنْسْ\add* ذِي ڒخْڒَا عَاوذْ ؤُشَا \add أَمُّو إِ غَا\add* ثجّمْ مَارَّا ڒْڭنْسْ أَيَا أَذْ إِهلّكْ.“   
\m
\v 16 خنِّي قَارّْبنْ-د غَارسْ، نَّانْ: ”أَذْ نبْنَا ذَا ڒْكُورِييَّاثْ إِ وُودْجِي نّغْ ؤُ ثِيندَّامْ إِ إِحنْجِيرنْ نّغْ،  
\v 17 مَاشَا نشِّينْ أَذْ د-نفّغْ نوْجذْ إِ ؤُمنْغِي زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل س ڒسْنَاحْ \add نّغْ\add*، أَڒَامِي ثنْ نسِّيوضْ غَارْ ومْشَانْ نْسنْ. إِحنْجِيرنْ نّغْ أَذْ قِّيمنْ ذِي ثْندَّامْ إِفَارْينْ زِي سِّيبّثْ ن إِمزْذَاغْ ن ثمُّورْثْ.  
\v 18 وَارْ ندّكّْوِيڒْ غَارْ ثُوذْرِينْ نّغْ أَڒْ إِ غَا ثمّوْشْ ثسْغَارْثْ ن ڒْوَارْثْ إِ كُوڒْ إِجّْ زڭْ أَيْثْ ن إِسْرَائِيل.  
\v 19 مِينْزِي وَارْ نْثطّفْ ذِي ڒْوَارْثْ أَكِيذْسنْ غَارْ ثْمَا نّغْنِي ن لْ-ؤُرْذُونْ ؤُڒَا غَارْ زَّاثْ، مِينْزِي ثَاسْغَارْثْ إِ ذ أَنغْ د-إِتَّاسنْ أَقَا-ت غَارْ ثْمَا-يَا ثَانِيثَا ن لْ-ؤُرْذُونْ، غَارْ شَّارْقْ.“   
\m
\v 20 \add خنِّي\add* إِنَّا أَسنْ مُوسَا: ”مَاڒَا ثڭِّيمْ أَمُّو، مَاڒَا ثسّْوجْذمْ إِخفْ نْومْ إِ ؤُمنْغِي زَّاثْ إِ وُوذمْ ن سِيذِي،  
\v 21 ؤُ كُوڒْ إِجّْ، ونِّي إِسّْوجْذنْ إِخفْ نّسْ إِ ؤُمنْغِي، أَذْ إِژْوَا لْ-ؤُرْذُونْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَڒْ نتَّا أَذْ يَاژّڒْ خْ ڒْعذْيَانْ نّسْ زَّاثْ إِ وُوذمْ نّسْ زِي ثسْغَارْثْ نْسنْ ن ڒْوَارْثْ،  
\v 22 ؤُ أَذْ ثِيڒِي ثمُّورْثْ ثتّْوَاخْضعْ زَّاثْ إِ وُوذمْ ن سِيذِي، \add خنِّي\add* إِعدّڒْ أَذْ د-ثْذوْڒمْ ؤُ أَذْ ثِيڒِيمْ ثْبدّمْ زَّاثْ إِ سِيذِي ؤُ زَّاثْ إِ إِسْرَائِيل بْڒَا أَمَارْوَاسْ ؤُ أَذْ ثِيڒِي ثمُّورْثْ-أَ ذ أَڭْڒَا نْومْ زَّاثْ إِ وُوذمْ ن سِيذِي.   
\m
\v 23 \add مَاشَا\add* مَاڒَا وَارْ ثڭِّيمْ أَمُّو، \add خنِّي\add* أَقَا ثخْضَامْ ضِيدّْ إِ سِيذِي ؤُشَا أَذْ ثسّْنمْ أَقَا دّنْبْ نْومْ أَذْ كنِّيوْ يَافْ.  
\v 24 بْنَامْ ثِيندَّامْ إِ إِحنْجِيرنْ نْومْ ذ ڒْكُورِييَّاثْ إِ وُودْجِي نْومْ ؤُشَا ڭّمْ مِينْ د-إِفّْغنْ زڭْ ؤُقمُّومْ نْومْ.“   
\m
\v 25 \add خنِّي\add* سِّيوْڒنْ أَيْثْ ن جَاذْ ذ أَيْثْ ن رُوبِينْ أَكْ-ذ مُوسَا، نَّانْ: ”إِمْسخَّارنْ نّشْ أَذْ ڭّنْ أَمْ مَامّشْ ثنْ يُومُورْ سِيذِي إِنُو.  
\v 26 ثَارْوَا نّغْ، ثِيمْغَارِينْ نّغْ، ڒكْسِيبثْ نّغْ ذ مَارَّا ڒبْهَايمْ نّغْ أَذْ قِّيمنْ ذِي ثْندَّامْ ن جِيلْعَاذْ،  
\v 27 \add مَاشَا\add* إِمْسخَّارنْ نّشْ أَذْ ژْوَانْ إِ ؤُمنْغِي زَّاثْ إِ وُوذمْ ن سِيذِي، مَارَّا إِنِّي إِسّْوجْذنْ \add إِخفْ نْسنْ\add* إِ ؤُمنْغِي، أَمْ مَامّشْ إِسِّيوڒْ سِيذِي إِنُو.“   
\m
\v 28 ؤُشَا يُومُورْ خَاسنْ مُوسَا إِ ؤُكهَّانْ أَلِيعَازَارْ ؤُ إِ يَاشُووَا، مِّيسْ ن نُونْ، ؤُ إِ إِزدْجِيفنْ ن \add ثُوذْرِينْ ن\add* إِبَابَاثنْ ن ثْقبَّاڒْ ن أَيْثْ ن إِسْرَائِيل، \x ◘ \xo 32:‏28 \xt ياش. 1‏:‏13؛ 4‏:‏12\x*  
\v 29 إِنَّا أَسنْ مُوسَا: ”مَاڒَا أَيْثْ ن جَاذْ ذ أَيْثْ ن رُوبِينْ أَذْ كِيومْ ژْوَانْ لْ-ؤُرْذُونْ، كُوڒْ إِجّْ ونِّي إِسّْوجْذنْ إِخفْ نّسْ إِ ؤُمنْغِي زَّاثْ إِ وُوذمْ ن سِيذِي، ؤُ مَاڒَا \add خنِّي\add* ثَامُّورْثْ أَذْ ثِيڒِي ثتّْوَاخْضعْ زَّاثْ إِ وُوذمْ نْومْ، \add أَذْ ثَافْ\add* أَذْ أَسنْ ثوْشمْ ثَامُّورْثْ ن جِيلْعَاذْ ذ أَڭْڒَا.  
\v 30 مَاشَا مَاڒَا وَارْ كِيومْ ژكّْوِيمْ وجْذنْ إِ ؤُمنْغِي، \add خنِّي\add* أَذْ طّْفنْ أَڭْڒَا ذِي ڒْوسْطْ نْومْ ذِي ثمُّورْثْ ن كنْعَانْ.“  
\v 31 أَيْثْ ن جَاذْ ذ أَيْثْ ن رُوبِينْ أَرِّينْ-د، نَّانْ: ”أَمْ مَامّشْ إِسِّيوڒْ سِيذِي أَكْ-ذ إِمْسخَّارنْ نّشْ، أَمُّو إِ غَا نڭّْ.  
\v 32 نشِّينْ أَذْ نژْوَا غَارْ ثمُّورْثْ ن كنْعَانْ أَذْ نِيڒِي نوْجذْ إِ ؤُمنْغِي زَّاثْ إِ وُوذمْ ن سِيذِي، \add مَاشَا\add* ثَاسْغَارْثْ نّغْ ن ڒْوَارْثْ أَذْ ثِيڒِي غَارْ ثْمَا-يَا وَانِيثَا ن لْ-ؤُرْذُونْ.“   
\b  
\m
\v 33 ؤُ إِوْشَا أَسنْ مُوسَا، إِ أَيْثْ ن جَاذْ ؤُ إِ أَيْثْ ن رُوبِينْ ؤُ إِ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا، مِّيسْ ن يُوسُوفْ، ثَاڭلْذِيثْ ن سِيحُونْ، أَجدْجِيذْ ن إِمُورِييّنْ، ذ ثْڭلْذِيثْ ن عُوجْ، أَجدْجِيذْ ن بَاشَانْ، ثَامُّورْثْ س ثْندَّامْ نّسْ نِّي إِدْجَانْ ذِي جّْوَايهْ نّسْ ؤُڒَا ذ ثِيندَّامْ ذِي ثمُّورْثْ إِ ذ أَسْ د-إِنّْضنْ. \x ◘ \xo 32:‏33 \xt أَعَوذ. 3‏:‏12؛ ياش. 13‏:‏8؛ 22‏:‏4 \x*  
\v 34 أَيْثْ ن جَاذْ بْنَانْ ذِيبُونْ، عَاطَارُوثْ، عَارُوعِيرْ،  
\v 35 عَاطْرُوثْ-شُوفَانْ، يَاعْزِيرْ، يُوجْبَاهَا،  
\v 36 بَايْثْ-نِيمْرَا ذ بَايْثْ-هَارَانْ، ثِيندَّامْ إِفَارْينْ ذ ڒْكُورِييَّاثْ إِ وُودْجِي.  
\v 37 أَيْثْ ن رُوبِينْ بْنَانْ حَاشْبُونْ، أَلِيعَالَا، قَارْيَاثَايِيمْ، \f ◼ \fr 32:‏37 \ft \+bd ’قَارْيَاثَايِيمْ‘\+bd* - إِخْسْ أَذْ يِينِي ’ثْنَاينْ ن ثْندَّامْ‘.\f*  
\v 38 نابُو، بَاعْلْ-مَاعُونْ، ثنِّي زِي إِتّْوَابدّڒْ إِسمْ نْسنْ، ذ سِيبْمَا، ؤُشَا ڒَاغَانْ إِسْمَاونْ ن ثْندَّامْ إِ بْنَانْ \add عَاوذْ\add* س يِيسمْ \add نّغْنِي\add*.   
\m
\v 39 أَيْثْ ن مَاكِيرْ، مِّيسْ ن مَانَاسَّا، رُوحنْ غَارْ جِيلْعَاذْ ؤُشَا طّْفنْ ت ؤُشَا ؤُژّْڒنْ خْ إِمُورِييّنْ نِّي ذِينْ إِدْجَانْ زِي ڒْوَارْثْ نْسنْ. \x ◘ \xo 32:‏39 \xt أَمز. 50‏:‏23\x*  
\v 40 ؤُشَا مُوسَا إِوْشَا جِيلْعَاذْ إِ مَاكِيرْ، مِّيسْ ن مَانَاسَّا، ؤُشَا إِرُوحْ نتَّا أَذْ إِزْذغْ ذِينْ.  
\v 41 ؤُشَا يَا‘إِرْ، مِّيسْ ن مَانَاسَّا، إِرُوحْ ؤُشَا إِطّفْ ذْشُورَاثْ نّسْ ؤُشَا إِڒَاغَا أَسنْثْ ذْشُورَاثْ ن يَا‘إِرْ.  
\v 42 أَمنِّي إِرُوحْ نُوبَاحْ ؤُشَا إِطّفْ قِينَاثْ ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ ؤُشَا إِسمَّا أَسْ نُوبَاحْ س يِيسمْ نّسْ.   
\b  
\b  
\m  
\c 33
\s1 إِسَافَارنْ زِي مِيصْرَا أَڒْ كنْعَانْ  
\m
\v 1 أَمُّو إِ سّْمُّوطِّيينْ أَيْثْ ن إِسْرَائِيل إِنِّي د-إِفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، زڭْ ومْشَانْ غَارْ ومْشَانْ، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ \add ثِيرْبِيعِينْ ن\add* ڒْعسْكَارْ نْسنْ، س ؤُفُوسْ ن مُوسَا ذ هَارُونْ.  
\v 2 خْ ڒُومُورْ ن سِيذِي يُورَا مُوسَا إِمُوشَانْ مَانِيسْ د-فّْغنْ أَكْ-ذ إِرحَّالنْ نْسنْ. إِنَا ذ إِرحَّالنْ نْسنْ أَكْ-ذ إِمُوشَانْ مَانِيسْ د-فّْغنْ.   
\b  
\m
\v 3 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* \bd زِي رَاعَامْسِيسْ\bd* ذڭْ ؤُيُورْ أَمزْوَارُو، ذڭْ وَاسّْ وِيسّْ خمّسْطَاشْ ن ؤُيُورْ أَمزْوَارُو. ذِي صّْبحْ، \add ذغْيَا\add* أَوَارْنِي إِ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو فّْغنْ-د أَيْثْ ن إِسْرَائِيل س يِيجّْ ن ؤُفُوسْ إِتّْوَاسّْڭعّْذنْ زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا إِمِيصْرِييّنْ، \x ◘ \xo 33:‏3 \xt ؤُف. 12‏:‏37 \x*  
\v 4 \add ؤُمِي\add* ثُوغَا شغْڒنْ إِمِيصْرِييّنْ نطّْڒنْ مَارَّا إِمنْزَا نْسنْ، إِنِّي إِوْثَا سِيذِي \add س ڒْموْثْ\add* جَارْ أَسنْ. \add عَاوذْ\add* إِسِّيوضْ سِيذِي ڒحْكَامْ \add نّسْ\add* خْ إِربِّيثنْ نْسنْ.   
\m
\v 5 فسْينْ أَيْثْ ن إِسْرَائِيل إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي رَاعَامْسِيسْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي سُوكُّوثْ.   
\m
\v 6 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي سُوكُّوثْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي إِثَامْ غَارْ ثْمَا ن ڒخْڒَا. \x ◘ \xo 33:‏6 \xt ؤُف. 13‏:‏20 \x*   
\m
\v 7 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي إِثَامْ ؤُشَا ذوْڒنْ-د غَارْ بِي-هَاحِيرُوثْ نِّي إِدْجَانْ أَرنْذَاذْ ن بَاعْلْ-صَافُونْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ زَّاثْ إِ وُوذمْ ن مَاجْذَالْ. \x ◘ \xo 33:‏7 \xt ؤُف. 14‏:‏2 \x*   
\m
\v 8 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي بِي-هَاحِيرُوثْ ؤُشَا شُوكّنْ ذِي ڒْوسْطْ ن ڒبْحَارْ غَارْ ڒخْڒَا ؤُشَا ؤُيُورنْ ثِيشْڒِي ن ثْڒَاثَا ن وُوسَّانْ ذِي ڒخْڒَا ن إِثَامْ، \add خنِّي\add* وْثِينْ إِقِيضَانْ نْسنْ ذِي مَارَا. \x ◘ \xo 33:‏8 \xt ؤُف. 15‏:‏22، 23\x*   
\m
\v 9 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي مَارَا ؤُشَا إِوْضنْ غَارْ إِلِيمْ، مَانِي إِدْجَا ثنْعَاشْ ن إِغْبَالُوثنْ ن وَامَانْ ذ سبْعِينْ ن ثْشجُّورَا ن ثِينِي ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِينْ. \x ◘ \xo 33:‏9 \xt ؤُف. 15‏:‏27\x*   
\m
\v 10 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي إِلِيمْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ غَارْ ڒبْحَارْ ن ثلْڭَا.   
\m
\v 11 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي ڒبْحَارْ ن ثلْڭَا ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ڒخْڒَا ن سِينْ. \x ◘ \xo 33:‏11 \xt ؤُف. 16‏:‏1\x*   
\m
\v 12 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي ڒخْڒَا ن سِينْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ذُوفْقَا.   
\m
\v 13 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي ذُوفْقَا ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي أَلُوشْ.   
\m
\v 14 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي أَلُوشْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي رَافِيذِيمْ، مَانِي وَارْ يُوفِي أَمَانْ إِ ڒْڭنْسْ مَاحنْذْ أَذْ سْونْ. \x ◘ \xo 33:‏14 \xt ؤُف. 17‏:‏1\x*   
\m
\v 15 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي رَافِيذِيمْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ڒخْڒَا ن سِينَا. \x ◘ \xo 33:‏15 \xt ؤُف. 19‏:‏1\x*   
\m
\v 16 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي ڒخْڒَا ن سِينَا ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي قَابَارُوثْ-هَاثَاآوَاثْ. \x ◘ \xo 33:‏16 \xt ڒخْڒ. 11‏:‏34، 35\x*   
\m
\v 17 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي قَابَارُوثْ-هَاثَاآوَاثْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي حَاضَايْرُوثْ.   
\b  
\m
\v 18 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي حَاضَايْرُوثْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي \bd رِيثْمَا\bd*.   
\m
\v 19 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي رِيثْمَا ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي رِيمُّونْ-فَارِيصْ.   
\m
\v 20 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي رِيمُّونْ-فَارِيصْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي لِيبْنَا.   
\m
\v 21 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي لِيبْنَا ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي رِيسَّا.   
\m
\v 22 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي رِيسَّا ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي قِيهَايْلَاثَا.   
\m
\v 23 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي قِيهَايْلَاثَا ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي وذْرَارْ ن شَافَارْ.   
\m
\v 24 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زڭْ وذْرَارْ ن شَافَارْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي حَارَاذَا.   
\m
\v 25 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي حَارَاذَا ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي مَاقْهَايْلُوثْ.   
\m
\v 26 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي مَاقْهَايْلُوثْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ثَاحَاثْ.   
\m
\v 27 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي ثَاحَاثْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ثَارَاحْ.   
\m
\v 28 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي ثَارَاحْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي مِيثْقَا.   
\m
\v 29 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي مِيثْقَا ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي حَاشْمُونَا.   
\m
\v 30 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي حَاشْمُونَا ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي مُوسِيرُوثْ. \x ◘ \xo 33:‏30 \xt أَعَوذ. 10‏:‏6\x*   
\m
\v 31 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي مُوسِيرُوثْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي بَانِي-يَاعْقَانْ.   
\b  
\m
\v 32 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي بَانِي-يَاعْقَانْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي \bd حُورْ-جِيذْجَاذْ\bd*.   
\m
\v 33 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي زِي هُورْ-جِيذْجَاذْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي يُوثْبَاثْ.   
\m
\v 34 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي زِي يُوثْبَاثْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي عَابْرُونَا.   
\m
\v 35 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي زِي عَابْرُونَا ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي عِيصْيُونْ-جَابَارْ.   
\m
\v 36 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي زِي عِيصْيُونْ-جَابَارْ ؤُشَا ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ڒخْڒَا ن صِينْ نِّي \add يدْجَا\add* قَاذَاشْ. \x ◘ \xo 33:‏36 \xt ڒخْڒ. 20‏:‏1\x*   
\m
\v 37 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي قَاذَاشْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ غَارْ وذْرَارْ ن هُورْ، غَارْ ثْمَا ن ثمُّورْثْ ن إِذُومْ. \x ◘ \xo 33:‏37 \xt ڒخْڒ. 20‏:‏22\x*   
\b  
\m
\v 38 يُوڒِي ؤُكهَّانْ \bd هَارُونْ\bd* أَذْرَارْ ن هُورْ أَمْ مَامّشْ ذ أَسْ إِنَّا سِيذِي ؤُشَا إِمُّوثْ ذِينْ ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعِينْ أَوَارْنِي إِ ؤُفُّوغْ ن أَيْثْ ن إِسْرَائِيل زِي ثمُّورْثْ ن مِيصْرَا، ذڭْ ؤُيُورْ وِيسّْ خمْسَا، ذڭْ وَاسّْ أَمزْوَارُو ن ؤُيُورْ. \x ◘ \xo 33:‏38 \xt ڒخْڒ. 20‏:‏25؛ أَعَوذ. 32‏:‏50\x*  
\v 39 ثُوغَا هَارُونْ غَارسْ مْيَا ؤُ-ثْڒَاثَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِمُّوثْ ذڭْ وذْرَارْ ن هُورْ.   
\b  
\m
\v 40 ؤُشَا أَكنْعَانِي، أَجدْجِيذْ ن عَارَاذْ، \add ونِّي\add* ثُوغَا إِزدّْغنْ ذِي لْجَانُوبْ ن ثمُّورْثْ ن كنْعَانْ، إِسْڒَا س ثْوَاسِيثْ ن أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 33:‏40 \xt ڒخْڒ. 21‏:‏1\x*   
\b  
\m
\v 41 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زڭْ وذْرَارْ ن هُورْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي صَالْمُونَا. \x ◘ \xo 33:‏41 \xt ڒخْڒ. 21‏:‏4\x*   
\m
\v 42 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي صَالْمُونَا ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي فُونُونْ.   
\m
\v 43 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي فُونُونْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ؤُبُوثْ. \x ◘ \xo 33:‏43 \xt ڒخْڒ. 21‏:‏10\x*   
\m
\v 44 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي ؤُبُوثْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ڒْخِيرْبَاثْ ن عَابَارِيمْ ذِي جّْوَايهْ ن ويْمِيرْ أَكْ-ذ مُوآبَ. \f ◼ \fr 33:‏44 \ft \+bd ’ڒْْخِيرْبَاثْ‘\+bd* - نِيغْ ’أَرْوِينَاثْ‘.\f*   
\m
\v 45 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي ڒْخِيرْبَاثْ \add ن عَابَارِيمْ\add* ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ذِيبُونْ-جَاذْ.   
\m
\v 46 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي ذِيبُونْ-جَاذْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي عَالْمُونْ-ذِيبْلَاثَايِيمْ.   
\b  
\m
\v 47 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي عَالْمُونْ-ذِيبْلَاثَايِيمْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ \bd ذڭْ إِذُورَارْ ن عَابَارِيمْ زَّاثْ إِ وُوذمْ \+bdit ن وذْرَارْ\+bdit* ن نابُو\bd*.   
\m
\v 48 فسْينْ إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زڭْ إِذُورَارْ ن عَابَارِيمْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ \bd ذِي ڒوْضَاثْ ن مُوآبَ غَارْ لْ-ؤُرْذُونْ \+bdit أَرنْذَاذْ\+bdit* إِ أَرِيحَا\bd*.   
\m
\v 49 نِيثْنِي وْثِينْ إِقِيضَانْ نْسنْ غَارْ لْ-ؤُرْذُونْ زِي بَايْثْ-يَاشِيمُوثْ أَڒْ أَبَالْ-شِيطِّيمْ ذِي ڒوْضَاثْ ن مُوآبَ. \x ◘ \xo 33:‏49 \xt ڒخْڒ. 25‏:‏1؛ ياش. 2‏:‏1\x*   
\b  
\m  
\s1 أَوَاڒْ ن مُوسَا خْ ؤُطفُّو ن كنْعَانْ  
\m
\v 50 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذِي ڒوْضَاثْ ن مُوآبَ غَارْ لْ-ؤُرْذُونْ \add أَرنْذَاذْ ن\add* أَرِيحَا، إِنَّا:   
\m
\v 51 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ: ’خْمِي إِ غَا ثژْوَامْ لْ-ؤُرْذُونْ غَارْ ثمُّورْثْ ن كنْعَانْ،  
\v 52 \add خنِّي\add* إِتّْخصَّا كنِّيوْ أَذْ ثسُّوفّْغمْ مَارَّا إِمزْذَاغْ ن ثمُّورْثْ زَّاثْ إِ ؤُغمْبُوبْ نْومْ ذ مَارَّا ڒخْيَاڒَاثْ نْسنْ إِنقْشنْ أَذْ ثنْثْ ثَارذْدْجمْ. \add عَاوذْ\add* إِتّْخصَّا كنِّيوْ أَذْ ثثحَّامْ مَارَّا ڒخْيَاڒَاثْ إِفسْينْ نْسنْ ذ مَارَّا ڒڭْعُوذِي نْسنْ. \x ◘ \xo 33:‏52 \xt أَعَوذ. 7‏:‏2‏-‏26 \x*  
\v 53 أَذْ ثطّْفمْ ثَامُّورْثْ ذ ڒْوَارْثْ ؤُشَا أَذْ ذَايسْ ثْزذْغمْ، مِينْزِي نشّْ وْشِيغْ أَومْ ثَامُّورْثْ نِّي ذ أَڭْڒَا.  
\v 54 أَذْ ثبْضَامْ ثَامُّورْثْ س ثْقدُّوحْثْ أَمْ ڒْوَارْثْ خْ ڒَادْجَاثْ نْومْ. وِي غَارْ إِدْجَا أَطَّاسْ، أَذْ أَسْ ثوْشمْ أَطَّاسْ، ؤُ ونِّي غَارْ إِدْجَا ذْرُوسْ، أَذْ أَسْ ثوْشمْ ذْرُوسْ. مَانِي ذ أَسْ د-ثُوسَا ثْقدُّوحْثْ، أَذْ يِيڒِي نّسْ. عْلَاحْسَابْ ثِيقبَّاڒْ ن ڒجْذُوذْ نْومْ أَذْ ثْوَارْثمْ ثَاسْغَارْثْ نْومْ. \x ◘ \xo 33:‏54 \xt ڒخْڒ. 26‏:‏54‏-‏65\x*  
\v 55 مَاشَا مَاڒَا كنِّيوْ وَارْ ثسُّوفُّوغمْ شَا إِمزْذَاغْ ن ثمُّورْثْ زَّاثْ إِ وُوذمْ نْومْ، \add خنِّي\add* أَذْ إِمْسَارْ أَقَا إِنِّي إِ غَا ثجّمْ أَذْ قِّيمنْ، أَذْ ذوْڒنْ ذ إِسنَّاننْ ذِي ثِيطَّاوِينْ نْومْ ذ إِوزْوِيزنْ ذڭْ إِغزْذِيسنْ نْومْ ؤُشَا نِيثْنِي أَذْ كنِّيوْ حْصَارنْ ذِي ثمُّورْثْ نِّي مَانِي ثْزدّْغمْ. \x ◘ \xo 33:‏55 \xt ياش. 23‏:‏13؛ ڒقض. 2‏:‏3\x*  
\v 56 ؤُشَا \add خنِّي\add* أَذْ إِمْسَارْ أَذْ أَومْ ڭّغْ أَمْ مَامّشْ ثُوغَا خَارّْصغْ أَذْ أَكِيذْسنْ ڭّغْ.“   
\b  
\b  
\m  
\c 34
\s1 إِيْمِيرنْ ن ثمُّورْثْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”ؤُمُورْ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ: ’خْمِي غَا ثَاذْفمْ ثَامُّورْثْ ن كنْعَانْ، \add خنِّي\add* ثَا ذ ثَامُّورْثْ إِ ذ أَومْ غَا يِيڒِينْ ذ ڒْوَارْثْ، ثَامُّورْثْ ن كنْعَانْ أَكْ-ذ إِيْمِيرنْ نّسْ \add أَذْ ثِيڒِي أَمُّو\add*:   
\m
\v 3 جِّيهثْ ن لْجَانُوبْ أَذْ غَارْومْ ثِيڒِي زِي ڒخْڒَا ن صِينْ أَڒْ أَيْمِيرْ ن إِذُومْ ؤُشَا \bd أَيْمِيرْ ن لْجَانُوبْ\bd* أَذْ غَارْومْ يِيڒِي زِي طَّارْفْ أَنڭَّارُو ن ڒبْحَارْ أَمدْجَاحْ ذِي شَّارْقْ \x ◘ \xo 34:‏3 \xt ياش. 15‏:‏1\x*  
\v 4 ؤُشَا أَيْمِيرْ أَذْ إِميّڒْ زِي لْجَانُوبْ غَارْ ثْسُونْثَا ن ثْغَارْضْمِيوِينْ ؤُشَا أَذْ إِعْذُو غَارْ صِينْ ؤُشَا طّْرُوفَا نّسْ \add أَذْ د-أَوْضنْ\add* جِّيهثْ ن لْجَانُوبْ ن قَاذَاشْ-بَارْنِيعْ ؤُشَا أَذْ إِعْذُو غَارْ حَاصَارْ-أَدَّارْ ؤُشَا أَذْ إِژْوَا غَارْ أَصْمُونْ.  
\v 5 أَذْ إِنّضْ ويْمِيرْ زِي أَصْمُونْ غَارْ ثغْزَارْثْ ن مِيصْرَا ؤُشَا طّْرُوفَا نّسْ \add أَذْ أَوْضنْ\add* أَڒْ ڒبْحَارْ.   
\b  
\m
\v 6 ؤُشَا \bd أَيْمِيرْ ن ڒْغَارْبْ\bd* أَذْ أَومْ يِيڒِي ڒبْحَارْ أَمقّْرَانْ. وَا أَذْ أَومْ يِيڒِي ذ أَيْمِيرْ ن ڒْغَارْبْ.“ \f ◼ \fr 34:‏6 \ft \+bd ’ڒبْحَارْ أَمقّْرَانْ‘\+bd* - نِيغْ ’إِلّْ أَمقّْرَانْ‘. ڒبْحَارْ-أَ قَّارنْ أَسْ ذِي أَرِيفْ ’ڒبْحَارْ أَمژْيَانْ‘، ؤُشَا إِسمْ نّسْ ن جْذِيذْ أَقَا-ث ’إِلّْ أَڭْرَاكَالْ‘.\f*   
\b  
\m
\v 7 وَا أَذْ أَومْ يِيڒِي ذ \bd أَيْمِيرْ ن شَّامَالْ\bd*: أَذْ ث ثَارْشْممْ إِ يِيخفْ نْومْ زڭْ ڒبْحَارْ أَمقّْرَانْ أَڒْ أَذْرَارْ ن هُورْ.  
\v 8 زڭْ وذْرَارْ ن هُورْ أَذْ ث ثَارْشْممْ أَڒْ مَانِي غَا ثَاوْضذْ غَارْ حَامَاثْ ؤُشَا طّْرُوفَا ن ويْمِيرْ أَذْ أَوْضنْ أَڒْ صَاذَاذْ.  
\v 9 أَذْ يعْذُو ويْمِيرْ أَڒْ زِيفْرُونْ ؤُشَا طّْرُوفَا نّسْ أَذْ أَوْضنْ أَڒْ حَاصَارْ-عِينَانْ. وَا أَذْ أَومْ يِيڒِي ذ أَيْمِيرْ ن شَّامَالْ.   
\b  
\m
\v 10 أَذْ ثَارْشْممْ \bd أَيْمِيرْ نْومْ ن شَّارْقْ\bd* زِي حَاصَارْ-عِينَانْ غَارْ شَافَامْ  
\v 11 ؤُشَا أَذْ د-إِهْوَا ويْمِيرْ زِي شْفَامْ أَڒْ رِيبْلَا، شَّارْقْ ن عَايْنْ. \add خنِّي\add* أَذْ د-إِهْوَا ويْمِيرْ \add عَاذْ\add* كْثَارْ ؤُشَا أَذْ إِمُونْ أَكْ-ذ ثْمَا ن شَّارْقْ ن ڒبْحَارْ ن كِينَّارَاثْ.  
\v 12 \add خنِّي\add* أَذْ د-إِهْوَا ويْمِيرْ غَارْ لْ-ؤُرْذُونْ ؤُشَا طّْرُوفَا نّسْ أَذْ أَوْضنْ أَڒْ ڒبْحَارْ أَمدْجَاحْ. ثَا أَذْ أَومْ ثِيڒِي ذ ثَامُّورْثْ أَكْ-ذ إِيْمِيرنْ نّسْ إِ ذ أَسْ د-إِنّْضنْ.“   
\b  
\m
\v 13 ؤُشَا مُوسَا يُومُورْ أَيْثْ ن إِسْرَائِيل، إِنَّا: ”ثَا ذ ثَامُّورْثْ نِّي إِ غَا ثبْضَامْ جَارْ أَومْ س ثْقدُّوحْثْ، ثنِّي خْ يُومُورْ سِيذِي أَذْ ثمّوْشْ إِ ثسْعَا ن ثْقبَّاڒْ ؤُ إِ وزْينْ ن ثقْبِيتْشْ \add ن مَانَاسَّا\add*.  
\v 14 مِينْزِي ثَاقْبِيتْشْ ن أَيْثْ ن رُوبِينْ \add ثتّْوَاستّفْ\add* عْلَاحْسَابْ ثَادَّارْثْ ن إِبَابَاثنْ نْسنْ ؤُ ثَاقْبِيتْشْ ن جَاذْ \add ثتّْوَاستّفْ\add* عْلَاحْصَابْ ثَادَّارْثْ ن إِبَابَاثنْ نْسنْ، أَقَا نِيثْنِي طّْفنْ \add عَاذْ ثَاسْغَارْثْ نْسنْ\add*، ؤُ أَزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا ثطّفْ \add ؤُڒَا ذ نتَّاثْ\add* ثَاسْغَارْثْ نّسْ ن ڒْوَارْثْ.  
\v 15 ثْنَاينْ ن ثْقبَّاڒْ ذ وزْينْ أَقَا طّْفنْثْ ڒْوَارْثْ نْسنْثْ غَارْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، زِي أَرِيحَا غَارْ شَّارْقْ غَارْ مَانِيسْ د-ثْنقَّارْ \add ثْفُوشْثْ\add*.“   
\b  
\m
\v 16 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 17 ”إِنَا ذ إِسْمَاونْ ن يرْيَازنْ إِنِّي إِ غَا إِبْضَانْ ثَامُّورْثْ جَارْ أَومْ:  
\m أَكهَّانْ أَلِيعَازَارْ ذ يَاشُووَا، مِّيسْ ن نُونْ. \x ◘ \xo 34:‏17 \xt ياش. 14‏:‏1\x*   
\b  
\m
\v 18 أَذْ ثكْسِيمْ \add عَاوذْ\add* إِجّْ ن ڒْحَاكمْ زِي كُوڒْ ثَاقْبِيتْشْ مَاحنْذْ أَذْ ثبْضَامْ ثَامُّورْثْ.   
\m
\v 19 إِنَا ذ إِسْمَاونْ ن يرْيَازنْ:  
\m إِ ثقْبِيتْشْ ن يَاهُوذَا، كَالِيبْ، مِّيسْ ن يَافُونِّي   
\m
\v 20 إِ ثقْبِيتْشْ ن أَيْثْ ن شِيمْعُونْ، شِيمُووِيلْ، مِّيسْ ن عَامِّيهُوذْ،   
\m
\v 21 إِ ثقْبِيتْشْ ن بِينْيَامِينْ، إِلِيذَاذْ، مِّيسْ ن كَاسْلُونْ،   
\m
\v 22 إِ ثقْبِيتْشْ ن أَيْثْ ن ذَانْ، ڒْحَاكمْ بُوقِّي، مِّيسْ ن يُوجْلِي،   
\m
\v 23 إِ ثقْبِيتْشْ ن أَيْثْ ن يُوسُوفْ:  
\m إِ ثقْبِيتْشْ ن أَيْثْ ن مَانَاسَّا، ڒْحَاكمْ حَانِّييِيلْ، مِّيسْ ن إِفُوذْ،   
\m
\v 24 إِ ثقْبِيتْشْ ن أَيْثْ ن إِفْرَايِيمْ، ڒْحَاكمْ قِيمُويِيلْ، مِّيسْ ن شِيفْطَانْ،   
\m
\v 25 إِ ثقْبِيتْشْ ن أَيْثْ ن زابُولُونْ، ڒْحَاكمْ إِلِيصَافَانْ، مِّيسْ ن فَارْنَاخْ،   
\m
\v 26 إِ ثقْبِيتْشْ ن أَيْثْ ن إِسَّاكَارْ، ڒْحَاكمْ فَالْطِييِيلْ، مِّيسْ ن عَازَّانْ،   
\m
\v 27 إِ ثقْبِيتْشْ ن أَيْثْ ن أَشِيرْ، ڒْحَاكمْ أَخِيهُوذْ، مِّيسْ ن شَالُومِي،   
\m
\v 28 إِ ثقْبِيتْشْ ن أَيْثْ ن نَافْثَالِي، ڒْحَاكمْ فَاذَاهْيِيلْ، مِّيسْ ن عَامِّيهُوذْ.“   
\m
\v 29 إِنَا ذ إِنِّي خْ يُومُورْ سِيذِي أَذْ بْضَانْ ڒْوَارْثْ إِ أَيْثْ ن إِسْرَائِيل ذِي ثمُّورْثْ ن كنْعَانْ.   
\b  
\b  
\m  
\c 35
\s1 ثِيندَّامْ إِ إِلَاوِييّنْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذِي ڒوْضَاثْ ن مُوآبَ غَارْ لْ-ؤُرْذُونْ \add أَرنْذَاذْ ن\add* أَرِيحَا ؤُشَا إِنَّا:   
\m
\v 2 ”ؤُمُورْ أَيْثْ ن إِسْرَائِيل حِيمَا أَذْ وْشنْ، زِي ڒْوَارْثْ نْسنْ إِ طّْفنْ، ثِيندَّامْ إِ إِلَاوِييّنْ مَاحنْذْ أَذْ ذَايْسنْثْ زذْغنْ. أَذْ ثوْشمْ إِ إِلَاوِييّنْ \add عَاوذْ\add* دّْمَانِي ن ثَاروْسَا، إِنِّي ذ أَسنْ د-إِنّْضنْ إِ ثْندَّامْ. \x ◘ \xo 35:‏2 \xt ياش. 21‏:‏2\x*  
\v 3 ثِيندَّامْ-أَ أَذْ إِڒِينْثْ مَاحنْذْ أَذْ ذَايْسنْثْ زذْغنْ، ؤُشَا دّْمَانِي ن ثَاروْسَا أَذْ إِڒِينْ إِ ڒبْهَايمْ نْسنْ ؤُ إِ وَاڭْڒَا نْسنْ ؤُ إِ مَارَّا إِمُودَّارنْ نْسنْ.  
\v 4 ؤُشَا دّْمَانِي ن ثَاروْسَا إِ إِدْجَانْ غَارْ ثْندَّامْ نِّي إِ غَا ثوْشمْ إِ إِلَاوِييّنْ، أَذْ إِڒِينْ زڭْ وغْبَارْ ن ثنْذِينْثْ غَارْ بَارَّا أَڒفْ ن إِغَادْجنْ ؤُشَا \add أَمنِّي\add* غَارْ مَارَّا إِغزْذِيسنْ \add نّسْ\add*.  
\v 5 بَارَّا ن ثنْذِينْثْ غَارْ شَّارْقْ أَذْ ثْعبَّارمْ أَڒْفَاينْ ن إِغَادْجنْ ؤُ غَارْ لْجَانُوبْ أَڒْفَاينْ ن إِغَادْجنْ ؤُ غَارْ ڒْغَارْبْ أَڒْفَاينْ ن إِغَادْجنْ ؤُ غَارْ شَّامَالْ أَڒْفَاينْ ن إِغَادْجنْ ؤُشَا ثَانْذِينْثْ \add أَذْ ثِيڒِي\add* ذِي ڒْوسْطْ. إِنَا أَذْ أَسنْ إِڒِينْ ذ دّْمَانِي ن ثَاروْسَا ن ثْندَّامْ.  
\v 6 ثِيندَّامْ إِ غَا ثوْشمْ إِ إِلَاوِييّنْ \add أَذْ إِڒِينْثْ\add* ستَّا ن ثْندَّامْ ن ثَاروْڒَا. أَذْ ثنْثْ ثوْشمْ مَاحنْذْ أَذْ ذِينْ يَارْوڒْ ؤُقتَّاڒْ. سنّجْ إِ مَانْ أَيَا أَذْ \add ثنْثْ\add* ثوْشمْ \add عَاذْ\add* ثْنَاينْ ؤُ-ربْعِينْ ن ثْندَّامْ. \x ◘ \xo 35:‏6 \xt ياش. 21‏:‏21\x*   
\m
\v 7 مَارَّا ثِيندَّامْ إِ غَا ثوْشمْ إِ إِلَاوِييّنْ، \add أَذْ إِڒِينْثْ\add* ثْمنْيَا ؤُ-ربْعِينْ ن ثْندَّامْ، ثِينَا \add سِيمَانْثْ نْسنْثْ\add* ذ دّْمَانِي نْسنْثْ ن ثَاروْسَا.  
\v 8 خْ ثْندَّامْ إِ غَا ثوْشمْ زڭْ وَاڭْڒَا ن أَيْثْ ن إِسْرَائِيل، أَذْ ثنْثْ ثكْسِيمْ كْثَارْ زڭْ ونِّي غَارْ إِدْجَا وَاطَّاسْ ؤُ زڭْ ونِّي غَارْ إِدْجَا ذْرُوسْ، أَذْ ثكْسِيذْ ذْرُوسْ. كُوڒْ إِجّْ أَذْ إِوْشْ زِي ثْندَّامْ نّسْ إِ إِلَاوِييّنْ عْلَاحْسَابْ \add ڒْقدّْ ن\add* ثسْغَارْثْ نّسْ زِي ڒْوَارْثْ إِ إِطّفْ.“   
\b  
\m  
\s1 ثِيندَّامْ إِ ثَاروْڒَا  
\m
\v 9 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 10 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ: ’خْمِي غَا ثژْوَامْ لْ-ؤُرْذُونْ غَارْ ثمُّورْثْ ن كنْعَانْ، \x ◘ \xo 35:‏10 \xt أَعَوذ. 19‏:‏2؛ ياش. 20‏:‏2\x*  
\v 11 أَذْ ثْنيّْشمْ إِ يِيخفْ نْومْ ثِيندَّامْ نِّي ذ أَومْ إِ غَا إِڒِينْثْ ذ ثِيندَّامْ ن ثَاروْڒَا، حِيمَا أَقتَّاڒْ، ونِّي إِنْغِينْ حذْ زڭْ ؤُودَّارْ، إِزمَّارْ أَذْ ذِينْ يَارْوڒْ.  
\v 12 ثِيندَّامْ-أَ أَذْ أَومْ إِڒِينْثْ إِ ثَاروْڒَا زڭْ ؤُنقَّامْ ن إِذَامّنْ، حِيمَا وَارْ إِتّْمتِّي ؤُقتَّاڒْ قْبڒْ مَا أَذْ إِبدّْ زَّاثْ إِ وُوذمْ ن ثْمسْمُونْثْ إِ ڒْحُوكْمْ.  
\v 13 زِي ثْندَّامْ إِ غَا ثوْشمْ، أَذْ \add زَّايْسنْثْ\add* إِڒِينْثْ ستَّا ذ ثِيندَّامْ ن ثَاروْڒَا إِ كنِّيوْ.   
\m
\v 14 ثْڒَاثَا ن ثْندَّامْ أَذْ \add ثنْثْ\add* ثوْشمْ غَارْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ ؤُ ثْڒَاثَا ن ثْندَّامْ أَذْ \add ثنْثْ\add* ثوْشمْ ذِي ثمُّورْثْ ن كنْعَانْ. أَذْ إِڒِينْثْ ذ ثِيندَّامْ ن ثَاروْڒَا. \x ◘ \xo 35:‏14 \xt أَعَوذ. 4‏:‏41؛ ياش. 20‏:‏8\x*  
\v 15 ستَّا ن ثْندَّامْ-أَ أَذْ إِڒِينْثْ إِ ثَاروْڒَا إِ أَيْثْ ن إِسْرَائِيل ؤُڒَا إِ ؤُبَارَّانِي ذ ؤُمْعزّبْ ذِي ڒْوسْطْ نْسنْ، حِيمَا ونِّي إِنْغِينْ حذْ زڭْ ؤُودَّارْ، إِزمَّارْ أَذْ ذِينْ يَارْوڒْ.   
\m
\v 16 مَاڒَا إِوّثْ إِ-ث س إِشْثْ ن ڒْقشْعثْ ن وُوزَّاڒْ ؤُشَا إِمُّوثْ، \add خنِّي\add* أَقَا نتَّا ذ أَقتَّاڒْ. أَقتَّاڒْ أَذْ إِتّْوَانغْ نِيشَانْ.  
\v 17 مَاڒَا إِوّثْ إِ-ث س إِجّْ ن وژْرُو ذڭْ ؤُفُوسْ إِ زِي إِزمَّارْ أَذْ إِمّثْ ؤُشَا \add خنِّي\add* إِمُّوثْ، أَقَا نتَّا ذ أَنقَّامْ. أَنقَّامْ أَذْ إِتّْوَانغْ نِيشَانْ.  
\v 18 نِيغْ \add مَاڒَا\add* إِوّثْ إِ-ث س إِشْثْ ن ڒْقشْعثْ ن ؤُكشُّوضْ ذڭْ ؤُفُوسْ إِ زِي إِزمَّارْ أَذْ إِمّثْ ؤُشَا \add خنِّي\add* إِمُّوثْ، أَقَا نتَّا ذ أَقتَّاڒْ. أَقتَّاڒْ أَذْ إِتّْوَانغْ نِيشَانْ.  
\v 19 أَنقَّامْ ن إِذَامّنْ أَذْ إِنغْ أَقتَّاڒْ. مَاڒَا أَذْ ث إِڒْقَا، أَذْ ث إِنغْ.   
\m
\v 20 ؤُ مَاڒَا إِعَارْنْ إِ-ث س وشْرَاهْ، نِيغْ إِنْضَارْ غَارسْ \add شَا\add* س نعْمَاذَا أَڒَامِي \add زَّايسْ\add* إِمُّوثْ، \x ◘ \xo 35:‏20 \xt أَعَوذ. 19‏:‏11\x*  
\v 21 نِيغْ إِوّثْ إِ-ث س ڒعْذَاوثْ س ؤُفُوسْ نّسْ، أَڒَامِي \add زَّايسْ\add* إِمُّوثْ، \add خنِّي\add* ونِّي \add ث\add* إِنْغِينْ أَذْ إِتّْوَانغْ نِيشَانْ. أَقَا-ث ذ أَقتَّاڒْ. أَنقَّامْ ن إِذَامّنْ أَذْ إِنغْ أَقتَّاڒْ خْمِي ث غَا إِڒْقَا.   
\m
\v 22 \add مَاشَا\add* مَاڒَا ثُوغَا إِعَارّنْ إِ-ث أَمنِّي ذڭْ ورْمَاشْ ن وَابْڒِيونْ بْڒَا ڒعْذَاوثْ، نِيغْ إِنْضَارْ غَارسْ شَا ن ڒْقشْعثْ أَمْ إِودَّارْ،  
\v 23 نِيغْ أَمْ وَارْ ث إِژْرِي، إِڭَّا أَذْ خَاسْ د-إِوْضَا شَا ن وژْرُو إِ زِي إِزمَّارْ أَذْ إِمّثْ، ؤُشَا \add خنِّي\add* إِمُّوثْ أَمْ وَارْ ثُوغِي ذ ڒعْذُو نّسْ ؤُ نتَّا ثُوغَا وَارْ ذ أَسْ يَارزُّو ڒْغَارْ،  
\v 24 \add خنِّي\add* ثَامسْمُونْثْ أَذْ ثحْكمْ جَارْ ؤُقتَّاڒْ ذ ؤُنقَّامْ ن إِذَامّنْ عْلَاحْسَابْ لْفَارَايِيضْ-أَ.  
\v 25 ثَامسْمُونْثْ أَذْ ثْفكّْ أَقتَّاڒْ زڭْ ؤُفُوسْ ن ؤُنقَّامْ ن إِذَامّنْ ؤُشَا ثَامسْمُونْثْ أَذْ ثجّْ نتَّا أَذْ إِعْقبْ غَارْ ثنْذِينْثْ نّسْ ن ثَاروْڒَا. أَذْ ذِينْ إِقِّيمْ أَڒْ ڒْموْثْ ن أَرَّايْسْ ن إِكهَّاننْ، ونِّي ذهْننْ نِيثْنِي س زّشْثْ إِقدّْسنْ.  
\v 26 \add مَاشَا\add* مَاڒَا أَقتَّاڒْ إِفّغْ بَارَّا ن إِيْمِيرنْ ن ثنْذِينْثْ ن ثَاروْڒَا مَانِي يَارْوڒْ،  
\v 27 ؤُشَا أَنقَّامْ ن إِذَامّنْ يُوفَا إِ-ث بَارَّا ن إِيْمِيرنْ ن ثنْذِينْثْ ن ثَاروْڒَا ؤُشَا أَنقَّامْ ن إِذَامّنْ إِنْغَا ونِّي إِنْغِينْ، وَارْ خَاسْ شَا إِذَامّنْ \add خنِّي\add*.  
\v 28 مِينْزِي ثُوغَا خَاسْ أَذْ إِقِّيمْ ذِي ثنْذِينْثْ نّسْ ن ثَاروْڒَا أَڒْ ڒْموْثْ ن أَرَّايْسْ ن إِكهَّاننْ. \add مَاشَا\add* أَوَارْنِي ڒْموْثْ ن أَرَّايْسْ ن إِكهَّاننْ إِزمَّارْ أَذْ إِعْقبْ ؤُقتَّاڒْ غَارْ ثمُّورْثْ نِّي إِدْجَانْ نّسْ.  
\v 29 أَيَا أَذْ أَومْ ثِيڒِي ذ ثَاوْصيّثْ ن ڒْحقّْ إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ مَانِي مَا غَا ثْزذْغمْ.   
\m
\v 30 كُوڒْ إِجّْ، ونِّي إِنْغِينْ حذْ، أَقَا أَقتَّاڒْ أَذْ إِتّْوَانغْ عْلَاحْسَابْ أَقمُّومْ ن ڒشْهُوذْ، \add مَاشَا\add* إِجّْ ن ؤُشهَّاذْ \add وَاهَا\add*، وَارْ إِزمَّارْ أَذْ إِشْهذْ خْ إِشْثْ ن نّفْسْ س ڒْموْثْ. \x ◘ \xo 35:‏30 \xt أَعَوذ. 17‏:‏6؛ 19‏:‏15\x*  
\v 31 وَارْ كسِّيمْ دّيّثْ خْ ڒعْمَارْ ن ؤُقتَّاڒْ نِّي خْ إِتّْوَاحْكمْ س ڒْموْثْ، مَاغَارْ إِتّْخصَّا أَذْ إِتّْوَانغْ نِيشَانْ.  
\v 32 وَارْ كسِّيمْ دّيّثْ خْ ونِّي يَاروْڒنْ غَارْ ثنْذِينْثْ نّسْ ن ثَاروْڒَا ذِي طّْوعْ ن وعْقَابْ نّسْ، مَاحنْذْ أَذْ إِزْذغْ ذِي ثمُّورْثْ قْبڒْ ڒْموْثْ ن أَرَّايْسْ ن إِكهَّاننْ.   
\m
\v 33 وَارْ إِعدّڒْ أَذْ ثسّخْسَارمْ ثَامُّورْثْ مَانِي ثدْجَامْ، مِينْزِي إِذَامّنْ سّخْسَارَانْ ثَامُّورْثْ ؤُشَا وَارْ إِزمَّارْ أَذْ إِتّْوَاڭّْ وصْڒَاحْ إِ ثمُّورْثْ ذِي طّْوعْ ن إِذَامّنْ إِ ذَايسْ إِتّْوَاسِّيزْڒنْ، مْغِيرْ س إِذَامّنْ ن ونِّي ثنْ إِسِّيزّْڒنْ.  
\v 34 وَارْ سْخمِّيجمْ ثَامُّورْثْ مَانِي غَا ثْزذْغمْ كنِّيوْ، ذِي ڒْوسْطْ نّسْ إِ غَا زذْغغْ نشّْ، مِينْزِي نشّْ ذ سِيذِي، ونِّي إِزدّْغنْ ذِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل.“   
\b  
\b  
\m  
\c 36
\s1 ثَاسْغَارْثْ ن ڒْوَارْثْ إِ يسِّيسْ ن صَالُوفْحَاذْ  
\m
\v 1 زِي ڒَادْجَاثْ ن إِحنْجِيرنْ ن يُوسُوفْ قَارّْبنْ-د إِزدْجِيفنْ جَارْ إِبَابَاثنْ ن ڒَادْجْ ن إِحنْجِيرنْ ن جِيلْعَاذْ، مِّيسْ ن مَاكِيرْ، مِّيسْ ن مَانَاسَّا ؤُشَا نِيثْنِي سِّيوْڒنْ زَّاثْ إِ وُوذمْ ن مُوسَا ؤُ زَّاثْ إِ وُوذمْ ن ڒْحُوكَّامْ، إِزدْجِيفنْ \add نّغْنِي\add* خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ن أَيْثْ ن إِسْرَائِيل  
\v 2 ؤُشَا نِيثْنِي نَّانْ: ”سِيذِي يُومُورْ سِيذِي إِنُو مَاحنْذْ أَذْ إِوْشْ ثَامُّورْثْ س ثْقدُّوحْثْ إِ أَيْثْ ن إِسْرَائِيل ذ ڒْوَارْثْ. ؤُشَا يُومُورْ سِيذِي إِ سِيذِي إِنُو أَذْ إِوْشْ ثَاسْغَارْثْ ن ڒْوَارْثْ ن ؤُمَاثْنغْ صَالُوفْحَاذْ إِ يسِّيسْ. \x ◘ \xo 36:‏2 \xt ڒخْڒ. 26‏:‏55، 56؛ 27‏:‏7؛ 33‏:‏54؛ ياش. 17‏:‏3، 4\x*  
\v 3 مَاڒَا ذوْڒنْثْ نِيثنْثِي ذ ثِينمْڒَاتْشْ أَكْ-ذ إِجّنْ زڭْ إِحنْجِيرنْ ن ثْقبَّاڒْ نّغْنِي ن أَيْثْ ن إِسْرَائِيل، خنِّي أَذْ ثتّْوَاكّسْ ثسْغَارْثْ نْسنْثْ ذِي ڒْوَارْثْ ن ڒجْذُوذْ نّغْ ؤُشَا أَذْ ثتّْوَارْنِي \add ثَاسْغَارْثْ نْسنْثْ\add* إِ ثسْغَارْثْ ن ثقْبِيتْشْ إِ غَارْ غَا مُوننْثْ ؤُشَا \add أَمُّو\add* أَذْ إِتّْوَاسّمْژِي مِينْ إِدْجَانْ ذ ثَاسْغَارْثْ نّغْ س ثْقدُّوحْثْ.  
\v 4 خْمِي د غَا يَاسْ ؤُسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ إِ أَيْثْ ن إِسْرَائِيل، \add خنِّي\add* أَذْ ثتّْوَامَارْنِي ثسْغَارْثْ نْسنْثْ إِ ثسْغَارْثْ ن ثقْبِيتْشْ أَكْ-ذ وِي غَا مُوننْثْ. \add أَمُّو\add* إِ غَا ثتّْوَاكّسْ \add خنِّي\add* ثسْغَارْثْ نْسنْثْ ذِي ڒْوَارْثْ ن ثقْبِيتْشْ ن ڒجْذُوذْ نّغْ.“   
\m
\v 5 \add خنِّي\add* يُومُورْ مُوسَا إِ أَيْثْ ن إِسْرَائِيل عْلَاحْسَابْ ڒُومُورْ ن سِيذِي، إِنَّا: ”\add أَقَا ذ ثِيذتّْ\add* أَمْ مَامّشْ ثسِّيوڒْ ثقْبِيتْشْ ن أَيْثْ ن يُوسُوفْ.  
\v 6 وَا ذ أَوَاڒْ إِ زِي يُومُورْ سِيذِي خْ يسِّيسْ ن صَالُوفْحَاذْ، إِقَّارْ: ’أجّْ إِ-ثنْثْ أَذْ مڒْشنْثْ أَكْ-ذ ونِّي ذ أَسنْثْ يَارشْقنْ. إِتّْخصَّا مْغِيرْ أَذْ مڒْشنْثْ ذِي ڒَادْجْ ن ثقْبِيتْشْ ن بَابَاثْسنْثْ.  
\v 7 وَارْ إِعدّڒْ أَذْ ثْرَاحْ ثسْغَارْثْ ن أَيْثْ ن إِسْرَائِيل زِي ثقْبِيتْشْ غَارْ ثقْبِيتْشْ \add نّغْنِي\add*، مِينْزِي كُوڒْ أَرْيَازْ ن أَيْثْ ن إِسْرَائِيل أَذْ إِقِّيمْ إِطّفْ ذِي ثسْغَارْثْ ن ثقْبِيتْشْ ن ڒجْذُوذْ نّسْ.  
\v 8 يدْجِيسْ ن كُوڒْ إِجّْ إِ غَا إِطّْفنْ إِشْثْ ن ثسْغَارْثْ زڭْ أَيْثْ ن إِسْرَائِيل، إِتّْخصَّا أَسْ أَذْ ثمْڒشْ أَكْ-ذ إِجّْ زڭْ إِجّْ ن ڒَادْجْ زِي ثقْبِيتْشْ ن بَابَاسْ، حِيمَا كُوڒْ إِجّْ زڭْ أَيْثْ ن إِسْرَائِيل أَذْ إِوَارْثْ ثَاسْغَارْثْ ن ڒجْذُوذْ نّسْ. \f ◼ \fr 36:‏8 \ft \+bd ’يدْجِيسْ‘\+bd* - نِيغْ ’إِدْجِيسْ‘.\f*  
\v 9 وَارْ إِعدّڒْ أَذْ ثْرَاحْ ثسْغَارْثْ ن إِشْثْ ن ثقْبِيتْشْ غَارْ ثقْبِيتْشْ نّغْنِي، مِينْزِي إِتّْخصَّا إِ كُوڒْ إِشْثْ زِي ثْقبَّاڒْ ن أَيْثْ ن إِسْرَائِيل أَذْ إِقِّيمْ إِطّفْ ذِي ثسْغَارْثْ نّسْ.‘ “   
\m
\v 10 يسِّيسْ ن صَالُوفْحَاذْ ڭِّينْثْ أَمْ مَامّشْ \add ث\add* يُومُورْ سِيذِي إِ مُوسَا.  
\v 11 مَاحْلَا، ثِيرْصَا، حُوجْلَا، مِيلْكَا ذ نُوعَا، يسِّيسْ ن صَالُوفْحَاذْ، ذوْڒنْثْ ذ ثِينمْڒَاتْشْ أَكْ-ذ إِحنْجِيرنْ نعمِّيثْسنْثْ. \x ◘ \xo 36:‏11 \xt ڒخْڒ. 27‏:‏1\x*  
\v 12 ذوْڒنْثْ ذ ثِينمْڒَاتْشْ ذِي ڒَادْجَاثْ ن أَيْثْ ن مَانَاسَّا، مِّيسْ ن يُوسُوفْ. \add أَمُّو إِ\add* ثقِّيمْ ثسْغَارْثْ نْسنْثْ ذِي ثقْبِيتْشْ ن بَابَاثْسنْثْ.   
\m
\v 13 ثِينَا ذ ثِيوصَّا ذ لْفَارَايِيضْ نِّي يُومُورْ سِيذِي س ثْسخَّارْثْ ن مُوسَا إِ أَيْثْ ن إِسْرَائِيل ذِي ڒوْضَاثْ ن مُوآبَ، غَارْ لْ-ؤُرْذُونْ \add أَرنْذَاذْ ن\add* أَرِيحَا.   