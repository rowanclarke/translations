\v 3 \w Horsemen|strong="H6571"\w* charge, \w swords|strong="H2719"\w* \w flash|strong="H3851"\w*, \w spears|strong="H2595"\w* \w glitter|strong="H1300"\w*! \w Many|strong="H7230"\w* \w dead|strong="H2491"\w*, piles \w of|strong="H7230"\w* \w corpses|strong="H6297"\w*, countless \w bodies|strong="H6297"\w*—\w so|strong="H5927"\w* \w many|strong="H7230"\w* \w that|strong="H5927"\w* people \w stumble|strong="H3782"\w* \w over|strong="H3782"\w* \w them|strong="H5927"\w*.
\p 
\v 4 \w All|strong="H7230"\w* \w this|strong="H7230"\w* happens \w because|strong="H7230"\w* \w the|strong="H2181"\w* repeated prostitution \w of|strong="H4940"\w* Nineveh \w the|strong="H2181"\w* \w prostitute|strong="H2181"\w*, \w the|strong="H2181"\w* \w beautiful|strong="H2896"\w* \w mistress|strong="H1172"\w* \w with|strong="H2896"\w* her deadly charms \w who|strong="H2896"\w* seduces \w nations|strong="H1471"\w* \w into|strong="H4376"\w* slavery \w by|strong="H4940"\w* her prostitution \w and|strong="H1471"\w* her witchcraft.
\v 5 \w Watch|strong="H7200"\w* \w out|strong="H7200"\w*! \w For|strong="H5921"\w* \w I|strong="H2005"\w* \w am|strong="H3068"\w* \w against|strong="H5921"\w* \w you|strong="H6440"\w*, \w declares|strong="H5002"\w* \w the|strong="H6440"\w* \w Lord|strong="H3068"\w* \w Almighty|strong="H6635"\w*. \w I|strong="H2005"\w* \w will|strong="H3068"\w* \w lift|strong="H3068"\w* \w your|strong="H3068"\w* \w skirts|strong="H7757"\w* \w over|strong="H5921"\w* \w your|strong="H3068"\w* \w face|strong="H6440"\w* \w and|strong="H3068"\w* \w let|strong="H1540"\w* \w the|strong="H6440"\w* \w nations|strong="H1471"\w* \w see|strong="H7200"\w* \w your|strong="H3068"\w* \w nakedness|strong="H4626"\w*, \w and|strong="H3068"\w* \w kingdoms|strong="H4467"\w* \w see|strong="H7200"\w* \w your|strong="H3068"\w* \w shame|strong="H7036"\w*.
