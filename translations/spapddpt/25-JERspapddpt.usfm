\v 19 ¿\w Dónde|strong="H5921"\w* están tus \w profetas|strong="H5030"\w* \w que|strong="H3808"\w* \w les|strong="H5921"\w* \w profetizaban|strong="H5012"\w*: \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia \w no|strong="H3808"\w* vendrá \w contra|strong="H5921"\w* ustedes, \w ni|strong="H3808"\w* \w contra|strong="H5921"\w* \w esta|strong="H2063"\w* tierra?  
\v 20 Pero \w ahora|strong="H6258"\w*, oh \w rey|strong="H4428"\w*, \tl ʼadón\tl* mío, te \w ruego|strong="H8467"\w* \w que|strong="H3808"\w* me escuches. Permite \w que|strong="H3808"\w* \w mi|strong="H4994"\w* \w súplica|strong="H8467"\w* llegue \w ante|strong="H6440"\w* ti, y \w no|strong="H3808"\w* me devuelvas \w a|strong="H3068"\w* \w casa|strong="H1004"\w* del \w escriba|strong="H5608"\w* Jonatán \w para|strong="H6258"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w muera|strong="H4191"\w* \w allí|strong="H8033"\w*.   
\p
\v 21 \w Entonces|strong="H3117"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* Sedequías \w ordenó|strong="H6680"\w* \w que|strong="H4480"\w* custodiaran \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w en|strong="H4480"\w* \w el|strong="H3605"\w* \w patio|strong="H2691"\w* \w de|strong="H4480"\w* \w la|strong="H3605"\w* guardia \w real|strong="H4428"\w*, \w y|strong="H5704"\w* \w que|strong="H4480"\w* le dieran una hogaza \w de|strong="H4480"\w* \w pan|strong="H3899"\w* diariamente \w de|strong="H4480"\w* \w la|strong="H3605"\w* calle \w de|strong="H4480"\w* \w los|strong="H3427"\w* Panaderos, \w mientras|strong="H3605"\w* hubiera \w pan|strong="H3899"\w* \w en|strong="H4480"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w*. \w Por|strong="H4480"\w* tanto \w Jeremías|strong="H3414"\w* permaneció \w en|strong="H4480"\w* \w el|strong="H3605"\w* \w patio|strong="H2691"\w* \w de|strong="H4480"\w* \w la|strong="H3605"\w* guardia \w real|strong="H4428"\w*.   
\c 38  
\s1 Castigo para Jeremías en una cisterna de lodo  
\p
\v 1 Sefatías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Matán, \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Pasur, Jucal, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Selemías, y Pasur, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Malquías, \w oyeron|strong="H8085"\w* las \w Palabras|strong="H1697"\w* \w que|strong="H5971"\w* \w Jeremías|strong="H3414"\w* \w hablaba|strong="H1696"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*:  
\v 2 \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj \+w El|strong="H3427"\+w* \+w que|strong="H1961"\+w* \+w se|strong="H1961"\+w* \+w quede|strong="H1961"\+w* \+w en|strong="H3318"\+w* \+w esta|strong="H2063"\+w* \+w ciudad|strong="H5892"\+w* \+w morirá|strong="H4191"\+w* \+w a|strong="H3068"\+w* \+w espada|strong="H2719"\+w*, de \+w hambre|strong="H7458"\+w* \+w o|strong="H3068"\+w* de \+w pestilencia|strong="H1698"\+w*. Pero \+w el|strong="H3427"\+w* \+w que|strong="H1961"\+w* \+w se|strong="H1961"\+w* pase \+w a|strong="H3068"\+w* \+w los|strong="H3427"\+w* \+w caldeos|strong="H3778"\+w* \+w vivirá|strong="H2421"\+w*, \+w tendrá|strong="H1961"\+w* su \+w vida|strong="H5315"\+w* \+w como|strong="H1961"\+w* botín \+w y|strong="H3541"\+w* seguirá vivo.\wj*  
\v 3 \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj \+w Ciertamente|strong="H5414"\+w* \+w esta|strong="H2063"\+w* \+w ciudad|strong="H5892"\+w* \+w será|strong="H5414"\+w* \+w entregada|strong="H5414"\+w* en \+w mano|strong="H3027"\+w* del \+w ejército|strong="H2428"\+w* del \+w rey|strong="H4428"\+w* \+w de|strong="H5414"\+w* Babilonia, \+w y|strong="H3541"\+w* \+w la|strong="H2063"\+w* \+w tomará|strong="H3920"\+w*.\wj*   
\p
\v 4 \w Entonces|strong="H3588"\w* \w los|strong="H5921"\w* magistrados \w dijeron|strong="H1697"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w*: \w Te|strong="H5921"\w* rogamos \w que|strong="H3588"\w* \w este|strong="H2088"\w* hombre sea ejecutado, \w porque|strong="H3588"\w* debilita \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* guerreros \w que|strong="H3588"\w* quedan \w en|strong="H5921"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*, \w y|strong="H3588"\w* \w las|strong="H5921"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w al|strong="H5921"\w* hablarles \w así|strong="H3651"\w*. \w Este|strong="H2088"\w* hombre \w no|strong="H3588"\w* \w busca|strong="H1875"\w* \w el|strong="H1931"\w* bienestar \w de|strong="H5921"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, \w sino|strong="H3588"\w* \w su|strong="H1931"\w* \w mal|strong="H7451"\w*.   
\p
\v 5 \w Y|strong="H3068"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* Sedequías respondió: Miren, \w él|strong="H1931"\w* \w está|strong="H1931"\w* \w en|strong="H3588"\w* \w sus|strong="H1931"\w* \w manos|strong="H3027"\w*. \w El|strong="H1931"\w* \w rey|strong="H4428"\w* \w nada|strong="H1697"\w* \w puede|strong="H3201"\w* hacer contra ustedes.   
\p
\v 6 \w Entonces|strong="H3588"\w* \w tomaron|strong="H3947"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w y|strong="H3588"\w* lo echaron \w en|strong="H3588"\w* \w la|strong="H3588"\w* cisterna \w de|strong="H3588"\w* Malquías, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Hamelec, \w la|strong="H3588"\w* \w cual|strong="H3588"\w* estaba \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w patio|strong="H2691"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* guardia. Bajaron \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w con|strong="H3588"\w* \w sogas|strong="H2256"\w*. \w En|strong="H3588"\w* \w la|strong="H3588"\w* cisterna \w no|strong="H3588"\w* \w había|strong="H3588"\w* \w agua|strong="H4325"\w*, \w sino|strong="H3588"\w* lodo, \w y|strong="H3588"\w* \w Jeremías|strong="H3414"\w* se hundió \w en|strong="H3588"\w* \w el|strong="H3588"\w* lodo.   
\p
\v 7 \w Pero|strong="H3588"\w* \w el|strong="H1931"\w* \w etíope|strong="H3569"\w* llamado \w Ebed-melec|strong="H5663"\w*, servidor \w en|strong="H3588"\w* \w el|strong="H1931"\w* palacio \w real|strong="H4428"\w*, \w supo|strong="H8085"\w* \w que|strong="H3588"\w* habían metido \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w en|strong="H3588"\w* \w la|strong="H1931"\w* cisterna. \w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w estaba|strong="H3427"\w* \w sentado|strong="H3427"\w* \w en|strong="H3588"\w* \w la|strong="H1931"\w* \w puerta|strong="H8179"\w* \w de|strong="H3588"\w* \w Benjamín|strong="H1144"\w*,  
\v 8 \w Ebed-melec|strong="H5663"\w* \w salió|strong="H3318"\w* del palacio \w real|strong="H4428"\w* y \w habló|strong="H1696"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*:  
\v 9 Oh \w rey|strong="H4428"\w*, \tl ʼadón\tl* mío, \w estos|strong="H3605"\w* \w varones|strong="H3588"\w* actuaron \w mal|strong="H7489"\w* \w en|strong="H3588"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3588"\w* \w hicieron|strong="H6213"\w* \w con|strong="H3588"\w* \w el|strong="H3588"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w*, \w al|strong="H4428"\w* \w cual|strong="H3588"\w* echaron \w en|strong="H3588"\w* \w la|strong="H3588"\w* cisterna, \w donde|strong="H8478"\w* \w morirá|strong="H4191"\w* \w de|strong="H3588"\w* \w hambre|strong="H7458"\w*, \w porque|strong="H3588"\w* ya \w no|strong="H6213"\w* \w hay|strong="H5750"\w* \w pan|strong="H3899"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w*.   
\p
\v 10 Entonces \w el|strong="H5030"\w* \w rey|strong="H4428"\w* \w ordenó|strong="H6680"\w* \w al|strong="H4480"\w* \w etíope|strong="H3569"\w* \w Ebed-melec|strong="H5663"\w*: \w Toma|strong="H3947"\w* 30 hombres contigo, y saquen \w al|strong="H4480"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w de|strong="H4480"\w* la cisterna \w antes|strong="H2962"\w* \w que|strong="H4480"\w* \w muera|strong="H4191"\w*.   
\p
\v 11 \w Ebed-melec|strong="H5663"\w* \w tomó|strong="H3947"\w* \w en|strong="H8478"\w* su \w poder|strong="H3027"\w* \w a|strong="H3068"\w* los hombres, entró \w en|strong="H8478"\w* el palacio \w real|strong="H4428"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* la tesorería. \w De|strong="H8478"\w* \w allí|strong="H8033"\w* \w tomó|strong="H3947"\w* \w trapos|strong="H5499"\w* \w viejos|strong="H1094"\w* y ropas raídas y andrajosas, y \w junto|strong="H3027"\w* con unas \w sogas|strong="H2256"\w*, los \w bajó|strong="H8478"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w en|strong="H8478"\w* la cisterna.  
\v 12 \w El|strong="H6213"\w* \w etíope|strong="H3569"\w* \w Ebed-melec|strong="H5663"\w* dijo \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*: \w Ponte|strong="H7760"\w* \w ahora|strong="H4994"\w* esos \w trapos|strong="H5499"\w* \w viejos|strong="H1094"\w*, ropas raídas y andrajosas \w bajo|strong="H8478"\w* los sobacos, \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* las \w sogas|strong="H2256"\w*.  
\p \w Y|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w lo|strong="H6213"\w* \w hizo|strong="H6213"\w* \w así|strong="H3651"\w*.   
\p
\v 13 \w De|strong="H4480"\w* este modo \w sacaron|strong="H4900"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w con|strong="H4480"\w* \w sogas|strong="H2256"\w* y lo \w subieron|strong="H5927"\w* \w de|strong="H4480"\w* la cisterna. \w Y|strong="H3068"\w* \w Jeremías|strong="H3414"\w* permaneció \w en|strong="H4480"\w* \w el|strong="H3427"\w* \w patio|strong="H2691"\w* \w de|strong="H4480"\w* la guardia.   
\s1 Una consulta del rey a Jeremías  
\p
\v 14 Después \w el|strong="H5030"\w* \w rey|strong="H4428"\w* Sedequías llamó \w al|strong="H4480"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* ante su presencia, \w en|strong="H4480"\w* la \w tercera|strong="H7992"\w* \w entrada|strong="H3996"\w* \w de|strong="H4480"\w* la \w Casa|strong="H1004"\w* \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \w Y|strong="H3068"\w* \w el|strong="H5030"\w* \w rey|strong="H4428"\w* dijo \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*: \w Te|strong="H4480"\w* haré una \w pregunta|strong="H7592"\w*. No \w me|strong="H4480"\w* \w encubras|strong="H3582"\w* alguna \w cosa|strong="H1697"\w*.   
\p
\v 15 \w Y|strong="H3068"\w* \w Jeremías|strong="H3414"\w* contestó \w a|strong="H3068"\w* Sedequías: \w Si|strong="H3588"\w* \w te|strong="H3588"\w* \w lo|strong="H3808"\w* digo, \w ciertamente|strong="H3588"\w* ¿\w no|strong="H3808"\w* \w me|strong="H3588"\w* matarás? \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w te|strong="H3588"\w* \w aconsejo|strong="H3289"\w*, \w no|strong="H3808"\w* \w me|strong="H3588"\w* escucharás.   
\p
\v 16 Pero \w el|strong="H6213"\w* \w rey|strong="H4428"\w* Sedequías \w juró|strong="H7650"\w* en secreto \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*: \w Vive|strong="H2416"\w* \nd \+w Yavé|strong="H3068"\+w*,\nd* \w Quien|strong="H6213"\w* nos \w da|strong="H5414"\w* \w la|strong="H2063"\w* \w vida|strong="H5315"\w*, \w que|strong="H3027"\w* \w ciertamente|strong="H4191"\w* \w no|strong="H6213"\w* \w te|strong="H5315"\w* \w mataré|strong="H4191"\w*, ni \w te|strong="H5315"\w* \w entregaré|strong="H5414"\w* en \w mano|strong="H3027"\w* \w de|strong="H5414"\w* \w estos|strong="H2063"\w* hombres \w que|strong="H3027"\w* \w buscan|strong="H1245"\w* \w tu|strong="H6213"\w* \w vida|strong="H5315"\w*.   
\p
\v 17 Entonces \w Jeremías|strong="H3414"\w* dijo \w a|strong="H3068"\w* Sedequías: \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w de|strong="H8269"\w* las huestes, \nd ʼElohim\nd* \w de|strong="H8269"\w* \w Israel|strong="H3478"\w*, dice: \wj \+w Si|strong="H3808"\+w* tú \+w en|strong="H3318"\+w* verdad \+w sales|strong="H3318"\+w* \+w a|strong="H3068"\+w* los oficiales del \+w rey|strong="H4428"\+w* \+w de|strong="H8269"\+w* Babilonia, \+w vivirás|strong="H2421"\+w*, \+w y|strong="H3541"\+w* \+w esta|strong="H2063"\+w* \+w ciudad|strong="H5892"\+w* \+w no|strong="H3808"\+w* \+w será|strong="H3808"\+w* \+w quemada|strong="H8313"\+w*. \+w Vivirás|strong="H2421"\+w*, tú \+w y|strong="H3541"\+w* tu \+w casa|strong="H1004"\+w*.\wj*  
\v 18 \wj Pero \+w si|strong="H3808"\+w* \+w no|strong="H3808"\+w* te entregas \+w a|strong="H3068"\+w* los oficiales del \+w rey|strong="H4428"\+w* \+w de|strong="H8269"\+w* Babilonia, \+w esta|strong="H2063"\+w* \+w ciudad|strong="H5892"\+w* \+w será|strong="H3808"\+w* \+w entregada|strong="H5414"\+w* \+w en|strong="H3318"\+w* \+w la|strong="H2063"\+w* \+w mano|strong="H3027"\+w* \+w de|strong="H8269"\+w* los \+w caldeos|strong="H3778"\+w*. \+w La|strong="H2063"\+w* incendiarán, y tú \+w no|strong="H3808"\+w* \+w escaparás|strong="H4422"\+w* \+w de|strong="H8269"\+w* sus \+w manos|strong="H3027"\+w*.\wj*   
\p
\v 19 \w El|strong="H5307"\w* \w rey|strong="H4428"\w* Sedequías dijo \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*: Tengo temor \w de|strong="H5414"\w* los \w judíos|strong="H3064"\w* \w que|strong="H6435"\w* desertaron \w a|strong="H3068"\w* los \w caldeos|strong="H3778"\w*. Yo podría ser \w entregado|strong="H5414"\w* \w a|strong="H3068"\w* \w ellos|strong="H3027"\w*, y \w ellos|strong="H3027"\w* me maltratarían.   
\p
\v 20 Pero \w Jeremías|strong="H3414"\w* le respondió: \w No|strong="H3808"\w* \w te|strong="H5315"\w* entregarán. \w Oye|strong="H8085"\w* \w ahora|strong="H4994"\w* la \w voz|strong="H6963"\w* \w de|strong="H5414"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* en \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w te|strong="H5315"\w* digo, y \w te|strong="H5315"\w* irá \w bien|strong="H3190"\w* y \w vivirás|strong="H2421"\w*.  
\v 21 Pero si rehúsas entregarte, \w ésta|strong="H2088"\w* \w es|strong="H2088"\w* la \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* me \w mostró|strong="H7200"\w*:  
\v 22 \wj \+w Ciertamente|strong="H2009"\+w* \+w todas|strong="H3605"\+w* las mujeres \+w que|strong="H3605"\+w* quedan \+w en|strong="H3318"\+w* \+w el|strong="H3605"\+w* palacio del \+w rey|strong="H4428"\+w* \+w de|strong="H8269"\+w* \+w Judá|strong="H3063"\+w* serán sacadas \+w a|strong="H3068"\+w* \+w los|strong="H3605"\+w* oficiales del \+w rey|strong="H4428"\+w* \+w de|strong="H8269"\+w* Babilonia. \+w Ellas|strong="H2007"\+w* mismas dirán: Tus amigos te engañaron y \+w prevalecieron|strong="H3201"\+w* contra ti. Hundieron tus \+w pies|strong="H7272"\+w* \+w en|strong="H3318"\+w* \+w el|strong="H3605"\+w* lodo y se volvieron atrás.\wj*  
\v 23 \wj \+w Sacarán|strong="H3318"\+w*, \+w pues|strong="H3588"\+w*, \+w a|strong="H3068"\+w* \+w todas|strong="H3605"\+w* tus mujeres \+w y|strong="H3588"\+w* \+w a|strong="H3068"\+w* tus \+w hijos|strong="H1121"\+w* \+w para|strong="H3588"\+w* \+w los|strong="H1121"\+w* \+w caldeos|strong="H3778"\+w*. Tú \+w no|strong="H3808"\+w* \+w escaparás|strong="H4422"\+w* \+w de|strong="H3588"\+w* sus \+w manos|strong="H3027"\+w*, \+w sino|strong="H3588"\+w* serás apresado \+w por|strong="H3588"\+w* \+w la|strong="H3588"\+w* \+w mano|strong="H3027"\+w* del \+w rey|strong="H4428"\+w* \+w de|strong="H3588"\+w* Babilonia, \+w y|strong="H3588"\+w* \+w esta|strong="H2063"\+w* \+w ciudad|strong="H5892"\+w* \+w será|strong="H3808"\+w* destruida \+w con|strong="H3588"\+w* fuego.\wj*   
\p
\v 24 Entonces Sedequías dijo \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*: \w Que|strong="H3808"\w* \w nadie|strong="H3808"\w* \w sepa|strong="H3045"\w* estas \w Palabras|strong="H1697"\w*, y tú \w no|strong="H3808"\w* \w morirás|strong="H4191"\w*.  
\v 25 \w Si|strong="H3588"\w* \w los|strong="H3588"\w* magistrados \w oyen|strong="H8085"\w* \w que|strong="H3588"\w* \w yo|strong="H4480"\w* \w hablé|strong="H1696"\w* contigo, \w y|strong="H3588"\w* acuden \w a|strong="H3068"\w* \w ti|strong="H4480"\w* \w y|strong="H3588"\w* \w te|strong="H4480"\w* \w dicen|strong="H1696"\w*: \w Decláranos|strong="H5046"\w* \w ahora|strong="H4994"\w* \w lo|strong="H4100"\w* \w que|strong="H3588"\w* le \w dijiste|strong="H1696"\w* \w al|strong="H4480"\w* \w rey|strong="H4428"\w*, \w sin|strong="H3808"\w* ocultarnos \w nada|strong="H3808"\w*, \w no|strong="H3808"\w* \w te|strong="H4480"\w* \w mataremos|strong="H4191"\w*, \w y|strong="H3588"\w* también \w qué|strong="H3588"\w* \w te|strong="H4480"\w* respondió \w el|strong="H3588"\w* \w rey|strong="H4428"\w*,  
\v 26 tú les dirás: \w Supliqué|strong="H5307"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w que|strong="H1115"\w* \w no|strong="H1115"\w* me devolviera \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* Jonatán para \w morir|strong="H4191"\w* \w allá|strong="H8033"\w*.  
\v 27 \w En|strong="H4480"\w* efecto, luego \w todos|strong="H3605"\w* \w los|strong="H1992"\w* magistrados fueron \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*, \w y|strong="H3588"\w* le \w preguntaron|strong="H7592"\w*, \w y|strong="H3588"\w* \w él|strong="H3588"\w* \w les|strong="H1992"\w* respondió \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* le \w mandó|strong="H6680"\w*. \w Ellos|strong="H1992"\w* dejaron \w de|strong="H4480"\w* hablarle, \w de|strong="H4480"\w* modo \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w asunto|strong="H1697"\w* \w no|strong="H3808"\w* \w fue|strong="H3808"\w* escuchado.   
\p
\v 28 \w Jeremías|strong="H3414"\w* permaneció \w en|strong="H5704"\w* \w el|strong="H3427"\w* \w patio|strong="H2691"\w* \w de|strong="H5704"\w* la guardia \w hasta|strong="H5704"\w* \w el|strong="H3427"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* Jerusalén \w fue|strong="H1961"\w* capturada.   
\c 39  
\s1 La caída de Jerusalén en manos de Nabucodonosor  
\p
\v 1 \w El|strong="H5921"\w* \w año|strong="H8141"\w* \w noveno|strong="H8671"\w* \w de|strong="H5921"\w* Sedequías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w el|strong="H5921"\w* \w mes|strong="H2320"\w* \w décimo|strong="H6224"\w*, \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, llegó \w con|strong="H5921"\w* \w todo|strong="H3605"\w* su \w ejército|strong="H2428"\w* \w contra|strong="H5921"\w* Jerusalén \w y|strong="H5921"\w* \w la|strong="H5921"\w* sitió.  
\v 2 El \w año|strong="H8141"\w* 11 de Sedequías, el \w mes|strong="H2320"\w* \w cuarto|strong="H7243"\w*, el día \w nueve|strong="H8672"\w* del \w mes|strong="H2320"\w*, una brecha fue \w abierta|strong="H1234"\w* en el muro de la \w ciudad|strong="H5892"\w*.  
\v 3 \w Todos|strong="H3605"\w* \w los|strong="H3427"\w* oficiales del \w rey|strong="H4428"\w* \w de|strong="H8269"\w* Babilonia \w pasaron|strong="H3427"\w* \w por|strong="H4428"\w* \w ella|strong="H3605"\w* y se \w sentaron|strong="H3427"\w* \w en|strong="H8432"\w* \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w de|strong="H8269"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w*. Eran \w Nergal-sarezer|strong="H5371"\w*, \w Samgar-nebo|strong="H5562"\w*, Sarsequim, \w el|strong="H3605"\w* \tl \+w Rabsaris|strong="H7249"\+w*\tl*, \w Nergal-sarezer|strong="H5371"\w*, \w el|strong="H3605"\w* \tl \+w Rabmag|strong="H7248"\+w*\tl* y \w todos|strong="H3605"\w* \w los|strong="H3427"\w* demás oficiales del \w rey|strong="H4428"\w* \w de|strong="H8269"\w* Babilonia.  
\v 4 \w Al|strong="H4480"\w* verlos Sedequías, \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*, y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* guerreros, \w huyeron|strong="H1272"\w* \w de|strong="H4480"\w* \w noche|strong="H3915"\w*. Abandonaron \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w por|strong="H4480"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w* \w del|strong="H4480"\w* \w huerto|strong="H1588"\w* \w del|strong="H4480"\w* \w rey|strong="H4428"\w*, \w por|strong="H4480"\w* \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w que|strong="H4480"\w* \w había|strong="H1961"\w* \w entre|strong="H4480"\w* \w los|strong="H3605"\w* dos \w muros|strong="H2346"\w*. \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w salió|strong="H3318"\w* \w por|strong="H4480"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w* \w del|strong="H4480"\w* Arabá.   
\p
\v 5 Pero el \w ejército|strong="H2428"\w* de \w los|strong="H7291"\w* \w caldeos|strong="H3778"\w* \w los|strong="H7291"\w* \w persiguió|strong="H7291"\w*, y \w alcanzaron|strong="H5381"\w* \w a|strong="H3068"\w* Sedequías en \w los|strong="H7291"\w* \w llanos|strong="H6160"\w* de \w Jericó|strong="H3405"\w*. Después de atraparlo, lo \w llevaron|strong="H3947"\w* adonde estaba \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* de Babilonia, \w a|strong="H3068"\w* Ribla, en tierra de Hamat. Allí lo sentenció.  
\v 6 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Babilonia \w degolló|strong="H7819"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Sedequías en presencia \w de|strong="H1121"\w* éste en Ribla. \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Babilonia mandó degollar también \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* nobles \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.  
\v 7 \w Le|strong="H5869"\w* sacó los \w ojos|strong="H5869"\w* al rey Sedequías y lo aprisionó con grillos \w de|strong="H5869"\w* bronce para llevarlo \w a|strong="H3068"\w* Babilonia.   
\p
\v 8 Los \w caldeos|strong="H3778"\w* destruyeron con fuego la \w casa|strong="H1004"\w* del \w rey|strong="H4428"\w* y las \w casas|strong="H1004"\w* del \w pueblo|strong="H5971"\w*, y derribaron los \w muros|strong="H2346"\w* \w de|strong="H5971"\w* Jerusalén.  
\v 9 \w Al|strong="H5921"\w* \w resto|strong="H3499"\w* \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5921"\w* \w quedó|strong="H7604"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* pasaron \w a|strong="H3068"\w* \w ellos|strong="H5921"\w*, \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* guardia, \w los|strong="H5921"\w* llevó \w cautivos|strong="H1540"\w* \w a|strong="H3068"\w* Babilonia, \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* remanente \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w*.  
\v 10 Pero \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H4480"\w* \w la|strong="H1931"\w* guardia, ordenó \w que|strong="H4480"\w* \w los|strong="H1931"\w* \w más|strong="H4480"\w* \w pobres|strong="H1800"\w* \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w*, \w los|strong="H1931"\w* \w que|strong="H4480"\w* \w nada|strong="H3972"\w* tenían, permanecieran \w en|strong="H4480"\w* tierra \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*, y \w les|strong="H3972"\w* \w dio|strong="H5414"\w* viñedos y heredades.   
\s1 Provisión para el profeta Jeremías  
\p
\v 11 \w En|strong="H5921"\w* \w cuanto|strong="H5921"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*, \w Nabucodonosor|strong="H5019"\w* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* guardia:  
\v 12 \w Tómalo|strong="H3947"\w* \w y|strong="H3588"\w* vela \w por|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H3588"\w* \w no|strong="H6213"\w* \w le|strong="H5921"\w* \w hagas|strong="H6213"\w* algún daño, \w sino|strong="H3588"\w* trátalo \w tal|strong="H3651"\w* \w como|strong="H3588"\w* \w él|strong="H5921"\w* \w te|strong="H5869"\w* \w diga|strong="H1696"\w*.   
\p
\v 13 Entonces \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* de \w la|strong="H3605"\w* guardia, y Nabusazbán, \w el|strong="H3605"\w* \tl \+w Rabsaris|strong="H7249"\+w*\tl*, \w Nergal-sarezer|strong="H5371"\w*, \w el|strong="H3605"\w* \tl \+w Rabmag|strong="H7248"\+w*\tl* y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* oficiales del \w rey|strong="H4428"\w* de Babilonia,  
\v 14 \w enviaron|strong="H7971"\w* \w a|strong="H3068"\w* sacar \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* del \w patio|strong="H2691"\w* \w de|strong="H1121"\w* la guardia. Lo entregaron \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahicam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Safán, \w para|strong="H5414"\w* \w que|strong="H5971"\w* lo \w llevara|strong="H3947"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w*. Vivió \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del \w pueblo|strong="H5971"\w*.   
\p
\v 15 \w Cuando|strong="H1961"\w* \w estaba|strong="H1961"\w* \w preso|strong="H6113"\w* en el \w patio|strong="H2691"\w* \w de|strong="H1697"\w* la guardia, la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*:  
\v 16 \wj \+w Vé|strong="H1980"\+w*, \+w habla|strong="H1697"\+w* al \+w etíope|strong="H3569"\+w* \+w Ebed-melec|strong="H5663"\+w*: \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w de|strong="H6440"\+w* las huestes, \+w el|strong="H1931"\+w* \+nd ʼElohim\+nd* \+w de|strong="H6440"\+w* \+w Israel|strong="H3478"\+w*, \+w dice|strong="H1697"\+w*: \+w Mira|strong="H2005"\+w*, Yo traigo mis \+w Palabras|strong="H1697"\+w* \+w sobre|strong="H1961"\+w* \+w esta|strong="H2063"\+w* \+w ciudad|strong="H5892"\+w* \+w para|strong="H1961"\+w* \+w mal|strong="H7451"\+w* \+w y|strong="H3541"\+w* \+w no|strong="H3808"\+w* \+w para|strong="H1961"\+w* \+w bien|strong="H2896"\+w*. \+w Se|strong="H1961"\+w* cumplirá \+w aquel|strong="H1931"\+w* \+w día|strong="H3117"\+w* en tu \+w presencia|strong="H6440"\+w*.\wj*  
\v 17 \wj Pero en \+w aquel|strong="H1931"\+w* \+w día|strong="H3117"\+w* Yo te \+w libraré|strong="H5337"\+w*, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \wj y \+w no|strong="H3808"\+w* serás \+w entregado|strong="H5414"\+w* en \+w manos|strong="H3027"\+w* \+w de|strong="H6440"\+w* aquellos \+w a|strong="H3068"\+w* quienes tú \+w temes|strong="H3016"\+w*.\wj*  
\v 18 \wj \+w Ciertamente|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* \+w te|strong="H3588"\+w* libraré, \+w y|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w caerás|strong="H5307"\+w* \+w a|strong="H3068"\+w* \+w espada|strong="H2719"\+w*, \+w sino|strong="H3588"\+w* tu \+w vida|strong="H5315"\+w* \+w te|strong="H3588"\+w* \+w será|strong="H1961"\+w* \+w como|strong="H3588"\+w* botín, \+w porque|strong="H3588"\+w* tuviste confianza \+w en|strong="H3588"\+w* \+w Mí|strong="H1961"\+w*,\wj* \w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\c 40  
\s1 Diversas circunstancias del remanente  
\p
\v 1 \w Palabra|strong="H1697"\w* \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H4480"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*, \w después|strong="H1961"\w* \w que|strong="H4480"\w* \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H4480"\w* \w la|strong="H1931"\w* guardia, \w lo|strong="H1931"\w* \w envió|strong="H7971"\w* \w desde|strong="H4480"\w* \w Ramá|strong="H7414"\w*, \w cuando|strong="H1961"\w* \w lo|strong="H1931"\w* encontró encadenado \w entre|strong="H8432"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w cautivos|strong="H1540"\w* \w de|strong="H4480"\w* Jerusalén y \w de|strong="H4480"\w* \w Judá|strong="H3063"\w* \w que|strong="H4480"\w* iban deportados \w a|strong="H3068"\w* Babilonia.  
\v 2 El \w capitán|strong="H7227"\w* \w de|strong="H7451"\w* \w la|strong="H2063"\w* guardia apartó \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* y le \w dijo|strong="H1696"\w*: \nd \+w Yavé|strong="H3068"\+w*\nd* tu \nd ʼElohim\nd* predijo \w este|strong="H2088"\w* \w mal|strong="H7451"\w* contra \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*.  
\v 3 \nd \+w Yavé|strong="H3068"\+w*\nd* \w lo|strong="H1697"\w* trajo \w y|strong="H3588"\w* \w lo|strong="H1697"\w* \w hizo|strong="H6213"\w* según \w lo|strong="H1697"\w* \w dijo|strong="H1696"\w*, \w porque|strong="H3588"\w* \w pecaron|strong="H2398"\w* \w contra|strong="H1961"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w oyeron|strong="H8085"\w* \w su|strong="H3588"\w* \w voz|strong="H6963"\w*. \w Por|strong="H3588"\w* eso les \w vino|strong="H1961"\w* \w esto|strong="H2088"\w* \w a|strong="H3068"\w* ustedes.  
\v 4 \w Ahora|strong="H6258"\w*, \w mira|strong="H7200"\w*, \w hoy|strong="H3117"\w* \w te|strong="H5869"\w* libro \w de|strong="H4480"\w* \w las|strong="H5921"\w* cadenas \w que|strong="H4480"\w* \w están|strong="H2009"\w* \w en|strong="H5921"\w* tus \w manos|strong="H3027"\w*. \w Si|strong="H6440"\w* \w te|strong="H5869"\w* parece \w bien|strong="H2896"\w* \w ir|strong="H3212"\w* conmigo \w a|strong="H3068"\w* Babilonia, \w ven|strong="H3212"\w*, \w y|strong="H5921"\w* \w yo|strong="H4480"\w* velaré \w por|strong="H5921"\w* \w ti|strong="H5921"\w*. \w Si|strong="H6440"\w* \w no|strong="H2308"\w* \w te|strong="H5869"\w* parece \w bien|strong="H2896"\w* \w ir|strong="H3212"\w* conmigo \w a|strong="H3068"\w* Babilonia, permanece \w aquí|strong="H2009"\w*. \w Mira|strong="H7200"\w*, \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra \w está|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* \w ti|strong="H5921"\w*. \w Vé|strong="H3212"\w* adonde \w te|strong="H5869"\w* \w parezca|strong="H7200"\w* \w mejor|strong="H2896"\w* \w y|strong="H5921"\w* conveniente.  
\v 5 \w Como|strong="H5750"\w* Jeremías \w aún|strong="H5750"\w* \w no|strong="H3808"\w* regresaba, \add le dijo\add*: Regresa hacia \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5750"\w* Ahicam, \w hijo|strong="H1121"\w* \w de|strong="H5750"\w* Safán, \w al|strong="H4428"\w* cual \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w de|strong="H5750"\w* Babilonia \w dio|strong="H5414"\w* autoridad sobre \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5750"\w* \w Judá|strong="H3063"\w*. Vive con \w él|strong="H3605"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del \w pueblo|strong="H5971"\w*, \w o|strong="H3068"\w* \w vé|strong="H3068"\w* adonde \w te|strong="H5869"\w* parezca mejor.  
\p \w El|strong="H3605"\w* \w capitán|strong="H7227"\w* \w de|strong="H5750"\w* \w la|strong="H3605"\w* guardia \w le|strong="H5869"\w* \w dio|strong="H5414"\w* provisiones y un presente, y \w lo|strong="H3808"\w* \w despidió|strong="H7971"\w*.  
\v 6 Entonces \w Jeremías|strong="H3414"\w* fue \w a|strong="H3068"\w* estar con \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahicam, \w en|strong="H8432"\w* Mizpa, y vivió con \w él|strong="H1121"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w quedó|strong="H7604"\w* \w en|strong="H8432"\w* la tierra.   
\p
\v 7 Ahora \w bien|strong="H3588"\w*, \w todos|strong="H3605"\w* \w los|strong="H1992"\w* comandantes del \w ejército|strong="H2428"\w* \w que|strong="H3588"\w* estaban \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w campo|strong="H7704"\w* \w con|strong="H3588"\w* \w sus|strong="H1992"\w* \w hombres|strong="H1121"\w*, \w oyeron|strong="H8085"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia dio autoridad sobre \w la|strong="H3588"\w* tierra \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Ahicam, \w y|strong="H3588"\w* \w que|strong="H3588"\w* le \w había|strong="H3588"\w* encomendado \w a|strong="H3068"\w* \w hombres|strong="H1121"\w*, mujeres \w y|strong="H3588"\w* \w niños|strong="H2945"\w* \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w más|strong="H3588"\w* pobres \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w que|strong="H3588"\w* \w no|strong="H3808"\w* fueron deportados \w a|strong="H3068"\w* Babilonia.  
\v 8 Entonces fueron \w a|strong="H3068"\w* visitar \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w* en Mizpa: \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Netanías, \w Johanán|strong="H3110"\w* y Jonatán, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Carea|strong="H7143"\w*, \w Seraías|strong="H8304"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Tanhumet, \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Efai \w netofatita|strong="H5200"\w*, y Jezanías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* un maacateo, \w ellos|strong="H1992"\w* y \w sus|strong="H1992"\w* \w hombres|strong="H1121"\w*.  
\v 9 \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahicam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Safán, les \w juró|strong="H7650"\w* \w a|strong="H3068"\w* ellos y \w a|strong="H3068"\w* sus \w hombres|strong="H1121"\w*: No tengan \w temor|strong="H3372"\w* \w de|strong="H1121"\w* \w servir|strong="H5647"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w caldeos|strong="H3778"\w*. Vivan en la tierra, obedezcan \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Babilonia y tendrán \w bien|strong="H3190"\w*.  
\v 10 Miren, yo tengo que vivir \w en|strong="H5975"\w* \w Mizpa|strong="H4709"\w*, \w a|strong="H3068"\w* disposición \w de|strong="H6440"\w* \w los|strong="H3427"\w* \w caldeos|strong="H3778"\w* que vendrán \w a|strong="H3068"\w* inspeccionarnos. Tomen \w el|strong="H3427"\w* \w vino|strong="H3196"\w*, \w los|strong="H3427"\w* \w frutos|strong="H7019"\w* \w de|strong="H6440"\w* \w verano|strong="H7019"\w* y \w el|strong="H3427"\w* \w aceite|strong="H8081"\w*. Pónganlos \w en|strong="H5975"\w* sus depósitos. Quédense \w en|strong="H5975"\w* sus \w ciudades|strong="H5892"\w* donde les corresponda ocupar.   
\p
\v 11 \w También|strong="H1571"\w* \w los|strong="H1121"\w* otros \w judíos|strong="H3064"\w* \w que|strong="H3588"\w* vivían \w en|strong="H5921"\w* \w Moab|strong="H4124"\w* \w entre|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón, \w en|strong="H5921"\w* Edom \w y|strong="H1571"\w* \w los|strong="H1121"\w* \w que|strong="H3588"\w* estaban \w en|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* tierras, \w cuando|strong="H3588"\w* \w oyeron|strong="H8085"\w* \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia \w dejó|strong="H5414"\w* \w a|strong="H3068"\w* \w algunos|strong="H7611"\w* \w en|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H1571"\w* \w que|strong="H3588"\w* \w dieron|strong="H5414"\w* autoridad \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Ahicam, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Safán, \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*,  
\v 12 \w todos|strong="H3605"\w* \w estos|strong="H3605"\w* \w judíos|strong="H3064"\w* regresaron de \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w lugares|strong="H4725"\w* adonde fueron echados. Llegaron \w a|strong="H3068"\w* tierra de \w Judá|strong="H3063"\w* \w a|strong="H3068"\w* visitar \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w* en Mizpa y recogieron \w vino|strong="H3196"\w* y abundantes \w frutos|strong="H7019"\w*.   
\s1 Conspiración contra Gedalías  
\p
\v 13 \w Johanán|strong="H3110"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Carea|strong="H7143"\w*, y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* comandantes \w que|strong="H1121"\w* estaban en \w el|strong="H3605"\w* \w campo|strong="H7704"\w* llegaron \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w* en Mizpa,  
\v 14 \w y|strong="H3588"\w* le dijeron: ¿\w No|strong="H3808"\w* \w sabes|strong="H3045"\w* \w que|strong="H3588"\w* Baalis, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Amón, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Netanías, \w para|strong="H3588"\w* \w matarte|strong="H5315"\w*?  
\p \w Pero|strong="H3588"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Ahicam, \w no|strong="H3808"\w* les creyó.  
\v 15 Entonces \w Johanán|strong="H3110"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Carea|strong="H7143"\w*, habló secretamente \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w* \w en|strong="H3212"\w* \w Mizpa|strong="H4709"\w* y le dijo: \w Yo|strong="H5315"\w* \w iré|strong="H3212"\w* \w ahora|strong="H4994"\w* y mataré \w a|strong="H3068"\w* \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Netanías, y \w nadie|strong="H3808"\w* \w lo|strong="H4100"\w* \w sabrá|strong="H3045"\w*. ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w te|strong="H5315"\w* \w va|strong="H3068"\w* \w a|strong="H3068"\w* matar para \w que|strong="H4100"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* judíos \w que|strong="H4100"\w* \w se|strong="H3045"\w* reunieron contigo \w se|strong="H3045"\w* dispersen, y perezca \w el|strong="H3605"\w* \w resto|strong="H7611"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*?   
\p
\v 16 \w Pero|strong="H3588"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Ahicam, \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* \w Johanán|strong="H3110"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Carea|strong="H7143"\w*: \w No|strong="H6213"\w* \w hagas|strong="H6213"\w* \w esto|strong="H2088"\w*, \w porque|strong="H3588"\w* \w es|strong="H2088"\w* \w falso|strong="H8267"\w* \w lo|strong="H1697"\w* \w que|strong="H3588"\w* \w tú|strong="H6213"\w* \w dices|strong="H1696"\w* \w de|strong="H3588"\w* \w Ismael|strong="H3458"\w*.   
\c 41  
\p
\v 1 Pero \w el|strong="H1121"\w* \w mes|strong="H2320"\w* \w séptimo|strong="H7637"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1121"\w* \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Netanías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Elisama, \w de|strong="H1121"\w* la \w descendencia|strong="H2233"\w* \w real|strong="H4428"\w*, y algunos oficiales del \w rey|strong="H4428"\w* y \w diez|strong="H6235"\w* \w hombres|strong="H1121"\w* con \w él|strong="H1121"\w*, llegaron \w a|strong="H3068"\w* visitar \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahicam, en \w Mizpa|strong="H4709"\w*. \w Allí|strong="H8033"\w* compartieron \w juntos|strong="H3162"\w* \w el|strong="H1121"\w* \w pan|strong="H3899"\w*.  
\v 2 Pero \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Netanías, y \w los|strong="H1121"\w* \w diez|strong="H6235"\w* \w hombres|strong="H1121"\w* \w que|strong="H1121"\w* \w estaban|strong="H1961"\w* con \w él|strong="H1121"\w*, \w se|strong="H1961"\w* \w levantaron|strong="H6965"\w* \w e|strong="H3068"\w* \w hirieron|strong="H5221"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahicam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Safán. \w Mataron|strong="H5221"\w* \w a|strong="H3068"\w* aquél \w a|strong="H3068"\w* quien \w el|strong="H1121"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Babilonia autorizó \w para|strong="H1961"\w* gobernar la tierra.  
\v 3 \w Ismael|strong="H3458"\w* también \w mató|strong="H5221"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w judíos|strong="H3064"\w* \w que|strong="H1961"\w* \w estaban|strong="H1961"\w* con \w Gedalías|strong="H1436"\w* \w en|strong="H5221"\w* \w Mizpa|strong="H4709"\w*, junto con \w todos|strong="H3605"\w* \w los|strong="H3605"\w* guerreros \w caldeos|strong="H3778"\w* \w que|strong="H1961"\w* \w estaban|strong="H1961"\w* \w allí|strong="H8033"\w*.   
\p
\v 4 Un \w día|strong="H3117"\w* \w después|strong="H1961"\w* de asesinar \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w*, \w cuando|strong="H3117"\w* \w aún|strong="H3808"\w* \w nadie|strong="H3808"\w* \w lo|strong="H3808"\w* \w sabía|strong="H3045"\w*,  
\v 5 sucedió \w que|strong="H7927"\w* llegaron ciertos hombres de Siquem, de \w Silo|strong="H7887"\w* y de \w Samaria|strong="H8111"\w*, unos 80 hombres, con sus barbas raídas, sus ropas rasgadas y sus cuerpos sajados, \w que|strong="H7927"\w* traían consigo ofrendas \w e|strong="H3068"\w* \w incienso|strong="H3828"\w* para presentarlos en la \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 6 \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Netanías, les \w salió|strong="H3318"\w* \w al|strong="H4480"\w* encuentro \w desde|strong="H4480"\w* \w Mizpa|strong="H4709"\w*, y \w lloraba|strong="H1058"\w* mientras caminaba, hasta \w cuando|strong="H1961"\w* \w los|strong="H1121"\w* encontró, y les dijo: Vengan \w a|strong="H3068"\w* ver \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Ahicam.  
\v 7 Pero al llegar \w ellos|strong="H1931"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w*, \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Netanías, \w los|strong="H1121"\w* \w degolló|strong="H7819"\w*, y apoyado por \w sus|strong="H1931"\w* \w hombres|strong="H1121"\w*, \w los|strong="H1121"\w* echó \w dentro|strong="H8432"\w* \w de|strong="H1121"\w* una cisterna.  
\v 8 \w Entre|strong="H8432"\w* aquéllos fueron hallados \w diez|strong="H6235"\w* hombres \w que|strong="H3588"\w* dijeron \w a|strong="H3068"\w* \w Ismael|strong="H3458"\w*: \w No|strong="H3808"\w* nos \w mates|strong="H4191"\w*, \w porque|strong="H3588"\w* \w tenemos|strong="H3426"\w* \w en|strong="H8432"\w* \w el|strong="H3588"\w* \w campo|strong="H7704"\w* \w tesoros|strong="H4301"\w* \w de|strong="H3588"\w* \w trigo|strong="H2406"\w*, \w cebada|strong="H8184"\w*, \w aceite|strong="H8081"\w* \w y|strong="H3588"\w* \w miel|strong="H1706"\w*.  
\p \w Y|strong="H3068"\w* desistió \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H3588"\w* asesinó \w como|strong="H3588"\w* \w a|strong="H3068"\w* sus hermanos.  
\v 9 \w La|strong="H1931"\w* cisterna \w donde|strong="H8033"\w* \w Ismael|strong="H3458"\w* \w echó|strong="H7993"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* cadáveres \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w que|strong="H1931"\w* asesinó \w junto|strong="H3027"\w* con \w Gedalías|strong="H1436"\w*, \w era|strong="H1931"\w* \w la|strong="H1931"\w* \w misma|strong="H1931"\w* \w que|strong="H1931"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* Asa \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* \w Baasa|strong="H1201"\w*, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*. \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Netanías, \w la|strong="H1931"\w* \w llenó|strong="H4390"\w* \w de|strong="H6440"\w* cadáveres.  
\v 10 Después \w Ismael|strong="H3458"\w* llevó \w cautivo|strong="H7617"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w resto|strong="H7611"\w* del \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* estaba \w en|strong="H3212"\w* \w Mizpa|strong="H4709"\w*, \w a|strong="H3068"\w* las \w hijas|strong="H1323"\w* del \w rey|strong="H4428"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* del \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w quedaron|strong="H7604"\w* \w en|strong="H3212"\w* \w Mizpa|strong="H4709"\w*, y \w que|strong="H5971"\w* \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* guardia, encomendó \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahicam. \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Netanías, \w los|strong="H1121"\w* llevó cautivos y procedió \w a|strong="H3068"\w* pasarse \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón.   
\p
\v 11 Pero como \w Johanán|strong="H3110"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Carea|strong="H7143"\w*, y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* oficiales \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w guerreros|strong="H6213"\w* \w que|strong="H1121"\w* estaban con \w él|strong="H3605"\w*, supieron \w de|strong="H1121"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w mal|strong="H7451"\w* \w que|strong="H1121"\w* \w hizo|strong="H6213"\w* \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Netanías,  
\v 12 \w tomaron|strong="H3947"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* y \w fueron|strong="H3212"\w* \w a|strong="H3068"\w* luchar \w contra|strong="H5973"\w* \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Netanías, \w a|strong="H3068"\w* \w quien|strong="H3605"\w* \w hallaron|strong="H4672"\w* \w junto|strong="H5973"\w* al \w gran|strong="H7227"\w* estanque \w de|strong="H5973"\w* \w Gabaón|strong="H1391"\w*.  
\v 13 \w Aconteció|strong="H1961"\w* \w que|strong="H5971"\w* \w cuando|strong="H1961"\w* \w los|strong="H1121"\w* del \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w estaban|strong="H1961"\w* con \w Ismael|strong="H3458"\w* divisaron \w a|strong="H3068"\w* \w Johanán|strong="H3110"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Carea|strong="H7143"\w*, \w junto|strong="H5971"\w* con \w los|strong="H1121"\w* oficiales \w de|strong="H1121"\w* \w los|strong="H1121"\w* guerreros, \w se|strong="H1961"\w* alegraron.  
\v 14 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H4480"\w* \w Ismael|strong="H3458"\w* llevó \w cautivo|strong="H7617"\w* \w desde|strong="H4480"\w* \w Mizpa|strong="H4709"\w* \w se|strong="H4480"\w* \w volvió|strong="H7725"\w* y regresó \w con|strong="H4480"\w* \w Johanán|strong="H3110"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Carea|strong="H7143"\w*.  
\v 15 Pero \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Netanías, \w escapó|strong="H4422"\w* \w de|strong="H6440"\w* \w Johanán|strong="H3110"\w* con \w ocho|strong="H8083"\w* \w hombres|strong="H1121"\w* y \w fue|strong="H3212"\w* \w a|strong="H3068"\w* estar con \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* Amón.   
\p
\v 16 \w Johanán|strong="H3110"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Carea|strong="H7143"\w*, y \w todos|strong="H3605"\w* sus oficiales \w con|strong="H4480"\w* \w él|strong="H3605"\w*, recogieron \w al|strong="H4480"\w* \w resto|strong="H7611"\w* \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w que|strong="H4480"\w* \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Netanías, apresó \w en|strong="H4480"\w* \w Mizpa|strong="H4709"\w*, después \w de|strong="H4480"\w* asesinar \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Ahicam, esto es, guerreros, mujeres, \w niños|strong="H2945"\w* y servidores \w del|strong="H4480"\w* palacio, liberados \w por|strong="H4480"\w* \w Johanán|strong="H3110"\w* \w en|strong="H4480"\w* \w Gabaón|strong="H1391"\w*.  
\v 17 Salieron y asentaron \w en|strong="H3212"\w* \w el|strong="H3427"\w* Mesón Quimam, que \w está|strong="H3427"\w* cerca de Belén, \w a|strong="H3068"\w* fin de proseguir \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*,  
\v 18 \w porque|strong="H3588"\w* \w temían|strong="H3372"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w caldeos|strong="H3778"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Netanías, asesinó \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Ahicam, \w a|strong="H3068"\w* quien \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia autorizó \w como|strong="H3588"\w* gobernador \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra.   
\c 42  
\s1 Consulta al profeta Jeremías  
\p
\v 1 \w Todos|strong="H3605"\w* \w los|strong="H1121"\w* comandantes \w de|strong="H5704"\w* \w los|strong="H1121"\w* guerreros, \w junto|strong="H5971"\w* \w con|strong="H5704"\w* \w Johanán|strong="H3110"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w Carea|strong="H7143"\w*, Jezanías, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* Osaías, \w y|strong="H5704"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w desde|strong="H5704"\w* \w el|strong="H3605"\w* \w menor|strong="H6996"\w* \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w mayor|strong="H1419"\w*, \w llegaron|strong="H5066"\w*  
\v 2 \w y|strong="H3588"\w* dijeron \w al|strong="H5704"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w*: Acepta \w ahora|strong="H4994"\w* nuestro \w ruego|strong="H8467"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti. \w Ora|strong="H6419"\w* \w por|strong="H3588"\w* \w nosotros|strong="H3605"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* tu \nd ʼElohim\nd* \w por|strong="H3588"\w* \w todo|strong="H3605"\w* \w este|strong="H2063"\w* remanente, \w porque|strong="H3588"\w* \w de|strong="H3588"\w* \w muchos|strong="H7235"\w* \w que|strong="H3588"\w* éramos, quedamos \w pocos|strong="H4592"\w*, \w como|strong="H3588"\w* nos \w ven|strong="H7200"\w* tus \w ojos|strong="H5869"\w*,  
\v 3 para \w que|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd* nos enseñe \w el|strong="H6213"\w* \w camino|strong="H1870"\w* \w por|strong="H1870"\w* donde debemos \w andar|strong="H3212"\w*, y \w lo|strong="H1697"\w* \w que|strong="H1697"\w* debemos \w hacer|strong="H6213"\w*.   
\p
\v 4 \w El|strong="H3605"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* les \w respondió|strong="H6030"\w*: \w Escuché|strong="H8085"\w*. Miren, voy \w a|strong="H3068"\w* orar \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd*, \w como|strong="H1961"\w* \w dijeron|strong="H1697"\w*, y \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* les \w responda|strong="H6030"\w*, les enseñaré. \w No|strong="H3808"\w* \w me|strong="H4480"\w* reservaré \w palabra|strong="H1697"\w*.   
\p
\v 5 \w Ellos|strong="H1992"\w* \w dijeron|strong="H1697"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*: \w Sea|strong="H1961"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w entre|strong="H3808"\w* \w nosotros|strong="H3605"\w* \w Testigo|strong="H5707"\w* fiel y verdadero. Juramos obrar conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w aquello|strong="H1697"\w* \w a|strong="H3068"\w* \w lo|strong="H1697"\w* cual \nd \+w Yavé|strong="H3068"\+w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd* te \w envíe|strong="H7971"\w* \w a|strong="H3068"\w* \w nosotros|strong="H3605"\w*.  
\v 6 Sea \w bueno|strong="H2896"\w*, sea \w malo|strong="H7451"\w*, \w obedeceremos|strong="H8085"\w* \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd*, al \w cual|strong="H3588"\w* \w te|strong="H3588"\w* \w enviamos|strong="H7971"\w*, \w para|strong="H4616"\w* \w que|strong="H3588"\w* estemos \w bien|strong="H2896"\w* \w cuando|strong="H3588"\w* obedezcamos \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd*.   
\p
\v 7 \w Después|strong="H1961"\w* \w de|strong="H1697"\w* \w diez|strong="H6235"\w* \w días|strong="H3117"\w* \w vino|strong="H1961"\w* la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*.  
\v 8 \w Llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Johanán|strong="H3110"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w Carea|strong="H7143"\w*, \w y|strong="H5704"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* comandantes \w de|strong="H5704"\w* \w los|strong="H1121"\w* guerreros \w que|strong="H5704"\w* \w estaban|strong="H5971"\w* \w con|strong="H5704"\w* \w él|strong="H3605"\w*, \w y|strong="H5704"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w desde|strong="H5704"\w* \w el|strong="H3605"\w* \w menor|strong="H6996"\w* \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w mayor|strong="H1419"\w*,  
\v 9 \w y|strong="H3541"\w* les dijo: \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* Quien \w me|strong="H3541"\w* \w enviaron|strong="H7971"\w* \w a|strong="H3068"\w* presentar sus ruegos \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Él|strong="H5307"\w*, dice:  
\v 10 \wj \+w Si|strong="H3588"\+w* permanecen \+w quietos|strong="H7725"\+w* \+w en|strong="H3588"\+w* \+w esta|strong="H2063"\+w* tierra, \+w Yo|strong="H3588"\+w* \+w los|strong="H3427"\+w* \+w edificaré|strong="H1129"\+w* \+w y|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w los|strong="H3427"\+w* \+w destruiré|strong="H2040"\+w*. \+w Los|strong="H3427"\+w* \+w plantaré|strong="H5193"\+w* \+w y|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w los|strong="H3427"\+w* \+w arrancaré|strong="H5428"\+w*, \+w porque|strong="H3588"\+w* \+w me|strong="H3588"\+w* pesa todo \+w el|strong="H3588"\+w* \+w mal|strong="H7451"\+w* \+w que|strong="H3588"\+w* les \+w hice|strong="H6213"\+w*.\wj*  
\v 11 \wj \+w No|strong="H3588"\+w* \+w teman|strong="H3372"\+w* \+w por|strong="H3588"\+w* \+w la|strong="H3588"\+w* \+w presencia|strong="H6440"\+w* \+w del|strong="H4480"\+w* \+w rey|strong="H4428"\+w* \+w de|strong="H4480"\+w* Babilonia, \+w a|strong="H3068"\+w* quien \+w temen|strong="H3372"\+w*. \+w No|strong="H3588"\+w* \+w teman|strong="H3372"\+w* \+w de|strong="H4480"\+w* \+w su|strong="H3588"\+w* \+w presencia|strong="H6440"\+w*, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \wj \+w porque|strong="H3588"\+w* \+w Yo|strong="H4480"\+w* estoy \+w con|strong="H4480"\+w* ustedes \+w para|strong="H3588"\+w* salvarlos \+w y|strong="H3588"\+w* librarlos \+w de|strong="H4480"\+w* \+w su|strong="H3588"\+w* \+w mano|strong="H3027"\+w*.\wj*  
\v 12 \wj Yo tendré \+w misericordia|strong="H7355"\+w* \+w de|strong="H5414"\+w* ustedes, y \+add el rey\+add* tendrá \+w misericordia|strong="H7355"\+w* \+w de|strong="H5414"\+w* ustedes y los regresará \+w a|strong="H3068"\+w* su tierra. \wj*   
\p
\v 13 Pero \w si|strong="H3808"\w* dicen: \w No|strong="H3808"\w* viviremos en \w esta|strong="H2063"\w* tierra, desobedecen \w la|strong="H2063"\w* \w voz|strong="H6963"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd*  
\v 14 \w y|strong="H3588"\w* dicen: \w No|strong="H3808"\w*, \w más|strong="H3588"\w* \w bien|strong="H3588"\w* entraremos \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w donde|strong="H8033"\w* \w no|strong="H3808"\w* \w veremos|strong="H7200"\w* \w guerra|strong="H4421"\w*, \w ni|strong="H3808"\w* \w oiremos|strong="H8085"\w* \w sonido|strong="H6963"\w* \w de|strong="H3588"\w* \w trompeta|strong="H7782"\w*, \w ni|strong="H3808"\w* padeceremos \w hambre|strong="H7456"\w*. \w Allá|strong="H8033"\w* viviremos.   
\p
\v 15 \w Entonces|strong="H3651"\w* \w escuchen|strong="H8085"\w* la \w Palabra|strong="H1697"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, oh remanente \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*: \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H6440"\w* las huestes, \nd ʼElohim\nd* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w dice|strong="H1697"\w*: \wj \+w Si|strong="H6440"\+w* vuelven sus caras \+w para|strong="H6258"\+w* entrar en \+w Egipto|strong="H4714"\+w* \+w y|strong="H3541"\+w* entran \+w a|strong="H3068"\+w* residir \+w allá|strong="H8033"\+w*,\wj*  
\v 16 \wj \+w sucederá|strong="H1961"\+w* \+w que|strong="H4480"\+w* la \+w espada|strong="H2719"\+w* \+w que|strong="H4480"\+w* \+w temen|strong="H3372"\+w* \+w los|strong="H1961"\+w* \+w alcanzará|strong="H5381"\+w* \+w en|strong="H4480"\+w* la tierra \+w de|strong="H4480"\+w* \+w Egipto|strong="H4714"\+w*, y el \+w hambre|strong="H7458"\+w* \+w por|strong="H4480"\+w* el cual \+w están|strong="H1961"\+w* ansiosos, \+w los|strong="H1961"\+w* perseguirá estrechamente \+w en|strong="H4480"\+w* \+w Egipto|strong="H4714"\+w*. \+w Allí|strong="H8033"\+w* \+w morirán|strong="H4191"\+w*.\wj*  
\v 17 \wj \+w Por|strong="H5921"\+w* \+w tanto|strong="H5921"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H5921"\+w* hombres \+w que|strong="H3808"\+w* fijen su mente \+w en|strong="H5921"\+w* ir \+w a|strong="H3068"\+w* \+w Egipto|strong="H4714"\+w* \+w para|strong="H5921"\+w* residir \+w allí|strong="H8033"\+w*, \+w morirán|strong="H4191"\+w* \+w a|strong="H3068"\+w* \+w espada|strong="H2719"\+w*, \+w de|strong="H5921"\+w* \+w hambre|strong="H7458"\+w* \+w y|strong="H5921"\+w* \+w por|strong="H5921"\+w* \+w pestilencia|strong="H1698"\+w*. \+w No|strong="H3808"\+w* \+w tendrán|strong="H1961"\+w* sobrevivientes \+w ni|strong="H3808"\+w* refugios \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* calamidad \+w que|strong="H3808"\+w* enviaré \+w sobre|strong="H5921"\+w* \+w ellos|strong="H5921"\+w*.\wj*   
\p
\v 18 \w Porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes, \w el|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, dice: \wj \+w Como|strong="H3588"\+w* \+w mi|strong="H5921"\+w* \+w ira|strong="H2534"\+w* \+w y|strong="H3588"\+w* \+w mi|strong="H5921"\+w* \+w furor|strong="H2534"\+w* \+w se|strong="H1961"\+w* derramaron \+w sobre|strong="H5921"\+w* \+w los|strong="H3427"\+w* \+w habitantes|strong="H3427"\+w* \+w de|strong="H5921"\+w* Jerusalén, \+w se|strong="H1961"\+w* derramará \+w mi|strong="H5921"\+w* \+w ira|strong="H2534"\+w* \+w sobre|strong="H5921"\+w* ustedes \+w cuando|strong="H3588"\+w* entren \+w en|strong="H5921"\+w* \+w Egipto|strong="H4714"\+w*. \+w Serán|strong="H1961"\+w* una \+w maldición|strong="H7045"\+w*, un objeto \+w de|strong="H5921"\+w* horror \+w e|strong="H3068"\+w* imprecación \+w y|strong="H3588"\+w* reproche, \+w de|strong="H5921"\+w* \+w maldición|strong="H7045"\+w* \+w y|strong="H3588"\+w* \+w afrenta|strong="H2781"\+w*. \+w No|strong="H3808"\+w* volverán \+w a|strong="H3068"\+w* \+w ver|strong="H7200"\+w* \+w este|strong="H2088"\+w* \+w lugar|strong="H4725"\+w*.\wj*   
\p
\v 19 Oh remanente \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*: \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* ustedes: \wj \+w No|strong="H3588"\+w* vayan \+w a|strong="H3068"\+w* \+w Egipto|strong="H4714"\+w*.\wj* \w Entiendan|strong="H3045"\w* claramente \w que|strong="H3588"\w* \w hoy|strong="H3117"\w* \w los|strong="H5921"\w* amonesto.  
\v 20 \w Porque|strong="H3588"\w* ustedes mismos \w se|strong="H3651"\w* \w engañan|strong="H8582"\w*, \w pues|strong="H3588"\w* \w me|strong="H3588"\w* \w enviaron|strong="H7971"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w su|strong="H3588"\w* \nd ʼElohim\nd* \w y|strong="H3588"\w* dijeron: \w Ora|strong="H6419"\w* \w por|strong="H3588"\w* \w nosotros|strong="H3605"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd*. Infórmanos \w todas|strong="H3605"\w* las cosas \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd* diga, \w y|strong="H3588"\w* las \w haremos|strong="H6213"\w*.  
\v 21 \w Hoy|strong="H3117"\w* \w se|strong="H3808"\w* \w lo|strong="H3808"\w* dije, y ustedes \w no|strong="H3808"\w* \w obedecen|strong="H8085"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd* en \w todas|strong="H3605"\w* las cosas \w que|strong="H3808"\w* \w Él|strong="H3605"\w* me \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decirles.  
\v 22 \w Por|strong="H3588"\w* tanto, \w ahora|strong="H6258"\w* deben \w saber|strong="H3045"\w* \w y|strong="H3588"\w* entender claramente \w que|strong="H3588"\w* \w morirán|strong="H4191"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w de|strong="H3588"\w* \w hambre|strong="H7458"\w* \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w pestilencia|strong="H1698"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w lugar|strong="H4725"\w* adonde desean ir \w para|strong="H3588"\w* residir.   
\c 43  
\s1 Huida del remanente a Egipto  
\p
\v 1 \w Aconteció|strong="H1961"\w* \w que|strong="H5971"\w*, \w cuando|strong="H1961"\w* \w Jeremías|strong="H3414"\w* terminó \w de|strong="H5971"\w* \w hablar|strong="H1696"\w* \w todas|strong="H3605"\w* las \w Palabras|strong="H1697"\w* \w de|strong="H5971"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, su \nd ʼElohim\nd*, \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w es|strong="H1961"\w* decir, \w todas|strong="H3605"\w* las \w Palabras|strong="H1697"\w* \w que|strong="H5971"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd* les \w envió|strong="H7971"\w*,  
\v 2 \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Osaías, y \w Johanán|strong="H3110"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Carea|strong="H7143"\w*, y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* varones arrogantes \w dijeron|strong="H1696"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*: Hablas \w mentira|strong="H8267"\w*. \w No|strong="H3808"\w* te \w envió|strong="H7971"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd* \w a|strong="H3068"\w* decirnos: \w No|strong="H3808"\w* entren \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* para residir \w allá|strong="H8033"\w*,  
\v 3 \w pero|strong="H3588"\w* Baruc, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Nerías, \w te|strong="H3588"\w* incita contra nosotros \w a|strong="H3068"\w* fin \w de|strong="H3588"\w* entregarnos \w en|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w caldeos|strong="H3778"\w*, \w para|strong="H4616"\w* \w que|strong="H3588"\w* nos maten \w o|strong="H3068"\w* nos lleven \w cautivos|strong="H1540"\w* \w a|strong="H3068"\w* Babilonia.   
\p
\v 4 \w Johanán|strong="H3110"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Carea|strong="H7143"\w*, y \w todos|strong="H3605"\w* \w los|strong="H3427"\w* comandantes \w de|strong="H1121"\w* \w los|strong="H3427"\w* guerreros y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w no|strong="H3808"\w* \w obedecieron|strong="H8085"\w* \w la|strong="H3605"\w* \w voz|strong="H6963"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w para|strong="H5971"\w* quedarse en tierra \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.  
\v 5 Pero \w Johanán|strong="H3110"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Carea|strong="H7143"\w*, y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* comandantes \w de|strong="H1121"\w* \w los|strong="H1121"\w* guerreros, reunieron al remanente \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* \w que|strong="H1121"\w* regresó \w de|strong="H1121"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* \w a|strong="H3068"\w* las cuales fueron echados para vivir en \w Judá|strong="H3063"\w*:  
\v 6 \w hombres|strong="H1121"\w* y \w mujeres|strong="H1323"\w*, \w niños|strong="H2945"\w* y princesas, y \w cuantos|strong="H3605"\w* \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* guardia, había encomendado \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahicam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Safán, y también \w al|strong="H4428"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* y \w a|strong="H3068"\w* Baruc, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Nerías.  
\v 7 Entraron \w en|strong="H5704"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*. \w No|strong="H3808"\w* \w obedecieron|strong="H8085"\w* \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w y|strong="H3588"\w* llegaron \w a|strong="H3068"\w* Tafnes.   
\s1 El profeta Jeremías en Egipto  
\p
\v 8 Entonces la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* en Tafnes:  
\v 9 \wj \+w Toma|strong="H3947"\+w* en tu \+w mano|strong="H3027"\+w* piedras \+w grandes|strong="H1419"\+w*, entiérralas con argamasa en el pavimento \+w que|strong="H3027"\+w* está en la \+w puerta|strong="H6607"\+w* \+w de|strong="H5869"\+w* la \+w casa|strong="H1004"\+w* \+w de|strong="H5869"\+w* \+w Faraón|strong="H6547"\+w*, en Tafnes, \+w a|strong="H3068"\+w* vista \+w de|strong="H5869"\+w* los hombres \+w de|strong="H5869"\+w* Judá,\wj*  
\v 10 \wj \+w y|strong="H5921"\+w* diles: \wj*\nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes, \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, dice: \wj Yo mandaré \+w a|strong="H3068"\+w* buscar \+w a|strong="H3068"\+w* \+w Nabucodonosor|strong="H5019"\+w*, \+w rey|strong="H4428"\+w* \+w de|strong="H5921"\+w* Babilonia, \+w mi|strong="H5921"\+w* esclavo, \+w y|strong="H5921"\+w* \+w pondré|strong="H7760"\+w* su \+w trono|strong="H3678"\+w* \+w sobre|strong="H5921"\+w* estas piedras \+w que|strong="H5921"\+w* escondí. \+w Él|strong="H5921"\+w* \+w extenderá|strong="H7971"\+w* su pabellón \+w sobre|strong="H5921"\+w* \+w ellas|strong="H5921"\+w*.\wj*  
\v 11 \wj Vendrá y desolará la tierra de \+w Egipto|strong="H4714"\+w*: el destinado \+w a|strong="H3068"\+w* \+w muerte|strong="H4194"\+w* irá \+w a|strong="H3068"\+w* \+w muerte|strong="H4194"\+w*, el destinado \+w a|strong="H3068"\+w* \+w cautiverio|strong="H7628"\+w*, \+w a|strong="H3068"\+w* \+w cautiverio|strong="H7628"\+w*, el destinado \+w a|strong="H3068"\+w* la \+w espada|strong="H2719"\+w*, \+w a|strong="H3068"\+w* la \+w espada|strong="H2719"\+w*.\wj*  
\v 12 \wj Incendiará los templos de los \+tl ʼelohim\+tl* de \+w Egipto|strong="H4714"\+w* y los \+w quemará|strong="H8313"\+w*. \+w A|strong="H3068"\+w* ellos los llevará cautivos. Así como el \+w pastor|strong="H7462"\+w* se sacude su ropa, limpiará la tierra de \+w Egipto|strong="H4714"\+w*, y \+w saldrá|strong="H3318"\+w* de \+w allá|strong="H8033"\+w* \+w en|strong="H3318"\+w* \+w paz|strong="H7965"\+w*.\wj*  
\v 13 \wj \+w Quebrará|strong="H7665"\+w* también las \+w columnas|strong="H4676"\+w* del \+w templo|strong="H1004"\+w* al sol que están en tierra de \+w Egipto|strong="H4714"\+w*, y aplicará fuego \+w a|strong="H3068"\+w* los templos de los \+tl ʼelohim\+tl* de \+w Egipto|strong="H4714"\+w*.\wj*   
\c 44  
\s1 El remanente huye a Egipto  
\p
\v 1 \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* con respecto \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w judíos|strong="H3064"\w* \w que|strong="H1697"\w* residían en \w la|strong="H3605"\w* tierra \w de|strong="H1697"\w* \w Egipto|strong="H4714"\w* y \w habitaban|strong="H3427"\w* en \w Migdol|strong="H4024"\w*, Tafnes, Menfis y en \w la|strong="H3605"\w* tierra \w de|strong="H1697"\w* Patros:  
\v 2 \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes, \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, dice: \wj Ustedes \+w vieron|strong="H7200"\+w* \+w todo|strong="H3605"\+w* \+w el|strong="H5921"\+w* \+w mal|strong="H7451"\+w* \+w que|strong="H5921"\+w* traje \+w sobre|strong="H5921"\+w* Jerusalén \+w y|strong="H5921"\+w* \+w sobre|strong="H5921"\+w* \+w todas|strong="H3605"\+w* \+w las|strong="H5921"\+w* \+w ciudades|strong="H5892"\+w* \+w de|strong="H5921"\+w* \+w Judá|strong="H3063"\+w*. \+w Pues|strong="H2088"\+w* miren, \+w hoy|strong="H3117"\+w* son una desolación \+w y|strong="H5921"\+w* \+w nadie|strong="H3605"\+w* vive \+w allí|strong="H3541"\+w*\wj*  
\v 3 \wj \+w por|strong="H6440"\+w* \+w causa|strong="H6440"\+w* \+w de|strong="H6440"\+w* la perversidad con la cual \+w se|strong="H3045"\+w* empeñaron \+w en|strong="H3212"\+w* provocarme \+w a|strong="H3068"\+w* \+w ira|strong="H3212"\+w* al quemar incienso para honrar \+w a|strong="H3068"\+w* \+tl ʼelohim\+tl* extraños \+w que|strong="H3808"\+w* \+w ni|strong="H3808"\+w* \+w ellos|strong="H1992"\+w*, \+w ni|strong="H3808"\+w* ustedes, \+w ni|strong="H3808"\+w* \+w sus|strong="H1992"\+w* antepasados \+w conocían|strong="H3045"\+w*.\wj*  
