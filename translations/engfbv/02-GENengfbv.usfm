\p \w The|strong="H1121"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Raamah|strong="H7484"\w*: \w Sheba|strong="H7614"\w* \w and|strong="H1121"\w* \w Dedan|strong="H1719"\w*.   
\p
\v 8 \w Cush|strong="H3568"\w* \w was|strong="H1961"\w* \w also|strong="H3205"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H3205"\w* \w Nimrod|strong="H5248"\w*, \w who|strong="H1931"\w* set \w himself|strong="H1931"\w* \w up|strong="H3205"\w* \w as|strong="H1961"\w* \w the|strong="H3205"\w* \w first|strong="H2490"\w* tyrant \w on|strong="H1961"\w* earth.  
\v 9 \w He|strong="H1931"\w* \w was|strong="H3068"\w* \w a|strong="H3068"\w* \w powerful|strong="H1368"\w* fighter \w who|strong="H1931"\w* defied\f + \fr 10:9 \ft “Defied”: The Septuagint reads “against” or “versus.”\f* \w the|strong="H6440"\w* \w Lord|strong="H3068"\w*; \w which|strong="H1931"\w* \w is|strong="H3068"\w* \w why|strong="H5921"\w* \w there|strong="H1961"\w*'s \w the|strong="H6440"\w* \w expression|strong="H6440"\w*, “\w Like|strong="H1961"\w* \w Nimrod|strong="H5248"\w*, \w a|strong="H3068"\w* \w powerful|strong="H1368"\w* fighter \w who|strong="H1931"\w* defied \w the|strong="H6440"\w* \w Lord|strong="H3068"\w*.”  
