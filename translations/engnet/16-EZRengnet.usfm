\c 6  
\p
\v 1  \w So|strong="H1768"\w* \w Darius|strong="H1868"\w* \w the|strong="H1768"\w* \w king|strong="H4430"\w* \w issued|strong="H7761"\w* \w orders|strong="H2942"\w*, \w and|strong="H4430"\w* \w they|strong="H1768"\w* searched \w in|strong="H4430"\w* \w the|strong="H1768"\w* \w archives|strong="H1005"\w* \w of|strong="H1005"\w* \w the|strong="H1768"\w* \w treasury|strong="H1005"\w* \w which|strong="H1768"\w* \w were|strong="H1768"\w* deposited \w there|strong="H8536"\w* \w in|strong="H4430"\w* Babylon.  
\v 2  \w A|strong="H3068"\w* \w scroll|strong="H4040"\w* \w was|strong="H1768"\w* \w found|strong="H7912"\w* \w in|strong="H7912"\w* \w the|strong="H1768"\w* citadel \w of|strong="H4083"\w* Ecbatana \w which|strong="H1768"\w* \w is|strong="H1768"\w* \w in|strong="H7912"\w* \w the|strong="H1768"\w* \w province|strong="H4083"\w* \w of|strong="H4083"\w* \w Media|strong="H4076"\w*, \w and|strong="H4076"\w* it \w was|strong="H1768"\w* inscribed \w as|strong="H1768"\w* \w follows|strong="H3652"\w*:  
\p “\w Memorandum|strong="H1799"\w*:  
\v 3  \w In|strong="H4430"\w* \w the|strong="H1768"\w* \w first|strong="H2298"\w* \w year|strong="H8140"\w* \w of|strong="H1005"\w* \w his|strong="H1768"\w* \w reign|strong="H4430"\w*, \w King|strong="H4430"\w* \w Cyrus|strong="H3567"\w* \w gave|strong="H7761"\w* \w orders|strong="H2942"\w* \w concerning|strong="H2942"\w* \w the|strong="H1768"\w* \w temple|strong="H1005"\w* \w of|strong="H1005"\w* God \w in|strong="H4430"\w* \w Jerusalem|strong="H3390"\w*: ‘Let \w the|strong="H1768"\w* \w temple|strong="H1005"\w* \w be|strong="H1005"\w* \w rebuilt|strong="H1124"\w* \w as|strong="H1768"\w* \w a|strong="H3068"\w* place \w where|strong="H1768"\w* \w sacrifices|strong="H1685"\w* \w are|strong="H1768"\w* \w offered|strong="H1684"\w*. Let its foundations \w be|strong="H1005"\w* \w set|strong="H7761"\w* \w in|strong="H4430"\w* place. Its \w height|strong="H7314"\w* \w is|strong="H1768"\w* \w to|strong="H2942"\w* \w be|strong="H1005"\w* \w ninety|strong="H8361"\w* feet \w and|strong="H4430"\w* its \w width|strong="H6613"\w* \w ninety|strong="H8361"\w* feet,  
\v 4  with \w three|strong="H8532"\w* \w layers|strong="H5073"\w* \w of|strong="H4481"\w* large stones \w and|strong="H4430"\w* one \w layer|strong="H5073"\w* \w of|strong="H4481"\w* timber. \w The|strong="H4481"\w* expense \w is|strong="H1768"\w* \w to|strong="H4481"\w* \w be|strong="H5313"\w* subsidized \w by|strong="H4481"\w* \w the|strong="H4481"\w* \w royal|strong="H4430"\w* \w treasury|strong="H1005"\w*.  
\v 5  Furthermore let \w the|strong="H4481"\w* \w gold|strong="H1722"\w* \w and|strong="H1722"\w* \w silver|strong="H3702"\w* \w vessels|strong="H3984"\w* \w of|strong="H4481"\w* \w the|strong="H4481"\w* \w temple|strong="H1005"\w* \w of|strong="H4481"\w* God, \w which|strong="H1768"\w* \w Nebuchadnezzar|strong="H5020"\w* \w brought|strong="H2987"\w* \w from|strong="H4481"\w* \w the|strong="H4481"\w* \w temple|strong="H1005"\w* \w in|strong="H5182"\w* \w Jerusalem|strong="H3390"\w* \w and|strong="H1722"\w* carried \w to|strong="H5312"\w* Babylon, \w be|strong="H1005"\w* \w returned|strong="H8421"\w* \w and|strong="H1722"\w* \w brought|strong="H2987"\w* \w to|strong="H5312"\w* their proper \w place|strong="H5182"\w* \w in|strong="H5182"\w* \w the|strong="H4481"\w* \w temple|strong="H1005"\w* \w in|strong="H5182"\w* \w Jerusalem|strong="H3390"\w*. Let them \w be|strong="H1005"\w* deposited \w in|strong="H5182"\w* \w the|strong="H4481"\w* \w temple|strong="H1005"\w* \w of|strong="H4481"\w* God.’   
\p
\v 6 “\w Now|strong="H3705"\w* \w Tattenai|strong="H8674"\w* \w governor|strong="H6347"\w* \w of|strong="H4481"\w* \w Trans-Euphrates|strong="H5103"\w*, Shethar Bozenai, \w and|strong="H1934"\w* their \w colleagues|strong="H3675"\w*, \w the|strong="H4481"\w* officials \w of|strong="H4481"\w* \w Trans-Euphrates|strong="H5103"\w* – all \w of|strong="H4481"\w* \w you|strong="H1768"\w* stay \w far|strong="H7352"\w* \w away|strong="H7352"\w* \w from|strong="H4481"\w* \w there|strong="H8536"\w*!  
\v 7  \w Leave|strong="H7662"\w* \w the|strong="H5922"\w* \w work|strong="H5673"\w* \w on|strong="H5922"\w* \w this|strong="H1791"\w* \w temple|strong="H1005"\w* \w of|strong="H1005"\w* God \w alone|strong="H7662"\w*. Let \w the|strong="H5922"\w* \w governor|strong="H6347"\w* \w of|strong="H1005"\w* \w the|strong="H5922"\w* \w Jews|strong="H3062"\w* \w and|strong="H1005"\w* \w the|strong="H5922"\w* \w elders|strong="H7868"\w* \w of|strong="H1005"\w* \w the|strong="H5922"\w* \w Jews|strong="H3062"\w* \w rebuild|strong="H1124"\w* \w this|strong="H1791"\w* \w temple|strong="H1005"\w* \w of|strong="H1005"\w* God \w in|strong="H5922"\w* its proper place.   
\p
\v 8 “\w I|strong="H4481"\w* \w also|strong="H4430"\w* \w hereby|strong="H4481"\w* \w issue|strong="H7761"\w* \w orders|strong="H2942"\w* \w as|strong="H1768"\w* \w to|strong="H2942"\w* \w what|strong="H1768"\w* \w you|strong="H1768"\w* \w are|strong="H1768"\w* \w to|strong="H2942"\w* \w do|strong="H5648"\w* \w with|strong="H5974"\w* \w those|strong="H1768"\w* \w elders|strong="H7868"\w* \w of|strong="H4481"\w* \w the|strong="H4481"\w* \w Jews|strong="H3062"\w* \w in|strong="H4430"\w* order \w to|strong="H2942"\w* \w rebuild|strong="H1124"\w* \w this|strong="H1791"\w* \w temple|strong="H1005"\w* \w of|strong="H4481"\w* God. \w From|strong="H4481"\w* \w the|strong="H4481"\w* \w royal|strong="H4430"\w* \w treasury|strong="H5232"\w*, \w from|strong="H4481"\w* \w the|strong="H4481"\w* \w taxes|strong="H4061"\w* \w of|strong="H4481"\w* \w Trans-Euphrates|strong="H5103"\w* \w the|strong="H4481"\w* complete \w costs|strong="H5313"\w* \w are|strong="H1768"\w* \w to|strong="H2942"\w* \w be|strong="H1934"\w* \w given|strong="H3052"\w* \w to|strong="H2942"\w* \w these|strong="H4481"\w* \w men|strong="H1400"\w*, \w so|strong="H1768"\w* \w that|strong="H1768"\w* \w there|strong="H1768"\w* may \w be|strong="H1934"\w* \w no|strong="H3809"\w* interruption \w of|strong="H4481"\w* \w the|strong="H4481"\w* work.  
\v 9  \w Whatever|strong="H4101"\w* \w is|strong="H1768"\w* needed – \w whether|strong="H1768"\w* \w oxen|strong="H8450"\w* \w or|strong="H3809"\w* \w rams|strong="H1798"\w* \w or|strong="H3809"\w* lambs \w or|strong="H3809"\w* \w burnt|strong="H5928"\w* \w offerings|strong="H5928"\w* \w for|strong="H1768"\w* \w the|strong="H1768"\w* God \w of|strong="H1123"\w* \w heaven|strong="H8065"\w* \w or|strong="H3809"\w* \w wheat|strong="H2591"\w* \w or|strong="H3809"\w* \w salt|strong="H4416"\w* \w or|strong="H3809"\w* \w wine|strong="H2562"\w* \w or|strong="H3809"\w* \w oil|strong="H4887"\w*, \w as|strong="H1768"\w* required \w by|strong="H3549"\w* \w the|strong="H1768"\w* \w priests|strong="H3549"\w* \w who|strong="H1768"\w* \w are|strong="H1768"\w* \w in|strong="H3549"\w* \w Jerusalem|strong="H3390"\w* – must \w be|strong="H1934"\w* \w given|strong="H3052"\w* \w to|strong="H3390"\w* \w them|strong="H3052"\w* \w daily|strong="H3118"\w* \w without|strong="H3809"\w* any \w neglect|strong="H7960"\w*,  
\v 10  \w so|strong="H1768"\w* \w that|strong="H1768"\w* \w they|strong="H1768"\w* \w may|strong="H2417"\w* \w be|strong="H1934"\w* \w offering|strong="H7127"\w* \w incense|strong="H5208"\w* \w to|strong="H4430"\w* \w the|strong="H1768"\w* God \w of|strong="H4430"\w* \w heaven|strong="H8065"\w* \w and|strong="H4430"\w* \w may|strong="H2417"\w* \w be|strong="H1934"\w* \w praying|strong="H6739"\w* \w for|strong="H1768"\w* \w the|strong="H1768"\w* good fortune \w of|strong="H4430"\w* \w the|strong="H1768"\w* \w king|strong="H4430"\w* \w and|strong="H4430"\w* \w his|strong="H1768"\w* family.   
\p
\v 11 “\w I|strong="H4481"\w* \w hereby|strong="H4481"\w* \w give|strong="H7761"\w* \w orders|strong="H2942"\w* \w that|strong="H1768"\w* if \w anyone|strong="H3606"\w* \w changes|strong="H8133"\w* \w this|strong="H1836"\w* \w directive|strong="H6600"\w* \w a|strong="H3068"\w* beam \w is|strong="H1768"\w* \w to|strong="H5922"\w* \w be|strong="H1005"\w* pulled \w out|strong="H5648"\w* \w from|strong="H4481"\w* \w his|strong="H5922"\w* \w house|strong="H1005"\w* \w and|strong="H1005"\w* \w he|strong="H1768"\w* \w is|strong="H1768"\w* \w to|strong="H5922"\w* \w be|strong="H1005"\w* raised \w up|strong="H2211"\w* \w and|strong="H1005"\w* \w impaled|strong="H2211"\w* \w on|strong="H5922"\w* \w it|strong="H5922"\w*, \w and|strong="H1005"\w* \w his|strong="H5922"\w* \w house|strong="H1005"\w* \w is|strong="H1768"\w* \w to|strong="H5922"\w* \w be|strong="H1005"\w* \w reduced|strong="H7761"\w* \w to|strong="H5922"\w* \w a|strong="H3068"\w* \w rubbish|strong="H5122"\w* \w heap|strong="H5122"\w* \w for|strong="H5922"\w* \w this|strong="H1836"\w* indiscretion.  
\v 12  May God \w who|strong="H1768"\w* \w makes|strong="H7932"\w* \w his|strong="H7972"\w* \w name|strong="H8036"\w* \w to|strong="H2942"\w* reside \w there|strong="H8536"\w* \w overthrow|strong="H4049"\w* \w any|strong="H3606"\w* \w king|strong="H4430"\w* \w or|strong="H4430"\w* nation \w who|strong="H1768"\w* reaches \w out|strong="H5648"\w* \w to|strong="H2942"\w* \w cause|strong="H3606"\w* \w such|strong="H1768"\w* \w change|strong="H8133"\w* \w so|strong="H1768"\w* \w as|strong="H3606"\w* \w to|strong="H2942"\w* \w destroy|strong="H2255"\w* \w this|strong="H1791"\w* \w temple|strong="H1005"\w* \w of|strong="H1005"\w* God \w in|strong="H8133"\w* \w Jerusalem|strong="H3390"\w*. \w I|strong="H1768"\w*, \w Darius|strong="H1868"\w*, \w have|strong="H7761"\w* \w given|strong="H7761"\w* \w orders|strong="H2942"\w*. Let them \w be|strong="H1005"\w* \w carried|strong="H5648"\w* \w out|strong="H5648"\w* \w with|strong="H5648"\w* precision!”   
\s1 The Temple Is Finally Dedicated  
\p
\v 13  \w Then|strong="H6903"\w* \w Tattenai|strong="H8674"\w* \w governor|strong="H6347"\w* \w of|strong="H4430"\w* \w Trans-Euphrates|strong="H5103"\w*, \w Shethar-Bozenai|strong="H8370"\w*, \w and|strong="H4430"\w* their \w colleagues|strong="H3675"\w* \w acted|strong="H5648"\w* \w accordingly|strong="H6903"\w* – \w with|strong="H5648"\w* precision, \w just|strong="H6903"\w* \w as|strong="H6903"\w* \w Darius|strong="H1868"\w* \w the|strong="H5675"\w* \w king|strong="H4430"\w* \w had|strong="H4430"\w* given instructions.  
