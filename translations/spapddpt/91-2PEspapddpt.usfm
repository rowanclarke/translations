\v 19 \w También|strong="G2532"\w* \w tenemos|strong="G2192"\w* \w la|strong="G3588"\w* \w Palabra|strong="G3056"\w* \w profética|strong="G4397"\w* \w más|strong="G2532"\w* confiable. \w Hacen|strong="G4160"\w* \w bien|strong="G2573"\w* \w en|strong="G1722"\w* estar atentos \w a|strong="G1722"\w* \w esta|strong="G3588"\w* \w Palabra|strong="G3056"\w* \w como|strong="G5613"\w* \w a|strong="G1722"\w* \w una|strong="G3588"\w* \w antorcha|strong="G3088"\w* \w que|strong="G3588"\w* \w alumbra|strong="G5316"\w* \w en|strong="G1722"\w* \w un|strong="G3588"\w* \w lugar|strong="G5117"\w* oscuro \w hasta|strong="G2193"\w* \w que|strong="G3588"\w* \w el|strong="G3588"\w* \w día|strong="G2250"\w* amanezca \w y|strong="G2532"\w* \w el|strong="G3588"\w* lucero \w de|strong="G1722"\w* \w la|strong="G3588"\w* mañana salga \w en|strong="G1722"\w* \w sus|strong="G3588"\w* \w corazones|strong="G2588"\w*.   
