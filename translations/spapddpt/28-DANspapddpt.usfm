\p 
\v 15 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, oh \nd ʼAdonay\nd*, \nd ʼElohim\nd* nuestro, \w que|strong="H6258"\w* \w sacaste|strong="H3318"\w* \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* la tierra \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w* con \w mano|strong="H3027"\w* \w poderosa|strong="H2389"\w* y te \w hiciste|strong="H6213"\w* famoso como sucede \w hoy|strong="H3117"\w*: ¡\w Pecamos|strong="H2398"\w* y fuimos perversos!
\p 
\v 16 Oh \nd ʼAdonay\nd*, aparta tu \w ira|strong="H2534"\w* \w y|strong="H3588"\w* \w furor|strong="H2534"\w* \w de|strong="H3588"\w* sobre tu \w ciudad|strong="H5892"\w* Jerusalén, tu Montaña \w Santa|strong="H6944"\w*, según \w todas|strong="H3605"\w* tus obras justas. \w Porque|strong="H3588"\w* \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* nuestros \w pecados|strong="H5771"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* las \w iniquidades|strong="H5771"\w* \w de|strong="H3588"\w* nuestros antepasados, Jerusalén \w y|strong="H3588"\w* tu \w pueblo|strong="H5971"\w* \w son|strong="H3588"\w* \w el|strong="H3588"\w* \w oprobio|strong="H2781"\w* \w de|strong="H3588"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* nos \w rodean|strong="H5439"\w*.
\p 
\v 17 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, \nd ʼElohim\nd* nuestro, \w oye|strong="H8085"\w* \w el|strong="H5921"\w* clamor \w de|strong="H5921"\w* tu esclavo \w y|strong="H5921"\w* sus súplicas. \w Por|strong="H5921"\w* amor \w a|strong="H3068"\w* \w Ti|strong="H5921"\w*, concede \w que|strong="H6258"\w* tu \w Rostro|strong="H6440"\w* resplandezca \w sobre|strong="H5921"\w* tu \w Santuario|strong="H4720"\w* desolado, oh \nd ʼAdonay\nd*.
\v 18 ¡Oh \nd ʼElohim\nd* \w mío|strong="H5921"\w*! \w Inclina|strong="H5186"\w* tu \w oído|strong="H8085"\w* \w y|strong="H3588"\w* \w escucha|strong="H8085"\w*. \w Abre|strong="H6491"\w* tus \w ojos|strong="H5869"\w* \w y|strong="H3588"\w* \w mira|strong="H7200"\w* nuestras desolaciones \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cual|strong="H3588"\w* \w es|strong="H3588"\w* \w invocado|strong="H7121"\w* tu \w Nombre|strong="H8034"\w*. \w Porque|strong="H3588"\w* \w no|strong="H3808"\w* presentamos nuestras súplicas \w ante|strong="H6440"\w* \w Ti|strong="H5921"\w* confiados \w en|strong="H5921"\w* algún mérito nuestro, \w sino|strong="H3588"\w* confiados \w en|strong="H5921"\w* tus \w grandes|strong="H7227"\w* \w misericordias|strong="H7356"\w*.
\v 19 ¡Oh \nd ʼAdonay\nd*, \w escucha|strong="H8085"\w*! ¡Oh \nd ʼAdonay\nd*, \w perdona|strong="H5545"\w*! ¡Oh \nd ʼAdonay\nd*, \w escucha|strong="H8085"\w* \w y|strong="H3588"\w* actúa! ¡Oh \nd ʼElohim\nd* \w mío|strong="H5921"\w*, \w por|strong="H5921"\w* amor \w a|strong="H3068"\w* \w Ti|strong="H5921"\w* mismo, \w no|strong="H6213"\w* tardes! \w Porque|strong="H3588"\w* \w por|strong="H5921"\w* \w tu|strong="H6213"\w* \w Nombre|strong="H8034"\w* \w son|strong="H3588"\w* \w nombrados|strong="H8034"\w* \w tu|strong="H6213"\w* \w ciudad|strong="H5892"\w* \w y|strong="H3588"\w* \w tu|strong="H6213"\w* \w pueblo|strong="H5971"\w*.
\s1 Explicación de la visión
\p 
\v 20 \w Aún|strong="H5750"\w* \w hablaba|strong="H1696"\w* \w con|strong="H5921"\w* \w Dios|strong="H3068"\w*, confesaba \w mi|strong="H5921"\w* \w pecado|strong="H2403"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* presentaba \w mi|strong="H5921"\w* \w súplica|strong="H8467"\w* \w ante|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w mi|strong="H5921"\w* \nd ʼElohim\nd* \w por|strong="H5921"\w* \w la|strong="H5921"\w* Montaña \w Santa|strong="H6944"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \nd ʼElohim\nd*.
\v 21 \w Mientras|strong="H5750"\w* \w aún|strong="H5750"\w* \w hablaba|strong="H1696"\w* \w con|strong="H5060"\w* Dios, aquel varón \w Gabriel|strong="H1403"\w*, \w a|strong="H3068"\w* quien \w miré|strong="H7200"\w* \w al|strong="H6256"\w* principio \w en|strong="H8462"\w* la \w visión|strong="H2377"\w*, voló hacia mí \w con|strong="H5060"\w* rapidez \w como|strong="H5060"\w* \w a|strong="H3068"\w* la \w hora|strong="H6256"\w* del sacrificio \w de|strong="H5750"\w* la \w tarde|strong="H6153"\w*.
\v 22 \w Y|strong="H3068"\w* \w me|strong="H5973"\w* explicó: \w Daniel|strong="H1840"\w*, \w ahora|strong="H6258"\w* vine \w para|strong="H5973"\w* iluminar tu entendimiento.
\v 23 Al principio \w de|strong="H3588"\w* tus \w ruegos|strong="H8469"\w* fue dada \w la|strong="H3588"\w* orden. \w Y|strong="H3068"\w* \w yo|strong="H3588"\w* vine \w para|strong="H3588"\w* enseñártela, \w porque|strong="H3588"\w* tú eres un varón muy amado. \w Por|strong="H3588"\w* tanto, considera \w el|strong="H3588"\w* \w asunto|strong="H1697"\w* \w y|strong="H3588"\w* entiende \w la|strong="H3588"\w* \w visión|strong="H4758"\w*.
\p 
\v 24 70 \w semanas|strong="H7620"\w* están determinadas \w sobre|strong="H5921"\w* tu \w pueblo|strong="H5971"\w* \w y|strong="H5921"\w* tu \w Santa|strong="H6944"\w* \w Ciudad|strong="H5892"\w*, \w para|strong="H5921"\w* terminar \w la|strong="H5921"\w* transgresión, poner fin \w al|strong="H5921"\w* \w pecado|strong="H2403"\w*, hacer sacrificio \w que|strong="H5921"\w* apacigua \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w iniquidad|strong="H5771"\w*, introducir \w la|strong="H5921"\w* \w justicia|strong="H6664"\w* perdurable, sellar \w la|strong="H5921"\w* \w visión|strong="H2377"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w profecía|strong="H2377"\w* \w y|strong="H5921"\w* ungir \w al|strong="H5921"\w* \w Santísimo|strong="H6944"\w*.
\p 
\v 25 \w Sabe|strong="H3045"\w* \w y|strong="H5704"\w* \w entiende|strong="H3045"\w* \w que|strong="H4480"\w* \w desde|strong="H4480"\w* la \w salida|strong="H4161"\w* \w del|strong="H4480"\w* decreto \w para|strong="H5704"\w* restaurar \w y|strong="H5704"\w* reedificar \w a|strong="H3068"\w* Jerusalén \w hasta|strong="H5704"\w* el Mesías \w Príncipe|strong="H5057"\w*, habrá \w siete|strong="H7651"\w* \w semanas|strong="H7620"\w* \w y|strong="H5704"\w* 62 \w semanas|strong="H7620"\w*. \w Se|strong="H3045"\w* \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* \w edificar|strong="H1129"\w* la plaza \w y|strong="H5704"\w* el muro \w en|strong="H4480"\w* \w tiempos|strong="H6256"\w* \w angustiosos|strong="H6695"\w*.
\v 26 \w Después|strong="H5704"\w* \w de|strong="H5704"\w* las 62 \w semanas|strong="H7620"\w* \w se|strong="H5971"\w* quitará la vida \w al|strong="H5704"\w* Mesías, pero \w no|strong="H7843"\w* \w por|strong="H5704"\w* \add causa\add* \w de|strong="H5704"\w* Él. \w Y|strong="H3068"\w* el \w pueblo|strong="H5971"\w* \w de|strong="H5704"\w* un \w príncipe|strong="H5057"\w* \w que|strong="H5704"\w* vendrá \w destruirá|strong="H3772"\w* la \w ciudad|strong="H5892"\w* \w y|strong="H5704"\w* el \w Santuario|strong="H6944"\w*, pero su \w fin|strong="H7093"\w* será \w como|strong="H5704"\w* una inundación. \w Hasta|strong="H5704"\w* el \w fin|strong="H7093"\w* \w de|strong="H5704"\w* la \w guerra|strong="H4421"\w* \w se|strong="H5971"\w* decretaron \w asolamientos|strong="H8074"\w*.
\p 
\v 27 \w Él|strong="H5921"\w* hará \w el|strong="H5921"\w* \w pacto|strong="H1285"\w* \w con|strong="H5921"\w* \w muchos|strong="H7227"\w* \w por|strong="H5921"\w* otra \w semana|strong="H7620"\w*. \w A|strong="H3068"\w* \w la|strong="H5921"\w* mitad \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w semana|strong="H7620"\w* hará cesar \w el|strong="H5921"\w* \w sacrificio|strong="H2077"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w ofrenda|strong="H4503"\w*. \w Después|strong="H5921"\w*, \w con|strong="H5921"\w* \w las|strong="H5921"\w* numerosas repugnancias, vendrá \w el|strong="H5921"\w* desolador, \w hasta|strong="H5704"\w* \w que|strong="H5921"\w* venga \w la|strong="H5921"\w* \w consumación|strong="H3617"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w está|strong="H5921"\w* determinado \w se|strong="H5921"\w* derrame \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* desolador.
\c 10
\s1 Semejanza de hombre
\p 
\v 1 El tercer \w año|strong="H8141"\w* \w de|strong="H1697"\w* \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Persia|strong="H6539"\w*, \w fue|strong="H6635"\w* revelada \w Palabra|strong="H1697"\w* \w a|strong="H3068"\w* \w Daniel|strong="H1840"\w*, \w llamado|strong="H8034"\w* \w Beltsasar|strong="H1095"\w*, \w Palabra|strong="H1697"\w* verdadera con respecto \w a|strong="H3068"\w* un \w gran|strong="H1419"\w* conflicto. Él comprendió la \w Palabra|strong="H1697"\w* y tuvo inteligencia en la \w visión|strong="H4758"\w*.
\p 
\v 2 En \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w*, yo, \w Daniel|strong="H1840"\w*, \w estuve|strong="H1961"\w* afligido por espacio de \w tres|strong="H7969"\w* \w semanas|strong="H7620"\w*.
\v 3 \w No|strong="H3808"\w* comí \w manjar|strong="H3899"\w* delicado, \w ni|strong="H3808"\w* \w carne|strong="H1320"\w* \w ni|strong="H3808"\w* \w vino|strong="H3196"\w* entraron \w en|strong="H5704"\w* mi \w boca|strong="H6310"\w*, \w ni|strong="H3808"\w* me ungí \w con|strong="H5704"\w* ungüento, \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* \w se|strong="H3808"\w* cumplieron \w tres|strong="H7969"\w* \w semanas|strong="H7620"\w* completas.
\p 
\v 4 \w El|strong="H1931"\w* \w día|strong="H3117"\w* 24 \w del|strong="H5921"\w* \w mes|strong="H2320"\w* \w primero|strong="H7223"\w* yo \w estaba|strong="H1961"\w* \w en|strong="H5921"\w* \w la|strong="H1931"\w* orilla \w del|strong="H5921"\w* \w gran|strong="H1419"\w* \w río|strong="H5104"\w* Hidequel.
\v 5 Al levantar \w mis|strong="H5375"\w* \w ojos|strong="H5869"\w* \w miré|strong="H7200"\w*, y \w vi|strong="H7200"\w* \w a|strong="H3068"\w* un varón \w vestido|strong="H3847"\w* \w de|strong="H3847"\w* lino blanco, ceñida su cintura con \w oro|strong="H3800"\w* \w de|strong="H3847"\w* Ufaz.
\v 6 Su cuerpo era como \w crisólito|strong="H8658"\w*, su \w rostro|strong="H6440"\w* como un relámpago y sus \w ojos|strong="H5869"\w* como antorchas \w de|strong="H6440"\w* fuego. Sus \w brazos|strong="H2220"\w* y \w pies|strong="H4772"\w* tenían la refulgencia del bronce incandescente, y el \w sonido|strong="H6963"\w* \w de|strong="H6440"\w* sus \w palabras|strong="H1697"\w* era como el \w estruendo|strong="H6963"\w* \w de|strong="H6440"\w* una \w multitud|strong="H1995"\w*.
\p 
\v 7 Solo yo, \w Daniel|strong="H1840"\w*, \w vi|strong="H7200"\w* \w aquella|strong="H5921"\w* \w visión|strong="H4759"\w*. \w Los|strong="H5921"\w* hombres \w que|strong="H3808"\w* \w estaban|strong="H1961"\w* \w conmigo|strong="H5973"\w* \w no|strong="H3808"\w* \w la|strong="H5921"\w* \w vieron|strong="H7200"\w*. Pero un \w gran|strong="H1419"\w* \w temor|strong="H2731"\w* \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H5921"\w* \w huyeron|strong="H1272"\w* \w para|strong="H5921"\w* esconderse.
\v 8 Yo \w quedé|strong="H7604"\w* solo \w y|strong="H5921"\w* \w vi|strong="H7200"\w* \w esta|strong="H2063"\w* \w gran|strong="H1419"\w* \w visión|strong="H4759"\w*. \w No|strong="H3808"\w* \w quedó|strong="H7604"\w* \w fuerza|strong="H3581"\w* \w en|strong="H5921"\w* \w mí|strong="H5921"\w*, \w porque|strong="H5921"\w* \w mi|strong="H5921"\w* \w vigor|strong="H3581"\w* \w se|strong="H5921"\w* cambió \w en|strong="H5921"\w* fragilidad. \w Me|strong="H5921"\w* \w quedé|strong="H7604"\w* \w sin|strong="H3808"\w* \w vigor|strong="H3581"\w*.
\v 9 Pero \w oí|strong="H8085"\w* \w el|strong="H5921"\w* \w sonido|strong="H6963"\w* \w de|strong="H5921"\w* sus \w palabras|strong="H1697"\w*. \w Y|strong="H3068"\w* \w al|strong="H5921"\w* oírlo, \w me|strong="H5921"\w* postré \w en|strong="H5921"\w* tierra \w con|strong="H5921"\w* un sueño profundo.
\p 
\v 10 Sin embargo, una \w mano|strong="H3027"\w* \w me|strong="H5921"\w* \w tocó|strong="H5060"\w*. Temblaba \w y|strong="H5921"\w* \w me|strong="H5921"\w* puso \w sobre|strong="H5921"\w* mis \w manos|strong="H3027"\w* \w y|strong="H5921"\w* mis \w rodillas|strong="H1290"\w*.
\v 11 \w Y|strong="H3068"\w* \w me|strong="H5921"\w* \w dijo|strong="H1696"\w*: \w Daniel|strong="H1840"\w*, varón muy amado, \w está|strong="H2088"\w* atento \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w que|strong="H3588"\w* \w te|strong="H5921"\w* \w hablaré|strong="H1696"\w*. \w Ponte|strong="H5975"\w* derecho \w sobre|strong="H5921"\w* tus pies, \w porque|strong="H3588"\w* \w ahora|strong="H6258"\w* fui \w enviado|strong="H7971"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*. \w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* \w me|strong="H5921"\w* \w dijo|strong="H1696"\w* esa \w palabra|strong="H1697"\w*, \w me|strong="H5921"\w* \w puse|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H5975"\w* \w y|strong="H3588"\w* temblaba.
\p 
\v 12 \w Me|strong="H4480"\w* dijo: \w Daniel|strong="H1840"\w*, \w no|strong="H3588"\w* \w temas|strong="H3372"\w*, \w porque|strong="H3588"\w* \w desde|strong="H4480"\w* \w el|strong="H3588"\w* \w primer|strong="H7223"\w* \w día|strong="H3117"\w* \w cuando|strong="H3588"\w* dispusiste tu \w corazón|strong="H3820"\w* \w para|strong="H3588"\w* entender \w y|strong="H3588"\w* \w humillarte|strong="H6031"\w* \w ante|strong="H6440"\w* tu \nd ʼElohim\nd*, tus \w palabras|strong="H1697"\w* fueron oídas, \w y|strong="H3588"\w* vine \w a|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H4480"\w* ellas.
\v 13 Pero el \w príncipe|strong="H8269"\w* del \w reino|strong="H4438"\w* \w de|strong="H5048"\w* \w Persia|strong="H6539"\w* se me opuso 21 \w días|strong="H3117"\w*. Pero \w mira|strong="H2009"\w*, \w Miguel|strong="H4317"\w*, uno \w de|strong="H5048"\w* los \w principales|strong="H8269"\w* arcángeles, vino para ayudarme, y \w yo|strong="H2009"\w* quedé \w allí|strong="H8033"\w* con los \w reyes|strong="H4428"\w* \w de|strong="H5048"\w* \w Persia|strong="H6539"\w*.
\v 14 \w Vine|strong="H7136"\w* \w para|strong="H3588"\w* informarte lo \w que|strong="H3588"\w* vendrá \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w* \w en|strong="H3588"\w* \w los|strong="H3588"\w* últimos \w días|strong="H3117"\w*, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w visión|strong="H2377"\w* \w es|strong="H3588"\w* \w para|strong="H3588"\w* aquellos \w días|strong="H3117"\w*.
\p 
\v 15 Mientras \w él|strong="H5973"\w* \w me|strong="H5973"\w* decía estas \w palabras|strong="H1697"\w*, yo volví mi \w rostro|strong="H6440"\w* \w hacia|strong="H6440"\w* la tierra y enmudecí.
\v 16 Pero \w ciertamente|strong="H2009"\w* uno \w que|strong="H3808"\w* parecía un ser humano \w tocó|strong="H5060"\w* mis \w labios|strong="H8193"\w*. Entonces \w abrí|strong="H6605"\w* \w mi|strong="H5921"\w* \w boca|strong="H6310"\w* \w y|strong="H5921"\w* \w hablé|strong="H1696"\w*, \w y|strong="H5921"\w* \w dije|strong="H1696"\w* \w al|strong="H5921"\w* \w que|strong="H3808"\w* \w estaba|strong="H5975"\w* \w delante|strong="H5048"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*: \tl ʼadón\tl* \w mío|strong="H5921"\w*, \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w visión|strong="H4759"\w* \w me|strong="H5921"\w* vinieron dolores \w y|strong="H5921"\w* \w no|strong="H3808"\w* retuve \w fuerza|strong="H3581"\w*.
\v 17 ¿\w Cómo|strong="H5973"\w* \w puede|strong="H3201"\w* \w el|strong="H5973"\w* esclavo \w de|strong="H5973"\w* mi \tl ʼadón\tl* \w hablar|strong="H1696"\w* \w con|strong="H5973"\w* mi \tl ʼadón\tl*? \w Porque|strong="H3808"\w* \w en|strong="H5973"\w* cuanto \w a|strong="H3068"\w* mí, \w ahora|strong="H6258"\w* mismo \w no|strong="H3808"\w* \w me|strong="H5973"\w* \w queda|strong="H7604"\w* \w fuerza|strong="H3581"\w* \w ni|strong="H3808"\w* aliento.
\p 
\v 18 Entonces, aquel que tenía semejanza de hombre me \w tocó|strong="H5060"\w* otra vez, me fortaleció
\v 19 \w y|strong="H3588"\w* \w me|strong="H3588"\w* \w dijo|strong="H1696"\w*: Muy amado, \w no|strong="H3588"\w* \w temas|strong="H3372"\w*. \w La|strong="H3588"\w* \w paz|strong="H7965"\w* sea \w contigo|strong="H5973"\w*. \w Esfuérzate|strong="H2388"\w* \w y|strong="H3588"\w* aliéntate.
\p \w Y|strong="H3068"\w* \w mientras|strong="H3588"\w* \w él|strong="H5973"\w* \w me|strong="H3588"\w* \w hablaba|strong="H1696"\w*, recobré las fuerzas \w y|strong="H3588"\w* \w dije|strong="H1696"\w*: \w Que|strong="H3588"\w* \w hable|strong="H1696"\w* mi \tl ʼadón\tl*, \w porque|strong="H3588"\w* \w me|strong="H3588"\w* fortaleciste.
\p 
\v 20 \w Entonces|strong="H7725"\w* \w él|strong="H5973"\w* preguntó: ¿Entiendes \w por|strong="H4100"\w* \w qué|strong="H4100"\w* vine \w a|strong="H3068"\w* \w ti|strong="H5973"\w*? \w Ahora|strong="H6258"\w* tengo \w que|strong="H4100"\w* \w volver|strong="H7725"\w* \w para|strong="H5973"\w* luchar \w contra|strong="H5973"\w* \w el|strong="H5973"\w* \w príncipe|strong="H8269"\w* \w de|strong="H5973"\w* \w Persia|strong="H6539"\w*, y \w ciertamente|strong="H2009"\w* \w el|strong="H5973"\w* \w príncipe|strong="H8269"\w* \w de|strong="H5973"\w* \w Grecia|strong="H3120"\w* viene pronto.
\v 21 \w Pero|strong="H3588"\w* \w te|strong="H5921"\w* declararé \w lo|strong="H5921"\w* \w que|strong="H3588"\w* \w está|strong="H5921"\w* escrito \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w la|strong="H5921"\w* verdad. Nadie \w me|strong="H5921"\w* ayuda \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w sino|strong="H3588"\w* \w Miguel|strong="H4317"\w*, \w el|strong="H5921"\w* \w príncipe|strong="H8269"\w* \w de|strong="H5921"\w* ustedes.
\c 11
\s1 Guerras entre diversos pueblos
\p 
\v 1 El primer \w año|strong="H8141"\w* de \w Darío|strong="H1867"\w* el medo, me levanté para ser un estímulo y protección para él.
\p 
\v 2 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w* te \w anunciaré|strong="H5046"\w* \w la|strong="H3605"\w* verdad: \w Mira|strong="H2009"\w*, se levantarán \w aún|strong="H5750"\w* \w tres|strong="H7969"\w* \w reyes|strong="H4428"\w* \w en|strong="H5750"\w* \w Persia|strong="H6539"\w*, y \w el|strong="H3605"\w* \w cuarto|strong="H7243"\w* conseguirá \w grandes|strong="H1419"\w* \w riquezas|strong="H6239"\w*, \w más|strong="H5750"\w* \w que|strong="H6258"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w*. Cuando se fortalezca \w por|strong="H5750"\w* medio \w de|strong="H5750"\w* sus \w riquezas|strong="H6239"\w*, agitará \w a|strong="H3068"\w* \w todos|strong="H3605"\w* contra \w el|strong="H3605"\w* \w reino|strong="H4438"\w* \w de|strong="H5750"\w* \w Grecia|strong="H3120"\w*.
\v 3 Se levantará luego un \w rey|strong="H4428"\w* \w poderoso|strong="H1368"\w* que gobernará con \w gran|strong="H7227"\w* dominio y \w hará|strong="H6213"\w* \w lo|strong="H6213"\w* que quiera.
\v 4 \w Pero|strong="H3588"\w* tan pronto \w como|strong="H3588"\w* \w se|strong="H3808"\w* levante, \w su|strong="H3588"\w* \w reino|strong="H4438"\w* \w será|strong="H7665"\w* \w quebrantado|strong="H7665"\w* \w y|strong="H3588"\w* repartido \w a|strong="H3068"\w* \w los|strong="H3588"\w* cuatro puntos cardinales del \w cielo|strong="H8064"\w*, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w a|strong="H3068"\w* sus descendientes, \w ni|strong="H3808"\w* \w con|strong="H3588"\w* \w el|strong="H3588"\w* poder \w con|strong="H3588"\w* \w el|strong="H3588"\w* \w cual|strong="H3588"\w* \w él|strong="H3588"\w* dominó. \w Porque|strong="H3588"\w* \w su|strong="H3588"\w* \w reino|strong="H4438"\w* \w será|strong="H7665"\w* arrancado \w y|strong="H3588"\w* pasará \w a|strong="H3068"\w* otros fuera \w de|strong="H3588"\w* aquéllos.
\p 
\v 5 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w del|strong="H4480"\w* sur será fuerte, pero uno \w de|strong="H4480"\w* sus \w príncipes|strong="H8269"\w* será \w más|strong="H4480"\w* fuerte \w que|strong="H4480"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* ejercerá un dominio \w mayor|strong="H7227"\w* \w que|strong="H4480"\w* \w él|strong="H5921"\w*.
\v 6 Después \w de|strong="H5414"\w* algunos \w años|strong="H8141"\w* \w harán|strong="H6213"\w* una alianza, y \w la|strong="H1931"\w* \w hija|strong="H1323"\w* del \w rey|strong="H4428"\w* del sur irá \w al|strong="H6256"\w* \w rey|strong="H4428"\w* del \w norte|strong="H6828"\w* \w para|strong="H5414"\w* \w hacer|strong="H6213"\w* \w la|strong="H1931"\w* paz. Pero \w ella|strong="H1931"\w* \w no|strong="H3808"\w* retendrá \w su|strong="H1931"\w* posición \w de|strong="H5414"\w* \w poder|strong="H3581"\w*, \w ni|strong="H3808"\w* \w él|strong="H1931"\w* \w permanecerá|strong="H5975"\w* con \w su|strong="H1931"\w* \w poder|strong="H3581"\w*. \w Ella|strong="H1931"\w* \w será|strong="H1931"\w* \w entregada|strong="H5414"\w* junto con \w los|strong="H1931"\w* \w que|strong="H1931"\w* \w la|strong="H1931"\w* llevaron, con \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w la|strong="H1931"\w* \w engendró|strong="H3205"\w* y con \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w la|strong="H1931"\w* fortaleció \w en|strong="H5975"\w* \w su|strong="H1931"\w* \w tiempo|strong="H6256"\w*.
