\q2 i̱naga bu miniha dungulo holebero.   
\q1
\v 10 I̱na Anduane Homogohondo ka̱i̱ lalu,  
\q1 Anduane Homogo-o í̠ ale mende ai kabe.  
\q1 Í̠na wali agali yagibano karu biamogo bialu  
\q2 agali hongohe karunaga giha howa biamogo bialu mo wirili.  
\q1 Agali homogo hongohe karume yagibano karu mo ko holilono  
\q2 í̠na pele mialu mamage ho harili.   
\b  
\q1
\v 11 Agali ke̱ haga bu karume i̱hondo bi laede halu  
\q2 i̱na mana ko nabinigo tigua i̱na ko biya laga ka.   
\q1
\v 12 I̱na tihondo mana bayale bialu kogola\x + \xo 35.12 \xt Iba 38.20, Yar 18.20, Yo 10.32\x*  
\q2 tigua i̱hondo ko biadai biaga ka.  
\q1 Anidagua bialu haragome  
\q2 i̱naga bu miniha genda ho kogoni.   
\q1
\v 13 Ti warago timbuni bo ngangi i̱na ti dara halu\x + \xo 35.13 \xt Yob 30.25, Md 10.13, Lg 10.6\x*  
\q2 i̱ni mo dindiha howa dara holene aga karulalu tomo nane haruli.  
\q1 Tomo nane howa i̱na Anduane Homogohondo tinaga bi la halu harugoni.   
\q1
\v 14 I̱na i̱ni aba hamene haniniru baba miniha gendaho hagadagua  
\q2 ti dara halu gendaho ibaga bialu harugoni.  
\q1 I̱ agali darabi ai̱ya homene igini haradagua buwa  
\q2 dugu bialu i̱naga bu miniha genda yu harugoni.   
\b  
\q1
\v 15 I̱ genda yu hewangi  
\q2 ti mo mogo buwa i̱ hondo oba halu turu haga biya.  
\q1 Tigua i̱ mo ko holenaga mo ngoai ho hayagoni.  
\q1 Agali maru i̱ de nahendene hearume  
\q2 i̱ mo ko holenaga bi ko lalu i̱ baabo haya.   
\q1
