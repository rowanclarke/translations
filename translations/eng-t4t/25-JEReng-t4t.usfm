\v 28 \w He|strong="H1931"\w* \w sent|strong="H7971"\w* \w a|strong="H3068"\w* letter \w to|strong="H7971"\w* \w us|strong="H5921"\w* \add who are here\add* \w in|strong="H3427"\w* Babylon, saying \w that|strong="H3588"\w* \add we will be here for\add* \w a|strong="H3068"\w* \w long|strong="H7971"\w* \w time|strong="H5921"\w*. \w He|strong="H1931"\w* \w said|strong="H3651"\w* \w that|strong="H3588"\w* \add therefore\add* \w we|strong="H3068"\w* \w should|strong="H3588"\w* \w build|strong="H1129"\w* \w houses|strong="H1004"\w* \w and|strong="H7971"\w* plan \w to|strong="H7971"\w* \w stay|strong="H3427"\w* \w here|strong="H3651"\w*, \w and|strong="H7971"\w* \w plant|strong="H5193"\w* \w gardens|strong="H1593"\w*, \w and|strong="H7971"\w* eat \w the|strong="H5921"\w* \w food|strong="H1004"\w* \w that|strong="H3588"\w* \w is|strong="H1931"\w* produced \w in|strong="H3427"\w* \w the|strong="H5921"\w* \w gardens|strong="H1593"\w*.”   
\p
