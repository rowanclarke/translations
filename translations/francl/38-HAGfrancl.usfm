\p \w Tel|strong="H03426"\w* \w est|strong="H03068"\w* \w ce|strong="H01931"\w* \w peuple|strong="H05971"\w*, \w telle|strong="H02090"\w* \w est|strong="H03068"\w* \w cette|strong="H06440"\w* \w nation|strong="H01471"\w* \w devant|strong="H06440"\w* \w moi|strong="H06440"\w*, — \w oracle|strong="H04853"\w* \w de|strong="H03027"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* ; telles \w sont|strong="H03027"\w* \w toutes|strong="H03606"\w* \w les|strong="H06440"\w* \w œuvres|strong="H04639"\w* \w de|strong="H03027"\w* \w leurs|strong="H06440"\w* \w mains|strong="H03027"\w* : \w ce|strong="H01931"\w* qu’\w ils|strong="H05971"\w* \w offrent|strong="H07126"\w* \w là|strong="H06440"\w* \w est|strong="H03068"\w* \w souillé|strong="H02931"\w*.\f + \fr 2:14 \ft 14. Application. Le peuple est semblable à l’homme devenu impur par l’attouchement d’un cadavre ; tout ce qu’il fait est souillé.\f*   
