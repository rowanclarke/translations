\v 18 \w and|strong="H3548"\w* \w must|strong="H3808"\w* \w bring|strong="H3045"\w* \w a|strong="H3068"\w* \w flawless|strong="H8549"\w* ram \w from|strong="H4480"\w* \w the|strong="H5921"\w* \w flock|strong="H6629"\w*, \w convertible|strong="H6187"\w* \w into|strong="H5921"\w* silver shekels, \w for|strong="H5921"\w* \w a|strong="H3068"\w* guilt \w offering|strong="H4480"\w* \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w priest|strong="H3548"\w*. \w So|strong="H4480"\w* \w the|strong="H5921"\w* \w priest|strong="H3548"\w* \w will|strong="H3808"\w* \w make|strong="H3722"\w* \w atonement|strong="H3722"\w* \w on|strong="H5921"\w* \w his|strong="H5921"\w* \w behalf|strong="H5921"\w* \w for|strong="H5921"\w* \w his|strong="H5921"\w* \w error|strong="H7684"\w* \w which|strong="H1931"\w* \w he|strong="H1931"\w* \w committed|strong="H5921"\w* (\w although|strong="H3808"\w* \w he|strong="H1931"\w* \w himself|strong="H1931"\w* \w had|strong="H3045"\w* \w not|strong="H3808"\w* \w known|strong="H3045"\w* \w it|strong="H1931"\w*) \w and|strong="H3548"\w* \w he|strong="H1931"\w* \w will|strong="H3808"\w* \w be|strong="H3808"\w* \w forgiven|strong="H5545"\w*.
\v 19 \w It|strong="H1931"\w* \w is|strong="H3068"\w* \w a|strong="H3068"\w* guilt \w offering|strong="H3068"\w*; \w he|strong="H1931"\w* \w was|strong="H3068"\w* surely guilty before \w the|strong="H3068"\w* \nd \w Lord|strong="H3068"\w*\nd*.”
\c 6
\p 
\v 1 \w Then|strong="H1696"\w* \w the|strong="H3068"\w* \nd \w Lord|strong="H3068"\w*\nd* \w spoke|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*:
\v 2 “\w When|strong="H5704"\w* \w a|strong="H3068"\w* person sins \w and|strong="H1121"\w* commits \w a|strong="H3068"\w* trespass \w against|strong="H5921"\w* \w the|strong="H3605"\w* \nd Lord\nd* \w by|strong="H5921"\w* deceiving \w his|strong="H3605"\w* \w fellow|strong="H1121"\w* citizen \w in|strong="H5921"\w* \w regard|strong="H5921"\w* \w to|strong="H5704"\w* \w something|strong="H3605"\w* held \w in|strong="H5921"\w* trust, \w or|strong="H5704"\w* \w a|strong="H3068"\w* pledge, \w or|strong="H5704"\w* \w something|strong="H3605"\w* stolen, \w or|strong="H5704"\w* \w by|strong="H5921"\w* extorting \w something|strong="H3605"\w* \w from|strong="H5921"\w* \w his|strong="H3605"\w* \w fellow|strong="H1121"\w* citizen,
\v 3 \w or|strong="H5930"\w* \w has|strong="H3548"\w* found something lost \w and|strong="H3548"\w* denies \w it|strong="H7760"\w* \w and|strong="H3548"\w* swears falsely \w concerning|strong="H5921"\w* \w any|strong="H7760"\w* \w one|strong="H1320"\w* \w of|strong="H4196"\w* \w the|strong="H5921"\w* things \w that|strong="H3548"\w* someone might do \w to|strong="H5921"\w* sin –
\v 4 \w when|strong="H3318"\w* \w it|strong="H3318"\w* happens \w that|strong="H4725"\w* \w he|strong="H3318"\w* sins \w and|strong="H3318"\w* \w he|strong="H3318"\w* \w is|strong="H4725"\w* found guilty, \w then|strong="H3318"\w* \w he|strong="H3318"\w* \w must|strong="H2351"\w* return whatever \w he|strong="H3318"\w* \w had|strong="H4264"\w* stolen, or whatever \w he|strong="H3318"\w* \w had|strong="H4264"\w* extorted, or \w the|strong="H3318"\w* thing \w that|strong="H4725"\w* \w he|strong="H3318"\w* \w had|strong="H4264"\w* held \w in|strong="H3847"\w* trust, or \w the|strong="H3318"\w* lost thing \w that|strong="H4725"\w* \w he|strong="H3318"\w* \w had|strong="H4264"\w* found,
\v 5 \w or|strong="H3808"\w* \w anything|strong="H3808"\w* \w about|strong="H5921"\w* \w which|strong="H4196"\w* \w he|strong="H3808"\w* swears falsely. \w He|strong="H3808"\w* \w must|strong="H3808"\w* restore \w it|strong="H5921"\w* \w in|strong="H5921"\w* full \w and|strong="H6086"\w* add \w one|strong="H3808"\w* fifth \w to|strong="H5921"\w* \w it|strong="H5921"\w*; \w he|strong="H3808"\w* \w must|strong="H3808"\w* give \w it|strong="H5921"\w* \w to|strong="H5921"\w* \w its|strong="H5921"\w* owner \w when|strong="H5921"\w* \w he|strong="H3808"\w* \w is|strong="H6086"\w* found guilty.
\v 6 \w Then|strong="H3808"\w* \w he|strong="H3808"\w* \w must|strong="H3808"\w* bring \w his|strong="H5921"\w* guilt offering \w to|strong="H5921"\w* \w the|strong="H5921"\w* \nd Lord\nd*, \w a|strong="H3068"\w* flawless ram \w from|strong="H5921"\w* \w the|strong="H5921"\w* flock, convertible \w into|strong="H5921"\w* silver shekels, \w for|strong="H5921"\w* \w a|strong="H3068"\w* guilt offering \w to|strong="H5921"\w* \w the|strong="H5921"\w* priest.
\v 7 \w So|strong="H7126"\w* \w the|strong="H6440"\w* priest \w will|strong="H3068"\w* make atonement \w on|strong="H3068"\w* \w his|strong="H3068"\w* behalf \w before|strong="H6440"\w* \w the|strong="H6440"\w* \nd \w Lord|strong="H3068"\w*\nd* \w and|strong="H1121"\w* \w he|strong="H3068"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* forgiven \w for|strong="H6440"\w* whatever \w he|strong="H3068"\w* \w has|strong="H3068"\w* done \w to|strong="H3068"\w* become guilty.”
\s1 Sacrificial Instructions for the Priests: The Burnt Offering
\p 
\v 8 \w Then|strong="H7311"\w* \w the|strong="H3605"\w* \nd \w Lord|strong="H3068"\w*\nd* spoke \w to|strong="H3068"\w* Moses:
\v 9 “Command Aaron \w and|strong="H1121"\w* \w his|strong="H4480"\w* \w sons|strong="H1121"\w*, ‘\w This|strong="H1121"\w* \w is|strong="H1121"\w* \w the|strong="H4480"\w* law \w of|strong="H1121"\w* \w the|strong="H4480"\w* burnt \w offering|strong="H4480"\w*. \w The|strong="H4480"\w* burnt \w offering|strong="H4480"\w* \w is|strong="H1121"\w* \w to|strong="H1121"\w* \w remain|strong="H3498"\w* \w on|strong="H4725"\w* \w the|strong="H4480"\w* hearth \w on|strong="H4725"\w* \w the|strong="H4480"\w* altar \w all|strong="H4480"\w* \w night|strong="H1121"\w* until morning, \w and|strong="H1121"\w* \w the|strong="H4480"\w* fire \w of|strong="H1121"\w* \w the|strong="H4480"\w* altar \w must|strong="H1121"\w* \w be|strong="H1121"\w* kept burning \w on|strong="H4725"\w* \w it|strong="H1121"\w*.
\v 10 \w Then|strong="H5414"\w* \w the|strong="H5414"\w* priest \w must|strong="H3808"\w* \w put|strong="H5414"\w* \w on|strong="H5414"\w* \w his|strong="H5414"\w* linen robe \w and|strong="H2403"\w* \w must|strong="H3808"\w* \w put|strong="H5414"\w* linen leggings \w over|strong="H5414"\w* \w his|strong="H5414"\w* bare flesh, \w and|strong="H2403"\w* \w he|strong="H1931"\w* \w must|strong="H3808"\w* \w take|strong="H5414"\w* \w up|strong="H5414"\w* \w the|strong="H5414"\w* fatty ashes \w of|strong="H2403"\w* \w the|strong="H5414"\w* burnt \w offering|strong="H2403"\w* \w that|strong="H1931"\w* \w the|strong="H5414"\w* fire consumed \w on|strong="H5414"\w* \w the|strong="H5414"\w* altar, \w and|strong="H2403"\w* \w he|strong="H1931"\w* \w must|strong="H3808"\w* \w place|strong="H5414"\w* \w them|strong="H5414"\w* beside \w the|strong="H5414"\w* altar.
\v 11 \w Then|strong="H3068"\w* \w he|strong="H3068"\w* \w must|strong="H1121"\w* \w take|strong="H1121"\w* off \w his|strong="H3605"\w* clothes \w and|strong="H1121"\w* \w put|strong="H3068"\w* \w on|strong="H3068"\w* \w other|strong="H3605"\w* clothes, \w and|strong="H1121"\w* \w he|strong="H3068"\w* \w must|strong="H1121"\w* \w bring|strong="H5060"\w* \w the|strong="H3605"\w* fatty ashes outside \w the|strong="H3605"\w* camp \w to|strong="H3068"\w* \w a|strong="H3068"\w* ceremonially clean \w place|strong="H3605"\w*,
\v 12 \w but|strong="H1696"\w* \w the|strong="H3068"\w* fire \w which|strong="H3068"\w* \w is|strong="H3068"\w* \w on|strong="H3068"\w* \w the|strong="H3068"\w* altar must \w be|strong="H3068"\w* kept burning \w on|strong="H3068"\w* \w it|strong="H1696"\w*. \w It|strong="H1696"\w* must \w not|strong="H1696"\w* \w be|strong="H3068"\w* extinguished. \w So|strong="H1696"\w* \w the|strong="H3068"\w* priest must kindle wood \w on|strong="H3068"\w* \w it|strong="H1696"\w* morning \w by|strong="H3068"\w* morning, \w and|strong="H4872"\w* \w he|strong="H3068"\w* must arrange \w the|strong="H3068"\w* burnt \w offering|strong="H3068"\w* \w on|strong="H3068"\w* \w it|strong="H1696"\w* \w and|strong="H4872"\w* offer \w the|strong="H3068"\w* fat \w of|strong="H3068"\w* \w the|strong="H3068"\w* peace \w offering|strong="H3068"\w* up \w in|strong="H3068"\w* smoke \w on|strong="H3068"\w* \w it|strong="H1696"\w*.
\v 13 \w A|strong="H3068"\w* \w continual|strong="H8548"\w* fire \w must|strong="H1121"\w* \w be|strong="H3068"\w* kept burning \w on|strong="H3117"\w* \w the|strong="H3068"\w* altar. \w It|strong="H7126"\w* \w must|strong="H1121"\w* \w not|strong="H2088"\w* \w be|strong="H3068"\w* extinguished.
\s1 The Grain Offering of the Common Person
\p 
\v 14 “‘\w This|strong="H6213"\w* \w is|strong="H3068"\w* \w the|strong="H5921"\w* law \w of|strong="H3068"\w* \w the|strong="H5921"\w* grain \w offering|strong="H4503"\w*. \w The|strong="H5921"\w* sons \w of|strong="H3068"\w* Aaron \w are|strong="H3068"\w* \w to|strong="H3068"\w* \w present|strong="H7126"\w* \w it|strong="H5921"\w* \w before|strong="H5921"\w* \w the|strong="H5921"\w* \nd \w Lord|strong="H3068"\w*\nd* \w in|strong="H5921"\w* front \w of|strong="H3068"\w* \w the|strong="H5921"\w* altar,
\v 15 \w and|strong="H1121"\w* \w the|strong="H6213"\w* \w priest|strong="H3548"\w* \w must|strong="H1121"\w* \w take|strong="H6213"\w* \w up|strong="H1121"\w* \w with|strong="H3068"\w* \w his|strong="H3068"\w* hand some \w of|strong="H1121"\w* \w the|strong="H6213"\w* choice wheat flour \w of|strong="H1121"\w* \w the|strong="H6213"\w* \w grain|strong="H6999"\w* \w offering|strong="H6999"\w* \w and|strong="H1121"\w* some \w of|strong="H1121"\w* \w its|strong="H8478"\w* olive oil, \w and|strong="H1121"\w* \w all|strong="H6213"\w* \w of|strong="H1121"\w* \w the|strong="H6213"\w* frankincense \w that|strong="H3068"\w* \w is|strong="H3068"\w* \w on|strong="H3068"\w* \w the|strong="H6213"\w* \w grain|strong="H6999"\w* \w offering|strong="H6999"\w*, \w and|strong="H1121"\w* \w he|strong="H6213"\w* \w must|strong="H1121"\w* \w offer|strong="H6213"\w* \w its|strong="H8478"\w* memorial \w portion|strong="H2706"\w* \w up|strong="H1121"\w* \w in|strong="H3068"\w* \w smoke|strong="H6999"\w* \w on|strong="H3068"\w* \w the|strong="H6213"\w* altar \w as|strong="H6213"\w* \w a|strong="H3068"\w* soothing aroma \w to|strong="H3068"\w* \w the|strong="H6213"\w* \nd \w Lord|strong="H3068"\w*\nd*.
\v 16 Aaron \w and|strong="H3548"\w* \w his|strong="H3605"\w* sons \w are|strong="H3548"\w* \w to|strong="H1961"\w* eat what \w is|strong="H3605"\w* \w left|strong="H3548"\w* \w over|strong="H3605"\w* \w from|strong="H1961"\w* \w it|strong="H1961"\w*. \w It|strong="H1961"\w* \w must|strong="H3808"\w* \w be|strong="H1961"\w* eaten unleavened \w in|strong="H3808"\w* \w a|strong="H3068"\w* holy \w place|strong="H1961"\w*; \w they|strong="H3808"\w* \w are|strong="H3548"\w* \w to|strong="H1961"\w* eat \w it|strong="H1961"\w* \w in|strong="H3808"\w* \w the|strong="H3605"\w* courtyard \w of|strong="H3605"\w* \w the|strong="H3605"\w* Meeting Tent.
\v 17 \w It|strong="H1696"\w* must \w not|strong="H1696"\w* \w be|strong="H3068"\w* baked \w with|strong="H3068"\w* yeast. \w I|strong="H3068"\w* \w have|strong="H3068"\w* given \w it|strong="H1696"\w* \w as|strong="H3068"\w* \w their|strong="H3068"\w* portion \w from|strong="H3068"\w* \w my|strong="H3068"\w* gifts. \w It|strong="H1696"\w* \w is|strong="H3068"\w* \w most|strong="H3068"\w* holy, \w like|strong="H3068"\w* \w the|strong="H3068"\w* sin \w offering|strong="H3068"\w* \w and|strong="H4872"\w* \w the|strong="H3068"\w* guilt \w offering|strong="H3068"\w*.
\v 18 \w Every|strong="H3068"\w* \w male|strong="H1121"\w* \w among|strong="H8451"\w* \w the|strong="H6440"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* Aaron \w may|strong="H3068"\w* eat \w it|strong="H1931"\w*. \w It|strong="H1931"\w* \w is|strong="H3068"\w* \w a|strong="H3068"\w* perpetual allotted \w portion|strong="H6944"\w* \w throughout|strong="H6440"\w* \w your|strong="H3068"\w* generations \w from|strong="H6440"\w* \w the|strong="H6440"\w* \w gifts|strong="H6944"\w* \w of|strong="H1121"\w* \w the|strong="H6440"\w* \nd \w Lord|strong="H3068"\w*\nd*. \w Anyone|strong="H1931"\w* \w who|strong="H1931"\w* touches \w these|strong="H1696"\w* \w gifts|strong="H6944"\w* \w must|strong="H1121"\w* \w be|strong="H3068"\w* \w holy|strong="H6944"\w*.’”
\s1 The Grain Offering of the Priests
\p 
\v 19 \w Then|strong="H3548"\w* \w the|strong="H3548"\w* \nd Lord\nd* spoke \w to|strong="H4725"\w* Moses:
\v 20 “\w This|strong="H6942"\w* \w is|strong="H3605"\w* \w the|strong="H3605"\w* offering \w of|strong="H6918"\w* Aaron \w and|strong="H1818"\w* \w his|strong="H3605"\w* sons \w which|strong="H4725"\w* \w they|strong="H5921"\w* \w must|strong="H1818"\w* present \w to|strong="H5921"\w* \w the|strong="H3605"\w* \nd Lord\nd* \w on|strong="H5921"\w* \w the|strong="H3605"\w* day \w when|strong="H5060"\w* \w he|strong="H3605"\w* \w is|strong="H3605"\w* anointed: \w a|strong="H3068"\w* tenth \w of|strong="H6918"\w* \w an|strong="H5921"\w* ephah \w of|strong="H6918"\w* choice wheat flour \w as|strong="H3605"\w* \w a|strong="H3068"\w* continual \w grain|strong="H3605"\w* offering, half \w of|strong="H6918"\w* \w it|strong="H5921"\w* \w in|strong="H5921"\w* \w the|strong="H3605"\w* morning \w and|strong="H1818"\w* half \w of|strong="H6918"\w* \w it|strong="H5921"\w* \w in|strong="H5921"\w* \w the|strong="H3605"\w* evening.
\v 21 \w It|strong="H7665"\w* must \w be|strong="H4325"\w* \w made|strong="H3627"\w* \w with|strong="H3627"\w* olive oil \w on|strong="H3627"\w* \w a|strong="H3068"\w* griddle \w and|strong="H4325"\w* \w you|strong="H7665"\w* must \w bring|strong="H7665"\w* \w it|strong="H7665"\w* well soaked, so \w you|strong="H7665"\w* must present \w a|strong="H3068"\w* grain offering \w of|strong="H3627"\w* \w broken|strong="H7665"\w* \w pieces|strong="H7665"\w* \w as|strong="H4325"\w* \w a|strong="H3068"\w* soothing aroma \w to|strong="H4325"\w* \w the|strong="H7665"\w* \nd Lord\nd*.
\v 22 \w The|strong="H3605"\w* high \w priest|strong="H3548"\w* \w who|strong="H3605"\w* succeeds \w him|strong="H3605"\w* \w from|strong="H2145"\w* among \w his|strong="H3605"\w* sons must \w do|strong="H3605"\w* \w it|strong="H1931"\w*. \w It|strong="H1931"\w* \w is|strong="H1931"\w* \w a|strong="H3068"\w* perpetual statute; \w it|strong="H1931"\w* must \w be|strong="H3548"\w* offered \w up|strong="H3605"\w* \w in|strong="H2145"\w* smoke \w as|strong="H3605"\w* \w a|strong="H3068"\w* \w whole|strong="H3605"\w* \w offering|strong="H3548"\w* \w to|strong="H3605"\w* \w the|strong="H3605"\w* \nd Lord\nd*.
\v 23 \w Every|strong="H3605"\w* \w grain|strong="H3605"\w* \w offering|strong="H2403"\w* \w of|strong="H1818"\w* \w a|strong="H3068"\w* priest \w must|strong="H1818"\w* \w be|strong="H3808"\w* \w a|strong="H3068"\w* \w whole|strong="H3605"\w* \w offering|strong="H2403"\w*; \w it|strong="H3808"\w* \w must|strong="H1818"\w* \w not|strong="H3808"\w* \w be|strong="H3808"\w* eaten.”
\s1 The Sin Offering
\p 
\v 24 Then the \nd Lord\nd* spoke to Moses:
\v 25 “Tell Aaron and his sons, ‘This is the law of the sin offering. In the place where the burnt offering is slaughtered the sin offering must be slaughtered before the \nd Lord\nd*. It is most holy.
\v 26 The priest who offers it for sin is to eat it. It must be eaten in \w a|strong="H3068"\w* holy place, in the court of the Meeting Tent.
\v 27 Anyone who touches its meat must be holy, and whoever spatters some of its blood on \w a|strong="H3068"\w* garment, you must wash whatever he spatters it on in \w a|strong="H3068"\w* holy place.
\v 28 Any clay vessel it is boiled in must be broken, and if it was boiled in \w a|strong="H3068"\w* bronze vessel, then that vessel must be rubbed out and rinsed in water.
\v 29 Any male among the priests may eat it. It is most holy.
\v 30 But any sin offering from which some of its blood is brought into the Meeting Tent to make atonement in the sanctuary must not be eaten. It must be burned up in the fire.
\c 7
\p 
\v 1 “‘\w This|strong="H2063"\w* \w is|strong="H1931"\w* \w the|strong="H1931"\w* \w law|strong="H8451"\w* \w of|strong="H8451"\w* \w the|strong="H1931"\w* guilt offering. \w It|strong="H1931"\w* \w is|strong="H1931"\w* \w most|strong="H6944"\w* \w holy|strong="H6944"\w*.
