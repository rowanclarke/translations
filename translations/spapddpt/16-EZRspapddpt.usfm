\v 26 \w Después|strong="H5921"\w* yo \w pesé|strong="H8254"\w* \w en|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w ellos|strong="H3027"\w* 21,45 toneladas \w de|strong="H5921"\w* \w plata|strong="H3701"\w*, 3.300 toneladas \w en|strong="H5921"\w* objetos \w de|strong="H5921"\w* \w plata|strong="H3701"\w*, 3,3 toneladas \w de|strong="H5921"\w* \w oro|strong="H2091"\w*,  
\v 27 20 \w tazones|strong="H3713"\w* de \w oro|strong="H2091"\w* por valor de 8 kilogramos y \w dos|strong="H8147"\w* objetos de bronce reluciente, \w preciosos|strong="H2896"\w* como el \w oro|strong="H2091"\w*.   
\p
\v 28 Les dije: Ustedes están consagrados \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, y los objetos son \w sagrados|strong="H6944"\w*. La \w plata|strong="H3701"\w* y el \w oro|strong="H2091"\w* son ofrenda \w voluntaria|strong="H5071"\w* para \nd \+w Yavé|strong="H3068"\+w*\nd*, el \nd ʼElohim\nd* de sus antepasados.  
\v 29 Sean vigilantes \w y|strong="H5704"\w* custódienlos \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* los depositen \w en|strong="H5704"\w* las \w cámaras|strong="H3957"\w* del \w Templo|strong="H1004"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w delante|strong="H6440"\w* \w de|strong="H6440"\w* los \w principales|strong="H8269"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H5704"\w* \w levitas|strong="H3881"\w*, \w y|strong="H5704"\w* \w de|strong="H6440"\w* los \w jefes|strong="H8269"\w* \w de|strong="H6440"\w* las \w casas|strong="H1004"\w* paternas \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w en|strong="H5704"\w* Jerusalén.  
\v 30 De este modo los \w sacerdotes|strong="H3548"\w* y \w levitas|strong="H3881"\w* \w recibieron|strong="H6901"\w* la \w plata|strong="H3701"\w* y el \w oro|strong="H2091"\w* \w por|strong="H3881"\w* \w peso|strong="H4948"\w* y los objetos \w para|strong="H4948"\w* llevarlos al \w Templo|strong="H1004"\w* de nuestro \nd ʼElohim\nd* en Jerusalén.   
\s1 El viaje  
\p
\v 31 Entonces salimos \w del|strong="H5921"\w* \w río|strong="H5104"\w* Ahava \w el|strong="H5921"\w* 12 \w del|strong="H5921"\w* \w mes|strong="H2320"\w* \w primero|strong="H7223"\w* \w para|strong="H5921"\w* \w ir|strong="H3212"\w* \w a|strong="H3068"\w* Jerusalén. \w La|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* nuestro \nd ʼElohim\nd* \w estaba|strong="H1961"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H8147"\w*. \w Nos|strong="H5921"\w* \w libró|strong="H5337"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w del|strong="H5921"\w* enemigo \w y|strong="H5921"\w* \w las|strong="H5921"\w* emboscadas \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w*.  
\v 32 Llegamos \w a|strong="H3068"\w* Jerusalén y reposamos \w allí|strong="H8033"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w*.   
\p
\v 33 \w El|strong="H5921"\w* \w cuarto|strong="H7243"\w* \w día|strong="H3117"\w*, \w la|strong="H5921"\w* \w plata|strong="H3701"\w*, \w el|strong="H5921"\w* \w oro|strong="H2091"\w* \w y|strong="H5921"\w* \w los|strong="H1121"\w* \w vasos|strong="H3627"\w* \w del|strong="H5921"\w* \w Templo|strong="H1004"\w* \w de|strong="H5921"\w* nuestro \nd ʼElohim\nd* fueron entregados \w por|strong="H5921"\w* peso \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* Meremot, \w hijo|strong="H1121"\w* \w del|strong="H5921"\w* \w sacerdote|strong="H3548"\w* Urías, Eleazar, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Finees, \w Jozabad|strong="H3107"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Jesuá|strong="H3442"\w*, \w y|strong="H5921"\w* Noadías, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Binúi.  
\v 34 \w Todo|strong="H3605"\w* \w fue|strong="H1931"\w* contado \w por|strong="H3789"\w* \w número|strong="H4557"\w* y \w por|strong="H3789"\w* \w peso|strong="H4948"\w*. \w Todo|strong="H3605"\w* \w fue|strong="H1931"\w* \w escrito|strong="H3789"\w* en \w esa|strong="H1931"\w* ocasión.   
\p
\v 35 Entonces \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H5921"\w* \w cautiverio|strong="H1473"\w* \w que|strong="H5921"\w* regresaron \w del|strong="H5921"\w* exilio ofrecieron 12 \w becerros|strong="H6499"\w*, 96 carneros, 76 \w corderos|strong="H3532"\w* \w por|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w como|strong="H5921"\w* \w holocaustos|strong="H5930"\w* \w al|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*. \w Como|strong="H5921"\w* ofrenda \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w* ofrecieron 12 \w machos|strong="H6842"\w* cabríos, \w como|strong="H5921"\w* \w holocausto|strong="H5930"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 36 Después entregaron los edictos del \w rey|strong="H4428"\w* \w a|strong="H3068"\w* los \tl sátrapas\tl*\f + \fr 8:36 \ft Sátrapa: funcionario persa de alto rango.\f* del \w rey|strong="H4428"\w* y \w a|strong="H3068"\w* los \w gobernadores|strong="H6346"\w* \w de|strong="H5971"\w* Más Allá del \w Río|strong="H5104"\w*, quienes favorecieron \w al|strong="H4428"\w* \w pueblo|strong="H5971"\w* y \w al|strong="H4428"\w* \w Templo|strong="H1004"\w* \w de|strong="H5971"\w* \nd ʼElohim\nd*.   
\c 9  
\s1 Contaminación sexual  
\p
\v 1 Después \w de|strong="H5971"\w* concluirse estas cosas, los \w jefes|strong="H8269"\w* \w llegaron|strong="H5066"\w* \w a|strong="H3068"\w* mí y dijeron: \w El|strong="H5066"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*, los \w sacerdotes|strong="H3548"\w* y los \w levitas|strong="H3881"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* separaron \w de|strong="H5971"\w* los \w pueblos|strong="H5971"\w* \w de|strong="H5971"\w* la tierra en sus repugnancias, \w es|strong="H8441"\w* decir, \w de|strong="H5971"\w* los \w cananeos|strong="H3669"\w*, heteos, ferezeos, \w jebuseos|strong="H2983"\w*, amonitas, moabitas, \w egipcios|strong="H4713"\w* y amorreos.  
\v 2 \w Porque|strong="H3588"\w* \w tomaron|strong="H5375"\w* \w de|strong="H3588"\w* \w las|strong="H1992"\w* \w hijas|strong="H1323"\w* \w de|strong="H3588"\w* \w éstos|strong="H1992"\w* \w para|strong="H3588"\w* \w ellos|strong="H1992"\w* \w y|strong="H3588"\w* \w para|strong="H3588"\w* \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w*. Emparentaron \w la|strong="H3588"\w* \w descendencia|strong="H2233"\w* \w santa|strong="H6944"\w* \w con|strong="H3588"\w* \w la|strong="H3588"\w* \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w pueblos|strong="H5971"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra. \w Los|strong="H1992"\w* magistrados \w y|strong="H3588"\w* \w los|strong="H1992"\w* oficiales \w fueron|strong="H1961"\w* \w los|strong="H1992"\w* \w primeros|strong="H7223"\w* \w que|strong="H3588"\w* \w cometieron|strong="H4604"\w* \w esta|strong="H2088"\w* infidelidad.   
\p
\v 3 Cuando \w oí|strong="H8085"\w* \w hablar|strong="H1697"\w* \w de|strong="H1697"\w* \w este|strong="H2088"\w* suceso, \w rasgué|strong="H7167"\w* mi vestidura y mi \w manto|strong="H4598"\w*, arranqué cabellos \w de|strong="H1697"\w* mi \w cabeza|strong="H7218"\w* y mi \w barba|strong="H2206"\w*, y me senté consternado.  
\v 4 Entonces \w se|strong="H5921"\w* presentaron ante \w mí|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H5921"\w* temblaban ante \w las|strong="H5921"\w* \w Palabras|strong="H1697"\w* \w del|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* infidelidad \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w del|strong="H5921"\w* \w cautiverio|strong="H1473"\w*. Pero yo seguía \w sentado|strong="H3427"\w*, consternado, \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* hora \w del|strong="H5921"\w* sacrificio \w de|strong="H5921"\w* \w la|strong="H5921"\w* llegada \w de|strong="H5921"\w* \w la|strong="H5921"\w* noche.   
\p
\v 5 \w A|strong="H3068"\w* \w la|strong="H5921"\w* hora \w del|strong="H5921"\w* sacrificio \w de|strong="H5921"\w* \w la|strong="H5921"\w* llegada \w de|strong="H5921"\w* \w la|strong="H5921"\w* noche \w me|strong="H5921"\w* levanté \w de|strong="H5921"\w* \w mi|strong="H5921"\w* aflicción. \w Me|strong="H5921"\w* puse \w de|strong="H5921"\w* \w rodillas|strong="H1290"\w* \w con|strong="H5921"\w* \w mi|strong="H5921"\w* vestidura \w y|strong="H5921"\w* \w manto|strong="H4598"\w* \w rasgados|strong="H7167"\w*. \w Extendí|strong="H6566"\w* mis \w manos|strong="H3709"\w* \w hacia|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w mi|strong="H5921"\w* \nd ʼElohim\nd*  
\v 6 \w y|strong="H3588"\w* le dije:  
\p ¡Oh \nd ʼElohim\nd* mío, estoy \w confuso|strong="H3637"\w* \w y|strong="H3588"\w* \w avergonzado|strong="H3637"\w* \w para|strong="H5704"\w* elevar \w mi|strong="H1431"\w* \w rostro|strong="H6440"\w* \w ante|strong="H6440"\w* Ti, \nd ʼElohim\nd* mío, \w porque|strong="H3588"\w* nuestras \w iniquidades|strong="H5771"\w* se \w multiplicaron|strong="H7235"\w* \w por|strong="H3588"\w* \w encima|strong="H4605"\w* \w de|strong="H3588"\w* nuestra \w cabeza|strong="H7218"\w* \w y|strong="H3588"\w* nuestros delitos \w crecieron|strong="H7235"\w* \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w cielo|strong="H8064"\w*!  
\v 7 \w Desde|strong="H5704"\w* los \w días|strong="H3117"\w* \w de|strong="H6440"\w* nuestros antepasados hemos \w pecado|strong="H5771"\w* muchísimo \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*. \w Por|strong="H6440"\w* nuestras \w iniquidades|strong="H5771"\w* nosotros, nuestros \w reyes|strong="H4428"\w* \w y|strong="H5704"\w* nuestros \w sacerdotes|strong="H3548"\w* fuimos entregados \w en|strong="H5704"\w* \w mano|strong="H3027"\w* \w de|strong="H6440"\w* los \w reyes|strong="H4428"\w* \w de|strong="H6440"\w* otras tierras \w a|strong="H3068"\w* la \w espada|strong="H2719"\w*, \w al|strong="H5704"\w* \w cautiverio|strong="H7628"\w*, \w al|strong="H5704"\w* saqueo \w y|strong="H5704"\w* \w a|strong="H3068"\w* la \w confusión|strong="H1322"\w* \w de|strong="H6440"\w* \w rostro|strong="H6440"\w*, \w como|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
\p
\v 8 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, \w por|strong="H5414"\w* un breve \w momento|strong="H7281"\w*, \w hay|strong="H1961"\w* misericordia \w de|strong="H5414"\w* \w parte|strong="H4725"\w* \w de|strong="H5414"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, nuestro \nd ʼElohim\nd*, \w pues|strong="H6258"\w* nos dejaste un remanente escapado y nos \w diste|strong="H5414"\w* una clavija en tu \w Lugar|strong="H4725"\w* \w Santo|strong="H6944"\w* al iluminar \nd ʼElohim\nd* nuestros \w ojos|strong="H5869"\w* y concedernos un \w pequeño|strong="H5414"\w* avivamiento en medio \w de|strong="H5414"\w* nuestra esclavitud.  
\v 9 Somos esclavos, \w pero|strong="H3588"\w* \w en|strong="H5921"\w* nuestra esclavitud nuestro \nd ʼElohim\nd* \w no|strong="H3808"\w* \w nos|strong="H5921"\w* desamparó, \w sino|strong="H3588"\w* \w extendió|strong="H5186"\w* \w misericordia|strong="H2617"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Persia|strong="H6539"\w*, \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w se|strong="H5921"\w* \w nos|strong="H5921"\w* concediera \w la|strong="H5921"\w* preservación \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w vida|strong="H4241"\w*, \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* \w que|strong="H3588"\w* erigiéramos \w el|strong="H5921"\w* \w Templo|strong="H1004"\w* \w de|strong="H5921"\w* nuestro \nd ʼElohim\nd*, restauráramos sus ruinas \w y|strong="H3588"\w* darnos un muro \w en|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H3588"\w* Jerusalén.   
\p
\v 10 \w Pero|strong="H3588"\w* \w ahora|strong="H6258"\w*, \w oh|strong="H4100"\w* \nd ʼElohim\nd* nuestro, ¿\w qué|strong="H3588"\w* diremos después \w de|strong="H3588"\w* \w esto|strong="H2063"\w*? \w Porque|strong="H3588"\w* abandonamos tus \w Mandamientos|strong="H4687"\w*  
\v 11 \w que|strong="H1931"\w* prescribiste \w por|strong="H3027"\w* \w medio|strong="H3027"\w* \w de|strong="H5971"\w* tus esclavos \w profetas|strong="H5030"\w*, quienes dijeron: \w La|strong="H1931"\w* tierra \w que|strong="H1931"\w* van \w a|strong="H3068"\w* poseer \w es|strong="H1931"\w* impura \w a|strong="H3068"\w* causa \w de|strong="H5971"\w* \w la|strong="H1931"\w* repugnancia \w de|strong="H5971"\w* \w los|strong="H1931"\w* \w pueblos|strong="H5971"\w* \w que|strong="H1931"\w* viven en \w ella|strong="H1931"\w*, \w por|strong="H3027"\w* \w sus|strong="H1931"\w* prácticas impuras con las cuales \w la|strong="H1931"\w* \w llenaron|strong="H4390"\w* \w de|strong="H5971"\w* un extremo \w a|strong="H3068"\w* otro.   
\p
\v 12 \w Por|strong="H4616"\w* tanto, \w no|strong="H3808"\w* \w darán|strong="H5414"\w* sus \w hijas|strong="H1323"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* ellos, \w ni|strong="H3808"\w* \w tomarán|strong="H5375"\w* las \w hijas|strong="H1323"\w* \w de|strong="H5704"\w* ellos \w para|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* ustedes, \w ni|strong="H3808"\w* procurarán su \w paz|strong="H7965"\w* \w ni|strong="H3808"\w* su \w bien|strong="H2896"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*, \w a|strong="H3068"\w* fin \w de|strong="H5704"\w* \w que|strong="H3808"\w* sean fortalecidos, coman \w lo|strong="H3808"\w* \w bueno|strong="H2896"\w* \w de|strong="H5704"\w* la tierra \w y|strong="H5704"\w* la dejen \w en|strong="H5704"\w* posesión \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.   
\p
\v 13 \w Pero|strong="H3588"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H3588"\w* \w nos|strong="H5921"\w* sobrevino \w por|strong="H5921"\w* causa \w de|strong="H5921"\w* nuestras \w malas|strong="H7451"\w* \w obras|strong="H4639"\w* \w y|strong="H3588"\w* \w por|strong="H5921"\w* nuestro \w gran|strong="H1419"\w* \w pecado|strong="H5771"\w*, ya \w que|strong="H3588"\w* Tú, \nd ʼElohim\nd* nuestro, \w no|strong="H3588"\w* \w nos|strong="H5921"\w* castigaste \w según|strong="H5921"\w* nuestras \w iniquidades|strong="H5771"\w* \w y|strong="H3588"\w* \w nos|strong="H5921"\w* \w diste|strong="H5414"\w* un remanente \w como|strong="H3588"\w* \w éste|strong="H2063"\w*,  
\v 14 ¿\w volveremos|strong="H7725"\w* \w a|strong="H3068"\w* violar tus \w Mandamientos|strong="H4687"\w* \w al|strong="H5704"\w* emparentar \w con|strong="H5704"\w* \w pueblos|strong="H5971"\w* \w que|strong="H3808"\w* cometen tales repugnancias? ¿\w No|strong="H3808"\w* te airarías contra nosotros \w hasta|strong="H5704"\w* \w consumirnos|strong="H3615"\w*, \w de|strong="H5704"\w* tal modo \w que|strong="H3808"\w* \w no|strong="H3808"\w* quede un remanente \w ni|strong="H3808"\w* sobreviviente?   
\p
\v 15 ¡Oh \nd \+w Yavé|strong="H3068"\+w*, ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*! Tú eres \w justo|strong="H6662"\w*, \w porque|strong="H3588"\w* \w nos|strong="H5921"\w* \w quedó|strong="H7604"\w* un remanente \w hasta|strong="H5921"\w* \w hoy|strong="H3117"\w*. \w Aquí|strong="H2088"\w* estamos \w en|strong="H5921"\w* tu \w Presencia|strong="H6440"\w*, \w a|strong="H3068"\w* pesar \w de|strong="H5921"\w* nuestros delitos, \w porque|strong="H3588"\w* nadie puede estar \w en|strong="H5921"\w* \w pie|strong="H5975"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w Ti|strong="H5921"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* \w esto|strong="H2063"\w*.   
\c 10  
\s1 Arrepentimiento del pueblo  
\p
\v 1 \w Mientras|strong="H3588"\w* \w Esdras|strong="H5830"\w* oraba, confesaba \w y|strong="H3588"\w* \w lloraba|strong="H1058"\w* \w postrado|strong="H5307"\w* \w delante|strong="H6440"\w* del \w Templo|strong="H1004"\w* \w de|strong="H3588"\w* \nd ʼElohim\nd*, una \w gran|strong="H3966"\w* \w multitud|strong="H6951"\w* \w de|strong="H3588"\w* hombres, mujeres \w y|strong="H3588"\w* \w niños|strong="H3206"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w se|strong="H5971"\w* reunió \w en|strong="H3588"\w* torno \w a|strong="H3068"\w* \w él|strong="H3588"\w*. Todo \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w lloraba|strong="H1058"\w* \w amargamente|strong="H1058"\w*.   
\p
\v 2 Entonces Secanías, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Jehiel|strong="H3171"\w*, uno \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Elam|strong="H5867"\w*, tomó \w la|strong="H5921"\w* palabra \w y|strong="H5921"\w* dijo \w a|strong="H3068"\w* \w Esdras|strong="H5830"\w*: \w Nosotros|strong="H5921"\w* fuimos infieles \w hacia|strong="H5921"\w* nuestro \nd ʼElohim\nd*, \w al|strong="H5921"\w* convivir \w con|strong="H5921"\w* mujeres \w extranjeras|strong="H5237"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w pueblos|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra. Pero \w aún|strong="H6258"\w* \w hay|strong="H3426"\w* \w esperanza|strong="H4723"\w* \w para|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* relación \w con|strong="H5921"\w* \w esto|strong="H2063"\w*.  
\v 3 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, \w hagamos|strong="H6213"\w* un \w pacto|strong="H1285"\w* con nuestro \nd ʼElohim\nd* \w para|strong="H6258"\w* expulsar \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w las|strong="H1992"\w* mujeres y \w sus|strong="H1992"\w* hijos, según \w el|strong="H3605"\w* \w consejo|strong="H6098"\w* de mi \nd ʼAdonay\nd* y de \w los|strong="H1992"\w* \w que|strong="H6258"\w* tiemblan ante \w el|strong="H3605"\w* \w Mandamiento|strong="H4687"\w* de nuestro \nd ʼElohim\nd*. Sea \w hecho|strong="H6213"\w* \w esto|strong="H6213"\w* de acuerdo con \w la|strong="H3605"\w* \w Ley|strong="H8451"\w*.  
\v 4 ¡\w Levántate|strong="H6965"\w*, \w porque|strong="H3588"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w está|strong="H6965"\w* \w la|strong="H5921"\w* tarea, \w y|strong="H3588"\w* \w nosotros|strong="H5973"\w* estaremos \w contigo|strong="H5973"\w*! ¡\w Esfuérzate|strong="H2388"\w*, \w y|strong="H3588"\w* actúa!   
\p
\v 5 Entonces \w Esdras|strong="H5830"\w* se \w levantó|strong="H6965"\w* y ordenó \w que|strong="H1697"\w* \w los|strong="H3605"\w* \w principales|strong="H8269"\w* \w sacerdotes|strong="H3548"\w*, \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* y \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* juraran \w que|strong="H1697"\w* harían \w de|strong="H1697"\w* acuerdo con \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w*. \w Y|strong="H3068"\w* \w así|strong="H2088"\w* \w juraron|strong="H7650"\w*.  
\v 6 \w Esdras|strong="H5830"\w* \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w de|strong="H5921"\w* \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w Templo|strong="H1004"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd* \w y|strong="H3588"\w* entró \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cámara|strong="H3957"\w* \w de|strong="H5921"\w* \w Johanán|strong="H3076"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Eliasib. \w Cuando|strong="H3588"\w* estuvo \w allí|strong="H8033"\w* \w no|strong="H3808"\w* comió \w pan|strong="H3899"\w* \w ni|strong="H3808"\w* \w bebió|strong="H8354"\w* \w agua|strong="H4325"\w*, \w pues|strong="H3588"\w* \w estaba|strong="H1004"\w* afligido \w por|strong="H5921"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* infidelidad \w de|strong="H5921"\w* \w los|strong="H1121"\w* deportados.   
\p
