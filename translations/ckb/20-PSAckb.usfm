\id PSA - Biblica® Open Kurdi Sorani Standard Version 
\h زەبوورەکان 
\toc1 زەبوورەکان 
\toc2 زەبوورەکان 
\toc3 زەبوورەکان 
\mt1 زەبوورەکان 
\c 1  
\ms1 کۆکراوەی بەشی یەکەم 
\mr زەبوورەکانی 1‏–41 
\cl زەبووری 1 
\q1  
\v 1 خۆزگە دەخوازرێت بەو کەسەی 
\q2 بەپێی ڕاوێژی بەدکاران ناڕوات و 
\q1 لە ڕێگای گوناهباران ڕاناوەستێت و 
\q2 لە کۆڕی گاڵتەجاڕان دانانیشێت. 
\q1  
\v 2 بەڵکو ئارەزووی ئەو لە فێرکردنی\f + \fr 1:2 \ft عیبری: \+tl تەورات‏\+tl*.‏\f* یەزدانە، 
\q2 شەو و ڕۆژ لە فێرکردنەکەی ورد دەبێتەوە. 
\q1  
\v 3 وەک دارێک وایە کە لەدەم جۆگەی ئاو ڕوابێت و 
\q2 لە وەرزی خۆیدا بەرهەم بدات و 
\q1 گەڵاکانی هەرگیز وشک نەبن، 
\q2 لە هەموو کارێک سەرکەوتوو دەبێت. 
\b  
\q1  
\v 4 بێگومان بەدکاران وانین، 
\q2 بەڵکو وەک کا وان کاتێک با پەرشوبڵاوی دەکاتەوە. 
\q1  
\v 5 بۆیە نە بەدکاران لەبەردەم دادوەری بێتاوانن، 
\q2 نە گوناهبارانیش لە کۆڕی ڕاستودروستان دادەنیشن. 
\b  
\q1  
\v 6 یەزدان چاودێری ڕێگای ڕاستودروستان دەکات، 
\q2 بەڵام ڕێگای بەدکاران لەناودەچێت. 
\c 2  
\cl زەبووری 2 
\q1  
\v 1 بۆچی نەتەوەکان دەوروژێن و 
\q2 گەلان پیلان لە شتی پووچ دەگێڕن؟ 
\q1  
\v 2 پاشایانی زەوی خۆیان ڕێک دەخەن، 
\q2 سەرۆکەکانیان پێکەوە کۆدەبنەوە 
\q1 لە دژی یەزدان و مەسیحەکەی\f + \fr 2:2 \ft بە زمانی عیبری پێی دەگوترێ \+tl مەشیخ‏\+tl* یان \+tl مەشیح‏\+tl*، واتا هەڵبژێردراو بە دەستی پێغەمبەر و بە چەورکردن بە ڕۆن بۆ پاشایەتی، بڕوانە \xt دەرچوون 30‏:22‏-31‏ و یەکەم ساموئێل 9‏:16؛ 10‏:1.‏\ft ‏\f* و دەڵێن: 
\q1  
\v 3 «با کۆتەکانیان بشکێنین و 
\q2 زنجیرەکانیان لە خۆمان بکەینەوە.» 
\b  
\q1  
\v 4 ئەوەی لە ئاسمان دانیشتووە پێدەکەنێت، 
\q2 پەروەردگار گاڵتەیان پێ دەکات. 
\q1  
\v 5 ئینجا بە تووڕەیی خۆی قسەیان بۆ دەکات، 
\q2 بە هەڵچوونی خۆی دەیانتۆقێنێت: 
\q1  
\v 6 «من پاشای خۆمم لەسەر سییۆن\f + \fr 2:6 \ft سییۆن یان زایۆن، چیاکە لە ئۆرشەلیم، وەک نازناو بۆ ئۆرشەلیم بەکاردێت.‏\f* داناوە، 
\q2 لەسەر کێوی پیرۆزی خۆم.» 
\b  
\q1  
\v 7 من فەرمانی یەزدانتان پێ ڕادەگەیەنم: 
\q2 پێی فەرمووم: «تۆ کوڕی منی، 
\q2 من ئەمڕۆ بوومە باوکت. 
\q1  
\v 8 داوام لێ بکە، نەتەوەکان دەکەم بە میراتت، 
\q2 ئەوپەڕی زەوی دەکەم بە موڵکی تۆ. 
\q1  
\v 9 بە گۆچانێکی ئاسنین دەیانشکێنیت و 
\q2 وەک گۆزەیەکی گڵین وردوخاشیان دەکەیت.» 
\b  
\q1  
\v 10 بۆیە، ئەی پاشایان، وریابن، 
\q2 سەرۆکەکانی زەوی، ئاگاداربن. 
\q1  
\v 11 بە ترسەوە یەزدان بپەرستن، 
\q2 بە لەرزەوە دڵخۆش بن. 
\q1  
\v 12 کوڕەکە ماچ\f + \fr 2:12 \ft ماچکردنی پێی کوڕی پاشا وەک ملکەچبوونی.‏\f* بکەن، نەوەک تووڕە ببێت و 
\q2 لە ڕێگای خۆتان بفەوتێن، 
\q1 چونکە تووڕەیی ئەو زوو دێتە جۆش. 
\q2 خۆزگە دەخوازرێ بە هەموو ئەوانەی پەنا دەبەنە بەر ئەو. 
\c 3  
\cl زەبووری 3 
\d زەبوورێکی داودە کاتێک لە دەستی ئەبشالۆمی\f + \fr 3:0 \ft سێیەم کوڕی داود بوو، ناکۆکی لەگەڵ داودی باوکی هەبوو و سەرکردایەتی یاخیبوونێکی کرد لە دژی. بۆ زانیاری زیاتر بڕوانە دووەم ساموئێل بەشەکانی 13‏–18.‏\f* کوڕی هەڵات. 
\q1  
\v 1 ئەی یەزدان، دوژمنانم چەند زۆرن! 
\q2 چەند زۆرن لە دژم سەریان هەڵداوە! 
\q1  
\v 2 زۆر کەس لەبارەی منەوە دەڵێن: 
\q2 «خودا ڕزگاری ناکات.»\f + \fr 3:2 \ft لە دەقی عیبری لێرە و لە ئایەتی 4 و 8، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 3 بەڵام تۆ ئەی یەزدان، قەڵغانی منیت، 
\q2 شکۆمەندی منیت و سەرم بەرز دەکەیتەوە. 
\q1  
\v 4 پڕ بە دەنگم هاوار بۆ یەزدان دەکەم، 
\q2 ئەویش لە کێوی پیرۆزی خۆیەوە وەڵامم دەداتەوە. 
\b  
\q1  
\v 5 ڕادەکشێم و دەخەوم، 
\q2 بەئاگادێمەوە، چونکە یەزدان پشتگیریم دەکات. 
\q1  
\v 6 لە دەیان هەزار کەس ناترسم، 
\q2 ئەوانەی دەوریان گرتووم. 
\b  
\q1  
\v 7 ئەی یەزدان، ڕاپەڕە! 
\q2 ئەی خودای من، ڕزگارم بکە! 
\q1 بێگومان لە بناگوێی دوژمنەکانم دەدەیت و 
\q2 کەڵبەی بەدکاران وردوخاش دەکەی. 
\b  
\q1  
\v 8 ڕزگاری لە یەزدانەوەیە، 
\q2 با بەرەکەتەکەت لەسەر گەلەکەت بێت. 
\c 4  
\cl زەبووری 4 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بە ئامێرە ژێدارەکان. زەبوورێکی داود. 
\q1  
\v 1 ئەی خودای ڕاستودروستم، 
\q2 کە لێت دەپاڕێمەوە وەڵامم بدەوە. 
\q1 لە تەنگانەدا بە هانامەوە وەرە، 
\q2 لەگەڵم میهرەبان بە و گوێ لە نوێژەکەم بگرە. 
\b  
\q1  
\v 2 ئەی خەڵکینە، هەتا کەی شکۆی من دەگۆڕن بە شورەیی؟ 
\q2 هەتا کەی حەز لە قسەی پووچ دەکەن و بەدوای درۆدا دەگەڕێن؟\f + \fr 4:2 \ft لە دەقی عیبری لێرە و لە ئایەتی 4، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 3 بەڵام بزانن کە یەزدان دڵسۆزەکانی بۆ خۆی تەرخان کردووە. 
\q2 یەزدان گوێم لێ دەگرێت کاتێک لێی دەپاڕێمەوە. 
\b  
\q1  
\v 4 کاتێک تووڕە دەبن، گوناه مەکەن، 
\q2 بەڵام کە لەسەر نوێنەکانتانن 
\q2 لە دڵی خۆتاندا لێکی بدەنەوە و بێدەنگ بن. 
\q1  
\v 5 قوربانیی ڕاستودروست بکەن و 
\q2 پشت بە یەزدان ببەستن. 
\b  
\q1  
\v 6 زۆر کەس دەڵێن: «کێ چاکەمان نیشان دەدات؟» 
\q2 ئەی یەزدان، با ڕووناکی ڕووی تۆ بەسەرماندا هەڵبێت\f + \fr 4:6 \ft خودا بە چاکەکانی بەسەرمان بکاتەوە، بڕوانە \xt سەرژمێری 6‏:24‏-26.‏\ft ‏\f*. 
\q1  
\v 7 تۆ خۆشییەکی وات خستووەتە دڵی منەوە 
\q2 زۆر لەوانە زیاترە کە دانەوێڵە و شەرابیان زۆرە. 
\b  
\q1  
\v 8 ئەی یەزدان، بە ئاشتی پاڵ دەدەمەوە و دەخەوم، 
\q2 چونکە تەنها تۆ بە ئاسوودەیی نیشتەجێم دەکەیت. 
\c 5  
\cl زەبووری 5 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بە شمشاڵ.  // زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، گوێ لە قسەکانم بگرە، 
\q2 لە ناڵەم وردبەرەوە. 
\q1  
\v 2 گوێ لە هاوارم بگرە، ئەی پاشا و خودام، 
\q2 چونکە لێت دەپاڕێمەوە. 
\b  
\q1  
\v 3 ئەی یەزدان، بەیانییان گوێ لە دەنگم دەگریت، 
\q2 بەیانییان خۆم ئامادە دەکەم بۆ نوێژکردن و چاوەڕێ دەکەم، 
\q1  
\v 4 چونکە تۆ خودایەک نیت خراپەت پێ خۆش بێت، 
\q2 بەدکار لەگەڵت نیشتەجێ نابێت. 
\q1  
\v 5 لووتبەرزەکان لەبەرچاوت ناوەستن، 
\q2 ڕقت لە هەموو بەدکارێک دەبێتەوە، 
\q1  
\v 6 ئەوانەی بە درۆ قسە دەکەن تۆ لەناویان دەبەیت، 
\q2 یەزدان قێزی لە کەسی خوێنڕێژ و فێڵباز دەبێتەوە. 
\q1  
\v 7 بەڵام من، بەهۆی خۆشەویستییە نەگۆڕەکەت، دێمە ناو ماڵی تۆ، 
\q2 بە ترسی تۆوە بەرەو پەرستگا پیرۆزەکەت کڕنۆش دەبەم. 
\b  
\q1  
\v 8 ئەی یەزدان، لەبەر دوژمنەکانم بە ڕاستودروستی خۆت ڕێنماییم بکە، 
\q2 ڕێگای خۆت تەخت بکە لەپێشم، 
\q1  
\v 9 چونکە لەسەر زمانی ئەوان قسەی ڕاست نییە، 
\q2 ناوەڕۆکیان لەناوچوونە، 
\q1 قوڕگیان گۆڕێکی کراوەیە، 
\q2 زمانیان فێڵی لێ دەڕژێت. 
\q1  
\v 10 ئەی خودایە، تاوانباریان بکە! 
\q2 با بکەونە ناو تۆڕی پیلانی خۆیانەوە، 
\q1 لەبەر زۆری گوناهەکانیان دەریانبکە، 
\q2 چونکە لە دژی تۆ یاخی بوون. 
\q1  
\v 11 بەڵام با هەموو ئەوانەی پەنا بە تۆ دەگرن دڵخۆش بن، 
\q2 با هەتاهەتایە گۆرانی شادی بڵێن. 
\q1 دەیانخەیتە ژێر سێبەری خۆتەوە، 
\q2 هەتا هەموو ئەوانەی ناوی تۆیان خۆشدەوێت بە تۆ شاد بن. 
\b  
\q1  
\v 12 بێگومان ئەی یەزدان، تۆ ڕاستودروستان بەرەکەتدار دەکەیت، 
\q2 بە ڕەزامەندی خۆت وەک قەڵغان دەوریان دەدەیت. 
\c 6  
\cl زەبووری 6 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بە قیسارە بە شێوەی شیمینیت\f + \fr 6:0 \ft دەستەواژەیەکی بواری مۆسیقایە.‏\f*. زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، لە کاتی تووڕەیی خۆت سەرزەنشتم مەکە، 
\q2 لە کاتی تووڕەییت تەمبێم مەکە. 
\q1  
\v 2 ئەی یەزدان، لەگەڵم میهرەبان بە، چونکە داهێزراوم، 
\q2 ئەی یەزدان، چاکم بکەرەوە، چونکە ئێسقانەکانم ژان دەکات. 
\q1  
\v 3 گیانم زۆر دەلەرزێت، 
\q2 هەتا کەی، ئەی یەزدان، هەتا کەی؟ 
\b  
\q1  
\v 4 ئەی یەزدان، بگەڕێوە و ژیانم ڕزگار بکە، 
\q2 بە خۆشەویستییە نەگۆڕەکەت دەربازم بکە، 
\q1  
\v 5 چونکە مردوو ناتوانێت یادی تۆ بکات. 
\q2 لە جیهانی مردووان\f + \fr 6:5 \ft عیبری: \+tl شیۆل‏\+tl*، ئەو شوێنەیە کە لەدوای مردن ڕۆحی مرۆڤ دەچێتە ئەوێ هەتا ڕۆژی لێپرسینەوە.‏\f* کێ ستایشت دەکات؟ 
\b  
\q1  
\v 6 ئەوەندەم ناڵاند شەکەت بووم! 
\q1 هەموو شەوێک نوێنەکەم نوقومی فرمێسک دەکەم، 
\q2 جێگاکەم تەڕ دەکەم. 
\q1  
\v 7 چاوەکانم لە خەفەتان کز بوون، 
\q2 بەهۆی دوژمنەکانمەوە بێهێز بوون. 
\b  
\q1  
\v 8 ئەی هەموو بەدکاران، لێم دوور بکەونەوە، 
\q2 چونکە یەزدان گوێی لە دەنگی گریانم بووە. 
\q1  
\v 9 یەزدان گوێی لە پاڕانەوەم بووە، 
\q2 یەزدان نوێژم وەردەگرێت. 
\q1  
\v 10 هەموو دوژمنەکانم بە توندی شەرمەزار و ڕیسوا دەبن، 
\q2 لەناکاو سەرشۆڕی دایاندەگرێت و شەرمەزار دەبن. 
\c 7  
\cl زەبووری 7 
\d لاواندنەوەی داود سەبارەت بە وتەکانی کوشی بنیامینی کە بە گۆرانی بۆ یەزدانی گوتووە. 
\q1  
\v 1 ئەی یەزدان، خودای من، پەنا دەهێنمە بەر تۆ، 
\q2 لەوانەی ڕاوم دەنێن ڕزگارم بکە و دەربازم بکە، 
\q1  
\v 2 ئەگینا وەک شێر پەلامارم دەدەن، 
\q2 پارچەپارچەم دەکەن و کەسیش نییە دەربازم بکات. 
\b  
\q1  
\v 3 ئەی یەزدان، خودای من، ئەگەر من وام کردووە، 
\q2 ئەگەر دەستەکانم ناڕەوایەتییان کردووە، 
\q1  
\v 4 ئەگەر خراپەم کردووە دەرهەق بەوەی بە ئاشتی لەگەڵمدا دەژیێت، 
\q2 یان بەبێ هۆ دوژمنەکەمم تاڵان کردووە، 
\q1  
\v 5 با دوژمن ڕاوم بنێت و پێشم لێ بگرێت، 
\q2 با ژیانم پێشێل بکات لەسەر زەوی و 
\q2 شکۆمەندیم بکەوێتە سەر خاک.\f + \fr 7:5 \ft لە دەقی عیبری وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 6 ئەی یەزدان، لە تووڕەیی خۆت ڕاپەڕە، 
\q2 لە دژی قینی دوژمنەکانم ڕاستبەرەوە. 
\q2 ئەی خودای من هەستە، فەرمان بکە بۆ دادپەروەری. 
\q1  
\v 7 کۆڕی گەلان لە دەوری خۆت ببەستە و 
\q2 لە بەرزاییەوە فەرمانڕەوایەتییان لەسەر بکە. 
\q1  
\v 8 با یەزدان دادوەری گەلان بکات. 
\q2 ئەی یەزدان، بەگوێرەی ڕاستودروستییەکەم بێتاوانیم دەربخە، 
\q2 بەگوێرەی دروستییەکەم. 
\q1  
\v 9 ئەی خودای ڕاستودروست، 
\q2 کە مێشک و دڵەکان دەپشکنی، 
\q1 خراپەی بەدکاران مەهێڵە، 
\q2 بەڵام ڕاستودروستان بچەسپێنە. 
\b  
\q1  
\v 10 خودای هەرەبەرز قەڵغانی منە، 
\q2 ئەوەی دڵڕاستەکان ڕزگار دەکات، 
\q1  
\v 11 خودا دادوەرێکی ڕاستودروستە، 
\q2 هەموو ڕۆژێکیش تووڕە دەبێت. 
\q1  
\v 12 ئەگەر کەسێک نەگەڕێتەوە، 
\q2 خودا شمشێرەکەی خۆی تیژ دەکات، 
\q2 کەوانەکەی دەچەمێنێتەوە و ژێیەکەی توند دەکات. 
\q1  
\v 13 چەکی کوشندەی خۆی ئامادە کردووە، 
\q2 تیرەکانی کردووەتە تیری ئاگرین. 
\b  
\q1  
\v 14 ببینە کەسی بەدکار بە خراپەوە ژانی گرتووە، 
\q2 بە ئاژاوە سکی پڕ بووە و درۆی دەبێت. 
\q1  
\v 15 چاڵێک هەڵدەکەنێت و قووڵی دەکات، 
\q2 بەڵام خۆی دەکەوێتە ئەو چاڵەی هەڵیکەندووە. 
\q1  
\v 16 ئاژاوەکەی دەگەڕێتەوە سەر خۆی و 
\q2 توندوتیژییەکەشی بەسەر سەری خۆیدا دەبارێت. 
\b  
\q1  
\v 17 ستایشی یەزدان دەکەم بۆ ڕاستودروستییەکەی، 
\q2 گۆرانی ستایش دەڵێم بۆ ناوی یەزدانی هەرەبەرز. 
\c 8  
\cl زەبووری 8 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، لەسەر ئاوازی گتیت\f + \fr 8:0 \ft دەستەواژەیەکی بواری مۆسیقایە.‏\f*. 
\d زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدانی پەروەردگارمان، 
\q2 ناوت لە سەراپای زەویدا چەند شکۆدارە! 
\b  
\q1 تۆ شکۆمەندی خۆتت خستووەتە سەرووی ئاسمان. 
\q1  
\v 2 بە ستایشی منداڵان و شیرەخۆران 
\q2 هێزت بۆ خۆت دامەزراندووە لە دژی ناحەزەکانت، 
\q2 هەتا دوژمنە تۆڵەسێنەرەکانی پێ دەمکوت بکەیتەوە. 
\q1  
\v 3 کاتێک تەماشای ئاسمانت دەکەم، 
\q2 کە پەنجەکانی تۆ دروستی کردووە، 
\q2 مانگ و ئەستێرەکان، کە تۆ لەوێ داتناون، 
\q1  
\v 4 مرۆڤ چییە تاکو بیری لێ بکەیتەوە؟ 
\q2 کوڕی مرۆڤ چییە تاکو بایەخی پێبدەیت؟ 
\b  
\q1  
\v 5 کەمێک لە فریشتەکانت\f + \fr 8:5 \ft عیبری: خوداکان، بە واتای بوونەوەرە ئاسمانییەکان.‏\f* بە کەمتر دانا و 
\q2 تاجی شکۆ و ڕێزت خستە سەری. 
\q1  
\v 6 دەسەڵاتت داوەتێ بەسەر هەموو دەستکردی خۆتدا، 
\q2 تۆ هەموو شتێکت خستووەتە ژێر پێی ئەو: 
\q1  
\v 7 هەموو مەڕ و مانگاکان، 
\q2 هەروەها ئاژەڵی کێوی، 
\q1  
\v 8 باڵندەی ئاسمان و ماسی دەریا و 
\q2 هەرچی لەناو دەریادا دەژی. 
\b  
\q1  
\v 9 ئەی یەزدانی پەروەردگارمان، 
\q2 ناوت لە سەراپای زەویدا چەند شکۆدارە! 
\c 9  
\cl زەبووری 9 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، لەسەر ئاوازی «مردنی کوڕەکە». زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، بە هەموو دڵەوە ستایشت دەکەم، 
\q2 هەموو کارە سەرسوڕهێنەرەکانت ڕادەگەیەنم. 
\q1  
\v 2 بە تۆوە شاد و دڵخۆش دەبم، 
\q2 ئەی هەرەبەرز، گۆرانی ستایش بۆ ناوی تۆ دەڵێم. 
\b  
\q1  
\v 3 کاتێک دوژمنەکانم بەرەو پاش هەڵدێن، 
\q2 لەبەردەمی تۆدا دەکەون و لەناودەچن، 
\q1  
\v 4 چونکە دادپەروەرانە دادوەریت بۆ کردووم، 
\q2 دادوەرێکی ڕاستودروستی لەسەر تەختی خۆت دانیشتووی. 
\q1  
\v 5 تۆ نەتەوەکانت سەرزەنشت کردووە و بەدکارانت لەناوبردووە، 
\q2 هەتاهەتایە ناویانت سڕیوەتەوە. 
\q1  
\v 6 دوژمنانت تووشی لەناوچوونی بێ کۆتایی کردووە، 
\q2 شارەکانیانت وێران کردووە، 
\q2 تەنانەت بیرەوەریشیان نامێنێت. 
\b  
\q1  
\v 7 بەڵام یەزدان هەتاهەتایە دادەنیشێت، 
\q2 تەختی خۆی بۆ دادوەری دامەزراندووە. 
\q1  
\v 8 بە ڕاستودروستی دادوەری جیهان دەکات، 
\q2 بە دادپەروەری گەلان حوکم دەدات. 
\q1  
\v 9 یەزدان پەناگای زۆرلێکراوانە، 
\q2 قەڵایە لە کاتی تەنگانەدا. 
\q1  
\v 10 ئەوانەی بە ناوی تۆ ئاشنان\f + \fr 9:10 \ft بە واتای ناسینی خودا و کەسایەتییەکەی.‏\f* پشتت پێ دەبەستن، 
\q2 چونکە ئەی یەزدان، قەت تۆ وازت لەوانە نەهێناوە کە حەز دەکەن لە تۆ نزیک ببنەوە. 
\b  
\q1  
\v 11 گۆرانی ستایش بڵێن بۆ یەزدان کە لە سییۆن\f + \fr 9:11 \ft ناوێکی ئەدەبییە بۆ شاری ئۆرشەلیم.‏\f* نیشتەجێیە، 
\q2 لەنێو نەتەوەکان کردارەکانی ڕابگەیەنن، 
\q1  
\v 12 چونکە ئەوەی تۆڵەی خوێن دەکاتەوە یادی دەکرێتەوە، 
\q2 هاواری ستەملێکراوان لەبیرناکات. 
\b  
\q1  
\v 13 ئەی یەزدان، ببینە چ ئازارێک بەدەست دوژمنەکانمەوە دەکێشم! 
\q2 لەگەڵم میهرەبان بە و لە دەروازەکانی مردن ڕزگارم بکە\f + \fr 9:13 \ft عیبری: بەرزم بکەرەوە، بە واتای پارێزگار و فریاکەوتن.‏\f*، 
\q1  
\v 14 تاکو لەبەردەم دەروازەکانی سییۆنی کچ\f + \fr 9:14 \ft مەبەست لە شاری سییۆنە، ئۆرشەلیم.‏\f* بە ستایشی تۆوە بدوێم، 
\q2 هەروەها بە ڕزگاریی تۆوە دڵخۆش بم. 
\b  
\q1  
\v 15 نەتەوەکان کەوتوونەتە ئەو چاڵەی کە خۆیان هەڵیانکەندبوو، 
\q2 پێیان بەو تۆڕەوە بووە کە نابوویانەوە. 
\q1  
\v 16 یەزدان بە دادپەروەری ناسراوە، 
\q2 بەدکاران دەکەونە داوی کردەوەی دەستی خۆیان.\f + \fr 9:16 \ft لە دەقی عیبری لێرە وشەی \+tl هیگایۆن‏\+tl* و \+tl سەلاه‏\+tl* هەیە و لە کۆتایی ئایەتی 20 وشەی \+tl سەلاه‏\+tl* هەیە، کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 17 بەدکاران بەرەو جیهانی مردووان دەڕۆن، 
\q2 هەروەها هەموو ئەو نەتەوانەی کە خودا لەبیر دەکەن. 
\q1  
\v 18 بەڵام نەداران هەتاسەر لەبیر ناکرێن، 
\q2 ئومێدی ستەملێکراو هەتاهەتایە لەناو ناچێت. 
\b  
\q1  
\v 19 ئەی یەزدان ڕاپەڕە، مەهێڵە مرۆڤ سەربکەوێت، 
\q2 با نەتەوەکان لەبەردەم تۆ دادگایی بکرێن. 
\q1  
\v 20 ئەی یەزدان، ترس بخەرە دڵیانەوە، 
\q2 با نەتەوەکان بزانن کە تەنها مرۆڤن. 
\c 10  
\cl زەبووری 10 
\q1  
\v 1 ئەی یەزدان، بۆچی لە دوورەوە وەستاویت؟ 
\q2 بۆچی لە کاتی تەنگانە خۆت دەشاریتەوە؟ 
\b  
\q1  
\v 2 بەدکاران لە لووتبەرزییان ڕاوی هەژار دەکەن، 
\q2 گرفتاری ئەو پیلانەیان دەکەن کە بۆیان دادەنێن. 
\q1  
\v 3 کەسی بەدکار شانازی بە ئارەزووە خراپەکانی دڵییەوە دەکات، 
\q2 داوای بەرەکەت بۆ چاوبرسی دەکات و کفر بە یەزدان دەکات. 
\q1  
\v 4 بەدکار لە لووتبەرزی خۆی باکی بە یەزدان نییە، 
\q2 هەموو بیرکردنەوەی ئەوەیە کە: «خودا نییە.» 
\q1  
\v 5 هەمیشە ڕێگاکانی سەرکەوتووە، 
\q2 لە حوکمەکانی خودا ناگات، 
\q2 ناحەزەکانی خۆی بە هیچ دەزانێت. 
\q1  
\v 6 لە دڵی خۆیدا دەڵێت: «هیچ شتێک ناملەقێنێت، 
\q2 هەموو کاتێک دڵخۆش دەبم و هەرگیز تووشی بەڵا نابم.» 
\b  
\q1  
\v 7 دەمی پڕە لە نەفرەت و درۆ و هەڕەشە، 
\q2 بەڵا و گوناه لەبن زمانیەتی. 
\q1  
\v 8 لە نزیکی گوندەکان بۆسە دادەنێت، 
\q2 خۆی دەشارێتەوە بۆ کوشتنی بێتاوانان. 
\q1  
\v 9 وەک شێر خۆی مات دەکات، 
\q2 خۆی مات دەکات بۆ گرتنی بەستەزمانان، 
\q2 بەستەزمانان گرفتاری ئەو داوە دەکات کە بۆی ناونەتەوە و ڕاپێچیان دەکات. 
\q1  
\v 10 نێچیرەکانی وردوخاش دەکات، دەڕووخێن، 
\q2 دەکەونە ژێر هێزی ئەوەوە. 
\q1  
\v 11 لە دڵی خۆیدا دەڵێت: «خودا ئاگای لێ نییە، 
\q2 چاوی خۆی نوقاندووە و هەرگیز نامبینێت.» 
\b  
\q1  
\v 12 ئەی یەزدان، ڕاپەڕە! ئەی خودایە، دەستت بەرز بکەرەوە، 
\q2 ستەملێکراوان لەبیر مەکە. 
\q1  
\v 13 چۆن دەبێت کەسی بەدکار کفر بە خودا بکات؟ 
\q2 بۆچی لە دڵی خۆیدا بڵێت: «خودا لێم ناپێچێتەوە؟» 
\q1  
\v 14 بەڵام تۆ ئەی خودایە، ئازار و تەنگانە دەبینیت، 
\q2 لێت دیارە و کاردانەوەت هەیە، 
\q1 ستەملێکراوان خۆیان داوەتە دەستی تۆ، 
\q2 تۆش هەمیشە یارمەتیدەری هەتیوانیت. 
\q1  
\v 15 بازووی بەدکاران و خراپەکاران بشکێنە، 
\q2 تەنانەت لەسەر ئەو خراپانەش لێیان بپێچەوە کە نابینرێن. 
\b  
\q1  
\v 16 یەزدان پاشایە هەتاهەتایە، 
\q2 نەتەوەکان لە خاکەکەی لەناودەچن. 
\q1  
\v 17 ئەی یەزدان، تۆ گوێ لە داواکاری ستەملێکراوان دەگریت، 
\q2 دڵیان دەچەسپێنی و گوێیان لێ دەگریت، 
\q1  
\v 18 بۆ پارێزگاری لە هەتیوان و زۆرلێکراوان، 
\q2 تاکو لەمەولا مرۆڤی سەر زەوی نەیان ترسێنێت. 
\c 11  
\cl زەبووری 11 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان،  // زەبوورێکی داود. 
\q1  
\v 1 من پەنا دەبەمە بەر یەزدان، 
\q2 ئیتر چۆن ئێوە پێم دەڵێن: 
\q2 «وەک باڵدار بەرەو چیاکانت هەڵفرە، 
\q1  
\v 2 چونکە ئەوەتا بەدکاران کەوان ڕادەکێشن و 
\q2 تیر دەخەنە بەر کەوان، 
\q2 بۆ ئەوەی لە تاریکییەوە دڵڕاستان بپێکن. 
\q1  
\v 3 کاتێک بنچینەکان بڕووخێن، 
\q2 کەسی ڕاستودروست چی دەکات؟» 
\b  
\q1  
\v 4 یەزدان لە پەرستگای پیرۆزی خۆیەتی، 
\q2 تەختی یەزدان لە ئاسمانە، 
\q1 تەماشای کوڕانی مرۆڤ دەکات و 
\q2 چاوەکانی تاقییان دەکاتەوە. 
\q1  
\v 5 یەزدان کەسی ڕاستودروست تاقی دەکاتەوە، 
\q2 بەڵام لە دڵەوە ڕقی لە خراپەکار و خۆشەویستانی توندوتیژییە. 
\q1  
\v 6 پشکۆی ئاگر و گۆگرد بەسەر بەدکارەکاندا دەبارێنێت، 
\q2 گڕەی بای سووتێنەر بەشیانە. 
\b  
\q2  
\v 7 لەبەر ئەوەی یەزدان ڕاستودروستە و حەزی لە دادپەروەرییە، 
\q2 کەسی سەرڕاست تەماشای ڕووی دەکات. 
\c 12  
\cl زەبووری 12 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بە شێوەی شیمینیت\f + \fr 12:0 \ft دەستەواژەیەکی بواری مۆسیقایە.‏\f*. زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، ڕزگارمان بکە، چونکە کەسی خواناس نەماوە، 
\q2 چونکە لەناو ئادەمیزادان دڵسۆز نەماوە. 
\q1  
\v 2 هەمووان درۆ لەگەڵ یەکتر دەکەن، 
\q2 بە لێوی ڕیایی و دڵی ساختەوە قسە دەکەن. 
\b  
\q1  
\v 3 یەزدان هەموو لێوە ڕیاییکەرەکان دەبڕێت، 
\q2 هەموو ئەو زمانانەی بە فیزەوە دەدوێن، 
\q1  
\v 4 ئەوانەی دەڵێن: «بە زمانی خۆمان زاڵ دەبین، 
\q2 بە لێوی خۆمان سەرکەوتوو دەبین. 
\q2 کێ هەیە ببێت بە گەورەمان؟» 
\b  
\q1  
\v 5 یەزدان دەڵێت: «لەبەر ستەمکاری لە هەژاران و 
\q2 ناڵەی کڵۆڵان، ئێستا ڕادەپەڕم، 
\q2 ئەو ئاسوودەییەیان دەدەمێ، لەوانەی پەستیان دەکەن.» 
\q1  
\v 6 وتەکانی یەزدان وتەی پاکن، 
\q2 وەک ئەو زیوەیە لە بۆتەی گڵین پاڵێورابێت، 
\q2 حەوت جار پاڵێوراوە. 
\b  
\q1  
\v 7 ئەی یەزدان، دەمانپارێزیت و 
\q2 هەتاهەتایە لەم جۆرە کەسانە پاسمان دەکەیت. 
\q1  
\v 8 بەدکارەکان بە هەموو لایەکدا بە ئازادی دەگەڕێن، 
\q2 کاتێک خەڵکی بە شان و باڵی خراپەدا هەڵدەدەن. 
\c 13  
\cl زەبووری 13 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان،  // زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، هەتا کەی؟ بە تەواوی لەبیرم دەکەیت؟ 
\q2 هەتا کەی ڕووی خۆتم لێ وەردەگێڕیت؟ 
\q1  
\v 2 هەتا کەی ڕۆژانە دەروونم ڕاڕا بێت و 
\q2 خەفەت لەناو دڵم کۆبکەمەوە؟ 
\q2 هەتا کەی دوژمنم بەسەرمدا زاڵ بێت؟ 
\b  
\q1  
\v 3 ئەی یەزدان، خودای من، سەیرم بکە و بە دەنگمەوە وەرە، 
\q2 چاوم ڕۆشن بکەرەوە، نەوەک خەوی مەرگم لێبکەوێت، 
\q1  
\v 4 نەوەک دوژمن بڵێت: «بەسەریدا زاڵ بووم،» 
\q2 نەوەک ناحەزەکانم بە کەوتنی من شادمان بن. 
\b  
\q1  
\v 5 بەڵام من پشتم بە خۆشەویستییە نەگۆڕەکەت بەستووە، 
\q2 دڵم بە ڕزگاریی تۆوە خۆشە. 
\q1  
\v 6 سروود بۆ یەزدان دەڵێم، 
\q2 چونکە چاکەی لەگەڵ کردووم. 
\c 14  
\cl زەبووری 14 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان،  // زەبوورێکی داود. 
\q1  
\v 1 گێل\f + \fr 14:1 \ft لە عیبری مەبەستی لە کەسی بەدڕەوشتە.‏\f* لە دڵی خۆیدا دەڵێت: «خودا نییە.» 
\q2 ئەوانە گەندەڵن و کردەوەکانیان پیسە، 
\q2 کەس نییە چاکە بکات. 
\b  
\q1  
\v 2 یەزدان لە ئاسمانەوە سەیری ئادەمیزاد دەکات، 
\q2 تاکو بزانێت کەس هەیە تێگەیشتوو بێت، 
\q2 کەس هەیە ڕوو لە خودا بکات. 
\q1  
\v 3 هەموو ڕوویان وەرگێڕا، 
\q2 هەموو گەندەڵ بوون، 
\q1 کەس نییە چاکە بکات، 
\q2 تەنانەت یەکێکیش نییە. 
\b  
\q1  
\v 4 ئایا ئەم هەموو گوناهبارانە هیچ نازانن؟ 
\b  
\q1 ئەوانەی وەک نان گەلەکەی من دەخۆن و 
\q2 ئەوانەی لە یەزدان ناپاڕێنەوە. 
\q1  
\v 5 لەوێ ترسێکی گەورەیان لێ نیشت، 
\q2 چونکە خودا لەناو کۆڕی ڕاستودروستان ئامادەیە. 
\q1  
\v 6 ئێوەی گوناهبار سووکایەتی بە پلانی هەژاران دەکەن، 
\q2 بەڵام یەزدان پەناگای ئەوانە. 
\b  
\q1  
\v 7 با ڕزگاریی ئیسرائیل لە سییۆنەوە\f + \fr 14:7 \ft مەبەست لە شاری سییۆنە لە ئۆرشەلیم کە خودا بەڵێنی داوە لەوێ نیشتەجێ دەبێ.‏\f* دەربکەوێت! 
\q2 کاتێک یەزدان گەلەکەی خۆی لە ڕاپێچکراوی دەگەڕێنێتەوە، 
\q2 با یاقوب شاد و ئیسرائیل دڵخۆش بێت! 
\c 15  
\cl زەبووری 15 
\d زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، کێ لە پیرۆزگای تۆ نیشتەجێ دەبێت؟ 
\q2 کێ لەسەر کێوی پیرۆزی تۆ دەژیێت؟ 
\b  
\q1  
\v 2 ئەو کەسەی ڕێگای تەواو دەگرێت و 
\q2 ڕاستودروستی پەیڕەو دەکات، 
\q1 لە دڵەوە بە ڕاستگۆیی قسە دەکات و 
\q2  
\v 3 بە زمانی بوختان ناکات، 
\q1 کە خراپە لەگەڵ کەس ناکات و 
\q2 هاوڕێکەی شەرمەزار ناکات، 
\q1  
\v 4 کە بە سووکایەتییەوە دەڕوانێتە خراپەکاران 
\q2 بەڵام ڕێزی ئەوانە دەگرێت کە ترسی یەزدانیان لە دڵدایە، 
\q1 کە سوێندی خۆی بەجێدەهێنێت، 
\q2 ئەگەر ببێتە مایەی زەرەریش بۆی، 
\q1  
\v 5 کە پارە بە سوود نادات و 
\q2 بەرتیل وەرناگرێت لە دژی پیاوی بێتاوان. 
\b  
\q1 ئەوەی ئەم شتانە بکات، 
\q2 هەتاهەتایە جێی لەق نابێت. 
\c 16  
\cl زەبووری 16 
\d پاڕانەوەیەکی داود. 
\q1  
\v 1 ئەی خودایە، بمپارێزە، 
\q2 چونکە من پەنا دەهێنمە بەر تۆ. 
\b  
\q1  
\v 2 بە یەزدانم گوت: «تۆ گەورەی منی، 
\q2 بێجگە لە تۆ هیچ شتێکی چاکم نییە.» 
\q1  
\v 3 هەموو خۆشییەکم بە گەلە پیرۆزەکەیە کە لەناو خاکەکەن، 
\q2 ئەوانە شکۆدارن. 
\q1  
\v 4 ئەوانەی بەدوای خوداوەندەکانی دیکە دەکەون، 
\q2 دەردیان زۆر دەبێت. 
\q1 خوێنی قوربانییان بۆ ناڕێژم و 
\q2 ناویشیان لەسەر لێوم نابێت. 
\b  
\q1  
\v 5 ئەی یەزدان، تۆ بەشە میرات و چارەنووسی منی، 
\q2 تۆ پشکی من دەستەبەر دەکەیت. 
\q1  
\v 6 گوریس\f + \fr 16:6 \ft دیاریکردنی سنووری زەوی بە گوریس بووە.‏\f* کەوتە سەر چاکترین خاک بۆ بەشی من، 
\q2 بە ڕاستی میراتێکی دڵخۆشکەرم هەیە. 
\q1  
\v 7 ستایشی یەزدان دەکەم کە ئامۆژگاریم دەکات، 
\q2 تەنانەت بە شەویش دڵم ڕێنماییم دەکات. 
\q1  
\v 8 هەمیشە چاوم لەسەر یەزدانە، 
\q2 لەبەر ئەوەی لەلای دەستی ڕاستمەوەیە، ناهەژێم. 
\b  
\q1  
\v 9 بۆیە دڵشادم و گیانم خۆشحاڵە، 
\q2 تەنانەت جەستەم بە ئاسوودەیی نیشتەجێیە، 
\q1  
\v 10 چونکە تۆ گیانم لە جیهانی مردوواندا بەجێناهێڵیت، 
\q2 هەروەها ڕێگا نادەیت دڵسۆزەکەی تۆ\f + \fr 16:10 \ft مەبەستی ئەوەی بۆ خودا تەرخان کراوە، وەک مەسیح.‏\f* لەناو گۆڕ بۆگەن بێت. 
\q1  
\v 11 ڕێگای ژیانت پێ ناساندم، 
\q2 تێربوون لە شادی لە ئامادەبوونتدایە، 
\q2 خۆشحاڵی هەتاهەتایی لەلای دەستەڕاستی تۆدایە. 
\c 17  
\cl زەبووری 17 
\d نوێژێکی داود. 
\q1  
\v 1 ئەی یەزدان، گوێ لە داواکاری ڕاستودروستی من بگرە، 
\q2 بایەخ بە هاوارم بدە، 
\q1 گوێ لە نوێژەکەم بگرە، 
\q2 لە زاری بێ فێڵمەوە دەردەچێ. 
\q1  
\v 2 ئەستۆپاکی من لەلای تۆوە دێت، 
\q2 چاوەکانت ڕاست و ڕێکی دەبینێت. 
\b  
\q1  
\v 3 ئەگەر دڵم بپشکنیت و لە شەودا چاودێریم بکەیت، 
\q2 ئەگەر تاقیم بکەیتەوە، هیچ خراپەیەکم تێدا نابینیت، 
\q2 پێداگری دەکەم کە دەمم سنوور نەبەزێنێت. 
\q1  
\v 4 سەبارەت بە کاری خەڵک، بە فەرمایشتی سەر لێوی تۆ، 
\q2 خۆم لە ڕێگای توندوتیژی پاراستووە. 
\q1  
\v 5 هەنگاوم بە ڕێڕەوی تۆوە جێگیر بوو، 
\q2 پێم نەخلیسکاوە. 
\b  
\q1  
\v 6 ئەی خودایە، لێت دەپاڕێمەوە، چونکە تۆ بە دەنگمەوە دێیت، 
\q2 گوێ بۆ پاڕانەوەکەم شل بکە و ببیستە. 
\q1  
\v 7 جوانی خۆشەویستییە نەگۆڕەکەت دەربخە، 
\q2 ئەی ئەوەی بە دەستی ڕاستت ئەوانە ڕزگار دەکەیت 
\q2 کە لەبەر دوژمنەکانیان پەنات بۆ دەهێنن. 
\q1  
\v 8 وەک گلێنەی چاوت بمپارێزە، 
\q2 لەژێر سێبەری باڵەکانت بمشارەوە، 
\q1  
\v 9 لەو بەدکارانەی هێرشم دەکەنە سەر، 
\q2 لەو دوژمنە بکوژانەی دەوریان داوم. 
\b  
\q1  
\v 10 دڵە بەردینەکانیان داخستووە، 
\q2 بە دەمیش لاف لێدەدەن. 
\q1  
\v 11 شوێن پێم دەکەون، وا دەوریان داوم، 
\q2 چاویان لەوەیە بە زەویم دا بدەن. 
\q1  
\v 12 وەک شێرێکن کە برسی پەلاماردانە، 
\q2 وەک بەچکە شێرێک خۆی لە بۆسە نابێت. 
\b  
\q1  
\v 13 ئەی یەزدان ڕاپەڕە، لە ڕوویان بوەستەوە، بەریان بدەوە! 
\q2 بە شمشێری خۆت گیانم لە بەدکار ڕزگار بکە! 
\q1  
\v 14 ئەی یەزدان، بە دەستی خۆت لەم جۆرە کەسانە ڕزگارم بکە، 
\q2 لە خەڵکی ئەم جیهانە کە بەشیان لەم ژیانەیە، 
\q1 ورگیانت پڕکردووە لەو شتەی هەڵتگرتووە بۆیان، 
\q2 کوڕەکانیان تێر دەخۆن، 
\q2 ئەوەی دەمێنێتەوە بۆ منداڵەکانیان جێی دەهێڵن. 
\b  
\q1  
\v 15 بەڵام من بێتاوان دەبم و ڕووی تۆ دەبینم، 
\q2 کە بەئاگادێم تێر دەبم لە بینینی شێوەت. 
\c 18  
\cl زەبووری 18 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، زەبوورێکی داودی بەندەی یەزدان. ئەم سروودەی بۆ یەزدان گوت، دوای ئەوەی یەزدان لە دەستی هەموو دوژمنەکانی و لە دەستی شاول ڕزگاری کرد. گوتی: 
\q1  
\v 1 ئەی یەزدان، ئەی هێزی من، خۆشمدەوێی. 
\b  
\q1  
\v 2 یەزدان تاشەبەردی\f + \fr 18:2 \ft شوبهێنراوە بەو تاشەبەردەی لە کاتی تەنگانەدا پشتی پێدەدرێت، وەکو لە کاتی شەڕکردن دەبێتە پەناگا.‏\f* منە، قەڵا و دەربازکەرمە، 
\q2 خودام ئەو تاشەبەردەیە کە پەنای بۆ دەبەم، 
\q2 قەڵغان و هێزی ڕزگاریمە، پەناگای منە. 
\b  
\q1  
\v 3 لە یەزدان دەپاڕێمەوە، ئەوەی کە شایانی ستایشە، 
\q2 لە دوژمنەکانم ڕزگار دەبم، 
\q1  
\v 4 چونکە پەتی مەرگ شەتەکی داوم، 
\q2 لێشاوی لەناوچوون زەندەقی بردم، 
\q1  
\v 5 پەتی جیهانی مردووان بە دەورمدا تەنراوە، 
\q2 داوی مردن لەبەردەمم دانراوە. 
\b  
\q1  
\v 6 لە تەنگانەمدا لە یەزدان پاڕامەوە، 
\q2 هاوارم بردە بەر خودام، 
\q1 لە پەرستگاکەیەوە گوێی لە دەنگی من بوو، 
\q2 هاوارم گەیشتە بەرگوێی. 
\q1  
\v 7 ئینجا زەوی لەرزی و هەژا، 
\q2 بناغەی چیاکانیش ڕاژەنین، 
\q2 لە تووڕەیی ئەو لەرزین. 
\q1  
\v 8 دووکەڵ لە لووتی بەرزبووەوە، 
\q2 ئاگرێکی لووشدەر لە دەمی هاتە دەرەوە، 
\q2 وەک ژیلەمۆی پشکۆی داگیرساو بوو. 
\q1  
\v 9 ئاسمانی شەقکرد و دابەزییە خوارەوە، 
\q2 هەوری تاریک لەژێر پێی بوو. 
\q1  
\v 10 سواری کەڕوب\f + \fr 18:10 \ft بوونەوەری ئاسمانی باڵدارە، لە شێوەی مرۆڤ و ئاژەڵ.‏\f* بوو و فڕی، 
\q2 بەسەر باڵی بادا بەرزبووەوە. 
\q1  
\v 11 بە تاریکی خۆی داپۆشی و کردییە خێوەت لە دەوری خۆی، 
\q2 هەوری تاریکی پڕ بارانی ئاسمانی کردە چەتری خۆی. 
\q1  
\v 12 لە ڕۆشنایی ئامادەبوونی ئەو هەورەکان بەرەو پێش چوون، 
\q2 تەرزە و پشکۆی ئاگریان لێ هاتە دەرەوە. 
\q1  
\v 13 یەزدان لە ئاسمانەوە گرماندی، 
\q2 ئەو خودایەی هەرەبەرزە دەنگی خۆی لەرزاندەوە. 
\q1  
\v 14 تیرەکانی هاویشت و بڵاوەی بە دوژمنەکانی کرد، 
\q2 بە بروسکەی گەورە پەرێشانی کردن. 
\q1  
\v 15 ئەی یەزدان، بنی دەریا دەرکەوت، 
\q2 بناغەکانی زەوی ئاشکرا بوون، 
\q1 لە سەرزەنشتی تۆ، 
\q2 لە گەرمی هەناسەی لووتی تۆ. 
\b  
\q1  
\v 16 لە بەرزاییەوە دەستی درێژکرد و منی گرت، 
\q2 لەناو ئاوە قووڵەکانەوە دەریهێنام. 
\q1  
\v 17 لە دوژمنە بە تواناکەم ڕزگاری کردم، 
\q2 لە ناحەزەکانم کە زۆر لە من بەهێزتر بوون. 
\q1  
\v 18 لە ڕۆژی لێقەومانم هاتنە سەرم، 
\q2 بەڵام یەزدان پشت و پەنام بوو. 
\q1  
\v 19 منی هێنایە دەرەوە بۆ جێگایەکی پان و بەرین، 
\q2 ڕزگاری کردم، چونکە دڵخۆشە پێم. 
\b  
\q1  
\v 20 یەزدان بەگوێرەی ڕاستودروستیم پاداشتی داومەتەوە، 
\q2 بەگوێرەی دەستپاکیم ڕێزداری کردووم، 
\q1  
\v 21 چونکە من ڕێچکەی یەزدانم گرتووەتەبەر، 
\q2 لە خودای خۆم یاخی نەبووم. 
\q1  
\v 22 هەموو حوکمەکانی لەبەرچاومدان، 
\q2 لە فەرزەکانی لام نەداوە. 
\q1  
\v 23 لەبەردەمی ئەو بێ کەموکوڕی بووم و 
\q2 خۆم لە گوناه پاراستووە. 
\q1  
\v 24 یەزدان بەگوێرەی ڕاستودروستیم پاداشتی داومەتەوە، 
\q2 بەگوێرەی دەستپاکیم لەبەردەمی. 
\b  
\q1  
\v 25 لەگەڵ دڵسۆزەکان دڵسۆزی دەنوێنیت، 
\q2 لەگەڵ ئەوانەی بێ کەموکوڕین چاکی دەنوێنیت، 
\q1  
\v 26 لەگەڵ پاکەکان پاکی دەنوێنیت، 
\q2 بەڵام لەگەڵ خوارەکان زیرەکی دەنوێنیت. 
\q1  
\v 27 تۆ خەڵکی بێفیز ڕزگار دەکەیت، 
\q2 بەڵام لووتی لووتبەرزان دەشکێنیت.\f + \fr 18:27 \ft لە عیبری: چاوی لووتبەرزان شۆڕ دەکەیت.‏\f* 
\q1  
\v 28 ئەی یەزدان، تۆ چراکەم دادەگیرسێنیت، 
\q2 خودام تاریکیم ڕووناک دەکاتەوە. 
\q1  
\v 29 بە یارمەتی تۆ دەتوانم لەشکرێک تێکبشکێنم، 
\q2 لەگەڵ خودای خۆم دەتوانم بەسەر شووراکاندا سەربکەوم. 
\b  
\q1  
\v 30 ڕێبازی خودا تەواوە، 
\q2 بەڵێنی یەزدان بێگەردە، 
\q2 ئەو قەڵغانە بۆ هەموو ئەوانەی پەنای بۆ دەبەن. 
\q1  
\v 31 لە یەزدان بەولاوە کێ خودایە؟ 
\q2 لە خودامان بەولاوە کێ تاشەبەردەکەیە؟ 
\q1  
\v 32 خودایە ئەوەی کەمەری منی توند بەستووە، 
\q2 بە تەواوی ڕێگام لەبەردەمدا دەکاتەوە. 
\q1  
\v 33 پێیەکانم وەک پێی ئاسک لێ دەکات، 
\q2 لەسەر بەرزایی ڕامدەگرێت. 
\q1  
\v 34 مەشق بە دەستەکانم دەکات بۆ جەنگ، 
\q2 تاکو بتوانم بە بازووم کەوانی بڕۆنز بچەمێنمەوە. 
\q1  
\v 35 قەڵغانی ڕزگاریی خۆتت پێ بەخشیوم، 
\q2 بە دەستی ڕاستت پشتم دەگریت، 
\q2 هاوکاریت گەورەم دەکات. 
\q1  
\v 36 جێی هەنگاوەکانم تەخت و فراوان دەکەیت، 
\q2 تاکو پێم نەخلیسکێت. 
\b  
\q1  
\v 37 دوژمنەکانم ڕاونا و پێشم لێ گرتن، 
\q2 هەتا لەناوم نەبردن نەگەڕامەوە. 
\q1  
\v 38 وردوخاشم کردن، ئیتر نەیانتوانی هەستنەوە، 
\q2 لەژێر پێم کەوتن. 
\q1  
\v 39 کەمەری منت توند کرد بۆ جەنگ، 
\q2 وات لە بەرهەڵستکارانی من کرد لەبەر پێم کڕنۆش ببەن. 
\q1  
\v 40 دوژمنەکانم پشتیان تێ کردم و ڕایانکرد، 
\q2 من ناحەزەکانی خۆمم لەناوبرد. 
\q1  
\v 41 هاواریان هێنا، بەڵام ڕزگارکەر نەبوو، 
\q2 هاواریان بۆ یەزدان برد، بەڵام بە دەنگیانەوە نەچوو. 
\q1  
\v 42 وەک تۆزی بەر با منیان هاڕی، 
\q2 وەک قوڕی سەر ڕێگا پێشێلم کردن. 
\q1  
\v 43 لە هێرشی گەل ڕزگارت کردم، 
\q2 تۆ منت کرد بە سەرۆکی نەتەوەکان، 
\q2 گەلێک کە نەمدەناسین خزمەتم دەکەن. 
\q1  
\v 44 هەرکە دەنگم دەبیستن گوێڕایەڵم دەبن، 
\q2 بێگانەکان ملکەچیم بۆ دەنوێنن. 
\q1  
\v 45 بێگانەکان ورە بەر دەدەن و 
\q2 بە لەرزەوە لە قەڵاکانیان دێنە دەرەوە. 
\b  
\q1  
\v 46 یەزدان زیندووە، ستایش بۆ تاشەبەردەکەم! 
\q2 خودای ڕزگارکەرم پایەبەرزە! 
\q1  
\v 47 خودایە کە تۆڵەم بۆ دەکاتەوە، 
\q2 گەلان دەخاتە ژێر ڕکێفم، 
\q2  
\v 48 لە دوژمنەکانم ڕزگاری کردم. 
\q1 پایەبەرزی کردم بەسەر ناحەزانم، 
\q2 لە دەست پیاوێکی توندوتیژ ڕزگارت کردم. 
\q1  
\v 49 لەبەر ئەوە ئەی یەزدان، لەنێو نەتەوەکاندا ستایشت دەکەم، 
\q2 گۆرانی ستایش بۆ ناوت دەڵێم. 
\b  
\q1  
\v 50 سەرکەوتنی گەورە بە پاشای خۆی دەبەخشێت، 
\q2 خۆشەویستی نەگۆڕ بەسەر دەستنیشانکراوەکەیدا دەبارێنێت، 
\q2 بۆ سەر داود و نەوەکانی بۆ هەتاهەتایە. 
\c 19  
\cl زەبووری 19 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، زەبوورێکی داود. 
\q1  
\v 1 ئاسمان باسی شکۆی خودا دەکات، 
\q2 گەردوون کارەکانی دەستی ڕادەگەیەنێت. 
\q1  
\v 2 ڕۆژ لەدوای ڕۆژ وتەی بەرز دەبارێنن، 
\q2 شەو لەدوای شەو زانین ڕادەگەیەنن. 
\q1  
\v 3 هیچ قسە و زمانێکیان نییە، 
\q2 دەنگیان نابیسترێت، 
\q1  
\v 4 بەڵام پەیامیان دەگاتە هەموو زەوی، 
\q2 وتەکانیان بەوپەڕی جیهان. 
\q1 لە ئاسمان چادری بۆ خۆر هەڵداوە، 
\q2  
\v 5 کە وەک زاوایەکە لە ژوورەکەی بێتە دەرەوە، 
\q2 وەک پاڵەوانێکە کە شادە بە ڕاکردن لە گۆڕەپان. 
\q1  
\v 6 لەو سەری ئاسمانەوە هەڵدێت و 
\q2 دەسووڕێتەوە هەتا ئەو سەری، 
\q2 هیچ شتێک لەبەر گەرماییەکەی ناشاردرێتەوە. 
\b  
\q1  
\v 7 فێرکردنی یەزدان تەواوە، 
\q2 دەروون دەبووژێنێتەوە. 
\q1 شەریعەتی\f + \fr 19:7 \ft مەبەستی لە پەیمان و ڕاسپاردەکانی خودایە بۆ گەلەکەی کە لەسەر تەختەی پەیمان نووسراون. هەروەها بڕوانە \xt دەرچوون 16‏:31‏-34.‏\ft ‏\f* یەزدان جێی متمانەیە، 
\q2 ساویلکە دەکەنە دانا. 
\q1  
\v 8 ڕێنمایی یەزدان دروستە، 
\q2 دڵ خۆش دەکات. 
\q1 ڕاسپاردەی یەزدان پاکە، 
\q2 چاو ڕۆشن دەکات. 
\q1  
\v 9 لەخواترسی بێگەردە، 
\q2 هەتاهەتایە سەقامگیرە. 
\q1 حوکمی یەزدان ڕاستە، 
\q2 بە تەواوی ڕاستودروستە. 
\b  
\q1  
\v 10 ئەوانە لە زێڕ دڵگیرترن، 
\q2 لە زێڕی بێگەردی زۆر، 
\q1 لە هەنگوین شیرینترن، 
\q2 لە دڵۆپی شانەی هەنگوین. 
\q1  
\v 11 خزمەتکارەکەت بەوانە ئاگادار کراوەتەوە، 
\q2 پەیڕەوکردنیان پاداشتی زۆرە. 
\q1  
\v 12 کێ لە هەڵەکانی خۆی تێدەگات؟ 
\q2 گوناهە شاراوەکانم ببەخشە. 
\q1  
\v 13 خزمەتکارەکەت لە گوناهی یاخیبوون بپارێزە، 
\q2 وا مەکە بەسەرمدا زاڵبێت. 
\q1 ئیتر بێ کەموکوڕی دەبم، 
\q2 لە گوناهی گەورە بێبەری دەبم. 
\b  
\q1  
\v 14 با قسەی دەم و لێکدانەوەی دڵم 
\q2 جێی ڕەزامەندی تۆ بێت، 
\q2 ئەی یەزدان، تاشەبەردی من و ڕزگارکەرم\f + \fr 19:14 \ft لە زمانی عیبری بە واتای خوێنگر دێت، بۆ تێگەیشتن لەم دەربڕینە بڕوانە \xt ڕائووس 4‏\ft ‏.‏\f*. 
\c 20  
\cl زەبووری 20 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، زەبوورێکی داود. 
\q1  
\v 1 با یەزدان لە ڕۆژی تەنگانەدا بە دەنگتەوە بێت، 
\q2 با ناوی خودای یاقوب بتپارێزێت. 
\q1  
\v 2 با لە پیرۆزگاکەیەوە یارمەتیت بۆ بنێرێت و 
\q2 لە سییۆنەوە پشتگیریت بکات. 
\q1  
\v 3 با هەموو قوربانییەکانی تۆی لەبیربێت و 
\q2 هەموو قوربانی سووتاندنەکانی تۆ قبوڵ بکات.\f + \fr 20:3 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 4 با ئارەزووی دڵت بهێنێتە دی و 
\q2 هەموو مەبەستەکانت بە ئەنجام بگەیەنێت. 
\q1  
\v 5 هەلهەلە لێدەدەین بۆ ڕزگاربوونت و 
\q2 بە ناوی خودامانەوە ئاڵا بەرز دەکەینەوە. 
\b  
\q1 با یەزدان هەموو داواکارییەکانت بەجێبهێنێت. 
\b  
\q1  
\v 6 ئێستا زانیم کە یەزدان دەستنیشانکراوەکەی\f + \fr 20:6 \ft بە زمانی عیبری پێی دەگوترێ \+tl مەشیخ‏\+tl* یان \+tl مەشیح‏\+tl*.‏\f* ڕزگار دەکات، 
\q2 لە پیرۆزگا ئاسمانییەکەی خۆیەوە بە دەنگییەوە دێت، 
\q2 بە توانای ڕزگاریی دەستی ڕاستی. 
\q1  
\v 7 هەندێک شانازی بە گالیسکە دەکەن و هەندێک بە ئەسپ، 
\q2 بەڵام ئێمە شانازی بە ناوی یەزدانی پەروەردگارمان دەکەین. 
\q1  
\v 8 ئەوان چەمانەوە و کەوتن، 
\q2 بەڵام ئێمە هەستاین و چەسپاین. 
\q1  
\v 9 ئەی یەزدان، پاشا ڕزگار بکە! 
\q2 کە لێت دەپاڕێینەوە بەدەنگمانەوە وەرە! 
\c 21  
\cl زەبووری 21 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان،  // زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، پاشا بە هێزی تۆ شادمان دەبێت. 
\q2 چەند دڵخۆشە بەو ڕزگارییەی پێت بەخشیوە! 
\b  
\q1  
\v 2 ئارەزووی دڵیت پێ بەخشیوە و 
\q2 لە داواکارییەکانی زمانیت ڕانەگرتووه.\f + \fr 21:2 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 3 بە بەرەکەتێکی زۆرەوە پێشوازیت لێکرد و 
\q2 تاجێکی زێڕی بێگەردت لە سەری کرد. 
\q1  
\v 4 داوای ژیانی لێکردیت، پێت بەخشی، 
\q2 ڕۆژگاری درێژی هەتاهەتاییە. 
\q1  
\v 5 بەو ڕزگارییەی کە پێت داوە، شکۆمەندییەکەی مەزنە، 
\q2 تۆ شکۆمەندی و پایەبەرزیت پێ بەخشیوە. 
\q1  
\v 6 بێگومان بەرەکەتێکی بێ کۆتاییت داوەتێ، 
\q2 بە خۆشی دیداری خۆت شادی دەکەیت. 
\q1  
\v 7 لەبەر ئەوەی پاشا پشت بە یەزدان دەبەستێت، 
\q2 بە خۆشەویستی نەگۆڕی خودای هەرەبەرزە هەرگیز نالەقێت. 
\b  
\q1  
\v 8 دەستت بەسەر هەموو دوژمنەکانتدا دەڕوات، 
\q2 دەستی ڕاستت بەسەر ناحەزانت. 
\q1  
\v 9 کە دەردەکەویت وەک تەنوورێکی بڵێسەداریان لێ دەکەیت، 
\q2 لە تووڕەییدا یەزدان هەڵیاندەلووشێت، 
\q2 ئاگریش دەیانخوات. 
\q1  
\v 10 ڕەچەڵەکیان لەسەر زەوی لەناودەبەیت، 
\q2 نەوەیان لەناو ئادەمیزاد. 
\q1  
\v 11 هەرچەندە پیلانیان لە دژت دانا و 
\q2 بیریان لە خراپە کردەوە، سەرناکەون، 
\q1  
\v 12 چونکە تۆ وایان لێ دەکەیت ڕابکەن، 
\q2 کاتێک بە تیروکەوان نیشانیان لێ دەگریت. 
\b  
\q1  
\v 13 ئەی یەزدان، بە هێزی خۆت پایەبەرز بە، 
\q2 گۆرانی و ستایش بۆ توانای تۆ دەڵێین. 
\c 22  
\cl زەبووری 22 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بەگوێرەی ئاسکی بەرەبەیان. زەبوورێکی داود. 
\q1  
\v 1 خودای من، خودای من، بۆ وازت لێ هێنام؟ 
\q2 بۆ وا دووری لە ڕزگارکردنم، لە بیستنی ناڵەم؟ 
\q1  
\v 2 ئەی خودای من، بە ڕۆژ لێت دەپاڕێمەوە، وەڵامم نادەیتەوە، 
\q2 بە شەویش ئارامیم نییە. 
\b  
\q1  
\v 3 لەگەڵ ئەوەشدا، تۆ خودای پیرۆزیت، 
\q2 لەنێو ستایشی ئیسرائیل دانیشتوویت. 
\q1  
\v 4 باوباپیرانمان پشتیان بە تۆ بەست، 
\q2 پشتیان بە تۆ بەست و تۆش ڕزگارت کردن. 
\q1  
\v 5 هاواریان بۆ تۆ هێنا و تۆش دەربازت کردن، 
\q2 پشتیان بە تۆ بەست و شەرمەزار نەبوون. 
\b  
\q1  
\v 6 بەڵام من سەگم\f + \fr 22:6 \ft عیبری: کرمێک.‏\f* نەک مرۆڤ، 
\q2 مایەی ڕیسوایی ئادەمیزاد و سووکایەتی خەڵک. 
\q1  
\v 7 هەموو ئەوانەی دەمبینن گاڵتەم پێ دەکەن، 
\q2 توانجم لێ دەگرن و بە بزەوە سەر بادەدەن و دەڵێن: 
\q1  
\v 8 «پشتی بە یەزدان بەست، با یەزدان ڕزگاری بکات. 
\q2 با فریای بکەوێت، ئەگەر یەزدان پێی دڵخۆشە.» 
\b  
\q1  
\v 9 بەڵام تۆ لەناو سکی دایکم دەرتهێنام، 
\q2 کاتێک لەبەر مەمکی دایکم بووم، دڵنیات کردم. 
\q1  
\v 10 من لە کاتی لەدایکبوونمەوە بە تۆ سپێردراوم، 
\q2 لە سکی دایکمەوە تۆ خودای منی. 
\b  
\q1  
\v 11 لێم دوور مەبە، چونکە تەنگانە نزیک بووەتەوە و 
\q2 کەس نییە یارمەتیم بدات. 
\b  
\q1  
\v 12 گای زۆر دەوریان داوم، 
\q2 گایە بەهێزەکانی باشان\f + \fr 22:12 \ft شوێنێک بووە لە ڕۆژهەڵاتی ڕووباری ئوردون و لەوەڕگایەکی بەناوبانگ بووە بۆ گا.‏\f* ئابڵوقەیان داوم. 
\q1  
\v 13 وەک شێری دڕندەی بە نەڕەنەڕ، 
\q2 ددانیان لێ تیژکردوومەتەوە. 
\q1  
\v 14 وەک ئاو ڕژام، 
\q2 هەموو ئێسقانەکانم لێک جیا بوونەتەوە. 
\q1 دڵم بووە بە مۆم، 
\q2 لە ناخمدا تواوەتەوە. 
\q1  
\v 15 هێزم وەک پارچە گۆزە وشک بووە، 
\q2 زمانم بە مەڵاشوومەوە نووساوە، 
\q2 منت خستە ناو خاکی مەرگ. 
\b  
\q1  
\v 16 سەگ دەوریان داوم، 
\q2 تاقمێک بەدکار ئابڵوقەیان داوم، 
\q2 دەست و پێیان کون کردووم. 
\q1  
\v 17 هەموو ئێسقانەکانم دەژمێرم، 
\q2 ئەمانە تەماشام دەکەن و سەرنجیان لەسەرمە. 
\q1  
\v 18 جلوبەرگەکەم لەنێو خۆیان بەش دەکەن، 
\q2 تیروپشک لەسەر کراسەکەم دەکەن. 
\b  
\q1  
\v 19 بەڵام تۆ ئەی یەزدان، لێم دوور مەبە، 
\q2 ئەی هێزی من، زوو بگە فریام. 
\q1  
\v 20 ژیانم لە شمشێر دەرباز بکە، 
\q2 ژیانی بەهادارم لە چنگی سەگ. 
\q1  
\v 21 لە دەمی شێر ڕزگارم بکە، 
\q2 لە قۆچی گای کێوی، دەربازم بکە. 
\b  
\q1  
\v 22 ناوی تۆ بە براکانم ڕادەگەیەنم، 
\q2 لەناو کۆمەڵدا ستایشت دەکەم. 
\q1  
\v 23 ئەی لەخواترسەکان، ستایشی بکەن! 
\q2 ئەی هەموو نەوەکانی یاقوب، شکۆداری بکەن! 
\q2 ئەی هەموو نەوەکانی ئیسرائیل، لێی بترسن! 
\q1  
\v 24 لەبەر ئەوەی بە سووکییەوە نەیڕوانییە ستەمی ستەملێکراوەکە و پشتی لێ ناکات، 
\q2 ڕووی لێ وەرناگێڕێت، 
\q2 بەڵکو گوێ لە هاواری دەگرێت. 
\b  
\q1  
\v 25 لە کۆڕ و کۆمەڵی گەورەدا تۆ بابەتی ستایشکردنی منی، 
\q2 نەزرەکانم\f + \fr 22:25 \ft نەزر: داوا لە خودا دەکرێت بۆ ئەنجامدانی کارێک، کارەکە پابەند دەکرێت بە مەرجێکەوە. ئەگەر خودا ئەوە بکات، ئەوا دەرئەنجام ئەو کارەی بۆ ئەنجام دەدرێت کە پێیەوە پابەند کراوە. بڕوانە \xt سەرژمێری 2‏:21‏\ft ‏.‏\f* بەجێدەهێنم لەپێش ئەوانەی ترسی تۆیان هەیە. 
\q1  
\v 26 هەژارەکان دەخۆن\f + \fr 22:26 \ft لەدوای بەجێهێنانی نەزر قوربانی هاوبەشی دەکرێت و هەژاران لەو قوربانییە دەخۆن.‏\f* و تێر دەبن، 
\q2 ئەوانەی ڕوو لە یەزدان دەکەن ستایشی دەکەن، 
\q2 دڵتان بۆ هەتاهەتایە بژیێت. 
\b  
\q1  
\v 27 سەرانسەری زەوی یەزدانیان بەبیر دێتەوە و دەگەڕێنەوە لای ئەو، 
\q2 هەروەها هەموو هۆزەکانی نەتەوەکان لەبەردەمی کڕنۆش دەبەن، 
\q1  
\v 28 چونکە پاشایەتی بۆ یەزدانە و 
\q2 ئەو فەرمانڕەوایەتی نەتەوەکان دەکات. 
\b  
\q1  
\v 29 هەموو دەوڵەمەندەکانی سەر زەوی دەخۆن و کڕنۆشی بۆ دەبەن، 
\q2 هەروەها هەموو ئەوانەی دەچنە ناو خۆڵ لەبەردەمی ئەو چۆک دادەدەن، 
\q2 ئەوانەی ناتوانن خۆیان بە زیندوویی بهێڵنەوە. 
\q1  
\v 30 نەوەکان دەیپەرستن، 
\q2 باسی پەروەردگار بۆ نەوەکانی داهاتوو دەکرێت. 
\q1  
\v 31 ڕاستودروستییەکەی بەو خەڵکانە ڕادەگەیەنن کە هێشتا لەدایک نەبوونە، 
\q2 چونکە ئەم کارەی\f + \fr 22:31 \ft مەبەستی لە کارەکانی خودایە لەناو ئەم دەقە.‏\f* کردووە. 
\c 23  
\cl زەبووری 23 
\d زەبوورێکی داود. 
\q1  
\v 1 یەزدان شوانی منە، پێویستم بە هیچ نابێت. 
\q2  
\v 2 لە لەوەڕگای سەوزدا دەملەوەڕێنێت و 
\q1 دەمباتە سەر ئاوی هێمن و سازگار، 
\q2  
\v 3 گیانم دەبووژێنێتەوە. 
\q1 بەرەو ڕێگای ڕاستودروستی ڕێنماییم دەکات 
\q2 لە پێناوی ناوی خۆی. 
\q1  
\v 4 ئەگەر تەنانەت بەناو دۆڵی سێبەری مەرگیشدا بڕۆم، 
\q2 لە هیچ خراپەیەک ناترسم، 
\q1 لەبەر ئەوەی تۆ لەگەڵمدای، 
\q2 گۆچان و داردەستەکەت دڵنەواییم دەکەن. 
\b  
\q1  
\v 5 سفرەم بۆ ئامادە دەکەیت لەبەردەم دوژمنانم، 
\q2 زەیت لە سەرم دەدەیت بۆ دەستنیشانکردنم، 
\q2 جامەکەم لێوانلێو دەکەیت. 
\q1  
\v 6 بێگومان بە درێژایی ژیانم چاکە و خۆشەویستی نەگۆڕ بەدوام دەکەون، 
\q2 بۆ هەتاهەتایە لە ماڵی یەزدان دەژیم. 
\c 24  
\cl زەبووری 24 
\d زەبوورێکی داود. 
\q1  
\v 1 زەوی و هەرچی تێدایە هی یەزدانە، 
\q2 جیهان و ئەوانەی تێیدا دەژین، 
\q1  
\v 2 چونکە لەسەر دەریاکان بناغەی داناوە و 
\q2 لەسەر ڕووبارەکان دایمەزراندووە. 
\b  
\q1  
\v 3 کێ سەردەکەوێتە سەر کێوی یەزدان؟ 
\q2 کێ لە جێگای پیرۆزی ئەو دەوەستێت؟ 
\q1  
\v 4 ئەوەی دەست پاک و دڵی بێگەرد بێت، 
\q2 ئەوەی مەیلی شتی پووچ نەکات و 
\q2 بە درۆ سوێند نەخوات. 
\b  
\q1  
\v 5 لە یەزدانەوە بەرەکەت بەدەستدەهێنێت، 
\q2 لە خودای ڕزگارکەری بێتاوانکردن. 
\q1  
\v 6 ئەمەیە ئەو نەوەیەی دوای یەزدان دەکەوێت، 
\q2 ئەوەی ڕوویان لە تۆ دەکەن، ئەی خودای یاقوب.\f + \fr 24:6 \ft لە دەقی عیبری لێرە و لە ئایەتی 10، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 7 ئەی دەروازەکان، سەر هەڵبڕن! 
\q2 ئەی دەرگا دێرینەکان، بەرزبنەوە، 
\q2 هەتا پاشای شکۆمەندی بێتە ژوورەوە. 
\q1  
\v 8 ئەم پاشایەی شکۆمەندی کێیە؟ 
\q2 یەزدانی بەهێز و دەسەڵاتدارە، 
\q2 یەزدانی پاڵەوان لە جەنگ. 
\q1  
\v 9 ئەی دەروازەکان، سەر هەڵبڕن! 
\q2 ئەی دەرگا دێرینەکان، بەرزبنەوە! 
\q2 هەتا پاشای شکۆمەندی بێتە ژوورەوە. 
\q1  
\v 10 ئەم پاشایەی شکۆمەندی کێیە؟ 
\q2 یەزدانی سوپاسالار پاشای شکۆمەندییە. 
\c 25  
\cl زەبووری 25 
\d زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، گیانی خۆم بۆ تۆ بەرز دەکەمەوە. 
\b  
\q2  
\v 2 ئەی خودای من، پشتم بە تۆ بەستووە. 
\q1 ڕێ مەدە شەرمەزار بم، 
\q2 دوژمنانم پێ خۆش مەکە. 
\q1  
\v 3 هەموو ئەوانەی ئومێدیان بە تۆ هەیە 
\q2 شەرمەزار نابن، 
\q1 بەڵکو ئەوانە شەرمەزار دەبن 
\q2 کە بەبێ هۆ ناپاکی دەکەن. 
\b  
\q1  
\v 4 ئەی یەزدان، ڕێگاکانی خۆتم پێ بناسێنە، 
\q2 ڕێڕەوەکانی خۆتم فێر بکە. 
\q1  
\v 5 لە ڕاستی خۆت ڕێنماییم بکە و فێرم بکە، 
\q1 چونکە تۆ خودای ڕزگارکەری منیت، 
\q2 بە درێژایی ڕۆژ ئومێدم هەر بە تۆیە. 
\q1  
\v 6 ئەی یەزدان، بەزەیی و خۆشەویستییە نەگۆڕەکەی خۆت لەبیر بێت، 
\q2 چونکە لە دێرزەمانەوە ئەمانە هەن. 
\q1  
\v 7 ئەی یەزدان، گوناهەکانی کاتی گەنجیەتیم و 
\q2 یاخیبوونەکانم بەبیر خۆت مەهێنەوە، 
\q1 بەڵکو بەگوێرەی خۆشەویستییە نەگۆڕەکەت بیرم لێ بکەرەوە، 
\q2 لە پێناوی چاکی خۆت. 
\b  
\q1  
\v 8 یەزدان چاک و سەرڕاستە، 
\q2 بۆیە گوناهباران فێری ڕاستەڕێیی دەکات، 
\q1  
\v 9 ڕابەرایەتی بێفیزەکان دەکات بۆ دادپەروەری، 
\q2 ئەوان فێری ڕێگای خۆی دەکات. 
\q1  
\v 10 هەموو ڕێگاکانی یەزدان ڕاست و خۆشەویستی نەگۆڕن 
\q2 بۆ ئەو کەسانەی فەرزەکانی پەیمانەکەی ناشکێنن. 
\q1  
\v 11 ئەی یەزدان، لە پێناوی ناوی خۆت، 
\q2 لە گوناهم خۆشبە، هەرچەندە گەورەشە. 
\b  
\q1  
\v 12 کێیە ئەو کەسەی لە یەزدان دەترسێت؟ 
\q2 خودا فێری ئەو ڕێگایەی دەکات کە بۆی هەڵبژاردووە. 
\q1  
\v 13 هەموو ڕۆژانی لە چاکەدا دەبێت و 
\q2 زەوی بە میرات بۆ نەوەکانی دەمێنێتەوە. 
\q1  
\v 14 خودا نهێنی خۆی بەوانە دەسپێرێت کە لێی دەترسن، 
\q2 وا دەکات پەیمانەکەی زانراو بێت لەلایان. 
\q1  
\v 15 من هەمیشە چاوم ئاراستەی یەزدان کردووە، 
\q2 چونکە تەنها ئەو پێم لە تەڵە دەکاتەوە. 
\b  
\q1  
\v 16 ئاوڕم لێ بدەوە و لەگەڵم میهرەبان بە، 
\q2 چونکە تەنها و کڵۆڵم. 
\q1  
\v 17 دڵتەنگیم زیاد بووە، 
\q2 لە تەنگانەکانم ڕزگارم بکە. 
\q1  
\v 18 تەماشای داماوی و ڕەنجکێشانم بکە و 
\q2 لە هەموو گوناهەکانم خۆشبە. 
\q1  
\v 19 تەماشای دوژمنەکانم بکە چەند زۆر بوونە و 
\q2 چەند بە قینەوە ڕقیان لێمە. 
\b  
\q1  
\v 20 ژیانم بپارێزە و ڕزگارم بکە، 
\q2 شەرمەزارم مەکە، 
\q2 چونکە پەنا وەبەر تۆ دەهێنم. 
\q1  
\v 21 با دروستی و سەرڕاستی پارێزەرم بن، 
\q2 چونکە ئومێدم بە تۆیە. 
\b  
\q1  
\v 22 ئەی خودایە، ئیسرائیل بکڕەوە 
\q2 لە هەموو تەنگانەکانی! 
\c 26  
\cl زەبووری 26 
\d زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، ئەستۆپاکیم بسەلمێنە، 
\q2 چونکە بەبێ کەموکوڕی ژیاوم، 
\q1 پشتم بە یەزدان بەستووە، 
\q2 بەبێ دوودڵی. 
\q1  
\v 2 ئەی یەزدان، تاقیم بکەوە، بمخە ناو لێکۆڵینەوە، 
\q2 مێشک و دڵم بپشکنە، 
\q1  
\v 3 چونکە خۆشەویستی نەگۆڕی تۆم لەبەرچاوە، 
\q2 بە ڕاستیی تۆ ڕەفتار دەکەم. 
\b  
\q1  
\v 4 لەگەڵ فێڵبازان دانانیشم، 
\q2 تێکەڵی دووڕووان نابم. 
\q1  
\v 5 ڕقم لە کۆمەڵی بەدکاران دەبێتەوە و 
\q2 لەگەڵ خراپەکار دانانیشم. 
\q1  
\v 6 دەستەکانم دەشۆم تاکو بێتاوانیم دەربخەم، 
\q2 ئەی یەزدان، بە دەوری قوربانگاکەتدا دەسووڕێمەوە و 
\q1  
\v 7 بە دەنگی بەرز ستایشت دەکەم و 
\q2 هەموو کارە سەرسوڕهێنەرەکانت ڕادەگەیەنم. 
\b  
\q1  
\v 8 ئەی یەزدان، ئەو ماڵەم خۆشدەوێت کە تۆ تێیدا دەژیت، 
\q2 ئەو شوێنەی کە شکۆی تۆی تێدا نیشتەجێیە. 
\q1  
\v 9 گیانم لەگەڵ گوناهباران کۆ مەکەوە، 
\q2 ژیانم لەگەڵ خوێنڕێژان، 
\q1  
\v 10 ئەوانەی کە دەستیان بە خراپە پیس بووە، 
\q2 ئەوانەی دەستی ڕاستەیان پڕ لە بەرتیلە. 
\q1  
\v 11 بەڵام من بەبێ کەموکوڕی ژیاوم، 
\q2 بمکڕەوە و لەگەڵم میهرەبان بە. 
\b  
\q1  
\v 12 پێم لەسەر زەوییەکی تەختە، 
\q2 لە کۆڕ و کۆمەڵی گەورەدا ستایشی یەزدان دەکەم. 
\c 27  
\cl زەبووری 27 
\d زەبوورێکی داود. 
\q1  
\v 1 یەزدان ڕووناکی و ڕزگاریی منە، 
\q2 لە کێ بترسم؟ 
\q1 یەزدان قەڵای ژیانی منە، 
\q2 لە کێ بتۆقم؟ 
\b  
\q1  
\v 2 کاتێک بەدکاران لێم نزیک بنەوە 
\q2 بۆ ئەوەی گۆشتم بخۆن، 
\q1 کاتێک دوژمنان و ناحەزانم پەلامارم بدەن، 
\q2 ساتمە دەکەن و دەکەون. 
\q1  
\v 3 ئەگەر لەشکرێکیش دەورم بدات، 
\q2 دڵم ناترسێت. 
\q1 ئەگەر جەنگ بەرپا بکەن دژم، 
\q2 ئەو کاتەش هەر دڵنیا دەبم. 
\b  
\q1  
\v 4 داوای یەک شت لە یەزدان دەکەم، 
\q2 ئەوەی بەدوایدا دەگەڕێم: 
\q1 کە هەموو ڕۆژانی ژیانم 
\q2 لە ماڵی یەزدان نیشتەجێ بم، 
\q1 تاکو تەماشای جوانی یەزدان بکەم و 
\q2 لە پەرستگاکەی ورد ببمەوە. 
\q1  
\v 5 لەبەر ئەوەی لە ڕۆژی بەڵا، 
\q2 لەژێر سێبەری خۆی دەمشارێتەوە، 
\q1 بە پڵاسی نشینگەکەی دامدەپۆشێت. 
\q2 بۆ سەر تاشەبەردێک بڵندم دەکاتەوە. 
\b  
\q1  
\v 6 ئێستاش سەرفرازم بەسەر دوژمنانی دەوروبەرم، 
\q2 لەناو نشینگەکەیدا بە هاوار و خۆشییەوە قوربانی پێشکەش دەکەم، 
\q2 سروود بۆ یەزدان دەڵێم و مۆسیقا دەژەنم. 
\b  
\q1  
\v 7 ئەی یەزدان، گوێت لە دەنگم بێ کاتێک لێت دەپاڕێمەوە، 
\q2 لەگەڵم میهرەبان بە و وەڵامم بدەوە. 
\q1  
\v 8 سەبارەت بە تۆ دڵم دەڵێت: «ڕووت لەو بکە!» 
\q2 ئەی یەزدان، ڕووم لە تۆ دەکەم. 
\q1  
\v 9 ڕووی خۆتم لێ مەشارەوە، 
\q2 خزمەتکاری خۆت لە کاتی تووڕەییت مەگەڕێنەوە، 
\q2 تۆ یارمەتیدەری من بوویت. 
\q1 ئەی خودای ڕزگارکەرم، 
\q2 ڕەتم مەکەرەوە و جێم مەهێڵە. 
\q1  
\v 10 تەنانەت دایک و باوکیشم وازم لێ بهێنن، 
\q2 یەزدان دەمگرێتە خۆی. 
\q1  
\v 11 ئەی یەزدان، ڕێگای خۆتم فێر بکە، 
\q2 بۆ ڕێگای ڕاست ڕێنماییم بکە، 
\q2 لەبەر دوژمنەکانم. 
\q1  
\v 12 بە ویستی ناحەزەکانم مەمسپێرە، 
\q2 چونکە شایەتی درۆ لێم ڕاست بوونەتەوە، 
\q2 هەناسەی زۆردارییان لێ دێتە دەرەوە. 
\b  
\q1  
\v 13 من هێشتا باوەڕم بەوە هەیە، 
\q2 کە لە خاکی زیندووان 
\q2 چاکەی یەزدان دەبینم. 
\q1  
\v 14 چاوەڕێی یەزدان بە، 
\q2 خۆت ئازا بکە و دڵت بەهێز بکە، 
\q2 چاوەڕێی یەزدان بە. 
\c 28  
\cl زەبووری 28 
\d زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، من بۆ تۆ هاوار دەکەم. 
\q2 ئەی تاشەبەردەکەم، گوێی خۆتم لێ کەڕ مەکە، 
\q1 چونکە ئەگەر تۆ خۆتم لێ بێدەنگ بکەیت، 
\q2 وەک ئەوانەم لێدێت کە شۆڕ دەبنەوە ناو گۆڕ. 
\q1  
\v 2 گوێ لە دەنگی پاڕانەوەم بگرە، 
\q2 کاتێک کە هاوارت بۆ دەهێنم، 
\q1 دەستەکانم بەرز دەکەمەوە 
\q2 بەرەو شوێنی هەرەپیرۆزی تۆ. 
\b  
\q1  
\v 3 لەگەڵ بەدکارەکان ڕاممەکێشە، 
\q2 ئەوانەی ئیشی خراپە دەکەن، 
\q1 بە ئاشتی قسە لەگەڵ دراوسێکانیان دەکەن، 
\q2 بەڵام دڵیان پڕ لە کینەیە. 
\q1  
\v 4 بەگوێرەی کردەوە و خراپەکارییەکانیان سزایان بدە، 
\q2 بەگوێرەی کردەوەکانی دەستیان سزایان بدە و 
\q2 ڕەفتارەکانی خۆیان بگەڕێنەوە سەر خۆیان. 
\b  
\q1  
\v 5 لەبەر ئەوەی گوێ نادەن بە کردارەکانی یەزدان و 
\q2 بە کارەکانی دەستی، 
\q1 تێکیان دەشکێنێت و 
\q2 جارێکی دیکە بنیادیان نانێتەوە. 
\b  
\q1  
\v 6 ستایش بۆ یەزدان، 
\q2 چونکە گوێی لە دەنگی پاڕانەوەم بوو. 
\q1  
\v 7 یەزدان هێز و قەڵغانی منە، 
\q2 دڵم متمانەی بەو کرد و یارمەتیم وەرگرت، 
\q1 دڵم شاد دەبێت و 
\q2 بە گۆرانی خۆم ستایشی دەکەم. 
\b  
\q1  
\v 8 یەزدان هێزی گەلەکەیەتی، 
\q2 قەڵای ڕزگاریی دەستنیشانکراوەکەی\f + \fr 28:8 \ft بە زمانی عیبری پێی دەگوترێ \+tl مەشیخ‏\+tl* یان \+tl مەشیح‏\+tl*.‏\f*. 
\q1  
\v 9 گەلەکەت ڕزگار بکە و میراتەکەت بەرەکەتدار بکە، 
\q2 ببە بە شوانیان و هەتاهەتایە هەڵیانبگرە. 
\c 29  
\cl زەبووری 29 
\d زەبوورێکی داود «لە جەژنی کەپرەشینە». 
\q1  
\v 1 ستایشی شکۆ و هێزی یەزدان بکەن، 
\q2 ستایشی یەزدان بکەن، ئەی فریشتەکانی ئاسمان. 
\q1  
\v 2 ستایشی ناوی شکۆداری یەزدان بکەن، 
\q2 کڕنۆش بۆ یەزدان ببەن، چونکە شکۆدار و پیرۆزە. 
\b  
\q1  
\v 3 دەنگی یەزدان لەسەر ئاوەکان دەنگ دەداتەوە، 
\q2 خودای شکۆمەندی تریشقە دەدات، 
\q2 یەزدان لەسەر ئاوە زۆرەکان تریشقە دەدات. 
\q1  
\v 4 دەنگی یەزدان بە هێزە، 
\q2 دەنگی یەزدان بە شکۆیە. 
\q1  
\v 5 دەنگی یەزدان داری ئورز دەشکێنێت، 
\q2 یەزدان ئورزەکانی لوبنان دەشکێنێت، 
\q1  
\v 6 وا دەکات لوبنان\f + \fr 29:6 \ft مەبەستی لە چیای لوبنانە.‏\f* وەک گوێرەکە ڕابکات و 
\q2 حەرمۆنیش\f + \fr 29:6 \ft هەروەها سریۆنیشی پێ دەگوترێ، بەرزترین شاخە لە سوریا.‏\f* وەک جوانەگای کێوی. 
\q1  
\v 7 دەنگی یەزدان چەخماخە دەدات 
\q2 بە بروسکە و تریسکەوە. 
\q1  
\v 8 دەنگی یەزدان بیابان دەلەرزێنێت 
\q2 یەزدان بیابانی قادێش\f + \fr 29:8 \ft دەکەوێتە دووری 80 کم لە باکووری بیری شابەع، گەلی ئیسرائیل لەدوای هاتنەدەرەوەیان لە میسر ماوەیەک لەوێ ماونەتەوە.‏\f* دەلەرزێنێت. 
\q1  
\v 9 دەنگی یەزدان دار بەڕوو لوول دەدات و 
\q2 دارستانەکان ڕووت دەکاتەوە. 
\q1 لەناو پەرستگاکەیدا هەموو هاوار دەکەن: «شکۆمەندی!» 
\b  
\q1  
\v 10 یەزدان بە تەختی پاشاییەوە، لەسەر تۆفان دادەنیشێت، 
\q2 یەزدان هەتاهەتایە وەک پاشا لەسەر تەخت دادەنیشێت. 
\q1  
\v 11 یەزدان هێز بە گەلەکەی دەبەخشێت، 
\q2 یەزدان بەرەکەتی ئاشتی دەداتە گەلەکەی. 
\c 30  
\cl زەبووری 30 
\d زەبوورێکی داود.  // گۆرانییەک بۆ تەرخانکردنی پەرستگا.\f + \fr 30:0 \ft بڕوانە \xt یەکەم پاشایان 8‏:61 و دووەم پوختەی مێژوو 7‏\ft ‏.‏\f* 
\q1  
\v 1 ئەی یەزدان، بە گەورەت دەزانم، 
\q2 چونکە هەڵتکێشام و 
\q2 نەتهێشت دوژمنەکانم شانازیم بەسەردا بکەن. 
\q1  
\v 2 ئەی یەزدان، خودای من، هاوارم بۆ تۆ هێنا، 
\q2 تۆش چاکت کردمەوە. 
\q1  
\v 3 ئەی یەزدان، تۆ گیانی منت لەناو جیهانی مردووان هێنایە دەرەوە، 
\q2 منت دەرباز کرد لەوەی شۆڕببمەوە ناو گۆڕ. 
\b  
\q1  
\v 4 ئەی خۆشەویستانی یەزدان، گۆرانی بۆ بڵێن، 
\q2 ستایشی ناوە پیرۆزەکەی بکەن، 
\q1  
\v 5 چونکە تووڕەبوونی تەنها چرکەیەکە، 
\q2 بەڵام ڕەزامەندی بە درێژایی ژیانە. 
\q1 ڕەنگە گریان بۆ شەوێ بمێنێت، 
\q2 بەڵام بۆ بەیانییەکەی هەلهەلە دێنێت. 
\b  
\q1  
\v 6 کاتێک هەستم بە دڵنیایی کرد گوتم: 
\q2 «هەرگیز نالەقێم.» 
\q1  
\v 7 ئەی یەزدان، بە ڕەزامەندی خۆت، 
\q2 منت وەک چیایەکی بەهێز چەسپاند، 
\q1 بەڵام کە ڕووی خۆتت لە من شاردەوە، 
\q2 پەرێشان بووم. 
\b  
\q1  
\v 8 ئەی یەزدان، من هاوارم بۆ تۆ هێنا، 
\q2 من لە پەروەردگار پاڕامەوە: 
\q1  
\v 9 «مەرگی من سوودی چی تێدایە، 
\q2 ئەگەر من شۆڕ ببمەوە ناو گۆڕ؟ 
\q1 ئایا خۆڵ ستایشت دەکات؟ 
\q2 ئایا دڵسۆزیت ڕادەگەیەنێت؟ 
\q1  
\v 10 ئەی یەزدان، گوێ بگرە و لەگەڵم میهرەبان بە! 
\q2 ئەی یەزدان، ببە بە یارمەتیدەرم!» 
\b  
\q1  
\v 11 تۆ شینی منت گۆڕی بۆ شایی، 
\q2 جلوبەرگی گوشت\f + \fr 30:11 \ft لە کاتی ماتەمگێڕان و تۆبەکردندا جلوبەرگی لە گوش دروستکراویان لەبەرکردووە کە ئەزیەتی پێستیانی داوە.‏\f* لەبەر داماڵیم و بەرگی شادیت لەبەرکردم، 
\q1  
\v 12 بۆ ئەوەی دڵم گۆرانیت بۆ بڵێت و بێدەنگ نەبێت. 
\q2 ئەی یەزدان، خودای من، هەتاهەتایە هەر ستایشت دەکەم. 
\c 31  
\cl زەبووری 31 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، من پەنا دەبەمە بەر تۆ، 
\q2 با هەرگیز شەرمەزار نەبم، 
\q2 بە ڕاستودروستی خۆت دەربازم بکە. 
\q1  
\v 2 گوێت بۆم شل بکە، 
\q2 بە زوویی فریام بکەوە، 
\q1 ببە بەو تاشەبەردەی پەنای بۆ دەبەم، 
\q2 بەو قەڵا سەختە بۆ ڕزگارکردنم. 
\q1  
\v 3 لەبەر ئەوەی تاشەبەرد و قەڵای منی، 
\q2 لە پێناوی ناوی خۆت ڕابەرایەتی و ڕێنماییم بکە. 
\q1  
\v 4 لەو تەڵەیەی بۆم نراوەتەوە ئازادم بکە، 
\q2 چونکە تۆ پەناگای منی. 
\q1  
\v 5 ڕۆحی خۆم بە دەستی تۆ دەسپێرم، 
\q2 ئەی یەزدان، خودای ڕاستی، بمکڕەوە. 
\b  
\q1  
\v 6 من ڕقم لەوانە دەبێتەوە کە دەست بە بتی پووچەوە دەگرن، 
\q2 من متمانەم بە یەزدان هەیە. 
\q1  
\v 7 من بە خۆشەویستی نەگۆڕی تۆ شاد و دڵخۆش دەبم، 
\q2 چونکە تۆ دەردی منت بینیوە و 
\q2 لە تەنگانەدا گیانی منت ناسیوە. 
\q1  
\v 8 نەتخستوومەتە بەردەستی دوژمنان، 
\q2 بەڵکو لەسەر شوێنێکی فراوان ڕاتگرتووم. 
\b  
\q1  
\v 9 ئەی یەزدان، لەگەڵم میهرەبان بە، چونکە لە تەنگانەدام. 
\q2 چاوەکانم کزبوون لە خەفەتان، 
\q2 ڕۆح و لەشم لە خەمان. 
\q1  
\v 10 ژیانم بە خەم و خەفەت فەوتاوە، 
\q2 ساڵانی تەمەنم بە ئاخ هەڵکێشان، 
\q1 لەبەر دەرد و بەڵا هێزم لێ بڕاوە، 
\q2 ئێسقانەکانم پووکاونەتەوە. 
\q1  
\v 11 بەهۆی دوژمنەکانمەوە، 
\q2 بە تەواوی بوومەتە مایەی شەرمەزاری لای دراوسێکانم، 
\q1 بوومەتە مایەی ترس بۆ ئاشناکانم، 
\q2 ئەوانەی لە شەقامدا دەمبینن، لێم دوور دەکەونەوە. 
\q1  
\v 12 لەبیرکراوم وەک ئەوەی مردبم، 
\q2 وەک قاپێکی شکاوم بەسەرهاتووە. 
\q1  
\v 13 گوێم لە چپەچپی زۆر کەس بووە، 
\q2 «لە هەموو لایەکەوە ترس و تۆقین هەیە!» 
\q1 هەموو پێکەوە پیلان لە دژم دەگێڕن، 
\q2 بیر لەوە دەکەنەوە ژیانم لەناو ببەن. 
\b  
\q1  
\v 14 بەڵام ئەی یەزدان، من پشتم بە تۆ بەستووە، 
\q2 دەڵێم: «تۆ خودای منیت.» 
\q1  
\v 15 ڕۆژگارم لەناو دەستی تۆدایە، 
\q2 لە دەستی دوژمنان و 
\q2 ئەوانەی ڕاوم دەنێن دەربازم بکە. 
\q1  
\v 16 با ڕوخسارت بەسەر خزمەتکاری خۆتدا بدرەوشێتەوە، 
\q2 بە خۆشەویستی نەگۆڕی خۆت ڕزگارم بکە. 
\q1  
\v 17 با شەرمەزار نەبم ئەی یەزدان، 
\q2 چونکە هاوار بۆ تۆ دەهێنم، 
\q1 با بەدکاران شەرمەزار بن، 
\q2 لەناو جیهانی مردووان خامۆش بن. 
\q1  
\v 18 با زمانە درۆزنەکانیان لاڵ بێت، 
\q2 چونکە بە فیز و وشەی ناشیرینەوە 
\q2 سووکایەتی بە سەرڕاستان دەکەن. 
\b  
\q1  
\v 19 چاکەت چەند مەزنە، 
\q2 کە هەڵتگرتووە بۆ ئەوانەی ترسی تۆیان لە دڵدایە، 
\q1 ئەوەی بە بەرچاوی خەڵکەوە، 
\q2 بەوانەی دەبەخشیت کە پەنات بۆ دەهێنن. 
\q1  
\v 20 لە پەنای خۆت دەیانشاریتەوە، 
\q2 لە پیلانەکانی خەڵکی، 
\q1 لەژێر سێبەری خۆت دەیانپارێزیت، 
\q2 لە زمانی سکاڵاکەران. 
\b  
\q1  
\v 21 ستایش بۆ یەزدان، 
\q2 چونکە خۆشەویستییە نەگۆڕە سەرسوڕهێنەرەکەی خۆی نیشاندام، 
\q2 کاتێک لە شارێکی ئابڵوقەدراو بووم. 
\q1  
\v 22 لە کاتی سەرلێشێوانم گوتم: 
\q2 «لەبەرچاوت نەماوم!» 
\q1 بەڵام تۆ گوێت لە دەنگی پاڕانەوەم گرت، 
\q2 کە هاوارم بۆت هێنا. 
\b  
\q1  
\v 23 ئەی هەموو خۆشەویستانی، یەزدانتان خۆشبوێت! 
\q2 یەزدان دڵسۆزەکان دەپارێزێت، 
\q2 بەڵام بە تەواوی سزای لووتبەرزەکان دەدات. 
\q1  
\v 24 ئازابن و دڵتان بەهێز بکەن، 
\q2 ئەی هەموو ئەوانەی هیواتان بە یەزدان هەیە. 
\c 32  
\cl زەبووری 32 
\d هۆنراوەیەکی داود. 
\q1  
\v 1 خۆزگە دەخوازرێ بەوەی لە یاخیبوونەکانی بەخشراوە، 
\q2 گوناهەکانی داپۆشراوە. 
\q1  
\v 2 خۆزگە دەخوازرێ بەو کەسەی 
\q2 کە یەزدان تاوانی لەسەر ناژمێرێت و 
\q2 لە ڕۆحەکەی بێ فێڵە. 
\b  
\q1  
\v 3 کاتێک دانم بە گوناهەکانمدا نەنا، 
\q2 ئێسقانەکانم پووکانەوە، 
\q2 لە ناڵینم بە درێژایی ڕۆژ. 
\q1  
\v 4 لەبەر ئەوەی بە شەو و بە ڕۆژ، 
\q2 دەستت بەسەر سەرمەوە قورس بوو، 
\q2 تەڕێتیم گۆڕا بۆ وشکی هاوین.\f + \fr 32:4 \ft لە دەقی عیبری لێرە و لە ئایەتەکانی 5 و 7، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 5 ئینجا لەلای تۆدا داندەنێم بە گوناهم و 
\q2 تاوانم ناشارمەوە. 
\q1 گوتم: «لەلای یەزدان داندەنێم بە یاخیبوونم.» 
\q2 تۆش لە تاوانی گوناهم خۆشبوویت. 
\b  
\q1  
\v 6 بۆیە با هەموو خواناسێک لێت بپاڕێتەوە 
\q2 لە کاتی خۆی بتدۆزێتەوە، 
\q2 بێگومان کە لافاو هەستا، نایگاتێ. 
\q1  
\v 7 تۆ پەناگای منیت، 
\q2 لە تەنگانە دەمپارێزی و 
\q2 بە سروودی دەربازبوون دەورم دەدەیت. 
\b  
\q1  
\v 8 خودا دەفەرموێت: «من فێرت دەکەم و ڕێنماییت دەکەم بۆ ئەو ڕێگایەی کە دەبێت پێیدا بڕۆیت، 
\q2 ئامۆژگاریت دەکەم و چاودێریت دەکەم. 
\q1  
\v 9 وەک ئەسپ و هێستر مەبە کە هیچ تێناگەن، 
\q2 بەڵکو دەبێت لغاوی لە دەم بکرێت و جڵەوی ڕابکێشرێت، 
\q2 بۆ ئەوەی لێت نزیک ببێتەوە. 
\q1  
\v 10 بەدکارەکان ئازاریان زۆرە، 
\q2 بەڵام ئەوەی پشت بە یەزدان ببەستێت، 
\q2 خۆشەویستی نەگۆڕ دەوری دەدات.» 
\b  
\q1  
\v 11 ئەی سەرڕاستەکان، شاد بن بە یەزدان و دڵخۆش بن، 
\q2 ئەی هەموو دڵڕاستەکان، گۆرانی بڵێن! 
\c 33  
\cl زەبووری 33 
\q1  
\v 1 ئەی سەرڕاستان گۆرانی شادی بۆ یەزدان بڵێن، 
\q2 ستایشکردن لە دڵڕاستان دەوەشێتەوە. 
\q1  
\v 2 بە ساز ستایشی یەزدان بکەن، 
\q2 بە قیسارەی دە ژێیی مۆسیقای بۆ بژەنن. 
\q1  
\v 3 سروودێکی نوێی بۆ بڵێن، 
\q2 بە کارامەیی مۆسیقا بژەنن، بە هەلهەلەوە. 
\b  
\q1  
\v 4 لەبەر ئەوەی فەرمایشتی یەزدان ڕاستە، 
\q2 لە هەموو کردارەکانی دڵسۆزە. 
\q1  
\v 5 یەزدان ڕاستودروستی و دادپەروەری خۆشدەوێت، 
\q2 زەوی پڕ بووە لە خۆشەویستییە نەگۆڕەکەی. 
\b  
\q1  
\v 6 بە فەرمانی یەزدان ئاسمان دروستکرا، 
\q2 بە هەناسەی دەمی هەموو ئەستێرەکانی ئاسمان. 
\q1  
\v 7 ئاوی دەریا وەک بەنداو کۆدەکاتەوە و 
\q2 زەریاکان دەخاتە ناو ئەمبارەوە. 
\q1  
\v 8 با هەموو زەوی لە یەزدان بترسێت، 
\q2 با هەموو خەڵکی دنیا سام دایانگرێت! 
\q1  
\v 9 لەبەر ئەوەی کە فەرمووی، پەیدا بوو، 
\q2 فەرمانی دا، بوو. 
\b  
\q1  
\v 10 یەزدان پیلانی نەتەوەکانی پووچ کردەوە، 
\q2 تەگبیری گەلانی هەڵوەشاندەوە. 
\q1  
\v 11 بەڵام پلانی یەزدان هەتاهەتایە دەمێنێت، 
\q2 تەگبیری دڵی بۆ هەموو نەوەکانە. 
\b  
\q1  
\v 12 خۆزگە دەخوازرێ بەو نەتەوەیەی کە یەزدان خودایانە، 
\q2 بەو گەلەی هەڵیبژاردووە بۆ میراتی خۆی. 
\q1  
\v 13 یەزدان لە ئاسمانەوە دەڕوانێتە خوارێ، 
\q2 هەموو ئادەمیزاد دەبینێت. 
\q1  
\v 14 لە نشینگەکەی خۆیەوە 
\q2 چاودێری هەموو دانیشتووانی زەوی دەکات. 
\q1  
\v 15 ئەو کە شێوەی دڵی هەمووانی دروستکردووە، 
\q2 ئاگاداری هەموو کردەوەکانیانە. 
\b  
\q1  
\v 16 هیچ پاشایەک بە گەورەیی سوپاکەی ڕزگاری نابێت، 
\q2 هیچ پاڵەوانێک بە هێزی بازووی دەرباز نابێت. 
\q1  
\v 17 ئەسپ ئومێدێکی دۆڕاوە بۆ ڕزگار بوون، 
\q2 بە توندی هێزی ناتوانێت کەس دەرباز بکات. 
\q1  
\v 18 بەڵام یەزدان چاوی لەوانەیە کە ترسی ئەویان لە دڵدایە، 
\q2 ئەوانەی هیوایان بە خۆشەویستی نەگۆڕی ئەوە، 
\q1  
\v 19 بۆ ئەوەی لە مردندا فریایان بکەوێت و 
\q2 لە قاتوقڕیدا ژیانیان دابین بکات. 
\b  
\q1  
\v 20 ئێمە بە ئومێدی چاوەڕوانی یەزدانین، 
\q2 یەزدان یارمەتیدەر و قەڵغانمانە. 
\q1  
\v 21 دڵمان بەو خۆشە، 
\q2 چونکە ئێمە پشت بە ناوی پیرۆزی ئەو دەبەستین. 
\q1  
\v 22 ئەی یەزدان، با خۆشەویستی نەگۆڕت بەسەرمانەوە بێت، 
\q2 بەگوێرەی هیوامان بە تۆ. 
\c 34  
\cl زەبووری 34 
\d زەبوورێکی داود، کاتێک لەبەردەم ئەبیمەلەخ خۆی کردە شێت، ئەویش دەریکرد و داود ڕۆیشت.\f + \fr 34:0 \ft بڕوانە \xt یەکەم ساموئێل 21‏:10‏–22‏:1.‏\ft ‏\f* 
\q1  
\v 1 هەموو کاتێک ستایشی یەزدان دەکەم، 
\q2 هەمیشە ستایشی ئەو لەسەر لێوەکانمە. 
\q1  
\v 2 گیانم شانازی بە یەزدانەوە دەکات، 
\q2 با ستەملێکراوان گوێیان لێ بێت و شاد بن. 
\q1  
\v 3 با پێکەوە یەزدان بە گەورە بزانین، 
\q2 با بەیەکەوە ناوی بەرز بکەینەوە. 
\b  
\q1  
\v 4 ڕووم لە یەزدان کرد، یەزدان بە دەنگمەوە هات، 
\q2 لە هەموو ترسەکانم فریام کەوت. 
\q1  
\v 5 ئەوانەی پشت بە یەزدان دەبەستن، دەدرەوشێنەوە، 
\q2 ڕوویان هەرگیز شەرمەزاری پێوە نابێت. 
\q1  
\v 6 ئەم پیاوە ستەملێکراوە هاواری بۆ کرد، یەزدان گوێی لێ بوو، 
\q2 لە هەموو گرفتەکانی ڕزگاری کرد. 
\q1  
\v 7 فریشتەی یەزدان دەوری ئەو کەسانە دەگرێت کە لێی دەترسن، 
\q2 دەربازیان دەکات. 
\b  
\q1  
\v 8 تامی بکەن و ببینن کە یەزدان چاکە! 
\q2 خۆزگە دەخوازرێ بەو کەسەی پەنای بۆ دەبات. 
\q1  
\v 9 لە یەزدان بترسن ئەی گەلە پیرۆزەکەی، 
\q2 چونکە ئەوانەی لێی دەترسن پێویستیان بە هیچ نابێت. 
\q1  
\v 10 ڕەنگە شێرەکان تووشی برسیێتی و لاوازی بن، 
\q2 بەڵام ئەوانەی ڕوو لە یەزدان دەکەن پێویستیان بە شتی چاک نابێت. 
\q1  
\v 11 کوڕینە، وەرن گوێ لە من بگرن، 
\q2 فێری لەخواترسیتان دەکەم. 
\q1  
\v 12 چ کەسێکە ژیانی خۆشدەوێت و 
\q2 ئارەزوو دەکات زۆر ڕۆژگاری خۆش ببینێت؟ 
\q1  
\v 13 زمانت لە خراپە بپارێزە و 
\q2 لێوەکانت لە فێڵبازی. 
\q1  
\v 14 لە خراپە دوور بە و چاکە بکە، 
\q2 بەدوای ئاشتیدا بگەڕێ و کۆششی بۆ بکە. 
\b  
\q1  
\v 15 چاوی یەزدان لەسەر ڕاستودروستانە و 
\q2 گوێی لە پاڕانەوەکانیان ڕاگرتووە. 
\q1  
\v 16 ڕووی یەزدان لە دژی خراپەکارانە، 
\q2 تاکو یادەوەرییان لەسەر زەوی ببڕێتەوە. 
\b  
\q1  
\v 17 سەرڕاستان هاوار دەکەن و یەزدان گوێی لێیان دەبێت، 
\q2 لە هەموو تەنگانەکانیان دەربازیان دەکات. 
\q1  
\v 18 یەزدان لە دڵشکاوان نزیکە و 
\q2 ئەوانە ڕزگار دەکات کە ڕۆحیان وردوخاش بووە. 
\b  
\q1  
\v 19 پیاوچاک گرفتی زۆر دەبێت، 
\q2 بەڵام یەزدان لە هەمووی دەربازی دەکات، 
\q1  
\v 20 هەموو ئێسکەکانی دەپارێزێت، 
\q2 هیچیان ناشکێنرێت. 
\b  
\q1  
\v 21 بەدکاری بەدکاران لەناو دەبات، 
\q2 ئەوانەی ڕقیان لە ڕاستودروستانە، تاوانبار دەکرێن. 
\q1  
\v 22 یەزدان گیانی خزمەتکارەکانی خۆی دەکڕێتەوە و 
\q2 ئەوانەی پەنا دەبەنە بەر یەزدان تاوانبار ناکرێن. 
\c 35  
\cl زەبووری 35 
\d زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، ململانێی ئەوانە بکە کە ململانێم لەگەڵ دەکەن، 
\q2 لە دژی ئەوانە بجەنگە کە لە دژی من دەجەنگن. 
\q1  
\v 2 سپەر بپۆشە و قەڵغان هەڵبگرە، 
\q2 ڕاپەڕە و بگە فریام. 
\q1  
\v 3 ڕم ئاراستە بکە و تەور هەڵبگرە 
\q2 لە دژی ئەوانەی ڕاوم دەنێن. 
\q2 بە گیانم بڵێ: «من ڕزگاریی تۆم.» 
\b  
\q1  
\v 4 با ڕیسوا و شەرمەزار بن 
\q2 ئەوانەی هەوڵی کوشتنم دەدەن، 
\q1 با بەرەو پاش ببنەوە و ڕیسوا بن 
\q2 ئەوانەی پیلان دادەنێن بۆ ڕاوکردنم. 
\q1  
\v 5 با وەک کای بەر بایان لێ بێت، 
\q2 فریشتەی یەزدان ڕایانبماڵێت. 
\q1  
\v 6 با ڕێگایان تاریک و خلیسک بێت، 
\q2 فریشتەی یەزدان ڕاویان بنێت. 
\b  
\q1  
\v 7 لەبەر ئەوەی بەبێ هۆ داویان بۆ نامەوە، 
\q2 بەبێ هۆ چاڵیان بۆ هەڵکەندم، 
\q1  
\v 8 با ماڵوێرانی لەناکاو بەسەریاندا بدات، 
\q2 با بەو داوەوە بن کە خۆیان ناویانەتەوە، 
\q2 با بکەونە ئەو ماڵوێرانییە. 
\q1  
\v 9 ئەوسا گیانم بە یەزدان شاد دەبێت، 
\q2 بە ڕزگارییەکەی دڵخۆش دەبێت. 
\q1  
\v 10 هەموو ئێسقانەکانم هاوار دەکەن: 
\q2 «ئەی یەزدان، کێ وەک تۆیە؟ 
\q1 تۆ داماو دەرباز دەکەیت لە دەست ئەوانەی کە لەو بەهێزترن، 
\q2 هەژار و نەبوون لە دەست ئەوانەی دەیانڕووتێننەوە.» 
\b  
\q1  
\v 11 شایەتە دڵڕەقەکان ڕاست دەبنەوە، 
\q2 پرسیاری شتی وا دەکەن کە ئاگام لێی نییە. 
\q1  
\v 12 بەرامبەر بە چاکە خراپەم دەدەنەوە، 
\q2 گیانم بە بێکەسی جێدەهێڵن. 
\q1  
\v 13 بەڵام کاتێک ئەوان نەخۆش دەکەوتن، جلوبەرگی گوشم دەپۆشی، 
\q2 بە ڕۆژووگرتن خۆمم نزم دەکردەوە. 
\q1 کاتێک نوێژەکانم بەبێ وەڵام دەگەڕانەوە، 
\q2  
\v 14 وەک ئەوەی دۆست و برام بێت، 
\q2 پرسەدار بووم بۆی، 
\q1 وەک ئەوەی بۆ دایکم بلاوێنمەوە، 
\q2 لە خەفەتان سەرم دانەواند بوو. 
\q1  
\v 15 بەڵام کە کەوتم، ئەوان بە خۆشییەوە لە دژی من کۆبوونەوە، 
\q2 کەسانێک بێ ئەوەی بیانناسم هێرشیان هێنایە سەرم و 
\q2 بەبێ وەستان ئابڕوویان بردم. 
\q1  
\v 16 وەک خوانەناسان بە خراپی گاڵتەجاڕی دەکەن، 
\q2 ددانیان لێ جیڕدەکردمەوە. 
\b  
\q1  
\v 17 ئەی پەروەردگار، هەتا کەی تەماشا دەکەیت؟ 
\q2 گیانم دەرباز بکە لە دەست تێکدەرییان، 
\q2 ژیانم لەو بەچکە شێرانە. 
\q1  
\v 18 لەنێو کۆڕی گەورە سوپاست دەکەم، 
\q2 لەنێو خەڵکێکی زۆر ستایشت دەکەم. 
\q1  
\v 19 مەهێڵە ئەوانە پێم شاد بن، 
\q2 کە بەبێ هۆ بوونەتە دوژمنم. 
\q1 مەهێڵە ئەوانەی بەبێ هۆ ڕقیان لێمە، 
\q2 بە مەکرەوە چاو لە یەک دابگرن. 
\q1  
\v 20 ئەوانە قسە بۆ ئاشتی ناکەن، 
\q2 بەڵکو درۆ دادەڕێژن 
\q2 لە دژی ئەوانەی بە ئارامی دەژین لەسەر زەوی. 
\q1  
\v 21 دەمیان لێم دەکەنەوە و دەڵێن: 
\q2 «ئەها! بە چاوی خۆمان بینیمان.» 
\b  
\q1  
\v 22 ئەی یەزدان، تۆ ئەمەت بینی، بێدەنگ مەبە. 
\q2 ئەی پەروەردگار، لێم دوور مەبە. 
\q1  
\v 23 هەستە و ڕاپەڕە بۆ دادم، 
\q2 ئەی خودا و گەورەی من، بۆ مافم. 
\q1  
\v 24 ئەی یەزدان، خودای من، بەپێی ڕاستودروستی خۆت ئەستۆپاکیم بسەلمێنە، 
\q2 مەهێڵە ئەوانە پێم شاد بن. 
\q1  
\v 25 مەهێڵە لە دڵی خۆیان بڵێن: «ئەمە مرازی ئێمەیە!» 
\q2 یان بڵێن: «هەڵمانلووشی.» 
\b  
\q1  
\v 26 با هەموو ئەوانەی بە گرفتی من شاد دەبن، 
\q2 تووشی شەرمەزاری و گومڕایی بن. 
\q1 با هەموو ئەوانەی پۆز بەسەر مندا لێدەدەن، 
\q2 بەرگی شەرمەزاری و ڕیسوایی بپۆشن. 
\q1  
\v 27 با ئەوانەی بە بێتاوانکردنی من دڵخۆشن، 
\q2 گۆرانی خۆشی و شادی بڵێن. 
\q1 با هەمیشە بڵێن: «یەزدان پایەبەرز بێت، 
\q2 کە دڵخۆش دەبێت بە ئاشتی خزمەتکارەکەی.» 
\b  
\q1  
\v 28 زمانم باسی ڕاستودروستی تۆ دەکات و 
\q2 بە درێژایی ڕۆژ ستایشت دەکات. 
\c 36  
\cl زەبووری 36 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، زەبوورێکی داودی بەندەی یەزدانە. 
\q1  
\v 1 جاڕنامەیەک لە ناخی دڵمە 
\q2 دەربارەی یاخیبوونی بەدکار: 
\q2 ترسی خودای لەبەرچاو نییە. 
\b  
\q1  
\v 2 بە ڕادەیەک خۆی دەڕازێنێتەوە 
\q2 کە خۆی هەست بە گوناهی خۆی ناکات و ڕقی لێ نابێتەوە. 
\q1  
\v 3 قسەی دەمی خراپە و تەفرەدانە، 
\q2 دەستبەرداری وریایی و چاکی بووە. 
\q1  
\v 4 تەنانەت لەناو نوێنیش بیر لە پیلانی خراپە دەکاتەوە، 
\q2 خۆی دەخاتە سەر ڕێگایەک کە باش نییە، 
\q2 هەڵە ڕەت ناکاتەوە. 
\b  
\q1  
\v 5 ئەی یەزدان، خۆشەویستییە نەگۆڕەکەت دەگاتە ئاسمان، 
\q2 دڵسۆزیت دەگاتە هەورەکان. 
\q1  
\v 6 ڕاستودروستییەکەت وەک چیا سەرکەشەکانە، 
\q2 دادپەروەرییەکەت وەک دەریا گەورەکەی ژێر زەوییە\f + \fr 36:6 \ft بەپێی بیروباوەڕی خەڵکی ڕۆژهەڵاتی کۆن (دەریای ژێر زەوی) هەبوو کە سەرچاوەی کانیاو و ڕووبارەکان بوو.‏\f*. 
\q1 ئەی یەزدان، تۆ مرۆڤ و ئاژەڵەکانیش ڕزگار دەکەیت. 
\q2  
\v 7 ئەی خودایە، خۆشەویستییە نەگۆڕەکەت چەند بەنرخە! 
\q1 ئادەمیزاد لەژێر سێبەری باڵەکانت پەنا دەگرن. 
\q1  
\v 8 بە چەوری ماڵەکەت تێر دەبن، 
\q2 تۆش پێیان دەدەیت لە ڕووباری خۆشییەکانت بنۆشن، 
\q1  
\v 9 چونکە کانی ژیان لەلای تۆیە، 
\q2 بە ڕووناکی تۆ ئێمە ڕووناکی دەبینین. 
\b  
\q1  
\v 10 با خۆشەویستییە نەگۆڕەکەت بەردەوام بێت بۆ ئەوانەی دەتناسن، 
\q2 ڕاستودروستییەکەشت بۆ ئەوانەی دڵڕاستن. 
\q1  
\v 11 با نەکەومە ژێر پێی پیاوی لووتبەرز، 
\q2 دەستی بەدکاران وێڵم نەکات. 
\q1  
\v 12 ببینە بەدکاران چۆن دەڕووخێن، 
\q2 دەکەون و ناتوانن هەستنەوە! 
\c 37  
\cl زەبووری 37 
\d زەبوورێکی داود. 
\q1  
\v 1 بەهۆی خراپەکاران مەراق مەخۆ، 
\q2 بەغیلی بە بەدکاران مەبە، 
\q1  
\v 2 چونکە وەک گیان، زوو وشک دەبن، 
\q2 وەک گژوگیای سەوز زوو سیس دەبن. 
\b  
\q1  
\v 3 پشت بە یەزدان ببەستە و چاکە بکە، 
\q2 لەسەر خاکەکە نیشتەجێ بە و چاودێری دڵسۆزی بکە. 
\q1  
\v 4 خۆشی لە یەزدان ببینە، 
\q2 داواکارییەکانی دڵت پێدەبەخشێت. 
\b  
\q1  
\v 5 ڕێگای خۆت بە یەزدان بسپێرە و 
\q2 متمانەی پێ بکە و ئەو ئاوا دەکات: 
\q1  
\v 6 ڕاستودروستیت وەک ڕووناکی دەردەخات، 
\q2 بێتاوانییەکەت وەک خۆری نیوەڕۆ. 
\b  
\q1  
\v 7 لەبەردەم یەزدان بێدەنگ بە و بە ئارامییەوە چاوەڕێی بکە، 
\q2 کاتێک ئەوانە لە ڕێگاکانیان سەردەکەون، 
\q2 کاتێک فرتوفێڵەکانیان جێبەجێ دەکەن، مەراق مەخۆ. 
\b  
\q1  
\v 8 لە تووڕەیی هێوربەوە و خۆت لە قین لابدە. 
\q2 مەراق مەخۆ، دەنا بەرەو خراپەت دەبات. 
\q1  
\v 9 بەدکاران دوایان دەبڕدرێتەوە، 
\q2 بەڵام ئەوانەی ئومێدیان بە یەزدانە، دەبنە میراتگری خاکەکە. 
\b  
\q1  
\v 10 پاش ماوەیەکی کەم بەدکار نامێنێت، 
\q2 دەڕوانیتە شوێنەکەی، لەوێ نەماوە. 
\q1  
\v 11 بەڵام بێفیزەکان دەبن بە میراتگری خاکەکە و 
\q2 خۆشی لە زۆری ئاشتی دەبینن. 
\b  
\q1  
\v 12 خراپەکار پیلان لە دژی کەسی ڕاستودروست دادەڕێژێت و 
\q2 ددانی لێ جیڕدەکاتەوە، 
\q1  
\v 13 بەڵام پەروەردگار پێی پێدەکەنێت، 
\q2 چونکە دەزانێت ڕۆژی دێت. 
\b  
\q1  
\v 14 بەدکاران شمشێر هەڵدەکێشن و 
\q2 کەوانەکانیان دەچەمێننەوە، 
\q1 بۆ ئەوەی هەژار و نەدارەکان بپێکن، 
\q2 بۆ سەربڕینی ئەوانەی ڕێگایان ڕاستە. 
\q1  
\v 15 بەڵام شمشێرەکانیان دەچێتە ناو دڵی خۆیان، 
\q2 کەوانەکانیان تێکدەشکێت. 
\b  
\q1  
\v 16 ئەو کەمەی کە کەسی ڕاستودروست هەیەتی، 
\q2 لە سامانی گەلێک بەدکاران باشترە، 
\q1  
\v 17 چونکە بەدکارەکان بازوویان دەشکێت، 
\q2 بەڵام یەزدان پشتی ڕاستودروستان دەگرێت. 
\b  
\q1  
\v 18 یەزدان تەمەنی ئەوانە دەزانێت کە بێ کەموکوڕین، 
\q2 هەتاهەتایە میراتیان دەمێنێت. 
\q1  
\v 19 لە ڕۆژگاری بەڵا شەرمەزار نابن، 
\q2 لە ڕۆژگاری قاتوقڕیدا تێر دەبن. 
\b  
\q1  
\v 20 بەڵام بەدکاران دەفەوتێن، 
\q2 دوژمنەکانی یەزدانیش وەک گوڵی کێوی لەناودەچن، 
\q2 وەک دووکەڵ لەناودەچن. 
\b  
\q1  
\v 21 بەدکاران قەرز دەکەن و پێیان نادرێتەوە، 
\q2 بەڵام ڕاستودروستەکان بە دڵفراوانییەوە دەبەخشن. 
\q1  
\v 22 ئەوانەی یەزدان بەرەکەتداری کردوون دەبن بە میراتگری خاکەکە، 
\q2 بەڵام ئەوانەی بەر نەفرەتی کەوتوون دوایان دەبڕدرێتەوە. 
\b  
\q1  
\v 23 یەزدان هەنگاوەکانی مرۆڤ دەچەسپێنێ، 
\q2 بە ڕێگاکەی دڵخۆش دەبێ. 
\q1  
\v 24 ئەگەر پێی بخزێت، ناکەوێت، 
\q2 چونکە یەزدان بە دەستی خۆی پشتی دەگرێت. 
\b  
\q1  
\v 25 من گەنج بووم و ئێستا پیرم، 
\q2 هەرگیز نەمبینی ڕاستودروست وازی لێ بهێنرێت، 
\q2 یان منداڵەکانی سواڵی نان بکەن. 
\q1  
\v 26 هەردەم دڵفراوانە و قەرز دەدات، 
\q2 منداڵەکانیشی بەرەکەتدار دەبن. 
\b  
\q1  
\v 27 لە بەدکاری لابدە و چاکە بکە، 
\q2 ئینجا هەتاهەتایە لە خاکەکە نیشتەجێ دەبیت، 
\q1  
\v 28 چونکە یەزدان حەز لە دادپەروەری دەکات، 
\q2 واز لە خۆشەویستانی ناهێنێ. 
\b  
\q1 هەتاهەتایە دەپارێزرێن، 
\q2 بەڵام منداڵەکانی بەدکاران دوایان دەبڕدرێتەوە. 
\q1  
\v 29 ڕاستودروستان دەبن بە میراتگری خاکەکە و 
\q2 هەتاهەتایە لەسەری نیشتەجێ دەبن. 
\b  
\q1  
\v 30 دەمی پیاوچاک بە دانایی دەدوێت، 
\q2 زمانیشی باسی دادپەروەری دەکات. 
\q1  
\v 31 فێرکردنی\f + \fr 37:31 \ft تەورات.‏\f* خودای خۆی لەناو دڵیەتی، 
\q2 بۆیە پێی ناخلیسکێت. 
\b  
\q1  
\v 32 بەدکار خۆی مات دەکات بۆ ڕاستودروست، 
\q2 هەوڵدەدات بیکوژێت، 
\q1  
\v 33 بەڵام یەزدان لەبەردەستی بەجێی ناهێڵێت، 
\q2 ناهێڵێ لە دادگاش تاوانبار بکرێت. 
\b  
\q1  
\v 34 چاوەڕێی یەزدان بکە و 
\q2 ڕێگای ئەو بگرە. 
\q1 ئەویش بەرزت دەکاتەوە و دەتکات بە میراتگری خاکەکە، 
\q2 کاتێک بەدکاران دوایان دەبڕدرێتەوە، دەیانبینیت. 
\b  
\q1  
\v 35 بەدکارم دی بێ ویژدان بوو، 
\q2 وەک دار ئورزێکی سەوز لە خاکێکی بەپیت گەشەی دەکرد، 
\q1  
\v 36 بەڵام زوو تێپەڕی و نەما، 
\q2 هەرچەند بۆی گەڕام بەڵام دیار نەبوو. 
\b  
\q1  
\v 37 بڕوانە مرۆڤی بێ کەموکوڕی، سەیری مرۆڤی ڕاست بکە، 
\q2 مرۆڤی ئاشتیخواز دواڕۆژی هەیە. 
\q1  
\v 38 بەڵام هەموو یاخیبووەکان لەناودەچن، 
\q2 دواڕۆژی بەدکاران دەبڕدرێتەوە. 
\b  
\q1  
\v 39 ڕزگاریی ڕاستودروستان لەلایەن یەزدانەوە دێت، 
\q2 ئەو قەڵای ئەوانە لە کاتی تەنگانە. 
\q1  
\v 40 یەزدان یارمەتییان دەدات و دەربازیان دەکات، 
\q2 لە بەدکاران دەربازیان دەکات و ڕزگاریان دەکات، 
\q2 چونکە پەنا بۆ ئەو دەبەن. 
\c 38  
\cl زەبووری 38 
\d زەبوورێکی داود، بۆ یادکردنەوە. 
\q1  
\v 1 ئەی یەزدان، بە تووڕەیی خۆت سەرزەنشتم مەکە، 
\q2 بە ڕقی خۆت تەمبێم مەکە. 
\q1  
\v 2 تیرەکانت منیان پێکا، 
\q2 دەستت منی خستە خوارەوە. 
\q1  
\v 3 بەهۆی تووڕەیی تۆوە تەندروستی لە لەشمدا نەماوە، 
\q2 بەهۆی گوناهمەوە ساغی لە ئێسقانەکانمدا نەماوە. 
\q1  
\v 4 تاوانەکانم بەسەر سەرم کەوتوون، 
\q2 وەک بارێکی گران کە توانام نییە هەڵیبگرم. 
\b  
\q1  
\v 5 برینەکانم بۆگەن بوون و چڵکیان کردووە، 
\q2 بەهۆی گێلایەتی خۆم. 
\q1  
\v 6 پشتم چەماوەتەوە و کووڕ بوومەتەوە، 
\q2 بە درێژایی ڕۆژ ماتەم دەگێڕم. 
\q1  
\v 7 کەلەکەم\f + \fr 38:7 \ft قەبرغەم.‏\f* پڕ بووە لە ژانێکی سووتێنەر، 
\q2 تەندروستی لە لەشمدا نەماوە. 
\q1  
\v 8 بە تەواوی تێکشکاوم و بێهێز بووم، 
\q2 لەبەر نەهامەتی دڵم هەر دەناڵێنم. 
\b  
\q1  
\v 9 ئەی پەروەردگار، هەموو ئارەزووەکانم لەپێش چاوتە، 
\q2 ئاخ هەڵکێشانم لە تۆ شاردراوە نییە. 
\q1  
\v 10 دڵەکوتێمە و هێزم لەبەر بڕاوە، 
\q2 تەنانەت ڕووناکیش لە چاوانم بڕاوە. 
\q1  
\v 11 لەبەر برینەکانم دۆست و برادەرەکانم خۆیان لێم دەپارێزن، 
\q2 خزمانم لێم دوور دەکەونەوە. 
\q1  
\v 12 ئەوانەی بەدوای ژیانی منەوەن تەڵە دەنێنەوە، 
\q2 ئەوانەی دەیانەوێت ئازارم بدەن باسی تێکشکانم دەکەن، 
\q2 بە درێژایی ڕۆژ بیر لە فرتوفێڵ دەکەنەوە. 
\b  
\q1  
\v 13 بەڵام من وەک کەڕ وام، گوێم لێ نابێت، 
\q2 وەک لاڵ وام، ناتوانم دەمم بکەمەوە. 
\q1  
\v 14 وەک کەسێکم لێ هاتووە کە نابیستێت، 
\q2 هیچ بەهانەیەکیشی لە دەمی نەبێت. 
\q1  
\v 15 ئەی یەزدان، چاوەڕێی تۆ دەکەم، 
\q2 ئەی خودای پەروەردگارم، تۆ وەڵام دەدەیتەوە، 
\q1  
\v 16 چونکە گوتم: «مەهێڵە پێم دڵخۆش بن، 
\q2 یان کاتێک پێم دەخلیسکێت خۆیان بە گەورە بزانن لە سەرم.» 
\b  
\q1  
\v 17 خەریکە دەکەوم، 
\q2 هەمیشە ئازارەکانم لەگەڵمە. 
\q1  
\v 18 دان بە تاوانی خۆمدا دەنێم، 
\q2 بە گوناهی خۆم خەمبار دەبم. 
\q1  
\v 19 دوژمن چالاک و بەهێزن، 
\q2 ئەوانەی بەبێ هۆ ڕقیان لێمە زۆرن. 
\q1  
\v 20 ئەوانەی بەرامبەری چاکە خراپەم دەدەنەوە، 
\q2 دژایەتیم دەکەن، چونکە دوای چاکە کەوتووم. 
\b  
\q1  
\v 21 ئەی یەزدان، پشتگوێم مەخە، 
\q2 ئەی خودای من، لێم دوور مەکەوە. 
\q1  
\v 22 ئەی پەروەردگاری ڕزگارکەرم، 
\q2 خێرا بگە فریام. 
\c 39  
\cl زەبووری 39 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بۆ یەدوتون\f + \fr 39:0 \ft یەکێک بووە لە ڕابەرانی ستایش لە پەرستگا. بڕوانە \xt یەکەم پوختەی مێژوو 16‏:41‏-42.‏\ft ‏\f* زەبوورێکی داود. 
\q1  
\v 1 گوتم: «چاودێری ڕێگای خۆم دەکەم و 
\q2 زمانی خۆم لە گوناه دەپارێزم. 
\q1 ئەوەندەی بەدکار لەبەردەممە، 
\q2 دەمم بە لغاو دەبەستم.» 
\q1  
\v 2 بەڵام کاتێک کپ و بێدەنگ بووم، 
\q2 تەنانەت شتی چاکیشم نەدەگوت، 
\q2 ئازارم زیاد بوو. 
\q1  
\v 3 دڵم لە ناخمەوە قوڵپی دەدا، 
\q2 هەروەها کە نوقومی بیرکردنەوە دەبووم، گڕم دەگرت، 
\q2 ئەوسا بە زمانم هاتمە قسەکردن: 
\b  
\q1  
\v 4 «ئەی یەزدان، کۆتایی ژیانی خۆم پیشان بدە، 
\q2 هەروەها ڕۆژەکانی ژیانم چەندە، 
\q2 بۆ ئەوەی بزانم من چ فەوتاوێکم. 
\q1  
\v 5 بەڕاستی ڕۆژگاری منت کردووە بە بستێک، 
\q2 تەمەنم لەبەرچاوت وەک هیچە. 
\q2 ژیانی هەر مرۆڤێک تەنها هەناسەیەکە.\f + \fr 39:5 \ft لە دەقی عیبری لێرە و لە ئایەتی 11، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 6 «بەڕاستی مرۆڤ وەک سێبەر دێت و دەچێت، 
\q2 ڕەنج دەدات، بەڵام بێگومان بێهوودەیە، 
\q2 سامان کۆدەکاتەوە، نازانێت دوای خۆی بۆ کێ دەبێت. 
\b  
\q1  
\v 7 «ئێستاش ئەی پەروەردگار، من چاوەڕێی چی بکەم؟ 
\q2 هیوای من بە تۆیە. 
\q1  
\v 8 لە هەموو سەرپێچییەکانم ڕزگارم بکە، 
\q2 مەمکە بە گاڵتەجاڕی گێلەکان. 
\q1  
\v 9 بێدەنگ بووم، دەمم ناکەمەوە، 
\q2 چونکە تۆ ئەوەی کە ئەمەت کردووە. 
\q1  
\v 10 بەڵای خۆت لەسەر من لابدە، 
\q2 بە زەبرەکانی دەستی تۆ فەوتام. 
\q1  
\v 11 مرۆڤ بە سەرزەنشتکردنی لەبەر گوناهەکانی تەمبێ دەکەیت، 
\q2 وەک مۆرانە سامانی ئەو لەناودەبەیت، 
\q2 هەر مرۆڤێک تەنها هەناسەیەکە. 
\b  
\q1  
\v 12 «ئەی یەزدان، گوێ لە نوێژم بگرە، 
\q2 گوێ لە هاوارم بگرە، 
\q2 لە ئاست گریانم گوێت دامەخە، 
\q1 چونکە لەلای تۆ وەک نامۆیەکم، 
\q2 میوانم وەک هەموو باوباپیرانم. 
\q1  
\v 13 ڕووی گرژت لە من وەرگێڕە، هەتا شادمان ببمەوە، 
\q2 پێش ئەوەی بڕۆم و نەمێنم.» 
\c 40  
\cl زەبووری 40 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان زەبوورێکی داود. 
\q1  
\v 1 بە پشوودرێژییەوە چاوەڕێی یەزدانم کرد، 
\q2 ئاوڕی لێ دامەوە و گوێی لە هاوارم بوو. 
\q1  
\v 2 لەناو چاڵی لەناوچوون هەڵیکێشامە دەرەوە، 
\q2 لەناو قوڕ و زەلکاو دەریهێنام. 
\q1 پێیەکانمی لەسەر تاشەبەرد دانا و 
\q2 هەنگاوەکانی منی توندوتۆڵ کرد. 
\q1  
\v 3 گۆرانییەکی نوێی خستە ناو دەمم، 
\q2 سروودێکی ستایش بۆ خودامان. 
\q1 زۆر کەس ئەمە دەبینن و دەترسن و 
\q2 پشت بە یەزدان دەبەستن. 
\b  
\q1  
\v 4 خۆزگە دەخوازرێ بەو کەسەی 
\q2 پشت بە یەزدان دەبەستێت، 
\q1 ڕوو لە لووتبەرزان ناکات، 
\q2 لەوانەی ڕوویان وەرگێڕاوە بەرەو درۆ. 
\q1  
\v 5 ئەی یەزدان، خودای من، 
\q2 زۆرن ئەو کارە سەرسوڕهێنەرانەی کە کردووتە. 
\q1 ئەو شتانەی بۆ ئێمە نەخشەت کێشاوە 
\q2 کەس ناتوانێت بیانژمێرێت بۆت، 
\q1 ئەگەر باسیان بکەم و بیانگێڕمەوە، 
\q2 ئەوەندە زۆرن نایەنە ژماردن. 
\b  
\q1  
\v 6 بە قوربانی و پێشکەشکراو ڕازی نەبوویت، 
\q2 بەڵکو گوێی منت کردەوە، 
\q2 داوای قوربانی سووتاندن و قوربانی گوناهت نەکرد. 
\q1  
\v 7 ئینجا گوتم: «ئەوەتا هاتم، 
\q2 هەروەک لە تۆمارەکەدا لەسەرم نووسراوە.\f + \fr 40:7 \ft بڕوانە دواوتار 18‏:17‏-20‏\f* 
\q1  
\v 8 ئەی خودای من، شادمانیم لەوەدایە کە خواستی تۆ بەجێبهێنم، 
\q2 فێرکردنی تۆ لە ناخی دڵمدایە.» 
\b  
\q1  
\v 9 لەناو کۆمەڵی گەورە ڕاستودروستی ڕادەگەیەنم، 
\q2 ئەی یەزدان، تۆ خۆت دەزانیت، 
\q2 دەمی خۆم ناگرم. 
\q1  
\v 10 ڕاستودروستیت لەناو دڵم کپ ناکەمەوە، 
\q2 باسی دڵسۆزیت و ڕزگاریت دەکەم. 
\q1 خۆشەویستییە نەگۆڕەکەت و ڕاستییەکەت لەناو کۆمەڵی گەورە ناشارمەوە. 
\b  
\q1  
\v 11 ئەی یەزدان، بەزەیی خۆتم لەسەر لامەبە، 
\q2 با خۆشەویستییە نەگۆڕ و ڕاستییەکەت هەمیشە بمپارێزێت، 
\q1  
\v 12 چونکە بەڵای بێشومار دەوری داوم، 
\q2 گوناهەکانم بە شێوەیەک گرفتاریان کردووم ناتوانم ببینم. 
\q1 لە مووی سەرم زیاترن، 
\q2 ورەم بەرداوە. 
\q1  
\v 13 یەزدان، ڕازیبە بۆ دەربازکردنم، 
\q2 یەزدان، خێرابە بۆ یارمەتیدانم. 
\b  
\q1  
\v 14 با هەموو شەرمەزار و سووک بن، 
\q2 ئەوانەی گیانی منیان دەوێت بۆ لەناوبردنی. 
\q1 ببەزن و ڕیسوا بن 
\q2 ئەوانەی خراپەی منیان دەوێت. 
\q1  
\v 15 با لە شەرمەزارییان بپەشۆکێن، 
\q2 ئەوانەی بە من دەڵێن: «هۆی ها! هۆی ها!» 
\q1  
\v 16 بەڵام با هەموو ئەوانەی ڕوو لە تۆ دەکەن 
\q2 شاد و دڵخۆش بن. 
\q1 با هەمیشە بڵێن: «مەزن بێت یەزدان!» 
\q2 ئەوانەی حەز لە ڕزگاریی تۆ دەکەن. 
\b  
\q1  
\v 17 بەڵام سەبارەت بە من، هەژار و نەدارم، 
\q2 با پەروەردگار بایەخم پێبدات. 
\q1 یارمەتی و دەربازکەرم تۆی، 
\q2 ئەی خودای من، دوا مەکەوە. 
\c 41  
\cl زەبووری 41 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، زەبوورێکی داود. 
\q1  
\v 1 خۆزگە دەخوازرێ بەوەی ئاوڕ لە هەژار دەداتەوە، 
\q2 یەزدان لە ڕۆژی تەنگانەدا ڕزگاری دەکات. 
\q1  
\v 2 یەزدان دەیپارێزێت و ژیانی دەبووژێنێتەوە، 
\q2 لەسەر زەوی خۆشحاڵی دەکات و 
\q2 نایداتە دەست حەزی دوژمنەکانی. 
\q1  
\v 3 یەزدان لە کاتی لاوازی پاڵپشتی دەکات و 
\q2 لە کاتی نەخۆشی دەیبووژێنێتەوە. 
\b  
\q1  
\v 4 گوتم: «ئەی یەزدان، لەگەڵم میهرەبان بە، 
\q2 چارەسەرم بکە، چونکە گوناهم دەرهەق بە تۆ کردووە.» 
\q1  
\v 5 دوژمنەکانم دەربارەی من قسەی خراپ دەکەن: 
\q2 «کەی دەمرێت و ناوی دەسڕێتەوە؟» 
\q1  
\v 6 کاتێک یەکێکیان بۆ دیدەنیم بێت، 
\q2 بە درۆ قسە دەکات، بوختان لە دڵی کۆدەکاتەوە، 
\q2 کە دەچێتە دەرەوەش بڵاوی دەکاتەوە. 
\b  
\q1  
\v 7 هەموو دوژمنەکانم چرپەچرپ دەکەن، 
\q2 پیلان دژم دەگێڕن، دەڵێن: 
\q1  
\v 8 «دەردێکی کوشندە تەنگی پێ هەڵچنیوە، 
\q2 لەکوێ بکەوێ هەستانەوەی نابێت.» 
\q1  
\v 9 تەنانەت ئەو برادەرە نزیکەشم کە متمانەم پێی هەبوو، 
\q2 ئەوەی نمەکی کردووم، ناپاکی لەگەڵم کرد.\f + \fr 41:9 \ft ناپاکی لەگەڵم کرد: لە زمانی عیبری نووسراوە: (پاژنەپێی لێ بەرز کردمەوە)، کە دەربڕینێکی عیبرییە بە واتای ناپاکی.‏\f* 
\b  
\q1  
\v 10 بەڵام تۆ ئەی یەزدان، لەگەڵم میهرەبان بە، 
\q2 هەڵمستێنەوە بۆ ئەوەی تۆڵەیان لێ بکەمەوە. 
\q1  
\v 11 بەمە دەزانم تۆ لێم ڕازیت، 
\q2 چونکە دوژمنەکەم هاواری سەرکەوتن ناکات بەسەرمدا. 
\q1  
\v 12 بەهۆی ئەوەی من دروستم، تۆ پاڵپشتیم دەکەیت و 
\q2 لەپێش خۆت ڕامدەگریت، هەتاهەتایە. 
\b  
\q1  
\v 13 ستایش بۆ یەزدانی پەروەردگاری ئیسرائیل، 
\q2 لە ئەزەلەوە هەتا هەتاهەتایە. 
\q4 ئامین و ئامین. 
\c 42  
\ms1 کۆکراوەی بەشی دووەم 
\mr زەبوورەکانی 42‏–72 
\cl زەبووری 42 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، هۆنراوەیەکی کوڕانی قۆرەح 
\q1  
\v 1 چۆن ئاسک بە پەرۆشە بۆ ئاوی ڕووبار، 
\q2 ئەی خودایە، گیانی منیش بە پەرۆشە بۆ تۆ. 
\q1  
\v 2 گیانم تینووی خودایە، خودای زیندوو. 
\q2 کەی دێم و بە دیداری خودا شاد دەبم\f + \fr 42:2 \ft لە ئەمادەگی خودا لە پەرستگا دەبم.‏\f*؟ 
\q1  
\v 3 بە شەو و ڕۆژ فرمێسکەکانم بوون بە خۆراکم، 
\q2 لە کاتێکدا بە درێژایی ڕۆژ پێم دەڵێن: «کوا خوداکەت؟» 
\q1  
\v 4 هەناوم دەتوێتەوە ئەو کاتەی دێتەوە یادم: 
\q2 چۆن لەگەڵ کۆمەڵانی خەڵکدا دەڕۆیشتین، 
\q1 بەرەو ماڵی خودا پێشڕەویانم دەکرد، 
\q2 بە هەلهەلە و ستایشکردنەوە لەناو کۆمەڵی جەژنگێڕان. 
\b  
\q1  
\v 5 ئەی گیانی من بۆچی خەمباریت؟ 
\q2 بۆ لە ناخمدا پەرێشانیت؟ 
\q1 ئومێدت بە خودا هەبێت، 
\q2 چونکە هەر ستایشی ئەو دەکەم، 
\q2 ئەو ڕزگارکەر و خودامە. 
\b  
\q1  
\v 6 گیانم خەمبارە لە ناخم، 
\q2 بۆیە یادت دەکەمەوە 
\q1 لە لای ڕووباری ئوردون، 
\q2 لە بەرزاییەکانی حەرمۆنەوە\f + \fr 42:6 \ft بەرزترین شاخە لە سوریا، نزیکە 75 کم لە باکووری دەریاچەی جەلیل بووە.‏\f*، لە کێوی میچعارەوە. 
\q1  
\v 7 قووڵایی بانگی قووڵایی دەکات، 
\q2 بە دەم خوڕەی تاڤگەکانتەوە، 
\q2 هەموو شەپۆلەکانت و تەوژمەکانت بەسەرمدا کەوتوون. 
\b  
\q1  
\v 8 بە ڕۆژ یەزدان خۆشەویستییە نەگۆڕەکەی ئاراستە دەکات، 
\q2 بە شەویش سروودی ئەو لەسەر لێومە، 
\q2 نوێژێکە بۆ خودای ژیانم. 
\b  
\q1  
\v 9 خودا، کە تاشەبەردی منە، پێی دەڵێم: 
\q2 «بۆچی لە یادت کردووم؟ 
\q1 بۆچی دەبێت بناڵێنم، 
\q2 بچەوسێمەوە بە دەست دوژمنانم؟» 
\q1  
\v 10 بە تێکشکانی ئێسقانەکانم 
\q2 ناحەزانم توانجم تێدەگرن، 
\q2 بە درێژایی ڕۆژ پێم دەڵێن: «کوا خوداکەت؟» 
\b  
\q1  
\v 11 ئەی گیانی من بۆچی خەمباریت؟ 
\q2 بۆ لە ناخمەوە پەرێشانیت؟ 
\q1 ئومێدت بە خودا هەبێت، 
\q2 چونکە من هەر ستایشی ئەو دەکەم، 
\q2 ئەو ڕزگارکەر و خودامە. 
\c 43  
\cl زەبووری 43 
\q1  
\v 1 ئەی خودایە، ئەستۆپاکیم بسەلمێنە، 
\q2 پارێزگاریم لێ بکە لە نەتەوەیەکی خوانەناس، 
\q2 لە پیاوی فێڵباز و لە زۆردار دەربازم بکە. 
\q1  
\v 2 تۆ خودا و قەڵای منی. 
\q2 بۆ وازت لێ هێنام؟ 
\q1 بۆچی دەبێت بناڵێنم، 
\q2 بچەوسێمەوە بە دەست دوژمنانم؟ 
\q1  
\v 3 ڕووناکی و ڕاستی خۆت بنێرە، 
\q2 با ئەوان ڕێنماییم بکەن، 
\q1 با ئەوان بمهێننە کێوی پیرۆزت، 
\q2 بۆ نشینگەکەت. 
\q1  
\v 4 ئەوسا دێم بۆ قوربانگای خودا، 
\q2 خودای خۆشی و دڵشادیم، 
\q2 خودایە، خودای من، بە قیسارەوە ستایشت دەکەم. 
\b  
\q1  
\v 5 ئەی گیانی من بۆچی خەمباریت؟ 
\q2 بۆ لە ناخمەوە پەرێشانیت؟ 
\q1 ئومێدت بە خودا هەبێت، 
\q2 چونکە هەر ستایشی ئەو دەکەم، 
\q2 ئەو ڕزگارکەر و خودامە. 
\c 44  
\cl زەبووری 44 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، هۆنراوەیەکی کوڕانی قۆرەح. 
\q1  
\v 1 خودایە، بە گوێی خۆمان بیستمان، 
\q2 باوباپیرانمان پێیان ڕاگەیاندین، 
\q1 تۆ لە ڕۆژگاری ئەوان، 
\q2 لە ڕۆژگاری کۆن چیت کردووە. 
\q1  
\v 2 بە دەستی خۆت نەتەوەکانت ڕیشەکێش کرد و 
\q2 باوباپیرانی ئێمەت چاند، 
\q1 گەلانت وردوخاش کرد و 
\q2 گەشەت بە باوباپیرانمان دا. 
\q1  
\v 3 ئەوان بە شمشێری خۆیان دەستیان بەسەر خاکەکەدا نەگرت، 
\q2 بە بازووی خۆیان سەرکەوتنیان بەدەست نەهێنا، 
\q1 بەڵکو دەستی ڕاستی تۆ بوو، بازووی تۆ بوو، 
\q2 هەروەها ڕووناکی ڕوخساری تۆ بوو، چونکە ئەوانت خۆشویست. 
\b  
\q1  
\v 4 تۆ پاشا و خودای منی، 
\q2 تۆی فەرمانی ڕزگاری دەدەیت بۆ یاقوب. 
\q1  
\v 5 لە ڕێگەی تۆوە دوژمنەکانمان دەبەزێنین، 
\q2 بە ناوی تۆوە ناحەزەکانمان پێشێل دەکەین. 
\q1  
\v 6 من پشت بە کەوانەکەم نابەستم، 
\q2 شمشێرەکەم ڕزگارم ناکات. 
\q1  
\v 7 بەڵام تۆ لە دوژمنەکانمان ڕزگارت کردین، 
\q2 تۆ ناحەزەکانی ئێمەت ڕیسوا کرد. 
\q1  
\v 8 بە درێژایی ڕۆژ شانازی بە خوداوە دەکەین، 
\q2 هەتاهەتایە ستایشی ناوت دەکەین.\f + \fr 44:8 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 9 بەڵام ئێستا وازت لێ هێناوین و ڕیسوات کردین، 
\q2 لەگەڵ سوپاکانمان دەرناچیت. 
\q1  
\v 10 وات لێکردین لەبەر دوژمنەکانمان ڕابکەین، 
\q2 ناحەزەکانمان تاڵانیان کردین. 
\q1  
\v 11 وەک مەڕ بۆ سەربڕین بەدەستەوەت داین، 
\q2 لەنێو نەتەوەکان پەرشوبڵاوت کردینەوە. 
\q1  
\v 12 گەلی خۆتت هەرزان فرۆش کردووە، 
\q2 قازانجت لە فرۆشتنەکەیان نەکردووە. 
\b  
\q1  
\v 13 لەلای نەتەوەکانی دراوسێمان ئێمەت کردووە بە مایەی ڕیسوایی، 
\q2 بە مایەی گاڵتەجاڕی و سووکایەتی پێکردن لەلای ئەوانەی دەوروبەرمان. 
\q1  
\v 14 ئێمەت کردووە بە پەندی نەتەوەکان، 
\q2 خەڵکی سەریان بادەدەن لە ئاستمان. 
\q1  
\v 15 ڕیسواییم بە درێژایی ڕۆژ لەپێشمە، 
\q2 شەرمەزاریم ڕووی داپۆشیوم، 
\q1  
\v 16 لەبەر دەنگی توانج لێدەر و جنێو پێدەرم، 
\q2 لە ڕووی دوژمن و تۆڵەسێنەر. 
\b  
\q1  
\v 17 ئەمانەمان هەمووی بەسەرهاتووە، 
\q2 لەگەڵ ئەوەشدا تۆمان لەبیر نەکردووە، 
\q2 پەیمانی تۆمان نەشکاندووە. 
\q1  
\v 18 دڵمان پاشگەز نەبووەتەوە، 
\q2 پێیەکانمان ڕێگای تۆیان بەرنەداوە. 
\q1  
\v 19 بەڵام تۆ وردوخاشت کردین و ئێمەت کردە جێگای چەقەڵ، 
\q2 بە سێبەری مەرگ داتپۆشین. 
\b  
\q1  
\v 20 ئەگەر ناوی خودای خۆمان لەبیر بکردایە، 
\q2 یان دەستمان لەبەر خوداوەندێکی بیانی پان بکردایەوە، 
\q1  
\v 21 ئایا لەلای خودا ئاشکرا نەدەبوو، 
\q2 چونکە هەموو نهێنییەکانی دڵ دەزانێت؟ 
\q1  
\v 22 لەگەڵ ئەمەشدا لە پێناوی تۆ بە درێژایی ڕۆژ ڕووبەڕووی مردن دەبینەوە، 
\q2 وەک مەڕ بۆ سەربڕین دادەنرێین. 
\b  
\q1  
\v 23 ئەی پەروەردگار، بەئاگا بە! بۆ خەواڵوو بوویت؟ 
\q2 هەستە! هەتاهەتایە وازمان لێمەهێنە! 
\q1  
\v 24 بۆچی ڕووی خۆتمان لێ دەشاریتەوە؟ 
\q2 بۆچی تەنگانە و چەوسانەوەمان لەبیردەکەیت؟ 
\b  
\q1  
\v 25 گیانمان بەرەو خاک شۆڕ بووەتەوە، 
\q2 سکمان بە زەوییەوە نووساوە. 
\q1  
\v 26 ڕاپەڕە! بگە فریامان! 
\q2 لەبەر خۆشەویستییە نەگۆڕەکەت بمانکڕەوە. 
\c 45  
\cl زەبووری 45 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بە ئاوازی گوڵی سەوسەن. هۆنراوەیەکی کوڕانی قۆرەح. گۆرانی زەماوەند. 
\q1  
\v 1 دڵم بە قسەی باش دەجۆشێت، 
\q2 کاتێک هۆنراوەکانم بۆ پاشا دەخوێنمەوە، 
\q2 زمانم پێنووسی نووسەرێکی کارامەیە. 
\b  
\q1  
\v 2 تۆ جوانترینی لەناو ئادەمیزاد و 
\q2 نیعمەت بەسەر لێوتدا باریوە، 
\q2 چونکە خودا بۆ هەتاهەتایە بەرەکەتداری کردوویت. 
\b  
\q1  
\v 3 ئەی توانادار، شمشێرەکەت بەلای ڕانتەوە بکە، 
\q2 شکۆمەندی و پایەبەرزی لەبەر بکە. 
\q1  
\v 4 بە شکۆمەندی خۆت سەرکەوتووانە سواربە، 
\q2 لە پێناوی ڕاستی و نەرمونیانی و دادپەروەری، 
\q2 با دەستی ڕاستت شتی سامناک بخاتە پێش چاو. 
\q1  
\v 5 با تیرە تیژەکانت دڵی دوژمنانی پاشا کون بکەن، 
\q2 با گەلان لەبەر پێت بکەون. 
\q1  
\v 6 ئەی خودایە، تەختی تۆ بۆ هەتاهەتاییە، 
\q2 داردەستی شانشینیت داردەستی دادپەروەرییە. 
\q1  
\v 7 تۆ حەزت لە ڕاستودروستییە و ڕقت لە خراپەیە، 
\q2 بۆیە خودا، خودای خۆت، لە سەرووی هاوەڵەکانتەوە داینای، 
\q2 بە ڕۆنی شادی دەستنیشانی کردیت\f + \fr 45:7 \ft دەستنیشانکردنی کەسێک بۆ ئەرکێکی ئایینی یان پاشایەتی ئەو کاتە بە چەورکردنی بووە بە ڕۆن.‏\f*. 
\q1  
\v 8 جلوبەرگت هەمووی بە بۆنی موڕ و ئەلوا\f + \fr 45:8 \ft ڕووەکێکی دڕکاوییە وەک سەباڕ، شلەیەکی تێدایە بۆ پێست باشە.‏\f* و کاسیا\f + \fr 45:8 \ft دارێکە بۆ بۆنخۆشی بەکاردێت.‏\f* بۆندار بووە، 
\q2 لە کۆشکی بە عاج\f + \fr 45:8 \ft عاج، دوو قۆچە گەورەکەی فیل، دەتاشرێن بۆ دروستکردنی پەیکەر و شتی دیکە بۆ ڕازاندنەوەی ناو ماڵ.‏\f* ڕازاوەوە دەنگی مۆسیقا دڵخۆشت دەکات. 
\q1  
\v 9 لەناو ژنە خانەدانەکانت شازادە هەن، 
\q2 شاژنیش بە بەرگی زێڕی ئۆفیرەوە\f + \fr 45:9 \ft ڕەنگە وڵاتی یەمەن بێت، بە چاکی جۆری زێڕەکەی بەناوبانگ بووە.‏\f* لەلای دەستی ڕاستتە. 
\b  
\q1  
\v 10 ئەی کچ، گوێ بگرە، لەبەرچاوتی بگرە و گوێ شل بکە، 
\q2 گەلەکەت و بنەماڵەکەت لەبیر بکە. 
\q1  
\v 11 پاشا تامەزرۆی جوانی تۆیە، 
\q2 کڕنۆشی بۆ ببە، چونکە گەورەی تۆیە. 
\q1  
\v 12 دانیشتووانی شاری سور\f + \fr 45:12 \ft مەبەست لە دانیشتووانی شاری سورە، کە شارێکی فینیقی زۆر بەناوبانگ و زۆر کۆنە.‏\f* بە دیارییەوە دێن، 
\q2 خاوەن سامانەکان ڕەزامەندی تۆیان دەوێت. 
\q1  
\v 13 کچی پاشا لە ماڵی خۆی بە تەواوی شکۆدارە، 
\q2 جلوبەرگەکەی بە زێڕ چنراوە. 
\q1  
\v 14 بە کراسێکی نەخشێنراوەوە بۆ لای پاشا دەیبەن، 
\q2 یاوەرە پاکیزەکانی بەدوایەوە بۆ لای تۆ\f + \fr 45:14 \ft تۆی پاشا.‏\f* دێنن. 
\q1  
\v 15 بە شادی و خۆشییەوە دەیانهێنن، 
\q2 دێنە ناو کۆشکی پاشا. 
\b  
\q1  
\v 16 کوڕەکانت جێی باوکانیان دەگرنەوە، 
\q2 دەیانکەیتە میری سەرانسەری زەوی. 
\b  
\q1  
\v 17 یادی ناوت دەکەمەوە نەوە دوای نەوە، 
\q2 بۆیە نەتەوەکان هەتاهەتایە ستایشت دەکەن. 
\c 46  
\cl زەبووری 46 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، گۆرانییەکی کوڕانی قۆرەح لەسەر ئاوازی عەلامۆت\f + \fr 46:0 \ft جۆرە ئاوازێکە، واتا بە دەنگی کچان.‏\f*. 
\q1  
\v 1 خودا پەناگا و هێزمانە، 
\q2 لە تەنگانەدا زۆر بەهاناوە دێت. 
\q1  
\v 2 بۆیە ترسمان نییە ئەگەر زەویش بلەرزێت، 
\q2 ئەگەر چیاکانیش بکەونە ناو قووڵایی دەریاکانەوە، 
\q1  
\v 3 ئەگەر ئاوەکەشی بجۆشێت و کەف بکات، 
\q2 چیاکانیش لە سەرکێشی ئەو بلەرزن.\f + \fr 46:3 \ft لە دەقی عیبری لێرە و لە ئایەتەکانی 7 و 11، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 4 ڕووبارێک هەیە جۆگەکانی شاری خودا\f + \fr 46:4 \ft ئۆرشەلیم، بڕوانە ئاشکراکردن 21، \xt حزقیێل 40‏\ft ‏.‏\f* شاد دەکات، 
\q2 ئەو شوێنە پیرۆزەی کە هەرەبەرز تێیدا نیشتەجێیە. 
\q1  
\v 5 خودا لە ناوەڕاستدایە، بۆیە هەرگیز ناکەوێت، 
\q2 لەگەڵ بەرەبەیاندا خودا بەهاناوە دێت. 
\q1  
\v 6 نەتەوەکان هەڵدەچن و شانشینەکان دەکەون، 
\q2 خودا دەنگی بەرز دەکاتەوە و زەوی دەتوێتەوە. 
\b  
\q1  
\v 7 یەزدانی سوپاسالار لەگەڵمانە، 
\q2 خودای یاقوب پەناگامانە. 
\b  
\q1  
\v 8 وەرن سەیری کردارەکانی یەزدان بکەن، 
\q2 ئەو وێرانکارییەکانی بەسەر زەویدا هێناوە. 
\q1  
\v 9 جەنگەکان ڕادەگرێت هەتا ئەوپەڕی جیهان، 
\q2 کەوانەکان دەشکێنێت و ڕمەکان پارچەپارچە دەکات، 
\q2 گالیسکەکان بە ئاگر دەسووتێنێت. 
\q1  
\v 10 «هێوربنەوە، بزانن کە من خودام، 
\q2 لەنێو نەتەوەکان پایەم بەرز دەبێتەوە، 
\q2 لەسەر زەوی بەرز دەبمەوە.»\f + \fr 46:10 \ft خودا بۆ نەتەوەکان قسە دەکات.‏\f* 
\b  
\q1  
\v 11 یەزدانی سوپاسالار لەگەڵمانە، 
\q2 خودای یاقوب پەناگامانە. 
\c 47  
\cl زەبووری 47 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان،  // زەبوورێکی کوڕانی قۆرەح. 
\q1  
\v 1 ئەی هەموو نەتەوەکان، چەپڵە لێبدەن، 
\q2 بە هاواری شادییەوە هوتاف بۆ خودا بکێشن. 
\b  
\q1  
\v 2 یەزدانی هەرەبەرز بە سامە، 
\q2 پاشایەکی گەورەیە بەسەر هەموو زەوییەوە. 
\q1  
\v 3 نەتەوەکانی خستە ژێر دەستمان، 
\q2 گەلانی خستە ژێر پێمان. 
\q1  
\v 4 میراتی بۆ هەڵبژاردین، 
\q2 ئەو خاکە کە شانازی نەوەی یاقوبە، 
\q2 ئەوانەی کە ئەو خۆشیویستن.\f + \fr 47:4 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 5 لەناو هوتافی شادی خودا بەرزبووەوە\f + \fr 47:5 \ft بۆ تەختی خۆی، لە کاتی هاتنی سندوقی پەیمان بۆ ناو پەرستگا.‏\f*، 
\q2 یەزدان بەرزبووەوە، لەگەڵ دەنگی کەڕەنا. 
\q1  
\v 6 گۆرانی ستایش بۆ خودا بڵێن، گۆرانی ستایش، 
\q2 گۆرانی ستایش بۆ پاشامان بڵێن، گۆرانی ستایش. 
\q1  
\v 7 خودا پاشای هەموو زەوییە، 
\q2 هۆنراوەی ستایشی بە گۆرانی بۆ بڵێن. 
\b  
\q1  
\v 8 خودا پاشایەتی نەتەوەکان دەکات، 
\q2 خودا لەسەر تەختی پیرۆزی خۆی دادەنیشێت. 
\q1  
\v 9 سەروەرانی گەلان وەک گەلی خودای ئیبراهیم کۆبوونەوە، 
\q2 چونکە پاشاکانی\f + \fr 47:9 \ft عیبری: قەڵغانەکان.‏\f* زەوی هی خودان، 
\q2 ئەو پایەی زۆر بەرزبووەوە. 
\c 48  
\cl زەبووری 48 
\d گۆرانییەک، زەبوورێکی کوڕانی قۆرەح. 
\q1  
\v 1 یەزدان مەزنە و شایانی هەموو ستایشێکە، 
\q2 لە شاری خودامان، لە کێوی پیرۆزی خۆی. 
\b  
\q1  
\v 2 کێوی سییۆن جوانە لە بەرزاییدا، 
\q2 خۆشی هەموو زەوییە، 
\q1 وەک لووتکەی شاخی چافۆن\f + \fr 48:2 \ft شاخی پیرۆز لە باکوور، لە فینیکیا، کە لە ئەندێشەی خەڵک شوێنی نیشتەجێبوونی خودا بووە.‏\f*، 
\q2 شاری پاشای گەورەیە\f + \fr 48:2 \ft مەبەست لە پاشای گەورە، خودایە. بڕوانە 47‏:2؛ 48‏:1.‏\f*. 
\q1  
\v 3 خودا لەناو قەڵاکانی 
\q2 وەک پەناگایەک ناسراوە. 
\b  
\q1  
\v 4 ئەوەتا پاشاکان هێزیان کۆکردەوە، 
\q2 ئەوەتا پێکەوە هاتنە پێشەوە، 
\q1  
\v 5 کە بینییان تاسان، 
\q2 بە ترسەوە هەڵاتن. 
\q1  
\v 6 لەوێ لەرزیان لێهات، 
\q2 ژانیان گرت، وەک ژن لە کاتی منداڵبوون. 
\q1  
\v 7 وەک کەشتییەکانی تەرشیش\f + \fr 48:7 \ft جۆرە کەشتییەکی تایبەت بوون کە بۆ بازرگانی بەکاردەهێنران.‏\f* تێکت شکاندن، 
\q2 بە بای ڕۆژهەڵات تەفروتونات کردن. 
\b  
\q1  
\v 8 هەروەک بیستمان، 
\q2 ئاواش بینیمان 
\q1 لە شاری یەزدانی سوپاسالار، 
\q2 لە شاری خودامان: 
\q2 «خودا هەتاهەتایە دەیچەسپێنێت.»\f + \fr 48:8 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 9 ئەی خودایە، لە ناوەندی پەرستگاکەت 
\q2 بیر لە خۆشەویستییە نەگۆڕەکەت دەکەینەوە. 
\q1  
\v 10 ئەی خودایە، وەک ناوت 
\q2 ستایشت دەگاتە ئەوپەڕی زەوی، 
\q2 دەستە ڕاستت پڕە لە ڕاستودروستی. 
\q1  
\v 11 کێوی سییۆن شادمان دەبێت، 
\q2 کچانی\f + \fr 48:11 \ft لە کەلتوری عیبری بە گوندەکانی دەوروبەری شارەکان دەگوترێ کچانی.‏\f* یەهودا دڵخۆش دەبن 
\q2 بەهۆی دادوەرییەکانت. 
\b  
\q1  
\v 12 بە دەوری سییۆندا بگەڕێن، بە دەوریدا بسووڕێنەوە، 
\q2 قوللەکانی بژمێرن، 
\q1  
\v 13 لە شووراکانی وردبنەوە، 
\q2 بڕواننە قەڵاکانی، 
\q2 هەتا بۆ نەوەی داهاتووی باس بکەن. 
\b  
\q1  
\v 14 هەتاهەتایە ئەم خودایە خودامانە، 
\q2 هەتا مردنیش ئەو ڕابەرمانە. 
\c 49  
\cl زەبووری 49 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، زەبوورێکی کوڕانی قۆرەح. 
\q1  
\v 1 ئەی هەموو گەلان، ئەمە ببیستن، 
\q2 ئەی هەموو دانیشتووانی زەوی، گوێ بگرن، 
\q1  
\v 2 پایەبەرز و پایەنزم، 
\q2 هەژار و دەوڵەمەند پێکەوە. 
\q1  
\v 3 دەمم باسی دانایی دەکات، 
\q2 لێکدانەوەی دڵم تێگەیشتنە. 
\q1  
\v 4 گوێ بۆ پەند شل دەکەم، 
\q2 بە قیسارە مەتەڵەکەم ڕوون دەکەمەوە. 
\b  
\q1  
\v 5 بۆ لە ڕۆژانی تەنگانە بترسم، 
\q2 کاتێک فێڵبازە خراپەکارەکان دەورم دەگرن؟ 
\q1  
\v 6 ئەوانەن کە پشت بە سامانیان دەبەستن، 
\q2 شانازی بە دەوڵەمەندییەکەیان دەکەن. 
\q1  
\v 7 کەس ناتوانێت ژیانی براکەی بکڕێتەوە، 
\q2 یان کەفارەتی ئەو بداتە خودا. 
\q1  
\v 8 کڕینەوەی ژیان زۆر گران دەکەوێت، 
\q2 هەرگیز ناتوانرێت نرخی تەواوی بدرێت، 
\q1  
\v 9 تاکو بۆ هەتاهەتایە بە زیندووێتی بمێنێتەوە و 
\q2 گۆڕ نەبینێت. 
\q1  
\v 10 بێگومان هەموو دەبینن کە تەنانەت کەسە داناکانیش دەمرن، 
\q2 نەزانەکان و گێلەکان وەک یەک لەناودەچن و 
\q2 سامانیان بۆ ئەوانی دیکە جێدەهێڵن. 
\q1  
\v 11 گۆڕیان ماڵی هەتاهەتاییانە، 
\q2 شوێنی نیشتەجێبوونیانە نەوە دوای نەوە، 
\q2 لەگەڵ ئەوەشدا زەویشیان بە ناوی خۆیانەوە ناودەنا. 
\b  
\q1  
\v 12 مرۆڤ هەرچەندە دەوڵەمەند بێت نامێنێت، 
\q2 وەک ئەو ئاژەڵانە وایە کە لەناودەچن. 
\b  
\q1  
\v 13 ئەمە ڕێگای ئەوانەیە کە پشت بە خۆیان دەبەستن، 
\q2 ئەوانەش کە دوایان دەکەون بە قسەکانیان پەسەندی دەکەن.\f + \fr 49:13 \ft لە دەقی عیبری لێرە و لە ئایەتی 15، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 14 ئەوانە وەک مەڕن و چارەنووسیان مەرگە، 
\q2 مەرگ دەبێتە شوانیان. 
\q1 لە بەیانیدا سەرڕاستەکان فەرمانڕەوایەتییان دەکەن، 
\q2 شێوەیان دادەڕزێت، 
\q2 جیهانی مردووان دەبێتە ماڵیان. 
\q1  
\v 15 بەڵام خودا گیانم لە چنگی جیهانی مردووان دەکڕێتەوە، 
\q2 چونکە بۆ لای خۆی دەمبات. 
\q1  
\v 16 ترست لێ نەنیشێت ئەگەر یەکێک دەوڵەمەند بوو، 
\q2 شکۆمەندی ماڵەکەی زیاد بوو، 
\q1  
\v 17 چونکە کە مرد هیچ لەگەڵ خۆی نابات، 
\q2 شکۆیەکەی بەدوایەوە نابێت. 
\q1  
\v 18 لەگەڵ ئەوەی کاتێک زیندووە خۆی بە بەختەوەر دەزانێت، 
\q2 ستایش دەکرێیت کاتێک سەرکەوتوو بیت. 
\q1  
\v 19 بەڵام ئەویش بۆ نەوەی باوباپیرانی دەڕوات، 
\q2 ئەوانەی هەتاهەتایە چاویان بە ڕووناکی ناکەوێتەوە. 
\b  
\q1  
\v 20 مرۆڤ دەوڵەمەندیش بێت ئەگەر تێنەگات، 
\q2 وەک ئەو ئاژەڵانە وایە کە لەناودەچن. 
\c 50  
\cl زەبووری 50 
\d زەبوورێکی ئاساف. 
\q1  
\v 1 خودای توانادار، یەزدان، دەفەرموێت، 
\q2 لە ڕۆژهەڵاتەوە هەتا ڕۆژئاوای زەوی بانگ دەکات. 
\q1  
\v 2 لە سییۆنەوە کە لە جوانیدا تەواوە، 
\q2 خودا پڕشنگ دەدات. 
\q1  
\v 3 خودامان دێت و بێدەنگ نابێت، 
\q2 ئاگر لەپێشیەوە هەڵدەلووشێت، 
\q2 گەردەلوولێکی بەهێز لە دەوریەتی. 
\q1  
\v 4 بانگی ئاسمان دەکات لە بەرزایی، 
\q2 هەروەها زەوی، بۆ دادگایی گەلەکەی: 
\q1  
\v 5 «بۆم کۆبکەنەوە خۆشەویستانم\f + \fr 50:5 \ft بۆ ئەوانەی کە پابەندن بە پەیمانی خۆشەویستی نەگۆڕی پەروەردگار.‏\f*، 
\q2 کە بە قوربانی پەیمانیان لەگەڵ بەستووم.» 
\q1  
\v 6 ئاسمان ڕاستودروستییەکەی ڕادەگەیەنێت، 
\q2 چونکە خودا خۆی دادوەرە.\f + \fr 50:6 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 7 «ئەی گەلی من، گوێ بگرن هەتا قسە بکەم، 
\q2 ئەی ئیسرائیل، هەتا شایەتیت لەسەر بدەم: 
\q2 من خودام، خودای تۆم. 
\q1  
\v 8 سەرزەنشتت ناکەم لەسەر قوربانییەکانت، 
\q2 قوربانی سووتاندنەکانت هەمیشە لەبەردەممە. 
\q1  
\v 9 من پێویستیم بە گای ماڵەکەت نییە، 
\q2 پێویستیم بە گیسکی ناو پشتیرەکەت\f + \fr 50:9 \ft پشتیر: گەوڕ، شوێنێکی تایبەت بووە بە پەروەردەکردنی ئاژەڵ.‏\f* نییە، 
\q1  
\v 10 چونکە هەموو گیانلەبەرانی دارستان هی منن، 
\q2 هەروەها مێگەلەکانی سەر هەزارەها گرد. 
\q1  
\v 11 هەموو باڵندەی چیاکان دەزانم، 
\q2 هەموو زیندەوەرانی دەشتودەر هی منن. 
\q1  
\v 12 ئەگەر برسی بم، بە تۆ ناڵێم، 
\q2 چونکە جیهان و هەرچی تێیدایە هی منە. 
\q1  
\v 13 ئایا من گۆشتی گا دەخۆم، 
\q2 یان خوێنی گیسک دەخۆمەوە؟ 
\b  
\q1  
\v 14 «قوربانی سوپاسگوزاری بۆ خودا بکە، 
\q2 نەزرەکانت بەرامبەر هەرەبەرز بهێنە دی، 
\q1  
\v 15 لە ڕۆژی تەنگانەدا نزام بۆ بکە، 
\q2 دەربازت دەکەم و شکۆدارم دەکەیت.» 
\q1  
\v 16 بەڵام خودا بە بەدکار دەڵێ: 
\q1 «تۆ کێیت باسی فەرزەکانم دەکەیت، 
\q2 یان پەیمانی منت بەسەر زماندا دێت؟ 
\q1  
\v 17 تۆ کە ڕقت لە تەمبێکردنە و 
\q2 فەرمایشتی منت پشتگوێ خستووە. 
\q1  
\v 18 کاتێک دزێک ببینیت، بە کردارەکەی ڕازی دەبیت، 
\q2 بەشت لەگەڵ داوێنپیسانە. 
\q1  
\v 19 دەمت بە خراپە دەکەیتەوە، 
\q2 زمانت فێڵبازی دادەهێنێت. 
\q1  
\v 20 دادەنیشیت و لە دژی براکەت قسە دەکەیت، 
\q2 بوختان بۆ کوڕی دایکت هەڵدەبەستیت. 
\q1  
\v 21 ئەمانەت کردووە و من بێدەنگ بووم، 
\q2 وات زانی منیش وەک تۆم. 
\q1 بەڵام من سەرزەنشتت دەکەم و 
\q2 ڕووبەڕوو تاوانبارت دەکەم. 
\b  
\q1  
\v 22 «ئەی ئەوانەی خوداتان لەبیر کردووە، ئەمە لەبەرچاو بگرن، 
\q2 دەنا پارچەپارچەتان دەکەم، کەسیش نایەتە فریاتان. 
\q1  
\v 23 ئەوەی قوربانی سوپاسگوزاری پێشکەش بکات، شکۆدارم دەکات، 
\q2 ئەوەی ڕێگای خۆی ڕێک بکات، ڕزگاریی خودای نیشان دەدەم.» 
\c 51  
\cl زەبووری 51 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان. زەبوورێکی داودە. کاتێک ناتانی پێغەمبەر هاتە لای دوای ئەوەی داود لەگەڵ بەتشەبەع\f + \fr 51:0 \ft ژنی ئوریای حیتی بوو، داود لەگەڵی جووتبوو، بەم جۆرە داود داوێنپیسی لەگەڵی کرد. بۆ داپۆشینی گوناهەکەی، پلانێکی دانا بۆ بەکوشتدانی ئوریا. پاشان داود هێنای و کردییە ژنی خۆی. دایکی سلێمان بوو.‏\f* جووتبوو. 
\q1  
\v 1 ئەی خودایە، بەگوێرەی خۆشەویستییە نەگۆڕەکەت لەگەڵم میهرەبان بە، 
\q2 بەگوێرەی زۆری بەزەیی خۆت یاخیبوونم بسڕەوە. 
\q1  
\v 2 بە تەواوی لە تاوانم بمشۆرەوە و 
\q2 لە گوناهم پاکم بکەرەوە، 
\q1  
\v 3 چونکە من یاخیبوونم دەزانم، 
\q2 هەمیشە گوناهم لەبەردەممە. 
\q1  
\v 4 لە دژی تۆ، تەنها تۆ، گوناهم کرد، 
\q2 لەبەرچاوی تۆ خراپەم کرد، 
\q1 تاکو لە بڕیارەکانت ڕاست بیت، 
\q2 دادپەروەر بیت لە حوکمەکانت. 
\q1  
\v 5 ئەوەتا من بە زگماکی تاوانبارم، 
\q2 گوناهبارم لەو کاتەوە کە دایکم سکی بە من پڕ بووە. 
\q1  
\v 6 ئەوەتا لە ناوەڕۆکەوە بە ڕاستی دڵشاد دەبیت، 
\q2 لە ویژدانەوە فێری داناییم دەکەیت. 
\b  
\q1  
\v 7 بە زوفا\f + \fr 51:7 \ft جۆرە ڕووەکێکە، جولەکەکان بە پێ ڕێوەرەسم بۆ پاککردنەوە بەکاریاندەهێنا.‏\f* پاکم بکەرەوە پاک دەبم، 
\q2 بمشۆرەوە لە بەفر سپیتر دەبم. 
\q1  
\v 8 با گوێم لە شادی و خۆشی بێت، 
\q2 با ئەو ئێسقانانەی وردوخاشت کردووە شاد بن. 
\q1  
\v 9 چاو لە گوناهەکانم بپۆشە و 
\q2 هەموو خراپەکانم بسڕەوە. 
\b  
\q1  
\v 10 ئەی خودایە، دڵێکی پاکم تێدا دروستبکە و 
\q2 ڕۆحێکی چەسپاو لە ناخم نوێ بکەرەوە. 
\q1  
\v 11 لە بەرچاوی خۆت دەرم مەکە، 
\q2 ڕۆحی پیرۆزی خۆتم لێ مەستێنەوە. 
\q1  
\v 12 شادی ڕزگاریی خۆتم پێ بدەوە، 
\q2 بە ڕۆحێکی خۆویستانە پشتگیریم بکە. 
\b  
\q1  
\v 13 ئینجا یاخیبووان فێری ڕێگای تۆ دەکەم، 
\q2 گوناهباران دەگەڕێنەوە لات. 
\q1  
\v 14 ئەی خودایە، خودای ڕزگاریم، لە سزای خوێنڕشتن دەربازم بکە، 
\q2 هەتا زمانم گۆرانی بەسەر ڕاستودروستیتدا بڵێت. 
\q1  
\v 15 ئەی پەروەردگار، لێوەکانم لێک بکەرەوە و 
\q2 دەمم ستایشت ڕابگەیەنێت. 
\q1  
\v 16 تۆ بە قوربانی دڵشاد نابیت، ئەگینا پێشکەشی دەکەم، 
\q2 بە قوربانی سووتاندن ڕازی نابیت. 
\q1  
\v 17 قوربانی بۆ خودا ڕۆحێکی شکاوە، 
\q2 ئەی خودایە، تۆ بە سووکییەوە تەماشای دڵی شکاو و وردوخاشکراو ناکەیت. 
\b  
\q1  
\v 18 بە ڕەزامەندی خۆت چاکە لەگەڵ سییۆن بکە، 
\q2 شووراکانی ئۆرشەلیم بنیاد بنێوە. 
\q1  
\v 19 ئەوسا بە قوربانی ڕاستودروستی و 
\q2 بە قوربانی سووتاندنی تەواو دڵشاد دەبیت، 
\q2 ئەوسا گا لەسەر قوربانگاکەت پێشکەش دەکرێت. 
\c 52  
\cl زەبووری 52 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، هۆنراوەیەکی داودە. کاتێک دۆئێگی\f + \fr 52:0 \ft سەرۆک شوانەکانی شاول بوو، کاتێک داود لە ڕووی شاول هەڵات بۆ نوب بۆ لای ئەحیمەلەخ کە سەرۆک کاهین بوو، جا ئەحیمەلەخ نانی قوربانی دا بە داود و ئەوانەی لەگەڵی بوون. لەو کاتەدا دۆئێگ لە نوب بوو و هەواڵی برد بۆ شاول. ئینجا شاول ئەحیمەلەخ و کاهینەکانی گرت و فەرمانی دا بە پاسەوانەکان بیانکوژن، بەڵام ئەوان ڕەتیانکردەوە. جا فەرمانی دا بە دۆئێگ، ئەویش هەشتا و پێنج کاهینی کوشت.‏\f* ئەدۆمی چوو بۆ لای شاول و پێی گوت کە داود چووە بۆ ماڵی ئەحیمەلەخ. 
\q1  
\v 1 ئەی پاڵەوان، بۆچی شانازی بە خراپەوە دەکەیت؟ 
\q2 ئەی شەرمەزار لەبەرچاوی خودا، 
\q2 بۆچی بە درێژایی ڕۆژ شانازی دەکەیت؟ 
\q1  
\v 2 زمانت پیلانی کاولکاری دادەڕێژێت، 
\q2 وەک گوێزانێکی تیژ وایە، 
\q2 خەریکی فێڵبازییە. 
\q1  
\v 3 زیاتر حەزت لە خراپەیە نەک لە چاکە، 
\q2 لە درۆ نەک لە ڕاستگۆیی.\f + \fr 52:3 \ft لە دەقی عیبری لێرە و لە ئایەتی 5، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 4 حەزت لە هەموو وشەیەکی زیانبەخشە، 
\q2 ئەی زمانی فێڵباز! 
\b  
\q1  
\v 5 بێگومان خودا هەتاهەتایە وێرانت دەکات، 
\q2 دەتڕفێنێت و لە ماڵەکەت دەرتدەهێنێت، 
\q2 ڕیشەکێشت دەکات لە خاکی زیندووان. 
\q1  
\v 6 ڕاستودروستان ئەمە دەبینن و دەترسن، 
\q2 پێی پێدەکەنن و دەڵێن: 
\q1  
\v 7 «ئا ئەوەتا ئەو کەسەی کە خودا ناکاتە پەناگای خۆی، 
\q2 بەڵکو پشتی بە زۆریی سامانەکەی بەستبوو، 
\q2 بە تێکشکاندنی کەسانی دیکە بەهێز بوو!» 
\b  
\q1  
\v 8 بەڵام من لە ماڵی خودا وەک دار زەیتوونێکی سەوزم، 
\q2 هەتاهەتایە پشت بە خۆشەویستی نەگۆڕی خودا دەبەستم. 
\q1  
\v 9 هەتاهەتایە لەبەردەم خۆشەویستانت ستایشت دەکەم بۆ کردەوەکانت، 
\q2 ئومێدم بە ناوی تۆیە، چونکە چاکە. 
\c 53  
\cl زەبووری 53 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بە ساز، هۆنراوەیەکی داود. 
\q1  
\v 1 گێل لە دڵی خۆیدا دەڵێت: 
\q2 «خودا نییە.» 
\q1 ئەوانە گەندەڵن و خراپەکانیان پیسە، 
\q2 کەس نییە چاکە بکات. 
\b  
\q1  
\v 2 خودا لە ئاسمانەوە سەیری ئادەمیزاد دەکات، 
\q2 تاکو بزانێت کەس هەیە تێگەیشتوو بێت، 
\q2 کەس هەیە ڕوو لە خودا بکات. 
\q1  
\v 3 هەموو هەڵگەڕانەوە، 
\q2 هەموو گەندەڵ بوون، 
\q1 کەس نییە چاکە بکات، 
\q2 تەنانەت یەکێکیش نییە. 
\b  
\q1  
\v 4 ئایا ئەم هەموو گوناهبارانە هیچ نازانن؟ 
\b  
\q1 ئەوانەی وەک نان گەلەکەی من دەخۆن و 
\q2 ئەوانەی لە خودا ناپاڕێنەوە. 
\q1  
\v 5 لەوێ ترسێکی گەورەیان لێ نیشت، 
\q2 کە هیچ ترسی لێ نەبوو. 
\q1 خودا ئێسقانی ئەوانە پەرشوبڵاو دەکاتەوە کە گەمارۆیان داویت، 
\q2 ڕیسوایان دەکەیت، چونکە خودا ڕەتی کردنەوە. 
\b  
\q1  
\v 6 با ڕزگاریی ئیسرائیل لە سییۆنەوە دەربکەوێت! 
\q2 کاتێک خودا گەلەکەی خۆی لە ڕاپێچکراوی دەگەڕێنێتەوە، 
\q2 با یاقوب شاد و ئیسرائیل دڵخۆش بێت! 
\c 54  
\cl زەبووری 54 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بە ئامێرە ژێدارەکان. هۆنراوەیەکی داودە کاتێک زیفییەکان\f + \fr 54:0 \ft دانیشتووانی زیف، کە شارێک بوو لە ناوچە شاخاوییەکەی یەهودا. ئێستا بە گردی زیف بەناوبانگە. دەکەوێتە دووری شەش کیلۆمەتر لە باشووری ڕۆژهەڵاتی حەبرۆن.‏\f* هاتن و بە شاولیان گوت: «داود لەلای ئێمە خۆی شاردووەتەوە.» 
\q1  
\v 1 ئەی خودایە، بە ناوی خۆت ڕزگارم بکە، 
\q2 بە هێزی خۆت ئەستۆپاکیم بسەلمێنە. 
\q1  
\v 2 ئەی خودایە، گوێ لە نوێژم بگرە، 
\q2 قسەکانی دەمم ببیستە. 
\b  
\q1  
\v 3 بێگانە لێم هەستاون، 
\q2 دڵڕەقەکان دەیانەوێ بمکوژن، 
\q2 ئەوانەی ڕوویان لە خودا نەکردووە.\f + \fr 54:3 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 4 بە ڕاستی خودا یارمەتیدەری منە، 
\q2 پەروەردگار پشتگیری گیانم دەکات. 
\b  
\q1  
\v 5 با خراپە بگەڕێتەوە سەر دوژمنەکانم، 
\q2 بە دڵسۆزی خۆت لە ناویان ببە. 
\b  
\q1  
\v 6 ئەی یەزدان، بەخشینی\f + \fr 54:6 \ft بەخشینی ئازاد: ئەو بەخشینەیە کە کەسێک پێشکەشی خودای دەکات وەک سوپاسگوزارییەک بۆی. بڕوانە \xt لێڤییەکان 22‏:18‏-23.‏\ft ‏\f* ئازادت پێشکەش دەکەم، 
\q2 ستایشی ناوت دەکەم، چونکە چاکە. 
\q1  
\v 7 لە هەموو تەنگانەکان دەربازی کردووم، 
\q2 سەرکەوتووانە چاوم بڕیوەتە دوژمنەکانم. 
\c 55  
\cl زەبووری 55 
\d بۆ گەورەی گۆرانیبێژان بە ئامێرە ژێدارەکان، هۆنراوەیەکی داود. 
\q1  
\v 1 ئەی خودایە، گوێ لە نوێژم بگرە، 
\q2 پاڕانەوەم پشت گوێ مەخە، 
\q2  
\v 2 گوێم لێ بگرە و وەڵامم بدەوە. 
\q1 سەرم لێ شێواوە لە نەگبەتی خۆم و بێزارم، 
\q2  
\v 3 لە بیستنی دەنگی دوژمن، 
\q2 لە چاو لێ سوور کردنەوەی بەدکاران، 
\q1 چونکە ئەمانە تووشی گرفتم دەکەن و 
\q2 بە تووڕەییەوە دەمچەوسێننەوە. 
\b  
\q1  
\v 4 دڵم لە ناخمدا پڕ لە ئازارە، 
\q2 ترسی مەرگ هاتووەتە سەرم. 
\q1  
\v 5 ترس و لەرز دایگرتووم، 
\q2 تۆقین باڵی بەسەرمدا کێشاوە. 
\q1  
\v 6 گوتم: «خۆزگە وەک کۆتر باڵم دەبوو، 
\q2 دوور دەفڕیم و دەحەسامەوە، 
\q1  
\v 7 بە ڕاستی دووردەکەوتمەوە و 
\q2 لە چۆڵەوانی دەمامەوە.\f + \fr 55:7 \ft لە دەقی عیبری لێرە و لە ناوەڕاستی ئایەتی 19، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 8 پەلەم دەکرد بۆ شوێنی پەناگای خۆم، 
\q2 دوور لە ڕەشەبا و لە گەردەلوول.» 
\b  
\q1  
\v 9 ئەی پەروەردگار، سەریان لێ بشێوێنە، زمانیان تێک بئاڵێنە، 
\q2 چونکە زۆرداری و دووبەرەکی لە شاردا دەبینم. 
\q1  
\v 10 شەو و ڕۆژ بەسەر شووراکانیدا دەسووڕێنەوە و 
\q2 خراپە و ناڕەوایی لە ناوەڕاستیدایە. 
\q1  
\v 11 وێرانکاری لە ناوەڕاستیدایە، 
\q2 دەستدرێژی و ساختەکاری هەرگیز شەقامەکانی بەرنادەن. 
\b  
\q1  
\v 12 ئەگەر دوژمن سووکایەتی پێم بکردایە، 
\q2 بەرگەم دەگرت، 
\q1 ئەگەر ناحەز بەسەرمدا زاڵ بووایە، 
\q2 دەمتوانی خۆمی لێ بشارمەوە. 
\q1  
\v 13 بەڵام ئەوە تۆی! هاوشێوەی من مرۆڤی، 
\q2 هاوڕێمی، نزیکترین برادەری منی، 
\q1  
\v 14 کە بەیەکەوە پەیوەندییەکی شیرینمان هەبوو، 
\q2 بەیەکەوە لەگەڵ کۆمەڵانی خەڵکدا بەرەو ماڵی خودا دەچووین. 
\b  
\q1  
\v 15 با مەرگ چەواشەیان بکات، 
\q2 با بە زیندوویی دابەزنە ناو جیهانی مردووان، 
\q2 چونکە خراپە شوێنی خۆی کردووەتەوە لەنێویان. 
\b  
\q1  
\v 16 بەڵام هاواری من بۆ خودایە، 
\q2 یەزدانیش ڕزگارم دەکات. 
\q1  
\v 17 ئێواران و بەیانییان و نیوەڕۆیان 
\q2 گلەیی دەکەم و دەناڵێنم، 
\q2 ئەویش گوێم لێ دەگرێت. 
\q1  
\v 18 گیانمی بە تەواوی کڕییەوە 
\q2 لەو جەنگەی دژم هەڵگیرساوە، 
\q2 چونکە زۆرن بەرهەڵستکارانم. 
\q1  
\v 19 خودا، ئەوەی لە ئەزەلەوە لەسەر تەخت دانیشتووە، 
\q2 گوێی لێ دەبێت و ڕیسوایان دەکات؛ 
\q1 ئەوانەی ناگۆڕێن و 
\q2 ترسی خودایان لە دڵدا نییە. 
\b  
\q1  
\v 20 هاوڕێکەم دەستدرێژی دەکاتە سەر دۆستەکانی، 
\q2 پەیمانی خۆی دەشکێنێت. 
\q1  
\v 21 زمانی وەک کەرە لووسە، 
\q2 بەڵام دڵی پڕ لە شەڕە. 
\q1 قسەی لە ڕۆن نەرمترە، 
\q2 بەڵام شمشێری هەڵکێشراوە. 
\b  
\q1  
\v 22 خەمەکانت بە یەزدان بسپێرە، 
\q2 ئەو پشتگیریت دەکات، 
\q2 هەرگیز ناهێڵێت ڕاستودروستان بهەژێن. 
\q1  
\v 23 بەڵام تۆ ئەی خودایە، فڕێیان بدە ناو قووڵترین بیر، 
\q2 خوێنڕێژ و فێڵبازەکان، 
\q2 ڕۆژگاریان ناگاتە نیوە. 
\b  
\q1 بەڵام من پشت بە تۆ دەبەستم. 
\c 56  
\cl زەبووری 56 
\d بۆ گەورەی گۆرانیبێژان لەسەر ئاوازی گۆرانی «کۆتر لەسەر دار بەڕوو دوورن.» پاڕانەوەیەکی داودە کاتێک فەلەستییەکان لە گەت\f + \fr 56:0 \ft بڕوانە \xt پەیدابوون 10‏:14،‏\ft ‏ یەکێک بوو لە پێنج شارە گەورەکەی فەلەستییەکان. شوێنی لەدایکبوونی گولیاتە کە پاڵەوانی فەلەستییەکان بوو و داود بە بەردەقانی کوشتی. بڕوانە ساموئێلی یەکەم \xt 17‏:1‏–18‏:7 و 21‏:11.‏\ft ‏\f* گرتیان. 
\q1  
\v 1 ئەی خودایە، لەگەڵم میهرەبان بە، چونکە خەڵک ڕاوم دەنێن، 
\q2 بە درێژایی ڕۆژ لە دژی من دەجەنگن. 
\q1  
\v 2 دوژمنانم بە درێژایی ڕۆژ ڕاوم دەنێن، 
\q2 چونکە زۆرن ئەوانەی بە لووتبەرزییەوە دەمچەوسێننەوە. 
\b  
\q1  
\v 3 کاتێک ترسم لێ دەنیشێت، 
\q2 من پشت بە تۆ دەبەستم. 
\q1  
\v 4 بە خودا، کە ستایشی پەیامەکەی دەکەم، 
\q2 پشت بە خودا دەبەستم، من ناترسم، 
\q2 مرۆڤ چیم لێ دەکات؟ 
\b  
\q1  
\v 5 بە درێژایی ڕۆژ دەستکاری قسەکانم دەکەن، 
\q2 هەمیشە پیلان بۆ خراپەم دەگێڕن. 
\q1  
\v 6 گیروگرفت دەنێنەوە، خۆیان مات دەکەن، 
\q2 چاویان لە هەنگاوەکانمە، 
\q2 بۆ ئەوەی لە دەرفەتێکدا بمکوژن. 
\q1  
\v 7 لە پێناوی تاوانیان سزایان بدە، 
\q2 ئەی خودایە، بە تووڕەیی خۆت گەلان ژێر بخە. 
\b  
\q1  
\v 8 خۆت ئاگاداری سەرگەردانی منی، 
\q2 فرمێسکەکانم بخەرە مەشکەی خۆتەوە، 
\q2 ئایا ئەوان لە پەڕتووکی تۆدا نەنووسراون؟ 
\q1  
\v 9 لەو ڕۆژەی هاوار بۆ تۆ دەکەم، 
\q2 دوژمنەکانم بەرەو پاش دەکشێنەوە. 
\q2 بەمە دەزانم کە خودا لەگەڵمە. 
\b  
\q1  
\v 10 بە خودا، کە ستایشی پەیامەکەی دەکەم، 
\q2 بە یەزدان، کە ستایشی وشەکەی دەکەم، 
\q1  
\v 11 بە خودا پشت دەبەستم، من ناترسم. 
\q2 مرۆڤ چیم لێ دەکات؟ 
\b  
\q1  
\v 12 ئەی خودایە، نەزرەکانی خۆم بۆ تۆ بەجێدەهێنم، 
\q2 قوربانی سوپاسگوزاری پێشکەش دەکەم. 
\q1  
\v 13 بێگومان تۆ لە مردن فریای گیانم دەکەویت، 
\q2 تۆ پێیەکانی من لە خلیسکان دەپارێزیت، 
\q1 تاکو دۆستایەتی لەگەڵ خودا بکەم و 
\q2 لە ڕووناکی ژیاندا بڕۆم. 
\c 57  
\cl زەبووری 57 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، لەسەر ئاوازی «مەفەوتێنە.» پاڕانەوەیەکی داودە کاتێک لەبەردەم شاول هەڵات لە ئەشکەوتەکە. 
\q1  
\v 1 لەگەڵم میهرەبان بە، ئەی خودایە، لەگەڵم میهرەبان بە، 
\q2 چونکە گیانم پەنا دەهێنێتە بەر تۆ، 
\q1 من پەنا دەهێنمە بەر سێبەری باڵەکانی تۆ، 
\q2 هەتا ئەم بەڵایە بەسەردەچێت. 
\b  
\q1  
\v 2 بۆ خودای هەرەبەرز هاوار دەکەم، 
\q2 بۆ ئەو خودایەی ئەستۆپاکیم دەسەلمێنێت. 
\q1  
\v 3 لە ئاسمانەوە دەنێرێت و ڕزگارم دەکات، 
\q2 ئەوانە ڕیسوا دەکات کە ڕاوم دەنێن.\f + \fr 57:3 \ft لە دەقی عیبری لێرە و لە ئایەتی 6، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q2 خودا خۆشەویستییە نەگۆڕەکەی و دڵسۆزییەکەی دەنێرێت. 
\b  
\q1  
\v 4 گیانم لەناو شێرانە، 
\q2 لەنێو ئاژەڵی دڕندە ڕادەکشێم، 
\q1 ئەو مرۆڤانەی کە ددانەکانیان ڕم و تیرن، 
\q2 زمانیشیان شمشێری تیژە. 
\b  
\q1  
\v 5 ئەی خودایە، بەسەر ئاسماندا بەرزببەوە، 
\q2 با شکۆی تۆ بەسەر هەموو زەوییەوە بێت. 
\b  
\q1  
\v 6 تۆڕیان ناوەتەوە بۆ پێیەکانم، 
\q2 گیانم پەرێشانە. 
\q1 چاڵێکیان لەپێشم هەڵکەند، 
\q2 بەڵام خۆیان تێی کەوتن. 
\b  
\q1  
\v 7 دڵم چەسپاوە، ئەی خودایە، 
\q2 دڵم چەسپاوە، 
\q2 سروود دەڵێم و مۆسیقا دەژەنم. 
\q1  
\v 8 ئەی گیانی من، هەستە! 
\q2 ئەی ساز و قیسارە، هەستن! 
\q2 من بەرەبەیانان هەڵدەستم. 
\b  
\q1  
\v 9 ئەی پەروەردگار، من لەنێو گەلان ستایشت دەکەم، 
\q2 لەنێو نەتەوەکان گۆرانیت بۆ دەڵێم، 
\q1  
\v 10 چونکە خۆشەویستییە نەگۆڕەکەت مەزنە، دەگاتە ئاسمان، 
\q2 دڵسۆزیشت دەگاتە هەورەکان. 
\b  
\q1  
\v 11 ئەی خودایە، بەسەر ئاسماندا بەرزببەوە، 
\q2 با شکۆی تۆ بەسەر هەموو زەوییەوە بێت. 
\c 58  
\cl زەبووری 58 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، لەسەر ئاوازی «مەفەوتێنە.» پاڕانەوەیەکی داود. 
\q1  
\v 1 ئەی فەرمانڕەوایان، ئایا لە ڕاستیدا بە ڕاستودروستی بڕیار دەدەن؟ 
\q2 ئایا دادپەروەرانە حوکمی ئادەمیزاد دەکەن؟ 
\q1  
\v 2 بەڵکو ئێوە لە دڵەوە کار بە خراپە دەکەن، 
\q2 هەروەها دەستتان توندوتیژی لەسەر زەوی ئەنجام دەدات. 
\b  
\q1  
\v 3 بەدکاران لە کاتی لەدایکبوونەوە گومڕان، 
\q2 لە سکی دایکیانەوە درۆ دەکەن. 
\q1  
\v 4 ژەهریان وەک ژەهری مارە، 
\q2 وەک ماری کۆبرا کە کەڕە و گوێی خۆی داخستووە، 
\q1  
\v 5 کە ئاوازی ئەفسونگەران نابیستێت، 
\q2 هەرچەندە بە شارەزاییش ئەفسون بکەن. 
\b  
\q1  
\v 6 ئەی خودایە، ددانیان لە دەمیان بشکێنە، 
\q2 ئەی یەزدان، کەڵبەی شێران وردوخاش بکە! 
\q1  
\v 7 با بتوێنەوە و وەک ئاو بڕۆن، 
\q2 با تیرەکانیان بشکێت کاتێک کەوان ڕادەکێشن. 
\q1  
\v 8 وەک لولپێچ کە دەتوێتەوە کاتێک دەڕوات، 
\q2 وەک منداڵی لەبارچوو، با خۆر نەبینن. 
\b  
\q1  
\v 9 پێش ئەوەی مەنجەڵەکانتان هەست بە ئاگری دڕکەکان بکەن، 
\q2 چ تەڕ بن چ وشک بن، خراپەکانیان ڕادەماڵرێت. 
\q1  
\v 10 کەسی ڕاستودروست کە تۆڵە دەبینێت شاد دەبێت، 
\q2 پێی خۆی بە خوێنی خراپەکار دەشوا. 
\q1  
\v 11 ئینجا خەڵکی دەڵێن: 
\q2 «بێگومان کەسی ڕاستودروست پاداشتی هەیە، 
\q2 بێگومان خودایەک هەیە کە دادگایی زەوی دەکات.» 
\c 59  
\cl زەبووری 59 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، لەسەر ئاوازی «مەفەوتێنە.» پاڕانەوەیەکی داودە، کاتێک شاول پیاوی نارد بۆ ئەوەی چاودێری ماڵی داود بکەن و بیکوژن. 
\q1  
\v 1 ئەی خودای من، فریام بکەوە لە دەست دوژمنەکانم، 
\q2 بمپارێزە لە بەرهەڵستکارانم. 
\q1  
\v 2 فریام بکەوە لە دەست خراپەکاران، 
\q2 ڕزگارم بکە لە دەست خوێنڕێژان. 
\b  
\q1  
\v 3 ببینە چۆن خۆیان بۆم مات داوە! 
\q2 ئەی یەزدان، زۆرداران گەمارۆیان داوم، 
\q2 بەبێ ئەوەی تاوان و گوناهم کردبێ. 
\q1  
\v 4 هەرچەندە هەڵەم نەکردووە، ئامادەن بۆ پەلاماردانم. 
\q2 ڕاپەڕە بۆ فریاکەوتنم، بڕوانە گرفتەکەم! 
\q1  
\v 5 تۆ ئەی یەزدان، خودای سوپاسالار، خودای ئیسرائیل، 
\q2 هەستە بۆ سزادانی هەموو نەتەوەکان، 
\q2 لەگەڵ خیانەتکارە بەدکارەکان میهرەبان مەبە.\f + \fr 59:5 \ft لە دەقی عیبری لێرە و لە ئایەتی 13، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 6 دەمەو ئێواران دەگەڕێنەوە، 
\q2 وەک سەگ دەمڕێنن و 
\q2 بەناو شاردا دەسووڕێنەوە. 
\q1  
\v 7 ئەوەتا تاڵاو لە دەمیانە و 
\q2 شمشێر لە لێویانە، 
\q2 دەڵێن: «کێ گوێی لێمان دەبێت؟» 
\q1  
\v 8 بەڵام تۆ ئەی یەزدان، پێیان پێدەکەنیت، 
\q2 گاڵتە بە هەموو نەتەوەکان دەکەیت. 
\b  
\q1  
\v 9 ئەی هێزی من، چاوەڕێی تۆ دەکەم، 
\q2 ئەی خودایە، تۆ پەناگای منیت. 
\b  
\q1  
\v 10 خودا بە خۆشەویستییە نەگۆڕەکەی دێتە لام، 
\q2 سەرکەوتنم نیشان دەدات بەسەر دوژمنەکانم. 
\q1  
\v 11 ئەی پەروەردگار، قەڵغانی ئێمە، مەیانکوژە، 
\q2 ئەگینا گەلی من لەبیریان دەچێت. 
\q1 بە هێزی خۆت دەربەدەریان بکە و 
\q2 بەریان بدەوە. 
\q1  
\v 12 لەبەر گوناهەکانی دەمیان، 
\q2 لەبەر وتەکانی لێویان، 
\q2 با گرفتاری لووتبەرزی خۆیان بن. 
\q1 لەبەر ئەو درۆ و نەفرەتانەی کردوویانە، 
\q2  
\v 13 لە تووڕەییدا بیانفەوتێنە، 
\q2 بیانفەوتێنە هەتا نەمێنن. 
\q1 ئەوسا دەزانن کە خودا فەرمانڕەوایەتی یاقوب دەکات، 
\q2 هەتا ئەوپەڕی زەوی. 
\b  
\q1  
\v 14 دەمەو ئێواران دەگەڕێنەوە، 
\q2 وەک سەگ دەمڕێنن و 
\q2 بەناو شاردا دەسووڕێنەوە. 
\q1  
\v 15 بەدوای خواردندا وێڵ دەبن، 
\q2 دەوەڕن ئەگەر تێر نەبن. 
\q1  
\v 16 بەڵام من سروود بەسەر هێزی تۆدا دەڵێم، 
\q2 بەیانییان گۆرانی بەسەر خۆشەویستییە نەگۆڕەکەتدا دەڵێم، 
\q1 چونکە تۆ قەڵای منیت، 
\q2 لە ڕۆژی تەنگانەدا پەناگای منیت. 
\b  
\q1  
\v 17 ئەی هێزی من، گۆرانی ستایشت بۆ دەڵێم، 
\q2 ئەی خودایە، تۆ پەناگای منیت، خۆشەویستییە نەگۆڕەکەی خۆتم بۆ دەردەخەی. 
\c 60  
\cl زەبووری 60 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، لەسەر گوڵی سەوسەنی پەیمان. پاڕانەوەیەکی داودە بۆ فێرکردن. کاتی شەڕکردنی لەگەڵ ئارامییەکانی میسۆپۆتامیا و ئارامییەکانی چۆڤا\f + \fr 60:0 \ft یەکێک بوو لە پاشایەتییەکانی ئارامییەکان، دەکەوتە ڕۆژئاوای فوراتەوە.‏\f*، هەروەها کاتێک یۆئاب\f + \fr 60:0 \ft سەرکردەی سوپاکەی داود بوو.‏\f* گەڕایەوە و لە دۆڵی خوێ\f + \fr 60:0 \ft دەکەوێتە باشووری دەریای مردوو.‏\f* دوازدە هەزاری لە ئەدۆمییەکان کوشت. 
\q1  
\v 1 ئەی خودایە، ئێمەت ڕەتکردەوە و ئێمەت شکاند، 
\q2 تۆ تووڕە بووی، ئێستا بمانگەڕێنەوە! 
\q1  
\v 2 تۆ زەویت لەرزاند و شەقت کرد، 
\q2 شکاوییەکانی چاک بکەرەوە، چونکە لەرزۆکە. 
\q1  
\v 3 کاتی سەختت نیشانی گەلەکەت دا، 
\q2 بادەی سەرگەردانیت پێمان نۆشی. 
\q1  
\v 4 بەڵام بۆ ئەوانەی ترسی تۆیان لە دڵدایە، ئاڵات هەڵکرد، 
\q2 بۆ ئەوەی لە دژی تیری دوژمنان بشەکێتەوە.\f + \fr 60:4 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 5 بە دەستی ڕاستت دەربازمان بکە و یارمەتیمان بدە، 
\q2 بۆ ئەوەی خۆشەویستانت ڕزگاریان بێت. 
\q1  
\v 6 خودا لە پیرۆزگاکەی خۆیەوە فەرموویەتی: 
\q2 «بە هاواری خۆشییەوە شەخەم دابەش دەکەم و 
\q2 دۆڵی سوکۆت\f + \fr 60:6 \ft ناوی دوو شاری کۆنە. شەخەم شارێکی شوورابەند بوو لە پاڵ کێوی گریزیم، سوکۆتیش دەکەوتە دووری شەش کیلۆمەتر لە ڕۆژهەڵاتی ڕووباری ئوردون.‏\f* دەپێوم. 
\q1  
\v 7 گلعاد هی منە، مەنەشەش هی منە، 
\q2 ئەفرایم کڵاوی منە، 
\q2 یەهودا\f + \fr 60:7 \ft گلعاد کوڕی ماکیرە و کوڕەزای منەششێیە و منەششێش نۆبەرەی یوسفە، ئەفرایمیش کوڕی دووەمی یوسفە، یەهوداش کوڕی یاقوبە، بۆیە ئەم ناوانە بوون بە ناوی هۆز و عەشیرەتەکانی ئیسرائیل و هەروەها ناوی شار و ناوچەکانیان.‏\f* داری دەسەڵاتی منە، 
\q1  
\v 8 مۆئاب\f + \fr 60:8 \ft خاکی مۆئابییەکان، دەکەوتە بەشی ڕۆژهەڵاتی دەریای مردوو.‏\f* دەستشۆرمە، 
\q2 پێڵاوەکەم فڕێدەدەمە سەر ئەدۆم، 
\q2 لەسەر فەلەستیە هاواری سەرکەوتن دەکەم.» 
\b  
\q1  
\v 9 کێیە دەمباتە شاری قەڵابەند؟ 
\q2 کێیە پێشڕەویم دەکات بۆ ئەدۆم؟ 
\q1  
\v 10 ئەی خودایە، مەگەر تۆ نیت کە ئێمەت ڕەت کردووەتەوە و 
\q2 ئیتر لەگەڵ لەشکرەکانمان دەرناچیت؟ 
\q1  
\v 11 یارمەتیمان بدە بەرامبەر بە دوژمنەکە، 
\q2 چونکە ڕزگاری لە مرۆڤەوە پووچە. 
\q1  
\v 12 لەگەڵ خودا سەرکەوتن بەدەستدەهێنین، 
\q2 هەروەها ئەوە دوژمنەکانمان دەخاتە ژێر پێ. 
\c 61  
\cl زەبووری 61 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، لەسەر ئامێری ژێدار، زەبوورێکی داودە. 
\q1  
\v 1 ئەی خودایە، گوێت لە هاوارم بێت، 
\q2 گوێ لە نوێژەکەم بگرە. 
\b  
\q1  
\v 2 لەوپەڕی زەوییەوە هاوار بۆ تۆ دەکەم، 
\q2 کە دڵم لاواز دەبێت، 
\q2 پێشڕەویم بکە بۆ سەر تاشەبەردێکی لە خۆم بڵندتر، 
\q1  
\v 3 چونکە تۆ پەناگای منی، 
\q2 قوللەیەکی بەهێزی لە ڕووی دوژمن. 
\b  
\q1  
\v 4 با هەتاهەتایە لە پیرۆزگای تۆدا نیشتەجێ بم و 
\q2 پەنا بهێنمە ژێر سێبەری باڵەکانت.\f + \fr 61:4 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 5 ئەی خودایە، چونکە تۆ گوێت لە نەزرەکانم گرت، 
\q2 منت کردە میراتگر لەگەڵ ئەوانەی ترسی ناوی تۆ لە دڵیانە. 
\b  
\q1  
\v 6 درێژە بدە بە ڕۆژانی تەمەنی پاشا، 
\q2 بە ساڵانی تەمەنی بۆ نەوە دوای نەوە. 
\q1  
\v 7 با هەتاهەتایە لە ئامادەبوونی خودا دابنیشێت، 
\q2 دڵسۆزی و خۆشەویستییە نەگۆڕەکەت ئەو بپارێزن. 
\b  
\q1  
\v 8 ئەوسا هەتاهەتایە گۆرانی بۆ ناوی تۆ دەڵێم، 
\q2 ڕۆژ بە ڕۆژیش نەزرەکانم بەجێدەهێنم. 
\c 62  
\cl زەبووری 62 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بۆ یەدوتون، زەبوورێکی داود. 
\q1  
\v 1 گیانم تەنها بە خودا ئارام دەبێت، 
\q2 ڕزگاریشم لەلای ئەوەوە دێت. 
\q1  
\v 2 تەنها ئەو تاشەبەرد و ڕزگاریمە، 
\q2 پەناگای منە، هەرگیز نالەقێم. 
\b  
\q1  
\v 3 هەتا کەی هێرش دەکەنە سەر مرۆڤێک؟ 
\q2 ئایا هەمووتان وەک دیوارێکی لار تێکی دەدەن، 
\q2 وەک شوورایەکی داڕووخاو؟ 
\q1  
\v 4 تەنها پیلان بۆ ئەوە دەگێڕن 
\q2 کە ئەو لەو پلەوپایەیە بخەن، 
\q2 خۆشییان لە درۆوە دێت. 
\q1 بە دەم داوای بەرەکەت دەکەن، 
\q2 بەڵام لە دڵەوە نەفرەت.\f + \fr 62:4 \ft لە دەقی عیبری لێرە و لە ئایەتی 8، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 5 ئەی گیانی من، تەنها بە خودا ئارام بە، 
\q2 چونکە ئومێدی من لەلای ئەوەوە دێت. 
\q1  
\v 6 تەنها ئەو تاشەبەرد و ڕزگاریمە، 
\q2 پەناگای منە، نالەقێم. 
\q1  
\v 7 ڕزگاری و شکۆمەندی من بە خوداوە بەندە، 
\q2 تاشەبەردی بەهێزمە، پەناگای منە. 
\q1  
\v 8 هۆ خەڵکینە، هەموو کاتێک پشت بەو ببەستن، 
\q2 دڵی خۆتانی لەبەردەم هەڵبڕێژن، 
\q2 چونکە خودا پەناگای ئێمەیە. 
\b  
\q1  
\v 9 ئادەمیزاد تەنها هەناسەیەکە، 
\q2 مرۆڤ تەنها درۆیەکە، 
\q1 ئەگەر بخرێنە تای تەرازوو هیچ نین، 
\q2 هەموو پێکەوە تەنها هەناسەیەکن. 
\q1  
\v 10 پشت بە زۆرداری مەبەستن، 
\q2 پۆز بە ماڵی دزراوەوە لێمەدەن. 
\q1 ئەگەر سامانتان زیادی کرد، 
\q2 دڵی خۆتانی پێوە مەبەستن. 
\b  
\q1  
\v 11 جارێک خودا فەرموویەتی، 
\q2 دوو جار بیستوومە\f + \fr 62:11 \ft شێوازێکی دەربڕینی ئەدەبیانەی عیبرییە، بە مەبەستی ئەوەی یەکەمیان گرنگە و دووەمیان لەو گرنگترە.‏\f*: 
\q1 کە هێز هەر هی خودایە، 
\q2  
\v 12 هەروەها کە خۆشەویستی نەگۆڕ هەر هی تۆیە، ئەی پەروەردگار. 
\q1 بێگومان تۆش، هەرکەسێک 
\q2 بەپێی کردەوەی خۆی پاداشت دەدەیتەوە. 
\c 63  
\cl زەبووری 63 
\d زەبوورێکی داودە کاتێک لە چۆڵەوانی یەهودا بوو. 
\q1  
\v 1 ئەی خودایە، تۆ خودای منی، بە پەرۆشم بۆت، 
\q2 گیانم تینووی تۆیە، 
\q1 جەستەم شەیدای تۆیە، 
\q2 لە خاکێکی وشک و ماندوو و بێ ئاو. 
\b  
\q1  
\v 2 لە پیرۆزگاکە سەیرم کردوویت و 
\q2 هێز و شکۆمەندی تۆم بینیوە. 
\q1  
\v 3 لەبەر ئەوەی خۆشەویستییە نەگۆڕەکەت لە ژیان باشترە، 
\q2 لێوەکانم ستایشت دەکەن. 
\q1  
\v 4 بە درێژایی ژیانم ستایشت دەکەم، 
\q2 بە ناوی تۆوە دەستم بەرز دەکەمەوە. 
\q1  
\v 5 گیانم تێر دەبێت وەک ئەوەی بە دوگ\f + \fr 63:5 \ft دوگ یان دونگ‏\f* و چەوری، 
\q2 بە لێوی شادمانەوە دەمم ستایشت دەکات. 
\b  
\q1  
\v 6 لەناو نوێنەکەم یادی تۆ دەکەم، 
\q2 بە درێژایی شەو بیر لە تۆ دەکەمەوە، 
\q1  
\v 7 چونکە تۆ هاریکارم بوویت، 
\q2 لەژێر سێبەری باڵەکانت گۆرانی دەڵێم. 
\q1  
\v 8 گیانم بە تۆوە بەندە، 
\q2 دەستی ڕاستی تۆ پشتم دەگرێت. 
\b  
\q1  
\v 9 بەڵام ئەوانەی بۆ کوشتنی من دەگەڕێن لەناودەچن، 
\q2 بەرەو ناخی زەوی شۆڕ دەبنەوە. 
\q1  
\v 10 ئەوانە بە دەمی شمشێر دەسپێردرێن و 
\q2 دەبن بە خۆراکی چەقەڵ. 
\b  
\q1  
\v 11 بەڵام پاشا بە خودا دڵخۆش دەبێت، 
\q2 هەموو ئەوانەی سوێند بە خودا دەخۆن ستایشی دەکەن، 
\q2 چونکە دەمی درۆزنان دادەخرێت. 
\c 64  
\cl زەبووری 64 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، زەبوورێکی داودە. 
\q1  
\v 1 ئەی خودایە، گوێ لە دەنگی سکاڵام بگرە، 
\q2 ژیانم لە مەترسی دوژمنانم بپارێزە. 
\b  
\q1  
\v 2 لە پیلانی بەدکاران بمشارەوە، 
\q2 لە کۆمەڵی خراپەکاران. 
\q1  
\v 3 کە زمانی خۆیان وەک شمشێر تیژ کردووە، 
\q2 قسە تاڵەکانیان وەک تیری هاوێژراوە. 
\q1  
\v 4 لە بۆسەکانیانەوە تیر لە کەسی بێ کەموکوڕی دەگرن، 
\q2 لەناکاو تێی دەگرن و ناترسن. 
\b  
\q1  
\v 5 بۆ کاری خراپە یەکتری هاندەدەن، 
\q2 دەربارەی شاردنەوەی داوەکانیان دەدوێن، 
\q2 دەڵێن: «کێ دەمانبینێ؟» 
\q1  
\v 6 تەگبیر بۆ تاوان دەکەن، 
\q2 دەڵێن: «پیلانێکی تەواومان داڕشت!» 
\q2 بێگومان دڵ و دەروونی مرۆڤ قووڵە. 
\b  
\q1  
\v 7 بەڵام خودا تیریان تێدەگرێت، 
\q2 لەناکاو برینداریان دەکات. 
\q1  
\v 8 زمان درێژییان دەبێتە هۆی کەوتنیان، 
\q2 هەرکەسێک کە دەیانبینێت سەری بادەدات. 
\q1  
\v 9 هەموو ئادەمیزاد دەترسن، 
\q2 کاری خودا ڕادەگەیەنن و 
\q2 بیردەکەنەوە لەوەی کە کردی. 
\b  
\q1  
\v 10 با ڕاستودروستان بە یەزدان دڵخۆش بن و 
\q2 پەنا ببەنە بەر ئەو، 
\q2 با هەموو دڵڕاستان ستایشی بکەن! 
\c 65  
\cl زەبووری 65 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، زەبوورێکی داود، گۆرانییەک. 
\q1  
\v 1 ئەی خودایە، ستایشکردن لە سییۆن شایانی تۆیە، 
\q2 نەزرەکانمان بۆ تۆ بەجێدەهێنین. 
\q1  
\v 2 ئەی ئەوەی گوێت لە نوێژ دەبێت، 
\q2 هەموو کەس بۆ لای تۆ دێت. 
\q1  
\v 3 کاتێک گوناه بەسەرماندا زاڵ بوو، 
\q2 تۆ کەفارەتی یاخیبوونەکانی ئێمەت کرد. 
\q1  
\v 4 خۆزگە بەوانە دەخوازرێ کە هەڵیاندەبژێریت و 
\q2 نزیکیان دەکەیتەوە بۆ ئەوەی لە حەوشەی ماڵەکەت بژین! 
\q1 تێر بووین لە چاکی ماڵەکەت، 
\q2 لە پەرستگای پیرۆزی تۆ. 
\b  
\q1  
\v 5 بە سامناکی ڕاستودروستی وەڵاممان دەدەیتەوە، 
\q2 ئەی خودای ڕزگارکەرمان، 
\q1 ئەی ئەوەی دانیشتووانی سەراپای زەوی و 
\q2 دەریا دوورەکان پشتت پێ دەبەستن، 
\q1  
\v 6 کە بە هێزی خۆت چیاکانت دامەزراندووە، 
\q2 بە توانا خۆتت چەکدار کردووە، 
\q1  
\v 7 کە هەڵچوونی دەریاکان هێمن دەکەیتەوە، 
\q2 هەڵچوونی شەپۆلەکانیان، 
\q2 هەروەها ئاژاوەی گەلان. 
\q1  
\v 8 ئەوانەی لەوپەڕی جیهان دەژین، لە کارە سەرسوڕهێنەرەکانت دەترسن. 
\q2 لە شوێنی دەرکەوتنی بەرەبەیان و ئاوابوونی ئێواران، 
\q2 گۆرانی شادمانییان پێ دەڵێیت. 
\b  
\q1  
\v 9 بایەخ بە زەوی دەدەیت و ئاوی دەدەیت، 
\q2 زۆر بەپیت و فەڕی دەکەیت، 
\q1 جۆگەکانی خودا پڕ ئاون، 
\q2 دەغڵودانیان ئامادە دەکەیت، 
\q2 چونکە بەم شێوەیە ڕێکت خستووە. 
\q1  
\v 10 هێڵی جووتەکانی تێر ئاو دەکەیت و 
\q2 تەخت و ڕێکیان دەکەیت، 
\q1 بە لێزمەی باران پاراوی دەکەیت و 
\q2 بەروبوومیان بەرەکەتدار دەکەیت. 
\q1  
\v 11 بە چاکەی خۆت تاج دەخەیتە سەر ساڵ و 
\q2 ڕێڕەوەکانت چەوری لێ دەچۆڕێت. 
\q1  
\v 12 لەوەڕگاکانی دەشتودەر پڕ دەبن، 
\q2 ناوقەدی گردەکان بە شادی دەبەستییەوە. 
\q1  
\v 13 مێرگەکان بە ڕانە مەڕ و مێگەل دادەپۆشرێن، 
\q2 دەغڵودان دەبن بە کەوای دۆڵەکان، 
\q2 لە شادمانیدا هاوار دەکەن و گۆرانی دەڵێن. 
\c 66  
\cl زەبووری 66 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، گۆرانییەک، زەبوورێک. 
\q1  
\v 1 ئەی سەراپای زەوی، بە شادمانییەوە هاوار بۆ خودا بکەن! 
\q2  
\v 2 بە شکۆمەندی ناوی ئەو گۆرانی بڵێن، 
\q2 ستایشی شکۆدار بکەن! 
\q1  
\v 3 بە خودا بڵێن: «کردەوەکانت چەند سامناکن! 
\q2 هێزت ئەوەندە گەورەیە، 
\q2 دوژمنانت ملکەچیت بۆ دەنوێنن. 
\q1  
\v 4 سەراپای زەوی کڕنۆشت بۆ دەبەن، 
\q2 گۆرانی ستایشت بۆ دەڵێن، 
\q2 گۆرانی ستایش بۆ ناوی تۆ دەڵێن.»\f + \fr 66:4 \ft لە دەقی عیبری لێرە و لە ئایەتەکانی 7 و 15، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 5 وەرن کردارەکانی خودا ببینن، 
\q2 کارە سامناکەکەی لە پێناوی ئادەمیزاد! 
\q1  
\v 6 دەریای گۆڕی بۆ وشکانی، 
\q2 ئەوان بە پێیان لە ڕووبار پەڕینەوە. 
\q2 با بە ئەو شادمان بین. 
\q1  
\v 7 بە توانای خۆی هەتاهەتایە فەرمانڕەوایەتی دەکات، 
\q2 چاوەکانی چاودێری نەتەوەکان دەکەن، 
\q2 با یاخییەکان خۆیان بەرامبەری هەڵنەکێشن. 
\b  
\q1  
\v 8 ئەی خەڵکینە، ستایشی خودامان بکەن، 
\q2 با دەنگی ستایشکردنی ببیسترێت، 
\q1  
\v 9 کە گیانی ئێمەی بە زیندوویی پاراستووە و 
\q2 نەیهێشتووە پێمان بخلیسکێت. 
\q1  
\v 10 ئەی خودایە، چونکە تۆ ئێمەت تاقی کردووەتەوە، 
\q2 وەک زیو ئێمەت پاڵاوتووە. 
\q1  
\v 11 ئێمەت خستووەتە داوەوە و 
\q2 باری گرانت خستووەتە سەر شانمان. 
\q1  
\v 12 تۆ هێشتت خەڵکی سواری سەرمان بن، 
\q2 بە ناو ئاو و ئاگردا ڕۆیشتین، 
\q2 بەڵام دواتر بۆ شوێنێکی بەپیتت هێناین. 
\b  
\q1  
\v 13 بە قوربانی سووتاندنەوە دێمە پەرستگاکەت، 
\q2 نەزرەکانم بەجێدەهێنم، 
\q1  
\v 14 ئەو نەزرانەی کە لە کاتی تەنگانەدا، 
\q2 لێوەکانم بەڵێنی پێدابوون و بە دەممدا هاتبوون. 
\q1  
\v 15 ئاژەڵی قەڵەو دەکەمە قوربانی، 
\q2 لەگەڵ بۆنی دووکەڵی قۆچی قوربانی، 
\q2 تەگە\f + \fr 66:15 \ft نێری، سابرێن.‏\f* و گات بۆ دەکەمە قوربانی. 
\b  
\q1  
\v 16 ئەی هەموو لەخواترسەکان، وەرن و گوێ بگرن، 
\q2 با پێتان بڵێم چی بۆ من کردووە. 
\q1  
\v 17 بە دەمی خۆم هاوارم بۆی کرد، 
\q2 ستایشکردنی لەسەر زمانم بوو. 
\q1  
\v 18 ئەگەر دڵم حەزی لە خراپە بووایە، 
\q2 پەروەردگار گوێی لێ نەدەگرتم، 
\q1  
\v 19 بەڵام بێگومان خودا گوێی لێ گرتم، 
\q2 گوێی لە دەنگم بوو لە کاتی نوێژکردنم. 
\q1  
\v 20 ستایش بۆ خودا، 
\q2 کە نە نوێژەکەی منی لە خۆی دوورخستەوە و 
\q2 نە خۆشەویستییە نەگۆڕەکەی خۆی لە من. 
\c 67  
\cl زەبووری 67 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بە ئامێرە ژێدارەکان، زەبوورێک، گۆرانییەک. 
\q1  
\v 1 با خودا لەگەڵمان میهرەبان بێت و بەرەکەتدارمان بکات، 
\q2 ڕوخساری خۆیمان بەسەردا بدرەوشێنێتەوە،\f + \fr 67:1 \ft لە دەقی عیبری لێرە و لە ئایەتی 4، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 2 تاکو ڕێگات لەسەر زەوی زانراو بێت، 
\q2 ڕزگاریت لەناو هەموو نەتەوەکان. 
\b  
\q1  
\v 3 ئەی خودایە، با گەلان ستایشت بکەن، 
\q2 با هەموو گەلان ستایشت بکەن. 
\q1  
\v 4 با نەتەوەکان دڵخۆش بن و گۆرانی شادی بڵێن، 
\q2 چونکە بە ڕێکی حوکمی خەڵک دەکەیت و 
\q2 ڕێنمایی نەتەوەکانی سەر زەوی دەکەیت. 
\q1  
\v 5 ئەی خودایە، با گەلان ستایشت بکەن، 
\q2 با هەموو گەلان ستایشت بکەن. 
\b  
\q1  
\v 6 ئینجا زەوی بەروبوومی دەدات، 
\q2 خودا، خودامان، بەرەکەتدارمان دەکات. 
\q1  
\v 7 خودا بەرەکەتدارمان دەکات، 
\q2 سەرتاسەری زەوی لێی دەترسن. 
\c 68  
\cl زەبووری 68 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بۆ داود، زەبوورێک، گۆرانییەک. 
\q1  
\v 1 با خودا هەستێت، با دوژمنانی پەرشوبڵاو ببنەوە! 
\q2 با ناحەزانی لە ڕووی هەڵبێن! 
\q1  
\v 2 وەک بەباکردنی دووکەڵ بەبایان بکەیت، 
\q2 وەک توانەوەی مۆم لەبەردەم ئاگر، 
\q2 با بەدکارانیش لەبەردەم خودا لەناوبچن. 
\q1  
\v 3 بەڵام با ڕاستودروستان لەبەردەم خودا شاد و دڵخۆش بن، 
\q2 لە خۆشییان شاگەشکە بن. 
\b  
\q1  
\v 4 گۆرانی بۆ خودا بڵێن، مۆسیقا بۆ ناوی بژەنن، 
\q2 ئەوەی سواری گالیسکەیە بەسەر هەورەکان بەرزی بکەنەوە، 
\q1 ناوی یەزدانە، 
\q2 لەبەردەمی دڵشاد بن. 
\q1  
\v 5 باوکی هەتیوان و پارێزەری بێوەژنان، 
\q2 خودایە لە چادری پەرستنی پیرۆزی خۆی. 
\q1  
\v 6 خودا ماڵ بۆ لانەوازان دابین دەکات، 
\q2 بەندکراوەکان ئازاد دەکات، 
\q1 بەڵام یاخییەکان لە خاکێکی سووتاو نیشتەجێ دەبن. 
\b  
\q1  
\v 7 ئەی خودایە، کاتێک تۆ پێشڕەویی گەلەکەتت کرد، 
\q2 کاتێک بە چۆڵەوانیدا ڕۆیشتیت،\f + \fr 68:7 \ft لە دەقی عیبری لێرە و لە ئایەتەکانی 19 و 32، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 8 زەوی لەرزی و ئاسمان دڵۆپەی کرد 
\q2 لەبەردەم خودا، خودای سینا، 
\q2 لەبەردەم خودا، خودای ئیسرائیل. 
\q1  
\v 9 ئەی خودایە، بارانێکی چاکت باراند، 
\q2 میراتەکەت ماندوو بوو، تۆ بەهێزت کرد. 
\q1  
\v 10 کۆمەڵەکەت تێیدا نیشتەجێ دەبن، 
\q2 خودایە، بە چاکەی خۆت، بۆ هەژارانت دابین کرد. 
\b  
\q1  
\v 11 پەروەردگار فەرمانی دا\f + \fr 68:11 \ft بەر لە دەستپێکردنی جەنگ خودا فەرمانی سەرکەوتنی دا.‏\f* و 
\q2 کۆمەڵی ژنانی مزگێنیدەر زۆرن: 
\q1  
\v 12 «پاشایان و لەشکرەکانیان بە خێرایی هەڵدێن! 
\q2 ژنەکان کە لە ماڵ ماونەتەوە تاڵان دابەش دەکەن، 
\q1  
\v 13 تەنانەت ئەوانەشی کە لەناو تەویلەشن، 
\q2 باڵی کۆترە لە زیو هەڵکێشراوەکەم و 
\q2 پەڕەمووچەی زێڕی بێگەردیان بەردەکەوێ.» 
\q1  
\v 14 کە خودای هەرە بەتوانا پاشاکانی پەرتەوازە کرد، 
\q2 وەک بارینی بەفر بوو لەسەر کێوی چەلمۆن\f + \fr 68:14 \ft کێوێکی دارستاناوییە لە نزیک شەخەم. بڕوانە \xt ڕابەران 9‏:48‏،49‏\ft ‏.‏\f*. 
\b  
\q1  
\v 15 چیای باشان چیای خودایە، 
\q2 چیای باشان چیای فرە لووتکەیە. 
\q1  
\v 16 ئەی چیا فرە لووتکەکان، بۆچی چاو دەبڕنە ئەو چیایە 
\q2 کە خودا ئارەزووی دەکات تێیدا نیشتەجێ بێت، 
\q2 بەڵێ، ئەوەی یەزدان هەتاهەتایە تێیدا نیشتەجێیە؟ 
\q1  
\v 17 گالیسکەکانی خودا هەزاران هەزارانە، 
\q2 پەروەردگار لە سیناوە هاتە پیرۆزگا. 
\q1  
\v 18 ئەی یەزدان، کاتێک بەرزبوویتەوە بۆ بەرزایی، 
\q2 دیلێکی زۆرت لەگەڵ خۆت برد، 
\q2 دیاریت لە خەڵک وەرگرت، 
\q1 تەنانەت لە یاخییەکانیش، 
\q2 ئەی خودایە، بۆ ئەوەی تۆ لەوێ نیشتەجێ بیت. 
\b  
\q1  
\v 19 ستایش بۆ پەروەردگار، بۆ خودای ڕزگاریمان، 
\q2 ڕۆژ بە ڕۆژ بارمان هەڵدەگرێت. 
\q1  
\v 20 خودا بۆ ئێمە خودای ڕزگارییە، 
\q2 لە مردن دەربازبوونیش لە یەزدانی پەروەردگارەوەیە. 
\q1  
\v 21 بێگومان خودا سەری ناحەزانی پان دەکاتەوە، 
\q2 تەوقی سەری ئەوانەی بە ڕێگای گوناهدا دەڕۆن. 
\q1  
\v 22 پەروەردگار دەفەرموێ: «لە باشانەوە دوژمنانت دەهێنمەوە، 
\q2 لە قووڵایی دەریاکانەوە دەیانهێنمەوە، 
\q1  
\v 23 بۆ ئەوەی پێت بە خوێنیان سوور بێت، 
\q2 زمانی سەگەکانت بەشیان هەبێت لێیان.» 
\b  
\q1  
\v 24 ئەی خودایە، کەژاوەی تۆیان بینی، 
\q2 کەژاوەی خودا و پاشای من بەرەو پیرۆزگا. 
\q1  
\v 25 گۆرانیبێژەکان لەپێشەوەن و ساز لێدەرەکان لە دواوە، 
\q2 کچۆڵە دەف لێدەرەکان لە ناوەڕاستیان. 
\q1  
\v 26 لە کۆڕ و کۆمەڵی گەورەدا ستایشی خودا بکەن، 
\q2 ئەی ڕەچەڵەکی ئیسرائیل، ستایشی یەزدان بکەن. 
\q1  
\v 27 ئەوەتا هۆزی بنیامینی بچکۆڵە پێشەوایانە، 
\q2 کۆمەڵێک سەرکردەی یەهودا، 
\q2 سەرکردەکانی زەبولون و نەفتالی. 
\b  
\q1  
\v 28 ئەی خودایە، تواناکەتمان بۆ دەربخە، 
\q2 ئەی خودایە، پاڵپشتیت دەربخە، هەروەک بۆ ئێمەت کرد. 
\q1  
\v 29 لە پەرستگاکەتەوە، لە ئۆرشەلیم، 
\q2 پاشاکان دیاریت پێشکەش دەکەن. 
\q1  
\v 30 سەرزەنشتی گیانداری ناو قامیشەڵان بکە، 
\q2 ڕەوە گا و گوێرەکەی گەلان،\f + \fr 68:30 \ft مەبەستی لە فیرعەون و سوپای نەتەوەکانی دیکەیە.‏\f* 
\q1 تاکو بە ملکەچییەوە پارچە زیو پێشکەش بکات. 
\q2 ئەو گەلانەی حەزیان لە شەڕە، پەرتیان بکە. 
\q1  
\v 31 باڵوێز لە میسرەوە دێن، 
\q2 کوش\f + \fr 68:31 \ft وڵاتێکە لە سەرووی ڕووباری نیل.‏\f* دەستی خۆی بۆ خودا درێژ دەکات. 
\b  
\q1  
\v 32 ئەی شانشینەکانی زەوی، گۆرانی بۆ خودا بڵێن، 
\q2 مۆسیقا بۆ پەروەردگار بژەنن، 
\q1  
\v 33 بۆ سواری ئاسمان، ئاسمانی دێرین، 
\q2 ئەوەتا دەنگی بەرز دەکاتەوە، بە دەنگێکی بەهێزەوە. 
\q1  
\v 34 با هێزی خودا ڕابگەیەنرێت، 
\q2 ئەوەی شکۆمەندییەکەی بەسەر ئیسرائیلەوەیە، 
\q2 ئەوەی هێزی لەناو هەورەکانە. 
\q1  
\v 35 خودایە، لە پیرۆزگاکەت سامدارتریت، 
\q2 خودای ئیسرائیل هێز و توانا دەدات بە گەلەکەی. 
\b  
\q1 ستایش بۆ خودا! 
\c 69  
\cl زەبووری 69 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بە ئاوازی گوڵی سەوسەن، بۆ داود. 
\q1  
\v 1 ئەی خودایە، ڕزگارم بکە، 
\q2 چونکە ئاو هەتا لووتم هاتووە. 
\q1  
\v 2 لە زەلکاوێکی قووڵ نوقوم دەبم، 
\q2 جێی پێی تێدا نییە. 
\q1 چوومەتە ناو قووڵایی ئاو، 
\q2 لافاو ڕایماڵیوم. 
\q1  
\v 3 ماندوو بووم لە هاوارکردن، 
\q2 گەرووم ژان دەکات، 
\q1 چاوەکانم کز بوون 
\q2 هێندە چاوەڕوانی خودام بکەن. 
\q1  
\v 4 ئەوانەی بەبێ هۆ ڕقیان لێمە 
\q2 لە مووی سەرم زۆرترن، 
\q1 زیاد بوون ئەوانەی دەیانەوێت تێکم بشکێنن، 
\q2 ئەوانەی بە ناڕەوا لە دژی منن. 
\q1 ئەوەی نەمدزیوە 
\q2 ئێستا دەبێت بیدەمەوە. 
\b  
\q1  
\v 5 ئەی خودایە، تۆ دەبەنگی من دەزانیت، 
\q2 تاوانەکانم لە تۆ شاراوە نین. 
\b  
\q1  
\v 6 ئەی یەزدان، پەروەردگاری سوپاسالار، 
\q2 با ئەوانەی هیوایان بە تۆیە، 
\q2 بەهۆی منەوە ڕیسوا نەبن. 
\q1 ئەی خودای ئیسرائیل، 
\q2 با ئەوانەی ڕوو لە تۆ دەکەن، 
\q2 بەهۆی منەوە شەرمەزار نەبن. 
\q1  
\v 7 لە پێناوی تۆ بەرگەی ڕیسواییم گرت، 
\q2 شەرمەزاری ڕووی داگرتم. 
\q1  
\v 8 لەلای براکانم بووم بە بیانی، 
\q2 لەلای کوڕانی دایکم بووم بە بێگانە. 
\q1  
\v 9 دڵگەرمی بۆ ماڵەکەت دەمسووتێنێت، 
\q2 جنێوی ئەوانەی جنێوت پێدەدەن کەوتە سەر من. 
\q1  
\v 10 کاتێک گریام و بە ڕۆژووگرتن گیانم نزم کردەوە، 
\q2 بوو بە سووکایەتی بۆم. 
\q1  
\v 11 جلوبەرگی گوشم پۆشی، 
\q2 بووم بە پەند لەلایان، 
\q1  
\v 12 بووم بە جێی سەرنجی ئەوانەی لەبەر دەروازە دادەنیشن\f + \fr 69:12 \ft پیران و ماقوڵانی شار لەبەردەم دەروازەی شارەکە کۆبوونەتەوە.‏\f*، 
\q2 مەستەکانیش دەربارەی من گۆرانی گاڵتەئامێز هەڵدەبەستن. 
\b  
\q1  
\v 13 ئەی یەزدان، من نوێژم بۆ تۆیە، 
\q2 لە کاتی ڕەزامەندیت، 
\q1 ئەی خودایە، بە گەورەیی خۆشەویستییە نەگۆڕەکەت، 
\q2 بە ڕزگارییە دڵسۆزانەکەت وەڵامم بدەرەوە. 
\q1  
\v 14 دەربازم بکە لە زەلکاو، با نوقوم نەبم، 
\q2 لە دوژمنەکانم و لە قووڵایی ئاو دەرباز دەبم. 
\q1  
\v 15 با لافاو ڕام نەماڵێت، 
\q2 قووڵایی ئاو هەڵمنەلووشێت، 
\q2 زەوی قووتم نەدات. 
\b  
\q1  
\v 16 ئەی یەزدان، بەدەنگمەوە وەرە، چونکە خۆشەویستییە نەگۆڕەکەت چاکە، 
\q2 بەگوێرەی زۆری بەزەییەکەت ئاوڕم لێ بدەوە، 
\q1  
\v 17 ڕووت لە خزمەتکاری خۆت مەپۆشە، 
\q2 چونکە لە تەنگانەدام، زوو وەڵامم بدەوە. 
\q1  
\v 18 لێم نزیک بەرەوە و گیانم دەرباز بکە، 
\q2 لەبەر دوژمنانم بمکڕەوە. 
\b  
\q1  
\v 19 تۆ بە سووکایەتی و شەرمەزاری و ڕیسوایی من دەزانیت، 
\q2 هەموو دوژمنەکانم لەبەردەمتن. 
\q1  
\v 20 ڕیسوایی دڵی شکاندووم، 
\q2 نەخۆش کەوتووم، 
\q1 چاوەڕێی سۆز بووم، نەبوو، 
\q2 چاوم لە دڵنەوایی گێڕا، دەستم نەکەوت. 
\q1  
\v 21 ژەهری تاڵیان دەرخواردم دا، 
\q2 لە تینوویەتیم سرکەیان دەرخوارد دام. 
\b  
\q1  
\v 22 با خوانەکەی بەردەمیان ببێتە داویان، 
\q2 ببێتە سزا و تەڵەیان. 
\q1  
\v 23 با بەرچاویان تاریک بێت تاکو نەبینن، 
\q2 هەمیشە پشتیان چەماوە بێت. 
\q1  
\v 24 هەڵچوونی خۆتیان پێدا هەڵبڕێژە، 
\q2 با ئاگری تووڕەییت بیانگاتێ. 
\q1  
\v 25 با خێوەتگاکانیان چۆڵ بێت، 
\q2 کەس نەبێت لە ڕەشماڵیان نیشتەجێ بێت! 
\q1  
\v 26 ئەوەی تۆ لێت داوە، ئەوان دەیچەوسێننەوە و 
\q2 ئەوەی تۆ بریندارت کردووە، باسی ئازارەکانی دەکەن. 
\q1  
\v 27 تاوان بخەرە سەر تاوانەکانیان، 
\q2 بێبەشیان بکە لە ڕاستودروستیت. 
\q1  
\v 28 لە پەڕتووکی ژیاندا بیانسڕەوە، 
\q2 لەگەڵ ڕاستودروستان ناویان مەنووسە. 
\b  
\q1  
\v 29 ئەی خودایە، من لە ئازار و تەنگانەدام، 
\q2 با ڕزگاریت بمپارێزێت. 
\b  
\q1  
\v 30 بە گۆرانی ستایشی ناوی خودا دەکەم، 
\q2 بە سوپاسگوزارییەوە گەورەیی ڕادەگەیەنم. 
\q1  
\v 31 ئەمە لەلای یەزدان لە گا چاکترە، 
\q2 لە گوێرەکەی بە قۆچ و سم. 
\q1  
\v 32 هەژاران دەبینن و شاد دەبن، 
\q2 ئەی ئەوانەی ڕوو لە خودا دەکەن، با دڵتان ببووژێتەوە! 
\q1  
\v 33 یەزدان بە دەنگ ستەملێکراوانەوە دەچێت، 
\q2 بە سووکییەوە تەماشای دیلەکانی ناکات. 
\b  
\q1  
\v 34 با ئاسمان و زەوی ستایشی بکەن، 
\q2 دەریاکانیش و هەرچی تێیاندا دەجوڵێت، 
\q1  
\v 35 چونکە خودا سییۆن ڕزگار دەکات و 
\q2 شارەکانی یەهودا بنیاد دەنێتەوە، 
\q1 لەوێ نیشتەجێ دەبن و دەبێتە موڵکیان، 
\q2  
\v 36 دەبێتە میرات بۆ منداڵی خزمەتکارەکانی، 
\q2 ئەوانەی ناوی ئەویان خۆشدەوێت تێیدا دەژین. 
\c 70  
\cl زەبووری 70 
\d بۆ گەورەی گۆرانیبێژان، بۆ داود، بۆ یادکردنەوە. 
\q1  
\v 1 ئەی خودایە، خێرابە بۆ دەربازکردنم، 
\q2 ئەی یەزدان، پەلە بکە لە یارمەتیدانم. 
\b  
\q1  
\v 2 با شەرمەزار و سووک بن 
\q2 ئەوانەی گیانی منیان دەوێت، 
\q1 با ببەزن و ڕیسوا بن 
\q2 ئەوانەی حەز بە خراپەی من دەکەن. 
\q1  
\v 3 با هەڵبێن لە شەرمان 
\q2 ئەوانەی پێم دەڵێن: «هۆی ها! هۆی ها!» 
\q1  
\v 4 بەڵام با هەموو ئەوانەی ڕوو لە تۆ دەکەن، 
\q2 شاد و دڵخۆش بن. 
\q1 با هەمیشە بڵێن: «مەزن بێت خودا!» 
\q2 ئەوانەی حەز لە ڕزگاریی تۆ دەکەن. 
\b  
\q1  
\v 5 بەڵام سەبارەت بە من، هەژار و نەدارم، 
\q2 خودایە، خێرا وەرە بۆ لام. 
\q1 یارمەتیدەر و دەربازکەرم تۆی، 
\q2 ئەی یەزدان، دوامەکەوە. 
\c 71  
\cl زەبووری 71 
\q1  
\v 1 ئەی یەزدان، من پەنا دەبەمە بەر تۆ، 
\q2 با هەرگیز شەرمەزار نەبم، 
\q1  
\v 2 بە ڕاستودروستی خۆت فریام بکەوە و دەربازم بکە. 
\q2 گوێم بۆ ڕاگرە و ڕزگارم بکە. 
\q1  
\v 3 بۆم ببە بە تاشەبەردی پەنا، 
\q2 هەمیشە پەنای بۆ ببەم. 
\q1 فەرمانی ڕزگاریی من بدە، 
\q2 چونکە تۆ تاشەبەردی منیت، تۆ قەڵای منیت. 
\q1  
\v 4 ئەی خودای من، لە دەستی بەدکاران، 
\q2 لە چەپۆکی خراپەکاران و زۆرداران دەربازم بکە. 
\b  
\q1  
\v 5 ئەی یەزدانی باڵادەستم، تۆ هیوای منیت، 
\q2 لە گەنجییەوە پشتوپەنای منیت. 
\q1  
\v 6 لە سکی دایکمەوە پشتم بە تۆ بەستووە، 
\q2 تۆ بووی لە هەناوی دایکمەوە دەرتهێنام، 
\q2 ستایشم هەمیشە بۆ تۆیە. 
\q1  
\v 7 بووم بە پەند لەلای زۆر کەس، 
\q2 بەڵام تۆ پەناگای بەهێزی منیت. 
\q1  
\v 8 دەمم پڕە لە ستایشی تۆ، 
\q2 لە شکۆدارکردنت بە درێژایی ڕۆژ. 
\b  
\q1  
\v 9 لە کاتی پیری فڕێممەدە، 
\q2 کە هێزم لەبەر نەما وازم لێ مەهێنە، 
\q1  
\v 10 چونکە دوژمنەکانم قسەم لەسەر دەکەن، 
\q2 ئەوانەی چاوەڕێی کوشتنم دەکەن، پێکەوە تەگبیر دەکەن. 
\q1  
\v 11 دەڵێن: «خودا وازی لێ هێناوە، 
\q2 ڕاوی بنێن و بیگرن، 
\q2 چونکە دەربازکەری نییە.» 
\q1  
\v 12 خودایە، لێم دوور مەکەوە، 
\q2 ئەی خودای من، زوو بگە فریام. 
\q1  
\v 13 با شەرمەزار بن و لەناوبچن، ئەوانەی سکاڵام لێ دەکەن، 
\q2 با بە ڕیسوایی و سووکایەتی بپۆشرێن، 
\q2 ئەوانەی خراپەی منیان دەوێت. 
\b  
\q1  
\v 14 بەڵام من هەمیشە هیوادارم، 
\q2 هەتا دێت زیاتر ستایشت دەکەم. 
\b  
\q1  
\v 15 دەمم باسی ڕاستودروستیت دەکات، 
\q2 بە درێژایی ڕۆژ باسی ڕزگاریت دەکات، 
\q2 هەرچەندە پێوانەکەی نازانم. 
\q1  
\v 16 دان بە پاڵەوانیێتی یەزدانی باڵادەستم دەنێم، 
\q2 تەنها ڕاستودروستی تۆ دەهێنمەوە یاد. 
\q1  
\v 17 خودایە، لە سەردەمی گەنجییەوە فێرت کردووم، 
\q2 هەتا ئێستا کارە سەرسوڕهێنەرەکانت ڕادەگەیەنم. 
\q1  
\v 18 خودایە، تەنانەت لە پیری و ڕیش سپیێتیشم، 
\q2 وازم لێ مەهێنە، 
\q1 هەتا توانات بۆ نەوەی داهاتوو ڕابگەیەنم، 
\q2 هێزت بۆ هەموو ئەوانەی دێن. 
\b  
\q1  
\v 19 خودایە، ڕاستودروستیت هەتا بەرزاییە، 
\q2 کردارەکانت زۆر مەزنن. 
\q2 ئەی خودایە، کێ وەک تۆیە؟ 
\q1  
\v 20 تۆ تەنگانەی زۆر و تاڵت پیشاندام، 
\q2 بەڵام دەگەڕێیتەوە و زیندووم دەکەیتەوە، 
\q2 لە ناخی زەوییەوە دووبارە بەرزم دەکەیتەوە. 
\q1  
\v 21 مەزنێتیم زیاتر دەکەیت، 
\q2 دەگەڕێیتەوە و دڵنەواییم دەکەیت. 
\b  
\q1  
\v 22 ئەی خودای من، 
\q2 لە پێناوی دڵسۆزیت بە ساز ستایشت دەکەم، 
\q1 ئەی پیرۆزەکەی ئیسرائیل، 
\q2 بە قیسارەوە مۆسیقات بۆ دەژەنم. 
\q1  
\v 23 لێوەکانم هەلهەلە لێدەدەن، 
\q2 کە گۆرانیت بۆ دەڵێم، 
\q2 هەروەها گیانم، ئەوەی کە کڕیتەوە. 
\q1  
\v 24 زمانیشم بە درێژایی ڕۆژ باسی ڕاستودروستیت دەکات، 
\q2 چونکە شەرمەزار و سووک بوون، 
\q2 ئەوانەی خراپەی منیان دەوێت. 
\c 72  
\cl زەبووری 72 
\d بۆ سلێمان. 
\q1  
\v 1 ئەی خودایە، دادپەروەری خۆت بدە بە پاشا، 
\q2 ڕاستودروستیت بە کوڕی پاشا. 
\q1  
\v 2 با بە ڕاستودروستی حوکمی گەلەکەت بکات، 
\q2 بە دادپەروەریش هەژارەکانت. 
\b  
\q1  
\v 3 با چیاکان ئاشتی بۆ گەل دابین بکەن، 
\q2 گردەکان ڕاستودروستی. 
\q1  
\v 4 با دادوەری کڵۆڵانی گەل بکات، 
\q2 کوڕی نەداران ڕزگار بکات، 
\q2 زۆرداران وردوخاش بکات. 
\q1  
\v 5 با وەک خۆر بمێنێت، 
\q2 وەک مانگ بە درێژایی نەوەکان. 
\q1  
\v 6 وەک باران بەسەر گیادا ببارێت، 
\q2 وەک هەور زەوی ئاو بدات، 
\q1  
\v 7 ڕاستودروستان لە سەردەمی ئەو شکۆفە دەکەن، 
\q2 ئاشتییەکی زۆر دەبێت هەتا فەوتانی مانگ. 
\b  
\q1  
\v 8 لە دەریاوە هەتا دەریا حوکم دەکات، 
\q2 لە ڕووباری فوراتەوە هەتا ئەوپەڕی زەوی. 
\q1  
\v 9 بیاباننشینەکان کڕنۆشی بۆ دەبەن و 
\q2 ناحەزانی تۆز دەلێسنەوە. 
\q1  
\v 10 پاشاکانی تەرشیش\f + \fr 72:10 \ft تەرشیش: دوایین سنووری ڕۆژئاوای جیهان بووە کە ئەو سەردەمە مرۆڤ پێی زانیبێت.‏\f* و دوورگە دوورەکان سەرانە دەنێرن، 
\q2 پاشاکانی شەبا و سەبا\f + \fr 72:10 \ft ناوی هۆز و شوێنە، دەکەونە یەمەن و هەندێکیان کۆچیان کردووە بۆ ئەسیوپیا. خەڵکەکەی بە بازرگانی بەناوبانگ بوون.‏\f* دیاری بۆ دێنن. 
\q1  
\v 11 هەموو پاشاکان کڕنۆشی بۆ دەبەن و 
\q2 هەموو نەتەوەکان خزمەتی دەکەن. 
\b  
\q1  
\v 12 لەبەر ئەوەی نەدار کە هاواری بۆ دەبات، دەربازی دەکات، 
\q2 چەوسێنراویش کە یارمەتیدەری نییە. 
\q1  
\v 13 بەزەیی بە لاواز و نەداردا دێتەوە، 
\q2 گیانی نەدارەکان ڕزگار دەکات، 
\q1  
\v 14 گیانیان لە ستەم و توندوتیژی دەکڕێتەوە، 
\q2 خوێنی ئەوان لەلای بەنرخە. 
\b  
\q1  
\v 15 تەمەن درێژ بێت! 
\q2 با لە زێڕی شەبای پێبدرێت، 
\q1 با هەمیشە خەڵک نزای بۆ بکەن، 
\q2 با بە درێژایی ڕۆژ داوای بەرەکەتی بۆ بکەن. 
\q1  
\v 16 با دانەوێڵەیەکی زۆر لەسەر زەوی بێت، 
\q2 لەسەر لووتکەی گردەکان، 
\q1 بەرهەمی وەک لوبنان بشەکێتەوە، 
\q2 با ئەوانەی لە شارەکانن وەک گیای کێڵگە چرۆ بکەن. 
\q1  
\v 17 با هەتاهەتایە ناوی بمێنێت، 
\q2 هەتا خۆر مابێت ناوی بەردەوام بێت. 
\b  
\q1 هەموو نەتەوەکان لەوەوە بەرەکەتدار بن، 
\q2 هەمووان خۆزگەی پێ بخوازن. 
\b  
\q1  
\v 18 ستایش بۆ یەزدانی پەروەردگار، خودای ئیسرائیل، 
\q2 بە تەنها ئەوە کاری سەرسوڕهێنەر دەکات. 
\q1  
\v 19 هەتاهەتایە ستایش بۆ ناوی شکۆداری، 
\q2 با شکۆمەندییەکەی هەموو جیهان پڕ بکات. 
\q4 ئامین و ئامین. 
\b  
\q1  
\v 20 لێرەدا نوێژەکانی داودی کوڕی یەسا تەواو بوون. 
\c 73  
\ms1 کۆکراوەی بەشی سێیەم 
\mr زەبوورەکانی 73‏–89 
\cl زەبووری 73 
\d زەبوورێکی ئاساف. 
\q1  
\v 1 بێگومان خودا چاکە بۆ ئیسرائیل، 
\q2 بۆ دڵپاکەکان. 
\b  
\q1  
\v 2 بەڵام من خەریک بوو پێم بخزێت و 
\q2 زۆری نەمابوو هەنگاوم بخلیسکێت، 
\q1  
\v 3 چونکە بەغیلیم بە لووتبەرزەکان برد، 
\q2 کە ئاسوودەیی بەدکارانم دی. 
\b  
\q1  
\v 4 ترسیان لە مردن نییە، 
\q2 جەستەیان تەندروست و قەڵەوە. 
\q1  
\v 5 لە ڕەنجکێشانی مرۆڤ بەدەرن، 
\q2 وەک خەڵکی تێناکەون. 
\q1  
\v 6 بۆیە لووتبەرزییان وەک ملوانکە لە مل کردووە و 
\q2 بەرگی توندوتیژییان پۆشیوە. 
\q1  
\v 7 خراپە لە دڵی بێ بەزەییانەوە دێت، 
\q2 لێکدانەوەی دڵیان بێ سنوورە. 
\q1  
\v 8 گاڵتەجاڕی دەکەن و بە خراپە دەدوێن، 
\q2 بە لووتبەرزییەوە باسی ستەم دەکەن. 
\q1  
\v 9 ڕووی دەمیان لە ئاسمان کردووە، 
\q2 زمانیشیان بەسەر زەویدا دەگێڕن. 
\q1  
\v 10 بۆیە خەڵکی خۆیان دێنە لایان و 
\q2 باوەڕ بە قسەکانیان دەکەن\f + \fr 73:10 \ft عیبری: ئاو بە زۆری دەخۆنەوە.‏\f*. 
\q1  
\v 11 دەڵێن: «چۆن خودا دەزانێت؟ 
\q2 ئایا لەلای هەرەبەرز زانیاری هەیە؟» 
\b  
\q1  
\v 12 ئەوەتا ئەمانە بەدکارن، 
\q2 هەمیشە لە خۆشیدان و سامانیان لە زیادبووندایە. 
\b  
\q1  
\v 13 بێگومان بە بێهوودە دڵی خۆمم بە پاکی ڕاگرتووە، 
\q2 دەستیشم بە بێگەردی شوشتووە. 
\q1  
\v 14 بە درێژایی ڕۆژ لێم قەومابوو، 
\q2 هەتا بەرەبەیان تەمبێ کرابووم. 
\b  
\q1  
\v 15 ئەگەر بە ڕاشکاوی قسەم دەکرد، 
\q2 ئەوا لەگەڵ منداڵەکانت ناپاک دەبووم. 
\q1  
\v 16 کاتێک ویستم لەمە تێبگەم، 
\q2 بە ئەرکێکی سەختم بینی، 
\q1  
\v 17 هەتا چوومە ناو پیرۆزگای خودا، 
\q2 ئەوسا لە چارەنووسیان تێگەیشتم. 
\b  
\q1  
\v 18 بە ڕاستی لە جێگایەکی خلیسک داتناون، 
\q2 تووشی وێرانیت کردوون. 
\q1  
\v 19 چۆن بە چاوتروکانێک وێران بوون، 
\q2 لە ترسان بە تەواوی لەناوچوون! 
\q1  
\v 20 ئەی پەروەردگار، وەک خەون کاتی بەئاگا هاتنەوە، 
\q2 لە کاتی بەئاگایی وەک خەون ڕیسوایان دەکەیت. 
\b  
\q1  
\v 21 کاتێک دڵم تەنگ بوو، 
\q2 وەک شمشێر هەناومی بڕی، 
\q1  
\v 22 گێل و نەزان بووم، 
\q2 لەلای تۆ وەک ئاژەڵم لێهات. 
\b  
\q1  
\v 23 لەگەڵ ئەوەشدا، من هەمیشە لەلای تۆم، 
\q2 دەستی ڕاستی منت گرت. 
\q1  
\v 24 بە ئامۆژگاریت ڕێنماییم دەکەیت، 
\q2 پاشان بۆ شکۆمەندیم دەبەیت. 
\q1  
\v 25 بێجگە لە تۆ لە ئاسمان کێم هەیە؟ 
\q2 ئەگەر لەگەڵ تۆ بم، لەسەر زەویش هیچ نییە ئارەزووی بکەم. 
\q1  
\v 26 جەسته و دڵم کۆتاییان پێدێت، 
\q2 بەڵام هەتاهەتایە هێزی دڵ و بەشی من خودایە. 
\b  
\q1  
\v 27 ئەوەتا ئەوانەی لە تۆ دوورن وێڵ دەبن، 
\q2 ئەوانەی ناپاکیت لەگەڵ بکەن دوایان دەبڕیتەوە. 
\q1  
\v 28 بەڵام نزیکبوونەوە لە خودا بۆ من باشە، 
\q2 یەزدانی باڵادەستم کرد بە پەناگام، 
\q2 هەتا باسی هەموو کردەوەکانت بکەم. 
\c 74  
\cl زەبووری 74 
\d هۆنراوەیەکی ئاساف. 
\q1  
\v 1 ئەی خودایە، بۆچی هەتاهەتایە ڕەتت کردینەوە؟ 
\q2 بۆچی تووڕەییت دووکەڵ دەکات بەسەر مەڕی لەوەڕگاکەتدا؟ 
\q1  
\v 2 کۆمەڵی خۆت لەبیر بێت، کە لە کۆنەوە بەدەستت هێناوە، 
\q2 هۆزی میراتی خۆتت کڕییەوە، 
\q2 ئەم کێوی سییۆنە کە تێیدا نیشتەجێ بوویت. 
\q1  
\v 3 هەنگاو هەڵبڕە بەرەو وێرانگای هەمیشەیی، 
\q2 هەموو ئەو وێرانکارییەی کە دوژمن بە پیرۆزگای کرد. 
\b  
\q1  
\v 4 ناحەزەکانت لە ناوەڕاستی شوێنی چاوپێکەوتنی تۆدا نەڕاندیان، 
\q2 ئاڵاکانیان وەک نیشانە چەقاند. 
\q1  
\v 5 لەوانە دەچوون کە تەورەکانیان بەرزکردووەتەوە، 
\q2 لەسەر داری دارستانەکان. 
\q1  
\v 6 بە تەور و چەکوش تێکیان شکاند، 
\q2 هەموو نەخشێنراوەکان. 
\q1  
\v 7 ئاگریان لە پیرۆزگاکەت بەردا، 
\q2 ئەو شوێنەی کە ناوی تۆی تێدا نیشتەجێیە گڵاویان کرد. 
\q1  
\v 8 لە دڵی خۆیاندا گوتیان: «بە تەواوی بەسەریاندا زاڵ دەبین!» 
\q2 هەموو نزرگەیەکی خودایان لەسەر زەوی سووتاند. 
\b  
\q1  
\v 9 پەرجووەکانمان\f + \fr 74:9 \ft پەرجوو: موعجیزە.‏\f* نابینین و 
\q2 هیچ پێغەمبەرێک نەماوە، 
\q2 کەسیشمان نازانێت تاکو کەیە. 
\q1  
\v 10 ئەی خودایە، هەتا کەی ناحەزان جنێو بدەن؟ 
\q2 ئایا دوژمن هەتاهەتایە بێزیان لە ناوی تۆ بێتەوە؟ 
\q1  
\v 11 بۆچی دەستت دەگەڕێنیتەوە؟ 
\q2 دەستی ڕاستت لە باخەڵت دەربهێنە و لەناویان ببە! 
\b  
\q1  
\v 12 بەڵام خودایە، تۆ هەر لە ئەزەلەوە پاشای منی، 
\q2 دروستکەری ڕزگاریت لە ناوەڕاستی زەوی. 
\b  
\q1  
\v 13 تۆ بە هێزی خۆت دەریات شەقکرد، 
\q2 سەری ئەژدیهاکانی دەریات لەسەر ئاو پانکردەوە. 
\q1  
\v 14 تۆ سەرەکانی لیڤیاتانت\f + \fr 74:14 \ft جۆرە ئەژدیهایەکە، بڕوانە \xt ئەیوب 41‏:1‏\ft ‏.‏\f* وردوخاش کرد، 
\q2 کردت بە خۆراکی دڕندە بیابانییەکان. 
\q1  
\v 15 تۆ کانی و جۆگەکانت تەقاندەوە، 
\q2 تۆ ڕووبارە هەمیشە ڕۆیشتووەکانت وشککرد. 
\q1  
\v 16 ڕۆژ هی تۆیە و شەویش هی تۆیە، 
\q2 تۆ ڕووناکی و خۆرت دامەزراند. 
\q1  
\v 17 هەموو سنوورەکانی زەوی تۆ دیارت کردوون، 
\q2 تۆ هاوین و زستانت داهێناوە. 
\b  
\q1  
\v 18 ئەی یەزدان، ئەمەت لەبیر بێت، ناحەزان سووکایەتییان پێت کرد، 
\q2 گەلێکی گێل بێزیان لە ناوی تۆ کردەوە. 
\q1  
\v 19 گیانی کۆترەکەت\f + \fr 74:19 \ft مەبەستی لە گەلی ئیسرائیلە، بڕوانە \xt هۆشەع 7‏:11‏\ft ‏.‏\f* مەکە نێچیری دڕندەکان، 
\q2 هەرگیز ژیانی گەلە چەوسێنراوەکەت لەبیر مەکە. 
\q1  
\v 20 پەیمانی خۆت لەبیر بێت، 
\q2 چونکە هەموو شوێنە تاریکەکانی زەوی بوونە لانەی توندوتیژی. 
\q1  
\v 21 ڕێ مەدە کەسی تێکشکاو بە شەرمەزاری بگەڕێتەوە. 
\q2 با هەژار و کڵۆڵان ستایشی ناوت بکەن. 
\q1  
\v 22 ئەی خودایە، ڕاپەڕە، بەرگری لە مافی خۆت بکە! 
\q2 لەبیرت بێت چۆن گێلەکان بە درێژایی ڕۆژ گاڵتەیان پێت دەکرد. 
\q1  
\v 23 قسەی دژەکانت لەبیر مەکە، 
\q2 ژاوەژاوی نەیارانت کە بەردەوام لە زیادبوونە. 
\c 75  
\cl زەبووری 75 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، لەسەر ئاوازی «وێران مەکە»، زەبوورێکی ئاساف. گۆرانییەک. 
\q1  
\v 1 ئەی خودایە، ستایشت دەکەین، 
\q2 ستایشت دەکەین، چونکە ناوت نزیکە، 
\q2 خەڵکی باسی کارە سەرسوڕهێنەرەکانت دەکەن. 
\b  
\q1  
\v 2 تۆ دەفەرمووی: «کات دیار دەکەم، 
\q2 بە ڕاستی دادوەری دەکەم. 
\q1  
\v 3 کە زەوی و هەموو دانیشتووانەکەی دەلەرزن، 
\q2 منم کۆڵەکەکانی دەچەسپێنم.\f + \fr 75:3 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 4 بە لووتبەرزان دەڵێم: ”لووتبەرز مەبن،“ 
\q2 بە خراپەکاران: ”هێزتان دەرمەخەن. 
\q1  
\v 5 هێزتان بەرەو ئاسمان دەرمەخەن، 
\q2 بە کەللەڕەقی مەدوێن.“» 
\b  
\q1  
\v 6 نە لە ڕۆژهەڵات و نە لە ڕۆژئاوا، 
\q2 نە لە بیابان کەس ناتوانێ مرۆڤ بەرز بکاتەوە، 
\q1  
\v 7 بەڵکو خودایە دادپەروەری دەکات، 
\q2 ئەم نزم دەکات و ئەو بەرز دەکاتەوە. 
\q1  
\v 8 جام بەدەستی یەزدانەوەیە، 
\q2 پڕە لە مەی ترشاو و تێکەڵ بە داوودەرمان، 
\q1 لەمە تێدەکات، هەموو بەدکارانی سەر زەوی 
\q2 لێی بخۆنەوە و هەتا خڵتەکەی بەتاڵی بکەن. 
\b  
\q1  
\v 9 بەڵام من هەتاهەتایە ئەمە ڕادەگەیەنم، 
\q2 گۆرانی بۆ خودای یاقوب دەڵێم، کە دەفەرموێت: 
\q1  
\v 10 «هێزی هەموو بەدکارەکان دەڕووخێنم، 
\q2 هێزی ڕاستودروستانیش زیاد دەکەم.» 
\c 76  
\cl زەبووری 76 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بە ئامێری ژێدار. زەبوورێکی ئاساف. گۆرانییەک. 
\q1  
\v 1 لە یەهودا خودا ناسراوە، 
\q2 لە ئیسرائیلدا ناوی گەورەیە! 
\q1  
\v 2 کەپری لە شالیمە\f + \fr 76:2 \ft واتا (ئاشتی)، مەبەست لە شاری ئۆرشەلیمە (قودس).‏\f*، 
\q2 هەواری لە سییۆنە. 
\q1  
\v 3 لەوێ تیرە گڕدارەکان و 
\q2 قەڵغان و شمشێر و جەنگەکانی تێکشکاند.\f + \fr 76:3 \ft لە دەقی عیبری لێرە و لە ئایەتی 9، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 4 تۆ ڕەوشەنی، 
\q2 لە چیای نێچیرەکان شکۆدارتری. 
\q1  
\v 5 قارەمانەکان ماڵیان بە تاڵان چوو، 
\q2 دوایین خەوی خۆیان نوستن، 
\q2 هیچ جەنگاوەرێک نەیتوانی دەست بکاتەوە. 
\q1  
\v 6 ئەی خودای یاقوب، بە سەرزەنشتی تۆ، 
\q2 ئەسپ و سوار پێکەوە کەوتنە خەوێکی قووڵەوە! 
\b  
\q1  
\v 7 تۆ خۆت بەسامیت! 
\q2 لە کاتی تووڕەییت، کێ لەبەردەمت ڕادەوەستێت؟ 
\q1  
\v 8 لە ئاسمان حوکمت بیسترا، 
\q2 زەوی ترسا و کپ بوو، 
\q1  
\v 9 بە هەستانی خودا بۆ دادوەری، 
\q2 بۆ ڕزگارکردنی هەموو ستەملێکراوانی زەوی. 
\q1  
\v 10 بێگومان تووڕەیی مرۆڤ ستایشت دەکات، 
\q2 خۆتت بە پاشماوەی تووڕەیی چەکدار کردووە. 
\b  
\q1  
\v 11 نەزر بۆ یەزدانی پەروەردگارتان بکەن و بەجێی بهێنن. 
\q2 ئەی هەموو ئەوانەی لە دەوریدان، 
\q2 دیاری پێشکەش بە سامناک بکەن. 
\q1  
\v 12 ئەوەی ڕۆحی میرەکان دەشکێنێت، 
\q2 سامناکە بۆ پاشاکانی سەر زەوی. 
\c 77  
\cl زەبووری 77 
\d بۆ گەورەی گۆرانیبێژان. ئاوازی یەدوتون، زەبوورێکی ئاساف. 
\q1  
\v 1 دەنگم بۆ خودا بەرز دەکەمەوە، هاوار دەکەم، 
\q2 دەنگم بۆ خودا بەرز دەکەمەوە بۆ ئەوەی گوێی لێم بێت. 
\q1  
\v 2 لە ڕۆژی تەنگانەم ڕوو لە پەروەردگار دەکەم، 
\q2 بە درێژایی شەو دەست پان دەکەمەوە، بێ ئەوەی سڕبێت. 
\q2 گیانم نەوازش ڕەت دەکاتەوە. 
\b  
\q1  
\v 3 بیر لە خودا دەکەمەوە و دەناڵێنم، 
\q2 ورد دەبمەوە و ڕۆحم دەبوورێتەوە.\f + \fr 77:3 \ft لە دەقی عیبری لێرە و لە ئایەتەکانی 9 و 15، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 4 پێڵووی چاوەکانمت گرت، 
\q2 شپرزە بووم، قسەم پێ نەکرا. 
\q1  
\v 5 بیر لە ڕۆژگاری دێرین دەکەمەوە، 
\q2 ساڵانی ڕابردوو. 
\q1  
\v 6 شەوانە لە دڵی خۆم بیر لە ئاوازەکانم دەکەمەوە، 
\q2 ورد دەبمەوە و ڕۆحم دەگەڕێت: 
\b  
\q1  
\v 7 «ئایا هەتاهەتایە پەروەردگار ڕەتمان دەکاتەوە؟ 
\q2 چیتر لێمان ڕازی نابێتەوە؟ 
\q1  
\v 8 ئایا خۆشەویستییە نەگۆڕەکەی هەتاهەتایە نەماوە؟ 
\q2 ئایا بەڵێنەکانی بۆ نەوە دوای نەوە دواییان هاتووە؟ 
\q1  
\v 9 ئایا خودا میهرەبانی لەبیر کردووە؟ 
\q2 یان لە تووڕەیی بەزەیی خۆی داخستووە؟» 
\q1  
\v 10 ئینجا دەڵێم: «ئەمە دەردی منە: 
\q2 دەستە ڕاستەی خودای هەرەبەرز گۆڕاوە.» 
\b  
\q1  
\v 11 کردارەکانی یەزدان دێنمەوە یادم، 
\q2 بێگومان پەرجووەکانی تۆم لەبیرە کە لە کۆنەوەیە. 
\q1  
\v 12 لە هەموو کارەکانت ورد دەبمەوە و 
\q2 بیر لە کردەوە مەزنەکانت دەکەمەوە. 
\b  
\q1  
\v 13 ئەی خودایە، ڕێگات پیرۆزە. 
\q2 چ خودایەک وەک خودا مەزنە؟ 
\q1  
\v 14 تۆ ئەو خودایەی کە پەرجووت کردووە و 
\q2 هێزی خۆتت لەنێو خەڵک دەرخستووە. 
\q1  
\v 15 بە بازووی خۆت گەلی خۆتت کڕییەوە، 
\q2 نەوەی یاقوب و یوسف. 
\b  
\q1  
\v 16 ئەی خودایە، کە ئاوەکان تۆیان بینی، 
\q2 کە ئاوەکان تۆیان بینی ترسان، 
\q2 بگرە قووڵاییەکان هەژان. 
\q1  
\v 17 هەورەکان ئاویان ڕشت، 
\q2 هەورەتریشقەکان دەنگیان دایەوە، 
\q2 هەروەها تیرەکانت بریسکانەوە. 
\q1  
\v 18 گرمەی هەورەتریشقەی تۆ لە گەردەلوول، 
\q2 بروسکەکان دنیایان ڕووناک کردەوە، 
\q2 زەوی لەرزی و هەژا. 
\q1  
\v 19 ڕێگات بە ناو دەریادایە، 
\q2 ڕێچکەکانت بە ناو ئاوە زۆرەکانە، 
\q2 شوێن پێیەکانت نەزانران. 
\b  
\q1  
\v 20 لەسەر دەستی موسا و هارون، 
\q2 وەک مێگەلە مەڕ ڕێنمایی گەلی خۆتت کرد. 
\c 78  
\cl زەبووری 78 
\d هۆنراوەیەکی ئاساف. 
\q1  
\v 1 ئەی گەلی من، گوێ بدەنە فێرکردنم، 
\q2 گوێ شل بکەن بۆ قسەکانی دەمم. 
\q1  
\v 2 بە نموونە دەمم دەکەمەوە، 
\q2 مەتەڵی ڕۆژگاری کۆن ڕادەگەیەنم. 
\q1  
\v 3 ئەو شتانەی بیستوومانە و زانیومانە، 
\q2 ئەوەی باوباپیرانمان پێیان گوتووین. 
\q1  
\v 4 ئەو شتانە لە منداڵەکانیان ناشارینەوە، 
\q2 بەڵکو بە نەوەی داهاتوو، 
\q1 ستایشی یەزدان ڕادەگەیەنین، 
\q2 هێزی و کارە سەرسوڕهێنەرەکانی کە کردوویەتی. 
\q1  
\v 5 لەناو بنەماڵەی یاقوب شەریعەتی\f + \fr 78:5 \ft بڕوانە \xt دەرچوون 16‏:31‏-34.‏\ft ‏\f* دامەزراند، 
\q2 لەناو ئیسرائیل تەورات، 
\q1 کە باوباپیرانی ئێمەی ڕاسپارد 
\q2 کە فێری منداڵانی خۆیانی بکەن، 
\q1  
\v 6 بۆ ئەوەی نەوەی داهاتوو بیانزانێت، 
\q2 ئەو منداڵانەی لەدایک دەبن، 
\q2 ئەوانیش هەستن و بۆ منداڵانی خۆیانی باس بکەن. 
\q1  
\v 7 ئینجا هیوایان بە خودا دەبێت، 
\q2 کردارەکانی خودایان لە یاد ناچێ، 
\q2 بەڵکو ڕاسپاردەکانی بەجێدەگەیەنن، 
\q1  
\v 8 بۆ ئەوەی وەک باوباپیرانیان نەبن، 
\q2 نەوەیەکی یاخی و کەللەڕەق، 
\q1 نەوەیەک جگەرسۆز نەبوو بۆ خودا، 
\q2 ڕۆحیشیان دڵسۆزی ئەو نەبوو. 
\b  
\q1  
\v 9 ئەفرایمییەکان کە چەکیان تیروکەوان بوو، 
\q2 لە ڕۆژی جەنگدا گەڕانەوە. 
\q1  
\v 10 پەیمانی خودایان شکاند، 
\q2 بەپێی فێرکردنی نەجوڵانەوە. 
\q1  
\v 11 کردارەکانی خودایان لەبیر کرد، 
\q2 ئەو کارە سەرسوڕهێنەرانەی کە پیشانی دابوون. 
\q1  
\v 12 لەبەرچاوی باوباپیرانیان پەرجووی کرد، 
\q2 لە خاکی میسر، لە وڵاتی چۆعەن\f + \fr 78:12 \ft شارێکی میسرییە دەکەوتە ڕۆژهەڵاتی دەلتای نیلەوە.‏\f*. 
\q1  
\v 13 دەریای شەقکرد و پەڕاندنیەوە، 
\q2 وەک بەربەست ئاوی ڕاگرت. 
\q1  
\v 14 بە ڕۆژ بەهۆی هەورەوە ڕێبەری کردن، 
\q2 بە درێژایی شەویش بە ڕووناکی ئاگر. 
\q1  
\v 15 لە بیابان تاشەبەردی شەقکرد و ئاوی پێدان، 
\q2 ئەوەندە زۆر وەک لە دەریاوە بێت. 
\q1  
\v 16 جۆگەی لەناو تاشەبەرد هەڵقوڵاند، 
\q2 وەک ڕووبار ئاوی بەردایەوە. 
\b  
\q1  
\v 17 بەڵام بەردەوام بوون لە گوناهکردن لە دژی، 
\q2 لە یاخیبوون لە دژی خودای هەرەبەرز لە بیابان. 
\q1  
\v 18 لە دڵی خۆیاندا خودایان تاقی کردەوە 
\q2 بە داواکردنی ئەو خواردنەی دڵیان پێوەی بوو. 
\q1  
\v 19 لە دژی خودا دوان و گوتیان: 
\q2 «ئایا خودا دەتوانێت لە چۆڵەوانی مێزێک بڕازێنێتەوە؟ 
\q1  
\v 20 ڕاستە، لە تاشەبەردەکەی دا و ئاوی لێ هێنا، 
\q2 جۆگەکان ئاویان لێ ڕژا! 
\q1 بەڵام ئایا دەتوانێت نانیش بدات و 
\q2 گۆشت بۆ گەلەکەی دابین بکات؟» 
\q1  
\v 21 کە یەزدان ئەمەی بیست زۆر تووڕە بوو، 
\q2 ئاگری داگیرسا لە دژی یاقوب، 
\q2 هەروەها تووڕەیی هەستا لە ئیسرائیل، 
\q1  
\v 22 چونکە بڕوایان بە خودا نەهێنا و 
\q2 پشتیان بە ڕزگاریی ئەو نەبەست. 
\q1  
\v 23 جا فەرمانی دا بە هەورەکان لە بەرزایی، 
\q2 دەرگای ئاسمانی کردەوە، 
\q1  
\v 24 مەنی بەسەریاندا باراند بۆ خواردن و 
\q2 دانەوێڵەی ئاسمانی پێدان. 
\q1  
\v 25 مرۆڤ نانی فریشتەکانیان خوارد، 
\q2 ئازووقەی بۆ ناردن هەتا تێربوون. 
\q1  
\v 26 لە ئاسمانەوە بای ڕۆژهەڵاتی هەڵکرد، 
\q2 بە هێزیشی بای باشووری بەرەو پێش برد. 
\q1  
\v 27 وەک خۆڵ گۆشتی بەسەریاندا باراند، 
\q2 وەک لمی دەریاکان پەلەوەری باڵدار. 
\q1  
\v 28 باراندییە ناو ئۆردوگاکەیان، 
\q2 لە دەوروبەری چادرەکانیان. 
\q1  
\v 29 خواردیان و زۆر تێر بوون، 
\q2 ئەوەی دڵیان پێوەی بوو بۆی هێنان. 
\q1  
\v 30 بەڵام بەر لەوەی ئەوەی حەزیان لێی بوو بەجێی بهێڵن، 
\q2 هێشتا خواردنەکەیان لەناو دەم بوو، 
\q1  
\v 31 تووڕەیی خودا لێیان هەستا، 
\q2 هەرە بەهێزەکانی کوشتن و 
\q2 باشترین گەنجەکانی ئیسرائیلی خست. 
\b  
\q1  
\v 32 لەگەڵ ئەمەشدا گوناهیان کردەوە، 
\q2 بڕوایان بە کارە سەرسوڕهێنەرەکانی نەکرد. 
\q1  
\v 33 بە فووێک ڕۆژگاری لەناوبردن، 
\q2 بە تۆقاندن ساڵانیان. 
\q1  
\v 34 هەر کاتێک لێیان بکوژێت بەدوای دەکەون، 
\q2 بە پەرۆشەوە دەگەڕێنەوە لای. 
\q1  
\v 35 بەبیریان دێتەوە کە خودا تاشەبەردیانە، 
\q2 خودای هەرەبەرزیشە کە دەیانکڕێتەوە\f + \fr 78:35 \ft عیبری: بە واتای خوێنگر دێت، بۆ تێگەیشتن لەم دەربڕینە بڕوانە \xt ڕائووس 4‏\ft ‏.‏\f*. 
\q1  
\v 36 بەڵام بە دەم فێڵ دەکەن، 
\q2 بە زمان درۆی لەگەڵ دەکەن. 
\q1  
\v 37 دڵیان لەلای ناچەسپێت، 
\q2 دڵسۆز نین لەگەڵ پەیمانەکەی. 
\q1  
\v 38 ئەویش بەزەییداره و 
\q2 لە گوناه خۆشدەبێت و نافەوتێنێت. 
\q1 زۆر جار تووڕەیی خۆی دەگێڕێتەوە، 
\q2 هەموو هەڵچوونی خۆی دەرنابڕێت. 
\q1  
\v 39 بەبیری دێتەوە ئەمانە مرۆڤن، 
\q2 بایەکن هەڵدەکەن و ناگەڕێنەوە. 
\b  
\q1  
\v 40 چەند جار لە چۆڵەوانی لێی یاخیبوون، 
\q2 لە بیابان دڵتەنگیان کرد. 
\q1  
\v 41 جار لەدوای جار خودایان تاقی کردەوە، 
\q2 خودا پیرۆزەکەی ئیسرائیلیان تووڕە کرد. 
\q1  
\v 42 دەستی ئەویان لەبیرچوو، 
\q2 ئەو ڕۆژەی ئەوانی لە دوژمن کڕییەوە. 
\q1  
\v 43 ئەو ڕۆژەی لە میسر نیشانەی پیشاندا، 
\q2 لە وڵاتی چۆعەن پەرجووی کرد. 
\q1  
\v 44 ڕووبار و جۆگەکانیانی گۆڕی بۆ خوێن، 
\q2 بۆ ئەوەی نەخۆنەوە. 
\q1  
\v 45 مێشومەگەزی نارد پێوەیان دان، 
\q2 بۆقی نارد بۆگەنیان کردن. 
\q1  
\v 46 بەروبوومی ئەوانی دا بە سن، 
\q2 بەری ماندووبوونیان بە کوللە. 
\q1  
\v 47 بە تەرزە ڕەزەمێوەکانی کوتان و 
\q2 بە زوقم دار هەنجیرەکانی وشککردن. 
\q1  
\v 48 گاوگۆتاڵی ئەوانی خستنە بەر تەرزە و 
\q2 ئاژەڵی ماڵی دانە بەر بروسکە. 
\q1  
\v 49 گڕی هەڵچوونی خۆی ڕژاندە سەریان، تووڕەیی و تۆڵە و بەڵا، 
\q2 بە فریشتەی لەناوبەر ناردی. 
\q1  
\v 50 ڕێگای بۆ تووڕەیی خۆی خۆشکرد، 
\q2 مردنی لێ نەگێڕانەوە، 
\q2 ژیانیانی تووشی دەرد کرد. 
\q1  
\v 51 لە هەموو نۆبەرەکانی میسری دا، 
\q2 یەکەمین بەرهەمی پیاوەتی وڵاتی حام\f + \fr 78:51 \ft مەبەست وڵاتی میسرە.‏\f*. 
\q1  
\v 52 ئینجا وەک مەڕ گەلەکەی بەپێشدا، 
\q2 وەک ڕان لە چۆڵەوانی ڕابەرایەتی کردن. 
\q1  
\v 53 بە ئاسوودەیی ڕێنمایی کردن، ئیتر بێ ترس بوون، 
\q2 بەڵام دەریا دوژمنەکانی داپۆشین. 
\q1  
\v 54 بردنی بۆ سنووری خاکی پیرۆز، 
\q2 ئەو ناوچە شاخاوییەی بە دەستی ڕاستی بەدەستیهێنا. 
\q1  
\v 55 نەتەوەکانی لەبەردەم دەرکردن، 
\q2 میراتی بە گوریس بۆ دابەش کردن، 
\q2 هۆزەکانی ئیسرائیلی لە خێوەتەکانیان نیشتەجێ کرد. 
\b  
\q1  
\v 56 بەڵام خودای هەرەبەرزیان تاقی کردەوە و یاخی بوون، 
\q2 یاساکانی ئەویان پەیڕەو نەکرد. 
\q1  
\v 57 هەڵگەڕانەوە و فێڵبازییان کرد، 
\q2 وەک باپیرانیان لەڕێ لایاندا، وەک کەوانێکی ناڕێک. 
\q1  
\v 58 بە نزرگەکانیان لەسەر بەرزاییەکان پەستیان کرد، 
\q2 بە بتەکانیان ئیرەیی\f + \fr 78:58 \ft ئیرەیی: واتای هەڵوێستی توندی خودا بەرامبەر بە بتپەرستی، چونکە خودا دەیەوێت تەنها ئەو بپەرسترێت.‏\f* ئەویان جۆشاند. 
\q1  
\v 59 خودا ئەمەی بیست، پڕ تووڕەیی بوو، 
\q2 بە تەواوی ئیسرائیلی ڕەتکردەوە. 
\q1  
\v 60 چادری پەرستنی شیلۆی\f + \fr 78:60 \ft شارێک بوو لە باکووری بێت ئێل. یهۆشع ئەو شوێنەی هەڵبژارد بۆ ئەوەی سندوقی پەیمان و چادری چاوپێکەوتنی تێدا دابنێن.‏\f* بەجێهێشت، 
\q2 ئەو چادرەی لەناو مرۆڤ هەڵیدابوو. 
\q1  
\v 61 سندوقی پەیمانی خۆی دایە دەست، 
\q2 هێمای هێز و شکۆی خۆی دایە دەست ناحەزەکانی. 
\q1  
\v 62 گەلی خۆی خستە بەردەمی شمشێر، 
\q2 لە میراتەکەی تووڕە بوو. 
\q1  
\v 63 گەنجەکانیان ئاگر هەڵیلووشین، 
\q2 کچەکانیان هەلهەلەیان لێ نەدا. 
\q1  
\v 64 کاهینەکانیان بە شمشێر کەوتن، 
\q2 بێوەژنەکانیان شیوەنیان نەگێڕا. 
\b  
\q1  
\v 65 ئەوسا پەروەردگار هەستا وەک ئەو کەسەی لە خەو بەئاگا دێتەوە، 
\q2 وەک ئەو پاڵەوانەی لە سەرخۆشی بەهۆش دێتەوە. 
\q1  
\v 66 لە دوژمنەکانی دا بۆ دواوە، 
\q2 کردنی بە ڕیسوایی هەمیشەیی. 
\q1  
\v 67 خێوەتەکانی یوسفی ڕەتکردەوە، 
\q2 هۆزی ئەفرایمی هەڵنەبژارد، 
\q1  
\v 68 بەڵکو هۆزی یەهودای هەڵبژارد، 
\q2 کێوی سییۆن کە خۆشی دەوێت. 
\q1  
\v 69 وەک بەرزاییەکان پیرۆزگای خۆی بنیاد نا، 
\q2 وەک زەوی هەتاهەتایە چەسپاندی. 
\q1  
\v 70 داودی بە خزمەتکاری خۆی هەڵبژارد و 
\q2 لەناو پشتیری مەڕ دەریهێنا. 
\q1  
\v 71 لەدوای مەڕە شیردەرەکانەوە هێنای، 
\q2 بۆ ئەوەی ببێتە شوانی یاقوبی گەلی خۆی، 
\q2 ئیسرائیلی میراتگری خۆی. 
\q1  
\v 72 داودیش بە دڵپاکییەوە شوانایەتی کردن، 
\q2 بە دەستێکی کارامە ئاراستەی کردن. 
\c 79  
\cl زەبووری 79 
\s1 زەبوورێکی ئاساف. 
\q1  
\v 1 ئەی خودایە، نەتەوەکان هاتوونەتە ناو میراتی تۆ، 
\q2 پەرستگای پیرۆزی تۆیان گڵاو کردووە، 
\q2 ئۆرشەلیمیان کردووە بە کەلاوە. 
\q1  
\v 2 تەرمی خزمەتکارەکانی تۆیان 
\q2 کردووە بە خۆراکی باڵندەی ئاسمان و 
\q2 گۆشتی خۆشەویستانت بۆ دڕندەی زەوی. 
\q1  
\v 3 لە دەوروبەری ئۆرشەلیم وەک ئاو خوێنیان ڕشتن، 
\q2 کەس نەبوو بیاننێژێت. 
\q1  
\v 4 بووین بە پەندی دراوسێکانمان، 
\q2 بووین بە سووکایەتی و گاڵتەجاڕی دەوروبەرمان. 
\b  
\q1  
\v 5 ئەی یەزدان هەتا کەی؟ ئایا هەتاسەر هەر تووڕە دەبیت؟ 
\q2 هەتا کەی ئیرەییت وەک ئاگر دەسووتێت؟ 
\q1  
\v 6 تووڕەیی خۆت بەسەر ئەو نەتەوانەدا ببارێنە کە پشت گوێت دەخەن، 
\q2 بەسەر ئەو شانشینانەدا بیڕێژە کە بە ناوی تۆ ناپاڕێنەوە، 
\q1  
\v 7 چونکە ئەوانە یاقوبیان هەڵلووشیوە، 
\q2 نیشتیمانیان خاپوور کردووە. 
\b  
\q1  
\v 8 گوناهی باپیرانی پێش خۆمان لەسەر مەژمێرە، 
\q2 با بەزەییت زوو پێشمان بکەوێت، 
\q2 چونکە ئێمە زۆر زەلیل بووین. 
\q1  
\v 9 ئەی خودای ڕزگارکەرمان، یارمەتیمان بدە، 
\q2 لەبەر شکۆی ناوی خۆت. 
\q1 دەربازمان بکە و لە گوناهمان خۆشبە، 
\q2 لە پێناوی ناوی خۆت. 
\q1  
\v 10 بۆچی نەتەوەکان بڵێن: 
\q2 «کوا خوداکەیان؟» 
\b  
\q1 با هەموو نەتەوەکان بزانن کە تۆ لەبەرچاوی هەموومان 
\q2 تۆڵەی خوێنی ڕژاوی خزمەتکارەکانی خۆت دەکەیتەوە. 
\q1  
\v 11 با ناڵە و هاواری دیلەکانت پێ بگات، 
\q2 بە گەورەیی بازووی خۆت بیانهێڵەوە 
\q2 ئەوانەی سزای مردنیان بەسەردا دراوە. 
\q1  
\v 12 ئەی پەروەردگار، حەوت ئەوەندەی ئەو سووکایەتییەی 
\q2 دراوسێکانمان پێیان کردی، 
\q2 لە باوەشیان سووکایەتییان پێ بکە. 
\q1  
\v 13 ئینجا ئێمەی گەلی تۆ، مەڕی لەوەڕگای تۆ، 
\q2 هەتاهەتایە ستایشت دەکەین، 
\q2 نەوە بە نەوە باسی ستایشی تۆ دەکەین. 
\c 80  
\cl زەبووری 80 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، بە ئاوازی گوڵی سەوسەنی پەیمان. بۆ ئاساف، زەبوورێک. 
\q1  
\v 1 ئەی شوانی ئیسرائیل، گوێ ڕادێرە، 
\q2 ئەی ڕابەری یوسف وەک مێگەل، 
\q1 ئەی ئەوەی لەنێوان کەڕوبەکان لەسەر تەخت دانیشتوویت\f + \fr 80:1 \ft لە سەردەمی پەیمانی کۆن خودا لە شوێنی هەرەپیرۆزی پەرستگا ئامادە دەبوو، بە تایبەت سندوقی پەیمان و نێوان کەڕوبەکان وەک تەختی خودا بوون.‏\f*، بدرەوشێوە 
\q2  
\v 2 لەبەردەم ئەفرایم و بنیامین و مەنەشە. 
\q1 پاڵەوانیێتی خۆت دەربخە، 
\q2 بۆ ڕزگاریی ئێمە وەرە. 
\b  
\q1  
\v 3 ئەی خودایە، بمانگەڕێنەوە، 
\q2 ڕووی خۆتمان بۆ بدرەوشێنەوە 
\q2 بۆ ئەوەی ڕزگارمان بێت. 
\b  
\q1  
\v 4 ئەی یەزدان، خودای سوپاسالار، 
\q2 هەتا کەی لەسەر نوێژی گەلەکەت تووڕە دەبیت؟ 
\q1  
\v 5 تۆ نانی فرمێسکت دەرخوارد داون، 
\q2 فرمێسکت پڕ بە پێوانە پێ نۆشیون. 
\q1  
\v 6 دەمانکەیتە مایەی ناکۆکی لەلای دراوسێکانمان، 
\q2 ناحەزانمان لەناو خۆیان پێمان پێدەکەنن. 
\b  
\q1  
\v 7 ئەی خودای سوپاسالار، بمانگەڕێنەوە، 
\q2 ڕووی خۆتمان بۆ بدرەوشێنەوە 
\q2 بۆ ئەوەی ڕزگارمان بێت. 
\b  
\q1  
\v 8 دار مێوێکت لە میسرەوە گواستەوە، 
\q2 نەتەوەکانت وەدەرنا و چاندت. 
\q1  
\v 9 خاکت بۆ ئامادە کرد، 
\q2 ڕەگ و ڕیشەیت داکوتا، زەوی پڕکرد. 
\q1  
\v 10 سێبەرەکەی چیاکانی داپۆشی، 
\q2 چڵەکانی ئورزە گەورەکان. 
\q1  
\v 11 لقی هەتا دەریا\f + \fr 80:11 \ft دەریای سپی ناوەڕاست.‏\f* هاویشت، 
\q2 پۆپکەکانی بۆ دەم ڕووبار\f + \fr 80:11 \ft مەبەستی ڕووباری فوراتە.‏\f*. 
\b  
\q1  
\v 12 بۆچی شووراکانیت ڕووخاند 
\q2 تاکو هەر ڕێبوارێک لێی بکاتەوە؟ 
\q1  
\v 13 بەرازی دارستان وێرانی دەکات، 
\q2 زیندەوەرەکانی کێڵگە لەسەری دەلەوەڕێن. 
\q1  
\v 14 ئەی خودای سوپاسالار بمانگەڕێنەوە! 
\q2 لە ئاسمانەوە سەیر بکە و ببینە! 
\q2 ئەم دار مێوە بەسەربکەوە، 
\q1  
\v 15 ئەو قەدەی دەستی ڕاستت چاندوویەتی، 
\q2 ئەو کوڕەی بۆ خۆت بەهێزت کردووە. 
\b  
\q1  
\v 16 سووتاوە و بە ئاگر بڕاوەتەوە، 
\q2 بە سەرزەنشتی ڕووی تۆ گەلەکەت لەناودەچێت. 
\q1  
\v 17 با دەستت لەسەر مرۆڤی دەستە ڕاستت بێت، 
\q2 لەسەر ئەو کوڕەی مرۆڤ بۆ خۆت بەهێزت کردووە. 
\q1  
\v 18 ئینجا لێت هەڵناگەڕێینەوە، 
\q2 بمانژیێنەوە و بە ناوی تۆوە نزا دەکەین. 
\b  
\q1  
\v 19 ئەی یەزدان، خودای سوپاسالار، بمانگەڕێنەوە! 
\q2 ڕووی خۆتمان بۆ بدرەوشێنەوە 
\q2 بۆ ئەوەی ڕزگارمان بێت. 
\c 81  
\cl زەبووری 81 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، لەسەر ئاوازی گتیت\f + \fr 81:0 \ft دەستەواژەیەکی بواری مۆسیقایە.‏\f*. بۆ ئاساف. 
\q1  
\v 1 هەلهەلە لێدەن بۆ خودا ئەوەی هێزمانە، 
\q2 بە خۆشییەوە هاوار بکەن بۆ خودای یاقوب. 
\q1  
\v 2 ئاوازێک بەرز بکەنەوە و دەف بهێنن، 
\q2 سازێکی ناسک لەگەڵ قیسارە. 
\b  
\q1  
\v 3 لە جەژنی سەرەمانگ کەڕەنا لێدەن و 
\q2 لە مانگی تابان، بۆ ڕۆژی جەژنەکانمان، 
\q1  
\v 4 چونکە ئەمە فەرزە لەسەر ئیسرائیل، 
\q2 حوکمی خودای یاقوبە. 
\q1  
\v 5 لە بنەماڵەی یوسفدا کردی بە یاسا، 
\q2 کە لە خاکی میسر دەریهێنا. 
\b  
\q1 گوێمان لە دەنگێک بوو بە زمانێک کە لێی تێنەگەیشتین: 
\b  
\q1  
\v 6 «بارم لەسەر شانەکانی لادا، 
\q2 دەستەکانی لە سەبەتە بەربوون. 
\q1  
\v 7 لە تەنگانەدا هاوارت کرد، دەربازم کردیت، 
\q2 لەژێر سێبەری هەورەتریشقە وەڵامم دایتەوە، 
\q2 لە مێرگی مەریبا\f + \fr 81:7 \ft کانییەکە نزیک ڕفیدیم لە بەردێکەوە هەڵقوڵا، کاتێک موسا بە فەرمانی خودا لە بەردەکەی دا.‏\f* تاقیم کردیتەوە.\f + \fr 81:7 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 8 ئەی گەلی من، گوێ بگرە، ئاگادارت دەکەمەوە. 
\q2 ئەی ئیسرائیل، خۆزگە گوێت لە من دەگرت! 
\q1  
\v 9 لەنێو ئێوەدا خوداوەندێکی بێگانە نابێت، 
\q2 کڕنۆش بۆ خوداوەندێکی بیانی نابەیت. 
\q1  
\v 10 من یەزدانی پەروەردگاری تۆم، 
\q2 کە لە خاکی میسر دەرمهێنای، 
\q2 دەمت بکەوە و پڕی دەکەم. 
\b  
\q1  
\v 11 «بەڵام گەلەکەم گوێی لە قسەم نەگرت، 
\q2 ئیسرائیل منی نەویست. 
\q1  
\v 12 منیش ئەوانم دایە دەست کەللەڕەقییەکەی خۆیان، 
\q2 بە ڕاوێژی خۆیان هەڵسوکەوت بکەن. 
\b  
\q1  
\v 13 «خۆزگە گەلەکەم بە قسەی منیان دەکرد، 
\q2 ئەگەر ئیسرائیل ڕێگای منیان دەگرتەبەر، 
\q1  
\v 14 هەر زوو دوژمنەکانم بۆ زەلیل دەکردن، 
\q2 دەستم درێژ دەکردە سەر ناحەزانیان! 
\q1  
\v 15 ئەوانەی ڕقیان لە یەزدانە، ملکەچی دەبن، 
\q2 هەتاهەتایە کاتی سزایان دەبێت. 
\q1  
\v 16 باشترین گەنمم دەرخوارد دەدایت، 
\q2 لە تاشەبەردەوە تێر هەنگوینم دەکردیت.» 
\c 82  
\cl زەبووری 82 
\d زەبوورێکی ئاساف. 
\q1  
\v 1 خودا لە کۆڕی خوداوەندەکان ڕاوەستاوە، 
\q2 لەنێو خوداوەندەکان\f + \fr 82:1 \ft ڕەنگە مەبەست لە بوونەوەرە ئاسمانییەکان (فریشتەکان) بێت، یان ئەوانەی پەیام و فەرمانەکانی خودایان بۆ دێت و جێبەجێی دەکەن. بڕوانە 82‏:6و بەراوردی بکە لەگەڵ \xt یۆحەنا 10‏:34‏-36.‏\ft ‏\f* دادوەری دەکات. 
\b  
\q1  
\v 2 «هەتا کەی بە ناڕەوایی دادوەری دەکەن، 
\q2 لایەنگری بەدکاران دەکەن؟\f + \fr 82:2 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 3 بەرگری لە لاواز و هەتیوان بکەن، 
\q2 دادی هەژار و کڵۆڵان بدەن. 
\q1  
\v 4 فریای لاواز و نەداران بکەون، 
\q2 لە دەست بەدکاران دەربازیان بکەن. 
\b  
\q1  
\v 5 «نازانن و تێناگەن، لە تاریکیدا دەڕۆن، 
\q2 هەموو بنچینەکانی زەوی دەشڵەژێن. 
\b  
\q1  
\v 6 «من گوتم: ”ئێوە ’خوداوەندەکان‘ن، 
\q2 هەمووتان کوڕی خودای هەرەبەرزن.“ 
\q1  
\v 7 بەڵام وەک ئادەمیزاد دەمرن، 
\q2 وەک یەکێک لە میرەکان دەکەون.» 
\b  
\q1  
\v 8 خودایە، هەستە! دادوەری زەوی بکە، 
\q2 چونکە هەموو نەتەوەکان میراتی تۆن. 
\c 83  
\cl زەبووری 83 
\d گۆرانییەک، زەبوورێکی ئاساف. 
\q1  
\v 1 ئەی خودایە، بێدەنگ مەبە، 
\q2 کپ مەبە، خودایە، هێدی مەبە. 
\q1  
\v 2 ئەوەتا دوژمنانت هەرایانە، 
\q2 ناحەزانت لە دژت ڕاپەڕیون. 
\q1  
\v 3 ڕاوێژ دەکەن لە دژی گەلەکەت، 
\q2 پیلان دەگێڕن لە دژی ئەوانەی تۆ پەنات داون. 
\q1  
\v 4 دەڵێن: «با لەناو نەتەوەکان بیانسڕینەوە، 
\q2 لەمەودوا ناوی ئیسرائیل باس نەکرێت.» 
\b  
\q1  
\v 5 بە هاوبیری پێکەوە پیلان دەگێڕن، 
\q2 لە دژی تۆ پەیمانیان بەستووە. 
\q1  
\v 6 خێوەتەکانی ئەدۆم و ئیسماعیلییەکان\f + \fr 83:6 \ft نەوەی ئیسماعیلی کوڕی ئیبراهیمن لە هاجەری کەنیزەکەی. بە ژیانی کۆچەری و چادرنشینی بەناوبانگ بوونە، هەروەها لە بەکارهێنانی تیروکەوان.‏\f*، 
\q2 مۆئاب و هاجەرییەکان، 
\q1  
\v 7 جوبەیل\f + \fr 83:7 \ft شاری جوبەیل شارێکی کۆنە کە مێژووەکەی دەگەڕێتەوە بۆ 7000 لەمەوپێش، ئەمرۆ بە دووری 38 کیلۆمەتر دەکەوێتە باکووری بەیروت.‏\f* و عەمۆن و عەمالێق\f + \fr 83:7 \ft مەبەست لە جبیل بەشی باکوورە لە چیاکانی ئەدۆم، عەمونیش ناوی گەلێکە لە ناوچەیەکی شاخاوی لە ڕۆژهەڵاتی ڕووباری ئوردون نیشتەجێ بوون، عەمالێقیش بە کۆنترین دانیشتووانی باشووری سوریا دادەنرێن، نەوەی ئەلیفازی کوڕی عیسۆ کوڕی ئیسحاقن.‏\f*، 
\q2 فەلەستیە لەگەڵ دانیشتووی سور. 
\q1  
\v 8 هەروەها ئاشوریش\f + \fr 83:8 \ft مەبەست لە ئاشورییەکانە کە لە ناوچەی میسۆپۆتامیا ژیاون و ئیمپراتۆریەتێکی بەهێزیان هەبووە. نەوەی دووەم کوڕی شێمی کوڕی نوحن. بڕوانە \xt پەیدابوون 10‏:22‏\ft ‏.‏\f* چووەتە پاڵیان، 
\q2 بوونە بازووی بەهێزی نەوەی لوت\f + \fr 83:8 \ft مەبەست لوتی برازای ئیبراهیمە.‏\f*.\f + \fr 83:8 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 9 هەروەک چیت لە میدیان\f + \fr 83:9 \ft شارێکی کۆنە دەکەوتە چۆڵەوانی یەهوداوە.‏\f* کرد ئاوایان لێ بکە، 
\q2 هەروەک چیت لە سیسرا\f + \fr 83:9 \ft سیسرا سەرکردەی سوپاکەی یابینی پاشای کەنعانییەکان بوو لە خاچۆر. بۆ زانیاری زیاتر بڕوانە ڕابەران بەشەکانی 4، 5.‏\f* و یاڤین\f + \fr 83:9 \ft پاشای کەنعانییەکان بوو لە خاچۆر. بۆ زانیاری زیاتر بڕوانە ڕابەران بەشی 4.‏\f* کرد لە ڕووباری قیشۆن\f + \fr 83:9 \ft قیشۆن، ڕووبارێکە بە دەشتی ئیبن عامر دەڕوات لە فەلەستین.‏\f*، 
\q1  
\v 10 کە لە کانی دۆر\f + \fr 83:10 \ft شارێکە دەکەوێتە دووری نۆ کیلۆمەتر لە باشووری ڕۆژهەڵاتی ناسیرە، هەتا ئێستاش ئەمە ناویەتی.‏\f* فەوتان، 
\q2 بوون بە زبڵ بۆ زەوی. 
\q1  
\v 11 گەورەکانیان وەک عۆرێڤ و زئێڤ\f + \fr 83:11 \ft عۆرێب و زئێب، ناوی دوو سەرکردەی میدیانییەکانن بە دەستی ئەفرایمییەکان کوژران، دوای ئەوەی لەبەر گدعۆن هەڵاتن. بڕوانە \xt ڕابەران 7‏:25‏\ft ‏.‏\f* لێ بکە، 
\q2 هەموو میرەکانیان وەک زەڤەح و زەلموناع\f + \fr 83:11 \ft زەڤەح و زەلموناع، دوو پاشای میدیانییەکان بوون گدعۆن کوشتنی. بڕوانە \xt ڕابەران 8‏:5‏\ft ‏.‏\f*، 
\q1  
\v 12 ئەوانەی گوتیان: «لەوەڕگاکانی خودا 
\q2 دەکەینە موڵکی خۆمان.» 
\b  
\q1  
\v 13 ئەی خودای من، بیانکە بە تەپوتۆز، 
\q2 وەک کای دەم بایان لێ بکە. 
\q1  
\v 14 وەک چۆن ئاگر دارستان دەسووتێنێت، 
\q2 وەک گڕ چیا دەسووتێنێت، 
\q1  
\v 15 ئاوا بە ڕەشەبای خۆت ڕاویان بنێ، 
\q2 بە گەردەلوولی خۆت هوڕیان بکە. 
\q1  
\v 16 ئەی یەزدان، ڕوویان بە شەرمەزاریی داپۆشە، 
\q2 تاکو بەدوای ناوتدا بگەڕێن. 
\b  
\q1  
\v 17 هەتاهەتایە شەرمەزار و پەرێشانن، 
\q2 ڕیسوا دەبن و دەفەوتێن. 
\q1  
\v 18 با بزانن کە تۆ، ئەوەی ناوت یەزدانە، 
\q2 لەسەر هەموو زەوی تەنها تۆ هەرەبەرزیت! 
\c 84  
\cl زەبووری 84 
\d بۆ گەورەی گۆرانیبێژان، لەسەر ئاوازی گتیت\f + \fr 84:0 \ft دەستەواژەیەکی بواری مۆسیقایە.‏\f*، زەبوورێکی کوڕانی قۆرەح. 
\q1  
\v 1 ئەی یەزدانی سوپاسالار، 
\q2 ماڵەکەت چەند خۆشە! 
\q1  
\v 2 گیانم شەیدایە، تەنانەت تامەزرۆی چوونە ناو حەوشەی ماڵی یەزدانە. 
\q2 لەش و دڵم هەلهەلە لێدەدەن بۆ خودای زیندوو. 
\q1  
\v 3 تەنانەت پاساریش ماڵی دەست دەکەوێت و 
\q2 پەڕەسێلکەش هێلانە، بۆ ئەوەی بێچووەکانی تێدا دابنێت، 
\q1 لە نزیک قوربانگای تۆ، 
\q2 ئەی یەزدانی سوپاسالار، پاشا و خودام. 
\q1  
\v 4 خۆزگە بەوانە دەخوازرێ کە لە ماڵی تۆدا نیشتەجێن، 
\q2 هەمیشە ستایشی تۆ دەکەن.\f + \fr 84:4 \ft لە دەقی عیبری لێرە و لە ئایەتی 8، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 5 خۆزگە بەوانە دەخوازرێ کە هێزیان لە تۆوەیە، 
\q2 ڕێگاکانت لەناو دڵیاندایە\f + \fr 84:5 \ft ئەو ڕێگایانەی کە بەرەو سییۆنە و لە دڵەوە پەرۆشین.‏\f*، 
\q1  
\v 6 کە بە دۆڵی فرمێسک\f + \fr 84:6 \ft عیبری: \+tl دۆڵی باخا‏\+tl*.‏\f* تێدەپەڕن، 
\q2 دەیکەنە کانیاو، 
\q2 پاییزە بارانیش پڕ بەرەکەتی دەکات. 
\q1  
\v 7 لە هێزێکەوە دەچنە هێزێکی دیکە، 
\q2 هەتا هەریەک لەبەردەم خودا لە سییۆن دەربکەوێت. 
\b  
\q1  
\v 8 ئەی یەزدان، خودای سوپاسالار، گوێت لە نوێژم بێت، 
\q2 خودای یاقوب، گوێ شل بکە. 
\q1  
\v 9 ئەی خودایە، بڕوانە قەڵغانەکەمان، 
\q2 سەیری ڕوخساری دەستنیشانکراوەکەت\f + \fr 84:9 \ft بە زمانی عیبری پێی دەگوترێ \+tl مەشیخ‏\+tl* یان \+tl مەشیح‏\+tl*.‏\f* بکە. 
\b  
\q1  
\v 10 یەک ڕۆژ لە حەوشەی ماڵی تۆ 
\q2 لە هەزار ڕۆژ لە شوێنێکی دیکە باشترە. 
\q1 ڕاوەستان لە بەردەرگای ماڵی خودای خۆمم هەڵبژارد، 
\q2 نەک نیشتەجێی نێو ڕەشماڵی بەدکاران، 
\q1  
\v 11 لەبەر ئەوەی یەزدانی پەروەردگار خۆر و قەڵغانە، 
\q2 یەزدان میهرەبانی و شکۆ دەبەخشێت، 
\q2 ڕێ لە چاکە ناگرێت بۆ ئەوانەی ڕێگایان تەواوە. 
\b  
\q1  
\v 12 ئەی یەزدانی سوپاسالار، 
\q2 خۆزگە بەوە دەخوازرێ کە پشت بە تۆ دەبەستێت. 
\c 85  
\cl زەبووری 85 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، زەبوورێکی کوڕانی قۆرەح. 
\q1  
\v 1 ئەی یەزدان، تۆ لە زەوی خۆت ڕازیت، 
\q2 دیلەکانی یاقوبت گێڕاوەتەوە. 
\q1  
\v 2 لە تاوانەکانی گەلەکەت خۆشبوویت، 
\q2 هەموو گوناهەکانیت داپۆشیوە.\f + \fr 85:2 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 3 هەموو تووڕەیی خۆتت گرتەوە، 
\q2 لە جۆشانی تووڕەییت گەڕایتەوە. 
\b  
\q1  
\v 4 ئەی خودای ڕزگاریمان، بمانگەڕێنەوە، 
\q2 تووڕەیی خۆتمان لەسەر لابدە. 
\q1  
\v 5 ئایا هەتاهەتایە لێمان تووڕە دەبیت؟ 
\q2 نەوە دوای نەوە درێژە بە تووڕەییت دەدەیت؟ 
\q1  
\v 6 ئایا تۆ ناگەڕێیتەوە هەتا زیندوومان بکەیتەوە، 
\q2 بۆ ئەوەی گەلەکەت پێت شاد بێت؟ 
\q1  
\v 7 ئەی یەزدان، خۆشەویستییە نەگۆڕەکەتمان پیشان بدە، 
\q2 ڕزگاریی خۆتمان پێ ببەخشە. 
\b  
\q1  
\v 8 ئەوەی خودای پەروەردگار دەیڵێت، گوێی لێ دەگرم، 
\q2 چونکە بەڵێنی ئاشتی دەدات بە گەلەکەی و بە خۆشەویستانی، 
\q2 بەڵام با نەگەڕێنەوە سەر گێلایەتی. 
\q1  
\v 9 بێگومان ڕزگارییەکەی لەو کەسانە نزیکە کە لێی دەترسن، 
\q2 بۆ ئەوەی شکۆمەندییەکەی لە خاکی ئێمەدا نیشتەجێ بێت. 
\b  
\q1  
\v 10 خۆشەویستی نەگۆڕ و ڕاستی بە یەک گەیشتوون، 
\q2 ڕاستودروستی و ئاشتی یەکتری ماچ دەکەن\f + \fr 85:10 \ft تایبەتمەندی دیاری خودا، پاشایەتی خودا لەسەر زەوی و دڵی مرۆڤ دادەمەزرێت.‏\f*. 
\q1  
\v 11 ڕاستی لە زەوییەوە دەڕوێت و 
\q2 ڕاستودروستی لە ئاسمانەوە سەر دەردێنێت. 
\q1  
\v 12 هەروەها یەزدان چاکە دەبەخشێت و 
\q2 زەوی ئێمەش دەغڵودان دەدات. 
\q1  
\v 13 ڕاستودروستی لەپێشی دەڕوات، 
\q2 ڕێگای بۆ خۆش دەکات. 
\c 86  
\cl زەبووری 86 
\d نوێژێکی داود. 
\q1  
\v 1 ئەی یەزدان، گوێ ڕادێرە و بەدەنگمەوە وەرە، 
\q2 من هەژار و نەدارم. 
\q1  
\v 2 ژیانم بپارێزە، چونکە من خۆشەویستی تۆم، 
\q2 تۆ خودای منیت، خزمەتکارەکەی خۆت ڕزگار بکە، 
\q2 ئەوەی پشتی پێت بەستووە. 
\q1  
\v 3 ئەی پەروەردگار، لەگەڵم میهرەبان بە، 
\q2 بە درێژایی ڕۆژ هاوار بۆ تۆ دەکەم. 
\q1  
\v 4 گیانی خزمەتکاری خۆت شاد بکە، 
\q2 ئەی پەروەردگار، چونکە گیانی خۆم بۆ تۆ بەرز دەکەمەوە. 
\b  
\q1  
\v 5 ئەی پەروەردگار، تۆ چاک و لێبوردەیت، 
\q2 پڕیت لە خۆشەویستی نەگۆڕ بۆ ئەوانەی هاوارت بۆ دەهێنن. 
\q1  
\v 6 ئەی یەزدان، گوێ لە نوێژم بگرە، 
\q2 گوێ لە پاڕانەوەم بگرە. 
\q1  
\v 7 لە ڕۆژی تەنگانەدا هاوار بۆ تۆ دەهێنم، 
\q2 چونکە بە هاوارمەوە دێیت. 
\b  
\q1  
\v 8 ئەی پەروەردگار، کوا هاوشێوەی تۆ لەنێو خوداوەندەکان؟ 
\q2 کوا هاوشێوەی کردەوەکانت؟ 
\q1  
\v 9 ئەی پەروەردگار، هەموو ئەو نەتەوانەی دروستت کردوون، 
\q2 دێن و لەبەردەم تۆدا کڕنۆش دەبەن و 
\q2 ناوت شکۆدار دەکەن، 
\q1  
\v 10 چونکە تۆ مەزنیت و کاری سەرسوڕهێنەری گەورەت کردووە، 
\q2 هەر تەنها تۆ خودایت. 
\b  
\q1  
\v 11 ئەی یەزدان، ڕێگای خۆتم فێر بکە، 
\q2 بۆ ئەوەی بە ڕاستی تۆ بڕۆم، 
\q2 دڵم یەکبخە بۆ ترسی ناوەکەت. 
\q1  
\v 12 ئەی خودای پەروەردگارم، بە هەموو دڵەوە ستایشت دەکەم، 
\q2 هەتاهەتایە ناوت شکۆدار دەکەم، 
\q1  
\v 13 چونکە خۆشەویستییە نەگۆڕەکەت گەورەیە بۆ من، 
\q2 گیانی منت لە جیهانی مردووانی ژێرەوە دەرباز کرد. 
\b  
\q1  
\v 14 ئەی خودایە، لووتبەرزەکان لێم هەستاون، 
\q2 تاقمە زۆردارەکان دەیانەوێت لەناوم ببەن، 
\q2 تۆ لەبەرچاو ناگرن. 
\q1  
\v 15 بەڵام ئەی پەروەردگار، تۆ خودایەکی میهرەبان و بەزەییداریت، 
\q2 پشوودرێژیت و پڕیت لە خۆشەویستی نەگۆڕ و دڵسۆزیی. 
\q1  
\v 16 ئاوڕم لێ بدەوە و لەگەڵم میهرەبان بە، 
\q2 هێزی خۆت بە خزمەتکارەکەت ببەخشە و 
\q2 کوڕی کارەکەرەکەت ڕزگار بکە. 
\q1  
\v 17 نیشانەی چاکەی خۆتم لەگەڵ بکە، 
\q2 بۆ ئەوەی ناحەزانم ببینن و شەرمەزار بن، 
\q2 ئەی یەزدان، چونکە تۆ یارمەتیت داوم و دڵنەواییت کردووم. 
\c 87  
\cl زەبووری 87 
\d زەبوورێکی کوڕانی قۆرەح. گۆرانییەک. 
\q1  
\v 1 خودا لە کێوی پیرۆز بناغەکانی شارەکەی دانا، 
\q2  
\v 2 یەزدان دەروازەکانی سییۆنی 
\q2 لە هەموو ماڵی یاقوب خۆشتر دەوێت. 
\b  
\q1  
\v 3 ئەی شاری خودا، 
\q2 بە شکۆمەندی باست کراوە:\f + \fr 87:3 \ft لە دەقی عیبری لێرە و لە ئایەتی 6، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 4 «ئەوانەی دەمناسن ناویان دەهێنمەوە یادم، 
\q2 خەڵکی ڕاهەب\f + \fr 87:4 \ft مەبەست لە ڕاهەب وڵاتی میسرە، هەروەها لە ئەفسانە کۆنەکانی ڕۆژهەڵاتی ناوەڕاست ڕاهەب دڕندەیەکی دەریاییە و هێمای خراپەکاری و سەرلێشێوانە.‏\f* و بابل لەنێویاندان، 
\q1 لەگەڵ فەلەستیە و سور و خەڵکی کوش، 
\q2 سەبارەت بە ئەوان دەگوترێت: ”ئەم کەسە لە سییۆن لەدایک بووە.“» 
\q1  
\v 5 دەربارەی سییۆن دەگوترێ: «ئەمە و ئەوەی تێدا لەدایک بووە و 
\q2 خودای هەرەبەرز خۆی دەیچەسپێنێت.» 
\q1  
\v 6 یەزدان لە پەڕتووکی گەلاندا تۆماری دەکات: 
\q2 «ئەمە لە سییۆن لەدایک بووە.» 
\b  
\q1  
\v 7 سەماکەران گۆرانی دەڵێن: 
\q2 «هەموو سەرچاوەکانم لە تۆوەیە.» 
\c 88  
\cl زەبووری 88 
\d گۆرانییەک. زەبوورێکی کوڕانی قۆرەح. بۆ گەورەی گۆرانیبێژان. بەگوێرەی «ماحەلەت لعەنۆت»\f + \fr 88:0 \ft ماحەلەت لعەنۆت: دەستەواژەیەکی مۆسیقییە، لەوانەیە بە واتای ئازاری ناخۆشی بێت.‏\f*. هۆنراوەیەکی هێیمانی ئەزراحی. 
\q1  
\v 1 ئەی یەزدان، خودای ڕزگاریم، 
\q2 شەو و ڕۆژ بەرامبەر بە تۆ هاوارم کرد. 
\q1  
\v 2 با نوێژەکانم بگاتە بەردەمت، 
\q2 گوێ بۆ هاوارم شل بکە. 
\b  
\q1  
\v 3 گیانم پڕ خراپە بووە و 
\q2 ژیانم لە جیهانی مردووان نزیک بووەتەوە. 
\q1  
\v 4 وەک ئەوانە دانراوم کە دەچنە نێو جیهانی مردووان، 
\q2 وەک پیاوێکم لێهاتووە هێزی لەبەربڕابێت. 
\q1  
\v 5 لەناو مردووان وازلێهێنراو، 
\q2 وەک کوژراوەکانی ناو گۆڕ ڕاکشاو، 
\q1 ئەوانەی ئیتر یادیان ناکەیتەوە، 
\q2 ئەوانەی دەستت لێیان شوشتووە. 
\b  
\q1  
\v 6 لەناو قووڵترین گۆڕ داتناوم، 
\q2 لەناو جەرگەی تاریکی، لە قووڵایی. 
\q1  
\v 7 تووڕەییت قورسە بەسەرمەوە، 
\q2 شەپۆلەکانت ڕامدەماڵن.\f + \fr 88:7 \ft لە دەقی عیبری لێرە و لە ئایەتی 10، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\q1  
\v 8 ناسیاوەکانمت لێ دوورخستمەوە، 
\q2 قێزم لێ دەکەنەوە. 
\q1 گیراوم و دەربازبوونم بۆ نییە، 
\q2  
\v 9 بەهۆی ژێردەستەیی چاوم لە کزبوونە. 
\b  
\q1 ئەی یەزدان، بە درێژایی ڕۆژ هاوار بۆ تۆ دەکەم، 
\q2 دەستم لە تۆ پان دەکەمەوە. 
\q1  
\v 10 ئایا کاری سەرسوڕهێنەر بۆ مردووان دەکەیت؟ 
\q2 یان ڕۆحەکان هەڵدەستنەوە ستایشت بکەن؟ 
\q1  
\v 11 ئایا لەناو گۆڕ باسی خۆشەویستییە نەگۆڕەکەت دەکرێت، 
\q2 یان لە لەناوچوون\f + \fr 88:11 \ft لەناوچوون: عیبری: \+tl ئەبەدۆن‏\+tl*. لە پەیمانی نوێ ئەم وشەیە بە واتای (لەناوبەر) هاتووە، بڕوانە \xt ئاشکراکردن 11‏:9‏\ft ‏.‏\f* باسی دڵسۆزییەکەت؟ 
\q1  
\v 12 ئایا لە تاریکایی کارە سەرسوڕهێنەرەکانت دەناسرێت، 
\q2 یان لە خاکی لەبیرچوون\f + \fr 88:12 \ft شوێنی مردووان، کە چیتر خودا گرنگییان پێ نادات.‏\f* ڕاستودروستیت؟ 
\b  
\q1  
\v 13 ئەی یەزدان، هاوار بۆ تۆ دەهێنم، 
\q2 بەیانییان نوێژم بەرەو ڕووت دێت. 
\q1  
\v 14 ئەی یەزدان، بۆچی گیانم ڕەت دەکەیتەوە، 
\q2 ڕووی خۆتم لێ دەشاریتەوە؟ 
\b  
\q1  
\v 15 من لە منداڵییەوە کڵۆڵم و نزیکە مەرگم، 
\q2 بەرگەی ترسەکانی تۆم گرت و سەرم لێ شێوا. 
\q1  
\v 16 تووڕەیی تۆ بەسەر مندا تێپەڕی، 
\q2 ترسی بەڵاکانی تۆ وێرانی کردم. 
\q1  
\v 17 وەک لافاو بە درێژایی ڕۆژ دەوری داوم، 
\q2 لە هەموو لایەکەوە دەوری گرتووم. 
\q1  
\v 18 دۆست و خۆشەویستەکانت لێ دوورخستمەوە، 
\q2 تاریکی بووە بە نزیکترین هاوڕێم. 
\c 89  
\cl زەبووری 89 
\d هۆنراوەیەکی ئێیتانی ئەزراحی\f + \fr 89:0 \ft بڕوانە \xt یەکەم پاشایان 4‏:31‏\ft ‏\f*. 
\q1  
\v 1 هەتاهەتایە گۆرانی بەسەر خۆشەویستی نەگۆڕی یەزداندا دەڵێم، 
\q2 نەوە دوای نەوە بە دەمم دڵسۆزیت ڕادەگەیەنم. 
\q1  
\v 2 هەروەک گوتم، هەتاهەتایە خۆشەویستی نەگۆڕ بنیاد دەنرێت، 
\q2 لە ئاسمان دڵسۆزیت چەسپاوە. 
\q1  
\v 3 فەرمووت: «پەیمانم لەگەڵ هەڵبژاردەی خۆم بەستووە، 
\q2 سوێندم بۆ داودی بەندەم خواردووە، 
\q1  
\v 4 ”هەتاهەتایە وەچەکەت دەچەسپێنم، 
\q2 نەوە دوای نەوە تەختت بنیاد دەنێم.“»\f + \fr 89:4 \ft لە دەقی عیبری لێرە و لە ئایەتەکانی 37 و 45 و 48، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 5 ئەی یەزدان، ئاسمان ستایشی کارە سەرسوڕهێنەرەکانت دەکات، 
\q2 هەروەها لەناو کۆڕی پیرۆزانیش\f + \fr 89:5 \ft هەندێک لە فریشتەکان لەبەردەم خودا ئامادە دەبن، خودا لە فەرمایشت و فەرمانەکانی دەکرێ ڕاوێژیان پێ بکات و گفتوگۆیان لەگەڵ بکات.‏\f* دڵسۆزیت. 
\q1  
\v 6 لەناو هەورەکان کێ هاوتای یەزدانە؟ 
\q2 لەنێو فریشتەکانی ئاسمان کامەیان لە یەزدان دەچێت؟ 
\q1  
\v 7 خودا لەنێو ئەنجومەنی پیرۆزان زۆر سامناکە، 
\q2 لە هەموو ئەوانەی دەوروبەری ترسناکترە. 
\q1  
\v 8 ئەی یەزدان، خودای سوپاسالار، کێ وەک تۆ وایە؟ 
\q2 تۆ بەهێزیت، ئەی یەزدان، دڵسۆزیشت دەوری داویت. 
\b  
\q1  
\v 9 دەسەڵاتت بەسەر هەڵچوونی دەریادا هەیە، 
\q2 کە شەپۆلەکانی بەرز دەبنەوە، هێمنیان دەکەیتەوە. 
\q1  
\v 10 وەک بریندارێکی سەخت ڕاهەبت\f + \fr 89:10 \ft مەبەست لە دڕندەی دەریایە کە ئاماژە بوو بۆ خراپە.‏\f* پان کردەوە، 
\q2 بە هێزی بازووت دوژمنەکانت پەرتەوازە کرد. 
\q1  
\v 11 ئاسمان هی تۆیە، هەروەها زەویش، 
\q2 گەردوون و هەرچی تێیدایە تۆ داتمەزراندووە. 
\q1  
\v 12 باکوور و باشوور تۆ بەدیت هێناون، 
\q2 تابۆر\f + \fr 89:12 \ft کێوێکە لە ناوچەی جەلیل ئێستا پێی دەگوترێت ئەلگور.‏\f* و حەرمۆن بۆ ناوی تۆ هەلهەلە لێدەدەن. 
\q1  
\v 13 بازووت هەیە لەگەڵ توانا، 
\q2 دەستت بەهێزە، دەستی ڕاستت بەرزە. 
\b  
\q1  
\v 14 ڕاستودروستی و دادپەروەری بناغەی تەختی تۆن، 
\q2 خۆشەویستی نەگۆڕ و ڕاستی\f + \fr 89:14 \ft بڕوانە \xt یۆحەنا 1‏:17‏\ft ‏.‏\f* لەبەردەمی تۆ دەڕۆن. 
\q1  
\v 15 خۆزگە بەو گەلە دەخوازرێ کە دەزانن چۆن پڕ بە دەنگیان هاواری شادی بکەن، 
\q2 ئەی یەزدان، بە ڕووناکی ڕوخساری تۆ ڕێ دەکەن. 
\q1  
\v 16 بەهۆی ناوی تۆوە بە درێژایی ڕۆژ شادمان دەبن، 
\q2 بە ڕاستودروستی تۆ بەرز دەبنەوە، 
\q1  
\v 17 چونکە تۆ شکۆمەندی و هێزی ئەوانیت، 
\q2 ئێمە بە ڕەزامەندی تۆ بەهێز دەبین. 
\q1  
\v 18 بێگومان قەڵغانمان هی یەزدانە، 
\q2 پاشامان هی خودا پیرۆزەکەی ئیسرائیلە. 
\b  
\q1  
\v 19 جارێکیان لە بینینێکدا\f + \fr 89:19 \ft بینین. خودا لە ڕێی پیشاندانی دیمەنێکەوە پەیامێک دەگەیەنێتە ئەو مرۆڤەی بییەوێت.‏\f* قسەت کرد، 
\q2 بە خۆشەویستانی خۆتت فەرموو: 
\q1 «هێزم بە پاڵەوانێک بەخشی، 
\q2 لەنێو گەل گەنجێکم بەرزکردەوە. 
\q1  
\v 20 داودی بەندەی خۆمم دۆزییەوە، 
\q2 بە ڕۆنی پیرۆزم دەستنیشانم کرد\f + \fr 89:20 \ft دەستنیشانکردنی کەسێک بۆ ئەرکێکی ئایینی یان پاشایەتی ئەو کاتە بە چەورکردنی بووە بە ڕۆن.‏\f*. 
\q1  
\v 21 ئەوەی دەستم پێوەی دەچەسپێت، 
\q2 هەروەها بازووم بەهێزی دەکات. 
\q1  
\v 22 دوژمن بەسەریدا زاڵ نابێت، 
\q2 نابێتە ژێر دەستەی کوڕی زۆردار. 
\q1  
\v 23 لەبەردەمی خۆی دوژمنانی تێکدەشکێنم، 
\q2 ناحەزانی تووشی بەڵا دەکەم. 
\q1  
\v 24 دڵسۆزی و خۆشەویستی نەگۆڕی منی لەگەڵدایە، 
\q2 بە ناوی منەوە بەهێز دەبێت. 
\q1  
\v 25 وا دەکەم دەستی بەسەر دەریاوە بێت، 
\q2 دەستی ڕاستی بەسەر ڕووبارەکان. 
\q1  
\v 26 هاوارم بۆ دەکات: ”تۆ باوکمی، 
\q2 خودای منی، تاشەبەردی ڕزگاریی منیت.“ 
\q1  
\v 27 منیش دەیکەمە نۆبەرەی خۆم، 
\q2 بەرزترین لە پاشایانی زەوی. 
\q1  
\v 28 هەتاهەتایە خۆشەویستی نەگۆڕی خۆمی بۆ دەپارێزم، 
\q2 پەیمانی من بۆ ئەو دەچەسپێت. 
\q1  
\v 29 هەتاهەتایە وەچەکەی دەچەسپێنم، 
\q2 تەختیشی بەقەد ڕۆژگاری ئاسمان بێت. 
\b  
\q1  
\v 30 «ئەگەر کوڕانی واز لە فێرکردنم بهێنن، 
\q2 ڕێگای یاساکانی من نەگرنەبەر، 
\q1  
\v 31 ئەگەر سەرپێچی فەرزەکانم بکەن، 
\q2 ڕاسپاردەکانم بەجێنەگەیەنن، 
\q1  
\v 32 لەسەر یاخیبوونەکانیان بە دار سزایان دەدەم، 
\q2 بە لێدان گوناهەکانیان، 
\q1  
\v 33 بەڵام خۆشەویستی نەگۆڕی خۆمی لێ ناکەمەوە، 
\q2 درۆ ناکەم دەربارەی دڵسۆزییەکەم. 
\q1  
\v 34 پەیمانی خۆم ناشکێنم و 
\q2 قسەی خۆم ناگۆڕم. 
\q1  
\v 35 جارێک سوێندم بە پیرۆزی خۆم خوارد، 
\q2 درۆ لەگەڵ داود ناکەم. 
\q1  
\v 36 هەتاهەتایە نەوەی داود دەمێنێت و 
\q2 تەختی وەک خۆر لەبەردەممە، 
\q1  
\v 37 هەمیشە وەک مانگ دەچەسپێت، 
\q2 ئەو شایەتەی لە ئاسمانیشە دڵسۆزە.» 
\b  
\q1  
\v 38 بەڵام تۆ ڕەتت کردەوە و وازت لێی هێنا، 
\q2 لە دەستنیشانکراوەکەت\f + \fr 89:38 \ft بە زمانی عیبری پێی دەگوترێ \+tl مەشیخ‏\+tl* یان \+tl مەشیح‏\+tl*.‏\f* تووڕەبوویت. 
\q1  
\v 39 پەیمانەکەت لەگەڵ خزمەتکارەکەت شکاند و 
\q2 تاجەکەی ئەوت لە خۆڵ وەردا و گڵاوت کرد. 
\q1  
\v 40 هەموو شووراکانیت ڕووخاند، 
\q2 قەڵاکانیت کردە کاولگە. 
\q1  
\v 41 هەموو ئەوانەی تێدەپەڕن تاڵانیان کرد، 
\q2 لەلای دراوسێکانی\f + \fr 89:41 \ft مەبەستی گەلەکانی دراوسێی ئیسرائیلە.‏\f* ڕیسوا بوو. 
\q1  
\v 42 دەستی ڕاستی دوژمنەکانیت بەرزکردەوە، 
\q2 هەموو ناحەزەکانیت دڵشاد کرد. 
\q1  
\v 43 دەمی شمشێرەکەیت هەڵگێڕایەوە و 
\q2 لە جەنگدا سەرتنەخست. 
\q1  
\v 44 شکۆمەندییەکەیت پووچەڵ کردەوە، 
\q2 تەختی ئەوت فڕێدایە سەر زەوی. 
\q1  
\v 45 ڕۆژگاری گەنجیت کورت کردەوە و 
\q2 بەرگی شەرمەزاریت کردە بەری. 
\b  
\q1  
\v 46 ئەی یەزدان، هەتا کەی؟ ئایا بە تەواوی خۆت دەشاریتەوە؟ 
\q2 هەتا کەی تووڕەییت وەک ئاگر دادەگیرسێت؟ 
\q1  
\v 47 لەبیرت بێت تەمەنم چەند کورتە. 
\q2 ئادەمیزادت بۆ چ مەبەستێکی پووچ بەدیهێناوە؟ 
\q1  
\v 48 ئایا پیاو هەیە بژیێت و مردن نەبینێت؟ 
\q2 یان گیانی خۆی لە دەست جیهانی مردووان دەرباز بکات؟ 
\q1  
\v 49 ئەی پەروەردگار، کوا خۆشەویستییە نەگۆڕەکەی جارانت، 
\q2 کە بە دڵسۆزی خۆت سوێندت بۆ داود خوارد؟ 
\q1  
\v 50 پەروەردگار، شورەیی خزمەتکاری خۆت لەبیر بێت، 
\q2 چۆن هی هەموو گەلانم لە باوەشی خۆم گرتووە، 
\q1  
\v 51 ئەو سووکایەتییەی دوژمنەکانت، ئەی یەزدان، 
\q2 ئەوەی بە ڕاستی بە نەوەکانی دەستنیشانکراوەکەت\f + \fr 89:51 \ft بە زمانی عیبری پێی دەگوترێ \+tl مەشیخ‏\+tl* یان \+tl مەشیح‏\+tl*.‏\f* کرا. 
\b  
\q1  
\v 52 هەر ستایش بۆ یەزدان، هەتاهەتایە. 
\q4 ئامین و ئامین. 
\c 90  
\ms1 کۆکراوەی بەشی چوارەم 
\mr زەبوورەکانی 90‏–106 
\cl زەبووری 90 
\d نوێژێکی موسای پیاوی خودا. 
\q1  
\v 1 ئەی پەروەردگار، نەوە دوای نەوە 
\q2 تۆ پەناگامان بوویت. 
\q1  
\v 2 بەر لەوەی چیاکان پەیدا ببن، 
\q2 یان زەوی و جیهان دروستببن، 
\q2 لە ئەزەلەوە و بۆ هەتاهەتایە، تۆ خودایت. 
\b  
\q1  
\v 3 تۆ مرۆڤ دەکەیتەوە بە تۆز، 
\q2 دەفەرموویت: «ئادەمیزادینە، بگەڕێنەوە بۆ تۆز.» 
\q1  
\v 4 لەلای تۆ، هەزار ساڵ 
\q2 وەک دوێنێ وایە کە تێپەڕیوە، 
\q2 وەک بەشێکی شەو وایە. 
\q1  
\v 5 مرۆڤ وەک خەون ڕادەماڵیت، 
\q2 وەک ئەو گیایەی سەر لە بەیانی نوێ دەبێتەوە، 
\q1  
\v 6 سەر لە بەیانی دەبووژێتەوە و نوێ دەبێتەوە، 
\q2 بۆ ئێوارە سیس دەبێت و دەفەوتێت. 
\b  
\q1  
\v 7 بە هەڵچوونی تۆ لەناوچووین، 
\q2 بە تووڕەیی تۆ تۆقین. 
\q1  
\v 8 گوناهەکانی ئێمەت لەبەردەمی خۆت داناوە، 
\q2 شتە شاراوەکانمان لەبەر ڕووناکی ڕوخسارت. 
\q1  
\v 9 هەموو ڕۆژگارمان بە تووڕەیی تۆ بەسەرچوو، 
\q2 ساڵانی تەمەنمان وەک هەناسەیەک بەسەربرد. 
\q1  
\v 10 ساڵانی تەمەنمان حەفتا ساڵە، 
\q2 یان هەشتا ساڵ ئەگەر بە هێزەوە بێت، 
\q1 ئەوەی مایەی شانازیش بێت ڕەنج و ناخۆشییە، 
\q2 چونکە بە پەلە دەڕەوێتەوە و ئێمە باڵدەگرین. 
\q1  
\v 11 کێ هێزی تووڕەیی تۆ دەزانێت؟ 
\q2 لەبەر ئەوەی تووڕەیی تۆ ترسێکی زۆر دەهێنێ. 
\q1  
\v 12 ئیتر فێرمان بکە ڕۆژانمان بژمێرین، 
\q2 بۆ ئەوەی دڵێکی پڕ داناییمان هەبێت. 
\b  
\q1  
\v 13 ئەی یەزدان، تووڕەییەکەت دابمرکێنەوە! هەتا کەی؟ 
\q2 لەگەڵ خزمەتکارەکانت میهرەبان بە. 
\q1  
\v 14 سەر لە بەیانی لە خۆشەویستییە نەگۆڕەکەت تێرمان بکە، 
\q2 تاکو هەموو ڕۆژانی ژیانمان هەلهەلە لێبدەین و دڵشاد ببین. 
\q1  
\v 15 دڵشادمان بکە ئەوەندەی بۆ ئەو ڕۆژانەی تووشی ناخۆشیت کردین، 
\q2 ئەو ساڵانەی کە خراپەمان بینی. 
\q1  
\v 16 کردەوە مەزنەکانت بۆ خزمەتکارەکانت دەربخە، 
\q2 شکۆمەندیت بەسەر منداڵەکانیان. 
\b  
\q1  
\v 17 با نیعمەتی خودای پەروەردگارمان بەسەرمانەوە بێت، 
\q2 کردەوەکانی دەستمان بۆ بچەسپێنە، 
\q2 بەڵێ، کردەوەکانی دەستمان بچەسپێنە. 
\c 91  
\cl زەبووری 91 
\q1  
\v 1 ئەوەی لە پەناگای هەرەبەرز دادەنیشێت، 
\q2 ئەوەی لە سێبەری خودای هەرە بەتوانا دەمێنێتەوە، 
\q1  
\v 2 بە یەزدان دەڵێ: «تۆ پەناگامی، قەڵامی، 
\q2 خودای منی، پشتت پێ دەبەستم.» 
\b  
\q1  
\v 3 بێگومان لە تۆڕی ڕاوچی دەربازت دەکات، 
\q2 لە دەرد و بەڵای کوشندە. 
\q1  
\v 4 بە باڵی خۆی داتدەپۆشێت، 
\q2 لەژێر باڵەکانی پەنا دەگریت و 
\q2 دڵسۆزییەکەی قەڵغان و شوورایە. 
\q1  
\v 5 نە لە تۆقینی شەو دەترسیت و 
\q2 نە لەو تیرەی بە ڕۆژ دەهاوێژرێت، 
\q1  
\v 6 نە لەو دەردەی کە لە تاریکی دێت، 
\q2 نە لەو ئافاتەی بە ڕۆژی نیوەڕۆ زیان دەبەخشێت. 
\q1  
\v 7 هەزار کەس لەتەنیشتت بەردەبنەوە، 
\q2 دە هەزار لەلای دەستی ڕاستت، 
\q2 بەڵام لە تۆ نزیک ناکەوێتەوە. 
\q1  
\v 8 بەڵکو تەنها بە چاوی خۆت سەیر دەکەیت و 
\q2 سزای بەدکاران دەبینیت. 
\b  
\q1  
\v 9 ئەگەر یەزدانت کرد بە پەناگات، 
\q2 هەرەبەرزت کرد بە لانەی خۆت، 
\q1  
\v 10 هیچ خراپەت بەسەرنایەت و 
\q2 هیچ بەڵایەک لە ماڵت نزیک ناکەوێتەوە. 
\q1  
\v 11 لەبەر ئەوەی سەبارەت بە تۆ فەرمان بە فریشتەکانی دەدات، 
\q2 بۆ ئەوەی لە هەموو هەنگاوێکت بتپارێزن، 
\q1  
\v 12 لەسەر دەستیان هەڵتدەگرن، 
\q2 تاکو پێت بەر بەردێک نەکەوێت. 
\q1  
\v 13 پێ بە شێر و ماری کۆبرادا دەنێیت، 
\q2 بەچکە شێر و ئەژدیها پێشێل دەکەیت. 
\b  
\q1  
\v 14 یەزدان دەفەرموێت: «لەبەر ئەوەی دڵی بە منەوە بەندە، ڕزگاری دەکەم، 
\q2 دەیپارێزم، چونکە من دەناسێت\f + \fr 91:14 \ft عیبری: (ناوی من دەناسێت) بە واتای ناسینی خودا و کەسایەتییەکەی.‏\f*. 
\q1  
\v 15 نزام بۆ دەکات، وەڵامی دەدەمەوە، 
\q2 لە تەنگانە لەگەڵیدام، 
\q2 دەربازی دەکەم و ڕێزداری دەکەم. 
\q1  
\v 16 بە ڕۆژگاری درێژ تێری دەکەم، 
\q2 ڕزگاریی خۆمی نیشان دەدەم.» 
\c 92  
\cl زەبووری 92 
\d زەبوورێک، گۆرانییەک بۆ ڕۆژی شەممە. 
\q1  
\v 1 چاکە ستایشی یەزدان بکرێت، 
\q2 گۆرانی گوتن بۆ ناوت، ئەی هەرەبەرز، 
\q1  
\v 2 بەیانییان خۆشەویستی نەگۆڕت ڕابگەیەنرێت و 
\q2 دڵسۆزیت بە شەوان، 
\q1  
\v 3 بە قیسارەی دە ژێیی، 
\q2 بە ئاوازی ساز. 
\b  
\q1  
\v 4 ئەی یەزدان، بە کردارەکانت دڵخۆشت کردووم، 
\q2 هەلهەلە لێدەدەم بۆ کارەکانی دەستت. 
\q1  
\v 5 ئەی یەزدان، کردارەکانت چەندە مەزنە! 
\q2 بیرکردنەوەی تۆ چەندە قووڵە! 
\q1  
\v 6 مرۆڤی گێل ئەمە نازانێت، 
\q2 نەزانیش ئەمە تێناگات: 
\q1  
\v 7 هەرچەندە خراپەکاران وەک گیا بگەشێنەوە و 
\q2 هەموو بەدکاران چرۆ بکەن، 
\q1 بۆ هەتاهەتایە لەناودەچن. 
\b  
\q1  
\v 8 بەڵام ئەی یەزدان، تۆ هەمیشە بەرزیت. 
\b  
\q1  
\v 9 ئەی یەزدان، دوژمنانت، 
\q2 بێگومان دوژمنانت دەفەوتێن و 
\q2 هەموو بەدکاران پەرتەوازە دەبن. 
\q1  
\v 10 بەڵام وەک گای کێوی بەهێز بووم، 
\q2 بە ڕۆنی گرانبەها چەور کرام. 
\q1  
\v 11 بە چاوی خۆم بەزینی دوژمنانم دەبینم، 
\q2 گوێم لە بەزینی ئەوانە دەبێت کە بە خراپە دژم هەستاون. 
\b  
\q1  
\v 12 ڕاستودروستان وەک دار خورما گەشە دەکەن، 
\q2 وەک ئورزی لوبنان گەشە دەکەن، 
\q1  
\v 13 لە ماڵی یەزدان ڕواون، 
\q2 لە حەوشەی ماڵەکەی خودامان گەشە دەکەن. 
\q1  
\v 14 بە پیریش هەر بەریان دەبێت، 
\q2 هەمیشە تەڕ و سەوزن، 
\q1  
\v 15 بۆ ئەوەی ڕابگەیەنن کە یەزدان ڕاستودروستە، 
\q2 تاشەبەردمە و خراپە لە ئەودا نییە. 
\c 93  
\cl زەبووری 93 
\q1  
\v 1 یەزدان پاشایەتی دەکات، پایەبەرزی لەبەر دەکات، 
\q2 یەزدان هێزی لەبەر دەکات و لە خۆی بەستووە، 
\q2 هەروەها جیهان چەسپاوە و ناهەژێت. 
\q1  
\v 2 لە دێر زەمانەوە تەختت چەسپاوە، 
\q2 تۆ لە ئەزەلەوە و هەتاهەتایە هەیت. 
\b  
\q1  
\v 3 ئەی یەزدان، دەریاکان بەرزیان کردەوە، 
\q2 دەریاکان دەنگیان بەرزکردەوە، 
\q2 دەریاکان شەپۆلەکانیان بەرز دەکەنەوە. 
\q1  
\v 4 لە خوڕەی ئاوی زۆر، 
\q2 لە توانای شەپۆلەکانی دەریا، 
\q2 یەزدانی ئاسمان توانادارترە. 
\b  
\q1  
\v 5 یاساکانت زۆر چەسپاون، 
\q2 ئەی یەزدان، پیرۆزی لە ماڵی تۆ دەوەشێتەوە، 
\q2 بە درێژایی ڕۆژگار. 
\c 94  
\cl زەبووری 94 
\q1  
\v 1 ئەی یەزدان، خودای تۆڵە، 
\q2 ئەی خودای تۆڵە، بدرەوشێوە. 
\q1  
\v 2 ئەی دادوەری زەوی، ڕاپەرە، 
\q2 سزای لووتبەرزەکان بدەوە. 
\q1  
\v 3 ئەی یەزدان، هەتا کەی بەدکاران، 
\q2 هەتا کەی بەدکاران دڵشاد دەبن؟ 
\b  
\q1  
\v 4 بەدکاران لووتبەرزی لە قسەکانیانەوە هەڵدەقوڵێت، 
\q2 شانازی بە خۆیانەوە دەکەن. 
\q1  
\v 5 ئەی یەزدان، گەلەکەت وردوخاش دەکەن، 
\q2 میراتی تۆ دەچەوسێننەوە. 
\q1  
\v 6 بێوەژن و نامۆ دەکوژن، 
\q2 هەتیو سەردەبڕن. 
\q1  
\v 7 دەڵێن: «یەزدان نابینێت، 
\q2 خودای یاقوب ئاگای لێ نییە.» 
\b  
\q1  
\v 8 ئەی دەبەنگەکان لەنێو گەل، وریابن! 
\q2 ئەی گێلەکان، کەی تێدەگەن؟ 
\q1  
\v 9 ئایا ئەوەی گوێی چاندووە، نابیستێت؟ 
\q2 ئایا ئەوەی چاوی دروستکردووە، نابینێت؟ 
\q1  
\v 10 ئایا ئەوەی نەتەوەکان تەمبێ دەکات، سەرزەنشت ناکات؟ 
\q2 ئایا ئەوەی فێری مرۆڤ دەکات، زانیاری نییە؟ 
\q1  
\v 11 یەزدان بیرکردنەوەی مرۆڤ دەزانێت، 
\q2 کە پووچە. 
\b  
\q1  
\v 12 ئەی یەزدان، خۆزگە دەخوازرێ بەو کەسەی تۆ تەمبێی دەکەیت، 
\q2 لە تەوراتی خۆت فێری دەکەیت، 
\q1  
\v 13 لە ڕۆژی سەختدا ئارامی بکەیتەوە، 
\q2 هەتا گۆڕ بۆ بەدکار هەڵبکەنرێت، 
\q1  
\v 14 چونکە یەزدان واز لە گەلی خۆی ناهێنێ، 
\q2 میراتی خۆی ڕەت ناکاتەوە. 
\q1  
\v 15 دادوەری بۆ ڕاستودروستی دەگێڕێتەوە، 
\q2 هەموو دڵڕاستەکان شوێنی دەکەون. 
\b  
\q1  
\v 16 کێ بۆم لە دژی بەدکاران هەڵدەستێتەوە؟ 
\q2 کێ بۆم لە دژی خراپەکاران بوەستێتەوە؟ 
\q1  
\v 17 یەزدان هاریکارم بوو، ئەگینا هێندەی نەمابوو 
\q2 گیانم لەنێو بێدەنگی مردووان نیشتەجێ بێت. 
\q1  
\v 18 کاتێک گوتم: «پێم دەخلیسکێت،» 
\q2 ئەی یەزدان، خۆشەویستییە نەگۆڕەکەت پشتی گرتم. 
\q1  
\v 19 کە خەم لە ناخم زۆر بوو، 
\q2 دڵنەوایی تۆ گیانی منی شاد کرد. 
\b  
\q1  
\v 20 ئایا تەختی گەندەڵی هاوڕێیەتی لەگەڵ تۆ دەبەستێت، 
\q2 ئەوانەی بەگوێرەی زۆرداری خۆیان، شێوەی یاسا دادەڕێژن؟ 
\q1  
\v 21 لە دژی گیانی ڕاستودروست کۆدەبنەوە، 
\q2 خوێنێکی بێگەرد تاوانبار دەکەن. 
\q1  
\v 22 بەڵام یەزدان بۆم دەبێتە قەڵا، 
\q2 خودا بۆم بووە بە تاشەبەردی پەناگام. 
\q1  
\v 23 ئەو خراپەیەی دەیکەن بەسەر خۆیانیدا دەداتەوە و 
\q2 لە سزای بەدکاری خۆیان کڕیان دەکات، 
\q2 یەزدانی پەروەردگارمان کڕیان دەکات. 
\c 95  
\cl زەبووری 95 
\q1  
\v 1 وەرن، هەلهەلە بۆ یەزدان لێبدەین، 
\q2 هاواری شادی بکەین بۆ تاشەبەردی ڕزگاریمان. 
\q1  
\v 2 بە ستایشەوە بچینە بەردەمی، 
\q2 بە مۆسیقاوە هاواری شادی بۆ بکەین. 
\b  
\q1  
\v 3 لەبەر ئەوەی یەزدان خودایەکی گەورەیە، 
\q2 پاشایەکی گەورەیە بەسەر هەموو خوداوەندەکانەوە. 
\q1  
\v 4 قووڵاییەکانی زەوی بە دەستە و 
\q2 لووتکەی شاخەکان هی ئەون. 
\q1  
\v 5 دەریا هی ئەوە و ئەو دروستی کردووە، 
\q2 بە دەستی خۆی شێوەی وشکانیی پێکهێنا. 
\b  
\q1  
\v 6 وەرن، کڕنۆشی بۆ ببەین و بیپەرستین، 
\q2 لەبەردەم یەزدانی دروستکەرمان چۆک دابدەین، 
\q1  
\v 7 چونکە ئەو خودامانە و 
\q2 ئێمە گەلی لەوەڕگاکەی ئەوین، 
\q2 مەڕی دەستی ئەوین. 
\b  
\q1 ئەگەر ئەمڕۆ گوێتان لە فەرمایشتی یەزدان بێت کە دەفەرموێت: 
\q2  
\v 8 «دڵی خۆتان ڕەق مەکەن وەک لە مەریبا ڕوویدا، 
\q2 وەک ئەو ڕۆژە لە مەسا\f + \fr 95:8 \ft ناوێکی عیبرییە بە واتای تاقیکردنەوە، شوێنێکە لە چۆڵەوانی سینا، هەروەها پێی دەگوترێت مەریبا. بڕوانە ڕوونکردنەوە دەربارەی مێرگی مەریبا لە \xt زەبوورەکان 81‏:7.‏\ft ‏ هەروەها بڕوانە \xt دەرچوون 17‏:1‏-7.‏\ft ‏\f* لە بیابان، 
\q1  
\v 9 لەوێ باوباپیرانتان تاقییان کردمەوە، 
\q2 هەرچەندە کردارەکانی منیان بینی، 
\q2 بەڵام هەر تاقییان کردمەوە. 
\q1  
\v 10 چل ساڵ لەو نەوەیە تووڕە بووم، 
\q2 فەرمووم: ”ئەمانە گەلێکن دڵیان گومڕا بووە و 
\q2 ڕێگای منیان نەناسی.“ 
\q1  
\v 11 بۆیە لە تووڕەییمدا سوێندم خوارد: 
\q2 ”نایەنە ناو حەسانەوەی من.“» 
\c 96  
\cl زەبووری 96 
\q1  
\v 1 گۆرانی بڵێن بۆ یەزدان، گۆرانییەکی نوێ، 
\q2 گۆرانی بۆ یەزدان بڵێن، ئەی هەموو زەوی. 
\q1  
\v 2 گۆرانی بۆ یەزدان بڵێن، ستایشی ناوی بکەن، 
\q2 ڕۆژ بە ڕۆژ مژدەی ڕزگاریی ئەو ڕابگەیەنن. 
\q1  
\v 3 لەنێو نەتەوەکان شکۆمەندی ئەو ڕابگەیەنن، 
\q2 لەنێو هەموو گەلان کارە سەرسوڕهێنەرەکانی. 
\b  
\q1  
\v 4 یەزدان مەزنە و شایانی ستایشی زۆرە، 
\q2 سامناکە بەسەر هەموو خوداوەندەکانەوە، 
\q1  
\v 5 چونکە هەموو خوداوەندەکانی گەلان بتن، 
\q2 بەڵام یەزدان ئاسمانی دروستکردووە. 
\q1  
\v 6 شکۆ و سەربەرزی لەبەردەمیدان، 
\q2 هێز و جوانی لە پیرۆزگاکەیدان. 
\b  
\q1  
\v 7 ئەی هەموو خێڵەکانی گەلان، ستایشی یەزدان بکەن، 
\q2 ستایشی شکۆ و هێزی یەزدان بکەن. 
\q1  
\v 8 ستایشی ناوی شکۆداری یەزدان بکەن، 
\q2 دیاری بهێنن و وەرنە ناو حەوشەی ماڵەکەی. 
\q1  
\v 9 کڕنۆش بۆ یەزدان ببەن، چونکە شکۆدار و پیرۆزە، 
\q2 ئەی هەموو خەڵکی زەوی، لەبەردەمی بلەرزن. 
\q1  
\v 10 لەنێو نەتەوەکان بڵێن: «یەزدان پاشایەتی دەکات! 
\q2 جیهان چەسپاوە و هەرگیز نالەقێت، 
\q2 بە دادپەروەری حوکم بەسەر گەلاندا دەدات.» 
\b  
\q1  
\v 11 با ئاسمان شادبێت و زەوی دڵخۆش بێت، 
\q2 با دەریا و هەرچی تێدایە بخرۆشێن، 
\q2  
\v 12 با کێڵگە و هەرچی تێدایە شاگەشکە بن. 
\q1 ئینجا هەموو درەختەکانی دارستان گۆرانی دەڵێن، 
\q2  
\v 13 لەبەردەم یەزدان، چونکە دێت، 
\q2 دێت بۆ ئەوەی دادوەری زەوی بکات، 
\q1 دادوەری جیهان دەکات، بە ڕاستودروستی، 
\q2 گەلانیش بە دڵسۆزی. 
\c 97  
\cl زەبووری 97 
\q1  
\v 1 یەزدان پاشایەتی دەکات، با زەوی دڵخۆش بێت، 
\q2 دوورگە زۆرەکان شادمان بن. 
\q1  
\v 2 هەور و تەم لە دەوروپشتی ئەوە، 
\q2 ڕاستودروستی و دادپەروەری بنچینەی تەختی ئەوە. 
\q1  
\v 3 ئاگر لەپێشیەوە، 
\q2 دوژمنەکانی دەوروبەری دەسووتێنێت. 
\q1  
\v 4 بروسکەکانی جیهان ڕووناک دەکەنەوە، 
\q2 زەوی چاوی پێکەوت و لەرزی. 
\q1  
\v 5 چیاکان وەک مۆم لەبەردەم یەزدان توانەوە، 
\q2 لەبەردەم پەروەردگاری هەموو جیهان. 
\q1  
\v 6 ئاسمان ڕاستودروستییەکەی ڕادەگەیەنێت، 
\q2 هەموو گەلان شکۆمەندی ئەویان بینی. 
\b  
\q1  
\v 7 ئەوانەی پەیکەر دەپەرستن شەرمەزار دەبن، 
\q2 ئەوانەی شانازی بە بت دەکەن. 
\q2 ئەی هەموو خوداوەندەکان، کڕنۆشی بۆ ببەن. 
\b  
\q1  
\v 8 سییۆن بیستی و شادمان بوو، 
\q2 کچانی یەهودا دڵخۆش بوون، 
\q2 بە حوکمەکانت، ئەی یەزدان، 
\q1  
\v 9 چونکە لەسەر هەموو زەوی تۆ هەرەبەرزی، 
\q2 تۆ لە هەموو خوداوەندەکان پایەبەرزتری. 
\q1  
\v 10 با دۆستانی یەزدان ڕقیان لە بەدکاری ببێتەوە، 
\q2 لەبەر ئەوەی گیانی خۆشەویستانی دەپارێزێت و 
\q2 لە دەست خراپەکاران دەربازیان دەکات. 
\q1  
\v 11 ڕووناکی لەسەر ڕاستودروستان دەدرەوشێتەوە و 
\q2 شادییش بۆ دڵڕاستەکان. 
\q1  
\v 12 ئەی ڕاستودروستان، بە یەزدان شاد بن، 
\q2 ستایشی ناوە پیرۆزەکەی بکەن. 
\c 98  
\cl زەبووری 98 
\d زەبوورێک 
\q1  
\v 1 گۆرانی بۆ یەزدان بڵێن، گۆرانییەکی نوێ، 
\q2 چونکە کاری سەرسوڕهێنەری کردووە. 
\q1 دەستی ڕاست و بازووی پیرۆزی، 
\q2 سەرکەوتنیان بۆ بەدەستهێناوە. 
\q1  
\v 2 یەزدان ڕزگاریی خۆی ڕاگەیاند، 
\q2 ڕاستودروستییەکەی بۆ گەلان دەرخست. 
\q1  
\v 3 خۆشەویستییە نەگۆڕەکەی و دڵسۆزییەکەی، 
\q2 بەیادهێنایەوە بۆ بنەماڵەی ئیسرائیل. 
\q1 هەموو زەوی هەتا ئەوپەڕی دنیا، 
\q2 ڕزگاریی خودای ئێمەیان بینی. 
\b  
\q1  
\v 4 ئەی سەراپای زەوی هاواری شادی بکەن بۆ یەزدان، 
\q2 بە دەنگی بەرز گۆرانی بڵێن و هەلهەلە لێ بدەن. 
\q1  
\v 5 بە قیسارە مۆسیقا بۆ یەزدان بژەنن، 
\q2 بە قیسارە و دەنگی گۆرانی. 
\q1  
\v 6 بە زوڕنا و دەنگی کەڕەنا، 
\q2 هاواری شادی بکەن بەرامبەر بە یەزدانی پاشا. 
\b  
\q1  
\v 7 با دەریا و هەرچی تێیدایە، 
\q2 با جیهان و دانیشتووانی بخرۆشێن. 
\q1  
\v 8 با ڕووبارەکان چەپڵە لێبدەن و 
\q2 هەموو چیاکان هەلهەلە لێبدەن،  
\v 9 لەبەردەم یەزدان، 
\q1 چونکە دێت بۆ ئەوەی دادوەری زەوی بکات، 
\q2 بە ڕاستودروستی دادوەری جیهان دەکات، 
\q2 گەلانیش بە دادپەروەری. 
\c 99  
\cl زەبووری 99 
\q1  
\v 1 یەزدان پاشایەتی دەکات، 
\q2 با گەلان بلەرزن، 
\q1 لەنێوان کەڕوبەکان لەسەر تەخت دانیشتووە، 
\q2 با زەوی بهەژێت. 
\q1  
\v 2 یەزدان مەزنە لە سییۆن، 
\q2 بەرزە و بەسەر هەموو گەلانەوەیە. 
\q1  
\v 3 با ستایشی ناوە مەزن و سامناکەکەت بکەن، 
\q2 ئەو پیرۆزە. 
\b  
\q1  
\v 4 پاشا بەهێزە، حەز لە دادپەروەری دەکات. 
\q2 تۆ ڕاست و ڕێکیت چەسپاند، 
\q1 تۆ دادپەروەری و ڕاستودروستیت لەناو یاقوب دروستکردووە. 
\q1  
\v 5 یەزدانی پەروەردگارمان بەرز بکەنەوە، 
\q2 لە تەختەپێی کڕنۆش ببەن، 
\q2 ئەو پیرۆزە. 
\b  
\q1  
\v 6 موسا و هارون لەناو کاهینەکانی ئەون، 
\q2 ساموئێل لەناو ئەو کەسانەیە بە ناوی ئەو دەپاڕێنەوە. 
\q1 لە یەزدان پاڕانەوە، 
\q2 ئەویش وەڵامی دانەوە، 
\q1  
\v 7 بە ستوونی هەور قسەی لەگەڵ کردن، 
\q2 یاساکەیان پەیڕەو کرد، هەروەها ئەو فەرزەی پێیدان. 
\b  
\q1  
\v 8 ئەی یەزدانی پەروەردگارمان، تۆ وەڵامت دانەوە، 
\q2 خودایەکی لێبوردە بوویت، 
\q2 هەرچەندە تۆ لەسەر کردەوەکانیان تۆڵەت لێ سەندنەوە. 
\q1  
\v 9 یەزدانی پەروەردگارمان بەرز بکەنەوە، 
\q2 لە چیای پیرۆزی ئەو کڕنۆش ببەن، 
\q2 چونکە یەزدانی پەروەردگارمان پیرۆزە. 
\c 100  
\cl زەبووری 100 
\d زەبوورێکی ستایش. 
\q1  
\v 1 ئەی هەموو زەوی، هاواری خۆشی بۆ یەزدان بکەن، 
\q2  
\v 2 بە شادمانییەوە یەزدان بپەرستن، 
\q2 بە هەلهەلەوە وەرنە بەردەمی. 
\q1  
\v 3 بزانن کە یەزدان خودایە، 
\q2 ئەوە کە ئێمەی دروستکردووە و ئێمەش هی ئەوین، 
\q2 ئێمە گەل و مەڕی لەوەڕگای ئەوین. 
\b  
\q1  
\v 4 بە سوپاسەوە بڕۆنە ناو دەروازەکانی\f + \fr 100:4 \ft مەبەست لێی چوونە ناو پەرستگای خودایە دەم بە سوپاس و ستایشەوە.‏\f*، 
\q2 بە ستایشەوە بڕۆنە ناو حەوشەی پەرستگاکەی، 
\q2 سوپاسی بکەن و ستایشی ناوی بکەن، 
\q1  
\v 5 چونکە یەزدان چاکە و 
\q2 خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە، 
\q2 دڵسۆزیشی بۆ نەوە دوای نەوەیە. 
\c 101  
\cl زەبووری 101 
\d زەبوورێکی داود. 
\q1  
\v 1 گۆرانی بەسەر خۆشەویستییە نەگۆڕەکەت و دادپەروەریتدا دەڵێم، 
\q2 ئەی یەزدان، سروودی ستایش بۆ تۆ دەڵێم. 
\q1  
\v 2 لە ڕێگای تەواوەتی وریا دەبمەوە. 
\q2 کەی دێیت بۆ لام؟ 
\b  
\q1 بە دڵێکی تەواوەوە هەڵسوکەوت دەکەم، 
\q2 لەناو ماڵی خۆم. 
\q1  
\v 3 شتی قێزەون لەپێش چاوم دانانێم. 
\b  
\q1 ڕقم لە کاری یاخیبووانە، 
\q2 قەت بە منەوە نانووسێت. 
\q1  
\v 4 دڵی خواروخێچ لە من دوور دەبێت، 
\q2 پەیوەندیم بە بەدکارییەوە نابێت. 
\b  
\q1  
\v 5 ئەوەی بەدزییەوە بوختان بە کەسێک بکات، 
\q2 دەمکوتی دەکەم، 
\q1 لەگەڵ لووتبەرز و دڵ پڕ لە فیز 
\q2 بەرگە ناگرم. 
\b  
\q1  
\v 6 چاوم لە سەرڕاستانی زەوییە بۆ ئەوەی لەگەڵ خۆم دایاننیشێنم، 
\q2 ئەوانەی ڕێگای تەواوەتییان گرتووە خزمەتم دەکەن. 
\b  
\q1  
\v 7 ئەوەی بە فێڵ ئیش بکات، لە ماڵی من دانانیشێت، 
\q2 ئەوەی درۆ بکات، لەبەرچاوی من ناوەستێت. 
\b  
\q1  
\v 8 بەیانییان زوو هەموو بەدکارەکانی زەوی 
\q2 دەمکوت دەکەم، 
\q1 لە شاری یەزدان ڕیشەکێشیان دەکەم، 
\q2 هەموو ئەوانەی گوناهبارن. 
\c 102  
\cl زەبووری 102 
\d نوێژی هەژارێکی ورەڕووخاو، کە هاواری دەباتە بەردەم یەزدان. 
\q1  
\v 1 ئەی یەزدان، گوێ لە نوێژم بگرە، 
\q2 با هاوارم بگاتە لات. 
\q1  
\v 2 لە ڕۆژی تەنگانەدا ڕووی خۆتم لێ مەشارەوە، 
\q2 لەو ڕۆژەی کە هاوارت بۆ دەکەم گوێم بۆ شل بکە، 
\q2 زوو وەڵامم بدەوە. 
\b  
\q1  
\v 3 ڕۆژگارم وەک دووکەڵ ڕەوییەوە، 
\q2 ئێسکم وەک پشکۆ گڕی گرتووە. 
\q1  
\v 4 هەڵپڕووکاوە، دڵم وشک بووەتەوە، 
\q2 نانخواردنم لەبیر نەماوە. 
\q1  
\v 5 لە دەنگی ناڵەم 
\q2 ئێسکم بە پێستمەوە نووساوە. 
\q1  
\v 6 وەک کوندەپەپووی بیابانم لێهاتووە لە چۆڵەوانیدا، 
\q2 وەک کوندەپەپووی کەلاوەم لێهاتووە. 
\q1  
\v 7 ڕادەکشێم و 
\q2 وەک چۆلەکەیەکی تەنهای سەربانم لێهاتووە. 
\q1  
\v 8 بە درێژایی ڕۆژ دوژمنەکانم سووکایەتیم پێ دەکەن، 
\q2 ئەوانەی لە دژی منن وەک شێتیان لێ هاتووە، نەفرەتم لێدەکەن. 
\q1  
\v 9 بۆیە خۆڵەمێش دەخۆم وەک نان، 
\q2 فرمێسکم تێکەڵ بە خواردنەوەم بووە، 
\q1  
\v 10 لەبەر تووڕەیی زۆری تۆ، 
\q2 چونکە هەڵتگرتم و فڕێتدام. 
\q1  
\v 11 ڕۆژگارم وەک سێبەری خوارە، 
\q2 خۆشم وەک گیا وشک دەبمەوە. 
\b  
\q1  
\v 12 تۆش ئەی یەزدان، هەتاهەتایە لەسەر تەختی، 
\q2 نەوە دوای نەوە یادت دەکەنەوە. 
\q1  
\v 13 تۆ هەڵدەستیت و بەزەییت بە سییۆن دێتەوە، 
\q2 چونکە ماوەی میهرەبانییە، کاتی هاتووە. 
\q1  
\v 14 خزمەتکارەکانت بە تاسەوەن بۆ بەردەکانی، 
\q2 دڵیان دەسووتێ بۆ خۆڵەکەی. 
\q1  
\v 15 هەموو نەتەوەکان لە ناوی یەزدان دەترسن، 
\q2 هەموو پاشاکانی زەویش لە شکۆمەندیت، 
\q1  
\v 16 چونکە کە یەزدان سییۆن بنیاد دەنێتەوە، 
\q2 بە شکۆمەندی خۆی دەبینرێت. 
\q1  
\v 17 ئاوڕ لە نوێژی ڕووتوڕەجاڵەکان دەداتەوە، 
\q2 نوێژەکانیان بە کەم نازانێت. 
\b  
\q1  
\v 18 ئەمە بۆ نەوەی داهاتوو دەنووسرێت، 
\q2 تاکو ئەو نەوەیە ستایشی یەزدان بکەن، کە هێشتا لەدایک نەبوونە: 
\q1  
\v 19 «یەزدان لە بەرزایی پیرۆزگای خۆیەوە دەڕوانێتە خوارێ، 
\q2 لە ئاسمانەوە سەیری زەوی دەکات، 
\q1  
\v 20 بۆ ئەوەی گوێی لە ناڵەی دیلەکان بێت، 
\q2 ئەوانە ئازاد بکات کە دراونەتە دەست مردن.» 
\q1  
\v 21 جا لە سییۆن ناوی یەزدان ڕادەگەیەنرێت، 
\q2 لە ئۆرشەلیم ستایشی، 
\q1  
\v 22 کاتێک گەلان و پاشایەتییەکان 
\q2 پێکەوە بۆ پەرستنی یەزدان کۆدەبنەوە. 
\b  
\q1  
\v 23 لە ناوەڕاستی تەمەنم هێزی کزکردم، 
\q2 ڕۆژگاری کورتکردم. 
\q1  
\v 24 گوتی: «ئەی خودای من، لە ناوەڕاستی ڕۆژگارم لام مەدە، 
\q2 ساڵانی تۆ بۆ نەوە دوای نەوەیە. 
\q1  
\v 25 لە سەرەتاوە بناغەی زەویت دانا، 
\q2 ئاسمانیش دەستکردی تۆیە. 
\q1  
\v 26 ئەوان لەناودەچن، بەڵام تۆ دەمێنیت، 
\q2 هەموو وەک کراس کۆن دەبن، 
\q2 وەک جلوبەرگ دەیانگۆڕیت و فڕێدەدرێن. 
\q1  
\v 27 بەڵام تۆ هەروەک خۆتی، 
\q2 ساڵانی تۆ کۆتایی نایەت. 
\q1  
\v 28 کوڕی خزمەتکارەکانت نیشتەجێ دەبن و 
\q2 نەوەکانیان لەبەردەمت دەچەسپێن.» 
\c 103  
\cl زەبووری 103 
\d گۆرانییەکی داود. 
\q1  
\v 1 ئەی گیانی من، ستایشی یەزدان بکە، 
\q2 هەموو ناخیشم ستایشی ناوی پیرۆزی بکە. 
\q1  
\v 2 ئەی گیانی من، ستایشی یەزدان بکە، 
\q2 هیچ چاکەیەکی لەبیر مەکە: 
\q1  
\v 3 ئەوەی لە هەموو گوناهێکت خۆشدەبێت، 
\q2 لە هەموو نەخۆشییەک چاکت دەکاتەوە، 
\q1  
\v 4 ئەوەی ژیانت لە گۆڕ دەکڕێتەوە، 
\q2 خۆشەویستی نەگۆڕ و بەزەیی دەکاتە تاجی سەرت، 
\q1  
\v 5 ئەوەی تەمەنت تێر دەکات بە چاکە، 
\q2 تاکو گەنجییەتیت وەک هەڵۆ نوێ ببێتەوە. 
\b  
\q1  
\v 6 یەزدان ڕاستودروستی ئەنجام دەدات، 
\q2 دادپەروەری بۆ هەموو چەوساوەکان. 
\b  
\q1  
\v 7 ڕێگای خۆی بە موسا ناساند، 
\q2 کردارەکانی بە نەوەکانی ئیسرائیل: 
\q1  
\v 8 یەزدان میهرەبان و بە بەزەییە، 
\q2 پشوودرێژە و خۆشەویستی نەگۆڕی زۆرە. 
\q1  
\v 9 تاوانبارکردنی هەتاسەر نییە، 
\q2 تووڕەیی هەتاهەتایە نییە. 
\q1  
\v 10 بە گوناهی خۆمان لەگەڵ ناکات و 
\q2 بەگوێرەی تاوانەکانمان سزامان ناداتەوە. 
\q1  
\v 11 وەک بەرزی ئاسمان لەسەر زەوییەوە، 
\q2 خۆشەویستییە نەگۆڕەکەی زۆرکردووە بۆ ئەوانەی کە لێی دەترسن. 
\q1  
\v 12 وەک دووری ڕۆژهەڵات لە ڕۆژئاواوە، 
\q2 یاخیبوونەکانمانی لێ دوورخستووینەتەوە. 
\b  
\q1  
\v 13 وەک باوک چۆن بەزەیی بە منداڵەکانیدا دێتەوە، 
\q2 یەزدانیش ئاوا بەزەیی بەوانەدا دێتەوە کە لێی دەترسن، 
\q1  
\v 14 چونکە دەزانێت ئێمە چۆن پێکهێنراوین، 
\q2 لەبیریەتی کە ئێمە خۆڵین. 
\q1  
\v 15 مرۆڤ ڕۆژگاری ژیانی وەک گیا وایە، 
\q2 وەک گوڵی ناو کێڵگە گوڵ دەکات، 
\q1  
\v 16 بایەک بەسەریدا هەڵبکات، ئیتر نامێنێت، 
\q2 ئاسەواریشی دیار نابێت. 
\q1  
\v 17 بەڵام خۆشەویستی نەگۆڕی یەزدان لە ئەزەلەوە و 
\q2 هەتاهەتایە بۆ ئەوانەیە کە ترسی ئەویان لە دڵدایە، 
\q2 ڕاستودروستییەکەشی بۆ نەوەکانە، 
\q1  
\v 18 بۆ ئەوانەی پەیمانی بەجێدەگەیەنن، 
\q2 ئەوانەی ڕێنماییەکانی ئەویان لەبیرە بۆ ئەوەی پەیڕەوی بکەن. 
\b  
\q1  
\v 19 یەزدان تەختی خۆی لە ئاسمان چەسپاندووە و 
\q2 پاشایەتییەکەشی بەسەر هەمووانەوە فەرمانڕەوایەتی دەکات. 
\b  
\q1  
\v 20 ئەی فریشتەکانی یەزدان، ستایشی بکەن، 
\q2 ئەی ئەو بەهێزانەی وتەکانی بەجێدەهێنن، 
\q2 ئەی ئەوانەی گوێڕایەڵی وتەی ئەو دەبن. 
\q1  
\v 21 ئەی هەموو سوپاکانی، ستایشی یەزدان بکەن، 
\q2 ئەی خزمەتکارانی کە بە ڕەزامەندی ئەو کار دەکەن. 
\q1  
\v 22 ئەی هەموو کارەکانی، ستایشی یەزدان بکەن 
\q2 لە هەموو شوێنێکی ژێر دەسەڵاتی. 
\b  
\q1 ئەی گیانی من، ستایشی یەزدان بکە. 
\c 104  
\cl زەبووری 104 
\q1  
\v 1 ئەی گیانی من، ستایشی یەزدان بکە. 
\b  
\q1 ئەی یەزدانی پەروەردگارم، تۆ زۆر مەزنیت! 
\q2 شکۆمەندی و پایەبەرزیت لەبەرکردووە. 
\b  
\q1  
\v 2 وەک بەرگ ڕووناکیت پۆشیوە، 
\q2 وەک خێوەت ئاسمانت هەڵداوە، 
\q2  
\v 3 وەک کاریتە بەیتوونەکەت لەسەر ئاو داناوە. 
\q1 هەوری ئاسمانت کردووەتە گالیسکەت، 
\q2 بەسەر باڵی باوە دەڕۆیت. 
\q1  
\v 4 بایەکانت کردووەتە فریشتەکانت، 
\q2 بڵێسەی ئاگر خزمەتکارانت. 
\b  
\q1  
\v 5 زەویت لەسەر بناغەی خۆی دامەزراندووە، 
\q2 هەتاهەتایە نالەقێت. 
\q1  
\v 6 تۆ وەک کراس زەویت بە دەریای قووڵ داپۆشی، 
\q2 لەسەر چیاکان ئاوەکان ڕادەوەستن. 
\q1  
\v 7 بەڵام لە سەرزەنشتی تۆ ئاوەکان هەڵاتن، 
\q2 لە گرمەی دەنگی تۆ بە ترسەوە ڕایانکرد، 
\q1  
\v 8 بەسەر چیاکان کەوتن و 
\q2 شۆڕ بوونەوە ناو دۆڵەکان، 
\q2 بۆ ئەو شوێنەی تۆ بۆت دامەزراندبوون. 
\q1  
\v 9 سنوورێکت دانا لێی تێنەپەڕن، 
\q2 نەگەڕێنەوە هەتا زەوی دابپۆشن. 
\b  
\q1  
\v 10 کانیاو لە شیوەکان دەتەقێنیتەوە، 
\q2 بۆ ئەوەی لەنێوان چیاکاندا بڕۆن. 
\q1  
\v 11 هەموو زیندەوەرێکی دەشتودەر ئاودەدەن، 
\q2 کەرەکێوییەکان تینووێتی خۆیانی پێ دەشکێنن. 
\q1  
\v 12 باڵندەی ئاسمان هێلانەی تێدا دەکات، 
\q2 لەناو چڵەکان دەخوێنێت. 
\q1  
\v 13 لە بەیتوونەکەی خۆتەوە چیاکان ئاو دەدەیت، 
\q2 زەوی لە بەروبوومی کردەوەکانت تێر دەبێت. 
\q1  
\v 14 گیا بۆ ئاژەڵی ماڵی دەڕوێنیت، 
\q2 سەوزە بۆ خزمەتی مرۆڤ، 
\q2 بۆ دەرهێنانی نان لە زەوییەوە. 
\q1  
\v 15 مەی پێ دەبەخشی بۆ ئەوەی دڵی مرۆڤ خۆش بکەی، 
\q2 ڕۆن بۆ درەوشانەوەی زیاتری ڕووی، 
\q2 نان بۆ پتەوکردنی دڵی مرۆڤ. 
\q1  
\v 16 درەختەکانی یەزدان تێر دەبن، 
\q2 ئەو داری ئورزەی لوبنان کە چاندی، 
\q1  
\v 17 ئەوەی چۆلەکە هێلانەی تێدا دەکات، 
\q2 لەقلەقیش داری سنەوبەر ماڵیەتی، 
\q1  
\v 18 چیای بەرزیش بۆ بزنە کێوی، 
\q2 تاشەبەردەکانیش پەناگای گۆڕهەڵکەنە. 
\b  
\q1  
\v 19 مانگت دروستکرد بۆ دیاریکردنی وەرزەکان، 
\q2 خۆریش ئاوابوونی خۆی دەزانێت. 
\q1  
\v 20 تاریکی دادێنێت دەبێت بە شەو، 
\q2 هەموو زیندەوەری دارستان تێیدا دەکەونە جموجۆڵ. 
\q1  
\v 21 بەچکە شێر بۆ نێچیر دەنەڕێنن، 
\q2 بۆ داواکردنی خواردنیان لە خودا. 
\q1  
\v 22 کە ڕۆژ هەڵدێت دەکشێنەوە، 
\q2 لەناو لانەکانیان خۆیان مات دەکەن. 
\q1  
\v 23 مرۆڤ دەچێت بۆ ئیشوکاری، 
\q2 بۆ ڕەنجکێشییەکەی هەتا ئێوارە. 
\b  
\q1  
\v 24 ئەی یەزدان، کردەوەکانت چەندە زۆرن! 
\q2 هەموویت بە دانایی دروستکردووە، 
\q2 زەوی پڕە لە دەستکردی تۆ. 
\q1  
\v 25 ئەم دەریا گەورە و فراوانە، 
\q2 کە بێشومار گیانداری گەورە و بچووکی تێدا جمەی دێت. 
\q1  
\v 26 لەوێ کەشتییەکان دەڕۆن، 
\q2 لیڤیاتان\f + \fr 104:26 \ft جۆرە ئەژدیهایەکە، بڕوانە \xt ئەیوب 41‏:1‏\ft ‏.‏\f*، ئەمەی خۆت بەدیت هێناوە بۆ ئەوەی یاری تێدا بکات. 
\b  
\q1  
\v 27 ئەمانە هەمووی چاویان لە تۆیە، 
\q2 بۆ ئەوەی لە کاتی خۆی خواردنیان بدەیتێ، 
\q1  
\v 28 پێیان دەدەیت و وەریدەگرن، 
\q2 دەستت دەکەیتەوە تێر چاکە دەبن. 
\q1  
\v 29 ڕوو وەردەگێڕیت، دەتۆقن، 
\q2 هەناسەیان لێ دەبڕیت، دەمرن، 
\q2 دەگەڕێنەوە بۆ خۆڵی خۆیان. 
\q1  
\v 30 کاتێک ڕۆحی خۆت دەنێریت، 
\q2 ئەوان بەدیدەهێنرێن، 
\q2 ڕووی زەوی نوێ دەکەیتەوە. 
\b  
\q1  
\v 31 با شکۆی یەزدان هەتاهەتایە بەردەوام بێت، 
\q2 با یەزدان بە کارەکانی خۆی دڵخۆش بێت. 
\q1  
\v 32 ئەوەی سەیری زەوی دەکات، لەرز دەیگرێت، 
\q2 دەست دەداتە چیاکان، دووکەڵ دەکەن. 
\b  
\q1  
\v 33 بە درێژایی ژیانم گۆرانی بۆ یەزدان دەڵێم، 
\q2 تاکو ماوم سروود بۆ خودای خۆم دەڵێم. 
\q1  
\v 34 با بیرکردنەوەم شیرین بێت لەلای، 
\q2 منیش بە یەزدان دڵخۆش دەبم. 
\q1  
\v 35 بەڵام با گوناهباران لەسەر زەوی دواییان ببڕێتەوە، 
\q2 با بەدکاران ئیتر نەمێنن. 
\b  
\q1 ئەی گیانی من، ستایشی یەزدان بکە. 
\b  
\q1 هەلیلویا!\f + \fr 104:35 \ft وشەیەکی عیبرییە بە واتای (ستایشی یەزدان بکەن).‏\f* 
\c 105  
\cl زەبووری 105 
\q1  
\v 1 ستایشی یەزدان بکەن و بە ناوی ئەوەوە نوێژ بکەن، 
\q2 کردارەکانی بە گەلان بناسێنن. 
\q1  
\v 2 گۆرانی بۆ بڵێن، ستایشی بکەن، 
\q2 هەموو کارە سەرسوڕهێنەرەکانی ڕابگەیەنن، 
\q1  
\v 3 شانازی بە ناوی پیرۆزیەوە بکەن، 
\q2 با دڵی ئەوانە خۆش بێت کە ڕوو لە یەزدان دەکەن. 
\q1  
\v 4 پشت بە یەزدان و هێزەکەی ببەستن، 
\q2 بەردەوام ڕووتان لەو بکەن. 
\b  
\q1  
\v 5 باسی ئەو کارە سەرسوڕهێنەرانە بکەن کە کردوونی، 
\q2 پەرجوو و حوکمەکانی دەمی، 
\q1  
\v 6 ئەی نەوەی ئیبراهیمی بەندەی ئەو، 
\q2 ئەی کوڕانی یاقوب، هەڵبژاردەکانی. 
\q1  
\v 7 ئەو یەزدانی پەروەردگارمانە، 
\q2 حوکمەکانیشی لە سەراپای زەوییە. 
\b  
\q1  
\v 8 بۆ هەتاهەتایە پەیمانەکەی لە یادە، 
\q2 ئەو بەڵێنەی دەیدات بۆ هەزار پشتە، 
\q1  
\v 9 ئەو پەیمانەی لەگەڵ ئیبراهیم بەستی، 
\q2 ئەو سوێندەی بۆ ئیسحاقی خوارد. 
\q1  
\v 10 وەک فەرز بۆ یاقوب چەسپاندی، 
\q2 وەک پەیمانێکی هەمیشەیی بۆ ئیسرائیل. 
\q1  
\v 11 فەرموویەتی: «خاکی کەنعان\f + \fr 105:11 \ft مەبەست لەو خاکەیە کە کەنعانییەکان تێیدا نیشتەجێ بوون، ئێستاش پێی دەگوترێت فەلەستین.‏\f* دەدەمە تۆ، 
\q2 بەشە میراتی خۆتانە.» 
\b  
\q1  
\v 12 ئەو کاتەی ژمارەیان کەم بوو، 
\q2 کەم و نامۆ بوون لەو خاکە، 
\q1  
\v 13 لە نەتەوەیەکەوە دەچوونە نەتەوەیەکی دیکە، 
\q2 لە پاشایەتییەکەوە بۆ گەلێکی دیکە. 
\q1  
\v 14 لێ نەگەڕا کەس ستەمیان لێ بکات، 
\q2 بەڵکو لەبەر ئەوان پاشایانی سەرزەنشت کرد: 
\q1  
\v 15 «دەست لە دەستنیشانکراوەکانم\f + \fr 105:15 \ft دەستنیشانکراوە: بە زمانی عیبری پێی دەگوترێ \+tl مەشیخ‏\+tl* یان \+tl مەشیح‏\+tl*.‏\f* مەدەن، 
\q2 خراپە لەگەڵ پێغەمبەرەکانم مەکەن.» 
\b  
\q1  
\v 16 قاتوقڕی ناردە سەر زەوی، 
\q2 هەموو نانێکی لە زەوی بڕی. 
\q1  
\v 17 کەسێکی لەپێشیانەوە نارد، 
\q2 یوسف بە کۆیلایەتی فرۆشرا، 
\q1  
\v 18 بە کۆت ئازاری پێیان دا، 
\q2 زنجیری ئاسنیان لە ملی کرد، 
\q1  
\v 19 هەتا کاتی هاتنەدی قسەکەی، 
\q2 پەیامی یەزدان ڕاستگۆیی ئەوی چەسپاند. 
\q1  
\v 20 پاشا ناردی کۆتەکەیان کردەوە، 
\q2 فەرمانڕەوای گەلان ئازادی کرد. 
\q1  
\v 21 کردی بە گەورەی ماڵی خۆی، 
\q2 کردی بە دەسەڵاتدار لەسەر هەموو موڵکی خۆی، 
\q1  
\v 22 بۆ ئەوەی بە دڵی خۆی میرەکانی ڕێنمایی بکات، 
\q2 پیرەکانی فێری دانایی بکات. 
\b  
\q1  
\v 23 جا ئیسرائیل هاتە میسر، 
\q2 یاقوب لە خاکی حام بوو بە لانەواز. 
\q1  
\v 24 بەم جۆرەی کرد گەلەکەی زۆر بە بەروبووم بن، 
\q2 لە هەموو دوژمنەکانی بەهێزتری کردن، 
\q1  
\v 25 ئەو دڵی گۆڕین بۆ ئەوەی ڕقیان لە گەلەکەی بێتەوە، 
\q2 هەتا فێڵ لە خزمەتکارەکانی بکەن. 
\q1  
\v 26 موسای بەندەی خۆی نارد و 
\q2 هارون ئەوەی هەڵیبژارد. 
\q1  
\v 27 لەنێو خۆیان ئەو پەرجوو و نیشانانەی فەرمانی پێکرابوو، 
\q2 لە خاکی حام هێنایانە دی. 
\q1  
\v 28 تاریکی نارد و تاریک داهات، 
\q2 میسرییەکان لە دژی فەرمانەکانی یاخی بوون. 
\q1  
\v 29 ئاوەکانی گۆڕین بۆ خوێن، 
\q2 ماسییەکانیانی کوشت. 
\q1  
\v 30 زەوی پڕبوو لە بۆق، 
\q2 کە چوونە نێو نوێنی پاشاکانیشیان. 
\q1  
\v 31 بە فەرمانی ئەو مێشومەگەز هات، 
\q2 مێشوولە بۆ هەموو سنوورەکانیان. 
\q1  
\v 32 بارانی کردن بە تەرزە، 
\q2 ئاگری بە گڕ لە زەوییەکانیان. 
\q1  
\v 33 لە هەنجیر و دار مێوەکانی دان، 
\q2 درەختی سنوورەکانیانی شکاند. 
\q1  
\v 34 بە فەرمانی ئەو کوللە هات، 
\q2 کوللەحاجی بێشومار، 
\q1  
\v 35 هەموو سەوزایی زەوییەکەیانی خوارد، 
\q2 بەروبوومی خاکەکەیانی خوارد. 
\q1  
\v 36 لە هەموو نۆبەرەیەکی دا لە خاکەکەیان، 
\q2 یەکەمین بەرهەمی پیاوەتییان. 
\q1  
\v 37 بە زێڕ و زیوەوە دەریهێنان، 
\q2 لەنێو هۆزەکانیان کەس پەکی نەکەوت. 
\q1  
\v 38 میسر بە چوونەدەرەوەیان دڵخۆش بوو، 
\q2 چونکە ترسی ئەوان چووبووە دڵیانەوە. 
\b  
\q1  
\v 39 هەورێکی هێنا بۆ داپۆشین، 
\q2 ئاگرێک بۆ ڕووناککردنەوەی شەو. 
\q1  
\v 40 داوایان کرد، سوێسکەی\f + \fr 105:40 \ft سوێسکە: باڵندەیەکی بچووکە، لە شێوەی کەوە، لە پۆلێکی گەورەدا کۆچ دەکەن، لە ئاستێکی نزمدا دەفڕن و هێلانەکانیشیان لەسەر زەوی دروستدەکەن. بڕوانە \xt دەرچوون 16‏:13‏\ft ‏\f* هێنا، 
\q2 نانی ئاسمانی تێری کردن. 
\q1  
\v 41 بەردی شەقکرد و ئاوی لێ هەڵقوڵا، 
\q2 وەک ڕووبار بەناو بیاباندا ڕۆیی. 
\b  
\q1  
\v 42 لەبەر ئەوەی بەڵێنی پیرۆزی خۆی یادکردەوە، 
\q2 بۆ ئیبراهیمی بەندەی. 
\q1  
\v 43 گەلەکەی بە شادییەوە هێنایە دەرەوە، 
\q2 هەڵبژاردەکانی بە هەلهەلەوە. 
\q1  
\v 44 خاکی نەتەوەکانی پێ بەخشین، 
\q2 بەری ماندووبوونی گەلانیان بە میرات بۆ مایەوە، 
\q1  
\v 45 بۆ ئەوەی فەرزەکانی بەجێبهێنن، 
\q2 فێرکردنی جێبەجێ بکەن. 
\b  
\q1 هەلیلویا. 
\c 106  
\cl زەبووری 106 
\q1  
\v 1 هەلیلویا! 
\b  
\q1 ستایشی یەزدان بکەن، لەبەر ئەوەی چاکە، 
\q2 خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\b  
\q1  
\v 2 کێ باسی پاڵەوانیێتی یەزدان دەکات؟ 
\q2 کێ بە تەواوی ستایشی ئەو دەکات؟ 
\q1  
\v 3 خۆزگە دەخوازرێ بەوانەی دادپەروەری پەیڕەو دەکەن، 
\q2 ئەوانەی هەموو کاتێک بە ڕاستودروستی کار دەکەن. 
\b  
\q1  
\v 4 ئەی یەزدان، لە کاتی ڕەزامەندیت لە گەلەکەت یادم بکەرەوە، 
\q2 لە ڕزگارییەکەت بەسەرم بکەرەوە، 
\q1  
\v 5 بۆ ئەوەی خۆشگوزەرانی هەڵبژێردراوانت ببینم، 
\q2 بۆ ئەوەی بە دڵخۆشی نەتەوەکەت دڵخۆشبم، 
\q2 بۆ ئەوەی لەگەڵ میراتەکەت شانازی بکەم. 
\b  
\q1  
\v 6 ئێمە وەک باوباپیران گوناهمان کرد، 
\q2 خراپەمان کرد و بەدکاریمان کرد. 
\q1  
\v 7 کاتێک باوکانمان لە میسر بوون، 
\q2 لە پەرجووەکانی تۆ تێنەگەیشتن، 
\q1 یادی گەورەیی خۆشەویستییە نەگۆڕەکەی تۆیان نەکردەوە، 
\q2 بەڵکو یاخی بوون لەلای دەریا، لەلای دەریای سوور\f + \fr 106:7 \ft عیبری \+tl سوف‏\+tl* واتا (زەل). دەشێت مەبەست لە دەریای سوف بێت، ئەو دەریایە بێت کە دەکەوێتە سەرووی باکووری کەنداوی سوێسی ئەمڕۆ، بەڵام لە دەقی یۆنانی پەیمانی نوێ هەر بە دەریای سوور نووسراوە. بڕوانە \xt عیبرانییەکان 11‏:29‏\ft ‏.‏\f*، 
\q1  
\v 8 بەڵام لەبەر ناوی خۆی ڕزگاری کردن، 
\q2 بۆ ئەوەی پاڵەوانیێتی بزانرێت. 
\q1  
\v 9 لە دەریای سووری ڕاخوڕی، وشک بوو، 
\q2 بە ناو قووڵاییەکەیدا بردنی، وەک لە بیابان. 
\q1  
\v 10 لە دەست ناحەز ڕزگاری کردن، 
\q2 لە دەست دوژمن کڕینیەوە. 
\q1  
\v 11 ئاو دوژمنانی ئەوانەی داپۆشی، 
\q2 کەسیان دەرباز نەبوون. 
\q1  
\v 12 ئەوسا بڕوایان بە بەڵێنەکانی کرد، 
\q2 گۆرانییان بۆ ستایشی گوت. 
\b  
\q1  
\v 13 بەڵام هەر زوو کردارەکانی ئەویان لەیادچوو، 
\q2 چاوەڕێی ڕاوێژی ئەویان نەکرد. 
\q1  
\v 14 بەڵکو لە چۆڵەوانی نەوسیان هەستا، 
\q2 لە بیابان خودایان تاقی کردەوە، 
\q1  
\v 15 ئەوەی داوایان کرد، پێیدان، 
\q2 بەڵام نەخۆشی لەڕی بۆ ناردن. 
\b  
\q1  
\v 16 لە ئۆردوگا بەغیلییان برد بە موسا و 
\q2 بە هارونی تەرخانکراوی\f + \fr 106:16 \ft عیبری: پیرۆزی یەزدان بە واتای تەرخانکراو بۆ خزمەتی یەزدان وەک کاهین.‏\f* یەزدان. 
\q1  
\v 17 زەوی لێک بووەوە و داتانی قووت دا، 
\q2 بەسەر تاقمەکەی ئەبیرامدا\f + \fr 106:17 \ft دوو کوڕی ئەلیئاب بوون لە نەوەی ڕئووبێن، بەشداری ئۆنی کوڕی فالتیان کرد لە یاخیبوونەکەی قۆرەح لە دژی موسا و هارون. بڕوانە سەرژمێری بەشی 16.‏\f* هاتەوەیەک. 
\q1  
\v 18 ئاگر بەربووە تاقمەکەیان، 
\q2 گڕ بەدکارانی هەڵلووشی. 
\q1  
\v 19 لە حۆرێڤ گوێرەکەیەکیان دروستکرد، 
\q2 کڕنۆشیان بۆ پەیکەرێکی داڕێژراو برد. 
\q1  
\v 20 شکۆیان\f + \fr 106:20 \ft مەبەستی لە شکۆی خودایە.‏\f* گۆڕییەوە 
\q2 بە پەیکەری گای گیاخۆر. 
\q1  
\v 21 خودای ڕزگارکەری خۆیان لەبیر کرد، 
\q2 کە لە میسر کاری مەزنی کردبوو، 
\q1  
\v 22 پەرجووەکان لە وڵاتی حام، 
\q2 کارە سامناکەکان لەلای دەریای سوور. 
\q1  
\v 23 ئینجا فەرمووی لەناودەچن، 
\q2 ئەگەر موسای هەڵبژاردەی خۆی، 
\q1 لە کەلێنی شووراکە لە بەرامبەری ڕانەوەستابایە، 
\q2 بۆ ئەوەی نەهێڵێ تووڕەیی ئەو دایانبڕزێنێ. 
\b  
\q1  
\v 24 خاکی خۆشییان بە سووک زانی، 
\q2 باوەڕیان بە بەڵێنی ئەو نەکرد. 
\q1  
\v 25 لەناو خێوەتەکانیاندا کەوتنە بۆڵەبۆڵ، 
\q2 گوێیان لە قسەی یەزدان نەگرت. 
\q1  
\v 26 ئەویش سوێندی بۆ خواردن، 
\q2 کە لە بیابان بە مردوویی بکەون، 
\q1  
\v 27 نەوەکانیان لەنێو نەتەوەکان بخات و 
\q2 لە خاکەکان پەرتیان بکات. 
\b  
\q1  
\v 28 پەیوەست بوون بە بەعلی پەعۆرەوە\f + \fr 106:28 \ft ناوێکی مۆئابییە بۆ ئەو خوداوەندەی لە کێوی پەعۆر دەیانپەرست. بڕوانە \xt سەرژمێری 25‏:1‏-9.‏\ft ‏\f*، 
\q2 ئەو قوربانییانەیان خوارد کە بۆ بتی مردوو کرابوون\f + \fr 106:28 \ft نەریتی کەنعانییەکان بوو، کاتێک یەکێکیان دەمرد، قوربانی پێشکەش بکەن و بخۆن و بخۆنەوە و سەما بکەن.‏\f*. 
\q1  
\v 29 بە کردەوەکانیان یەزدانیان پەست کرد، 
\q2 دەرد بەناویاندا بڵاو بووەوە. 
\q1  
\v 30 بەڵام فینەحاس\f + \fr 106:30 \ft کوڕی ئەلیعەزەری کوڕی هارونە، دڵگەرم بوو بۆ یەزدان بۆیە کاتێک زەمری کوڕی سالووای شمعۆنی لەگەڵ ژنە میدیانییەکە داوێنپیسی دەکرد هەردووکیانی کوشت، بەو شێوەیە ئەو بەڵایەی بەسەر جولەکەکان هاتبوو بڕایەوە. بڕوانە \xt سەرژمێری 25‏:1‏-9.‏\ft ‏\f* هەستا و 
\q2 کەوتە نێوانەوە و دەرد ڕاگیرا. 
\q1  
\v 31 بە ڕاستودروستی بۆی دانرا، 
\q2 نەوە دوای نەوە هەتاهەتایە. 
\q1  
\v 32 لەلای مێرگی مەریبا یەزدانیان تووڕە کرد و 
\q2 موسا بەهۆی ئەوانە کەوتە ناخۆشی، 
\q1  
\v 33 چونکە کاتێک ئەوان لە ڕۆحی خودا یاخیبوون، 
\q2 قسەی ناشایستەش لە دەمی موسا دەرچوو. 
\b  
\q1  
\v 34 گەلەکانیان لەناونەبرد، 
\q2 وەک یەزدان فەرمانی پێ کردبوون، 
\q1  
\v 35 بەڵکو لەگەڵ نەتەوەکان تێکەڵاو بوون، 
\q2 فێری نەریتەکانیان بوون. 
\q1  
\v 36 بتەکانی ئەوانیان پەرست و 
\q2 بوو بە داو بۆیان. 
\q1  
\v 37 کوڕ و کچانی خۆیان 
\q2 بۆ بتەکان\f + \fr 106:37 \ft بە واتای ڕۆحە پیسەکان.‏\f* سەربڕی. 
\q1  
\v 38 خوێنێکی بێتاوانیان ڕشت، 
\q2 خوێنی کوڕ و کچەکانیان، 
\q1 ئەوانەی بۆ بتەکانی کەنعان سەریان بڕین، 
\q2 زەوی پیس بوو بە خوێن. 
\q1  
\v 39 گڵاو بوون بە کردەوەکانیان، 
\q2 داوێنپیس بوون بە کارەکانیان. 
\b  
\q1  
\v 40 لەبەر ئەوە تووڕەیی یەزدان بەسەر گەلەکەیدا جۆشا، 
\q2 قێزی لە میراتەکەی بووەوە. 
\q1  
\v 41 ژێردەستەی نەتەوەکانی کردن، 
\q2 ناحەزانیان بەسەریاندا زاڵبوون، 
\q1  
\v 42 دوژمنەکانیان تەنگیان پێ هەڵچنین، 
\q2 زەلیلی ژێر دەستیان بوون. 
\q1  
\v 43 زۆر جار دەربازی کردن، 
\q2 بەڵام بە ئەنقەست یاخیبوون، 
\q2 داڕووخان بە گوناهەکانیان. 
\q1  
\v 44 بەڵام لە تەنگانەیاندا ئاوڕی لێ دانەوە، 
\q2 کە گوێی لە دەنگی هاواریان بوو. 
\q1  
\v 45 لە پێناوی ئەوان پەیمانی خۆی هێنایەوە یاد، 
\q2 بەگوێرەی گەورەیی خۆشەویستییە نەگۆڕەکەی پاشگەز بووەوە. 
\q1  
\v 46 وای کرد ئەوانەی بە دیل گرتوویانن، 
\q2 سکیان پێیان بسووتێت. 
\b  
\q1  
\v 47 ئەی یەزدانی پەروەردگارمان، ڕزگارمان بکە، 
\q2 لەنێو نەتەوەکان کۆمان بکەرەوە، 
\q1 بۆ ئەوەی ستایشی ناوی پیرۆزی تۆ بکەین و 
\q2 شانازی بە ستایشکردنی تۆوە بکەین. 
\b  
\q1  
\v 48 ستایش بۆ یەزدانی پەروەردگاری ئیسرائیل، 
\q2 لە ئەزەلەوە و بۆ هەتاهەتایە. 
\b  
\q1 با هەموو گەل بڵێن: «ئامین!» 
\b  
\q1 هەلیلویا! 
\c 107  
\ms1 کۆکراوەی بەشی پێنجەم 
\mr زەبوورەکانی 107‏–150 
\cl زەبووری 107 
\q1  
\v 1 ستایشی یەزدان بکەن، لەبەر ئەوەی چاکە، 
\q2 خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\b  
\q1  
\v 2 با ئەوانەی یەزدان کڕینیەوە بەسەرهاتی خۆیان بگێڕنەوە، 
\q2 ئەوانەی لە دەستی دوژمن کڕینیەوە، 
\q1  
\v 3 لە وڵاتانەوە کۆی کردنەوە، 
\q2 لە ڕۆژهەڵات و ڕۆژئاوا، لە باکوور و باشوورەوە: 
\b  
\q1  
\v 4 هەندێک گومڕابوون لە چۆڵەوانی، لە بیابان، 
\q2 ڕێگایان بۆ شاری نیشتەجێبوونیان نەدۆزییەوە. 
\q1  
\v 5 برسی و تینوو بوون، 
\q2 گیانیان داهێزرا. 
\q1  
\v 6 ئینجا لە تەنگانەیاندا هاواریان بۆ یەزدان کرد، 
\q2 ئەویش لە ناخۆشییەکانیان دەربازی کردن. 
\q1  
\v 7 ڕابەرایەتی کردن بۆ ڕێگای ڕاست، 
\q2 بۆ ئەوەی بچن بۆ شاری نیشتەجێبوون. 
\q1  
\v 8 با ئەوان ستایشی یەزدان بکەن بۆ خۆشەویستییە نەگۆڕەکەی، 
\q2 بۆ کارە سەرسوڕهێنەرەکانی بۆ ئادەمیزاد، 
\q1  
\v 9 چونکە گیانێکی تینووی تێرکرد، 
\q2 گیانێکی برسی پڕکرد لە چاکە. 
\b  
\q1  
\v 10 هەندێک دانیشتن لە تاریکی و سێبەری مەرگ، 
\q2 لە دیلیێتی ئازار و ئاسن، 
\q1  
\v 11 چونکە لە قسەکانی خودا یاخی بوون، 
\q2 سووکایەتییان بە ڕاوێژی هەرەبەرز کرد. 
\q1  
\v 12 لەبەر ئەوە پشتیان لەژێر باردا چەمایەوە، 
\q2 کەوتن و کەس نەبوو یارمەتییان بدات. 
\q1  
\v 13 ئینجا لە تەنگانەیاندا هاواریان بۆ یەزدان کرد، 
\q2 ئەویش لە ناخۆشییەکانیان ڕزگاری کردن. 
\q1  
\v 14 لە تاریکی و سێبەری مەرگ دەریهێنان، 
\q2 کۆت و زنجیرەکانی پچڕاندن. 
\q1  
\v 15 با ئەوان ستایشی یەزدان بکەن بۆ خۆشەویستییە نەگۆڕەکەی، 
\q2 بۆ کارە سەرسوڕهێنەرەکانی بۆ ئادەمیزاد، 
\q1  
\v 16 چونکە دەروازەی بڕۆنزی تێکشکاند، 
\q2 شیشە ئاسنەکانی شکاند. 
\b  
\q1  
\v 17 هەندێک بوونە گێل لە ڕێگای یاخیبوونیان و 
\q2 لە گوناهەکانیان تووشی ناخۆشی دەبن. 
\q1  
\v 18 قێزیان لە هەموو خواردنێک بووەوە، 
\q2 لە دەروازەکانی مەرگ نزیک بوونەوە. 
\q1  
\v 19 ئینجا لە تەنگانەیاندا هاواریان بۆ یەزدان کرد، 
\q2 ئەویش لە ناخۆشییەکانیان ڕزگاری کردن. 
\q1  
\v 20 فەرمایشتی خۆی نارد و چاکی کردنەوە، 
\q2 لە فەوتان دەربازی کردن. 
\q1  
\v 21 با ئەوان ستایشی یەزدان بکەن بۆ خۆشەویستییە نەگۆڕەکەی، 
\q2 بۆ کارە سەرسوڕهێنەرەکانی بۆ ئادەمیزاد، 
\q1  
\v 22 با قوربانی سوپاسگوزاری بکەن، 
\q2 بە هەلهەلەوە باسی کردارەکانی بکەن. 
\b  
\q1  
\v 23 هەندێک بە کەشتی دابەزینە ناو دەریا، 
\q2 ئەوانەی لە دەریای گەورە بازرگانییان دەکرد. 
\q1  
\v 24 ئەوان کارەکانی یەزدانیان بینی، 
\q2 کارە سەرسوڕهێنەرەکانی لە قووڵایی. 
\q1  
\v 25 بە قسەی ئەو ڕەشەبا هەستا، 
\q2 شەپۆلەکانی بەرزکردەوە. 
\q1  
\v 26 بەرز دەبنەوە بۆ ئاسمان، دادەبەزنە ناو قووڵاییەکان، 
\q2 گیانیان لە مەترسی دەتوێتەوە. 
\q1  
\v 27 وەک سەرخۆش سەرسم دەدەن و بە ئەملا و ئەولادا دەکەون، 
\q2 نازانن چی دەکەن. 
\q1  
\v 28 ئینجا لە تەنگانەیاندا هاواریان بۆ یەزدان کرد، 
\q2 ئەویش لە ناخۆشییەکانیان دەربازی کردن. 
\q1  
\v 29 ڕەشەبای هێدی کردەوە بۆ ئارامی، 
\q2 شەپۆلەکانی بێدەنگ کرد. 
\q1  
\v 30 دڵخۆش بوون، چونکە شەپۆلەکان هێمن بوونەوە، 
\q2 گەیاندیانی بەو بەندەرەی دەیانویست. 
\q1  
\v 31 با ئەوان ستایشی یەزدان بکەن بۆ خۆشەویستییە نەگۆڕەکەی، 
\q2 بۆ کارە سەرسوڕهێنەرەکانی بۆ ئادەمیزاد، 
\q1  
\v 32 با لەناو کۆڕی خەڵک بەرزی بکەنەوە، 
\q2 لە ئەنجومەنی پیرەکان ستایشی بکەن. 
\b  
\q1  
\v 33 ڕووباری کردە بیابان و 
\q2 سەرچاوەی ئاوەکانی کردە زەوی تینوو، 
\q1  
\v 34 خاکی بە پیتی کردە زەوی بێ کەڵک، 
\q2 لەبەر خراپەی ئەوانەی تێیدا دانیشتبوون. 
\q1  
\v 35 بیابانی کردە گۆمە ئاو و 
\q2 زەوی وشکی کردە سەرچاوەی ئاوەکان. 
\q1  
\v 36 برسییەکانی لەوێ نیشتەجێ کرد، 
\q2 شاری نیشتەجێبوونیان دامەزراند. 
\q1  
\v 37 کێڵگەیان چاند و ڕەزەمێویان ڕواند، 
\q2 دەغڵیان بە بەروبووم بوو. 
\q1  
\v 38 بەرەکەتداری کردن و زۆر زیاد بوون، 
\q2 ئاژەڵی ئەوانی کەم نەکردەوە. 
\b  
\q1  
\v 39 ئینجا کەم بوونەوە و چەمانەوە، 
\q2 لەژێر باری خراپەکاری و ناخۆشی. 
\q1  
\v 40 ئەوەی ڕیسوایی بەسەر میرەکاندا دەڕێژێت، 
\q2 لە چۆڵەوانییەکی بێ ڕێگا گومڕای کردن. 
\q1  
\v 41 بەڵام هەژاری لە زەلیلی بەرز کردەوە، 
\q2 وەک ڕانە مەڕ بنەماڵەی ئەوانی زیاد کرد. 
\q1  
\v 42 سەرڕاستەکان ئەمە دەبینن و دڵخۆش دەبن، 
\q2 بەڵام هەموو خراپەکاران دەمیان دەگیرێت. 
\b  
\q1  
\v 43 کێ دانایە، با سەرنج بداتە ئەمانە و 
\q2 لە خۆشەویستییە نەگۆڕەکەی یەزدان تێبگات. 
\c 108  
\cl زەبووری 108 
\d گۆرانییەک. زەبوورێکی داود. 
\q1  
\v 1 ئەی خودایە، دڵم چەسپاوە، 
\q2 بە هەموو گیانم سروود دەڵێم و مۆسیقا دەژەنم. 
\q1  
\v 2 ئەی ساز و قیسارە، هەستن! 
\q2 من بەرەبەیانان هەڵدەستم. 
\q1  
\v 3 ئەی یەزدان، لەنێو گەلان ستایشت دەکەم، 
\q2 لەنێو نەتەوەکان گۆرانیت بۆ دەڵێم، 
\q1  
\v 4 چونکە خۆشەویستییە نەگۆڕەکەت مەزنە، لە ئاسمان بەرزترە، 
\q2 دڵسۆزیشت دەگاتە هەورەکان. 
\q1  
\v 5 ئەی خودایە، بەسەر ئاسماندا بەرزببەوە، 
\q2 با شکۆی تۆ بەسەر هەموو زەوییەوە بێت. 
\b  
\q1  
\v 6 بە دەستی ڕاستت دەربازمان بکە و یارمەتیمان بدە، 
\q2 بۆ ئەوەی خۆشەویستانت ڕزگاریان بێت. 
\q1  
\v 7 خودا لە پیرۆزگاکەی خۆیەوە فەرموویەتی: 
\q2 «بە هاواری خۆشییەوە شەخەم دابەش دەکەم و 
\q2 دۆڵی سوکۆت\f + \fr 108:7 \ft ناوی دوو شاری کۆنە. شەخەم شارێکی شوورابەند بوو لە پاڵ کێوی گریزیم، سوکۆتیش دەکەوتە دووری شەش کیلۆمەتر لە ڕۆژهەڵاتی ڕووباری ئوردون.‏\f* دەپێوم. 
\q1  
\v 8 گلعاد هی منە، مەنەشەش هی منە، 
\q2 ئەفرایم کڵاوی منە، 
\q2 یەهودا\f + \fr 108:8 \ft گلعاد کوڕی ماکیرە و کوڕەزای منەششێیە و منەششێش نۆبەرەی یوسفە، ئەفرایمیش کوڕی دووەمی یوسفە، یەهوداش کوڕی یاقوبە، بۆیە ئەم ناوانە بوون بە ناوی هۆز و عەشیرەتەکانی ئیسرائیل و هەروەها ناوی شار و ناوچەکانیان.‏\f* داری دەسەڵاتی منە. 
\q1  
\v 9 مۆئاب\f + \fr 108:9 \ft خاکی مۆئابییەکان، دەکەوتە بەشی ڕۆژهەڵاتی دەریای مردوو.‏\f* دەستشۆرمە، 
\q2 پێڵاوەکەم فڕێدەدەمە سەر ئەدۆم، 
\q2 لەسەر فەلەستیە هاواری سەرکەوتن دەکەم.» 
\b  
\q1  
\v 10 کێیە دەمباتە شاری قەڵابەند؟ 
\q2 کێیە پێشڕەویم دەکات بۆ ئەدۆم؟ 
\q1  
\v 11 ئەی خودایە، مەگەر تۆ نیت کە ئێمەت ڕەت کردووەتەوە و 
\q2 ئیتر لەگەڵ لەشکرەکانمان دەرناچیت؟ 
\q1  
\v 12 یارمەتیمان بدە بەرامبەر بە دوژمنەکە، 
\q2 چونکە ڕزگاری لە مرۆڤەوە پووچە. 
\q1  
\v 13 لەگەڵ خودا سەرکەوتن بەدەستدەهێنین، 
\q2 هەروەها ئەوە دوژمنەکانمان دەخاتە ژێر پێ. 
\c 109  
\cl زەبووری 109 
\d بۆ سەرۆکی کۆمەڵی مۆسیقاژەنان، زەبوورێکی داود. 
\q1  
\v 1 ئەی خودایە، ئەوەی ستایشت دەکەم، 
\q2 بێدەنگ مەبە، 
\q1  
\v 2 چونکە دەمی بەدکار و دەمی فریودەر لێم کراونەتەوە، 
\q2 بە زمانی درۆ قسەم لەسەر دەکەن. 
\q1  
\v 3 بە قسەی ڕقەوە دەوریان گرتووم، 
\q2 بەبێ هۆ لە دژم دەجەنگن. 
\q1  
\v 4 لە جیاتی خۆشەویستییەکەم دژایەتیم دەکەن، 
\q2 بەڵام من نوێژم کردووە. 
\q1  
\v 5 لە پاداشتی چاکە خراپەم لەگەڵ دەکەن، 
\q2 ڕقیش لە پاداشتی خۆشەویستیم. 
\b  
\q1  
\v 6 بەدکارێکی لەسەر دابنێ، 
\q2 با سکاڵاکار لەلای ڕاستیەوە ڕاوەستێت. 
\q1  
\v 7 با لە دادگایی تاوانبار بکرێت، 
\q2 با نوێژی بۆی بە گوناه دابنرێت. 
\q1  
\v 8 با ڕۆژگاری کورت بێت، 
\q2 یەکێکی دیکە ئەرکەکەی ئەو وەربگرێت! 
\q1  
\v 9 با کوڕەکانی هەتیو بن، 
\q2 ژنی بێوەژن بێت. 
\q1  
\v 10 با کوڕەکانی سەرگەردان بن و سواڵ بکەن، 
\q2 لە ماڵە کاولەکانیان دەربکرێن. 
\q1  
\v 11 با هەرچی هەیەتی خاوەن قەرز بیبات، 
\q2 بێگانەش بەری ڕەنجی تاڵان بکەن. 
\q1  
\v 12 با کەس نەبێت دەستی خۆشەویستی بۆ درێژ بکات، 
\q2 کەس نەبێت دڵی بە هەتیوەکانی بسووتێت! 
\q1  
\v 13 با نەوەکانی ببڕێتەوە، 
\q2 ناوی لە نەوەی داهاتوو بسڕێتەوە! 
\q1  
\v 14 با تاوانەکانی باوباپیرانی بخرێنە بەردەم یەزدان، 
\q2 با گوناهەکانی دایکی نەسڕێنەوە! 
\q1  
\v 15 با هەمیشە لەبەردەم یەزدان بن 
\q2 هەتا یادیان لەسەر زەوی ببڕێتەوە! 
\b  
\q1  
\v 16 لەبەر ئەوەی بیری نەکردەوە کە خۆشەویستی نەگۆڕ بنوێنێت، 
\q2 بەڵکو کەسی هەژار و نەدار و دڵشکاوی ڕاوناوە و کوشتووە. 
\q1  
\v 17 حەزی لە نەفرەت لێکردن بوو، 
\q2 با بۆی بێت! 
\q2 دڵشاد نەبوو بە داوای بەرەکەت بۆ کردن، 
\q2 با لێی دووربکەوێتەوە! 
\q1  
\v 18 نەفرەتی وەک کراس لەبەرکردبوو، 
\q2 وەک ئاو چووە ناو لەشی، 
\q2 وەک ڕۆن چووە ناو ئێسقانەکانی. 
\q1  
\v 19 با وەک بەرگێک بێ لە خۆی بیپێچێتەوە، 
\q2 هەمیشە وەک پشتێنێک بێ لە خۆی بیبەستێت! 
\q1  
\v 20 با ئەمە کرێی یەزدان بێت بۆ سکاڵاکارانم، 
\q2 ئەوانەی بە خراپە لە دژی من دەدوێن. 
\b  
\q1  
\v 21 بەڵام تۆ ئەی یەزدانی پەروەردگار، 
\q2 لە پێناوی ناوی خۆت چاکەم لەگەڵ بکە، 
\q2 دەربازم بکە، چونکە خۆشەویستییە نەگۆڕەکەت چاکە. 
\q1  
\v 22 لەبەر ئەوەی من هەژار و نەدارم، 
\q2 دڵم لە ناخمدا بریندارە. 
\q1  
\v 23 وەک سێبەری ئێوارە دەڕۆم، 
\q2 وەک کوللە هەڵدەوەرێم. 
\q1  
\v 24 ئەژنۆم شل بووە لەبەر ڕۆژووگرتن، 
\q2 لەشم لاواز بووە لە کەمی چەوری. 
\q1  
\v 25 بووم بە سووکایەتی بۆیان، 
\q2 دەمبینن سەر بادەدەن. 
\b  
\q1  
\v 26 ئەی یەزدان، خودای من، یارمەتیم بدە، 
\q2 بەگوێرەی خۆشەویستییە نەگۆڕەکەت ڕزگارم بکە. 
\q1  
\v 27 با بزانن کە ئەمە دەستی تۆیە، 
\q2 ئەی یەزدان، کە تۆ ئەمەت کردووە. 
\q1  
\v 28 ئەوان نەفرەت دەکەن، بەڵام تۆ بەرەکەت دەدەیت، 
\q2 هەستان و شەرمەزار بوون، 
\q2 بەڵام خزمەتکاری تۆ دڵخۆش بوو. 
\q1  
\v 29 با سکاڵاکارانم بەرگی نامەردی بکەنە بەر، 
\q2 با شەرمەزاری وەک کەوا لە خۆیان بئاڵێنن. 
\b  
\q1  
\v 30 بە دەمی خۆم زۆر سوپاسی یەزدان دەکەم، 
\q2 لەنێو خەڵکێکی زۆر ستایشی دەکەم، 
\q1  
\v 31 چونکە ئەو لە دەستەڕاستی نەدار ڕادەوەستێت، 
\q2 بۆ ڕزگارکردنی لەوانەی حوکمی بەسەردا دەدەن. 
\c 110  
\cl زەبووری 110 
\d زەبوورێکی داود. 
\q1  
\v 1 یەزدان بە خاوەن شکۆی منی فەرموو: 
\b  
\q2 «لە دەستەڕاستم دابنیشە، 
\q2 هەتا دوژمنانت دەکەمە تەختەپێ\f + \fr 110:1 \ft پاشا بەهۆی ئەوەی کورسییەکەی بەرزتر بووە، تەختەیەک لەژێر پێی بووە، پاشا وێنەی دوژمنەکانی لەسەر کێشاوە، وەک هێمایەک بۆ خستنە ژێر پێیان.‏\f* بۆ پێیەکانت.» 
\b  
\q1  
\v 2 یەزدان لە سییۆنەوە هێز و دەسەڵاتەکەت فراوان دەکات، 
\q2 لەناو دوژمنەکانت فەرمانڕەوایەتی دەکەیت. 
\q1  
\v 3 گەلەکەت لە ڕۆژی هێزت خۆیان پێشکەش دەکەن، 
\q2 بە ئاراییشتێکی پیرۆزەوە لە منداڵدانی بەرەبەیانەوە، 
\q2 تۆ شەونم لە گەنجییەتیت وەردەگریت. 
\b  
\q1  
\v 4 یەزدان سوێندی خواردووە و بڕیاری ناگۆڕێت: 
\q2 «هەتاهەتایە تۆ کاهینیت لە پلەی مەلکیسادق\f + \fr 110:4 \ft باڵاترین کاهینە لەلای خودای گەورە. بڕوانە \xt پەیدابوون 14‏:18‏\ft ‏.‏\f*.» 
\b  
\q1  
\v 5 خاوەن شکۆ لە دەستەڕاستی تۆیە، 
\q2 لە ڕۆژی تووڕەییەکەی پاشایان وردوخاش دەکات. 
\q1  
\v 6 لەنێو نەتەوەکان حوکم دەدات، خاکیان پڕ دەکات لە تەرم، 
\q2 سەرۆکەکان لەسەر هەموو زەوی وردوخاش دەکات. 
\q1  
\v 7 پاشا لە جۆگەی دەم ڕێگا دەخواتەوە، 
\q2 لەبەر هەموو ئەمانە سەری بەرز ڕادەگرێت. 
\c 111  
\cl زەبووری 111 
\q1  
\v 1 هەلیلویا! 
\b  
\q1 بە هەموو دڵەوە ستایشی یەزدان دەکەم، 
\q2 لە ئەنجومەنی سەرڕاستان و لە کۆبوونەوەکان. 
\b  
\q1  
\v 2 کردارەکانی یەزدان مەزنن، 
\q2 هەموو ئەوانەی لێی ورد دەبنەوە خۆشی لێ دەبینن. 
\q1  
\v 3 بەرز و شکۆمەندە کردارەکانی، 
\q2 ڕاستودروستییەکەشی هەتاهەتایە چەسپاوە. 
\q1  
\v 4 وای کردووە کارە سەرسوڕهێنەرەکانی یاد بکرێنەوە، 
\q2 یەزدان میهرەبان و بە بەزەییە. 
\q1  
\v 5 خواردن دەداتە ئەوانەی لێی دەترسن، 
\q2 هەمیشە پەیمانی خۆی لەبیرە. 
\b  
\q1  
\v 6 هێزی کردارەکانی خۆی نیشانی گەلەکەی داوە، 
\q2 بەوەی کە میراتی نەتەوەکانی پێداون. 
\q1  
\v 7 کردارەکانی دەستی دڵسۆزی و دادپەروەرییە، 
\q2 ڕێنماییەکانی جێی متمانەن، 
\q1  
\v 8 هەتاهەتایە چەسپاون، 
\q2 بە دڵسۆزی و سەرڕاستی دروستکراون. 
\q1  
\v 9 کڕینەوەی بۆ گەلی خۆی نارد، 
\q2 فەرمانی هەتاهەتایی بۆ پەیمانەکەی داوە، 
\q2 پیرۆز و سامناکە ناوی. 
\b  
\q1  
\v 10 لەخواترسی سەرەتای داناییە، 
\q2 تێگەیشتنێکی باشە بۆ هەموو ئەوانەی کار بە ڕێنماییەکانی دەکەن. 
\q2 ستایشکردن بۆ ئەوە هەتاهەتایە چەسپاوە. 
\c 112  
\cl زەبووری 112 
\q1  
\v 1 هەلیلویا! 
\b  
\q1 خۆزگە دەخوازرێ بەو کەسەی لە یەزدان دەترسێت، 
\q2 بە ڕاسپاردەکانی زۆر دڵخۆشە. 
\b  
\q1  
\v 2 وەچەی لەسەر زەوی بەهێز دەبن، 
\q2 نەوەی سەرڕاستان بەرەکەتدار دەبن. 
\q1  
\v 3 سامان و دەوڵەمەندی لە ماڵیەتی، 
\q2 ڕاستودروستییەکەی هەتاهەتایە چەسپاوە. 
\q1  
\v 4 لە تاریکیدا ڕووناکی بۆ سەرڕاستان درەوشایەوە، 
\q2 بۆ ئەوانەی کە میهرەبان و بە بەزەیی و ڕاستودروستن. 
\q1  
\v 5 چاک دەبێت بۆ ئەو کەسەی کە دڵفراوانە و قەرز دەدات، 
\q2 بە دادپەروەرییەوە ئیشوکاری خۆی ڕادەپەڕێنێت. 
\b  
\q1  
\v 6 بێگومان پیاوچاک هەتاهەتایە نالەقێت، 
\q2 هەتاهەتایە یادی دەکرێتەوە. 
\q1  
\v 7 لە بیستنی هەواڵی خراپ ناترسێت، 
\q2 دڵی پتەوە، پشتی بە یەزدان بەستووە. 
\q1  
\v 8 دڵی چەسپاوە و ناترسێت، 
\q2 لە کۆتاییدا سەرکەوتوو دەبێت و شکستی دوژمنانی دەبینێت. 
\q1  
\v 9 بە دڵفراوانییەوە بە هەژارانی بەخشیوە، 
\q2 ڕاستودروستییەکەی هەتاهەتایە چەسپاوە، 
\q2 بە ڕێزەوە شکۆمەندییەکەی بەرز دەبێتەوە. 
\b  
\q1  
\v 10 بەدکار ئەمە دەبینێت و بێزار دەبێت، 
\q2 ددانەکانی جیڕدەکاتەوە و دەتوێتەوە، 
\q2 ئارەزووی بەدکاران لەناودەچێت. 
\c 113  
\cl زەبووری 113 
\q1  
\v 1 هەلیلویا! 
\b  
\q1 ئەی بەندەکانی یەزدان، ستایشی بکەن، 
\q2 ستایشی ناوی یەزدان بکەن. 
\q1  
\v 2 با ستایشی ناوی یەزدان بکرێت، 
\q2 لە ئێستاوە و هەتاهەتایە. 
\q1  
\v 3 لە ڕۆژهەڵاتەوە هەتا ڕۆژئاوا، 
\q2 با ستایشی ناوی یەزدان بکرێت. 
\b  
\q1  
\v 4 یەزدان لە سەرووی هەموو نەتەوەکانەوەیە، 
\q2 شکۆمەندی بەسەر ئاسمانەوەیە. 
\q1  
\v 5 کێ وەک یەزدانی پەروەردگارمانە، 
\q2 ئەوەی لە ئاسمان دانیشتووە، 
\q1  
\v 6 ئەوەی دەچەمێتەوە 
\q2 هەتا بڕوانێتە ئاسمان و زەوی؟ 
\b  
\q1  
\v 7 ئەو هەژار لەناو خۆڵ ڕاست دەکاتەوە، 
\q2 کڵۆڵ لەناو زبڵخانە بەرز دەکاتەوە، 
\q1  
\v 8 بۆ ئەوەی لەگەڵ میران داینیشێنێت، 
\q2 لەگەڵ میرانی گەلی خۆی. 
\q1  
\v 9 ئافرەتی نەزۆک دەکاتە خاوەن ماڵ، 
\q2 دەیکاتە دایکێکی شادمان لەنێو منداڵانی. 
\b  
\q1 هەلیلویا! 
\c 114  
\cl زەبووری 114 
\q1  
\v 1 کاتێک ئیسرائیل لە میسر هاتنە دەرەوە، 
\q2 بنەماڵەی یاقوب لەنێو گەلێکی نامۆ زمان دەرچوون، 
\q1  
\v 2 یەهودا بووە پیرۆزگای خودا، 
\q2 ئیسرائیل بووە جێی فەرمانڕەوایەتی. 
\b  
\q1  
\v 3 دەریا بینی و هەڵات، 
\q2 ڕووباری ئوردون بەرەو پاش کشایەوە. 
\q1  
\v 4 چیاکان وەک بەران بازیان دا، 
\q2 گردەکان وەک بەرخۆلە. 
\b  
\q1  
\v 5 چیتە ئەی دەریا، بۆ وا هەڵدێیت؟ 
\q2 ئەی ئوردون، بۆ بەرەو پاش دەکشێیتەوە؟ 
\q1  
\v 6 ئەی چیاکان، بۆ وەک بەران باز دەدەن و 
\q2 ئێوەش ئەی گردەکان، وەک بەرخۆلە؟ 
\b  
\q1  
\v 7 ئەی زەوی لەبەردەم پەروەردگار بلەرزە، 
\q2 لەبەردەم خودای یاقوب، 
\q1  
\v 8 ئەوەی بەردی کرد بە گۆمی ئاو، 
\q2 بەردەئەستێی کردە کانیاو. 
\c 115  
\cl زەبووری 115 
\q1  
\v 1 بۆ ئێمە نا، ئەی یەزدان، بۆ ئێمە نا، 
\q2 بەڵکو بۆ ناوی خۆت شکۆ ببەخشە، 
\q2 لەبەر خۆشەویستییە نەگۆڕەکەت و دڵسۆزییەکەت. 
\b  
\q1  
\v 2 بۆچی نەتەوەکان بڵێن: 
\q2 «کوا، خودایان لەکوێیە؟» 
\q1  
\v 3 خودامان لە ئاسمانە، 
\q2 هەرچی حەز بکات، دەیکات. 
\q1  
\v 4 بتەکانیان زێڕ و زیون، 
\q2 دەستکردی مرۆڤن. 
\q1  
\v 5 دەمیان هەیە، بەڵام قسە ناکەن، 
\q2 چاویان هەیە، بەڵام نابینن، 
\q1  
\v 6 گوێیان هەیە، بەڵام نابیستن، 
\q2 لووتیان هەیە، بەڵام بۆن ناکەن، 
\q1  
\v 7 دەستیان هەیە، بەڵام دەست لە هیچ نادەن، 
\q2 پێیان هەیە، بەڵام ناڕۆن، 
\q2 دەنگ لە گەروویان نایەتە دەرەوە. 
\q1  
\v 8 دروستکەرەکانیان وەک ئەوان دەبن، 
\q2 هەروەها هەموو ئەوانەش کە پشتیان پێ دەبەستن. 
\b  
\q1  
\v 9 ئەی بنەماڵەی ئیسرائیل، پشت بە یەزدان ببەستن. 
\q2 ئەو یارمەتیدەر و قەڵغانیانە. 
\q1  
\v 10 ئەی بنەماڵەی هارون، پشت بە یەزدان ببەستن. 
\q2 ئەو یارمەتیدەر و قەڵغانیانە. 
\q1  
\v 11 ئەی ئەوانەی لەخواترسیتان لە دڵدایە، پشت بە یەزدان ببەستن. 
\q2 ئەو یارمەتیدەر و قەڵغانیانە. 
\b  
\q1  
\v 12 یەزدان ئێمەی لەبیرە و بەرەکەتدارمان دەکات، 
\q2 بەرەکەت بە بنەماڵەی ئیسرائیل دەبەخشێت، 
\q2 بەرەکەت بە بنەماڵەی هارون دەبەخشێت. 
\q1  
\v 13 بەرەکەت بەوانە دەبەخشێت کە لەخواترسییان لە دڵدایە، 
\q2 گەورە و بچووکیش. 
\b  
\q1  
\v 14 با یەزدان هەر زیادتان بکات، 
\q2 ئێوە و منداڵەکانتان. 
\q1  
\v 15 با ئێوە بە یەزدان بەرەکەتدار بن، 
\q2 دروستکەری ئاسمان و زەوی. 
\b  
\q1  
\v 16 ئاسمان ئاسمانی یەزدانە، 
\q2 زەویشی بە ئادەمیزاد بەخشیوە. 
\q1  
\v 17 نە مردووان ستایشی یەزدان دەکەن، 
\q2 نە هەموو ئەوانەی شۆڕ دەبنەوە ناو بێدەنگی، 
\q1  
\v 18 بەڵام ئێمە ستایشی یەزدان دەکەین، 
\q2 لە ئێستاوە و هەتاهەتایە. 
\b  
\q2 هەلیلویا! 
\c 116  
\cl زەبووری 116 
\q1  
\v 1 یەزدانم خۆشدەوێت، 
\q2 چونکە گوێ لە دەنگ و لە پاڕانەوەم دەگرێت، 
\q1  
\v 2 چونکە گوێی خۆی بۆم شل کرد، 
\q2 هەتا ماوم هەر لێی دەپاڕێمەوە. 
\b  
\q1  
\v 3 تۆڕی مەرگ دەوری دام، 
\q2 ناخۆشی جیهانی مردووان کەوتە سەرم، 
\q2 دەرد و تەنگانەم چێژت. 
\q1  
\v 4 بە ناوی یەزدانەوە دەپاڕێمەوە: 
\q2 «ئەی یەزدان، تکات لێ دەکەم، گیانم دەرباز بکە!» 
\b  
\q1  
\v 5 یەزدان میهرەبان و ڕاستودروستە، 
\q2 خودامان بە بەزەییە. 
\q1  
\v 6 یەزدان چاودێری خەڵکی ساکار دەکات، 
\q2 کاتێک زەلیل بووم، ئەو ڕزگاری کردم. 
\b  
\q1  
\v 7 ئەی گیانی من، بگەڕێوە بۆ ئارامی خۆت، 
\q2 چونکە یەزدان چاکەی بەسەرتدا باراند. 
\b  
\q1  
\v 8 تۆ گیانی منت لە مردن ڕزگار کرد، 
\q2 چاوەکانم لە فرمێسک، 
\q2 پێیەکانم لە خزان، 
\q1  
\v 9 تاکو دۆستایەتی یەزدان بکەم 
\q2 لە خاکی زیندووان. 
\b  
\q1  
\v 10 باوەڕم هەبوو، بۆیە گوتم: 
\q2 «من زۆر دەردەدارم!» 
\q1  
\v 11 من لە کاتی تۆقینەکەمدا گوتم: 
\q2 «مرۆڤ هەموو درۆزنن!» 
\b  
\q1  
\v 12 چی بدەمەوە یەزدان، 
\q2 بەرامبەر هەموو چاکەکانی بۆ من. 
\b  
\q1  
\v 13 جامی ڕزگاری بەرز دەکەمەوە و 
\q2 بە ناوی یەزدانەوە دەپاڕێمەوە. 
\q1  
\v 14 نەزرەکانم بۆ یەزدان بەجێدەهێنم، 
\q2 بەرامبەر بە هەموو گەلەکەی. 
\b  
\q1  
\v 15 یەزدان مردنی خۆشەویستانی 
\q2 لەلا سەنگینە. 
\q1  
\v 16 ئەی یەزدان، من بە ڕاستی خزمەتکاری تۆم، 
\q2 من خزمەتکاری تۆم، کوڕی کەنیزەکەت، 
\q2 تۆ کۆتەکانی منت کردەوە. 
\b  
\q1  
\v 17 قوربانی سوپاسگوزاری بۆ تۆ سەردەبڕم، 
\q2 بە ناوی یەزدانەوە دەپاڕێمەوە. 
\q1  
\v 18 نەزرەکانم بۆ یەزدان بەجێدەهێنم، 
\q2 بەرامبەر بە هەموو گەلەکەی، 
\q1  
\v 19 لە حەوشەی ماڵی یەزداندا، 
\q2 لە ناوەندی تۆدا، ئەی ئۆرشەلیم. 
\b  
\q1 هەلیلویا! 
\c 117  
\cl زەبووری 117 
\q1  
\v 1 ئەی هەموو نەتەوەکان، ستایشی یەزدان بکەن! 
\q2 ئەی هەموو گەلان، ستایشی بکەن، 
\q1  
\v 2 چونکە خۆشەویستییە نەگۆڕەکەی بەسەرمانەوە گەورەیە، 
\q2 دڵسۆزی یەزدانیش هەتاهەتاییە! 
\b  
\q1 هەلیلویا! 
\c 118  
\cl زەبووری 118 
\q1  
\v 1 ستایشی یەزدان بکەن، لەبەر ئەوەی چاکە، 
\q2 خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\b  
\q1  
\v 2 با ئیسرائیل بڵێ: 
\q2 «خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە.» 
\q1  
\v 3 با بنەماڵەی هارون بڵێن: 
\q2 «خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە.» 
\q1  
\v 4 با ئەوانەی لەخواترسییان لە دڵدایە بڵێن: 
\q2 «خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە.» 
\b  
\q1  
\v 5 لە تەنگانەدا هاواری یەزدانم کرد، 
\q2 بە دەنگمەوە هات و ئازادی کردم. 
\q1  
\v 6 یەزدان لەلای منە، ناترسم، 
\q2 مرۆڤ دەتوانێت چیم لێ بکات؟ 
\q1  
\v 7 یەزدان لەلای منە، ئەو یارمەتیدەری منە، 
\q2 سەرکەوتووانە تەماشای ئەوانە دەکەم کە ڕقیان لێمە. 
\b  
\q1  
\v 8 پەنابردنە بەر یەزدان باشترە 
\q2 لە پشتبەستن بە مرۆڤ. 
\q1  
\v 9 پەنابردنە بەر یەزدان باشترە 
\q2 لە پشتبەستن بە میران. 
\q1  
\v 10 هەموو نەتەوەکان ئابڵوقەیان دام، 
\q2 بە ناوی یەزدان ڕیشەکێشم کردن. 
\q1  
\v 11 ئابڵوقەیان دام و دەوریان گرتم، 
\q2 بە ناوی یەزدان ڕیشەکێشم کردن. 
\q1  
\v 12 وەک کوورە هەنگ تێم ئاڵان، 
\q2 وەک ئاگری دڕکوداڵ کوژانەوە، 
\q2 بە ناوی یەزدان ڕیشەکێشم کردن. 
\q1  
\v 13 توند پاڵیان پێوەنام بۆ ئەوەی بکەوم، 
\q2 بەڵام یەزدان یارمەتی داوم. 
\q1  
\v 14 یەزدان هێز و گۆرانی منە، 
\q2 یەزدان بووەتە ڕزگاریی من. 
\b  
\q1  
\v 15 دەنگی هەلهەلە و ڕزگاری دێت لە خێوەتی ڕاستودروستان: 
\q2 «دەستی ڕاستی یەزدان کاری ئازایانە دەکات، 
\q1  
\v 16 دەستی ڕاستی یەزدان بەرز بووەتەوە، 
\q2 دەستی ڕاستی یەزدان کاری ئازایانە دەکات.» 
\q1  
\v 17 من نامرم، بەڵکو دەژیم و 
\q2 باسی کردارەکانی یەزدان دەکەم. 
\q1  
\v 18 یەزدان بە توندی تەمبێی کردم، 
\q2 بەڵام نەیدامە دەست مەرگ. 
\q1  
\v 19 دەرگاکانی ڕاستودروستیم لێ بکەنەوە، 
\q2 پێیدا دەچمە ژوورەوە و ستایشی یەزدان دەکەم. 
\q1  
\v 20 ئەم دەرگایە هی یەزدانە، 
\q2 ڕاستودروستان پێیدا دەچنە ژوورەوە. 
\q1  
\v 21 ستایشت دەکەم کە فریام کەوتی، 
\q2 بۆم بووی بە ڕزگاری. 
\b  
\q1  
\v 22 ئەو بەردەی وەستاکان ڕەتیان کردەوە 
\q2 بوو بە گرنگترین بەردی بناغە\f + \fr 118:22 \ft گرنگترین بەردی بناغە: بەردی قولینچک، بەردێکی گەورەیە لە گۆشەی دیوار دادەنرێت لەو بەردانە بەهێزترە کە لە دیوارەکە بەکاردێت و دەبێتە هۆی بەهێزکردنی دیوارەکە.‏\f*. 
\q1  
\v 23 ئەمە لەلایەن یەزدانەوە بوو، 
\q2 لەبەرچاومان سەیرە. 
\q1  
\v 24 ئەمە ئەو ڕۆژەیە کە یەزدان دروستی کردووە، 
\q2 با تێیدا شاد و دڵخۆش بین. 
\b  
\q1  
\v 25 ئەی یەزدان، تکایە، ڕزگارمان بکە، 
\q2 ئەی یەزدان، تکایە، سەرکەوتوومان بکە. 
\b  
\q1  
\v 26 پیرۆزە ئەوەی بە ناوی یەزدانەوە دێت، 
\q2 لە ماڵی یەزدانەوە داوای بەرەکەتتان بۆ دەکەین. 
\q1  
\v 27 یەزدان خودامانە و 
\q2 ئەو ڕووناکی خۆی بەسەرماندا درەوشاندەوە. 
\q1 قوربانی جەژن بە گوریس ببەستنەوە 
\q2 بە قۆچەکانی قوربانگا. 
\b  
\q1  
\v 28 تۆ خودای منیت و منیش ستایشت دەکەم، 
\q2 تۆ خودای منیت، بە گەورەت دەزانم. 
\b  
\q1  
\v 29 ستایشی یەزدان بکەن، لەبەر ئەوەی چاکە، 
\q2 خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\c 119  
\cl زەبووری 119 
\s1 א (ئەلف)\f + \fr 119:0 \ft ڕێکخستنی پیتەکان بەپێی ڕێکخستنی عیبرییە \+tl ئەلف، بێت، گیمێل‏\+tl*… هتد، لە دەقە عیبرییەکە سەری دێڕەکان بەو پیتە دەستپێدەکەن کە لەژێر بەشی ئەو پیتەن.‏\f* 
\q1  
\v 1 خۆزگە بەوانە دەخوازرێ کە ڕێگایان تەواوە، 
\q2 ئەوانەی بەپێی فێرکردنی یەزدان دەڕۆن. 
\q1  
\v 2 خۆزگە بەوانە دەخوازرێ کە یاساکەی پەیڕەو دەکەن، 
\q2 بە هەموو دڵەوە ڕوو لە خودا دەکەن. 
\q1  
\v 3 هەروەها خراپە ناکەن و 
\q2 بە ڕێگای ئەودا دەڕۆن. 
\q1  
\v 4 تۆ ڕێنماییەکانت داوە، 
\q2 بۆ ئەوەی خەڵک بە تەواوی گوێڕایەڵی بن. 
\q1  
\v 5 خۆزگە ڕێگاکانم بچەسپابوونایە 
\q2 لە بەجێگەیاندنی فەرزەکانت! 
\q1  
\v 6 ئەو کاتە شەرمەزار نەدەبووم، 
\q2 کە دەمڕوانییە هەموو ڕاسپاردەکانت. 
\q1  
\v 7 بە دڵی پاکەوە ستایشت دەکەم، 
\q2 کاتێک فێری حوکمە ڕاستودروستەکانت دەبم. 
\q1  
\v 8 فەرزەکانت بەجێدەهێنم، 
\q2 هەرگیز وازم لێ مەهێنە. 
\s1 ב (بێت) 
\q1  
\v 9 گەنج بە چی هەڵسوکەوتی خۆی بێگەرد دەکات؟ 
\q2 بە پاراستنی وشەکانت. 
\q1  
\v 10 بە هەموو دڵەوە ڕوو لە تۆ دەکەم، 
\q2 مەهێڵە لە ڕاسپاردەکانت گومڕابم. 
\q1  
\v 11 وشەکانی تۆم لەناو دڵم پاراستووە، 
\q2 تاکو لە دژی تۆ گوناه نەکەم. 
\q1  
\v 12 ئەی یەزدان، ستایش بۆ تۆ! 
\q2 فێری فەرزەکانی خۆتم بکە. 
\q1  
\v 13 بە لێوەکانی خۆم، 
\q2 باسی هەموو حوکمەکانی دەمی تۆ دەکەم. 
\q1  
\v 14 بە پەیڕەوکردنی یاساکانت شاد دەبم، 
\q2 وەک کەسێک سامانێکی زۆر دەبینێتەوە. 
\q1  
\v 15 لە ڕێنماییەکانت ورد دەبمەوە، 
\q2 چاو دەبڕمە ڕێگاکانت. 
\q1  
\v 16 بە فەرزەکانت دڵخۆش دەبم، 
\q2 وشەکانی تۆم لە یاد ناچێت. 
\s1 ג (گیمێل) 
\q1  
\v 17 چاکە لەگەڵ خزمەتکاری خۆت بکە، 
\q2 تاکو بژیم و گوێڕایەڵی فەرمانەکەت بم. 
\q1  
\v 18 چاوم بکەرەوە تاکو ئەوانە ببینم، 
\q2 کردەوە سەرسوڕهێنەرەکان لە فێرکردنت. 
\q1  
\v 19 من نامۆم لە زەوی، 
\q2 ڕاسپاردەکانی خۆتم لێ مەشارەوە. 
\q1  
\v 20 گیانم توایەوە لە تامەزرۆیی 
\q2 بۆ حوکمەکانت لە هەموو کاتێک. 
\q1  
\v 21 سەرزەنشتی لووت بەرزە نەفرەت لێکراوەکانت کرد، 
\q2 کە لە ڕاسپاردەکانی تۆ گومڕا بوون. 
\q1  
\v 22 ڕیسوایی و سووکایەتیم لەسەر لابە، 
\q2 چونکە یاسای تۆم پەیڕەو کردووە. 
\q1  
\v 23 هەرچەندە میرەکان دادەنیشن و لە دژم پیلان دەگێڕن، 
\q2 بەڵام خزمەتکارەکەت لە فەرزەکانت ورد دەبێتەوە. 
\q1  
\v 24 یاساکانت شادمانی منن، 
\q2 ئەوانە ڕاوێژکارەکانی منن. 
\s1 ד (دالێت) 
\q1  
\v 25 گیانم بە خۆڵەوە نووساوە، 
\q2 بەگوێرەی بەڵێنی خۆت بمژیێنەوە. 
\q1  
\v 26 باسی ڕێگاکانی خۆمم کرد، تۆ بەدەنگمەوە هاتیت، 
\q2 فەرزەکانی خۆتم فێر بکە. 
\q1  
\v 27 ڕێگای ڕێنماییەکانی خۆتم تێبگەیەنە، 
\q2 لە کارە سەرسوڕهێنەرەکانت ورد دەبمەوە. 
\q1  
\v 28 گیانم لە خەفەتان توایەوە، 
\q2 بەگوێرەی بەڵێنی خۆت بەهێزم بکە. 
\q1  
\v 29 ڕێگای درۆم لێ دووربخەوە، 
\q2 لەگەڵم میهرەبان بە و فێری تەوراتی خۆتم بکە. 
\q1  
\v 30 ڕێگای ڕاستیم هەڵبژاردووە، 
\q2 حوکمەکانی تۆم خستووەتە بەرچاوم. 
\q1  
\v 31 دەست بە یاساکانی تۆوە دەگرم، 
\q2 ئەی یەزدان، ڕێ مەدە شەرمەزار بم! 
\q1  
\v 32 بە ڕاکردن لەسەر ڕێگای ڕاسپاردەکانت دەڕۆم، 
\q2 چونکە دڵی منت ئازاد کرد. 
\s1 ה (هێی) 
\q1  
\v 33 ئەی یەزدان، فێری ڕێگای فەرزەکانی خۆتم بکە، 
\q2 هەتا کۆتایی بەجێیان دەهێنم. 
\q1  
\v 34 تێمبگەیەنە و فێرکردنت پەیڕەو دەکەم، 
\q2 بە هەموو دڵەوە گوێڕایەڵی دەبم. 
\q1  
\v 35 بمخە سەر ڕێگای ڕاسپاردەکانت، 
\q2 چونکە دڵخۆشم دەکەن. 
\q1  
\v 36 دڵم بخەرە سەر یاساکانت، 
\q2 نەک سەر قازانج. 
\q1  
\v 37 چاوم وەرگێڕە لە تەماشاکردنی شتی پووچ، 
\q2 لە ڕێگای خۆتدا بمبوژێنەوە. 
\q1  
\v 38 بەڵێنی خۆت بۆ خزتمەتکارەکەت بهێنە دی، 
\q2 ئەوەی بەوانەت داوە کە لێت دەترسن. 
\q1  
\v 39 ئەو سووکایەتییەم لەسەر لابە کە لێی دەترسم، 
\q2 چونکە حوکمەکانت چاکن. 
\q1  
\v 40 ئەوەتا پەرۆشی ڕێنماییەکانی تۆم، 
\q2 بە ڕاستودروستی خۆت بمژیێنەوە. 
\s1 ו (ڤاڤ) 
\q1  
\v 41 ئەی یەزدان، با خۆشەویستییە نەگۆڕەکەتم بۆ بێت، 
\q2 ڕزگارییەکەت بەگوێرەی بەڵێنی خۆت، 
\q1  
\v 42 جا وەڵامی ئەوە دەدەمەوە کە گاڵتەم پێ دەکات، 
\q2 چونکە پشتم بە بەڵێنی تۆ بەستووە. 
\q1  
\v 43 وشەی ڕاست هەرگیز لە دەمم دوور مەخەوە، 
\q2 چونکە ئومێدم بە حوکمەکانی تۆ هەیە. 
\q1  
\v 44 بە بەردەوامی گوێڕایەڵی فێرکردنی تۆ دەبم، 
\q2 هەتاهەتایە و هەتاسەر. 
\q1  
\v 45 بە ئازادی دەڕۆم، 
\q2 چونکە داواکاری ڕێنماییەکانی تۆم. 
\q1  
\v 46 لەبەردەم پاشاکانیش باسی یاساکانی تۆ دەکەم، 
\q2 شەرمەزاریش نابم. 
\q1  
\v 47 خۆشی لە ڕاسپاردەکانت دەبینم، 
\q2 چونکە حەزم لێیانە. 
\q1  
\v 48 دەست بۆ ڕاسپاردەکانت بەرز دەکەمەوە، ئەوەی خۆشم دەوێت، 
\q2 سەرنج دەدەمە فەرزەکانت. 
\s1 ז (زاین) 
\q1  
\v 49 پەیمانی خۆت لەبیر بێت بۆ خزمەتکارەکەت، 
\q2 چونکە هیوات پێم داوە. 
\q1  
\v 50 لە کاتی تەنگانەمدا دڵنەوایی من ئەمەیە: 
\q2 بەڵێنەکەت منی ژیاندەوە. 
\q1  
\v 51 لووتبەرزەکان زۆر گاڵتەم پێ دەکەن، 
\q2 بەڵام من لە فێرکردنی تۆ لام نەداوە. 
\q1  
\v 52 ئەی یەزدان، حوکمە لەمێژینەکانی تۆم هاتەوە یاد، 
\q2 دڵنەواییم هاتەوە. 
\q1  
\v 53 لەبەر بەدکاران تووڕەییم جۆشا، 
\q2 ئەوانەی وازیان لە فێرکردنی تۆ هێناوە. 
\q1  
\v 54 فەرزەکانت بوونە بابەت گۆرانییەکانم، 
\q2 لە ماڵی ئاوارەییم. 
\q1  
\v 55 ئەی یەزدان، بە شەو یادی ناوی تۆ دەکەمەوە و 
\q2 گوێڕایەڵی فێرکردنت دەبم. 
\q1  
\v 56 ئەم نەریتە بۆ من بوو: 
\q2 ڕێنماییەکانی تۆم پەیڕەو کرد. 
\s1 ח (حێیت) 
\q1  
\v 57 ئەی یەزدان، تۆ بەشی منی، 
\q2 بەڵێنم داوە گوێڕایەڵی فەرمانەکانت بم. 
\q1  
\v 58 بە هەموو دڵەوە داوای ڕەزامەندی تۆ دەکەم، 
\q2 بەپێی بەڵێنی خۆت لەگەڵم میهرەبان بە. 
\q1  
\v 59 لە ڕێگای خۆم ڕامام، 
\q2 پێم بەرەو یاساکانت وەرگێڕایەوە. 
\q1  
\v 60 خێرا بووم و دوا نەکەوتم 
\q2 لە بەجێگەیاندنی ڕاسپاردەکانت. 
\q1  
\v 61 گوریسی بەدکاران منیان بەستووەتەوە، 
\q2 بەڵام فێرکردنی تۆ لەبیر ناکەم. 
\q1  
\v 62 لە نیوەشەودا هەڵدەستم بۆ ئەوەی ستایشت بکەم 
\q2 لەسەر حوکمە ڕاستودروستەکانت. 
\q1  
\v 63 من هاوڕێی هەموو ئەوانەم لە تۆ دەترسن، 
\q2 لەوانەی ڕێنماییەکانت پەیڕەو دەکەن. 
\q1  
\v 64 ئەی یەزدان، خۆشەویستییە نەگۆڕەکەت زەوی پڕکردووە، 
\q2 فەرزەکانی خۆتم فێر بکە. 
\s1 ט (تێیت) 
\q1  
\v 65 ئەی یەزدان، چاکەت لەگەڵ خزمەتکارەکەت کرد، 
\q2 بەگوێرەی بەڵێنی خۆت. 
\q1  
\v 66 هەستی باش و زانینم فێر بکە، 
\q2 چونکە باوەڕم بە ڕاسپاردەکانت هەیە. 
\q1  
\v 67 بەر لەوەی زەلیل بم گومڕا بووم، 
\q2 بەڵام ئێستا گوێڕایەڵی فەرمایشتەکەت دەبم. 
\q1  
\v 68 تۆ چاکیت و چاکەکاری، 
\q2 فەرزەکانی خۆتم فێر بکە. 
\q1  
\v 69 لووتبەرزان درۆم بۆ هەڵدەبەستن، 
\q2 بەڵام من بە هەموو دڵەوە ڕێنماییەکانت پەیڕەو دەکەم. 
\q1  
\v 70 دڵیان وەک پیو بێ هەستە، 
\q2 بەڵام فێرکردنت شادییە بۆ من. 
\q1  
\v 71 چاک بوو بۆ من کە زەلیل بم، 
\q2 بۆ ئەوەی فێری فەرزەکانت بم. 
\q1  
\v 72 فێرکردنی دەمی تۆ 
\q2 لە هەزار زێڕ و زیو باشترە بۆ من. 
\s1 י (یۆد) 
\q1  
\v 73 دەستی تۆ دروستی کردم و دایڕشتم، 
\q2 تێمبگەیەنە تاکو فێری ڕاسپاردەکانت بم. 
\q1  
\v 74 ئەوانەی لێت دەترسن شادمان دەبن کاتێک دەمبینن، 
\q2 چونکە من هیوام بە بەڵێنی تۆ هەیە. 
\q1  
\v 75 ئەی یەزدان، زانیم کە حوکمەکانت ڕاستودروستە، 
\q2 بە دڵسۆزی زەلیلت کردم. 
\q1  
\v 76 با خۆشەویستییە نەگۆڕەکەت بۆ دڵنەواییم بێت، 
\q2 بەپێی بەڵێنەکەت بۆ خزمەتکارەکەت. 
\q1  
\v 77 با بەزەییت پێمدا بێتەوە بۆ ئەوەی بژیم، 
\q2 چونکە فێرکردنی تۆ شادمانییە بۆ من. 
\q1  
\v 78 با لووتبەرزان شەرمەزار بن، چونکە بوختانیان بۆ هەڵبەستم، 
\q2 بەڵام من سەرنج دەدەمە ڕێنماییەکانت. 
\q1  
\v 79 با ئەوانەی لێت دەترسن بگەڕێنەوە لای من، 
\q2 ئەوانەی لە یاساکانی تۆ تێدەگەن. 
\q1  
\v 80 با دڵم تەواو بێت لە فەرزەکانت، 
\q2 بۆ ئەوەی شەرمەزار نەبم. 
\s1 כ (کاف) 
\q1  
\v 81 گیانم پەرۆشی ڕزگاریی تۆیە، 
\q2 ئومێدم بە بەڵێنی تۆیە. 
\q1  
\v 82 چاوم کز بوو لە چاوەڕوانی بەڵێنەکەت، 
\q2 دەپرسم: «کەی دڵنەواییم دەکەیت؟» 
\q1  
\v 83 هەرچەندە وەک مەشکەیەکم لێهاتووە کەوا دووکەڵ دایپۆشیوە، 
\q2 فەرزەکانی تۆم لەیاد نەکردووە. 
\q1  
\v 84 خزمەتکارەکەت دەبێ چەند ڕۆژ چاوەڕێ بکات؟ 
\q2 کەی حوکم دەدەیت بەسەر ئەوانەی من دەچەوسێننەوە؟ 
\q1  
\v 85 لووتبەرزان چاڵیان بۆم هەڵکەندووە، 
\q2 ئەمەش بەگوێرەی فێرکردنی تۆ نییە! 
\q1  
\v 86 هەموو ڕاسپاردەکانت جێی متمانەن، 
\q2 فریام بکەوە، چونکە بە فێڵ دەمچەوسێننەوە! 
\q1  
\v 87 خەریک بوو لەسەر زەوی کۆتاییم پێ بهێنن، 
\q2 بەڵام من دەستبەرداری ڕێنماییەکانی تۆ نەبووم. 
\q1  
\v 88 بەپێی خۆشەویستییە نەگۆڕەکەت بمژیێنەوە، 
\q2 یاساکانی دەمی تۆ پەیڕەو دەکەم. 
\s1 ל (لامد) 
\q1  
\v 89 ئەی یەزدان، فەرمایشتی تۆ هەتاهەتاییە، 
\q2 لە ئاسمان چەسپاوە. 
\q1  
\v 90 دڵسۆزیت نەوە دوای نەوەیە، 
\q2 زەویت دامەزراند و دەمێنێت. 
\q1  
\v 91 ئەوان بە حوکمەکانی تۆ هەتا ئەمڕۆ ماون، 
\q2 چونکە هەمووان خزمەتکاری تۆن. 
\q1  
\v 92 ئەگەر فێرکردنی تۆ سەرچاوەی شادیم نەدەبوو، 
\q2 بە زەلیلی خۆم لەناودەچووم. 
\q1  
\v 93 هەرگیز ڕێنماییەکانت لەبیرناکەم، 
\q2 چونکە بەوان منت ژیاندەوە. 
\q1  
\v 94 من هی تۆم، ڕزگارم بکە، 
\q2 چونکە داواکاری ڕێنماییەکانی تۆم. 
\q1  
\v 95 بەدکارەکان خۆیان بۆم ماتداوە تاکو بمفەوتێنن، 
\q2 بەڵام من لە یاساکانی تۆ ڕادەمێنم. 
\q1  
\v 96 بۆ هەموو تەواوییەک سنوورم بینی، 
\q2 بەڵام ڕاسپاردەی تۆ زۆر فراوانە. 
\s1 מ (میم) 
\q1  
\v 97 چەند حەزم لە فێرکردنی تۆیە! 
\q2 بە درێژایی ڕۆژ لێی ورد دەبمەوە. 
\q1  
\v 98 بەهۆی ڕاسپاردەکانت لە دوژمنەکانم داناتر بووم، 
\q2 چونکە هەتاهەتایە بۆ منە. 
\q1  
\v 99 لە هەموو مامۆستاکانم هۆشمەندتر بووم، 
\q2 چونکە لە یاساکانت ورد دەبمەوە. 
\q1  
\v 100 لە پیرەکان زیاتر تێدەگەم، 
\q2 چونکە ڕێنماییەکانت پەیڕەو دەکەم. 
\q1  
\v 101 پێی خۆمم قەدەغە کردووە لە هەموو ڕێگایەکی خراپ، 
\q2 بۆ ئەوەی گوێڕایەڵی فەرمانی تۆ بم. 
\q1  
\v 102 لە حوکمەکانی تۆ لام نەداوە، 
\q2 چونکە تۆ خۆت فێرت کردووم. 
\q1  
\v 103 بەڵێنەکانت چەند شیرینن بۆ زمانم، 
\q2 لە هەنگوین شیرینترن بۆ دەمم. 
\q1  
\v 104 لە ڕێنماییەکانی تۆ تێگەیشتنم بەدەستهێنا، 
\q2 بۆیە ڕقم لە هەموو ڕێگایەکی خوارە. 
\s1 נ (نون) 
\q1  
\v 105 وشەکانی تۆ چرایە بۆ پێیەکانم، 
\q2 ڕووناکییە بۆ ڕێگام. 
\q1  
\v 106 سوێندم خواردووە و بەجێی دەهێنم، 
\q2 کە ملکەچی حوکمە ڕاستودروستەکانت دەبم. 
\q1  
\v 107 ئەی یەزدان، زۆر ئازارم چێژتووە، 
\q2 جا بەپێی بەڵێنی خۆت بمژیێنەوە. 
\q1  
\v 108 ئەی یەزدان، بەو ستایشە ڕازی بە کەوا هەردەم لەسەر لێوانمە. 
\q2 حوکمەکانی خۆتم فێر بکە. 
\q1  
\v 109 هەمیشە گیانم لەناو دەستمدایە، 
\q2 بەڵام فێرکردنی تۆ لەبیرناکەم. 
\q1  
\v 110 بەدکاران تەڵەیان بۆم ناوەتەوە، 
\q2 بەڵام من لە ڕێنماییەکانی تۆ گومڕا نابم. 
\q1  
\v 111 یاساکانت هەتاهەتایە گەنجینەن بۆ من، 
\q2 چونکە ئەوان شادی دڵمن. 
\q1  
\v 112 دڵم بۆ بەجێهێنانی فەرزەکانت تەرخان دەکەم، 
\q2 هەتاهەتایە و هەتا کۆتایی. 
\s1 ס (سامخ) 
\q1  
\v 113 ڕقم لە کەسانی دوودڵە، 
\q2 حەزم لە فێرکردنی تۆیە. 
\q1  
\v 114 تۆ پەناگا و قەڵغانی منیت، 
\q2 هیوام بە بەڵێنی تۆیە. 
\q1  
\v 115 ئەی بەدکارەکان، لێم دوور بکەونەوە، 
\q2 تاکو ڕاسپاردەکانی خودای خۆم پەیڕەو بکەم. 
\q1  
\v 116 بەپێی بەڵێنەکەی خۆت پشتم بگرە هەتا بژیم، 
\q2 لە ئومێدی خۆم شەرمەزارم مەکە. 
\q1  
\v 117 پشتم بگرە و ڕزگاردەبم، 
\q2 هەمیشە چاوم لە فەرزەکانت دەبێت. 
\q1  
\v 118 هەموو ئەوانەی لە فەرزەکانی تۆ گومڕا بوون ڕەتیان دەکەیتەوە، 
\q2 چونکە فێڵەکەیان پووچە. 
\q1  
\v 119 هەموو بەدکارانی زەوی وەک خڵت جیا دەکەیتەوە، 
\q2 بۆیە حەزم لە یاساکانتە. 
\q1  
\v 120 لەشم لە تۆقینی تۆ دەلەرزێت و 
\q2 لە حوکمەکانت دەترسم. 
\s1 ע (عەین) 
\q1  
\v 121 دادپەروەری و ڕاستودروستیم بەجێهێناوە، 
\q2 ڕادەستی زۆردارم مەکە. 
\q1  
\v 122 بەڵێن بدە چاکە لەگەڵ خزمەتکاری خۆت بکەیت، 
\q2 با لووتبەرزەکان ستەمم لێ نەکەن. 
\q1  
\v 123 چاوم شل بوو لە پەرۆشیم بۆ ڕزگارییەکەت، 
\q2 بۆ بەجێهێنانی بەڵێنە ڕاستودروستەکەت. 
\q1  
\v 124 بەپێی خۆشەویستییە نەگۆڕەکەت لەگەڵ خزمەتکارەکەت ڕەفتار بکە، 
\q2 فێری فەرزەکانی خۆتم بکە. 
\q1  
\v 125 من خزمەتکاری تۆم، تێمبگەیەنە، 
\q2 بۆ ئەوەی لە یاساکانت تێبگەم. 
\q1  
\v 126 ئەی یەزدان، کاتی کارکردنی تۆیە، 
\q2 چونکە فێرکردنی تۆ شکێنراوە. 
\q1  
\v 127 لەبەر ئەوەی حەز لە ڕاسپاردەکانت دەکەم 
\q2 زیاتر لە زێڕ، لە زێڕی پوختەکراو، 
\q1  
\v 128 هەروەها لەبەر ئەوەی هەموو ڕێنماییەکانت بە ڕاست دەزانم، 
\q2 ڕقم لە هەموو ڕێگایەکی خوارە. 
\s1 פ (پێ) 
\q1  
\v 129 یاساکانت سەرسوڕهێنەرە، 
\q2 بۆیە گیانم پەیڕەویان دەکات. 
\q1  
\v 130 ڕوونکردنەوەی فەرمایشتەکانت ڕووناکی دەبەخشێت، 
\q2 تێگەیشتنیش بە نەزانەکان. 
\q1  
\v 131 دەمم کردەوە و هەناسەبڕکێمە، 
\q2 چونکە پەرۆشی ڕاسپاردەکانی تۆم. 
\q1  
\v 132 ئاوڕم لێ بدەوە و لەگەڵم میهرەبان بە، 
\q2 وەک نەریتی خۆت بۆ ئەوانەی ناوی تۆیان خۆشدەوێت. 
\q1  
\v 133 هەنگاوەکانم لەسەر وتەکەت بچەسپێنە، 
\q2 مەهێڵە هیچ گوناهێک بەسەرمدا زاڵ بێت. 
\q1  
\v 134 لە زۆرداری مرۆڤ بمکڕەوە، 
\q2 بۆ ئەوەی ڕێنماییەکانی تۆ پەیڕەو بکەم. 
\q1  
\v 135 ڕووت بەسەر خزمەتکاری خۆتدا بدرەوشێنەوە، 
\q2 فێری فەرزەکانی خۆتم بکە. 
\q1  
\v 136 جۆگەی ئاو لە چاوەکانم دادەڕژێت، 
\q2 چونکە فێرکردنت پەیڕەو ناکرێت. 
\s1 צ (تسادێ) 
\q1  
\v 137 ئەی یەزدان، تۆ ڕاستودروستیت، 
\q2 حوکمەکانت ڕاستن. 
\q1  
\v 138 ئەو یاسایانەی دەرتکردووە ڕاستودروستن و 
\q2 بە تەواوی جێی متمانەن. 
\q1  
\v 139 دڵگەرمیم سووتاندمی، 
\q2 چونکە دوژمنانم فەرمانەکانی تۆیان لەبیر کردووە. 
\q1  
\v 140 بەڵێنی تۆ زۆر تاقیکراوەتەوە، 
\q2 خزمەتکارەکەت حەزی لێیەتی. 
\q1  
\v 141 من بچووک و ڕیسوام، 
\q2 بەڵام ڕێنماییەکانت لە یاد ناکەم. 
\q1  
\v 142 ڕاستودروستیت هەتاهەتایی تەواوە و 
\q2 فێرکردنت ڕاستە. 
\q1  
\v 143 تەنگانە و ناخۆشیم تووش بووە، 
\q2 بەڵام ڕاسپاردەکانت شادی منن. 
\q1  
\v 144 یاساکانت هەتاهەتایە ڕاستودروستن، 
\q2 تێمبگەیەنە بۆ ئەوەی بژیم. 
\s1 ק (قۆف) 
\q1  
\v 145 پڕ بە دڵ هاوار دەکەم، ئەی یەزدان، وەڵامم بدەوە، 
\q2 فەرزەکانت بەجێدەهێنم. 
\q1  
\v 146 هاوار بۆ تۆ دەکەم، ڕزگارم بکە! 
\q2 یاساکانت پەیڕەو دەکەم. 
\q1  
\v 147 پێش بەرەبەیان هەڵدەستم و هاوارت بۆ دەهێنم، 
\q2 ئومێدم بە بەڵێنی تۆ هەیە. 
\q1  
\v 148 بە درێژایی شەو بەئاگام، 
\q2 بۆ ئەوەی لە بەڵێنەکانت وردببمەوە. 
\q1  
\v 149 بەگوێرەی خۆشەویستییە نەگۆڕەکەت گوێ لە دەنگم بگرە، 
\q2 ئەی یەزدان، بەگوێرەی حوکمەکانت\f + \fr 119:149 \ft مەبەست لە بڕیاری خودایە بەگوێرەی پەیمانی خۆی بۆ بەخشینی ژیانی هەتاهەتایی بۆ بێتاوانکراوان.‏\f* بمژیێنەوە. 
\q1  
\v 150 پیلانگێڕان نزیک بوونەوە، 
\q2 لە فێرکردنی تۆ دوور کەوتوونەتەوە. 
\q1  
\v 151 بەڵام ئەی یەزدان، تۆ زۆر نزیکیت، 
\q2 هەموو ڕاسپاردەکانت ڕاستن. 
\q1  
\v 152 لەمێژە لە یاساکانت دەزانم، 
\q2 کە بۆ هەتاهەتایە داتناوە. 
\s1 ר (ڕێیش) 
\q1  
\v 153 سەیری ئازارم بکە و دەربازم بکە، 
\q2 چونکە فێرکردنی تۆ لەبیر ناکەم. 
\q1  
\v 154 پارێزەری لە گرفتەکەم بکە و بمکڕەوە، 
\q2 بەگوێرەی بەڵێنەکەت بمژیێنەوە. 
\q1  
\v 155 ڕزگاری لە بەدکاران دوورە، 
\q2 چونکە بەدوای فەرزەکانتدا ناگەڕێن. 
\q1  
\v 156 ئەی یەزدان، بەزەییت زۆرە، 
\q2 بەگوێرەی حوکمەکانت بمژیێنەوە. 
\q1  
\v 157 دوژمنانم و ئەوانەی دەمچەوسێننەوە زۆرن، 
\q2 بەڵام لە یاساکانی تۆ لام نەداوە. 
\q1  
\v 158 ناپاکەکانم بینی بێزم هاتەوە، 
\q2 چونکە گوێڕایەڵی فەرمانەکانت نەبوون. 
\q1  
\v 159 ببینە چەندە حەزم لە ڕێنماییەکانتە، 
\q2 ئەی یەزدان، بەگوێرەی خۆشەویستییە نەگۆڕەکەت بمژیێنەوە. 
\q1  
\v 160 هەموو وشەکانی تۆ ڕاستییە، 
\q2 هەموو حوکمە ڕاستودروستەکانی هەتاهەتایین. 
\s1 ש (شین) 
\q1  
\v 161 میرەکان بەبێ هۆ دەمچەوسێننەوە، 
\q2 بەڵام دڵم لە فەرمایشتی تۆ دەتۆقێت. 
\q1  
\v 162 بە بەڵێنەکانت دڵشاد دەبم، 
\q2 وەک یەکێک دەستکەوتێکی زۆری چنگکەوتبێت. 
\q1  
\v 163 ڕقم لە درۆیە و قێزم لێی دەبێتەوە، 
\q2 بەڵام حەزم لە فێرکردنی تۆیە. 
\q1  
\v 164 ڕۆژانە حەوت جار ستایشت دەکەم، 
\q2 بۆ حوکمە ڕاستودروستەکانت. 
\q1  
\v 165 ئاشتیێکی گەورە بۆ ئەوانەی حەز لە فێرکردنت دەکەن، 
\q2 هیچ شتێک بۆیان نابێتە کۆسپ. 
\q1  
\v 166 ئەی یەزدان، هیوام بە ڕزگاریی تۆیە، 
\q2 ڕاسپاردەکانی تۆ پەیڕەو دەکەم. 
\q1  
\v 167 گیانم یاساکانت پەیڕەو دەکات، 
\q2 چونکە زۆر حەزم لێیەتی. 
\q1  
\v 168 ڕێنمایی و یاساکانی تۆ پەیڕەو دەکەم، 
\q2 چونکە هەموو ڕێگاکانم لەبەردەمتن. 
\s1 ת (تاو) 
\q1  
\v 169 ئەی یەزدان، با هاوارم بگاتە بەردەمت، 
\q2 بەگوێرەی پەیمانی خۆت تێمبگەیەنە. 
\q1  
\v 170 با پاڕانەوەم بێتە بەردەمت، 
\q2 بەگوێرەی بەڵێنەکەت دەربازم بکە. 
\q1  
\v 171 با لێوم ستایشی لێ بڕژێت، 
\q2 چونکە فێری فەرزەکانی خۆتم دەکەیت. 
\q1  
\v 172 با زمانم گۆرانی بەسەر وتەکەتدا بڵێ، 
\q2 چونکە هەموو ڕاسپاردەکانت ڕاستودروستن. 
\q1  
\v 173 با دەستت ئامادەبێت بۆ یارمەتیم، 
\q2 چونکە ڕێنماییەکانی تۆم هەڵبژاردووە. 
\q1  
\v 174 ئەی یەزدان، من بە پەرۆشم بۆ ڕزگاریی تۆ، 
\q2 فێرکردنت شادی منە. 
\q1  
\v 175 با گیانم بژیێتەوە بۆ ئەوەی ستایشت بکەم، 
\q2 حوکمەکانت یارمەتیم بدات. 
\q1  
\v 176 وەک بەرخی وێڵ گومڕا بووم، 
\q2 بەدوای خزمەتکارەکەتدا بگەڕێ، 
\q2 چونکە ڕاسپاردەکانی تۆم لەبیر نەکردووە. 
\c 120  
\cl زەبووری 120 
\d گۆرانی گەشتیاران. 
\q1  
\v 1 لە تەنگانەمدا لە یەزدان پاڕامەوە و 
\q2 بە دەنگمەوە هات. 
\q1  
\v 2 ئەی یەزدان، گیانم دەرباز بکە 
\q2 لە لێوی درۆزن و لە زمانی فێڵباز. 
\b  
\q1  
\v 3 چیت پێدەدرێت، 
\q2 چیت بۆ زیاد دەکرێت، ئەی زمانی فێڵباز؟ 
\q1  
\v 4 سزاتان دەدەم بە تیری تیژکراوی پاڵەوان، 
\q2 لەگەڵ پشکۆی خەڵووزی دار گەز! 
\b  
\q1  
\v 5 قوڕبەسەرم، چونکە ئاوارەی مەشەکم\f + \fr 120:5 \ft مەشەک، هەرێمێکە لە ئێستای وڵاتی تورکیا.‏\f*، 
\q2 کە لە خێوەتەکانی قێدار\f + \fr 120:5 \ft قێدار، هەرێمێکە لە نیمچە دوورگەکەی عەرەبی.‏\f* نیشتەجێم. 
\q1  
\v 6 نیشتەجێبوونم درێژەی کێشا 
\q2 لەگەڵ ئەوانەی ڕقیان لە ئاشتییە. 
\q1  
\v 7 من ئاشتیخوازم، 
\q2 بەڵام کاتێک قسە دەکەم، ئەوان شەڕخوازن. 
\c 121  
\cl زەبووری 121 
\d گۆرانی گەشتیاران. 
\q1  
\v 1 چاوم بەرەو چیاکان\f + \fr 121:1 \ft مەبەستی چیاکانی دەوری ئۆرشەلیمە.‏\f* هەڵدەبڕم، 
\q2 یارمەتی من لەکوێوە دێت؟ 
\q1  
\v 2 یارمەتی من لەلای یەزدانەوەیە، 
\q2 دروستکەری ئاسمان و زەوی. 
\b  
\q1  
\v 3 لێ ناگەڕێت پێت بخزێت، 
\q2 ئەوەی دەتپارێزێت خەواڵوو نابێت. 
\q1  
\v 4 بێگومان ئەوەی ئیسرائیل دەپارێزێت 
\q2 خەواڵوو نابێت و نانوێت. 
\b  
\q1  
\v 5 یەزدان پارێزگاری تۆیە، 
\q2 یەزدان سێبەری تۆیە لەلای دەستی ڕاستت، 
\q1  
\v 6 نە خۆر بە ڕۆژ ئەزیەتت دەدات، 
\q2 نە مانگ بە شەو. 
\b  
\q1  
\v 7 یەزدان لە هەموو خراپەیەک دەتپارێزێت، 
\q2 گیانت دەپارێزێت. 
\q1  
\v 8 یەزدان پارێزگاری هاتوچۆت دەکات، 
\q2 لە ئێستاوە و بۆ هەتاهەتایە. 
\c 122  
\cl زەبووری 122 
\d گۆرانی گەشتیاران، بۆ داود. 
\q1  
\v 1 شادمان بووم بەوانەی پێیان گوتم، 
\q2 «با بچینە ماڵی یەزدان.» 
\q1  
\v 2 ئەی ئۆرشەلیم، پێیەکانمان 
\q2 لە دەروازەکانت ڕادەوەستن. 
\b  
\q1  
\v 3 ئۆرشەلیم بنیاد نراوە، 
\q2 وەک شارێکی یەکگرتوو. 
\q1  
\v 4 لەوێ کە خێڵەکان سەردەکەون، 
\q2 هۆزەکانی یەزدان، 
\q1 بۆ ئەوەی ستایشی ناوی یەزدان بکەن 
\q2 بەگوێرەی ئەو یاسایەی کە بۆ ئیسرائیل دانراوە. 
\q1  
\v 5 لەبەر ئەوەی تەختەکان بۆ دادوەری لەوێ دادەنرێت، 
\q2 تەختەکانی بنەماڵەی داود. 
\b  
\q1  
\v 6 داوای ئاشتی بکەن بۆ ئۆرشەلیم: 
\q2 «با ئەوانەی تۆیان خۆشدەوێت ئاسوودە بن. 
\q1  
\v 7 با ئاشتی لە شووراکانت بێت، 
\q2 ئاسایش لە قەڵاکانت.» 
\q1  
\v 8 لە پێناوی برا و هاوڕێیەکانم 
\q2 داوای ئاشتیت بۆ دەکەم. 
\q1  
\v 9 لە پێناوی ماڵی یەزدانی پەروەردگارمان، 
\q2 بەدوای چاکەی تۆدا دەگەڕێم. 
\c 123  
\cl زەبووری 123 
\d گۆرانی گەشتیاران. 
\q1  
\v 1 چاوم بۆ تۆ هەڵبڕی، 
\q2 تۆ ئەی دانیشتوو لە ئاسمان. 
\q1  
\v 2 بێگومان وەک چۆن خزمەتکار چاوی لە دەستی گەورەکەیەتی، 
\q2 وەک چۆن کەنیزە چاوی لە دەستی خاتوونەکەیەتی، 
\q1 ئاواش ئێمە چاومان لە دەستی یەزدانی پەروەردگارمانە، 
\q2 بۆ ئەوەی لەگەڵمان میهرەبان بێت. 
\b  
\q1  
\v 3 لەگەڵمان میهرەبان بە، ئەی یەزدان، لەگەڵمان میهرەبان بە! 
\q2 چونکە لە ڕادەبەدەر لە سووکایەتی تێربووین. 
\q2  
\v 4 گیانمان زۆر تێر بووە لە گاڵتەی بێ خەمەکان، 
\q2 لە سووکایەتی لووتبەرزەکان. 
\c 124  
\cl زەبووری 124 
\d گۆرانی گەشتیاران، بۆ داود. 
\q1  
\v 1 «ئەگەر یەزدان لایەنگرمان نەدەبوو،» 
\q2 با ئێستا ئیسرائیل بڵێت، 
\q1  
\v 2 «ئەگەر یەزدان لایەنگرمان نەدەبوو، 
\q2 کاتێک خەڵک لێمان هەستان، 
\q1  
\v 3 ئەوا بە زیندوویی قووتیان دەداین، 
\q2 کاتێک قینیان لە دژمان جۆشا، 
\q1  
\v 4 ئەوا لافاو ڕایدەماڵین، 
\q2 لێشاو گیانمانی دەبرد، 
\q1  
\v 5 ئەوا ئاوی هەڵچوو 
\q2 گیانمانی دەبرد.» 
\b  
\q1  
\v 6 ستایش بۆ یەزدان، 
\q2 کە ئێمەی نەکردە نێچیری بەر کەڵبەیان. 
\q1  
\v 7 گیانمان وەک چۆلەکە لە داوی ڕاوچی دەربازبوو، 
\q2 داوەکە پسا و ئێمە دەربازبووین. 
\q1  
\v 8 هانامان بە ناوی یەزدانەوەیە، 
\q2 دروستکەری ئاسمان و زەوی. 
\c 125  
\cl زەبووری 125 
\d گۆرانی گەشتیاران. 
\q1  
\v 1 ئەوانەی پشتیان بە یەزدان بەستووە وەک کێوی سییۆن وان، 
\q2 کە نالەقێت، بەڵکو هەتاهەتایە هەر چەسپاوە. 
\q1  
\v 2 وەک چۆن چیاکان دەوری ئۆرشەلیمیان داوە، 
\q2 یەزدانیش دەوری گەلی خۆی داوە، 
\q2 لە ئێستاوە و هەتاهەتایە. 
\b  
\q1  
\v 3 داردەستی خراپەکاران 
\q2 لەسەر میراتی ڕاستودروستان جێگیر نابێت، 
\q1 نەوەک ڕاستودروستان 
\q2 دەستیان درێژ بکەن بۆ خراپەکاری. 
\b  
\q1  
\v 4 ئەی یەزدان، چاکە بکە لەگەڵ پیاوچاکان، 
\q2 لەگەڵ ئەوانەی بە دڵ ڕاستودروستن. 
\q1  
\v 5 بەڵام ئەوانەی بادەدەنەوە و ڕێگای خوار دەگرن، 
\q2 یەزدان لەگەڵ بەدکاران دەیانبات. 
\b  
\q1 ئاشتی بۆ ئیسرائیل! 
\c 126  
\cl زەبووری 126 
\d گۆرانی گەشتیاران. 
\q1  
\v 1 کە یەزدان ڕاپێچکراوانی سییۆنی گەڕاندەوە، 
\q2 وامان لێهات وەک خەون ببینین. 
\q1  
\v 2 ئەو کاتە دەممان پڕ پێکەنین و 
\q2 زمانمان پڕ هەلهەلە بوو، 
\q1 ئەوسا لەنێو نەتەوەکان گوتیان: 
\q2 «یەزدان کارێکی گەورەی لەگەڵ ئەوان کرد!» 
\q1  
\v 3 یەزدان کارێکی گەورەی لەگەڵ ئێمە کرد، 
\q2 شادمان بووین. 
\b  
\q1  
\v 4 ئەی یەزدان، ڕاپێچکراوانمان بگەڕێنەوە، 
\q2 وەک جۆگەکانی نەقەب\f + \fr 126:4 \ft دەکەوێتە خوارووی فەلەستین، بۆیە لە زمانی عیبری بە واتای باشووریش دێت.‏\f*. 
\q1  
\v 5 ئەوانەی بە فرمێسکەوە دەچێنن، 
\q2 بە هەلهەلەوە دروێنە دەکەن. 
\q1  
\v 6 ئەوەی بە گریانەوە دەڕوات و 
\q2 تۆو بۆ چاندن بار دەکات، 
\q1 بە هەلهەلەوە دێتەوە و 
\q2 بەرهەمەکەی بە مەڵۆ بار دەکات. 
\c 127  
\cl زەبووری 127 
\d گۆرانی گەشتیاران، بۆ سلێمان. 
\q1  
\v 1 ئەگەر یەزدان خانووەکە دروست نەکات، 
\q2 وەستاکان بێ سوود خۆیان ماندوو دەکەن. 
\q1 ئەگەر یەزدان چاودێری شارەکە نەکات، 
\q2 پاسەوان بێ سوود ئێشک دەگرێت. 
\q1  
\v 2 بێ سوودە بۆتان زوو هەستان و دانیشتن هەتا درەنگی شەو، 
\q2 خواردنی نانی ڕەنجکێشی، 
\q2 چونکە خەو بە خۆشەویستانی خۆی دەبەخشێت. 
\b  
\q1  
\v 3 بێگومان منداڵان میراتن لە یەزدانەوە، 
\q2 پاداشتی بەری سکن. 
\q1  
\v 4 وەک تیری دەستی پاڵەوان، 
\q2 ئاوان کوڕانی مرۆڤی گەنج. 
\q1  
\v 5 خۆزگە دەخوازرێ بەو کەسەی تیردانی خۆی لەوان پڕکردووە، 
\q2 شەرمەزار نابێت کە لە دادگا\f + \fr 127:5 \ft عیبری: لە دەروازە. لە کەلتوری عیبری دادگا لە دەروازەی شار بووە، زۆر جار وشەی دەروازە لەبری دادگا بەکاردێت.‏\f* لەگەڵ دوژمنان دەکەوێتە دەمەقاڵێ. 
\c 128  
\cl زەبووری 128 
\d گۆرانی گەشتیاران. 
\q1  
\v 1 خۆزگە دەخوازرێ بەو کەسەی لە یەزدان بترسێت، 
\q2 ڕێگای ئەو بگرێتەبەر. 
\q1  
\v 2 بەری ڕەنجی دەستی خۆت دەخۆیت، 
\q2 خۆزگەت پێ دەخوازرێت و چاکیشە بۆت. 
\q1  
\v 3 ژنەکەت وەک دار مێوێکی بەردار دەبێت لەناو ماڵەکەت، 
\q2 کوڕەکانت وەک شەتڵە زەیتوون دەبن لە دەوری خوانەکەت. 
\q1  
\v 4 ئەو کەسەی لە یەزدان بترسێت 
\q2 ئاوا بەرەکەتدار دەبێت. 
\b  
\q1  
\v 5 یەزدان لە سییۆن بەرەکەتدارت بکات، 
\q2 چاکەی ئۆرشەلیم ببینیت 
\q1 هەموو ڕۆژانی ژیانت و 
\q2  
\v 6 منداڵی منداڵەکانت ببینیت! 
\q1 ئاشتی بۆ ئیسرائیل! 
\c 129  
\cl زەبووری 129 
\d گۆرانی گەشتیاران. 
\q1  
\v 1 «لە گەنجییەتیم زۆر هەراسانیان کردم!» 
\q2 با ئێستا ئیسرائیل بڵێت: 
\q1  
\v 2 «لە گەنجییەتیم زۆر هەراسانیان کردم! 
\q2 بەڵام بەسەرمدا زاڵ نەبوون. 
\q1  
\v 3 جوتیارەکان جووتیان لەسەر پشتم کرد و 
\q2 هێڵی جووتەکانیان درێژکردەوە.» 
\q1  
\v 4 بەڵام یەزدان ڕاستودروستە، 
\q2 پەتی بەدکارانی پچڕاند. 
\b  
\q1  
\v 5 با هەموو ئەوانەی ڕقیان لە سییۆنە 
\q2 ڕیسوا بن و ببەزن. 
\q1  
\v 6 با بە دەردی گیای سەربان بچن، 
\q2 پێش ئەوەی گەشە بکات وشک دەبێت، 
\q1  
\v 7 ئەوەی نە دەستی دروێنەکەر پڕ دەکات و 
\q2 نە باوەشی گیشەکەر\f + \fr 129:7 \ft ئەو کەسەیە کە لەدوای دروێنەکەران گوڵە گەنمەکان بە باوەش کۆدەکاتەوە.‏\f*. 
\q1  
\v 8 با ئەوانەی بەلایانەوە تێدەپەڕن پێیان نەڵێن: 
\q2 «بەرەکەتی یەزدانتان لێ بێت! 
\q2 بە ناوی یەزدان داوای بەرەکەتتان بۆ دەکەین!» 
\c 130  
\cl زەبووری 130 
\d گۆرانی گەشتیاران. 
\q1  
\v 1 ئەی یەزدان، لە ناخی قووڵاییەکانەوە هاوار بۆ تۆ دەکەم! 
\q2  
\v 2 ئەی پەروەردگار، گوێ لە دەنگم بگرە! 
\q2 با گوێیەکانت سووک بن بۆ دەنگی پاڕانەوەم. 
\b  
\q1  
\v 3 ئەی یەزدان، ئەگەر گوناهەکان تۆمار بکەیت، 
\q2 ئەی پەروەردگار، کێ دەوەستێت؟ 
\q1  
\v 4 بەڵام لێخۆشبوون لەلای تۆیە، 
\q2 بۆ ئەوەی لێت بترسین. 
\b  
\q1  
\v 5 چاوەڕێی یەزدان دەکەم، گیانم چاوەڕێی دەکات، 
\q2 هیوام بە بەڵێنەکانییەتی. 
\q1  
\v 6 گیانم چاوەڕێی پەروەردگار دەکات، 
\q2 زیاتر لە ئێشکگر بۆ بەرەبەیان، 
\q2 زیاتر لە ئێشکگر بۆ بەرەبەیان. 
\b  
\q1  
\v 7 ئەی ئیسرائیل، هیوات بە یەزدان هەبێت، 
\q2 چونکە خۆشەویستی نەگۆڕ لەلای یەزدانە، 
\q2 توانایەکی زۆریشی هەیە بۆ کڕینەوە. 
\q1  
\v 8 هەر ئەوە ئیسرائیل دەکڕێتەوە 
\q2 لە هەموو گوناهەکانی. 
\c 131  
\cl زەبووری 131 
\d گۆرانی گەشتیاران، بۆ داود. 
\q1  
\v 1 ئەی یەزدان، نە دڵم بەفیزە و 
\q2 نە چاوەکانم بە لووتبەرزییەوە دەڕوانن، 
\q2 خۆم بە شتی لە خۆم گەورەتر و گرنگترەوە خەریک ناکەم. 
\q1  
\v 2 بەڵکو گیانی خۆمم ئارام و کپ کردووە، 
\q2 وەک منداڵێکی لەشیربڕاوەیە لە باوەشی دایکی، 
\q2 گیانم وەک منداڵێکی لەشیربڕاوە وایە. 
\b  
\q1  
\v 3 ئەی ئیسرائیل، هیوات بە یەزدان هەبێت، 
\q2 لە ئێستاوە و بۆ هەتاهەتایە. 
\c 132  
\cl زەبووری 132 
\d گۆرانی گەشتیاران. 
\q1  
\v 1 ئەی یەزدان، داود و هەموو ئازارەکانی 
\q2 بەبیر خۆت بهێنەوە. 
\b  
\q1  
\v 2 ئەو سوێندەی بۆ یەزدانی خوارد، 
\q2 نەزرەکەی بۆ خودای تواناداری یاقوب: 
\q1  
\v 3 «شەرت بێت نەچمەوە ناو خێوەتی ماڵەکەم، 
\q2 نەچمە ناو نوێنەکەم، 
\q1  
\v 4 خەو نەدەم بە چاوەکانم، 
\q2 پشوو نەدەم بە پێڵووەکانم، 
\q1  
\v 5 هەتا شوێنێک بۆ یەزدان پەیدا نەکەم، 
\q2 نشینگەیەک بۆ خودای تواناداری یاقوب.» 
\b  
\q1  
\v 6 ئەوەتا لە ئەفراتە\f + \fr 132:6 \ft ئەفراتە ناوی پێشتری شاری بێت‌لەحم بووە.‏\f* هەواڵی ئەومان بیست، 
\q2 لەناو کێڵگەکانی یاعەر\f + \fr 132:6 \ft یاعەر، مەبەست قیریەت یەعاریمە دەکەوێتە نزیکەی دووری 14 کیلۆمەتر لە بێت‌شەمەش، بڕوانە \xt یەکەم ساموئێل 6‏:17‏-21.‏\ft ‏\f* دۆزیمانەوە: 
\q1  
\v 7 «با بچینە نشینگەکەی، 
\q2 با لە تەختەپێی کڕنۆش ببەین. 
\q1  
\v 8 ئەی یەزدان، هەستە و وەرە بۆ شوێنی حەوانەوەت، 
\q2 خۆت و سندوقی هێزت\f + \fr 132:8 \ft مەبەست سندوقی پەیمانە، بڕوانە \xt دەرچوون 25‏:10‏-22 و یەکەم ساموئێل 4‏:11‏–6‏:21.‏\ft ‏\f*. 
\q1  
\v 9 با کاهینەکانت ڕاستودروستی لەبەر بکەن، 
\q2 خۆشەویستانت هەلهەلە لێبدەن.» 
\b  
\q1  
\v 10 لە پێناوی داودی بەندەی خۆت، 
\q2 دەستنیشانکراوەکەت\f + \fr 132:10 \ft بە زمانی عیبری پێی دەگوترێ \+tl مەشیخ‏\+tl* یان \+tl مەشیح‏\+tl*.‏\f* ڕەت مەکەرەوە. 
\b  
\q1  
\v 11 یەزدان سوێندی بۆ داود خوارد و 
\q2 هەرگیز لێی پاشگەز نابێتەوە: 
\q2 «لە بەری پشتی خۆت لەسەر تەختەکەت دادەنێم. 
\q1  
\v 12 ئەگەر کوڕەکانت پەیمانەکەم نەشکێنن، 
\q2 هەروەها ئەو فەرزانەی کە فێریان دەکەم، 
\q1 ئەوسا خۆیان و نەوەکانیان هەتاهەتایە 
\q2 لەسەر تەختەکەت دادەنیشن.» 
\b  
\q1  
\v 13 لەبەر ئەوەی یەزدان سییۆنی هەڵبژارد و 
\q2 حەزی کرد بیکات بە نشینگەی خۆی. 
\q1  
\v 14 «هەتاهەتایە ئەمە ئارامگامە، 
\q2 لێرە نیشتەجێ دەبم، چونکە پێم خۆشە! 
\q1  
\v 15 بەرەکەت بەسەر ئازووقەکەیدا دەبارێنم، 
\q2 هەژارەکانی تێر نان دەکەم. 
\q1  
\v 16 ڕزگاری دەکەمە بەر کاهینەکانی، 
\q2 خۆشەویستانی بە شادمانییەوە هەلهەلە لێ دەدەن. 
\b  
\q1  
\v 17 «لەوێ هێز بە داود دەبەخشم، 
\q2 چرایەک بۆ دەستنیشانکراوەکەم\f + \fr 132:17 \ft بە زمانی عیبری پێی دەگوترێ \+tl مەشیخ‏\+tl* یان \+tl مەشیح‏\+tl*.‏\f* ئامادە دەکەم. 
\q1  
\v 18 شەرمەزاری دەکەمە بەر دوژمنەکانی، 
\q2 بەڵام تاجەکەی سەر ئەو شکۆفە دەکات.» 
\c 133  
\cl زەبووری 133 
\d گۆرانی گەشتیاران، بۆ داود. 
\q1  
\v 1 ئەوەتا چەند باشە و چەند جوانە، 
\q2 کاتێک گەلی خودا پێکەوە بژین! 
\b  
\q1  
\v 2 وەک ڕۆنی بۆن خۆشە بەسەر سەرەوە، 
\q2 کە بەسەر ڕیشدا دێتە خوارێ، ڕیشی هارون، 
\q2 کە بەسەر یەخەی کراسەکەیدا دێتە خوارێ. 
\q1  
\v 3 وەک شەونمی حەرمۆن\f + \fr 133:3 \ft بەرزترین شاخە لە سوریا.‏\f* کە دێتە خوارێ 
\q2 بەسەر کێوی سییۆن، 
\q2 چونکە لەوێ یەزدان فەرمانی بە بەرەکەت دا، ژیانی هەتاهەتایی. 
\c 134  
\cl زەبووری 134 
\s1 گۆرانی گەشتیاران. 
\q1  
\v 1 ستایشی یەزدان بکەن، ئەی هەموو بەندەکانی یەزدان، 
\q2 ئەی ئەوانەی بە شەوان لە ماڵی یەزدان ڕادەوەستن. 
\q1  
\v 2 لە پیرۆزگاکە\f + \fr 134:2 \ft بڕوانە \xt یەکەم تیمۆساوس 2‏:8‏\ft ‏\f* دەست بەرزبکەنەوە و 
\q2 ستایشی یەزدان بکەن. 
\b  
\q1  
\v 3 با یەزدان، دروستکەری ئاسمان و زەوی، 
\q2 لە سییۆنەوە بەرەکەتدارت بکات. 
\c 135  
\cl زەبووری 135 
\q1  
\v 1 هەلیلویا! 
\b  
\q1 ستایشی ناوی یەزدان بکەن، 
\q2 ئەی بەندەکانی یەزدان، ستایشی بکەن، 
\q1  
\v 2 ئەی ئەوانەی لە ماڵی یەزدان ڕاوەستاون، 
\q2 لە حەوشەی ماڵی خودامان. 
\b  
\q1  
\v 3 ستایشی یەزدان بکەن، چونکە یەزدان چاکە، 
\q2 مۆسیقا بۆ ناوی بژەنن، چونکە ئاوا جوانە، 
\q1  
\v 4 چونکە یەزدان یاقوبی بۆ خۆی هەڵبژاردووە و 
\q2 ئیسرائیل بۆ گەنجینەیەکی تایبەتی خۆی. 
\b  
\q1  
\v 5 من دەزانم یەزدان مەزنە، 
\q2 پەروەردگارمان لە هەموو خوداوەندەکان مەزنترە. 
\q1  
\v 6 یەزدان هەرچی پێ خۆشبێت دەیکات، 
\q2 لە ئاسمان و لەسەر زەوی، 
\q2 لە دەریا و لە هەموو قووڵاییەکان. 
\q1  
\v 7 لەوپەڕی زەوییەوە هەورەکان بەرز دەکاتەوە، 
\q2 بروسکە بۆ باران دروستدەکات و 
\q2 لە ئەمباری خۆی با دەردێنێت. 
\b  
\q1  
\v 8 ئەو بوو کە نۆبەرەکانی میسری لەناوبرد، 
\q2 لە مرۆڤەوە هەتا ئاژەڵ. 
\q1  
\v 9 ئەی میسرییەکان، لەنێو ئێوە نیشانە و پەرجووی نارد، 
\q2 لە دژی فیرعەون و هەموو خزمەتکارەکانی. 
\q1  
\v 10 ئەو زۆر نەتەوەی لەناوبرد و 
\q2 پاشا بە تواناکانی کوشت. 
\q1  
\v 11 سیحۆنی\f + \fr 135:11 \ft سیحۆن، یەکێک بوو لە پاشاکانی ئەمۆرییەکان، ویستی بەرەنگاری جولەکەکان بێتەوە و ڕێی پێنەدان بەناو خاکەکەیدا تێبپەڕن، کاتێک بەڕێوە بوون بەرەو خاکی کەنعان. جا خۆی و سوپاکەی تێکشکان. بڕوانە ژمارە 21‏:21‏-29.‏\f* پاشای ئەمۆرییەکان و 
\q2 عۆگی\f + \fr 135:11 \ft عۆگ، پاشای باشان بوو، بە هەمان دەردی سیحۆن چوو. بڕوانە ژمارە 21‏:31‏-35.‏\f* پاشای باشان و 
\q2 هەموو پاشاکانی کەنعان 
\q1  
\v 12 خاکەکەیانی کردە میرات، 
\q2 میرات بۆ ئیسرائیلی گەلی خۆی. 
\b  
\q1  
\v 13 ئەی یەزدان، ناوت هەتاهەتاییە، 
\q2 ئەی یەزدان، یادت بۆ نەوە دوای نەوەیە، 
\q1  
\v 14 چونکە یەزدان ئەستۆپاکی گەلی خۆی دەسەلمێنێت، 
\q2 میهرەبان دەبێت لەگەڵ خزمەتکارەکانی. 
\b  
\q1  
\v 15 بتەکانی نەتەوەکان زێڕ و زیون، 
\q2 دەستکردی مرۆڤن. 
\q1  
\v 16 دەمیان هەیە، بەڵام قسە ناکەن، 
\q2 چاویان هەیە، بەڵام نابینن، 
\q1  
\v 17 گوێیان هەیە، بەڵام نابیستن، 
\q2 هەناسە لە دەمیان نییە. 
\q1  
\v 18 دروستکەرەکانیان وەک ئەوان دەبن، 
\q2 هەروەها هەموو ئەوانەش کە پشتیان پێ دەبەستن. 
\b  
\q1  
\v 19 ئەی بنەماڵەی ئیسرائیل، ستایشی یەزدان بکەن! 
\q2 ئەی بنەماڵەی هارون، ستایشی یەزدان بکەن! 
\q1  
\v 20 ئەی بنەماڵەی لێڤی، ستایشی یەزدان بکەن! 
\q2 ئەی ئەوانەی ترسی یەزدانتان لە دڵدایە، ستایشی یەزدان بکەن! 
\q1  
\v 21 ستایش بۆ یەزدان لە سییۆن، 
\q2 بۆ ئەوەی لە ئۆرشەلیم نیشتەجێیە. 
\b  
\q1 هەلیلویا! 
\c 136  
\cl زەبووری 136 
\q1 هەلیلویا! 
\q1  
\v 1 ستایشی یەزدان بکەن، لەبەر ئەوەی چاکە، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 2 ستایشی خودای خودایان بکەن، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 3 ستایشی گەورەی گەورەیان بکەن، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\b  
\q1  
\v 4 بۆ ئەوەی بە تەنها ئەوە کاری سەرسوڕهێنەری مەزن دەکات، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 5 ئەوەی بە تێگەیشتنەوە ئاسمانی دروستکردووە، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 6 ئەوەی زەوی لەسەر ئاوەکان ڕاخستووە، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 7 ئەوەی ڕووناکییە مەزنەکانی دروستکردووە، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 8 خۆر بۆ حوکمگێڕی ڕۆژ، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 9 مانگ و ئەستێرەکان بۆ حوکمگێڕی شەو، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\b  
\q1  
\v 10 بۆ ئەوەی لە میسر و نۆبەرەکانی دا\f + \fr 136:10 \ft مەبەستی لە لەناوبردنی نۆبەرەکانی میسرە، بڕوانە دەرچوون بەشی 11.‏\f* 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 11 ئیسرائیلی لە ناوەڕاستیان دەرهێنا، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 12 بە دەستێکی پۆڵایین و بازووێکی بەهێز، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\b  
\q1  
\v 13 بۆ ئەوەی دەریای سووری کرد بە دوو بەشەوە، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 14 ئیسرائیلی بە نێوانیاندا پەڕاندەوە، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 15 فیرعەون و لەشکرەکەی فڕێدایە ناو دەریای سوور، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\b  
\q1  
\v 16 بۆ ئەوەی لە بیابان ڕابەرایەتی گەلی خۆی کرد، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\b  
\q1  
\v 17 ئەوەی پاشا مەزنەکانی لەناوبرد، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 18 ئەوەی پاشا ناودارەکانی کوشت، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 19 سیحۆنی پاشای ئەمۆرییەکان، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 20 عۆگی پاشای باشان، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 21 خاکەکەیانی کرد بە میرات، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 22 بە میرات بۆ ئیسرائیلی بەندەی خۆی، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\b  
\q1  
\v 23 بۆ ئەوەی کاتێک زەلیل بووین ئێمەی بەبیر هاتەوە، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 24 ئەوەی لەناو دوژمنمان دەریهێناین، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\q1  
\v 25 ئەوەی نان دەداتە هەموو بەدیهێنراوێک. 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\b  
\q1  
\v 26 ستایشی خودای ئاسمان بکەن، 
\qr خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە. 
\c 137  
\cl زەبووری 137 
\q1  
\v 1 لەدەم ڕووبارەکانی بابل، لەوێ دانیشتین، 
\q2 هەروەها گریاین کە سییۆنمان بیر کەوتەوە. 
\q1  
\v 2 بە شۆڕەبییەکانی ناوەڕاستی 
\q2 قیسارەکانی خۆمان هەڵواسی، 
\q1  
\v 3 چونکە لەوێ ڕاپێچکەرانمان داوای گۆرانییان لێکردین، 
\q2 چەوسێنەرانمان داوایان کرد دڵخۆشیان بکەین: 
\q2 «گۆرانییەکمان بۆ بڵێن لە گۆرانییەکانی سییۆن.» 
\b  
\q1  
\v 4 چۆن گۆرانی یەزدان بڵێین 
\q2 لە خاکێکی بێگانە؟ 
\q1  
\v 5 ئەی ئۆرشەلیم، ئەگەر لەبیرت بکەم، 
\q2 با دەستی ڕاستم بەهرەکەی لەبیر بکات. 
\q1  
\v 6 با زمانم بە مەڵاشوومەوە بنووسێت، ئەگەر یادت نەکەم، 
\q2 ئەگەر ئۆرشەلیم لە سەرووی هەموو خۆشییەکم دانەنێم. 
\b  
\q1  
\v 7 ئەی یەزدان، ئەو ڕۆژەی ئۆرشەلیم کەوت\f + \fr 137:7 \ft بابلییەکان لە ساڵی 587 پ. ز. بە یارمەتی ئەدۆمییەکان ئۆرشەلیمیان داگیر کرد.‏\f* نەوەی ئەدۆمت لەبیر بێت، 
\q2 کاتێک گوتیان: «تەختی بکەن، هەتا بناغە تەختی بکەن!» 
\q1  
\v 8 ئەی دانیشتووانی بابل کە چارەنووستان لەناوچوونە، 
\q2 دەستی خۆش بێت ئەو کەسەی تۆڵەتان لێ دەستێنێتەوە، 
\q2 وەک ئەو خراپەی هی ئێمەتان دایەوە! 
\q1  
\v 9 دەستی خۆش بێت ئەو کەسەی منداڵەکانتان دەگرێت و 
\q2 بە تاشەبەردیاندا دەدات! 
\c 138  
\cl زەبووری 138 
\d بۆ داود. 
\q1  
\v 1 بە هەموو دڵەوە ستایشت دەکەم، 
\q2 لەبەردەم خوداوەندەکان گۆرانیت بۆ دەڵێم. 
\q1  
\v 2 بەرامبەر پەرستگای پیرۆزت کڕنۆش دەبەم، 
\q2 ستایشی ناوت دەکەم، 
\q1 لەبەر خۆشەویستییە نەگۆڕەکەت و دڵسۆزییەکەت، 
\q2 چونکە فەرمایشتی خۆتت لە ناوبانگەکەت بەرزتر کردووەتەوە. 
\q1  
\v 3 ئەو ڕۆژەی هاوارم بۆ تۆ کرد بەدەنگمەوە هاتیت، 
\q2 ئازا و بوێرت کردم. 
\b  
\q1  
\v 4 ئەی یەزدان، هەموو پاشاکانی سەر زەوی ستایشت دەکەن، 
\q2 کاتێک فەرمایشتی دەمی تۆیان بیست. 
\q1  
\v 5 گۆرانی بەسەر کارەکانی یەزداندا دەڵێن، 
\q2 چونکە شکۆمەندی یەزدان مەزنە. 
\b  
\q1  
\v 6 هەرچەندە یەزدان پایەبەرزە، دەڕوانێتە کەسی بێفیز و 
\q2 لووتبەرزان لە دوورەوە دەناسێت. 
\q1  
\v 7 ئەگەر بەناو تەنگانەشدا بڕۆم ژیانم دەپارێزیت، 
\q2 دەست درێژ دەکەیت بەسەر تووڕەیی دوژمنانم، 
\q2 بە دەستی ڕاستت ڕزگارم دەکەیت. 
\q1  
\v 8 یەزدان ئەستۆپاکیم دەسەلمێنێت؛ 
\q2 ئەی یەزدان، خۆشەویستییە نەگۆڕەکەت هەتاهەتاییە، 
\q2 واز لە کارەکانی دەستت مەهێنە. 
\c 139  
\cl زەبووری 139 
\d بۆ گەورەی گۆرانیبێژان، زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، تۆ منت پشکنی و 
\q2 منت ناسی. 
\q1  
\v 2 هەستان و دانیشتنی منت زانیوە، 
\q2 لە دوورەوە لە بیرکردنەوەم گەیشتووی. 
\q1  
\v 3 ڕێڕەو و جێی ڕاکشانی منت پێواوە، 
\q2 شارەزای هەموو ڕێگاکانی منیت. 
\q1  
\v 4 ئەی یەزدان، بەر لەوەی وشەیەک لەسەر زمانم هەبێت، 
\q2 تۆ بە تەواوی دەیزانی. 
\q1  
\v 5 لەپێش و لە پشتەوە دەورت داوم، 
\q2 دەستت دەخەیتە سەرم. 
\q1  
\v 6 ئەم زانینەی تۆم بەلاوە زۆر سەیرە، 
\q2 لە سەرووی منەوەیە، ناتوانم بەدەستی بهێنم. 
\b  
\q1  
\v 7 بۆ کوێ بچم لە ڕۆحی تۆ؟ 
\q2 بۆ کوێ هەڵبێم لە ڕوخسارت؟ 
\q1  
\v 8 ئەگەر سەربکەوم بۆ ئاسمان، ئەوەتا تۆ لەوێی، 
\q2 ئەگەر لەناو جیهانی مردووان ڕاکشێم، ئەوەتا تۆ لەوێی. 
\q1  
\v 9 ئەگەر دەست بە باڵی بەرەبەیانەوە بگرم، 
\q2 ئەگەر لەوپەڕی دەریا\f + \fr 139:9 \ft مەبەستی لە ڕۆژئاوای دوورە.‏\f* نیشتەجێ بم، 
\q1  
\v 10 لەوێش دەستی تۆ ڕێنماییم دەکات، 
\q2 دەستی ڕاستت بە خۆیەوە دەمگرێت. 
\q1  
\v 11 ئەگەر گوتم: «بێگومان تاریکی دامدەپۆشێت، 
\q2 ڕووناکیش دەبێتە شەوی دەورم،» 
\q1  
\v 12 ئەوا لە تاریکیشدا لەلای تۆ تاریک دانایەت، 
\q2 شەو وەک ڕۆژ ڕووناکی دەبەخشێت، 
\q2 تاریکیش وەک ڕووناکی وایە. 
\b  
\q1  
\v 13 تۆ ناخی منت دروستکردووە، 
\q2 لەناو سکی دایکم منت چنیوە. 
\q1  
\v 14 ستایشت دەکەم، چونکە بە سامناکی و سەرسوڕهێنەری دروستکراوم، 
\q2 کارەکانت سەرسوڕهێنەرن، 
\q2 لە ناخمەوە باش ئەمە دەزانم. 
\q1  
\v 15 ئێسقانم لە تۆ شاراوە نەبوو، 
\q2 کاتێک لە پەنهانی دروستکرام، 
\q2 لەناو سکی زەوی نەخشێنرام. 
\q1  
\v 16 هێشتا لە سکی دایکم بووم، ئەندامەکانی لەشمت بینی. 
\q2 هەموو ئەو ڕۆژانە کە بۆ من شێوەیان کێشرا، 
\q1 لە پەڕتووکەکەتدا نووسراون، 
\q2 پێش ئەوەی هیچ کامێکیان هەبن. 
\q1  
\v 17 ئەی خودایە، بیرۆکەکانت بەلای منەوە چەند گرانبەهایە! 
\q2 کۆی ژمارەیان چەندە مەزنە! 
\q1  
\v 18 ئەگەر بیانژمێرم، لە لم زیاترن. 
\q2 کە بەئاگادێمەوە هێشتا لەگەڵ تۆم. 
\b  
\q1  
\v 19 خودایە، خۆزگە بەدکارەکانت دەکوشت! 
\q2 ئەی خوێنڕێژەکان، لێم دووربکەونەوە! 
\q1  
\v 20 ئەوانەی بە خراپە باست دەکەن، 
\q2 سکاڵاکاران بەبێ هۆ لێت هەستاون! 
\q1  
\v 21 ئەی یەزدان، ئایا ڕقم لەوانە نەبێت کە ڕقیان لە تۆیە؟ 
\q2 ئایا قێزم لەوانە نەبێتەوە کە لە دژی تۆ دەوەستن؟ 
\q1  
\v 22 بە تەواوی ڕقم لێیانە، 
\q2 بوون بە دوژمنم. 
\q1  
\v 23 خودایە، بمپشکنە و بزانە دڵم چی تێدایە! 
\q2 تاقیم بکەوە و بزانە خولیای چیم. 
\q1  
\v 24 سەیر بکە ئاخۆ هیچ ڕێگایەکی خراپەم تێدایە، 
\q2 ڕێنماییم بکە لە ڕێگای هەتاهەتایی. 
\c 140  
\cl زەبووری 140 
\d بۆ گەورەی گۆرانیبێژان، زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، لە کەسی بەدکار دەربازم بکە، 
\q2 لە پیاوی توندوتیژ بمپارێزە، 
\q1  
\v 2 ئەوانەی لە دڵەوە بیر لە خراپە دەکەنەوە و 
\q2 هەموو ڕۆژێک خەریکی شەڕانگێزین. 
\q1  
\v 3 زمانیان وەک زمانی مار تیژکردووە، 
\q2 ژەهری تیرەمار لەژێر لێویانە.\f + \fr 140:3 \ft لە دەقی عیبری لێرە و لە ئایەتەکانی 5 و 8، وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 4 ئەی یەزدان، لە دەست بەدکار ئاگادارم بە، 
\q2 لە پیاوی توندوتیژ بمپارێزە، 
\q2 ئەوانەی پیلانیان داناوە بۆ ئەوەی قاچم بخلیسکێنن. 
\q1  
\v 5 لووتبەرزان تەڵەیان بۆم ناوەتەوە، 
\q2 پەت و تۆڕیان بڵاو کردووەتەوە، 
\q2 لە دەم ڕێگا داویان بۆم ناوەتەوە. 
\b  
\q1  
\v 6 بە یەزدانم گوت: «تۆ خودای منی!» 
\q2 ئەی یەزدان، گوێ لە دەنگی پاڕانەوەم بگرە. 
\q1  
\v 7 ئەی یەزدانی پەروەردگار، هێزی ڕزگاریم، 
\q2 لە ڕۆژی شەڕدا سەری منت داپۆشی. 
\q1  
\v 8 ئەی یەزدان، ئارەزووەکانی بەدکار مەهێنە دی، 
\q2 لێمەگەڕێ پیلانەکانی سەربگرێت، 
\q2 بۆ ئەوەی لووتبەرز نەبن. 
\b  
\q1  
\v 9 با سەری ئەوانەی دەوریان داوم 
\q2 بە خراپەی لێویان بپۆشرێن، 
\q1  
\v 10 با پشکۆیان بەسەردا ببارێت، 
\q2 بکەونە ناو ئاگرەوە، 
\q2 بکەونە ناو چاڵەوە، ڕاست نەبنەوە. 
\q1  
\v 11 با بوختانکەر لەسەر زەوی جێگیر نەبێت، 
\q2 با کەسی توندوتیژ ببێتە نێچیری خراپە. 
\b  
\q1  
\v 12 دەزانم یەزدان دادپەروەری دەکات بۆ هەژاران، 
\q2 ماف دەدات بە نەداران. 
\q1  
\v 13 بێگومان ڕاستودروستان ستایشی ناوت دەکەن، 
\q2 سەرڕاستان لە ئامادەبوونت دادەنیشن. 
\c 141  
\cl زەبووری 141 
\d زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، هاوارم بۆ تۆ کرد، خێرابە بۆ لام! 
\q2 گوێ لە دەنگم بگرە کە هاوارت بۆ دەکەم. 
\q1  
\v 2 با نوێژم وەک بخوور لەبەردەمت پەسەند بێت، 
\q2 دەست بەرزکردنەوەم وەک قوربانی ئێوارە بێت. 
\b  
\q1  
\v 3 ئەی یەزدان، پاسەوانێک دابنێ بۆ دەمم، 
\q2 دەرگای لێوەکانم بپارێزە. 
\q1  
\v 4 وا مەکە دڵم بەلای خراپەدا بچێت، 
\q2 نەوەک خۆم بە کردەوەی بەد خەریک بکەم، 
\q1 لەگەڵ ئەوانەی بەدکاری دەکەن؛ 
\q2 با لە شتە خۆشەکانی ئەوان نەخۆم. 
\b  
\q1  
\v 5 با پیاوچاک لێم بدات، ئەمە خۆشەویستییە، 
\q2 با سەرزەنشتم بکات، ئەمە وەک ڕۆنی بۆنخۆشی سەرە، 
\q2 سەرم لاری نییە، 
\q1 چونکە بەردەوام نوێژەکانم لە دژی خراپەکانیانە. 
\b  
\q2  
\v 6 ڕابەرانیان لە خەرەند فڕێدەدرێنە خوارێ، 
\q2 ئەوسا گوێ لە قسەم دەگرن چونکە ڕاستە. 
\q1  
\v 7 وەک کێڵان و شەقکردنی زەوی، 
\q2 ئاوا ئێسقانەکانیان لە دەمی گۆڕ پەرت دەکرێن. 
\b  
\q1  
\v 8 بەڵام چاوەکانم سەرنجیان لەسەر تۆیە، ئەی یەزدانی پەروەردگار، 
\q2 پەنا دێنمە بەر تۆ، با گیانم نەفەوتێت. 
\q1  
\v 9 بمپارێزە لەو داوەی بۆیان ناومەتەوە، 
\q2 لە تەڵەی بەدکاران. 
\q1  
\v 10 با بەدکاران پێکەوە بکەونە تۆڕی خۆیانەوە، 
\q2 لەو کاتەدا من بە ئاسوودەیی بپەڕمەوە. 
\c 142  
\cl زەبووری 142 
\d هۆنراوەیەکی داود کە لە ئەشکەوت بوو. نوێژ. 
\q1  
\v 1 پڕ بە دەنگم هاوار بۆ یەزدان دەکەم، 
\q2 بە دەنگی بەرز لە یەزدان دەپاڕێمەوە. 
\q1  
\v 2 سکاڵای خۆمی لەبەردەم هەڵدەڕێژم، 
\q2 لەبەردەمی باسی تەنگانەکانی خۆم دەکەم. 
\b  
\q1  
\v 3 لە کاتی ورەبەردانی ڕۆحم، 
\q2 تۆ شارەزای ڕێڕەوی منی. 
\q1 لەو ڕێگایەی پێیدا دەڕۆم، 
\q2 خەڵک تەڵەیان بۆم ناوەتەوە. 
\q1  
\v 4 ئاوڕ بەلای ڕاستدا بدەوە و ببینە، 
\q2 کوا ناسیاوی من؟ 
\q1 پەناگا بۆ من قڕبووە، 
\q2 کوا پرسیارکەر لە ئەحواڵی من؟ 
\b  
\q1  
\v 5 ئەی یەزدان، هاوارم بۆ تۆ کرد، 
\q2 گوتم: «تۆ پەناگای منی، 
\q2 لە خاکی زیندووان تۆ بەشی منی.» 
\b  
\q1  
\v 6 بە وردی گوێ لە لاوانەوەم بگرە، 
\q2 چونکە زۆر زەلیلم، 
\q1 لە دەست ڕاونەرانم دەربازم بکە، 
\q2 چونکە لە من بەهێزترن. 
\q1  
\v 7 گیانم لە بەندیخانە دەربهێنە، 
\q2 بۆ ئەوەی ستایشی ناوت بکەم. 
\q1 ئینجا ڕاستودروستان دەورم دەگرن، 
\q2 چونکە چاکەم لەگەڵ دەکەیت. 
\c 143  
\cl زەبووری 143 
\d زەبوورێکی داود. 
\q1  
\v 1 ئەی یەزدان، نوێژم ببیستە، 
\q2 گوێ لە پاڕانەوەم بگرە، 
\q1 بە دڵسۆزی و ڕاستودروستی خۆت 
\q2 وەڵامم بدەوە. 
\q1  
\v 2 لەگەڵ خزمەتکاری خۆت مەکەوە دادگایی، 
\q2 چونکە کەس نییە لەبەردەم تۆ بێتاوان دەربچێت. 
\q1  
\v 3 دوژمن ڕاوم دەنێت، 
\q2 ژیانمی بەرەو زەوی پێپەست کردووە، 
\q1 لەناو تاریکی داینیشاندووم 
\q2 وەک ئەوانەی دەمێکە مردوون. 
\q1  
\v 4 ڕۆحم بێ ورە دەبێت، 
\q2 لە ناخمەوە دڵم دەبەسترێت. 
\q1  
\v 5 ڕۆژگاری دێرین دێتەوە یادم، 
\q2 لە هەموو کارەکانت ورد دەبمەوە، 
\q2 سەرنج دەدەمە کردارەکانی دەستت. 
\q1  
\v 6 دەستم بۆ تۆ پاندەکەمەوە، 
\q2 گیانم بۆ تۆ وەک خاکێکی وشکە.\f + \fr 143:6 \ft لە دەقی عیبری لێرە وشەی \+tl سەلاە‏\+tl* هەیە کە لەوانەیە ئاماژەیەکە بۆ وەستانی مۆسیقا و خوێندنەوە.‏\f* 
\b  
\q1  
\v 7 ئەی یەزدان، زوو وەڵامم بدەوە، 
\q2 ڕۆحم لەناودەچێت، 
\q1 ڕووی خۆتم لێ مەشارەوە، 
\q2 ئەگینا لەوانە دەچم کە دەچنە نێو جیهانی مردووان. 
\q1  
\v 8 با بەیانییان گوێم لە خۆشەویستییە نەگۆڕەکەت بێت، 
\q2 چونکە من پشت بە تۆ دەبەستم. 
\q1 ئەو ڕێگایەم پێ بناسێنە کە دەیگرمەبەر، 
\q2 چونکە گیانی خۆم بە تۆ دەسپێرم. 
\q1  
\v 9 ئەی یەزدان، لە دوژمنەکانم دەربازم بکە، 
\q2 هانا بۆ تۆ دەهێنم. 
\q1  
\v 10 فێرم بکە بە ڕەزامەندیی تۆ کار بکەم، 
\q2 چونکە تۆ خودای منی. 
\q1 با ڕۆحە چاکەکەت ڕێنماییم بکات 
\q2 لە زەوییەکی ڕاست. 
\b  
\q1  
\v 11 ئەی یەزدان، لەبەر ناوی خۆت بمژیێنەوە، 
\q2 بە ڕاستودروستی خۆت گیانم لە تەنگانە دەربهێنە. 
\q1  
\v 12 بە خۆشەویستییە نەگۆڕەکەت دوژمنانم دەمکوت بکە، 
\q2 هەموو ئەوانە لەناوببە کە تەنگم پێ هەڵدەچنن، 
\q2 چونکە من خزمەتکاری تۆم. 
\c 144  
\cl زەبووری 144 
\d زەبوورێکی داود. 
\q1  
\v 1 ستایش بۆ یەزدان، تاشەبەردی من، 
\q2 ئەوەی مەشق بە دەستم دەکات بۆ شەڕ، 
\q2 پەنجەکانم بۆ جەنگ. 
\q1  
\v 2 ئەو خودای خۆشەویستم و قەڵامە، 
\q2 پەناگا و دەربازکەرە بۆم، 
\q1 قەڵغانمە و پشتم بەو بەستووە، 
\q2 ئەوەی گەلەکانی خستووەتە ژێر ڕکێفم. 
\b  
\q1  
\v 3 ئەی یەزدان، مرۆڤ چییە هەتا گرنگی پێبدەیت؟ 
\q2 کوڕی مرۆڤ چییە هەتا تۆ بیری لێ بکەیتەوە؟ 
\q1  
\v 4 مرۆڤ لە هەناسەیەک دەچێت، 
\q2 ڕۆژگاریشی وەک سێبەرێکی تێپەڕیوە. 
\b  
\q1  
\v 5 ئەی یەزدان، ئاسمانەکەت لێکبکەوە و وەرە خوارەوە، 
\q2 دەست بدە چیاکان و دووکەڵ دەکەن. 
\q1  
\v 6 چەخماخە بدە و دوژمنەکانم پەرت بکە، 
\q2 تیرت تێگرە و بیانبەزێنە. 
\q1  
\v 7 لە بەرزاییەوە دەستت درێژ بکە، 
\q2 فریام بکەوە و دەربازم بکە، 
\q2 لە ئاوی زۆر و لە دەستی بێگانە، 
\q1  
\v 8 ئەوانەی بە دەم درۆ دەکەن، 
\q2 سوێندخواردنیان ساختەیە. 
\b  
\q1  
\v 9 ئەی خودایە، گۆرانییەکی نوێت بۆ دەڵێم، 
\q2 بە قیسارەی دە ژێیی مۆسیقات بۆ دەژەنم، 
\q1  
\v 10 بۆ ئەوەی ڕزگاری دەدات بە پاشایان، 
\q2 ئەوەی داودی بەندەی خۆی لە شمشێری بەدکار دەرباز دەکات. 
\b  
\q1  
\v 11 دەربازم بکە و لە دەست بێگانە فریام بکەوە، 
\q2 ئەوانەی بە دەم درۆ دەکەن، 
\q2 سوێندخواردنیشیان ساختەیە. 
\b  
\q1  
\v 12 ئیتر کوڕەکانمان لە سەردەمی لاویێتییان 
\q2 وەک نەمامی گەشەکردوو دەبن، 
\q1 کچەکانمان وەک ستونی داتاشراوی 
\q2 گۆشەی کۆشک دەبن. 
\q1  
\v 13 ئەمبارەکانمان پڕ دەبن 
\q2 لە هەموو جۆرە دانەوێڵەیەک، 
\q1 مەڕەکانمان یەکە و هەزار و 
\q2 بە دەیان هەزار دەبن لەناو کێڵگەکانمان، 
\q1  
\v 14 گایەکانمان باری قورس ڕادەکێشن. 
\q2 بێ شکانی شوورا و بێ ڕاپێچکردن، 
\q2 شەقامەکانمان هاواری تەنگانەیان لێ نایێت! 
\q1  
\v 15 خۆزگە دەخوازرێ بەو گەلەی ئاوای بۆ ببێت، 
\q2 خۆزگە دەخوازرێ بەو گەلەی یەزدان خودایانە. 
\c 145  
\cl زەبووری 145 
\d ستایشێکی داود. 
\q1  
\v 1 بەرزت دەکەمەوە، ئەی خودایە، ئەی پاشا، 
\q2 هەتاهەتایە ستایشی ناوت دەکەم. 
\q1  
\v 2 هەموو ڕۆژێک ستایشت دەکەم، 
\q2 هەتاهەتایە ستایشی ناوت دەکەم. 
\b  
\q1  
\v 3 یەزدان مەزنە و شایانی ستایشێکی زۆرە، 
\q2 مەزنایەتی لە سەرووی تێگەیشتنە. 
\q1  
\v 4 هەموو نەوەیەک بۆ نەوەی دوای خۆی شایەتی بۆ کارەکانت دەدات، 
\q2 پاڵەوانیێتی تۆ ڕادەگەیەنن. 
\q1  
\v 5 دەربارەی پایەبەرزی شکۆی پاشایەتیت دەدوێن، 
\q2 منیش لە کارە سەرسوڕهێنەرەکانت ورد دەبمەوە. 
\q1  
\v 6 دەربارەی هێزی کردەوە سامناکەکانت دەدوێن، 
\q2 منیش مەزنیت ڕادەگەیەنم. 
\q1  
\v 7 یادی زۆری چاکەی تۆ هەڵدەڕێژن، 
\q2 گۆرانی بەسەر ڕاستودروستیتدا دەڵێن. 
\b  
\q1  
\v 8 یەزدان میهرەبان و بە بەزەییە، 
\q2 پشوودرێژە و پڕە لە خۆشەویستی نەگۆڕ. 
\b  
\q1  
\v 9 یەزدان بۆ هەمووان چاکە، 
\q2 بەزەییەکەی بۆ هەموو ئەوانەیە کە دروستی کردوون. 
\q1  
\v 10 ئەی یەزدان، هەموو ئەوانەی دروستت کردوون ستایشت دەکەن، 
\q2 خۆشەویستانت ستایشت دەکەن. 
\q1  
\v 11 دەربارەی شکۆمەندی شانشینەکەت دەدوێن، 
\q2 باسی پاڵەوانیێتی تۆ دەکەن، 
\q1  
\v 12 تاکو پاڵەوانیێتیت لەلای هەموو ئادەمیزادێک زانراو بێت، 
\q2 هەروەها پایەبەرزی شکۆی شانشینەکەت. 
\q1  
\v 13 شانشینەکەت شانشینی هەموو سەردەمێکە، 
\q2 فەرمانڕەوایەتیشت بەسەر هەموو نەوەکانەوەیە. 
\b  
\q1 یەزدان لە هەموو بەڵێنەکانی دڵسۆزە، 
\q2 خۆشەویستییەکەی بۆ هەموو ئەوانەیە کە دروستی کردوون. 
\q1  
\v 14 یەزدان پشتگیرە بۆ هەموو کەوتووەکان، 
\q2 ڕاستکەرەوەیە بۆ هەموو ئەوانەی چەماونەتەوە. 
\q1  
\v 15 چاوی هەمووان هیوای بە تۆیە، 
\q2 تۆش لە کاتی خۆیدا خواردنیان دەدەیتێ. 
\q1  
\v 16 دەستت دەکەیتەوە و 
\q2 ئارەزووی هەموو زیندووێک تێر دەکەیت. 
\b  
\q1  
\v 17 یەزدان لە هەموو ڕێگاکانی ڕاستودروستە، 
\q2 خۆشەویستییەکەی بۆ هەموو ئەوانەیە کە دروستی کردوون. 
\q1  
\v 18 یەزدان نزیکە لە هەموو ئەوانەی لێی دەپاڕێنەوە، 
\q2 لە هەموو ئەوانەی بە ڕاستییەوە لێی دەپاڕێنەوە. 
\q1  
\v 19 ئارەزووی هەموو ئەوانە بەجێدەهێنێت کە لێی دەترسن، 
\q2 گوێی لە هاواریان دەبێت و ڕزگاریان دەکات. 
\q1  
\v 20 یەزدان هەموو ئەوانە دەپارێزێت کە خۆشیان دەوێت، 
\q2 بەڵام هەموو بەدکاران تەفروتونا دەکات. 
\b  
\q1  
\v 21 دەمم بە ستایشی یەزدان دەدوێ، 
\q2 با هەموو گیاندارێک ستایشی ناوی پیرۆزی بکات، هەتاهەتایە. 
\c 146  
\cl زەبووری 146 
\q1  
\v 1 هەلیلویا! 
\b  
\q1 ئەی گیانی من ستایشی یەزدان بکە. 
\b  
\q1  
\v 2 هەتا لە ژیاندام ستایشی یەزدان دەکەم، 
\q2 هەتا ماوم مۆسیقا بۆ خودای خۆم دەژەنم. 
\q1  
\v 3 نە پشت بە میرەکان ببەستن، 
\q2 نە بە ئادەمیزاد کە ڕزگارییان لەلا نییە. 
\q1  
\v 4 کە ڕۆحی دەرچوو بۆ خۆڵەکەی خۆی دەگەڕێتەوە، 
\q2 لە هەمان ڕۆژدا پلانەکانی دەسڕێتەوە. 
\q1  
\v 5 خۆزگە دەخوازرێ بەو کەسەی کە خودای یاقوب یارمەتیدەری بێت و 
\q2 هیوای بە یەزدانی پەروەردگاری خۆی بێت، 
\q1  
\v 6 دروستکەری ئاسمان و زەوی و 
\q2 دەریا و هەموو ئەوەی کە تێیاندایە، 
\q2 ئەوەی هەتاهەتایە دڵسۆز دەمێنێتەوە. 
\q1  
\v 7 دادپەروەری بۆ زۆرلێکراوان بەڕێوە دەبات، 
\q2 نان دەداتە برسییەکان. 
\q1 یەزدان گیراوەکان ئازاد دەکات، 
\q2  
\v 8 یەزدان چاوی کوێرەکان دەکاتەوە، 
\q1 یەزدان کەسە چەماوەکان ڕاست دەکاتەوە، 
\q2 یەزدان ڕاستودروستانی خۆشدەوێت. 
\q1  
\v 9 یەزدان نامۆکان دەپارێزێت، 
\q1 یارمەتی هەتیو و بێوەژنان دەدات، 
\q2 بەڵام ڕێگای بەدکاران خوار دەکات. 
\b  
\q1  
\v 10 یەزدان هەتاهەتایە پاشایەتی دەکات، 
\q2 ئەی سییۆن، ئەو خودای تۆیە بۆ هەموو نەوەکانت. 
\b  
\q1 هەلیلویا. 
\c 147  
\cl زەبووری 147 
\q1  
\v 1 هەلیلویا! 
\b  
\q1 چەندە باشە مۆسیقا ژەنین بۆ خودامان! 
\q2 ستایشکردن چەندە خۆشە و شیاوە! 
\b  
\q1  
\v 2 یەزدان ئۆرشەلیم بنیاد دەنێتەوە، 
\q2 ڕاپێچکراوەکانی\f + \fr 147:2 \ft ڕاپێچکراوەکان بۆ بابل.‏\f* ئیسرائیل کۆدەکاتەوە. 
\q1  
\v 3 دڵشکاوان چاک دەکاتەوە و 
\q2 برینیان ساڕێژ دەکات. 
\q1  
\v 4 ژمارەی ئەستێرەکان دیاری دەکات و 
\q2 هەریەکەیان بە ناوێک بانگ دەکات. 
\q1  
\v 5 پەروەردگارمان گەورەیە و هێزی زۆرە، 
\q2 تێگەیشتنی بێ سنوورە. 
\q1  
\v 6 یەزدان یارمەتی بێفیزەکان دەدات و 
\q2 بەدکاران بەرەو زەوی نزم دەکاتەوە. 
\b  
\q1  
\v 7 بە سوپاسەوە گۆرانی بۆ یەزدان بڵێن، 
\q2 بە قیسارە مۆسیقا بۆ خودامان بژەنن. 
\b  
\q1  
\v 8 ئەوەی ئاسمان بە هەور دادەپۆشێت، 
\q2 باران بۆ زەوی ئامادە دەکات، 
\q2 گیا لەسەر چیاکان دەڕوێنێت، 
\q1  
\v 9 خۆراکی ئاژەڵ و 
\q2 بێچووە قەلەڕەشی دەم بە قیڕە دەدات. 
\b  
\q1  
\v 10 یەزدان بە هێزی ئەسپ خۆشحاڵ نابێت، 
\q2 بە قاچی مرۆڤ دڵشاد نییە، 
\q1  
\v 11 بەڵام یەزدان بەوانە دڵشادە کە ترسی ئەویان لە دڵدایە، 
\q2 ئەوانەی هیوایان بە خۆشەویستییە نەگۆڕەکەی هەیە. 
\b  
\q1  
\v 12 ئەی ئۆرشەلیم، ستایشی یەزدان بکە، 
\q2 ئەی سییۆن، ستایشی خودات بکە. 
\b  
\q1  
\v 13 یەزدان شمشیرەی\f + \fr 147:13 \ft شمشیر، پارچە دارێک بووە لە جیاتی قوفڵ لە دواوەی دەرگا بە شێوەی ئاسۆیی دانراوە بۆ داخستنی دەرگا.‏\f* دەروازەکانت بەهێز دەکات، 
\q2 کوڕەکانت لەناو خۆت بەرەکەتدار دەکات. 
\q1  
\v 14 لە سنوورەکانت ئاشتی بەرقەرار دەکات، 
\q2 لە باشترین گەنم تێرت دەکات. 
\b  
\q1  
\v 15 فەرمانەکەی بۆ سەر زەوی دەنێرێت، 
\q2 پەیامی ئەو زوو دێتەجێ. 
\q1  
\v 16 بەفر وەک خوری دەبارێنێت، 
\q2 زوقم وەک خۆڵەمێش بڵاو دەکاتەوە. 
\q1  
\v 17 تەرزە وەک نانەڕەق فڕێدەدا. 
\q2 کێ لە ڕووی سەرمای ئەو خۆی ڕادەگرێت؟ 
\q1  
\v 18 پەیامی خۆی دەنێرێت و دەیانتوێنێتەوە. 
\q2 بای خۆی هەڵدەکات و ئاو بەڕێدەکەوێت. 
\b  
\q1  
\v 19 پەیامی خۆی بە یاقوب ڕادەگەیەنێت، 
\q2 فەرز و حوکمەکانی بە ئیسرائیل. 
\q1  
\v 20 ئەمەی لەگەڵ هیچ نەتەوەیەکی دیکە نەکردووە، 
\q2 حوکمەکانی ئەویان نەزانیوە. 
\b  
\q1 هەلیلویا! 
\c 148  
\cl زەبووری 148 
\q1  
\v 1 هەلیلویا! 
\b  
\q1 لە ئاسمانەوە ستایشی یەزدان بکەن، 
\q2 لە بەرزاییەکان ستایشی بکەن. 
\q1  
\v 2 ئەی هەموو فریشتەکانی، ستایشی بکەن، 
\q2 ئەی هەموو سوپاکەی، ستایشی بکەن. 
\q1  
\v 3 ئەی خۆر و مانگ، ستایشی بکەن، 
\q2 ئەی هەموو ئەستێرەکانی ڕووناکی، ستایشی بکەن. 
\q1  
\v 4 ئەی بەرزترینی ئاسمان، ستایشی بکەن، 
\q2 ئەی ئەو ئاوانەی لە سەرووی ئاسمانن. 
\b  
\q1  
\v 5 با ستایشی ناوی یەزدان بکەن، 
\q2 چونکە فەرمانی دا و بەدیهێنران. 
\q1  
\v 6 هەتاهەتایە و هەتا ماون دەچەسپێن، 
\q2 فەرزی داناوە بەسەرناچێت. 
\b  
\q1  
\v 7 لە زەوییەوە ستایشی یەزدان بکەن، 
\q2 ئەی ئەژدیهاکان و قووڵایی دەریاکان، 
\q1  
\v 8 بروسکە و تەرزە، بەفر و تەم، 
\q2 ڕەشەبا، کە فەرمانی ئەو بەجێدەهێنن، 
\q1  
\v 9 چیاکان و هەموو گردەکان، 
\q2 داری بەردار و هەموو ئورزەکان، 
\q1  
\v 10 گیانلەبەر و هەموو ئاژەڵ، 
\q2 خشۆک و باڵدار، 
\q1  
\v 11 پاشاکانی زەوی و هەموو نەتەوەکان، 
\q2 میرەکان و هەموو ڕابەرانی زەوی، 
\q1  
\v 12 گەنجان و کچان، 
\q2 پیران و منداڵان. 
\b  
\q1  
\v 13 با هەموو ستایشی ناوی یەزدان بکەن، 
\q2 چونکە تەنها ناوی ئەو بەرزە، 
\q2 شکۆمەندی ئەو لە سەرووی زەوی و ئاسمانە. 
\q1  
\v 14 پیاوی بەهێزی بە گەلی خۆی بەخشیوە، 
\q2 تاکو هەموو خۆشەویستانی ستایشی بکەن، 
\q2 نەوەی ئیسرائیل، ئەو گەلەی کە لێیەوە نزیکن. 
\b  
\q1 هەلیلویا. 
\c 149  
\cl زەبووری 149 
\q1  
\v 1 هەلیلویا! 
\b  
\q1 گۆرانییەکی نوێ بۆ یەزدان بڵێن، 
\q2 ستایشی لەناو کۆڕی خۆشەویستانیەتی. 
\b  
\q1  
\v 2 با ئیسرائیل بە دروستکەری دڵخۆش بێت، 
\q2 با کوڕانی سییۆن بە پاشایان شاد بن. 
\q1  
\v 3 با بە هەڵپەڕکێ ستایشی ناوی بکەن، 
\q2 بە دەف و قیسارە مۆسیقای بۆ بژەنن، 
\q1  
\v 4 چونکە یەزدان دڵشادە بە گەلەکەی، 
\q2 بێفیزەکان بە ڕزگاری دەڕازێنێتەوە. 
\q1  
\v 5 با خۆشەویستانی بەم شکۆمەندییەوە شاد بن، 
\q2 با لەناو نوێنەکانیان گۆرانی بڵێن. 
\b  
\q1  
\v 6 با ستایشکردن بۆ خودا لەسەر زاریان بێت، 
\q2 شمشێری دوودەمیان بەدەستەوە بێت، 
\q1  
\v 7 بۆ ئەوەی تۆڵە لە نەتەوەکان بکەنەوە، 
\q2 گەلان سزا بدەن، 
\q1  
\v 8 بۆ ئەوەی پاشاکانیان بە زنجیر ببەستنەوە، 
\q2 کۆت بکەنە دەستی پیاوماقوڵانیان، 
\q1  
\v 9 بۆ ئەوەی حوکمی نووسراویان بەسەردا جێبەجێ بکەن. 
\q2 ئەمەش شکۆمەندییە بۆ هەموو خۆشەویستانی. 
\b  
\q1 هەلیلویا. 
\c 150  
\cl زەبووری 150 
\q1  
\v 1 هەلیلویا! 
\b  
\q1 ستایشی خودا بکەن، لە پیرۆزگاکەی، 
\q2 ستایشی بکەن، لە گەردوونی هێزی، 
\q1  
\v 2 ستایشی بکەن، بۆ پاڵەوانیێتی، 
\q2 ستایشی بکەن، بەپێی زۆری مەزنایەتی، 
\q1  
\v 3 بە دەم دەنگی کەڕەناوە ستایشی بکەن، 
\q2 بە دەم ساز و قیسارەوە ستایشی بکەن، 
\q1  
\v 4 بە دەف و هەڵپەڕکێ ستایشی بکەن، 
\q2 بە ئامێری ژێدار و شمشاڵ ستایشی بکەن، 
\q1  
\v 5 بە سەنجی بیستراو ستایشی بکەن، 
\q2 بە سەنجی دەنگ بەرز ستایشی بکەن! 
\b  
\q1  
\v 6 با هەموو ئەوەی هەناسە دەدات ستایشی یەزدان بکات! 
\b  
\q1 هەلیلویا.