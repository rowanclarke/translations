\v 14 A \w then|strong="H2896"\w* \w tue|strong="H3117"\w* \w vaengah|strong="H9996"\w* tah a \w then|strong="H2896"\w* \w la|strong="H9996"\w* \w om|strong="H1961"\w*. \w Tedae|strong="H9999"\w* a \w yoethae|strong="H7451"\w* \w tue|strong="H3117"\w* \w vaengkah|strong="H9996"\w* khaw \w hmu|strong="H7200"\w*. \w He|strong="H2088"\w* \w khaw|strong="H1571"\w* \w dumlai|strong="H1700"\w* \w dongah|strong="H5921"\w* \w Pathen|strong="H0430"\w* loh \w voeivang|strong="H5980"\w* ah a \w khueh|strong="H6213"\w*. Te daengah ni \w hlang|strong="H0120"\w* loh \w a|strong="H9909"\w* \w hnukah|strong="H0310"\w* te \w pakhat|strong="H3972"\w* khaw a\w hmu|strong="H4672"\w* \w pawt|strong="H3808"\w* eh.   
\s1 Ming Voei Khaw Ngaithuen  
\p
