\id 1KI - Biblica® Open Igbo Contemporary Bible 2020 
\h 1 Ndị Eze 
\toc1 1 Ndị Eze 
\toc2 1 Ndị Eze 
\toc3 1Ez 
\mt1 1 Ndị Eze 
\c 1  
\s1 Adonaịja echie onwe ya eze 
\p  
\v 1 Mgbe eze Devid ghọrọ agadi, nʼagbanyeghị na-eji ọtụtụ uwe kpuchie ya, ahụ ya ekpoghị ọkụ.  
\v 2 Ya mere, ndị na-ejere ya ozi sịrị ya, “Ka anyị chọtara eze otu nwaagbọghọ na-amaghị nwoke, onye ga-akwụ nʼihu eze ma bụrụkwa onye ga-elekọta ya. O nwere ike idina nʼakụkụ onyenwe anyị bụ eze ime ka ahụ kpoo ya ọkụ.” 
\p  
\v 3 Ha gagharịrị nʼala Izrel niile chọọ nwaagbọghọ mara mma, chọta otu nwaagbọghọ onye Shunem, aha ya bụ Abishag, kpọtaara ya eze.  
\v 4 Nwaagbọghọ a mara mma nke ukwuu; ọ lekọtakwara eze, jekwaara ya ozi ma ya na eze enweghị mmekọ ọbụla. 
\p  
\v 5 Nʼoge a, Adonaịja\f + \fr 1:5 \ft Adonaịja, bụ nwa nke anọ a mụrụ Devid. Ọkpara ya bụ Amọn, Kiliab na Absalọm nwụrụ anwụ, ma Kiliab nwụrụ nʼoge ọ bụ nwantakịrị. \xt 2Sa 3:4\f* onye nne ya bụ Hagit, wepụtara onwe ya, kwuo sị, “Aga m abụ eze.” Nʼihi nke a, ọ kwadooro onwe ya ụgbọ agha na ọtụtụ ịnyịnya, kpọtakwa iri ndị ikom ise, ndị ga-agba ọsọ nʼihu ya.  
\v 6 Na ndụ Adonaịja niile, o nweghị oge nna ya baara ya mba site nʼịjụ ya, “Gịnị mere i ji akpa agwa dị otu a?” Ọ bụ nwokorobịa mara mma nke ukwuu; ọ bụ ya na-esotekwa nwanne ya Absalọm. 
\p  
\v 7 Adonaịja na Joab, nwa Zeruaya\f + \fr 1:7 \ft Zeruaya, bụ nwanne nwanyị Devid.\f* tinyere Abịata\f + \fr 1:7 \ft Abịata, bụ nwa Ahimelek. \xt 1Sa 22:20\f* onye nchụaja, kparịtara ụka. Ha kwenyere inyere ya aka ka ọ ghọọ eze.  
\v 8 Ma Zadọk onye nchụaja, Benaya nwa Jehoiada, Netan onye amụma, Shimei, Rei na ndị agha niile na-eche Devid nche esonyeghị Adonaịja. 
\p  
\v 9 Adonaịja chịịrị atụrụ, ehi na ụmụ ehi gbara abụba, gaa nʼakụkụ En-Rogel chụọ aja na Nkume Zohelet. Ọ kpọrọ ụmụnne ya niile bụ ụmụ ndị ikom eze na ndịisi Juda niile, ndị na-ejere eze ozi oku,  
\v 10 ma ọ kpọghị Netan onye amụma, maọbụ Benaya, maọbụ ndị agha niile na-eche Devid nche. Ọ kpọkwaghị Solomọn nwanne ya. 
\p  
\v 11 Mgbe ahụ, Netan onye amụma jụrụ Batsheba nne Solomọn ajụjụ sị, “Ị nụghị na Adonaịja nwa Hagit aghọọla eze ugbu a, ma onyenwe anyị bụ Devid amaghị ihe ọbụla banyere ya?  
\v 12 Ma ugbu a, ka m dụọ gị ọdụ otu ị ga-esi zọpụta ndụ gị na ndụ nwa gị Solomọn.  
\v 13 Bakwuru eze Devid sị ya, ‘Onyenwe m bụ eze, ọ bụ na i kweghị m bụ ohu gị nkwa sị: “Nʼezie, Solomọn nwa gị ga-abụ eze nʼọnọdụ m, ọ ga-anọdụ nʼocheeze m”? Ma gịnị mere Adonaịja ji bụrụ eze?’  
\v 14 Mgbe ị ka nọ na-akpanyere eze ụka, mụ onwe m ga-abịakwute gị gbaa okwu niile ị na-ekwu ume.” 
\p  
\v 15 Batsheba bakwuuru eze nʼime ụlọ. Eze emeela nnọọ agadi nke ukwuu. Abishag onye Shunem nọkwa na-elekọta ya.  
\v 16 Batsheba gburu ikpere nʼala, kpọọ isiala nye eze. 
\p Mgbe ahụ, eze jụrụ ya sị, “Gịnị ka ị na-achọ?” 
\p  
\v 17 Batsheba zara sị ya, “Onyenwe m, i jiri \nd Onyenwe anyị\nd* Chineke gị ṅụọrọ m iyi, kwee m nkwa sị na nwa m Solomọn ga-abụ eze, nọdụkwa nʼocheeze gị.  
\v 18 Ma ugbu a, Adonaịja aghọọla eze, ma gị onyenwe m bụ eze amaghị ihe banyere nke a.  
\v 19 O jirila ọtụtụ igwe ehi na ụmụ ehi gbara abụba, na atụrụ chụọ aja. Ọ kpọkwara ụmụ ndị ikom eze niile na Abịata onye nchụaja, na Joab onyeisi agha. Ma ọ kpọghị Solomọn bụ ohu gị.  
\v 20 Ma ugbu a, onyenwe m eze, ndị Izrel niile na-ele gị anya isi nʼọnụ gị nụta onye ga-anọchi anya gị, ịnọkwasị nʼocheeze eze gị.  
\v 21 Ma ọ bụghị otu a, ngwangwa onyenwe m bụ eze ga-esoro ndị nna nna ya ha dina nʼọnwụ, mụ onwe m na nwa m Solomọn ka a ga-emeso mmeso dịka ndị mmebi iwu.” 
\p  
\v 22 Mgbe Batsheba nọ na-akpanyere eze ụka, Netan onye amụma batara.  
\v 23 A gwara eze okwu sị, “Netan onye amụma nọ nʼebe a.” Ya mere, ọ gara nʼihu eze kpọọ isiala nye ya. 
\p  
\v 24 Netan sịrị, “Onyenwe m, bụ eze, ọ bụ gị onwe gị sịrị Adonaịja ga-abụ eze mgbe ị nwụrụ, na ọ ga-anọkwasịkwa nʼocheeze gị?  
\v 25 Taa, ọ gaala jiri ọtụtụ igwe ehi, na ụmụ ehi gbara abụba, na ụmụ atụrụ chụọ aja. Ọ kpọọkwala ụmụ ndị ikom eze niile. Ọ kpọkwara ndịisi agha, na Abịata onye nchụaja. Ha na ya na-eri ihe oriri, na-aṅụkwa ihe ọṅụṅụ, na-eti mkpu na-asị, ‘Eze Adonaịja ga-adị ruo mgbe ebighị ebi.’  
\v 26 Ma ha akpọghị mụ bụ ohu gị na Zadọk, onye nchụaja, na Benaya nwa Jehoiada, na ohu gị bụ Solomọn.  
\v 27 Ọ bụ site nʼaka onyenwe m bụ eze ka ihe nke a siri mee, ma i meghị ka ndị ohu ya mata onye ga-anọdụ nʼocheeze onyenwe m eze, mgbe ọ nọghịkwa ya?” 
\s1 Devid emee Solomọn eze 
\p  
\v 28 Mgbe ahụ, Devid kwuru okwu sị, “Kpọọrọnụ m Batsheba.” Batsheba batara, guzo nʼihu eze. 
\p  
\v 29 Mgbe ahụ, eze ṅụrụ iyi sị ya, “Dịka \nd Onyenwe anyị\nd* na-adị ndụ, Onye ahụ napụtara m site na nsogbu m niile,  
\v 30 otu ahụ m siri ṅụrụ gị iyi nʼaha \nd Onyenwe anyị\nd*, Chineke Izrel, sị, na Solomọn nwa gị ga-abụ eze nʼọnọdụ m, ọ bụ ya ga-anọchi anya m, nọdụkwa nʼocheeze m. Otu ahụ ka m ga-eme nʼụbọchị taa.” 
\p  
\v 31 Mgbe ahụ, Batsheba kpọrọ isiala, gbukwaa ikpere nʼihu eze sị ya, “Ka onyenwe m eze Devid dịrị ndụ ruo mgbe ebighị ebi.” 
\p  
\v 32 Mgbe ahụ, Devid nyere iwu sị, “Kpọọrọ m Zadọk onye nchụaja, na Netan onye amụma, na Benaya, nwa Jehoiada.” Mgbe ha niile bịara nʼihu eze,  
\v 33 ọ sịrị ha, “Duru ndị ozi\f + \fr 1:33 \ft Ndị ozi nʼụlọeze, a na-ekwu ihe banyere ha nʼebe a, bụ ndị agha eze.\f* onyenwe unu, tinyere unu onwe unu, mee ka Solomọn nwa m nọkwasị nʼelu ịnyịnya muul nke mụ onwe m, kpọrọnụ ya gbada Gaihọn.  
\v 34 Nʼebe ahụ, ka Zadọk onye nchụaja, na Netan onye amụma, tee ya mmanụ ịbụ eze Izrel. Fụkwaanụ opi, tiekwanụ mkpu sị, ‘Eze Solomọn ga-adị ndụ ruo mgbe ebighị ebi.’  
\v 35 Mgbe ahụ, unu na ya ga-esokwa gbagota, ọ ga-abịa nọkwasị nʼocheeze m ịchị nʼọnọdụ m. Nʼihi na ọ bụ ya ka m họpụtara ịchị eze nʼIzrel na Juda.” 
\p  
\v 36 Benaya nwa Jehoiada zara eze sị, “Amen, ka \nd Onyenwe anyị\nd* Chineke onyenwe m na eze, kwupụta ya ka ọ dị otu a.  
\v 37 Dịka \nd Onyenwe anyị\nd* si nọnyere onyenwe m bụ eze, biko, ka o si otu a nọnyere Solomọn ime ka ocheeze ya dị ukwuu karịa ocheeze onyenwe m bụ eze Devid.” 
\p  
\v 38 Ya mere, Zadọk, onye nchụaja, na Netan onye amụma, na Benaya, nwa Jehoiada, na ndị Keret na ndị Pelet,\f + \fr 1:38 \ft Ndị Keret na ndị Pelet, bụ ndị nche eze Devid, ndị sitere na mba Kriit na Filistia. \xt 1Sa 30:14; 2Sa 2:18\f* duuru Solomọn mee ya ka ọ nọkwasị nʼelu ịnyịnya muul nke eze Devid. Emesịa, ha duuru ya gaa Gaihọn.  
\v 39 Nʼebe ahụ, Zadọk onye nchụaja wepụtara mpi mmanụ\f + \fr 1:39 \ft Mmanụ a, bụ ụdị mmanụ otiti ahụ Chineke nyere Mosis iwu ka o mee nʼAkwụkwọ \xt Ọpụ 30:22-33\f* ahụ dị nʼụlọ nzute\f + \fr 1:39 \ft Ụlọ nzute, bụ ụlọ ikwu ahụ Devid wuru maka i dọba igbe ọgbụgba ndụ Chineke. Mgbe ahụ, ụlọ nzute ahụ ka dị na Gibiọn. \xt 1Ez 3:4; 2Sa 6:17\f* Chineke, were tee Solomọn nʼisi. Ha fụkwara opi. Mgbe ahụ, ndị mmadụ niile tiri mkpu sị, “Ka eze Solomọn dịrị ndụ ruo mgbe ebighị ebi.”  
\v 40 Ndị Izrel niile sooro ya rigoo, na-afụ ọja na-aṅụrịkwa oke ọnụ, ruo nʼala mara jijiji nʼihi oke ụzụ. 
\p  
\v 41 Adonaịja na ndị ọbịa ya niile nụrụ mkpu ọṅụ ahụ mgbe ha onwe ha na-erisi nri. Mgbe Joab nụrụ opi ike ka ọ na-ada, ọ jụrụ sị, “Gịnị mere oke ụzụ dị otu a ji na-ada nʼime obodo.” 
\p  
\v 42 Ma mgbe ọ ka kpụ okwu ahụ nʼọnụ, lee Jonatan nwa Abịata onye nchụaja, ka ọ batara. Adonaịja sịrị, “Bata! Nʼihi na ị bụ ezi mmadụ amaara m na ọ bụ oziọma ka i ji bịa.” 
\p  
\v 43 Jonatan zara ya sị, “Mba, ọ dịghị otu ahụ! Onyenwe anyị eze Devid emeela Solomọn eze.  
\v 44 Eze e zigala ya na Zadọk onye nchụaja, na Netan onye amụma, na Benaya nwa Jehoiada, ndị Keret na ndị Pelet sokwa duru ya gaa. Ha mere ka ọ nọkwasị nʼelu ịnyịnya muul eze.  
\v 45 Zadọk onye nchụaja na Netan onye amụma eteela ya mmanụ na Gaihọn ịbụ eze. Ha esitekwala nʼebe ahụ ṅụrụ ọṅụ na-alaghachikwa, ndị obodo niile nọkwa ugbu a na-eme mkpọtụ, na-aṅụrịkwa ọṅụ. Ọ bụkwa ụzụ ọṅụ ha ka unu nụrụ.  
\v 46 Solomọn na-anọkwasị nʼocheeze ugbu a.  
\v 47 Ọzọkwa, ndị na-ejere eze ozi abịala ikele onyenwe anyị eze Devid ekele, na-asị, ‘ka Chineke gị mee ka aha Solomọn bụrụ aha a ma ama karịa nke gị, ka ocheeze Solomọn dịkwa ukwuu karịa nke gị.’ Eze nọkwa nʼelu ihe ndina ya kpọọ isiala ofufe,  
\v 48 sị, ‘Otuto dịrị \nd Onyenwe anyị\nd*, Chineke Izrel onye mere ka m jiri anya m hụ onye nọchiri anya nʼocheeze m taa.’ ” 
\p  
\v 49 Mgbe ahụ, Adonaịja, na ndị ọbịa ya si nʼebe ha na-eri ihe malie. Onye ọbụla sikwa nʼebe ahụ gbapụ ọsọ, nʼihi ụjọ.  
\v 50 Ma Adonaịja tụrụ egwu nke ukwuu ihe Solomọn ga-eme ya, nʼihi ya, ọ gara jide mpi dị nʼebe ịchụ aja aka.  
\v 51 Mgbe ahụ, a gwara Solomọn sị, “Adonaịja na-atụ egwu ihe Solomọn ga-eme ya, nʼihi ya ọ na-ejide mpi ebe nchụaja aka. Ọ na-asị, ‘Ka eze Solomọn ṅụọra m iyi taa sị na ọ gaghị eji mma agha gbuo ohu ya.’ ” 
\p  
\v 52 Solomọn zara sị, “Ọ bụrụ na o gosi onwe ya dịka onye kwesiri ntụkwasị obi, otu agịrị isi dị ya nʼisi agaghị ada nʼala, ma ọ bụrụ na a hụta ihe ọjọọ na nʼaka ya, ọ ga-anwụ.”  
\v 53 Mgbe ahụ, eze Solomọn, zigara ndị ozi mere ka o site nʼebe nchụaja rịdata. Adonaịja bịara kpọọ isiala nye eze Solomọn. Mgbe ahụ, Solomọn sịrị ya, “Laa nʼụlọ gị.” 
\c 2  
\s1 Ndụmọdụ Devid nyere Solomọn 
\p  
\v 1 Mgbe ụbọchị ọnwụ eze Devid na-abịaru nso, o nyere nwa ya Solomọn iwu sị ya, 
\p  
\v 2 “Oge ọnwụ m eruola,” ka ọ sịrị, “Ya mere, dị ike, meekwa dịka nwoke.  
\v 3 Debe iwu niile \nd Onyenwe anyị\nd* bụ Chineke gị nyere, bie ndụ nʼụzọ ya niile. Debekwa ụkpụrụ na ihe niile o nyere nʼiwu, na ntụziaka ya niile dịka e dere ya nʼakwụkwọ iwu Mosis. Mee nke a ka ihe niile ị ga-eme gaara gị nke ọma, nʼihe niile ị na-eme, nʼebe ọbụla ị na-eche ihu gị.  
\v 4 Ka \nd Onyenwe anyị\nd* mezuo nkwa o kwere banyere m, sị ‘Ọ bụrụ na ụmụ gị na ụmụ ụmụ ha elezie anya nʼotu ha si ebi ndụ, ọ bụrụ na ha ejegharịa nʼụzọ ikwesi ntụkwasị obi nʼihu m, jiri obi ha niile na mkpụrụobi ha mee nke a, ị gaghị achọ onye ga-anọkwasị nʼoche eze Izrel achọ.’ 
\p  
\v 5 “Ugbu a, gị onwe gị maara ihe Joab nwa Zeruaya mere m, ya bụ ihe o mere mmadụ abụọ bụ ndịisi agha Izrel, Abna nwa Nea, na Amasa nwa Jeta. O gburu ha, wufuo ọbara ha nʼoge udo, dịka a ga-asị na ọ bụ ihe e mere nʼagha. O jikwa ọbara ahụ merụọ ihe okike o kere nʼukwu na akpụkpọụkwụ o yi nʼụkwụ.  
\v 6 Ị bụ nwoke maara ihe, ị makwaara ihe ị ga-eme. Ekwela ka Joab, nʼagbanyeghị isi awọ ya, nwụọ nʼudo. 
\p  
\v 7 “Ma meere ụmụ Bazilai onye Gilead ebere. Meekwa ka ha bụrụ ndị na-eso gị rie ihe na tebul gị nʼihi na ha ji obi ha zute m mgbe m na-agba ọsọ ndụ nʼihi nwanne gị Absalọm. 
\p  
\v 8 “Cheta Shimei, nwa Gera, onye Benjamin ahụ bi nʼobodo Bahurim, onye kọchara m nkọcha jọgburu onwe ya nʼụbọchị ahụ m jere Mahanaim. Mgbe ọ bịara izute m na Jọdan, eji m aha \nd Onyenwe anyị\nd* ṅụọrọ ya iyi sị ya, ‘Agaghị m eji mma agha gbuo gị.’  
\v 9 Ma achọghị m ka ị hapụ ya dịka onye ikpe na-amaghị. Ị bụ nwoke maara ihe. Ị makwaara ihe ị ga-eme ya. Mee ka o jiri isi awọ ọbara juru baa nʼili.” 
\p  
\v 10 Emesịa, Devid sooro ndị nna nna ya ha dina nʼọnwụ. E liri ya na obodo Devid.  
\v 11 Ma ọ chịrị Izrel iri afọ anọ; ọ chịrị afọ asaa na Hebrọn, chịakwa iri afọ atọ na atọ na Jerusalem.  
\v 12 Solomọn nọdụrụ nʼocheeze nna ya Devid dịka eze. Alaeze ya guzosiri ike nke ukwuu. Ọchịchị ya gakwara nke ọma. 
\s1 Iguzosi ike nke ịchị eze Solomọn 
\p  
\v 13 Otu ụbọchị, Adonaịja nwa Hagit, bịakwutere Batsheba, nne Solomọn. Mgbe Batsheba hụrụ ya, ọ jụrụ ya ajụjụ sị, “Ọ bụkwa ọbịbịa udo ka ị bịara?” 
\p Adonaịja zara sị ya, “E, abịara m nʼudo.”  
\v 14 O kwuru sị, “O nwere ihe m nwere ịgwa gị.” 
\p Nne Solomọn zara sị ya, “Kwuo.” 
\p  
\v 15 Ọ zara sị, “Dịka ị maara, ọ bụ m nwe alaeze a. Ndị Izrel niile lekwara anya na m ga-abụ eze ha. Ma otu ọ dị, ihe niile adịghịkwa ka ọ dị na mbụ, alaeze a aghọọla nke nwanne m, nʼihi na o si nʼaka \nd Onyenwe anyị\nd* rute ya aka.  
\v 16 Ugbu a, enwere m otu ihe m na-arịọ nʼaka gị. Biko ajụkwala imere m ya.” 
\p Batsheba sịrị ya, “Gịnị bụ arịrịọ gị? Kwuo ihe ọ bụ.” 
\p  
\v 17 Ọ zaghachiri ya sị, “Biko rịọrọ m Solomọn eze, nʼihi na amaara m na ọ ga-eme ihe ọbụla ị rịọrọ ya, ka ọ kpọnye m Abishag, nwanyị Shunem ahụ, ka ọ bụrụ nwunye m.” 
\p  
\v 18 Batsheba zara sị ya, “Ọ dị mma, aga m agwara gị eze okwu.” 
\p  
\v 19 Emesịa, Batsheba bịakwutere eze Solomọn ịgwa ya okwu banyere Adonaịja. Mgbe ọ na-abata, eze sitere nʼocheeze ya bilie gaa izute ya, kpọkwaa isiala nye ya nọdụ ala nʼocheeze ya. O mere ka e butere nne eze\f + \fr 2:19 \ft Nʼụlọeze mba ndị dị nʼọwụwa anyanwụ, nne eze bụ onye a na-asọpụrụ. A na-enyekwa ya ọrụ ụfọdụ ka ọ rụọ, i ji kwanyere ya ugwu.\f* ocheeze, ọ nọdụkwara ala nʼaka nri ya. 
\p  
\v 20 Ọ sịrị, “Enwere m arịrịọ nta m chọrọ ịrịọ gị. Ajụkwala i mere m ya.” 
\p Eze zaghachiri, “Rịọọ ya nne m. Agaghị m ajụ i mere gị ya.” 
\p  
\v 21 Ya mere ọ sịrị, “Biko, kwere ka enye nwanne gị nwoke Adonaịja Abishag nwanyị Shunem, ka ọ bụrụ nwunye ya.” 
\p  
\v 22 Eze Solomọn zara nne ya sị, “Gịnị mere i ji rịọọ m ka m nye Adonaịja naanị Abishag nwanyị Shunem ka ọ bụrụ nwunye ya? Ị gaara arịọkwa m sị m nye ya alaeze m. Nʼihi na ọ bụ ya tọrọ m” Ị gaara arịọkwa nʼihi Abịata onye nchụaja ma Joab nwa Zeruaya. 
\p  
\v 23 Mgbe ahụ, eze Solomọn ji \nd Onyenwe anyị\nd* ṅụọ iyi sị, “Ka Chineke mesoo m mmeso, otu ọbụla mmeso ahụ si dị njọ, ma ọ bụrụ na Adonaịja ejighị ndụ ya kwụọ ụgwọ nʼihi arịrịọ a.  
\v 24 Ugbu a, dịka \nd Onyenwe anyị\nd* na-adị ndụ, bụ onye ahụ mere ka m nọgidesie ike nʼocheeze nna m Devid, onye mere ka ọchịchị eze m malite dịka o kwere na nkwa, a ga-eme ka Adonaịja nwụọ taa.”  
\v 25 Eze Solomọn zigara Benaya nwa Jehoiada ka ọ gaa gbuo Adonaịja. Benaya gakwara tigbuo Adonaịja. 
\p  
\v 26 Eze kpọkwara Abịata onye nchụaja sị ya, “Laghachi azụ nʼubi gị nʼAnatot.\f + \fr 2:26 \ft Anatot, bụ otu nʼime obodo nke ebo Benjamin nyere ndị nchụaja \xt Jos 21:18; Jer 1:1\f* I kwesiri ịnwụ ọnwụ ma ọ bụghị ugbu a ka a ga-egbu gị nʼihi na i buru igbe ọgbụgba ndụ Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* nʼoge nna m Devid dị ndụ. I sokwa ya hụọ ahụhụ nʼoge ahụ niile o nwere nsogbu.”  
\v 27 Ya mere, Solomọn chụpụrụ Abịata\f + \fr 2:27 \ft Ọ bụ naanị Abịata gbapụrụ mgbe a na-egbu ndị ezinaụlọ Elayị. \xt 1Sa 22:17-20\f* ka ọ ghara ịbụ onye nchụaja \nd Onyenwe anyị\nd* ọzọ. Otu a ka o si mezuo\f + \fr 2:27 \ft \xt 1Sa 2:27-36\f* bụ okwu ahụ \nd Onyenwe anyị\nd* kwuru banyere ezinaụlọ Elayị na Shaịlo. 
\p  
\v 28 Ma mgbe Joab nụrụ na Adonaịja anwụọla, ọ gbaara ọsọ gaa nʼụlọ nzute \nd Onyenwe anyị\nd* jigide mpi dị nʼakụkụ ebe ịchụ aja aka. Ọ bụ ezie na Joab so Adonaịja gbaa izu imegide Solomọn, ma o soghị Absalọm gbaa izu imegide Devid.  
\v 29 Mgbe a gwara eze Solomọn, na Joab a gbabala nʼụlọ ikwu \nd Onyenwe anyị\nd*, nọdụ nʼakụkụ ebe ịchụ aja. Solomọn nyere Benaya, nwa Jehoiada iwu sị, “Gaa, tituo ya nʼala.” 
\p  
\v 30 Benaya banyere nʼime ụlọ nzute \nd Onyenwe anyị\nd*, sị Joab, “Eze sị gị, ‘pụta ezi!’ ” 
\p Ma ọ zara, “Mba, aga m anwụ nʼebe a.” 
\p Nʼihi nke a, Benaya jekwuru eze gwa ya ihe Joab kwuru. 
\p  
\v 31 Mgbe ahụ, eze nyere Benaya iwu sị ya, “Gaa mee dịka o kwuru. Gbuo ya, liekwa ya. Nke a ga-eme ka ikpe ọmụma ghara ịdịrị mụ na ezinaụlọ nna m Devid nʼihi ikpe ọmụma dịrị Joab maka ọbara ndị aka ha dị ọcha ọ wụsiri.  
\v 32 \nd Onyenwe anyị\nd* ga-emekwa ka ọbara ọ wụsiri laa ya nʼisi, nʼihi na o ji mma agha gbuo ndị ikom abụọ, ma nna m Devid amaghị maka ya. Ha abụọ, ya bụ Abna nwa Nea, ọchịagha ndị Izrel, na Amasa nwa Jeta, ọchịagha ndị Juda, ndị dị mma ma bụrụkwa ndị ezi omume karịa ya.  
\v 33 Ka ikpe ọmụma dị nʼihi igbu ọchụ ndị a dịkwasị Joab na ụmụ ụmụ ya nʼisi ruo mgbe ebighị ebi. Ma nʼebe Devid na ụmụ ụmụ ya, na ụlọ ya, na ocheeze ya dị, ka udo \nd Onyenwe anyị\nd* dịkwasị ha ruo mgbe ebighị ebi.” 
\p  
\v 34 Benaya nwa Jehoiada gara gbuo Joab. E liri ya nʼala nke ya\f + \fr 2:34 \ft Nʼoge ochie, nʼihi na-enweghị ebe ili ozu nke ozuzu ọha, a na-eli onye ọbụla nʼala nke aka ya.\f* dị nʼọzara.  
\v 35 Mgbe ahụ, eze họpụtara Benaya, nwa Jehoiada ka ọ bụrụ onyeisi ndị agha ya niile, ma mee Zadọk onye nchụaja nʼọnọdụ Abịata. 
\p  
\v 36 Emesịa, eze ziri Shimei ozi sị ya, “wuoro onwe gị ụlọ na Jerusalem, biri nʼebe ahụ, esitekwala nʼebe ahụ pụọ jee ebe ọbụla.  
\v 37 Nʼihi na ụbọchị ị ga-apụ gafee iyi dị na Ndagwurugwu Kidrọn, mara nke ọma na ị ghaghị ịnwụ. Ọbara gị ga-adịkwa gị nʼisi.” 
\p  
\v 38 Shimei zara eze, “Okwu gị dị mma. Ohu gị ga-eme dịka onyenwe m bụ eze kwuru.” Shimei biiri nʼime Jerusalem, nọọkwa ọtụtụ ụbọchị. 
\p  
\v 39 Ma nʼọgwụgwụ afọ atọ, ndị ohu abụọ Shimei nwere gbapụrụ ọsọ gbakwuru Akish, nwa Maaka, eze Gat.\f + \fr 2:39 \ft Obodo Gat dị na Filistia.\f* Ndị mmadụ bịara gwa Shimei sị ya, “Lee, ndị ohu gị nọ na Gat.”  
\v 40 Nke a mere ka o bilie, rịkwasị nʼelu ịnyịnya ibu ya, gaa Gat, jekwuru Akish nʼihi ịchọ ndị ohu ya. Shimei gara mee ka ndị ohu ya soro ya laghachite azụ. 
\p  
\v 41 Mgbe a gwara Solomọn na Shimei hapụrụ Jerusalem gaa Gat ma lọghachikwa azụ,  
\v 42 eze ziri ozi kpọọ Shimei sị ya, “Ọ bụ na m adọghị gị aka na ntị, jiri aha \nd Onyenwe anyị\nd* ṅụọ iyi sị, ‘Mara nke ọma nʼụbọchị ọbụla ị ga-esi nʼebe a pụọ gaa nʼebe ọbụla ọzọ, na ị ga-anwụ?’ Nʼoge ahụ, ị zara m sị m, ‘Okwu gị dị mma. Aga m emekwa ya.’  
\v 43 Ọ bụ gịnị mere i ji mebie iyi ị ṅụrụ nye \nd Onyenwe anyị\nd*, jụkwa idebe ihe m nyere gị nʼiwu?” 
\p  
\v 44 Eze gwakwara Shimei okwu sị ya, “I maara ihe ọjọọ\f + \fr 2:44 \ft \xt 2Sa 16:5-13\f* niile i mere megide nna m Devid. Ugbu a \nd Onyenwe anyị\nd* ga-akwụghachi gị ụgwọ nʼihi omume ọjọọ gị.  
\v 45 Ma eze Solomọn ga-abụ onye a gọziri agọzi. Ocheeze Devid ga-eguzosikwa ike nʼihu \nd Onyenwe anyị\nd* ruo mgbe ebighị ebi.” 
\p  
\v 46 Mgbe ahụ, eze nyere Benaya, nwa Jehoiada iwu ka o gbuo Shimei. Ọ pụkwara tituo ya, ọ nwụọ. 
\p Sitekwa nʼoge ahụ, alaeze Solomọn guzosiri ike nʼaka ya. 
\c 3  
\s1 Solomọn arịọ maka amamihe 
\p  
\v 1 Solomọn na Fero eze Ijipt jikọtara onwe ha nʼotu, ọ lụrụ nwa nwanyị Fero. Ọ kpọbatara ya nʼobodo Devid ruo mgbe o wusiri ụlọeze ya na ụlọnsọ \nd Onyenwe anyị\nd*, na mgbidi gbara Jerusalem gburugburu.  
\v 2 Nʼoge ahụ, ndị Izrel ka na-achụ aja ha nʼebe dị elu niile, nʼihi na ewubeghị ụlọnsọ ukwu nye aha \nd Onyenwe anyị\nd*.  
\v 3 Ma Solomọn gosiri ịhụnanya nʼebe \nd Onyenwe anyị\nd* nọ, site na ịgbaso ntụziaka niile nke Devid nna ya nyere ya, ọ bụ naanị na ọ chụrụ ọtụtụ aja dị iche iche, na ihe nsure ọkụ na-esi isi ụtọ nʼebe dị elu dị iche iche. 
\p  
\v 4 Eze gara Gibiọn nʼihi ịchụ aja, nʼihi na ebe ahụ bụ ebe kachasị mkpa, dị elu. Solomọn chụrụ otu puku aja nsure ọkụ nʼelu ebe ịchụ aja ahụ.  
\v 5 Na Gibiọn, \nd Onyenwe anyị\nd* mere ka Solomọn hụ ya anya na nrọ nke abalị, Chineke sịrị ya, “Rịọọ ihe ọbụla ị chọrọ ka m nye gị.” 
\p  
\v 6 Solomọn zara sị, “I gosila ohu gị bụ nna m Devid obi ebere dị ukwuu, nʼihi na ọ bụ onye kwesiri ntụkwasị obi nye gị, onye ezi omume nakwa onye obi ya ziri ezi. Ị nọgidela na-egosi ya obi ebere dị ukwuu, nyekwa ya nwa nwoke ga-anọkwasị nʼocheeze ya nʼụbọchị taa. 
\p  
\v 7 “Ugbu a, \nd Onyenwe anyị\nd* bụ Chineke m, i meela ohu gị eze nʼọnọdụ nna m, bụ Devid. Ma abụ m naanị nwantakịrị\f + \fr 3:7 \ft Ọ bụghị nwantakịrị nʼọnụọgụgụ afọ kama ọ bụ nʼamamihe, nʼihi nʼoge a, ọ bụ naanị iri afọ abụọ ka Solomọn gbara. \xt 1Ih 22:5; Jer 1:6\f* na-amaghị otu esi apụ ma na-abatakwa.\f + \fr 3:7 \ft Maọbụ, \fqa na-amaghị otu m ga-esi arụ ọrụ m ndị a.\f* 
\v 8 Ohu gị nọ nʼebe a, nʼetiti ndị gị ị họpụtara, ndị bara ụba nke ukwuu, ndị a na-adịghị agụta ọnụ nʼihi nʼọnụọgụgụ ha babigara ụba oke.  
\v 9 Ya mere, nye ohu gị uche nghọta nke m ga-eji chịa ndị gị, na ịghọta ihe dị iche nʼetiti ezi ihe na ajọ ihe. Nʼihi na onye pụrụ ịchịkọta ndị gị a dị ukwuu?” 
\p  
\v 10 Ọ masịrị Onyenwe anyị na Solomọn rịọrọ nke a.  
\v 11 Ya mere, Chineke zara sị ya, “Nʼihi na ị rịọrọ amamihe na nghọta ị ga-eji chịa ndị m, ma ị rịọghị m ka m nye gị ndụ ogologo, maọbụ akụnụba, maọbụ ọnwụ nye ndị iro gị.  
\v 12 Aga m eme dịka ihe ị rịọrọ si dị. Aga m enye gị obi maara ihe na uche ịghọta ihe ziri ezi, nke ga-abụ na ọ dịghị onye ọbụla dịka gị, ọ dịghịkwa onye ọbụla ga-adị ka gị.  
\v 13 Ọzọkwa, aga m enyekwa gị ihe ndị ahụ ị na-arịọghị m, akụnụba, na nsọpụrụ, ka ọ ga-abụ nʼụbọchị niile nke ndụ gị, ị gaghị enwe onye ọbụla ga-adị ka gị nʼetiti ndị eze niile.  
\v 14 Ọ bụrụkwa na i jee ije nʼụzọ m niile, debe iwu m, meekwa ihe m gwara gị, dịka nna gị Devid mere, aga m enye gị ogologo ndụ.”  
\v 15 Mgbe ahụ, Solomọn si nʼụra teta, ghọtakwa na ọ bụ nrọ ka ọ na-arọ. 
\p Ọ lọtara na Jerusalem bata guzo nʼihu igbe ọgbụgba ndụ Onyenwe anyị, chụọ aja nsure ọkụ na aja udo. Emesịa, o meere ndị na-ejere ya ozi oke oriri. 
\s1 Ikpe ziri ezi Solomọn kpere 
\p  
\v 16 Mgbe ihe ndị a gasịrị, ụmụ nwanyị akwụna abụọ bịakwutere eze, guzo nʼihu ya.\f + \fr 3:16 \ft Ka o dozieere ha okwu.\f* 
\v 17 Otu nʼime ha gwara ya sị, “Onyenwe m, mụ na nwanyị a bi nʼotu ụlọ. Anyị abụọ dịkwa ime. Ma eburu m ya ụzọ mụọ nwa nke m.  
\v 18 Mgbe ụbọchị atọ gasịrị ka m mụsịrị nwa, ya onwe ya mụkwara nwa nke ya. Naanị anyị abụọ bi, o nweghị onye ọzọ binyere anyị. 
\p  
\v 19 “Ma nʼotu abalị, nwa ya nwụrụ mgbe o dinakwasịrị ya nʼoge ọ na-arahụ ụra.  
\v 20 Mgbe o biliri nʼetiti abalị, chọpụtara na nwa ya anwụọla, o kuuru ya nibe ya nʼakụkụ m, kurukwanụ nwa nke m dị ndụ nibe nʼakụkụ ya onwe ya.  
\v 21 Nʼisi ụtụtụ, mgbe m tetara nʼụra chọọ inye nwa m ara, achọpụtara m na ọ nwụọla. Ma mgbe m leziri ya anya nke ọma ka chi bọrọ, ahụrụ m na nwa mụ na ya dina abụghị nwa nke m mụrụ.” 
\p  
\v 22 Mgbe ahụ, nwanyị nke ọzọ kwuru sị, “Mba, nwantakịrị ahụ dị ndụ bụ nwa m, ma nke nwụrụ anwụ bụ nwa gị.” Nwanyị nke mbụ zara sị, 
\p “Mba, ọ bụghị eziokwu; nwa nke nwụrụ anwụ bụ nke gị, ma nke dị ndụ bụ nke m.” Otu a ka ha si na-arụrịta ụka nʼihu eze. 
\p  
\v 23 Eze kwuru sị, “Onye nke a na-asị, ‘Nwa m bụ nke dị ndụ, ma nke gị bụ nke nwụrụ anwụ,’ mgbe onye nke ọzọ na-asị, ‘Mba! Nwa gị bụ nke nwụrụ anwụ, ma nke m bụ nke dị ndụ.’ ” 
\p  
\v 24 Mgbe ahụ, eze sịrị, “Wetara m mma agha.” Ya mere, ha wetaara eze mma agha.  
\v 25 Eze nyere iwu sị, “Kpọwaa nwa ahụ dị ndụ ụzọ abụọ, were otu ọkara nye otu onye, werekwa nke ọzọ nye onye nke ọzọ.” 
\p  
\v 26 Nwanyị ahụ nwa ya dị ndụ jupụtara nʼọmịiko nʼebe nwa ya nọ, ọ gwara eze sị, “Biko, onyenwe m, kunye ya nwantakịrị ahụ dị ndụ. Egbukwala ya.” 
\p Ma onye nke ọzọ sịrị, “Kpọwaa ya abụọ. Nwa a agaghị abụ nke gị, ọ gaghị abụkwa nke m.” 
\p  
\v 27 Mgbe ahụ, eze kpebiri ikpe sị, “Kuru nwantakịrị a dị ndụ kunye ya nwanyị ahụ chọrọ ka ọ dị ndụ. Egbula ya, nʼihi na nwanyị ahụ bụ nne ya.” 
\p  
\v 28 Mgbe ndị Izrel niile nụrụ otu eze si kpebie ikpe a, ha sitere nʼịtụ egwu nye eze nsọpụrụ, nʼihi na ha hụrụ na o si nʼaka Chineke nweta amamihe\f + \fr 3:28 \ft \xt 1Ez 3:9,11-12; 2Ih 1:12; Dan 1:17; Kọl 2:2,3\f* ikpe ikpe ziri ezi. 
\c 4  
\s1 Ndịisi ozi Solomọn 
\p  
\v 1 Ya mere Solomọn ghọrọ eze ndị Izrel niile. 
\b  
\li4  
\v 2 Ndị a bụ aha ndịisi ọchịchị obodo eze Solomọn họpụtara inyere ya aka. 
\b  
\li1 Azaraya,\f + \fr 4:2 \ft Zadọk mụrụ Ahimaaz, Ahimaaz a mụọ Azaraya. Ya mere, Zadọk ji bụrụ nna nna Azaraya. Azaraya bụ onyeisi nchụaja nʼIzrel nʼafọ niile Solomọn chịrị, nʼihi na mgbe ahụ Ahimaaz anwụọla. \xt 2Sa 15:27,36; 1Ih 6:8-9\f* nwa Zadọk bụ onye nchụaja. 
\li1  
\v 3 Elihoref na Ahija, ụmụ ndị ikom Shisha, bụ ndị ode akwụkwọ. 
\li1 Jehoshafat, nwa Ahilud bụ onye na-edekọ akụkọ. 
\li1  
\v 4 Benaya, nwa Jehoiada bụ onyeisi agha ndị Izrel. 
\li1 Zadọk na Abịata, bụ ndị nchụaja. 
\li1  
\v 5 Azaraya nwa Netan bụ onyeisi na-elekọta ndị na-ejere eze ozi. 
\li1 Zabud nwa Netan bụ onye nchụaja na onye ndụmọdụ nye eze. 
\li1  
\v 6 Ahisha, bụ onyeisi na-elekọta nʼụlọeze. 
\li1 Adoniram nwa Abda bụ onyeisi na-elekọta ndị ọrụ mmanye. 
\b  
\p  
\v 7 Eze Solomọn họpụtara ndị ikom iri na abụọ ndị o mere ndịisi ga-elekọta akụkụ iri na abụọ nke o mere ka Izrel dịrị. Mmadụ iri na abụọ ndị a nwekwa ọrụ iwetara eze ihe oriri. Nwoke ọbụla nʼime ha nwe iwetara eze na ezinaụlọ ya ihe oriri otu ọnwa nʼafọ. 
\b  
\li4  
\v 8 Nke a bụ aha ndị ikom iri na abụọ ahụ. 
\b  
\li1 Ben-Hua, onye na-achị ala ugwu ugwu Ifrem. 
\li1  
\v 9 Ben-Deka, onye na-achị Makaz, na Shaalbim na Bet-Shemesh, na Elọn Bethanan. 
\li1  
\v 10 Ben-Hesed, onye na-achị Arubot, na Soko, na Ala Hefa niile. 
\li1  
\v 11 Ben-Abinadab, onye na-achị ala elu elu Doa. Nwoke a lụrụ Tafat, nwa nwanyị Solomọn. 
\li1  
\v 12 Baana, nwa Ahilud, onye na-achị Teanak, na Megido nʼakụkụ Bet-Shan niile, nke dị nʼakụkụ Zaretan na ndịda Jezril, sitekwa na Bet-Shan ruo Ebel-Mehola gafee ma ruokwa Jokmeam. 
\li1  
\v 13 Ben-Geba, onye na-achị Ramọt Gilead, na obodo niile nke ikwu Jaịa, nwa Manase nwere nʼime Gilead, na akụkụ Agob niile nke dị na Bashan, na iri obodo ukwu isii e ji mgbidi gbaa gburugburu, nke nwekwara mkpọrọ bronz e ji kpụọ ụzọ ya. 
\li1  
\v 14 Ahinadab nwa Ido, onye na-achị Mahanaim. 
\li1  
\v 15 Ahimaaz, onye na-achị Naftalị (ọ lụkwara nwa nwanyị Solomọn a na-akpọ Basemat). 
\li1  
\v 16 Baana nwa Hushaị, onye na-achị Asha na Alot. 
\li1  
\v 17 Jehoshafat nwa Parua onye na-achị Isaka. 
\li1  
\v 18 Shimei nwa Ela onye na-achị Benjamin. 
\li1  
\v 19 Gebea nwa Uri, onye na-achị Gilead (ala Saịhọn eze ndị Amọrait, na nke Ọg eze Bashan). Naanị ya ka e doro dịka gọvanọ ala ahụ. 
\s1 Ihe a na-ebubatara Solomọn kwa ụbọchị 
\p  
\v 20 Nʼoge a, ndị Juda na Izrel bara ụba nʼọnụọgụgụ dịka aja dị nʼakụkụ osimiri. Ha dịkwa ukwuu nʼọnụọgụgụ. Ha na-eri na-aṅụ, na-emekwa onwe ha obi ụtọ.  
\v 21 Ala niile Solomọn na-achị sitere nʼoke osimiri Yufretis ruo ala ndị Filistia, rukwaa nʼoke ala ndị Ijipt.\f + \fr 4:21 \ft Oke alaeze niile Solomọn bụ dịka Chineke kweere ya Ebraham na nkwa \xt Jen 15:18-21; Dit 17; 11:24; Jos 1:4.\f* Ndị niile a lụgburu nʼagha nʼobodo ndị a na-atụta ụtụ ha na-enye Solomọn. Ha nọgidekwara nʼokpuru Solomọn ụbọchị niile nke ndụ ya. 
\p  
\v 22 Ihe oriri a na-ewebata nʼụlọ Solomọn ụbọchị niile bụ otu narị bushel ụtụ ọka na iri bushel asatọ, na iri akpa ọka a kwọrọ akwọ isii,  
\v 23 na ehi iri mara abụba, na iri ehi abụọ a zụrụ nʼebe a na-azụ anụ, na narị atụrụ na ewu. A gụnyeghị anụ ele na mgbada na oke ele na ọkụkọ ọma\f + \fr 4:23 \ft Ya bụ, ụgbala mmiri\f* a na-ewebata.  
\v 24 Nʼihi na ọ chịrị alaeze niile a ruo nʼakụkụ ọdịda anyanwụ nke osimiri Yufretis, site na Tifsa ruo na Gaza.\f + \fr 4:24 \ft Tifsa ruo na Gaza, bụ obodo dị nʼọwụwa anyanwụ nke ugwu. Ọ bụ oke alaeze Solomọn nʼugwu, bụrụkwa obodo dị mkpa nke dị nʼakụkụ osimiri Yufretis. Gaza na Filistia bụ obodo ndị dị nso nʼosimiri Mediterenịan. Ha bụ oke ala nʼọwụwa anyanwụ nke ndịda alaeze ahụ.\f* O nwekwara udo nʼakụkụ niile.  
\v 25 Nʼoge ndụ Solomọn niile, Juda na Izrel site na Dan ruo Bịasheba bi nʼudo. Nwoke ọbụla nọ nʼokpuru osisi vaịnị na nʼokpuru osisi fiig nke ya.\f + \fr 4:25 \fq Nwoke ọbụla nọ nʼokpuru osisi vaịnị na nʼokpuru osisi fiig nke ya \ft Nke a pụtara nʼezinaụlọ ọbụla, \fqa biri nʼudo na nchekwa nʼụlọ ha. \xt Jer 23:6.\f* 
\p  
\v 26 Ọnụọgụgụ ụlọ a na-etinye ụgbọ agha ịnyịnya na-adọkpụ nke Solomọn nwere dị puku anọ. Ọnụọgụgụ ịnyịnya a na-agba agba o nwere dị puku iri na abụọ.\f + \fr 4:26 \ft \xt Dit 17:16\f* 
\p  
\v 27 Nʼọnwa ọbụla, ndị ahụ a họpụtara ịchị Izrel na-ewetara eze Solomọn na ndị ụlọ ya ihe oriri. Ha adịghị ekwekwa ka otu ihe kọọ nʼụlọ ya.  
\v 28 Ha na-ewetakwa ọka balị na ahịhịa ọka nʼebe o kwesiri, maka ịnyịnya na-adọkpụ ụgbọ agha na ịnyịnya ụkwụ ọsọ ndị ọzọ dịka ihe ha ketara nʼụtụ si dị. 
\s1 Amamihe Solomọn 
\p  
\v 29 Chineke nyere Solomọn amamihe, na uche nghọta, na mmụọ ịmụta ọtụtụ ihe nke bara ụba dịka aja dị nʼakụkụ osimiri.  
\v 30 Amamihe Solomọn dị ukwuu karịa amamihe ndị si ọwụwa anyanwụ.\f + \fr 4:30 \ft Ebe a, na-ekwu banyere ebo ndị Arab bi na mpaghara ọwụwa anyanwụ Palestia. \xt Jen 25:6; Nkp 6:3,33; 7:12; 8:10\f* Nʼezie, ọ dị ukwuu karịakwa amamihe ndị maara ihe nʼIjipt.  
\v 31 Ọ maara ihe karịa onye ọbụla, karịa Etan onye Ezra, na Heman, na Kalkol, na Dada, ụmụ ndị ikom Mahol. Ihe banyere ịdị ukwuu ya gbasara na mba niile gbara ha gburugburu.  
\v 32 Ọ tụrụ puku ilu atọ, deekwa abụ ọnụọgụgụ ha dị otu puku na ise.  
\v 33 O kwuru okwu banyere osisi, site na osisi sida nke Lebanọn ruo nʼahịhịa hisọp nke na-eto na mgbidi aja, na ihe banyere ụmụ anụmanụ na anụ ufe, na anụ na-akpụgharị nʼala nakwa azụ.  
\v 34 Ndị eze niile dị nʼụwa bụ ndị bịara ịnụrụ banyere amamihe ya zitere ndị si na mba niile dị iche iche ịnụrụ okwu amamihe Solomọn. 
\c 5  
\s1 Nkwado maka iwu Ụlọnsọ ukwu 
\p  
\v 1 Mgbe Hiram eze Taịa\f + \fr 5:1 \ft \xt 2Sa 5:11; 2Ih 14:1\f* nụrụ na eteela Solomọn mmanụ ịbụ eze nʼọnọdụ nna ya Devid, o zipụrụ ndị ozi ya ijekwuru Solomọn, nʼihi na ya na Devid bụ enyi, dịrịkwa na mma.  
\v 2 Mgbe ahụ, Solomọn zigara Hiram ozi, sị ya: 
\pm  
\v 3 “Ị maara na Devid nna m enweghị ike iwu ụlọnsọ ukwuu nye Aha \nd Onyenwe anyị\nd* Chineke ya, nʼihi agha niile ọ lụrụ mgbe ọ dị ndụ.\f + \fr 5:3 \ft \xt 1Ih 28:2-3; 22:7-8\f* Ọ nọkwa na-eche ka \nd Onyenwe anyị\nd* nye ya udo.  
\v 4 Ugbu a, \nd Onyenwe anyị\nd* Chineke m enyela m udo nʼakụkụ ọbụla. Enwekwaghị m ndị iro, ma ọ bụkwanụ ihe ndakwasị ọjọọ ọbụla.  
\v 5 Nʼihi ya, ana m achọ iwu ụlọnsọ ukwu nye Aha \nd Onyenwe anyị\nd* Chineke m, dịka \nd Onyenwe anyị\nd* gwara nna m Devid mgbe ọ sịrị ya, ‘Nwa gị nwoke, onye m ga-eme ka ọ nọdụ nʼocheeze gị, ga-ewu ụlọnsọ ukwu nye Aha m.’ 
\pm  
\v 6 “Ya mere, nye iwu ka e gbutuoro m osisi sida nke Lebanọn. Ndị ọrụ m ga-esoro ndị nke gị nʼọrụ a. Aga m akwụ gị ihe ọbụla i kpebiri bụ ụgwọ ọrụ ha. Ị maara na anyị enweghị ndị ọka igbutu osisi dịka ndị Saịdọn.” 
\p  
\v 7 Mgbe Hiram nụrụ ozi Solomọn ziri, obi tọrọ ya ụtọ nke ukwuu. O kwuru sị, “Otuto dịrị \nd Onyenwe anyị\nd* taa, nʼihi na o nyela Devid nwa nwoke nwere amamihe ịchị mba ukwuu a.” 
\p  
\v 8 Ya mere, Hiram zigaara Solomọn ozi sị, 
\pm “Anụla m ozi i ziteere m. Aga m emekwa ihe niile dịka i kwuru banyere i budatara gị osisi sida na osisi junipa.  
\v 9 Ndị ohu m ga-esi nʼugwu Lebanọn budaruo ha nʼosimiri Mediterenịa. A ga-ekekọta ha ọnụ, zitere gị ha nʼebe ị chọrọ ịnọ buru ha. Mgbe ha sere nʼelu mmiri rute ebe ị chọrọ, anyị ga-atọsakwara gị ha, ka i buru ha. Ma gị onwe gị ga-eme ihe bụ ọchịchọ m, site na-inye ndị ụlọ m ihe oriri.” 
\p  
\v 10 Nʼụzọ dị otu a, Hiram nọgidere na-ezitere Solomọn osisi sida na junipa niile ọ chọrọ.  
\v 11 Solomọn nyere Hiram na ezinaụlọ ya narị puku bushel, na iri puku bushel ọka wiiti abụọ, ka ọ bụrụ ihe oriri nye ezinaụlọ ya, tinyekwara narị puku galọọnụ, na iri puku galọọnụ abụọ nke mmanụ oliv asụrụ asụ. Solomọn nọgidere na-enye Hiram ihe ndị a kwa afọ.  
\v 12 \nd Onyenwe anyị\nd* nyere Solomọn amamihe dị ukwuu dịka o kwere ya na nkwa. Hiram na Solomọn nwere mmekọ udo, ha abụọ gbakwara ndụ. 
\p  
\v 13 Eze Solomọn, sitere nʼakụkụ Izrel niile kpọbata ndị ọrụ mmanye ọnụọgụgụ ha dị iri puku atọ.  
\v 14 Nʼotu ọnwa, ọ na-eziga puku mmadụ iri nʼime ndị a ka ha gaa Lebanọn ịrụ ọrụ. Nʼọnwa ọzọ, ọ na-ezigakwa puku mmadụ iri ka ha gaa gbanwee ndị buuru ụzọ gaa. Nʼụzọ dị otu a, otu ụzọ nʼime iri puku mmadụ atọ ndị a na-anọ na Lebanọn otu ọnwa maka ịrụ ọrụ, ma ha na-alọta zuo ike ọnwa abụọ. Adoniram\f + \fr 5:14 \ft \xt 1Ez 12:18\f* bụ onyeisi ndị ọrụ mmanye a.  
\v 15 Solomọn nwere ndị ọrụ ọzọ ọnụọgụgụ ha dị iri puku asaa na-ebu ibu, nweekwa ndị na-awa nkume nʼugwu ọnụọgụgụ ha dị iri puku asatọ.  
\v 16 Nʼagụnyeghị ndị a, o nwekwara ndịisi, ndị na-elekọta ndị ọrụ ndị a, ọnụọgụgụ ha dị puku atọ na narị atọ.  
\v 17 Dịka iwu eze si dị, ha na-esite nʼebe a na-awa nkume ebupụta nkume dị mma buru ibu nke e ji ewu ntọala ụlọnsọ ukwu ahụ  
\v 18 Ndị ikom si Gebal, nyere ndị ọrụ Solomọn na ndị ọrụ Hiram aka, igbutu osisi na ịwa ha. Ha nyekwara aka ịkwado nkume e ji ewu ụlọ ahụ. 
\c 6  
\s1 Solomọn ewuo Ụlọnsọ Ukwu 
\p  
\v 1 Solomọn bidoro iwu ụlọnsọ ukwu \nd Onyenwe anyị\nd* ahụ nʼọnwa Zif,\f + \fr 6:1 \ft Ọnwa Zif, bụ ọnwa abụọ nʼafọ, nʼọnụọgụgụ afọ ndị Juu ma bụrụ ọnwa ise nʼafọ nʼọnụọgụgụ afọ ugbu.\f* bụ ọnwa nke abụọ nʼafọ nke anọ nke ịbụ eze ya. Ọ bụkwa nʼafọ nke mere ya narị afọ anọ na iri afọ asatọ site nʼoge ndị Izrel si nʼala Ijipt pụta. 
\p  
\v 2 Ụlọnsọ nke eze Solomọn wuuru \nd Onyenwe anyị\nd* dị iri mita abụọ na asaa nʼogologo, mita itoolu nʼobosara, ebe ịla elu ya dịkwa mita iri na anọ.  
\v 3 Mpụta ọnụ ụlọ nke dị nʼihu ụlọ ezumezu nke ụlọnsọ ahụ dị mita itoolu nʼogologo nke gbakwunyere ihe nʼobosara ụlọnsọ ahụ, dịrịkwa mita anọ na ọkara nʼobosara ya.  
\v 4 O meere ụlọnsọ ahụ oghereikuku kpara nkpa nʼime ma saa mbara nʼezi, nʼebe elu elu mgbidi ụlọ ahụ.  
\v 5 Nʼakụkụ mgbidi ụlọ ezumezu ahụ nakwa mgbidi nke ime ebe nsọ ahụ, o wuru okpukpu gburugburu ụlọ ahụ, nke nwere ọtụtụ ụlọ nta dị iche iche gbaa gburugburu.  
\v 6 Obosara okpukpu ụlọ nke dịkarịsịrị ala\f + \fr 6:6 \ft Maọbụ, \fqa ụlọ nke mbụ dị nʼala\f* bụ mita abụọ na ọkara, obosara okpukpu nke ụlọ etiti dị mita atọ, otu a kwa, obosara okpukpu ụlọ nke atọ dị mita atọ na ọkara. Mgbe e wuru mgbidi gbara ụlọnsọ ukwu ahụ gburugburu, e wukwara ihe dịka aka nʼakụkụ mgbidi ahụ niile. Ọ bụ nʼelu ihe ndị a dịka aka ka e dokwasịrị osisi e ji wuo ọnụụlọ nta ndị ahụ. Nʼụzọ dị otu a, ka e ji gbochie ịmanye ihe ọbụla nʼaja ụlọnsọ ukwu ahụ. 
\p  
\v 7 Mgbe a na-ewu ụlọnsọ ukwu ahụ, ọ bụ naanị nkume awara nke ọma nʼebe a nọ gwupụta ha ka eji wuo ya. O nweghị onye nụrụ ụzụ itipịa nkume, maọbụ ụzụ ịwa osisi, maọbụ ụdị mkpọtụ ahụ ngwa ọrụ mkpirisi igwe na-eme, nʼebe a nọ wuo ụlọnsọ ukwu ahụ, mgbe a na-ewu ya. 
\p  
\v 8 Ọnụ ụzọ e si abata nʼọnụ ụlọ ndị dị nʼokpukpu ụlọ elu nke mbụ dị nʼakụkụ aka nri nke ụlọnsọ ukwu ahụ. E nwekwara ụzọ nrigo e wuru e si abanye nʼọnụ ụlọ ndị dị nʼokpukpu ndị dị nʼetiti. A na-esitekwa na nke a rigoro ruo na nke atọ.  
\v 9 Mgbe o wusiri ụlọnsọ ukwu a, Solomọn jiri ibe osisi na osisi dị obosara e si nʼosisi sida mepụta, wuo ihe mgbachị elu ụlọ ahụ.  
\v 10 O wuru ọtụtụ ọnụụlọ nta nʼakụkụ mgbidi gbara ụlọnsọ ukwu ahụ gburugburu. Ọ bụkwa osisi sida ka e ji jikọta mgbidi ụlọ ahụ na ọnụụlọ nta ndị ahụ. Ịdị elu nke ọbụla nʼime ha bụ mita abụọ na ọkara. 
\p  
\v 11 Okwu \nd Onyenwe anyị\nd* rutere Solomọn ntị,  
\v 12 “Banyere ụlọnsọ ukwu a i na-ewu, ọ bụrụ na i mee ihe m gwara gị, gbasoo ihe niile m nyere gị nʼiwu, ma mezuo okwu m niile, aga m esite na gị mezuo nkwa ahụ m kwere nna gị Devid.  
\v 13 Aga m ebikwa nʼetiti ndị Izrel, agaghị m ahapụkwa ndị m, Izrel.” 
\p  
\v 14 Emesịa, Solomọn wusiri ụlọnsọ ukwu ahụ.  
\v 15 O ji osisi sida dị obosara machie ahụ ime ụlọnsọ ukwu ahụ site nʼakụkụ ala ruo nʼelu ya. E jikwa osisi junipa machie ala ụlọ ahụ niile.  
\v 16 O ji osisi sida kewapụta ihe ruru mita itoolu nʼazụ ụlọnsọ ukwu ahụ, site nʼala ụlọ ahụ ruo nʼelu, nʼihi iwepụta site nʼụlọnsọ ahụ, ime ime ebe nsọ, nke bụ Ebe Kachasị Nsọ.  
\v 17 Ụlọ ezumezu nke dị nʼihu ọnụụlọ a dị iri mita na asatọ.  
\v 18 Ahụ ime ụlọnsọ ukwu ahụ bụ osisi sida, nke a tụrụ ihe ọtụtụ nke oyiyi afụfa ọhịa na okoko osisi wasara awasa nʼelu ya. Ihe niile dị nʼime ụlọ ahụ bụ osisi sida, adịghị ahụ nkume ọbụla anya. 
\p  
\v 19 Ọ kwadokwara ebe nsọ ahụ, ebe dị nʼime ime ụlọ ahụ, maka idebe igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* nʼebe ahụ.  
\v 20 Ime ime ebe nsọ ahụ, dị mita iri nʼogologo, obosara ya dịkwa mita iri, ịdị elu ya dịkwa mita iri.\f + \fr 6:20 \ft \xt Ọpụ 37:25-28; 1Ez 7:48-50\f*\f + \fr 6:20 \ft Ogologo ime ime nʼụlọnsọ ukwu a, bụ ọtụtụ abụọ, ma a tụnyere ya na Ebe Kachasị Nsọ nke ụlọ nzute ahụ. \xt Ọpụ 26\f* O ji ọlaedo a nụchara anụcha machie ahụ ime ụlọ a niile, jiri osisi sida machie ebe nchụaja ya.  
\v 21 Solomọn ji ọlaedo a nụchara anụcha machie ahụ ime ụlọnsọ ukwu ahụ. Ọ gbatịrị ụdọ ọlaedo gafere nʼihu ime ime ebe nsọ ahụ, nke e jikwa ọlaedo machie.  
\v 22 Ya mere, o ji ọlaedo machie ime ya niile. O jikwa ọlaedo machie ebe ịchụ aja nke dịịrị ime ime ebe nsọ ahụ. 
\p  
\v 23 O mere cherubim abụọ, nke e ji osisi oliv tụọ nʼime ime ebe nsọ ahụ, ịdị elu nke ọbụla bụ mita ise.  
\v 24 Cherub nke mbụ nwere nku abụọ, otu nku dị mita abụọ na ụma atọ nʼogologo, nku nke ọzọ dịkwa mita abụọ na ụma atọ nʼogologo. Ya bụ, mita ise site na ụma isii, site nʼọnụ otu nku ruo nʼọnụ nku nke ọzọ.  
\v 25 Cherub nke abụọ dịkwa iri mita na ụma isii, nʼihi na cherubim abụọ ndị a bụ otu nʼọtụtụ nakwa nʼibu ibu.  
\v 26 Ịdị elu nke cherub ọbụla ruru mita ise na ụma isii.  
\v 27 O tinyere cherubim ndị a nke gbasapụrụ nku ha nʼime ime Ebe Nsọ Kachasị Nsọ nke ụlọnsọ ukwu. Ọnụ ọnụ nke nku cherub ọbụla na-emetụ otu akụkụ ahụ ụlọ ahụ, ebe ọnụ ọnụ nke nku cherub ọbụla na-emetụ na nke ibe ya nʼetiti ọnụụlọ ahụ.  
\v 28 O jiri ọlaedo machie cherubim ndị ahụ. 
\p  
\v 29 Nʼahụ aja ụlọnsọ ukwu ahụ gbaa gburugburu, ma nʼime ọnụụlọ nke dị nʼime na ndị dị na mpụta, ka ọ pịkwasịrị oyiyi cherubim, osisi nkwụ na okoko osisi wara awa.  
\v 30 O jikwa ọlaedo machie ala ụlọ nke ọnụụlọ niile dị nʼime ụlọ, na ọnụụlọ ndị dị na mpụta ụlọnsọ ukwu ahụ. 
\p  
\v 31 O ji osisi oliv mee ibo ọnụ ụzọ mbata nke ime ime ebe nsọ ahụ, osisi ndị a bụ otu ụzọ nʼụzọ ise nke obosara ebe nsọ ahụ.  
\v 32 Nʼahụ ibo abụọ ahụ nke si nʼosisi oliv, ọ tụnyere oyiyi cherubim abụọ, igu nkwụ na okoko osisi wara awa. O ji ọlaedo etipịara etipịa machie oyiyi cherubim na igu nkwụ ndị ahụ.  
\v 33 Otu a kwa, o ji osisi oliv mee mbudo ibo ọnụ ụzọ e si abata nʼụlọ ezumezu ahụ, nke bụ otu ụzọ na nkewa anọ nke obosara ụlọ ezumezu ahụ.  
\v 34 O jikwa osisi junipa mee ibo abụọ a na-emechikọta nʼotu.  
\v 35 Ọ pịrị oyiyi cherubim na oyiyi nkwụ, na oyiyi okoko osisi wara awa, jiri ọlaedo techie ibo ndị ahụ na oyiyi a pịkwasịrị ha. 
\p  
\v 36 O wuru ogige nʼime ụlọnsọ ukwu ahụ. Ọ bụ ahịrị nkume atọ e doziri edozi na otu ahịrị osisi sida a kwachara nke ọma ka e ji wuo ogige a. 
\p  
\v 37 Ọ bụ nʼọnwa Ziv, nʼafọ nke anọ, nke ịbụ eze Solomọn ka a tọrọ ntọala ụlọnsọ ukwu \nd Onyenwe anyị\nd*.  
\v 38 Ọ bụ nʼime afọ iri na otu, nʼọnwa Bul,\f + \fr 6:38 \ft Ọnwa Bul, bụ ọnwa nke asatọ, nʼọnụọgụgụ afọ ndị Juu, ma bụrụ ọnwa iri nʼafọ nʼọnụọgụgụ ugbu a.\f* ya bụ ọnwa nke asatọ, ka e wusiri ụlọnsọ ukwu ahụ, nʼihe niile ya dịka ntụziaka e nyere si dị. Ọ bụ afọ asaa ka o weere ya i ji rụchaa ụlọnsọ ukwu ahụ. 
\c 7  
\s1 Solomọn ewuo ụlọeze ya 
\p  
\v 1 Solomọn ji afọ iri na atọ wuo ụlọ nke ya, bịa ruchakwaa ụlọ ya niile.  
\v 2 O wuru ụlọeze ukwu aha ya bụ Oke Ọhịa Lebanọn,\f + \fr 7:2 \ft Aha a, bụ nʼihi ogidi osisi sida eji wuo ụlọeze, nke e si Lebanọn buta, bụ ndị edoro nʼahịrị nʼahịrị dịka osisi dị nʼime ọhịa.\f* nke ogologo ya dị iri mita ise, obosara ya dị iri mita abụọ na ise. Otu a kwa, ịdị elu ya dị mita iri na ise. Osisi sida ukwu e ji rụọ elu ya ka e mere ka ha nọkwasị nʼelu ogidi e doro nʼahịrị nʼahịrị. Ahịrị ogidi ndị a dịkwa anọ.  
\v 3 Ọ bụkwa osisi sida ka e ji machie elu ụlọ ahụ. A kụkwasịrị osisi ndị a nʼelu osisi sida ukwu ndị a a wara awa, ndị e mere ka ha nọkwasị nʼogidi ndị ahụ. Ọnụọgụgụ osisi ndị ahụ bụ iri anọ na ise. Ọ bụkwa iri na ise ka e nwere nʼahịrị ọbụla.  
\v 4 Oghereikuku ya dịkwa nʼụzọ ahịrị atọ, otu nʼelu ibe ya. E mere ka oghereikuku ndị dị nʼelu nʼotu akụkụ chee oghereikuku ndị dị nʼakụkụ nke ọzọ ihu.  
\v 5 Ọnụ ụzọ niile nwere mbudo ọnụ ụzọ anọ. Ha dị atọ atọ cherịtara ibe ha ihu nʼebe mpụta ya. 
\p  
\v 6 O wuru ọnụ ụzọ mbata nke ogidi, nke ruru iri mita na anọ nʼobosara, rukwaa iri mita anọ na ise nʼịdị ogologo. Nʼihu ya, e nwere mpụta ọnụ ụlọ, nʼihu ya, e nwekwara ogidi na elu ebe kpuchiri ekpuchi. 
\p  
\v 7 E nwekwara ọnụ ụlọ ọzọ a na-akpọ, Ụlọ Ocheeze, maọbụ Ụlọ Ikpe ziri ezi ebe Solomọn na-anọ ekpe ikpe. E ji osisi sida machie ahụ ya niile, site nʼala ruo nʼelu.  
\v 8 Ụlọ obibi Solomọn dịkwa nʼogige dị nʼazụ ụlọ ikpe a. E wukwara ya dịka e si wuo ụlọ ndị ọzọ. Solomọn wukwaara nwunye ya ụlọ yiri nke ya. Nwanyị a bụ nwa Fero, eze ndị Ijipt, nke Solomọn na-alụ. 
\p  
\v 9 E ji nkume dị mma ma dịkwa oke ọnụahịa nke a wara awa na nke a kwadoro nke ọma nʼime na nʼezi dịka ọtụtụ si dị, wuo ụlọ ndị a. Site na ezi ruo nʼogige ukwu ahụ ma sitekwa na ntọala ruo nʼelu ya.  
\v 10 Nkume e ji tọọ ntọala ụlọ ndị a bụ nkume buru ibu, ndị dị ezi mma. Ụfọdụ nʼime nkume ndị a ruru mita anọ na ọkara nʼogologo, ndị ọzọ dị mita atọ na ụma isii.  
\v 11 Nʼelu nkume ndị a ka e doro nkume ndị ọzọ, ndị dị ezi mma, a waziri awazi dịka ọtụtụ si dị. Emesịa, e dokwara osisi sida nʼelu ha.  
\v 12 Ogige ukwu ahụ bụ nke eji ahịrị nkume atọ a wara awa dịkwasịrị nʼelu ibe ya gbaa gburugburu, otu ahịrị bụ nke sida a wara awa dịka ọ dị nʼime ime ogige ụlọnsọ ukwu \nd Onyenwe anyị\nd* ahụ, ya na mpụta ọnụ ụlọ ya. 
\s1 Ihe ndị e ji chọọ ụlọnsọ ukwu mma 
\p  
\v 13 Eze Solomọn zigara ozi na Taịa, ka a kpọta Huram.  
\v 14 Nne Huram bụ nwanyị si nʼebo Naftalị nke di ya nwụrụ anwụ, ma nna ya bụ onye Taịa, onye maara ǹka dị nʼịkpụ bronz. Huram jupụtara nʼamamihe na nghọta nʼihe ọmụma ịrụ ọrụ ọbụla metụtara bronz. Ọ bịakwutere eze bụ Solomọn, rụọkwa ọrụ niile enyere ya ịrụ. 
\s1 Ogidi bronz abụọ 
\p  
\v 15 Ọ kpụrụ ogidi bronz abụọ, nke ọtụtụ ya ruru mita asatọ na otu ụma nʼogologo, na mita ise na ụma anọ gburugburu ya.  
\v 16 Ọ kpụkwara ihe ọkpụkpụ bronz, nke isi ya yiri ọnụ ite mmiri. A dọkwasịrị ha nʼelu ogidi ọla abụọ ahụ. Otu nʼime ihe ọkpụkpụ bronz abụọ ndị a dị ihe ruru mita abụọ na ụma atọ nʼogologo.  
\v 17 E nwekwara ihe e ji chọọ ha mma. Ọ bụ ọla akpara akpa, nke yiri ụdọ a tụrụ atụ ka e ji chọọ ha mma. Asaa dị nʼotu ihe ọkpụkpụ ọla.  
\v 18 Ọ kpụrụ ihe yiri mkpụrụ pomegranet, nke dị nʼahịrị abụọ, nke o ji gbaa ihe ịchọ mma ndị ahụ gburugburu, maka iji ha chọọ ihe ọkpụkpụ ọla ndị ahụ dị nʼelu ogidi ndị ahụ mma. O mere otu ihe a maka ihe ọkpụkpụ ọla ọbụla.  
\v 19 Ihe ọkpụkpụ ọla ndị dị nʼelu ogidi dị na mgbe ụlọ ka o mere ka ha yie okoko osisi lili. Ịdị elu ha ruru otu mita na ụma asatọ.  
\v 20 Nʼelu ihe ọkpụkpụ ọla dị nʼogidi abụọ ahụ, nʼelu elu ha, ebe ahụ yiri ọnụ ite mmiri nke dị nʼakụkụ ihe ọkpụkpụ ọla ahụ, e nwere ihe yiri narị mkpụrụ pomegranet abụọ e doro nʼahịrị nʼahịrị gburugburu ha.  
\v 21 O guzobere ogidi abụọ ndị ahụ na mgbe ọnụ ụzọ ụlọnsọ ukwu ahụ. Ogidi nke dị na ndịda ka ọ kpọrọ Jakin, ma nke dị nʼugwu ka ọ kpọrọ Boaz.  
\v 22 Ihe ọkpụkpụ ọla dị nʼelu ogidi ndị a bụ nke yiri okoko osisi lili. Ọ bụ nʼụzọ dị otu a ka e si rụzuo ọrụ niile metụtara ogidi ndị ahụ. 
\s1 Oke osimiri eji ọla kpụọ 
\p  
\v 23 O mekwara Oke osimiri\f + \fr 7:23 \ft Ndị nchụaja na-eji mmiri dị nʼime ya na-asa ụkwụ na aka ha, tupu ha a baa nʼụlọ nzute nʼihi ịchụ aja nsure ọkụ nke na-esi isi ụtọ. \xt Ọpụ 30:17-21\f* nke ọla awụrụ awụ, nke dị gburugburu nʼụdịdị. Ọtụtụ ya bụ mita abụọ na ụma atọ nʼogologo, dịkwa mita ise na ụma atọ, site nʼotu ọnụ ruo nʼọnụ nke ọzọ. Ọ bụ eriri e ji atụ ihe ruru ihe dịka mita iri na anọ ka e ji tụọ ya gburugburu.  
\v 24 Nʼokpuru ọnụ ya, oyiyi ọba gbara ya gburugburu, iri dị na mita anọ na ọkara ọbụla. Ọba ndị a dị nʼahịrị abụọ, awụkọtara ha na Oke osimiri ahụ otu mgbe. 
\p  
\v 25 E mekwara ka Oke osimiri ahụ guzo nʼelu ehi iri na abụọ. Atọ na-eche ihu nʼakụkụ ọwụwa anyanwụ; atọ na-eche ihu nʼọdịda anyanwụ; atọ na-eche ihu nʼakụkụ ndịda, atọ na-eche ihu nʼakụkụ ugwu. Oke osimiri ahụ dịkwasịrị ha nʼelu, ebe azụ ha niile dị nʼime nʼetiti.  
\v 26 Ịdị arọ ya ha ka otu ọtụtụ ntu-aka dimkpa. E mere ọnụ ya ka ọ dị ka ọnụ iko mmiri, dịkwa ka okoko lili na-awapụta awapụta. Ọ na-erite puku galọọnụ iri na abụọ. 
\s1 Ihe ndọkwasị bronz 
\p  
\v 27 O mekwara ihe ndọkwasị bronz iri, nke e nwere ike ịkpụgharị akpụgharị. Mita abụọ ka ogologo nke otu ihe ndọkwasị ọbụla dị, mita abụọ ka obosara ya dịkwa; ịdị elu ya dị otu mita na ọkara.  
\v 28 Ihe ndọkwasị ahụ nwere ihe e ji jikọta ya dị nʼetiti ya. Otu a ka e si mee ihe ndọkwasị ahụ.  
\v 29 Nʼelu ihe njikọta ahụ ka a wụrụ oyiyi dị iche iche, dịka ọdụm, na oke ehi, na ndị mmụọ ozi cherubim nwere nku. Nʼelu, na nʼokpuru ọdụm, na oke ehi ndị ahụ, a wụkwara ahịhịa na okoko osisi dị iche iche.  
\v 30 Otu ihe ndọkwasị ọbụla nwere ụkwụ bronz anọ dị gburugburu, nweekwa okporo bronz ebe ụkwụ ndị a na-agbagharị. Nʼakụkụ anọ nke ihe ndọkwasị ndị a, a rụnyere ebe a na-adọkwasị efere. E ji oyiyi okoko osisi na ahịhịa chọọ ihe ndị a mma.  
\v 31 Nʼime ihe ndọkwasị ahụ, e nwere oghere nke nwere ọnụ dị gburugburu nke ịdị omimi ya bụ sentimita iri anọ na ise. Oghere a dị gburugburu, nwee ebe ndọkwasị nʼokpuru ya nke dị sentimita iri isii na asatọ nʼọtụtụ. Oyiyi ihe apịrị apị dịkwa gburugburu ọnụ ya. Ihe njikọta ha niile nwere akụkụ anọ nke ha nʼotu, ha adịghị gburugburu.  
\v 32 A na-adọkpụgharị ihe ndọkwasị a nʼụkwụ anọ o nwere. A dụnyekọtakwara ụkwụ anọ ndị a nʼime okporo ọla e mekọtara ya na ihe ndọkwasị ahụ. Ịdị elu nke ụkwụ ọbụla bụ iri sentimita isii na asatọ.  
\v 33 E mekwara ụkwụ ndị a dịka ụkwụ ụgbọala nke ịnyịnya na-adọkpụ. Ọ bụkwa ọla ka e ji kpụọ akụkụ ihe ndọkwasị ahụ niile, ma okporo igwe ukwu, ma okporo igwe nta, na ihe niile jikọtara ha. 
\p  
\v 34 Ụkwụ ọla nta anọ dịkwa nʼokpuru ihe ndọkwasị ahụ, nʼakụkụ ọbụla. A wụkọtakwara ha na ihe ndọkwasị ahụ.  
\v 35 E nwere ihe a magidere gburugburu nʼelu ihe ndọkwasị ọbụla, nke omimi ya dị iri sentimita abụọ na ụma atọ. Ọla a, na ụkwụ ya, ka a wụkọtara na ihe ndọkwasị ahụ otu mgbe.  
\v 36 Ebe ọbụla ohere dị, o gbunyere oyiyi cherubim nwere nku, na oyiyi ọdụm, na oyiyi osisi nkwụ, nʼahụ ibo ọla ahụ e mere ka ọ dịrị gburugburu elu ihe ndọkwasị ọla ahụ.  
\v 37 Ihe ndọkwasị ọla iri ndị ahụ ha otu. Ha yikwara ibe ha, nʼihi na e mere ka ha nwee otu ụdị. 
\p  
\v 38 Huram jikwa bronz kpụọ efere ịsa ihe iri. Ogbu efere ọbụla dị mita abụọ na otu ụma, otu efere maka ihe ndọkwasị ọbụla. Mmiri na-eju otu nʼime ha bụ narị galọọnụ mmiri abụọ na iri anọ.\f + \fr 7:38 \ft Maọbụ, \fqa ihe ruru narị lita asatọ na iri asatọ\f* 
\v 39 Ọ dọnyere ihe ndọkwasị ọla ise nʼakụkụ ndịda ụlọnsọ ukwu ahụ, dọnyekwa ihe ndọkwasị ọla ise nke ọzọ nʼakụkụ ugwu. Ọ dọbara ihe ichenye mmiri ukwu ahụ nʼakụkụ ndịda, nʼihu ọwụwa anyanwụ nke ụlọnsọ ahụ, nʼebe chere ihu na ndịda.  
\v 40 Ọ kpụkwara ite dị iche iche, shọvel niile, na efere ịkwọsa mmiri niile. 
\p Nʼikpeazụ, ọ rụchara ọrụ niile dị nʼụlọnsọ \nd Onyenwe anyị\nd*, nke eze Solomọn tinyere ya nʼaka ịrụ. 
\b  
\li1  
\v 41 Ogidi abụọ ahụ; 
\li1 ihe ọkpụkpụ abụọ dịka efere dị nʼelu ogidi abụọ ahụ; 
\li1 ihe ọkpụkpụ yiri ụdọ a tụrụ atụ nke e ji chọọ ihe ọkpụkpụ abụọ ahụ dịka efere mma. 
\li1  
\v 42 Narị anọ nke mkpụrụ pomegranet a kpụrụ akpụ maka ahịrị ihe abụọ ahụ a kpụrụ akpụ, ya bụ, ahịrị pomegranet abụọ nʼihi otu ihe ọkpụkpụ, iji chọọ ihe ọkpụkpụ ahụ yiri efere dị nʼisi elu ogidi ahụ mma. 
\li1  
\v 43 Ihe ndọkwasị iri na efere ịsa mmiri iri nke dọkwasịrị nʼelu ha; 
\li1  
\v 44 na Oke osimiri ahụ na oke ehi iri na abụọ ahụ dị ya nʼokpuru; 
\li1  
\v 45 ite niile, shọvel niile na efere ịkwọsa mmiri. 
\b  
\p Ihe ndị a niile nke Huram meere eze Solomọn nʼihi ụlọnsọ \nd Onyenwe anyị\nd*, bụ bronz na-egbu maramara ka eji mee ha.  
\v 46 Ọ bụ nʼala ụrọ, nʼobosara ala Jọdan, nʼetiti Sukọt na Zaretan ka eze mere ka a nọrọ kpụọ ihe ndị a.  
\v 47 Ma Solomọn atụghị ihe ndị a niile a kpụrụ nʼihe ọtụtụ, nʼihi na ha dị ọtụtụ nʼọnụọgụgụ, achọpụtaghịkwa ịdị arọ nke bronz ahụ. 
\p  
\v 48 Solomọn mekwara ngwongwo niile dị nʼime ụlọnsọ \nd Onyenwe anyị\nd*, ya bụ: 
\b  
\li1 ebe ịchụ aja e ji ọlaedo kpụọ, 
\li1 tebul ọlaedo nke a dọkwasịrị achịcha nke iche nʼIhu Onyenwe anyị. 
\li1  
\v 49 E jikwa ọlaedo a nụchara anụcha kpụọ ihe ịdọkwasị oriọna, ise nʼakụkụ aka nri, ise nʼakụkụ aka ekpe,\f + \fr 7:49 \ft Nʼụlọ nzute, ọ bụ naanị otu ihe ịdọba oriọna nwere iheọkụ asaa ka e nwere. Ma Solomọn kpụrụ nke nwere iheọkụ iri were dochie nke ochie ahụ. \xt Ọpụ 25:31-40; 26:35\f* nʼihu ime ime ebe nsọ; 
\li1 tinyere ihe ịchọ mma oyiyi okoko osisi, na oriọna niile, na ihe ịgụta ihe niile; 
\li1  
\v 50 na efere ọlaedo a nụchara anụcha dị iche iche, na ihe ịkpakepụ ọkụ niile, na efere ịkwọsa mmiri, na ngaji na ihe ịgụ ọkụ; 
\li1 na ihe ikonye ibo nʼihi ibo ọnụụlọ ndị dị nʼime ime, bụ Ebe Kachasị Nsọ, nakwa ibo ndị dị nʼọnụ ụzọ ụlọ ezumezu nke ụlọnsọ ukwu. 
\b  
\p  
\v 51 Mgbe a rụzuru ọrụ niile nke eze Solomọn nwere ịrụ maka ụlọnsọ ukwu \nd Onyenwe anyị\nd* ahụ, o webatara ihe niile Devid bụ nna ya doro nsọ nʼime ya, ya bụ ọlaọcha, ọlaedo na ngwongwo ndị ọzọ niile. O tinyere ha nʼụlọakụ dị nʼụlọnsọ \nd Onyenwe anyị\nd*. 
\c 8  
\s1 Mbubata igbe ọgbụgba ndụ nʼime Ụlọnsọ Ukwu 
\p  
\v 1 Mgbe ahụ, eze Solomọn kpọkọtara ndị okenye Izrel, na ndịisi ebo niile, na ndịisi ezinaụlọ Izrel niile, ka ha bịakwute eze na Jerusalem, maka i site na Zayọn bụ obodo Devid bugota igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*.  
\v 2 Ndị Izrel niile gbakọtara bịakwute eze Solomọn nʼoge a na-eme mmemme nʼọnwa Etanim\f + \fr 8:2 \fq Ọnwa Etanim, \ft bụ ihe dị ka ọnwa itoolu, ma ọ bụkwanụ \fqa ọnwa iri ndị Juu.\f* nke bụ ọnwa asaa nʼafọ. 
\p  
\v 3 Mgbe ndị okenye Izrel niile bịarutere, ndị nchụaja buliri igbe ọgbụgba ndụ ahụ.  
\v 4 Ha bugotara igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*, ya na ụlọ nzute, na ngwongwo niile dị nsọ dị nʼime ya. Ndị nchụaja na ndị Livayị buliri ha elu.  
\v 5 Eze Solomọn na ọgbakọ Izrel niile, bụ ndị zukọtara nʼebe ọ nọ, nọ nʼihu igbe ọgbụgba ndụ ahụ, na-achụ aja ọtụtụ atụrụ na ọtụtụ ehi nke a na-apụghị ịgụta ọnụ maọbụ gbakọta ọnụọgụgụ ha nʼihi ịba ụba. 
\p  
\v 6 Ndị nchụaja bubatara igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* ahụ nʼime ime ụlọnsọ ukwu ahụ, nʼime Ebe Kachasị Nsọ, dọba ya nʼokpuru nku cherubim ahụ.  
\v 7 Cherubim ndị ahụ gbasara nku ha nʼelu igbe ọgbụgba ndụ ahụ, zochie igbe ọgbụgba ndụ ahụ na okporo osisi ndị e ji ebu ya.  
\v 8 Okporo osisi ndị a dị oke ogologo, na e nwere ike ị site nʼEbe Nsọ, dị nʼihu ime ime ebe nsọ ahụ hụ isi ha anya, ma onye na-anọghị nʼEbe Nsọ ahụ adịghị ahụ ha. Ha ka dịkwa nʼebe ahụ ruo taa.  
\v 9 O nweghị ihe dị nʼime igbe ọgbụgba ndụ ahụ, karịakwa mbadamba nkume abụọ ahụ Mosis tinyere nʼime ya nʼugwu Horeb, nʼebe \nd Onyenwe anyị\nd* na ụmụ Izrel gbara ndụ, mgbe ha si nʼala Ijipt pụta. 
\p  
\v 10 Mgbe ndị nchụaja si nʼEbe Nsọ ahụ pụta, igwe ojii jupụtara ụlọnsọ ukwu \nd Onyenwe anyị\nd* ahụ.  
\v 11 Ndị nchụaja enwekwaghị ike jee ozi ha, nʼihi igwe ojii ahụ, nʼihi na ebube \nd Onyenwe anyị\nd* jupụtara nʼime ụlọnsọ ya. 
\p  
\v 12 Mgbe ahụ, Solomọn sịrị, “\nd Onyenwe anyị\nd* ekwuola na ọ ga-ebi nʼoke igwe ojii.  
\v 13 Ma nʼezie, ewuola m ụlọnsọ pụrụ iche, maa mma nye gị, ebe ị ga-ebi ruo mgbe ebighị ebi.” 
\p  
\v 14 Dịka ọgbakọ Izrel niile na-eguzo nʼebe ahụ, eze chigharịrị onwe ya chee ha ihu, gọzie ha.  
\v 15 Mgbe ahụ, ọ sịrị, 
\pm “Otuto dịrị \nd Onyenwe anyị\nd*, bụ Chineke Izrel, onye ji aka ya mezuo nkwa nke o sitere nʼọnụ ya kwee nna m Devid. Nʼihi na o kwuru sị,  
\v 16 ‘Site nʼụbọchị ahụ m si nʼala Ijipt kpọpụta ndị m, ahọpụtaghị m obodo ọbụla nʼebo ọbụla nke Izrel, ka e wuru m ụlọnsọ ka Aha m dịrị nʼebe ahụ. Ma a họrọla m Devid ị bụ onye ga-achị ndị m Izrel.’ 
\pm  
\v 17 “Nna m, Devid bu nʼobi iwu ụlọnsọ ukwu nye Aha \nd Onyenwe anyị\nd*, bụ Chineke nke Izrel.  
\v 18 Ma \nd Onyenwe anyị\nd* sịrị nna m, Devid, ‘I mere nke ọma ibu nʼobi iwu ụlọnsọ ukwu nye Aha m.  
\v 19 Ma otu ọ dị, ọ bụghị gị ga-ewu ụlọnsọ ukwu ahụ, kama ọ bụ nwa gị nwoke, anụ ahụ gị na ọbara gị; ọ bụ ya ga-ewu ụlọnsọ ukwu nye Aha m.’ 
\pm  
\v 20 “Ugbu a, \nd Onyenwe anyị\nd* emezuola nkwa ahụ o kwere. A nọchiela m nna m Devid, ugbu a, ana m anọdụ nʼocheeze nke Izrel dịka \nd Onyenwe anyị\nd* kwere na nkwa. Ewuokwala m ụlọnsọ ukwu nye Aha \nd Onyenwe anyị\nd*, bụ Chineke nke Izrel.  
\v 21 Edoziekwala m ọnọdụ ebe igbe ọgbụgba ndụ ahụ ga-adị, nʼime ya ka ọgbụgba ndụ \nd Onyenwe anyị\nd* dị, bụ nke ya na nna nna anyị ha gbara, mgbe o mere ka ha si nʼala Ijipt pụta.” 
\s1 Ekpere Solomọn 
\p  
\v 22 Mgbe ahụ, Solomọn guzoro nʼihu ebe ịchụ aja \nd Onyenwe anyị\nd*, na nʼihu ọgbakọ ụmụ Izrel niile, gbasapụ aka ya abụọ chilie ha elu,  
\v 23 kwuo sị, 
\pm “\nd Onyenwe anyị\nd*, Chineke nke Izrel, ọ dịghị Chineke dịka gị nʼeluigwe nke dị nʼelu, maọbụ nʼụwa, nʼokpuru eluigwe. Gị onye na-edebe ọgbụgba ndụ ịhụnanya gị na ndị ohu gị, bụ ndị ji obi ha niile na-eso ụzọ gị.  
\v 24 I mezuokwala nkwa niile i kwere nna m Devid, bụ ohu gị. I ji ọnụ gị kwee nkwa a ma taa, i jirila aka gị mezuo ya. 
\pm  
\v 25 “Ugbu a, O! \nd Onyenwe anyị\nd*, Chineke nke Izrel, mezukwaa nkwa niile i kwere Devid nna m, mgbe ị sịrị, ‘Ọ bụrụ na ụmụ ụmụ gị elezie anya bie ndụ nʼụzọ kwesiri ntụkwasị obi nʼihu m, nʼihe niile ha na-eme, dịka gị onwe gị mere, agaghị achọ onye ga-anọ nʼihu m nʼocheeze Izrel nʼime ha.’  
\v 26 Ma ugbu a, Chineke nke Izrel, ka okwu gị, bụ nkwa nke i kwere ohu gị, bụ nna m Devid, bịa na mmezu. 
\pm  
\v 27 “Ma ọ bụ ezie na gị Chineke ga-ebi nʼelu ụwa? Lee, eluigwe ọbụladị ebe kachasị elu nke eluigwe, ezughị ịba gị. Olee otu ụlọ a nke m wuru ga-esi bata gị?  
\v 28 Ma \nd Onyenwe anyị\nd* Chineke m, ṅaa ntị nʼekpere ohu gị, na arịrịọ ọ na-arịọ maka ebere. Nụrụ akwa na ekpere nke ohu gị na-ekpe nʼihu gị taa.  
\v 29 Biko, mee ka anya gị abụọ ghere oghe nʼebe ụlọnsọ ukwu a dị, abalị na ehihie, bụ ebe a i kwuru banyere ya, sị, ‘Aha m ga-adị nʼebe ahụ,’ ka i si otu a nụrụ ekpere nke ohu gị ga-ekpe banyere ebe a.  
\v 30 Nụrụkwa arịrịọ ohu gị na nke ndị gị Izrel niile, mgbe ọbụla ha chere ihu ha nʼebe a nʼekpere. Biko, site nʼeluigwe bụ ebe obibi gị nụrụ, mgbe ị nụrụ biko, gbagharakwa. 
\pm  
\v 31 “Mgbe onye ọbụla mehiere mmadụ ibe ya, a kpọọ ya oku ka ọ bịa ṅụọ iyi, onye dị otu a bịa, guzo nʼebe a, nʼihu ebe ịchụ aja gị a, ṅụọ iyi ahụ.  
\v 32 Mgbe ahụ, nụrụ olu ya nʼeluigwe ma mee ihe ziri ezi. Kpeekwa ikpe nʼetiti ndị ohu gị, maa onye mejọrọ ikpe site nʼịtụkwasị nʼisi ha ihe o metara, meekwa ka onye aka ya dị ọcha nwere onwe ya, site nʼimeso ha dịka ezi omume ha si dị. 
\pm  
\v 33 “Mgbe ndị iro meriri ndị gị Izrel, nʼihi na ha mehiere megide gị, ọ bụrụ na ha alọghachikwute gị, too aha gị, na-ekpe ekpere, na-arịọ gị arịrịọ nʼụlọnsọ ukwu a,  
\v 34 biko, site nʼeluigwe nụrụ ekpere ha, gbaghara mmehie ndị gị Izrel. Meekwa ka ha lọghachita nʼala ahụ nke i nyere nna nna ha. 
\pm  
\v 35 “Mgbe e gbochiri eluigwe, mee na mmiri adịghị ezokwa, nʼihi na ndị gị emehiela megide gị, ọ bụrụ na ha echee ihu nʼebe a kpee ekpere, too aha gị, si na mmehie ha chegharịa, nʼihi na ịtaala ha ahụhụ.  
\v 36 Biko, site nʼeluigwe nụrụ ma gbagharakwa mmehie ndị ohu gị, bụ ndị gị Izrel. Kuziere ha ezi ụzọ ha ga-esi bie ndụ ma zidata mmiri ozuzo nʼala ahụ nke i nyere ndị gị ka ọ bụrụ ihe nketa ha. 
\pm  
\v 37 “Mgbe ụnwụ maọbụ ajọ ọrịa na-efe efe ga-adakwasị ala a, maọbụ ọrịa na-eripịa ihe ubi maọbụ ọmụma ebu, maọbụ igurube maọbụ ụkpana, maọbụ mgbe onye iro nọchibidoro ha nʼobodo ha niile, ihe mbibi niile maọbụ ọrịa ọbụla,  
\v 38 ekpere ọbụla maọbụ arịrịọ nke onye ọbụla nʼetiti ndị gị Izrel kpere ma rịọọ, nʼihi ịghọta ihe otiti niile nke obi ha, ha gbasapụ aka ha, ma chee ihu ha nʼebe ụlọnsọ ukwu dị,  
\v 39 mgbe ahụ, site nʼeluigwe bụ ebe obibi gị nụrụ arịrịọ ha. Gbaghara ma meekwa; mesoo onye ọbụla dịka ihe niile ha na-eme si dị, ebe ọ bụ na ị maara obi ha niile, nʼihi na naanị gị maara obi mmadụ ọbụla,  
\v 40 ka ha tụọ egwu gị oge niile nke ha na-ebi nʼala ahụ nke i nyere nna nna anyị ha. 
\pm  
\v 41 “Ma banyere onye mba ọzọ, onye na-esonyeghị na ndị gị Izrel, kama o si nʼala ebe dị anya bịa nʼihi Aha gị,  
\v 42 nʼihi na ha ga-anụ ihe banyere aha ukwu gị, nʼaka gị dị ike na ogwe aka gị e setipụrụ esetipụ. Mgbe ha bịara kpee ekpere nʼụlọnsọ a,  
\v 43 mgbe ahụ, site nʼeluigwe ebe obibi gị nụrụ arịrịọ ha. Mekwaa ihe niile nke onye mba ọzọ ahụ na-arịọ nʼekpere, ka ndị niile nke ụwa mara aha gị, tụọkwa egwu gị, dịka ndị nke gị bụ Izrel na-eme, ka ha matakwa na-akpọkwasịrị Aha gị nʼụlọ a nke m wuru. 
\pm  
\v 44 “Mgbe ndị gị ga-aga ibu agha megide ndị iro ha, nʼebe ọbụla ị na-eziga ha, mgbe ha chere ihu ha nʼụzọ obodo a nke ị họpụtara na nʼụlọnsọ ukwu a m wuru nye Aha gị, kpee ekpere nye \nd Onyenwe anyị\nd*,  
\v 45 mgbe ahụ, site nʼeluigwe nụrụ ekpere na arịrịọ amara ha, mezukwa ihe ha na-arịọ (dịnyekwara ha). 
\pm  
\v 46 “Mgbe ha mehiere megide gị, nʼihi na ọ dịghị mmadụ ọbụla na-adịghị emehie, ị wee iwe megide ha, rara ha nyefee nʼaka ndị iro ha, ndị dọkpụrụ ha nʼagha gaa nʼobodo ọzọ, maọbụ obodo dị anya maọbụ nke dị nso;  
\v 47 ọ bụrụ na ha anọrọ nʼala ahụ a dọkpụrụ ha gaa, chegharịa nʼobi ha, nọrọ nʼala ebe ahụ eji ha rịọọ gị, sị, ‘Anyị emehiela, anyị emeela ihe nʼadịghị mma, anyị emekwala ajọ omume’;  
\v 48 ọ bụrụ na ha ejiri obi ha na mmụọ ha niile chegharịa, nʼala ebe ndị iro ha, bụ ndị dọọrọ ha nʼagha, ma kpee ekpere nye gị chee ihu ha nʼụzọ ala a nke i nyere nna nna ha, nʼobodo a nke ị họpụtara, ya na nʼụlọnsọ ukwu a m wuru nye Aha gị;  
\v 49 mgbe ahụ, site nʼeluigwe, ebe obibi gị, nụrụ ekpere ha na arịrịọ ha, nyekwara ha aka.  
\v 50 Gbaghara ndị gị, bụ ndị mehiere megide gị, gbaghara njehie niile ha mere megide gị, ma meekwa ka ndị dọtara ha nʼagha gosi ha obi ebere.  
\v 51 Nʼihi na ha bụ ndị gị na oke gị, ndị i mere ka ha si nʼala Ijipt pụta, ala oke ịta ahụhụ nke nhụju anya. 
\pm  
\v 52 “Ka anya gị ghere oghe nʼarịrịọ mụ bụ ohu gị, nakwa nʼarịrịọ ndị gị Izrel, biko, na-egekwa ha ntị mgbe ọbụla ha bekuru gị akwa.  
\v 53 Nʼihi na gị onwe gị kewapụtara ha site na mba niile nke ụwa ka ha bụụrụ gị ihe nketa, dịka ị kwupụtara site nʼọnụ ohu gị bụ Mosis, mgbe gị bụ Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* mere ka nna nna anyị ha si nʼala Ijipt pụta.” 
\p  
\v 54 Mgbe Solomọn kpechara ekpere ndị a ya na arịrịọ ọ rịọrọ \nd Onyenwe anyị\nd* o si nʼihu ebe ịchụ aja \nd Onyenwe anyị\nd*, bụ ebe o gburu ikpere nʼala, bilie, gbasapụ aka ya abụọ chilie ha elu.  
\v 55 O guzoro gọzie ọgbakọ Izrel niile, gwa ha okwu nʼoke olu sị ha, 
\pm  
\v 56 “Onye a gọziri agọzi ka \nd Onyenwe anyị\nd* bụ, onye nyere ndị ya, Izrel izuike dịka o kwere na nkwa. Ọ dịkwaghị okwu ọbụla nke na-emezughị nʼime ezi nkwa ahụ niile o kwere site nʼọnụ Mosis ohu ya.  
\v 57 Ka \nd Onyenwe anyị\nd* Chineke anyị dịnyere anyị, dịka o si dịnyere nna nna anyị ha. Ka ọ gharakwa ịhapụ anyị, maọbụ gbakụta anyị azụ.  
\v 58 Ya nyekwa anyị mmụọ ime ihe niile ọ chọrọ, dịka uche nsọ ya si dị, na mmụọ ijezi ije nʼụzọ ya niile, na idebe ụkpụrụ na iwu niile nke o nyere nna nna anyị ha.  
\v 59 Ka okwu m ndị a niile, nke m ji rịọ amara nʼihu \nd Onyenwe anyị\nd* dịkwa \nd Onyenwe anyị\nd* Chineke anyị nso ehihie na abalị. Ka o nyekwara ohu ya na ndị Izrel niile aka, dịka mkpa ụbọchị ọbụla si dị.  
\v 60 Ka ndị niile bi nʼụwa mara na \nd Onyenwe anyị\nd* bụ Chineke, marakwa na o nweghị chi ọzọ dị karịa ya.  
\v 61 Ya mere, werenụ obi unu nyechasịa \nd Onyenwe anyị\nd* bụ Chineke anyị, kpamkpam, na-ebinụ ndụ nʼụkpụrụ ya, rubenụ isi nʼiwu ya, dịka ọ dị taa.” 
\s1 Ido Ụlọnsọ Ukwu ahụ Nsọ 
\p  
\v 62 Mgbe ahụ, eze ya na ndị Izrel niile chụrụ aja dị iche iche nʼihu \nd Onyenwe anyị\nd*.  
\v 63 Solomọn chụrụ aja udo, bụ nke ọ chụrụ nye \nd Onyenwe anyị\nd*. Ehi dị puku iri abụọ na abụọ, na ewu na atụrụ dị narị puku na iri puku abụọ. Ya mere, eze na ndị Izrel niile si otu a doo ụlọnsọ \nd Onyenwe anyị\nd* nsọ. 
\p  
\v 64 Nʼotu ụbọchị ahụ kwa, eze doro etiti ogige dị nʼihu ụlọnsọ \nd Onyenwe anyị\nd* ahụ nsọ. Nʼebe ahụ ka ọ nọ chụọ aja nsure ọkụ, aja onyinye mkpụrụ ọka na aja abụba udo. O mere nke a nʼihi na ebe ịchụ aja bronz nke na-eguzo nʼihu Chineke dị oke nta ịbata aja nsure ọkụ niile, aja mkpụrụ ọka niile nakwa aja abụba udo niile ahụ. 
\p  
\v 65 Ya mere, Solomọn ya na ndị Izrel niile mere mmemme a nʼoge ahụ, ọ bụ nzukọ dị ukwuu. Ndị mmadụ bịara sitere na Lebo Hamat ruo na mmiri iyi Ijipt. Ha mere mmemme a nʼihu \nd Onyenwe anyị\nd* Chineke anyị, ụbọchị asaa tinyere ụbọchị asaa ọzọkwa, ya bụ agụkọta ha ụbọchị iri na anọ.  
\v 66 Nʼụbọchị nke na-eso ya, o zilagara ndị ahụ niile. Ha gọziri eze, laakwa nʼụlọ ha, nʼịṅụrị ọṅụ na obi ụtọ nʼihi ihe ọma niile nke \nd Onyenwe anyị\nd* meere ohu ya Devid, na ndị ya Izrel. 
\c 9  
\s1 \nd Onyenwe anyị\nd* emee ka Solomọn hụ ya anya 
\p  
\v 1 Mgbe Solomọn rụchara ụlọnsọ ukwu \nd Onyenwe anyị\nd*, na ụlọeze, rụzukwaa ihe niile bụ nke o bu nʼobi ime,  
\v 2 \nd Onyenwe anyị\nd* mere ka ọ hụ ya anya nke ugboro abụọ dịka o mere ka ọ hụ ya anya na Gibiọn.\f + \fr 9:2 \ft \xt 1Ez 3:5; 11:9; 2Ih 1:7\f* 
\v 3 \nd Onyenwe anyị\nd* sịrị ya, 
\pm “Anụla m ekpere gị, na arịrịọ gị, nke ị rịọrọ nʼihu m. Edoola m ụlọnsọ a nke i wuru nsọ, site nʼitinye Aha m nʼebe ahụ ruo mgbe ebighị ebi. Anya m na obi m abụọ ga-adịkwa nʼebe ahụ ụbọchị niile. 
\pm  
\v 4 “Ma gị onwe gị, ọ bụrụ na ị jiri obi zuruoke na omume ziri ezi, bie ndụ nʼikwesị ntụkwasị obi nʼihu m dịka Devid nna gị mere, na-eme ihe niile m nyere nʼiwu, debe ụkpụrụ m na iwu m niile,  
\v 5 mgbe ahụ, aga m eme ka ocheeze ọchịchị gị nʼIzrel guzosie ike ruo mgbe ebighị ebi, dịka m kwere nna gị Devid nkwa, mgbe m sịrị, ‘Ị ghaghị inwe onye nnọchite anya nʼocheeze Izrel.’ 
\pm  
\v 6 “Ma ọ bụrụ na unu, maọbụ ụmụ ụmụ unu alaghachi azụ, site nʼebe m nọ, jụ idebe iwu na ụkpụrụ niile bụ nke m nyere unu, pụọ gbasoro chi ndị ọzọ ife ha ofufe na ịkpọ isiala nye ha,  
\v 7 mgbe ahụ, aga m esite nʼala ahụ nke m nyere ha wezuga Izrel. Aga m ajụkwa ụlọnsọ a m doro nsọ nye Aha m. Izrel ga-aghọ ihe eji atụ ilu na ihe ịkpa ọchị nʼetiti ndị niile.  
\v 8 Ọ bụ ezie na ụlọnsọ ukwu a kachasị elu ugbu a, ma ọnọdụ ya ga-eju ndị niile ga-esi nʼakụkụ ya gafee anya. Ha ga-emi ọnụ, sị, ‘Gịnị mere \nd Onyenwe anyị\nd* ji mee ala a na ụlọnsọ a, ihe dị otu a?’  
\v 9 Ndị mmadụ ga-aza, ‘Nʼihi na ha gbakụtara \nd Onyenwe anyị\nd* Chineke ha azụ, onye kpọpụtara ha site nʼala Ijipt azụ, makụọ chi ndị ọzọ, na-akpọ isiala na-efekwa ha ofufe. Ọ bụ nʼihi nke a ka O ji mee ka ihe ọjọọ niile ndị a bịakwasị ha.’ ” 
\s1 Ọrụ ndị ọzọ Solomọn rụrụ 
\p  
\v 10 Nʼọgwụgwụ iri afọ abụọ, mgbe Solomọn ji wuo ụlọ abụọ ndị a, ya bụ ụlọnsọ \nd Onyenwe anyị\nd* na ụlọeze.  
\v 11 Eze Solomọn nyere Hiram, eze Taịa, iri obodo abụọ dị na Galili, nʼihi osisi sida, na osisi junipa, na ọlaedo niile Hiram butere ya dịka o si chọọ ya.  
\v 12 Ma mgbe Hiram si Taịa gaa ịhụ obodo ndị a nke Solomọn nyere ya, ha amasịghị obi ya.  
\v 13 Ya mere, ọ jụrụ sị, “Nwanne m nwoke, ụdị obodo dị aṅaa bụ ihe a i nyere m?” Nʼihi ya, ọ kpọrọ ha Kabul,\f + \fr 9:13 \ft Ala na-adịghị ihe ọ dị mma iji ya mee.\f* aha ọ na-aza ruo taa.  
\v 14 Hiram zigaara eze ọlaedo dị puku kilogram anọ na iri asatọ. 
\p  
\v 15 Nke a bụ akụkọ banyere ndị ọrụ mmanye niile eze bụ Solomọn chịkọtara maka ịrụ ụlọnsọ ukwu \nd Onyenwe anyị\nd*, na ụlọeze nke ya, na ebe e wusiri ike nke Milo, na mgbidi Jerusalem, Hazọ, Megido nakwa Gaza.  
\v 16 Fero eze Ijipt buru agha na mbụ merie Gaza, kpọọ ya ọkụ, gbukwaa ọtụtụ ndị Kenan bi nʼobodo ahụ, were ya nye nwa ya nwanyị, bụ nwunye Solomọn, ka ọ bụrụ ihe o ji duo ya ụlọ.  
\v 17 Solomọn wugharịrị obodo Gaza, wuokwa ndịda Bet-Horon,  
\v 18 Baalat na Tadmọ\f + \fr 9:18 \ft Maọbụ, \fqa Tama nʼasụsụ ndị Hibru\f* nke dị nʼọzara nʼime ala ya.  
\v 19 O wukwara ọtụtụ obodo ebe nchịkọba ihe, obodo ebe idebe ụgbọ agha na ịnyịnya ya niile. O wuru ihe ọbụla gụrụ obi ya agụụ iwu na Jerusalem, Lebanọn na nʼoke ala ahụ niile ọ na-achị. 
\p  
\v 20 Ndị niile fọdụrụ ndụ nʼetiti ndị Amọrait, ndị Het, ndị Periz, ndị Hiv na Jebus (ndị ahụ abụghị ndị Izrel),  
\v 21 ndị ụmụ ụmụ ha niile fọdụrụ nʼala ahụ, ndị ahụ ndị Izrel na-enweghị ike egbuchapụ, ndị a ka Solomọn mere ndị ọrụ mmanye na ndị ohu, nke a bụkwa ọnọdụ ha ruo taa.  
\v 22 Ma Solomọn emeghị ka onye Izrel ọbụla bụrụ ohu. Kama ha bụ ndị ikom agha, ndịisi ọrụ nʼọchịchị, ndịisi ndị ọchịagha, ndịisi ụgbọ agha na ndị na-agba ịnyịnya agha ya.  
\v 23 Ndị a bụkwa ndịisi na-ahụ ihe banyere ọrụ niile nke Solomọn ji nʼaka. Ndị Izrel dị narị ise na iri ise (550), ka e mere ndịisi na-elekọta ndị ọrụ Solomọn. 
\p  
\v 24 Emesịa, ada Fero sitere nʼobodo Devid pụta gbagoo nʼụlọeze nke Solomọn wuuru ya. Solomọn wukwara ebe mpụta nke ụlọ ahụ. 
\p  
\v 25 Ugboro atọ nʼafọ,\f + \fr 9:25 \ft Ọ bụ nʼusoro ụzọ mmemme atọ dị mkpa nke ndị Izrel na-eme kwa afọ. Ndị a bụ mmemme achịcha ekoghị eko, mmemme owuwe ihe ubi, na mmemme ibi ụlọ ikwu. \xt Ọpụ 23:14-17; Dit 16:16; 2Ih 8:13\f* ka Solomọn na-achụ aja nsure ọkụ, na aja udo nʼelu ebe ịchụ aja o wuru nye \nd Onyenwe anyị\nd*, tinyere aja nsure ọkụ ihe na-esi isi ụtọ ọ na-achụ nʼihu \nd Onyenwe anyị\nd*. O si otu a wuchaa ụlọnsọ ukwu \nd Onyenwe anyị\nd*. 
\p  
\v 26 Eze Solomọn wukwara ọtụtụ ụgbọ mmiri nʼEziọn Geba,\f + \fr 9:26 \ft Obodo Eziọn Geba dị nʼakụkụ Elat nʼala Edọm, baara Solomọn uru nʼebe ọ dị ukwu nʼihi osimiri Uhie na oke osimiri India dị ya nso. \xt Ọnụ 33:35; Dit 2:8; 1Ez 22:48\f* bụ nke dị nʼakụkụ Elat, nʼọnụ mmiri Oke osimiri Uhie nʼala Edọm.  
\v 27 Hiram zigaara ndị ikom ya na-anya ụgbọ, ndị maara ihe banyere ime njem osimiri nke ọma, ka ha soro ndị ikom Solomọn jee ozi nʼime ụgbọ ndị a.  
\v 28 Ha nyaara ụgbọ gaa Ọfịa,\f + \fr 9:28 \ft Ọtụtụ mmadụ na-ama atụ ebe a ga-enwe ike chọta obodo Ọfịa taa. Ụfọdụ na-asị, na ọ bụ nʼọnụ mmiri Arebịa ka ọ dị, ndị ọzọ na-asị, ọ bụ na mpaghara akụkụ ọnụ mmiri Sọmalia. Ebe ndị ọzọ na-asị, na ọ dị nʼala India maọbụ nʼala Zimbabwe.\f* site nʼebe ahụ bulatara eze Solomọn ọlaedo nke ịdị arọ ya ruru puku kilogram iri na anọ na narị abụọ na asatọ. 
\c 10  
\s1 Eze nwanyị Sheba bịara ileta Solomọn 
\p  
\v 1 Mgbe eze nwanyị Sheba nụrụ akụkọ Solomọn, na ịdị na mma nke dị nʼetiti ya na \nd Onyenwe anyị\nd*, ọ bịara ka o were ọtụtụ ajụjụ siri ike nwalee Solomọn.\f + \fr 10:1 \ft Maka ịnwapụta amamihe o nwere\f* 
\v 2 Ọ bịarutere Jerusalem, ya na ọtụtụ ndị ozi nʼebe ha bara ụba, ndị so ya, tinyere ọtụtụ ịnyịnya kamel ndị bu ụda dị iche iche, ọtụtụ ọlaedo na nkume dị oke ọnụahịa dị iche iche. Ọ bịakwutere Solomọn, ya na ya kparịtara ụka banyere ihe niile nke dị ya nʼobi.  
\v 3 Solomọn zara ya ajụjụ ya niile; ọ dịkwaghị ihe siiri eze ike ịkọwara ya.  
\v 4 Mgbe eze nwanyị Sheba hụrụ amamihe niile nke Solomọn, hụkwa ụlọeze o wuru,  
\v 5 na ihe oriri a na-adọkwasị nʼelu tebul ya, usoro ọnọdụ nke ndịisi ọchịchị ya, na ndị guzo na-ejere ya ozi nʼuwe ha yi, onye na-ebu iko ihe ọṅụṅụ ya, na aja nsure ọkụ niile ọ na-achụ nʼụlọnsọ \nd Onyenwe anyị\nd*, ọ dịkwaghị ihe ọzọ ọ maara ọ ga-eme, maọbụ kwuo. 
\p  
\v 6 Ọ sịrị eze, “Akụkọ niile m nọ nʼala m nụ banyere ihe niile ị rụpụtara na amamihe gị bụ eziokwu.  
\v 7 Ma ekwenyeghị m akụkọ ndị a tutu ruo mgbe m bịara jiri anya m abụọ hụ ha. Nʼezie, ihe m nụrụ erughị ọkara; nʼamamihe nakwa nʼịba ụba gị, ị tụkwasịla ihe nʼakụkọ m nụrụ.  
\v 8 Lee, ụdị ọṅụ ndị gị na-enwe. Lee, ụdị ọṅụ nke ndị ozi na-enwe, bụ ndị na-eguzo nʼihu gị mgbe niile na-anụ okwu amamihe gị.  
\v 9 Ngọzị dịrị \nd Onyenwe anyị\nd* Chineke gị, onye nwere mmasị nʼebe ị nọ, o debere gị nʼocheeze Izrel. Nʼihi ịhụnanya nke \nd Onyenwe anyị\nd* na-adị ruo mgbe ebighị ebi nʼebe Izrel nọ, o meele gị eze, ka ị debe ikpe ziri ezi na ezi omume.” 
\p  
\v 10 O nyere Solomọn onyinye ọlaedo ịdị arọ ya dị puku kilogram anọ,\f + \fr 10:10 \ft Talenti dị narị na iri abụọ\f* nyekwa ya ọtụtụ ụda na-esi isi ụtọ dị iche iche, na ọtụtụ nkume dị oke ọnụahịa. O nwebeghị oge ọzọ ewebatara ọtụtụ ụda na-esi isi ụtọ dịka ndị ahụ eze nwanyị Sheba nyere eze Solomọn. 
\p  
\v 11 (Ọzọkwa, ọtụtụ ụgbọ mmiri nke eze Hiram bubatara ọlaedo site nʼỌfịa bulatara Solomọn. Ha sitekwara nʼebe ahụ bute osisi almụg nʼebe ọ bara ụba, na ọtụtụ nkume dị oke ọnụahịa dị iche iche.  
\v 12 Eze ji osisi almụg ndị a wuo ogidi ndabere dị nʼụlọnsọ ukwu \nd Onyenwe anyị\nd* na nke ụlọeze. O jikwa ya meere ndị na-abụ abụ ụbọ akwara na une. Ọ dịbeghị mgbe ọbụla ahụrụ maọbụ tụbata osisi almụg ha otu a site nʼụbọchị ahụ ruo taa.) 
\p  
\v 13 Eze Solomọn nyekwara eze nwanyị Sheba ihe niile ọ chọrọ na ihe niile bụ nke ọ rịọrọ, na-agụnyeghị onyinye niile Solomọn nyere ya dịka eze ọ bụ. Emesịa, ọ hapụrụ laghachi nʼala nke aka ya, ya na ndị na-ejere ya ozi. 
\s1 Ebube ịbụ eze Solomọn 
\p  
\v 14 Ọtụtụ ịdị arọ nke ọlaedo Solomọn na-enweta kwa afọ bụ puku kilogram iri abụọ na atọ,\f + \fr 10:14 \ft Narị talenti isii na talenti iri isii na isii\f* 
\v 15 na-agụnyeghị uru nke na-esi nʼaka ndị na-atụ mgbereahịa na ndị na-azụ ahịa na nke sitekwara nʼaka ndị eze Arebịa niile, nakwa nʼaka ndịisi na-achị obodo niile nke ala ahụ. 
\p  
\v 16 Eze Solomọn kpụrụ narị ọta ọlaedo ukwu abụọ site nʼọlaedo etipịara etipịa. Ọ bụ ọlaedo nke ịdị arọ ya ruru kilogram isii na ụma itoolu ka eji kpụọ ọta ọbụla.  
\v 17 Ọ kpụkwara narị ọta nta atọ, nke sitere na ọlaedo etipịara etipịa. Ọ bụ ọlaedo ịdị arọ ya ruru kilogram atọ na ọkara ka eji kpụọ ọta ọbụla. Eze debere ha nʼụlọeze nʼOke Ọhịa Lebanọn. 
\p  
\v 18 Eze mekwara ocheeze dị ukwu nke e ji ọdụ enyi na ọlaedo a nụchara anụcha machie.  
\v 19 Ocheeze ahụ nwere ihe nrigo isii, o nwere elu dị gburugburu nʼazụ ya. E nwere ebe ntụkwasị aka nʼakụkụ abụọ ya, nke nwere oyiyi ọdụm abụọ guzo nʼakụkụ nke ọbụla nʼime ha.  
\v 20 Ọdụm iri na abụọ na-eguzo nʼelu ihe nrigo isii ahụ, otu nʼakụkụ isi abụọ nke ihe nrigo ọbụla. Ọ dịkwaghị alaeze ọzọ dị nke e mere ihe dị otu a nye.  
\v 21 Ihe niile Solomọn nwere nke e ji aṅụ ihe bụ ọlaedo ka e ji mee ha. Ngwongwo niile nke dị nʼime ụlọeze nʼOke Ọhịa Lebanọn bụkwa ọlaedo a nụchara anụcha ka e ji kpụọ ha. Ọ dịghị ihe e ji ọlaọcha kpụọ, nʼihi na-agụnyeghị ọlaọcha dịka ihe ọbụla nʼoge Solomọn.  
\v 22 Eze nwere ọtụtụ ụgbọ\f + \fr 10:22 \ft Hibru ga-asị, \fqa Ọtụtụ ụgbọ nke Tashish\f* mmiri e ji azụ ahịa nʼoke osimiri, tinyere ụgbọ nke Hiram. Otu ugbo nʼafọ atọ, ka ụgbọ mmiri ndị a na-alọta, buru ọlaedo, ọlaọcha na ọdụ enyi, enwe na adaka dị iche iche bata. 
\p  
\v 23 Eze Solomọn bara ụba nʼakụ, nwekwa amamihe karịa ndị eze niile dị nʼụwa.  
\v 24 Ụwa niile na-abịa ịchọ ihu Solomọn ka ha nụta okwu amamihe nke Chineke tinyere nʼobi ya.  
\v 25 Onye ọbụla bịakwutere ya na-ebutere ya onyinye ịnata ihuọma, ya bụ ngwa ọlaọcha na ọlaedo, uwe dị iche iche, ngwa agha, ụda dị iche iche, ịnyịnya na ịnyịnya muul, nke a bụ kwa afọ, kwa afọ. 
\p  
\v 26 Solomọn chịkọbara ọtụtụ ụgbọ agha na ịnyịnya dị iche iche. O nwere ụgbọ agha dị otu puku na narị anọ na ịnyịnya agha dị puku iri na abụọ nʼọnụọgụgụ, ndị o debere ụfọdụ nʼime ha nʼobodo ụgbọ agha ya ma ndị ọzọ dị na Jerusalem ebe ya onwe ya nọ.  
\v 27 Eze mere ka ọlaọcha baa ụba dịka nkume efu na Jerusalem. O mekwara ka osisi sida dị ọtụtụ dịka osisi sikamọ nke dị nʼala ala ugwu dị iche iche.  
\v 28 A na-esite nʼIjipt nakwa ala Kue atụbatara Solomọn ịnyịnya. Ndị ahịa eze na-azụta ha site na Kue nʼọnụ ahịa a na-ere ha nʼoge ahụ.  
\v 29 Ha sitere nʼIjipt tụbata otu ụgbọ agha nʼọnụ ahịa narị shekel ọlaọcha isii, jirikwa otu narị shekel na iri shekel ise zụta otu ịnyịnya. Ha zipụkwara ha nye ndị eze niile nke ndị Het na ndị Aram. 
\c 11  
\s1 Ọtụtụ ndị inyom Solomọn 
\p  
\v 1 Ma eze Solomọn hụrụ ọtụtụ ndị inyom mba ọzọ nʼanya, tinyere nwa nwanyị Fero, ha bụ ndị inyom ndị Moab, ndị Amọn, ndị Edọm, ndị Saịdọn na ndị Het.  
\v 2 Ha bụ ndị sitere na mba ndị ahụ \nd Onyenwe anyị\nd* gwara Izrel sị, “Unu na ha agaghị alụrịtakwa di na nwunye, nʼihi na ha aghaghị ime ka obi unu gbasoo chi niile ha.” Ma, nʼagbanyeghị nke a, Solomọn rapara ha nʼahụ nʼihi ịhụnanya.  
\v 3 Ọnụọgụgụ ndị inyom Solomọn lụrụ dị narị asaa, bụ ndị amụrụ nʼobi ndị eze. O nwekwara ndị iko nwanyị, ọnụọgụgụ ha dị narị atọ. Ndị inyom ya duhiere obi ya.  
\v 4 Mgbe Solomọn ghọrọ agadi, ndị inyom ndị a duhiere obi ya mee ka ọ gbasoo chi ndị ọzọ, nke mere na o jikwaghị obi ya niile gbasoo \nd Onyenwe anyị\nd* Chineke ya, dịka Devid bụ nna ya mere.  
\v 5 Ọ gbasoro Ashtọret, bụ chi ndị Saịdọn na Molek,\f + \fr 11:5 \ft Maọbụ, \fqa Milkọm\f* bụ chi rụrụ arụ nke ndị Amọn.  
\v 6 Nʼụzọ dị otu a, Solomọn mere ihe ọjọọ nʼanya \nd Onyenwe anyị\nd*. O soghị ụzọ \nd Onyenwe anyị\nd* dịka nna ya Devid si mee nʼụbọchị niile nke ndụ ya. 
\p  
\v 7 Nʼelu ugwu dị nʼọwụwa anyanwụ Jerusalem,\f + \fr 11:7 \ft Ugwu dị nʼọwụwa anyanwụ Jerusalem \ft Ugwu a, bụ Ugwu Oliv, nke aha ọzọ a na-akpọ ya bụ Ugwu rụrụ arụ, \xt 2Ez 23:13\f* Solomọn wuru ebe dị elu nye Kemosh, chi rụrụ arụ nke ndị Moab, wuokwara Molek chi rụrụ arụ nke ndị Amọn.  
\v 8 O mekwara otu ihe ahụ nye ndị nwunye ya niile si mba ọzọ, bụ ndị na-achụ aja nsure ọkụ ihe na-esi isi ụtọ, na-achụkwa aja nsure ọkụ dị iche iche nye chi niile ha. 
\p  
\v 9 \nd Onyenwe anyị\nd* were iwe dị ukwuu megide Solomọn, nʼihi na obi ya esitela nʼebe \nd Onyenwe anyị\nd* Chineke Izrel nọ pụọ, bụ onye mere ka ọ hụ ya anya ugboro abụọ.  
\v 10 Ọ bụ ezie na o nyere Solomọn iwu ka ọ ghara ịgbaso chi ndị ọzọ, ma Solomọn erubeghị isi nʼiwu a \nd Onyenwe anyị\nd* nyere.  
\v 11 Ya mere, \nd Onyenwe anyị\nd* gwara Solomọn okwu sị, “Ebe ọ bụ na i mere ihe dị otu a, jụ idebe ọgbụgba ndụ m na ụkpụrụ m, nke m nyere gị idebe, aghaghị m isite nʼaka gị dọkapụ alaeze a, were ya nye otu nʼime ndị na-ejere gị ozi.  
\v 12 Ma nʼihi nna gị Devid agaghị m eme ihe ndị a mgbe ị dị ndụ. Aga m anapụ nwa gị nwoke alaeze Izrel.  
\v 13 Ma agaghị m anapụcha ya alaeze Izrel niile, kama aga m eme ka ọ bụrụ eze otu ebo Izrel, nʼihi Devid, na nʼihi Jerusalem, obodo m họpụtara nye onwe m.” 
\s1 Ndị iro Solomọn 
\p  
\v 14 Mgbe ahụ, \nd Onyenwe anyị\nd* mere ka onye iro bilie megide Solomọn. Onye a bụ Hadad onye Edọm, onye sikwa nʼezinaụlọ ndị eze Edọm.  
\v 15 Nʼoge gara aga, mgbe Devid na-ebuso ndị Edọm agha, Joab, onyeisi ndị agha, onye gara ili ndị agha e gburu egbu, tigburu ndị ikom niile nọ nʼEdọm.  
\v 16 Joab na ndị agha Izrel niile nọgidere nʼebe ahụ ọnwa isii, tutu ruo mgbe ha gbuchapụrụ ndị ikom niile nọ nʼEdọm.  
\v 17 Ma Hadad, onye bụ nwantakịrị nʼoge ahụ, gbapụrụ ọsọ gbaga Ijipt, ya na ụfọdụ ndịisi ọchịchị Edọm, ndị jeere nna ya ozi.  
\v 18 Ha sitere nʼala Midia gaa Paran. Site na Paran, ha duuru ụfọdụ ndị mmadụ, ndị sooro ha gaa Ijipt, jekwuru Fero eze Ijipt, onye nyere Hadad ụlọ obibi na ala, nyekwa ya ihe oriri. 
\p  
\v 19 Hadad hụtara amara nʼihu Fero, nke mere na ọ kpọnyere ya nwanne nwanyị Tapenes bụ nwunye eze ka ọ bụrụ nwunye ya.  
\v 20 Nwanne Tapenes mụtara ya nwa nwoke aha ya bụ Genubat, onye Tapenes zụlitere nʼụlọeze. Genubat biri nʼetiti ụmụ Fero. 
\p  
\v 21 Mgbe Hadad nọ nʼIjipt, ọ nụrụ na Devid sooro ndị nna nna ya ha dina nʼọnwụ na Joab ọchịagha ndị agha anwụọkwala, ọ rịọrọ Fero arịrịọ ka o kwenye ka ọ laghachi nʼEdọm. 
\p  
\v 22 Fero jụrụ ya ajụjụ sị ya, “Gịnị mere i ji chọọ ịla? O nwere ihe ị chọrọ nke ị na-adịghị enweta nʼebe a?” 
\p Hadad zara sị ya, “O nweghị ihe kọrọ m, kama kwere ka m laghachi.” 
\p  
\v 23 Nwoke ọzọ Chineke mere ka ọ bụrụ onye iro Solomọn bụ Rezon nwa Eliada, onye gbapụrụ site nʼaka nna ya ukwu bụ Hadadeza, eze Zoba.  
\v 24 Devid lara ndị agha Zoba nʼiyi, Rezon chịkọtara ndị ikom gbara ya gburugburu, ghọọ onyendu ha, ndị nnupu isi a gara Damaskọs biri nʼebe ahụ, na-achịkwa nʼebe ahụ.  
\v 25 Ogologo ụbọchị niile nke ndụ Solomọn, Rezon bụ onye iro Izrel, tinyekwara nsogbu nke Hadad wetaara Izrel. Rezon bụ eze ndị Aram, bụrụkwa onye na-emegide Izrel. 
\s1 Nnupu isi Jeroboam 
\p  
\v 26 Jeroboam nwa Nebat, onye Ifrem nke Zereda, otu nʼime ndị ozi Solomọn, biliri megide eze. Nne ya bụ Zerua, nwanyị di ya nwụrụ anwụ. 
\p  
\v 27 Nke a bụ akụkọ banyere otu o siri bilie imegide eze: Solomọn wugharịrị Milo, wuziekwa ntipu dị na mgbidi obodo Devid bụ nna ya.  
\v 28 Ugbu a Jeroboam, nʼonwe ya, bụ dimkpa. Mgbe Solomọn hụrụ otu nwokorobịa a si arụzi ọrụ ya nke ọma, o mere ya onye nlekọta ndị ọrụ niile si nʼezinaụlọ Josef. 
\p  
\v 29 Ma otu ụbọchị, mgbe Jeroboam si Jerusalem na-apụ, o zutere Ahija onye amụma, onye Shilo, nʼụzọ, ebe o yi uwe ọhụrụ. Ọ bụkwa naanị ha abụọ nọ nʼọhịa mgbe ahụ.  
\v 30 Mgbe ahụ, Ahija yipụrụ uwe ọhụrụ nke o yi nʼahụ dọwasịa ya ụzọ iri na abụọ.  
\v 31 Mgbe ahụ, ọ gwara Jeroboam sị, “Chịrị iberibe iri nye onwe gị, nʼihi na otu a ka \nd Onyenwe anyị\nd*, Chineke Izrel sịrị, ‘Lee, aga m anapụ Solomọn alaeze a, ma aga m enyekwa gị ebo iri nʼime ha.  
\v 32 Ma aga m ahapụrụ ya otu ebo, nʼihi ohu m Devid na nʼihi Jerusalem obodo m họpụtara site nʼebo niile nke Izrel.  
\v 33 Nʼihi na ha ahapụla m malite ịkpọ isiala nye Ashtọret, chi nwanyị ndị Saịdọn; na nyekwa Kemosh, chi ndị Moab; na nye Molek, chi ụmụ Amọn. Ha agbasoghị ụzọ m, ha emekwaghị ihe ndị ahụ m gụrụ dịka ezi ihe. Ha edebeghị iwu m na ụkpụrụ m niile dịka Devid nna Solomọn mere. 
\p  
\v 34 “ ‘Ma agaghị m anapụ alaeze ya ugbu a, nʼihi ohu m Devid, onye m họpụtara, na onye mere ihe tọrọ m ụtọ. Aga m ahapụ Solomọn ka ọ nọgide dịka eze ụbọchị ndụ ya niile.  
\v 35 Ma aga m anapụ alaeze ya site nʼaka nwa ya, nye gị ebo iri.  
\v 36 Nwa ya ka m ga-enye otu ebo, nʼihi na achọrọ m ka Devid ohu m nọgide ịbụ eze Jerusalem, obodo m họpụtara nye onwe m, ebe m mere ka Aha m dịrị.  
\v 37 Ma otu ọ dị, gị ka m ga-ewere. Ị ga-abụkwa onye ga-achị ebe ahụ niile obi gị chọrọ; i ga-abụ eze Izrel.  
\v 38 Ọ bụrụ na i gee ntị mee ihe niile m ga-enye gị nʼiwu, jekwa ije nʼirubere m isi, mee ihe ziri ezi nʼanya m, site nʼidebe ụkpụrụ niile na iwu niile, dịka ohu m Devid mere, aga m anọnyere gị. Aga m ewuru gị ụlọ ga-adịgide dịka m siri wuoro Devid. Aga m enyekwa gị Izrel.  
\v 39 Aga m eweda agbụrụ Devid nʼihi ihe a, ma ha agaghị abụ ndị e wedara nʼala ruo ebighị ebi.’ ” 
\p  
\v 40 Solomọn gbalịrị igbu Jeroboam, ma Jeroboam gbaara ọsọ gbakwuru eze Shishak nke Ijipt.\f + \fr 11:40 \ft Eze Shishak, bụ Fero mbụ chịrị Ijipt na senchuri nke iri. Mgbe ọchịchị pụrụ site nʼaka ezinaụlọ a, ahọpụtara onye ọzọ ga-achị \xt 1Ez 14:25-26; 2Ih 12:2-9\f* Ọ nọkwara nʼIjipt ruo mgbe Solomọn nwụrụ. 
\s1 Ọnwụ Solomọn 
\p  
\v 41 Ma banyere ihe ndị ọzọ mere nʼoge ọchịchị Solomọn, nke bụ, ihe niile o mere na amamihe o gosipụtara, ọ bụ na-edeghị ha nʼakwụkwọ akụkọ nke Solomọn?  
\v 42 Solomọn chịrị Izrel niile iri afọ anọ na Jerusalem.  
\v 43 O sooro nna nna ya ha dina nʼọnwụ, e lie ya nʼobodo Devid bụ nna ya. Rehoboam nwa ya, ghọkwara eze nʼọnọdụ nna ya. 
\c 12  
\s1 Ọchịchị Rehoboam 
\p  
\v 1 Rehoboam gara Shekem, nʼihi na Izrel niile zukọrọ ebe ahụ ime ya eze.  
\v 2 Mgbe Jeroboam nwa Nebat nụrụ nke a (ọ ka nọ nʼIjipt ebe ọ gbagara ọsọ ndụ site nʼaka eze Solomọn), o sitere Ijipt lọta.  
\v 3 Ya mere, ha ziri ozi kpọọ Jeroboam, ya na ọgbakọ Izrel niile jekwuru Rehoboam sị ya:  
\v 4 “Nna gị boro anyị ibu arọ, ma ugbu a mee ka ibu arọ na ịyagba arọ a nke o bokwasịrị anyị, dị mfe, anyị ga-ejere gị ozi.” 
\p  
\v 5 Rehoboam zara ha sị, “Laanụ, ụbọchị atọ gasịa unu bịaghachikwutenụ m.” Nʼihi ya ndị ahụ lara. 
\p  
\v 6 Mgbe ahụ, eze Rehoboam gara ịnata ndụmọdụ nʼaka ndị okenye, bụ ndị jeere nna ya Solomọn ozi nʼoge ọ dị ndụ, sị ha, “Olee ndụmọdụ unu ga-enye m maka mụ inye ndị a ọsịsa?” 
\p  
\v 7 Ha zara ya, “Ọ bụrụ na ị ga-abụ odibo nye ndị a taa, jeere ha ozi, nyekwa ha ọsịsa dị mma,\f + \fr 12:7 \ft \xt Ilu 15:1; 2Ih 10:7\f* ha ga-anọgide bụrụ ndị ohu gị mgbe niile.” 
\p  
\v 8 Ma ọ nabataghị ndụmọdụ ndị okenye nyere ya, ọ gakwuru ụmụ okorobịa ndị ya na ha tokọrọ, bụkwa ndị na-ejere ya ozi, ka ha nye ya ndụmọdụ.  
\v 9 Rehoboam jụrụ ha sị, “Gịnị bụ ndụmọdụ unu? Gịnị bụ ọsịsa anyị ga-enye ndị a na-asị, ‘Mee ka ibu arọ nna gị bokwasịrị anyị dị mfe’? ” 
\p  
\v 10 Ụmụ okorobịa ahụ, bụ ndị ya na ha tokọrọ, zaghachiri sị, “Gwa ndị ahụ sịrị gị, ‘Nna gị bokwasịrị anyị ibu arọ, ma mee ka ibu anyị dị mfe,’ ị ga-agwa ha, sị, ‘Mkpịsịaka nta dị nʼaka m gbara okpotokpo karịa ukwu nna m.  
\v 11 Nna m boro unu ibu arọ; aga m atụkwasị ihe nʼibu ahụ mee ka ọ dị arọ karịa. Nna m ji apịpịa dọọ unu aka na ntị, maọbụ akpị ka m ga-eji mekpaa unu ahụ.’ ” 
\p  
\v 12 Mgbe ụbọchị atọ gasịrị, Jeroboam na ndị Izrel\f + \fr 12:12 \ft Ndị Izrel a na-ekwu banyere ha nʼebe a, bụ ndị Izrel nke alaeze ugwu ugwu.\f* niile bịaghachiri ịnụrụ ọsịsa Rehoboam, dịka eze kwuru, sị, “Laghachitenụ nʼụbọchị nke atọ.”  
\v 13 Eze sara ndị a okwu nʼolu dị ike. Ọ jụrụ ndụmọdụ nke ndị okenye nyere ya,  
\v 14 ma gbasoro ndụmọdụ nke ụmụ okorobịa nyere. Ọ sịrị, “Nna m mere ka ibu unu dị arọ, aga m eme ka ibu unu dị arọ karịa. Nna m ji apịpịa dọọ unu aka na ntị, aga m eji akpị mekpaa unu ahụ.”  
\v 15 Ya mere, eze aṅaghị ndị ahụ ntị, nʼihi mgbanwe nke ọnọdụ niile a sitere nʼebe \nd Onyenwe anyị\nd* nọ, ka e mezuo okwu ahụ \nd Onyenwe anyị\nd* gwara Jeroboam nwa Nebat site nʼọnụ Ahija onye Shilo. 
\p  
\v 16 Mgbe Izrel niile hụrụ na eze jụrụ ige ha ntị, ha zaghachiri ya sị, 
\q1 “Olee oke anyị nwere nʼime Devid? 
\q2 Olee ihe nketa anyị nwere nʼime nwa Jesi? 
\q1 Ndị Izrel, laanụ nʼụlọ ikwu unu! 
\q2 Gị Devid lekọtakwa ụlọ nke gị.” 
\m Ya mere, ndị Izrel lara nʼụlọ ha.  
\v 17 Ma banyere ndị Izrel bi nʼobodo niile nke Juda, Rehoboam gara nʼihu bụrụ eze ha. 
\p  
\v 18 Eze Rehoboam zipụrụ Adoniram, onyeisi na-elekọta ndị ọrụ mmanye, ma ndị Izrel niile ji nkume tugbuo ya. Ma eze Rehoboam jisiri ike gbaba nʼime ụgbọ agha ya, gbalaga laa Jerusalem.  
\v 19 Ya mere, Izrel nọ na nnupu isi megide ụlọ Devid ruo taa. 
\p  
\v 20 Mgbe ndị Izrel nụrụ na Jeroboam alaghachitala, ha ziri ya ozi sị ya pụta nʼihu ọha mmadụ. Nʼebe ahụ ka ha nọ mee ya eze Izrel. Ọ dịghị ebo ọbụla kwenyere iso ụlọ Devid, karịakwa ebo Juda. 
\p  
\v 21 Mgbe Rehoboam bịarutere Jerusalem, ọ kpọkọtara ndị ụlọ Juda niile na ndị ebo Benjamin, ha dị narị puku na iri asatọ nʼọnụọgụgụ, ụmụ okorobịa ndị tozuru ịga agha, ka ha gaa buso ụlọ Izrel agha ma weghachitekwa alaeze nʼokpuru ọchịchị Rehoboam, nwa Solomọn. 
\p  
\v 22 Ma okwu Chineke rutere Shemaya onye nke Chineke ntị, sị,  
\v 23 “Gwa Rehoboam, nwa Solomọn eze Juda, na ndị Juda niile, na Benjamin na ndị ọzọ niile, sị ha,  
\v 24 Otu a ka \nd Onyenwe anyị\nd* kwuru, ‘Unu agakwala gaa buso ụmụnna unu, bụ ndị Izrel agha. Laghachinụ, nwoke ọbụla nʼụlọ ya, nʼihi na ọ bụ m na-eme nke a.’ ” Ya mere, ha rubere isi nʼokwu \nd Onyenwe anyị\nd*, onye ọbụla nʼime ha laghachikwara nʼụlọ ya dịka \nd Onyenwe anyị\nd* nyere nʼiwu. 
\s1 Oyiyi ehi ọlaedo dị na Betel na Dan 
\p  
\v 25 Mgbe ahụ, Jeroboam wusiri Shekem dị nʼala ugwu Ifrem ike, biri nʼebe ahụ. Nʼebe ahụ ka o si pụọ, gaa wuo obodo Peniel.\f + \fr 12:25 \ft Nʼasụsụ Hibru \fqa Penuel \ft bụ otu ọzọ e si akpọ \fq Peniel\f* 
\p  
\v 26 Ma Jeroboam chere nʼobi ya, sị “Ugbu a, ka alaeze nwere ike laghachikwa nʼaka ụlọ Devid.  
\v 27 Nʼihi na ọ bụrụ na ndị mmadụ gaa ịchụ aja nʼụlọnsọ ukwu \nd Onyenwe anyị\nd* nke dị na Jerusalem, obi ha nwere ike laghachikwuru onyenwe ha, bụ Rehoboam eze Juda. Ha ga-egbu m, laghachikwuru eze Rehoboam.” 
\p  
\v 28 Mgbe ọ natachara ndụmọdụ, eze kpụrụ ụmụ ehi ọlaedo abụọ. Ọ sịrị ndị mmadụ, “Ọ bụ oke ọrụ nye unu ịgbago Jerusalem. Leenụ chi unu, ndị Izrel, ndị sitere nʼIjipt kpọpụta unu.”  
\v 29 Otu nʼime ha ka o guzobere na Betel, tinyekwa nke ọzọ na Dan.  
\v 30 Ihe a ghọrọ mmehie dịrị ha, nʼihi na ndị mmadụ na-abịa kpọọ isiala nye nke dị na Betel ma gaakwa ebe dị anya, dịka Dan, nʼihi ife ehi ọlaedo nke dị nʼebe ahụ ofufe. 
\p  
\v 31 Jeroboam wuru ebe ịchụ aja nʼebe dị elu dị iche iche. Ọ họpụtara ndị nchụaja site nʼetiti ndị Izrel niile,\f + \fr 12:31 \ft Mgbe ndị nchụaja gbapụrụ ọsọ site na Jerusalem, nʼihi ize ndụ site nʼaka Jeroboam, ọ họpụtara ndị nchụaja site nʼetiti ndị Izrel niile, nʼagbanyeghị na ndị a abụghị ndị Livayị. \xt 2Ih 11:13-17\f* nʼagbanyeghị na ha abụghị ndị Livayị.  
\v 32 O hiwere mmemme a na-eme nʼụbọchị nke iri na ise nʼọnwa nke asatọ, dịka mmemme a na-eme na Juda. Ọ chụkwara aja nʼebe ịchụ aja. O mere nke a na Betel, chụọrọ ụmụ ehi ọlaedo ahụ ọ kpụrụ aja. O tinyere ndị nchụaja nʼọrụ nʼebe niile dị elu nke o mere ka ha dịrị na Betel.  
\v 33 Nʼụbọchị nke iri na ise, nʼọnwa asatọ, bụ ọnwa nke ya onwe ya chepụtara, ọ chụrụ aja dị iche iche nʼelu ebe ịchụ aja o wuru na Betel. Ya mere, o hiwere mmemme a ka ọ dịịrị ndị Izrel niile; ya onwe ya kwa gara chụọ aja onyinye dị iche iche nʼelu ebe ịchụ aja. 
\c 13  
\s1 Onye nke Chineke si Juda 
\p  
\v 1 Otu onye nke Chineke si Juda bịa Betel, site nʼokwu nke \nd Onyenwe anyị\nd* oge Jeroboam guzo nʼebe ịchụ aja ka ọ chụọ aja.  
\v 2 O tiri mkpu nʼoke olu megide ebe ịchụ aja ahụ dịka okwu \nd Onyenwe anyị\nd* si dị, “Ebe ịchụ aja, ebe ịchụ aja! Otu a ka \nd Onyenwe anyị\nd* na-ekwu: ‘A ga-amụ otu nwa nwoke nʼụlọ Devid, aha ya ga-abụ Josaya.\f + \fr 13:2 \ft \xt 2Ez 23:15-16\f* Ọ ga-eji ndị nchụaja niile nke ebe dị elu, bụ ndị na-achụ aja nʼelu gị, chụọ aja nʼelu gị. A ga-esurekwa ọkpụkpụ ndị mmadụ ọkụ nʼelu gị.’ ”  
\v 3 Nʼụbọchị ahụ, onye nke Chineke ahụ kwuru okwu banyere ihe ịrịbama ga-emezu. O kwuru sị, “Nke a bụ ihe ịrịbama \nd Onyenwe anyị\nd* ji emesi okwu ya ike: Ebe ịchụ aja a ga-agbawa ụzọ abụọ. Ntụ dị nʼelu ya ga-awụsasị nʼala.” 
\p  
\v 4 Mgbe eze Jeroboam nụrụ ihe onye nke Chineke ahụ kwuru megide ebe ịchụ aja Betel, o setịpụrụ aka ya site nʼebe ịchụ aja ahụ sị, “Jidenụ nwoke a!” Ma aka ahụ ọ setịpụrụ tụgide nwoke ahụ kpọnwụrụ na o nwekwaghị ike iweghachi ya azụ ọzọ.  
\v 5 Ọzọkwa, ebe ịchụ aja ahụ gbawara abụọ, ntụ dị nʼelu ya wụsịkwara nʼala dịka ihe ịrịbama nke onye amụma Chineke nyere, site nʼokwu \nd Onyenwe anyị\nd*. 
\p  
\v 6 Mgbe ahụ, eze sịrị onye nke Chineke ahụ, “Biko, rịọọ \nd Onyenwe anyị\nd* Chineke gị, kpekwara m ekpere ka e nyeghachi m aka m.” Ya mere, onye nke Chineke ahụ rịọrọ \nd Onyenwe anyị\nd* site nʼekpere, emekwara ka aka eze dịghachi dịkwa ka ọ dị na mbụ. 
\p  
\v 7 Emesịa, eze gwara onye nke Chineke ahụ okwu sị, “Soro m gaa nʼụlọ m. Aga m enye gị ihe oriri, nyekwa gị onyinye.” 
\p  
\v 8 Ma onye nke Chineke ahụ zara eze sị, “Ọ bụrụ na i nye m ọkara ihe niile i nwere, agaghị m eso gị baa nʼime ụlọ gị. Agaghị m erikwa nri gị maọbụ ṅụọ mmiri nʼebe a.  
\v 9 Nʼihi na-enyere m iwu site nʼokwu \nd Onyenwe anyị\nd*, sị, ‘Erila nri, aṅụkwala mmiri, esitekwala ụzọ i si gaa laghachi.’ ”  
\v 10 Ya mere, o sitere nʼụzọ ọzọ lawa, nke na-abụghị ụzọ o si bịa Betel. 
\p  
\v 11 Ma o nwere otu onye amụma bụ agadi bi na Betel. Onye ụmụ ya bịara kọọrọ ihe niile onye nke Chineke ahụ mere nʼụbọchị ahụ na Betel, ha kọkwaara nna ha ihe niile ọ gwara eze.  
\v 12 Nna ha jụrụ ha, “Olee ụzọ ọ gara?” Ụmụ ya ndị ikom ziri ya ụzọ nke onye nke Chineke ahụ si Juda gara.  
\v 13 Mgbe ahụ, ọ sịrị ụmụ ya ndị ikom, “Jikekwaranụ m ịnyịnya ibu m.” Ha jikekwaara ya ịnyịnya ibu, ọ nọkwasịrị nʼelu ya.  
\v 14 Ọ gbasooro onye nke Chineke nʼazụ, ọ hụrụ ya ka ọ nọ ala nʼokpuru osisi ook, Ọ sịrị ya, “Ọ bụ gị bụ onye nke Chineke ahụ si Juda bịa?” 
\p Ọ zara, “E, ọ bụ mụ onwe m.” 
\p  
\v 15 Onye amụma ahụ sịrị ya, “Soro m ka anyị gaa nʼụlọ m, ka i rie nri.” 
\p  
\v 16 Ma ọ sịrị, “Apụghị m iso gị laghachi azụ, maọbụ rie nri, ma ọ bụkwa ṅụọ mmiri ọbụla nʼebe a.  
\v 17 Nʼihi na a gwara m site nʼokwu \nd Onyenwe anyị\nd* sị, ‘Erikwala nri maọbụ ṅụọ mmiri nʼebe ahụ, maọbụ soro ụzọ ị si gaa lọtakwa.’ ” 
\p  
\v 18 Ma onye nke ọzọ sịrị ya, “Mụ onwe m bụkwa onye amụma dịka gị, mmụọ ozi zikwara m ozi site nʼokwu \nd Onyenwe anyị\nd* sị, ‘Kpọrọ ya ka o soro gị laghachi nʼụlọ gị, ka o rie nri, ṅụọkwa mmiri.’ ” (Ma ọ gwara ya okwu ụgha.)  
\v 19 Ya mere, nwoke nke Chineke ahụ soro ya laghachi rie nri, ṅụọkwa mmiri. 
\p  
\v 20 Ma mgbe ha abụọ nọdụ na-eri ihe na tebul, okwu \nd Onyenwe anyị\nd* rutere onye amụma agadi ahụ ntị, bụ onye mere ka ọ lọghachi azụ.  
\v 21 Ọ kpọrọ onye nke Chineke ahụ si Juda bịa sị ya, “Otu a ka \nd Onyenwe anyị\nd* na-ekwu, ‘Nʼihi na ị nupula isi nʼokwu ọnụ \nd Onyenwe anyị\nd*, hapụ idebe iwu \nd Onyenwe anyị\nd* Chineke gị nyere gị.  
\v 22 Ị laghachikwara nʼebe a, rie nri, ṅụọkwa mmiri, bụ ebe ọ gwara gị sị gị, erila nri, aṅụkwala mmiri. Ya mere, agaghị eli ozu gị nʼala ili nna gị ha.’ ” 
\p  
\v 23 Mgbe onye nke Chineke ahụ risiri nri, ṅụọkwa ihe ọṅụṅụ, ha kwadooro ya ịnyịnya ibu nke onye amụma ahụ kpọghachiri ya azụ.  
\v 24 Dịka ọ na-alaghachi, otu ọdụm zutere ya nʼụzọ, dọgbuo ya. Ma ọ hapụrụ ozu ya ka ọ tọgbọrọ nʼokporoụzọ, ma ịnyịnya ibu ya ma ọdụm ahụ dọgburu nwoke ahụ guzokwa nʼakụkụ ozu ya.  
\v 25 Ndị mmadụ na-agafe hụrụ ozu ahụ ka ọ tọgbọrọ nʼụzọ, hụkwa ka ọdụm ahụ guzo nʼakụkụ ya. Ndị a gara kọọ akụkọ ihe ha hụrụ nʼụzọ nʼobodo ebe onye amụma agadi ahụ bi. 
\p  
\v 26 Mgbe onye amụma ahụ mere ka ọ laghachi azụ nụrụ ihe mere, ọ sịrị, “Ọ bụ onye nke Chineke ahụ nupuru isi nʼokwu \nd Onyenwe anyị\nd*. \nd Onyenwe anyị\nd* enyefeela ya nʼaka ọdụm, nke dọgburu ma gbukwaa ya, dịka okwu \nd Onyenwe anyị\nd* dọrọ ya aka na ntị.” 
\p  
\v 27 Mgbe ahụ, ọ sịrị ụmụ ya ndị ikom, “Jikekwaranụ m ịnyịnya ibu.” Ha mere otu a.  
\v 28 Ọ pụrụ gaa chọta ozu nwoke ahụ ka ọ tọgbọrọ nʼụzọ. Ịnyịnya ibu ya na ọdụm ahụ guzokwa nʼakụkụ ozu ahụ. Ọdụm erighị anụ nwoke ahụ, ọ dọgbukwaghị ịnyịnya ibu ahụ.  
\v 29 Onye amụma agadi ahụ buliri ozu onye nke Chineke ahụ dọkwasị ya nʼelu ịnyịnya ibu ya, buru ya bughachi ya nʼobodo, nʼihi iruru ya ụjụ, nakwa ili ya.  
\v 30 O liri ozu onye nke Chineke ahụ nʼili nke aka ya. Mgbe o liri ya, ọ kwara akwa sị, “Ewoo nwanna m!” 
\p  
\v 31 Mgbe o lisiri ya, ọ gwara ụmụ ya ndị ikom sị, “Mgbe m nwụrụ, lienụ m nʼotu ili a e liri onye nke Chineke; doonụ ọkpụkpụ m ka ọ dịrị nʼakụkụ ọkpụkpụ ya.  
\v 32 Nʼihi na ozi ahụ niile o ziri site nʼokwu \nd Onyenwe anyị\nd* megide ebe ịchụ aja dị na Betel, na megidekwa ebe ụlọ arụsị niile dị nʼebe dị elu nʼobodo Sameria aghaghị imezu.” 
\p  
\v 33 Nʼagbanyeghị ihe ndị a niile, Jeroboam esiteghị nʼụzọ ọjọọ ya tụgharịa. Kama ọ gara nʼihu họpụta ndị nchụaja maka ebe niile dị elu site nʼetiti ndị mmadụ efu. Onye ọbụla chọrọ ị bụ onye nchụaja ka o doro nsọ maka ije ozi nʼebe niile dị elu.  
\v 34 \f + \fr 13:34 \ft \xt 1Ez 12:30; 2Ez 17:21\f*Nke a bụ mmehie ezinaụlọ Jeroboam. Ọ bụ ya mere alaeze Jeroboam ji daa, meekwa ka e kpochapụ ya nʼelu ụwa. 
\c 14  
\s1 Amụma Ahija megide Jeroboam 
\p  
\v 1 Nʼoge a, Abija nwa Jeroboam nọ nʼọrịa nke dị ukwuu.  
\v 2 Nʼihi ya, Jeroboam sịrị nwunye ya, “Gaa, jikwaa onwe gị nʼụzọ mmadụ na-enweghị ike ịmata na ị bụ nwunye Jeroboam. Ị ga-ejekwa Shaịlo, Ahija onye amụma nọ nʼebe ahụ, bụ nwoke ahụ gwara m okwu na m ga-abụ eze ndị nke a.  
\v 3 Chịrịkwa ogbe achịcha iri, na achịcha nta ole na ole, na otu karama mmanụ aṅụ, jekwuru ya. Ọ ga-agwa gị ihe ga-eme banyere nwantakịrị a.”  
\v 4 Nwunye Jeroboam mere ihe o kwuru, o biliri jee nʼụlọ Ahija na Shaịlo. 
\p Ahija bụ agadi nwoke nʼoge a. Ọ naghị ahụkwa ụzọ nʼihi nka ọ kara.  
\v 5 Ma \nd Onyenwe anyị\nd* agwalarị Ahija okwu sị ya, “Nwunye Jeroboam na-abịa ịjụta ase nʼaka gị banyere nwa ya nwoke ahụ na-adịghị ike, ọsịsa dị otu a ka i ganye ya. Mgbe ọ ga-abịa ịhụ gị ọ ga-eme onwe ya dịka ọ bụghị nwunye Jeroboam.” 
\p  
\v 6 Mgbe Ahija nụrụ ụda nzọ ụkwụ ya ka ọ na-abata nʼọnụ ụzọ, ọ kpọrọ ya oku sị ya, “Bata, nwunye Jeroboam. Gịnị mere i ji jie ejiji dịka onye ọzọ? Enwere m akụkọ ọjọọ m ga-akọrọ gị  
\v 7 Ga gwa Jeroboam sị ya, Otu a ka \nd Onyenwe anyị\nd*, Chineke Izrel kwuru, ‘Esi m nʼetiti ndị m welie gị elu, mee gị ka ị bụrụ onye ga-achị ndị m, bụ Izrel.  
\v 8 Adọwapụrụ m alaeze Izrel site nʼụlọ Devid nye gị ya, ma ị geghị ntị nʼiwu m, maọbụ debe ha dịka ohu m Devid debere ihe niile m nyere ya nʼiwu. Onye echiche obi ya na ihe na-atọ obi ya ụtọ mgbe niile bụ idebe iwu m, na ime ihe ziri ezi nʼanya m.  
\v 9 \f + \fr 14:9 \ft \xt 1Ez 12:28; 2Ih 11:15\f* Ma ihe ọjọọ i mere adịla ukwuu karịa nke ndị niile bu gị ụzọ bụrụ eze mere. Ị kpụọlara onwe gị chi ndị ọzọ, chi ndị e ji ọla kpụọ, si otu a kpasuo m iwe, gbakụta m azụ gị. 
\p  
\v 10 “ ‘Nʼihi ihe ndị a, aga m eme ka ihe ọjọọ bịakwasị ezinaụlọ Jeroboam. Aga m ekpochapụkwa ụmụ ndị ikom gị niile, ma ndị ohu, ma ndị nwe onwe ha nọ nʼala Izrel. Aga m ekpochapụkwa ụlọ Jeroboam dịka mmadụ si ekpochapụ nsị anụ, ruo mgbe e kpochapụrụ ha niile.  
\v 11 Nkịta ga-eri ozu ndị nke Jeroboam ndị nwụrụ nʼime obodo, ma ndị nwụrụ nʼọhịa ka anụ ufe nke eluigwe ga-eri ozu ha. \nd Onyenwe anyị\nd* ekwuola ya.’ 
\p  
\v 12 “Ma gị onwe gị, Laa nʼụlọ gị. Mgbe ị na-azọbanye ụkwụ gị nʼobodo, nwokorobịa ahụ ga-anwụ.  
\v 13 Ndị Izrel niile ga-akwa akwa nʼihi ya lie ya. Ọ bụ naanị ya bụ onye a ga-eli eli, nʼihi na nʼime ezinaụlọ Jeroboam, ọ bụ naanị nʼime nwokorobịa a ka \nd Onyenwe anyị\nd*, Chineke Izrel chọtara ihe dị mma. 
\p  
\v 14 “Ma \nd Onyenwe anyị\nd* ga-emekwa ka eze ọzọ bilie nʼIzrel, onye ga-ekpochapụ ezinaụlọ Jeroboam niile. O bidola taa, e, ma ugbu a kwa!  
\v 15 \nd Onyenwe anyị\nd* ga-eti Izrel ihe, mee ka ọ maa jijiji dịka osisi achara nke ikuku na-ebugharị nʼime mmiri. Ọ ga-ehopu Izrel site nʼezi ala o nyere nna nna ha, fesaa ha nʼofe osimiri Yufretis, nʼihi na ha akpasuola iwe \nd Onyenwe anyị\nd* site nʼiguzobe ogidi ofufe Ashera.  
\v 16 Ọ ga-agbakụta Izrel azụ nʼihi mmehie Jeroboam mere, ma meekwa ka Izrel niile soro ya mehie.” 
\p  
\v 17 Mgbe ahụ, nwunye Jeroboam biliri laghachi Tịaza. Ma nwokorobịa ahụ nwụrụ mgbe ọ na-azọbata ụkwụ ya nʼọnụ ụzọ ụlọ ha.  
\v 18 Ha liri ya, ndị Izrel niile rukwara ụjụ nʼihi ya, dịka okwu \nd Onyenwe anyị\nd* si dị, nke o kwuru site nʼọnụ Ahija, onye amụma. 
\p  
\v 19 Ihe niile ọzọ Jeroboam mere, na ihe niile banyere ibu agha ya niile, na ọtụtụ ihe ọzọ dị iche iche banyere ọchịchị ya, ka e dere nʼakwụkwọ akụkọ ihe ndị eze Izrel mere.  
\v 20 Jeroboam chịrị Izrel iri afọ abụọ na abụọ. O sooro ndị nna nna ya ha dina nʼọnwụ, nwa ya Nadab ghọrọ eze nʼọnọdụ ya. 
\s1 Rehoboam, eze Juda 
\p  
\v 21 Nʼoge a, Rehoboam nwa Solomọn, bụ eze Juda. Ọ gbara iri afọ anọ na otu mgbe ọ malitere ịbụ eze. Ọ chịrị afọ iri na asaa na Jerusalem, bụ obodo ahụ \nd Onyenwe anyị\nd* họọrọ site nʼetiti ebo niile nke Izrel, bụ ebe ọ ga-akpọkwasị Aha ya. Aha nne ya bụ Naama, onye Amọn. 
\p  
\v 22 Mgbe ahụ, ndị Juda mehiekwara megide \nd Onyenwe anyị\nd*. Ha sitere nʼọtụtụ mmehie ha mere, nke karịrị mmehie nke ndị nna nna ha ochie mere, kpasuo ekworo ya.  
\v 23 Ha wukwara nye onwe ha ebe ịchụ aja na ogidi arụsị nʼelu ugwu niile, na ogidi chi Ashera, na nʼokpuru osisi ọbụla akwụkwọ ndụ dị nʼelu ya.\f + \fr 14:23 \ft Mgbe ndị Izrel wuru ebe ịchụ aja na ogidi arụsị, ha nupuru isi site nʼiwu Chineke nyere ha nʼakwụkwọ \xt Ọpụ 23:24; 34:13-14; Dit 7:5; 12:2-3\f* 
\v 24 E nwere ndị ikom akwụna nʼala ahụ, ndị nọ nʼụlọ arụsị ha dị iche iche. Ndị mmadụ mere ụdị ihe arụ ahụ nke ndị mba niile ndị ahụ na-eme, bụ mba ndị ahụ \nd Onyenwe anyị\nd* sitere nʼihu ndị Izrel chụpụ. 
\p  
\v 25 Nʼafọ nke ise, nke ọchịchị eze Rehoboam, Shishak, eze Ijipt, busoro Jerusalem agha.  
\v 26 O bukọrọ akụ niile dị nʼime ụlọ \nd Onyenwe anyị\nd*, na akụ niile dịkwa nʼụlọeze. Ọ kwakọọrọ ihe niile, werekwa ọta ọlaedo niile ndị ahụ Solomọn kpụrụ.  
\v 27 Ma eze Rehoboam kpụrụ ọta bronz i ji dochie ndị ahụ, nyefee ha nʼaka ndịisi ndị nche, bụ ndị na-eche nʼọnụ ụzọ ụlọeze nche ka a lekọta ha anya.  
\v 28 Mgbe ọbụla eze na-aga nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*, ndị nche na-ebu ọta ndị ahụ, emesịa, ha na-ebughachikwa ha nʼime ụlọ ndị nche. 
\p  
\v 29 Ma banyere ihe ndị ọzọ niile mere nʼoge ọchịchị Rehoboam, na ihe niile o mere, ọ bụ na e deghị ha nʼakwụkwọ akụkọ ndị eze Juda?  
\v 30 Agha dịgidere nʼetiti Rehoboam na Jeroboam ụbọchị niile nke ndụ ha.  
\v 31 Rehoboam sooro ndị nna nna ya ha dina nʼọnwụ, e lie ya nʼebe e liri ha nʼobodo Devid. Aha nne ya bụ Naama, onye Amọn. Abija nwa ya ghọrọ eze nʼọnọdụ ya. 
\c 15  
\s1 Ọchịchị eze Abija 
\p  
\v 1 Abija malitere ịbụ eze Juda, nʼafọ iri na asatọ nke ọchịchị eze Jeroboam nwa Nebat.  
\v 2 Ọ chịrị afọ atọ na Jerusalem. Aha nne ya bụ Maaka, nwa nwanyị Abishalom. 
\p  
\v 3 O mere mmehie niile nna ya mere nʼihu ya; o jighị obi zuruoke gbasoo \nd Onyenwe anyị\nd* Chineke ya, dịka obi nna nna ya Devid dị.  
\v 4 Ma nʼihi Devid, \nd Onyenwe anyị\nd* Chineke ya nyere ya oriọna na Jerusalem, site na-ime ka nwa ya nwoke nọchie ọnọdụ ya nakwa ime ka Jerusalem guzosie ike.  
\v 5 Nʼihi na Devid mere ihe ziri ezi nʼanya \nd Onyenwe anyị\nd*, ọ dịghịkwa iwu \nd Onyenwe anyị\nd* ọbụla nke ọ na-edebeghị nʼụbọchị ndụ ya niile, ma ọ bụghị naanị ihe banyere okwu Ụraya, onye Het. 
\p  
\v 6 Agha dị nʼetiti Abija na Jeroboam nʼụbọchị niile nke ndụ Abija.  
\v 7 Ma banyere ihe ndị ọzọ niile mere nʼoge ọchịchị Abija, o bụ na e deghị ha nʼakwụkwọ akụkọ ndị eze Juda? Agha dịgidere nʼetiti Abija na Jeroboam.  
\v 8 Abija sooro nna nna ya ha dina nʼọnwụ, e lie ya nʼobodo Devid. Asa, nwa ya nwoke ghọrọ eze nʼọnọdụ ya. 
\s1 Asa, eze Juda 
\p  
\v 9 Nʼafọ nke iri abụọ nke ọchịchị Jeroboam eze Izrel, ka Asa ghọrọ eze Juda.  
\v 10 Ọ chịrị iri afọ anọ na otu na Jerusalem. Aha nne nne ya bụ Maaka, nwa nwanyị Abishalom. 
\p  
\v 11 Asa mere ihe ziri ezi nʼanya \nd Onyenwe anyị\nd* dịka Devid nna ya mere.\f + \fr 15:11 \ft \xt 2Ih 14:2; 1Ez 9:4; 14:8\f* 
\v 12 O sitere nʼala ahụ niile chụpụ ndị ikom akwụna ụlọ arụsị niile, wezugakwa arụsị niile nke ndị nna nna ya ha mere.  
\v 13 Ọ chụdakwara ọbụladị nne nne ya bụ Maaka, site nʼọnọdụ ya dịka nne eze, nʼihi na ọ kpụrụ ihe arụ, ogidi Ashera maka iji fee ya ofufe. Asa gbuturu ya kpọọ ya ọkụ na ndagwurugwu iyi Kidrọn.  
\v 14 Ọ bụ ezie na o wezugaghị ugwu niile dị elu, ma Asa ji obi zuruoke jere \nd Onyenwe anyị\nd* ozi nʼoge ndụ ya niile.  
\v 15 O webatara nʼime ụlọnsọ \nd Onyenwe anyị\nd* ọlaọcha na ọlaedo na ihe niile nke nna ya na ya onwe ya doro nsọ. 
\p  
\v 16 Ma agha dịgidere nʼetiti Asa na Baasha, eze Izrel ụbọchị ọchịchị ha niile.  
\v 17 Baasha eze Izrel, busoro Juda agha, wuchie Rema igbochi onye ọbụla na-apụ apụ maọbụ onye na-abata abata nʼoke ala Asa, eze Juda. 
\p  
\v 18 Mgbe ahụ, Asa chịịrị ọlaọcha na ọlaedo niile dị nʼụlọakụ ụlọnsọ \nd Onyenwe anyị\nd*, na ndị dị nʼụlọeze ya, nyefee ya nʼaka ndị ozi ya ka ha chịrị ha zigara Ben-Hadad, nwa Tabrimọm, nwa Hezion, bụ eze Aram, onye na-achị na Damaskọs, sị,  
\v 19 “Biko, ka anyị gbaa ndụ dịka nna m na nna gị mere. Lee, ana m ezitere gị onyinye ọlaọcha na ọlaedo. Ugbu a, mebie ọgbụgba ndụ dị nʼetiti gị na Baasha, bụ eze Izrel, ka o si nʼebe m nọ wezuga onwe ya.” 
\p  
\v 20 Ben-Hadad kwenyere eze Asa, zipụ ndị ọchịagha ndị agha ya ka ha gaa buso obodo Izrel niile agha. Ọ lụgburu Ijon, Dan, Ebel-Bet-Maaka na ala Kineret niile, tinyere ala niile nke ndị Naftalị.  
\v 21 Mgbe Baasha nụrụ nke a, ọ kwụsịrị iwu Rema, laghachi biri na Tịaza.  
\v 22 Mgbe ahụ, eze Asa nyere iwu zigara ndị Juda niile, na ọ dịghị onye iwu ahụ hapụrụ, ha bịara bupusịa nkume na osisi niile dị na Rema, nke Baasha ji na-ewu ihe nʼebe ahụ. Eze Asa ji ihe ndị a wulie Geba nke Benjamin, wuokwa Mizpa. 
\p  
\v 23 Ma banyere ihe ndị ọzọ niile mere nʼoge ọchịchị Asa, na ihe niile ọ rụpụtara na obodo niile ndị o wuru, ọ bụ na e deghị ha nʼakwụkwọ akụkọ ihe e mere nʼoge ndị eze Juda? Ma ọ rịara ọrịa nke metụtara ụkwụ ya abụọ, mgbe o mere agadi.  
\v 24 Asa sooro ndị nna nna ya ha dina nʼọnwụ, e lie ya nʼebe e liri ha, nʼobodo Devid, bụ nna ya. Jehoshafat nwa ya ghọrọ eze nʼọnọdụ ya. 
\s1 Nadab, eze Izrel 
\p  
\v 25 Nadab, nwa Jeroboam, malitere ịbụ eze Izrel, nʼafọ nke abụọ nke Asa, eze Juda. Ọ chịrị Izrel afọ abụọ.  
\v 26 O mere ihe dị njọ nʼanya \nd Onyenwe anyị\nd*. Ọ gbasoro ụzọ niile nke nna ya ma na-emekwa otu mmehie ahụ nke nna ya ji duba Izrel nʼime mmehie. 
\p  
\v 27 Baasha nwa Ahija, onye si nʼebo Isaka gbara izu ọjọọ megide ya. O tidara ya na Gibeton, nʼotu obodo ndị Filistia, mgbe Nadab na ndị Izrel niile nọchibidoro ya.  
\v 28 Baasha gburu Nadab, nọchie ọnọdụ ya dịka eze, nʼafọ nke atọ nke ọchịchị Asa, eze Juda. 
\p  
\v 29 Ngwangwa, mgbe ọ malitere ọchịchị ya, o gburu ndị ezinaụlọ Jeroboam niile. O kweghị ka onye ọbụla na-eku ume fọdụ, kama ọ lara ha niile nʼiyi, dịka okwu \nd Onyenwe anyị\nd* kwuru site nʼọnụ onyeozi ya, bụ Ahija onye Shilo.  
\v 30 Ihe ndị a mere nʼihi mmehie niile Jeroboam mere, nke o mere ka Izrel mee, nakwa nʼihi na ọ kpasuru \nd Onyenwe anyị\nd*, bụ Chineke Izrel iwe. 
\p  
\v 31 Ma banyere ihe ndị ọzọ niile mere nʼoge ọchịchị Nadab, o bụ na e deghị ha nʼakwụkwọ akụkọ ihe mere nʼoge ndị eze Izrel?  
\v 32 Ma agha dịgidere nʼetiti Asa na Baasha, eze Izrel, ụbọchị ọchịchị ha niile. 
\s1 Baasha, eze Izrel 
\p  
\v 33 Nʼafọ nke atọ nke Asa, eze Juda, Baasha nwa Ahija ghọrọ eze ndị Izrel niile na Tịaza. Ọ chịrị iri afọ abụọ na abụọ.  
\v 34 O mere ọtụtụ ihe dị njọ nʼanya \nd Onyenwe anyị\nd*. Ọ gbasoro ụzọ ọjọọ niile nke Jeroboam, jeekwa ije nʼime otu mmehie ahụ nke Jeroboam dubara ndị Izrel ime. 
\c 16  
\p  
\v 1 Mgbe ahụ, ozi \nd Onyenwe anyị\nd* sitere nʼọnụ Jehu, nwa Hanani banyere Baasha, eze Izrel sị ya,  
\v 2 “Esi m nʼaja welie gị elu, mee gị onye ọchịchị ndị m Izrel. Ma i jeela ije nʼụzọ ọjọọ niile nke Jeroboam. I meela ka ndị m bụ Izrel mmehie, si otu a kpasuo m iwe site na mmehie ha.  
\v 3 Ya mere, aga m ekpochapụ Baasha na ezinaụlọ ya, m ga-emekwa ụlọ gị ka ọ dịka ụlọ Jeroboam, nwa Nebat.  
\v 4 \f + \fr 16:4 \ft \xt 1Ez 14:11; 21:24\f*Onye ọbụla nke metụtara Baasha nke nwụrụ nʼime obodo ka nkịta ga-eri ozu ya, ma ndị nwụrụ nʼọhịa ka anụ ufe nke eluigwe ga-eri ozu ha.” 
\p  
\v 5 Akụkọ niile banyere ọrụ Baasha rụrụ, na ibu agha ya niile, e deghị ha nʼakwụkwọ akụkọ ọrụ ndị eze Izrel?  
\v 6 Baasha sooro ndị nna nna ya ha dina nʼọnwụ, e lie ya na Tịaza. Ela, nwa ya nwoke, nọchiri ọnọdụ ya dịka eze. 
\p  
\v 7 Ma ozi \nd Onyenwe anyị\nd* si nʼọnụ Jehu onye amụma, nwa Hanani bịara Baasha na ndị ezinaụlọ ya nʼihi ihe ọjọọ niile o mere, si otu a kpasuo \nd Onyenwe anyị\nd* iwe. Ọ bụ ezie na ọ maara na Onyenwe anyị kpochapụrụ ezinaụlọ Jeroboam nʼihi ihe ọjọọ o mere, ma Baasha gara nʼihu mee ihe ọjọọ. 
\s1 Ela, eze Izrel 
\p  
\v 8 Ela, nwa Baasha, malitere ịbụ eze Izrel nʼiri afọ abụọ na isii nke ịbụ eze Asa, eze Juda. Ma naanị afọ abụọ ka ọ chịrị dịka eze na Tịaza. 
\p  
\v 9 Mgbe ahụ, Zimri, ọchịagha na-achị ọkara ụgbọala agha eze, gbara izuzu megide ya. Nʼoge a, Ela nọ na-aṅụ mmanya na Tịaza, nʼụlọ Aza, onye na-elekọta ụlọeze dị nʼobodo ahụ. Ọ ṅụkwara mmanya ahụ ṅụbiga ya oke.  
\v 10 Zimri batara kụdaa ma gbukwaa ya. Ọ bụ nʼiri afọ abụọ na asaa nke ọchịchị Asa, eze Juda. Ọ bụụrụ eze nʼọnọdụ ya. 
\p  
\v 11 Ngwangwa ọ ghọrọ eze, nọkwasị nʼocheeze ya, o gburu mmadụ niile nọ nʼezinaụlọ Baasha. Ọ hapụghị ọ bụladị otu nwoke. O gburu ikwu na ibe Baasha, na ndị enyi ya niile.  
\v 12 Ya mere, Zimri kpochapụrụ ndị ezinaụlọ niile Baasha, nʼusoro okwu \nd Onyenwe anyị\nd* kwuru megide Baasha site nʼọnụ onye amụma ya bụ Jehu.  
\v 13 Nʼihi mmehie niile nke Baasha na nwa ya Ela mere, na nke ha ji mee ka Izrel mehie, bịakwa kpasuo iwe \nd Onyenwe anyị\nd* bụ Chineke Izrel, site nʼarụsị ha niile na-abaghị uru. 
\p  
\v 14 Akụkọ banyere ọchịchị Ela, na ihe niile o mere e deghị ha nʼakwụkwọ ọchịchị ndị eze Izrel? 
\s1 Zimri, eze Izrel 
\p  
\v 15 Nʼafọ nke iri abụọ na asaa nke ọchịchị Asa, eze Juda, ka Zimri chịrị ụbọchị asaa na Tịaza. Nʼoge a, ndị agha Izrel mara ụlọ ikwu na Gibeton, obodo ndị Filistia na-ebu agha.  
\v 16 Mgbe ha nụrụ na Zimri egbuola eze ha, ha niile kwekọtara mee Omri eze ọhụrụ ha. Omri bụ onyeisi agha ndị agha Izrel niile.  
\v 17 Nʼihi nke a, Omri duuru ndị agha ahụ nọ na Gibeton bịa ibuso Tịaza, isi obodo Izrel agha.  
\v 18 Mgbe Zimri hụrụ na-adọtala obodo ahụ nʼagha, ọ banyere nʼụlọ elu dị nʼụlọeze, sunye onwe ya na ụlọeze ahụ ọkụ. O si otu a nwụọ,  
\v 19 nʼihi na Zimri nʼonwe ya mere ihe ọjọọ nʼanya \nd Onyenwe anyị\nd* dịka Jeroboam. Ọ kpọrọ isiala nye arụsị, dubakwa ụmụ Izrel nʼime mmehie. 
\p  
\v 20 Akụkọ banyere Zimri na ihe ọjọọ niile o mere e deghị ha nʼakwụkwọ akụkọ ọchịchị ndị eze Izrel? 
\s1 Omri, eze Izrel 
\p  
\v 21 Ma nʼoge a, ndị Izrel kere onwe ha ụzọ abụọ maka onye ga-abụ eze ha. Otu ụzọ dịnyeere Omri, ndị nke ọzọ dịnyeere Tibni, nwa Ginat.  
\v 22 Ma ndị dịnyeere Omri dị ike karịa ndị dịnyeere Tibni, nwa Ginat. Ya mere, Tibni nwụrụ. Omri ghọkwara eze Izrel. 
\p  
\v 23 Asa, eze Juda anọọla iri afọ atọ na otu dịka eze mgbe Omri malitere ịbụ eze Izrel. Omri chịrị Izrel afọ iri na abụọ, afọ isii nʼime afọ ndị a na Tịaza.  
\v 24 Omri zụrụ ala ugwu ugwu a na-akpọ Sameria site nʼaka Shema, kwụọ ya talenti ọlaọcha abụọ. O wuru obodo ọhụrụ nʼugwu ahụ gụọ aha ya Sameria, nʼihi na aha onyenwe ala ahụ na mbụ bụ Shema. 
\p  
\v 25 Ma Omri mere ihe ọjọọ nʼanya \nd Onyenwe anyị\nd* karịa ndị eze Izrel niile buru ya ụzọ.  
\v 26 Ọ kpọrọ isiala nye arụsị, dịka Jeroboam nwa Nebat mere. O dubakwara ndị Izrel nʼime mmehie. Nʼihi nke a o mere ka iwe wee \nd Onyenwe anyị\nd*, Chineke Izrel, nʼihi arụsị nzuzu ha. 
\p  
\v 27 Akụkọ ihe niile Omri mere, ọ bụ na e deghị ha nʼakwụkwọ akụkọ ọchịchị ndị eze Izrel?  
\v 28 Omri sooro ndị nna nna ya ha dina nʼọnwụ, e lie ya na Sameria. Ehab, nwa ya ghọrọ eze nʼọnọdụ ya. 
\s1 Ehab, aghọọ eze Izrel 
\p  
\v 29 Nʼafọ nke iri atọ na asatọ nke ọchịchị eze Asa na Juda, ka Ehab, nwa Omri, malitere ịchị dịka eze nʼIzrel. Ọ chịrị ndị Izrel iri afọ abụọ na abụọ na Sameria.  
\v 30 Ehab nwa Omri mere ihe ọjọọ nʼanya \nd Onyenwe anyị\nd* karịa ndị eze niile buru ya ụzọ.  
\v 31 Ọ bụghị naanị na ọ gụrụ mmehie niile Jeroboam nwa Nebat mere dị ka ihe dị nta, kama ọ gara nʼihu lụọ Jezebel, nwa nwanyị Etbaal, eze ndị Saịdọn.\f + \fr 16:31 \ft \xt Dit 7:3; Nkp 18:7\f* O bidokwara ịkpọ isiala nye arụsị Baal, na ife ya ofufe.  
\v 32 O guzobere ebe ịchụ aja nye Baal, nʼụlọ arụsị Baal nke o wuru na Sameria.  
\v 33 Ehab manyere ogidi chi Ashera, si otu a kpasuo \nd Onyenwe anyị\nd* bụ Chineke nke Izrel iwe karịa otu ndị eze Izrel niile bu ya ụzọ chịa si mee. 
\p  
\v 34 Mgbe Ehab na-achị, ka Hiel, onye Betel, wughachiri obodo Jeriko. Ọkpara ya bụ Abiram nwụrụ, mgbe ọ tọrọ ntọala obodo ahụ, ka ọ guzobere ọnụ ụzọ ama ya ọtọ, nwa ya nwoke nke nta aha ya bụ Segub nwụrụ, imezu okwu \nd Onyenwe anyị\nd* kwuru site nʼọnụ Joshua nwa Nun. 
\c 17  
\s1 Ịlaịja ekwuo maka oke ụnwụ nke ga-ada 
\p  
\v 1 Ugbu a, Ịlaịja onye Tishbe, onye si obodo Tishbe, nke dị nʼala Gilead, sịrị Ehab, “Eji m aha \nd Onyenwe anyị\nd* Chineke Izrel dị ndụ, onye m na-efe na onye m na-ejere ozi na-agwa gị na igirigi agaghị ada, mmiri agaghị ezo ọzọ nʼafọ ndị a na-abịa karịa ma ọ bụghị naanị site nʼokwu ọnụ m!” 
\s1 Ugolọma ebutere Ịlaịja nri 
\p  
\v 2 Okwu \nd Onyenwe anyị\nd* rutere Ịlaịja ntị, sị ya,  
\v 3 “Si nʼebe a pụọ. Soro ụzọ ọwụwa anyanwụ, gaa zoo onwe gị nʼakụkụ iyi Kerit, nʼakụkụ ọwụwa anyanwụ ya, nke bụ nʼihu Jọdan.  
\v 4 Nọdụ nʼebe ahụ ṅụọ mmiri si nʼiyi ahụ, riekwa nri ọbụla ụmụ ugolọma ga-ebutere gị, nʼihi na enyela m ha iwu ka ha nye gị nri.” 
\p  
\v 5 O mere ihe \nd Onyenwe anyị\nd* gwara ya ka o mee. Ọ gara nʼakụkụ iyi nta Kerit nʼakụkụ ọwụwa anyanwụ Jọdan nọrọ nʼebe ahụ.  
\v 6 Ugolọma na-ebutere ya achịcha na anụ, ụtụtụ na anyasị niile. Ọ na-aṅụkwa mmiri site nʼiyi ahụ. 
\s1 Ịlaịja na Nwanyị Zarefat 
\p  
\v 7 Ma mgbe ụbọchị ụfọdụ gasịrị, mmiri ahụ tara, nʼihi na mmiri adịghị ezokwa nʼala ahụ.  
\v 8 Okwu \nd Onyenwe anyị\nd* bịakwutere ya,  
\v 9 “Bilie, jee Zarefat, obodo dị Saịdọn nso, biri nʼebe ahụ. O nwere otu nwanyị di ya nwụrụ, onye m nyere iwu ka o nye gị nri.”  
\v 10 Ịlaịja biliri jee Zarefat. Mgbe o ruru ọnụ ụzọ ama e si abanye obodo ahụ, ọ hụrụ otu nwanyị di ya nwụrụ ka ọ nọ na-achịkọta nkụ. Ịlaịja kpọrọ ya oku sị ya, “Biko, kutere m ntakịrị mmiri nʼiko ka m ṅụọ.”  
\v 11 Mgbe nwanyị ahụ na-aga ikute mmiri ahụ, Ịlaịja kpọrọ ya oku ọzọ sị ya, “Biko, wetara m otu iberibe achịcha ka m taa.” 
\p  
\v 12 Ma nwanyị ahụ zara sị ya, “Dịka \nd Onyenwe anyị\nd* Chineke na-adị ndụ, enweghị m achịcha ọbụla nʼụlọ m. Naanị ihe m nwere bụ otu njuaka ụtụ ọka dị nʼite, na mmanụ ntakịrị dị na karama. Ugbu a, ana m achịkọta nkụ ka m baa ga siere onwe m siekwara nwa m nri, ka anyị rie, chere ọnwụ ga-abịa egburu anyị.” 
\p  
\v 13 Ịlaịja sịrị ya, “Atụla egwu! Gaa mee dịka i kwuru. Ma naanị buru ụzọ meere m ogbe achịcha ntakịrị site nʼihe i nwere, wetara m ya. Emesịa, mee nke gị na nwa gị ga-eri.  
\v 14 Nʼihi na nke a bụ ihe \nd Onyenwe anyị\nd*, Chineke Izrel kwuru, ‘Ụtụ ọka dị nʼite ahụ agaghị agwụ, mmanụ ahụ dị nʼite ahụ agakwaghị akọ tutu ruo ụbọchị ahụ \nd Onyenwe anyị\nd* ga-ezite mmiri ozuzo nʼala a.’ ” 
\p  
\v 15 Nwanyị ahụ mere dịka Ịlaịja kwuru. Sitekwa nʼụbọchị ahụ gaa nʼihu, ihe oriri akọkwaghị Ịlaịja na nwanyị ahụ, na ezinaụlọ ya.  
\v 16 Nʼihi na ụtụ ọka ahụ agwụghị, mmanụ akọkwaghị nwanyị ahụ, dịka okwu \nd Onyenwe anyị\nd* kwuru site nʼọnụ Ịlaịja, onye amụma. 
\p  
\v 17 Mgbe ihe ndị a gasịrị, nwa nwanyị ahụ nwe ụlọ rịara ọrịa. Ọrịa a bịara sie ike nke ukwuu na ume afọdụghị nʼime ya.  
\v 18 Mgbe ahụ, nwanyị ahụ kwaara akwa bịakwute Ịlaịja sị ya, “Ewoo, onye nke Chineke, gịnị ka i nwere megide m? Ị bịara ka i chetara m mmehie m, na igbu nwa m nwoke?” 
\p  
\v 19 Ịlaịja zara sị ya, “Kunye m nwa gị nwoke.” Ịlaịja kuuru ya site nʼaka nne ya rigoo nʼụlọ elu ebe ya onwe ya na-edina,\f + \fr 17:19 \ft Ọnụụlọ a, bụ ebe e debere maka ndị ọbịa nakwa ichekwa ihe oriri.\f* nibe ya nʼelu ihe ndina ya.  
\v 20 Ọ kpọkuru \nd Onyenwe anyị\nd* sị ya, “\nd Onyenwe anyị\nd* Chineke m, gịnị mere i ji wetara nwanyị a m bi nʼụlọ ya ihe mgbu site nʼikwe ka nwa nwoke ya nwụọ?”  
\v 21 Ịlaịja gbatịrị onwe ya nʼahụ nwantakịrị ahụ ugboro atọ, kpọkuo \nd Onyenwe anyị\nd*, sị, “Biko, \nd Onyenwe anyị\nd* Chineke m, kwere ka mkpụrụobi nwantakịrị a laghachikwute ya.” 
\p  
\v 22 \nd Onyenwe anyị\nd* nụrụ ekpere Ịlaịja, ndụ nwantakịrị ahụ laghachikwutere ya, ọ dịkwara ndụ ọzọ.  
\v 23 Mgbe ahụ, Ịlaịja kuuru ya si nʼụlọ elu ahụ rịdata, kunye ya nne ya, gwa ya okwu sị, “Lee, nwa gị dị ndụ!” 
\p  
\v 24 Nwanyị ahụ sịrị Ịlaịja, “Ugbu a, amatala m na ị bụ onye nke chineke, na okwu \nd Onyenwe anyị\nd* si nʼọnụ gị apụta bụ eziokwu.” 
\c 18  
\s1 Ịlaịja na Ọbadaya 
\p  
\v 1 Mgbe ọtụtụ oge gasịrị, nʼafọ nke atọ, okwu \nd Onyenwe anyị\nd* rutere Ịlaịja ntị, “Bilie, gaa gosi Ehab onwe gị. Aga m emekwa ka mmiri zookwa nʼala a.”  
\v 2 Ya mere, Ịlaịja pụrụ gaa igosi Ehab onwe ya. 
\p Ma ụnwụ dị na Sameria nʼoge a siri nnọọ ike.  
\v 3 O nwere otu nwoke na-elekọta ihe dị nʼezinaụlọ Ehab. Aha ya bụ Ọbadaya. (Ọ bụ nwoke ji obi ya niile kwere na \nd Onyenwe anyị\nd*.  
\v 4 Mgbe eze nwanyị bụ Jezebel na-egbu ndị amụma \nd Onyenwe anyị\nd* chọọ igbuchapụ ha, ọ bụ Ọbadaya zoro narị ndị amụma nʼime ha nʼime ọgba nkume. O zoro iri ndị amụma ise nʼotu ọgba nkume, zookwa iri ndị amụma ise fọdụrụ nʼime ọgba nkume ọzọ. Emesịa, ọ na-ewegara ha nri na mmiri nʼebe ahụ.)  
\v 5 Ehab kpọrọ Ọbadaya sị ya, “Jegharịa nʼala a niile nyochapụta na ndagwurugwu na isi iyi niile, ebe ahịhịa ndụ dị. Gbutere ịnyịnya na ịnyịnya muul m ahịhịa ahụ ka ha taa ghara ịnwụ, ka anyị gharakwa igbu ha.”  
\v 6 Ha kere ala ahụ nʼetiti onwe ha. Ehab sitere otu akụkụ, ma Ọbadaya sitere akụkụ nke ọzọ. 
\p  
\v 7 Ọ dịghị anya, na mberede, Ọbadaya hụrụ Ịlaịja ka ọ na-abịa izute ya. Ọbadaya matara na ọ bụ ya. Nʼihi ya, ọ dara nʼala kpuo ihu ya nʼala sị, “Ọ bụ gị ka m hụrụ nʼezie, onyenwe m, Ịlaịja?” 
\p  
\v 8 Ịlaịja zara sị ya, “E, ọ bụ m. Ugbu a gaa gwa onyenwe gị, ‘mụ bụ Ịlaịja nọ nʼebe a.’ ” 
\p  
\v 9 Mgbe ahụ, Ọbadaya jụrụ Ịlaịja sị, “Gịnị bụ ihe m mejọrọ, nke mere i ji na-achọ inyefe ohu gị nʼaka Ehab ka o gbuo ya?  
\v 10 Dịka \nd Onyenwe anyị\nd* Chineke gị sị adị ndụ, o nwebeghị mba maọbụ alaeze dị nke nna m ukwu na-ezigaghị mmadụ ịchọ gị. Ebe ọbụla ọ gara a na-akọrọ ya na Ịlaịja anọghị nʼebe ahụ. Ehab na-eme ka eze obodo ahụ ṅụọ iyi na ihe ọ na-ekwu bụ eziokwu.  
\v 11 Ma ugbu a, ị na-asị m gaa gwa Onyenwe m na, ‘Ịlaịja nọ nʼebe a.’  
\v 12 Ọ bụrụkwanụ na m esite nʼebe a pụọ, onye ma ebe Mmụọ \nd Onyenwe anyị\nd* ga-ebuga gị. Mgbe ahụ, ọ bụrụ na Ehab abịa hapụ ịhụ gị, ọ ga-egbu m. Nʼihi na mụ bụ ohu gị bụ onye na-efe \nd Onyenwe anyị\nd* ofufe siterị na mgbe m bụ okorobịa.  
\v 13 Ọ bụ na onyenwe m anụghị ihe m mere mgbe Jezebel nọ na-egbu ndị amụma \nd Onyenwe anyị\nd*? E zoro narị ndị amụma \nd Onyenwe anyị\nd* nʼime ọgba nkume abụọ, iri ise nʼime otu ọgba nkume, iri ise nʼime otu ọgba nkume ka m zoro ha, jirikwa nri na mmiri ọṅụṅụ zụọ ha.  
\v 14 Ma ugbu a i na-agwa m sị m, ‘Gaa gwa onyenwe gị na Ịlaịja abịala.’ Ọ ga-egbukwa m!” 
\p  
\v 15 Ma Ịlaịja zara sị ya, “Dịka \nd Onyenwe anyị\nd* Chineke Onye pụrụ ime ihe niile na-adị ndụ, onye m na-ejere ozi, ana m agwa gị na agaghị m esi nʼebe a pụọ tutu ruo mgbe m gosiri Ehab onwe m taa.” 
\s1 Ịlaịja nʼugwu Kamel 
\p  
\v 16 Mgbe ahụ, Ọbadaya pụrụ gaa kọọrọ Ehab na Ịlaịja abịala. Emesịa, Ehab pụtara izute Ịlaịja.  
\v 17 Mgbe ọ hụrụ Ịlaịja, Ehab sịrị ya, “Ọ bụ gị onwe gị bụ nke a, gị onye na-emekpa Izrel ahụ?” 
\p  
\v 18 Ịlaịja zara sị Ehab, “O nweghị mgbe m ji butere Izrel nsogbu. Ọ bụ gị onwe gị na ezinaụlọ nna gị na-ebutere Izrel nsogbu. Unu agbakụtala iwu \nd Onyenwe anyị\nd* azụ, gbasoro chi Baal dị iche iche.\f + \fr 18:18 \ft \xt 1Ez 16:30-33\f* 
\v 19 Ugbu a, kpọkọta ndị Izrel niile ka ha zute m nʼugwu Kamel. Kpọpụtakwa ndị amụma Baal ọnụọgụgụ ha dị narị anọ na iri mmadụ ise, na ndị amụma Ashera, ndị dị narị anọ, bụ ndị na-eso eze nwanyị Jezebel erikọ ihe na tebul ya.” 
\p  
\v 20 Ehab zigara ozi kpọkọta ndị Izrel niile, na ndị amụma ahụ niile. Ha niile bịakwara nʼugwu Kamel.  
\v 21 Ịlaịja gara nʼihu ndị a, sị ha, “Ọ bụ ruo ole mgbe ka unu ga-akwụsị inwe obi abụọ? Ọ bụrụ na \nd Onyenwe anyị\nd* bụ Chineke unu, soronụ ya! Ma ọ bụrụkwanụ na unu ekpebie na Baal bụ chi unu, soronụ ya.” 
\p Ma ndị zukọrọ nʼebe ahụ ekwughị ihe ọbụla. 
\p  
\v 22 Mgbe ahụ Ịlaịja sịrị ha, “Leenụ! Ọ bụ mụ onwe m, naanị m, bụ onye amụma \nd Onyenwe anyị\nd* fọdụrụ, ma ndị amụma Baal dị narị anọ na iri ise nʼọnụọgụgụ.  
\v 23 Ugbu a wetanụ oke ehi abụọ ka ndị amụma Baal họrọ otu oke ehi, nke ha chọrọ. Ha ga-egbujasị ya, tụkwasị ya nʼelu nkụ dị nʼebe ịchụ aja, ma ha agaghị amụnye ọkụ ọbụla nʼokpuru ya. Mụ onwe m ga-akwado oke ehi nke ọzọ tụkwasị ya nʼelu nkụ ma agaghị m amụnyekwa ọkụ nʼokpuru ya.  
\v 24 Emesịa, unu ga-akpọku chi Baal\f + \fr 18:24 \ft Baal, bụ chi egbe eluigwe, nke ọtụtụ ndị Siria na ndị Kenan na-efe.\f* unu, mụ onwe m kwa ga-akpọku aha \nd Onyenwe anyị\nd*. Ọ ga-erukwa na chi ga-eji ọkụ za, chi ahụ bụ Chineke.” 
\p Ndị Izrel niile zara sị, “Okwu gị dị mma.” 
\p  
\v 25 Ịlaịja gwara ndị amụma Baal, sị, “Ebe unu dị ọtụtụ, burunu ụzọ họrọ otu oke ehi nʼime ehi abụọ a dozie ya. Unu amụnyekwala ya ọkụ nʼokpuru, kama kpọkuonụ chi unu.”  
\v 26 Ya mere, ndị amụma Baal weere oke ehi ahụ e nyere ha doziekwa ya. 
\p Mgbe ahụ, ha kpọkuru aha Baal, chi ha. Site nʼụtụtụ tigide mkpu ruo nʼetiti ehihie na-asị “O Baal, biko, zaa anyị.” Ma o nweghị ihe ha nụrụ site nʼọnụ Baal. Ọ dịkwaghị onye zara ha. Ha malitere ite egwu gburugburu ebe ịchụ aja ahụ ha kwadoro. 
\p  
\v 27 Nʼihe dị ka nʼetiti ehihie, Ịlaịja malitere ịchị ha ọchị, na ịkwa ha emo. Ọ gwara ha okwu sị ha, “Tisienụ mkpu ike ka Baal nwe ike ịnụ arịrịọ unu. Nʼezie, ọ bụ chi! Ma eleghị anya ọ nọ nʼoke echiche, maọbụ o ji ọrụ nʼaka, maọbụ ọ gara njem. Ma eleghị anya ọ na-arahụ ụra. Ọ chọrọ onye ga-akpọte ya.”  
\v 28 Ndị amụma a tiri mkpu nʼoke olu dịka ha si eme. Ha ji mma na ùbe na-egbukasị onwe ha ahụ, tutu ruo mgbe ọbara malitere isite ha nʼahụ na-agbapụta.  
\v 29 Ma mgbe etiti ehihie gasịrị, ha nọgidekwara na-ebu amụma ruo mgbe oge ịchụ aja uhuruchi ruru, ma o nweghị onye zara ha, o nwekwaghị olu a nụrụ. Ọ dịkwaghị onye ṅara ha ntị. 
\p  
\v 30 Mgbe ahụ, Ịlaịja kpọrọ ndị Izrel sị ha, “Bịaruenụ m nso.” Ha niile bịaruru ya nso, o doziri ebe ịchụ aja \nd Onyenwe anyị\nd*, bụ ndị ahụ a kwaturu nʼala na mbụ.  
\v 31 Ịlaịja chịịrị nkume iri na abụọ, nke otu nʼime ha nọchiri anya otu ebo Jekọb, onye okwu \nd Onyenwe anyị\nd* rutere si ya, “Aha gị ga-abụ Izrel.”  
\v 32 O ji nkume ndị a wuzie ebe ịchụ aja \nd Onyenwe anyị\nd*. Emesịa, o gwuru olulu miri emi, nke gbara ebe ịchụ aja ahụ gburugburu.  
\v 33 Ọ tụkwasịrị nkụ nʼelu ebe ịchụ aja ahụ, tụkwasịkwa otu oke ehi o gbujasịrị nʼelu nkụ ndị ahụ. Emesịa, o nyere ndị nọ nʼebe ahụ iwu sị ha, “Gbajuonụ ite anọ mmiri. Butekwanụ mmiri ahụ bịa wụkwasị ya nʼelu aja nsure ọkụ a, na nʼelu nkụ ndị a.” Mgbe ha mesiri nke a, Ịlaịja gwara ha okwu sị, 
\p  
\v 34 “Gbajukwaanụ ite mmiri ndị ahụ, bute ha bịa wụkwasị mmiri ahụ nke ugboro abụọ nʼelu aja nsure ọkụ a.” Ha mere dịka Ịlaịja kwuru. 
\p Ịlaịja nyekwara ha iwu sị, “Gbajukwaanụ ya nke ugboro atọ, bịa wụkwasị ya.” Ha mekwara otu a.  
\v 35 Mmiri jupụtakwara nʼebe ịchụ aja ahụ, na olulu ahụ dị ya gburugburu. 
\p  
\v 36 Mgbe oge e ji achụ aja anyasị ruru, Ịlaịja, onye amụma bịara ebe ịchụ aja ahụ nso kpee ekpere sị, “O, \nd Onyenwe anyị\nd* Chineke Ebraham, na Aịzik, na Izrel, biko gosi taa na ọ bụ gị onwe gị bụ naanị Chineke nʼIzrel, na mụ onwe m bụkwa ohu gị. Gosikwa na m bụ onyeozi gị, na ọ bụ ihe i nyere m nʼiwu ka m mere oge ndị a niile.  
\v 37 Biko, \nd Onyenwe anyị\nd* m, zaa m ekpere m, zaa m ya, ka ndị Izrel niile mata na gị onwe gị, \nd Onyenwe anyị\nd* bụ Chineke, na gị onwe gị na-atụgharịkwa obi ha ịlaghachikwute gị.” 
\p  
\v 38 Mgbe ahụ, na mberede, ọkụ \nd Onyenwe anyị\nd* sitere nʼeluigwe daa, rechapụ oke ehi ahụ, na nkụ ahụ, na nkume, na ntụ, ma rechapụkwa mmiri niile dị nʼime olulu ahụ dị gburugburu ebe ịchụ aja ahụ. 
\p  
\v 39 Mgbe ndị mmadụ ahụ niile hụrụ ihe a mere, ha niile dara nʼala kpuo ihu nʼala, na-eti mkpu na-asị, “\nd Onyenwe anyị\nd*, ya onwe ya bụ Chineke! \nd Onyenwe anyị\nd* ya onwe ya bụ Chineke!” 
\p  
\v 40 Mgbe ahụ, Ịlaịja nyere ha iwu sị, “Jidenụ ndị amụma Baal niile. Unu ekwekwala ka otu onye nʼime ha laa.” Ha jidekwara ha niile. Ịlaịja dukwaara ha niile gaa na ndagwurugwu iyi Kishọn, gbuo ha nʼebe ahụ. 
\p  
\v 41 Emesịa, Ịlaịja gwara Ehab okwu sị, “Gaa rie nri, ṅụọkwa ihe ọṅụṅụ; nʼihi na anụrụ m ụzụ oke mmiri ozuzo ka ọ na-ada.”  
\v 42 Nʼihi nke a, Ehab sitere nʼebe ahụ pụọ gaa iri nri na ịṅụ ihe ọṅụṅụ ma Ịlaịja rigooro nʼelu ugwu Kamel gbuo ikpere nʼala, kpuokwa ihu ya nʼala nʼetiti ikpere ya abụọ ikpe ekpere. 
\p  
\v 43 Nʼoge a, ọ gwara nwokorobịa na-ejere ya ozi sị ya, “Gaa lee anya nʼụzọ oke osimiri.” Ọ rịgoro lee anya, sị, 
\p “Ọ dịghị ihe ọbụla m hụrụ.” 
\p Ịlaịja gwakwara ya otu a, ugboro asaa, sị ya, “Jeghachi.” 
\p  
\v 44 O ruo na nke ugboro asaa, nwokorobịa ahụ bịaghachiri sị Ịlaịja, “Onyenwe m, ahụrụ m igwe ojii dị nta dịka ọbụ aka mmadụ ka o si nʼoke osimiri na-apụta.” 
\p Ya mere, Ịlaịja sịrị, “Gaa gwa Ehab, ‘dozie ụgbọ agha gị, gbadaa tupu mmiri ozuzo egbochi gị ịla.’ ” 
\p  
\v 45 Ọ dịghị anya, eluigwe gbajikọtara nnọọ oji. Oke ifufe bidokwara ife. Mmiri dị ukwuu bidokwara izo. Mgbe ahụ, Ehab gbaara ụgbọ agha ya laa Jezril.  
\v 46 Ma ike \nd Onyenwe anyị\nd* bịakwasịrị Ịlaịja. Ọ fanyere ọnụ uwe mwụda ya na belịt o kere nʼukwu, gbapụ ọsọ buru Ehab ụzọ gbaruo obodo Jezril. 
\c 19  
\s1 Ịlaịja agbaga nʼugwu Horeb 
\p  
\v 1 Ehab kọọrọ Jezebel ihe niile Ịlaịja mere, na otu o si jiri mma agha gbuo ndị amụma Baal niile.  
\v 2 Nʼihi nke a, Jezebel zigara onyeozi ka ọ ga zie Ịlaịja sị, “Ka chi ndị a mesoo m mmeso, nʼagbanyeghị otu mmeso ahụ si dị njọ, ma ọ bụrụ na oge dịka oge a echi, egbughị gị dịka i si gbuo ndị amụma Baal.” 
\p  
\v 3 Ịlaịja tụrụ egwu, gbapụ ọsọ, nʼihi ichebe ndụ ya. Mgbe ọ bịaruru Bịasheba, dị na Juda, ọ hapụrụ nwokorobịa na-ejere ya ozi nʼebe ahụ.  
\v 4 Ma ya onwe ya pụkwara jee ije otu ụbọchị nʼọzara naanị ya. Nʼikpeazụ, ọ kwụsịrị nọdụ ala nʼokpuru otu osisi brum, kpee ekpere rịọọ ka a napụ ya ndụ ya. Ekpere o kpere nʼoge a bụ, “O zuorela m \nd Onyenwe anyị\nd*, biko napụ ndụ m. O nweghị ụzọ m si dị mma karịa nna nna m ha.”  
\v 5 O dinara nʼokpuru osisi brum rahụ ụra. 
\p Ma lee, otu oge ahụ, mmụọ ozi metụrụ ya aka, sị ya, “Bilie, rie nri.”  
\v 6 Ịlaịja biliri legharịa anya, hụ ogbe achịcha na ite mmiri nta nke dị nʼakụkụ ebe ọ tụkwasịrị isi ya. O riri ogbe achịcha ahụ a hụrụ nʼicheku ọkụ, ṅụọkwa mmiri ahụ. Emesịa, o dinakwara ọzọ. 
\p  
\v 7 Mmụọ ozi nke \nd Onyenwe anyị\nd* bịaghachikwara nke ugboro abụọ, sị ya, “Bilie rie ihe, nʼihi na ije dị gị nʼihu dị ukwuu.”  
\v 8 Ịlaịja biliri rie ihe, ṅụọkwa mmiri. Nri ahụ nyere ya ike ije ije iri ụbọchị anọ ọzọ, ehihie na abalị, tutu ruo mgbe ọ bịaruru nʼugwu Horeb\f + \fr 19:8 \fq Ugwu Horeb \ft Maọbụ, \fqa Saịnaị, \ft ọ bụ nʼebe a ka Chineke mere ka Mosis hụ ya anya. \xt Ọpụ 3:1; 4:27; 31:18; 32:17\f* nke bụ ugwu Chineke.  
\v 9 Nʼebe ahụ, ọ banyere nʼotu ọgba nkume rahụ ụra abalị nʼime ya. 
\s1 \nd Onyenwe anyị\nd* apụta ìhè nye Ịlaịja 
\p Ma okwu \nd Onyenwe anyị\nd* rutere ya sị, “Ịlaịja, gịnị ka ị na-eme nʼebe a?” 
\p  
\v 10 Ọ zaghachiri sị, “Eji m ịnụ ọkụ nʼobi na-ejere \nd Onyenwe anyị\nd* Chineke Onye pụrụ ime ihe niile ozi. Ndị Izrel ajụla ọgbụgba ndụ gị, tidasịakwa ebe ịchụ aja gị, were mma agha gbukwaa ndị amụma gị niile, ugbu a, ọ bụ naanị mụ onwe m bụ onye fọdụrụ, ma ha na-achọkwa iwepụ ndụ m.” 
\p  
\v 11 \nd Onyenwe anyị\nd* sịrị ya, “Pụọ gaa guzo nʼelu ugwu, nʼihu \nd Onyenwe anyị\nd*, nʼihi na \nd Onyenwe anyị\nd* na-aga isite nʼebe ahụ gafee.” 
\p Mgbe ahụ, oke ifufe dị ike gbawara ugwu ahụ, tipịasịa nkume ndị ahụ nʼihu \nd Onyenwe anyị\nd*, ma \nd Onyenwe anyị\nd* anọghị nʼime ifufe ahụ. Mgbe ifufe ahụ gasịrị, e nwere oke ala ọma jijiji nʼugwu ahụ, ma \nd Onyenwe anyị\nd* anọkwaghị nʼala ọma jijiji ahụ.  
\v 12 Mgbe ala ọma jijiji ahụ gasịrị, ọkụ nwuuru, ma \nd Onyenwe anyị\nd* anọghị nʼime ọkụ ahụ. Ma mgbe ọkụ ahụ gasịrị, nwa olu nta dị nwayọọ dara.  
\v 13 Mgbe Ịlaịja nụrụ ya, o ji uwe mwụda ya kpuchie ihu\f + \fr 19:13 \ft Ịlaịja kpuchiri ihu ya, nʼihi na o nweghị onye ọbụla ga-adị ndụ, ma ọ hụ ihu Chineke. \xt Ọpụ 3:6; Aịz 6:2\f* ya, pụọ gaa guzo nʼọnụ ụzọ ọgba nkume ahụ. 
\p Mgbe ahụ, ọ nụrụ olu jụrụ ya sị, “Ịlaịja, gịnị ka ị na-eme nʼebe a?” 
\p  
\v 14 Ọ zaghachiri sị, “Eji m ịnụ ọkụ nʼobi na-ejere \nd Onyenwe anyị\nd* Chineke Onye pụrụ ime ihe niile ozi. Ndị Izrel ajụla ọgbụgba ndụ gị, tidasịakwa ebe ịchụ aja gị, were mma agha gbukwaa ndị amụma gị niile, ugbu a ọ bụ naanị mụ onwe m bụ onye fọdụrụ, ma ha na-achọkwa iwepụ ndụ m.” 
\p  
\v 15 \nd Onyenwe anyị\nd* sịrị ya, “Sikwa ụzọ i si bịa laghachi, gaa nʼọzara Damaskọs. Mgbe i ruru ebe ahụ, tee Hazael mmanụ ịbụ eze Aram.  
\v 16 Teekwa Jehu, nwa Nimshi mmanụ ịbụ eze Izrel. Ị ga-etekwa Ịlaisha nwa Shafat, onye Ebel-Mehola mmanụ ịbụ onye amụma nʼọnọdụ gị.  
\v 17 Onye ọbụla gbanarịrị Hazael ga-anwụ nʼaka Jehu. Otu a kwa, ndị niile gbanarịrị mma agha Jehu ka Ịlaisha ga-egbu.  
\v 18 Ma ghọta na ọ dị puku mmadụ asaa nọ nʼIzrel, ndị na-egbubeghị ikpere ha nʼala nye Baal, maọbụ sutu ya ọnụ, ife ya ofufe.” 
\s1 Ọkpụkpọ Ịlaisha 
\p  
\v 19 Ịlaịja sitere nʼebe ahụ pụọ gaa chọta Ịlaisha nwa Shafat ebe ọ nọ na-akọ ala ubi. Iri ehi abụọ na anọ e jikọtara abụọ abụọ dị ya nʼihu, ma ya onwe ya ji ehi abụọ e jikọtara ọnụ, nke iri na abụọ ya na-akọ ala ubi. Ịlaịja jekwuru Ịlaisha wụkwasị ya uwe mwụda ya nʼubu ya.  
\v 20 Mgbe ahụ, Ịlaisha hapụrụ ehi ndị ahụ ebe ha guzoro nʼubi ahụ gbara ọsọ gbakwuru Ịlaịja sị ya, “Biko, kwere ka m gaa sutu nna m na nne m ọnụ, sị ha nọdụ nke ọma. Emesịa, aga m esokwa gị.” 
\p Ịlaịja zara sị ya, “Laghachi azụ, ọ bụ gịnị ka m mere gị?” 
\p  
\v 21 Ịlaisha laghachiri azụ, gbuo ehi abụọ ahụ e jikọtara nʼotu, kpọọ ihe ahụ e ji arụ ọrụ nʼubi ọkụ, were ha sie anụ ahụ nye ndị mmadụ, ha rie. Mgbe ahụ, o biliri ije pụọ ga soro Ịlaịja, bụrụ nwaodibo ya. 
\c 20  
\s1 Ben-Hadad ebuso Sameria agha 
\p  
\v 1 Ugbu a, Ben-Hadad, bụ eze ndị Aram, chịkọtara ndị agha ya niile. Iri ndị eze atọ na abụọ sonyere ya, ha na ịnyịnya ha na ụgbọ agha ha. Ọ rịgooro nọchibido obodo Sameria buso ya agha.  
\v 2 Mgbe ahụ, eze ndị Siria zigaara Ehab, eze Izrel ozi nʼime obodo sị ya, “otu a ka Ben-Hadad sịrị,  
\v 3 ‘Ọlaọcha na ọlaedo gị, nkem ka ha bụ, ndị nwunye gị na ụmụ gị, bụ ndị dị mma karịsịa nke m ka ha bụ.’ ” 
\p  
\v 4 Ehab eze Izrel, zighachiri ozi sị, “Ọ dị mma, onyenwe m, mụ onwe m, na ihe niile m nwere bụ nke gị.” 
\p  
\v 5 Ngwangwa ndị ozi Ben-Hadad bịaghachiri zie Ehab ozi ọzọ sị ya, “Otu a ka Ben-Hadad sịrị, ‘Ọ bụ ezie na m ziteere gị ozi, sị, ọlaọcha gị na ọlaedo gị na ndị nwunye gị na ụmụ gị ka ị ga-enye m.  
\v 6 Ma ugbu a, nʼoge dị ka nke a, echi, aga m ezite ndị ozi m ka ha bịa nyochaa ụlọ gị niile na ụlọ ndị ozi gị niile. Ihe ọbụla dị oke ọnụahịa nʼanya gị ka ha ga-ewere.’ ” 
\p  
\v 7 Eze Izrel kpọrọ ndị okenye niile nke ala ahụ, sị ha, “Leenụ ugbu a, hụkwanụ otu nwoke a si achọ nsogbu. Mgbe o zitere m ozi inye ya ndị nwunye m, na ụmụ, na ọlaọcha m na ọlaedo m, ekwenyere m ya inye ya ihe ndị a.” 
\p  
\v 8 Ndị okenye na ndị Izrel zara sị ya, “Aṅala ya ntị! Enyela ya ihe ọbụla.” 
\p  
\v 9 Mgbe ahụ, ọ sịrị ndị ozi Ben-Hadad, “Gwanụ onyenwe m, bụ eze, ‘M bụ odibo gị jikeere ime ihe niile ị buru ụzọ kwuo na m ga-enye gị. Ma ekwenyeghị m nʼozi nke ugboro abụọ a.’ ” Ndị ozi ahụ laghachiri kọọrọ Ben-Hadad ihe niile Ehab kwuru. 
\p  
\v 10 Ma Ben-Hadad zigakwaara Ehab ozi ọzọ sị, “Ka chi ndị a mesoo m mmeso,\f + \fr 20:10 \ft \xt 1Ez 19:2; 2Ez 6:31\f* otu ọbụla mmeso ahụ si dị njọ, ma ọ bụrụ na aja Sameria ga-afọdụ inye onye ọbụla nʼetiti ndị ikom m otu njuaka.” 
\p  
\v 11 Ma eze Izrel zaghachiri, “Gwa ya, ‘Onye na-ebu agha na-anya isi naanị mgbe a lụchara agha, ọ bụghị tupu a lụọ agha.’ ” 
\p  
\v 12 Ben-Hadad nụrụ ozi Ehab ziri mgbe ya na ndị eze ndị ọzọ ahụ nọ na-aṅụ mmanya nʼụlọ ikwu ha manyere nʼọgbọ agha ahụ. Ben-Hadad nyere ndị agha ya iwu sị ha, “Jikerenụ, buso ndị Izrel agha.” Ya mere, ha kwadoro ibuso obodo ahụ agha. 
\s1 Ehab emerie Ben-Hadad 
\p  
\v 13 Nʼoge a, otu onye amụma bịakwutere Ehab, bụ eze Izrel sị, “Otu a ka \nd Onyenwe anyị\nd* sịrị, ‘Ị hụrụ oke igwe ndị agha a? Aga m enyefe ha nʼaka gị taa, mgbe ahụ ị ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*.’ ”\f + \fr 20:13 \ft \xt 1Ez 20:28\f* 
\p  
\v 14 Ma Ehab jụrụ sị, “Onye ga-eme nke a?” 
\p Onye amụma zara, “Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, ‘Ọ bụ ụmụ okorobịa bụ ndịisi agha nọ nʼokpuru ndị ọchịagha na-achị akụkụ ala Izrel.’ ” 
\p Ehab jụkwara ọzọ, “Onye ga-amalite agha a?” 
\p Onye amụma ahụ zara, “Gị onwe gị.” 
\p  
\v 15 Mgbe ahụ, Ehab kpọkọtara ụmụ okorobịa bụ ndịisi agha si nʼakụkụ obodo ya. Ọnụọgụgụ ha dị narị abụọ na iri atọ na mmadụ abụọ. Ọnụọgụgụ ndị agha Izrel ndị ọzọ dị puku asaa.  
\v 16 Nʼetiti ehihie, mgbe Ben-Hadad na iri ndị eze atọ na abụọ ahụ, bụ ndị ahụ bịara inyere ya aka nọ na-aṅụ mmanya, na-aṅụbiga ya oke,  
\v 17 ụmụ okorobịa, bụ ndị agha, ndị nọ nʼokpuru ndị ọchịagha na-achị akụkụ ala Izrel buru ụzọ pụọ ibu agha. 
\p Ma Ben-Hadad, nʼonwe ya ezipụlarị ndị nledo, ndị lọghachiri bịa gwa ya sị, “Ndị agha si Sameria na-abịa.” 
\p  
\v 18 Ọ sịrị, “Ọ bụrụ na ha abịa nʼihi udo, jidenụ ha na ndụ; ọ bụrụ na ha bịara maka ibu agha, jidenụ ha na ndụ!” 
\p  
\v 19 Ma ụmụ okorobịa ndị ọchịchị a bụ ndị nọ nʼokpuru ndịisi, na-achị akụkụ ala ahụ sitere nʼobodo zọlie ije ebe ndị agha so ha nʼazụ, pụọ ibu agha.  
\v 20 Onye ọbụla nʼime ha gburu onye agha Siria ọbụla lụsoro ya ọgụ. Nke a mere ka ndị agha Siria gbapụ ọsọ, ndị agha Izrel chụsokwara ha. Ma Ben-Hadad, eze Aram, na ndị agha na-agba ịnyịnya, sitekwara nʼihu ọgbọ agha ahụ gbapụkwa ọsọ.  
\v 21 Ma eze ndị Izrel pụkwuru ya, nwude ọtụtụ ịnyịnya na ụgbọ agha, butere ndị Aram ọghọm dị ukwuu. 
\p  
\v 22 Emesịa, onye amụma ahụ bịakwutere eze Izrel sị ya, “Mee onwe gị ka ị dị ike nke ọma, mara ihe e kwesiri ka e mee, nʼihi nʼetiti ọkọchị na udu mmiri nke afọ nʼabịa, eze Aram ga-abịa ibuso gị agha ọzọ.” 
\p  
\v 23 Ma otu ọ dị, ndịisi agha eze ndị Aram dụrụ ya ọdụ sị, “Chi ha bụ chi ugwu. Nʼihi ya ka ha ji dị ike karịa anyị. Ma ọ bụrụ na anyị ebuso ha agha nʼobosara ala dị larịị, anyị aghaghị ịdị ike karịa ha.  
\v 24 Mee ihe a, wepụ ndị eze a niile site nʼebe ha nọ, jiri ndị na-achị ala gbanwee ha.  
\v 25 Kpọkọtaakwa ndị agha ọzọ, ndị dị ukwuu nʼọnụọgụgụ, dịka ndị agha i du gaa agha na mbụ. Nyekwa anyị ịnyịnya na ụgbọ agha ga-ezuru anyị. Anyị ga-apụkwa buso ndị Izrel agha nʼobosara ala dị larịị. Ọ dịkwaghị ihe ga-egbochi anyị imeri ha nʼoge a.” Ben-Hadad, eze Aram, kwenyere, meere ha dịka ha rịọrọ ya. 
\p  
\v 26 Mgbe otu afọ gasịrị, Ben-Hadad chịkọtakwara ndị Aram niile duru ha gaa Afek ibuso Izrel agha.  
\v 27 Mgbe a kpọkọtara ndị agha niile nọ nʼIzrel nye ha ngwa agha, ha pụrụ izute ha. Ndị agha Izrel mara ụlọ ikwu ha na ncherita ihu ndị agha Siria, dịka igwe ewu nta abụọ, ebe ndị Aram jupụtara ala ahụ niile. 
\p  
\v 28 Onye nke Chineke bịara gwa eze ndị Izrel, “Otu a ka \nd Onyenwe anyị\nd* sịrị, ‘Nʼihi na ndị Aram na-eche na \nd Onyenwe anyị\nd* bụ chi nke ugwu, na ọ bụghị chi ala ndagwurugwu, aga m arara igwe ndị agha a nyefee gị nʼaka, ka gị na ndị gị mata nʼeziokwu na m bụ \nd Onyenwe anyị\nd*.’ ” 
\p  
\v 29 Ọ bụ ụbọchị asaa ka ha mara ụlọ ikwu ha na ncherita ihu ibe ha. Ma nʼụbọchị nke asaa ahụ, ndị agha malitere ibu agha. Ndị Izrel merụrụ narị puku ndị agha Aram ahụ nʼotu ụbọchị.  
\v 30 Ma ndị fọdụrụ nʼetiti ndị agha Aram gbapụrụ ọsọ gbalaga nʼobodo Afek. Ebe ahụ ka mgbidi obodo Afek nọ dagbuo iri puku ndị agha abụọ na asaa nʼime ha. Ma Ben-Hadad nʼonwe ya gbalagara, gbaba nʼime obodo ahụ, gaa zoo onwe ya nʼime ime otu ụlọ. 
\p  
\v 31 Mgbe ahụ, ndịisi agha ya bịakwutere ya sị ya, “Lee, anyị nụrụ na ndị eze Izrel bụ ndị obi ebere. Ka anyị yiri akwa mkpe nʼukwu anyị, kee ụdọ nʼolu anyị, gaa rịọọ eze Izrel. Ma eleghị anya ọ ga-edebe gị ndụ.” 
\p  
\v 32 Ya mere, ha yikwasịrị onwe ha akwa mkpe, nyarakwa ụdọ nʼolu ha, jekwuru eze Izrel sị ya, “Ohu gị bụ Ben-Hadad na-asị, ‘Biko, kwee ka m dịrị ndụ.’ ” 
\p Eze jụrụ ha sị, “Ọ bụ ezie na ọ ka dị ndụ ugbu a? Nwanne m ka ọ bụ.” 
\p  
\v 33 Okwu a mere ka ndị ozi eze Aram nwee olileanya. Ha mere ngwangwa kwugharịakwa ihe ahụ o kwuru. Ha sịrị, “E, Nwanne gị bụ Ben-Hadad.” 
\p Mgbe ahụ, eze Ehab nyere ha iwu sị, “Gaanụ kpọpụta ya, dutekwanụ ya nʼebe a.” Mgbe Ben-Hadad bịara, Ehab mere ka ọ rigota nʼụgbọ agha nke ya. 
\p  
\v 34 Mgbe ahụ, Ben-Hadad gwara Ehab sị, “Obodo niile nke nna m naara nna gị, ka m ga-enyeghachi gị. I nwere ike iwuru onwe gị ọdụ ahịa nʼama obodo Damaskọs dịka nna m wuru nʼime Sameria.” 
\p Ehab kwuru, “Ọ bụrụ na anyị agbaa ndụ, aga m eme ka i nwere onwe gị.” Ya mere, ha abụọ gbara ndụ. Ehab hapụkwara ya ka ọ laa nʼudo. 
\s1 Onye amụma amaa Ehab ikpe 
\p  
\v 35 Emesịa, okwu \nd Onyenwe anyị\nd* rutere otu onye nʼetiti ụmụ ndị amụma. Ọ gwara otu nwoke nʼime ụmụ ndị amụma ahụ nọ ya nso sị ya, “Jiri ngwa agha dị gị nʼaka tie m ihe.” Ma nwoke ahụ jụrụ ime ihe onye amụma ahụ kwuru. 
\p  
\v 36 Nʼihi nke a, onye amụma gwara nwoke ahụ okwu sị, “Ebe ọ bụ na ị jụrụ ime ihe \nd Onyenwe anyị\nd* nyere nʼiwu, lee ihe ga-adakwasị gị. Mgbe i si nʼebe a na-ala nʼụlọ gị, ọdụm ga-ezute gị nʼụzọ dọgbuo gị.” Amụma a mezukwara, nʼihi na mgbe nwoke ahụ tụgharịrị si nʼebe ahụ na-ala, ọdụm lụsoro ya ọgụ nʼụzọ gbuo ya.\f + \fr 20:36 \ft \xt 1Ez 13:24.\f* 
\p  
\v 37 Onye amụma ahụ pụkwara chọta onye ọzọ sị ya, “Biko, tie m ihe.” Nwoke ahụ tiri ya ihe tihịa ya ahụ.  
\v 38 Mgbe ahụ, onye amụma ahụ e tiri ihe jiri akwa kechie ihu ya, ka mmadụ ọbụla ghara ịmata onye ọ bụ. Ọ pụrụ gaa guzo nʼakụkụ ụzọ ebe eze Izrel ga-esi gafee.  
\v 39 Mgbe eze na-agafe, onye amụma ahụ tiri mkpu sị, “Onyenwe m, biko gee m ntị. Lee, otu onye agha bịakwutere m mgbe m nọ nʼihu agha sị m, ‘Lee nwoke a a dọtara nʼagha; chee ya nche. Ekwekwala ka ọ gbanarị gị. Nʼihi na ọ bụrụ na o site nʼaka gị gbapụ,\f + \fr 20:39 \ft \xt 2Ez 10:24\f* ị ga-anwụ, maọbụ i jiri otu talenti ọlaọcha gbara isi gị.’  
\v 40 Ma mgbe m nọ na-arụ ọrụ ọzọ, nwoke ahụ a dọtara nʼagha gbapụrụ. Ahụkwaghị m ya anya ọzọ.” 
\p Mgbe ahụ, eze Izrel zara sị ya, “I jirila ọnụ gị maa onwe gị ikpe. Ị ghaghị ịnata ahụhụ dịrị gị.” 
\p  
\v 41 Mgbe ahụ, onye amụma ahụ mere ngwangwa wepụ akwa ahụ o ji kechie anya ya abụọ. Eze Izrel matakwara na ọ bụ otu onye nʼime ndị amụma.  
\v 42 Onye amụma ahụ gwara eze okwu sị ya, “Otu a ka \nd Onyenwe anyị\nd* kwuru, ‘Ebe i mere ka nwoke a laa, bụ onye m nyere gị nʼaka ime ka ọ nwụọ, ugbu a, ị ghaghị ịnwụ nʼọnọdụ ya. A ga-alakwa ndị gị nʼiyi, nʼọnọdụ ndị nke ya.’ ”  
\v 43 Nʼihi okwu a, eze Izrel ji iwe na ihu mgbarụ laa nʼụlọ ya dị na Sameria. 
\c 21  
\s1 Ubi Nebọt 
\p  
\v 1 Mgbe nwa oge nta gasịrị, Nebọt, onye Jezril, nwere ubi vaịnị dị na Jezril, nʼakụkụ ụlọeze Ehab bụ eze Sameria.\f + \fr 21:1 \ft Sameria bụ isi obodo alaeze ugwu ugwu, ya mere ọ na-anọchite anya alaeze ahụ nʼebe a. \xt 1Ez 16:24\f* 
\v 2 Ehab sịrị Nebọt, “Nye m ubi vaịnị gị ka ọ bụrụ ubi a gbara ogige, ebe m ga-akụ akwụkwọ nri, ebe ọ dị nso nʼụlọeze m. Aga m enye gị ubi vaịnị ọzọ dị mma karịa ya, ma ọ bụrụkwa na ị chọrọ, aga m akwụ gị ego ọbụla o ruru nʼọnụ ahịa ya.” 
\p  
\v 3 Ma Nebọt zara sị Ehab, “Ala a bụ ihe nketa ruuru m site nʼaka nna nna m ha. M ga-esi aṅaa nye gị ya. \nd Onyenwe anyị\nd* ekwela na m ga-ewere ihe nketa nke nna nna m ha nye gị.” 
\p  
\v 4 Ehab jiri obi ụfụ na ihu mgbarụ laa nʼụlọ ya nʼihi okwu a Nebọt, onye Jezril gwara ya, sị, “Agaghị m enye gị ihe nketa nna nna m ha.” O dinara nʼihe ndina ya, chee ihu ya nʼaja ụlọ, jụ iri ihe ọbụla. 
\p  
\v 5 Ma nwunye ya bụ Jezebel, bịakwutere ya jụọ ya sị, “Gịnị mere i ji jụ iri ihe? Gịnị mere i ji nọgide nʼobi ọjọọ na iwe?” 
\p  
\v 6 Ehab zara sị ya, “Agwara m Nebọt, nwoke onye Jezril okwu sị ya, ‘Resi m ubi vaịnị gị, ma ọ bụrụ na ị chọrọ, aga m enye gị ala ubi ọzọ mara mma nʼọnọdụ ya.’ Ma ọ jụrụ jụwaa isi inye m ubi ahụ.” 
\p  
\v 7 Mgbe ahụ, nwunye ya Jezebel jụrụ ya ajụjụ sị ya, “Ọ bụghị gị bụ eze na-achị Izrel? Bilie, rie nri, enyela obi gị nsogbu, nʼihi na aga m enyefe gị ubi vaịnị Nebọt onye Jezril nʼaka.” 
\p  
\v 8 Ya mere, Jezebel dere akwụkwọ nʼaha Ehab, were mgbaaka akara eze kaa nʼakwụkwọ ndị ahụ, zigara ha ndị okenye obodo na ndị a na-asọpụrụ bi nʼobodo ebe Nebọt bi.  
\v 9 Nʼime akwụkwọ ozi ndị a, o dere sị, 
\pm “Nyenụ iwu ka mmadụ niile buo ọnụ. Kpọkọtaanụ ndị Jezril niile, ka ha zukọta. Mgbe unu zukọrọ, nyenụ Nebọt ọnọdụ nʼoche dị mkpa.  
\v 10 Họpụtanụ ndị ikom abụọ, ndị na-abaghị uru ka ha pụta nʼihu nzukọ unu guzo gbaa ama ụgha megide Nebọt sị na ha nụrụ mgbe ọ kọchara Chineke na eze.\f + \fr 21:10 \ft Ị kọchaa Chineke na eze \xt Ọpụ 22:28; Lev 24:15-16; Ọrụ 6:11\f* Maanụ ya ikpe ọnwụ, kpụpụ ya nʼazụ obodo, jiri nkume tugbuo ya, ka ọ nwụọ.” 
\p  
\v 11 Ndị okenye na ndị a na-asọpụrụ ndị bi nʼobodo ahụ mere dịka Jezebel nyere nʼiwu nʼakwụkwọ ahụ o degaara ha.  
\v 12 Ha nyere iwu maka ibu ọnụ, kpọọkwa nzukọ ndị obodo ahụ niile, meekwa ka Nebọt nọdụ nʼoche dị mkpa.  
\v 13 Mgbe ahụ, ndị ikom abụọ na-abaghị uru pụtakwara, nọdụ na ncherita ihu ya, ha gbara ama ụgha megide Nebọt, nʼihu ndị mmadụ, sị, “Nebọt kọchara Chineke na eze.” Nʼihi nke a, ha dọkpụụrụ ya gaa nʼazụ obodo jiri nkume tugbuo ya.  
\v 14 Emesịa, ndị okenye na ndị a maara aha ha nke obodo Jezril, ziri ozi zigara Jezebel gwa ya na Nebọt anwụọla. 
\p  
\v 15 Ngwangwa Jezebel natara ozi na a tụgbola Nebọt, ọ sịrị Ehab, “Bilie, gaa nwetara onwe gị ubi vaịnị Nebọt, nwoke onye Jezril. Ubi ahụ ọ jụrụ inye gị nʼego abụrụla nke gị ugbu a nʼihi na Nebọt anwụọla. Ọ dịkwaghị ndụ ọzọ!”  
\v 16 Mgbe Ehab nụrụ na Nebọt anwụọla, o biliri pụọ, gaa ịbanye nʼubi ahụ, inwetara onwe ya ubi vaịnị Nebọt, onye Jezril. 
\p  
\v 17 Ma okwu \nd Onyenwe anyị\nd* rutere Ịlaịja, onye Tishbe, sị ya,  
\v 18 “Bilie, gaa zute Ehab, eze Izrel onye bi na Sameria. Ọ nọ ugbu a nʼime ubi vaịnị Nebọt inwetara ya onwe ya.  
\v 19 Gwa ya sị ya, ‘Ihe a ka \nd Onyenwe anyị\nd* kwuru: I gbuola ọchụ mmadụ si otu a nwetara onwe gị ihe nketa? Ebe ahụ nkịta nọ rachaa ọbara Nebọt ka ha ga-anọ rachaakwa ọbara gị. E, ọbara gị onwe gị.’ ” 
\p  
\v 20 Mgbe ahụ, Ehab jụrụ Ịlaịja ajụjụ sị ya, “Onye iro m, ị chọrọkwala m bịa?” 
\p Ịlaịja zara sị ya, “E, achọrọla m gị bịa nʼihi nnyefe i nyefere onwe gị ime ihe dị njọ nʼanya \nd Onyenwe anyị\nd*.  
\v 21 Ọ sịrị, ‘Aga m eme ka ihe ọjọọ dakwasị gị. Aga m ekpochapụ ndị agbụrụ gị, site nʼezinaụlọ Ehab bipụ nwoke ọbụla, maọbụ ohu maọbụ onyenwe onwe ya nʼIzrel.  
\v 22 Aga m eme ka ụlọ gị dịrị ka nke Jeroboam nwa Nebat, na dịka nke Baasha nwa Ahija, nʼihi na ị kpasuola m iwe, meekwa ka Izrel mehie.’ 
\p  
\v 23 “Ma banyere Jezebel, \nd Onyenwe anyị\nd* sịrị, ‘Ụmụ nkịta ga-eri anụ ahụ Jezebel nʼakụkụ mgbidi aja ụlọ dị nʼobodo Jezril.’ 
\p  
\v 24 “Nkịta ga-eri anụ onye ọbụla si nʼezinaụlọ Ehab nke nwụrụ nʼime obodo, ma anụ ufe nke eluigwe ga-eri anụ ndị ọbụla nwụrụ nʼọhịa.” 
\p  
\v 25 (Nʼezie, o nweghị onye ọbụla ọzọ dị ka Ehab, onye rere onwe ya nye ime ihe ọjọọ dị ukwuu nʼanya \nd Onyenwe anyị\nd*, onye Jezebel nwunye ya kwagidere ime ihe ọjọọ dị iche iche.  
\v 26 Ehab bụ onye mere mmehie dị oke njọ nke ịgbaso na ife arụsị dị iche iche ofufe dịka ndị Amọrait\f + \fr 21:26 \ft Aha a, ka e ji mara ndị biri nʼala ahụ Chineke kwere Ebraham na nkwa tupu ụmụ Izrel a bịa bichie na ya. \xt Jen 15:16; Ọpụ 23:23; Dit 1:7-8; 2Ez 21:11\f* mere, bụ ndị ahụ \nd Onyenwe anyị\nd* sitere nʼala a chụpụ ime ka ndị Izrel nweta ala ha.) 
\p  
\v 27 Mgbe Ehab nụrụ okwu amụma ndị a, ọ dọwara uwe ya, yikwasị onwe ya akwa mkpe, buo ọnụ, dinaa nʼakwa mkpe ahụ, jegharịakwa nʼịdị umeala. 
\p  
\v 28 Ma okwu \nd Onyenwe anyị\nd* rutere Ịlaịja, onye Tishbe ọzọ, sị ya,  
\v 29 “Ị hụrụ otu Ehab si weda onwe ya ala nʼihu m? Nʼihi ihe a o mere, iweda onwe ya ala nʼihu m, agaghị m eme ka ihe ọjọọ ndị a m kwuru okwu banyere ha rute ya nʼoge ọ dị ndụ. Kama aga m eme ka ihe ndị a dakwasị ezinaụlọ ya mgbe nwa ya ga-achị dịka eze.” 
\c 22  
\s1 Amụma Mikaya megide Ehab 
\p  
\v 1 Agha ọzọ adaghị nʼetiti Aram na Izrel afọ atọ.  
\v 2 Ma nʼafọ nke atọ, Jehoshafat, eze Juda, gara ileta Ehab eze Izrel.  
\v 3 Eze Izrel sịrị ndị ozi ya, “Unu amaghị na ala Ramọt Gilead bụ nke anyị, ma lee na anyị gbara nkịtị ịga napụta ya site nʼaka eze Aram?” 
\p  
\v 4 Ya mere, ọ jụrụ Jehoshafat, “Ị ga-eso m gaa buso Ramọt Gilead agha?” 
\p Jehoshafat zaghachiri eze Izrel, sị, “Otu m dị ka gị onwe gị dị, ndị m bụkwa ndị gị, ịnyịnya m bụkwa nke gị.”  
\v 5 Ma Jehoshafat gwakwara eze Izrel, sị, “Buru ụzọ chọpụta ihe bụ ntụziaka \nd Onyenwe anyị\nd*.” 
\p  
\v 6 Ya mere, eze Izrel kpọkọtara ndị amụma, ọnụọgụgụ ha ruru narị ndị ikom anọ, jụọ ha sị, “Ọ bụ m gaa buso Ramọt Gilead agha, ka ọ bụ m hapụ ịga?” 
\p Ha zara, “Gaa, nʼihi na Onyenwe anyị ga-enyefe ha nʼaka eze.” 
\p  
\v 7 Ma Jehoshafat jụrụ, “Ọ bụ na e nwekwaghị onye amụma \nd Onyenwe anyị\nd* nọ nʼebe a, onye anyị nwere ike ịjụta ase nʼaka ya?” 
\p  
\v 8 Eze Izrel zaghachiri Jehoshafat, sị, “A ka nwere otu onye amụma, onye anyị nwere ike isite nʼaka ya jụọ \nd Onyenwe anyị\nd* ase, ọ bụ Maikaya nwa Imla,\f + \fr 22:8 \ft Nke a, abụghị onye dere akwụkwọ Maika, nke bụ otu akwụkwọ nʼime akwụkwọ nsọ\f* ma akpọrọ m ya asị, nʼihi na o nweghị oge ọ na-ebu amụma ihe ọma nʼebe m nọ, kama ọ bụ naanị nke ọjọọ.” 
\p Jehoshafat sịrị, “Eze ekwesighị ikwu okwu dị otu a.” 
\p  
\v 9 Mgbe ahụ, eze Izrel kpọrọ otu onye na-ejere ya ozi sị ya, “Mee ọsịịsọ kpọta Maikaya nwa Imla nʼebe a.” 
\p  
\v 10 Ehab eze Izrel na Jehoshafat eze Juda, onye ọbụla yi uwe eze ya, na-anọkwasị nʼocheeze ya nʼebe ịzọcha ọka nʼọnụ ụzọ ama e si abata obodo Sameria. Ndị amụma ahụ niile nọkwa na-ebu amụma nʼihu ha.  
\v 11 Zedekaya nwa Kenaana, mere mpi igwe, ọ kwupụtara sị, “Nke a bụ ihe \nd Onyenwe anyị\nd* na-ekwu, ‘Ihe ndị a ka ị ga-eji sọgide ndị Aram, ruo mgbe a ga-ala ha nʼiyi.’ ” 
\p  
\v 12 Ndị amụma ndị ọzọ niile na-ebu otu ihe ahụ nʼamụma, na-asị, “Gaa, busoo Ramọt Gilead agha, ị ga-enwekwa mmeri, nʼihi na \nd Onyenwe anyị\nd* ga-enyefe ya nʼaka eze.” 
\p  
\v 13 Onyeozi ahụ nke gara ịkpọ Maikaya sịrị ya, “Lee, ndị amụma ndị ọzọ na-agụpụghị onye ọbụla na-ebu amụma ọganihu nye eze. Mee ka okwu gị na ha dakọta. Kwuokwa ihe ga-adị eze mma.” 
\p  
\v 14 Ma Maikaya sịrị, “Dịka \nd Onyenwe anyị\nd* na-adị ndụ, aga m agwa ya naanị ihe \nd Onyenwe anyị\nd* gwara m.”\f + \fr 22:14 \ft \xt Ọnụ 22:38; 24:13\f* 
\p  
\v 15 Mgbe ọ bịarutere, eze jụrụ ya, “Maikaya, ọ bụ anyị gaa buso Ramọt Gilead agha, ka ọ bụ anyị hapụ?” 
\p Ọ zara, “Gaa, ma nwekwa mmeri, nʼihi na \nd Onyenwe anyị\nd* ga-enyefe ya nʼaka eze.” 
\p  
\v 16 Eze sịrị ya, “Ugboro ole ka m ga-eme ka ị ṅụọ iyi na ị gaghị agwa m ihe ọzọ, karịa naanị eziokwu nʼaha \nd Onyenwe anyị\nd*?” 
\p  
\v 17 Mgbe ahụ Mikaya zara, “Ahụrụ m Izrel niile ka ha gbasasịrị nʼelu ọtụtụ ugwu dịka atụrụ na-enweghị onye ọzụzụ atụrụ, ma \nd Onyenwe anyị\nd* sịrị, ‘Ndị a enweghị onyendu. Ka onye ọbụla laghachi nʼụlọ ya nʼudo.’ ” 
\p  
\v 18 Eze Izrel, sịrị Jehoshafat, “Ọ bụ na m agwaghị gị na ọ dịghị mgbe ọ na-ebu amụma ihe ọma banyere m, kama naanị ihe ọjọọ?” 
\p  
\v 19 Mikaya gara nʼihu, sị, “Ya mere, nụrụnụ okwu \nd Onyenwe anyị\nd*. Ahụrụ m \nd Onyenwe anyị\nd* ka ọ nọkwasịrị nʼocheeze ya, hụkwa usuu nke eluigwe ka ha na-eguzo nʼakụkụ ya, nʼaka nri ya nakwa nʼaka ekpe ya.  
\v 20 \nd Onyenwe anyị\nd* sịrị, ‘Onye ga-aga rafuo Ehab ka ọ gaa buso Ramọt Gilead agha, gaa nwụọ nʼebe ahụ?’ 
\p “Otu onye tụpụtara aro nke a, ebe onye ọzọ tụpụtara nke ọzọ.  
\v 21 Nʼikpeazụ otu mmụọ pụtara, guzo nʼihu \nd Onyenwe anyị\nd* sị, ‘Mụ onwe m ga-arafu ya.’ 
\p  
\v 22 “ ‘\nd Onyenwe anyị\nd* jụrụ sị, Olee otu ị ga-esi mee nke a?’ 
\p “ ‘Aga m apụ gaa bụrụ mmụọ nrafu nʼọnụ ndị amụma ya niile,’ ka ọ zara. 
\p “\nd Onyenwe anyị\nd* sịrị, ‘Ị ga-enwe ike ịrafu ya. Gaa mee otu a.’ 
\p  
\v 23 “Ma ugbu a, \nd Onyenwe anyị\nd* etinyela mmụọ okwu ụgha nʼọnụ ndị amụma gị niile ndị a. \nd Onyenwe anyị\nd* ekwubiela nʼihe ọjọọ ga-adakwasị gị.” 
\p  
\v 24 Mgbe ahụ, Zedekaya nwa Kenaana, gara nso, maa Maikaya aka na nti, jụọ ya, “Olee ụzọ ka mmụọ ahụ sitere na \nd Onyenwe anyị\nd* gara, mgbe ọ hapụrụ m bịa ịgwa gị okwu?” 
\p  
\v 25 Maikaya zaghachiri, “Ị ga-achọpụta nke a nʼụbọchị ị ga-agbaba nʼime ime ụlọ izo onwe gị.” 
\p  
\v 26 Mgbe ahụ, eze Izrel nyere iwu sị, “Jidenụ Maikaya kpụgara ya Amọn onye na-achị obodo a, na Joash nwa eze  
\v 27 ị ga-asịkwa, ‘Otu a ka eze sịrị: Tinye nwoke a nʼụlọ mkpọrọ, nye ya naanị achịcha na mmiri ọṅụṅụ tutu ruo mgbe m lọghachiri nʼudo.’ ” 
\p  
\v 28 Maikaya kwupụtara sị, “Ọ bụrụ na ị lọghachi nʼudo, ọ pụtara na ọ bụghị \nd Onyenwe anyị\nd* si nʼọnụ m kwuo okwu.” O kwukwara sị, “Unu niile hụbakwanụ okwu m ndị a niile ama!” 
\s1 Ehab anwụọ na Ramọt Gilead 
\p  
\v 29 Ya mere, eze Izrel na Jehoshafat eze Juda, pụrụ gawa Ramọt Gilead.  
\v 30 Eze Izrel gwara Jehoshafat, sị, “Aga m ejikere onwe m dịka m bụ onye ọzọ banye nʼọgbọ agha, ma gị onwe gị yiri uwe eze gị.” Ya mere, eze Izrel nwogharịrị onwe ya ka onye ọzọ baa nʼọgbọ agha. 
\p  
\v 31 Ma eze Aram enyelarị ndị ọchịagha ndị na-agba ụgbọ agha, ọnụọgụgụ ha dị iri atọ na abụọ, iwu sị, “Unu ebusola onye ọbụla agha, maọbụ onye ukwu maọbụ onye nta, karịakwa naanị eze Izrel.”  
\v 32 Mgbe ndị ọchịagha, na-achị ụgbọ agha hụrụ Jehoshafat, ha chere nʼobi ha, “Nʼezie, onye a bụ eze Izrel.” Nʼihi ya ha tụgharịrị ibuso ya agha, ma Jehoshafat tiri mkpu,  
\v 33 ndị ọchịagha, na-achị ndị na-agba ụgbọ agha hụrụ na ọ bụghị eze Izrel, ma kwụsị ịchụso ya. 
\p  
\v 34 Ma otu onye dọrọ ụta ya gbapụ ya na-ebughị onye ọbụla nʼobi, gbata ya eze Izrel nʼetiti njikọ nke uwe agha ya.\f + \fr 22:34 \ft Eleghị anya ebe uwe agha ya na-ekpuchiteghị\f* Eze gwara onye ọkwọ ụgbọ agha ya, sị, “Tụgharịa, si nʼebe a bupụ m, nʼihi na emerụọla m ahụ.”  
\v 35 Agha ahụ siri ike nʼụbọchị ahụ niile, e ji ihe mee ka eze kwụrụ ọtọ nʼime ụgbọ agha ya na-eche ndị Aram ihu. Ọbara si nʼọnya ahụ sọjuru nʼala ụgbọ agha ahụ, ọ nwụrụ nʼuhuruchi ụbọchị ahụ.  
\v 36 Mgbe anyanwụ na-ada, e tiri mkpu nke gazuru nʼọgbọ agha ndị Izrel, sị, “Nwoke ọbụla laa nʼobodo ya, onye ọbụla laakwa nʼala nke aka ya!” 
\p  
\v 37 Ya mere, eze nwụrụ, e buta ozu ya nʼobodo Sameria, ebe a nọ lie ya.  
\v 38 Ha sachara ụgbọ agha ya nʼọdọ mmiri dị na Sameria (ebe ndị akwụna na-asa ahụ). Ụmụ nkịta rachara ọbara ya, dịka okwu \nd Onyenwe anyị\nd* kwubiri.\f + \fr 22:38 \ft \xt 1Ez 21:19\f* 
\p  
\v 39 Ma banyere ihe ndị ọzọ niile mere nʼoge ọchịchị Ehab na ihe niile o mere, ụlọeze o wuru nke o ji ọdụ chọọ mma, na obodo niile o wusiri ike, ọ bụ na e deghị ha nʼakwụkwọ akụkọ ihe mere nʼoge ndị eze Izrel?  
\v 40 Ehab sooro ndị nna nna ya ha dina nʼọnwụ. Ahazaya nwa ya ghọrọ eze nʼọnọdụ. 
\s1 Jehoshafat, eze Juda 
\p  
\v 41 Jehoshafat nwa Asa ghọrọ eze Juda, nʼafọ nke anọ, nke ọchịchị Ehab eze Izrel.  
\v 42 Jehoshafat gbara iri afọ atọ na ise mgbe ọ malitere ịbụ eze. Ọ chịrị iri afọ abụọ na ise na Jerusalem. Aha nne ya bụ Azuba, nwa Shilhi.  
\v 43 Nʼihe niile o jere ije nʼụzọ Asa bụ nna ya, o sitekwaghị nʼime ha wezuga onwe ya, o mekwara ihe ziri ezi nʼanya \nd Onyenwe anyị\nd*. Naanị na o wezugaghị ebe dị elu niile, nke mere na ndị mmadụ gara nʼihu na-achụ aja, na-esurekwa ihe nsure ọkụ na-esi isi ụtọ nʼebe ahụ niile.  
\v 44 Jehoshafat mere ka udo dị nʼetiti ya na eze Izrel. 
\p  
\v 45 Ma banyere ihe ndị ọzọ niile mere nʼoge ọchịchị Jehoshafat, ihe niile ndị ọ rụpụtara, ike ọ kpara nʼọtụtụ agha nke o buru, ọ bụ na e deghị ha nʼakwụkwọ akụkọ ihe mere nʼoge ndị eze Juda?  
\v 46 O kpochapụrụ ndị ikom akwụna ụlọ arụsị, bụ ndị nke fọdụrụ, mgbe nna ya bụ Asa chịchara ọchịchị.  
\v 47 Nʼoge a, eze adịghị nʼala Edọm, kama ọ bụ onye nnọchite anya eze bụ onye na-achị. 
\p  
\v 48 Jehoshafat wuuru ọtụtụ ụgbọ mmiri eji azụ ahịa, maka ije nʼala Ọfịa ịga bute ọlaedo ma ụgbọ mmiri ndị a agaghị ebe ọbụla, nʼihi na ha mikpuru nʼEziọn Geba.  
\v 49 Nʼoge ahụ, Ahazaya nwa Ehab sịrị Jehoshafat, “Kwere ka ndị ikom m soro ndị ọrụ gị nʼụgbọ gị,” ma Jehoshafat ekweghị. 
\p  
\v 50 Mgbe ahụ, Jehoshafat sooro nna nna ya ha dina nʼọnwụ, e lie ya nʼebe e liri ha nʼobodo Devid, nna ya. Jehoram nwa ya ghọrọ eze nʼọnọdụ ya. 
\s1 Ahazaya, eze Izrel 
\p  
\v 51 Ahazaya nwa Ehab, malitere ịbụ eze Izrel na Sameria, nʼafọ iri na asaa nke ọchịchị Jehoshafat, eze Juda. Ma ọ chịrị Izrel naanị afọ abụọ.  
\v 52 O mere ihe dị njọ nʼanya \nd Onyenwe anyị\nd*, nʼihi na o sooro ụzọ ọjọọ niile nke nna na nne ya, na ụzọ ọjọọ nke Jeroboam nwa Nebat, onye mere ka Izrel mee mmehie.  
\v 53 Ọ fekwara arụsị Baal ofufe, kpọọkwa isiala nye ya, si otu a kpasuo \nd Onyenwe anyị\nd*, Chineke Izrel iwe, dịka nna ya mere.