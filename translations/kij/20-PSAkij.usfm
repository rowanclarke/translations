\q1  
\v 21 Mapaila baisa Guyau igibuluwa avai tuta ilagi si biga, 
\q2 e iwaiya la tomota metoya wa kova. 
\q2 E la gibuluwa baisa matausina isisiniveka, 
\q1  
\v 22 paila uula gala idubumaisi matauna, 
\q2 deli gala idubumaisi paila bikatumovi matausina. 
\q1  
\v 23 Mitaga iluki labuma walakaiwa, 
\q2 e ikaraiwogi kala lulu bikapogegasi. 
\q1  
\v 24 E isaiki matausina kaula metoya wa labuma, 
\q2 e iwitali ididebwalisi mana paila matausina bikamsi. \x - \xo 78.24 \xt Yn 6.31\x* 
\q1  
\v 25 Mapaila baisa mwada anelosi kʹasi eikomasiga, 
