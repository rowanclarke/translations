\q1
\v 9 \w It|strong="H3068"\w* \w was|strong="H3068"\w* \w the|strong="H3605"\w* Commander \w of|strong="H3068"\w* \w the|strong="H3605"\w* \w armies|strong="H6635"\w* \w of|strong="H3068"\w* angels \w who|strong="H3605"\w* \w did|strong="H3068"\w* \w it|strong="H3068"\w*;  
