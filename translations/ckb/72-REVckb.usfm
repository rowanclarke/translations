\id REV - Biblica® Open Kurdi Sorani Standard Version 
\h ئاشکراکردن 
\toc1 ئاشکراکردنی عیسای مەسیح 
\toc2 ئاشکراکردن 
\toc3 ئاشکراکردن 
\mt1 ئاشکراکردنی عیسای مەسیح 
\c 1  
\s1 پێشەکی 
\p  
\v 1 ئاشکراکردنی عیسای مەسیح کە خودا پێیداوە، تاکو ئەو شتانەی دەبێت زوو ڕووبدەن بە بەندەکانی پیشان بدات. خودا لە ڕێگەی ناردنی فریشتەکەیەوە بۆ لای یۆحەنای بەندەی، ئەو شتانەی دەرخست،  
\v 2 کە شایەتیی دا بۆ هەموو ئەو شتانەی کە بینی، واتا وشەی خودا و شایەتیی عیسای مەسیح.  
\v 3 خۆزگە دەخوازرێت بەوەی وتەکانی ئەم پێشبینییە دەخوێنێتەوە، هەروەها خۆزگە بەو کەسانەش دەخوازرێت کە دەیبیستن و ئەوەی تێیدا نووسراوە پەیڕەوی دەکەن، چونکە کاتەکە نزیکە. 
\b  
\s1 سڵاو بۆ کڵێساکان 
\p  
\v 4 لە یۆحەناوە، 
\b  
\p بۆ حەوت کڵێساکەی هەرێمی ئاسیا: 
\b  
\p با نیعمەت\f + \fr 1:4 \ft نیعمەت بەخشینێکی خودایە بە مرۆڤ بەبێ شایستەبوونی پێی دەبەخشێت.\f* و ئاشتیتان بۆ ببێت لەوەوەی کە هەیە و هەبووە و دێت و لەو حەوت ڕۆحەوەی لەبەردەم تەختەکەیدان،  
\v 5 هەروەها لە عیسای مەسیحیشەوە کە شایەتیدەری دڵسۆزە، نۆبەرەی هەستانەوەی نێو مردووانە و سەرۆکی پاشاکانی سەر زەوییە. 
\b  
\p ئەو کە ئێمەی خۆشدەوێت و بە خوێنی خۆی لە گوناهەکانمان ئازادی کردین و  
\v 6 ئێمەی کردە شانشین و کاهین بۆ خودای باوکی، هەتاهەتایە شکۆ و دەسەڵات بۆ ئەوە! ئامین. 
\q1  
\v 7 ئەوەتا لەگەڵ هەوردا\f + \fr 1:7 \ft بڕوانە \xt دانیال 7‏:13‏\ft ‏.‏\f* دێت و 
\q2 هەموو چاوێک دەیبینێت، 
\q1 ئەوانەش کە ڕمیان لێیداوە، 
\q2 هەموو خێڵەکانی زەویش شیوەنی بۆ دەگێڕن. 
\qc بێگومان بەم جۆرە دەبێت، ئامین. 
\p  
\v 8 یەزدانی پەروەردگار دەفەرموێ: «من ئەلف و یێم، ئەوەی هەیە و هەبووە و دێت، هەرە بەتوانا.» 
\b  
\s1 بینینی مەسیحی زیندوو 
\p  
\v 9 من یۆحەنای براتانم، کە بە یەکبوون لەگەڵ عیسادا هاوبەشتانم لە تەنگانە و شانشین و دانبەخۆداگرتن، لە پێناوی پەیامی خودا و شایەتی بۆ عیسا لە دوورگەی پەتمۆس بووم.  
\v 10 لە ڕۆژی یەزداندا\f + \fr 1:10 \fq ڕۆژی یەزدان \ft ڕۆژی یەزدان واتا ڕۆژی یەکشەممە کە تێیدا مەسیح زیندوو بووەوە.\f* ڕۆحی پیرۆزم هاتە سەر و لە پشتمەوە گوێم لە دەنگێکی بەرزی وەک کەڕەنا بوو،  
\v 11 دەیفەرموو: «ئەوەی دەیبینی لە پەڕتووکێک بینووسەوە و بۆ حەوت کڵێساکەی بنێرە، واتا ئەفەسۆس و سمیرنا و پرگامۆس و سیاتیرا و ساردس و فیلادەلفیا و لاودیکییا.\f + \fr 1:11 \ft ئەو حەوت شارە دەکەونە ڕۆژئاوای تورکیای ئێستا.‏\f*» 
\p  
\v 12 ئاوڕم دایەوە تاکو ئەو دەنگە ببینم کە لەگەڵم دەدوا. کاتێک ئاوڕم دایەوە حەوت چرادانی زێڕینم بینی،  
\v 13 لە ناوەڕاستی چرادانەکاندا یەکێکم وەک کوڕی مرۆڤ\f + \fr 1:13 \ft \xt دانیال 7‏:13.‏\ft ‏\f* بینی، جلێکی شۆڕی لەبەردا بوو هەتا بەرپێی، پشتێنێکی زێڕینی بە سنگییەوە بەستبوو.  
\v 14 سەر و قژی سپی وەک خوری و وەک بەفر سپی بوون و چاوەکانی وەک گڕی ئاگر بوون.  
\v 15 پێیەکانی وەک بڕۆنزێکی بریقەدار کە لە کوورە پوختە کرابێت وابوون، دەنگیشی وەک هاژەی تاڤگە وابوو.  
\v 16 حەوت ئەستێرە لە دەستی ڕاستی بوون، شمشێرێکی دوودەمیش لە دەمیەوە دەردەچوو، ڕوخساری وەک تیشکی بەتینی ڕۆژ دەدرەوشایەوە. 
\p  
\v 17 کاتێک بینیم وەک مردوو لەبەرپێی کەوتم، دەستی ڕاستی خستە سەرم و فەرمووی: «مەترسە، من سەرەتا و کۆتاییم.  
\v 18 منم زیندووەکە! مردبووم، بەڵام ئەوەتا ئێستا بۆ هەتاهەتایە زیندووم! هەروەها کلیلەکانی مردن و جیهانی مردووانم\f + \fr 1:18 \ft یۆنانی: \+tl هادیس‏\+tl*: بڕوانە پەراوێزی \xt مەتا 11‏:23‏\ft ‏‏.‏\f* پێیە. 
\p  
\v 19 «بۆیە ئەمانە بنووسە لەوەی بینیت و ئەوەی هەیە و ئەوەی پاش ئەمەش دەبێت.  
\v 20 نهێنی ئەو حەوت ئەستێرەیەی لە دەستی ڕاستم بینیت و حەوت چرادانە زێڕینەکە ئەمەیە: حەوت ئەستێرەکە فریشتەی حەوت کڵێساکانن و حەوت چرادانەکەش حەوت کڵێساکەن.» 
\c 2  
\s1 نامەیەک بۆ کڵێسای ئەفەسۆس 
\p  
\v 1 بۆ فریشتەی کڵێساکەی ئەفەسۆس بنووسە: 
\pm ئەوەی حەوت ئەستێرەکەی بە دەستی ڕاستی گرتووە و بە ناو حەوت چرادانە زێڕینەکەدا هاتوچۆ دەکات، دەفەرموێ: 
\b  
\pm  
\v 2 «ئاگام لە کردار و ماندووبوون و دانبەخۆداگرتنتە. دەزانم کە ناتوانیت بەرگەی خراپەکاران بگریت و ئەوانەشت تاقی کردەوە کە خۆیان بە نێردراو دەزانن بەڵام نێردراو نین و بە درۆزن دەرچوون،  
\v 3 دانت بە خۆتدا گرت و لەبەر ناوی من بەرگەت گرت و کۆڵت نەدا. 
\pm  
\v 4 «بەڵام ئەمەم لەسەرت هەیە: تۆ خۆشەویستییەکەی جارانت بەلاوە ناوە.  
\v 5 بەبیرت بێتەوە لە چ پایەیەکی بەرز کەوتیت! تۆبە بکە و کارەکانی پێشترت دووبارە بکەرەوە. ئەگەر تۆبە نەکەیت، دێمە لات و چرادانەکەت لە شوێنی خۆی لادەدەم.  
\v 6 بەڵام شتێکی باشت هەیە: تۆش وەکو من ڕقت لە دابونەریتی نیکۆلاوییەکان\f + \fr 2:6 \ft کۆمەڵێکی شوێنکەوتەی نیکۆلاوس، لە بیری ئەوان ئازادی بە مەسیح ئازادی بوو بۆ بەڕەڵایی. بڕوانە \xt 2‏:15‏\ft .‏\f* دەبێتەوە. 
\pm  
\v 7 «ئەوەی گوێی هەیە، با ببیستێت ڕۆحی پیرۆز چی بە کڵێساکان دەفەرموێ. ئەوەی سەربکەوێت، ڕێگەی دەدەم لە درەختی ژیان\f + \fr 2:7 \ft \xt پەیدابوون 2‏:9؛ 3‏:22.‏\ft ‏\f* بخوات، کە لە بەهەشتی خودایە.» 
\s1 نامەیەک بۆ کڵێسای سمیرنا 
\p  
\v 8 بۆ فریشتەی کڵێساکەی سمیرنا بنووسە: 
\pm ئەوەی یەکەمین و دواهەمینە، ئەوەی مردوو بوو و زیندووبووەوە، دەفەرموێ: 
\b  
\pm  
\v 9 «ئاگام لە تەنگانە و هەژاریتە، هەرچەندە تۆ دەوڵەمەندیت. هەروەها ئاگام لە قسە هەڵبەستنی ئەوانەیە کە دەڵێن جولەکەین و واش نین، بەڵام کەنیشتی شەیتانن.  
\v 10 هەرگیز مەترسە لەو ئازارانەی وا بۆت دێت. وا ئیبلیس خەریکە هەندێکتان بخاتە زیندانەوە، تاکو تاقی بکرێنەوە و دە ڕۆژ تەنگانەتان دەبێت. هەتا مردن دڵسۆزبە، منیش تاجی ژیانت پێ دەبەخشم. 
\pm  
\v 11 «ئەوەی گوێی هەیە، با ببیستێت ڕۆحی پیرۆز چی بە کڵێساکان دەفەرموێ. ئەوەی سەربکەوێت، مردنی دووەم ئازاری نادات.» 
\s1 نامەیەک بۆ کڵێسای پرگامۆس 
\p  
\v 12 بۆ فریشتەی کڵێساکەی پرگامۆس بنووسە: 
\pm ئەوەی شمشێرە تیژە دوودەمەکەی هەیە دەفەرموێ: 
\b  
\pm  
\v 13 «ئاگام لێیە لەکوێ دەژیت، ئەو شوێنەی تەختی شەیتانی لێیە. لەگەڵ ئەوەشدا دەست بە ناوی منەوە دەگریت. تەنانەت لەو ڕۆژانەش کە ئەنتیپاسی شایەتیدەری دڵسۆزم لەلاتان شەهید کرا، لەو شوێنەی شەیتان نیشتەجێیە، نکۆڵیت لە باوەڕی من نەکرد. 
\pm  
\v 14 «بەڵام هەندێک شتم لەسەرت هەیە: هەندێک کەس لەلاتن پابەندن بە فێرکردنی بەلعامەوە\f + \fr 2:14 \ft \xt سەرژمێری 31‏:16‏\ft ‏\f*، ئەوەی بالاقی فێردەکرد کۆسپ لەبەردەم نەوەی ئیسرائیل دابنێت تاکو لەو قوربانییانە بخۆن\f + \fr 2:14 \ft \xt سەرژمێری 25‏:1‏\ft ‏.‏\f* کە بۆ بت کراون و داوێنپیسی بکەن.  
\v 15 بە هەمان شێوە، لەلای تۆش هەندێک هەن پابەندن بە فێرکردنی نیکۆلاوییەکان.  
\v 16 بۆیە تۆبە بکە! ئەگینا، بەم زووانە دێمە لات و بە شمشێرەکەی دەمم لەگەڵیان دەجەنگم. 
\pm  
\v 17 «ئەوەی گوێی هەیە، با ببیستێت ڕۆحی پیرۆز چی بە کڵێساکان دەفەرموێ. ئەوەی سەربکەوێت، لە مەنی\f + \fr 2:17 \ft ئەو نانەی کە خودا لە سەردەمی موسادا لە ئاسمانەوە باراندی. گەلی خودا لەو باوەڕەدا بوون کە لە سەردەمی مەسیحدا خودا دووبارە ئەم مەنە بە گەلەکەی دەداتەوە. بڕوانە \xt دەرچوون 16‏:4‏-34.‏\ft ‏\f* شاراوەی دەدەمێ، هەروەها بەردێکی سپی دەدەمێ کە ناوێکی نوێی لەسەر نووسراوە، جگە لەوەی وەریدەگرێت کەس نایزانێت.» 
\s1 نامەیەک بۆ کڵێسای سیاتیرا 
\p  
\v 18 بۆ فریشتەی کڵێساکەی سیاتیرا بنووسە: 
\pm کوڕی خودا، ئەوەی چاوەکانی وەک گڕی ئاگرە و پێیەکانی وەک بڕۆنزی بریقەدارە، دەفەرموێ: 
\b  
\pm  
\v 19 «ئاگام لە کردار و خۆشەویستی و خزمەت و باوەڕ و دانبەخۆداگرتنتە. کارەکانی ئەم دواییەت لەوانەی یەکەم جارت زیاترن. 
\pm  
\v 20 «بەڵام ئەمەم لەسەرت هەیە: تۆ ڕێت بەو ژنە داوە کە ناوی ئیزابێلە\f + \fr 2:20 \ft ناوێکە وەکو هێما بۆ خراپەکار بەکاردێت، بڕوانە \xt یەکەم پاشایان 18‏:4‏\ft ‏.‏\f*، خۆی بە پێغەمبەر ناوببات، بەندەکانم فێردەکات و چەواشەیان دەکات تاکو داوێنپیسی بکەن و لەو خواردنە بخۆن کە بۆ بت کراوەتە قوربانی.  
\v 21 کاتم پێیدابوو تاکو تۆبە بکات، بەڵام نەیویست تۆبە لە داوێنپیسی بکات.  
\v 22 لەبەر ئەوە فڕێیدەدەمە سەر جێگا و نەخۆش دەکەوێ، هەروەها ئەگەر ئەوانەی داوێنپیسییان لەگەڵی کردووە لە کردارەکانیان تۆبە نەکەن، دەیانخەمە ناو تەنگانەیەکی گەورەوە.  
\v 23 هەروەها منداڵەکانی بە مردن لەناودەبەم، هەموو کڵێساکانیش دەزانن من پشکێنەری مێشک و دڵەکانم، سزای هەر یەکێکیشتان بەگوێرەی کارەکانی دەدەم. 
\pm  
\v 24 «بەڵام بە ئێوە دەڵێم، ئەوانەی لە سیاتیرا ماونەتەوە، ئەوانەی ئەم فێرکردنەیان نییە و بە قووڵایی شەیتانیان نەزانیوە، وەک دەڵێن، من بارێکی دیکەتان ناخەمە سەر،  
\v 25 تەنها ئەوەی هەتانە دەستی پێوە بگرن، هەتا دێم. 
\pm  
\v 26 «ئەوەی سەربکەوێت و هەتا کۆتایی کارەکانی من ئەنجام بدات، دەسەڵاتی بەسەر نەتەوەکاندا دەدەمێ، 
\q1  
\v 27 ﴿بە گۆچانێکی ئاسنین بەڕێوەیان دەبات، 
\q2 وەک گۆزەیەکی گڵین وردوخاشیان دەکات.﴾\f + \fr 2:27 \ft \xt زەبوورەکان 2‏:9‏\ft ‏\f* 
\m هەروەک منیش لە باوکمەوە دەسەڵاتم وەرگرتووە.  
\v 28 هەروەها ئەستێرەی بەرەبەیانی دەدەمێ.  
\v 29 ئەوەی گوێی هەیە، با ببیستێت ڕۆحی پیرۆز چی بە کڵێساکان دەفەرموێ.» 
\c 3  
\s1 نامەیەک بۆ کڵێسای ساردس 
\p  
\v 1 هەروەها بۆ فریشتەی کڵێساکەی ساردس بنووسە: 
\pm ئەوەی حەوت ڕۆحی خودا و حەوت ئەستێرەکەی هەیە دەفەرموێ: 
\b  
\pm «ئاگام لە کردارەکانتە، تۆ بە ناو زیندوویت، بەڵام مردوویت.  
\v 2 ئێشک بگرە! ئەوەی ماوە و خەریکە بمرێت بەهێزی بکە، چونکە لەبەردەم خودام کارەکانتم بە ناتەواوی بینی.  
\v 3 ئیتر ئەو شتەی کە فێری بوویت و بیستت بەبیر خۆتی بهێنەرەوە و بە باشی پێیەوە پابەند بە و تۆبە بکە. بەڵام ئەگەر ئێشک نەگریت ئەوا وەک دزێک دێم و نازانی لە چ کاتێکدا دێمە سەرت. 
\pm  
\v 4 «کەچی خەڵکێکی کەمت لە ساردسدا هەیە بەرگەکانیان گڵاو نەکردووە. ئەوان بە بەرگی سپییەوە لەگەڵ من ڕێ دەکەن، چونکە شایانی ئەوەن.  
\v 5 ئەوەی سەربکەوێت، ئاوا بەرگی سپی دەپۆشێت و ناوی لە پەڕتووکی ژیاندا ناسڕمەوە و لەبەردەم باوکم و لەبەردەم فریشتەکانی دان بە ناوەکەیدا دەنێم.  
\v 6 ئەوەی گوێی هەیە، با ببیستێت ڕۆحی پیرۆز چی بە کڵێساکان دەفەرموێ.» 
\s1 نامەیەک بۆ کڵێسای فیلادەلفیا 
\p  
\v 7 هەروەها بۆ فریشتەی کڵێساکەی فیلادەلفیا بنووسە: 
\pm ئەوەی پیرۆز و ڕاستە، کلیلەکەی داودی لە دەستە، ئەوەی دەیکاتەوە و کەس دایناخات، دایدەخات و کەس نایکاتەوە، دەفەرموێ: 
\b  
\pm  
\v 8 «ئاگام لە کردارەکانتە. ئەوەتا دەرگایەکی کراوەم لەبەردەمت داناوە و کەس ناتوانێت دایبخات. دەزانم هێزێکی کەمت هەیە، بەڵام وشەی من دەپارێزیت، نکۆڵیت لە ناوی من نەکرد.  
\v 9 ئەوەتا ئاوا لەوانەی کەنیشتی شەیتان دەکەم، ئەوانەی دەڵێن جولەکەین و جولەکەش نین، بەڵکو درۆ دەکەن، وایان لێ دەکەم بێن و لەبەردەم پێیەکانتدا کڕنۆش ببەن و بزانن تۆم خۆشویستووە.  
\v 10 لەبەر ئەوەی بەگوێرەی ڕاسپاردەکەم دانت بەخۆتداگرت، منیش لە کاتی تاقیکردنەوەدا دەتپارێزم کە بەسەر هەموو جیهاندا دێت بۆ ئەوەی دانیشتووانی جیهان تاقی بکرێنەوە. 
\pm  
\v 11 «زوو دێم. دەست بگرە بەوەی هەتە، تاکو کەس تاجەکەت لێ نەستێنێت.  
\v 12 ئەوەی سەربکەوێت، دەیکەمە کۆڵەکەیەک لەناو پەرستگای خودام و هەرگیز لێی دەرناچێت. ناوی خودای خۆم و ناوی شاری خودای خۆمی لەسەر دەنووسم، ئۆرشەلیمی نوێ، ئەوەی لەلایەن خودای خۆم لە ئاسمانەوە دێتە خوارەوە، هەروەها ناوی نوێی خۆمی لەسەر دەنووسم.  
\v 13 ئەوەی گوێی هەیە، با ببیستێت ڕۆحی پیرۆز چی بە کڵێساکان دەفەرموێ.» 
\s1 نامەیەک بۆ کڵێسای لاودیکییا 
\p  
\v 14 بۆ فریشتەی کڵێساکەی لاودیکییا بنووسە: 
\pm ئەمە پەیامی ئەوەیە کە بە «ئامین»\f + \fr 3:14 \ft ناوێکی تایبەتە بۆ مەسیح.‏\f* ناو دەبردرێت، کە شایەتیدەری دڵسۆز و ڕاستگۆیە و سەرچاوەی بەدیهێنراوەکانی خودایە: 
\b  
\pm  
\v 15 «ئاگام لە کردارەکانتە، تۆ نە سارد و نە گەرمیت. خۆزگە سارد یان گەرم بووای،  
\v 16 بەڵام لەبەر ئەوەی شلەتێنیت، نە ساردیت و نە گەرمیت، بەتەمام لە دەممەوە بتتفێنمەوە.  
\v 17 تۆ دەڵێی: ”دەوڵەمەندم و زەنگین بوومە، پێویستیم بە هیچ نییە.“ بەڵام بێئاگای لەوەی کە بەدبەخت و نەگبەت و هەژار و کوێر و ڕووتیت.  
\v 18 ئامۆژگاریت دەکەم زێڕی بە ئاگر پوختەکراوم لێ بکڕیت تاکو دەوڵەمەند بیت، جلی سپیش تاکو لەبەری بکەیت بۆ ئەوەی شەرمەزاری ڕووتیت دەرنەکەوێت، هەروەها کلیش بۆ ئەوەی لە چاوتی بدەیت هەتا ببینیت. 
\pm  
\v 19 «ئەوانەی خۆشم بوێن سەرزەنشتیان دەکەم و تەمبێیان دەکەم. بۆیە دڵگەرم بە و تۆبە بکە.  
\v 20 ئەوەتا لە بەردەرگا وەستاوم و لە دەرگا دەدەم. ئەگەر یەکێک گوێی لە دەنگم بوو و دەرگاکەی کردەوە، لێی دێمە ژوورەوە و نانی لەگەڵ دەخۆم، ئەویش لەگەڵ من. 
\pm  
\v 21 «ئەوەی سەربکەوێت، لەگەڵ خۆم لەسەر تەختەکەم دایدەنیشێنم، وەک چۆن منیش سەرکەوتنم بەدەستهێنا و لەگەڵ باوکم لەسەر تەختەکەی دانیشتم.  
\v 22 ئەوەی گوێی هەیە، با ببیستێت ڕۆحی پیرۆز چی بە کڵێساکان دەفەرموێ.» 
\c 4  
\s1 بینینی تەختی پاشایانەی خودا 
\p  
\v 1 پاش ئەمە تەماشام کرد دەرگایەکی کراوەم بینی لە ئاسماندا، ئەو دەنگەش کە یەکەم جار وەک کەڕەنا هاتە گوێم\f + \fr 4:1 \ft بڕوانە \xt 1‏:10‏\ft .‏\f*، پێی فەرمووم: «سەربکەوە بۆ ئێرە، ئەوەت پیشان دەدەم کە دوای ئەمە پێویستە ڕووبدات.»  
\v 2 دەستبەجێ ڕۆحی پیرۆزم هاتە سەر و تەختێکم بینی لە ئاسمان دانرابوو، لەسەر تەختەکەش یەکێک دانیشتبوو.  
\v 3 ڕوخساری دانیشتووەکە لە بەردی یەشب و یاقووتی سوور دەچوو، پەلکەزێڕینەیەکیش وەک زمروود لە دەوری تەختەکە دەدرەوشایەوە.  
\v 4 لە دەوری تەختەکەش بیست و چوار تەخت هەبوون، بیست و چوار پیریش کە جلی سپییان پۆشی بوو لەسەر تەختەکان دانیشتبوون و تاجی زێڕینیان لەسەر بوو.  
\v 5 لە تەختەکەوە هەورە بروسکە و دەنگەدەنگ و هەورەگرمە دەهات، لەبەردەم تەختەکەش حەوت چرای ئاگرین دەسووتان، کە حەوت ڕۆحەکەی خودان.  
\v 6 لەبەردەم تەختەکەش شوێنێکی وەک دەریایەکی شووشەیی هەبوو، وەک کریستاڵ. 
\p لە ناوەڕاست، لە دەوروبەری تەختەکە چوار بوونەوەر هەبوون، لەپێش و پاش بە چاو داپۆشرا بوون.  
\v 7 بوونەوەری یەکەم وەک شێر بوو، دووەم بوونەوەر وەک جوانەگا، سێیەم بوونەوەر ڕوخسارێکی وەک مرۆڤی هەبوو، چوارەم بوونەوەر وەک هەڵۆیەکی فڕیو بوو.  
\v 8 چوار بوونەوەرەکە هەریەکەیان شەش باڵی هەبوو، دەوروبەر و ژێر باڵیشیان بە چاو داپۆشرابوو. شەو و ڕۆژ بێ وەستان دەڵێن: 
\qc «پیرۆزە، پیرۆزە، پیرۆزە، 
\qc خودای پەروەردگاری هەرە بەتوانا، 
\qc ئەوەی هەبووە و هەیە و دێت.» 
\m  
\v 9 هەر کاتێک بوونەوەرەکان شکۆ و ڕێز و سوپاسی دانیشتووی سەر تەختەکە دەکەن، کە هەتاهەتایە زیندووە،  
\v 10 بیست و چوار پیرەکەی بەردەم دانیشتووی سەر تەختەکە دەکەون و کڕنۆش بۆ زیندووی هەتاهەتایی دەبەن و تاجەکانیان لەبەردەم تەختەکە فڕێدەدەن و دەڵێن: 
\q1  
\v 11 «ئەی خودای پەروەردگارمان، تۆ شایانی ئەوەی شکۆ و ڕێز و توانا وەربگریت، 
\q2 چونکە تۆ هەموو شتێکت بەدیهێناوە، 
\q2 بە خواستی تۆش هەن و بەدیهێنران.» 
\c 5  
\s1 تۆمار و بەرخە سەربڕدراوەکە 
\p  
\v 1 لەلای ڕاستی دانیشتووی سەر تەختەکەوە تۆمارێکم بینی لەسەر هەردوو ڕووی نووسرا بوو، بە حەوت مۆریش مۆر کرابوو.  
\v 2 هەروەها فریشتەیەکی بەهێزم بینی بە دەنگێکی بەرز هاواری دەکرد: «کێ شایستەی ئەوەیە تۆمارەکە بکاتەوە و مۆرەکانی بشکێنێت؟»  
\v 3 کەس نەبوو، نە لە ئاسمان و نە لەسەر زەوی و نە لەژێر زەوی بتوانێت تۆمارەکە بکاتەوە یاخود تەماشای بکات.  
\v 4 دەستم بە گریانێکی زۆر کرد، چونکە کەس شایستەی ئەوە نەبوو تۆمارەکە بکاتەوە یان تەماشای ناوەوەی بکات.  
\v 5 یەکێک لە پیرەکان پێی گوتم: «مەگریێ، ئەوەتا ئەو شێرەی لە هۆزی یەهودایە و لە ڕەگی داودە\f + \fr 5:5 \ft بڕوانە \xt ڕۆما 15‏:12‏\ft ‏.‏\f* سەرکەوتنی بەدەستهێنا، تۆمارەکە دەکاتەوە و حەوت مۆرەکەی دەشکێنێت.» 
\p  
\v 6 ئینجا لە ناوەڕاستی تەختەکە بەرخێکم بینی وەستا بوو وەک سەربڕدرابێت وابوو، چوار بوونەوەرەکە و پیرەکانیش بەدەوریدا بوون. بەرخەکە حەوت شاخ و حەوت چاوی هەبوو، کە حەوت ڕۆحەکەی خودان بۆ هەموو زەوی نێردراون.  
\v 7 هات و تۆمارەکەی لە دەستی ڕاستی دانیشتووی سەر تەختەکە وەرگرت.  
\v 8 کاتێک تۆمارەکەی وەرگرت، چوار بوونەوەرەکە و بیست و چوار پیرەکە کەوتنە بەردەم بەرخەکە، هەریەکەیان قیسارە و جامی زێڕینی پڕ بخووریان پێبوو، ئەوەش نوێژەکانی گەلی پیرۆزی خودایە،  
\v 9 سروودێکی نوێشیان دەگوت: 
\q1 «تۆ شایستەی ئەوەی تۆمارەکە ببەیت و 
\q2 مۆرەکانی بکەیتەوە، 
\q1 چونکە تۆ سەربڕایت و بە خوێنی خۆت خەڵکت بۆ خودا کڕییەوە، 
\q2 لە هەموو هۆز و زمان و گەل و نەتەوەیەک. 
\q1  
\v 10 ئەوانیشت کردە شانشین و کاهین بۆ خودامان و 
\q2 فەرمانڕەوایەتی زەوی دەکەن.» 
\p  
\v 11 ئینجا تەماشام کرد و گوێم لە دەنگی فریشتەیەکی زۆر بوو لە دەوری تەختەکە و بوونەوەرەکان و پیرەکان، ژمارەیان هەزاران هەزار و دەیان هەزار دە هەزار دەبوو،  
\v 12 بە دەنگێکی بەرز دەیانگوت: 
\q1 «بەرخە سەربڕدراوەکە شایستەی وەرگرتنی 
\q2 توانا و دەوڵەمەندی و دانایی و هێز و 
\q2 ڕێز و شکۆ و ستایشە!» 
\p  
\v 13 هەموو بوونەوەرێکی ئاسمان و زەوی و ژێر زەوی و ناو دەریاش، هەموو ئەوانەی لەوێدا بوون، بیستم دەیانگوت: 
\q1 «با ستایش و ڕێز و شکۆ و توانا، 
\q2 بۆ دانیشتووی سەر تەختەکە و 
\q2 بەرخەکە بێت، هەتاهەتایە!» 
\m  
\v 14 چوار بوونەوەرەکەش دەیانگوت: «ئامین»، پیرەکانیش کەوتن و کڕنۆشیان برد. 
\c 6  
\s1 حەوت مۆرەکە 
\p  
\v 1 سەیرم کرد کە بەرخەکە یەکێک لە حەوت مۆرەکەی کردەوە. ئینجا گوێم لێبوو یەکێک لە چوار بوونەوەرەکە بە دەنگێکی وەک هەورەگرمە گوتی: «وەرە!»  
\v 2 تەماشام کرد و ئەسپێکی سپیم بینی. سوارەکەی کەوانێکی بەدەستەوە بوو و تاجێکی پێدرابوو، بە سەرکەوتنەوە دەرچوو تاکو سەربکەوێت. 
\p  
\v 3 کاتێک بەرخەکە مۆری دووەمی کردەوە، گوێم لە بوونەوەری دووەم بوو گوتی: «وەرە!»  
\v 4 ئەسپێکی دیکەی سووری درەوشاوە هاتە پێشەوە، سوارەکەی دەسەڵاتی پێدرابوو ئاشتی لە زەویدا نەهێڵێت تاکو خەڵک یەکتری بکوژن. هەروەها شمشێرێکی گەورەی پێدرابوو. 
\p  
\v 5 کاتێک بەرخەکە مۆری سێیەمی کردەوە، گوێم لێبوو بوونەوەری سێیەم گوتی: «وەرە!» سەیرم کرد، ئەسپێکی ڕەشم بینی، سوارەکەی تەرازووێکی بەدەستەوە بوو.  
\v 6 گوێم لێبوو دەنگێک لە ناوەڕاستی چوار بوونەوەرەکەدا دەیگوت: «یەک مشت\f + \fr 6:6 \ft نزیکی 1 کیلۆ.‏\f* گەنم بە دینارێک\f + \fr 6:6 \ft دینارێک کرێی ڕۆژانەی کرێکارێک بووە.‏\f*، سێ مشت جۆ بە دینارێک، بەڵام زیان بە ڕۆن و شەرابەکە مەگەیەنە.» 
\p  
\v 7 کاتێک بەرخەکە مۆری چوارەمی کردەوە، گوێم لە دەنگی بوونەوەری چوارەم بوو گوتی: «وەرە!»  
\v 8 تەماشام کرد، ئەسپێکی زەردباوم بینی، سوارەکەی ناوی «مردن» بوو، یەکێکی دیکە بە ناوی «جیهانی مردووان» دوای کەوتبوو. هەردووکیان دەسەڵاتیان پێدرابوو کە چارەکی دانیشتووانی زەوی بە شمشێر و قاتوقڕی و دەرد و بە دڕندە کێوییەکانی زەوی بکوژن. 
\p  
\v 9 کاتێک مۆری پێنجەمی کردەوە، لەژێر قوربانگادا ڕۆحی ئەوانەم بینی لەبەر پەیامی خودا و لەبەر ئەو شایەتییەی لەلایان بوو کوژرابوون.  
\v 10 بە دەنگێکی بەرز هاواریان کرد و گوتیان: «ئەی یەزدانی باڵادەست، پیرۆز و ڕاست، هەتا کەی حوکمیان نادەیت و تۆڵەی خوێنی ئێمە لە دانیشتووانی سەر زەوی ناستێنی؟»  
\v 11 جا هەریەکەیان جلێکی سپییان درایێ و پێیان گوترا ماوەیەک بحەسێنەوە، هەتا بەندە هاوکارەکان و خوشک و براکانیان کە وەک ئەوان دەکوژرێن تەواو دەبن. 
\p  
\v 12 تەماشام کرد کە مۆری شەشەمی کردەوە، بوومەلەرزەیەکی گەورە ڕوویدا و خۆر وەک جلوبەرگی ماتەم ڕەش هەڵگەڕا، مانگیش وەک خوێن سوور هەڵگەڕا و  
\v 13 ئەستێرەکانی ئاسمان کەوتنە زەوی، وەک دار هەنجیر کاتێک بایەکی توند دەیهەژێنێت، بەرەکەی دەکەوێت.  
\v 14 ئاسمان وەک تۆمارێکی لوولکراو لەبەرچاو ون بوو، هیچ چیا و دوورگەیەک لە شوێنی خۆی نەما. 
\p  
\v 15 پاشایانی سەر زەوی و گەورە و سوپاسالار و دەوڵەمەند و بەهێز و هەموو کۆیلە و ئازادێک، خۆیان لە ئەشکەوت و تاشەبەردی چیادا حەشار دا.  
\v 16 بە چیا و بەردیان دەگوت: «بکەونە سەرمان تاکو لە ڕووی دانیشتووی سەر تەختەکە و تووڕەیی بەرخەکە بمانشارنەوە!  
\v 17 چونکە ڕۆژی تووڕەبوونە گەورەکەیان هاتووە و کێ دەتوانێت خۆی ڕابگرێت؟» 
\c 7  
\s1 پاراستنی بەندەکانی خودا 
\p  
\v 1 پاش ئەمە چوار فریشتەم بینی لەسەر هەر چوار گۆشەی زەوی ڕاوەستابوون، چوار بایەکەی زەوییان گرتبوو تاکو بۆ سەر زەوی و سەر دەریا و سەر هیچ درەختێک هەڵنەکەن.  
\v 2 فریشتەیەکی دیکەشم بینی لە ڕۆژهەڵاتەوە دەردەکەوت مۆری خودای زیندووی پێبوو، بە دەنگێکی بەرز بانگی چوار فریشتەکەی کرد کە توانایان پێدرابوو زیان بە زەوی و دەریا بگەیەنن و گوتی:  
\v 3 «زیان بە زەوی و دەریا و درەخت مەگەیەنن هەتا نێوچەوانی بەندەکانی خودامان مۆر دەکەین.»  
\v 4 گوێم لێبوو کە ژمارەی مۆرکراوان لە هەموو هۆزەکانی نەوەی ئیسرائیل سەد و چل و چوار هەزارە. 
\b  
\li1  
\v 5 لە هۆزی یەهودا دوازدە هەزار مۆرکراو، 
\li1 لە هۆزی ڕەئوبێن دوازدە هەزار، 
\li1 لە هۆزی گاد دوازدە هەزار، 
\li1  
\v 6 لە هۆزی ئاشێر دوازدە هەزار، 
\li1 لە هۆزی نەفتالی دوازدە هەزار، 
\li1 لە هۆزی مەنەشە دوازدە هەزار، 
\li1  
\v 7 لە هۆزی شیمۆن دوازدە هەزار، 
\li1 لە هۆزی لێڤی دوازدە هەزار، 
\li1 لە هۆزی یەساخار دوازدە هەزار، 
\li1  
\v 8 لە هۆزی زەبولون دوازدە هەزار، 
\li1 لە هۆزی یوسف دوازدە هەزار، 
\li1 لە هۆزی بنیامین دوازدە هەزار مۆرکراو. 
\s1 خەڵکانێکی سپیپۆش 
\p  
\v 9 پاش ئەمە سەیرم کرد ئاپۆرەیەک لە خەڵکم بینی لە هەموو نەتەوە و هۆز و گەل و زمانێک کە لە ژمارە نەدەهات، لەبەردەم تەختەکە و بەرخەکە ڕاوەستابوون، جلی سپییان لەبەردا بوو و لقە دار خورمایان بەدەستەوە گرتبوو،  
\v 10 بە دەنگێکی بەرز هاواریان دەکرد و دەیانگوت: 
\q1 «ڕزگاری هی خودامانە، 
\q2 کە لەسەر تەختەکە دانیشتووە و 
\q2 هی بەرخەکەیە.» 
\m  
\v 11 هەموو فریشتەکان لە دەوری تەختەکە ڕاوەستابوون، پیرەکان و چوار بوونەوەرەکە، لەبەردەم تەختەکە بە ڕوودا کەوتن و کڕنۆشیان بۆ خودا برد،  
\v 12 دەیانگوت: 
\q1 «ئامین! 
\q1 ستایش و شکۆ و دانایی و 
\q2 سوپاس و ڕێز و هێز و توانا 
\q1 بۆ خودامانە، هەتاهەتایە! 
\q1 ئامین!» 
\p  
\v 13 دوایی یەکێک لە پیرەکان لێی پرسیم: «ئەم سپی پۆشانە کێن و لەکوێوە هاتوون؟» 
\p  
\v 14 منیش پێم گوت: «گەورەم، تۆ دەزانیت.» 
\p پێی گوتم: «ئەمانە ئەوانەن کە لە تەنگانە گەورەکەوە هاتوون و جلەکانیان بە خوێنی بەرخەکە شوشتووە و سپی کردووە.  
\v 15 بۆیە 
\q1 «لەبەردەم تەختی خودان و 
\q2 شەو و ڕۆژ لە پەرستگاکەی خزمەتی دەکەن و 
\q1 دانیشتووی سەر تەختەکەش بە چادر دایاندەپۆشێت. 
\q1  
\v 16 ئیتر نە برسی دەبن و نە تینوو، 
\q2 نە هەتاو لێیان دەدات و نە گەرمی سووتێنەر، 
\q1  
\v 17 چونکە بەرخەکەی ناوەڕاستی تەختەکە شوانایەتییان دەکات و 
\q2 بەرەو کانییەکانی ئاوی ژیانیان دەبات، 
\q1 خوداش هەموو فرمێسکەکانی چاویان دەسڕێتەوە.» 
\c 8  
\s1 مۆری حەوتەم 
\p  
\v 1 کاتێک بەرخەکە مۆری حەوتەمی کردەوە، نیو کاتژمێر بێدەنگییەک ئاسمانی گرتەوە. 
\p  
\v 2 ئەو حەوت فریشتەیەم بینی کە لەبەردەم خودا ڕادەوەستن و حەوت کەڕەنایان پێدرابوو. 
\p  
\v 3 فریشتەیەکی دیکەش هات و لەلای قوربانگاکە وەستا، بخووردانێکی زێڕینی پێبوو. بخوورێکی زۆریشی پێدرابوو تاکو لەگەڵ نوێژی گەلی پیرۆزی خودا لەسەر ئەو قوربانگا زێڕینەی کە لەبەردەم تەختەکەیە پێشکەشی بکات.  
\v 4 لەگەڵ نوێژەکانی گەلی پیرۆزی خودا، دووکەڵی بخوور لە دەستی فریشتەکە لەبەردەم خودا بەرزبووەوە.  
\v 5 فریشتەکەش بخووردانەکەی برد و لە قوربانگاکە پڕی کرد لە ئاگر و فڕێیدایە سەر زەوی. ئیتر بوو بە هەورەگرمە و دەنگەدەنگ و هەورە بروسکە، پاشان بوومەلەرزەیەک ڕوویدا. 
\s1 حەوت کەڕەناکان 
\p  
\v 6 ئیتر ئەو حەوت فریشتەیەی کە حەوت کەڕەناکەیان پێبوو، خۆیان بۆ لێدانی کەڕەنا ئامادە کرد. 
\p  
\v 7 فریشتەی یەکەم کەڕەناکەی لێدا و تەرزە و ئاگری تێکەڵ بە خوێن پەیدابوو، فڕێدرانە سەر زەوی. سێیەکی زەوی سووتا و سێیەکی درەختەکانیش سووتان و هەموو گیایەکی سەوز سووتان. 
\p  
\v 8 فریشتەی دووەم کەڕەناکەی لێدا و شتێک لە شێوەی چیایەکی گەورەی گڕگرتوو فڕێدرایە دەریاوە. سێیەکی دەریاکەش بووە خوێن،  
\v 9 سێیەکی بوونەوەرانی زیندووی دەریاش مردن، سێیەکی کەشتییەکانیش تێکشکان. 
\p  
\v 10 فریشتەی سێیەم کەڕەناکەی لێدا و ئەستێرەیەکی گەورەی پرشنگداری وەک چرا لە ئاسمانەوە کەوتە سەر سێیەکی ڕووبار و سەرچاوەکانی ئاو،  
\v 11 ئەستێرەکەش ناوی زەقنەبووت بوو. سێیەکی ئاو تاڵ بوو، خەڵکانێکی زۆریش لەبەر تاڵی ئاوەکە مردن. 
\p  
\v 12 فریشتەی چوارەمیش کەڕەناکەی لێدا و سێیەکی خۆر و سێیەکی مانگ و سێیەکی ئەستێرەکان لێدران، تاکو سێیەکیان تاریک بن. ڕۆژ سێیەکی تاریک بوو، سێیەکی شەویش بە هەمان شێوە بێ ڕووناکی بوو. 
\p  
\v 13 پاشان تەماشام کرد، بیستم هەڵۆیەکی هەڵفڕیو لە ناوەڕاستی ئاسماندا، بە دەنگێکی بەرز دەیگوت: «قوڕبەسەرتان! قوڕبەسەرتان! ئەی دانیشتووانی سەر زەوی، قوڕبەسەرتان! کاتێک ئەو سێ فریشتەیەی کە خەریکن کەڕەناکانیان لێدەدەن، چی بەسەر زەوی دەهێنن!» 
\c 9  
\p  
\v 1 کاتێک فریشتەی پێنجەم کەڕەناکەی لێدا، تەماشام کرد ئەستێرەیەک لە ئاسمانەوە کەوتە سەر زەوی و کلیلی بیری بێ بنی\f + \fr 9:1 \ft بڕوانە \xt لۆقا 8‏:31‏\ft ‏.‏\f* پێدرابوو.  
\v 2 کاتێک فریشتەکە بیری بێ بنی کردەوە، دووکەڵێک لە شێوەی دووکەڵی کوورەیەکی گەورە لێی بەرزبووەوە و خۆر و ئاسمانی تاریک کرد.  
\v 3 لە دووکەڵەکەوە کوللە بارییە سەر زەوی و توانا و دەسەڵاتێکی وەک توانا و دەسەڵاتی دووپشکی زەوییان پێدرابوو.  
\v 4 کوللەکان فەرمانی ئەوەیان پێدرابوو کە زیان بە گیای زەوی و هیچ سەوزایی و هیچ درەختێک نەگەیەنن، تەنها زیان بەو خەڵکانە بگەیەنن کە مۆری خودایان بە نێوچەوانەوە نییە.  
\v 5 ڕێیان پێنەدرابوو ئەو خەڵکانە بکوژن، بەڵکو پێنج مانگ ئازاریان بدەن. ئازارەکەی وەک ئازاری دووپشکە کاتێک بە مرۆڤەوە دەدات.  
\v 6 لەو ڕۆژانەدا خەڵک بەدوای مردندا دەگەڕێن بەڵام نایدۆزنەوە، حەز لە مردن دەکەن بەڵام مردن لێیان ڕادەکات. 
\p  
\v 7 شێوەی کوللەکان وەک ئەو ئەسپانە بوون کە بۆ شەڕ ئامادە دەکرێن، لەسەر سەریان شتێک لە شێوەی تاجێکی زێڕین هەبوو و ڕوخساریان وەک مرۆڤ بوو.  
\v 8 قژیان لە شێوەی قژی ئافرەت بوو و ددانەکانیشیان وەک ددانی شێر.  
\v 9 زرێیان هەبوو وەک زرێی ئاسنین، دەنگی باڵەکانیان وەک دەنگی ئەو گالیسکانە بوو کە ئەسپێکی زۆری پێوەیە و تاودەدرێن بەرەو جەنگ.  
\v 10 چەند کلکێکی چزووداری وەک دووپشکیان هەبوو، پێنج مانگ توانا و دەسەڵاتی ئەوەیان پێدرابوو کە بە کلکەکانیان ئازاری خەڵک بدەن.  
\v 11 فریشتە بەدکارەکەی بیری بێ بن پاشا بوو بەسەریانەوە، بە عیبری ناوی \tl ئەبەدۆنە‏\tl*\f + \fr 9:11 \ft ئەبەدۆن: لە پەیمانی کۆن، ئەم وشەیە بە (لەناوبەر) وەرگێڕدراوە، بڕوانە \xt ئەیوب 26‏:6‏\ft ‏.‏\f* و بە یۆنانی ناوی \tl ئەپۆلیۆنە‏\tl*. 
\p  
\v 12 نەهامەتی یەکەم نەماوە، دوو نەهامەتی دیکە ماون کە دوای ئەمە دێن. 
\p  
\v 13 پاشان فریشتەی شەشەم کەڕەناکەی لێدا و دەنگێک لە چوار قۆچەکەی قوربانگا زێڕینەکەی بەردەم خوداوە هاتە بەر گوێم،  
\v 14 کە بە فریشتەی شەشەمی دەگوت کە کەڕەناکەی پێبوو: «چوار فریشتە بەستراوەکەی لای ڕووباری گەورەی فورات ئازاد بکە.»  
\v 15 چوار فریشتەکەی ئامادە کرابوون بۆ ئەو کاتژمێر و ڕۆژ و مانگ و ساڵە، ئازاد کران، تاکو سێیەکی ئادەمیزاد بکوژن.  
\v 16 گوێم لێبوو ژمارەی سەربازە سوارەکان دوو هێندەی دە هەزار جار دە هەزار بوو. 
\p  
\v 17 ئەو ئەسپ و سوارانەی کە لە بینینەکەدا بۆم ئاشکرا کران بەم شێوەیە بوون: زرێی ئاگرین و مرواریدار و گۆگردیان هەبوو، سەری ئەسپەکان وەک سەری شێر وابوون و لە دەمیانەوە ئاگر و دووکەڵ و گۆگرد دەردەچوو.  
\v 18 بەو سێ بەڵایە سێیەکی ئادەمیزاد کوژران، بە ئاگر و دووکەڵ و گۆگرد کە لە دەمیانەوە دەردەچوو.  
\v 19 هێزی ئەسپەکان لە دەم و کلکیاندا بوو، چونکە کلکیان وەک مار سەری هەبوو خەڵکیان پێ ئازار دەدا. 
\p  
\v 20 پاشماوەی ئادەمیزاد کە بەو بەڵایانە نەکوژران، تۆبەیان لە کردەی دەستی خۆیان نەکرد. بەردەوام بوون لە کڕنۆشبردن بۆ ڕۆحی پیس و ئەو بتانەی کە لە زێڕ و زیو و بڕۆنز و بەرد و دار دروستکرابوون، کە ناتوانن ببیستن و ببینن و بڕۆن.  
\v 21 هەروەها لە کوشتن و فاڵچیێتی و داوێنپیسی و دزیکردن تۆبەیان نەکرد. 
\c 10  
\s1 فریشتە و تۆمارە بچووکەکە 
\p  
\v 1 پاشان فریشتەیەکی دیکەی بەهێزم بینی لە ئاسمانەوە دەهاتە خوارەوە و بە هەور خۆی پۆشیبوو، پەلکەزێڕینە لەسەر سەری بوو، ڕووی وەک خۆر وابوو، پێیەکانی وەک ستوونی ئاگر وابوون.  
\v 2 تۆمارێکی بچووکی کراوەی بەدەستەوە بوو. پێی ڕاستی لەسەر دەریا و چەپی لەسەر وشکانی دانا.  
\v 3 بە دەنگێکی بەرز وەک نەڕەی شێر نەڕاندی. کاتێک نەڕاندی، حەوت هەورەگرمەکە بە دەنگەکانیان هاتنە دوان.  
\v 4 کاتێک حەوت هەورەگرمەکە هاتنە دوان، بەتەمابووم بنووسم، بەڵام دەنگێکم لە ئاسمانەوە گوێ لێبوو دەیفەرموو: «ئەوەی حەوت هەورەگرمەکە گوتیان مۆری بکە و مەیاننووسە.» 
\p  
\v 5 ئەو فریشتەیەی بینیم لەسەر دەریا و وشکانی ڕاوەستابوو، دەستی ڕاستی بۆ ئاسمان بەرزکردەوە و  
\v 6 سوێندی بە خودای زیندووی هەتاهەتایی خوارد، ئەوەی ئاسمان و زەوی و دەریا و هەموو ئەو شتانەی تێیاندایە بەدییهێناون و گوتی: «چیتر کاتەکە دواناخرێت!  
\v 7 بەڵکو لە ڕۆژانی پێش لێدانی کەڕەنا لەلایەن فریشتەی حەوتەمەوە، پێش ئەوەی دەنگی کەڕەناکە بێت، نهێنی خودا دێتە دی، وەک چۆن خوداش مژدەی بە بەندە پێغەمبەرەکانی دا.» 
\p  
\v 8 ئەو دەنگەی لە ئاسمانەوە گوێم لێبوو دیسان قسەی لەگەڵ کردم و فەرمووی: «بڕۆ تۆمارە کراوەکە لە فریشتە ڕاوەستاوەکەی سەر دەریا و وشکانی وەربگرە.» 
\p  
\v 9 چوومە لای فریشتەکە و پێم گوت کە تۆمارە بچووکەکەم بداتێ. ئەویش پێی گوتم: «بیبە و بیخۆ. گەدەت تاڵ دەکات، بەڵام لە دەمتدا وەک هەنگوین شیرین دەبێت.»  
\v 10 ئەوە بوو تۆمارە بچووکەکەم لە دەستی فریشتەکە وەرگرت و خواردم، لە دەممدا وەک هەنگوین شیرین بوو، بەڵام کە خواردم گەدەی تاڵ کردم.  
\v 11 پاشان پێم گوترا: «دەبێت دووبارە پێشبینی لەسەر خەڵک و نەتەوە و زمان و پاشای زۆر بکەیت.» 
\c 11  
\s1 دوو شایەتەکە 
\p  
\v 1 پاشان قامیشێکی وەک داری پێوانەم پێدرا، خوداش پێی فەرمووم: «هەستە، پەرستگای خودا و قوربانگا بپێوە و ئەو خەڵکانە بژمێرە کە تێیدا کڕنۆش دەبەن.  
\v 2 بەڵام واز لە حەوشەی پەرستگا بهێنە و مەیپێوە، چونکە بە ناجولەکەکان دراوە. ئەوان چل و دوو مانگ شاری پیرۆز پێشێل دەکەن.  
\v 3 هەروەها توانا و دەسەڵات بە دوو شایەتەکەم دەدەم بۆ هەزار و دوو سەد و شەست ڕۆژ بە جلوبەرگی گوشەوە پەیامی خودا ڕابگەیەنن.»  
\v 4 ئەمانە ئەو دوو دار زەیتوونە و ئەو دوو چرادانەن کە لەبەردەم پەروەردگاری جیهاندا ڕاوەستاون.  
\v 5 ئەگەر یەکێک بیەوێت زیانیان پێ بگەیەنێت، ئاگر لە دەمیانەوە دەردەچێت و دوژمنانیان دەخوات. هەر کەسێک بیەوێت زیانیان پێ بگەیەنێت، دەبێت بەم شێوەیە بکوژرێت.  
\v 6 ئەمانە دەسەڵاتی ئەوەیان هەیە کە لە کاتی ڕاگەیاندنی پەیامی خودا ئاسمان دابخەن، تاکو باران نەبارێت. هەروەها دەسەڵاتیان بەسەر ئاودا هەیە کە هەر کاتێک بیانەوێ بیکەنە خوێن و زەوی تووشی هەموو بەڵایەک بکەن. 
\p  
\v 7 کاتێک شایەتییەکەیان تەواو کرد ئەو دڕندەیەی لە بیری بێ بن دێتە دەرەوە، لەگەڵیان دەجەنگێت، دەیانبەزێنێت و دەیانکوژێت.  
\v 8 هەروەها تەرمەکانیان لەسەر شەقامی شارە گەورەکە دەبێت کە ناوی مەجازی سەدۆم و میسرە، لەوێش گەورەکەیان لە خاچ درا.  
\v 9 بۆ ماوەی سێ ڕۆژ و نیو خەڵکانێک لە هەموو گەل و هۆز و زمان و نەتەوەکان تەماشای تەرمەکانیان دەکەن و ناهێڵن تەرمەکانیان بنێژرێن،  
\v 10 هەروەها دانیشتووانی سەر زەوی پێی شاد دەبن و شایی دەگێڕن و دیاری بۆ یەکتری دەنێرن، چونکە ئەم دوو پێغەمبەرە دانیشتووانی سەر زەوییان ئازار دابوو. 
\p  
\v 11 بەڵام پاش سێ ڕۆژ و نیو هەناسەی ژیان لە خوداوە چووە ناویان، ئەوانیش هەستانەوە لەسەر پێیەکانیان و ترسێکی گەورە کەوتە سەر ئەوانەی تەماشایان دەکرد.  
\v 12 دەنگێکی بەرزیشیان لە ئاسمانەوە بیست کە پێی دەفەرموون: «سەربکەونە ئێرە.» ئەوانیش لەبەرچاوی دوژمنانیان لە هەوردا بۆ ئاسمان سەرکەوتن. 
\p  
\v 13 هەر لەو کاتەدا بوومەلەرزەیەکی گەورە ڕوویدا و دەیەکی شارەکە داڕما. حەوت هەزار کەس بە بوومەلەرزەکە کوژران، ئەوانی دیکە ترسان و ستایشی خودای ئاسمانیان کرد. 
\p  
\v 14 نەهامەتی دووەم نەما، ئەوەتا نەهامەتی سێیەم زوو دێت. 
\s1 کەڕەنای حەوتەم 
\p  
\v 15 فریشتەی حەوتەمیش کەڕەناکەی لێدا و چەند دەنگێکی بەرز لە ئاسمانەوە هاتن و گوتیان: 
\q1 «شانشینی جیهان بووەتە شانشینی پەروەردگارمان و مەسیحەکەی\f + \fr 11:15 \ft بڕوانە \xt دانیال 7‏:13‏-14.‏\ft ‏\f*، 
\q2 مەسیحیش بۆ هەتاهەتایە پاشایەتی دەکات.» 
\m  
\v 16 ئەو بیست و چوار پیرەی کە لەبەردەم خودا لەسەر تەختەکانیان دانیشتبوون، خۆیان بە زەویدا دا و کڕنۆشیان بۆ خودا برد،  
\v 17 گوتیان: 
\q1 «سوپاست دەکەین، خودای پەروەردگاری هەرە بەتوانا، 
\q2 ئەوەی هەیە و هەبووە، 
\q1 چونکە هێزە گەورەکەی خۆتت وەرگرت و 
\q2 دەستت بە فەرمانڕەوایی کرد. 
\q1  
\v 18 نەتەوەکان تووڕە بوون، 
\q2 بەڵام کاتی تووڕەیی تۆش هاتووە. 
\q1 کاتی لێپرسینەوەی مردووان هات، 
\q2 بۆ پاداشتکردنی بەندە پێغەمبەرەکانت و 
\q1 گەلە پیرۆزەکەت کە لە ناوی تۆ دەترسن، بە گەورە و بچووکەوە، 
\q2 هەروەها بۆ لەناوبردنی ئەوانەی زەوی لەناودەبەن.» 
\p  
\v 19 پەرستگای خوداش لە ئاسمان کرایەوە و سندوقی پەیمانەکەی لە پەرستگاکەی دەرکەوت. لەوێدا بووە هەورە بروسکە و دەنگەدەنگ و هەورەگرمە و بوومەلەرزە و تەرزەی قەبارە گەورە باری. 
\c 12  
\s1 ژن و ئەژدیها 
\p  
\v 1 نیشانەیەکی گەورەش لە ئاسماندا دەرکەوت: ئافرەتێک خۆری پۆشیبوو، مانگ لەژێر پێیدا و تاجێکی دوازدە ئەستێرەیی لەسەر سەری بوو،  
\v 2 سکی هەبوو، ئازاری هەبوو و لەتاو ژانی منداڵبوون هاواری دەکرد.  
\v 3 نیشانەیەکی دیکەش لە ئاسماندا دەرکەوت: ئەژدیهایەکی گەورەی سوور، حەوت سەر و دە شاخی هەبوو، حەوت تاج لەسەر سەرەکانی بوون.  
\v 4 کلکیشی سێیەکی ئەستێرەی ئاسمانی ڕاکێشا و فڕێیدانە سەر زەوی. ئەژدیهاکە لەبەردەم ئەو ئافرەتەی کە منداڵی دەبوو وەستابوو، بۆ ئەوەی هەرکە منداڵەکە لەدایکبوو بیخوات.  
\v 5 ئیتر منداڵێکی نێرینەی بوو، ئەوەی لە داهاتوودا بە گۆچانێکی ئاسنین فەرمانڕەوایەتی نەتەوەکان دەکات. بەڵام منداڵەکەی بۆ لای خودا و تەختەکەی ڕفێنرا.  
\v 6 ئافرەتەکەش بەرەو چۆڵەوانی ڕایکرد، لەوێدا شوێنێکی هەیە لەلایەن خوداوە ئامادە کراوە، تاکو لەوێ هەزار و دوو سەد و شەست\f + \fr 12:6 \ft دەکاتە چل و دوو مانگ یان سێ ساڵ و نیو. بڕوانە \xt 11‏:2 و 12‏:14‏\ft .‏\f* ڕۆژ بەخێو بکرێت. 
\p  
\v 7 پاشان لە ئاسماندا بووە شەڕ. میکائیل و فریشتەکانی لە دژی ئەژدیهاکە جەنگان، ئەژدیهاکە و فریشتەکانیشی دژی ئەوان،  
\v 8 بەڵام ئەژدیهاکە بەهێز نەبوو، شوێنیان لە ئاسماندا نەما.  
\v 9 ئەژدیهایە گەورەکە فڕێدرایە خوارەوە، مارە دێرینەکە کە بە ئیبلیس و شەیتان ناودەبردرێت، ئەوەی هەموو جیهان گومڕا دەکات، فریشتەکانیشی لەگەڵیدا فڕێدرانە سەر زەوی. 
\p  
\v 10 جا گوێم لە دەنگێکی بەرز بوو لە ئاسماندا دەیفەرموو: 
\q1 «ئێستا ڕزگاری و هێز و شانشینی خودامان و 
\q2 دەسەڵاتی مەسیحەکەی هاتووە، 
\q1 چونکە سکاڵاکار لە خوشک و براکانمان، 
\q2 ئەوەی کە شەو و ڕۆژ لەبەردەم خوداماندا سکاڵای لێیان دەکرد، 
\q2 فڕێدرایە خوارەوە. 
\q1  
\v 11 ئەوان بە خوێنی بەرخەکە و 
\q2 بەو شایەتییەی کە دایان، بەسەریدا سەرکەوتن، 
\q2 ژیانی خۆیان خۆشنەویست و پێشوازییان لە مەرگ کرد. 
\q1  
\v 12 بۆیە ئەی ئاسمان و ئەوانەی تێیدا نیشتەجێن، دڵخۆش بن! 
\q1 بەڵام قوڕبەسەر زەوی و دەریا، 
\q2 چونکە ئیبلیس بۆتان دابەزیوە! 
\q1 تووڕەییەکی گەورەی پێیە، 
\q2 چونکە دەزانێت کاتێکی کورتی هەیە.» 
\p  
\v 13 کاتێک ئەژدیهاکە خۆی بینی فڕێدراوەتە سەر زەوی، ئافرەتەکەی ڕاونا کە کوڕەکەی لێ ببوو.  
\v 14 ئافرەتەکە هەردوو باڵی هەڵۆیەکی گەورەی پێدرا تاکو بۆ چۆڵەوانی و شوێنی خۆی بفڕێت و لەوێدا بۆ ماوەی چل و دوو مانگ دوور لە مارەکە بەخێو بکرێت.  
\v 15 مارەکەش لە دەمیەوە ئاوێکی وەک ڕووباری بەدوای ئافرەتەکەدا فڕێدا بۆ ئەوەی ئاو بیبات.  
\v 16 زەوی یارمەتی ئافرەتەکەی دا، زەوی دەمی کردەوە و ئەو ڕووبارەی قووت دا کە ئەژدیهاکە لە دەمیەوە فڕێیدا.  
\v 17 ئەژدیهاکە لە ئافرەتەکە تووڕە بوو، چوو لەگەڵ نەوەکانی دیکەی بجەنگێت، ئەوانەی ڕاسپاردەکانی خودا بەجێدەگەیەنن و پابەندن بە شایەتییان بۆ عیسا. 
\c 13  
\s1 دەرکەوتنی دڕندەیەک لە دەریا 
\p  
\v 1 ئەژدیهاکەش لەسەر لمی دەریا ڕاوەستا. ئینجا دڕندەیەکم بینی لە دەریاکە دەهاتە دەرەوە، دە شاخ و حەوت سەری هەبوو، دە تاجیش لەسەر شاخەکانی بوون، لەسەر سەرەکانیشی ناوی کفرکردن هەبوو.  
\v 2 ئەو دڕندەیەی بینیم لە پڵنگ دەچوو، پێی وەک ورچ و دەمی وەک دەمی شێر بوو. ئەژدیهاکەش توانا و تەختی خۆی و دەسەڵاتێکی گەورەی دایە دڕندەکە.  
\v 3 سەرێک لە سەرەکانی دڕندەکە وەک بۆ مردن سەربڕابێت، بەڵام برینە کوشندەکەی ساڕێژ ببوو. هەموو زەویش بە سەرسامییەوە بەدوای دڕندەکە کەوتن،  
\v 4 کڕنۆشیان بۆ ئەژدیهاکە برد، چونکە دەسەڵاتی بە دڕندەکە دابوو، کڕنۆشیان بۆ دڕندەکەش برد و گوتیان: «کێ وەک دڕندەکە وایە؟ کێ دەتوانێت لە دژی بجەنگێت؟» 
\p  
\v 5 دڕندەکە دەمێکی پێدرابوو، قسەی گەورە و کفری دەکرد، هەروەها چل و دوو مانگی پێدرابوو تاکو دەسەڵات بەکاربهێنێت.  
\v 6 ئیتر دەمی کردەوە و کفری بە خودا کرد و جنێوی بە ناوی خودا و نشینگەکەی و دانیشتووانی ئاسمان دەدا.  
\v 7 ڕێگەی پێدرابوو لە دژی گەلی پیرۆزی خودا بجەنگێت و بیانبەزێنێت، دەسەڵاتیشی پێدرابوو بەسەر هەموو هۆز و گەل و زمان و نەتەوەیەکدا.  
\v 8 هەموو دانیشتووانی سەر زەویش کڕنۆشی بۆ دەبەن، ئەوانەی ناویان لە پەڕتووکی ژیانی بەرخەکەدا نەنووسراوە، ئەو بەرخەی کە لە دامەزراندنی جیهانەوە سەربڕدراوە. 
\p  
\v 9 ئەوەی گوێی هەیە، با ببیستێت. 
\q1  
\v 10 ئەگەر یەکێک بۆ ڕاپێچکردن بچێت، 
\q2 ڕاپێچ دەکرێت. 
\q1 ئەگەر یەکێک بە شمشێر بکوژرێت، 
\q2 بە شمشێر دەکوژرێت\f + \fr 13:10 \ft \xt یەرمیا 15‏:2.‏\ft ‏\f*. 
\m ئەم بانگەوازە بۆ دانبەخۆداگرتن و دڵسۆزی گەلی پیرۆزی خودایە. 
\s1 دەرکەوتنی دڕندەیەک لە زەوی 
\p  
\v 11 دڕندەیەکی دیکەم بینی لە زەوییەوە دەهاتە دەرەوە، دوو شاخی وەک بەرخی هەبوو، بەڵام وەک ئەژدیها دەدوا.  
\v 12 بە تەواوی دەسەڵاتی دڕندەی یەکەمی بۆ ئەو پەیڕەو دەکرد، وای لە زەوی و دانیشتووانی سەری دەکرد کڕنۆش بۆ دڕندەی یەکەم ببەن، کە برینە کوشندەکەی ساڕێژ ببوو.  
\v 13 نیشانەی گەورەی دەکرد، تەنانەت وای دەکرد لەبەرچاوی خەڵک ئاگر لە ئاسمانەوە بێتە خوارەوە بۆ زەوی.  
\v 14 هەروەها بەو نیشانانەی کە پێی درابوو لە پێناوی دڕندەی یەکەمدا بیکات، دانیشتووانی سەر زەویی گومڕا دەکرد. فەرمانی بە خەڵکی سەر زەوی دا پەیکەرێک بۆ ئەو دڕندەیە دابمەزرێنن کە بە شمشێر بریندار کرا و بە زیندوویی مایەوە.  
\v 15 هەروەها ڕێگەی پێدرابوو هەناسە بداتە پەیکەری دڕندەی یەکەم تاکو پەیکەری دڕندەکە قسە بکات و وا بکات هەموو ئەوانەی کڕنۆش بۆ پەیکەری دڕندەکە نابەن بکوژرێن.  
\v 16 وای لە هەمووانیش دەکرد، گەورە و بچووک، دەوڵەمەند و هەژار، ئازاد و کۆیلە، نیشانەیەک لەسەر دەستی ڕاستیان یان لەسەر ناوچەوانیان دروستبکرێت،  
\v 17 تاکو کەس نەتوانێت کڕین و فرۆشتن بکات، تەنها ئەوە نەبێت نیشانەکەی پێوەیە. نیشانەکەش ناوی دڕندەکەیە یان ژمارەی ناوەکەی. 
\p  
\v 18 ئەمە بانگەوازە بۆ دانایی: ئەوەی تێدەگات، با ژمارەی دڕندەکە لێکبداتەوە، چونکە ئەوە ژمارەی مرۆڤە کە ژمارەکەی شەش سەد و شەست و شەشە\f + \fr 13:18 \ft ژمارەی هێمایی بە واتای کەمکراوەی لە ژمارەی خودا 777 کە ژمارەیەکی تەواوە.‏\f*. 
\c 14  
\s1 بەرخەکە و سروودی جەماوەر 
\p  
\v 1 پاشان بینیم بەرخەکە لەسەر کێوی سییۆن ڕاوەستابوو، سەد و چل و چوار هەزار کەسی لەگەڵ بوو، ناوی ئەو و ناوی باوکی لەسەر ناوچەوانیان\f + \fr 14:1 \ft بڕوانە \xt حزقیێل 9‏:4‏\ft ‏.‏\f* نووسرابوو.  
\v 2 لە ئاسمانەوە دەنگێکم بیست وەک خوڕەی ئاوێکی زۆر و دەنگی هەورەگرمەیەکی گەورە. ئەو دەنگەی کە گوێم لێبوو وەک دەنگی قیسارەش وابوو کە ژەنیاران دەیژەنن.  
\v 3 لەبەردەم تەختەکە و لەبەردەم چوار بوونەوەرەکە و پیرەکان سروودێکی نوێیان دەگوت. کەس نەیدەتوانی سروودەکە فێرببێت جگە لەو سەد و چل و چوار هەزارەی لە زەوییەوە کڕابوونەوە.  
\v 4 ئەوانە ئەو کەسانەن کە خۆیان لەگەڵ ئافرەت گڵاو نەکردووە، چونکە پاکیزەن و بەدوای بەرخەکە دەکەون بۆ هەرکوێ بڕوات. ئەوانە لەنێو خەڵک کڕدراونەتەوە وەک نۆبەرە بۆ خودا و بەرخەکە.  
\v 5 درۆ لە دەمیاندا نادۆزرێتەوە، ئەوان بێ کەموکوڕین. 
\s1 سێ فریشتەکە 
\p  
\v 6 ئینجا فریشتەیەکی دیکەم بینی لە ناوەڕاستی ئاسماندا دەفڕی، مزگێنیی هەتاهەتایی پێبوو، تاکو بۆ دانیشتووانی سەر زەوی ڕابگەیەنێت، بۆ هەموو نەتەوە و هۆز و زمان و گەلێک.  
\v 7 بە دەنگێکی بەرز دەیگوت: «لە خودا بترسن و ستایشی بکەن، چونکە کاتی حوکمدان هاتووە. کڕنۆش بۆ دروستکەری ئاسمان و زەوی و دەریا و کانیاوەکان ببەن.» 
\p  
\v 8 فریشتەی دووەم، لەدوایەوە دەیگوت: «کەوت! بابلی گەورە کەوت، ئەوەی بەم جۆرەی کرد هەموو نەتەوەکان شەرابی تووڕەیی داوێنپیسییەکەی بخۆنەوە.» 
\p  
\v 9 فریشتەی سێیەم، لە دوایانەوە بە دەنگێکی بەرز دەیگوت: «هەرکەسێک کڕنۆش بۆ دڕندەکە و پەیکەرەکەی ببات و نیشانەی سەر نێوچەوانی یان دەستی وەربگرێت،  
\v 10 هەروەها ئەویش شەرابی تووڕەیی خودا دەخواتەوە، کە بە سادەیی لە جامی تووڕەییەکەی ڕژاوە. لەبەردەم فریشتە پیرۆزەکان و بەرخەکەدا بە ئاگر و گۆگرد ئازار دەدرێت.  
\v 11 دووکەڵی ئازاریان بۆ هەتاهەتایە بەرز دەبێتەوە. ئەوانەی کڕنۆش بۆ دڕندەکە و پەیکەرەکەی دەبەن، ئەوەی نیشانەی ناوەکەی وەربگرێت شەو و ڕۆژ پشوویان نابێت.» 
\p  
\v 12 ئەمە بانگەوازە بۆ دانبەخۆداگرتنی گەلی پیرۆزی خودا کە ڕاسپاردەکانی خودا بەجێدەگەیەنن و باوەڕی عیسا دەپارێزن. 
\p  
\v 13 گوێم لە دەنگێک بوو لە ئاسمانەوە دەیگوت: «بنووسە: خۆزگە دەخوازرێت بەو مردووانەی لە ئێستاوە بە یەکبوون لەگەڵ عیسای خاوەن شکۆ دەمرن!» 
\p ڕۆحی پیرۆز دەفەرموێ: «بەڵێ، بۆ ئەوەی لە ماندووبوونیان بحەسێنەوە، چونکە کردەوەکانیان شوێنیان دەکەون.» 
\s1 دروێنەی زەوی 
\p  
\v 14 پاشان تەماشام کرد، هەورێکی سپیم بینی و لەسەر هەورەکە کەسێکی وەک کوڕی مرۆڤ\f + \fr 14:14 \ft بڕوانە \xt دانیال 7‏:13‏\ft ‏.‏\f* دانیشتووە، تاجێکی زێڕینی لەسەر و داسێکی تیژی بەدەستەوە بوو.  
\v 15 فریشتەیەکی دیکە لە پەرستگا هاتە دەرەوە و بە دەنگێکی بەرز بانگی دانیشتووی سەر هەورەکەی کرد: «داسەکەت هەڵگرە و بدروەوە، چونکە کاتی دروێنە هاتووە و بەرهەمی زەوی پێگەیشتووە.»  
\v 16 جا دانیشتووی سەر هەورەکە داسەکەی بۆ سەر زەوی وەشاند و زەوی دروێنە کرا. 
\p  
\v 17 فریشتەیەکی دیکە لە پەرستگاکەی ئاسمان دەرچوو و ئەویش داسێکی تیژی پێبوو.  
\v 18 ئینجا فریشتەیەکی دیکە لە قوربانگاوە هاتە دەرەوە کە دەسەڵاتی بەسەر ئاگردا هەبوو. بە دەنگێکی بەرز بە ئەوەی گوت کە داسە تیژەکەی پێبوو: «داسە تیژەکەت هەڵگرە و هێشووەکانی ڕەزی زەوی کۆبکەرەوە، چونکە ترێیەکەی پێگەیشتووە.»  
\v 19 فریشتەکە داسەکەی وەشاندە زەوی و ڕەزەکانی زەوی ڕنی و فڕێیدایە ناو گوشەرە گەورەکەی تووڕەیی خودا.  
\v 20 گوشەرەکە\f + \fr 14:20 \ft بڕوانە \xt ئیشایا 63‏:3‏\ft ‏.‏\f* لە دەرەوەی شار گوشرا، بە بەرزی لغاوی ئەسپێک، هەزار و شەش سەد ستادیا\f + \fr 14:20 \ft دەکاتە نزیکەی سێ سەد کیلۆمەتر.‏\f* خوێن لە گوشەرەکە دەرچوو. 
\c 15  
\s1 حەوت فریشتە و حەوت دەرد 
\p  
\v 1 پاشان نیشانەیەکی گەورە و سەیری دیکەم لە ئاسماندا بینی: حەوت فریشتە حەوت دەردی کۆتاییان پێبوو، چونکە تووڕەیی خودا لەوانەدا تەواو دەبێت. 
\p  
\v 2 پاشان شتێکی وەک دەریای شووشەیی تێکەڵ بە ئاگرم بینی و ئەوانەی دڕندەکە و پەیکەرەکەی و ژمارەی ناوەکەیان بەزاندبوو لەسەر دەریا شووشەییەکە ڕاوەستابوون و قیسارەی خودایان پێبوو.  
\v 3 سروودی موسای بەندەی خودا و سروودی بەرخەکەیان دەچڕی و دەیانگوت: 
\q1 «ئەی یەزدان، خودای هەرە بەتوانا، 
\q2 کارەکانت گەورە و سەیرە! 
\q1 ئەی پاشای نەتەوەکان، 
\q2 ڕێگاکانت ڕاست و دادپەروەرە. 
\q1  
\v 4 ئەی یەزدان، کێ لە تۆ ناترسێت و 
\q2 ناوت شکۆدار ناکات؟ 
\q1 چونکە تۆ تاقە پیرۆزیت. 
\q1 هەموو نەتەوەکان دێن و کڕنۆشت بۆ دەبەن، 
\q2 چونکە دادپەروەرییەکانت دەرکەوتوون.» 
\p  
\v 5 پاش ئەوە تەماشام کرد و بینیم لە ئاسماندا شوێنی هەرەپیرۆز لە چادری پەیمان کرایەوە.  
\v 6 حەوت فریشتەکە لە پەرستگاکە هاتنە دەرەوە و حەوت دەردەکەیان پێبوو. کەتانی پاک و پرشنگداریان پۆشیبوو و چەند پشتێنێکی زێڕینیان لە سنگ بەستبوو.  
\v 7 یەکێک لە چوار بوونەوەرەکە حەوت جامی زێڕینی پڕ لە تووڕەیی خودای هەمیشە زیندووی دا بە حەوت فریشتەکە.  
\v 8 پەرستگاکەش پڕبوو لە دووکەڵی شکۆ و هێزی خودا و هەتا حەوت دەردەکەی حەوت فریشتەکە تەواو نەبوون، کەس نەیتوانی بچێتە ناو پەرستگاکەوە. 
\c 16  
\s1 حەوت جامی تووڕەیی خودا 
\p  
\v 1 ئینجا لە پەرستگاکەوە گوێم لە دەنگێکی بەرز بوو بە حەوت فریشتەکەی دەفەرموو: «بڕۆن حەوت جامەکەی تووڕەیی خودا بەسەر زەویدا بڕێژن.» 
\p  
\v 2 فریشتەی یەکەم چوو و جامەکەی خۆی بەسەر زەویدا ڕژاند، جا دومەڵی پیس و ئازاربەخش لەوانە دەرکەوت کە نیشانەی دڕندەکەیان هەڵگرتبوو و کڕنۆشیان بۆ پەیکەرەکەی بردبوو. 
\p  
\v 3 فریشتەی دووەمیش جامەکەی خۆی ڕژاندە سەر دەریا و وەک خوێنی مردووی لێهات، هەموو زیندەوەرێکی ناو دەریا مردن. 
\p  
\v 4 فریشتەی سێیەم جامەکەی خۆی ڕژاندە سەر ڕووبار و کانیاوەکان، بووە خوێن.  
\v 5 گوێم لە فریشتەی ئاوەکان بوو دەیگوت: 
\q1 «تۆ دادپەروەریت، ئەی ئەوەی هەیە و هەبووە، پیرۆزەکە، 
\q2 چونکە ئاوا حوکمت داوە، 
\q1  
\v 6 چونکە ئەوانە خوێنی پێغەمبەران و گەلی پیرۆزی تۆیان ڕشتووە، 
\q2 تۆش خوێنت پێدان بیخۆنەوە، چونکە شایانی ئەوەن.» 
\m  
\v 7 گوێم لە دەنگێک بوو لە قوربانگاکەوە دەیگوت: 
\q1 «بەڵێ ئەی خودای پەروەردگاری هەرە بەتوانا، 
\q2 حوکمەکانت ڕاست و دادپەروەرن.» 
\p  
\v 8 فریشتەی چوارەم جامەکەی خۆی ڕژاندە سەر خۆر و ڕێگە بە خۆر درابوو کە خەڵکی بە ئاگر بسووتێنێت.  
\v 9 خەڵک بە گەرمایەکی بەتین سووتان، کفریان بە ناوی خودا کرد، ئەوەی دەسەڵاتی بەسەر ئەم دەردانەدا هەیە، بەڵکو تۆبەیان نەکرد تاکو شکۆداری بکەن. 
\p  
\v 10 فریشتەی پێنجەم جامەکەی ڕژاندە سەر تەختی دڕندەکە، شانشینەکەی تاریک بوو، خەڵکی شانشینەکە لەتاو ئازار زمانی خۆیان دەگەست.  
\v 11 لەتاو ئازار و برینیان کفریان بە خودای ئاسمان کرد بەڵام تۆبەیان لە کردەوەکانیان نەکرد. 
\p  
\v 12 فریشتەی شەشەم جامەکەی ڕژاندە سەر ڕووباری گەورەی فورات، ئیتر ئاوەکە وشکی کرد، تاکو ڕێگای پاشاکانی ڕۆژهەڵات خۆش بکات.  
\v 13 ئینجا سێ ڕۆحی پیسی وەک بۆقم بینی لە دەمی ئەژدیهاکە و دەمی دڕندەکە و دەمی پێغەمبەرە درۆزنەکە دەهاتنە دەرەوە.  
\v 14 ئەوانە ڕۆحی شەیتانین کە پەرجوو دەکەن، دەچنە لای پاشاکانی هەموو جیهان، تاکو لەو ڕۆژە گەورەیەی خودای هەرە بەتوانادا بۆ جەنگ کۆیان بکەنەوە. 
\b  
\mi  
\v 15 مەسیح دەفەرموێ: «ئەوەتا وەک دزێک دێم! خۆزگە دەخوازرێت بەوەی ئێشک دەگرێت و جلوبەرگەکانی دەپارێزێت، نەوەک ئابڕووی ببینرێت و بە ڕووتی بڕوات.»\f + \fr 16:15 \ft بڕوانە \xt مەتا 24‏:36‏-44.‏\ft ‏\f* 
\b  
\m  
\v 16 پاشان ڕۆحەکان لە شوێنێکدا کۆی کردنەوە کە بە عیبری پێی دەگوترێ «هارمەگیدۆن\f + \fr 16:16 \ft عیبری: چیای مەگیدۆ، بڕوانە \xt ڕابەران 5‏:19‏\ft ‏.‏\f*». 
\p  
\v 17 فریشتەی حەوتەم جامەکەی خۆی بە هەوادا ڕژاند، دەنگێکی بەرز لە پەرستگاکە و لە تەختەکەوە هات و گوتی: «هاتە دی!»  
\v 18 پاشان هەورە بروسکە و دەنگەدەنگ و هەورەگرمە پەیدابوو، بوومەلەرزەیەکی گەورە ڕوویدا، تەنانەت لەو کاتەوەی خەڵک لەسەر زەوین شتی وا ڕووی نەداوە. بوومەلەرزەکە زۆر بەهێز بوو.  
\v 19 شارە گەورەکە بووە سێ بەش، شارەکانی نەتەوەکانیش کەوتن. خوداش بابلی گەورەی بەبیر هاتەوە تاکو جامی شەرابی تووڕەیی هەڵچووی خۆی بداتێ.  
\v 20 هەموو دوورگەکان ڕایانکرد و چیاکان نەدۆزرانەوە.  
\v 21 تەرزەیەکی گەورە کە قورساییەکەی یەک \tl تالنت‏\tl*\f + \fr 16:21 \ft یەک \+tl تالنت‏\+tl*، نزیکەی سی و چوار کیلۆگرامە.‏\f* دەبوو لە ئاسمانەوە بەسەر خەڵکیدا باری، لەتاو لێدانی تەرزەکە کفریان بە خودا کرد، چونکە لێدانەکەی زۆر توند بوو. 
\c 17  
\s1 بابل دایکی داوێنپیسانە 
\p  
\v 1 ئینجا یەکێک لەو حەوت فریشتەیەی حەوت جامەکەیان پێبوو پێی گوتم: «وەرە با سزای لەشفرۆشە گەورەکەت پیشان بدەم کە لەسەر ڕووبارێکی زۆر دانیشتووە.  
\v 2 ئەوەی پاشاکانی زەوی داوێنپیسییان لەگەڵ کردووە و دانیشتووانی سەر زەوی بە شەرابی داوێنپیسییەکەی سەرخۆش بوون.» 
\p  
\v 3 پاشان فریشتەکە بە ڕۆحی پیرۆز بردمییە چۆڵەوانی. بینیم ژنێک لەسەر دڕندەیەکی قرمزی دانیشتووە کە بە ناوی کفر داپۆشرابوو. دڕندەکە حەوت سەر و دە شاخی هەبوو.  
\v 4 ژنەکە جلوبەرگی ئەرخەوانی و قرمزی لەبەر کرابوو، هەروەها بە زێڕ و بەردی گرانبەها و مرواری ڕازێنرابووەوە. جامێکی زێڕینی بەدەستەوە بوو، پڕ لە قێز و گڵاوی داوێنپیسییەکەی.  
\v 5 لەسەر ناوچەوانیشی ناوێکی نهێنی نووسرابوو: 
\pc «بابلی گەورە، 
\pc دایکی لەشفرۆشان و 
\pc قێزەونانی زەوی.» 
\m  
\v 6 هەروەها بینیم کە ژنەکە بە خوێنی گەلی پیرۆزی خودا و خوێنی شەهیدانی عیسا سەرخۆش ببوو. 
\p بە بینینی زۆر سەرسام بووم.  
\v 7 فریشتەکە پێی گوتم: «بۆ سەرسام بوویت؟ نهێنی ژنەکە و ئەو دڕندەیەشت پێ دەڵێم کە هەڵیگرتووە و حەوت سەر و دە شاخی هەیە.  
\v 8 ئەو دڕندەیەی بینیت هەبووە و ئێستا نییە، خەریکە لە بیری بێ بن دەردەچێت و بۆ لەناوچوون دەڕوات. دانیشتووانی سەر زەوی، ئەوانەی لە دامەزراندنی جیهانەوە ناویان لە پەڕتووکی ژیاندا نەنووسراوە، کاتێک دڕندەکە دەبینن سەرسام دەبن، چونکە دڕندەکە پێشتر هەبووە و ئێستا نییە، بەڵام لە داهاتوودا دێتەوە. 
\p  
\v 9 «ئەمە بانگەوازە بۆ مێشکی دانا: حەوت سەرەکە حەوت گردن\f + \fr 17:9 \ft مەبەست لە شاری ڕۆمایە کە لەسەر حەوت گرد بنیاد نراوە.‏\f* کە ژنەکە لەسەریان دانیشتووە.  
\v 10 حەوت پاشاکەش، پێنجیان کەوتن و یەکێکیان هەیە و ئەوی دیکە هێشتا نەهاتووە، کاتێکیش دێت پێویستە کەمێک بمێنێتەوە.  
\v 11 ئەو دڕندەیەی هەبووە و ئێستا نییە هەشتەمینە، بەڵام لە حەوتەکەیە و بۆ لەناوچوون دەڕوات. 
\p  
\v 12 «ئەو دە شاخەی بینیت دە پاشان، هێشتا شانشینیان وەرنەگرتووە، بەڵام بۆ ماوەی یەک کاتژمێر لەگەڵ دڕندەکە وەکو پاشا دەسەڵات وەردەگرن.  
\v 13 ئەوانە یەک مەبەستیان هەیە، هێز و دەسەڵاتی خۆیان دەدەنە دڕندەکە.  
\v 14 ئەوانە لەگەڵ بەرخەکە دەجەنگن و بەرخەکە دەیانبەزێنێت، چونکە گەورەی گەورانە و پاشای پاشایانە، ئەوانەی لەگەڵیدان بانگکراو و هەڵبژێردراو و دڵسۆزن.» 
\p  
\v 15 ئینجا پێی گوتم: «ئەو ئاوانەی بینیت، کە لەشفرۆشەکە لەوێ دانیشتووە، گەل و خەڵک و نەتەوە و زمانن.  
\v 16 دە شاخەکە و دڕندەکەی کە بینیت، ڕق لە لەشفرۆشەکە هەڵدەگرن، وێران و ڕووتی دەکەنەوە، گۆشتەکەی دەخۆن و بە ئاگر دەیسووتێنن،  
\v 17 چونکە خودا خستوویەتییە دڵیان کە مەبەستی ئەو جێبەجێ بکەن و ڕێک بکەون، دەسەڵاتیان بدەنە دڕندەکە، هەتا وشەکانی خودا بێتە دی.  
\v 18 ئەو ژنەی بینیشت ئەو شارە گەورەیە کە دەسەڵاتی بەسەر پاشاکانی زەویدا هەیە.» 
\c 18  
\s1 کەوتنی بابل 
\p  
\v 1 پاش ئەوەش فریشتەیەکی دیکەم بینی لە ئاسمانەوە دەهاتە خوارەوە و دەسەڵاتێکی گەورەی هەبوو، زەویش بە شکۆی ئەو ڕووناک بووەوە.  
\v 2 بە دەنگێکی بەرز هاواری کرد و گوتی: 
\q1 «کەوت! بابلی گەورە کەوت! 
\q2 بووە جێنشینی جنۆکەکان و 
\q1 پەناگای هەموو ڕۆحە پیسەکان، 
\q2 پەناگای هەموو باڵندەیەکی گڵاو، 
\q2 پەناگای هەموو ئاژەڵێکی گڵاو و قێزەون. 
\q1  
\v 3 لەبەر ئەوەی هەموو نەتەوەکان 
\q2 لە شەرابێکی زۆری داوێنپیسی ئەویان خواردووەتەوە. 
\q1 پاشاکانی زەوی داوێنپیسییان لەگەڵدا کردووە، 
\q2 بازرگانانی زەویش بە توانای سەڵتەنەتی ئەو دەوڵەمەند بوون.» 
\p  
\v 4 گوێم لە دەنگێکی دیکە بوو لە ئاسمانەوە دەیفەرموو: 
\q1 «ئەی گەلی من لێی دەربچن، 
\q2 تاکو بەشداری لە گوناهەکانی نەکەن، 
\q2 تاکو دەردەکانی نەگرن، 
\q1  
\v 5 چونکە گوناهەکانی تاکو ئاسمان بەرزبوونەوە و 
\q2 خوداش خراپی ئەوی بە یاد هاتەوە. 
\q1  
\v 6 سزای بدەنەوە وەک ئەویش سزای دایەوە و 
\q2 بەگوێرەی کردارەکانی خۆی دووقاتی بدەنەوە، 
\q2 لەو جامەی تێیدا تێکەڵی کرد دووقاتی بۆ تێکەڵ بکەنەوە. 
\q1  
\v 7 هێندەی ئەوەی کە خۆی بە گەورە داناوە و خۆش ڕایبواردووە، 
\q2 ئازار و خەمی بدەنێ، چونکە لە دڵی خۆیدا دەڵێت: 
\q1 ”من وەک شاژن دانیشتووم و بێوەژن نیم، 
\q2 هەرگیز شیوەن ناگێڕم.“ 
\q1  
\v 8 لەبەر ئەوە دەردەکانی لە ڕۆژێکدا دێن، 
\q2 مردن و شیوەن و قاتوقڕی. 
\q1 بە ئاگریش دەسووتێت، 
\q2 خودای پەروەردگار ئەوەی حوکمی دەدات، بەهێزە. 
\s1 سێ جار قوڕبەسەری بۆ بابل 
\p  
\v 9 «پاشاکانی زەوی، ئەوانەی لەگەڵیدا داوێنپیسییان کردووە و لە ژیاندا خۆشیان ڕابواردووە، کاتێک دووکەڵی سووتانەکەی دەبینن بۆی دەگریێن و شیوەنی بۆ دەگێڕن.  
\v 10 لە ترسی ئازارەکەی لە دوور دەوەستن و دەڵێن: 
\q1 «”ئەی شارە مەزنەکە، قوڕت بەسەر، قوڕت بەسەر! 
\q2 ئەی بابل، شارە بەهێزەکە! 
\q2 چونکە لە کاتژمێرێکدا سزادانت هات.“ 
\p  
\v 11 «بازرگانانی زەوی دەگریێن و شیوەنی بۆ دەگێڕن، چونکە ئیتر کەس شتومەکیان لێ ناکڕێت،  
\v 12 شتومەکی زێڕ و زیو و بەردی گرانبەها و مرواری، کەتانی ناسک و ئەرخەوانی و حەریر و قرمز، هەموو دارێکی بۆندار و هەموو شتێکی دروستکراو لە عاج و هەموو قاپێک لە داری گرانبەها، بڕۆنز و ئاسن و مەڕمەڕ،  
\v 13 دارچین و بۆنوبەرام و بخوور و موڕ و لبان\f + \fr 18:13 \ft جۆرێکی تایبەتە لە بخوور و لە دار دروستدەکرێ.‏\f*، شەراب و ڕۆنی زەیتوون و باشترین ئارد و گەنم، مەڕوماڵات، ئەسپ و گالیسکە و مرۆڤی وەک کۆیلە فرۆشراو.» 
\p  
\v 14 دەڵێن: «بەرهەمی شەیدای دڵت لە دەست چوو، هەموو دەوڵەمەندی و سەڵتەنەتت لێ بڕا و ئیتر هەرگیز نایاندۆزیتەوە.»  
\v 15 بازرگانانی ئەم شتانە کە بەهۆی ئەوەوە دەوڵەمەند بوون، لە ترسی ئازارەکەی لە دوور دەوەستن، دەگریێن و شیوەنی بۆ دەگێڕن و  
\v 16 دەڵێن: 
\q1 «”قوڕت بەسەر! قوڕت بەسەر، ئەی شارە گەورەکە، 
\q2 کە بە کەتانی ناسک و ئەرخەوانی و قرمز پۆشرابوویت، 
\q2 بە زێڕ و بەردی گرانبەها و مرواری ڕازابوویتەوە! 
\q1  
\v 17 چونکە لە یەک کاتژمێردا دەوڵەمەندییەکی ئاوا لەدەست چوو!“ 
\p «هەموو کەشتیوانان و گەشتیاران و کرێکارانی نێو کەشتی، لەگەڵ هەموو ئەوانەی لە دەریادا کار دەکەن، لە دوور دەوەستن.  
\v 18 کاتێک چاویان بە دووکەڵی سووتانەکەی دەکەوێت، هاوار دەکەن و دەڵێن: ”چ شارێک وەکو شارە گەورەکەیە؟“  
\v 19 خۆڵ بە سەری خۆیاندا دەکەن، بە گریان و شیوەنەوە هاوار دەکەن و دەڵێن: 
\q1 «”قوڕت بەسەر! قوڕت بەسەر، ئەی شارە گەورەکە! 
\q2 ئەوەی هەموو خاوەن کەشتی دەریا بە سامانەکەی دەوڵەمەند بوون! 
\q1 لە کاتژمێرێکدا بەفیڕۆ چوو! 
\b  
\q1  
\v 20 «”ئەی ئاسمان و گەلی پیرۆزی خودا و نێردراوان و پێغەمبەران پێی دڵشاد بن! 
\q2 چونکە خودا لە بەرژەوەندی ئێوە حوکمی ئەوی دا.“» 
\s1 دوایین کەوتنی بابل 
\p  
\v 21 ئینجا فریشتەیەکی بەهێز بەردێکی هەڵگرت، وەک بەردی ئاش گەورە بوو، فڕێیدایە دەریاوە و گوتی: 
\q1 «ئاوا بە توندی شاری بابلی گەورە فڕێدەدرێت، 
\q2 هەرگیز نادۆزرێتەوە. 
\q1  
\v 22 ئیتر دەنگی ژەنیارانی قیسارە و مۆسیقا و شمشاڵ و کەڕەنا 
\q2 تێیدا نابیسترێت. 
\q1 هەرگیز وەستای هیچ پیشەیەکیش لە تۆدا نادۆزرێتەوە، 
\q2 دەنگی ئاش لە تۆدا نابیسترێت. 
\q1  
\v 23 هیچ چرایەک تێیدا هەڵناکرێت، 
\q2 ئیتر دەنگی بووک و زاوا تێیدا نابیسترێت. 
\q1 بازرگانەکانت گەورەی زەوی بوون و 
\q2 هەموو نەتەوەکان بە جادووگەریی تۆ گومڕابوون. 
\q1  
\v 24 تێیدا خوێنی پێغەمبەران و گەلی پیرۆزی خودا و 
\q2 هەموو ئەوانەی لەسەر زەویدا کوژران دۆزراونەتەوە.» 
\c 19  
\s1 هەلیلویا! حوکمڕانی بۆ یەزدان 
\p  
\v 1 پاش ئەوەش گوێم لە دەنگێکی گەورە بوو وەک دەنگی خەڵکانێکی زۆر لە ئاسمانەوە دەیگوت: 
\q1 «هەلیلویا! 
\q1 ڕزگاری و شکۆ و هێز بۆ خودامانە، 
\q2  
\v 2 چونکە حوکمەکانی ڕاست و دادپەروەرن. 
\q1 لەشفرۆشە گەورەکەی تاوانبار کرد 
\q2 کە بە داوێنپیسییەکەی زەویی گەندەڵ دەکرد. 
\q2 تۆڵەی خوێنی بەندەکانی خۆی لێکردەوە.» 
\p  
\v 3 دووبارە گوتیانەوە: 
\q1 «هەلیلویا! 
\q1 دووکەڵەکەی بۆ هەتاهەتایە بەرز دەبێتەوە.» 
\p  
\v 4 بیست و چوار پیرەکە و چوار بوونەوەرەکە کەوتنە سەر چۆک و کڕنۆشیان بۆ خودای دانیشتووی سەر تەختەکە برد و گوتیان: 
\q1 «ئامین. هەلیلویا!» 
\p  
\v 5 دەنگێک لەلای تەختەکەوە هات و گوتی: 
\q1 «ستایشی خودامان بکەن ئەی هەموو بەندەکانی، 
\q2 ئەوانەی لێی دەترسن، گەورە و بچووک.» 
\p  
\v 6 پاشان گوێم لە دەنگێک بوو وەک دەنگی خەڵکێکی ئێجگار زۆر، وەک دەنگی خوڕەی ئاوێکی زۆر و وەک دەنگی هەورەگرمەی بەهێز بوو، دەیگوت: 
\q1 «هەلیلویا! 
\q2 خودای پەروەردگارمان هەرە بەتوانایە، حوکومڕانی دەکات. 
\q1  
\v 7 با دڵخۆش و شاد بین، شکۆداری بکەین، 
\q2 چونکە زەماوەندی بەرخەکە هاتووە و 
\q1 بووکەکەی خۆی ئامادە کردووە. 
\q2  
\v 8 کراسێکی کەتانی ناسکی پاک و پرشنگداری پێدرابوو لەبەری بکات.» 
\m ئەم کەتانە ناسکە هێمای کردارە ڕاستودروستەکانی گەلی پیرۆزی خودایە. 
\b  
\p  
\v 9 پێی گوتم: «بنووسە: خۆزگە دەخوازرێت بەوانەی بۆ خوانی زەماوەندی بەرخەکە بانگهێشت کراون!» هەروەها پێی گوتم: «ئەمانە وشە ڕاستەکانی خودان.» 
\p  
\v 10 کەوتمە بەرپێی تاکو کڕنۆشی بۆ ببەم. بەڵام پێی گوتم: «وا مەکە! منیش لەگەڵ تۆ و خوشک و برایانت بەندەی هاوکارم، ئەوانەی پابەندن بە شایەتییان بۆ عیسا. کڕنۆش بۆ خودا ببە! چونکە ئەو ڕۆحەی کە سروشی بە پێغەمبەرەکان داوە، هەر ئەو شایەتی بۆ مەسیح دەدات.» 
\s1 سواری ئەسپێکی سپی 
\p  
\v 11 پاشان ئاسمانم بە کراوەیی بینی، ئەسپێکی سپیم بینی و سوارەکەی بە «دڵسۆز» و «ڕاستگۆ» ناودەبردرا. بە دادپەروەری حوکم دەدات و دەجەنگێت.  
\v 12 چاوەکانی وەک گڕی ئاگر وابوون و ژمارەیەکی زۆر تاجی بە سەرەوە بوو. ناوێکی نووسراوی هەیە کە جگە لە خۆی کەس نایزانێت.  
\v 13 کەوایەکی لە خوێن هەڵکێشراوی\f + \fr 19:13 \ft بڕوانە \xt ئیشایا 63‏:3‏\ft ‏.‏\f* لەبەربوو، ئەو ناوەی پێی بانگ دەکرێ «وشەی خودا»یە.  
\v 14 لەشکرەکانی ئاسمان بە سواری ئەسپی سپی شوێنی دەکەوتن و کەتانی ناسکی سپی پاکیان لەبەردا بوو.  
\v 15 لە دەمیەوە شمشێرێکی تیژ دەردەچوو، تاکو پێی لە نەتەوەکان بدات. ﴿بە گۆچانێکی ئاسنین شوانایەتییان دەکات.﴾\f + \fr 19:15 \ft بڕوانە \xt زەبوورەکان 2‏:9.‏\ft ‏\f* گوشەری شەرابی تووڕەیی هەڵچووی خودای هەرە بەتوانا دەگوشێت.  
\v 16 ناوێکی هەیە لەسەر کەوا و ڕانی نووسراوە: 
\pc «پاشای پاشایان و گەورەی گەورەیان.» 
\p  
\v 17 فریشتەیەکی دیکەم بینی لەبەر خۆردا ڕاوەستابوو، بە دەنگێکی بەرز هاواری لە هەموو باڵندە فڕیوەکانی ناوەڕاستی ئاسمان کرد و گوتی: «وەرن کۆببنەوە، بۆ شێوی گەورەی خودا،  
\v 18 تاکو گۆشتی پاشاکان و گۆشتی سوپاسالارەکان و گۆشتی بەهێزان، گۆشتی ئەسپەکان و سوارەکانیان، گۆشتی هەمووان، ئازاد و کۆیلە، گەورە و بچووک بخۆن.» 
\p  
\v 19 هەروەها دڕندەکە و پاشاکانی زەوی و لەشکرەکانیانم بینی کۆببوونەوە، تاکو لە دژی سوارەکە و سوپاکەی بجەنگن.  
\v 20 دڕندەکە و پێغەمبەرە درۆزنەکەی یاوەری دەستگیر کران، ئەوەی نیشانەکانی لە پێناوی کرد و بەهۆیەوە ئەوانەی چەواشە کرد کە نیشانەی دڕندەکەیان وەرگرت و ئەوانەی کڕنۆشیان بۆ پەیکەرەکەی برد. هەردووکیان بە زیندوویی فڕێدرانە نێو دەریاچەی ئاگرەوە، کە بە گۆگرد داگیرساوە.  
\v 21 پاشماوەکە بە شمشێری سوارەکە کوژران کە لە دەمیەوە دەردەچوو، هەموو باڵندەکان لە گۆشتەکانیان تێربوون. 
\c 20  
\s1 دەستگیرکردنی شەیتان 
\p  
\v 1 فریشتەیەکم بینی لە ئاسمانەوە دەهاتە خوارەوە و کلیلی بیری بێ بنی پێبوو، زنجیرێکی گەورەشی بەدەستەوە بوو.  
\v 2 ئەژدیهاکەی دەستگیر کرد، مارە دێرینەکە کە ئیبلیس و شەیتانە، هەزار ساڵ بەستییەوە.  
\v 3 فڕێیدایە بیری بێ بن و دەرگای لەسەر داخست و مۆرێکی لێدا، بۆ ئەوەی ئیتر نەتەوەکان چەواشە نەکات، هەتا هەزار ساڵەکە تەواو دەبێت. پاش ئەمە دەبێت بۆ ماوەیەکی کەم ئازاد بکرێت. 
\s1 حوکمی هەزار ساڵەی مەسیح 
\p  
\v 4 چەند تەختێکم بینی و ئەوانەی لەسەری دانیشتن دەسەڵاتی حوکمدانیان پێدرابوو. هەروەها گیانی ئەوانەم بینی کە لەبەر شایەتی عیسا و لەبەر وشەی خودا سەربڕابوون، ئەوانە کڕنۆشیان بۆ دڕندەکە و پەیکەرەکەی نەبردبوو، نیشانەی نێوچەوان و سەر دەستیان وەرنەگرتبوو. جا زیندووبوونەوە و هەزار ساڵ لەگەڵ مەسیحدا فەرمانڕەواییان کرد.  
\v 5 (بەڵام مردووەکانی دیکە هەتا هەزار ساڵەکە تەواو بوو بۆ ژیان نەگەڕانەوە. ئەمە هەستانەوەی یەکەمە.)  
\v 6 ئەوەی لە هەستانەوەی یەکەمدا بەشی هەبێت بەرەکەتدار و پیرۆزە. ئەوانە مردنی دووەم دەسەڵاتی بەسەریاندا نییە، بەڵکو دەبنە کاهینی خودا و مەسیح، هەزار ساڵ لەگەڵیدا فەرمانڕەوایەتی دەکەن. 
\s1 کەوتنی شەیتان 
\p  
\v 7 کاتێک هەزار ساڵەکە تەواو دەبێت شەیتان لە بەندیخانە ئازاد دەکرێت و  
\v 8 دێتە دەرەوە تاکو نەتەوەکانی چوارگۆشەی زەوی چەواشە بکات، گۆگ و ماگۆگ\f + \fr 20:8 \ft بڕوانە \xt حزقیێل 38‏\ft ‏ و 39، هێمایە بۆ ئەو نەتەوانەی لە دژی خودان.‏\f*، تاکو بۆ جەنگ کۆیان بکاتەوە، ئەوانەی ژمارەیان وەک لمی دەریایە.  
\v 9 بەسەر پانتایی زەویدا بڵاو بوونەوە و ئۆردوگای گەلی خودا، واتا شارە خۆشەویستەکەی خودایان گەمارۆ دا، بەڵام ئاگر لە ئاسمانەوە هاتە خوارەوە و هەڵیلووشین.  
\v 10 ئەو ئیبلیسەی چەواشەی دەکردن فڕێدرایە دەریاچەی ئاگر و گۆگرد، کە دڕندەکە و پێغەمبەرە درۆزنەکەی لێیە. هەتاهەتایە شەو و ڕۆژ ئازار دەدرێن. 
\s1 حوکمدانی مردووان 
\p  
\v 11 پاشان تەختێکی گەورەی سپیم بینی و ئەوەی لەسەری دانیشتبوو. ئاسمان و زەوی لەبەر ڕووی هەڵاتن، شوێنیان لە ئاسماندا نەما.  
\v 12 مردووەکانم بینی بە گەورە و بچووکەوە لەبەردەم تەختەکەدا ڕاوەستابوون و پەڕتووکەکان کرانەوە. پەڕتووکێکی دیکەش کە پەڕتووکی ژیانە کرابووەوە. مردووەکان بەگوێرەی کردەوەکانیان بەوەی لە پەڕتووکەکان نووسراوە حوکم دران.  
\v 13 دەریاش مردووەکانی ناوخۆی ڕادەست کرد، هەروەها مردن و جیهانی مردووان مردووەکانی خۆیان ڕادەست کرد و هەریەکە و بەگوێرەی کردەوەکانی حوکم درا.  
\v 14 مردن و جیهانی مردووان فڕێدرانە دەریاچە ئاگرەکە. ئەم دەریاچە ئاگرە مردنی دووەمە.  
\v 15 هەرکەسێک ناوی لە پەڕتووکی ژیاندا تۆمار نەکرابوو، فڕێدرایە دەریاچە ئاگرەکە. 
\c 21  
\s1 ئاسمانێکی نوێ و زەوییەکی نوێ 
\p  
\v 1 پاشان ئاسمانێکی نوێ و زەوییەکی نوێم بینی، چونکە ئاسمانی یەکەم و زەوی یەکەم بەسەرچوون، ئیتر دەریاش نەما.  
\v 2 شارە پیرۆزەکەش، ئۆرشەلیمی نوێم بینی لە ئاسمانەوە لەلایەن خوداوە دەهاتە خوارەوە، وەک بووکێکی ڕازاوە بۆ زاواکەی ئامادە کرابێت.  
\v 3 گوێم لە دەنگێکی گەورە بوو لە تەختەکەوە فەرمووی: «ئەوەتا نشینگەی خودا لەگەڵ خەڵک، ئەویش لەگەڵیان نیشتەجێ دەبێت. ئەوانیش دەبن بە گەلی ئەو، خودا خۆی لەگەڵیاندایە و دەبێتە خودای ئەوان.  
\v 4 ئەویش هەموو فرمێسکێکی چاویان دەسڕێتەوە، ئیتر مردن نابێت، شیوەن و هاوار و ئازار نامێنن، چونکە شتەکانی پێشوو بەسەرچوون.» 
\p  
\v 5 دانیشتووی سەر تەختەکە فەرمووی: «ئەوەتا هەموو شتێک نوێ دەکەمەوە.» پاشان فەرمووی: «بنووسە، چونکە ئەم وتانە متمانەدار و ڕاستن.» 
\p  
\v 6 پاشان پێی فەرمووم: «ئەوا هاتە دی. من ئەلف و یێم\f + \fr 21:6 \ft لە یۆنانی نووسراوە \+tl ئەلفا‏\+tl* و \+tl ئۆمێگا‏\+tl* یەکەم و دوایین پیتی ڕێنووسی یۆنانییە، مەبەستی لە سەرەتا و کۆتاییە.‏\f*، سەرەتا و کۆتاییم. لە کانی ئاوی ژیان بەخۆڕایی دەدەمە تینوو.  
\v 7 ئەوەی سەربکەوێت ئەوانەی بە میرات بۆ دەمێنێتەوە، دەبمە خودای و ئەویش دەبێتە کوڕم.  
\v 8 بەڵام ترسنۆک و بێباوەڕ و قێزەونان، هەروەها بکوژ و داوێنپیس و جادووگەر و بتپەرستان، لەگەڵ هەموو درۆزنان، بەشیان لە دەریاچەی بە ئاگر و گۆگرد داگیرساوە کە مردنی دووەمە.» 
\s1 ئۆرشەلیمی نوێ 
\p  
\v 9 یەکێک لەو حەوت فریشتەیەی حەوت جامەکەیان پێبوو کە بە دوایین حەوت دەردەکە پڕکرابوون، هات بۆ لام و پێی گوتم: «وەرە بووکەکەت پیشان بدەم، ژنی بەرخەکە.»  
\v 10 بە ڕۆحی پیرۆز بردمی بۆ چیایەکی گەورە و بەرز، ئۆرشەلیمی شارە پیرۆزەکەی پیشاندام کە لە ئاسمانەوە لەلایەن خوداوە دەهاتە خوارەوە.  
\v 11 شکۆی خودای هەبوو، درەوشانەوەی وەک گرانبەهاترین بەرد، وەک یەشب، ڕوون وەک کریستاڵ.  
\v 12 شوورایەکی گەورە و بەرز و دوازدە دەرگای هەبوو، لەسەر دەرگاکان دوازدە فریشتە هەبوون، ناوی دوازدە هۆزەکەی کوڕانی ئیسرائیل لەسەر دەرگاکان نووسرابوون.  
\v 13 لە ڕۆژهەڵاتەوە سێ دەرگا هەبوون، لە باکوورەوە سێ دەرگا، لە باشوورەوە سێ دەرگا، لە ڕۆژئاواوە سێ دەرگا.  
\v 14 شوورای شارەکە دوازدە بناغەی هەبوو، دوازدە ناو لە سەریان هەبوو، ناوی دوازدە نێردراوەکەی بەرخەکە. 
\p  
\v 15 ئەو فریشتەیەی لەگەڵم دەدوا دارێکی پێوانەی زێڕینی پێبوو، تاکو شارەکە و دەرگاکانی و شووراکەی بپێوێت.  
\v 16 شارەکە بە چوار گۆشەیی دانرابوو، درێژییەکەی هێندەی پانییەکەی بوو. شارەکەی بە دارەکە پێوا، دوازدە هەزار ستادیا\f + \fr 21:16 \ft دوازدە هەزار ستادیا: نزیکەی دوو هەزار و دوو سەد کیلۆمەترە.‏\f* بوو، درێژی و پانی و بەرزییەکەی یەکسان بوون.  
\v 17 شووراکەشی پێوا، سەد و چل و چوار باڵ\f + \fr 21:17 \ft نزیکەی 65 مەتر.‏\f* بوو بە باڵی مرۆڤ کە فریشتەکە بەکاریدەهێنا.  
\v 18 بینای شووراکە لە یەشب بوو، شارەکەش لە زێڕی بێگەرد بوو، وەک شووشەی ساف.  
\v 19 بناغەکانی شوورای شارەکە بە هەموو بەردێکی گرانبەها ڕازێنرابووەوە. بناغەی یەکەم یەشب، دووەم یاقووتی شین، سێیەم یاقووتی سپی، چوارەم زمروود،  
\v 20 پێنجەم شیلانە، شەشەم یاقووتی سوور، حەوتەم زەبەرجەد، هەشتەم زمروودی سەوز، نۆیەم یاقووتی زەرد، دەیەم یاقووتی سەوز، یازدەیەم یاقووتی زەعفەرانی، دوازدەیەم جەمشت.  
\v 21 دوازدە دەرگاکەش دوازدە مروارین، هەر دەرگایەک لە یەک دەنکە مرواری بوو. شەقامی شارەکە لە زێڕی بێگەرد بوو وەک شووشەی ڕۆشن. 
\p  
\v 22 پەرستگام تێیدا نەبینی، چونکە یەزدانی پەروەردگاری هەرە بەتوانا لەگەڵ بەرخەکە پەرستگای ئەون.  
\v 23 شارەکەش پێویستی بە خۆر و مانگ نییە بەسەریدا بدرەوشێنەوە، چونکە شکۆی خودا ڕووناکی کردووەتەوە و بەرخەکە چرایەتی.  
\v 24 نەتەوەکان بە ڕووناکییەکەی دەڕۆن و پاشاکانی زەوی شکۆی خۆیانی بۆ دەهێنن.  
\v 25 دەرگاکانی بە ڕۆژ هەرگیز داناخرێن، چونکە لەوێ شەو دانایەت.  
\v 26 شکۆ و ڕێزی نەتەوەکانیشی بۆ دەهێنن.  
\v 27 هیچ شتێکی گڵاو و هیچ کەسێکی قێزەون و درۆزن ناچنە ناوی، بەڵکو تەنها ئەوانەی کە ناویان لە پەڕتووکی ژیانی بەرخەکەدا نووسراوە. 
\c 22  
\s1 ڕووباری ژیان 
\p  
\v 1 پاشان فریشتەکە ڕووباری ئاوی ژیانی پیشاندام، پڕشنگدار وەک کریستاڵ، لە تەختی خودا و بەرخەکە و  
\v 2 بە ناوەڕاستی شەقامی شارەکەدا دەڕوات. لە هەردوو ڕۆخی ڕووبارەکەدا درەختی ژیان ڕوابوو کە دوازدە جار بەرهەم دەدات، هەر مانگە و بەرهەمێک. گەڵای درەختەکەش بۆ چاکبوونەوەی نەتەوەکانە.  
\v 3 ئیتر هیچ نەفرەتێک نامێنێت. تەختی خودا و بەرخەکەش لەناو شارەکەدا دەبن، بەندەکانی خزمەتی دەکەن و  
\v 4 ڕووی دەبینن و ناوی لەسەر نێوچەوانیانە.  
\v 5 لەوێ شەو دانایەت و پێویستییان بە چرا و ڕووناکی خۆر نابێت، چونکە یەزدانی پەروەردگار بەسەریاندا دەدرەوشێتەوە و بۆ هەتاهەتایە فەرمانڕەوایەتی دەکەن. 
\p  
\v 6 پاشان پێی فەرمووم: «ئەم وشانە ڕاست و جێی متمانەن. خودای پەروەردگاری ڕۆحی پێغەمبەران، فریشتەکەی خۆی نارد تاکو ئەو شتانە پیشانی بەندەکانی خۆی بدات کە دەبێت زوو ڕووبدەن.» 
\s1 من بە پەلە دێم 
\p  
\v 7 «ئەوەتا بە پەلە دێم! خۆزگە دەخوازرێت بەوەی پێشبینییەکانی ئەم پەڕتووکە وشە بە وشە پەیڕەو دەکات.» 
\b  
\p  
\v 8 من یۆحەنام، ئەوەی کە ئەم شتانەم بینی و بیستم. کاتێک بینیم و بیستم، کەوتم بۆ ئەوەی لەبەرپێی ئەو فریشتەیە کڕنۆش ببەم کە ئەم شتانەی پیشاندەدام.  
\v 9 جا پێی گوتم: «وا مەکە! منیش وەک تۆ بەندەی هاوکارتم، لەگەڵ خوشک و برا پێغەمبەرەکانت و ئەوانەی پەیامی ئەم پەڕتووکە پەیڕەو دەکەن. کڕنۆش بۆ خودا ببە!» 
\p  
\v 10 هەروەها پێی گوتم: «پەیامی پێشبینییەکانی ئەم پەڕتووکە مەشارەوە، چونکە کاتەکە نزیکە.  
\v 11 ئەوەی ستەمکارە با هەر ستەم بکات، ئەوەی گڵاوە با هەر گڵاو بێت، ئەوەی ڕاستودروستە با هەر کاری ڕاستودروست بکات، ئەوەی پیرۆزیشە با هەر پیرۆز بێت. 
\s1 بەشی کۆتایی: بانگهێشت و ئاگاداری 
\p  
\v 12 «ئەوەتا بە پەلە دێم! پاداشتی خۆم پێیە، تاکو پاداشتی هەرکەسێک بەگوێرەی کارەکەی بدەمەوە.  
\v 13 من ئەلف و یێم، یەکەمین و دواهەمینم، سەرەتا و کۆتاییم. 
\b  
\p  
\v 14 «خۆزگە دەخوازرێت بەوانەی جلەکانیان دەشۆن، تاکو مافیان لە درەختی ژیان هەبێت و لە دەرگاکانەوە بچنە ناو شارەکە.  
\v 15 سەگەکان و جادووگەران و داوێنپیسان و بکوژان و بتپەرستان و هەموو درۆزن و ئەوانەی حەز لە درۆ دەکەن لە دەرەوە دەبن. 
\b  
\p  
\v 16 «من عیسام، فریشتەکەمم نارد تاکو بەم شتانە شایەتی بۆ کڵێساکان بدەم. من لە ڕەگ و نەوەی داودم، ئەستێرەی بەیانی پڕشنگدار.» 
\b  
\p  
\v 17 ڕۆحی پیرۆز و بووک دەفەرموون: «وەرە!» ئەوەی گوێی لێیە با بڵێت: «وەرە!» ئەوەی تینوویەتی با بێت، ئەوەی دەیەوێت با بەخۆڕایی ئاوی ژیان ببات. 
\b  
\p  
\v 18 من هەموو ئەوانە ئاگادار دەکەمەوە کە گوێیان لە وشەکانی پێشبینیی ئەم پەڕتووکە دەبێت، هەرکەسێک وشەیەک بۆ ئەم پێشبینییانە زیاد بکات ئەوا خودا ئەو دەردانەی لەسەر زیاد دەکات کە لەم پەڕتووکەدا نووسراون.  
\v 19 ئەگەر کەسێکیش وشەیەکی پێشبینییەکانی ئەم پەڕتووکە بسڕێتەوە، خودا لە درەختی ژیان و لە شارە پیرۆزەکە بێبەشی دەکات، ئەوەی لەم پەڕتووکەدا نووسراوە. 
\b  
\p  
\v 20 شایەتی ئەمانە دەفەرموێ: «بەڵێ، بە پەلە دێم.» 
\p ئامین! وەرە، عیسای خاوەن شکۆ. 
\b  
\p  
\v 21 با نیعمەتی عیسای خاوەن شکۆ لەگەڵ هەمووتان بێت. ئامین.