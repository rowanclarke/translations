\id PHM
\h فىلېمونغا
\toc1 فىلېمونغا
\toc2 فىلېمونغا
\toc3 فلم.
\mt1 فىلېمونغا
\c 1
\s1 روسۇل پاۋلۇس فىلېمونغا يازغان مەكتۇپ
\m 
\v 1 مەسىھ ئەيسانىڭ مەھبۇسى مەنكى پاۋلۇس ۋە قېرىندىشىمىز تىموتىيدىن سۆيۈملۈكۈمىز ۋە خىزمەتدىشىمىز فىلېمونغا \f ◼ \fr 1:1 \ft \bd «مەسىھ ئەيسانىڭ مەھبۇسى مەنكى پاۋلۇس ...»\bd* ــ پاۋلۇس بۇ مەكتۇپنى يازغاندا رىمنىڭ مەھبۇسى ئىدى. شۈبھىسىزكى، رىملىقلار پاۋلۇسنى «بىزنىڭ مەھبۇسىمىز» دەپ ئويلايتتى ــ لېكىن پاۋلۇس ئىشقا باشقىچە قارايتتى. رىملىقلارنىڭ ئۇنى قولغا ئېلىپ تۈرمىگە تاشلىۋەتكىنى خۇدانىڭ ئىرادىسى بولۇپ، شۇ ئىش بىلەن «يات ئەللىك» ئىشەنگۈچىلەرنىڭ كۆپ پايدا كۆرىدىغانلىقىغا پاۋلۇسنىڭ كۆزى يەتكەن؛ شۇنىڭ بىلەن پاۋلۇس ئۆزىنى: «رىملىقلارنىڭ مەھبۇسى» دېمەي، بەلكى «مەسىھنىڭ مەھبۇسى» دەيدۇ.\f*  \x ◘ \xo 1:1 \xt ئ‍ەف. 3‏:1؛ 4‏:1. \x*
\v 2 ۋە سىڭلىمىز ئافىياغا، سەپدىشىمىز ئاركىپپۇسقا ۋە ئۆيۈڭدە يىغىلىدىغان جامائەتكە سالام! \f ◼ \fr 1:2 \ft \bd «سەپدىشىمىز ئاركىپپۇس»\bd* ــ «سەپدىشىمىز» (ياكى «كۈرەشدىشىمىز») ــ روھىي «ئۇرۇش سېپى»دە بولغان كۈرەشتە، ئەلۋەتتە.\f*  \x ◘ \xo 1:2 \xt رىم. 16‏:5؛ 1كور. 16‏:19؛ كول. 4‏:15،17. \x*
\m 
\v 3 خۇدائاتىمىز ۋە رەببىمىز ئەيسا مەسىھتىن سىلەرگە مېھىر-شەپقەت ۋە خاتىرجەملىك بولغاي!
\b
\s1 فىلېموننىڭ مېھىر-مۇھەببىتى ۋە ئېتىقادى
\m 
\v 4‏-5 رەببىمىز ئەيساغا ۋە بارلىق مۇقەددەس بەندىلەرگە بولغان مېھىر-مۇھەببىتىڭ ۋە ئىشەنچ-ئېتىقادىڭنى ئاڭلاپ، مەن دۇئالىرىمدا ھەمىشە سېنى ياد ئېتىپ تۇرۇۋاتىمەن، سەن ئۈچۈن تەشەككۈر ئېيتىمەن؛ \f ◼ \fr 1:4‏-5 \ft \bd «رەببىمىز ئەيساغا ۋە بارلىق مۇقەددەس بەندىلەرگە بولغان مېھىر-مۇھەببىتىڭ ۋە ئىشەنچ-ئېتىقادىڭ»\bd* ــ دېمەك، فىلېموننىڭ مۇھەببىتى ۋە ئىشەنچى مەسىھكە ۋە مۇقەددەس بەندىلىرىگىمۇ قارىتىپ باغلانغانىدى.\f*  \x ◘ \xo 1:4‏-5 \xt 1تېس. 1‏:2؛ 2تېـس. 1‏:3. \x*
\v 6 بىزگە نېسىپ بولغان، مەسىھنى ئۇلۇغلايدىغان بارلىق ياخشى ئىلتىپاتنى تولۇق تونۇپ يېتىشىڭ بىلەن، سېنىڭ ئېتىقادنىڭ ئەمەللىرىدە مەردلەرچە ئورتاقلىشىشىڭ كۈچەيتىلسۇن دەپ دۇئا قىلىمەن. \f ◼ \fr 1:6 \ft \bd «مەسىھنى ئۇلۇغلايدىغان بارلىق ياخشى ئىلتىپاتنى تولۇق تونۇپ يېتىشىڭ بىلەن..»\bd* ــ باشقا چۈشەنچىسى «مەسىھدە بولغان بارلىق ياخشى ئىلتىپاتنى تولۇق تونۇپ يېتىشىڭ بىلەن...». \bd «بىزگە نېسىپ بولغان، مەسىھنى ئۇلۇغلايدىغان بارلىق ياخشى ئىلتىپاتنى تولۇق تونۇپ يېتىشىڭ بىلەن، سېنىڭ ئېتىقادنىڭ ئەمەللىرىدە مەردلەرچە ئورتاقلىشىشىڭ كۈچەيتىلسۇن دەپ دۇئا قىلىمەن»\bd* ــ تولۇق ئايەتنىڭ باشقا بىر تەرجىمىسى: «سېنىڭ ئېتىقادنىڭ ئەمەللىرىدە مەردلەرچە ئورتاقلىشىشىڭ تېخىمۇ جارى قىلىنىشى بىلەن، بىزگە نېسىپ بولغان، مەسىھنى ئۇلۇغلايدىغان بارلىق ياخشى ئىلتىپاتنى تولۇق تونۇپ يېتىشىڭ ئۈچۈن دۇئا قىلىمەن».\f*
\v 7 چۈنكى سېنىڭ مېھىر-مۇھەببىتىڭ ماڭا زور خۇشاللىق ۋە رىغبەت ئېلىپ كەلدى؛ چۈنكى ئى قېرىندىشىم، مۇقەددەس بەندىلەرنىڭ ئىچ-باغىرلىرى سېنىڭ ئارقىلىق كۆپ سۆيۈندۈرۈلدى.
\b
\s1 فىلېموننىڭ قۇلى ئونېسىمۇس ھەققىدە ئىلتىماس
\m 
\v 8 شۇڭا، گەرچە سېنى لايىق ئىشنى قىلىشقا بۇيرۇشقا مەسىھدە جۈرئەتلىك بولالىساممۇ،
\v 9 لېكىن يەنىلا مۇھەببەتنىڭ تۈرتكىسى بىلەن مەنكى قېرى پاۋلۇس ھەمدە ھازىرمۇ ئەيسا مەسىھنىڭ مەھبۇسى بولۇش سۈپىتىدە ساڭا ئىلتىماس قىلىپ ئۆتۈنۈشنى لايىق كۆردۇم ــ \f ◼ \fr 1:9 \ft \bd «لېكىن يەنىلا مۇھەببەتنىڭ تۈرتكىسى بىلەن مەنكى قېرى پاۋلۇس ھەمدە ھازىرمۇ ئەيسا مەسىھنىڭ مەھبۇسى بولۇش سۈپىتىدە ساڭا ئىلتىماس قىلىپ ئۆتۈنۈشنى لايىق كۆردۇم»\bd* ــ «مۇھەببەتنىڭ تۈرتكىسى بىلەن.. ئۆتۈنۈش...» توغرۇلۇق «كورىنتلىقلارغا (1)»دىكى «قوشۇمچە سۆز»ىمىزدە بايان قىلغان «ھوقۇق ۋە مۇھەببەت» (24:15) ئۈستىدە بولغان مۇزاكىرىمىزنى كۆرۈڭ.\f*
\v 10 كىشەنلەردە تۇرۇپ تۇغقان بالام، يەنى ئونېسىمۇس توغرۇلۇق ئىلتىماسىم بار. \x ◘ \xo 1:10 \xt 1كور. 4‏:15. گال. 4‏:19؛ كول. 4‏:9. \x*
\v 11 ئۇ بۇرۇن ساڭا پايدىسىز بولغان بولسىمۇ، ئەمما ھازىر ساڭىمۇ، ماڭىمۇ پايدىلىقتۇر. \f ◼ \fr 1:11 \ft \bd «ئۇ بۇرۇن ساڭا پايدىسىز بولغان بولسىمۇ، ئەمما ھازىر ساڭىمۇ، ماڭىمۇ پايدىلىقتۇر»\bd* ــ «ئونېسىمۇس» دېگەن ئىسىم گرېكچە «پايدىلىق» دېگەن مەنىدە. كىرىش سۆزىمىزدە ئېيتقىنىمىزدەك، ئونېسىمۇس ئەسلى فىلېموننىڭ قۇلى ئىدى، ئۇ ئۇنىڭ قېشىدىن قاچقانىدى.\f*
\v 12 مەن ھازىر ئۇنى ــ جانجىگىرىمنى سېنىڭ يېنىڭغا قايتۇرۇپ ئەۋەتىمەن.
\v 13 خۇش خەۋەرنى دەپ كىشەنلەردە تۇرغىنىمدا ئۇنى سېنىڭ ئورنۇڭدا مېنىڭ خىزمىتىمدە بولۇشقا يېنىمدا قالدۇرۇپ قالغۇم بار ئىدى؛
\v 14 بىراق سېنىڭ رازىلىقىڭنى ئالماي ھېچنېمىنى قىلغۇم يوق؛ شۇنداق قىلغاندا سېنىڭ ماڭا قىلغان ياخشىلىقىڭ مەجبۇرىي ئەمەس، بەلكى رازىمەنلىك بىلەن بولىدۇ.
\v 15 چۈنكى سېنىڭ ئونېسىمۇستىن ۋاقىتلىق مەھرۇم بولغىنىڭنىڭ سەۋەبى، بەلكىم دەل سېنىڭ ئۇنىڭغا ئەبەدىلئەبەدگىچە نېسىۋە بولۇشۇڭ ئۈچۈن ئىدى. \f ◼ \fr 1:15 \ft \bd «چۈنكى سېنىڭ ئونېسىمۇستىن ۋاقىتلىق مەھرۇم بولغىنىڭنىڭ سەۋەبى، بەلكىم دەل سېنىڭ ئۇنىڭغا ئەبەدىلئەبەدگىچە نېسىۋە بولۇشۇڭ ئۈچۈن ئىدى»\bd* ــ بۇ ئايەت ئۈستىدە «قوشۇمچە سۆز»ىمىزدە توختىلىمىز.\f*  \x ◘ \xo 1:15 \xt يار.50‏:20؛ 1تېس.4‏:13\x*
\b
\m 
\v 16 مېنىڭ شۇنداق دېگىنىم، ئۇنىڭغا قۇل قاتارىدا ئەمەس، بەلكى قۇلدىن كۆپ ئۈستۈن ــ ماڭا نەقەدەر سۆيۈملۈك، شۇنداقلا ساڭا تېخىمۇ شۇنداق بولىدىغان (ئىنسانىي مۇناسىۋەتلەر بىلەن ھەم رەبدە بولغان مۇناسىۋەت بىلەن)، سۆيۈملۈك قېرىنداش قاتارىدا ئىگە بولىسەن؛ \f ◼ \fr 1:16 \ft \bd «ئىنسانىي مۇناسىۋەتلەر بىلەن ھەم رەبدە بولغان مۇناسىۋەت بىلەن»\bd* ــ گرېك تىلىدا «ئەت تەرىپىدىن ۋە رەبدە بولۇش تەرىپىدىن...». ئەسلىدە ئونېسىمۇس فىلېمونغا قۇل ئىدى، ئىنسانىي تەرەپتىن ئۇلارنىڭ ئوتتۇرىسىدىكى (رىم ئىمېرىيەسىدىكى قانۇن بويىچە) مۇناسىۋەت خوجايىن بىلەن قۇل ئايرىلماسلىق مۇناسىۋىتى ئىدى. بۇ سۆز بەلكىم يەنە فىلېموننىڭ قۇلى ئونېسىمۇسقا ئەسلىدە ئامراق ئىكەنلىكىنى كۆرسىتىدۇ.\f*
\v 17 شۇنىڭ ئۈچۈن، ئەگەر سەن مېنى ھەمداش قاتارىدا كۆرسەڭ، ئۇنى مېنى قوبۇل قىلغاندەك قوبۇل قىلغىن.
\v 18 ئەگەر بۇرۇن ئۇ ساڭا بىرەر يولسىزلىق قىلغان بولسا ياكى ساڭا قەرزدار بولغان بولسا، بۇنى مېنىڭ ھېسابىمغا يازغىن. \f ◼ \fr 1:18 \ft \bd «ئەگەر بۇرۇن ئۇ ساڭا بىرەر يولسىزلىق قىلغان بولسا ياكى ساڭا قەرزدار بولغان بولسا، بۇنى مېنىڭ ھېسابىمغا يازغىن»\bd* ــ مۇمكىنچىلىكى باركى، پاۋلۇسنىڭ: «ئەگەر ئۇ... ساڭا قەرزدار بولغان بولسا» دېگىنى، ئونېسىمۇسنى خىجالەتكە قالدۇرماسلىق ئۈچۈن «ئۇ سەندىن بىرەر پۇل-دۇنيا ئوغرىلىغان بولسا» دېگەننى سىلىق ئىپادىلىشى ئىدى.\f*
\v 19 مانا مەنكى پاۋلۇس بۇ سۆزلەرنى ئۆز قولۇم بىلەن يېزىۋاتىمەن: قەرزى بولسا ئۆزۈم قايتۇرىمەن؛ لېكىن مەن ساڭا ئۆزۈڭنىڭ جېنىڭ بىلەن ماڭا قەرزدار بولغىنىڭنى تىلغا ئالمايمەن. \f ◼ \fr 1:19 \ft \bd «لېكىن مەن ساڭا ئۆزۈڭنىڭ جېنىڭ بىلەن ماڭا قەرزدار بولغىنىڭنى تىلغا ئالمايمەن»\bd* ــ «ئۆز جېنىڭ بىلەن ماڭا قەرزدار بولغىنىڭ» دېگەن سۆز، شۈبھىسىزكى، پاۋلۇسنىڭ فىلېمونغا خۇش خەۋەرنى يەتكۈزۈشى بىلەن فىلېمون ئېتىقاد ئارقىلىق دوزاخ يولىدىن چىققانلىقىنى، شۇنداقلا مەڭگۈلۈك ھاياتقا ئېرىشكەنلىكىنى كۆرسىتىدۇ. «مەن ساڭا... تىلغا ئالمايمەن» ــ بۇ گەپنى دېيىشى چىرايلىق بىر چاقچاق بولىدۇ، ئەلۋەتتە.\f*
\v 20 شۇڭا، ئەي قېرىندىشىم، مەن رەبدە سەندىن مەنپەئەتكە ئېرىشمەكچىمەن؛ ئىچ-باغىرلىرىمنى مەسىھدە سۆيۈندۈرگىن. \f ◼ \fr 1:20 \ft \bd «شۇڭا، ئەي قېرىندىشىم، مەن رەبدە سەندىن مەنپەئەتكە ئېرىشمەكچىمەن»\bd* ــ گرېك تىلىدا «مەنپەئەت» ۋە «ئونېسىمۇس» («مەنپەئەتلىك، پايدىلىق») دېگەن سۆز بىلەن مۇناسىۋەتلىك بولغاچقا، پاۋلۇس يەنە سۆز ئويۇنى ئوينايدۇ. بۇ ئايەت ئۈستىدە يەنە «كىرىش سۆز»ىمىزنى كۆرۈڭ.\f*
\m 
\v 21 ئىشەنچىم سۆزۈمنى ئاڭلايدىغانلىقىڭغا كامىل بولۇپ ۋە سورىغانلىرىمدىن ئارتۇق ئورۇنلايدىغانلىقىڭنى بىلىپ، ساڭا مۇشۇنداق يازدىم.
\v 22 بۇلاردىن باشقا، ماڭا تۇرالغۇ جاي تەييارلاپ قويغىن. چۈنكى دۇئالىرىڭلار ئارقىلىق مېنىڭ سىلەرگە قايتۇرۇپ بېرىلىشىمنى ئۈمىد قىلىمەن. \f ◼ \fr 1:22 \ft \bd «چۈنكى دۇئالىرىڭلار ئارقىلىق مېنىڭ سىلەرگە قايتۇرۇپ بېرىلىشىمنى ئۈمىد قىلىمەن»\bd* ــ «دۇئالىرىڭلار ئارقىلىق» ــ فىلېموننىڭ ۋە ئۆيدە يىغىلغان جامائەتنىڭ دۇئالىرى ئارقىلىق.\fp «مېنىڭ سىلەرگە قايتۇرۇپ بېرىلىشىم» ــ دېمەك، «سولاقتىن ئازاد بولۇپ، يېنىڭلارغا قايتىپ بېرىشىم». روسۇلنىڭ كېيىنكى «فىلىپپىلىقلارغا» يازغان خېتىدە (26:1-27) ئۇنىڭ بۇ ئىشقا بولغان مۇتلەق ئىشەنچى ئىپادىلىنىدۇ. شۇ خەتتىكى 26:1-27-ئايەتلەردىكى ئىزاھاتلار ۋە خەتتىكى «قوشۇمچە سۆز»ىمىزنى كۆرۈڭ. پاۋلۇسنىڭ يۇقىرىقى سۆزىدىن دائىم ئۆز قىيىنچىلىقىنى ئەمەس (چۈنكى ئۇ تۈرمىدە ياتقانلىقىنى بىۋاسىتە تىلغا ئالمايدۇ) بەلكى باشقىلارنىڭ مەنپەئىتىنى («مېنىڭ سىلەرگە قايتۇرۇپ بېرىلىشىم») كۆزلەيدىغانلىقى كۆرۈنىدۇ.\f*  \x ◘ \xo 1:22 \xt فىل. 1‏:25. \x*
\b
\s1 ئاخىرقى سالام
\m 
\v 23 ئەيسا مەسىھكە خىزمەت قىلغانلىقى ئۈچۈن زىنداندىشىم بولغان ئەپافراس، \f ◼ \fr 1:23 \ft \bd «ئەيسا مەسىھكە خىزمەت قىلغانلىقى ئۈچۈن زىنداندىشىم بولغان ئەپافراس»\bd* ــ گرېك تىلىدا «ئەيسا مەسىھدە بولغان زىنداندىشىم ئەپافراس».\fp ئەپافراس توغرۇلۇق يەنە «كول.» 7:1، 12:4نى كۆرۈڭ.\f*  \x ◘ \xo 1:23 \xt كول. 1‏:7؛ 4‏:12. \x*
\v 24 خىزمەتداشلىرىم ماركۇس، ئارىستارخۇس، دېماس ۋە لۇقالاردىن ساڭا سالام. \f ◼ \fr 1:24 \ft \bd «خىزمەتداشلىرىم ماركۇس، ئارىستارخۇس، دېماس ۋە لۇقالاردىن ساڭا سالام»\bd* ــ دېماس توغرۇلۇق يەنە «2تىم.» 12:4 نى كۆرۈڭ.\f*  \x ◘ \xo 1:24 \xt روس. 12‏:12،25؛ 15‏:37؛ كول. 4‏:10؛ 2تىم. 4‏:11؛ 1پېت. 5‏:13؛ روس. 19‏:29؛ 20‏:4؛ 27‏:2؛ كول. 4‏:10،14؛ 2تىم. 4‏:10،11. \x*
\m 
\v 25 رەببىمىز ئەيسا مەسىھنىڭ مېھىر-شەپقىتى روھىڭلارغا يار بولغاي! 
