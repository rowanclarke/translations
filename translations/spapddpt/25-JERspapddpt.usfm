\p
\v 6 El \w mes|strong="H2320"\w* \w cuarto|strong="H7243"\w*, \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w nueve|strong="H8672"\w* días del \w mes|strong="H2320"\w*, el \w hambre|strong="H7458"\w* \w era|strong="H1961"\w* aguda en la \w ciudad|strong="H5892"\w*, hasta \w no|strong="H3808"\w* \w haber|strong="H1961"\w* \w pan|strong="H3899"\w* \w para|strong="H1961"\w* la población.  
\v 7 Entonces, \w mientras|strong="H3605"\w* \w los|strong="H5921"\w* \w caldeos|strong="H3778"\w* rodeaban \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w se|strong="H5921"\w* abrió una brecha \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*. \w Los|strong="H5921"\w* guerreros \w huyeron|strong="H1272"\w* \w de|strong="H5921"\w* \w noche|strong="H3915"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \add ubicada\add* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* dos \w muros|strong="H2346"\w*, \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* jardines \w reales|strong="H4428"\w*, \w y|strong="H5921"\w* \w salieron|strong="H3318"\w* rumbo \w al|strong="H5921"\w* Arabá.  
\v 8 Pero \w el|strong="H5921"\w* \w ejército|strong="H2428"\w* caldeo \w persiguió|strong="H7291"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w*. \w Alcanzaron|strong="H5381"\w* \w a|strong="H3068"\w* Sedequías \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w llanos|strong="H6160"\w* \w de|strong="H5921"\w* \w Jericó|strong="H3405"\w*, \w mientras|strong="H3605"\w* \w todo|strong="H3605"\w* su \w ejército|strong="H2428"\w*, ya disperso, \w lo|strong="H5921"\w* abandonaba.  
\v 9 Detuvieron \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, y se lo llevaron \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de Babilonia, quien estaba en Ribla, en tierra de Hamat, donde \w pronunció|strong="H1696"\w* \w sentencia|strong="H4941"\w* contra él.  
\v 10 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Babilonia \w degolló|strong="H7819"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Sedequías ante sus propios \w ojos|strong="H5869"\w*. \w También|strong="H1571"\w* \w degolló|strong="H7819"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* magistrados \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* en Ribla.  
\v 11 El \w rey|strong="H4428"\w* \w de|strong="H5704"\w* Babilonia \w le|strong="H5869"\w* sacó los \w ojos|strong="H5869"\w* \w a|strong="H3068"\w* Sedequías \w y|strong="H5704"\w* \w le|strong="H5869"\w* \w puso|strong="H5414"\w* grillos. Mandó llevarlo \w a|strong="H3068"\w* Babilonia \w y|strong="H5704"\w* \w lo|strong="H5704"\w* metió \w en|strong="H5704"\w* la cárcel \w hasta|strong="H5704"\w* el \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* murió.   
\s1 La cautividad  
\p
\v 12 \w El|strong="H1931"\w* \w mes|strong="H2320"\w* \w quinto|strong="H2549"\w*, \w a|strong="H3068"\w* \w los|strong="H1931"\w* \w diez|strong="H6240"\w* días del \w mes|strong="H2320"\w*, \w año|strong="H8141"\w* 19 del \w reinado|strong="H4428"\w* \w de|strong="H6440"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* Babilonia, llegó \w a|strong="H3068"\w* Jerusalén \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H6440"\w* \w la|strong="H1931"\w* guardia \w que|strong="H1931"\w* servía \w en|strong="H5975"\w* \w la|strong="H1931"\w* \w presencia|strong="H6440"\w* del \w rey|strong="H4428"\w* \w de|strong="H6440"\w* Babilonia.  
\v 13 \w Quemó|strong="H8313"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H3605"\w* palacio \w real|strong="H4428"\w* y \w todas|strong="H3605"\w* las \w casas|strong="H1004"\w* de Jerusalén. Destruyó con fuego \w todo|strong="H3605"\w* \w edificio|strong="H1004"\w* \w grande|strong="H1419"\w*.  
\v 14 \w El|strong="H3605"\w* \w ejército|strong="H2428"\w* caldeo, \w a|strong="H3068"\w* las órdenes del \w capitán|strong="H7227"\w* de \w la|strong="H3605"\w* guardia, \w destruyó|strong="H5422"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w muros|strong="H2346"\w* \w alrededor|strong="H5439"\w* de Jerusalén.  
\v 15 \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H5971"\w* la guardia, \w se|strong="H5971"\w* llevó en cautividad una parte \w de|strong="H5971"\w* la \w gente|strong="H5971"\w* humilde del \w pueblo|strong="H5971"\w*, \w el|strong="H5307"\w* remanente \w de|strong="H5971"\w* la población \w que|strong="H5971"\w* \w quedó|strong="H7604"\w* en la \w ciudad|strong="H5892"\w*, \w junto|strong="H5971"\w* con los desertores \w que|strong="H5971"\w* \w se|strong="H5971"\w* habían pasado \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H5971"\w* Babilonia y \w el|strong="H5307"\w* \w resto|strong="H3499"\w* \w de|strong="H5971"\w* los artesanos.  
\v 16 Pero \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* de la guardia, \w dejó|strong="H7604"\w* \w a|strong="H3068"\w* los \w más|strong="H7227"\w* pobres del \w pueblo|strong="H7227"\w* como viñadores y labradores asalariados.   
\p
\v 17 \w Los|strong="H3605"\w* \w caldeos|strong="H3778"\w* rompieron en pedazos las \w columnas|strong="H5982"\w* de bronce, las \w basas|strong="H4350"\w* y \w el|strong="H3605"\w* \w mar|strong="H3220"\w* de bronce \w que|strong="H3605"\w* estaban en \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*. Se \w llevaron|strong="H5375"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* bronce \w a|strong="H3068"\w* Babilonia.  
