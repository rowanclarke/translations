\id 3JN - Amarakaeri NT -Peru 2008 (DBL -2013)
\h 3 JUAN
\toc1 Juana bapaʼaʼ oʼnigmadoyaʼuyate.
\toc2 3 Juan
\toc3 3 JN
\mt1 3 JUAN
\mt2 Juana bapaʼaʼ oʼnigmadoyaʼuyate.
\c 1
\s1 Gayotaj Juana huadak oʼtimadoyaʼuyate.
\p 
\v 1 Do Juan huaknopo̱e̱ʼeritaj huamanmadikaʼeri i̱jje̱po Gayotaj oʼnigmadoyaʼne. Buttida huaʼa iknopo̱e̱nok diʼda o̱ʼe̱ne.
\p 
\v 2 Ayaʼda katepiʼ iʼkikaʼ huadakda ka̱e̱ʼ. Kenpaʼti huadaknopoʼ ka̱e̱ʼ. Ontehuapaʼ ijnigtionaʼpakikay. Diostaj durugda oʼnigpe̱i̱kaʼ ijnopo̱e̱po, huadiʼda egʼ.
\v 3 Jesucristotaj huaknopo̱e̱ʼeri sueʼda oʼnokye̱po i̱yo̱. “Gayo Jesucristoen buttida huaʼa oknopo̱e̱po huadakyoʼ oʼkikaʼ.” Boʼhuaaʼnok huakkaʼ ijdurugpakmey.
\v 4 Doʼhued huaknopo̱e̱ʼeri huasiʼpo Cristoen buttida huaʼa oʼnoknopo̱e̱po onʼnigpe̱i̱kaʼnigtaj ijtipe̱e̱po huakkaʼnada ijdurugpaki.
\p 
\v 5 Cristoen huadak huaʼa huamanmadikaʼeri enʼtiakdeʼte dakaʼ iʼmato̱i̱kaʼ. Kenpaʼti sueʼda huaknopo̱e̱ʼeritaj nogbayaʼ iʼmato̱i̱kaʼ. Kenda iʼkaʼpo Diosen huaʼa dakaʼ iʼkikaʼpo, huadiʼda egʼ.
\v 6 Gayoa diʼ moʼi̱kaʼne moʼmato̱i̱kaʼne. Cristotaj huaknopo̱e̱ʼeri e̱gkupopakyaʼ boʼtiaʼpakmeʼne. Huadak huamanmadikaʼeri onteʼti enʼhuaʼte yabatihuapok. Aypopiʼ yabayoktiʼ. Diosa betiahuaypo oʼdurugpakapo.
\v 7 Cristotaj onʼnigpe̱i̱kaʼpo Cristoen huaʼa aʼmanmadikayaʼpo onʼhuaʼudhuahuaʼpo oknopo̱e̱hueʼ hua̱e̱ʼeried katepiʼ bakehueʼda o̱ʼnikaʼ.
\v 8 Kenaʼpo oroʼ huaknopo̱e̱ʼeriayoʼda bayokikaʼdik o̱ʼe̱ne. Oroʼ oʼbatihuapoknok kenomey buttida huaʼa manmadikikaʼdik o̱ʼnikaʼ.
\s1 Diótrefes dakhueaʼ oʼkikaʼ.
\p 
\v 9 Cristoen huaknopo̱e̱ʼeri o̱ʼnenbayo e̱gkupopakikaʼyo berobaʼ ijnigmadoyaʼpo ijnigtaʼmonameʼnigʼa Diótrefes huabokerek opudya̱ʼ o̱ʼnada huairi e̱e̱ʼtaʼ oʼpakpo doʼtaj nigpe̱e̱hueʼ o̱ʼe̱meʼ.
\v 10 Do ijtiakdepo ayaʼda kenda dakhueaʼ oʼkikaʼnig ijhuaaʼapoy. Doʼtaj dakhueʼdikaʼda beʼhuaaʼpo da beʼhuaameʼne. Nog kenpaʼti dakhueʼ oʼkaʼpo Jesucristoen huadak huaʼa huamanmadikaʼeritaj totayhueʼ o̱ʼi̱kaʼ. Jakyo kenpaʼti nogomeya̱ eʼbatotaytaʼ enʼpakte “kejeʼ,” oʼmanikaʼ. Kenomeya̱ onʼbatotaynok Cristoen huaknopo̱e̱ʼeri e̱gkupopakyaʼ oʼmaenikaʼ.
\p 
\v 11 Konig dakhueaʼ huakikaʼeri o̱gkikaʼnig konigti kikahueʼ ya̱i̱kaʼ. Huadakda huakikaʼeri konig huadak o̱gkikaʼnig konigti yakikaʼ. Kenomey huadak o̱gkikaʼpo Diosensiʼpo o̱ʼne. Kenomey namaʼda o̱gkikaʼpo Diostaj oknopo̱e̱hueʼ o̱ʼne, ontaj onaʼne, huadiʼda egʼ.
\s1 Demetrio huadakaʼda oʼkikaʼ.
\p 
\v 12 Demetrio huadakbokerek o̱ʼe̱. Huadakda oʼkikaʼ. Ayaʼada onʼhuaaʼ. Diosen buttida huaʼa oʼkikaʼ. Huadakda o̱ʼe̱ oroʼakon oʼhuaay. Buttida oʼdikaʼ opuda̱ moʼnopo̱e̱ne.
\s1 Juana taʼpote keneʼhua̱ya̱ʼkon oʼnigmadoyaʼuyate.
\p 
\v 13 Huakkaʼ nogi̱ti enataʼ eʼpakada eʼnigmadoyaʼtaʼ pakhueʼ i̱jje̱y.
\v 14 Aʼti etaʼhuade̱taʼ ijpaki. Kenokaʼ hua̱so̱ʼteda meʼbatiaʼpak.
\p 
\v 15 Diosa menopoʼnoeye̱ʼ. Huadiʼda aratbut i̱ya̱ʼda saludos moʼdiktaʼmonaʼne. Kenpaʼti doʼhued huadiʼ ke̱yo̱da saludos ijmadiktaʼmonay.
