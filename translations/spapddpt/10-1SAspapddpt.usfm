\v 1 \w La|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* \w Samuel|strong="H8050"\w* llegaba \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*. Entonces \w Israel|strong="H3478"\w* \w salió|strong="H3318"\w* \w a|strong="H3068"\w* enfrentar \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w en|strong="H5921"\w* \w batalla|strong="H4421"\w* \w y|strong="H5921"\w* acampó \w junto|strong="H5921"\w* \w a|strong="H3068"\w* Ebenezer. \w Los|strong="H5921"\w* \w filisteos|strong="H6430"\w* acamparon \w en|strong="H5921"\w* Afec \w y|strong="H5921"\w*
