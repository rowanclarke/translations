\id AMO
\h عَامُوسْ 
\toc1 عَامُوسْ 
\toc2 عَامُوسْ 
\toc3 عَام. 
\mt1 عَامُوسْ  
\c 1
\s1 ڒحْكَامَاثْ يَاهُوذَا ذ إِسْرَائِيل ؤُ خْ ثِيمُّورَا إِ ذ أَسنْثْ-إِ-د إِنّْضنْ  
\m
\v 1 أَوَاڒنْ ن عَامُوسْ، ونِّي ثُوغَا إِدْجَانْ جَارْ إِمكْسَاونْ ن ثَاقُوعَا، \add أَوَاڒنْ\add* إِ إِژْرَا خْ إِسْرَائِيل، ذڭْ وُوسَّانْ ن عُوزِّييَا، أَجدْجِيذْ ن يَاهُوذَا، ذ يَارُوبْعَامْ، مِّيسْ ن يُووَاشْ، أَجدْجِيذْ ن إِسْرَائِيل، ثْنَاينْ ن إِسڭّْوُوسَا قْبڒْ إِ ونْهزِّي ن ثمُّورْثْ. \x ◘ \xo 1:‏1 \xt زَاك. 14‏:‏5\x*   
\b  
\m
\v 2 نتَّا إِنَّا: ”سِيذِي أَذْ إِزهَّارْ زِي صِيهْيُونْ، أَذْ إِسّْڭعّذْ ثْمِيجَّا نّسْ زِي ؤُرْشَالِيمْ. دّْمَانِي ن ثَاروْسَا أَذْ شضْننْثْ ؤُ ثَاقِيشّثْ ن كَارْمِيلْ أَذْ ثِيسْڒَاوْ.“ \x ◘ \xo 1:‏2 \xt إِرْم. 25‏:‏30؛ يُووِ. 4‏:‏16\x*   
\b  
\m
\v 3 ”أَمُّو إِ إِقَّارْ سِيذِي: خْ ثْڒَاثَا ن إِخطَّانْ \add إِ إِڭَّا\add* \bd ذِيمَاشْقْ\bd*، \add عَاذْ مَاهُو\add* خْ أَربْعَا، وَارْ ث سّْبطَّاڒغْ، مِينْزِي نِيثْنِي سَّارْوَاثنْ جِيلْعَاذْ س ثڒْوِيحِينْ إِتّحْڒُودْجُوضنْ ن وُوزَّاڒْ إِ ؤُسَارْوثْ.  
\v 4 أَذْ سّكّغْ ثِيمسِّي ذِي ثَادَّارْثْ ن حَازَايِيلْ، أَذْ ثشّْ ڒقْصُورْ ن بِينْهَاذَاذْ.  
\v 5 أَذْ أَرْژغْ زّكْرُونْ ن ذِيمَاشْقْ ؤُ أَذْ مْحِيغْ ونِّي إِزدّْغنْ زِي بُوقْعَا-أَوَانْ، \add زِي ڒوْضَا ن وَاردّدْجْ\add*، ذ ونِّي زِي ثَادَّارْثْ ن مژْرِي إِ يَاربُّونْ أَزدْجَاضْ، ؤُ ڒْڭنْسْ ن أَرَامْ أَذْ إِتّْوَانْذهْ ذِي ثْمحْبَاسْثْ غَارْ قِيرْ!، إِنَّا سِيذِي.“ \x ◘ \xo 1:‏5 \xt 2 إِج. 16‏:‏9؛ إِشا. 17‏:‏1‏-‏11؛ إِرْم. 49‏:‏23‏-‏27\x*   
\b  
\m
\v 6 ”أَمُّو إِ إِنَّا سِيذِي: خْ ثْڒَاثَا ن إِخطَّانْ \add إِ إِڭَّا\add* \bd غَازَّا\bd*، \add عَاذْ مَاهُو\add* خْ أَربْعَا، وَارْ ث سّْبطَّاڒغْ، مِينْزِي نِيثْنِي إِوْينْ \add ڒْْڭنْسْ إِنُو\add* قَاعْ ذِي لْمنْفَا، حِيمَا أَذْ \add ث\add* سلّْمنْ إِ إِذُومْ. \x ◘ \xo 1:‏6 \xt 2 إِم. 21‏:‏16، 17؛ 28‏:‏18\x*  
\v 7 أَذْ سّكّغْ ثِيمسِّي ذَاخڒْ ذِي ڒحْيُوضْ ن غَازَّا، أَذْ ثشّْ ڒقْصُورْ نّسْ.  
\v 8 نشّْ أَذْ ثحِّيغْ أَمزْذُوغْ زِي أَشْذُوذْ ؤُ زِي أَشْقَالُونْ ونِّي يَاربُّونْ أَزدْجَاضْ ؤُ نشّْ أَذْ كْسِيغْ أَفُوسْ إِنُو ضِيدّْ إِ عَاقْرُونْ ؤُ مِينْ إِقِّيمنْ ن أَيْثْ ن إِفِيلِيسْطِينِييّنْ أَذْ إِتّْوَاهلّكْ، إِقَّارْ سِيذِي إِنُو، سِيذِي.“   
\b  
\m
\v 9 ”أَمُّو إِ إِنَّا سِيذِي: خْ ثْڒَاثَا ن إِخطَّانْ \add إِ إِڭَّا\add* \bd صُورْ\bd*، \add عَاذْ مَاهُو\add* خْ أَربْعَا، وَارْ ث سّْبطَّاڒغْ، مِينْزِي نِيثْنِي سلّْمنْ \add ڒْڭنْسْ إِنُو\add* قَاعْ ذِي لْمنْفَا إِ إِذُومْ، وَارْ إِذَارنْ ڒْعَاهْذْ أَكْ-ذ وَاوْمَاثنْ نْسنْ.  
\v 10 س ؤُينِّي أَذْ سّكّغْ ثِيمسِّي ذَاخڒْ ذِي ڒحْيُوضْ ن صُورْ، أَذْ ثشّْ ڒقْصُورْ نّسْ.“   
\b  
\m
\v 11 ”أَمُّو إِ إِنَّا سِيذِي: خْ ثْڒَاثَا ن إِخطَّانْ \add إِ إِڭَّا\add* \bd إِذُومْ\bd*، \add عَاذْ مَاهُو\add* خْ أَربْعَا، وَارْ ث سّْبطَّاڒغْ، مِينْزِي نتَّا إِضْفَارْ أَوْمَاثنْ نّسْ س سِّيفْ ؤُ إِسّْعِيدْجِي أَرّحْمثْ نّسْ، ؤُ \add مِينْزِي\add* أَغْضَابْ نّسْ إِقِّيمْ إِشَارّڭْ بْڒَا قطُّو، ؤُ \add مِينْزِي\add* أَهذِّي ن ؤُذُوقّزْ نّسْ \add ن ؤُفُوڭمْ\add* إِقِّيمْ \add إِسَّاڭّْوَاذْ\add* ڒبْذَا.  
\v 12 نشّْ أَذْ سّكّغْ ثِيمسِّي ذِي ثَايْمَانْ، أَذْ ثشّْ ڒقْصُورْ ن بُوصْرَا.“   
\b  
\m
\v 13 ”أَمُّو إِ إِنَّا سِيذِي: خْ ثْڒَاثَا ن إِخطَّانْ \add إِ إِڭِّينْ\add* \bd أَيْثْ ن عَامُّونْ\bd*، \add عَاذْ مَاهُو\add* خْ أَربْعَا، وَارْ ث سّْبطَّاڒغْ، مِينْزِي نِيثْنِي شَارّْڭنْ ثِيمْغَارِينْ س دّيْسثْ زِي جِيلْعَاذْ، حِيمَا أَذْ سّْوسّْعنْ ثَامُّورْثْ نْسنْ.  
\v 14 نشّْ أَذْ سَّارْغغْ إِشْثْ ن ثْمسِّي ذَاخڒْ إِ ڒحْيُوضْ نْ رَابَّا، أَذْ ثشّْ ڒقْصُورْ نّسْ، غَارْ إِغُويَّانْ ذڭْ وَاسّْ ن ؤُمنْغِي، أَمْ إِسُوضْ ؤُسمِّيضْ ذڭْ وَاسّْ ن ثْحَارْيَاضْثْ.  
\v 15 أَجدْجِيذْ نْسنْ أَذْ يُويُورْ ذِي لْمنْفَا، نتَّا أَكْ-ذ ڒْحُوكَّامْ نّسْ، إِنَّا سِيذِي.“   
\b  
\b  
\m  
\c 2
\m
\v 1 ”أَمُّو إِ إِنَّا سِيذِي: خْ ثْڒَاثَا ن إِخطَّانْ \add إِ إِڭَّا\add* \bd مُوآبَ\bd*، \add عَاذْ مَاهُو\add* خْ أَربْعَا، وَارْ ث سّْبطَّاڒغْ، مِينْزِي نِيثْنِي سّْشمْضنْ إِيْسَانْ ن ؤُجدْجِيذْ ن إِذُومْ أَڒَامِي ذوْڒنْ ذ جِّيرْ.  
\v 2 نشّْ أَذْ سّكّغْ ثِيمسِّي ذِي مُوآبَ، أَذْ ثشّْ ڒقْصُورْ ن قَارْيُوثْ. مُوآبَ أَذْ إِمّثْ غَارْ دّْرِيزْ أَمقّْرَانْ، غَارْ إِغُويَّانْ \add ن ؤُمنْغِي\add* \add ؤُ\add* غَارْ ڒْحسّْ نْ  ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي.  
\v 3 نشّْ أَذْ ثحِّيغْ ڒْقَاضِي زِي ڒْوسْثْ نّسْ ؤُ أَذْ نْغغْ مَارَّا ڒْحُوكَّامْ نّسْ أَكِيذسْ، إِقَّارْ سِيذِي.“   
\b  
\m
\v 4 ”أَمُّو إِ إِنَّا سِيذِي: خْ ثْڒَاثَا ن إِخطَّانْ \add إِ إِڭَّا\add* \bd يَاهُوذَا\bd*، \add عَاذْ مَاهُو\add* خْ أَربْعَا، وَارْ ث سّْبطَّاڒغْ، مِينْزِي نِيثْنِي وَارْ قْبِيڒنْ شَّارِيعَا ن سِيذِي ؤُ وَارْ طِّيفنْ ذِي ثْوصَّا إِنُو ؤُ \add مِينْزِي\add* \add إِربِّيثنْ نْسنْ\add* ن إِخَارِّيقنْ، إِنِّي ضْفَارنْ ڒجْذُوذْ نْسنْ، أَرِّينْ ثنْ ودَّارنْ،  
\v 5 نشّْ أَذْ سّكّغْ ثِيمسِّي ذِي يَاهُوذَا، أَذْ ثشّْ ڒقْصُورْ ن ؤُرْشَالِيمْ.“   
\b  
\m
\v 6 ”أَمُّو إِ إِنَّا سِيذِي: خْ ثْڒَاثَا ن إِخطَّانْ \add إِ إِڭَّا\add* \bd إِسْرَا‘إِلْ\bd*، \add عَاذْ مَاهُو\add* خْ أَربْعَا، وَارْ ث سّْبطَّاڒغْ، مِينْزِي نِيثْنِي زّنْزنْ أَمْسڭّذْ س \add ثْمنْيَاثْ ن\add* نُّوقَارْثْ ؤُ أَمزْڒُوضْ إِ ثْيُويَا ن سَانْذَالِييَاثْ.  
\v 7 نِيثْنِي ثشْضِيضِيحنْ غَارْ ثْعجَّاجْثْ خْ ؤُزدْجِيفْ ن إِمُوقْڒِيڒنْ ؤُ نِيثْنِي تّْبلَّاعنْ أَبْرِيذْ ن إِمْوَاضْعنْ \add بْڒَا سِّيبّثْ\add*. أَرْيَازْ ذ بَابَاسْ رُوحنْ غَارْ ثحْرَامْثْ ذ إِشْثْ، حِيمَا أَذْ فضْحنْ إِسمْ إِنُو إِقدّْسنْ.  
\v 8 نِيثْنِي سّْوَاژَّاضنْ إِخفْ نْسنْ زَّاثْ مْكُوڒْ أَعَالْطَارْ خْ وَارُّوضْ إِ د-إِتّْوَارهْننْ ؤُ ذِي ثَادَّارْثْ ن أَربِّي نْسنْ سسّنْ بِينُو \add سَّاغنْ ث س ثْمنْيَاثْ\add* ن يِينِّي خْ إِتّْوَاڭّْ مُولْثَا.  
\v 9 ذ نشّْ إِ ثُوغَا \add ذِينْ\add* ثحِّيغْ إِمُورِييّنْ زَّاثْ إِ ؤُغمْبُوبْ نْسنْ، إِنِّي ثُوغَا يُوعْڒَانْ أَمْ ثْنڭْلِينْ يُوعْڒَانْ ؤُ جهّْذنْ أَمْ ثْشجُّورَا ن ڒْبدْجُوضْ. نشّْ ثحِّيغْ ڒْغِيدْجثْ نّسْ سنّجْ ؤُ إِژوْرَانْ نّسْ سْوَادَّايْ. \x ◘ \xo 2:‏9 \xt ڒخْڒ. 21‏:‏24؛ أَعَوذ. 2‏:‏31؛ ياش. 24‏:‏8\x*  
\v 10 ذ نشّْ إِ ثُوغَا كنِّيوْ إِ د-إِسّْڭعّْذنْ زِي مِيصْرَا ؤُ أَرِّيغْ كنِّيوْ ثُويُورمْ أَربْعِينْ ن إِسڭّْوُوسَا ذِي ڒخْڒَا، مَاحنْذْ أَذْ ثطّْفمْ ثَامُّورْثْ ن إِمُورِييّنْ ذ ڒْوَارْثْ. \x ◘ \xo 2:‏10 \xt ؤُف. 12‏:‏51\x*  
\v 11 زڭْ إِحنْجِيرنْ نْومْ أَرِّيغْ زَّايْسنْ إِنَابِييّنْ ؤُ زڭْ إِحُوذْرِييّنْ نْومْ \add أَرِّيغْ زَّايْسنْ\add* إِنِّي ثُوغَا يَاربُّونْ تَّاجْ \add ن ؤُشُوَّافْ ن لْوَاعْذْ\add*. مَا وَارْ إِدْجِي أَمنِّي، \add أَ\add* أَيْثْ ن إِسْرَائِيل؟!، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.  
\v 12 كنِّيوْ \add مَاشَا\add* ثَارِّيمْ إِنِّي ثُوغَا يَاربُّونْ تَّاجْ \add ن وعْزَاڒْ\add* أَذْ سْونْ بِينُو ؤُ كنِّيوْ ثْوصَّامْ إِنَابِييّنْ، ثنَّامْ: ’كنِّيوْ وَارْ غَارْومْ بُو تّسْرِيحْ، حِيمَا أَذْ ثْنبَّامْ!‘ \x ◘ \xo 2:‏12 \xt عَام. 7‏:‏12، 13\x*  
\v 13 خْزَارْ، نشّْ أَذْ أَومْعبّْزغْ سْوَادَّايْ أَمْ يِيشْثْ ن ثْكَارُّوثْ ثشُّورْ س ثْقبِّيضِينْ \add ن إِمنْذِي\add* ثْعبّزْ \add ثِيجَارَّارِينْ نّسْ ذِي ثمُّورْثْ سْوَادَّايْ\add*.  
\v 14 أَقَا صَافِي ثَاروْڒَا إِ ونِّي إِفْسُوسنْ، ؤُ ونِّي إِجهْذنْ وَارْ إِزمَّارْ أَذْ إِحْضَا جّهْذْ نّسْ ؤُ بُو-ثغْڒُوضْثْ وَارْ إِزمَّارْ أَذْ إِسّنْجمْ ثُوذَارْثْ نّسْ.  
\v 15 ونِّي إِطّْفنْ ذِي ڒْقوْسْ، وَارْ \add إِتّْغِيمِي\add* إِبدّْ، ؤُ ونِّي إِزمَّارنْ خْ ثَازْڒَا، وَارْ إِنجّمْ، ؤُ ونِّي إِندّْهنْ أَيِيسْ، وَارْ إِزمَّارْ أَذْ إِسّنْجمْ ڒعْمَارْ نّسْ.  
\v 16 ونِّي إِزعّْمنْ قَاعْ جَارْ أَيْثْ ن بُو-ثغْرُوضْثْ أَذْ يَارْوڒْ ذ أَعَارْيَانْ \bd ذڭْ وَاسّْ نِّي\bd*، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“   
\b  
\b  
\m  
\c 3
\s1 ڒْحُوكْمْ ن سِيذِي خْ إِسْرَائِيل ذ سَامَارْيَا  
\m
\v 1 ”سْڒمْ أَوَاڒْ-أَ إِ كِيذْومْ إِسَّاوَاڒْ سِيذِي، \add أَ\add* أَيْثْ ن إِسْرَائِيل، أَكْ-ذ كُوڒْ ڒَادْجْ نِّي سّْڭعّْذغْ نشّْ زِي ثمُّورْثْ ن مِيصْرَا، أَمْ قَّارغْ:  
\v 2 ’زِي مَارَّا ڒَادْجَاثْ ن دُّونشْثْ سّْنغْ مْغِيرْ كنِّيوْ. خْ ؤُيَا أَذْ كنِّيوْ عَاقْبغْ خْ مَارَّا ڒْمُوعْصِييَّاثْ نْومْ!  
\v 3 مَا أَذْ ؤُيُورنْ ثْنَاينْ أَكْ-ذ وَايَاوْيَا، بْڒَا مَا تَّافْقنْ؟  
\v 4 مَا أَذْ إِزهَّارْ وَايْرَاذْ ذڭْ وزْغَارْ ڒَامِي وَارْ غَارسْ بُو زَّارْذثْ؟ مَا أَيْرَاذْ ذ أَمژْيَانْ أَذْ يجّْ ثْمِيجَّا نّسْ أَذْ ثتّْوَاسڒْ زڭْ يفْرِي، أَمْ وَارْ إِمْنِيعْ وَالُو؟ \f ◼ \fr 3:‏4 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  
\v 5 مَا أَذْ إِنْضَارْ وجْضِيضْ ذِي ڒْفخْ خْ \add وُوذمْ ن\add* ثمُّورْثْ، مَاڒَا وَارْ ذِينْ \add ذَايسْ\add* مَاشَّا إِ نتَّا؟ مَا أَذْ إِنُّورْفعْ ڒْفخْ زِي ثمُّورْثْ مَاڒَا ثخْوَا؟  
\v 6 مَاڒَا \add حذْ\add* إِسُوضْ ذڭْ ؤُيِيشّْ ن إِشَارِّي ذِي ثنْذِينْثْ، مَا وَارْ إِتَّارْجِيجِي ڒْڭنْسْ؟ مَاڒَا إِمْسَارْ إِجّْ ن ؤُشڒْوَاوْ ذِي ثنْذِينْثْ، مَا وَارْ ت إِڭِّي سِيذِي؟\x ◘ \xo 3:‏6 \xt إِشا. 45‏:‏7؛ إِڭجذ. 3‏:‏37، 38\x*  
\v 7 مَاغَارْ سِيذِي إِنُو، سِيذِي، وَارْ إِتّڭّْ ؤُڒَا ذ إِشْثْ نْ ڒْحَاجثْ بْڒَا مَا أَذْ إِسَّارْڭبْ شّْوَارْ نّسْ \add إِنُّوفَّارنْ\add* إِ إِمْسخَّارنْ نّسْ، إِنَابِييّنْ.  
\v 8 أَيْرَاذْ إِزهَّارْ، مَانْ ونْ وَارْ إِتّڭّْوْذنْ؟ سِيذِي إِنُو، سِيذِي، أَقَا إِسِّيوڒْ، مَانْ ونْ وَارْ إِتّْنبَّا؟‘ “   
\b  
\m
\v 9 ”جّمْ أَذْ إِتّْوَاسڒْ أَيَا ذِي ڒقْصُورْ ذِي أَشْذُوذْ ؤُ ذِي ڒقْصُورْ ن ثمُّورْثْ ن مِيصْرَا، إِنِي: ’مُونمْ خْ إِذُورَارْ ن سَامَارْيَا ؤُ خْزَارمْ أَنهْوڒْ أَمقّْرَانْ ذِي ڒْوسْطْ نّسْ ؤُ إِنِّي ذَايسْ إِتّْوَاحْصَارنْ!‘  
\v 10 نِيثْنِي وَارْ سِّيننْ مَامّشْ غَا ڭّنْ مِينْ إِسڭّْذنْ، إِقَّارْ سِيذِي، نِيثْنِي إِنِّي إِيَارّْونْ لْعُونْفْ ذ ثْكشَّاضْثْ ذِي ڒقْصُورْ نْسنْ.‘  
\v 11 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’إِجّْ ن ڒعْذُو! نتَّا إِتّنّضْ إِ ثمُّورْثْ \add مَارَّا\add*! أَذْ إِسّهْوَا جّهْذْ نّمْ زَّايمْ ؤُ ڒقْصُورْ نّمْ أَذْ تّْوَاكشّْضنْ.‘ \x ◘ \xo 3:‏11 \xt إِشا. 28‏:‏1‏-‏3\x*  
\v 12 أَمُّو إِ إِقَّارْ سِيذِي: ’أَمْ إِفكّْ إِجّْ ن ؤُمكْسَاوْ ثْنَاينْ ن إِضَارنْ نِيغْ إِجّْ ن يِيخفْ ن ؤُمزُّوغْ زڭْ ؤُقمُّومْ ن وَايْرَاذْ، أَمُّو إِ غَا تّْوَاسّْنجْمنْ أَيْثْ ن إِسْرَائِيل، إِنِّي \add إِ ذِينْ\add* إِتّْغِيمَانْ ذِي سَامَارْيَا خْ ثْمَا ن قَامَا ؤُ خْ يِيشْثْ ن ثْزرْبِييّثْ زِي ذِيمَاشْقْ ڭِّينْ ت خْ يِيشْثْ ن ڒمْطَارْبثْ.‘ “   
\m
\v 13 ”سْڒمْ ؤُ شهْذمْ ذِي ثَادَّارْثْ ن يَاعْقُوبْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ.  
\v 14 مِينْزِي ذڭْ وَاسّْ نِّي ذِي غَا خڒْفغْ إِخطَّانْ ن إِسْرَائِيل، أَذْ سِّيوْضغْ \add عَاوذْ\add* أَخدْجصْ خْ إِعَالْطَارنْ ن بَايْثْ-إِلْ، \add مَاغَارْ\add* أَذْ تّْوَاقضْعنْ وَاشَّاونْ ن ؤُعَالْطَارْ، أَذْ وْضَانْ غَارْ ثمُّورْثْ.  
\v 15 نشّْ أَذْ هذْمغْ ثَازذِّيغْثْ ن ثْڭَارْسْثْ ذ ثْزذِّيغْثْ ن ؤُنبْذُو ؤُ ثُوذْرِينْ ن ڒْعَاجْ أَذْ تّْوَاقْضَانْثْ، ؤُ أَطَّاسْ ن ثُوذْرِينْ أَذْ تّْوَارذْدْجنْثْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ \f ◼ \fr 3:‏15 \ft \+bd ’ڒْعَاجْ‘\+bd* - نِيغْ ’لْعَاجْ‘.\f*   
\b  
\b  
\m  
\c 4
\s1 إِسْرَائِيل وَارْ ثتُّوبْ شَا  
\m
\v 1 ”سْڒنْثْ، أَوَاڒْ-أَ، \add أَ\add* ثِيفُونَاسِينْ ن بَاشَانْ نِّي \add إِدْجَانْ\add* خْ وذْرَارْ ن سَامَارْيَا، ثِينِّي إِحصَّارنْ إِمُوقْڒِيڒنْ، ثِينِّي إِعفّْسنْ خْ إِمزْڒَاضْ، ثِينِّي إِقَّارنْ إِ أَيْثْبَابْ نْسنْ: ’أَوْيمْ-د \add شَا\add* \add أَڒَامِي\add* إِ غَا نسُّو!‘  
\v 2 سِيذِي إِنُو، سِيذِي، إِجُّودْجْ س ثْقدَّاسْثْ نّسْ، أَقَا أَذْ خَاكنْثْ د-كّنْ وُوسَّانْ، أَذْ كنِّينْثْ كّْسنْ س إِغَانْثْشُوثنْ ؤُ مِينْ زَّايْكنْثْ إِقِّيمنْ س ثْصنَّارِينْ ن إِسڒْمَانْ.  
\v 3 كنِّينْثْ أَذْ ثفّْغنْثْ زِي ثِيزّيِّينْ ن ڒحْيُوضْ، كُوڒْ إِشْثْ ن ثمْغَارْثْ نِيشَانْ غَارْ زَّاثْ. كنِّينْثْ أَذْ تّْوَاسّكّنْثْ غَارْ هَارْمُونْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.   
\m
\v 4 \add إِوَا،\add* أَسمْ-د غَارْ بَايْثْ-إِلْ ؤُعدَّامْ، \add أَسمْ-د غَارْ\add* جِيلْجَالْ ؤُ أَرْنِيمْ ذڭْ إِعذِّيينْ نْومْ. \add إِوَا،\add* أَوْيمْ-د ثِيغَارْصَا نْومْ كُوڒْ ضّْبحْ ذ ڒعْشُورْ نْومْ إِشْثْ ن ثْوَاڒَا ذِي ثْڒَاثَا ن وُوسَّانْ! \x ◘ \xo 4:‏4 \xt حُوش. 12‏:‏12\x*  
\v 5 \add إِوَا،\add* سْبخَّارْ إِشْثْ ن ثوْهِيبْثْ ن ؤُقَاذِي س \add وغْرُومْ أَكْ-ذ\add* ونْثُونْ ؤُ ڒَاغَامْ، \add مَاحنْذْ أَذْ قدّْمنْ\add* ثِيوْهِيبِينْ س ڒْخَاضَارْ، بَارّْحمْ زَّايسْ، مَاغَارْ أَمُّو إِ ذ أَومْ إِتّعْجِيبْ، \add أَ\add* أَيْثْ ن إِسْرَائِيل، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“ \x ◘ \xo 4:‏5 \xt لَاوِي 2‏:‏1، 15؛ 7‏:‏13\x*   
\b  
\m
\v 6 ”عَاوذْ نشّْ جِّيغْ أَومْ ثَازْذُوڭِي ن ثغْمَاسْ ذِي مَارَّا ثِيندَّامْ نْومْ ؤُ ثُوقْڒِيتْشْ ن وغْرُومْ ذِي مَارَّا إِمُوشَانْ نْومْ \add مَانِي ثْزدّْغمْ\add*. \bd \+bdit قَاعْ أَمنِّي مَاشَا\+bdit* كنِّيوْ وَارْ د-ثذْوِيڒمْ غَارِي\bd*، إِقَّارْ سِيذِي.   
\m
\v 7 نشّْ سّْبدّغْ خَاومْ أَنْژَارْ ؤُمِي ذِينْ \add عَاذْ\add* ثْڒَاثَا ن إِيُورنْ أَڒْ ثْميْرَا ؤُ نشّْ ڭِّيغْ أَذْ إِوّثْ ونْژَارْ خْ إِشْثْ ن ثنْذِينْثْ، \add مَاشَا\add* ذِي ثنْذِينْثْ نّغْنِي وَارْ ڭِّيغْ أَذْ إِوّثْ ونْژَارْ. إِجّْ ن ييَّارْ إِمّوْشْ أَسْ ونْژَارْ ؤُ إِيَّارْ نّغْنِي إِ خْ وَارْ إِوْثِي ونْژَارْ، إِنْژغْ.  
\v 8 ثْنَاينْ، ثْڒَاثَا ن ثْندَّامْ ؤُيُورنْثْ تّنْهزَّانْثْ غَارْ إِشْثْ ن ثنْذِينْثْ نّغْنِي، مَاحنْذْ أَذْ سْونْثْ أَمَانْ، \add مَاشَا\add* نِيثنْثِي وَارْ جِّيوْننْثْ شَا. \bd \+bdit قَاعْ أَمنِّي مَاشَا\+bdit* كنِّيوْ وَارْ د-ثذْوِيڒمْ غَارِي\bd*، إِقَّارْ سِيذِي.   
\m
\v 9 نشّْ وْثِيغْ كنِّيوْ س \add إِمنْذِي\add* إِتّْوَاسّْشمْضنْ \add زڭْ ؤُسمِّيضْ\add*، س جّْرِيحشْثْ ن وفْسُو. أَطَّاسْ ن إِحْوِيشنْ نْومْ ذ إِمَارْجَاعنْ نْومْ ن ؤُضِيڒْ ذ وُورْثَانْ نْومْ ذ ثْزِيثُونِينْ نْومْ أَقَا إِشَّا إِ-ثنْ بُو-وقْضعْ. \bd \+bdit قَاعْ أَمنِّي مَاشَا\+bdit* كنِّيوْ وَارْ د-ثذْوِيڒمْ غَارِي\bd*، إِقَّارْ سِيذِي. \x ◘ \xo 4:‏9 \xt أَعَوذ. 28‏:‏22؛ يُووِ. 1‏:‏4\x*   
\m
\v 10 نشّْ سّكّغْ-د جَارْ أَومْ طَّاعُونْ، أَمْ مَامّشْ ڭِّيغْ ذِي مِيصْرَا. نشّْ نْغِيغْ إِحُوذْرِيينْ نْومْ س سِّيفْ، إِيْسَانْ نْومْ نذْهغْ ثنْ ذ ثَاكشَّاضْطْ ؤُ أَرِّيغْ أَرِّيحثْ ن ڒْعسْكَارَاثْ نْومْ أَذْ ثْڭعّذْ أَڒْ ونْزَارنْ نْومْ. \bd \+bdit قَاعْ أَمنِّي مَاشَا\+bdit* كنِّيوْ وَارْ د-ثذْوِيڒمْ غَارِي\bd*، إِقَّارْ سِيذِي.   
\m
\v 11 نشّْ سّنْقڒْبغْ كنِّيوْ أَمْ مَامّشْ ثُوغَا إِسّْنقْڒَابْ أَربِّي سَاذُومْ ذ عَامُورَّا. ثُوغَا كنِّيوْ أَمْ يِيجّْ ن ؤُكشُّوضْ ذِي ثْمسِّي نِّي د-إِتّْوَاقڒْعنْ زڭْ \add ؤُحَاذُوقْ ن\add* ثْمسِّي. \bd \+bdit قَاعْ أَمنِّي مَاشَا\+bdit* كنِّيوْ وَارْ د-ثذْوِيڒمْ غَارِي\bd*، إِقَّارْ سِيذِي. \x ◘ \xo 4:‏11 \xt 19‏:‏24\x*   
\m
\v 12 س ؤُيَا نشّْ أَذْ أَشْ ڭّغْ أَيَا، \add أَ\add* إِسْرَائِيل! مِينْزِي نشّْ أَذْ أَشْ ڭّغْ مَانْ أَيَا، حزّمْ \add إِخفْ نّشْ\add*، \add أَ\add* إِسْرَائِيل، مَاحنْذْ أَذْ ثمّڒْقِيذْ أَكْ-ذ أَربِّي نّشْ.  
\v 13 مَاغَارْ خْزَارْ، ذ نتَّا إِ إِكوّْننْ إِذُورَارْ ؤُ إِتّجَّا-د أَسمِّيضْ ؤُ إِسّْشَانْ مِينْ ذِي إِتّْخَارّصْ، ذ ونِّي إِتَّارَّانْ ثُوفُّوثْ ن ڒْحَاڒْ ذ ثَادْجسْثْ ؤُ إِڭُّورْ ثِيوَا إِ ڒڭْعُوذِي ن ثمُّورْثْ، أَقَا: سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ ذ إِسمْ نّسْ.“ \x ◘ \xo 4:‏13 \xt نَحُم. 1‏:‏3\x*   
\b  
\b  
\m  
\c 5
\s1 أَشثْشِي ن سِيذِي خْ إِسْرَائِيل  
\m
\v 1 ”سْڒمْ أَوَاڒْ-أَ إِ خَاومْ سّكَّارغْ، إِجّْ ن يزْڒِي ن ؤُڭجْذُورْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل.   
\b  
\m
\v 2 \qt ”أَقَا ثوْضَا ثعْزَارشْثْ إِسْرَائِيل،\qt*  
\m \qt وَارْ ثتّكَّارْ عَاذْ.\qt*  
\m \qt نتَّاثْ ثمّنْضَارْ غَارْ ثمُّورْثْ نّسْ،\qt*  
\m \qt وَارْ ذِينْ ؤُڒَا ذ إِجّْ إِ ت غَا إِسّْبدّنْ.“\qt*   
\b  
\m
\v 3 ”مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ثَانْذِينْثْ نِّي إِ غَا إِفّْغنْ س وَاڒفْ \add ن يرْيَازنْ\add*، أَذْ أَسْ ثْشطّْ مْيَا، ؤُ ثنِّي إِ غَا إِفّْغنْ س مْيَا، أَذْ أَسْ ثْشطّْعشْرَا إِ ثَادَّارْثْ ن إِسْرَائِيل.  
\v 4 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي غَارْ ثَادَّارْثْ ن إِسْرَائِيل: أَرْزُومْ خَافِي، خنِّي أَذْ ثدَّارمْ!“  
\v 5 وَارْ ثَارزّْفمْ بَايْثْ-إِلْ، وَارْ د-ثتِّيسمْ غَارْ جِيلْجَالْ ؤُ وَارْعدُّومْ خْ بِئرْ-سبْعَا، مِينْزِي س ثِيذتّْ جِيلْجَالْ أَذْ إِتّْوَانْذهْ غَارْ لْمنْفَا ؤُ بَايْثْ-إِلْ أَذْ ثتّْوَابطّڒْ. \x ◘ \xo 5:‏5 \xt عَام. 4‏:‏4\x*  
\v 6 أَرْزُومْ خْ سِيذِي، خنِّي أَذْ ثدَّارمْ، حِيمَا نتَّا وَارْ إِتِّيذِيفْ غَارْ ثَادَّارْثْ ن يُوسُوفْ أَمْ يِيشْثْ ن ثْمسِّي إِتّتّنْ ؤُ وَارْ ذِينْ إِتِّيڒِي ؤُڒَا ذ إِجّْ مَاحنْذْ أَذْ \add ت\add* إِسّخْسِي ذِي طّْوعْ ن بَايْثْ-إِلْ.“   
\b  
\m
\v 7 ”\add أَخيّبْ إِ\add* يِينِّي إِتَّارَّانْ ڒْحقّْ غَارْ شِّيحْ ؤُ إِنِّي إِسّْهكّْوَانْ ثَاسڭْذَا غَارْ ثمُّورْثْ.  
\v 8 نتَّا ذ ونِّي إِڭِّينْ إِبْلِييَاذنْ ذ ؤُرِييُونْ ذ ونِّي إِتَّارَّانْ ثِيڒِي ن ڒْموْثْ ذ ثُوفُّوثْ ن ڒْحَاڒْ، ذ ونِّي \add إِتَّارَّانْ\add* أَسّْ ذ دْجِيڒثْ، ونِّي إِتّْڒَاغَانْ إِ وَامَانْ ن ڒبْحَارْ ؤُ إِفَارّغْ إِ-ثنْ ثِيوَا إِ وُوذمْ ن ثمُّورْثْ، أَقَا سِيذِي ذ إِسمْ نّسْ!، \x ◘ \xo 5:‏8 \xt أَيُوبْ 9‏:‏9؛ 38‏:‏31؛ عَام. 9‏:‏6\x*  
\v 9 أَقَا نتَّا إِڭَّا أَذْ د-يَاسْ وَاردّدْجْ \add أَمْ\add* وَاسَّامْ خْ ونِّي إِجهْذنْ ؤُ \add أَقَا يَارَّا\add* أَردّدْجْ أَذْ د-يَاسْ خْ لْقلْعَا.  
\v 10 \add مَاشَا\add* نِيثْنِي شَارّْهنْ ونِّي إِدَّافَاعنْ خْ ڒْحقّْ ذِي ثوَّارْثْ \add ن ثنْذِينْثْ\add* ؤُ نِيثْنِي تّْعِيفَّانْ ونِّي إِسَّاوَاڒنْ نِيشَانْ.  
\v 11 س ؤُيَا، مِينْزِي كنِّيوْ ثْعفّْسمْ خْ ؤُمُوقْڒِيڒْ ؤُ ثتّْكسّمْ زَّايسْ ڒعْشُورْ ن إِمنْذِي: \add وَاخَّا\add* ثبْنَامْ ثُوذْرِينْ نْومْ س وژْرُو يُويْذَانْ، وَارْ ذَايْسنْثْ ثْزدّْغمْ، \add وَاخَّا\add* ثژُّومْ ثِيزَايَارِينْ شْنَانْثْ ذڭْ إِمَارْجَاعنْ، وَارْ زَّايْسنْثْ ثْسسّمْ بِينُو. \x ◘ \xo 5:‏11 \xt صَاف. 1‏:‏13\x*  
\v 12 مَاغَارْ نشّْ سّْنغْ أَطَّاسْ ن إِعذِّيينْ نْومْ ؤُ أَقَا دّْنُوبْ نْومْ سّڭّْوَاذنْ: نِيثْنِي حصَّارنْ أَمْسڭّذْ، تّطّْفنْ ثْمنْيَاثْ ن ڒْغشّْ ؤُ عَارّْننْ إِمزْڒَاضْ غَارْ بَارَّا ذِي ثوَّارْثْ \add ن ثنْذِينْثْ\add*.  
\v 13 س ؤُيَا أَذْ إِسّغْذْ ؤُمِيغِيسْ ذِي ڒْوقْثْ نِّي، مَاغَارْ أَذْ ثِيڒِي ذ إِشْثْ ن ڒْوقْثْ ذ ثَاعفَّانْثْ.“   
\b  
\m
\v 14 ”أَرْزُومْ مِينْ إِصبْحنْ، وَارْ إِدْجِي مِينْ إِعفّْننْ، خنِّي أَذْ كِيذْومْ يِيڒِي سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ، أَمْ مَامّشْ \add ث\add* ثقَّارمْ كنِّيوْ.  
\v 15 شَارْهمْ مِينْ إِعفّْننْ، ثخْسمْ مِينْ إِصبْحنْ ؤُ سْمثْنمْ ڒْحقّْ ذِي ثوَّارْثْ \add ن ثنْذِينْثْ\add*. أَذْ ثَاغْ أَذْ إِحِينّْ سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ خْ مِينْ إِقِّيمنْ ن يُوسُوفْ.“ \x ◘ \xo 5:‏15 \xt إِزهد. 34‏:‏15؛ 97‏:‏10؛ رُوم. 12‏:‏9\x*  
\v 16 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ، سِيذِي إِنُو: ذِي مَارَّا أَزَّاينْ أَذْ ثِيڒِي ثْغُويِّيثْ ن وشْضَانْ ؤُ ذِي مَارَّا زّْنَاقِي أَذْ إِنِينْ: ’أَيَّاوْ! أَيَّاوْ!‘، ؤُ نِيثْنِي أَذْ ڒَاغَانْ خْ ؤُفدْجَاحْ، مَاحنْذْ أَذْ إِشْضنْ، ؤُ خْ يِينِّي إِسّْننْ إِزْڒَانْ ن وشْضَانْ مَاحنْذْ أَذْ سْغُوينْ س وشْضَانْ.  
\v 17 ذِي مَارَّا إِمَارْجَاعنْ ن ؤُضِيڒْ \add أَذْ ذِينْ ثِيڒِي\add* ثْغُويِّيثْ ن وشْضَانْ، مَاغَارْ نشّْ أَذْ شُوقغْ ذِي ڒْوسْثْ نّشْ، إِقَّارْ سِيذِي.“   
\b  
\m
\v 18 ”أَيَّاوْ إِ يِينِّي إِتّْمژْرنْ ذڭْ وَاسّْ ن سِيذِي! مِينْ غَارْومْ إِ غَا يِيڒِي وَاسّْ ن سِيذِي؟ \add أَذْ يِيڒِي\add* ذ ثَادْجسْثْ، وَارْ إِتِّيڒِي ذ ثَافَاوْثْ. \x ◘ \xo 5:‏18 \xt إِرْم. 30‏:‏7؛ يُووِ. 2‏:‏2؛ صَاف. 1‏:‏15\x*  
\v 19 \add أَذْ يِيڒِي\add* أَمْ شَا ن إِجّْ إِ يَاروْڒنْ زڭْ وَايْرَاذْ، خنِّي يُوسَا-د غَارسْ دُّوبْ، نِيغْ أَمْ شَا ن إِجّْ إِ يُوذْفنْ غَارْ ثَادَّارْثْ، إِعمّذْ س ؤُفُوسْ نّسْ خْ ڒْحِيضْ، خنِّي إِزْعفْ إِ-ث إِجّْ ن ؤُفِيغَارْ.  
\v 20 \add مَا\add* وَارْ إِتِّيڒِي أَسّْ ن سِيذِي ذ ثَادْجسْثْ ؤُ وَارْ إِتِّيڒِي ذ ثْفَاوْثْ؟ ذ طّْڒَامْ ؤُ وَارْ \add ثدْجِي\add* ؤُڒَا ذ إِشْثْ ن جُّورّثْ ن ثْفَاوْثْ!“   
\b  
\m
\v 21 ”نشّْ شَارّْهغْ، عِيفّغْ ؤُرَارنْ نْومْ ؤُ وَارْ تّخْسغْ أَذْ شمّغْ إِمُونِيثنْ نْومْ إِفَارْزنْ. \x ◘ \xo 5:‏21 \xt إِشا. 1‏:‏11؛ إِرْم. 6‏:‏20\x*  
\v 22 مَاغَارْ وَاخَّا كنِّيوْ ثِيوْيمْ أَيِي-ذ ثِيغَارْصَا نْومْ ن وشْمَاضْ ذ ثوْهِيبِينْ نْومْ \add ن ڒْغِيدْجثْ\add*، نشّْ وَارْ خَاسنْثْ أَرطِّيغْ شَا ؤُ نشّْ وَارْ خزَّارغْ \add وَالُو\add* غَارْ ثوْهِيبْثْ ن ڒهْنَا ن ڒْمَاڒْ إِصحّنْ.  
\v 23 سِيڭّْوجْ خَافِي دّْرِيزْ ن إِزْڒَانْ نّشْ، وَارْ خْسغْ أَذْ سْڒغْ ڒْحسّْ ن لهَارْپَاثْ نّشْ.  
\v 24 أجّْ ڒْحُوكْمْ أَذْ يَازّڒْ أَمْ وَامَانْ \add إِتَّازّْڒنْ\add* ؤُ ثَاسڭْذَا أَمْ يِيجّْ ن إِغْزَارْ إِتَّازّْڒنْ ڒبْذَا.“   
\b  
\m
\v 25 ”مَا ثِيوْيمْ أَيِي-د ثِيغَارْصَا ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذِي ڒخْڒَا أَربْعِينْ ن إِسڭّْوُوسَا، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل؟ \x ◘ \xo 5:‏25 \xt ڒخ. 7‏:‏42\x*  
\v 26 كنِّيوْ ثَارْبُومْ إِقِيضَانْ ن ؤُجدْجِيذْ نْومْ ذ ؤُضَارْ \add إِ خفْ ثُوغَا\add* تّْبدَّانْ ڒخْيَاڒَاثْ نْومْ \add إِ\add* يثْرِي ن إِربِّيثنْ نْومْ، إِنِّي ثڭِّيمْ إِ يِيخفْ نْومْ.  
\v 27 نشّْ أَذْ كنِّيوْ نذْهغْ غَارْ لْمنْفَا، أَغِيرِينْ إِ ذِيمَاشْقْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ، أَقَا ذ وَا ذ إِسمْ نّسْ.“   
\b  
\b  
\m  
\c 6
\m
\v 1 ”ؤُشْثْ خْ يِينِّي وَارْ ذِي يدْجِي بُو ومْنُوسْ ذِي صِيهْيُونْ ؤُ خْ يِينِّي ؤُمِي إِتّْغِيڒْ أَقَا أَثنْ ذِي ڒَامَانْ خْ وذْرَارْ ن سَامَارْيَا، إِمْشنّْعنْ ن ونِّي ذ أَمزْوَارُو جَارْ ڒڭْنُوسْ، إِ غَارسْ د-ثتَّاسْ \add مَارَّا\add* ثَادَّارْثْ ن إِسْرَائِيل. \x ◘ \xo 6:‏1 \xt ؤُف. 19‏:‏5؛ إِرْم. 2‏:‏3\x*   
\m
\v 2 عْذُومْ غَارْ كَالْنَا ؤُ ثْخزَّارمْ \add مَامّشْ ثدْجَا\add*! ؤُيُورمْ سّنِّي غَارْ حَامَاثْ ؤُ هْوَامْ-د غَارْ جَاثْ ن إِفِيلِيسْطِينِييّنْ. مَا نِيثْنِي حْسنْ زِي ثْڭلْذَاوِينْ-أَ نِيغْ ثَامُّورْثْ نْسنْ ذ ثَامقّْرَانْثْ خْ ثمُّورْثْ نْومْ؟ \f ◼ \fr 6:‏2 \ft \+bd ’ثِيڭلْذَاوِينْ-أَ‘\+bd* - إِخْسْ أَذْ يِينِي إِسْرَائِيل ذ يَاهُوذَا.\f*   
\m
\v 3 \add كنِّيوْ\add*، إِنِّي إِسّْبعّْذنْ أَسّْ أَعفَّانْ غَارْ زَّاثْ نْومْ، \add مَاشَا\add* ثسّْقَارَّابمْ ڒْكُوڒْسِي ن لْعُونْفْ،\x ◘ \xo 6:‏3 \xt حِز. 12‏:‏27؛ عَام. 5‏:‏18\x*  
\v 4 \add كنِّيوْ\add*، إِنِّي إِ \add ذِينْ\add* إِتّزّْڒنْ خْ قَامَاثْ ن ڒْعَاجْ ؤُشَا تّسْطِيڒنْ خْ ڒمْطَارْبَاثْ نْومْ ؤُ تّتّنْ إِزْمَارنْ ن وُودْجِي ؤُڒَا ذ إِعجْمِييّنْ زِي ڒْوسْطْ ن ڒْكُورِي، \f ◼ \fr 6:‏4 \ft \+bd ’أَمْوَا‘\+bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*  
\v 5 إِنِّي إِ \add ذِينْ\add* إِغنّْجنْ أَمنِّي وَاهَا غَارْ دْجْغَا ن لهَارْپَا، أَمْ د-سُّوفّْغنْ \add عْڒَامْ كُوڒْ ن\add* إِزْڒَانْ س دُّوزَانْ ن لْمُوسِيقَا، أَمْ مَامّشْ \add ث إِڭَّا\add* ذَاوُوذْ، \x ◘ \xo 6:‏5 \xt إِشا. 5‏:‏12\x*  
\v 6 إِنِّي إِسسّنْ بِينُو زِي طَّاوْيَاثْ ن ؤُرُوشِّي، إِنِّي إِذهّْننْ إِخفْ نْسنْ س ڒمْخيَّارْ ن زّشْثْ ؤُ وَارْ تَّارَّانْ ثَايْنِيثْ إِ ثْرژِّيثْ ن يُوسُوفْ. \x ◘ \xo 6:‏6 \xt إِشا. 5‏:‏11، 12\x*  
\v 7 س ؤُيَا أَذْ ؤُيُورنْ نِيثْنِي ڒخُّو غَارْ لْمنْفَا غَارْ ؤُزدْجِيفْ ن إِمنْفِييّنْ. أَقَا إِتّْوَاقْضَا دّْرِيزْ ن ؤُغُويِّي ن يِينِّي إِ \add ذِينْ\add* إِتّْغِيمَانْ \add غَارْ طَّابْڒَا\add* \x ◘ \xo 6:‏7 \xt إِشا. 5‏:‏13\x*   
\m
\v 8 سِيذِي إِنُو، سِيذِي إِجُّودْجْ س يِيخفْ نّسْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ: نشّْ عِيفّغْ نّْفَاخثْ ن يَاعْقُوبْ ؤُ شَارّْهغْ ڒقْصُورْ نّسْ. س ؤُينِّي أَذْ سلّْمغْ ثَانْذِينْثْ ذ مَارَّا مِينْ ذَايسْ.“   
\b  
\m
\v 9 ”أَذْ إِمْسَارْ ڒَامِي قِّيمنْعشْرَا ن إِرْيَازنْ ذِي ثَادَّارْثْ ذ إِشْثْ، \add أَقَا\add* أَذْ مّْثنْ نِيثْنِي.  
\v 10 \add مَاڒَا\add*عمِّيسْ، ونِّي خَاسْ مَاحنْذْ أَذْ ث إِسّْشمْضْ، أَذْ ث إِكْسِي حِيمَا أَذْ إِسُّوفّغْ ڒْخشْبثْ زِي ثَادَّارْثْ، ؤُشَا \add خنِّي\add* أَذْ يِينِي إِ ونِّي \add عَاذْ\add* غَارْ ذَاخڒْ ذِي ثَادَّارْثْ: ’مَا أَقَا ذِينْ غَاركْ عَاذْ كْثَارْ؟‘، ؤُشَا أَذْ يِينِي ونّغْنِي: ’ؤُڒَا ذ إِجّْ!‘، \add خنِّي\add* أَذْ يِينِي نتَّا: ’سْقَارْ، مِينْزِي إِتّْخصَّا وَارْ نتِّيذَارْ إِسمْ ن سِيذِي.‘ “   
\b  
\m
\v 11 ”مَاغَارْ خْزَارْ، سِيذِي إِتَّامَارْ، ؤُشَا نتَّا أَذْ إِوّثْ ثَادَّارْثْ ثَامقّْرَانْثْ أَڒْ غَا ثذْوڒْ ذ ڒْخَارْبثْ ؤُ ثَادَّارْثْ ثَامژْيَانْثْ \add أَذْ ثذْوڒْ\add* ذ إِشدْجِيقنْ.  
\v 12 مَا أَذْ ثَازّْڒنْ إِيْسَانْ خْ ڒجْرُوفْ؟ مَا أَذْ ث شَارْزنْ س إِفُونَاسنْ؟ كنِّيوْ مَاشَا ثَارِّيمْ ڒْحقّْ ذ أَرّْهَاجْ ؤُ ڒْغِيدْجثْ ن ثْسڭْذَا ثَارِّيمْ ت ذ شِّيحْ. \x ◘ \xo 6:‏12 \xt عَام. 5‏:‏7\x*  
\v 13 \add كنِّيوْ\add* إِنِّي إِفَارّْحنْ زِي مِينْ وَارْ إِدْجِينْ، إِنِّي إِقَّارنْ: ’مَا وَارْ نطِّيفْ أَشَّاونْ س جّهْذْ نّغْ؟‘  
\v 14 مَاغَارْ خْزَارْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل، نشّْ أَذْ د-سّكَّارغْ إِجّْ ن ڒْڭنْسْ ضِيدّْ نْومْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ. نِيثْنِي أَذْ كنِّيوْ حْصَارنْ زِي مَانِيسْ د-إِوْضنْ \add إِوْذَانْ\add* غَارْ حَامَاثْ أَڒْ ثَاغْزَارْثْ ن ڒوْضَا.“   
\b  
\b  
\m  
\c 7
\s1 ثَامژْرِيوْثْ ثَامزْوَارُوثْ: إِپُورخْسنْ  
\m
\v 1 ”مَانْ أَيَا إِسّْشنْ أَيِي \add ت\add* سِيذِي إِنُو، سِيذِي! خْزَارْ، نتَّا إِڭَّا إِبُورخْسنْ ؤُمِي ثُوغَا أَرْبِيعْ أَنڭَّارْ إِبدَّا أَذْ إِسُّوفّغْ. خْزَارْ، ثُوغَا-ث ذ أَرْبِيعْ أَنڭَّارْ أَوَارْنِي مَا حثْشنْ \add أَرْبِيعْ\add* إِ ؤُجدْجِيذْ.  
\v 2 إِمْسَارْ، ؤُمِي كمّْڒنْ نِيثْنِي زِي مَاشَّا ن ؤُغمُّويْ أَزِيزَا ن ثمُّورْثْ، نشّْ نِّيغْ: ’\add أَ\add* سِيذِي إِنُو، سِيذِي، سَامحْ مَاشَا! مَامّشْ إِ غَا يڭّْ يَاعْقُوبْ أَذْ إِقِّيمْ أَذْ إِبدّْ، أَقَا نتَّا ذ أَمژْيَانْ!‘  
\v 3 \add خنِّي\add* إِنْذمْ سِيذِي خْ مَانْ أَيَا. ’وَارْ إِتِّيڒِي!‘، إِنَّا سِيذِي.“   
\b  
\m  
\s1 ثَامژْرِيوْثْ وِيسّْ ثْنَاينْ: ثِيمسِّي إِهلّْكنْ  
\m
\v 4 ”مَانْ أَيَا إِسّْشنْ أَيِي \add ت\add* سِيذِي إِنُو، سِيذِي. خْزَارْ، سِيذِي إِنُو، سِيذِي، إِڒَاغَا-د مَاحنْذْ أَذْ ذِينْ يِيڒِي لْعِيقَابْ س ثْمسِّي ؤُشَا \add ثِيمسِّي\add* ثشَّا \add أَمَانْ\add* إِمقّْرَاننْ إِهوْڒنْ أَڒَامِي أَذْ ثشّْ \add ؤُڒَا ذ\add* ثَاسْغَارْثْ \add ن ڒْوَارْثْ\add*. \f ◼ \fr 7:‏4 \ft \+bd ’ڒْوَارْثْ‘\+bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي ’ثَامُّورْثْ ن إِسْرَائِيل‘ إِ إِوْشَا سِيذِي إِ أَيْثْ ن إِسْرَائِيل.\f*  
\v 5 نشّْ نِّيغْ: ’\add أَ\add* سِيذِي إِنُو، سِيذِي، سْبدّْ مَاشَا! مَامّشْ إِ غَا يڭّْ يَاعْقُوبْ أَذْ إِقِّيمْ أَذْ إِبدّْ، أَقَا نتَّا ذ أَمژْيَانْ!‘  
\v 6 \add خنِّي\add* إِنْذمْ سِيذِي خْ مَانْ أَيَا. ’وَارْ إِتِّيڒِي!‘، إِنَّا سِيذِي إِنُو، سِيذِي!“   
\b  
\m  
\s1 ثَامژْرِيوْثْ وِيسّْ ثْڒَاثَا: بْلُومُو ن ڒْحِيضْ  
\m
\v 7 ”مَانْ أَيَا إِسّْشنْ أَيِي \add ت\add* نتَّا: خْزَارْ، سِيذِي إِنُو إِبدّْ خْ يِيجّْ ن ڒْحِيضْ إِ إِتّْوَاڭّْ س بْلُومُو ؤُ يِيجّْ ن بْلُومُو ثُوغَا ذڭْ ؤُفُوسْ نّسْ.  
\v 8 إِنَّا أَيِي سِيذِي: ’مِينْ ثتّْوَارِيذْ شكْ، عَامُوسْ؟‘ نشّْ نِّيغْ: ’إِجّْ ن بْلُومُو!‘ \add ڒخْذنِّي\add* إِنَّا سِيذِي: ’خْزَارْ، نشّْ أَذْ أَرّغْ بْلُومُو إِنُو ذِي ڒْوسْطْ نْ ڒْڭنْسْ ن إِسْرَائِيل. نشّْ وَارْ خَاسْعدُّوغْ عَاذْ!  
\v 9 ڒڭْعُوذِي ن إِسْحَاقْ أَذْ تّْوَاردّْدْجنْثْ ؤُ ثِيزَاوِييِّينْ إِقدّْسنْ ن إِسْرَائِيل أَذْ ذوْڒنْثْ ذ ڒْخَارْبثْ ؤُ نشّْ أَذْ كَّارغْ خْ ثَادَّارْثْ ن يَارُوبْعَامْ س سِّيفْ.‘ “   
\b  
\m  
\s1 أَجدْجِيذْ أَمَاصْيَا إِخْسْ أَذْ يَاژّڒْ خْ عَامُوسْ زِي ثمُّورْثْ  
\m
\v 10 \add ڒخْذنِّي\add* إِسّكّْ أَمَاصْيَا، أَكهَّانْ ذِي بَايْثْ-إِلْ، \add إِجّنْ\add* غَارْ يَارُوبْعَامْ، أَجدْجِيذْ ن إِسْرَائِيل، إِنَّا: ”عَامُوسْ إِڭَّا إِجّْ ن ڒْعَاهْذْ ضِيدّْ إِ شكْ ذِي ڒْوسْطْ ن ثَادَّارْثْ ن إِسْرَائِيل. ثَامُّورْثْ وَارْ ثْزمَّارْ أَذْ ثكْسِي أَوَاڒنْ نّسْ.  
\v 11 مَاغَارْ أَمُّو إِ إِقَّارْ عَامُوسْ: ’يَارُوبْعَامْ أَذْ إِتّْوَانغْ س سِّيفْ ؤُ إِسْرَائِيل أَذْ إِتّْوَانْذهْ غَارْ لْمنْفَا، أَذْ ث سِّيڭّْوجنْ خْ وُوذمْ ن ثمُّورْثْ نّسْ.‘ “  
\v 12 \add خنِّي\add* إِنَّا أَمَاصْيَا إِ عَامُوسْ: ”\add أَ\add* شكْ، أَمْوَاڒَاوْ، رُوحْ، أَرْوڒْ غَارْ ثمُّورْثْ ن يَاهُوذَا! أشّْ ذِينِّي أَغْرُومْ ؤُ نَابّْ ذِينِّي!  
\v 13 ذِي بَايْثْ-إِلْ \add مَاشَا\add* وَارْ ثْزمَّارذْ أَذْ ثْنبِّيذْ عَاذْ، مِينْزِي نتَّاثْ ذ زَّاوشْثْ إِقدّْسنْ ن ؤُجدْجِيذْ ؤُ نتَّاثْ ذ ثَادَّارْثْ ن ثَاڭلْذِيثْ.“   
\m
\v 14 يَارَّا-د عَامُوسْ، إِنَّا إِ أَمَاصْيَا: ”نشّْ وَارْ دْجِيغْ ذ أَنَابِي ؤُ نشّْ وَارْ دْجِيغْ ذ مِّيسْ ن ؤُنَابِي، مَاشَا نشّْ ثُوغَا أَيِي ذ بُو-ڒبْهَايمْ ؤُڒَا ذ إِجّْ ن ورْيَازْ نِّي إِڒقّْضنْ ثَازَارْثْ ثابُورشْثْ.  
\v 15 سِيذِي إِكّسْ أَيِي زِي ضفَّارْ ن وُودْجِي ؤُ سِيذِي إِنَّا أَيِي: ’ؤُيُورْ، نَابّْ إِ ڒْڭنْسْ إِنُو إِسْرَائِيل!‘  
\v 16 \add خنِّي\add* ڒخُّو، سڒْ إِ وَاوَاڒْ ن سِيذِي، شكْ ذ ونِّي إِقَّارنْ: ’وَارْ إِعدّڒْ أَذْ ثْنبِّيذْ ضِيدّْ إِ إِسْرَائِيل ؤُ أَذْ ثسُّوذْمذْ \add أَوَاڒْ ن سِيذِي\add* خْ ثَادَّارْثْ ن إِسْحَاقْ!‘ \x ◘ \xo 7:‏16 \xt حِز. 21‏:‏7\x*  
\v 17 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي: ثَامْغَارْثْ نّشْ أَذْ ثسّفْسذْ إِخفْ نّسْ س ؤُغِيڒْ ذِي ثنْذِينْثْ ؤُ إِحنْجِيرنْ نّشْ ذ يسِّيشْ نّشْ أَذْ وْضَانْ س سِّيفْ ؤُ ثَامُّورْثْ نّشْ أَذْ ت بْضَانْ س ؤُفِيڒُو ن ڒعْبَارْ ؤُ شكْ أَذْ ثمّْثذْ ذڭْ إِشْثْ ن ثمُّورْثْ ثخْمجْ ؤُ س ثِيذتّْ إِسْرَائِيل أَذْ ثتّْوَاطّفْ ذِي لْمنْفَا بَارَّا إِ ثمُّورْثْ نّسْ.“   
\b  
\b  
\m  
\c 8
\s1 ثَامژْرِيوْثْ وِيسّْ أَربْعَا: ثَاسُودْجثْ س ڒْغِيدْجثْ  
\m
\v 1 ”مَانْ أَيَا إِسّْشنْ أَيِي \add ت\add* سِيذِي إِنُو، سِيذِي: خْزَارْ، إِشْثْ ن ثْسُودْجثْ ذَايسْ ثِينِي ن ؤُنبْذُو!  
\v 2 نتَّا إِنَّا: ’مِينْ ثتّْوَاڒِيذْ شكْ أَ عَامُوسْ؟‘ نشّْ نِّيغْ: ’إِشْثْ ن ثْسُودْجثْ ذَايسْ ثِينِي ن ؤُنبْذُو!‘ \add خنِّي\add* إِنَّا أَيِي سِيذِي: ’أَقَا يُوسَا-د قطُّو خْ ڒْڭنْسْ إِنُو إِسْرَائِيل. نشّْ وَارْ خَاسْعدُّوغْ عَاذْ!  
\v 3 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ ذوْڒنْ إِزْڒَانْ ن ڒقْصَارْ ذ إِمطَّاونْ، إِقَّارْ سِيذِي إِنُو، سِيذِي. أَذْ إِڒِينْثْ أَطَّاسْ ن ڒْخشْبَاثْ ذِي كُوڒْ أَمْشَانْ، ثِينِّي إِنْضَارْ نتَّا. سغْذْ!‘ “   
\b  
\m  
\s1 إِعْڒَامنْ إِمقّْرَاننْ ن سِيذِي  
\m
\v 4 ”سْڒمْ أَيَا، كنِّيوْ إِنِّي إِصَارّْضنْ أَمزْڒُوضْ ؤُ ثقْضَامْ خْ ڒْمُوسَاكِينْ ن ثمُّورْثْ،  
\v 5 أَمْ ثقَّارمْ: ’مڒْمِي غَا إِعْذُو ؤُيُورْ ن جْذِيذْ أَڒَامِي \add نْزمَّارْ\add* أَذْ نزّنْزْ ڒْحبّْ \add ن يِيرْذنْ\add*. ؤُ \add مڒْمِي غَا إِعْذُو وَاسّْ ن\add* سّبْثْ أَڒَامِي \add نْزمَّارْ\add* أَذْ نَارْزمْ ثِيسْرَافِينْ \add ن يِيرْذنْ\add*، حِيمَا أَذْ نسّمْژِي \add ڒعْبَارْ ن\add* إِفَا ؤُ أَذْ نسّمْغَارْ شِيقْلُو ؤُ أَذْ نشْمثْ س ڒْمِيزَانَاثْ ن ڒْغشّْ، \x ◘ \xo 8:‏5 \xt حُوش. 12‏:‏8\x*  
\v 6 أَڒَامِي نْزمَّارْ أَذْ نْسغْ إِمُوقْڒِيڒنْ س \add ثنْعَاشِينْ ن\add* نُّوقَارْثْ ؤُڒَا ذ أَمزْڒُوضْ إِ ثْيُويَا ن سَانْذَالِييَاثْ!‘، ؤُ \add أَمْ ثقَّارمْ\add*: ’أَذْ نزّنْزْ إِشَارْفَا ذڭْ ومْشَانْ ن إِمنْذِي!‘ “\x ◘ \xo 8:‏6 \xt عَام. 2‏:‏6\x*   
\b  
\m
\v 7 ”سِيذِي إِجُّودْجْ غَارْ نّْفَاخثْ ن يَاعْقُوبْ: ’عمَّارْصْ أَذْ تُّوغْ ثِيمڭَّا نْسنْ!  
\v 8 مَا وَارْ تّنْهزِّي ثمُّورْثْ س مَانْ أَيَا ؤُ مَا وَارْ تِّيڒِينْ مَارَّا إِمزْذَاغْ نّسْ شضْننْ؟ مَا وَارْ ثتّْڭعِّيذْ \add ثمُّورْثْ\add* ثْمُونْ أَمْ يغْزَارْ، أَذْ ثَاڒِي ؤُ أَذْ د-ثهْوَا أَمْ يغْزَارْ ن مِيصْرَا؟“   
\b  
\m
\v 9 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِمْسَارْ، إِقَّارْ سِيذِي إِنُو، سِيذِي، أَذْ أَرّغْ ثْفُوشْثْ أَذْ ثغْڒِي ذڭْ وزْينْ ن وَاسّْ ؤُ أَذْ سّْبَارشْنغْ ثَامُّورْثْ غَارْ طْحَا ن وَاسّْ.  
\v 10 نشّْ أَذْ أَرّغْ فِيشْثَاثْ نْومْ ذ أَشْضَانْ ذ مَارَّا إِزْڒَانْ نْومْ ذ إِزْڒَانْ ن وشْضَانْ ؤُ نشّْ أَذْ ڭّغْ إِشْثْ ن ثْخَانْشثْ \add ن وشْضَانْ\add* خْ مَارَّا ثْبيْسَا ؤُ خْ كُوڒْ أَزدْجِيفْ أَذْ ڭّغْ ثُوقشَّارْثْ. أَذْ أَوْيغْ أَشْضَانْ \add خْ ثمُّورْثْ\add* أَمْ \add وشْضَانْ\add* خْ ؤُينِّي ن مِّيسْ، ؤُ \add أَ\add*قطُّو نّسْ أَذْ ث ڭّغْ أَمْ يِيجّْ ن وَاسّْ ذ أَمَارْزَاڭْ.“   
\b  
\m
\v 11 ”خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ، إِقَّارْ سِيذِي إِنُو، سِيذِي، أَقَا نشّْ أَذْ سّكّغْ ڒَاژْ خْ ثمُّورْثْ، وَارْ إِدْجِي ڒَاژْ ن وغْرُومْ، وَارْ إِدْجِي فَاذْ ن وَامَانْ، مَاشَا \add إِجّْ ن ؤُفَاذِي\add* مَاحنْذْ أَذْ سْڒنْ إِ وَاوَاڒنْ ن سِيذِي.  
\v 12 \add خنِّي\add* أَذْ تّلْعنْ زِي ڒبْحَارْ غَارْ ڒبْحَارْ ؤُ زِي شَّامَالْ غَارْ شَّارْقْ، أَذْ ؤُيُورنْ زِي سَّا غَارْ ذَا مَاحنْذْ أَذْ أَرْزُونْ خْ وَاوَاڒْ ن سِيذِي، \add مَاشَا\add* وَارْ ث تِّيفنْ.  
\v 13 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ غَاشَانْثْ ثعْزَارِييِّينْ نِّي إِشْنَانْ قَاعْ ؤُڒَا ذ إِحُوذْرِييّنْ س ؤُفَاذِي،  
\v 14 إِنِّي إِتّْجَّادْجَانْ غَارْ ؤُمَارْوَاسْ ن سَامَارْيَا، قَّارنْ: ’س ثِيذتّْ أَمْ إِدَّارْ أَربِّي نّشْ، \add أَ\add* ذَانْ، ؤُ أَمْ إِدَّارْ وبْرِيذْ غَارْ بِئرْ-سبْعَا!‘، أَذْ وْضَانْ، وَارْ تّكَّارنْ عَاذْ!“ \x ◘ \xo 8:‏14 \xt عَام. 5‏:‏5\x*   
\b  
\b  
\m  
\c 9
\s1 ثَامژْرِيوْثْ وِيسّْ خمْسَا: ڒْحُوكْمْ أَنڭَّارُو  
\m
\v 1 ”نشّْ ژْرِيغْ سِيذِي إِنُو إِبدّْ غَارْ ؤُعَالْطَارْ، إِنَّا: ’وّثْ خْ ؤُزدْجِيفْ \add ن ؤُپِيلَارْ\add*، \add أَڒَامِي\add* إِ غَا أَرْجِيجنْثْ ثْنبْذَاثِينْ ؤُ أَرْژْ إِ-ثنْثْ ذ إِوثْوِيثنْ خْ ؤُزدْجِيفْ نْسنْ مَارَّا. مِينْ زَّايْسنْ إِقِّيمنْ، أَذْ ث نْغغْ س سِّيفْ. وَارْ زَّايْسنْ إِتّْرِيكّْوِيڒْ ؤُڒَا ذ إِجّْ ن ؤُمَارْوَاڒْ ؤُ ؤُڒَا ذ إِجّْ ونِّي إِنجّْمنْ، أَذْ إِتّْوَافكّْ.  
\v 2 وَاخَّا نِيثْنِي غْزِينْ أَڒَامِي \add إِوْضنْ غَارْ\add* ثْمسِّي ن ڒَاخَارْثْ، أَفُوسْ إِنُو أَذْ ثنْ سّنِّي يَاوِي، ؤُ وَاخَّا نِيثْنِي ڭعَّاذنْ غَارْ ؤُجنَّا، نشّْ أَذْ ثنْ د سّنِّي سّهْوِيغْ، \x ◘ \xo 9:‏2 \xt إِزهد. 139‏:‏8‏-‏10\x*  
\v 3 وَاخَّا نِيثْنِي سّْنُوفَّارنْ إِخفْ نْسنْ خْ ثْقِيشَّاثْ ن \add وذْرَارْ ن\add* كَارْمِيلْ، نشّْ أَذْ أَرْزُوغْ ؤُ أَذْ ثنْ د-أَوْيغْ سّنِّي. وَاخَّا نِيثْنِي سّْنُوفَّارنْ إِخفْ نْسنْ زَّاثْ إِ ثِيطَّاوِينْ إِنُو خْ ثِيسِي ن ڒبْحَارْ، خنِّي نشّْ أَذْ وصِّيغْ أَفِيغَارْ مَاحنْذْ أَذْ ثنْ إِزْعفْ،  
\v 4 ؤُ وَاخَّا نِيثْنِي ؤُيُورنْ ذِي ثْمحْبَاسْثْ زَّاثْ إِ وُوذمْ ن ڒْعذْيَانْ نْسنْ، نشّْ أَذْ وصِّيغْ ذِينِّي سِّيفْ مَاحنْذْ أَذْ ثنْ إِنغْ. نشّْ أَذْ خَاسنْ نْضَارغْ ثِيطّْ إِنُو إِ ڒْغَارْ، وَارْ إِدْجِي إِ ڒْخَارْ. \x ◘ \xo 9:‏4 \xt إِرْم. 44‏:‏11\x*  
\v 5 سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ، نتَّا ذ ونِّي إِتّْحَاذَانْ ثَامُّورْثْ، \add أَڒَامِي\add* ثنْهزّْ ؤُ مَارَّا إِمزْذَاغْ نّسْ شضْننْ. ثتّْڭعّذْ ثْمُونْ أَمْ يغْزَارْ ن نِيلْ ؤُشَا ثتَّاڒِي ثْهكّْوِي أَمْ يغْزَارْ ن مِيصْرَا.  
\v 6 نتَّا ذ ونِّي إِبنَّانْ إِخَّامنْ نّسْ سنّجْ ذڭْ ؤُجنَّا ؤُ إِتّڭّْ ڒْقُوبّثْ نّسْ خْ ثمُّورْثْ، نتَّا ذ ونِّي إِتّْڒَاغَانْ إِ وَامَانْ ن ڒبْحَارْ ؤُشَا إِتّْفَارّغْ إِ-ثنْ خْ وُوذمْ ن ثمُّورْثْ، سِيذِي ذ إِسمْ نّسْ.\x ◘ \xo 9:‏6 \xt إِزهد. 104‏:‏3، 13؛ عَام. 5‏:‏8\x*  
\v 7 مَا كنِّيوْ وَارْ ثدْجِيمْ إِنُو أَمْ أَيْثْ ن كُوشْ، \add أَ\add* أَيْثْ ن إِسْرَائِيل؟، إِقَّارْ سِيذِي. مَا نشّْ وَارْ د-سُّوفّْغغْ إِسْرَائِيل زِي مِيصْرَا ؤُ إِفِيلِيسْطِينِييّنْ زِي كَافْثُورْ ؤُ أَرَامْ زِي قِيرْ؟  
\v 8 خْزَارمْ، ثِيطَّاوِينْ ن سِيذِي إِنُو، سِيذِي، أَقَا أَثنْثْ ضِيدّْ إِ ثْڭلْذِيثْ ثَامذْنُوبْثْ. نشّْ أَذْ ت ثحِّيغْ زڭْ وُوذمْ ن ثمُّورْثْ. نشّْ مَاشَا وَارْ تّحِّيغْ مَارَّا ثَادَّارْثْ ن يَاعْقُوبْ، إِقَّارْ سِيذِي.  
\v 9 مَاغَارْ خْزَارمْ، نشّْ أَذْ ؤُمُورغْ ؤُ أَذْ زّڒْزغْ ثَادَّارْثْ ن إِسْرَائِيل جَارْ مَارَّا ڒڭْنُوسْ، أَمْ مَامّشْ زّڒْزنْ زَّارِيعثْ ذڭْ إِجّْ ن بُو-سِييَّارْ ؤُ وَارْ ثْوطِّي ؤُڒَا ذ إِشْثْ ن ثْحبُّوشْثْ غَارْ ثمُّورْثْ.  
\v 10 مَارَّا إِمذْنَابْ ن ڒْڭنْسْ إِنُو أَذْ تّْوَانْغنْ س سِّيفْ، إِنِّي إِقَّارنْ: ’ڒْغَارْ وَارْ ذ أَنغْ إِڒقّفْ شَا ؤُ وَارْ غَارْنغْ د-إِتّْقَارِّيبْ شَا زِي مَارَّا إِغزْذِيسنْ!‘ “   
\b  
\m
\v 11 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ سّْڭعّْذغْ عَاوذْ ثَاخْزَانْثْ إِوطَّانْ ن ذَاوُوذْ إِ إِوْضَانْ ؤُ نشّْ أَذْ قّْنغْ ثِيزَّا نّسْ ؤُ مِينْ زَّايسْ إِتّْوَاهذْمنْ، أَذْ ث أَرّغْ غَارْ ومْشَانْ نّسْ ؤُ نشّْ أَذْ ث بْنِيغْ \add عَاوذْ\add* أَمْ ذڭْ وُوسَّانْ ن وشْحَاڒْ ؤُيَا، \x ◘ \xo 9:‏11 \xt ڒخ. 15‏:‏16\x*  
\v 12 مَاحنْذْ نِيثْنِي أَذْ وَارْثنْ مِينْ إِقِّيمنْ زِي إِذُومْ ذ مَارَّا ڒڭْنُوسْ إِ خْ إِتّْوَابَارّحْ س يِيسمْ إِنُو، إِقَّارْ سِيذِي ونِّي إِتّڭّنْ مَارَّا أَيَا.  
\v 13 خْزَارمْ، أَذْ د-أَسنْ وُوسَّانْ، إِقَّارْ سِيذِي، أَقَا ونِّي إِشَارّْزنْ أَذْ خَاسْ د-إِحَارْثْ ونِّي إِمجَّارنْ، ؤُ ونِّي إِڒبّْزنْ أَضِيڒْ س إِضَارنْ \add أَذْ خَاسْ د-إِحَارْثْ\add* ونِّي إِسّْوِيژّْضنْ \add أَفُوسْ أَكْ-ذ\add* زَّارِيعثْ، ؤُ إِذُورَارْ أَذْ تُّوشْرُورنْ س بِينُو ژمّنْ ث جْذِيذْ، ؤُ مَارَّا ثِيوْرِيرِينْ أَذْ سّفْينْثْ. \x ◘ \xo 9:‏13 \xt يُووِ. 4‏:‏18\x*  
\v 14 نشّْ أَذْ سّنْقڒْبغْ ثَامحْبَاسْثْ خْ ڒْڭنْسْ إِنُو إِسْرَائِيل ؤُ نِيثْنِي أَذْ بْنَانْ عَاوذْ ثِيندَّامْ إِ ثُوغَا إِتّْوَاهذْمنْ ؤُ أَذْ ذَايْسنْثْ زدّْغنْ ؤُ نِيثْنِي أَذْ ڭّنْ إِمَارْجَاعنْ ن ؤُضِيڒْ أَذْ ذَايْسنْ ژُّونْ ثِيزَايَارِينْ ؤُ أَذْ زَّايْسنْثْ سْونْ بِينُو، أَذْ ڭّنْ إِحْوِيشنْ أَذْ شّنْ ڒْغِيدْجثْ نّسْ.  
\v 15 نشّْ أَذْ ثنْ ژُّوغْ ذِي ثمُّورْثْ نْسنْ ؤُعمَّارْصْ عَاذْ أَذْ تّْوَاقڒْعنْ زِي ثمُّورْثْ نْسنْ نِّي إِ ذ أَسنْ وْشِيغْ، إِقَّارْ سِيذِي، أَربِّي نّشْ.“ \x ◘ \xo 9:‏15 \xt إِرْم. 32‏:‏41\x*   