\v 24 \w Stop|strong="G3361"\w* \w judging|strong="G2919"\w* \w on|strong="G2596"\w* \w the|strong="G2596"\w* \w basis|strong="G2596"\w* \w of|strong="G2596"\w* appearances, \w but|strong="G3361"\w* \w judge|strong="G2919"\w* \w the|strong="G2596"\w* \w righteous|strong="G1342"\w* \w judgment|strong="G2920"\w*.”
