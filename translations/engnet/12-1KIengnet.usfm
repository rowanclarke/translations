\v 26  \w The|strong="H5921"\w* real mother spoke \w up|strong="H5414"\w* \w to|strong="H4191"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w*, \w for|strong="H3588"\w* \w her|strong="H5414"\w* motherly instincts \w were|strong="H1961"\w* aroused. \w She|strong="H3588"\w* said, “\w My|strong="H5414"\w* \w master|strong="H5414"\w*, \w give|strong="H5414"\w* \w her|strong="H5414"\w* \w the|strong="H5921"\w* \w living|strong="H2416"\w* \w child|strong="H1121"\w*! \w Whatever|strong="H1504"\w* \w you|strong="H5414"\w* do, don’t \w kill|strong="H4191"\w* \w him|strong="H5414"\w*!” \w But|strong="H3588"\w* \w the|strong="H5921"\w* \w other|strong="H3205"\w* \w woman|strong="H3205"\w* said, “\w Neither|strong="H3808"\w* \w one|strong="H3808"\w* \w of|strong="H1121"\w* \w us|strong="H5414"\w* \w will|strong="H1961"\w* \w have|strong="H1961"\w* \w him|strong="H5414"\w*! \w Let|strong="H5414"\w* \w them|strong="H5414"\w* \w cut|strong="H1504"\w* \w him|strong="H5414"\w* \w in|strong="H5921"\w* \w two|strong="H3808"\w*!”  
\v 27  \w The|strong="H5414"\w* \w king|strong="H4428"\w* \w responded|strong="H6030"\w*, “\w Give|strong="H5414"\w* \w the|strong="H5414"\w* first \w woman|strong="H3205"\w* \w the|strong="H5414"\w* \w living|strong="H2416"\w* \w child|strong="H3205"\w*; don’t \w kill|strong="H4191"\w* \w him|strong="H5414"\w*. \w She|strong="H1931"\w* \w is|strong="H1931"\w* \w the|strong="H5414"\w* mother.”  
\v 28  \w When|strong="H3588"\w* \w all|strong="H3605"\w* \w Israel|strong="H3478"\w* \w heard|strong="H8085"\w* \w about|strong="H8085"\w* \w the|strong="H3605"\w* judicial \w decision|strong="H4941"\w* \w which|strong="H3478"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w had|strong="H3478"\w* rendered, \w they|strong="H3588"\w* respected \w the|strong="H3605"\w* \w king|strong="H4428"\w*, \w for|strong="H3588"\w* \w they|strong="H3588"\w* \w realized|strong="H7200"\w* \w that|strong="H3588"\w* \w he|strong="H3588"\w* possessed supernatural \w wisdom|strong="H2451"\w* \w to|strong="H3478"\w* \w make|strong="H6213"\w* judicial \w decisions|strong="H4941"\w*.   
\c 4  
\p
\v 1  \w King|strong="H4428"\w* \w Solomon|strong="H8010"\w* \w ruled|strong="H4428"\w* \w over|strong="H5921"\w* \w all|strong="H3605"\w* \w Israel|strong="H3478"\w*.  
\v 2  These \w were|strong="H1121"\w* \w his|strong="H6659"\w* \w officials|strong="H8269"\w*:  
\p \w Azariah|strong="H5838"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Zadok|strong="H6659"\w* \w was|strong="H1121"\w* \w the|strong="H6659"\w* \w priest|strong="H3548"\w*.   
\p
\v 3  Elihoreph \w and|strong="H1121"\w* Ahijah, \w the|strong="H2142"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Shisha|strong="H7894"\w*, wrote down \w what|strong="H2142"\w* happened.  
\p \w Jehoshaphat|strong="H3092"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Ahilud \w was|strong="H1121"\w* \w in|strong="H1121"\w* charge \w of|strong="H1121"\w* \w the|strong="H2142"\w* records.   
\p
\v 4  \w Benaiah|strong="H1141"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jehoiada|strong="H3077"\w* \w was|strong="H1121"\w* commander \w of|strong="H1121"\w* \w the|strong="H5921"\w* \w army|strong="H6635"\w*.  
\p \w Zadok|strong="H6659"\w* \w and|strong="H1121"\w* Abiathar \w were|strong="H1121"\w* \w priests|strong="H3548"\w*.   
\p
\v 5  \w Azariah|strong="H5838"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Nathan|strong="H5416"\w* \w was|strong="H4428"\w* \w supervisor|strong="H5921"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* \w district|strong="H5324"\w* governors.  
\p \w Zabud|strong="H2071"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Nathan|strong="H5416"\w* \w was|strong="H4428"\w* \w a|strong="H3068"\w* \w priest|strong="H3548"\w* \w and|strong="H1121"\w* adviser \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w*.   
\p
\v 6  Ahishar \w was|strong="H1004"\w* \w supervisor|strong="H5921"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* \w palace|strong="H1004"\w*.  
\p Adoniram \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Abda|strong="H5653"\w* \w was|strong="H1004"\w* \w supervisor|strong="H5921"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* work crews.   
\p
\v 7  \w Solomon|strong="H8010"\w* \w had|strong="H1961"\w* \w twelve|strong="H8147"\w* \w district|strong="H5324"\w* governors \w appointed|strong="H5324"\w* \w throughout|strong="H3605"\w* \w Israel|strong="H3478"\w* \w who|strong="H3605"\w* acquired supplies \w for|strong="H5921"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w and|strong="H3478"\w* \w his|strong="H3605"\w* \w palace|strong="H1004"\w*. \w Each|strong="H3605"\w* \w was|strong="H1961"\w* responsible \w for|strong="H5921"\w* \w one|strong="H3605"\w* \w month|strong="H2320"\w* \w in|strong="H5921"\w* \w the|strong="H3605"\w* \w year|strong="H8141"\w*.  
\v 8  These \w were|strong="H2022"\w* their \w names|strong="H8034"\w*:  
\p \w Ben-Hur|strong="H1133"\w* \w was|strong="H8034"\w* \w in|strong="H8034"\w* charge \w of|strong="H2022"\w* \w the|strong="H8034"\w* \w hill|strong="H2022"\w* \w country|strong="H2022"\w* \w of|strong="H2022"\w* \w Ephraim|strong="H8034"\w*.   
\p
\v 9  \w Ben-Deker|strong="H1128"\w* was \w in|strong="H1128"\w* charge of \w Makaz|strong="H4739"\w*, \w Shaalbim|strong="H8169"\w*, Beth Shemesh, \w and|strong="H1053"\w* Elon Beth Hanan.   
\p
\v 10  \w Ben-Hesed|strong="H1136"\w* \w was|strong="H3605"\w* \w in|strong="H3605"\w* charge \w of|strong="H3605"\w* Arubboth; \w he|strong="H3605"\w* controlled \w Socoh|strong="H7755"\w* \w and|strong="H3605"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* territory \w of|strong="H3605"\w* \w Hepher|strong="H2660"\w*.   
\p
\v 11  \w Ben-Abinadab|strong="H1125"\w* \w was|strong="H1961"\w* \w in|strong="H8010"\w* charge \w of|strong="H1323"\w* Naphath \w Dor|strong="H1756"\w*. (\w He|strong="H3605"\w* \w was|strong="H1961"\w* married \w to|strong="H1961"\w* \w Solomon|strong="H8010"\w*’s \w daughter|strong="H1323"\w* \w Taphath|strong="H2955"\w*.)   
\p
\v 12  \w Baana|strong="H1195"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Ahilud \w was|strong="H1121"\w* \w in|strong="H1121"\w* charge \w of|strong="H1121"\w* \w Taanach|strong="H8590"\w* \w and|strong="H1121"\w* \w Megiddo|strong="H4023"\w*, \w as|strong="H5704"\w* well \w as|strong="H5704"\w* \w all|strong="H3605"\w* \w of|strong="H1121"\w* Beth Shan next \w to|strong="H5704"\w* \w Zarethan|strong="H6891"\w* \w below|strong="H8478"\w* \w Jezreel|strong="H3157"\w*, \w from|strong="H1121"\w* Beth Shan \w to|strong="H5704"\w* Abel Meholah \w and|strong="H1121"\w* \w on|strong="H8478"\w* past \w Jokmeam|strong="H3361"\w*.   
\p
\v 13  \w Ben-Geber|strong="H1127"\w* \w was|strong="H5892"\w* \w in|strong="H5892"\w* charge \w of|strong="H1121"\w* \w Ramoth|strong="H7433"\w* \w Gilead|strong="H1568"\w*; \w he|strong="H5892"\w* controlled \w the|strong="H1121"\w* tent villages \w of|strong="H1121"\w* \w Jair|strong="H2971"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Manasseh|strong="H4519"\w* \w in|strong="H5892"\w* \w Gilead|strong="H1568"\w*, \w as|strong="H5892"\w* well \w as|strong="H5892"\w* \w the|strong="H1121"\w* \w region|strong="H2256"\w* \w of|strong="H1121"\w* Argob \w in|strong="H5892"\w* \w Bashan|strong="H1316"\w*, including \w sixty|strong="H8346"\w* \w large|strong="H1419"\w* \w walled|strong="H2346"\w* \w cities|strong="H5892"\w* \w with|strong="H5892"\w* \w bronze|strong="H5178"\w* \w bars|strong="H1280"\w* locking their gates.   
\p
\v 14  Ahinadab \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Iddo|strong="H5714"\w* \w was|strong="H1121"\w* \w in|strong="H1121"\w* charge \w of|strong="H1121"\w* \w Mahanaim|strong="H4266"\w*.   
\p
\v 15  Ahimaaz \w was|strong="H1931"\w* \w in|strong="H8010"\w* charge \w of|strong="H1323"\w* \w Naphtali|strong="H5321"\w*. (\w He|strong="H1931"\w* \w married|strong="H3947"\w* \w Solomon|strong="H8010"\w*’s \w daughter|strong="H1323"\w* \w Basemath|strong="H1315"\w*.)   
\p
\v 16  \w Baana|strong="H1195"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Hushai|strong="H2365"\w* \w was|strong="H1121"\w* \w in|strong="H1121"\w* charge \w of|strong="H1121"\w* Asher \w and|strong="H1121"\w* \w Aloth|strong="H1175"\w*.   
\p
\v 17  \w Jehoshaphat|strong="H3092"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Paruah|strong="H6515"\w* \w was|strong="H1121"\w* \w in|strong="H1121"\w* charge \w of|strong="H1121"\w* \w Issachar|strong="H3485"\w*.   
\p
\v 18  \w Shimei|strong="H8096"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Ela \w was|strong="H1121"\w* \w in|strong="H1121"\w* charge \w of|strong="H1121"\w* \w Benjamin|strong="H1144"\w*.   
\p
\v 19  \w Geber|strong="H1398"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Uri \w was|strong="H4428"\w* \w in|strong="H4428"\w* charge \w of|strong="H1121"\w* \w the|strong="H1121"\w* land \w of|strong="H1121"\w* \w Gilead|strong="H1568"\w* (\w the|strong="H1121"\w* territory \w which|strong="H4428"\w* \w had|strong="H4428"\w* once belonged \w to|strong="H1121"\w* \w King|strong="H4428"\w* \w Sihon|strong="H5511"\w* \w of|strong="H1121"\w* \w the|strong="H1121"\w* Amorites \w and|strong="H1121"\w* \w to|strong="H1121"\w* \w King|strong="H4428"\w* \w Og|strong="H5747"\w* \w of|strong="H1121"\w* \w Bashan|strong="H1316"\w*). \w He|strong="H4428"\w* \w was|strong="H4428"\w* sole governor \w of|strong="H1121"\w* \w the|strong="H1121"\w* area.   
\s1 Solomon’s Wealth and Fame  
\p
\v 20  \w The|strong="H5921"\w* people \w of|strong="H7230"\w* \w Judah|strong="H3063"\w* \w and|strong="H3063"\w* \w Israel|strong="H3478"\w* \w were|strong="H3478"\w* \w as|strong="H7230"\w* innumerable \w as|strong="H7230"\w* \w the|strong="H5921"\w* \w sand|strong="H2344"\w* \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w seashore|strong="H3220"\w*; \w they|strong="H5921"\w* \w had|strong="H3478"\w* \w plenty|strong="H7230"\w* \w to|strong="H3478"\w* eat \w and|strong="H3063"\w* \w drink|strong="H8354"\w* \w and|strong="H3063"\w* \w were|strong="H3478"\w* \w happy|strong="H8056"\w*.  
\v 21  Solomon ruled all the kingdoms from the Euphrates River to the land of the Philistines, as far as the border of Egypt. These kingdoms paid tribute as Solomon’s subjects throughout his lifetime.  
\v 22  Each day Solomon’s royal court consumed thirty cors of finely milled flour, sixty cors of cereal,  
\v 23  ten calves fattened in the stall, twenty calves from the pasture, and \w a|strong="H3068"\w* hundred sheep, not to mention rams, gazelles, deer, and well-fed birds.  
\v 24  His royal court was so large because he ruled over all the kingdoms west of the Euphrates River from Tiphsah to Gaza; he was at peace with all his neighbors.  
\v 25  All the people of Judah and Israel had security; everyone from Dan to Beer Sheba enjoyed the produce of their vines and fig trees throughout Solomon’s lifetime.  
\v 26  Solomon had 4,000 stalls for his chariot horses and 12,000 horses.  
\v 27  The district governors acquired supplies for King Solomon and all who ate in his royal palace. Each was responsible for one month in the year; they made sure nothing was lacking.  
\v 28  Each one also brought to the assigned location his quota of barley and straw for the various horses.   
\p
\v 29  God gave Solomon wisdom and very great discernment; the breadth of his understanding was as infinite as the sand on the seashore.  
\v 30  Solomon was wiser than all the men of the east and all the sages of Egypt.  
\v 31  He was wiser than any man, including Ethan the Ezrahite or Heman, Calcol, and Darda, the sons of Mahol. He was famous in all the neighboring nations.  
\v 32  He composed 3,000 proverbs and 1,005 songs.  
\v 33  He produced manuals on botany, describing every kind of plant, from the cedars of Lebanon to the hyssop that grows on walls. He also produced manuals on biology, describing animals, birds, insects, and fish.  
\v 34  People from all nations came to hear Solomon’s display of wisdom; they came from all the kings of the earth who heard about his wisdom.   
\c 5  
\p
\v 1  King Hiram \w of|strong="H3117"\w* Tyre sent messengers \w to|strong="H5704"\w* \w Solomon|strong="H8010"\w* \w when|strong="H1961"\w* \w he|strong="H3117"\w* heard \w that|strong="H3605"\w* \w he|strong="H3117"\w* \w had|strong="H1961"\w* \w been|strong="H1961"\w* anointed king \w in|strong="H3117"\w* \w his|strong="H3605"\w* father’s \w place|strong="H1961"\w*. (Hiram \w had|strong="H1961"\w* \w always|strong="H3605"\w* \w been|strong="H1961"\w* \w an|strong="H1961"\w* ally \w of|strong="H3117"\w* \w David|strong="H3117"\w*.)  
\v 2  \w Solomon|strong="H8010"\w* \w then|strong="H1961"\w* sent \w this|strong="H3117"\w* message \w to|strong="H1961"\w* Hiram:  
\v 3 “You know \w that|strong="H1241"\w* my father David \w was|strong="H6629"\w* unable \w to|strong="H6242"\w* build \w a|strong="H3068"\w* temple \w to|strong="H6242"\w* honor \w the|strong="H3967"\w* \nd Lord\nd* his God, \w for|strong="H1241"\w* \w he|strong="H1241"\w* \w was|strong="H6629"\w* busy fighting battles on all fronts while \w the|strong="H3967"\w* \nd Lord\nd* subdued his enemies.  
\v 4  \w But|strong="H3588"\w* \w now|strong="H1961"\w* \w the|strong="H3605"\w* \nd Lord\nd* \w my|strong="H3605"\w* God \w has|strong="H1961"\w* \w made|strong="H1961"\w* \w me|strong="H1961"\w* \w secure|strong="H7965"\w* \w on|strong="H1961"\w* \w all|strong="H3605"\w* fronts; \w there|strong="H1961"\w* \w is|strong="H1931"\w* \w no|strong="H3605"\w* adversary \w or|strong="H5704"\w* dangerous threat.  
\v 5  \w So|strong="H3427"\w* \w I|strong="H3117"\w* \w have|strong="H3478"\w* decided \w to|strong="H5704"\w* build \w a|strong="H3068"\w* temple \w to|strong="H5704"\w* honor \w the|strong="H3605"\w* \nd Lord\nd* \w my|strong="H3605"\w* God, \w as|strong="H5704"\w* \w the|strong="H3605"\w* \nd Lord\nd* instructed \w my|strong="H3605"\w* father \w David|strong="H3117"\w*, ‘\w Your|strong="H3605"\w* son, whom \w I|strong="H3117"\w* \w will|strong="H3478"\w* put \w on|strong="H3117"\w* \w your|strong="H3605"\w* throne \w in|strong="H3427"\w* \w your|strong="H3605"\w* \w place|strong="H8478"\w*, \w is|strong="H3117"\w* \w the|strong="H3605"\w* \w one|strong="H3605"\w* \w who|strong="H3605"\w* \w will|strong="H3478"\w* build \w a|strong="H3068"\w* temple \w to|strong="H5704"\w* honor \w me|strong="H8478"\w*.’  
\v 6  \w So|strong="H1961"\w* \w now|strong="H1961"\w* order some cedars \w of|strong="H8147"\w* Lebanon \w to|strong="H1961"\w* \w be|strong="H1961"\w* cut \w for|strong="H1961"\w* \w me|strong="H1961"\w*. \w My|strong="H1961"\w* servants \w will|strong="H1961"\w* work \w with|strong="H8147"\w* \w your|strong="H1961"\w* servants. \w I|strong="H1961"\w* \w will|strong="H1961"\w* pay \w your|strong="H1961"\w* servants whatever \w you|strong="H1961"\w* say \w is|strong="H1961"\w* appropriate, \w for|strong="H1961"\w* \w you|strong="H1961"\w* know \w that|strong="H1961"\w* \w we|strong="H3068"\w* \w have|strong="H1961"\w* \w no|strong="H1961"\w* \w one|strong="H1961"\w* among \w us|strong="H1961"\w* who knows how \w to|strong="H1961"\w* cut down trees \w like|strong="H1961"\w* \w the|strong="H1961"\w* Sidonians.”   
\p
\v 7  When Hiram heard \w Solomon|strong="H8010"\w*’s \w message|strong="H1697"\w*, \w he|strong="H3605"\w* \w was|strong="H1697"\w* very happy. \w He|strong="H3605"\w* \w said|strong="H1697"\w*, “\w The|strong="H3605"\w* \nd Lord\nd* \w is|strong="H1697"\w* worthy \w of|strong="H4428"\w* praise today \w because|strong="H1697"\w* \w he|strong="H3605"\w* \w has|strong="H4428"\w* given David \w a|strong="H3068"\w* wise son \w to|strong="H4428"\w* \w rule|strong="H4428"\w* \w over|strong="H4428"\w* \w this|strong="H1697"\w* great nation.”  
\v 8  Hiram \w then|strong="H1961"\w* sent \w this|strong="H1961"\w* message \w to|strong="H1961"\w* Solomon: “\w I|strong="H1961"\w* \w received|strong="H1961"\w* \w the|strong="H1961"\w* message \w you|strong="H4725"\w* sent \w to|strong="H1961"\w* \w me|strong="H1961"\w*. \w I|strong="H1961"\w* \w will|strong="H1961"\w* \w give|strong="H1961"\w* \w you|strong="H4725"\w* all \w the|strong="H1961"\w* cedars \w and|strong="H4941"\w* evergreens \w you|strong="H4725"\w* need.  
\v 9  \w My|strong="H5414"\w* servants \w will|strong="H3820"\w* \w bring|strong="H5414"\w* \w the|strong="H5921"\w* timber \w down|strong="H5414"\w* \w from|strong="H5921"\w* Lebanon \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w sea|strong="H3220"\w*. \w I|strong="H5414"\w* \w will|strong="H3820"\w* \w send|strong="H5414"\w* \w it|strong="H5414"\w* \w by|strong="H5921"\w* \w sea|strong="H3220"\w* \w in|strong="H5921"\w* raft-like \w bundles|strong="H3220"\w* \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w place|strong="H5414"\w* \w you|strong="H5414"\w* \w designate|strong="H5414"\w*. There \w I|strong="H5414"\w* \w will|strong="H3820"\w* separate \w the|strong="H5921"\w* logs \w and|strong="H2451"\w* \w you|strong="H5414"\w* can carry \w them|strong="H5414"\w* \w away|strong="H5414"\w*. \w In|strong="H5921"\w* \w exchange|strong="H5414"\w* \w you|strong="H5414"\w* \w will|strong="H3820"\w* supply \w the|strong="H5921"\w* food \w I|strong="H5414"\w* need \w for|strong="H5921"\w* \w my|strong="H5414"\w* royal court.”   
\p
\v 10  \w So|strong="H7235"\w* Hiram supplied \w the|strong="H3605"\w* cedars \w and|strong="H1121"\w* evergreens \w Solomon|strong="H8010"\w* needed,  
\v 11  \w and|strong="H1121"\w* Solomon supplied Hiram \w annually|strong="H3605"\w* \w with|strong="H3605"\w* 20,000 cors \w of|strong="H1121"\w* wheat \w as|strong="H1961"\w* provision \w for|strong="H8034"\w* \w his|strong="H3605"\w* royal court, \w as|strong="H1961"\w* well \w as|strong="H1961"\w* 20,000 baths \w of|strong="H1121"\w* pure olive oil.  
\v 12  \w So|strong="H1961"\w* \w the|strong="H1961"\w* \nd Lord\nd* \w gave|strong="H1696"\w* Solomon wisdom, \w as|strong="H1961"\w* \w he|strong="H2568"\w* \w had|strong="H1961"\w* \w promised|strong="H1696"\w* \w him|strong="H1696"\w*. \w And|strong="H2568"\w* Hiram \w and|strong="H2568"\w* Solomon \w were|strong="H1961"\w* \w at|strong="H1961"\w* peace \w and|strong="H2568"\w* \w made|strong="H1696"\w* \w a|strong="H3068"\w* treaty.   
\p
\v 13  \w King|strong="H5921"\w* Solomon conscripted work crews \w from|strong="H4480"\w* \w throughout|strong="H5921"\w* Israel, 30,000 men \w in|strong="H5921"\w* \w all|strong="H5704"\w*.  
