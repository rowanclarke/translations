\v 21 \w Whoever|strong="H4191"\w* \w kills|strong="H5221"\w* \add another person’s\add* animal \w must|strong="H4191"\w* give \w that|strong="H4191"\w* person \w a|strong="H3068"\w* live animal \w to|strong="H4191"\w* replace \w the|strong="H5221"\w* one \w that|strong="H4191"\w* \w he|strong="H5221"\w* \w killed|strong="H5221"\w*, \w but|strong="H5221"\w* anyone \w who|strong="H5221"\w* murders another person \w must|strong="H4191"\w* \w be|strong="H4191"\w* \w executed|strong="H5221"\w*.
\v 22 \w That|strong="H3588"\w* \w law|strong="H4941"\w* applies \w to|strong="H3068"\w* \w you|strong="H3588"\w* Israelis \w and|strong="H3068"\w* \w and|strong="H3068"\w* \w also|strong="H3068"\w* \w to|strong="H3068"\w* \w the|strong="H3588"\w* \w foreigners|strong="H1616"\w* \w who|strong="H3068"\w* live among \w you|strong="H3588"\w*; \w I|strong="H3588"\w*, \w Yahweh|strong="H3068"\w* \w your|strong="H3068"\w* \w God|strong="H3068"\w* \add am the one who has commanded it\add*.”
\p 
\v 23 \w Then|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w I|strong="H6680"\w* \w told|strong="H1696"\w* \w the|strong="H6213"\w* Israelis \add what they must do to the man who cursed Yahweh\add*, \w so|strong="H6213"\w* \w they|strong="H3068"\w* \w took|strong="H3318"\w* \w the|strong="H6213"\w* \w man|strong="H1121"\w* \w outside|strong="H2351"\w* \w the|strong="H6213"\w* \w camp|strong="H4264"\w* \w and|strong="H1121"\w* \add killed him by\add* throwing stones \w at|strong="H3478"\w* \w him|strong="H6213"\w*. \w They|strong="H3068"\w* \w did|strong="H6213"\w* \w what|strong="H6213"\w* \w Yahweh|strong="H3068"\w* \w commanded|strong="H6680"\w* \w Moses|strong="H4872"\w*/\w me|strong="H6213"\w* \add to tell them to do\add*.
\c 25
\s1 The seventh year
\p 
\v 1 \w Yahweh|strong="H3068"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w* \w on|strong="H3068"\w* \w Sinai|strong="H5514"\w* \w Mountain|strong="H2022"\w*,
\v 2 “\w Tell|strong="H1696"\w* \w the|strong="H3588"\w* Israelis \add that I, Yahweh, say this\add*: \w When|strong="H3588"\w* \w you|strong="H3588"\w* enter \w the|strong="H3588"\w* land \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w am|strong="H3068"\w* \w about|strong="H1696"\w* \w to|strong="H1696"\w* \w give|strong="H5414"\w* \w you|strong="H3588"\w*, \w every|strong="H5414"\w* seventh \w year|strong="H1121"\w* \w you|strong="H3588"\w* \w must|strong="H1121"\w* honor \w me|strong="H5414"\w* \w by|strong="H3068"\w* \add not planting any seeds. You will be\add* allowing \w the|strong="H3588"\w* ground \w to|strong="H1696"\w* \w rest|strong="H7673"\w*.
\v 3 \w For|strong="H7704"\w* \w six|strong="H8337"\w* \w years|strong="H8141"\w* \w you|strong="H8141"\w* \w are|strong="H8141"\w* \w to|strong="H7704"\w* \w plant|strong="H2232"\w* seeds \w in|strong="H8141"\w* \w your|strong="H2232"\w* \w fields|strong="H7704"\w* \w and|strong="H8141"\w* \w prune|strong="H2168"\w* \w your|strong="H2232"\w* grapevines \w and|strong="H8141"\w* \w harvest|strong="H8393"\w* \w the|strong="H8141"\w* \w crops|strong="H8393"\w*.
\v 4 \w But|strong="H3808"\w* \w the|strong="H3068"\w* \w seventh|strong="H7637"\w*/next \w year|strong="H8141"\w* \w you|strong="H3808"\w* \w must|strong="H3808"\w* \add dedicate\add* \w to|strong="H3068"\w* \w me|strong="H3808"\w*, \w and|strong="H3068"\w* allow \w your|strong="H3068"\w* \w fields|strong="H7704"\w* \w to|strong="H3068"\w* \w rest|strong="H7677"\w*. \w Do|strong="H3068"\w* \w not|strong="H3808"\w* \w plant|strong="H2232"\w* seeds \w in|strong="H8141"\w* \w your|strong="H3068"\w* \w fields|strong="H7704"\w* \w or|strong="H3808"\w* \w prune|strong="H2168"\w* \w your|strong="H3068"\w* grapevines \add during that year\add*.
\v 5 Do \w not|strong="H3808"\w* \w reap|strong="H7114"\w* \add the grain\add* \w that|strong="H8141"\w* \w grows|strong="H5599"\w* \w in|strong="H8141"\w* \w your|strong="H1961"\w* fields \w without|strong="H3808"\w* \w having|strong="H3808"\w* \w been|strong="H1961"\w* planted, \w or|strong="H3808"\w* \w harvest|strong="H7105"\w* \w the|strong="H1961"\w* \w grapes|strong="H6025"\w* \w that|strong="H8141"\w* \w grow|strong="H5599"\w* \add without the vines being pruned\add*; \w you|strong="H3808"\w* \w must|strong="H3808"\w* allow \w the|strong="H1961"\w* land \w to|strong="H1961"\w* \w rest|strong="H7677"\w* \w for|strong="H3808"\w* \w that|strong="H8141"\w* \w one|strong="H3808"\w* \w year|strong="H8141"\w*.
\v 6 \w But|strong="H1961"\w* \w you|strong="H5973"\w* \w are|strong="H5650"\w* permitted \w to|strong="H1961"\w* eat whatever crops grow \w by|strong="H1961"\w* \w themselves|strong="H1481"\w* \w during|strong="H1961"\w* \w that|strong="H5650"\w* year \w without|strong="H1961"\w* \w having|strong="H1961"\w* \w been|strong="H1961"\w* planted. \w You|strong="H5973"\w* \w and|strong="H5650"\w* \w your|strong="H1961"\w* \w male|strong="H5650"\w* \w and|strong="H5650"\w* female \w servants|strong="H5650"\w*, \w and|strong="H5650"\w* \w workers|strong="H7916"\w* whom \w you|strong="H5973"\w* \w have|strong="H1961"\w* \w hired|strong="H7916"\w*, \w and|strong="H5650"\w* people \w who|strong="H5650"\w* \w are|strong="H5650"\w* \w living|strong="H1481"\w* \w among|strong="H5973"\w* \w you|strong="H5973"\w* temporarily \w are|strong="H5650"\w* permitted \w to|strong="H1961"\w* eat \w it|strong="H1961"\w*.
\v 7 Also, \add during that year\add* \w your|strong="H3605"\w* livestock \w and|strong="H3605"\w* \w the|strong="H3605"\w* wild \w animals|strong="H2416"\w* \w in|strong="H1961"\w* \w your|strong="H3605"\w* land \w are|strong="H1961"\w* permitted \w to|strong="H1961"\w* eat \w it|strong="H1961"\w*.’
\s1 The fiftieth year
\p 
\v 8-9 ‘Also, after every 49 years has ended, you must do this: ◄On the tenth day of the seventh month/At the end of September► \add of the next/50th year\add*, blow trumpets throughout the country, to declare that it will be \w a|strong="H3068"\w* day on which you request that I forgive you for the sins that you have committed.
\v 10 \w Set|strong="H3427"\w* \w apart|strong="H6942"\w* \w that|strong="H3605"\w* \w year|strong="H8141"\w*, \w and|strong="H7725"\w* \w proclaim|strong="H7121"\w* \w that|strong="H3605"\w* \w throughout|strong="H3605"\w* \w the|strong="H3605"\w* country, \w it|strong="H1931"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w a|strong="H3068"\w* \w year|strong="H8141"\w* \w of|strong="H8141"\w* \w restoring|strong="H7725"\w* \w the|strong="H3605"\w* \w land|strong="H4940"\w* \w and|strong="H7725"\w* freeing \w people|strong="H3427"\w*: \w All|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H3427"\w* \add who sold their property\add* \w will|strong="H1961"\w* \w receive|strong="H1961"\w* \w back|strong="H7725"\w* \w the|strong="H3605"\w* property \w that|strong="H3605"\w* \w they|strong="H8141"\w* previously owned, \w and|strong="H7725"\w* slaves must \w be|strong="H1961"\w* ◄freed/allowed \w to|strong="H7725"\w* \w return|strong="H7725"\w* \w to|strong="H7725"\w* \add their property and\add* \w their|strong="H3605"\w* \w families|strong="H4940"\w*►.
\v 11 \w That|strong="H1931"\w* \w year|strong="H8141"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w a|strong="H3068"\w* \w Year|strong="H8141"\w* \w of|strong="H8141"\w* Celebration; \add during that year\add* do \w not|strong="H3808"\w* \w plant|strong="H2232"\w* \w anything|strong="H3808"\w*, \w and|strong="H2572"\w* do \w not|strong="H3808"\w* \w harvest|strong="H7114"\w* \add in the usual way\add* \w the|strong="H1961"\w* grain/wheat \w that|strong="H1931"\w* \w grows|strong="H5599"\w* \w without|strong="H3808"\w* \w having|strong="H3808"\w* \w been|strong="H1961"\w* \w planted|strong="H2232"\w*, \w or|strong="H3808"\w* \w the|strong="H1961"\w* grapes \w that|strong="H1931"\w* \w grow|strong="H5599"\w* \w without|strong="H3808"\w* \w the|strong="H1961"\w* \w vines|strong="H5139"\w* \w being|strong="H1961"\w* pruned.
\v 12 \w It|strong="H1931"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w a|strong="H3068"\w* Year \w of|strong="H7704"\w* Celebration, \w so|strong="H4480"\w* eat \add only\add* \w what|strong="H3588"\w* grows \w in|strong="H1961"\w* \w the|strong="H3588"\w* \w fields|strong="H7704"\w* ◄\w by|strong="H1961"\w* \w itself|strong="H1931"\w*/\w without|strong="H4480"\w* \w any|strong="H4480"\w* work \w being|strong="H1961"\w* \w done|strong="H1961"\w* \w to|strong="H1961"\w* \w produce|strong="H8393"\w* \w anything|strong="H4480"\w*►.
\p 
\v 13 ‘\w In|strong="H8141"\w* \w that|strong="H8141"\w* \w Year|strong="H8141"\w* \w of|strong="H8141"\w* Celebration, everyone must \w return|strong="H7725"\w* \w to|strong="H7725"\w* \w their|strong="H7725"\w* own property.
\p 
\v 14 ‘\w If|strong="H3588"\w* \w you|strong="H3588"\w* \w sell|strong="H4376"\w* \w some|strong="H3027"\w* \w of|strong="H3027"\w* \w your|strong="H3588"\w* land \w to|strong="H3027"\w* \w a|strong="H3068"\w* \w fellow|strong="H5997"\w* Israeli \w or|strong="H4376"\w* \w if|strong="H3588"\w* \w you|strong="H3588"\w* \w buy|strong="H7069"\w* \w some|strong="H3027"\w* land \w from|strong="H3027"\w* \w one|strong="H3588"\w* \w of|strong="H3027"\w* \w them|strong="H3027"\w*, \w you|strong="H3588"\w* must treat \w that|strong="H3588"\w* \w person|strong="H3027"\w* fairly:
\v 15 If \w you|strong="H8141"\w* \w buy|strong="H7069"\w* land, \w the|strong="H7069"\w* price \w that|strong="H8141"\w* \w you|strong="H8141"\w* will pay will depend \w on|strong="H5997"\w* \w the|strong="H7069"\w* \w number|strong="H4557"\w* \w of|strong="H8141"\w* \w years|strong="H8141"\w* there will \w be|strong="H8141"\w* until \w the|strong="H7069"\w* next \w Year|strong="H8141"\w* \w of|strong="H8141"\w* Celebration. If someone \w sells|strong="H4376"\w* land \w to|strong="H8141"\w* \w you|strong="H8141"\w*, \w he|strong="H8141"\w* will charge \w a|strong="H3068"\w* price \w that|strong="H8141"\w* \w is|strong="H8141"\w* determined \w by|strong="H8141"\w* \w the|strong="H7069"\w* \w number|strong="H4557"\w* \w of|strong="H8141"\w* \w years|strong="H8141"\w* until \w the|strong="H7069"\w* next \w Year|strong="H8141"\w* \w of|strong="H8141"\w* Celebration.
\v 16 \w If|strong="H3588"\w* \w there|strong="H7230"\w* \w will|strong="H1931"\w* \w be|strong="H8141"\w* \w many|strong="H7230"\w* \w years|strong="H8141"\w* before \w the|strong="H3588"\w* next \w Year|strong="H8141"\w* \w of|strong="H8141"\w* Celebration, \w the|strong="H3588"\w* \w price|strong="H4736"\w* \w will|strong="H1931"\w* \w be|strong="H8141"\w* higher; \w if|strong="H3588"\w* \w there|strong="H7230"\w* \w will|strong="H1931"\w* \w be|strong="H8141"\w* \w only|strong="H3588"\w* \w a|strong="H3068"\w* \w few|strong="H4557"\w* \w years|strong="H8141"\w* \w until|strong="H3588"\w* \w the|strong="H3588"\w* next \w Year|strong="H8141"\w* \w of|strong="H8141"\w* Celebration, \w the|strong="H3588"\w* \w price|strong="H4736"\w* \w will|strong="H1931"\w* \w be|strong="H8141"\w* lower. \add You could say that\add* \w what|strong="H6310"\w* \w he|strong="H1931"\w* \w is|strong="H1931"\w* really \w selling|strong="H4376"\w* \w you|strong="H3588"\w* \w is|strong="H1931"\w* \w the|strong="H3588"\w* \w number|strong="H4557"\w* \w of|strong="H8141"\w* \w crops|strong="H8393"\w* \add which you can harvest before the next Year of Celebration\add*.
\v 17 \w Do|strong="H3068"\w* \w not|strong="H3808"\w* cheat each other; \w instead|strong="H3588"\w*, \w revere|strong="H3372"\w* \w me|strong="H3372"\w*. \w I|strong="H3588"\w*, \w Yahweh|strong="H3068"\w* \w your|strong="H3068"\w* \w God|strong="H3068"\w*, \add am the one who am commanding this\add*.
\p 
\v 18 ‘\w Obey|strong="H6213"\w* \w all|strong="H6213"\w* \w my|strong="H8104"\w* laws [DOU] \w carefully|strong="H6213"\w*. If \w you|strong="H5921"\w* \w do|strong="H6213"\w* \w that|strong="H6213"\w*, \w you|strong="H5921"\w* \w will|strong="H6213"\w* \w continue|strong="H3427"\w* \w to|strong="H5921"\w* \w live|strong="H3427"\w* safely \w in|strong="H3427"\w* \w your|strong="H5921"\w* country [DOU].
\v 19 \w And|strong="H3427"\w* crops \w will|strong="H5414"\w* grow well \w on|strong="H5921"\w* \w the|strong="H5921"\w* land, \w and|strong="H3427"\w* \w you|strong="H5414"\w* \w will|strong="H5414"\w* \w have|strong="H5414"\w* plenty \w to|strong="H5921"\w* eat.
\v 20 \w But|strong="H3588"\w* \w you|strong="H3588"\w* \w may|strong="H3808"\w* ask, “\w If|strong="H3588"\w* \w we|strong="H3068"\w* \w do|strong="H4100"\w* \w not|strong="H3808"\w* \w plant|strong="H2232"\w* \w or|strong="H3808"\w* \w harvest|strong="H8393"\w* \w our|strong="H3588"\w* \w crops|strong="H8393"\w* during \w the|strong="H3588"\w* \w seventh|strong="H7637"\w* \w year|strong="H8141"\w*, \w what|strong="H4100"\w* \w will|strong="H3808"\w* \w we|strong="H3068"\w* \w have|strong="H3588"\w* \w to|strong="H3808"\w* eat?”
\v 21 \add My answer is that\add* \w I|strong="H6680"\w* \w will|strong="H6213"\w* bless \w you|strong="H6680"\w* \w very|strong="H6213"\w* \w much|strong="H6213"\w* during \w the|strong="H6213"\w* \w sixth|strong="H8345"\w*/previous \w year|strong="H8141"\w*, \w with|strong="H6213"\w* \w the|strong="H6213"\w* result \w that|strong="H8141"\w* during \w that|strong="H8141"\w* \w year|strong="H8141"\w* there \w will|strong="H6213"\w* \w be|strong="H8141"\w* \w enough|strong="H6213"\w* \w crops|strong="H8393"\w* \w to|strong="H6213"\w* \w provide|strong="H6213"\w* food \w for|strong="H6213"\w* \w you|strong="H6680"\w* \w for|strong="H6213"\w* \w three|strong="H7969"\w* \w years|strong="H8141"\w*!
\v 22 Then, \w after|strong="H4480"\w* \w you|strong="H5704"\w* \w plant|strong="H2232"\w* \w seed|strong="H2232"\w* during \w the|strong="H4480"\w* \w eighth|strong="H8066"\w*/next \w year|strong="H8141"\w* \add and wait for the crops to grow\add*, \w you|strong="H5704"\w* \w will|strong="H5704"\w* eat \w the|strong="H4480"\w* food grown \w in|strong="H8141"\w* \w the|strong="H4480"\w* sixth \w year|strong="H8141"\w*, \w and|strong="H8141"\w* continue \w to|strong="H5704"\w* eat \w it|strong="H5704"\w* \w until|strong="H5704"\w* \w more|strong="H4480"\w* food \w is|strong="H8141"\w* harvested \w in|strong="H8141"\w* \w the|strong="H4480"\w* \w ninth|strong="H8671"\w* \w year|strong="H8141"\w*!
