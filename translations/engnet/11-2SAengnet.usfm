\c 16  
\p
\v 1  \w When|strong="H5674"\w* \w David|strong="H1732"\w* \w had|strong="H1732"\w* \w gone|strong="H5674"\w* \w a|strong="H3068"\w* short \w way|strong="H5674"\w* \w beyond|strong="H5674"\w* \w the|strong="H5921"\w* \w summit|strong="H7218"\w*, \w Ziba|strong="H6717"\w* \w the|strong="H5921"\w* \w servant|strong="H5288"\w* \w of|strong="H7218"\w* \w Mephibosheth|strong="H4648"\w* \w was|strong="H1732"\w* \w there|strong="H2009"\w* \w to|strong="H5921"\w* \w meet|strong="H7122"\w* \w him|strong="H5921"\w*. \w He|strong="H1732"\w* \w had|strong="H1732"\w* \w a|strong="H3068"\w* \w couple|strong="H6776"\w* \w of|strong="H7218"\w* \w donkeys|strong="H2543"\w* \w that|strong="H5288"\w* \w were|strong="H1732"\w* \w saddled|strong="H2280"\w*, \w and|strong="H3967"\w* \w on|strong="H5921"\w* \w them|strong="H5921"\w* \w were|strong="H1732"\w* \w two|strong="H6776"\w* \w hundred|strong="H3967"\w* \w loaves|strong="H3899"\w* \w of|strong="H7218"\w* \w bread|strong="H3899"\w*, \w a|strong="H3068"\w* \w hundred|strong="H3967"\w* raisin cakes, \w a|strong="H3068"\w* \w hundred|strong="H3967"\w* baskets \w of|strong="H7218"\w* \w summer|strong="H7019"\w* \w fruit|strong="H7019"\w*, \w and|strong="H3967"\w* \w a|strong="H3068"\w* container \w of|strong="H7218"\w* \w wine|strong="H3196"\w*.   
\p
\v 2  \w The|strong="H8354"\w* \w king|strong="H4428"\w* \w asked|strong="H4100"\w* \w Ziba|strong="H6717"\w*, “\w Why|strong="H4100"\w* \w did|strong="H4100"\w* \w you|strong="H4100"\w* \w bring|strong="H7392"\w* \w these|strong="H4428"\w* things?” \w Ziba|strong="H6717"\w* replied, “\w The|strong="H8354"\w* \w donkeys|strong="H2543"\w* \w are|strong="H4100"\w* \w for|strong="H1004"\w* \w the|strong="H8354"\w* \w king|strong="H4428"\w*’s \w family|strong="H1004"\w* \w to|strong="H4428"\w* \w ride|strong="H7392"\w* \w on|strong="H7392"\w*, \w the|strong="H8354"\w* \w loaves|strong="H3899"\w* \w of|strong="H4428"\w* \w bread|strong="H3899"\w* \w and|strong="H4428"\w* \w the|strong="H8354"\w* \w summer|strong="H7019"\w* \w fruit|strong="H7019"\w* \w are|strong="H4100"\w* \w for|strong="H1004"\w* \w the|strong="H8354"\w* \w attendants|strong="H5288"\w* \w to|strong="H4428"\w* \w eat|strong="H3899"\w*, \w and|strong="H4428"\w* \w the|strong="H8354"\w* \w wine|strong="H3196"\w* \w is|strong="H4100"\w* \w for|strong="H1004"\w* those \w who|strong="H5288"\w* get exhausted \w in|strong="H1004"\w* \w the|strong="H8354"\w* \w desert|strong="H4057"\w*.”  
