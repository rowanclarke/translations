\v 29 A \w yaak|strong="G0191"\w* uh \w vaengah|strong="G2532"\w* \w Johan|strong="G0846"\w* kah \w hnukbang|strong="G3101"\w* rhoek \w tah|strong="G3588"\w* ha \w pawk|strong="G2064"\w* uh \w tih|strong="G2532"\w* \w a|strong="G0846"\w* \w rhok|strong="G4430"\w* \w te|strong="G3588"\w* a \w khuen|strong="G0142"\w* uh \w tih|strong="G2532"\w* \w phuel|strong="G3419"\w* \w ah|strong="G1722"\w* a \w khueh|strong="G5087"\w* uh.  
\v 30   
\s1 Hlang Thawng Nga A Kok  
\p Te \w vaengah|strong="G2532"\w* \w caeltueih|strong="G0652"\w* rhoek \w te|strong="G3588"\w* \w Jesuh|strong="G2424"\w* \w taengah|strong="G4314"\w* \w tingtun|strong="G4863"\w* uh \w tih|strong="G2532"\w* a \w saii|strong="G4160"\w* \w neh|strong="G2532"\w* a \w thuituen|strong="G1321"\w* uh \w boeih|strong="G3956"\w* \w te|strong="G3745,G3745"\w* \w a|strong="G0846"\w* taengah \w puen|strong="G0518"\w* uh.  
\v 31 Te \w vaengah|strong="G2532"\w* \w amih|strong="G0846"\w* te, \wj “ \+w Nangmih|strong="G5210"\+w* tah \+w namamih|strong="G0846"\+w* \+w bueng|strong="G2596"\+w* \+w mah|strong="G2398"\+w* \+w khosoek|strong="G2048"\+w* \+w hmuen|strong="G5117"\+w* la \+w halo|strong="G1205"\+w* uh \+w lamtah|strong="G2532"\+w* \+w rhaih|strong="G3641"\+w* \+w duem|strong="G0373"\+w* uh dae,” \wj* a \w ti|strong="G3004"\w* nah.  
\p Aka \w voei|strong="G2064"\w* \w rhoek|strong="G3588"\w* \w neh|strong="G2532"\w* aka \w bal|strong="G5217"\w* \w rhoek|strong="G3588"\w* te \w muep|strong="G4183"\w* a \w om|strong="G2258"\w* \w vaengah|strong="G2532"\w* buh \w caak|strong="G5315"\w* ham pataeng \w hoeng|strong="G2119"\w* uh \w pawh|strong="G3761"\w*.  
\v 32 Te \w dongah|strong="G2532"\w* \w amamih|strong="G2398"\w* \w bueng|strong="G2596"\w* \w khosoek|strong="G2048"\w* \w hmuen|strong="G5117"\w* \w la|strong="G1519"\w* \w lawng|strong="G4143"\w* \w neh|strong="G1722"\w* \w cet|strong="G0565"\w* uh.  
\v 33 \w Amih|strong="G0848"\w* a \w caeh|strong="G5217"\w* uh te a \w hmuh|strong="G3708"\w* uh \w tih|strong="G2532"\w* \w muep|strong="G4183"\w* a \w ming|strong="G1921"\w* uh \w vaengah|strong="G2532"\w* \w kho|strong="G4172"\w* \w tom|strong="G3956"\w* \w lamloh|strong="G0575"\w* \w kho|strong="G3979"\w* neh \w capit|strong="G4936"\w* uh \w tih|strong="G2532"\w* ana \w lamhma|strong="G4281"\w* uh coeng.  
\v 34 \x - \xo 6.34 \xt Lmp 27. 17; 1Mg 22. 17; 2Kh 18. 16; Eze 34. 5; Mat 9. 36.\x* \w Tedae|strong="G2532"\w* \w a\w* \w caeh|strong="G1831"\w* vaengah \w hlangping|strong="G3793"\w* \w te \w* \w muep|strong="G4183"\w* \w a\w* \w hmuh|strong="G3708"\w*. \w Te\w* \w vaengah|strong="G2532"\w* \w tudawn|strong="G4166"\w* \w aka \w*\w om|strong="G2192"\w* \w pawh|strong="G3361"\w* \w tu|strong="G4263"\w* \w rhoek \w* \w bangla|strong="G5613"\w* \w a\w* \w om|strong="G2258"\w* \w uh \w* \w dongah|strong="G3754"\w* \w amih|strong="G0848"\w* \w soah|strong="G1909"\w* \w a\w* \w thinphat|strong="G4697"\w* \w tih|strong="G2532"\w* \w amih|strong="G0848"\w* \w rhoek \w* \w te \w* \w muep|strong="G4183"\w* \w pahoi|strong="G0756"\w* \w a\w* \w thuituen|strong="G1321"\w*.  
\v 35 \w Kholaeh|strong="G4183"\w* \w tue|strong="G5610"\w* a \w pha|strong="G1096"\w* \w coeng|strong="G2235"\w* atah \w a|strong="G0846"\w* \w hnukbang|strong="G3101"\w* rhoek \w loh|strong="G3588"\w* \w amah|strong="G0846"\w* te a \w paan|strong="G4334"\w* tih, “\w Khosoek|strong="G2048"\w* \w hmuen|strong="G5117"\w* la \w om|strong="G2076"\w* \w tih|strong="G2532"\w* a \w tue|strong="G5610"\w* khaw \w kholaeh|strong="G4183"\w* \w coeng|strong="G2235"\w*.  
\v 36 \w Amih|strong="G0848"\w* he n'\w tueih|strong="G0630"\w* \w daengah|strong="G2443"\w* \w ni \w*\w a\w* \w taengvai|strong="G2945"\w* \w kah \w* \w lohma|strong="G0068"\w* \w neh|strong="G2532"\w* \w vangca|strong="G2968"\w* \w la|strong="G1519"\w* \w cet|strong="G0565"\w* uh vetih \w amamih|strong="G1438"\w* \w caak|strong="G5315"\w* \w te|strong="G5101"\w* \w khaw \w*\w a\w* \w lai|strong="G0059"\w* uh eh,” \w a \w*\w ti|strong="G3004"\w* na\w uh\w*.   
\p
\v 37 \w Tedae|strong="G1161"\w* \w Jesuh|strong="G2424"\w* \w loh|strong="G3588"\w* \w amih|strong="G0846"\w* te a \w doo|strong="G0611"\w* tih, \wj “ \+w Amih|strong="G0846"\+w* te \+w caak|strong="G5315"\+w* koi \+w nangmih|strong="G5210"\+w* loh \+w pae|strong="G1325"\+w* uh,” \wj* a \w ti|strong="G2036"\w* nah.  
\p Te vaengah \w amah|strong="G0846"\w* taengah, “Ka \w cet|strong="G0565"\w* uh vetih \w denari|strong="G1220"\w* \w yahnih|strong="G1250"\w* phu \w vaidam|strong="G0740"\w* ka \w lai|strong="G0059"\w* uh mako, te \w phoeiah|strong="G2532"\w* \w amih|strong="G0846"\w* \w caak|strong="G5315"\w* te ka \w paek|strong="G1325"\w* uh mako,” a \w ti|strong="G3004"\w* uh.   
\p
\v 38 Te \w vaengah|strong="G1161"\w* Jesuh \w loh|strong="G2424"\w* \w amih|strong="G0846"\w* te, \wj “ \+w Vaidam|strong="G0740"\+w* \+w meyet|strong="G4214"\+w* na \+w khueh|strong="G2192"\+w* uh? \+w Cet|strong="G5217"\+w* uh lamtah \+w so|strong="G3708"\+w* uh lah,” \wj* a \w ti|strong="G3004"\w* nah.  
\p Te \w daengah|strong="G2532"\w* a \w ming|strong="G1097"\w* uh tih, “Vaidam hluem \w nga|strong="G4002"\w* \w neh|strong="G2532"\w* \w nga|strong="G2486"\w* lung \w nit|strong="G1417"\w* om,” a \w ti|strong="G3004"\w* na uh.  
