\v 19 \w De|strong="H4480"\w* \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* cierto funcionario \w que|strong="H4480"\w* estaba encargado \w de|strong="H4480"\w* \w los|strong="H5921"\w* hombres \w de|strong="H4480"\w* \w guerra|strong="H4421"\w*, \w a|strong="H3068"\w* \w cinco|strong="H2568"\w* varones \w de|strong="H4480"\w* \w los|strong="H5921"\w* consejeros \w del|strong="H4480"\w* \w rey|strong="H4428"\w* \w que|strong="H4480"\w* \w estaban|strong="H5971"\w* \w en|strong="H5921"\w* \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w*, \w al|strong="H5921"\w* \w escriba|strong="H5608"\w* \w principal|strong="H8269"\w* \w del|strong="H4480"\w* \w ejército|strong="H6635"\w* \w que|strong="H4480"\w* llevaba \w el|strong="H1931"\w* registro \w de|strong="H4480"\w* \w la|strong="H1931"\w* \w gente|strong="H5971"\w* \w de|strong="H4480"\w* \w la|strong="H1931"\w* tierra, \w y|strong="H5921"\w* \w a|strong="H3068"\w* 60 hombres \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w de|strong="H4480"\w* \w la|strong="H1931"\w* tierra \w que|strong="H4480"\w* \w estaban|strong="H5971"\w* \w en|strong="H5921"\w* \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w*.
\v 20 \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* guardia, \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* éstos \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w llevó|strong="H3947"\w* ante \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia \w en|strong="H5921"\w* Ribla,
\v 21 quien \w los|strong="H5921"\w* \w hirió|strong="H5221"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w mató|strong="H5221"\w* \w en|strong="H5921"\w* Ribla, \w en|strong="H5921"\w* tierra \w de|strong="H5921"\w* Hamat.
\p Así \w fue|strong="H1540"\w* sacado \add el pueblo de\add* \w Judá|strong="H3063"\w* \w de|strong="H5921"\w* su tierra \w y|strong="H5921"\w* llevado cautivo.
\p 
\v 22 \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, designó \w como|strong="H5921"\w* gobernador \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5921"\w* \w dejó|strong="H7604"\w* \w en|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Ahicam, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Safán.
\v 23 \w Al|strong="H4428"\w* \w oír|strong="H8085"\w* \w todos|strong="H3605"\w* \w los|strong="H1992"\w* \w jefes|strong="H8269"\w* del \w ejército|strong="H2428"\w* \w y|strong="H3588"\w* \w sus|strong="H1992"\w* \w hombres|strong="H1121"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia designó \w como|strong="H3588"\w* \w gobernador|strong="H8269"\w* \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w*, fueron \w a|strong="H3068"\w* \w él|strong="H3588"\w* \w en|strong="H3588"\w* \w Mizpa|strong="H4709"\w*: \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Netanías, \w Johanán|strong="H3110"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Carea|strong="H7143"\w*, \w Seraías|strong="H8304"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Tanhumet \w netofatita|strong="H5200"\w*, \w y|strong="H3588"\w* Jaazanías, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* un maacateo, \w y|strong="H3588"\w* \w sus|strong="H1992"\w* \w hombres|strong="H1121"\w*.
\p 
\v 24 \w Gedalías|strong="H1436"\w* les \w juró|strong="H7650"\w* \w a|strong="H3068"\w* ellos y sus hombres: No \w teman|strong="H3372"\w* \w de|strong="H3372"\w* \w los|strong="H3427"\w* esclavos \w de|strong="H3372"\w* \w los|strong="H3427"\w* \w caldeos|strong="H3778"\w*. Vivan en la tierra y sirvan \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H3372"\w* Babilonia, y les irá \w bien|strong="H3190"\w*.
\p 
\v 25 Pero \w el|strong="H1121"\w* \w mes|strong="H2320"\w* \w séptimo|strong="H7637"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1121"\w* \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Netanías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Elisama, \w de|strong="H1121"\w* la \w descendencia|strong="H2233"\w* \w real|strong="H4410"\w*, \w fue|strong="H1961"\w* con \w diez|strong="H6235"\w* \w hombres|strong="H1121"\w* y atacaron \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w*, y \w murió|strong="H4191"\w* junto con \w los|strong="H1121"\w* \w judíos|strong="H3064"\w* y \w los|strong="H1121"\w* \w caldeos|strong="H3778"\w* \w que|strong="H1121"\w* \w estaban|strong="H1961"\w* con \w él|strong="H1121"\w* \w en|strong="H5221"\w* \w Mizpa|strong="H4709"\w*.
\v 26 \w Al|strong="H5704"\w* \w levantarse|strong="H6965"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w*, \w desde|strong="H5704"\w* \w el|strong="H3588"\w* \w menor|strong="H6996"\w* \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w mayor|strong="H1419"\w*, \w con|strong="H3588"\w* \w los|strong="H3605"\w* \w jefes|strong="H8269"\w* \w de|strong="H3588"\w* las tropas, salieron \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* \w por|strong="H3588"\w* \w temor|strong="H3372"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w caldeos|strong="H3778"\w*.
\p 
\v 27 \w Aconteció|strong="H1961"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* 37 \w años|strong="H8141"\w* del \w cautiverio|strong="H1546"\w* de Joaquín, \w rey|strong="H4428"\w* de \w Judá|strong="H3063"\w*, \w a|strong="H3068"\w* \w los|strong="H1961"\w* 27 días del \w mes|strong="H2320"\w* 12, \w que|strong="H1961"\w* Evil-merodac, \w rey|strong="H4428"\w* de Babilonia, en el \w primer|strong="H7218"\w* \w año|strong="H8141"\w* de su \w reinado|strong="H4427"\w*, libertó \w a|strong="H3068"\w* Joaquín, \w rey|strong="H4428"\w* de \w Judá|strong="H3063"\w*, y lo sacó de la cárcel.
\v 28 \w Le|strong="H5921"\w* \w habló|strong="H1696"\w* \w con|strong="H5921"\w* benevolencia \w y|strong="H5921"\w* colocó su \w trono|strong="H3678"\w* \w más|strong="H5921"\w* alto \w que|strong="H5921"\w* \w los|strong="H5921"\w* tronos \w de|strong="H5921"\w* \w los|strong="H5921"\w* demás \w reyes|strong="H4428"\w* vasallos \w que|strong="H5921"\w* estaban \w en|strong="H5921"\w* Babilonia.
\v 29 Cambió las ropas \w de|strong="H6440"\w* su prisión, y comió \w pan|strong="H3899"\w* en su \w presencia|strong="H6440"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H6440"\w* su \w vida|strong="H2416"\w*.
