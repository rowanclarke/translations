\q2 \w le|strong="H3068"\w* \w souffle|strong="H7307"\w* \w du|strong="H5927"\w* \w SEIGNEUR|strong="H3068"\w* \w montant|strong="H5927"\w* \w du|strong="H5927"\w* \w désert|strong="H4057"\w* ;  
