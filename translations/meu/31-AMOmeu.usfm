\id AMO .01, Amos 1, Motu, PNG, RTWP 12/92
\h AMOS
\toc1 AMOS
\toc2 AMOS
\mt1 AMOS
\c 1
\s1 Hahemaoro bese idau-idau latadiai
\p 
\v 1 Amos, Tekoa mamoe ireḡudia taudia ta, ena hereva, Israel dainai e ita ḡaudia herevadia, Usia, Iuda pavapavana, bona Ieroboam loasa, Israel pavapavana, edia nega ai, laḡani rua dounu mimia ema bona tano-laga e kau negana ai.
\v 2 Ia eto:
\q1 Iehova na Siona amo e lolomu,
\q2 Ierusalem amo e herevamu;
\q1 mamoe ireḡudia taudia edia rei gabudia na e kakoromu,
\q2 Karamele ororona dorina na e maraimu.
\b
\q1 
\v 3 Iehova ini e gwau tomamu:
\q2 Damasko ena kerere toi bona hani daidiai,
\q2 lau ese ena dika davana ihenina basina gwaua tao;
\q1 badina be idia ese Gilead vada e kwadia, uit na heto,
\q2 edia kwadikwadi ḡaudia na auri ḡaudia.
\q1 
\v 4 Taunabunai lau ese lahi ta baina siaia Hasaele ena ruma latanai,
\q2 una lahi ese Ben-hadad ena gabu aukadia baine aradia ore.
\q1 
\v 5 Damasko ena ikoukou auridia baina hakwaidudia,
\q2 Avene Kourana inoholaina taudia na baina negedia daure,
\q1 bona dagi auna e dogoa taomu tauna na Bet eden amo baina abia oho,
\q2 bona Suria taudia na dauhai baina hanohodia, Kiri tanona ai.
\q2 Iehova na e herevamu.
\b
\q1 
\v 6 Iehova ini e gwau tomamu:
\q2 Gasa ena kerere toi bona hani daidiai,
\q2 lau ese ena dika davana ihenina basina gwaua tao;
\q1 badina be idia ese bese ta taunimanimadia iboudiai na dauhai vada e hanohodia,
\q2 Edom imana ai bae atodia helaoreana.
\q1 
\v 7 Taunabunai lau ese lahi ta baina siaia, Gasa maḡuna latanai,
\q2 una lahi ese ena gabu aukadia baine aradia ore.
\q1 
\v 8 Asdod inoholaina taudia na baina negedia daure,
\q2 bona dagi auna e dogoa taomu tauna na Askelono amo baina abia oho;
\q1 imagu baina pala henia Ekron ihadikana,
\q2 bona Filistia kwabukwabudia na bae mase ore.
\q2 Ḡaubada Iehova na e herevamu.
\q1 
\v 9 Iehova ini e gwau tomamu:
\q2 Turo ena kerere toi bona hani daidiai,
\q2 lau ese ena dika davana ihenina basina gwaua tao;
\q1 badina be idia ese bese ta taunimanimadia iboudiai na Edom imana ai e atodia,
\q2 bona asie laloa tao, tadikaka vada e hegwauhamata heheni.
\q1 
\v 10 Taunabunai lau ese lahi ta baina siaia, Turo maḡuna latanai,
\q2 una lahi ese ena gabu aukadia baine aradia ore.
\b
\q1 
\v 11 Iehova ini e gwau tomamu:
\q2 Edom ena kerere toi bona hani daidiai,
\q2 lau ese ena dika davana ihenina basina gwaua tao;
\q1 badina be ia ese tadina na dare amo e hahavaia,
\q2 bona hebogahisi e negea vaitani;
\q1 ena badu na e siahu loulou,
\q2 ena badu ḡaraḡara na e dogoa tao hanaihanai.
\q1 
\v 12 Taunabunai lau ese lahi ta baina siaia, Teman latanai,
\q2 una lahi ese Bosra ena gabu aukadia baine aradia ore.
\b
\q1 
\v 13 Iehova ini e gwau tomamu:
\q2 Amono taudia edia kerere toi bona hani daidiai,
\q2 lau ese edia dika davana ihenina basina gwaua tao;
\q1 badina be idia ese rogorogo hahinedia vada e dapadia parara Gilead ai,
\q2 edia tano hetoana bae habadaia totona.
\q1 
\v 14 Taunabunai, lau ese lahi ta baina ha-araia Raba maḡuna ai,
\q2 una lahi ese ena gabu aukadia baine aradia ore,
\q1 mai lolona ida tuari dinana ai,
\q2 mai lai gubana ida koe-hirihiri dinana ai;
\q1 
\v 15 edia pavapava na dauhai bae hanohoa,
\q2 ia bona ena lohia taudia danu ia ida.
\q2 Iehova na e herevamu.
\c 2
\q1 
\v 1 Iehova ini e gwau tomamu:
\q1 Moab ena kerere toi bona hani daidiai,
\q2 lau ese ena dika davana ihenina basina gwaua tao;
\q1 badina be ia ese Edom pavapavana turiana e gabudia,
\q2 ahu ai e halaodia.
\q1 
\v 2 Taunabunai lau ese lahi ta baina siaia Moab latanai,
\q2 una lahi ese Kerioto ena gabu aukadia baine aradia ore;
\q1 bena Moab na heloḡo-heloḡo ai baine mase,
\q2 lolo bona kibi reḡedia bogaragidiai.
\q1 
\v 3 Lau ese pavapava na ia bogaragina amo baina negea daure,
\q2 bona ena lohia iboudiai na ia ida baina aladia mase.
\q2 Iehova na e herevamu.
\b
\q1 
\v 4 Iehova ini e gwau tomamu:
\q2 Iuda ena kerere toi bona hani daidiai,
\q2 lau ese ena dika davana ihenina basina gwaua tao;
\q1 badina be idia ese Iehova ena taravatu vada e dadaraia,
\q2 bona ena hahedua herevadia asie badinadia;
\q1 a tamadia ese e rakalaidia daladia koikoidia ese
\q2 idia vada e hakaudia kerere.
\q1 
\v 5 Taunabunai lau ese lahi ta baina siaia Iuda latanai,
\q2 una lahi ese Ierusalem ena gabu aukadia baine aradia ore.
\s1 Hahemaoro Israel latanai
\q1 
\v 6 Iehova ini e gwau tomamu:
\q2 Israel ena kerere toi bona hani daidiai,
\q2 lau ese ena dika davana ihenina basina gwaua tao;
\q1 badina be idia ese kara maoromaoro tauna e hoiamu, \it silver\it* davana,
\q2 bona e dabumu tauna e hoiamu, tamaka rua davadia.
\q1 
\v 7 Idia ese ogoḡami tauna kwarana na tano gahuna ai e moimoilaiamu,
\q2 bona e hisihisimu tauna ena dala e laoa ahumu.
\q1 Tau ta bona tamana ese hane-ulato tamona dekenai e raka vareaimu,
\q2 unu amo lau ladagu helaḡana e hamiroamu.
\q1 
\v 8 Idia ese ihaboulaina patadia iboudiai badibadidiai e hekuremu,
\q2 henitao dabuadia latadiai.
\q1 Edia Dirava ena dubu ai vine ranuna e inuamu,
\q2 hahemaoro ai haida edia amo e abia ḡauna.
\b
\q1 
\v 9 Ḡau tamona, lau ese Amoro tauna na habuaia tari idia vairadiai;
\q2 ena lata na sida audia edia lata heḡereḡeredia,
\q2 bona ena goada na \it oak\it* audia edia goada heḡereḡeredia.
\q1 Ia huahuana na habuaia tari atai ai,
\q2 bona ramuna danu henu ai.
\q1 
\v 10 Ina danu, lau ese Aigupto tanona amo na hakaumui lasi,
\q2 laḡani hari-ahui lalodiai tano ḡaḡaena ai na hakaumui lao,
\q2 Amoro tauna ena tano ba ḡaunaia totona.
\q1 
\v 11 Natumui haida na haginidia, peroveta taudia ai baela,
\q2 bona emui eregabe taudia haida na abidia,
\q2 Nasiri oreana taudia ai baela.
\q1 Israel taumui e, una na momokani ani?
\q2 Iehova na e herevamu.
\q1 
\v 12 A umui ese Nasiri oreana taudia na vine ranuna amo o ha-inudia,
\q2 bona peroveta taudia na o haḡanidia, oto
\q2 “Umui na basio peroveta”.
\b
\q1 
\v 13 A itaia, lau ese emui gabu ai baina taomui tari,
\q2 uit iḡuidia ai e honumu reruena e hetao tarimu na heto.
\q1 
\v 14 Ae-haraḡa tauna na basine heau diba,
\q2 goada tauna ese ena goada basine dogoa tao,
\q2 bona tuari tauna basine roho mauri.
\q1 
\v 15 Peva tauna basine gini,
\q2 ae-haraga tauna na sibona basine hahemauri,
\q2 bona hosi-gui tauna basine roho mauri.
\q1 
\v 16 Lalo-auka tauna tuari taudia bogaragidiai na
\q2 ḡaḡaena ai baine heau una dina ai.
\q2 Iehova na e herevamu.
\c 3
\s1 Peroveta tauna ena ḡaukara
\p 
\v 1 Israel taumui e, ina hereva, Iehova ese umui latamui ai, Aigupto tanona amo na hakaua lasi besena idoinai latanai, vada e gwauraia herevana vada ba kamonai.
\q1 
\v 2 Tanobada besedia iboudiai bogaragidia amo
\q2 umui sibomui vada na dibamui;
\q1 taunabunai lau ese matamui baina hakani,
\q2 emui kara havara iboudiai daidiai.
\b
\q1 
\v 3 Tatau rarua basiema henega bou guna,
\q2 idia bema raka hebou diba a?
\q1 
\v 4 Leona na asi damuna negana ai
\q2 uda ai e ḡoumu a?
\q1 Leona natuna ese ḡau ta se abiamu negana ai
\q2 ena kohua lalonai e taimu a?
\q1 
\v 5 Idoa se miamu gabuna ai
\q2 manu ta e heidoamu a?
\q1 Ḡau ta se heidoa negana ai
\q2 idoa na e hepiu isimu a?
\q1 
\v 6 Kibi na hanua ta ai e hiririamu negana ai
\q2 taunimanima basie gari a?
\q1 Iehova ese se hadikaiamu negana ai
\q2 dika na hanua ta ai e kaumu a?
\q1 
\v 7 Momokani Ḡaubada Iehova ese kara ta se karaia hehunimu,
\q2 a peroveta taudia, ena hesiai taudia, na e hadibalaidia gunamu.
\q1 
\v 8 Leona vada e ḡou,
\q2 daika basine gari?
\q1 Ḡaubada Iehova vada e hereva;
\q2 daika basine peroveta?
\s1 Samaria irevana
\q1 
\v 9 Asuria ena gabu aukadia ba hamaorodia,
\q2 bona Aigupto tanona ena gabu aukadia danu;
\q1 baoto: Samaria ororodia latadiai ba hahebou,
\q2 heloḡo-ahuahu badadia ia lalonai ba itadia,
\q2 bona hahehisi karadia ia bogaraginai danu.
\q1 
\v 10 Iehova na e tomu: Kara maoromaoro ikaradia na asi dibadia;
\q2 idia ese daḡedaḡe bona dadidadi karadia na
\q2 edia gabu aukadia ai e heḡaeḡaelaidiamu.
\q1 
\v 11 Taunabunai Ḡaubada Iehova ini e gwau tomamu;
\q2 mai tauna ta ese tano baine koua hegege,
\q1 emui maḡu baine ḡiḡidia dobi,
\q2 bona emui gabu aukadia kohudia baine dadi ore.
\p 
\v 12 Iehova ini e gwau tomamu: Mamoe ireḡudia tauna ese leona uduna amo mamoe aena rua eiava taiana kahana baine rauadia na heto, Israel taudia Samaria ai e nohomu na unu bae rauadia toma, mai hekure patana daigunina ta eiava mahuta ḡauna kahana ta ida.
\q1 
\v 13 Ḡaubada Iehova, Iehova Sabaota, ini e gwau tomamu:
\q2 A kamonai, bona Iakob iduhuna latanai
\q2 hahebade herevadia ba gwaurai, baoto,
\q1 
\v 14 Israel na ena kara havara daidiai matana baina hakania dinana ai,
\q2 lau ese Betele ena ihaboulaina patadia latadiai
\q2 mata-hakani karadia baina kara;
\q1 bena ihaboulaina patana doadia bae heutu oho,
\q2 tano ai bae moru.
\q1 
\v 15 Keru negana rumana bona siahu negana rumana na baina huaridia,
\q2 bona aivori\f + \fr 3:15 \ft “Aivori” na elefant doadia.\f* rumadia na bae heḡiḡi dobi,
\q1 bona ruma badadia na bae ore vaitani.
\q2 Iehova na e herevamu.
\c 4
\q1 
\v 1 Basan boromakau hahinedia e, ina hereva ba kamonai,
\q2 Samaria ororona ai o nohomu hahinemui e;
\q1 umui ese ogoḡami taudia na o hahisidiamu,
\q2 bona e dabumu taudia na o taodia tarimu;
\q1 adavamui o hamaorodiamu, o tomu
\q2 “A mailaia, baia inua”.
\q1 
\v 2 Ḡaubada Iehova na ena helaḡa bagunai vada e gwau hamata,
\q2 e tomu: Nega na emui ai baine kau,
\q1 igau amo bae verimui oho,
\q2 kimai amo bae abimui ore;
\q1 
\v 3 bena maḡu maurudia amo do ba rau lasi,
\q2 ta ta vairana vairana amo baola;
\q1 bae negemui daure Haramono ai.
\q2 Iehova na e herevamu.
\s1 Israel na se helalomu
\q1 
\v 4 Betele baoma, ba kara kerere,
\q2 Gilgal baoma, emui kerere ba hahohodia;
\q1 daba iboudiai emui boubou ḡaudia ba mailaidia,
\q2 dina toi toi amo emui ḡau karoadia ihagwautadia danu.
\q1 
\v 5 Israel taumui e, e hatubua flaoana ba hahelagaia,
\q2 emui hahenamo bouboudia;
\q1 ura-kwalimu herahiadia ba gwauraidia,
\q2 ba gwauraidia hedinarai;
\q1 badina be emui ura korikori bunai.
\q2 Ḡaubada Iehova na e herevamu.
\b
\q1 
\v 6 Ise ḡoevaḡoeva na henimui, emui hanua iboudiai lalodiai,
\q2 doe danu na henimui, emui gabu iboudiai lalodiai;
\q1 ḡau tamona umui na dekegu asio lou mai.
\q2 Iehova na e herevamu.
\b
\q1 
\v 7 Taboro negana na do hua toi vairai,
\q2 lau ese medu na emui ai na rua.
\q1 Medu na hanua ta latanai na hadihoa,
\q2 bona ma hanua ta latanai asina hadihoa;
\q1 uma ta na medu ese e hapariparia,
\q2 ma uma ta na e kaukau, medu na ia latanai se diho dainai.
\q1 
\v 8 Bena hanua rua eiava toi taudia ese
\q2 hanua ta e lao heniava, ranu bae inua totona,
\q2 a gadodia asie doro;
\q1 ḡau tamona umui na dekegu asio lou mai.
\q2 Iehova na e herevamu.
\q1 
\v 9 Hogohogo bona valavala amo na hadikamui,
\q2 emui uma bona emui vine imeadia na havahudia;
\q1 emui suke audia bona emui olive audia na kwadi ese e ani ore;
\q2 ḡau tamona umui na dekegu asio lou mai.
\q2 Iehova na e herevamu.
\b
\q1 
\v 10 Dai-hanai gorerena na bogaragimui ai na siaia vasi,
\q2 Aigupto ai na karava na heto;
\q1 emui eregabe taudia na dare amo na aladia mase,
\q2 emui hosi na na abidia oho dauhai,
\q2 bona emui taruha bodagana na udu-baubaumui ai na hadaea;
\q1 ḡau tamona umui na dekegu asio lou mai.
\q2 Iehova na e herevamu.
\b
\q1 
\v 11 Lau ese umui haida na hadareremui,
\q2 Dirava ese Sodoma bona Gomora e hadareredia na heto;
\q1 umui na lahi tutuna lahi lalona amo e veria lasimu na heto;
\q2 ḡau tamona umui na dekegu asio lou mai.
\q2 Iehova na e herevamu.
\b
\q1 
\v 12 Taunabunai, Israel e, ini baina karamui toma;
\q2 bena ini baina karamui toma dainai,
\q1 Israel e, ba heḡaeḡae,
\q2 emui Dirava ida do ba hedavari.
\b
\q1 
\v 13 A itaia, ororo e karadiamu
\q2 bona lai e havaradiamu Diravana,
\q1 ena lalo-hadai na taunimanima e hadibalaidiamu Diravana,
\q2 daba e hadiburaiamu bona tanobada ena atai gabudia e moimoilaidiamu Diravana,
\q1 Iehova, Iehova Sabaota,
\q2 ia ladana bunai.
\c 5
\s1 Israel e, ba helalo
\p 
\v 1 Israel besena e, egu rohe-ahu herevana oi latamu ai vada ba kamonai.
\q1 
\v 2 Israel hane-ulatona vada e moru,
\q2 ia na basine tore isi lou;
\q1 ena tano ai vada e rakatania,
\q2 ta ese basine hatorea isi.
\b
\q1 
\v 3 Badina be Ḡaubada Iehova ini e gwau tomamu:
\q2 Hanua ta amo daha-ta e raka lasimu,
\q2 a sinahu tamona bae mauri;
\q1 ma hanua ta amo sinahu-ta e raka lasimu,
\q2 a gwauta mo bae mauri,
\q2 Israel besena enai.
\q1 
\v 4 Badina be Iehova ese Israel besena e hereva heniamu,
\q2 ini e gwau tomamu:
\q1 Lau ba tahugu, bena ba mauri.
\q2 
\v 5 Betele basio tahua,
\q1 Gilgal ai basio raka vareai,
\q2 Bere-sieba ai basio raka hanai;
\q1 badina be Gilgal na dauhai bae hanohoa,
\q2 bona Betele na baine baia.
\b
\q1 
\v 6 Iehova ba tahua, bena ba mauri;
\q2 ia na lahi na heto baine ara, Iosef ena ruma ai,
\q2 baine ara ore, ta basine habodoa diba Betele ai, na garina;
\q1 
\v 7 umui, hahemaoro ḡoevaḡoeva na muramura iditana ai vada o halaoa
\q2 bona kara maoromaoro tanobada ai vada o tilhoa dobi taumui!
\b
\q1 
\v 8 Ia ese Kima bona Kesili\f + \fr 5:8 \ft “Kima” bona “Kesili” be hisiu haida ladadia, Heberu gado ai.\f* e karadia,
\q2 hanuaboi diburana na daba ai e halaoamu,
\q2 bona dina na e hadiburaiamu, hanuaboi ai e halaoamu;
\q1 ia ese davara ranudia e boiridiamu,
\q2 bena tanobada kopina ai e bubudia dobimu;
\q2 ia ladana na Iehova.
\q1 
\v 9 Ia ese goada taudia e aladia oremu,
\q2 bona kohoro aukadia e habuadia tarimu.
\b
\q1 
\v 10 Hahemaoro gabuna ai sisiba herevadia e gwauraimu tauna na
\q2 idia ese e inai heniamu,
\q1 bona hereva momokanidia e gwauraimu tauna na
\q2 idia ese e inai henia badamu.
\q1 
\v 11 Taunabunai, badina be ogoḡami tauna vada o moia tao
\q2 bona ena uit momo vada o dadia dainai,
\q1 nadi rumadia vada o haginidia,
\q2 to lalodiai basio noho,
\q1 bona vine imeadia namodia vada o hado,
\q2 to edia vine ranudia basio inu.
\q1 
\v 12 Badina be lau dibagu emui kerere na momo,
\q2 bona emui kara dika na bada herea.
\q1 Umui ese kara maoromaoro taudia o hahisidiamu,
\q2 bona koikoi henitaona o abiamu,
\q1 bona e dabumu tauna hanua ikoukouna ai na
\q2 hahemaoro gabuna amo o lulua ohomu.
\q1 
\v 13 Taunabunai, nega inihetomana ai
\q2 lalo-ihunu tauna na asi reḡereḡena baine noho,
\q2 badina be nega dikana.
\b
\q1 
\v 14 Namo ba tahua, dika basio tahua,
\q2 ba mauri helaoreana;
\q1 bena Dirava, Iehova Sabaota, ese baine bamomu,
\q2 ema hereva heḡereḡerena.
\q1 
\v 15 Dika ba inai henia, namo ba ura henia,
\q2 hahemaoro ḡoevaḡoeva na hanua ikoukouna ai ba haginia;
\q1 bena reana Dirava, Iehova Sabaota, ese
\q2 Iosef iduhuna taudia kwabukwabudia baine bogadia hisi.
\b
\q1 
\v 16 Taunabunai Dirava, Iehova Sabaota, Ḡaubada, na ini e gvvau tomamu:
\q2 Ariara iboudiai lalodiai bae tai lolololo,
\q1 bona hanua ariaradia iboudiai lalodiai baeto
\q2 “Inaio, inaio!”
\q1 Biru taudia bae boiridia, bae taitai,
\q2 bona herohe-ahu mai dibadia taudia bae boiridia, bae tai lolololo;
\q1 
\v 17 vine imeadia iboudiai lalodiai bae tai lolololo,
\q2 badina be bogaragimui amo baina raka hanai.
\q2 Iehova na e herevamu.
\b
\q1 
\v 18 Iehova ena dina o hekise-hekise heniamu taumui, madi, ihabaimui!
\q2 Dahaka dainai Iehova ena dina o laroamu?
\q1 Una dina na dibura, dia diari;
\q2 
\v 19 tau ta ese leona bema heautania
\q2 bena bea ta ida bema hedavari na heto;
\q1 eiava ruma lalonai bema raka vareai,
\q2 haba ai bema hetaotao,
\q2 bena gaigai ese bema koria na heto.
\q1 
\v 20 Iehova ena dina na dibura, dia diari, ani?
\q2 bona gabora asi diarina ani?
\b
\q1 
\v 21 Emui aria na na inai henidiamu bona na dadaraidiamu;
\q2 emui hebou helaḡadia asina moalelaidiamu.
\q1 
\v 22 Ena be emui ḡole-oho bouboudia bona emui flaoa bouboudia ḡaudia o harihari henigumu,
\q2 to lau ese basina abidia dae;
\q1 bona emui ubu-ubu ḡaudia, maino boubou ḡaudia ai o halaodiamu, na
\q2 lau ese basina haḡeredia.
\q1 
\v 23 Emui ane reḡedia na egu ai bavabi oho,
\q2 emui gitara reḡedia basina hakala henidia.
\q1 
\v 24 A hahemaoro ḡoevaḡoeva baine aru, abata na heto,
\q2 bona kara maoromaoro, se kororomu sinavaina na heto.
\p 
\v 25 Israel besena e, laḡani hari-ahui tano ḡaḡaena ai o nohova lalodiai boubou bona herahia ḡaudia na egu ai o mailaidia a?
\v 26 Emui pavapava Sakutu, bona emui hisiu diravana Kaiwana, emui kaivakuku, imamui amo o kara gaudia, na do ba huadia;
\v 27 taunabunai, lau ese baina laohaimui, Damasko unukahanai baina hanohomui. Dirava, ladana Iehova Sabaota, na e herevamu.
\c 6
\s1 Israel ihabua-tarina
\q1 
\v 1 Siona ai e noho namonamomu
\q2 bona Samaria ororona ai asi garidia e nohomu taudia,
\q1 bese gini-gunana ena tatau hereadia,
\q2 Israel taudia e lao henidiamu taudia,
\q2 madi, ihabaidia!
\q1 
\v 2 Ba raka lao, Kalne baola, ba itaia;
\q2 unu amo Hamat badana baola;
\q1 bena ba hekei diho,
\q2 Gata, Filistia taudia edia hanua, baola.
\q1 Idia ese ini basileia e hereadiamu a?
\q2 Eiava edia tano na bada, emui tano be maraḡi, a?
\q1 
\v 3 Umui dika dinana o atoa daudaumu
\q2 bona daḡedaḡe ena vara badina o veria kahimu taumui,
\q2 na nanadaimuimu.
\b
\q1 
\v 4 Aivori patadia ai e hekuremu
\q2 bona edia laḡa-ani patadia ai e eno deremu taudia,
\q1 mamoe natudia seri amo
\q2 bona boromakau natudia ubu-ubu gabuna amo e animu taudia,
\q2 madi, ihabaidia!
\q1 
\v 5 Gitara e hataidiamu ai ane kavakavadia e abimu
\q2 bona David na heto hatai-hatai ḡaudia idaudia e karamu taudia,
\q2 madi, ihabaidia!
\q1 
\v 6 Vine ranuna na nau amo e inuamu,
\q2 bona dehoro namo-hereadia amo taudia e dahudiamu,
\q1 a Iosef ena dika asie lalo hisihisilaiamu taudia,
\q2 madi, ihabaidia!
\q1 
\v 7 Taunabunai dauhai ihanohodia negana ai idia na bae laohaidia guna,
\q2 bona e eno deremu taudia edia moale baine boio.
\b
\q1 
\v 8 Ḡaubada Iehova na sibona ladana ai vada e gwau hamata;
\q2 Dirava, Iehova Sabaota, na e herevamu e tomu:
\q1 Iakob ena heaḡi na inai henia badamu,
\q2 ena gabu aukadia danu na inai henidiamu;
\q1 hanua na baina kahua nege,
\q2 bona ia lalona ḡaudia iboudiai.
\b
\p 
\v 9 Tatau gwauta ruma tamona ai bema noho, idia na bae mase.
\v 10 Bena mase tauna varavarana, tau-anina baine hagolea oho tauna, ese baine abia isi, turiana na ruma lalona amo murimuri ai baine laohai totona, bona ruma laloma kahana ai e nohomu tauna baine nanadaia, baineto “Tau ta doene noho eiava?”, bena una tau baine haere, baineto “Lasi”, negana ai, ia ma baineto “Eremu! Iehova ladana na basita hatoa”.
\q1 
\v 11 Badina be, a itaia, Iehova na e haheḡanimu,
\q2 bena ruma badana na bae huaria patapata,
\q2 bona ruma maraḡina na bae huaria sisisisi.
\q1 
\v 12 Hosi be haga nadidia ai e heaumu a?
\q2 Davara na boromakau mamaruanedia amo e ruaiamu a?
\q1 A umui ese hahemaoro ḡoevaḡoeva na mase muramurana ai vada o halaoa,
\q2 bona kara maoromaoro huahuana na muramura iditana ai vada o halaoa.
\q1 
\v 13 Umui ese Lo-debara o moalelaiamu,
\q2 o tomu “Sibomai emai goada ai Karanaimi vada a abia emai”, ani?
\q1 
\v 14 Dirava, Iehova Sabaota, na e tomu:
\q2 Israel taumui e,
\q1 a itaia, lau ese bese ta baina hatorea isi
\q2 umui ihadikamui totona,
\q1 bena bae hahisihisimui, Hamat raka-vareaina amo
\q2 ela bona Araba dokana.
\c 7
\s1 Mata-hanai toi
\p 
\v 1 Bena Ḡaubada Iehova ese e haheitalaigu, ia ese kwadi e haboudia heḡaeḡaeva, rei matamatana e tubu louva negana ai; una na rei ena tubu iharuana, pavapava ena rei vada e utua murinai.
\v 2 Unu kwadi ese tano reina vada e ania ore murinai, lau na hereva, nato:
\q1 Ḡaubada Iehova e, lau na noimumu, ba heboga hisi.
\q2 Iakob ede baine gini toma?
\q2 Ia na maraḡi herea.
\q1 
\v 3 Bena Iehova ese e helalolaia kerehai;
\q2 Iehova eto “Ina na basine hekara”.
\p 
\v 4 Taunabunai Ḡaubada Iehova ese e haheitalaigu, na itaia, Ḡaubada Iehova ese hahemaoro e boilaia, lahi ḡauna; bena una lahi ese gadobada e hakaukauava bona tano e araiava.
\v 5 Bena lau nato:
\q1 Ḡaubada Iehova e, lau na noimumu, a doko.
\q2 Iakob ede baine gini toma?
\q2 Ia na maraḡi herea.
\q1 
\v 6 Bena Iehova ese e helalolaia kerehai;
\q2 Ḡaubada Iehova eto “Ina danu basine hekara”.
\p 
\v 7 Ma e haheitalaigu, na itaia, Ḡaubada na gini-maoro varona amo e haginia habana badibadinai e gini, mai gini-maoro varona ta imana ai.
\v 8 Bena Iehova ese e hereva henigu, eto, Amos e, dahaka o itaiamu? Lau nato, Gini-maoro varona ta. Bena Ḡaubada eto:
\q1 A itaia, gini-maoro varona ta
\q2 egu bese Israel bogaragidiai na atoamu;
\q2 nega ta ai basina lagaudia hanai lou.
\q1 
\v 9 Isaak ena atai gabudia bae ḡaḡae,
\q2 Israel ena gabu helaḡadia bae vahu;
\q2 bona Ieroboam ena iduhu na dare amo baina tuari henidia.
\s1 Amos bona Amasia
\p 
\v 10 Bena Amasia, hahelaḡa tauna Betele ai, ese gwaukau e siaia, Ieroboam, Israel pavapavana, dekenai, eto, Amos ese oi ihadikamu dalana e karaia hatamu, Israel besena bogaraginai; tano taudia lalodia na asie heḡereḡere iena hereva iboudiai ihaheaukalaidia ai.
\v 11 Badina be Amos na ini e gwau toma:
\q1 Ieroboam na dare amo do baine mase,
\q2 bona Israel taudia na edia tano amo bae abidia oho,
\q2 dauhai bae hanohodia.
\p 
\v 12 Bena Amasia ese Amos e hamaoroa, eto, Mata-hanai taumu e, aola, Iuda tanona ba heau lao, unuseni ai bavaniani bona ba peroveta;
\v 13 a nega ta ai Betele ai basio peroveta lou, badina be ina na hanua pavapavana ena gabu helaḡana bona basileia ena dubu.
\p 
\v 14 Bena Amos ese Amasia e haere henia, eto, Lau na dia peroveta tauna, bona dia peroveta tauna natuna. Lau na mamoe bona sukamore audia ireḡudia tauna;
\v 15 bena Iehova ese manoe serina iḡavana amo e abigu. Bena Iehova ese e hamaorogu, eto, Aola, egu bese Israel ediai ba peroveta.
\q1 
\v 16 Taunabunai, Iehova ena hereva a kamonai.
\q2 Oi na o tomu “Israel taudia latadiai basio peroveta
\q2 bona Isaak iduhuna taudia latadiai basio haroro”.
\q1 
\v 17 Taunabunai Iehova ini e gwau tomamu:
\q2 Adavamu na ariara hahinena ai bainela, hanua lalonai;
\q1 natumu mamaruanedia bona hahinedia na dare ai bae mase,
\q2 bona emu tano na haida ese bae heharilaia;
\q1 oi na tano dia ḡoeva ai ba mase,
\q2 bona Israel na momokani edia tano amo bae abidia oho,
\q2 dauhai bae hanohodia.
\c 8
\s1 Mata-hanai ihahanina
\p 
\v 1 Bena Ḡaubada Iehova ese ma e haheitalaigu, au huahua maḡedia bosea ta na itaia.
\v 2 Bena ia eto, Amos e, dahaka o itaiamu? Bena lau nato, Au huahua maḡedia bosea ta. Bena Iehova ese e hereva henigu, eto:
\q1 Egu bese Israel vada e maḡe, hahebua-tari enai;
\q2 nega ta ai basina lagaudia hanai lou;
\q1 
\v 3 dubu anedia na taitai ai bae hahelao una dina ai.
\q2 Ḡaubada Iehova na e herevamu.
\q1 Mase tau-anidia bae hoho,
\q2 gabu iboudiai murimuri ai bae tahodia lasi,
\q2 asi reḡereḡedia.
\s1 Hahedika vada e kahikahi Israel latanai
\q1 
\v 4 Umui, e dabumu taudia o moidia taomu
\q2 bona tano ena ogoḡami taudia o hamasediamu taumui,
\q2 ina na a kamonai!
\q1 
\v 5 Umui na o hereva hehenimu, o tomu:
\q2 Hua matamata ariana na edena nega ai baine ore,
\q2 bena aniani ḡaudia baita hoihoilai?
\q1 Bona dina helaḡa na edena nega ai baine ore,
\q2 bena uit baita hoihoilaia?
\q1 Bena efa baita hamaraḡia bona sekele baita habadaia,
\q2 bona hahetoho ḡaudia koikoidia amo taunimanima baita dibaḡanidia;
\q1 
\v 6 ogoḡami taudia na \it silver\it* amo baita hoidia,
\q2 bona e dabumu taudia na tamaka rua rua amo danu;
\q2 bona uit momona danu baita hoihoilaia.
\b
\q1 
\v 7 Iakob ena heaḡi dainai Iehova vada e gwau hamata, eto:
\q2 Momokani edia kara ta basina laloa boio.
\q1 
\v 8 Una dainai tano baine heude-heude,
\q2 bona inoholaina taudia iboudiai bae tai,
\q1 idoinai baine dae, Nilo sinavaina na heto,
\q2 baine hegure-hegure, bena ma baiule diho,
\q2 Nilo, Aigupto sinavaina, na heto, ani?
\b
\q1 
\v 9 Ḡaubada Iehova na e tomu: Una dina ai
\q2 dina tubua ai dina baina hadihoa,
\q2 bona dina diarina ai tanobada baina hadiburaia.
\q1 
\v 10 Emui aria na taitai ai baina halaodia,
\q2 bona emui ane iboudiai na rohe-ahu ai baina halaodia.
\q1 Koekoe iboudiai na puse dabuadia baina hariolaidia,
\q2 bona kwara iboudiai baina naudia.
\q1 Vara-edea merona itailaina heḡereḡerena ai baina halaoa,
\q2 bona dokona na dina iditana heḡereḡerena ai.
\b
\q1 
\v 11 Ḡaubada Iehova na e tomu.
\q2 A itaia, nega na e maimu,
\q2 doe na tano latanai baina siaia.
\q1 Dia aniani ai eiava ranu ai basie dabu,
\q2 a Iehova ena hereva ikamonaidia ai hari.
\q1 
\v 12 Davara ta konena ela bona ma davara ta konena bae loa eva-eva,
\q2 mirigini kahana amo ela bona laurabada danu;
\q1 bae heau lao heau mai, Iehova ena hereva itahuna,
\q2 to basie davaria.
\b
\q1 
\v 13 Una dina ai hane-ulato rami-hebou namo-hereadia bona uhau na
\q2 bae ranu mase, bae manori.
\q1 
\v 14 Asima, Samaria diravana, ladana ai e gwau hamatamu taudia
\q2 e tomu “Dan e, emu dirava e maurimu heḡereḡerena”,
\q2 bona “Bere-sieba dalana e maurimu heḡereḡerena”;
\q1 idia na bae keto,
\q2 bona nega ta ai basie tore isi lou.
\c 9
\s1 Iehova ena siahu
\q1 
\v 1 Ḡaubada na itaia, ihaboulaina patana badibadinai e gini,
\q2 e hereva, eto:
\q1 Au-tubua kwaradia ikorodla ba botadia,
\q2 ela bona badidia bae heude-heude;
\q1 ba huaridia patapata,
\q2 bena taunimanima iboudiai kwaradia ai bae heḡiḡi kau.
\q1 Bena oredia na dare amo baina aladia mase,
\q2 ta basine heau oho,
\q2 ta basine roho mauri.
\b
\q1 
\v 2 Ena be guri bae ḡei ela bona Mase Gabuna,
\q2 to unu amo lau imagu ese baine abidia;
\q1 ena be guba ai bae dara dae,
\q2 to unu amo baina veridia dobi.
\q1 
\v 3 Ena be Karamele ororona dorina ai bae komu,
\q2 to unuseni ai baina tahudia ela bona baina abidia;
\q1 ena be davara ena dobu gabudia ai lau vairagu amo bae komu,
\q2 to unuseni ai dagwala baina haganidia, bena baine koridia.
\q1 
\v 4 Ena be inaidia ese bae guidia, bena bae doridia lao,
\q2 to unuseni ai dare baina hagania, bena baine aladia mase.
\q1 Baina raraidia tao,
\q2 dia ihanamodia to ihadikadia totona.
\b
\q1 
\v 5 Ḡaubada, Iehova Sabaota, ese
\q2 tanobada e daua tohomu, bena e veve ohomu,
\q2 bona inoholaina taudia na e taitaimu;
\q1 idoinai e daemu, Nilo sinavaina na heto,
\q2 ma e dihomu, Nilo, Aigupto sinavaina, na heto.
\q1 
\v 6 Ia ese ena atai daiutudia e hadaidiamu guba ai,
\q2 bona ena henu daiutudia tanobada ai;
\q1 ia ese davara ranudia e boilaidiamu,
\q2 bona tanobada kopina ai e bubudia dobimu;
\q2 ia ladana na Iehova.
\b
\q1 
\v 7 Iehova na e tomu: Israel taumui e,
\q2 umui na dia Etiopia taudia heḡereḡeredia lauegu ai a?
\q1 Israel taudia na Aigupto tanona amo asina hakaudia lasi a?
\q2 Filistia taudia na Kaftoro amo bona Suria taudia na Kiri amo asina mailaidia a?
\q1 
\v 8 A itaia, Ḡaubada Iehova ese
\q2 kara dika basileiana na e raraia taomu.
\q1 Iehova na e tomu: tano kopina amo baina habuaia tari;
\q2 ḡau tamona, Iakob ena iduhu basina habuaia tari vaitani.
\s1 Israel baine namo lou
\q1 
\v 9 A itaia, lau na baina haheḡani,
\q2 Israel besena baina haruiruia, basileia iboudiai bogaragidiai,
\q1 ruirui ḡauna amo bama ruiruia na heto,
\q2 a nadinadi ta na tano ai basine moru.
\q1 
\v 10 Kara dika taudia egu bese bogaraginai iboudiai,
\q2 e tomu “Dika ese basine lasida tao eiava basine hedavari henida” taudia,
\q2 na dare ai bae mase.
\b
\q1 
\v 11 Una dina ai David ena kalaga, e heḡiḡi dobi ḡauna,
\q2 lau ese ma baina haginia lou;
\q1 e mauru gabudia baina banidia,
\q2 e heḡiḡi dobi gabudia baina haginidia,
\q1 baina haginia lou,
\q2 nega gunadia heḡereḡeredia ai!
\q1 
\v 12 Edom orena bae ḡaunaia helaoreana,
\q2 bona lau ladagu e henemailai besedia iboudiai danu.
\q1 Iehova, ini kara e karamu Diravana,
\q2 na e herevamu.
\b
\q1 
\v 13 Iehova na e tomu: A itaia, nega na e maimu,
\q2 ruarua tauna ese uit iutuna tauna baine lasia tao,
\q2 bona vine huahuadia imoimoilaidia tauna ese hadohado tauna baine lasia tao;
\q1 ororo amo vine ranuna gaihona baine hetuturu,
\q2 bona ororo komutadia amo baine aru.
\q1 
\v 14 Egu bese Israel taudia baina hanamodia lou,
\q2 e heḡiḡi dobi hanuadia bae haginidia lou,
\q2 bena bae noholaidia;
\q1 vine imeadia bae hado, bena edia vine ranuna bae inua,
\q2 uma bae kara, bena anidia bae ani.
\q1 
\v 15 Edia tano ai baina hanohodia,
\q2 bona vada na henidia tanona amo
\q1 idia na nega ta ai basie heabi oho lou.
\q2 Iehova, emui Dirava, na e herevamu. 
