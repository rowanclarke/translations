\v 16 \w Y|strong="H3068"\w* \w David|strong="H1732"\w* \w le|strong="H5921"\w* dijo: Tu \w sangre|strong="H1818"\w* sea \w sobre|strong="H5921"\w* tu \w cabeza|strong="H7218"\w*, \w pues|strong="H3588"\w* \w que|strong="H3588"\w* tu \w boca|strong="H6310"\w* \w atestiguó|strong="H6030"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, diciendo: \w Yo|strong="H3588"\w* \w maté|strong="H4191"\w* \w al|strong="H5921"\w* \w ungido|strong="H4899"\w* \w del|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*.   
