\p
\v 17 \w Remember|strong="G2192"\w* \w that|strong="G1487"\w* \w I|strong="G1473"\w*’m \w your|strong="G2192"\w* friend, \w and|strong="G3767"\w* \w we|strong="G1487"\w* \w do|strong="G2192"\w* \w things|strong="G1487"\w* together. \w If|strong="G1487"\w* \w you|strong="G1487"\w* reckon \w I|strong="G1473"\w*’m \w your|strong="G2192"\w* friend, \w be|strong="G2192"\w* happy \w to|strong="G2192"\w* see Onesimus \w when|strong="G5613"\w* \w he|strong="G5613"\w* comes back \w to|strong="G2192"\w* \w you|strong="G1487"\w*, \w and|strong="G3767"\w* \w be|strong="G2192"\w* good \w to|strong="G2192"\w* \w him|strong="G4355"\w*, \w just|strong="G5613"\w* \w like|strong="G5613"\w* \w you|strong="G1487"\w* \w are|strong="G2192"\w* happy \w to|strong="G2192"\w* see \w me|strong="G1473"\w*, \w and|strong="G3767"\w* \w you|strong="G1487"\w* \w are|strong="G2192"\w* good \w to|strong="G2192"\w* \w me|strong="G1473"\w* \w whenever|strong="G5613"\w* \w I|strong="G1473"\w* visit \w you|strong="G1487"\w*.  
