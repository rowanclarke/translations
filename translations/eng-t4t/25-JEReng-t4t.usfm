\s1 Yahweh said what would happen to the people of Judah  
\p
\v 1 \w Then|strong="H3318"\w* \w Yahweh|strong="H3068"\w* \w said|strong="H3318"\w* \add this\add* \w to|strong="H3318"\w* \w me|strong="H6440"\w*: “\w Even|strong="H3068"\w* if \w Moses|strong="H4872"\w* \w and|strong="H4872"\w* \w Samuel|strong="H8050"\w* \w could|strong="H2088"\w* \add come back from their graves and\add* \w and|strong="H4872"\w* \w stand|strong="H5975"\w* \w in|strong="H5921"\w* \w front|strong="H6440"\w* \w of|strong="H3068"\w* \w me|strong="H6440"\w* \add and plead with me for these Israeli people\add*, \w I|strong="H5921"\w* \w would|strong="H3068"\w* \w not|strong="H2088"\w* \w act|strong="H5975"\w* mercifully [IDM] \w toward|strong="H5921"\w* \w these|strong="H2088"\w* \w people|strong="H5971"\w*. \add I would tell you\add*, ‘\w Send|strong="H7971"\w* \w them|strong="H5921"\w* \w away|strong="H7971"\w* \w from|strong="H3318"\w* \w me|strong="H6440"\w*. \w Cause|strong="H5971"\w* \w them|strong="H5921"\w* \w to|strong="H3318"\w* \w leave|strong="H3318"\w* \w me|strong="H6440"\w*!’  
\v 2 \w And|strong="H3068"\w* \w if|strong="H3588"\w* \w they|strong="H3588"\w* ask \w you|strong="H3588"\w*, ‘Where \w shall|strong="H3068"\w* \w we|strong="H3068"\w* \w go|strong="H3318"\w*?’, tell \w them|strong="H3318"\w*, ‘\w This|strong="H3541"\w* \w is|strong="H3068"\w* \w what|strong="H3541"\w* \w Yahweh|strong="H3068"\w* \w says|strong="H3541"\w*:  
\q1 \w The|strong="H3588"\w* ones \w that|strong="H3588"\w* \w I|strong="H3588"\w* say must \w die|strong="H4194"\w*, \w will|strong="H3068"\w* \w die|strong="H4194"\w*:  
\q1 \w The|strong="H3588"\w* ones \w that|strong="H3588"\w* \w I|strong="H3588"\w* say must \w die|strong="H4194"\w* \w in|strong="H3068"\w* \w wars|strong="H2719"\w* [MTY], \w will|strong="H3068"\w* \w die|strong="H4194"\w* \w in|strong="H3068"\w* \w wars|strong="H2719"\w*.  
\q1 \w The|strong="H3588"\w* ones \w that|strong="H3588"\w* \w I|strong="H3588"\w* say must \w die|strong="H4194"\w* \w from|strong="H3318"\w* \w hunger|strong="H7458"\w*, \w will|strong="H3068"\w* \w die|strong="H4194"\w* \w from|strong="H3318"\w* \w hunger|strong="H7458"\w*.  
\q1 \w The|strong="H3588"\w* ones \w that|strong="H3588"\w* \w I|strong="H3588"\w* say must \w be|strong="H1961"\w* \w captured|strong="H7628"\w* \add and taken to other countries\add*, \w will|strong="H3068"\w* \w be|strong="H1961"\w* \w captured|strong="H7628"\w* \add and taken to other countries\add*.   
\p
\v 3 \w I|strong="H5921"\w* \w will|strong="H3068"\w* send four things \w that|strong="H3068"\w* \w will|strong="H3068"\w* get rid \w of|strong="H3068"\w* \w them|strong="H5921"\w*: \w I|strong="H5921"\w* \w will|strong="H3068"\w* send \add enemy soldiers using\add* \w swords|strong="H2719"\w* \w to|strong="H3068"\w* \w kill|strong="H2026"\w* \w them|strong="H5921"\w*. \w I|strong="H5921"\w* \w will|strong="H3068"\w* send wild \w dogs|strong="H3611"\w* \w to|strong="H3068"\w* \w drag|strong="H5498"\w* away \add their corpses\add*. \w I|strong="H5921"\w* \w will|strong="H3068"\w* send vultures \w to|strong="H3068"\w* eat \add their corpses\add*. \w And|strong="H3068"\w* \w I|strong="H5921"\w* \w will|strong="H3068"\w* send \add other\add* wild animals \w to|strong="H3068"\w* eat \w what|strong="H5921"\w* remains \add of their corpses\add*.  
\v 4 \w Because|strong="H5921"\w* \w of|strong="H1121"\w* \add the wicked things that\add* \w King|strong="H4428"\w* \w Manasseh|strong="H4519"\w* \w did|strong="H6213"\w* \w in|strong="H5921"\w* \w Jerusalem|strong="H3389"\w*, \w I|strong="H5414"\w* \w will|strong="H4428"\w* \w cause|strong="H5414"\w* \add people in\add* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w kingdoms|strong="H4467"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* earth \w to|strong="H5921"\w* \w be|strong="H1121"\w* \w horrified|strong="H2113"\w* \w about|strong="H5921"\w* \add what will happen in Judah to\add* \w my|strong="H5414"\w* \w people|strong="H1121"\w*.   
\q1
\v 5 \w You|strong="H3588"\w* \add people of \add*\w Jerusalem|strong="H3389"\w*, \w no|strong="H4310"\w* \w one|strong="H3588"\w* \w will|strong="H4310"\w* [RHQ] feel \w sorry|strong="H5110"\w* \w for|strong="H3588"\w* \w you|strong="H3588"\w*.  
\q2 \w No|strong="H4310"\w* \w one|strong="H3588"\w* \w will|strong="H4310"\w* [RHQ] weep/cry \w for|strong="H3588"\w* \w you|strong="H3588"\w*.  
\q2 \w No|strong="H4310"\w* \w one|strong="H3588"\w* \w will|strong="H4310"\w* [RHQ] \w ask|strong="H7592"\w* ◄\w how|strong="H3588"\w* \w you|strong="H3588"\w* \w are|strong="H4310"\w*/\w if|strong="H3588"\w* \w you|strong="H3588"\w* \w are|strong="H4310"\w* \w well|strong="H7965"\w*►.   
\q1
\v 6 \w You|strong="H5921"\w* people \w have|strong="H3068"\w* \w abandoned|strong="H5203"\w* \w me|strong="H5921"\w*;  
\q2 \w you|strong="H5921"\w* \w have|strong="H3068"\w* continued \w to|strong="H3068"\w* \w walk|strong="H3212"\w* \w away|strong="H3212"\w* \add from me\add* [DOU].  
\q1 \w So|strong="H3027"\w*, \w I|strong="H5921"\w* \w will|strong="H3068"\w* \w lift|strong="H3068"\w* \w up|strong="H5921"\w* \w my|strong="H3068"\w* \w fist|strong="H3027"\w* \w to|strong="H3068"\w* smash \w you|strong="H5921"\w*;  
\q2 \w I|strong="H5921"\w* \w will|strong="H3068"\w* \w not|strong="H3212"\w* \w act|strong="H7843"\w* mercifully \w toward|strong="H5921"\w* \w you|strong="H5921"\w* \w any|strong="H7843"\w* longer.   
\q1
\v 7 \w At|strong="H7725"\w* \w the|strong="H7725"\w* \w gates|strong="H8179"\w* \w of|strong="H1870"\w* \w your|strong="H7725"\w* \w cities|strong="H8179"\w*, \w I|strong="H3808"\w* \w will|strong="H5971"\w* \add scatter you like a farmer scatters the chaff from his grain by\add* ◄\w winnowing|strong="H2219"\w* \w it|strong="H7725"\w*/throwing \w it|strong="H7725"\w* \w up|strong="H7725"\w* \w to|strong="H7725"\w* allow \w the|strong="H7725"\w* wind \w to|strong="H7725"\w* blow \w the|strong="H7725"\w* chaff \w away|strong="H7725"\w*► [MET].  
\q2 \w You|strong="H7725"\w*, \w my|strong="H7725"\w* \w people|strong="H5971"\w*, \w have|strong="H5971"\w* \w refused|strong="H3808"\w* \w to|strong="H7725"\w* \w turn|strong="H7725"\w* \w away|strong="H7725"\w* \w from|strong="H7725"\w* \w your|strong="H7725"\w* evil \w behavior|strong="H1870"\w*.  
\q1 \add So\add*, \w I|strong="H3808"\w* \w will|strong="H5971"\w* \w get|strong="H7725"\w* rid \w of|strong="H1870"\w* \w you|strong="H7725"\w*,  
\q2 \w and|strong="H7725"\w* \w I|strong="H3808"\w* \w will|strong="H5971"\w* \w even|strong="H3808"\w* \w cause|strong="H5971"\w* \w your|strong="H7725"\w* \w children|strong="H7921"\w* \w to|strong="H7725"\w* \w be|strong="H3808"\w* killed.   
\q1
\v 8 \w I|strong="H5921"\w* \w will|strong="H5892"\w* cause \w there|strong="H1992"\w* \w to|strong="H5921"\w* \w be|strong="H5892"\w* \w more|strong="H6105"\w* widows \add in Judah\add*  
\q2 \w than|strong="H5921"\w* \add there are grains of\add* \w sand|strong="H2344"\w* \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w seashore|strong="H3220"\w* [HYP].  
\q1 \w At|strong="H5921"\w* noontime, \add when people will not be expecting it to happen\add*, \w I|strong="H5921"\w* \w will|strong="H5892"\w* cause \add an enemy army\add* \w to|strong="H5921"\w* \w attack|strong="H7703"\w* \w you|strong="H5921"\w*,  
\q2 \w an|strong="H5307"\w* army \w that|strong="H5892"\w* \w will|strong="H5892"\w* \w destroy|strong="H7703"\w* \w your|strong="H5921"\w* young \w men|strong="H3220"\w* \w and|strong="H5892"\w* cause \w their|strong="H1992"\w* mothers \w to|strong="H5921"\w* weep.  
\q1 \w I|strong="H5921"\w* \w will|strong="H5892"\w* cause \w you|strong="H5921"\w* \w to|strong="H5921"\w* \w suddenly|strong="H6597"\w* experience \w great|strong="H6105"\w* suffering/pain \w and|strong="H5892"\w* become \w very|strong="H1992"\w* terrified.   
\q1
\v 9 \w A|strong="H3068"\w* \w woman|strong="H3205"\w* \w who|strong="H3068"\w* \w has|strong="H3068"\w* \w seven|strong="H7651"\w* \w children|strong="H3205"\w* \w will|strong="H3068"\w* \w become|strong="H3205"\w* faint \w and|strong="H3068"\w* ◄gasp \w for|strong="H6440"\w* \w breath|strong="H5315"\w*/\w be|strong="H5750"\w* hardly able \w to|strong="H3068"\w* \w breathe|strong="H5301"\w*►;  
\q2 \add it will be as though\add* \w daylight|strong="H8121"\w* \w will|strong="H3068"\w* \w become|strong="H3205"\w* darkness \w for|strong="H6440"\w* \w her|strong="H5414"\w*,  
\q1 \add because most of\add* \w her|strong="H5414"\w* \w children|strong="H3205"\w* \w will|strong="H3068"\w* \w be|strong="H5750"\w* \w dead|strong="H5315"\w*,  
\q2 \w and|strong="H3068"\w* \w she|strong="H6440"\w* \w will|strong="H3068"\w* \w be|strong="H5750"\w* \w disgraced|strong="H2659"\w* \w and|strong="H3068"\w* \w humiliated|strong="H2659"\w* [DOU].  
\q1 \w And|strong="H3068"\w* \w her|strong="H5414"\w* \w children|strong="H3205"\w* \w who|strong="H3068"\w* \w are|strong="H3068"\w* \w still|strong="H5750"\w* \w alive|strong="H5315"\w*, \w I|strong="H5414"\w* \w will|strong="H3068"\w* enable \w your|strong="H3068"\w* enemies \w to|strong="H3068"\w* \w kill|strong="H2719"\w* \w them|strong="H5414"\w*.  
\q2 \add That will surely happen because I\add*, \w Yahweh|strong="H3068"\w*, \w have|strong="H3068"\w* \w said|strong="H5002"\w* \w it|strong="H5414"\w*.’ ”   
\s1 Jeremiah’s complaint and Yahweh’s reply  
\p
\v 10  \add I said to\add* \w my|strong="H3605"\w* mother, “\w I|strong="H3588"\w* am very sad;  
\q1 \w I|strong="H3588"\w* wish \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w had|strong="H3205"\w* \w not|strong="H3808"\w* \w given|strong="H3205"\w* \w birth|strong="H3205"\w* \w to|strong="H3205"\w* \w me|strong="H3205"\w*;  
\q2 \w everyone|strong="H3605"\w* \w in|strong="H3808"\w* \w this|strong="H3588"\w* land opposes \w me|strong="H3205"\w* \w and|strong="H7379"\w* \w quarrels|strong="H7379"\w* \w with|strong="H3605"\w* \w me|strong="H3205"\w*.  
\q1 \w I|strong="H3588"\w* am \w not|strong="H3808"\w* \w a|strong="H3068"\w* person \w who|strong="H3605"\w* lends \add money to people and threatens to sue/harm them if they do not pay me back when they should\add*,  
\q2 \w and|strong="H7379"\w* \w I|strong="H3588"\w* am \w not|strong="H3808"\w* \w a|strong="H3068"\w* person \w who|strong="H3605"\w* borrows \add money from others and then refuses to pay it back\add*,  
\q1 \w but|strong="H3588"\w* \w everyone|strong="H3605"\w* [HYP] \w curses|strong="H7043"\w* \w me|strong="H3205"\w*.”   
\p
\v 11 \w But|strong="H3808"\w* \w Yahweh|strong="H3068"\w* replied \w to|strong="H3068"\w* \w me|strong="H3808"\w*,  
\q1 “\add Jeremiah\add*, \w I|strong="H6256"\w* \w will|strong="H3068"\w* take care \w of|strong="H3068"\w* \w you|strong="H3808"\w*.  
\q1 \w And|strong="H3068"\w* \w at|strong="H3068"\w* \w times|strong="H6256"\w* \w when|strong="H6256"\w* \w your|strong="H3068"\w* enemies \w have|strong="H3068"\w* \w troubles|strong="H6869"\w* \w and|strong="H3068"\w* \w disasters|strong="H7451"\w*,  
\q2 \w they|strong="H3068"\w* \w will|strong="H3068"\w* \add come to you and\add* \w plead|strong="H6293"\w* \w for|strong="H3068"\w* \w you|strong="H3808"\w* \add to help them\add*.”   
\q1
\v 12  \add Yahweh also told me to say to the people\add* \w of|strong="H6828"\w* Judah,  
\q1 “Your enemies, \w who|strong="H7489"\w* \w are|strong="H1270"\w* \add as strong as\add* \w iron|strong="H1270"\w* \w or|strong="H7489"\w* \w bronze|strong="H5178"\w*, \add will attack you\add* from \w the|strong="H7489"\w* \w north|strong="H6828"\w*;  
\q2 no one \w will|strong="H6828"\w* \w be|strong="H1270"\w* able \w to|strong="H5178"\w* stop \w them|strong="H1270"\w*.   
\q1
\v 13 \w I|strong="H5414"\w* \w will|strong="H5414"\w* \w give|strong="H5414"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* valuable possessions \add of the people of Judah\add* \w to|strong="H5414"\w* \w their|strong="H3605"\w* enemies,  
\q2 \w without|strong="H3808"\w* \w them|strong="H5414"\w* paying \w for|strong="H3605"\w* \w it|strong="H5414"\w*.  
\q1 \w Their|strong="H3605"\w* valuable possessions \w will|strong="H5414"\w* \w be|strong="H3808"\w* \w the|strong="H3605"\w* \w payment|strong="H4242"\w*/reward \add that I will give them\add*  
\q2 \w because|strong="H3605"\w* \w of|strong="H1366"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w sins|strong="H2403"\w* \w that|strong="H3605"\w* \w you|strong="H5414"\w* \w have|strong="H5414"\w* \w committed|strong="H5414"\w* \w throughout|strong="H3605"\w* \w your|strong="H3605"\w* country.   
\q1
\v 14 \w I|strong="H3588"\w* \w will|strong="H3808"\w* \w tell|strong="H3045"\w* \w your|strong="H5921"\w* enemies \w to|strong="H5921"\w* force \w you|strong="H3588"\w* \w to|strong="H5921"\w* become \w their|strong="H5921"\w* prisoners,  
\q2 \w and|strong="H3045"\w* \w to|strong="H5921"\w* \w take|strong="H5674"\w* \w you|strong="H3588"\w* \w to|strong="H5921"\w* other lands \w that|strong="H3588"\w* \w you|strong="H3588"\w* do \w not|strong="H3808"\w* \add even\add* \w know|strong="H3045"\w* \w about|strong="H5921"\w*,  
\q2 \w and|strong="H3045"\w* force \w you|strong="H3588"\w* \w to|strong="H5921"\w* become \w their|strong="H5921"\w* slaves.  
\q1 \add That will happen\add* \w because|strong="H3588"\w* \w I|strong="H3588"\w* am extremely \w angry|strong="H5674"\w* \add with you\add*;  
\q2 \w my|strong="H5921"\w* being \w angry|strong="H5674"\w* \w is|strong="H3808"\w* \add like\add* [SIM] \w a|strong="H3068"\w* fire \w that|strong="H3588"\w* \w will|strong="H3808"\w* \w burn|strong="H3344"\w* forever.”   
\s1 Another complaint by Jeremiah, and Yahweh’s reply  
\q1
\v 15  \add Then I said\add*, “\w Yahweh|strong="H3068"\w*, \w you|strong="H5921"\w* \w know|strong="H3045"\w* \add what is happening to me\add*.  
\q2 \add Please\add* \w come|strong="H3045"\w* \w and|strong="H3068"\w* ◄\w help|strong="H5375"\w* \w me|strong="H5921"\w*/\w take|strong="H3947"\w* \w care|strong="H6485"\w* \w of|strong="H3068"\w* \w me|strong="H5921"\w*►.  
\q2 \w Punish|strong="H6485"\w* \w those|strong="H5921"\w* \w who|strong="H3068"\w* \w are|strong="H3068"\w* ◄persecuting \w me|strong="H5921"\w*/causing \w me|strong="H5921"\w* \w to|strong="H3068"\w* \w suffer|strong="H5375"\w*►.  
\q1 \add Please\add* \w do|strong="H3068"\w* \w not|strong="H3045"\w* continue \w to|strong="H3068"\w* \w be|strong="H3068"\w* patient \w with|strong="H3068"\w* \w them|strong="H5921"\w*  
\q2 \w and|strong="H3068"\w* \w do|strong="H3068"\w* \w not|strong="H3045"\w* allow \w me|strong="H5921"\w* \w to|strong="H3068"\w* die \w now|strong="H3947"\w*.  
\q1 \w It|strong="H5921"\w* \w is|strong="H3068"\w* ◄\w for|strong="H5921"\w* \w your|strong="H3068"\w* \w sake|strong="H5921"\w*/\w because|strong="H5921"\w* \w I|strong="H5921"\w* serve \w you|strong="H5921"\w*► \w that|strong="H3045"\w* \w I|strong="H5921"\w* \w am|strong="H3068"\w* suffering.   
\q1
\v 16 \w Yahweh|strong="H3068"\w* \w my|strong="H3068"\w* \w God|strong="H3068"\w*, \w you|strong="H3588"\w* \w are|strong="H1697"\w* \w the|strong="H5921"\w* Commander \w of|strong="H3068"\w* \w the|strong="H5921"\w* \w armies|strong="H6635"\w* \w of|strong="H3068"\w* angels;  
\q1 \w and|strong="H3068"\w* \w when|strong="H3588"\w* \w you|strong="H3588"\w* \w spoke|strong="H1697"\w* \w to|strong="H3068"\w* \w me|strong="H5921"\w*,  
\q2 \w I|strong="H3588"\w* \w was|strong="H3068"\w* delighted \w with|strong="H3068"\w* \w your|strong="H3068"\w* \w message|strong="H1697"\w*; \w it|strong="H7121"\w* \w caused|strong="H1961"\w* \w me|strong="H5921"\w* \w to|strong="H3068"\w* \w be|strong="H1961"\w* \w joyful|strong="H8342"\w*,  
\q1 \w and|strong="H3068"\w* \w I|strong="H3588"\w* eagerly accepted [\w MET|strong="H4672"\w*] \w what|strong="H1697"\w* \w you|strong="H3588"\w* \w said|strong="H1697"\w*  
\q2 \w because|strong="H3588"\w* \w I|strong="H3588"\w* \w belong|strong="H1961"\w* \w to|strong="H3068"\w* \w you|strong="H3588"\w*. [IDM, MTY]   
\q1
\v 17 \w When|strong="H3588"\w* \w the|strong="H6440"\w* \w people|strong="H3427"\w* \w were|strong="H3027"\w* carousing \w together|strong="H4390"\w*,  
\q2 \w I|strong="H3588"\w* \w never|strong="H3808"\w* joined \w them|strong="H6440"\w*;  
\q1 \w I|strong="H3588"\w* \w sat|strong="H3427"\w* alone, \w because|strong="H3588"\w* \w you|strong="H3588"\w* [MTY] \w are|strong="H3027"\w* \w the|strong="H6440"\w* \w one|strong="H3808"\w* \w who|strong="H3427"\w* controls \w what|strong="H3588"\w* \w I|strong="H3588"\w* \w do|strong="H3027"\w*.  
\q2 \w I|strong="H3588"\w* \w was|strong="H3027"\w* very angry \add with those people because of their sins\add*.   
\q1
\v 18 \w So|strong="H1961"\w*, ◄\w why|strong="H4100"\w* \w do|strong="H4100"\w* \w you|strong="H3808"\w* \add allow\add* \w me|strong="H1961"\w* \w to|strong="H1961"\w* \w continue|strong="H1961"\w* \w to|strong="H1961"\w* \w suffer|strong="H1961"\w*?/\w I|strong="H4100"\w* \w do|strong="H4100"\w* \w not|strong="H3808"\w* understand \w why|strong="H4100"\w* \w you|strong="H3808"\w* allow \w me|strong="H1961"\w* \w to|strong="H1961"\w* \w continue|strong="H1961"\w* \w to|strong="H1961"\w* \w suffer|strong="H1961"\w*.► [RHQ]  
\q2 \w It|strong="H1961"\w* seems \w that|strong="H4325"\w* [RHQ] \w my|strong="H1961"\w* \w wounds|strong="H4347"\w* \w cannot|strong="H3808"\w* \w be|strong="H1961"\w* \w healed|strong="H7495"\w*.  
