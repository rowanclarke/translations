\id GAL Ika New Testament 2009 
\h Ndị Galeshịa 
\toc1 Ẹhụhụọ-Ozi Pọlụ Dejẹnni Ndị Galeshịa 
\toc2 Ndị Galeshịa 
\toc3 Gal 
\mt2 Ẹhụhụọ-Ozi Pọlụ Dejẹnni 
\mt1 Ndị Galeshịa 
\c 1  
\cl Isi Nke Ohu 
\p  
\v 1 Mmẹ wụ Pọlụ de ẹkụkwọ-ozini. M wụ onyẹ-ozi pụ-ichẹn—ẹlẹ hụn ịhịan zi mọbụ hụn ndị-ọkịkị wụ ịhịan tumẹ—kanị hụn Jesu Kristi lẹ Chuku-Nẹdi hụn gha imẹ ọnwụn weli Jesu Kristi tumẹ.  
\v 2 Mmẹ lẹ umunẹ ẹnyi imẹ Kraịstị ndị mmẹ lẹ wẹ rị ebeni gba de ẹ. Ẹnyi dejẹnni ụka rị ichẹn-ichẹn rịsọnmẹ Azụụn Galeshịa ya. 
\p  
\v 3 Ẹfọma lẹ udọn hụn gha ẹka Osolobuẹ Nẹdi ẹnyi lẹ Di-nwọnni-ẹnyi wụ Jesu Kristi bịa ya rịnị ọnụ. 
\p  
\v 4 Nna ẹnyi wụ Jizọs' Kraịstị we ndụn a ye makẹ ifiri njọ ẹnyi, kẹni ọ gbapụha ẹnyi imẹ eje-agbọnị rị ogẹnni, igi mẹzu uche Osolobuẹ ẹnyi wụ Nẹdi ẹnyi.  
\v 5 Ọghọ ya rịnị Osolobuẹ Nẹdi ẹnyi jẹnrin ejẹn! Isẹẹ. 
\s1 Oziọma Ọzọ Arịa 
\p  
\v 6 Ọ tụ m ẹnya nị ụnụ a latọmakẹnrinkẹzi onyẹ hụn gi ifiri ẹfọma Kraịstị kpọ ụnụ, nabanhanma “oziọma ọzọ”.  
\v 7 Ẹlẹ ni oziọma ọzọ rị arị, kanị o nwọnghọ ndị rị e ye ụnụ nsọngbu, e mẹ obi eruzilẹ ụnụ alị, a chọ nị wẹ rụkpọ oziọma Kraịstị.  
\v 8 Kanị, ọsụọn'a nị ẹnyi lẹ enwẹn ẹnyi mọbụ mmọn-ozi ghadẹ enu-igwee bịa e zimẹ ụnụ “oziọma” ọzọ hụn wụlẹni hụn ẹnyi zi ụnụ, onyẹ ahụn ya wụrụ onyẹ wẹ bụ ọnụ—ya la ntikpọ jẹnrin ejẹn!  
\v 9 Kẹ ẹnyi dọn ku mbụ, m rịzị nwan e ku ẹ: omẹni onyẹ ọwụlẹ rị e zi ọnụ “oziọma” ọzọ wụlẹni hụn ọnụ nabanhangụụ mbụ, ya wụrụ onyẹ wẹ bụ ọnụ: ya la ntikpọ jẹnrin ejẹn! 
\s1 Jesu Tumẹ M, Ẹlẹ Ịhịan 
\p  
\v 10 M rịdẹ nwan a chọ nị ịhịan kuni m ọhụnma ra Osolobuẹ? Ra a chọmagụọ m nwan nị m mẹ n'ọ sụọ ịhịan? Omẹni echẹn kẹ m rịkwọ a chọ nị m mẹ n'ọ sụọ ịhịan, ya wụ nị ẹlẹ m igbọn Kraịstị. 
\p  
\v 11 Umunẹ m, m chọ nị ụnụ marịn nị oziọma m zi aghanị ẹka ịhịan bịa;  
\v 12 amụnnarịnnị m ịhịan ya; ẹlẹ ịhịan kuzi m'ẹ. Kama, Jesu Kristi lẹ enwẹn ẹ we ẹ ghọsị m. 
\p  
\v 13 W'a ra rụ ụka a, ụnụ a nụgụọ kẹ m dọn bi mbụ, ogẹn m gi rị e fe ofufe ndị-Ju lẹ nke Iwu Mozizi: kẹ m dọn kpokpokẹnmẹ ụka Osolobuẹ, chọ nị m tikpọ a.  
\v 14 Imẹ ofufe ẹnyi wụ ndị Ju, mmẹ ka ndị isi-otu m bu ọda ofufe e fe ogẹn ahụn. M'e mẹkẹnmẹ oku omẹnalị ndị nẹdi ẹnyi wẹ. 
\p  
\v 15 Kanị, ogẹn o gi sụọ Osolobuẹ, hụn gi ẹfọma a họtọ m, kpọ m—kẹ m rịdẹ ẹfọ nnẹ m,  
\v 16 ọ nọ mẹ m marịn Nwa a, kẹni m zi ndị anị ndị ọzọ wụlẹni ndị Ju ozi banyeni ya wụ Nwa a. Ogẹn o gi mẹ ẹ, ejẹnni m d'e kunrun ịhịan n'ọ gwa m ihiẹn ọwụlẹ mọbụ buche ni m ihiẹn ọwụlẹ.  
\v 17 Ejẹndẹni m Jerusalẹm d'e kunrun ndị bu m ụzọ wụrụ ndị-ozi pụ-ichẹn, kama, m nọ shi Arebịa ozigbo. O mẹgụụ, m nọ gha ebẹhụ kinhẹnzi Damas'kọsị.  
\v 18 Ahụa ẹtọ a ghafegụụ, m nọ shi Jerusalẹm d'a hụn Kẹfasị wụ Pita; m nọ sọn ẹ nọdị akp'ọhịn mmisẹn.  
\v 19 O nwọnni onyẹ ọzọ m hụn imẹ ndị-ozi pụ-ichẹn họdụnị, wezụka Jemisi nwẹnẹ Di-nwọnni-ẹnyi. 
\p  
\v 20 M rị a gwa ụnụ, id'ẹnya Osolobuẹ, nị ihiẹnni m rị e de ni ụnụ wụ ezioku, ẹlẹ ntụ! 
\p  
\v 21 Omẹgụụ, m nọ jẹn Azụụn Siria lẹ Silisia.  
\v 22 Ndị ụka Kraịstị hụn rịsọnmẹ ẹgbẹrẹ Judia e ke marịn m ọmarịn-ẹnya ogẹn ahụn.  
\v 23 Wẹ nụ a hụ a nụ nị wẹ sị nị “Onyẹ ahụn te rị e kpokponi ẹnyi mbụ rịzị nwan e zisọnmẹ ozi okukwe ahụn o te chọ n'o tikpọ!”  
\v 24 Wẹ nọ gi ifiri m ja ẹfan Osolobuẹ mma. 
\c 2  
\cl Isi Nke Ẹbụọ 
\s1 Pita, Jemisi lẹ Jọnụ Nabanhan Pọlụ Anabanhan 
\p  
\v 1 O mẹpụ ahụa mmẹnọ, m nọ shizi Jerusalẹm. Mmẹ lẹ Banabasị wị ogẹn ahụn, m nọzị weri Taitọsị.  
\v 2 M jẹn ebẹhụ makẹni o nwọn ihiẹn Osolobuẹ ghọsị m; m nọ kọwa nị wẹ oziọma hụn m rị e zi ebe ndị wụlẹni ndị Ju rị. Kanị m mẹ ẹ ụsụọ—ẹgbata mmẹ lẹ ndị wẹ weri nị wẹ wụ ndị-isi sụọ—amamgbe ọ wụrụ nị m rị a gba ọsọ ọlal'iwi mọbụ nị hụn m gbafụ a lagụọ iwi, ọ wụrụ nị ọrụn m la iwi.  
\v 3 Awadẹni wẹ ịkwa-ugun ye Taitọsị mmẹ lẹ ịya wị olu, ọsụọn'a nị ẹlẹ onyẹ Ju, nị onyẹ Griki rọ—  
\v 4 kanị oku ịkwa a ugun e te pụhaghọ makẹ ndị hụn gi nzuzue rụbanhan, e mẹ kẹ sị wẹ wụ ndị kwerini. Wẹ bịa d'a hụndẹle ụdị inwọnrin-enwẹn hụ ẹnyi nwọn imẹ Kraịstị, kẹni wẹ wezi ẹnyi che imẹ igbọn.  
\v 5 Kanị, ẹnyi ekweyeni ni wẹ kaka akpụ-ohu, makẹni ẹnyi chọkẹnmẹ nị ẹnyi chedọn ni ụnụ ezioku rị oziọma, kẹni ụnụ marịn a k'ọ rịchanrịn. 
\p  
\v 6 Nke ndị hụn nọ kẹ sị wẹ wụ ndị-ndu—o nwọnni ihiẹn ọhụn wẹ buche ni m. (Ihiẹn ọwụlẹ wẹ wụ enwọn ihiẹn ọ wụ ebe m rị, makẹni Osolobuẹ ara gbeyeni ịhịan.)  
\v 7 Mba. Kama, o wedẹ wẹ ẹnya nị Osolobuẹ e yegụọ m ọrụn ịgbashịa oziọma ebe ndị kwalẹni ugun rị, ya wụ ndị alị ndị ọzọ wụlẹni ndị Ju, k'o dọn ye Pita ọrụn ịgbashịa n'a ebe ndị kwa ugun rị, ya wụ ndị Ju.  
\v 8 (Makẹni onyẹ ohu hụ gi Pita a rụn ọrụn onyẹ-ozi pụ-ichẹn imẹ igunrun ndị Ju, ndị kwa ugun, ịya gizikwọ mmẹ nwẹn a rụn ọrụn onyẹ-ozi pụ-ichẹn imẹ igunrun ndị wụlẹni ndị Ju, ya wụ ndị kwalẹni ugun.)  
\v 9 Ogẹn Jemisi lẹ Pita lẹ Jọnụ, ndị hụn wẹ weri nọkẹ ndị-isi, gi hụn nị ẹka Osolobuẹ rị imẹ m, wẹ nọ na mmẹ lẹ Banabasị ẹka, nabanhan ẹnyi, nị ẹnyi lẹ wẹ wụ ohu. Wẹ nọ kweri n'ọ hụghọ mma nị mmẹ lẹ Banabasị jẹnmẹ d'a rụnma imẹ ndị wụlẹni ndị Ju, ya wụ ndị kwalẹni ugun, uwẹ lẹ enwẹn wẹ a rụnma imẹ ndị Ju, ya wụ ndị kwa ugun.  
\v 10 Ihiẹn ohu sụọ kẹ wẹ sịhụ ẹnyi mẹ: ẹnyi a nyanhankwọ ndị-igbẹnnyẹ, hụn a dụzịkwọnị m. 
\s1 Pọlụ A Jụgbọ Pita Imẹ Antịọkụ 
\p  
\v 11 Kanị, ogẹn Kẹfasị wụ Pita gi bịa Antịọkụ, m jụgbọ a elee-m, elee-i, makẹni o mẹfie hụn wẹ hụn ẹnya ogẹn ahụn.  
\v 12 Makẹni, kẹ ndị ahụn Jemisi zihẹ kelẹni bịa ebẹhụ, Pita e sọn ndị wụlẹni ndị Ju e ri ihiẹn-oriri. Kanị, ogẹn ndịnị gi bịagụụ, Pita nọ nọye nkọ, o duzini ndị wụlẹni ndị Ju ri, makẹni ọ rị a tụ egun ndị rị itu ndị hụn a kwadọn ịkwa-ugun.  
\v 13 Ndị Ju ndị ọzọ rị ebẹhụ nọ sọn ẹ mẹmẹ ihunnaị ahụn, nke wụ nị e dufiedẹ wẹ Banabasị lẹ enwẹn ẹ.  
\v 14 Ogẹn m gi hụn a nị ihiẹn wẹ rị e mẹ lẹ ezioku rị oziọma a dangbamanị, m nọ nọ id'ẹnya wẹ ile sị Pita, “Onyẹ Ju kẹ ị wụ, kanị ị rị e bi kẹ ndị wụlẹni ndị Ju, y'a ra bi kẹ ndị Ju. Nanị kẹ i dọnzị nwan a chọ nị ị wa obibi ndị Ju ye ndị wụlẹni ndị Ju olu?” 
\s1 Okukwe Sụọ 
\p  
\v 15 M nọzị sị Pita, “Nke ẹnyi lẹ enwẹn ẹnyi, ndị Ju mụ ẹnyi, ẹnyi ẹlẹ ndị hụn w'a kpọ ‘ndị wụlẹni ndị Ju, ndị omẹ-njọ.’ 
\p  
\v 16 Bụ ẹnyi a marịnghọ nị ẹlẹ idọnmẹ Iwu kẹ Osolobuẹ gi e kuni ịhịan ọhụnma, kanị ikwerini Jesu Kristi, gi ẹ e dọn ẹnya. Ifiri ẹ, ẹnyi lẹ enwẹn ẹnyi e kwerigụọ nị Jesu Kristi, kẹni Osolobuẹ kuni ẹnyi ọhụnma, makẹni ẹnyi kwerini Kraịstị, gi Kraịstị e dọn ẹnya, ẹlẹ makẹni ẹnyi e dọnmẹ Iwu Mozizi. Makẹni, Osolobuẹ ekukọnị onyẹ ọwụlẹ ọhụnma makẹni onyẹ ahụn e dọnmẹ Iwu.  
\v 17 Kanị, o mẹ nwan nị, ebe ẹnyi nọ rị a chọ nị Osolobuẹ kuni ẹnyi ọhụnma makẹni ẹnyi rị imẹ Kraịstị, a hụn w'a nị ẹnyi lẹ enwẹn ẹnyi wụ ndị njọ, ya wụ Kraịstị a kwadọn njọ? Kaka!  
\v 18 O mẹ nwan nị a tụndọnzimẹ m ihiẹn m tikpọ, ya wụ m rị a ghọsị nị m dan Iwu ogẹn m gi tikpọ a.  
\v 19 Ẹghẹẹ, makẹni, e gigụọ m ihiẹn rị imẹ Iwu nwụnnahịn Iwu, kẹni m hụn ụzọ rịnị Osolobuẹ ndụn.  
\v 20 A kpọgbugụọ wẹ mmẹ lẹ Kraịstị enu obe Kraịstị. Ẹlẹzị mmẹ rị ndụn, Kraịstị ya rị ndụn imẹ m. Ndụnnị m rị nwan e bi imẹ ẹhụ, m rị e bi ẹ ghahanị okukwe m nwẹ imẹ Nwa Osolobuẹ, hụn nwẹ ihiẹn-ọsụsụọ m, we enwẹn ẹ ye makẹ ufiri m.  
\v 21 Emẹkọ m ẹfọma Osolobuẹ wụrụ ihiẹn na iwi—makẹni, omẹni eziẹ rọ nị ịhịan dọnmẹ Iwu, Osolobuẹ e gi ẹ kun'ẹ ọhụnma, ya wụ nị ọnwụn Kraịstị nwụn la iwi!” 
\c 3  
\cl Isi Nke Ẹtọ 
\s1 Iwu ra Okukwe? 
\p  
\v 1 Euu ndị Galeshịa, ndị-nzuzu! Onyẹ mẹ ọnụ ihiẹnni? Bụ id'ẹnya ụnụ kẹ wẹ nọ ghọsịchanrịn nị wẹ kpọgbu Kraịstị elu obe.  
\v 2 Ihiẹn ohuni sụọ kẹ m chọ nị m marịn: gwadẹle ni m, nanị kẹ ụnụ dọn nwẹhẹn Mmọn-nsọ? Ụnụ nwẹhẹn ẹ ghahanị idọnmẹ Iwu ra ghahanị ikweri oziọma ụnụ nụ?  
\v 3 Ẹrịra kẹ ụnụ e zuzuhan? Ẹka Mmọn-nsọ kẹ ụnụ gha bidọn; ọnụ rị nwan a lịlịma nị ọnụ gi ikẹn ụnụ—ikẹn ịhịan—mẹchanrịn a?  
\v 4 Nị m jụdẹle ụnụ: afụnfụn nẹi ile ụnụ ta wụ nke ọlal'iwi? Ra ọ lagụọdẹ iwi nke-esi?  
\v 5 Osolobuẹ hụn e ye ụnụ Mmọn-nsọ a, a rụn ọrụn atụ-ẹnya imẹ igunrun ụnụ, o ye ụnụ ya makẹni ụnụ rị e dọnmẹ Iwu Mozizi ra makẹni ụnụ hụ a nụ e kweri ihiẹn ụnụ nụ? 
\p  
\v 6 Nke Ebraham, Ẹhụhụọ-nsọ sị nị “O kweyeni Osolobuẹ, Osolobuẹ nọ gụn a yen'ẹ, kpọ a onyẹ rị kẹ Osolobuẹ chọ.”  
\v 7 Gi ni ọnwan marịn nị ndị hụn wụ ezigbo ụmụ Ebraham wụ ndị kwerini.  
\v 8 Ẹkụkwọ-nsọ e kutọgụọ a nị Osolobuẹ jẹnkọ d'e gi ifiri okukwe ndị wụlẹni ndị Ju kuni wẹ ọhụnma; ọ sị nị Chuku zi Ebraham oziọma ẹdẹi, sị, “Ndị anị ile jẹnkọ d'e nwẹhẹn ngọzi ghahanị ị.”  
\v 9 Ya wụ, ndị hụn kwerini k'e sọn Ebraham hụn kwerini wụrụ ndị wẹ gọzi agọzi. 
\p  
\v 10 Ndị hụ gi idọnmẹ Iwu e dọn ẹnya a wụrụọlẹ ndị wẹ bụ ọnụ. Makẹni, Ẹhụhụọ-nsọ sị, “Onyẹ ọwụlẹ hụn ghalẹni e dọnmẹ ihiẹn ile wẹ de imẹ ẹhụhụọ Iwu, e hẹnringụọ onyẹ wẹ bụ ọnụ!”  
\v 11 O wegụụ nwan ẹnya n'o nwọnni onyẹ ọwụlẹ hụn Osolobuẹ jẹnkọ d'e kuni ọhụnma makẹni o dọnmẹ Iwu. Ọnwan wụ ezioku, makẹni, Ẹhụhụọ-nsọ sị nị, “Okukwe kẹ onyẹ rị kẹ Chuku chọ k'e gi rị ndụn,”  
\v 12 bụ ẹlẹ okukwe kẹ Iwu gi a rụn, makẹni, Iwu lẹ enwẹn ẹ e kugụọ nị, “Onyẹ hụ hụn rị e dọnmẹ ihiẹn ndịnị ile Iwu ku k'e gi rị ndụn makẹni ọ rị e dọnmẹ wẹ.” 
\p  
\v 13 Kraịstị gbafụha ẹnyi imẹ abụmọnụ Iwu ghahanị igi ifiri ẹnyi hẹnrin onyẹ wẹ bụ ọnụ. Makẹni, Ẹkụkwọ-nsọ sị nị, “Onyẹ ọwụlẹ wẹ hogbu elu osisi a wụrụọlẹ onyẹ wẹ bụ ọnụ.”  
\v 14 Ọ gbapụha ẹnyi kẹni ngọzi Osolobuẹ gọzi Ebraham hụn ụzọ bịanị ndị alị ndị ọzọ ile hụn wụlẹni ndị Ju, ghahanị Kraịstị wụ Jizọsị, kẹni ẹnyi hụn ụzọ gi okukwe nwọnhẹn Mmọn-nsọ hụn Osolobuẹ kwe nkwa a. 
\s1 Iwu Lẹ Nkwa Osolobuẹ 
\p  
\v 15 Umunẹ m, nị m gi ihiẹn w'e mẹ ụhụọhịn ile kọwa ihiẹn: madụ ẹbụọ kwerigbamahụ banyeni ihiẹn ọwụlẹ, biyegụụ a ẹka, ọ nwọnni onyẹ ọwụlẹ k'a saẹka kagbu ẹ mọbụ we ihiẹn ọwụlẹ chen'ẹ.  
\v 16 Ogẹn Osolobuẹ gi kwe nkwa hụ, o kwe Ebraham lẹ nwa a ya wụ nkwa, Ẹhụhụọ-nsọ asịnị “Ụmụ ị” ya wụ, hụn karị onyẹ ohu; kanị ọ sị “nwa ị” ya wụ ohu sụọ—hụn wụ Kraịstị.  
\v 17 Ihiẹn m gi ẹ e ku wụ nị Osolobuẹ e biyegụọ nkwerigbama hụ ẹka, tumẹ ẹ; ya wụ nị Iwu wẹ webanhan ogẹn o gi mẹpụ ọrọgbọ ahụa iri-kwasị-ọgụn kwasị nnụ as'ẹka kagbu nkwerigbama hụn Osolobuẹ biyegụụ ẹka lẹ nkwa o kwe imẹ nkwerigbama ahụn.  
\v 18 Makẹni, omẹni idọnmẹ Iwu kẹ wẹ gi e nwọnhẹn ihiẹn Osolobuẹ kwe nkwa a, ya wụ nị ẹlẹzi n'o kwe nkwa haịn wẹ gi e nwẹhẹn ẹ. Kanị, ezioku-ezioku, Osolobuẹ ye Ebraham ya ọfẹ igi mẹzu nkwa a. 
\s1 Kị Haịn Nwan Wẹ Gi Ye Iwu Hụ? 
\p  
\v 19 Kị wụzị nwan mkpa Iwu hụ rị? Wẹ webanhan a nị ịhịan e gi ẹ a marịn njọ lẹ mmẹfie, a marịnzị njọ wẹ lẹ mmẹfie wẹ, d'e ru ogẹn nwa ahụn, onyẹ hụ wẹ kwe ya wụ nkwa e gi bịa. Wẹ gha ẹka ndị mmọn-ozi tumẹ ya wụ Iwu, we ẹ ye ụkọ ye wẹ.  
\v 20 Kanị w'a ra chọ ụkọ ebe onyẹ ohu sụọ nọ e mẹ ihiẹn. Osolobuẹ gi ẹka a mẹ ihiẹn ẹ ogẹn o gi kwe Ebraham nkwa ahụn. 
\p  
\v 21 Arị m'e ku nị Iwu wụ eṅẹnrẹn nkwa Osolobuẹ. Kaka akp'ohu! Makẹni, omẹni wẹ te ye iwu hụn a saẹka e ye ịhịan ndụn, nkẹ o wụrụ nị, ezioku-ezioku, onyẹ dọnmẹ ẹ, ọ wụrụ onyẹ rị ọchan.  
\v 22 Kanị Ẹhụhụọ-nsọ e kugụọ a nị ịhịan ile rị imẹ ẹgbụn njọ, ku ẹ hụn we ẹnya, kẹni ọ wụrụ nị ụzọ ohu sụọ kẹ wẹ gi e nwẹhẹn ihiẹn Osolobuẹ kwe nkwa a. Ụzọ ohu hụ wụ ikweri ni Jesu Kristi, gi Jesu Kristi e dọn ẹnya: onyẹ kweri, o nwẹhẹn ẹ.  
\v 23 Kẹ ẹnyi kelẹni kweri ni Kraịstị, Osolobuẹ bu ẹnyi dọnmẹ okpuru Iwu, kpọkin ẹnyi ye, nọkẹ ndị ngan, e che ogẹn okukwe e gi bịa.  
\v 24 Ya wụ, Osolobuẹ tumẹ Iwu n'ọ wụrụnị ẹnyi onyẹ bu mkpịnsịn e lepụ ẹnyi ẹnya, d'e ru nị Kraịstị a bịa, kẹni, o ru, o gi okweri ẹnyi jẹnkọ d'e kweri ni Kraịstị kuni ẹnyi ọhụnma.  
\v 25 Kanị, hụnnị ẹnyi kwerigụụ nwan, ẹnyi arịzị okpuru onyẹ-nlepụ-ẹnya. 
\p  
\v 26 Ụnụ ile wụ ụmụ Osolobuẹ ghahanị okweri ụnụ kwerini Kraịstị wụ Jizọsị,  
\v 27 makẹni, ọnụ ile, hụn wẹ bugụụ che imẹ Jesu Kristi ghahanị imẹ ọnụ mirin-Chuku, e yirigụọ Kraịstị.  
\v 28 Ya wụ nị o nwọnzi ihiẹn rị ichẹn ẹgbata ndị Ju lẹ ndị wụlẹni ndị Ju; ẹgbata igbọn lẹ onyẹ nwọn enwẹn ẹ; ẹgbata ikẹnnyẹ lẹ ikpoho: ẹnyi ile wụ ohu imẹ Kraịstị wụ Jizọsị.  
\v 29 O mẹ nwan nị ẹnyi wụ nke Kraịstị, ya wụ nị ẹnyi wụ ụmụ Ebraham, nị ẹnyi k'e nwọnhẹn ihiẹn Osolobuẹ kwe nkwa n'o k'e ye. 
\c 4  
\cl Isi Nke Ẹnọ 
\s1 Ụnụ E Nwẹringụọ Enwẹn Ụnụ! 
\p  
\v 1 Ihiẹn m rị e ku wụ nị, ebe nwa ahụn jẹnkọ d'e nwọnrin ihiẹn nẹdi ẹ kelẹni ru ogo, ọ rịhụ kẹ igbọn, ihiẹn ichẹn arị a, ọsụọn'a nị ihiẹn ile wụ nke ẹ.  
\v 2 Ọ rịsọnmẹ okpuru ndị e du n'ẹ lẹ ndị e lepụ a ẹnya d'e ru ogẹn hụ nẹdi ẹ kaye.  
\v 3 Ẹrịra k'ọ rị ẹnyi kẹ ẹnyi kelẹni ru ogo, ya wụ kẹ ẹnyi kelẹni kweri, ẹnyi wụsọnmẹ igbọn ihiẹn ndị hụn a kị obibi rị imẹ ụwanị.  
\v 4 Kanị, mgbe ogẹn gi zu, Osolobuẹ nọ zihẹ Nwa a; okpoho mụ a; wẹ mụ a ye okpuru Iwu.  
\v 5 Osolobuẹ zihẹ ẹ n'ọ hụn ụzọ gbarị ndị rị okpuru Iwu, kẹni ẹnyi hẹnrin ụmụ Osolobuẹ, ụmụ Osolobuẹ ru ogo ụmụ.  
\v 6 Makẹni ụnụ wụ ụmụ, Osolobuẹ nọ zihẹ Mmọn nke Nwa a ye imẹ obi ụnụ; Mmọn ahụn rị nwan imẹ ẹnyi ile a hị, “Baba! Baba-Nẹdi m!”  
\v 7 Ya wụ nwan nị y'ẹlẹzi igbọn; nwa kẹ ị wụ. Ebe o mẹ ni nwa kẹ ị wụ, Osolobuẹ k'e keye i ihiẹn ẹ. 
\s1 E Kinlẹ Ni Azụụn Imẹ Ẹgbụn 
\p  
\v 8 Mgbe mbụ, ogẹn ụnụ kelẹni marịn Osolobuẹ, ụnụ wụ igbọn mmọn ndị hụ furulẹni w'e fe, ụnụ e fe wẹ e fe.  
\v 9 Kanị hụnnị ụnụ marịngụụ Osolobuẹ—mba, hụnnị Osolobuẹ marịngụụ ụnụ, kịnị kẹ ụnụ kinkọzịnị azụụn d'e kunrun mmọn ndị ahụn lẹ ihiẹn ndị hụ ndụn gụụ? Ụnụ chọ nị ụnụ hẹnrinzi igbọn wẹ?  
\v 10 Ụnụ e mẹsọnmẹ mmẹmmẹ wẹ gi a nyanhansọnmẹ ụhụọhịn lẹ ifọn lẹ ogẹn lẹ ahụa rị ichẹn-ichẹn!  
\v 11 Egun ụnụ rịkwọ a tụ m, nị ikẹnkwọ ọrụn ile m rụn ebe ọnụ rị a lagụọ iwi! 
\p  
\v 12 M rị a rịọ ụnụ umunẹ m, rị nị kẹ mmẹ, makẹni a rịgụọ m kẹ ụnụ. Ụnụ emẹni m njọ.  
\v 13 Ụnụ a marịnghọ nị emu rị a kụnị m ogẹn ahụn wụ ihiẹn wẹhẹni m oghere m gi zi ụnụ oziọma isi-ibuzọ ahụn.  
\v 14 Kanị, ọsụọn'a nị ẹhụ hụn rị e sọngbuni m wụrụ nị ụnụ ibu lẹ ihiẹn-nlele, ụnụ elegberini m, ụnụ ajụnị m; kama, ụnụ nabanhan m nọkẹ sị m wụ mmọn-ozi Osolobuẹ, nọkẹ sị m wụ Kraịstị lẹ enwẹn ẹ.  
\v 15 Kị mẹzi ịghọghọ hụ ile ụnụ nwẹ ogẹn hụ?! M k'a s'ẹka shịa ẹri nị, omẹni ọ rị nfe, nkẹ ụnụ e te gụye m akpụrụ-ẹnya ụnụ, omẹni o te k'e yeni m ẹka!  
\v 16 Kẹ m hẹnrinni eṅẹnrẹn ọnụ makẹni m gwa ụnụ ezioku? 
\p  
\v 17 Ndị ahụn rị nwan a lịlịma nị wẹ dọrị ọnụ, kanị ẹlẹ ihiẹn rị mma kẹ wẹ bu obi! Ihiẹn wẹ bu obi wụ nị wẹ wepụ ọnụ ebe ụnụ rị, kẹni ụnụ buchanrịn obi ụnụ che ebe wẹ rị.  
\v 18 Ọ hụghọkwọ mma ibu obi e che ihiẹn ẹnịna, e mẹkẹnmẹ oku ẹ—omẹni ifiri ihiẹn rị mma rọ, omẹni w'e mẹ ẹ ogẹn ile—ẹlẹ mmẹ lẹ ụnụ nọdịhụ sụọ. 
\p  
\v 19 Ụmụ m hụn rị m obi, imẹ ụnụ e mẹmẹzi m, oku ụnụ a kpamazị m, d'e ru nị ụnụ e sọnmẹchanrịn Kraịstị.  
\v 20 K'o te rị m, m rị nwan ebe ụnụ rị kikẹnni, kẹni m hụn ụzọ gbehutọ olu, makẹni obi eruzini m alị ebe ụnụ rị! 
\s1 Ihiẹn Pọlụ Gi Sara Lẹ Haga Ghọsị 
\p  
\v 21 Gwadẹle ni m, ụnụ ndị chọkọ nị ụnụ rị okpuru Iwu, ụnụ anụnị ihiẹn Iwu Mozizi ku?  
\v 22 Wẹ de ẹ imẹ Iwu nị Ebraham mụ ikẹnnyẹ ẹbụọ: Haga, nnẹ ohu wụ igbọn; Sara, nnẹ hụn-ẹbọ nwẹ enwẹn ẹ, ẹlẹ igbọn.  
\v 23 Wẹ mụn'a hụn nnẹ ẹ wụ igbọn kẹ ịhịan dọn a mụ nwa; kanị wẹ mụn'a hụn nnẹ ẹ nwẹ enwẹn ẹ ghahanị nkwa Osolobuẹ kwe. 
\p  
\v 24 Ẹnyi k'a s'ẹka gi ihiẹn ndịnị ghọsị ihiẹn: ikpoho ẹbụọnị nọkin ẹnya nkwerigbama ẹbụọ. Ohu wụ hụn wẹ nọ elu Ugu Saịnaị mẹmẹ. Ọhụn kẹ Haga nọkin ẹnya a; ọ mụ ụmụ, a wụrụ wẹ igbọn.  
\v 25 Haga nọkin ẹnya Ugu Saịnaị, hụn rị imẹ atụ alị Arebịa. Ọ ghọsị obodo Jerusalẹm hụn rị ogẹnni, makẹni Jerusalẹm lẹ ndị rịn'a wụ igbọn kikẹnni.  
\v 26 Kanị Jerusalẹm hụ hụn rị enu- igwee nwọn enwẹn ẹ, ẹlẹ igbọn. Ịya wụ nnẹ ẹnyi.  
\v 27 Makẹni Ẹhụhụọ-nsọ sị, 
\q1 “Ghọghọma nwan! 
\q2 Ịyụ wụ agan, 
\q2 hụn mụtulẹni nwa! 
\q1 Kwankpọma ẹbụ! Yimẹ oro! 
\q2 Ịyụ, hụn marịntulẹni ụfụ-nwa! 
\q1 Makẹni, ụmụ okpoho hụ wẹ jụtọ, 
\q2 a karịgụọ 
\q2 nke okpoho hụ ya lẹ di ẹ bi!” 
\p  
\v 28 Umunẹ m, ụnụ wụ ụmụ Osolobuẹ ghahanị nkwa hụ o kwe, nọkẹ kẹ Aziki dọn wụ.  
\v 29 Kanị, ọ rị nwan k'ọ rị ogẹn hụ: ogẹn ahụn, nwa wẹ mụ kẹ ịhịan dọn a mụ nwa kpokpo hụn wẹ mụ ghahanị Mmọn nke Osolobuẹ.  
\v 30 Kanị, kịnị kẹ Ẹhụhụọ-nsọ ku? Ọ sị, “Chụpụ igbọn hụ lẹ nwa a; makẹni nwa igbọn hụ esọnkọ nwa okpoho hụn nwọn enwẹn ẹ keri uku.” 
\p  
\v 31 Umunẹ m, ya wụ nị ẹnyi ẹlẹ nwan ụmụ igbọn-okpoho hụ, kama, ụmụ okpoho hụn nwẹ enwẹn ẹ kẹ ẹnyi wụ. 
\c 5  
\cl Isi Nke Isẹn 
\s1 Ụnụ E Werigụọkwọ Enwẹn Ụnụ! 
\p  
\v 1 Kraịstị gbafụha ẹnyi kẹni ẹnyi wụrụ ndị nwẹ enwẹn wẹ. Wuzokẹnmẹ ni nwan kẹ ndị werigụụ enwẹn wẹ! Anịkwọlẹ ni wẹ kpọmazị ụnụ ẹgan igbọn! 
\p  
\v 2 Gọn ni ntịn! Mmẹ wụ Pọlụ rị a gwa ọnụ nị ọnụ nị wẹ kwa ọnụ ugun, ya wụ nị o nwọnni erere Kraịstị k'a ban nị ụnụ.  
\v 3 M rị a gwazị okẹnnyẹ ọwụlẹ hụn k'a nị wẹ kwa a ugun ya kwademẹkwọ nwan n'o dọnmẹchanrịn Iwu ile.  
\v 4 Onyẹ ọwụlẹ rị nwan e dọnmẹ Iwu, e gi ẹ e ro ni Osolobuẹ rị e kun'ẹ ọhụnma, a ghagụọkwọ imẹ Kraịstị pụ; ọ ghagụọkwọ imẹ ẹfọma Osolobuẹ danpụ.  
\v 5 Kanị, okukwe lẹ ikẹn Mmọn-nsọ kẹ ẹnyi nwẹn gi rị e chekẹnmẹ ọhụnma ahụn Osolobuẹ jẹnkọ d'e kuni ẹnyi, hụn ẹnyi rị a tụ ẹnya a.  
\v 6 Makẹni, imẹ Kraịstị wụ Jizọsị, ịkwa-ugun lẹ akwanị-ugun enwọnni ihiẹn ọ wụ. Ihiẹn rị mkpa wụ okukwe hụn gi ihiẹn-ọsụsụọ a ghọsị n'ọ hụ a. 
\p  
\v 7 Ụnụ te rị a gba-ọsọ ọhụnma! Onyẹ bu uke che ni ụnụ, ụnụ gizilẹni e sọn ezioku?  
\v 8 Ẹlẹkwọ Osolobuẹ hụn kpọ ọnụ dụnye ọnụ ụdị ọdụnyeni!  
\v 9 Ọ rịhụ kẹ wẹ dọn e ku ẹ, “Ẹkẹrẹ yisti sụọ kẹ w'e buchehụ, ọ ghagbarị flawa brẹdi hụ ile.”  
\v 10 Kanị, makẹni a marịnghọ m ihiẹn Di-nwọnni-ẹnyi k'a saẹka mẹ imẹ ndụn ọnụ, obi ru m alị nị ụnụ erokọ ihiẹn ichẹn, sọnmẹ nkuzi ọzọ. Onyẹ hụ rị e nuhunmẹni ụnụ—onyẹ ọwụlẹ ọ wụ—k'a narịnrịrị afụnfụn rịn'a. 
\p  
\v 11 Umunẹ m, omẹni echẹn kẹ m rịkwọ a kuzi nị ịkwa-ugun rị mkpa, kị haịnzị wẹ gi e kpokpo m? Omẹni ezioku rọ nị m rị a kuzi nị ịkwa-ugun rị mkpa, ya wụ nị ozi m rị e zi banyeni obe Kraịstị e ke gha e buhẹ oku.  
\v 12 K'ọ rị m, ndị hụ rị e ye ụnụ nsọngbu e jẹn d'a waradẹ enwẹn wẹ, ẹlẹdẹ ịkwa-ugun sụọ! 
\s1 Anịlẹ Enwẹn I Kị Ị 
\p  
\v 13 O mẹ nke ụnụ umunẹ m, Osolobuẹ kpọ ụnụ d'e weri enwẹn ụnụ. Kanị, egikwọlẹ ni nị ọnụ e werigụọ enwẹn ọnụ mẹmẹ k'ọ rị ọnụ, rịkẹ ịhịan-mmaka; ka gi ni ihiẹn-ọsụsụọ e fetarị ibe ụnụ.  
\v 14 Makẹni, wẹ wegbamachanrịn Iwu ile che imẹ akpụ iwu ohu hụn wụ “Ihiẹn ibe i k'a sụọrịrị ị kẹ ihiẹn enwẹn i dọn a sụọ ị.”  
\v 15 Kanị, omẹni ụnụ hụ a tagbu ibe ọnụ e ri, kpachanfụkwọ nị nwan ẹnya, amamgbe ọnụ e gbupụ ibe ọnụ! 
\s1 Mmọn-nsọ Lẹ Ịhịan-mmaka 
\p  
\v 16 M sị ụnụ, a nị nị nwan Mmọn-nsọ a kị ụnụ, makẹ ụnụ gha e mẹ kẹ ịhịan-mmaka.  
\v 17 Makẹni, ihiẹn ịhịan-mmaka a chọ ẹlẹ ihiẹn Mmọn-nsọ a chọ; ihiẹn Mmọn-nsọ a chọ ẹlẹ ihiẹn ịhịan-mmaka a chọ. Wẹ ẹbụọ a lụsọn ibe wẹ ọgụn, nke wụ nị, y'a saẹka mẹ ihiẹn ị chọ.  
\v 18 Kanị, omẹni Mmọn-nsọ rị e du ụnụ, ya wụ nị ụnụ arịzị okpuru iwu. 
\p  
\v 19 Ihiẹn ịhịan-mmaka e mẹ pụhachanrịn ifọn; wẹ wụ ihiẹn ndịnị: ughẹrẹ, ibi obibi rịlẹni ọchan, imẹ ihiẹn-ifẹnrẹn,  
\v 20 ịrụa-mmọn, ibu-nshi lẹ igi ikẹn eje-mmọn a rụn, idu-eṅẹnrẹn, ikpe, ẹnya-ụfụ, eje-olulu, ịchọ nke-i nke-i, nkebe, ịzụọ ẹka-nke,  
\v 21 iwe-ẹnya, igbu-ọchụ, ịra-manya tụ, eje-mmẹmmẹ lẹ ihiẹn ndị ọzọ nọ ẹrịra. M rị nwan a gba ụnụ mkpịnsịn-ẹka kẹ m dọn gba ụnụ ya mbụ, nị ndị hụn e mẹ ihiẹn ndị nọ ẹrịra a bankọ Alị-eze Osolobuẹ. 
\p  
\v 22 Kanị, ihiẹn Mmọn-nsọ a mịpụha wụ: ihiẹn-ọsụsụọ, ịghọghọ, udọn, ndidi, ẹfọma, imẹ-mma, ịwụ onyẹ wẹ gi e dọn ẹnya,  
\v 23 imẹ-jụụ, ikwọndọn-enwẹn-ịhịan. Onyẹ mẹ ihiẹn ndịnị adannị iwu ọwụlẹ.  
\v 24 Ndị hụn wụ nke Kraịstị wụ Jizọsị a kpọgbugụọ ịhịan-mmaka wẹ te wụ lẹ ihiẹn a gụnn'a lẹ ihiẹn a sụọn'a enu obe Kraịstị.  
\v 25 Ebe o mẹ ni Mmọn-nsọ e ye ẹnyi ndụn, nị ẹnyi e bi ni nwan kẹ ndị Mmọn-nsọ rị a kị.  
\v 26 Ẹlẹ hụn ẹnyi e gi a pache mọbụ a kpasu ibe ẹnyi iwe mọbụ e we ni ibe ẹnyi iwe-ẹnya. 
\c 6  
\cl Isi Nke Isin 
\s1 E Bu Ni Ibu Ibe Ụnụ 
\p  
\v 1 Umunẹ m, onyẹ mẹ njọ, ụnụ ndị rị e bi kẹ Mmọn-nsọ chọ, gi ni nwayọ wekinhẹn ẹ. Ka kpachanpụkwọ nị ẹnya amamgbe ọnwụnwan a bịazịkwọ nị ụnụ nwẹn.  
\v 2 E bu ni ibu ibe ọnụ. Ụnụ gha e mẹ ẹ, ya wụ nị ọnụ hụ e mẹzu iwu Kraịstị.  
\v 3 Onyẹ rị e ro n'o nwọnghọ ihiẹn ọ wụ bụ o nwọnni ihiẹn ọ wụ rị e dufie enwẹn ẹ.  
\v 4 Onyẹ-onyẹ ya lele ihiẹn ọ rị e mẹ. Omẹni ọ hụghọ mma, ya họnrọn makẹ ihiẹn rị mma o mẹ, ka y'e gilẹ enwẹn ẹ tụnị onyẹ ọzọ,  
\v 5 makẹni onyẹ-onyẹ furu n'o buru ibu ẹ. 
\p  
\v 6 Ndị wẹ rị a kuzi oku-Chuku furu ni wẹ keye ndị rị a kuzi ni wẹ oku-Chuku ihiẹn-ọma ọwụlẹ wẹ nwọn.  
\v 7 Edufiekwọlẹ ni enwẹn ọnụ: Osolobuẹ anịkọkwọ onyẹ ọwụlẹ mẹgbu ẹ; ihiẹn onyẹ kụn k'o k'a ghọrị.  
\v 8 Omẹni ugbo wẹ kụnye ẹ wụ imẹ-ihiẹn a sụọ nị wẹ, wẹ k'a gha ugbo hụ ghọrị ntikpọ; omẹni ugbo imẹ-ihiẹn a sụọ Mmọn-nsọ kẹ wẹ kụnye ẹ, wẹ k'a gha ebẹhụ ghọrị ndụn-itẹbitẹ.  
\v 9 Ya wụ, ndụn imẹ ihiẹn rị mma y'a gụkwọlẹ ẹnyi. Makẹni, omẹni ẹnyi anịnị ndụn gụụ ẹnyi, ogẹn ru, ẹnyi jẹnkọ d'e ri erere ẹ.  
\v 10 Ya wụ, nị ẹnyi gi ni nwan oghere ile ẹnyi nwẹ e mẹ ni onyẹ ọwụlẹ ọhụnma, tụmadụ ndị hụn rị ikpun-ụlọ okukwe. 
\s1 Mkpịnsịn-ẹka Ịkpazụụn Lẹ Ekele 
\p  
\v 11 \sc Lee ni akpụrụ-ẹkụkwọ ndịnị nọ jagbo-jagbo m gi ẹka m deni ọnụ.\sc* 
\v 12 Ndị hụn rị a chọ nị wẹ gi ihiẹn ẹnya e legha dụ ẹka obi, uwẹ rị nwan a chọ nị wẹ wa ịkwa-ugun ye ụnụ olu. Wẹ rị e mẹ ẹ amamgbe wẹ e gi ifiri obe Kraịstị kpokpo wẹ.  
\v 13 Kẹ ndị hụn kwa ugun lẹ enwẹn wẹ arịdẹ e dọnmẹ Iwu, bụ wẹ hụ a chọ nị ụnụ kwa ugun kẹni wẹ gi ihiẹn rị ụnụ ẹhụ nyan isi: nị ụnụ e dọnmẹgụọ omẹnalị hụn w'e legha ẹnya.  
\v 14 O bugharị m! Egikọ m ihiẹn ọwụlẹ nyan isi, wezụka obe Nna ẹnyi wụ Jesu Kristi. E gigụọ wẹ obe hụ kpọgbu ụwanị—ọ wụrụ ihiẹn nwụnnị ebe m rị, gizikwọ obe hụ kpọgbu m—a wụrụ m ihiẹn nwụnnị ebe ụwa rị.  
\v 15 Kẹ ịkwa-ugun kẹ akwanị-ugun arịnị mkpa, kaka! Ihiẹn rị mkpa wụ nị wẹ kedọnzi ịhịan.  
\v 16 Udọn lẹ omikẹn ya rịnị kẹ wẹ han gi usọnrọnnị e bi—uwẹ wụ ndị Izrẹlụ Osolobuẹ nke-esi! 
\p  
\v 17 Gha ogẹnni e jẹn, onyẹ ọwụlẹ egizilẹ oku ịkwa-ugun ye m nsọngbu, makẹni apa ẹhụ wẹ rụsọnmẹ m makẹ ufiri Jesu hụsọnmẹ m ẹhụ. 
\p  
\v 18 Umunẹ m, ẹfọma Onyẹ-nwọnni-ẹnyi wụ Jesu Kristi ya nọyeni ụnụ imẹ-mmọn. Isẹẹ.