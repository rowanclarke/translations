\v 24 \w et|strong="G2532"\w* \w pour|strong="G2532"\w* \w offrir|strong="G1325"\w* \w en|strong="G1722"\w* \w sacrifice|strong="G2378"\w*, \w ainsi|strong="G2532"\w* \w que|strong="G2532"\w* \w le|strong="G2532"\w* \w prescrit|strong="G2046"\w* \w la|strong="G2532"\w* \w loi|strong="G3551"\w* \w du|strong="G2532"\w* \w Seigneur|strong="G2962"\w*, \w une|strong="G2532"\w* paire \w de|strong="G2532"\w* \w tourterelles|strong="G5167"\w*, \w ou|strong="G2228"\w* \w deux|strong="G1417"\w* \w petites|strong="G1417"\w* \w colombes|strong="G4058"\w*.   
