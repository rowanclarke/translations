\id TIT
\h ثِيثُوسْ
\toc1 ثِيثُوسْ
\toc2 ثِيثُوسْ
\toc3 ثِيث.
\mt1 ثِيثُوسْ
\c 1
\s1 أَسدْجمْ غَارْ ؤُمزْوَارُو
\m 
\v 1 بُولُوسْ، أَمْسخَّارْ ن أَربِّي ذ رَّاسُولْ ن يَاسُوع لْمَاسِيحْ، ذِي لْ-إِيمَانْ ن يِينِّي إِتّْوَافَارْزنْ زِي أَربِّي ؤُ \add ذِي\add* ثُوسّْنَا ن ثِيذتّْ، ثنِّي إِدْجَانْ ذِي ثِيڭّْوُوذِي زِي أَربِّي، \f ◼ \fr 1:‏1 \ft \bd ’رَّاسُولْ‘\bd* - نِيغْ ’أَمَازَانْ‘.\f*
\v 2 خْ ؤُسِيثمْ ن ثُوذَارْثْ إِتّْذُومَانْ، ثنِّي زِي ثُوغَا إِوَاعْذْ أَربِّي ذ ثِيذتّْ، قْبڒْ زّْمَانَاثْ ن ڒْوقْثْ-أَ. \x ◘ \xo 1:‏2 \xt ڒخْڒ. 23‏:‏19؛ رُوم. 16‏:‏25؛ أَفا. 1‏:‏9؛ 3‏:‏9؛ كُول. 1‏:‏26؛ 2 تِيم. 2‏:‏13؛ 1 بُط. 1‏:‏20. \x*
\v 3 نتَّا أَقَا إِسَّارْڭبْ أَوَاڒْ نّسْ ذِي ڒْوقْثْ نّسْ س ثْبَارّحْثْ نّغْ إِ ذ أَيِي إِتّْوَاوكّْڒنْ عْلَاحْسَابْ ڒُومُورْ ن أَربِّي، ونِّي ذ أَنغْ إِتِّيشنْ ثُوذَارْثْ. \x ◘ \xo 1:‏3 \xt ڒخ. 20‏:‏24؛ ڭال. 1‏:‏1.\x*
\m 
\v 4 إِ ثِيثُوسْ، مِّي ذ ثِيذتّْ عْلَاحْسَابْ لْ-إِيمَانْ نّغْ إِشَارْشنْ: أَرْضَا ذ ڒهْنَا زِي أَربِّي، بَابَاثْنغْ، ؤُ زِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، ونِّي ذ أَنغْ إِتِّيشنْ ثُوذَارْثْ. \x ◘ \xo 1:‏4 \xt 2 كُور. 2‏:‏12؛ 7‏:‏13، 14؛ 8‏:‏6، 16؛ ڭال. 2‏:‏3؛ أَفا. 1‏:‏2؛ كُول. 1‏:‏2؛ 2 تِيم. 1‏:‏2؛ 1 بُط. 1‏:‏2. \x*
\b
\s1 ثِيثُوسْ ذِي كْرِيثَا
\m 
\v 5 س ؤُينِّي جِّيغْ شكْ ذِي كْرِيثَا، حِيمَا أَذْ ثْعذْڒذْ مِينْ ثُوغَا عَاذْ إِتّْخصَّا، ؤُ حِيمَا أَذْ ثسّْڭعّْذذْ إِمْغَارنْ ذِي كُوڒْ ثَانْذِينْثْ، أَمْ مَامّشْ شكْ ؤُمُورغْ. \x ◘ \xo 1:‏5 \xt 2 تِيم. 2‏:‏2. \x*
\v 6 \add أَمْغَارْ\add* ذ إِجّنْ نِّي وَارْ ذِي إِدْجِي ڒْعِيبْ، أَقَا-ث ذ أَرْيَازْ إِ غَارسْ \add مْغِيرْ\add* إِشْثْ ن ثمْغَارْثْ، غَارسْ إِحنْجِيرنْ تَّامْننْ، وَارْ تّكّْوَارنْ، وَارْ تّْوَاطّْفنْ زڭْ ؤُفُوشّحْ. \x ◘ \xo 1:‏6 \xt 1 تِيم. 3‏:‏2. \x*
\v 7 مِينْزِي إِتّْخصَّا إِ ؤُمْغَارْ أَذْ يِيڒِي بْڒَا ڒْعِيبْ أَمْ ووْكِيڒْ ن أَربِّي. إِتّْخصَّا وَارْ ذَايسْ إِتِّيڒِي ؤُعفَّارْ نِيغْ زّْعَافْ، وَارْ إِسسّْ شّْرَابْ سنّجْ إِ ڒْقدّْ، وَارْ إِشِّيثْ س ؤُفُوسْ نّسْ ذغْيَا ؤُ وَارْ إِتّخْسْ أَرْبحْ وَارْ إِحْڒِينْ. \x ◘ \xo 1:‏7 \xt لَاوِي 10‏:‏9؛ مت. 24‏:‏45؛ 1 كُور. 4‏:‏1؛ أَفا. 5‏:‏18؛ 1 تِيم. 3‏:‏3، 15؛ 1 بُط. 5‏:‏2. \x*
\v 8 أجّْ إِ-ث أَذْ يَارحّبْ س إِنوْجِيونْ، أَذْ إِخْسْ مِينْ إِصبْحنْ، إِتّْخصَّا أَذْ يِيڒِي ذ أَسخَّايْ، ذ أَمْسڭَّاذْ، ذ أَمزْذَاڭْ، أَذْ إِحْكمْ خْ إِخفْ نّسْ. \x ◘ \xo 1:‏8 \xt 1 تِيم. 3‏:‏2. \x*
\v 9 إِتّْخصَّا أَسْ أَذْ إِحْضَا ثْغُورِي \add ن صَّاحْ\add* ن وَاوَاڒْ ن لْ-إِيمَانْ، حِيمَا إِقدّْ أَذْ إِڭّْ وُوڒْ ذڭْ \add يِينِّي يُومْننْ\add* س ثْغُورِي نّسْ ن صَّاحْ ؤُ أَذْ إِسڭّمْ ثَارْوَا ن بُو-ثْغنَّانْثْ.
\m 
\v 10 مِينْزِي أَقَا ذِينْ أَطَّاسْ ن إِوْذَانْ إِنِّي وَارْ إِخْسنْ أَذْ سّْوَاضْضْعنْ إِخفْ نْسنْ، سَّاوَاڒنْ أَوَاڒنْ إِخْوَانْ. نِيثْنِي سّْخَارْوَاضنْ إِخَارِّيصنْ ن إِوْذَانْ، غَارْ ؤُمزْوَارُو نْسنْ ذ إِنِّي إِدْجَانْ زڭْ وخْثَانْ. \x ◘ \xo 1:‏10 \xt ڒخ. 15‏:‏1\x*
\v 11 إِتّْخصَّا أَذْ أَسنْ إِتّْوَاقّنْ ؤُقمُّومْ، مِينْزِي نِيثْنِي قڒْعنْ خْ وَاطَّاسْ ن ڒَادْجَاثْ، سّڒْمَاذنْ مِينْ وَارْ إِشُووَّارنْ مَاحنْذْ أَذْ طّْفنْ أَرْبحْ وَارْ إِحْڒِينْ. \x ◘ \xo 1:‏11 \xt مت. 23‏:‏14؛ 2 تِيم. 3‏:‏6. \x*
\v 12 إِجّنْ زَّايْسنْ، أَقَا-ث ذ أَنَابِي نْسنْ، ثُوغَا إِنَّا: ”إِكْرِيثِييّنْ سّْخَارِيقّنْ ڒبْذَا، أَقَا-ثنْ ذ ڒوْحُوشْ إِعفَّاننْ، إِمعْڭَازنْ إِ ذَايْسنْ أَعذِّيسْ \add وَاهَا\add*.“
\v 13 شّْهَاذثْ-أَ ذ ثِيذتّْ. س ؤُينِّي وبّخْ أَسنْ س جّهْذْ، حِيمَا أَذْ إِڒِينْ ذ إِصْحَاحنْ ذِي لْ-إِيمَانْ،
\v 14 وَارْ تِّيشنْ شَا ثَايْنِيثْ إِ ثْحُوجَا ن وُوذَاينْ ذ ثِيوصَّا ن إِوْذَانْ نِّي إِوْشِينْ س وعْرُورْ إِ ثِيذتّْ. \x ◘ \xo 1:‏14 \xt إِشا. 29‏:‏13؛ مت. 15‏:‏9؛ كُول. 2‏:‏22؛ 1 تِيم. 1‏:‏4؛ 4‏:‏7؛ 6‏:‏20. \x*
\v 15 إِ ؤُمزْذَاڭْ مَارَّا ذ ثَازْذُوڭِي، مَاشَا إِ يِينِّي إِتّْوَاخمْجنْ ذ يِينِّي وَارْ يُومِيننْ، إِ نِيثْنِي ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ وَارْ ثِيزْذِيڭْ، مِينْزِي إِخَارِّيصنْ نْسنْ ذ ثْنفْسشْثْ نْسنْ خمْجنْ. \x ◘ \xo 1:‏15 \xt مت. 15‏:‏11؛ 23‏:‏25؛ ڒخ. 10‏:‏15؛ رُوم. 14‏:‏20، 23. \x*
\v 16 نِيثْنِي شهّْذنْ أَقَا سّْننْ أَربِّي، مَاشَا نْضَارنْ ث س ڒخْذَايمْ نْسنْ. يَاعُّوثْ مِينْ تّڭّنْ، أَقَا وَارْ تّطِّيعنْ شَا، وَارْ نفّْعنْ ؤُڒَا إِ يِيشْثْ ن ڒْخذْمثْ إِصبْحنْ.
\b
\b
\c 2
\s1 ثَاغُورِي ن صَّاحْ
\m 
\v 1 مَاشَا شكْ، سِيوڒْ مِينْ إِتّْڒِيقنْ إِ ثْغُورِي ن صَّاحْ.
\m 
\v 2 سڒْمذْ إِمْغَارنْ مَاحنْذْ أَذْ إِڒِينْ فَاقنْ، أَذْ ؤُيُورنْ س ثْسخَّايْثْ ذ ثَازْذُوڭِي ذ لْ-إِيمَانْ ن صَّاحْ ؤُ س ثَايْرِي ذ صّْبَارْ.
\v 3 \add سڒْمذْ\add* ثِيوسُّورَا عَاوذْ أَمُّو، مَاحنْذْ أَذْ ڭُّورنْثْ أَمْ د-إِتّْڒِيقْ أَكْ-ذ ثِيڭّْوُوذِي زِي أَربِّي، وَارْ تّْشقِّيفنْثْ شَا، وَارْ وْشِينْثْ إِ بِينُو، مَاشَا أجّْ إِ-ثنْثْ أَذْ سّْڒمْذنْثْ مِينْ إِصبْحنْ، \x ◘ \xo 2:‏3 \xt 1 تِيم. 2‏:‏9؛ 5‏:‏13؛ 1 بُط. 3‏:‏3. \x*
\v 4 حِيمَا أَذْ شجّْعنْثْ ثِيبْڒِيغِينْ أَذْ ؤُيُورنْثْ س ؤُوقَّارْ، أَذْ خْسنْثْ إِرْيَازنْ نْسنْثْ ذ ثَارْوَا نْسنْثْ،
\v 5 ؤُشَا أَذْ ذَايْسنْثْ يِيڒِي ؤُثبّثْ ذ ثْقدَّاسْثْ، أَذْ وْشنْثْ ثَايْنِيثْ إِ \add أَيْثْ بَابْ ن\add* ثَادَّارْثْ نْسنْثْ، أَذْ ڭّنْثْ أَرَّايْ إِ يرْيَازنْ نْسنْثْ، حِيمَا ؤُڒَا ذ إِجّْ وَارْ إِتّْشقَّافْ شَا ذڭْ وَاوَاڒْ ن أَربِّي. \x ◘ \xo 2:‏5 \xt أَمز. 3‏:‏16؛ 1 كُور. 14‏:‏34؛ أَفا. 5‏:‏22؛ كُول. 3‏:‏18؛ 1 بُط. 3‏:‏1. \x*
\m 
\v 6 شجّْعثْ عَاوذْ إِبْڒِيغنْ حِيمَا أَذْ ؤُيُورنْ س ثْسخَّايْثْ.
\v 7 أڭّْ إِخفْ نّشْ ذِي مَارَّا ذ لْمِيثَالْ، ذِي مَارَّا ڒخْذَايمْ ثِيصبْحَانِينْ، ؤُ خْمِي ثسّْڒمْذذْ، حْضَا مَاحنْذْ أَذْ يِيڒِي وَاوَاڒْ نّشْ ذ صّحْ، \x ◘ \xo 2:‏7 \xt 1 تِيم. 4‏:‏12؛ 1 بُط. 5‏:‏3. \x*
\v 8 س ڒصْفَايثْ بْڒَا ڒْغشّْ، ؤُشَا وَارْ ث إِسّحْقَارْ ؤُڒَا ذ إِجّْ، أَڒْ غَا إِسضْحَا ونِّي ذ أَنغْ إِتّْعكَّاسنْ ؤُمِي وَارْ إِزمَّارْ أَذْ خَانغْ إِسِّيوڒْ س ؤُڒَا ذ إِجّْ ن وَاوَاڒْ إِسّْفطَّاحنْ. \x ◘ \xo 2:‏8 \xt 1 بُط. 2‏:‏12، 15؛ 3‏:‏16. \x*
\m 
\v 9 إِتّْخصَّا إِ إِمْسخَّارنْ حِيمَا أَذْ طَّاعنْ إِ أَيْثْبَابْ نْسنْ ذِي مَارَّا، أَذْ أَسنْ أَرْضَانْ، وَارْ ثنْ تّْعكّْسنْ. \x ◘ \xo 2:‏9 \xt أَفا. 6‏:‏5؛ كُول. 3‏:‏22؛ 1 تِيم. 6‏:‏1، 2؛ 1 بُط. 2‏:‏18. \x*
\v 10 وَارْ إِعدّڒْ أَذْ أَشَارنْ، مَاشَا أجّْ إِ-ثنْ أَذْ سّشْننْ ڒْمَانثْ نْسنْ إِشْنَانْ، حِيمَا أَذْ إِتّْوَاڭّْ شَّانْ إِ ثْغُورِي ن أَربِّي، ونِّي ذ أَنغْ إِتِّيشنْ ثُوذَارْثْ.
\m 
\v 11 مِينْزِي أَرْضَا ن أَربِّي إِ إِسَّاكّْوَاضنْ أَسنْجمْ إِ مَارَّا، أَقَا إِفّغْ-د إِ مَارَّا إِوْذَانْ.
\v 12 أَرْضَا نِّي إِتَّاربَّا أَنغْ مَاحنْذْ أَذْ نتّجّْ ڒقْجَاحثْ ذ نّشْوَاثْ ن دُّونشْثْ، مَاحنْذْ أَذْ ندَّارْ ذِي دُّونشْثْ-أَ س ثْسخَّايْثْ ذ ثْسڭْذَا ؤُ س ثِيڭّْوُوذِي زِي أَربِّي. \x ◘ \xo 2:‏12 \xt أَفا. 1‏:‏4. كُول. 1‏:‏22؛ 2 تِيم. 1‏:‏9؛ 1 يُوح. 2‏:‏16. \x*
\v 13 \add أَمُّو\add* إِ نتّْرَاجَا أَسِيثمْ إِتّْوَابَارْكنْ ؤُڒَا ذ أَسَارْڭبْ ن ؤُعُودْجِي ن أَربِّي أَمقّْرَانْ ذ ونِّي ذ أَنغْ إِتِّيشنْ ثُوذَارْثْ: يَاسُوع لْمَاسِيحْ. \x ◘ \xo 2:‏13 \xt 1 كُور. 1‏:‏7؛ فِيل. 3‏:‏20. \x*
\v 14 نتَّا ذ ونِّي إِ خَانغْ إِوْشِينْ إِخفْ نّسْ ذڭْ ومْشَانْ نّغْ، مَاحنْذْ أَذْ أَنغْ إِسلّكْ زِي مَارَّا ڒْمُوعْصِييّثْ، حِيمَا أَذْ إِسِّيزْذڭْ إِ يِيخفْ نّسْ إِجّْ ن ڒْڭنْسْ إِمحّْضنْ إِ ڒخْذَايمْ ثِيصبْحَانِينْ. \x ◘ \xo 2:‏14 \xt ڭال. 1‏:‏4؛ 2‏:‏20؛ أَفا. 2‏:‏10؛ 5‏:‏2؛ عبر. 9‏:‏14. \x*
\m 
\v 15 سِيوڒْ خْ مَانْ أَيَا، زِييَّارْ ؤُ وبّخْ س مَارَّا جّهْذْ، وَارْ تّجِّي حذْ أَذْ شكْ إِسّحْقَارْ. \x ◘ \xo 2:‏15 \xt 1 تِيم. 4‏:‏12. \x*
\b
\b
\c 3
\m 
\v 1 سعْقڒْ إِ-ثنْ، مَاحنْذْ أَذْ طَّاعنْ إِ ڒْحُوكَّامْ ؤُ إِ صُّولَاطَاثْ، أَذْ أَسنْ ڭّنْ أَرَّايْ، أَذْ إِڒِينْ وجْذنْ إِ ڒْخذْمثْ ثَاصبْحَانْثْ مَامّشْ مَا ثڭَّا، \x ◘ \xo 3:‏1 \xt رُوم. 13‏:‏1، 3‏-‏7؛ 1 بُط. 2‏:‏13. \x*
\v 2 وَارْ تّْشقِّيفنْ ذِي حذْ، وَارْ تّمْشُوبُّوشنْ، أَذْ إِڒِينْ تّبْثنْ ؤُشَا أَذْ سّشْننْ ڒضْرَافثْ إِ مَارَّا إِوْذَانْ زِي مَارَّا إِغزْذِيسنْ. \x ◘ \xo 3:‏2 \xt فِيل. 4‏:‏5؛ 2 تِيم. 2‏:‏24، 25. \x*
\v 3 أَقَا ؤُڒَا ذ نشِّينْ زِيشْ ثُوغَا أَنغْ ذ إِفْغَاڒْ، \add س وُوڒْ\add* وَارْ إِمْثِيننْ، نْودَّارْ، أَقَا أَنغْ ذ إِسمْغَانْ ن عْڒَامْ كُوڒْ نّشْوَاثْ ذ شّهْوَاثْ، ثُوغَا ندَّارْ ذِي ثُوعفّْنَا ؤُڒَا ذِي ڒحْسذْ، ذَايْنغْ أَشْرَاهْ ؤُشَا نْشَارْهْ إِجّنْ ونّغْنِي. \x ◘ \xo 3:‏3 \xt 1 كُور. 6‏:‏11؛ أَفا. 2‏:‏1؛ كُول. 3‏:‏7؛ 1 بُط. 4‏:‏3. \x*
\m 
\v 4 مَاشَا خْمِي ثْبَانْ ثْشُونِي ذ ثَايْرِي ن أَربِّي، ونِّي ذ أَنغْ إِتِّيشنْ ثُوذَارْثْ، \f ◼ \fr 3:‏4 \ft \bd ثَاشُونِي‘\bd* - نِيغْ ’ڒضْرَافثْ‘ نِيغْ ’لْحَانَانَا‘.\f*
\v 5 أَقَا إِوْشَا أَنغْ ثُوذَارْثْ، وَارْ إِدْجِي عْلَاحْسَابْ ڒخْذَايمْ ن ثْسڭْذَا إِ نڭَّا، مَاشَا عْلَاحْسَابْ أَرّحْمثْ نّسْ، عْلَاحْسَابْ أَسِيرْذْ ن وخْڒَاقْ ن جْذِيذْ ذ ثَاجْذِيذثْ س أَرُّوحْ إِقدّْسنْ \x ◘ \xo 3:‏5 \xt ڒخ. 15‏:‏11؛ رُوم. 3‏:‏20، 28؛ 4‏:‏2، 6؛ 9‏:‏11؛ 11‏:‏6؛ ڭال. 2‏:‏16؛ أَفا. 1‏:‏4؛ 2‏:‏4، 9؛ 2 تِيم. 1‏:‏9. \x*
\v 6 إِ خَانغْ د-إِفَارّغْ س ؤُفيّضْ س يَاسُوع لْمَاسِيحْ، ونِّي ذ أَنغْ إِتِّيشنْ ثُوذَارْثْ، \x ◘ \xo 3:‏6 \xt حِز. 36‏:‏25. \x*
\v 7 حِيمَا أَذْ نتّْوَاسڭّذْ س أَرْضَا نّسْ، أَذْ نذْوڒْ ذ إِوْرِيثنْ س ؤُسِيثمْ ذِي ثُوذَارْثْ إِتّْذُومَانْ.
\m 
\v 8 أَوَاڒْ-أَ ذَايسْ ڒْمَانثْ، ؤُشَا نشّْ خْسغْ عَاوذْ أَذْ ثكَّارذْ أَذْ ثْبدّذْ س جّهْذْ خْ مَانْ أَيَا، حِيمَا إِنِّي إِتّشْڒنْ خْ أَربِّي، أَذْ محْضنْ مَاحنْذْ أَذْ شبَّارنْ ڒبْذَا ذِي ڒخْذَايمْ ثِيصبْحَانِينْ. ثِيمسْڒَايِينْ-أَ شْنَانْثْ ؤُ ذَايْسنْثْ نّْفَاعْ إِ إِوْذَانْ.
\v 9 مَاشَا بعّذْ خْ ؤُمْحَارْوضْ أَبُوهَاڒِي، خْ ثْهُوجَا ن ثَاصِيڒَاثْ، خْ ؤُمنْغِي ؤُ خْ إِمْشُوبَّاشْ ن إِمْسڒْمَاذنْ ن إِذْلِيسنْ، مِينْزِي ذِي \add مَارَّا\add* مَانْ أَيَا وَارْ ذَايسْ بُو نّْفَاعْ، أَقَا مَانْ أَيَا ذ ڒْبَاطڒْ. \x ◘ \xo 3:‏9 \xt 1 تِيم. 1‏:‏4؛ 4‏:‏7؛ 6‏:‏20؛ ثِيث. 1‏:‏14. \x*
\m 
\v 10 مَاڒَا ذِينْ حذْ إِسّْبطَّا، إِتّْخصَّا كنِّيوْ أَذْ أَسْ ثَاڭِيمْ أَوَارْنِي ڒَامِي ث ثْوبّْخمْ إِشْثْ ن ثْوَاڒَا ؤُ إِشْثْ ن ثْوَاڒَا نّغْنِي. \x ◘ \xo 3:‏10 \xt مت. 18‏:‏17؛ رُوم. 16‏:‏17؛ 2 تس. 3‏:‏6؛ 2 تِيم. 3‏:‏5؛ 2 يُوح. 10. \x*
\v 11 أَقَا ثسّْنمْ بلِّي وَانِيثَا ذ أَمْفَارْيَاضْ، أَقَا ذ أَمذْنُوبْ، أَقَا إِتّْوَاحَاسبْ زڭْ إِخفْ نّسْ.
\b
\s1 أَوَاڒْ ذ ؤُسدْجمْ أَنڭَّارُو
\m 
\v 12 خْ مِينِّي إِ غَاركْ د غَا سّْقَاذغْ أَرْثِيمَاسْ نِيغْ ثِيشِيكُوسْ، أڭّْ ثِيزمَّارْ مَاحنْذْ أَذْ غَارِي د-ثَاسذْ ذغْيَا غَارْ نِيكُوپُولِيسْ، مِينْزِي أَقَا ڭِّيغْ أَذْ ذِينْ سّعْذُوغْ ڒْمشْثَا. \x ◘ \xo 3:‏12 \xt ڒخ. 20‏:‏4؛ أَفا. 6‏:‏21؛ 2 تِيم. 4‏:‏12. \x*
\m 
\v 13 زنَاسْ، أَمْسڒْمَاذْ ن إِذْلِيسنْ، ذ أَپُولُّوسْ، أَوْيمْ ثنْ-د مْلِيحْ ذڭْ وبْرِيذْ، حِيمَا وَارْ ذ أَسنْ إِتّْخصِّي ؤُڒَا ذ إِشْثْ ن ثْمسْڒَاشْثْ. \x ◘ \xo 3:‏13 \xt ڒخ. 18‏:‏24؛ 1 كُور. 1‏:‏12. \x*
\v 14 نِيثْنِي أَذْ سّڒْمَاذنْ إِنِّي نّغْ مَاحنْذْ أَذْ ڭّنْ ڒخْذَايمْ ثِيصبْحَانِينْ مَاڒَا ذِينْ ڒحْوجْ أَمقّْرَانْ، حِيمَا وَارْ تِّيڒِينْ بْڒَا ڒْغِيدْجثْ.
\m 
\v 15 مَارَّا وِي كِيذِي ذَانِيثَا تّْسدْجَامنْ خَاكْ س ڒهْنَا. سدْجمْ س ڒهْنَا عَاوذْ خْ يِينِّي ذ أَنغْ إِتّخْسنْ ذِي لْ-إِيمَانْ. أَرْضَا أَذْ كِيومْ يِيڒِي مَارَّا إِذْومْ! أَمِينْ. 
