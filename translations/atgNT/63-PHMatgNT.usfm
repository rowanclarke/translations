\id PHM - Okphela 
\h iFilẹmọ 
\toc1 iFilẹmọ 
\toc2 iFilẹmọ 
\toc3 iFilẹ 
\mt2 Ebe ni iPọlu ọ kẹkẹ ghi 
\mt1 IFilẹmọ 
\c 1  
\p  
\v 1 Mhẹmhẹ iPọlu ni a ri itobọ khi mhi a gbe akanya na iJesu iKirisiti mu shi ọgba ighumha, mhi kẹkẹ ebe ona, ali iTimoti. IFilẹmọ ọmọle anye ni anye ga a gbe akanya, a kẹkẹ ọli ghi,  
\v 2 li shi igbaa oyi eni e mie iJesu iKirisiti suọ ni o la owa oyẹ ali inyọghuo awa ni ọkpotso na lui Apfia ali Achipọsi ni anye ga khi ekhọli-okhuẹ eyi Ẹshinẹgba.\f + \fr 1:2 \ft Li zẹ \fq iKolo 4.17\f* 
\v 3 Ẹshinẹgba Ita awa ali iJesu iKirisiti Ọnọmhuẹ e ka li okhale na ẹ, e ri opfọmhẹ na ẹ. 
\s1 Inono ali iregbenga ni iFilẹmọ ọ mhọli 
\p  
\v 4 IFilẹmọ, ẹghẹghẹ kpa mhi rọ kphẹmhi na Ẹshinẹgba ini mhia sọ iromhi nẹ.  
\v 5 Irari khi mhi suọ inono ni u mhọli na ẹgbọ eyi Ẹshinẹgba nya ali irudunga ni u mhuẹ shi iJesu Ọnọmhuẹ.  
\v 6 Iromhi ni mhia sọ khi, ọ zẹ ni ilakugbe oyawa abi eni e mhọli irudunga oghuo, o ri awa lẹsẹ ikhivọsẹ nya, ni awa mhọli irari khi awa kugbe iKirisiti ọ.  
\v 7 Inono oyẹ i, inyọghuo-mhẹ, o she ri ukpokpomhi oghẹlẹ ghi mhẹ, o gbo ri udu shi mhẹ ọ! U gbo guise udu oyi eni e miesuọ le. 
\s1 IPọlu ọ sọ iromhi na Onẹsimusi 
\p  
\v 8 Itobọ ighọ, ini o riẹ khia khi mhi kha dobẹ mhẹsẹ nẹ emini o ti ni u riẹlẹ abi inyọghuoẹ elemhi iKirisiti,  
\v 9 mhi ya ri itobọ inono lema ẹ, abi mhẹmhẹ iPọlu ni ọ she khi ọgbhali ni mhi gbo khi ọni ọọ ga ọyi iJesu iKirisiti memena.  
\v 10 Mhi lema ẹ shi itobọ oyi Onẹsimusi ni ọ la elemhi ọgba ighumha ana mele omimhẹ-a.\f + \fr 1:10 \ft Li zẹ \fq iKolo 4.9\f* 
\v 11 Ni o khia khi waa ke kpẹ mhuẹ emini a rọli ẹ riẹlẹ, ama memena, ọ she mhuẹ emini awa rọli ya riẹlẹ. 
\p  
\v 12 Mhi ghie ọli nyenẹ egbe ẹ ghi ẹ, rọte ekelemhi udu inono oyẹmhẹ.  
\v 13 Mhii kha zẹ ọli obọ ni ọ nu mhẹ la akana ni ọ to ẹloli ẹ ke ri ẹloe khu mhẹ abi mhi li la ọgba oghumha ena shi usomhi onete oyi Ẹshinẹgba.  
\v 14 Ama mhi aa nono ni mhi riẹlẹ emhi okhọghuo ni u waa lama shi, ni a rọ bhale ya ẹ khi ikanya enete ni u gbe, eri u rọte elemhi udu gbe wẹ. Ni ọa khi eri a tanọ ẹ abọ shi ọ.  
\v 15 A dobẹ ẹ mẹ khi eri Onẹsimusi ọ rọte ẹ obọ vu ukuku ẹghẹghẹ, ni ọ kha ke jele deba ẹ, ọ nu ẹ la agbọagbọ.  
\v 16 Ọa ke khi oghumha tsẹ, ama ọ fu dọsẹ oghumha, inyọghuo awa elemhi iKirisiti ọ ke khi. Ọni awa nono ingme oyọli egbegbọ ọ khi, abi ọgbọ ali inyọghuo, elemhi Ọnọmhuẹ. 
\p  
\v 17 Ini o khia khi u lẹsẹ mhẹ shi ọnuzava ọyẹ, gbo mie ọli abi u kha li mie mhẹ.  
\v 18 Ama ini o khia khi ọ lue nẹ, okekhia khi eri ọ lo ẹ ota, ku ota eyọli lo ẹkuẹ oyẹmhẹ.  
\v 19 Mhẹmhẹ iPọlu mhi ri obọ oyẹmhẹ ẹ kẹkẹ ebe ona. Mhiẹ yẹ khi mhi ya fali ẹ ẹwẹ. Mhia ke khi ọni ọ ke gbolo ẹ yele ẹ le khi mhẹmhẹ mhi mhọli agbọ oyẹ nya.  
\v 20 Irarighọ, inyọghuo, ri ikpaghiobọ ona na mhẹ itobọ Ọnọmhuẹ, abi inyọghuo ni awa ga mie iKirisiti suọ ri oghẹlẹ shi mhẹ udu.  
\v 21 Mhi lẹsẹ gboo khi abi mhi liẹ kẹkẹ ebe ona ghi ẹ, khi u ya riẹlẹ emini mhiẹ u riẹlẹ, mhi ga lẹsẹ khi u ya riẹlẹ dọsẹ abi mhiẹ u li riẹlẹ. 
\p  
\v 22 Gbo li riẹlẹ elemhi owa oghuo shi ekẹ khẹ mhẹ. Irari khi mhi lẹsẹ khi a ya rue mhẹ obọ a na ẹ, ni o ri iromhi ni a sọ bhale ya tsẹ. 
\p  
\v 23 Epafurasi ni anye ga khi eni ẹẹ ga eyi iJesu iKirisiti, ọọ tsẹ ẹ.\f + \fr 1:23 \ft Li zẹ \fq iKolo 1.7; 4.12\f* 
\v 24 Ighọ li khi iMaki ali Arisitakusi ali iDẹmasi ali iLuku ni anye ga gbe akanya, ẹẹ tsẹ ẹ.\f + \fr 1:24 \ft Li zẹ \fq Ika 12.12,25; 13.13; 15.37-39; 19.29; 27.2; iKolo 4.10,14; 2 iTimo 4.10,11\f* 
\p  
\v 25 Okhale oyi iJesu iKirisiti Ọnọmhuẹ o ka la ayẹmhẹ oyi ẹẹ nya.