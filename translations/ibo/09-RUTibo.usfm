\id RUT - Biblica® Open Igbo Contemporary Bible 2020 
\h Rut 
\toc1 Rut 
\toc2 Rut 
\toc3 Rut 
\mt1 Rut 
\c 1  
\s1 Rut na Naomi 
\p  
\v 1 Nʼoge ndị ahụ, mgbe ndị ikpe na-achị, oke ụnwụ dara nʼala Izrel. Nʼihi ụnwụ a, otu nwoke, onye Betlehem, obodo dị na Juda, kwakọọrọ ihe ya niile, duru nwunye ya, na ụmụ ya ndị ikom abụọ, hapụ obodo ya gaa biri dịka ọbịa nʼala Moab.  
\v 2 Aha nwoke a bụ Elimelek. Aha nwunye ya bụ Naomi, ma aha ụmụ ya ndị ikom abụọ bụ Mahlọn na Kilịọn. Ha bụ ndị Efrat\f + \fr 1:2 \ft Efrata bụ aha ezinaụlọ ebe Elimelek si pụta. Ọ bụ Elimelek gụrụ mpaghara ala ahụ dị nso Betlehem, Efrata. Mgbe ụfọdụ a na-akpọkwa ya Betlehem Efrata. \xt Rut 4:11; Jen 35:19; 1Sa 17:12; Mai 5:2\f* si Betlehem nke dị na Juda. Ha bịarutere nʼala Moab biri nʼebe ahụ. 
\p  
\v 3 Ma Elimelek di Naomi nwụrụ, hapụ naanị Naomi, na ụmụ ya ndị ikom abụọ.  
\v 4 Ha lụrụ ndị nwunye site nʼetiti ndị inyom Moab. Aha nke mbụ bụ Ọpa, ebe aha nke abụọ bụ Rut. Ha biri nʼebe ahụ ihe dị ka afọ iri.  
\v 5 Mahlọn na Kilịọn mechara nwụọ. Ya mere, Naomi ghọrọ onye gba aka di, na onye gba aka ụmụ. 
\s1 Naomi na Rut alaghachi nʼobodo Betlehem 
\p  
\v 6 Mgbe Naomi nọ nʼala Moab nụ na \nd Onyenwe anyị\nd* eletala ndị Izrel site nʼinye ha ihe oriri, Naomi na ndị nwunye ụmụ ya abụọ kwadoro ịlaghachi azụ nʼala Izrel.  
\v 7 Ya mere, Naomi na ndị nwunye ụmụ ya abụọ hapụrụ ala Moab ebe ha bi kemgbe, malite ịgbaso ụzọ ha ga-esi laghachi nʼala Juda. 
\p  
\v 8 Mgbe ahụ, Naomi gwara ndị nwunye ụmụ ya abụọ okwu sị ha, “Ngwa, onye ọbụla nʼime unu laghachi nʼụlọ nne ya.\f + \fr 1:8 \ft Omenaala bụ na ndị ada na-alụbeghị di, na ndị ada di ha nwụrụ, na-ebinyere nne ha. \xt Jen 24:28,67\ft  Nʼakwụkwọ Rut isi abụọ, amaokwu nke iri na otu, e mere ka anyị mata na nna Rut ka dị ndụ.\f* Ka \nd Onyenwe anyị\nd* gosi unu obiọma dịka unu si gosi mụ onwe m, na ndị unu nwụrụ anwụ.  
\v 9 Ka \nd Onyenwe anyị\nd* nyekwa unu di ọzọ ma meekwa ka unu chọta udo nʼezinaụlọ ọzọ.” 
\p Mgbe ahụ Naomi suturu ha ọnụ, ha niile kwara akwa.  
\v 10 Ma Ọpa na Rut zara Naomi sị ya, “E, anyị agaghị ala. Anyị ga-esoro gị laghachikwuru ndị gị.” 
\p  
\v 11 Naomi zara sị ha, “Laghachinụ ụmụ m, ọ bụ nʼihi gịnị ka unu ga-eji soro m laa? E nwere m ike ịmụta ụmụ ndị ikom ọzọ ndị ga-abụ di unu?\f + \fr 1:11 \ft Ajụjụ a bụ nʼihi omenaala ndị Juu, nke bụ, na nwanyị ọbụla na-amụtaghị nwa tupu di ya a nwụọ, na nwanne di ya ga-alụrụ ya. \xt Jen 38:6-8; Dit 25:5-10\f* 
\v 12 Laghachinụ azụ ụmụ m. Emeela m agadi ịlụ di ọzọ. A sịkwarị na olileanya fọdụụrụ m ịlụ di na ịmụta ụmụ ndị ikom nʼabalị taa,  
\v 13 unu ga-echere ruo mgbe ha tolitere? Unu ga-anọ na-alụghị di ọzọ? Mba, ụmụ m ndị inyom, ọnọdụ m dị ilu karịa nke unu, nʼihi\f + \fr 1:13 \ft \xt Nkp 2:15; Job 19:12; Abụ 38:2\f* na \nd Onyenwe anyị\nd* esepụtala aka ya imegide m.” 
\p  
\v 14 Ha welitere olu ha kwaa akwa ọzọ. Mgbe ahụ Ọpa suturu nne di ya ọnụ ma Rut kwusịrị ike nʼebe ọ nọ. 
\p  
\v 15 Ma Naomi gwara ya sị, “Lee, nwunye nwanne di gị alaghachikwurula ndị nwe ya na chi ya niile, soro ya laa.” 
\p  
\v 16 Ma Rut zara, “Akwagidela m ka m hapụ gị, maọbụ ime ka m site nʼiso gị chigharịa. Aga m esoro gị gaa ebe ọbụla ị na-aga. Aga m esokwa gị biri nʼebe ọbụla ị ga-ebi; ndị gị ga-abụ ndị m, Chineke gị ga-abụkwa Chineke m,  
\v 17 ebe ị nwụrụ ka m ga-anwụ, ebe ahụ kwa ka a ga-eli m. Ka \nd Onyenwe anyị\nd* mesoo m mmeso, otu ọbụla mmeso ahụ si dị njọ, ma ọ bụrụ na m ekwere ka ihe ọzọ, ma ọ bụghị ọnwụ, kewaa mụ na gị.”  
\v 18 Mgbe Naomi hụrụ na Rut ekpebiela nʼime onwe ya iso ya, ọ kwụsịrị ịgwa ya okwu ọzọ. 
\p  
\v 19 Ya mere, ha abụọ gagidere ije rute Betlehem. Mgbe ha batara Betlehem, obodo ahụ mere mkpọtụ, nʼihi nlọta ha. Ndị inyom jụrụ sị, “Ọ bụ Naomi bụ nke a nʼezie?” 
\p  
\v 20 Ma Naomi zara ha sị, “Unu akpọkwala m Naomi, kama kpọọnụ m Mara, nʼihi na Onye pụrụ ime ihe niile emeela ka ndụ m jupụta nʼihe ilu.  
\v 21 Aka m juru eju mgbe m si nʼebe a pụọ, ma \nd Onyenwe anyị\nd* emeela ka m gbara aka lọta. Gịnị mere unu ji akpọ m Naomi ebe ọ bụ na \nd Onyenwe anyị\nd* gbakụtara m azụ, ebe ọ bụ na Onye pụrụ ime ihe niile mere ka nsogbu dakwasị m.” 
\p  
\v 22 Otu a ka Naomi na Rut onye Moab bụ nwunye nwa ya si laghachi nʼala Juda. Oge ha ji lọbata nʼobodo Betlehem bụ oge a na-amalite ịghọ ọka balị.\f + \fr 1:22 \ft Nʼoge owuwe ihe ubi, ọka balị bụ ihe ubi mbụ a na-eweta, mgbe izu ụka ole na ole gasịrị, ọ bụrụ oge owuwe ihe ubi wiiti. \xt Rut 2:23; 2Sa 21:9\f* 
\c 2  
\s1 Rut ezute Boaz 
\p  
\v 1 Ma Naomi nwere otu nwanne di ya, onye bara ụba, bụrụkwa onye a maara nke ọma, onye si nʼagbụrụ Elimelek. Aha nwoke a bụ Boaz. 
\p  
\v 2 Rut onye Moab, gwara Naomi okwu sị ya, “Kwere ka m gaa nʼubi ebe a na-aghọ ọka, ka m lee ma m ga-achọta ihuọma nʼihu ndị na-aghọ ọka, ndị ga-ekwere ka m tụtụkọta ọka\f + \fr 2:2 \ft Ị tụtụkọta ọka ndị a hapụrụ mgbe a na-ewe ihe ubi, bụ oke ndị inyom di ha nwụrụ anwụ, na ụmụ mgbei na ndị ọbịa. \xt Lev 19:9; Dit 24:19\f* ndị ha hapụrụ.” 
\p Naomi zara sị ya, “Ọ dị mma nwa m, gaa.”  
\v 3 Ya mere, Rut pụrụ gaa na-atụtụ ọka nʼazụ ndị na-ewe ihe ubi. Ma dịka ihe si dị, Rut chọpụtara na ubi ọ na-atụtụ ọka bụ ubi Boaz, onye si nʼagbụrụ Elimelek. 
\p  
\v 4 Nʼoge ahụ, Boaz nʼonwe ya si na Betlehem bịarute nʼubi ahụ, kelee ndị ahụ na-aghọ mkpụrụ nʼubi sị ha, “\nd Onyenwe anyị\nd* nọnyere unu.” 
\p Ha niile zakwara sị ya, “\nd Onyenwe anyị\nd* gọzie gị.” 
\p  
\v 5 Mgbe Boaz hụrụ Rut, ọ jụrụ onyeisi ndị ọrụ ubi ya sị, “Onye ka nwanyị a bụ?” 
\p  
\v 6 Onye nlekọta ọrụ ubi ahụ zaghachiri, “Ọ bụ onye Moab ahụ so Naomi lọta.  
\v 7 Ọ sịrị, ‘Biko kwere ka m soro ndị ọrụ nʼazụ tụtụkọtaa ukwu ọka ha hapụrụ.’ Kemgbe ụtụtụ ọ bịara, ọ kwụsịbeghị ọrụ ya karịakwa naanị nwa mgbe nta o zuru ike nʼokpuru ndo.” 
\p  
\v 8 Ya mere, Boaz gwara Rut okwu sị ya, “Nwa m nwanyị, gee m ntị. Agakwala ịtụtụ ọka nʼubi ọzọ, esitekwala nʼebe a pụọ. Soro ụmụ agbọghọ na-ejere m ozi nọdụ nʼebe a.  
\v 9 Lezie anya nʼubi ebe ndị ikom na-ewe ihe ubi, ma soro ụmụ agbọghọ ndị a. Enyela m ndị ikom ndị a iwu ka ha ghara ịmetụ gị aka. Mgbe ọbụla agụụ mmiri gụrụ gị, gaa nʼite mmiri ndị ahụ ndị ikom gbanyere mmiri kuru mmiri ṅụọ.” 
\p  
\v 10 Mgbe Boaz na-agwa ya okwu, Rut hulatara isi ya ala. Emesịa o kwuru sị, “Gịnị mere m ji chọta ụdị amara dị otu a nʼebe ị nọ, na ị hụtara m, ebe ị maara na m bụ naanị onye mba ọzọ?” 
\p  
\v 11 Boaz zara sị ya, “Anụla m ihe niile i meere nne di gị site nʼoge di gị nwụrụ, na otu i si hapụ nne gị na nna gị, na ala ebe amụrụ gị, bịa nʼebe a ibi nʼetiti ndị ị na-amaghị na mbụ.  
\v 12 Ka \nd Onyenwe anyị\nd* kwụghachi gị ụgwọ ihe ọma ndị a i mere. Ka \nd Onyenwe anyị\nd* onye bụ Chineke Izrel, onye ị gbabara nʼokpuru nku ya izere ndụ kwụghachi gị nkwụghachi dị ukwu nʼihi ezi ọrụ gị niile.” 
\p  
\v 13 Rut zara sị ya, “Ka m gaa nʼihu na-achọta amara nʼebe ị nọ, onyenwe m. Nʼihi na ị kasịela m obi, gwakwa m, odibo nwanyị gị, okwu dị nro. Ọ bụ ezie na m abụghị otu nʼime ndị odibo nwanyị gị.” 
\p  
\v 14 Mgbe oge iri nri ruru, Boaz sịrị ya, “Bịa nso nʼebe a, were ụfọdụ nri rie, sunyekwa achịcha gị nʼime mmanya viniga.”\f + \fr 2:14 \ft Ọ bụ mmanya gbara ụka a wụnyere mmanụ ntakịrị, ka e ji emepụta mmanya viniga.\f* 
\p Mgbe o soro ndị ahụ na-ewe ihe ubi nọdụ ala iri ihe, o nyere ya ụfọdụ ọka a hụrụ nʼọkụ. O riri, rijuo afọ ma nri e nyere ya fọdụrụ.  
\v 15 Mgbe o biliri ịchịkọtakwa ọka, Boaz nyere ụmụ okorobịa ya iwu, “Hapụnụ ya ka ọ chịkọta ọka ọ bụladị nʼetiti ukwu ọka ndị guzo eguzo, unu agwala ya okwu ihere ọbụla.  
\v 16 Unu sitekwa nʼukwu ọka mịpụtara ya ụfọdụ tụsara ya nʼala ka ọ tụtụrụ. Unu abarala ya mba.” 
\p  
\v 17 Ya mere, Rut tụtụrụ ọka nʼubi ahụ ruo oge anyasị. Mgbe ọ fuchasịrị ọka balị niile ọ tụtụtara, o nwetara ihe nwere ike iru otu bushel.  
\v 18 O buuru ya baa nʼime obodo, bunye ya nne di ya, nyekwa ya nri o rifọrọ mgbe o rijuchara afọ. 
\p  
\v 19 Nne di ya jụrụ ya, “Ebee ka ị tụtụrụ ọka taa? Ebee ka ị rụrụ ọrụ? Ka nwoke ahụ hụtara gị bụrụ onye a gọziri agọzi.” 
\p Rut kọọrọ nne di ya banyere onye ahụ ọ rụrụ ọrụ na nke ya. Ọ sịrị, “Aha nwoke mụ na ya rụrụ ọrụ bụ Boaz.” 
\p  
\v 20 Mgbe ahụ Naomi zara nwunye nwa ya sị, “Onye \nd Onyenwe anyị\nd* gọziri ka ọ bụ, onye na-ahapụbeghị igosi ebere ya nye ndị dị ndụ na ndị nwụrụ anwụ. Nwoke a bụ otu nʼime ndị agbụrụ anyị, otu onye nʼime ndị onye mgbapụta anyị.”\f + \fr 2:20 \fq Onye mgbapụta anyị \ft Onye dị otu a, aghaghị ịbụ onye metụtara nwoke ahụ nwụrụ anwụ. O nwere ike bụrụ nwanne ya maọbụ nwanna ya. Ọ bụ ya ka ọ dịrị dịka iwu ahụ si dị, inwetaghachi maọbụ zụghachite ala niile nke onye ahụ nwụrụ anwụ. Iwu ahụ bụ, na onye mgbapụta a dị nso, ga-alụ nwunye nwanne maọbụ nwanna ya ahụ nwụrụ anwụ, ma ọ bụrụ na ọ mụtaghị nwa. \xt Dit 25:5-10\f* 
\p  
\v 21 Mgbe ahụ Rut, onye Moab sịrị, “Ihe ọ sịkwara m bụ, ‘Nọnyere ndị ọrụ m tutu ruo mgbe ha ghọchara ọka niile dị nʼubi m.’ ” 
\p  
\v 22 Naomi sịrị Rut, nwunye nwa ya, “Nwa m nwanyị, ọ kaara gị mma ime dịka o kwuru. Soro ụmụ agbọghọ nọ nʼubi ya nʼazụ tụtụọ ọka ị na-atụtụ, nʼihi na nʼubi onye ọzọ, e nwere ike imerụ gị ahụ.” 
\p  
\v 23 Ya mere, Rut sogidere ụmụ agbọghọ Boaz na-atụtụ ọka, tutu ruo ọgwụgwụ ịghọ ọka balị na wiiti. Ya na nne di ya bigidekwara. 
\c 3  
\s1 Rut ejekwuru Boaz 
\p  
\v 1 Otu ụbọchị, Naomi, nne di Rut, gwara ya okwu sị, “Nwa m nwanyị, ọ bụ na o rubeghị mgbe m ga-achọtara gị ụlọ nke aka gị, ebe a ga-anọ lekọtazie gị anya nke ọma?  
\v 2 Ọ bụ na Boaz, onye gị na ụmụ agbọghọ ya so rụọ ọrụ ịchịkọta ọka abụghị onye agbụrụ anyị? Lee, nʼabalị taa ka ọ ga-afụcha ọka balị nʼebe ịzọcha ọka.  
\v 3 Ugbu a, gaa saa ahụ gị, teekwa mmanụ isi ụtọ, yirikwa uwe mara mma. I mesịa, gaa nʼebe ịzọcha ọka,\f + \fr 3:3 \ft Ọ bụ ọrụ ụmụ anụmanụ ịzọcha ọka nʼoge ehihie. Ma nʼoge uhuruchi, mgbe ikuku nʼefe, ndị ọrụ ubi na-eji ihe dịka nkata na-awụli ọka ahụ elu nʼihi ịyọcha ya. Dịka ha na-awụli ya elu, ikuku na-ebufu igbugbo ọka na ahịhịa, ma mkpụrụ ọka na-adịgide nʼime nkata ahụ.\f* ma ekwekwala ka ọ hụ gị, tutu ruo mgbe o risiri nri ṅụọkwa ihe ọṅụṅụ.  
\v 4 Leziekwa anya chọpụta ebe ọ ga-edina rahụ ụra. Mgbe ị maara na ọ rahụla ụra nke ọma, gaa kpughepụ akwa o ji kpuchie ụkwụ ya, dinaakwa ala nʼebe ahụ. Ọ ga-agwa gị ihe ị ga-eme.” 
\p  
\v 5 Rut zara sị, “Aga m eme ihe ọbụla ị sị m mee.”  
\v 6 Ya mere, Rut pụrụ nʼabalị ahụ gaa nʼebe ịzọcha ọka ahụ, meekwa dịka nne di ya gwara ya. 
\p  
\v 7 Mgbe Boaz risiri nri ma ṅụọkwa ihe ọṅụṅụ, mmụọ ya dịkwa mma, ọ gara ka ọ dinaa ala na nsọtụ ebe atụkọtara akpa ọka. Rut jiri nwayọọ gaa nʼebe ahụ, kpughepụ akwa o ji kpuchie ụkwụ ya abụọ, dina nʼakụkụ ụkwụ ya.  
\v 8 Nʼetiti abalị Boaz kụjara teta na mberede, tụgharịa, ma lee o nwere nwanyị dina nʼala ala ụkwụ ya. 
\p  
\v 9 Ọ jụrụ ya sị, “Ị bụ onye?” 
\p Rut zara ya sị, “Abụ m Rut, ohu gị nwanyị, onyenwe m. Were ọnụ ọnụ akwa gị kpukwasị m,\f + \fr 3:9 \ft Mgbe nwoke were akwa, maọbụ ọnụ akwa gbasaa nwanyị nʼahụ, nke a na-egosi na ọ chọrọ ịlụ ya. \xt Izk 16:8\f* nʼihi na ị bụ onye agbụrụ mgbapụta m dị nso.” 
\p  
\v 10 Boaz zara sị ya, “\nd Onyenwe anyị\nd* gọzie gị, nwa m nwanyị. Ịhụnanya i gosiri ugbu a akarịala nke i gosiri na mbụ, nʼihi na i gbasoghị ụmụ okorobịa, ma ha bụ ọgaranya maọbụ ogbenye.  
\v 11 Ma ugbu a, nwa m nwanyị, atụla ụjọ. Aga m emezuru gị dịka i si rịọọ, nʼihi na mmadụ niile maara na ị bụ onye nwere ezi agwa.  
\v 12 Ọ bụ ezie na m bụ onye mgbapụta dị nso nke ezinaụlọ anyị, ma o nwere onye ọzọ dị ezi nso karịa m.  
\v 13 Nọdụ nʼebe a nʼabalị a. Nʼụtụtụ, ọ bụrụ na onye ahụ ekwere imezu ọrụ ya dịka onye mgbapụta, ya rụzuo ya. Ọ bụrụ na o kwere, ọ dị mma, ọ bụrụkwanụ na o kweghị, dịka \nd Onyenwe anyị\nd* na-adị ndụ, aga m emezu ya. Ugbu a, dinara ala ruo ụtụtụ.” 
\p  
\v 14 Ya mere, Rut dinara nʼụkwụ ya ruo ụtụtụ. Ma chi abọzibeghị nke ọma mgbe o si nʼebe ahụ bilie nʼihi na Boaz sịrị ya, “Ekwela ka onye ọbụla mata na nwanyị bịara nʼebe ịzọcha ọka.” 
\p  
\v 15 O gwakwara Rut okwu sị ya, “Chịta akwa mgbokwasị gị, gbasaa ya.” Ya mere Rut gbasara akwa ya, Boaz manyere ya ọtụtụ ọka balị isii, bokwasị ya Rut, onye buuru ya banye nʼime obodo. 
\p  
\v 16 Mgbe Rut bịakwutere nne di ya, Naomi jụrụ ya sị, “Nwa m nwanyị, olee otu ihe si gaa?” 
\p Rut gwara ya ihe niile Boaz meere ya, sị,  
\v 17 “Ọ manyeere m ọtụtụ ọka balị isii ndị a si m, ‘O kwesighị ka ị gbara aka lakwuru nne di gị.’ ” 
\p  
\v 18 Naomi zara si ya, “Chere, nwa m nwanyị, ruo mgbe ị ga-ahụ otu okwu a ga-esi bie. Nwoke a agaghị ezu ike tutu ruo mgbe o kwubiri okwu a taa.” 
\c 4  
\s1 Boaz alụọ Rut 
\p  
\v 1 Ya mere, Boaz pụrụ gaa nʼọnụ ụzọ ama obodo ahụ, nọdụ ala nʼebe ahụ. Ọ dịghị anya onye mgbapụta ahụ dị nso nke Boaz kwuru okwu banyere ya si nʼebe ahụ na-agafe. Boaz kpọrọ ya sị, “Enyi m bịa nọdụ ala.” Ọ bịara nọdụ ala. 
\p  
\v 2 Boaz kpọrọ mmadụ iri, ndị bụ ndị okenye obodo ahụ, gwa ha, “Nọdụnụ ala nʼebe a.” Ha mere otu ahụ.  
\v 3 Mgbe ahụ, ọ gwara nwoke onye mgbapụta ahụ dị nso sị, “Naomi, onye si nʼala ndị Moab lọta, na-achọ ire ala nwanna anyị nwoke Elimelek.  
\v 4 Ahụrụ m na o kwesiri ka m buru ụzọ gwa gị ka ị zụọ ya nʼihu ndị a nọ ọdụ nʼebe a, na nʼihu ndị okenye obodo anyị. Ọ bụrụ na ị ga-agbara ya, gwa m, ọ bụrụkwanụ na ị gaghị agbara ya, gwa m, ka m mara ihe m ga-eme. Nʼihi na ọ bụ gị ka ọ dịrị ịgbapụta ya. Mụ onwe m na-esote gị.” 
\p Ọ zara sị, “Aga m agbapụta ya.” 
\p  
\v 5 Mgbe ahụ, Boaz sịrị, “Nʼụbọchị ị ga-azụrụ ala ahụ site nʼaka Naomi ka ị ga-enwetakwa Rut onye Moab bụ nwunye onye ahụ nwụrụ anwụ, ime ka aha onye ahụ nwụrụ anwụ na ihe nketa ya na-adịgide.” 
\p  
\v 6 Na nke a, onye nchekwa mgbapụta ahụ sịrị, “Apụghị m ịgbapụta ya nʼihi na e nwere m ike itinye ihe nketa m na nsogbu. Gị onwe gị gbapụta ya. Nke a agaghị ekwe m omume.” 
\p  
\v 7 Na mgbe ochie nʼala Izrel,\f + \fr 4:7 \ft \xt Dit 25:7-10\f* ime ka mgbapụta ihe na iwefe ihe site nʼaka baa nʼaka zuo oke, otu onye ga-eyipụ akpụkpọụkwụ\f + \fr 4:7 \ft Gbaa mba niile dị nʼetiti ọwụwa anyanwụ gburugburu, akpụkpọụkwụ bụ ihe na-egosipụta onye nwe ihe. Mgbe mmadụ nyere onye ọzọ akpụkpọụkwụ ya, nʼihi ihe ọbụla, nke a pụtara inye ya ikike i sị, site ugbu a gawa ihe ahụ a bụrụla nke gị. \xt Abụ 60:8; Ems 2:6; 8:6\f* ya were ya nye onye nke ọzọ. Otu a ka e si ekpebi okwu gbasara orire na ọzụzụ, na-ime ka ihe ndị ọzọ guzosie ike nʼala Izrel. 
\p  
\v 8 Nʼihi ya, mgbe nwoke ahụ gwara Boaz sị ya, “Zụrụ ala ahụ nʼonwe gị,” o yipụtara akpụkpọụkwụ ya. 
\p  
\v 9 Mgbe ahụ, Boaz kwupụtara na ntị ndị okenye ndị ahụ na ndị mmadụ nọ nʼebe ahụ sị ha, “Unu bụ ndị akaebe na esitela m nʼaka Naomi zụrụ ala niile Elimelek, na Kilịọn na Mahlọn nwere.  
\v 10 Azụrụkwala m Rut onye Moab, nwunye Mahlọn ka ọ bụrụ nwunye m, ime ka aha onye nwụrụ anwụ na ihe nketa ya na-adịgide, ka aha ha hapụ ifu nʼetiti ndị ikwu ya maọbụ site nʼobodo ebe amụrụ ya. Taa unu niile bụ ndị akaebe m.” 
\p  
\v 11 Mgbe ahụ, ndị okenye na ndị niile nọ nʼọnụ ụzọ ama kwuru sị, “Anyị bụ ndị akaebe. Ka \nd Onyenwe anyị\nd* mee nwanyị a na-abata nʼezinaụlọ gị ka ọ dịrị ka Rechel na Lịa,\f + \fr 4:11 \ft Rechel na Lịa bụ ndị mụrụ ebo niile nke Izrel, nʼotu aka ahụkwa, agbụrụ Devid na onye nzọpụta ahụ sitere na Rut pụta. Ị ga-agụta nke a nʼakwụkwọ \xt Mat 1:5,6,16\f* ndị ebo Izrel niile sitere na ha pụta! Ka ị bụrụkwa ọgaranya nʼagbụrụ Efrata, ghọọkwa onye a ma ama na Betlehem.  
\v 12 Site nʼụmụ \nd Onyenwe anyị\nd* ga-enye gị site na nwanyị a, ka ezinaụlọ gị dịrị ka nke Perez\f + \fr 4:12 \ft Perez bụ nna ochie Boaz. \xt Mat 1:3; Luk 3:33\f* onye Tama mụụrụ Juda.” 
\s1 Nwa nwoke a mụtara Naomi 
\p  
\v 13 Boaz kpọọrọ Rut ka ọ bụrụ nwunye ya. Mgbe ya na Rut dinakọrọ, \nd Onyenwe anyị\nd* nyeere ya aka ịtụrụ ime. Ọ mụkwara nwa nwoke.  
\v 14 Mgbe ahụ, ndị inyom obodo ahụ bịakwutere Naomi sị ya, “Onye a gọziri agọzi ka \nd Onyenwe anyị\nd* bụ, onye na-agbawaghị gị aka onye agbụrụ mgbapụta dị nso. Ka aha ya bụrụ ihe ga-ada ụda nʼala Izrel niile.  
\v 15 Ya wetakwara gị ntute na ndụ gị ma bụrụkwa onye ga-azụ gị nʼisi awọ gị. Nʼihi na nwunye nwa gị, onye hụrụ gị nʼanya, onye baara gị uru karịa ndị ikom asaa, amụọrala gị nwa nwoke.” 
\p  
\v 16 Naomi kuuru nwantakịrị ahụ, jikụọ ya nʼapata ya, lekọtaa ya.  
\v 17 Ndị inyom ndị agbataobi ya sịrị, “Ugbu a, nʼikpeazụ, Naomi enwetala nwa nwoke ọzọ!” Ha gụrụ ya Obed. Ọ bụkwa onye ahụ bụ nna Jesi, onye bụ nna Devid. 
\s1 Usoro ọmụmụ Devid 
\li4  
\v 18 Nke a bụ usoro ndị a mụrụ site na Perez. 
\b  
\li1 Perez mụrụ Hezrọn 
\li1  
\v 19 Hezrọn mụrụ Ram 
\li1 Ram mụrụ Aminadab 
\li1  
\v 20 Aminadab mụrụ Nashọn 
\li1 Nashọn mụrụ Salmọn 
\li1  
\v 21 Salmọn mụrụ Boaz 
\li1 Boaz mụrụ Obed 
\li1  
\v 22 Obed mụrụ Jesi 
\li1 Jesi mụrụ Devid.