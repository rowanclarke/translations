\p Pero \w no|strong="H6213"\w* \w se|strong="H5921"\w* oía \w ni|strong="H5704"\w* una \w voz|strong="H6963"\w* \w ni|strong="H5704"\w* una respuesta, \w mientras|strong="H5704"\w* brincaban \w alrededor|strong="H5921"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w* \w que|strong="H5921"\w* \w hicieron|strong="H6213"\w*.
