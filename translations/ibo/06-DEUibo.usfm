\id DEU - Biblica® Open Igbo Contemporary Bible 2020 
\h Diuteronomi 
\toc1 Diuteronomi 
\toc2 Diuteronomi 
\toc3 Dit 
\mt1 Diuteronomi 
\c 1  
\s1 Ụmụ Izrel ebuliekwa ije 
\p  
\v 1 Ndị a bụ okwu ahụ Mosis gwara Izrel niile mgbe ha nọ nʼọwụwa anyanwụ Jọdan,\f + \fr 1:1 \ft Nke a bụ nʼofe Jọdan\f* nʼọzara nʼAraba, ebe chere ihu nʼobodo Suf, nʼetiti Paran na Tofel na Leban, na Hazerọt, na Dizahab.  
\v 2 Site nʼugwu\f + \fr 1:2 \fq Ugwu Horeb \fqa Aha ọzọ a na-akpọ ugwu Horeb bụ ugwu Saịnaị.\f* Horeb ruo Kadesh Banea, bụ njem abalị iri na otu ma e soro ụzọ gawara ugwu Sia. 
\p  
\v 3 Ọ bụ nʼabalị mbụ nke ọnwa iri na otu, nke afọ iri anọ ka Mosis gwara ụmụ Izrel ihe niile \nd Onyenwe anyị\nd* nyere ya nʼiwu banyere ha.  
\v 4 Nke mere mgbe ọ lụgbuchara Saịhọn, eze ndị Amọrait, onye na-achị na Heshbọn, lụgbukwaa Ọg, eze ndị Bashan na Edrei, onye na-achị nʼAshtarọt. 
\p  
\v 5 Nʼọwụwa anyanwụ Jọdan, nʼala ndị Moab ka Mosis nọ kọwaara ụmụ Izrel iwu ndị a sị ha, 
\b  
\p  
\v 6 \nd Onyenwe anyị\nd* Chineke anyị gwara anyị nʼugwu Horeb sị, “Unu anọọla ọtụtụ oge nʼugwu a.  
\v 7 Ugbu a bilienụ ije, baa nʼala ugwu ugwu ndị Amọrait. Gaakwanụ nʼala niile ndị agbataobi ha bụ Araba, nʼugwu niile na nʼebe dị ala ala na Negeb, nʼọnụ mmiri nke oke osimiri, garuokwanụ ala ndị Kenan na nke ndị Lebanọn, gagidekwanụ ruo nʼosimiri ukwu Yufretis.  
\v 8 Lee, enyela m unu ala ahụ niile! Baanụ nʼime ya, bichiekwanụ ala ahụ \nd Onyenwe anyị\nd* ṅụrụ iyi na ọ ga-enye nna nna unu bụ Ebraham, Aịzik, Jekọb na ụmụ ụmụ ha niile ndị ga-esote ha.” 
\s1 Nhọpụta ndị ndu 
\p  
\v 9 Nʼoge ahụ, agwara m unu ụmụ Izrel okwu sị, “Unu bụụrụ m oke ibu arọ, apụghịkwa m ibu unu naanị m.  
\v 10 \nd Onyenwe anyị\nd* Chineke unu emeela ka unu mụbaa dịka kpakpando nke eluigwe.  
\v 11 Ka \nd Onyenwe anyị\nd* Chineke nna nna unu ha meekwa ka unu mụbaa nʼọnụọgụgụ, puku kwụrụ puku, ya gọziekwa unu dịka o kwere na nkwa.  
\v 12 Ma olee otu naanị m ga-esi buo ibu unu, doziekwa ise okwu unu na nsogbu unu niile?  
\v 13 Họpụtanụ ụfọdụ ndị ikom nwe amamihe, nghọta, na ndị a na-akwanyere ụgwụ, site nʼebo niile unu nʼotu nʼotu, aga m emekwa ha ndịisi unu.” 
\p  
\v 14 Unu zara sị m, “Ihe ahụ i zubere ime dị mma.” 
\p  
\v 15 Ya mere, a kpọọrọ m ndịisi nʼebo dị iche iche, ndị ikom maara ihe, na ndị a na-asọpụrụ, mee ka ha bụrụ ndịisi ọchịchị unu, ụfọdụ ha na-elekọta puku mmadụ, ụfọdụ narị mmadụ, ndị ọzọ na-elekọta iri mmadụ ise, ndị ọzọ mmadụ iri, ka ha bụrụ ndị ndu ebo dị iche iche.  
\v 16 Adọrọ m ndị ikpe unu a aka na ntị nʼoge ahụ sị ha, “Nụrụnụ ikpe niile metụtara esemokwu dị nʼetiti ụmụnna unu, ma kpeenụ ikpe ọbụla na-eleghị mmadụ anya nʼihu ma ikpe ahụ ọ dị nʼetiti ụmụnna unu ndị Izrel, maọbụ nʼetiti ndị Izrel na ndị ọbịa.  
\v 17 Kpeenụ ikpe ziri ezi nye onye ukwu na onye nta. Elekwala ndị unu na-ekpe ikpe anya nʼihu, nʼihi na unu na-ekpe ikpe unu nʼọnọdụ Chineke.” Enyekwara m ha iwu sị ha wetaranụ m ikpe niile siri unu ike ka m leba ha anya.  
\v 18 Nʼoge ahụ, agwara m unu ihe niile unu na-aghaghị ime. 
\s1 Nzipụ ndị Nnyopụta 
\p  
\v 19 Emesịa, dịka iwu \nd Onyenwe anyị\nd* Chineke anyị nyere si dị, anyị hapụrụ ugwu Horeb, chee ihu gawa nʼala ugwu ugwu ndị Amọrait. Ụzọ anyị si gafee ọzara ukwu ahụ dị egwu nke unu ji anya unu hụ tutu anyị erute Kadesh Banea.  
\v 20 Mgbe ahụ agwara m unu okwu sị, “Unu erutela nʼala ugwu ugwu ndị Amọrait, ala ahụ \nd Onyenwe anyị\nd* Chineke anyị na-enye anyị.  
\v 21 Lee, \nd Onyenwe anyị\nd* Chineke unu enyela unu ala ahụ. Gaanụ nweta ya ka ọ bụrụ nke unu dịka \nd Onyenwe anyị\nd* Chineke nna nna unu gwara unu sị, Unu atụla egwu, ka obi unu gharakwa ịda mba.”\f + \fr 1:21 \ft \xt Jos 1:6,9\f* 
\p  
\v 22 Ma unu niile bịakwutere m sị m, “Ka anyị zipụ ndị nnyocha ka ha gaa mata ezi ụzọ e si abanye nʼala ahụ. Anyị ga-ekpebikwa obodo ndị anyị ga-ebu ụzọ banye.” 
\p  
\v 23 Ntụpụta unu juru m afọ, nʼihi ya, esitere m nʼetiti unu họpụta mmadụ iri na abụọ, otu onye site nʼebo ọbụla.\f + \fr 1:23 \ft \xt Ọnụ 13:2-3\f* 
\v 24 Ndị a pụrụ, gbagoo ala ugwu ugwu ahụ tutu bịaruo na Ndagwurugwu Eshkọl. Ha legharịrị anya nʼala ahụ.  
\v 25 Ha ghọtara ụfọdụ nʼime mkpụrụ osisi mịrị nʼala ahụ, bulatara anyị. Ha wetakwaara anyị ozi, sị, “Ala ahụ \nd Onyenwe anyị\nd* Chineke anyị na-aga inye anyị dị mma.” 
\s1 Nnupu isi ụmụ Izrel 
\p  
\v 26 Ma unu jụrụ ịga nʼala ahụ, si otu a nupu isi megide iwu \nd Onyenwe anyị\nd* Chineke unu nyere.  
\v 27 Unu nọ nʼụlọ ikwu unu tamuo ntamu na-asị, “Nʼezie \nd Onyenwe anyị\nd* ahụghị anyị nʼanya. Lee ka o si site nʼala Ijipt dupụta anyị were anyị nyefee nʼaka ndị Amọrait ka ha laa anyị nʼiyi!  
\v 28 Ebee ka anyị nwere ike ịga ugbu a? Ụmụnna anyị gara nyochaa ala ahụ emenyela anyị egwu. Ha sịrị, ‘Na ndị bi nʼala ahụ toro ogologo karịa anyị bụrụkwa ndị dị ike. Ha sịkwara na mgbidi e ji gbaa obodo ha gburugburu topuru ruo nʼeluigwe! Anyị hụkwara ụmụ Anak\f + \fr 1:28 \fq Ụmụ Anak \ft Ụmụ Anak bụ ndị bi nʼala Kenan. Ha bụ ndị a kọwara dịka ndị gbara nnọọ dimkpa, topụkwa etopụ. \xt Ọnụ 13:28\f* nʼebe ahụ.’ ” 
\p  
\v 29 Ma agwara m unu sị, “Ka ụjọ ghara ịtụ unu, unu atụla ndị ahụ egwu.  
\v 30 \nd Onyenwe anyị\nd* Chineke unu, onye na-aga nʼihu unu, ga-alụrụ unu ọgụ,\f + \fr 1:30 \ft \xt Ọpụ 14:14; Dit 3:22; 20:4; Neh 4:20\f* dịka o si lụọra unu ọgụ nʼihu anya unu, nʼala Ijipt,  
\v 31 nakwa nʼime ọzara, ebe unu nọ hụ otu \nd Onyenwe anyị\nd* Chineke unu si bulie unu elu dịka nna si ebuli nwa ya elu, nʼụzọ niile unu gbasoro tutu unu erute ebe a.” 
\p  
\v 32 Ma agbanyeghị nke a, unu ekwenyeghị na \nd Onyenwe anyị\nd* Chineke unu,  
\v 33 bụ onye gara nʼihu unu nʼije unu niile, ịchọpụtara unu ebe unu ga-ama ụlọ ikwu unu, onye jikwa ọkụ duo unu nʼabalị, jiri igwe ojii duo unu nʼehihie, iji zi unu ụzọ unu ga-agbaso. 
\p  
\v 34 Ma otu o si dị, mgbe \nd Onyenwe anyị\nd* nụrụ ntamu unu, iwe dị ukwuu were ya, nʼihi ntamu unu, ọ ṅụrụ iyi sị,  
\v 35 “O nweghị otu onye nʼime ọgbọ ọjọọ a ga-anọ ndụ hụ ala ọma ahụ m ṅụrụ iyi inye nna nna unu,  
\v 36 karịakwa Kaleb, nwa Jefune. Ọ ga-ahụ ala ahụ anya, aga m enye ya na ụmụ ụmụ ya ala ahụ ọ zọkwasịrị ụkwụ ya, nʼihi na o ji obi ya niile sogide \nd Onyenwe anyị\nd*.” 
\p  
\v 37 Ọ bụkwa nʼihi unu ka \nd Onyenwe anyị\nd* ji weso m iwe, na-asị, “Gị onwe gị kwa, ị gaghị aba nʼebe ahụ!  
\v 38 Kama Joshua, nwa Nun, onye na-enyere gị aka, ga-edu ha banye nʼebe ahụ. Gbaa ya ume nʼihi na ọ bụ ya ga-edu ndị Izrel inweta ala ahụ dịka ihe nketa ha.  
\v 39 Ọ bụkwa ụmụntakịrị ahụ na-amaghị ihe dị iche site nʼihe ọma na ihe ọjọọ ka m ga-enye ala ahụ. Ha ga-abanye nʼime ya, nweta ya dịka ihe nketa.  
\v 40 Ma unu onwe unu, bilienụ, chigharịa gawa nʼime ọzara. Cheenụ ihu unu nʼOsimiri Uhie.” 
\p  
\v 41 Mgbe ahụ, unu kwupụtara mmehie unu sị, “Anyị emehiela megide \nd Onyenwe anyị\nd*. Anyị ga-agbago nʼala ahụ gaa lụọ ọgụ, dịka \nd Onyenwe anyị\nd* Chineke anyị nyere anyị nʼiwu.” Ya mere, onye ọbụla nʼime unu yikwasịrị ihe agha ya na-eche na ọ dị mfe ịgbago nʼobodo ndị ahụ dị nʼugwu. 
\p  
\v 42 Ma \nd Onyenwe anyị\nd* sịrị m, “Gwa ha, ‘Unu arịgokwala, gaa buo agha, nʼihi na agaghị m anọnyere unu. Ndị iro unu ga-emerikwa unu.’ ” 
\p  
\v 43 Ya mere, agwara m unu, ma unu aṅaghị ntị. Unu nupuru isi nʼiwu \nd Onyenwe anyị\nd*, jiri nganga juru unu obi bilie, rigoo nʼobodo ahụ dị nʼugwu.  
\v 44 Ndị Amọrị bụ ndị bi nʼugwu ahụ pụtara, ha chụsasịrị unu dịka aṅụ si eme, tidaa unu nʼala site na Sia ruo Homa.  
\v 45 Emesịa, unu lọghachiri bịa kwaa akwa nʼihu \nd Onyenwe anyị\nd*, ma o geghị ntị nye olu akwa unu, ọ ṅakwaghị unu ntị.  
\v 46 Nʼihi ya, unu nọrọ ọtụtụ oge na Kadesh. 
\c 2  
\s1 Mwagharị nʼọzara 
\p  
\v 1 Anyị laghachiri azụ chee ihu nʼọzara nʼụzọ gawara Osimiri Uhie, dịka \nd Onyenwe anyị\nd* gwara m. Ọtụtụ afọ ka anyị nọ na-awagharị gburugburu ugwu Sia. 
\p  
\v 2 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị m,  
\v 3 “Unu agbaala ala ugwu ugwu a gburugburu ogologo oge, cheenụ ihu nʼakụkụ ugwu.  
\v 4 Nye ụmụ Izrel iwu ndị a: ‘Unu ga-aga site nʼala ụmụnna unu ndị Edọm gafee. Ndị Edọm bụ ụmụ ụmụ Ịsọ, onye biri na Sia. Ha ga-atụ egwu mgbe ha nụrụ na unu ga-esi nʼala ha gafee, ma kpachapụnụ anya.  
\v 5 Unu akpasukwala ha ka ha lụsoo unu ọgụ, nʼihi na agaghị m enye unu ala ọbụla sitere nʼala ha, ọ bụladị ebe ga-ezuru unu ịzọkwasị ụkwụ unu. Enyela m Ịsọ ala niile nke ugwu Sia dịka nke aka ya.\f + \fr 2:5 \ft Ndị Edọm, ndị Moab na ndị Amọn nwere ka ha si bụrụ ụmụnna ndị Izrel. Chineke nyere ha ala nke aka ha, \xt Jen 36:6-8; Jos 24:4\f* 
\v 6 Jirinụ ọlaọcha kwụọ ha ụgwọ nri ọbụla unu riri, jirikwanụ ọlaọcha kwụọ ha ụgwọ nʼihi mmiri ọbụla unu ṅụrụ.’ ” 
\p  
\v 7 \nd Onyenwe anyị\nd* Chineke unu agọziela unu nʼihe ọbụla bụ akaọrụ unu. O cheela nzọ ụkwụ unu nche iri afọ anọ ndị a niile unu wagharịrị nʼọzara ukwuu a. \nd Onyenwe anyị\nd* Chineke unu anọnyerela unu, ọ dịkwaghị ihe kọrọ unu. 
\p  
\v 8 Ya mere, anyị sitere nʼala ụmụnna anyị bụ ụmụ Ịsọ,\f + \fr 2:8 \fk Ụmụ Ịsọ \ft Ha kwesiri ịkpọ ndị Edọm ụmụnna ha, nʼihi na nna nna ha bụ Ịsọ bụ nwanne Jekọb. \xt Jen 25:24-26; Jos 24:4\f* ndị bi na Sia gafee. Anyị hapụkwara ụzọ Araba nke si Elat na Eziọn Geba, tụgharịa gawa elu elu ụzọ ọzara Moab. 
\p  
\v 9 Mgbe ahụ, \nd Onyenwe anyị\nd* dọrọ anyị aka na ntị sị, “Unu esogbula maọbụ lụso ndị Moab ọgụ nʼihi na unu enweghị oke nʼala ha, nʼihi na enyela m ụmụ ụmụ Lọt ala Ar ka ọ bụrụ ihe nketa nke ha.” 
\p  
\v 10 (Ndị biri nʼebe ahụ na mgbe gara aga bụ ndị Emim, agbụrụ ha gbara dimkpa dịkwa ọtụtụ nʼọnụọgụgụ. Ha toro ogologo dịka ndị Anak.  
\v 11 A na-eche na ha bụ ndị Refaim, dịka ndị Anak, ma ndị Moab na-akpọ ha ndị Emim.  
\v 12 Ma mgbe gara aga ọ bụ ndị Hor bi na Sia, ma ndị Edọm, ụmụ Ịsọ, chụpụrụ ha. Ha bibiri ndị Hor bichikwaa ala ha, dịka ụmụ Izrel si bichie nʼala ahụ \nd Onyenwe anyị\nd* nyere ha dịka ihe nketa.) 
\p  
\v 13 \nd Onyenwe anyị\nd* gwara anyị okwu sị, “Ugbu a bilienụ, gafee Ndagwurugwu Zered.” Anyị bilikwara gafee. 
\p  
\v 14 Iri afọ atọ na asatọ gasịrị, site na mgbe anyị hapụrụ Kadesh Banea ruo mgbe anyị gafere Ndagwurugwu Zered! Nʼoge a, ọgbọ ndị ikom ahụ niile na-alụ agha anwụchaala site nʼọmụma ụlọ ikwu, dịka \nd Onyenwe anyị\nd* ṅụrụ ha nʼiyi.  
\v 15 E, aka \nd Onyenwe anyị\nd* dị megide ha, ruo mgbe o mere ka ha niile nwụchaa site nʼọmụma ụlọ ikwu ahụ. 
\p  
\v 16 Mgbe onye nke ikpeazụ nʼime ndị niile a tozuru ije agha nwụchara,  
\v 17 \nd Onyenwe anyị\nd* sịrị m,  
\v 18 “Taa, ụmụ Izrel ga-esi na Ar gafee oke ala ndị Moab.  
\v 19 Mgbe unu bara nʼala ndị Amọn, unu esogbula ha, unu alụsola ha ọgụ, nʼihi na agaghị m enye unu ala ndị Amọn. Enyela m ụmụ ụmụ Lọt ala ahụ dịka ihe onwunwe ha.” 
\p  
\v 20 \f + \fr 2:20 \ft \xt Jen 15:5\f* Ndị bi nʼebe a na mbụ bụ ndị Refaim, ma ụmụ Amọn na-akpọ ha ndị Zamzum.  
\v 21 Ha bụ agbụrụ dị ukwuu nʼọnụọgụgụ, siekwa ike nke ukwuu, ha toro ogologo dịka ụmụ Anak. \nd Onyenwe anyị\nd* sitere nʼaka ndị Amọn laa ha nʼiyi, bụ ndị chụpụrụ ha ma bichie nʼobodo ha.  
\v 22 \nd Onyenwe anyị\nd* mekwara otu ihe ahụ nye ndị agbụrụ Ịsọ bụ ndị bi nʼugwu Sia mgbe ọ lara ndị Hor bụ ụzọ biri nʼebe ahụ nʼiyi. Ha chụpụrụ ha, bichie ala ha ruo taa.  
\v 23 Ebe ọzọkwa \nd Onyenwe anyị\nd* mere ihe dị otu a bụ mgbe o mere ka ndị Kafto laa ndị Avim nʼiyi. Ha bichiri obodo nta niile ndị Avim nwere nke dị gburugburu ebe ahụ rukwaa Gaza. 
\s1 Mmeri Saịhọn eze Heshbọn 
\p  
\v 24 Emesịa, \nd Onyenwe anyị\nd* sịrị, “Gafeenụ ndagwurugwu dị warawara nke Anọn, baakwanụ nʼalaeze Saịhọn, onye Amọrị, eze obodo Heshbọn. Lụsonụ ya agha, bichiekwanụ nʼala ya nʼihi na enyefeela m ya bụ eze na ala ya nʼaka unu.  
\v 25 Site taa gaa nʼihu, aga m etinye egwu na ụjọ nʼobi ndị niile bi nʼokpuru mbara eluigwe. Ha ga-anụ akụkọ unu tụọ oke egwu, maakwa jijiji nʼihi unu.” 
\p  
\v 26 Esitere m nʼọzara Kedemot zipụ ndị ozi, ka ha jekwuru Saịhọn, eze Heshbọn, zie ya ozi na anyị chọrọ udo, sị,  
\v 27 “Kwere ka anyị site nʼobodo gị gafee. Ọ bụ naanị nʼokporoụzọ ka anyị ga-anọ. Anyị agaghị atụgharị gaa nʼaka nri maọbụ nʼaka ekpe.  
\v 28 Renye anyị ihe oriri anyị ga-eri na mmiri anyị ga-aṅụ nʼọnụ ahịa ọlaọcha. Naanị kweere ka anyị gabiga nʼụkwụ ala,  
\v 29 dịka ụmụ Ịsọ, bụ ndị bi na Sia, nakwa ndị Moab bi nʼobodo Ar meere anyị, ruo mgbe anyị gafere Jọdan banye nʼala ahụ \nd Onyenwe anyị\nd* Chineke anyị na-enye anyị.”  
\v 30 Ma Saịhọn, eze Heshbọn, ekweghị ka anyị si nʼala ya gafee. Nʼihi na \nd Onyenwe anyị\nd* Chineke unu mere ka mmụọ ya sie ike, meekwa ka o mesie obi ya ike, ka o si otu a nyefee ya nʼaka unu dịka ọ mere ugbu a. 
\p  
\v 31 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara m sị, “Lee, amalitela m iwere Saịhọn na obodo a nyefee unu nʼaka. Ngwanụ, malitenụ ibuso ya agha! Merienụ ya, nwetakwanụ ala ya.” 
\p  
\v 32 Mgbe Saịhọn na ndị agha ya niile pụtara izute anyị nʼagha nʼebe a na-akpọ Jehaz,  
\v 33 \nd Onyenwe anyị\nd* Chineke anyị nyefere ya nʼaka anyị. Anyị gburu ya, gbukwaa ụmụ ya ndị ikom niile, na ndị agha ya niile.  
\v 34 Nʼoge ahụ, anyị meriri obodo ya niile, bibiekwa ha niile kpamkpam, ma ndị ikom, ma ndị inyom, ma ụmụntakịrị. Anyị ahapụghị mmadụ onye ndụ.  
\v 35 Ma ihe ndị anyị bukọọrọ bụ naanị anụ ụlọ, na ngwongwo ndị ọzọ dị iche iche anyị si nʼobodo ndị anyị meriri kwata.  
\v 36 Anyị lụgburu ndị niile bi nʼobodo dị site nʼAroea ruo nʼọnụ ndagwurugwu dị warawara nke Anọn, na site nʼetiti ndagwurugwu ahụ ruo Gilead. O nweghị obodo ọbụla rara anyị ahụ imeri, nʼihi na \nd Onyenwe anyị\nd* Chineke nyefere ha niile nʼaka anyị.  
\v 37 Ma dịka usoro iwu \nd Onyenwe anyị\nd* Chineke anyị si dị, anyị abanyeghị ala ndị Amọn ọbụla maọbụ ruokwa nʼala dị nʼakụkụ iyi Jabọk nso, maọbụ nʼobodo ndị ahụ niile dị nʼugwu. 
\c 3  
\s1 Izrel emerie eze Ọg 
\p  
\v 1 Ihe ọzọ bụ na anyị chigharịrị, gbagoo nʼụzọ gawara Bashan. Ma Ọg, eze Bashan, ya na ndị agha ya niile biliri chịrị agha pụta izute anyị nʼagha na Edrei.  
\v 2 Ma \nd Onyenwe anyị\nd* gwara m okwu, sị, “Atụla ya egwu, nʼihi na ewerela m ya na ndị agha ya niile, na ala ya, nyefee gị nʼaka. Mee ya ihe i mere Saịhọn eze ndị Amọrait, onyeisi obodo Heshbọn.” 
\p  
\v 3 Ya mere, \nd Onyenwe anyị\nd* bụ Chineke anyị nyefere Ọg, eze Bashan na ndị agha ya niile nʼaka anyị. Anyị gbuchapụkwara ha niile, na-ahapụghị onye ọbụla ndụ.  
\v 4 Nʼoge ahụ, anyị lụgburu obodo ya. Ọ dịghị obodo ọbụla nʼime iri obodo isii ahụ niile nke anyị na-anaraghị ha, ya bụ akụkụ Agob niile bụ alaeze Ọg nʼime Bashan.  
\v 5 Obodo ndị a bụ obodo e wusiri ike, nwechara mgbidi dị elu nke ukwuu, nwekwaa ọnụ ụzọ na mkpọrọ e ji akpọchi ha. Anyị lụgbukwara ọtụtụ obodo nta ndị ọzọ, ndị na-enweghị mgbidi.  
\v 6 Anyị bibiri ihe niile dị nʼobodo Bashan, dịka anyị mere nʼobodo Saịhọn, eze Heshbọn. Anyị gburu mmadụ niile bi nʼime ha, nwoke, nwanyị, na ụmụntakịrị.  
\v 7 Ma anụ ụlọ ha niile, na ihe nkwata si nʼobodo ha niile, bụ ihe anyị lụtara nʼagha nye onwe anyị. 
\p  
\v 8 Mgbe ahụ, anyị napụrụ ala ahụ site nʼaka eze abụọ ndị Amọrait, ya bụ ala ndị dị nʼakụkụ ọwụwa anyanwụ osimiri Jọdan. Ha dị site na ndagwurugwu Anọn ruo nʼugwu Hemon.  
\v 9 (Aha ndị Saịdọn na-akpọ ugwu Hemon bụ Siriọn, ma ndị Amọrait na-akpọ ya Senia.)  
\v 10 Anyị meriri obodo ndị ahụ niile dị nʼala dị larịị, meriekwa Gilead niile na Bashan, tutu ruo obodo Saleka na Edrei, obodo ndị dị nʼalaeze Ọg, eze Bashan.  
\v 11 (Ọg, eze ndị Bashan bụ naanị onye fọdụrụ ndụ nʼagbụrụ ndị Refaim. E ji igwe kwaa ihe ndina ya, nke ogologo ya dị mita anọ, nke obosara ya bụkwa mita abụọ. Ihe ndina a dị ruo taa nʼobodo Raba, otu nʼime obodo ndị Amọn.) 
\s1 Ihe nketa nʼọwụwa anyanwụ Jọdan 
\p  
\v 12 Mgbe anyị nwetara ala ndị a, eweere m ya nye ndị Ruben, na Gad, ya bụ, oke ala dị nʼebe obodo ugwu Aroea, nke dị nʼakụkụ ndagwurugwu Anọn. Tinyekwara ọkara obodo ugwu Gilead, na obodo niile dị nʼime ya.  
\v 13 Ala fọdụrụ na Gilead nakwa Bashan niile na alaeze Ọg ka m nyere otu ọkara ebo Manase. Nke a bụ ala Agob niile dị na Bashan, bụ ndị amaara dịka ala ndị Refaim.  
\v 14 Jaịa, onye si nʼebo Manase, were ala niile dị nʼAgob, ọ bụladị ruo nʼoke ala ndị Geshua na ndị Maaka. Ọ kpọrọ ya nʼaha ya, nke mere na ruo taa ihe a na-akpọ Bashan bụ Havọt Jaịa, nke pụtara, obodo Jaịa.  
\v 15 Makia ka m nyere Gilead.  
\v 16 Ma Ebo Ruben na Gad ka m nyere ala niile dị site na Gilead ruo nʼetiti ndagwurugwu Anọn, na site na ndagwurugwu a ruo nʼiyi Jabọk, nke bụ oke ala ụmụ Amọn. Etiti ndagwurugwu Anọn bụkwa oke ala ebo Ruben na Gad.  
\v 17 Oke ala ha nʼakụkụ ọdịda anyanwụ bụ osimiri Jọdan nke dị nʼAraba. Oke ala a sitere na Kineret gbatịa ruo nʼOsimiri Araba (ya bụ Osimiri Nnu), nke dị na mgbada ugwu Pisga. 
\p  
\v 18 Enyekwara m unu iwu nʼoge ahụ sị, “\nd Onyenwe anyị\nd* Chineke unu enyela unu ala a ka unu nwere ya. Ma ndị unu niile, ndị bụ dimkpa, ndị jikeere maka agha, ga-agafe nọrọ ndị Izrel ndị ọzọ nʼihu.  
\v 19 Otu ọ dị, ebe ọ bụ na unu nwere ọtụtụ anụ ụlọ, ndị nwunye unu na ụmụntakịrị unu ga-ebi nʼobodo ndị m nyere unu, lekọtaa anụ ụlọ unu anya,  
\v 20 tutu ruo mgbe \nd Onyenwe anyị\nd* ga-enye ụmụnna unu mmeri dịka o nyere unu. Mgbe ha nwetara ala \nd Onyenwe anyị\nd* Chineke anyị na-enye ha nʼofe Jọdan, onye ọbụla nʼime unu nwere ike lọghachi bịa biri nʼala unu.” 
\s1 Mosis agaghị agafe osimiri Jọdan 
\p  
\v 21 Nʼoge ahụ, agwara m Joshua okwu sị, “I jirila anya gị hụ ihe \nd Onyenwe anyị\nd* Chineke gị mere eze abụọ ndị a. Otu a ka ọ ga-emekwa alaeze niile dị nʼofe Jọdan ebe unu na-aga.  
\v 22 Atụla ha egwu, nʼihi \nd Onyenwe anyị\nd* Chineke gị ga-alụrụ gị ọgụ.” 
\p  
\v 23 Nʼoge ahụ, arịrịọ m \nd Onyenwe anyị\nd* arịrịọ sị ya,  
\v 24 “Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ị malitela igosi mụ bụ ohu gị ịdị ukwuu gị na ike gị. O nweghị chi ọzọ dị nʼeluigwe maọbụ nʼụwa pụrụ ịrụ ọrụ ebube niile ị rụrụ.  
\v 25 Kwere ka m gafee hụ ala ọma ahụ dị nʼofe ọzọ nke Jọdan, ala ugwu ugwu ahụ mara mma, na Lebanọn.” 
\p  
\v 26 Ma nʼihi unu, \nd Onyenwe anyị\nd* wesoro m iwe jụ ige m ntị! \nd Onyenwe anyị\nd* gwara m okwu sị m, “O zuola! Agwakwala m ihe ọbụla banyere okwu a.  
\v 27 Gaa, rigoruo nʼelu ugwu Pisga, site nʼebe ahụ lepụ anya nʼakụkụ ugwu na ndịda ma nʼakụkụ ọwụwa anyanwụ na ọdịda anyanwụ. Ọ bụ anya gị ka ị ga-eji hụ ala ahụ, nʼihi na ị gaghị agafe osimiri Jọdan.  
\v 28 Nye Joshua ike ka ọ nọchie ọnọdụ gị. Gbaakwa ya ume,\f + \fr 3:28 \ft \xt Ọnụ 27:18,23; Dit 31:3,7-8,23\f* nʼihi na ọ bụ ya ga-edu ndị a gafee Jọdan iketa ala ahụ niile ị ga-ahụ.”  
\v 29 Ya mere, anyị nọdụrụ na ndagwurugwu ahụ dị nso na Bet-Peoa. 
\c 4  
\s1 Nrube isi dị mkpa 
\p  
\v 1 Ugbu a, O Izrel, gee ntị nʼụkpụrụ na iwu niile m na-aga ikuziri unu ka unu na-eme ma ọ bụrụ na unu chọrọ ịdị ndụ banye, ma nwetakwa ala ahụ \nd Onyenwe anyị\nd* Chineke nna nna unu ha na-enye unu.  
\v 2 Unu atụkwasịla iwu ọzọ nʼelu iwu ndị a, ma ọ bụkwanụ site na ha wepụ iwu ọbụla. Kama, meenụ ihe iwu ndị a na-ekwu, nʼihi na ha si nʼaka \nd Onyenwe anyị\nd* Chineke unu. 
\p  
\v 3 Unu ji anya unu hụ ihe \nd Onyenwe anyị\nd* mere na Baal-Peoa. \nd Onyenwe anyị\nd* Chineke unu sitere nʼetiti unu bibie ndị niile gbasoro Baal nke Peoa.  
\v 4 Ma unu niile nọgidesịrị ike soro \nd Onyenwe anyị\nd* Chineke unu bụ ndị dị ndụ taa. 
\p  
\v 5 Lee, ezila m unu ụkpụrụ na iwu niile \nd Onyenwe anyị\nd* Chineke m sị m zi unu, iwu unu na-aghaghị idebe nʼala ahụ unu na-aga inweta.  
\v 6 Lezienụ anya hụ na unu debere ha, nʼihi na nke a ga-egosi mba gbara unu gburugburu na unu bụ ndị nwere nghọta na amamihe. Nʼihi na mgbe ha nụrụ banyere ụkpụrụ ndị a, ha ga-ekwu okwu sị, “Nʼezie, ndị jupụtara na mba ukwu a bụ ndị nwere nghọta na amamihe.”  
\v 7 Olee mba ọzọ dị ukwuu, nke e mere ka chi ha nọọ ha nso dịka \nd Onyenwe anyị\nd* Chineke anyị si na-anọ anyị nso mgbe ọbụla anyị kpọkuru ya nʼekpere?  
\v 8 Olee mba ukwu ọzọ dịkwa nke nwere ụkpụrụ na iwu ziri ezi dịka iwu ndị a m na-enye unu taa? 
\p  
\v 9 Naanị kpachapụnụ anya unu, ma cheenụ onwe unu nche mgbe niile, ka unu ghara ichefu ihe ndị a niile unu ji anya unu hụ, ka ha gharakwa isi nʼobi unu pụọ ụbọchị niile nke ndụ unu. Kama kuziere ha ụmụ unu, na ụmụ ụmụ ndị ga-esote ha.  
\v 10 Cheta ụbọchị ahụ unu bịara guzo nʼihu \nd Onyenwe anyị\nd* Chineke unu nʼugwu Horeb, nʼụbọchị ahụ ọ gwara m okwu sị m, “Kpọkọtaa ụmụ Izrel ka ha bịa nʼihu m, nụrụ okwu m, ka ha nwee ike mụta ịtụ m egwu ụbọchị niile nke ha ga-ebi nʼala ahụ, ka ha nweekwa ike ikuziri ụmụ ha.”  
\v 11 Ọ bụ nʼala ugwu ahụ ka unu bịara nso, guzo, mgbe ọkụ si nʼugwu ahụ na-ere, na-alali elu iru eluigwe, ya na igwe ojii\f + \fr 4:11 \ft Maọbụ, \fqa anwụrụ ọkụ dị oji\f* nakwa oke ọchịchịrị.  
\v 12 Mgbe ahụ \nd Onyenwe anyị\nd* sitere nʼọkụ ahụ gwa unu okwu. Unu nụrụ ụda olu ya, ma unu ahụghị oyiyi ọbụla anya, naanị ụda olu.  
\v 13 O nyere unu ọgbụgba ndụ ya, nke unu na-aghaghị idebe. Ha dị iwu iri. O dere ha na mbadamba nkume abụọ.  
\v 14 E, ọ bụ nʼoge ahụ ka \nd Onyenwe anyị\nd* nyere m iwu sị m nye unu ụkpụrụ na iwu unu ga-agbaso mgbe unu banyere nʼala ahụ dị nʼofe Jọdan, nke unu na-aga inweta. 
\s1 Ịdọ aka na ntị banyere ikpere arụsị 
\p  
\v 15 Unu maara na unu ahụghị ụdịdị \nd Onyenwe anyị\nd* anya nʼụbọchị ahụ o sitere nʼọkụ gwa unu okwu nʼugwu Horeb. Ya mere kpachapụrụnụ onwe unu anya  
\v 16 ka unu ghara imerụ onwe unu site nʼịkpụ oyiyi ọbụla dịka arụsị, ụdị oyiyi ihe ọbụla, maọbụ nʼụdị nwoke maọbụ nʼụdị nwanyị,  
\v 17 maọbụ nʼụdị anụmanụ, maọbụ nʼụdị nnụnụ na-efe efe,  
\v 18 maọbụ nʼụdị anụ na-akpụ akpụ, ma ọ bụkwanụ nʼụdị azụ bi na mmiri.  
\v 19 Mgbe unu lere anya na mbara eluigwe hụ anyanwụ, ọnwa, na kpakpando, dịka ha si basaa na mbara eluigwe, unu ekwela ka unu bụrụ ndị a na-arafu ịkpọ isiala nye ha na ife ha ofufe bụ ihe ndị a \nd Onyenwe anyị\nd* Chineke unu kere nye mba niile bi nʼokpuru eluigwe.  
\v 20 Ma banyere unu, Onyenwe anyị kpọọrọ unu, kpọpụta unu site nʼime ọkụ na-agbaze igwe, site nʼIjipt pụta, ka unu bụrụ ihe nketa ya, dịka unu dị ugbu a. 
\p  
\v 21 \nd Onyenwe anyị\nd* wesoro m iwe nʼihi unu, ọ ṅụrụ iyi na m agaghị agafe osimiri Jọdan ịbanye nʼala ọma ahụ nke \nd Onyenwe anyị\nd* Chineke gị na-enye gị dịka ihe nketa gị.  
\v 22 Aghaghị m ịnwụ nʼala a. Agaghị m agafe Jọdan. Ma unu ga-agafe gaa nweta ala ọma ahụ.  
\v 23 Lezienụ anya ka unu ghara ichefu ọgbụgba ndụ unu na \nd Onyenwe anyị\nd* Chineke unu nwekọrọ, unu emerela onwe unu arụsị yiri ụdịdị ihe ọbụla, ndị ahụ iwu \nd Onyenwe anyị\nd* Chineke unu nyere megidere.  
\v 24 Nʼihi na \nd Onyenwe anyị\nd* Chineke unu bụ ọkụ na-erepịa erepịa. Ọ bụ Chineke ekworo. 
\p  
\v 25 Mgbe ị ga-amụ ụmụ, nwekwa ụmụ ụmụ, mgbe unu birila ọtụtụ oge nʼala ahụ, ọ bụrụ na unu emerụọ onwe unu site nʼimere onwe unu ụdị arụsị ọbụla, si otu a mee ihe dị njọ nʼanya \nd Onyenwe anyị\nd* Chineke unu, ma kpasuo ya iwe  
\v 26 ana m akpọku eluigwe na ụwa ka ha bụrụ ndị akaebe mụ na unu taa, na a ga-ala unu nʼiyi ngwangwa nʼala ahụ bụ nke unu na-agafe Jọdan inweta. Unu agaghị ebi ogologo oge nʼebe ahụ, nʼihi na a ga-ekpochapụ unu.  
\v 27 \nd Onyenwe anyị\nd* ga-eme ka unu gbasasịa nʼetiti mba ndị ọzọ. Ọ bụkwa naanị mmadụ ole na ole ga-afọdụ ndụ nʼetiti mba ndị ahụ \nd Onyenwe anyị\nd* ga-achụga unu.  
\v 28 Nʼebe ahụ, unu ga-efe chi ndị bụ ọrụ aka mmadụ nke e ji osisi tụọ na nke e ji nkume pịa, nke na-adịghị ahụ ụzọ, nke na-adịghị anụ ihe, nke na-apụghị iri nri ma ọ bụkwanụ ịnụ isisi.  
\v 29 Ma ọ bụrụ na unu anọrọ nʼebe ahụ chọọ \nd Onyenwe anyị\nd* Chineke unu, unu ga-achọtakwa ya, mgbe unu ji obi unu niile na mkpụrụobi unu niile chọọ ya.  
\v 30 Mgbe mkpagbu bịara, mgbe ihe ilu ndị a bịakwasịrị unu nʼoge dị nʼihu, unu ga-emesịa lọghachikwute \nd Onyenwe anyị\nd* Chineke unu, unu ga-egekwa ntị nʼihe ọ ga-agwa unu.  
\v 31 Nʼihi na \nd Onyenwe anyị\nd* Chineke unu bụ Chineke na-eme ebere. Ọ gaghị agọnarị unu maọbụ laa unu nʼiyi, maọbụ chefuo ọgbụgba ndụ ya na nna nna unu ha gbara, nke o ji iyi ọ ṅụrụ mesie ike. 
\s1 \nd Onyenwe anyị\nd* bụ Chineke 
\p  
\v 32 Nyochaanụ ihe mere nʼoge gara aga, tupu a mụọ unu, na tupu Chineke ekee mmadụ nʼụwa. Jụọnụ ajụjụ nʼụwa niile, jụta ma ihe ukwu dị otu a o metụla mgbe ọbụla.  
\v 33 O nweela ndị mmadụ nụrụ olu Chineke mgbe o si nʼọkụ gwa ha okwu dịka unu mere, ma ha anwụghị?  
\v 34 O nweela chi ọzọ nwara ka o site na mba ọzọ nwetara onwe ya otu mba, site nʼihe nwalee, site nʼihe ịrịbama na ihe ebube dị iche iche, site nʼagha, nʼaka dị ike, na ogwe aka esetipụrụ esetipụ, maọbụ nʼihe dị oke egwu dị iche iche, dịka ihe niile nke \nd Onyenwe anyị\nd* Chineke unu mere nʼala Ijipt nʼihu anya unu abụọ? 
\p  
\v 35 O gosiri unu ihe ndị a ka unu mara na \nd Onyenwe anyị\nd* bụ Chineke nʼezie, na ọ dịkwaghị onye ọzọ ma ọ bụghị ya.  
\v 36 O sitere nʼeluigwe mee ka unu nụ olu ya maka ịdọ unu aka na ntị. Nʼụwa, o mere ka unu hụ oke ogidi ọkụ ahụ o wuru, unu nụkwara olu ya nʼetiti ọkụ ahụ.  
\v 37 Nʼihi ịhụnanya o nwere nʼebe nna nna unu nọ na nʼihi nhọpụta ọ họpụtara ụmụ ụmụ ha, ka o ji si nʼIjipt dupụta unu nʼihu ya. Ọ bụkwa ike aka ya ka o ji mezuo nke a.  
\v 38 Ka o site nʼihu unu chụpụ mba dị ukwuu na ndị dị ike, ma kpọbata unu nʼala ha, inye unu ala ahụ dịka ihe nketa unu, dị ka o si dị taa. 
\p  
\v 39 Matanụ nke ọma, ma nabata okwu a nʼobi unu na \nd Onyenwe anyị\nd* bụ Chineke nʼeluigwe na nʼụwa. O nwekwaghị chi ọzọ dị ma ọ bụghị ya.  
\v 40 Debenụ ụkpụrụ ya na iwu ndị a niile m na-enye unu taa, ka ihe niile gaara unu na ụmụ unu nke ọma, ka unu biekwa nʼala ahụ \nd Onyenwe anyị\nd* Chineke na-enye unu ruo mgbe niile. 
\s1 Obodo mgbaba 
\p  
\v 41 Mgbe ahụ, Mosis họpụtara obodo atọ nʼofe ọwụwa anyanwụ nke osimiri Jọdan,  
\v 42 ebe onye ọbụla gburu mmadụ ga-agbaba ọsọ ndụ, ma ọ bụrụ na ha gburu onye agbataobi ha na-amaghị ama, na-akpọghị ya asị na mgbe gara aga. Ọ ga-agbaba nʼotu ime obodo ndị a ichebe ndụ ya.  
\v 43 Obodo ndị ahụ bụ, Beza, nke dị nʼugwu elu ya dị larịị nʼime ọzara. A họpụtara ya maka ebo Ruben. Ramọt, nke dị na Gilead, maka ebo Gad, na Golan, nke dị na Bashan, maka ebo Manase. 
\s1 Okwu mmalite tupu enye iwu 
\p  
\v 44 Nke a bụ iwu Mosis chere nʼihu ụmụ Izrel.  
\v 45 Ndị a bụ ihe ama, na ụkpụrụ, na iwu Mosis nyere ụmụ Izrel nke ha aghaghị idebe mgbe ha si nʼIjipt pụta  
\v 46 na ndagwurugwu Bet-Peoa nke dị nʼọwụwa anyanwụ Jọdan, nʼala Saịhọn, eze ndị Amọrait, onye na-achị na Heshbọn, bụ onye Mosis na ndị Izrel meriri nʼagha mgbe ha si nʼIjipt pụta.  
\v 47 Ndị Izrel nwetaara onwe ha ala ya na ala Ọg, eze Bashan. Eze abụọ ndị a bụ eze ndị Amọrait ndị ala ha dị nʼọwụwa anyanwụ nke osimiri Jọdan.  
\v 48 Ala a sitere nʼAroea, nʼọnụ mmiri Anọn ruo nʼugwu Siriọn (ya bụ ugwu Hemon),  
\v 49 ruo nʼala Araba niile, nke dị nʼọwụwa anyanwụ osimiri Jọdan, ruokwa nʼOsimiri Nnu, nʼala ala ugwu Pisga. 
\c 5  
\s1 Iwu iri 
\p  
\v 1 Mosis kpọkọtara Izrel niile gwa ha okwu sị, 
\p Geenụ ntị, unu Izrel, nʼụkpụrụ ndị a na iwu ndị a niile m na-agụpụta na ntị unu taa, mụtanụ ha, hụkwanụ na unu debere ha!  
\v 2 Anyị na \nd Onyenwe anyị\nd* Chineke anyị gbara ndụ nʼugwu Horeb.\f + \fr 5:2 \ft \xt Ọpụ 19:5; Dit 4:23\f* 
\v 3 Ọ bụghị \nd Onyenwe anyị\nd* na nna nna anyị ha gbara ndụ, kama ọ bụ anyị na ya, anyị niile ndị dị ndụ taa.  
\v 4 \nd Onyenwe anyị\nd* sitere nʼetiti ọkụ gwa unu okwu ihu na ihu nʼugwu ahụ.  
\v 5 E guzoro m nʼetiti unu na \nd Onyenwe anyị\nd* mgbe ahụ, ikwupụtara unu okwu \nd Onyenwe anyị\nd*, nʼihi na unu tụrụ egwu ọkụ ahụ, unu arịgoghịkwa nʼugwu ahụ. 
\p Ọ sịrị: 
\b  
\li4  
\v 6 “Mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke unu, onye kpọpụtara unu site nʼIjipt, bụ ala nke ịbụ ohu. 
\b  
\li1  
\v 7 “Gị enwela chi ọzọ tinyere m. 
\li1  
\v 8 Gị emerela onwe gị arụsị a pịrị apị, nʼoyiyi nke ụdị ọbụla nke yiri ihe dị nʼeluigwe maọbụ nke yiri ihe dị nʼụwa, nʼokpuru ya maọbụ nʼime mmiri, nʼokpuru ụwa.  
\v 9 Gị akpọla isiala nye ha, efekwala ha ofufe, nʼihi na Mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke gị, abụ m Chineke ekworo. Onye na-ata ụmụ na ụmụ ụmụ ahụhụ, nʼihi ajọ omume nke ndị mụrụ ha, ọ bụladị ruo nʼọgbọ nke atọ na nke anọ, nke ndị ahụ kpọrọ m asị.  
\v 10 Ma na-egosi ịhụnanya nye puku ọgbọ niile nke ndị hụrụ m nʼanya, bụ ndị na-edebe ihe niile m nyere nʼiwu. 
\li1  
\v 11 Gị ejikwala aha \nd Onyenwe anyị\nd* bụ Chineke gị eme ihe efu, nʼihi na \nd Onyenwe anyị\nd* agaghị agụ onye ji aha ya eme ihe efu dịka onye ikpe na-amaghị. 
\li1  
\v 12 Debe ụbọchị izuike site nʼido ya nsọ, dịka \nd Onyenwe anyị\nd* Chineke gị nyere gị nʼiwu.  
\v 13 Nʼime ụbọchị isii ka ị ga-eje ozi gị niile. Ọ bụkwa nʼime ha ka ị ga-arụzu ọrụ gị niile,  
\v 14 ma ụbọchị nke asaa bụ ụbọchị izuike nke \nd Onyenwe anyị\nd* Chineke gị. Ị gaghị arụ ọrụ ọbụla nʼụbọchị ahụ, gị onwe gị, nwa gị nwoke na nwa gị nwanyị, onye ọrụ gị nwoke, onye ọrụ gị nwanyị, ehi gị, ịnyịnya ibu gị maọbụ anụ ụlọ gị ọbụla, ọ bụladị onye ọbịa bi nʼobodo gị, ka ohu gị nwoke na ohu gị nwanyị zuru ike dịka gị onwe gị si ezu ike.  
\v 15 Ị ga-echetakwa na ị bụ ohu nʼala Ijipt, ma \nd Onyenwe anyị\nd* Chineke mere ka i si nʼohu pụta. Ọ bụ ike ya dị ukwuu ka o ji napụta gị. Ọ bụ ya mere \nd Onyenwe anyị\nd* Chineke gị ji nye iwu na ị ga-edebe ụbọchị izuike nsọ. 
\li1  
\v 16 Sọpụrụ nne gị na nna gị, dịka \nd Onyenwe anyị\nd* Chineke gị nyere gị nʼiwu, ka ụbọchị ndụ gị dị ogologo, ka ihe dịkwara gị mma nʼala ahụ nke \nd Onyenwe anyị\nd* Chineke gị na-enye gị. 
\li1  
\v 17 Gị egbula mmadụ. 
\li1  
\v 18 Gị akwala iko. 
\li1  
\v 19 Gị ezula ohi. 
\li1  
\v 20 Gị agbala ama ụgha megide onye agbataobi gị. 
\li1  
\v 21 Gị enwela anya ukwu nʼebe nwunye onye agbataobi gị dị. Gị enwekwala agụụ inwetara onwe gị ụlọ onye agbataobi gị, maọbụ nʼebe ala ya, maọbụ ohu ya nwoke, maọbụ ohu ya nwanyị, maọbụ ehi ya, maọbụ ịnyịnya ibu ya, ma ọ bụkwanụ nʼihe ọbụla nke onye agbataobi nwere dị.” 
\b  
\p  
\v 22 Iwu ndị a ka \nd Onyenwe anyị\nd* sitere nʼolu ike kwupụta nye ọgbakọ unu niile nʼelu ugwu ahụ, site nʼọkụ ahụ na igwe ojii ahụ na oke ọchịchịrị ahụ. O nweghị okwu ọzọ o tụkwasịrị nʼelu ya. O mechara dee ha na mbadamba nkume abụọ, nye m ha. 
\p  
\v 23 Ma mgbe unu nụrụ oke olu ahụ kwuru okwu site nʼoke ọchịchịrị ahụ, hụkwa ire ọkụ ahụ dị egwu na-enwu nʼelu ugwu, ndịisi unu, ndị ndu ebo ọbụla na ndị okenye unu bịakwutere m.  
\v 24 Unu sịrị, “\nd Onyenwe anyị\nd* bụ Chineke anyị egosila anyị ebube ya, na ịdị ukwu ya, anyị anụkwala olu ya site nʼime ọkụ ahụ. Taa anyị ahụla na mmadụ pụrụ ịdị ndụ ọbụladị ma Chineke kpanyere ha ụka.  
\v 25 Ma ugbu a nʼihi gịnị ka anyị ga-eji nwụọ? Ọkụ a, nke na-enwusi ike ga-erechapụ anyị. Anyị ga-anwụ ma ọ bụrụ na anyị anụ olu \nd Onyenwe anyị\nd* Chineke anyị gaa nʼihu.  
\v 26 Nʼihi na onye dị nʼetiti mmadụ, nke nụrụ olu Chineke dị ndụ ka ọ na-ekwu okwu site nʼetiti ọkụ, dịka anyị nụrụ ma dịrị ndụ.  
\v 27 Gaa nso nụtara anyị ihe \nd Onyenwe anyị\nd* Chineke anyị na-ekwu, mgbe ahụ, gwa anyị ihe ọbụla bụ nke ọ gwara gị, anyị ga-anụ, mekwa ya.” 
\p  
\v 28 \nd Onyenwe anyị\nd* nụrụ olu okwu mgbe unu gwara m okwu, \nd Onyenwe anyị\nd* sịrị m, “Anụla m ihe ndị a gwara gị. Ihe niile ha kwuru ziri ezi.  
\v 29 Lee, ọ ga-adị nnọọ mma ma mkpụrụobi ha dị otu a, ịtụ egwu m, na idebe ihe niile m nyere ha nʼiwu, ka ihe gaara ha na ụmụ ha nke ọma mgbe niile ebighị ebi. 
\p  
\v 30 “Gaa, gwa ha ka ha laghachi nʼụlọ ikwu ha.  
\v 31 Ma gị onwe gị, guzo nʼebe a nʼakụkụ m, ka m nye gị iwu m na ụkpụrụ m niile, ị ga-akụziri ha idebe iwu m, ha aghakwaghị idebe ha nʼala ahụ m gaje inye ha ka ha nweta.” 
\p  
\v 32 Lezienụ anya ime ihe ndị ahụ niile \nd Onyenwe anyị\nd* bụ Chineke unu nyere unu nʼiwu. Unu esitela na ha wezuga onwe unu gaa nʼaka nri maọbụ nʼaka ekpe.  
\v 33 Jegharịanụ ije nʼụzọ niile \nd Onyenwe anyị\nd* Chineke unu nyere unu nʼiwu, ka unu dịrị ndụ, baa ụba, ma meekwa ka ndụ unu dị ogologo nʼala ahụ unu na-aga inweta. 
\c 6  
\s1 Ịhụ \nd Onyenwe anyị\nd* nʼanya 
\p  
\v 1 Ndị a bụ iwu, na ụkpụrụ, na ikpe niile nke \nd Onyenwe anyị\nd* bụ Chineke unu, nyere m nʼiwu ka a kuziere unu ka unu debe, nʼala ahụ unu na-agafe Jọdan inweta.  
\v 2 Ihe e ji nye iwu ndị a bụ ka unu na ụmụ unu, na ụmụ ụmụ unu, tụọ egwu \nd Onyenwe anyị\nd* bụ Chineke unu, site nʼidebe iwu ya, ogologo ndụ unu niile. Ọ bụrụ na unu emee ya, unu ga-enwe ndụ ogologo.  
\v 3 Nụrụ Izrel ma lezie anya nʼirube isi, ka ihe gaara unu nke ọma, ka unu baa ụba nke ukwuu nʼala ahụ mmiri ara ehi na mmanụ aṅụ na-eru nʼime ya, ọ bụladị dịka \nd Onyenwe anyị\nd* Chineke nna nna unu ha kwere unu na nkwa. 
\p  
\v 4 Nụrụ gị Izrel, \nd Onyenwe anyị\nd* bụ Chineke anyị, \nd Onyenwe anyị\nd* bụ otu.  
\v 5 Were obi gị niile, na mkpụrụobi gị niile, na uche gị na ike gị niile, hụ \nd Onyenwe anyị\nd* Chineke gị nʼanya.  
\v 6 Iwu ndị a m na-enye gị taa ka ị ga-eme ka ọ dịrị gị nʼobi.  
\v 7 Ị ga-akụziri ya ụmụ gị. Kwuo okwu banyere ha mgbe ị na-anọdụ ala nʼụlọ gị, mgbe ị na-aga nʼokporoụzọ, mgbe ị na-edina ala na mgbe i si nʼihe ndina bilie.  
\v 8 Keenụ ha dịka ihe ịrịbama nʼelu aka unu, kekwasịkwa ha dịka ihe ncheta nʼegedege ihu unu.  
\v 9 Dee ha nʼelu ibo ọnụ ụzọ ụlọ gị na nke ọnụ ụzọ ama gị. 
\p  
\v 10 Mgbe \nd Onyenwe anyị\nd* Chineke ga-akpọbata unu nʼala ahụ ọ ṅụrụ iyi nye nna nna unu ha, bụ Ebraham, na Aịzik, na Jekọb, na inye unu, ala sara mbara nke jupụtara nʼobodo unu na-ewughị,  
\v 11 na ụlọ ihe ọma dị iche iche jupụtara nʼime ya nke unu na-azụghị, na olulu mmiri unu na-egwughị nʼonwe unu, na ubi vaịnị na ọtụtụ osisi oliv unu na-amaghị ndị kụrụ ha, mgbe unu riri ihe rijuo afọ,  
\v 12 leruonu anya, ka unu ghara ichefu \nd Onyenwe anyị\nd*, onye mere ka unu site nʼala Ijipt pụta, bụ ala ebe unu bụ ohu. 
\p  
\v 13 \nd Onyenwe anyị\nd* bụ Chineke gị, ka ị ga-atụ egwu, naanị ya ka ị ga-efe ofufe, ọ bụkwa aha ya ka ị ga-eji ṅụọ iyi.  
\v 14 Unu agbasola chi ndị ọzọ, bụ chi ndị niile a gbara unu gburugburu na-efe.  
\v 15 Nʼihi na \nd Onyenwe anyị\nd* Chineke unu, onye nọ nʼetiti unu, bụ Chineke ekworo. Ọ ga-eme ka iwe ya dị ọkụ megide unu, ọ ga-ekpochapụkwa unu site nʼelu ụwa.  
\v 16 Anwala \nd Onyenwe anyị\nd*, bụ Chineke gị ọnwụnwa, dịka unu nwara ya na Masa.  
\v 17 Lezienụ anya hụ na unu debere iwu niile na ụkpụrụ niile, na ihe ama niile \nd Onyenwe anyị\nd* Chineke unu nyere unu.  
\v 18 Meenụ ihe ziri ezi, na nke dị mma nʼanya \nd Onyenwe anyị\nd*, ka ihe niile gaara unu nke ọma, ka unu nweekwa ike ịbanye, ma nweta ezi ala ahụ \nd Onyenwe anyị\nd* ji ịṅụ iyi kwee nna nna unu ha na nkwa.  
\v 19 Ka unu chụpụkwa ndị iro unu niile site nʼala ahụ, dịka \nd Onyenwe anyị\nd* nʼonwe ya kwuru. 
\s1 Ọsịsa nye ụmụ ụmụ 
\p  
\v 20 Nʼoge na-abịa, mgbe nwa nwoke gị ga-ajụ gị sị, “Gịnị bụ isi ihe ama ndị a, na ụkpụrụ ndị a, na iwu ndị a \nd Onyenwe anyị\nd* Chineke anyị nyere unu?”  
\v 21 Ị ga-aza ya sị, “Anyị bụrị ndị ohu Fero nʼala Ijipt, ma site nʼike ya dị ukwuu, \nd Onyenwe anyị\nd* kpọpụtara anyị site nʼala Ijipt.  
\v 22 Nʼihu anyị, \nd Onyenwe anyị\nd* zipụrụ ọtụtụ ihe ịrịbama dị iche iche na ihe ebube dị iche iche, dị ukwuu jọọkwa njọ nʼahụ Ijipt na eze Fero nakwa ndị ụlọ ya niile.  
\v 23 Ma o mere ka anyị site nʼIjipt pụta, ịkpọbata na inye anyị ala ahụ o ji ịṅụ iyi kwee nna nna anyị ha na nkwa.  
\v 24 Nʼihi ya ka \nd Onyenwe anyị\nd* ji nye anyị iwu ka anyị debe ụkpụrụ ndị a niile, na-atụ \nd Onyenwe anyị\nd* Chineke anyị egwu, ka anyị bụrụ ndị ihe ga-agara nke ọma ụbọchị niile, ndị a na-edebe ndụ, dịka ọ dị taa.  
\v 25 Ọ bụrụ na anyị elezie anya debe iwu ndị a niile \nd Onyenwe anyị\nd* Chineke anyị nyere anyị, dịka o nyere anyị nʼiwu, anyị ga-abụ ndị na-ejegharị nʼezi omume.” 
\c 7  
\s1 Iwu banyere ikpochapụ ndị Kenan 
\p  
\v 1 Mgbe \nd Onyenwe anyị\nd* bụ Chineke unu ga-akpọbata unu nʼala ahụ unu na-abanye inweta, mgbe o si nʼihu unu chụpụ ọtụtụ mba ndị a nʼihu unu, bụ ndị Het, ndị Gigash, ndị Amọrait, ndị Kenan, ndị Periz, ndị Hiv na ndị Jebus, bụ mba asaa ndị dị ike nke ukwuu, baakwa ụba karịa unu;  
\v 2 mgbe \nd Onyenwe anyị\nd* bụ Chineke unu nyefere ha nʼaka unu, unu meriekwa ha, lezienụ anya hụ na unu bibiri ha kpamkpam. Ka unu na ha ghara ịgba ndụ, unu emekwarala ha ebere.  
\v 3 Unu na ha alụrịtakwala di na nwunye, unu enyekwala ụmụ ha ndị ikom ụmụ unu ndị inyom ka ha lụọ, maọbụ lụtara ụmụ unu ndị ikom ụmụ ha ndị inyom.  
\v 4 Nʼihi na nke a ga-eme ka ụmụ unu site nʼiso m tụgharịa, malite ife chi ndị ọzọ. Mgbe ahụ iwe \nd Onyenwe anyị\nd* ga-adị ọkụ megide unu, laakwa unu nʼiyi ngwangwa.  
\v 5 Kama otu a ka unu ga-eme: tikpọọnụ ebe ịchụ aja ha niile. Kụrienụ ogidi arụsị ha niile. Gbutukwaanụ osisi Ashera ha, ma suo arụsị ha niile ọkụ.  
\v 6 Nʼihi na unu bụ ndị dị nsọ nye \nd Onyenwe anyị\nd* bụ Chineke unu. \nd Onyenwe anyị\nd* bụ Chineke unu ahọpụtala unu site nʼagbụrụ niile dị nʼụwa a, ka unu bụrụ ndị nke ya, ihe onwunwe ya dị oke ọnụahịa. 
\p  
\v 7 Ọ bụghị nʼihi na unu dị ukwuu nʼọnụọgụgụ karịa ndị mba ọzọ, ka \nd Onyenwe anyị\nd* ji họpụta unu, hụ unu nʼanya otu a, nʼezie unu dịkarịsịrị nta nʼọnụọgụgụ.  
\v 8 Kama, ọ bụ nʼihi \nd Onyenwe anyị\nd* hụrụ unu nʼanya, mezuokwa iyi ọ ṅụrụ nye nna nna unu ha, ka o ji site nʼaka ya dị ike gbapụta unu site nʼala ebe unu bụ ndị ohu, site nʼike nke Fero, bụ eze Ijipt.  
\v 9 Matanụ nke ọma na \nd Onyenwe anyị\nd* bụ Chineke unu bụ Chineke. Ọ bụ Chineke kwesiri ntụkwasị obi, onye na-edebe ọgbụgba ndụ ịhụnanya ya ruo puku ọgbọ, nye ndị niile hụrụ ya nʼanya, ndị na-edebe ihe niile o nyere nʼiwu.  
\v 10 Ma 
\q1 onye kpọrọ ya asị, ọ na-eji mbibi kwụghachi ya ụgwọ nʼihu ya, 
\q2 ọ gaghị egbu oge ịkwụghachi onye kpọrọ ya asị ụgwọ nʼihu ha. 
\m  
\v 11 Nʼihi ya, hụ na unu debezuru iwu na ụkpụrụ ndị a m na-enye unu taa. 
\p  
\v 12 Ọ bụrụ na unu elezie anya, ṅaa ntị nʼiwu ndị a, debe ha, ma mezuokwa ha, \nd Onyenwe anyị\nd* bụ Chineke unu ga-emezuru unu ọgbụgba ndụ ịhụnanya ahụ dịka ọ ṅụrụ nʼiyi nye nna nna unu ha.  
\v 13 Ọ ga-ahụ unu nʼanya, gọzie unu, meekwa ka unu baa ụba nʼọnụọgụgụ. Ọ ga-agọzi unu nʼọmụmụ, gọzie ihe ọkụkụ nke ala unu, ọka unu, na mmanya ọhụrụ unu, na mmanụ unu, na ụmụ ehi unu mụrụ, na ụmụ igwe atụrụ unu mụrụ, nʼala ahụ ọ ṅụụrụ nna nna unu ha iyi inye unu.  
\v 14 A ga-agọzi unu karịa mba ndị ọzọ niile dị nʼụwa. Ọ dịghị onye ọbụla nʼime unu, maọbụ nwoke maọbụ nwanyị ga-anọ na-amụtaghị nwa, ọ dịkwaghị anụ ụlọ unu ga-agba aka nwa.  
\v 15 \nd Onyenwe anyị\nd* ga-ewepụrụ unu ọrịa niile. Ọ gaghị ekwe ka ọrịa ndị Ijipt ọbụla, nke unu na-echeta nke ọma dakwasị unu, ọrịa ndị a niile ka ọ ga-eme ka ọ bịakwasị ndị iro unu!  
\v 16 Mba ọbụla \nd Onyenwe anyị\nd* bụ Chineke unu nyefere unu nʼaka ka unu ga-ala nʼiyi. Unu emerela ha ebere, unu efekwala chi niile ha, nʼihi na nke a ga-abụrụ unu ihe ịma nʼọnya. 
\p  
\v 17 Ma eleghị anya, unu ga na-eche nʼime onwe unu sị, “Mba ndị a dị ike karịa anyị, olee otu anyị ga-esi chụpụ ha?”  
\v 18 Ma unu atụla egwu! Naanị chetanụ ihe \nd Onyenwe anyị\nd* bụ Chineke unu mere Fero na ndị Ijipt niile.  
\v 19 Unu ji anya unu hụ ọnwụnwa ukwuu niile, ihe ịrịbama niile na ihe ebube niile, nʼaka ahụ dị ike na ogwe aka esetipụrụ esetipụ, nke \nd Onyenwe anyị\nd* bụ Chineke unu ji kpọpụta unu. \nd Onyenwe anyị\nd* bụ Chineke ga-emekwa otu ihe ahụ nʼebe ndị niile a unu na-atụ egwu ugbu a.  
\v 20 Karịsịa, \nd Onyenwe anyị\nd* bụ Chineke unu ga-ezipụ ebu nʼetiti ha tutu ruo mgbe ọ bụladị ndị fọdụrụ ndụ, ndị ahụ ga-ezo onwe ha site nʼebe unu nọ, ghọrọ ndị e bibiri.  
\v 21 Unu amala jijiji nʼihu ha, nʼihi na \nd Onyenwe anyị\nd* bụ Chineke unu, onye nọ nʼetiti unu bụ Chineke dị ukwuu, dịkwa egwu.  
\v 22 \nd Onyenwe anyị\nd* bụ Chineke unu, ga-achụpụ mba ndị a ntakịrị ntakịrị. Ọ gaghị ekwe ka unu chụpụ ha otu ugboro, ma ọ bụghị ya, ụmụ anụ ọhịa ọjọọ ga-amụba megide unu.  
\v 23 \nd Onyenwe anyị\nd* Chineke unu ga-enyefe ha nʼaka unu, ọ ga-etinye ha oke ọgbaaghara nʼobi, tutu ruo mgbe ha lara nʼiyi.  
\v 24 Eze ha niile ka ọ ga-enyefe nʼaka unu, unu ga-ehichapụkwa aha ha nʼelu ụwa. Ọ dịkwaghị onye pụrụ iguzo nʼihu unu, nʼihi na unu ga-ebibi ha niile.  
\v 25 Kpọọnụ arụsị niile nke apịrị apị nke chi niile ha ọkụ. Unu enwela anya ukwu nʼebe ọlaọcha maọbụ ọlaedo dị ha nʼahụ dị. Unu ewerela ya ka ọ bụrụ nke unu, ka unu ghara ịbụ ndị ọ matara nʼọnya, nʼihi na ọ bụ ihe arụ nye \nd Onyenwe anyị\nd* bụ Chineke unu.  
\v 26 Unu ewebatala ihe arụ ọbụla nʼụlọ unu, ka unu ghara ịbụ ihe e debere iche nye mbibi dịka ya. Kpọọnụ ihe arụ ahụ asị, ledakwanụ ya anya, nʼihi na ihe e debere iche nye mbibi ka ọ bụ. 
\c 8  
\s1 Echezọla \nd Onyenwe anyị\nd* 
\p  
\v 1 Lezie anya hụ na i debezuru iwu ndị a niile m nyere gị taa. Ọ bụrụ na i debe ha, ọ bụghị naanị na ị ga-adị ndụ, kama ị ga-amụba, banyekwa inweta ala ahụ \nd Onyenwe anyị\nd* kwere nna nna gị ha na nkwa.  
\v 2 Chetakwa otu \nd Onyenwe anyị\nd* bụ Chineke gị si duo gị nʼime ọzara iri afọ anọ ndị a niile. O wedara mmụọ gị ala, nwakwaa gị ọnwụnwa ịmata ihe dị gị nʼobi, ịchọpụta ma ị ga-edebekwa iwu ya.  
\v 3 E, o wedatara mmụọ gị ala mgbe o mere ka ihe oriri kọ gị, mgbe o mere ka i rie mánà, nri ahụ gị na nna gị na-amaghị ihe ọ bụ. O mere nke a igosi gị na izi gị na ọ bụghị naanị achịcha ka mmadụ ga-eji dị ndụ, kama ọ bụ nʼokwu niile nke si nʼọnụ \nd Onyenwe anyị\nd* pụta.  
\v 4 Iri afọ anọ ndị a niile, uwe gị akaghị nka, ụkwụ gị azakwaghị aza.  
\v 5 Nʼihi ya, mata nke a nʼobi gị, na dịka nna si adọ nwa ya aka na ntị, otu a ka \nd Onyenwe anyị\nd* bụ Chineke gị si adọ gị aka na ntị. 
\p  
\v 6 Debe iwu \nd Onyenwe anyị\nd* Chineke gị. Na-ejegharị ije nʼụzọ ya, ma na-atụkwa ya egwu.  
\v 7 Nʼihi na \nd Onyenwe anyị\nd* Chineke gị na-ewebata gị nʼala mara mma, bụ ala nwere iyi, na ọdọ mmiri, ala nwere mmiri nke si nʼime ya na-asọpụta asọgharị nʼugwu na ndagwurugwu,  
\v 8 ọ bụ ala na-epu ọka wiiti na ọka balị, na osisi vaịnị, na osisi fiig, na osisi pomegranet, na mmanụ oliv, na mmanụ aṅụ.  
\v 9 Ọ bụkwa ala jupụtara nʼihe oriri, ebe a na-agaghị enwe ụkọ nri. Ọ bụ ala ebe igwe jupụtara nʼime ya dị ka ha bụ nkume, ala ebe ọla jupụtakwara nʼugwu ya niile. 
\p  
\v 10 Mgbe i riri rijuo afọ, too \nd Onyenwe anyị\nd* Chineke gị nʼihi ala mara mma nke o nyere gị.  
\v 11 Ma lezie anya ka ị ghara ichefu \nd Onyenwe anyị\nd* Chineke gị, na-edebeghị iwu ya niile, na ikpe ya niile, na ụkpụrụ ya niile, nke m na-enye gị taa.  
\v 12 Ka ọ ghara ị bụ, mgbe i riri rijuru afọ, mgbe i wuuru onwe gị ezi ụlọ dị mma birikwa nʼime ha,  
\v 13 mgbe igwe ehi na igwe atụrụ gị mụbara, mgbe ọlaọcha na ọlaedo gị mụbara, na mgbe ihe niile i nwere mụbara.  
\v 14 Kpachara anya hụ na nganga abanyeghị gị nʼobi, ime ka i chefuo \nd Onyenwe anyị\nd* Chineke gị onye mere ka ị site nʼIjipt, sitekwa nʼala ịbụ ohu pụta.  
\v 15 Onye duuru gị nʼime ọzara ukwu ahụ dị egwu, ebe agwọ ọjọọ na akpị jupụtara, ebe na-ekpo ọkụ, nke mmiri na-adịghị. O sitere na nkume nye gị mmiri ọṅụṅụ  
\v 16 O ji mánà nyejuo gị afọ nʼọzara, mánà ahụ nna gị ha na-amaghị ihe ọ bụ na mbụ. O mere ya nʼihi iweda mmụọ gị ala, na ịnwale gị, ka ihe si otu a gaara gị nke ọma.  
\v 17 I nwere ike kwuo sị, “Ọ bụ site nʼike aka m ka m ji baa ụba.”  
\v 18 Ma cheta \nd Onyenwe anyị\nd* Chineke gị, nʼihi na ọ bụ ya onwe ya na-enye gị ike i ji akpata akụ, ime ka ọgbụgba ndụ ya guzosie ike, bụ nke ọ ṅụrụ nna nna gị ha nʼiyi, dịka ọ dị taa. 
\p  
\v 19 Ma ọ bụrụ na i chefuo \nd Onyenwe anyị\nd* bụ Chineke gị, gbasoo chi ndị ọzọ, fee ha ofufe ma kpọọkwa isiala nye ha, ana m agba ama megide gị taa na ị ghaghị ịla nʼiyi.  
\v 20 Ọ bụrụ na unu egeghị ntị nʼolu \nd Onyenwe anyị\nd* Chineke unu, ime ihe ọ chọrọ, ọ ga-ala unu nʼiyi, dịka o si bibie mba ndị a niile dị iche iche ọ na-ebibi nʼihi unu. 
\c 9  
\s1 Ọ bụghị nʼihi ezi omume Izrel 
\p  
\v 1 Nụrụ, Izrel! Taa ka ị na-aga ịgafe osimiri Jọdan ịbanye ka inweta ala mba ndị dị ukwuu na ndị dị ike karịa gị, inweta obodo ndị dị ukwuu nke nwere mgbidi ha dị elu ruo nʼeluigwe.  
\v 2 Ndị bi nʼime ha bụ ndị Anak, ndị gbara dimkpa, too ogologo nke ukwuu. Ị maara banyere ha. Ị nụkwaala ka e kwuru sị, “Onye pụrụ iguzo onwe ya nʼihu ụmụ Anak?”  
\v 3 Ma mata taa na \nd Onyenwe anyị\nd* Chineke gị bụ onye na-aga nʼihu gị dịka ọkụ na-erepịa erepịa. Ọ ga-ala ha nʼiyi. Ọ bụkwa ya ga-eme ka unu lụgbuo ha, chụpụ ha, bibiekwa ha ngwangwa dịka \nd Onyenwe anyị\nd* kwere gị na nkwa. 
\p  
\v 4 Mgbe \nd Onyenwe anyị\nd* Chineke gị sitere nʼihu gị chụpụ ha, asịla onwe gị, “\nd Onyenwe anyị\nd* akpọbatala m nʼebe a, ka m nweta ala a nʼihi ezi omume m.” Mba, ọ bụ naanị nʼihi ajọ omume nke mba ndị a bi nʼala ahụ ka \nd Onyenwe anyị\nd* ji esite nʼihu gị chụpụ ha.  
\v 5 Ọ bụghị nʼihi ezi omume gị, maọbụ izi ezi nke obi gị ka ị ga-eji nweta ala ahụ, kama ọ bụ nʼihi ajọ omume nke mba ndị a bi nʼime ya ka \nd Onyenwe anyị\nd* Chineke gị ga-eji achụpụ ha site nʼihu gị. Ọ na-emekwa ya nʼihi imezu nkwa ahụ o kwere nna nna gị ha bụ Ebraham, Aịzik, na Jekọb.  
\v 6 Ya mere, ghọta ya nke ọma na \nd Onyenwe anyị\nd* Chineke gị anaghị enye gị ezi ala a ka inweta ya nʼihi ezi omume gị, nʼihi na unu bụ ndị isiike. 
\s1 Nwa ehi ọlaedo 
\p  
\v 7 Chetakwa nke a ma echefukwala otu i si kpasuo \nd Onyenwe anyị\nd* Chineke gị iwe, mgbe mgbe, nʼime ọzara. Site nʼụbọchị ị hapụrụ Ijipt tutu ruo taa, ka ị na-enupu isi nʼebe \nd Onyenwe anyị\nd* nọ.  
\v 8 Unu kpasuru \nd Onyenwe anyị\nd* iwe nʼugwu Horeb, ya mere o jiri were iwe laa unu nʼiyi.  
\v 9 Mgbe m rigooro nʼelu ugwu ahụ ịnata mbadamba nkume ndị ahụ bụ mbadamba nkume ọgbụgba ndụ dị nʼetiti \nd Onyenwe anyị\nd* na unu, anọrọ m nʼelu ugwu ahụ iri ụbọchị anọ, ehihie na abalị, ọ dịghị nri m riri, ọ dịghịkwa mmiri m ṅụrụ.  
\v 10 \nd Onyenwe anyị\nd* nyere m mbadamba nkume abụọ ndị ahụ, nke eji mkpịsịaka Chineke dee. Edekwasịrị nʼelu ha iwu niile nke \nd Onyenwe anyị\nd* gwara unu nʼugwu ahụ site nʼetiti ọkụ, nʼụbọchị mkpọkọta ahụ. 
\p  
\v 11 Mgbe iri abalị anọ gwụrụ \nd Onyenwe anyị\nd* nyere m mbadamba nkume abụọ ndị ahụ, bụ mbadamba nkume ọgbụgba ndụ.  
\v 12 Mgbe ahụ ka \nd Onyenwe anyị\nd* gwara m sị m, “Rịdata ọsịịsọ, nʼihi na ndị gị, ndị i si nʼIjipt dupụta, emerụọla onwe ha, ha emeela ngwangwa iwezuga onwe ha site nʼiwu m nyere ha. Ha emeerela onwe ha nwa ehi a kpụrụ akpụ, ka ọ bụrụ chi ha.” 
\p  
\v 13 \nd Onyenwe anyị\nd* gwara m sị, “Ahụla m na ndị a bụ ndị isiike nʼezie.  
\v 14 Hapụ m, ka m kpochapụ ma hichapụkwa aha ha site nʼokpuru eluigwe. Aga m emekwa gị ka ị ghọọ mba dị ike karịa, dịkwa ọtụtụ nʼọnụọgụgụ karịa ha.” 
\p  
\v 15 Ya mere, atụgharịrị m malite isi nʼugwu ahụ na-enwu ọkụ rịdata, ejikwa m mbadamba nkume abụọ nke ọgbụgba ndụ ahụ nʼaka m.  
\v 16 Mgbe m lepụrụ anya, ahụrụ m na unu emeela mmehie megide \nd Onyenwe anyị\nd* Chineke unu. Unu akpụọlara onwe unu arụsị nʼụdị nwa ehi. Unu esitela nʼịgbaso iwu \nd Onyenwe anyị\nd* wezuga onwe unu ọsịịsọ.  
\v 17 Mgbe ahụ, ewere m mbadamba nkume abụọ ahụ, tụpụ ha site nʼaka m abụọ, kụrie ha nʼihu unu. 
\p  
\v 18 Mgbe ahụ, adara m nʼala ọzọ nʼihu \nd Onyenwe anyị\nd*. Iri ụbọchị anọ, ehihie na abalị, erighị m nri maọbụ ṅụọ ihe ọṅụṅụ ọbụla, nʼihi mmehie niile unu mere. Unu mere ihe ọjọọ nʼanya \nd Onyenwe anyị\nd* si otu a kpasuo ya iwe nke ukwuu.  
\v 19 Atụrụ m egwu iwe na ọnụma nke \nd Onyenwe anyị\nd*, nʼihi na iwe ya dị ukwuu megide unu ruo na ikpochapụ unu. Ma nʼoge ahụ, \nd Onyenwe anyị\nd* gere ntị nʼarịrịọ m.  
\v 20 Nʼoge ahụ, Erọn nʼonwe ya, nọrọ nʼoke nsogbu, nʼihi na \nd Onyenwe anyị\nd* were iwe megide ya, chọọ ibibi ya, ma arịọrọ m \nd Onyenwe anyị\nd* arịrịọ nʼihi ya.  
\v 21 Mgbe ahụ, eweere m ngwa ọrụ mmehie unu, ya bụ nwa ehi ahụ unu kpụrụ, kpọọ ya ọkụ, tipịa ya, gwerie ya nke ọma dịka ntụ, wụnye ntụ ya nʼime mmiri nke si nʼugwu na-asọpụta. 
\p  
\v 22 Ọzọkwa, unu kpasuru \nd Onyenwe anyị\nd* iwe na Tabera, na Masa, ọ bụladị na Kibrọt Hataava. 
\p  
\v 23 Mgbe \nd Onyenwe anyị\nd* si na Kadesh Banea zipụ unu ọ sị unu, “Gaanụ nweta ala ahụ m nyere unu.” Ma unu nupuru isi nʼiwu \nd Onyenwe anyị\nd* Chineke unu nyere unu. Unu ekwenyeghị maọbụ rubere ya isi.  
\v 24 Site nʼụbọchị m maara ndị unu bụ, ọ dịbeghị mgbe unu na-enupughị isi nʼebe \nd Onyenwe anyị\nd* nọ. 
\p  
\v 25 Ọ bụ ya mere m jiri daa nʼala nʼihu \nd Onyenwe anyị\nd* iri ụbọchị anọ, ehihie na abalị, nʼihi na \nd Onyenwe anyị\nd* kwuru na ọ ga-ala unu nʼiyi.  
\v 26 Ekpere m ekpere nʼoge ahụ nye \nd Onyenwe anyị\nd* sị ya, “Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* biko, alala ndị gị nʼiyi, nʼihi na ha bụ ihe nketa gị, bụrụkwa ndị i ji ike aka gị na ebube gị gbapụta site nʼIjipt.  
\v 27 Elekwasịla nnupu isi ha na isiike ha anya, kama, cheta nkwa gị, nke i kwere ndị ohu gị, Ebraham, Aịzik, na Jekọb. Biko, agụnyela ndụ ọjọọ ha, na mmehie ha megide ha.  
\v 28 Ma ọ bụghị otu a, ndị obodo ahụ nke i si na ya kpọpụta anyị ga-asị, ‘Ọ bụ nʼihi na \nd Onyenwe anyị\nd* apụghị inye ha ala o kwere ha na nkwa ka o ji laa ha nʼiyi. Nʼihi na ọ kpọrọ ha asị, ka o ji kpọbata ha nʼime ọzara mee ka ha nwụọ nʼebe ahụ.’  
\v 29 Ma ha bụ ndị gị, ha bụkwa ihe nketa gị. Ha bụ ndị i sitere nʼike gị dị egwu na ike nke aka gị kpọpụta site nʼIjipt.” 
\c 10  
\s1 Mbadamba nkume abụọ ọzọ 
\p  
\v 1 Nʼoge ahụ, \nd Onyenwe anyị\nd* gwara m, sị, “Wapụta mbadamba nkume abụọ dịka nke mbụ, were ha bịakwute m nʼelu ugwu. Ọzọ, wuokwara onwe gị igbe osisi.  
\v 2 Aga m edekwasị nʼelu mbadamba nkume ndị a, okwu niile nke dị nʼelu mbadamba nkume ndị mbụ, bụ nke ị tụpịasịrị. Ị ga-etinyekwa ha nʼime igbe ahụ.” 
\p  
\v 3 Ya mere, eji m osisi akashia kwaa igbe ahụ. A wapụtakwara m mbadamba nkume abụọ yiri ndị nke mbụ, were ha rigoro ugwu ahụ.  
\v 4 \nd Onyenwe anyị\nd* dere nʼelu mbadamba nkume ahụ ihe ndị ahụ o dere na mbụ, bụ iwu iri ndị ahụ o gwara unu nʼelu ugwu site nʼime ọkụ, nʼụbọchị mkpọkọta ahụ. \nd Onyenwe anyị\nd* nyekwara m ha.  
\v 5 Mgbe m si nʼugwu ahụ rịdata, etinyere m mbadamba nkume abụọ ahụ nʼime igbe ahụ m kwara, dịka \nd Onyenwe anyị\nd* nyere m nʼiwu. Ha dịkwa nʼebe ahụ ruo taa. 
\p  
\v 6 (Ụmụ Izrel gara ije site nʼolulu mmiri nke Bene Jaakan garuo Mosera, nʼebe ahụ ka Erọn nọ nwụọ, e lie ya nʼebe ahụ. Elieza, bụ ọkpara ya nọchiri ọnọdụ ya dịka onye nchụaja.  
\v 7 Site nʼebe ahụ, ha gagidere ije ruo Gudgoda, sitekwa na ya ruo Jotbata, ala nke iyi na-asọ asọ juru nʼime ya.  
\v 8 Nʼoge ahụ, \nd Onyenwe anyị\nd* kewapụtara ebo Livayị ibu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*, na iguzo nʼihu \nd Onyenwe anyị\nd* ijere ya ozi na ikwupụta ngọzị nʼaha ya, dịka ha sị eme ruo taa.  
\v 9 Ọ bụ nke a mere ndị Livayị enweghị oke maọbụ ihe nketa nʼetiti ndị Izrel ibe ha; \nd Onyenwe anyị\nd* bụ ihe nketa ha, dịka \nd Onyenwe anyị\nd* Chineke unu gwara ha.) 
\p  
\v 10 Ugbu a, anọọla m nʼelu ugwu ahụ iri ụbọchị anọ, ehihie na abalị, dịka m mere nʼoge mbụ, \nd Onyenwe anyị\nd* gekwara m ntị nʼoge ugbu a. Ọ bụghị ọchịchọ \nd Onyenwe anyị\nd* ibibi unu.  
\v 11 \nd Onyenwe anyị\nd* gwara m, “Bilie, gaa ka i duru ndị a gaa na njem ha, ka ha banye, ma nwetakwa ala ahụ nke m kwere nna nna ha na nkwa inye ha.” 
\s1 Sọpụrụ \nd Onyenwe anyị\nd* 
\p  
\v 12 Ugbu a, Izrel, gịnị ka \nd Onyenwe anyị\nd* Chineke gị na-ana nʼaka gị ma ọ bụghị ka ị tụọ egwu \nd Onyenwe anyị\nd* bụ Chineke gị, jee ije na nrube isi nye ya, ịhụ ya nʼanya, na iwere obi gị niile na mmụọ gị niile fee ya ofufe,  
\v 13 na ilezi anya debezuo iwu na ụkpụrụ \nd Onyenwe anyị\nd*, ndị m na-enye gị taa, nʼihi ọdịmma gị. 
\p  
\v 14 Ụwa na eluigwe na ebe niile kachasị elu nke eluigwe, na ihe niile dị nʼime ha, bụ nke \nd Onyenwe anyị\nd* Chineke gị.  
\v 15 Ma \nd Onyenwe anyị\nd* nwere mmasị nʼahụ nna nna unu ha, hụkwa ha nʼanya, ọ họrọ unu, na naanị ụmụ ha niile, site nʼetiti mba niile dịka ọ dị taa.  
\v 16 Nʼihi nke a, biekwanụ obi unu ugwu, kwụsịkwanụ ibi ndụ nke isiike.  
\v 17 Nʼihi na \nd Onyenwe anyị\nd*, bụ Chineke unu bụ Chineke kachasị chi niile, bụrụkwa Onyenwe kachasị ndị nwenụ niile. Chineke ukwu ahụ, onye dị ike dịkwa egwu, onye na-adịghị ele mmadụ anya nʼihu, ọ nakwaghị eri ngarị.  
\v 18 Ọ na-alụrụ ndị na-enweghị nna, na ụmụ nwanyị na-enweghị di ọgụ. Ọ na-ahụ ndị ọbịa nʼanya, na-enyekwa ha nri na uwe.  
\v 19 Ya mere, unu onwe unu kwa, hụnụ ndị ọbịa nʼanya, nʼihi na unu onwe unu bụrụrị ndị ọbịa nʼala Ijipt.  
\v 20 Tụọ \nd Onyenwe anyị\nd* Chineke gị egwu, feekwa ya ofufe. Ya ka ị ga-arapara nʼahụ,\f + \fr 10:20 \ft Ya ka ị ga-ejidesi aka ike\f* ọ bụkwa naanị nʼaha ya ka ị ga-aṅụ iyi.  
\v 21 Ọ bụ ya bụ onye ị ga-eto otuto, ọ bụ ya bụ Chineke gị, onye rụrụ gị ọrụ ndị ahụ dị oke egwu na ebube, nke gị onwe gị ji anya gị hụ.  
\v 22 Nna nna unu ndị gara nʼIjipt dị naanị iri mmadụ asaa, ma ugbu a, \nd Onyenwe anyị\nd* Chineke gị emeela ka ịmụbaa dịka kpakpando nke mbara igwe. 
\c 11  
\s1 Ịhụ \nd Onyenwe anyị\nd* nʼanya na irubere ya isi 
\p  
\v 1 Hụ \nd Onyenwe anyị\nd* bụ Chineke gị nʼanya, na-edebezukwa ikpe ya na ụkpụrụ ya na ihe niile o nyere nʼiwu.  
\v 2 Chetanụ taa na ọ bụghị ụmụ unu, kama ọ bụ unu onwe unu jiri anya unu hụ ịdọ aka na ntị \nd Onyenwe anyị\nd* Chineke unu. Ọ bụ unu hụrụ ịdị ukwuu ya, ịdị ike ya, ịrụsị ọrụ ike nke ike ya,  
\v 3 ihe ịrịbama ya niile na ihe niile o mere nʼIjipt, otu o si megide Fero eze Ijipt na ndị ala Ijipt niile.  
\v 4 Unu hụrụ ihe o mere ndị agha Ijipt na ịnyịnya ha, na ụgbọ agha ha. Otu o si mee ka ha laa nʼiyi nʼime Osimiri Uhie, mgbe ha na-achụ unu ọsọ, na otu \nd Onyenwe anyị\nd* si wetara ha ịla nʼiyi ebighị ebi.  
\v 5 Ọ bụghị ụmụ unu hụrụ ihe o meere unu nʼoge ahụ niile unu nọ nʼọzara tutu unu erute nʼebe a,  
\v 6 na ihe o mere Datan na Abiram, ụmụ Eliab, ndị si nʼebo Ruben, otu ala si meghee ọnụ ya loda ha, ha na ezinaụlọ ha, ụlọ ikwu ha na ihe ọbụla nke dị ndụ ha nwere nʼetiti Izrel niile.  
\v 7 Ma ọ bụ anya unu hụrụ oke ihe ịtụnanya ndị a niile \nd Onyenwe anyị\nd* mere. 
\p  
\v 8 Lezienụ anya debe iwu ndị a m na-enye unu taa, ka unu nwee ike, baa bichikwaa ala ahụ unu na-agafe Jọdan inweta,  
\v 9 ka unu bie ogologo ndụ nʼime ala ahụ \nd Onyenwe anyị\nd* ṅụrụ nʼiyi inye nna nna unu ha, na ụmụ ụmụ ha, ala mmiri ara ehi na mmanụ aṅụ na-eru na ya.  
\v 10 Nʼihi na ala a unu na-aga ịbanye nʼime ya inweta adịghị ka ala Ijipt, ebe unu si pụta, ebe ị na-agha mkpụrụ gị, were ụkwụ tụwara mmiri ụzọ,\f + \fr 11:10 \ft Nke a bụ nʼala ebe ihe ọkụkụ na-adịghị eto ma a gbaghị ya mmiri.\f* dịka a na-eme nʼubi akwụkwọ nri.  
\v 11 Ma ala unu na-agafe Jọdan inweta bụ ala nwere ugwu na ndagwurugwu, nke na-aṅụ mmiri ozuzo si nʼeluigwe.  
\v 12 Ọ bụ ala nke \nd Onyenwe anyị\nd* Chineke unu nʼonwe ya na-elekọta! Site nʼụbọchị ruo nʼụbọchị, sitekwa na mbido afọ ruo nʼọgwụgwụ afọ, anya ya adịghị apụ na ya. 
\p  
\v 13 Ya mere, ọ bụrụ na unu ga-eji ntụkwasị obi rube isi nʼiwu ya niile, nke m na-enye unu taa, ọ bụrụkwa na unu ga-eji obi unu niile na mmụọ unu niile hụ \nd Onyenwe anyị\nd* Chineke unu nʼanya, ọ bụrụkwa na unu ga-efe ya ofufe,  
\v 14 ọ ga na-ezite mmiri ozuzo nʼoge ya, mmiri ozuzo nke mbụ na nke ikpeazụ, nke ga-eme ka ọka unu mịa mkpụrụ hiri nne, ka unu nwee ọtụtụ vaịnị, nweekwa mmanụ oliv.  
\v 15 Ọ ga-eme ka anụ ụlọ gị nwee ahịhịa ha ga-ata, gị onwe gị ga-enwekwa ihe oriri dị ukwuu. Afọ ga-ejukwa gị nʼihe i nwere. 
\p  
\v 16 Ma lezienụ anya, ka ahapụ ịrafu obi unu mee ka unu wezuga onwe unu, bido ife chi ndị ọzọ ofufe, kpọọkwa isiala nye ha.  
\v 17 Mgbe ahụ, iwe \nd Onyenwe anyị\nd* ga-adị ọkụ nʼebe unu nọ, ọ ga-agbachi eluigwe, mmiri agaghị ezo, ala agaghị epupụtakwa ihe ubi, unu ga-alakwa nʼiyi nʼotu ntabi anya, nʼezi ala ahụ \nd Onyenwe anyị\nd* na-enye unu.  
\v 18 Meenụ ka okwu m ndị a dịgide nʼobi unu na nʼime mmụọ unu. Keenụ ha dịka ihe ịrịbama nʼelu aka unu, kekwasịkwa ha dịka ihe ncheta nʼegedege ihu unu.  
\v 19 Kuzierenụ ha ụmụ unu, na-ekwu ihe banyere ha mgbe ị na-anọdụ nʼụlọ gị, na mgbe ị na-aga nʼokporoụzọ, mgbe ị na-edina ala na mgbe i si nʼihe ndina bilie.  
\v 20 Dee ha nʼelu ibo ọnụ ụlọ gị na nke ọnụ ụzọ ama gị.  
\v 21 Ka ụbọchị ndụ unu na nke ụmụ unu dị ogologo nʼala ahụ unu na-aga ibi nʼime ya, nke \nd Onyenwe anyị\nd* kwere nna unu na nkwa. Dịka ogologo ụbọchị niile ha nke eluigwe dị nʼelu, ụwa dịkwa nʼokpuru ya. 
\p  
\v 22 Ọ bụrụ na unu elezie anya debe iwu niile m na-enye unu taa, na-ahụkwa \nd Onyenwe anyị\nd* Chineke unu nʼanya, na-eso ụzọ ya, na-adaberekwa na ya,  
\v 23 \nd Onyenwe anyị\nd* ga-achụpụ mba niile bi nʼala ahụ unu na-aga inweta, unu ga-anapụkwa ha ala ahụ, ọ bụladị na ha buru ibu, siekwa ike karịa unu.  
\v 24 Ebe ọbụla unu zọnyere ụkwụ unu nʼala ahụ aghọọla nke unu, site na ndịda Negeb ruo Lebanọn, sitekwa nʼOsimiri Yufretis ruo Osimiri Mediterenịa. Ha ga-abụ nke unu.  
\v 25 Ọ dịghị onye ọbụla pụrụ imegide unu nʼihi na \nd Onyenwe anyị\nd* Chineke unu ga-emenye ha egwu na ụjọ nʼafọ nʼụzọ ọbụla unu na-aga, dịka o kwere na nkwa. 
\p  
\v 26 Lee, taa, ana m eche nʼihu unu ngọzị \nd Onyenwe anyị\nd* na ọbụbụ ọnụ.  
\v 27 Ngọzị ga-adịrị unu ma ọ bụrụ na unu edebe iwu \nd Onyenwe anyị\nd* Chineke unu, nke m na-enye unu taa.  
\v 28 Nkọcha ahụ ga-adị ma ọ bụrụ na unu ajụ irube isi nye iwu niile nke \nd Onyenwe anyị\nd*, bụ Chineke unu, wezuga onwe unu nʼụzọ ahụ nke m nyere unu nʼiwu taa site nʼịgbaso chi ndị ọzọ, nke unu na-amaghị.  
\v 29 Mgbe \nd Onyenwe anyị\nd* Chineke unu mere ka unu nweta ala ahụ, a ga-esite nʼelu ugwu Gerizim kwupụta ngọzị ga-adịrị unu, a ga-esitekwa nʼelu ugwu Ebal kwupụta ọbụbụ ọnụ ga-adakwasị unu.  
\v 30 Gerizim na Ebal bụ ugwu dị nʼofe Jọdan, nʼakụkụ okporoụzọ dị nʼọdịda anyanwụ. Ọ dị nso nʼebe osisi ukwu ndị ahụ toro na More, nʼala ndị Kenan ahụ bi nʼAraba, nʼakụkụ Gilgal.  
\v 31 Nʼihi na unu na-aga ịgafe osimiri Jọdan, ịbanye nweta ala ahụ \nd Onyenwe anyị\nd* Chineke unu na-enye unu. Mgbe unu nwetara ya biri nʼime ya,  
\v 32 hụnụ na unu rubere isi debe iwu niile na ụkpụrụ niile m na-eche nʼihu unu taa. 
\c 12  
\s1 Ebe a ga-anọ fee Onyenwe anyị 
\p  
\v 1 Ndị a bụ iwu na ụkpụrụ niile unu na-aghaghị idebe ogologo ụbọchị niile unu ga-ebi nʼala ahụ, \nd Onyenwe anyị\nd* Chineke nna unu ha nyere unu, dịka ihe nweta.  
\v 2 Tikpọọnụ ebe niile nke dị nʼelu ugwu niile dị elu na nʼelu ugwu niile dị nta, nakwa nʼokpuru osisi mgbasa ọbụla, bụ ebe mba niile unu na-anapụ ala ha fere chi niile ha ofufe.  
\v 3 Kwatuokwanụ ebe ịchụ aja ha niile, tijisie ogidi nsọ ha niile, kpọọkwa osisi Ashera ha ọkụ, gbutukwaanụ arụsị niile a apịrị apị nke chi niile ha. Kpochapụkwanụ aha ha niile site nʼebe niile ahụ. 
\p  
\v 4 Unu agaghị efe \nd Onyenwe anyị\nd* Chineke unu ofufe dịka ndị ahụ na-efe arụsị na-eme.  
\v 5 Kama unu chọpụta ebe ahụ \nd Onyenwe anyị\nd* Chineke unu ga-ahọpụta, site nʼetiti ebo Izrel niile, ebe ọ ga-akpọkwasị aha ya. Nʼebe ahụ ka unu ga-abịakwute ya.  
\v 6 Ọ bụkwa nʼebe ahụ ka unu ga-ewetara \nd Onyenwe anyị\nd* aja nsure ọkụ unu, na aja ndị ọzọ niile, na otu ụzọ nʼụzọ iri unu, na onyinye pụrụ iche unu, bụ onyinye unu kwere nkwa inye, na onyinye afọ ofufu unu, na onyinye ụmụ mbụ igwe ehi, na igwe ewu na atụrụ unu.  
\v 7 Unu na ezinaụlọ unu ga-anọkwa nʼebe ahụ, nʼihu \nd Onyenwe anyị\nd* Chineke unu, rie oriri unu. Nʼihu ya kwa ka unu ga-aṅụrịkwa ọṅụ, nʼihi ihe niile ahụ unu setịpụrụ aka unu ime, na nʼihi ngọzị \nd Onyenwe anyị\nd* Chineke unu gọziri unu. 
\p  
\v 8 Unu agaghị emekwa ihe masịrị unu, dịka unu si eme taa, nʼihi na onye ọbụla na-eme ihe ọbụla o chere na o ziri ezi nʼanya ya,  
\v 9 nʼihi na iwu ndị a ebidobeghị ịdị ire, ebe ọ bụ na unu abanyebeghị nʼebe izuike ahụ, na ihe nketa ahụ \nd Onyenwe anyị\nd* Chineke unu na-enye unu.  
\v 10 Kama, mgbe unu gafere osimiri Jọdan, birikwa nʼala ahụ \nd Onyenwe anyị\nd* Chineke unu na-enye unu dịka ihe nketa, mgbe \nd Onyenwe anyị\nd* nyere unu izuike, meekwa ka unu nwere onwe unu site nʼebe ndị iro unu nọ.  
\v 11 Mgbe ahụ, unu ga-eweta ihe ndị ahụ niile m nyere unu nʼiwu: aja nsure ọkụ unu niile, na aja ndị ọzọ, na onyinye ahụ pụrụ iche unu kwere nkwa inye, unu ga-eweta ya nʼebe ahụ \nd Onyenwe anyị\nd* Chineke unu họpụtara ebe o kpọkwasịrị aha ya.  
\v 12 Unu na ụmụ unu ndị ikom, na ụmụ unu ndị inyom, na ndị odibo nwoke na nwanyị niile unu, na ndị Livayị bi nʼobodo unu, ndị na-enweghị ihe nketa nke aka ha, ga-anọ nʼebe ahụ ṅụrịa ọṅụ nʼihu \nd Onyenwe anyị\nd* Chineke unu.  
\v 13 Ị gaghị achụ aja nsure ọkụ gị nʼebe ọbụla masịrị gị,  
\v 14 ọ bụ naanị nʼebe ahụ \nd Onyenwe anyị\nd* ga-ahọpụta. Ọ ga-ahọpụta otu ebe, nʼala otu ebo. Ọ bụ naanị nʼebe ahụ ka ị ga-esure aja unu niile, ọ bụkwa nʼebe ahụ ka ị ga-eweta onyinye gị niile. 
\p  
\v 15 Otu ọ dị, ị pụrụ ịnọ nʼebe ọbụla gbuo anụ ị ga-eri, dịka ọ bụ ele maọbụ mgbada ugbu a. Rie anụ mgbe ọbụla ọ gụrụ gị agụụ, na-erikwa ya mgbe ọbụla i nwetara ya, dịka ngọzị \nd Onyenwe anyị\nd* Chineke unu na-enye unu. Ma onye dị ọcha, ma onye na-adịghị ọcha nwere ike iso rie ya.  
\v 16 Naanị iwu dị nʼiri anụ ndị a bụ na ị gaghị eri ọbara ya, wụsa ọbara ya nʼala, dịka mmiri.  
\v 17 Ma o nweghị onyinye ọbụla a na-enye \nd Onyenwe anyị\nd* i kwesiri ịnọ nʼụlọ gị rie. I kwesighị ịnọ nʼụlọ gị rie onyinye ndị a: onyinye otu ụzọ nʼụzọ iri nke ọka na mmanya ọhụrụ gị, na nke mmanụ oliv, na ụmụ mbụ nke igwe ehi na igwe ewu na atụrụ gị, na ihe ọbụla i kwere na nkwa, na onyinye afọ ofufu gị, na onyinye ndị ọzọ pụrụ iche.  
\v 18 Kama unu ga-eri ha nʼihu \nd Onyenwe anyị\nd* bụ Chineke unu, nʼebe ahụ \nd Onyenwe anyị\nd* Chineke unu ga-ahọpụta, gị onwe gị, na ụmụ gị ndị nwoke na ụmụ gị ndị nwanyị, na ndị odibo nwoke na nwanyị niile unu, na ndị Livayị si nʼobodo unu niile, unu ga-aṅụrịkwa ọṅụ nʼihu \nd Onyenwe anyị\nd* bụ Chineke unu, nʼihe niile aka gị rụpụtara.  
\v 19 Echefukwala ndị Livayị, gị na ha ga na-enwekọ ihe ndị a niile, ogologo ụbọchị niile i biri nʼala ahụ. 
\p  
\v 20 Mgbe \nd Onyenwe anyị\nd*, bụ Chineke gị mere ka oke ala gị saa mbara, dịka o kwere gị na nkwa, i nwee oke agụụ maka iri anụ na-asị, “Achọrọ m iri anụ,” mgbe ahụ, i nwere ike rie anụ dịka i si chọọ.  
\v 21 Ọ bụrụ nʼebe ahụ \nd Onyenwe anyị\nd* Chineke gị kpọkwasịrị aha ya dị gị anya site nʼebe i nọ, i nwere ike gbuo anụ ụlọ site nʼigwe ehi maọbụ ewu na atụrụ nke \nd Onyenwe anyị\nd* nyere gị, dịka m si nye gị nʼiwu. Gbuo ha nʼobodo ebe i bi, riekwa ha otu ị chọrọ.  
\v 22 Rie ha dịka ị ga-esi rie ele maọbụ mgbada. Onye ọbụla nʼime unu nwere ike rie ya, ma onye dị ọcha ma onye na-adịghị ọcha.  
\v 23 Ma lezie anya hụ na i righị ọbara, nʼihi na ndụ dị nʼọbara. Ị gaghị erikọta anụ ọbụla na ndụ ya.  
\v 24 Erila ọbara, wụsa ya nʼala dịka mmiri.  
\v 25 Erila ya, ka ihe si otu a gaara gị na ụmụ ụmụ gị nke ọma, nʼihi na ị na-eme ihe ziri ezi nʼanya \nd Onyenwe anyị\nd*. 
\p  
\v 26 Ma were ihe ndị ahụ niile i doro nsọ, ya na ihe ọbụla i kwere \nd Onyenwe anyị\nd* na nkwa gaa nʼebe ahụ \nd Onyenwe anyị\nd* ga-ahọpụta.  
\v 27 Chụọ aja nsure ọkụ nʼelu ebe ịchụ aja \nd Onyenwe anyị\nd* Chineke gị, ma anụ na ọbara. A ghaghị ịwụsa ọbara anụ ahụ e ji chụọ aja nʼakụkụ ebe nchụaja nke \nd Onyenwe anyị\nd* Chineke gị. Ma i nwere ike rie anụ ahụ e ji chụọ aja.  
\v 28 Lezie anya, debe iwu ndị a niile m na-enye gị. Ọ bụrụ na i mee ya, ihe ga-agara gị na ụmụ gị nke ọma, nʼihi na ọ bụ ihe dị mma nʼanya \nd Onyenwe anyị\nd* Chineke gị, na ihe ziri ezi ka ị ga na-eme. 
\p  
\v 29 \nd Onyenwe anyị\nd* Chineke gị ga-ala mba niile bi nʼala ahụ ị na-aga ibuso agha nʼiyi. Ma mgbe i si nʼala ahụ chụpụ ha, ị ga-ebichi nʼala ha.  
\v 30 Mgbe ị lachara ha nʼiyi, lezie anya ka ị ghara ịma nʼọnya, site nʼịjụ ajụjụ ka ịjụpụta otu ha si efe chi ha, na-asị, “Mba ndị a o si aṅaa na-efe chi ha ofufe? Anyị ga-emekwa otu a.”  
\v 31 Efekwala \nd Onyenwe anyị\nd* bụ Chineke gị dịka ha si efe chi ha, nʼihi na mgbe ha na-efe chi ha ofufe, ha na-eme ihe arụ dị iche iche nke \nd Onyenwe anyị\nd* kpọrọ asị. Ọ bụladị ụmụ ha ndị ikom na ndị inyom ka ha na-esure nʼọkụ nye chi ha dị iche iche dịka aja. 
\p  
\v 32 Lezienụ anya hụ na unu na-eme ihe niile bụ nke m nyere unu nʼiwu. Unu etinyela ihe nʼime ya maọbụ wepụkwa ihe site na ya. 
\c 13  
\s1 Ikpere chi ndị ọzọ\f + \fr 13:1 \ft Maọbụ, \fqa ikpere arụsị\f* 
\p  
\v 1 Ọ bụrụ na onye amụma, maọbụ onye na-akọwa nrọ apụta nʼetiti gị kwee nkwa na ihe ịrịbama maọbụ ihe dị ebube na-aga ime,  
\v 2 ọ bụrụkwa na ihe ịrịbama ahụ maọbụ ihe ebube ahụ e kwuru maka ya emezuo, emesịa onye amụma ahụ na-asị, “Ka anyị gbaso chi ndị ọzọ dị iche, ka anyị feekwa ha,” bụ chi ndị ị na-amaghị,  
\v 3 egela okwu onye amụma maọbụ ọrọ nrọ ahụ ntị. Nʼihi na \nd Onyenwe anyị\nd* bụ Chineke unu na-ele unu ule ịmata ma unu jikwa obi unu, na uche unu hụ ya nʼanya.  
\v 4 Ọ bụ \nd Onyenwe anyị\nd* bụ Chineke unu ka unu ga-eso, naanị ya ka unu ga-atụ egwu. Debenụ iwu ya niile na-erubekwara ya isi, na-ejere ya ozi, jidesiekwa ya ike.  
\v 5 A ga-egbu onye amụma ahụ maọbụ onye ọrọ nrọ ahụ nke chọrọ iduhie unu, nʼihi na ọ chọrọ iweta nnupu isi megide \nd Onyenwe anyị\nd* bụ Chineke unu, onye kpọpụtara unu site nʼala Ijipt, onye gbapụtara unu site nʼọnọdụ ịbụ ndị ohu. Ihe ọ chọrọ ime bụ iduhie gị, ka ị ghara ibi ụdị ndụ ahụ \nd Onyenwe anyị\nd* Chineke gị chọrọ ka i bie. Ọnwụ ya ga-eme ka i wezuga ihe ọjọọ site nʼetiti gị. 
\p  
\v 6 Ọ bụrụ na ezi enyi gị maọbụ nwanne gị nwoke maọbụ nwa gị nwoke maọbụ nwunye gị ị hụrụ nʼanya ejiri aghụghọ gwa gị okwu sị gị, “Bịa ka anyị gaa fee chi ndị ọzọ ofufe” (bụ chi ndị ị na-amaghị maọbụ nke nna gị ha na-amaghị,  
\v 7 chi nke ndị ala ahụ gbara unu gburugburu, ma ha bụ ndị bi gị nso ma ha bụ ndị bi nʼebe dị anya, site nʼotu nsọtụ nke ala ahụ ruo nsọtụ nke ọzọ),  
\v 8 ekwenyekwala maọbụ ṅaa ntị nʼihe ọ na-ekwu. Enwekwala obi ebere nʼebe ọ nọ, ekpuchikwala atụmatụ ọjọọ ya niile.  
\v 9 Ị ghaghị igbu ha. Buru ụzọ setịpụ aka gị tụọ ya nkume, ka ndị ọzọ soro gị tugbuo ya.  
\v 10 Jiri nkume tugbuo ya, nʼihi na ọ chọrọ ime ka i site nʼiso \nd Onyenwe anyị\nd* Chineke, wezuga onwe gị, ka ị pụọ, ma chigharịa site nʼiso ya, bụ \nd Onyenwe anyị\nd*, onye mere ka i site nʼala Ijipt pụta, ala ebe ị nọ nʼime ya dịka ohu.  
\v 11 Izrel niile ga-anụkwa banyere ihe ọjọọ o mere, ha ga-atụkwa ihe ọjọọ dị otu a egwu, ọ dịkwaghị onye ọbụla nʼetiti gị ga-achọkwa ime ihe ọjọọ dị otu ahụ. 
\p  
\v 12 Mgbe i bi nʼobodo ndị ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị, ọ bụrụ na akụkọ esite nʼotu obodo ndị a ruo gị ntị sị,  
\v 13 na ụfọdụ ndị mmadụ jọgburu onwe ha eduhiela ndị obodo ha, na-asị, “Ka anyị gaa fee chi ndị ọzọ ofufe” (bụ chi ndị ị na-amaghị na mbụ),  
\v 14 tupu i mee ihe ọbụla, ị ga-eburu ụzọ jụọ ase, jụpụta nke ọma, ma nyochapụta ma okwu ahụ ọ bụ eziokwu. Ọ bụrụ na ọ bụ eziokwu na-achọpụtakwara nʼihe arụ dị otu a mere nʼetiti unu,  
\v 15 ị ghaghị ibuso obodo ahụ agha jiri mma agha gbuo ndị mmadụ niile bi nʼime obodo ahụ. Ị ghaghị ibibi ya kpamkpam, ma ndị mmadụ ma anụ ụlọ ha.  
\v 16 Ihe nkwata niile i si nʼobodo ahụ kwata ka ị ga-ekpokọta nʼotu ebe, nʼama dị nʼetiti obodo ahụ. A ga-akpọkwa ha niile ọkụ, gbaakwa obodo ahụ niile ọkụ, dịka aja nsure ọkụ nye \nd Onyenwe anyị\nd* bụ Chineke unu. Ruo mgbe ebighị ebi, obodo ahụ ga-abụ mkpọmkpọ ebe, a gaghị ewugharịkwa ya ọzọ.  
\v 17 Ọ dịghị ihe ndị ahụ e debere nye mbibi nke e kwesiri ịhụ nʼaka gị. Nke a ga-emekwa ka iwe ọkụ \nd Onyenwe anyị\nd* dajụọ, ka o gosikwa gị obi ebere. Ọ ga-enwekwa ọmịiko nʼahụ gị, meekwa ka ị baa ụba nʼọnụọgụgụ, dịka o ji ịṅụ iyi kwee nna nna gị ha na nkwa.  
\v 18 \nd Onyenwe anyị\nd* Chineke gị ga-eme ihe ndị a ma ọ bụrụ na ị na-erubere ya isi, na-edebezukwa iwu ya niile, nke m na-enye gị taa, ma na-eme ihe ziri ezi nʼanya \nd Onyenwe anyị\nd* Chineke gị. 
\c 14  
\s1 Nri kwesiri oriri na ndị na-ekwesighị 
\p  
\v 1 Unu onwe unu bụ ụmụ \nd Onyenwe anyị\nd* Chineke unu, ya mere unu egbula onwe unu mma, maọbụ kpụchapụ agịrị isi dị nso nso egedege ihu unu nʼihi onye nwụrụ anwụ.\f + \fr 14:1 \ft Ihe ndị a bụ usoro mmemme iru ụjụ nke ndị na-eme omenaala. \xt Lev 19:27-28\f* 
\v 2 Nʼihi na onye dị nsọ ka ị bụ nye \nd Onyenwe anyị\nd* Chineke gị. Ọ bụkwa gị ka \nd Onyenwe anyị\nd* họọrọ site na ndị niile nọ nʼelu ụwa, ị bụ ihe oke ọnụahịa nye ya. 
\p  
\v 3 Erila ihe ọbụla m kwuru na ọ bụ ihe rụrụ arụ.  
\v 4 Ndị a bụ anụmanụ unu ga-eri: ehi, atụrụ, na ewu,  
\v 5 na ele nta, na mgbada, na atụrụ ọhịa, na ewu ọhịa, ele ukwu, na anịgọ bi nʼelu ugwu.  
\v 6 Anụmanụ ọbụla ụkwụ ya wara njakpa, nke na-atagharị ọnụ ka unu ga-eri.  
\v 7 Ma otu ọ dị, nʼetiti anụ ndị ahụ na-atagharị nri maọbụ ndị ụkwụ ha wara njakpa, ndị a ka unu na-agaghị eri, ịnyịnya kamel, na ewi maọbụ ewi nkume, na anụ ndị ọzọ yiri ha, ọ bụ ezie na ha na-atagharị ọnụ, ma ha enweghị ụkwụ wara njakpa. Ha bụ ihe na-adịghị ọcha nye unu.  
\v 8 Ezi bụkwa anụ na-adịghị ọcha; ọ bụ ezie na o nwere ụkwụ wara njakpa, ma ọ dịghị atagharị nri. Unu agaghị emetụla ozu ha aka maọbụ rie anụ ha. 
\p  
\v 9 Nʼime ihe niile e kere eke, dị ndụ, biri na mmiri, unu nwere ike iri nke ọbụla nwere ntu na akpịrịkpa,  
\v 10 ma ihe ọbụla nke na-enweghị ntu na akpịrịkpa, unu erila ha, nʼihi na ha rụrụ arụ. 
\p  
\v 11 Unu ga-eri nnụnụ ọbụla dị ọcha,  
\v 12 ma unu agaghị eri ndị a: ugo, na udele, na udele ojii,  
\v 13 na ndagbụ, na ọgankwọ, na ndagbụ dị iche iche,  
\v 14 na ugolọma ọbụla dị iche iche,  
\v 15 na enyi nnụnụ, na egbe abalị, na nnụnụ oke osimiri, na egbe dị iche iche,  
\v 16 na okwukwu nta, na okwukwu ukwu, na okwukwu nwere mpi,  
\v 17 na okwolo na udele, na komorant,  
\v 18 na ụgbala, na utù dị iche iche, na nnụnụ ọdụ nta, na ụsụ. 
\p  
\v 19 Ụmụ ahụhụ niile na-efe efe rụrụ arụ nye unu, unu erila ha,  
\v 20 Ma unu nwere ike iri ụmụ ahụhụ ndị ahụ nwere nku, ndị dị ọcha. 
\p  
\v 21 Unu erila anụ ọbụla nwụrụ anwụ. Ma otu o si dị, onye ọbịa nʼetiti unu nwere ike rie ya. I nwere ike inye ya, maọbụ resi ya onye ahụ, ma erila ya, nʼihi na onye dị nsọ nye \nd Onyenwe anyị\nd* Chineke gị ka ị bụ. 
\p Esila nwa ewu maọbụ nwa atụrụ nʼime mmiri ara nne ya. 
\s1 Onyinye otu ụzọ nʼụzọ iri 
\p  
\v 22 Ị ghaghị inye otu ụzọ nʼụzọ iri nke mkpụrụ ubi gị afọ niile.  
\v 23 Ị ga-erikwa mkpụrụ ndị a nʼihu \nd Onyenwe anyị\nd*, bụ Chineke gị, nʼebe ahụ ọ ga-ahọpụta ka ọ bụrụ ebe obibi ya, ị ga-anọ nʼebe ahụ rie otu ụzọ nʼụzọ iri nke ọka gị, na mmanya vaịnị ọhụrụ gị, na mmanụ oliv gị, na nwa mbụ nke igwe ehi gị, na igwe ewu na atụrụ gị. Ihe e ji eme nke a bụ ka ị mụta ịtụ egwu \nd Onyenwe anyị\nd* Chineke gị ụbọchị ndụ gị niile.  
\v 24 Ọ bụrụ na ebe \nd Onyenwe anyị\nd* họpụtara dị anya, ọ bụrụkwa na \nd Onyenwe anyị\nd* Chineke gị agọziela gị ruo na ị pụghị ibu otu ụzọ nʼụzọ iri gị gaa nʼebe ahụ (nʼihi na ebe ahụ \nd Onyenwe anyị\nd* họpụtara dị anya),  
\v 25 mgbe ahụ, gbanwee otu ụzọ nʼụzọ iri nata ọlaọcha, were ọlaọcha ahụ jee nʼebe ahụ \nd Onyenwe anyị\nd* Chineke gị họpụtara.  
\v 26 Were ọlaọcha ahụ zụọ ihe ọbụla ị chọrọ: ehi, na atụrụ, na mmanya, maọbụ mmanya siri ike na-aba nʼanya maọbụ ihe ọbụla ọzọ nke ị chọrọ. Mgbe ahụ, gị na ezinaụlọ gị ga-eri nri nʼihu \nd Onyenwe anyị\nd* Chineke gị, ṅụrịakwa ọṅụ.  
\v 27 Echefukwala ime ka ndị Livayị soro gị rie ihe ị kpatara, nʼihi na ha enweghị ihe nketa ọbụla, maọbụ ihe ubi dịka gị. 
\p  
\v 28 Nʼọgwụgwụ afọ atọ ọbụla, ị ga-eweta otu ụzọ nʼụzọ iri nke ihe ubi gị, chịkọta ha nʼebe a ga-echebe ha nʼobodo gị,  
\v 29 ka ndị Livayị, ndị na-enweghị ihe nketa nʼetiti gị, na ndị ọbịa, na ndị inyom di ha nwụrụ anwụ, na ụmụ mgbei niile nọ nʼobodo gị, bịa nʼebe ahụ were nri ha ga-eri, rijuokwa afọ. Nʼụzọ dị otu a, \nd Onyenwe anyị\nd* Chineke gị ga-agọzi gị, gọziekwa ọrụ aka gị niile. 
\c 15  
\s1 Afọ inwere onwe 
\p  
\v 1 Nʼọgwụgwụ afọ asaa ọbụla, ị ga-akagbu ụgwọ niile mmadụ ji gị.  
\v 2 Otu a ka a ga-esi mee ya: Onye ọbụla e ji ụgwọ ga-akagbu ụgwọ niile onye Izrel ibe ya ji ya. Ọ gaghị elekwa anya na onye agbataobi ya maọbụ nwanna ya ga-akwụ ya ụgwọ ahụ, nʼihi na oge a na-ekwusa mgbaghara ụgwọ \nd Onyenwe anyị\nd* eruola.  
\v 3 Mgbaghara a erughị nʼebe ndị ọbịa nọ,\f + \fr 15:3 \ft Ndị ọbịa kwesiri ịkwụ ụgwọ a, nʼihi na ha adịghị eso ụmụ Izrel na-ahapụ ala ha ka o zuo ike nye Onyenwe anyị, mgbe afọ asaa ruru. Ya mere, ha nwere ego ịkwụ ụgwọ ha ji. \xt Lev 25:1-7\f* ma ị ghaghị ịkagbu ụgwọ ọbụla nwanna gị ji gị.  
\v 4 Otu ọ dị, o kwesighị ka ndị ogbenye dịrị nʼetiti gị, nʼihi nʼala ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị ka inweta dịka ihe nketa gị, ọ ga-agọzi gị nke ukwuu,  
\v 5 ma ọ bụrụ na i rube isi nye \nd Onyenwe anyị\nd* Chineke gị, ma lezie anya debe iwu ndị a niile m na-enye gị taa.  
\v 6 \nd Onyenwe anyị\nd* Chineke gị ga-agọzi gị dịka o kwere na nkwa. Ị ga-agbazinye ọtụtụ mba ego, ị gaghị anọ nʼụkọ! Ị ga-achị ọtụtụ mba, ma ha agaghị achị gị. 
\p  
\v 7 Ma mgbe ị banyere nʼala ahụ \nd Onyenwe anyị\nd* Chineke unu na-enye gị, a sị na e nwee onye ogbenye nʼetiti gị, nke bụ onye Izrel ibe gị, ị gaghị emechi obi gị maọbụ kechie aka gị megide ya,  
\v 8 ị ghaghị ịgbazinye ya ihe dị ka o si chọọ.  
\v 9 Lezie anya ka ị ghara inwe ụdị echiche ọjọọ a nʼobi gị sị, “Afọ mgbaghara ụgwọ na-abịa nso,” nʼihi ya, i kechie obi gị jụ ibinye nwanna gị nọ na mkpa ihe ọ chọrọ. Ọ bụrụ na onye ahụ nọ na mkpa akwaa akwa kpọkuo \nd Onyenwe anyị\nd*, a ga-agụ gị dịka onye ikpe mmehie mara.  
\v 10 Ị ghaghị inye ha site nʼafọ ofufu, meekwa nke a na-enweghị obi ilu, mgbe ahụ, nʼihi nke a, \nd Onyenwe anyị\nd* bụ Chineke gị ga-agọzi gị nʼọrụ gị niile nakwa ihe niile nke ị tinyere aka na ya.  
\v 11 A ghaghị inwe ndị ogbenye nʼetiti unu, ọ bụ ya mere iwu a jiri dị mkpa. Gbasapụ aka nʼebe nwanna gị na nʼebe ndị ogbenye na ndị nọ na mkpa nọ. 
\s1 Mmeso a na-emeso ndị ohu 
\p  
\v 12 Ọ bụrụ na onye Hibru ibe gị, ndị nwoke maọbụ ndị nwanyị, eresi gị onwe ha, gbakwaara gị odibo afọ isii, nʼafọ nke asaa, ị ghaghị ịhapụ ha ka ha nwere onwe ha.  
\v 13 Mgbe ọ hapụrụ ụlọ gị, ezipụkwala ya nʼaka efu!  
\v 14 Ị ga-esite nʼigwe anụ ụlọ gị, na nʼebe ịzọcha ọka gị, na nʼebe ịzọcha vaịnị gị, nye ya onyinye pụrụ iche iji sị ya laa nʼudo. Nye ya onyinye a dịka \nd Onyenwe anyị\nd* Chineke gị si gọzie gị.  
\v 15 Cheta na ị bụrị ohu nʼala Ijipt ma \nd Onyenwe anyị\nd* bụ Chineke gị gbapụtara gị. Ọ bụ nʼihi ya ka m ji na-enye gị iwu a taa. 
\p  
\v 16 Ma ọ bụrụ na ohu gị asị gị, “Achọghị m ịhapụ gị,” nʼihi na ọ hụrụ gị na ndị ụlọ gị nʼanya, hụkwa na ihe na-agara gị na ya nke ọma, mgbe gị na ya nọ.  
\v 17 Were agịga kpọpuo ntị\f + \fr 15:17 \ft Ịkpọpu ntị bụ akara e ji amara onye bụ ohu na mgbe ochie.\f* ya nʼọnụ ụzọ ụlọ gị. Ọ ga-abụkwara gị ohu ogologo ndụ ya niile. Otu aka ahụ kwa ka ị ga-eme ohu gị nwanyị. 
\p  
\v 18 Enwela obi mwute mgbe ọbụla ị na-ahapụ ohu gị ka o nwere onwe ya, nʼihi na ị ga-echeta na ọ rụụrụ gị ọrụ afọ isii, ihe i mefukwara erughị ọkara ihe ị gaara eji goo ndị ọrụ. \nd Onyenwe anyị\nd* Chineke gị ga-agọzikwa gị nʼihe niile ị na-eme. 
\s1 Anụ ụlọ e bụ ụzọ mụọ 
\p  
\v 19 Nwa oke ehi ọbụla maọbụ nwa atụrụ ọbụla maọbụ nwa ewu ọbụla e bụ ụzọ mụọ nʼime igwe anụ ụlọ gị ka ị ga-edo nsọ nye \nd Onyenwe anyị\nd* Chineke gị, ejila nwa mbụ nke ehi gị e buru ụzọ mụọ arụ ọrụ ubi, akpachakwala ajị nwa ewu maọbụ nwa atụrụ ọbụla e buru ụzọ mụọ dị nʼime igwe ewu na atụrụ gị.  
\v 20 Gị na ezinaụlọ gị ga-eri anụ ndị a nʼihu \nd Onyenwe anyị\nd* Chineke gị afọ ọbụla nʼebe ọ họpụtara.  
\v 21 Ma ọ bụrụ na nwa anụ ọbụla e buru ụzọ mụọ nwere nkwarụ, dịka ngwụrọ maọbụ ìsì maọbụ nkwarụ ọbụla nke jọrọ njọ, ị gaghị eji ya achụ aja nye \nd Onyenwe anyị\nd* Chineke gị.  
\v 22 Kama, ka ọ bụrụ ihe oriri nye ezinaụlọ gị nʼime ụlọ gị. Onye ọbụla, ma ndị dị ọcha ma onye rụrụ arụ nʼoge ahụ ga-eri ya, dịka onye ọbụla pụrụ iri anụ ele maọbụ anụ mgbada.  
\v 23 Ma erila ọbara ya. Wụsa ya nʼala dịka mmiri. 
\c 16  
\s1 Mmemme Ngabiga 
\p  
\v 1 Debe ọnwa Abib\f + \fr 16:1 \ft Nke a bụ nʼetiti ọnwa atọ na ọnwa anọ nʼafọ, dịka anyị si agụ afọ nke anyị.\f* iche maka ime Mmemme Ngabiga \nd Onyenwe anyị\nd* Chineke gị, nʼihi na ọ bụ nʼọnwa Abib ka \nd Onyenwe anyị\nd* Chineke gị mere ka i si nʼala Ijipt pụta nʼabalị.  
\v 2 Ị ga-eji anụ si nʼigwe atụrụ na ehi gị chụọrọ \nd Onyenwe anyị\nd* Chineke gị aja ngabiga nʼebe ahụ \nd Onyenwe anyị\nd* ga-ahọpụta dịka ebe obibi nye aha ya.  
\v 3 Erila ya na achịcha e ji ihe na-eko achịcha mee, kama ụbọchị asaa ka ị ga-eri achịcha na-ekoghị eko, ya bụ, achịcha ahụhụ, iji cheta na i si nʼala Ijipt pụta ngwangwa. Nke a ga-eme ka i nwee ike na-echeta mgbe i sitere nʼala Ijipt pụta, ụbọchị niile nke ndụ.  
\v 4 Ka ihe ọbụla na-eko achịcha ghara ịbata nʼezinaụlọ gị abalị asaa ndị ahụ. Unu ahapụkwala anụ ọbụla unu chụrụ nʼaja nʼoge uhuruchi nke ụbọchị mbụ, nọọ ruo ụtụtụ. 
\p  
\v 5 Ị gaghị achụ aja ngabiga nʼobodo ọbụla \nd Onyenwe anyị\nd* Chineke gị nyere gị,  
\v 6 karịakwa nʼebe ahụ \nd Onyenwe anyị\nd* Chineke gị họpụtara dịka ebe obibi nye ya ka i ga-anọ chụọ ya. Nʼebe ahụ ka ị ga-achụ aja ngabiga gị nʼoge uhuruchi, mgbe anwụ dachara, nʼoge mgbe dịka oge ụbọchị ahụ i sitere nʼIjipt pụta.  
\v 7 Ị ga-ahụ ya nʼọkụ riekwa ya nʼebe ahụ \nd Onyenwe anyị\nd* bụ Chineke ga-ahọpụta. Nʼụtụtụ, ị ga-alaghachikwa nʼụlọ ikwu gị.  
\v 8 Ụbọchị isii ka ị ga-eri achịcha na-ekoghị eko, nʼụbọchị nke asaa, nweenụ mkpọkọta nye \nd Onyenwe anyị\nd* Chineke gị, arụkwala ọrụ ọbụla. 
\s1 Mmemme owuwe ihe ubi 
\p  
\v 9 Gụpụta izu asaa site na mgbe ị malitere itinye mma iwe ihe ubi nʼukwu ọka guzoro eguzo nʼubi gị.  
\v 10 Meenụ Mmemme Izu Ụka asaa nye \nd Onyenwe anyị\nd*, bụ Chineke gị, site na inye onyinye afọ ofufu, nʼusoro ọtụtụ ngọzị \nd Onyenwe anyị\nd* bụ Chineke gị ji gọzie gị.  
\v 11 Ọ bụ oge ịṅụrị ọṅụ nye gị na ụmụ gị ndị ikom na ndị inyom, ndị ohu gị nwoke na nwanyị, ndị Livayị bi nʼobodo gị, ndị ọbịa, ndị na-enweghị nna na ndị inyom di ha nwụrụ bi nʼetiti gị. Meenụ nke a nʼihu \nd Onyenwe anyị\nd* Chineke gị, nʼebe ahụ ọ họpụtara dịka ebe obibi nye aha ya.  
\v 12 Cheta na ị bụrị ohu nʼala Ijipt, nʼihi nke a, unu echefula iwu ndị a. 
\s1 Mmemme ụlọ ikwu 
\p  
\v 13 Mmenụ mmemme ụlọ Ikwu. Unu aghaghị ime ya ụbọchị asaa mgbe unu wechara ihe ubi, ya bụ, mgbe unu chịkọtachara ọka site nʼebe ịzọcha ọka, nakwa ebe ịzọcha mmanya unu niile  
\v 14 Ọ bụ oge ịṅụrị ọṅụ, nye gị onwe gị, ụmụ ndị ikom na ndị inyom gị, ndị odibo nwoke na nwanyị unu niile, ndị Livayị, ndị ọbịa, ụmụ mgbei na ụmụ nwanyị niile di ha nwụrụ anwụ ndị bi nʼobodo gị niile.  
\v 15 A ga-eme mmemme a nye \nd Onyenwe anyị\nd* Chineke gị ụbọchị asaa nʼebe ahụ \nd Onyenwe anyị\nd* nʼonwe ya họpụtara. Nʼihi na \nd Onyenwe anyị\nd* Chineke gị ga-agọzi ihe ubi gị niile, gọziekwa akaọrụ gị niile, ime ka ọṅụ gị zuo oke. 
\p  
\v 16 Ugboro atọ nʼafọ ka ndị ikom unu niile aghaghị ịbịa chee onwe ha nʼihu Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* unu, nʼebe ọ ga-ahọpụta: nʼoge mmemme ndị a: Mmemme Achịcha na-ekoghị eko, Mmemme Izu Ụka asaa na Mmemme Ụlọ Ikwu. Ọ dịghị onye ọbụla ga-agba aka efu bịa nʼihu \nd Onyenwe anyị\nd*.  
\v 17 Onye ọbụla ga-eweta onyinye dịka o nwere ike na dịka \nd Onyenwe anyị\nd* Chineke gị sị gọzie ya. 
\s1 Ndị ikpe 
\p  
\v 18 Ị ga-ahọpụta ndị ikpe, na ndịisi ozi nʼebo niile, na nʼobodo ọbụla \nd Onyenwe anyị\nd* Chineke gị na-enye gị. Ha ga-eme ka ezi ikpe dịrị ndị mmadụ niile.  
\v 19 Ekpekwala ikpe aghụghọ, maọbụ kpee ikpe ile mmadụ anya nʼihu. Erikwala ngarị, nʼihi na iri ngarị na-eme ka anya onye amamihe kpuo ìsì, meekwa ka okwu onye aka ya dị ọcha gbagọọ agbagọ.  
\v 20 Gbasoo ikpe ziri ezi, mee ka ikpe ziri ezi dịgide, ka ị dịrị ndụ, nweta ala ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị. 
\s1 Ikpere arụsị\f + \fr 16:21 \ft Ikpere chi ndị ọzọ\f* 
\p  
\v 21 Amanyela oyiyi osisi chi Ashera ọbụla gị nʼakụkụ ebe ịchụ aja ị wuru nye \nd Onyenwe anyị\nd* Chineke gị.  
\v 22 Eguzokwala ogidi nkume ọbụla nʼihi na ha bụ ihe \nd Onyenwe anyị\nd* Chineke gị kpọrọ asị. 
\c 17  
\p  
\v 1 Achụrụla \nd Onyenwe anyị\nd* bụ Chineke gị ehi maọbụ atụrụ nwere nkwarụ ọbụla maọbụ ntụpọ. Onyinye dị otu a bụ ihe arụ nʼebe ọ nọ. 
\p  
\v 2 Ọ bụrụ na ị nụ na onye ọbụla nʼime obodo ndị ahụ \nd Onyenwe anyị\nd* nyere gị, nwoke maọbụ nwanyị na-eme ihe dị njọ nʼanya \nd Onyenwe anyị\nd* Chineke gị ime ihe megidere ọgbụgba ndụ ya,  
\v 3 ọ bụrụ na onye ahụ efee chi ndị ọzọ, maọbụ kpọọ isiala nye ha, maọbụ fee anwụ, maọbụ ọnwa, maọbụ kpakpando nke mbara eluigwe bụ ihe m na-enyeghị nʼiwu,  
\v 4 ọ bụrụ na e mere ka ị maara nʼihe dị otu a dị maọbụ ị nụ ya, ị ghaghị ịjụ ase, nyochaa ya nke ọma. Ọ bụrụ na ihe ị nụrụ bụ eziokwu, ọ bụrụ nʼezie na e mere ihe arụ dị otu a nʼala Izrel,  
\v 5 kpọrọ nwoke maọbụ nwanyị ahụ mere ihe ọjọọ dị otu a, kpọpụta ya nʼọnụ ụzọ ama obodo, tụọ ya nkume, tugbuo ya.  
\v 6 Ma otu o si dị, a gaghị eme ka onye ahụ nwụọ site naanị nʼama otu mmadụ, kama ọ ga-anwụ site nʼama mmadụ abụọ maọbụ atọ gbara.  
\v 7 Ndị ahụ gbara akaebe nʼisi ya ga-eburu ụzọ tụọ ya nkume, tupu mmadụ niile esoro tugbuo ya. Site nʼụzọ dị otu a, unu ga-ekpochapụ ihe ọjọọ site nʼetiti gị. 
\s1 Ụlọ ikpe 
\p  
\v 8 Ọ bụrụ na unu enwee okwu siri ike na mkpebi, dịka igbu ọchụ, maọbụ okwu na ụka metụtara mmadụ, maọbụ ịlụ ọgụ nke mmerụ ahụ dapụtara nʼime ya, ihe unu ga-eme bụ iweta ikpe ahụ nʼebe obibi \nd Onyenwe anyị\nd* Chineke gị họpụtara,  
\v 9 nʼihu ndị nchụaja, bụ ndị Livayị na onye nọ nʼoche ikpe nʼoge ahụ ka ha gbubie ikpe ahụ.  
\v 10 Ị ga-emekwa dịka mkpebi ha nyere gị nʼebe ahụ \nd Onyenwe anyị\nd* ga-ahọpụta. Lezie anya hụ na i mezuru ihe niile dịka ha si tụziere gị aka.  
\v 11 Mee dịka iwu ha ziri gị si dị, na dịka mkpebi ha nyere gị si dị. Ewezugala onwe gị site nʼokwu ha nyere gị nʼụzọ ọbụla  
\v 12 Ma onye ahụ ledara onye nchụaja na onye ikpe ahụ a họpụtara ije ozi nye \nd Onyenwe anyị\nd* Chineke gị ga-anwụ. Unu ga-esi nʼala Izrel wezuga ihe ọjọọ dị otu ahụ.  
\v 13 Nʼụzọ dị otu a, mmadụ niile ga-anụ ihe mere onye ahụ nupuru isi, ha ga-atụ egwu ghara ịbụ ndị mpako. 
\s1 Inwe eze 
\p  
\v 14 Mgbe ị banyere nʼala ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị, merie ndị bi nʼime ya, biri nʼime ya, i nwere ike malite iche nʼobi gị sị, “Anyị kwesiri inwe eze dịka mba ndị ọzọ niile dị anyị gburugburu.”  
\v 15 O si otu a dịrị, lezie anya hụ na onye ị ga-eme eze bụ onye ahụ \nd Onyenwe anyị\nd* Chineke gị ga-ahọpụta. Onye ahụ aghaghị ịbụ onye Izrel nʼihi na i kwesighị ime onye mba ọzọ eze ka ọ chịa gị.  
\v 16 Hụ na eze ahụ ị họpụtara enweghị ọtụtụ ịnyịnya. Eze ahụ ekwesịkwaghị izipụ ndị ga-aga Ijipt ịzụpụtara ya ọtụtụ ịnyịnya ọzọ, nʼihi na \nd Onyenwe anyị\nd* agwala gị sị, “Ị gaghị alaghachi Ijipt ọzọ.”  
\v 17 Eze ahụ agaghị enwe ọtụtụ nwunye, nʼihi na nke a ga-eme ka obi ya si nʼebe \nd Onyenwe anyị\nd* nọ pụọ. Ọ gakwaghị ababiga ụba ọlaọcha na ọlaedo oke. 
\p  
\v 18 Mgbe ọ nọkwasịrị nʼocheeze dịka eze, ọ ga-esite nʼakwụkwọ iwu a ndị nchụaja bụ ndị Livayị na-edebe, depụtara onwe ya iwu a metụtara obibi ndụ ndị eze.  
\v 19 Ihe ahụ o depụtara ka ọ ga-agụ mgbe niile na ndụ ya. Nke a ga-eme ka ọ mụta ịtụ egwu \nd Onyenwe anyị\nd* Chineke ya, na ịgbaso ihe niile dị nʼiwu na ụkpụrụ ndị a.  
\v 20 Ịgụ akwụkwọ iwu a mgbe niile ga-eme ka ọ mata na o nweghị ụzọ o si dị elu karịa ụmụnna ya. Ọ ga-emekwa ka ọ ghara iwezuga onwe ya site nʼiwu a nʼụzọ ọbụla. Mgbe ahụ, ya onwe ya, na ụmụ ụmụ ya ga-achị alaeze Izrel ogologo oge. 
\c 18  
\s1 Ihe nketa ndị nchụaja na ndị Livayị 
\p  
\v 1 Ndị nchụaja bụ ndị Livayị, na ndị ebo Livayị niile agaghị enwe oke maọbụ ihe nketa ọbụla dịka ebo ndị ọzọ nʼIzrel. Ihe onyinye ịchụ aja niile e wetara nʼihu \nd Onyenwe anyị\nd* site nʼọkụ bụ ihe nketa ha.  
\v 2 Ha agaghị enwe ihe nketa ọbụla nʼetiti ụmụ Izrel ndị ọzọ, nʼihi na \nd Onyenwe anyị\nd* abụrụla ihe nketa nke ha dịka o kwere ha na nkwa. 
\p  
\v 3 Nke ga-abụ oke ruuru ndị nchụaja nʼebe ndị mmadụ nọ, nʼebe ndị na-achụ aja, site nʼanụ ehi maọbụ atụrụ: a ga-enye onye nchụaja ubu aka ya, agba ya abụọ na afọ ya.  
\v 4 Ha ga-enwetakwa mkpụrụ mbụ nke owuwe ihe ubi unu, ya bụ, ọka mbụ unu, mmanya vaịnị ọhụrụ unu, mmanụ oliv unu na ajị mbụ a kpụchapụtara site nʼahụ igwe atụrụ unu.  
\v 5 Nʼihi na \nd Onyenwe anyị\nd* Chineke unu ahọpụtala ebo Livayị na ụmụ ụmụ ha site nʼebo niile nke Izrel ka ha bụrụ ndị ga-eguzo jee ozi nʼihu \nd Onyenwe anyị\nd* oge niile. 
\p  
\v 6 Onye Livayị ọbụla si nʼebe o bi kwapụ gaa biri nʼobodo ọzọ nʼIzrel nwere ike ije nʼebe ịchụ aja \nd Onyenwe anyị\nd* họpụtara,  
\v 7 ọ ga-eje ozi nʼaha \nd Onyenwe anyị\nd* bụ Chineke ya dịka ụmụnna ya ndị Livayị na-eje ozi nʼihu \nd Onyenwe anyị\nd*.  
\v 8 Ọ ga-esokwa keta oke a na-ekenye ndị Livayị bi nʼobodo ahụ, nʼagbanyeghị na ọ na-enweta ego site nʼorire e rere ihe onwunwe ezinaụlọ ya. 
\s1 Ikpere arụsị 
\p  
\v 9 Mgbe ị banyere nʼala ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị, amụtakwala ime omume arụ dịka ndị mba bi nʼala ahụ.  
\v 10 Ka a hapụ ịchọta onye ọbụla nʼetiti gị nke na-ewere nwa ya nwoke maọbụ nwanyị nye ka a kpọọ ya ọkụ nʼihi ịchụrụ chi ndị mba ọzọ aja. Ka onye Izrel ọbụla ghara ịbụ onye na-ajụ mmụọ ase maọbụ onye mgbaasị maọbụ na-agba aja,  
\v 11 maọbụ onye na-akụ mmadụ ibe ya ọgwụ, maọbụ onye na-ajụ mmụọ ọjọọ ase, maọbụ dibịa afa maọbụ onye na-ajụ ase site nʼaka ndị nwụrụ anwụ.  
\v 12 Onye ọbụla na-eme ihe ndị a bụ onye \nd Onyenwe anyị\nd* kpọrọ asị. Ọ bụkwa nʼihi ihe arụ ndị a ka \nd Onyenwe anyị\nd* Chineke gị ji na-achụpụ ndị bi nʼala a.  
\v 13 Ị ghaghị ịbụ onye zuruoke nʼụzọ niile nʼihu \nd Onyenwe anyị\nd* Chineke gị. 
\s1 Onye amụma nke ga-abịa 
\p  
\v 14 Mba ndị ị na-aga inweta ala ha bụ ndị na-ajụ ase site nʼaka ndị mgbaasị na ndị na-agba aja, ma \nd Onyenwe anyị\nd* Chineke gị anabataghị na ị ga-eme ihe dị otu ahụ.  
\v 15 Kama \nd Onyenwe anyị\nd* Chineke gị ga-eme ka onye amụma nke dị ka m biliere unu site nʼetiti unu, site nʼetiti ndị unu bụ Izrel. Ọ bụ ya ka unu ga-aṅa ntị.  
\v 16 Nʼihi na nke a bụ ihe gị onwe gị rịọrọ \nd Onyenwe anyị\nd* bụ Chineke gị nʼugwu Horeb, nʼụbọchị mkpokọta ahụ. I kwuru sị, “Anyị achọghị ịnụ olu \nd Onyenwe anyị\nd* maọbụ hụ ọkụ ahụ dị egwu anya ọzọ, ka anyị ghara ịnwụ.” 
\p  
\v 17 Nʼihi ya, \nd Onyenwe anyị\nd* gwara m okwu sị m, “Ihe ha kwuru dị mma.  
\v 18 Aga m eme ka onye amụma bilie nʼetiti ha, onye Izrel dịka gị. Aga m agwa ya ihe ọ ga-ekwu, okwu niile m tinyere nʼọnụ ya ka ọ ga-agwa ha.  
\v 19 Onye ọbụla jụrụ ige ntị nʼokwu m niile nke onye amụma ga-agwa ha nʼaha m ka mụ onwe m ga-emesi ike.  
\v 20 Ma onye amụma ọbụla sitere na nganga obi ya kwuo okwu nʼaha m, bụ okwu nke m na-ezighị ya ka o kwuo, ga-anwụ, maọbụ onye amụma ọbụla nke kwuru okwu nʼaha chi ndị ọzọ, onye amụma ahụ ga-anwụkwa.” 
\p  
\v 21 I nwere ike ikwu nʼobi gị sị, “Olee otu anyị ga-esi mata na okwu e kwuru si nʼaka \nd Onyenwe anyị\nd* nʼezie?”  
\v 22 Otu a ka unu ga-esi mata, ọ bụrụ na ihe onye amụma buru nʼamụma nʼaha \nd Onyenwe anyị\nd* emezughị, okwu ahụ esighị nʼebe \nd Onyenwe anyị\nd* nọ bịa. Ọ bụ okwu onye amụma ahụ chepụtara kwuo nʼonwe ya. Unu atụla ya ụjọ. 
\c 19  
\s1 Obodo mgbaba 
\p  
\v 1 Mgbe \nd Onyenwe anyị\nd* Chineke gị bibiri mba ndị ahụ nwe ala ahụ ọ na-enye gị, mgbe ị chụpụrụ ha bichie nʼobodo ha nakwa ụlọ ha niile,  
\v 2 mgbe ahụ, kewapụta\f + \fr 19:2 \fk Obodo atọ \ft Ndị a bụ obodo atọ ọzọ tinyere ndị mbụ e kewapụtarala nʼọwụwa anyanwụ Jọdan nʼihi ize ndụ. Ndị a ga-adị nʼebe ọdịda anyanwụ nke Jọdan.\f* obodo atọ nʼala ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị inweta, doo ha iche.  
\v 3 Kewaa ala ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị dịka ihe nketa ụzọ atọ ka otu obodo mgbaba dịrị nʼotu akụkụ. Wuzie ụzọ e si aga nʼobodo ndị a ka ọ dịrị onye na-agba ọsọ mfe ịgbaje nʼebe ahụ. 
\p  
\v 4 Nke a bụ iwu banyere onye ọbụla gburu mmadụ gbaba nʼebe ahụ maka izere ndụ. Ọ bụrụ na mmadụ esite na-amaghị ama gbuo onye agbataobi ya, bụ onye ọ na-akpọghị asị nʼoge gara aga, ọ ga-agbaba nʼobodo ahụ nʼihi ize ndụ ya.  
\v 5 Ọ bụrụ na mmadụ na ibe ya agaa nʼọhịa ịwa nkụ ma isi anyụike ya esite nʼosisi ya dapụ dagbuo nwoke ahụ so ya gaa ịwa nkụ, nwoke ahụ na-awa nkụ ga-agbala nʼime otu obodo ndị a ichebe ndụ ya.  
\v 6 Ma ọ bụghị otu a, onye ahụ na-agba ụgwọ ọchụ ga-esite nʼọnụma juru ya obi chụọ nwoke ahụ ọsọ, chụkwute ya, gbuo ya ma ọ bụrụ na obodo mgbaba ahụ adịrị nʼebe dị anya, ọ bụ ezie na nwoke ahụ abụghị onye kwesiri ọnwụ, ebe ọ bụ na o siteghị nʼekworo gbuo onye o gburu.  
\v 7 Ọ bụ nke a mere m ji nye unu iwu ka unu wepụtara onwe unu obodo mgbaba atọ. 
\p  
\v 8 Ọ bụrụ na \nd Onyenwe anyị\nd* Chineke gị emee ka oke ala gị saa mbara dịka ọ ṅụụrụ nna nna gị ha nʼiyi na ọ ga-eme, ọ bụrụkwa na o nye gị ala niile dịka o kwere na nkwa,  
\v 9 nʼihi na i leziri anya gbasoo iwu ndị a m nyere gị taa ịhụ \nd Onyenwe anyị\nd* Chineke gị nʼanya, na ije ije dịka ụzọ ya si dị, mgbe ahụ, i nwere ike họpụta obodo atọ ọzọ, nke ga-abụ obodo izere ndụ.  
\v 10 Nʼụzọ dị otu a, ị ga-enwe ike gbochie ọnwụ ndị aka ha dị ọcha. Ọbara onye na-adịghị ihe o mere agaghị adịkwa gị nʼisi, nʼala ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị dịka ihe nketa. 
\p  
\v 11 Ma ọ bụrụ na nwoke ọbụla echere onye ọ kpọrọ asị nʼụzọ, gbuo ya, mesịa gbara ọsọ gaa nʼime otu obodo ndị a,  
\v 12 ndị okenye obodo ya ga-ezi ndị mmadụ ka ha gaa kpụta ya site nʼebe ahụ. Ha ga-ewerekwa ya nyefee nʼaka onye ga-abọrọ onye ahụ nwụrụ anwụ ọbọ, ka o gbuo ya.  
\v 13 Emerela ya ebere. Ị ghaghị ikpochapụ site nʼIzrel ikpe ọmụma nke so iwufu ọbara ndị aka ha dị ọcha, ka ihe gaara gị nke ọma. 
\p  
\v 14 Mgbe ị batara nʼala ahụ \nd Onyenwe anyị\nd* Chineke gị na-aga inye gị dịka ihe nketa, ehigharịla oke ala onye agbataobi gị nʼala ahụ enyere gị inweta. 
\s1 Ndị akaebe 
\p  
\v 15 Amala onye ọbụla ikpe mmehie nʼihi ama otu onye gbara. E kwesiri inwe ndị akaebe abụọ, maọbụ atọ tupu a maa mmadụ ikpe. 
\p  
\v 16 Ọ bụrụ na onye ọbụla achọọ imegide onye ọzọ site nʼịgba ama ụgha,  
\v 17 a ga-eduru mmadụ abụọ ahụ bịa nʼihu \nd Onyenwe anyị\nd* na nʼihu ndị nchụaja na ndị ikpe na-arụ ọrụ nʼoge ahụ.  
\v 18 Ndị ikpe ga-enyocha okwu ahụ nke ọma. Ọ bụrụ na a chọpụta na onye akaebe ahụ gbara ama ụgha,  
\v 19 ọ ga-ata ahụhụ ahụ nwoke ahụ ọ gbagidere akaebe gaara ata. Nʼụzọ dị otu a, ị ga-ekpochapụ ndị ọjọọ site nʼetiti gị.  
\v 20 Ndị niile nụrụ ya ga-atụ egwu, ha agaghị emekwa ihe ọjọọ dị otu ahụ ọzọ.  
\v 21 Emekwala ebere ọbụla. Ndụ laara ndụ, anya laara anya, eze laara eze, aka laara aka, ụkwụ laara ụkwụ. 
\c 20  
\s1 Ibu agha 
\p  
\v 1 Mgbe i pụrụ ibuso ndị iro gị agha, ọ bụrụ na i lee anya hụ na ndị iro gị nwere ọtụtụ ịnyịnya, ụgbọ agha na ndị agha dị ukwuu nʼọnụọgụgụ karịa gị, unu atụla egwu, nʼihi na \nd Onyenwe anyị\nd* Chineke gị, onye ahụ mere ka i si nʼala Ijipt pụta nʼudo, nọnyeere gị.  
\v 2 Tupu agha ebido, otu onye nchụaja ga-eguzo nʼihu ndị agha Izrel gwa ha okwu sị,  
\v 3 “Geenụ ntị, unu ndị Izrel, taa, unu na-apụ ibuso ndị iro unu agha. Unu atụla egwu. Unu atụla ụjọ. Ka obi unu gharakwa ịda mba.  
\v 4 Nʼihi na \nd Onyenwe anyị\nd* Chineke unu ga-eso unu gaa, ọ ga-alụrụ unu ọgụ imegide ndị iro unu, ọ ga-enyekwa unu mmeri.” 
\p  
\v 5 Mgbe ahụ, ndị ọchịagha ga-esi otu a gwa ndị agha Izrel okwu sị ha, “O nwere onye ọbụla nʼime unu wuru ụlọ ọhụrụ ọ na-edobeghị nsọ nye \nd Onyenwe anyị\nd*? Ka onye dị otu a laghachi nʼụlọ ya. Ka onye ahụ ghara ịnwụ nʼagha hapụ ụlọ ya, ka nwoke ọzọ doo ya nsọ nye \nd Onyenwe anyị\nd*!  
\v 6 Ọ dị nwoke ọbụla kụrụ ubi vaịnị ọhụrụ nke ọ na-esitebeghị nʼime ya ghọọ mkpụrụ ọbụla? Ya laa, ka ọ ghara ịnwụ nʼagha, hapụrụ ya onye ọzọ nke ga-eri mkpụrụ si na ya!  
\v 7 Ọ dị nwoke nwere nwaagbọghọ o kwere nkwa na ọ ga-alụ? Ya laa, gaa lụọ nwanyị! Nʼihi na ọ bụrụ na ọ nwụọ nʼagha, nwoke ọzọ ga-alụ ya.”  
\v 8 Mgbe ahụ, ndị ọchịagha ahụ ga-ekwukwa sị, “Ọ dị onye egwu na-atụ? Ọ bụrụ na o nwere onye ụjọ na-atụ, ya laghachi nʼụlọ ya ka ịtụ ụjọ ya hapụ ijide ndị ọzọ.”  
\v 9 Mgbe ndịisi agha gwachara ndị agha ha okwu ndị a, ha ga-ahọpụta ndịisi ga-achịkọta usuu ndị agha. 
\p  
\v 10 Mgbe ị bịaruru obodo ọbụla nso ibuso ya agha, ị ga-ebu ụzọ kpọọ ndị bi nʼime ya oku, maka ime udo.  
\v 11 Ọ bụrụ na ha anabata ime udo, megheere gị ọnụ ụzọ ama ha, ndị niile bi nʼime obodo ahụ ga-abụrụ gị ndị ọrụ na-agbakwara gị odibo.  
\v 12 Ma ọ bụrụ na ha ekweghị ime udo, lụso gị agha, mgbe ahụ, ndị agha gị ga-agba ya gburugburu.  
\v 13 Mgbe \nd Onyenwe anyị\nd* Chineke gị nyefere gị ya nʼaka, were mma agha gbuo nwoke ọbụla nọ nʼime ya.  
\v 14 Ma ụmụ nwanyị niile na ụmụntakịrị niile, anụ ụlọ niile na ihe nkwata niile nke ndị obodo ahụ ka ị ga-edebere onwe gị. Ị ga-ewerekwa ihe nkwata nke \nd Onyenwe anyị\nd* Chineke gị nyere site nʼaka ndị iro gị mee ihe dị gị mma.  
\v 15 Iwu ndị a metụtara naanị mmeso ị ga-emeso obodo ndị tere anya. O metụtaghị obodo ndị na-adịghị nʼime mba ndị a dị nso. 
\p  
\v 16 Ma otu ọ dị, nʼobodo niile ndị ahụ \nd Onyenwe anyị\nd* Chineke na-enye gị dịka ihe nketa, o nweghị ihe ọbụla na-eku ume ị ga-ahapụ ndụ. Laa ihe niile na-eku ume nʼiyi.  
\v 17 Ị ghaghị ịla obodo ndị a nʼiyi: obodo ndị Het na nke ndị Amọrait, nke ndị Kenan na nke ndị Periz, nke ndị Hiv na nke ndị Jebus, dịka \nd Onyenwe anyị\nd* Chineke gị nyere gị nʼiwu.  
\v 18 Ma ọ bụghị otu a, ha ga-akụziri gị ime ihe ndị ahụ niile rụrụ arụ ha na-eme mgbe ha na-efe chi ha dị iche iche, mee ka i mehie megide \nd Onyenwe anyị\nd* Chineke gị. 
\p  
\v 19 Mgbe ị nọchibidoro obodo ọbụla ogologo oge, na-ebu agha megide ya maka iwere ya, ebibila osisi na-amị mkpụrụ dị nʼime ya site nʼiji anyụike gbutuo ha. Nʼihi na i nwere ike rie mkpụrụ osisi ha, egbutula ha. Osisi dị nʼọhịa ha ọ bụ ndị mmadụ, na ị ga-anọchibido ha?  
\v 20 Naanị osisi na-adịghị amị mkpụrụ ka ị ga-egbutu, nke a na-adịghị eri mkpụrụ ya eri. Jiri ha meere onwe gị ngwa ọgụ, dịka ubibi, na nkwasa, na ihe unu ji etitu mgbidi obodo ahụ. 
\c 21  
\s1 Ọnwụ amaghị ihe kpatara ya 
\p  
\v 1 Mgbe ị batara nʼala ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị inweta, biri nʼime ya, ọ bụrụ na ị hụ otu onye e gburu egbu ka ọ tọgbọ nʼime ọhịa, ma ị maghị onye gburu ya,  
\v 2 ndị okenye gị, na ndị ikpe ga-apụta, tụọ ịdị anya nke obodo niile dị gburugburu ọhịa ahụ, site nʼebe ahụ onye ahụ e gburu egbu tọgbọ.  
\v 3 Ndị okenye obodo ahụ ga-ewere nwa nne ehi a na-ejibeghị rụọ ọrụ, maọbụ nyara yoku ọbụla  
\v 4 ha ga-eduru ya gaa na ndagwurugwu nke mmiri na-eru nʼime ya, ndagwurugwu a na-egwuzebeghị mgbe ọbụla ịrụ ọrụ ubi nʼime ya, nke a na-akụghị mkpụrụ nʼime ya, gbajie olu nwaagbọghọ ehi ahụ nʼebe ahụ.  
\v 5 Ndị nchụaja, ụmụ Livayị, ga-abịa, nʼihi na \nd Onyenwe anyị\nd* Chineke gị ahọpụtala ha ka ha bụrụ ndị na-ejere ya ozi. Ha ka ọ họpụtakwara ikwupụta ngọzị nʼaha \nd Onyenwe anyị\nd*, na ikpe niile metụtara mmerụ ahụ.  
\v 6 Mgbe ahụ, ndị okenye niile nke obodo ndị ahụ dịkarịsịrị ozu ahụ nso, ga-akwọ aka ha nʼelu nwaagbọghọ ehi ahụ,\f + \fr 21:6 \ft Omume dị otu a, zipụtara na ha bụ ndị aka ha dị ọcha nʼọnwụ onye ahụ e gburu.\f* nke ahụ a gbajiri olu nʼime ndagwurugwu ahụ.  
\v 7 Ha ga-ekwupụta sị, “Aka anyị dị ọcha, ọ bụghị anyị gburu nwoke a, anyị amakwaghị onye gburu ya.  
\v 8 \nd Onyenwe anyị\nd*, kpuchiere ndị gị Izrel mmehie ha, bụ ndị gị ị gbapụtara. Agụla ndị gị dịka ndị ikpe mara nʼihi ọnwụ nwoke a na-emeghị ihe ọjọọ.” Otu a ka a ga-esi kpuchie mmehie nʼihi mwụfu ọbara ahụ.  
\v 9 Nʼụzọ dị otu a, ka ị ga-esi wezugara onwe gị ikpe ọmụma gaara abụ nke gị nʼihi ọbara onye ahụ nwụrụ anwụ, ebe ọ bụ na i meela ihe ziri ezi nʼanya \nd Onyenwe anyị\nd*. 
\s1 Ịlụ ndị inyom a dọtara nʼagha 
\p  
\v 10 Mgbe ị pụrụ ibuso ndị iro gị agha, ọ bụrụ na \nd Onyenwe anyị\nd* Chineke gị emee ka i merie ndị iro gị, dọta ụfọdụ nʼime ha nʼagha,  
\v 11 ọ bụrụ na ị hụ nwaagbọghọ mara mma nke masịrị gị nʼetiti ndị a dọtara nʼagha, i nwere ike iduru ya ka ọ bụrụ nwunye gị.  
\v 12 Ị ga-akpọbata ya nʼụlọ gị, mee ka ọ kpụcha agịrị isi ya, bekwaa mbọ ya niile,  
\v 13 yipụ uwe ahụ o yi mgbe e jidere ya. Ọ ga-anọdụ nʼụlọ gị ruo ụjụ nʼihi nna ya na nne ya otu ọnwa. Emesịa, i nwere ike ịbakwuru ya ghọọ di ya, ya onwe ya ga-aghọkwa nwunye gị.  
\v 14 Ọ bụrụ na ihe ya amasịkwaghị gị, ị ga-ahapụ ya ka ọ gaa ebe ọbụla ọ chọrọ. Ị gaghị ere ya nʼọnụ ego ọbụla maọbụ kpasi ya agwa dịka ohu, ebe ọ bụ na ị wedala ya nʼala site nʼịhụ ọtọ ya anya. 
\s1 Oke ruru ọkpara 
\p  
\v 15 Ọ bụrụ na nwoke lụrụ ndị inyom abụọ, ma hụ otu nʼime ha nʼanya karịa nke ọzọ, ọ bụrụkwa na ndị inyom abụọ ahụ mụtaara ya ụmụ ndị ikom, ma nwanyị ahụ ọ kpọrọ asị buuru ụzọ mụta nwa nwoke,  
\v 16 mgbe nwoke ahụ na-eke ihe onwunwe ya, ọ gaghị ewere oke ruuru ọkpara ya, nke nwanyị ahụ ọ kpọrọ asị mụtara kenye nwa nwoke nke nwanyị ahụ ọ hụrụ nʼanya mụrụ.  
\v 17 Ọ ga-anabata nwa nwoke nke nwanyị ahụ ọ na-ahụghị nʼanya mụtara dị ka ọkpara, nye ya, oke abụọ site nʼihe niile o nwere. Nʼihi na nwoke ahụ bụ mmalite ume ya, ọnọdụ nke ị bụ ọkpara bụkwa nke ya. 
\s1 Nwa isiike 
\p  
\v 18 Ọ bụrụ na nwoke amụta nwa nwoke na-eme isiike, nke na-enupu isi, onye na-adịghị ege nna ya na nne ya ntị, ọ bụladị mgbe ha dọrọ ya aka na ntị.  
\v 19 Nne ya na nna ya ga-eduru ya gaa nʼihu ndị okenye, nʼọnụ ụzọ ama obodo ha.  
\v 20 Ha ga-agwa ndị okenye obodo ahụ, “Nwa anyị nwoke a na-eme isiike, na-enupu isi, ọ dịghị ege ntị nʼolu anyị. Ọ bụ onye mmefu na onye na-aṅụbiga mmanya oke.”  
\v 21 Ndị ikom niile nke obodo ahụ ga-ewere nkume tugbuo ya. Nʼụzọ dị otu a, unu ga-ekpochapụ ihe ọjọọ ahụ nʼetiti unu. Ndị Izrel niile ga-anụ ihe mere, ụjọ ga-atụkwa ha. 
\s1 Iwu dị iche iche 
\p  
\v 22 Ọ bụrụ na nwoke ọbụla emee ihe ọjọọ kwesiri ọnwụ, ọ bụrụ na e kpee ya ikpe ọnwụ, kwụgbuo ya nʼosisi,  
\v 23 unu agaghị ahapụ ozu ya ka ọ dịgide nʼelu osisi abalị ahụ niile. Hụnụ na e liri ya nʼotu ụbọchị ahụ, nʼihi na onye ọbụla a kwụbara nʼelu osisi bụ onye Chineke bụrụ ọnụ. Emerụla ala ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị dịka ihe nketa. 
\c 22  
\p  
\v 1 Ọ bụrụ na ị hụ ehi, maọbụ atụrụ nwanna gị ka ọ na-akpafu, emela dịka a ga-asị na ị hụghị ya, jide ya, kpụlaara ya onye nwe ya.  
\v 2 Ọ bụrụ na ị maghị onye nwe ya, maọbụ na nwanna gị ebighị nso, were ya laa nʼụlọ gị, hapụ ya nʼebe ahụ tutu onye nwe ya achọwa ya, mgbe ahụ ka ị ga-ewere ya nyeghachi ya.  
\v 3 Otu a kwa ka ị ga-eme ma ị hụ ịnyịnya ibu nwanna gị, maọbụ uwe, maọbụ ihe ọbụla ị ga-atụtụta. Were ya debere onye nwe ya. 
\p  
\v 4 Ọ bụrụ na ị hụ ịnyịnya ibu, maọbụ ehi nwanna gị ka ha dara nʼụzọ, elela anya nʼebe ọzọ, gaa nyere ya aka bulie ya. 
\p  
\v 5 Nwanyị ekwesighị iyi uwe ndị ikom, nwoke agaghị eyikwa uwe ndị inyom. Nʼihi na ihe arụ ka ọ bụ nʼanya \nd Onyenwe anyị\nd* Chineke gị. 
\p  
\v 6 Ọ bụrụ na ị hụ akwụ nnụnụ tọgbọ nʼala, maọbụ nke dị nʼelu osisi, ọ bụrụkwa na ọ bụ nnụnụ nke nọ nʼelu ụmụ ya, maọbụ nʼelu akwa ya, ewerela nne na ụmụ nnụnụ ya.  
\v 7 Hapụ nne nnụnụ ka ọ laa, ma were naanị ụmụ ya. Ihe ga-agakwara gị nke ọma nʼihi ya, ị ga-enwekwa ndụ ogologo. 
\p  
\v 8 \f + \fr 22:8 \ft Iwu a bụ ihe dị mkpa nʼihi na elu ụlọ ha na-adị larịị, nke bụ na mmadụ nwere ike ijegharị nʼebe ahụ, maọbụ dinaa ala nʼabalị nʼoge okpomọkụ.\f*Mgbe i wuru ụlọ, wuokwa ihe mgbochi gburugburu elu ya, nke ga-eme ka onye ọbụla ghara isi nʼelu ya dapụ, si otu a wetara ụlọ na onye nwe ya ikpe ọmụma nke iwufu ọbara. 
\p  
\v 9 Akụla ụdị mkpụrụ abụọ nʼubi vaịnị gị. Ọ bụrụ na i mee otu a, ihe ọkụkụ ndị a, na mkpụrụ ha mịrị ga-abụ ihe rụrụ arụ. 
\p  
\v 10 Ejikọla ehi na ịnyịnya ibu maka ịdọ ihe e ji akọ ala ubi. 
\p  
\v 11 Eyila uwe e ji ụzọ ihe abụọ kpaa, dịka uwe ajị anụ na ogho ọcha kpaa. 
\p  
\v 12 Ị ga-akpanyere onwe gị ihe ogho akpara akpa, nʼakụkụ anọ nke uwe mgbokwasị gị. 
\s1 Mmekọrịta nwoke na nwanyị 
\p  
\v 13 Ọ bụrụ na nwoke alụọ nwaagbọghọ, mesie mgbe o dinakwuru ya kpebie nʼobi ya na ọ chọkwaghị ịlụ ya ọzọ,  
\v 14 ọ bụrụ na nwoke a ekwutọọ nwaagbọghọ ahụ, mebie aha ya kwuo na nwaagbọghọ ahụ amatalarị nwoke tupu ha abụọ alụọ,  
\v 15 nne nwaagbọghọ ahụ, na nna ya, ga-ewere ihe ga-egosi na nwa ha amabeghị nwoke gaa nʼihu ndị okenye obodo ahụ, nʼọnụ ụzọ ama.  
\v 16 Nna nwaagbọghọ ahụ ga-agwa ndị okenye, “Enyere m nwoke a nwa m nwanyị dịka nwunye, ma ugbu a, ọ chọkwaghị ịlụ ya.  
\v 17 Ugbu a, o boola ya ebubo ihere, sị, ‘Achọpụtaghị m ihe ọbụla nʼahụ nwa gị nwanyị a ihe na-egosi na ọ maghị nwoke.’ Ma nke a bụ ihe ngosi na ada anyị amaghị nwoke.” Mgbe ahụ ndị mụrụ ya ga-agbasapụ akwa ahụ nʼihu ndị okenye obodo ahụ.  
\v 18 Ndị okenye obodo ahụ ga-akpọrọ nwoke nyekwa ya ahụhụ.  
\v 19 Ha ga-emekwa ya ka ọ kwụọ nna nwaagbọghọ ahụ narị shekel ọlaọcha, nʼihi na o boro nwaagbọghọ Izrel na-amaghị nwoke ebubo ụgha. Nwaagbọghọ ahụ ga-anọgide bụrụ nwunye nwoke ahụ. Nwoke ahụ agaghị achụpụkwa ya ụbọchị ndụ ya niile. 
\p  
\v 20 Ma ọ bụrụ na ebubo nwoke ahụ bụ eziokwu, na achọpụtaghị ihe gosiri na nwaagbọghọ ahụ amaghị nwoke.  
\v 21 A ga-eduru nwaagbọghọ ahụ pụta nʼọnụ ụzọ ụlọ nna ya, nʼebe ahụ ka ndị ikom obodo ya ga-anọ were nkume tugbuo ya. Nʼihi na o mere ihe ihere jọgburu onwe ya nʼIzrel, site nʼibi ndụ akwụna mgbe ọ ka nọ nʼụlọ nne ya na nna ya. Ị ghaghị ikpochapụ ihe ọjọọ ahụ site nʼetiti unu. 
\p  
\v 22 Ọ bụrụ na e jide nwoke ebe ya na nwunye onye ọzọ dina, ma nwoke ahụ dinara ya ma nwanyị ahụ o dinara aghaghị ịnwụ. Nʼụzọ dị otu a, ị ga-ekpochapụ ihe ọjọọ a site nʼIzrel. 
\p  
\v 23 Ma ọ bụrụ na nwaagbọghọ na-amaghị nwoke a na-alụ alụ na nwoke ọzọ edinakọọ nʼime obodo,  
\v 24 ya na nwoke ahụ ka a ga-eduru gaa nʼọnụ ụzọ ama obodo, were nkume tugbuo ha nʼebe ahụ, ka ha nwụọ, nwaagbọghọ ahụ ga-anwụ nʼihi na o tighị mkpu, ma nwoke ahụ ga-anwụ nʼihi na o mebiela nwunye nwoke ibe ya na-achọ ịlụ. Unu aghaghị ikpochapụ ihe ọjọọ site nʼetiti unu. 
\p  
\v 25 Ma ọ bụrụ na nwoke ezute nwaagbọghọ na-amaghị nwoke a na-alụ alụ nʼọhịa, were ike mee ka ha abụọ dina, ọ bụ naanị nwoke ahụ ga-anwụ.  
\v 26 Aka nwaagbọghọ ahụ dị ọcha, ọ dịghị mmehie o mere nke ikpe ọnwụ ji adịrị ya, nʼihi na ọnọdụ ya dị ka ọnọdụ mmadụ ahụ onye iro ya bịakwasịrị na mberede gbuo ya.  
\v 27 A pụrụ ị sị na nwaagbọghọ ahụ tiri mkpu ma ọ dịghị onye nọ ịnapụta ya. 
\p  
\v 28 Ọ bụrụ na nwoke ọbụla ejiri ike jide nwaagbọghọ na-amaghị nwoke, nke nwoke ọbụla na-ekwebeghị nkwa ịlụ, mee ka ha abụọ dinaa,  
\v 29 nwoke ahụ ga-akwụ nna nwaagbọghọ ahụ iri shekel ọlaọcha ise. Ọ ga-alụkwa nwaagbọghọ ahụ nʼihi na o mebiela ya. Ọ gakwaghị achụpụ ya ụbọchị niile nke ndụ ya. 
\p  
\v 30 Nwoke ọbụla agaghị alụ nwunye nna ya, nʼihi na ọ bụ nwunye nna ya. Ime ihe dị otu a bụ imerụ ihe ndina nna ya. 
\c 23  
\s1 Ndị na-agaghị esonye na mkpọkọta ahụ 
\p  
\v 1 Nwoke ọbụla echipịara mkpụrụ amụ ya, maọbụ nke e bipụrụ mkpụrụ amụ ya, agaghị esonye na mkpọkọta \nd Onyenwe anyị\nd*. 
\p  
\v 2 Nwa ọbụla a mụtara site nʼịkwa iko agakwaghị esonye na mkpọkọta \nd Onyenwe anyị\nd*, ụmụ ụmụ ya, ruo nʼọgbọ nke iri, agakwaghị esonye na mkpọkọta \nd Onyenwe anyị\nd*. 
\p  
\v 3 Onye Amọn, maọbụ onye Moab, agaghị esonye na mkpọkọta \nd Onyenwe anyị\nd*, ọ bụladị ruo nʼọgbọ nke iri ha.  
\v 4 Nʼihi na ha e jighị achịcha na mmiri bịa zute unu nʼụzọ mgbe unu si Ijipt pụta, ha goro Belam, nwa Beoa, onye si Petọ nke dị na Aram Naharaim, ka ọ bụọ unu ọnụ.  
\v 5 Ma \nd Onyenwe anyị\nd* Chineke gị egeghị Belam ntị, kama \nd Onyenwe anyị\nd* Chineke gị gbanwere ịbụ ọnụ ahụ mee ka ọ ghọọrọ gị ngọzị, nʼihi na \nd Onyenwe anyị\nd* Chineke gị hụrụ gị nʼanya.  
\v 6 Achọla udo ndị Amọn na Moab, na ọdịmma ha ụbọchị ndụ gị niile ruo mgbe ebighị ebi. 
\p  
\v 7 Ma eledala ndị Edọm anya, nʼihi na ndị Edọm bụ ụmụnna unu. Unu eledala ndị Ijipt anya, nʼihi na unu biri dịka ndị ọbịa nʼime ala ha.  
\v 8 Ụmụ a ga-amụrụ ha nʼọgbọ nke atọ ha nwere ike ịbata na mkpọkọta nke \nd Onyenwe anyị\nd*. 
\s1 Adịghị ọcha nʼọmụma ụlọ ikwu 
\p  
\v 9 Mgbe unu mara ụlọ ikwu unu maka ibu agha megide ndị iro unu, wezuganụ onwe unu site nʼihe ọbụla na-adịghị ọcha.  
\v 10 Nwoke ọbụla nʼetiti gị nke na-adịghị ọcha site nʼịnyụ mkpụrụ nwa nʼahụ ya nʼabalị, ga-apụ gaa nọdụ nʼazụ ọmụma ụlọ ikwu.  
\v 11 Ọ ga-anọ nʼebe ahụ ruo uhuruchi, emesịa, ọ ga-asa ahụ ya lọghachi nʼụlọ ikwu nʼanyasị. 
\p  
\v 12 Ị ga-enwekwa otu ebe ndị gị ga-anọ jee nʼogwe ga-adị nʼazụ ọmụma ụlọ ikwu.  
\v 13 Onye ọbụla nʼime unu ga-enwe shọvel dịka otu nʼime ngwa agha ya. Mgbe ọbụla kwa o jere nʼogwe, ọ ga-eji ya gwuo ala kpochie nsị ọ nyụrụ.  
\v 14 Ụlọ ikwu gị ga-adị nsọ, nʼihi na \nd Onyenwe anyị\nd* Chineke gị na-ejegharị nʼetiti gị ichebe gị, na ịnapụta gị site nʼaka ndị iro gị. \nd Onyenwe anyị\nd* achọghị ihu ihe ọbụla na-adịghị mma nʼanya, ka ọ ghara ịlaghachi azụ iso gị. 
\s1 Iwu ndị ọzọ 
\p  
\v 15 Ọ bụrụ na ohu esite nʼaka onye nwe ya gbakwute unu, akwagidela ya ka ọ lọghachi,  
\v 16 hapụ ya ka o biri nʼetiti gị nʼime obodo ọbụla masịrị ya, emegbukwala ya. 
\p  
\v 17 Ọ dịghị nwoke maọbụ nwanyị, onye Izrel ga-aghọ akwụna ụlọ arụsị.  
\v 18 Ị gaghị ewebata nʼụlọ \nd Onyenwe anyị\nd* Chineke gị, onyinye ọbụla site nʼego nwanyị na-agba akwụna kpatara, maọbụ site nʼego nwoke ahụ na-edebe onwe ya dịka akwụna nye ndị ikom ibe\f + \fr 23:18 \ft Maọbụ, \fqa ego e retara na nkịta\f* ya kpatara, iji mezuo nkwa ọbụla. Nʼihi na ha abụọ bụ ihe rụrụ arụ nʼanya \nd Onyenwe anyị\nd* Chineke gị. 
\p  
\v 19 A nakwala onye Izrel ibe gị ọmụrụnwa, nʼihe ọbụla i binyere ya, maọbụ ego, maọbụ nri, ma ọ bụkwanụ ihe ọbụla ọzọ nwere ike ịmụta ọmụrụnwa.  
\v 20 Onye mba ọzọ ka ị ga-ana ọmụrụnwa nʼihe i binyere ya, ọ bụghị onye Izrel ibe gị. Ka \nd Onyenwe anyị\nd* bụ Chineke gị gọzie gị nʼihe niile i tinyere aka gị ime nʼala ahụ nke ị na-aba inweta. 
\p  
\v 21 Mgbe i kwere \nd Onyenwe anyị\nd* bụ Chineke gị nkwa, alala azụ nʼịkwụghachi ya, nʼihi na \nd Onyenwe anyị\nd* Chineke gị chọrọ ka ị kwụghachi nkwa gị ọsịịsọ. Ọ ga-abụkwara gị mmehie ma i meghị ya.  
\v 22 Ma ọ gaghị abụrụ gị mmehie ma ọ bụrụ na i kweghị nkwa ọbụla!  
\v 23 Ihe ọbụla nke i kwere na nkwa, jisie ike hụ na i mezuru nke ahụ dịka okwu gị si dị, nʼihi na ọ bụ onyinye afọ ofufu nye \nd Onyenwe anyị\nd* Chineke gị. 
\p  
\v 24 Ọ bụrụ na ị banye nʼubi vaịnị onye agbataobi gị, i nwere ike ghọrọ mkpụrụ vaịnị ọbụla ị chọrọ rachaa nʼebe ahụ, ma etinyela mkpụrụ ọbụla nʼakpa gị.  
\v 25 Otu a kwa, ị banye nʼubi ọka onye agbataobi gị, ghọrọ mkpụrụ ọka ọbụla ị chọrọ nʼaka gị, nọọkwa nʼebe ahụ taa ya, ma ị gaghị etinye mma iwe ihe ubi nʼime ọka ha ndị guzoro eguzo. 
\c 24  
\p  
\v 1 Ọ bụrụ na nwoke akpọrọ nwanyị, lụọ ya, ma emesịa ihe nwanyị ahụ amasịkwaghị ya nʼihi na ọ dị ihe ọ chọpụtara nʼahụ ya nke na-adịghị mma, ọ ga-ede akwụkwọ alụkwaghị m nye nwanyị ahụ nʼaka, zilaa ya.  
\v 2 Ọ bụrụ na emesịa, nwoke ọzọ alụọ ya,  
\v 3 ma nwoke ahụ ekpebiekwa ịgbara ya akwụkwọ achọkwaghị m, maọbụ na nwoke a mesịrị nwụọ,  
\v 4 nwoke mbụ ahụ lụrụ nwanyị ahụ agaghị alụ ya ọzọ, nʼihi na nwanyị a abụrụla onye rụrụ arụ nye nwoke ahụ. Ọ bụkwa arụ nʼanya \nd Onyenwe anyị\nd* ma di ya nke mbụ lụọ ya ọzọ. Ihe dị otu a ga-eweta ihe ọjọọ nʼala ahụ \nd Onyenwe anyị\nd* Chineke na-enye gị dịka ihe nketa. 
\p  
\v 5 Nwoke ọbụla lụrụ nwunye ọhụrụ agaghị apụ soro ndị agha, maọbụ soro rụọ ọrụ ọzọ pụrụ iche, otu afọ ka ọ ga-enwere onwe ya ịnọ nʼụlọ ya, ya na nwunye ya, ime onwe ha obi ụtọ. 
\p  
\v 6 Mmadụ agaghị ewere nkume ịkwọ nri dịka ihe ebe, nʼihi na ọ bụ ihe onye nwe ya ji achọta nri ụbọchị ya. 
\p  
\v 7 Ọ bụrụ na onye ọbụla ezuru nwanna ya onye Izrel nʼohi, mesoo ya mmeso dịka ohu, maọbụ ree ya, onye ohi ahụ ga-anwụ. Nke a bụ ikpochapụ ihe ọjọọ nʼetiti gị. 
\p  
\v 8 Gbalịsie ike ịhụ na ị na-eso iwu niile onye nchụaja, bụ onye Livayị nyere gị banyere ndị nwere ọrịa ekpenta, nʼihi na agwala m ya usoro ha ga-agbaso.  
\v 9 Chetakwa ihe \nd Onyenwe anyị\nd* Chineke gị mere Miriam, mgbe i si nʼIjipt na-apụta. 
\p  
\v 10 Ọ bụrụ na i binye mmadụ ihe ọbụla, abanyekwala nʼụlọ ya ịnata ihe a na-enye gị dị ka ihe ebe.  
\v 11 Guzo nʼezi! Ka onye ahụ ị na-ebinye ihe wetara gị ihe ibe ahụ nʼezi.  
\v 12 Ọ bụrụ na ọ bụ onye ogbenye na-enweghị ihe, e jidela ihe ibe ya naba ụra abalị.  
\v 13 Weghachiri ya akwa ahụ nʼanyasị, ka onye agbataobi gị jiri ya hie ụra abalị. Mgbe ahụ ha ga-ekele gị, \nd Onyenwe anyị\nd* Chineke gị ga-agụkwara gị ya nʼezi omume. 
\p  
\v 14 Emegbula nwa ogbenye mkpa na-akpa i goro ọrụ, ma onye ahụ ọ bụ nwa Izrel ma ọ bụkwanụ onye ọbịa bi nʼobodo gị.  
\v 15 Kwụọ ya ụgwọ ya ụbọchị niile tupu anwụ adaa, nʼihi na ebe ọ bụ nwa ogbenye, obi ya dabeere nʼụgwọ ahụ ị ga-akwụ ya. Ọ bụrụ na i meghị otu a, ọ ga-akwa akwa kpọkuo \nd Onyenwe anyị\nd* megide gị. A ga-agụkwara gị ya dịka mmehie. 
\p  
\v 16 Agaghị eme ka ndị mụrụ ụmụ nwụọ nʼihi ihe ụmụ ha metara, maọbụ mee ka ụmụ nwụọ nʼihi ihe ndị mụrụ ha metara, onye ọbụla ga-anwụ nʼihi mmehie nke aka ya. 
\p  
\v 17 Ikpe ziri ezi ga-adịrị, ọ bụladị onye ọbịa na nwa mgbei, anarakwala nwanyị di ya nwụrụ anwụ uwe ya dịka ihe ibe.  
\v 18 Cheta mgbe niile na i bụrụrị ohu nʼala Ijipt, ma \nd Onyenwe anyị\nd* Chineke gị gbapụtara gị, nʼihi nke a ka m ji enye gị iwu ndị a. 
\p  
\v 19 Ọ bụrụ na i lefuo ukwu ọka ụfọdụ anya mgbe ị na-ewe ihe ubi nʼubi gị, alaghachila azụ nʼubi gị ịchịrị ha. Hapụrụ ya ndị ọbịa, na ndị inyom di ha nwụrụ anwụ, na ụmụ mgbei, \nd Onyenwe anyị\nd* Chineke gị ga-agọzi gị, ọ ga-emekwa ka ị baa ụba.  
\v 20 Mgbe ị na-akụtusi mkpụrụ osisi oliv gị, ejeghachila azụ nʼalaka ọbụla inyochazi ya, ịchọpụta ma ị ghọtachaala mkpụrụ niile mịrị nʼelu ha. Hapụrụ ndị ọbịa na ụmụ mgbei, na ndị inyom di ha nwụrụ mkpụrụ ọbụla fọdụrụ.  
\v 21 Otu a ka ị ga-emekwa nʼihe banyere mkpụrụ ubi vaịnị gị. Atụtụkọchala mkpụrụ niile mịrị nʼelu ya. Hapụrụ ndị ọbịa, na ndị mgbei, na ndị inyom di ha nwụrụ ihe niile fọdụrụ.  
\v 22 Chetakwa na o nwere mgbe ị bụ ndị ohu nʼala Ijipt. Ọ bụ nʼihi ya ka m ji na-enye gị iwu a. 
\c 25  
\p  
\v 1 Mgbe esemokwu dị nʼetiti ndị mmadụ, ha ga-ebuga ikpe ha nʼụlọikpe ebe ndị ikpe ga-elenye anya nʼikpe ahụ, maa onye ajọ omume ikpe, meekwa ka onye aka ya dị ọcha nwere onwe ya.  
\v 2 Ọ bụrụkwa na onye ikpe mara kwesiri ka apịa ya ụtarị, onye ọkaikpe ga-eme ka onye ahụ dinaa ala nʼihu ya, ka apịakwa ya ọnụọgụgụ ụtarị kwesiri ajọ omume ya,  
\v 3 ma agaghị eti ya karịa ọnụ ụtarị iri anọ. Ọ bụrụ na e tie onye ahụ ikpe mara ọnụ ụtarị karịrị nke a, ọ ga-abụ onye e leliri anya nʼihu ndị Izrel ibe ya. 
\p  
\v 4 Mgbe ehi\f + \fr 25:4 \ft Ọtụtụ oge, ehi bụ ihe na-azọcha ọka nʼebe ịzọcha ọka. A na-eji osisi kegide anụ ndị a na nkume igwe nri, mgbe ha na-agagharị, ụkwụ ha bụ ihe na-azọcha mkpụrụ ọka site nʼigbugbo ya. Nʼotu oge ahụ, nkume igwe nri ahụ na-egweri ọka ndị a ka ọ bụrụ ụtụ ọka.\f* na-azọcha ọka, ejila ihe kechie ya ọnụ. 
\p  
\v 5 Ọ bụrụ na nwoke anwụọ na-amụtaghị nwa, nwunye ya ahụ agaghị alụ di nʼama, kama nwanne nwoke di ya ga-alụrụ ya, ha ga-edinakọkwa.  
\v 6 Nwa nwoke mbụ nwanyị ahụ ga-amụ ga-aza aha nwoke ahụ nwụrụ anwụ, ka a ghara ihichapụ aha ya nʼala Izrel. 
\p  
\v 7 Ma ọ bụrụ na nwoke ahụ ajụ ịlụ nwunye nwanne ya nwụrụ anwụ, nwanyị ahụ ga-ejekwuru ndị okenye obodo ahụ nʼọnụ ụzọ ama, gwa ha sị, “Nwanne di m ajụla ime ka aha nwanne ya nwoke dịgide nʼIzrel. O kweghị ịrụ ọrụ kwesiri nwanne di nʼebe m nọ.”  
\v 8 Ndị okenye obodo ga-akpọ ya, dụọ ya ọdụ. Ọ bụrụ na ọ nọgide jụ sị, “Achọghị m ịlụ ya,”  
\v 9 nwanyị ahụ ga-ejekwuru ya nʼihu ndị okenye, tọpụ akpụkpọụkwụ o yi nʼụkwụ aka nri ya, bụọ ya asụ nʼihu, sị ya, “Otu a ka a na-eme nwoke ọbụla jụrụ iwuli ụlọ nwanne ya nwoke.”  
\v 10 A ga-ama ahịrị ya nʼIzrel dịka, “Ezinaụlọ nwoke ahụ e sitere nʼụkwụ ya yipụ akpụkpọụkwụ ya.” 
\p  
\v 11 Mgbe ndị ikom abụọ na-alụ ọgụ, ọ bụrụ na nwunye otu nʼime ha abịa ịnapụta di ya site nʼaka onye na-eti ya ihe, ma nwanyị ahụ esetipụ aka jide nwoke ahụ nʼamụ ya,  
\v 12 a ga-egbupụ aka nwanyị ahụ. Ebere adịghị ya. 
\p  
\v 13 Enwela ụzọ ihe ọtụtụ abụọ nʼime akpa gị, nke dị arọ, na nke na-adịghị arọ.\f + \fr 25:13 \ft Nke ukwu na nke nta\f* 
\v 14 Enwela ụdị ihe ọtụtụ abụọ nʼụlọ gị, nke ukwu na nke nta.  
\v 15 Ị ghaghị inwe ezi ihe ọtụtụ na nke zuru ezu. Nke a ga-eme ka ndụ gị dị ogologo, dịkwa mma nʼala ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị.  
\v 16 Nʼihi na \nd Onyenwe anyị\nd* Chineke gị kpọrọ onye ọbụla na-eme ihe ndị a asị, bụ onye ọbụla na-aghọ aghụghọ. 
\p  
\v 17 Cheta ihe ndị Amalek mere gị nʼụzọ mgbe i si nʼIjipt na-apụta.  
\v 18 Chetakwa na ha lụsoro gị ọgụ mgbe ike gwụrụ gị, mgbe ị dara mba, tigbuo ndị niile ji nwayọọ na-abịa nʼazụ. Ha atụkwaghị egwu Chineke.  
\v 19 Mgbe \nd Onyenwe anyị\nd* Chineke gị mere ka i nwere onwe gị site nʼaka ndị iro gbara gị gburugburu, mgbe o mere ka i zuru ike nʼala ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị dịka ihe nketa, ime ka i nweta ya, ị ghaghị igbuchapụ ndị Amalek, ka ha bụrụ ndị a na-agaghị echetakwa ọzọ nʼokpuru eluigwe. Echefukwala ime otu a. 
\c 26  
\s1 Onyinye mkpụrụ mbụ na otu ụzọ nʼụzọ iri 
\p  
\v 1 Mgbe ị ga-aba nʼala ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị dịka ihe nketa, mgbe ị nwetara ya, birikwa nʼime ya,  
\v 2 ị ga-ewere ụfọdụ nʼime mkpụrụ niile si nʼala ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị, tinye ya nʼime nkata, were ya gaa nʼebe ahụ \nd Onyenwe anyị\nd* Chineke unu ga-ahọpụta, dịka ebe a kpọkwasịrị aha ya.  
\v 3 Ị ga-agwakwa onye nchụaja nọ nʼọrụ nʼoge ahụ okwu sị: “Ana m ekwupụta taa nye \nd Onyenwe anyị\nd* Chineke gị na abịala m nʼala ahụ \nd Onyenwe anyị\nd* ṅụụrụ nna nna anyị ha nʼiyi inye anyị.”  
\v 4 Onye nchụaja ahụ ga-anara nkata ahụ, dọba ya nʼihu ebe ịchụ aja \nd Onyenwe anyị\nd* Chineke gị.  
\v 5 Mgbe ahụ, ị ga-ekwupụta nʼihu \nd Onyenwe anyị\nd* Chineke gị sị, “Nna nna m bụ onye Aram na-awagharị awagharị, onye jere Ijipt izere ndụ.\f + \fr 26:5 \ft Onye a na-ekwu banyere ya bụ Jekọb, \xt Hos 12:12; Jen 43:3; 45:7,11\f* Ha dị ole na ole mgbe ha gara Ijipt, ma nʼIjipt ha ghọrọ mba dị ukwuu, ndị dị ike, na ndị bara ụba nʼọnụọgụgụ.  
\v 6 Ma ndị Ijipt mejọrọ anyị, mee ka anyị taa ahụhụ nʼihi ọrụ dị ike nke ha bokwasịrị anyị.  
\v 7 Mgbe ahụ, anyị tikuru \nd Onyenwe anyị\nd* Chineke nna nna anyị. \nd Onyenwe anyị\nd* nụrụ olu anyị, hụkwa mmegbu a na-emegbu anyị, na ndọgbu anyị na-adọgbu onwe anyị nʼọrụ, na ọnọdụ ọjọọ anyị.  
\v 8 \nd Onyenwe anyị\nd* ji aka dị ike na ogwe aka o setịrị eseti, nʼọtụtụ ihe oke egwu na ọrụ ịrịbama, na ihe ebube, si nʼIjipt kpọpụta anyị.  
\v 9 Ọ kpọbatara anyị nʼebe a, nye anyị ala a, ala mmiri ara ehi na mmanụ aṅụ na-eru na ya.  
\v 10 Ya mere, ugbu a, \nd Onyenwe anyị\nd*, lee, ewebatala m mkpụrụ mbụ sitere nʼala i nyere m.” Dọba nkata ahụ nʼihu \nd Onyenwe anyị\nd* Chineke gị, kpọọkwa isiala nye ya nʼebe ahụ.  
\v 11 Mgbe ahụ, gị na ndị Livayị, na ndị mbịarambịa bi nʼetiti unu, ga-aṅụrị ọṅụ nʼihe ọma niile \nd Onyenwe anyị\nd* Chineke gị nyere gị na ezinaụlọ gị. 
\p  
\v 12 Nʼafọ nke atọ ọbụla, ị ga-enye onyinye pụrụ iche, onyinye otu ụzọ nʼụzọ iri, nke ihe ubi gị. Nʼafọ ahụ, ị ga-enye ndị Livayị, na ndị ọbịa, na ụmụ mgbei, na ndị inyom di ha nwụrụ, onyinye otu ụzọ nʼụzọ iri gị, ka ha rie ya nʼobodo gị dị iche iche, ka afọ jukwa ha.  
\v 13 Ị ga-ekwupụta nʼihu \nd Onyenwe anyị\nd* Chineke gị sị, “Esitela m nʼụlọ wepụ oke ahụ dị nsọ, nye ha ndị Livayị, na ndị ọbịa, na ụmụ mgbei, na ndị inyom di ha nwụrụ, dịka i nyere m nʼiwu, enupughị m isi maọbụ chefuo iwu gị ọbụla.  
\v 14 Erighị m ihe ọbụla si nʼime ya mgbe m na-eru ụjụ maọbụ wepụ ihe ọbụla nʼime ya nʼọnọdụ adịghị ọcha m, ọ dịkwaghị nke m ji chụọrọ ndị nwụrụ anwụ aja. Egeela m ntị nʼolu \nd Onyenwe anyị\nd* Chineke m, meekwa ihe niile i nyere m nʼiwu.  
\v 15 Site nʼebe obibi nsọ gị dị nʼeluigwe ledata anya gị, gọzie ndị gị Izrel na ala a i nyere anyị, ala mmiri ara ehi na mmanụ aṅụ na-eru na ya, dịka i kwere nna nna anyị ha na nkwa.” 
\s1 Ịgbaso iwu \nd Onyenwe anyị\nd* 
\p  
\v 16 \nd Onyenwe anyị\nd* Chineke gị na-enye gị iwu taa si gị gbaso ụkpụrụ ndị a na iwu ndị a. Lezie anya hụ na i ji obi gị niile na mkpụrụobi gị niile debe ha.  
\v 17 I kwupụtala taa na \nd Onyenwe anyị\nd* bụ Chineke gị, i kweekwala nkwa na ị ga-ege ya ntị, debe iwu ya niile, na ụkpụrụ ya niile, na ị ga-emekwa ihe niile ọ sị gị mee.  
\v 18 Taa kwa, \nd Onyenwe anyị\nd* ekwupụtala na unu bụ ndị nke aka ya, dịka o kwere na nkwa, na ị ga-edebekwa ihe niile o nyere nʼiwu.  
\v 19 O kwuru na ọ ga-emekwa ka i karịa mba niile o kere elu, nʼotuto, nʼaha, nsọpụrụ na ịja mma. Na unu ga-abụkwa mba dị nsọ nye \nd Onyenwe anyị\nd* Chineke unu, dịka o kwere na nkwa. 
\c 27  
\s1 Ebe ịchụ aja nʼugwu Ebal 
\p  
\v 1 Mosis na ndị okenye Izrel nyere ndị Izrel iwu sị, “Debenụ iwu ndị a niile m na-enye unu taa.  
\v 2 Mgbe ị gabigara osimiri Jọdan ruo nʼala ahụ \nd Onyenwe anyị\nd* Chineke gị na-enye gị, bukọtaanụ nkume buru ibu nʼotu ebe, jirikwa ụrọ ọcha techie ha.  
\v 3 Depụta nʼelu nkume ndị ahụ iwu na ụkpụrụ ndị a mgbe ị batara nʼala ahụ mmiri ara ehi na mmanụ aṅụ na-eru nʼime ya, nke \nd Onyenwe anyị\nd* Chineke nna nna gị kwere nkwa inye gị.  
\v 4 Mgbe ị nọkwa nʼofe ọzọ nke osimiri Jọdan, doo nkume ukwu ndị a nʼugwu Ebal, dịka m na-enye gị nʼiwu taa. Jirikwa ụrọ ọcha techie ha.  
\v 5 Wuokwara \nd Onyenwe anyị\nd* Chineke gị ebe ịchụ aja ya nʼebe ahụ. Ebe ịchụ aja eji naanị nkume wuo, nke ejighị ihe ngwa ọrụ igwe rụọ ihe bụla na ya.  
\v 6 Jiri nkume a na-awaghị awa wuore \nd Onyenwe anyị\nd* Chineke gị ebe ịchụ aja ahụ, chụọkwa aja nʼelu ya nye \nd Onyenwe anyị\nd* Chineke gị.  
\v 7 Chụọ aja udo nʼebe ahụ, rie ha, ma ṅụrịakwa ọṅụ nʼihu \nd Onyenwe anyị\nd* Chineke gị.  
\v 8 Depụta iwu ndị a nke ọma, nʼelu nkume ndị ahụ i guzobere.” 
\s1 Ịbụ ọnụ site nʼugwu Ebal 
\p  
\v 9 Mgbe ahụ, Mosis na ndị nchụaja, bụ ndị Livayị, gwakwara ndị Izrel niile okwu sị, “Nọọnụ jii, gị Izrel, gekwaa ntị! Taa, ị ghọọla ndị nke \nd Onyenwe anyị\nd* Chineke unu.  
\v 10 Nʼihi ya debe iwu niile \nd Onyenwe anyị\nd* Chineke gị na ụkpụrụ niile ndị m nyere gị taa.” 
\p  
\v 11 Nʼotu ụbọchị ahụ ka Mosis nyere ha iwu sị, 
\p  
\v 12 Mgbe unu gafere Jọdan, ebo ndị a: Simiọn, na Livayị na Juda na Isaka na Josef na Benjamin, ga-eguzo nʼelu ugwu Gerizim gọzie ụmụ Izrel  
\v 13 Agbụrụ Ruben, Gad, Asha, Zebụlọn, Dan na Naftalị ga-eguzo nʼelu ugwu Ebal kwupụta ọbụbụ ọnụ. 
\p  
\v 14 Ndị Livayị ga-eji olu dị elu gụpụta ya nye ụmụ Izrel niile, 
\b  
\p  
\v 15 “Onye a bụrụ ọnụ ka mmadụ ahụ bụ nke na-apị arụsị maọbụ oyiyi ọbụla, akaọrụ onye ǹka, nke bụ ihe arụ nʼanya \nd Onyenwe anyị\nd*, ma na-eguzobe ya na nzuzo.” 
\pr Ndị mmadụ niile ga-aza sị, “Amen.” 
\p  
\v 16 “Onye a bụrụ ọnụ ka onye ahụ bụ, nke na-elelị nna ya na nne ya.” 
\pr Ụmụ Izrel niile ga-aza, “Amen.” 
\p  
\v 17 “Onye a bụrụ ọnụ ka onye ahụ bụ nke na-ehigharị oke ala onye agbataobi ya.” 
\pr Ụmụ Izrel niile ga-aza, “Amen.” 
\p  
\v 18 “Onye a bụrụ ọnụ ka onye ahụ bụ nke na-eduhie onye ìsì ụzọ.” 
\pr Ụmụ Izrel niile ga-aza, “Amen.” 
\p  
\v 19 “Onye a bụrụ ọnụ ka onye ahụ bụ nke na-adịghị ekpe ikpe ziri ezi nye ndị ọbịa, na ụmụ mgbei, na ndị inyom di ha nwụrụ.” 
\pr Ụmụ Izrel niile ga-aza, “Amen.” 
\p  
\v 20 “Onye a bụrụ ọnụ ka onye ahụ bụ nke na-abakwuru nwunye nna ya soro ya dinaa, nʼihi na o merụọla ihe ndina nna ya.” 
\pr Ụmụ Izrel niile ga-aza, “Amen.” 
\p  
\v 21 “Onye a bụrụ ọnụ ka onye ahụ bụ nke ya na anụmanụ ọbụla na-edina.” 
\pr Ụmụ Izrel niile ga-aza, “Amen.” 
\p  
\v 22 “Onye a bụrụ ọnụ ka onye ahụ bụ, nke ya na nwanne ya nwanyị na-akwa iko, bụ nwanne ya nke nne ya mụrụ, maọbụ nke nwunye nna ya mụrụ.” 
\pr Ụmụ Izrel niile ga-aza, “Amen.” 
\p  
\v 23 “Onye a bụrụ ọnụ ka onye ahụ bụ, nke ya na nne nwunye ya na-edina.” 
\pr Ụmụ Izrel niile ga-aza, “Amen.” 
\p  
\v 24 “Onye a bụrụ ọnụ ka onye ahụ bụ, nke na-etigbu mmadụ ibe ya na nzuzo.” 
\pr Ụmụ Izrel niile ga-aza, “Amen.” 
\p  
\v 25 “Onye a bụrụ ọnụ ka onye ahụ bụ, nke na-anara ngarị maka itigbu onye na-emeghị ihe ọjọọ ọbụla.” 
\pr Ụmụ Izrel niile ga-aza, “Amen.” 
\p  
\v 26 “Onye a bụrụ ọnụ ka onye ahụ bụ, nke na-adịghị eme ka iwu ndị a guzosie ike site na-edebeghị ha.” 
\pr Ụmụ Izrel niile ga-aza, “Amen.” 
\c 28  
\s1 Nrube isi na ngọzị 
\p  
\v 1 Ọ bụrụ na i debezuo ma gbasookwa iwu ndị a niile \nd Onyenwe anyị\nd* Chineke gị sitere nʼaka m na-enye gị taa, \nd Onyenwe anyị\nd* Chineke gị ga-eme ka ị ghọọ mba kachasị mba niile nʼụwa elu.  
\v 2 Ngọzị ndị a niile ga-abịakwasị gị, zuo gị ahụ, ma ọ bụrụ na i rubere \nd Onyenwe anyị\nd* Chineke gị isi. 
\pm  
\v 3 Onye a gọziri agọzi ka ị ga-abụ nʼobodo, bụrụkwa onye a gọziri agọzi nʼala ubi. 
\pm  
\v 4 Ihe a gọziri agọzi ka mkpụrụ nke afọ gị ga-abụ na mkpụrụ nke ala ubi gị na mkpụrụ nke anụ ụlọ gị, ụmụ ehi gị mụrụ na ụmụ igwe ewu na atụrụ gị. 
\pm  
\v 5 Ihe a gọziri agọzi ka abọ gị na ihe i ji agwọ achịcha ga-abụ. 
\pm  
\v 6 Onye a gọziri agọzi ka ị ga-abụ mgbe ị na-abata na mgbe ị na-apụ apụ. 
\p  
\v 7 \nd Onyenwe anyị\nd* ga-eme ka ndị iro ọbụla buliri onwe ha elu imegide gị bụrụ ndị e meriri nʼihu anya gị. Ha ga-esite nʼotu ụzọ buso gị agha, ma ha ga-esite nʼụzọ asaa si nʼihu gị gbalaga. 
\p  
\v 8 \nd Onyenwe anyị\nd* ga-ezipụ ngọzị ya ka ọ dịkwasị nʼelu ọba gị na nʼelu ihe ọbụla i tinyere aka gị. \nd Onyenwe anyị\nd* Chineke gị ga-agọzi gị nʼala ahụ ọ na-enye gị. 
\p  
\v 9 \nd Onyenwe anyị\nd* ga-eme ka i guzosie ike dịka ndị nsọ ya, dịka o sitere nʼịṅụ iyi kwee nkwa ime ma ọ bụrụ na i debe iwu \nd Onyenwe anyị\nd* Chineke gị, ma jee ije nʼụzọ ya niile.  
\v 10 Mgbe ahụ, ndị niile nọ nʼụwa ga-ahụta na ọ bụ aha \nd Onyenwe anyị\nd* ka a kpọkwasịrị gị. Ha ga-atụkwa gị egwu.  
\v 11 \f + \fr 28:11 \ft \xt Dit 30:9\f*\nd Onyenwe anyị\nd* ga-eme ka ị babiga ụba oke na mkpụrụ nke afọ gị, na mkpụrụ nke anụ ụlọ gị, na mkpụrụ nke ihe ubi gị, nʼala ahụ ọ ṅụrụ nʼiyi nye nna nna gị na ọ ga-enye gị. 
\p  
\v 12 \nd Onyenwe anyị\nd* ga-emeghepụ eluigwe ebe ụlọakụ ya dị, zidata mmiri nʼala gị nʼoge ya, ma gọzie akaọrụ gị niile. Ị ga-agbazinye ọtụtụ mba ihe, ma gị onwe gị agaghị esite nʼaka onye ọbụla gbaziri ihe ọbụla.  
\v 13 \nd Onyenwe anyị\nd* ga-eme ka ị bụrụ isi, ọ bụghị ọdụdụ. Ọ bụrụ na ị ṅaa ntị nʼiwu ndị a \nd Onyenwe anyị\nd* Chineke gị na-enye gị taa, lezie anya ịgbaso ha, ị ga-anọgide nʼelu, ị gaghị anọ nʼokpuru.  
\v 14 Ewezugala onwe gị site nʼiwu niile ndị a m na-enye gị taa, maọbụ gaa nʼaka nri maọbụ nʼaka ekpe, ịgbaso chi ndị ọzọ na ife ha ofufe. 
\s1 Nnupu isi na ọbụbụ ọnụ 
\p  
\v 15 Ma otu ọ dị, ọ bụrụ na ị jụ irubere \nd Onyenwe anyị\nd* Chineke gị isi, jụkwa ilezi anya, gbasoo iwu ya na ụkpụrụ ya niile, nke m na-enye gị taa, ọbụbụ ọnụ ndị a ga-adakwasị gị. 
\pm  
\v 16 Ị ga-abụ onye a bụrụ ọnụ nʼobodo, bụrụ onye a bụrụ ọnụ nʼala ubi, 
\pm  
\v 17 Abọ gị na ihe ịgwọ achịcha gị ga-abụ ihe a bụrụ ọnụ. 
\pm  
\v 18 Ihe a bụrụ ọnụ ka mkpụrụ nke afọ gị ga-abụ, ihe a bụrụ ọnụ ka mkpụrụ nke ala gị ga-abụ, ya na ụmụ nke igwe anụ ụlọ gị, na ụmụ ehi gị na nke igwe ewu na atụrụ gị mụrụ. 
\pm  
\v 19 Onye a bụrụ ọnụ ka ị ga-abụ mgbe ị na-abata abata na mgbe ị na-apụ apụ. 
\p  
\v 20 \nd Onyenwe anyị\nd* ga-ezidata nʼisi gị ọbụbụ ọnụ, na ọgbaaghara, tinyere nkọcha nʼihe niile nke i tinyere aka gị, tutu ruo mgbe ị ghọrọ onye e bibiri ebibi bụrụ onye lara nʼiyi na mberede, nʼihi ihe ọjọọ niile i mere site nʼịhapụ m.  
\v 21 \nd Onyenwe anyị\nd* ga-ezite ajọ ọrịa nʼetiti gị tutu ruo mgbe a ga-ekpochapụ gị site nʼala ahụ ị gaje ịba nʼime ya inweta.  
\v 22 \nd Onyenwe anyị\nd* ga-eti unu ọrịa na-eripịa eripịa, ahụ ọkụ na ọrịa na-aza anụ ahụ, oke okpomọkụ na mma agha, ụkọ mmiri ozuzo na ọrịa na-eripịa ihe ubi, na ọmụma ebu ga-abịakwasị gị tutu ruo mgbe i lara nʼiyi.  
\v 23 Mbara eluigwe nke ị na-ahụ anya ga-aghọ bronz, ala ị na-azọkwasị ụkwụ gị ga-aghọ igwe.  
\v 24 \nd Onyenwe anyị\nd* ga-eme ka mmiri kwesiri izo nʼala gị ghọọ uzuzu na aja. Ha ga-esi na mbara eluigwe na-ezodata nʼala tutu ruo mgbe ị lara nʼiyi. 
\p  
\v 25 \nd Onyenwe anyị\nd* ga-eme ka ndị iro gị merie gị nʼagha. Ị ga-esi otu ụzọ pụta ibuso ha agha, ma ị ga-esi ụzọ asaa gbalaga. Ị ga-aghọrọ ndị ụwa ihe a na-asọ oyi mgbe ha hụrụ ihe dakwasịrị gị.  
\v 26 Ozu unu ga-aghọrọ ụmụ anụ ufe niile na anụ ọhịa niile ihe oriri. O nwekwaghị onye ga-anọ menye ha egwu chụpụ ha.  
\v 27 \nd Onyenwe anyị\nd* ga-ezite etuto ndị Ijipt ka ha bịakwasị gị, ya na ọnya, na agba, na ọkọ. Ọ dịkwaghị ihe a ga-eji gwọọ ha.  
\v 28 \nd Onyenwe anyị\nd* ga-ezitere gị isi mgbaka, na ikpu ìsì, na ọgbaaghara nke obi.  
\v 29 Ị ga-asọgharị isi nʼetiti ehihie dịka onye kpuru ìsì nʼasọgharị nʼọchịchịrị. Ọ dịghị ihe ọbụla ga-agara gị nke ọma. Site nʼụbọchị ruo nʼụbọchị, ị ga-abụ onye a na-emegbu emegbu, na onye a na-anapụ ihe ya nʼike oge niile, na-enweghị onye ga-anapụta gị. 
\p  
\v 30 Gị na nwanyị ga-enwe nkwekọrịta ịlụ di na nwunye, ma nwoke ọzọ ga-eduru ya dinaa ya nʼike. Ị ga-ewu ụlọ ma ị gaghị ebi nʼime ya. Ị ga-akụ ubi vaịnị ma ị gaghị eri mkpụrụ si na ya.  
\v 31 Nʼihu anya gị ka a ga-egbu ehi gị, ma ị gaghị ata iberibe anụ ya. A ga-anapụ gị ịnyịnya ibu gị nʼihu anya gị ma a gaghị eweghachiri gị ya. Atụrụ gị ka a ga-enye ndị iro gị. Ọ dịkwaghị onye ga-anapụta ha.  
\v 32 A ga-ewere ụmụ gị ndị ikom na ndị inyom nye ndị mba ọzọ. Ọ ga-agụ gị agụụ ogologo oge ka ị hụ ha anya, ma ị pụghị inyere ha aka.  
\v 33 Mba nke ị na-amaghị ga-eri mkpụrụ ubi ị tara ahụhụ kụọ nʼala gị. Ị ga-abụ naanị onye a na-emegbu emegbu na onye a na-akpagbu ụbọchị ndụ gị niile.  
\v 34 Ihe ndị a niile ị ga-eji anya gị hụ ga-eme ka i nwe isi mgbaka.  
\v 35 \nd Onyenwe anyị\nd* ga-eme ka etuto nke na-egbu oke mgbu a na-apụghị ịgwọta agwọta too gị nʼikpere na ogwe ụkwụ gị abụọ, ọ ga-agbasa site nʼọbọ ụkwụ gị abụọ ruo nʼopi isi gị. 
\p  
\v 36 \nd Onyenwe anyị\nd* ga-achụpụ gị na eze ahụ ị họpụtara nye onwe gị, chụpụ gị nye mba ọzọ, ebe gị na nna nna gị ha, na-amaghị. Nʼebe ahụ, ị ga-efe chi ndị ọzọ nke e ji osisi na nkume kpụọ.  
\v 37 Ị ga-abụ ihe iju anya, na ihe e ji atụ ilu, na ihe akụkọ, nʼetiti mba ahụ niile \nd Onyenwe anyị\nd* ga-achụga gị. 
\p  
\v 38 Ị ga-akụ ọtụtụ mkpụrụ nʼubi ma ị ga-aghọta ntakịrị mkpụrụ, nʼihi na igurube ga-ericha ihe ị kụrụ nʼubi.  
\v 39 Ị ga-akọ ubi vaịnị lekọtakwa ya anya, ma ị gaghị aracha mkpụrụ ya maọbụ ṅụọ mmanya si na ya, nʼihi na ikpuru ga-eri ha.  
\v 40 Osisi oliv ga na-eto ebe niile, ma mmanụ oliv agaghị adị nke ị ga-ete nʼahụ nʼihi na mkpụrụ oliv ga-adasịsị na-akaghị aka oge ha mara ifuru.  
\v 41 Ị ga-amụta ụmụ ndị ikom na ndị inyom ma ha agaghị adịgide nʼihi na a ga-adọta ha nʼagha.  
\v 42 Igwe igurube ga-erichasị osisi niile dị nʼubi gị, ya na ihe ị kụrụ nʼubi gị. 
\p  
\v 43 Onye ọbịa bi nʼetiti gị ga-aba ụba karịa gị. Ihe ga na-agara ya nke ọma, ma ihe ga na-ajọrọ gị njọ.  
\v 44 Ọ ga-ebinye gị ihe, ọ bụkwaghị gị ga-ebinye ya! Ọ ga-abụ isi ma ị ga-abụ ọdụdụ. 
\p  
\v 45 Ọbụbụ ọnụ ndị a niile ga-abịakwasị gị. Ha ga-achụso gị ọsọ, chụkwute gị tutu ruo mgbe a lara gị nʼiyi, naanị nʼihi na ị jụrụ irubere \nd Onyenwe anyị\nd* Chineke gị isi, na idebe iwu na ụkpụrụ ndị a o nyere gị.  
\v 46 Ha ga-abụ ihe ịrịbama na ihe ebube nye gị, na mkpụrụ gị niile, ruo mgbe ebighị ebi.  
\v 47 Nʼihi na ị jụrụ iji ọṅụ na obi ụtọ fee \nd Onyenwe anyị\nd* Chineke gị nʼoge ihe na-agara gị nke ọma.  
\v 48 Ya mere, nʼọnọdụ agụụ na akpịrị ịkpọ nkụ, nʼọnọdụ ịgba ọtọ na ụkọ ka ị ga-efe ndị iro ahụ \nd Onyenwe anyị\nd* na-ezite imegide gị. Ọ ga-anyakwasị yoku igwe nʼolu gị ruo mgbe ọ lara gị nʼiyi. 
\p  
\v 49 \nd Onyenwe anyị\nd* ga-eme ka mba si nʼebe dị anya na nsọtụ ụwa, bịakwasị gị, imegide gị. Mba a ga-adị gara gara dịka ugo, ọ ga-abụkwa mba ị na-amaghị asụsụ ha,  
\v 50 Mba na-enweghị ihu ọchị nke na-adịghị asọpụrụ okenye maọbụ were ihuọma leta ụmụntakịrị.  
\v 51 Ha ga-erichapụ mkpụrụ nke anụ ụlọ gị niile na mkpụrụ nke ihe ubi gị niile tutu ruo mgbe ị ghọrọ ihe e bibiri ebibi. O nwekwaghị ihe ga-afọdụrụ gị, maọbụ ọka, maọbụ mmanya ọhụrụ maọbụ mmanụ oliv, maọbụ ụmụ ehi maọbụ ewu na atụrụ gị mụrụ, ruo mgbe e mere ka ị laa nʼiyi.  
\v 52 Mba ahụ ga-anọchigide obodo ndị ahụ niile dị nʼala gị tutu ruo mgbe mgbidi ndị ahụ niile e wusiri ike, nke ị na-atụkwasị obi dara. Ọ ga-anọchigide ndị ahụ niile dị nʼala ahụ niile \nd Onyenwe anyị\nd* Chineke gị na-enye gị. 
\p  
\v 53 Ị ga-erikwa anụ ahụ ụmụ gị ndị ikom na ndị inyom ndị \nd Onyenwe anyị\nd* Chineke gị nyere gị nʼihi oke nnọchigide nke ndị agha nọchigidere gị na nʼihi oke mkpagbu nke ndị iro.  
\v 54 Ọ bụladị nwoke ahụ dịkasịrịrị nwayọọ na-enwekwa mmetụta mmadụ nʼetiti unu ga-aghọ onye afọ tara mmiri nke ukwuu megide nwanne ya nwoke, maọbụ nwunye nke ọ hụrụ nʼanya, maọbụ ụmụ ya, ndị ka dị ndụ.  
\v 55 Ọ gaghị enye onye ọbụla nʼime ha ụfọdụ nʼime anụ ahụ ụmụ ndị ọ na-eri, nʼihi na ọ bụ naanị ya bụ ihe oriri fọdụrụ ya, nʼihi ahụhụ nke nnọchi ndị iro nọchiri ọnụ ụzọ obodo gị niile butere.  
\v 56 Nwanyị nke dịkarịsịrị nwayọọ na-enwekwa mmetụta mmadụ nʼetiti unu, nke dị oke nwayọọ, nke ihe na-emetụta na ọ dịghị amasị ya ịzọgịdesị ọbụ ụkwụ ya ike nʼala, ga-ajụ ikenye di ya ọ hụrụ nʼanya, nwa ya nwoke maọbụ nwa ya nwanyị,  
\v 57 ọ bụladị akpanwa si nʼetiti ụkwụ ya pụta na ụmụ ọhụrụ ọ mụrụ. Nʼọnọdụ ọjọọ nʼoke ụkọ ya, ọ chọrọ iri ha na nzuzo, nʼihi ahụhụ nke ndị iro gị mere ka ọ bịakwasị gị nʼoge nnọchigide nke obodo gị niile. 
\p  
\v 58 Ọ bụrụ na i lezighị anya gbasoo okwu iwu niile e dere nʼime akwụkwọ a, ọ bụrụ na ị sọpụrụghị aha a dị ebube na nke dị egwu, bụ \nd Onyenwe anyị\nd* Chineke gị,  
\v 59 \nd Onyenwe anyị\nd* ga-ezitere gị na ụmụ ụmụ gị ihe otiti dị oke egwu, oke mbibi nke ga-adị ogologo oge, na ọrịa dị oke njọ nke na-adịghị ala ala.  
\v 60 Ọ ga-ezitere gị ọrịa ndị ahụ niile dị nʼIjipt, nke ị na-atụ ụjọ ha, ha ga-arapara gị nʼahụ.  
\v 61 Ọ bụghị naanị nke a! \nd Onyenwe anyị\nd* ga-eme ka ụdị ọrịa ọbụla, na ụdị ihe otiti ọbụla, ọ bụladị ndị na-adịghị nʼime Akwụkwọ Iwu a, bịakwasị gị, tutu ruo mgbe a ga-ekpochapụ gị.  
\v 62 Ọ bụ ezie na ị dị ukwuu nʼọnụọgụgụ dịka kpakpando nke eluigwe, maọbụ naanị mmadụ ole na ole nʼime gị ga-afọdụ. Ihe ndị a niile ga-emezu nʼihi na i geghị ntị nʼolu \nd Onyenwe anyị\nd* bụ Chineke gị.  
\v 63 Dịka mmụba ị mụbara nʼọnụọgụgụ, na ịdị ukwuu nke akụnụba gị si bụrụ ihe nyere \nd Onyenwe anyị\nd* obi ụtọ, otu a ka ọ ga-esi tọkwaa ya ụtọ ibibi gị, na ime ka ị daa ụkpa. Ọ ga-esi nʼala ahụ ị na-aga inweta hopu gị. 
\p  
\v 64 Nʼihi na \nd Onyenwe anyị\nd* ga-eme ka ị gbasasịa nʼetiti mba niile, site nʼotu nsọtụ ụwa ruo na nsọtụ nke ọzọ. Nʼebe ahụ, ị ga-efekwa chi ndị ọzọ, nke gị, maọbụ nna nna gị ha, na-amaghị, chi e ji osisi na nkume kpụọ.  
\v 65 Nʼetiti mba ndị a, obi agaghị eru gị ala, ọbụ ụkwụ gị agaghị enwe ebe izuike. Nʼebe ahụ, \nd Onyenwe anyị\nd* ga-enye gị mkpụrụobi na-ama jijiji, anya nke ike gwụrụ nʼihi enweghị olileanya, na obi na-ada mba.  
\v 66 Ndụ gị ga-ekonye nʼelu nʼihi oke egwu. Ị ga-anọ nʼegwu, ehihie na abalị, ị gaghị ejikwa ndụ gị nʼaka.  
\v 67 Nʼụtụtụ, ị ga-asị, “Ewoo, a sịkwa na ugbu a bụ uhuruchi!” Nʼuhuruchi ị ga-asịkwa, “Ewoo, a sịkwarị na ugbu a bụ ụtụtụ!” Ị ga-ekwu ihe ndị a nʼihi ihe egwu juru gị obi, na nʼihi ihe ndị ahụ niile anya gị na-ahụ.  
\v 68 \nd Onyenwe anyị\nd* ga-eme ka i soro ụgbọ mmiri lọghachi nʼIjipt, nʼije ahụ m kwuru na ị gaghị ejekwa ọzọ. Nʼebe ahụ ị ga-ewere onwe gị resi ndị iro gị dịka ohu ndị ikom maọbụ ndị inyom, ma ọ dịghị onye ga-achọ ịzụ gị. 
\c 29  
\s1 Imesi ọgbụgba ndụ ike 
\p  
\v 1 Ndị a bụ okwu nke ọgbụgba ndụ ahụ \nd Onyenwe anyị\nd* nyere Mosis nʼiwu ka ya na ụmụ Izrel gbaa nʼala Moab na-agbanweghị ọgbụgba ndụ ahụ ya na ha gbara nʼugwu Horeb. 
\p  
\v 2 Mosis kpọkọtara ụmụ Izrel niile gwa ha okwu sị, 
\b  
\p Unu ji anya unu hụ ihe \nd Onyenwe anyị\nd* mere nʼIjipt megide Fero, na ndị ozi ya, na ala ya niile.  
\v 3 Anya unu hụrụ oke nwale niile, na ihe ịrịbama ndị ahụ, na ọrụ ebube niile ahụ.  
\v 4 Ma tutu ruo taa, \nd Onyenwe anyị\nd* enyebeghị unu obi nwere nghọta, na anya na-ahụ ụzọ, maọbụ ntị na-anụ ihe, nke ga-enyere unu aka ịṅomi ihe ndị a niile.  
\v 5 Ma \nd Onyenwe anyị\nd* na-asị, “Nʼime iri afọ anọ ndị ahụ nke m duuru unu nʼime ọzara, uwe unu emeghị ochie, akpụkpọụkwụ unu akapụghị nʼụkwụ unu.  
\v 6 Ọ dịghị achịcha unu riri, ọ dịkwaghị mmanya maọbụ ihe ọṅụṅụ na-aba nʼanya unu ṅụrụ. E mere m ihe ndị a ime ka unu mata na mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke unu.” 
\p  
\v 7 Mgbe unu rutere ebe a, Saịhọn, eze ndị Heshbọn, na Ọg, eze ndị Bashan, pụtara ibuso anyị agha, ma anyị lụgburu ha.  
\v 8 Anyị weere ala ha nye agbụrụ Ruben, na Gad, na otu ọkara ebo Manase, dịka ihe nketa ha. 
\p  
\v 9 Nʼihi ya, lezie anya idebe ụkpụrụ niile nke ọgbụgba ndụ a, ka ihe niile unu na-eme gaara unu nke ọma.  
\v 10 Unu niile, ndị ndu unu, na ndịisi unu, na okenye, na ndịisi ọchịchị, na ndị ikom niile nke Izrel, unu ndị guzo nʼihu \nd Onyenwe anyị\nd* Chineke taa,  
\v 11 na ụmụntakịrị unu, na ndị nwunye unu, na ndị ọbịa bi nʼetiti unu, ndị na-egburu unu nkụ, na ndị na-echukwara unu mmiri.\f + \fr 29:11 \ft Nke a bụ ọrụ nleda anya nke ndị bụ ohu na-arụ. \xt Jos 9:21,23,27\f* 
\v 12 Unu guzo nʼebe a taa ka unu na \nd Onyenwe anyị\nd* Chineke gbaa ndụ. Unu guzokwa, maka ọgbụgba ndụ a unu na \nd Onyenwe anyị\nd* na-agba taa, nke e ji ịṅụ iyi mesie ike,  
\v 13 ime ka ọ pụta ìhè nye unu taa na unu bụ ndị nke ya, imekwa ka unu mata na ọ bụ Chineke unu, dịka o kwere nna nna unu ha, Ebraham, na Aịzik, na Jekọb na nkwa.  
\v 14 Ọgbụgba ndụ a nke ya na ịṅụ iyi so nke m na-eme ka ọ dịrị abụghị naanị nʼihi unu,  
\v 15 ndị soro anyị guzo nʼebe a taa, nʼihu \nd Onyenwe anyị\nd* Chineke anyị, kama ọ bụkwa nʼihi ndị ahụ na-anọghị nʼebe a. 
\p  
\v 16 Unu onwe unu maara otu anyị si bie nʼala Ijipt, na otu anyị si gafee mba ndị ahụ niile anyị gafere nʼụzọ.  
\v 17 Unu hụrụ nʼetiti ha ihe arụ ha niile, na arụsị niile e ji osisi, na nkume na ọlaọcha, na ọlaedo kpụọ.  
\v 18 Lezienụ anya ka unu hụ na obi onye ọbụla nʼime unu, nwoke maọbụ nwanyị, agbụrụ maọbụ ebo ọbụla nʼIzrel, esighị nʼebe \nd Onyenwe anyị\nd* bụ Chineke anyị nọ pụọ, bido chewe echiche ife chi ndị mba ọzọ ndị a niile. Lezienụ anya hụ na mgbọrọgwụ na-ewepụta nsi na-elu ilu dị otu a adịghị nʼetiti unu. 
\p  
\v 19 Mgbe onye dị otu a nụrụ okwu ịṅụ iyi a, na ha ga-agọzi onwe ha, na-eche, “Ihe ga-agara m nke ọma, ọ bụ ezie na m nọgidere na-agbaso ụzọ isiike m.” Ha ga-eweta mbibi nye ala a gbara mmiri nke ọma nyekwa ala ahụ kpọrọ nkụ.  
\v 20 Nʼihi na \nd Onyenwe anyị\nd* agaghị agbaghara onye dị otu a! Iwe ya, na ekworo ya, ga-adị ọkụ megide nwoke ahụ. Ọbụbụ ọnụ niile e dere nʼime akwụkwọ a ga-abịakwasịkwa ya. \nd Onyenwe anyị\nd* ga-ehichapụkwa aha ya, ka a ghara ịnụkwa ihe banyere ya nʼụwa.  
\v 21 \nd Onyenwe anyị\nd* ga-akpa oke nʼetiti ya na ebo niile nke Izrel, maka iwetara ya mbibi, dị ka ọbụbụ ọnụ niile nke ọgbụgba ndụ nke e dere nʼime Akwụkwọ Iwu a si dị. 
\p  
\v 22 Mgbe ahụ, ụmụ unu ndị ga-eso unu nʼọgbọ ndị dị nʼihu, na ndị ọbịa si ebe dị anya bịa, ga-ahụ oke ihe otiti ọjọọ a bịakwasịrị ala a, ya na ọrịa niile \nd Onyenwe anyị\nd* mere ka ọ bịakwasị ya.  
\v 23 Ala ahụ niile ga-abụ ala nnu, nke ọkụ repịara, ala nke a na-adịghị akụ ihe ọbụla nʼime ya, ala na-adịghị amị mkpụrụ, nke ahịhịa na-adịghị epu nʼelu ya. Ala dịka ala Sọdọm na Gọmọra, na Adma, na Zeboiim, nke \nd Onyenwe anyị\nd* sitere nʼoke iwe ya mebie.  
\v 24 Mba niile ga-ajụ sị, “Gịnị mere \nd Onyenwe anyị\nd* ji mee ihe dị otu a nʼala a? Gịnị kpatara oke iwe ọkụ a?” 
\p  
\v 25 Ọsịsa ya ga-abụ, “Ọ bụ nʼihi na ndị a hapụrụ idebe ọgbụgba ndụ ha na \nd Onyenwe anyị\nd*, Chineke nke nna nna ha gbara, ọgbụgba ndụ ha na ya gbara mgbe o mere ka ha site nʼIjipt pụta.  
\v 26 Nʼihi na ha fere chi ndị ọzọ ofufe, kpọọkwa isiala nye ha, bụ chi ndị nke ha na-amaghị, chi ndị nke ọ na-enyeghị ha.  
\v 27 Ọ bụ ya mere iwe \nd Onyenwe anyị\nd* ji dị ọkụ megide ala a, meekwa ka o zidata nʼisi ha ọbụbụ ọnụ niile e dere nʼime akwụkwọ a.  
\v 28 Nʼoke iwe ya na ọnụma ya ka \nd Onyenwe anyị\nd* ji hopu ha site nʼala ha, werekwa ha tụba nʼala ọzọ, dịka ọ dị ugbu a.” 
\p  
\v 29 Ihe niile e zoro ezo dịrị \nd Onyenwe anyị\nd* Chineke anyị, ma ihe ndị ahụ niile e kpughere ekpughe dịịrị anyị, dịkwara ụmụ anyị ruo mgbe ebighị ebi, ka anyị nwee ike ịgbaso na imezu okwu niile nke iwu a. 
\c 30  
\s1 Ịbịaghachikwute \nd Onyenwe anyị\nd* na ngọzị ya 
\p  
\v 1 Mgbe ihe ndị a niile ga-emezu nʼebe unu nọ, ya bụ, ngọzị niile na ọbụbụ ọnụ niile m gụpụtara nʼihu unu, ọ bụrụ na unu ga na-atụgharị uche na ha nʼetiti mba ndị ahụ \nd Onyenwe anyị\nd* Chineke unu ga-achụba unu,  
\v 2 ọ bụrụkwa na unu ekpebie nʼobi unu nʼoge ahụ ịlọghachikwute \nd Onyenwe anyị\nd* Chineke unu, ọ bụrụ na unu, na ụmụ unu ga-eji obi unu niile na mmụọ unu niile mezuo iwu ndị a niile m nyere unu taa.  
\v 3 Mgbe ahụ, \nd Onyenwe anyị\nd* bụ Chineke unu ga-anapụta unu. Ọ ga-enwe obi ebere nʼebe unu nọ kpọkọtakwa unu site na mba niile ebe ọ chụsasịrị unu.  
\v 4 A sịkwarị na ọ bụ nʼala dị na nsọtụ ụwa nʼokpuru eluigwe ka a chụgara unu, nʼebe ahụ \nd Onyenwe anyị\nd* bụ Chineke gị ga-achịkọta unu, kpọghachitekwa unu.  
\v 5 \nd Onyenwe anyị\nd* bụ Chineke unu ga-akpọlata unu nʼala ahụ bụ nke nna nna unu ha. Unu ga-enwetakwa ya, ọ ga-eme ka ihe gara unu nke ọma, meekwa ka unu baa ụba karịa nna nna unu ha.  
\v 6 \nd Onyenwe anyị\nd* bụ Chineke unu ga-ebi obi unu, na obi ụmụ unu, na nke ụmụ ụmụ unu ugwu, ka unu were obi unu niile na mmụọ unu niile, hụ ya nʼanya, ma dịkwa ndụ.  
\v 7 \nd Onyenwe anyị\nd* bụ Chineke unu ga-eme ka ọbụbụ ọnụ ndị a bịakwasị ndị iro unu, ndị kpọrọ unu asị na ndị na-akpagbu unu.  
\v 8 Unu ga-emesịakwa rubere \nd Onyenwe anyị\nd* isi, gbasookwa iwu ya niile nke m na-enye unu taa.  
\v 9 Mgbe ahụ, \nd Onyenwe anyị\nd* bụ Chineke unu ga-eme ka unu babiga ụba oke nʼọrụ niile nke aka unu, nʼime mkpụrụ nke afọ, nʼime mkpụrụ nke anụ ụlọ gị, na mkpụrụ nke ala ubi gị. Obi ga-atọkwa \nd Onyenwe anyị\nd* ụtọ ọzọ, ime gị ka ị baa ụba dịka ọ tọrọ ya nʼebe nna unu ha nọ.  
\v 10 Ma ọ bụrụ na unu erubere \nd Onyenwe anyị\nd* bụ Chineke unu isi, debekwa iwu ya na ụkpụrụ ya niile nke e dere nʼAkwụkwọ iwu a, jirikwa obi unu niile na mmụọ unu niile bịaghachikwute \nd Onyenwe anyị\nd* bụ Chineke unu. 
\s1 Ndụ maọbụ ọnwụ 
\p  
\v 11 Idebe iwu ndị a m na-enye unu taa abụghị ọrụ sịrị ike, ọ bụkwaghị ihe karịrị unu ike ime.  
\v 12 Nʼihi na iwu ndị a adịghị nʼeluigwe nke ị ga-eji sị, “Onye ga-arịgo nʼeluigwe wedatara m ya ka m nụ ihe ọ na-ekwu, ma debekwa ya.”  
\v 13 Iwu a adịghịkwa nʼofe ọzọ nke oke osimiri, nke ị ga-eji sị, “Onye ga-agafe ga weta ya, kpọsaa ya nye anyị ka anyị nụ, ma debekwa ihe ọ na-ekwu?”  
\v 14 Mba, okwu ahụ dị gị nso, ọ dị gị nʼọnụ, dịrịkwa nʼobi gị, ka i nwee ike idebe ha. 
\p  
\v 15 Lee, edoola m nʼihu gị taa ndụ na ọganihu, ọnwụ na ịla nʼiyi.  
\v 16 Enyela m gị iwu taa, sị gị hụ \nd Onyenwe anyị\nd* bụ Chineke gị nʼanya, ana m asịkwa gị gbasoo ụzọ ya, ma debekwa iwu na ụkpụrụ ya niile, ka ị dịrị ndụ, ghọọkwa mba buru ibu, ka \nd Onyenwe anyị\nd* bụ Chineke gị gọzie gị nʼala ahụ ị na-aga inweta. 
\p  
\v 17 Ma ọ bụrụ na obi gị e si nʼiso ya tụgharịa, ọ bụrụkwa na ị jụ ige ntị, ọ bụrụ na a dọkpụfuo gị mee ka i fee chi ndị ọzọ ofufe ma ịkpọ isiala nye ha,  
\v 18 agwala m gị hoohaa taa, na ị ga-ala nʼiyi, ị gaghị enwe ogologo ndụ nʼala ahụ ị na-agafe osimiri Jọdan inweta. 
\p  
\v 19 Ana m akpọku eluigwe na ụwa\f + \fr 30:19 \ft \xt Dit 4:26; 8:19\f* taa ka ha bụrụ ndị akaebe m, na edebela m nʼihu gị ọnwụ na ndụ, debekwa nʼihu gị ngọzị na ọbụbụ ọnụ. Ugbu a, họrọ ndụ, ka gị na ụmụ gị dị ndụ  
\v 20 ka ị hụ \nd Onyenwe anyị\nd* bụ Chineke gị nʼanya, ṅaa ntị nʼolu ya, daberekwa na ya. Nʼihi na \nd Onyenwe anyị\nd* bụ ndụ gị, ọ ga-enye gị ụbọchị ndụ gị niile nʼala ahụ o kwere nkwa ị nye nna nna gị ha Ebraham, na Aịzik, na Jekọb. 
\c 31  
\s1 Joshua anọchie anya Mosis 
\p  
\v 1 Mgbe Mosis gwachara ụmụ Izrel okwu ndị a niile,  
\v 2 ọ gwakwara ha okwu ọzọ sị, “Ugbu a, agbaala m otu narị afọ na iri afọ abụọ! Enwekwaghị m ike idu unu, nʼihi na \nd Onyenwe anyị\nd* agwala m sị, Ị gaghị agafe osimiri Jọdan.  
\v 3 \nd Onyenwe anyị\nd* Chineke gị nʼonwe ya ga-ebu gị ụzọ gabiga osimiri a. Ọ ga-ebibi mba niile ndị a nʼihu gị. Ị ga-enwetakwa ala ha. Joshua ga-edu gị gabiga osimiri a, dịka \nd Onyenwe anyị\nd* kwuru.  
\v 4 \nd Onyenwe anyị\nd* ga-emekwa ha ihe o mere Saịhọn na Ọg, bụ eze ndị Amọrait, ndị o kpochapụrụ ha na ala ha.  
\v 5 \nd Onyenwe anyị\nd* ga-enyefe ndị bi nʼebe ahụ nʼaka unu, unu ga-ekpochapụkwa ha dịka m nyere unu nʼiwu.  
\v 6 Dịnụ ike! Nweenụ obi ike! Unu atụla ha egwu! Nʼihi na \nd Onyenwe anyị\nd* Chineke unu ga-anọnyere unu. Ọ gaghị agbakụta unu azụ, ọ gakwaghị ahapụ unu.” 
\p  
\v 7 Mgbe ahụ, Mosis kpọrọ Joshua, gwa ya okwu nʼihu ụmụ Izrel, sị ya, “Dị ike! Nwee obi ike! Nʼihi na ọ bụ gị ga-edu ndị a baa nʼala ahụ \nd Onyenwe anyị\nd* ṅụrụ iyi inye nna nna ha, ị ga-emekwa ka ha keta ala a dịka ihe nketa ha.  
\v 8 \nd Onyenwe anyị\nd* nʼonwe ya ga-eburu gị ụzọ, ọ ga-anọnyekwara gị, ọ gaghị ahapụ gị maọbụ gbakụta gị azụ. Atụla egwu, adala mba.” 
\s1 Ngụpụta akwụkwọ iwu 
\p  
\v 9 Mgbe ahụ, Mosis depụtara iwu ndị ahụ niile nʼakwụkwọ, were ya nye ndị nchụaja, ụmụ Livayị, ndị na-ebu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* ahụ. Mosis nyekwara ndị okenye Izrel akwụkwọ a e dere iwu niile.  
\v 10 Mgbe ahụ, Mosis nyere ha iwu sị, “Na ngwụcha afọ asaa ọbụla, nʼafọ ahụ a na-akagbu ụgwọ niile, nʼoge a na-eme Mmemme ụlọ Ikwu,  
\v 11 mgbe Izrel niile ga-abịa nʼihu \nd Onyenwe anyị\nd* bụ Chineke unu, nʼebe ahụ ọ ga-ahọpụta, ị ga-agụpụta ihe a site nʼakwụkwọ iwu a nʼihu mmadụ niile ka ha nụrụ ya.  
\v 12 Kpọkọta mmadụ niile nʼotu ebe, ndị ikom, na ndị inyom na ụmụntakịrị,\f + \fr 31:12 \ft Ọ bụ naanị na mmemme nke a, ka a na-akpọkọta ndị inyom na ụmụntakịrị, ka ha bịa nụrụ ihe a na-agụpụta site nʼakwụkwọ iwu ahụ.\f* na ndị ọbịa bi nʼetiti obodo unu, ka ha nụrụ, ma mụta ịtụ egwu \nd Onyenwe anyị\nd* Chineke unu na ilezi anya ịgbaso okwu niile dị nʼiwu a.  
\v 13 Ụmụntakịrị ha, ndị na-amabeghị iwu ndị a, aghaghị ịnụ na ịmụta ịtụ egwu \nd Onyenwe anyị\nd* Chineke unu, ụbọchị ndụ unu niile nʼala ahụ unu na-agafe Jọdan inweta.” 
\s1 Okwu ikpeazụ Onyenwe anyị gwara Mosis 
\p  
\v 14 \nd Onyenwe anyị\nd* gwara Mosis sị, “Lee, ụbọchị ọnwụ gị na-abịaru nso. Kpọrọ Joshua ka gị na ya soro bịa nʼụlọ nzute ebe m ga-anọ nye ya ọrụ ọ ga-arụ.” Mosis na Joshua sooro bịa guzo onwe ha nʼọnụ ụzọ ụlọ nzute. 
\p  
\v 15 Mgbe ahụ, \nd Onyenwe anyị\nd* gosiri ha onwe ya nʼime ogidi igwe ojii nke guzochiri ọnụ ụzọ ụlọ nzute ahụ.  
\v 16 \nd Onyenwe anyị\nd* gwara Mosis okwu sị, “Ị ga-anwụ, jekwuru nna nna gị ha. Mgbe ị nwụrụ, ndị a ga-amalite ife chi ọzọ ofufe ndị dị nʼala ahụ ha na-abanye. Ha ga-agbakụta m azụ, mebie ọgbụgba ndụ mụ na ha gbara.  
\v 17 Nʼụbọchị ahụ, iwe m ga-adị ọkụ megide ha, aga m agbakụta ha azụ, zoo ihu m nʼebe ha nọ. A ga-alakwa ha nʼiyi. Ọdachi na ahụhụ dị iche iche ga-abịakwasị ha, nke ga-eme ka ha sị, ‘Chineke anyị anọkwaghị nʼetiti anyị, ọ bụ ya mere ọdachi ndị a ji bịakwasị anyị.’  
\v 18 Aga m echepụ ihu m site nʼebe ha nọ nʼụbọchị ahụ, nʼihi ajọ omume ha nke ife chi ọzọ ofufe. 
\p  
\v 19 “Ugbu a, depụtaranụ onwe unu abụ a nʼakwụkwọ, kuziekwara ya ụmụ Izrel, ka ọ bụrụ ihe akaebe m megide ha.  
\v 20 Mgbe m mere ka ha bata nʼala ahụ m kwere nna nna ha na nkwa, ala ahụ mmiri ara ehi na mmanụ aṅụ na-erugharị nʼime ya, mgbe ha rijukwara afọ, baakwa ụba, ha ga-ebido ife chi ọzọ ofufe, jụ m, ma mebikwaa ọgbụgba ndụ m.  
\v 21 Ma mgbe ọtụtụ ihe ọdachi na ahụhụ ga-abịakwasị ha, abụ a ga-eme ka ha cheta ihe mere nsogbu ha niile ji bịakwasị ha, nʼihi na abụ a ga-adịgide site nʼọgbọ ruo nʼọgbọ. Amaara m nke ọma ugbu a, ọ bụladị tupu ha abanye nʼala ahụ m kwere nkwa inye ha site nʼịṅụ iyi, ụdị mmadụ ha bụ.”  
\v 22 Ya mere, nʼụbọchị ahụ, Mosis dere abụ ahụ, kuziekwara ya ụmụ Izrel. 
\p  
\v 23 Mgbe ahụ \nd Onyenwe anyị\nd* nyere Joshua nwa Nun iwu sị ya, “Dị ike, nwee obi ike, ị ghaghị ịkpọbata ụmụ Izrel nʼala ahụ m sitere nʼịṅụ iyi kwee ha na nkwa. Mụ onwe m ga-anọnyere gị.” 
\p  
\v 24 Mgbe Mosis dechara okwu niile nke iwu ndị a nʼakwụkwọ, site na mbido ruo nʼọgwụgwụ,  
\v 25 o nyere ndị Livayị na-ebu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* iwu sị ha,  
\v 26 “Werenụ Akwụkwọ Iwu a tinye ya nʼakụkụ igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* Chineke unu, ka ọ bụrụ ihe ịgba ama megide unu.  
\v 27 Nʼihi na amaara m na unu bụ ndị nnupu isi, na ndị isiike. Lee, ọ bụladị taa m nọ ndụ nʼetiti unu, unu na-enupu isi nʼebe \nd Onyenwe anyị\nd* nọ, unu ga-esi aṅaa ghara inupu isi mgbe m nwụrụ?  
\v 28 Kpọkọtaanụ ndị okenye unu niile, na ndị ọchịchị agbụrụ unu niile, ka m kwupụta okwu ndị a mgbe ha na-anụ ya. Ka m kpọkuokwa eluigwe na ụwa ka ha gbaa ama megide ha.  
\v 29 Nʼihi na amaara m na mgbe m nwụrụ, unu ga-aghọ ndị rụrụ arụ nke ukwuu, unu ga-ewezuga onwe unu site nʼebe iwu ndị ahụ m nyere unu dị. Amakwaara m na nʼụbọchị ndị ahụ na-abịa, ihe ọjọọ ga-adakwasị unu, nʼihi ihe ọjọọ niile unu mere nʼihu \nd Onyenwe anyị\nd* nke unu ji kpasuo ya iwe site nʼihe ndị ahụ unu ji aka unu kpụọ.” 
\s1 Abụ Mosis 
\p  
\v 30 Ya mere, Mosis gụpụtara okwu niile dị nʼabụ a site na mbido ruo ọgwụgwụ na ntị nzukọ ndị Izrel niile. 
\c 32  
\q1  
\v 1 Gee ntị, gị eluigwe, nụrụ ihe m na-ekwu! 
\q2 Gee ntị, ụwa, nụrụ okwu si m nʼọnụ. 
\q1  
\v 2 Ka okwu m daa dịka mmiri ozuzo 
\q2 ka okwu m daa dịka igirigi, 
\q1 ka ọ daa dịka nshansha mmiri nʼelu ahịhịa, 
\q2 dịka oke mmiri ozuzo nʼahịhịa na-epupụta epupụta. 
\b  
\q1  
\v 3 Aga m eto aha \nd Onyenwe anyị\nd* 
\q2 toonu ịdị ukwuu Chineke anyị! 
\q1  
\v 4 Ọ bụ oke nkume ahụ, ọrụ ya zuruoke, 
\q2 ụzọ ya niile ziri ezi. 
\q1 Chineke kwesiri ntụkwasị obi, nke na-adịghị eme ihe ọjọọ, 
\q2 onye ezi omume na onye ziri ezi ka ọ bụ. 
\b  
\q1  
\v 5 Ha emerụọla onwe ha, ha abụkwaghị ụmụ ya, 
\q2 ha bụ ọgbọ gbagọrọ agbagọ, ndị ụdịdị ha gbanwere agbanwe 
\q1  
\v 6 Ọ bụ otu a ka unu si emeso \nd Onyenwe anyị\nd* 
\q2 unu ndị nzuzu, ndị na-enweghị uche? 
\q1 \nd Onyenwe anyị\nd* ọ bụghị nna unu, onye kere unu, 
\q2 onye kpụrụ unu mee ka unu guzosie ike? 
\b  
\q1  
\v 7 Cheta ụbọchị ochie ndị ahụ gara aga, 
\q2 tulee ọgbọ ndị ahụ gara aga 
\q1 jụọ nna gị, ọ ga-akọrọ gị. 
\q2 Jụọ ndị okenye gị, ha ga-eme ka o doo gị anya. 
\q1  
\v 8 Mgbe Onye kachasị ihe niile elu nyere mba ọbụla ihe nketa nke ha, 
\q2 mgbe o kesara ụmụ mmadụ, 
\q1 mgbe o guzobere oke ala nye ndị niile 
\q2 dịka ọnụọgụgụ ụmụ Izrel si dị. 
\q1  
\v 9 Nʼihi na oke \nd Onyenwe anyị\nd* nwetara bụ ndị ya 
\q2 Jekọb bụ ihe nketa e kenyere ya. 
\b  
\q1  
\v 10 Nʼala dị nʼọzara ka ọ chọtara ya, 
\q2 nʼala tọgbọrọ nʼefu, nke kpọrọ nkụ. 
\q1 O kpuchitere ya, lezie ya anya, 
\q2 o chebere ya dịka ọ bụ mkpụrụ anya ya, 
\q1  
\v 11 dịka ugo nke na-akpọte ụmụ dị nʼakwụ ya, 
\q2 nke na-erugharị nʼelu ụmụ ya, 
\q1 nke na-agbasapụ nku ya ijide ha, 
\q2 nke na-ebu ha na nku ya, 
\q1  
\v 12 \nd Onyenwe anyị\nd* naanị ya duru ya, 
\q2 chi ala ọzọ esokwaghị ya. 
\b  
\q1  
\v 13 O mere ka ọ rịkwasị nʼebe niile dị elu nke ala ahụ, 
\q2 jiri mkpụrụ na-amị nʼala ubi ahụ zụọ ya. 
\q1 O ji mmanụ aṅụ si na nkume zụọ ya, 
\q2 ya na mmanụ si nʼoke nkume, 
\q1  
\v 14 na mmiri ara rahụrụ arahụ nke igwe ehi, na mmiri ara rahụrụ arahụ nke igwe ewu na atụrụ, 
\q2 na ụmụ atụrụ na mkpi gbara abụba, 
\q1 na oke ebule Bashan dị ezi mma, 
\q2 tinyere ezi obi ọka wiiti. 
\q1 Ị ṅụkwara mmanya na-agbọ ụfụfụ, nke bụ ọbara mkpụrụ vaịnị. 
\b  
\q1  
\v 15 Ma Jeshurun mara abụba, ma gbagharịa ụkwụ ya, 
\q2 ebe nri juru ya ọnụ, o buru ibu, maa mma ile anya. 
\q1 Ọ hapụrụ Chineke kpụrụ ya, 
\q2 jụ oke nkume ahụ, bụ Onye Nzọpụta ya. 
\q1  
\v 16 Ha sitere na chi ndị ala ọzọ ha kpasuo ekworo ya, 
\q2 meekwa ka iwe wee ya nʼihi ihe arụ nke arụsị ha. 
\q1  
\v 17 Ha chụrụ aja nye ụmụ mmụọ, ndị na-abụghị Chineke, 
\q2 bụ chi ndị ha na-amaghị, 
\q2 chi ndị ka pụtara ọhụrụ, 
\q2 chi ndị ahụ nna nna ha na-atụghị ụjọ ha. 
\q1  
\v 18 Ị gbakụtara Oke Nkume ahụ mụrụ gị azụ, 
\q2 i chefuru Chineke ahụ mụrụ gị. 
\b  
\q1  
\v 19 \nd Onyenwe anyị\nd* hụrụ ihe dị otu a, jụ ha, 
\q2 nʼihi na ụmụ ya ndị ikom na ndị inyom kpasuru ya iwe. 
\q1  
\v 20 “Aga m ezo ihu m nʼebe ha nọ,” ka o kwuru, 
\q2 “ka m hụ ihe ọnọdụ ikpeazụ ha ga-abụ, 
\q1 nʼihi na ha bụ ọgbọ gbagọrọ agbagọ, 
\q2 ụmụ na-ekwesighị ntụkwasị obi. 
\q1  
\v 21 Ha esitela nʼihe na-abụghị chi kpalie ekworo m, 
\q2 jiri arụsị ha na-abaghị uru mee ka iwe wee m. 
\q1 Mụ onwe m ga-esite na ndị na-abụghị ndị kpalie ekworo ha, 
\q2 sitekwa na mba na-enweghị nghọta kpalie iwe ya. 
\q1  
\v 22 Nʼihi na a mụnyela ọkụ nʼọnụma m, 
\q2 ọkụ ga-enwu ruo ala mmụọ nʼokpuru ụwa. 
\q1 Ọ ga-erepịa ụwa na mkpụrụobi niile, 
\q2 ọ ga-amụnye ọkụ na ntọala ugwu ukwu niile. 
\b  
\q1  
\v 23 “Aga m ekpokwasị mbibi nʼelu ha, 
\q2 zipụ àkụ m niile megide ha. 
\q1  
\v 24 Aga m eziga ọnwụ na-eripịa eripịa megide ha, 
\q2 na ịla nʼiyi nke na-ebibi ebibi, na ọrịa ọjọọ na-egbu egbu. 
\q1 Aga m eziga anụ ọhịa ndị ga-eji eze tapịasịa ha, 
\q2 na ajụala na-akpụ akpụ nʼuzuzu, nke elo ọnwụ dị nʼọnụ ya. 
\q1  
\v 25 Nʼokporoụzọ, mma agha ga-eme ka ha gbara aka ụmụ, 
\q2 nʼime ụlọ ha, ihe oke egwu ga-abịakwasị ha. 
\q1 Ụmụ okorobịa na agbọghọbịa ga-ala nʼiyi, 
\q2 ọ bụladị ụmụntakịrị na ndị agadi isi awọ. 
\q1  
\v 26 Ekwuru m na m ga-achụsasị ha, 
\q2 hichapụ ncheta ọbụla banyere ha nʼetiti ụmụ mmadụ. 
\q1  
\v 27 Ma ihe banyere ịnya isi onye iro tinyere m ụjọ nʼobi, 
\q2 ka onye iro ghara ịghọtahie kwuo sị, 
\q1 ‘Aka anyị ewetarala anyị mmeri, 
\q2 ọ bụghị \nd Onyenwe anyị\nd* mere ihe ndị a niile.’ ” 
\b  
\q1  
\v 28 Ha bụ mba na-enweghị uche, 
\q2 ndị na-enweghị mmụọ nghọta ọbụla nʼime ha. 
\q1  
\v 29 A sịkwarị na ha maara ihe, nwee uche 
\q2 nakwa ịghọta ihe ikpeazụ ha ga-abụ. 
\q1  
\v 30 Kedụ ka otu onye ga-esi chụọ otu puku mmadụ ọsọ, 
\q2 kedụ ka mmadụ abụọ ga-esi chụọ iri puku mmadụ ọsọ, 
\q1 ma ọ bụghị na Oke Nkume ha erefuola ha, 
\q2 ma ọ bụghị na \nd Onyenwe anyị\nd* echepụla ihu ya nʼebe ha nọ? 
\q1  
\v 31 Nʼihi na nkume ha adịghị ka Nkume anyị, 
\q2 dịka ndị iro anyị, nʼonwe ha, jiri ọnụ ha kwuo. 
\q1  
\v 32 Osisi vaịnị ha si nʼosisi vaịnị Sọdọm, 
\q2 na nʼubi dị na Gọmọra 
\q1 mkpụrụ vaịnị ha jupụtara na nsi, 
\q2 ụyọkọ vaịnị ha jupụtara nʼilu ilu. 
\q1  
\v 33 Mmanya vaịnị ha bụ elo agwọ, 
\q2 elo ajụala na-ebute ọnwụ. 
\b  
\q1  
\v 34 “Nke a ọ bụghị ihe m dokọtarala chere oge, 
\q2 chezie ha nke ọma nʼụlọakụ m? 
\q1  
\v 35 Ọ bụ m ka ịbọ ọbọ dịrị m, aga m akwụghachi. 
\q2 Mgbe oge ruru ụkwụ ha ga-agbuchapụ, 
\q1 ụbọchị mbibi ha na-abịa nso, 
\q2 ịla nʼiyi ha chị ọsọ na-abịakwasị ha.” 
\b  
\q1  
\v 36 \nd Onyenwe anyị\nd* ga-ekpe ndị ya ikpe, 
\q2 ọ ga-enwe ọmịiko nʼahụ ndị ohu ya, 
\q1 mgbe ọ hụrụ na ike ha nwere agwụla, 
\q2 mgbe otu onye na-agaghị afọdụ, ohu na onye nwe onwe ya. 
\q1  
\v 37 Ọ ga-asịkwa, “Ugbu a, olee ebe chi niile ha nọ, 
\q2 bụ oke nkume ahụ ha gbabara izere ndụ nʼime ya, 
\q1  
\v 38 chi ndị ahụ riri abụba ihe ịchụ aja ha, 
\q2 ṅụọkwa mmanya ha ji chụọ aja ihe ọṅụṅụ? 
\q1 Ha bilie bịa nyere unu aka! 
\q2 Ha bụrụ ụlọ ndo nye unu!” 
\b  
\q1  
\v 39 “Ugbu a, hụnụ na mụ onwe m abụ m ya! 
\q2 Ọ dịghịkwa chi ọzọ dị ma ọ bụghị m. 
\q1 Mụ onwe m na-eme ka a nwụọ, mụ onwe m na-eme ka a dị ndụ. 
\q2 Mụ onwe m na-etipụ mmadụ ọnya, mụ onwe m na-agwọ ya, 
\q2 mmadụ ọbụla apụghịkwa ịnapụta onye m ji nʼaka m. 
\q1  
\v 40 Ana m eweli aka nʼeluigwe na-ekwupụta nʼịnụ iyi sị, 
\q2 dịka m na-adị ndụ ruo mgbe ebighị ebi, 
\q1  
\v 41 mgbe m mụrụ mma agha m na-egbu amụma, 
\q2 mgbe aka m jidere mma agha ahụ nʼọnọdụ ikpe ikpe, 
\q1 aga m abọ ọbọ megide ndị iro, 
\q2 kwụghachi ndị ahụ niile kpọrọ m asị. 
\q1  
\v 42 Aga m eme ka àkụ m ṅụjuo ọbara afọ, 
\q2 ma mma agha ga-ebibi anụ ahụ, 
\q1 ọbara ndị e gburu egbu, na nke ndị a dọtara nʼagha, 
\q2 na isi ndị ndu ndị iro.” 
\b  
\q1  
\v 43 Ṅụrịanụ ọṅụ mba niile, unu na ndị ya, 
\q2 nʼihi na ọ ga-abọ ọbọ ọbara ndị ohu ya, 
\q1 ọ ga-abọ ọbọ megide ndị iro ya, 
\q2 kpuchiere ala ya na ndị ya mmehie ha. 
\p  
\v 44 Mosis na Joshua\f + \fr 32:44 \fq Joshua \fqa Hosea bụ ụzọ ọzọ e si akpọ aha a\f* nwa Nun soro bịa gụpụta mkpụrụ okwu abụ a na ntị ndị Izrel.  
\v 45 Mgbe Mosis gụpụtachara abụ a nye ndị Izrel,  
\v 46 ọ gwara ha okwu ndị a sị, “Na-atụgharịnụ uche nʼokwu niile m kwupụtara nye unu taa, ka unu si otu a nyefeekwa ya nʼaka ụmụ unu, ka ha onwe ha lezie anya debe okwu niile dị nʼiwu ndị a.  
\v 47 Nʼihi na okwu ndị a abụghị okwu efu, ndụ unu dabeere na ha. Unu debe ha, unu ga-adị ndụ ogologo nʼime ala ahụ unu na-aga inweta nʼofe ọzọ nke osimiri Jọdan.” 
\s1 Ọnwụ Mosis nʼugwu Nebo 
\p  
\v 48 Nʼotu ụbọchị ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị,  
\v 49 “Bilie ga nʼugwu Nebo nke dị nʼetiti ugwu Abarim, nʼala Moab, na ncherita ihu Jeriko, leekwa ala Kenan anya, bụ ala ahụ m na-enye ụmụ Izrel dịka ihe nketa ha.  
\v 50 Mgbe ị hụsịrị ala a, ị ga-anwụ nʼebe ahụ nʼelu ugwu ahụ, lakwurukwa nna nna gị ha, dịka Erọn nwanne gị si nwụọ nʼugwu Hor, lakwuru ha.  
\v 51 Nʼihi na gị na Erọn jụrụ irubere m isi nʼihu ụmụ Izrel, na mmiri Meriba Kadesh, nke dị nʼọzara Zin, unu edoghị m nsọ nʼihu ndị Izrel.\f + \fr 32:51 \ft \xt Ọnụ 20:11-13\f* 
\v 52 Nʼihi ya, ị ga-esite nʼebe dị anya hụ ala ahụ m na-enye ụmụ Izrel, ma ị gaghị aba nʼime ya.” 
\c 33  
\s1 Mosis agọzie ụmụ Izrel 
\p  
\v 1 Nke a bụ ngọzị Mosis, onye nke Chineke, jiri gọzie ụmụ Izrel, tupu ọ nwụọ.  
\v 2 Ọ sịrị, 
\q1 “\nd Onyenwe anyị\nd* si nʼugwu Saịnaị bịa, 
\q2 ọ waliteere ha site nʼugwu Sia, 
\q2 o nwupụtara site nʼugwu Paran 
\q1 Ya na igwe ndị nsọ so bịa 
\q2 site nʼakụkụ ndịda, site nʼala ala ugwu ahụ. 
\q1  
\v 3 Nʼezie, ọ bụ gị na-ahụ ndị mmadụ ahụ nʼanya, 
\q2 ndị nsọ ahụ niile dị gị nʼaka. 
\q1 Nʼụkwụ gị ka ha na-ada kpọọ isiala, 
\q2 gị na-akụziri ha ihe, 
\q1  
\v 4 iwu ahụ Mosis nyere anyị, 
\q2 ihe onwunwe nke ọgbakọ Jekọb. 
\q1  
\v 5 Ọ bụ ya bụ eze na Jeshurun, 
\q2 mgbe ndị ndu ndị mmadụ zukọrọ 
\q2 ha na ebo niile nke Izrel. 
\b  
\q1  
\v 6 “Ka ebo Ruben dịrị ndụ ghara ịnwụ, 
\q2 ma ka ọnụọgụgụ ndị ikom ya dịrị ole na ole.” 
\p  
\v 7 Ihe a ka o kwuru banyere Juda, 
\q1 “Nụrụ, \nd Onyenwe anyị\nd*, akwa Juda, 
\q2 kpọlata ya nʼebe ndị ya nọ. 
\q1 Aka ya ka o ji alụrụ onwe ya ọgụ ichebe ihe o bu nʼuche. 
\q2 Bụụrụ ya onye inyeaka megide ndị iro ya.” 
\p  
\v 8 Banyere Livayị o kwuru sị, 
\q1 “Urim na Tumim gị dịịrị 
\q2 ohu gị ahụ kwesiri ntụkwasị obi. 
\q1 Ị nwara ya ọnwụnwa na Masa, 
\q2 gị na ya sekwara okwu na mmiri Meriba. 
\q1  
\v 9 Onye ahụ lere nne na nna ya anya sị, 
\q2 ‘Ejighị m ha kpọrọ ihe.’ 
\q1 Ọ gụnyeghịkwa ụmụnne ya dịka ndị ọ maara, 
\q2 ọ nabatakwaghị ụmụ nke aka ya. 
\q1 Ma o debere okwu gị, 
\q2 cheziekwa ọgbụgba ndụ gị. 
\q1  
\v 10 Ọ na-akụziri Jekọb ikpe gị, 
\q2 na-akụzikwara Izrel iwu gị. 
\q1 Ọ na-achụkwa aja ụda na-esi isi ụtọ nʼihu gị, 
\q2 na-achụkwa aja nsure ọkụ nʼebe ịchụ aja gị. 
\q1  
\v 11 Gọzie akụnụba ya \nd Onyenwe anyị\nd*, 
\q2 ka ọrụ aka ya bụrụkwa ihe na-atọ gị ụtọ. 
\q1 Tijie ụkwụ ndị niile na-ebili imegide ya, 
\q2 tigbuo ndị iro ya ka ha ghara inwe ike ibili ọzọ.” 
\p  
\v 12 Mosis kwuru banyere ebo Benjamin sị, 
\q1 “Ka onye ahụ \nd Onyenwe anyị\nd* hụrụ nʼanya zuru ike na-atụghị ụjọ nʼime ya. 
\q2 Nʼihi na ọ ga-ekpuchi ya ogologo ụbọchị niile. 
\q2 Ọ bụkwa nʼetiti ubu ya abụọ ka onye \nd Onyenwe anyị\nd* hụrụ nʼanya na-anọ.” 
\p  
\v 13 Banyere Josef o kwuru sị, 
\q1 “Ka \nd Onyenwe anyị\nd* gọzie ala ya, 
\q2 ya jiri igirigi dị oke ọnụahịa nke eluigwe dị nʼelu, 
\q2 na ogbu mmiri dị nʼokpuru ala, 
\q1  
\v 14 na ihe ọma niile anyanwụ na-eweta, 
\q2 na ihe ọma niile ọnwa na-ewepụta, 
\q1  
\v 15 na onyinye ọma niile si nʼugwu ukwu ochie, 
\q2 na ịba ụba ugwu ebighị ebi ndị ahụ, 
\q1  
\v 16 na onyinye ọma niile si nʼala na uju ya niile, 
\q2 na ihuọma onye ahụ na-ebi nʼọhịa nta ahụ na-enwu ọkụ. 
\q1 Ka ihe ndị a niile dịrị nʼisi Josef, 
\q2 nʼiku anya onye bụ nwa eze, nʼetiti ụmụnna ya. 
\q1  
\v 17 Nʼịma mma, ọ dị ka nwa oke ehi e bụ ụzọ mụọ, 
\q2 mpi ya dị ka mpi ehi ọhịa. 
\q1 Ya ka ọ ga-eji sọda mba niile 
\q2 ọ bụladị mba ndị ahụ dị na nsọtụ ụwa. 
\q1 Otu a ka iri puku kwụrụ puku ndị Ifrem dị 
\q2 otu a ka imerime puku ndị Manase dị.” 
\p  
\v 18 Banyere Zebụlọn, o kwuru sị, 
\q1 “Ṅụrịa, gị Zebụlọn, nʼọpụpụ gị, 
\q2 ma gị Isaka, ṅụrịa nʼebe obibi gị. 
\q1  
\v 19 Ha ga-akpọ ndị mmadụ oku nʼelu ugwu ukwuu, 
\q2 nọ nʼebe ahụ chụọ aja ezi omume, 
\q1 ha ga-eri site nʼịba ụba nke ihe dị nʼosimiri, 
\q2 site nʼakụ nzuzo dị nʼaja.” 
\p  
\v 20 Banyere Gad, o kwuru sị, 
\q1 “Ngọzị na-adịrị onye ahụ na-eme ka ebe obibi Gad saa mbara. 
\q2 Gad na-ebi dịka ọdụm, 
\q2 na-adọkapụ aka maọbụ isi. 
\q1  
\v 21 Ọ họọrọ ala nke kachasị mma nye onwe ya; 
\q2 oke ruuru onyendu ka e wepụrụ dobere ya. 
\q1 Mgbe ndị ndu ndị mmadụ zukọrọ, 
\q2 o mezuru ezi ihe dị \nd Onyenwe anyị\nd* nʼobi, 
\q2 na ikpe ya niile banyere Izrel.” 
\p  
\v 22 Banyere Dan, o kwuru sị, 
\q1 “Dan bụ nwa ọdụm, 
\q2 onye na-esi na Bashan mapụta.” 
\p  
\v 23 Banyere Naftalị, o kwuru sị, 
\q1 “Naftalị bụ onye njupụta nke ihuọma \nd Onyenwe anyị\nd* dịrị, 
\q2 o jupụtakwara na ngọzị ya, 
\q2 ọ ga-eketa akụkụ ndịda nke iyi ukwu.” 
\p  
\v 24 Banyere Asha, o kwuru sị, 
\q1 “Onye a gọziri karịchasịa nʼụmụ ndị ikom ka Asha bụ, 
\q2 ka ihe banyere ya tọọ ụmụnna ya ụtọ, 
\q2 ka o jirikwa mmanụ\f + \fr 33:24 \ft Mmanụ bụ ihe ngosi na mmadụ bụ ọgaranya nʼọrụ ubi, nke kachasị, ọ bụrụ na onye dị otu a na-akọ mkpụrụ oliv nke e si na ya emepụta mmanụ. \xt Jen 49:20; Job 29:6.\f* saa ụkwụ ya. 
\q1  
\v 25 Ihe mkpọchi nke ọnụ ụzọ ama gị ga-abụ bronz na igwe, 
\q2 dịka ụbọchị ndụ gị niile si dị, otu a ka ịdị ike gị ga-adị. 
\b  
\q1  
\v 26 “O nweghị onye dịka Chineke Jeshurun, 
\q2 onye na-agba eluigwe dịka ịnyịnya ịbịa inyere gị aka, 
\q2 onye na-agba igwe ojii dịka ịnyịnya nʼịdị ukwuu ya. 
\q1  
\v 27 Chineke ebighị ebi bụ ebe mgbaba gị. 
\q2 Nʼokpuru gị ka aka ebighị ebi ya dị. 
\q1 Ọ ga-esite nʼihu gị chụpụ ndị iro gị, kwuokwa sị, 
\q2 ‘Bibie ha!’ 
\q1  
\v 28 Ya mere Izrel ga-ebi naanị ya nʼudo, 
\q2 isi iyi mmiri Jekọb dị chịm, 
\q1 nʼala ahụ jupụtara na mkpụrụ ubi na mmanya ọhụrụ 
\q2 ebe igirigi nke eluigwe na-ada. 
\q1  
\v 29 Onye a gọziri agọzi ka ị bụ, gị Izrel, 
\q2 onye dị ka gị 
\q2 ndị \nd Onyenwe anyị\nd* zọpụtara? 
\q1 Ọ bụ ọta gị na onye inyeaka gị, 
\q2 na mma agha gị dị ebube. 
\q1 Ndị iro gị ga-eji egwu daa nʼihu gị, 
\q2 ị ga-azọdakwa ebe ha niile dị elu.” 
\c 34  
\s1 Ọnwụ Mosis 
\p  
\v 1 Mgbe ahụ, Mosis sitere na mbara ala Moab rigoruo nʼelu nʼugwu Nebo, ruo nʼelu Pisga, nke dị na ncherita ihu Jeriko. Nʼebe ahụ \nd Onyenwe anyị\nd* mere ka ọ hụ ala ahụ niile anya site na Gilead ruo Dan;  
\v 2 ya na ala Naftalị niile nʼoke ala Ifrem, na nke Manase, na ala Juda niile ruo nʼosimiri Mediterenịa.\f + \fr 34:2 \ft Osimiri Mediterenịa dị nʼọdịda anyanwụ\f* 
\v 3 Mosis hụkwara ala Negev, na akụkụ ala ahụ niile dị site na Ndagwurugwu Jeriko, obodo nkwụ, ruo Zoa.  
\v 4 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis sị ya, “Nke a bụ ala ahụ m sitere nʼịṅụ iyi kwee Ebraham, Aịzik na Jekọb nkwa mgbe m kwuru sị, ‘Aga m enye ya ụmụ ụmụ gị.’\f + \fr 34:4 \ft \xt Jen 12:7\f* Ugbu a emeela m ka i jiri anya gị hụ ya ma ị gaghị agabiga banye nʼime ya.”\f + \fr 34:4 \ft \xt Dit 3:27\f* 
\p  
\v 5 Ya mere, Mosis, onyeozi \nd Onyenwe anyị\nd* nwụrụ nʼebe ahụ, nʼala Moab, dịka \nd Onyenwe anyị\nd* kwuru.  
\v 6 \nd Onyenwe anyị\nd* liri ya na Moab, na ndagwurugwu chere ihu na Bet-Peoa, ma ruo taa, ọ dịghị onye ọbụla maara ebe ili ya dị.  
\v 7 Mosis gbara narị afọ na iri afọ abụọ mgbe ọ nwụrụ, ma nʼoge ahụ ike ka dị ya nʼahụ, anya ya na-ahụkwa ụzọ nke ọma.  
\v 8 Ụmụ Izrel ruru ụjụ nʼihi Mosis, iri ụbọchị atọ nʼobosara ala Moab, tutu ruo mgbe oge iru ụjụ na ịkwa akwa gasịrị. 
\p  
\v 9 Joshua nwa Nun, jupụtara na mmụọ amamihe,\f + \fr 34:9 \ft \xt Aịz 11:2\f* nʼihi na Mosis ebikwasịla ya aka nʼisi. Ya mere, ụmụ Izrel ṅara Joshua ntị, gbasookwa iwu niile \nd Onyenwe anyị\nd* nyere ha site nʼọnụ Mosis. 
\p  
\v 10 Ọ dịbeghị onye amụma ọzọ pụtarala nʼala Izrel niile, nke dịka Mosis,\f + \fr 34:10 \ft \xt Dit 18:15,18\f* onye ya na \nd Onyenwe anyị\nd* kparịtara ụka ihu na ihu,\f + \fr 34:10 \ft \xt Ọpụ 33:11; Ọnụ 12:8; Dit 5:4\f* 
\v 11 onye mere ihe ịrịbama ndị a niile, rụọkwa ọrụ ebube niile nke \nd Onyenwe anyị\nd* ziri ya ka o mee nʼIjipt, nʼihu Fero, na ndị ozi ya niile, nakwa nʼala ahụ niile.  
\v 12 Nʼihi na o nwebekwaghị onye ọzọ gosirila ike dị oke egwu, maọbụ rụọ ọrụ dị oke egwu ụdị nke Mosis rụrụ nʼihu ndị Izrel niile.