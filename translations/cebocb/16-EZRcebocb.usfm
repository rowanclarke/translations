\li2  
\v 49 Uza, Pasea, Besai, 
\li2  
\v 50 Ashna, Meunim, Nefusim, 
\li2  
\v 51 Bakbuk, Hakufa, Harhur, 
\li2  
\v 52 Bazlut, Mehida, Harsha, 
\li2  
