\v 4 \w καὶ|strong="G2532"\w* \w ἀπελθὼν|strong="G0565"\w* συνελάλησε \w τοῖς|strong="G3588"\w* ἀρχιερεῦσι \w καὶ|strong="G2532"\w* \f + \fr 22:4 \ft στρατηγοις ¦ τοις στρατηγοις ᴛʀ ¦ γραμματευσιν και στρατηγοις ᴀɴᴛ \f*\w στρατηγοῖς|strong="G4755"\w* \w τὸ|strong="G3588"\w* \w πῶς|strong="G4459"\w* \f + \fr 22:4 \ft αυτον παραδω αυτοις ¦ αυτοις παραδω αυτον ᴄᴛ \f*\w αὐτὸν|strong="G0846"\w* \w παραδῷ|strong="G3860"\w* \w αὐτοῖς|strong="G0846"\w*.  
\v 5 \w καὶ|strong="G2532"\w* \w ἐχάρησαν|strong="G5463"\w*, \w καὶ|strong="G2532"\w* \w συνέθεντο|strong="G4934"\w* \w αὐτῷ|strong="G0846"\w* \f + \fr 22:5 \ft αργυριον \+bd ʙ\+bd*\+sup pt\+sup* ¦ αργυρια \+bd ʙ\+bd*\+sup pt\+sup* ᴀɴᴛ ᴘᴄᴋ \f*\w ἀργύριον|strong="G0694"\w* \w δοῦναι|strong="G1325"\w*.  
\v 6 \w καὶ|strong="G2532"\w* ἐξωμολόγησε \w καὶ|strong="G2532"\w* \w ἐζήτει|strong="G2212"\w* \w εὐκαιρίαν|strong="G2120"\w* \w τοῦ|strong="G3588"\w* \w παραδοῦναι|strong="G3860"\w* \w αὐτὸν|strong="G0846"\w* \f + \fr 22:6 \ft αυτοις ατερ οχλου ¦ ατερ οχλου αυτοις ᴄᴛ \f*\w αὐτοῖς|strong="G0846"\w* \w ἄτερ|strong="G0817"\w* \w ὄχλου|strong="G3793"\w*.   
