\p
\v 28 \w Moïse|strong="H4872"\w* \w dit|strong="H3068"\w* : « \w À|strong="H3068"\w* \w ceci|strong="H3068"\w* \w vous|strong="H3068"\w* \w saurez|strong="H3045"\w* \w que|strong="H3588"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H7971"\w* m'\w a|strong="H3068"\w* \w envoyé|strong="H7971"\w* \w pour|strong="H6213"\w* \w accomplir|strong="H6213"\w* \w toutes|strong="H6213"\w* \w ces|strong="H6213"\w* \w œuvres|strong="H4639"\w*, \w et|strong="H3068"\w* \w qu|strong="H3588"\w*'\w elles|strong="H3588"\w* \w ne|strong="H3808"\w* \w viennent|strong="H3820"\w* \w pas|strong="H3808"\w* \w de|strong="H6213"\w* \w ma|strong="H3045"\w* \w propre|strong="H3068"\w* \w volonté|strong="H3820"\w*.  
\v 29 \w Si|strong="H3808"\w* \w ces|strong="H7971"\w* \w hommes|strong="H3068"\w* \w meurent|strong="H4191"\w* \w de|strong="H5921"\w* \w la|strong="H3068"\w* \w mort|strong="H4191"\w* naturelle \w de|strong="H5921"\w* \w tous|strong="H3605"\w* \w les|strong="H3068"\w* \w hommes|strong="H3068"\w*, \w ou|strong="H3605"\w* s'\w ils|strong="H3068"\w* \w subissent|strong="H6485"\w* \w le|strong="H3068"\w* \w sort|strong="H7971"\w* \w commun|strong="H6486"\w* \w à|strong="H3068"\w* \w tous|strong="H3605"\w* \w les|strong="H3068"\w* \w hommes|strong="H3068"\w*, \w alors|strong="H3808"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H7971"\w* \w ne|strong="H3808"\w* m'\w a|strong="H3068"\w* \w pas|strong="H3808"\w* \w envoyé|strong="H7971"\w*.  
\v 30 \w Mais|strong="H3588"\w* \w si|strong="H3588"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3045"\w* accomplit \w une|strong="H3068"\w* \w chose|strong="H3068"\w* \w inouïe|strong="H1278"\w*, \w si|strong="H3588"\w* \w la|strong="H3068"\w* \w terre|strong="H3068"\w* \w ouvre|strong="H6475"\w* \w sa|strong="H3068"\w* \w bouche|strong="H6310"\w* \w et|strong="H3068"\w* \w les|strong="H3068"\w* \w engloutit|strong="H1104"\w* \w avec|strong="H3381"\w* \w tout|strong="H3605"\w* \w ce|strong="H3605"\w* \w qui|strong="H3068"\w* \w leur|strong="H3068"\w* \w appartient|strong="H3068"\w*, \w et|strong="H3068"\w* \w qu|strong="H3588"\w*'\w ils|strong="H6310"\w* \w descendent|strong="H3381"\w* \w vivants|strong="H2416"\w* \w au|strong="H3068"\w* Shéol,\f + \fr 16.30 \ft Le Shéol est le séjour des morts.\f* \w alors|strong="H3045"\w* \w vous|strong="H3068"\w* \w saurez|strong="H3045"\w* \w que|strong="H3588"\w* \w ces|strong="H3605"\w* \w hommes|strong="H3068"\w* \w ont|strong="H3068"\w* \w méprisé|strong="H5006"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3045"\w*. »   
\p
\v 31 \w Comme|strong="H1961"\w* \w il|strong="H1697"\w* \w achevait|strong="H3615"\w* \w de|strong="H1697"\w* \w prononcer|strong="H1696"\w* \w toutes|strong="H1696"\w* \w ces|strong="H1697"\w* \w paroles|strong="H1697"\w*, \w le|strong="H1696"\w* sol \w qui|strong="H1697"\w* \w était|strong="H1961"\w* \w sous|strong="H8478"\w* \w eux|strong="H1697"\w* \w se|strong="H1697"\w* \w fendit|strong="H1234"\w*.  
\v 32 \w La|strong="H6605"\w* \w terre|strong="H6605"\w* \w ouvrit|strong="H6605"\w* \w sa|strong="H6310"\w* \w bouche|strong="H6310"\w* \w et|strong="H1004"\w* \w les|strong="H3605"\w* \w engloutit|strong="H1104"\w* \w avec|strong="H6310"\w* \w leurs|strong="H1004"\w* maisonnées, \w tous|strong="H3605"\w* \w les|strong="H3605"\w* \w hommes|strong="H6310"\w* \w de|strong="H1004"\w* Coré, \w et|strong="H1004"\w* \w tous|strong="H3605"\w* \w leurs|strong="H1004"\w* \w biens|strong="H7399"\w*.  
\v 33 \w Ils|strong="H1992"\w* \w descendirent|strong="H3381"\w* \w vivants|strong="H2416"\w* \w au|strong="H3381"\w* Shéol,\f + \fr 16.33 \ft Le Shéol est le séjour des morts.\f* \w eux|strong="H1992"\w* \w et|strong="H5921"\w* \w tout|strong="H3605"\w* \w ce|strong="H3605"\w* \w qui|strong="H1992"\w* \w leur|strong="H3381"\w* appartenait. \w La|strong="H5921"\w* \w terre|strong="H5921"\w* \w se|strong="H2416"\w* \w referma|strong="H3680"\w* \w sur|strong="H5921"\w* \w eux|strong="H1992"\w*, \w et|strong="H5921"\w* \w ils|strong="H1992"\w* \w disparurent|strong="H1992"\w* \w du|strong="H8432"\w* \w milieu|strong="H8432"\w* \w de|strong="H5921"\w* l'\w assemblée|strong="H6951"\w*.  
\v 34 \w Tout|strong="H3605"\w* \w Israël|strong="H3478"\w* \w qui|strong="H3478"\w* \w était|strong="H3478"\w* \w autour|strong="H5439"\w* d'\w eux|strong="H3588"\w* \w s|strong="H3478"\w*'\w enfuit|strong="H5127"\w* \w à|strong="H3478"\w* \w leurs|strong="H3605"\w* \w cris|strong="H6963"\w*, \w car|strong="H3588"\w* \w ils|strong="H3588"\w* disaient : « \w De|strong="H6963"\w* \w peur|strong="H6435"\w* \w que|strong="H3588"\w* \w la|strong="H3478"\w* \w terre|strong="H3588"\w* \w ne|strong="H3478"\w* \w nous|strong="H3588"\w* \w engloutisse|strong="H1104"\w* ! »  
\v 35 \w Un|strong="H3068"\w* \w feu|strong="H3068"\w* \w sortit|strong="H3318"\w* \w de|strong="H3318"\w* \w la|strong="H3068"\w* \w part|strong="H3068"\w* \w du|strong="H3318"\w* \w SEIGNEUR|strong="H3068"\w*, \w et|strong="H3068"\w* dévora \w les|strong="H3068"\w* \w deux|strong="H3318"\w* \w cent|strong="H3967"\w* \w cinquante|strong="H2572"\w* \w hommes|strong="H3967"\w* \w qui|strong="H3068"\w* \w offraient|strong="H7126"\w* l'\w encens|strong="H7004"\w*.   
\p
\v 36 Le SEIGNEUR parla à Moïse :  
\v 37 « Dis à Éléazar, fils du prêtre Aaron, de retirer les encensoirs de l'incendie et d'en disperser le feu au loin, car ils sont saints.  
\v 38 Quant aux encensoirs de ces hommes qui ont péché au péril de leur vie, qu'on en fasse des plaques martelées pour recouvrir l'autel. Puisqu'ils les ont présentés devant le SEIGNEUR, ils sont saints. Ils serviront de signe aux enfants d'Israël. »   
\p
\v 39 Le prêtre Éléazar prit les encensoirs de bronze qu'avaient présentés ceux qui avaient été brûlés, et on les martela pour en faire un revêtement pour l'autel,  
\v 40 afin de servir de mémorial aux enfants d'Israël, pour qu'aucun étranger qui n'est pas de la descendance d'Aaron ne s'approche pour brûler de l'encens devant le SEIGNEUR, et qu'il ne subisse pas le même sort que Coré et sa bande, selon ce que le SEIGNEUR lui avait dit par l'intermédiaire de Moïse.   
\p
\v 41 Dès le lendemain, toute la communauté des enfants d'Israël murmura contre Moïse et contre Aaron, en disant : « Vous avez fait mourir le peuple du SEIGNEUR ! »   
\p
\v 42 Comme la communauté s'attroupait contre Moïse et contre Aaron, ils se tournèrent vers la tente de la Rencontre. Et voici, la nuée la couvrit, et la gloire du SEIGNEUR apparut.  
\v 43 Moïse et Aaron se rendirent devant la tente de la Rencontre.  
\v 44 Le SEIGNEUR parla à Moïse :  
\v 45 « Retirez-vous du milieu de cette communauté, et je les consumerai en un instant ! » Ils tombèrent le visage contre terre.   
\p
\v 46 Moïse dit à Aaron : « Prends ton encensoir, mets-y du feu de l'autel, déposes-y de l'encens, \w va|strong="H3068"\w* vite vers la communauté et fais l'expiation pour eux ; car la colère \w a|strong="H3068"\w* éclaté de la part du SEIGNEUR ! Le fléau \w a|strong="H3068"\w* commencé. »   
\p
\v 47 Aaron prit l'encensoir, comme Moïse l'avait dit, et courut au milieu de l'assemblée. Le fléau avait déjà commencé parmi le peuple. Il mit l'encens et fit l'expiation pour le peuple.  
\v 48 Il se tint entre les morts et les vivants, et le fléau s'arrêta.  
\v 49 Ceux qui moururent de ce fléau furent quatorze mille sept cents, en plus de ceux qui étaient morts à cause de l'affaire de Coré.  
\v 50 Aaron retourna auprès de Moïse, à l'entrée de la tente de la Rencontre, et le fléau fut arrêté.   
\c 17
\p
\v 1 \w Le|strong="H3068"\w* \w SEIGNEUR|strong="H1696"\w* \w dit|strong="H1696"\w* \w à|strong="H3068"\w* \w Moïse|strong="H4872"\w* :  
\v 2 « \w Parle|strong="H1121"\w* \w aux|strong="H6942"\w* \w enfants|strong="H1121"\w* d'\w Israël|strong="H1121"\w* \w et|strong="H1121"\w* \w prends|strong="H3588"\w* d'\w eux|strong="H3588"\w* \w des|strong="H1121"\w* bâtons, \w un|strong="H1121"\w* bâton \w pour|strong="H3588"\w* \w chaque|strong="H1121"\w* \w maison|strong="H1121"\w* paternelle, \w de|strong="H1121"\w* \w la|strong="H1121"\w* \w part|strong="H1121"\w* \w de|strong="H1121"\w* \w tous|strong="H1121"\w* \w leurs|strong="H1121"\w* \w princes|strong="H1121"\w* \w selon|strong="H1121"\w* \w leurs|strong="H1121"\w* \w maisons|strong="H3548"\w* paternelles, \w soit|strong="H7311"\w* douze bâtons. \w Tu|strong="H3588"\w* \w écriras|strong="H3588"\w* \w le|strong="H1121"\w* nom \w de|strong="H1121"\w* \w chacun|strong="H3588"\w* \w sur|strong="H3588"\w* \w son|strong="H3588"\w* bâton.  
\v 3 \w Tu|strong="H3588"\w* \w écriras|strong="H3588"\w* \w le|strong="H6440"\w* \w nom|strong="H3068"\w* \w d|strong="H6440"\w*'\w Aaron|strong="H3068"\w* \w sur|strong="H6440"\w* \w le|strong="H6440"\w* bâton \w de|strong="H1121"\w* Lévi. \w Il|strong="H3068"\w* \w y|strong="H3068"\w* \w aura|strong="H1961"\w* \w un|strong="H1121"\w* \w seul|strong="H3068"\w* bâton \w pour|strong="H6213"\w* \w chaque|strong="H6213"\w* \w chef|strong="H1121"\w* \w de|strong="H1121"\w* \w leurs|strong="H1121"\w* \w maisons|strong="H6213"\w* paternelles.  
\v 4 \w Tu|strong="H3947"\w* \w les|strong="H3947"\w* déposeras \w dans|strong="H3947"\w* \w la|strong="H3947"\w* \w tente|strong="H3947"\w* \w de|strong="H4196"\w* \w la|strong="H3947"\w* Rencontre, \w devant|strong="H7126"\w* \w le|strong="H3947"\w* Témoignage, \w là|strong="H3947"\w* où \w je|strong="H3548"\w* \w vous|strong="H3947"\w* rencontre.  
\v 5 \w Il|strong="H3068"\w* \w arrivera|strong="H3068"\w* \w que|strong="H1121"\w* \w le|strong="H6440"\w* bâton \w de|strong="H1121"\w* \w l|strong="H6440"\w*'\w homme|strong="H1121"\w* \w que|strong="H1121"\w* \w je|strong="H6440"\w* \w choisirai|strong="H6440"\w* bourgeonnera. \w Je|strong="H3068"\w* \w ferai|strong="H3068"\w* \w ainsi|strong="H1696"\w* cesser \w devant|strong="H6440"\w* \w moi|strong="H6440"\w* \w les|strong="H3068"\w* \w murmures|strong="H6440"\w* \w des|strong="H3068"\w* \w enfants|strong="H1121"\w* \w d|strong="H6440"\w*'\w Israël|strong="H3478"\w*, qu'\w ils|strong="H1121"\w* \w profèrent|strong="H1696"\w* \w contre|strong="H3068"\w* \w vous|strong="H3068"\w*. »   
\p
\v 6 \w Moïse|strong="H4872"\w* \w parla|strong="H4872"\w* \w aux|strong="H5971"\w* \w enfants|strong="H1121"\w* d'\w Israël|strong="H3478"\w*, \w et|strong="H1121"\w* \w tous|strong="H3605"\w* \w leurs|strong="H1121"\w* \w princes|strong="H1121"\w* \w lui|strong="H3068"\w* \w donnèrent|strong="H1121"\w* \w des|strong="H3068"\w* bâtons, \w un|strong="H1121"\w* \w pour|strong="H3068"\w* \w chaque|strong="H3605"\w* \w prince|strong="H3605"\w*, \w selon|strong="H5921"\w* \w leurs|strong="H1121"\w* \w maisons|strong="H3068"\w* paternelles, \w soit|strong="H3068"\w* \w un|strong="H1121"\w* \w total|strong="H1121"\w* \w de|strong="H1121"\w* douze bâtons. \w Le|strong="H3068"\w* bâton d'\w Aaron|strong="H4872"\w* \w se|strong="H3068"\w* \w trouvait|strong="H3068"\w* \w parmi|strong="H3068"\w* \w leurs|strong="H1121"\w* bâtons.  
\v 7 \w Moïse|strong="H4872"\w* \w déposa|strong="H4872"\w* \w les|strong="H3068"\w* bâtons \w devant|strong="H7200"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H7200"\w*, \w dans|strong="H5921"\w* \w la|strong="H3068"\w* \w tente|strong="H7200"\w* \w du|strong="H5921"\w* Témoignage.   
\p
\v 8 \w Le|strong="H6440"\w* lendemain, \w Moïse|strong="H4872"\w* \w entra|strong="H4872"\w* \w dans|strong="H6440"\w* \w la|strong="H6440"\w* \w tente|strong="H6440"\w* \w du|strong="H6440"\w* Témoignage ; \w et|strong="H4872"\w* \w voici|strong="H4872"\w*, \w le|strong="H6440"\w* bâton \w d|strong="H6440"\w*'\w Aaron|strong="H4872"\w* \w pour|strong="H6440"\w* \w la|strong="H6440"\w* \w maison|strong="H6440"\w* \w de|strong="H6440"\w* Lévi \w avait|strong="H4872"\w* fleuri, \w poussé|strong="H4872"\w* \w des|strong="H6440"\w* bourgeons, produit \w des|strong="H6440"\w* fleurs \w et|strong="H4872"\w* \w fait|strong="H6440"\w* mûrir \w des|strong="H6440"\w* amandes.  
