\p
\v 11 God \w said|strong="H3651"\w*, “\w Let|strong="H1961"\w* \w the|strong="H5921"\w* earth \w produce|strong="H6529"\w* \w vegetation|strong="H6212"\w*—\w plants|strong="H6212"\w* \w that|strong="H3651"\w* \w produce|strong="H6529"\w* \w seeds|strong="H2233"\w* \w and|strong="H6086"\w* \w trees|strong="H6086"\w* \w that|strong="H3651"\w* \w produce|strong="H6529"\w* seeded \w fruit|strong="H6529"\w*—each \w one|strong="H6213"\w* \w according|strong="H5921"\w* \w to|strong="H1961"\w* \w its|strong="H5921"\w* \w own|strong="H1961"\w* \w kind|strong="H4327"\w*.” \w And|strong="H6086"\w* \w that|strong="H3651"\w*'s \w what|strong="H6213"\w* \w happened|strong="H1961"\w*.  
