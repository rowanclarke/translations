\v 3 \w Y|strong="H3068"\w* \w aun|strong="H1571"\w* \w mientras|strong="H3605"\w* \w va|strong="H3068"\w* \w el|strong="H1931"\w* \w necio|strong="H5530"\w* \w por|strong="H1870"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w*, \w fálta|strong="H2638"\w*\add le\add* \w su|strong="H1931"\w* cordura, \w y|strong="H1571"\w* dice \w a|strong="H3068"\w* \w todos|strong="H3605"\w*, \add que\add* \w es|strong="H1931"\w* \w necio|strong="H5530"\w*.
