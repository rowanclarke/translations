\v 23 Llegaron \w hasta|strong="H5704"\w* el Valle \w de|strong="H4480"\w* Escol. \w Allí|strong="H8033"\w* \w cortaron|strong="H3772"\w* una rama \w con|strong="H4480"\w* un racimo \w de|strong="H4480"\w* \w uvas|strong="H6025"\w*, el cual \w llevaron|strong="H5375"\w* \w en|strong="H4480"\w* un \w palo|strong="H4132"\w* \w entre|strong="H8033"\w* \w dos|strong="H8147"\w*. También \add cortaron\add* algunas \w granadas|strong="H7416"\w* \w y|strong="H5704"\w* algunos \w higos|strong="H8384"\w*.  
\v 24 \w Llamaron|strong="H7121"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* \w el|strong="H1931"\w* Valle \w de|strong="H5921"\w* Escol, \w a|strong="H3068"\w* causa \w del|strong="H5921"\w* racimo \w que|strong="H1931"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w cortaron|strong="H3772"\w* \w allí|strong="H8033"\w*.  
\v 25 Regresaron de explorar la tierra al \w fin|strong="H7093"\w* de 40 \w días|strong="H3117"\w*.   
\p
\v 26 Emprendieron viaje y llegaron \w a|strong="H3068"\w* donde estaban \w Moisés|strong="H4872"\w*, Aarón y \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w en|strong="H3212"\w* \w Cades|strong="H6946"\w*, \w en|strong="H3212"\w* \w el|strong="H3605"\w* \w desierto|strong="H4057"\w* \w de|strong="H1121"\w* \w Parán|strong="H6290"\w*. Dieron \w cuenta|strong="H1697"\w* \w a|strong="H3068"\w* \w ellos|strong="H3605"\w* y \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* asamblea, y les mostraron \w el|strong="H3605"\w* \w fruto|strong="H6529"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* tierra.  
\v 27 Les \w contaron|strong="H5608"\w*: Llegamos \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w cual|strong="H1931"\w* nos \w enviaste|strong="H7971"\w*, \w y|strong="H1571"\w* \w ciertamente|strong="H1571"\w* \w fluye|strong="H2100"\w* \w leche|strong="H2461"\w* \w y|strong="H1571"\w* \w miel|strong="H1706"\w*. ¡\w Y|strong="H3068"\w* \w este|strong="H2088"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w fruto|strong="H6529"\w* de \w ella|strong="H1931"\w*!   
\p
\v 28 \w Pero|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w que|strong="H3588"\w* \w habita|strong="H3427"\w* \w en|strong="H3588"\w* esa tierra \w es|strong="H3588"\w* \w fuerte|strong="H5794"\w*. Las \w ciudades|strong="H5892"\w* \w están|strong="H3427"\w* \w fortificadas|strong="H1219"\w* \w y|strong="H1571"\w* \w son|strong="H3588"\w* \w muy|strong="H3966"\w* \w grandes|strong="H1419"\w*. \w También|strong="H1571"\w* \w vimos|strong="H7200"\w* \w allí|strong="H8033"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* descendientes \w de|strong="H3588"\w* Anac.  
\v 29 \w Los|strong="H3427"\w* amalecitas \w habitan|strong="H3427"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w del|strong="H5921"\w* Neguev. \w El|strong="H5921"\w* heteo, \w jebuseo|strong="H2983"\w* \w y|strong="H5921"\w* amorreo \w habitan|strong="H3427"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* región montañosa \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w cananeo|strong="H3669"\w* \w habita|strong="H3427"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w mar|strong="H3220"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* ribera \w del|strong="H5921"\w* \w Jordán|strong="H3383"\w*.   
\p
\v 30 \w Entonces|strong="H3588"\w* \w Caleb|strong="H3612"\w* trató \w de|strong="H3588"\w* apaciguar al \w pueblo|strong="H5971"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* presencia \w de|strong="H3588"\w* \w Moisés|strong="H4872"\w*, \w y|strong="H3588"\w* dijo: ¡\w De|strong="H3588"\w* todos modos, debemos \w subir|strong="H5927"\w* \w y|strong="H3588"\w* tomar posesión \w de|strong="H3588"\w* ella, \w porque|strong="H3588"\w* \w ciertamente|strong="H3588"\w* \w la|strong="H3588"\w* conquistaremos!   
\p
\v 31 \w Pero|strong="H3588"\w* \w los|strong="H5973"\w* hombres \w que|strong="H3588"\w* \w subieron|strong="H5927"\w* \w con|strong="H5973"\w* \w él|strong="H1931"\w* dijeron: \w No|strong="H3808"\w* \w podremos|strong="H3201"\w* \w subir|strong="H5927"\w* \w contra|strong="H5973"\w* \w aquel|strong="H1931"\w* \w pueblo|strong="H5971"\w*, \w porque|strong="H3588"\w* \w es|strong="H1931"\w* \w más|strong="H3588"\w* \w fuerte|strong="H2389"\w* \w que|strong="H3588"\w* \w nosotros|strong="H5973"\w*.  
\v 32 Difamaron ante \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w la|strong="H1931"\w* tierra \w que|strong="H1931"\w* exploraron y dijeron: \w La|strong="H1931"\w* tierra \w que|strong="H1931"\w* fuimos \w a|strong="H3068"\w* explorar \w es|strong="H1931"\w* una tierra \w que|strong="H1931"\w* devora \w a|strong="H3068"\w* \w sus|strong="H1931"\w* \w habitantes|strong="H3427"\w*. \w Todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w que|strong="H1931"\w* \w vimos|strong="H7200"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* \w ella|strong="H1931"\w* son \w hombres|strong="H1121"\w* \w de|strong="H1121"\w* gran estatura.  
\v 33 \w También|strong="H3651"\w* \w vimos|strong="H7200"\w* \w allí|strong="H8033"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* nefileos (\w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Anac \w son|strong="H1961"\w* parte \w de|strong="H4480"\w* \w los|strong="H1121"\w* nefileos, raza \w de|strong="H4480"\w* \w gigantes|strong="H5303"\w*), y \w nos|strong="H4480"\w* \w pareció|strong="H7200"\w* \w que|strong="H4480"\w* éramos \w como|strong="H1961"\w* saltamontes. \w Así|strong="H3651"\w* éramos ante sus \w ojos|strong="H5869"\w*.   
\c 14  
\s1 Rebelión del pueblo  
\p
\v 1 Entonces \w toda|strong="H3605"\w* \w la|strong="H1931"\w* congregación gritó y \w lloró|strong="H1058"\w* \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w*.  
\v 2 \w Toda|strong="H3605"\w* \w la|strong="H5921"\w* congregación \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w se|strong="H5921"\w* quejó \w contra|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* Aarón \w y|strong="H5921"\w* \w les|strong="H5921"\w* dijeron: ¡\w Ojalá|strong="H3863"\w* hubiéramos \w muerto|strong="H4191"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*! ¡\w Ojalá|strong="H3863"\w* \w muriéramos|strong="H4191"\w* \w en|strong="H5921"\w* \w este|strong="H2088"\w* \w desierto|strong="H4057"\w*!  
\v 3 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w nos|strong="H4100"\w* trae \w a|strong="H3068"\w* \w esta|strong="H2063"\w* tierra \w para|strong="H1961"\w* \w caer|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*? ¿\w Para|strong="H1961"\w* \w que|strong="H4100"\w* nuestras mujeres y nuestros pequeños sirvan de presa? ¿\w No|strong="H3808"\w* \w nos|strong="H4100"\w* \w sería|strong="H1961"\w* \w mejor|strong="H2896"\w* \w volvernos|strong="H7725"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*?  
\v 4 Se decían el uno al otro: ¡Escojamos un líder y regresemos \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*!   
\p
\v 5 Entonces \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* Aarón \w cayeron|strong="H5307"\w* \w sobre|strong="H5921"\w* sus \w rostros|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* asamblea \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w congregación|strong="H6951"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 6 \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Nun|strong="H5126"\w*, y \w Caleb|strong="H3612"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Jefone, \w que|strong="H4480"\w* eran \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w que|strong="H4480"\w* exploraron la tierra, \w rasgaron|strong="H7167"\w* sus ropas  
\v 7 y hablaron \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* asamblea \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*: \w La|strong="H3605"\w* tierra por donde \w pasamos|strong="H5674"\w* para explorarla es tierra \w muy|strong="H3966"\w* \w buena|strong="H2896"\w*.  
\v 8 \w Si|strong="H1931"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w se|strong="H1931"\w* agrada \w de|strong="H5414"\w* \w nosotros|strong="H1931"\w*, \w Él|strong="H1931"\w* nos introducirá en \w esa|strong="H1931"\w* tierra y nos \w entregará|strong="H5414"\w* \w la|strong="H1931"\w* tierra \w que|strong="H1931"\w* \w fluye|strong="H2100"\w* \w leche|strong="H2461"\w* y \w miel|strong="H1706"\w*.  
\v 9 \w Pero|strong="H3588"\w* \w no|strong="H3588"\w* \w se|strong="H5921"\w* rebelen \w contra|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* ni \w teman|strong="H3372"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w gente|strong="H5971"\w* \w de|strong="H5921"\w* esa tierra, \w porque|strong="H3588"\w* \w serán|strong="H1992"\w* \w como|strong="H3588"\w* nuestro \w pan|strong="H3899"\w*. \w Su|strong="H1992"\w* defensa \w se|strong="H5921"\w* apartó \w de|strong="H5921"\w* \w ellos|strong="H1992"\w*, \w y|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w está|strong="H1992"\w* \w con|strong="H5921"\w* \w nosotros|strong="H5921"\w*. ¡\w No|strong="H3588"\w* \w les|strong="H1992"\w* \w teman|strong="H3372"\w*!   
\p
\v 10 Pero \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación hablaba \w de|strong="H1121"\w* apedrearlos. Entonces \w la|strong="H3605"\w* \w gloria|strong="H3519"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w apareció|strong="H7200"\w* en \w el|strong="H3605"\w* Tabernáculo \w de|strong="H1121"\w* Reunión ante \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*,  
\v 11 \w y|strong="H5704"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj ¿\+w Hasta|strong="H5704"\+w* \+w cuándo|strong="H5704"\+w* me despreciará \+w este|strong="H2088"\+w* \+w pueblo|strong="H5971"\+w*? ¿\+w Hasta|strong="H5704"\+w* \+w cuándo|strong="H5704"\+w* \+w no|strong="H3808"\+w* me creerá \+w a|strong="H3068"\+w* pesar \+w de|strong="H5704"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H3605"\+w* prodigios \+w que|strong="H3808"\+w* \+w hice|strong="H6213"\+w* \+w en|strong="H5704"\+w* \+w medio|strong="H7130"\+w* \+w de|strong="H5704"\+w* \+w ellos|strong="H3605"\+w*?\wj*  
\v 12 \wj \+w Lo|strong="H6213"\+w* \+w heriré|strong="H5221"\+w* \+w con|strong="H4480"\+w* \+w mortandad|strong="H1698"\+w* y \+w lo|strong="H6213"\+w* destruiré. \+w Haré|strong="H6213"\+w* \+w de|strong="H4480"\+w* \+w ti|strong="H4480"\+w* una \+w nación|strong="H1471"\+w* \+w más|strong="H4480"\+w* \+w grande|strong="H1419"\+w* y \+w más|strong="H4480"\+w* \+w fuerte|strong="H6099"\+w* \+w que|strong="H4480"\+w* \+w ellos|strong="H4480"\+w*.\wj*   
\p
\v 13 \w Pero|strong="H3588"\w* \w Moisés|strong="H4872"\w* respondió \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*: \w Lo|strong="H2088"\w* \w oirán|strong="H8085"\w* \w los|strong="H3588"\w* \w egipcios|strong="H4713"\w*, \w pues|strong="H3588"\w* \w de|strong="H3588"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* ellos \w sacaste|strong="H5927"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w con|strong="H3588"\w* tu \w poder|strong="H3581"\w*.  
\v 14 \w Y|strong="H3068"\w* \w lo|strong="H2088"\w* dirán \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w esta|strong="H2063"\w* tierra, \w los|strong="H3427"\w* cuales \w oyeron|strong="H8085"\w* \w que|strong="H3588"\w* Tú, oh \nd \+w Yavé|strong="H3068"\+w*\nd*, \w estás|strong="H5975"\w* \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, \w que|strong="H3588"\w* Tú, oh \nd \+w Yavé|strong="H3068"\+w*\nd*, \w te|strong="H5869"\w* dejas \w ver|strong="H7200"\w* \w cara|strong="H6440"\w* \w a|strong="H3068"\w* \w cara|strong="H6440"\w*, \w que|strong="H3588"\w* tu \w nube|strong="H6051"\w* \w está|strong="H2063"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* Tú \w vas|strong="H1980"\w* \w delante|strong="H6440"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* \w columna|strong="H5982"\w* \w de|strong="H5921"\w* \w nube|strong="H6051"\w* durante \w el|strong="H5921"\w* \w día|strong="H3119"\w* \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w columna|strong="H5982"\w* \w de|strong="H5921"\w* fuego \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w noche|strong="H3915"\w*.  
\v 15 Si haces \w morir|strong="H4191"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* como un solo hombre, las \w naciones|strong="H1471"\w* \w que|strong="H5971"\w* \w oyeron|strong="H8085"\w* tu fama dirán:  
\v 16 Porque \w no|strong="H1115"\w* \w pudo|strong="H3201"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* introducir \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* en la tierra \w que|strong="H5971"\w* les prometió con juramento, los mató en el \w desierto|strong="H4057"\w*.   
\p
\v 17 \w Ahora|strong="H6258"\w* \w pues|strong="H4994"\w*, te \w ruego|strong="H4994"\w* \w que|strong="H6258"\w* sea magnificado el \w poder|strong="H3581"\w* de \w mi|strong="H1431"\w* \nd ʼAdón\nd*, como \w dijiste|strong="H1696"\w*:   
