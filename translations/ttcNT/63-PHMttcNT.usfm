\id PHM - Maya-Tektiteko NT -Guatemala 2003 (DBL -2013) 
\h Te Mo'nch 
\toc1 Te Stz'ib'en Pa'k Te Mo'nch 
\toc2 Te Mo'nch 
\toc3 Mnch 
\mt1 Te Stz'ib'en Pa'k Te Mo'nch 
\c 1  
\s1 Jun Limb'il 
\p  
\v 1 Wetz a'in Pa'k akyinqex pres tzan tpaj Kristo Jesus, b'ix atqet tzani wuky'i'l te qerman Timotey, [nqet qtz'ib'a'na] te yatz Mo'nch\f + \fr 1:1 \ft Filemón tb'i tuj kastiy.\f* aj ganimich nim qitza'na, yatz aj nxhch'onen quky'ila.  
\v 2 [Jun limb'il te yatz] b'ix ax te qerman xuj Apy b'ix ax te qerman Arkip, jun quky'ila aj nim n'aq'unan tuj taq'un Jesukrist,\f + \fr 1:2 \ft Ax: “Arkip jun quky'ila jun soldad te Jesukrist.”\f* b'ix ax [jun limb'il] kye a'e' qerman aj n'ok kchimo' kyib' tuj ajay. 
\p  
\v 3 Instzaj si'xwit jun nim b'an galan etajsik b'ix qet chewsa'xwit ek'u'j tzan Qtata Dios b'ix tzan te Qajaw Jesukrist. 
\s1 Te Pa'k B'an Nchalaj Tuq Ti'j Te Mo'nch 
\p  
\v 4 Nxik nsi' pixon te Qtata Dios\f + \fr 1:4 \ft Nyolin tuj kastiy “mi Dios” per k'onti'l telponx cha a'ox te Dios aj ntzaj tna'o' tuq te Pa'k sinoke te Dios aj ntzaj tna'o' tuq tetz parej titza' ntzaj tna'o' tuq te Mo'nch.\f* awi'j oj nxnaq'tzan  
\v 5 tzan tpaj aj n'ok ncha'o' titza' yatz wit'lik ak'u'j ti'j te Qajaw Jesus b'ix titza' nqet agani' tetz kyuky'i kyaqil kye aj pawame' te tetz.  
\v 6 Nxik nqani' tuky'i Qtata Dios awi'j yatz aj wit'lik ak'u'j iktza' qetz, nxik nqani' tzan tokenxwit b'an galan te aj awit'lb'en ak'u'jni tzan tel aniky' byenech ti'j kyaqil te aj tb'anil aj oje tzaj tsi' te Krist qetz.  
\v 7 Wetz b'an nkyinchalaj tuj wanim b'ix njaw awin nk'u'j tzan tpaj n'ok ncha'o' nkyeqet agani' kyaqil kye aj pawame' te Qtata Dios b'ix tzan tpaj yatz erman njaw awin kyk'u'j kkyaqil kyetz. 
\s1 Te Pa'k Nqet Twitz Twitz Mo'nch Tzan Tk'amon Te Onésimo 
\p  
\v 8 Astilji anke wetz tzan tpaj Krist at nim woklen tzan axik nk'ulu' mandad tzan tqet ak'ulu' te aj presis,  
\v 9 per tzan tpaj b'an ajb'ila' a'ich witza', astilji wetz nqet nwitz awitz, wetz a'in Pa'k ya b'an tijky a'in, b'ix pyor ajna'lky pres atin tzan tpaj te [npakb'en ti'j] Kristo Jesus,  
\v 10 nqet nwitz awitz ti'j jun xjal aj naqe nk'wa'al, aj Onésimo, aj nk'wa'lij tuj pres.  
\v 11 [Qanq] tuj jun tyemp k'onti'l tuq token te yatz, per ajna'l at nim token nya'tx a'ox te yatz sinoke ax te wetz.  
\v 12 Ajna'l owajel nlajo' awuky'i'lky tetz aj b'an nim nqet ngani'.  
\v 13 Wetz ngan-tal tzan tqet nk'amo' wuky'i'l tzan-tal tonen wuky'i'l te aky'ixel man akyinqex pres tzan tpaj te tpakb'alil galan ti'j Jesukrist.  
\v 14 Per k'on ngan tuq k'ulun ikxjani qa yatz nya'tx tuq tuky'i jun tk'u'jlal ma atzoqpij, tzan k'on tok te aj n'ak'ulu' iktza' cha alajwers, sinoke tuky'i aboluntadx yatz tuky'i jun tk'u'jlal. 
\p  
\v 15 Qanq tzan tpaj ntzani owex tuj ajay jun tyemp, per tzan tuq ak'amon tetz b'eyx te jun-ele'x,  
\v 16 nya'tx cha a'ox iktza' jun aj mosi' awitza' sinoke mas galan twitz nini, iktza' jun erman aj b'an gani' qitza', b'ix ajb'ila' nim witza' wetz b'ix pyorx-al yatz oqtel agani' tzan tpaj jun axjalil b'ix tzan tpaj nxnaq'tzan.  
\v 17 Qa yatz tuj anab'l a'in jun awuky'i'l, ntons pak'amon te tetz iktze'xtzun a'in.  
\v 18 Qatzun at jun tidi' aj otk'uluj nya'tx galan, qatzun at tidi' k'asb'ena' titza' awuky'i'l, intkaj asi' tuj nq'ab'. 
\p  
\v 19 Ajna'l wetz a'in Pa'k nqet ntz'ib'a' ntzani tuky'i nq'ab'x, wetz owokel nchojo', anke at tidi'chq galan aj oje qet nk'ulu' te yatz.  
\v 20 Astilji, erman, wetz ngan tzan ab'ek'an ch'in wi'j tzan tpaj te Qajaw. Intjaw awin ch'in nk'u'j tuky'i Krist. 
\p  
\v 21 Ma'tx qet ntz'ib'a' te yatz b'ix wit'lik nk'u'j awi'j okyinqtel awoksla'. Wetz web'en, yatz oqtel ak'ulu' mas twitz te aj nxik nq'uma' yatzni.  
\v 22 Intqet ak'ulu' jun nwatb'il tuj ajay tzan tpaj lo'ik nk'u'j okyinpoyon etuky'i'l tzan tpaj exnaq'tzb'en wi'j. 
\s1 Jun Kawb'il 
\p  
\v 23 Ntons, jun limb'il te yatz tzan Pa'xh, jun wuky'i'l tuj ja presni tzan tpaj [tpakb'en ti'j] Kristo Jesus.  
\v 24 Ax jun limb'il tzan te Mak, Aristark, Démas, b'ix Luks, a'e' aj nkye'onen wuky'i'l. 
\p  
\v 25 Bwen, Qajaw Jesukrist tzaj sinxwit tuj etanim jun nim b'an galan.