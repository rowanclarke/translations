\v 13 \w Je|strong="G2532"\w* \w ne|strong="G3756"\w* \w veux|strong="G2309"\w* \w pas|strong="G3756"\w* \w vous|strong="G5210"\w* \w laisser|strong="G5210"\w* ignorer, \w frères|strong="G2532"\w*, \w que|strong="G3754"\w* \w je|strong="G2532"\w* \w me|strong="G4314"\w* \w suis|strong="G2064"\w* \w souvent|strong="G4178"\w* proposé \w d|strong="G1722"\w*’\w aller|strong="G2064"\w* \w vous|strong="G5210"\w* \w voir|strong="G2064"\w*, — \w mais|strong="G1161"\w* \w j|strong="G1161"\w*’\w en|strong="G1722"\w* \w ai|strong="G2192"\w* \w été|strong="G3756"\w* \w empêché|strong="G2967"\w* jusqu’\w ici|strong="G4314"\w*, — \w afin|strong="G2443"\w* \w de|strong="G2532"\w* \w recueillir|strong="G2192"\w* \w aussi|strong="G2532"\w* \w quelques|strong="G5100"\w* \w fruits|strong="G2590"\w* \w parmi|strong="G1722"\w* \w vous|strong="G5210"\w*, \w comme|strong="G2531"\w* \w parmi|strong="G1722"\w* \w les|strong="G2532"\w* \w autres|strong="G3062"\w* \w nations|strong="G1484"\w*\f + \fr 1:13 \ft Voy. 15, 20 sv.\f*.  
