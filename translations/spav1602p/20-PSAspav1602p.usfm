\id PSA Psalms
\h Salmos
\toc1 Salmos
\toc2 Salmos
\mt1 Salmos
\c 1
\m 
\v 1 BIENAVENTURADO \add es\add* \w el|strong="H3427"\w* varón \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w anda|strong="H1980"\w* \w en|strong="H5975"\w* \w consejo|strong="H6098"\w* de \w impíos|strong="H7563"\w*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* para \w en|strong="H5975"\w* \w camino|strong="H1870"\w* de \w pecadores|strong="H2400"\w*, \w ni|strong="H3808"\w* \w en|strong="H5975"\w* silla de escarnecedores \w se|strong="H3808"\w* sienta.
\m 
\v 2 \w Pero|strong="H3588"\w* \w su|strong="H3588"\w* \w deleite|strong="H2656"\w* \add está\add* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w ley|strong="H8451"\w* del \w SEÑOR|strong="H3068"\w*; \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w ley|strong="H8451"\w* \w medita|strong="H1897"\w* \w de|strong="H3588"\w* \w día|strong="H3119"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w noche|strong="H3915"\w*.
\m 
\v 3 \w Y|strong="H3068"\w* \w él|strong="H5921"\w* \w será|strong="H1961"\w* \w como|strong="H1961"\w* un \w árbol|strong="H6086"\w* \w plantado|strong="H8362"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w ríos|strong="H6388"\w* \w de|strong="H5921"\w* \w aguas|strong="H4325"\w*, \w que|strong="H3808"\w* \w da|strong="H5414"\w* su \w fruto|strong="H6529"\w* \w en|strong="H5921"\w* su \w tiempo|strong="H6256"\w*; su hoja \w tampoco|strong="H3808"\w* \w se|strong="H1961"\w* marchitará; \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w hace|strong="H6213"\w* \w prosperará|strong="H6743"\w*.
\m 
\v 4 \w No|strong="H3808"\w* \w así|strong="H3651"\w* \w los|strong="H3588"\w* \w impíos|strong="H7563"\w*: \w sino|strong="H3588"\w* \w como|strong="H3588"\w* \w el|strong="H3588"\w* tamo \w que|strong="H3588"\w* arrebata \w el|strong="H3588"\w* \w viento|strong="H7307"\w*.
\m 
\v 5 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w* \w no|strong="H3808"\w* resistirán \w los|strong="H5921"\w* \w impíos|strong="H7563"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w juicio|strong="H4941"\w*, \w ni|strong="H3808"\w* \w los|strong="H5921"\w* pecado­res \w en|strong="H5921"\w* \w la|strong="H5921"\w* congregación \w de|strong="H5921"\w* \w los|strong="H5921"\w* jus­tos.
\m 
\v 6 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w* \w conoce|strong="H3045"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w justos|strong="H6662"\w*; \w pero|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w impíos|strong="H7563"\w* perecerá.
\c 2
\m 
\v 1 ¿\w POR|strong="H4100"\w* \w qué|strong="H4100"\w* \w se|strong="H4100"\w* enfurecen los paganos, y los \w pueblos|strong="H3816"\w* ima­ginan cosas vanas?
\m 
\v 2 \w Se|strong="H5921"\w* pondrán \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w los|strong="H5921"\w* gobernadores \w consultarán|strong="H3245"\w* \w unidos|strong="H3162"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*, \w y|strong="H5921"\w* \w contra|strong="H5921"\w* su \w ungido|strong="H4899"\w*, \add diciendo\add*:
\m 
\v 3 \w Rompamos|strong="H5423"\w* sus \w ataduras|strong="H4147"\w*, y echemos \w de|strong="H4480"\w* nosotros sus cuer­das.
\m 
\v 4 \w El|strong="H3427"\w* que se sienta en \w los|strong="H3427"\w* \w cielos|strong="H8064"\w* se reirá; \w el|strong="H3427"\w* Señor se burlará de ellos.
\m 
\v 5 Entonces \w hablará|strong="H1696"\w* \w a|strong="H3068"\w* ellos en su \w ira|strong="H2740"\w*, y los vejará en su doloroso disgusto.
\m 
\v 6 Pero yo he puesto \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w Sión|strong="H6726"\w*, \w mi|strong="H5921"\w* \w monte|strong="H2022"\w* \w santo|strong="H6944"\w*.
\m 
\v 7 Yo declararé \w el|strong="H1121"\w* decreto: \w el|strong="H1121"\w* \w SEÑOR|strong="H3068"\w* me ha dicho: Mi \w Hijo|strong="H1121"\w* \add eres\add* tú; este \w día|strong="H3117"\w* yo te he engendrado.
\m 
\v 8 \w Pídeme|strong="H7592"\w*, y \add te\add* \w daré|strong="H5414"\w* los paganos \w para|strong="H4480"\w* \add tu\add* \w heredad|strong="H5159"\w*, y los fines \w de|strong="H4480"\w* la tierra \w para|strong="H4480"\w* \add tu\add* \w posesión|strong="H5159"\w*.
\m 
\v 9 Quebrantarlos has con \w vara|strong="H7626"\w* de \w hierro|strong="H1270"\w*: como \w vaso|strong="H3627"\w* de alfarero los destrozarás en pedazos.
\m 
\v 10 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, oh \w reyes|strong="H4428"\w*, sed sabios: sed instruidos, \w jueces|strong="H8199"\w* de la tierra.
\m 
\v 11 \w Servid|strong="H5647"\w* al \w SEÑOR|strong="H3068"\w* con \w temor|strong="H3374"\w*, y regocijaos con \w temblor|strong="H7461"\w*.
\m 
\v 12 Besad al \w Hijo|strong="H1248"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H6435"\w* \w se|strong="H6435"\w* enoje, \w y|strong="H3588"\w* perezcáis del \w camino|strong="H1870"\w*, \w cuando|strong="H3588"\w* \w se|strong="H6435"\w* encendiere un \w poco|strong="H4592"\w* \w su|strong="H3588"\w* ira. Bienaventurados \add son\add* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* ponen \w su|strong="H3588"\w* confianza \w en|strong="H3588"\w* \w él|strong="H3588"\w*.
\c 3
\d Salmo de David, cuando huía de delante de Absalom su hijo.
\m 
\v 1 ¡Señor, cuánto se han aumentado mis enemi­gos! muchos se levantan \w contra|strong="H6440"\w* mí.
\m 
\v 2 \w Muchos|strong="H7227"\w* \add hay\add* \w que|strong="H4100"\w* dicen \w de|strong="H5921"\w* \w mi|strong="H5921"\w* alma, \w No|strong="H5921"\w* \add hay\add* \w para|strong="H5921"\w* \w él|strong="H5921"\w* ayuda \w en|strong="H5921"\w* \w Dios|strong="H3068"\w*. Selah.
\m 
\v 3 Pero tú, oh SEÑOR, \add eres\add* escu­do para \w mí|strong="H5315"\w*: \w mi|strong="H5315"\w* gloria, y el que ensalza \w mi|strong="H5315"\w* cabeza.
\m 
\v 4 Con mi voz clamé \w al|strong="H1157"\w* \w SEÑOR|strong="H3068"\w*, \w y|strong="H3519"\w* él me oyó de su monte santo. Selah.
\m 
\v 5 Yo me acosté, y dormí, y des­perté; porque el \w SEÑOR|strong="H3068"\w* me sos­tuvo.
\m 
\v 6 \w No|strong="H3588"\w* temeré \w de|strong="H3588"\w* diez millares \w de|strong="H3588"\w* pueblos, \w que|strong="H3588"\w* pusieren cerco \w con|strong="H3588"\w*­tra mí.
\m 
\v 7 Levántate, oh SEÑOR; sálvame, Dios \w mío|strong="H5921"\w*: \w porque|strong="H5921"\w* tú heriste \w a|strong="H3068"\w* todos mis enemigos \add en\add* \w la|strong="H5921"\w* quija­da; \w los|strong="H5921"\w* dientes \w de|strong="H5921"\w* \w los|strong="H5921"\w* impíos \w que|strong="H3808"\w*­brantaste.
\m 
\v 8 \w La|strong="H3605"\w* salvación \add pertenece\add* al \w SEÑOR|strong="H3068"\w*: sobre tu pueblo \add es\add* tu bendi­ción. Selah.
\c 4
\d Al Músico principal: sobre Neginot: Salmo de David.
\m 
\v 1 Óyeme cuando clamo, oh Dios de mi justicia: \add estando\add* en angustia, tú me hiciste ensanchar: ten misericordia de mí, y oye mi oración.
\m 
\v 2 Oh hijos de los hombres, ¿hasta cuándo \add volveréis\add* \w mi|strong="H6030"\w* gloria en vergüenza? ¿\add Hasta cuándo\add* amaréis la vanidad, y buscaréis la mentira? Selah.
\m 
\v 3 Sabed \w pues|strong="H4100"\w*, \w que|strong="H4100"\w* \w el|strong="H1121"\w* SEÑOR ha apartado \w al|strong="H5704"\w* pío \w para|strong="H5704"\w* sí: \w el|strong="H1121"\w* SEÑOR oirá \w cuando|strong="H4100"\w* yo \w a|strong="H3068"\w* \w él|strong="H1121"\w* cla­mare.
\m 
\v 4 Asombraos, \w y|strong="H3588"\w* \w no|strong="H3588"\w* pequéis: conver­sad \w en|strong="H3588"\w* vuestro corazón sobre vuestra cama, \w y|strong="H3588"\w* estad quietos. Selah.
\m 
\v 5 Ofreced sacrificios \w de|strong="H5921"\w* justicia, \w y|strong="H5921"\w* confiad \w en|strong="H5921"\w* \w el|strong="H5921"\w* SEÑOR.
\m 
\v 6 Muchos dicen: ¿Quién nos mostrará el bien? Alza sobre nosotros, oh \w SEÑOR|strong="H3068"\w*, la luz de tu semblante.
\m 
\v 7 Tú has puesto alegría \w en|strong="H5921"\w* \w mi|strong="H5921"\w* corazón, \w más|strong="H5921"\w* \w que|strong="H4310"\w* tienen \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* tiempo \add que\add* incrementó su grano \w y|strong="H5921"\w* su vino.
\m 
\v 8 En paz me acostaré, y asimis­mo dormiré; porque solo tú, SEÑOR, me haces habitar en seguridad.
\c 5
\d Al Músico principal: sobre Nehilot: Salmo de David.
\m 
\v 1 ESCUCHA, oh SEÑOR, mis palabras; considera la meditación mía.
\m 
\v 2 Escucha la voz de mi cla­mor, Rey mío y \w Dios|strong="H3068"\w* mío, por­que \w a|strong="H3068"\w* ti oraré.
\m 
\v 3 Oh SEÑOR, \w de|strong="H3588"\w* mañana oirás mi \w voz|strong="H6963"\w*; \w de|strong="H3588"\w* mañana presenta­ré \add mi oración\add* \w a|strong="H3068"\w* ti, \w y|strong="H3588"\w* miraré arriba.
\m 
\v 4 Porque tú no \add eres\add* un \w Dios|strong="H3068"\w* que se complace en la impiedad, ni la maldad habitará contigo.
\m 
\v 5 \w Los|strong="H3588"\w* necios \w no|strong="H3808"\w* \w se|strong="H3808"\w* pararán \w en|strong="H3588"\w* tu vista: aborreces \w a|strong="H3068"\w* todos \w los|strong="H3588"\w* obreros \w de|strong="H3588"\w* iniquidad.
\m 
\v 6 Destruirás \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w que|strong="H3808"\w* hablan mentira: al hombre sanguinario y al engañador aborrecerá \w el|strong="H3605"\w* SEÑOR.
\m 
\v 7 Pero yo, en la multitud \w de|strong="H1818"\w* tu misericordia entraré \add en\add* tu casa: y adoraré hacia tu santo templo en tu temor.
\m 
\v 8 Guíame, oh SEÑOR, en tu justicia \w a|strong="H3068"\w* causa de mis enemigos; ende­reza delante de mi rostro tu camino.
\m 
\v 9 \w Porque|strong="H6440"\w* \w no|strong="H1870"\w* \add hay\add* en su boca fidelidad; su parte interior es la maldad misma; sepulcro abierto es su garganta; con su lengua lisonjean.
\m 
\v 10 Destrúyelos, oh Dios; caigan \w de|strong="H3588"\w* sus propios consejos: \w por|strong="H3588"\w* \w la|strong="H3588"\w* multitud \w de|strong="H3588"\w* sus transgresiones échalos, \w porque|strong="H3588"\w* se han rebelado contra ti.
\m 
\v 11 \w Pero|strong="H3588"\w* regocíjense \w todos|strong="H7230"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* ti confían; \w que|strong="H3588"\w* clamen siempre \w por|strong="H3588"\w* gozo \w porque|strong="H3588"\w* tú \w los|strong="H3588"\w* defiendes: \w que|strong="H3588"\w* se regocijen \w en|strong="H3588"\w* ti también \w los|strong="H3588"\w* \w que|strong="H3588"\w* aman tu nombre.
\m 
\v 12 \w Porque|strong="H5921"\w* tú, oh SEÑOR, ben­decirás \w al|strong="H5921"\w* justo; \w lo|strong="H5921"\w* cercarás \w con|strong="H5921"\w* favor \w como|strong="H5921"\w* \add con\add* un escu­do.
\c 6
\d Al Músico principal: en Neginot sobre Seminit: Salmo de David.
\m 
\v 1 OH SEÑOR, \w no|strong="H5921"\w* \w me|strong="H5921"\w* reprendas \w en|strong="H5921"\w* tu enojo, ni \w me|strong="H5921"\w* castigues \w con|strong="H5921"\w* tu disgusto enardecido.
\m 
\v 2 Ten misericordia de mí, oh \w SEÑOR|strong="H3068"\w*, \w porque|strong="H3198"\w* yo \add soy\add* débil: Sáname, oh \w SEÑOR|strong="H3068"\w*, por­que mis huesos están perturbados.
\m 
\v 3 Mi alma asimismo está muy perturbada: \w y|strong="H3588"\w* tú, oh \w SEÑOR|strong="H3068"\w*, ¿hasta \w cuándo|strong="H3588"\w*?
\m 
\v 4 Vuelve, oh \w SEÑOR|strong="H3068"\w*, libra \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*; sálvame \w por|strong="H5704"\w* causa \w de|strong="H5704"\w* tu misericor­dia.
\m 
\v 5 \w Porque|strong="H4616"\w* en la muerte no \add hay\add* memoria de ti: ¿quién \w te|strong="H5315"\w* \w dará|strong="H7725"\w* gracias en el sepulcro?
\m 
\v 6 Estoy fatigado \w con|strong="H3588"\w* mi gemido; toda \w la|strong="H3588"\w* noche inundo mi cama; Riego mi lecho \w con|strong="H3588"\w* mis lágrimas.
\m 
\v 7 Mis ojos están consumidos por dolor. Se envejecen \w a|strong="H3068"\w* causa de \w todos|strong="H3605"\w* mis enemigos.
\m 
\v 8 Apartaos \w de|strong="H5869"\w* mí, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* obra­dores \w de|strong="H5869"\w* iniquidad; porque \w el|strong="H3605"\w* SEÑOR ha oído \w la|strong="H3605"\w* voz \w de|strong="H5869"\w* mi lloro.
\m 
\v 9 \w El|strong="H3588"\w* \w SEÑOR|strong="H3068"\w* ha \w oído|strong="H8085"\w* mi súplica; recibirá \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w* mi \w ora|strong="H3588"\w*­ción.
\m 
\v 10 Sean avergonzados y dolorosamente afligidos todos mis enemigos: que se vuelvan \add y\add* sean avergonzados súbitamente.
\c 7
\d Sigaión de David, que cantó al SEÑOR sobre las palabras de Cus, hijo de Benjamín.
\m 
\v 1 OH \w SEÑOR|strong="H3068"\w* \w Dios|strong="H3068"\w* \w mío|strong="H5921"\w*, \w en|strong="H5921"\w* \w ti|strong="H5921"\w* pongo \w mi|strong="H5921"\w* confianza: sálvame \w de|strong="H5921"\w* todos \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w me|strong="H5921"\w* persiguen, \w y|strong="H5921"\w* líbrame;
\m 
\v 2 No sea \w que|strong="H3605"\w* desgarre mi \w alma|strong="H3605"\w* como león, despedazándola, sin \w que|strong="H3605"\w* \add haya\add* \w quien|strong="H3605"\w* \w libre|strong="H5337"\w*.
\m 
\v 3 Oh SEÑOR Dios mío, \w si|strong="H6435"\w* \w yo|strong="H5315"\w* he \w hecho|strong="H5315"\w* esto, \w si|strong="H6435"\w* hay en mis manos iniquidad;
\m 
\v 4 \w Si|strong="H3426"\w* he recompensado mal al que estaba en paz \w conmigo|strong="H6213"\w*, (hasta he libertado al que sin causa era mi enemigo;)
\m 
\v 5 Persiga el \w enemigo|strong="H6887"\w* mi alma, y llévesela; sí, que pise en tierra mi vida, y mi honra ponga en el polvo. Selah
\m 
\v 6 Levántate, oh SEÑOR, con tu enojo, álzate \w a|strong="H3068"\w* causa de la furia de mis enemigos, \w y|strong="H3519"\w* despierta en favor mío el juicio \add que\add* has mandado.
\m 
\v 7 Así te rodeará la congregación del pueblo; entonces vuélvete en lo alto por su causa.
\m 
\v 8 \w El|strong="H5921"\w* SEÑOR juzgará \w los|strong="H5921"\w* pue­blos: júzgame, oh SEÑOR, \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* justicia \w y|strong="H5921"\w* \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* integridad \add que está\add* \w en|strong="H5921"\w* \w mí|strong="H5921"\w*.
\m 
\v 9 Oh deja \w que|strong="H5921"\w* acabe \w la|strong="H5921"\w* iniquidad \w de|strong="H5921"\w* \w los|strong="H5921"\w* inicuos: pero establece \w al|strong="H5921"\w* justo; pues \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* justo prueba \w los|strong="H5921"\w* corazones \w y|strong="H5921"\w* \w las|strong="H5921"\w* entrañas.
\m 
\v 10 \w Mi|strong="H4994"\w* defensa \add es\add* \w de|strong="H6662"\w* Dios, \w que|strong="H4994"\w* salva \w a|strong="H3068"\w* los rectos \w de|strong="H6662"\w* \w corazón|strong="H3826"\w*.
\m 
\v 11 Dios juzga \w a|strong="H3068"\w* \w los|strong="H5921"\w* justos, \w y|strong="H5921"\w* Dios \w está|strong="H5921"\w* enojado todos \w los|strong="H5921"\w* días \add contra el impío\add*.
\m 
\v 12 Si no se volviere, \w él|strong="H3605"\w* afilará su espada: tensado tiene su arco, y \w lo|strong="H3605"\w* ha preparado.
\m 
\v 13 Asimismo \w ha|strong="H3808"\w* aparejado para él los instrumentos de muerte; él \w ordena|strong="H3559"\w* sus saetas contra los perseguidores.
\m 
\v 14 He aquí, él sufre dolores de parto con iniquidad, y concibió maldad y parió falsedad.
\m 
\v 15 Un pozo hizo, y lo cavó; y en la fosa \add que\add* hizo ha caído.
\m 
\v 16 Su maldad se tornará sobre su propia cabeza, y su trato violento descenderá sobre su propia mollera.
\m 
\v 17 Alabaré yo \w al|strong="H5921"\w* SEÑOR confor­\w me|strong="H5921"\w* \w a|strong="H3068"\w* su justicia, \w y|strong="H5921"\w* cantaré alabanza \w al|strong="H5921"\w* nombre \w del|strong="H5921"\w* SEÑOR Altísimo.
\c 8
\d Al Músico principal: sobre Gitit: Salmo de David.
\m 
\v 1 OH SEÑOR, Señor nuestro, ¡cuán excelente \add es\add* tu nombre \w en|strong="H5921"\w* \w toda|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w que|strong="H5921"\w* has puesto tu gloria \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* cielos!
\m 
\v 2 \w De|strong="H5921"\w* \w la|strong="H5921"\w* boca \w de|strong="H5921"\w* \w los|strong="H5921"\w* chiquitos \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H4100"\w* maman, ordenaste fuerza \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* tus enemigos, \w para|strong="H5921"\w* hacer cesar \w al|strong="H5921"\w* enemigo \w y|strong="H5921"\w* \w al|strong="H5921"\w* vengador.
\m 
\v 3 Cuando considero tus cielos, la obra de tus dedos, la luna \w y|strong="H5797"\w* las estrellas, \w que|strong="H6310"\w* tú ordenaste:
\m 
\v 4 ¿\w Qué|strong="H3588"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* hombre, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* acuerdes \w de|strong="H3588"\w* \w él|strong="H3588"\w*, \w y|strong="H3588"\w* \w el|strong="H3588"\w* hijo del hombre, \w que|strong="H3588"\w* lo visites?
\m 
