\v 10 \w The|strong="H5921"\w* Supreme \w Priest|strong="H3548"\w* \w is|strong="H3027"\w* \w the|strong="H5921"\w* \w one|strong="H3808"\w* \w among|strong="H5921"\w* \w his|strong="H5921"\w* relatives \w who|strong="H3548"\w* \w has|strong="H3027"\w* \w been|strong="H3808"\w* \add appointed for that work\add* \w by|strong="H3027"\w* \w having|strong="H3808"\w* \w his|strong="H5921"\w* \w head|strong="H7218"\w* \w anointed|strong="H4888"\w* \w with|strong="H4390"\w* \w olive|strong="H8081"\w* \w oil|strong="H8081"\w*. \w He|strong="H3027"\w* \w is|strong="H3027"\w* \w also|strong="H3027"\w* \w the|strong="H5921"\w* \w one|strong="H3808"\w* \w who|strong="H3548"\w* \w has|strong="H3027"\w* \w been|strong="H3808"\w* appointed \w to|strong="H5921"\w* \w wear|strong="H3847"\w* \w the|strong="H5921"\w* special garments \w that|strong="H3548"\w* \w priests|strong="H3548"\w* \w wear|strong="H3847"\w*. \w He|strong="H3027"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* allow \w the|strong="H5921"\w* \w hair|strong="H7218"\w* \w on|strong="H5921"\w* \w his|strong="H5921"\w* \add head\add* \w to|strong="H5921"\w* \w remain|strong="H3808"\w* uncombed, \w and|strong="H1419"\w* \w he|strong="H3027"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* \w tear|strong="H6533"\w* \w his|strong="H5921"\w* \w clothes|strong="H3847"\w* \add when he is mourning for someone\add*.
\v 11 \w He|strong="H3605"\w* \w must|strong="H4191"\w* \w not|strong="H3808"\w* enter \w some|strong="H3605"\w* \w place|strong="H3605"\w* \w where|strong="H5921"\w* \w there|strong="H3605"\w* \w is|strong="H5315"\w* \w a|strong="H3068"\w* \w corpse|strong="H5315"\w*. \w He|strong="H3605"\w* \w must|strong="H4191"\w* \w not|strong="H3808"\w* \w do|strong="H3605"\w* \w that|strong="H3605"\w* \w and|strong="H4191"\w* cause \w himself|strong="H5315"\w* \w to|strong="H4191"\w* \w become|strong="H2930"\w* unfit \w for|strong="H5921"\w* \w his|strong="H3605"\w* work, \w even|strong="H3808"\w* if \w it|strong="H5921"\w* \w is|strong="H5315"\w* \w his|strong="H3605"\w* father \w or|strong="H3808"\w* \w his|strong="H3605"\w* mother \w who|strong="H3605"\w* \w has|strong="H5315"\w* \w died|strong="H4191"\w*.
