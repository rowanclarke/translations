\p
\v 1 \w Entonces|strong="G1161"\w* \w los|strong="G3588"\w* apóstoles \w y|strong="G2532"\w* \w los|strong="G3588"\w* hermanos \w de|strong="G2596"\w* \w Judea|strong="G2449"\w* supieron \w que|strong="G3754"\w* \w también|strong="G2532"\w* \w los|strong="G3588"\w* gentiles \w recibieron|strong="G1209"\w* \w la|strong="G3588"\w* \w Palabra|strong="G3056"\w* \w de|strong="G2596"\w* \w Dios|strong="G2316"\w*.  
\v 2 \w Cuando|strong="G3753"\w* \w Pedro|strong="G4074"\w* subió \w a|strong="G1519"\w* Jerusalén, \w los|strong="G3588"\w* judíos disputaban \w con|strong="G4314"\w* \w él|strong="G3588"\w*:  
\v 3 ¡\w Entraste|strong="G1525"\w* \w a|strong="G4314"\w* \add la casa de\add* \w los|strong="G3748"\w* gentiles \w y|strong="G2532"\w* comiste \w con|strong="G4314"\w* ellos!   
