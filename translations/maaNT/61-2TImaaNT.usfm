\id 2TI
\h 2 Timoteo
\toc1 Xo̱jo̱n carta‑la̱ San Pablo xi ma‑ne jò xi kiskiì‑la̱ Timoteo
\toc2 2 Timoteo
\toc3 2 Ti.
\mt1 Xo̱jo̱n carta‑la̱ San Pablo xi ma‑ne jò xi kiskiì‑la̱ Timoteo
\c 1
\s1 Kó tsò Pablo nga síhixat'aà Timoteo
\p 
\v 1 'A̱n, Pablo, tìkjiì‑lè xo̱jo̱n jè. Nga 'a̱n tsibíxáya‑na Jesucristo nga k'oa̱á s'ín kjòmejèn‑la̱ Nainá. K'oa̱á s'ín kitsjaà tso'ba Nainá nga kíjnakon ini̱ma̱‑ná i̱t'aà ts'e̱ Cristo Jesús.
\v 2 Ngaji̱ Timoteo xi 'ñó matsjake̱‑lè koni tsà ki'ndí ts'a̱n xan‑lè, Nainá xi Na̱'èn‑ná ko̱ Na̱'èn‑ná Jesucristo kàtatsjá‑lè kjo̱ndaà, kàtahi̱ma̱keè‑lè, kàtas'e‑la̱ kjoa̱'nchán i̱jiìn ini̱ma̱‑lè.
\s1 'Én xi tsjá Pablo i̱t'aà ts'e̱ Cristo
\p 
\v 3 Mìkiì jchàajiìn‑na ko̱ na̱chrjein ko̱ ni̱tje̱n bìtsi'batjì‑lè ti̱koa̱ tsjaà‑la̱ kjo̱ndaà Nainá, jè xi 'a̱n bexkoán koni s'ín kijtseèxkón jñà xi̱ta̱ jchínga‑na̱ nga nguì tsjeè tjín kjo̱hítsjeèn‑na̱.
\v 4 K'e̱ nga bítsjeèn‑na kjoa̱ ts'e̱ ndáxkoiìn mejèn‑na nga skoeè ìjngoò k'a‑lè mé‑ne nga ko̱tsja‑la̱ ini̱ma̱‑na̱.
\v 5 Bítsjeèn‑na nga nguì ndaà mokjeiín‑lè i̱t'aà ts'e̱ Cristo koni s'ín kòkjeiín ítjòn‑la̱ nea̱ájchá‑lè Loida ko̱ nea̱‑lè Eunice. 'A̱n k'oa̱á s'ín makixi̱‑na nga ngaji̱ ti̱koa̱á ndaà mokjeiín‑lè.
\p 
\v 6 Koií k'oa̱s'ín tìsìkítsjeèn‑lè nga ìsa̱ ndaà ti̱kjiín kjo̱tjò xi kitsjaà‑lè Nainá nga ndaà ti̱xá‑la̱, jè kjo̱tjò xi kitjoé‑lè k'e̱ nga 'a̱n tsakàsòn‑lè ndsa̱a.
\v 7 Nainá, mìtsà ini̱ma̱ tsakjón kitsjaà‑ná. Jè kitsjaà‑ná Ini̱ma̱ Tsjeè‑la̱ nga tsjá‑ná nga'ñó, nga tsjá‑ná kjoa̱tjòcha, nga tsjá‑ná kjo̱hítsjeèn kós'ín s'e̱én nga kixi̱ si̱jchá yijo‑ná.
\v 8 Koií kjoa̱‑la̱ kì masobà‑lè nga nokjoàkoi̱i xi̱ta̱ i̱t'aà ts'e̱ Na̱'èn‑ná Jesucristo. Ti̱koa̱ kì masobà‑lè xi i̱t'aà ts'a̱n nga nda̱yá tíjna'ya koií kjoa̱‑la̱ nga ya̱ sìxát'aà‑la̱ Na̱'èn‑ná. Ti̱kjeiín‑ko̱‑ná kjo̱'in xi i̱t'aà ts'e̱ 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo. Jè Nainá tsjá‑lè nga'ñó xi ko̱chjeén‑lè.
\v 9 Nainá, jyeé tsachrjekàjiìn‑ná kjo̱'in. K'oa̱á s'ín kiìchja̱‑ná nga tsjeè si̱jchá yijo‑ná. Mìtsà koi kjoa̱‑la̱ nga ndaà ki'né. Koi‑né nga k'oa̱s'ín kjòmejèn‑la̱ Nainá ti̱koa̱ kitsjaà‑ná kjo̱ndaà‑la̱ xi i̱t'aà ts'e̱ Cristo skanda ti̱sa̱ tàts'en‑la̱ kjoa̱ k'e̱ nga ti̱kj'eè sindaà i̱sò'nde.
\v 10 I̱'ndei̱ Nainá jyeé tsakó kjo̱ndaà‑la̱ nga jyeé j'iì Jesucristo xi ochrjekàjiìn‑ná kjo̱'in. Jaàxìn‑ná nga'ñó‑la̱ kjoa̱biyaà. Xi i̱t'aà ts'e̱ 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo, tsakó‑ná kjoa̱binachon ti̱koa̱ tsakó‑ná nga mìtsà jngoò k'a ki̱yá ni̱ta̱ kjé‑ne.
\p 
\v 11 Nainá, 'a̱án kisìnga̱tsja‑na xá jè nga 'a̱n kichjàya 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo. Tsibíxáya‑na i̱t'aà ts'e̱ xá‑la̱ nga 'a̱n kokoòya‑la̱ jñà xi mìtsà xi̱ta̱ judío.
\v 12 Tseé kjo̱'in tìsìkjiaán tà jè nga̱tjì‑la̱ 'én xi 'a̱n chjàya. Ta̱nga mìkiì masobà‑na. Jyeé tíjiìn‑na nga i̱t'aà ts'e̱ Cristo mokjeiín‑na. Ti̱koa̱á ndaà tíjiìn‑na nga ta̱ jngoò jè Nainá xi tjín‑la̱ nga'ñó. Ndaà si̱ìkinda̱ jè xá xi 'a̱n kisìnga̱tsja‑na skanda jè na̱chrjein k'e̱ nga kjoi̱í ìjngoò k'a‑ne Jesucristo.
\p 
\v 13 Ndaà tíjiìn takoìn 'én ndaà xi 'a̱n tsakoòya‑lè koni s'ín tjín 'én xi mokjeiín‑ná ko̱ kjoa̱tjòcha xi tjín‑ná nga Cristo titsa̱jnakoa̱á.
\v 14 Ndaà ti̱kitasoìn xá ndaà xi ji̱ kjònga̱tsjei. Jè si̱ìchját'aà‑lè Ini̱ma̱ Tsjeè‑la̱ Nainá xi tíjnajiìn ini̱ma̱‑ná.
\p 
\v 15 Jyeé tíjiìn‑lè ngats'iì xi títsa̱jna nangui Asia, jyeé kitsjeiìn takòn‑na, koni jè Figelo ko̱ Hermógenes.
\v 16 Nainá kàtahi̱ma̱keè xi̱ta̱ ni'ya‑la̱ Onesíforo. Kjìn k'a j'iì síjehikon‑na. Mìkiì kjòsobà‑la̱ na̱s'ín nda̱yá tíjna'ya.
\v 17 Tà sa̱á, k'e̱ nga j'iì i̱ Roma skanda mìkiì kisìkjáya nga 'ñó tsohótsji‑na skanda kó nga kisakò‑la̱ ñánda tìjna̱a.
\v 18 Na̱'èn‑ná kàtahi̱ma̱keè jè Onesíforo k'e̱ nga ki̱jchò na̱chrjein‑la̱ Nainá. Ngaji̱ jyeé ndaà tíjiìn‑lè, ndaà kisìchját'aà‑ná ján Éfeso.
\c 2
\s1 Timoteo, jngoò soldado‑la̱ Cristo xi ndaà síxá‑la̱
\p 
\v 1 Ngaji̱ Timoteo koni tsà ki'ndí ts'a̱n xan‑lè, tjiì‑la̱ nga'ñó yijo‑lè i̱t'aà ts'e̱ kjo̱ndaà xi tsjá Jesucristo nga jè titsa̱jnakoa̱á.
\v 2 Jè 'én xi kina'yà‑ná nga kichjàya nguixko̱n nga kjìn ma xi̱ta̱ xi kiì'nchré, k'oa̱á s'ín ta̱kóya‑la̱ xi xi̱ta̱ kixi̱ xi ndaà ma‑la̱ okóya mé‑ne k'oa̱ ti̱s'ín ko̱kòya ngajo‑la̱ xi̱ta̱ xi kj'ei̱í.
\p 
\v 3 Ngaji̱ Timoteo, ti̱kjeiín‑ko̱‑ná kjo̱'in nga ndaà mìt'aà‑la̱ Jesucristo koni jngoò soldado xi síkjeiín kjo̱'in.
\v 4 Jngoò xi̱ta̱ xi soldado síkitasòn mìkiì tjí'nde‑la̱ nga kj'ei̱í xá skóngajiìn xi tjín i̱sò'nde, tjínè‑la̱ nga ya̱ si̱kitasòn‑la̱ jè xi kitsjaà‑la̱ xá mé‑ne nga ndaà kíjnako̱.
\v 5 K'oa̱á ti̱s'ín tjín jè ts'e̱ xi̱ta̱ xi síská. Tsà mì kixi̱í si̱ìská koni s'ín tjín kjo̱tíxoma‑la̱ mìkiì tjoé‑la̱ chjí‑la̱.
\v 6 Xi̱ta̱ xi bínè‑la̱ yijo‑la̱ nga ndaà síxá nga bítje̱ tsojmì tjè, k'e̱ nga jye ko̱jchá tsojmì, jè tjoé ítjòn chiba‑la̱ tsojmì xi majchá koni tsà chjí‑la̱.
\v 7 Ti̱kítsjiìn koni s'ín tìxan‑lè. Jè Nainá ìsa̱ ndaà tsjáya yije‑lè kjo̱hítsjeèn.
\p 
\v 8 Ti̱kítsjiìn i̱t'aà ts'e̱ Jesucristo, jè xi jaáyajiìn‑la̱ mik'en xi tje̱‑la̱ xi̱ta̱xá ítjòn xi David ki'mì. K'oa̱á tsò 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo xi 'a̱n chjàya.
\v 9 Koií kjoa̱‑la̱ 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo xi 'a̱n chjàya, tìsìkjiaán kjo̱'in skanda na'ñó ki̱cha̱ tjít'aà'ñoá nga tìjna̱'ya nda̱yá koni jngoò xi̱ta̱ xi 'ñó ts'e̱n. Ta̱nga jè 'én‑la̱ Nainá mìtsà tjít'aà'ñó i̱ya nda̱yá.
\v 10 Koií kjoa̱‑la̱ tìsìkjiaán yije kjo̱'in xi kjo̱ndaà ts'e̱ xi̱ta̱ xi xó jaàjiìn‑ne Nainá mé‑ne nga ti̱koa̱ ki̱tjokàjiìn‑ne kjo̱'in xi i̱t'aà ts'e̱ Cristo Jesús; s'e̱é‑la̱ kjoa̱jeya xi mìkiì fehet'aà ni̱ta̱ kjé‑ne.
\p 
\v 11 'Én koi, 'én kixi̱‑ne nga tsò:
\q1 Nga ya̱ k'en‑koa̱á Cristo, ti̱koa̱á ya̱á ki̱tsa̱jnakon‑koa̱á.
\q1 
\v 12 Tsà chíkjoa̱‑ná kjo̱'in ti̱koa̱á ya̱á ko̱ti̱xomakoa̱á Cristo.
\q1 Tsà kixoán mìkiì bexkoan, jè k'oa̱á ti̱ ki̱tso̱‑ná mìkiì bexkoan.
\q1 
\v 13 Tsà mìkiì si̱kitasoán 'én xi nokjoá, ta̱nga Nainá síkitasòn 'én xi chja̱.
\q1 Mìkiì ko̱ma si̱ìkjatjìya 'én‑la̱.
\s1 Jngoò xi̱ta̱ xi ndaà síxá‑la̱ Cristo
\p 
\v 14 Ti̱kítsjeèn‑la̱ kjoa̱ koi. Ti̱nókjoa̱koi̱i nga nguixko̱n Nainá mé‑ne nga mì ko̱hótiya‑ne kjoa̱ ts'e̱ 'én. Jè kjoa̱ xi chitiya‑ne ni̱mé chjí‑la̱. Ta̱ sa̱á síkits'ón xi̱ta̱ xi 'nchré.
\v 15 'Ñó ndaà tjínè‑la̱ yijo‑lè mé‑ne nga ndaà ki̱jna‑ne nga nguixko̱n Nainá. Ni̱mé xi ko̱sobà‑lè nga ndaà tjín xá‑lè koa̱ ndaà okoòyi 'én kixi̱‑la̱ Cristo.
\v 16 Kì ta̱xki̱ nokjoà‑jèn 'én xi mìkiì sasén‑la̱ Nainá xi ni̱mé chjí‑la̱. Jñà xi̱ta̱ xi k'oa̱s'ín chja̱, ìsa̱á 'ñó binchat'aàxìn‑ìsa‑la̱ Nainá.
\v 17 Jñà 'én xi ch'o tsò k'oa̱á ngaya‑la̱ koni ch'in nchikòn xi bi'ndo‑ne yijo‑ná. K'oa̱á s'ín chja̱ Himeneo ko̱ Fileto
\v 18 nga jyeé chinchat'aàxìn‑la̱ xi kjoa̱kixi̱ nga tsò: “Jè kjoa̱ xi faáya‑la̱ mik'en jyeé tsato‑né.” K'oa̱á ma‑ne sískáya i'nga‑la̱ xi̱ta̱ kjoa̱ xi mokjeiín‑la̱.
\v 19 Ta̱nga Nainá jyeé tsibíjna'ñó tàts'en jngoò kjoa̱kixi̱ ñánda tjít'aà 'én xi tsò: “Nainá beèxkon‑né xi xi̱ta̱ ts'e̱”; ngats'iì xi tsò: “'A̱n, xi̱ta̱‑la̱ Cristo‑ná, kàtinchat'aàxìn‑la̱ kjoa̱ xi ch'o tjín.”
\p 
\v 20 Jngoò ni'ya xi je kji, tjín tsojmì xi oro ko̱ plata. Ti̱koa̱á tjín tsojmì xi yá ko̱ xi ni'nde. Tjín tsojmì xi na̱chrjein nchijòn mochjeén koa̱ tjín xi tà k'e̱ mochjeén k'e̱ nga ndaà tíma.
\v 21 Tsà si̱tsjeé kjo̱hítsjeèn‑ná nga ki̱nchat'aàxìn‑lá kjoa̱ xi ch'o tjín, k'oa̱á s'ín si̱ìkjeén‑ná Nainá koni tsojmì tsjeè xi tà k'e̱ mochjeén k'e̱ nga ndaà tíma. Titsa̱jnandaà nga si̱kitasoán ni̱ta̱ mé xá‑la̱ Nainá xi ndaà tjín.
\p 
\v 22 Ngaji̱ Timoteo, ti̱si̱t'aàxìn‑la̱ kjo̱hítsjeèn‑la̱ i̱xti xi ch'o tjín. Koií t'in tji̱ngui‑la̱ xi kjoa̱kixi̱, ko̱ kjoa̱ xi mokjeiín‑ná i̱t'aà ts'e̱ Cristo, ko̱ kjoa̱tjòcha, ko̱ kjoa̱'nchán takòn. K'oa̱s'ín t'in tji̱ngui‑la̱ kjoa̱ koi ko̱ xi̱ta̱ xi tsjeè tjín ini̱ma̱‑la̱ nga chja̱t'aà‑la̱ Nainá.
\v 23 Kì kjoa̱ nchi̱kón nìs'in‑la̱ xi ni̱mé chjí‑la̱. Jyeé ndaà tíjiìn‑lè nga kjoa̱siì ótsji.
\v 24 Jngoò chi̱'nda‑la̱ Nainá mìkiì mochjeén nga kjoa̱siì skóngajiìn. Ndaà kàtasìko̱ yije xi̱ta̱. Kàtìjnandaà nga ko̱kòya 'én‑la̱ Nainá. Kàtas'e‑la̱ kjoa̱tsetakòn mé kjoa̱ xi mat'in.
\v 25 Ko̱ó kjo̱ndaà‑la̱ kàtasíkixi̱ya jñà xi xi̱ta̱ kondra̱, tsà koi na̱chrjein Nainá tsjá ìsa̱‑la̱ na̱chrjein nga si̱ìkájno jé‑la nga mì ti̱ jé ko̱hótsji‑ne mé‑ne nga ko̱kjeiín‑la̱ xi kjoa̱kixi̱.
\v 26 K'e̱ nga táx'a̱nguì xko̱n, ko̱maá ki̱tjokàjiìn kjoa̱na̱cha̱n‑la̱ nei̱í nga ya̱ tjít'aà'ñó‑la̱ nga k'oa̱s'ín síkitasòn‑la̱ koni s'ín mejèn‑la̱ nei̱í.
\c 3
\s1 Mé kjoa̱ ch'o xi s'i̱in xi̱ta̱ k'e̱ nga tímachrañà nga kjoe̱het'aà na̱chrjein
\p 
\v 1 Ngaji̱ Timoteo, kàtasijiìn‑lè k'e̱ nga tímachrañàt'aà na̱chrjein nga kjoi̱í ìjngoò k'a‑ne Cristo, kjìn sko̱ya kjoa̱ s'e̱ xi mìkiì ndaà tjín.
\v 2 Jñà xi̱ta̱ xi s'e̱, tà yijo‑la̱á 'ñó si̱ìs'in‑la̱; to̱ón 'ñó ko̱tsjakeè; yijo‑la̱á 'ñó ndaà si̱ìkítsa̱jna; xi̱ta̱ 'nga ikoón ko̱ma; ki̱chja̱jno‑la̱ Nainá ko̱ xi̱ta̱; mìkiì kiì'nchréñijon‑la̱ xi̱ta̱ jchínga‑la̱; mìkiì tsjá ngajo‑ne kjo̱ndaà, mìkiì skoe̱xkón Nainá,
\v 3 mìkiì si̱ìtjòkeè xíkjín, jngoò k'a mìkiì si̱ìje‑la̱ ikon, 'én ndiso tsját'in xíkjín, mìkiì si̱ìkinda̱ yijo‑la̱ mé kjoa̱ xi s'i̱in, xi̱ta̱ ch'o ko̱ma, kondra̱á kjoi̱‑la̱ kjoa̱ xi ndaà tjín,
\v 4 kondra̱á kjoi̱‑la̱ amigo‑la̱, mìtsà ítjòn si̱ìkítsjeèn mé kjoa̱ xi s'i̱in, 'ñó 'nga ikon ko̱ma, jè si̱ìtsjakeè kjoa̱ ts'e̱ i̱sò'nde xi sasén‑la̱ yijo‑la̱, mìkiì si̱ìtsjakeè Nainá.
\v 5 K'oa̱á s'ín s'i̱in koni tsà beèxkón Nainá, ta̱nga mìkiì tsjá'nde nga jè nga'ñó‑la̱ Nainá si̱ìxájiìn ini̱ma̱‑la̱.
\p Xi̱ta̱ koi kì kiì nìs'in‑la̱.
\v 6 Jñà xi̱ta̱ koi, ótsji'nde‑la̱ nga fahas'en ni'ya‑la̱ íchjín xi mìkiì beèxkón yijo‑la̱ ko̱ xi tse jé tjín‑la̱ nga ma kona̱cha̱n‑la̱. Íchjín koi, ya̱á fìtji̱ngui‑la̱ kjoa̱ xi ìsa̱ 'ñó ch'o tjín koni s'ín mejèn‑la̱ yijo‑la̱.
\v 7 Kjit'aà na̱chrjein nchikota'yà 'én xi̱tse̱ ta̱nga ni̱jngoò na̱chrjein fahas'en‑jiìn‑la̱ xi nguì kjoa̱kixi̱.
\v 8 Jñà xi̱ta̱ koi, k'oa̱á ti̱s'ín binchahikon‑la̱ xi kjoa̱kixi̱, koni kis'iìn xi̱ta̱ chji̱ne̱ xi ma‑la̱ bíndaà xi ki'mì Janes ko̱ Jambres nga chinchahikon‑la̱ Moisés. Xi̱ta̱ koi, jngoò k'aá ch'o tjín kjo̱hítsjeèn‑la̱. Bitjongui‑né nga nguixko̱n Nainá nga mìkiì mokjeiín‑la̱ xi kjoa̱kixi̱.
\v 9 Ta̱nga mìkiì si̱ìkijne. Ki̱jchò na̱chrjein nga skoe̱ yije xi̱ta̱ kjoa̱ tòndo̱‑la̱. K'oa̱á s'ín jcha̱t'in‑la̱ koni jè Janes ko̱ Jambres.
\s1 Kó tsò Pablo nga bít'in‑la̱ Timoteo nga 'én kixi̱ ko̱kòya
\p 
\v 10 Ta̱nga ji̱ Timoteo k'oa̱á s'ín tì'mìtji̱ngui‑la̱ koni s'ín tsakoòya‑lè, koni s'ín tísíjchá yijo‑na̱, koni s'ín tjín kjo̱hítsjeèn‑na̱ mé kjoa̱ xi tìfitji̱ngui‑la̱. K'oa̱á ti̱s'ín mokjeiín‑lè koni s'ín mokjeiín‑na 'a̱n i̱t'aà ts'e̱ Cristo. K'oa̱á s'ín tjín kjoa̱tsetakòn‑lè ko̱ kjoa̱tjòcha‑lè koni s'ín tjín ts'a̱n. K'oa̱á ti̱s'ín chíkjoa̱ yije‑lè ni̱ta̱ mé kjoa̱‑ne koni 'a̱n.
\v 11 Tíjiìn‑lè koni s'ín tìsìkjiaán kjo̱'in i̱t'aà ts'e̱ Cristo ti̱koa̱ ongatji̱ngui‑na xi̱ta̱ kondra̱ koni s'ín komàt'ian ján na̱xa̱ndá Antioquía, Iconio ko̱ Listra. ¡Ta̱xki̱ toòn kijtseè‑na xi̱ta̱ nga tsangatji̱ngui‑na ta̱nga jè Na̱'èn‑ná tsachrjekàjiìn yije‑na kjoa̱ koi!
\v 12 Kixi̱í kjoa̱, ngats'iì xi mejèn‑la̱ skoe̱xkón Na̱'èn‑ná Jesucristo, k'oa̱á ti̱s'ín s'e̱‑la̱ kondra̱ nga kji̱tji̱nguikeè xi̱ta̱.
\v 13 Ta̱nga jñà xi̱ta̱ xi ch'o s'ín, xi kona̱cha̱n, kjit'aà na̱chrjein, sa̱á 'ñó, sa̱á 'ñó ch'o s'i̱in nga skóna̱cha̱n‑la̱ xi̱ta̱, ta̱nga k'oa̱á ti̱s'ín ko̱mat'in ngajo‑ne nga skóna̱cha̱n‑la̱ xi̱ta̱ xi kj'ei̱í.
\p 
\v 14 Ta̱nga ngaji̱, ndaà kixi̱ tikoi̱i jñà kjoa̱ xi kichìta'yì xi jye k'oa̱s'ín ndaà kòkjeiín‑lè. Jyeé tíjiìn‑lè yá xi̱ta̱ xi tsakóya‑lè.
\v 15 Skanda ti̱k'e̱‑né nga ti̱sa̱ ndí ti titsjoi, kiyaxkoin Xo̱jo̱n Tsjeè‑la̱ Nainá jè xi ko̱ma‑la̱ si̱ìchji̱ne̱‑lè kó s'ín ki̱tjokàjiìn kjo̱'in nga mokjeiín‑lè i̱t'aà ts'e̱ Cristo Jesús.
\v 16 Ngats'iì 'én xi tjít'aà Xo̱jo̱n‑la̱ Nainá, kjo̱hítsjeèn ts'e̱é Nainá nga kitjei. K'oa̱á s'ín mochjeén nga okóya‑ná, nga okó‑ná k'e̱ nga ch'o 'nè, nga síkixi̱yandaà‑ná, nga okó‑ná ndi̱yá kixi̱,
\v 17 mé‑ne jñá xi xi̱ta̱‑la̱ Nainá 'mì‑ná jngoò k'a ndaà ki̱tsa̱jnandaá nga si̱kitasoán yije kjoa̱ xi ndaà tjín.
\c 4
\s1 Kó tsò Pablo nga tíbínè‑la̱ Timoteo nga 'Én‑la̱ Nainá ki̱chja̱
\p 
\v 1 'Ñó tìbìnè‑lè nga nguixko̱n Nainá ko̱ Na̱'èn‑ná Jesucristo jè xi jeya kjoi̱í ìjngoò k'a‑ne koni xi̱ta̱xá ítjòn nga koi̱ìndaàjiìn‑la̱ xi̱ta̱ xi títsa̱jnakon ko̱ xi jye k'en.
\v 2 Ti̱nókjoa̱yi 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo. Ti̱jnandeiì nga kjit'aà na̱chrjein ni̱ta̱ mé kjoa̱ xi tjín. Chi̱koi̱i xi̱ta̱ k'e̱ nga ch'o s'ín; ti̱kixi̱yi; tìt'in‑la̱ nga 'ñó kàt'eé‑la̱ ikon. K'e̱ nga k'oa̱s'ín s'i̱in, tseé t'i̱in takoìn, ko̱ kjo̱ndaà‑lè ta̱kóya‑la̱.
\v 3 Ki̱jchò na̱chrjein k'e̱ nga jñà xi̱ta̱ mì ti̱ kiì ko̱kjeiín‑la̱ nga kji̱'nchré 'én ndaà xi kixi̱ tjín xi jñá okoòyaá i̱t'aà ts'e̱ Cristo. Kjìn maestro ko̱hótsji xi ko̱kòya‑la̱ kjoa̱ xi jñà ko̱mejèn‑la̱ nga kji̱'nchré‑la̱.
\v 4 Ki̱nchat'aàxìn‑la̱ xi kjoa̱kixi̱, koií kji̱t'aà‑la̱ xi ta̱xki̱ cuento jchínga xi mìtsà kixi̱ kjoa̱.
\v 5 Ta̱nga ngaji̱ Timoteo, indaà t'è‑la̱ takoìn ni̱ta̱ mé kjoa̱‑ne, ti̱kjeiín kjoa̱ ts'e̱ kjo̱'in, koi xá t'i̱in nga ti̱ka'bísoìn 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo, ndaà ti̱kitasoìn xá xi ji̱ kjònga̱tsjei.
\p 
\v 6 'A̱n, jye tìtsjaà kjo̱tjò‑la̱ yijo‑na̱ Nainá. Jyeé ijchò na̱chrjein nga ki̱yá.
\v 7 Jyeé ndaà kiskaàn‑tjià xá‑la̱ Cristo; jyeé ndaà kisìkitasoàn xá xi 'a̱n kjònga̱tsja; jyeé ndaà tsohóti̱jnakoa̱a jè 'én xi mokjeiín‑na i̱t'aà ts'e̱ Cristo.
\v 8 I̱'ndei̱, Cristo, xi xi̱ta̱xá kixi̱ tíjna, tíjnatjò jngoò‑la̱ corona ján ngajmiì xi 'a̱n tsjá‑na nga kixi̱ tsohóti̱jnakoa̱a. K'e̱ nga kjoi̱í ìjngoò k'a‑ne, mìtsà tà 'a̱n xi tjoé‑na. Ti̱koa̱á tjoé‑la̱ ngats'iì xi̱ta̱ xi tíjngoò ikon nga nchikoña‑la̱ Cristo.
\s1 Kó kitsò Pablo nga kisìxátíya‑la̱ Timoteo nga kjoi̱kon ni̱to̱n
\p 
\v 9 Ti̱xátíyi nga ni̱to̱n nchrobáchon‑ná.
\v 10 Nga jè Demas, jyeé kitsjeiìn takòn‑na. Jè 'ñó matsjakeè kjoa̱ xi tjín i̱ i̱sò'nde. Ján kiì na̱xa̱ndá Tesalónica. Crescente, ján kiì nangui Galacia, koa̱ jè Tito ján kiì nangui Dalmacia.
\v 11 Tà jè Lucas tíjnako̱‑na. K'e̱ nga kji̱nchroboì, tjàjchatoi Marcos, nchrobákoi̱i. Ko̱chjeén‑na kjoa̱ ts'e̱ xá xi tjín‑na.
\v 12 Jè Tíquico, ján kisìkasén Éfeso.
\v 13 K'e̱ nga kji̱nchroboì, jcha̱‑ná i̱nchro̱kisòn‑na̱ xi tsakajná ya̱ na̱xa̱ndá Troas ya̱ ni'ya‑la̱ Carpo. Jch'i̱i xo̱jo̱n‑na̱; jñà xi ìsa̱ 'ñó mochjeén‑na xi chrjoa̱ kjoàn.
\p 
\v 14 Alejandro, jè xi chji̱ne̱ ki̱cha̱, 'ñó ch'o tjín kjoa̱ xi tísíko̱‑na. Nainá, jè kàtatsjá‑la̱ kjo̱'in kjoa̱ xi tís'ín.
\v 15 Ngaji̱ Timoteo, ti̱kindi̱i yijo‑lè i̱t'aà ts'e̱ xi̱ta̱ jè. 'Ñó kondra̱ fìtji̱ngui‑la̱ 'én xi okoòyaá.
\p 
\v 16 K'e̱ nga kisindaàjiìn ítjòn‑na nga nguixko̱n xi̱ta̱xá, ni̱yá xi tsasìko̱‑na. Ngats'iì xi̱ta̱ kitsjeiìn takòn‑na. Kì kinda̱á s'ín Nainá kjoa̱ koi.
\v 17 Ta̱nga Na̱'èn‑ná tsasìko̱‑na. Kitsjaà‑na nga'ñó mé‑ne nga komà kichjàjiìn‑la̱ jñà xi̱ta̱ 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo. K'oa̱á s'ín komà‑ne nga kiì'nchré yije xi mìtsà xi̱ta̱ judío. Nainá tsasìko̱‑na nga mìkiì kisìk'en‑na xi̱ta̱ xi tsibíndaàjiìn‑na.
\v 18 Na̱'èn‑ná ko̱si̱ko̱‑na i̱t'aà ts'e̱ ngats'iì kjoa̱ xi ch'o tjín. Kji̱ko̱‑na ñánda tíhotíxoma ján ngajmiì. Nainá, kàtas'e‑la̱ kjoa̱jeya ni̱ta̱ mé nó‑ne ni̱ta̱ mé na̱chrjein‑ne. K'oa̱s'ín kàtama.
\s1 Xi fehet'aà‑ne, Pablo síhixat'aà xi̱ta̱ xíkjín
\p 
\v 19 Ti̱ixat'eì jè Priscila ko̱ Aquila ko̱ xi̱ta̱ ni'ya‑la̱ Onesíforo.
\v 20 Erasto, ján tsibìjna na̱xa̱ndá Corinto. Jè Trófimo, ján kisìkíjna na̱xa̱ndá Mileto. Xk'én‑né.
\v 21 Ti̱xátíyi nga ni̱to̱n nchrobáchón‑ná k'e̱ nga ti̱kj'eè f'iì na̱chrjein choòn 'nchán. Tísíhixat'aà‑lè Eubulo, Pudente, Lino ko̱ Claudia, ko̱ ngats'iì xi̱ta̱ xi 'ndsè chibá.
\p 
\v 22 Jè kàtìjnako̱‑lè Jesucristo xi otíxoma‑ná. Ngats'ioò, jè kàtìjnako̱‑nò kjo̱ndaà‑la̱. K'oa̱s'ín kàtama.
