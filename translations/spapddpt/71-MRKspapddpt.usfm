\v 32 ¡\w El|strong="G3588"\w* \w Cristo|strong="G5547"\w*, \w el|strong="G3588"\w* Rey \w de|strong="G3588"\w* \w Israel|strong="G2474"\w*! Baja \w ahora|strong="G3568"\w* \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w cruz|strong="G4716"\w* \w para|strong="G2443"\w* \w que|strong="G3588"\w* veamos \w y|strong="G2532"\w* \w creamos|strong="G4100"\w*. \w También|strong="G2532"\w* \w lo|strong="G3588"\w* insultaban \w los|strong="G3588"\w* \w que|strong="G3588"\w* fueron crucificados \w con|strong="G4862"\w* \w Él|strong="G3588"\w*.   
