\p 
\v 1 Just \w before|strong="H4480"\w* \w the|strong="H3068"\w* \nd \w Lord|strong="H3068"\w*\nd* \w took|strong="H1961"\w* Elijah \w up|strong="H5927"\w* \w to|strong="H3212"\w* \w heaven|strong="H8064"\w* \w in|strong="H3068"\w* \w a|strong="H3068"\w* windstorm, Elijah \w and|strong="H3068"\w* Elisha \w were|strong="H1961"\w* traveling \w from|strong="H4480"\w* \w Gilgal|strong="H1537"\w*.
\v 2 Elijah told \w Elisha|strong="H3427"\w*, “\w Stay|strong="H3427"\w* \w here|strong="H6311"\w*, \w for|strong="H3588"\w* \w the|strong="H3588"\w* \nd \w Lord|strong="H3068"\w*\nd* \w has|strong="H3068"\w* \w sent|strong="H7971"\w* \w me|strong="H4994"\w* \w to|strong="H5704"\w* \w Bethel|strong="H1008"\w*.” \w But|strong="H3588"\w* \w Elisha|strong="H3427"\w* said, “\w As|strong="H5704"\w* \w certainly|strong="H3588"\w* \w as|strong="H5704"\w* \w the|strong="H3588"\w* \nd \w Lord|strong="H3068"\w*\nd* \w lives|strong="H5315"\w* \w and|strong="H3068"\w* \w as|strong="H5704"\w* \w you|strong="H3588"\w* \w live|strong="H3427"\w*, \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w not|strong="H3588"\w* \w leave|strong="H5800"\w* \w you|strong="H3588"\w*.” \w So|strong="H7971"\w* \w they|strong="H3588"\w* \w went|strong="H3381"\w* \w down|strong="H3381"\w* \w to|strong="H5704"\w* \w Bethel|strong="H1008"\w*.
