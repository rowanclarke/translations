\v 4 \w Porque|strong="H3588"\w* tú quebraste \w su|strong="H3588"\w* pesado yugo, \w y|strong="H3588"\w* \w la|strong="H3605"\w* vara \w de|strong="H3588"\w* \w su|strong="H3588"\w* hombro, \w y|strong="H3588"\w* \w el|strong="H3588"\w* cetro \w de|strong="H3588"\w* \w su|strong="H3588"\w* exactor, \w como|strong="H3588"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* día \w de|strong="H3588"\w* Madián.   
\m
\v 5 \w Porque|strong="H3588"\w* \w toda|strong="H7965"\w* batalla \w de|strong="H5921"\w* quien pelea \add es\add* \w con|strong="H5921"\w* estruendo, \w y|strong="H3588"\w* \w con|strong="H5921"\w* revolcamiento \w de|strong="H5921"\w* vestidura \w en|strong="H5921"\w* sangre: \w mas|strong="H3588"\w* esto \w será|strong="H1961"\w* \w para|strong="H5921"\w* quema, \w y|strong="H3588"\w* pábulo \w del|strong="H5921"\w* fuego.   
\m
\v 6 \w Porque|strong="H5921"\w* un niño \w nos|strong="H5921"\w* \w es|strong="H2063"\w* nacido, hijo \w nos|strong="H5921"\w* \w es|strong="H2063"\w* dado; \w y|strong="H5921"\w* \w el|strong="H5921"\w* principado \w sobre|strong="H5921"\w* su hombro: \w y|strong="H5921"\w* llamaráse su nombre Admirable, Consejero, \w Dios|strong="H3068"\w* fuerte, Padre \w eterno|strong="H5769"\w*, Príncipe \w de|strong="H5921"\w* \w paz|strong="H7965"\w*.   
