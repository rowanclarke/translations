\id JAS - Yaour칠 NT [yre] -C칪te d'Ivoire 1999 (web version -2013 bd) 
\h Zaji 
\toc1 'Fluba n톝n Zaji -a cr톝n -t톝 
\toc2 Zaji 
\toc3 Zaji 
\mt2 'Fluba n톝n 
\mt1 Zaji 
\mt2 -a cr톝n -t톝 
\c 1  
\p  
\v 1 'An 'b톖 Zaji n톝n an Bali 'lee Minsan Zozi Crizi "sua b톝, m톝톝n 'fluba 'g툶톝 -a cr톝n -t톝. Maan cr톝n -t톝 Bali -le minnun p톝톝n톖n n톝n 'o fuilad톨 "man 'tr톝da b톝, -wl톝. An 'ka 't톖 bo. 
\s1 E 'ka "le Zozizan 'e 'ci -f톖톖 "d톨! 
\p  
\v 2 'An "b툶톨 Zozin톖n, 'w톨 't톖nd톖n p톝톝n톖n n톝n o b톖a 'ka man b톝, 'ka y톨 'cee ci "nran w톨 -a.  
\v 3 K톖톖 te ka yi -t톝ra Bali da b톝, ka b톖ala 'ji, -e 'e -p톖an 's톖d톨 -n톖n 'c톝톝.  
\v 4 'Ka yi톝 'tr톖a "da, -e -p톖an 's톖d톨 z톨톝 'e 'k툶 'kaa -trilii "le z톨 e c톨 Bali ci 's톖 'a b톝, -yee 'w톨 'z툶. -E 'ka 'k톖n t톨gl톨, te 'ka dr톝 w톨 a 'e 's툶d톨 "ji Bali 'l톝. 
\p  
\v 5 'Pian -te min -t툶 a 'ka yei 'nan 'w톨 n톝n k톖 'e dr톝 ya'a t톖a d톨톝, 'e laab툶 Bali 'l톖. Bali 'w톨 't톖d톨 -n톖an -yr톝 "le z톨 yaa laab툶 -yr톖 "b톝 -yee 'w톨 'z툶. K톖톖 ya'a min bo "va "d톨, 톝n yaa -n톖an 'e "tun.  
\v 6 'Pian min 'b톖 'e yi -t톝ra "da -e 'e laab툶 -yr톖. Te 'e 'ci -f톖톖 "d톨! K톖톖 min n톝n 'e 'ci -f톖톖man b톝, e ya "le "p톝zann톝n n톝n ful톖 'ta -t톖a "man "b톝, -yee 'w톨 'z툶.  
\v 7 Maan ve 'c톝톝 'nan, te -a -cin 'e 'k톖n min z톨톝 -a -ji 'nan, 'e f톝 -t툶 ye Minsan 'l톖 "fo "d톨.  
\v 8 K톖톖 min n톝n 'e 'ci -f톖톖man b톝, -a -wulo -ji w톨 'ka -t툶wli "d톨. 쿯n -yee 'w톨 p톝톝n톖n dr톝d톨 -ji b톝, ya'a 'e yi톝 't톖ala 'w톨 't툶 da t톨gl톨 -e 'e dr톝 d톨. 
\s1 Seezan 'lee f톝zan -le 'w톨 
\p  
\v 9 Min n톝n e ya seezan -a, 톝n e s톖톖nla Zozi -sru "b톝, -a san ci 'e "nran 'nan, Bali 'e dra min -dan a.  
\v 10 'Pian min n톝n e ya f톝zan -a, 톝n e s톖톖nla Zozi -sru "b톝, -a -cin 'e 'k톖n -a san ji 'nan, e 'ka min -dan a Bali 'l톝 "fo "d톨. K톖톖 e "sia 'e y톨f톝 -sru "le z톨 lu 'e -fui -t톝a, -e 'e 'sran b톝 -yee 'w톨 'z툶.  
\v 11 -Te yid톝 bii 'pl톝bl톝 b톝, -e lu -fui 'e 'sran, te -yee f톝nyian -nyan. Z톨 f톝zan "sia 'e y톨f톝 da z톨톝. 
\s1 'W톨 'wlid톨 "dr톝d톨 -taala 'k톖! 
\p  
\v 12 Min n톝n 'w톨 'wlid톨 "cin -tr톖a "ji 톝n ya'a dr톝l톝 d톨톝, Bali -le -f톝a -a san man. K톖톖 -te -a san 'yee 'pl톝bl톝 'ci k톖톖n z톨톝 -trilii 톝n e 'b톖la -a -wulo planan "b톝, 'belid톨 n톝n ya'a 'nyaan d톨톝 e ya -yee v톝 -a. Minnun n톝n o Bali ye "yi "b톝 o -kopa n톝n z톨톝. 
\p  
\v 13 Min n톝n 'w톨 'wlid톨 "cin -tr톖a "ji "b톝, te 'e 'pa Bali da d톨! K톖톖 'w톨 'wlid톨 "cin 'ka Bali ji d톨, 톝n Bali 'ka 'w톨 'wlid톨 "cin t톖ala min ji d톨.  
\v 14 'Pian blamin 'b톖 'wulo -ji w톨 'b톝 see "paaman, -e 'e 'w톨 'wlid톨 "dr톝d톨 -cin -t톖 "ji.  
\v 15 -Te min s톖톖nla 'e 'wulo -ji "nr톖nd톨 'wlid톨 z톨톝 -a -sru "b톝, -e 'e 'w톨 'wlid톨 "dr톝. 쿯n -te min 'w톨 'wlid톨 dr톝 'trilii b톝, -a 'le 'srannan "n톝n -kad톨 -a. 
\p  
\v 16 'An "b툶톨 Zozin톖n, an 'ka ye "yi 'kpa. Te 'ka 'w톨 'g툶톝 -a "sia 'ka see "paa w톨 -a d톨.  
\v 17 Maan ve 'c톝톝 'nan, 'w톨 "yi 'lee 'w톨 t톨gl톨 p톝톝n톖n "sia Bali va lou. -Y톝톝 laji f톝nun p톝톝n톖n n톝n o "bia b톝 o dr톝. F톝nun p톝톝n톖n z톨톝 'o 'man limlan, 'pian Bali 'ka 'limlan 'li "fo "d톨.  
\v 18 Bali 'b톖 'ci 's톖 'a n톝n, e -kaa dr톝 'yee 'n톝nnun -a. Zozi 'le 'w톨 'n톖nn톖n n톝n e ya 'w톨 t톨gl톨 'a b톝, -a 'b톖 'a n톝n e 'belid톨 'n톖n -c톝톝 'nan, -e -kaa k톖n 'e 'p톝 dr톝v톝 flin -a. 
\s1 'Ka "tr톖톝n "t톖 Bali wei l톝, -e 'ka 'ta w툶la "da! 
\p  
\v 19 'An "b툶톨 Zozin톖n, an 'ka ye "yi 'kpa. 'W톨 'g툶톝 -a -cin 'e 'f톖la 'ka 'ji. 'Ka "tr톖톝n 'e 'w톨 man! Te 'ka 'l톝bo 'e 'f톖 'e 'flin -e 'e 'w톨 d톨! 쿯n te 'bli 'e 'f톖 'ka 'ji tada d톨!  
\v 20 K톖톖 -te 'bli 'f톖 min ji b톝, ya'a Bali ci 's톖 w톨nun dra "fo "d톨!  
\v 21 -Yee "w톝an n톝n 'ka 'w톨 p톝톝n톖n n톝n e min "tri -t톖a Bali 'l톝 b톝 -a 't툶톨, 'lee 'w톨 'wlid톨 p톝톝n톖n, -e 'ka 'w톨 Bali wei n톝n waa 'v톨 'c톝톝 b톝 -a man, -e 'e -k톖la 'e 'ka 'si 'w톨 'ji -le "w톝an. 
\p  
\v 22 Te 'ka 'fli s톝톝 w툶 'nan ka ya Bali wei mannan d톨! 'Pian -te kaa 'man b톝, 'ka 'ta w툶la "da!  
\v 23 -Y톝톝 c톨 'nan, min n톝n 'e "tr톖톝n -t톖a Bali wei l톝, te ya'a 'ta 'wo "da "d톨톝, yaa dra "le 'nan min -t툶 'b톝 'e 'fli -nanj톝톝n -niannun 'ji, 톝n 'e 'fli -t톖 kl톖 'y톨.  
\v 24 Z톨 e c톝톝n "man 톝n e -k툶 b톝, 'nun t톖톖n -a -t톖 kl톖 'san 'e 'fli ji.  
\v 25 'Pian bii n톝n 'i yi톝 -tr톖a Bali wei t톨gl톨 n톝n e min "sia 'w톨 'wlid톨 "le n톖anba -ji b톝 -a da b톝, Bali -f톝a ve 'i man. K톖톖 'i "tr톖톝n "t톖 -yr톝, 톝n i k톖ala "man, 톝n -a -cin 'ka 'sanl톝 'i 'ji d톨, 'pian i 'ta 'w툶la "da. 
\p  
\v 26 Min n톝n e 'nan e ya Bali -sru, te ya'a 'k톖laman 'e wei 'kund톨 -a d톨톝, te e ya 'e 'fli s톝톝 w툶nan. Te -yee 'ta w툶d톨 Bali -sru "b톝 -a -ci "ka "d톨.  
\v 27 'Pian -kaa "t톨 Bali b톖d톨 t톨gl톨 n톝n 'nan, blamin 'e yi톝 't톖 "t톨 'lee "b툶 "ka "da "n톝nnun 'lee -calenun va 'wee yra y톨d톨 -ji. 쿯n "nyian 'nan blamin 'e 'fli 'kun -e 'e v톨l톝 'e 'w톨 'wlid톨 "t툶wli "dr톝 d톨. 
\c 2  
\s1 Te 'ka min b툶 "va d톨! 
\p  
\v 1 'An "b툶톨 Zozin톖n, kaa n톝n ka yi -t톝ra ming톖nn톝n -kaa san Zozi Crizi da b톝, te 'ka min b툶 "va "d톨.  
\v 2 'Ka 'ci "nr톖n 'w톨 'g툶톝 -a da. F톝zan -t툶 wla 'cee cin y톨 'kuin 'e 'p톝 'wl톝 man le -siga, 톝n 'e 'ta le s톖 f톝nyian -a. Seezan -t툶 wla "nyian 'cee cin y톨 'k톖n 'lein z톨톝 -a -ji, te s톖 "c톝톝nd톨 a "da.  
\v 3 Min n톝n 'e 'ta le s톖 f톝nyian -a b톝, kaa -nanj톝n, 톝n 'ka 'nyrannan f톝nyian -n톖n -yr톝. 'Pian kaa 'v톨 seezan "le "l톝 'nan: 춺Bii 'g툶, "i "t톖 w툶 lou, 톝n -te i ya "va "b톝, 'i 'nyran 'm톝n p톝in "sr톖n "tra.췉  
\v 4 'W톨 z톨톝 -a dr톝d톨 b톝, e ya min b툶d톨 "va "wlid톨 "a. 
\p  
\v 5 'An "b툶톨 Zozin톖n, an 'ka ye "yi 'kpa. 'Ka "tr톖톝n "t톖 'w톨 'g툶톝 -yr톝! Maan ve 'c톝톝 'nan, minnun n톝n o c톨 seen톖n 'a 'tr톝 'g툶톝 -a da b톝, Bali o 'si "va 'nan, -e 'e o dr톝 f톝n톖n 'a 'wee yi -t톝rad톨 'e da man, -e 'o 'k툶 'yee ming톖nn톝n tr톝 n톝n yaa 'pla minnun n톝n waa ye "yi "b톝, -wl톝 "b톝 -a da.  
\v 6 'Pian 'cee v톝 b톝, ka'a seen톖n 'siala min -a d톨, f톝n톖n n톝n ka o ye "yi. -M톝 "le "w톝an n톝n kaa dra z톨? F톝n톖n 'b톝 't톝 "paa 'ka da, 톝n -w톝톝 -ko 'kaa tin 'ban톖n 'c톝in -da.  
\v 7 쿯n -w톝톝 't톖 "sr톖nman 't톖 f톝nyian n톝n Zozi Crizi 't톖 a b톝 -a man. 
\p  
\v 8 Bali -le 'fluba 'ji b톝, -yee -pei -t톖 w톨 -dan t툶 -a. E ya 'e 'cr톝n -t톝d톨 'nan: 
\q1 춺'I b톖톝zan -t툶 y톨 "yi 
\q1 "le 'yie 'w톨 'z툶!췉 
\m -Te 'w톨 z톨톝 -a dr톝nan n톝n ka c톨 b톝, te ka 'w톨 "yi dr톝.  
\v 9 'Pian -te ka min 'b툶 "va "b톝, te ka 'w톨 'wlid톨 dr톝. 쿯n te Bali -le -pei z톨톝 e tin -t톝a 'ka da Bali 'l톝.  
\v 10 K톖톖 -te min Bali -le -pei -t툶wli "c톝 sr톝 b톝, te yaa p톝톝n톖n sr톝 "fo.  
\v 11 Bali -a 'v톨 'nan: 
\q1 춺Te blamin 'e min nan -w톝톝 "d톨, 
\q1 톝n te 'e min -sran -w톝톝 "d톨!췉 
\m 쿯n yaa 'v톨 "nyian 'nan: 
\q1 춺Te blamin 'e dr톝 min -t톝zan -a d톨!췉 
\m -Te min 'ka min nan -w톝톝l톝 d톨, 'pian 톝n e dr톝 min -t톝zan -a b톝, te ya'a 'ta w툶l톝a Bali wei da "fo "d톨. 
\p  
\v 12 -Yee "w톝an maan ve 'c톝톝 'nan, -te 'ka "ta "we, 톝n 'ka "ta 'w톨 dra b톝, -a -cin 'e 'k톖n 'ka 'ji 'nan, Bali wei n톝n e min "sia 'w톨 'wlid톨 "le n톖anba -ji b톝, e 'cee tin "baa.  
\v 13 K톖톖 yi n톝n Bali 'tr톝dan톖n 'le tin "baa b톝, min n톝n ya'a 'e b톖톝nun nyrinda 'sil톝 d톨톝, Bali 'ka -a san nyrinda sia d톨. 'Pian min n톝n 'e b톖톝nun nyrinda 'si b톝, te "klan 'e 'k톖n -a san -ji d톨. 
\s1 Yi -t톝rad톨 Bali da 'lee min dr톝 w톨 
\p  
\v 14 'An "b툶톨 Zozin톖n, -te min -a 'v톨 'nan, an yi -t톝ala Bali da, te ya'a k톖톖nman 'e dr톝 w톨 -a d톨톝, -a -ci n톝n 'n톖n? -Yee yi -t톝rad톨 Bali da z톨톝, ya'a sia 'w톨 'ji "fo "d톨.  
\v 15 'Ka 'ci "nr톖n 'w톨 'g툶톝 -a da. 'Ka "b툶톨 Zozizan 't툶 a 'ka 'va, -te 'b톝 "c톝톝 d톨, 'ka "blu Zozizan 't툶 a 'ka 'va, -a ta s톖 "ka "d톨, 톝n -a -bl톨f톝 "ka "d톨.  
\v 16 쿯n kaa 'v톨 -yr톝 'nan: 춺K툶 ya yi pee nyan. I -f툶 -tr톖톖. Bali 'e f톝 n톝n yia -w톝톝man b톝 -a -n톖n 'yi톝.췉 'Pian f톝 n톝n 'e kl톨 "man "b톝, ka'a -n톖nl톝 -yr톝 "d톨. 'W톨 z톨톝 -a dr톝d톨 b톝, -a -ci "ka "fo "d톨.  
\v 17 -A -t툶wli "n톝n "nyian yi -t톝rad톨 Bali da -a. Min n톝n e yi -t톝ala Bali da, 톝n ya'a k톖톖nman 'e dr톝 w톨nun -a d톨톝, min z톨톝 -yee yi -t톝rad톨 Bali da -ci "ka "fo "d톨. 
\p  
\v 18 쿯n "nyian b톝, -te min -a 'v톨 'm톝n 'nan: 춺Min -t툶 yi -t톝ala Bali da, 톝n min pee "e "yi "dra minnun l톝.췉 
\p T톖톖n maan laabo min z톨톝 -yr톖 'nan, 'i 'yie yi -t톝rad톨 Bali da n톝n wa'a k톖톖nman o dr톝 w톨 -a d톨톝, -a -ci -k톖톖n 'm톝n! -E 'an 'm톝n yi -t톝rad톨 Bali da -ci -k톖톖n 'yi톝 'an dr톝 w톨 -a.  
\v 19 I yi -t톝ala "da 'nan Bali a -t툶wli "c톝. 'W톨 'kpa n톝n. 'Pian -a -cin 'e 'k톖n 'i 'ji 'nan, -y툶 -wlid톨nun "o yi -t톝ala "nyian "da z톨, 톝n o "klanman -yr톖. 
\p  
\v 20 -Bl툶zan, i ya "vale 'an -ci -k톖톖n 'yi톝 'nan, yi -t톝rad톨 Bali da n톝n wa'a k톖톖nman 'o dr톝 w톨 -a d톨톝, -a -ci "ka "d툶툶?  
\v 21 -M톝 "le "w톝an n톝n Bali -kaa tra Abraam 'sia min t톨gl톨 'a? -A dr톝 w톨 man n톝n. K톖톖 Abraam w톨톨 "man, 톝n e 'e 'p톨 Izak 'si, yaa -n톖n Bali l톝 'sraga b툶v톝 -a Bali -pan "dav톝 da.  
\v 22 Yia 'y톨? -A dr톝 w톨 'lee -yee yi -t톝rad톨 Bali da dr톝 't툶wli. 쿯n -yee yi -t톝rad톨 Bali da 'e 'l톝 s톖톖 -a dr톝 w톨 man.  
\v 23 'W톨 'b톖 z톨톝 -yee "w톝an e ya 'e 'cr톝n -t톝d톨 Bali -le 'fluba 'ji 'nan: 
\q1 춺Abraam yi -t톝ra Bali wei da, 
\q1 톝n Bali -a 'sia min t톨gl톨 'a 
\q1 'yee yi -t톝rad톨 'e da man.췉 
\m Bali -a laab툶 'e bee.  
\v 24 -Yee "w톝an maan 'v톨 'c톝톝 'nan, Bali min "siala min t톨gl톨 'a 'e dr톝 w톨 'lee 'yee yi -t톝rad톨 'e da man, 'pian ya'a siala min t톨gl톨 'a 'yee yi -t톝rad톨 Bali da 'saza "c톝 "man d톨. 
\p  
\v 25 'W톨 't툶wli z톨톝 -y톝톝 dr톝 "nyian -k톖nn톝n -w톝톝zan n톝n waa laabo Rab b톝 -yee v톝 -a. Bali -a "sia l톨m톖n t톨gl톨 'a 'e dr톝 w톨 man. K톖톖 minnun n톝n Zozue o 'pa 'sia b톝, e 'pa 'o 'va, 톝n e -si -t툶 k톖톖n -wl톝 'nan 'o 't톝 -ji "da. 
\p  
\v 26 Kaa -t톖a 'nan -te 'flind톨 -nyan min l톖 b톝, te e -ka. -A -t툶wli "n톝n "nyian yi -t톝rad톨 Bali da -le v톝 -a. Yi -t톝rad톨 Bali da n톝n wa'a k톖톖nman 'o dr톝 w톨 -a d톨톝, te e ya 'e 'kad톨. 
\c 3  
\s1 Min nr톝n 'le 'w톨 
\p  
\v 1 'An "b툶톨 Zozin톖n, te 'ka v톨nan 'ka p톝톝n톖n 'e dr톝 Bali wei "paan톖n 'a d톨. K톖톖 kaa -t톖a 'nan, 'k툶 Bali wei "paan톖n b톝, Bali 'k툶e 'w톨 tin "baa 'pl톝bl톝 'e "mlian min peenun -le v톝 da.  
\v 2 -Kaa p톝톝n톖n -p톝 "saanman 'w톨 'wlid톨 'va 'w톨 "kaga "ji. -Te min 'lewei 'ka "saanl톝 -t툶wli 'w톨 'wlid톨 'va d톨톝, te min n톝n -a dr톝 w톨 a 'e 'l톝 s톖톖d톨 b톝, -nyr톝n. Te e -k톖laman 'e 'fli 'kund톨 -a "fo. 
\p  
\v 3 'Ka 'ci "nr톖n 'w톨 'g툶톝 -a da. -Kaa -bulal톝 wl톝 wo -s툶nun 'le, 'nan -e 'o -kaa wei man, -e -kaa -k톖la "o plad톨 -a.  
\v 4 쿯n "nyian b톝, 'ka 'ci "nr톖n -kl툶 -dandannun da. -Te -kl툶 a -dan 'k톖 oo, -a -tr톖a "v톝 -si yra a "w톝nn톖n. -Te ful톖 'pl톝bl톝 a 'ta 't톖nan "man "b톝, -a -tr톖a "v톝 -si yra "w톝nn톝n z톨톝 -y톝톝 -maan -e -a -f톖zan 'e -tr톖a -si yra.  
\v 5 -A -t툶wli "n톝n "nyian min nr톝n 'le v톝 -a. E ya min man m톝nnun va "w톝nn톖n, 'pian -y톝톝 -maan -e 'w톨 -dan 'e 'f톖la. 
\p 쿯n "nyian b톝 'ka 'ci "nr톖n pl톖 -dan n톝n 't톝 "w톝nn톝n -f톖ala 'ji b톝 -a da.  
\v 6 Min nr톝n a "le 't톝 'le 'w톨 'z툶. -A da n톝n 'w톨 'wlid톨 't톖 -t툶d툶 p톝톝n톖n c톨. E ya -kaa man m톝nnun va, 톝n -y톝톝 -kaa munmuan "tri -t톖a. Maan ve 'c톝톝 'nan, -e 'e 'sia yi n톝n o min -yaa "da "trilii, -e -a -ka yi 'e b톖 b톝, -a nr톝n 'b톝 't톝 wo -yee 'tr톝da va. 'T톝 z톨톝 Satan -va n톝n e "sia. 
\p  
\v 7 Min -k톖laman -e 'e luji wi p톝톝n톖n, 'lee "lomannun, 'lee p톖n톝nnun, 'lee f톝 p톝톝n톖n n톝n o 'ta w툶la 'o 'k톖l톝n톝n "b톝, o 'l톝b툶.  
\v 8 'Pian min -t툶 'ka 'k톖laman 'e nr톝n plad톨 -a "fo "d톨. F톝 -wlid톨 "n톝n, ya'a 't톖a 'e "pa 'ji fl톨톨 d톨톝, -nyr톝n. E ya 'e fad톨 min -t톝 'yile -a. 
\p  
\v 9 Nr톝n z톨톝 -a 'b톖 'a n톝n -kaa Minsan n톝n e c톨 -kaa "t톨 "a b톝, -a 't톖 b톖a. 쿯n -a 'b톖 'a n톝n -kaa wei "paala blamin n톝n Bali -a dr톝 "le 'yee 'w톨 'z툶 b톝, -a man.  
\v 10 Min 'le 'a n톝n min -f톝a ve min man. 쿯n min 'le 't툶wli z톨톝 -a 'b톖 'a n톝n min 'e wei "paala min man. 'An beenun, te 'cee v톝 'e 'k톖n z톨톝 d톨!  
\v 11 F톝nan n톝n 'yi b톖ala b톝, 'e dr톝 'cee 'w톨 -k톖톖n "manv톝 -a! 'Yi 'n톖nn톖n 'lee 'yi nyrannyran 'ka 'b톖ala f톝 -t툶wli z톨톝 -a -nan 'e cin -a d톨.  
\v 12 쿯n "nyian b톝, -lomin yiba 'ka 'baa -voga -a d톨, 톝n -mango yiba 'ka 'baa -lomin -a d톨. 쿯n 'yi 'w톝w톝a 'lee 'yi 'n톖nn톖n 'ka b톖ala 'yi b톖lanan 't툶wli "nan d톨. 
\s1 Laji 'w톨 't톖d톨 
\p  
\v 13 -Te min -t툶 a 'ka yei, te 'w톨 p톝톝n톖n 'cin a "ji, 톝n e 'w톨 -t톖a "b톝, 'e -k톖톖n 'yee -k톖nd톨 "yi 'lee 'e dr톝 w톨nun t톨gl톨 'a.  
\v 14 'Pian -te man b툶d톨 -n톖nn톖an -cin a 'ka 'ji b톝, te 'ka 'fli -k톖톖n 'cee 'w톨 't톖d톨 -a "fo "d톨. 쿯n -te b톖톝 "bl톨d톨 -cin a 'ka 'ji b톝, te 'ka 'fli -k톖톖n 'cee 'w톨 't톖d톨 -a "fo "d톨. K톖톖 -te 'ka 'fli -k톖톖n 'nan ka ya 'w톨 't톖n톖n 'a b톝, te ka 'wlu -s톝an.  
\v 15 'W톨 't톖d톨 z톨톝, Bali "c톝톝 'b톝 -n톖an "d톨. E "sia 'tr톝da 'g툶, 톝n min 'b톖 -wulo -ji n톝n e -t톖ala. Satan -va n톝n e "sia.  
\v 16 F톝 n톝n maan ve z톨톝 -y톝톝 c톨 'nan, -te man b툶d톨 a f톝nan, 톝n b톖톝 "bl톨d톨 a f톝nan b톝, f톝 z톨톝 -a -nan 'ka fl톨톨 "fo "d톨. 'W톨 'wlid톨 't톖 't툶d툶 p톝톝n톖n a -nan. 
\p  
\v 17 'Pian 'w톨 't톖d톨 n톝n e "sia Bali va b톝, e ya 'w톨 't톖d톨 t톨gl톨 'a. E min dra min -tr톖톖 -a, 톝n e min dra min ci "yizan 'a. Min z톨톝 e min wei maan, min nyrinda -s톝an "da, 톝n e "yi "dra min l톝. Ya'a min bo "va "d톨, 톝n ya'a 'w톨 'dra -dawli a d톨.  
\v 18 Minnun n톝n waa -w톝톝man -tr톖톖 'nan minnun yei 'e 'f툶 -tr톖톖 b톝, -a 'le 'srannan "b톝 'w톨 "yi "dr톝d톨 nun 'b톝 -taa "b톖l톝a. 
\c 4  
\s1 'Ka Satan 't툶톨 -e 'ka -s톖톖nla Bali -sru! 
\p  
\v 1 -Kulinun a 'ka yei, 톝n 'w톨 'bl톨d톨nun a 'ka yei. Nyin zia n톝n 'w톨nun z톨톝 -a pou 'si? Maan ve 'c톝톝 'nan, 'ka 'b톖 'wulo -ji "nr톖nd톨 -wlid톨nun n톝n ka 'ta w툶la "da "b톝 -y톝톝 -maan 'w톨nun a 'ka yei.  
\v 2 Ka ya "vale f톝 -t툶 'e dr톝 'cee v톝 -a, 'pian -te ka'a ye d톨톝, te ka 'nand톨 'sia min man "le 'ka -t톝. 쿯n ka ya "vale 'nan 'ka b톖톝zan -t툶 -l톖 f톝 'e dr톝 'cee v톝 -a, 'pian -te ka'a 'k톖laman -a y톨d톨 -a d톨톝, te -kulinun 'lee 'w톨 'bl톨d톨nun wla 'ka yei. F톝 n톝n ka c톨 "va "b톝 ka'a ye d톨, ka'a laabo Bali l톖 d톨 -le "w톝an.  
\v 3 쿯n -te kaa laab툶 Bali l톖 b톝, ya'a n톖an 'c톝톝 d톨, k톖톖 -a laab툶 "manw톨 a -wlid톨. Kaa laabo 'nan, -e 'ka 'fli ci 's톖 w톨nun dr톝 -a. 
\p  
\v 4 Ka "we "flivli Bali man "le l톨m톖n n톝n e 'si 'e 'sran wlu, 톝n e -k툶 -k톖nn톝n pee -va b톝 -yee 'w톨 'z툶. 'Tr톝da f톝nun y톨d톨 "yi "b톝, e ya Bali 'nan man w톨 -a. Ka'a -ci t톖a d툶툶? Min oo min n톝n e 'tr톝da f톝nun p톝톝n톖n ye "yi "b톝, 'e 'fli dra Bali 'nanmanzan 'a.  
\v 5 E ya 'e 'cr톝n -t톝d톨 Bali -le 'fluba 'ji 'nan: 
\q1 춺Lei n톝n Bali -a -n톖n 'c톝톝 b톝, 
\q1 Bali -a ye "yi, 톝n e man bo "da!췉 
\m Te -a -cin 'e 'k톖n 'ka 'ji 'nan, 'w톨 z톨톝 e ya 'w톨 "tun "a d톨!  
\v 6 'Pian "yi "n톝n Bali -a dra -c톝톝 b톝 e "mlianla "da. K톖톖 e ya 'e 'cr톝n -t톝d톨 Bali -le 'fluba 'ji 'nan: 
\q1 춺Minnun n톝n o 'fli dra -dandan b톝 
\q1 Bali 'ka o ye "yi "d톨. 
\q1 'Pian e "yi "dra minnun n톝n 
\q1 wa'a 'o 'fli k톖톖nman d톨톝 -wl톝.췉 
\p  
\v 7 -Yee "w톝an n톝n 'ka 'w톨 "man 'ka 'ci 'f톨daa 'a, -e 'ka 'ta w툶la Bali -sru! Te 'ka t톖a Satan l톝 d톨! 'Ka dr톝 z톨톝 -e 'e 'si 'ka man -k톖톖bli!  
\v 8 'Ka -pli Bali man, -e 'e -pli 'ka man! 'W톨 'wlid톨 "dr톝n톖n, 'ka 'p톝 'e 'si 'w톨 'wlid톨 -sru! Kaa n톝n 'ka 'ci -f톖톖man Bali -sru 'ta w툶d톨 -ji b톝, 'ka 'ci 'si 'f톨daa -e 'ka 'ta w툶la Bali -sru.  
\v 9 'W톨 'wlid톨nun n톝n kaa dra b톝, -a 'w톨 'e 'nan 'ka man! 'O 'ka 'ta dr톝 -tr톖dr톖! 'Ka 'wu톖! 'Ka 'cee 'sh톝 'bl톨d톨 lila "da -wu톖d톨 -a! 'Ka 'cee 'ci "nrand톨 lila "da -trund톨 -a!  
\v 10 'Ka 'fli dr톝 "w톝nn톖n Bali 'l톝, -e 'e 'ka dr톝 -dan! 
\s1 Te 'ka min 't톖 't톝 d톨! 
\p  
\v 11 'An "b툶톨 Zozin톖n, te 'ka 'w톨 'ka cin man -wlid톨 "d톨! Min n톝n e 'w톨 'wlid톨 'v톨 'e "b툶톨 -t툶 man, -te 'b톝 "c톝톝 d톨 yaa 't톖 't톝 b톝, te e 'w톨 'wlid톨 'v톨 Bali -le -pei man, 톝n e tin -t톝 "da. -Y톝톝 c톨 'nan, -te i 'w톨 'wlid톨 'v톨 Bali -le -pei man b톝, te yi'a 'ta w툶l톝a "da "d톨, 'pian te i dr톝 -a man tin 'bazan 'a.  
\v 12 Bali -t툶wli 'b톝 -pei -t톖 minnun l톝, 톝n -y톝톝 c톨 -a ta tin 'bazan a. -A -t툶wli 'b톝 -k톖laman min 'sid톨 -a 'w톨 'ji, 'lee min -t톝d톨 -a. 'I 'fli "siala 'k톖, 톝n i "we 'i b톖톝nun man z톨톝. 
\s1 F톝n톖n, te 'ka 'fli 'sia -dan d톨! 
\p  
\v 13 Kaa n톝n kaa ve 'nan: 춺C톝톝g툶 'lee "tr톝 "a k툶 -ko 'fla 'g툶톝 -a da, k툶 l톝 -t툶 -t톝a "nan nun, k툶 'fl톝 -taan -e 'k툶 "lala y톨췉 b톝, 'ka dr톝 "yi!  
\v 14 Ka'a "tr톝 w톨 t톖a d톨. Ka ya "le "lolu -koei "w톝nn톝n n톝n e -t톖ala -voo, -e 'e 'si 'nan b톝 -yee 'w톨 'z툶.  
\v 15 'W톨 n톝n k톖 'ka v톨 b톝, -nyr톝n 'g툶. 'Ka v톨 'nan: 춺-Te Minsan w톨톨 "man 'nan 'belid톨 'b톖 'k툶 man b톝, k툶 f톝 'g툶 'lee f톝 'g툶톝 -a dra.췉  
\v 16 'Pian ka'a 'w톨 z톨톝 'b톝 've d톨. 'Ka 'fli "siala -dan, 톝n 'ka 'fli -k톖톖nman. 'W톨 z톨톝 -a dr톝d톨 b톝, e ya -wlid톨. 
\p  
\v 17 Maan ve 'c톝톝 'nan, min oo min n톝n e 'w톨 "yi "n톝n k톖 'e dr톝 b톝 -a -t톖a, 톝n ya'a dr톝l톝 d톨톝, te e 'w톨 'wlid톨 dr톝. 
\c 5  
\s1 F톝n톖n, 'ka dr톝 "yi, "t톖g톖 'w톨 'e b톖 'ka man! 
\p  
\v 1 F톝n톖n, an 'w톨 "paala 'c톝톝 'nan, 'ka wu 'sia 'pl톝bl톝, 'w톨 'n톖nn톖an n톝n e -taa "b톖l톝 'ka man b톝 -yee "w톝an.  
\v 2 T툶 z톨톝 -a man b톝, 'ka y톨f톝nun sr톝man, 톝n fadr툶n톝n 'cee s톖nun -ble.  
\v 3 -Jeza -f톖a 'cee -siga 'lee 'cee "lalanun man. -Jeza z톨톝 -y톝톝 'ka man w톨 -t톖a lou -e 'e 'ka k톖l톝bo "bl톨 "le 't톝 'z툶. 'Tr톝da -nyan t툶 'b톖 'kogo, 'pian te ka -ko 'ka y톨f톝nun tred톨 -a "kaga.  
\v 4 Minnun n톝n o 'nyranman 'pa 'cee fei 톝n ka'a o -pan w툶l톝 d톨톝, 'pl톝bl톝 p톝톝n톖n 'san Bali -wee -paand톨 man.  
\v 5 쿯n "nyian b톝 f톝 -t툶 'ka 'kl톨l톝 'ka man d톨, 'ka 'ci 's톖 w톨nun p톝톝n톖n dr톝 'tr톝da. 'Tr톝da -nyan t툶 'b톖 'kogo, 'pian te ka -ko f톝nun -bl톨d톨 -a, 톝n ka -ko b톖ad톨 -a "le -sru n톝n o c톨 -a 'l톝 b툶nan 'nan -e 'o -bl톨 b톝 -yee 'w톨 'z툶.  
\v 6 쿯n "nyian b톝 minnun n톝n wa'a 'w톨 't툶 dr톝l톝 d톨톝, ka 'w톨 'pa o da, 톝n ka o t톝톝. Wa'a 'w톨 't툶 v톨l톝 d톨. 
\s1 'Ka -p톖an 'e 's톖! 
\p  
\v 7 'An "b툶톨 Zozin톖n, 'ka -p톖an 'e 's톖 'trilii, -e Minsan -ta t툶 'e b톖. 'Ka 'ci "nr톖n fei 'pazan n톝n e 'yee f톝 'wl톝 -f톖a 'tr톝 'ji b톝 -a da. Yaa man -p톝an -p톖an 's톖d톨 -a -trilii, -e laa 'e 'f톝n "man, -e -a -t톝 t툶 'e b톖.  
\v 8 'Ka 'b톖 "nyian, "cee -p톖an 'e 's톖 z톨톝! 'Ka -p톖an 'kun, k톖톖 Minsan -tad톨 'b톖 'kogo. 
\p  
\v 9 'An "b툶톨 Zozin톖n, te 'ka cin man w톨 'pa d톨, "t톖g톖 Bali 'e tin -t톝 'ka da! Min n톝n 'e tin -t톝a "min da b톝, e 'b톖 'kogo.  
\v 10 Minnun n톝n o Bali 'lewei 'v톨 Minsan 't톖 da b톝, o -p톖an 's톖 'wee yra y톨d톨 -ji. 'Ka 'ci "nr톖n o da, -e 'o dr톝 'cee 'w톨 -k톖톖n "mann톖n 'a.  
\v 11 Minnun n톝n o -p톖an 's톖 yra y톨d톨 -ji b톝, k툶a ve o man 'nan 'wee 'w톨 a "yi. Ka Zob -le -p톖an 's톖d톨 'w톨 'man. 쿯n f톝 n톝n Bali -a -n톖n -yr톝 -a 'le 'srannan "b톝, kaa -t톖a. Maan ve 'c톝톝 'nan, Minsan ci a "yi, 톝n min nyrinda -s톝an "da. 
\p  
\v 12 'An "b툶톨 Zozin톖n, te 'ka 'w톨 't툶 -ji -p톝 wluan d톨! Te 'ka 'p톝 wluan labli man d톨, 톝n te 'ka 'p톝 wluan 'tr톝 man d톨, 톝n te 'ka 'p톝 wluan "nyian f톝 pee man d톨! 'Pian 'w톨 t톨gl톨 n톝n 'ka v톨! -Te 'w톨 a 'w톨 'kpa -a b톝, 'ka v톨 -inyan! 쿯n -te 'w톨 a 'wlu 'a b톝, 'ka v톨 -c톝j톝! "T톖g톖 yi n톝n Bali tin -t톝a 'tr톝dan톖n da b톝, 'e v톨l톝 'e 'ka 't툶톨 'e "tun "d톨. 
\s1 'Ka Bali tr툶 'ba! 
\p  
\v 13 -Te min -t툶 a 'ka yei 'nan e ya 'e yra y톨nan b톝, 'e Bali tr툶 'ba! -Te min -t툶 a 'ka yei 'nan -a ci "nranman b톝, 'e Bali 't톖 'b톖 "dre "f톖!  
\v 14 -Te min -t툶 a 'ka yei 'nan -a man "yaaman b톝, 'e -leglizin톖n ceje laab툶, -e 'o Bali tr툶 'ba -yr톝, te o 'nyr톖n -s톝an -a -win -ji Minsan 't톖 da.  
\v 15 -Wee Bali tr툶 'bad톨 n톝n waa dra yi -t톝rad톨 Bali da -a b톝, e man "yaazan z톨톝 -a "belia, 톝n Minsan -a wuanla. -Te 'w톨 'wlid톨 "n톝n yaa dr톝 b톝, Bali -a fuiman. 
\p  
\v 16 -Yee "w톝an n톝n 'ka 'cee 'w톨 'wlid톨 "v톨 'ka cin l톝 'vaa -e 'ka Bali tr툶 'ba 'ka cin l톝, 'd툶 -e 'ka 'beli. K톖톖 -te min a t톨gl톨 Bali 'l톝 b톝, -yee Bali tr툶 'bad톨 'e 'bli p톝톝n톖n 'a b톝, -a 'l톝 a "man. 
\p  
\v 17 'Ka 'ci "nr톖n 'w톨 n톝n Bali 'lewei v톨zan -t툶 -a dr톝 'li b톝 -a da. Bali 'lewei v톨zan z톨톝 waa laabo Eli, 톝n e ya blamin -a "le -cee 'w톨 'z툶. E Bali tr툶 'ba 'e 'bli p톝톝n톖n 'a 'nan, te laa 'e 'f톝n d톨. 쿯n 'w톨 'kpa, laa 'ka 'f톝nl톝 'tr톝da d톨. Yaa dr톝 l톝 yaaga ml톝n 'sh톝톝d툶.  
\v 18 "B톝 -sru 톝n e Bali tr툶 'ba "nyian, t톖톖n laa 'f톝n, 톝n f톝 p톝톝n톖n b톖d톨 'sia. 
\p  
\v 19 'An "b툶톨 Zozin톖n, -te min -t툶 a 'ka yei, 톝n e 'si 'w톨 t톨gl톨 man -k톖톖bli b톝, 'ka dr톝 -e 'e s톖톖nla "nyian 'w톨 t톨gl톨 z톨톝 -a -sru.  
\v 20 'Ka -t톖 'nan, min oo min n톝n yaa dr톝 톝n e 'w톨 'wlid톨 "dr톝zan 'si 'si 'wlid톨 "da 톝n yaa s톖톖nla 'w톨 t톨gl톨 -sru "b톝, -y톝톝 -maan 톝n Bali 'belid톨 n톝n ya'a 'nyaan d톨톝 -a -n톖n min z톨톝 -yr톝, k톖톖 Bali -yee 'w톨 'wlid톨 p톝톝n톖n fui.