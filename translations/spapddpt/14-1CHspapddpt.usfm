\v 17 \w Y|strong="H3068"\w* los \w porteros|strong="H7778"\w*: Salum, Acub, \w Talmón|strong="H2929"\w*, Ahimán y los hermanos de ellos. Salum era el \w jefe|strong="H7218"\w*.  
\v 18 \w Hasta|strong="H5704"\w* entonces estaban encargados \w de|strong="H5704"\w* la \w puerta|strong="H8179"\w* \w real|strong="H4428"\w*, \w al|strong="H5704"\w* \w oriente|strong="H4217"\w*, \w y|strong="H5704"\w* eran \w porteros|strong="H7778"\w* \w de|strong="H5704"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Leví|strong="H3878"\w*.  
\v 19 Salum, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Coré|strong="H7141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Abiasaf, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Coré|strong="H7141"\w*, \w y|strong="H5921"\w* sus hermanos \w los|strong="H1121"\w* coreítas, \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* su padre, tuvieron \w a|strong="H3068"\w* su cargo \w la|strong="H5921"\w* \w obra|strong="H4399"\w* \w del|strong="H5921"\w* servicio, \w y|strong="H5921"\w* cuidaban \w las|strong="H5921"\w* puertas \w del|strong="H5921"\w* Tabernáculo, \w como|strong="H5921"\w* sus padres cuidaban \w las|strong="H5921"\w* puertas \w del|strong="H5921"\w* \w campamento|strong="H4264"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 20 \w En|strong="H5921"\w* tiempo antiguo, Finees, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Eleazar, \w fue|strong="H1961"\w* jefe \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*. \nd \+w Yavé|strong="H3068"\+w*\nd* \w estuvo|strong="H1961"\w* \w con|strong="H5973"\w* \w él|strong="H5921"\w*.  
