\v 14 ¿\w Está|strong="G3588"\w* \w alguno|strong="G5100"\w* \w enfermo|strong="G1722"\w* \w entre|strong="G1722"\w* ustedes? \w Llame|strong="G4341"\w* \w a|strong="G1909"\w* \w los|strong="G3588"\w* \w ancianos|strong="G4245"\w* \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w iglesia|strong="G1577"\w*, hablen \w con|strong="G1722"\w* \w Dios|strong="G2962"\w* \w por|strong="G1722"\w* \w él|strong="G3588"\w* \w y|strong="G2532"\w* únjanlo \w con|strong="G1722"\w* \w aceite|strong="G1637"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w Nombre|strong="G3686"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w*.  
