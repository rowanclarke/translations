\c 2  
\s1 Ruth met Boaz  
\p
\v 1 \w There|strong="H3045"\w* \w was|strong="H8034"\w* \w a|strong="H3068"\w* \w man|strong="H1368"\w* \w in|strong="H8034"\w* Bethlehem \w who|strong="H1368"\w* belonged \w to|strong="H3045"\w* \w the|strong="H3045"\w* \w clan|strong="H4940"\w* \w of|strong="H8034"\w* \add Naomi’s dead husband\add*, Elimelech. \w He|strong="H8034"\w* \w was|strong="H8034"\w* rich \w and|strong="H3045"\w* well-known/influential. \w His|strong="H3045"\w* \w name|strong="H8034"\w* \w was|strong="H8034"\w* \w Boaz|strong="H1162"\w*.   
\p
\v 2  \add One day\add* \w Ruth|strong="H7327"\w* said \w to|strong="H3212"\w* \w Naomi|strong="H5281"\w*, “\w Let|strong="H4994"\w* \w me|strong="H4994"\w* \w go|strong="H3212"\w* \w to|strong="H3212"\w* \w the|strong="H4672"\w* \w fields|strong="H7704"\w* \w and|strong="H3212"\w* pick \w up|strong="H3950"\w* \w the|strong="H4672"\w* \w grain|strong="H7641"\w* \w left|strong="H4672"\w* behind \w by|strong="H3212"\w* \w the|strong="H4672"\w* workers.” \w Naomi|strong="H5281"\w* replied, “\w Go|strong="H3212"\w* ahead, \w my|strong="H4672"\w* \w daughter|strong="H1323"\w*.”  
