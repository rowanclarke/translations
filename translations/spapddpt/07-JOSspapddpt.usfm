\v 9 \w Josué|strong="H3091"\w* \w también|strong="H2088"\w* ordenó erigir 12 piedras \w en|strong="H5704"\w* \w medio|strong="H8432"\w* del \w Jordán|strong="H3383"\w*, \w en|strong="H5704"\w* el \w lugar|strong="H8478"\w* \w donde|strong="H8033"\w* \w estuvieron|strong="H1961"\w* \w los|strong="H1961"\w* \w pies|strong="H7272"\w* \w de|strong="H8478"\w* \w los|strong="H1961"\w* \w sacerdotes|strong="H3548"\w* \w que|strong="H5704"\w* cargaban el Arca del \w Pacto|strong="H1285"\w*. \w Allí|strong="H8033"\w* \w están|strong="H1961"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
\p
\v 10 \w Los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w que|strong="H5704"\w* cargaban \w el|strong="H3605"\w* Arca permanecieron \w en|strong="H5704"\w* \w medio|strong="H8432"\w* del \w Jordán|strong="H3383"\w* \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w se|strong="H5971"\w* cumplió \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H5704"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w* \w que|strong="H5704"\w* le dijera \w al|strong="H5704"\w* \w pueblo|strong="H5971"\w*, según \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H5704"\w* \w Moisés|strong="H4872"\w* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*. \w El|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* apresuró \w a|strong="H3068"\w* cruzar.  
\v 11 \w Cuando|strong="H1961"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* terminó \w de|strong="H6440"\w* cruzar, \w el|strong="H3605"\w* Arca \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* y \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* cruzaron \w ante|strong="H6440"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*.  
\v 12 También \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Rubén|strong="H7205"\w*, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Gad|strong="H1410"\w* y la media \w tribu|strong="H7626"\w* \w de|strong="H6440"\w* \w Manasés|strong="H4519"\w* cruzaron en orden \w de|strong="H6440"\w* batalla \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, tal como \w Moisés|strong="H4872"\w* les \w habló|strong="H1696"\w*.  
\v 13 Unos 40.000 hombres equipados para la \w guerra|strong="H4421"\w* \w pasaron|strong="H5674"\w* en \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* en formación \w de|strong="H6440"\w* \w batalla|strong="H4421"\w* \w a|strong="H3068"\w* las llanuras \w de|strong="H6440"\w* \w Jericó|strong="H3405"\w*.   
