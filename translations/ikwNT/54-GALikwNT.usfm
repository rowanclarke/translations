\id GAL - Ikwerre
\h Ele Galasia
\toc1 Ọkwukwo izi Pọlu gbaznennu Ele Galasia
\toc2 Ele Galasia
\toc3 Gal
\mt2 Ọkwukwo izi Pọlu
\mt2 gbaznennu
\mt1 Ele Galasia
\imt1 Nhne gbasịri ọkwukwo izi ka
\im Hite n'ọpanizo ọkwukwo izi Pọlu gbaznennu ọgbako Chiokike ke zị nụ Galasia, o mernu be mahịa nhne lawụru ke zị mkpa. Ke mbọm, bụ ma be mahịa nụ ọ bụ ezi nye izi Karaịsi, ke ẹbo bụ nụ izi ọma ọ nọokpo okwo a bụ ezi ọka. Ka bụ kwnornu nụ agịda ele badnụ naakaa nụ Pọlu bụ nye izi aghalaghala nụ nye nọokpo okwo izi ọma aghalaghala.
\ip Pọlu bụ nye izi Karaịsi n'ezi ọka, nye Nyenwe aị nyernu ẹrnu o zni ele bụ́o ele Ju izi ọma. Pọlu kannụ Pita nụ ọ bụ nye ruwhnu lawụru, kwnornu nụ o kwémana o snornu ele bụ́o ele Ju ele zá naabịta Iwu Mozizi ri wiri nga ọ whnụrnu ele hi nụ Jerusẹlem va.
\ip Pọlu kwusiri a rikne nụ okwolem hite n'ọkwnata mkpọma nhne Chiokike jeeji znọhia badnụ. Ka whụyaru iwhne nụ bụdnu Ebereham, nye nahịaru mkwna Chiokike hite n'ọkwnata mkpọma.
\iot Nhne zị n'ọkwukwo izi ka
\io1 Ezi nye izi nụ ezi izi ọma \ior (1:1-10) \ior*
\io1 Chiokike họhiaru Pọlu lele nye izi Karaịsi \ior (1:11-24)\ior*
\io1 Pọlu naagbanụ izi ọma akebne \ior (2:1-21) \ior*
\io1 Ọznohia kwolem hite n'ọkwnata mkpọma \ior (3:1---4:31)\ior*
\io1 Ele Enine Nsọ nụ ọwhnun'anya noodu \ior (5:1---6:10)\ior*
\io1 Ọdo aka nụ nsnị ipne-aznụ \ior (6:11-18)\ior*
\c 1
\p 
\v 1 Mawa, Pọlu, nye izi Karaịsi ke híge n'aka badnụ mọbu nụ rikne ke badnụ, kọvu hite nụ Jizọsi Karaịsi nụ Chiokike Nda, nye mernu Jizọsi hi n'ẹnwu lizọ,
\v 2 nụ kpakara rụmu nda ele me nụ be zị naagbaznenu kpakara ọgbako Chiokike ke zị nụ Galasia ọkwukwo.
\p 
\v 3 Oru nụ udno ke Chiokike Nda aị nụ ke hi n'aka Nyenwe aị Jizọsi Karaịsi dazịnu anụ.
\v 4 Karaịsi gweru bụdnu a nyee kwnornu mmehie aị ma ọ dọhia aị n'ige ọjo ka lele kpa echiche Chiokike Nda aị pioru.
\v 5 Ọznarni zịnu a ọkwnukokwnu. Amịm.
\s1 Izi ọma berere zị́la
\p 
\v 6 Ọ gbagwojiri m anya nụ anụ ghasarụ nye wam sukwuru anụ bna n'oru ke Karaịsi, zne izi ọma berere.
\v 7 N'ezi, izi ọma berere zị́la, kọvu agwna ele badnụ naakpahie anụ anya, noopio ọ gbanwo izi ọma Karaịsi.
\v 8 Kọvu ọ bụru aị mọbu enine izi hi n'oligwe va zni anụ izi ọma berere ke bụ́o ke a znirni anụ, Chiokike vụ a ọnu ọkwnukokwnu.
\v 9 Lele kpa a kwuru nụ mbọm, m nookwu kwno a berere, ọ bụru nụ nye ọbula zni anụ izi ọma ke zị ichne nụ ke anụ nahịaru, Chiokike vụ a ọnu ọkwnukokwnu.
\p 
\v 10 Ka o neegesi nụ m noopio ruwhnu ọma ke badnụ, bụ́o ke Chiokike? M noopio nhne jaamasị badnụ sa? Ọ bụru nụ m noopio ruwhnu ọma ke badnụ, m jọ́obu nye izi Karaịsi.
\s1 Chiokike sukwuru Pọlu
\p 
\v 11 Me kanụ anụ, rụmu nda m, izi ọma me nọokpo okwo a bụ́o nhne hi n'aka badnụ.
\v 12 M náhịage m a n'aka badnụ, ọ bụ́o badnụ znirni m a, kọvu Jizọsi Karaịsi kpumernu a nyee m.
\p 
\v 13 Anụ nụrnu kpa me wuru bụdnu nụ mbọm n'okpukpe ele Ju, nụ kpa me kpaknarnụ ọgbako Chiokike ẹhni k'agịda, gbalị ma o whu.
\v 14 M be m ele Ju ibne m ọsno ele me nụ be bụ ebiri n'okpukpe ele Ju, m ji m kpakara mkpọma yisi n'omen'ẹli ele nda aị ọknani.
\v 15 Kọvu Chiokike bịtaru m ichne hite nụ rụwho nne m, o sukwuru m hite n'oru a. Nga ọ masịri a,
\v 16 o kpumennu m Nnwọ a, ma m nwernu m rikne zni ele bụ́o ele Ju izi ọma gbasịri a. Ige wam, m znége ma me nụ badnụ ọbula tnụ ọtnutnu gbasịri a.
\v 17 M znége m Jerusẹlem zne ọ whnụ ele be m ọsno bụru ele izi, kọvu m znernu m Arebịa, m lahna Damasịkosi.
\p 
\v 18 Nga awha ẹto whemernu, m znernu m Jerusẹlem zne mahịa Pita, me nụ a dazịri nri nụ ọbochi isne.
\v 19 M whnụ́ge m nye izi berere okwolem Jemisi nwene Nyenwe aị Jizọsi.
\v 20 Nhne me gbannụ anụ n'ọkwukwo bụ ezi ọka, Chiokike magwụ nụ ọ bụ́o aghalaghala.
\v 21 Omekwo, m zne n'ẹli ke zị nụ rime Siriya nụ Silisia.
\v 22 Ọ zá nye Karaịsi ke zị nụ ọgbako Chiokike ke zị nụ Judiya magwụ nye me bụ ruwhnu nụ ruwhnu.
\v 23 Kọvu nụ be nụrnu ọtnutnu, “Nye wam ke naakpakna aị ẹhni neezni izi ọma ọkwnata mkpọma wam ọ gbalịri o mee ma o whu nụ mbọm.”
\v 24 Be znarnị Chiokike kwnornu m.
\c 2
\s1 Ele izi berere // nabnanyarnụ Pọlu
\p 
\v 1 Nga nri nụ awha ẹno whemernu, m lahna m Jerusẹlem, me nụ Banabasị, m kwuru Taịtosi zne.
\v 2 M znernu m kwnornu nụ Chiokike kpumennu m me zne. N'iznuznu ke me nụ ele risi gbarụ ichne, m kọwaru m izi ọma me znirni ele bụ́o ele Ju, ọ zị ẹrnu me rnụrnu mọbu ke me nọornu kịtna bọ bụ nhne etekne.
\v 3 Taịtosi nye me nụ a sno, ọ bụ n'ezi nụ ọ bụ nye Giriki, be kwnágidnene a ọ kpa nka.
\v 4 Agwna rụmu nda aghalaghala gbebnarnụ va o nyosna kpa a jiri nwernu ẹhni aị nụ rime Karaịsi Jizọsi, be pioru ma a bụru ọhi iwu ele Ju.
\v 5 A nyége be oghere rịa rịa ma a bịtannu anụ ezi ọka ke izi ọma chịm chịm.
\p 
\v 6 Agwna ele nụ lele be bụ ele risi. Nhne ọbula be bụ zá m mkpa, kwnornu nụ Chiokike lé badnụ anya nụ ruwhnu n'ikpe. Ọ zá nhne ele ka tụkwasiri nụ izi me znirni.
\v 7 Kọvu be whnụrnu nụ Chiokike nyernu m izi ọma me zni ele bụ́o ele Ju, lele kpa o nyernu Pita ẹrnu o zni ele Ju izi ọma.
\v 8 Chiokike wam ke nọornu ẹrnu n'izi ọma Pita znirni ele Ju lele nye izi, bụ masị nye nọornu ẹrnu n'izi ọma me znirni ele bụ́o ele Ju lele nye izi.
\v 9 Nga Jemisi nụ Pita nụ Jọni, ele nụ lele ele risi whnụrnu nụ Chiokike nyernu m ẹrnu ka zị ichne, be gbasịri me nụ Banabasị akarikwnunga ke neegesi nụ a bụ otu. Be kweru a zne zni ele bụ́o ele Ju izi ọma, be zne zni ele Ju izi ọma.
\v 10 Nhne be nọorio kpọi bụ, a chenwanya ele mboni, kị bụ nhne me mernu wara wara.
\s1 Pọlu bigbọru Pita // n'Antịoku
\p 
\v 11 Nga Pita vaduru Antịoku, m bigbọru m a nụ ruwhnu ọhna kwnornu nụ ọ dnahieru.
\v 12 Sụ ele Jemisi ziyaru va, Pita nụ ele bụ́o ele Ju neerikọ wiri. Kọvu nga be vaduru, o kwéle o sno be ri wiri, kwnornu nụ ogwnu ele be kparụ nka tụru a.
\v 13 Ele Ju ke gwnarnụ snornu a kpa ichne ichne kwnornu nụ ruwhnu lawụru a, ke kpayarụ Banabasị sno be nụ ruwhnu lawụru be.
\p 
\v 14 Nga me whnụrnu nụ be méne lele ezi ọka ke izi ọma, m kanụ Pita nụ ruwhnu kpakara be, “Ị bụ nye Ju, kọvu ị noowu bụdnu lele ele bụ́o ele Ju, ọ bụ́o lele nye Ju. Ndaa kpa ị naakwnagidne ele bụ́o ele Ju be snornu omen'ẹli ele Ju?”
\s1 Ọznohia bụ hite n'oru
\p 
\v 15 N'ezi, a bụ ele Ju hite n'ọmumu aị, a bụ́o ele mmehie lele kpa be nookwu ele bụ́o ele Ju.
\v 16 Kọvu a magwụ nụ badnụ nụ Chiokike mernu udno hite n'ọkwnata mkpọma nụ Jizọsi Karaịsi, ọ bụ́o n'ome nhne iwu kwuru. A kweru nụ Karaịsi Jizọsi ma aị nụ Chiokike zịri n'udno hite n'ọkwnata mkpọma nụ Karaịsi. Ọ bụ́o n'ome nhne iwu kwuru, kwnornu nụ ọ zá nye ọbula bụ nye ọma hite n'ome nhne iwu kwuru.
\p 
\v 17 Ọ bụru nụ nga a noopio ma aị nụ Karaịsi zịri n'udno, a whnụ ẹhni aị nụ a bụ ele mmehie lele ele berere, ka o neegesi nụ Karaịsi naadasị mmehie n'ikwnu? Chiokike kwé.
\v 18 Ọ bụru nụ me panịzo noowu nhne me kwnadnarnụ akwnadna, ka neegesi nụ m bụ m nye noolulu iwu.
\v 19 Kwnornu nụ hite n'iwu m nwụrnu ẹnwu hne iwu zị, ma m zịri m bụdnu nụ rime Chiokike.
\v 20 Be gweru m yisinu Karaịsi kpọgidne aị n'olu ọgba a, m zá m bụdnu ke m, kọvu Karaịsi wu nụ rime m. Bụdnu ke me zị n'anọ-ẹhni bụ ke me zị n'ọkwnata mkpọma ke Nnwọ Chiokike, nye whnụrnu m n'anya gweru bụdnu a nyee kwnornu m.
\v 21 M zá m neelewhu oru Chiokike anya, kwnornu nụ ọ bụru nụ ome mma bụ hite n'iwu, ẹnwu Karaịsi nwụrnu bụ nhne etekne.
\c 3
\s1 Iwu mọbu ọkwnata // mkpọma
\p 
\v 1 Anụ ele Galasia iwhnirniwhno, nyele kpahieru anụ anya? Nụ ruwhnu anụ bụ hne me gesiri anụ nụ be kpọgburu Jizọsi Karaịsi n'ọgba.
\v 2 M pioru m ọ mahịa otu nhne n'aka anụ. Anụ nahịaru Enine Nsọ hite n'ome nhne iwu kwuru, sọbu hite n'okweru nhne anụ nụrnu?
\v 3 Anụ bụ ele iwhnirniwhno kpa? Anụ panịzoru n'Enine ke Chiokike, anụ naagbalị o wu bụdnu kịtna hite nụ rikne ke aka anụ?
\v 4 Kpakara awhnụwhnu anụ tarụ ọ bụ nhne etekne? N'ezi, ọ bụ kwnornu nụ nhne etekne?
\v 5 Chiokike nyernu anụ Enine a, rnụ ẹrnu ndu-ẹhni n'esilawụru anụ. Ọ bụ kwnornu nụ anụ mernu nhne iwu kwuru sọbu nụ anụ kweru nhne anụ nụrnu?
\v 6 Lele kpa Ebereham “kweruru Chiokike, Chiokike gwnụsinu a nụ ọ bụ nye mee mma.”
\v 7 Anụ mahịa nụ kpakara ele nwernu ọkwnata mkpọma bụ rụmu Ebereham.
\v 8 Ọkwukwo nsọ kwuru nụ hne zị nụ ruwhnu nụ Chiokike jeeme ma ya nụ ele bụ́o ele Ju zịri n'udno hite n'ọkwnata mkpọma, znirni Ebereham izi ọma, kaa, “Hite nụ rime i, m jọogozi kpakara mba ke ọwa.”
\v 9 A whnụrnu nụ Chiokike nọogozi kpakara ele ke jeekweru lele kpa Chiokike gọziri Ebereham, nye kweru nụ ya.
\p 
\v 10 Ọvu ọnu zịnu kpakara ele neeche nụ Chiokike jọogwnu be lele ele ikpe mána kwnornu nụ be naabịta Iwu. Be gbarụ a n'ọkwukwo nsọ, kaa, “Ọvu ọnu zịnu kpakara ele zá naabịta kpakara nhne be gbarụ n'Iwu, neeme masị be.”
\v 11 O dnornu aị anya nụ ọ zá nye ya nụ Chiokike zị n'udno hite n'Iwu, kwnornu nụ ọkwukwo nsọ kwuru, “Nye mee mma jeehi n'ọkwnata mkpọma a zịri bụdnu.”
\v 12 Kọvu Iwu knóge aka n'ọkwnata mkpọma, lele kpa ọkwukwo nsọ kwuru, “Nye neeme kpakara nhne ka jaazị bụdnu nụ rime be.”
\v 13 Karaịsi gbahịaru aị hite n'aka ọvu ọnu ke iwu, ọ ghọnu aị ọvu ọnu. Ọkwukwo nsọ kwuru, “Be vụru nye ọbula be kpọkwnusiri n'olu isisi ọnu.”
\v 14 Karaịsi mernu ka ma ngọzi wam Chiokike kweru Ebereham mkwna bụru ke ele bụ́o ele Ju hite nụ Karaịsi Jizọsi, ma a hite n'ọkwnata mkpọma nahọru mkwna Enine Chiokike.
\s1 Iwu nụ mkwna
\p 
\v 15 Rụmu nda m, m jeeji nhne anya nọowhnu noogbu esni. Ọ zá nye nwernu rikne o lulu njọ-ẹhni badnụ lawụru gbarụ, mọbu tụkwasi nhne n'olu a.
\v 16 Kịtna, Chiokike kweru Ebereham nụ nnwọ a mkwna wam. Ọkwukwo nsọ kwúge agịda rụmu, kọvu “nnwọ ị,” ke bụ otu badnụ, nye bụ Karaịsi.
\v 17 Nhne me nookwu bụ ka, iwu wam ke be nyernu riwhu awha ẹno nụ nri ẹto kpa mkwna Chiokike kweru Ebereham whemernu, nwée rikne lulu mkwna Chiokike kweru mọbu mee a ọ gharụ ọ zị ire.
\v 18 Kwnornu nụ ọ bụru nụ nhne okehịa ka kno aka n'iwu, ọ bụ́ma mkwna, kọvu Chiokike kwnornu n'oru a, o nyernu a Ebereham hite nụ mkwna.
\p 
\v 19 Kịni bụ nhne be kwno nyee iwu? Be nyernu a kwnornu ọdnahie ke badnụ tem dụ nga Nnwọ wam jaava bụ nye mkwna wam nọotu aka. Chiokike nyernu iwu hite n'aka ele enine izi, o nyee a nye ibno.
\v 20 Nye ibno zá mkpa hne otu badnụ zị, Chiokike bụ otu.
\p 
\v 21 Ka o neegesi nụ iwu megidnernu mkwna Chiokike? Ọ́za rịa rịa! Kwnornu nụ ọ bụru nụ be nyernu iwu ke jeenye bụdnu, ome mma jọoburu hite n'iwu.
\v 22 Kọvu ọkwukwo nsọ kwuru nụ kpakara ọwa bụ ọhi mmehie, ma nhne Chiokike kweru mkwna o nyee hite n'ọkwnata mkpọma nụ Jizọsi Karaịsi bụru ke ele kweru ekwe.
\p 
\v 23 Tụtu sụ ọkwnata mkpọma varụ, a bụ ele ikelu ke iwu, be gbagidnernu aị ọnuhna dụ nga be kpumernu ọkwnata mkpọma.
\v 24 Iwu wam bụ nye neelegidne aị anya, kwuru aị vakwnusi Karaịsi, ma aị nụ Chiokike zịri n'udno hite n'ọkwnata mkpọma.
\v 25 Kpa ọkwnata mkpọma varụ, a zị́ma nụ mkpururu nye neelegidne aị anya, ke bụ iwu.
\s1 A bụ rụmu Chiokike
\p 
\v 26 Kpakara anụ bụ rụmu Chiokike hite n'ọkwnata mkpọma nụ Karaịsi Jizọsi.
\v 27 Kpakara anụ ele be wụru mini bna nụ Karaịsi jooworu bụdnu ikne Karaịsi lele iwo.
\v 28 Ọ zá nhne zị ichne nụ hne nye Ju nụ nye Giriki zị, mọbu hne ọhi nụ nye bụ́o ọhi zị, mọbu hne nyerukna nụ nyerinya zị. Kpakara anụ bụ otu nụ rime Karaịsi Jizọsi.
\v 29 Ọ bụru nụ anụ bụ ele Karaịsi, anụ bụ rụmu Ebereham, ele jeekehịa mkwna wam Chiokike kweru Ebereham.
\c 4
\p 
\v 1 Nhne me nookwu bụ kọriri ka, nye ọbula ke jeeri mkpe nda a hne ọ bụ watakịri, ọ zá nhne zị ichne hne ya nụ nye ọhi zị, ọ bụ n'ezi nụ ya nwe kpakara nhne.
\v 2 Ele berere jaazị neelegidne a anya, neezni a nhne, tem dụ ige nda a karụ.
\v 3 Kpam masị, nga a bụ rụmu takịri, a bụ ọhi rẹnwu ọjo matị matị ke ọwa.
\v 4 Kọvu nga ige dụru, Chiokike ziyaru Nnwọ a, nye nyerinya mụrnu nụ mkpururu Iwu Mozizi,
\v 5 ma ọ gbahịa ele zị nụ mkpururu iwu, ma a bụru rụmu Chiokike.
\v 6 Kwnornu nụ anụ bụ rụmu a, Chiokike ziyaru Enine Nnwọ a nụ rime mkpọma aị, Enine ke naakwna, “Papa, Nda m.”
\v 7 Kam kpayarụ ị bụ́ma ọhi, kọvu nnwọ, hne ị bụ nnwọ, Chiokike mernu ị bụru nye jeeri mkpe a.
\s1 Nhne metụru Pọlu // nụ mkpọma
\p 
\v 8 Nụ mbọm, nga anụ máa Chiokike, anụ bụ ọhi nhne bụ́o chi.
\v 9 Kọvu kịtna, anụ magwụ Chiokike, mọbu Chiokike magwụ anụ. Ndaa kpa anụ jaalahnakwnusi rẹnwu ọjo matị matị ke nwée rikne, ọ zá nhne be ji be neeme? Kịni kpayarụ anụ jọoburu kwno ọhi be berere?
\v 10 Kịni kpayarụ anụ naabịta ọbochi zị ichne, ma ẹnwa, ma ige nụ awha?
\v 11 Ogwnu anụ nọotu m. Ọ jọobu nụ ẹrnu m nụ risi anụ bụ nhne etekne sa?
\p 
\v 12 Rụmu nda m, m naarịasno anụ, anụ nụ lele me, m nụ m lele anụ ele bụ́o ele Ju. Ọ zá nhne ọjo ọbula anụ mernu m nga me znirni anụ izi ọma nụ mbọm.
\v 13 Anụ chenwanya ọ bụ ẹhni igbugbu mernu me dazịri zni anụ izi ọma nụ mbọm.
\v 14 Ọ bụ n'ezi nụ ẹhni igbugbu m bụnnu anụ nhne ọrnurna, anụ lédnage m anya mọbu zụsa m. Kọvu anụ kwubnanyarnụ m lele nụ m bụ m enine izi Chiokike, lele nụ m bụ m Karaịsi Jizọsi n'iwhuru a.
\v 15 Kịni mernu ovu ọso n'ọnu ke anụ nwernu nụ mbọm? M jaagbanụ anụ akebne, ọ bụru nụ o kweru o mee, anụ znernu ahnahịa mkpụru anya anụ lawụru chịta m be.
\v 16 M ghọla nye irno anụ kwnornu nụ m kannụ m anụ ezi ọka sa?
\p 
\v 17 Kpakara ele neegesi nụ nhne gbasịri anụ neemetụ be nụ mkpọma, be zá neeme a kwnornu nhne ọma anụ. Nhne be noopio bụ ma be gweme anụ hne a zị, ma anụ menu be kpa be neemenu anụ.
\v 18 Ọ bụru ọma o gweru mkpọma anụ neeme nhne bụru ọma ige ọbula, ọ bụ́o nga me nụ anụ zị kpọi.
\v 19 Rụmu takịri m, ele rime neeme m kwnornu be lele kpa rime neeme nyerinya nọomu nnwọ. M zị m nụ nhne igbugbu ka tem oyiyi Karaịsi zịri nụ rime anụ.
\v 20 Ọ kanụ m mma ọ bụru nụ me nụ anụ zị kịtna, m znernu m amahịa kpa me znernu ọbita ọnu kwunu anụ ọka. Kwnornu nụ mkpọma naala m mini hne anụ zị.
\s1 Haga nụ Sera
\p 
\v 21 Anụ kanụ m, anụ ele noopio ọ zị nụ mkpururu iwu, anụ máa nhne iwu wam kwuru?
\v 22 Kwnornu nụ be gbarụ a n'ọkwukwo nsọ, kaa nụ Ebereham nwernu rụmu rukna lawụru, nnwerne ọhi mụrnu otu, nnwerne ke bụ́o ọhi mụrnu ke berere.
\v 23 Nnwọ ke nnwerne ọhi mụrnu bụ ke ọ mụrnu kpa be mụrnu ele berere. Kọvu nnwọ ke nnwerne ke bụ́o ọhi mụrnu bụ nnwọ Chiokike kweru mkwna a.
\p 
\v 24 Ka bụ nhne ọma atụ, ele rinya lawụru ka bụ ọgba-njọ-ẹhni lawụru. Otu bụ Haga, ke hi nụ rugwu Saịna, nye rụmu a bụ ele ọhi.
\v 25 Haga nụ lele rugwu Saịna ke zị nụ Arebịa, ọ nụ kwno lele ẹli Jerusẹlem tna, ke ya nụ kpakara rụmu a bụ ọhi nụ mkpururu iwu.
\v 26 Kọvu Jerusẹlem ke zị n'olu bụ́o ọhi, ọ bụ nne aị.
\v 27 Kwnornu nụ be gbarụ a n'ọkwukwo nsọ, kaa,
\q1 “Nwụdna, jị nyerinya ke nwée nnwọ,
\q2 jị nye mụ́ge nnwọ,
\q1 gweru okne nkọli siwama lụlo, mkpọma sọ ị n'ọnu,
\q2 jị nye rime nnwọ mélele,
\q1 kwnornu nụ nyerinya ke be ghasarụ jeenwe agịda rụmu,
\q2 kakwo nyerinya ke nwernu nzi.”
\p 
\v 28 Kịtna, rụmu nda m, lele Aziki, anụ bụ rụmu Chiokike kweru nụ mkwna.
\v 29 N'ige wam, nnwọ wam be mụrnu lele kpa be mụrnu ele berere kpaknarnụ nnwọ wam be mụrnu hite nụ rikne Enine ẹhni. Ọ zị kọriri kpam kịtna.
\p 
\v 30 Kọvu kịni bụ nhne ọkwukwo nsọ kwuru? “Chịhala ọhi nyerinya wam nụ nnwọ a, kwnornu nụ nnwọ nnwerne ọhi nụ nnwọ nnwerne ke bụ́o ọhi jéeri otu mkpe.”
\v 31 Ke bụ nụ, rụmu nda m, a bụ́o rụmu nnwerne ọhi, kọvu a bụ rụmu nnwerne ke bụ́o ọhi.
\c 5
\s1 A nwernu ẹhni aị // nụ rime Karaịsi
\p 
\v 1 Karaịsi mernu a nwernu ẹhni aị. Kam kpayarụ, anụ gwuzosi rikne, anụ kwé anụ bụru kwno ọhi berere.
\p 
\v 2 Anụ bnote nsnị, mawa Pọlu naakanụ anụ, anụ kwé be kpa anụ nka, kwnornu nụ anụ mee kpam, ọ zá mbnarna Karaịsi bnannụ anụ rịa rịa.
\v 3 Me kwu kwno a berere, nye ọbula ke kweru be kpa a nka jaabịtariri kpakara iwu.
\v 4 Anụ ele noopio be nụ Chiokike zịri n'udno hite n'iwu, anụ kewahalaru ẹhni anụ hne Karaịsi zị. Anụ zị́ma n'oru Chiokike.
\v 5 Kọvu a neele anya nụ aị nụ Chiokike jaazị n'udno hite n'ọkwnata ovu. Ka bụ nhne a neese hite n'Enine.
\v 6 Kwnornu nụ rime Karaịsi Jizọsi, ọ zá nhne zị ichne nụ ọkpa nka nụ ọkpáge nka, kọvu ọkwnata ovu aị ke nọornu ẹrnu n'ọwhnun'anya bụ nhne zị mkpa.
\p 
\v 7 Anụ neemekwa nkarị nụ mbọm, nyele kpahieru anụ anya, kaa, anụ bnó nsnị nhne ezi ọka nookwu?
\v 8 Nhne nụ kpa híge n'aka nye wam sukwuru anụ.
\v 9 “Nhne whụ brẹdi matị neeme kpakara brẹdi whụ ọwhu.”
\v 10 M tụkwasiri m Nyenwe aị mkpọma nụ anụ jéekwe anya hie anụ, anụ mee nhne berere. Kọvu nye ọbula ke naakpakna anụ ẹhni jeeri nhne ọ kpasịri, nye ọ masịri a ọ bụru.
\v 11 Rụmu nda m, ọ bụru nụ m zị kọriri m neezni nụ ọkpa nka zị mkpa, kịni kpayarụ be naakpakna m ẹhni? Ọ bụru nụ m zị m nookwu nụ ọkpa nka zị mkpa, izi gbasịri ọgba Karaịsi jọ́oburu rugwu ọkpobi ọchi.
\v 12 Ọ jaamasị m ọ bụru nụ ele wam naakpakna anụ ẹhni jọowhoga, mee ẹhni be okiri badnụ.
\p 
\v 13 Rụmu nda m, Chiokike sukwuru anụ bụru ele nwernu ẹhni be. Kọvu anụ kwékwadia o nwernu ẹhni anụ mee, anụ mee nhne anọ-ẹhni anụ noopio. Kọvu anụ gweru ọwhnun'anya znenu ibne anụ izi.
\v 14 Kpakara nhne be nyernu n'iwu chịkotaru risi n'otu nhne ka, “Ị jọowhnu nye agbatibi i n'anya, lele ẹhni ị.”
\v 15 Ọ bụru nụ anụ jaazị naatagbu, nọodoka ibne anụ, anya dụ anụ ẹli ọ zị anụ gbukwo ẹhni anụ.
\s1 Anụ kweru Enine // nẹechi anụ
\p 
\v 16 Nhne me naakaa bụ ka, anụ wuru bụdnu n'Enine, anụ jéemezu nhne anọ-ẹhni noopio.
\v 17 Kwnornu nụ nhne anọ-ẹhni noopio neemegidne nhne Enine Chiokike noopio. Nhne Enine Chiokike noopio neemegidne nhne anọ-ẹhni noopio. Be neemegidne ibne be, anụ gharụ o mee nhne anụ noopio.
\v 18 Kọvu, ọ bụru nụ Enine noodu anụ, anụ zá nụ mkpururu iwu.
\p 
\v 19 Ẹrnu ke anọ-ẹhni whụyaru iwhne, ke bụ, ome ọyi, ọgba ikoro, nhne zị́la rịchna,
\v 20 ọkwa rẹnwu nụ amusu, irno, ọlu ọgwnu, ọkpa ichne ichne, okwno-awụwa, ọnuma, aka-nchnị, ọbna otu,
\v 21 ọwho-anya, okne manya, okne otne eri, nụ nhne nụ kpa. Ka bụ nhne me nọodọ anụ aka nụ nsnị kịtna, lele kpa me dọru anụ nụ mbọm, kaa nụ ele neeme nhne nụ kpa, jéekehịa igwe n'ẹli-eze Chiokike.
\p 
\v 22 Kọvu mkpụru ke Enine neegweya bụ ọwhnun'anya, snarnịma, udno, ndidi, ovu ọma, ọburu ọma, okwesi ọkwnata mkpọma,
\v 23 ọzi wọhnernerne, badnụ nwụkwaru ẹhni a, ọ zá iwu ke megidnernu nhne nụ kpa.
\v 24 Ele ke Karaịsi Jizọsi bụ ele gweru anọ-ẹhni be nụ nhne nọogwnu be kpọgidne n'olu ọgba.
\v 25 Ọ bụru nụ a zị bụdnu nụ rime Enine, ngwa ma a zne izne nụ rime Enine.
\v 26 Ngwa ma a gharụ oknomokno, gharụ naakpasu ibne aị ovu owe ẹhni, gharụ enwe ọwho-anya hne ibne aị zị.
\c 6
\s1 A vurita ivu ibne aị
\p 
\v 1 Rụmu nda m, ọ bụru nụ badnụ ọbula mee mmehie, anụ ele gwuzosiri rikne nụ rime enine gweru wọhnernerne znikwata a nkarị. Anya dụ masị anụ ẹli, ọ zị anụ dnabna n'ọrnurna.
\v 2 Anụ vurita ivu ibne anụ. Ọ bụru nụ anụ neeme kpam, anụ jeemezu iwu Karaịsi.
\v 3 Ọ bụru nụ badnụ ọbula neeche nụ ọ bụ nhne nga ọ zá nhne ọ bụ, o nooduwhu ẹhni a.
\v 4 Nye ọbula tule ẹrnu a, ige wam, o jeenwe rikne mee oknomokno n'ẹrnu a. Ọ zá nye ji ẹrnu a tụ n'ẹrnu nye berere,
\v 5 kwnornu nụ nye ọbula jọornu ẹrnu zịnu a.
\p 
\v 6 Nye ọbula be znirni izi ọma ke Karaịsi whnụ nụ ya nụ nye znirni a nhne kehịaru nhne bụru ọma.
\p 
\v 7 Anụ dúwhu ẹhni anụ. Kwnornu nụ ọ zá nye jọokpoli Chiokike mgbaị. Mkpụru ọbula badnụ kpasịri bụ nhne ọ jọoghoru.
\v 8 Nye ọbula ke kparụ mkpụru n'anọ-ẹhni a, jeehite n'anọ-ẹhni a ghọru ẹnwu, kọvu nye kparụ mkpụru n'Enine, jeehi n'Enine a ghọru bụdnu kwó okwo lele mkpụru.
\p 
\v 9 Anụ kwékọ rikne gwụ anụ n'ome nhne bụru ọma, kwnornu nụ ige vawa nga a jọoghoru mkpụru, ọ bụru nụ rikne gwụ́ge aị.
\v 10 Kam kpayarụ, lele kpa a nwernu oghere, a zịri neemenu kpakara ele badnụ nhne bụru ọma, ke kakwo, ele zị n'ezi-nụ-ọro ke ọkwnata mkpọma.
\s1 Ọdo aka nụ nsnị ipne-aznụ
\p 
\v 11 Kịtna, m ji m aka m naagba ọkwukwo izi. Le kpa mkpụru ọkwukwo me naagba hna ezi.
\p 
\v 12 Ele neeme oknomokno n'anọ-ẹhni bụ ele naakaa be kpa anụ nka. Ka bụ ma be gharụ ọ kpakna be ẹhni kwnornu ẹnwu n'ọgba Karaịsi.
\v 13 Ọ bụbedi be ele be kparụ nka zá naabịta iwu. Be noopio be kpa anụ nka ma be mee oknomokno nụ nhne zị n'anọ-ẹhni anụ.
\v 14 Chiokike kwékọ me mee oknomokno hne ọ bụ́o n'ọgba Nyenwe aị Jizọsi Karaịsi, nye be kwnornu ẹhni a kpọgidne ọwa n'ọgba hne me zị, kpọgidne masị m n'ọgba hne ọwa zị.
\v 15 Kwnornu nụ ọkpa nka nụ ọkpáge nka bụ́o nhne. Nhne bụ nhne bụ bụdnu ikne.
\v 16 Udno nụ obirizi zịnu kpakara ele noosno iwu ka nụ bụdnu be, be nụ kpakara ele bụ Izirẹli ke Chiokike.
\p 
\v 17 Hite kịtna zne ruwhnu, ọ zá nye kpakna m ẹhni berere, kwnornu nụ m vu m n'ẹhni m ẹnya ke neegesi nụ m bụ m nye izi Jizọsi.
\p 
\v 18 Rụmu nda m, oru ke Nyenwe aị Jizọsi Karaịsi dazịnu enine anụ. Amịm.
