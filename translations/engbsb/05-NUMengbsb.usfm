\b  
\m
\v 3 \w You|strong="H3605"\w* \w and|strong="H1121"\w* Aaron \w are|strong="H1121"\w* \w to|strong="H3318"\w* \w number|strong="H6485"\w* \w those|strong="H3605"\w* \w who|strong="H3605"\w* \w are|strong="H1121"\w* \w twenty|strong="H6242"\w* \w years|strong="H8141"\w* \w of|strong="H1121"\w* \w age|strong="H1121"\w* \w or|strong="H1121"\w* \w older|strong="H4605"\w* \w by|strong="H8141"\w* \w their|strong="H3605"\w* divisions—\w everyone|strong="H3605"\w* \w who|strong="H3605"\w* \w can|strong="H1121"\w* serve \w in|strong="H8141"\w* \w Israel|strong="H3478"\w*’s \w army|strong="H6635"\w*.  
\v 4 \w And|strong="H1004"\w* \w one|strong="H1931"\w* \w man|strong="H7218"\w* \w from|strong="H1961"\w* each \w tribe|strong="H4294"\w*, \w the|strong="H1961"\w* \w head|strong="H7218"\w* \w of|strong="H1004"\w* each \w family|strong="H1004"\w*, must \w be|strong="H1961"\w* \w there|strong="H1961"\w* \w with|strong="H1004"\w* \w you|strong="H1004"\w*.   
\s1 The Leaders of the Tribes  
\b  
\m
\v 5 These \w are|strong="H1121"\w* \w the|strong="H5975"\w* \w names|strong="H8034"\w* \w of|strong="H1121"\w* \w the|strong="H5975"\w* \w men|strong="H1121"\w* \w who|strong="H1121"\w* \w are|strong="H1121"\w* \w to|strong="H1121"\w* assist you:  
\b  
\li1 From the tribe of Reuben, Elizur son of Shedeur;   
\b  
\li1
\v 6 from Simeon, Shelumiel son of Zurishaddai;   
\b  
\li1
\v 7 from Judah, Nahshon son of Amminadab;   
\b  
\li1
\v 8 from Issachar, Nethanel son of Zuar;   
\b  
\li1
\v 9 from Zebulun, Eliab son of Helon;   
\b  
\li1
\v 10 from the sons of Joseph:  
\b  
\li2 from Ephraim, Elishama son of Ammihud,  
\b  
\li2 and from Manasseh, Gamaliel son of Pedahzur;   
\b  
\li1
\v 11 from Benjamin, Abidan son of Gideoni;   
\b  
\li1
\v 12 from Dan, Ahiezer son of Ammishaddai;   
\b  
\li1
\v 13 from Asher, Pagiel son of Ocran;   
\b  
\li1
\v 14 from Gad, Eliasaph son of Deuel;   
\b  
\li1
\v 15 and from Naphtali, Ahira son of Enan.”   
\b  
\m
\v 16 \w These|strong="H1992"\w* \w men|strong="H7218"\w* \w were|strong="H3478"\w* appointed \w from|strong="H3478"\w* \w the|strong="H3478"\w* \w congregation|strong="H5712"\w*; \w they|strong="H1992"\w* \w were|strong="H3478"\w* \w the|strong="H3478"\w* \w leaders|strong="H7218"\w* \w of|strong="H4294"\w* \w the|strong="H3478"\w* \w tribes|strong="H4294"\w* \w of|strong="H4294"\w* \w their|strong="H1992"\w* fathers, \w the|strong="H3478"\w* \w heads|strong="H7218"\w* \w of|strong="H4294"\w* \w the|strong="H3478"\w* clans \w of|strong="H4294"\w* \w Israel|strong="H3478"\w*.   
\s1 The Number of Every Tribe  
\b  
\m
