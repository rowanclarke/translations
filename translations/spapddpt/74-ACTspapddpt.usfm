\v 1 Mientras \w ellos|strong="G3588"\w* \w hablaban|strong="G2980"\w* \w al|strong="G3588"\w* \w pueblo|strong="G2992"\w*, \w llegaron|strong="G2186"\w* \add los\add* \w sacerdotes|strong="G2409"\w*, \w el|strong="G3588"\w* jefe \w de|strong="G4314"\w* \w la|strong="G3588"\w* guardia \w del|strong="G3588"\w* \w Templo|strong="G2411"\w* \w y|strong="G2532"\w* \w los|strong="G3588"\w* \w saduceos|strong="G4523"\w*.  
