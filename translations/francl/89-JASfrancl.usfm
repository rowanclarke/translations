\v 25 \w De|strong="G2532"\w* \w même|strong="G2532"\w* \w Rahab|strong="G4460"\w*, \w la|strong="G2532"\w* courtisane, \w ne|strong="G3756"\w* \w fut-elle|strong="G3756"\w* \w pas|strong="G3756"\w* \w justifiée|strong="G1344"\w* \w par|strong="G1537"\w* \w les|strong="G2532"\w* \w œuvres|strong="G2041"\w*, \w quand|strong="G1161"\w* \w elle|strong="G2532"\w* \w reçut|strong="G5264"\w* \w les|strong="G2532"\w* \w envoyés|strong="G2532"\w* \w de|strong="G2532"\w* Josué \w et|strong="G2532"\w* \w les|strong="G2532"\w* \w fit|strong="G2532"\w* \w partir|strong="G1544"\w* \w par|strong="G1537"\w* \w un|strong="G2532"\w* \w autre|strong="G2087"\w* \w chemin|strong="G3598"\w* ?
