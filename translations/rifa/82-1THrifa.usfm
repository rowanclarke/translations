\id 1TH
\h 1 إِثِيسَّالُونِيكِييّنْ 
\toc1 1 إِثِيسَّالُونِيكِييّنْ 
\toc2 1 إِثِيسَّالُونِيكِييّنْ 
\toc3 1 تس. 
\mt1 1 إِثِيسَّالُونِيكِييّنْ  
\c 1
\s1 أَسدْجمْ ذ ؤُسمْغَارْ غَارْ ؤُمزْوَارُو  
\m
\v 1 بُولُوسْ ذ سِيلْوَانُوسْ ذ ثِيمُوثِييُو، إِ ثْمسْمُونْثْ ن إِثِيسَّالُونِيكِييّنْ، \add ثنِّي\add* ذِي أَربِّي، بَابَاثْنغْ، ؤُ ذِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ: أَرْضَا ذ ڒهْنَا أَذْ كِيومْ إِڒِينْ. \x ◘ \xo 1:‏1 \xt رُوم. 1‏:‏7؛ أَفا. 1‏:‏2؛ 1 بُط. 1‏:‏2. \x*   
\b  
\m
\v 2 أَقَا نتّْقَاذَا أَربِّي إِ كنِّيوْ مَارَّا ڒبْذَا، ؤُ نْثِيذَارْ كنِّيوْ بْڒَا قطُّو ذِي ثْژَادْجِيثِينْ نّغْ. \x ◘ \xo 1:‏2 \xt أَفا. 1‏:‏16؛ فِيل. 1‏:‏3؛ كُول. 1‏:‏3؛ 2 تس. 1‏:‏3. \x*  
\v 3 قِيبَاتْشْ إِ \add وُوذمْ ن\add* أَربِّي بَابَاثْنغْ، نتّْفكَّارْ ذِي ڒخْذَايمْ ن لْ-إِيمَانْ نْومْ، ذڭْ ؤُثَامَارْ ن ثَايْرِي نْومْ ؤُ ذِي صّْبَارْ ن ؤُسِيثمْ نْومْ ذِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، \x ◘ \xo 1:‏3 \xt يُوح. 6‏:‏29. \x*  
\v 4 مَاغَارْ نسّنْ أَقَا كنِّيوْ ثتّْوَافَارْزمْ، \add أَ\add* أَيْثْمَا، إِمْعِيزّنْ ن أَربِّي،  
\v 5 مِينْزِي ڒخْبَارْ أَصبْحَانْ نّغْ وَارْ د غَارْومْ يِيوِيضْ س وَاوَاڒنْ وَاهَا، مَاشَا ؤُڒَا س جّهْذْ، س أَرُّوحْ إِقدّْسنْ ؤُ س ڒقْنَاعثْ ذ ثِيذتّْ. أَقَا ثسّْنمْ مَامّشْ ذ أَنغْ ثُوغَا جَارْ أَومْ ذِي طّْوعْ نْومْ. \x ◘ \xo 1:‏5 \xt 1 كُور. 2‏:‏4؛ 4‏:‏20؛ 1 تس. 2‏:‏1. \x*  
\v 6 أَقَا كنِّيوْ ثْذوْڒمْ ذ إِمضْفَارنْ زَّايْنغْ ؤُڒَا زِي سِيذِيثْنغْ، مَاغَارْ ؤُمِي خَاومْ ثكَّا ڒْمحْنثْ ثَامقّْرَانْثْ، ثطّْفمْ ذڭْ وَاوَاڒْ س ڒفْرَاحثْ ن أَرُّوحْ إِقدّْسنْ. \x ◘ \xo 1:‏6 \xt 1 كُور. 4‏:‏16؛ 11‏:‏1؛ فِيل. 3‏:‏17؛ 2 تس. 3‏:‏9. \x*  
\v 7 أَمُّو ثْذوْڒمْ ذ أَمذْيَا إِ قَاعْ يِينِّي يُومْننْ ذِي مَاكِيذُونِييَا ؤُ ذِي أَخَايَا.  
\v 8 مِينْزِي ڒخْبَارْ ن وَاوَاڒْ ن سِيذِيثْنغْ أَقَا إِفّغْ-د زَّايْومْ، وَارْ إِدْجِي ذِي مَاكِيذُونِييَا ذ أَخَايَا وَاهَا، مَاشَا لْ-إِيمَانْ نْومْ ذِي أَربِّي إِذْوڒْ إِتّْوَاسّنْ ثَانْيَا ذِي مَارَّا إِمُوشَانْ، أَڒَامِي نهْڒَا مَا نسِّيوڒْ خَاسْ عَاذْ.  
\v 9 مِينْزِي نِيثْنِي س يِيخفْ نْسنْ عَاوْذنْ أَنغْ، مَامّشْ ثُوغَا ثَارزْممْ أَنغْ ثَاوَّارْثْ، ؤُشَا مَامّشْ د-ثْذوْڒمْ زِي لْ-أَصْنَامْ غَارْ أَربِّي، حِيمَا أَذْ ثْعبْذمْ أَربِّي إِدَّارنْ ونِّي ذ ثِيذتّْ،  
\v 10 أَمْ ثتّْرَاجَامْ مِّيسْ زڭْ إِجنْوَانْ، ونِّي د-إِسّْنكَّارْ زِي ثَادَّارْثْ ن إِمتِّيننْ، يَاسُوع، ونِّي ذ أَنغْ إِ غَا إِسّْنجْمنْ زڭْ وغْضَابْ إِ د غَا يَاسنْ. \x ◘ \xo 1:‏10 \xt ڒخ. 1‏:‏11؛ فِيل. 3‏:‏20؛ 2 تس. 1‏:‏10؛ أَسَا. 1‏:‏7. \x*   
\b  
\b  
\m  
\c 2
\s1 ثَاسخَّارْثْ ن بُولُوسْ ذِي ثِيسَّالُونِيكِي  
\m
\v 1 مَاغَارْ كنِّيوْ سِيمَانْثْ نْومْ، \add أَ\add* أَيْثْمَا، ثسّْنمْ بلِّي أَذَافْ نّغْ نِّي ذ غَارْومْ نڭَّا، وَارْ ثُوغِي إِدْجِي بَاطڒْ. \x ◘ \xo 2:‏1 \xt 1 تس. 1‏:‏5، 9. \x*  
\v 2 ثُوغَا خَانغْ إِكَّا ؤُودّبْ ذ ڒْحَاڭْرَا ذِي فِيلِيبِّي قْبڒْ، أَمْ مَامّشْ ثسّْنمْ. أَوَارْنِي مَانْ أَيَا، أَقَا نْبَارّحْ أَومْ ڒخْبَارْ أَصبْحَانْ ن لْمَاسِيحْ س ثرْيَاسْثْ ذِي أَربِّي نّغْ ؤُ س ؤُمنْغِي أَمقّْرَانْ. \x ◘ \xo 2:‏2 \xt ڒخ. 16‏:‏22؛ 17‏:‏2. \x*  
\v 3 س مِينْزِي أَفوّجْ نّغْ وَارْ إِدْجِي شَا زڭْ ؤُغكّْوِي نِيغْ زِي ڒخْمجْ نِيغْ زِي ڒْغشّْ،  
\v 4 مَاشَا نسَّاوَاڒْ أَمْ \add إِوْذَانْ\add* إِ إِتّْوَاحسْبنْ نِيشَانْ زِي أَربِّي أَڒَامِي ذ أَنغْ إِوكّڒْ \add ثَابَارّحْثْ ن\add* ڒخْبَارْ نّسْ ذ أَصبْحَانْ، وَارْ إِدْجِي إِ أَرْضَا ن إِوْذَانْ، مَاشَا \add إِ أَرْضَا\add* ن أَربِّي ونِّي إِقدْجْبنْ ؤُڒَاونْ نّغْ. \x ◘ \xo 2:‏4 \xt ڭال. 1‏:‏10. \x*  
\v 5 مِينْزِيعمَّارْصْ وَارْ ثُوغِي نتّڭّْ ثِيقدُّوحِينْ، أَقَا كنِّيوْ ثسّْنمْ ت، ؤُ وَارْ نتّڭّْعمَّارْصْ إِجّْ ن ؤُڒحَّافْ خْ طّْمعْ نّغْ، أَربِّي أَقَا-ث ذِينْ! \x ◘ \xo 2:‏5 \xt رُوم. 1‏:‏9؛ 9‏:‏1؛ 2 كُور. 1‏:‏23؛ 11‏:‏31؛ ڭال. 1‏:‏20؛ فِيل. 1‏:‏8؛ 1 تِيم. 5‏:‏21؛ 2 تِيم. 4‏:‏1. \x*  
\v 6 وَارْ نَارزُّو أَعُودْجِي ن إِوْذَانْ، ؤُڒَا زَّايْومْ ؤُڒَا زڭْ إِنّغْنِي، وَاخَّا ثُوغَا نْزمَّارْ أَذْ نڭّْ إِخفْ نّغْ جَارْ أَونْ أَمْ رُّوسُولْ ن لْمَاسِيحْ. \f ◼ \fr 2:‏6 \ft \+bd ’رُّوسُولْ‘\+bd* - نِيغْ ’إِمَازَاننْ‘.\f*  \x ◘ \xo 2:‏6 \xt 1 كُور. 9‏:‏3؛ 2 تس. 3‏:‏9. \x*  
\v 7 مَاشَا ثُوغَا أَنغْ ذ إِحْنِيننْ أَكِيذْومْ، أَمْ يِيشْثْ ن ثبْڒِيغْثْ ثتّْهِيلَّا ذڭْ إِحنْجِيرنْ نّسْ.  
\v 8 أَمُّو عَاوذْ ثُوغَا نتّخْسْ كنِّيوْ ؤُ ثُوغَا ذَايْنغْ مژْرِي مَاحنْذْ أَذْ نْشَارْشْ أَكِيذْومْ، وَارْ إِدْجِي ڒخْبَارْ أَصبْحَانْ ن أَربِّي وَاهَا، أَحقَّا ؤُڒَا ذ ثُوذَارْثْ نّغْ، مِينْزِي ثْذوْڒمْ ذ إِمْعِيزّنْ غَارْنغْ.  
\v 9 عقْڒمْ خنِّي، \add أَ كنِّيوْ\add* أَوْمَاثنْ نّغْ، مَامّشْ ثُوغَا نتَّامَارْ ؤُ نْخدّمْ س إِفَاسّنْ نّغْ دْجِيڒثْ ذ وَاسّْ، حِيمَا وَارْ خَاومْ نتّڭّْ دّْقڒْ. \x ◘ \xo 2:‏9 \xt ڒخ. 18‏:‏3؛ 20‏:‏34؛ 1 كُور. 4‏:‏12؛ 2 كُور. 11‏:‏9؛ 12‏:‏13؛ 2 تس. 3‏:‏8. \x*   
\m
\v 10 كنِّيوْ ذ أَربِّي أَقَا ذ ڒشْهُوذْ خْ مَامّشْ ذ أَومْ ثُوغَا نتّْبَارّحْ س ڒخْبَارْ أَصبْحَانْ ن أَربِّي ذِي ڒصْفَايثْ ذ ثْنِيشَانْثْ \add ن وُوڒْ\add*، ؤُ مَامّشْ ثُوغَا نڭُّورْ بْڒَا ڒْعِيبْ جَارْ مَارَّا إِنِّي يُومْننْ.  
\v 11 أَقَا ثسّْنمْ عَاوذْ مَامّشْ ثُوغَا نْعدْجمْ إِجّْ-إِجّْ زَّايْومْ، أَمْ يِيجّْ ن بَابَاسْ إِ إِحنْجِيرنْ نّسْ، ؤُ \add مَامّشْ\add* نڭَّا ذَايْومْ ؤُڒْ ؤُ نشْهذْ إِ كنِّيوْ،  
\v 12 مَاحنْذْ أَذْ ثُويُورمْ أَمْ مَامّشْ إِسْذَاهدْجْ قِيبَاتْشْ إِ أَربِّي، ونِّي ذ أَومْ د-إِڒَاغَانْ غَارْ ثْڭلْذِيثْ نّسْ ؤُ غَارْ ؤُعُودْجِي نّسْ. \x ◘ \xo 2:‏12 \xt أَمز. 17‏:‏1؛ 1 كُور. 7‏:‏20؛ أَفا. 4‏:‏1؛ فِيل. 1‏:‏27؛ كُول. 1‏:‏10. \x*   
\m
\v 13 س ؤُينِّي نتّْقَاذَا أَربِّي بْڒَا قطُّو، ؤُمِي كنِّيوْ ثْقبْڒمْ أَوَاڒْ ن أَربِّي إِ ثطّْفمْ زَّايْنغْ، وَارْ إِدْجِي أَمْ يِيجّْ ن وَاوَاڒْ ن إِوْذَانْ، مَاشَا أَمْ وَاوَاڒْ ن أَربِّي، ؤُشَا ذ مَانْ أَيَا إِ يدْجَا ذ ثِيذتّْ، ؤُ \add أَوَاڒْ-أَ\add* إِخدّمْ ذَايْومْ س ڒخْذَايمْ ن يِينِّي يُومْننْ.  
\v 14 مِينْزِي كنِّيوْ، \add أَ\add* أَيْثْمَا، ثْذوْڒمْ ذ إِمضْفَارنْ ن ثْمسْمُونِينْ ن أَربِّي إِ إِدْجَانْ ذِي يَاهُوذِييَّا ذِي يَاسُوع لْمَاسِيحْ، مِينْزِي كنِّيوْ ثكْسِيمْ عَاوذْ أَرّْمحْ زڭْ أَيْثْ ن ڒْڭنْسْ نْومْ، أَمْ مَامّشْ كْسِينْ ؤُڒَا ذ نِيثْنِي \add أَرّْمحْ\add* زڭْ وُوذَاينْ، \x ◘ \xo 2:‏14 \xt ڒخ. 17‏:‏5، 13. \x*  
\v 15 إِنِّي إِنْغِينْ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ ؤُڒَا ذ إِنَابِييّنْ إِ زَّايْسنْ \add د-فّْغنْ\add*، ؤُشَا \add عَاوذْ\add* ذَارّْشنْ خَانغْ. أَقَا أَثنْ وَارْ أَرطِّينْ شَا إِ أَربِّي، \add مَاشَا\add* ذوْڒنْ ضِيدّْ ن إِوْذَانْ مَارَّا. \x ◘ \xo 2:‏15 \xt مت. 23‏:‏37؛ لك. 13‏:‏34؛ ڒخ. 7‏:‏52. \x*  
\v 16 مَاغَارْ منْعنْ أَنغْ، مَاحنْذْ أَذْ نسِّيوڒْ غَارْ ڒڭْنُوسْ، حِيمَا \add ڒڭْنُوسْ\add* أَذْ طّْفنْ ثُوذَارْثْ. أَمُّو إِ تّْعمَّارنْ نِيثْنِي \add ڒْْمِيزَانْ ن\add* دّْنُوبْ نْسنْ ڒبْذَا، مَاشَا إِوْضَا-د خَاسنْ وغْضَابْ أَڒْ أَنڭَّارْ. \x ◘ \xo 2:‏16 \xt ڒخ. 17‏:‏13. \x*   
\b  
\m  
\s1 أَمْنُوسْ ن بُولُوسْ ذ ثِيمُوثِييُو  
\m
\v 17 \add أَ كنِّيوْ\add* أَيْثْمَاثْنغْ، غَارْ ذْرُوسْ ن ڒْوقْثْ نذْوڒْ نشِّينْ ذ إِيُوجِيڒنْ نْومْ زِي جِّيهثْ ن ؤُغمْبُوبْ، مَاشَا وَارْ إِدْجِي زِي جِّيهثْ ن وُوڒْ. س ؤُيَا ثُوغَا نَارزُّو س مژْرِي ذ أَمقّْرَانْ أَذْ نْژَارْ أَغمْبُوبْ نْومْ.  
\v 18 ثُوغَا نخْسْ أَذْ غَارْومْ د-نَاسْ، نشّْ بُولُوسْ إِشْثْ ن ثْوَاڒَا ذ إِشْثْ ن ثْوَاڒَا نّغْنِي \add عَاذْ\add*، مَاشَا شِّيطَانْ إِبدّْ أَيِي ذڭْ وبْرِيذْ. \x ◘ \xo 2:‏18 \xt رُوم. 1‏:‏13؛ 15‏:‏22. \x*  
\v 19 مِينْزِي مَانْ ونْ إِ إِدْجَانْ ذ أَسِيثمْ نّغْ، ذ ڒفْرَاحثْ نّغْ نِيغْ ذ تَّاجْ ن ؤُعُودْجِي نّغْ زَّاثْ إِ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ خْمِي د غَا يَاسْ، إِلَّا كنِّيوْ وَاهَا؟ \x ◘ \xo 2:‏19 \xt 2 كُور. 1‏:‏14؛ فِيل. 2‏:‏16؛ 4‏:‏1. \x*  
\v 20 أَقَا كنِّيوْ ذ أَعُودْجِي نّغْ ذ ڒفْرَاحثْ نّغْ.   
\b  
\b  
\m  
\c 3
\s1 ڒخْبَارْ إِسّْفَارّْحنْ زِي ثِيمُوثِييُو  
\m
\v 1 ؤُمِي وَارْ نْزمَّارْ أَذْ ث نصْبَارْ كْثَارْ، ثُوغَا إِتّْغِيڒْ أَنغْ مْلِيحْ مَاحنْذْ أَذْ نقِّيمْ ذِي أَثِينَا وحّذْنغْ،  
\v 2 ؤُشَا نسّكّْ أَومْ-د ؤُمَاثْنغْ ثِيمُوثِييُو. نتَّا ذ أَمْسخَّارْ ن أَربِّي ذ أَمْعَاونْ نّغْ ذِي \add ثْبَارّحْثْ ن\add* ڒخْبَارْ أَصبْحَانْ ن لْمَاسِيحْ، أَڒَامِي إِزمَّارْ أَذْ كنِّيوْ إِسّجْهذْ ؤُ أَذْ إِقدْجبْ لْ-إِيمَانْ نْومْ، \x ◘ \xo 3:‏2 \xt ڒخ. 16‏:‏1؛ رُوم. 16‏:‏21؛ فِيل. 2‏:‏19. \x*  
\v 3 حِيمَا ؤُڒَا ذ إِجّْ زَّايْومْ وَارْ إِقطّعْ ڒَايَاسْ زِي سِّيبّثْ ن ڒمْحَايمْ-أَ. أَقَا كنِّيوْ ثسّْنمْ سِيمَانْثْ نْومْ، بلِّي نتّْوَاڭّْ إِ مَانْ أَيَا. \x ◘ \xo 3:‏3 \xt ڒخ. 14‏:‏22؛ أَفا. 3‏:‏13؛ فِيل. 1‏:‏14؛ 2 تِيم. 3‏:‏12. \x*  
\v 4 مَاغَارْ ڒَامِي ذ أَنغْ ثُوغَا أَكِيذْومْ، نِيزَّارْ ننَّا، بلِّي أَذْ خَانغْ ثكّْ ڒحْصَارثْ، ؤُشَا أَمُّو إِ إِمْسَارْ أَمْ مَامّشْ ثسّْنمْ كنِّيوْ.  
\v 5 س ؤُينِّي، ؤُمِي وَارْ زمَّارغْ أَذْ صْبَارغْ كْثَارْ، أَقَا سّكّغْ ث-إِ-د حِيمَا أَذْ سّْنغْ خْ لْ-إِيمَانْ نْومْ، مَا أَذْ ثَاغْ ونِّي إِتّْجَارَّابنْ أَقَا إِجَارّبْ كنِّيوْ ؤُشَا أَذْ إِفّغْ أَرْبرْ نّغْ ذ وَالُو.   
\m
\v 6 مَاشَا ڒخُّو إِذْوڒْ-د غَارْنغْ زَّايْومْ ثِيمُوثِييُو ؤُشَا إِسِّيوضْ أَنغْ-د ڒخْبَارْ أَصبْحَانْ ن لْ-إِيمَانْ نْومْ ذ ثَايْرِي نْومْ، أَقَا كنِّيوْ ڒبْذَا ثتِّيذَارمْ أَنغْ س ڒْخَارْ زِي مَارَّا إِغزْذِيسنْ ؤُ ذَايْومْ مژْرِي مَاحنْذْ أَذْ أَنغْ ثْژَارمْ، أَمْ ؤُڒَا ذ نشِّينْ \add ذَايْنغْ مژْرِي أَذْ كنِّيوْ نْژَارْ\add*.  
\v 7 س ؤُينِّي نتّْوَافوّجْ زَّايْومْ، \add أَ كنِّيوْ\add* أَوْمَاثنْ نّغْ، ذِي مَارَّا ثَامَارَا نّغْ ذ ڒمْحَايمْ نّغْ، زِي سِّيبّثْ ن لْ-إِيمَانْ نْومْ،  
\v 8 ؤُشَا ڒخُّو نتّْوَانْعشّْ، مَاڒَا كنِّيوْ ثتّْغِيمَامْ ثتّْبدَّامْ \add نِيشَانْ\add* ذِي سِيذِيثْنغْ.  
\v 9 مَامّشْ إِ غَا نڭّْ أَذْ نْقَاذَا أَربِّي زِي سِّيبّثْ نْومْ خْ مَارَّا ڒفْرَاحثْ إِ زِي نْفَارّحْ زَّايْومْ،  
\v 10 مْغِيرْ ؤُمِي نتّتَّارْ دْجِيڒثْ ذ وَاسّْ س وَاطَّاسْ زَّاثْ إِ وُوذمْ ن أَربِّي، حِيمَا أَذْ كنِّيوْ نْژَارْ س ؤُغمْبُوبْ ؤُشَا أَذْ نْكمّڒْ مِينْ إِتّْخصَّانْ عَاذْ إِ لْ-إِيمَانْ نْومْ. \x ◘ \xo 3:‏10 \xt رُوم. 1‏:‏10، 11؛ 15‏:‏23؛ 2 تِيم. 1‏:‏4. \x*   
\m
\v 11 مَاشَا أَربِّي، بَابَاثْنغْ، ذ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، أَذْ إِسڭّمْ أَبْرِيذْ نّغْ غَارْومْ.  
\v 12 نتَّا أَذْ يَارْنِي ذِي ثَايْرِي نْومْ ن إِجّنْ إِ ونّغْنِي ؤُ \add ثَايْرِي نْومْ\add* إِ مَارَّا، أَمْ مَامّشْ نتّخْسْ نشِّينْ ؤُڒَا إِ كنِّيوْ،  
\v 13 ؤُشَا نتَّا أَذْ إِسّْمحّذْ ؤُڒَاونْ نْومْ، حِيمَا أَذْ ثِيڒِيمْ بْڒَا ڒْعِيبْ ذِي ثْقدَّاسْثْ قِيبَاتْشْ إِ أَربِّي بَابَاثْنغْ، خْ مِينِّي د غَا يَاسْ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ أَكْ-ذ مَارَّا إِمْقدَّاسنْ نّسْ. \x ◘ \xo 3:‏13 \xt 1 كُور. 1‏:‏8؛ 1 تس. 5‏:‏23؛ 2 تس. 2‏:‏17. \x*   
\b  
\b  
\m  
\c 4
\s1 دَّارمْ إِ أَرْضَا ن أَربِّي  
\m
\v 1 س ؤُينِّي، \add أَ\add* أَيْثْمَا، أَقَا نتّْزَاوڭْ كنِّيوْ ؤُ نتّْژَادْجْ إِ كنِّيوْ ذِي سِيذِيثْنغْ يَاسُوع، حِيمَا، أَمْ زَّايْنغْ ثْڒمْذمْ مَامّشْ إِتّْخصَّا أَذْ ثُويُورمْ ؤُ أَذْ ثَارْضَامْ إِ أَربِّي، أَذْ ثيْمَامْ ذِي مَانْ أَيَا كْثَارْ، \x ◘ \xo 4:‏1 \xt فِيل. 1‏:‏27؛ 1 تس. 2‏:‏12. \x*  
\v 2 مِينْزِي كنِّيوْ ثسّْنمْ ثِيوصَّا نِّي ذ أَومْ نوْشَا س سِيذِيثْنغْ يَاسُوع.  
\v 3 أَقَا ذ مَانْ أَيَا مِينْ إِخْسْ أَربِّي، أَقَا أَذْ ثيْمَامْ ذِي ثْقدَّاسْثْ، أَذْ ثْحيّْذمْ خْ مَارَّا فَارْقْ-شّْغڒْ، \x ◘ \xo 4:‏3 \xt رُوم. 12‏:‏2؛ أَفا. 5‏:‏27؛ فِيل. 4‏:‏8. \x*  
\v 4 ؤُ مَاحنْذْ كُوڒْ إِجّنْ زَّايْومْ أَذْ إِسّنْ مَامّشْ إِتّْخصَّا أَذْ يَاوِي ثَامْغَارْثْ نّسْ س ثْقدَّاسْثْ ذ شَّانْ،  
\v 5 وَارْ إِدْجِي ذِي شّهْوَاثْ ن نّشْوثْ، أَمْ ڒڭْنُوسْ نِّي وَارْ إِسِّيننْ شَا أَربِّي. \x ◘ \xo 4:‏5 \xt 1 كُور. 15‏:‏34؛ أَفا. 4‏:‏18. \x*  
\v 6 أجّْ ؤُڒَا ذ إِجّْ زَّايْومْ أَذْ إِزْعمْ أَذْ إِسّهْڒشْ ؤُمَاسْ نِيغْ أَذْ ث إِغشّْ ذِي ثْمسْڒَاشْثْ-أَ، مِينْزِي سِيذِيثْنغْ أَذْ إِنقّمْ ذِي مَانْ أَيَا مَارَّا، أَمْ مَامّشْ نِيزَّارْ ننَّا ؤُ نشْهذْ أَومْ.  
\v 7 مِينْزِي أَربِّي وَارْ خَانغْ د-إِڒَاغَا إِ ڒخْمجْ، مَاشَا إِ ثْقدَّاسْثْ. \x ◘ \xo 4:‏7 \xt يُوح. 17‏:‏19؛ 1 كُور. 1‏:‏2. \x*  
\v 8 س ؤُينِّي ونِّي إِ غَا إِسّْذدْجنْ، وَارْ إِسّْذدْجِي شَا بْنَاذمْ، مَاشَا أَربِّي، ونِّي إِوْشِينْ أَرُّوحْ نّسْ إِقدّْسنْ ذَايْومْ. \x ◘ \xo 4:‏8 \xt لك. 10‏:‏16؛ 1 كُور. 7‏:‏40. \x*   
\m
\v 9 نْهْڒَا مَا نُورَا أَومْ-د خْ ثَايْرِي ثنِّي جَارْ وَاوْمَاثنْ، أَقَا كنِّيوْ س يِيخفْ نْومْ تّْوَاسّْڒمْذمْ زِي أَربِّي حِيمَا أَذْ ثخْسمْ أَيَاوْيَا. \x ◘ \xo 4:‏9 \xt لَاوِي 19‏:‏18؛ مت. 22‏:‏39؛ يُوح. 13‏:‏34؛ 15‏:‏12؛ أَفا. 5‏:‏2؛ 1 بُط. 4‏:‏8؛ 1 يُوح. 3‏:‏23؛ 4‏:‏21. \x*  
\v 10 مَاغَارْ أَمُّو إِ ثتّڭّمْ أَكْ-ذ مَارَّا أَوْمَاثنْ ذِي مَاكِيذُونِييَا ثْمُونْ. مَاشَا تَّارغْ زَّايْومْ، \add أَ\add* أَيْثْمَا، حِيمَا أَذْ ثْفيّْضمْ \add ذِي مَانْ أَيَا\add*.  
\v 11 أَرْزُومْ أَذْ ثدَّارمْ ذِي ڒْهُوذْنثْ، أَذْ ثوْشمْ ثَايْنِيثْ إِ مِينْ إِدْجَانْ نْومْ، أَذْ ثْخذْممْ س إِفَاسّنْ نْومْ، أَمْ مَامّشْ كنِّيوْ نُومُورْ، \x ◘ \xo 4:‏11 \xt ڒخ. 20‏:‏34؛ أَفا. 4‏:‏28؛ 2 تس. 3‏:‏7، 12. \x*  
\v 12 حِيمَا أَذْ ثُويُورمْ س ؤُوقَّارْ أَكْ-ذ ينِّي إِدْجَانْ ذِي بَارَّا، ؤُشَا وَارْ ثهْذَاجمْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ زِي شَا ن إِجّنْ.   
\b  
\m  
\s1 أَعْقَابْ ن يَاسُوع لْمَاسِيحْ غَارْ دُّونشْثْ-أَ  
\m
\v 13 \add أَ\add* أَيْثْمَا، أَقَا خْسغْ أَذْ ثسّْنمْ بلِّي وَارْ إِتّْخصِّي أَذْ ثكْسِيمْ س ومْنُوسْ خْ ينِّي إِذوْڒنْ طّْصنْ، أَمْ ث تّڭّنْ إِوْذَانْ إِنّغْنِي إِنِّي ؤُمِي إِقْضعْ ڒَايَاسْ. \x ◘ \xo 4:‏13 \xt لَاوِي 19‏:‏28؛ أَعَوذ. 14‏:‏1؛ 2 صم. 12‏:‏20. \x*  
\v 14 مِينْزِي مَاڒَا نُومنْ بلِّي يَاسُوع ثُوغَا إِمُّوثْ ؤُشَا إِكَّارْ-د، \add خنِّي\add* أَذْ كِيذسْ يِيوِي أَربِّي عَاوذْ إِنِّي إِذوْڒنْ طّْصنْ أَمُّو \add ذڭْ ونْضڒْ\add* ذِي يَاسُوع.   
\m
\v 15 مَاشَا أَذْ أَومْ نِينِي أَيَا س وَاوَاڒْ ن سِيذِيثْنغْ، أَقَا نشِّينْ، إِنِّي إِ غَا إِقِّيمنْ أَڒْ د غَا يَاسْ سِيذِيثْنغْ، إِنِّي \add عَاذْ\add* إِدَّارنْ، وَارْ نتِّيزَّارْ إِ يِينِّي إِذوْڒنْ أَذْ طّْصنْ \add ذڭْ ونْضڒْ\add*. \x ◘ \xo 4:‏15 \xt 1 كُور. 15‏:‏22، 51. \x*  
\v 16 مِينْزِي سِيذِيثْنغْ س إِخفْ نّسْ أَذْ د-إِهْوَا زڭْ ؤُجنَّا، خْمِي د غَا إِفّغْ ڒُومُورْ ذ ثْمِيجَّا ن ؤُزدْجِيفْ ن لْمَالَاكَاثْ، ؤُ خْمِي إِ غَا ثِيڒِي \add ثْمِيجَّا ن ؤُسُوضِي س\add* ؤُيِيشّْ ن أَربِّي، ؤُشَا إِمتَّانْ إِنِّي إِدْجَانْ ذِي لْمَاسِيحْ أَذْ د-كَّارنْ ذ إِمزْوُورَا. \x ◘ \xo 4:‏16 \xt مت. 24‏:‏31؛ 1 كُور. 15‏:‏52؛ 2 كُور. 4‏:‏14؛ 2 تس. 1‏:‏7. \x*  
\v 17 خَاسْ ؤُشَا نشِّينْ، إِنِّي إِقِّيمنْ ؤُ \add عَاذْ\add* دَّارنْ، أَذْ كِيذْسنْ نتّْوَاكّسْ ذڭْ إِسيْنُوثنْ غَارْ ؤُمڒْقِي أَكْ-ذ سِيذِيثْنغْ ذڭْ ؤُجنَّا ؤُشَا أَمُّو إِ غَا نِيڒِي ڒبْذَا أَكْ-ذ سِيذِيثْنغْ. \x ◘ \xo 4:‏17 \xt 2 كُور. 4‏:‏14\x*  
\v 18 س ؤُيَا ڭّمْ ؤُڒْ ذڭْ وَايَاوْيَا س وَاوَاڒنْ-أَ.   
\b  
\b  
\m  
\c 5
\s1 أَحطُّو  
\m
\v 1 مَاشَا زِي جِّيهثْ ن زّْمَانَاثْ ذ ثْسَاعّثِينْ، \add أَ\add* أَيْثْمَا، أَقَا نْهْڒَا مَا أَذْ أَومْ د-أَرِيغْ.  
\v 2 كنِّيوْ سِيمَانْثْ نْومْ ثسّْنمْ نِيشَانْ أَقَا أَسّْ ن سِيذِيثْنغْ أَذْ د-يَاسْ أَمْ ؤُشفَّارْ ذِي دْجِيڒثْ. \x ◘ \xo 5:‏2 \xt مت. 24‏:‏43؛ 2 بُط. 3‏:‏10؛ أَسَا. 3‏:‏3؛ 16‏:‏15. \x*  
\v 3 خْمِي غَا إِنِينْ نِيثْنِي: ’أَقَا ڒهْنَا ذ ڒْهُوذْنثْ!‘، ڒخْذنِّي أَذْ خَاسنْ إِكّْ وَاريّبْ ذغْيَا، أَمْ تّكّنْ ڒوْجعْ \add ن ثَارُوثْ\add* خْ ثمْغَارْثْ ثنِّي س دّيْسثْ، ؤُشَا وَارْ ذِينْ مَانِي غَا يَاروْڒنْ. \x ◘ \xo 5:‏3 \xt 2 تس. 1‏:‏9. \x*  
\v 4 مَاشَا كنِّيوْ، \add أَ\add* أَيْثْمَا، وَارْ ثدْجِيمْ شَا ذِي ثَادْجسْثْ مَاحنْذْ أَذْ خَاومْ-د إِوْضَا وَاسّْ نِّي أَمْ ؤُشفَّارْ، \x ◘ \xo 5:‏4 \xt أَفا. 5‏:‏8. \x*  
\v 5 \add مَاغَارْ\add* كنِّيوْ مَارَّا ذ ثَارْوَا ن ثْفَاوْثْ ذ ثَارْوَا ن وَاسّْ، وَارْ ثدْجِيمْ شَا ن دْجِيڒثْ نِيغْ ن ثَادْجسْثْ. \x ◘ \xo 5:‏5 \xt لك. 16‏:‏8؛ رُوم. 13‏:‏12؛ أَفا. 5‏:‏8. \x*  
\v 6 س ؤُينِّي إِتّْخصَّا أَنغْ وَارْ نتّطّصْ أَمْ ونّغْنِي، مَاشَا أَذْ نِيڒِي نْفَاقْ، نحْضَا، \x ◘ \xo 5:‏6 \xt لك. 21‏:‏36؛ رُوم. 13‏:‏11، 13؛ 1 كُور. 15‏:‏34؛ أَفا. 5‏:‏14. \x*  
\v 7 مِينْزِي إِنِّي إِتّطّْصنْ، أَقَا تّطّْصنْ ذِي دْجِيڒثْ، ؤُ إِنِّي إِتّْغلَّانْ، أَقَا تّْغلَّانْ س دْجِيڒثْ،  
\v 8 مَاشَا أجّْ أَنغْ، نشِّينْ إِ يدْجَانْ ذ إِحنْجِيرنْ ن وَاسّْ، أَذْ نِيڒِي نحْضَا ذڭْ إِخَارِيصّنْ نّغْ، أَذْ نْحزّمْ إِذْمَارنْ نّغْ س وَارُّوضْ ن وُوزَّاڒْ ن لْ-إِيمَانْ ذ ثَايْرِي، ؤُ أَذْ نسَّارْسْ لْكَاسْكْ ن ؤُسِيثمْ ن ثُوذَارْثْ \add خْ ؤُزدْجِيفْ\add*. \x ◘ \xo 5:‏8 \xt إِشا. 59‏:‏17؛ أَفا. 6‏:‏14. \x*  
\v 9 مِينْزِي أَربِّي وَارْ ذ أَنغْ يڭِّي إِ وغْضَابْ، مَاشَا حِيمَا أَذْ نطّفْ ثُوذَارْثْ ذِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ،  
\v 10 ونِّي خَانغْ إِمُّوثنْ، حِيمَا نشِّينْ، مَا نْفَاقْ نِيغْ نطّصْ، أَذْ كِيذسْ ندَّارْ. \x ◘ \xo 5:‏10 \xt رُوم. 14‏:‏7؛ 2 كُور. 5‏:‏15؛ ڭال. 2‏:‏20؛ 1 بُط. 4‏:‏2. \x*  
\v 11 س ؤُينِّي ڭّمْ ؤُڒْ ذڭْ وَايَاوْيَا، بْنَامْ إِجّنْ ونّغْنِي أَمْ ث ثڭِّيمْ عَاوذْ.   
\b  
\m  
\s1 أَوَاڒْ غَارْ ؤُنڭَّارُو ذ ؤُسدْجمْ  
\m
\v 12 مَاشَا نتَّارْ زَّايْومْ، \add أَ\add* أَيْثْمَا، أَذْ ثسّْنمْ إِنِّي إِتّڭّنْ ثِيزمَّارْ أَطَّاسْ جَارْ أَومْ ذ إِنِّي خَاومْ إِدْجَانْ ذِي سِيذِيثْنغْ ذ إِنِّي كنِّيوْ إِسّڒْمَاذنْ، \x ◘ \xo 5:‏12 \xt رُوم. 15‏:‏27؛ 1 كُور. 9‏:‏11؛ 16‏:‏18؛ ڭال. 6‏:‏6؛ فِيل. 2‏:‏29؛ 1 تِيم. 5‏:‏17؛ عبر. 13‏:‏7، 17. \x*  
\v 13 مَاحنْذْ أَذْ تّْوقَّارنْ زَّايْومْ ؤُمِي ذ أَسنْ ثتّمّْڒمْ ثَايْرِي س ؤُفيّضْ ؤُشَا أَذْ ثحْضَامْ ڒهْنَا أَكِيذْسنْ زِي سِّيبّثْ ن ڒْخذْمثْ نْسنْ.   
\m
\v 14 نعْڒمْ أَومْ، \add أَ\add* أَيْثْمَا، أَذْ ثْسڭّْممْ إِنِّي د-إِفّْغنْ زڭْ وبْرِيذْ، ڭّمْ ؤُڒْ ذڭْ إِنِّي وَارْ غَارْسنْ ثدْجِي ثرْيَاسْثْ، أَرْبُومْ دّْقڒْ ن يِينِّي إِضعْفنْ، إِڒِيمْ ذ إِصبَّارنْ أَكْ-ذ مَارَّا.  
\v 15 حْضَامْ مَاحنْذْ ؤُڒَا ذ إِجّْ وَارْ إِتّنْثِيقِيمْ ڒْغَارْ س ڒْغَارْ، مَاشَا أَرْزُومْ ڒبْذَا مِينْ إِصبْحنْ أَكْ-ذ وَايَاوْيَا ؤُشَا إِ كُوڒْشِي. \x ◘ \xo 5:‏15 \xt لَاوِي 19‏:‏18؛ أَوڒن. 20‏:‏22؛ 24‏:‏29؛ مت. 5‏:‏39؛ رُوم. 12‏:‏17؛ 1 كُور. 6‏:‏7؛ 1 بُط. 3‏:‏9. \x*   
\m
\v 16 فَارْحمْ ڒبْذَا، \x ◘ \xo 5:‏16 \xt مت. 5‏:‏12؛ لك. 10‏:‏20؛ رُوم. 12‏:‏12؛ فِيل. 4‏:‏4. \x*  
\v 17 ژَّادْجمْ بْڒَا قطُّو، \x ◘ \xo 5:‏17 \xt لك. 18‏:‏1؛ رُوم. 12‏:‏12؛ كُول. 4‏:‏2. \x*  
\v 18 قَاذمْ ذِي مَارَّا ثِيمسْڒَايِينْ، مِينْزِي ذ مَانْ أَيَا مِينْ إِخْسْ أَربِّي ذِي يَاسُوع لْمَاسِيحْ إِ كنِّيوْ. \x ◘ \xo 5:‏18 \xt أَفا. 5‏:‏20. \x*   
\m
\v 19 وَارْ سّْخسّْيمْ شَا أَرُّوحْ، \x ◘ \xo 5:‏19 \xt 1 كُور. 14‏:‏30. \x*  
\v 20 وَارْ سّحْقَارَامْ أَوَاڒنْ ن نُّوبُووَاثْ،  
\v 21 وزْنمْ قَاعْ مِينْ إِدْجَانْ ؤُشَا طّْفمْ غَارْ مِينْ إِصبْحنْ. \x ◘ \xo 5:‏21 \xt 1 يُوح. 4‏:‏1. \x*   
\m
\v 22 أَڭّْوجمْ خْ مَارَّا مِينْ إِدْجَانْ دَّابْ ن ثُوعفّْنَا. \x ◘ \xo 5:‏22 \xt فِيل. 4‏:‏8. \x*  
\v 23 إِڒِي أَذْ كنِّيوْ إِسّْقدّسْ أَربِّي ن ڒهْنَا مَارَّا ؤُشَا أَذْ إِحْضَا مَارَّا أَرُّوحْ ذ ڒعْمَارْ ذ أَرِّيمثْ نْومْ بْڒَا ڒْعِيبْ أَڒْ ثَاوَاسِيثْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 5:‏23 \xt 1 كُور. 1‏:‏8؛ فِيل. 4‏:‏9؛ 1 تس. 3‏:‏13. \x*  
\v 24 أَقَا ذ ونِّي خَاومْ د-إِتّْڒَاغَانْ ذ أَمْثِيقِّي، أَقَا نتَّا أَذْ ث إِڭّْ. \x ◘ \xo 5:‏24 \xt 1 كُور. 1‏:‏9؛ 10‏:‏13؛ 2 كُور. 1‏:‏18؛ 2 تس. 3‏:‏3. \x*   
\m
\v 25 \add أَ\add* أَيْثْمَا، كْسِيمْ أَنغْ ڒْمعْرُوفْ عَاوذْ.   
\m
\v 26 سدْجْممْ خْ وَاوْمَاثنْ نّغْ س ؤُسُوذمْ إِقدّْسنْ. \x ◘ \xo 5:‏26 \xt رُوم. 16‏:‏16؛ 1 كُور. 16‏:‏20؛ 2 كُور. 13‏:‏12؛ 1 بُط. 5‏:‏14. \x*   
\m
\v 27 نشّْ سّْجُودْجغْ كنِّيوْ ذڭْ وُوذمْ ن سِيذِيثْنغْ مَاحنْذْ أَذْ ثْغَارمْ ثَابْرَاثْ-أَ إِ مَارَّا أَوْمَاثنْ إِمْقدَّاسنْ.   
\m
\v 28 أَرْضَا ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ أَذْ كِيومْ يِيڒِي.   