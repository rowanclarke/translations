\id LAM - Guji Bible
\h Gadda Ermiyaasii
\toc1 Kitaaba Gadda Ermiyaasii
\toc2 Kitaaba Gadda Ermiyaasii
\toc3 Gad.
\mt1 Kitaaba Gadda Ermiyaasii
\imt1 Seensa
\ip Kitaab gadda Ermiyaasii kun dhaloota Kiristoosiitiin dura woggaa dhibba shanii fi saddeettamii jaatti Yerusaalem waan diigantee fi kolbaan isi'iille waan baqatteef wolaloo gaddaa shanan ka wolitti qabatee dhiyaate. Kutaan kitaaba kanaa irra caalaa marroo bowaatii fi gaddaa odeessulle, waan Waaqatti addatiisaa fi addii qabaatiisaa kutaan dubbatulle jira. Wolaloota kana Yihudooti dhaloota Kiristoosiitiin dura woggaa dhibba shanii fi saddeettamii jaatti, badii Yerusaalem irra dhaqqadde qaabbi'iif woggaa wogga'aan guyyoota waaqonfannaa laamaatii fi gadda irratti itti fayyadaman.
\iot Haadhoo dubbi'ii
\io1 Gadda Yerusaalemii\ior 1:1-22\ior*
\io1 Adabamiisa Yerusaalemii\ior 2:1-22\ior*
\io1 Adabamiisaa fi addii\ior 3:1-66\ior*
\io1 Diigama Yerusaalemii\ior 4:1-22\ior*
\io1 Daadimata mararti'ii\ior 5:1-22\ior*
\c 1
\s1 Gadda Yerusaalemii
\q1 
\v 1 Yerusaalemiin dur kolbaan keessa guutte attam qofi hatte!
\q2 Ka gosa biyya adda addaa oddu'utti guddoo teete,
\q2 attam akka haadha hiyyeessaa teete.
\q2 Qachoota oddu'utti giittii ta teete,
\q2 attam akka garbaa teete.
\q1 
\v 2 Halkan guutuu hin bootti,
\q2 imimmaan boqoo isi'ii irra yaati.
\q2 Jaalota isi'ii keessaa
\q2 ka isii jajjabeessu tokkolle hin jiru.
\q2 Jaaloti isi'ii marti isii mormataneeran;
\q2 diinalle itti te'aneeran.
\q1 
\v 3 Kolbaan Yihuda'aa
\q2 garbumma'aa fi eloo jaddu'uun rakkattee,
\q2 biyya ifii irraa ari'antee,
\q2 addee «Teenna» hin jenne,
\q2 lafa dhibii keessa leete.
\q1 Karaan milixxu ka hin jirre,
\q2 diinaan marfante.
\q1 
\v 4 Nami jilaaf gara Xiyoonii dhufu,
\q2 waan hin jirreef,
\q2 karaan karra isi'ii martinuu duwwaa te'e;
\q2 Hayyootille gaddaan aadan.
\q2 Durrooti isi'ii hin gadditi.
\q2 Xiyoon gadda keessa jirti.
\q1 
\v 5 Diinoti isi'ii isii irratti goottomanee,
\q2 badhaadhaneeran.
\q1 Bacinna cubbuu isi'iitiif,
\q2 Waaqi isii rakkise;
\q1 Ijoolleen isi'ii diinaan booji'antee,
\q2 fudhatanteerti.
\b
\q1 
\v 6 Ulfinni Yerusaalemii marti
\q2 irraa deemeera.
\q1 Sooreyyiin isi'iille
\q2 akka gadansa beelowee dadhabee,
\q2 worra isa ari'u duraa hin baqannee te'aneeran.
\b
\q1 
\v 7 Yerusaalem rakkatee mana dhaddee
\q2 waan dansaa ifii durii qaabatte.
\q1 Kolbaan isi'ii ammoo diinaan waan injifatanteef,
\q2 nami isii qarqaarulle hin jiru.
\q2 Diinoti isi'iille diigama isi'iititti kollane.
\b
\q1 
\v 8 Yerusaalem cubbuu guddoo hujjee
\q2 xomorootteerti;
\q2 isaan waan duwwaa isii dhagganeef,
\q2 worri isii ulfeessanu marti tuffataneeran;
\q2 isiinuu aadiisaan,
\q2 fokko'oon fuula ifii achi garagalti.
\b
\q1 
\v 9 Xomorummaan isi'ii woyaa isi'ii irratti mudhatti;
\q2 isiin waan hegeri teetu hin beenne;
\q2 jinnanni isi'ii sodaachisa'a;
\q2 ka isii jajjabeessu tokkolle hin jiru.
\q2 Diinoti isi'ii waan isii injifataneef,
\q2 rakkoo isi'ii akka ilaaluuf gara Waaqaa iyyite.
\b
\q1 
\v 10 Diinoti Yerusaalemii
\q2 qabeenna isi'ii dadansaa saamane.
\q1 Isiin Galma Waaqaa ka ifii,
\q2 ka Waaqi worri Yihudoota hin te'in
\q2 akka hin seenne dhoogge seenanuun dhaggite.
\b
\q1 
\v 11 Kolbaan isi'ii marti sagale'eef aaddi;
\q2 lubbu'uun jiraatiisaaf
\q2 qabeenna dadansaa ifii sagale'een jijjiiratti.
\q1 Yerusaalem «Waaqa! Na ilaali;
\q2 salphinna kiyya duudiille dhaggi!
\b
\q1 
\v 12 «Isin worri karaa tartanu,
\q2 isiniif womaayyuu te'uu dhaddulle,
\q2 ka Waaqi guyyaa mufii jaddu'uu natti fide,
\q2 rakkinna kiyya kana ka fakkaatu jiraa ree?
\q2 Me ilaala'aatii, dhagga'a!
\b
\q1 
\v 13 «Waaqi ol-gubbaa irraa ibidda erge;
\q2 ibiddille lafee tiyya keessa gube.
\q2 Inni tiyyoo miila kiyyatti afee,
\q2 duubatti na deebise.
\q2 Inni qofi na lakkisee,
\q2 guyyaa guutuu na gaggasse.
\b
\q1 
\v 14 «Inni waanjoo cubbuu tiyyaa wolitti hidhee,
\q2 morma kiyya irra keyeera.
\q1 Isiin guddoo waan ulfaattuuf
\q2 hunna na dhooggite.
\q1 Waaqi diinota ani dande'ee ifi irraa hin dhooggannetti
\q2 dabarsee na kenne.
\b
\q1 
\v 15 «Waaqi loltoota jajjaboo ani qabu dhidhiiteera;
\q2 inni dargaggoota tiyya balleessiisaaf loltoota erge;
\q2 kolbaa tiyya akka midhaan woyni'ii cunfe.
\b
\q1 
\v 16 «Wonni ani imimmaan tiyya
\q2 dhangalaasee bowuuf tana:
\q2 ka na jajjabeessu waan na irraa fagaateef,
\q2 ka na jabeessu hin jiru;
\q2 Diinni waan injifateef,
\q2 ijoolleen tiyya qofi hatteerti» jetti.
\b
\q1 
\v 17 Xiyoon harka ifii badhitteerti;
\q2 ka isii jajjabeessu ammoo hin jiru.
\q2 Ollooti isi'ii duudiin sanyii Yaaqoobiititti
\q2 diinota akka itti te'anu Waaqi ajajeera.
\q2 Yerusaalem odduu isaaniititti xomorootteerti.
\b
\q1 
\v 18 Yerusaalem, «Anattuu ajaja isaa dide malee,
\q2 Waaqi sirrii godhe.
\q2 Isin kolbaan marti dhage'a'a; rakkoo tiyyaalle ilaala'a;
\q2 dargaggooti tiyya dhiiraa fi dubartiin marti booji'amaneeran.
\b
\q1 
\v 19 «Ani jaalota tiyya mara waammadhe;
\q2 isaan ammoo na qarqaaruu didatane.
\q2 Hayyootaa fi sooreyyiin tiyya
\q2 lubbuu ifii jiraachisiisaaf, sagalee adoo barbaadatanuu
\q2 karaa qacha'aa keessatti du'ane.
\b
\q1 
\v 20 «Waaqa kiyya, attam akka rakkadhee,
\q2 keessi kiyya laalatee,
\q2 gadhaan kiyya raafame ilaali;
\q2 kolbaa tiyya alatti shallaagaan,
\q2 mana keessatti duuti fixiisatti jirti.
\b
\q1 
\v 21 «Kolbaan aadiisa kiyya dhageetteerti;
\q2 ammoo eennulle na hin jajjabeessine.
\q2 Diinoti kiyya marti rakkoo tiyya dhage'anee,
\q2 waan ati na irratti gootetti gammadaneeran.
\q2 Guyyaa jette san fidiitii,
\q2 isaanille akka kiyya te'anuu ti.
\b
\q1 
\v 22 «Hammeenni isaanii marti si duratti mudhatuu ti;
\q2 akkuma cubbuu tiyyaaf na adadde isaanille adabi.
\q2 Ani guddoo waan aadeef,
\q2 gaggabeera» jetti.
\c 2
\s1 Adabamiisa Yerusaalemii
\q1 
\v 1 Attam attam Waaqi mufii ifiitiin
\q2 Xiyoonitti duumensa uffise!
\q1 Guddinna isi'iille ol-gubbaa irraa
\q2 gad lafatti darbe.
\q1 Xiyoon ijjata miila isaa akka teete,
\q2 guyyaa mufii ifii isii hin qaabanne.
\q1 
\v 2 Waaqi bultoo Israa'elii mara
\q2 marartii malee balleesse.
\q1 Kushee Yihuda'aa mufii ifiitiin diigee balleessee,
\q2 Mootumma'aa fi bulchitoota isi'ii
\q2 gad lafatti gatee salphise.
\q1 
\v 3 Mufii ifii jaddu'uun,
\q2 hunna Israa'elii mara dhoogge.
\q1 Diinni yennaa isaanitti dhufelle,
\q2 gargaaruu didate.
\q1 Akkuma bobeenni ibiddaa,
\q2 waan adaala isaa jiru mara gubu,
\q2 Waaqi Israa'el gube.
\b
\q1 
\v 4 Inni akka diinaa daaya ifii itti qajeelfate;
\q2 harka middicha ifiille qopheeffate.
\q1 Worra ila namaatitti tolu duudii,
\q2 akka diinaa ijjeese.
\q1 Dunkaanii kolbaa Xiyoonii irratti mufii ifii,
\q2 akka ibiddaa isaan irratti gabbise.
\b
\q1 
\v 5 Waaqi akka diinaatitti,
\q2 Israa'el balleesse;
\q2 inni kushee isi'ii maraa fi
\q2 mana mootummaa isi'ii mara balleesse.
\q1 Kolbaa Yihuda'aa irratti
\q2 bowichaa fi gadda bira dabarse.
\b
\q1 
\v 6 Galma ifii akka gosee fichaa keessaa
\q2 diigee balleesse;
\q1 Waaqi jilaa fi Sanbati Xiyoon keessatti
\q2 akka dedhamanu godhe.
\q1 Inni mufii ifii jaddu'uun
\q2 mootichaa fi hayyicha salphise.
\b
\q1 
\v 7 Waaqi addee ciincaa ifii didee,
\q2 Galma ifiille lakkise.
\q1 Dalleya mana mootummaa isi'ii
\q2 harka diinaatitti dabarsee kenne;
\q2 akkuma guyyaa jilaatitti godhamu,
\q2 Galma Waaqa keessatti diinni qeexale.
\b
\q1 
\v 8 Waaqi dalleya qachaa Xiyoonii diigiisaaf murteessee
\q2 wodaroo miki'ii\f + \fr 2:8 \fqa Wodaroo miki'ii: \ft Ta dheerinnaa fi badhinna woyii haga ittiin ilaalanu.\f* buuseera.
\q1 Inni balleessiisaaf
\q2 harka ifii irraa hin deebifanne.
\q1 Xelleepho'oo fi dalleya isi'ii
\q2 wolumatti diigeera.
\b
\q1 
\v 9 Balbalti karra isi'ii marti awwaalante,
\q2 danqaraan isi'iille caccabee bade.
\q1 Mootichii fi qondaaltoti isi'ii ari'amanee
\q2 gosa biyya dhibi'ii odduu jiran;
\q1 Haganaa achi seerri hin jiraatu;
\q2 raagoti isi'iille Waaqa irraa
\q2 mudhii hin dhagganu.
\b
\q1 
\v 10 Jaarsoleen qachaa Xiyoonii
\q2 mataa ifiititti bukuu\f + \fr 2:10 \fqa Bukuu: \ft Yookiin awwaar.\f* firfirfatanee,
\q2 woyaa gaddaa uffatanee,
\q2 cadhi jedhanee lafa tee'ane.
\q1 Durri qachaa Xiyoonii
\q2 gaddaan lafa ilaalti.
\b
\q1 
\v 11 Kolbaan tiyya waan fixanteef,
\q2 ijoolle'ee fi annoolleen
\q2 karaa qacha'aa irratti waan gaggabaneef
\q2 bowiisaan ilti na jaamaarti.
\q1 Keessi kiyya na laalatee,
\q2 addii kutadhe.
\b
\q1 
\v 12 Ijoolleen akka loltoota madoottee,
\q2 karaa qacha'aa irratti gaggabanee,
\q2 «Sagale'ee fi bisaan» meet jedhaa,
\q2 harka haadha isaanii irratti du'an.
\b
\q1 
\v 13 Ee Yerusaalem, maan siin jedha?
\q2 Maani'iin wol si qixxeessa?
\q1 Xiyoonii tiyya, akka si jajjabeessuuf,
\q2 maaniin wol si fakkeessa?
\q1 Badiin si irra dhaqqadde akka abbaaya'aa badho'o;
\q2 eentu si fayyisuu dande'a?
\b
\q1 
\v 14 Raagoleen teeti
\q2 mudhii dharaa ta bu'aa hin qanne si'iif dhaggite.
\q1 Mudhii dharaatii fi dokonkora si'iif dhaggite malee,
\q2 yakkaa teeti si'itti ifa baasanee
\q2 badii si'itti dhufaartu si'i irraa hin oolchine.
\b
\q1 
\v 15 Worri karaa dabaru marti
\q2 cooraa harka sitti dhowaa, mataa ifii raasaa,
\q2 «Yerusaalemiin tun ta shaggummaa guutuu qadduu fi
\q2 qachaa biyyi lafaa duudiin itti gammaddee motii?» jedhan.
\b
\q1 
\v 16 Diinoti keeti marti afaan bananee si'itti cooran.
\q2 Ilkaan ciniinnatanee, «Yerusaalem balleessine.
\q1 Guyyaan nuuti eeggataa turre kana;
\q2 amma bira geennee dhaggine» jedhan.
\b
\q1 
\v 17 Waaqi waan yaade muummesse;
\q2 jecha ifiille guute.
\q1 Akkuma dur murteesse marartii malee si balleessee,
\q2 hunna diinota keetii jabeessee,
\q2 jinnana keetitti akka gammadanu godhe.
\b
\q1 
\v 18 Kolbaa qachaa Xiyoonii,
\q2 gara Waaqaa iyya'a!
\q1 Dalleya qachaa Xiyoonii,
\q2 imimmaan teeti halkanii fi guyyaa
\q2 akka lagaa yaatuu ti;
\q2 hin cadhisin;
\q2 boyiisalle hin lakkisin.
\b
\q1 
\v 19 Halkan guutuu yennaa yenna'atti ka'ii iyyi!
\q2 Waan gadhaa keeti keessa jiru,
\q2 Waaqa duratti dhikeessi.
\q1 Lubbuu ijoollee teetii,
\q2 ta qaxxaamura karaa irratti
\q2 beelaan gaggabaneef,
\q2 daadimanna'aan harka keeti gara Waaqaa ol kaasi.
\b
\q1 
\v 20 Yerusaalem, «Ee, Waaqa, kunoo ilaali!
\q2 Kolbaan ati akkana gooteertu jirtii?
\q2 Dubartooti annoolee ifii deyane nyaatanuu tii?
\q1 Hayyootii fi raagoti
\q2 Galma Waaqaa keessatti ijjeefamanuu tii?
\b
\q1 
\v 21 «Dargaggootii fi maanguddooti,
\q2 karaa irratti jiganee du'aneeran.
\q1 Dargaggooti dhiiraatii fi dubarti'ii
\q2 shallaaga'aan ijjeefamaneeran.
\q1 Guyyaa mufii teetii
\q2 marartii malee isaan qalte.
\b
\q1 
\v 22 «Akka guyyaa jilaa,
\q2 diinota kiyya adaala mara irraa waanteerta.
\q1 Guyyaa mufii Waaqaa,
\q2 ka miliqe yookiin jiru'uun ka hafe hin jiru.
\q1 Ijoollee ani uumadhee guddifadhe
\q2 diinni kiyya na jalaa fixe» jedhi.
\c 3
\s1 Adabama, Cubbuu Irraa Deebi'iisaa Fi Addii
\q1 
\v 1 Ani nama ulee mufii Waaqaatiin,
\q2 adabamee rakkinna dhagge.
\q1 
\v 2 Inni addee ifi hin jirre,
\q2 dukkanatti na ari'e.
\q1 
\v 3 Inni dhugumaan guyyaa mara deddeebi'ee,
\q2 harka ifiitiin na adabe.
\b
\q1 
\v 4 Inni foonii fi gogaa kiyya dulloonsee,
\q2 lafee tiyyalle caccasse.
\q1 
\v 5 Inni na marsee,
\q2 rakkinna hadhowa'aa fi laaleffata keessa na galche.
\q1 
\v 6 Inni akka worra dur du'ee awwaalamee,
\q2 dukkana keessa akka le'u na tolche.
\b
\q1 
\v 7 Akka ani hin baaneef,
\q2 dalleya marsee natti ijaaree,
\q2 wodaroo sibiilaa ulfaattu'uun na hidhe.
\q1 
\v 8 Qarqaarsaaf itti iyyadhulle,
\q2 na caqasuu dide.
\q1 
\v 9 Karaa kiyya dhaka'aan duuchee,
\q2 daandii tiyyalle daddasse.
\b
\q1 
\v 10 Inni akka doobbaa\f + \fr 3:10 \fqa Doobbaa: \fqa Bineensa hamaa iyyaa fakkaatu tokko. \f* ciisee na gaaduutii fi
\q2 akka neenqa dhokaata jiruu ti.
\q1 
\v 11 Inni karaa irraa na harkisee, kukkutee,
\q2 qarqaarsa malee na lakkise.
\q1 
\v 12 Guubee ifii dhisee,
\q2 itti qajeelfata daaya ifii na godhe.
\b
\q1 
\v 13 Inni daaya subba ifii keessaa luqqisee,
\q2 kalattii tiyya woraane.
\q1 
\v 14 Kolbaan tiyya marti natti kollitee,
\q2 guyyaa guutuu weeddu'uun natti murgite.
\q1 
\v 15 Inni rakkinnaan jiruu tiyya hadheessee,
\q2 waan akka hargiisaa na quusse.
\q1 
\v 16 Inni cabbi'iin ilkaan kiyya caccassee,
\q2 bukuu keessatti na gangalche.
\q1 
\v 17 Ani nageya dhabee,
\q2 gammadi maan akka te'e dedhe.
\q1 
\v 18 Tanaaf ani «Jabeenni kiyya,
\q2 addiin ani Waaqa irraa eegadhu marti baddeerti» jedhe.
\b
\q1 
\v 19 Rakko'oo fi daaqa kiyya qaabatiis,
\q2 akka qararu'uutii fi hadhoottu'uu natti teeteerti.
\q2 
\v 20 Ani yennaa tana qaabadhu mara,
\q2 mataa buusa.
\q1 
\v 21 Teetulle yennaa waan tokko qaabadhu,
\q2 addii qaba:
\b
\q1 
\v 22 Jaalalli Waaqaa ka bara baraa waan te'eef,
\q2 marartii isaa ta dhuma hin qanne irraa ta kaate
\q2 nuuti badiisa dhanne.
\q2 
\v 23 Jaalallii fi marartiin isaa barii mara haareya;
\q2 addatamummaan isaa guddo'o.
\q1 
\v 24 Ani ifiin, «Waaqi qooda kiyya;
\q2 tanaaf isatti addadha» jedhe.
\b
\q1 
\v 25 Waaqi worra addi'iin isa eegatuuf,
\q2 worra isa barbaaduuf dansa'a.
\q1 
\v 26 Tanaaf nami cadhisee
\q2 fayyisiisa Waaqaa eegatiis dansa'a.
\q2 
\v 27 Nami bara dargaggumma'aatitti
\q2 waanjoo ba'atiisa barachuun dansa'a.
\b
\q1 
\v 28 Yennaa Waaqi waanjoo isa ba'achiise,
\q2 qofii ifii cadhisee tee'uu ti.
\q1 
\v 29 Ammalle addiin jiraatuu waan dandeettuuf,
\q2 ifi gad qabuu ti.
\q1 
\v 30 Nama isa kabaluuf boqoo ifii kennuu ti;
\q2 arraballe fudhatuu ti.
\b
\q1 
\v 31 Waaqi haga bara baraa isa hin gatu.
\q2 
\v 32 Inni nama gaddisiisulle,
\q2 akka jaalala ifii ka bara baraa gudda'aatitti marartii qaba.
\q1 
\v 33 Inni nama rakkisu'uu fi gaddisiisu'utti hin gammadu.
\b
\q1 
\v 34 Hidhantooti biyya tokkoo
\q2 yennaa dhiitamanu,
\q1 
\v 35 Waaqa Ol-Aanaa duratti
\q2 mirgi ilmaan namaa yennaa dhooggamu,
\q1 
\v 36 Haajaan nama tokkoo haqa yennaa dhabu,
\q2 Waaqi kana hin dhagguu?
\b
\q1 
\v 37 Waaqi adoo hin ajajin,
\q2 ka dubbatee woy godhuu dande'u eennu?
\q1 
\v 38 Wonni dansa'aa fi hantuulle
\q2 ajaja Waaqa Ol-Aana'aatiin teetii motii ree?
\q1 
\v 39 Nami adoo hin du'in
\q2 sababa cubbuu ifiitiin
\q2 yoo adabame maaf gunguma ree?
\b
\q1 
\v 40 Karaa keenna qorqorree ilaallee,
\q2 gara Waaqaa deebinuu ti.
\q1 
\v 41 Kowa'a gadha'aa fi harka keenna
\q2 gara Waaqa ol-gubbaa jiruu ol kaannee,
\q1 
\v 42 «Nuuti ajaja keeti didannee, jallannee
\q2 atille nu'uuf hin araaranne.
\b
\q1 
\v 43 «Ati aari'iin guutantee, nu ariitee,
\q2 marartii malee nu ijjeette.
\q1 
\v 44 Daadimannaan teenna si bira akka hin geenne,
\q2 duumensaan ifi gollatte.
\q1 
\v 45 Gosa biyya adda addaa oddu'utti
\q2 xuri'ii fi huuraa nu goote.
\b
\q1 
\v 46 «Diinoti keenna marti
\q2 afaan bananee nutti murgane.
\q1 
\v 47 Soda'aa fi boolla bu'iis,
\q2 diigamaa fi badiin nu dhaqqaddeerti» hin jenna.
\q1 
\v 48 Kolbaan tiyya waan badeef
\q2 imimmaan ila tiyyaa akka lagaa lolaati.
\b
\q1 
\v 49 Imimmaan tiyya yennaa mara lolaati,
\q1 
\v 50 Tun haga Waaqi ol-gubbaa irraa gad
\q2 ilaalee na dhaggutti teeti.
\q1 
\v 51 Waan diinni kolbaa qachaa Yerusaalemii irratti godhe
\q2 yennaa dhaggitu gadhaan kiyya hin gadda.
\b
\q1 
\v 52 Diinoti kiyya ka sababa malee na jibbanu
\q2 akka gororri'ii na adansane.
\q1 
\v 53 Jiru'uunuu boollatti na gatanee
\q2 afaan boollaa dhaka'aan cufane.
\q1 
\v 54 Bisaan mataa kiyya irra dacha'ee,
\q2 ani «Du'aara» jedhe.
\b
\q1 
\v 55 Qilee boollaa keessaa,
\q2 maqaa keeti waammadhe.
\q1 
\v 56 Ati gaaffii tiyya dhageetteertaa,
\q2 yennaa ani qarqaarsaaf sitti iyyadhu,
\q2 gurra keeti hin qabatin; ammoo furii naa kenni!
\q1 
\v 57 Yennaa ani si waammadhe,
\q2 ati na bira dhuttee, «Hin sodaatin!» naan jette.
\q1 
\v 58 Goottaa kiyya! Haajaa kiyya fudhattee,
\q2 lubbuu tiyya wodatte.
\q1 
\v 59 Goottaa kiyya!
\q2 Daba na irratti hujame dhaggiteerta,
\q2 ati naaf muri!
\q1 
\v 60 Haluu diinoti na irratti qabanuu fi
\q2 mala isaan na irratti dhowane
\q2 mara dhaggiteerta.
\b
\q1 
\v 61 Ee waaqa! Murgoo isaan natti murgane,
\q2 mala isaan natti dhowane dhageetteerta.
\q1 
\v 62 Guyyaa guutuu diinoti kiyya,
\q2 na irratti hasaasaa, gunguman.
\q1 
\v 63 Kunoo isaan yennaa tee'anu fi ka'anu mara,
\q2 weeddu'uun natti murgan.
\b
\q1 
\v 64 Ee Waaqa!
\q2 Akka hujii isaaniititti isaaniif kenni!
\q1 
\v 65 Abaarsi keeti akka isaanitti dhufu,
\q2 mataa isaanii jabeessi!
\q1 
\v 66 Waaqa kiyya! Aari'iin isaan ari'iitii,
\q2 Biyya lafaa irraa isaan balleessi.
\c 4
\s1 Diigama Yerusaalemii
\q1 
\v 1 Worqiin attam calalaqa ifii dhaddee,
\q2 worqiin qulqulluun attam jijjiirante!
\q1 Dhakaan Galmi Waaqaa ittiin ijaarame
\q2 attam karaa irratti bittinnowe!
\b
\q1 
\v 2 Ilmaan Xiyoonii worri dur
\q2 akka worqii gatii guddo'ootitti ilaallamanu
\q2 amma attam akka faara
\q2 harka namaatiin hujamee te'ane!
\b
\q1 
\v 3 Jeedaltinuu\f + \fr 4:3 \fqa Jeedalti: \ft Ukkullolle hin jedhanti.\f* ilmee ifii
\q2 harma hoosifatti,
\q2 kolbaa tiyya ammoo akka guchiin gammoojji'ii
\q2 ilme'etti gadhaa jabaatu teeteerti.
\b
\q1 
\v 4 Dheebuu bisaaniitiin
\q2 arrabi ijoolle'ee laagada'atti goge.
\q1 Jjoolleen sagalee kadhatti;
\q2 ammoo ka itti kennu hin jiru.
\b
\q1 
\v 5 Kolbaan dur waan dansaa nyaataa turte
\q2 karaa irratti beelaan dhumatte;
\q2 worri dur woyaa dhiillee uffatee guddate
\q2 amma tuulaa daadha'aa irra irkate.
\b
\q1 
\v 6 Adabamiis kolbaa tiyyaa
\q2 adabamiisa Sodoom,
\q2 harki nama tokkoolle adoo hin tuqin
\q2 dedhuma badde san caala.
\b
\q1 
\v 7 Sooreyyiin isaanii cabbii caalaa calalaqanee,
\q2 aanan caalaa addaatan;
\q2 nafi isaaniille dooqa caalaa dhiille'e;
\q2 akki dansummaa isaaniille akka dhakaa Safiirosii tola.
\b
\q1 
\v 8 Amma fuulli isaanii cilee caalaa gurraachoweera;
\q2 nami karaa irratti isaan beekuuyyuu hin jiru.
\q1 Gogaan isaanii shuntuuratee lafe'etti maxxanee,
\q2 akka muka gogee te'eera.
\b
\q1 
\v 9 Worra midhaan ficha'aa dhabee
\q2 suutuma suutaan
\q2 beelaan du'ee mannaa,
\q2 worra shallaaga'aan du'e woyya.
\b
\q1 
\v 10 Badiin kolbaa tiyyatti yennaa dhutte
\q2 dubartooti gadhi-laafeyyiin
\q2 ijoollee ifii harka ifiitiin
\q2 nyaatiisaaf iffeelane.
\b
\q1 
\v 11 Waaqi aarii hantuu ifii buusee
\q2 hundee isi'ii balleessiisaaf,
\q2 Xiyoonitti ibidda gabbise.
\b
\q1 
\v 12 Moototi lafaalle te'ee kolbaan biyya lafaa,
\q2 diinoti yookiin nyaaphi karra dalleya Yerusaalemii
\q2 seenuu akka dande'anu hin dhugeeffanne.
\b
\q1 
\v 13 Te'uu malee,
\q2 sababa cubbuu raagota isi'iitii fi
\q2 yakkaa hayyoota isi'ii
\q2 dhiiga worra yakkaa hin qannee
\q2 dhangalaasaneef tun teete.
\b
\q1 
\v 14 Isaan dhiigaan waan battowaneef
\q2 nami woyaa isaaniituu tuqu hin jiru.
\q1 Isaan akka balla'aa
\q2 karaa irra titimisane.
\b
\q1 
\v 15 Namooti «Isin worri battoottane, achi deema'a!
\q2 Nu hin tuqina'a» jedhanee isaanitti iyyane.
\q1 Yennaa isaan baqatanee joonjane,
\q2 kolbaan gosa biyya adda addaa,
\q2 «Haganaa achi isaan as turuu hin dande'anu!» jedhane.
\b
\q1 
\v 16 Waaqi ifumaafuu isaan bittinneesse;
\q2 inni deebi'ee isaan hin ilaalu.
\q2 Hayyooti hin kabajantu,
\q2 jaarsoleelle fudhatama hin qabaattu.
\b
\q1 
\v 17 Akkasuma qarqaarsa adoo eegannuu
\q2 ilti nu dadhadde;
\q2 gosa biyya nu qarqaaruu hin dandeenne irraa
\q2 qarqaarsa eegane.
\b
\q1 
\v 18 Diinoti keenna waan nu gaadanuuf
\q2 kara'aayyuu deemiisa hin dandeenne.
\q1 Muummeen teenna dhikaattee,
\q2 barri keenna waan hobba'eef,
\q2 guyyooti keenna laakkossatti galeera.
\b
\q1 
\v 19 Diinoti keenna
\q2 risaa caalaa ariifatan;
\q2 gaara irra nu ari'anee,
\q2 goomolee keessalle'etti nu gaadane.
\b
\q1 
\v 20 Ka Waaqi nu'uuf muude,
\q2 ka nuuti, «Hafuura jiruu teennaa ti;
\q2 gaaddisa isaa jalatti
\q2 gosa biyya adda addaa odduu hin leena» jenne,
\q2 boolla isaan nu'uuf qotane keessatti qabame.
\b
\q1 
\v 21 Isin kolbaa qachaa Edoomii,
\q2 worra biyya Uzii keessa leetanu,
\q2 gammada'aa ilillisa'a;
\q2 ammoo muduunuun mufii Waaqaa
\q2 isinitti dhufaarti;
\q2 isin machoottanee qullaa deentan.
\b
\q1 
\v 22 Kolbaa Xiyoonii!
\q2 Adabbiin teessan hobbaateerti;
\q1 Waaqi haganaa achi
\q2 boojuu keessa akka leetanu isin hin godhu.
\q1 Ee kolbaa Edoomii,
\q2 inni yakkaa teessan hin adaba
\q2 cubbuu teessanille qaaleyatti baasa.
\b
\c 5
\s1 Daadimata Marartii Dhaggatiisaaf Dhikaate
\q1 
\v 1 Ee Waaqa, waan nu irratti te'e qaabadhu;
\q2 kunoo, salphinna keennalle dhaggi.
\b
\q1 
\v 2 Qabeenna keenna ormi,
\q2 mana keenna alagaan fudhate.
\b
\q1 
\v 3 Nuuti ijoollee worri irraa du'e,
\q2 ta abbaa hin qannee teeneerra;
\q2 haadhotiin teennalle
\q2 haadha hiyyeessaa te'aneeran.
\b
\q1 
\v 4 Bisaan unnuuf hin kaffalla;
\q2 qoraanille hin bitanna.
\b
\q1 
\v 5 Akka horii waanjoo itti hidhanee
\q2 oofamiisaan guddoo dadhanneerra;
\q2 fooralle nu dhoogganeeran.
\b
\q1 
\v 6 Sagalee quufiisaaf,
\q2 worra Gibxi'iitii fi Asooriititti harka kennanne.
\b
\q1 
\v 7 Abbootiin teenna ta durii
\q2 cubbuu hujjee dabarte;
\q2 nuuti ammoo sababa cubbuu isaaniitiif
\q2 rakkatiisatti jirra.
\b
\q1 
\v 8 Garbooleen nu bulchan;
\q2 nami harka isaaniitii nu baasu hin jiru.
\b
\q1 
\v 9 Goomolee keessa
\q2 ijjeechaan waan jirtuuf,
\q2 lubbuu teenna gurgurannee,
\q2 sagalee dhagganna.
\b
\q1 
\v 10 Beela irraa ka ka'e
\q2 gogaan keenna
\q2 akka suunsumaa gurraachoweera.
\b
\q1 
\v 11 Dubartoota Xiyoon keessatti,
\q2 durralle qachoota Yihuda'aa keessatti
\q2 hunnaan woliin rafane.
\b
\q1 
\v 12 Sooreyyiin harka isaaniitiin fannifante;
\q2 jaarsoleen ulfinna dhadde.
\b
\q1 
\v 13 Dargaggoota dhiiraa
\q2 hunnaan daakuu daassifatane;
\q2 ijoolleen dhiiraa
\q2 qoraan guddaa ba'atanee tintimane\f + \fr 5:13 \fqa Tintimane: \ft Yookiin gatantarane.\f*.
\b
\q1 
\v 14 Jaarsoleen
\q2 yaa'ii karra qacha'aa,
\q2 dargaggootille sirba lakkitteerti.
\b
\q1 
\v 15 Gammadi gadhaa keenna keessaa badeera,
\q2 sirbi keenna gara bowaa deebi'eera.
\b
\q1 
\v 16 Nuuti cubbuu waan hunyeef,
\q2 ulfinni nu irraa ka'eera;
\q2 nu'uuf aanne'e!
\b
\q1 
\v 17 Waan kanaaf gadhaan nu dhibameera;
\q2 iltille nu cuurrotteerti.
\b
\q1 
\v 18 Sababa kanaaf gaarri Xiyoonii onee,
\q2 jeedalti irra burraaxxi.
\b
\q1 
\v 19 Ee Waaqa, ati ammoo,
\q2 haga bara baraa mooti'i;
\q2 barcumaan mootummaa teetiille
\q2 dhalootaa haga dhalootaatitti jiraata.
\b
\q1 
\v 20 Ati maaf ijjumaa nu deete?
\q2 Maaf haga kana mara nu lakkitte?
\b
\q1 
\v 21 Ee Waaqa, akka duriititti nu deebifadhu,
\q2 nuutille hin deebina;
\q2 bara keenna haaressii akka durii nuu tolchi.
\b
\q1 
\v 22 Yoo kana hin tolchin ati nu gatteerta;
\q2 akka maleelle nutti aarteerta.
