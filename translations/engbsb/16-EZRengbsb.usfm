\b  
\m
\v 5 But \w the|strong="H5922"\w* \w eye|strong="H5870"\w* \w of|strong="H5922"\w* their God \w was|strong="H1934"\w* \w on|strong="H5922"\w* \w the|strong="H5922"\w* \w elders|strong="H7868"\w* \w of|strong="H5922"\w* \w the|strong="H5922"\w* \w Jews|strong="H3062"\w*, \w so|strong="H5705"\w* \w that|strong="H5922"\w* \w they|strong="H3809"\w* \w were|strong="H1934"\w* \w not|strong="H3809"\w* stopped \w until|strong="H5705"\w* \w a|strong="H3068"\w* report \w was|strong="H1934"\w* sent \w to|strong="H5922"\w* \w Darius|strong="H1868"\w* \w and|strong="H1934"\w* \w written|strong="H5407"\w* instructions \w about|strong="H5922"\w* \w this|strong="H1836"\w* \w matter|strong="H1836"\w* \w were|strong="H1934"\w* \w returned|strong="H8421"\w*.   
\s1 Tattenai’s Letter to Darius  
\b  
\m
\v 6 \w This|strong="H5922"\w* \w is|strong="H1768"\w* \w the|strong="H5922"\w* text \w of|strong="H4430"\w* \w the|strong="H5922"\w* letter \w that|strong="H1768"\w* \w Tattenai|strong="H8674"\w* \w the|strong="H5922"\w* \w governor|strong="H6347"\w* \w of|strong="H4430"\w* \w the|strong="H5922"\w* \w region|strong="H5675"\w* west \w of|strong="H4430"\w* \w the|strong="H5922"\w* Euphrates, \w Shethar-bozenai|strong="H8370"\w*, \w and|strong="H4430"\w* their associates, \w the|strong="H5922"\w* officials \w in|strong="H5922"\w* \w the|strong="H5922"\w* \w region|strong="H5675"\w*, \w sent|strong="H7972"\w* \w to|strong="H5922"\w* \w King|strong="H4430"\w* \w Darius|strong="H1868"\w*.  
\v 7 \w The|strong="H3606"\w* \w report|strong="H6600"\w* \w they|strong="H3606"\w* \w sent|strong="H7972"\w* \w him|strong="H5922"\w* read \w as|strong="H3606"\w* follows:  
\b  
\pmo \w To|strong="H5922"\w* \w King|strong="H4430"\w* \w Darius|strong="H1868"\w*:  
\b  
\pmo \w All|strong="H3606"\w* \w peace|strong="H8001"\w*.   
\b  
\pmo
\v 8 Let \w it|strong="H1932"\w* \w be|strong="H1934"\w* \w known|strong="H3046"\w* \w to|strong="H3046"\w* \w the|strong="H1768"\w* \w king|strong="H4430"\w* \w that|strong="H1768"\w* \w we|strong="H3068"\w* went into \w the|strong="H1768"\w* \w province|strong="H4083"\w* \w of|strong="H1005"\w* \w Judah|strong="H3061"\w*, \w to|strong="H3046"\w* \w the|strong="H1768"\w* \w house|strong="H1005"\w* \w of|strong="H1005"\w* \w the|strong="H1768"\w* \w great|strong="H7229"\w* God. \w The|strong="H1768"\w* people \w are|strong="H1768"\w* \w rebuilding|strong="H1124"\w* \w it|strong="H1932"\w* \w with|strong="H5648"\w* \w large|strong="H7229"\w* stones, \w and|strong="H4430"\w* placing timbers \w in|strong="H5648"\w* \w the|strong="H1768"\w* \w walls|strong="H3797"\w*. \w This|strong="H1791"\w* \w work|strong="H5673"\w* \w is|strong="H1768"\w* being \w carried|strong="H5648"\w* \w out|strong="H5648"\w* diligently \w and|strong="H4430"\w* \w is|strong="H1768"\w* prospering \w in|strong="H5648"\w* their \w hands|strong="H3028"\w*.   
\b  
\pmo
\v 9 \w So|strong="H3660"\w* \w we|strong="H3068"\w* questioned \w the|strong="H1124"\w* \w elders|strong="H7868"\w* \w and|strong="H1005"\w* \w asked|strong="H7593"\w*, “\w Who|strong="H4479"\w* authorized you \w to|strong="H2942"\w* \w rebuild|strong="H1124"\w* \w this|strong="H1836"\w* \w temple|strong="H1005"\w* \w and|strong="H1005"\w* restore \w this|strong="H1836"\w* \w structure|strong="H3635"\w*?”   
\b  
\pmo
\v 10 \w We|strong="H1768"\w* also \w asked|strong="H7593"\w* \w for|strong="H1768"\w* \w their|strong="H7593"\w* \w names|strong="H8036"\w*, \w so|strong="H1768"\w* \w that|strong="H1768"\w* \w we|strong="H3068"\w* \w could|strong="H1768"\w* \w write|strong="H3790"\w* \w down|strong="H3790"\w* \w the|strong="H1768"\w* \w names|strong="H8036"\w* \w of|strong="H1768"\w* \w their|strong="H7593"\w* leaders \f + \fr 5:10 \ft Aramaic the names of the men at their heads\f* \w for|strong="H1768"\w* \w your|strong="H1768"\w* \w information|strong="H3046"\w*.   
\b  
\pmo
\v 11 \w And|strong="H4430"\w* \w this|strong="H1836"\w* \w is|strong="H1768"\w* \w the|strong="H1768"\w* \w answer|strong="H6600"\w* \w they|strong="H3660"\w* \w returned|strong="H8421"\w*:  
\b  
\pmo “\w We|strong="H1768"\w* \w are|strong="H1768"\w* \w servants|strong="H5649"\w* \w of|strong="H1005"\w* \w the|strong="H1768"\w* God \w of|strong="H1005"\w* \w heaven|strong="H8065"\w* \w and|strong="H4430"\w* earth, \w and|strong="H4430"\w* \w we|strong="H3068"\w* \w are|strong="H1768"\w* \w rebuilding|strong="H1124"\w* \w the|strong="H1768"\w* \w temple|strong="H1005"\w* \w that|strong="H1768"\w* \w was|strong="H1934"\w* \w built|strong="H1124"\w* \w many|strong="H7690"\w* \w years|strong="H8140"\w* \w ago|strong="H6928"\w*, \w which|strong="H1768"\w* \w a|strong="H3068"\w* \w great|strong="H7229"\w* \w king|strong="H4430"\w* \w of|strong="H1005"\w* \w Israel|strong="H3479"\w* \w built|strong="H1124"\w* \w and|strong="H4430"\w* completed.  
\v 12 \w But|strong="H3861"\w* \w since|strong="H1768"\w* \w our|strong="H4481"\w* fathers \w angered|strong="H7265"\w* \w the|strong="H4481"\w* God \w of|strong="H4481"\w* \w heaven|strong="H8065"\w*, \w He|strong="H1768"\w* \w delivered|strong="H3052"\w* \w them|strong="H1994"\w* \w into|strong="H1541"\w* \w the|strong="H4481"\w* \w hand|strong="H3028"\w* \w of|strong="H4481"\w* \w Nebuchadnezzar|strong="H5020"\w* \w king|strong="H4430"\w* \w of|strong="H4481"\w* Babylon, \w the|strong="H4481"\w* \w Chaldean|strong="H3679"\w* \w who|strong="H1768"\w* \w destroyed|strong="H5642"\w* \w this|strong="H1836"\w* \w temple|strong="H1005"\w* \w and|strong="H4430"\w* \w carried|strong="H1541"\w* \w away|strong="H1541"\w* \w the|strong="H4481"\w* \w people|strong="H5972"\w* \w to|strong="H1994"\w* Babylon.   
\b  
\pmo
\v 13 \w In|strong="H4430"\w* \w his|strong="H1768"\w* \w first|strong="H2298"\w* \w year|strong="H8140"\w*, \w however|strong="H1297"\w*, \w Cyrus|strong="H3567"\w* \w king|strong="H4430"\w* \w of|strong="H1005"\w* Babylon \w issued|strong="H7761"\w* \w a|strong="H3068"\w* \w decree|strong="H2942"\w* \w to|strong="H2942"\w* \w rebuild|strong="H1124"\w* \w this|strong="H1836"\w* \w house|strong="H1005"\w* \w of|strong="H1005"\w* God.  
\v 14 \w He|strong="H1768"\w* \w also|strong="H4430"\w* removed \w from|strong="H4481"\w* \w the|strong="H4481"\w* \w temple|strong="H1005"\w* \f + \fr 5:14 \ft Or palace\f* \w of|strong="H4481"\w* Babylon \w the|strong="H4481"\w* \w gold|strong="H1722"\w* \w and|strong="H4430"\w* \w silver|strong="H3702"\w* articles belonging \w to|strong="H1994"\w* \w the|strong="H4481"\w* \w house|strong="H1005"\w* \w of|strong="H4481"\w* God, \w which|strong="H1768"\w* \w Nebuchadnezzar|strong="H5020"\w* \w had|strong="H4430"\w* \w taken|strong="H5312"\w* \w and|strong="H4430"\w* carried \w there|strong="H1768"\w* \w from|strong="H4481"\w* \w the|strong="H4481"\w* \w temple|strong="H1005"\w* \w in|strong="H5020"\w* \w Jerusalem|strong="H3390"\w*. \w King|strong="H4430"\w* \w Cyrus|strong="H3567"\w* \w gave|strong="H3052"\w* \w these|strong="H1994"\w* articles \w to|strong="H1994"\w* \w a|strong="H3068"\w* man \w named|strong="H8036"\w* \w Sheshbazzar|strong="H8340"\w*, \w whom|strong="H1768"\w* \w he|strong="H1768"\w* \w appointed|strong="H7761"\w* \w governor|strong="H6347"\w*  
\v 15 \w and|strong="H1005"\w* instructed, ‘\w Take|strong="H5376"\w* \w these|strong="H1994"\w* articles, \w put|strong="H5182"\w* \w them|strong="H1994"\w* \w in|strong="H5922"\w* \w the|strong="H5922"\w* \w temple|strong="H1005"\w* \w in|strong="H5922"\w* \w Jerusalem|strong="H3390"\w*, \w and|strong="H1005"\w* let \w the|strong="H5922"\w* \w house|strong="H1005"\w* \w of|strong="H1005"\w* God \w be|strong="H1005"\w* \w rebuilt|strong="H1124"\w* \w on|strong="H5922"\w* its original site.’   
\b  
\pmo
\v 16 \w So|strong="H1768"\w* \w this|strong="H1791"\w* \w Sheshbazzar|strong="H8340"\w* \w came|strong="H1768"\w* \w and|strong="H1005"\w* \w laid|strong="H3052"\w* \w the|strong="H4481"\w* foundation \w of|strong="H4481"\w* \w the|strong="H4481"\w* \w house|strong="H1005"\w* \w of|strong="H4481"\w* God \w in|strong="H8000"\w* \w Jerusalem|strong="H3390"\w*, \w and|strong="H1005"\w* \w from|strong="H4481"\w* \w that|strong="H1768"\w* time \w until|strong="H5705"\w* \w now|strong="H3705"\w* \w it|strong="H4481"\w* \w has|strong="H1768"\w* been \w under|strong="H4481"\w* \w construction|strong="H1124"\w*, \w but|strong="H4481"\w* \w it|strong="H4481"\w* \w has|strong="H1768"\w* \w not|strong="H3809"\w* yet been \w completed|strong="H8000"\w*.”   
\b  
\pmo
\v 17 \w Now|strong="H3705"\w*, \w therefore|strong="H5922"\w*, \w if|strong="H2006"\w* \w it|strong="H5922"\w* \w pleases|strong="H2869"\w* \w the|strong="H5922"\w* \w king|strong="H4430"\w*, \w let|strong="H3705"\w* \w a|strong="H3068"\w* \w search|strong="H1240"\w* \w be|strong="H1005"\w* \w made|strong="H7761"\w* \w of|strong="H4481"\w* \w the|strong="H5922"\w* \w royal|strong="H4430"\w* \w archives|strong="H1005"\w* \w in|strong="H5922"\w* Babylon \w to|strong="H5922"\w* see \w if|strong="H2006"\w* \w King|strong="H4430"\w* \w Cyrus|strong="H3567"\w* did indeed \w issue|strong="H7761"\w* \w a|strong="H3068"\w* \w decree|strong="H2942"\w* \w to|strong="H5922"\w* \w rebuild|strong="H1124"\w* \w the|strong="H5922"\w* \w house|strong="H1005"\w* \w of|strong="H4481"\w* God \w in|strong="H5922"\w* \w Jerusalem|strong="H3390"\w*. \w Then|strong="H1768"\w* \w let|strong="H3705"\w* \w the|strong="H5922"\w* \w king|strong="H4430"\w* \w send|strong="H7972"\w* \w us|strong="H5922"\w* \w his|strong="H5922"\w* decision \w in|strong="H5922"\w* \w this|strong="H1836"\w* \w matter|strong="H1836"\w*.   
\c 6  
\s1 The Decree of Darius  
\m
\v 1 Thus \w King|strong="H4430"\w* \w Darius|strong="H1868"\w* ordered \w a|strong="H3068"\w* \w search|strong="H1240"\w* \w of|strong="H1005"\w* \w the|strong="H1768"\w* \w archives|strong="H1005"\w* \w stored|strong="H5182"\w* \w in|strong="H4430"\w* \w the|strong="H1768"\w* \w treasury|strong="H1596"\w* \w of|strong="H1005"\w* Babylon.  
\v 2 \w And|strong="H4076"\w* \w a|strong="H3068"\w* \w scroll|strong="H4040"\w* \w was|strong="H4040"\w* \w found|strong="H7912"\w* \w in|strong="H7912"\w* \w the|strong="H1768"\w* fortress \w of|strong="H4083"\w* Ecbatana, \w in|strong="H7912"\w* \w the|strong="H1768"\w* \w province|strong="H4083"\w* \w of|strong="H4083"\w* \w Media|strong="H4076"\w*, with \w the|strong="H1768"\w* following \w written|strong="H3790"\w* on it:  
\b  
\pmo \w Memorandum|strong="H1799"\w*:   
\b  
\pmo
\v 3 \w In|strong="H4430"\w* \w the|strong="H1768"\w* \w first|strong="H2298"\w* \w year|strong="H8140"\w* \w of|strong="H1005"\w* \w King|strong="H4430"\w* \w Cyrus|strong="H3567"\w*, \w he|strong="H1768"\w* \w issued|strong="H7761"\w* \w a|strong="H3068"\w* \w decree|strong="H2942"\w* \w concerning|strong="H2942"\w* \w the|strong="H1768"\w* \w house|strong="H1005"\w* \w of|strong="H1005"\w* God \w in|strong="H4430"\w* \w Jerusalem|strong="H3390"\w*:  
\b  
\pmo Let \w the|strong="H1768"\w* \w house|strong="H1005"\w* \w be|strong="H1005"\w* \w rebuilt|strong="H1124"\w* \w as|strong="H1768"\w* \w a|strong="H3068"\w* place \w for|strong="H1768"\w* offering \w sacrifices|strong="H1685"\w*, \w and|strong="H4430"\w* let its foundations \w be|strong="H1005"\w* firmly \w laid|strong="H7761"\w*. It \w is|strong="H1768"\w* \w to|strong="H2942"\w* \w be|strong="H1005"\w* \w sixty|strong="H8361"\w* cubits high \w and|strong="H4430"\w* \w sixty|strong="H8361"\w* cubits \w wide|strong="H6613"\w*,\f + \fr 6:3 \ft The house was to be approximately 90 feet or 27.4 meters in height and width; Syriac (see also 1 Kings 6:2) It is to be sixty cubits long, twenty cubits wide, and thirty cubits high.\f*  
\v 4 with \w three|strong="H8532"\w* \w layers|strong="H5073"\w* \w of|strong="H4481"\w* cut stones \w and|strong="H4430"\w* one \w of|strong="H4481"\w* timbers. \w The|strong="H4481"\w* \w costs|strong="H5313"\w* \w are|strong="H1768"\w* \w to|strong="H4430"\w* \w be|strong="H1005"\w* \w paid|strong="H3052"\w* \w from|strong="H4481"\w* \w the|strong="H4481"\w* \w royal|strong="H4430"\w* \w treasury|strong="H1005"\w*.   
\b  
\pmo
\v 5 Furthermore, \w the|strong="H4481"\w* \w gold|strong="H1722"\w* \w and|strong="H1722"\w* \w silver|strong="H3702"\w* articles \w of|strong="H4481"\w* \w the|strong="H4481"\w* \w house|strong="H1005"\w* \w of|strong="H4481"\w* God, \w which|strong="H1768"\w* \w Nebuchadnezzar|strong="H5020"\w* \w took|strong="H5312"\w* \w from|strong="H4481"\w* \w the|strong="H4481"\w* \w temple|strong="H1005"\w* \w in|strong="H5020"\w* \w Jerusalem|strong="H3390"\w* \w and|strong="H1722"\w* carried \w to|strong="H1946"\w* Babylon, must \w also|strong="H4481"\w* \w be|strong="H1005"\w* \w returned|strong="H8421"\w* \w to|strong="H1946"\w* \w the|strong="H4481"\w* \w temple|strong="H1005"\w* \w in|strong="H5020"\w* \w Jerusalem|strong="H3390"\w* \w and|strong="H1722"\w* deposited \w in|strong="H5020"\w* \w the|strong="H4481"\w* \w house|strong="H1005"\w* \w of|strong="H4481"\w* God.   
\b  
\m
\v 6 \w Therefore|strong="H4481"\w* Darius decreed:  
\b  
\pmo \w To|strong="H4481"\w* \w Tattenai|strong="H8674"\w* \w governor|strong="H6347"\w* \w of|strong="H4481"\w* \w the|strong="H4481"\w* \w region|strong="H5675"\w* west \w of|strong="H4481"\w* \w the|strong="H4481"\w* Euphrates,\f + \fr 6:6 \ft Aramaic governor beyond the River; similarly in verses 8 and 13\f* \w Shethar-bozenai|strong="H8370"\w*, \w and|strong="H1934"\w* \w your|strong="H1768"\w* associates \w and|strong="H1934"\w* officials \w in|strong="H8536"\w* \w the|strong="H4481"\w* \w region|strong="H5675"\w*:  
\b  
\pmo \w You|strong="H1768"\w* must stay \w away|strong="H7352"\w* \w from|strong="H4481"\w* \w that|strong="H1768"\w* \w place|strong="H1934"\w*!  
\v 7 \w Leave|strong="H7662"\w* \w this|strong="H1791"\w* \w work|strong="H5673"\w* \w on|strong="H5922"\w* \w the|strong="H5922"\w* \w house|strong="H1005"\w* \w of|strong="H1005"\w* God \w alone|strong="H7662"\w*. Let \w the|strong="H5922"\w* \w governor|strong="H6347"\w* \w and|strong="H1005"\w* \w elders|strong="H7868"\w* \w of|strong="H1005"\w* \w the|strong="H5922"\w* \w Jews|strong="H3062"\w* \w rebuild|strong="H1124"\w* \w this|strong="H1791"\w* \w house|strong="H1005"\w* \w of|strong="H1005"\w* God \w on|strong="H5922"\w* its original site.   
\b  
\pmo
\v 8 \w I|strong="H4481"\w* \w hereby|strong="H4481"\w* \w decree|strong="H2942"\w* \w what|strong="H1768"\w* \w you|strong="H1768"\w* must \w do|strong="H5648"\w* \w for|strong="H1768"\w* \w these|strong="H4481"\w* \w elders|strong="H7868"\w* \w of|strong="H4481"\w* \w the|strong="H4481"\w* \w Jews|strong="H3062"\w* \w who|strong="H1768"\w* \w are|strong="H1768"\w* \w rebuilding|strong="H1124"\w* \w this|strong="H1791"\w* \w house|strong="H1005"\w* \w of|strong="H4481"\w* God:  
\b  
\pmo \w The|strong="H4481"\w* \w cost|strong="H5313"\w* \w is|strong="H1768"\w* \w to|strong="H2942"\w* \w be|strong="H1934"\w* \w paid|strong="H3052"\w* \w in|strong="H5648"\w* full \w to|strong="H2942"\w* \w these|strong="H4481"\w* \w men|strong="H1400"\w* \w from|strong="H4481"\w* \w the|strong="H4481"\w* \w royal|strong="H4430"\w* \w treasury|strong="H5232"\w* \w out|strong="H5648"\w* \w of|strong="H4481"\w* \w the|strong="H4481"\w* \w taxes|strong="H4061"\w* \w of|strong="H4481"\w* \w the|strong="H4481"\w* provinces west \w of|strong="H4481"\w* \w the|strong="H4481"\w* Euphrates, \w so|strong="H1768"\w* \w that|strong="H1768"\w* \w the|strong="H4481"\w* work \w will|strong="H1768"\w* \w not|strong="H3809"\w* \w be|strong="H1934"\w* hindered.  
\v 9 \w Whatever|strong="H4101"\w* \w is|strong="H1768"\w* needed—\w young|strong="H1123"\w* \w bulls|strong="H8450"\w*, \w rams|strong="H1798"\w*, \w and|strong="H8065"\w* lambs \w for|strong="H1768"\w* \w burnt|strong="H5928"\w* \w offerings|strong="H5928"\w* \w to|strong="H3390"\w* \w the|strong="H1768"\w* God \w of|strong="H1123"\w* \w heaven|strong="H8065"\w*, \w as|strong="H1768"\w* well \w as|strong="H1768"\w* \w wheat|strong="H2591"\w*, \w salt|strong="H4416"\w*, \w wine|strong="H2562"\w*, \w and|strong="H8065"\w* \w oil|strong="H4887"\w*, \w as|strong="H1768"\w* requested \w by|strong="H3118"\w* \w the|strong="H1768"\w* \w priests|strong="H3549"\w* \w in|strong="H1768"\w* \w Jerusalem|strong="H3390"\w*—must \w be|strong="H1934"\w* \w given|strong="H3052"\w* \w to|strong="H3390"\w* \w them|strong="H3052"\w* \w daily|strong="H3118"\w* \w without|strong="H3809"\w* \w fail|strong="H7960"\w*.  
\v 10 \w Then|strong="H4430"\w* \w they|strong="H1768"\w* \w will|strong="H1768"\w* \w be|strong="H1934"\w* able \w to|strong="H4430"\w* \w offer|strong="H7127"\w* \w sacrifices|strong="H5208"\w* \w of|strong="H4430"\w* \w a|strong="H3068"\w* sweet aroma \w to|strong="H4430"\w* \w the|strong="H1768"\w* God \w of|strong="H4430"\w* \w heaven|strong="H8065"\w* \w and|strong="H4430"\w* \w to|strong="H4430"\w* \w pray|strong="H6739"\w* \w for|strong="H1768"\w* \w the|strong="H1768"\w* \w lives|strong="H2417"\w* \w of|strong="H4430"\w* \w the|strong="H1768"\w* \w king|strong="H4430"\w* \w and|strong="H4430"\w* \w his|strong="H1768"\w* \w sons|strong="H1123"\w*.   
\b  
\pmo
