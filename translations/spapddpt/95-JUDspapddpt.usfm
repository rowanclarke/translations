\s1 Consejos finales  
\p
\v 17 \w Pero|strong="G1161"\w* ustedes, amados, recuerden \w las|strong="G3588"\w* \w palabras|strong="G4487"\w* dichas \w por|strong="G5259"\w* \w los|strong="G3588"\w* apóstoles \w de|strong="G5259"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w*,  
\v 18 quienes \w les|strong="G1909"\w* \w decían|strong="G3004"\w*: \w En|strong="G1909"\w* \add el \add*\w tiempo|strong="G5550"\w* \w final|strong="G2078"\w* \w se|strong="G1438"\w* manifestarán \w burladores|strong="G1703"\w* \w que|strong="G3754"\w* andarán \w según|strong="G2596"\w* \w sus|strong="G3588"\w* propios \w deseos|strong="G1939"\w* ardientes.\f + \fr 1:18 \ft Lit. \fqa de las iniquidades.\f*  
\v 19 \w Éstos|strong="G3778"\w* \w son|strong="G1510"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* causan división, gentes mundanas, \w que|strong="G3588"\w* \w no|strong="G3361"\w* \w tienen|strong="G2192"\w* \add el\add* \w Espíritu|strong="G4151"\w*.   
