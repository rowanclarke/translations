\v 7  \w The|strong="H3605"\w* \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w Israel|strong="H3478"\w* \w summoned|strong="H7121"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w leaders|strong="H2205"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* land \w and|strong="H1121"\w* \w said|strong="H7121"\w*, “\w Notice|strong="H3045"\w* \w how|strong="H3588"\w* \w this|strong="H2088"\w* \w man|strong="H2205"\w* \w is|strong="H2088"\w* \w looking|strong="H1245"\w* \w for|strong="H3588"\w* \w trouble|strong="H7451"\w*. \w Indeed|strong="H3588"\w*, \w he|strong="H3588"\w* demanded \w my|strong="H3605"\w* wives, \w sons|strong="H1121"\w*, \w silver|strong="H3701"\w*, \w and|strong="H1121"\w* \w gold|strong="H2091"\w*, \w and|strong="H1121"\w* \w I|strong="H3588"\w* \w did|strong="H3478"\w* \w not|strong="H3808"\w* \w resist|strong="H4513"\w* \w him|strong="H7121"\w*.”  
