\v 14 Sus esposas, sus pequeños y sus \w ganados|strong="H4735"\w* \w quedarán|strong="H3427"\w* en \w la|strong="H3605"\w* tierra \w que|strong="H3605"\w* \w Moisés|strong="H4872"\w* les \w dio|strong="H5414"\w* \w a|strong="H3068"\w* este \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*, pero \w todos|strong="H3605"\w* sus \w valientes|strong="H1368"\w* guerreros \w pasarán|strong="H5674"\w* en orden \w de|strong="H6440"\w* batalla al frente \w de|strong="H6440"\w* sus hermanos y \w los|strong="H3427"\w* ayudarán,  
\v 15 \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* conceda descanso \w a|strong="H3068"\w* \w sus|strong="H1992"\w* hermanos \w como|strong="H1571"\w* \w a|strong="H3068"\w* ustedes, \w y|strong="H1571"\w* \w ellos|strong="H1992"\w* \w también|strong="H1571"\w* \w posean|strong="H3423"\w* \w la|strong="H1571"\w* tierra \w que|strong="H5704"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w su|strong="H1992"\w* \nd ʼElohim\nd* \w les|strong="H1992"\w* \w da|strong="H5414"\w*. \w Entonces|strong="H7725"\w* \w se|strong="H1992"\w* \w volverán|strong="H7725"\w* \w a|strong="H3068"\w* \w la|strong="H1571"\w* tierra \w de|strong="H5704"\w* \w su|strong="H1992"\w* \w posesión|strong="H3425"\w*, \w y|strong="H1571"\w* \w poseerán|strong="H3423"\w* \w la|strong="H1571"\w* tierra \w que|strong="H5704"\w* \w Moisés|strong="H4872"\w*, esclavo \w de|strong="H5704"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w les|strong="H1992"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w este|strong="H4217"\w* \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*, hacia donde \w nace|strong="H4217"\w* \w el|strong="H1571"\w* \w sol|strong="H8121"\w*.   
