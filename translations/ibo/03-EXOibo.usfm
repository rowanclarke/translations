\id EXO - Biblica® Open Igbo Contemporary Bible 2020 
\h Ọpụpụ 
\toc1 Ọpụpụ 
\toc2 Ọpụpụ 
\toc3 Ọpụ 
\mt1 Ọpụpụ 
\c 1  
\s1 Eze na-amaghị Josef 
\li4  
\v 1 Ndị a bụ aha ụmụ ndị ikom Izrel, ndị sooro Jekọb gaa biri nʼala Ijipt, onye ọbụla nʼime ha kpọ ezinaụlọ ya. 
\b  
\li1  
\v 2 Ruben, Simiọn, Livayị na Juda; 
\li1  
\v 3 Isaka, Zebụlọn na Benjamin; 
\li1  
\v 4 Dan, na Naftalị; 
\li1 Gad na Asha. 
\b  
\li4  
\v 5 Ọnụọgụgụ ụmụ Jekọb ndị sooro ya gaa biri nʼIjipt dị iri mmadụ asaa. Ma Josef nọrịị nʼIjipt. 
\b  
\p  
\v 6 Emesịa, Josef na ụmụnne ya niile nwụrụ, ma ọgbọ ahụ niile nwụkwara.  
\v 7 Ma ihe gaara ụmụ ụmụ Izrel nke ọma, ha mụbara, dị ukwuu nʼọnụọgụgụ, jupụta ala ahụ niile. 
\p  
\v 8 Ma mgbe eze ọhụrụ nke na-amaghị Josef malitere ịchị ọchịchị nʼala Ijipt,  
\v 9 ọ sịrị ndị ya, “Lee, ndị Izrel abaala ụba nke ukwuu nʼọnụọgụgụ dịkwa ike karịa anyị.  
\v 10 Ngwanụ, ka anyị were amamihe meso ha mmeso ọjọọ, ma ọ bụghị otu a, ha ga-amụba karịa, mgbe agha ga-adapụta nʼetiti anyị na ndị iro anyị, ha ga-esoro ndị iro anyị lụso anyị agha, site nʼala a gbapụ.” 
\p  
\v 11 Nʼihi nke a, ha tinyere ndịisi ohu ga na eledo ha, bụ ndị ga-eji ọrụ mmanye kpagbuo ha. Ha wuuru Fero obodo Payitọm na Ramesis, ebe ọ na-echekwa ihe.  
\v 12 Ma dịka a na-ata ụmụ Izrel ahụhụ na-eleghị anya nʼazụ, otu a kwa ka ụmụ Izrel gara nʼihu na-amụba nʼọnụọgụgụ na-agbasakwa. Nke a mere ka ndị Ijipt tụọ ndị Izrel egwu.  
\v 13 Ha ji oke ọrụ mekpaa ụmụ Izrel ahụ nke ukwuu,  
\v 14 mee ka ndụ ụmụ Izrel bụrụ ndụ jupụtara nʼihe ilu. Ha nyere ha ọrụ ike nke ịkpụ brik na ụrọ, tinyere ọrụ dị iche iche nʼubi ha. Nʼime ọrụ niile ha na-arụ, ndị Ijipt mesiri ha ike nke ukwuu. 
\p  
\v 15 Mgbe ahụ kwa, eze Ijipt gwara ndị inyom Hibru na-aghọ nwa, ndị aha ha bụ Shifra na Pua\f + \fr 1:15 \ft Aha ndị inyom ndị a na-elekọta ndị inyom Hibru ime na-eme, zipụtara nʼebe o doro anya na ha bụ ndị Ijipt.\f* sị,  
\v 16 “Mgbe ọbụla unu na-aghọ nwa ndị inyom Hibru, unu lezie anya nʼokwute e ji amụ nwa, ọ bụrụ nwoke, gbuonụ ya, ma ọ bụrụkwanụ nwanyị, hapụnụ ya ka ọ dịrị ndụ.”  
\v 17 Ma ndị inyom ndị a na-aghọ nwa emeghị ihe eze Ijipt gwara ha, nʼihi na ha tụrụ egwu Chineke. Kama ha hapụrụ ụmụ ndị ikom ndị a ndụ.  
\v 18 Emesịa, eze Ijipt kpọrọ ndị inyom abụọ ahụ jụọ ha sị, “Gịnị mere unu ji nupu isi nʼiwu m nyere unu site nʼịhapụ igbu ụmụntakịrị ndị ikom Hibru a mụrụ, dịka m gwara unu?” 
\p  
\v 19 Ndị inyom ahụ zara Fero sị, “Ndị inyom Hibru na-adị ike karịa ndị inyom Ijipt nʼịmụ nwa. Ha na-amụpụtacharị ụmụ ha tupu anyị erute.” 
\p  
\v 20 Ya mere, Chineke gọziri ndị inyom ndị ahụ na-aghọ nwa. Ụmụ Izrel gara nʼihu na-amụba, ghọọ mba dị ukwuu.  
\v 21 Chineke nʼonwe ya, nyekwara ndị inyom ahụ na-aghọ nwa ezinaụlọ nke aka ha nʼihi na ha tụrụ egwu Chineke. 
\p  
\v 22 Mgbe ahụ, Fero nyere ndị ya niile iwu a, “A ga-atụnye ụmụntakịrị ndị ikom Hibru niile a mụrụ ọhụrụ nʼime osimiri Naịl, ma a ga-edebe ụmụntakịrị ọhụrụ bụ ndị inyom ndụ.” 
\c 2  
\s1 Ọmụmụ Mosis na mgbapụ ya 
\p  
\v 1 Nʼoge a, otu nwoke onye Hibru si nʼebo Livayị, gakwara lụọ otu nwaada onye Livayị.  
\v 2 Nwanyị a tụụrụ ime, mụọ otu nwa nwoke. Mgbe ọ hụrụ na nwa ọhụrụ ahụ mara mma, o zoro ya nʼụlọ ọnwa atọ.  
\v 3 Mgbe ọ na-enweghịkwa ike izo nwantakịrị a gaa nʼihu, o jiri ahịhịa papịrọs\f + \fr 2:3 \ft Bụ ahịhịa na-epu nʼakụkụ mmiri\f* kpaa nkata, were korota tee nʼahụ nkata ahụ niile igbochi mmiri ịbata nʼime ya. O kunyere nwantakịrị ahụ nʼime ya buru nkata ahụ debe ya nʼakụkụ osimiri Naịl ebe ahịhịa mmiri na-eto.  
\v 4 Nwanne nwantakịrị ahụ, nke nwanyị, gakwara guzo nʼebe dị anya na-eche nwantakịrị ahụ nche, ịhụ ihe ga-eme ya. 
\p  
\v 5 Ọ dịghị anya, ada Fero bịara nʼakụkụ osimiri Naịl ahụ ịsa ahụ. Mgbe ọ nọ na-asa ahụ, ụmụ agbọghọ na-ejere ya ozi malitere ịgagharị nʼakụkụ osimiri Naịl. Ma ada Fero lepụrụ anya hụ nkata ahụ nʼetiti riidi, zie otu nʼime ohu ya nwanyị ka ọ gaa bute ya.  
\v 6 Mgbe o bupụtara ya, meghee ya, ada Fero hụrụ nwantakịrị ahụ ka ọ na-akwa akwa. O nwere ọmịiko nʼebe nwantakịrị ahụ nọ. Ọ sịrị, “Nwatakịrị a ga-abụrịrị otu nʼime ụmụ ndị Hibru.” 
\p  
\v 7 Mgbe ahụ, nwanne nwanyị nwantakịrị a jụrụ ada Fero sị, “Ọ bụ m gaa chọọrọ gị otu nwanyị nʼime ndị inyom Hibru ka ọ na-elekọtaara gị nwantakịrị a anya?” 
\p  
\v 8 Ada Fero zaghachiri sị, “Ee, gaa mee otu ahụ.” Nwaagbọghọ ahụ gara ngwangwa nʼụlọ ha kpọọ nne nwantakịrị ahụ.  
\v 9 Mgbe ha bịaghachiri, ada Fero gwara nne nwantakịrị ahụ sị ya, “Kuru nwantakịrị a, gaa zụpụtara m ya. Aga m akwụ gị ụgwọ nke ọma.” Ya mere, nwanyị ahụ kuuru nwantakịrị ahụ, gaa zụọ ya.  
\v 10 Mgbe nwantakịrị ahụ tolitere, nne ya kulaara ya ada Fero, ka ọ bụrụ nwa ada Fero. Aha ada Fero gụrụ ya bụ Mosis, nʼihi ọ sịrị, “Esi m na mmiri gụpụta ya.” 
\s1 Mosis agbapụ ọsọ 
\p  
\v 11 Otu ụbọchị, mgbe Mosis toro, ọ pụrụ gaa nʼebe ụmụnna ya nọ, ilele ha mgbe ha nọ na-arụ ọrụ ike ha. Ọ hụrụ otu onye Ijipt ka ọ na-eti onye Hibru ihe, bụ otu nʼime ụmụnna ya.  
\v 12 Mosis lere anya nʼakụkụ abụọ. Mgbe ọ hụrụ na ọ dịghị onye na-ele ya anya, o gburu onye Ijipt ahụ, lie ya nʼime aja.  
\v 13 Nʼechi ya, Mosis pụrụ hụ ndị Hibru abụọ ka ha na-alụ ọgụ. Mosis jụrụ onye nke ikpe mara ajụjụ sị ya, “Gịnị mere i ji si otu a na-eti nwanna gị ihe?” 
\p  
\v 14 Ma onye ahụ jụrụ Mosis ajụjụ sị, “Onye mere gị onyeisi na onye ikpe nʼetiti anyị? Ị na-achọ igbu m dị ka i si gbuo onye Ijipt ahụ?” Mgbe ahụ Mosis tụrụ ụjọ. O kwuru nʼime onwe ya sị, “Ndị mmadụ amatala banyere ihe ahụ m mere.” 
\p  
\v 15 Mgbe Fero nụrụ ihe Mosis mere, ọ gbalịrị igbu Mosis. Ma Mosis si nʼihu Fero gbapụ ọsọ gbaga ala Midia.\f + \fr 2:15 \ft Midian bụ otu nʼime ụmụ Ebraham mụtara nʼikpeazụ. \xt Jen 25:2\ft  Ndị Midia na-ebi nʼakụkụ ugwu nke Ugwu Saịnaị.\f* Nʼebe ahụ ọ gara nọdụ ala nʼakụkụ olulu mmiri.  
\v 16 Ma o nwere otu onye nchụaja obodo Midia mụtara ụmụ agbọghọ asaa. Nʼoge a, ha bịara iseta mmiri na ịgbanye ya nʼime ihe ịgbanye mmiri anụ ụlọ maka inye igwe anụ ụlọ nna ha mmiri.  
\v 17 Ma ụfọdụ ndị na-azụ atụrụ bịara chụpụ ha. Mosis biliri ọtọ, bịa napụta ha, nyere ha aka nye igwe anụ ụlọ ha mmiri. 
\p  
\v 18 Ha lọghachikwutere nna ha, Reuel,\f + \fr 2:18 \ft Reuel bụ aha ọzọ e ji mara Jetro ọgọ Mosis. \xt Ọpụ 3:1; Ọnụ 10:29\f* onye jụrụ ha sị, “Gịnị mere unu ji lọta nʼoge taa?” 
\p  
\v 19 Ha zara nna ha sị, “Otu onye Ijipt napụtara anyị site nʼaka ndị ọzụzụ atụrụ. O setaara anyị mmiri, nyekwa igwe anụ ụlọ anyị mmiri.” 
\p  
\v 20 Nna ha jụrụ ha sị, “Olee ebe ọ nọ? Gịnị mere unu ji hapụ ya nʼebe ahụ? Gaanụ kpọọ ya ka o soro anyị rie nri.” 
\p  
\v 21 Mosis nabatara oku ahụ Reuel kpọrọ ya ka ha na ya biri. O sokwara ha biri. Reuel kpọnyere Mosis Zipọra, otu nwa ya nwanyị, ka ọ bụrụ nwunye ya.  
\v 22 Zipọra mụtara nwa nwoke, onye Mosis kpọrọ aha ya Geshọm. Nʼihi na Mosis sịrị, “Abụ m onye ọbịa nʼala ndị ọzọ.” 
\p  
\v 23 O ruo, mgbe ọtụtụ ụbọchị gara, Fero eze Ijipt nwụrụ. Nʼoge a, ụmụ Izrel nọ na-asụ ude nʼime ọnọdụ ịbụ ohu ha. Ha kwara akwa nke ukwuu. Akwa ha kwara ka e nyere ha aka nʼihi ọnọdụ ịbụ ohu ha ruru Chineke ntị.  
\v 24 Chineke nụrụ ịsụ ude ha. O chetara ọgbụgba ndụ ahụ ya na Ebraham, na Aịzik, na Jekọb gbara.  
\v 25 Chineke hụrụ ụmụ Izrel, ihe banyere ha metukwara ya nʼobi. 
\c 3  
\s1 Mosis nʼihu ọhịa na-enwu ọkụ 
\p  
\v 1 Nʼoge a, Mosis na-azụ igwe anụ ụlọ Jetro ọgọ ya nwoke, onye nchụaja na Midia. Otu ụbọchị, o duuru igwe anụ ụlọ ndị a gaa nʼakụkụ ọzara. Ọ batara Horeb,\f + \fr 3:1 \ft Ugwu a na-aza, Ugwu Chineke maọbụ Ugwu Saịnaị. \xt Ọpụ 4:27; 18:5\f* ugwu Chineke.  
\v 2 Nʼebe ahụ, mmụọ ozi nke \nd Onyenwe anyị\nd* mere ka ọ hụ ya nʼọkụ na-ere nʼetiti ọhịa. Mosis hụrụ na ọ bụ ezie na ọhịa ahụ na-enwu ọkụ ma ọ naghị ere ọkụ.  
\v 3 Nʼihi ya, Mosis chere nʼobi ya sị, “Aga m aga nso leruo ihe omimi a anya, otu ọkụ si enwu ma ọhịa anaghị ere ọkụ.” 
\p  
\v 4 Mgbe \nd Onyenwe anyị\nd* hụrụ na ọ tụgharịrị ka ọ hụ ihe na-eme, Chineke kpọrọ ya oku site nʼime ọhịa ahụ, “Mosis! Mosis!” 
\p Ọ sị, “Lekwa m nʼebe a.” 
\p  
\v 5 Mgbe ahụ, ọ sịrị ya, “Abịakwala nso. Yipụ akpụkpọụkwụ gị, nʼihi na ebe i guzo bụ ala dị nsọ.”  
\v 6 Ọ sịrị, “Abụ m Chineke nke nna gị. Chineke nke Ebraham, Chineke nke Aịzik na Chineke nke Jekọb.” Mosis zoro ihu ya, nʼihi na ọ tụrụ egwu ilegide Chineke anya. 
\p  
\v 7 Mgbe ahụ \nd Onyenwe anyị\nd* sịrị, “Nʼezie, ahụla m nhụju anya nke ndị m nọ nʼIjipt, anụkwala m mkpu akwa ha, nʼihi aka ike nke ndị na-achị ha dịka ndị ohu. Nʼihi na ama m ahụhụ ha na-agabiga.  
\v 8 Ya mere, agbadatala m ịnapụta ha site nʼaka ndị Ijipt na ịkpọpụta ha site nʼala ahụ, idubata ha nʼala ọma ahụ, nke sara mbara, ala mmiri ara ehi na mmanụ aṅụ na-eru na ya. Ala ebe ndị Kenan, na ndị Het, na ndị Amọrait, na ndị Periz, na ndị Hiv, na ndị Jebus bi.  
\v 9 Ugbu a, akwa ụmụ Izrel eruola m ntị, ahụkwala m otu ndị Ijipt si na-emegbu ha.  
\v 10 Ugbu a, aga m eziga gị ka i jekwuru Fero, ka i dupụta ndị m bụ ụmụ Izrel site nʼala Ijipt.” 
\p  
\v 11 Mosis sịrị Chineke, “Onye ka m bụ na m ga-ejekwuru Fero, meekwa ka ụmụ Izrel site nʼala Ijipt pụta?” 
\p  
\v 12 Chineke gwara ya sị, “Aga m anọnyere gị. Nke a ga-abụ ihe ama nye gị na ọ bụ m na-eziga gị. Mgbe i sitere nʼala Ijipt kpọpụta ụmụ Izrel, unu niile ga-efe m ofufe nʼelu ugwu a.” 
\p  
\v 13 Ma Mosis jụrụ Chineke sị, “Ọ bụrụ na m agwa ụmụ Izrel sị, ‘Chineke nna nna unu zitere m izi unu ozi,’ ha ga-ajụ m sị, ‘Gịnị bụ aha ya?’ Gịnị ka m ga-aza ha?” 
\p  
\v 14 Chineke sịrị Mosis, “ABỤ M ONYE M BỤ. Naanị gwa ụmụ Izrel na ‘ABỤ M zitere gị.’ ” 
\p  
\v 15 Chineke gakwara nʼihu gwa Mosis sị, Si otu a gwa ụmụ Izrel okwu. “\nd Onyenwe anyị\nd*, Chineke nna nna unu, Chineke Ebraham, Chineke Aịzik na Chineke Jekọb, zitere m ịbịakwute unu.” 
\q1 Nke a bụ aha m ruo mgbe ebighị ebi, 
\q2 aha nke e ji echeta m 
\q2 site nʼọgbọ ruo nʼọgbọ. 
\p  
\v 16 “Gaa, kpọkọta ndị okenye Izrel niile zie ha sị, ‘\nd Onyenwe anyị\nd* Chineke nna nna unu, Chineke Ebraham, Chineke Aịzik, na Chineke Jekọb, egosila m onwe ya, sị m, Eleruola m ọnọdụ unu anya hụ ihe a na-eme unu nʼala Ijipt.  
\v 17 Ekweela m nkwa ịkpọpụta unu site nʼahụhụ unu na-ahụ nʼala Ijipt duru unu baa nʼala nke ndị Kenan, na ndị Het, na ndị Amọrait, na ndị Periz, na ndị Hiv, na ndị Jebus bi nʼime ya. Ala mmiri ara ehi na mmanụ aṅụ na-eru na ya.’ 
\p  
\v 18 “Ndị okenye Izrel ga-anabata ozi gị. Mgbe ahụ gị na ha ga-eso gaa nʼihu eze Ijipt gwa ya sị, ‘\nd Onyenwe anyị\nd*, Chineke ndị Hibru ezutela anyị. Kwere ka anyị gaa njem nʼime ọzara abalị atọ gaa chụọrọ \nd Onyenwe anyị\nd* Chineke anyị aja.’  
\v 19 Amaara m rịị na eze Ijipt agaghị ekwe ka unu gaa, tutu ruo mgbe e ji aka ike kwagide ya.  
\v 20 Ma aga m esetipụ aka m tie Ijipt ihe otiti, site nʼihe ịrịbama dị iche iche nke m ga-eme nʼetiti ya. Mgbe nke a gasịrị, ọ ga-ahapụ unu ka unu laa. 
\p  
\v 21 “Aga m emekwa ka unu nweta amara nʼihu ndị Ijipt, ka unu ghara ịgba aka mgbe unu na-ala.  
\v 22 Nwanyị ọbụla ga-arịọ site nʼaka nwanyị Ijipt onye agbataobi ya na nwanyị ọbịa bi nʼụlọ ya, ihe niile e ji ọlaọcha na ọlaedo kpụọ, na akwa dị iche iche. Unu ga-eyikwasị ha ụmụ unu ndị ikom na ụmụ unu ndị inyom, bịa si otu a kwakọrọ ngwongwo ndị Ijipt.” 
\c 4  
\s1 Ihe ịrịbama nye Mosis 
\p  
\v 1 Mosis zaghachiri ya sị, “Gịnị ga-eme ma ọ bụrụ na ha agaghị ekwenye ihe m kwuru maọbụ ajụ ige m ntị? Ọ bụrụ na ha asị, ‘\nd Onyenwe anyị\nd* egosighị gị onwe ya.’ ” 
\p  
\v 2 Ma \nd Onyenwe anyị\nd* jụrụ Mosis ajụjụ sị ya, “Gịnị ka i ji nʼaka?” 
\p Mosis zara sị, “Ọ bụ mkpanaka.” 
\p  
\v 3 \nd Onyenwe anyị\nd* sịrị ya, “Tụpụ ya nʼala.” 
\p Mosis tụpụrụ ya nʼala. Ma otu mgbe ahụ, ọ ghọrọ agwọ. Mosis sitere nʼebe agwọ ahụ nọ gbapụ ọsọ.  
\v 4 \nd Onyenwe anyị\nd* gwara Mosis okwu ọzọ sị ya, “Jide agwọ ahụ aka nʼọdụdụ ya.” Mgbe Mosis mere nke a, agwọ ahụ ghọghachikwara mkpanaka.  
\v 5 \nd Onyenwe anyị\nd* gwara Mosis sị, “Ọ bụrụ na i mee ihe ịrịbama a, ha ga-ekwere ihe ị gwara ha. Ha ga-aghọta na \nd Onyenwe anyị\nd* Chineke nna nna ha, Chineke Ebraham, Chineke Aịzik, na Chineke Jekọb gosiri gị onwe ya.” 
\p  
\v 6 \nd Onyenwe anyị\nd* gwara ya okwu ọzọ sị, “Tinye aka gị nʼime uwe i yi nʼime ahụ gị.” Mgbe Mosis tinyere aka ya wepụta ya, ọ chọpụtara na ekpenta jupụtara nʼaka ahụ nke na-enwu ezi ọcha. 
\p  
\v 7 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya, “Tinyekwa aka gị nʼime uwe i yi nʼime ahụ gị.” Mosis mere otu a. Mgbe o wepụtara aka ya ọzọ, ọ hụrụ na ọ dịghachiri dịka akụkụ anụ ahụ ya ndị ọzọ. 
\p  
\v 8 Mgbe ahụ \nd Onyenwe anyị\nd* sịrị, “Ọ bụrụ na ụmụ Izrel ekweghị gị maọbụ nabata ihe ama nke mbụ, ha ga-ekwe ihe ịrịbama nke abụọ a.  
\v 9 Ma ọ bụrụ na ha ekwenyeghị nʼihe ịrịbama abụọ ndị a ma ọ bụkwanụ gee gị ntị; kute mmiri nʼosimiri Naịl, wụpụ ya nʼala akọrọ. Mmiri ahụ nke i kutere site nʼosimiri ga-agbanwe, ghọọ ọbara nʼala akọrọ.” 
\p  
\v 10 Mosis sịrị \nd Onyenwe anyị\nd*, “Biko Onyenwe m, abụghị m onye mara ekwu okwu. Ọ nwebeghị oge m ji bụrụ onye ọka okwu, na mgbe gara aga maọbụ site na mgbe ị gwara ohu gị okwu. Lee, onye nwere ire na egbugbere ọnụ dị arọ ka m bụ.” 
\p  
\v 11 \nd Onyenwe anyị\nd* jụrụ Mosis ajụjụ sị, “Onye mere ọnụ mmadụ? Onye na-emekwa ka ntị mmadụ chie ya, maọbụ ka mmadụ daa ogbi? Onye na-eme ka mmadụ hụ ụzọ, maọbụ kpụọ ìsì? Ọ bụghị mụ onwe m bụ \nd Onyenwe anyị\nd*?  
\v 12 Ugbu a, gaa mee ihe m gwara gị. Aga m enyere gị aka ikwu okwu nke ọma. Aga m agwakwa gị ihe ị ga-ekwu.” 
\p  
\v 13 Ma ọ rịọrọ, “Biko Onyenwe m, ziganụ onye ọzọ.” 
\p  
\v 14 \nd Onyenwe anyị\nd* were iwe dị ọkụ megide Mosis sị ya, “Kedụ maka nwanne gị nwoke Erọn onye Livayị, amaara m na ọ bụ onye ọka okwu. Lee, ọ na-abịa izute gị. Ọ ga-aṅụrị ọṅụ mgbe ọ chọtara gị.  
\v 15 Ị ga-agwa ya okwu, tinye okwu gị nʼọnụ ya. Aga m enyere unu abụọ aka ikwu okwu nke ọma, aga m ezikwa unu abụọ ihe unu ga-eme.  
\v 16 Ọ ga-abụ onye na-ekwuchite ọnụ gị nʼebe ndị mmadụ nọ. Ị ga-anọ dịka Chineke nʼebe ọ nọ, nʼihi na ị ga-agwa ya ihe niile ọ ga-ekwu.  
\v 17 Ma ị ga-ejide mkpanaka a dị nʼaka gị ka i nwee ike jiri ya mee ihe ịrịbama.” 
\s1 Nlọghachi Mosis nʼIjipt 
\p  
\v 18 Emesịa, Mosis lọghachiri nʼụlọ ebe o bi, jekwuru Jetro ọgọ ya nwoke rịọọ ya sị, “Biko kwere ka m laghachi nʼIjipt gaa chọpụta ma o nwere ndị ikwu m ka dị ndụ.” 
\p Jetro sịrị, “Gaa nʼudo.” 
\p  
\v 19 Ugbu a \nd Onyenwe anyị\nd* gwara Mosis okwu nʼala Midia sị ya, “Laghachi Ijipt nʼihi na ndị niile chọrọ igbu gị anwụchaala.”  
\v 20 Mosis kpọọrọ nwunye ya, na ụmụ ya ndị ikom, nọkwasị nʼelu ịnyịnya ibu, laghachi nʼala Ijipt. O jikwa mkpanaka Chineke ahụ nʼaka ya. 
\p  
\v 21 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya, “Mgbe i ruru Ijipt, hụ na ị gara nʼihu Fero mee ihe ebube niile m nyere gị ike ime. Ma aga m eme ka obi ya sie ike, ka ọ ghara ikwe ka ndị m laa.  
\v 22 Ị ga-agwa Fero okwu sị ya, ‘Nke a bụ ihe \nd Onyenwe anyị\nd* kwuru, Izrel bụ Ọkpara m.  
\v 23 Agwara m gị okwu sị, “Hapụ nwa m nwoke ka o si nʼala Ijipt pụọ gaa ebe ọ ga-anọ fee m ofufe,” ma ị jụrụ ajụ. Ugbu a aga m egbu ọkpara gị.’ ” 
\p  
\v 24 Mgbe Mosis na ezinaụlọ ya na-alaghachi Ijipt, ha rutere ebe ha ga-ezu ike abalị. Nʼebe ahụ, \nd Onyenwe anyị\nd* bịakwutere Mosis chọọ igbu ya.  
\v 25 Ma Zipọra nwunye Mosis weere mma ntakịrị bie nwa ya ugwu. O were ihe o bipụtara nʼugwu a metụ nʼụkwụ Mosis, kwuo sị, “Nʼezie, ị bụ di ọbara nʼebe m nọ.”  
\v 26 Nʼihi ya, \nd Onyenwe anyị\nd* hapụrụ Mosis. (Mgbe ahụ, Zipọra kwuru sị, “Ị bụ di ọbara,” nʼihi obibi ugwu ahụ.) 
\p  
\v 27 Ugbu a, \nd Onyenwe anyị\nd* gwara Erọn okwu sị, “Gaa nʼime ọzara ka izute Mosis.” Erọn gara jekwuru Mosis nʼugwu Horeb, ugwu Chineke, sutu ya ọnụ.  
\v 28 Mgbe ahụ Mosis gwara Erọn ihe niile \nd Onyenwe anyị\nd* ziri ya ka o kwuo, ya na ihe ịrịbama ndị ahụ niile o nyere nʼiwu ka o mee. 
\p  
\v 29 Mosis na Erọn jeruru Ijipt kpọọ nzukọ ndị okenye ụmụ Izrel niile.  
\v 30 Erọn gwara ha ihe niile \nd Onyenwe anyị\nd* gwara Mosis. Mosis, nʼonwe ya mere ihe ịrịbama ahụ niile nʼihu anya ha.  
\v 31 Mgbe ahụ, ha kwenyere; dịka ha nụrụ na \nd Onyenwe anyị\nd* eletala ụmụ Izrel, ma hụkwa ahụhụ ha. Ha kpọrọ isiala fee ya ofufe. 
\c 5  
\s1 Mosis nʼihu Fero 
\p  
\v 1 Emesịa, Mosis na Erọn jekwuuru Fero guzo nʼihu ya gwa ya okwu sị, “Ihe a ka \nd Onyenwe anyị\nd*, Chineke Izrel kwuru, ‘Hapụ ndị m ka ha gaa meere m mmemme dị nsọ nʼime ọzara.’ ” 
\p  
\v 2 Fero zara sị, “Onye ka \nd Onyenwe anyị\nd* bụ m ga-eji gee ntị nʼolu ya ịhapụ ụmụ Izrel ka ha si nʼebe a pụọ? Amaghị m onye ọ bụ, agaghị m ekwekwa ka Izrel gaa ebe ọbụla.” 
\p  
\v 3 Ha zara sị, “Chineke ndị Hibru zutere anyị. Biko kwere ka anyị gaa njem ụbọchị atọ\f + \fr 5:3 \ft Nʼala Ijipt ehi na oke ehi bụ anụmanụ a na-ahụta ka ihe dị nsọ. Ya mere, ndị Izrel ji sị na ha ga-aga njem abalị atọ nʼime ọzara nọrọ nʼebe ahụ chụọrọ Onyenwe anyị aja.\f* nʼime ọzara nọọ nʼebe ahụ chụọrọ \nd Onyenwe anyị\nd* Chineke anyị aja. Ọ bụrụ na anyị ajụ ige ntị nʼolu ya, ọ ga-eji ọrịa ọjọọ maọbụ mma agha kpochapụ anyị.” 
\p  
\v 4 Eze Ijipt zara ha sị, “Mosis na Erọn, gịnị mere unu ji na-ewepụ ụmụ Izrel aka site nʼọrụ ha? Laghachinụ nʼọrụ unu!”  
\v 5 Fero gara nʼihu sị, “Lee, ka ndị obodo a si dị ọtụtụ ugbu a, ihe unu na-eme bụ naanị igbochi ha ịrụ ọrụ ha.” 
\p  
\v 6 Nʼụbọchị ahụ kwa, Fero nyere ndị nlekọta\f + \fr 5:6 \ft Ndị nlekọta ndị ohu na-arụ ọrụ bụ ndị Ijipt, ma ndịisi ndị ọrụ ahụ, bụ ndị Izrel.\f* ụmụ Izrel na ndị o mere ndịisi nʼebe ụmụ Izrel nọ iwu sị,  
\v 7 “Unu enyekwala ụmụ Izrel ahịhịa ha ga-eji kpụọ brik\f + \fr 5:7 \ft Brik bụ ụrọ a gwakọtara ya na okporo ọka. Ọ bụ okporo ọka ahụ e tinyere ya na-enye aka ime ka o sie ike mgbe a na-amị ya nʼanwụ. Nʼoge owuwe ihe ubi, a na-egbupụ elu okporo ọka, ma hapụ ogwe ya. Ọ bụ ogwe ya ahụ, ka ụmụ Izrel na-egburu, gwakọta ya nʼụrọ jiri ya kpụọ brik.\f* dịka unu na-eme nʼoge gara aga. Kama, ha ga-achọta ahịhịa ahụ nʼonwe ha.  
\v 8 Ọzọ, meenụ ka ọnụọgụgụ brik ha na-akpụ dịrị ka ọ dị na mbụ, unu emela ka ọ dịrị ala. Ha bụ ndị umengwụ. Ọ bụ ya mere ha ji na-eti mkpu, ‘Ka anyị gaa nʼọzara gaa chụọrọ Chineke anyị aja.’  
\v 9 Nyenụ ha ọrụ dị ike, nke ga-ezi ha na ha ekwesighị ịṅa ntị nʼokwu ụgha Mosis na Erọn na-ekwuru ha.” 
\p  
\v 10 Ndị na-achị ndị ohu na ndị nlekọta jekwuuru ụmụ Izrel sị ha, “Ihe a ka Fero kwuru: ‘Agaghị m enyekwa unu ahịhịa ọzọ.  
\v 11 Gaanụ chọtara onwe unu okporo ahịhịa ebe ọbụla unu nwere ike ịchọta ya, ma nke a agaghị eme ka e gbubilata ọrụ unu kwesiri ịrụ.’ ”  
\v 12 Ya mere ndị ha gbasasịrị nʼala Ijipt niile ịchịkọta okporo ahịhịa ha ji akpụ brik.  
\v 13 Ndị na-achị ha nọgidere na-akwagide ha sị ha, “Rụchaanụ ọrụ unu kwesiri ịrụ nʼụbọchị dịka unu si arụ ya mgbe a na-enye unu ahịhịa.”  
\v 14 Ndịisi ọrụ Fero malitere iti ndị Izrel ha họpụtara maka inyere ha aka ilekọta ndị ọrụ ihe, na-ajụ ha ajụjụ sị, “Gịnị mere unu akpụtaghị oke ọnụọgụgụ brik unu kwesiri ịkpụta ụnyaahụ maọbụ taa?” 
\p  
\v 15 Mgbe ahụ, ndịisi ọrụ ndị Izrel bịakwutere Fero kwaara ya akwa sị ya, “Gịnị mere i ji si otu a na-emeso ndị ohu gị mmeso?  
\v 16 Ọ dịghị okporo ahịhịa a na-enye ndị ohu gị, ma ha na-asị anyị, ‘Kpụọnụ brik!’ A na-etikwa ndị ohu gị ihe, ma ịta ụta ekwesighị ịdịrị anyị kama ịta ụta dịrị ndị gị.” 
\p  
\v 17 Fero zaghachiri ha sị, “Ndị umengwụ! Nʼezie ndị umengwụ ka unu bụ. Ọ bụ ya mere unu ji nọgide na-asị, ‘Ka anyị gaa chụọrọ \nd Onyenwe anyị\nd* aja.’  
\v 18 Laghachinụ azụ ugbu a nʼọrụ unu. A gaghị enye unu okporo ahịhịa ọbụla. Ma unu ga-arụpụtarịrị ọnụọgụgụ brik dị ka a chọrọ nʼaka unu.” 
\p  
\v 19 Ndịisi ọrụ ụmụ Izrel ghọtara na ha nọ na nsogbu mgbe a gwara ha okwu sị ha, “Unu ga-akpụtarịrị ọnụọgụgụ brik unu kwesiri ịkpụ kwa ụbọchị.”  
\v 20 Mgbe ha si nʼihu Fero pụọ, ha zutere Mosis na Erọn ebe ha nọ na-eche ha.  
\v 21 Ndị nlekọta ọrụ ndị a gwara Mosis na Erọn okwu sị, “Ka \nd Onyenwe anyị\nd* lee unu anya ma kpee unu ikpe. Unu emeela ka anyị bụrụ ihe na-esi ajọ isi nʼihu Fero na ndị na-ejere ya ozi. Unu etinyela mma agha nʼaka ha nke ha ga-eji gbuo anyị.” 
\s1 Nkwa mgbapụta nke Chineke kwere 
\p  
\v 22 Mgbe ahụ Mosis laghachikwuru \nd Onyenwe anyị\nd* jụọ ya sị, “Onyenwe anyị, gịnị mere i ji butere ndị a nsogbu? Gịnị mere i ji zite m?  
\v 23 Nʼihi na site na mgbe m jekwuuru Fero gwa ya okwu nʼaha gị, o meela ka nsogbu dakwasị ndị a, ma ị napụtabeghị ndị gị.” 
\c 6  
\p  
\v 1 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị, “Ugbu a, ị ga-ahụ ihe m ga-eme Fero. Nʼihi ike aka m, ọ ga-ezipụ ha. Nʼihi ike aka, ọ ga-achụpụ ha site nʼala ya.” 
\p  
\v 2 Chineke gara nʼihu gwa Mosis sị, “Mụ onwe m bụ \nd Onyenwe anyị\nd*.”  
\v 3 Egosiri m Ebraham na Aịzik na Jekọb onwe m dịka Chineke, Onye pụrụ ime ihe niile. Ma ọ dịghị mgbe m mere ka ha mata aha m dịka \nd Onyenwe anyị\nd*.  
\v 4 Emere m ka ọgbụgba ndụ m guzosie ike nʼetiti mụ na ha, ọgbụgba ndụ nke inye ha ala Kenan ebe ha biri dịka ndị ọbịa.  
\v 5 Ugbu a, anụla m ịsụ ude ụmụ Izrel, bụ ndị ahụ ndị Ijipt mere ka ha bụrụ ndị ohu. Echetakwala m ọgbụgba ndụ m. 
\p  
\v 6 “Ya mere, gwa ụmụ Izrel, ‘Abụ m \nd Onyenwe anyị\nd*. Aga m akpọpụta unu site nʼọnọdụ ịbụ ohu ndị Ijipt. Aga m eme ka unu nwere onwe unu site nʼọnọdụ ịbụ ndị ohu nye ha. Aga m eji aka ike m nke m ga-esetipụ, ya na ihe ngosipụta dị ukwuu nke ikpe ikpe m, gbapụta unu.  
\v 7 Mgbe ahụ, aga m ewere unu ka unu bụrụ ndị m. Aga m abụ Chineke unu. Unu ga-amata na m bụ \nd Onyenwe anyị\nd*, onye kpọpụtara unu site nʼaka ịbụ ohu nʼala Ijipt.  
\v 8 Aga m akpọbata unu nʼala ahụ m weliri aka m elu, ṅụọ nʼiyi, nye Ebraham, na Aịzik, na Jekọb, ime ka ọ bụrụ ihe nketa unu. Abụ m \nd Onyenwe anyị\nd*.’ ” 
\p  
\v 9 Mosis gwara ụmụ Izrel ihe ndị a, ma ha egeghị ntị nʼihi ịda mba nke obi ha na ahụhụ sitere na ndọgbu nʼọrụ ha. 
\p  
\v 10 \nd Onyenwe anyị\nd* gwara Mosis okwu ọzọ sị,  
\v 11 “Gaa gwa Fero eze Ijipt, ka ọ hapụ ụmụ Izrel ka ha pụọ nʼala ya.” 
\p  
\v 12 Mosis kwuru nʼihu \nd Onyenwe anyị\nd* sị, “Mgbe ụmụ Izrel na-aṅaghị m ntị, olee otu Fero ga-esi ṅaa m ntị? Nke ka nke, enweghị m ike ikwu okwu nke ọma.” 
\s1 Agbụrụ Mosis na Erọn 
\p  
\v 13 \nd Onyenwe anyị\nd* gwara Mosis na Erọn okwu banyere ụmụ Izrel na banyere Fero eze Ijipt. O nyere ha iwu sị ha site nʼala Ijipt kpọpụta ụmụ Izrel. 
\b  
\li4  
\v 14 Ndị a bụ aha ndịisi ebo Izrel niile. 
\b  
\li1 Ụmụ ndị ikom Ruben, ọkpara Izrel bụ, 
\li2 Hanok na Palu, Hezrọn na Kami. 
\li4 Ndị a bụ agbụrụ Ruben. 
\b  
\li1  
\v 15 Ụmụ ndị ikom Simiọn bụ, 
\li2 Jemuel, Jamin, Ohad, Jakin, Zoha na Shaul (onye nne ya bụ onye Kenan). 
\li4 Ndị a bụ agbụrụ Simiọn. 
\b  
\li1  
\v 16 \f + \fr 6:16 \ft Nʼusoro ọmụmụ a, ọ bụ naanị ndị ikom atọ e buru ụzọ mụọ ka a kpọrọ aha. Mosis na Erọn so na ndị ikom atọ Amram bụ ụzọ mụta.\f*Ndị a bụ ụmụ ndị ikom Livayị nʼusoro e si mụọ ha: 
\li2 Geshọn, Kohat na Merari. 
\li4 Livayị nʼonwe ya gbara narị afọ na iri afọ atọ na asaa mgbe ọ nwụrụ. 
\li2  
\v 17 Ụmụ ndị ikom Geshọn, nʼagbụrụ ha, 
\li3 bụ Libni na Shimei, nʼusoro ezinaụlọ ha. 
\li2  
\v 18 Ụmụ ndị ikom Kohat bụ, 
\li3 Amram, Izha, Hebrọn na Uziel. 
\li2 Kohat gbara narị afọ na iri afọ atọ na atọ mgbe ọ nwụrụ. 
\li2  
\v 19 Ụmụ ndị ikom Merari bụ 
\li3 Mahali na Mushi. 
\li4 Ndị a niile si nʼagbụrụ Livayị, dịka ihe e dere banyere ha si dị. 
\b  
\li1  
\v 20 Amram lụrụ Jokebed, nwanne nna ya. Erọn na Mosis bụ ụmụ ha ndị ikom. 
\li4 Ma Amram gbara narị afọ na iri afọ atọ na asaa mgbe ọ nwụrụ. 
\li1  
\v 21 Ụmụ ndị ikom Izha bụ 
\li2 Kora, Nefeg na Zikri. 
\li1  
\v 22 Ụmụ ndị ikom Uziel bụ, 
\li2 Mishael, Elzafan na Sitri. 
\li1  
\v 23 Erọn lụrụ Elisheba, nwa Aminadab, na nwanne nwanyị Nashọn. Ụmụ ha bụ, Nadab, na Abihu, Elieza na Itama. 
\b  
\li1  
\v 24 Ụmụ ndị ikom Kora bụ, 
\li2 Asịa, Elkena na Abiasaf. 
\li4 Ndị a bụ ndị ikwu Kora. 
\b  
\li1  
\v 25 Elieza, nwa Erọn lụrụ otu nʼime ụmụ Putiel, onye mụtaara ya Finehaz. 
\b  
\li4 Ndị a bụ aha ndịisi ezinaụlọ Livayị dịka ikwu ha si dị. 
\b  
\p  
\v 26 Ọ bụkwa Mosis na Erọn ka \nd Onyenwe anyị\nd* gwara okwu sị, “Sitenụ nʼala Ijipt dupụta ụmụ Izrel dịka ọnụọgụgụ ha si dị.”  
\v 27 Ha bụ ndị gwara Fero, eze Ijipt okwu banyere ime ka ụmụ Izrel site nʼala Ijipt pụọ. Ọ bụkwa otu Mosis na Erọn ahụ. 
\s1 Erọn ga-ekwuchitere Mosis ọnụ ya 
\p  
\v 28 Otu ụbọchị, \nd Onyenwe anyị\nd* gwara Mosis okwu nʼIjipt,  
\v 29 ọ sịrị ya, “Mụ onwe m bụ \nd Onyenwe anyị\nd*, gaa gwa Fero eze Ijipt ihe niile m gwara gị.” 
\p  
\v 30 Mosis kwuru nʼihu \nd Onyenwe anyị\nd* sị, “Lee, abụ m onye na-adịghị ekwuzi okwu nke ọma, gịnị mere Fero ga-eji gee ntị nʼihe m ga-agwa ya?” 
\c 7  
\s1 Ihe ịrịbama dị iche iche 
\p  
\v 1 Mgbe ahụ \nd Onyenwe anyị\nd* gwara Mosis okwu sị, “Emeela m gị ka ị dịrị ka Chineke nʼebe Fero nọ. Nwanne gị Erọn ga-abụkwa onye amụma gị.\f + \fr 7:1 \ft Nke a pụtara, ga-abụ ọnụ na-ekwuru gị\f* 
\v 2 Ị ga-agwa Erọn ihe niile m gwara gị. Ọ ga-ekwukwa ha nʼihu Fero, rịọọ ya ka o kwere ka ụmụ Izrel hapụ ala Ijipt.  
\v 3 Ma aga m eme ka obi Fero sie ike. Ọ bụ ezie na m ga-eme ọtụtụ ihe ịrịbama nʼihe ebube nʼala Ijipt,  
\v 4 ma Fero agaghị ege unu ntị. Mgbe ahụ aga m eme ka aka m bịakwasị Ijipt. Aga m esite nʼoke ọrụ nke ikpe ọmụma dị oke egwu, mee ka ndị m, Izrel, dịka usuu ha niile si dị, site nʼala Ijipt pụọ.  
\v 5 Ndị Ijipt ga-amata nʼezie na m bụ \nd Onyenwe anyị\nd*, mgbe m setịpụrụ aka nʼIjipt, ma site nʼetiti ha kpọpụta ụmụ Izrel.” 
\p  
\v 6 Mosis na Erọn mere dịka \nd Onyenwe anyị\nd* nyere ha iwu.  
\v 7 Nʼoge a, mgbe ha gwara Fero okwu, Mosis agbaala iri afọ asatọ. Ma Erọn agbaala iri afọ asatọ na atọ. 
\s1 Mkpanaka Erọn aghọọ agwọ 
\p  
\v 8 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis na Erọn sị,  
\v 9 “Mgbe Fero ga-agwa unu okwu sị, ‘Meenụ ihe ebube.’ Ị ga-agwa Erọn okwu sị ya, ‘Were mkpanaka gị tụpụ ya nʼala nʼihu Fero.’ Ọ ga-aghọ agwọ.” 
\p  
\v 10 Mgbe ahụ, Mosis na Erọn jekwuuru Fero mee dịka Onyenwe anyị nyere ha nʼiwu. Erọn tụpụrụ mkpanaka ya nʼala nʼihu Fero na ndị ozi ya. Ọ ghọrọ agwọ.  
\v 11 Ma Fero kpọkọtara ndị maara ihe, na ndị mgbaasị, na ndị majiki nọ nʼIjipt. Ha bịara mee ụdị ihe ịrịbama ahụ Mosis na Erọn mere site nʼihe nzuzo nke akaọrụ ha.  
\v 12 Onye ọbụla nʼime ha tụpụrụ mkpanaka ya, nke ghọkwara agwọ. Ma mkpanaka ahụ Erọn tụpụrụ, nke ghọrọ agwọ, loro mkpanaka ndị ahụ niile ndị Ijipt tụpụrụ.  
\v 13 Fero nyịchiri obi ya, mee ka o sie ike. O geghị Erọn na Mosis ntị dịka Onyenwe anyị kwuru. 
\s1 Mmiri aghọọ ọbara 
\p  
\v 14 \nd Onyenwe anyị\nd* gwara Mosis sị, “Obi Fero siri ike. Ọ bụ nke a mere o ji na-aga nʼihu na-ajụ ka ndị m laa.  
\v 15 Ma otu ọ dị; nʼisi ụtụtụ echi, jekwuru Fero tupu ọ gaa nʼosimiri.\f + \fr 7:15 \ft Ndị Fero na-aga nʼosimiri Naịl ụtụtụ ụbọchị niile, nʼihi ikpe ekpere nye chi Naịl, onye ha weere ka nna chi niile. Ya mere, mmadụ ime ihe ọbụla ga-emetụta osimiri Naịl dịka onye ahụ ịmetụ aka na mkpụrụobi ndị Ijipt. Nʼihi na ha kwenyere na ihe ọbụla mee osimiri Naịl, nʼala Ijipt ga-aghọ ọzara.\f* Guzoro nʼakụkụ osimiri Naịl, jidekwa mkpanaka ahụ ghọrọ agwọ nʼaka gị.  
\v 16 Ị ga-agwa Fero sị, ‘\nd Onyenwe anyị\nd*, Chineke ndị Hibru, ezitela m ka m gwa gị sị, hapụ ndị m ka ha gaa nʼọzara fee m ofufe. Tutu ruo ugbu a, ị jụrụ ige ntị.’  
\v 17 Ugbu a \nd Onyenwe anyị\nd* kwuru nke a sị, ‘Ị ga-amata site na nke a na mụ onwe m bụ \nd Onyenwe anyị\nd*. Aga m ewere mkpanaka a nke m ji nʼaka tie nʼosimiri Naịl. Ọ ga-agbanwe ghọọ ọbara.  
\v 18 Azụ niile dị nʼime ya ga-anwụ. Osimiri ahụ ga-esikwa isi dịka ihe rere ure. Nke a ga-eme ka ọ bụrụ ihe rara ahụ nye ndị Ijipt ịṅụ mmiri site na ya.’ ” 
\p  
\v 19 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis sị ya, “Gwa Erọn ka o setịpụ mkpanaka ya nʼelu mmiri niile dị nʼIjipt. Nke a metụtara osimiri ha niile, mmiri ntakịrị ha niile, ọdọ mmiri ha niile, na ebe niile ha na-echekọta mmiri. Ọbara ga-ejupụta ebe niile nʼIjipt, ite mmiri na ite aja na ite osisi niile.” 
\p  
\v 20 Mosis na Erọn mere dị ka \nd Onyenwe anyị\nd* nyere ha nʼiwu ime. Nʼihu Fero na ndịisi ọrụ ya, Erọn weliri mkpanaka ya tie ya nʼelu mmiri dị nʼosimiri Naịl. Nʼotu ntabi anya, mmiri ahụ gbanwere ghọọ ọbara.  
\v 21 Ka azụ dị nʼime mmiri Naịl nwụsịrị, mmiri ahụ malitere na-esi isi ọjọọ, nke mere ka ndị Ijipt hapụ inwe ike ịṅụ mmiri sitere na ya. Ọbara jupụtakwara nʼala Ijipt niile. 
\p  
\v 22 Ma ndị majiki Ijipt jikwa ihe nzuzo ha mee ka mmiri chaa ọbara ọbara.\f + \fr 7:22 \ft Ihe ịrịbama (ọrịa na-efe efe) niile ndị a dị iche iche gosipụtara ike Chineke nʼebe ihe niile e kere eke dị, karịchasịa nʼebe ihe e kere eke nke ndị mmadụ na-efe dịka chi. Ọ bụ nʼetiti ọnwa mbụ nʼafọ ruo nʼọnwa anọ ka ihe ịrịbama niile ndị ahụ mere.\f* Nke a mere ka Fero nyịchie obi ya. Ọ ṅaghị Mosis na Erọn ntị, dịka \nd Onyenwe anyị\nd* gwara ha na ọ ga-eme.  
\v 23 Fero tụgharịrị laghachi nʼụlọeze ya, na-echeghị echiche banyere ihe niile ahụ e mere.  
\v 24 Ya mere, ndị Ijipt niile gwuru olulu mmiri nʼakụkụ osimiri ahụ ịchọ mmiri ọṅụṅụ ebe ha na-enweghị ike ịṅụ mmiri sitere nʼosimiri Naịl. 
\s1 Awọ ejupụta nʼala Ijipt 
\p  
\v 25 Ụbọchị asaa gasịrị, site nʼụbọchị \nd Onyenwe anyị\nd* tichara ihe otiti ahụ na Naịl. 
\c 8  
\nb  
\v 1 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis sị, “Jekwuru Fero gwa ya, ‘Nke a bụ ihe \nd Onyenwe anyị\nd* kwuru. Hapụ ndị m, ka ha gaa fee m ofufe.  
\v 2 Ọ bụrụ na ị jụ ịhapụ ha ka ha gaa, aga m eme ka awọ jupụta nʼala Ijipt niile.  
\v 3 Osimiri Naịl ga-ejupụta nʼawọ. Ha ga-abata nʼụlọeze gị na nʼime ọnụụlọ ndina gị, ma nʼelu ihe ndina gị, ma nʼụlọ ndị na-ejere gị ozi, ma nʼụlọ ndị gị niile, na nʼebe a na-esi nri, ma nʼime ihe e ji agwakọta ụtụ ọka.  
\v 4 Awọ ndị a ga-arịgokwa nʼahụ gị, na nʼahụ ndị gị, na nʼahụ ndị na-ejere gị ozi.’ ” 
\p  
\v 5 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis sị, “Gwa Erọn, ‘Setịpụ aka gị ya na mkpanaka gị nʼelu osimiri niile, na mmiri nta na ọdọ mmiri ndị Ijipt, mee ka awọ jupụta ala Ijipt niile.’ ” 
\p  
\v 6 Erọn setịpụrụ aka nʼelu mmiri niile nke Ijipt, awọ pụtara kpuchie ala ahụ niile.  
\v 7 Ma ndị majiki Ijipt jikwa ihe nzuzo ha mee ihe ahụ Mosis na Erọn mere. Ha mekwara ka awọ jupụta ala ahụ niile. 
\p  
\v 8 Fero kpọrọ Mosis na Erọn rịọọ ha sị, “Rịọọnụ \nd Onyenwe anyị\nd* ka o wepụrụ mụ na ndị m awọ ndị a. Emesịa aga m ekwe ka ndị gị gaa chụọrọ \nd Onyenwe anyị\nd* aja.” 
\p  
\v 9 Mosis zaghachiri Fero sị, “Gị ka ọ dịrị ịgwa m mgbe m ga-arịọ arịrịọ a nʼisi gị na nʼisi ndị gị, ka e wezuga awọ ndị a site nʼụlọ unu, ma hapụ naanị ndị nọ nʼosimiri Naịl.” 
\p  
\v 10 Mgbe ahụ Fero sịrị Mosis, “Achọrọ m ka i mee ya echi.” 
\p Mosis zaghachiri Fero sị, “Ọ dị mma, ka ọ dịrị dịka i kwuru. Mgbe ahụ, ị ga-amata na o nweghị onye dịka \nd Onyenwe anyị\nd* Chineke anyị.  
\v 11 Awọ ndị a niile ga-apụ site nʼebe ị nọ, na site nʼụlọ gị na site nʼụlọ ndị na-ejere gị ozi na site nʼụlọ ndị Ijipt niile. Ọ bụ naanị nʼosimiri Naịl ka ha ga-anọ.” 
\p  
\v 12 Mgbe Mosis na Erọn sitere nʼụlọ Fero pụọ, Mosis kpọkuru \nd Onyenwe anyị\nd* ka o wepụ awọ ndị a o mere ka ha bịakwasị Fero.  
\v 13 \nd Onyenwe anyị\nd* mere ihe Mosis rịọrọ. Awọ ndị ahụ niile nwụrụ nʼime ụlọ, na nʼama, na nʼọhịa.  
\v 14 E kpokọtara ozu awọ ndị a niile nʼebe dị iche iche. Isi ọjọọ ha wetara nʼala ahụ dị egwu.  
\v 15 Ma mgbe Fero hụrụ na awọ ndị a anwụchaala, o mechiri obi ya jụ ige Mosis na Erọn ntị, dịka \nd Onyenwe anyị\nd* kwuru na ọ ga-eme. 
\s1 Ụmụ ndanda nta na-efe efe ejupụta ala Ijipt 
\p  
\v 16 Ya mere, \nd Onyenwe anyị\nd* gwara Mosis sị ya, “Gwa Erọn, setịpụ mkpanaka gị, tie nʼaja nke ala nʼala Ijipt niile, aja ya ga-aghọ anwụ nta nke na-ata ata.”  
\v 17 Mosis na Erọn mere nke a. Mgbe Erọn setịpụrụ aka tie mkpanaka ya nʼelu ala, anwụ nta jupụtara nʼala Ijipt niile, nʼahụ ndị mmadụ, na nʼahụ anụmanụ ha. Ndanda ndị a jupụtakwara nʼuzuzu niile dị nʼala ahụ.  
\v 18 Ndị Ijipt na-eme majiki gbalịrị iji ihe nzuzo ha mee otu ihe ahụ Erọn mere, ma ha enweghị ike ime ka anwụ nta ọbụla pụta. 
\p Ebe ọ bụ na anwụ nta ndị a jupụtara nʼahụ mmadụ na nʼahụ anụmanụ niile.  
\v 19 Naanị ihe ndị na-eme majiki gwara Fero bụ, “Nke a bụ akaọrụ Chineke.” Ma Fero mere ka obi ya sie ike. Ọ chọghị ige, ọ bụladị ndị majiki ya ntị, dịka \nd Onyenwe anyị\nd* kwuru na ọ ga-eme. 
\s1 Usuu ijiji ejupụta ala Ijipt 
\p  
\v 20 \nd Onyenwe anyị\nd* gwara Mosis sị ya, “Bilie nʼisi ụtụtụ echi jekwuru Fero. Mgbe ọ ga-aga nʼosimiri,\f + \fr 8:20 \ft Eleghị anya ọ na-aga ịsa ahụ\f* gwa ya okwu sị, ‘Nke a bụ ihe \nd Onyenwe anyị\nd* kwuru, Hapụ ndị m ka ha gaa fee m ofufe.  
\v 21 Ọ bụrụ na ị chọghị ime otu a, aga m eme ka igwe ijiji jupụta nʼala Ijipt niile. Ha ga-ejupụta gị nʼahụ na nʼahụ ndị na-ejere gị ozi, na nʼahụ ndị gị niile, na nʼime ụlọ unu niile. 
\p  
\v 22 “ ‘Nʼụbọchị ahụ, igwe ijiji ndị a agaghị emetụ ndị nọ na Goshen ebe ndị m bi. Mgbe ahụ ka ị ga-amata na mụ bụ \nd Onyenwe anyị\nd* bịara ije nʼala a.  
\v 23 Aga m emekwa ka ọ pụta ìhè na o nwere ihe dị iche nʼetiti ndị m na ndị gị. Ihe ịrịbama a ga-emezukwa echi.’ ” 
\p  
\v 24 Nʼechi ya, \nd Onyenwe anyị\nd* mere dịka o kwuru. Igwe ijiji dị egwu nʼọnụọgụgụ bịara nʼala Ijipt, jupụta nʼụlọ Fero, na nʼụlọ ndị niile na-ejere ya ozi, na nʼala Ijipt niile. E mere ka ala Ijipt bụrụ ihe e ji ijiji mebie. 
\p  
\v 25 Mgbe ihe ndị a na-eme, Fero kpọrọ Mosis na Erọn gwa ha okwu sị, “Gaanụ chụọrọ Chineke unu aja, ma ka ọ bụrụ nʼala Ijipt.” 
\p  
\v 26 Mosis zaghachiri Fero sị, “Nke ahụ abụghị ihe ziri ezi, nʼihi na aja anyị na-aga ịchụrụ \nd Onyenwe anyị\nd* Chineke anyị bụ ihe rụrụ arụ nʼanya ndị Ijipt. Ọ bụrụ na anyị achụọ aja a nʼihu ha, ha ga-eji nkume tugbuo anyị.  
\v 27 Anyị ga-aga njem ụbọchị atọ nʼime ọzara gaa chụọrọ \nd Onyenwe anyị\nd* Chineke anyị aja, dịka o nyere anyị iwu ka anyị mee.” 
\p  
\v 28 Fero zaghachiri ha sị, “Aga m ekwenye ka unu ga chụọrọ \nd Onyenwe anyị\nd* Chineke unu aja nʼọzara, ma unu agaghị aga ebe dị anya. Ugbu a, kperenụ m ekpere.” 
\p  
\v 29 Mosis zara Fero sị ya, “Ngwangwa m si nʼihu gị pụọ, aga m arịọ \nd Onyenwe anyị\nd* arịrịọ. Echi, a ga-esite nʼụlọ Fero, na nʼụlọ ndị na-ejere ya ozi, na nʼụlọ ndị Ijipt niile wezuga ijiji ndị a. Ọ ga-adị mkpa na Fero ga-elezi anya hapụ ịghọ aghụghọ ọzọ site ịjụ ka ụmụ Izrel gaa chụọrọ \nd Onyenwe anyị\nd* aja.” 
\p  
\v 30 Mgbe ahụ, Mosis sitere nʼihu Fero pụọ rịọọ \nd Onyenwe anyị\nd* ka o mee ka ijiji ndị a gabiga.  
\v 31 \nd Onyenwe anyị\nd* mere dịka Mosis rịọrọ. Ijiji ndị a sitere nʼụlọ Fero na ụlọ ndị na-ejere ya ozi na ụlọ ndị Ijipt niile pụọ. O nwekwaghị ijiji ọ bụla fọdụrụ nʼala ahụ.  
\v 32 Ma nʼoge a, Fero gara nʼihu ime ka obi ya sie ike. O kweghị ka ụmụ Izrel laa. 
\c 9  
\s1 Ọrịa metụtara ụmụ anụ ụlọ 
\p  
\v 1 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis sị ya, “Jekwuru Fero sị ya. ‘Nke a bụ ihe \nd Onyenwe anyị\nd* Chineke ndị Hibru kwuru, “Hapụ ndị m ka ha gaa fee m.”  
\v 2 Ọ bụrụ na ị jụ, ma gaa nʼihu igbochi ha,  
\v 3 aka \nd Onyenwe anyị\nd* ga-ewebata oke ọrịa na-efe efe nke ga-abịakwasị igwe anụ ụlọ unu niile dị nʼubi. Ya bụ, ịnyịnya unu, na ịnyịnya ibu unu, na ịnyịnya kamel unu, na ehi unu, na atụrụ unu na ewu unu.  
\v 4 \nd Onyenwe anyị\nd* ga-akpa oke nʼetiti anụ ụlọ ndị Ijipt na nke ndị Izrel. Nʼihi ya, o nweghị anụ ụlọ ọbụla si nʼetiti anụ ụlọ ndị Izrel ga-anwụ.’ ” 
\p  
\v 5 \nd Onyenwe anyị\nd* ekwuola oge nke a ga-amalite sị, “Echi ka \nd Onyenwe anyị\nd* ga-eme ihe dị otu a nʼala a.”  
\v 6 Nʼụtụtụ echi ya, \nd Onyenwe anyị\nd* mere dịka o kwuru. Igwe anụ ụlọ niile dị nʼIjipt nwụrụ. Ma ọ dịghị otu nʼime anụ ụlọ ụmụ Izrel nwụrụ.  
\v 7 Mgbe ahụ Fero zipụrụ ndị mmadụ ndị gara chọpụta na o nweghị otu nʼime anụ ụlọ ụmụ Izrel nwụrụ. Ma ọ bụladị mgbe ọ chọpụtara na nke a bụ eziokwu, ọ gbanweghị obi ya, ọ nọgidere jụ ikwe ka ndị Izrel laa. 
\s1 Ọrịa etuto 
\p  
\v 8 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis na Erọn sị, “Sitenụ nʼekwu e ji esi nri kporo ntụ nke Mosis ga-awụli elu nʼihu Fero.  
\v 9 Ntụ ahụ ga-efesasị, dịka uzuzu nʼala Ijipt niile. Ọ ga-ebute etuto nke ga-aghọ ọnya nʼahụ ndị mmadụ na ụmụ anụmanụ dị iche iche dị nʼala ahụ niile.” 
\p  
\v 10 Mosis na Erọn kpooro ntụ gaa guzo nʼihu Fero. Mgbe Fero nọ na-ele anya Mosis wụliri ntụ ahụ elu. Ọ ghọrọ etuto, nke gbawara ghọọ ọnya nʼahụ ụmụ mmadụ na ụmụ anụmanụ niile.  
\v 11 Ndị majiki Ijipt enweghị ike iguzo\f + \fr 9:11 \ft Ihe otiti ọrịa, bụ ihe ịrịbama ndị mbụ, metụtara naanị ihe ndị ahụ niile nke ndị Ijipt na-efe dịka chi. Ma ihe otiti ọrịa nke ugbu a, metụtara ndị majiki Ijipt dịka ihe ịdọ aka na ntị, ka ha gharakwa ị bịaghachi nʼihi imaa Mosis aka nʼihu.\f* nʼihu Mosis, nʼihi etuto ndị jupụtara ha nʼahụ dịka ọ dị nʼahụ ndị Ijipt ndị ọzọ.  
\v 12 Ma \nd Onyenwe anyị\nd* mere ka obi Fero sie ike. Ọ jụrụ ige Mosis na Erọn ntị dịka \nd Onyenwe anyị\nd* gwara Mosis na ọ ga-eme. 
\s1 Mkpụrụ mmiri a 
\p  
\v 13 \nd Onyenwe anyị\nd* gwara Mosis ọzọ sị, “Bilie nʼisi ụtụtụ echi gaa gwa Fero okwu sị ya, ‘Nke a bụ ihe \nd Onyenwe anyị\nd* Chineke ndị Hibru kwuru, Hapụ ndị m ka ha gaa fee m ofufe.  
\v 14 Ma ọ bụghị ya, nʼoge a, aga m ezite ọrịa ọjọọ niile nke na-efe efe, ka ha bịakwasị gị, na ndị na-ejere gị ozi, na ndị Ijipt niile. Nke a ga-eme ka unu ghọta na ọ dịghị Onye ọzọ dịka m nʼelu ụwa niile.  
\v 15 Nʼihi na tupu oge a, agaara m esetipụ aka m, jiri ajọ ọrịa tie gị na ndị gị niile nke ga-egbuchapụ unu site nʼelu ụwa.  
\v 16 Ma ọ bụ nʼihi nke a ka m ji guzobe gị, ka m gosipụta ike m nʼebe ịnọ, ka e nwe ike kwusaa aha m nʼụwa niile.  
\v 17 Ma ị nọ na-ebuli onwe gị elu megide ndị m, jụ na ha agaghị ala.  
\v 18 Ya mere, nʼoge dịka oge a echi, aga m ezipu oke ifufe nke ya na akụmmiri igwe so nʼala Ijipt niile. Ụdị ifufe a adịbeghị mbụ nʼala Ijipt, malite nʼoge a tọrọ ntọala ya rute ugbu a.  
\v 19 Ya mere, nye iwu ka a gaa ngwangwa nʼubi unu webata anụ ụlọ unu na ihe ndị ọzọ unu nwere nʼebe a ga-echebe ha, nʼihi na oke ifufe nke ya na mkpụrụ mmiri so ga-egbu mmadụ na anụ ụlọ ọbụla a hapụrụ nʼezi.’ ” 
\p  
\v 20 Ụfọdụ ndị na-ejere Fero ozi, ndị na-atụ okwu \nd Onyenwe anyị\nd* egwu mere ngwangwa gaa dulata anụ ụlọ ha, na ndị ohu ha.  
\v 21 Ma ndị ahụ na-enweghị nrube isi nye okwu \nd Onyenwe anyị\nd* hapụrụ ndị ohu ha nakwa anụ ụlọ ha nʼọhịa. 
\p  
\v 22 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis, “Setịpụ aka gị nʼeluigwe. Nke a ga-eme ifufe nke ya na mkpụrụ mmiri so malite izokwasị ala Ijipt niile, na ụmụ mmadụ, na anụmanụ, na ihe niile a kụrụ nʼubi nʼIjipt.”  
\v 23 Mgbe Mosis setịpụrụ mkpanaka ya nʼihu eluigwe, \nd Onyenwe anyị\nd* zidatara egbe eluigwe na oke ifufe nke ya na mkpụrụ mmiri so. Amụma egbe eluigwe chakwara nʼala. Ya mere, \nd Onyenwe anyị\nd* zidatara oke ifufe nke ya na mkpụrụ mmiri so nʼala Ijipt.  
\v 24 Mkpụrụ mmiri dara, amụma gbukwara nʼihu nakwa nʼazụ. Nʼezie, ọ bụ oke ifufe dị njọ, ụdị nke a na-ahụtụbeghị nʼala Ijipt kemgbe ọ ghọrọ nnukwu mba.  
\v 25 Mkpụrụ mmiri ahụ tigburu ihe niile dị nʼọhịa, ma mmadụ ma anụmanụ niile dị nʼala Ijipt. O feturu ihe niile na-epu nʼubi, ma ahịhịa niile dị nʼosisi.  
\v 26 Ma akụkụ ebe mkpụrụ mmiri ndị a na-erughị bụ naanị Goshen, ebe ụmụ Izrel bi. 
\p  
\v 27 Mgbe ahụ Fero ziri ozi ka a kpọ Mosis na Erọn. O kwupụtara nʼihu ha sị, “Nʼoge a, emehiela m. \nd Onyenwe anyị\nd* bụ onye ezi omume, mụ na ndị m bụ ndị mejọrọ.  
\v 28 Kpee ekpere rịọọ \nd Onyenwe anyị\nd* nʼihi na oke mkpụrụ mmiri na egbe eluigwe a ezuola. Aga m ekwe ka unu gaa, unu agaghị atụfukwa mgbe.” 
\p  
\v 29 Mosis gwara Fero sị ya, “Mgbe m si nʼobodo a pụọ, aga m esetipụ aka m nʼebe \nd Onyenwe anyị\nd* nọ, egbe eluigwe a, na ifufe a nke ya na mkpụrụ mmiri so ga-akwụsịkwa. Site na nke a, ị ga-amata na ụwa niile bụ nke \nd Onyenwe anyị\nd*.  
\v 30 Ma amaara m na gị onwe gị na ndị na-ejere gị ozi adịghị atụ \nd Onyenwe anyị\nd* Chineke egwu.” 
\p  
\v 31 Oke ifufe ahụ nke ya na mkpụrụ mmiri so mebiri ihe a kụrụ nʼubi, dịka flakisi na ọka balị. Nʼihi na nʼoge a, ọka balị emenyela isi, flakisi etojuokwala maa ifuru.  
\v 32 Ma ifufe na mmiri ukwu ahụ emebighị ọka wiiti na spelti, nʼihi na ha achabeghị. 
\p  
\v 33 Mosis hapụrụ Fero si nʼobodo ahụ pụọ. Ọ gbasapụrụ aka ya abụọ nʼihu \nd Onyenwe anyị\nd*, egbe eluigwe na mkpụrụ mmiri ahụ kwụsịrị. Mmiri ozuzo kwụsịkwara izo nʼala ahụ.  
\v 34 Mgbe Fero hụrụ na mmiri ozuzo na mkpụrụ mmiri na egbe eluigwe akwụsịla, o mehiere ọzọ. Ya na ndị na-ejere ya ozi gara nʼihu nyịchie obi ha.  
\v 35 Ya mere, Fero mere ka obi ya sie ike. Ọ jụrụ ikwere ka ụmụ Izrel pụọ, dịka \nd Onyenwe anyị\nd* gwararịị Mosis. 
\c 10  
\s1 Igurube ejupụta ala Ijipt 
\p  
\v 1 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya, “Jekwuru Fero nʼihi na emeela m ka obi ya, na obi ndị na-ejere ya ozi sie ike, ka m nwee ike rụọ ọrụ ịrịbama ndị a dị iche iche nʼetiti ha.  
\v 2 Nke a ga-abụ akụkọ unu ga-akọrọ ụmụ unu, na ụmụ ụmụ unu, banyere otu m si mesie ndị Ijipt ike, na otu m si rụọ ọrụ ịrịbama m nʼetiti ha, ime ka unu mata na m bụ \nd Onyenwe anyị\nd*.” 
\p  
\v 3 Ọzọ, Mosis na Erọn jekwuuru Fero gwa ya sị, “Nke a bụ ihe \nd Onyenwe anyị\nd* Chineke ndị Hibru kwuru, ‘Ọ bụ ruo olee mgbe ka ị ga-ajụ iwedata onwe gị ala nʼihu m? Hapụ ndị m ka ha gaa fee m ofufe.  
\v 4 Ọ bụrụ na ị jụ ikwere ka ha gaa, nʼụtụtụ echi, aga m ezite igurube nʼala Ijipt.  
\v 5 Igurube ndị a ga-ekpuchi ihu ala Ijipt niile, ka mmadụ ọbụla hapụ ịhụ ala anya. Ha ga-erichapụ ihe ndị fọdụrụ bụ nke ifufe na mkpụrụ mmiri ahụ na-emebighị, tinyere osisi niile na-eto eto nʼubi unu.  
\v 6 Ha ga-ejupụta nʼụlọ gị, na nʼụlọ ndị na-ejere gị ozi, na nʼụlọ ndị Ijipt niile. Ihe dị otu a bụ ụdị ihe na-emetụbeghị na mbụ, nke nna gị maọbụ nna nna gị ha na-ahụtụbeghị ụdị ya site na mgbe ha bidoro ibi nʼala a tutu ruo ugbu a.’ ” Mgbe ahụ, Mosis tụgharịrị hapụ Fero pụọ. 
\p  
\v 7 Ndị na-ejere Fero ozi bịakwutere ya, jụọ ya sị, “Ruo ole mgbe ka nwoke a ga-anọgide na-abụrụ anyị ihe ọnwụnwa? Hapụ ndị a ka ha laa, ka ha nwee ike ife \nd Onyenwe anyị\nd* Chineke ha ofufe. Ọ bụ na ị ghọtabeghị na e bibiela Ijipt?” 
\p  
\v 8 Mgbe ahụ, a kpọghachiri Mosis na Erọn azụ nʼihu Fero. Ọ gwara ha sị, “Ọ dị mma, gaa feenụ \nd Onyenwe anyị\nd* Chineke unu ofufe.” Fero jụkwara ha sị, “Olee ndị nʼetiti unu ga-eso unu jee?” 
\p  
\v 9 Mosis zaghachiri sị, “Anyị niile na-aga, ụmụntakịrị na ndị okenye, ụmụ anyị ndị ikom na ndị inyom, igwe ehi anyị na igwe ewu na atụrụ anyị; nʼihi na anyị na-aga ime mmemme dị nsọ nye \nd Onyenwe anyị\nd*.” 
\p  
\v 10 Fero sịrị, “Ka \nd Onyenwe anyị\nd* nọnyere unu. Ma agaghị m ekwe ka unu na ndị inyom unu, na ụmụntakịrị unu gaa. O doro anya na unu na-atụ atụmatụ ọjọọ nʼime obi unu.  
\v 11 Ọ gaghị adị otu a! Jeenụ naanị\f + \fr 10:11 \ft Nʼusoro ofufe chi ndị Ijipt, ọ bụ naanị ndị ikom na-ahụ ma na-emekwa ihe niile banyere ofufe, ndị inyom na ụmụntakịrị adịghị e sonyere ha. Ihe mere Fero ji na-ekwenyeghị na ndị inyom na ụmụntakịrị ha ga-eso gaa, bụ nʼihi ime ka ndị ikom ha nọgide nʼohu nʼala Ijipt.\f* unu bụ ndị ikom gaa fee \nd Onyenwe anyị\nd* unu ofufe, nʼihi na nke a bụ ihe unu na-arịọ.” Mgbe ahụ a chụpụrụ Mosis na Erọn site nʼihu Fero. 
\p  
\v 12 \nd Onyenwe anyị\nd* gwara Mosis sị, “Setịpụ aka gị nʼala Ijipt ka igurube jupụta na ya, kpuchie ebe niile, richapụ ihe niile na-eto eto dị nʼala ahụ bụ nke ifufe na mkpụrụ mmiri ahụ hapụrụ.” 
\p  
\v 13 Ya mere, Mosis setịpụrụ mkpanaka ya nʼelu ala Ijipt, \nd Onyenwe anyị\nd* mere ka ifufe nke si nʼebe anyanwụ si awa fee nʼụbọchị ahụ niile na abalị ahụ niile. Nʼụtụtụ ya, ifufe ahụ si nʼebe anyanwụ si awa bubatara igurube ndị ahụ.  
\v 14 Ha niile kpuchichara ala Ijipt niile, site nʼotu akụkụ ruo nʼakụkụ nke ọzọ. Nke a bụ mbata igurube kachasị ibe ya njọ nʼIjipt. Ijipt agaghị enwekwa nke dịka ya ọzọ.  
\v 15 Ha kpuchiri ala niile ruo mgbe ọchịchịrị gbachiri ya. Ha richapụrụ ihe niile na-eto nʼubi, na mkpụrụ niile na-amị nʼosisi, bụ nke ifufe na mkpụrụ mmiri ukwu ahụ hapụrụ. Nʼikpeazụ, ọ dịghị ahịhịa ndụ fọdụrụ nʼala ma nʼelu osisi nʼIjipt niile. 
\p  
\v 16 Na-atụfughị oge, Fero ziri ozi ka a kpọọ Mosis na Erọn. Mgbe ha bịara, ọ gwara ha sị, “Emehiela m megide unu na \nd Onyenwe anyị\nd* bụ Chineke unu.  
\v 17 Biko gbagharakwa m mmehie nke a, ma rịọọ \nd Onyenwe anyị\nd* bụ Chineke unu ka o wepụrụ m ọnwụ nke a. Ekwere m nkwa na agaghị m ajụkwa ọzọ ka unu laa.” 
\p  
\v 18 Mosis hapụrụ Fero pụọ gaa kpeere \nd Onyenwe anyị\nd* ekpere.  
\v 19 Ngwangwa, \nd Onyenwe anyị\nd* zitere ikuku nke si nʼebe anyanwụ na-ada bịa, nke bupụrụ igurube ndị ahụ site nʼala Ijipt, buba ha nʼOsimiri Uhie. Ọ dịkwaghị otu igurube fọdụrụ nʼala Ijipt niile.  
\v 20 Ma \nd Onyenwe anyị\nd* mere ka obi Fero sie ike, o kweghị ka ụmụ Izrel gaa fee Chineke ofufe. 
\s1 Ọchịchịrị nʼala Ijipt 
\p  
\v 21 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis sị, “Setịpụ aka gị abụọ nʼeluigwe ka ọchịchịrị gbaa nʼala Ijipt niile.”  
\v 22 Mosis setịpụrụ aka ya nʼeluigwe. Oke ọchịchịrị gbara abalị atọ nʼala Ijipt niile.  
\v 23 Ndị Ijipt ahụghị ihu ibe ha. Ha ahapụghịkwa ebe obibi ha abalị atọ ahụ. Ma ụmụ Izrel nwere ìhè nʼebe niile ha bi. 
\p  
\v 24 Mgbe ahụ, Fero kpọrọ Mosis sị ya, “Gaanụ fee \nd Onyenwe anyị\nd* unu ofufe. Unu na ndị inyom na ụmụ unu nwere ike ịga, ma unu ga-ahapụ igwe ehi unu na igwe anụ ụlọ unu gaa.” 
\p  
\v 25 Mosis zara, “Ị ghaghị ịhapụ anyị ka anyị were ihe aja na aja nsure ọkụ, nke anyị chee nʼihu \nd Onyenwe anyị\nd* Chineke anyị.  
\v 26 Igwe anụ ụlọ anyị ga-esoro anyị. O nweghị ihe ọ bụla anyị ga-ahapụ nʼihi na anyị ga-eji ụfọdụ nʼime ha fee \nd Onyenwe anyị\nd* Chineke anyị ofufe. Ọ bụkwa naanị mgbe anyị ruru nʼebe ahụ ka anyị nwere ike ịmata ihe anyị ga-eji fee \nd Onyenwe anyị\nd* anyị ofufe.” 
\p  
\v 27 Ma \nd Onyenwe anyị\nd* mere ka obi Fero sie ike. O kweghị ka ha laa.  
\v 28 Fero gwara Mosis sị, “Si nʼihu m pụọ. Lezie anya hụ na ị bịaghị nʼihu m ọzọ. Ụbọchị ọbụla ị nwara bịa nʼihu m, onye nwụrụ anwụ ka ị ga-abụ.” 
\p  
\v 29 Mosis zaghachiri Fero sị, “Ihe i kwuru dị mma, agaghị m abịakwa nʼihu gị ọzọ.” 
\c 11  
\s1 Ogbugbu ụmụ e buru ụzọ mụọ 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis, “Aga m ewetara Fero na Ijipt otu ihe otiti ọzọ. Mgbe nke a gasịrị, ọ ga-ekwe ka unu si nʼebe a pụọ. Nʼeziokwu, ọ ga-eji aka ya chụpụ unu nʼala ya.  
\v 2 Gwa nwoke na nwanyị Izrel ọbụla ka ha jikere. Ha rịọọ ndị agbataobi ha bụ ndị Ijipt, ka ha nye ha ihe ọbụla e ji ọlaọcha na ọlaedo kpụọ.”  
\v 3 \nd Onyenwe anyị\nd* mere ka ụmụ Izrel nweta ihuọma nʼebe ndị Ijipt, na ndị agbataobi ha nọ. Nke ka nke, Mosis ghọrọ onye a na-asọpụrụ nʼetiti ndị ozi Fero na nʼihu ndị Ijipt niile. 
\p  
\v 4 Ya mere, Mosis sịrị, “Ihe a ka \nd Onyenwe anyị\nd* kwuru, ‘Nʼihe dịka nʼetiti abalị taa, aga m agafe nʼime ala Ijipt niile.  
\v 5 Mgbe nke a na-eme, ndị ikom niile e bụ ụzọ mụọ\f + \fr 11:5 \ft Gbaa gburugburu ala niile dị nʼetiti ọwụwa anyanwụ, ọdịnihu ezinaụlọ ọbụla na-adabere nʼọkpara.\f* nʼala Ijipt ga-anwụ, site nʼọkpara Fero, onye nọ ugbu a nʼocheeze ya, ruo nʼọkpara ohu onye nwanyị na-akwọ ihe na nkume ịkwọ nri, na ụmụ ehi niile e bụ ụzọ mụọ.  
\v 6 Mgbe nke a mere, iti mkpu akwa dị ukwuu ga-adị nʼala Ijipt, ụdị ga-ada nʼala Ijipt niile nke na-adịbeghị nʼala Ijipt, ụdị iti mkpu akwa nke na-agaghị adịkwa ọzọ.  
\v 7 Ma nʼebe ụmụ Izrel nọ, nkịta agaghị agbọ nwoke maọbụ nwanyị maọbụ anụmanụ ọbụla ụja.’ Site na nke a, ị ga-amata na \nd Onyenwe anyị\nd* na-akpa oke nʼetiti ndị Izrel na ndị Ijipt.  
\v 8 Ndị ọchịchị gị ndị a ga-abịa gbuo ikpere rịọọ m sị m, ‘Biko kpọrọ ndị gị pụọ nʼobodo anyị.’ Mgbe ha mesịrị nke a, aga m apụ.” Iwe were Mosis mgbe o si nʼụlọ Fero na-apụta. 
\p  
\v 9 \nd Onyenwe anyị\nd* agwalarị Mosis sị ya, “Fero agaghị ege gị ntị. Nke a ga-enye m ohere ime ọtụtụ ihe ebube dị iche iche nʼIjipt.”  
\v 10 Ọ bụ ezie na Mosis na Erọn mere ihe ebube ndị a nʼihu Fero, ma \nd Onyenwe anyị\nd* mere ka obi Fero sie ike, ka ọ hapụ ikwe ka ụmụ Izrel si nʼala ya pụọ. 
\c 12  
\s1 Mmemme Ngabiga na nke achịcha na-ekoghị eko 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis na Erọn okwu nʼala Ijipt sị ha,  
\v 2 “Ọnwa a ga-abụrụ unu isi ọnwa. Ọ ga-abụ ọnwa mbụ nke ọnwa niile nʼafọ unu.  
\v 3 Gwa ọgbakọ ụmụ Izrel niile okwu sị ha, Nʼafọ ọbụla, nʼabalị iri nke ọnwa a, nwoke ọbụla ga-eweta nwa atụrụ nʼisi ezinaụlọ ọbụla.  
\v 4 Ezinaụlọ ọbụla nke dịkarịrị nta, nke na-enweghị ike iweta na iricha otu nwa atụrụ, ga-ejekwuru ezinaụlọ ọzọ dịkwa nta, ka ha jikọtaa onwe ha ọnụ weta nwa atụrụ. Ndị ga-ejikọta onwe ha ọnụ aghaghị ibu ụzọ pịa mmadụ ole ha ga-adị nwee ike richaa otu atụrụ.  
\v 5 Nwa atụrụ a ga-eweta ga-abụ oke gbara naanị otu afọ, nke na-enweghị ntụpọ ọbụla nʼahụ ya. Unu nwere ike họrọ atụrụ maọbụ ewu.  
\v 6 Unu ga-elekọta ya anya ruo nʼụbọchị nke iri na anọ nke ọnwa a. Nʼabalị ụbọchị ahụ ka ọgbakọ Izrel niile ga-egbu ya.  
\v 7 Ha ga-ewere ọbara ya tee nʼelu na nʼakụkụ ibo ọnụ ụzọ nke dị nʼezinaụlọ ha niile, ebe ha ga-anọ rie anụ atụrụ ahụ.  
\v 8 Ha ga-eri anụ atụrụ a, nke a ga-ahụ nʼọkụ nʼabalị ahụ, ya na achịcha na-ekoghị eko, na ahịhịa ndụ na-elu ilu.  
\v 9 A gaghị eri nwa atụrụ ọbụla na ndụ, a gaghị esikwa ya esi, kama a ga-ahụ ya nʼọkụ. A ga-ahụ akụkụ ahụ nwa atụrụ ọbụla nʼọkụ, tinyere isi ya, ụkwụ ya na ihe dị nʼime afọ ya.  
\v 10 Unu agaghị erifọdụ ya ruo nʼụtụtụ echi ya. Nke ọbụla ga-afọdụ nʼabalị ahụ, a ga-akpọ ya ọkụ.  
\v 11 Otu a ka unu ga-esi rie ya: yirinụ uwe unu, na akpụkpọụkwụ unu.\f + \fr 12:11 \ft Akpụkpọụkwụ na belịt abụghị ihe ndị mmadụ na-eyi mgbe ọbụla ha nọ nʼụlọ. Mgbe ụmụ Izrel yiri ha, ha na-ezipụta okwukwe na olileanya ha nwere banyere ọpụpụ ha site nʼala Ijipt.\f* Jirikwanụ mkpara unu. Jikerenụ dịka ndị na-aga njem dị anya. Unu ga-eri anụ atụrụ a na achịcha na-ekoghị eko ngwangwa. A ga-akpọ oriri a Mmemme Ngabiga \nd Onyenwe anyị\nd*. 
\p  
\v 12 “Aga m agafe nʼala Ijipt nʼabalị ahụ, igbu ndị ikom niile e bụ ụzọ mụọ nʼala Ijipt, ma mmadụ, ma anụmanụ. Aga m emekwa ka ikpe ọmụma bịakwasị chi ndị ọzọ ahụ niile Ijipt na-efe ofufe. Abụ m \nd Onyenwe anyị\nd*.  
\v 13 Ọbara ahụ unu ga-ete nʼọnụ ibo ụlọ unu ga-abụ ihe ama igosi ebe unu bi, nʼihi na mgbe m hụrụ ọbara ahụ, aga m agafe unu. Ọ nwekwaghị ihe otiti ga-abịakwasị unu mgbe m ga-egbu ndị Ijipt. 
\p  
\v 14 “Ụbọchị a ga-abụrụ unu ihe ncheta nye ọgbọ niile ndị na-eso nʼazụ. Unu ga-emekwa ya ka ọ bụrụ mmemme nye \nd Onyenwe anyị\nd*. Ụkpụrụ nke na-adịgide adịgide site nʼọgbọ ruo nʼọgbọ.  
\v 15 Ụbọchị asaa ka unu ga-eri achịcha na-ekoghị eko.\f + \fr 12:15 \ft Ọ bụ nri a ha riri nʼabalị ụbọchị ahụ mere e ji akpọ ncheta Mmemme Ngabiga, Mmemme achịcha na-ekoghị eko.\f* Nʼụbọchị mbụ nke ụbọchị asaa ahụ, ka unu ga-esite nʼụlọ unu wezuga ihe iko achịcha niile, nʼihi na onye ọbụla riri nri nke ihe na-eko achịcha dị nʼime ya site nʼụbọchị mbụ ruo nʼụbọchị nke asaa, aghaghị ibipụ ya site nʼala Izrel.  
\v 16 Unu ga-ewere ụbọchị mbụ na ụbọchị nke asaa, nke mmemme ahụ, nwee mkpọkọta dị nsọ. Onye ọbụla agaghị arụ ọrụ ọbụla nʼụbọchị abụọ ndị a, karịakwa isi nri unu ga-eri. 
\p  
\v 17 “Unu ga-edobekwa mmemme achịcha na-ekoghị eko nʼihi na ọ bụ nʼime otu ụbọchị a ka m sitere nʼala Ijipt kpọpụta unu dịka usuu ndị agha. Unu ga-emekwa mmemme ụbọchị a ka ọ bụrụ ụkpụrụ nke na-adịgide adịgide site nʼọgbọ ruo nʼọgbọ  
\v 18 Nʼọnwa mbụ, nʼanyasị nke ụbọchị nke iri na anọ, ka unu ga-eri achịcha a na-ejighị ihe na-eko achịcha mee ruo nʼanyasị nke ụbọchị iri abụọ na otu.  
\v 19 Nʼime ụbọchị asaa ahụ, agaghị ahụ ihe na-eko achịcha nʼụlọ unu. A ga-esite nʼọgbakọ ndị Izrel bipụ onye ọbụla riri ihe ọbụla nke ihe na-eko achịcha dị nʼime ya. Iwu a dịrị ndị ọbịa niile nʼala Izrel, dịkwara ndị nwa afọ ala.  
\v 20 Unu agaghị eri ihe ọbụla e ji ihe na-eko achịcha mee. Nʼebe obibi unu niile, ọ bụ naanị achịcha na-ekoghị eko ka unu ga-eri.” 
\p  
\v 21 Mgbe ahụ, Mosis kpọkọtara ndị okenye ụmụ Izrel niile gwa ha okwu sị, “Gaanụ họpụta ụmụ atụrụ nʼihi agbụrụ unu niile, gbuonụ atụrụ ngabiga ndị a.  
\v 22 Were ahịhịa hisọp, denye ya nʼọbara si nʼatụrụ ndị a nke a ga-awụnye nʼefere, tee ya nʼelu ibo na nʼakụkụ abụọ nke ọnụ ụzọ ụlọ unu. Onye ọbụla nʼime unu agaghị apụ nʼezi tutu ruo ụtụtụ.  
\v 23 Mgbe \nd Onyenwe anyị\nd* ga-agafe igbu ndị Ijipt, ọ ga-ahụ ọbara ahụ nʼawara na mbudo ibo ọnụ ụzọ ụlọ unu. Ọ ga-agafe ụlọ unu, gharakwa ikwe ka onye mbibi bata nʼụlọ unu gbuo unu. 
\p  
\v 24 “Unu ga-edobe mmemme a dịka iwu ga-adịgide nye unu na ụmụ unu.  
\v 25 Mgbe unu batara nʼala ahụ \nd Onyenwe anyị\nd* ga-enye unu dịka o kwere na nkwa, unu ga-edobe ofufe\f + \fr 12:25 \ft Ofufe nʼebe ana-ekwu banyere mmemme ahụ.\f* a.  
\v 26 Mgbe ụmụ unu ga-ajụ unu ajụjụ sị, ‘Gịnị ka ofufe a pụtara?’  
\v 27 Unu ga-azaghachi ha sị, ‘Ọ bụ aja ngabiga anyị na-achụrụ \nd Onyenwe anyị\nd* nʼihi na ọ gafere ụlọ ụmụ Izrel nʼala Ijipt, mgbe o gburu ndị Ijipt, ma o nweghị onye ọbụla nʼime anyị o gburu.’ ”  
\v 28 Ụmụ Izrel mezuru ihe niile \nd Onyenwe anyị\nd* gwara ha site nʼọnụ Mosis na Erọn. 
\p  
\v 29 Nʼime etiti abalị ụbọchị ahụ, \nd Onyenwe anyị\nd* gburu ndị ikom niile e bụ ụzọ mụọ nʼala Ijipt, malite nʼọkpara Fero onye nọ nʼocheeze ya, ruo nʼọkpara nke onye Ijipt nọ nʼụlọ mkpọrọ olulu. O gbukwara ụmụ anụ ụlọ niile e bụ ụzọ mụọ.  
\v 30 Nʼabalị ahụ kwa, Fero na ndị ozi ya, na ndị Ijipt niile biliri. Oke iti mkpu akwa dakwara nʼala Ijipt, nʼihi na ọ dịghị ezinaụlọ ọnwụ na-erughị. 
\s1 Ọpụpụ ụmụ Izrel 
\p  
\v 31 Nʼotu abalị ahụ, Fero zipụrụ ozi ka a kpọ Mosis na Erọn. Mgbe ha bịara, ọ gwara ha sị, “Ngwa bilienụ, unu bụ ụmụ Izrel niile. Kewapụnụ onwe unu site nʼetiti anyị. Gaanụ, fee \nd Onyenwe anyị\nd* unu ofufe dịka unu rịọrọ.  
\v 32 Durunụ igwe ehi na atụrụ unu mgbe unu na-aga. Gọziekwanụ m mgbe unu na-apụ.” 
\p  
\v 33 Ndị Ijipt gbalịrị ime ka ụmụ Izrel hapụ ha ngwangwa. Ha sịrịtara onwe ha, “Ọ bụrụ na ụmụ Izrel ahapụghị anyị ugbu a, anyị niile ga-anwụkwa.”  
\v 34 Ya mere, ụmụ Izrel buuru ụtụ ọka e ji eme achịcha na-ekoghị eko, nke ha tinyere nʼefere e ji agwakọta ya. Ha ji akwa kechie ha, bukwasị ha nʼubu ha.  
\v 35 Ha mekwara ihe ndị ọzọ dịka Mosis gwara ha. Ha rịọrọ ndị Ijipt ka ha nye ha ihe iji ngwa nke ọlaọcha na ọlaedo, na uwe.  
\v 36 \nd Onyenwe anyị\nd* nyere ndị ya amara nʼihu ndị Ijipt, ha nyere ha ihe niile ha rịọrọ. Site nʼụzọ dị otu a, ụmụ Izrel napụtara ndị Ijipt ihe niile ha ji biri nʼụlọ. 
\p  
\v 37 Mgbe nke a gasịrị, ụmụ Izrel malitere ije ha site na Ramesis. Mgbe ha hapụrụ Ramesis, na-eje Sukọt, ha dị narị puku ndị ikom isii, na-agụghị ndị inyom na ụmụntakịrị.  
\v 38 Ọtụtụ mmadụ dị iche iche sooro ha nʼije ha. Ha dukwa igwe anụ ụlọ, igwe ewu na atụrụ ha, nke dị ukwu nʼọnụọgụgụ.  
\v 39 Ha ji ụtụ ọka ha si Ijipt buputa mee achịcha na-ekoghị eko. Nʼihi na a chụpụrụ ha achụpụ site nʼIjipt, ha enweghị ezi ohere kwadooro onwe ha ihe oriri. 
\p  
\v 40 Tupu ha ahapụ ala Ijipt, ụmụ Izrel ebiela nʼebe ahụ narị afọ anọ na iri afọ atọ.  
\v 41 Mgbe narị afọ anọ na iri afọ atọ zuru, nʼụbọchị ahụ o zuru, usuu ndị \nd Onyenwe anyị\nd* niile hapụrụ Ijipt.  
\v 42 \nd Onyenwe anyị\nd* chere nche nʼabalị ụbọchị ahụ maka ịkpọpụta ha site nʼala Ijipt. Nʼihi ya, abalị ụbọchị ahụ bụ mgbe pụrụ iche nye ụmụ Izrel maka iji iche nche sọpụrụ \nd Onyenwe anyị\nd* nʼọgbọ ha niile. 
\s1 Iwu metụtara Mmemme Ngabiga 
\p  
\v 43 \nd Onyenwe anyị\nd* kpọrọ Mosis na Erọn gwa ha sị, “Ndị a bụ usoro iwu metụtara Mmemme Ngabiga: 
\p “Onye mba ọzọ agaghị eri anụ nwa atụrụ ahụ.  
\v 44 Ohu ọbụla a kwụrụ ụgwọ nʼisi ya ga-eri ya naanị ma e biri ya ugwu.  
\v 45 Ohu e goro ọrụ, maọbụ onye ọbịa ọbụla agaghị eri ya. 
\p  
\v 46 “A ga-eri ya naanị nʼime otu ụlọ. Ọ gaghị apụ nʼezi. Unu agaghị atapịa ọkpụkpụ ọbụla nke nwa atụrụ ahụ.  
\v 47 Nzukọ niile nke ụmụ Izrel ga-eme Mmemme Ngabiga a. 
\p  
\v 48 “Onye mba ọzọ bi nʼetiti unu chọrọ isoro unu na Mmemme Ngabiga \nd Onyenwe anyị\nd* aghaghị ibi ndị ikom niile nọ nʼezinaụlọ ya ugwu. Mgbe ahụ, ọ ga-abịaru nso isoro na mmemme, nʼihi na a ga-agụ ya dịka nwa afọ ala. Ọ dịghị onye ikom a na-ebighị ugwu ga-eri nri ahụ.  
\v 49 Otu iwu a dịrị nwa afọ ala na ndị ọbịa niile bi nʼala Izrel.” 
\p  
\v 50 Ụmụ Izrel mere ihe ndị a niile, dịka \nd Onyenwe anyị\nd* nyere ha nʼiwu site nʼọnụ Mosis na Erọn.  
\v 51 Ọ bụkwa nʼotu ụbọchị ahụ ka \nd Onyenwe anyị\nd* sitere nʼala Ijipt dupụta ụmụ Izrel, dịka usuu ha niile si dị. 
\c 13  
\s1 Ido nsọ nke ụmụ e bụ ụzọ mụọ 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu sị,  
\v 2 “Dooro m nsọ onye ọbụla bụ ọkpara, onye ọbụla e bụ ụzọ mụọ nʼetiti ụmụ Izrel, na nʼetiti mmadụ ma nʼetiti anụ ụlọ, nke m ka ọ bụ.” 
\p  
\v 3 Mosis gwara ndị Izrel sị, “Chetanụ ụbọchị taa, ụbọchị unu si nʼala Ijipt pụta, ala ebe unu bụ ndị ohu, nʼihi na \nd Onyenwe anyị\nd* sitere nʼike aka ya dị ukwu kpọpụta unu site nʼebe ahụ. Unu erikwala achịcha ọbụla e ji ihe na-eko achịcha mee.  
\v 4 Taa, nʼọnwa Abib, bụ ụbọchị unu na-ahapụ ala Ijipt.  
\v 5 Mgbe \nd Onyenwe anyị\nd* dubatara unu nʼala ndị Kenan, ndị Het, ndị Amọrait, ndị Hiv na ndị Jebus bi nʼime ya, bụ ala ahụ ọ ṅụrụ nʼiyi nye nna nna unu ha na ọ ga-enye unu, ala mmiri ara ehi na mmanụ aṅụ na-eru na ya, unu ga-eme ofufe mmemme a nʼọnwa a.  
\v 6 Unu ga-eri achịcha na-ekoghị eko ụbọchị asaa ahụ. Nʼụbọchị nke ikpeazụ nʼime ụbọchị asaa ahụ, unu ga-eme mmemme oke oriri nʼihu \nd Onyenwe anyị\nd*.  
\v 7 Rienụ achịcha na-ekoghị eko nʼime ụbọchị asaa ndị ahụ. Achịcha e ji ihe na-eko achịcha mee agaghị adị nʼụlọ unu. Achịcha e ji ihe na-eko achịcha mee agaghị adị nʼoke ala unu niile.  
\v 8 Nʼoge ọbụla ị na-eme mmemme a, kọwaara nwa gị nwoke ihe kpatara i ji eme mmemme a, si ya, ‘Ana m eme mmemme a maka icheta ihe \nd Onyenwe anyị\nd* meere m, mgbe m si nʼIjipt pụta.’  
\v 9 Imezu mmemme a ga-adịrị unu dịka ihe ịrịbama nʼala unu, dịrịkwa ka ihe ngosi nʼegedege ihu unu, ichetara unu na \nd Onyenwe anyị\nd* ji aka ike ya dupụta anyị site nʼala Ijipt.  
\v 10 Unu ga na-eme mmemme a nʼoge a kara aka nʼafọ ọbụla. 
\p  
\v 11 “Mgbe \nd Onyenwe anyị\nd* dubatara unu nʼala ndị Kenan, nyefee unu ala ahụ dịka ọ ṅụrụ nʼiyi nye nna nna unu ha,  
\v 12 unu ga-enyefe \nd Onyenwe anyị\nd* ụmụ ndị ikom unu niile e bụ ụzọ mụọ. Ọzọ, ụmụ oke anụ ụlọ niile e bụ ụzọ mụọ bụ nke \nd Onyenwe anyị\nd*.  
\v 13 Jiri nwa atụrụ gbapụta nwa ịnyịnya ibu\f + \fr 13:13 \ft Ịnyịnya ibu bụ otu nʼime anụ na-adịghị ọcha na nke e kwesighị ka e jiri ya nye onyinye ọbụla. \xt Ọnụ 18:15; Lev 11:2-23\ft  Ma nʼihi iba uru ha nʼihe banyere ọrụ, Chineke nyere oghere maka iji nwa atụrụ gbara ha.\f* mbụ e bụ ụzọ mụọ. Ọ bụrụ na unu achọghị ịgbara nwa ịnyịnya ibu ahụ, unu aghaghị ịgbaji ya olu. Ma unu aghaghị ịgbara ụmụ ndị ikom niile e bụ ụzọ mụọ. 
\p  
\v 14 “Nʼoge dị nʼihu, mgbe nwa gị nwoke ga-ajụ gị sị, ‘Gịnị ka ihe ndị a pụtara?’ Ị ga-azaghachi ya sị, ‘\nd Onyenwe anyị\nd* jiri aka ike dị ukwu dupụta anyị site nʼIjipt, site nʼala nke ohu.  
\v 15 Mgbe Fero mesiri obi ya ike, jụ ka anyị si nʼala ya pụọ, \nd Onyenwe anyị\nd* gburu ụmụ ndị ikom niile e bụ ụzọ mụọ nʼala Ijipt, ma mmadụ ma anụ ụlọ. Nʼihi ya, ana m eji ụmụ oke anụ ụlọ niile e bụ ụzọ mụọ achụ aja nye \nd Onyenwe anyị\nd*. Ma ụmụ m ndị ikom niile e bụ ụzọ mụọ ka m na-agbapụta.’  
\v 16 Mmemme a ga-adị ka ihe ịrịbama nʼanya unu, dịrịkwa ka ihe ngosi nʼegedege ihu unu, ichetara unu na \nd Onyenwe anyị\nd* ji aka ike ya dupụta anyị site nʼala Ijipt.” 
\s1 Ngafe Osimiri Uhie 
\p  
\v 17 Mgbe Fero mesịrị kwere ka ụmụ Izrel laa, Chineke edughị ha site nʼụzọ ahụ gafere ala ndị Filistia. Ọ bụ ezie na ụzọ ahụ dị nso karịa.\f + \fr 13:17 \ft Ụzọ ahụ dị nso nke ha esiteghị, jupụtara nʼọtụtụ ebe mgbaba e wusiri ike nke ndị agha Ijipt na-eche nche.\f* Chineke mere nke a nʼihi na o chere nʼobi ya sị, “Ọ bụrụ na ndị a ezute agha, ha nwere ike ịgbanwe obi ha tụgharịa ịlaghachi azụ nʼIjipt.”  
\v 18 Ya mere, Chineke duuru ha ga nʼụzọ Osimiri Uhie, nke gara nʼụzọ nke ọzara. Ụmụ Izrel kwadokwara akwado ibu agha mgbe ha si nʼala Ijipt pụọ. 
\p  
\v 19 Mosis buuru ọkpụkpụ Josef mgbe ha na-ala. Nʼihi na o mere ka ụmụ Izrel ṅụọ iyi na ha ga-eme otu a, na-asị, “Chineke ga-eleta unu nʼezie, mgbe ahụ, unu aghaghị iburu ọkpụkpụ m si nʼebe a pụọ.” 
\p  
\v 20 Ha si Sukọt bilie ije, maa ụlọ ikwu ha na Etam, na nsọtụ ọzara.  
\v 21 \nd Onyenwe anyị\nd* ji ogidi igwe ojii na-eje nʼihu ha nʼehihie, idu ha nʼụzọ ha niile. Nʼabalị, o ji ogidi ọkụ, inye ha ìhè ka ha nwee ike ịga njem nʼehihie nakwa nʼabalị.  
\v 22 Ma ogidi igwe ojii nʼehihie na ogidi ọkụ ahụ nʼabalị, ọ dịghị nke hapụrụ ọnọdụ ya nʼihu ha. 
\c 14  
\p  
\v 1 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis,  
\v 2 “Gwa ụmụ Izrel ka ha chigharịa azụ jee maa ụlọ ikwu ha na ncherita ihu Pi Hahirot, nke dị nʼetiti Migdol na osimiri. Ọ bụ nʼakụkụ osimiri, na ncherita ihu obodo Baal-Zefọn ka ha ga-ama ụlọ ikwu ha.  
\v 3 Fero ga-asị banyere ụmụ Izrel, ‘Ha na-awagharị gburugburu ala ahụ nʼọnọdụ mgbagwoju anya ebe ọzara riri ha.’  
\v 4 Aga m eme ka obi Fero sie ike ka ọ chụso unu ọsọ nʼazụ, ma m ga-ewetara onwe m otuto site na Fero na ndị agha ya niile. Ndị Ijipt niile ga-ama na mụ onwe m bụ \nd Onyenwe anyị\nd*.” Ndị Izrel mekwara otu ahụ. 
\p  
\v 5 Mgbe a gwara eze Ijipt na ndị a agbaala ọsọ, obi Fero na ndị ozi ya gbanwere megide ndị Izrel. Ha sịrị, “Gịnị bụ ihe anyị mere, site na izipụ ndị Izrel nʼọrụ ife anyị?”  
\v 6 Na-atụfughị oge, Fero rigoro nʼelu ụgbọ agha ya, duru ndị agha ya ịchụso ha.  
\v 7 Ọ chịịrị ụgbọ agha dị narị isii e leziri anya họpụta, tinyere ụgbọ agha Ijipt niile. Ndịisi agha ndị Ijipt nọcha nʼelu ha niile.  
\v 8 \nd Onyenwe anyị\nd* mere ka obi Fero eze Ijipt sie ike. Ọ chụsoro ụmụ Izrel, ndị na-aga nʼihu nʼije ha, na-atụghị egwu maọbụ ịda mba.  
\v 9 Ndị Ijipt chụsoro ha ọsọ, ịnyịnya Fero na ụgbọ agha, na ndị na-agba ịnyịnya na ndị agha ndị ọzọ chụsoro ndị Izrel ọsọ chụkwute ha nʼebe ha na-ezu ike nʼakụkụ osimiri dị nso na Pi Hahirot na ncherita ihu Baal-Zefọn. 
\p  
\v 10 Mgbe ndị agha Fero na-abịa nso, ndị Izrel lere anya nʼazụ, hụ ndị Ijipt ka ha na-abịa nso. Ha tụrụ egwu, tie mkpu akwa, kpọkuo \nd Onyenwe anyị\nd*.  
\v 11 Ha jụrụ Mosis sị, “Ọ bụ na o nweghị ili dị nʼala Ijipt, i ji kwagide anyị ka anyị niile bịa nwụọ nʼebe a nʼọzara? Gịnị mere i ji kwagide anyị ka anyị hapụ Ijipt?  
\v 12 Ọ bụ na anyị agwaghị gị nʼala Ijipt si gị, ‘Hapụ anyị ka anyị nọgide na-ejere ndị Ijipt ozi?’ Ọ gara akara anyị mma ị bụ ohu ndị Ijipt karịa ịnwụ nʼọzara.” 
\p  
\v 13 Mosis zaghachiri ha sị, “Unu atụla egwu. Guzosienụ ike. Unu ga-ahụ ụzọ dị ebube \nd Onyenwe anyị\nd* ga-esi zọpụta unu taa. Ndị Ijipt a unu na-ahụ taa, unu agaghị ahụkwa ha ọzọ.  
\v 14 Nọrọnụ jii. \nd Onyenwe anyị\nd* ga-alụrụ unu ọgụ.” 
\p  
\v 15 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya, “Gịnị mere i ji na-akpọku m. Gwa ụmụ Izrel ka ha gaa nʼihu.  
\v 16 Welie mkpanaka gị elu. Setịpụ ya nʼelu osimiri ahụ ka o kewaa abụọ. Ụzọ ga-adịkwa nʼetiti osimiri ahụ. Ụmụ Izrel ga-esitekwa nʼala akọrọ gafee.  
\v 17 Aga m eme ka obi ndị Ijipt sie ike, ka ha sorokwa unu nʼazụ banye. Aga m ewetara onwe m otuto site na Fero, na ndị agha niile, na ụgbọ agha niile nakwa ndị na-agba ịnyịnya ya.  
\v 18 Nʼoge ahụ, ndị Ijipt ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*. M ga-enweta nsọpụrụ site na Fero, na ụgbọ agha ya niile, na ndị na-agba ịnyịnya ya.” 
\p  
\v 19 Mgbe ahụ, mmụọ ozi Chineke, onye na-aga nʼihu ndị agha Izrel, sitere nʼihu pụọ gaa nọdụ nʼazụ ha. Otu a kwa, ogidi igwe ojii ahụ sitere nʼihu gaa nʼazụ ha.  
\v 20 Nke a mere ka ogidi igwe ojii ahụ dịrị nʼetiti ụmụ Izrel na ndị Ijipt. Nʼabalị ụbọchị ahụ, Onyenwe anyị mere ka ogidi igwe ojii ahụ nye ụmụ Izrel ìhè, ma ndị Ijipt nọgidere nʼọchịchịrị. Otu a, ndị Ijipt enweghị ike bịarute nʼebe ụmụ Izrel nọ. 
\p  
\v 21 Mgbe ahụ, Mosis setịpụrụ aka ya nʼelu Osimiri Uhie ahụ. \nd Onyenwe anyị\nd* ji oke ifufe si nʼọwụwa anyanwụ, nke fere nʼabalị ahụ niile, nughachi osimiri ahụ, mee ka osimiri ahụ kebie ụzọ abụọ, ka ụzọ pụta nʼala osimiri ahụ.  
\v 22 Ụmụ Izrel sitere nʼetiti osimiri ahụ gafee. Mmiri osimiri ahụ ghọọrọ mgbidi nʼaka nri ha ma nʼaka ekpe ha. 
\p  
\v 23 Mgbe ndị agha Ijipt na-achụ ha ọsọ hụrụ ha ka ha na-agafe, ha sogidere ha baa, ọ bụladị nʼetiti osimiri ahụ. Ndị agha Ijipt niile sooro ha, ya bụ, ụgbọ agha Fero, ndị agha ya na ndị na-agba ịnyịnya ya niile.  
\v 24 Nʼisi ụtụtụ echi ya, \nd Onyenwe anyị\nd* ledatara anya site nʼogidi igwe ojii ahụ na-enye ihe. O legidere ndị agha Ijipt anya, tinyekwa ha ụjọ nʼobi nke mere na ha amakwaghị onwe ha.  
\v 25 O mebiri ụkwụ ụgbọ agha ha mee ka o siere ịnyịnya ha ike ịdọkpụ ụgbọ agha ndị ahụ. Mgbe ahụ, ndị Ijipt kwuru sị, “Ka anyị sinụ nʼịchụ ndị Izrel gbapụ, nʼihi na \nd Onyenwe anyị\nd* na-alụrụ ha ọgụ, na-emegidekwa anyị.” 
\p  
\v 26 Mgbe ụmụ Izrel gafesịrị ruo nʼakụkụ nke ọzọ nke osimiri ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị, “Setịpụ aka gị ọzọ ka mmiri ahụ kpuchigide ndị Ijipt, na ụgbọ agha ha niile, na ndị na-agba ịnyịnya ya.”  
\v 27 Mosis setịpụrụ aka nʼelu osimiri ahụ. Nʼụtụtụ ya, mmiri osimiri ahụ sọghachiri gaa ebe ọ nọ na mbụ. Ndị Ijipt chọsịrị ụzọ ha si agbapụ ike, ma \nd Onyenwe anyị\nd* mere ka osimiri ahụ kpuchie ha.  
\v 28 Osimiri ahụ kpuchigidere ụgbọ agha ha niile, na ndị na-agba ịnyịnya, na ndị agha Fero niile ndị chụụrụ ụmụ Izrel baa nʼime osimiri ahụ. O nweghị otu onye nʼime ha fọdụrụ ndụ. 
\p  
\v 29 Ma ụmụ Izrel esitelarị nʼala nke mmiri kọrọ gafee osimiri ahụ. Mgbe ha na-agafekwa, akụkụ abụọ nke osimiri ahụ guzoro ọtọ dịka mgbidi, nʼaka nri ha ma nʼaka ekpe ha.  
\v 30 Site nʼụzọ dị otu a, \nd Onyenwe anyị\nd* zọpụtara ụmụ Izrel site nʼaka ndị Ijipt. Ụmụ Izrel hụkwara ozu ndị Ijipt nʼikpere mmiri osimiri ahụ.  
\v 31 Ụmụ Izrel tụrụ egwu Onyenwe anyị mgbe ha hụrụ ihe ịrịbama ndị a \nd Onyenwe anyị\nd* ji zọpụta ha site nʼaka ndị Ijipt. Ha kwenyere na \nd Onyenwe anyị\nd*, kwenyekwa na Mosis ohu ya. 
\c 15  
\s1 Abụ Mosis 
\p  
\v 1 Mgbe ahụ, Mosis na ụmụ Izrel bụkuru \nd Onyenwe anyị\nd* abụ dị otu a sị, 
\q1 “Aga m abụku \nd Onyenwe anyị\nd* abụ 
\q2 nʼihi na o buliela onwe ya elu nke ukwuu. 
\q1 Ọ tụnyela ịnyịnya 
\q2 na onye na-agba ya nʼosimiri. 
\b  
\q1  
\v 2 “\nd Onyenwe anyị\nd* bụ ike m na abụ m. 
\q2 Ọ ghọrọla m nzọpụta. 
\q1 Ọ bụ Chineke m, aga m etokwa ya, 
\q2 Chineke nke nna m, aga m ebulikwa ya elu. 
\q1  
\v 3 Onye na-ebu agha ka \nd Onyenwe anyị\nd* bụ. 
\q2 Nʼezie, aha ya bụ \nd Onyenwe anyị\nd*. 
\q1  
\v 4 Ụgbọ agha Fero na usuu ndị agha ya, 
\q2 ka ọ tụnyere nʼosimiri ahụ. 
\q1 Ndịisi agha Fero, ndị ahọrọ ahọ, 
\q2 ka o mere ka Osimiri Uhie rie. 
\q1  
\v 5 Ogbu osimiri ahụ ekpuchiela ha. 
\q2 Nʼime mmiri ahụ dị omimi ka ha rịdaruru dịka nkume. 
\q1  
\v 6 Aka nri gị \nd Onyenwe anyị\nd*, dị ike, 
\q2 dịkwa ebube. 
\q1 Aka nri gị, \nd Onyenwe anyị\nd* 
\q2 na-etipịasị ndị iro. 
\b  
\q1  
\v 7 “Nʼoke ike nke ịdị elu gị, 
\q2 Ị lụgbuola ndị niile na-ebili imegide gị. 
\q1 I zipụrụ iwe gị dị ọkụ, 
\q2 o repịara ha dịka igbugbo ọka. 
\q1  
\v 8 I sitere na nkuume nke oghere imi gị, 
\q2 mee ka mmiri osimiri guzoro ọtọ. 
\q1 Mmiri ahụ na-erugharị erugharị guzoro nʼotu ebe dịka mgbidi; 
\q2 ogbu mmiri kpụkọtara rahụ nʼala ala nsọtụ nke osimiri. 
\q1  
\v 9 Onye iro nyara isi sị, 
\q2 ‘Aga m achụso ha, gafee ha. 
\q1 Aga m ekesa ihe a kwatara nʼagha. 
\q2 Nyejuo onwe m afọ site na ha. 
\q1 Aga m amịpụta mma agha m. 
\q2 Jiri aka m laa ha nʼiyi.’ 
\q1  
\v 10 Ma i kupụrụ ikuku si gị nʼimi pụta, 
\q2 osimiri riri ha, 
\q1 ha mikpuru nʼime osimiri ukwu ahụ 
\q2 dịka igwe. 
\q1  
\v 11 Onye dịka gị \nd Onyenwe anyị\nd*, 
\q2 nʼetiti chi niile? 
\q1 Onye dịka gị? 
\q2 Onye dị ebube nʼịdị nsọ.\f + \fr 15:11 \ft Onye ịdị nsọ ya dị ukwuu\f* 
\q1 Onye otuto ya na-eyi egwu. 
\q2 Onye na-arụ ọrụ dị ebube? 
\b  
\q1  
\v 12 “I setịpụrụ aka nri gị, 
\q2 ala meghere ọnụ ya loo ndị iro gị niile. 
\q1  
\v 13 Site nʼebere gị, 
\q2 i dupụtara ndị ị zọpụtara. 
\q1 Sitekwa nʼike gị dị ebube, i duru ha 
\q2 ruo nʼebe obibi gị dị nsọ. 
\q1  
\v 14 Ụwa niile nụrụ ya, maa jijiji. 
\q2 Ndị Filistia ka oke ihe mgbu bịakwasịrị. 
\q1  
\v 15 Ndị eze Edọm ga-anọ nʼọnọdụ obi ịlọ mmiri. 
\q2 Ndị ndu Moab niile ga-abụ ndị ọma jijiji ga-ejidekwa, 
\q1 ndị Kenan niile nʼọnọdụ ịtụ egwu ga-agbaze; 
\q2  
\v 16 oke egwu na oke ụjọ ejidela ha. 
\q1 Site nʼike nke aka gị, 
\q2 ha ga-anọ jụụ dịka nkume, 
\q1 tutu ruo mgbe ndị gị, \nd Onyenwe anyị\nd*, gafechara, 
\q2 tutu ruo mgbe ndị gị, ndị ị zụtara nye onwe gị, gafechara. 
\q1  
\v 17 Gị onwe gị ga-akpọbata ha, kụọ ha dịka mkpụrụ, 
\q2 nʼelu ugwu nke ihe nketa gị. 
\q1 Nʼebe ahụ, \nd Onyenwe anyị\nd*, i mere ka ọ bụrụ ebe obibi gị, 
\q2 ebe nsọ ahụ, Onyenwe anyị, nke i ji aka gị tọọ ntọala ya. 
\b  
\q1  
\v 18 “\nd Onyenwe anyị\nd* ga-abụ eze 
\q2 ruo mgbe niile ebighị ebi.” 
\p  
\v 19 Mgbe ịnyịnya Fero, na ụgbọ agha ya, na ndị na-agba ịnyịnya, gbabanyere nʼosimiri, \nd Onyenwe anyị\nd* mere ka mgbidi mmiri ahụ dagbuo ha. Ma ụmụ Izrel sitere nʼala mmiri kọrọ gafee. 
\s1 Abụ Miriam na ndị inyom 
\p  
\v 20 Nʼoge ahụ, Miriam onye amụma nwanyị, nwanne Erọn weere ịgba iti egwu nʼaka ya, duo ndị inyom ndị so ya, jiri ịgba egwu nke ha na-etekwa egwu.  
\v 21 Miriam bụrụ abụ sị ha, 
\q1 “Bụkuonụ \nd Onyenwe anyị\nd* abụ, 
\q2 nʼihi na ọ bụ onye e buliri elu nke ukwu. 
\q1 Ịnyịnya na ndị na-agba ha, 
\q2 ka ọ tụnyere nʼime osimiri.” 
\s1 Mmiri ilu Mara na Elim 
\p  
\v 22 Mgbe ihe ndị a mesịrị, Mosis nọgidere na-edu ụmụ Izrel. Ha sitere nʼOsimiri Uhie ahụ bilie ije, jeruo ọzara Shua. Ha jere ije nʼime ọzara abalị atọ, ma ha achọtaghị mmiri ọṅụṅụ  
\v 23 Mgbe ha ruru Mara, ha enweghị ike ịṅụ mmiri dị nʼebe ahụ, nʼihi na mmiri ahụ na-elu ilu. (Ọ bụ ilu ilu a mere e ji kpọọ ya Mara.)  
\v 24 Nʼebe a, ụmụ Izrel malitere itamu ntamu, megide Mosis sị, “Olee mmiri anyị ga-aṅụ?” 
\p  
\v 25 Mosis tikuru \nd Onyenwe anyị\nd* mkpu akwa. \nd Onyenwe anyị\nd* gosiri Mosis osisi ọ ga-atụnye nʼime mmiri ahụ. Mgbe Mosis mere otu a, mmiri ahụ malitere ịdị ụtọ ọṅụṅụ. 
\p Ọ bụkwa na Mara ka \nd Onyenwe anyị\nd* nọ nye ha ụkpụrụ ya na iwu ya maka iji ya nwalee ha.  
\v 26 Ọ sịrị, “Ọ bụrụ na unu ga-ege ntị nke ọma nʼokwu \nd Onyenwe anyị\nd* Chineke unu, mee ihe ziri ezi nʼanya ya, ọ bụrụkwa na unu eleruo anya idebe iwu ya na ụkpụrụ ya niile, ọ dịghị ọrịa nke m tinyere nʼahụ ndị Ijipt nke m ga-etinye nʼahụ unu. Nʼihi na mụ onwe m bụ \nd Onyenwe anyị\nd*, onye na-agwọ unu ọrịa niile.” 
\p  
\v 27 Ha bịaruru nʼobodo Elim, ebe e nwere isi iyi mmiri ala na-asọpụta dị iri na abụọ, na iri osisi nkwụ asaa. Ụmụ Izrel mara ụlọ ikwu ha nʼakụkụ mmiri ahụ. 
\c 16  
\s1 Mánà na Kweel, nri dị iche Onyenwe anyị zitere 
\p  
\v 1 Ọgbakọ ụmụ Izrel niile hapụrụ obodo Elim, jere ije bịarute nʼọzara Sin nke dị nʼetiti Saịnaị na Elim. Ha bịaruru nʼebe ahụ nʼabalị iri na ise nke ọnwa abụọ, site na mgbe ha hapụrụ Ijipt.  
\v 2 Nʼọzara ahụ, nzukọ ahụ niile tamuru ntamu megide Mosis na Erọn.  
\v 3 Ụmụ Izrel gwara ha sị, “Ọ gaara adị anyị mma ma a sị na \nd Onyenwe anyị\nd* gburu anyị nʼala Ijipt. Nʼebe ahụ ite anụ dị iche iche na-adọ nʼihu anyị, anyị na-erikwa ụdị nri ọbụla anyị chọrọ. Ugbu a, i dubatala anyị nʼọzara ka anyị niile nwụọ nʼagụụ.” 
\p  
\v 4 \nd Onyenwe anyị\nd* gwara Mosis okwu sị, “Lee anya, aga m esi nʼeluigwe zitere unu achịcha. Onye ọbụla ga-aga tụtụkọtara onwe ya ihe oriri ụbọchị ọbụla dịka ọ chọrọ. Aga m eji nke a lee ha ule ịmata ma ha ga-eme ihe m nyere ha nʼiwu.  
\v 5 Gwa ha na nʼụbọchị nke isii, ha ga-ewere nri ha ga-ericha nʼụbọchị ahụ, ma nri ha ga-eri nʼụbọchị nke asaa, ka ha ga-achịkọta nʼụbọchị nke isii.” 
\p  
\v 6 Mosis na Erọn kpọkọtara ụmụ Izrel sị ha, “Nʼanyasị a ka unu ga-amata na ọ bụ \nd Onyenwe anyị\nd* dupụtara unu site nʼala Ijipt.  
\v 7 Unu ga-ahụkwa ebube \nd Onyenwe anyị\nd* nʼụtụtụ echi, nʼihi na \nd Onyenwe anyị\nd* anụla ntamu unu megide ya. Onye ka anyị bụ unu ga-eji na-atamu ntamu megide anyị?”  
\v 8 Mosis kwukwara sị, “Mgbe \nd Onyenwe anyị\nd* nyere unu anụ unu ga-eri nʼanyasị a, nyekwa unu achịcha ga-eju unu nʼụtụtụ, unu ga-amata na ọ bụ \nd Onyenwe anyị\nd*, nʼihi ọ nụla ntamu unu megide ya. Onye ka anyị bụ? Ọ bụghị anyị ka unu na-atamu megide kama ọ bụ \nd Onyenwe anyị\nd* ka unu na-atamu megide.” 
\p  
\v 9 Mgbe ahụ, Mosis gwara Erọn okwu sị ya, “Gwa nzukọ Izrel niile okwu sị ha, ‘Pụtanụ bịa nʼihu \nd Onyenwe anyị\nd*, nʼihi na ọ nụla ntamu unu.’ ” 
\p  
\v 10 Mgbe Erọn nọ na-agwa nzukọ Izrel okwu, ha lepụrụ anya nʼọzara hụ ebube \nd Onyenwe anyị\nd* ka ọ pụtara ihe nʼigwe ojii. 
\p  
\v 11 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 12 “Anụla m ntamu nke ụmụ Izrel na-atamu. Gwa ha sị, ‘Nʼanyasị taa, unu ga-ata anụ, nʼụtụtụ echi unu ga-eri achịcha. Mgbe ahụ, unu ga-amata na abụ m \nd Onyenwe anyị\nd* Chineke unu.’ ” 
\p  
\v 13 Nʼoge uhuruchi ụbọchị ahụ, nnụnụ kweel\f + \fr 16:13 \ft Ya bụ ọkụkụ ọgazị\f* bịara kpuchie ọmụma ụlọ ikwu ahụ. Nʼisi ụtụtụ echi ya, igirigi dakwara gburugburu ọmụma ụlọ ikwu ahụ.  
\v 14 Mgbe ala kọrọ mmiri igirigi ahụ, ihe dịka achịcha mbadamba nta jupụtara nʼala ọzara ahụ niile.  
\v 15 Mgbe ụmụ Izrel hụrụ ya, ha jụrịtara onwe ha ajụjụ sị, “Gịnị bụ nke a?” 
\p Mosis zaghachiri ha sị, “Ọ bụ achịcha \nd Onyenwe anyị\nd* nyere unu ka unu rie.  
\v 16 Ihe ndị a bụ iwu \nd Onyenwe anyị\nd* nyere, ‘Ka onye ọbụla chịkọta naanị nke ọ ga-ericha. Ihe ọtụtụ ọmaa\f + \fr 16:16 \ft Ya bụ ihe ruru otu kilogram na ụma anọ\f* maka otu onye dịka ọnụọgụgụ ha si dị nʼezinaụlọ.’ ” 
\p  
\v 17 Ụmụ Izrel mere dịka a gwara ha, ụfọdụ chịkọtara nke hiri nne, ụfọdụ nke dị nta.  
\v 18 Mgbe ha ji ihe ọtụtụ ọmaa tụọ ya, ha chọpụtara na onye chịkọtara hie nne enweghị karịa nke zuru ya, onye chịkọtakwara nke nta, ọ dịghị ihe fọdụrụ ya inweta. Onye ọbụla chịkọtara dị ka ihe ga-ezuru ya si dị. 
\p  
\v 19 Mosis gwara ha sị, “Ka onye ọbụla hụ na o nweghị nke ga-afọdụ ruo ụtụtụ echi ya.” 
\p  
\v 20 Ma ụfọdụ nʼime ha egeghị Mosis ntị. Ha rifọrọ nri ahụ debe ya. Ma mgbe chi echi ya bọrọ, ha chọpụtara na ha ereela ure jupụta nʼikpuru, ma na-esikwa isi dị njọ. Mosis were iwe dị ukwuu megide ụmụ Izrel nʼihi ya. 
\p  
\v 21 Site nʼụbọchị ahụ, gaa nʼihu, ezinaụlọ ọbụla na-ewebata nri nʼụtụtụ ọbụla, dịka mkpa ha siri dị. Mgbe anwụ wara, nri ahụ niile fọdụrụ na-agbaze.  
\v 22 Nʼụbọchị nke isii, ha na-ewere nri okpukpu abụọ karịa ka ha na-ewe nʼụbọchị ndị ọzọ. Mgbe ndịisi nzukọ Izrel hụrụ mgbanwe dị otu a, ha bịara kọọrọ Mosis.  
\v 23 Mosis zara sị ha, “Nke a bụ iwu \nd Onyenwe anyị\nd* nyere: ‘Ụbọchị echi bụ ụbọchị izuike, ụbọchị nke asaa dị nsọ nye \nd Onyenwe anyị\nd*. Ya mere, sienụ ihe niile unu nwere isi taa, nʼihi na unu agaghị esi ihe ọbụla echi. Nri ọbụla unu rifọrọ, hapụnụ ya ka ọ bụrụ nri unu ga-eri echi.’ ” 
\p  
\v 24 Ha mere dịka Mosis gwara ha. Mgbe chi echi bọrọ, ha chọpụtara na nri ha dị mma dịkwa ụtọ, ikpuru adịghịkwa nʼime ya.  
\v 25 Mosis gwara ha sị, “Nke a ga-abụ ihe oriri unu taa, nʼihi na ọ bụ ụbọchị izuike nye \nd Onyenwe anyị\nd*. Ọ dịghị nri unu ga-ahụ nke unu ga-achịkọta taa.  
\v 26 Abalị isii ka unu ga-achịkọta nri unu ga-eri. Ma nʼabalị nke asaa bụ ụbọchị izuike, unu agaghị ahụ nri unu ga-achịkọta.” 
\p  
\v 27 Ụfọdụ lefuru ọkwa ahụ Mosis maara ha anya. Ha pụrụ nʼụbọchị izuike ahụ ịchọ nri, ma o nweghị nke ha nwetara.  
\v 28 Nʼihi nke a, \nd Onyenwe anyị\nd* jụrụ Mosis ajụjụ sị ya, “Ruo ole mgbe ka unu ga-anọgide na-enupu isi nʼiwu m na ịdọ aka na ntị m?  
\v 29 Lee, \nd Onyenwe anyị\nd* enyela unu ụbọchị izuike. Ya mere, nʼụbọchị nke isii ọ na-enye unu nri ga-ezuru unu abalị abụọ. Onye ọbụla nʼime unu kwesiri ịnọgide nʼụlọ unu. Unu ekwesighị ịpụ apụ.”  
\v 30 Nʼihi nke a, ndị Izrel niile zuru ike nʼụbọchị nke asaa. 
\p  
\v 31 Ndị Izrel kpọkwara aha nri ahụ ha na-achịkọta mánà. Ọ dị ọcha dịka mkpụrụ kọrianda. Ọ na-atọkwa ụtọ dịka achịcha e ji mmanụ aṅụ mee.  
\v 32 Emesịa, Mosis gara nʼihu gwa ha okwu sị, “\nd Onyenwe anyị\nd* enyela iwu sị, ‘Na unu ga-eji ihe ọtụtụ ọmaa tụpụta mánà nke unu ga-edebe. Ọ ga-abụ ihe ncheta ga-adịrị ọgbọ ndị Izrel niile na-abịa nʼihu. Nʼụzọ dị otu a, ụmụ unu ga-ahụ ụdị achịcha m jiri zụọ unu nʼime ọzara mgbe m gbapụtara unu site nʼala ndị Ijipt.’ ” 
\p  
\v 33 Nʼihi nke a, Mosis nyere Erọn iwu sị ya, “Tụrụ ọtụtụ ọmaa mánà tinye ya nʼime ite nta. Bute ya debe ya nʼihu \nd Onyenwe anyị\nd*, ka ọ bụrụ ihe ga-adịgide nye ọgbọ dị nʼihu.” 
\p  
\v 34 Emesịa, Erọn dọnyere mánà a nʼihu Ihe Ama e debere nʼime ụlọ ikwu, dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu.  
\v 35 Ndị Izrel niile riri mánà ndị a iri afọ anọ\f + \fr 16:35 \ft Mánà kwụsịrị isi nʼelu dara ụmụ Izrel, mgbe ha mesịrị mmemme oriri achịcha na-ekoghị eko nʼala Kenan. \xt Jos 5:10-12\f* tutu ruo mgbe ha batara nʼala ebe ndị mmadụ bi, tutu ruo mgbe ha bịarutere nʼoke ala Kenan. 
\p  
\v 36 (Ihe ọtụtụ ọmaa bụ otu ọtụtụ nʼime ọtụtụ iri nke ga-eju ihe ọtụtụ efaf.) 
\c 17  
\s1 Mmiri si na nkume 
\p  
\v 1 Ọgbakọ ụmụ Izrel niile sitere nʼọzara Sin bilie ije ha, na-aga site nʼotu ebe ruo nʼebe ọzọ dịka \nd Onyenwe anyị\nd* nyere nʼiwu. Ha mara ụlọ ikwu ha na Refidim, ma ọ dịghị mmiri dị nke ndị mmadụ ga-aṅụ.  
\v 2 Nʼihi nke a, ha sesịrị Mosis okwu, sị, “Nye anyị mmiri ka anyị ṅụọ.” 
\p Mosis zara, sị, “Gịnị mere unu ji esesị m okwu? Gịnị mere unu ji chọọ ịnwapụta ntachiobi \nd Onyenwe anyị\nd*?” 
\p  
\v 3 Ma akpịrị mmiri kpọrọ ndị a nkụ nʼebe ahụ, nke a mere ka ha tamuo ntamu megide Mosis. Ha sịrị, “Ọ bụkwa nʼihi gịnị ka i ji site nʼobodo Ijipt kpọpụta anyị, ime ka anyị, ụmụntakịrị anyị na anụ ụlọ anyị nwụọ nʼihi akpịrị ịkpọ nkụ?” 
\p  
\v 4 Nʼihi ya, Mosis tikuru \nd Onyenwe anyị\nd* mkpu akwa sị, “Gịnị ka m ga-eme banyere ndị a. Lee, ha chọrọ itugbu m na nkume.” 
\p  
\v 5 Ma \nd Onyenwe anyị\nd* zaghachiri Mosis, sị ya, “Gaa nʼihu ndị a, kpọrọ ụfọdụ nʼime ndị okenye Izrel. Jirikwa mkpanaka ahụ nʼaka gị, bụ nke i tiri nʼelu osimiri Naịl gaa.  
\v 6 Lee, Aga m eguzo nʼihu gị nʼakụkụ nkume dị na Horeb. Ị ga-akụ mkpara gị nʼelu nkume ahụ. Mmiri ga-asọpụtakwa site na ya, ka ndị mmadụ ṅụọ.” Ya mere, Mosis mere otu a nʼihu ndị okenye Izrel niile.  
\v 7 Nʼihi nke a, ọ kpọrọ aha ebe ahụ Masa na Meriba nʼihi esemokwu ụmụ Izrel na nʼihi nwale ha nwalere \nd Onyenwe anyị\nd*, na-asị, “\nd Onyenwe anyị\nd* ọ nọnyeere anyị, ka ọ bụ na ọ nọnyereghị anyị?” 
\s1 Mmeri e meriri ndị Amalek nʼagha 
\p  
\v 8 Ndị Amalek\f + \fr 17:8 \ft Ndị Amalek bụ ụmụ ụmụ Ịsọ, \xt Jen 36:12\ft  Ha bụ ndị ọjọọ, na-apụnara ndị mmadụ na-aga nʼọzara ihe nʼike.\f* bịara lụso ụmụ Izrel agha na Refidim.  
\v 9 Mosis gwara Joshua okwu sị ya, “Họpụta ụfọdụ ndị ikom ka ha gaa lụso ndị Amalek agha. Echi, mụ onwe m ga-eguzoro nʼelu ugwu, jidekwa mkpara Chineke nʼaka m.” 
\p  
\v 10 Ya mere, Joshua pụrụ gaa lụso ndị Amalek agha dịka Mosis gwara ya. Ma Mosis na Erọn na Hua, rigoro nʼelu ugwu ahụ.  
\v 11 Ndị Izrel na-enwe mmeri mgbe ọbụla Mosis weliri aka ya elu, ma ndị Amalek na-emeri mgbe ọbụla Mosis wedatara aka ya.  
\v 12 Mgbe ike gwụrụ aka Mosis, ha butere nkume tinye nʼokpuru ya mee ka ọ nọkwasị nʼelu ya. Erọn na Hua jidere aka Mosis abụọ welie ya elu, otu onye nʼakụkụ a, onye nke ọzọ nʼakụkụ nke ọzọ. Ime ka aka Mosis guzosie ike tutu ruo mgbe anwụ dara.  
\v 13 Nʼihi nke a, Joshua na ndị agha ya meriri ndị agha Amalek site nʼiji mma agha gbuo ha. 
\p  
\v 14 Emesịa, \nd Onyenwe anyị\nd* sịrị Mosis, “Dee ihe niile ndị a nʼakwụkwọ, ka ọ bụrụ ihe ncheta. Gụgharịakwa ya na ntị Joshua. Nʼihi na aga m ehichapụ ihe niile a ga-eji cheta Amalek nʼelu ụwa.” 
\p  
\v 15 Mosis wuru ebe ịchụ aja nye \nd Onyenwe anyị\nd*. Ọ kpọrọ ya \nd Onyenwe anyị\nd* Nisi, nke pụtara, \nd Onyenwe anyị\nd* bụ ọkọlọtọ m.  
\v 16 Mosis sịrị, “Nʼihi na-eweliri aka elu nʼebe ocheeze \nd Onyenwe anyị\nd* dị. \nd Onyenwe anyị\nd* ga na-ebuso ndị Amalek agha site nʼọgbọ ruo nʼọgbọ.” 
\c 18  
\s1 Ndụmọdụ Jetro 
\p  
\v 1 Mgbe ihe ndị a gasịrị, Jetro, nna nwunye Mosis, onye bụkwa onye nchụaja Midia, nụrụ banyere ihe niile Chineke meere Mosis na Izrel ndị nke ya, na ụzọ \nd Onyenwe anyị\nd* si napụta Izrel site nʼaka ndị Ijipt. 
\p  
\v 2 Jetro ọgọ nwoke Mosis kpọọrọ Zipọra, nwunye Mosis, mgbe Mosis chụlara ya  
\v 3 na ụmụ ya ndị ikom abụọ. Aha nwa ya nke mbụ bụ Geshọm, nke pụtara, abụ m ọbịa na mba ọzọ.  
\v 4 Aha nwa nwoke nke abụọ bụ Elieza, nke bụ, \nd Onyenwe anyị\nd* bụ onye inyeaka m. Nʼihi na mgbe Mosis mụrụ Elieza o kwuru sị, “Chineke nna m bụ onye inyeaka m, nʼihi na ọ napụtara m site na mma agha Fero.” 
\p  
\v 5 Jetro, ọgọ nwoke Mosis, bịakwutere ha nʼime ọzara. O dutere ụmụ ndị ikom Mosis abụọ na nwunye Mosis. Nʼoge ahụ, Mosis na ụmụ Izrel mara ụlọ ikwu ha nʼakụkụ ugwu Chineke.  
\v 6 O ziri Mosis ozi sị, “Mụ bụ Jetro ọgọ gị nwoke bịakwutere gị, nwunye gị na ụmụ gị abụọ sokwa m.” 
\p  
\v 7 Nʼihi ya, Mosis gara zute ọgọ ya nwoke, kpọọ isiala nye ọgọ ya, sutu ya ọnụ. Emesịa, ọ kpọbatara ha nʼime ụlọ ikwu ya. Jetro na ọgọ ya Mosis kwurịtara okwu, jụọ ihe banyere otu ihe si agara ibe ha.  
\v 8 Mosis kọọrọ nna nwunye ya ihe niile \nd Onyenwe anyị\nd* mere Fero na ndị Ijipt niile nʼihi ndị Izrel. Ọ kọkwaara ya banyere ihe ndakwasị niile dakwasịrị ha nʼime ọzara, na otu \nd Onyenwe anyị\nd* si napụta ha. 
\p  
\v 9 Jetro soro Mosis ṅụrịa ọṅụ nke ukwuu nʼihi ihe niile \nd Onyenwe anyị\nd* meere ndị Izrel, na otu o siri napụta ha site nʼaka ndị Ijipt.  
\v 10 Jetro kwuru sị, “Onye a gọziri agọzi ka \nd Onyenwe anyị\nd* bụ. Onye napụtara unu site nʼaka ndị Ijipt na site nʼaka Fero.  
\v 11 Ugbu a, amaara m na \nd Onyenwe anyị\nd* kachasị chi ndị ọzọ niile elu, nʼihi na ọ zọpụtara ndị ya site nʼaka ndị Ijipt ndị sitere na mpako ha meso Izrel mmeso.”  
\v 12 Jetro, nna nwunye Mosis chụọrọ Chineke aja nsure ọkụ na aja ndị ọzọ. Emesịa, Erọn na ndị okenye Izrel bịara soro Mosis na ọgọ ya nwoke rie ihe nʼihu Chineke. 
\p  
\v 13 Nʼụbọchị nke ọzọ ya, Mosis bịara nọdụ ala ikpere ndị mmadụ ikpe. Igwe mmadụ nọgidere Mosis site nʼụtụtụ ruo nʼanyasị.  
\v 14 Ọgọ Mosis hụrụ ihe niile ọ na-emere ndị mmadụ, nke a mere na ọ jụrụ, “Gịnị bụ ihe nke a ị na-emere ndị a? Gịnị mere i ji nọdụ ala naanị gị, ndị a niile gbaa gị gburugburu malite nʼụtụtụ ruo nʼanyasị?” 
\p  
\v 15 Mosis zara nna nwunye ya sị, “Nʼihi na ha bịara ịjụta m ihe si nʼaka Chineke.  
\v 16 Ọ bụrụ na esemokwu adịrị nʼetiti mmadụ ọbụla na ibe ya, ha na-abịakwute m, ka m kpebie ihe dị nʼetiti mmadụ na ibe ya. Ana m eme ka ha mata iwu na ụkpụrụ Chineke.” 
\p  
\v 17 Mgbe Jetro, nna nwunye Mosis, nụrụ ihe ndị a niile, ọ sịrị Mosis, “Ihe ị na-eme adịghị mma.  
\v 18 Ike ga-agwụ gị, gwụkwa igwe mmadụ ndị a. Ọrụ a ị na-arụ dị ukwuu karịa gị. Naanị gị agaghị ebuli ya.  
\v 19 Ugbu a, gee m ntị. M ga-adụ gị ọdụ, ka Chineke nọnyekwara gị. Ọ ga-adị mma ma ọ bụrụ na ị bụ onye na-anọchi anya ndị a nʼihu Chineke. Nʼụzọ dị otu a, i nwere ike iweta nsogbu niile ha nwere nʼihu Chineke.  
\v 20 Ihe ọzọ ị ga-eme bụ nke a: ị ga-akụziri ha iwu na ụkpụrụ Chineke, gosikwa ha ụzọ ha ga-esi bie ndụ, na ọrụ ha kwesiri ịrụ.  
\v 21 Ma site nʼetiti ndị a họpụta ndị ikom tozuru, ndị ikom na-atụ egwu Chineke, ndị kwesiri ntụkwasị obi na ndị kpọrọ uru nʼezighị ezi\f + \fr 18:21 \ft Ya bụ ndị na-enweghị anya ukwu\f* asị. Mee ha ndịisi na-achị imerime puku ndị mmadụ, ndịisi narị mmadụ, ndịisi iri mmadụ ise na ndịisi mmadụ iri.  
\v 22 Mee ka ha bụrụ ndị ikpe nye ndị mmadụ oge niile. Nye iwu ka ha na-ewetara gị okwu dịkarịsịrị ike, ma na-ekpe ikpe gbasara okwu dị mfe na ndị ọzọ niile dị iche iche. Nʼụzọ dị otu a, ndị ikpe ndị ahụ ga-enyere gị aka ime ka ibu arọ gị dị mfe.  
\v 23 Ọ bụrụ na ị ga-eme ihe niile ndị a, ọ bụrụkwa na Chineke ekwenye, ị ga-enwe ike nagide nsogbu niile. Mmadụ niile ga-ewere udo na ọṅụ birikwa.” 
\p  
\v 24 Mosis gere ntị nʼihe niile nna nwunye ya gwara ya. O mekwara ihe niile o kwuru.  
\v 25 O sitere nʼetiti ụmụ Izrel họpụta ndị kwesiri ekwesi mee ka ha bụrụ ndịisi. Ụfọdụ ka o mere ndịisi na-elekọta imerime puku mmadụ, ụfọdụ na-achị narị mmadụ, ụfọdụ, iri mmadụ ise, ụfọdụ, mmadụ iri.  
\v 26 Ha jere ozi dịka ndị ikpe nye ndị mmadụ nʼoge niile. Ha na-ewetara Mosis okwu niile siri ike, ma ha onwe ha na-ekpe ikpe banyere okwu nke dịkarịsịrị nta. 
\p  
\v 27 Mgbe ahụ, Mosis zilagara nna nwunye ya. Jetro laghachikwara nʼobodo nke aka ya. 
\c 19  
\s1 Ụmụ Izrel nʼugwu Saịnaị 
\p  
\v 1 Nʼọnwa nke atọ, site nʼoge ndị Izrel hapụchara obodo Ijipt, nʼụbọchị ahụ, ha bịaruru ọzara Saịnaị.  
\v 2 Ọ bụ site na Refidim ka ha sị bịaruo ọzara Saịnaị, mee ebe obibi ha nʼebe ahụ, nʼakụkụ ugwu Saịnaị. 
\p  
\v 3 Mosis rigooro nʼelu ugwu ahụ izute Chineke. Mgbe ahụ, \nd Onyenwe anyị\nd* sitere nʼelu ugwu ahụ kpọ Mosis oku sị ya, “Otu a ka ị ga-esi gwa ụlọ Jekọb okwu. Ị ga-akọrọ ụmụ Izrel:  
\v 4 ‘Unu onwe unu ahụla ihe m mere ndị Ijipt, hụkwa otu m siri buru unu na nku ugo,\f + \fr 19:4 \ft Ọ bụ na nku ka nne ugo na-ebu ụmụ ya ma ọ na-erugharị nʼelu \xt Dit 32:11.\f* si otu a, dọtara unu onwe m.  
\v 5 Nʼihi nke a, ọ bụrụ na unu ga-erubere m isi nke ọma ma debe ọgbụgba ndụ m, unu ga-abụ ihe onwunwe nke m dị oke ọnụahịa. Nʼezie, ụwa niile bụ nke m,  
\v 6 ma unu ga-abụrụ m alaeze ndị nchụaja, na mba dị nsọ.’ Okwu ndị a ka ị ga-agwa ụmụ Izrel.” 
\p  
\v 7 Mosis gara kpọkọta ndị okenye ndị Izrel, gwa ha okwu niile nke \nd Onyenwe anyị\nd* nyere ya nʼiwu.  
\v 8 Ndị mmadụ niile a jikwa otu olu zaghachi ya sị, “Ihe ọbụla \nd Onyenwe anyị\nd* kwuru ka anyị ga-eme.” Mosis gwara \nd Onyenwe anyị\nd* ihe niile ndị Izrel kwuru. 
\p  
\v 9 \nd Onyenwe anyị\nd* gwara Mosis okwu sị, “Lee, agaje m izute gị nʼime igwe ojii gbara ọchịchịrị. Achọrọ m ka ụmụ Izrel niile were ntị ha nụrụ mgbe m ga-agwa gị okwu, ọzọkwa, ka ha kwerekwa na gị ruo mgbe niile.” Mosis gwara ndị Izrel niile okwu nke \nd Onyenwe anyị\nd* gwara ya. 
\p  
\v 10 \nd Onyenwe anyị\nd* gwara Mosis okwu ọzọ sị, “Rịdakwuru ndị m, doo ha nsọ taa na echi. Nʼihi na nke a ga-abụ nkwado ha izute m. Ka ha saa uwe ha mmiri,  
\v 11 jikerekwa nʼụbọchị nke atọ. Nʼihi na m ga-arịdata nʼelu ugwu Saịnaị nʼihu mmadụ niile.  
\v 12 Ị ga-akpa oke nʼebe ha na-agaghị agafe. Nye ha iwu si ha, ‘Kpacharanụ anya ka unu ghara ịbịa ugwu ahụ nso, maọbụ metụ ala ugwu ahụ aka. Nʼihi na onye ọ bụla metụrụ ugwu ahụ aka aghaghị ịnwụ.’  
\v 13 Agaghị emetụ onye mmebi iwu ahụ aka, kama, a ga-eji nkume tugbuo ya, maọbụ e were àkụ gbagbuo ya, maọbụ mmadụ maọbụ anụmanụ, ọ gaghị adị ndụ. Mmadụ ọbụla agaghị abịaru ugwu ahụ nso, ruo mgbe ha nụrụ opi nke a ga-afụ. Mgbe ahụ, ha nwere ike bịa nso ugwu ahụ.”\f + \fr 19:13 \ft Erọn na ụmụ ya ndị ikom abụọ, na iri ndị okenye Izrel asaa ahụ nwere ike irigoro ugwu ahụ. \xt Ọpụ 24:1,9-10.\f* 
\p  
\v 14 Ya mere, Mosis si nʼugwu ahụ rịdakwuru ụmụ Izrel. O doo ndị mmadụ ahụ nsọ. Ha niile ji mmiri saa uwe ha.  
\v 15 Mosis dọrọ ha aka na ntị sị ha, “Jikerenụ nʼụbọchị nke atọ. Nwoke na nwanyị enwekwala mmekọrịta ọbụla.” 
\p  
\v 16 Mgbe o ruru nʼụtụtụ ụbọchị nke atọ ahụ, oke igwe ojii kpuchiri elu ugwu ahụ. Amụma malitere na-egbuke, egbe eluigwe malitekwara ịgba. Nʼikpeazụ, opi ike dara. Mmadụ niile tụrụ egwu, makwa jijiji.  
\v 17 Mosis duuru ndị mmadụ ahụ niile si nʼụlọ ikwu ha pụta gaa izute Chineke. Ha niile guzokwara nʼala ugwu ahụ.  
\v 18 Mgbe ahụ, anwụrụ ọkụ kpuchiri ugwu Saịnaị. Ma lee! \nd Onyenwe anyị\nd* rịdatara dịka ire ọkụ nʼelu ugwu ahụ. Anwụrụ ọkụ rigoro elu dịka anwụrụ ọkụ nke ọhịa na-ere ọkụ. Ala ọma jijiji dị ukwuu dakwasịkwara ugwu ahụ.  
\v 19 Mgbe opi ike ahụ na-ada ike ike, Mosis malitere ịgwa Chineke okwu. Chineke zaghachiri Mosis okwu site nʼolu dara ụda dịka egbe eluigwe. 
\p  
\v 20 \nd Onyenwe anyị\nd* rịdatara bịaruo nʼelu ugwu Saịnaị. Ọ gwara Mosis ka ọ rịgota bịa zute ya. Mosis rigoro nʼelu ugwu ahụ ijekwuru Chineke.  
\v 21 \nd Onyenwe anyị\nd* gwara Mosis okwu sị, “Rịda gaa dọọ ndị mmadụ ahụ aka na ntị ka ha ghara ịgafe oke ala ahụ bịaruo nso ịhụ \nd Onyenwe anyị\nd* anya ka ha ghara ịla nʼiyi.  
\v 22 Ọ bụladị ndị nchụaja ndị chọrọ ịbịaru \nd Onyenwe anyị\nd* nso aghaghị ido onwe ha nsọ. Ma ọ bụghị otu a, \nd Onyenwe anyị\nd* ga-eme ka ha niile nwụọ.” 
\p  
\v 23 Mosis zaghachiri \nd Onyenwe anyị\nd* sị, “Ndị mmadụ agaghị arịgota nʼugwu Saịnaị nʼihi na gị onwe gị adọọla anyị aka na ntị sị, ‘Kpaanụ oke gburugburu ugwu a, doo ya nsọ.’ ” 
\p  
\v 24 Ma \nd Onyenwe anyị\nd* gwara Mosis okwu sị: “Gbada gaa kpọgota Erọn ka gị na ya soro rigota nʼelu ugwu a. Ma lezie anya ka ndị nchụaja na ndị Izrel ghara irigota nʼebe a ịbịakwute \nd Onyenwe anyị\nd*, ma ọ bụghị otu a, ọ ga-eji ike laa ha nʼiyi.” 
\p  
\v 25 Ya mere, Mosis rịdakwuru ndị Izrel ga gwa ha. 
\c 20  
\s1 Iwu Iri 
\p  
\v 1 Chineke kwuru okwu ndị a niile sị: 
\b  
\li4  
\v 2 “Mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke unu, onye kpọpụtara unu site nʼIjipt, bụ ala nke ibu ohu. 
\b  
\li1  
\v 3 “Ị gaghị enwe chi ọzọ tinyere m. 
\li1  
\v 4 Gị emerela onwe gị arụsị a pịrị apị, nʼoyiyi nke ụdị ọbụla nke yiri ihe dị nʼeluigwe maọbụ nke yiri ihe dị nʼụwa, nʼokpuru ya maọbụ nʼime mmiri, nʼokpuru ụwa.  
\v 5 Gị akpọla isiala nye ha, efekwala ha ofufe, nʼihi na Mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke gị, abụ m Chineke ekworo. Onye na-ata ụmụ na ụmụ ụmụ ahụhụ, nʼihi ajọ omume nke ndị mụrụ ha, ọ bụladị ruo nʼọgbọ nke atọ na nke anọ, nke ndị ahụ kpọrọ m asị.  
\v 6 Ma na egosi ịhụnanya nye puku ọgbọ niile nke ndị hụrụ m nʼanya, bụ ndị na-edebe ihe niile m nyere nʼiwu. 
\li1  
\v 7 Gị ejikwala aha \nd Onyenwe anyị\nd* bụ Chineke gị eme ihe efu, nʼihi na \nd Onyenwe anyị\nd* agaghị agụ onye ji aha ya eme ihe efu dịka onye ikpe na-amaghị. 
\li1  
\v 8 Cheta ụbọchị izuike site nʼido ya nsọ.  
\v 9 Nʼime ụbọchị isii ka ị ga-eje ozi gị niile. Ọ bụkwa nʼime ha ka ị ga-arụzu ọrụ gị niile.  
\v 10 Ma ụbọchị nke asaa bụ ụbọchị izuike nke \nd Onyenwe anyị\nd* Chineke gị. Ị gaghị arụ ọrụ ọbụla nʼụbọchị ahụ, gị onwe gị, nwa gị nwoke na nwa gị nwanyị, onye ọrụ gị nwoke, onye ọrụ gị nwanyị, maọbụ anụ ụlọ gị ọbụla, ọbụladị onye ọbịa bi nʼobodo gị.  
\v 11 Nʼihi na ọ bụ nʼime ụbọchị isii ka \nd Onyenwe anyị\nd* kere eluigwe na ụwa, na oke osimiri, na ihe niile dị nʼime ha. O zuru ike nʼụbọchị nke asaa. Nʼihi nke a \nd Onyenwe anyị\nd* gọziri ụbọchị nke asaa doo ya nsọ, ka ọ bụrụ ụbọchị izuike. 
\li1  
\v 12 Sọpụrụ nne gị na nna gị, dịka \nd Onyenwe anyị\nd* Chineke gị nyere gị nʼiwu, ka ụbọchị ndụ gị dị ogologo nʼala ahụ nke \nd Onyenwe anyị\nd* Chineke gị na-enye gị. 
\li1  
\v 13 Gị egbula mmadụ. 
\li1  
\v 14 Gị akwala iko. 
\li1  
\v 15 Gị ezula ohi. 
\li1  
\v 16 Agbala ama ụgha megide onye agbataobi gị. 
\li1  
\v 17 Gị enwela anya ukwu nʼebe ụlọ onye agbataobi gị dị. Gị enwekwala anya ukwu nʼebe nwunye onye agbataobi gị dị, maọbụ ohu ya nwoke maọbụ ohu ya nwanyị, ehi ya maọbụ ịnyịnya ibu ya, ma ọ bụkwanụ nʼihe ọbụla nke onye agbataobi gị nwere dị.” 
\b  
\p  
\v 18 Mgbe ndị Izrel hụrụ egbe eluigwe, na amụma ọkụ, na opi ike, hụkwa ugwu ahụ ka o jupụtakwara nʼanwụrụ ọkụ, ha mara jijiji nʼihi egwu. Ha guzoro nʼebe dị anya,  
\v 19 sị Mosis, “Biko ka gị onwe gị gwa anyị okwu, anyị ga-anụ ma ka Chineke gharakwa ịgwa anyị okwu, ma ọ bụghị ya, anyị ga-anwụ.” 
\p  
\v 20 Mosis sịrị ndị Izrel, “Unu atụkwala ụjọ, nʼihi na Chineke bịara ịnwale unu ime ka unu na-atụ ya egwu mgbe ọbụla ka unu ghara imehie megide ya.” 
\p  
\v 21 Nʼihi nke a, mmadụ niile guzoro nʼebe dị anya site nʼugwu ahụ. Ma Mosis bara nʼime igwe ojii ahụ, ebe Chineke nʼonwe ya nọ. 
\s1 Iwu megidere ikpere arụsị 
\p  
\v 22 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya, “Gwa ụmụ Izrel okwu sị, ‘Unu onwe unu ahụla na m si nʼeluigwe gwa unu okwu.  
\v 23 Unu emerela onwe unu chi ọzọ tinyere m, chi ọlaọcha maọbụ chi ọlaedo. Unu emerela onwe unu ha. 
\p  
\v 24 “ ‘Ebe ịchụ aja unu ga-ewuru m ga-abụ nke unu ji naanị aja wuo. Nʼebe ahụ ka unu ga-achụrụ m aja nsure ọkụ na aja udo. Unu ga-ejikwa igwe ewu na atụrụ, na ehi chụọrọ m aja. Unu ga-ewuru m ebe ịchụ aja naanị ebe ọbụla m mere ka aha m bụrụ ihe a na-asọpụrụ, nʼebe ahụ ka m ga-abịa gọzie unu.  
\v 25 Ọ bụrụ na unu ewuo ebe ịchụ aja nkume, unu ejikwala nkume a wara awa, nʼihi na unu ga-eme ka ọ ghara ịdị nsọ ma ọ bụrụ na unu ejiri ngwa ọrụ wagharịa nkume ya.  
\v 26 Unu ejila ihe nrigo gbagoro nʼebe ịchụ aja m, ka a ghara ikpughe ọtọ unu nʼelu ya.’ 
\c 21  
\s1 Iwu ndị ọzọ dị iche iche 
\p  
\v 1 “Ndị a bụ iwu ị ga-edebe nʼihu ha. 
\s1 Ndị ohu bụ ndị Hibru 
\p  
\v 2 “Ọ bụrụ na ị goro ohu onye Hibru, ọ ga-agbara gị odibo afọ isii. Ma nʼafọ nke asaa, ọ ga-abụ onye nwere onwe ya laakwa nʼakwụghị ụgwọ ọbụla.  
\v 3 Ọ bụrụ na sọọsọ ya bịara, sọọsọ ya ga-ala, ma ọ bụrụ na o nwere nwunye tupu ọ bụrụ ohu, ya na nwunye ya ga-eso ala.  
\v 4 Ọ bụrụ na nna ya ukwu kpọnyere ya nwunye onye mụtaara ya ụmụ ndị ikom na ụmụ ndị inyom, nwanyị ahụ na ụmụ ya ga-abụ nke nna ya ukwu, naanị nwoke ahụ ga-enwere onwe ya. 
\p  
\v 5 “Ma ọ bụrụ na ohu ahụ asị, nʼezie, ‘Ahụrụ m onyenwe m na nwunye m na ụmụ m nʼanya, achọghị m inwere onwe,’  
\v 6 mgbe ahụ, onyenwe ya ga-eduru ya bịakwute Chineke. Mgbe ọ kpọbatasịrị ya nʼọnụ ụzọ, onyenwe ya ga-eji agịga dupuo ntị ya.\f + \fr 21:6 \ft Otu omenaala ndị ala Siria na mba niile bi ha gburugburu na-eme, bụ iji agịga dupuo mmadụ ntị. Mgbe a dụpuru mmadụ ntị, o na-egosipụta na onye dị otu a bụ ohu onye ọzọ.\f* Malite nʼoge ahụ, ọ ga-abụkwa ohu ya ruo ọgwụgwụ ndụ ya. 
\p  
\v 7 “A sị na nwoke eree nwa ya nwanyị dịka ohu, agaghị ala otu ndị ohu nwoke si ala.  
\v 8 Ọ bụrụ na ihe nwanyị ahụ amasịkwaghị onyenwe ya, onye họọrọ ya nye onwe ya, onyenwe ya ga-ekwere ka a gbapụta ya. Ma ọ gaghị eresi ya ndị ọbịa. Nʼihi na onyenwe ya emeela nwanyị ahụ ihe ọjọọ mgbe ọ jụrụ na ọ gaghị alụkwa ya ọzọ.  
\v 9 Ọ bụrụ na ọ chọrọ ka nwa ya nwoke lụọ ya dịka nwunye ya, ọ ga-emeso ya dịka omenaala si kwado e si emeso ndị bụ nwaada.  
\v 10 Ọ bụrụkwa na ọ lụta ya dịka nwunye nke aka ya, mesịakwa lụta nwunye ọzọ, ọ gaghị akwụsị inye ya uwe maọbụ ihe oriri. Ọ gaghị agọnarịkwa ya ihe ọbụla kwesiri ya dịka nwunye.  
\v 11 Ọ bụrụ na o mereghị ohu nwanyị a ihe ndị a, nwanyị a pụrụ ịhapụ ya gaara onwe ya na-akwụghị ụgwọ ọbụla. Mgbe ahụ, ọ ga-enwerekwa onwe ya. 
\s1 Ihe ike na mmerụ ahụ 
\p  
\v 12 “Ọzọkwa, ọ bụrụ na mmadụ etigbuo mmadụ ibe ya, aghaghị ime ka onye dị otu a nwụọ.  
\v 13 Ma ọ bụrụ na o mere ya na-amaghị ama, ọ bụrụkwa na Chineke kwagidere omume dị otu a, mgbe ahụ, a ga-ahọpụtara ya ebe ọ ga-agbaga, jee zere ndụ.  
\v 14 Ọ bụrụkwa na onye ọbụla akpachara anya jiri aghụghọ gbuo mmadụ ibe ya, a ga-adọpụta ya, ọ bụladị site nʼebe ịchụ aja m, gbuo ya. 
\p  
\v 15 “Ọ bụrụ na onye ọbụla etie nna ya maọbụ nne ya ihe, a ghaghị ime ka onye dị otu a nwụọ. 
\p  
\v 16 “Onye ọbụla tọọrọ mmadụ ibe ya, ma o rere ya nʼahịa, maọbụ na a chọpụtara ya nʼaka ya, a ga-eme ka onye dị otu a nwụọ. 
\p  
\v 17 “Aghaghị ime ka onye ọbụla ga-akpọ nna ya maọbụ nne ya iyi nwụọ. 
\p  
\v 18 “Ọ bụrụ na mmadụ abụọ alụọ ọgụ ma otu nʼime ha ewere nkume maọbụ osisi tie onye nke ọzọ. Ọ bụrụ na ọ nwụghị, kama na o merụrụ ahụ, dinaakwa nʼihe ndina ya,  
\v 19 ọ bụrụ na onye ahụ ebilie were mkpara ya na-ejegharị, ikpe agaghị ama onye ahụ tiri ya ihe, kama ọ ga-akwụ ụgwọ ihe onye ahụ ji gwọọ onwe ya, na oge onye ahụ o tiri ihe ji nọọ nʼihe ndina, ruo mgbe ahụ ya ga-adị mma. 
\p  
\v 20 “Ọ bụrụ na ohu ọbụla anwụọ site nʼihe otiti nke onyenwe ya tiri ya, ma ohu ahụ ọ bụ nwoke maọbụ nwanyị, a ga-adọ onyenwe ya aka na ntị site nʼinye ya ntaramahụhụ.  
\v 21 Otu ọ dị, ọ bụrụ na ohu ahụ dị ndụ nʼụbọchị mbụ, maọbụ nʼụbọchị nke abụọ, a gaghị enye onyenwe ya ntaramahụhụ nʼihi na ohu ahụ bụ akụ ya. 
\p  
\v 22 “Ọ bụrụ na mmadụ abụọ esite nʼịlụ ọgụ ha merụọ nwanyị dị ime ahụ, mee ka ime ahụ pụọ, ma nwanyị ahụ emerụghị nnukwu ahụ, di nwanyị ahụ ga-anara site nʼaka onye ahụ merụrụ nwunye ya ahụ ihe niile ọbụla o kwuru na a ga-akwụ ya, bụkwa nke ndị na-ekpe ikpe kpebiri.  
\v 23 Ma ọ bụrụ na nwanyị ahụ a nwụọ nʼihi mmerụ ahụ ahụ e merụrụ ya, a ga-eme ka nwoke ahụ merụrụ ya ahụ nwụọ.  
\v 24 Ọ bụrụ na ọ bụ anya ka a kụkpọrọ, anya nʼọnọdụ anya. Ọ bụrụkwa otu eze ka e tipụrụ, eze nʼọnọdụ eze. Otu ahụ kwa, aka nʼọnọdụ aka, ụkwụ nʼọnọdụ ụkwụ.  
\v 25 Ịda ọkụ nʼọnọdụ ịda ọkụ, ọnya mma, nʼọnọdụ ọnya mma, ihe otiti nʼọnọdụ ihe otiti. 
\p  
\v 26 “Ọ bụrụ na mmadụ ọbụla esite nʼihe otiti o tiri ohu ya kụkpọọ ya anya, a ga-eme ka ohu ahụ nwere onwe ya, maọbụ ohu nwoke maọbụ ohu nwanyị, nʼihi na o jirila anya ya gbara onwe ya.  
\v 27 Ọ bụrụ na mmadụ ọbụla etipụ eze ohu ya nwoke maọbụ ohu ya nwanyị, a ga-eme ka ohu ahụ nwere onwe ya nʼihi eze ya nke e tipụrụ. 
\p  
\v 28 “Ọ bụrụ na ehi ejiri mpi ya sọda mmadụ si otu a mee ka onye ahụ nwụọ, a ga-atụgbu ehi ahụ na nkume. Mmadụ ọbụla agaghị erikwa anụ ehi ahụ. Ma a ga-agụ onyenwe ehi ahụ dịka onye ikpe na-amaghị.  
\v 29 Ọ bụrụ na ehi ahụ na-asọkarị ndị mmadụ mpi mgbe niile, agaghị eri anụ ya. Kama, ọ bụrụ na adọọla onyenwe ya aka na ntị banyere ehi ahụ ọtụtụ oge, ma o meghị ihe ọbụla banyere ya, a ga-eme ka ehi ahụ na onyenwe ya nwụọ.  
\v 30 Ma ọ bụrụ na ndị nwe mmadụ achọọ ka a kwụọ ha ụgwọ kama igbu onyenwe ehi ahụ, ndị ikpe ga-ekpebi ego ole onyenwe ehi ga-akwụ ha.  
\v 31 Otu a ka a ga-esikwa kpee ikpe nke ga-apụta ma ọ bụrụ na ehi asọda nwokorobịa maọbụ nwaagbọghọ ọbụla.  
\v 32 Kama ọ bụrụ na ehi asọda ohu nwoke maọbụ ohu nwanyị, onyenwe ehi ahụ ga-akwụ onyenwe ohu ahụ iri mkpụrụ ọlaọcha atọ.\f + \fr 21:32 \ft Iri mkpụrụ ọlaọcha atọ bụ ọnụahịa a na-ere maọbụ jiri zụta ohu. \xt Zek 11:12,13; Mat 26:13; 27:3,9\f* Emesịa, a ga-eji nkume tugbuo ehi ahụ. 
\p  
\v 33 “Ọ bụrụ onye ọbụla meghere olulu maọbụ gwuo olulu, ghara imechi ya, nke mere na ehi mmadụ maọbụ ịnyịnya ibu adaba nʼime ya,  
\v 34 onye ahụ gwuru olulu ahụ ga-akwụ onyenwe anụ ụlọ ahụ ọnụọgụgụ ego o jiri zụta ya. Mgbe ahụ ọ ga-eburu ozu anụ ahụ nwụrụ anwụ. 
\p  
\v 35 “Ọ bụrụ na oke ehi mmadụ emerụọ oke ehi onye ọzọ ahụ, emesịa ehi dị otu a anwụọ, a ga-ere ehi nke dị ndụ, kewaa ego ya ụzọ abụọ. Otu a kwa, a ga-ekewa ehi nke nwụrụ anwụ, nye mmadụ abụọ ahụ otu ụzọ otu ụzọ.  
\v 36 Ọ bụrụ na amaara na oke ehi ahụ na-asọ mpi mgbe niile nʼoge gara aga, ma onyenwe ya emeghị ihe ọbụla banyere ya, ọ ga-akwụzu ụgwọ ehi ahụ nwụrụ anwụ. Emesịa ehi ahụ nwụrụ anwụ ga-abụrụ nke ya. 
\c 22  
\s1 Nchekwa akụ na nkwụghachi 
\p  
\v 1 “Ọ bụrụ na mmadụ ezuru ehi maọbụ atụrụ gbuo ya, maọbụ ree ya, ọ ga-akwụghachi ehi ise nʼọnọdụ ehi ahụ. Nʼọnọdụ otu atụrụ o zuuru, ọ ga-akwụghachi atụrụ anọ. 
\p  
\v 2 “Ọ bụrụ na e jide onye ohi mgbe ọ na-egbuka ụlọ onye ọzọ, ọ bụrụkwa na e tigbuo ya, mee ka ọ nwụọ, iwu ejideghị onye ahụ gburu ya.  
\v 3 Kama ọ bụrụ na e tigburu onye ahụ mgbe chi bọcharala, ọmụma ikpe ga-adịrị onye ahụ tigburu ya. 
\p “Ọ bụrụ na e jide onye ohi, a ga-eme ka ọ kwụghachi ihe o zuru nʼohi. Ọ bụrụ na o nweghị ike kwụghachi, a ga-ere ya dịka ohu, jiri ego e retara kwụọ ụgwọ o ji.  
\v 4 Ọ bụrụ na a chọta ihe o zuru nʼaka ya, maọbụ ehi, maọbụ ịnyịnya ibu, maọbụ atụrụ, ọ ga-akwụghachi ọnụahịa ya okpukpu abụọ. 
\p  
\v 5 “Ọ bụrụ na mmadụ akpachara anya hapụ anụ ụlọ ya ka ọ gaa taa nri nʼubi maọbụ nʼubi vaịnị, maọbụ nʼubi onye ọzọ, onyenwe anụ ụlọ ahụ ga-akwụ ụgwọ ihe niile anụ ụlọ ya mebiri, ma ihe ọ ga-eji kwụọ ụgwọ ahụ aghaghị ịbụ ihe ọrụ ubi dị mma nke o si nʼubi ya maọbụ nʼubi vaịnị ya wepụta. 
\p  
\v 6 “Ọ bụrụ na ọkụ na-agba banye nʼogwu, repịa ogbo ọka dị nʼubi mmadụ maọbụ ọka guzoro eguzo, ma ọ bụkwanụ ọhịa niile, onye ahụ tinyere ọkụ ahụ ga-akwụghachi ụgwọ ihe ahụ niile nke ọkụ repịara.\f + \fr 22:6 \ft Ọ bụ osisi ogwu ogwu puru nʼọhịa ka a na-eji agba ubi ogige maọbụ gbachie ụzọ.\f* 
\p  
\v 7 “Ọ bụrụ na mmadụ enye enyi ya maọbụ onye agbataobi ya ego, maọbụ ihe ọbụla ka o debere ya, ma onye ohi agaa zuru ya site nʼụlọ ya, a si na e jide onye ohi dị otu a, ọ ga-akwụghachi ụgwọ ihe o zuru okpukpu abụọ.  
\v 8 Ọ bụrụ na a chọpụtaghị onye ohi ahụ, onye nwe ụlọ ahụ aghaghị ịbịa nʼihu Chineke, ka a chọpụta maọbụ ya nʼonwe ya setịpụrụ aka were ihe ahụ, bụ akụ nke onye ọzọ kpatara.  
\v 9 Ọ bụrụ na onye ehi ya, maọbụ ịnyịnya ibu ya, maọbụ atụrụ ya, maọbụ uwe, maọbụ ihe ọbụla furu efu, nke mmadụ na-asị, ‘Nke a bụ ya.’ Mmadụ abụọ ndị a ga-aga nʼihu ndị ikpe.\f + \fr 22:9 \ft Maọbụ, \fqa Chineke\f* Onye ọbụla ndị ikpe a mara ikpe\f + \fr 22:9 \ft Bụ ndị nnọchite anya Chineke\f* ga-akwụghachi ibe ya ụgwọ okpukpu abụọ. 
\p  
\v 10 “Ọ bụrụ na anụ ụlọ mmadụ nyere onye agbataobi ya nʼaka idebe anwụọ, maọbụ merụọ ahụ, maọbụ gbafuo, ma anụ ụlọ ahụ ọ bụ ịnyịnya ibu, maọbụ ehi, maọbụ atụrụ, maọbụ anụ ụlọ ọzọ, ọ bụrụ na ọ dịghị onye hụrụ mgbe ihe ndị a dakwasịrị anụ ụlọ ahụ,  
\v 11 mgbe ahụ, onye agbataobi ahụ e nyere anụ ndị a nʼaka idebe ga-aṅụ iyi nʼihu \nd Onyenwe anyị\nd*. Iyi ahụ ọ ṅụrụ ga-egosi onyenwe anụ ụlọ ahụ na o zughị ya nʼohi. Nʼihi nke a, ọ gaghị akwụghachi ụgwọ ọbụla.  
\v 12 Ma ọ bụrụ na o zuru anụ ụlọ ahụ nʼohi site na nke agbataobi ya, ọ ghaghị ịkwụghachi ụgwọ niile nye onyenwe ya.  
\v 13 Ọ bụrụ na anụ ọhịa gburu ya, ọ ga-eweta ụfọdụ nʼime anụ ahụ a dọgburu adọgbu, iji gosi na anụ ọhịa dọgburu ya.\f + \fr 22:13 \ft \xt Jen 31:39\f* Ọ ga-esikwa otu a gbanarị ikpe ọmụma. Nʼihi nke a, ọ gaghị akwụkwa ụgwọ ọbụla nʼihi anụ ụlọ ahụ. 
\p  
\v 14 “Ọ bụrụ na mmadụ agbaziri anụ ụlọ site nʼaka onye agbataobi ya, ọ bụrụ na anụ ụlọ ahụ anwụọ, maọbụ merụọ ahụ mgbe onyenwe ya na-anọghị nʼebe ahụ, onye ahụ a gbazinyere anụ ụlọ ahụ ga-akwụ ụgwọ ya.  
\v 15 Ọ bụrụ na anụ ụlọ ahụ nọ na nke onyenwe ya, onye gbaziri ya agaghị akwụ ụgwọ ọbụla. Ọ bụrụ na a kwụrụ ego mgbazi ọbụla nʼisi anụmanụ a, onye gbaziri ya agaghị akwụghachi ego ọbụla, nʼihi na ego mgbazi ọ kwuru ka a ga-ewere dịka ụgwọ. 
\s1 Ibi ndụ dị ka o kwesiri 
\p  
\v 16 “Ọ bụrụ na nwoke arafuo nwaagbọghọ na-amaghị nwoke,\f + \fr 22:16 \ft \xt Dit 22:28-29\f* site nʼime ka ha abụọ dinaa, nwoke ahụ ga-akwụ ụgwọ isi nwaagbọghọ ahụ. Ọ ga-alụkwa ya dịka nwunye ya.  
\v 17 Ọ bụrụ na nna nwaagbọghọ ahụ ekwenyeghị ka nwoke ahụ lụọ ya, nwoke ahụ aghaghị ịkwụ ụgwọ isi nwaagbọghọ ahụ. 
\p  
\v 18 “E kwesighị ịhapụ nwanyị mgbaasị ndụ. 
\p  
\v 19 “Onye ọbụla ya na anụ ọbụla dinakọrọ, e kwesiri ime ka ọ nwụọ. 
\p  
\v 20 “Onye ọbụla chụrụ aja nye chi ọzọ ma ọ bụghị naanị \nd Onyenwe anyị\nd*, a ga-eme ka ọ nwụọ. 
\p  
\v 21 “Ọ kwesighị ka mmadụ ọbụla mesie onye ọbịa ihe ike nʼụzọ ọbụla. Unu aghaghị icheta na unu bụ ndị ọbịa nʼala Ijipt. 
\p  
\v 22 “Unu emegbula nwanyị ọbụla di ya nwụrụ, maọbụ onye ọbụla na-enweghị nne na nna.  
\v 23 Unu megbuo ha, mee ka ha tikuo m, aga m anụ mkpu akwa ha, nyere ha aka.  
\v 24 Mgbe ahụ, iwe m dị oke ọkụ ga-eripịa unu. Aga m ejikwa mma agha tigbuo unu. Ndị nwunye unu ga-aghọkwa ndị inyom na-enweghị di, ụmụ unu ga-abụkwa ndị na-enweghị nna. 
\p  
\v 25 “Ọ bụrụ na ị gbazinyere onye Hibru ego, onye bụ nwa mgbei, ị gaghị anara ya ọmụrụnwa.  
\v 26 Ọ bụrụ na ị nara ya uwe ya nʼihi ego ahụ ị gbazinyere ya, ekwela ka uwe ahụ nọgide nʼaka gị ruo mgbe anwụ dara.  
\v 27 Nʼihi na uwe ahụ nwere ike bụrụ naanị ihe o nwere, maọbụ uwe ọ ga-eji rahụ ụra. Ọ bụrụ na i zighachighị ya, o tikuo m site nʼịkwa akwa, aga m anụrụ mkpu akwa ya, nʼihi na abụ m onye obi ebere. 
\p  
\v 28 “Ekwulula aha Chineke, abụkwala onye na-achị ndị gị ọnụ. 
\p  
\v 29 “Atụfukwala oge ọbụla nʼịkwụghachi onyinye unu kwesiri inye. Maọbụ nke mkpụrụ ala ubi gị, na nke mmanya vaịnị gị, na ụgwọ i kwesiri ịkwụ. 
\p “Ị ghaghị inye m nwa gị nwoke e buru ụzọ mụọ.  
\v 30 Otu a ka ị ga-emekwa banyere mkpụrụ mbụ nke ehi gị na atụrụ gị. Ị ga-ewebata ya nye m nʼụbọchị nke asatọ site nʼoge a mụrụ ha, mgbe ị hapụsịrị ha nne ha ụbọchị asaa. 
\p  
\v 31 “Unu ga na-abụrụ m ndị dị nsọ. Nʼihi nke a, wezuganụ onwe unu nʼebe anụ a dọgburu adọgbu dị. Unu erikwala anụ dị otu a, kama tụpụrụnụ ya nkịta. 
\c 23  
\s1 Ikpe ziri ezi na inwe obi ebere 
\p  
\v 1 “Ị gaghị agbasa akụkọ ụgha ọbụla. Esokwala mmadụ ọjọọ nwekọọ ihe ọbụla site nʼịgba ama ị maara na ọ bụghị eziokwu. 
\p  
\v 2 “Ị gaghị eso igwe mmadụ mee ihe ọjọọ. Mgbe ị na-agba akaebe nʼụlọikpe, ị gaghị esonye igwe mmadụ ndị na-atụgharị ikpe ziri ezi.  
\v 3 Nʼebe nwa ogbenye nọ, ị gaghị ekpelara ya nʼoge ikpe nʼihi na ọ bụ nwa ogbenye. 
\p  
\v 4 “Ọ bụrụ na ị hụ ehi, maọbụ ịnyịnya ibu nke kpafuru akpafu, ọ bụrụkwa na ọ bụ nke onye iro gị, duru ya dulatara onye iro gị ahụ.  
\v 5 Ọ bụrụ na ị hụ onye kpọrọ gị asị ka ọ na-agbalị iwelite ịnyịnya ibu ya nke dara nʼihi ibu dị arọ o bu, elefula ya anya, kama gaa nyere ya aka bulite ịnyịnya ahụ. 
\p  
\v 6 “Ewezugala ikpe ziri ezi nʼebe ndị ogbenye nọ, nʼihi ọnọdụ ogbenye ha.  
\v 7 Ebola mmadụ ibe gị ebubo ụgha. Esonyekwala gbuo onye aka ya dị ọcha, maọbụ onye na-eme ihe ziri ezi. Nʼihi na mụ onwe m agaghị ahapụ onye na-emebi iwu na-ataghị ya ahụhụ kwesiri ya. 
\p  
\v 8 “Erikwala ngarị, nʼihi na iri ngarị na-eme ka ndị na-ahụ ụzọ kpuo ìsì, meekwa ka okwu onye aka ya dị ọcha gbagọọ agbagọ. 
\p  
\v 9 “Abụkwala onye na-emegbu ndị ọbịa, nʼihi na ị maara ihe banyere ọnọdụ ndị ọbịa nke ọma. Gị onwe gị bụrịị ọbịa nʼIjipt. 
\s1 Iwu maka Ụbọchị nke asaa na afọ nke asaa 
\p  
\v 10 “Afọ isi ka ị ga-agha mkpụrụ nʼala ubi gị, ghọọkwa ihe omume ya.  
\v 11 Ma nʼafọ nke asaa, arụla ọrụ ọbụla nʼala ahụ ọzọ, hapụ ka ala ahụ zuru ike. Mgbe ahụ ndị ogbenye nʼetiti unu ga-aga nʼebe ahụ weta ihe oriri. Mkpụrụ ndị ọzọ fọdụrụ ga-adịrị ụmụ anụ ọhịa dị iche iche. Iwu ndị a ga-adịrị ubi vaịnị na ubi oliv unu niile. 
\p  
\v 12 “Ị ga-arụ ọrụ gị niile nʼime ụbọchị isii. Ị ga-ezukwa ike nʼụbọchị nke asaa. Izuike a ga-adịkwara ehi gị na ịnyịnya ibu gị, na ndị ohu gị nọ nʼezinaụlọ gị na ndị ọbịa niile bi nʼetiti unu. 
\p  
\v 13 “Kpachapụnụ anya hụ na unu mezuru ihe niile ndị a m gwara unu. Unu akpọkwala chi ndị ọzọ aha. Unu ekwupụtakwala ihe banyere ha nʼọnụ unu. 
\s1 Mmemme atọ a na-eme kwa afọ 
\p  
\v 14 “Ugboro atọ nʼafọ ka unu ga-emere m mmemme a. 
\p  
\v 15 “Meenụ Mmemme Achịcha na-ekoghị eko, ụbọchị asaa ka unu ga-eri achịcha nke e jighị ihe na-eko achịcha mee. Unu ga-eri ya na mgbe a kara aka, nʼọnwa Abib. Nʼihi na ọ bụ nʼọnwa ahụ ka unu si nʼala Ijipt pụta. 
\p “Ọ dịghị onye ọbụla ga-agba aka efu bịa nʼihu m. 
\p  
\v 16 “Mee Mmemme Owuwe Ihe ubi,\f + \fr 23:16 \ft Aha ọzọ a na-akpọ mmemme owuwe ihe ubi bụ mmemme Izu, gụọ ya nʼakwụkwọ \xt Ọpụ 34:22\ft , nʼihi na ọ bụ izu asaa, mgbe Mmemme Ngabiga gafesịrị ka a na-eme ya. Ọ bụkwa nʼọgwụgwụ owuwe ihe ubi.\f* bụ nke ị ga-eji mkpụrụ mbụ nke ihe niile ị kụrụ nʼubi unu. 
\p “Meekwanụ Mmemme Nchịkọta Ihe, nʼọgwụgwụ afọ ọbụla.\f + \fr 23:16 \ft Mmemme nchịkọta mkpụrụ bụ ihe na-egosi na e wechaala ihe ubi. \xt Dit 16:13\f* Mgbe unu si nʼubi na-achịbata mkpụrụ ubi unu niile. 
\p  
\v 17 “Ugbo atọ nʼafọ ka ndị ikom niile ga-abịa chee onwe ha nʼihu Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*. 
\p  
\v 18 “Unu etinyekwala ihe ọbụla nke nwere ihe na-eko achịcha nʼime ya, mgbe unu na-achụ ọbara nke aja nʼihu m. 
\p “Maọbụ hapụ abụba nke aja mmemme m ka ọ dịgide ruo ụtụtụ.\f + \fr 23:18 \ft Ya bụ chi ọbụbọ\f* 
\p  
\v 19 “Wetanụ mkpụrụ mbụ niile nke ala ubi unu, bụ ndị kachasị mma, nʼụlọ \nd Onyenwe anyị\nd* bụ Chineke unu. 
\p “Unu esikwala nwa ewu nʼime mmiri ara nne ya.\f + \fr 23:19 \ft Otu nʼime omenaala dị nʼusoro ofufe ndị Kenan bụ isi nwa ewu nʼime mmiri ara nne ya. \xt Dit 14:21\f* 
\s1 Nkwa onye ga-edu ha 
\p  
\v 20 “Lee, ana m eziga mmụọ ozi nʼihu unu, ichebe unu nʼije unu nakwa ịkpọbatakwa unu nʼebe ahụ M doziri nye unu.  
\v 21 Geenụ ya ntị, nụrụkwa olu ya. Unu enupukwarala ya isi, nʼihi na ọ gaghị agbaghara njehie unu niile, nʼihi na Aha m dị nʼime ya.  
\v 22 Ọ bụrụ na unu elezie anya nke ọma, gee ya ntị, mee ihe niile m nyere unu nʼiwu, mgbe ahụ, mụ onwe m ga-abụkwara ndị iro unu onye iro, megidekwa ndị na-emegide unu.  
\v 23 Mmụọ ozi m ga-ejekwa nʼihu unu, ịkpọbatakwa unu nʼala ndị Amọrait, na ndị Het, na ndị Periz, na ndị Kenan, na ndị Hiv, na ndị Jebus. Aga m ehichapụ obodo ndị a niile.  
\v 24 Unu agaghị akpọ isiala nye chi ha niile. Unu efekwala ha, maọbụ gbasoro omenaala ha. Kama, kwatuonụ ha. Tipịasịakwanụ ebe nkume nsọ\f + \fr 23:24 \ft Ebe a manyere ogidi, ka e ji amata ebe bụ ebe ịchụ aja ha.\f* niile nke chi ha.  
\v 25 Ma unu ga-efe \nd Onyenwe anyị\nd* bụ Chineke unu. Mgbe ahụ, ngọzị ya ga-adịkwasị nri unu na mmiri ọṅụṅụ unu. Aga m ewezugakwa ọrịa nʼetiti unu.  
\v 26 Nwanyị aga na nwanyị ime ya na-apụ agaghị adị nʼala unu. Aga m emekwa ka unu nwee ogologo ndụ. 
\p  
\v 27 “Aga m ezipu oke ụjọ m ka ọ nọrọ unu nʼihu tinye ọgbaaghara nʼime mba niile unu ga-ezute. Aga m eme ka ndị iro unu tụgharịa gbaa ọsọ.  
\v 28 Ọzọkwa, aga m eziga ebu ka ọ chụpụ ndị Hiv na ndị Kenan na ndị Het site nʼụzọ unu.  
\v 29 Ma agaghị m achụpụ ha nʼotu afọ, nʼihi na nke a ga-eme ka ala ahụ niile tọgbọrọ nʼefu, ụmụ anụ ọhịa a baa ụba karịa unu.  
\v 30 Ma aga m achụpụ ha nwantịntị nwantịntị, tutu ruo oge unu ga-adị ọtụtụ, mgbe ọnụọgụgụ unu ga-akarị nke ha ukwuu, mgbe unu ga-ejupụta ala ahụ niile. 
\p  
\v 31 “Aga m etinye oke ala unu site nʼOsimiri Uhie ruo nʼosimiri Mediterenịa, sitekwa nʼọzara ruo nʼosimiri Yufretis. Aga m enyefe ndị niile bi nʼala ahụ nʼaka unu. Unu ga-achụpụkwa ha.  
\v 32 Unu na ha agbala ndụ ọbụla. Unu na chi ha enwekwala mmekọ ọbụla.  
\v 33 Unu ekwela ka ha biri nʼala unu, ma ọ bụghị ya, ha ga-eme ka unu mehie megide m, nʼihi nʼife chi ha dị iche iche aghaghị ịbụrụ unu ihe ịma nʼọnya.” 
\c 24  
\s1 Mmesi ike nke ọgbụgba ndụ ahụ 
\p  
\v 1 Ọ gwara Mosis sị, “Rigokwute \nd Onyenwe anyị\nd*, gị na Erọn, na Nadab, na Abihu, na mmadụ iri asaa site na ndị okenye Izrel. Ma unu ga-efe ofufe site nʼebe dị anya.  
\v 2 Emesịa, ọ bụ naanị Mosis ga-abịarute \nd Onyenwe anyị\nd* nso. Ndị nke ọzọ agaghị abịaru nso. Ndị mmadụ ndị ọzọ agaghịkwa eso ya rigota.” 
\p  
\v 3 Mgbe ahụ, Mosis bịara gwa ndị Izrel okwu niile na iwu niile \nd Onyenwe anyị\nd* nyere. Ha niile zaghachiri ya nʼotu olu sị, “Anyị ga-emezu ihe niile \nd Onyenwe anyị\nd* kwuru.”  
\v 4 Mosis deturu ihe niile \nd Onyenwe anyị\nd* kwuru. 
\p Nʼisi ụtụtụ echi ya, o biliri wuo ebe ịchụ aja na ndịda ugwu ahụ. O gwunyere ogidi nkume iri na abụọ nke nọchiri anya ebo iri na abụọ ụmụ Izrel.  
\v 5 Mosis zipụtara ụmụ okorobịa Izrel, ndị chụrụ aja nsure ọkụ ma werekwa ụmụ oke ehi chụọ aja udo nye \nd Onyenwe anyị\nd*.  
\v 6 Mosis tinyere ọkara ọbara ehi ndị ahụ nʼime efere. Ma o fesara ọkara ọbara nke fọdụrụ nʼelu ebe ịchụ aja ahụ.  
\v 7 Emesịa, Mosis guzoro nʼebe ahụ gụpụta na ntị mmadụ niile, ihe dị nʼAkwụkwọ Ọgbụgba ndụ ahụ. Mgbe ụmụ Izrel nụrụ ya, ha weere otu olu kwuo sị, “Anyị anụla, anyị ga-eme ihe niile \nd Onyenwe anyị\nd* kwuru. Anyị ga-erube isi.” 
\p  
\v 8 Mgbe ahụ, Mosis weere ọbara ahụ dị nʼime efere, fesaa ya nʼahụ ndị ahụ niile, sị, “Nke a bụ ọbara ọgbụgba ndụ ahụ nke dị nʼetiti unu na \nd Onyenwe anyị\nd*, dịka okwu niile ndị a si dị.” 
\p  
\v 9 Mosis rigoro nʼelu ugwu, ya na Erọn, na Nadab na Abihu, na mmadụ iri asaa site na ndị okenye Izrel.  
\v 10 Ha hụrụ Chineke nke Izrel. Nʼokpuru ụkwụ ya abụọ, e were ihe dịka ebe nzọkwasị ụkwụ nke e ji nkume safaia mee. Nkume ndị a na-enwukwa ezi onwunwu dịka mbara eluigwe.  
\v 11 Ọ bụ ezie na ndị okenye Izrel hụrụ Chineke anya ma ọ laghị ha nʼiyi. Kama o mere ka ha nọọ nʼihu ya rie, ṅụọ. 
\p  
\v 12 Mgbe nke a gasịrị, \nd Onyenwe anyị\nd* gwara Mosis okwu sị, “Rigota, bịakwute m nʼelu ugwu, nọdụkwa ebe ahụ, maka na aga m enye gị mbadamba nkume nke iwu na ụkpụrụ dị na ya, nke m ji aka m dee maka i ji kuziere ha.” 
\p  
\v 13 Mosis biliri, ya na Joshua onye na-agara ya ozi. Mosis nʼonwe ya rigokwara nʼelu ugwu Chineke.  
\v 14 Ọ gwara ndị okenye Izrel okwu sị, “Cherenụ anyị nʼebe a tutu ruo mgbe anyị ga-alaghachikwute unu. Unu na Erọn na Hua nọ, onye ọbụla nwere nsogbu jekwuru ha.” 
\p  
\v 15 Ngwangwa, Mosis rigoro nʼelu ugwu ahụ, oke igwe ojii kpuchiri ugwu ahụ niile,  
\v 16 ebube \nd Onyenwe anyị\nd* kpuchikwara elu ugwu ahụ. Ọ bụ ụbọchị isii ka igwe ojii kpuchiri ugwu ahụ. Nʼụbọchị nke asaa, \nd Onyenwe anyị\nd* sitere nʼetiti igwe ojii ahụ kpọọ Mosis oku.  
\v 17 Ma nʼebe ndị Izrel nọ, ebube \nd Onyenwe anyị\nd* na-enwu dịka ọkụ na-achọ irechapụ ugwu ahụ.  
\v 18 Mosis banyere nʼime igwe ojii ahụ mgbe ọ na-arịgo ugwu ahụ. Ọ nọgidere nʼelu ugwu ahụ iri ụbọchị anọ, ehihie na abalị. 
\c 25  
\s1 Onyinye maka owuwu ụlọ nzute 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis sị,  
\v 2 “Gwa ụmụ Izrel ka ha wetara m onyinye. Ị ga-anabatara m onyinye ahụ site nʼaka nwoke ọbụla onye o metụrụ nʼobi inye onyinye a. 
\b  
\li4  
\v 3 “Ndị a bụ Onyinye ị ga-anata nʼaka ha: 
\b  
\li1 “ọlaọcha, ọlaedo na bronz. 
\li1  
\v 4 Ogho na-acha anụnụ anụnụ, nke odo odo, nke uhie uhie, nke ezi akwa ọcha, 
\li1 na nke ajị ewu; 
\li1  
\v 5 akpụkpọ anụ ebule e sijiri uhie uhie, akpụkpọ ehi mmiri, 
\li1 na osisi akashia; 
\li1  
\v 6 mmanụ oliv nke a ga-etinye nʼiheọkụ, 
\li1 ụda isi ụtọ a na-etinye na mmanụ nsọ, na ụda na-eme ka aja nsure ọkụ na-esi isi ụtọ; 
\li1  
\v 7 nkume ọma ọniks, na nkume ndị ọzọ a na-ahịọnye nʼefọọd,\f + \fr 25:7 \ft Efọọd bụ uwe dị nso nke onyeisi nchụaja na-eyi. \xt Ọpụ 28:4,6-14\f* na nke a na-ahịọnyekwa nʼihe mgbochi obi. 
\b  
\p  
\v 8 “Mee ka ha wuoro m ebe nsọ. Mụ onwe m ga-ebikwa nʼetiti ha.  
\v 9 Wuo ụlọ nzute a na ihe ịchọ ya mma niile, ka ọ bụrụ otu ihe dịka oyiyi m ga-egosi gị. 
\s1 Igbe ọgbụgba ndụ 
\p  
\v 10 “Ha ga-eji osisi akashia wuo igbe ọgbụgba ndụ nke ịdị ogologo ya ga-abụ otu mita na sentimita iri. Obosara ya bụ sentimita iri isii na asatọ. Ịla elu ya ga-abụkwa sentimita iri isii na asatọ.  
\v 11 Machie ọlaedo a nụchara anụcha nʼime na azụ ya niile, jiri ọlaedo kpụọ ihe gburugburu akụkụ ya niile.  
\v 12 Kpụọ mgbaaka ọlaedo anọ maka ya, kwụnye ha nʼụkwụ anọ ya, ya bụ mgbaaka abụọ nʼotu akụkụ, mgbaaka abụọ nʼakụkụ nke ọzọ ya  
\v 13 Jirikwa osisi akashia mee mkpara ogologo. Emesịa, were ọlaedo machie mkpara ndị a.  
\v 14 Ị ga-etinye mkpara ndị ahụ nʼime mgbaaka ahụ dị nʼakụkụ igbe ahụ, ka ọ bụrụ ihe iji na-ebu ya.  
\v 15 Nʼihi nke a, mkpara ọlaedo ndị ahụ ga-adịgide nʼime mgbaaka ọlaedo igbe a oge niile.  
\v 16 Ya mere, mgbe a rụsịrị igbe ọgbụgba ndụ ahụ, tinye Ihe Ama ahụ m nyere gị nʼime ya. 
\p  
\v 17 “Ị ga-ejikwa ọlaedo a nụchara anụcha mee ihe mkpuchi igbe ọgbụgba ndụ ahụ. Ogologo ya ga-adị nzọ ụkwụ anọ. Obosara ya ga-abụ nzọ ụkwụ abụọ na ọkara.  
\v 18 Ị ga-eji ọlaedo a nụchara anụcha, nke e tipịara etipịa kpụọ cherubim abụọ na nsọtụ abụọ nke ebe mkpuchi ahụ.  
\v 19 Rụọ otu cherub nʼotu nsọtụ, otu cherub na nsọtụ nke ọzọ; mee ka cherubim ndị a na okwuchi igbe ahụ bụrụ otu na nsọtụ abụọ ahụ.  
\v 20 Cherubim ndị a ga-agbasa nku ha laa elu, were ha na-ekpuchi okwuchi ahụ. Cherubim ndị ahụ ga-eche onwe ha ihu, na-ele anya nʼebe okwuchi ahụ dị.  
\v 21 Tụkwasị ihe mkpuchi ahụ nʼelu igbe ọgbụgba ndụ ahụ. Tinyekwa Ihe Ama ahụ m nyere gị nʼime igbe ahụ.  
\v 22 Nʼebe ahụ, nʼetiti cherubim abụọ ndị ahụ dị nʼelu ihe mkpuchi igbe ọgbụgba ndụ, ka m ga-ezute gị, nye gị iwu niile ị ga-enye ndị Izrel. 
\s1 Tebul na achịcha dị nsọ. 
\p  
\v 23 “Jiri osisi akashia mee tebul nke ogologo ya ga-adị iri sentimita itoolu. Obosara ya ga-abụ iri sentimita anọ na ise. Ịla elu ya ga-abụ iri sentimita isii na asaa.  
\v 24 Ị ga-eji ọlaedo a nụchara anụcha machie ya nke ọma, jirikwa ọlaedo kpụọ ọnụ ọnụ ya gburugburu.  
\v 25 Ị ga-etinye ihe njikọta a kpụrụ akpụ gburugburu ọnụ ọnụ ya, nke ga-aha ka otu ọbụ aka\f + \fr 25:25 \ft Ihe dịka inchi atọ\f* dimkpa. A ga-eji mpempe ọlaedo techie ihe njikọta ahụ gburugburu.  
\v 26 Kpụọ mgbaaka ọlaedo anọ maka tebul ahụ, kwụnye ha nʼakụkụ anọ ahụ nke ụkwụ anọ ya.  
\v 27 Mgbaaka ndị ahụ ga-adị nso nso, ihe njikọ ahụ ka ha jide mkpara ndị ahụ, i ji ebu tebul ahụ.  
\v 28 Jiri osisi akashia mee mkpara a ga-eji na-ebu tebul ahụ. Jiri ọlaedo techie ha.  
\v 29 Ọzọkwa, jiri ọlaedo a nụchara anụcha kpụọ efere dị iche iche, na iko dị iche iche, na ọkwa dị iche iche, nke e ji awụpụ onyinye.  
\v 30 Dọkwasị achịcha nke iche nʼIhu nʼelu tebul ahụ, nʼihu m, oge niile. 
\s1 Ihe ịdọba oriọna 
\p  
\v 31 “Jiri ọlaedo a nụchara anụcha kpụọ ihe ịdọkwasị oriọna. Kpụọ ụkwụ ala ala ya, na alaka ya, mee ka iko ya niile yiri okoko osisi, na isi ya niile, na ifuru ya niile bụrụ otu ya na ahụ ya.  
\v 32 Alaka isii ga-esite nʼakụkụ abụọ nke ihe ịdọkwasị oriọna ahụ wapụta, alaka atọ nʼotu akụkụ ya, alaka atọ nʼakụkụ nke ọzọ.  
\v 33 Iko atọ e mere dịka okoko osisi alụmọnd ya na ifuru, ya na okoko ya niile ga-adị nʼotu alaka, iko atọ nʼalaka nke ọzọ, otu a ka ọ ga-adị nʼalaka isii niile ahụ na-awapụta site nʼihe ịdọkwasị oriọna ahụ.  
\v 34 Nʼelu ihe ịdọba oriọna ahụ, ọ ga-adị iko anọ dịka ifuru osisi alụmọnd, ya na ebe o si awapụta na okoko ya.  
\v 35 Otu isi ga-adịkwa nʼokpuru alaka abụọ si nʼetiti ihe ịdọba oriọna ahụ pụta. Isi nke abụọ ga-adị nʼokpuru alaka abụọ nke ọzọ. Isi nke atọ ga-adị nʼokpuru alaka nke atọ, ya bụ ha niile alaka isii.  
\v 36 Isi nwapụta ya na alaka ya niile ga-adịkọtakwa ọnụ, ha na ihe ịdọkwasị oriọna ahụ, nke e ji ọlaedo a nụchara anụcha rụọ. 
\p  
\v 37 “Ị ga-eme oriọna asaa, dọba ha nʼelu ihe ịdọkwasị iheọkụ ahụ, ka ha na-enye ìhè naanị nʼebe ihu ya.  
\v 38 Mkpa ya na ihe ịkpakepụ ọkụ ya niile, ga-abụ ọlaedo a nụchara anụcha.  
\v 39 Ọlaedo a nụchara anụcha nke dị iri kilogram atọ na anọ ka a ga-eji kpụọ ihe ịdọkwasị oriọna ahụ na ngwongwo ndị a niile.  
\v 40 Lezie anya hụ na i mere ihe ndị a niile nʼusoro ihe atụ nke e gosiri gị nʼelu ugwu. 
\c 26  
\s1 Ụlọ nzute 
\p  
\v 1 “Rụọ ụlọ nzute nke ga-enwe akwa mgbochi iri, nke e ji ezi ogho na-acha anụnụ anụnụ, na ngwakọta anụnụ na uhie, na uhie uhie kpaa akwa ndị a. Onye ọrụ aka na-eme ǹka kpanyekwara oyiyi cherubim nʼime ha.  
\v 2 Akwa mgbochi ndị a ga-aha nʼotu. O nweghị nke ga-aka ibe ya. Ogologo akwa mgbochi ọbụla ga-abụ mita iri na abụọ na ọkara. Obosara ya bụ otu mita na sentimita asatọ.  
\v 3 Dụkọtaa akwa mgbochi ise nʼotu, dụkọtaakwa ise nke ọzọ nʼotu.  
\v 4 Jiri akwa na-acha anụnụ anụnụ dụnye anya nko nʼelu ọnụ akwa mgbochi nke otu ụzọ, otu a ka ị ga-emekwa na nsọtụ ọnụ akwa mgbochi nke ọzọ.  
\v 5 Dụnye iri anya nko ise nʼotu akwa mgbochi, dụnyekwa iri anya nko ise nʼọnụ akwa mgbochi nke ọzọ. Mee ka anya nko ndị a chee ibe ha ihu.  
\v 6 Ị ga-emekwa iri nko ọlaedo ise, nke ị ga-eji jikọta akwa mgbochi abụọ ahụ nʼotu, si otu a mee ka ụlọ nzute ahụ bụrụ otu. 
\p  
\v 7 “Ị ga-eji akpụkpọ ajị ewu mee akwa mgbochi maka i ji kpuchie elu ụlọ nzute ahụ. Iri na otu ka ha ga-adị nʼọnụọgụgụ.  
\v 8 Akwa mgbochi iri na otu ndị a ga-aha nʼotu. Ọ ga-abụ mita iri na atọ na ọkara nʼogologo. Ebe obosara ya bụ otu mita na iri sentimita asatọ.  
\v 9 Dụkọtaa ise nʼime akwa mgbochi ahụ. Debe ya iche. Dụkọtakwa isii nke fọdụrụ debekwa ya iche. Pịajie akwa mgbochi nke isii ụzọ abụọ nʼihu ụlọ nzute ahụ.  
\v 10 Dụnyekwa iri anya nko ise nʼelu ọnụ otu akwa mgbochi ndị ahụ. Meekwa otu ihe ahụ nʼọnụ akwa mgbochi nke ọzọ e debere iche.  
\v 11 Meekwa iri nko bronz ise, mee ka nko ahụ baa nʼanya nko nke ọzọ, i ji jikọta ụlọ nzute ahụ ka ọ bụrụ otu.  
\v 12 Ma banyere ogologo akwa mgbochi nke fọdụrụ maka ụlọ nzute, ya bụ ọkara akwa mgbochi nke mapụtara, nke a ga-akwụba nʼazụ ụlọ nzute ahụ.  
\v 13 Akwa mgbochi ahụ ga-eji ihe ruru ọkara mita nʼogologo karịa nʼakụkụ abụọ. Ụma ndị a mapụtara ga-akwụdata nʼakụkụ abụọ nke ụlọ nzute ahụ ikpuchi ya.  
\v 14 Ị ga-eji akpụkpọ ebule e sijiri uhie uhie mee ihe mkpuchi maka ụlọ nzute ahụ, ya na akwa mkpuchi ọzọ nke e ji akpụkpọ ehi mmiri mee maka ikpukwasị nʼelu ya. 
\p  
\v 15 “Ị ga-emere ụlọ nzute ahụ mbudo ibo osisi akashia, guzo ọtọ.  
\v 16 Mbudo ibo ọbụla ga-adị mita anọ na ọkara nʼogologo, dịrịkwa iri sentimita asaa nʼobosara.  
\v 17 Mbudo ibo ndị a ga-enwe ihe nhịọnye abụọ nke ga-abanye nʼime ibe ya ijikọ ha nʼotu. Ị ga-arụ mbudo ibo ụlọ nzute ahụ niile otu a.  
\v 18 Ị ga-arụ mbudo ibo iri abụọ maka akụkụ ndịda nke ụlọ nzute ahụ.  
\v 19 Meekwa iri ụkwụ ọlaọcha anọ nʼokpuru ha. Otu mbudo ibo ga-enwe ụkwụ abụọ, otu ụkwụ nʼokpuru otu ihe nhịọnye, otu ụkwụ nʼokpuru ihe nhịọnye nke ọzọ.  
\v 20 Nʼakụkụ nke ọzọ, bụ akụkụ ugwu nke ụlọ nzute ahụ, ị ga-arụkwa iri mbudo ibo abụọ.  
\v 21 Rụkwaa iri ụkwụ ọlaọcha anọ, ụkwụ abụọ nʼokpuru mbudo ibo ọbụla.  
\v 22 Nʼebe isi isi nsọtụ, ya bụ akụkụ ọdịda anyanwụ nke ụlọ nzute, ị ga-arụ mbudo ibo isii.  
\v 23 Rụọ mbudo ibo abụọ, ga-adị na nkuku niile nke nsọtụ ụlọ nzute ahụ.  
\v 24 Nʼisi nkuku abụọ ndị a, ha ga-anọ iche iche site nʼokpuru ruo nʼelu ya, ma a ga-ejikọ ha ọnụ nʼime otu mgbaaka, ha abụọ ga-adị otu ahụ.  
\v 25 Ha niile ga-adị mbudo ibo asatọ na ụkwụ ọlaọcha dị iri na isii, ya bụ ụkwụ abụọ nʼokpuru mbudo ibo ọbụla. 
\p  
\v 26 “Jiri osisi akashia mee osisi ntụbichi, ise maka mbudo ibo ndị dị nʼotu akụkụ nke ụlọ nzute,  
\v 27 ise nke ọzọ maka ndị dị nʼakụkụ nke ọzọ, ise nke ọzọ maka mbudo ibo dị nʼakụkụ ọdịda anyanwụ, nʼebe ndịda ndịda nke ụlọ nzute ahụ.  
\v 28 Osisi ntụbichi nke dị nʼetiti ga-esite nʼotu isi ruo nʼisi nke ọzọ nke mbudo ibo ahụ.  
\v 29 Jiri ọlaedo machie mbudo ibo ndị ahụ niile, kpụọ mgbaaka ọlaedo ka ọ bụrụ ọnọdụ ịchịkọta osisi ntụbichi ndị a. Jirikwa ọlaedo machie osisi ntụbichi ndị a. 
\p  
\v 30 “Guzobe ụlọ nzute a nʼusoro dịka ụdịdị ihe ahụ m ziri gị nʼelu ugwu si dị. 
\p  
\v 31 “Meekwa akwa mgbochi nke e ji ogho na-acha anụnụ anụnụ, ngwakọta anụnụ na uhie, uhie uhie na ezi akwa ọcha a kpara nke ọma, onye ǹka kpanyekwara oyiyi cherubim nʼime ya.  
\v 32 Were anya nko ọlaedo kwụba ya nʼelu ogidi osisi akashia anọ nke e ji ọlaedo machie, mee ka o guzoro nʼelu ụkwụ ọlaọcha anọ.  
\v 33 Konye akwa mgbochi ahụ na nko ndị ahụ, ma dọnye igbe ihe ama ahụ nʼazụ akwa mgbochi ahụ. Akwa mgbochi ahụ ga-ekewapụ Ebe Nsọ ahụ site nʼEbe Kachasị Nsọ.\f + \fr 26:33 \ft Ọ bụ naanị onyeisi nchụaja na-aba nʼime ebe ahụ a na-akpọ Ebe Kachasị Nsọ. Ọ bụ naanị otu ụbọchị nʼafọ, nke bụ ụbọchị ikpuchi mmehie ndị Izrel, ka ọ na-aba nʼebe ahụ.\f* 
\v 34 Tinye ihe mkpuchi mmehie ahụ nʼelu igbe ihe ama nʼime Ebe Kachasị Nsọ.  
\v 35 Dọnye tebul ahụ na mpụta nke akwa mgbochi ahụ, nʼakụkụ ugwu nke ụlọ nzute ahụ. Dọnyekwa ihe ịdọkwasị iheọkụ na ncherita ihu tebul ahụ, nʼakụkụ ndịda. 
\p  
\v 36 “Ị ga-eme akwa mgbochi maka ọnụ ụzọ mbata nke ụlọ ikwu ahụ nke eji ogho na-acha anụnụ anụnụ na ngwakọta anụnụ na uhie, na uhie uhie, na ezi akwa ọcha a kpara nke ọma, nke bụ akaọrụ onye ǹka.  
\v 37 Ị ga-arụrụ akwa mgbochi a anya nko ọlaedo na ogidi ise nke osisi akashia nke e ji ọlaedo machie. Ị ga-arụkwa ụkwụ bronz ise maka ha. 
\c 27  
\s1 Ebe ịchụ aja 
\p  
\v 1 “Ị ga-eji osisi akashia wuo ebe ịchụ aja. Ịdị elu ya ga-abụ otu mita na iri sentimita anọ. Ogologo ya na obosara ya ga-aha nʼotu, mita abụọ na iri sentimita atọ, mita abụọ na iri sentimita atọ.  
\v 2 Rụnye mpi nʼakụkụ anọ nke ebe ịchụ aja ahụ nʼotu nʼotu. Mee ka mpi ndị a na ebe ịchụ aja ahụ bụrụ ihe e jikọtara nʼotu. Jiri bronz machie ebe ịchụ aja a.  
\v 3 Jiri bronz kpụọ ngwongwo niile dị iche iche, ya bụ efere ikpofu ntụ, shọvel ya niile, efere ịkwọsa mmiri niile, ngaji eze ịdụta anụ na efere ndị e ji agụ ọkụ.  
\v 4 Ị ga-eme ngịga mbadamba, ihe ọkpụkpa bronz, meekwa mgbaaka bronz nke ga-adị nʼakụkụ anọ nke ngịga ahụ.  
\v 5 Tinye ya nʼokpuru oghere dị nʼebe ịchụ aja ahụ. Tinye ya ka ọ dịrị nʼetiti ebe ịchụ aja ahụ.  
\v 6 Jiri osisi akashia mee mkpara osisi maka ebe ịchụ aja ahụ, were bronz machie ha.  
\v 7 A ga-eme ka mkpara ahụ baa nʼime mgbaaka ndị ahụ, ka ha dị nʼakụkụ abụọ nke ebe ịchụ aja ahụ mgbe ọbụla a na-ebu ya.  
\v 8 Jiri obodobo osisi rụọ ebe ịchụ aja ahụ, ka o nwee oghere nʼime, dịka igbe. Ị ga-arụ ya dịka e gosiri gị nʼelu ugwu ahụ. 
\s1 Ogige ụlọ nzute 
\p  
\v 9 “Ị ga-arụkwa ogige maka ụlọ nzute ahụ. Nʼakụkụ ndịda ya ga-adị iri mita anọ na ise nʼogologo. Ọ ga-enwekwa akwa mgbochi nke e ji ezi akwa ọcha a kpara nke ọma mee.  
\v 10 Iri ogidi abụọ ga-adị na iri ebe ndọkwasị abụọ nke e ji bronz kpụọ. Anya nko ogidi ndị ahụ ha na ihe ikegide ha ga-abụ ọlaọcha.  
\v 11 Otu a kwa, akụkụ ugwu ga-adịkwa iri mita anọ na ise. Ọ ga-enwe akwa mgbochi, nwekwa iri ogidi abụọ na iri ebe ndọkwasị abụọ nke e ji bronz kpụọ, ya na anya nko nke ọlaọcha na ihe e ji ekegide ha nʼogidi ahụ. 
\p  
\v 12 “Akụkụ ọdịda anyanwụ nke ogige ahụ ga-adị iri mita abụọ na atọ nʼobosara. Ọ ga-enwe akwa mgbochi, na ogidi iri na ebe ndọkwasị iri.  
\v 13 Nʼakụkụ ọwụwa anyanwụ, ebe anwụ na-awalite, akwa mgbochi ahụ ga-adịkwa iri mita abụọ na atọ nʼobosara.  
\v 14 Akwa mgbochi nke ogologo ya dị mita isii na sentimita iri asatọ ga-adị nʼotu akụkụ nke ọnụ ụzọ mbata ahụ. O nwere ogidi atọ na ebe ndọkwasị atọ.  
\v 15 Otu a kwa, akwa mgbochi nke ịdị ogologo ya dị mita asaa ga-adị nʼakụkụ nke ọzọ. Ọ ga-enwekwa ogidi atọ na ebe ndọkwasị atọ. 
\p  
\v 16 “Banyere ọnụ ụzọ mbata nke ogige ahụ, mee akwa mgbochi ga-adị mita itoolu nke e ji ogho na-acha anụnụ anụnụ, ngwakọta anụnụ na uhie, uhie uhie na ezi akwa ọcha a kpara nke ọma, akaọrụ nke onye na-akpa ihe ịchọ mma. Ọ ga-enwe ogidi anọ na ihe ndọkwasị anọ.  
\v 17 Ogidi niile dị gburugburu ogige ahụ ga-enwe ihe njikọta ọlaọcha na nko, tinyere ebe ndọkwasị bronz.  
\v 18 Ogologo ogige ahụ ga-abụ iri mita anọ na ise. Ebe obosara ya ga-adị iri mita abụọ na atọ. Ọ ga-enwe akwa mgbochi nke ịdị elu ya dị iri mita abụọ na atọ, nke e ji ezi akwa ọcha a kpara nke ọma mee, nwekwa ebe ndọkwasị bronz.  
\v 19 Ngwongwo niile nke e ji eje ozi nʼụlọ nzute ahụ, ihe ọbụla bụ ọrụ ha, tinyere ǹtu ya niile na nke ogige ahụ, ga-abụ ihe e ji bronz rụọ. 
\s1 Mmanụ ịmụ ọkụ 
\p  
\v 20 “Nye ndị Izrel niile iwu ka ha wetara gị mmanụ oliv asụrụ asụ nke a na-agwaghị ihe maka itinye nʼiheọkụ ime ka ọkụ oriọna na-enwu mgbe niile.  
\v 21 Nʼime ụlọ nzute ahụ, na mpụta nke akwa mgbochi nke kpuchiri igbe Ihe Ama ahụ, Erọn na ụmụ ya ndị ikom ga-eme ka oriọna ndị ahụ dị nʼihu \nd Onyenwe anyị\nd*, na-enwu ọkụ, site nʼuhuruchi ruo nʼụtụtụ. Nke a bụ ụkpụrụ ga-adịgide nʼetiti ndị Izrel nye ọgbọ niile dị nʼihu. 
\c 28  
\s1 Uwe ndị nchụaja 
\p  
\v 1 “Ugbu a, site nʼetiti ụmụ Izrel kpọbata nwanne gị nwoke Erọn, ya na ụmụ ya ndị ikom, bụ Nadab, na Abihu, na Elieza na Itama. Ka ha jeere m ozi dịka ndị nchụaja.  
\v 2 Meere Erọn nwanne gị nwoke uwe nsọ, nke ga-enye ya ugwu na nsọpụrụ.  
\v 3 Gwa ndị niile nwere onyinye ǹka nʼịdụ akwa, bụ ndị m nyere amamihe nʼihe ndị a, sị ha dụọrọ Erọn uwe pụrụ iche, nke e ji edo ya nsọ, ime ya onye na-ejere m ozi dịka onye nchụaja.  
\v 4 Nke a bụ ụdị uwe ha ga-adụ: Ihe mgbochi obi, efọọd, uwe ime ahụ akpara akpa na-enweghị aka na uwe mwụda buru ibu, na uwe ime ahụ nke tụrụ agwa agwa na akwa a na-atụhị nʼisi na nke a na-eke nʼukwu. Ha ga-adụrụ Erọn nwanne gị nwoke na ụmụ ya ndị ikom uwe ndị a dị nsọ. Ka ha na-ejere m ozi dịka ndị nchụaja.  
\v 5 Ka ha jiri ogho ọlaedo, nke na-acha anụnụ anụnụ, nke ngwakọta anụnụ na uhie, nke uhie uhie nakwa nke ezi akwa ọcha dụọ ha. 
\s1 Efọọd 
\p  
\v 6 “Weere ogho ọlaedo, na nke na-acha anụnụ anụnụ, na ngwakọta anụnụ na uhie, na uhie uhie na ezi akwa ọcha a kpara nke ọma mee efọọd ahụ, nke bụ akaọrụ onye ǹka.  
\v 7 Ọ ga-enwe akwa nʼubu ya abụọ nke e ji ejikọta ọnụ nkuku ya abụọ, ka e nwe ike na-ekechisi ya ike.  
\v 8 Ihe okike nke ukwu ahụ nke onye ǹka kpaziri nke ọma ga-adị ka ya. Ya na efọọd ahụ bụ otu, nke e ji ogho na-acha edo edo, nke anụnụ anụnụ, na ngwakọta anụnụ na uhie na uhie uhie, nakwa nke ezi akwa ọcha a kpara nke ọma mee. 
\p  
\v 9 “Were nkume ọniks abụọ, gbunye aha ụmụ ndị nwoke Izrel nʼelu ya,  
\v 10 nʼusoro dịka e si mụọ ha, isii nʼelu otu nkume, isii fọdụrụ na nkume nke ọzọ.  
\v 11 Gbunye aha ụmụ ndị nwoke Izrel nʼelu nkume abụọ ndị ahụ, dịka onye ǹka si egbunye akara na nkume. Mgbe ahụ, hịọnye nkume ndị ahụ nʼime ihe ọlaedo ahụ a kpara akpa,  
\v 12 jikọta ha nʼelu akwa ubu nke efọọd ahụ ka ọ bụrụ nkume ncheta mgbe ebighị ebi nye ụmụ Izrel. Erọn ga-ebukwa aha ndị a nʼelu ubu ya abụọ, dịka ihe ncheta nʼihu \nd Onyenwe anyị\nd*.  
\v 13 Ị ga-eji ọlaedo mee ihe ịchọ mma a tụrụ atụ.  
\v 14 Jirikwa ọlaedo a nụchara anụcha kpụọ eriri a tụhịkọtara dịka ụdọ, jikọta eriri ọlaedo ahụ na ihe ịchọ mma ndị ahụ. 
\s1 Ihe mgbochi obi 
\p  
\v 15 “Ị ga-adụ ihe mgbochi obi nke ikpe, nke bụ ọrụ aka onye ǹka. Mee ya dịka efọọd ahụ: jiri ogho edo edo, nke anụnụ anụnụ, na ngwakọta anụnụ na uhie, na nke uhie uhie nakwa ezi akwa ọcha a kpara nke ọma mee ya.  
\v 16 Akụkụ anọ ya ga-aha nʼotu, iri sentimita abụọ na atọ nʼogologo, iri sentimita abụọ na atọ nʼobosara, nke apịajiri ụzọ abụọ.  
\v 17 Mgbe ahụ, hịọnye nʼelu ya ahịrị nkume anọ ndị dị oke ọnụahịa. Ụdị ga-adị nʼahịrị nke mbụ bụ, nkume kanelian, krisolaịt na beril,  
\v 18 nʼahịrị nke abụọ, ga-abụ nkume tọkwọisi, safaia na emeralụdụ.  
\v 19 Nʼahịrị nke atọ ga-abụ nkume jasint, ageeti na ametisiti.  
\v 20 Nʼahịrị nke anọ, ga-abụ nkume topaazi, ọniks na jaspa. Hịọnye ha nʼime ihe ọlaedo a kpara akpa.  
\v 21 Ha niile ga-adị nkume iri na abụọ, nke ọbụla na-anọchi anya aha ụmụ ndị ikom Izrel. Egbunyere aha ebo iri na abụọ ahụ, otu nʼotu, nke ọbụla dịka aha ya si dị. 
\p  
\v 22 “Jiri ọlaedo a nụchara anụcha mee eriri a kpara akpa dịka ụdọ, maka ihe mgbochi obi.  
\v 23 Kpụkwaa mgbaaka ọlaedo abụọ, dụnye ha na nkuku abụọ nke ihe mgbochi obi ahụ.  
\v 24 Dụnye ụdọ ọlaedo abụọ ndị ahụ nʼelu mgbaaka ndị ahụ dị na nkuku ihe mgbochi obi ahụ,  
\v 25 were isi ndị ọzọ nke ụdọ ahụ dụnye nʼihe ahụ a kpara akpa, konye ha nʼelu ubu efọọd ahụ, nʼebe ihu ya.  
\v 26 Ị ga-emekwa mgbaaka ọlaedo, konye ha na nkuku abụọ nke ihe mgbochi obi ahụ, nʼime ọnụ ọnụ ya ebe dị nso efọọd ahụ.  
\v 27 Ị ga-akpụ mgbaaka ọlaedo abụọ ọzọ, konye ha nʼelu ubu abụọ nke efọọd ahụ, nʼokpuru nʼebe nʼihu ya, na nso nso ebe a dụkọtara ya, nʼelu ihe okike ukwu nke efọọd ahụ.  
\v 28 A ga-eji eriri na-acha anụnụ kekọta mgbaaka ihe mgbochi obi ahụ na mgbaaka efọọd ahụ, jikọtaa ya na ihe okike ukwu ahụ, ime ka ihe mgbochi obi ahụ ghara ịtọghapụ site nʼefọọd ahụ. 
\p  
\v 29 “Nʼụzọ dị otu a, mgbe ọbụla Erọn banyere nʼEbe Nsọ, ọ ga-ebu aha ụmụ ndị ikom Izrel niile nʼelu obi ya, nʼelu ihe mgbochi obi nke ikpe ahụ, dịka ihe ncheta nʼihu \nd Onyenwe anyị\nd* mgbe niile.  
\v 30 Ị ga-etinyekwa nʼime ihe mgbochi obi ahụ ụmụ nkume abụọ e ji ajụta ase nke bụ Urim na Tumim.\f + \fr 28:30 \ft Urim na Tumim bụ nkume e ji ajụta ase, na ntụziaka site nʼebe Chineke nọ.\f* Ha ga-adị nʼelu obi Erọn mgbe ọbụla ọ gara nʼihu \nd Onyenwe anyị\nd*. Otu a kwa, Erọn ga-ebukwa ihe e ji ajụta ase banyere ndị Izrel nʼelu obi ya mgbe niile, nʼihu \nd Onyenwe anyị\nd*. 
\s1 Uwe ndị nchụaja ndị ọzọ 
\p  
\v 31 “Ọ bụ akwa nke na-acha anụnụ anụnụ, ka ị ga-eji dụọ uwe mwụda efọọd ahụ.  
\v 32 Ọ ga-enwe oghere nʼetiti ya ebe a ga-esi na-etinye isi. A ga-enwe ihe ọkpụkpa gburugburu oghere a dịka nke olu uwe agha, ime ka o sie ike, ghara ịdọka.  
\v 33 Nʼọnụ ala ala uwe ahụ gburugburu, ị ga-akpanye ihe ọkpụkpa oyiyi mkpụrụ pomegranet. Ọ bụ ogho nke na-acha anụnụ anụnụ, ngwakọta anụnụ na uhie na uhie uhie ka ị ga-eji. Ị ga-akpanyekwa ataṅụ ọlaedo nʼetiti ha.  
\v 34 Nʼọnụ ọnụ ala uwe mwụda ahụ, a ga-adụnye otu ataṅụ ọlaedo, otu oyiyi mkpụrụ pomegranet, gbaa gburugburu.  
\v 35 Mgbe ọbụla Erọn na-eje ozi ya, ọ ghaghị iyi ya. Aga na anụ mgbịrịgba ataṅụ ahụ ka ọ na-akụ, mgbe ọ banyere nʼEbe Nsọ ahụ nʼihu \nd Onyenwe anyị\nd*, na mgbe o si nʼebe ahụ na-apụta, ka ọ ghara ịnwụ. 
\p  
\v 36 “Ị ga-ejikwa ọlaedo a nụchara anụcha mee efere ntakịrị, gbunye akara dị otu a nʼelu ya: 
\pc Ihe nsọ dịrị Onyenwe anyị. 
\m  
\v 37 Kenye eriri na-acha anụnụ anụnụ i ji jikọta ya na ihe ike nʼisi ahụ; ọ ga-adị nʼihu akwa ike nʼisi ahụ.  
\v 38 Ọ ga-adị nʼegedege ihu Erọn. Ọ ga-ebukwa ikpe ọmụma metụtara njehie gbasara ihe nsọ niile nke ụmụ Izrel doro nsọ, na onyinye ha niile. Ọ ga-adị nʼegedege ihu Erọn mgbe niile, ka ha bụrụ ndị \nd Onyenwe anyị\nd* ga-anabata. 
\p  
\v 39 “Jiri ezi akwa ọcha kpaa uwe ime ahụ. Werekwa ezi akwa ọcha mee akwa ike nʼisi ahụ. Ihe ike nʼukwu ahụ ga-abụ ọrụ aka onye ǹka na-akpanye ihe ịchọ mma.  
\v 40 Meekwara ụmụ ndị ikom Erọn uwe ime ahụ, ihe ike nʼukwu na akwa ike nʼisi, inye ha ugwu na nsọpụrụ.  
\v 41 Mgbe i yinyekwasịrị Erọn nwanne gị na ụmụ ya ndị ikom uwe ndị a, tee ha mmanụ, doo ha nsọ. Chee ha nʼihu m ka ha bụrụ ndị na-ejere m ozi dịka ndị nchụaja. 
\p  
\v 42 “Meekwara ha uwe ụkwụ nke eji akwa ọcha mee, maka ikpuchi anụ ahụ ha. Ọ ga-esite nʼukwu ruo nʼikpere.  
\v 43 Erọn na ụmụ ya ndị ikom aghaghị iyi ha mgbe niile ha ga-aba nʼime ụlọ nzute, maọbụ mgbe ha na-abịa nso ebe ịchụ aja ije ozi nʼEbe Nsọ. Ka ha ghara imeta ihe ikpe ọmụma, ma nwụọ. 
\p “Nke a ga-abụ iwu na ụkpụrụ ebighị ebi, nke ga-adịrị Erọn na ụmụ ụmụ ya. 
\c 29  
\s1 Ido ndị nchụaja nsọ 
\p  
\v 1 “Nke a ga-abụ usoro mmemme nke ị ga-eme, iji doo Erọn na ụmụ ya ndị ikom nsọ, ka ha na-ejere m ozi dịka ndị nchụaja. Were nwa oke ehi na ebule abụọ nke na-enweghị ntụpọ ọbụla.  
\v 2 Werekwa ọka wiiti a kwọrọ nke ọma, mee achịcha nke na-enweghị ihe na-eko achịcha e tinyere nʼime ha, achịcha mbadamba na-ekoghị eko nke e ji mmanụ oliv gwakọtaa, ya na achịcha mbadamba ọzọ dị nta na-ekoghị eko nke e tere mmanụ nʼahụ ya.  
\v 3 Mgbe ahụ, ị ga-etinye achịcha ndị a niile nʼime otu nkata, bute ha nʼime nkata ahụ, wetakwa nwa oke ehi, na ebule abụọ.  
\v 4 Kpọpụta Erọn na ụmụ ya ndị ikom nʼọnụ ụzọ ụlọ nzute, jiri mmiri saa ha ahụ.  
\v 5 Yikwasị Erọn uwe ime ahụ, uwe mwụda nke efọọd, efọọd ahụ na ihe mgbochi obi. Were ihe okike efọọd ahụ nke akpaziri nke ọma kegide ya efọọd ahụ nʼahụ.  
\v 6 Tụhịakwa akwa ike nʼisi ahụ nʼisi ya. Tinye okpu nsọ ahụ nʼelu akwa ike nʼisi ahụ.  
\v 7 Werekwa mmanụ nsọ ahụ, tee ya, site nʼịwụkwasị ya nʼisi ya.  
\v 8 Kpọta ụmụ ya ndị ikom, yikwasị ha uwe ime ahụ.  
\v 9 Kekwasịkwa ha ihe okike nʼisi. Keekwa Erọn na ụmụ ya ndị ikom ihe ike nʼukwu. Mgbe ahụ ọrụ ndị nchụaja ga-abụ nke ha site nʼụkpụrụ ebighị ebi. 
\p “Nʼụzọ dị otu a ka ị ga-esi doo Erọn na ụmụ ya ndị ikom nsọ. 
\p  
\v 10 “Kpụta oke ehi ahụ nʼihu ụlọ nzute. Erọn na ụmụ ndị ikom ga-ebikwasị aka ha nʼelu isi ya.  
\v 11 Gbuo ya nʼihu \nd Onyenwe anyị\nd* nʼọnụ ụzọ ụlọ nzute ahụ.  
\v 12 Jiri mkpịsịaka gị rụta ụfọdụ nʼime ọbara oke ehi ahụ tee ya na mpi dị nʼebe ịchụ aja ahụ. Wụpụ ọbara fọdụrụ nʼụkwụ ala ala ebe ịchụ aja.  
\v 13 Were abụba niile kpuchiri ihe ime ya, mba-umeju nke dị nʼumeju ya, akụrụ ya abụọ ya na abụba dị nʼelu ha, kpọọ ha ọkụ nʼelu ebe ịchụ aja.  
\v 14 Ma anụ oke ehi ahụ, akpụkpọ ya na mgbịrị afọ ya, ka ị ga-akpọ ọkụ nʼazụ ọmụma ụlọ ikwu ahụ. Ọ bụ aja mmehie. 
\p  
\v 15 “Were otu nʼime ebule ndị ahụ, ka Erọn na ụmụ ya ndị ikom bikwasị aka ha nʼelu isi ya.  
\v 16 Gbuo ya. Werekwa ọbara ya fesaa nʼakụkụ ya niile nke ebe ịchụ aja.  
\v 17 Bọwasịa ebule ahụ ntakịrị ntakịrị, sachaa eriri afọ ya na ihe dị ya nʼime, ha na ụkwụ ya niile, tinyekọ ha na isi ya na akụkụ anụ ndị ọzọ.  
\v 18 Kpọọ ebule ahụ niile ọkụ nʼelu ebe ịchụ aja. Ọ bụ aja nsure ọkụ nye \nd Onyenwe anyị\nd*, nke isisi ya dị ezi mma. Aja a chụrụ nye \nd Onyenwe anyị\nd* site nʼọkụ. 
\p  
\v 19 “Were ebule nke ọzọ, ka Erọn na ụmụ ya ndị ikom ga-ebikwasị aka ha nʼelu isi ya.  
\v 20 Gbuo ya. Were ụfọdụ nʼime ọbara ya tee Erọn na ụmụ ya nʼọnụ ntị aka nri ha, na isi mkpụrụ aka nke aka nri ha, ya na isi mkpụrụ ụkwụ nke ụkwụ aka nri ha. Werekwa ọbara nke fọdụrụ fesaa nʼakụkụ ya niile nke ebe ịchụ aja ahụ.  
\v 21 Ị ga-esite nʼelu ebe ịchụ aja were ụfọdụ ọbara, ya na ụfọdụ mmanụ nsọ, fesa ya nʼahụ Erọn na nʼelu uwe ya, nʼahụ ụmụ ya ndị ikom, nakwa nʼelu uwe ha niile. Mgbe ahụ, ya na ụmụ ya ndị ikom ga-abụ ndị e doro nsọ nye \nd Onyenwe anyị\nd*, ha na uwe ha. 
\p  
\v 22 “Were abụba ebule ahụ, na akụkụ ọdụdụ ya nwere abụba, na abụba nke kpuchiri ime ya, mba-umeju nke dị nʼumeju ya, akụrụ ya abụọ na abụba gbara ha gburugburu, na apata aka nri ya (nʼihi na ebule ahụ bụ ebule ido nsọ),  
\v 23 site na nkata achịcha ahụ a na-ejighị ihe na-eko achịcha mee, nke na-adị nʼihu \nd Onyenwe anyị\nd*. Were otu achịcha dị gburugburu, otu ogbe achịcha a gwakọtara mmanụ oliv, na otu mbadamba ogbe achịcha,  
\v 24 tinye ihe ndị a niile nʼaka Erọn na ụmụ ya ndị ikom, mee ka ha fufee ha nʼihu \nd Onyenwe anyị\nd* dịka aja mfufe.  
\v 25 Mgbe ahụ, nara ha site nʼaka ha. Kpọọ ha ọkụ nʼelu ebe ịchụ aja ha na aja nsure ọkụ, ka ọ bụrụ ihe isisi ya dị ezi mma nye \nd Onyenwe anyị\nd*. Onyinye nsure ọkụ nye \nd Onyenwe anyị\nd*.  
\v 26 Mgbe i wepụtara obi ebule ahụ e ji doo Erọn nsọ, fufee ya nʼihu \nd Onyenwe anyị\nd* dịka aja mfufe. Ọ ga-abụkwa oke nke gị. 
\p  
\v 27 “Doo akụkụ ebule ido nsọ ahụ nsọ, ndị nke bụ oke Erọn na ụmụ ya ndị ikom, ya bụ, obi ya e fufere efufe na apata ya e chere nʼihu \nd Onyenwe anyị\nd*.  
\v 28 Nke a ga-abụ oke Erọn na ụmụ ụmụ ya ga-eketa dịka ụkpụrụ mgbe ebighị ebi nʼaka ndị Izrel. Mgbe niile ọbụla ha na-achụ aja udo maọbụ aja ekele, ka nke a bụrụ onyinye ụmụ Izrel na-enye \nd Onyenwe anyị\nd* site nʼaja ha. 
\p  
\v 29 “Uwe nsọ Erọn ndị a niile ka a ga-edebe nʼihi mmemme ido nsọ. A ga-eji ha na-edo ụmụ ya nsọ bụ ndị ga-anọchi anya ya site nʼọgbọ ruo nʼọgbọ.  
\v 30 Nwa ya nwoke ọbụla nke nọchiri anya ya dịka onye nchụaja, nke bịara nʼụlọ nzute m ije ozi nʼEbe Nsọ ga-eyi uwe ndị a ụbọchị asaa. 
\p  
\v 31 “Were anụ ebule ido nsọ ahụ, sienụ anụ ahụ nʼebe dị nsọ.  
\v 32 Erọn na ụmụ ya ndị ikom ga-eri anụ ebule ahụ, na achịcha ndị ahụ dị nʼime nkata nʼọnụ ụzọ ụlọ nzute.  
\v 33 Ha ga-eri ihe ndị aja niile ahụ nke e ji chụọ aja mkpuchi mmehie, nʼoge ido nsọ ha. Ọ dịghị onye ọbụla ọzọ ga-eso ha rie ya, nʼihi na ha bụ ihe dị nsọ.  
\v 34 Ọ bụrụ na ụfọdụ nʼime anụ na achịcha ido nsọ ndị ahụ afọdụ ruo ụtụtụ, a ga-akpọ ha ọkụ. A gaghị eri ya ọzọ, nʼihi na ọ bụ ihe dị nsọ. 
\p  
\v 35 “Ọ bụ otu a ka a ga-esi doo Erọn na ụmụ ya ndị ikom nsọ, dịka ihe niile m nyere gị nʼiwu si dị. Ọ ga-ewe ụbọchị asaa iji doo ha nsọ.  
\v 36 Ị ga-achụ aja oke ehi dịka aja mmehie maka ikpuchi mmehie kwa ụbọchị. Ị ga-emekwa ka ebe ịchụ aja m dị ọcha, site nʼịchụ aja mkpuchi mmehie nʼelu ya, na ite ya mmanụ nʼihi iji doo ya nsọ.  
\v 37 Ụbọchị asaa ka ị ga-edo ebe ịchụ aja nsọ site nʼịchụ aja mkpuchi mmehie. Mgbe ahụ ebe ịchụ aja ga-abụ ebe dịkarịsịrị nsọ. Ihe ọbụla metụrụ ebe ịchụ aja ahụ ga-adị nsọ. 
\p  
\v 38 “Ma nke a bụ ihe ị ga-achụ nʼelu ebe ịchụ aja kwa ụbọchị, ị ga-eji ụmụ atụrụ abụọ gbara otu afọ chụọ aja.  
\v 39 Chụọ otu nʼoge ụtụtụ; chụọkwa nke ọzọ nʼoge uhuruchi.  
\v 40 Ị ga-ewere nwa atụrụ, tinyere lita ụtụ ọka abụọ a kwọziri akwọzi nke a gwọkọtara nʼotu lita mmanụ oliv asụrụ asụ, chụọ aja. Wetakwa otu lita mmanya dịka aja ihe ọṅụṅụ.  
\v 41 Jirikwa nwa atụrụ nke ọzọ, ya na otu ụdị aja mkpụrụ ọka na aja ihe ọṅụṅụ ya dịka i mere nʼụtụtụ. Aja isisi ya dị ezi mma, nke e sitere nʼọkụ a na-achụ nye \nd Onyenwe anyị\nd*. 
\p  
\v 42 “A ga na-achụ aja nsure ọkụ a oge niile nʼọgbọ niile, nʼọnụ ụzọ ụlọ nzute m ka a ga-achụ ya, nʼihu \nd Onyenwe anyị\nd*. Nʼihi nʼebe ahụ ka m ga-ezute gị gwa gị okwu.  
\v 43 Nʼebe ahụ kwa ka m ga-ezute ndị Izrel niile. Nʼihi ya, aga m esite nʼịdị ebube m doo ebe ahụ nsọ. 
\p  
\v 44 “E, aga m edo ụlọ nzute ahụ nsọ, ya na ebe ịchụ aja, na Erọn na ụmụ ya ndị ikom, ka ha na-ejere m ozi dịka ndị nchụaja.  
\v 45 Mgbe ahụ, aga m ebi nʼetiti ụmụ Izrel, bụrụkwa Chineke ha.  
\v 46 Ha ga-amata na m bụ \nd Onyenwe anyị\nd* Chineke ha. Onye sitere nʼala Ijipt kpọpụta ha, ka m si otu a biri nʼetiti ha. Abụ m \nd Onyenwe anyị\nd* Chineke ha. 
\c 30  
\s1 Ebe ịchụ aja ụda na-esi isi ụtọ 
\p  
\v 1 “Jiri osisi akashia rụọ ebe ịchụ aja ihe nsure ọkụ na-esi isi ụtọ.  
\v 2 Akụkụ anọ ya ga-aha nʼotu. Ogologo ya na obosara ya ga-adị iri sentimita anọ na ise. Ịdị elu ya ga-adị iri sentimita itoolu. Mpi ya niile ga-esi na ya pụta.  
\v 3 Jiri ọlaedo a nụchara anụcha machie elu ya, akụkụ ya niile nakwa mpi ya niile. Ị ga-ejikwa ọlaedo kpụlite ọnụ ọnụ ya gburugburu.  
\v 4 Kpụnye mgbaaka ọlaedo abụọ nʼokpuru ihe ahụ akpụlitere akpụlite, abụọ na ncherita ihu akụkụ ọbụla, ebe ga na-ejide mkpara e ji ebu ya.  
\v 5 Ị ga-eji osisi akashia mee mkpara, jiri ọlaedo machie ha.  
\v 6 Ị ga-adọba ebe ịchụ aja ahụ nʼihu akwa mgbochi nke kpuchiri igbe iwu ọgbụgba ndụ ahụ, nʼihu oche ebere ahụ dị nʼelu igbe iwu ọgbụgba ndụ, nʼebe m ga-ezute gị. 
\p  
\v 7 “Ụtụtụ niile, mgbe Erọn doziri oriọna, ọ ga-esure ihe nsure ọkụ na-esi isi ụtọ nʼelu ebe ịchụ aja ahụ.  
\v 8 Nʼanyasị kwa, mgbe ọ na-amụnye ọkụ nʼoriọna ahụ, ọ ga-esurekwa ihe nsure ọkụ. Ihe nsure ọkụ na-esi isi ụtọ nke ga-adị nʼihu \nd Onyenwe anyị\nd* site nʼọgbọ ruo nʼọgbọ.  
\v 9 Unu echekwala ihe nsure ọkụ na-esi isi ụtọ na-adịghị nsọ nʼelu ya, maọbụ aja nsure ọkụ, maọbụ aja ihe oriri, unu awụpụla onyinye ihe ọṅụṅụ nʼelu ya.  
\v 10 Otu ugbo nʼafọ Erọn ga-ekpuchi mmehie nʼelu mpi ya. Mmemme mkpuchi mmehie a nke a na-eme otu ugbo nʼafọ, aghaghị ịbụ nke e ji ọbara nke si nʼaja a chụrụ nʼihi mkpuchi mmehie,\f + \fr 30:10 \ft Maọbụ, \fqa ido nsọ\f* nʼihi ọgbọ niile nke na-abịa. A ga na-edo ebe ịchụ aja nsọ otu a. Nke a bụ ebe dịkarịsịrị nsọ nye \nd Onyenwe anyị\nd*.” 
\s1 Ụtụ nʼihi ikpuchi mmehie 
\p  
\v 11 Mgbe nke a gasịrị, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 12 “Mgbe ọbụla a gụrụ mmadụ ọnụ, onye Izrel ọbụla ga-akwụ \nd Onyenwe anyị\nd* ụgwọ o ji gbara mkpụrụobi ya. Nke a dị mkpa, ka ihe otiti ọbụla ghara ịbịakwasị ha mgbe ị ga-agụ ha ọnụ.  
\v 13 Ihe onye a gụrụ ọnụ ga-akwụ bụ ọkara shekel, dịka shekel nke ebe nsọ si dị. Ọkara shekel bụ iri gera abụọ.\f + \fr 30:13 \ft \xt Mat 17:24\f* Ọkara shekel a bụ onyinye nye \nd Onyenwe anyị\nd*.  
\v 14 Ndị kwesiri inye onyinye a bụ ndị niile gbara iri afọ abụọ gbagoo. Ọ bụ ndị a kwesiri inye \nd Onyenwe anyị\nd* onyinye a.  
\v 15 Ndị ọgaranya agaghị enye karịa ọkara shekel. Otu a kwa ndị ogbenye agaghị enye ihe dị ntakịrị karịa ọkara shekel. Nʼihi na onyinye a bụ onyinye unu na-enye \nd Onyenwe anyị\nd* maka ikpuchiri mkpụrụobi unu mmehie.  
\v 16 Nabata ego niile ndị a site nʼaka ụmụ Izrel, ma jiri ya jee ozi dị nʼụlọ nzute. Ihe onyinye a ga-eme bụ ịkpọtụ uche \nd Onyenwe anyị\nd* nʼebe unu nọ nʼihi mkpuchi mmehie maka ndụ unu.” 
\s1 Efere mmiri ọsịsa 
\p  
\v 17 Ọzọkwa, \nd Onyenwe anyị\nd* gwara Mosis okwu sị,  
\v 18 “Jiri bronz kpụọ efere ukwu na ihe ndọkwasị ya, maka ịsa ihe. Wụnye mmiri nʼime ya, dọsa ya nʼetiti ụlọ nzute na ebe ịchụ aja.  
\v 19 Erọn na ụmụ ya ndị ikom ga na-asa ụkwụ na aka ha site na ya.  
\v 20 Mgbe ọbụla ha na-aba nʼụlọ nzute ahụ, ha ga-eji mmiri saa onwe ka ha ghara ịnwụ. Ọzọkwa, mgbe ha na-abịaru nso nʼebe ịchụ aja, maka ije ozi iche onyinye nʼihu \nd Onyenwe anyị\nd* site nʼọkụ,  
\v 21 ha ga-asa aka ha na ụkwụ ha, ka ha ghara ịnwụ. Nke a ga-abụ ụkpụrụ dịrị Erọn na ụmụ ya ndị ikom site nʼọgbọ ruo nʼọgbọ.” 
\s1 Mmanụ Nsọ 
\p  
\v 22 Ọzọkwa, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 23 “Were eso osisi na-esi isi ụtọ ndị a dị iche iche: máá, nke ọtụtụ ya ruru kilo isii, na ihe ruru kilo sinamọn abụọ na ụma itoolu, na kilo kalamus atọ,  
\v 24 na kilo kashia isii, na lita anọ na ụma asatọ nke mmanụ oliv,\f + \fr 30:24 \ft Ya bụ otu Hin\f* dịka ọtụtụ shekel ebe nsọ ahụ si dị.  
\v 25 Ị ga-eji ya mepụta mmanụ nsọ, nke dị nsọ, nke a gwakọtara nke ọma dịka nke onye na-eme mmanụ na-esi isi ụtọ mere. Ọ ga-abụ mmanụ otite dị nsọ.  
\v 26 Ị ga-ewere mmanụ ahụ tee ụlọ nzute ahụ niile na igbe iwu ọgbụgba ndụ ahụ,  
\v 27 na tebul ahụ, na ngwongwo ya niile, na nʼihe ịdọsa oriọna, na nʼihe niile dị ya nʼahụ, na nʼebe ịdọsa ihe nsure ọkụ na-esi isi ụtọ,  
\v 28 na nʼebe ịchụ aja nke aja nsure ọkụ, na ngwongwo ya niile, na nʼite ịsa ụkwụ na aka, na nʼebe a na-adọba ya.  
\v 29 Ị ga-edo ha nsọ, ka ha bụrụ ihe dịkarịrị nsọ. Ihe ọbụla metụrụ ha ahụ ga-adịkwa nsọ. 
\p  
\v 30 “Ị ga-eji mmanụ otite a tee Erọn na ụmụ ya ndị ikom. Ha niile ga-adịkwa nsọ, bụrụ ndị na-ejere m ozi dịka ndị nchụaja.  
\v 31 Gwa ụmụ Izrel okwu sị ha, ‘Nke a bụ mmanụ nsọ m, nke dị nsọ site nʼọgbọ ruo nʼọgbọ.  
\v 32 Agaghị awụsa ya nʼahụ mmadụ. O nwekwaghị onye kwesiri imepụta mmanụ otite dị otu a. Ọ dị nsọ, unu kwesikwara ido ya nsọ.  
\v 33 A ga-esite nʼetiti ndị m wezuga onye ọbụla mere ụdị mmanụ isi ọma a, maọbụ tee ya onye na-abụghị onye nchụaja m.’ ” 
\s1 Ihe nsure ọkụ na-esi isi ụtọ 
\p  
\v 34 Mgbe ahụ \nd Onyenwe anyị\nd* gwara Mosis okwu sị, “Were ụda na-esi isi ụtọ, dịka eso osisi stakit, na ọnyịcha, na galbanọm, na ezigbo frankisens a na-agwaghị ihe, nke ọtụtụ ha niile ga-abụ otu ihe.  
\v 35 Mee ihe nsure ọkụ na-esi isi ụtọ, nke a gwakọtara nke ọma, bụ ọrụ onye na-eme mmanụ isi ụtọ. Tinyekwa ya nnu, ka ọ bụrụ ihe nsure ọkụ a nụchara anụcha, nke dịkwa nsọ.  
\v 36 Gwerie ụfọdụ nʼime ya ka ọ dịka uzuzu. Wụsa ya nʼihu igbe iwu ọgbụgba ndụ ahụ nʼime ụlọ nzute, ebe m ga-ezute gị. Ọ ga-abụ ihe dịkarịsịrị nsọ nye unu.  
\v 37 Unu emerela onwe unu nke dịka ọtụtụ ụdị ihe nsure ọkụ a. Hụta ya ka ihe dị nsọ nʼebe \nd Onyenwe anyị\nd* nọ.  
\v 38 Onye ọbụla meere onwe ya ụdị ihe nsure ọkụ a, ịnụ isisi ya, a ga-ekewapụ onye ahụ site nʼetiti ụmụnna ya.” 
\c 31  
\s1 Bezalel na Oholiab 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu sị,  
\v 2 “Lee, ahọpụtala m Bezalel nwa Uri, nwa Hua, onye si nʼebo Juda,  
\v 3 emejupụtakwala m ya na Mmụọ nke Chineke, nʼamamihe, nghọta, ihe ọmụma na ike ije ozi ọrụ ǹka dị iche iche,  
\v 4 ichepụta ihe ǹka dị iche iche, nke metụtara ọlaọcha na ọlaedo na bronz,  
\v 5 ịwa nkume na ido nkume, ịkwa ǹka osisi, na ịrụ ọrụ ǹka dị iche iche.  
\v 6 Ọzọkwa, ahọpụtala m Oholiab, nwa Ahisamak, onye si nʼebo Dan, ka ọ bụrụ onye inyeaka Bezalel. 
\b  
\li4 “Enyekwala m ndị ǹka niile amara ịrụ ọrụ dị iche, nke ga-enyere ha aka ịrụ ihe ndị a niile m nyere gị iwu ịrụ: 
\b  
\li1  
\v 7 “ya bụ, ụlọ nzute ahụ, 
\li1 na igbe iwu ọgbụgba ndụ ahụ, na ebe mkpuchi mmehie dị ya nʼelu, 
\li1 na ngwongwo ndị ọzọ niile dị nʼụlọ ikwu ahụ, 
\li2  
\v 8 na tebul, na ngwongwo ya, 
\li2 ma ihe ịdọkwasị oriọna nke ọlaedo a nụchara anụcha, 
\li2 na ngwongwo ya, 
\li2  
\v 9 na ebe ịchụ aja nke aja nsure ọkụ na-esi isi ụtọ, na ebe ịchụ aja nke aja nsure ọkụ, na ngwongwo ya, 
\li2 na ite mmiri ịsa ụkwụ na aka, na ụkwụ ite ahụ. 
\li1  
\v 10 Na uwe ọma ahụ akpara akpa, 
\li2 ma uwe nsọ Erọn onye nchụaja 
\li2 na uwe nke ụmụ ya ndị ikom, mgbe ha na-eje ozi dịka ndị nchụaja. 
\li1  
\v 11 Ya na mmanụ nsọ ahụ, na ihe nsure ọkụ na-esi isi ụtọ e mere maka Ebe Nsọ. 
\b  
\li4 “Ha ga-arụzu ihe ndị a nʼusoro dịka m si nye gị ya nʼiwu.” 
\s1 Ụbọchị izuike 
\p  
\v 12 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị Mosis,  
\v 13 Gwa ndị Izrel, “Unu aghaghị ido ụbọchị izuike m nsọ. Nʼihi na nke a ga-abụ ihe ịrịbama nʼetiti mụ na unu ruo ọgbọ niile ga-abịa, ka unu maara na mụ onwe m bụ \nd Onyenwe anyị\nd*, onye na-edo unu nsọ. 
\p  
\v 14 “ ‘Ụbọchị izuike m dị nsọ nye unu. Nʼihi nke a, unu ga-edebe ya nsọ. Ọ bụrụ na onye ọbụla edebeghị ya nsọ, ọ ga-anwụ. Ọ bụrụkwa na onye ọbụla arụọ ọrụ ọbụla nʼụbọchị izuike m, a ga-ewezuga ya site nʼebe unu nọ.  
\v 15 Ụbọchị isii ka unu ga-arụ ọrụ unu niile. Ma ụbọchị nke asaa dị iche. Ọ bụ ụbọchị izuike. Ọ bụkwa ụbọchị dị nsọ nye \nd Onyenwe anyị\nd*. Nʼihi nke a, onye ọbụla rụrụ ọrụ ọbụla nʼụbọchị Izuike ga-anwụ.  
\v 16 Ndị Izrel ga-edebe ụbọchị Izuike, na-eme mmemme ya nʼọgbọ niile, dịka ọgbụgba ndụ nke ebighị ebi.  
\v 17 Ọ ga-abụ ihe ịrịbama nke ga-adịgide nʼetiti mụ na ndị Izrel ruo mgbe ebighị ebi. Nʼihi na nʼụbọchị isii ka \nd Onyenwe anyị\nd* kere eluigwe na ụwa. Ọ kwụsịrị ọrụ nʼụbọchị nke asaa, zuo ike, turu ndụ.’ ” 
\p  
\v 18 Mgbe \nd Onyenwe anyị\nd* gwasịrị Mosis okwu ndị a nʼelu ugwu Saịnaị, o nyere ya mbadamba nkume abụọ nke iwu ọgbụgba ndụ ahụ. Ọ bụkwa mbadamba nkume ndị ahụ nke mkpịsịaka Chineke dere ihe nʼelu ha. 
\c 32  
\s1 Oyiyi nwa ehi ọlaedo 
\p  
\v 1 Mgbe ndị mmadụ ahụ hụrụ na Mosis anọọla ọdụ ịrịdata site nʼelu ugwu Saịnaị, ha zukọtara, bịakwute Erọn, sị ya, “Bilie, meere anyị chi ndị ga-edu anyị, nʼihi na nwoke a bụ Mosis onye dupụtara anyị site nʼala Ijipt, anyị amaghị ihe mere ya.” 
\p  
\v 2 Erọn zara sị ha, “Yipụtanụ ọlantị ọlaedo ndị nwunye unu, na ụmụ unu ndị ikom na ndị inyom yi. Wetara m ha.”  
\v 3 Ngwangwa, ha niile yipụrụ ọlantị ha weta ha nye Erọn.  
\v 4 Ọ naara ya nʼaka ha, were ngwa ọrụ e ji egbunye akara, kpụtara ha arụsị nwa oke ehi. Mgbe ahụ, ha kwuru sị, “Ndị Izrel, ndị a bụ chi unu, nke sitere nʼala Ijipt dupụta unu.” 
\p  
\v 5 Mgbe Erọn hụrụ na ụmụ Izrel jupụtara nʼobi aṅụrị, nʼihi ihe ahụ ọ kpụrụ, o wuru ebe ịchụ aja nʼihu nwa ehi ahụ ọ kpụrụ, kwuo okwu sị, “Echi, a ga-enwe oke mmemme nye \nd Onyenwe anyị\nd*!”  
\v 6 Ya mere na echi ya, ha biliri nʼoge, bido ịchụ aja nsure ọkụ, na aja udo, nye nwa ehi ahụ a kpụrụ akpụ. Mgbe nke a gasịrị, ha nọdụrụ ala iri ihe na ịṅụ ihe ọṅụṅụ, biliekwa ọtọ gwurie egwu ime onwe ha obi ụtọ. 
\p  
\v 7 Nʼoge ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị, “Gbada ọsịịsọ, nʼihi na ndị gị, ndị i dupụtara site nʼIjipt emerụọla onwe ha.  
\v 8 Nʼotu ntabi anya a, ha ahapụla ụzọ m niile. Ha akpụọlara onwe ha arụsị nwa oke ehi, nke ha na-efe ofufe, nke ha chụkwaara aja nye. Ha kwukwara sị, ‘Ndị Izrel, ndị a bụ chi unu, nke dupụtara unu site nʼala Ijipt.’ ” 
\p  
\v 9 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị Mosis, “Ahụla m na ndị a bụ ndị isiike, na ndị na-enupu isi.  
\v 10 Ugbu a, hapụ m ka iwe m bịakwasị ha, ka m laa ha nʼiyi. Aga m eme ka gị onwe gị bụ Mosis bụrụ mba ukwu nʼọnọdụ ha.” 
\p  
\v 11 Ma Mosis rịọrọ \nd Onyenwe anyị\nd* Chineke ya arịrịọ sị ya, “Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* gịnị mere iwe gị ji dị ọkụ otu a nʼebe ndị gị nọ bụ ndị nke i ji ike ebube gị, na ọtụtụ ihe ịrịbama dị ịtụnanya, dupụta site nʼala Ijipt?  
\v 12 Nʼihi gịnị ka ndị Ijipt ga-ekwu sị, ‘Ọ bụghị ime ha ihe ọjọọ ka o ji dupụta ha, ka o nwee ike gbuo ha nʼugwu ndị a, ma kpochapụkwa ha site nʼelu ụwa a?’ Site nʼiwe gị dị ọkụ chigharịa, kwere ka ọ dajụọ. Chigharịakwaa site nʼatụmatụ ọjọọ a nʼebe ndị gị nọ.  
\v 13 Cheta nkwa ahụ i kwere ndị ohu gị bụ Ebraham, Aịzik, na Izrel. Nʼihi na i ji onwe gị ṅụọ iyi nye ha sị, ‘Aga m eme ka mkpụrụ gị mụbaa dịka kpakpando nke eluigwe. Aga m enye ha ala m kwere ụmụ ụmụ gị na nkwa ka ọ bụrụ ihe nketa ha ruo mgbe ebighị ebi.’ ”  
\v 14 Ya mere, \nd Onyenwe anyị\nd* gbanwere obi ya. Ọ lakwaghị ha nʼiyi. 
\p  
\v 15 Mgbe ahụ, Mosis tụgharịrị site nʼugwu ahụ rịdata, mbadamba nkume abụọ nke iwu ọgbụgba ndụ ahụ dị ya nʼaka. E dere ha ihe nʼihu abụọ, nʼihu nakwa nʼazụ.  
\v 16 Mbadamba nkume ndị ahụ bụ akaọrụ Chineke, ihe e dere nʼelu ha bụ ihe Chineke nʼonwe ya dekwasịrị nʼelu mbadamba nkume ndị ahụ. 
\p  
\v 17 Mgbe Joshua nụrụ ụzụ si na ndịda ugwu ahụ, nke ụmụ Izrel niile na-eme, ọ gwara Mosis okwu sị, “Ụzụ agha dị nʼọmụma ụlọ ikwu.” 
\p  
\v 18 Ma Mosis zara sị, 
\q1 “Mba, nke a abụghị ụzụ ndị meriri nʼagha, 
\q2 maọbụ ụzụ ndị e meriri nʼagha, 
\q2 kama ọ bụ olu abụ ka m na-anụ.” 
\p  
\v 19 Mgbe Mosis bịaruru nso ebe ahụ ha mara ụlọ ikwu ha, hụ nwa oke ehi ahụ a kpụrụ akpụ na egwu a na-ete, iwe were ya nke ukwuu. Ọ tụpụrụ mbadamba nkume ndị ahụ o ji nʼaka. Kụrie ha na ndịda ugwu ahụ.  
\v 20 Mosis weere nwa oke ehi ahụ ha kpụrụ akpụ, kpọọ ya ọkụ. Mgbe ahụ, o gweriri ya dịka ntụ. Fesaa ya nʼelu mmiri mee ka ụmụ Izrel ṅụọ mmiri ahụ. 
\p  
\v 21 Ọ gwara Erọn okwu sị, “Gịnị ka ndị a mere gị i ji bute ụdị mmehie ọjọọ dị otu a tụkwasị ha nʼisi?” 
\p  
\v 22 “Erọn zara sị ya, ka iwe gị ghara ịdị ọkụ, onyenwe m. Gị onwe gị maara ndị a, mata otu ha si bụrụ ndị ọjọọ.  
\v 23 Ha sịrị m, ‘Meere anyị chi ndị ga-edu anyị, nʼihi na nwoke a bụ Mosis onye dupụtara anyị site nʼala Ijipt, anyị amaghị ihe mere ya.’  
\v 24 Asịrị m ha, ‘Onye ọbụla nke nwere ihe ịchọ ọma ọlaedo, ya yipu ya.’ Mgbe ahụ, ha wetara m ọlaedo ndị a, nke m tụbara nʼime ọkụ. Ihe si na ya pụta bụ nwa ehi a kpụrụ akpụ!” 
\p  
\v 25 Mosis hụrụ na omume ndị a jọgbuziri onwe ya na njọ nʼihi na Erọn mere ka isi kopu ha. Nke mere ka ha bụrụzia ihe ọchị nʼebe ndị iro ha dị.  
\v 26 O guzoro nʼọnụ ụzọ ụlọ ikwu ahụ kwuo sị, “Onye ọbụla dịnyeere \nd Onyenwe anyị\nd* ya bịakwute m.” Ndị Livayị niile bịakwutere ya. 
\p  
\v 27 Mgbe ahụ, ọ sịrị ha, “Ihe ndị a ka \nd Onyenwe anyị\nd*, Chineke nke Izrel kwuru, ‘Nwoke ọbụla nyara mma agha ya nʼakụkụ ya,\f + \fr 32:27 \ft Nwoke ọ bụla kee mma agha ya nʼukwu ya\f* jegharịa nʼetiti ọmụma ụlọ ikwu ụmụ Izrel, site nʼotu isi ruo nʼisi nke ọzọ. Ya gbuo ọbụladị nwanne ya nwoke, maọbụ enyi ya, maọbụ onye agbataobi ya.’ ”  
\v 28 Ndị Livayị mezuru ihe Mosis gwara ha. Ya mere ndị nwụrụ nʼụbọchị ahụ dị puku mmadụ atọ.  
\v 29 Mgbe ahụ, Mosis gwara ndị Livayị okwu sị, “Taa, unu ekewapụtala onwe unu nye \nd Onyenwe anyị\nd*. Nʼihi na unu gburu ụmụ unu ndị ikom na ụmụnne unu ndị ikom. Ugbu a, ọ gọziela unu taa.” 
\p  
\v 30 Nʼechi ya, Mosis gwara ndị Izrel okwu sị ha, “Unu emeela mmehie dị ukwuu megide \nd Onyenwe anyị\nd*. Ma aga m alaghachikwuru \nd Onyenwe anyị\nd* nʼelu ugwu ahụ rịọọ ya. Ma eleghị anya, aga m arịọta maka ikpuchi mmehie unu.” 
\p  
\v 31 Ya mere, Mosis jekwuuru \nd Onyenwe anyị\nd* sị ya, “Biko Onyenwe anyị, ndị a emeela mmehie dị ukwuu megide gị, nʼihi na ha akpụọlara onwe ha chi ọlaedo.  
\v 32 Ma ugbu a, biko, gbaghara mmehie ha. Ọ bụrụ na ị gaghị agbaghara ha, biko hichapụ aha m site nʼakwụkwọ ahụ i dere.” 
\p  
\v 33 Ma \nd Onyenwe anyị\nd* zara sị Mosis, “Onye ọbụla mehiere megide m ka a ga-ehichapụ aha ya site nʼakwụkwọ m.  
\v 34 Ma ugbu a, duru ndị a gaa ebe ahụ m gwara gị. Mmụọ ozi m ga-edu unu nʼije a. Ma otu ọ dị, mgbe m bịara ileta ndị a, aga m ata ha ahụhụ nʼihi mmehie ha.” 
\p  
\v 35 Ya mere, \nd Onyenwe anyị\nd* mere ka ọrịa dị egwu bịakwasị ha, nʼihi ihe ha ji nwa ehi ahụ, bụ nke Erọn kpụrụ mee. 
\c 33  
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu sị, “Duru ndị a i si nʼala Ijipt kpọpụta baa nʼala ahụ m kwere Ebraham, na Aịzik na Jekọb na nkwa, nʼihi na agwara m ha sị, ‘Aga m enye ụmụ ụmụ unu ala a, ka ọ bụrụ ihe nketa ha.’  
\v 2 Aga m ezipu Mmụọ ozi m ka ọ gaa nʼihu unu chụpụrụ unu ndị Kenan, na ndị Amọrait, na ndị Het, na ndị Periz, na ndị Hiv, na ndị Jebus.  
\v 3 Gbago nʼala mmiri ara ehi na mmanụ aṅụ na-eru na ya, ma agaghị m eso unu nʼije unu, nʼihi na unu bụ ndị isiike. Ọ bụrụ na m esoro unu, unu ga-anwa m ọnwụnwa, nke ga-eme ka m laa unu nʼiyi nʼụzọ.” 
\p  
\v 4 Mgbe ndị mmadụ ahụ nụrụ okwu olu ike ndị a, ha malitere iru ụjụ, ọ dịghịkwa onye ọbụla yinyere ihe ịchọ mma ya nʼahụ ha.  
\v 5 Nʼihi na \nd Onyenwe anyị\nd* agwala Mosis sị, “Gwa ụmụ Izrel, ‘Unu bụ ndị isiike. A sị na m nọ nʼetiti unu, otu ntabi anya ezuorola m ịla unu nʼiyi. Ugbu a, yipụnụ ihe ịchọ mma niile unu yi nʼahụ, aga m ekpebi ihe m ga-eme unu.’ ”  
\v 6 Ya mere, ndị Izrel yipụrụ ihe ịchọ mma ha niile. Nʼugwu Horeb ka ha nọ mgbe ihe ndị a mere. 
\s1 Ụlọ nzute 
\p  
\v 7 Nʼoge a, Mosis na-ewere ụlọ ikwu manye nʼazụ ọmụma ụlọ ikwu, ọ na-akpọ ya ụlọ nzute. Ọ na-amanye ya nʼebe dị anya site nʼebe ụmụ Izrel mara ụlọ ikwu ha. Onye ọ bụla nke chọrọ ịjụta \nd Onyenwe anyị\nd* ase, na-apụ, gaa nʼụlọ nzute ahụ nke dị nʼazụ ọmụma ụlọ ikwu.  
\v 8 Mgbe ọbụla Mosis na-aga nʼụlọ ikwu nzute ahụ, ndị Izrel niile na-apụta guzoro nʼọnụ ụzọ ụlọ ha, na-ele ya anya tutu Mosis abanye nʼụlọ ikwu ahụ.  
\v 9 Mgbe ọ banyere nʼụlọ ikwu ahụ; ogidi igwe ojii ahụ na-abịa guzochie nʼọnụ ụzọ mgbe \nd Onyenwe anyị\nd* na Mosis na-akparị ụka.  
\v 10 Nʼoge ọbụla, ndị mmadụ hụrụ ogidi igwe ojii ahụ ka o guzo nʼọnụ ụzọ ụlọ ikwu nzute ahụ, ha onwe ha na-eguzokwa, onye ọbụla, nʼọnụ ụzọ ụlọ ikwu ha, kpọọ isiala.  
\v 11 Nʼime ụlọ nzute ahụ, \nd Onyenwe anyị\nd* na-agwa Mosis okwu ihu na ihu, dịka mmadụ sị agwa enyi ya okwu. Mgbe ha kparịchara ụka, Mosis na-alọghachi azụ nʼebe ụmụ Izrel mara ụlọ ikwu ha. Ma nwokorobịa ahụ na-enyere ya aka, bụ Joshua, nwa Nun, na-anọgide nʼụlọ ikwu nzute ahụ. 
\s1 Nkwa \nd Onyenwe anyị\nd* kwere ndị ya 
\p  
\v 12 Mgbe Mosis na \nd Onyenwe anyị\nd* nọ na-ekwurịta okwu, ihe Mosis gwara ya bụ nke a, “Ọ dịla anya kemgbe ị na-agwa m sị m, ‘Duru ndị m baa nʼala ahụ e kwere na nkwa inye ha.’ Ma matakwa na ị gwabeghị m onye ị ga-edunyere m ga-eduzi m ụzọ. I kwuola na ị maara aha m, kwukwaa na achọtala m ihuọma nʼebe ị nọ.  
\v 13 Biko, ọ bụrụ na o si otu a dị, zi m ụzọ gị, nke ga-eme ka m mata gị, gaakwa nʼihu inweta ihuọma site nʼebe ị nọ. Chetakwa na mba a dị ukwu bụ ndị gị.” 
\p  
\v 14 Ọ zara sị, “Mụ onwe m ga-eso gị gaa, aga m enyekwa gị izuike.” 
\p  
\v 15 Mgbe ahụ Mosis sịrị ya, “Ọ bụrụ na ị gaghị eso anyị nʼije a, ekwela ka anyị si nʼebe a zọpụ ụkwụ.  
\v 16 Ọ bụrụ na i soghị anyị, olee otu a ga-esi mata na mụ onwe m, na ndị gị achọtala ihuọma gị? Olee otu ọ ga-esi pụta ìhè na mụ na ndị gị bụ mba dị iche site na mba ndị ọzọ dị nʼụwa?” 
\p  
\v 17 Ma \nd Onyenwe anyị\nd* zara Mosis sị, “E, aga m eme ihe ị rịọrọ m, nʼihi na ị chọtala ihuọma m. Nʼezie, amara m onye ị bụ, marakwa aha gị.” 
\p  
\v 18 Mgbe ahụ, Mosis rịọrọ sị, “Gosi m ebube gị.” 
\p  
\v 19 Ma \nd Onyenwe anyị\nd* zara sị, “Aga m eme ka ị hụ ịdị mma m, aga m akọwakwara gị ihe aha m bụ \nd Onyenwe anyị\nd* pụtara. Onye m chọrọ imere ebere ka m ga-emere ebere, ọ bụkwa onye m chọrọ imere ọmịiko ka m ga-enwere ọmịiko.  
\v 20 Ma ị pụghị ịhụ ihu m nʼihi na mmadụ ọbụla enweghị ike ịhụ ihu m ma dịrịkwa ndụ.” 
\p  
\v 21 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị, “Lee, e nwere ebe dị nso nʼakụkụ m, nʼelu nkume, ebe i nwere ike iguzo.  
\v 22 Mgbe ebube m ga-agafe, aga m ezo gị nʼokpuru nkume, werekwa aka m kpuchie gị, tutu ruo mgbe m gafechara.  
\v 23 Emesịa, aga m eweli aka m, ka i nwee ike ịhụ azụ m anya, ma ị pụghị ịhụ ihu m.” 
\c 34  
\s1 Mbadamba nkume ọhụrụ 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis, “Wapụta mbadamba nkume abụọ dịka nke mbụ, aga m edekwasị nʼelu ha okwu niile nke dị nʼelu mbadamba nkume ndị mbụ ahụ, bụ nke ị tụpịasịrị.  
\v 2 Jikere nʼụtụtụ, rigoro ugwu Saịnaị ka i chee onwe gị nʼihu m nʼelu ugwu ahụ.  
\v 3 Onye ọbụla esokwala gị, ma ọ bụkwanụ nọdụ nso ugwu ahụ. Ekwekwala ka igwe ehi maọbụ igwe atụrụ kpaa nri nso nso ugwu ahụ.” 
\p  
\v 4 Mosis biliri nʼisi ụtụtụ, waa mbadamba nkume abụọ dịka ndị nke mbụ, rigoro ugwu Saịnaị dịka \nd Onyenwe anyị\nd* gwara ya. Ọ jikwa nkume abụọ ahụ nʼaka ya.  
\v 5 Nʼoge ahụ, \nd Onyenwe anyị\nd* rịdatara nʼime ogidi igwe ojii, guzo nʼihu Mosis, kwupụta aha ya bụ \nd Onyenwe anyị\nd*.  
\v 6 O si nʼihu Mosis gafee na-ekwu na-asị, “\nd Onyenwe anyị\nd*, \nd Onyenwe anyị\nd*, Chineke ọmịiko na onye amara, onye na-adịghị ewe iwe ọsịịsọ, na onye babigara ụba oke nʼịhụnanya na ikwesi ntụkwasị obi.  
\v 7 Onye na-egosi ịhụnanya ya nye imerime puku, ma na-agbaghara ajọ omume na nnupu isi, na mmehie. Ma ọ dịghị ahapụ ka onye ikpe mara laa na-anataghị ahụhụ, ọ na-ata ụmụ na ụmụ ụmụ ha ahụhụ nʼihi mmehie nna nna ha ruo nʼọgbọ nke atọ na nke anọ.” 
\p  
\v 8 Otu mgbe ahụ, Mosis hulatara kpọọ isiala,  
\v 9 sị ya, “Ọ bụrụ nʼezie na m achọtala ihuọma nʼanya gị, Onyenwe m, ka Onyenwe m, biko soro anyị gaa. Ọ bụ ezie na ndị a bụ ndị isiike, gbaghara anyị ajọ omume anyị, na mmehie anyị niile, ka ị nabatakwa anyị dịka ndị nke gị.” 
\p  
\v 10 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị, “Mụ onwe m na gị na-agba ndụ. Nʼihu ndị gị niile, aga m arụ oke ọrụ ịtụnanya dị ukwu, ụdị nke a na-emetụbeghị mbụ nʼụwa, maọbụ na mba ọ bụla. Ndị niile unu bi nʼetiti ha ga-ahụ ọrụ \nd Onyenwe anyị\nd*. Ọrụ ahụ dị oke egwu nke m ga-arụ nʼihi unu.  
\v 11 Debe ihe niile m nyere gị nʼiwu taa. Aga m esite nʼihu unu chụpụ ndị Amọrait, ndị Kenan, ndị Het, ndị Periz, ndị Hiv na ndị Jebus.  
\v 12 Kpacharanụ anya ka unu na ndị bi nʼala ahụ unu na-aba nʼime ya ghara ịgba ndụ. Ka ha ghara ị bụ ihe ịma nʼọnya nʼetiti unu.  
\v 13 Kama, tikpọọnụ ebe ịchụ aja ha niile. Kụrienụ ogidi arụsị ha niile. Gbutukwaanụ osisi Ashera ha jiri mere chi ha.  
\v 14 Unu efela chi ọzọ, nʼihi na \nd Onyenwe anyị\nd*, onye aha ya bụ Ekworo, bụ Chineke na-ekwo ekworo. 
\p  
\v 15 “Kpacharanụ anya ka unu na ndị bi nʼala ahụ ghara ịgba ndụ, nʼihi na mgbe ha na-akwaso chi ha iko, na-achụkwa aja nye chi ha, ha ga-akpọ unu oku nri, mgbe ahụ, unu ga-eri site nʼihe aja ha.  
\v 16 Mgbe unu lụtara ụfọdụ ndị inyom ha dịka nwunye nye ụmụ unu ndị ikom, ndị inyom ndị a na-akwaso chi ha iko, ga-eme ka ụmụ unu ndị ikom soro ha nʼomume dị otu a. 
\p  
\v 17 “Unu akpụla chi ọbụla. 
\p  
\v 18 “Na-emenụ mmemme achịcha na-ekoghị eko. Rienụ achịcha na-ekoghị eko ụbọchị asaa, dịka m nyere nʼiwu na a ga-eme nʼụbọchị ndị ahụ a họpụtara, nʼọnwa Abib, nʼihi na ọ bụ nʼọnwa ahụ ka unu si nʼala Ijipt pụta. 
\p  
\v 19 “Nwa nwoke ọbụla e bụ ụzọ mụọ bụ nke m, tinyere ụmụ anụ ụlọ, ma ehi, ma atụrụ, ma ewu.  
\v 20 E nwere ike ịgbapụta nwa oke ịnyịnya ibu site nʼiwere nwa atụrụ dochie nʼọnọdụ ya. Ọ bụrụ na i kpebie na ị gaghị agbapụta ya, mgbe ahụ, ị ga-agbaji olu ya. Ma ụmụ unu ndị ikom niile ka a ga-agbapụta. 
\p “O nweghị onye ọbụla nʼime unu ga-abịa guzo m nʼihu na-ejighị onyinye. 
\p  
\v 21 “Nʼoge ịkụ ihe nʼubi na nʼoge owuwe ihe ubi, rụọnụ ọrụ naanị ụbọchị isii. Zukwanụ ike nʼụbọchị nke asaa. 
\p  
\v 22 “Mee Mmemme Izu Ụka asaa, bụ nke ị ga-eji mkpụrụ mbụ nke ọka wiiti mee, na Mmemme Nchịkọta Ihe nʼọgwụgwụ afọ ọbụla.  
\v 23 Ugboro atọ nʼafọ ka ndị ikom unu niile ga-abịa chee onwe ha nʼihu Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* nke Izrel.  
\v 24 Nʼihi na aga m esite nʼihu unu chụpụ mba dị iche iche. Meekwa ka ala unu saa mbara. Ọ dịghị onye ọbụla ga-enwe anya ukwu nʼebe ala unu dị, mgbe unu na-aga iche onwe unu nʼihu \nd Onyenwe anyị\nd* bụ Chineke unu, ugbo atọ nʼafọ. 
\p  
\v 25 “Unu etinyekwala ihe ọbụla nke nwere ihe na-eko achịcha nʼime ya, mgbe unu na-achụ ọbara nke aja nye m. Unu ahapụkwala aja sitere na Mmemme Ngabiga ka ọ nọọ ruo ụtụtụ. 
\p  
\v 26 “Wetanụ mkpụrụ mbụ niile nke ala ubi unu, bụ ndị kachasị mma nʼụlọ \nd Onyenwe anyị\nd*, bụ Chineke unu. 
\p “Unu esikwala nwa ewu nʼime mmiri ara nne ya.” 
\p  
\v 27 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị, “Dee iwu ndị a m nyere gị, nʼihi na dịka okwu ndị a si dị, ka ọgbụgba ndụ mụ na gị na ụmụ Izrel gbara si dị.”  
\v 28 Mosis na \nd Onyenwe anyị\nd* nọ nʼebe ahụ iri ụbọchị anọ, ehihie na abalị. Ma nʼoge ndị a niile o righị nri ọbụla. Ọ ṅụkwaghị ihe ọṅụṅụ ọbụla. O dere na mbadamba nkume abụọ ahụ okwu niile nke ọgbụgba ndụ ahụ, nke bụ iwu iri ahụ. 
\s1 Mosis arịdata site nʼugwu Saịnaị 
\p  
\v 29 Mgbe Mosis ji mbadamba nkume abụọ nke ihe ama ahụ na-arịdata site nʼelu ugwu ahụ, ọ mataghị na ihu ya na-egbuke egbuke, nʼihi ọnọdụ nke ọ nọrọ nʼihu \nd Onyenwe anyị\nd*.  
\v 30 Nʼihi mgbuke ahụ ihu Mosis na-egbuke, ụjọ ekweghị Erọn na ụmụ Izrel bịaruo ya nso.  
\v 31 Ma Mosis kpọrọ ha ka ha bịakwute ya. Nʼihi ya, Erọn na ndị ndu nzukọ Izrel bịara ka ha na Mosis kparịtaa ụka.  
\v 32 Mgbe e mesịrị, ndị Izrel niile bịakwutere ya. O nyekwara ha iwu ndị ahụ \nd Onyenwe anyị\nd* nyere ya nʼelu ugwu Saịnaị. 
\p  
\v 33 Mgbe Mosis gwachara ha okwu, o weere akwa kpuchie ihu ya.  
\v 34 Ma mgbe ọbụla ọ na-abanye nʼihu \nd Onyenwe anyị\nd* ka ha kparịtaa ụka nʼime ụlọ nzute ahụ, ọ na-ekepụ akwa ahụ o ji kpuchie ihu ya tutu ruo mgbe ọ nọchara pụta. Mgbe ọ pụtara, ọ na-agwa ndị Izrel ihe niile \nd Onyenwe anyị\nd* nyere ya nʼiwu.  
\v 35 Ha hụkwara na ihu ya na akpụkpọ ihu ya na-egbuke egbuke. Emesịa, Mosis na-ekpuchikwa ihu ya tutu ruo mgbe ọ ga-abanye nʼime ka ya na \nd Onyenwe anyị\nd* kparịta ụka. 
\c 35  
\s1 Usoro Iwu metụtara ụbọchị izuike 
\p  
\v 1 Emesịa, Mosis kpọrọ nzukọ ụmụ Izrel niile gwa ha sị, “Ndị a bụ iwu \nd Onyenwe anyị\nd* nyere nke unu na-aghaghị idebe.  
\v 2 Rụọnụ ọrụ ụbọchị isii, ụbọchị nke asaa bụ ụbọchị izuike, ụbọchị dị nsọ nke izuike nye \nd Onyenwe anyị\nd*. Onye ọbụla rụrụ ọrụ nʼụbọchị nke asaa ga-anwụ.  
\v 3 Unu amụnyela ọkụ nʼebe obibi unu nʼụbọchị izuike ahụ.” 
\s1 Onyinye maka ọrụ ụlọ nzute 
\p  
\v 4 Mgbe ahụ Mosis gwara nzukọ Izrel niile sị, “Nke a bụ iwu \nd Onyenwe anyị\nd* nyere,  
\v 5 sitenụ nʼihe unu nwere wetara \nd Onyenwe anyị\nd* onyinye. Onye ọbụla nke ọ masịrị, ya wetara \nd Onyenwe anyị\nd* onyinye nke ihe ndị a: 
\b  
\li1 “Ọlaọcha, ọlaedo na bronz, 
\li1  
\v 6 ogho na-acha anụnụ anụnụ, nke odo odo, nke uhie uhie na nke ezi akwa ọcha, 
\li1 na ajị ewu; 
\li1  
\v 7 akpụkpọ ebule e sijiri uhie uhie, akpụkpọ ehi mmiri, 
\li1 na osisi akashia; 
\li1  
\v 8 mmanụ oliv nke a ga-etinye nʼiheọkụ, 
\li1 ụda a na-etinye na mmanụ nsọ, na ụda na-eme ka aja nsure ọkụ na-esi isi ụtọ; 
\li1  
\v 9 nkume ọma ọniks, na nkume ndị ọzọ a na-ahịọnye nʼefọọd, na nke a na-ahịọnyekwa nʼihe mgbochi obi. 
\b  
\p  
\v 10 “Unu niile ndị nwere onyinye ịkwa ǹka, bịanụ rụọ ihe ahụ niile \nd Onyenwe anyị\nd* nyere anyị nʼiwu ịrụ, nke bụ ihe ndị a: 
\b  
\li1  
\v 11 “ụlọ nzute ahụ, na ihe mkpuchi ya, na nko ya niile, na mbudo ibo ya, na mkpọrọ osisi ya, na ogidi ya, na ụkwụ ya niile. 
\li1  
\v 12 Rụkwanụ igbe ọgbụgba ndụ ahụ, na mkpara ahụ e ji ebu ya. Ya na oche ebere ahụ. Mekwaanụ akwa mgbochi nke ga-ekpuchi ebe nsọ ahụ, 
\li1  
\v 13 na tebul ahụ, na mkpara e ji ebu ya, na ngwongwo ya niile, na achịcha nke iche nʼIhu \nd Onyenwe anyị\nd*. 
\li1  
\v 14 Mekwaa ebe ịdọkwasị oriọna maka ìhè, ya na ngwongwo ya niile, iheọkụ na mmanụ maka ịmụ ọkụ; 
\li1  
\v 15 nʼebe ịchụ aja ihe nsure ọkụ na mkpara ya. Mmanụ nsọ ahụ na ihe nsure ọkụ na-esi isi ụtọ nke e ji ụda mee; 
\li1 akwa mgbochi maka ọnụ ụzọ nke dị nʼebe mbata ụlọ nzute ahụ; 
\li1  
\v 16 ebe ịchụ aja nke aja nsure ọkụ ya na ihe ọkpụkpa bronz ya, mkpara e ji ebu ya na ngwongwo ya niile, 
\li1 efere ukwu ahụ na ihe ndọkwasị ya. 
\li1  
\v 17 Akwa mgbochi nke ogige ụlọ ahụ na ogidi ha, na ihe ndọkwasị ya, nakwa akwa mgbochi nke ọnụ ụzọ e si abanye nʼogige ahụ; 
\li1  
\v 18 ǹtu maka ịkpọgide ụlọ ikwu ahụ na nke ogige ahụ, na ụdọ ha, 
\li1  
\v 19 uwe niile a kpara akpa nke a na-eyi eje ozi nʼebe nsọ ahụ, ma uwe nsọ nke Erọn, onye nchụaja na uwe nke ụmụ ya ndị ikom na-eyi mgbe ha na-eje ozi ha dịka ndị nchụaja.” 
\b  
\p  
\v 20 Ugbu a, ọgbakọ ụmụ Izrel niile siri nʼihu Mosis pụọ.  
\v 21 Onye ọbụla chọrọnụ na onye nke mmụọ ya kwaliri laghachiri azụ bịa wetara \nd Onyenwe anyị\nd* onyinye nʼihi ọrụ nke ụlọ nzute ahụ na nʼihi ije ozi dị nʼime ya na nʼihi uwe nsọ ndị ahụ.  
\v 22 Ndị niile ọ metụrụ nʼobi, ma ndị nwoke ma ndị nwanyị bịara weta onyinye ha. Ha wetaara \nd Onyenwe anyị\nd* onyinye ihe ịchọ mma nke ọlaedo dị iche iche: ihe ịkpọchi uwe, ọlantị, ọlaaka na ihe ndị ọzọ e ji achọ mma dị iche iche, nke e ji ọlaedo kpụọ. Ha chere ha nʼihu \nd Onyenwe anyị\nd* dịka aja mfufe.  
\v 23 Ụfọdụ mmadụ wetara akwa na-acha anụnụ anụnụ na ngwakọta anụnụ na uhie na nke uhie uhie maọbụ ezi akwa ọcha maọbụ akpụkpọ ajị ewu, akpụkpọ ebule e sijiri ọbara ọbara na akpụkpọ ehi mmiri.  
\v 24 Ndị ọzọ wetara ọlaọcha na bronz, dịka onyinye ha nyere \nd Onyenwe anyị\nd*, ụfọdụ wetara osisi akashia nke a ga-eji wuo ụlọ ikwu ahụ.  
\v 25 Ụmụ nwanyị ndị bụ ọka nʼịdụ akwa na ikwe akwa tụrụ eri na-acha anụnụ anụnụ, na ngwakọta anụnụ na uhie, nke na-acha uhie uhie na nke ezi akwa ọcha, webata ha dịka onyinye.  
\v 26 Ụfọdụ ụmụ nwanyị kwa ji onyinye ǹka pụrụ iche ha nwere kpaa ajị ewu dịka akwa pụrụ iche.  
\v 27 Ndị ndu niile wetakwara nkume ọniks na nkume ndị ọzọ nke ịhịọnye nʼihe a ga-eji dụọ efọọd na ihe mgbochi obi ahụ.  
\v 28 Ha wetakwara ụda dị iche iche, mmanụ oliv nke a ga-etinye nʼiheọkụ, nke a ga-eji mee mmanụ otite dị nsọ, mekwa ihe nsure ọkụ na-esi isi ụtọ.  
\v 29 Nʼụzọ dị otu a ka ụmụ Izrel niile, ma nwoke ma nwanyị, ndị chọrọ inyeaka nʼọrụ ahụ \nd Onyenwe anyị\nd* nyere Mosis nʼiwu si weta onyinye ha. Onye ọbụla nʼime ha nyere \nd Onyenwe anyị\nd* onyinye afọ ofufu. 
\s1 Bezalel na Oholiab 
\p  
\v 30 Mgbe ahụ, Mosis gwara ndị Izrel, sị, “Lee, \nd Onyenwe anyị\nd* ahọpụtala Bezalel, nwa Uri, nwa Hua, onye si nʼebo Juda.  
\v 31 O mejupụtala na Mmụọ nke Chineke, nʼamamihe, nghọta na ihe ọmụma na ike ije ozi ọrụ ǹka dị iche iche.  
\v 32 Ichepụta ihe ǹka dị iche iche, nke metụtara ọlaọcha na ọlaedo na bronz,  
\v 33 ịwa nkume na ido nkume, ịkwa ǹka osisi nakwa ọrụ ǹka niile dị iche iche.  
\v 34 Ma o tinyela nʼime ya na Oholiab, nwa Ahisamak, onye si nʼebo Dan, amara ikuziri ndị ọzọ ihe.  
\v 35 O mejupụtala ha nʼike ije ozi ọrụ ǹka dị iche iche, dịka igbunye akara, ise ihe osise, ịkpanye ihe ịchọ mma nʼakwa dị iche iche, ya bụ iji ogho na-acha anụnụ anụnụ, ngwakọta anụnụ na uhie, uhie uhie nakwa nʼezi akwa ọcha na nke ndị ọkpa akwa. Ha niile bụkwa ndị ǹka na ndị nchepụta ihe ịchọ mma doro anya.” 
\c 36  
\nb  
\v 1 Ya mere, Bezalel na Oholiab na ndị ǹka niile \nd Onyenwe anyị\nd* nyere ike na nghọta ịmata otu ha ga-esi rụọ ọrụ iwu ebe nsọ ahụ ga-arụ ọrụ ahụ dịka \nd Onyenwe anyị\nd* nyere nʼiwu. 
\p  
\v 2 Mgbe ahụ, Mosis kpọrọ Bezalel na Oholiab na ndị ǹka ndị ahụ \nd Onyenwe anyị\nd* nyere ike na nghọta, ndị wepụtara obi ha ịbịa ịrụ ọrụ ahụ.  
\v 3 Ha si nʼaka Mosis nara onyinye ndị ahụ niile ụmụ Izrel wetara maka ịrụ ọrụ ebe nsọ ahụ. Ndị mmadụ nọkwa na-eweta onyinye afọ ofufu ha ụtụtụ niile.  
\v 4 Nʼihi ya, ndị ọrụ ǹka niile nọ na-arụ ọrụ nʼebe nsọ ahụ hapụrụ ọrụ ha na-arụ,  
\v 5 bịakwute Mosis, sị ya, “Lee, onyinye ndị mmadụ na-eweta adịla ukwuu karịa ihe a chọrọ maka ịrụ ọrụ a \nd Onyenwe anyị\nd* nyere nʼiwu.” 
\p  
\v 6 Mgbe ahụ, Mosis nyere iwu, ha zisara ozi ahụ nʼọmụma ụlọ ikwu niile sị, “Ka nwoke maọbụ nwanyị ọbụla gharakwa inwe ihe ọbụla nke ọ ga-eweta dịka onyinye maka ọrụ ebe nsọ a.” Nʼihi nke a, ndị mmadụ kwụsịrị iweta ihe ọzọ.  
\v 7 Nʼihi na onyinye e wetara adịla ukwuu karịa ihe a chọrọ maka ọrụ ahụ. 
\s1 Ọrụ ụlọ nzute 
\p  
\v 8 Ndị niile mara ǹka nʼetiti ndị ọrụ ahụ ji ezi ogho na-acha anụnụ anụnụ, ngwakọta anụnụ na uhie na uhie uhie wuo ụlọ nzute ahụ. Onye ọka kpanyekwara oyiyi cherubim nʼime ha.  
\v 9 Akwa mgbochi ndị a ha nʼotu. Ịdị ogologo ha nʼotu nʼotu bụ mita iri na abụọ na ọkara. Obosara ha bụ otu mita na sentimita asatọ.  
\v 10 E jikọtara akwa mgbochi ise nʼotu, jikọtakwa akwa ise nke ọzọ nʼotu.  
\v 11 Ha ji akwa na-acha anụnụ anụnụ dụnye anya nko nʼelu ọnụ akwa mgbochi nke otu ụzọ, otu a ka emekwara menyekwa na nsọtụ ọnụ akwa mgbochi nke ọzọ.  
\v 12 Ha dụnyere iri anya nko ise nʼotu akwa mgbochi, dụnyekwa iri anya nko ise nʼọnụ akwa mgbochi nke ọzọ, mee ka anya nko ndị a chee ibe ha ihu.  
\v 13 Emesịa, ha ji iri nko ọlaedo ise jikọta ụzọ akwa mgbochi abụọ ndị a, si otu a mee ka ụlọ nzute ahụ ghọọ otu. 
\p  
\v 14 Ha ji akpụkpọ ajị ewu mee akwa mgbochi maka i ji kpuchie elu ụlọ nzute ahụ. Iri na otu ka ha ga-adị nʼọnụọgụgụ.  
\v 15 Akwa mgbochi iri na otu ndị a ha nʼotu. Ọ ga-abụ mita iri na atọ na ọkara nʼogologo, ebe obosara ya bụ otu mita na iri sentimita asatọ.  
\v 16 Ha dụkọtara ise nʼime akwa mgbochi ahụ, debe ya iche. Dụkọtakwa isii nke fọdụrụ debekwa ya iche.  
\v 17 Mgbe ahụ, ha dụnyekwara iri anya nko ise nʼelu ọnụ otu akwa mgbochi ndị ahụ. Mekwaa otu ihe ahụ nʼọnụ akwa mgbochi nke ọzọ e debere iche.  
\v 18 Ha mekwara iri nko bronz ise, iji jikọta ụlọ nzute ahụ ka ọ bụrụ otu.  
\v 19 Mgbe ahụ, ha ji akpụkpọ ebule e sijiri uhie uhie mee ihe mkpuchi maka ụlọ nzute ahụ, ya na akwa mkpuchi ọzọ nke e ji akpụkpọ ehi mmiri mee maka ịkpụkwasị nʼelu ya. 
\p  
\v 20 Ha meere ụlọ nzute ahụ mbudo ibo osisi akashia, guzo ọtọ.  
\v 21 Mbudo ibo ọ bụla dị mita anọ na ọkara nʼogologo, dịrịkwa iri sentimita asaa nʼobosara,  
\v 22 nwee ihe nhịọnye abụọ nke ga-abanye nʼime ibe ya ijikọ ha nʼotu. Ha rụrụ mbudo ibo ụlọ nzute ahụ niile otu a.  
\v 23 Ha rụrụ mbudo ibo iri abụọ maka akụkụ ndịda nke ụlọ nzute ahụ,  
\v 24 ma mekwaa iri ụkwụ ọlaọcha anọ nʼokpuru ha. Otu mbudo ibo ga-enwe ụkwụ abụọ, otu ụkwụ nʼokpuru otu ihe nhịọnye, otu ụkwụ nʼokpuru ihe nhịọnye nke ọzọ.  
\v 25 Nʼakụkụ nke ọzọ bụ akụkụ ugwu nke ụlọ nzute ahụ, ha rụkwara iri mbudo ibo abụọ,  
\v 26 rụkwaa iri ụkwụ ọlaọcha anọ, ụkwụ abụọ nʼokpuru mbudo ibo ọbụla.  
\v 27 Nʼebe isi isi nsọtụ ya bụ akụkụ ọdịda anyanwụ nke ụlọ nzute, ha rụrụ mbudo ibo isii.  
\v 28 Mbudo ibo abụọ ka e mere maka nkuku niile nke nsọtụ ụlọ nzute ahụ,  
\v 29 Nʼisi nkuku abụọ ndị a, mbudo ibo ndị a nọ iche iche site nʼokpuru ruo nʼelu ya; ma e jikọrọ ha ọnụ nʼime otu mgbaaka. Emere ka ha abụọ yie ibe ya.  
\v 30 Ha niile dị mbudo ibo asatọ na ụkwụ ọlaọcha dị iri na isii, ya bụ ụkwụ abụọ nʼokpuru mbudo ibo ọbụla. 
\p  
\v 31 Ha ji osisi akashia mekwaa osisi ntụbichi, ise maka mbudo ibo ndị dị nʼotu akụkụ nke ụlọ nzute ahụ,  
\v 32 ise nke ọzọ maka ndị dị nʼakụkụ nke ọzọ, ise nke ọzọ maka mbudo ibo dị nʼakụkụ ọdịda anyanwụ, nʼebe ndịda ndịda nke ụlọ nzute ahụ  
\v 33 Ha mere osisi ntụbichi nke dị nʼetiti ka ọ gabiga site nʼotu isi ruo nʼisi nke ọzọ nke mbudo ibo ahụ.  
\v 34 Ha ji ọlaedo machie mbudo ibo ndị ahụ niile. Kpụkwaa mgbaaka ọlaedo ka ọ bụrụ ọnọdụ ịchịkọta mkpọrọ osisi ahụ niile. Ha ji ọlaedo machiekwa mkpọrọ osisi ndị ahụ niile. 
\p  
\v 35 Ha ji ogho na-acha anụnụ anụnụ, ngwakọta anụnụ na uhie, uhie uhie na ezi akwa ọcha a kpara nke ọma mee akwa mgbochi. Onye ǹka kpanyekwara oyiyi cherubim nʼime ya.  
\v 36 Ha mere ogidi osisi akashia anọ maka ya were ọlaedo machie ha. Ha meere ha anya nko; wukwara ha ụkwụ ọlaọcha anọ.  
\v 37 Ha mere akwa mgbochi maka ọnụ ụzọ mbata nke ụlọ ikwu ahụ, nke e ji ogho na-acha anụnụ anụnụ, na ngwakọta anụnụ na uhie, na uhie uhie, na ezi akwa ọcha a kpara nke ọma, nke bụ akaọrụ onye ǹka.  
\v 38 Ha rụrụ ogidi ise ya na anya nko ha. Ha ji ọlaedo machie isi ogidi ahụ na ihe mkpọrọ ha, were bronz rụọ ụkwụ ise ha. 
\c 37  
\s1 Igbe Ọgbụgba ndụ 
\p  
\v 1 Bezalel ji osisi akashia wuo igbe ọgbụgba ndụ nke ịdị ogologo ya bụ otu mita na sentimita iri. Obosara ya ga-abụ sentimita iri isii na asatọ. Ịla elu ya ga-abụkwa sentimita iri isii na asatọ.  
\v 2 O ji ọlaedo a nụchara anụcha machie nʼime na azụ ya, jirikwa ọlaedo kpụọ ihe gburugburu akụkụ ya niile.  
\v 3 Ọ kpụrụ mgbaaka ọlaedo anọ maka ya, kwụnyekwa ha nʼụkwụ anọ ya, ya bụ mgbaaka abụọ nʼotu akụkụ, mgbaaka abụọ nʼakụkụ nke ọzọ ya.  
\v 4 O jikwa osisi akashia ahụ mee okporo osisi, machiekwa ha ọlaedo.  
\v 5 O tinyekwara mkpara ndị ahụ nʼime mgbaaka ahụ dị nʼakụkụ igbe ahụ; ka ọ bụrụ ihe iji na-ebu ya. 
\p  
\v 6 Emesịa, o ji ọlaedo a nụchara anụcha mee ihe e ji ekwuchi igbe ahụ. Aha a na-akpọ okwuchi igbe a bụ Oche Ebere. Ịdị ogologo ya dị otu mita na sentimita iri, obosara ya dị iri sentimita asaa.  
\v 7 Mgbe ahụ, o ji ọlaedo a nụchara anụcha, nke e tipịara etipịa, kpụọ cherubim abụọ na nsọtụ abụọ nke ebe mkpuchi ahụ.  
\v 8 A rụnyere otu cherub nʼotu nsọtụ, otu cherub na nsọtụ nke ọzọ; nʼisi nsọtụ abụọ ahụ, ka o jikọtara ha ọnụ ka ha na okwuchi igbe ahụ bụrụ otu.  
\v 9 Cherubim ndị a gbasara nku ha laa elu, were ha na-ekpuchi okwuchi ahụ. Cherubim ndị ahụ cherịtara onwe ha ihu, na-ele anya nʼebe okwuchi ahụ dị. 
\s1 Tebul 
\p  
\v 10 Emesịa, o mere tebul nke ịdị ogologo ya bụ iri sentimita itoolu. Obosara ya bụ iri sentimita ise, ịla elu ya bụ iri sentimita asaa. Ọ bụ osisi akashia ka o ji mee ya.  
\v 11 Ọ bụkwa ọlaedo a nụchara anụcha ka e ji machie ya. A kpụnyekwara ihe ọkpụkpụ ọlaedo gburugburu ọnụ ọnụ ya.  
\v 12 A rụnyere ihe nʼọnụ ọnụ tebul ahụ nke ịla elu ya ga-eru sentimita asatọ. Ihe a dị gburugburu ọnụ ọnụ tebul ahụ, ọ bụkwa ọlaedo a kpụrụ akpụ ka e ji rụọ ya.  
\v 13 Ha kpụrụ mgbaaka ọlaedo anọ maka tebul ahụ; kwụnyekwa ha nʼakụkụ anọ ahụ nʼebe ụkwụ anọ ya dị.  
\v 14 E tinyere mgbaaka ndị ahụ nso nso ihe njikọ ahụ ka ha jide mkpara ndị ahụ, e ji ebu tebul ahụ.  
\v 15 O jikwa osisi akashia mee okporo osisi ahụ e ji ebu tebul ahụ. Jirikwa ọlaedo machie ya.  
\v 16 O mekwara ihe niile na-adị nʼelu tebul ahụ: efere, ngaji, ọkwa na iko, nke e ji awụpụ aja ihe ọṅụṅụ. Ọ bụkwa ọlaedo a nụchara anụcha ka o ji kpụọ ha. 
\s1 Ihe ịdọba oriọna 
\p  
\v 17 Ha ji ọlaedo a nụchara anụcha kpụọ ihe ịdọkwasị oriọna. Ha kpụrụ ụkwụ ala ala ya, na alaka ya, mekwaa ka iko ya niile yiri okoko osisi, nʼisi ya niile, na ifuru ya niile bụrụ otu ya na ahụ ya.  
\v 18 Alaka isii sitere nʼakụkụ abụọ nke ihe ịdọkwasị oriọna ahụ wapụta, alaka atọ nʼotu akụkụ ya, alaka atọ nʼakụkụ nke ọzọ.  
\v 19 Iko atọ e mere dịka okoko osisi alụmọnd ya na ifuru, ya na okoko ya niile dịkwa nʼotu alaka; iko atọ nʼalaka nke ọzọ, otu a ka ọ ga-adị nʼalaka isii niile ahụ na-awapụta site nʼihe ịdọkwasị oriọna ahụ.  
\v 20 Nʼelu ihe ịdọba oriọna ahụ, enwere iko anọ dịka ifuru osisi alụmọnd, ya na ebe o si awapụta na okoko ya.  
\v 21 Otu isi dị nʼokpuru alaka abụọ si nʼetiti ihe ịdọba oriọna ahụ pụta, isi nke abụọ ga-adị nʼokpuru alaka abụọ nke ọzọ, isi nke atọ ga-adị nʼokpuru alaka nke atọ, ya bụ ha niile alaka isii.  
\v 22 Isi nwapụta ya na alaka ya niile dịkọtara ọnụ, ha na ihe ịdọkwasị oriọna ahụ, nke e ji ọlaedo a nụchara anụcha rụọ. 
\p  
\v 23 Ha mekwara oriọna asaa ya, ma mkpa ya na ihe ịkpakepụ ọkụ ya niile. Ha bụ ọlaedo a nụchara anụcha.  
\v 24 Ha sitere na iri kilogram atọ na anọ nke ọlaedo a nụchara anụcha kpụọ ihe ịdọkwasị oriọna ahụ na ngwongwo ya niile. 
\s1 Ebe ịchụ aja ihe nsure ọkụ na-esi isi ụtọ 
\p  
\v 25 Ha ji osisi akashia wuo ebe ịchụ aja a na-anọ esure ihe nsure ọkụ na-esi isi ụtọ. Akụkụ anọ ya ha nʼotu. Ogologo ya na obosara ya bụ iri sentimita anọ na ise. Ịdị elu ya bụ iri sentimita itoolu. Mpi ya niile si na ya pụta.  
\v 26 Ha ji ọlaedo a nụchara anụcha machie elu ya; akụkụ ya niile nakwa mpi ya niile. Ha jikwa ọlaedo kpụlite ọnụ ọnụ ya gburugburu.  
\v 27 Ha kpụnyere mgbaaka ọlaedo abụọ nʼokpuru ihe ahụ akpụlitere akpụlite, abụọ na ncherita ihu akụkụ ọ bụla, ebe a ga na-ejide mkpara e ji ebu ya.  
\v 28 Ha ji osisi akashia mee mkpara ndị ahụ. Jirikwa ọlaedo machie ha. 
\p  
\v 29 Ha mekwara mmanụ otite dị nsọ, na ezigbo ihe nsure ọkụ na-esi isi ụtọ nke a na-agwaghị ihe; bụ ọrụ nke onye na-eme mmanụ isi ụtọ. 
\c 38  
\s1 Ebe ịchụ aja ihe nsure ọkụ 
\p  
\v 1 Ha ji osisi akashia wuo ebe ịchụ aja nke aja nsure ọkụ. Nke ịla elu ya dị otu mita na iri sentimita atọ. Ogologo ya na obosara ya ha nʼotu. Ha dị mita abụọ na iri sentimita atọ, mita abụọ na iri sentimita atọ.  
\v 2 Ha rụnyekwara mpi nʼakụkụ anọ nke ebe ịchụ aja ahụ nʼotu nʼotu. Mee ka mpi ndị a na ebe ịchụ aja ahụ ghọọ nke e jikọtara nʼotu. Ha jikwa bronz machie ebe ịchụ aja a.  
\v 3 Ha ji bronz kpụọ ngwongwo niile dị iche iche, ya bụ efere ikpofu ntụ, shọvel ya niile, efere ịkwọsa mmiri niile, ngaji eze ịdụta anụ na efere ndị e ji agụ ọkụ.  
\v 4 Ha mere ngịga mbadamba maka ebe ịchụ aja ahụ, ihe ọkpụkpa bronz, nke ga-adị nʼokpuru oghere ọnụ ọnụ ya.  
\v 5 Ha kpụrụ mgbaka bronz ndị a ga-eji jide mkpara ndị ahụ maka akụkụ anọ nke ngịga bronz ahụ.  
\v 6 Ha mere mkpara osisi akashia ndị a, were bronz machie ha.  
\v 7 Ha mere ka mkpara ndị ahụ baa nʼime mgbaaka ndị ahụ, ime ka ha dịrị nʼakụkụ abụọ nke ebe ịchụ aja ahụ maka iji nʼebu ya. Ha ji obodobo osisi rụọ ya dịka igbe. 
\s1 Efere ịsa ihe 
\p  
\v 8 Ha ji bronz kpụọ efere ukwu na ihe ndọkwasị ya. Ọ bụ enyo nke ndị inyom ahụ ndị na-eje ozi nʼọnụ ụzọ ụlọ nzute ka e ji kpụọ ha. 
\s1 Ogige ụlọ nzute 
\p  
\v 9 Ọzọ, ha mere ogige ahụ. Ịdị ogologo nke nʼakụkụ ndịda dị iri mita anọ na ise. O nwere akwa mgbochi nke e ji ezi akwa ọcha a kpara nke ọma mee.  
\v 10 Iri ogidi abụọ ga-adị na iri ebe ndọkwasị abụọ nke e ji bronz kpụọ. Anya nko ogidi ndị ahụ ha na ihe ikegide ha ga-abụ ọlaọcha.  
\v 11 Otu a kwa, akụkụ ugwu dịkwa iri mita anọ na ise. O nwere iri ogidi abụọ na iri ebe ndọkwasị abụọ nke e ji bronz kpụọ, na anya nko nke ọlaọcha na ihe e ji ekegide ha nʼogidi ahụ. 
\p  
\v 12 Akụkụ ọdịda anyanwụ dị iri mita abụọ na atọ. Nwekwaa akwa mgbochi, nwere ogidi iri na ebe ndọkwasị iri, tinyere anya nko ọlaọcha na ihe e ji ekegide ha nʼogidi ahụ.  
\v 13 Nʼakụkụ ọwụwa anyanwụ, ebe anwụ na-awalite dịkwa iri mita abụọ na atọ nʼobosara.  
\v 14 Akwa mgbochi nke ogologo ya dị mita isii na sentimita iri asatọ bụ ihe dị nʼotu akụkụ nke ọnụ ụzọ mbata ahụ. O nwere ogidi atọ na ebe ndọkwasị atọ.  
\v 15 Otu a kwa, akwa mgbochi nke ịdị ogologo ya dị mita asaa bụ ihe dị nʼakụkụ nke ọzọ nke ọnụ ụzọ mbata nke ogige ahụ. Ọ ga-enwekwa ogidi atọ na ebe ndọkwasị atọ  
\v 16 Akwa mgbochi niile nke ogige ahụ gburugburu bụ ezi akwa ọcha a kpara nke ọma.  
\v 17 Ogidi ọbụla nwere ihe ndọkwasị bronz. Nko niile na ihe njikọta niile ka e jikwa ọlaọcha machie. Ọ bụkwa naanị ọlaọcha ka e ji mee okporo osisi ndị ahụ. 
\p  
\v 18 Akwa mgbochi nke ọnụ ụzọ mbata nke ogige ahụ bụ ihe e ji ogho na-acha anụnụ anụnụ, ngwakọta anụnụ na uhie, uhie uhie na nke ezi akwa ọcha a kpara nke ọma mee; akaọrụ nke onye na-akpa ihe ịchọ mma. Ọ dị mita itoolu nʼogologo, yikwaa akwa mgbochi nke ebe ogige ahụ, dị mita abụọ na iri sentimita atọ nʼịdị elu.  
\v 19 Ọ bụ ogidi anọ ka e ji jidesie ha ike na ihe ndọkwasị bronz anọ, nko na okporo osisi ha niile bụ ọlaọcha. E jikwa ọlaọcha machie isi ogidi ndị ahụ.  
\v 20 Ǹtu niile nke ụlọ nzute ahụ nakwa nʼogige ya gburugburu bụ bronz ka e ji kpụọ ha. 
\s1 Ngwongwo e ji wuo ụlọ nzute 
\p  
\v 21 Ndị a bụ ngwongwo niile e ji wuo ụlọ nzute ahụ; ebe a ga-edebe Ihe Ama ahụ. Ọ bụ ndị Livayị depụtara ihe niile ndị a nʼusoro dịka Mosis si nye ha nʼiwu. Ọ bụkwa Itama, nwa Erọn onye nchụaja, lekọtara ndị niile rụrụ ọrụ idekọta ya.  
\v 22 Bezalel, nwa Uri, nwa Hua, onye si nʼebo Juda, rụzuru ihe niile dịka \nd Onyenwe anyị\nd* si nye ya Mosis nʼiwu.  
\v 23 Onye na-enyere ya aka bụ Oholiab nwa Ahisamak, onye ebo Dan, bụ onye ọka a maara aha ya, ọ bụ onye ọka ihe ọtụtụ, na onye ọka ịdụnye ihe ịchọ mma dị iche iche nʼakwa na-acha anụnụ anụnụ, nke ngwakọta anụnụ na uhie, uhie uhie nakwa ezi akwa ọcha.  
\v 24 Ịdị arọ nke onyinye ọlaedo niile sitere nʼaja mfufe ahụ nke ndị mmadụ wetara maka ịrụ ebe nsọ ahụ, bụ otu puku na narị kilogram ise. 
\p  
\v 25 Ịdị arọ nke ọlaọcha enwetara nʼaka ọgbakọ ahụ, bụ puku kilogram anọ, na narị kilogram isii na iri ise dịka shekel ebe nsọ si dị.  
\v 26 Ha niile tụrụ otu beka, otu isi, dịka ụtụ mgbe e kere ụtụ ọkara shekel dịka ọtụtụ shekel ebe nsọ si dị, e nyere nʼisi onye ọbụla nke gabigara nʼebe ndị a gụrụ ọnụ nọ, bụ ndị gbara iri afọ abụọ rigoo. Ọnụọgụgụ ha dị narị isii, na puku atọ, na narị ise, na iri ise.  
\v 27 Ịdị arọ nke ọlaọcha niile e ji rụọ ụkwụ ibo niile nke ebe nsọ ahụ, na ụkwụ ogidi niile e ji jidesie akwa mgbochi ndị ahụ ike bụ puku kilogram atọ, na narị kilogram isii. Ịdị arọ nke ọlaọcha e ji wuo ụkwụ ọbụla bụ iri kilogram atọ na isii.  
\v 28 Ịdị arọ nke ọlaọcha e ji menye nko nʼibo osisi niile, na nke e ji machie okporo osisi niile, na nke e ji techie isi ogidi osisi niile, bụ iri kilogram abụọ. 
\p  
\v 29 Ịdị arọ nke bronz niile ndị mmadụ wetara dịka onyinye aja mfufe bụ puku kilogram atọ, na narị kilogram atọ, na iri isii.  
\v 30 E ji bronz ndị a wuo ụkwụ ogidi niile a manyere nʼihu ụzọ e si abata ogige ụlọ nzute ahụ. E jikwa ya wuo ebe ịchụ aja bronz ahụ, na ihe ọkpụkpụ bronz ahụ, na ngwongwo niile e ji eje ozi nʼebe ịchụ aja,  
\v 31 na ụkwụ ogidi a manyere nʼihu ụlọ nzute, na ǹtu niile e ji wuo ụlọ nzute ahụ, na ogige gbara ya gburugburu. 
\c 39  
\s1 Uwe ndị nchụaja 
\p  
\v 1 Ha sitekwara nʼogho akwa na-acha anụnụ anụnụ na nke na-acha ngwakọta anụnụ na uhie (odo odo), nke na-acha uhie uhie, meere ndị nchụaja uwe akpara akpa nke ọma iyi jee ozi nʼebe nsọ ahụ. Ha meekwara Erọn uwe nsọ, nʼusoro iwu \nd Onyenwe anyị\nd* nyere Mosis. 
\s1 Efọọd 
\p  
\v 2 Ha ji ogho ọlaedo, na nke na-acha anụnụ anụnụ, nke na-acha ngwakọta anụnụ na uhie, na nke na-acha uhie uhie, nakwa nke ezi akwa ọcha a kpara nke ọma mee efọọd ahụ.  
\v 3 Ha tipịara mpempe ọlaedo ndị ahụ mee ka ọ dị mbadamba. Bipụtasịa ha ntakịrị ntakịrị dịka eriri maka i ji ha kpanye nʼetiti ogho ndị a na-acha anụnụ anụnụ; ngwakọta anụnụ na uhie, nke uhie uhie nakwa nke ezi akwa ọcha ahụ, nke bụ akaọrụ onye ǹka.  
\v 4 Ha dụrụ akwa na-adị nʼubu maka efọọd ahụ, nke e jikọtara na nkuku ya abụọ, maka i ji na-ekechisi ya ike.  
\v 5 Ihe okike nke ukwu ahụ, nke onye ǹka kpaziri nke ọma yiri ya, ya na efọọd ahụ bụ otu, nke e ji ogho na-acha edo edo, anụnụ anụnụ, ngwakọta anụnụ na uhie na uhie uhie nakwa nke ezi akwa ọcha a kpara nke ọma mee, dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu. 
\p  
\v 6 Ha doziri nkume ọniks ndị ahụ nʼime ihe ọlaedo a kpara akpa; ma gbunye aha ụmụ ndị ikom Izrel niile nʼelu ya dịka onye ọka si egbunye aha mmadụ nʼelu mgbaaka akara.  
\v 7 Ha jikọtara ha nʼelu akwa ubu nke efọọd ahụ, ka ọ bụrụ nkume ncheta mgbe ebighị ebi nye ụmụ Izrel, dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu. 
\s1 Ihe mgbochi obi 
\p  
\v 8 Ha mekwara ihe mgbochi obi, nke bụ ọrụ aka onye ǹka. Ha mere ya dịka e si mee efọọd ahụ. Ọ bụ ogho edo edo, nke na-acha anụnụ anụnụ, nke ngwakọta anụnụ na uhie, nke uhie uhie na ezi akwa ọcha a kpara nke ọma ka e ji mee ya.  
\v 9 Ọ ha nʼotu, iri sentimita abụọ na atọ nʼogologo, iri sentimita abụọ na atọ nʼobosara; nke apịajiri ụzọ abụọ.  
\v 10 Mgbe ahụ, ha hịọnyere ahịrị nkume anọ ndị dị oke ọnụahịa nʼime ya. Ụdị dị nʼahịrị nke mbụ bụ: nkume kanelian, krisolaịt na beril,  
\v 11 nʼahịrị nke abụọ bụ: nkume tọkwọisi, safaia na emeralụdụ.  
\v 12 Nʼahịrị nke atọ bụ: nkume jasint, ageeti na ametisiti.  
\v 13 Nʼahịrị nke anọ bụ: nkume topaazi, ọniks na jaspa. Ahịọnyere ha nʼime ihe ọlaedo a kpara akpa.  
\v 14 Ha dị nkume iri na abụọ, nke ọbụla na-anọchi anya aha ụmụ ndị ikom Izrel. Egbunyere aha ebo iri na abụọ ahụ, otu nʼotu, nke ọbụla dịka aha ya si dị. 
\p  
\v 15 Ha ji ọlaedo a nụchara anụcha mee eriri a kpara akpa dịka ụdọ, maka ihe mgbochi obi.  
\v 16 Ha mere ihe ọlaedo abụọ nke a kpara akpa, ya na mgbaaka ọlaedo abụọ. Dụnyekwa mgbaaka ndị ahụ na nkuku abụọ nke ihe mgbochi obi ahụ.  
\v 17 Ha dụnyere ụdọ ọlaedo abụọ ndị ahụ nʼelu mgbaaka ndị ahụ dị na nkuku ihe mgbochi obi ahụ.  
\v 18 Were isi ndị ọzọ nke ụdọ ahụ dụnye nʼihe ahụ a kpara akpa. Konye ha nʼelu ubu efọọd ahụ, nʼebe ihu ya.  
\v 19 Ha mere mgbaaka ọlaedo. Konyekwa ha na nkuku abụọ nke ihe mgbochi obi ahụ, nʼime ọnụ ọnụ ya ebe dị nso efọọd ahụ.  
\v 20 Mgbe ahụ, ha kpụrụ mgbaaka ọlaedo abụọ ọzọ, konyekwa ha nʼelu ubu abụọ nke efọọd ahụ, nʼokpuru nʼebe ihu ya, na nso nso ebe a dụkọtara, nʼelu ihe okike ukwu nke efọọd ahụ.  
\v 21 Ha jikwa eriri na-acha anụnụ kekọta mgbaaka ihe mgbochi obi ahụ na mgbaaka efọọd ahụ, jikọta ya na ihe okike ukwu ahụ, ime ka ihe mgbochi obi ahụ hapụ ịtọghapụ site nʼefọọd ahụ, dịka iwu \nd Onyenwe anyị\nd* nyere Mosis si dị. 
\s1 Uwe ndị ọzọ 
\p  
\v 22 Ọ bụ akwa nke na-acha anụnụ anụnụ,\f + \fr 39:22 \ft Maọbụ, \fqa buluu\f* ka ha ji dụọ uwe mwụda efọọd ahụ, ọrụ onye okwe akwa.  
\v 23 A ga-enwe oghere nʼetiti uwe mwụda ahụ, dịka oghere olu uwe agha, nwekwa akwa nta a dụnyere nʼokpuru oghere a, ime ka o sie ike gharakwa ịdọka.  
\v 24 Ha ji ogho na-acha anụnụ anụnụ, ngwakọta anụnụ na uhie, nke na-acha uhie uhie na ezi akwa ọcha a kpara nke ọma kpanye oyiyi mkpụrụ pomegranet, gburugburu nʼọnụ ala ala uwe mwụda ahụ.  
\v 25 Ha dụnyekwara ataṅụ e ji ọlaedo a nụchara anụcha kpụọ, gburugburu nʼọnụ ọnụ ala ya nʼetiti pomegranet ndị ahụ.  
\v 26 Otu ataṅụ, otu oyiyi mkpụrụ pomegranet, otu a ka a dụnyere ya gburugburu ọnụ ọnụ ala uwe mwụda ahụ, nke a ga-eyi mgbe a na-eje ozi, dịka iwu \nd Onyenwe anyị\nd* nyere Mosis si dị. 
\p  
\v 27 Ha ji ezi akwa ọcha metara Erọn na ụmụ ya ndị ikom, uwe ime ahụ, akaọrụ nke onye ọkpa akwa,  
\v 28 jirikwa ezi akwa ọcha mee akwa ike nʼisi, okpu akwa ọcha, na uwe ukwu nke ezi akwa ọcha a kpara nke ọma.  
\v 29 Ihe ike nʼukwu bụ nke e ji ogho na-acha anụnụ anụnụ, ngwakọta anụnụ na uhie uhie, na uhie uhie, nke ezi akwa ọcha a kpara nke ọma, ọrụ aka onye ǹka na-akpanye ihe ịchọ mma, dịka \nd Onyenwe anyị\nd* si nye Mosis nʼiwu. 
\p  
\v 30 Ha mere efere, bụ okpu nsọ ahụ, site nʼọlaedo a nụchara anụcha, gbunyekwa akara nʼelu ya, dịka ihe e dere nʼelu mgbaaka akara: 
\pc Ihe nsọ dịrị Onyenwe anyị. 
\m  
\v 31 Mgbe ahụ, ha kenyere ya eriri na-acha anụnụ anụnụ i ji jikọta ya na ihe ike nʼisi ahụ, dịka \nd Onyenwe anyị\nd* nyere ya Mosis nʼiwu. 
\s1 Nrụcha ọrụ iwu ụlọ nzute 
\p  
\v 32 Otu a ka ha si rụchaa ọrụ iwu ụlọ nzute ahụ. Ndị Izrel mere ihe niile dịka \nd Onyenwe anyị\nd* si nye Mosis nʼiwu.  
\v 33 Mgbe ahụ, ha buteere Mosis ụlọ nzute ahụ: 
\b  
\li1 ụlọ ikwu ahụ ya na ngwongwo ya niile, ya bụ nko ya niile, mbudo ibo ya niile, mkpọrọ osisi ya niile, ogidi ya niile na ụkwụ ya niile, 
\li1  
\v 34 na akpụkpọ ebule e sijiri uhie uhie, akpụkpọ ehi mmiri e ji emechi elu ụlọ nzute ahụ, na akwa mgbochi, 
\li1  
\v 35 na igbe iwu ọgbụgba ndụ ahụ, ya na mkpara e ji ebu ya, na oche ebere ya, 
\li1  
\v 36 na tebul ahụ, ya na ngwongwo ya niile na achịcha nke iche nʼIhu Onyenwe anyị, 
\li1  
\v 37 na ihe ịdọkwasị oriọna e ji ọlaedo a nụchara anụcha kpụọ, na iheọkụ ya niile na ngwongwo ya niile, na mmanụ oliv maka ịmụ ọkụ, 
\li1  
\v 38 na ebe ịchụ aja ọlaedo, mmanụ nsọ na ụda na-esi isi ụtọ na akwa mgbochi nke ọnụ ụzọ ụlọ nzute, 
\li1  
\v 39 na ebe ịchụ aja bronz ahụ, na ihe ọkpụkpa bronz ya, mkpara ya niile na ngwongwo ya niile, 
\li1 efere ukwu ahụ ya na ihe ndọkwasị ya, 
\li1  
\v 40 akwa mgbochi nke ogige ụlọ ahụ, na ogidi ya na ihe ndọkwasị ya nakwa akwa mgbochi nke ọnụ ụzọ e si abanye nʼogige ahụ; 
\li1 ụdọ na ǹtu ịkpọgide ogige ahụ; 
\li1 ngwongwo niile nke ụlọ nzute ahụ, ụlọ ikwu nzute ahụ 
\li1  
\v 41 na uwe niile a kpara akpa, nke a na-eyi eje ozi nʼebe nsọ ahụ, ma uwe nsọ nke Erọn, onye nchụaja, na uwe nke ụmụ ya ndị ikom na-eyi mgbe ha na-eje ozi ha dịka ndị nchụaja. 
\b  
\p  
\v 42 Ndị Izrel niile rụzuru ọrụ ndị a niile dịka \nd Onyenwe anyị\nd* si nye ya Mosis nʼiwu.  
\v 43 Mosis nʼonwe ya hụkwara ọrụ ndị a niile, nabata ya ka nke e jere dịka iwu \nd Onyenwe anyị\nd* nyere si dị. Nʼihi ya, Mosis gọziri ha. 
\c 40  
\s1 Nguzo e guzobere ụlọ nzute 
\p  
\v 1 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 2 “Guzobe ụlọ nzute ahụ nʼụbọchị mbụ nke ọnwa mbụ.  
\v 3 Dọnye igbe ọgbụgba ndụ nke Ihe Ama ahụ nʼime ya. Konyekwa akwa mgbochi nke ga-ezo ya.  
\v 4 Webata tebul ahụ, na ngwongwo dị nʼelu ya, webatakwa ihe ịdọba oriọna ahụ. Mụnyekwa oriọna ndị ahụ ọkụ.  
\v 5 Doo ebe ịchụ aja ọlaedo ahụ nke e mere maka ịchụ aja ihe nsure ọkụ na-esi isi ụtọ nʼihu igbe iwu ọgbụgba ndụ ahụ. Konyekwa akwa mgbochi nke kwesiri ịdị nʼọnụ ụzọ e si abata nʼime ụlọ nzute ahụ. 
\p  
\v 6 “Doo ebe ịchụ aja nke aja nsure ọkụ ahụ nʼihu ọnụ ụzọ ịbata nʼụlọ nzute bụ ụlọ ikwu ahụ.  
\v 7 Dọnye efere ukwu ịsa mmiri ahụ nʼetiti ụlọ nzute na ebe ịchụ aja ahụ. Gbajukwaa ya mmiri.  
\v 8 Guzobe ogige gburugburu ụlọ nzute ahụ. Konyekwa akwa mgbochi nʼọnụ ụzọ ogige ahụ. 
\p  
\v 9 “Were mmanụ nsọ ahụ tee ụlọ nzute ahụ, ya na ihe niile dị nʼime ya, si otu a doo ha nsọ ma ngwongwo ịchọ mma ya niile. Ọ ga-abụ ebe dị nsọ.  
\v 10 Mgbe ahụ, tee ebe ịchụ aja nke aja nsure ọkụ ahụ mmanụ ya na ihe ya niile e ji eje ozi. Doo ebe ịchụ aja ahụ nsọ, ọ ga-abụkwa ebe dịkarịsịrị nsọ.  
\v 11 Tekwaa efere ukwu ịsa mmiri ahụ na ụkwụ ya mmanụ. Doo ha nsọ. 
\p  
\v 12 “Kpọbata Erọn na ụmụ ya ndị ikom nʼọnụ ụzọ ụlọ nzute. Jiri mmiri saa ha ahụ nʼebe ahụ.  
\v 13 Yikwasị Erọn uwe nsọ ya. Tekwaa ya mmanụ, ido ya nsọ maka i jere m ozi dịka onye nchụaja.  
\v 14 Mekwaa ka ụmụ ya ndị ikom bịaruo nso, yikwasịkwa ha uwe ime ahụ.  
\v 15 Tee ha mmanụ dịka i si tee nna ha, ime ka ha bụrụ ndị na-ejere m ozi dịka ndị nchụaja. Otite mmanụ ha ga-abụ nye ọrụ nchụaja ha nke ga-adịgide site nʼọgbọ ruo nʼọgbọ.”  
\v 16 Mosis mezuru ihe niile dịka \nd Onyenwe anyị\nd* nyere ya nʼiwu ime. 
\p  
\v 17 O ruo, nʼụbọchị mbụ nke ọnwa mbụ, nʼafọ nke abụọ, e mere ka ụlọ nzute ahụ guzo ọtọ.  
\v 18 Mosis mere ka ụlọ nzute ahụ guzo ọtọ site nʼitinye mbudo ibo ya niile, ụkwụ ya na mkpọrọ osisi ya niile nʼọnọdụ ha.  
\v 19 Emesịa, ọ gbasapụrụ ihe mkpuchi nʼelu ụlọ nzute ahụ, tụkwasịkwa okpukpu ihe mkpuchi nke abụọ nʼelu ya dịka \nd Onyenwe anyị\nd* nyere ya iwu. 
\p  
\v 20 O tinyere Ihe Ama nʼime igbe ọgbụgba ndụ ahụ. Emesịa, ọ tụkwasịkwara mkpara e ji ebu igbe ahụ nʼakụkụ igbe ahụ, were okwuchi igbe ahụ, nke bụ Oche Ebere ahụ, kpuchie igbe iwu ọgbụgba ndụ ahụ.  
\v 21 Emesịa, o bubatara igbe ahụ nʼime ụlọ nzute ahụ, kwụnyekwa akwa mgbochi nke mgbochi, kewapụ igbe iwu ọgbụgba ndụ ahụ, dịka \nd Onyenwe anyị\nd* nyere ya nʼiwu. 
\p  
\v 22 Mosis dọnyere tebul ahụ nʼakụkụ ugwu nke ụlọ nzute ahụ, na mpụta nke akwa mgbochi ahụ.  
\v 23 Ọ dọkwasịrị achịcha ahụ a na-edo nʼihu \nd Onyenwe anyị\nd* nʼelu tebul ahụ, dịka \nd Onyenwe anyị\nd* nyere ya nʼiwu. 
\p  
\v 24 Ọ dọkwasịrị ihe ịdọba oriọna ahụ nʼime ụlọ nzute nʼakụkụ tebul ahụ, nʼakụkụ ndịda nke ụlọ nzute ahụ.  
\v 25 Ọ mụnyere oriọna ndị ahụ nʼihu \nd Onyenwe anyị\nd* dịka \nd Onyenwe anyị\nd* si nye nʼiwu. 
\p  
\v 26 Mosis debere ebe ịchụ aja ọlaedo ahụ nʼime ụlọ nzute nso nso ebe akwa mgbochi ahụ dị,  
\v 27 surekwaa ihe nsure ọkụ na-esi isi ụtọ nʼelu ya, dịka \nd Onyenwe anyị\nd* nyere ya nʼiwu. 
\p  
\v 28 Ọ kwụbara akwa mgbochi nʼọnụ ụzọ ụlọ nzute ahụ.  
\v 29 Debekwa ebe ịchụ aja nke aja nsure ọkụ ahụ nso ọnụ ụzọ ịba ụlọ nzute ahụ. O surekwara aja nsure ọkụ nʼelu ya, na aja onyinye mkpụrụ ọka dịka \nd Onyenwe anyị\nd* si nye ya nʼiwu. 
\p  
\v 30 Ọ dọbara efere ịsa mmiri ahụ nʼetiti ụlọ nzute na ebe ịchụ aja, wụjuo ya mmiri, maka iji sachaa ihe.  
\v 31 Mosis, na Erọn, na ụmụ ya ndị ikom na-eji ya akwọcha aka ha, sakwaa ụkwụ ha.  
\v 32 Mgbe ọbụla ha na-abanye nʼụlọ nzute na mgbe ha na-abịa nso ebe ịchụ aja, ha na-asacha, dịka \nd Onyenwe anyị\nd* nyere ya Mosis nʼiwu. 
\p  
\v 33 Mosis guzobere ogige ahụ gburugburu ụlọ nzute ahụ na ebe ịchụ aja ahụ. O konyekwara akwa mgbochi nʼụzọ mbata nke ogige ụlọ nzute ahụ. Otu a, Mosis rụzuru ọrụ niile ahụ. 
\s1 Ebube \nd Onyenwe anyị\nd* 
\p  
\v 34 Mgbe ahụ, igwe ojii kpuchiri ụlọ nzute ahụ, ebube \nd Onyenwe anyị\nd* jupụtakwara nʼime ya.  
\v 35 Mosis nʼonwe ya enweghị ike ịbanye nʼime ụlọ nzute ahụ nʼihi igwe ojii kpuchiri elu ya na ebube \nd Onyenwe anyị\nd* jupụtara nʼụlọ nzute ahụ. 
\p  
\v 36 Nʼime njegharị ha niile, mgbe ọbụla igwe ojii ahụ si nʼelu ụlọ nzute ahụ bilie, mgbe ahụ ka ụmụ Izrel na-ebuli njem.  
\v 37 Ma ọ bụrụ na igwe ojii ahụ ebilighị, ụmụ Izrel adịghị ebulikwa njem tutuu ruo mgbe o biliri.  
\v 38 Igwe ojii \nd Onyenwe anyị\nd* ahụ na-anọgide nʼelu ụlọ nzute ahụ nʼehihie ma nʼabalị, ọkụ na-esi nʼime ya na-enwupụta. Ndị Izrel niile na-ahụkwa ya anya ụbọchị niile nke ha jegharịrị nʼọzara.