\mt1 Le livre du prophète Zacharie
\c 1
\ms1 PREMIÈRE PARTIE.
\ms2 [I, I — VIII, 23.]
\s1 PROPHÉTIES EN RAPPORT AVEC LA RECONSTRUCTION DU TEMPLE.
\s2 1. \sc Chap. i, 1-6 : Appel à la conversion.\sc*
\p 
\v 1 \w Le|strong="H03068"\w* \w huitième|strong="H08066"\w* \w mois|strong="H02320"\w*\f + \fr 1:1 \ft I, 1. \it Le huitième mois\it*, par conséquent entre la deuxième et la troisième prophétie d’Aggée ; le peuple était revenu de l’exil depuis seize ans.\f*, \w en|strong="H03068"\w* \w la|strong="H03068"\w* \w deuxième|strong="H08147"\w* \w année|strong="H08141"\w* \w de|strong="H01121"\w* \w Darius|strong="H01867"\w*, \w la|strong="H03068"\w* \w parole|strong="H01697"\w* \w de|strong="H01121"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w fut|strong="H03068"\w* \w adressée|strong="H01697"\w* \w à|strong="H03068"\w* \w Zacharie|strong="H02148"\w*, \w fils|strong="H01121"\w* \w de|strong="H01121"\w* Barachie, petit-fils d’Addo, \w le|strong="H03068"\w* \w prophète|strong="H05030"\w*, \w en|strong="H03068"\w* \w ces|strong="H01697"\w* \w termes|strong="H00559"\w* :
\p 
\v 2 \nd \w Yahweh|strong="H03068"\w*\nd* \w a|strong="H03068"\w* \w été|strong="H07019"\w* \w dans|strong="H05921"\w* \w un|strong="H03068"\w* \w grand|strong="H01419"\w* \w courroux|strong="H05678"\w* \w contre|strong="H03068"\w* \w vos|strong="H05375"\w* \w pères|strong="H00001"\w*.
\v 3 \w Et|strong="H07725"\w* \w tu|strong="H07725"\w* \w leur|strong="H03068"\w* \w diras|strong="H00559"\w* : \w Ainsi|strong="H03541"\w* \w parle|strong="H05002"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w* : \w Revenez|strong="H07725"\w* \w à|strong="H03068"\w* \w moi|strong="H06440"\w*, — \w oracle|strong="H04853"\w* \w de|strong="H07725"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*, \w et|strong="H07725"\w* \w je|strong="H07725"\w* \w reviendrai|strong="H07725"\w* \w à|strong="H03068"\w* \w vous|strong="H03068"\w*, — \w dit|strong="H05002"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*.
\v 4 \w Ne|strong="H03068"\w* \w soyez|strong="H01961"\w* \w pas|strong="H03808"\w* \w comme|strong="H01870"\w* \w vos|strong="H08085"\w* \w pères|strong="H00001"\w*, \w auxquels|strong="H00834"\w* \w ont|strong="H05030"\w* prêché \w les|strong="H08085"\w* \w premiers|strong="H07223"\w* \w prophètes|strong="H05030"\w* \w en|strong="H07725"\w* \w disant|strong="H00559"\w* : « \w Ainsi|strong="H03541"\w* \w parle|strong="H05002"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w* : \w Revenez|strong="H07725"\w* \w donc|strong="H07121"\w* \w de|strong="H01870"\w* \w vos|strong="H08085"\w* \w mauvaises|strong="H07451"\w* \w voies|strong="H01870"\w*, \w et|strong="H07725"\w* \w de|strong="H01870"\w* \w vos|strong="H08085"\w* \w mauvaises|strong="H07451"\w* \w actions|strong="H04611"\w* ! » \w et|strong="H07725"\w* \w qui|strong="H03068"\w* n’\w ont|strong="H03068"\w* \w pas|strong="H03808"\w* \w écouté|strong="H08085"\w* \w et|strong="H07725"\w* \w ne|strong="H03068"\w* m’\w ont|strong="H03068"\w* \w pas|strong="H03808"\w* \w prêté|strong="H05186"\w* \w attention|strong="H07181"\w*, — \w oracle|strong="H04853"\w* \w de|strong="H01870"\w* \nd \w Yahweh|strong="H03068"\w*\nd*.
\v 5 \w Vos|strong="H05375"\w* \w pères|strong="H00001"\w*, \w où|strong="H00370"\w* \w sont-ils|strong="H01368"\w* ? \w Et|strong="H05030"\w* \w les|strong="H02421"\w* \w prophètes|strong="H05030"\w*, \w pouvaient-ils|strong="H05030"\w* \w vivre|strong="H02421"\w* \w éternellement|strong="H05769"\w* ?
\v 6 \w Mais|strong="H00199"\w* \w mes|strong="H06213"\w* \w paroles|strong="H01697"\w* \w et|strong="H07725"\w* \w mes|strong="H06213"\w* décrets, \w dont|strong="H03068"\w* \w j|strong="H05650"\w*’\w avais|strong="H06213"\w* \w chargé|strong="H01697"\w* \w mes|strong="H06213"\w* \w serviteurs|strong="H05650"\w* \w les|strong="H06213"\w* \w prophètes|strong="H05030"\w*, n’\w ont-ils|strong="H05650"\w* \w pas|strong="H03808"\w* \w atteint|strong="H05381"\w* \w vos|strong="H06213"\w* \w pères|strong="H00001"\w*, \w si|strong="H03808"\w* \w bien|strong="H03651"\w* \w qu|strong="H01697"\w*’\w ils|strong="H07725"\w* \w se|strong="H03068"\w* \w sont|strong="H03068"\w* convertis\f + \fr 1:6 \ft 6. \it Se sont convertis\it*, mais trop tard pour leur salut.\f* \w et|strong="H07725"\w* \w ont|strong="H05650"\w* \w dit|strong="H01697"\w* : « \w Comme|strong="H06213"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w* \w avait|strong="H03068"\w* \w résolu|strong="H02161"\w* d’\w agir|strong="H06213"\w* \w à|strong="H03068"\w* \w notre|strong="H06213"\w* \w égard|strong="H01697"\w*, \w selon|strong="H06310"\w* \w nos|strong="H06213"\w* \w voies|strong="H01870"\w* \w et|strong="H07725"\w* \w selon|strong="H06310"\w* \w nos|strong="H06213"\w* \w actions|strong="H01697"\w*, \w ainsi|strong="H01697"\w* \w il|strong="H03068"\w* \w a|strong="H03068"\w* \w agi|strong="H06213"\w* \w envers|strong="H06213"\w* \w nous|strong="H03068"\w*. »
\s2 2. \sc Chap. i, 7\sc* — vi, 15 : Visions nocturnes : la théocratie nouvelle.
\s3 \sc A. Chap. i, 7-17\sc* : Vision des chevaux et des cavaliers. — Date (i, 7). La vision (i, 8-11). Question concernant Jérusalem (i, 12). Réponse de consolation (i, 13-15) ; Jérusalem sera rebâtie et bénie (i, 16, 17).
\p 
\v 7 \w Le|strong="H03068"\w* \w vingt-quatrième|strong="H03068"\w* \w jour|strong="H03117"\w* \w du|strong="H03117"\w* \w onzième|strong="H06249"\w* \w mois|strong="H02320"\w*, \w qui|strong="H03068"\w* \w est|strong="H03068"\w* \w le|strong="H03068"\w* \w mois|strong="H02320"\w* \w de|strong="H01121"\w* Sabath\f + \fr 1:7 \ft 7. \it Sabath\it* (hébr. \it Schebal\it*), février-mars. La date donnée en ce vers. et complétée par l’indication « pendant la nuit » du vers. suiv., convient à toutes les visions des chap, i, 8 — vi, 8.\f* , \w en|strong="H03117"\w* \w la|strong="H03117"\w* \w deuxième|strong="H08147"\w* \w année|strong="H08141"\w* \w de|strong="H01121"\w* \w Darius|strong="H01867"\w*, \w la|strong="H03117"\w* \w parole|strong="H01697"\w* \w de|strong="H01121"\w* \w Dieu|strong="H03068"\w* \w fut|strong="H03068"\w* \w adressée|strong="H01697"\w* \w à|strong="H03068"\w* \w Zacharie|strong="H02148"\w*, \w fils|strong="H01121"\w* \w de|strong="H01121"\w* Barachie, petit-fils d’Addo, \w le|strong="H03068"\w* \w prophète|strong="H05030"\w*, \w en|strong="H03117"\w* \w ces|strong="H01697"\w* \w termes|strong="H00559"\w* :
\p 
\v 8 \w J|strong="H03068"\w*’\w ai|strong="H01931"\w* \w eu|strong="H02492"\w* \w une|strong="H07200"\w* \w vision|strong="H07200"\w* \w pendant|strong="H07200"\w* \w la|strong="H07200"\w* \w nuit|strong="H03915"\w* : \w Voici|strong="H02009"\w* qu’\w un|strong="H07200"\w* \w homme|strong="H00376"\w*\f + \fr 1:8 \ft 8. \it Un homme\it*, un ange suivi de trois groupes de cavaliers dont il est le chef ; ils sont chargés de reconnaître l’état actuel des peuples qui environnent le pays d’Israël (vers. 10), et sont comme le symbole du regard divin qui se promène sur la terre : comp. Job 1,7 ; 2,2. — \it Entre des myrtes\it*. LXX, \it au milieu des montagnes\it* de même vers. 10, 11. cheval roux, et il se tenait entre des myrtes dans un lieu ombragé, et il y avait derrière lui des chevaux roux, alezans et blancs.\f* \w était|strong="H05975"\w* \w monté|strong="H07392"\w* \w sur|strong="H05921"\w* \w un|strong="H07200"\w* \w cheval|strong="H05483"\w* \w roux|strong="H00122"\w*, \w et|strong="H07200"\w* \w il|strong="H01931"\w* \w se|strong="H07200"\w* \w tenait|strong="H05975"\w* \w entre|strong="H00935"\w* \w des|strong="H07200"\w* \w myrtes|strong="H01918"\w* \w dans|strong="H07200"\w* \w un|strong="H07200"\w* \w lieu|strong="H04725"\w* \w ombragé|strong="H04699"\w*, \w et|strong="H07200"\w* \w il|strong="H01931"\w* \w y|strong="H08033"\w* \w avait|strong="H07200"\w* \w derrière|strong="H05975"\w* \w lui|strong="H01931"\w* \w des|strong="H07200"\w* \w chevaux|strong="H05483"\w* \w roux|strong="H00122"\w*, alezans \w et|strong="H07200"\w* \w blancs|strong="H03836"\w*.
\v 9 \w Je|strong="H05315"\w* \w dis|strong="H01696"\w*\f + \fr 1:9 \ft 9. \it Je dis\it* à l’ange qui va servir d’interprète à Zacharie dans tout le cours de ses visions, et qu’il voit déjà présent à côté de lui. — \it L’ange qui parlait avec moi\it*, ou \it en moi\it*.\f* : « \w Que|strong="H07200"\w* \w sont|strong="H01992"\w* ceux-ci, \w mon|strong="H07200"\w* \w seigneur|strong="H00136"\w* ? » \w Et|strong="H07200"\w* l’\w ange|strong="H04397"\w* \w qui|strong="H04397"\w* \w parlait|strong="H01696"\w* \w avec|strong="H01696"\w* \w moi|strong="H06440"\w* \w me|strong="H04397"\w* \w dit|strong="H01696"\w* : « \w Je|strong="H05315"\w* \w te|strong="H04100"\w* \w ferai|strong="H06213"\w* \w voir|strong="H07200"\w* \w ce|strong="H01992"\w* \w que|strong="H07200"\w* \w sont|strong="H01992"\w* ceux-ci. »
\v 10 \w Et|strong="H06030"\w* l’\w homme|strong="H03068"\w* \w qui|strong="H03068"\w* \w se|strong="H03068"\w* \w tenait|strong="H05975"\w* \w entre|strong="H01980"\w* \w les|strong="H03068"\w* \w myrtes|strong="H01918"\w* \w prit|strong="H03947"\w* \w la|strong="H07971"\w* \w parole|strong="H06030"\w* \w et|strong="H06030"\w* \w dit|strong="H06030"\w* : « \w Ce|strong="H07971"\w* \w sont|strong="H03068"\w* \w ceux|strong="H00582"\w* \w que|strong="H01697"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w a|strong="H03068"\w* \w envoyés|strong="H07971"\w* \w pour|strong="H07971"\w* \w parcourir|strong="H01980"\w* \w la|strong="H07971"\w* \w terre|strong="H00776"\w*. »
\v 11 \w Et|strong="H06030"\w* \w ils|strong="H01992"\w* \w répondirent|strong="H06030"\w* \w à|strong="H03068"\w* l’\w ange|strong="H04397"\w* \w de|strong="H03427"\w* \nd \w Yahweh|strong="H03068"\w*\nd*\f + \fr 1:11 \ft 11. \it L’ange de Yahweh\it*, l’image personnelle du Dieu invisible, qui toutefois s’en distingue (vers. 12). — \it Toute la terre\it*, les contrées voisines de la Palestine, est en repos : la paix et la tranquilité régnaient partout dans les premières années de Darius, tandis que les villes de Juda étaient encore en ruines.\f* \w qui|strong="H04397"\w* \w se|strong="H03068"\w* \w tenait|strong="H05975"\w* \w entre|strong="H03427"\w* \w les|strong="H03068"\w* \w myrtes|strong="H01918"\w*, \w et|strong="H06030"\w* \w ils|strong="H01992"\w* \w dirent|strong="H00559"\w* : « \w Nous|strong="H03068"\w* \w avons|strong="H03426"\w* \w parcouru|strong="H01980"\w* \w la|strong="H03068"\w* \w terre|strong="H00776"\w*, \w et|strong="H06030"\w* \w voici|strong="H02009"\w* \w que|strong="H04397"\w* \w toute|strong="H03605"\w* \w la|strong="H03068"\w* \w terre|strong="H00776"\w* \w est|strong="H03068"\w* \w habitée|strong="H03427"\w* \w et|strong="H06030"\w* \w tranquille|strong="H08252"\w*. »
\v 12 \w L|strong="H05892"\w*’\w ange|strong="H04397"\w* \w de|strong="H05892"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w prit|strong="H03947"\w* \w la|strong="H03068"\w* \w parole|strong="H06030"\w* \w et|strong="H06030"\w* \w dit|strong="H06030"\w* : « \nd \w Yahweh|strong="H03068"\w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*, jusques \w à|strong="H03068"\w* \w quand|strong="H03808"\w* n’auras-tu \w pas|strong="H03808"\w* \w pitié|strong="H07355"\w* \w de|strong="H05892"\w* \w Jérusalem|strong="H03389"\w* \w et|strong="H06030"\w* \w des|strong="H03068"\w* \w villes|strong="H05892"\w* \w de|strong="H05892"\w* \w Juda|strong="H03063"\w* \w contre|strong="H03068"\w* \w lesquelles|strong="H02004"\w* \w tu|strong="H08141"\w* \w es|strong="H00383"\w* \w irrité|strong="H02194"\w* \w voilà|strong="H01697"\w* \w soixante-dix|strong="H08141"\w*\f + \fr 1:12 \ft 12. \it Soixante-dix ans\it*, en prenant comme point de départ la destruction complète de Jérusalem (an 588).\f* \w ans|strong="H08141"\w* ? »
\v 13 \w Et|strong="H06030"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w adressa|strong="H01696"\w* \w à|strong="H03068"\w* l’\w ange|strong="H04397"\w* \w qui|strong="H04397"\w* \w parlait|strong="H01696"\w* \w avec|strong="H01696"\w* \w moi|strong="H06030"\w* \w de|strong="H01697"\w* \w bonnes|strong="H02896"\w* \w paroles|strong="H01697"\w*, \w des|strong="H03068"\w* \w paroles|strong="H01697"\w* \w de|strong="H01697"\w* \w consolation|strong="H05150"\w*.
\v 14 \w Et|strong="H01419"\w* l’\w ange|strong="H04397"\w* \w qui|strong="H04397"\w* \w parlait|strong="H01696"\w* \w avec|strong="H01696"\w* \w moi|strong="H06440"\w* \w me|strong="H03068"\w* \w dit|strong="H01696"\w* : « \w Proclame|strong="H01696"\w* \w ceci|strong="H01697"\w* : \w Ainsi|strong="H03541"\w* \w parle|strong="H01696"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w* : \w J|strong="H03068"\w*’\w ai|strong="H03068"\w* \w été|strong="H07019"\w* \w animé|strong="H07130"\w* d’\w une|strong="H03068"\w* \w grande|strong="H01419"\w* \w jalousie|strong="H07068"\w* \w pour|strong="H04397"\w* \w Jérusalem|strong="H03389"\w* \w et|strong="H01419"\w* \w pour|strong="H04397"\w* \w Sion|strong="H06726"\w* ;
\v 15 \w et|strong="H01419"\w* \w je|strong="H04592"\w* \w suis|strong="H01961"\w* \w animé|strong="H07107"\w* \w d|strong="H01992"\w*’\w un|strong="H05921"\w* \w grand|strong="H01419"\w* \w courroux|strong="H05678"\w* \w contre|strong="H07107"\w* \w les|strong="H01471"\w* \w nations|strong="H01471"\w* \w qui|strong="H01471"\w* \w vivent|strong="H02421"\w* \w dans|strong="H07600"\w* l’opulence ! \w Car|strong="H03588"\w* \w moi|strong="H06440"\w*, j’étais \w un|strong="H00259"\w* \w peu|strong="H04592"\w* \w irrité|strong="H07107"\w* ; \w et|strong="H01419"\w* \w elles|strong="H00310"\w* \w ont|strong="H01471"\w*, \w elles|strong="H00310"\w*, \w travaillé|strong="H06213"\w* \w à|strong="H07451"\w* \w la|strong="H05921"\w* \w ruine|strong="H07667"\w*\f + \fr 1:15 \ft 15. \it Et elles ont, elles, travaillé à la ruine\it* ; m. à m., \it et elles ont, elles, aidé, concouru, au mal\it*. Les nations, dépassant ma volonté et se montrant cruelles à l’excès, ont travaillé à la destruction totale d’Israël.\f*.
\v 16 C’\w est|strong="H03068"\w* \w pourquoi|strong="H03651"\w* \w ainsi|strong="H03541"\w* \w parle|strong="H05002"\w* \nd \w Yahweh|strong="H03068"\w*\nd* : \w Je|strong="H07725"\w* \w reviens|strong="H07725"\w* \w à|strong="H03068"\w* \w Jérusalem|strong="H03389"\w* \w avec|strong="H07725"\w* \w compassion|strong="H07356"\w* ; \w ma|strong="H05186"\w* \w maison|strong="H01004"\w* \w y|strong="H03068"\w* \w sera|strong="H03068"\w* \w rebâtie|strong="H01129"\w*, — \w oracle|strong="H04853"\w* \w de|strong="H01004"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*, \w et|strong="H07725"\w* \w le|strong="H05002"\w* \w cordeau|strong="H06957"\w* \w sera|strong="H03068"\w* \w étendu|strong="H05186"\w* \w sur|strong="H03068"\w* \w Jérusalem|strong="H03389"\w*.
\v 17 \w Proclame|strong="H07121"\w* \w encore|strong="H05750"\w* \w ceci|strong="H01697"\w* : \w Ainsi|strong="H03541"\w* \w parle|strong="H00559"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w* : \w Mes|strong="H07121"\w* \w villes|strong="H05892"\w* \w regorgeront|strong="H06555"\w* \w encore|strong="H05750"\w* \w de|strong="H05892"\w* \w biens|strong="H02896"\w*, \w et|strong="H03068"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w consolera|strong="H05162"\w* \w encore|strong="H05750"\w* \w Sion|strong="H06726"\w*, \w et|strong="H03068"\w* \w choisira|strong="H00977"\w* \w encore|strong="H05750"\w* \w Jérusalem|strong="H03389"\w*. »
\c 2
\s3 \sc B. Chap. ii, 1-4\sc* : Vision des quatre cornes et des quatre forgerons.\f + \fr 2:0 \ft II, 1-4 : Cette vision développe le vers. 15 du chap. i.\f*
\p 
\v 1 \w Je|strong="H05315"\w* \w levai|strong="H05375"\w* \w les|strong="H05375"\w* \w yeux|strong="H05869"\w* \w et|strong="H07200"\w* \w je|strong="H05315"\w* \w vis|strong="H07200"\w* : \w Et|strong="H07200"\w* \w voici|strong="H02009"\w* \w quatre|strong="H00702"\w* \w cornes|strong="H07161"\w*\f + \fr 2:1 \ft 1. \it Quatre cornes\it*, symbolisant l’ensemble des ennemis d’Israël, venus de tous les côtés, des quatre points de l’horizon.\f* .
\v 2 \w Et|strong="H03063"\w* \w je|strong="H05315"\w* \w dis|strong="H01696"\w* \w à|strong="H01696"\w* l’\w ange|strong="H04397"\w* \w qui|strong="H04397"\w* \w parlait|strong="H01696"\w* \w avec|strong="H01696"\w* \w moi|strong="H06440"\w* : « \w Que|strong="H04397"\w* \w sont|strong="H03478"\w* celles-ci ? » \w Il|strong="H03389"\w* \w me|strong="H03478"\w* \w dit|strong="H01696"\w* : « \w Ce|strong="H04100"\w* \w sont|strong="H03478"\w* \w les|strong="H01696"\w* \w cornes|strong="H07161"\w* \w qui|strong="H04397"\w* \w ont|strong="H03478"\w* \w dispersé|strong="H02219"\w* \w Juda|strong="H03063"\w*, \w Israël|strong="H03478"\w* \w et|strong="H03063"\w* \w Jérusalem|strong="H03389"\w*. »
\p 
\v 3 \w Et|strong="H03068"\w* \nd \w Yahweh|strong="H03068"\w*\nd* \w me|strong="H03068"\w* \w fit|strong="H03068"\w* \w voir|strong="H07200"\w* \w quatre|strong="H00702"\w* \w forgerons|strong="H02796"\w*.
