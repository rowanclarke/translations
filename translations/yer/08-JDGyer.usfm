\id JDG - Tarok 
\h Nlir Nnap-Akwali 
\toc3 Nnap Akw 
\toc2 Nnap-Akwali 
\toc1 Nlir Nnap-Akwali 
\mt1 Nnap Akw 
\c 1  
\s1 UYahuda ká̱ uSimeyon ri aUrushelima 
\p  
\v 1 Ka̱ nva̱ng ikú aJoshuwa te, oIsa̱rila ɓəp uYawe pa̱, <<Uda ka̱ ashe yi i ɓan ngga nlung onəm oga aKanana mpyal yà?>> 
\p  
\v 2 Te uYawe na ama̱n pa̱, <<Onəm aYahuda oma á ga, ó dər, n na mbin va̱ ta chit ka̱ ashe awo oza̱.>> 
\p  
\v 3 Te onəm aYahuda là ônəm aSimeyon ogənang oza̱ pa̱, <<Ó ga nzəng ká̱ yi ka̱ atak iya̱mkup yi, ka̱kul na í lung onəm oga aKanana. Wa nnà ta kpa í fa í ga nzəng ká̱ wó ka̱ ashe nkap iji wó.>>Te oSimeyon ga nzəng ká̱ oza̱. 
\p  
\v 4 Awalang va̱ onəm aYahuda ga ru oza̱ ká̱ ìkum te, uYawe na oKanana, ká̱ oPerizi ka̱ ashe awo oza̱. Oza̱ gbá̱ng onunggwan ìkalong pa̱ ìgba̱pchi ka̱ aBezek.  
\v 5 Ka̱ ta na oza̱ ya uAdoni-Bezek, te oza̱ ru na ká̱ ìkum, kang oza̱ ri oKanana ká̱ oPerizi.  
\v 6 UAdoni-Bezek chə́r, ǹnyi te, oza̱ wà nvəva̱ng oza̱ kpán na, kang oza̱ kyen ifəfang inunggwan iga ashar ká̱ iga awo. 
\p  
\v 7 Te uAdoni-Bezek là pa̱, <<Oponzhi ìsəm pa̱ ifangshat ova mmá kyen oga ifang inunggwan iga ashar ká̱ iga awo ôza̱ kang oza̱ pak inok nchák iya̱m-nrì ka̱ avəng atebəl mi á. Wa nva ka̱ n nəm ôza̱ te, wa nnà ta Inan pyát akəkat á mi kpa.>>Te oza̱ ga ká̱ na ka̱ aUrushelima kang uza̱ kú ka̱ ta. 
\p  
\v 8 Te onəm aYahuda ru aUrushelima ká̱ ìkum, kang oza̱ ri na. Oza̱ gba̱ng onənəm ká̱ ndokchi, kang oza̱ pwak ìtong va̱ ta ká̱ apər. 
\p  
\v 9 Ka̱ nvəva̱ng te, onəm aYahuda ga pa̱ na o lung ìkum ká̱ oKanana ova ra ka̱ mbin ngga aɗuktum, ká̱ aNegep, ká̱ oga ovan aɓam aga asa̱l ntar alum.  
\v 10 Te aYahuda ga nəm ìkum ká̱ oKanana ova ra ka̱ aHebron. Matmat te, aɗin aHebron ka̱ yà pa̱ aKiriyat-Arba. Kang oza̱ ri uSheshayi, ká̱ uAhiman, ká̱ uTalmayi ká̱ ikum.  
\v 11 Oza̱ wong ka̱ ta te, oza̱ ru aDebir. Matmat te, mí wór aɗin aDebir pa̱ aKiriyat-Sefer. 
\p  
\v 12 Te uKalip là pa̱, <<Mi na uyen mi uAksa ka̱ ìvang ûnəm va̱ i ru aKiriyat-Sefer ka̱ ìkum kang i ri na á.>>  
\v 13 Te uOtniyel uya aKenat, uɓwakan aKalip ga ri na ká̱ ìkum. Te uza̱ na uyen wò uAksa á na yà uchichar. 
\p  
\v 14 Ka̱ nva̱ngva̱ uza̱ ga atak aɓar wò te, uza̱ nok na pa̱ uza̱ á ɓəp iram ka̱ upo wò. Awalang va̱ uAksa fər ka̱ apal azhaki wò te, uKalip ɓəp na pa̱, <<Iza̱ mi nəm a ɓu yà?>>  
\v 15 Uza̱ na ama̱n a na pa̱, <<Pa̱r mi, ka̱kul u na mbin á mi chit ka̱ aNegep\f + \fr 1.15 \ft Atak va yà ká̱ ndəng ka̱t\f*, n chal pa̱ u na oga atak mɓəl ndəng á mi kpa.>> Te uKalip na oga atak aga mɓəl ndəng á na ngga apal ká̱ ngga avəng. 
\p  
\v 16 Te akum ìjili oKeni, ugwar aMusa, fa nzəng ká̱ onəm oga aYahuda ka̱ ashe ìtong iga akulom oza̱ ga pa̱ na ó təm nzəng ká̱ onəm ga nzam mmaləng ngga aYahuda, nva ra ka̱ nkwandal aArat. 
\p  
\v 17 Te oYahuda ká̱ ogənang oza̱ oSimeyon ga ru onəm oga aKanana ova ka̱ ntəm ka̱ aZefat ká̱ ìkum, kang oza̱ zhì ìtong va̱ ta pa̱ chatchat. Kang uza̱ wór aɗin ìtong va̱ ta pa̱ aHorma\f + \fr 1.17 \ft Ìpir aHorma pa̱ nzhì atak.\f*.  
\v 18 Onəm aYahuda ri aGaza kpa, ká̱ aAshkelon, ká̱ aEkron nzəng ká̱ nkpaktak oga mbin oza̱. 
\p  
\v 19 UYawe uwa ka̱ yà nzəng ká̱ onəm aYahuda. Oza̱ kwom mbin ngga aɗuktum, ǹnyi te, ìkam oza̱ kur mɓak onəm oga ntəm ka̱ mbin ngga agbagba ka̱t, ka̱kul onəm va̱ ta ká̱ akeke ipəri aga acham.  
\v 20 Te mmá na aHebron uKalip, wa nva uMusa ka̱ yar nsar nnap-nlà á na. Kang uza̱ ɓak ovan aAnak onunggwan pa̱ oshatɗing fa ka̱ ta.  
\v 21 Ǹnyi te, onəm aBenjamin ɓak oJebusi va̱ təm ka̱ aUrushelima ka̱t, ka̱kul nva̱ ta̱ te, oJebusi oma ka̱ ntəm nzəng ká̱ onəm aBenjamin ka̱ aUrushelima nda va̱ ta̱. 
\p  
\v 22 Ǹyangmata̱ te, akum ìjili aYusufu wong ga ru aBetel ka̱ ìkum, kang uYawe uwa yà nzəng ká̱ oza̱.  
\v 23 Awalang va̱ nzhi aYusufu re onəm pa̱ á ga á sóng aBetel (matmat te mí wór ìtong va̱ ta pa̱ aLut) te,  
\v 24 onəm oga nsóng atak va̱ ta ya unəm uro ka̱ nfa ka̱ ashe ìtong, te oza̱ là á na pa̱, <<Kusuk, nyám asa̱l aga ntar ashe ìtong va̱ ta̱ á yi, te í nyám ikin á ɓu.>>  
\v 25 Te uza̱ nyám asa̱l ôza̱, kang oza̱ táng ashe ìtong va̱ ta gbá̱ng onəm ká̱ ndokchi, ǹnyi te, oza̱ re unəm va̱ ta ká̱ nkpaktak nzhizhi.  
\v 26 Te unəm va̱ ta ga mbin oHitti, kang a me ìtong ka̱ ta, uza̱ pa̱ aɗin á na pa̱ aLut. Nna ta aɗiɗin ɓa chu nda va̱ ta̱. 
\p  
\v 27 Ǹnyi te, uManase ɓak onəm va̱ ka̱ ntəm ka̱ ashe aBet-Shan, ka̱t te aTayanak, ka̱t te aDor, ka̱t te aMegido, ka̱t te aIbəleyam ká̱ oga ivan ìtong oza̱ va̱ gáng oza̱ ka̱t. Ka̱kul oKanana zhet kà̱ ntəm ka̱ ashe mbin va̱ ta.  
\v 28 Ka̱ nva̱ngva̱ oIsa̱rila kam chit te, oza̱ nak oKanana ka̱ nnəm inok iga nkpak, ǹnyi te oza̱ ɓak oza̱ fa pa̱ chatchat ka̱t.  
\v 29 UEfrayim ɓak oKanana va̱ ka̱ ntəm ka̱ ashe aGezer fa ka̱t, wa nnà ta oKanana ga mpyal ká̱ ntəm ka̱ ashe oza̱ ka̱ aGezer.  
\v 30 UZebulun ɓak oKanana va̱ ka̱ ntəm ka̱ aKitron, ka̱t te onəm oga ntəm ka̱ aNahalol fa ka̱t. Á nak te oKanana təm nzəng ká̱ oza̱, ǹnyi te oza̱ nak oza̱ ka̱ nnəm inok iga nkpak.  
\v 31 UAsher ɓak onəm oga ntəm ka̱ ashe aAkko, ka̱t te onəm oga ntəm ka̱ aSidon, ka̱t te oga aAlap, ka̱t te oga aAkzip, ka̱t te oga aHelba, ka̱t te oga aAfek, ka̱t te oga aRehop fa ka̱t.  
\v 32 Ǹnyi te, onəm oga aAsher təm ka̱ ishimshe oKanana, onəm oga ntəm ka̱ mbin va̱ ta, ka̱kul oza̱ ɓak oza̱ fa ka̱t.  
\v 33 Wa nnà ta kpa, akum ìjili aNaftali ɓak onəm oga ntəm ka̱ aBet-Shemesh, ka̱t te oga ntəm ka̱ aBet-Anat fa ka̱t, ǹnyi te, oza̱ təm ka̱ ishimshe oKanana, onəm oga ntəm ka̱ mbin va̱ ta. Káp ká̱ nna te, onəm oga ntəm ka̱ aBet-Shemesh ká̱ aBet-Anat tong onəm oga nəm inok izwal ôza̱.  
\v 34 Ǹnyi te, oAmori ka̱r akum ìjili aDan ka̱ mbin ngga aɗuktum, kang oza̱ ma̱n ôza̱ pa̱ á fə́r á vang mbin ngga agbagba ka̱t.  
\v 35 Te oAmori zhet kpa ka̱ ntəm ka̱ aƁam aHeret, ká̱ aAijalon, kang ká̱ aShayalbim. Ǹnyi te, awalang va̱ oga akum ìjili aYusufu wong kam te, oza̱ nak oAmori ka̱ inok iga nkpak kpa.  
\v 36 Kang aswari oAmori ɓan ka̱ asa̱l aAkrabim ɓa ga aSela, kang á kyen ɓa ga mpyal. 
\c 2  
\s1 Uma̱leka aYawe ka̱ aBokim 
\p  
\v 1 <<Te uma̱leka aYawe fa ka̱ aGilgal ga aBokim kang a là pa̱, <<N fa ká̱ wó ka̱ aMasar kang m ɓa ká̱ wó ka̱ ashe mbin va n sóng anung pa̱ mi na ôkəka wó. N là pa̱, <Mi yà ka̱ nfən nsar nnap-nlà mi ka̱ wó ka̱t mbyet,  
\v 2 kang mmawó te, ó yà ka̱ ǹyar nsar nnap-nlà ká̱ onəm oga ntəm ka̱ mbin va̱ ta̱ ka̱t, ǹnyi te, ó shin oga atak nshì iya̱m awop oza̱.> Ká̱ nna kpa te, ó kpak nnap-nnəm á mi ka̱t. Iza̱ nak kang ó nəm pa yà?  
\v 3 Ka̱kul nva̱ ta te, n là pa̱, <<Mi yà ka̱ mɓak oza̱ i le ka̱ mpyal wó ka̱t, ǹnyi te oza̱ i tong wa izú ka̱ atak wó, kang oga inan oza̱ i tong ajəp á wó.>> 
\p  
\v 4 <<Ka̱ nva̱ngva̱ uma̱leka aYawe là iya̱m va̱ ta̱ chit n̂kpaktak ovan ga aIsa̱rila te, onəm gham ká̱ ayə́ng,  
\v 5 kang oza̱ wór aɗin atak va̱ ta pa̱ aBokim\f + \fr 2.5 \ft Ìpir aBokim pa̱ onəm oga yə́ng ayə́ng.\f*. Ka̱ ta te, oza̱ yichi nləfər iya̱m ipápà ûYawe. 
\p  
\v 6 Ka̱ awalang va̱ uJoshuwa lyang ká̱ onəm oga aIsa̱rila chit te, udanggo ga atak wò pa̱ na ô kwom mbin ngga iya̱mkup wò.  
\v 7 Onəm va̱ ta wop uYawe ka̱ ashe nkpaktak nra aJoshuwa, ká̱ nkpaktak nra onəmgbak va̱ oma yà ká̱ irirì ka̱ nva̱ng ikúku, ovəngva nyi nkpaktak oga iya̱m ichumchum va̱ uYawe nəm ka̱kul oIsa̱rila á. 
\p  
\v 8 Te uJoshuwa uya aNun ununggwan, uzwal aYawe kú, izuzun igba̱l ká̱ ngba̱pchi.  
\v 9 Kang oza̱ li na ka̱ mbin iya̱mkukup ka̱ ashe aTimnat-Heret, ka̱ mbin ngga aɗuktum aEfrayim, ka̱ asa̱l mpal aƁam aGayash. 
\p  
\v 10 Ka̱ nva̱ng va̱ nkpaktak nlwàk va̱ ta kú te, nlwàk nro wong ka̱ nva̱ng oza̱ nva nyi uYawe ka̱t te, inok va̱ uza̱ nəm ka̱kul oIsa̱rila ka̱t.  
\v 11 Te ovan oIsa̱rila nəm nnap-mɓá̱ngɓa̱ng ka̱ mpyal aYawe, kang oza̱ wop oga aBaal.  
\v 12 Oza̱ re ngwop uYawe, Inan okəka oza̱, uva fa ká̱ oza̱ ka̱ mbin aMasar. Oza̱ le i wop oga inan iro ka̱ ashe oga inan onəm va̱ ra gang oza̱, kang oza̱ kuchi oza̱. Te oza̱ lak ìgwak uYawe  
\v 13 ka̱kul oza̱ yang ká̱ ngwop uYawe, oza̱ le i wop aBaal ká̱ oga aAshtoret.  
\v 14 Ka̱ ashe nlak ìgugwak ka̱ apal oIsa̱rila te, uYawe na oza̱ ka̱ ashe awo onəm oga nyán ká̱ oza̱, kang a kwom iya̱m oza̱. Uza̱ yichi oza̱ ka̱ ashe awo okpa ìkum oza̱ ovəngva gang oza̱, ka̱kul nva̱ ta te, oza̱ kur ntong ka̱ mpyal okpa ìkum oza̱ lap ka̱t.  
\v 15 Nkpaktak awalang va̱ oIsa̱rila i fa pa̱ ó ga ìkum te, awo aYawe i lung oza̱ wa nva uza̱ ka̱ sóng anung ôza. Kang oza̱ ɓək anung pa̱ makmak. 
\p  
\v 16 Te uYawe wong ká̱ onəm oga nnáp akwali\f + \fr 2.16 \ft Ìpir onəm oga nnáp akwali ka̱ ta̱ te, onəm oga mpyal.\f*, ova ka̱m ishi oza̱ ka̱ ashe awo onəm oga nkwom iya̱m oza̱ ká̱ ìfan.  
\v 17 Káp ká̱ nna te, oza̱ gwong achwang ka̱ onəm oga nnap-akwali ôza̱ ka̱t, ǹnyi te, oza̱ nəm mmai ka̱ atak ngwop oga inan iro. Kang oza̱ ga̱ɓa̱n ká̱ nggha̱n re asa̱l va̱ okəka oza̱ wòl kà̱, ova ka̱ kpak nnap-mpakpak aYawe.  
\v 18 Nkpaktak awalang va̱ uYawe na unəm uga nnap-akwali ôza̱ te, uYawe uwa yà nzəng ká̱ unəm uga nnap-akwali va̱ ta, kang uza̱ ka̱m ishi oza̱ ka̱ ashe awo okpa ìkum oza̱ ka̱ ashe nra anəm uga nnap-akwali va̱ ta. Ka̱kul ayə́ng ká̱ nshìn oza̱ rwa ìgwak ûYawe, nva̱ onəm ka̱r oza̱ kang anyán ká̱ oza̱ á.  
\v 19 Ǹnyi te, awalang va̱ unəm uga nnap-akwali va̱ ta a kú te, oza̱ i ga̱ɓa̱n i le i nəm nlang nnandər nva ji nji okəka oza̱ ji, oza̱ i le ka̱ oga inan iro, oza̱ i wop oza̱ kang oza̱ i kuchi ôza̱, oza̱ i re oga nnap-mɓá̱ngɓa̱ng oza̱, ka̱t te ntwat ìgwak oza̱ ka̱t. 
\p  
\v 20 Te ìgwak lak uYawe pa̱ gənggəng ka̱ apal oIsa̱rila, kang uza̱ là pa̱, <<Ka̱kul onəm va̱ ta̱ fən nsar nnap-nlà mi va̱ n nak opo oza̱ chit, kang oza̱ gwong achwang ka̱ mi ka̱t te,  
\v 21 mi yà ká̱ mɓak mbin nro i le ka̱ mpyal oza̱ lap ka̱ ashe oga mbin va̱ uJoshuwa kú kang a re ka̱t.  
\v 22 Mi nəm inok ká̱ oza̱ na m ma oIsa̱rila, mwote oza̱ i nəm achen ka̱ asa̱l aYawe wa nva̱ opo oza̱ ka̱ nəm nggo, ka̱t te oza̱ i nəm pa ka̱t.>>  
\v 23 UYawe ka̱ re oga mbin va̱ ta təm ka̱ ta, uza̱ ɓak oza̱ fa ka̱ ashe awalang pa̱ zəng ka̱ atak nna oza̱ ka̱ ashe awo aJoshuwa ka̱t. 
\c 3  
\p  
\v 1 Oga mbin va ta̱ uYawe re, pa̱ na o ma oIsa̱rila ká̱, ova ma ka̱ lung ìkum chit ká̱ oKanana ka̱t.  
\v 2 Uza̱ nəm pa ka̱kul pa̱ na o ɗyang nlung ìkum ôga akum ìjili oIsa̱rila ovəngva̱ oma ka̱ nyi nlung ìkum chit kang ka̱t á.  
\v 3 Oga mbin va̱ oma ta̱, oponzhi pa̱ otukun oga oFilisti, ká̱ nkpaktak oKanana, ká̱ oSidon, ká̱ oHivi ova ra ka̱ oga aɓam aLebanon, a ɓan ka̱ aƁam aBaal-Harmon ga chu aLebo Hamat.  
\v 4 Mmá re oza̱ ka̱kul mma oIsa̱rila, mwote oza̱ i kpak nnap-mpakpak aYawe kpak nggo, nva̱ uza̱ nak ôkəka oza̱ ka̱ atak aMusa á. 
\p  
\v 5 Te onəm oIsa̱rila təm ka̱ ashe oKanana, ká̱ oHitti, ká̱ oAmori, ká̱ oPerizi, ká̱ oHivi, ká̱ oJebusi.  
\v 6 Oza̱ ka̱m ichar ká̱ ovan oza̱ ochar, kang oza̱ na ovan oza̱ ìvang ochar ôvan oza̱ onunggwan, kang oza̱ wop oga inan oza̱. 
\s1 UOtniyel 
\p  
\v 7 Kang oIsa̱rila kong ká̱ uYawe, Inan oza̱, oza̱ nəm nnap-mɓá̱ngɓa̱ng ka̱ mpipyal, oza̱ wop oga ichər aBaal ká̱ aAshera.  
\v 8 Ka̱kul nva̱ ta te, nlak ìgwak aYawe wong ka̱ apal oIsa̱rila, te uza̱ na oza̱ ka̱ ashe awo aKushan-Rishatayim, uponzhi uga aMesopotamiya. Kang oIsa̱rila nəm inok á na ka̱ apal izun pa̱ ina̱nne.  
\v 9 Ǹnyi te, awalang va̱ oIsa̱rila yar ayə́ng uYawe chit te, uza̱ wong ká̱ unəm uga nka̱m ishi ôza̱, uOtniyel, uya aKenat, uɓwakan aKalip uva ka̱m ishi oza̱.  
\v 10 ARuhu aYawe fə́r ka̱ apal ishishi, kang uza̱ sat unəm uga nnap-akwali ôIsa̱rila. Uza̱ fa ga ìkum te, uYawe na uKushan-Rishatayim, uponzhi uga aMesopotamiya ka̱ ashe awuwo. Kang uza̱ nəm igwan ka̱ apal aKushan-Rishatayim.  
\v 11 Te mbin va̱ ta təm ká̱ ikángkáng ìzun ìsəm pa̱ ineɗing, ga chu awalang va̱ uOtniyel uya aKenat ununggwan kú. 
\s1 UEhut 
\p  
\v 12 Ka̱ɗi te, oIsa̱rila nəm nnap-mɓá̱ngɓa̱ng ka̱ mpyal aYawe. Ka̱kul nva̱ ta te, uYawe na igwan ûEglon, uponzhi uga aMowap ka̱ apal oIsa̱rila.  
\v 13 Te uEglon ɓut oAmori ká̱ oAmalek, uza̱ ga ru oIsa̱rila ká̱ ìkum, kang oza̱ ka̱m ìtong iga aKulom.  
\v 14 Te oIsa̱rila nəm inok ûEglon, uponzhi uga aMowap izun pa̱ igba̱pchi ama̱n pa̱ na̱nne. 
\p  
\v 15 Ǹnyi te, awalang va̱ oIsa̱rila yə́ng ûYawe te, uYawe wong ká̱ unəm uga nka̱m ishi ôza̱, uEhut uya aGera, uga akum ìjili aBenjamin, uza̱ unəm uga mpa̱m. OIsa̱rila re na ká̱ imwa pa̱ uza̱ á ga ká̱ ûEglon, uponzhi uga aMowap.  
\v 16 Ǹyangmata̱ te, uEhut ka̱ la ndokchi îshi wò chit nva ká̱ ngba̱k pa̱ mparəm, nwuwang te, ashar pa̱ azəng ká̱ aɓuɓo, kang uza̱ sar ka̱ ìsong iga ari ka̱ avəng oga ìlukwan wò.  
\v 17 Te uza̱ yar imwa va̱ uza̱ ga ká̱ ûEglon, uponzhi uga aMowap. UEglon pa te, unəm va mwal byet.  
\v 18 Nva̱ngva̱ uEhut gba̱l ká̱ nna imwa va̱ chit, te uza̱ re onəm va̱ wur imwa va̱ ta ga.  
\v 19 Ǹnyi te, uza̱ ga chu ka̱ atak oga ichə̀r va̱ mmá kpa ká̱ ipang dat ká̱ aGilgal te, uza̱ ga̱ɓa̱n le ga atak aEglon kang a là á na pa̱, <<Áponzhi, na n yà ká̱ nre nro mbwambwam ka̱kul ɓu.>> 
\p Te uponzhi là ôkpari wò pa̱, <<Ó fa gbai.>> Kang nkpaktak oza̱ fa gbai. 
\p  
\v 20 Te uEhut ga ka̱ atətak, ya uwa ka̱ ntəm ká̱ nkukwa ka̱ atak njul wò nrusokrusok ka̱ nzhi ngga apal, kang a là á na pa̱, <<Na n yà ká̱ nre á ɓu ka̱ atak Inan.>> Uponzhi wong ka̱ apal ìtok iponzhi wò te,  
\v 21 uEhut ga ká̱ awo apəra̱m wò, á tur ndokchi va̱ uza̱ ka̱ ran ka̱ ìsong iga awo ari wò ká̱, kang á kyer na ká̱ ka̱ afu.  
\v 22 Atak nkpan awo ndokchi va̱ ta tar afu kpa nzəng ká̱ ishi, kang oga iya̱m afu fa agbai. UEhut tutur ndokchi va̱ ta ka̱t, kang mpip gún ndokchi va̱ ta.  
\v 23 Te uEhut fa ka̱ ashe agəla̱n, kang nva̱ngva̱ uza̱ fa chit te, uza̱ kùk oga anung nkəlang aponzhi va̱ ta, kang á vərang oza̱. 
\p  
\v 24 Ka̱ nva̱ngva̱ uza̱ ga chit te, ozwal aponzhi ɓa, kang oza̱ ya oga anung nzhi ngga nzhi ngga apal nrusokrusok aponzhi mmá avərangvərang te, oza̱ là pa̱, <<Uwa i yà ka̱ mpəngpəng ka̱ afu nzhi ngga ashe ngga nzhi iponzhi.>>  
\v 25 Oza̱ lok atak ga rwam oza̱, ǹnyi te, awalang va̱ oza̱ ya pa̱ uza̱ bol atak njul va̱ ta ka̱t te, oza̱ yar iya̱m iga mbol anung nzhi oza̱ bol ká̱, kang oza̱ ya unəm uga nzhi oza̱ kú chit ra ka̱ mbin. 
\p  
\v 26 Oza̱ ka̱ yà ka̱ nlok te, uEhut bar chit, uza̱ watar oga ichə̀r va̱ mmá kpa ká̱ ipang, kang a ga aSeyira.  
\v 27 Awalang va̱ uza̱ chu te, uza̱ ɓur agbəshi ka̱ apal aɗuktum aEfrayim. Te oIsa̱rila fəng nzəng ká̱ na ka̱ apal oga aɗuktum va̱ ta, kang uza̱ ləp mpyal ôza̱. 
\p  
\v 28 Uza̱ là ôza̱ pa̱, <<Ó yar nva̱ng mi, ka̱kul uYawe na okpa ìkum wó, onəm oga aMowap chit ka̱ ashe awo wó.>> Te oza̱ fəng ka̱ nvəva̱ng, oza̱ vyat atak mpa̱ng awang aUrdun va dər aMowap, kang oza̱ re unəm uro pa̱ uzəng pa̱ á pa̱l ka̱t.  
\v 29 Ka̱ awalang va̱ ta te, oza̱ gbá̱ng onunggwan oga aMowap ìkalong pa̱ igba̱pchi, nkpaktak oza̱ oga ǹnyi ìkum okamkam. Unəm uro yà bar ka̱t.  
\v 30 Ka̱ nda va̱ ta te, oIsa̱rila nəm igwan ká̱ aMowap, kang mbin va̱ ta təm ká̱ ikángkáng izun ìsəm pa̱ ìna̱nne. 
\s1 UShamgar 
\p  
\v 31 Ka̱ nva̱ng aEhut te, uShamgar uya aAnat ununggwan, uva gbá̱ng oFilisti ìgba̱l pa̱ ìkpa̱ɗing ká̱ ayok aga ngwap iram ina. Uza̱ ka̱m ishi oIsa̱rila kpa. 
\c 4  
\s1 UDebora ká̱ uBarak 
\p  
\v 1 Ka̱ nva̱ng ikú aEhut te, onəm oga aIsa̱rila nəm nnap-mɓá̱ngɓa̱ng ka̱ mpyal aYawe kà̱ɗi.  
\v 2 Te uYawe na oza̱ ka̱ ashe awo aJabin uponzhi uga aKanana, uva ka̱ nnəm iponzhi ka̱ aHazor. USisera, unəm uga mpyal oshozhashozha, ka̱ ntəm ka̱ aHaroshet-Hagoyim.  
\v 3 Te oIsa̱rila yar ayə́ng uYawe, ka̱kul uJabin wa ka̱ yà ká̱ akeke ipəri aga acham ìgba̱l pa̱ ìfangzəngtəng, kang uza̱ pak inok nnyán ká̱ ovan oIsa̱rila chit pa̱ zhalatzhalat ka̱ apal ìzun ìsəm pa̱ iparəm. 
\p  
\v 4 Ǹyangmata̱ te, uDebora uchar aLapidot, uchar uga nka̱m nre ka̱ atak Inan, ka̱ awalang va̱ ta te, uwa uchar uga nnap-akwali ovan oIsa̱rila.  
\v 5 Uza̱ i təm ka̱ vəng akulom aDebora ka̱ ishimshe aRama ká̱ aBetel ka̱ mbin ngga aɗuktum aEfrayim, kang onəm oIsa̱rila i kyén i ga ka̱ na ka̱kul nnap-akwali.  
\v 6 Te uza̱ re nre pa̱ mmá wór uBarak, uya aAbinowam ununggwan ka̱ aKadesh aga aNaftali, kang uza̱ là á na pa̱, <<UYawe, Inan oIsa̱rila, nak á ɓu pa̱, <U ga, na u ɓut onəm ìkalong pa̱ igba̱pchi ka̱ ashe onəm aNaftali ká̱ aZebulun na u ləp mpyal ôza̱ na ó ga aƁam aTabor.  
\v 7 Ǹnyi te, mi dap uSisera, unəm uga mpyal oshozha aJabin, ká̱ oga akeke ipəripəri, ká̱ nggatəkgatək, i ɓa aWang aKishon, te mi ná na ka̱ ashe awo ɓu.> >> 
\p  
\v 8 Te uBarak là á na pa̱, <<A yà pa̱ ɓu ga nzəng ká̱ mi te, mi gəga, ǹnyi te, a yà pa̱ ɓu ga nzəng ká̱ mi ka̱t te, mi ga ka̱t.>> 
\p  
\v 9 Te uDebora là pa̱, <<Nkpak pa̱ n ga nzəng ká̱ ɓu, ǹnyi te, ka̱kul atak nsat va̱ u yar ta̱ te, igwan achen va̱ ta i yà iji ɓu ka̱t, ka̱kul uYawe i na uSisera ka̱ ashe awo achar.>> Te uDebora wong ga aKedesh nzəng ká̱ uBarak.  
\v 10 Ka̱ ta te, uBarak wór onəm aZebulun ká̱ onəm aNaftali, kang onunggwan ìkalong pa̱ igba̱pchi yar nvəva̱ng. UDebora ga nzəng ká̱ na kpa. 
\p  
\v 11 Ǹyangmata̱ te, uHeber unəm oKeni va̱n ishi wò pa̱ ɗi ka̱ ashe oKeni, ka̱ akum ìjili aHobap ugwar aMusa, kang uza̱ la̱p apa̱k wò dat ká̱ ikun aoak ka̱ aZayanannim, va dat ká̱ aKedesh. 
\p  
\v 12 Awalang va̱ mmá là ûSisera pa̱ uBarak uya aAbinowam kyén chit ɓa ga aɓam aTabor,  
\v 13 te uSisera kwap nkpaktak oga akeke ipəri wò iga acham igba̱l pa̱ ìfangzəngtəng, ká̱ nkpaktak onunggwan va̱ nzəng ká̱ na, ɓan ka̱ aHaroshet-Hagoyim ga chu aWang aKishon. 
\p  
\v 14 Te uDebora là uBarak pa̱, <<Wong, ka̱kul nda va ta̱ uYawe na uSisera chit ka̱ ashe awo ɓu. UYawe ga chit ka̱ mpyal ɓu ka̱t ɗò? Te uBarak fə́r ka̱ apal aɓam aTabor ká̱ onunggwan ìkalong pa̱ igba̱pchi nzəng ká̱ na.  
\v 15 Te uYawe nak uSisera zwar ká̱ nkpaktak oga akeke ipəripəri, ká̱ nkpaktak onəm oga lung ìkukum ka̱ mpyal aBarak ka̱ atak ndokchi. Kang uSisera fə́r ka̱ apal akeke ipəri wò chə́r ká̱ ashar. 
\p  
\v 16 Kang uBarak wà nva̱ng oga akeke ipəri ká̱ onəm oga nlung ìkukum ga chu aHaroshet-Hagoyim, kang mmá gbá̱ng nkpaktak nggatək aSisera tak ká̱ ndokchi, unəm uro yà lar ka̱t. 
\p  
\v 17 Te uSisera chə́r ká̱ ashar ga aghal aJayel, uchar aHeber, unəm oKeni, ka̱kul ntəm ikángkáng nna yà ka̱ ishimshe aJabin, uponzhi uga aHazor ká̱ nzhi aHeber, unəm oKeni. 
\p  
\v 18 Te uJayel fa gwang uSisera kang a là á na pa̱, <<Ɓa, ɓa ashe aghal mi, anəm uga nzhi mi, kang ayər a nəm ɓu ka̱t.>> Te uza̱ ga ashe aghəghal, kang uza̱ gún na ká̱ agodò. 
\p  
\v 19 USisera là á na pa̱, <<N chal ɓu, na ndəng á mi ká̱ pa̱ ɗa̱p n wá, ka̱kul ndəng gba̱l mi gba̱l.>> Te uza̱ bol izəmɓa̱r iga nnak mbyal, uza̱ na mbyal á na wá, kang uza̱ gún na. 
\p  
\v 20 Te uza̱ là á na pa̱, <<Sat ka̱ anung asa̱l aga ntar aghal va̱ ta̱, a yà pa̱ unəm uro á ɓa á ɓəp ɓu pa̱,<Unəm uro uwa yà ka̱ ta̱ ɗò?> Te wa là á na pa̱ <O'o.> >> 
\p  
\v 21 Ǹnyi te, uJayel, uchar aHeber, yar iya̱m iga mpak aghal ká̱ nka̱m ala ka̱ awo wò. Kang uza̱ mwom ga atətak, ga pak á na ka̱ mbe achwang ga fu mbin, ka̱kul nda gba̱l na chit, ka̱ atak nrwam ìzər nchə́r va̱ uza̱ chə́r á. Te uza̱ kú. 
\p  
\v 22 Nva̱ uBarak ka̱ mɓak nva̱ng aSisera te, uJayel fa gwang na kang á là á na pa̱, <<Ɓa na n nyám unəm va̱ á ɓu, ɓu ram á.>> Te uBarak tar ashe aghəghal, kang uza̱ ya uSisera kú chit ra, ká̱ iya̱m iga mpak aghal ka̱ mbe achəchwang. 
\p  
\v 23 Ká̱ nda va̱ ta te, Inan na igwan ônəm oga aIsa̱rila ka̱ apal aJabin, uponzhi uga aKanana.  
\v 24 Kang ovan oga aIsa̱rila pak nnəm igwan kam ka̱ apal aJabin, uponzhi uga aKanana, a ga chu awalang va̱ oza̱ zhì na. 
\c 5  
\s1 Nnap-nshì aDebora 
\p  
\v 1 Ka̱ ilum va̱ ta te, uDebora ká̱ uBarak uya aAbinowam ununggwan shì nnap-nshì va̱ ta̱ pa̱, 
\q1  
\v 2 <<Awalang va̱ onəm oga mpyal oIsa̱rila yar atak nsat oza̱, 
\q2 awalang va̱ onəm na ishi oza̱ ka̱ ashe mma̱n oza̱ te, 
\q2 ashep təm aji aYawe. 
\b  
\q1  
\v 3 Ó fe mmawó oponzhi, ó gwong achwang mmawó ovan oponzhi, 
\q2 mmami, à, mi shì nnap kpa ûYawe, 
\q2 mi shì nnap-nshì ashep ûYawe, Inan oIsa̱rila. 
\b  
\q1  
\v 4 <<ÁYawe, ka̱ awalang va̱ u fa ka̱ aSeyir, 
\q2 awalang va̱ u fa ka̱ mbin aEdom te, 
\q1 apambin yənggət, apal apaɓur zùk, 
\q2 oga ìlulu zùk ndəng. 
\q1  
\v 5 Oga aɓam yənggət ka̱ mpyal aYawe uga aSinayi, 
\q2 ka̱ mpyal aYawe, Inan oIsa̱rila. 
\b  
\q1  
\v 6 <<Ka̱ ashe nra aShamgar uya aAnat ununggwan, 
\q2 ka̱ ashe nra aJayel te, mmá re ngwol oga anang asa̱l, 
\q2 kang onəm oga nnəm achen wòl oga avan asa̱l aga ashe nzam. 
\q1  
\v 7 ONəm oga ntəm ka̱ ashe ivan ìtong oIsa̱rila yà ka̱ ashishe lap ka̱t, 
\q2 oza̱ yà ka̱ ashishe ka̱t, a ga chu awalang va̱ mmami, uDebora n wong, 
\q2 n wong wa anang ka̱ ashe aIsa̱rila. 
\q1  
\v 8 Awalang va̱ oIsa̱rila yak oga inan ìpipye te, 
\q2 ìkum ɓa fa ka̱ oga anung asa̱l ìtong oza̱. 
\q1 Ǹnyi te, mmá ya nggwanggwang nro, ka̱t te, aɓar aro 
\q2 ka̱ ashe onəm oga nlung ìkum ìkalong ìsəm pa̱ ineɗing ka̱ aIsa̱rila ka̱t. 
\q1  
\v 9 Ìgwak mi ga ka̱ atak onəm oga mpyal ìkum oIsa̱rila, 
\q2 ka̱ atak onəm va na ishi oza̱ ká̱ nchang ìgwak. 
\q2 Ashep təm aji aYawe. 
\b  
\q1  
\v 10 <<Mmawó va̱ ó kwak oga azhaki achar aləfər, 
\q2 mmawó va̱ ó təm ka̱ apal oga agodò nkongkong 
\q2 kang mmawó va̱ ó chen ka̱ apal asa̱l, 
\q1 ó nak ishi  
\v 11 ká̱ achu onəm oga nshì nnap ka̱ anung ndəng nka̱pka̱p. 
\q2 Oza̱ ka̱ nshal nnap ka̱ apal igwan aYawe, 
\q2 igwan va onəm oga ntəm ka̱ ivan ìtong ka̱ ashe aIsa̱rila nəm á. 
\b  
\q1 <<Te onəm aYawe 
\q2 fa ga oga anung asa̱l ìtong oza̱. 
\q1  
\v 12 Yenda̱l, yenda̱l, aDebora. 
\q2 Yenda̱l, yenda̱l, na u shì nnap. 
\q1 Wong, aBarak, 
\q2 wur izwal ká̱ okpa ìkum ɓu, áya aAbinowam. 
\b  
\q1  
\v 13 <<Te aɓo onəm chumchum va̱ re 
\q2 á ɓa atak onəm oga mpyal, 
\q1 onəm aYawe fə́r vang atak mi, 
\q2 ka̱kul nlung onəm kamkam. 
\q1  
\v 14 Oro wong ka̱ aEfrayim, ova alə̀ng oza̱ ka̱ aAmalek kang a vàng, 
\q2 akum ìjili aBenjamin oma yà ka̱ ashe onəm va̱ yar nva̱ng ɓu. 
\q1 Onəm oga mpyal ìkum ka̱ aMakir fə́r vang, 
\q2 ka̱ aZebulun te, onəm oga nkpán idari anəm uga mpyal ɓa. 
\q1  
\v 15 Onəm oga mpyal aIsaka oma yà nzəng ká̱ uDebora, 
\q2 nnandər, onəm aIsaka oma ka̱ yà nzəng ká̱ uBarak, 
\q2 oza̱ yar nvəva̱ng fə́ng ga ashe aba̱nda̱m. 
\q1 Ǹnyi te, ka̱ ashe akum ìjili aRuben te, anung gwar ka̱t. 
\q1  
\v 16 Iza̱ nak kang ó təm ka̱ ashe afo itam yà? 
\q2 ka̱kul pa̱ na ó fe mɓur ayər aga ngwór iya̱mkang ɗò? 
\q1 Ǹnyi te, ka̱ ashe akum ìjili aRuben te, anung gwar ka̱t. 
\q1  
\v 17 Akum ìjili aGileyat təm ka̱ agwong aUrdun, 
\q2 sang kang akum ìjili aDan təm ka̱ atak oga agirgi ndəng ji oza̱ yà? 
\q1 UAsher uwa ka̱ ntəm ka̱ anung ìwa, 
\q2 uza̱ təm ka̱ atak mpa̱ng oga agirgi ndəng. 
\q1  
\v 18 Onəm aZebulun ká̱ uNaftali jiwò te, 
\q2 oza̱ yang ká̱ irirì oza̱ fa agbagba ìkum. 
\b  
\q1  
\v 19 <<Oponzhi ɓa, oza̱ nəm ìkum, 
\q2 oponzhi oKanana lung ìkum. 
\q1 Ka̱ aTayanak, ka̱ atak oga ndəng ngga aMegido, 
\q2 oza̱ wur iya̱m iga ngwur ka̱ atak ìkum ká̱ aazurfa ka̱t. 
\q1  
\v 20 Ka̱ apaɓur oga izhan lung ìkum, 
\q2 ka̱ ashe oga anang asa̱l oza̱, oza̱ lung uSisera. 
\q1  
\v 21 Awang aKishon wur oza̱ ga ká̱, 
\q2 awang agbakgbak va̱ ta, awang aKishon. 
\q2 Chen ga, áirirì mi, yà ká̱ ikam. 
\q1  
\v 22 Te ashar ipəri i chen i nap 
\q2 mmá ka̱ nfe nnáp ndong ashar oza̱ i chen ká̱ ngghan ka̱kul nkam oga ashar oza̱. 
\q1  
\v 23 <<UMa̱leka aYawe là pa̱, <vyap aMerot>, 
\q2 vyap onəm oga ntəm ka̱ ashishe pa̱ gənggəng, 
\q1 ka̱kul oza̱ ɓa pa̱ na ó ka̱mshi uYawe ka̱t, 
\q2 pa̱ na ó ka̱mshi uYawe ka̱ nlung onəm kamkam ka̱t. 
\b  
\q1  
\v 24 UJayel wà ká̱ nnap-nnəna̱n ji pa̱ kpaktak ka̱ ashe ochar, 
\q2 uchar aHeber unəm oKeni, 
\q2 uwà ká̱ nnap-nnəna̱n ji ka̱ ashe ochar oga ntəm ka̱ ashe aghal á. 
\q1  
\v 25 USisera ɓəp ndəng te, uza̱ na mbyal á na. 
\q2 Uza̱ ɓa ká̱ mbyal va̱ ká̱ mmì á na ka̱ ashe ìkpang onəm chumchum. 
\q1  
\v 26 Uza̱ yar acham aga mpak aghal ka̱ awo, 
\q2 uza̱ kpán nka̱m ala anəm uga inok ka̱ awo ari, 
\q1 uza̱ ləp uSisera, uza̱ chwan ishi á na, 
\q2 uza̱ chwan ishishi, kang a kyer na ka̱ mbe achwang. 
\q1  
\v 27 Uza̱ kwangtal ka̱ mpyal achar va̱ ta, 
\q2 uza̱ ru, uza̱ ra pa̱ kwak ka̱ ta, 
\q1 uza̱ kwangtal ka̱ mpipyal, uza̱ ru, 
\q2 ka̱ atak va̱ uza̱ kwangtal kà̱, uza̱ ru kú. 
\b  
\q1  
\v 28 <<Unang aSisera dər atak ka̱ mɓol ayə́r nzhi, 
\q2 uza̱ yə́ng ka̱ mɓol ayə́r nzhi va̱ ta pa̱, 
\q1 iza̱ nak kang oga akeke ipəripəri kali ká̱ mɓa yà? 
\q2 Iza̱ nak kang nva̱ng ashar oga akeke ipəripəri kali ka̱ mɓa yà? 
\q1  
\v 29 Ovanchəchar va̱ tàn ji na ama̱n á na pa̱, 
\q2 nnandər, uza̱ pak inok nlà îshi wò pa̱, 
\q1  
\v 30 <Oza̱ ka̱ mmwo kang oza̱ i kap iya̱m iga ngwur ka̱ atak ìkum ka̱t ɗò? 
\q2 Nza̱ unəm nggo ya uyenchar pa̱ uzəng, ka̱t te pa̱ oparəm, 
\q1 ilukwan iɓyenɓyen iga mbwai ûSisera wa iya̱m iga ngwur ka̱ atak ìkum, 
\q2 ilukwan iɓyenɓyen ira̱pra̱p iga mbwai, 
\q1 ilukwan iɓyenɓyen ira̱pra̱p iga mbwai va ji ka̱kul nsham isham 
\q2 nkpaktak oga iya̱m va̱ ta̱ iya̱m iga ngwur ka̱ atak ìkum á?> 
\b  
\q1  
\v 31 <<Re nkpaktak okpa ìkum ɓu á zhì, áYawe. 
\q2 Ǹnyi te, re nkpaktak okpa ɓu a yà wa alum 
\q2 awalang va i fa ka̱ ashe ikam wò.>> 
\q1 Te mbin təm ká̱ ikángkáng ìzun ìsəm pa̱ ineɗing. 
\c 6  
\s1 UGidiyon 
\p  
\v 1 Kang ovan oIsa̱rila nəm nnap-mɓá̱ngɓa̱ng ka̱ mpyal aYawe, te uYawe na oza̱ ka̱ ashe awo oMidiyan ìzun pa̱ ifangshat.  
\v 2 Ka̱kul oMidiyan nəm igwan ka̱ apal oIsa̱rila te, onəm oga aIsa̱rila ɗa̱mshi oga atak mbwam îshi oza̱ ka̱ ashe oga mbagar aɓam, ká̱ oga agba̱k, ká̱ oga atak mbwam ngga akamsəlang.  
\v 3 Awalang va pa̱ kpaktak oIsa̱rila i suk iya̱m chit te, oMidiyan, ká̱ oAmalek, ká̱ onəm va̱ ka̱ asa̱l nfa alum i ɓa i ru oza̱ ká̱ ìkum.  
\v 4 Oza̱ ləp apa̱k ka̱ ashe mbin va̱ ta, kang oza̱ vyap iya̱m nsuk ga chu aGaza, oza̱ wur itam, ká̱ ina, ká̱ oga azhaki, kang oza̱ re iya̱m iro ka̱ ashe aIsa̱rila ka̱t.  
\v 5 Oza̱ ɓa ká̱ iya̱mkang, ká̱ oga aghal oza̱, yə́l wa mban ìkum. Oza̱ ká̱ nkpaktak oga alakəmi oza̱, yə́l yà ká̱ nkung ka̱t, táng ashe mbin va̱ ta pa̱ na ó vyap na.  
\v 6 OMidiyan nak nkun ônəm oga aIsa̱rila pa̱ makmak, a nak te, oza̱ yə́ng ûYawe pa̱ á ka̱mshi wó. 
\p  
\v 7 Ka̱ nva̱ngva̱ ovan oIsa̱rila yə́ng ûYawe chit ka̱kul oMidiyan te,  
\v 8 uYawe re nre ôza̱ ká̱ unəm uga nka̱m nre ka̱ atak Inan uva là ôza̱ pa̱, <<Iya̱m va ta̱ uYawe, Inan oIsa̱rila là. N fa ká̱ wó ka̱ aMasar, n fa ká̱ wó ka̱ mbin izwal.  
\v 9 N fa ká̱ wó ka̱ ashe awo onəm oga aMasar, kang n fa ká̱ wó ka̱ ashe awo nkpaktak onəm oga nyán ká̱ wó. M ɓak oza̱ le ka̱ mpyal wó, kang n na mbin oza̱ á wó.  
\v 10 N là á wó pa̱, <Mmami na uYawe, Inan wó, kang ó wop oga inan oAmori ova mmawó ka̱ ntəm ka̱ ashe mbin oza̱ ka̱t.> Ǹnyi te, ó gwong achwang ka̱ mi ka̱t.>> 
\p  
\v 11 Te uma̱leka aYawe fa təm ka̱ avəng ikun aoak ka̱ aOfəra, iva iji aJowash unəm uga akum aAbiyezer, atak va uyiyen uGidiyon ka̱ yà ka̱ mpək ìzangzəng ka̱ atak nkáng ìba̱ngba̱ng, ka̱kul pa̱ na o bwam, le kang oMidiyan á ya ka̱t.  
\v 12 Awalang va̱ uma̱leka aYawe nyám ishi wò ûGidiyon te, á là á na pa̱, <<UYawe uwa yà nzəng ká̱ ɓu, áyennunggwan ìkum.>> 
\p  
\v 13 Te uGidiyon na ama̱n á na pa̱, <<Kusuk, ánəm uga nzhi mi, a yà pa̱ uYawe uwa ya nzəng ka̱ yi, te sang kang oga nnap va̱ ta̱ i yà yi yà? Te oga nnənap ngga nɗaktak va̱ che, nna opo yi ka̱ shet á yi pa̱, uYawe uwa fa ká̱ wó ka̱ aMasar yà? Kang ǹyangmata̱ te, uza̱ mandar yi chit, kang uza̱ na yi ka̱ ashe awo oMidiyan.>> 
\p  
\v 14 Te uYawe ga̱ɓa̱n là á na pa̱, <<Ga ka̱ ashe nkam ɓu va̱ ta na u ka̱m ishi oIsa̱rila ka̱ ashe awo oMidiyan. Mmami na ka̱ nre ɓu ka̱t ɗò?>> 
\p  
\v 15 Te uGidiyon na ama̱n pa̱, <<Kusuk, ánəm uga nzhi mi, mi ka̱m ishi ôIsa̱rila wa sang yà? Dər, ka̱ ashe akum ìjili aManase te, akum mi na kam ka̱t, kang ka̱ ashe nzhi apo mi te mmami na n nyen ji.>> 
\p  
\v 16 Te uYawe na ama̱n pa̱, <<Mi yà nzəng ká̱ ɓu, kang ɓu gbá̱ng nkpaktak onəm oMidiya unəm uro yà i lar ka̱t.>> 
\p  
\v 17 UGidiyon na ama̱n pa̱, <<A yà pa̱ ǹyangmata̱ mi ya nka̱m ishi ya ka̱ mpyal ɓu te, nyám ìpir nnàp á mi na n nyi pa̱, mmaɓu na ka̱ nlà nnap ká̱ mi pa̱ wàt.  
\v 18 Kang wa re atak va̱ ta̱ chit ka̱t, n chal ɓu, n ga n le m ɓa ká̱ imwa mi kang, mi nak ka̱ mpyal ɓu.>> Te Uza̱ là pa̱, <<Mi lok yà ɓu le kang.>> 
\p  
\v 19 Te uGidiyon tar ashe, kang a ɗa̱mshi ìzhe iya iɓəl, ká̱ nzəngkəng va yà ká̱ anyer ka̱t nva ma nəm ka̱ mma̱k ikpang iga mmà iya̱m pa̱ ìzəng. Uza̱ nak ìzhe ka̱ ashe anap, kang mməmal ka̱ ashe ngbət, te uza̱ fa ká̱ á na ka̱ avəng ikun aoak, uza̱ yichi á na. 
\p  
\v 20 Te uma̱leka Inan là á na pa̱, <<Yar ìzhe va̱ ta ká̱ nzəngkəng ngga nyà ká̱ anyer ka̱t, nak oza̱ ka̱ apal ipang va̱ ta̱, te kwonda̱l mmal ka̱ apal oza̱.>> Te uGidiyon nəm wanta.  
\v 21 Te uma̱leka aYawe dok ìzhe va̱ ta ká̱ nzəngkəng ngga nyà ká̱ anyer ka̱t ká̱ ishi ìdari va̱ ka̱ awuwo. Te apər fa ká̱ ìpang á ri ìzhe va̱ ta, ká̱ nzəngkəng. Te uma̱leka aYawe lar ka̱ mpipyal.  
\v 22 Awalang va̱ uGidiyon nyi chit pa̱ uma̱leka aYawe te, uza̱ là pa̱, <<Á làk ká̱ mi chit, áNəm uga Nzhi, uYawe. N ya uma̱leka aYawe chit ìwu ká̱ ìwu.>> 
\p  
\v 23 Te uYawe là á na pa̱, <<Yà ká̱ nra ìgwak, kang ayər a nəm ɓu ka̱t, ɓu yà ká̱ nkú ka̱t.>> 
\p  
\v 24 Te uGidiyon me atak aga nshì iya̱m awop ûYawe ka̱ ta, kang uza̱ wór pa̱, UYawe uwa ikángkáng. Nda ta̱ nna yà ka̱ aOfəra, ava aga akum ìjili aAbiyezer. 
\p  
\v 25 Ká̱ izwam va̱ ta te, uYawe là á na pa̱, <<Kpán akut apo ɓu, apəpar, ka̱ ashe iya̱m nkəkang ava ìzun pa̱ ifangshat. Shin atak nshì iya̱m awop ìchər aBaal aji apo ɓu, kang ɓu kyen ndar aAshera va̱ ka̱ ngbəgba̱k.  
\v 26 Te me atak nshì iya̱m awop ava mal ûYawe, Inan ɓu ká̱ ípang ka̱ apal atak mbwam ngga aɗuktum va̱ ta̱. Te yar akut aga aparəm na iya̱m inana iga nshì ká̱ ká̱ akun aAshera va̱ u kyen á.>> 
\p  
\v 27 Te uGidiyon kpa̱k onəm pa̱ ogba̱pchi ka̱ ashe ozwal wò, uza̱ nəm wa nva uYawe là á na. Te ka̱kul pa̱ uza̱ ka̱ nnəm ayər nzhi apo wò ká̱ onəm oga ìtong, te uza̱ nəm inok va̱ ta ká̱ alum ka̱t, uza̱ nəm ká̱ izwam. 
\p  
\v 28 Awalang va̱ onəm oga ìtong wong ká̱ ìpin te, oza̱ ya mmá shin atak nshì iya̱m awop ìchər aBaal chit, kang oga ndar aAshera va̱ ka̱ ngbəgba̱k te, mmá kyen chit tak, kang akut aga parəm mmá yichi chit ka̱ apal atak nshì iya̱m awop va̱ mmá me á. 
\p  
\v 29 Te oza̱ ɓəp owan oza̱ pa̱, <<Uda nəm iya̱m va̱ ta̱ yà? Kang nva̱ngva̱ oza̱ gbap chit, te mmá là oza̱ pa̱, uGidiyon uya aJowash ununggwan wa nəm iya̱m va̱ ta. 
\p  
\v 30 Te onəm oga ìtong là ûJowash pa̱, <<Ɓa ká̱ uyen ɓu, na uza̱ á kú, ka̱kul uza̱ shin atak nshì iya̱m awop ìchər aBaal, kang uza̱ kyen oga ndar aAshera va̱ ka̱ ngbəgba̱k tak.>> 
\p  
\v 31 Ǹnyi te, uJowash na ama̱n n̂kpaktak onəm va̱ ka̱ nfa iya̱mkak ká̱ wò pa̱, <<Ó lung nnap aBaal na ɗò? Ka̱t te ó ka̱m ishishi ka̱m ɗò? Unəm va̱ ka̱ nlung nnənap te, re mmá gba̱l na ká̱ ìpin na byet. A yà pa̱ uBaal inan yà nna̱n te, re uza̱ á lung îshi wò, ka̱kul pa̱ unəm uro shin atak nshì iya̱m awuwop chit tak.>>  
\v 32 Ka̱kul pa̱ uGidiyon shin atak nshì iya̱m awop aBaal chit te, oza̱ na aɗin á na pa̱, uJerup-Baal, ipipir pa̱, <<Re uBaal á lung na.>> 
\p  
\v 33 Ǹyangmata̱ te, nkpaktak oMidiyan, ká̱ oAmalek, ká̱ onəm oga asa̱l nfa alum gwang ishi kang a pa̱ng aUrdun, ləp apa̱k ka̱ mba̱nda̱m aJezireyel.  
\v 34 Te aRuhu aYawe vàng ka̱ apal aGidiyon, kang uza̱ ɓur agbəshi, te mmá wór akum ìjili aAbiyezer ɓut kang oza̱ yar nvəva̱ng.  
\v 35 Uza̱ re nre ká̱ onəm oga nre ka̱ ashe nkpaktak aManase, kang oza̱ wór ɓut, oza̱ yar nvəva̱ng kpa. Kang uza̱ re nre ká̱ onəm oga nre ka̱ atak onəm aAsher, ká̱ uZebulun, ká̱ uNaftali, te oza̱ fa ga gwang oza̱. 
\p  
\v 36 Kang uGidiyon là uYawe pa̱, <<A yà pa̱ ɓu nəm inok ká̱ mi ɓu ka̱m ishi aIsa̱rila ka̱m, wa nva̱ ka̱ u là te,  
\v 37 dər, mi nak awulu ka̱ atak mpək iya̱m. A yà pa̱ ìmimyang a ra ka̱ apal awulu va̱ ta na ká̱ nkukwa, kang nkpaktak mbin wuwom te, mi nyi pa̱ ɓu nəm inok nəm ká̱ mi ɓu ka̱m ishi aIsa̱rila ka̱m, wa nva̱ ka̱ u là á.>>  
\v 38 Te wa nnà ta á yà. UGidiyon wong ká̱ ìpin ikpa̱kkpa̱k ká̱ iɓotak te uza̱ káng ìmimyang iga izər awulu va̱ ta, kang ndədəng yə́l ìkpang pa̱ ìzəng. 
\p  
\v 39 Te uGidiyon là Înan pa̱, <<Kang wa mən ìkum ká̱ mi ka̱t. Re mi n là nnap nva̱ng pa̱ nzəng byet kang, re mi m ma nva̱ng pa̱ nzəng kà̱ɗi ká̱ awulu, re awulu na a wom byet, te re ìmimyang a ra ka̱ mbin pa̱ kpaktak.>>  
\v 40 Inan nəm wanta ká̱ izwam va̱ ta, ka̱kul awulu na təm awomwom byet, kang mbin pa̱ kpaktak te, á ra ìmimyang. 
\c 7  
\s1 UGidiyon ri oMidiyan ká̱ ìkum 
\p  
\v 1 Te uJerup-Baal, uwa uGidiyon á, wong ká̱ iɓotak ká̱ nkpaktak onəm va̱ nzəng ká̱ na, oza̱ ga ləp apa̱k dat ká̱ ndəng mɓəlɓəl ngga aHarot. Kang apa̱k oMidiyan ka̱ asa̱l mpal oza̱, ka̱ ashe aba̱nda̱m va̱ da̱t ká̱ aɗuktum aMoreh.  
\v 2 Te uYawe là ûGidiyon pa̱, <<Onəm va̱ nzəng ká̱ ɓu yəl byet. Mi yà ká̱ nna oMidiyan ka̱ ashe awo ôza̱ ka̱t, le kang oIsa̱rila a ləp ìkwoksok pa̱, <i ri oza̱ ká̱ ìkam yi> ka̱t.  
\v 3 Ǹyangmata̱ te, là ônəm pa̱, unəm va̱ pa̱ káp ayər ka̱ nnəm na kang uza̱ ka̱ ntán te, uza̱ á le, á re aɓam aGileyat na uza̱ á ga iya̱m wò.>> Te onəm ìkalong ìsəm pa̱ iparəm ama̱n pa̱ parəm le, kang aɓo onəm ìkalong pa̱ igba̱pchi tong. 
\p  
\v 4 Ǹnyi te, uYawe là ûGidiyon pa̱, <<Onəm va̱ ta̱ oma yəyəl. Fa ga ká̱ oza̱ ka̱ atak ndəng, na m ma oza̱ á ɓu ka̱ ta, kang uvəngva̱ n là á ɓu pa̱, i ga ká̱ ɓu, te uza̱ i ga ká̱ ɓu, kang uvəngva̱ pa̱ kpaktak n là á ɓu pa̱, i ga ká̱ ɓu ka̱t, te uza̱ i ga ka̱t.>> 
\p  
\v 5 Te uGidiyon fa ga ká̱ onəm va̱ ta ka̱ atak ndəng, kang uYawe là á na pa̱, <<Ven onəm va̱ i yep ndəng ká̱ aɓələm wa ìva á le pa̱ɗi ka̱ izər onəm va í ɓəram ká̱ irəng kang i wá.>>  
\v 6 Iyəl onəm va̱ kpa̱k ndəng ká̱ awo kang a wá, i yep wa iva te, oza̱ igba̱l pa̱ ishatɗing, aɓoshi onəm pa̱ kpaktak te, a ɓəram ká̱ irəng kang a wá ndəng. 
\p  
\v 7 Te uYawe là ûGidiyon pa̱, <<Ká̱ onəm oga igba̱l pa̱ ishatɗing va ta̱ ova yep ndəng te, mi ka̱m ishi wó, kang mi na oMidiyan ka̱ ashe awo wó. Re aɓo oza̱ á ga nzhi.>>  
\v 8 Te uGidiyon re nkpaktak aɓo oIsa̱rila le ga nzhi, ǹnyi te, uza̱ kpan oga igba̱l pa̱ ishatɗing va̱ ta. Oza̱ ka̱m oga iya̱m-nrì ká̱ oga agbəshi ka̱ awo owan oza̱ va̱ le. 
\p Ǹyangmata̱ te, apa̱k oMidiyan ka̱ avəng oza̱ ka̱ mba̱nda̱m. 
\p  
\v 9 Ká̱ izwam va ta uYawe là ûGidiyon pa̱, <<Wong, ga ru apa̱k oza̱ ká̱ ìkum, ka̱kul n na chit ka̱ ashe awo ɓu.  
\v 10 Kang a yà pa̱ ayər ngga nru oza̱ ká̱ ìkum ka̱ nnəm ɓu te, fa ga ashe apa̱k va̱ ta nzəng ká̱ uPura uzwal ɓu,  
\v 11 na u fe iya̱m va̱ oza̱ ka̱ nləlà. Ka̱ nvəva̱ng te, ìgwak i kam á ɓu pa̱ u ru apa̱k oza̱ ká̱ ìkum.>> Te uza̱ fə́r vang nzəng ká̱ uPura uzuzwal ga chu aswari apa̱k va̱ ta.  
\v 12 Kang oMidiyan, ká̱ oAmalek, ká̱ nkpaktak onəm oga asa̱l nfa alum ra məl ka̱ ashe aba̱nda̱m yə́l wa mban ìkum. Oga alakəmi oza̱ yə́l yà ká̱ nkung ka̱t, wa nva ashishiri yə́l ka̱ anung awang á. 
\p  
\v 13 Ka̱ awalang va̱ uGidiyon ɓa chu ka̱ ta te, uza̱ fe unəm uro i shal izwam ûwan wò i là pa̱, <<Dər, n lar izwam, te n ya mɓit nzəngkəng ibəshi i ɓəndəng i tar ashe apa̱k oMidiyan. Á ləp aghal va̱ ta ru ga̱ɓa̱n ga nggərgang, kang a shin.>> 
\p  
\v 14 Te ukpəkpa na ama̱n á na pa̱, <<Iya̱m ata̱, iya̱m iro ka̱t, ndokchi aGidiyon uya aJowash ununggwan, unəm oIsa̱rila. Inan na oMidiyan chit ká̱ nkpaktak apa̱k ka̱ ashe awuwo.>> 
\p  
\v 15 Awalang va̱ uGidiyon fe nshal izwam va̱ ta ká̱ nlà ìpipir te, uza̱ kuchi shep Inan. Te uza̱ le apa̱k oIsa̱rila kang uza̱ là pa̱, <<Ó wong, ka̱kul uYawe na apa̱k oMidiyan chit ka̱ ashe awo wó.>>  
\v 16 Kang uza̱ kap onunggwan oga igba̱l pa̱ ishatɗing va̱ ta idongkong pa̱ ishatɗing, te uza̱ na agbəshi n̂kpaktak oza̱ ka̱ awo, ká̱ ìɗyeri ilakchi, oga apitila na chwat ka̱ ashe oza̱. 
\p  
\v 17 Te uza̱ là ôza̱ pa̱, <<Ó dər mi, iya̱m va̱ mi nəm te, ó nəm kpa. Awalang va̱ mi ga mi chu nkur apa̱k te, iya̱m va̱ mi nəm, te ó nəm wa nnà ta kpa.  
\v 18 Awalang va̱ mmami ká̱ nkpaktak onəm va̱ nzəng ká̱ mi a ɓur oga agbəshi yi te, ó ɓur oga agbəshi wó kpa ka̱ nza̱ nkpaktak ngba̱k apa̱k va̱ ta nggo, ó là pa̱,<Ka̱kul aYawe kang ka̱kul aGidiyon.> >> 
\p  
\v 19 Te uGidiyon ká̱ onunggwan oga igba̱l pa̱ ìzəng va̱ nzəng ká̱ na ga chu nkur apa̱k va̱ ta ká̱ ishimshe izwam, yà nna mmá pa̱ng onəm oga mpángchí atak chit gbà̱ng nva̱ng ka̱t. Te oza̱ ɓur oga agbəshi oza̱, kang a chwan oga ìɗyeri va̱ ka̱ oga awo oza̱.  
\v 20 Idongkong iga ishatɗing va̱ ta ɓur oga agbəshi kang oza̱ chwan oga ìɗyeri. Oza̱ kpán oga apitila ka̱ awo apəra̱m oza̱, kang oga agbəshi ka̱ awo ari oza̱ ka̱kul mɓur, i nəm achu pa̱, <<Ndokchi ka̱kul aYawe, kang ka̱kul aGidiyon.>>  
\v 21 Nza̱ unəm nggo yar atak nsat wò gáng apa̱k, te nkpaktak oMidiya zəp nchəng. Oza̱ i nə́m achu kang i chəng. 
\p  
\v 22 Awalang va̱ onəm aGidiyon ɓur oga agbəshi aga igba̱l pa̱ ishatɗing va̱ ta te, uYawe nak oMidiyan va̱ ka̱ ashe apa̱k va̱ ta le i lung owan oza̱ ká̱ ndokchi. Oza̱ chəng ga chu aBet-Shita va dər asa̱l aZerera, lyam ga chu aswari aAbel-Mehola va dat ká̱ aTabat.  
\v 23 Te mmá wór oIsa̱rila fa ka̱ ashe aNaftali, aAsher, kang ka̱ ashe nkpaktak aManase ɓut, kang oza̱ ɓak oMidiyan.  
\v 24 UGidiyon re nre ká̱ onəm oga nre ka̱ ashe nkpaktak mbin ngga aɗuktum aEfrayim pa̱, <<Ó fa ìkum ká̱ oMidiyan, na ó gəl asa̱l ka̱ atak oga ndəng aUrdun ka̱ mpyal oza̱ á ga á chu aBet-Bara.>> 
\p Te mmá wór nkpaktak onunggwan aEfrayim fa, kang oza̱ gəl asa̱l ka̱ atak oga ndəng aUrdun ga chu aBet-Bara. 
\p  
\v 25 Kang oza̱ kpán oponzhi oMidiyan pa̱ oparəm kpa, uOrep ká̱ uZeyep. Oza̱ gba̱l uOrep ka̱ ìpang aOrep, kang oza̱ gba̱l uZeyep ka̱ atak nkáng ndəng ìba̱ngba̱ng aZeyep. Te oza̱ ɓak oMidiyan, kang oza̱ ɓa ká̱ ishi aOrep ká̱ uZeyep ûGidiyon ka̱ gwong awang aUrdun. 
\c 8  
\s1 UZeba ká̱ uZalmuna 
\p  
\v 1 Te onəm oga aEfrayim là ûGidiyon pa̱, <<Sang kang u nəm á yi wa nta̱, u wór yi ka̱t awalang va̱ mmaɓu ka̱ nlung ìkum ká̱ oMidiyan ka̱t yà?>> Kang oza̱ ra̱n ká̱ na pa̱ gənggəng. 
\p  
\v 2 Te uGidiyon na ama̱n ôza̱ pa̱, <<Iza̱ n nəm va̱ ji iji wó yà? Oga iya̱m ìchakchak ìba̱ngba̱ng aEfrayim ɓyen ji iya̱m mɓən iga ìba̱ngba̱ng aAbiyezer ka̱t ɗò?  
\v 3 Inan na oponzhi oMidiyan uOrep ká̱ uZeyep ka̱ ashe awo wó na. Iza̱ iya̱m va̱ n nəm va ji ivəngva̱ ó nəm yà?>> Nna chit te, nlak ìgwak oza̱ rusok ɗak. 
\p  
\v 4 Te uGidiyon ga aUrdun kang a pa̱l, uza̱ ká̱ onunggwan igba̱l pa̱ ishatɗing va̱ nzəng ká̱ na, oza̱ bəlak chit, ká̱ nna te, oza̱ ga mpyal ká̱ nwà nva̱ng okpa ìkum oza̱.  
\v 5 Kang uza̱ là ônunggwan oga aSukkot pa̱, <<Kusuk, ó na nzəngkəng ônəm mi va̱ ta̱ va̱ ka̱ nva̱ng mi á, ka̱kul oza̱ bəlak chit, kang na mmami ka̱ mwà nva̱ng aZeba ká̱ uZalmuna, oponzhi oMidiyan.>> 
\p  
\v 6 Ǹnyi te, onəm oga mpyal aSukkot là pa̱, <<U kpán uZeba ká̱ uZalmuna chit ka̱ ashe awo ɓu ɗò? Ka̱kul iza̱ kang í na nzəngkəng ônəm oga lung ìkum ɓu yà?>> 
\p  
\v 7 Te uGidiyon na ama̱n pa̱, <<Ka̱kul nva̱ ta te, awalang va̱ uYawe á na uZeba ká̱ uZalmuna ka̱ ashe awo mi te, mi cha izər wó ká̱ izu iga ashe nzam kang ká̱ mmər.>> 
\p  
\v 8 Te uGidiyon wong ka̱ ta ga aPeniyel, kang uza̱ ɓəp iya̱m izəngtəng va ta ka̱ atak oza̱, kang onunggwan oga aPeniyel na ama̱n á na wa nva̱ onunggwan oga aSukkot ka̱ na ama̱n á na á.  
\v 9 Te uza̱ là ônunggwan oga aPeniyel pa̱, <<Awalang va̱ mi le ka̱ ashe igwan te, mi shin nzhi nkúrkúr va̱ ta̱.>> 
\p  
\v 10 Ǹyangmata̱ te, uZeba ká̱ uZalmuna oma ka̱ aKarkor nzəng ká̱ onəm oga nlung ìkum oza̱, onunggwan ìkalong pa̱ igba̱pchi ama̱n pa̱ tukun, oma onəm va̱ re ka̱ ashe nkpaktak onəm ìkum ovan oga asa̱l nfa alum, ka̱kul onəm ìkalong igba̱l ká̱ ìsəm pa̱ ìparəm tak chit ka̱ ashe onunggwan va̱ zəp ndokchi.  
\v 11 Te uGidiyon wòl asa̱l onəm oga ntəm ka̱ ashe aghal va ka̱ asa̱l nfa alum aNoba ká̱ aJokbeha, kang uza̱ mul onəm oga nlung ìkum va̱ ta na pa ká̱ ìkum.  
\v 12 UZeba ká̱ uZalmuna, oponzhi oMidiyan oga oparəm va̱ ta chəng, ǹnyi te, uza̱ ɓak nva̱ng oza̱ ga wur oza̱, kang uza̱ nak nkpaktak onəm oga nlung ìkum va̱ ta zwar. 
\p  
\v 13 Te uGidiyon uya aJowash ununggwan le ka̱ atak ìkum va̱ ta, uza̱ wòl asa̱l va i kyén i ga aHeret.  
\v 14 Uza̱ kpán uyenza̱m uro uga aSukkot kang uza̱ kat na. Te uyenza̱m va̱ ta lir aɗin oponzhi oga aSukkot á na, oma onəmgbak oga ìtong va̱ ta á, onunggwan ìsəm pa̱ ìfangshat ama̱n pa̱ fangshat.  
\v 15 Te uGidiyon ɓa chu atak onunggwan oga aSukkot, kang uza̱ là ôza̱ pa̱, <<Ó dər, uZeba ká̱ uZalmuna oma ta̱, ova ka̱ ó nap avyal á mi, nva̱ ó là pa̱,<U kpán uZeba ká̱ uZalmuna chit ka̱ ashe awo ɓu ɗò? Ka̱kul iza̱ kang í na nzəngkəng ônunggwan ɓu va̱ bəlak chit yà?  
\v 16 Te uza̱ wur onəmgbak oga ìtong va̱ ta, kang uza̱ ɗyang ntàn ônəm oga aSukkot ká̱ izu iga ashe nzam ká̱ oga mmər.  
\v 17 Uza̱ shin nzhi nkúrkúr ngga aPeniyel kpa, kang uza̱ gbá̱ng onunggwan oga ashe ìtong va̱ ta. 
\p  
\v 18 Te uza̱ ɓəp uZeba ká̱ uZalmuna pa̱, <<Nza̱ apir onəm ó gbá̱ng ka̱ aTabor yà?>> 
\p Oza̱ na ma̱n á na pa̱, <<Onəm wa mmaɓu, nza̱ uzəngtəng oza̱ nggo wa aya aponzhi.>> 
\p  
\v 19 Te uGidiyon na ama̱n ôza̱ pa̱, <<Ogənang mi ta, ovan anang mi. N sóng anung ká̱ uYawe, ká̱ yà pa̱ ó re oza̱ re ká̱ irirì te, ka̱ n gbá̱ng wó ka̱t.>>  
\v 20 Uza̱ là ûJeter uyiyen ugəshi pa̱, <<Wóng, na u gbá̱ng oza̱.>> Ǹnyi te, uyenza̱m va̱ ta tur ndokchi wò ka̱t, ka̱kul uza̱ wa yà uyen uga iɓəl, kang ayər ka̱ nnəm na. 
\p  
\v 21 Te uZeba ká̱ uZalmuna là pa̱ <<Wong ká̱ ishi ɓu na u gba̱l yi, ka̱kul unəm i kur ununggwan kang i nəm nnap onunggwan.>> Te uGidiyon wong gba̱l uZeba ká̱ uZalmuna, kang uza̱ fən oga iya̱m isham va̱ ka̱ ishak oga alakəmi oza̱. 
\p  
\v 22 Te onəm oga aIsa̱rila là ûGidiyon pa̱, <<Nəm iponzhi ka̱ apal yi, mmaɓu ká̱ ovan ɓu, ká̱ okəka ɓu kpa, ka̱kul u ka̱m ishi yi chit ka̱ ashe awo oMidiyan.>> 
\p  
\v 23 Ǹnyi te, uGidiyon là ôza̱ pa̱, <<Mi yà ka̱ nnəm iponzhi ka̱ apal wó ka̱t, kang uyen mi i yà ka̱ nnəm iponzhi ka̱ apal wó ka̱t na kpa, uYawe uwa i nəm iponzhi ka̱ apal wó.>>  
\v 24 Kang uza̱ là ôza̱ pa̱, <<Mmami ka̱ nchal wó pa̱, nza̱ unəm nggo ka̱ ashe wó, á na iya̱m achwang á mi ka̱ ashe iyəya̱m iga ngwur ka̱ atak ìkum.>> Ka̱kul oMidiyan oma ka̱ oga iya̱m achwang iga azənariya, wa nva nnap-nnəm oIshəmayel á. 
\p  
\v 25 Te oza̱ na ama̱n pa̱, <<Í məma̱n, í na oza̱ na ká̱ kpaktak ìgwak.>> Te oza̱ nàr inang ìlukwan, kang nza̱ unəm nggo mang iya̱m achwang va̱ uza̱ ya ka̱ atak ìkum ka̱ apəpal.  
\v 26 Iɗək iya̱m achwang iga azənariya va̱ uza̱ chal te, ashekel ìkalong pa̱ izəng ká̱ igba̱l pa̱ ifangshat aga azənariya. Iya̱m nza̱m pa̱ kpa te a yà kà̱ ka̱t, wa iya̱m ishak, ká̱ ìlukwan irəzang pa̱ bit iga mpa oponzhi uga aMidiyan, ká̱ oga iya̱m ishak oga alakəmi oza̱  
\v 27 UGidiyon la ìchər ká̱ azənariya va̱ ta, kang uza̱ pak ka̱ ashe ìtong wò, aOfəra. Nkpaktak oIsa̱rila nəm mmai ka̱ atak ngwop ìchər va̱ ta, a le ta̱l ajəp ûGidiyon ká̱ nzhizhi. 
\p  
\v 28 Wa nnà ta, onəm oga aIsa̱rila nəm igwan ká̱ oMidiyan, kang oMidiyan wong ká̱ ishi lap ka̱t. Te, mbin təm ká̱ ikángkáng ìzun ìsəm pa̱ ineɗing ka̱ ashe nra aGidiyon. 
\s1 Ikú aGidiyon 
\p  
\v 29 Te uJerup-Baal uya aJowash ununggwan le ga təm ka̱ nzhi wò.  
\v 30 UGidiyon ká̱ ovan onunggwan ìsəm pa̱ ifangshat ova oji na, ka̱kul uza̱ ká̱ ochar pa̱ kyák.  
\v 31 Uchəchar va̱ uza̱ nak ka̱ ashe nzhi pa kùk ka̱ aShekem te, á mar uyen ununggwan á na kpa, kang uza̱ sok aɗin á na pa̱ uAbimelek.  
\v 32 Te uGidiyon uya aJowash gbák pa̱ gənggəng kang a kú, te oza̱ li na ka̱ awap apupo uJowash, ka̱ aOfəra aga akum aAbiyezer. 
\p  
\v 33 Ka̱ nva̱ng ikú aGidiyon na byet te, onəm oga aIsa̱rila ga̱ɓa̱n le nəm mmai ka̱ atak ngwop ìchər aBaal. Oza̱ nak ìchər aBaal-Berit sat inan oza̱,  
\v 34 kang onəm oga aIsa̱rila rəng uYawe Inan oza̱ lap ka̱t, uva ka̱ fa ká̱ oza̱ ka̱ ashe awo nkpaktak okpa ìkum oza̱, ova gáng oza̱ ka̱ nza̱ ngba̱k nggo á.  
\v 35 Kà̱ɗi te, oza̱ nəm iya̱m inəna̱n iro n̂zhi aJerup-Baal ka̱t, uwa aGidiyon á, káp ka̱ nkpaktak oga iya̱m inəna̱n va̱ uza̱ ka̱ nəm ôIsa̱rila á. 
\c 9  
\s1 UAbimelek 
\p  
\v 1 UAbimelek uya aJerup-Baal ununggwan ga atak okyán wò ka̱ aShekem, kang uza̱ là ôza̱ ká̱ nkpaktak akum anang wò pa̱,  
\v 2 <<Ó ɓəp nkpaktak onəm oga aShekem pa̱,<Nna ka̱ i ɓyen ká̱ wó yà, nva̱ pa̱ nkpaktak ovan onunggwan aJerup-Baal ìsəm pa̱ ifangshat á nəm iponzhi ka̱ apal wó, ka̱t te, unəm pa̱ uzəng á nəm á.> Ó rəng kpa pa̱ mmami akup ká̱ ìzhè wó.>> 
\p  
\v 3 Awalang va̱ okyikyán là nkpaktak oga nnap-nlà va̱ ta chit ka̱ ashe achwang onəm oga aShekem te, ìgwak oza̱ le atak aAbimelek, ka̱kul oza̱ là pa̱, <<Uza̱ ugənang yi.>>  
\v 4 Oza̱ na aazurfa á na ashekel ìsəm pa̱ ifangshat, ka̱ ashe nzhi awop ìchər aBaal-Berit, ká̱ nna ta uAbimelek yar nsar iyap ká̱ onunggwan oga ayə́r oro, kang oza̱ yar nvəva̱ng.  
\v 5 Te uza̱ ga nzhi apo wò ka̱ aOfəra, kang uza̱ gbá̱ng ogənang wò onunggwan ovan aJerup-Baal, onunggwan ìsəm pa̱ ifangshat, ka̱ apal ìpang pa̱ ìzəng. Ǹnyi te, uJotam uya aJerup-Baal ununggwan uga nkú irəng lár, ka̱kul uza̱ bwam ishi wò.  
\v 6 Te nkpaktak onəm oga aShekem ká̱ aBet-Milo ɓut ka̱ ngba̱k ìkun aOak ka̱ atak ndar ka̱ aShekem pa̱ na ó kyer iponzhi ûAbimelek. 
\p  
\v 7 Awalang va̱ mmá là ûJotam te, uza̱ ga kyén ka̱ apal aƁam aGerizim, kang á ləp achu ôza̱ pa̱, <<Ó gwong achwang ka̱ mi, ónəm oga aShekem, na Inan á fe wó kpa.  
\v 8 Ka̱ nda aro te, ikún ga pa̱ na ó gor uponzhi îshi oza̱. Te oza̱ là îkun mpyet pa̱, <Nəm iponzhi ka̱ pal yi.> 
\p  
\v 9 Ǹnyi te, ikun mpyet na ama̱n pa̱,<N re nna mmì mi nva mi na ichumchum Inan ká̱ onəm ká̱, kang mi ga mi yir ka̱ ashe ikun ɗò?> 
\p  
\v 10 Te ikún là îkun ìpipyan pa̱, <Ɓa na u nəm iponzhi ka̱ apal yi.> 
\p  
\v 11 Ǹnyi te, ikun ìpipyan na ama̱n ôza̱ pa̱, <N re nna awár mi va̱ ta̱, ava anəna̱n kang a chàng byet, na n ga n yir ka̱ apal ikún ɗò?> 
\p  
\v 12 << Te, oga ikún là îkun ìba̱ngba̱ng pa̱, <Ɓa na u nəm iponzhi ka̱ apal yi.> 
\p  
\v 13 Ǹnyi te, ìkun ìba̱ngba̱ng na ama̱n ôza̱ pa̱,<N re nna ndəng ìba̱ngba̱ng mi nchángchàng nva ka̱ nchàng ká̱ oga inan ká̱ onəmləbər, na ngga ntəm nyir ka̱ ashe ikún pa̱ mi nəm iponzhi á?> 
\p  
\v 14 <<Ka̱ nkukur te, nkpaktak ikún là îzu pa̱, <Ɓa na u nəm iponzhi ka̱ apal yi.> 
\p  
\v 15 <<Te ìzu là îkún pa̱, <A yà pa̱ nnandər ó gor mi chit pa̱ n yà uponzhi ka̱ apal wó, te ó ɓa na ó təm ayì ka̱ avəng mi, ǹnyi te, a yà pa ka̱t, te re apər á fa ka̱ ashe izu na á ri oga akun asida iga aLebanon.> 
\p  
\v 16 <<Ǹyangmata̱ te, ó nəm nnandər nəm ká̱ iva̱ mal, nva̱ ó kyer uAbimelek uponzhi ɗò? Ó nəm ikin nəm ûJerup-Baal ká̱ nzhizhi ɗò? Ó nəm nnap á na nva mal dakdak ɗò?  
\v 17 Ó rəng pa̱ upo mi ka̱ lung ìkum á wo, uza̱ yáp ká̱ irirì wò pa̱ na ò fa ká̱ wó ka̱ ashe awo oMidiyan.  
\v 18 Ǹnyi te, ka̱ nda va̱ ta̱ te, ó le chit ó fa iya̱mkak ká̱ nzhi apo mi. Ó gbá̱ng ovəvan onunggwan ìsəm pa̱ ifangshat ka̱ apal ìpang pa̱ ìzəng, kang ó kyer uAbimelek uya achar uzwal, uponzhi ka̱ apal onəm oga aShekem, ka̱kul pa̱ uza̱ ugənang wó.  
\v 19 Ǹyangmata̱ te, ó nəm nnandər nəm ka̱ iva̱ mal ûJerup-Baal ká̱ nzhizhi ka̱ nda va̱ ta̱ ɗò? A yà pa te, re ó fe nchàng aAbimelek, na uza̱ á fe nchang wó kpa.  
\v 20 Ǹnyi te, a yà pa ka̱t, te re apər á fa ka̱ atak aAbimelek, a ri onəm oga aShekem ká̱ aBet-Milo, na apər á fa ka̱ atak onəm oga aShekem ká̱ aBet-Milo a ri uAbimelek.>> 
\p  
\v 21 Te uJotam chə́r ga aBeyer, kang a təm ka̱ ta, ka̱kul uza̱ nəm ayər agənang wò uAbimelek. 
\p  
\v 22 Ka̱ nva̱ng va̱ uAbimelek nəm iponzhi chit ka̱ apal oIsa̱rila ìzun pa̱ ishatɗing te,  
\v 23 Inan nak nwong ká̱ nnap-nnəm ká̱ ishimshe aAbimelek ká̱ onəm oga aShekem, kang onəm oga aShekem fa iya̱mkak ká̱ uAbimelek.  
\v 24 Iya̱m va̱ ta fa ka̱kul pa̱ na mmá pyát inga va mmá nəm ka̱ atak ngbá̱ng ovan aJerup-Baal onunggwan ìsəm pa̱ ifangshat, ká̱ nchə̀r oza̱ va̱ mmá tar ka̱ apal ishi agənang oza̱ uAbimelek, uva gbá̱ng oza̱, kang ka̱ apal onəm oga aShekem, ova ka̱mshishi ká̱ ngbá̱ng ogənanggənang.  
\v 25 Te onəm oga aShekem nak onəm ra anyimnyal ka̱ apal oga aɗuktum i vyat iya̱m ka̱ atak nkpaktak onəm va̱ i wòl asa̱l ka̱ ta. Te mmá là iya̱m va̱ ta ûAbimelek. 
\p  
\v 26 Ǹyangmata̱ te, uGayal uya aEbet ununggwan, ɓa təm ka̱ aShekem ká̱ ogənang wò, kang onəm oga aShekem na nnandər ká̱ na.  
\v 27 Ka̱ nva̱ng va̱ onəm oga aShekem ga pang oga awár ìba̱ngba̱ng chit ka̱ ashe oga iram ìba̱ngba̱ng oza̱ kang a káng ndədəng te, oza̱ nəm nchàng izər ka̱ ashe nzhi inan oza̱. Oza̱ ri, oza̱ wá, kang oza̱ pwat uAbimelek.  
\v 28 Te uGayal uya aEbet ununggwan là pa̱, <<UAbimelek va̱ uda kang mmayi onəm oga aShekem, í kpak nnap-nnəm á na yà? Uya aJerup-Baal ka̱t ɗò? UZebul uwa unəm uga nvəva̱ng ka̱t ɗò? Ó kpak nnap-nnəm n̂zhi aHamor, upo aShekem. Ka̱kul iza̱ kang í pak nnəm izwal ûAbimelek yà?  
\v 29 Ká̱ yà pa̱ onəm va̱ ta̱ ka̱ ashe awo mi te, ká̱ n ngbá̱l uAbimelek. Ka̱ nlà ûAbimelek pa̱, <Ga na u dan iyəl oshozha ɓu, na u fa agbai.> >> 
\p  
\v 30 Awalang va̱ uZebul unəm uga mpyal aga ìtong va̱ ta fe oga nnap-nlà va̱ uGayal uya aEbet ununggwan ka̱ nləla te, ìgwak lak na pa̱ gənggəng.  
\v 31 Te uza̱ re nre ká̱ onəm oga nre ká̱ ayi ga atak aAbimelek ka̱ aAruma, uza̱ là pa̱, <<Dər, uGayal uya aEbet ununggwan ká̱ ogənanggənang ɓa aShekem chit, kang oza̱ ka̱ nnók onəm oga ìtong va̱ ta ka̱ apal ɓu.  
\v 32 Ǹyangmata̱ te, wong ká̱ izwam, mmaɓu ká̱ onəm va̱ nzəng ká̱ ɓu, na ó ra anyimnyal ka̱ ashe oga nzam.  
\v 33 Ipin, ká̱ ìɓotak, awalang va̱ alum ka̱ nfa ká̱ te, wa ru ìtong va̱ ta ká̱ ìkum. Kang awalang va̱ uGayal ká̱ onəm va̱ nzəng ká̱ na i fa ìkum ka̱ ɓu te, wa nəm iya̱m va̱ ká̱ na u ɗom.>> 
\p  
\v 34 Te uAbimelek wong ká̱ nkpaktak onəm va̱ nzəng ká̱ na ká̱ izwam, kang oza̱ ra anyimnyal idongkong pa̱ ineɗing gáng aShekem.  
\v 35 Ǹyangmata̱ te, uGayal uya aEbet ununggwan ka̱ fa chit ka̱ nsat ka̱ anung asa̱l aga ntar ìtong va̱ ta, a mal dakdak ká̱ awalang va̱ uAbimelek ká̱ onəm va̱ nzəng ká̱ na wong ka̱ atak va̱ oza̱ ra anyimnyal kà̱. 
\p  
\v 36 Awalang va̱ uGayal ya onəm chit, te uza̱ là ûZebul pa̱, <<Dər, onəm ka̱ nfəng ka̱ apal oga aɓam.>> 
\p UZebul là pa̱, <<Ala̱ka̱n aɓam na u ya kang á nəm ka̱ ɓu na onəm.>> 
\p  
\v 37 Ǹnyi te, uGayal là nnap kà̱ɗi pa̱, <<Dər, onəm ka̱ nfəng ka̱ oga aɗuktum aga ishimshe mbin ka̱ mɓa, kang idongkong iro ka̱ mɓa ka̱ asa̱l isu ikun aOak va̱ onəm oga iva̱k i nəm iva̱k kà̱.>> 
\p  
\v 38 Te uZebul là á na pa̱, <<Nnap anung ɓu va̱ nna ka̱ ǹyangmata̱ yà, mmaɓu va u là pa̱, <UAbimelek va̱ uda kang í kpak nnap-nnəm á na yà? Onəm va ta̱ ka̱ u ɓák va̱ ka̱t ɗò? Fa ǹyangmata̱, na u ga u lung oza̱.>> 
\p  
\v 39 Te uGayal ləp mpyal onəm oga aShekem, kang oza̱ lung uAbimelek.  
\v 40 UGayal chə́r, ǹnyi te uAbimelek ɓak na ga chu anung asa̱l ntar ìtong va̱ ta, kang mmá gbá̱ng onəm pa̱ makmak va̱ ka̱ nchəng.  
\v 41 Te uAbimelek təm ka̱ aAruma, kang uZebul ɓak uGayal ká̱ ogənanggənang fa ka̱ aShekem. 
\p  
\v 42 Ipin fa kpa̱k te, onəm oga aShekem fa ga ashe oga agbagba, kang mmá là iya̱m va̱ ta ûAbimelek.  
\v 43 Te uza̱ wur onəm wò kang uza̱ kap oza̱ idongkong pa̱ ishatɗing, kang oza̱ ra anyimnyal ka̱ ashe oga agbagba va̱ ta. Awalang va̱ uza̱ ya onəm va̱ ta ka̱ nfa ka̱ ashe ìtong te, uza̱ wong ru oza̱ ká̱ ìkum.  
\v 44 UAbimelek ká̱ ìdongkong va̱ nzəng ká̱ na gha̱n ga tong ka̱ anung asa̱l aga tar ìtong va̱ ta. Te aɓo idongkong iga ìparəm ga ru onəm va̱ ka̱ ashe oga agbagba ká̱ ìkum kang a gbá̱ng oza̱.  
\v 45 UAbimelek lung ìkum ká̱ ìtong va̱ ta ga chu ntar alum. Uza̱ ri ìtong va̱ ta, kang a gbá̱ng onəm va̱ ka̱ ashishe. Te uza̱ shin ìtong va̱ ta, kang a wung mman kà̱. 
\p  
\v 46 Awalang va̱ nkpaktak onəm oga nzhi nkúrkúr ngga aShekem fe te, oza̱ chəng táng atak mbwam ka̱ nzhi awop ìchər aEl-Berit.  
\v 47 Awalang va̱ mmá là ûAbimelek pa̱ nkpaktak onəm va̱ ta ga ɓut chit ka̱ atak azəngtəng te,  
\v 48 uza̱, ká̱ nkpaktak onəm va̱ nzəng ká̱ na kyén ga aƁam aZalmon. UAbimelek yar ìkù ka̱ awo kang a gəlchi igwong ìkun yar nak ka̱ agar wò. Te uza̱ là ônəm va̱ nzəng ká̱ na pa̱, <<Kəlak, ó nəm iya̱m va̱ ó ya n nəm ta̱ á.>>  
\v 49 Wa nnà ta nza̱ unəm nggo gəlchi igwong iji wò, kang a yar nva̱ng aAbimelek. Oza̱ ɓák oga akun va̱ ta ka̱ izər atak mbwam va̱ ta, kang oza̱ pá apər âtak va̱ ta nzəng ká̱ onəm va̱ ka̱ ashishe. Te nkpaktak onəm va̱ ka̱ ashe nzhi nkúrkúr ngga aShekem kú, onəm dat ká̱ ìkalong pa̱ ìzəng, onunggwan ká̱ ochar. 
\p  
\v 50 Ka̱ nvəva̱ng te, uAbimelek ga ru aTebet ká̱ ìkum, kang a ri na.  
\v 51 Ǹnyi te, nzhi nkúrkúr nkamkam ro nna ka̱ ishimshe ìtong va̱ ta, kang nkpaktak onunggwan ká̱ ochar, oma nkpaktak onəm oga ashe ìtong va̱ ta chəng ga táng ashishe. Oza̱ gún ishi oza̱ ka̱ ashishe, kang oza̱ kyén ga apal nzhi nkúrkúr va̱ ta.  
\v 52 Te uAbimelek ɓa nzhi nkúrkúr va̱ ta kang a ru na ká̱ ìkum. Ǹnyi te, awalang va̱ uza̱ ɓa dat ká̱ anung asa̱l aga nzhi nkúrkúr va̱ ta pa̱ na o pwak na ká̱ apər te,  
\v 53 uchar uro mang awo ako ka̱ apal ishi aAbimelek, kang a chwan ikpáng ishi á na. 
\p  
\v 54 Ta byet te, uza̱ wór uyenza̱m uga ngwur iya̱m ìkum á na ká̱ nggha̱n, uza̱ là á na pa̱, <<Tur ndokchi ɓu na u gbá̱l mi, le oza̱ a wong a là pa̱, <Uchar a gbá̱l mi> ka̱t.>> Te uyenza̱m va̱ ta kyer na ká̱ ndokchi, kang uza̱ kú.  
\v 55 Awalang va̱ oIsa̱rila ya pa̱ uAbimelek kú chit te, udanggo le ga nzhi wò. 
\p  
\v 56 Wa nnà ta Inan pyát akat nnap-mɓá̱ngɓa̱ng aAbimelek nva̱ uza̱ nəm ûpo wò, ka̱ atak ngbá̱ng ogənanggənang oga ìsəm pa̱ ifangshat va̱ á.  
\v 57 Ka̱ asa̱l va ta̱ kpa Inan nak nkpaktak onəm oga aShekem ɓək anung ka̱kul nnap-mɓá̱ngɓa̱ng oza̱. Nvyap va̱ uJotam uya aJerup-Baal ununggwan là ka̱ apal ishi oza̱ te, á ɓa yə́l. 
\c 10  
\s1 UTola 
\p  
\v 1 Ka̱ nva̱ng aAbimelek, te uTola uya aPuwa ununggwan, uya aDodo ununggwan, unəm uga aIsaka, uva ka̱ ntəm ka̱ aShamir ava ka̱ ìtong iga aɗuktum aEfrayim, wong pa̱ na ô ka̱m ishi oIsa̱rila.  
\v 2 Uza̱ nap-akwali ôIsa̱rila ìzun ìsəm pa̱ ìparəm ama̱n pa̱ shatɗing te uza̱ kú, kang mmá li na ka̱ aShamir. 
\s1 UJayir 
\p  
\v 3 Ka̱ nvəva̱ng te, uJayir unəm uga aGileyat, uza̱ nap-akwali ôIsa̱rila ìzun ìsəm pa̱ ìparəm ama̱n pa̱ pa̱rəm.  
\v 4 Uwa yà ká̱ ovan onunggwan ìsəm pa̱ ishatɗing, ova i kyén ka̱ apal oga azhaki ìsəm pa̱ ishatɗing. Oza̱ ká̱ oga itong ìsəm pa̱ ishatɗing ka̱ mbin aGileyat, ova mi wór pa̱ itong aJayir ɓa chu nda va̱ ta̱.  
\v 5 Awalang va̱ uJayir kú te, mmá li na ka̱ aKamon. 
\s1 uJefta 
\p  
\v 6 Ovan oga aIsa̱rila nəm nnap-mɓá̱ngɓa̱ng ka̱ mpyal aYawe kà̱ɗi. Oza̱ wop oga ìchər aBaal ká̱ aAshtoret, ká̱ oga inan aSuriya, ká̱ oga inan aSidon, ká̱ oga inan aMowap, ká̱ oga inan oAmmon, ká̱ oga inan oFilisti. Kang ka̱kul oIsa̱rila yang ká̱ uYawe, i wop na lap ka̱t te,  
\v 7 uYawe mən ìkum ká̱ oza̱. Uza̱ na oIsa̱rila ka̱ ashe awo oFilisti ká̱ oAmmon,  
\v 8 ova nyán ká̱ oza̱ kang a chwan oza̱ ka̱ ashe ìzun va̱ ta. Ka̱ apal ìzun pa̱ igba̱pchi ama̱n pa̱ na̱nne te, oza̱ nyán ká̱ nkpaktak oIsa̱rila va̱ ka̱ asa̱l nfa alum aUrdun ka̱ ashe aGileyat, mbin oAmori á.  
\v 9 Te oAmmon pa̱ng aUrdun ka̱kul pa̱ na ó lung akum ìjili aYahuda, ká̱ uBenjamin, ká̱ nzhi aEfrayim. Kang oIsa̱rila táng ashe mɓək anung pa̱ gənggəng.  
\v 10 Te onəm oga aIsa̱rila yə́ng ûYawe, oza̱ là pa̱, <<I nəm nnap-mɓá̱ngɓa̱ng á ɓu chit, ka̱kul i re ngwop Inan yi, i wop oga ìchər aBaal.>> 
\p  
\v 11 Te uYawe na ama̱n ônəm oga oIsa̱rila pa̱, <<Awalang va̱ onəm oga aMasar, ká̱ oAmori, ká̱ oAmmon, ká̱ oFilisti,  
\v 12 ká̱ oga aSidon, ká̱ oAmalek, ká̱ oMawoni ka̱ nyán ká̱ wó, kang ka̱ ó yə́ng á mi te, n ka̱m ishi wó ka̱ ashe awo oza̱ ka̱t ɗò?  
\v 13 Káp ká̱ nna te, ó ga̱ɓa̱n asəm á mi chit, ó wop oga inan iro, ka̱kul nva̱ ta te, mi yà ká̱ nka̱m ishi wó lap ka̱t.  
\v 14 Ó ga na ó yə́ng ôga inan va ó yak á. Re oza̱ a fa ká̱ wó ka̱ ashe awalang nɗaktak wó.>> 
\p  
\v 15 Ǹnyi te, onəm oga oIsa̱rila là ûYawe pa̱, <<I nəm nnap-mɓá̱ngɓa̱ng á ɓu chit. Nəm iya̱m va ká̱ yi u ya ma ká̱ ɓu, ǹnyi te, i chal ɓu chal, ka̱m ishi yi ka̱ nda va̱ ta̱.>>  
\v 16 Te oza̱ swang oga inan iga mbin nkak va̱ ka̱ ashe oza̱ kang oza̱ wop uYawe. Kang ìgwak lak uYawe ka̱kul mɓək anung va̱ onəm oga aIsa̱rila ka̱ ashishe. 
\p  
\v 17 Te oshozha oga aAmmon gbar izər ka̱kul ìkum, kang oza̱ ləp apa̱k ka̱ ashe aGileyat te, onəm oIsa̱rila ɓut kang oza̱ ləp apa̱k aji oza̱ ka̱ aMizpa.  
\v 18 Onəm oga mpyal aGileyat là ôwan oza̱ pa̱, <<Unəm va̱ káp a ga a ru onəm oga aAmmon ká̱ ìkum mpyal te, uza̱ wa i ya unəm uga mpyal n̂kpaktak onəm va̱ ka̱ ntəm ka̱ ashe aGileyat.>> 
\c 11  
\p  
\v 1 UJefta unəm uga aGileyat pa te, unəm uga ǹnyi ashar ìkum ukamkam. Upupo uGileyat, kang unənang te, uchar umaimai.  
\v 2 Uchar aGileyat mar ovan onunggwan á na kpa. Kang awalang va̱ oza̱ rup, te oza̱ wà uJefta pa̱, <<Ɓu ya ká̱ nrì iya̱mkup apo yi nzəng ká̱ yi ka̱t, ka̱kul mmaɓu uya achar ro pa̱ɗi.>>  
\v 3 Te uJefta chə́r ka̱ atak ogənang wó, uza̱ ga təm ka̱ mbin aTop. Ka̱ ta te, ovan oga ayə́r oro ɓa ɓut ka̱ atətak kang oza̱ i ranggang nzəng ká̱ na. 
\p  
\v 4 Mmá ka̱ ashe ntəm te, ovan oga oAmmon ɓa ru oga aIsa̱rila ká̱ ìkum.  
\v 5 Kang awalang va̱ oAmmon ru onəm oga aIsa̱rila chit ká̱ ìkum te, onəmgbak oga aGileyat ga mbin aTop pa̱ na ó le ká̱ uJefta ka̱ aGileyat.  
\v 6 Te oza̱ là ûJefta pa̱, <<Ɓa na u yà unəm uga mpyal ìkum á yi, na i nəm ìkum ká̱ onəm oga aAmmon.>> 
\p  
\v 7 Te uJefta là ônəmgbak oga aGileyat pa̱, <<Mmawo na ka̱ ó yang ká̱ mi, ó wà mi ka̱ ashe nzhi apo mi ka̱t ɗò? Iza̱ nak kang ó ɓa atak mi ǹyangmata̱ va̱ mmawó ka̱ ashe nɗaktak yà?>> 
\p  
\v 8 Te onəmgbak oga Gileyat là ûJefta pa, <<Ká̱ nna kpa te, í le chit í ɓa ka̱ atak ɓu ǹyangmata̱. A yà pa̱ ɓu ga nzəng ká̱ yi na i lung ìkum ká̱ onəm oga aAmmon te, mmaɓu na ɓu yà unəm uga mpyal onəm oga aGileyat pa̱ kpaktak.>> 
\p  
\v 9 Te uJefta na ama̱n ônəmgbak oga aGileyat pa̱, <<A yà pa̱ ó le ká̱ mi ka̱ nzhi pa̱ n lung ìkum ká̱ onəm oga aAmmon, kang uYawe ga na oza̱ ka̱ ashe awo mi te, mi yà unəm uga mpyal wó yà na ɗò?>> 
\p  
\v 10 Te onəmgbak oga aGileyat na ama̱n ûJefta pa̱, <<UYawe uwa unəm uga nshet nnap ka̱ ishimshe yi. Nnandər, iya̱m va ɓu là te, nna i nəm.>>  
\v 11 Te uJefta ga nzəng ká̱ onəmgbak oga aGileyat, kang onəm va̱ ta nak na sat unəm uga mpyal oza̱ ká̱ unəm uga mpyal ìkum oza̱ kpa. Te uJefta le là nkpaktak oga nnap-nlà wò va̱ ka̱ mpyal aYawe ka̱ aMizpa. 
\p  
\v 12 Te uJefta re nre ká̱ onəm oga nre ka̱ atak aponzhi oga aAmmon pa̱, <<Iza̱ gwang mi ká̱ ɓu, kang ɓu ɓa pa̱ na u lung ìkum ká̱ mbin mi yà?>> 
\p  
\v 13 Te uponzhi oAmmon na ama̱n ônəm oga nre aJefta pa̱, <<Awalang va̱ oIsa̱rila fa ka̱ aMasar te, oza̱ vyat mbin mi á ɓan ka̱ aArnon ɓa chu aJabok, kang a lyam ga aUrdun. Ǹyangmata̱ te, le ká̱ mbin va̱ ta á mi ka̱ ashe inal.>> 
\p  
\v 14 Te uJefta re onəm oga nre kà̱ɗi ga atak aponzhi oAmmon,  
\v 15 ká̱ nnap-nlà pa̱, 
\pmo <<Iya̱m va ta̱ uJefta là. Onəm oga aIsa̱rila vyat mbin oMowap, ka̱t te oAmmon ka̱t.  
\v 16 Ǹnyi te awalang va̱ oza̱ fa ka̱ ashe aMasar te, oIsa̱rila wòl ashe nzam mmaləng ga chu Ìwa Irəzang, kang oza̱ ga aKadesh.  
\v 17 Te oIsa̱rila re onəm oga nre ga atak aponzhi oga aEdom pa̱, <Kusuk, re yi na í watar ka̱ ashe mbin ɓu,> ǹnyi te, uponzhi oga aEdom ma̱n ka̱t. Te wa nnà ta oza̱ re nre ûponzhi oga aMowap kpa, kang uza̱ yang. A nak te, oIsa̱rila təm ka̱ aKadesh. 
\pm  
\v 18 Te oza̱ kak ashe nzam oza̱ gang mbin aEdom ká̱ aMowap, oza̱ wòl asa̱l nfa alum mbin aMowap, kang oza̱ ləp apa̱k ka̱ agwong aArnon. Oza̱ tar ashe mbin aMowap ka̱t, ka̱kul aArnon na aswari ga aMowap. 
\pm  
\v 19 Te oIsa̱rila re onəm oga nre ga atak aSihon uponzhi oAmori uva i nəm iponzhi ka̱ aHeshbon, oza̱ là á na pa̱, <Re yi i watar ka̱ ashe mbin ɓu na i ga mbin yi.>  
\v 20 Ǹnyi te, uSihon ma̱n ôIsa̱rila pa̱ a watar ka̱ ashe mbin wò ka̱t. Uza̱ ɓut nkpaktak onəm wò, oza̱ ga ləp apa̱k ka̱ aJahat, kang oza̱ ru oIsa̱rila ká̱ ìkum. 
\pm  
\v 21 <<Te uYawe, Inan oIsa̱rila, na uSihon ká̱ nkpaktak onəm wò ka̱ ashe awo oIsa̱rila kang oza̱ ri oza̱ ká̱ ìkum. OIsa̱rila kwom nkpaktak mbin oAmori, ova ka̱ ntəm ka̱ ashe mbin va̱ ta,  
\v 22 kang oza̱ kwom nkpaktak mbin oAmori va̱ ta, ɓan ka̱ aArnon ga chu aJabok, kang a ɓan ka̱ nzam mmaləng ga chu aUrdun. 
\pm  
\v 23 Ǹyangmata̱ te, uYawe, Inan oIsa̱rila wà oAmori chit fa ka̱ mpyal onəm wò oIsa̱rila. Nza̱ ichumchum mmaɓu ká̱ pa̱ u vyat ká̱ yi yà?  
\v 24 Ɓu kpán iya̱m va̱ inan ɓu uKemosh na ɓu ka̱t ɗò? Wa nnà ta kpa í kpán nkpaktak oga iya̱m va̱ uYawe, Inan yi na á yi.  
\v 25 U ji uBalak uya aZipo uponzhi oga aMowap ji ɗò? Uza̱ kpán ìkwoksok chit ká̱ oIsa̱rila, ka̱t te, uza̱ lung ìkum ká̱ oza̱ chit ɗak ɓo?  
\v 26 Izun chit ìgba̱l pa̱ ishatɗing nva̱ oIsa̱rila ka̱ ntəm ka̱ ashe aHeshbon ká̱ aAroyer, ká̱ oga ivan itong oza̱, ká̱ nkpaktak oga itong va̱ ka̱ anung awang aArnon. Iza̱ nak kang ó ɗak pa̱ na ó ka̱m oza̱ ka̱ ashe awalang va̱ ta ka̱t yà?  
\v 27 N nəm mpat nro á ɓu ka̱t, ǹnyi te, mmaɓu ka̱ nnəm mpat á mi, ka̱ atak nru mi ká̱ ìkum. Re uYawe, uga nnap-akwali, a kat ishimshe onəm oga aIsa̱rila ká̱ oga aAmmon ká̱ nda va̱ ta̱.>> 
\m  
\v 28 Ǹnyi te, uponzhi onəm oga aAmmon gwong achwang ka̱ nre va̱ uJefta re nre á na ká̱ ka̱t. 
\p  
\v 29 Te aRuhu aYawe fə́r ka̱ apal aJefta, kang uza̱ watar aGileyat ká̱ aManase, lyam ga ashe aMizpa aga aGileyat i ɓut oshozha. Kang uza̱ wong ka̱ ta ga ìkum ka̱ onəm oga aAmmon.  
\v 30 Kang uJefta sóng anung ûYawe pa̱, <<A yà pa̱ ɓu na onəm oga aAmmon ka̱ ashe awo mi te,  
\v 31 iya̱m va pa̱ káp i fa ka̱ anung nzhi mi pa̱ na o gwang mi awalang va̱ n le ká̱ ikángkáng ka̱ atak nlung ìkum ká̱ oAmmon te, mi yichi na iya̱m inana iga nshì ûYawe.>> 
\p  
\v 32 Te uJefta pa̱l ga atak onəm oga aAmmon pa̱ na o lung ìkum ká̱ oza̱, kang uYawe na oza̱ ka̱ ashe awuwo.  
\v 33 Uza̱ lung oza̱ ɓan ka̱ aAroyer ga chu nkap mbin aMinnit, lyam ga chu aAbel-Keramim. Uza̱ zhì oga itong ìsəm pa̱ ìparəm, uza̱ gbá̱ng oza̱ pa̱ makmak. Wa nnà ta onəm oga aIsa̱rila nəm igwan ka̱ apal oAmmon. 
\p  
\v 34 Awalang va̱ uJefta le nzhi wò ka̱ aMizpa te, uyiyen uyenchar fa pa̱ na ô gwang na, ká̱ iya̱m nnə́m ká̱ nza̱m. Uwa ta uyiyen byet, uza̱ yà ká̱ ovan onunggwan, ka̱t te ovan ochar oro ka̱t.  
\v 35 Awalang va̱ uza̱ ya na te, uza̱ kakchi ilukwan wò ka̱ ashe nlak igwak, kang uza̱ ləp achu pa̱, <<Áyen mi, u gbá̱l mi chit. U ɓa ká̱ nɗaktak á mi chit. Ka̱kul n sóng anung ûYawe chit, nva mi ya ká̱ mɓəkchiɓəkchi ka̱t á.>> 
\p  
\v 36 Te uza̱ na ama̱n á na pa̱, <<Ápo mi, u yar nsar nnap-nlà ûYawe chit. Nəm á mi wa nva u là ká̱ anung ɓu á, ka̱kul uYawe na igwan á ɓu chit ka̱ apal okpa ìkum ɓu oAmmon.>>  
\v 37 Ǹnyi te, uza̱ là ûpo wò pa̱, <<Na ape á mi pa̱ parəm na n ga ashe oga aɗuktum, n yə́ng ikú nzəng ká̱ okpa mi, ka̱kul mi ga nkú na nyà uyenɓyen.>> 
\p  
\v 38 Te uza̱ là á na pa̱, <<Ga.>> Kang uza̱ re na ga nzəng ká̱ okpa wò ape pa̱ parəm. Oza̱ ga ashe oga aɗuktum kang oza̱ yə́ng ikú, ka̱kul pa̱ uza̱ i kú uwa ya uyenɓyen.  
\v 39 Kang ka̱ nkur ape pa̱ parəm va̱ ta te, uza̱ le ɓa atak apo wò, kang upupo nəm á na wa nva uza̱ ka̱ sóng anung á. Uza̱ wa nyi ununggwan chit ka̱t. 
\p Iya̱m va̱ ta sat nnap-nnəm ka̱ ashe aIsa̱rila pa̱,  
\v 40 ka̱ ashe nza̱ ìzun nggo te, ovanchar oga aIsa̱rila i fa i rəng ká̱ ikú aya aJefta uga Gileyat ka̱ apal nra pa̱ nneɗing. 
\c 12  
\s1 UJefta ká̱ onəm oga aEfrayim 
\p  
\v 1 Mmá wór onəm oga aEfrayim fa ɓut ká̱ oga iya̱m ìkum, kang oza̱ pa̱ng ga aZafon. Oza̱ là ûJefta pa̱, <<Sang kang u fa u ga u lung ìkum ká̱ oAmmon kang u là á yi pa̱ í ga nzəng ká̱ ɓu ka̱t yà? Ǹyangmata̱ te, í ga mpwak ɓu ká̱ nzhi ɓu ká̱ apər. 
\p  
\v 2 Te uJefta na ama̱n ôza̱ pa̱, <<Mmami ká̱ onəm mi, í dap ká̱ oAmmon pa̱ gənggəng, kang n wór wó te, ó ɓa pa̱ na ó ka̱m ishi mi ka̱ ashe awo oza̱ ka̱t.  
\v 3 Awalang va̱ n ya pa̱ ó ga nka̱mshi mi ka̱t te, n na ishi mi, m pa̱l pa̱ n lung oAmmon, kang uYawe na igwan á mi ka̱ apal oza̱. Ǹyangmata̱ te, iza̱ nak kang ó ɓa ká̱ nda va̱ ta̱ pa̱ na ó lung mi yà? 
\p  
\v 4 Te uJefta ɓut nkpaktak onəm oga Gileyat, kang oza̱ lung ìkum ká̱ onəm oga aEfrayim. Onəm oga aGileyat ri oza̱ ká̱ ìkum, ka̱kul onəm oga aEfrayim ka̱ là chit pa̱, <<Mmawo onəm oga aGileyat te, mmawo onəm ova chəng ìkum kang a bwam ka̱ ashe aEfrayim ká̱ aManase.>>  
\v 5 Onəm oga aGileyat kpán oga atak va̱ mí pa̱ng awang aUrdun kà̱ kang mí ga aEfrayim, kang nkpaktak awalang va̱ unəm uga aEfrayim uro uva̱ chə́r ìkum a ɓa pa̱ o pa̱l te, onəm oga aGileyat i ɓəp na pa̱, <<Mmaɓu unəm uga aEfrayim ɗò?>>A yà pa̱ uza̱ a là pa̱, <<O'o te,>>  
\v 6 oza̱ i là á na pa̱, <<là pa̱, <aShibolet.> >> kang a yà pa̱ uza̱ a là pa̱, <<aSibolet,>> ka̱kul nləlà ka̱ asəsa̱l i ma̱t na ma̱t te, oza̱ i kpán na kang i gba̱l ka̱ atak mpa̱ng awang aUrdun va̱ ta. Onəm oga aEfrayim va̱ mmá gbá̱ng ka̱ awalang va̱ ta te, ìkalong ìsəm pa̱ ineɗing ama̱n pa̱ parəm. 
\p  
\v 7 UJefta unəm uga Gileyat nap-akwali aIsa̱rila ìzun pa̱ ìkpa̱ɗing te uza̱ kú, kang mmá li na ka̱ ashe ìtong iro ka̱ aGileyat. 
\s1 UIbzan ká̱ uElon ká̱ uAbdon 
\p  
\v 8 Ka̱ nva̱ng aJefta te, uIbzan unəm uga aBet-Lehem náp akwali ôIsa̱rila.  
\v 9 Uza̱ ká̱ ovan onunggwan ìsəm pa̱ ishatɗing kang ká̱ ovan ochar ìsəm pa̱ ishatɗing. Te uza̱ na ovan ochar wò va̱ ta ka̱ ìvang ka̱ akum aro pa̱ɗi, kang uza̱ ka̱m ochar ôvan wò onunggwan ka̱ akum aro pa̱ɗi. UIbzan náp akwali âIsa̱rila ìzun pa̱ ifangshat.  
\v 10 Te uIbzan kú, kang mmá li na ka̱ aBet-Lehem. 
\p  
\v 11 Ka̱ nvəva̱ng te, uElon unəm uga aZebulun náp akwali âIsa̱rila ìzun pa̱ igba̱pchi.  
\v 12 Te uElon unəm uga aZebulun kú, kang mmá li na ka̱ aAijalon ka̱ ashe mbin aZebulun. 
\p  
\v 13 Ka̱ nvəva̱ng te, uAbdon uya aHillel unəm uga aPiraton náp akwali âIsa̱rila.  
\v 14 Uza̱ ká̱ ovan onunggwan ìsəm pa̱ ineɗing kang ká̱ okəka ovan onunggwan ìsəm pa̱ ishatɗing, ova i kwak oga azhaki ìsəm pa̱ ifangshat. Kang uza̱ náp akwali âIsa̱rila ìzun pa̱ ina̱nne.  
\v 15 Te uAbdon uya aHillel unəm uga aPiraton kú, kang mmá li na ka̱ aPiraton ka̱ ashe mbin aEfrayim ka̱ ìtong iga aɗuktum oAmalek. 
\c 13  
\s1 Amar aSamson 
\p  
\v 1 Kang ovan oga aIsa̱rila nəm nnap-mɓá̱ngɓa̱ng ka̱ mpyal aYawe kà̱ɗi, te uYawe na oza̱ ka̱ ashe awo oFilisti ìzun ìsəm pa̱ ineɗing. 
\p  
\v 2 Unəm uro uwa ka̱ yà aɗiɗin pa̱ uManowa ka̱ ìtong aZora ka̱ akum ìjili aDan. Uchəchar asəsat.  
\v 3 Te uma̱leka aYawe ɓa atak achar va̱ ta kang à là á na pa̱, <<Dər, u səsat u mar ka̱t, ǹnyi te, ɓu ga ǹyar anyam ɓu mar uyen ununggwan.  
\v 4 Ǹyangmata̱ te, nak ishi ká̱ iya̱m va̱ ta̱, kang wa wá ndəng ìba̱ngba̱ng ǹsámsàm, ka̱t te iya̱m ngwa iro ikamkam, ka̱t te wa ri iya̱m iga ajan ka̱t.  
\v 5 Ɓu ga ǹyar anyam, ɓu mar uyen ununggwan, kang mí yà ká̱ nkpan ishi á na ka̱t. Ka̱kul uyen va̱ ta i yà uNazarat, ugargar Înan ka̱ ashe afu na byet. Uwa i ɓan nka̱mshi aIsa̱rila ka̱ ashe awo oFilisti. 
\p  
\v 6 Te uchar va̱ ta ɓa kang là ûɓar wò pa̱, <<Unəm Inan uro ɓa atak mi, a nəm ayər ǹya byet, asa̱l awuwu ɓu là pa̱ asa̱l awu ama̱leka Inan. Mmami te, m ɓəp pa̱ uza̱ fa ka̱ che yà ka̱t, uza̱ là aɗin wò á mi ka̱t.  
\v 7 Te uza̱ là á mi pa̱, <Ɓu ga ǹyar anyam kang ɓu mar uyen ununggwan. Ǹyangmata̱ te, kang wa wá ndəng ìba̱ngba̱ng ǹsámsàm, ka̱t te iya̱m ngwa iro ikamkam, ka̱t te wa ri iya̱m iga ajan iro ka̱t, ka̱kul uyen va̱ ta i yà uNazarat, ugargar Înan ka̱ ashe afu na byet i ga i chu nra ikúku.> >> 
\p  
\v 8 Te uManowa nəm afar ûYawe pa̱, <<ÁYawe, n chal pa̱ u re unəm Inan va̱ ka̱ u re ɓa atak yi á ɓa kà̱ɗi, na uza̱ a ɗyang á yi asa̱l va̱ i kpán uyen ununggwan va̱ mí ga mməmar á.>> 
\p  
\v 9 Te Inan fe achal aManowa, kang uma̱leka Inan ɓa atak achar va̱ ta kà̱ɗi ka̱ awalang va̱ uza̱ ka̱ ashe mpom. Ǹnyi te, uɓəɓar uManowa ka̱ yà nzəng ká̱ na ka̱t.  
\v 10 Uchar va̱ ta gha̱n ga atak á ɓar wò kang uza̱ là á na pa̱, <<Unəm va̱ ka̱ ɓa atak mi ká̱ nda va̱ te, á ɓa chit kà̱ɗi.>> 
\p  
\v 11 Te uManowa wong yar nva̱ng achar wò. Awalang va̱ uza̱ ɓa chu atak anəm va̱ ta te, uza̱ ɓəp na pa̱, <<Mmaɓu na unəm va̱ u là nnap ka̱ uchar mi ɗò?>> Te uza̱ na ama̱n pa̱, <<À, mmami na.>> 
\p  
\v 12 Te uManowa ɓəp na pa̱, <<Awalang va̱ nnap-nlà ɓu i yə́l te, nza̱ apir nnap-nnəm í ɗyang ûyen va̱ ta yà? Iza̱ i yà inok ayen va̱ ta yà? 
\p  
\v 13 Kang uma̱leka aYawe là ûManowa pa̱, <<Nkpaktak iya̱m va̱ n là ûchar ɓu te, re uza̱ nak ishi ká̱ pa̱ dakdak, na uza̱ a kpak.  
\v 14 Uza̱ i yà ká̱ nrì iya̱m va̱ pa̱ káp fa ka̱ izər ikun ìba̱ngba̱ng ka̱t, kang uza̱ a wá ndəng ìba̱ngba̱ng ǹsámsàm, ka̱t te nchè, ka̱t te uza̱ a ri iya̱m ro iga adak ka̱t. Nkpaktak iya̱m va̱ n nak á na te, uza̱ a kpak pa̱ dakdak.>> 
\p  
\v 15 Te uManowa là ûma̱leka aYawe pa̱, <<Wa ma̱n te, lok yi pa̱ ɗa̱p na i da̱mshi ìzhe iya iɓəl á ɓu kang.>> 
\p  
\v 16 UMa̱leka aYawe na ama̱n ûManowa pa̱, <<Ɓu ɗa̱t mi te, mi yà ká̱ nri iya̱m-nrì ɓu ka̱t. Ǹnyi te, a yà pa̱ ɓu da̱mshi iya̱m inana iga nshì te, wa na ûYawe.>> Ka̱kul uManowa uwa nyi chit pa̱ uza̱ uma̱leka aYawe ka̱t. 
\p  
\v 17 Kang uManowa ɓəp ûma̱leka aYawe pa̱, <<Iza̱ aɗin ɓu yà? Ka̱kul na awalang va̱ nnap-nlà ɓu i yə́l te, í na ichumchum á ɓu.>> 
\p  
\v 18 Te uma̱leka aYawe là á na pa̱, <<Ka̱kul iza̱ kang ɓu ɓəp aɗin mi yà? Aɗin mi ɗaktak byet ɓu yà ká̱ nkpan ìpipir ka̱t>>  
\v 19 Te uManowa kpán iya iɓəl nzəng ká̱ iya̱m inana ipirkur, kang uza̱ yichi ka̱ apal ìpang ûYawe. Kang uYawe nəm iya̱m iga nɗaktak ka̱ mpyal aManowa ká̱ uchar wò.  
\v 20 Awalang va̱ aməlam apər wong ka̱ atak nshì iya̱m awop i ga apaɓur te, uma̱leka aYawe wong ka̱ ashe aməlam apər va̱ ta ɓa ga ashe apaɓur. Nva̱ uManowa ká̱ uchichar ya iya̱m va̱ ta te, oza̱ tak ka̱ mbin zəp ká̱ afu.  
\v 21 Awalang va̱ uma̱leka aYawe nyám ishi wò ûManowa ká̱ uchichar lap ka̱t te, uManowa nyi ɗak pa̱ uma̱leka aYawe. 
\p  
\v 22 Kang uManowa là ûchar wò pa̱, <<Nkpak í ga nkú, ka̱kul í ya Inan chit.>> 
\p  
\v 23 Ǹnyi te, uchichar na ama̱n á na pa̱, <<Ká̱ yà pa̱ uYawe ɗom ngbá̱ng yi te, uza̱ ká̱ ka̱m iya̱m inana iga nshì ká̱ iya̱m inana iga ipirkur ka̱ awo yi, ka̱t te uza̱ ká̱ nyám ká̱ oga iya̱m va̱ ta̱ á yi pa̱ kpaktak ka̱t te, ká̱ là oga iya̱m va̱ ta̱ á yi ka̱ ashe awalang va̱ ta̱ ka̱t.>> 
\p  
\v 24 Uchar va̱ ta mar uyennunggwan, kang uza̱ sok aɗin á na pa̱ uSamson. Uyen va̱ ta rup, kang uYawe nak nnap-nnəna̱n á na.  
\v 25 Kang aRuhu aYawe ɓan nnəm inok ká na ka̱ awalang va uza̱ ka̱ ntəm ka̱ aMahane Dan, ka̱ ishimshe aZora ká̱ aEshtawol. 
\c 14  
\s1 Ìvang aSamson 
\p  
\v 1 USamson fa ga aTimna, kang uza̱ ya uyenɓyen uro ka̱ ta ka̱ ashe ovanchar oFilisti.  
\v 2 Awalang va̱ uza̱ le nzhi te, uza̱ là ûpo wò ká̱ unang wò pa̱, <<N ya uchar uro chit ka̱ aTimna ka̱ ashe ovanchar oFilisti, kang n ɗom pa̱ ó ka̱m ichar á mi ká̱ na ǹyangmata̱.>> 
\p  
\v 3 Te upupon ká̱ unənang na ama̱n á na pa̱, <<U lang ovanchar uka̱mka̱m ka̱ ashe onəm ɓu, ka̱t te ka̱ ashe nkpaktak onəm yi, kang ɓu ɗom ga nka̱m uchar ka̱ ashe oFilisti, onəm oga ache amulur ɗò?>> 
\p Ǹnyi te, uSamson là ûpo wò pa̱, <<Ó ka̱m uwa á mi, ka̱kul uwa ta n ya ɓyen ká̱ mi.>> 
\p  
\v 4 Upupo ká̱ unənang te nyi pa̱ nnap va̱ ta fa ka̱ atak aYawe ka̱t, ka̱kul uYawe ka̱ mmwo asa̱l va o nyám ntàn ôFilisti ká̱. Ka̱kul ka̱ awalang va̱ ta te, oFilisti oma i nəm iponzhi ka̱ apal oIsa̱rila. 
\p  
\v 5 Te uSamson ga aTimna nzəng ká̱ upupo ká̱ unənang. Awalang va̱ oza̱ ɓa chu oga iram ìba̱ngba̱ng iga aTimna te, ìya ìlir iro fa ɓa nggwang oza̱ i ɗúm ká̱ ìkum.  
\v 6 Te aRuhu aYawe vang ka̱ apal aSamson ká̱ ìkam, kang uza̱ kpán ìya ìlir va̱ ta ká̱ awo kakchi ɓu là pa̱ uza̱ kakchi ìya ìɓəl. Ǹnyi te, uza̱ là ûpo wò ká̱ unang wò iya̱m va̱ uza̱ nəm ka̱t.  
\v 7 Te uza̱ fə́r ga là nnap ká̱ uchar va̱ ta, kang uSamson ya pa̱ uchar va̱ ta ɓiɓyen ká̱ wò. 
\p  
\v 8 Ka̱ nva̱ng oga nra pa̱ ɗa̱p te, uza̱ le pa̱ o ka̱m na. Te uza̱ lyep pa̱ na ô dər akúm ìlir va̱ uza̱ ka̱ gbá̱l, kang uza̱ ga ya irizhe təm chit ka̱ ashishe ká̱ mmàl irizhe.  
\v 9 Uza̱ zə̀p mmàl irizhe va̱ ta ka̱ ashe awo wò, kang uza̱ ka̱ ngga uza̱ ka̱ nriri. Awalang va̱ uza̱ ɓa chu atak apo wò ká̱ unang wò te, uza̱ na oza̱ ká̱, kang oza̱ ri. Ǹnyi te, uSamson là ôza̱ pa̱ o zəp ka̱ ashe akúm ìlir ka̱t. 
\p  
\v 10 Te, upupo fə́r ga nzhi achar va̱ ta, kang uSamson nak mmá nəm iya̱m-nrì ká̱ iya̱m ngwá iga mɓut ka̱ ta, ka̱kul ovanza̱m i nəm wa nnà ta.  
\v 11 Awalang va̱ oFilisti ya na te, oza̱ ɓa ká̱ okpa ìsəm pa̱ ishatɗing pa̱ oza̱ a təm nzəng ká̱ na. 
\p  
\v 12 Kang uSamson là ôza̱ pa̱, <<Re n gba achu aro á wó, kang a yà pa̱ unəm uro á là ìpipir á mi ka̱ ashe nra pa̱ nfangshat ngga nəm nchàng izər va̱ ta̱ te, mi na ìlukwan alinin á na ìsəm pa̱ ishatɗing ká̱ oga inang ilukwan ìsəm pa̱ ishatɗing.  
\v 13 Kang a yà pa̱ nlà ìpipir a ma̱t wó te, ó ga nna ilukwan á mi iga alinin ìsəm pa̱ ishatɗing ká̱ oga inang ìlukwan ìsəm pa̱ ishatɗing.>> 
\p Te oza̱ là á na pa̱, <<Là ngba achu ɓu va̱ na í fe.>> 
\p  
\v 14 Te uza̱ là ôza̱ pa̱, 
\q1 <<Ka̱ atak anəm uga nrì iya̱m, iya̱m-nrì fa, 
\q2 ka̱ atak anəm uga nkam, te iya̱m ichangchang fa.>> 
\m Kang ka̱ ashe nra pa̱ nshatɗing te, oma nyi ìpir ngba achu va̱ ta chit ka̱t. 
\p  
\v 15 Ka̱ nra ngga nneɗing te, oza̱ là ûchar aSamson pa̱, <<Tàng uɓar ɓu na uza̱ á là ìpir ngba achu va̱ ta á yi, ka̱t te, í ga mpwak ɓu ká̱ nzhi apo ɓu ká̱ apər. Ó wór yi ka̱ ta̱ pa̱ na ó ka̱m idur yi ɗò? 
\p  
\v 16 Te uchar aSamson yə́ng ka̱ mpyal aɓar wò, kang a là pa̱, <<U yang mi yang, u ma̱n mi ka̱t. U gba achu ônəm mi, ǹnyi te, u là ìpipir á mi ka̱t.>> 
\p Te, uSamson na ama̱n á na pa̱, <<Dər, n là ìpipir ûpo mi ká̱ unang mi ka̱t, ka̱kul iza̱ kang mi là á ɓu jiwò yà?>> 
\p  
\v 17 Uza̱ pak inok ayə́ng ka̱ mpipyal ka̱ ashe nkpaktak nra pa̱ nfangshat aga nnəm nchang izər va̱ ta. Á nak te, ka̱ nra ngga nfangshat te, uza̱ là ipir ngba achu va̱ ta á na, ka̱kul uza̱ pak nɗak na pa̱ ɗəkər. Nnà chit te uchar va̱ ta ga shal ìpir ngba achu va̱ ta ônəm wò ɗak. 
\p  
\v 18 Ka̱ nra ngga nfangshat kang alum i tar te, onunggwan oga ìtong va̱ ta là ìpipir á na pa̱, 
\q1 <<Iza̱ ji mmàl irizhe ká̱ nchàng yà? 
\q2 Iza̱ ji ìlir ká̱ ìkam yà?>> 
\p Te uSamson là ôza̱ pa̱, 
\q1 <<Ká̱ yà pa̱ ó wap iram ká̱ ìya ìna mi ichar ka̱t te, 
\q1 ka̱ ó nyi ìpir ngba achu mi va̱ ta ka̱t.>> 
\p  
\v 19 Te aRuhu aYawe vang ka̱ apal ishishi ká̱ ìkam, kang uza̱ fa ga aAshkelon, uza̱ gbá̱ng onəm ìsəm pa̱ ishatɗing, uza̱ wur iya̱m oza̱, kang uza̱ na oga ilukwan oza̱ ônunggwan va̱ ka̱ là ìpir ngba achu va̱ ta á na á. Ǹnyi te, ìgwak lak uSamson pa̱ gənggəng ka̱ apal nnap va̱ ta, kang uza̱ le ga nzhi apo wò.  
\v 20 Te mmá yar uchar aSamson mmá na ûkpəkpa uva nəm ikpa ìvang á na. 
\c 15  
\s1 USamson pyát akat nnap ôFilisti 
\p  
\v 1 Á gba̱ng nva̱ng pa̱ ɗa̱p, ka̱ ashe awalang aga mɓən ìzangzəng te, uSamson kpán ìya ìɓəl ga nre anung ûchar wò ká̱. Uza̱ là pa̱, <<N ɗom tar ashe mbək achar mi.>> Ǹnyi te, upo achichar ma̱n á na pa̱ uza̱ a tar ashe ka̱t. 
\p  
\v 2 Upo achichar là pa̱, <<Nnandər, ka̱ n rəng pa̱ u yang ka̱ na chit, ka̱kul nva̱ ta te, n na ìvang ká̱ na chit ûkpa ɓu. Ugənanggənang uɓwakan ɓyen ji na ka̱t ɗò? N chal ɓu ka̱m uwa ka̱ anungnung.>> 
\p  
\v 3 Te uSamson là ôza̱ pa̱, <<Ka̱ awalang ava̱ ta̱ jiwò te, mi yà ká̱ mpat nro ka̱kul iya̱m iɓá̱ngɓa̱ng va̱ mi ga nnənəm ôFilisti ka̱t.  
\v 4 Te uSamson fa ga wur oga nchám ìgba̱l pa̱ ishatɗing, kang uza̱ ga̱ɓa̱n oza̱ ran pa̱ ìparpar aswal ká̱ aswal. Te uza̱ ran apitila aga apər ka̱ ishimshe nza̱ nran nggo.  
\v 5 Ka̱ nva̱ng va̱ uza̱ mwak apər chit ka̱ oga apitila, te uza̱ re oza̱ ga ashe iram oFilisti. Te a ri iya̱m-nrì va̱ mmá ɓən chit, ká̱ iva̱ na tong ka̱ ashe ìram, kang a pwak oga iram ìba̱ngba̱ng ká̱ oga iram mpyet oza̱ kpa. 
\p  
\v 6 Awalang va̱ oFilisti ɓəp pa̱, <<Uda nəm iya̱m va̱ ta̱ yà?>> te, mmá là ôza̱ pa̱, <<USamson, ugwar aTimna, ka̱kul uza̱ yar uchichar uza̱ na ûkpa ìvəvang.>> 
\p Te oFilisti ga pwak uchar va̱ ta ká̱ upupo ká̱ apər, kang oza̱ kú.  
\v 7 USamson là ôza̱ pa̱, <<Ka̱kul iya̱m va̱ ó nəm ta̱ te, n sóng anung pa̱ mi yà ká̱ nrəre ka̱t, yà mi pyát akəkat kang.>>  
\v 8 Kang uza̱ ru oza̱ ká̱ ìkum ká̱ nkam, kang a gbá̱ng oza̱ pa̱ makmak. Te uza̱ le ga təm ka̱ ashe agba̱k ro ka̱ ìpang aEtam. 
\p  
\v 9 Te oFilisti kyén ga ləp apa̱k ka̱ aYahuda, kang oza̱ ga zàl ishi oza̱ ka̱ aLehi.  
\v 10 Te onəm oga aYahuda ɓəp oza̱ pa̱, <<Iza̱ nak kang ó ɓa ìkum ka̱ yi yà?>> 
\p Kang oFilisti na ama̱n pa̱, <<Í ɓa pa̱ í ran uSamson, na í nəm á na wa nva uza̱ ka̱ nəm á yi á.>> 
\p  
\v 11 Te onunggwan oga aYahuda ìkalong pa̱ ishatɗing fəng vang ashe agba̱k va̱ ka̱ ìpang aEtam, kang oza̱ là ûSamson pa̱, <<U nyi pa̱ oFilisti oma i nəm iponzhi ka̱ apal yi ka̱t ɗò? Te sang kang u nəm á yi pa yà?>> 
\p USamson na ama̱n ôza̱ pa̱, <<Wa nva oza̱ nəm á mi te, wa nnà ta n nəm oza̱ kpa.>> 
\p  
\v 12 Te oza̱ là á na pa̱, <<Í ɓa pa̱ í ran ɓu, na í na ɓu ka̱ ashe awo oFilisti.>> 
\p Te uSamson là ôza̱ pa̱, <<Ó sóng anung á mi pa̱, mmawó na ká̱ ishi wó ó ga ngbá̱l mi ka̱t.>> 
\p  
\v 13 Te oza̱ là á na pa̱, <<Pa ka̱t. Í ga ngbá̱l ɓu ka̱t. Mmayi te, í ga nran ɓu í na oza̱.>> Te oza̱ ran na ká̱ asang apipye pa̱ parəm, kang oza̱ fa ká̱ na ka̱ ashe ìpang va̱ ta.  
\v 14 Awalang va̱ uza̱ ɓa aLehi te, oFilisti wong ká̱ nggha̱n pa̱ ó gwang na oza̱ í nə́m achu. Ta byet te, aRuhu aYawe vang ka̱ apal aSamson ká̱ ikam. Oga asang va̱ mmá ran awuwo ká̱ sərak ɓu là pa̱ afini va ri apər á, kang oga asang va̱ ta ka̱ awuwo tak ka̱ mbin.  
\v 15 Te uza̱ ya akup apipye aro aga njwalak azhaki, uza̱ yichi awo yar ká̱, kang uza̱ gbá̱ng oFilisti ká̱ ìkalong pa̱ ìzəng. 
\p  
\v 16 Te uSamson shì nnap-nshì pa̱, 
\q1 <<Ká̱ akup njwalak azhaki 
\q2 n gbá̱ng onunggwan ìkalong. 
\q1 Ká̱ akup njwalak azhaki 
\q2 m ɓut oza̱ nchələng ka̱ apal nchələng.>> 
\m  
\v 17 Awalang va̱ uza̱ gbá̱l ká̱ nnap-nlà te, uza̱ mandar akup njwalak azhaki va̱ ta. Kang mmá wór atak va̱ ta pa̱ aRamat-Lehi. 
\p  
\v 18 Kang ka̱kul ndəng gbá̱l na pa̱ gənggəng te, uza̱ chal uYawe, uza̱ là pa̱, <<Mmaɓu na u ná igwan ichumchum va̱ ta̱ ûzwal ɓu. Ǹyangmata̱ te, mi ga nkú ká̱ ndəng ngba̱l, kang mi tar ka̱ ashe awo onəm oga ache amulur va̱ ta̱ ɗò?>>  
\v 19 Te Inan bol ache aro ka̱ mbin aLehi, kang ndəng shák fa ka̱ ashishe. Nva̱ngva̱ uSamson wá te, nnap-nnənəm le ɓa, kang ìkəkam le kpa. Ka̱kul nva̱ ta te, mmá wór aɗin atak va̱ ta pa̱, <<aEn-Hakore,>> nna yà ka̱ aLehi ɓa chu nda va̱ ta̱. 
\p  
\v 20 USamson náp akwali ôIsa̱rila ìzun ìsəm pa̱ ìparəm ka̱ ashe nra va̱ oFilisti ka̱ yà ka̱ nnəm iponzhi ká̱ oza̱ á. 
\c 16  
\s1 USamson ká̱ uDelila 
\p  
\v 1 Ká̱ nda aro te, uSamson ga aGaza, kang uza̱ ya uchar umaimai ro ka̱ ta. Te uza̱ tar ga ra ká̱ na.  
\v 2 Mmá là ônəm oga aGaza pa̱, <<USamson uwa ɓa ka̱ ta̱.>> Te, oza̱ ga gang atak va̱ ta, kang oza̱ ra anyimnyal ka̱ na ká̱ izwam ka̱ anung asa̱l aga ntar ìtong va̱ ta. Oza̱ ma̱ng pa̱ kwak ka̱ ashe izwam va̱ ta, oza̱ í là pa̱, <<Re í lok atak aghánghàn aga anung ipin kang í gbá̱l na.>> 
\p  
\v 3 Ǹnyi te uSamson ra ka̱ ta ga chu ishimshe izwam. Te, uza̱ wong kpán oga anung nzhi aga ntar ìtong va̱ ta, nzəng ká̱ oga ndədar pa̱ mparəm, kang uza̱ yənggət oza̱ tur le nzəng ká̱ ndar ngga nvərang anunung, ká̱ nkpaktak oga iya̱m va̱ ka̱ izər anung nzhi va̱ ta. Uza̱ wur oza̱ nak ka̱ agar wò, kang uza̱ kyén ká̱ oza̱ ga apal aɗuktum va̱ ka̱ mpyal aHebron. 
\p  
\v 4 Ka̱ nvəva̱ng te, uSamson wong ɓan mma̱n uchar uro ka̱ mBa̱nda̱m aSorek, uva aɗiɗin pa̱ uDelila.  
\v 5 Te oponzhi oFilisti ɓa ga atak achar va̱ ta, kang oza̱ là á na pa̱, <<Ɗak na u tàng na pa̱ shiriri mwote uza̱ i nyám atak ìkam wò iga nəm ayər va̱ ta̱, ká̱ asa̱l va̱ í nəm kang i ji nkəkam, na í ran na í nəm igwan ká̱ na. Nza̱ uzəngtəng yi nggo i na aazurfa á ɓu ìkalong pa̱ ìzəng ká̱ ìgba̱l pa̱ ìzəng.>> 
\p  
\v 6 Te uDelila là ûSamson pa̱, <<N chal ɓu, nyám á mi atak va̱ nkam ɓu nchumchum va̱ ta̱ i fa kà̱, ká̱ asa̱l va̱ mí ran ɓu ká̱ kang mí ji nkam ɓu á.>> 
\p  
\v 7 USamson na ama̱n á na pa̱, <<A yà pa̱ unəm a ran mi ká̱ oga asang apipye aga nlyat ìjang pa̱ fangshat ava na wom chit ka̱t te, nkam mi i yà wa nji aɓoshi onəm.>> 
\p  
\v 8 Te oponzhi oFilisti va̱ ta ɓa ká̱ oga asang apipye aga nlyat ìjang va̱ ta á na pa̱ fangshat, ava nna wom chit ka̱t, kang uza̱ ran na ká̱ oga asang va̱ ta.  
\v 9 Uza̱ wa ka̱ yà ká̱ onəm va̱ ra anyimnyal ka̱ ashe afu nzhi va̱ ta. Te uDelila ləp achu á na pa̱, <<ÁSamson, oFilisti oma ta̱ ka̱ apal ishi ɓu.>> Ǹnyi te, uza̱ páng oga asang aga nlyat ìjang va̱ ta ɓu là pa̱ afini va mmá mang ka̱ ashe apər. Te, mmá nyi atak va̱ ìkəkam bwam kà̱ ka̱t. 
\p  
\v 10 Te uDelila là ûSamson pa̱, <<Dər, u tàng mi, u nap akwam á mi. Ǹyangmata̱ mmami ka̱ nchal ɓu, là á mi asa̱l va̱ mí ran ɓu ká̱.>> 
\p  
\v 11 Te uSamson là á na pa̱, <<A yà pa̱ unəm a ran mi ká̱ oga asang apipye ava na mmá nəm inok ká̱ oza̱ chit ka̱t te, ìkam mi i yà wa nji aɓoshi onəm.>> 
\p  
\v 12 Te uDelila wur oga asang apipye ran na ká̱, kang uza̱ ləp achu á na pa̱, <<ÁSamson, oFilisti oma ta̱ ka̱ apal ishi ɓu.>> Onəm ma ka̱ ra anyimnyal ka̱ na ka̱ ashe afu nzhi va̱ ta. Ǹnyi te, uSamson páng oga asang va̱ ta ka̱ awo wò ɓu là pa̱ oga afini. 
\p  
\v 13 Te uDelila là ûSamson pa̱, <<Nna mmaɓu ka̱ ntàng mi ɓa chu awalang va̱ ta̱, kang mmaɓu ka̱ nnap akwam á mi. Là á mi asa̱l va̱ mí ran ɓu ká̱.>> 
\p USamson na ama̱n á na pa̱, <<A yà pa̱ unəm a tát oga nlok akpap ishi mi pa̱ nfangshat va̱ ta̱ ká̱ afini ka̱ izər mɓuyər ngga nlok iya̱m te, nkam mi i yà wa nji aɓoshi onəm.>> Awalang va̱ uza̱ ka̱ nra nda te, uDelila tát oga nlok ishishi aga afangshat va̱ ta ká̱ afini,  
\v 14 kang uza̱ ran oza̱ ka̱ izər mɓuyər ngga nlok iya̱m. 
\p Te uza̱ ləp achu á na pa̱, <<ÁSamson, oFilisti oma ta̱ ka̱ apal ishi ɓu.>> Uza̱ yenda̱l ka̱ iwu nda kang uza̱ zəp mɓuyər ngga nlok iya̱m va̱ ta, nzəng ká̱ afini va̱ mmá tát ká̱. 
\p  
\v 15 Te, uDelila là á na pa̱, <<Sang kang ɓu là pa̱, <m ma̱n ɓu ma̱n,> ǹnyi te, ìgwak ɓu nzəng ká̱ mi ka̱t yà? U tàng mi chit nva̱ng pa̱ nshatɗing, kang na u là atak va̱ á mi chit nkam ɓu nchumchum va̱ kà̱ ka̱t.>>  
\v 16 Wa nnà ta nza̱ nra nggo uza̱ i pak nɗak na, ga chu awalang va̱ ìgwak ga lak na na uza̱ i kukú. 
\p  
\v 17 Ka̱ nkukur te, uSamson là nnandər igwak wò á na, uza̱ là pa̱, <<Nna mmá kpán ishi mi chit ká̱ ikpal ishi ka̱t, ka̱kul mmami uNazarat uva mmá gar Înan ka̱ ashe afu anang mi na byet. A yà pa̱ mmá kpán ishi á mi te, nkam mi i kap ká̱ mi, kang mi yà wa aɓo onəm. 
\p  
\v 18 Awalang va̱ uDelila ya pa̱ uza̱ là nnandər á wò chit te, uza̱ re nre mmá wór oponzhi oFilisti. Uza̱ là pa̱, <<Ó ɓa kà̱ɗi, ka̱kul uza̱ là nnandər ìgwak wò á mi chit.>> Te oponzhi oFilisti ɓa atətak ká̱ mbwai va̱ ka̱ awo oza̱.  
\v 19 Uza̱ nak na ra nda ka̱ apal oga isong wò, uza̱ wór unəm uro kpat oga nlok akpap ishishi aga afangshat va̱ ta. Te izər ɓan nrusok ká̱ na, kang ìkəkam kap ká̱ na. 
\p  
\v 20 Te uDelila là pa̱, <<ÁSamson, oFilisti oma ta̱ ka̱ apal ishi ɓu.>> 
\p Te uza̱ yenda̱l ka̱ iwu nda, kang uza̱ rəng pa̱, <<Mi wong mi fa wa mmatmat, ká̱ nkam izər mi.>> Ka̱kul uza̱ nyi pa̱ uYawe kap ka̱ wò chit ka̱t. 
\p  
\v 21 Te oFilisti kpán na, oza̱ zəp iwu ka̱ na, kang oza̱ ga ká̱ na ka̱ aGaza, te oza̱ ran na ká̱ oga nzwar ngga acham arəzang, kang oza̱ nak na i kpà iya̱m ka̱ ashe nzhi ikan.  
\v 22 Ǹnyi te, akpap ishishi ɓan nfa ka̱ɗi ka̱ nva̱ngva̱ mmá kpán ishi á na chit á. 
\s1 Ikú aSamson 
\p  
\v 23 Ǹyangmata̱ te, oponzhi oFilisti ɓut pa̱ na ó yichi nləfər iya̱m ipápà nchumchum, na ó shep inan oza̱ uDagon. Kang oza̱ là pa̱, <<Inan yi na igwan á yi chit ka̱ apal aSamson ukpa ìkum yi.>> 
\p  
\v 24 Awalang va̱ onəm va̱ ta ya na te, oza̱ shep inan oza̱, oza̱ i là pa̱, 
\q1 <<Inan yi na ukpa ìkum yi chit, 
\q2 ka̱ ashe awo yi, 
\q1 unəm uva nak mbin yi ra agung, 
\q2 kang à gbá̱ng onəm yi pa̱ makmak á.>> 
\p  
\v 25 Awalang va̱ oza̱ ka̱ ashe nchàng ìgwak pa̱ makmak te, oza̱ là pa̱, <<Mmá ɓa ká̱ uSamson, na uza̱ á na nchàng ǹyəl á yi.>> Te mmá wór uSamson ka̱ ashe nzhi ikan, kang uza̱ na nchàng ǹyəl ôza̱. 
\p Awalang va̱ oza̱ nak na sat ka̱ ishimshe oga ndar ngga nda̱r nzhi va̱ ta pa̱ mparəm te,  
\v 26 uSamson là ûyen uga ndap wò pa̱, <<Ga ká̱ mi na n dok izər oga ndar va̱ da̱r nzhi va̱ ta̱, na n da̱r izər ka̱ izər oza̱.>>  
\v 27 Ǹyangmata̱ te, nzhi va̱ ta yəl ká̱ onunggwan, ká̱ ochar. Nkpaktak oponzhi oFilisti oma yà ka̱ ta, kang onunggwan, ká̱ ochar oma yà ka̱ ta á chu ìkalong pa̱ ishatɗing ka̱ apal ova ka̱ ndər uSamson, nva̱ uza̱ kà̱ nna nchàng nyəl oza̱ á.  
\v 28 Te uSamson far afar ûYawe pa̱, <<ÁYawe uGa ngGatək, rəng ká̱ mi. ÁInan, n chal ɓu, na ìkam á mi ka̱ɗi nva̱ng pa̱ nzəng byet, na m pyát akat ka̱ apal oFilisti, ka̱kul iwú mi iga ìparəm va̱ oza̱ zəp á.>>  
\v 29 Kang uSamson kpán oga ndar ngga ishimshe ngga mparəm va̱ na ikam n̂zhi va̱ ta. Awuwo ari ka̱ apal aro, kang awuwo apəra̱m ka̱ apal nro.  
\v 30 USamson là pa̱, <<Re n kú nzəng ká̱ oFilisti va̱ ta̱.>> Te uza̱ da̱n ká̱ nkpaktak ikam wò, kang nzhi va̱ ta shin ka̱ apal oponzhi oFilisti, ká̱ nkpaktak onəm va̱ ka̱ ashishe. Onəm va̱ uza̱ gbá̱ng ka̱ awalang ikúku te, á yə́l ji ovəngva̱ ji uza̱ gbá̱ng ka̱ awalang va̱ uwa yà ká̱ irirì. 
\p  
\v 31 Te ogənanggənang ká̱ nkpaktak nzhi apupo fa ga yar akúkum, oza̱ le ga li na ka̱ ishimshe aZora ká̱ aEshtawol ka̱ ashe awap apupo uManowa. USamson ka̱ náp akwali ôIsa̱rila chit izun ìsəm pa̱ ìparəm. 
\c 17  
\s1 Ìchər aMika 
\p  
\v 1 Unəm uro uwa ka̱ yà ka̱ ìtong iga aɗuktum aEfrayim aɗiɗin pa̱ uMika.  
\v 2 Ká̱ nda nro uza̱ là ûnang wò pa̱, <<N fe u vyap unəm va̱ wur aazurfa ɓu ìkalong pa̱ ìzəng ká̱ ìgba̱l pa̱ ìzəng va̱, dər nna ta̱, mmami nà n wur.>> 
\p Te unənang là pa̱, <<UYawe á nak nnap-nnəna̱n á ɓu, áyen mi.>> 
\p  
\v 3 Awalang va̱ uza̱ le ká̱ aazurfa ìkalong pa̱ ìzəng ká̱ ìgba̱l pa̱ ìzəng va̱ ta ûnang wò te, unənang là pa̱, <<Ka̱kul kang nsur nro a kpán uyen mi ka̱t te, n gor aazurfa mi ûYawe. Mí kpà ala̱ka̱n ìchər ká̱ akun, kang mí ɓam izəzər ká̱ aazurfa. Ǹyangmata̱ te, mi le ká̱ aazurfa va̱ ta á ɓu.>> 
\p  
\v 4 Te uMika le ká̱ aazurfa va̱ ta ûnang wò, kang unənang kpa̱k aazurfa ìgba̱l pa̱ ìparəm na ûnəm uga nla ala, uva nəm ala̱ka̱n ìchər va̱ ká̱. Te mmá nak oza̱ ka̱ ashe nzhi aMika. 
\p  
\v 5 Ǹyangmata̱ te, uMika me nzhi iya̱m ngwop ka̱kul ìchər va̱ ta, kang uza̱ nəm ìlukwan ìkwoksok ká̱ oga ichər iro. Te uza̱ kyer uzəngtəng ka̱ ashe ovəvan onunggwan sat unəm uga mpyal iya̱m ngwuwop.  
\v 6 Ka̱ ashe oga nra va̱ ta te, oIsa̱rila yà ká̱ uponzhi ka̱t, udanggo i nəm iya̱m va ma ká̱ na. 
\p  
\v 7 Ka̱ awalang va̱ ta te, uyenza̱m uro ka̱ akum ìjili aLawi, uva ka̱ yà ntəm ka̱ aBet-Lehem aga aYahuda,  
\v 8 re ìtong va̱ ta pa̱ na ô ga ô ram atak va̱ o təm kà̱. Uza̱ ka̱ ashe achen te, uza̱ ɓa chu nzhi aMika ka̱ ìtong iga aɗuktum aEfrayim. 
\p  
\v 9 Te uMika ɓəp na pa̱, <<U fa ka̱ che yà?>> 
\p Kang uza̱ là pa̱, <<Mmami akum ìjili aLawi, n fa ka̱ aBet-Lehem aga aYahuda, kang mmami ka̱ nram atak pa̱ n təm kà̱.>> 
\p  
\v 10 Te uMika là á na pa̱, <<Təm ká̱ mi, na ú yà upo mi ká̱ unəm uga mpyal awop mi, te mi na aazurfa á ɓu pa̱ gba̱pchi ka̱ ashe ìzun, nzəng ká̱ ilukwan ɓu, ká̱ iya̱m-nrì ɓu.>>  
\v 11 Te uLawi va̱ ta ma̱n ká̱ iya̱m va̱ uza̱ là, kang uyenza̱m va̱ ta təm wa azəngtəng ka̱ ashe ovəvan onunggwan.  
\v 12 Te uMika nak na sat unəm uga mpyal awuwop, kang uyenza̱m va̱ ta təm ka̱ nzhi aMika.  
\v 13 Kang uMika là pa̱, <<Ǹyangmata̱ te, n nyi chit pa̱ uYawe iga nnəm inəna̱n á mi, ka̱kul n yà ká̱ uLawi chit unəm uga mpyal awop mi.>> 
\c 18  
\s1 UMika ká̱ akum ìjili aDan 
\p  
\v 1 Ka̱ ashe oga nra va̱ ta te, oIsa̱rila yà ká̱ uponzhi ka̱t. Kang akum ìjili aDan oma ka̱ yà ka̱ mmwo atak îshi oza̱ pa̱ na ó təm kà̱, ka̱kul oma ka̱ ya iya̱mkup iji oza̱ chit ka̱ ashe oga akum ìjili oIsa̱rila ka̱t. 
\p  
\v 2 Te onəm aDan yak onunggwan okamkam pa̱ otukun ka̱ aZora ká̱ aEshtawol pa̱ oza̱ á ga á song kang i gbap mbin va̱ ta. Onəm va̱ ta sat ka̱ anung nkpaktak akum ijili aDan. Oza̱ là ôza̱ pa̱ <<Ó ga na ó song mbin va̱ ta.>> 
\p Oza̱ ga chu aɗuktum aEfrayim, te oza̱ ga nzhi aMika, oza̱ ra ka̱ ta. 
\p  
\v 3 Awalang va̱ oza̱ ga dat ká̱ nzhi aMika te, oza̱ nyi uyenza̱m uga aLawi va̱ ta ka̱ atak ichəchu, kang oza̱ ga ɓəp na pa̱, <<Uda ɓa ká̱ ɓu ka̱ ta̱ yà? Iza̱ mmaɓu ka̱ nnənəm ka̱ atak va̱ ta̱ yà? Sang mmaɓu ka̱ ta̱ yà?>> 
\p  
\v 4 Uza̱ là ôza̱ iya̱m va̱ uMika ka̱ nəm á na chit pa̱, <<Uza̱ yar mi chit unəm uga mpyal awuwop, i mwa mi.>> 
\p  
\v 5 Te oza̱ là á na pa̱, <<Mmayi ka̱ nchal ɓu, ɓəp Inan, na í nyi mwote achen yi va̱ ta̱ i yìyà ká̱ igwan ɗò?>> 
\p  
\v 6 Te unəm uga mpyal awop va̱ ta na ama̱n ôza̱ pa̱, <<Ó ga ká̱ ikángkáng, ka̱kul uYawe uwa yà nzəng ká̱ wó ka̱ ashe achen wó.>> 
\p  
\v 7 Te onəm oga otukun va̱ ta wong ga, kang oza̱ ɓa chu aLayish. Oza̱ ya onəm va̱ ta ka̱ ntəm pa̱ shat wa onəm oga aSidon, oza̱ ka̱ ntəm ká̱ ikángkáng kang oza̱ ka̱ ntəm pa̱ shat. Oza̱ lang iya̱m iro ka̱ mbin oza̱ ka̱t, kang oza̱ dur byet. Kà̱ɗi te, oza̱ ra gbà̱ng ká̱ oSidon, kang oza̱ ka̱ nnəm ntəm nzəng ká̱ unəm uro ka̱t. 
\p  
\v 8 Awalang va̱ onəm va̱ ta le ga atak ogənang oza̱ ka̱ aZora ká̱ aEshtawol te, oza̱ ɓəp oza̱ pa̱, <<Ó ga ó ya sang yà?>>  
\v 9 Te oza̱ na ama̱n pa̱, <<Ó wong, í ga í ru oza̱ ká̱ ìkum, ka̱kul í ya mbin va̱ ta chit, kang á ɓyen byet. Kang ó kali pa mwang ka̱t, ó ga na ó ri mbin va̱ ta á yà nji wó. 
\p  
\v 10 Awalang va̱ ó ga ó chu atak va̱ ta te, ó ga nya onəm va̱ ta ka̱ ntəm pa̱ shat. Mbin va̱ ta bál byet, mbin ndopdop nva mí lang iya̱m iro ka̱ ashishe ka̱t, kang Inan na mbin va̱ ta chit ka̱ ashe awo wó. 
\p  
\v 11 Te, onunggwan ìgba̱l pa̱ ìkpa̱ɗing ka̱ akum ìjili aDan, ova gbar izər chit ká̱ oga iya̱mɓáng wong ka̱ aZora ká̱ aEshtawol,  
\v 12 oza̱ ga ləp apa̱k ka̱ asa̱l ntar alum aKiriyat-Jeyarim ka̱ ashe mbin aYahuda. Nna nak kang mí wór atak va̱ ta pa̱ aMahane Dan ɓa chu nda va̱ ta̱.  
\v 13 Oza̱ wong ka̱ ta te, oza̱ ga ìtong iga aɗuktum aEfrayim, kang oza̱ ɓa chu nzhi aMika. 
\p  
\v 14 Te onunggwan oga otukun va̱ ka̱ ga ka̱ sòng mbin aLayish, là ôgənang oza̱ pa̱, <<Ó nyinyi pa̱ ka̱ ashe oga nzhi va̱ ta̱ te, nzhi nro na yà ká̱ ìlukwan ìkwoksok, ká̱ oga ichər ikpákpà, ká̱ ala̱ka̱n ìchər va mmá kpà ká̱ akun kang mmá ɓam izəzər ká̱ aazurfa ka̱ ashishe ɗò? Ǹyangmata̱ te, ó rəng iya̱m va̱ ó ga nnənəm.>>  
\v 15 Te oza̱ lyep ka̱ ta, oza̱ ga re anung ûyenza̱m uLawi va̱ kà̱ nzhi aMika á.  
\v 16 Kang onəm aDan oga ìgba̱l pa̱ ìkpa̱ɗing va̱ ka̱ gbar izər ká̱ iya̱mɓáng ka̱kul ìkum tong ka̱ anung asa̱l aga ntar nzhi va̱ ta.  
\v 17 Onunggwan oga otukun va̱ ka̱ ga nsòng mbin va̱ ta táng ashe nzhi kang oza̱ wur oga ichər ikpákpà, ká̱ ala̱ka̱n ìchər va̱ mmá kpà ká̱ akun kang mmá ɓam izəzər ká̱ aazurfa, ká̱ ìlukwan ìkwoksok ìyə́ryər. Ǹnyi te, unəm uga mpyal awop uwa sat ka̱ anung asa̱l aga ntar nzhi va̱ ta nzəng ká̱ onəm ìgba̱l pa̱ ìkpa̱ɗing ova gbar izər ká̱ oga iya̱m-wór ka̱kul ìkum va̱ á. 
\p  
\v 18 Awalang va̱ onunggwan oga otukun va̱ ta̱ táng ashe nzhi aMika wur oga ichər ikpákpà ká̱ ala̱ka̱n ìchər va̱ mmá kpà ká̱ akun kang mmá ɓam izəzər ká̱ aazurfa, ká̱ ìlukwan ìkwoksok ìyə́ryər te, unəm uga mpyal awop ɓəp oza̱ pa̱, <<Iza̱ mmawó ka̱ nnənəm yà?>> 
\p  
\v 19 Te oza̱ na ama̱n á na pa̱, <<Ma̱r, kpán anung ɓu. Ga nzəng ká̱ yi, na ú yà upo ká̱ unəm uga mpyal awop á yi. Kapkap pa̱ ú yà unəm uga mpyal awop âkum ìjili aIsa̱rila ká̱ nva̱ pa̱ ú yà unəm uga mpyal awop n̂zhi anəm pa̱ uzəng ka̱t ɗò?>>  
\v 20 Awalang va̱ unəm uga mpyal awop va̱ ta fe pa te, ìgwak chàng na. Te uza̱ wur oga ichər ikpákpà, ká̱ ala̱ka̱n ìchər va̱ mmá kpà ká̱ akun kang mmá ɓam izəzər ká̱ aazurfa, ká̱ ìlukwan ìkwoksok ìyə́ryər, uza̱ ga nzəng ká̱ oza̱.  
\v 21 Te oza̱ le ga nva̱ng, oza̱ nak ovan oza̱, ká̱ iya̱mkang oza̱, ká̱ nkpaktak iya̱m oza̱ ka̱ mpyal. 
\p  
\v 22 Awalang va̱ onəm aDan ga chit gbà̱ng ɗa̱p ká̱ nzhi aMika te, mmá wór onəm va̱ ra dát ká̱ nzhi aMika fa ɓut, oza̱ ɓàk nva̱ng onəm aDan ga ɓan oza̱.  
\v 23 Nva̱ oza̱ ka̱ nnə́m achu í ɓàk nva̱ng oza̱ te, onəm aDan ga̱ɓa̱n ɓəp uMika pa̱, <<Iza̱ nɗaktak ɓu, kang u ɓut nggatək va̱ ta̱ ɓu ɓàk nva̱ng yi ká̱ yà?>> 
\p  
\v 24 Te uMika na ama̱n pa̱, <<Ó wur oga inan mi va̱ n nəm ká̱ unəm uga mpyal awop mi ó ga ká̱, ó re iya̱m iro á mi ka̱t. Te sang kang ó ɓəp mi pa̱, <Iza̱ nɗaktak mi yà á?>> 
\p  
\v 25 Te onəm aDan na ama̱n pa̱, <<Kang wa dap ká̱ yi ka̱t, ka̱t te ìgwak i wong i lak onəm oro kang oza̱ i ru ɓu ká̱ ìkum, te mmaɓu ká̱ nzhi ɓu ó zhì.>>  
\v 26 Te onəm aDan ga mpyal ká̱ achen oza̱. Awalang va̱ uMika ya pa̱ oza̱ ji nkam wò ji te, uza̱ ga̱ɓa̱n le ga nzhi wò. 
\p  
\v 27 Te onəm aDan wur oga ichər aMika ká̱ unəm uga mpyal awuwop, kang oza̱ kyén ga aLayish, atak va onənəm ka̱ ntəm ká̱ ikángkáng kang pa̱ shat á. Oza̱ ru oza̱ ká̱ ìkum gbá̱ng oza̱ ká̱ ndokchi, kang oza̱ pwak ìtong va̱ ta ká̱ apər.  
\v 28 Unəm uro yà pa̱ á ka̱m ishi onəm va̱ ta ka̱t, ka̱kul oza̱ ra gbà̱ng ká̱ aSidon, kang oza̱ yà ká̱ ngwang ishi ká̱ unəm uro ka̱t. Ìtong va̱ ta̱ ka̱ ashe aba̱nda̱m aro va dát ká̱ aBet-Rehop. 
\p Te onəm aDan le me ìtong va̱ ta kang oza̱ təm ka̱ ashishe.  
\v 29 Oza̱ ga̱ɓa̱n aɗin îtong va̱ ta le wór pa̱ aDan wa aɗin akəka oza̱ uDan, uva mmá mar ûIsa̱rila. Ka̱ yà te, mí wór ìtong va̱ ta pa̱ aLayish.  
\v 30 Te onəm aDan pak ìchər va̱ ka̱ ta, pa̱ na ó wop, kang oza̱ kyer uJonatan uya aGershom ununggwan, uya aMusa ununggwan, ká̱ ovəvan onunggwan sat onəm oga mpyal awop âkum ìjili aDan ga chu awalang va̱ mmá wur oza̱ ka̱ mbin va̱ ta ga izwal.  
\v 31 Oza̱ ga mpyal ká̱ ngwop ìchər va̱ aMika ka̱ nəm, ka̱ ashe nkpaktak awalang va̱ nzhi Inan ka̱ aShilo. 
\c 19  
\s1 ULawi uro ká̱ uchichar uga nnak ka̱ nzhi pa kùk 
\p  
\v 1 Ka̱ ashe oga nra va̱ ta te, aIsa̱rila yà ká̱ uponzhi ka̱t. 
\p Ǹyangmata̱ te, uLawi uro uva ka̱ ntəm ka̱ ashe iya ìtong iro ka̱ ìtong iga aɗuktum aEfrayim, ka̱m uchar va mí nak ka̱ ashe nzhi pa kùk ka̱ aBet-Lehem aga aYahuda.  
\v 2 Ǹnyi te, uchar va̱ ta nəm nlang nnandər á na. Uchar va̱ ta re na, le ga nzhi apo wò ka̱ aBet-Lehem aga aYahuda. Nva̱ngva̱ uza̱ təm chit ka̱ ta ga chu apye pa̱ neɗing te,  
\v 3 uɓəɓar wong ga pa̱ na ô chal na, pa̱ uza̱ a le á ɓa nzhi wò. Uza̱ nzəng ká̱ uzwal wò, ká̱ oga azhaki pa̱ aparəm. Uchar va̱ ta tar ká̱ na ka̱ ashe nzhi apo wò, kang awalang va̱ ugugwar ya na te, uza̱ ka̱m na ká̱ nchàng ìgwak pa̱ gənggəng.  
\v 4 Te ugugwar, upo achar va̱ ta kpán na pa̱ uza̱ á təm ká̱ wó pa̱ ɗa̱p kang, te uza̱ təm ká̱ oza̱ nra pa̱ ishatɗing, oza̱ ka̱ nri, oza̱ i wá, kang oza̱ i ra ka̱ ta. 
\p  
\v 5 Ka̱ nra ngga nneɗing te, unəm va̱ ta wong ká̱ iɓotak pa̱ na ó ga, ǹnyi te, upo achar va̱ ta là ûgwar wò pa̱, <<Ri iya̱m-nrì iro kang ɓu ga.>>  
\v 6 Te mparəm oza̱ le təm kang oza̱ ri, oza̱ wá nzəng. Ka̱ nvəva̱ng te, upo achar va̱ ta là á na pa̱, <<Kusuk, le ra kà̱ɗi, na u na nfe nchàng îzər ɓu.>>  
\v 7 Unəm va̱ ta wong pa̱ na ô ga te, ugugwar pak nchal na pa̱ uza̱ sat kang, te uza̱ ma̱n ra kà̱ɗi.  
\v 8 Ka̱ nra ngga ntukun te, uza̱ wong ká̱ iɓotak kà̱ɗi pa̱ na ô ga te, upo achar va̱ ta là pa̱, <<Ri iya̱m iro kang, na u lok alum á ɓan ntar kang ɓu ga.>> Te mparəm oza̱ va̱ ta təm kang oza̱ ri iya̱m-nrì nzəng. 
\p  
\v 9 Awalang va̱ unəm va̱ ta ká̱ uchəchar va̱ uza̱ nak ka̱ ashe nzhi pa kùk, ká̱ uzuzwal wong pa̱ na ó ga, te ugugwar, upo achar va̱ ta la̱ á na pa̱, <<Dər, ǹyangmata̱ alum dát chit i tar, le ra iya̱m ɓu ka̱ ta̱. Atak dát chit i kpà̱r, ra na u na nfe nchang îzər ɓu. Ipin ká̱ ìɓotak te, ɓu wong ɓu kpán asa̱l ɓu.>>  
\v 10 Ǹnyi te, unəm va̱ ta ɗom pa̱ ô ra lap ka̱t. Te uza̱ wong kpán asa̱l wòl ìsu aJebus, nna mí wór aUrushelima á. Uza̱ nzəng ká̱ oga azhaki wò aga nkongkong pa̱ mparəm, ká̱ uchəchar va̱ uza̱ nak ka̱ ashe nzhi pa kùk va̱ á. 
\p  
\v 11 Awalang va̱ oza̱ dát ká̱ aJebus kang alum kwangtal chit te, uzwal va̱ ta là ûnəm uga nzhi wò pa̱, <<Re í tong ka̱ ashe ìtong oJebusi va̱ ta̱, na í ra ka̱ ta̱.>> 
\p  
\v 12 Te unəm uga nzhizhi na ama̱n á na pa̱, <<Í yà ká̱ nra ka̱ mbin oɗyanəm ka̱t, ka̱kul onəm oga ìtong va̱ ta̱ oIsa̱rila ka̱t. Ka̱kul nva̱ ta te, í watar í ga aGibeya.>>  
\v 13 Kang uza̱ là ûzwal wò pa̱, <<Ɓa na í ɗak í ga i chu aGibeya, ka̱t te, aRama, kang í ra ka̱ atak aro ka̱ ashe ìtong va̱ ta.>>  
\v 14 Te oza̱ watar, oza̱ ɓa chu aGibeya iga mbin aBenjamin yà alum ka̱ ntar,  
\v 15 kang oza̱ tong ka̱ ta, pa̱ na oza̱ á ra ka̱ aGibeya. Oza̱ ga təm ka̱ ashe agbagba ìtong va̱ ta, ǹnyi te, unəm uro yà ka̱m oza̱ táng ashe nzhi wò ká̱ pa̱ oza̱ á ra ka̱t. 
\p  
\v 16 Oma ka̱ ta na te, unəmgbak uro ka̱ ìtong iga aɗuktum aEfrayim, uva ka̱ ntəm ka̱ aGibeya, atak va onəm oga akum ìjili aBenjamin təm kà̱, ka̱ nle ka̱ atak inok ka̱ ashe iram wò ká̱ arurong.  
\v 17 Awalang va̱ uza̱ wong ká̱ ìwu kang a ya unəm uga achen va̱ ta təm ka̱ agbagba aga ìtong va̱ ta te, unəmgbak va̱ ta ɓəp na pa̱, <<U fa ka̱ che yà? Mmaɓu ka̱ ngga che yà?>> 
\p  
\v 18 Te unəm oLawi va̱ ta na ama̱n á na pa̱, <<Í fa ka̱ aBet-Lehem ka̱ ashe aYahuda, mmayi ka̱ ngga iya ìtong iro ka̱ mbin ngga aɗuktum aEfrayim, n fa ka̱ ta na. N ga aBet-Lehem ka̱ aYahuda, kang ǹyangmata̱ te, mmami ka̱ ngga atak nzhi aYawe, kang ǹnyi te, unəm uro yà ka̱m mi tar nzhi wò ká̱, pa̱ na n ra ka̱ ta ka̱t.  
\v 19 Na í yà ká̱ ìpəpa ká̱ nrì ka̱kul oga azhaki yi, kang na í yà ká̱ nzəngkəng ká̱ ndəng ìba̱ngba̱ng ka̱kul ishi yi ozwal ɓu, mmami, ká̱ uchar va̱ ta̱, ká̱ uyenza̱m va̱ nzəng ká̱ yi á. Í lang iya̱m iro ka̱t. 
\p  
\v 20 Te unəmgbak va̱ ta là pa̱, <<Ntəm ikángkáng á yà nzəng ká̱ wó. Re n mwa nkpaktak nɗom wó á wó. Kang ó ra ka̱ ashe agbagba ka̱t.>>  
\v 21 Te uza̱ ka̱m oza̱ ga nzhi wó ká̱, na nrì ôga azhaki oza̱. Ka̱ nva̱ngva̱ oza̱ nal ashar oza̱ chit te, oza̱ ri kang oza̱ wá. 
\p  
\v 22 Oma ka̱ ashe nfe nchàng oza̱ te, onunggwan onga oro ka̱ ashe ìtong va̱ ta ɓa gang nzhizhi. Oza̱ i nə́m anung nzhi, kang oza̱ i là ûnəmgbak va̱ ta, uwa unəm uga nzhi pa̱, <<Fa ká̱ unəm va̱ ɓa nzhi ɓu, na í ra ichar ká̱ na. 
\p  
\v 23 Te unəm uga nzhi va̱ ta fa ga atak oza̱, là nnap ká̱ oza̱ pa̱, <<Pa ka̱t ógənang mi. Kang ó nəm inga ka̱t. Unəm va̱ ta̱ unəmchən mi, kang ó nəm apir iya̱m iga ìwuswa va̱ ta̱ ka̱t.  
\v 24 Dər, uyen mi uchar uwa ta̱ uva uwa nyi ununggwan chit ka̱t á, ká̱ uchəchar va̱ uza̱ nak ka̱ ashe nzhi pa kùk. Re n fa ká̱ oza̱ á wó, na ó nəm iya̱m va̱ ká̱ oza̱ ó ɗom. Ǹnyi te, kang ó nəm iya̱m ìwuswa ûnəm va̱ ta̱ ka̱t.>> 
\p  
\v 25 Ǹnyi te, onəm va̱ ta gwong achwang ka̱ na ka̱t. Te unəm uga aLawi va̱ ta fa ká̱ uchəchar va̱ uza̱ nak ka̱ ashe nzhi pa kùk ôza̱ ka̱ agbai, kang onəm va̱ ta ra ká̱ uchar va̱ ta ká̱ ìfan, oza̱ i pa̱ng izər ká̱ na ka̱ ashe ìzwam va̱ ta ga chu anung ìpin. Nna chit te oza̱ re na ɗak ga.  
\v 26 Atak tàn te, uchar va̱ ta le ga nzhi va̱ unəm uga nzhizhi kà̱, ru ka̱ anung asa̱l nzhi, kang uza̱ ra ka̱ ta atak ga ghan. 
\p  
\v 27 Awalang va̱ unəm uga nzhizhi wong ká̱ ìpin bol anung nzhi pa̱ na ká̱ ò ga mpyal ká̱ achen wò te, uza̱ ya uchəchar va̱ uza̱ nak ka̱ ashe nzhi pa kùk ra chit ka̱ anung asa̱l nzhi i yichi awo i ga izər anung nzhi.  
\v 28 Uza̱ là ûchar va̱ ta pa̱, <<Wong, na i ga.>> Ǹnyi te, uza̱ lyen á na ka̱t. Te unəm va̱ ta yar na nak ka̱ apal azhaki wò, kang uza̱ kpán asa̱l ga nzhi wò ká̱. 
\p  
\v 29 Awalang va̱ uza̱ chu nzhi wò te, uza̱ yar ìkpal, uza̱ nyat ìzhe achəchar va̱ uza̱ nak ka̱ ashe nzhi pa kùk, ngba̱ng ká̱ ngba̱ng pa̱ ngba̱pchi ama̱n pa̱ aparəm, kang uza̱ re nre ká̱ ngba̱ng pa̱ nzəng n̂za̱ akum ìjili nggo ka̱ ashe nkpaktak mbin aIsa̱rila.  
\v 30 Kang nza̱ unəm nggo va ya te, i là ûwan wò pa̱, <<Á ɓan ka̱ ilum va̱ í re aMasar te, nna mmá fe apir nnap va̱ ta̱ chit ka̱t, kang nna mmá nəm apipir chit ka̱ ashe mbin aIsa̱rila ka̱t. Ó rəng nnap kà̱. Nkpak pa̱ í nəm iya̱m iro. Í là nnàp kà̱. 
\c 20  
\s1 OIsa̱rila nyám ntàn âkum ìjili aBenjamin 
\p  
\v 1 Te nkpaktak onəm oga aIsa̱rila, ɓan ka̱ aDan ga chu aBeyersheba, kang ká̱ mbin aGileyat fa ɓut ka̱ anung zəngtəng ka̱ mpyal aYawe ka̱ aMizpa.  
\v 2 Te onəm oga mpyal nkpaktak oga akum ìjili aIsa̱rila, yar atak nsat oza̱ ka̱ ashe nggatək onəm Inan, onunggwan ìkalong ìgba̱l pa̱ ìneɗing ká̱ oga ndokchi.  
\v 3 Onəm aBenjamin fe pa̱ oIsa̱rila ga chit ga ɓut ka̱ aMizpa. Te oIsa̱rila là pa̱, <<Là á yi, nza̱ asa̱l iya̱m inga va̱ ta̱ fa yà?>> 
\p  
\v 4 Te unəm oLawi, uɓar achar va̱ mmá gbá̱l te, á là pa̱, <<Mmami ká̱ uchar mi va̱ n nak ka̱ ashe nzhi pa kùk í ɓa aGibeya, ìtong va iji onəm aBenjamin pa̱ na í ra ka̱ ta.  
\v 5 Ka̱ ìzwam va̱ ta te, onəm oga aGibeya wong ɓa gang nzhi va̱ n ra kà̱ pa̱ na ó gbá̱l mi. Oza̱ ra ká̱ uchar mi va̱ n nak ka̱ ashe nzhi pa kùk ká̱ ìfan, kang uza̱ kú.  
\v 6 Te n yar uchar mi va̱ n nak ka̱ ashe nzhi pa kùk va̱ ta, n nyat na ngba̱ng pa̱ ɗongɗong, kang n re nre ká̱ ngba̱ng pa̱ nzəng n̂za̱ nkap mbin ka̱ ashe iya̱mkup aIsa̱rila, ka̱kul oza̱ nəm iya̱m inga ká̱ iya̱m iga ìwuswa va̱ ta̱ ka̱ ashe aIsa̱rila.  
\v 7 Ǹyangmata̱ te, nkpaktak wó onəm oga aIsa̱rila, ó là iya̱m va̱ í ga nnənəm ka̱ apal nnap va̱ ta̱.>> 
\p  
\v 8 Te nkpaktak onəm va̱ ta wong tong wa anəm pa̱ uzəng kang oza̱ là pa̱, <<Unəm uro yà ka̱ ashe yi i ga nzhi ka̱t. I nəm ka̱t, unəm uro yà ka̱ ashe yi i le nzhi wò ka̱t.  
\v 9 Ǹnyi te, iya̱m va ta̱ iga nnənəm âGibeya. Í màng ayàk na í yàk onəm va̱ i ga i ru oza̱ ká̱ ìkum ká̱ asa̱l va̱ mí ga ká̱.  
\v 10 Í ga nyak uzəng ka̱ ashe agba̱pchi ka̱ ashe onunggwan oga nza̱ akum ìjili nggo ova i ɓa ká̱ iya̱m-nrì ôshozha. Kang aɓoshi oshozha te, i ga i nyám ntàn ônəm oga aGibeya ka̱ aBenjamin ka̱kul iya̱m ìwuswa va̱ oza̱ nəm ka̱ ashe aIsa̱rila.  
\v 11 Wa nnà ta nkpaktak oIsa̱rila ɓut kang oza̱ gwang ishi wa anəm pa̱ uzəng ka̱ apal ìtong va̱ ta. 
\p  
\v 12 Te oga akum ìjili oIsa̱rila re nre ká̱ onəm oga nre ga ashe akum ìjili aBenjamin, kang a là pa̱, <<Nza̱ apir iya̱m inga ó nəm wa nta̱ yà?  
\v 13 Ǹyangmata̱ te, ó na onunggwan onga oga aGibeya va̱ ta á yi na í gbá̱ng oza̱, na í fa ká̱ iya̱m inga va̱ ta̱ ka̱ ashe aIsa̱rila.>> 
\p Ǹnyi te, onəm aBenjamin gwong achwang kà̱ oza̱ ka̱t.  
\v 14 Te onəm aBenjamin fa ka̱ ashe oga itong oza̱ ɓa ɓut ka̱ aGibeya pa̱ na ó lung ìkum ká̱ oIsa̱rila.  
\v 15 Ka̱ nda va̱ ta te, onəm aBenjamin ɓut onəm ìkalong ìsəm pa̱ ìparəm ama̱n pa̱ kpa̱ɗing ova ká̱ oga ndokchi, oza̱ fa ka̱ ashe oga itong oza̱ ga gwang ká̱ onəm ìgba̱l pa̱ ìfangshat oga nnyi ìkum va̱ ka̱ ntəm ka̱ aGibeya á.  
\v 16 Ka̱ ashe nkpaktak oshozha va̱ ta te, onəm oyákyàk oga nnəm inok ká̱ awo apəra̱m oma yà ìgba̱l pa̱ ìfangshat. Nza̱ uzəngtəng oza̱ nggo, i màng ìpang ká̱ nchwalak i ləp akpap ishi pa̱ izəng, i yà ká̱ mpat ka̱t. 
\p  
\v 17 Ǹnyi te, oIsa̱rila ɓut oshozha oga ǹnyi nlung ìkum ìkalong ìgba̱l pa̱ ìneɗing ova ká̱ oga ndokchi, akum ìjili aBenjamin yà ka̱ ashishe ka̱t. 
\p  
\v 18 OIsa̱rila wong ga aBetel kang oza̱ ɓəp Inan pa̱, <<Nza̱ akum ìjili i ga i ru onəm aBenjamin ká̱ ìkum mpyal yà?>> 
\p Te uYawe na ama̱n pa̱, <<Akum ìjili aYahuda oma i ga mpyal.>> 
\p  
\v 19 Ìpin fa kpa̱k te, onəm oga aIsa̱rila wong kang oza̱ ga ləp apa̱k dát ká̱ aGibeya.  
\v 20 OIsa̱rila fa pa̱ na ó ru onəm aBenjamin ká̱ ìkum, kang oza̱ yar atak nsat ka̱kul nlung oza̱ datkulung ká̱ aGibeya.  
\v 21 Te onəm aBenjamin fa ka̱ ashe mbin aGibeya kang oza̱ gbá̱ng oIsa̱rila ìkalong ìsəm pa̱ ìparəm ama̱n pa̱ parəm ká̱ nda va̱ ta.  
\v 22 Ǹnyi te, oIsa̱rila na nkam irəng ôwan oza̱, kang oza̱ fa ga yar atak nsat oza̱ kà̱ɗi ka̱ atak va̱ oza̱ ka̱ tong kà̱, ka̱ nra ngga nggəshi á.  
\v 23 Ka̱kul oIsa̱rila ka̱ ga aBetel chit, kang oza̱ yə́ng ka̱ mpyal aYawe ga chu anung arurong. Kang oza̱ ɓəp uYawe pa̱, <<Í ga na í lung ìkum ká̱ ogənang yi onəm aBenjamin kà̱ɗi ɗò?>> 
\p Te uYawe na ama̱n ôza̱ pa̱, <<Ó ga, na ó lung oza̱.>> 
\p  
\v 24 Te oIsa̱rila fa ga pa̱ na ó lung ìkum ká̱ onəm aBenjamin kà̱ɗi.  
\v 25 Ǹnyi te, onəm aBenjamin fa ka̱ ashe mbin aGibeya kà̱ɗi ka̱kul nlung oza̱, kang oza̱ gbá̱ng oIsa̱rila ìkalong pa̱ ìgba̱pchi ama̱n pa̱ na̱nne, nkpaktak oza̱ ká̱ oga ndokchi. 
\p  
\v 26 Te nkpaktak onəm oga aIsa̱rila, oma nkpaktak oshozha, kyén ɓa ga aBetel, kang oza̱ təm ka̱ ta, i yə́ng ka̱ mpyal aYawe. Oza̱ yar ndəng gba̱l ká̱ nda va̱ ta ga chu anung arurong, kang oza̱ na iya̱m inana iga nshì, ká̱ iya̱m inana iga ntəm ikángkáng ûYawe.  
\v 27 Te onəm oga aIsa̱rila ɓəp uYawe kà̱ɗi. Ka̱ ashe oga nra va̱ ta te, aakwati aga nsar nnap-nlà Inan nna ka̱ yà ka̱ aBetel,  
\v 28 kang uFinehas uya aEleyazar uka aHaruna uwa ka̱ yà unəm uga mpyal awop. Kang oIsa̱rila ɓəp uYawe pa̱, <<Í ga na i lung ogənang yi onəm aBenjamin kà̱ɗi ro, ka̱t te, i re ɗò?>> 
\p Te uYawe na ama̱n pa̱, <<Ó ga, ka̱kul ìpin te, mi ga nna oza̱ ka̱ ashe awo wó.>> 
\p  
\v 29 Te oIsa̱rila nak onəm ra anyimnyal gang aGibeya.  
\v 30 Ka̱ ìlum ìga ishatɗing te, oIsa̱rila fa ga yar atak nsat oza̱ ka̱kul nlung onəm aBenjamin ka̱ aGibeya wa nva̱ oza̱ ma nəm á.  
\v 31 Awalang va̱ onəm aBenjamin fa ìkum ka̱ oza̱ te, mmá dap oza̱ ga gbà̱ng ká̱ ìtong va̱ ta. Oza̱ ɓan ngbá̱ng oIsa̱rila wa mmatmat, kang oIsa̱rila ìsəm pa̱ ishatɗing tàk ka̱ agbagba afini ká̱ oga anang asa̱l va̱ i ga aBetel ká̱ ava̱ i ga aGibeya á. 
\p  
\v 32 Nva̱ onəm aBenjamin ka̱ nlà pa̱, <<Mmayi ka̱ nnəm igwan ka̱ apal oza̱ wa nva̱ ka̱ i nəm matmat>> te, onəm oga aIsa̱rila ka̱ nlà ǹnyi pa̱, <<Re í dap oza̱ á fa á re ashe ìtong á ga apal oga anang asa̱l.>> 
\p  
\v 33 Nkpaktak oshozha oIsa̱rila chəng re atak oza̱ kang oza̱ ga wur oga atak nsat ka̱ aBaal Tamar. Te oIsa̱rila va̱ ra anyimnyal ka̱ asa̱l ntar alum aGibeya wong fa ìkum.  
\v 34 Te oshozha oIsa̱rila oga nnyi ìkum ìkalong pa̱ ìgba̱pchi ru aGibeya ká̱ ìkum. Ìkum va̱ ta sur byet, ǹnyi te onəm aBenjamin nyi pa̱ nnap va̱ ta i ga mɓa̱ng ôza̱ ka̱t.  
\v 35 Te uYawe nəm igwan ka̱ apal onəm aBenjamin ka̱ mpyal oIsa̱rila, kang ka̱ ìlum va̱ ta te, oIsa̱rila gbá̱ng onəm aBenjamin ìkalong ìsəm pa̱ ìparəm ama̱n pa̱ tukun ká̱ ìgba̱l pa̱ ìzəng, nkpaktak oza̱ onəm ova ká̱ oga ndokchi.  
\v 36 Nna chit te, onəm aBenjamin nyi pa̱ mmá ri wó chit ká̱ ìkum. 
\p Ǹyangmata̱ te, oIsa̱rila ka̱ chəng ka̱ mpyal onəm aBenjamin ka̱kul oza̱ da̱r nkam ka̱ oshozha va ka̱ ra anyimnyal dat ká̱ aGibeya á.  
\v 37 Ovəngva̱ ka̱ ra anyimnyal fa pa̱ kəlak táng kang a zàl ka̱ ashe ìtong aGibeya, te oza̱ gbá̱ng nkpaktak onəm va̱ ka̱ ashe ìtong va̱ ta ká̱ ndokchi.  
\v 38 Oza̱ ka̱ nak chit pa̱ nggù i wong pa̱ makmak ka̱ ashe ìtong va̱ ta wa ìlulu, nna i sat iya̱m iga ǹnyám ìpir nnap ka̱ ishimshe oIsa̱rila ká̱ ovəngva̱ ra anyimnyal.  
\v 39 OIsa̱rila i ya nggù va̱ ta te, oza̱ i ga̱ɓa̱n, kang i ru onəm aBenjamin ká̱ ìkum. 
\p Onəm aBenjamin ka̱ ɓan ngbá̱ng oIsa̱rila chit ga chu onəm ìsəm pa̱ ishatɗing, kang oza̱ i là pa̱, <<Mmayi ka̱ nnəm igwan ká̱ oza̱, wa ngga nggəshi va.>> 
\p  
\v 40 Ǹnyi te, awalang va̱ nggù ɓan ǹnənggət chit ka̱ ashe ìtong va̱ ta te, onəm aBenjamin ga̱ɓa̱n, kang oza̱ ya nggù i wong ka̱ ashe nkpaktak ìtong oza̱ i ga apaɓur.  
\v 41 Te onəm oga aIsa̱rila ga̱ɓa̱n ru oza̱ ká̱ ìkum, kang onəm aBenjamin tán ká̱ ayər ka̱kul oza̱ nyi ɗak pa̱ nɗaktak ya oza̱ chit.  
\v 42 Te oza̱ ga̱ɓa̱n chəng ka̱ mpyal oIsa̱rila, oza̱ wòl asa̱l nzam mmaləng, ǹnyi te, oza̱ bar ka̱ atak ìkum va̱ ta ka̱t. Kang oIsa̱rila va̱ fa ka̱ ashe oga itong gbá̱ng oza̱ ka̱ ta.  
\v 43 OIsa̱rila gang onəm aBenjamin, oza̱ ɓak oza̱ kang oza̱ ga kpán oza̱ ka̱ asa̱l nfa alum aGibeya.  
\v 44 Onəm aBenjamin ìkalong pa̱ ìgba̱pchi ama̱n pa̱ na̱nne kú. Nkpaktak oza̱ te, onəm okamkam.  
\v 45 Aɓo ovəngva̱ re te, ga̱ɓa̱n, chəng táng ashe nzam mmaləng ga asa̱l ìpang aRimmon, ǹnyi te, oIsa̱rila gbá̱ng oza̱ ìkalong pa̱ ìtukun ka̱ apal oga anang asa̱l. Oza̱ pak inok mɓàk nva̱ng oza̱ ga chu aGidom, kang oza̱ gbá̱ng onəm ìkalong pa̱ ìparəm kà̱ɗi. 
\p  
\v 46 Ká̱ nda va̱ ta te, mmá gbá̱ng onəm aBenjamin ìkalong ìsəm pa̱ ìparəm ama̱n pa̱ tukun, nkpaktak oza̱ oshozha okamkam ova ká̱ oga ndokchi.  
\v 47 Ǹnyi te, onəm ìgba̱l pa̱ ìkpa̱ɗing ga̱ɓa̱n chəng táng nzam mmaləng ga ìpang aRimmon. Oza̱ təm ka̱ ta apye pa̱ neɗing.  
\v 48 Te oIsa̱rila le ga mbin aBenjamin, kang oza̱ gbá̱ng nza̱ iya̱m iga irirì nggo ka̱ ashe oga itong va̱ ta ká̱ ndokchi, nzəng ká̱ iya̱mkang, ká̱ nza̱ iya̱m nggo va̱ oza̱ ya á. Kang oza̱ pwak nkpaktak oga itong va̱ oza̱ táng ashishe. 
\c 21  
\s1 Ochar ka̱kul onəm aBenjamin 
\p  
\v 1 Onəm oga aIsa̱rila ka̱ sóng anung chit ka̱ aMizpa pa̱, <<Unəm uro yà ka̱ ashe yi i na ivang ká̱ uyen wò uchar ûnəm uga aBenjamin ka̱t.>> 
\p  
\v 2 Te onəm va̱ ta ga aBetel, kang oza̱ təm ka̱ ta ka̱ mpyal Inan ga chu arurong, kang oza̱ gham achu ká̱ ayə́ng pa̱ gənggəng.  
\v 3 Oza̱ là pa̱, <<ÁYawe, Inan iga aIsa̱rila, iza̱ nak kang iya̱m va̱ ta̱ fa ka̱ ashe aIsa̱rila yà? Ka̱kul iza̱ kang mí lang akum ìjili pa̱ izəng ka̱ ashe aIsa̱rila ka̱ nda va̱ ta̱ yà?>> 
\p  
\v 4 Ìpin fa kpa̱k ká̱ ìɓotak te, oIsa̱rila me atak nshì iya̱m awop, kang oza̱ na oga iya̱m inana iga nshì ká̱ oga iya̱m inana iga ntəm ikángkáng. 
\p  
\v 5 Te oIsa̱rila ɓəp pa̱, <<Nza̱ akum ìjili ka̱ ashe nkpaktak aIsa̱rila ga nzəng ká̱ yi ka̱ aMizpa ka̱ awalang va̱ í ɓut ka̱ mpyal aYawe ka̱t yà?>> Ka̱kul oza̱ ka̱ yar nsóng anung chit pa̱, unəm va pa̱ káp yang ká̱ mɓa mɓut ka̱ mpyal aYawe te, nkpak mí gbá̱l na. 
\p  
\v 6 OIsa̱rila dər akum ìjili aBenjamin ugənang oza̱ ká̱ nrwa ìgwak, kang oza̱ là pa̱, <<Mmá gbá̱l akum ìjili iro chit pa̱ izəng le ka̱ ashe aIsa̱rila ká̱ nda va̱ ta̱.  
\v 7 Í nəm sang kang í ya ochar ôvəngva̱ re ta̱ yà? Ka̱kul ka̱ í sóng anung chit ká̱ uYawe pa̱ í yà ká̱ nna ovanchar yi ôza̱ ka̱ ìvang ka̱t.>>  
\v 8 Te oza̱ ɓəp pa̱, <<Nza̱ akum ìjili ka̱ ashe aIsa̱rila yang ga mɓut yi ka̱ mpyal aYawe ka̱ aMizpa ka̱t yà?>> Te oza̱ nyi pa̱ unəm uro yà ɓa mɓut nggatək va̱ ta ka̱ ashe akum aJabesh-Gileyat ka̱t.  
\v 9 Ka̱kul awalang va̱ oza̱ kung onəm pa̱ kpaktak te, oza̱ ya unəm uga aJabesh-Gileyat uro ka̱ ta pa̱ uzəng ka̱t. 
\p  
\v 10 Te nggatək va̱ ta re nre ká̱ onunggwan oga nyi nlung ìkum ìkalong pa̱ ìgba̱pchi ama̱n pa̱ parəm pa̱ oza̱ á ga, na oza̱ á gbá̱ng nkpaktak onəm oga ntəm ka̱ aJabesh-Gileyat ká̱ ndokchi, nzəng ká̱ ochar, ká̱ ovan kpa.  
\v 11 Oza̱ là ôza pa̱, <<Iya̱m va ta̱ ó ga nnənəm, ó gba̱l nkpaktak onunggwan, ká̱ nza̱ uchar nggo va̱ nyi ununggwan chit á.>>  
\v 12 Ka̱ ashe onəm oga ntəm ka̱ aJabesh-Gileyat te, oza̱ ya ovanɓyen ìgba̱l pa̱ ìneɗing ova oma nyi onunggwan chit ka̱t, kang oza̱ ɓa ká̱ oza̱ ka̱ apa̱k ka̱ aShilo ka̱ ashe mbin ngga aKanana. 
\p  
\v 13 Te nkpaktak nggatək oIsa̱rila re nre ngga ntəm ikángkáng âɓo onəm aBenjamin va̱ ka̱ ntəm ka̱ ashe ìpang aRimmon pa̱, ìkum kur chit.  
\v 14 Te onəm aBenjamin le nzhi ka̱ awalang va̱ ta, kang mmá na ovanɓyen oga aJabesh-Gileyat oga ìgba̱l pa̱ ìneɗing va̱ mmá re ká̱ irirì ôza̱ tong ochar oza̱. Ǹnyi te, ovanɓyen va̱ ta gàng oza̱ ka̱t. 
\p  
\v 15 Te aɗor ga onəm va̱ ta ka̱ apal onəm aBenjamin, ka̱kul uYawe re mɓol nro chit ka̱ ashe oga akum ìjili aIsa̱rila.  
\v 16 Te onəmgbak oga mɓut ɓəp pa̱, <<Mmá zhì nkpaktak ochar va̱ ka̱ ashe akum ìjili aBenjamin chit. Í nəm sang kang í ya ochar âɓo ovəngva̱ re yà?  
\v 17 Nkpak pa̱ mmá yà iya̱mkup âɓo akum ìjili aBenjamin va̱ bar, na kang mmá dəkən akum ìjili iro ka̱ ashe aIsa̱rila ka̱t  
\v 18 Káp ka̱ nna te, í yà ká̱ nna ovanchar yi ôza̱ ka̱ ìvang ka̱t, ka̱kul mmayi oIsa̱rila ka̱ í sóng anung chit pa̱, <Unəm va̱ pa̱ káp á na uyen wò ìvang ônəm aBenjamin te, uza̱ sat unəm uvyápvyàp chit.>  
\v 19 Ǹnyi te, ó dər, nnəm nchàng izər aYawe, va̱ mí nəm nza̱ ìzun nggo ka̱ aShilo te, á dat chit. Ìtong aShilo ra ka̱ asa̱l mpal aBetel, ka̱ asa̱l nfa alum anang asa̱l va̱ i wong ka̱ aBetel kang i ga aShekem, ka̱ asa̱l nkwandal aLebona á.>> 
\p  
\v 20 Te oza̱ là ônəm aBenjamin pa̱, <<Ó ga na ó ra anyimnyal ka̱ ashe oga ìram ìba̱ngba̱ng,  
\v 21 na ó lok atak. Awalang va̱ ovanɓyen oga aShilo i fa ngba̱p nza̱m te, ó gha̱n ó fa ka̱ ashe oga iram ìba̱ngba̱ng, na udanggo ka̱ ashe wó á kpán uyenchar pa̱ uzəng ka̱ ashe ovanɓyen va̱ ta ká̱ ìfan á ga ká̱, na á yà uchəchar. Te ó le mbin aBenjamin iya̱m wó.  
\v 22 Kang awalang va̱ opo oza̱ ká̱ ogənang oza̱ i ɓa ká̱ nnap-nlà ka̱ atak yi te, í là ôza̱ pa̱, <Í chal wó chal, ó ka̱mshi yi ka̱ atak nre oza̱ pa̱ á ka̱m ovanchar wó, ka̱kul í ya ochar ôza̱ ka̱ awalang nlung ìlum ka̱t. Ó yà ká̱ mpat ngga mɓəkchi nsóng anung wó ka̱t, ka̱kul mmawó na ó na ovan wó ôza̱ ka̱ ìvang ka̱t.> >> 
\p  
\v 23 Te onəm aBenjamin nəm wa nva mmá là ôza̱ á. Awalang va̱ ovanɓyen ka̱ ngba̱p nza̱m te, nza̱ uzəngtəng oza̱ nggo kpán uyenchar pa̱ uzəng ka̱ ashe ovanɓyen va̱ ta ga ká̱ pa̱ á təm uchəchar. Te oza̱ le mbin iya̱mkup oza̱, kang oza̱ me oga itong oza̱ kà̱ɗi, təm ka̱ ashishe. 
\p  
\v 24 Ka̱ awalang va̱ ta te, oIsa̱rila lyáng ka̱ ta, udanggo ga nzhi ka̱ atak akum ìjili wò ká̱ akum wò, udanggo le atak iya̱mkup wò. 
\p  
\v 25 Ka̱ ashe oga nra va̱ ta te, oIsa̱rila yà ká̱ uponzhi ka̱t, kang udanggo i nəm iya̱m va ma ká̱ na.