\v 7 \w Ils|strong="H5971"\w* \w vinrent|strong="H3478"\w* \w avec|strong="H5973"\w* \w Zorobabel|strong="H2216"\w*, \w Josué|strong="H3442"\w*, \w Néhémie|strong="H5166"\w*, \w Azaria|strong="H5838"\w*, \w Raamia|strong="H7485"\w*, Nahamani, \w Mardochée|strong="H4782"\w*, Bilshan, \w Mispéreth|strong="H4559"\w*, Bigvaï, \w Nehum|strong="H5149"\w* \w et|strong="H3478"\w* \w Baana|strong="H1196"\w*.  
\p \w Le|strong="H3478"\w* \w nombre|strong="H4557"\w* \w des|strong="H5971"\w* \w hommes|strong="H5971"\w* \w du|strong="H5971"\w* \w peuple|strong="H5971"\w* d'\w Israël|strong="H3478"\w* :   
\li1
\v 8 Les enfants de Pareosh : deux mille cent soixante-douze.   
\li1
\v 9 Les enfants de Shephatia : trois cent soixante-douze.   
\li1
\v 10 Les enfants d'Arah : six cent cinquante-deux.   
\li1
\v 11 Les enfants de Pahath-Moab, parmi les enfants de Josué et de Joab : deux mille huit cent dix-huit.   
\li1
\v 12 Les enfants d'Élam : mille deux cent cinquante-quatre.   
\li1
\v 13 Les enfants de Zatthu : huit cent quarante-cinq.   
\li1
\v 14 Les enfants de Zaccaï : sept cent soixante.   
\li1
\v 15 Les enfants de Binnuï : six cent quarante-huit.   
\li1
\v 16 Les enfants de Bébaï : six cent vingt-huit.   
\li1
\v 17 Les enfants d'Azgad : deux mille trois cent vingt-deux.   
\li1
\v 18 Les enfants d'Adonikam : six cent soixante-sept.   
\li1
\v 19 Les enfants de Bigvaï : deux mille soixante-sept.   
\li1
\v 20 Les enfants d'Adin : six cent cinquante-cinq.   
\li1
\v 21 Les enfants d'Ater, de la famille d'Ézéchias : quatre-vingt-dix-huit.   
\li1
\v 22 Les enfants de Hashum : trois cent vingt-huit.   
\li1
\v 23 Les enfants de Betsaï : trois cent vingt-quatre.   
\li1
\v 24 Les enfants de Hariph : cent douze.   
\li1
\v 25 Les enfants de Gabaon : quatre-vingt-quinze.   
\li1
\v 26 Les hommes de Bethléem et de Netopha : cent quatre-vingt-huit.   
\li1
\v 27 Les hommes d'Anathoth : cent vingt-huit.   
\li1
\v 28 Les hommes de Beth-Azmaveth : quarante-deux.   
\li1
\v 29 Les hommes de Kirjath-Jearim, de Kephira et de Beéroth : sept cent quarante-trois.   
\li1
\v 30 Les hommes de Rama et de Guéba : six cent vingt et un.   
\li1
\v 31 Les hommes de Micmas : cent vingt-deux.   
\li1
\v 32 Les hommes de Béthel et d'Aï : cent vingt-trois.   
\li1
\v 33 Les hommes de l'autre Nebo : cinquante-deux.   
\li1
\v 34 Les enfants de l'autre Élam : mille deux cent cinquante-quatre.   
\li1
\v 35 Les enfants de Harim : trois cent vingt.   
\li1
\v 36 Les enfants de Jéricho : trois cent quarante-cinq.   
\li1
\v 37 Les enfants de Lod, de Hadid et d'Ono : sept cent vingt et un.   
\li1
\v 38 Les enfants de Senaa : trois mille neuf cent trente.   
\b  
\li1
\v 39 Les prêtres : Les enfants de Jedaja, de la maison de Josué : neuf cent soixante-treize.   
\li1
\v 40 Les enfants d'Immer : mille cinquante-deux.   
\li1
\v 41 Les enfants de Pashhur : mille deux cent quarante-sept.   
\li1
\v 42 Les enfants de Harim : mille dix-sept.   
\b  
\li1
\v 43 Les Lévites : les enfants de Josué, de Kadmiel, parmi les enfants de Hodva : soixante-quatorze.   
\li1
\v 44 Les chantres : les enfants d'Asaph : cent quarante-huit.   
\li1
\v 45 Les portiers : les enfants de Shallum, les enfants d'Ater, les enfants de Talmon, les enfants d'Akkub, les enfants de Hatita, les enfants de Shobaï : cent trente-huit.   
\p
\v 46 \w Les|strong="H1121"\w* serviteurs \w du|strong="H1121"\w* temple : \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* Tsiha, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Hasupha|strong="H2817"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* Tabbaoth,  
