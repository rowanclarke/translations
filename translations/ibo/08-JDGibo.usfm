\id JDG - Biblica® Open Igbo Contemporary Bible 2020
\h Ndị Ikpe
\toc1 Ndị Ikpe
\toc2 Ndị Ikpe
\toc3 Nkp
\mt1 Ndị Ikpe
\c 1
\s1 Agha ndị Izrel lụrụ
\p 
\v 1 Mgbe Joshua nwụrụ, ụmụ Izrel jụrụ \nd Onyenwe anyị\nd* sị, “Olee ebo ga-ebu ụzọ gaa lụso ndị Kenan agha nʼihi anyị?”
\p 
\v 2 \nd Onyenwe anyị\nd* zara, “Ọ bụ ebo Juda. Enyefeela m ala ahụ nʼaka ha.”
\p 
\v 3 Ndị Juda gwara ụmụ nwanne ha ndị ebo Simiọn sị, “Soronụ anyị banye nʼala ahụ anyị ketara site nʼife nza, ka anyị ga lụso ndị Kenan agha. Anyị ga-esokwara unu banye nʼala nke unu.” Ya mere, ndị ebo Simiọn\f + \fr 1:3 \ft Ebo Simiọn na ebo Juda si nʼagbụrụ Lịa \xt Nkp 1:17\xt*\f* soro ha gaa.
\p 
\v 4 Mgbe Juda busoro ha agha, \nd Onyenwe anyị\nd* nyefere ndị Kenan, na ndị Periz nʼaka ha, mee ka ha gbuo puku ndị agha iri nʼime obodo Bezek.
\v 5 Nʼebe ahụ ka ha zutere Adoni-Bezek, buso ya agha, tigbukwaa ndị Kenan na ndị Periz.
\v 6 Ma Adoni-Bezek gbapụrụ ọsọ zoo onwe ya, ma ha chụgidere ya, jide ya, gbupụ ya isi mkpụrụ aka ya abụọ na isi mkpụrụ ụkwụ ya abụọ.\f + \fr 1:6 \ft I gbupụ isi mkpụrụ aka, na mkpịsịụkwụ nke ndị e jidere nʼagha, bụ ihe a na-ejighị kpọrọ ihe na mba ndị dị nʼetiti ọwụwa anyanwụ. Mgbe e gbupụrụ isi mkpụrụ aka na mkpịsịụkwụ onye agha, onye dị otu a agaghị e nwe ike jide ngwa agha ọzọ, maọbụ gaa ije.\f*
\p 
\v 7 Mgbe ahụ, Adoni-Bezek sịrị, “Iri ndị eze\f + \fr 1:7 \ft Ala Kenan bụ mba e kewara na mpaghara na mpaghara, maọbụ nʼobodo nta nʼobodo nta. Mpaghara, maọbụ obodo nta ọbụla nwere eze na-achị ya. Ọtụtụ obodo ndị a gbara isi obodo ahụ gburugburu.\f* asaa ka m mesoro ụdị mmeso a unu mesoro m, ọ bụkwa nri si na tebul m dapụ ka ha riri. Ugbu a Chineke akwụghachila m ụgwọ ọrụ ọjọọ m.” Ha kpụụrụ ya gaa Jerusalem, ebe ọ nọ nwụọ.
\p 
\v 8 Ndị Juda busoro obodo Jerusalem agha, were mma agha gbuchapụ mmadụ niile bi nʼime ya, ma gbaakwa obodo ahụ niile ọkụ.
\p 
\v 9 Mgbe nke a gasịrị, ndị agha Juda busoro ndị Kenan bi na ndịda ala ugwu ugwu ahụ, bụ Negev, ya na akụkụ ọdịda anyanwụ nʼebe dị ala ala.
\v 10 Ha jekwuru ndị Kenan bi nʼobodo Hebrọn (nke a na-akpọ Kiriat Aaba na mbụ) merie Sheshai, na Ahiman, na Talmai.
\v 11 Site nʼebe ahụ, ha jekwuru ndị bi na Debịa (nke a na-akpọ Kiriat Sefa, nʼoge mbụ).
\p 
\v 12 Kaleb sịrị, “Nwoke ọbụla ga-aga busoo Kiriat Sefa agha ma merie ya ka m ga-akpọnye Aksa bụ nwa m nwanyị ka ọ bụrụ nwunye ya.”
\v 13 Otniel nwa Kenaz, nwanne nta Kaleb, lụgburu obodo ahụ nʼagha. Nʼihi nke a, Kaleb kpọnyere ya Aksa, bụ nwa ya nwanyị ka ọ bụrụ nwunye ya.
\p 
\v 14 Otu ụbọchị, mgbe Aksa bịakwutere Otniel, ọ kwagidere ya ka ọ rịọọ ala ubi site nʼaka nna ya. Mgbe Aksa si nʼelu ịnyịnya ibu ya rịdata, Kaleb jụrụ ya sị, “Gịnị ka ị chọrọ ka m mere gị?”
\p 
\v 15 Ọ zaghachiri, “Nyem onyinye pụrụ iche. Ebe ọ bụ na i nyela m ala Negev, biko nyekwa m isi mmiri ụfọdụ.” Nʼihi nke a, Kaleb nyere ya isi mmiri mgbago na isi mmiri nke ndịda.
\p 
\v 16 Ụmụnna nwunye Mosis, onye Ken, si nʼobodo nkwụ nkwụ\f + \fr 1:16 \ft Nke a bụ Jeriko\f* soro ndị Juda, gaa biri nʼetiti ndị ahụ bi nʼọzara Juda, na Negev, nke dị nso nʼArad.
\p 
\v 17 Ndị ikom Juda sooro ndị ikom Simiọn, ụmụnna ha, lụso ndị Kenan bi na Zefat agha, bibie obodo ahụ kpamkpam. Nʼihi nke a, a gụgharịrị obodo ahụ, kpọọ ya Homa.
\v 18 Ndị agha Juda lụgbukwara obodo Gaza, na Ashkelọn, na Ekrọn, tinyere ala niile gbara ha gburugburu.
\p 
\v 19 \nd Onyenwe anyị\nd* nọnyeekwara ndị Juda mee ka ha kpochapụ ndị niile bi nʼobodo niile dị nʼala ugwu ugwu ahụ. Ma ha enweghị ike ịchụpụ ndị bi nʼala ndagwurugwu ahụ, nʼihi na ndị ahụ nwere ụgbọ agha igwe dị iche iche.
\v 20 E nyekwara Kaleb obodo Hebrọn, dịka Mosis kwere ya na nkwa. Kaleb chụpụrụ ụmụ Anak atọ site nʼala ahụ.
\v 21 Ndị ebo Benjamin enweghị ike chụpụ ndị Jebus bi na Jerusalem. Nʼihi nke a, ha soro ụmụ Benjamin biri ruo taa.
\p 
\v 22 Ma ndị sitere nʼebo Josef busoro obodo Betel agha. \nd Onyenwe anyị\nd* nọnyeere ha.
\v 23 Mgbe ha zipuru ndị ikom ịga nyochapụta obodo Betel, nke a na-akpọ Luz,
\v 24 ndị nnyopụta ahụ hụrụ otu nwoke sị nʼobodo ahụ na-apụta. Ha gwara ya okwu sị ya, “Zi anyị ụzọ anyị ga-esi banye nʼime obodo a, anyị ga-ahụ na e mesoro gị mmeso dị mma.”
\v 25 Ya mere, nwoke ahụ gosiri ha ụzọ, ha ji mma agha gbuo mmadụ niile bi nʼime obodo ahụ, ma ha hapụrụ nwoke ahụ na ezinaụlọ ya ndụ.
\v 26 Emesịa, nwoke ahụ kpọọrọ ezinaụlọ ya gaa biri nʼala ndị Het wuoro onwe ya otu obodo nʼebe ahụ. Ọ kpọrọ aha obodo ahụ Luz, nke bụkwa aha obodo ahụ ruo taa.
\p 
\v 27 Manase achụpụghị ndị Bet-Shan na obodo nta ya ndị ọzọ, maọbụ Teanak na obodo nta ya ndị ọzọ, maọbụ Doa, maọbụ Ibleam, maọbụ Megido, tinyere obodo nta niile ndị ọzọ gbara ha gburugburu. Nʼihi na ndị Kenan bigidere nʼebe ahụ.
\v 28 Mgbe ụmụ Izrel dịrị ike karịa, ha manyere ndị Kenan ị rụrụ ha ọrụ, ma ha achụpụghị ha site nʼala ahụ.
\v 29 Ifrem enwekwaghị ike chụpụ ndị Kenan bi na Gaza. Ndị Kenan gara nʼihu biri nʼetiti ha nʼebe ahụ.
\v 30 Otu a kwa, ebo Zebụlọn achụpụghị ndị Kenan bi nʼala Kitrọn, maọbụ na Nahalol, kama ha mere ha ndị ohu na-arụ ọrụ ike.
\v 31 Ọzọkwa, ndị ebo Asha achụpụghị ndị niile bi nʼAkọ, na Saịdọn, na Ahlab, na Akzib, na Helba, na Afik, maọbụ Rehob.
\v 32 Ndị Asha binyere nʼetiti ndị Kenan bụ ndị bi nʼala ahụ, nʼihi na ha achụpụghị ha.
\v 33 Ndị ebo Naftalị achụpụghịkwa ndị bi na Bet-Shemesh, maọbụ ndị bi na Bet-Anat. Kama ndị Naftalị binyere ndị Kenan bi nʼala ahụ. Ma ndị bi na Bet-Shemesh, na Bet-Anat ghọrọ ndị ohu ndị Naftalị.
\v 34 Ma banyere ndị ebo Dan, ndị Amọrait chụpụrụ ha chụba ha nʼelu ugwu. Ha ekwenyeghị ka ha rịdata na ndịda ugwu ahụ.
\v 35 Ma ndị Amọrait nọgidesịrị ike nʼugwu Heres, na Aijalon, na Shaalbim, ma mgbe ike ebo Josef bara ụba, ha meriri ha, mee ha ndị ohu ha.
\v 36 Oke ala ụmụ ndị Amọrait malitere na mgbago Akrabim ruo, ma gafeekwa ebe a na-akpọ Sela.
\c 2
\s1 Mmụọ ozi \nd Onyenwe anyị\nd* abịa Bokim
\p 
\v 1 Mmụọ ozi \nd Onyenwe anyị\nd* sitere na Gilgal bịa Bokim gwa ndị Izrel okwu sị ha, “Mụ onwe m kpọpụtara unu site nʼIjipt, kpọbata unu nʼala a dịka m kwere nna unu ha na nkwa. Asịrị m, ‘Agaghị m ala azụ imezu ọgbụgba ndụ mụ na unu,
\v 2 unu na ndị bi nʼobodo ahụ agbakwala ndụ ọbụla, kama unu ga-etitu ebe ịchụ aja ha.’ Ma unu erubeghị isi nʼokwu a, gịnị mere unu emeghị nke a?
\v 3 Agwara m unu, na ‘agaghị m esite nʼihu unu chụpụ ha; ha ga-adịrị unu dịka ọnya nʼakụkụ niile, ebe chi niile ha ga-abụkwara unu ihe na-eweta ọnwụnwa.\f + \fr 2:3 \ft Maọbụ, \fqa Ihe ịma nʼọnya\f*’ ”\f + \fr 2:3 \ft \xt Ọpụ 23:33; Dit 7:17\xt*\f*
\p 
\v 4 Mgbe Mmụọ ozi \nd Onyenwe anyị\nd* ahụ kwusiri okwu ndị a, ụmụ Izrel niile kwara akwa nke ukwuu.
\v 5 Nʼihi nke a, ha kpọrọ ebe ahụ Bokim. Ha chụụrụ \nd Onyenwe anyị\nd* aja nʼebe ahụ.
\s1 Nnupu isi na Mmeri
\p 
\v 6 Mgbe Joshua zilagasịrị ndị Izrel niile, onye ọbụla nʼime ha gara nʼihe nketa ya, inweta ya, dịka ebo ọbụla dị nʼIzrel si dị.
\v 7 Ndị Izrel fere\f + \fr 2:7 \ft Maọbụ, \fqa gbasokwara\f*\nd Onyenwe anyị\nd* ofufe ụbọchị niile nke ndụ Joshua, na nke ndụ ndị okenye ahụ, bụ ndị gara nʼihu bie ndụ mgbe ọ nwụsịrị, bụkwa ndị hụrụ ọrụ ukwuu niile nke \nd Onyenwe anyị\nd* rụụrụ ndị Izrel.
\p 
\v 8 Ma Joshua, nwa Nun, onyeozi \nd Onyenwe anyị\nd* nwụrụ, mgbe ọ gbara otu narị afọ, na afọ iri.
\v 9 E liri ya nʼoke ala nke ihe nketa ya, nʼobodo Timnat Heres, nʼala ugwu ugwu nke ebo Ifrem, nʼụzọ mgbago ugwu Gaash.
\p 
\v 10 Emesịa, ọgbọ ahụ niile nwụrụ dịka ndị nna nna ha, ọgbọ ọzọ tolitere, ndị na-amaghị \nd Onyenwe anyị\nd* maọbụ ihe ndị nke o mere\f + \fr 2:10 \ft Ya bụ, ọrụ ebube\f* nye ụmụ Izrel.
\v 11 Mgbe ahụ, ndị Izrel mere ihe ọjọọ nʼanya \nd Onyenwe anyị\nd* site nʼife Baal ofufe.
\v 12 Ha gbakụtara \nd Onyenwe anyị\nd* azụ, bụ Chineke ahụ, nna ha fere ofufe, onye kpọpụtara ha site nʼala Ijipt. Ma ha malitere ife na ịsọpụrụ, na ịkpọ isiala nye ọtụtụ chi dị iche iche, bụ chi nke ndị bi ha gburugburu. Ha si otu a kpasuo \nd Onyenwe anyị\nd* iwe.
\v 13 Ha gbakụtara \nd Onyenwe anyị\nd* azụ, fee chi Baal na Ashtọret ofufe.\f + \fr 2:13 \ft \xt Abụ 106:36\xt*\f*
\v 14 Ya mere, \nd Onyenwe anyị\nd*\f + \fr 2:14 \ft \xt Nkp 3:8; 2Ez 17:20\xt*\f* were iwe megide Izrel, rara ha nye nʼaka ndị ji aka ike pụnara ha ihe ha nwere. O weere ha resi ndị iro ha gbara ha gburugburu, bụ ndị ha enwekwaghị ike iguzogide.
\v 15 Dịka ọ ṅụrụ ya nʼiyi nye ha, mgbe ọbụla ụmụ Izrel pụrụ ibu agha, aka \nd Onyenwe anyị\nd* megidere ha ime ka ha bụrụ ndị e meriri emeri. Ọnọdụ ha jọrọ njọ nke ukwuu.
\p 
\v 16 Nʼihi ọnọdụ ọjọọ a, \nd Onyenwe anyị\nd* mere ka ndị ikpe sị nʼetiti ha pụta, ịnapụta ha site nʼaka ndị a ji ike na-apụnara ha ihe ha nwere.
\v 17 Ma ụmụ Izrel egeghị ndị ikpe ahụ ntị, kama ha nọgidere na-akpọ isiala nye ma na-agbasokwa chi ndị ọzọ. Dịka nna nna ha na-emeghị, ha mere ngwangwa wezuga onwe ha site nʼụzọ \nd Onyenwe anyị\nd*, bụrụ ndị na-enupu isi nʼebe iwu \nd Onyenwe anyị\nd* dị.
\v 18 Ma mgbe ọbụla \nd Onyenwe anyị\nd* nyere ụmụ Izrel onye ikpe, ọ na-anọnyere onye ikpe ahụ ogologo ụbọchị niile nke ndụ ya. Ọ na-esitekwa nʼaka onye ikpe a napụta ụmụ Izrel nʼaka ndị iro ha nʼihi na \nd Onyenwe anyị\nd* nwere obi ebere nʼahụ ụmụ Izrel, mgbe ha na-asụ ude, nʼihi mmegbu na mkpagbu niile ndị iro ha na-emegbu ha, ma na-akpagbukwa ha.
\v 19 Ma mgbe ọbụla onye ikpe a nwụrụ, ụmụ Izrel na-alaghachi azụ biwe ndụ ọjọọ karịa nke nna nna ha ochie. Ha na-agbaso chi ndị ọzọ, na-akpọ isiala nye ha, na ife ha ofufe. Ha jụrụ iwezuga agwa ọjọọ ha ndị a ma ọ bụkwa ụzụ isiike ha.
\p 
\v 20 Nʼihi nke a, \nd Onyenwe anyị\nd* were iwe dị ọkụ megide Izrel, ma sị, “Nʼihi na mba a emebiela ọgbụgba ndụ ahụ m nyere nna ha nʼiwu, jụkwa ige m ntị,
\v 21 agaghị m achụpụkwa site nʼihu ha mba ndị ahụ Joshua hapụrụ mgbe ọ nwụrụ.
\v 22 Aga m eji ha nwalee Izrel, ịchọpụta ma ha ga-elezi anya idebe ụzọ \nd Onyenwe anyị\nd*, gaakwa ije nʼime ya dịka nna nna ha mere m.”
\v 23 \nd Onyenwe anyị\nd* hapụrụ mba ndị ahụ niile ka ha nọgide. Ọ chụpụghị ha ngwangwa site na inyefe ha nʼaka Joshua.
\c 3
\p 
\v 1 Ndị a bụ aha mba dị iche iche \nd Onyenwe anyị\nd* hapụrụ nʼala ahụ iji nwapụta ndị Izrel ahụ niile na-esoghị mgbe e buru agha nʼime ala Kenan.
\v 2 O mere nke a naanị ka ọ kuziere ọgbọ niile ndị Izrel ibu agha, bụ ndị ahụ na-amabeghị ihe agha bụ nʼoge gara aga.
\v 3 Ndịisi ise nke ndị Filistia, na ndị Kenan niile, ndị Saịdọn na ndị Hiv, ndị bi nʼelu ugwu Lebanọn, site nʼugwu Baal-Hemon ruo na mbata obodo Hamat.
\v 4 A ga-esite na ndị a nwapụta okwukwe ụmụ Izrel ma ịmata ma ha ga-edebe iwu \nd Onyenwe anyị\nd* sitere nʼọnụ Mosis nye nna nna ha ochie.
\p 
\v 5 Nʼihi nke a, ụmụ Izrel biri nʼetiti ndị Kenan, ndị Het, ndị Hiv, ndị Periz, ndị Amọrait, na ndị Jebus.
\v 6 Ha lụtaara onwe ha ụmụ ha ndị inyom na nwunye,\f + \fr 3:6 \ft \xt Ọpụ 34:15-16; Dit 7:3-4; Jos 23:12\xt*\f* werekwa ụmụ ha ndị inyom nye ụmụ ha ndị ikom, feekwa chi ha niile ofufe.
\s1 Otniel, onye ikpe
\p 
\v 7 Ụmụ Izrel mere ihe jọrọ njọ nʼanya \nd Onyenwe anyị\nd*. Ha chefuru \nd Onyenwe anyị\nd* Chineke ha, malite ife chi Baal, na Ashera ofufe.
\v 8 Nʼihi ya, iwe ọkụ \nd Onyenwe anyị\nd* kpaliri megide ụmụ Izrel. Ọ raara ha nye nʼaka eze Kushan Rishataim, eze Aram Naharaim, onye ndị Izrel nọrọ nʼokpuru ọchịchị ya afọ asatọ.
\v 9 Ma mgbe ụmụ Izrel kpọkuru \nd Onyenwe anyị\nd*, o mere ka Otniel, nwa Kenaz, bilie nʼetiti ha. Otniel bụ nwa nwanne Kaleb nke nta. Ọ bụkwa ya napụtara ụmụ Izrel site nʼaka ndị iro ha.
\v 10 Mmụọ \nd Onyenwe anyị\nd* bịakwasịrị ya, nke mere ka ọ bụrụ onye ikpe ndị Izrel, ọ pụrụ ibu agha. \nd Onyenwe anyị\nd* nyefere Kushan Rishataim bụ eze ndị Aram nʼaka Otniel, onye ike ya karịrị nke ya.
\v 11 Sitekwa nʼoge ahụ gaa nʼihu, udo dịịrị nʼala niile iri afọ anọ, mgbe Otniel na-ekpe Izrel ikpe. Nʼikpeazụ, Otniel, nwa Kenaz nwụrụ.
\s1 Ehud
\p 
\v 12 Ụmụ Izrel bidoro ime ihe ọjọọ nʼanya \nd Onyenwe anyị\nd*. Ya mere, \nd Onyenwe anyị\nd* nyefere ha nʼaka Eglọn, eze Moab.
\v 13 Ọ kpọtara ndị Amọn\f + \fr 3:13 \ft Ndị Amọn bụ ndị si nʼagbụrụ Lọt, nke a dị nʼakwụkwọ \xt Jen 19:38\xt*\ft , ebe ndị Amalek si nʼagbụrụ Ịsọ (ị ga-agụta nke a nʼakwụkwọ \xt Jen 36:12,16\xt*\ft ). Ọ bụghị naanị na ha bụ ndị agbataobi ndị Izrel, ma ha bụ ndị iro ka ndị iro niile nke ndị Izrel nwere (gụọ \xt Dit 25:17-18\xt*\ft ).\f* na ndị Amalek ka ha dịnyere ya. Eglọn bịara buso ndị Izrel agha, nweta obodo Nkwụ, ya abụrụzia nke ha.
\v 14 Afọ iri na asatọ site nʼoge ahụ ka ụmụ Izrel nọrọ nʼokpuru ọchịchị Eglọn, eze Moab.
\p 
\v 15 Ma mgbe ụmụ Izrel tikuru \nd Onyenwe anyị\nd* banyere ọnọdụ ọjọọ ha, o zitere ha onye nzọpụta. Aha nwoke ahụ bụ Ehud, nwa Gera, onye sitere nʼagbụrụ Benjamin. Ọ bụ onye na-eme aka ekpe. Ya onwe ya bụkwa onye na-ebugara Eglọn, eze Moab, ego ụtụ niile ụmụ Izrel na-atụ kwa afọ.
\v 16 Tupu ọ malite ije ya, o buru ụzọ kwadebere onwe ya mma agha nwere ihu abụọ na nzuzo. Ogologo mma ahụ ga-eru ihe dịka site nʼọnụ mkpịsịaka ruo nʼisi mbụ aka. Ehud kekwasịrị mma ahụ nʼapata ụkwụ aka nri ya, yikwasị ya uwe mwụda ya.
\v 17 O bunyere Eglọn, eze Moab ego ụtụ ahụ. Eglọn bụ nwoke buru oke ibu.
\v 18 Mgbe Ehud nyesịrị eze Eglọn ego ụtụ ahụ o ji bịa, o zilagara ndị butere ego ahụ.
\v 19 Mgbe ọ bịaruru nso nʼobodo Gilgal, ebe arụsị dị iche iche a pịrị apị dị, ọ laghachiri azụ jekwuru eze Eglọn sị ya, “Enwere m ozi m ga-ezi gị, ma ọ ga-abụ na nzuzo.”
\p Mgbe ahụ, eze zipụrụ ndị so ya nọdụ, ka ya na Ehud naanị nwee ike ịnọ kparịa ụka ha na nzuzo.
\p 
\v 20 Ehud bịakwutere ya mgbe ọ nọ naanị ya nʼọnụụlọ dị nʼime nʼelu ụlọeze ya, sị, “Enwere m ozi Chineke sị m zie gị.” Dịka eze ahụ si nʼoche ya bilite ọtọ,
\v 21 Ehud tinyere aka ekpe ya nʼime uwe ya, mịpụta mma ahụ nwere ihu abụọ nke o kegidere nʼapata ụkwụ aka nri ya. O weere ya mapuo eze Eglọn afọ.
\v 22 Ọ bụladị isi mma ahụ sooro ihu mma ahụ mibanye nʼime afọ ukwu eze Eglọn. Ọnụ mma ahụ pụtakwara nʼazụ eze ahụ. Ehud amịpụtaghị mma ahụ, kama abụba dị nʼafọ eze ahụ kpuchiri ya.
\v 23 Ya mere, Ehud pụrụ nʼezi, mechibido ya ọnụ ụzọ niile e si abanye nʼọnụụlọ elu ahụ, kpọchie ha.
\p 
\v 24 Mgbe ọ pụchara, ndị na-ejere eze ozi bịara chọọ ịbanye nʼụlọ ahụ. Ma mgbe ha hụrụ na a kpọchiri ọnụ ụzọ ụlọ ahụ akpọchi, ha kwuru nʼonwe ha sị, “Ọ ga-abụ na ọ na-anyụ nsị nʼụlọ mposi.”
\v 25 Ma mgbe oge dị anya gasịrị ma eze apụtaghị, ha enweghị ike ijide onwe ha ọzọ. Ha weere ọtụghe ụzọ tụghee ọnụ ụzọ ahụ, hụ ebe eze ha tọgbọrọ nʼala, nwụọ.
\p 
\v 26 Mgbe ahụ ha nọ na-eche, Ehud gbapụrụ. O sitere nʼebe ahụ arụsị ndị ahụ a pịrị apị dị gbafee, gbaga Seira.
\v 27 Mgbe o ruru nʼebe ahụ, ọ fụrụ opi ike nʼala ugwu ugwu Ifrem, ndị Izrel sooro ya site nʼugwu ahụ rịda, ya onwe ya na-edu ha.
\p 
\v 28 Ọ sịrị ha, “Soronụ m nʼazụ, nʼihi na \nd Onyenwe anyị\nd* enyela ndị Moab ndị iro unu nʼaka unu.” Ya mere, ha sooro ya gbadaa, gaa nọchie ụzọ niile ndị Moab nwere ike isi gafee osimiri Jọdan. Ha ekwekwaghị ka onye Moab ọbụla si nʼebe ahụ gafee.
\v 29 Nʼụbọchị ahụ, ha gburu puku ndị agha Moab iri, ha niile siri ike bụrụkwa dimkpa. O nweghị otu onye gbapụrụ.
\v 30 Nʼụbọchị ahụ, e mere ka Moab nọdụ nʼokpuru ndị Izrel. Ala ahụ nwere ozuzu ike na udo, iri afọ asatọ.
\s1 Shamga
\p 
\v 31 Mgbe Ehud chịsịrị, Shamga, nwa Anat rịgotara ịchị. O tigburu narị ndị Filistia isii. Ọ bụ ndụdụ e ji achị ehi ka o ji tigbuo ha. Ya onwe ya kwa, zọpụtara ndị Izrel.
\c 4
\s1 Debọra
\p 
\v 1 Mgbe Ehud nwụsịrị, ụmụ Izrel mekwara ihe ọjọọ megide \nd Onyenwe anyị\nd*.
\v 2 Nʼihi ya, \nd Onyenwe anyị\nd* renyere ha nʼaka Jabin, eze Kenan, onye chịrị nʼobodo Hazọ. Aha onyeisi ndị agha ya bụ Sisera, onye bi nʼobodo a na-akpọ Heroshet Hagoyim.
\v 3 Nʼihi na o nwere narị ụgbọ agha igwe itoolu, ma megbukwaa ụmụ Izrel nke ukwu iri afọ abụọ, ha tikuru \nd Onyenwe anyị\nd* mkpu akwa, ka o nyere ha aka.
\p 
\v 4 Nʼoge a, Debọra, bụ nwanyị na-ebu amụma, nwunye Lapidọt bụ onyendu ụmụ Izrel.
\v 5 Ọ na-anọ nʼokpuru osisi nkwụ a na-akpọ Nkwụ Debọra, nke dị nʼagbata Rema na Betel, bụ nʼala ugwu ugwu Ifrem na-ekpe ikpe. Nʼebe ahụ ka ụmụ Izrel na-ejekwuru ya ka o doziere ha okwu ha niile.
\v 6 O ziri ozi kpọọ Barak, nwa Abinoam, onye bi nʼobodo Kedesh, nke dị nʼime Naftalị, ọ sịrị ya, “\nd Onyenwe anyị\nd* Chineke ụmụ Izrel na-enye gị iwu, ‘Gaa chịkọtaa puku ndị agha iri bụ ndị sitere nʼebo Naftalị na Zebụlọn, duru ha jeruo ugwu Taboa.
\v 7 Aga m edute Sisera, ọchịagha ndị agha Jabin, mee ka ọ bịaruo nso iyi ukwu Kishọn, ya na ụgbọ agha ya niile na ndị agha ya niile ma nyefee ha nʼaka gị.’ ”
\p 
\v 8 Barak sịrị ya, “Ejikeere m ịga ma ọ bụrụ na ị ga-eso m. Ọ bụrụkwanụ na ị jụ iso m, agaghị m aga.”
\p 
\v 9 Debọra sịrị, “Aghaghị m isoro gị jee ma nʼihi mkpebi gị nʼihe a, nsọpụrụ agaghị abụ nke gị, nʼihi na \nd Onyenwe anyị\nd* ga-enyefe Sisera nʼaka nwanyị.” Ya mere, Debọra biliri soro Barak jee obodo Kedesh.
\v 10 Barak sitere nʼebo Zebụlọn na Naftalị kpọkọtaa ndị ikom ga-eso ya jee agha ahụ, puku ndị agha iri ndị dịnyere ya. Debọra sokwa ya jee.
\p 
\v 11 Nʼoge a, Heba,\f + \fr 4:11 \ft Ezi mmekọrịta nke dị nʼetiti ndị Izrel na ndị Ken, bidoro nʼoge Mosis. \xt Ọpụ 3:1\xt*\ft Ndị Ken nyeere ụmụ Izrel aka imeri ndị iro ha, mgbe ha na-achọ inweta Kenan bụ ala nkwa ahụ \xt Nkp 1:16\xt*\f* onye Ken, ahapụla ndị Ken ndị ọzọ, ndị bụ ụmụ ụmụ Hobab, nwanne nwunye Mosis gaa maa ụlọ ikwu ya nʼokpuru osisi ukwu dị na Zaananim, nke dị nso Kedesh.
\p 
\v 12 Mgbe ha gwara Sisera na Barak nwa Abinoam arịgorola nʼelu ugwu Taboa,
\v 13 Sisera kpọkọtara ndị agha ya niile, tinyere narị ụgbọ agha itoolu ya, site na Haroshet Haroyim gaa nʼiyi ukwu Kishọn.
\p 
\v 14 Mgbe ahụ, Debọra sịrị Barak, “Gaa nʼihu! Taa bụ ụbọchị nke \nd Onyenwe anyị\nd* nyefere Sisera nʼaka gị. Ọ bụ na \nd Onyenwe anyị\nd* apụbeghị jee nʼihu gị?” Nʼihi nke a, Barak duuru puku ndị agha iri ahụ gbada ndịda ugwu Taboa.
\v 15 Mgbe ahụ, \nd Onyenwe anyị\nd* jiri mma agha ya chụsaa Sisera na ndị agha ya na ụgbọ agha igwe ha nʼihu Barak. Sisera nʼonwe ya hapụrụ ụgbọ agha ya jiri ụkwụ gbapụ ọsọ.
\p 
\v 16 Barak na ndị agha ya chụrụ ndị agha ahụ ọsọ, ha na ụgbọ agha igwe ha niile, chụruo ha Haroshet Hagoyim. Ha ji mma agha tigbuo ndị agha Sisera niile. Ọ dịkwaghị otu onye nʼime ha fọdụrụ ndụ.
\v 17 Ma Sisera gbapụrụ ọsọ gaa zoo onwe ya nʼụlọ ikwu Jael, nwunye Heba, onye Ken. Nʼihi udo dị nʼetiti eze Jabin, onye Hazọ, na ndị ezinaụlọ Heba, onye Ken.
\p 
\v 18 Jael pụrụ ije zute Sisera sị ya, “Bịa Onyenwe m, bakwute m. Atụla ụjọ.” Ya mere na ọ bara nʼime ụlọ ikwu ya, o weere akwa ịchụ oyi kpuchie ya.
\p 
\v 19 Mgbe ahụ, ọ sịrị ya, “Akpịrị na-akpọ m nkụ, nyetụ m mmiri ka m ṅụọ.” O meghere karama akpụkpọ mmiri ara ehi, nye ya ihe ọṅụṅụ, jirikwa akwa ahụ sachie ya.
\p 
\v 20 Sisera gwara nwanyị ahụ bụ Jael okwu sị, “Guzo nʼọnụ ụzọ ụlọ a. Ọ bụrụ na onye ọbụla abịa jụọ gị, ‘O nwere onye gbabatara nʼebe a?’ sị ya, ‘Mba.’ ”
\p 
\v 21 Ike gwụrụ nnọọ Sisera. Mgbe ahụ, ọ malitere ịrahụ ụra, Jael, nwunye Heba, wepụtara otu ǹtu e ji a kpọgide ụlọ ikwu ahụ nʼala, werekwa mkpirisi igwe nʼaka ya. O jiri nwayọọ jekwuuru Sisera ebe o dina na-arahụ ụra, kpọọ ya ǹtu ahụ nʼegedege ihu ya. Otu a ka Sisera si nwụọ.
\p 
\v 22 Mgbe Barak bịara ịchọ Sisera, Jael jekwuru ya sị, “Bịa ka m gosi gị nwoke ahụ ị na-achọ.” Barak sooro ya jee, ma lee, Sisera anwụọlarị site na ǹtu ahụ a kpọrọ ya nʼisi.
\p 
\v 23 Nʼụbọchị ahụ, Chineke meriri Jabin, eze ndị Kenan nʼihu ụmụ Izrel.
\v 24 Aka ụmụ Izrel bụ nke dị ike na-adịkwa ike nke ukwu megide Jabin bụ eze Kenan ruo mgbe ha lara ya nʼiyi.
\c 5
\s1 Abụ Debọra
\p 
\v 1 Nʼụbọchị ahụ, Debọra na Barak nwa Abinoam bụrụ abụ\f + \fr 5:1 \ft Banyere mmeri ahụ dị ukwu\f* sị,
\q1 
\v 2 “Mgbe ndị ndu na-edu nʼIzrel,
\q2 mgbe ndị mmadụ jikwa afọ ofufu nye onwe ha,
\q2 toonu \nd Onyenwe anyị\nd*!
\b
\q1 
\v 3 “Nụrụnụ nke a, unu ndị eze, Geenụ ntị, unu ndịisi!
\q2 Mụ onwe m, ọ bụladị mụ onwe m, ga-abụku Onyenwe anyị abụ.
\q2 Aga m abụ abụ otuto nye \nd Onyenwe anyị\nd*, bụ Chineke Izrel.
\b
\b
\q1 
\v 4 “\nd Onyenwe anyị\nd*, mgbe i si Sia pụta,
\q2 mgbe i sitere nʼala Edọm gabiga,\f + \fr 5:4 \ft Duuru anyị gabiga ọzara Edọm\f*
\q1 ụwa mara jijiji, mmiri ozuzo dị ukwuu
\q2 sikwa na mbara eluigwe zodata.
\q1 
\v 5 E, ọ bụladị ugwu ukwu niile mara jijiji nʼihu \nd Onyenwe anyị\nd*.
\q2 Ugwu Saịnaị makwara jijiji nʼihu \nd Onyenwe anyị\nd*, Chineke Izrel.
\b
\q1 
\v 6 “Nʼụbọchị Shamga, nwa Anat,
\q2 nʼụbọchị Jael, ndị ịnyịnya ibu na-azụ ahịa nʼọzara kwusịrị,
\q2 ndị ije niile na-esi nʼakụkụ ụzọ gbagọrọ agbagọ na-aga.
\q1 
\v 7 Ọ dịkwaghị ihe gara aga nʼobodo Izrel,
\q2 tutu ruo mgbe m bịara,
\q2 ee, mgbe m bụ Debọra bịara dịka nne nye Izrel.
\q1 
\v 8 Mgbe ụmụ Izrel họrọ ife chi ndị ọzọ ofufe,
\q2 mgbe agha bịara nʼọnụ ụzọ ama niile,
\q1 ahụghị ọ bụladị otu ụta maọbụ ùbe.\f + \fr 5:8 \ft Ndị iro ha ekwekwaghị ka onye Izrel ọbụla jide ngwa agha ọbụla.\f*
\q2 E, ọ bụladị nʼetiti iri puku ndị agha anọ, a hụghị otu ngwa agha ọbụla.
\q1 
\v 9 Ma ugbu a, ana m aṅụrị ọṅụ banyere ndị na-achị ụmụ Izrel.
\q2 Ndị ji obi ha niile were onwe ha nye nʼetiti ndị Izrel.
\q2 Toonu \nd Onyenwe anyị\nd*!
\b
\q1 
\v 10 “Kwupụtanụ ya, unu ndị na-agba ịnyịnya ibu dị ọcha,
\q2 unu ndị na-anọkwasị nʼelu akwa dị oke ọnụahịa nʼelu ịnyịnya unu,
\q2 na unu ndị na-eji ukwu na-agagharị nʼokporoụzọ.
\q1 Tụleenụ
\v 11 olu abụ igwe mmadụ ndị nọ nʼakụkụ olulu mmiri niile.
\q2 Ha na-akọ akụkọ mmeri niile nke \nd Onyenwe anyị\nd*,
\q2 ya bụ, mmeri nke obodo nta ya niile nʼIzrel.
\b
\q1 “Mgbe ahụ, ndị nke \nd Onyenwe anyị\nd*
\q2 ridara gaa nʼọnụ ụzọ ama niile e si abata nʼobodo.
\q1 
\v 12 ‘Teta, teta, gị Debọra!
\q2 Teta, teta, bụọ abụ.
\q1 Bilie, gị Barak nwa Abinoam, bilie!
\q2 Duru ndị ahụ niile ị dọtara nʼagha.’
\b
\q1 
\v 13 “Ndị fọdụrụ na ndị a na-asọpụrụ rịdatara,
\q2 ndị nke \nd Onyenwe anyị\nd* bịakwutere m imegide ndị dị ike.
\q1 
\v 14 Ụfọdụ si Ifrem bịa, bụ ndị ahụ nwere mgbọrọgwụ nʼala ndị Amalek,
\q2 ndị Benjamin sokwa pụta,
\q1 ndị ndu sikwa Makia bịa,
\q2 ndị na-eso ndị ndu sikwa Zebụlọn pụta.
\q2 
\v 15 Ndị ndu ebo Isaka pụkwutekwara Debọra.
\q2 E, Isaka sokwara Barak
\q2 na ndagwurugwu ahụ ka ezigara ha nʼokpuru ya.
\q1 Ma nʼetiti ndị Ruben,
\q2 ha nọ na-atụgharị uche.
\q1 
\v 16 Gịnị mere unu ji nọdụ nʼetiti ọgba atụrụ,
\q2 ịnụ ụda ọja a na-egburu igwe atụrụ?
\q1 Nʼetiti obodo niile nke Ruben,
\q2 ka e nwere ọtụtụ ntụgharị uche.
\q1 
\v 17 Ndị Gilead nọgidere nʼofe ọzọ nke osimiri Jọdan.
\q2 Ndị Dan nọgidekwara nʼime ụgbọ mmiri ha.
\q1 Ndị Asha nọgidere nʼahụ udo
\q2 nʼakụkụ ọnụ mmiri.
\q1 
\v 18 Ma ndị Zebụlọn na Naftalị jiri ndụ ha chụọ aja,
\q2 pụọ nʼọzara ibu agha ahụ.
\b
\q1 
\v 19 “Ndị eze ala Kenan bịara ọgụ na Teanak,
\q2 nʼakụkụ mmiri ala Megido.
\q1 Ma ha enweghị mmeri ọbụla.
\q2 Ha akwataghị ọlaọcha maọbụ ihe nkwata ọzọ nʼagha.
\q1 
\v 20 Ọ bụladị kpakpando niile
\q2 dị na mbara eluigwe lụrụ ọgụ megide Sisera.
\q1 
\v 21 Mmiri na-achị ọkụ nke iyi ukwu Kishọn bupụrụ ha niile.
\q2 Ya mere, mkpụrụobi m gaa nʼihu,
\q2 zoo ụkwụ gị nʼala, dị ike dịka ọdụm!
\q1 
\v 22 Gee ntị nụrụ ụda nzọ ụkwụ nke ịnyịnya ndị iro.
\q2 Leekwa mwuli elu nke ụkwụ ịnyịnya ahụ!
\q1 
\v 23 Ma Mmụọ ozi \nd Onyenwe anyị\nd* sịrị,
\q2 ‘Bụọ Meroz\f + \fr 5:23 \ft Meroz bụ obodo dị nʼebo Naftalị. Ha esonyeghị ndị Izrel mgbe ha na-alụ agha, ha e nyeghịkwa aka jide ndị iro Izrel e meriri emeri, mgbe ha na-agbapụ ọsọ ndu, ya mere e ji bụọ ha ọnụ.\f* ọnụ.’
\q1 ‘Bụọ ndị bi na ya ọnụ ebe ọ dị ukwuu,
\q2 nʼihi na ha abịaghị nyere \nd Onyenwe anyị\nd* aka imeri ndị iro ya.’
\b
\b
\q1 
\v 24 “Onye a gọziri karịchasịa ka Jael,
\q2 nwunye Heba onye Ken bụ,
\q2 e, onye a gọziri karịchasịa ndị inyom niile na-ebi nʼụlọ ikwu.
\q1 
\v 25 Nwoke ahụ rịọrọ mmiri, ma o nyere ya mmiri ara ehi,
\q2 o ji iko kwesiri ndị a na-asọpụrụ nye ya mmiri ara ehi rahụrụ arahụ.
\q1 
\v 26 O setịpụrụ aka ya were ǹtu ji ụlọ ikwu ahụ,
\q2 aka nri ya welitere mkpirisi igwe nke onye ọrụ ji arụ ọrụ.
\q1 Ọ kpọrọ ya Sisera otu mkpọ, kpọrie ya isi,
\q2 ọ kpọwasịrị, ma kpọmie ǹtu ahụ nʼegedege ihu ya.
\q1 
\v 27 Nʼụkwụ ya ka o milara nʼala,
\q2 nʼebe ahụ ọ dara, ka o dinara.
\q1 Nʼụkwụ ya ka o milara nʼala, nʼebe ọ dara,
\q2 nʼebe ahụ o milara nʼala, nʼebe ahụ ọ dara nwụọ.
\b
\q1 
\v 28 “Nne Sisera si na oghereikuku lepụ anya
\q2 nʼazụ oghere ịnata ikuku, o tiri mkpu,
\q1 ‘Gịnị mere ụgbọala igwe ya ji anọ ọdụ ịbịa?
\q2 Gịnị ji na mkpọtụ ụkwụ ụgbọala ya adawabeghị?’
\q1 
\v 29 Ma otu nʼime ndị inyom na-ejere ya ozi, nke makarịsịrị ibe ya nʼihe.
\q2 E, ya onwe ya kwukwara sị,
\q1 
\v 30 ‘Ọ bụ na ha adịghị achọta ma na-ekekwa ọtụtụ ihe a kwatara nʼagha:
\q2 onye agha ọbụla ga-eketa otu nwaagbọghọ, maọbụ abụọ.
\q1 Sisera ga-enweta uwe nwere ọtụtụ agwa dị iche iche,
\q2 uwe nwere ọtụtụ agwa ndị a kpara nke ọma
\q1 uwe ndị akpaziri nke ọma maka ịnya nʼolu m,
\q2 ihe ndị a niile dịka ihe nkwata nʼagha?’
\b
\b
\q1 
\v 31 “\nd Onyenwe anyị\nd*, biko, ka ndị iro gị niile si otu a laa nʼiyi.
\q2 Ka ndị niile hụrụ gị nʼanya nwupụta ihe dịka anyanwụ
\q2 mgbe o biliri nʼike.”
\p E nwere izuike nʼala ahụ iri afọ anọ.
\c 6
\s1 Gidiọn
\p 
\v 1 Ọzọkwa, ụmụ Izrel mere ihe ọjọọ nʼanya \nd Onyenwe anyị\nd*, nʼihi ya, \nd Onyenwe anyị\nd* nyefere ha nʼaka ndị Midia\f + \fr 6:1 \ft Ndị Midia, bụ ndị si nʼotu agbụrụ nʼime ụmụ ndị Ketura mụtara Ebraham.\f* afọ asaa.
\v 2 Nʼihi na ndị Midia mekpara ha ahụ nke ukwuu, ụmụ Izrel meere onwe ha ebe obibi nʼugwu, nʼime ọgba nkume, na nʼebe e wusiri ike dị iche iche.
\v 3 Mgbe ọbụla ndị Izrel ghasịrị mkpụrụ nʼubi ha, ndị Midia, ndị Amalek na ụfọdụ ndị ọzọ si nʼọwụwa anyanwụ na-abịa buso ha agha.
\v 4 Ha na-ebichi ala ahụ, bibie ihe niile a kụrụ nʼubi nʼala ahụ niile ruo na Gaza. O nweghị ihe ọbụla dị ndụ ndị Izrel nwere, ma atụrụ, ma ehi, ma ịnyịnya ibu, ha na-ahapụ.
\v 5 Dịka usuu igurube ka ha na-abịa, ha na anụ ụlọ ha niile, na ụlọ ikwu ha niile. Ọnụọgụgụ ha dị ukwuu ruo na-apụghị ịgụta ole ha dị, maọbụ ịnyịnya kamel ha. Ha na-abata nʼala ahụ nʼihi ibibicha ya.
\v 6 Site nʼomume ọjọọ ndị a, e mere ka ụmụ Izrel bụrụ ndị dara ụbịam nke ukwuu nʼihi ọchịchị ndị Midia. Nʼikpeazụ, ụmụ Izrel tikuru \nd Onyenwe anyị\nd* ka o nyere ha aka.
\p 
\v 7 Mgbe ụmụ Izrel tikuru \nd Onyenwe anyị\nd* nʼihi mkpagbu ndị Midia na-akpagbu ha,
\v 8 \nd Onyenwe anyị\nd* zitere onye amụma, onye gwara ha okwu sị, “Ihe a bụ ihe \nd Onyenwe anyị\nd* Chineke nke Izrel kwuru, Esi m nʼala Ijipt, ala ahụ unu bụ ndị ohu nʼime ya, kpọpụta unu.
\v 9 Anapụtara m unu site nʼaka ike ndị Ijipt na site nʼaka ndị niile kpagburu unu, chụpụ ha site nʼihu unu, ma nye unu ala ha.
\v 10 Agwara m unu sị, ‘Mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke unu. Unu efela chi niile nke ndị Amọrait, ndị unu bi nʼala ha.’ Ma unu jụrụ ige m ntị.”
\p 
\v 11 Mmụọ ozi \nd Onyenwe anyị\nd* bịara nọdụ ọdụ nʼokpuru osisi ukwu ook dị nʼOfra, nʼala ubi Joash, onye obodo Abieza, ebe nwa ya a na-akpọ Gidiọn nọ na-azọcha mkpụrụ ọka wiiti nʼime ebe ịzọcha mkpụrụ vaịnị nʼihi na ọ na-ezo onwe ya ka ndị Midia hapụ ịhụ ya anya.
\v 12 Mmụọ ozi \nd Onyenwe anyị\nd* pụtara ihe nʼebe ahụ gwa ya okwu sị, “Gị dike na dimkpa nʼagha, \nd Onyenwe anyị\nd* nọnyeere gị.”
\p 
\v 13 Gidiọn zara sị, “Biko onyenwe m, ma ọ bụrụ na \nd Onyenwe anyị\nd* nọnyeere anyị, gịnị mere ihe ndị a niile ji na-adakwasị anyị? Ebeekwanụ ka ihe ịrịbama ahụ niile dị nke nna anyị ha gwara anyị sị, ‘Ọ bụghị site nʼIjipt ka \nd Onyenwe anyị\nd* siri gbapụta anyị?’ Ma ugbu a, \nd Onyenwe anyị\nd* ajụla anyị, hapụ anyị nʼaka ndị Midia ka ha laa anyị nʼiyi.”
\p 
\v 14 Mgbe ahụ, \nd Onyenwe anyị\nd* nyere ya iwu sị ya, “Ngwa, jiri ike gị dị ukwuu pụọ, gaa ka ị gbapụta ụmụ Izrel site nʼaka ndị Midia. Mụ onwe m na-ezigakwa gị.”
\p 
\v 15 Ma Gidiọn sịrị ya, “Biko, Onyenwe m, olee otu m ga-esi zọpụta Izrel? Lee, esi m nʼikwu dịkarịsịrị nta nʼime Manase pụta. Mụ onwe m bụkwa onye dịkarịsịrị ala nʼezinaụlọ m.”
\p 
\v 16 Ma \nd Onyenwe anyị\nd* zara sị ya, “Mụ onwe m ga-anọnyere gị. Ị ga-ebibikwa ndị Midia niile.”
\p 
\v 17 Gidiọn zaghachiri sị, “Ọ bụrụ na m achọtala ihuọma nʼanya gị, nye m ihe ịrịbama nke ga-egosi na ọ bụ gị nʼezie na-agwa m okwu.
\v 18 Biko esikwala ebe a pụọ ruo mgbe m lọghachiri weta onyinye m ga-eche nʼihu gị.”
\p \nd Onyenwe anyị\nd* zara sị ya, “Aga m eche ruo mgbe ị lọghachiri.”
\p 
\v 19 Gidiọn mere ngwangwa laa nʼụlọ ya, gbuo otu nwa ewu, sie ya. O jikwa ụtụ ọka mee achịcha, nke ihe na-eko achịcha na-adịghị nʼime ya. Emesịa, o tinyere anụ ahụ nʼime nkata, wụnyekwa ofe nʼime ite, buru ha jekwuru Mmụọ ozi ahụ, ebe ọ nọ na-eche ya nʼokpuru osisi ook ahụ.
\p 
\v 20 Mmụọ ozi nke Chineke sịrị ya, “Were anụ a na ogbe achịcha ahụ na-ekoghị eko, tụkwasị ha nʼelu nkume a, wụpụkwa ofe ahụ.” Gidiọn mere otu a.
\v 21 Mgbe Mmụọ ozi \nd Onyenwe anyị\nd* ahụ metụrụ ọnụ mkpanaka ahụ nke dị nʼaka ya nʼelu anụ na achịcha ahụ na-ekoghị eko. Ọkụ sitere nʼoke nkume ahụ nwuru, rechapụ anụ ahụ na achịcha nʼekoghị eko ahụ. Mmụọ ozi nke \nd Onyenwe anyị\nd* ahụ gbara barịị site nʼihu ya.
\v 22 Mgbe Gidiọn ghọtara na ọ bụ Mmụọ ozi nke \nd Onyenwe anyị\nd*, o tiri mkpu akwa sị, “Ewoo! Onyenwe m \nd Onyenwe anyị\nd*! Ahụla m Mmụọ ozi \nd Onyenwe anyị\nd* ihu na ihu!”
\p 
\v 23 Ma \nd Onyenwe anyị\nd* sịrị ya, “Udo dịrị gị, atụla egwu! Ị gaghị anwụ.”
\p 
\v 24 Ya mere, Gidiọn wuuru \nd Onyenwe anyị\nd* ebe ịchụ aja nʼebe ahụ, kpọọ ya, \nd Onyenwe anyị\nd* bụ Onye Udo. Ụlọ nchụaja ahụ dịkwa nʼime obodo Ofra nʼala ndị Abieza ruo taa.
\p 
\v 25 Nʼabalị ụbọchị ahụ, \nd Onyenwe anyị\nd* gwara Gidiọn okwu sị ya, “Were oke ehi nna gị, bụ oke ehi nke abụọ, nke gbara afọ asaa. Dọtuo ebe ịchụ aja nna gị wuru maka Baal, gbutukwaa ogidi osisi Ashera dị nʼakụkụ ya.
\v 26 Mgbe ahụ, wuoro \nd Onyenwe anyị\nd* bụ Chineke gị ebe ịchụ aja, nʼelu ebe a dị oke elu. Jiri osisi Ashera ahụ nke ị gbuturu kwanye ọkụ, chụọ oke ehi nke abụọ ahụ dịka aja nsure ọkụ.”
\p 
\v 27 Ya mere, Gidiọn duuru mmadụ iri site na ndị na-ejere ya ozi, ndị nyeere ya aka imezu ihe niile dịka \nd Onyenwe anyị\nd* nyere ya nʼiwu. Kama, site nʼegwu maka ndị ikwu nna ya, na ndị bi nʼobodo ahụ, o mere ihe ndị a niile nʼime abalị.
\p 
\v 28 Mgbe chi bọrọ, mgbe ndị obodo ahụ malitere ijegharị, ha hụrụ na a kwatuola ebe ịchụ aja Baal, hụkwa na e gbutuola ogidi osisi Ashera dị nʼakụkụ ya, ma werekwa oke ehi nke abụọ chụọ aja nʼelu ebe ịchụ aja ọhụrụ ahụ!
\p 
\v 29 Ha jụrịtara onwe ha ajụjụ sị, “Onye mere ihe dị otu a?”
\p Mgbe ha ji nwayọọ jụgharịa ajụjụ, a gwara ha sị, “Ọ bụ Gidiọn nwa Joash mere ya.”
\p 
\v 30 Ndị obodo ahụ sịrị Joash, “Kpụpụta nwa gị. Ọ ga-anwụrịrị, nʼihi na ọ kwadala ebe ịchụ aja Baal, gbutuo ogidi osisi Ashera, nke dị nʼakụkụ ya.”
\p 
\v 31 Ma Joash tinyere ọnụ jụọ ha ajụjụ sị ha, “Baal, ọ gwara unu na ọ chọrọ ka unu nyere ya aka? Unu na-achọ ịzọpụta ya? Onye ọbụla wepụtara onwe ya maka ịlụrụ Baal ọgụ ga-anwụ tupu chi echi abọọ. Ọ bụrụ nʼezie na Baal bụ chi, hapụnụ ya ka o tigbuo onye ahụ mebiri ebe ịchụ aja ya.”
\v 32 Ya mere, nʼụbọchị ahụ, ha malitere ịkpọ Gidiọn “Jerub-Baal.” Ha kwuru sị, “Ka Baal lụọrọ onwe ya ọgụ,” nʼihi na ọ kwadara ebe ịchụ aja Baal.
\p 
\v 33 Mgbe na-adịghị anya, usuu ndị agha Midia, na ndị Amalek, na obodo niile gbara ha gburugburu jikọtara onwe ha nʼotu, bịa ibu agha megide ụmụ Izrel. Ha niile gafere osimiri Jọdan, bịaruo na Ndagwurugwu Jezril ebe ha mara ụlọ ikwu.
\v 34 Mgbe ahụ, Mmụọ Nsọ \nd Onyenwe anyị\nd* bịakwasịrị Gidiọn. Ọ fụrụ opi ike nke o ji kpọkọta ndị agha ka ha zukọọ. Ndị agha niile si nʼikwu Abieza pụkwutere ya.
\v 35 Otu aka ahụ, o zipụrụ ndị ozi ka ha jekwuru ndị agha ndị Manase, na nke ndị Asha, na nke ndị Zebụlọn, na nke ndị Naftalị, ịkpọ ha ka ha bịa soro ya gaa ibu agha. Ha niile kwenyere pụkwute ya maka agha ahụ.
\p 
\v 36 Gidiọn sịrị Chineke, “Ọ bụrụ nʼezie na ị ga-azọpụta Izrel site nʼaka m dịka i kwere na nkwa,
\v 37 lee, aga m edebe ajị anụ nʼebe ịzọcha ọka. Ọ bụrụ na igirigi adakwasị naanị nʼelu ajị anụ ahụ ma ala ebe ọ tọgbọ gbakọọ agbakọ, mgbe ahụ aga m amata na ị ga-anapụta Izrel site nʼaka m, dịka ị kwuru.”
\v 38 Ihe a mezukwara dịka Gidiọn si rịọọ ya. Mgbe chi bọrọ, ọ gara welite ajị anụ ahụ chọpụta na o jupụtara na mmiri. Mmiri o si na ya pịpụta juru otu efere miri emi.
\p 
\v 39 Mgbe ahụ, Gidiọn sịrị Chineke, “Ka iwe gị ghara ịdị ọkụ megide m. Ka m rịọkwuo naanị otu ihe ọzọ. Kwere ka m jiri ajị anụ a nwalee otu ugboro ọzọ, kama nʼoge a, mee ka mmiri ghara ịdị nʼajị anụ ahụ, ma ka igirigi jupụta nʼala ebe ọ tọgbọ.”
\v 40 Nʼabalị ahụ, Chineke mere otu a. Ala niile gbaa gburugburu dere mmiri site nʼigirigi, ma mmiri ọbụla adịghị nʼajị anụ ahụ.
\c 7
\s1 Gidiọn emerie ndị Midia
\p 
\v 1 Jerub-Baal, onye bụkwa Gidiọn, na ndị agha ya niile biliri nʼisi ụtụtụ, maa ụlọ ikwu ha nʼisi iyi Harod. Ma ndị agha Midia mara ụlọ ikwu nke ha nʼakụkụ ugwu ebe ndị Izrel nọ, nʼime ndagwurugwu nke dị nso nʼugwu nta More.
\v 2 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Gidiọn okwu sị ya, “Lee, ndị ikom gị dị ọtụtụ. Agaghị m enyefe ndị Midia nʼaka ha, ma ọ bụghị otu a, Izrel ga-anya isi megide m, sị, ‘Ike aka m azọpụtala m.’\f + \fr 7:2 \ft Ịdị ọtụtụ nke ọnụọgụgụ ndị agha ha\f*
\v 3 Ugbu a, maa ọkwa nye ndị agha sị ha, ‘Onye ọbụla ụjọ na-atụ, ya hapụ ugwu Gilead laghachi azụ.’ ” Nʼihi nke a, iri puku ndị agha abụọ na abụọ laghachiri azụ nʼụlọ nke aka ha. Ma ndị agha dị puku iri nʼọnụọgụgụ fọdụrụ.
\p 
\v 4 Ma \nd Onyenwe anyị\nd* gwara Gidiọn, sị ya, “Lee, ndị agha gị ka dị ọtụtụ. Duru ha gbada na mmiri ala, m ga-anwale ha ma webilatara gị ọnụọgụgụ ha nʼebe ahụ. Ọ bụrụ na m sị, ‘Onye nke a ga-eso gị jee,’ ọ ga-eje, ma ọ bụrụ na m sị, ‘Onye nke a agaghị eso gị jee,’ ọ gaghị eso jee.”
\p 
\v 5 Ya mere, Gidiọn duuru ha bịa na mmiri ala ahụ. Nʼebe ahụ, \nd Onyenwe anyị\nd* gwara ya okwu sị ya, “Kewapụ ndị ji ire ha rachara mmiri dịka nkịta, site na ndị ahụ gburu ikpere nʼala ịṅụ mmiri.”
\v 6 Ọ bụ naanị narị ndị agha atọ ji ọbụ aka ha kwọlịte mmiri ha ṅụrụ. Ma ndị agha fọdụrụ gburu ikpere ha abụọ nʼala tinye ọnụ ha na mmiri, ṅụọ mmiri.
\p 
\v 7 \nd Onyenwe anyị\nd* sịrị Gidiọn, “Ọ bụ narị ndị ikom atọ ndị a raara mmiri ka m ga-eji zọpụta gị, ma rarakwa ndị Midia nye gị nʼaka. Zilaga ndị fọdụrụ ka ha laa nʼụlọ nke aka ha.”
\v 8 Gidiọn zilagara ndị Izrel ndị a nʼụlọ ikwu ha ma hapụ naanị narị mmadụ atọ ndị napụtara ndị ahụ na-ala ala ngwongwo niile ha ji ebu agha, na opi ike.
\p Ndị Midia mara ụlọ ikwu ha na ndagwurugwu, nʼebe na-adịghị anya site nʼebe Gidiọn nọ.
\v 9 Nʼabalị ahụ, \nd Onyenwe anyị\nd* gwara Gidiọn okwu sị ya, “Bilie, gaa lụso ọmụma ụlọ ikwu ahụ agha, nʼihi na ana m aga inyefe ha nʼaka gị.
\v 10 Ma ọ bụrụ na ụjọ na-atụ gị ibuso ha agha, duru Pura onyeozi gị gaa nso nʼọmụma ụlọ ikwu ahụ,
\v 11 ṅaa ntị, nụrụ ihe ha na-ekwu. Emesịa, ị ga-abụ onye a gbara ume ibu agha megide ọmụma ụlọ ikwu ahụ.” Ya mere, ya na Pura onyeozi ya gara nʼebe dị nso, nʼebe ndị nche ọmụma ụlọ ikwu ahụ nọ.
\v 12 Ma lee, usuu ndị agha Midia, na ndị Amalek, na ndị obodo ndị ọzọ ahụ si nʼọwụwa anyanwụ bịa jupụtara na ndagwurugwu ahụ dị ka igurube. Nʼezie, ịnyịnya kamel ha dị ọtụtụ, dịka aja dị nʼakụkụ oke osimiri.
\p 
\v 13 Gidiọn rutere mgbe otu onye nọ na-akọrọ enyi ya banyere nrọ ọ rọrọ. Ọ na-asị, “Arọrọ m nrọ, ebe otu ogbe achịcha dị gburugburu, e ji ọka balị mee dabatara nʼime ụlọ ikwu ndị Midia. O ji ike dị egwu tie ụlọ ikwu a, nke mere na ụlọ ikwu a dajiri, kpuo ihu nʼala.”
\p 
\v 14 Onye ibe ya zara sị, “Nke a abụghị ihe ọzọ karịa mma agha Gidiọn nwa Joash, onye Izrel na-aga ịbịakwute anyị nʼebe a. Chineke enyefeela ndị Midia na ụlọ ikwu ya niile nʼaka ya.”
\p 
\v 15 Mgbe Gidiọn nụrụ nrọ ahụ, na nkọwa ya, ọ kpọrọ isiala kelee Chineke. Ọ laghachiri na ọmụma ụlọ ikwu ndị Izrel sị ha, “Bilienụ ọtọ! Nʼihi na \nd Onyenwe anyị\nd* enyefeela unu ọmụma ụlọ ikwu ndị Midia nʼaka.”
\v 16 O kewara ndị agha ya ụzọ atọ, nyekwa onye ọbụla nʼime ha opi ike, na ite aja nke iheọkụ dị nʼime ya.
\p 
\v 17 Ọ sịrị ha, “Unu na-ele m anya, meekwa ihe m na-eme. Mgbe anyị bịaruru nso na mpụta ebe ụlọ ikwu ahụ dị, meenụ ihe ọbụla unu hụrụ m mere.
\v 18 Mgbe ọbụla mụ na ndị so m nʼazụ fụrụ opi ike anyị, unu niile ga-afụkwa opi ike unu nʼakụkụ ọbụla unu nọ, tie mkpu, sị, ‘Anyị dịnyere \nd Onyenwe anyị\nd*, dịnyekwara Gidiọn.’ ”
\p 
\v 19 Nʼabalị ahụ, mgbe etiti abalị ahụ gabigasịrị, Gidiọn na narị ndị agha ya gbeere egbere ruo na mpụta ebe ndị agha Midia mara ụlọ ikwu ha. Nʼoge a, ha ka gbanwere ndị agha na-eche nche.
\v 20 Ụzọ ndị agha Gidiọn atọ ahụ fụrụ opi ike ha, tiwakwaa ite aja ha. Ha ji ọwaọkụ ndị ahụ nʼaka ekpe ha na opi ike ha gaje igbu nʼaka nri ha, ha tiri mkpu sị, “Mma agha \nd Onyenwe anyị\nd*, na mma agha Gidiọn!”
\v 21 Onye ọbụla nʼime ha guzoro nʼebe o kwesiri ịnọ gburugburu ọmụma ụlọ ikwu ahụ. Ndị Midia niile malitere ịgba ọsọ, na-etikwa mkpu akwa mgbe ha na-agbalaga.
\p 
\v 22 Mgbe ha fụrụ narị opi ike atọ ndị ahụ, \nd Onyenwe anyị\nd* mere ka ndị ikom niile nọ nʼakụkụ niile nke ọmụma ụlọ ikwu ahụ tụgharịa were mma agha gburịta onwe ha. Ndị agha ahụ gbapụrụ ọsọ gbara gaa Bet-Shita nʼụzọ Zerera, gbarukwaa nke oke ala Ebel-Mehola, nke dị nso Tabat.
\v 23 A kpọpụtara ndị Izrel si Naftalị, na Asha na Manase niile ka ha pụta chụso ndị Midia ọsọ.
\v 24 Gidiọn ziri ozi nʼala ugwu ugwu Ifrem sị ha, “Pụtanụ gbochie ụzọ niile ndị Midia si agbafe. Cheenụ ọnụ mmiri Jọdan niile nche ruo na Bet-Bara.”
\p Ya mere, a kpọpụtara ndị ikom niile nọ na Ifrem, bụ ndị gbochiri mmiri Jọdan ruo na Bet-Bara.
\v 25 Ha jidekwara ọchịagha ndị Midia abụọ, ndị aha ha bụ Oreb na Zeeb. Ha gburu Oreb nʼelu nkume nke na-aza aha ya ruo taa. E gbukwara Zeeb nʼebe a na-azọcha vaịnị. Ebe ahụ na-azakwa aha Zeeb ruo taa. Ha bipụrụ Oreb na Zeeb isi buru ha jekwuru Gidiọn nʼakụkụ osimiri Jọdan.
\c 8
\s1 Zeba na Zalmuna
\p 
\v 1 Ndị Ifrem jụrụ Gidiọn ajụjụ sị ya, “Gịnị mere i ji meso anyị mmeso dị otu a? Ọ bụ gịnị mere i zighị ozi kpọ anyị mgbe ị gara ibuso ndị Midia agha?” Ha tara ya ụta nke ukwuu.
\p 
\v 2 Ma Gidiọn zaghachiri ha sị, “Gịnị ka m rụpụtara e ji atụnyere nke unu. Ọ bụ na ntụtụkọta ihe ubi Ifrem adịghị mma karịa owuwe ihe ubi nke Abieza?
\v 3 Chineke nyefere unu Oreb na Zeeb, ndị ndu Midia, nʼaka. Gịnị ka m rụpụtara a ga-eji tụnyere nke unu?” Okwu a mere ka ọnụma ha nʼebe ọ nọ dajụọ.
\p 
\v 4 Nʼoge a, Gidiọn gabigara, gafee osimiri Jọdan, ya na narị ndị agha atọ so ya. Ike gwụrụ ha nke ukwuu ma ha nọgidere na-achụsi ndị iro ha ọsọ ike.
\v 5 Ọ sịrị ndị ikom Sukọt, “Nyetụnụ ndị agha m achịcha nʼihi na ike gwụrụ ha. Ana m na-achụso Zeba na Zalmuna, ndị eze Midia ọsọ.”
\p 
\v 6 Ma ndịisi Sukọt sịrị, “Anyị ga-esi aṅaa nye ndị agha gị achịcha? Ijidela Zeba na Zalmuna nʼaka gị?”
\p 
\v 7 Mgbe ahụ, Gidiọn zaghachiri, “Nʼihi nke a, mgbe \nd Onyenwe anyị\nd* nyefere m Zeba na Zalmuna nʼaka, aga m eji ogwu na ụga na-epu nʼọzara dọkasịa unu ahụ.”
\p 
\v 8 O sitere nʼebe ahụ gaa Peniel\f + \fr 8:8 \ft Ebe Jekọb gbasoro Chineke mgba \xt Jen 32:30-31\xt*\f* rịọkwaa ndị obodo ahụ otu arịrịọ ahụ. Ma otu ụdị ọsịsa ahụ ndị Sukọt nyere ka ndị Peniel nyekwara.
\v 9 Ya mere, ọ gwara ndị ikom Peniel sị, “Mgbe m nwere mmeri lọta, aga m akwatu ụlọ elu a.”
\p 
\v 10 Nʼoge a, Zeba na Zalmuna na puku ndị agha iri na ise fọdụụrụ ha nọ na Kako. Ndị a bụ naanị ndị agha fọdụrụ nʼime usuu ndị agha ndị Midia niile. Nʼihi na ọnụọgụgụ ndị agha e gburu egbu dị narị puku na iri puku abụọ.
\v 11 Gidiọn rigoro site ụzọ ndị na-achị anụ ụlọ nke dị nʼọwụwa anyanwụ obodo Nọba na Jogbeha, bịakwasị ndị agha ahụ na mberede nʼihi na ha nọ nʼatụghị egwu ihe ọbụla ime ha.
\v 12 Zeba na Zalmuna, eze abụọ ndị Midia, gbapụrụ ọsọ, ma Gidiọn na ndị agha ya chụgidere ha ọsọ, jide ha. Ha gweriri ndị agha ha niile.
\p 
\v 13 Emesịa, Gidiọn nwa Joash, sitere nʼokporoụzọ Heres lọta agha ahụ.
\v 14 Nʼebe ahụ ka Gidiọn nọ jide otu nwokorobịa onye Sukọt. O jụrụ ya ajụjụ, nwokorobịa ahụ depụtakwaara ya aha ndịisi obodo Sukọt. Ha dị iri asaa na asaa, ndị okenye obodo ahụ.
\v 15 Mgbe Gidiọn bịaruru obodo Sukọt, ọ gwara ha okwu sị, “Ngwa leenụ Zeba na Zalmuna ndị unu kparịrị m maka ha, kwuo sị, ‘Ijidela Zeba na Zalmuna nʼaka gị ugbu a nke mere na anyị ga-enye ndị ikom gị ike gwụrụ achịcha?’ ”
\v 16 O jidere ndị okenye obodo ahụ, were ogwu na ụga taa ndị ikom Sukọt ahụhụ ime ka ha mara ihe.
\v 17 Ọ kwaturu ụlọ elu Peniel gbukwaa ndị ikom obodo ahụ niile.
\p 
\v 18 Mgbe ahụ, ọ jụrụ Zeba na Zalmuna, “Ndị ikom dị aṅaa ka unu gburu na Taboa?”
\p Ha zara sị ya, “Ha nwere ụdịdị ka gị onwe gị, onye ọbụla nwere ụdịdị dịka nwa eze.”
\p 
\v 19 Gidiọn zaghachiri sị, “Ndị ahụ bụ ụmụnne m ndị ikom, ndị nke nne m mụrụ. Ugbu a, \nd Onyenwe anyị\nd* nʼonwe ya maara na a sị na unu egbughị ha, agaraghị m egbu unu.”
\v 20 O chigharịrị gwa Jeta, ọkpara ya, sị ya, “Gbuo ha!” Ma Jeta amịpụtaghị mma, nʼihi na ọ bụ naanị nwokorobịa. Ọ tụrụ egwu igbu ha.
\p 
\v 21 Zeba na Zalmuna, gwara Gidiọn okwu sị, “Jiri aka gị gbuo anyị. ‘A hụ dimkpa, a hụ ike ya.’ ” Nʼihi nke a, Gidiọn were aka ya gbuo ha, chịkọrọkwa ihe olu niile ha nyakwasịrị ịnyịnya kamel ha nʼolu.
\s1 Efọọd Gidiọn
\p 
\v 22 Mgbe ahụ, ndị Izrel gwara Gidiọn sị ya, “Bịa ka ị bụrụ eze anyị! Gị na ụmụ gị ndị ikom, na ezinaụlọ gị niile, ga-abụ ndị ga-achị, nʼihi na ị gbapụtala anyị site nʼaka usuu ndị agha Midia.”
\p 
\v 23 Ma Gidiọn gwara ha okwu sị, “Mụ onwe m na ụmụ m agaghị abụ eze unu, nʼihi na \nd Onyenwe anyị\nd* Chineke bụ eze unu.”
\v 24 Ọ sịrị, “Enwere m otu arịrịọ m ga-arịọ unu. Onye ọbụla nʼime unu nye m ọlantị site nʼoke unu nwetara site nʼihe nkwata nʼagha.” (Ọ bụ omenaala ndị Ishmel niile iyi ọlantị ọlaedo.)
\p 
\v 25 Ha jiri obi ụtọ kwenye, gbasaa akwa nʼala, tinyechaa ọlantị ha nʼime ya. Onye ọbụla nʼime ha mere nke a.
\v 26 Ịdị arọ nke ọlantị ọlaedo ndị a bụ otu puku na narị shekel asaa, na-agụnyeghị ihe ịchọ mma ndị ọzọ, na ihe olu, na uwe odo odo ndị eze Midia na-eyi, na ihe olu dị nʼolu ịnyịnya kamel ha.
\v 27 Gidiọn jiri ọlaedo ahụ niile kpụọ efọọd debe ya nʼOfra, nʼobodo nke aka ya. Ma mgbe na-adịghị anya, ụmụ Izrel niile malitere ịgbaso na ife ihe ahụ ofufe. Nʼụzọ dị otu a, ọ ghọọrọ Gidiọn na ezinaụlọ ya ihe ịma nʼọnya.
\s1 Ọnwụ Gidiọn
\p 
\v 28 Otu a ka Midia si ghọọ ndị Izrel meriri emeri. Midia eweliteghị isi ya ọzọ. Nʼihi nke a, Izrel biri nʼudo iri afọ anọ, nʼụbọchị niile Gidiọn dị ndụ.
\p 
\v 29 Jerub-Baal, nwa Joash laghachiri nʼụlọ nke aka ya, biri nʼebe ahụ.
\v 30 Ọ mụtakwara iri ụmụ ndị ikom asaa, nʼihi na ọ lụrụ ọtụtụ ndị inyom.
\v 31 O nwekwara iko nwanyị nʼobodo Shekem, onye mụtaara ya nwa nwoke aha ya bụ Abimelek.
\v 32 Mgbe ihe ndị a gasịrị, Gidiọn nwa Joash, nwụrụ, mgbe ọ kasịrị nka nke ukwu. E liri ya nʼili nna ya Joash nʼobodo Ofra, nʼala Abieza.
\p 
\v 33 Ọ dịghị anya ka Gidiọn nwụsịrị, ụmụ Izrel laghachiri azụ bido ife chi Baal. Ha guzobere Baal-Berit\f + \fr 8:33 \ft Baal-Berit bụ arụsị, ụlọ ya dị nʼobodo Shekem.\f* ka ọ bụrụ chi ha.
\v 34 Ma ụmụ Izrel echetaghị \nd Onyenwe anyị\nd* Chineke ha, onye napụtara ha site nʼaka ndị iro ha niile gbara ha gburugburu.
\v 35 Ha ekwesighịkwa ntụkwasị obi nye ezinaụlọ Jerub-Baal (ya bụ Gidiọn) dịka ezi ihe niile o mere ha si dị.
\c 9
\s1 Abimelek
\p 
\v 1 Otu ụbọchị, Abimelek nwa Jerub-Baal jekwuuru ụmụnne nne ya ndị ikom bi na Shekem, na ndị ikwu nne ya niile sị ha,
\v 2 “Jekwurunụ ndị Shekem jụọ ha, ‘Kedụ nke kara unu mma: ọ bụ ka ụmụ iri ndị ikom asaa Jerub-Baal mụrụ chịa unu, ka ọ bụ ka otu onye chịa unu?’ Chetakwanụ na mụ na unu bụ otu anụ ahụ na ọbara.”
\p 
\v 3 Mgbe ụmụnne nne ya ndị ikom gwara ndị Shekem ihe Abimelek kwuru, ha kwekọrịtara iso ya nʼihi na ha kwuru sị, “Nwanne anyị ka ọ bụ.”
\v 4 Ha sitere nʼụlọ arụsị Baal-Berit nye ya iri shekel ọlaedo asaa. Abimelek ji ego ndị a goo ndị efulefu jọgburu onwe ha, ndị na-akpọghị ndụ ha ihe ọbụla, ndị kwenyere ma gbasoro ya.
\v 5 Ọ gara nʼụlọ nna ya nʼobodo Ofra. Nʼebe ahụ, o gburu iri ndị ikom asaa ahụ bụ ụmụnna ya nʼelu otu nkume. Kama Jotam, bụ ọdụdụ nwa Jerub-Baal, zoro onwe ya gbapụ.
\v 6 Mgbe ahụ, ndị Shekem na ndị Bet Milo kpọrọ nzukọ nʼokpuru osisi ukwu dị nʼobodo ahụ nʼakụkụ ogidi e guzobere ọtọ na Shekem. Nʼebe ahụ ka ha nọ mee Abimelek eze Izrel.
\p 
\v 7 Mgbe Jotam nụrụ ya, o rigooro nʼugwu Gerizim\f + \fr 9:7 \ft \xt Dit 11:29; 27:12; Jos 8:33\xt*\f* guzo nʼebe ahụ tikuo ndị Shekem niile mkpu si ha, “Geenụ m ntị ka Chineke nwe ike gee unu ntị.
\v 8 Otu mgbe, osisi niile pụrụ ije ịga tee otu onye mmanụ ka ọ bụrụ eze ga-achị ha. Ha sịrị osisi oliv, ‘Bụrụ eze anyị.’
\p 
\v 9 “Ma osisi oliv jụrụ ha ajụjụ sị, ‘O kwesiri ka m hapụ iwepụta mmanụ m a nke a na-esite na ya sọpụrụ Chineke\f + \fr 9:9 \ft chi dị iche iche, nke bụ nʼebe o metụtara ndị nʼefe arụsị\f* na ụmụ mmadụ, nọọ ọnọdụ ifegharị alaka m nʼelu osisi ndị ọzọ?’
\p 
\v 10 “Ọzọkwa, ha rịọrọ osisi fiig ka ọ bụrụ eze ha.
\p 
\v 11 “Ma osisi fiig sịrị, ‘Ọ bụrụ na m ekwere na m ga-abụ eze unu, ọ pụtara na m ga-akwụsị ịmịpụta mkpụrụ osisi na-atọ ụtọ, nọọ ọnọdụ ifegharị alaka m nʼelu osisi ndị ọzọ?’
\p 
\v 12 “Ọzọkwa, ha rịọrọ osisi vaịnị ma ọ ga-ekwenye ịbụ eze ha.
\p 
\v 13 “Ma osisi vaịnị ahụ zara sị ha, ‘Ọ bụrụ na m ekwere ịbụ eze unu, ọ pụtara na m ga-akwụsị ịmịpụta mkpụrụ osisi e ji eme mmanya nke na-enye Chineke na ụmụ mmadụ obi ụtọ, nọọ ọnọdụ ifegharị alaka m nʼelu osisi ndị ọzọ?’
\p 
\v 14 “Nʼikpeazụ, osisi niile jekwuuru ogwu ọhịa, ‘Bịa ka ị bụrụ eze anyị.’
\p 
\v 15 “Ogwu ọhịa sịrị osisi niile, ‘Ọ bụrụ nʼezie na unu chọrọ ite m mmanụ ka m bụrụ eze unu, bịanụ zere ndụ nʼokpuru ndo m kpọkwanụ isiala nye m. Ọ bụrụ na unu ajụ ime nke a, ka ọkụ si nʼogwu ọhịa pụta rechapụ sida niile dị na Lebanọn!’
\p 
\v 16 “Ugbu a, omume unu o ziri ezi ma sitekwa nʼezi obi na unu mere Abimelek eze? Mmeso unu mesoro Jerub-Baal na ezinaụlọ ya o ziri ezi? Unu omesoro ya dịka o kwesiri ya?
\v 17 Chetakwanụ na nna m lụrụ ọgụ maka unu, kpọọ ndụ ya ihe efu, nʼihi ịnapụta unu site nʼaka ndị Midia.
\v 18 Ma taa, unu enupula isi megide nna m na ezinaụlọ ya, gbuo iri ụmụ ndị ikom asaa ya nʼelu otu nkume, meekwa Abimelek nwa ya nwoke nke ohu nwanyị ya mụtara eze ga-achị ndị Shekem niile, nʼihi na ọ bụ onye nke unu.
\v 19 Nke a o gosiri na omume unu ziri ezi, sitekwa nʼobi ọcha nʼebe Jerub-Baal na ezinaụlọ ya nọ taa? Ọ bụrụ na unu mere otu a, ka Abimelek bụrụ onye ga-ewetara unu ọṅụ ka unu bụkwara ndị ga-ewetara ya ọṅụ.
\v 20 Ma ọ bụrụ na omume unu ezighị ezi, ka ọkụ si nʼAbimelek pụta repịa unu, ndị Shekem na Bet Milo, ka ọkụ sitekwa nʼebe unu bụ ndị Shekem na Bet Milo, pụta repịa Abimelek.”
\p 
\v 21 Emesịa, Jotam gbapụrụ, gbaga Bịa, biri nʼebe ahụ nʼihi egwu Abimelek bụ nwanna ya.
\p 
\v 22 Mgbe ọ gasịrị afọ atọ Abimelek bidoro ịchị Izrel,
\v 23 Chineke kpaliri iro dị ukwuu nʼetiti Abimelek na ndị nwe obodo Shekem, nke bụ na ha mere omume ihu abụọ megide Abimelek.
\v 24 Chineke mere nke a nʼihi na ọ chọrọ ịbọta ọbọ ọbara iri ụmụ Jerub-Baal asaa ahụ nʼisi Abimelek, na ndị Shekem ahụ bụ ndị nyeere ya aka gbuo ụmụnne ya.
\v 25 Nʼọnọdụ imegide ya, ndị Shekem doro ndị ikom ụfọdụ nʼelu ugwu niile, ndị zoro nʼebe ahụ na-apụnara ndị ọbụla na-esite nʼebe ahụ agafe ihe ha nwere. E mere ka Abimelek mata na ihe dị otu a na-eme.
\p 
\v 26 Nʼoge ahụ, Gaal, nwa Ebed, chịkọtara ụmụnne\f + \fr 9:26 \ft Maọbụ, \fqa Ndị ikwu ya\f* ya ndị ikom gaa biri na Shekem, ndị Shekem nwere ntụkwasị obi nʼebe ọ nọ.
\v 27 Mgbe ha pụrụ baa nʼubi, chịkọta mkpụrụ vaịnị, zọchaa ha, ha mere mmemme nʼụlọ chi ha. Mgbe ha nọ na-eri na-aṅụ, ha kọchara Abimelek.
\v 28 Mgbe ahụ, Gaal nwa Ebed sịrị, “Onye bụ Abimelek? Gịnị mere na anyị bụ ndị Shekem ga-eji nọrọ nʼokpuru ya? Ọ bụghị nwa Jerub-Baal? Ọ bụkwaghị Zebul bụ onye na-esote ya? Ọ bụ ka anyị fee ezinaụlọ Hamọ, nna Shekem ofufe. Ọ bụ maka gịnị ka anyị ga-eji fee Abimelek ofufe?
\v 29 A sịkwarị na ndị a nọ nʼokpuru ọchịchị m, mgbe ahụ, m ga-ewezuga Abimelek. Aga m asị ya, ‘Kpọpụta ndị agha gị niile.’ ”
\p 
\v 30 Mgbe Zebul onye na-achị obodo ahụ nụrụ ihe Gaal nwa Ebed kwuru, o were nnọọ oke iwe.
\v 31 O zigara Abimelek ndị ozi na nzuzo ka ha sị ya, “Gaal nwa Ebed na ndị ikwu ya abịala obodo Shekem. Ha akpaliela obi ndị obodo a niile ka ha megide gị.
\v 32 Ugbu a, gị na ndị agha gị, bịanụ nʼabalị zoo onwe unu nʼọhịa.
\v 33 Nʼụtụtụ, mgbe anwụ wara, busonụ obodo a agha. Mgbe Gaal na ndị ya pụtara ịlụso gị agha, mee ha ihe dị gị mma.”
\p 
\v 34 Ya mere, Abimelek na ndị agha ya dị nʼotu anọ, jiri abalị bilie jeruo Shekem zoo onwe ha na nso obodo ahụ.
\v 35 Gaal nwa Ebed pụrụ guzo nʼọnụ ama obodo ahụ mgbe Abimelek na ndị ya sitere nʼebe ha zoro onwe ha pụta.
\p 
\v 36 Mgbe Gaal hụrụ ha, ọ kpọrọ Zebul si ya, “Lee ndị mmadụ sị nʼelu ugwu ndị a na-arịdata.”
\p Zebul zara si ya, “Ọ bụghị mmadụ ka ị na-ahụ, kama ọ bụ onyinyo ugwu ka ị na-akpọ mmadụ.”
\p 
\v 37 Gaal kwukwara okwu sị, “Lee ndị mmadụ si nʼetiti ala ahụ na-arịdata, ndị ọzọ sikwa nʼakụkụ ụzọ ebe osisi iju ase dị.”
\p 
\v 38 Mgbe ahụ, Zebul sịrị ya, “Olee uru ọ bara na ị turu ọnụ, gị onye na-asị, ‘Onye bụ Abimelek na anyị ga-efe ya ofufe?’ Ọ bụ ndị a abụghị ndị ahụ ị kọchara? Pụkwuru ha gaa lụso ha ọgụ.”
\p 
\v 39 Ya mere, Gaal duuru ndị nwe Shekem pụọ ịlụso Abimelek ọgụ.
\v 40 Ma Abimelek chụụrụ ya ọsọ ruo mbata ọnụ ụzọ ama, ọtụtụ bụkwa ndị egburu ka ha na-agba ọsọ.
\v 41 Abimelek nọgidere nʼAruma nʼoge ahụ. Ma Zebul chụpụrụ Gaal na ndị ikwu ya site na Shekem.
\p 
\v 42 Nʼechi ya, ndị Shekem pụtara baa nʼọhịa. E mere ka Abimelek mara nke a.
\v 43 Nʼihi ya, Abimelek kere ndị agha ya ụzọ atọ. Ha niile zokwara onwe ha nʼọhịa. Mgbe ọ hụrụ ka ndị mmadụ si nʼime obodo ahụ na-apụta, o biliri buso ha agha.
\v 44 Abimelek na usuu ndị agha so ya mapụtara, gbara ọsọ were ọnọdụ nʼọnụ ụzọ ama obodo ahụ. Emesịa, ụzọ abụọ nʼime ụzọ atọ nke ndị agha na-eso ya chere ihu nʼọhịa gbuo ndị ahụ niile nọ nʼebe ahụ.
\v 45 Ụbọchị ahụ niile, Abimelek busoro obodo ahụ agha tutu ruo mgbe o meriri ya, gbuo ndị niile bi nʼime ya. Emesịa, ọ lara obodo ahụ niile nʼiyi, fesaa nnu nʼala ya niile.
\p 
\v 46 Mgbe ndị nwe ala nọ nʼụlọ elu Shekem nụrụ ihe mere, ha gbabanyere nʼebe e wusiri ike nke ụlọ arụsị El Berit.
\v 47 Mgbe Abimelek nụrụ na ha ezukọtala nʼebe ahụ,
\v 48 ya na ndị agha ya rigoro ugwu Zalmon. O ji anyụike gbutuo ụfọdụ ngalaba osisi nke ọ tụkwasịrị nʼubu ya. O nyere ndị agha ya iwu si, “Ngwa, meenụ ihe unu hụrụ na m mere.”
\v 49 Ya mere, ndị agha ya niile gbuturu alaka osisi buru ha soro Abimelek. Ha tụkọtara alaka osisi ndị a niile nʼakụkụ ebe ahụ e wusiri ike mụnye ha ọkụ ka o regbuo ndị mmadụ nọ nʼime ya. Ya mere, ndị mmadụ niile nọ nʼụlọ elu Shekem, nwoke na nwanyị, ndị ọnụọgụgụ ha ruru otu puku nwụrụ.
\p 
\v 50 Ọzọ, Abimelek gara obodo Tebez lụso ya agha, merie ya.
\v 51 Ma e nwere nʼime obodo ahụ, otu ụlọ elu e wusiri ike, ebe ndị obodo ahụ niile, nwoke na nwanyị, gbabanyere. Ha kpọchidoro onwe ha ụzọ, rigoro nʼelu ụlọ ahụ.
\v 52 Abimelek gara nʼụlọ elu ahụ ibuso ya agha. Ma mgbe ọ na-abịaru ọnụ ụzọ ama ụlọ elu ahụ isunye ya ọkụ,
\v 53 otu nwanyị tụdara nkume igwe nri nʼisi ya, nke tiwara okpokoro isi ya.
\p 
\v 54 Ngwangwa, Abimelek kpọrọ onye na-ebu ihe agha ya sị ya, “Sepụta mma agha gị jiri ya gbuo m, ka ndị mmadụ ghara ị sị banyere m, ‘Ọ bụ nwanyị gburu ya.’ ” Ya mere nwokorobịa ahụ were mma agha ya dụgbuo ya, ọ nwụkwara.
\v 55 Mgbe ndị Izrel hụrụ na Abimelek anwụọla, ha niile lara nʼụlọ ha.
\p 
\v 56 Otu a ka Chineke si kwụghachi Abimelek ihe ọjọọ o mere megide nna ya site nʼigbu iri ụmụnna ya asaa.
\v 57 Chineke mekwara ka ndị Shekem nata ụgwọ ọrụ ihe ọjọọ ha. Ọbụbụ ọnụ Jotam nwa Jerub-Baal mezukwara nʼisi ha.
\c 10
\s1 Tola
\p 
\v 1 Mgbe Abimelek nwụsịrị, Tola nwa Pua, nwa nwa Dodo, biliri ịzọpụta Izrel. O si nʼebo Isaka pụta. Ọ bụkwa nʼobodo Shamia ka o bi, nʼime obodo e wukwasịrị nʼelu ugwu Ifrem.
\v 2 O kpere Izrel ikpe iri afọ abụọ na atọ. Mgbe ọ nwụrụ, e liri ya na Shamia.
\s1 Jaịa
\p 
\v 3 Onye ikpe ọzọ nọchiri ya bụ Jaịa, onye si Gilead pụta. O kpere Izrel ikpe iri afọ abụọ na abụọ.
\v 4 O nwere ụmụ ndị ikom iri atọ, ndị na-agba ịnyịnya ibu iri atọ. Ha nwekwara obodo iri atọ nke aka ha na Gilead, nke a na-akpọkwa Havọt Jaịa ruo taa.
\v 5 Ma mgbe Jaịa nwụrụ, e liri ya na Kamon.
\s1 Jefta
\p 
\v 6 Ọzọkwa, ụmụ Izrel mere ihe jọrọ njọ nʼihu \nd Onyenwe anyị\nd*, ha fere chi Baal na Ashtọret, chi ndị Aram, chi ndị Saịdọn, nke ndị Moab, nke ndị Amọn, na chi ndị Filistia ofufe. Ndị Izrel hapụrụ \nd Onyenwe anyị\nd*, ha efekwaghị ya ofufe.
\v 7 Nke a mere ka \nd Onyenwe anyị\nd* wee iwe megide ha. O nyefere ha nʼaka ndị Filistia na ndị Amọn,
\v 8 ndị mekpara ha ahụ, chie ha ọnụ nʼala. Afọ iri na asatọ ka ndị Filistia megburu ndị Izrel bi nʼakụkụ ọwụwa anyanwụ osimiri Jọdan, nʼime ala ndị Amọrait, ya bụ na Gilead.
\v 9 Ndị Amọn gafekwara osimiri Jọdan ibuso ndị Juda, ndị Benjamin na ndị Ifrem agha. Ihe ndị a mere ka ọnọdụ ụmụ Izrel dị nnọọ njọ nke ukwuu.
\v 10 Nʼikpeazụ, ụmụ Izrel tikuru \nd Onyenwe anyị\nd* mkpu akwa, rịọọ ya ka ọ gbapụta ha. Ha kwupụtara sị, “Anyị emehiela megide gị,\f + \fr 10:10 \ft \xt Dit 1:10; 1Sa 12:10\xt*\f* anyị ahapụla gị Chineke anyị, fee arụsị Baal ofufe.”
\p 
\v 11 Ma \nd Onyenwe anyị\nd* sịrị ndị Izrel, “Mgbe ndị Ijipt, ndị Amọrait, ndị Amọn, ndị Filistia,
\v 12 ndị Saịdọn, ndị Amalek na ndị Maon kpagburu unu; unu tikuru m mkpu akwa inyere unu aka, ọ bụ na m anapụtaghị unu site nʼaka ha?
\v 13 Ma unu nọgidere na-agbakụta m azụ oge niile, na-efe chi ndị ọzọ ofufe. Ya mere, gawaranụ onwe unu, agaghị m anapụtakwa unu ọzọ.
\v 14 Kpọkuonụ chi ndị ahụ bụ ndị unu họpụtaara onwe unu, ka ha zọpụta unu mgbe ọbụla nsogbu dakwasịrị unu!”
\p 
\v 15 Ma ndị Izrel sịrị \nd Onyenwe anyị\nd*, “Anyị emehiela. Mee anyị ihe ọbụla i chere dị gị mma, ma biko, zọpụta anyị taa.”
\v 16 Ha sitere nʼetiti ha wezuga chi ala ọzọ niile dị iche iche, fee \nd Onyenwe anyị\nd* ofufe. O nweghịkwa ike nagide ọnọdụ ọjọọ ndị Izrel gaa nʼihu.
\p 
\v 17 Mgbe a kpọkọtara ndị Amọn maka ibu agha, ha mara ụlọ ikwu ha na Gilead, ndị Izrel zukọtakwara maa ụlọ ikwu nke ha na Mizpa.
\v 18 Ndị ndu obodo Gilead gwarịtara onwe ha sị, “Onye ọbụla ga-amalite agha megide ndị Amọn ga-abụ onyeisi ndị niile bi na Gilead.”
\c 11
\p 
\v 1 Otu ọ dị, Jefta, onye Gilead, bụ dimkpa nʼagha. Nna ya bụ Gilead; nne ya bụ akwụna.
\v 2 Nwunye Gilead mụtaara ya ọtụtụ ụmụ ndị ikom ọzọ. Mgbe ha tolitere, ha chụpụrụ Jefta site nʼobodo ahụ, sị ya, “Ị gaghị eketa ihe ọbụla nʼezi nna anyị, nʼihi na nwa nwanyị ọzọ ka ị bụ.”
\v 3 Nʼihi nke a, Jefta gbapụrụ site nʼụlọ nna ya, gaa biri nʼobodo Tob. Mgbe na-adịghị anya, ọtụtụ ndị isi na-anụ ọkụ bịara nọnyere ya ma sorokwa ya.
\p 
\v 4 O ruo mgbe ọtụtụ oge gasịrị, ndị Amọn busoro ụmụ Izrel agha.
\v 5 Ndị okenye Gilead jere ịkpọpụta Jefta site nʼala Tob.
\v 6 Ha sịrị ya, “Bịa buru onyeisi agha anyị ka anyị nwee ike ibuso ndị Amọn agha.”
\p 
\v 7 Jefta sịrị ha, “Unu akpọghị m asị,\f + \fr 11:7 \ft \xt Jen 26:27\xt*\f* ma chụpụkwa m site nʼụlọ nna m? Gịnị mere unu ji na-achọ m ugbu a unu nọ nʼoke nsogbu?”
\p 
\v 8 Ndị okenye Gilead sịrị ya, “na-agbanyeghị nke a, anyị abịaghachikwutela gị ugbu a, bịa ka anyị na gị lụso ndị Amọn agha. Ị ga-abụkwa onyeisi anyị niile bi na Gilead.”
\p 
\v 9 Jefta zara, “A sịkwarị na m esoro unu gaa lụso ndị Amọn agha, ọ bụrụ na \nd Onyenwe anyị\nd* enyefee ha nʼaka m, m ga-abụ onyeisi unu nʼezie?”
\p 
\v 10 Ndị okenye Gilead zara, “\nd Onyenwe anyị\nd* bụ onye akaebe, na anyị aghaghị ime dịka i kwuru.”
\v 11 Ya mere, Jefta sooro ndị okenye Gilead, ha mekwara ya onyeisi ha na ọchịagha ha. O kwughachikwara okwu ya niile nʼihu \nd Onyenwe anyị\nd* nʼobodo Mizpa.
\p 
\v 12 Mgbe ahụ, Jefta zipụrụ ndị ozi ka ha jekwuru eze ndị Amọn jụọ ya ajụjụ sị, “Gịnị bụ ihe i nwere megide anyị i ji ebuso ala anyị agha?”
\p 
\v 13 Eze ndị Amọn zaghachiri ndị ozi Jefta, “Mgbe ụmụ Izrel si nʼala Ijipt pụta, ha ji aka ike napụ anyị ala anyị, site nʼosimiri Anọn ruo na Jabọk, rukwaa nʼosimiri Jọdan. Ugbu a nyeghachinụ anyị ala ahụ niile nʼudo.”
\p 
\v 14 Jefta zighachiri ndị ozi ka ha jekwuru eze ndị Amọn,
\v 15 na-asị,
\pm “Ihe ndị a ka Jefta sịrị: Izrel esiteghị nʼaka ike napụ Moab maọbụ Amọn ala ha.\f + \fr 11:15 \ft \xt Dit 2:9,19\xt*\f*
\v 16 Kama, mgbe ha si Ijipt rigopụta, Izrel sitere nʼọzara bịaruo Osimiri Uhie, sikwa nʼebe ahụ ruo Kadesh.
\v 17 Mgbe ahụ, Izrel zipụrụ ndị ozi ka ha jekwuru eze Edọm sị ya, ‘Kwere ka anyị si nʼala gị gafere,’ ma eze Edọm jụrụ ajụ. Ha zipụkwara ozi nye eze Moab, ma o kwenyeghị. Nʼihi ya, Izrel nọgidere na Kadesh.
\pm 
\v 18 “Ọzọ, ha sitere nʼọzara gaa gburugburu Edọm na Moab, site nʼakụkụ ọwụwa anyanwụ ala Moab, maa ụlọ ikwu ha nʼofe Anọn. Ha abaghị nʼoke ala Moab, nʼihi na Anọn bụ oke ala ya.
\pm 
\v 19 “Mgbe ahụ, ụmụ Izrel zigara ndị ozi ka ha jekwuru Saịhọn eze ndị Amọrait, onye bi na Heshbọn, sị ya, ‘Biko, ka anyị site nʼala gị gafee ruo nʼala nke anyị.’
\v 20 Ma eze Saịhọn atụkwasịghị Izrel obi isite nʼoke ala ya gabiga. Nʼihi nke a, ọ chịkọtara usuu ndị agha ya, ma ụlọ ikwu na Jahaz, buso ụmụ Izrel agha.
\pm 
\v 21 “Mgbe ahụ, \nd Onyenwe anyị\nd*, Chineke Izrel nyere Saịhọn na ndị agha ya niile nʼaka Izrel. Ha merikwara ha. Izrel nwetara ala niile nke ndị Amọrait, bụ ndị bi nʼala ahụ.
\v 22 Ha nwetara ala niile ahụ, site nʼAnọn ruo Jabọk, sitekwa nʼọzara ruo Jọdan.
\pm 
\v 23 “Ma ugbu a, \nd Onyenwe anyị\nd*, Chineke Izrel achụpụla ndị Amọrait nʼihu ndị ya bụ Izrel. Olee ikike i nwere iwere ala ahụ?
\v 24 Ọ bụghị ihe chi gị, Kemosh, nyere gị ka i ga-enweta? Otu aka ahụ kwa, ihe ọbụla \nd Onyenwe anyị\nd* Chineke anyị nyere anyị ka anyị ga-enweta.
\v 25 Ị dị mma karịa Balak nwa Zipoa, eze Moab? O nwere mgbe ọ chọrọ Izrel okwu, maọbụ lụso ha agha?
\v 26 Ọ bụ narị afọ atọ kemgbe ụmụ Izrel malitere ibi na Heshbọn na Aroea, na nʼime obodo ndị ọzọ gbara ha gburugburu ruo nʼiyi Anọn. Ọ bụkwa gịnị mere na ịnapụtaghị ala ndị a nʼoge ndị ahụ?
\v 27 Emegideghị m gị, kama ọ bụ gị na-emejọ m, site nʼibuso m agha. Ka \nd Onyenwe anyị\nd*, onye na-ekpe ikpe ziri ezi kpebie ikpe a taa nʼetiti ndị Izrel na ndị Amọn.”
\m 
\v 28 Ma eze Amọn egeghị ntị nʼozi Jefta ziri ka e zie ya.
\p 
\v 29 Nʼoge ahụ, mmụọ \nd Onyenwe anyị\nd* dakwasịrị Jefta. Site nʼike mmụọ ahụ, o duuru ndị agha Izrel gafee obodo Gilead na Manase, gafeekwa Mizpa, nke dị nʼime Gilead, gaa lụso ndị Amọn agha.
\v 30 Jefta kwere \nd Onyenwe anyị\nd* nkwa sị ya, “Ọ bụrụ na ị ga-enyefe ndị Amọn nʼaka m,
\v 31 ihe ọbụla sitere nʼọnụ ụzọ ụlọ m pụta izute m mgbe m lọghachiri nʼọnọdụ mmeri megide ndị Amọn, ga-abụ nke \nd Onyenwe anyị\nd*. Aga m eji ya chụọ aja nsure ọkụ.”
\p 
\v 32 Jefta duuru ndị agha ya gaa ibuso Amọn agha. \nd Onyenwe anyị\nd* nyekwara ya mmeri dị ukwuu.
\v 33 O bibiri iri obodo abụọ site nʼAroea ruo nso nso Minit, ruokwa Ebel-Keramim. Otu a ka Izrel si merie ndị Amọn.
\p 
\v 34 Mgbe Jefta lọghachiri nʼụlọ ya na Mizpa, ma lee ada ya nwanyị onye ji iti egwu na ite egwu pụta izute ya. Ọ bụ naanị ya ka nna ya mụtara. Ewezuga ya, nna ya amụtaghị nwa nwoke maọbụ nwa nwanyị ọzọ.
\v 35 Mgbe Jefta hụrụ ya, ọ dọwara uwe ya, tie mkpu sị, “Ewoo, nwa m nwanyị! I wetarala obi m ihe mgbu, nʼihi na ekwela m \nd Onyenwe anyị\nd* nkwa, nke m na-aghaghị imezu.”
\p 
\v 36 Ọ zara, “Nna m, lee, ị ghaghị imezu ihe i kwere \nd Onyenwe anyị\nd* na nkwa. Jiri m mee ihe i kwere \nd Onyenwe anyị\nd* na nkwa, nʼihi na o nyela gị mmeri dị ukwuu nʼebe ndị Amọn, ndị iro gị nọ.
\v 37 Ma ọ dị otu ihe m chọrọ ịrịọ gị, biko kwere ka m soro ụmụ agbọghọ ibe m gaa wagharịa nʼugwu ndị a, ka mụ na ha kwaa akwa ọnwa abụọ, nʼihi na agaghị m alụ di.”
\p 
\v 38 Nna ya zara sị ya, “E, nwa m, i nwere ike ịga.” Ọ pụrụ gaa, jegharịa, kwaakwa akwa, ya na ụmụ agbọghọ ndị enyi ya, ruo mgbe ọnwa abụọ ahụ zuru.
\v 39 Mgbe ọnwa abụọ gasịrị, ọ laghachikwutere nna ya, onye ji ya mezuo nkwa ahụ o kwere. Ọ bụ nwaagbọghọ na-amatabeghị nwoke.
\p Malite nʼoge ahụ ka ọ ghọrọ omenaala ndị Izrel,
\v 40 na ụmụ agbọghọ na-apụ kwa afọ, gaa, nọọ abalị anọ nʼihi icheta ada Jefta, onye Gilead.
\c 12
\s1 Jefta na ndị Ifrem
\p 
\v 1 Mgbe ahụ, ndị Ifrem kpọkọtara ndị agha ha na Zafọn zigara Jefta ozi sị ya, “Gịnị mere ị kpọghị anyị ka anyị bịa nyere gị aka ịlụso ndị Amọn agha? Anyị na-abịa iwere ọkụ irechapụ gị na ezinaụlọ gị.”
\p 
\v 2 Jefta zaghachiri ha sị, “Akpọrọ m unu mgbe mụ na ndị m na ndị Amọn na-ese okwu dị ukwu ma unu jụrụ ịbịa. Unu azọpụtaghị m site nʼaka ha.
\v 3 Mgbe m hụrụ na unu achọghị inyere anyị aka, e tinyere m ndụ m nʼaka m, gabiga nʼofe nke ọzọ ibuso ndị Amọn agha. Ma \nd Onyenwe anyị\nd* nyeere m aka imeri ha. Ugbu a, nʼihi gịnị ka unu ji bịa ịlụso m ọgụ taa?”
\p 
\v 4 Jefta kpọkọtara ndị ikom Gilead pụọ buso ndị Ifrem agha. Ndị Gilead tidara ha nʼala nʼihi na ndị Ifrem sịrị, “Ndị gbapụrụ agbapụ site nʼIfrem na Manase ka unu bụ.”
\v 5 Ọ nọchiri akụkụ Jọdan dị ndị agha Ifrem nʼazụ, ebe ndị agha Ifrem nwere ike isi gbapụ. Mgbe ọbụla onye agha Ifrem ọbụla gbapụrụ ọsọ chọọ ịgafe osimiri ahụ, ndị agha Gilead ga-ejide ya jụọ ya sị, “Ị bụ onye Ifrem?” Ọ bụrụ na onye ahụ ekwuo na ya abụghị onye Ifrem,
\v 6 ha sịrị, “Ọ dị mma, kpọọ, ‘Shibolet.’ ” Ọ bụrụ na onye ahụ akpọ, “Sibolet,” nʼihi na ọ kpọpụtaghị mkpụrụ okwu ahụ nke ọma, ha na-akpụrụ ya gbuo ya na ngabiga mmiri Jọdan. Ọ bụ ọnụọgụgụ iri puku anọ, na puku abụọ ndị Ifrem ka e gburu mgbe ahụ.
\p 
\v 7 Jefta duuru ndị Izrel afọ isii. Mgbe ọ nwụrụ, e liri ya nʼotu obodo Gilead.
\s1 Ibzan, Elọn, na Abdon
\p 
\v 8 Onye ikpe ọzọ Izrel nwere bụ Ibzan onye bi na Betlehem.\f + \fr 12:8 \ft Obodo Betlehem nke a dị nʼala Zebụlọn, ọ dịghị na Juda.\f*
\v 9 O nwere iri ụmụ ndị ikom atọ na iri ụmụ ndị inyom atọ. O kenyere ndị ikom ikwu ọzọ ụmụ ya ndị inyom. Otu a kwa, o sikwa nʼikwu ọzọ lụtara ụmụ ya ndị ikom iri ndị inyom atọ. O kpere Izrel ikpe afọ asaa.
\v 10 Ibzan nwụrụ, e lie ya na Betlehem.
\p 
\v 11 Onye ọzọ kpere Izrel ikpe bụ Elọn, onye Zebụlọn. O kpere Izrel ikpe afọ iri.
\v 12 Emesịa, Elọn nwụrụ, e lie ya nʼAijalon, nʼime ala Zebụlọn.
\p 
\v 13 Onye ọzọ kpere Izrel ikpe bụ Abdon nwa Hilel, onye Piraton.
\v 14 O nwere iri ụmụ ndị ikom anọ na iri ụmụ ụmụ atọ ndị na-agba iri ịnyịnya ibu asaa. O kpere ụmụ Izrel ikpe afọ asatọ.
\v 15 Mgbe ahụ, Abdon nwa Hilel nwụrụ, e lie ya na Piraton ala dị nʼIfrem, nʼobodo ugwu ndị Amalek.
\c 13
\s1 Ọmụmụ Samsin
\p 
\v 1 Ndị Izrel mehiekwara ọzọ nʼihu \nd onyenwe anyị\nd*. Nʼihi nke a, \nd Onyenwe anyị\nd* kwenyere ka ndị Filistia merie ha. Ndị Izrel nọrọ nʼokpuru ọchịchị ha iri afọ anọ.
\p 
\v 2 Nʼoge ahụ, o nwere otu nwoke onye Zora aha ya bụ Manoa. Nwoke a si nʼagbụrụ Dan, nwunye ya bụ nwanyị aga nke mere na ọ mụtaghị nwa.
\v 3 Otu ụbọchị, mmụọ ozi \nd Onyenwe anyị\nd* gosiri nwanyị a onwe ya, gwa ya okwu sị, “Ọ bụ ezie na ị bụ nwanyị aga nke mere na ị mụtaghị nwa ma na mgbe na-adịghị anya, ị ga-atụrụ ime mụta nwa.
\v 4 Ma site ugbu a, gaa nʼihu, aṅụkwala ihe ọṅụṅụ ọbụla na-aba nʼanya. Erikwala ihe ọbụla rụrụ arụ.
\v 5 Ị ga-atụrụ ime, mụkwaa nwa nwoke, onye agụba agaghị aba nʼisi ya,\f + \fr 13:5 \ft \xt Ọnụ 6:5; 6:2; 1Sa 1:11\xt*\f* nʼihi na ọ ga-abụ onye e kewapụrụ nye Chineke site nʼime akpanwa. Ọ ga-ebute ụzọ nʼịgbapụta Izrel site nʼaka ndị Filistia.”
\p 
\v 6 Nwanyị ahụ gbara ọsọ gbalaa gaa gwa di ya sị ya, “Otu onye nke Chineke egosila m onwe ya. O dokwara m anya na ọ bụ mmụọ ozi Chineke, nʼihi na ọ dị oke ebube nʼile anya. Ma ajụghị m ya ebe o siri bịa, ọ gwakwaghị m aha ya.
\v 7 Kama ọ sịrị m, ‘Ị ga-adị ime, mụta nwa nwoke. Ma ugbu a, ị gaghị aṅụ mmanya vaịnị maọbụ ihe ọbụla na-aba nʼanya, maọbụ rie ihe ọbụla rụrụ arụ, nʼihi na nwantakịrị ahụ ga-abụ onye e doro nsọ nye Chineke, site nʼime akpanwa ruo nʼọnwụ ya.’ ”
\p 
\v 8 Mgbe ahụ, Manoa kpere ekpere rịọọ \nd Onyenwe anyị\nd* arịrịọ sị, “Biko, Onyenwe anyị, ka onye nke Chineke ahụ i ziteere anyị bịaghachikwa ọzọ, kuziere anyị otu anyị ga-esi zụlite nwa nwoke a ga-amụta.”
\p 
\v 9 Chineke zara ekpere ya. Mmụọ ozi ahụ bịakwutekwara nwunye Manoa mgbe ọ nọ nʼubi; maọbụ naanị ya nọ, di ya anọghị ya.
\v 10 Ya mere, nwanyị ahụ gbara ọsọ gaa gwa di ya sị, “Lee, nwoke ahụ bịakwutere m ụbọchị a, abịala ọzọ!”
\p 
\v 11 Manoa biliri, soro nwunye ya. Mgbe o bịarutere ebe nwoke ahụ nọ, ọ jụrụ ya ajụjụ sị, “Ọ bụ gị bụ nwoke ahụ gwara nwunye m okwu nʼoge gara aga?”
\p Ọ zara sị ya, “E, ọ bụ m.”
\p 
\v 12 Manoa gwara ya okwu sị, “Mgbe okwu gị mezuru, gịnị bụ iwu banyere ndụ na ọrụ nwa nwoke a?”
\p 
\v 13 Mmụọ ozi \nd Onyenwe anyị\nd* zaghachiri, “Nwunye gị aghaghị imezu ihe niile m nke m gwara ya.
\v 14 Ka ọ ghara iri ihe ọbụla si nʼosisi vaịnị,\f + \fr 13:14 \ft \xt Ọnụ 6:3-4; Nkp 13:4\xt*\f* maọbụ ṅụọ mmanya ọbụla maọbụ ihe ọbụla na-aba nʼanya, maọbụ rie ihe rụrụ arụ ọbụla.”
\p 
\v 15 Manoa rịọrọ Mmụọ ozi \nd Onyenwe anyị\nd* si ya, “Ọ ga-amasị anyị ma ị nọdụ chere ka anyị kwadoro gị nwa ewu.”
\p 
\v 16 Ma Mmụọ ozi \nd Onyenwe anyị\nd* zara ya, “A sịkwarị na i mee ka m nọrọ, agaghị m eri nri gị ọbụla. Ma ọ bụrụ na i kwadoo aja nsure ọkụ, were ya chụọrọ \nd Onyenwe anyị\nd* aja.” Ma Manoa aghọtaghị na onye ahụ bụ Mmụọ ozi \nd Onyenwe anyị\nd*.
\p 
\v 17 Mgbe ahụ, Manoa jụrụ Mmụọ ozi \nd Onyenwe anyị\nd* ahụ, sị, “Biko, gịnị bụ aha gị, ka anyị nye gị nsọpụrụ dịịrị gị mgbe okwu gị mezuru?”
\p 
\v 18 Ọ zara, “Nʼihi gịnị kwa ka ị na-ajụ banyere aha m?\f + \fr 13:18 \ft \xt Jen 32:29\xt*\f* Ọ bụ ihe karịrị nghọta.”
\v 19 Mgbe ahụ, Manoa weere nwa ewu, ya na ụfọdụ mkpụrụ ọka, jiri ha chụọrọ \nd Onyenwe anyị\nd* aja nʼelu nkume. Mgbe ahụ kwa, \nd Onyenwe anyị\nd* mere ihe dị ebube nke ukwuu mgbe Manoa na nwunye ya guzo na-ele anya:
\v 20 Mgbe ire ọkụ ahụ sitere nʼebe ịchụ aja ahụ na-arịgo na-aga elu, Mmụọ ozi \nd Onyenwe anyị\nd* wụliri elu soro ire ọkụ ahụ rigoro gawa nʼeluigwe! Mgbe Manoa na nwunye ya hụrụ ka nke a na-eme, ha kpuru ihu ha nʼala.
\v 21 Mgbe Mmụọ ozi \nd Onyenwe anyị\nd* na-egosighị onwe ya ọzọ nye Manoa na nwunye ya, ka Manoa ghọtara na ọ bụ Mmụọ ozi \nd Onyenwe anyị\nd* ka ha hụrụ.
\p 
\v 22 Manoa gwara nwunye ya sị, “Anyị abụrụla ndị nwụrụ anwụ, nʼihi na anyị ahụla Chineke!”
\p 
\v 23 Ma nwunye ya zara sị ya, “Ọ bụrụ na \nd Onyenwe anyị\nd* chọrọ igbu anyị, ọ garaghị anara aja nsure ọkụ, na aja mkpụrụ ọka anyị chụrụ nye ya. Ọzọkwa, ọ garaghị egosi anyị ihe ndị a niile maọbụ gwa anyị ihe ndị a.”
\p 
\v 24 Emesịa, nwanyị ahụ mụrụ nwa nwoke, onye ha gụrụ Samsin. \nd Onyenwe anyị\nd* gọzikwara nwantakịrị ahụ mgbe ọ na-etolite.
\v 25 Mmụọ \nd Onyenwe anyị\nd* bidokwara na-agba ya ume nʼoge niile, mgbe ọ nọ Mahane Dan, nke dị nʼetiti Zora na Eshtaol.
\c 14
\s1 Ọlụlụ nwunye Samsin
\p 
\v 1 Samsin gbadara nʼobodo Timna\f + \fr 14:1 \ft Timna bụ otu obodo nʼihe nketa ebo Dan \xt Jos 19:43\xt*\ft Ọ bụ obodo ndị Filistia, tupu ndị Izrel e merie ha.\f* ebe ọ hụrụ otu nwaagbọghọ onye Filistia.
\v 2 Mgbe ọ lọtara nʼụlọ, ọ gwara nne na nna ya, “Ahụrụ m otu nwanyị nʼime Timna\f + \fr 14:2 \ft \xt Jen 38:13; Jos 15:10,57\xt*\f* sitere nʼụmụ ndị inyom Filistia; ugbu a, lụtara m ya na nwunye.”
\p 
\v 3 Nne na nna ya zara ya, “Ọ bụ na ọ dịghị nwanyị dị nʼetiti ndị inyom ụmụnne gị, maọbụ nʼetiti ndị anyị niile? Gịnị mere o ji bụrụ nʼetiti ndị Filistia a na-ebighị ugwu ka i si lụtara onwe gị nwunye?”
\p Ma Samsin sịrị nna ya, “Gaa lụtara m ya. Nʼihi na o ziri ezi nʼanya m.”
\v 4 (Nne na nna ya aghọtaghị na aka \nd Onyenwe anyị\nd* dị nʼọlụlụ nwunye a Samsin chọrọ ịlụ. Nʼihi na \nd Onyenwe anyị\nd* na-achọ ụzọ ọ ga-esi megide ndị Filistia, ndị na-achị ụmụ Izrel nʼoge ahụ.)
\p 
\v 5 Samsin na nne na nna ya gawara obodo Timna maka ọlụlụ nwanyị a. Mgbe ha na-erute ubi vaịnị dị obodo Timna nso, otu\f + \fr 14:5 \ft Nʼoge ahụ, ọtụtụ ọdụm bi na ndịda ala Palestia.\f* nwa ọdụm sitere nʼọhịa mapụta, gbọrọ ụja na-abịakwute Samsin.
\v 6 Nʼotu oge ahụ, Mmụọ \nd Onyenwe anyị\nd* bịakwasịrị Samsin nʼike. O jekwuuru ọdụm ahụ, were aka ya abụọ dọwaa ya ọnụ, dịka a ga-asị na ọ bụ nwa ewu. Ma Samsin agwaghị nne na nna ya ihe mere.
\v 7 Ma mgbe ha bịaruru Timna, Samsin na nwaagbọghọ ahụ kparịtara ụka. Ihe banyere nwaagbọghọ ahụ dị Samsin ezi mma.
\p 
\v 8 Ọ laghachiri mgbe ụbọchị ole na ole gasịrị ka ọ kpọrọ ya. Ma mgbe ọ tụgharịrị ka ọ hụ ozu ọdụm ahụ, ọ hụrụ na igwe aṅụ bizi nʼime ozu ọdụm ahụ, na-emepụtakwa mmanụ aṅụ.
\v 9 Ọ kọpụtara mmanụ aṅụ ahụ tinye nʼaka ya, malite ịracha ka ọ na-aga nʼụzọ. Mgbe ọ bịakwutere nne na nna ya, o nyebinyere ha ụfọdụ, ha onwe ha rachakwara ya. Ma ọ gwaghị ha na o wetara ya site nʼozu ọdụm.
\p 
\v 10 Nna ya gara ịhụ nwanyị ahụ ma Samsin kpọkọtara ụmụ okorobịa obodo ahụ meere ha oriri dịka omenaala ha sị di.
\v 11 Mgbe Samsin rutere, a kpọnyere ya ndị bịara mmemme ọnụọgụgụ ha dị iri atọ.
\p 
\v 12 Mgbe ahụ, Samsin gwara ha okwu sị ha, “O nwere ajụjụ, gwa m, gwa m, gwa m, m chọrọ ka unu kọwaara m. Ọ bụrụ na unu enwee ike kọwaa ya, site taa ruo nʼụbọchị asaa nke mmemme a, aga m enye unu iri uwe mwụda atọ, nyekwa unu iri uwe mwụda atọ ọzọ akpara akpa.
\v 13 Ọ bụrụkwanụ na unu enweghị ike kọwaa ya, unu ga-enye m iri uwe mwụda atọ, na iri uwe mwụda atọ akpara akpa.”
\p Ha niile kwenyere sị, “Ọ dị mma. Kwuo ka anyị nụ.”
\p 
\v 14 Ọ gwara ha sị,
\q1 “Ihe oriri si nʼime onye na-eri eri na-apụta,
\q2 ọzọkwa, ihe dị ụtọ si nʼime onye dị ike pụta.”
\m Mgbe ụbọchị atọ gasịrị, ha enwebeghịkwa ike kọwaa ya.
\p 
\v 15 Ma nʼụbọchị nke anọ, ha jekwuuru nwunye Samsin gwa ya okwu sị, “Chọọ ụzọ rafụta di gị ọnụ, ka ọ gwa gị ihe okwu a pụtara. Ma ọ bụghị ya, anyị ga-akpọ gị na ezinaụlọ nna gị ọkụ. Ọ bụ ịnapụ anyị ihe anyị nwere ka unu ji kpọọ anyị oku bịa nʼebe?”
\p 
\v 16 Mgbe ahụ nwunye Samsin buuru onwe ya tụọ nʼelu ahụ ya, nʼebe akwa, sị, “Ị kpọrọ m asị! Nʼezie, ị hụghị m nʼanya. Ị tụụrụ ndị m ilu, ma ị gwaghị m ọsịsa ya.”
\p Ọ sịrị ya, “Lee, agwaghị m nne na nna m, ọ bụkwa gị ka m ga akọwara ya?”
\v 17 Ma nwanyị ahụ kwagidere akwa abalị asaa ha nọ na mmemme ahụ. Nʼikpeazụ, nʼụbọchị nke asaa, Samsin kọwaara ya okwu ahụ nʼihi na ọ nọgidere na-enye ya nsogbu. Nwanyị ahụ gakwara kọwaara ụmụ okorobịa obodo ihe okwu ahụ pụtara.
\p 
\v 18 Ma tupu anwụ adaa nʼụbọchị nke asaa ahụ, ndị ikom obodo ahụ sịrị ya,
\q1 “Olee ihe dị ụtọ karịa mmanụ aṅụ?
\q2 Gịnị dịkwa ike karịa ọdụm?”
\p Ma Samsin zara sị ha,
\q1 “A sị na unu enyeghị nwa ehi m nsogbu,
\q2 unu agaraghị enwe ike kọwaa ya.”
\p 
\v 19 Otu mgbe ahụ kwa, Mmụọ \nd Onyenwe anyị\nd* bịakwasịrị ya. O sitere nʼebe ahụ pụọ, gaa nʼobodo Ashkelọn.\f + \fr 14:19 \ft Ashkelọn bụ otu obodo nʼala Palestia.\f* Nʼebe ahụ ka ọ nọ tigbuo iri mmadụ atọ, napụ ha uwe ha niile, chịrị ha chịnye ndị ahụ kọwaara ya ilu ahụ. Ma site nʼoke iwe, o laghachiri nʼụlọ nna ya.
\v 20 E duuru nwunye Samsin dunye enyi Samsin ka ha abụọ bụrụ di na nwunye.
\c 15
\s1 Samsin egbuo ndị Filistia
\p 
\v 1 Mgbe oge nta gasịrị, nʼoge owuwe ihe ubi, mgbe a na-aghọ ọka, Samsin weere nwa ewu\f + \fr 15:1 \ft Mgbe nwoke lụrụ nwanyị, ọ bụrụ na nna nwanyị dị otu a a naraghị ego isi akụ, ọ bụ onyinye nwa ewu nta ka ọ ga-ewegara nwunye ya ahụ, mgbe ọbụla ọ gara ihu ya. Nwanyị ahụ ga-ebikwa nʼụlọ nna ya, nʼihi na nna ya a naghị ego akụ nʼisi ya. Ma mgbe ọbụla di nwanyị ahụ ga-abịa, ọ ga-ewetara ọgọ ya ọtụtụ onyinye. Nwa ewu nta bụ onyinye onye ọbụla na-enye nʼoge ahụ. \xt Jen 38:17\xt*\f* nta, gaa ileta nwunye ya. O gwara nna nwunye ya sị, “Ana m aga nʼọnụụlọ nwunye m.” Ma nna nwunye ya ekweghị ka ọ banye.
\p 
\v 2 Nna ya sịrị, “O doro m anya na ị kpọrọ nwa m nwanyị asị, ọ bụ nʼihi nke a ka m jiri kenye ya enyi gị nwoke ka ọ bụrụ nwunye ya. Nwanne ya nwanyị nke nta, ọ maghị mma karịa ya? Kpọrọ ya ka ọ nọchie anya ya.”
\p 
\v 3 Samsin sịrị ha, “Nʼoge a, o ziri m ezi ị bọkwara ọbọ nʼebe ndị Filistia nọ.” Aghaghị m imesi ha ike.
\v 4 Ya mere, Samsin pụrụ gaa jide narị nkịta ọhịa atọ, wetakwa ọwa ụfọdụ. O kekọtara ọdụdụ ha abụọ abụọ. O kenyere ọwa nʼagbata otu nkịta ọhịa na ibe ya.
\v 5 Emesịa, ọ mụnyere ọkụ nʼọwa ahụ niile. O mekwara ka nkịta ọhịa ndị ahụ dọkpụrụ ọwa a mụnyere ọkụ baa nʼubi ọka ndị Filistia, si otu a rechapụ ọka niile guzoro eguzo nʼubi, na ubi vaịnị niile, ha na osisi oliv niile ọkụ.
\p 
\v 6 Mgbe ndị Filistia chọpụtara ihe mere, ha jụrụ sị, “Onye mere ihe dị otu a?” A gwara ha, “Ọ bụ Samsin ọgọ onye Timna, nʼihi na a kpọnyere enyi ya nwunye ya.”
\p Nʼihi nke a, ndị Filistia niile zukọtara kpọpụta nwaagbọghọ ahụ na nna ya kpọọ ha ọkụ.
\v 7 Ma Samsin gwara ha okwu sị, “Ebe ọ bụ na unu mere ihe dị otu a, agaghị akwụsị tutu m bọrọ ọbọ ihe ọjọọ unu mere.”
\v 8 Ya mere, ọ pụkwuru ha ọzọ, site nʼoke iwe, gbuo ọtụtụ mmadụ nʼime ha. Mgbe nke a gasịrị, ọ gara biri nʼime otu ọgba nkume nke Etam.
\p 
\v 9 Ndị Filistia gara maa ụlọ ikwu ha nʼala Juda, gbasaa nʼala ahụ ruo obodo Lehi.
\v 10 Ndị Juda jụrụ ajụjụ sị ha; “Ọ bụ gịnị mere unu ji bịa nʼebe a ibuso anyị agha?”
\p Ha zara sị, “Anyị na-achọ ijide Samsin, ka anyị megwara ya ihe ọjọọ o mere anyị.”
\p 
\v 11 Nʼihi nke a, ndị Juda zipụrụ puku ndị agha ka ha gaa jide Samsin nʼọgba nkume ahụ nke Etam. Ndị a bịara jụọ Samsin ajụjụ sị ya, “Gịnị bụ ihe a i mere anyị? Ọ bụ na ị maghị na ndị Filistia na-achị obodo anyị?”\f + \fr 15:11 \ft \xt Lev 26:25; Dit 28:43; Nkp 13:1; 14:4; Abụ 106:40-42\xt*\f*
\p Samsin zara sị ha, “Ihe m mere bụ imegwata ha ihe ha mere m.”
\p 
\v 12 Ha sịrị ya, “Anyị abịala ka anyị kee gị agbụ, dọkpụrụ gị, nye nʼaka ndị Filistia.”
\p Samsin sịrị ha, “Ṅụọrọnụ m iyi na unu agaghị eji aka unu gbuo m.”
\p 
\v 13 Ha zara sị ya, “Anyị agaghị egbu gị kama anyị ga-eke gị agbụ.” Ya mere, ha kere ya agbụ, duru ya jekwuru ndị Filistia.
\v 14 Mgbe ọ na-abịaru Lehi, ndị Filistia tiiri mkpu, bịa izute ya. Mmụọ \nd Onyenwe anyị\nd* bịakwasịrị Samsin nʼebe ọ dị ukwuu. Nke a mere ka eriri ahụ e kere ya nʼaka dịrị ka eriri ogho flakisi erere ọkụ, sitekwa nʼaka ya dapụsịa.
\v 15 Mgbe ahụ Samsin lere anya gburugburu, hụ ọkpụkpụ agba ịnyịnya ibu nke tọgbọrọ nʼala nʼebe ahụ. Ọ tụtụlitere ya, were ya tigbuo puku ndị agha Filistia.
\p 
\v 16 Mgbe ahụ, Samsin kwuru sị,
\q1 “E ji m agba ịnyịnya ibu
\q2 mee ka ha dị ka ịnyịnya ibu.
\q1 E ji m agba ịnyịnya ibu
\q2 tigbuo puku ndị ikom.”
\m 
\v 17 Mgbe o kwuchara ihe ndị a, o tufuru ọkpụkpụ agba ịnyịnya ibu ahụ; a kpọkwara ebe ahụ Ramat Lehi.
\p 
\v 18 Nʼoge a, akpịrị kpọrọ Samsin nkụ nke ukwuu, nʼihi ya, ọ kpọkuru \nd Onyenwe anyị\nd* nʼekpere sị, “Lee, i nyela ohu gị mmeri a dị ukwuu! Ma ugbu a, ị ga-ekwe ka m nwụọ nʼihi akpịrị ịkpọ nku, si otu a daba nʼaka ndị a na-ebighị ugwu?”
\v 19 Chineke gbawara olulu ahụ nke dị nʼime Lehi, mee ka mmiri si na ya nupụta. Mgbe Samsin ṅụrụ mmiri ahụ, ike ya lọghachiri, mmụọ ya bịaghachikwara. Ya mere, a kpọrọ isi iyi ahụ En-Hakkore. Mmiri ala ahụ ka dịkwa na Lehi nʼebe ahụ ruo taa.
\p 
\v 20 Ya mere, Samsin kpere ụmụ Izrel ikpe iri afọ abụọ nʼoge ndị Filistia.
\c 16
\s1 Samsin na Delaịla
\p 
\v 1 Otu ụbọchị, Samsin gara nʼotu obodo ndị Filistia a na-akpọ Gaza, soro otu nwanyị akwụna bi nʼebe ahụ hie ụra abalị.
\v 2 A gwara ndị Gaza sị, “Samsin nọ nʼobodo a.” Nʼihi ya, ha gbara ebe ahụ gburugburu ma nọdụ na-eche nʼọnụ ụzọ ama obodo ahụ abalị niile. Ọ dịghị ihe ha mere nʼabalị ahụ nʼihi na ha zubere sị, “Mgbe chi bọrọ, anyị ga-egbu ya.”
\p 
\v 3 Ma Samsin dinara nʼụlọ nwanyị akwụna ahụ ruo nʼetiti abalị ahụ. Mgbe ọ pụtara, ọ gara ruo nʼọnụ ụzọ obodo ahụ, foro ibo ọnụ ụzọ obodo ahụ, ya na ibo ya abụọ, bukwasị ya nʼubu ya, buru ha gaa nʼelu ugwu chere obodo Hebrọn ihu.
\p 
\v 4 Ọ dịghị anya, Samsin hụrụ otu nwaagbọghọ, onye ọ hụrụ nʼanya. Aha nwaagbọghọ a bụ Delaịla, onye si nʼobodo dị na Ndagwurugwu Sorek.
\v 5 Ndị eze ndị Filistia,\f + \fr 16:5 \ft Filistia bụ ala nwere obodo ise nʼime ya, nke ndị eze ise na-achị. \xt Jos 13:3\xt*\f* bịakwutere Delaịla rịọọ ya sị, “Gbalịa lee ma ị ga-enwe ike chọpụta ebe ike Samsin si abịa, ka anyị nwee ike ịmata ụzọ anyị ga-esi jide ya, kee ya agbụ. Ọ bụrụ na i meere anyị nke a, anyị na-ekwe nkwa na onye ọbụla nʼime anyị ga-enye gị puku shekel na narị shekel ọlaọcha.”\f + \fr 16:5 \ft A chịkọta ego niile e kweere na nkwa inye nʼihi ijide Samsin, ọ bụ ọnụ ego a na-akwụ nʼisi narị ohu na iri asaa na ise.\f*
\p 
\v 6 Nʼihi nke a, Delaịla gwara Samsin okwu sị ya, “Gwa m ebe ike gị si abịa. Gwakwa m otu mmadụ pụrụ isi kee gị agbụ, merie gị.”
\p 
\v 7 Mgbe ahụ, Samsin zara sị ya, “Ọ bụrụ na mmadụ e jiri akwara eriri asaa dị ọhụrụ, ndị a na-amịkpọghị amịkpọ kee m, m ga-abụkwa onye na-adịghị ike dịka mmadụ ọbụla ọzọ.”
\p 
\v 8 Ngwangwa, ndịisi ndị Filistia wetara ya eriri asaa dị ọhụrụ ndị a na-amịbeghị nʼanwụ, o weere ha kee Samsin.
\v 9 Ma o mere ka ụfọdụ ndị ikom Filistia zoo onwe ha nʼotu akụkụ ụlọ ya. O tiri mkpu sị, “Samsin, lee, ndị Filistia abịala ijide gị!” Otu mgbe ahụ kwa, Samsin biliri dọbisie eriri ahụ dịka ọ bụ eriri e ji ogho mee nke bịara ọkụ nso. Ya mere, a chọpụtaghị ebe ike Samsin si abịa.
\p 
\v 10 Emesịa, Delaịla gwara Samsin sị ya, “Lee, ị kwaala m emo, ghaara m ụgha. Biko, gwa m ụzọ a ga-esi kee gị agbụ.”
\p 
\v 11 Samsin zara sị ya, “Lee, ọ bụrụ na e jiri ụdọ ọhụrụ nke a na-ejibeghị kee ihe mgbe ọbụla, kee m, aga m adịkwa dịka ndị ọzọ.”
\p 
\v 12 Ya mere, Delaịla chịkọtara ụdọ ọhụrụ jiri ya kee ya nke ọma. Ma ụfọdụ ndị ikom Filistia zokwara onwe ha nʼime ime ụlọ ahụ. Ọzọkwa, Delaịla tiri mkpu sị, “Samsin, lee, ndị Filistia abịala ijide gị.” Ma Samsin biliri dọbisie eriri ahụ e ji kee ya ka a ga-asị na ọ bụ ogho ka e ji mee ha.
\p 
\v 13 Mgbe ahụ, Delaịla gwara ya sị, “Lee, ị na-eme ka abụ m onye nzuzu, ghaara m ụgha. Gwa m eziokwu, otu a ga-esi kee gị agbụ.”
\p Samsin zara sị ya, “Lee, e kewara agịrị isi dị m nʼisi ụzọ asaa, i were ụzọ nkekọta asaa e kekọtara agịrị isi m, kpanyekọtaa ha nʼihe i ji ekwe akwa, were ntu osisi i ji akpachi akwa kpachie ya, mgbe ahụ, aga m adịkwa ka ndị ọzọ.” Mgbe Samsin rahụrụ ụra, Delaịla weere agịrị isi Samsin kpanyekọtaa ya nʼihe o ji ekwe akwa.
\v 14 O jikwa ǹtu osisi o ji akpachi akwa, kpachikọtasie agịrị isi Samsin ike.
\p Ọzọ, Delaịla sịrị ya, “Samsin, ndị Filistia abịala ijide gị.” Ma Samsin bilitere nʼike fokọrọ ǹtu osisi ahụ, na ihe eji akpa akwa, na akwa akpara akpa.
\p 
\v 15 Mgbe ahụ, Delaịla gwara ya okwu sị, “Olee ka i si kwuo na ị hụrụ m nʼanya, ebe ọ bụ na i nweghị ike ịgwa m ihe dị gị nʼobi? Lee, ugbo atọ ndị a, i mere m ka m dịka onye nzuzu, ma ị gwabeghị m ebe ike gị dị ruo ugbu a.”
\v 16 Delaịla sikwara otu a nyegide Samsin nsogbu tutu ruo mgbe Samsin na-enweghịkwa ike ịnagide nsogbu ya.
\p 
\v 17 Ya mere, ọ gwara ya ihe niile, “Ọ dịbeghị mgbe agụba ọbụla gara nʼelu isi m, nʼihi na abụ m onye Nazirait, onye e doro nsọ nye Chineke ka m bụ, site nʼafọ nne m. Ọ bụrụkwa na a kpụchapụ agịrị isi m, mgbe ahụ, ike niile dị m nʼahụ ga-apụ. Mgbe ahụ, aga m adịkwa ka ndị ọzọ.”
\p 
\v 18 Mgbe Delaịla matara na ọ gwala ya ihe niile, o ziri ozi kpọọ ndịisi ndị Filistia ahụ, sị, “Bịaghachinụ otu ugbu a, nʼihi na ọ gwara m ihe niile.” Ya mere, ndịisi ndị Filistia lọghachiri jiri ego ọlaedo ahụ nʼaka ha.
\v 19 Ma Delaịla mere ka o dinaa nʼapata ụkwụ ya rahụ ụra. Mgbe ahụ, ọ kpọbatara nwoke na-akpụcha isi, ka ọ kpụchapụ agịrị isi niile dị Samsin nʼisi, si otu a mee ka ike ghara ịdịkwa ya. Ike ya hapụrụ ya.
\p 
\v 20 O tiri mkpu sị, “Samsin, lee, ndị Filistia abịala ijide gị.”
\p Ma mgbe Samsin bilitere site nʼụra, o chere nʼobi ya, “Aga m apụ ka m si mee na mbụ megharịa arụ ma nwere onwe m.” Ma ọ maghị na \nd Onyenwe anyị\nd* ahapụla ya.
\p 
\v 21 Ndị Filistia jidere ya, ghụpụ ya anya ya abụọ, duru ya gbadata Gaza. Nʼebe ahụ, ha jiri ụdọ bronz kee ya agbụ, nye ya ọrụ ịnyagharị igwe na-akwọ ọka nʼụlọ mkpọrọ ha tinyere ya.
\v 22 Mgbe na-adịghị anya, agịrị isi ya malitekwara ito ọzọ.
\s1 Ọnwụ Samsin
\p 
\v 23 Ugbu a, ndịisi ndị Filistia niile zukọtara ịchụrụ chi ha bụ Dagọn,\f + \fr 16:23 \ft Dagọn bụ chi ahịhịa ndụ nye ndị Filistia. Ogidi oyiyi ya bụ ọkara mmadụ na ọkara azụ. Nʼasụsụ ndị Hibru, Dagọn pụtara mkpụrụ ọka, ebe mkpụrụ okwu a Dag pụtara azụ.\f* aja dị ukwuu, na ịṅụrị ọṅụ, na-asị, “Chi anyị enyela Samsin bụ onye iro anyị nʼaka anyị.”
\p 
\v 24 Mgbe ndị mmadụ hụrụ ya, ha toro chi ha sị,
\q1 “Chi anyị enyela onye iro anyị
\q2 nʼaka anyị,
\q1 onye mere ka ala anyị tọgbọrọ nʼefu
\q2 gbukwaa ọtụtụ ndị anyị.”
\p 
\v 25 Mgbe ha ka nọ nʼobi ụtọ, ha tiri mkpu sị, “Dupụtara anyị Samsin, ka o kpaa anyị ọchị.” Ya mere, e dupụtara Samsin site nʼụlọ mkpọrọ ka o meere ha ihe egwuregwu.
\p Ha mere ka o guzo nʼetiti ebe ogidi e ji wuo ụlọ ahụ dị.
\v 26 Mgbe ahụ, Samsin sịrị onye na-eji ya nʼaka sị, “Debe m nʼebe m ga-emetụ ogidi ndị ụlọ a na-eguzo na ha aka, ka m nwe ike dabere na ha.”
\v 27 Nʼoge a, mmadụ ejupụtala nʼime ụlọ ahụ, nwoke na nwanyị; ndịisi ọchịchị ndị Filistia nọkwa nʼebe ahụ. Ndị ọzọ ọnụọgụgụ ha ruru puku atọ, nwoke na nwanyị, nọ nʼelu ụlọ ahụ na-ele Samsin, ebe ọ na-emere ha ihe ọchị.
\v 28 Mgbe ahụ, Samsin kpere ekpere rịọọ \nd Onyenwe anyị\nd* arịrịọ sị, “O! Onyenwe m \nd Onyenwe anyị\nd*, biko cheta m naanị otu ugbu a. Biko, Chineke, nye m ike nʼotu ohere a m nwere, ka m nwee ike ịbọrọ ọbọ nʼahụ ndị Filistia nʼihi, ọ bụladị, mkpụrụ anya m abụọ.”
\v 29 Mgbe ahụ, Samsin jidesiri ogidi abụọ dị nʼetiti ụlọ ahụ aka ike, aka nri ya nʼotu, aka ekpe ya na nke ọzọ.
\v 30 Samsin kpere ekpere sị, “Ka m soro ndị Filistia nwụọ!” O ji ike ya niile nuo ogidi ahụ aka. Otu mgbe ahụ kwa, ụlọ arụsị ahụ dara, dakwasị ndịisi ọchịchị Filistia ndị ahụ, na ndị niile nọ nʼime ụlọ ahụ. Ya mere, ndị niile so Samsin nwụọ nʼoge ahụ dị ọtụtụ karịa ndị Samsin gburu mgbe ọ dị ndụ.
\p 
\v 31 Mgbe ihe ndị a gasịrị, ụmụnna ndị ikom Samsin, na ndị ezinaụlọ nna ya bịara nʼebe ahụ, buru ozu ya. Ha liri ya nʼagbata Zora na Eshtaol, ebe e liri nna ya Manoa. Samsin kpere ụmụ Izrel ikpe iri afọ abụọ.
\c 17
\s1 Arụsị Maịka
\p 
\v 1 E nwere otu nwoke si nʼala ugwu ugwu Ifrem, aha ya bụ Maịka.
\v 2 Otu ụbọchị, Maịka gwara nne ya okwu sị ya, “I chetara puku na narị ego ọlaọcha shekel ndị ahụ funarịrị gị, nke i ji nʼihi ya bụọ onye zuru ya ọnụ nʼoge gara aga? Eji m ọlaọcha ahụ. Ọ bụ m weere ya.”
\p Nne ya sịrị, “Ka \nd Onyenwe anyị\nd* gọzie gị nwa m!”
\p 
\v 3 Mgbe o nyeghachiri nne ya puku na narị ego ọlaọcha shekel ahụ, nne ya gwara ya sị, “Ana m edo ọlaọcha ndị a nsọ nye \nd Onyenwe anyị\nd* nʼihi nwa m nwoke maka iji ya mee oyiyi a pịrị apị na arụsị a kpụrụ akpụ. Aga m emesịa nyeghachi gị ya.”
\p 
\v 4 Ya mere, o nyeghachiri nne ya ọlaọcha ahụ, Nne ya weere narị ego ọlaọcha shekel abụọ wegara ọkpụ ụzụ ọlaọcha, onye jiri ya mee oyiyi a pịrị apị na ihe a kpụrụ akpụ. E tinyere ha nʼụlọ Maịka.
\p 
\v 5 Nwoke ahụ bụ Maịka nwere ụlọ arụsị, o mere efọọd na arụsị ezinaụlọ\f + \fr 17:5 \ft Maọbụ, \fqa terafim\f* dị iche iche, mee otu nʼime ụmụ ya ndị ikom ka ọ bụrụ onye nchụaja ya.
\v 6 Nʼụbọchị ndị a, Izrel enweghị eze na-achị ha. Nʼihi nke a, onye ọbụla na-eme ihe ọbụla ọ chọrọ, na ihe ọbụla dị ya mma nʼanya.
\p 
\v 7 Otu nwokorobịa onye Livayị, sitere nʼobodo Betlehem nke dị na Juda, bụ onye binyere ndị agbụrụ Juda,
\v 8 hapụrụ obodo ahụ, bụ Betlehem Juda ịchọ ọnọdụ nʼebe ọzọ. Mgbe ọ na-aga, ọ bịaruru nʼụlọ Maịka nʼala ugwu ugwu Ifrem.
\p 
\v 9 Maịka jụrụ ya, “Ebee ka i si bịa?”
\p Ọ sịrị “Abụ m onye Livayị si Betlehem dị na Juda. Ana m achọrọ onwe m ebe m ga-anọ.”
\p 
\v 10 Mgbe ahụ, Maịka sịrị ya, “Soro biri nʼụlọ m, ghọkwara m nna na onye nchụaja, aga m akwụ gị mkpụrụ ego ọlaọcha shekel iri kwa afọ, nyekwa gị uwe, na ihe oriri.”
\v 11 Ya mere, onye Livayị ahụ kwere nʼihe ọ gwara ya, nwokorobịa ahụ sooro ya biri ka otu nʼime ụmụ ya ndị ikom.
\v 12 Mgbe ahụ, Maịka nyere onye Livayị ahụ ọrụ, nwokorobịa ahụ ghọọrọ ya onye nchụaja, birikwa nʼụlọ ya.
\v 13 Mgbe ahụ, Maịka kwuru, “Ugbu a, amaara m na \nd Onyenwe anyị\nd* ga-agọzi m nke ukwuu, nʼihi na onye Livayị a aghọọla onye nchụaja m.”
\c 18
\s1 Ebo Dan ebiri na Laish
\p 
\v 1 Nʼoge ahụ kwa, ụmụ Izrel enweghị eze ọbụla na-achị ha.
\p Ebo Dan na-achọkwara onwe ha ebe obibi nke ga-abụ ala nke aka ha, nʼihi na ruo ugbu a, ha enwebeghị ike chụpụ ndị bi nʼala ahụ e kenyere ha dịka ihe nketa nke ha.
\v 2 Nʼihi nke a, ebo Dan sitere nʼikwu ise dị nʼebo ha họpụta mmadụ ise. Ndị a bụ dimkpa, na dike nʼagha, bụrụkwa ndị si nʼobodo Zora na Eshtaol. Ha zipụrụ mmadụ ise ndị a ka ha gaa nyochaa ala ahụ ha na-achọ ibi nʼime ya.
\p Mgbe ndị ahụ jeruru obodo ugwu ugwu Ifrem, ha gara nọdụ ọdụ abalị nʼụlọ Maịka.
\v 3 Mgbe ha nọ nso ụlọ Maịka, ha nụrụ asụsụ nwokorobịa onye Livayị ahụ bụ onye nchụaja. Ha kpọpụtara ya nʼotu akụkụ jụọ ya ajụjụ sị, “Onye kpọtara gị ebe a? Gịnị ka ị na-eme nʼebe a? Gịnị mere i ji bịa nʼebe a?”
\p 
\v 4 Nwokorobịa ahụ kọwara ha ihe Maịka meere ya. Ọ gwara ha, “O nyere m ọrụ, abụkwa m onye nchụaja ya.”
\p 
\v 5 Ha sịrị ya, “Ọ dị mma! Biko, jụta Chineke ase, chọpụta ma ije anyị a ọ ga-agakwa nke ọma.”
\p 
\v 6 Onye nchụaja ahụ zara sị ha, “Gaa nʼudo. Ije unu nwere ngọzị \nd Onyenwe anyị\nd*.”
\p 
\v 7 Ya mere, ndị ikom ise ndị ahụ biliri ije bịaruo nʼobodo Laish, ebe ha hụrụ na ndị ahụ na-ebi nʼudo, na-enweghị nsogbu ọbụla. Ha dịka ndị obodo Saịdọn, ndị onwe ha juru afọ, ndị na-adịghị atụ anya ihe egwu ọbụla. Ha bụ ndị bara ụba, ebe ọ dịghị ihe ọbụla kọrọ ụkọ nʼala ahụ. Ọzọ, ha bi nʼebe dị anya site nʼobodo ndị Saịdọn. Ọ dịkwaghị ihe ha na mmadụ ọbụla nwekọrọ.
\p 
\v 8 Mgbe ndị nnyocha ahụ laghachiri nʼobodo Zora na Eshtaol, ndị ebo Dan ibe ha jụrụ ha, sị, “Unu si aṅaa jee? Gịnị ka unu chọpụtara?”
\p 
\v 9 Ha zara sị, “Bịanụ, ka anyị gaa buso ha agha. Anyị ahụla ala ahụ, ọ dịkwa mma nke ukwu. Gịnị ka unu na-agbara nkịtị? Unu egbula oge ịba nʼebe ahụ nweta ya.
\v 10 Mgbe unu ruru ebe ahụ, unu ga-ahụ ndị na-adịghị atụ anya ihe egwu ọbụla, na ala sara mbara nke Chineke na-etinye unu nʼaka. Ala nke ihe ọbụla na-adịghị akọ nʼime ya.”
\p 
\v 11 Ya mere, narị ndị agha isii ndị si nʼebo Dan biliri gaa ibuso obodo ahụ agha. Ha sikwa Zora na Eshtaol pụọ.
\v 12 Mgbe ha na-aga, ha rutere Kiriat Jearim, nke dị na Juda, maa ụlọ ikwu ha nʼebe ahụ. Ọ bụ ya mere e ji akpọ ebe ahụ dị nʼakụkụ ọdịda anyanwụ Kiriat Jearim Mahane Dan ruo taa.
\v 13 Emesịa, ha pụrụ nʼala ugwu ugwu Ifrem, bịarute nʼụlọ Maịka.
\p 
\v 14 Mmadụ ise ndị ahụ gara nnyochapụta ala (ya bụ ala Laish) ahụ gwara ụmụnna ha sị, “Unu maara na nʼime otu ụlọ ndị a na e nwere efọọd, nʼụfọdụ arụsị ezinaụlọ ndị dị iche iche, na oyiyi a kpụrụ akpụ nke eji ọla wuo? Ugbu a, maranụ ihe unu ga-eme.”
\v 15 Ya mere, ha gara nʼebe ahụ, banye nʼụlọ nwokorobịa Livayị ahụ, ebe o bi nʼụlọ Maịka, jụọ ya maka ọdịmma ya.
\v 16 Narị ndị ikom Dan, ndị jikere ibu agha, guzo nʼọnụ ụzọ ama.
\v 17 Mgbe ahụ, ndị nnyocha ise ahụ banyere nʼime ụlọ ahụ buru arụsị ọla ahụ, na efọọd ahụ, na arụsị ezinaụlọ ndị ahụ, ma onye nchụaja ahụ na narị ndị agha isii ndị ji ngwa agha guzo nʼọnụ ụzọ ama.
\p 
\v 18 Mgbe ndị ikom ahụ banyere nʼụlọ Maịka buru arụsị ọla ahụ, efọọd ahụ na arụsị ezinaụlọ ndị ọzọ ahụ, onye nchụaja ahụ sịrị ha, “Gịnị ka unu na-eme?”
\p 
\v 19 Ha zara sị ya, “Mechie ọnụ gị! Ekwukwala okwu ọbụla. Soro anyị bịa bụrụ nna anyị na onye nchụaja anyị. Ọ ga-abara gị uru karịa ịbụ onye nchụaja nye otu ebo na otu agbụrụ nʼIzrel, karịa ịbụ onye nchụaja nke naanị otu nwoke nʼime ezinaụlọ ya.”
\v 20 Mgbe ahụ, obi tọrọ nwokorobịa onye nchụaja ahụ ụtọ isoro ha gaa. O buuru efọọd ahụ, arụsị ezinaụlọ ndị ọzọ ahụ na oyiyi ahụ a pịrị apị soro ndị ahụ gawa.
\v 21 Ha malitekwara ije ha, ụmụntakịrị ha, na igwe anụ ụlọ ha, na ngwongwo ha ka ha tinyere nʼihu ha.
\p 
\v 22 Mgbe ha gamitụrụ nke nta site nʼụlọ Maịka, ndị ikom ndị bi nso ụlọ Maịka kpọkọtara onwe ha chụso ndị Dan, gafee ha.
\v 23 Maịka na ndị so ya na-etikwa mkpu na-akpọku ha sị ha kwụsị ije ha. Ma ndị ebo Dan jụrụ Maịka ajụjụ sị ya, “Gịnị na-eme gị iji kpọpụta ndị gị ka ha bịa lụso anyị agha?”
\p 
\v 24 Ọ zaghachiri, “Unu chịịrị chi ndị m mere, kpọrọ onye nchụaja m pụọ. Gịnị ọzọ ka m nwekwara? Olee otu unu si ajụ, ‘Gịnị na-eme gị?’ ”
\p 
\v 25 Ndị ikom Dan zara sị ya, “Lezie anya kpachara anya banyere ụdị okwu ị na-ekwu. Nʼihi na i kwuo ụdị okwu a gaa nʼihu, ụfọdụ ndị ikom isi na-anụ ọkụ ga-abịa lụso gị agha gbuo gị na ndị ezinaụlọ gị.”
\v 26 Ya mere, ndị ebo Dan gbara ya nkịtị na-aga ebe ha na-aga. Mgbe Maịka hụrụ na ha dị ọtụtụ karịa ya, ọ hapụrụ ha, tụgharịa laghachi nʼụlọ ya.
\p 
\v 27 Ụmụ Dan chịịrị arụsị ahụ niile Maịka mere, durukwa onye nchụaja ya gawa nʼobodo Laish, obodo nọ nʼudo, nke na-adịghị atụ anya ihe egwu ọbụla. Ha busoro ndị obodo ahụ agha, suo obodo ahụ ọkụ.
\v 28 Ọ dịghị onye ọbụla nwere ike bịa inyere ndị obodo ahụ aka nʼihi ha bi nʼebe dị anya site nʼobodo Saịdọn. O nwekwaghị obodo ọbụla ha na ha na-emekọrịta. Obodo a dị na ndagwurugwu dị nso na Bet-Rehob.
\p Emesịa, ndị ebo Dan wughachiri obodo ahụ ọzọ, biri nʼime ya.
\v 29 Ọ bụ nke a mere e ji kpọọ aha obodo ahụ Dan, nke bụ aha nna ha ochie, onye bụ nwa Izrel. Ma tupu ebo Dan ebibie ya, aha obodo a nʼoge gara aga bụ Laish.
\v 30 Nʼebe ahụ ndị Dan guzobeere onwe ha arụsị, Jonatan, nwa Geshọm, nwa Mosis, na ụmụ ya ndị ikom niile ghọọrọ ndị nchụaja nye ebo Dan ruo nʼoge a dọtara ala ahụ nʼagha.
\v 31 \f + \fr 18:31 \ft \xt Dit 12:1-32; Jos 18:1,8; Nkp 18:18; 21:12\xt*\f* Ndị ebo Dan nọgidere na-efe arụsị ndị ahụ Maịka mere oge ahụ niile ụlọ nzute Chineke dị na Shaịlo.
\c 19
\s1 Onye Livayị na iko ya nwanyị
\p 
\v 1 Nʼoge a, Izrel enweghị eze na-achị ha.
\p Nʼoge ahụ kwa, ọ dị otu nwoke, onye Livayị bi nʼebe dị anya nʼala ugwu ugwu Ifrem. Nwoke a gara Betlehem, nʼime Juda, kpọrọ otu nwaagbọghọ ka ọ bụrụ iko ya nwanyị.
\v 2 Ma iko ya nwanyị ahụ kwara iko megide ya. Ọ hapụrụ ya laghachi nʼezinaụlọ nne na nna ya na Betlehem, Juda. Ọ nọrọ ọnwa anọ nʼebe ahụ.
\v 3 Nwoke ahụ kpebiri ịga nʼụlọ nna nwaagbọghọ ahụ ịrịọ ya ka ọ lọghachi. Ọ kpọọrọ otu nʼime ndị ohu ya, duru ịnyịnya ibu abụọ. Mgbe nwoke ahụ bịaruru nʼụlọ ahụ, iko ya nwanyị kpọbatara ya nʼụlọ nna ya. Mgbe nna nwaagbọghọ ahụ hụrụ ya, o jiri ọṅụ kelee ya ekele.
\v 4 Nna nwanyị ahụ rịọrọ ya ka ọ nọnyere ha ụfọdụ oge. Nʼihi nke a, ọ nọnyeere ha ụbọchị atọ. Ha niile nọrọ ọnọdụ obi ụtọ abalị atọ ahụ niile, rie ṅụọkwa.
\p 
\v 5 Nʼụbọchị nke anọ, nwoke ahụ na iko ya jikeere nʼisi ụtụtụ ịlaghachi. Ma nna nwanyị ahụ rịọrọ ha sị ha, “Jirinụ ihe oriri gbaanụ onwe unu ume. Emesịa unu nwere ike ịlawa.”
\v 6 Ya mere, ha abụọ nọdụrụ ala rie ihe, ṅụọkwa ihe ọṅụṅụ. Mgbe e mesiri, nna nwaagbọghọ ahụ sịrị ha, “Biko, nọdụnụ rahụ ụra nʼabalị taa, meekwanụ onwe unu obi ụtọ.”
\v 7 Ma mgbe nwoke ahụ biliri ka ọ laa, nna nwaagbọghọ ahụ, nọgidere ya, nke a mere ka o kwenye ịnọ ruo echi ya.
\v 8 Nʼisi ụtụtụ ụbọchị nke ise, ha bilikwara ngwangwa jikere ịhapụ ma ịlaghachi. Ọzọkwa, nna nwaagbọghọ ahụ rịọkwara ha sị ha, “Biko, nọgidenụ nʼụtụtụ taa, ma nʼoge ehihie unu nwere ike laa.” Nʼihi nke a, ha nọgidekwara rie, ṅụọ.
\p 
\v 9 Mgbe nwoke ahụ na iko ya nwanyị, na ohu ya, jikeere ịhapụ, nna nwaagbọghọ ahụ rịọkwara ha sị ha, “Biko, lee chi ebidola iji ugbu a, abalị adịkwala nso. Biko, nọgide nʼụlọ m naanị abalị taa. Anyị ga-emekwa onwe anyị obi ụtọ abalị taa niile. Ma unu ga-amalite ije unu nʼisi ụtụtụ echi. Mgbe ahụ, unu ga-ala nʼudo.”
\v 10 Ma nwoke ahụ ekweghị ịnọ ọnọdụ abalị ọzọ, ọ hapụrụ gawa nʼụzọ ije Jebus (ya bụ Jerusalem), ya na ịnyịnya ibu ya abụọ akwadoro maka njem nakwa iko ya nwanyị.
\p 
\v 11 Ha rutere ebe ahụ oge chi na-akwado iji. Ohu ya sịrị nna ya ukwu, “Bịa, ka anyị kwụsị nʼobodo ndị Jebus a, nọ ọnọdụ abalị.”
\p 
\v 12 Ma nna ya ukwu zaghachiri, “Mba! Anyị agaghị aba nʼobodo ndị na abụghị ụmụ Izrel. Anyị ga-aga nʼihu ruo Gibea.”
\v 13 O kwukwara sị, “Bịa ka anyị gbalịa iru Gibea maọbụ Rema, nọọ ọnọdụ abalị nʼotu nʼime ebe ndị a.”
\v 14 Ya mere, ha gara nʼihu nʼije ha. Anwụ dara dịka ha na-eru Gibea dị na Benjamin.
\v 15 Nʼebe ahụ ka ha kwụsịrị ịnọ ọnọdụ abalị. Ha gara nọrọ na mbara ama obodo ahụ, ma o nweghị onye ọbụla kpọbatara ha ka ha rahụ ụra nʼụlọ ya.
\p 
\v 16 Nʼanyasị ahụ, otu agadi nwoke zutere ha ka o si ịrụ ọrụ nʼubi na-alọghachi, onye si nʼobodo ugwu ugwu Ifrem, ma o bi ka onye ọbịa na Gibea (ndị bi nʼebe a bụ ndị Benjamin).
\v 17 Mgbe agadi nwoke a hụrụ ndị ije ahụ na mbara ama obodo ahụ, ọ jụrụ ha ajụjụ sị, “Ebee ka unu si bịa? Ebee ka unu na-aga?”
\p 
\v 18 Nwoke ahụ zara sị ya, “Anyị si Betlehem dị na Juda na-alọghachi nʼụlọ anyị dị nʼebe dị anya nʼala ugwu ugwu Ifrem. Esi m ebe ahụ gaa Betlehem dị na Juda, ma ugbu a, ana m aga nʼụlọ \nd Onyenwe anyị\nd*. O nweghị onye kpọbatara anyị nʼụlọ ya.
\v 19 Anyị nwere ihe oriri nke ịnyịnya ibu anyị ga-eri, achịcha na mmanya nke anyị bụ ndị ohu gị ga-eri, ya bụ, mụ onwe m na ohu gị nwanyị na nwokorobịa so anyị. Anyị achọghị ihe ọbụla nʼaka onye ọbụla.”
\p 
\v 20 Agadi nwoke ahụ sịrị ha, “Batanụ nʼụlọ m dịka ndị ọbịa nke m. Ka m nye unu ihe niile bụ mkpa unu. Naanị unu anọla ọnọdụ abalị nʼama.”
\v 21 Nʼihi nke a, ọ kpọbatara ha nʼụlọ ya. O duuru ịnyịnya ibu ha, nye ha ihe oriri. Emesịa, ha sara ụkwụ\f + \fr 19:21 \ft Ịsacha ụkwụ bụ omenaala i ji gosi na-anabatara mmadụ mgbe ọ batara nʼụlọ. Mmemme a bụ ihe a na-eme ebe ndị mmadụ na-eji ụkwụ aga ogologo ụzọ, nʼala ebe uzuzu jupụtara. \xt Jen 18:4; Jọn 13:5\xt*\f* ha mmiri, nọdụ ala rie ma ṅụọkwa.
\p 
\v 22 Ma mgbe ha risiri nri, nọrọ na-ezu ike, na-akpakọrịta ụka, na mberede, ndị ikom ụfọdụ sitere nʼobodo ahụ, ndị jọgburu onwe ha nʼomume gbara ụlọ ahụ gburugburu. Ha malitekwara iti aka nʼụzọ ahụ na iti mkpu na-akpọku agadi nwoke ahụ, sị ya, “Kpọpụta onye ọbịa ahụ nọ nʼime ụlọ gị ka anyị mara ya.”
\p 
\v 23 Agadi nwoke ahụ bụ onyenwe ụlọ ahụ pụkwuuru ha nʼezi, sị ha, “Biko ụmụnna m, unu emela ihe ọjọọ dị otu a. Nwoke a nọ nʼụlọ m dịka ọbịa. Unu emela ihe ihere dị otu a.
\v 24 Ka m kpọpụtara unu nwa m nwanyị na-amaghị nwoke, na iko nwanyị nwoke a ka unu jiri ha mee ihe ọbụla unu chọrọ ma hapụnụ nwoke a. Unu emela ihe ihere dị otu a.”
\p 
\v 25 Ma ndị ikom ahụ egeghị ya ntị. Ya mere, nwoke ahụ kpọpụtara iko ya nwanyị zipụrụ ha ya nʼezi. Ha niile nʼotu na otu, dinakwuru nwanyị ahụ abalị ahụ niile. Mgbe chi na-achọ ịbọ, ha hapụrụ ya ka ọ laa.
\v 26 Nʼisi ụtụtụ, nwanyị ahụ biliri laghachi azụ nʼụlọ ahụ iko ya nwoke nọ. Ma ọ dara nʼala nʼihu ọnụ ụzọ ụlọ ahụ tọgbọrọ nʼebe ahụ tutu chi abọzie.
\p 
\v 27 Mgbe nwoke ahụ biliri nʼụtụtụ, meghee ụzọ ka ọ malite ije ya, ọ hụrụ iko ya nwanyị ahụ ka ọ tọgbọ nʼọnụ ụzọ ahụ. Aka ya abụọ dịkwa nʼọnụ ụzọ mbata ụlọ ahụ.
\v 28 Nwoke ahụ kpọkuru ya sị ya, “Ngwa, bilie ka anyị laa.” Ma nwaagbọghọ ahụ ekwughị okwu ọbụla. Nwoke ahụ buliri ya, tụkwasị ya nʼelu ịnyịnya ibu ya, buru ya laa nʼobodo nke aka ya.
\p 
\v 29 Mgbe ọ bịaruru obodo ya, ọ banyere nʼụlọ ya wepụta mma jiri ya bọwaa ozu iko ya nwanyị ahụ ụzọ iri na abụọ. O zigaara ebo iri na abụọ niile dị nʼIzrel otu ụzọ, otu ụzọ.
\v 30 Nʼihi nke a, Onye ọbụla hụrụ ihe ọjọọ a kwuru sị, “O nwebeghị onye ọbụla mere ụdị ajọ omume dị otu a kemgbe ụmụ Izrel si nʼobodo Ijipt pụta. Chee echiche banyere ihe a. Tulee ya ma gwa anyị ihe anyị ga-eme?”
\c 20
\s1 Ndị Izrel ebuso ebo Benjamin agha
\p 
\v 1 Mgbe ahụ, ndị Izrel niile ndị si nʼala Dan ruo Bịasheba, tinyere ndị si nʼala Gilead, pụtara dịka otu mmadụ, bịa zukọọ nʼihu \nd Onyenwe anyị\nd* na Mizpa.
\v 2 Ndị ndu ebo Izrel niile weere ọnọdụ na nzukọ nke ndị Chineke, ọnụọgụgụ ha bụ narị puku ndị agha anọ, ndị na-ebu mma agha.
\v 3 Mgbe na-adịghị anya, nzukọ ụmụ Izrel niile na Mizpa ruru ụmụ Benjamin ntị. Mgbe ahụ, ndịisi Izrel niile kpọrọ nwoke ahụ e gburu iko ya nwanyị sị ya, “Kọọrọ anyị otu ihe ọjọọ a si mee.”
\p 
\v 4 Ya mere, onye Livayị ahụ, di nwanyị ahụ e gburu kwuru sị, “Mụ na iko m nwanyị bịaruru obodo Gibea, obodo nta ndị Benjamin, kwụsị nʼebe ahụ ịnọ ọnọdụ abalị.
\v 5 Nʼoge abalị, ndị ikom Gibea bịara gba ụlọ anyị nọ nʼime ya gburugburu. Nzube ha bụ igbu m. Ma ha jidere iko m nwanyị, dinakwuru ya nʼike, tutu ruo mgbe ọ nwụrụ.
\v 6 Nʼihi ya, abọwasịrị m ahụ iko m nwanyị ụzọ iri na abụọ, zisa ya nʼakụkụ niile nke ihe nketa ndị Izrel niile nʼihi na ndị ikom Gibea ndị ahụ emeela ihe ọjọọ na ihe ihere nʼala Izrel.
\v 7 Ugbu a, unu ụmụ Izrel niile, unu onwe unu tụleenụ okwu a, nyekwanụ ndụmọdụ ihe a ga-eme ebe a.”
\p 
\v 8 Ndị mmadụ niile kulitere dịka otu onye, sị, “O nweghị onye ọbụla ga-ala na be ya. O nweghị onye ọbụla ga-esi nʼebe a laa nʼụlọ ya.
\v 9 Ma ugbu a, nke a bụ ihe anyị ga-eme ndị Gibea. Anyị ga-efe nza chọpụta ndị ga-aga lụso ndị Gibea agha.
\v 10 Anyị ga-esite nʼebo niile nke Izrel họpụta mmadụ iri site na narị mmadụ, họpụta narị mmadụ site na puku mmadụ, họpụtakwa puku mmadụ site nʼiri puku mmadụ, ka ha hụ maka iwetara ndị agha ihe oriri. Mgbe ndị agha a rutere Geba dị na Benjamin, anyị pụrụ ịkwụghachi ha ụgwọ ruru ha dịka ihe ihere niile ha mere nʼala Izrel si dị.”
\v 11 Ya mere, ndị Izrel niile jikọtara onwe ha ọnụ ibu agha ahụ dịka otu onye, megide obodo ahụ.
\p 
\v 12 Ndị ebo Izrel zipụrụ ndị ozi ka ha gazuo ebo Benjamin niile, sị ha, “Gịnị bụ ihe ọjọọ nke a jọgburu onwe ya emere nʼetiti unu?
\v 13 Ugbu a, kpọpụtara anyị ndị ikom ọjọọ dị a si nʼobodo Gibea ka anyị gbuo ha. Anyị ga-esikwa otu a hichapụ ihe ọjọọ a site nʼIzrel.”
\p Ma ụmụ Benjamin egeghị ndị Izrel ibe ha ntị.
\v 14 Ha sitere nʼobodo ha dị iche iche zukọtaa na Gibea maka ibuso ndị Izrel agha.
\v 15 Nʼụbọchị ahụ, ndị Benjamin sitere nʼobodo ha dị iche iche kpọkọta iri puku ndị ikom abụọ na puku isii bụ ndị na-amịpụta mma agha, tinyere narị ndị ikom asaa ahụ zuruoke site na ndị bi na Gibea.
\v 16 Nʼime ndị agha ndị a, e nwere narị ndị agha asaa, ndị a maara nke ọma dịka ndị na-agbata ụta nke ọma.\f + \fr 20:16 \ft \xt Nkp 3:16; 1Ih 12:2\xt*\f* Ha bụ ndị na-eme aka ekpe, onye ọbụla nʼime ha nwere ike iji okwute mata otu agịrị isi, ghara ịmahie ya.
\p 
\v 17 Ma ọnụọgụgụ ndị agha ụmụ Izrel, ma ọ bụrụ na e wezuga ụmụ Benjamin, dị narị puku anọ.
\p 
\v 18 Ma tupu agha ahụ ebido, ndị agha Izrel buru ụzọ gaa Betel ịjụta Chineke ase. Ha jụrụ ya sị, “Olee ebo ga-edu anyị ibuso ndị agha Benjamin agha?”
\p \nd Onyenwe anyị\nd* zara sị ha na ọ bụ Juda ga-ebu ụzọ.
\p 
\v 19 Nʼihi nke a, nʼisi ụtụtụ echi ya, ndị agha ụmụ Izrel niile buliri ihe agha ha pụọ, maa ụlọ ikwu ha nso nso Gibea.
\v 20 Emesịa, ndị Izrel pụrụ izute ndị Benjamin, doo onwe ha nʼusoro ibu agha na Gibea.
\v 21 Ma nʼụbọchị ahụ, ndị Benjamin si Gibea nupụta nʼigwe gbuo ndị agha Izrel ọnụọgụgụ ha dị iri puku abụọ na puku abụọ.
\v 22 Ndị agha Izrel gbarịtara onwe ha ume, ma werekwa ọnọdụ ibu agha dịka ha mere nʼụbọchị mbụ.
\v 23 Ndị agha Izrel kwara akwa nke ukwuu nʼụbọchị ahụ nʼihu \nd Onyenwe anyị\nd* site nʼụtụtụ ruo anyasị. Ha jụrụ \nd Onyenwe anyị\nd* ase ọzọ sị ya, “Anyị ga-aga nʼihu ịlụso ụmụnna anyị ndị Benjamin ọgụ?”
\p \nd Onyenwe anyị\nd* zara sị ha, “Gaanụ ga lụso ha agha.”
\p 
\v 24 Nʼihi nke a, ndị Izrel jeghachikwara ọzọ ibuso ụmụ Benjamin agha nʼụbọchị nke abụọ ya.
\v 25 Nʼoge a kwa, ndị agha Benjamin si nʼobodo Gibea pụta ibuso ha agha. Ha gburu ndị agha Izrel ọnụọgụgụ ha dị puku iri na asatọ. Ndị a niile bụkwa ndị ji mma agha ebu agha.
\p 
\v 26 Mgbe ahụ, ndị Izrel niile gara Betel, nọdụ nʼebe ahụ, kwaa akwa nʼihu \nd Onyenwe anyị\nd* Ha erighị nri ọbụla nʼụbọchị ahụ site nʼụtụtụ ruo nʼanyasị. Ha chere nʼihu \nd Onyenwe anyị\nd* onyinye aja udo, ma chụọkwa aja nsure ọkụ.
\v 27 Ndị Izrel jụrụ ase site nʼaka \nd Onyenwe anyị\nd*. (Nʼoge ndị ahụ, igbe ọgbụgba ndụ Chineke dị nʼebe ahụ.
\v 28 Finehaz nwa Elieza, nwa nwa Erọn na-eje ozi nchụaja nʼebe ahụ.) Ụmụ Izrel jụrụ \nd Onyenwe anyị\nd* ase sị ya, “Ọ bụ anyị gaakwa ọzọ ibuso ụmụnna anyị ndị Benjamin agha, ka ị sị anyị agala?”
\p \nd Onyenwe anyị\nd* zara sị ha, “Gaanụ, nʼihi na aga m ahụ na unu meriri ndị agha Benjamin echi.”
\p 
\v 29 Nʼihi nke a, ụmụ Izrel kewapụtara ndị zoro onwe ha nʼọhịa, gburugburu obodo Gibea.
\v 30 Nʼụbọchị nke atọ ya, ha pụrụ gaakwa izute ndị Benjamin, ha were ọnọdụ ha imegide ndị Gibea dịka ha mere nʼoge gara aga.
\v 31 Ndị Benjamin pụtara izute ha, e mere ka ha site nʼobodo pụọ. Ha malitere igbu ndị Izrel dịka ha mere na mbụ, nke mere na ndị ikom iri atọ dara nwụọ nʼọhịa ma na ụzọ, otu nke gawara obodo Betel, na nke ọzọ gawara obodo Gibea.
\v 32 Ya mere, mgbe ndị agha Benjamin malitere na-asị, “Lee, anyị emeriela ha dịka anyị mere na mbụ,” ndị Izrel nọ na-ekwu sị, “Ka anyị gbara ọsọ na-aga ruo mgbe ha ga-anọ ebe dị anya site nʼobodo ha.”
\p 
\v 33 Ndị ikom niile nke Izrel sitere nʼọnọdụ ha bilie, doo onwe ha nʼusoro na Baal-Tama, ndị Izrel ndị zoro onwe ha wapụtara site nʼọnọdụ ha nʼọdịda anyanwụ nke Geba, si nʼọhịa mapụta.
\v 34 Iri puku ndị ikom Izrel ahụ zuruoke gara na ncherita ihu Gibea busoo ya agha. Agha ahụ dị ike nke ukwuu nke mere na ndị Benjamin amataghị na oke mbibi na-abịakwasị ha.
\v 35 \nd Onyenwe anyị\nd* meriri ndị Benjamin nʼihu Izrel, nʼụbọchị ahụ; ndị Izrel gburu ndị agha Benjamin ọnụọgụgụ ha dị iri puku abụọ, na puku ise, na otu narị. Ha niile bụkwa ndị na-eji mma agha aga agha.
\v 36 Mgbe ahụ, ndị Benjamin nʼonwe ha, hụrụ na e emeriela ha.
\p Ugbu a, ndị ikom Izrel nyere ndị Benjamin ohere ịga nʼihu, nʼihi na ha dabere na ndị ha zoro nʼọhịa nʼakụkụ Gibea.
\v 37 Ndị ahụ zoro nʼọhịa gbapụtara ọsịịsọ gbaba nʼobodo Gibea, kesaa onwe ha, were mma agha gbuchapụ ndị niile nọ nʼobodo ahụ.
\v 38 Ndị Izrel na ndị zoro nʼọhịa kwekọtara na ha ga-eme ka anwụrụ ọkụ dị ukwuu na-ala elu elu site nʼobodo ahụ,
\v 39 ma mgbe ahụ, ndị Izrel ga-ebido ịbọ ọbọ ogbugbu egburu ha.
\p Ndị Benjamin egbuolarị iri ndị Izrel atọ, nʼihi ya ha sịrị, “Anyị na-emeri ha dịka anyị mere nʼagha mbụ.”
\v 40 Ma mgbe anwụrụ ọkụ malitere ịla elu site nʼobodo ahụ, ndị Benjamin lere anya nʼazụ hụ ka anwụrụ ọkụ na-ala elu site nʼakụkụ niile nke obodo ahụ.
\v 41 Mgbe ahụ, ndị Izrel bidoro igbu ha, oke egwu jidere ndị Benjamin nʼihi na ha ghọtara na ịla nʼiyi adakwasịla ha.
\v 42 Ha si nʼihu ndị Izrel gbaa ọsọ, gbaga nʼụzọ gawara nʼọzara, ma ha enweghị ike ịgbanarị agha ahụ. Ndị Izrel si nʼobodo Gibea gbapụta gburu ha nʼebe ahụ.
\v 43 Ha gbara ndị Benjamin gburugburu nʼakụkụ ọwụwa anyanwụ Gibea, gbuo ọtụtụ nʼime ha nʼebe ahụ.
\v 44 Ndị agha Benjamin e gburu nʼagha ụbọchị ahụ dị puku iri na asatọ.
\v 45 Mgbe ha chigharịrị na-agbala nʼụzọ ọzara na-aga nʼebe oke nkume Rimọn dị, ndị Izrel gburu puku ndị agha ise nʼime ha nʼụzọ ahụ. Ha chụgidere ndị Benjamin ọsọ ruo Gidom, gbukwaa puku ndị agha ha abụọ.
\p 
\v 46 Ya mere, ndị Benjamin e gburu nʼagha nʼụbọchị ahụ dị iri puku abụọ, na ise. Ndị a bụ ndị agha mma agha, dike na dimkpa nʼagha.
\v 47 Naanị narị ndị agha isii nʼime ha tụgharịrị gbapụ ọsọ gbalaga nʼọzara, nʼebe nkume Rimọn dị. Ha nọgidere nʼebe ahụ ọnwa anọ.
\v 48 Mgbe ahụ, ndị agha Izrel hapụrụ ha, laghachi azụ, gaa nʼobodo ndị Benjamin niile gbuo ndị niile nọ nʼime ha, igwe anụ ụlọ, na ihe ndị ọzọ niile dị nʼime ha. Obodo niile ha ruru, ha kpọrọ ha ọkụ.
\c 21
\s1 Ndị nwunye ndị ikom Benjamin
\p 
\v 1 Mgbe ndị ikom Izrel niile zukọtara na Mizpa, ha ṅụrụ iyi sị, “O nweghị onye ọbụla nʼime anyị ga-ekwe ka nwoke ọbụla si nʼebo Benjamin lụọ ụmụ anyị ndị inyom.”
\p 
\v 2 Ndị Izrel niile gara Betel, nọdụ ebe ahụ ruo mgbede nʼihu Chineke. Ha welitere olu bee akwa dara ụda.
\v 3 “Ha sịrị, \nd Onyenwe anyị\nd*, Chineke Izrel, gịnị mere ihe dị otu a ji dakwasị Izrel? Gịnị mere a ga-eji na-achọ otu ebo Izrel achọ taa?”
\p 
\v 4 Nʼisi ụtụtụ echi ya, ha biliri ngwangwa rụọ ebe ịchụ aja. Ha chụrụ aja nsure ọkụ, na aja udo nʼebe ahụ.
\p 
\v 5 Emesịa, ha jụrịtara onwe ha ajụjụ sị, “O nwere ebo Izrel na-enweghị onye nọchiri anya ha nʼihu \nd Onyenwe anyị\nd* anyị mgbe anyị zukọrọ na Mizpa?” Nʼihi na ha ṅụrụ iyi kwuo na onye ọbụla jụrụ ịbịa nʼihu \nd Onyenwe anyị\nd* na Mizpa aghaghị ịnwụ.
\p 
\v 6 Ma oke iru ụjụ dị nʼala Izrel dum nʼihi ihe dakwasịrị ụmụnna ha, bụ ndị Benjamin. Ha niile kwuru sị, “Taa, otu ebo Izrel alaala nʼiyi, e kpochapụla ya.
\v 7 Olee otu anyị ga-esi nwetara ndị fọdụrụ nwunye ha ga-alụ ebe anyị ṅụrụ iyi site nʼaha \nd Onyenwe anyị\nd* na anyị agaghị enye ha ụmụ anyị ndị inyom?”
\v 8 Mgbe ahụ, ha jụrụ ajụjụ sị, “O nwere ebo Izrel na-esoghị anyị zukọta mgbe anyị zukọtara nʼihu \nd Onyenwe anyị\nd* na Mizpa?” Ha chọpụtara na o nweghị onye ọbụla si na Jebesh Gilead bịa.
\v 9 Nʼihi na mgbe ha gụrụ ndị zukọrọ ọnụ, ha chọpụtara na o nweghị ndị si Jebesh Gilead bịa.
\p 
\v 10 Ya mere, nzukọ ahụ zipụrụ puku ndị agha iri na abụọ, ndị dị ike nʼetiti ha, ka ha gaa jiri mma agha gbuchapụ mmadụ niile bi na Jebesh Gilead, ndị nwoke, na ndị nwanyị, na ụmụntakịrị.
\v 11 Nke a bụkwa ihe unu ga-eme, “Gbuonụ ndị ikom niile na ụmụ nwanyị niile matarala nwoke.”
\v 12 Ọnụọgụgụ ụmụ agbọghọ na-amabeghị nwoke ha chọtara na Jebesh Gilead dị narị anọ. Ndị agha ahụ kpọtara ha na Shaịlo, nʼime Kenan, ebe ndị Izrel mara ụlọ ikwu ha.
\p 
\v 13 Emesịa, ha zigara ụfọdụ mmadụ ka ha jekwuru ndị agha Benjamin na nkume Rimọn maka ime udo.
\v 14 Mgbe ndị Benjamin lọghachiri, e dunyere ha narị ndị inyom anọ, ndị Jebesh Gilead, bụ ndị e mere ka ha dị ndụ. Ma ụmụ agbọghọ ndị a ezughị ọnụọgụgụ ha niile.
\p 
\v 15 Oge ahụ bụ nnọọ oge iru ụjụ dị ukwuu nʼala Izrel maka ọnọdụ ndị Benjamin, nʼihi na \nd Onyenwe anyị\nd* emeela ka ebo ndị Izrel hapụ izu ezu.
\v 16 Ndị okenye Izrel jụrịtara onwe ha sị, “Gịnị ka anyị ga-eme ịlụtara ụmụnna anyị nwunye ebe ọ bụ na ụmụ agbọghọ ndị Benjamin anwụchaala?
\v 17 Ndị Benjamin fọdụrụ ndụ aghaghị inweta ndị ga-anọchi anya ha,” bụ ihe ha kwuru, “ka otu nʼime ebo Izrel ghara ịbụ ndị e kpochapụrụ ekpochapụ.
\v 18 Ma anyị enweghị ike inye ha ndị nwunye site nʼụmụ anyị ndị inyom, nʼihi na ụmụ Izrel ṅụrụ iyi sị, ‘Onye abụrụ ọnụ ka ọ bụ, bụ onye ọbụla nke nyere onye Benjamin nwunye.’
\v 19 Ma lee, e nwere mmemme \nd Onyenwe anyị\nd* a na-eme afọ niile na Shaịlo, nʼakụkụ ugwu Betel, na mpaghara ọwụwa anyanwụ nke ụzọ ahụ sitere Betel gaa Shekem, na nʼakụkụ ndịda Lebona.”
\p 
\v 20 Ya mere, ha gwara ndị ikom Benjamin, bụ ndị chọrọ nwunye okwu sị ha, “Gaanụ zoo onwe unu nʼubi vaịnị dị nʼagbata ụzọ ahụ,
\v 21 ma na-elepụ anya. Mgbe ụmụ agbọghọ Shaịlo ga-apụta ite egwu ha, sitenụ nʼubi vaịnị gbapụtanụ jide ha, ka onye ọbụla nʼime unu jide otu nwaagbọghọ kpụrụ ya laa nʼala Benjamin, ka ha bụrụ nwunye unu.
\v 22 Ọ bụrụ na nna ha maọbụ ụmụnne ha abịakwute anyị ịjụ ajụjụ banyere ha, anyị ga-agwa ha okwu sị, ‘Biko, gosinụ anyị amara, site nʼịhapụ ha ka ha lụọ ụmụ agbọghọ ahụ, nʼihi na anyị achọtaghị ụmụ agbọghọ ga-ezuru ha niile mgbe anyị gburu ndị niile bi na Jebesh Gilead. O nwekwaghị ụzọ ọzọ unu gaara esi nye ha ụmụ unu ndị nwanyị ghara ịbụ ndị ikpe mara.’ ”
\p 
\v 23 Ya mere, ndị Benjamin mere dịka ndụmọdụ e nyere ha si dị. Onye ọbụla nʼime ha jidere otu nwaagbọghọ nʼike mgbe ha na-ete egwu nʼoge mmemme ahụ ka ọ bụrụ nwunye ya. Ha lara nʼihe nketa ha, wughachi obodo ha, biri nʼime ya.
\p 
\v 24 Mgbe ihe ndị a gasịrị, ụmụ Izrel laghachiri nʼobodo ha, nʼotu nʼotu, onye ọbụla kwa laghachiri nʼebo ya, nʼikwu ya, nʼihe nketa nke aka ya.
\p 
\v 25 Nʼụbọchị ndị a, Izrel enweghị eze na-achị ha.\f + \fr 21:25 \ft \xt Nkp 17:6; 18:1; 19:1\xt*\f* Nʼihi nke a, onye ọbụla na-eme ihe ọbụla ọ chọrọ, na ihe ọbụla dị ya mma nʼanya.\f + \fr 21:25 \ft \xt Dit 12:8; Nkp 17:6\xt*\f*
