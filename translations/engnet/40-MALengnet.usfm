\v 9  \w You|strong="H3605"\w* \w are|strong="H1471"\w* \w bound|strong="H3994"\w* \w for|strong="H3605"\w* \w judgment|strong="H1471"\w* \w because|strong="H3605"\w* \w you|strong="H3605"\w* \w are|strong="H1471"\w* \w robbing|strong="H6906"\w* \w me|strong="H3605"\w* – \w this|strong="H3605"\w* \w whole|strong="H3605"\w* \w nation|strong="H1471"\w* \w is|strong="H3605"\w* guilty.   
\p
\v 10 “\w Bring|strong="H1961"\w* \w the|strong="H3605"\w* \w entire|strong="H3605"\w* \w tithe|strong="H4643"\w* \w into|strong="H1961"\w* \w the|strong="H3605"\w* storehouse \w so|strong="H1961"\w* \w that|strong="H3605"\w* \w there|strong="H1961"\w* \w may|strong="H1961"\w* \w be|strong="H1961"\w* \w food|strong="H2964"\w* \w in|strong="H3068"\w* \w my|strong="H3605"\w* \w temple|strong="H1004"\w*. Test \w me|strong="H4994"\w* \w in|strong="H3068"\w* \w this|strong="H2063"\w* matter,” says \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3605"\w* rules \w over|strong="H3068"\w* \w all|strong="H3605"\w*, “\w to|strong="H5704"\w* see \w if|strong="H1961"\w* \w I|strong="H5704"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w open|strong="H6605"\w* \w for|strong="H5704"\w* \w you|strong="H3605"\w* \w the|strong="H3605"\w* windows \w of|strong="H1004"\w* \w heaven|strong="H8064"\w* \w and|strong="H3068"\w* pour \w out|strong="H7324"\w* \w for|strong="H5704"\w* \w you|strong="H3605"\w* \w a|strong="H3068"\w* \w blessing|strong="H1293"\w* \w until|strong="H5704"\w* \w there|strong="H1961"\w* \w is|strong="H3068"\w* \w no|strong="H3808"\w* \w room|strong="H1004"\w* \w for|strong="H5704"\w* \w it|strong="H1961"\w* \w all|strong="H3605"\w*.  
\v 11  \w Then|strong="H3068"\w* \w I|strong="H3808"\w* \w will|strong="H3068"\w* \w stop|strong="H3808"\w* \w the|strong="H3068"\w* plague \w from|strong="H3068"\w* ruining \w your|strong="H3068"\w* crops, \w and|strong="H3068"\w* \w the|strong="H3068"\w* \w vine|strong="H1612"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w lose|strong="H7921"\w* \w its|strong="H7843"\w* \w fruit|strong="H6529"\w* \w before|strong="H3808"\w* harvest,” says \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H3068"\w* \w all|strong="H7843"\w*.  
\v 12 “\w All|strong="H3605"\w* \w nations|strong="H1471"\w* \w will|strong="H3068"\w* call \w you|strong="H3588"\w* happy, \w for|strong="H3588"\w* \w you|strong="H3588"\w* \w indeed|strong="H3588"\w* \w will|strong="H3068"\w* live \w in|strong="H3068"\w* \w a|strong="H3068"\w* \w delightful|strong="H2656"\w* land,” says \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3605"\w* rules \w over|strong="H3068"\w* \w all|strong="H3605"\w*.   
\s1 Resistance to the Lord through Self-sufficiency  
\p
\v 13 “\w You|strong="H5921"\w* \w have|strong="H3068"\w* criticized \w me|strong="H5921"\w* sharply,” \w says|strong="H1696"\w* \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd*, “\w but|strong="H2388"\w* \w you|strong="H5921"\w* ask, ‘\w How|strong="H4100"\w* \w have|strong="H3068"\w* \w we|strong="H3068"\w* criticized \w you|strong="H5921"\w*?’  
\v 14  \w You|strong="H3588"\w* \w have|strong="H3068"\w* said, ‘\w It|strong="H3588"\w* \w is|strong="H3068"\w* useless \w to|strong="H1980"\w* \w serve|strong="H5647"\w* \w God|strong="H3068"\w*. \w How|strong="H4100"\w* \w have|strong="H3068"\w* \w we|strong="H3068"\w* \w been|strong="H5647"\w* helped \w by|strong="H3068"\w* \w keeping|strong="H8104"\w* \w his|strong="H8104"\w* requirements \w and|strong="H1980"\w* \w going|strong="H1980"\w* \w about|strong="H1980"\w* \w like|strong="H1980"\w* mourners \w before|strong="H6440"\w* \w the|strong="H6440"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H6440"\w* \w all|strong="H6440"\w*?  
\v 15  \w So|strong="H6213"\w* \w now|strong="H6258"\w* \w we|strong="H3068"\w* consider \w the|strong="H6213"\w* \w arrogant|strong="H2086"\w* \w to|strong="H6213"\w* \w be|strong="H1571"\w* happy; \w indeed|strong="H1571"\w*, \w those|strong="H6213"\w* \w who|strong="H1129"\w* \w practice|strong="H6213"\w* \w evil|strong="H6213"\w* \w are|strong="H6213"\w* successful. \w In|strong="H6213"\w* fact, \w those|strong="H6213"\w* \w who|strong="H1129"\w* challenge God \w escape|strong="H4422"\w*!’”   
\p
\v 16  \w Then|strong="H1696"\w* \w those|strong="H8085"\w* \w who|strong="H3068"\w* respected \w the|strong="H6440"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w spoke|strong="H1696"\w* \w to|strong="H1696"\w* \w one|strong="H8034"\w* \w another|strong="H7453"\w*, \w and|strong="H3068"\w* \w the|strong="H6440"\w* \nd \+w Lord|strong="H3068"\+w*\nd* took notice. \w A|strong="H3068"\w* \w scroll|strong="H5612"\w* \w was|strong="H3068"\w* prepared \w before|strong="H6440"\w* \w him|strong="H6440"\w* \w in|strong="H3068"\w* \w which|strong="H3068"\w* \w were|strong="H5612"\w* \w recorded|strong="H3789"\w* \w the|strong="H6440"\w* \w names|strong="H8034"\w* \w of|strong="H3068"\w* \w those|strong="H8085"\w* \w who|strong="H3068"\w* respected \w the|strong="H6440"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w and|strong="H3068"\w* honored \w his|strong="H3068"\w* \w name|strong="H8034"\w*.  
\v 17 “\w They|strong="H3117"\w* \w will|strong="H3068"\w* \w belong|strong="H1961"\w* \w to|strong="H3068"\w* \w me|strong="H5921"\w*,” says \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H5921"\w* \w all|strong="H6213"\w*, “\w in|strong="H5921"\w* \w the|strong="H5921"\w* \w day|strong="H3117"\w* \w when|strong="H1961"\w* \w I|strong="H3117"\w* \w prepare|strong="H6213"\w* \w my|strong="H3068"\w* \w own|strong="H1961"\w* \w special|strong="H5459"\w* property. \w I|strong="H3117"\w* \w will|strong="H3068"\w* \w spare|strong="H2550"\w* \w them|strong="H5921"\w* \w as|strong="H3117"\w* \w a|strong="H3068"\w* \w man|strong="H1121"\w* \w spares|strong="H2550"\w* \w his|strong="H3068"\w* \w son|strong="H1121"\w* \w who|strong="H3068"\w* \w serves|strong="H5647"\w* \w him|strong="H5921"\w*.  
\v 18  \w Then|strong="H7725"\w* \w once|strong="H7725"\w* \w more|strong="H3808"\w* \w you|strong="H7725"\w* \w will|strong="H6662"\w* \w see|strong="H7200"\w* \w that|strong="H7200"\w* \w I|strong="H7200"\w* \w make|strong="H7725"\w* \w a|strong="H3068"\w* distinction between \w the|strong="H7200"\w* \w righteous|strong="H6662"\w* \w and|strong="H7725"\w* \w the|strong="H7200"\w* \w wicked|strong="H7563"\w*, between \w the|strong="H7200"\w* \w one|strong="H3808"\w* \w who|strong="H6662"\w* \w serves|strong="H5647"\w* \w God|strong="H3808"\w* \w and|strong="H7725"\w* \w the|strong="H7200"\w* \w one|strong="H3808"\w* \w who|strong="H6662"\w* \w does|strong="H3808"\w* \w not|strong="H3808"\w*.   
\c 4  
\p
\v 1  “For indeed the day is coming, burning like \w a|strong="H3068"\w* furnace, and all the arrogant evildoers will be chaff. The coming day will burn them up,” says the \nd Lord\nd* who rules over all. “It will not leave even \w a|strong="H3068"\w* root or branch.  
\v 2  But for you who respect my name, the sun of vindication will rise with healing wings, and you will skip about like calves released from the stall.  
\v 3  You will trample on the wicked, for they will be like ashes under the soles of your feet on the day which I am preparing,” says the \nd Lord\nd* who rules over all.   
\s1 Restoration through the Lord  
\p
\v 4 “Remember the law of my servant Moses, to whom at Horeb I gave rules and regulations for all Israel to obey.  
\v 5  Look, I will send you Elijah the prophet before the great and terrible day of the \nd Lord\nd* arrives.  
\v 6  He will encourage fathers and their children to return to me, so that I will not come and strike the earth with judgment.”   