\p
\v 8  \w On|strong="H6440"\w* \w the|strong="H6440"\w* next \w day|strong="H4872"\w* \w Moses|strong="H4872"\w* \w went|strong="H4872"\w* into \w the|strong="H6440"\w* tent \w of|strong="H6440"\w* \w the|strong="H6440"\w* testimony – \w and|strong="H4872"\w* \w the|strong="H6440"\w* staff \w of|strong="H6440"\w* Aaron \w for|strong="H6440"\w* \w the|strong="H6440"\w* house \w of|strong="H6440"\w* Levi \w had|strong="H4872"\w* sprouted, \w and|strong="H4872"\w* \w brought|strong="H4872"\w* \w forth|strong="H6440"\w* buds, \w and|strong="H4872"\w* produced blossoms, \w and|strong="H4872"\w* yielded almonds!  
