\p
\v 24 \wj Por tanto Yo los \+w esparciré|strong="H6327"\+w* como \+w el|strong="H5674"\+w* pasto seco que \+w pasa|strong="H5674"\+w* con \+w el|strong="H5674"\+w* \+w viento|strong="H7307"\+w* del \+w desierto|strong="H4057"\+w*.\wj*  
\v 25 \wj \+w Ésta|strong="H2088"\+w* \+w es|strong="H2088"\+w* tu \+w parte|strong="H4490"\+w*, la cantidad \+w que|strong="H2088"\+w* medí para ti,\wj* \w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \wj porque te \+w olvidaste|strong="H7911"\+w* \+w de|strong="H7911"\+w* Mí y confiaste en la \+w mentira|strong="H8267"\+w*.\wj*  
\v 26 \wj \+w Por|strong="H5921"\+w* \+w tanto|strong="H5921"\+w* Yo \+w también|strong="H1571"\+w* levantaré tus faldas \+w y|strong="H1571"\+w* \+w las|strong="H5921"\+w* alzaré \+w sobre|strong="H5921"\+w* tu \+w cara|strong="H6440"\+w*, \+w para|strong="H5921"\+w* \+w que|strong="H5921"\+w* sea vista tu vergüenza,\wj*  
\v 27 \wj tus adulterios, tus lujuriosos relinchos, \+w y|strong="H5921"\+w* \+w la|strong="H5921"\+w* perversidad \+w de|strong="H5921"\+w* tu \+w fornicación|strong="H2184"\+w*. \+w Vi|strong="H7200"\+w* todas tus repugnancias \+w sobre|strong="H5921"\+w* \+w las|strong="H5921"\+w* colinas \+w y|strong="H5921"\+w* \+w en|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w campo|strong="H7704"\+w*. ¡Ay \+w de|strong="H5921"\+w* \+w ti|strong="H5921"\+w*, Jerusalén! ¿\+w Hasta|strong="H5921"\+w* \+w cuándo|strong="H4970"\+w* \+w no|strong="H3808"\+w* \+w te|strong="H5921"\+w* purificas?\wj*   
\c 14  
\s1 Una espantosa sequía  
\p
\v 1 \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H5921"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w con|strong="H5921"\w* \w motivo|strong="H1697"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* sequía:  
\v 2 \wj \+w Judá|strong="H3063"\+w* se enlutó, y sus \+w puertas|strong="H8179"\+w* se despoblaron. Ellos se sientan consternados en tierra y lamentan. \+w Subió|strong="H5927"\+w* el clamor de Jerusalén.\wj*  
\v 3 \wj \+w Los|strong="H5921"\+w* nobles envían \+w a|strong="H3068"\+w* sus esclavos \+w por|strong="H5921"\+w* \+w agua|strong="H4325"\+w*. Van \+w a|strong="H3068"\+w* \+w las|strong="H5921"\+w* cisternas, pero \+w no|strong="H3808"\+w* encuentran \+w agua|strong="H4325"\+w*. \+w Vuelven|strong="H7725"\+w* \+w avergonzados|strong="H3637"\+w* \+w y|strong="H5921"\+w* confusos \+w con|strong="H5921"\+w* \+w los|strong="H5921"\+w* cántaros \+w vacíos|strong="H7387"\+w*. Cubren sus \+w cabezas|strong="H7218"\+w*.\wj*  
\v 4 \wj \+w Porque|strong="H3588"\+w* \+w se|strong="H1961"\+w* resquebrajó \+w el|strong="H3588"\+w* suelo, \+w pues|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w hay|strong="H1961"\+w* \+w lluvia|strong="H1653"\+w* \+w en|strong="H3588"\+w* \+w la|strong="H3588"\+w* tierra. \+w Los|strong="H1961"\+w* labradores \+w están|strong="H1961"\+w* confusos. Cubren sus \+w cabezas|strong="H7218"\+w*.\wj*  
\v 5 \wj Hasta \+w la|strong="H1571"\+w* venada al parir abandona \+w su|strong="H3588"\+w* cría \+w en|strong="H3588"\+w* \+w el|strong="H3588"\+w* \+w campo|strong="H7704"\+w*, \+w porque|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w hay|strong="H1961"\+w* \+w hierba|strong="H1877"\+w*.\wj*  
\v 6 \wj \+w Los|strong="H5921"\+w* asnos monteses \+w se|strong="H5921"\+w* paran \+w en|strong="H5921"\+w* \+w las|strong="H5921"\+w* alturas \+w y|strong="H3588"\+w* aspiran \+w el|strong="H5921"\+w* aire \+w como|strong="H3588"\+w* chacales. Sus \+w ojos|strong="H5869"\+w* \+w se|strong="H5921"\+w* debilitan \+w porque|strong="H3588"\+w* \+w no|strong="H3588"\+w* hay \+w hierba|strong="H6212"\+w*. \wj*   
\p
\v 7 \w Aunque|strong="H3588"\w* nuestras \w iniquidades|strong="H5771"\w* \w testifican|strong="H6030"\w* contra nosotros, actúa, oh \nd \+w Yavé|strong="H3068"\+w*\nd*, \w por|strong="H3588"\w* amor \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w Nombre|strong="H8034"\w*. \w Ciertamente|strong="H3588"\w* nuestras \w rebeliones|strong="H4878"\w* se multiplicaron \w y|strong="H3588"\w* \w pecamos|strong="H2398"\w* contra Ti.  
\v 8 \w Oh|strong="H4100"\w* \w Esperanza|strong="H4723"\w* \w de|strong="H6256"\w* \w Israel|strong="H3478"\w*, su \w Salvador|strong="H3467"\w* en \w tiempo|strong="H6256"\w* \w de|strong="H6256"\w* \w aflicción|strong="H6869"\w*. ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w eres|strong="H1961"\w* \w como|strong="H4100"\w* forastero en la tierra, \w como|strong="H4100"\w* caminante \w que|strong="H4100"\w* levanta su tienda solo \w para|strong="H1961"\w* pernoctar?  
\v 9 ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w te|strong="H5921"\w* muestras \w como|strong="H4100"\w* un \w hombre|strong="H1368"\w* espantado, \w y|strong="H5921"\w* \w como|strong="H4100"\w* \w valiente|strong="H1368"\w* incapaz \w de|strong="H5921"\w* librar? Pero Tú, \w oh|strong="H4100"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, estás \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* \w nosotros|strong="H5921"\w*. Tu \w Nombre|strong="H8034"\w* \w es|strong="H1961"\w* \w invocado|strong="H7121"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*. \w No|strong="H3808"\w* \w nos|strong="H5921"\w* desampares.   
\p
\v 10 Con respecto \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj \+w Se|strong="H3808"\+w* deleitaron en vagar \+w y|strong="H3541"\+w* \+w no|strong="H3808"\+w* dieron reposo \+w a|strong="H3068"\+w* sus \+w pies|strong="H7272"\+w*. \+w Por|strong="H2088"\+w* \+w tanto|strong="H3651"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w no|strong="H3808"\+w* \+w se|strong="H3808"\+w* complace en ellos. \+w Ahora|strong="H6258"\+w* recuerda su \+w iniquidad|strong="H5771"\+w* \+w y|strong="H3541"\+w* castiga sus \+w pecados|strong="H2403"\+w*.\wj*   
\p
\v 11 \w Y|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* me dijo: \wj No intercedas \+w por|strong="H1157"\+w* \+w este|strong="H2088"\+w* \+w pueblo|strong="H5971"\+w*.\wj*  
\v 12 \wj \+w Cuando|strong="H3588"\+w* ayunen, \+w no|strong="H3588"\+w* \+w escucharé|strong="H8085"\+w* \+w su|strong="H3588"\+w* \+w clamor|strong="H7440"\+w*. \+w Cuando|strong="H3588"\+w* ofrezcan \+w holocaustos|strong="H5930"\+w* \+w y|strong="H3588"\+w* \+w ofrenda|strong="H4503"\+w*, \+w no|strong="H3588"\+w* \+w los|strong="H3588"\+w* aceptaré, \+w sino|strong="H3588"\+w* \+w los|strong="H3588"\+w* consumiré \+w con|strong="H3588"\+w* \+w espada|strong="H2719"\+w*, \+w hambre|strong="H7458"\+w* \+w y|strong="H3588"\+w* \+w pestilencia|strong="H1698"\+w*.\wj*   
\p
\v 13 \w Entonces|strong="H3588"\w* dije: Oh, \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd*. \w Mira|strong="H7200"\w*, \w los|strong="H1961"\w* \w profetas|strong="H5030"\w* les dicen: \w No|strong="H3808"\w* \w verán|strong="H7200"\w* \w espada|strong="H2719"\w* \w ni|strong="H3808"\w* \w tendrán|strong="H1961"\w* \w hambre|strong="H7458"\w*, \w sino|strong="H3588"\w* les \w daré|strong="H5414"\w* \w paz|strong="H7965"\w* duradera \w en|strong="H3588"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*.   
\p
\v 14 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* me respondió: \wj \+w Los|strong="H1992"\+w* \+w profetas|strong="H5030"\+w* \+w profetizan|strong="H5012"\+w* \+w mentira|strong="H8267"\+w* en mi \+w Nombre|strong="H8034"\+w*. \+w No|strong="H3808"\+w* \+w los|strong="H1992"\+w* \+w envié|strong="H7971"\+w*, \+w ni|strong="H3808"\+w* \+w les|strong="H1992"\+w* \+w di|strong="H1696"\+w* \+w orden|strong="H6680"\+w*, \+w ni|strong="H3808"\+w* \+w les|strong="H1992"\+w* \+w hablé|strong="H1696"\+w*. \+w Les|strong="H1992"\+w* \+w profetizan|strong="H5012"\+w* \+w visión|strong="H2377"\+w* \+w mentirosa|strong="H8267"\+w*, brujería, \+w vanidad|strong="H8267"\+w* y \+w engaño|strong="H8267"\+w* de \+w su|strong="H1992"\+w* \+w corazón|strong="H3820"\+w*.\wj*  
\v 15 \wj \+w Por|strong="H5921"\+w* \+w tanto|strong="H3651"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* dice \+w a|strong="H3068"\+w* \+w los|strong="H1992"\+w* \+w profetas|strong="H5030"\+w* \+w que|strong="H3808"\+w* \+w profetizan|strong="H5012"\+w* \+w en|strong="H5921"\+w* \+w mi|strong="H5921"\+w* \+w Nombre|strong="H8034"\+w*, \+w a|strong="H3068"\+w* \+w los|strong="H1992"\+w* cuales Yo \+w no|strong="H3808"\+w* \+w envié|strong="H7971"\+w*. \+w Ellos|strong="H1992"\+w* dicen: \+w No|strong="H3808"\+w* \+w habrá|strong="H1961"\+w* \+w espada|strong="H2719"\+w* \+w ni|strong="H3808"\+w* hambruna \+w en|strong="H5921"\+w* \+w esta|strong="H2063"\+w* tierra. \+w Pues|strong="H3651"\+w* \+w tales|strong="H3651"\+w* \+w profetas|strong="H5030"\+w* perecerán \+w a|strong="H3068"\+w* \+w espada|strong="H2719"\+w* \+w y|strong="H5921"\+w* \+w de|strong="H5921"\+w* \+w hambre|strong="H7458"\+w*.\wj*  
\v 16 \wj \+w El|strong="H5921"\+w* \+w pueblo|strong="H5971"\+w* \+w al|strong="H5921"\+w* cual \+w ellos|strong="H1992"\+w* \+w profetizan|strong="H5012"\+w* \+w será|strong="H1961"\+w* \+w echado|strong="H7993"\+w* \+w en|strong="H5921"\+w* \+w las|strong="H1992"\+w* \+w calles|strong="H2351"\+w* \+w de|strong="H5921"\+w* Jerusalén \+w por|strong="H5921"\+w* \+w causa|strong="H6440"\+w* \+w del|strong="H5921"\+w* \+w hambre|strong="H7458"\+w* \+w y|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w espada|strong="H2719"\+w*. \+w No|strong="H1961"\+w* \+w habrá|strong="H1961"\+w* quien \+w los|strong="H1992"\+w* \+w entierre|strong="H6912"\+w* \+w a|strong="H3068"\+w* \+w ellos|strong="H1992"\+w*, ni \+w a|strong="H3068"\+w* \+w sus|strong="H1992"\+w* esposas, ni \+w a|strong="H3068"\+w* \+w sus|strong="H1992"\+w* \+w hijos|strong="H1121"\+w*, ni \+w a|strong="H3068"\+w* \+w sus|strong="H1992"\+w* \+w hijas|strong="H1323"\+w*, \+w porque|strong="H5921"\+w* \+w derramaré|strong="H8210"\+w* \+w su|strong="H1992"\+w* perversidad \+w sobre|strong="H5921"\+w* \+w ellos|strong="H1992"\+w*.\wj*   
\p
\v 17 \wj \+w Diles|strong="H1697"\+w* \+w esta|strong="H2088"\+w* \+w Palabra|strong="H1697"\+w*: Mis \+w ojos|strong="H5869"\+w* derramen \+w lágrimas|strong="H1832"\+w* \+w noche|strong="H3915"\+w* \+w y|strong="H3588"\+w* \+w día|strong="H3119"\+w*, \+w y|strong="H3588"\+w* \+w no|strong="H3588"\+w* \+w cesen|strong="H1820"\+w*. \+w Porque|strong="H3588"\+w* \+w la|strong="H3588"\+w* \+w virgen|strong="H1330"\+w* \+w hija|strong="H1323"\+w* \+w de|strong="H3588"\+w* mi \+w pueblo|strong="H5971"\+w* \+w está|strong="H2088"\+w* \+w quebrantada|strong="H7665"\+w* \+w con|strong="H3588"\+w* \+w gran|strong="H1419"\+w* \+w quebranto|strong="H7665"\+w* \+w por|strong="H3588"\+w* un golpe \+w muy|strong="H3966"\+w* doloroso.\wj*  
\v 18 \wj \+w Si|strong="H3588"\+w* \+w salgo|strong="H3318"\+w* al \+w campo|strong="H7704"\+w*, ahí \+w están|strong="H2009"\+w* \+w los|strong="H3588"\+w* \+w muertos|strong="H2491"\+w* \+w a|strong="H3068"\+w* \+w espada|strong="H2719"\+w*. \+w Si|strong="H3588"\+w* entro \+w en|strong="H3588"\+w* \+w la|strong="H1571"\+w* \+w ciudad|strong="H5892"\+w*, ahí \+w están|strong="H2009"\+w* \+w los|strong="H3588"\+w* \+w enfermos|strong="H8463"\+w* \+w a|strong="H3068"\+w* causa del \+w hambre|strong="H7458"\+w*. Tanto \+w el|strong="H3588"\+w* \+w profeta|strong="H5030"\+w* \+w como|strong="H3588"\+w* \+w el|strong="H3588"\+w* \+w sacerdote|strong="H3548"\+w* vagan \+w por|strong="H3588"\+w* \+w la|strong="H1571"\+w* tierra \+w y|strong="H1571"\+w* \+w no|strong="H3808"\+w* \+w entendieron|strong="H3045"\+w*. \wj*   
\p
\v 19 ¿\w Desechaste|strong="H3988"\w* completamente \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*? ¿\w Aborreció|strong="H3988"\w* tu \w alma|strong="H5315"\w* \w a|strong="H3068"\w* \w Sion|strong="H6726"\w*? ¿\w Por|strong="H4069"\w* \w qué|strong="H6256"\w* nos \w heriste|strong="H5221"\w* sin \w remedio|strong="H4832"\w*? \w Esperábamos|strong="H6960"\w* \w paz|strong="H7965"\w*, pero no hay bienestar, \w tiempo|strong="H6256"\w* \w de|strong="H6256"\w* sanidad. \w Aquí|strong="H2009"\w* está el terror.  
\v 20 \w Reconocemos|strong="H3045"\w*, oh \nd \+w Yavé|strong="H3068"\+w*\nd*, nuestras perversidades \w y|strong="H3588"\w* las \w iniquidades|strong="H5771"\w* \w de|strong="H3588"\w* nuestros antepasados, \w porque|strong="H3588"\w* \w pecamos|strong="H2398"\w* contra Ti.  
\v 21 \w Por|strong="H4616"\w* amor \w a|strong="H3068"\w* tu \w Nombre|strong="H8034"\w*, no \w deseches|strong="H5006"\w* ni deshonres tu \w glorioso|strong="H3519"\w* \w trono|strong="H3678"\w*. \w Acuérdate|strong="H2142"\w*, no anules tu \w Pacto|strong="H1285"\w* con nosotros.  
\v 22 \w Entre|strong="H3808"\w* \w los|strong="H3605"\w* ídolos\f + \fr 14:22 \ft Lit. las vanidades. \f* \w de|strong="H3588"\w* \w los|strong="H3605"\w* gentiles, ¿\w hay|strong="H3426"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* \w hagan|strong="H6213"\w* llover? ¿\w O|strong="H3068"\w* \w los|strong="H3605"\w* \w cielos|strong="H8064"\w* \w dar|strong="H5414"\w* \w lluvias|strong="H7241"\w*? ¿Oh \nd \+w Yavé|strong="H3068"\+w*\nd*, \w no|strong="H3808"\w* \w eres|strong="H1931"\w* \w Tú|strong="H6213"\w* nuestro \nd ʼElohim\nd*? Esperaremos \w en|strong="H3588"\w* Ti, \w porque|strong="H3588"\w* \w Tú|strong="H6213"\w* \w haces|strong="H6213"\w* \w todas|strong="H3605"\w* \w estas|strong="H6213"\w* cosas.   
\c 15  
\s1 Una ira implacable  
\p
\v 1 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* \w me|strong="H5921"\w* dijo: \wj Aunque \+w Moisés|strong="H4872"\+w* \+w y|strong="H5921"\+w* \+w Samuel|strong="H8050"\+w* \+w se|strong="H5921"\+w* coloquen \+w delante|strong="H6440"\+w* \+w de|strong="H5921"\+w* \+w Mí|strong="H5921"\+w*, \+w no|strong="H5921"\+w* \+w me|strong="H5921"\+w* conmoveré \+w por|strong="H5921"\+w* \+w este|strong="H2088"\+w* \+w pueblo|strong="H5971"\+w*. \+w Échalos|strong="H7971"\+w*, \+w que|strong="H5921"\+w* \+w salgan|strong="H3318"\+w* \+w de|strong="H5921"\+w* \+w mi|strong="H5921"\+w* \+w Presencia|strong="H6440"\+w*.\wj*  
\v 2 \wj \+w Si|strong="H3588"\+w* \+w te|strong="H3588"\+w* preguntan: ¿\+w A|strong="H3068"\+w* dónde iremos? Les dirás: \+nd \+w Yavé|strong="H3068"\+w*\+nd* dice \+w así|strong="H3541"\+w*: \+w Los|strong="H1961"\+w* \+w que|strong="H3588"\+w* \+w a|strong="H3068"\+w* \+w muerte|strong="H4194"\+w*, \+w a|strong="H3068"\+w* \+w muerte|strong="H4194"\+w*, \+w los|strong="H1961"\+w* \+w que|strong="H3588"\+w* \+w a|strong="H3068"\+w* \+w espada|strong="H2719"\+w*, \+w a|strong="H3068"\+w* \+w espada|strong="H2719"\+w*, \+w los|strong="H1961"\+w* \+w que|strong="H3588"\+w* \+w a|strong="H3068"\+w* \+w hambre|strong="H7458"\+w*, \+w a|strong="H3068"\+w* \+w hambre|strong="H7458"\+w*, \+w los|strong="H1961"\+w* \+w que|strong="H3588"\+w* \+w a|strong="H3068"\+w* \+w cautiverio|strong="H7628"\+w*, \+w a|strong="H3068"\+w* \+w cautiverio|strong="H7628"\+w*.\wj*   
\p
\v 3 \wj \+w Enviaré|strong="H6485"\+w* \+w sobre|strong="H5921"\+w* \+w ellos|strong="H5921"\+w* cuatro clases \+w de|strong="H5921"\+w* castigo, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \wj \+w la|strong="H5921"\+w* \+w espada|strong="H2719"\+w* \+w para|strong="H5921"\+w* matar, \+w los|strong="H5921"\+w* \+w perros|strong="H3611"\+w* \+w para|strong="H5921"\+w* destrozar, \+w las|strong="H5921"\+w* \+w aves|strong="H5775"\+w* \+w del|strong="H5921"\+w* \+w cielo|strong="H8064"\+w* \+w y|strong="H5921"\+w* \+w las|strong="H5921"\+w* bestias \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra \+w para|strong="H5921"\+w* devorar \+w y|strong="H5921"\+w* \+w destruir|strong="H7843"\+w*.\wj*  
\v 4 \wj \+w Los|strong="H1121"\+w* \+w entregaré|strong="H5414"\+w* \+w como|strong="H5921"\+w* objeto \+w de|strong="H5921"\+w* horror \+w entre|strong="H5921"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H1121"\+w* \+w reinos|strong="H4467"\+w* \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra, \+w a|strong="H3068"\+w* causa \+w de|strong="H5921"\+w* \+w Manasés|strong="H4519"\+w*, \+w hijo|strong="H1121"\+w* \+w de|strong="H5921"\+w* Ezequías, \+w rey|strong="H4428"\+w* \+w de|strong="H5921"\+w* \+w Judá|strong="H3063"\+w*, \+w por|strong="H5921"\+w* \+w lo|strong="H5921"\+w* \+w que|strong="H5921"\+w* \+w él|strong="H5921"\+w* \+w hizo|strong="H6213"\+w* \+w en|strong="H5921"\+w* Jerusalén.\wj*   
\p
\v 5 \wj \+w Oh|strong="H4310"\+w* Jerusalén, \+w en|strong="H5921"\+w* verdad, ¿\+w quién|strong="H4310"\+w* tendrá compasión \+w de|strong="H5921"\+w* \+w ti|strong="H5921"\+w*? ¿\+w Quién|strong="H4310"\+w* llorará \+w por|strong="H5921"\+w* \+w ti|strong="H5921"\+w*? ¿\+w Quién|strong="H4310"\+w* \+w se|strong="H5921"\+w* \+w desviará|strong="H5493"\+w* \+w para|strong="H5921"\+w* preguntar \+w con|strong="H5921"\+w* respecto \+w a|strong="H3068"\+w* \+w ti|strong="H5921"\+w*?\wj*  
\v 6 \wj Tú \+w me|strong="H5921"\+w* abandonaste, \+w te|strong="H5921"\+w* devolviste, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \wj \+w Por|strong="H5921"\+w* \+w tanto|strong="H5921"\+w*, Yo extiendo \+w mi|strong="H5921"\+w* \+w mano|strong="H3027"\+w* \+w contra|strong="H5921"\+w* \+w ti|strong="H5921"\+w* \+w y|strong="H5921"\+w* \+w te|strong="H5921"\+w* \+w destruiré|strong="H7843"\+w*. Estoy \+w cansado|strong="H3811"\+w* \+w de|strong="H5921"\+w* compadecerme.\wj*  
\v 7 \wj Los \+w aventaré|strong="H2219"\+w* con un aventador hasta las \+w puertas|strong="H8179"\+w* \+w de|strong="H5971"\+w* la tierra, y los privaré \+w de|strong="H5971"\+w* hijos. Destruiré \+w a|strong="H3068"\+w* mi \+w pueblo|strong="H5971"\+w*, \+w porque|strong="H3808"\+w* \+w no|strong="H3808"\+w* \+w se|strong="H3808"\+w* devolvieron \+w de|strong="H5971"\+w* sus \+w caminos|strong="H1870"\+w*.\wj*  
\v 8 \wj \+w Sus|strong="H1992"\+w* viudas \+w serán|strong="H1992"\+w* \+w más|strong="H5921"\+w* \+w que|strong="H5921"\+w* \+w la|strong="H5921"\+w* arena \+w del|strong="H5921"\+w* \+w mar|strong="H3220"\+w*. Traeré \+w al|strong="H5921"\+w* destructor \+w contra|strong="H5921"\+w* \+w ellos|strong="H1992"\+w* \+w en|strong="H5921"\+w* pleno día, \+w contra|strong="H5921"\+w* \+w la|strong="H5921"\+w* madre \+w y|strong="H5921"\+w* \+w contra|strong="H5921"\+w* \+w los|strong="H1992"\+w* hijos. Destruiré \+w a|strong="H3068"\+w* \+w mi|strong="H5921"\+w* \+w pueblo|strong="H1992"\+w* \+w porque|strong="H5921"\+w* \+w no|strong="H5921"\+w* regresaron \+w de|strong="H5921"\+w* \+w sus|strong="H1992"\+w* caminos.\wj*  
\v 9 \wj La \+w que|strong="H7651"\+w* \+w dio|strong="H5414"\+w* \+w a|strong="H3068"\+w* luz \+w siete|strong="H7651"\+w* desfallecerá y exhalará su \+w alma|strong="H5315"\+w*. Su \+w sol|strong="H8121"\+w* se ocultará cuando sea \+w aún|strong="H5750"\+w* \+w de|strong="H6440"\+w* \+w día|strong="H3119"\+w*. \+w Será|strong="H5414"\+w* avergonzada y confundida. \+w Y|strong="H3068"\+w* lo \+w que|strong="H7651"\+w* quede lo \+w entregaré|strong="H5414"\+w* \+w a|strong="H3068"\+w* la \+w espada|strong="H2719"\+w* \+w de|strong="H6440"\+w* sus enemigos, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 10 ¡Ay \w de|strong="H3588"\w* mí, madre mía, \w que|strong="H3588"\w* \w me|strong="H3588"\w* diste \w a|strong="H3068"\w* luz \w como|strong="H3588"\w* varón \w de|strong="H3588"\w* \w contienda|strong="H7379"\w* \w y|strong="H3588"\w* hombre \w de|strong="H3588"\w* discordia \w para|strong="H3588"\w* \w toda|strong="H3605"\w* esta tierra! \w Ni|strong="H3808"\w* presté \w ni|strong="H3808"\w* \w me|strong="H3588"\w* prestaron, \w pero|strong="H3588"\w* \w todos|strong="H3605"\w* \w me|strong="H3588"\w* maldicen.  
