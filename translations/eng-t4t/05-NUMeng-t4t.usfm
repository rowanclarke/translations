\v 45 \w They|strong="H3068"\w* \w were|strong="H1121"\w* \w the|strong="H5921"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Merari|strong="H4847"\w* \w who|strong="H3068"\w* \add were able to\add* \w work|strong="H3027"\w*. Aaron \w and|strong="H1121"\w* \w Moses|strong="H4872"\w*/\w I|strong="H5921"\w* \w counted|strong="H6485"\w* \w them|strong="H5921"\w* \w as|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w had|strong="H3068"\w* \w commanded|strong="H6310"\w* \w Moses|strong="H4872"\w*/\w me|strong="H5921"\w*.
\p 
