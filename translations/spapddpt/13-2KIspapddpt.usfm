\v 20 \w Cuando|strong="H1961"\w* llegaron \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w*, \w sucedió|strong="H1961"\w* \w que|strong="H1961"\w* Eliseo dijo: Oh \nd \w Yavé|strong="H3068"\w*\nd*, \w abre|strong="H6491"\w* \w los|strong="H1961"\w* \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* éstos \w para|strong="H1961"\w* \w que|strong="H1961"\w* puedan \w mirar|strong="H7200"\w*. \w Y|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w abrió|strong="H6491"\w* sus \w ojos|strong="H5869"\w*, y \w miraron|strong="H7200"\w*. \w Ciertamente|strong="H2009"\w* \w estaban|strong="H1961"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H5869"\w* \w Samaria|strong="H8111"\w*.
