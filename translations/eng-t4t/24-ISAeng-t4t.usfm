\q1
\v 5 \w But|strong="H1961"\w*, \w suddenly|strong="H6597"\w* \w your|strong="H1961"\w* \w enemies|strong="H2114"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* blown \w away|strong="H5674"\w* \w like|strong="H1961"\w* \w dust|strong="H1851"\w*;  
\q1 \w their|strong="H1961"\w* armies \w will|strong="H1961"\w* disappear  
