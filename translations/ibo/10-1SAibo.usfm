\id 1SA - Biblica® Open Igbo Contemporary Bible 2020 
\h 1 Samuel 
\toc1 1 Samuel 
\toc2 1 Samuel 
\toc3 1Sa 
\mt1 1 Samuel 
\c 1  
\s1 Ọmụmụ Samuel 
\p  
\v 1 O nwere otu nwoke onye Zuf, si na Ramataim, nʼala ugwu ugwu Ifrem. Aha ya bụ Elkena nwa Jeroham, nwa Elihu, nwa Tohu, nwa Zuf, onye Ifrem.  
\v 2 Elkena lụrụ ndị inyom abụọ, aha nke mbụ bụ Hana, ebe aha nke abụọ bụ Penina. Penina nwere ụmụ, ma Hana enweghị nwa. 
\p  
\v 3 Kwa afọ, nwoke a na-esi nʼobodo ya gaa Shaịlo ife ofufe na ịchụrụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile aja. Ọ bụ nʼebe ahụ ka ụmụ ndị ikom abụọ Elayị a na-akpọ Hofni na Finehaz, bụ ndị nchụaja \nd Onyenwe anyị\nd* nọ.\f + \fr 1:3 \ft Onye Izrel ọbụla kwesiri ịga nʼihu Onyenwe anyị maka ife ofufe, ugboro atọ kwa afọ. \xt Dit 16:16-17; Ọpụ 23:14-19\ft  Ebe ụlọ nzute na igbe ọgbụgba ndụ ahụ dị, bụ ihe dịka iri kilomita atọ nʼebe ugwu ugwu Jerusalem. \xt 1Sa 3:3; Jos 18:1\f* 
\v 4 Nʼụbọchị ọbụla Elkena na-achụ aja ya, ọ na-ekenye Penina na ụmụ ya ndị ikom na ndị inyom ọtụtụ oke site nʼanụ o ji chụọ aja.  
\v 5 Ma ọ na-enye Hana oke mmadụ abụọ, nʼihi na ọ hụrụ ya nʼanya, ọ bụ ezie na \nd Onyenwe anyị\nd* mechiri akpanwa ya.  
\v 6 Ma Penina na-eme ka obi jọọ Hana njọ karịa, site nʼikpasu ya iwe, nʼihi na \nd Onyenwe anyị\nd* mechiri akpanwa ya.  
\v 7 Ihe ndị a na-eme kwa afọ. Penina na-akwa Hana emo, na-achị ya ọchị oge niile ha gara nʼụlọ \nd Onyenwe anyị\nd*, si otu a na-eme ka ọ na-akwa akwa, gharakwa iri nri.  
\v 8 Mgbe Hana bidoro ịkwa akwa otu a, Elkena na-ajụ ya sị, “Hana, ọ bụ gịnị mere i ji na-akwa akwa? Gịnị mere ị naghị eri nri? Gịnị mere obi ji ajọ gị njọ? Ọ bụ na mụ adịghị gị mma karịa ụmụ ndị ikom iri nye gị?” 
\p  
\v 9 Otu ụbọchị mgbe ha risiri nri, ṅụọkwa ihe ọṅụṅụ na Shaịlo, Hana biliri ọtọ. Nʼoge a, Elayị onye nchụaja nọdụrụ ala nʼoche ya nʼakụkụ ọnụ ụzọ ụlọ \nd Onyenwe anyị\nd*.  
\v 10 Nʼọnọdụ obi mwute Hana kwara akwa, kpee ekpere, kpọkuo \nd Onyenwe anyị\nd*.  
\v 11 O kwere nkwa sị, “O! \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, ọ bụrụ na ị ga-elekwasị anya na nhụju anya nke ohu gị nwanyị ma cheta m, ghara ichefu ohu gị nwanyị, ma nye ya nwa nwoke, mgbe ahụ, aga m enyeghachi ya \nd Onyenwe anyị\nd* ogologo ụbọchị niile nke ndụ ya. Agụba agakwaghị aga nʼisi ya mgbe ọbụla.” 
\p  
\v 12 Mgbe ọ nọgidere na-ekpe ekpere nye \nd Onyenwe anyị\nd*, Elayị nọ na-ele ya anya nʼọnụ.  
\v 13 Ka Hana nọ na-ekpe ekpere nʼobi ya, naanị egbugbere ọnụ ya na-emegharị emegharị, ma enweghị onye na-anụ olu ya. Mgbe ahụ, Elayị chere nʼobi ya na ọ bụ nwanyị mmanya na-egbu.  
\v 14 Elayị sịrị ya, “Ruo ole mgbe ka ị ga-akwụsị ịṅụbiga mmanya oke? Si nʼebe mmanya dị wezuga onwe gị!” 
\p  
\v 15 Ma Hana zara sị ya, “Mba, onyenwe m, aṅụghị m mmanya ọbụla! Kama abụ m nwanyị obi ya dị ilu nke ukwuu. Anọ m na-ekwupụtara \nd Onyenwe anyị\nd* ihe dị m nʼobi.  
\v 16 Biko agụla ohu gị nwanyị dịka onye ajọ omume. Esi m nʼobi mwute na-akwasara \nd Onyenwe anyị\nd* ụwa m.” 
\p  
\v 17 Elayị zara sị ya, “Laa nʼudo, ka Chineke Izrel mezuoro gị dịka arịrịọ gị niile si dị.” 
\p  
\v 18 Hana zara sị, “Ka m bụrụ onye si nʼaka gị nata ihuọma.” O jiri obi ụtọ laghachi, malitekwa iri nri ya. Ihu ya agbarụkwaghị ọzọ. 
\p  
\v 19 Nʼisi ụtụtụ echi ya, ha biliri kpọọ isiala nʼihu \nd Onyenwe anyị\nd*, mgbe ahụ, ha laghachiri nʼụlọ ha dị na Rema. Mgbe ha laruru, Elkena bakwuru nwunye ya Hana, \nd Onyenwe anyị\nd* chetakwara ya.  
\v 20 Mgbe oge ruru, o mere ka Hana tụrụ ime, mụọ nwa nwoke. Ọ gụrụ ya Samuel, nʼihi na ọ sịrị, “Arịrịọ m \nd Onyenwe anyị\nd* maka ya.” 
\s1 Hana edoo Samuel nsọ 
\p  
\v 21 Mgbe di ya, bụ Elkena na ndị ezinaụlọ ya gara Shaịlo ịchụrụ \nd Onyenwe anyị\nd* aja nke afọ ahụ, na ịchụkwa aja metụtara nkwa dị iche nke o kwere \nd Onyenwe anyị\nd*,  
\v 22 Hana esoghị ha, ọ gwara di ya, “Mgbe nwantakịrị a kwụsịrị ịṅụ ara,\f + \fr 1:22 \ft Nʼoge ochie, adịghị anapụ ụmụntakịrị ara ọsịịsọ, kama ọ bụ mgbe ha gbara afọ atọ maọbụ karịa.\f* ka m duru ya ga chee ya nʼihu \nd Onyenwe anyị\nd*, ọ ga-ebikwa nʼebe ahụ ruo mgbe ebighị ebi.” 
\p  
\v 23 Elkena bụ di ya sịrị ya, “Mee ihe ọbụla i chere kwesiri ekwesi. Nọdụ ruo mgbe ọ hapụrụ ịṅụ ara, ma ka \nd Onyenwe anyị\nd* mezuo okwu ya.” Hana nọgidere nʼụlọ tutu ruo mgbe ọ zụlitere nwantakịrị ahụ, kwụsị ya ịṅụ ara. 
\p  
\v 24 Mgbe ọ kwụsịrị nwantakịrị ahụ ịṅụ ara, nwantakịrị ahụ ka dị ntakịrị. Ma o duuru ya, jiri oke ehi gbara afọ atọ, na iri lita ụtụ ọka abụọ na abụọ, na otu karama mmanya, gaa nʼụlọ \nd Onyenwe anyị\nd* dị na Shaịlo.  
\v 25 Mgbe ha ji oke ehi ahụ chụsịa aja, ha kpọtaara Elayị nwantakịrị ahụ.  
\v 26 Mgbe ahụ, ọ sịrị, “Onyenwe m, dịka ị si na-adị ndụ, ọ bụ m bụ nwanyị ahụ guzoro onwe ya nso nʼebe ị nọ kpee ekpere nye \nd Onyenwe anyị\nd*.  
\v 27 Nʼihi nwa a ka m kpere ekpere, \nd Onyenwe anyị\nd* emelara m ihe m rịọrọ nʼaka ya.  
\v 28 Ma ugbu a, ana m enyeghachi ya \nd Onyenwe anyị\nd* ka ọ bụrụ nke ya ndụ ya niile.” O fere \nd Onyenwe anyị\nd* ofufe nʼebe ahụ. 
\c 2  
\s1 Ekpere Hana 
\p  
\v 1 Mgbe ahụ Hana kpere ekpere sị: 
\q1 “Obi m na-aṅụrị ọṅụ nʼime \nd Onyenwe anyị\nd*; 
\q2 nʼime \nd Onyenwe anyị\nd* ka e buliri mpi\f + \fr 2:1 \ft Nʼebe a, mpi na-akọwa maka ike\f* m elu. 
\q1 Ọnụ m na-anya isi megide ndị iro m, 
\q2 nʼihi na-enwere m mmasị na nzọpụta gị. 
\b  
\q1  
\v 2 “O nweghị onye dị nsọ dịka \nd Onyenwe anyị\nd*; 
\q2 o nweghị onye dị karịa gị, 
\q2 o nweghị nkume ọzọ yiri Chineke anyị. 
\b  
\q1  
\v 3 “Anọgidela na-ekwu okwu site na mpako, 
\q2 ekwekwala ka ọnụ gị kwupụta okwu nganga. 
\q1 Nʼihi na \nd Onyenwe anyị\nd* bụ Chineke maara ihe niile, 
\q2 ya bụ onye na-anwale ọrụ niile. 
\b  
\q1  
\v 4 “Ụta ndị na-ebu agha agbajiela 
\q2 ma ndị ahụ dara mba ka e nyere ike. 
\q1  
\v 5 Ndị na-eriju afọ e meela onwe ha ndị ọrụ ngo maka nri, 
\q2 ma ndị na-adịghị eriju afọ na mbụ aghọọla ndị agụụ adịghị agụkwa. 
\q1 Nwanyị aga amụtala ụmụ asaa 
\q2 ma nwanyị ahụ mụrụ ọtụtụ ụmụ adịghị amụtakwa. 
\b  
\q1  
\v 6 “\nd Onyenwe anyị\nd* na-eweta ọnwụ, ya na-emekwa ka a dị ndụ, 
\q2 ọ bụ ya na-eme ka mmadụ daa nʼụra ọnwụ, na-emekwa ka ha dị ndụ ọzọ. 
\q1  
\v 7 \nd Onyenwe anyị\nd* na-ezite ụbịam na akụnụba; 
\q2 ọ na-eweda nʼala, ma na-ebulikwa elu. 
\q1  
\v 8 Ọ na-esite na ntụ welite onye ogbenye 
\q2 na-ebuli ndị mkpa na-akpa site nʼikpo ntụ. 
\q1 Ọ na-eme ka ha soro ụmụ eze nọdụ, 
\q2 na-emekwa ka ha keta ocheeze nsọpụrụ. 
\b  
\q1 “Nʼihi na ntọala ụwa bụ nke \nd Onyenwe anyị\nd* 
\q2 nʼelu ya ka ọ dọkwasịrị ụwa. 
\q1  
\v 9 Ọ ga-echebe ụkwụ ndị nsọ ya 
\q2 ma ndị ajọ omume ka ọ ga-eme ka ha dere duu nʼime ọchịchịrị. 
\b  
\q1 “Ọ bụghị site nʼịdị ike ka mmeri si abịa. 
\q2  
\v 10 Ndị ahụ na-ebuli onwe ha imegide \nd Onyenwe anyị\nd* ka a ga-etipịa. 
\q1 Onye kachasị ihe niile elu ga-ebigbọ site nʼeluigwe megide ha. 
\q2 \nd Onyenwe anyị\nd* ga-ekpe nsọtụ niile nke ụwa ikpe. 
\b  
\q1 “Ọ ga-enye eze ya ike 
\q2 bulikwaa ịdị ike\f + \fr 2:10 \ft Maọbụ, \fqa mpi\f* nke onye ya e tere mmanụ.” 
\p  
\v 11 Mgbe ahụ, Elkena na Hana laghachiri Rema, ma ha hapụrụ Samuel nʼebe ahụ. Nwata ahụ ghọrọ onyeozi \nd Onyenwe anyị\nd*, nʼihi na ọ nọ na-enyere Elayị onye nchụaja aka. 
\s1 Ụmụ ọjọọ Elayị 
\p  
\v 12 Ụmụ Elayị bụ ndị omume ha jọgburu onwe ya; ha na-elelị \nd Onyenwe anyị\nd* anya.  
\v 13 Dịka mmeso ndị nchụaja nʼebe ndị mmadụ si dị: mgbe onye ọbụla bịara ịchụ aja, onyeozi onye nchụaja na-abịa mgbe a na-esi anụ, jiri ndụdụ nwere eze atọ nʼaka ya.  
\v 14 Ọ na-adụnye ya nʼime efere anụ maọbụ ite, maọbụ iko e ji esi anụ. Ihe ọbụla ndụdụ ahụ dụpụtara ka onye nchụaja na-ewere. Otu a ka ha si emeso ndị Izrel niile na-abịa na Shaịlo.  
\v 15 Mgbe ụfọdụ, tupu e suree abụba anụ nʼebe ịchụ aja,\f + \fr 2:15 \ft Nʼiwu e nyere banyere ịchụ aja, abụba na anụ niile abụba kpuchiri ka a na-akpọ ọkụ nʼelu ebe ịchụ aja. \xt Lev 3:3-5,16; 4:8-10\f* ndị ozi onye nchụaja na-abịa gwa onye wetara anụ ịchụ aja sị ya, “Nye onye nchụaja anụ ndụ nke ọ ga-ahụ nʼọkụ, nʼihi na ọ chọghị iri anụ e siri esi, kama anụ ndụ ka ọ chọrọ.” 
\p  
\v 16 Ọ bụrụ na onye ji anụ ahụ bịa ịchụ aja agwa onyeozi ahụ okwu sị, “Chere ka anyị buru ụzọ suo abụba ndị a ọkụ tupu i were ihe ị chọrọ,” onyeozi ahụ na-aza sị, “Nye m anụ ahụ ugbu a, ọ bụrụ na i nyeghị m ya aga m eji ike were ya.” 
\p  
\v 17 Mmehie ụmụ okorobịa ndị a na-eme dị ukwuu nʼanya \nd Onyenwe anyị\nd*, nʼihi na ha na-eleda onyinye a na-ewetara \nd Onyenwe anyị\nd* anya. 
\p  
\v 18 Nʼoge a, Samuel na-agakwa ozi ya nʼihu \nd Onyenwe anyị\nd*. Ọ bụ ezie na ọ bụ naanị nwantakịrị, ọ na-eyi akwa ọcha efọọd dịka ndị nchụaja.  
\v 19 Afọ ọbụla, nne ya na-akwara ya uwe mwụda, nke ọ na-ewetara ya mgbe ya na di ya bịara ịchụ aja.  
\v 20 Tupu ha alaa, Elayị na-agọzi Elkena na Hana sị, “Ka \nd Onyenwe anyị\nd* nye gị ụmụ ọzọ, ndị ga-anọchi anya onye a ị rịọrọ maka ya, nke i nyeghachiri \nd Onyenwe anyị.\nd*”  
\v 21 \nd Onyenwe anyị\nd* gosiri Hana amara. Ọ tụrụ ime mụta ụmụ ndị ikom atọ, na ụmụ ndị inyom abụọ. Ma Samuel tokwara nʼije ozi ya nʼihu \nd Onyenwe anyị\nd*. 
\p  
\v 22 Nʼoge a, Elayị abụrụla nnọọ agadi. Ọ nọkwa na-anụ ihe ọjọọ niile ụmụ ya ndị ikom na-eme ndị Izrel niile, ya na otu ha si edinakwuru ụmụ nwanyị na-eje ozi nʼọnụ ụzọ ebe ịchụ aja ụlọ nzute.  
\v 23 Ya mere, Elayị gwara ụmụ ya sị, “Anụla m site nʼọnụ ndị \nd Onyenwe anyị\nd*, banyere ihe ọjọọ niile dị iche iche unu na-eme. Gịnị mere unu ji na-eme ihe ọjọọ dị otu a?  
\v 24 Ọ bụghị akụkọ ọma ka m na-anụ site nʼọnụ ndị \nd Onyenwe anyị\nd* banyere unu.  
\v 25 Ọ bụrụ na mmadụ emehie megide mmadụ, Chineke nwere ike gbooro ya ọgụ. Ma ọ bụrụ na mmadụ emehie megide \nd Onyenwe anyị\nd*, onye ga-egboro ya ọgụ?” Ma ụmụ ya ndị ikom egeghị nna ha ntị, nʼihi na \nd Onyenwe anyị\nd* na-akwado ịla ha nʼiyi. 
\p  
\v 26 Nwata ahụ bụ Samuel na-eto, na-agba dimkpa, bụrụkwa onye ihe ya dị \nd Onyenwe anyị\nd* na mmadụ mma. 
\s1 Amụma megide ezinaụlọ Elayị 
\p  
\v 27 Otu onye nke Chineke bịara gwa Elayị okwu sị ya, “Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru: Ọ bụ na m ezipụtaghị ike m nʼụzọ pụtara ihe mgbe nna nna gị ha bụ ohu nʼala Ijipt nʼokpuru Fero?  
\v 28 Ahọpụtara m nna nna unu ochie site nʼetiti ebo niile nke Izrel mee ya ka ọ bụrụ onye nchụaja m, ka ọ chụọ aja nʼebe ịchụ aja m, isure ihe nsure ọkụ na-esi isi ụtọ, na iyi uwe efọọd ndị nchụaja nʼihu m. Enyere m ezinaụlọ nna nna gị onyinye niile Izrel ji chụọ aja nsure ọkụ.  
\v 29 Gịnị mere unu ji na-elelị aja a na-achụrụ m, na onyinye a na-ewetara m nʼusoro dịka m si nye ya nʼiwu anya? Gịnị mere i ji na-asọpụrụ ụmụ gị karịa m, ime onwe unu ka unu gbaa abụba site nʼidebere onwe unu akụkụ kachasị mma nke onyinye niile ụmụ Izrel, ndị m, na-ewetara m. 
\p  
\v 30 “Nʼihi ya, otu a ka \nd Onyenwe anyị\nd*, Chineke Izrel, kwupụtara, sị, ‘Ekwere m nkwa na ndị ezinaụlọ gị na nke nna gị ga-eje ozi nʼihu m ruo mgbe ebighị ebi,’ ma ugbu a, otu a ka \nd Onyenwe anyị\nd* kwubiri ya, ‘Ọ gaghị adịkwa otu a nʼebe m nọ! Nʼihi na ndị na-asọpụrụ m ka m ga-asọpụrụ, ma ndị niile na-eleda m anya, ka a ga-akpọ ihe efu.  
\v 31 Oge na-abịa mgbe m ga-ebipụ ike gị na ike ezinaụlọ nna gị, wezuga ha ka nwoke ọbụla nʼezinaụlọ gị hapụ ito ghọọ agadi.  
\v 32 Ị ga-ahụ mkpagbu nʼebe obibi m; a ga-emere Izrel ihe ọma nke ga-eme ka i nwee anya ụfụ, ma ọ dịghị onye ga-eme agadi nʼezinaụlọ gị.  
\v 33 Onye ọbụla nʼime unu nke m na-ebipụghị site nʼebe ịchụ aja m ga-adị ndụ naanị nʼọnọdụ anya mmiri akwa nke ga-ekpuchi ya anya, na iru ụjụ nke obi. Ụmụ ụmụ gị niile ga-anwụ tupu ha eruo agadi. 
\p  
\v 34 “ ‘Ihe ga-adakwasị ụmụ gị ndị ikom, bụ Hofni na Finehaz, ga-abụrụ gị ihe ama. Ha abụọ ga-anwụ nʼotu ụbọchị.  
\v 35 Aga m akpọlite nye onwe m, onye nchụaja kwesiri ntụkwasị obi, onye ga-eme ihe dị m nʼuche na nʼobi. Aga m eme ka ezinaụlọ ya guzosie ike. O ga-eje ozi nʼihu Onye m e tere mmanụ oge niile.  
\v 36 Mgbe ahụ, ndị niile fọdụrụ nʼezinaụlọ gị ga-abịa kpọọ isiala nye ya, rịọọ ya ego na ihe oriri. Ha ga-asị, “Biko, nyetụ m ọrụ m ga-arụ nʼetiti ndị nchụaja, ka m hụ ihe m ga-eri.” ’ ” 
\c 3  
\s1 Onyenwe anyị akpọọ Samuel 
\p  
\v 1 Nwata ahụ bụ Samuel nọkwa na-ejere \nd Onyenwe anyị\nd* ozi nʼihu Elayị. Nʼụbọchị ndị ahụ okwu \nd Onyenwe anyị\nd* dị ụkọ, adịghịkwa ahụ ọtụtụ ọhụ. 
\p  
\v 2 O ruru nʼotu abalị, ka Elayị dinara ala nʼọnọdụ ya ịrahụ ụra, ebe ọ bụ na anya ya akala nka nke bụ na ọ dịghị ahụzikwa ụzọ nke ọma.  
\v 3 Mgbe ahụ, oriọna\f + \fr 3:3 \ft Oriọna dị nʼebe nsọ ahụ kwesiri ị na-enwu ọkụ ehihie na abalị ọbụla. \xt Ọpụ 27:20-21; 30:7-8\ft  Ọ bụ nʼisi ụtụtụ tupu chi abọọ ka ihe a mere.\f* Chineke anyụbeghị, Samuel dinara nʼụlọnsọ \nd Onyenwe anyị\nd*, nʼebe ahụkwa ka igbe ọgbụgba ndụ Chineke dị.  
\v 4 \nd Onyenwe anyị\nd* kpọrọ Samuel oku, 
\p Samuel zara sị, “Lee m nʼebe a.”  
\v 5 O biliri jekwuru Elayị, sị ya, “Lee m abịala m.” 
\p Ma Elayị sịrị ya, “Mba, akpọghị m gị, laghachi gaa dinaa ala.” Samuel gara dina ala. 
\p  
\v 6 Ọzọkwa, \nd Onyenwe anyị\nd* kpọrọ ya sị, “Samuel!” Samuel gbaara ọsọ jekwuru Elayị sị ya, “Lee m, gịnị ka m ga-eme?” 
\p Ma Elayị zara sị ya. “Mba akpọghị m gị oku, nwa m. Laghachi gaa dinaa ala.” 
\p  
\v 7 Ma Samuel amatabeghị onye \nd Onyenwe anyị\nd* bụ, ekpughebeghị okwu \nd Onyenwe anyị\nd* nye ya. 
\p  
\v 8 \nd Onyenwe anyị\nd* kpọrọ ya oku nke ugbo atọ; ọzọkwa Samuel biliri jekwuru Elayị sị ya, “Lee m, gịnị ka ị chọrọ ka m mee?” 
\p Mgbe ahụ, Elayị ghọtara na ọ bụ \nd Onyenwe anyị\nd* na-akpọ nwantakịrị ahụ,  
\v 9 nʼihi ya ọ gwara Samuel okwu sị, “Laghachi, dinaa ala. Ọ bụrụ na ọ kpọọ gị ọzọ, sị ya, ‘Lee m, kwuo, \nd Onyenwe anyị\nd*, nʼihi na ohu gị na-ege ntị.’ ” Ya mere Samuel laghachiri gaa dinaa ala. 
\p  
\v 10 \nd Onyenwe anyị\nd* bịara guzo onwe ya nʼebe ahụ, kpọọ ya ọzọ dịka o si kpọọ ya na mbụ sị, “Samuel! Samuel!” 
\p Samuel zara sị, “Lee m, kwuo, nʼihi na ohu gị na-anụ.” 
\p  
\v 11 \nd Onyenwe anyị\nd* gwara Samuel sị, “Lee, ana m aga ime ihe nʼIzrel nke ga-eme ka ntị nụrụ ya zụọ wuruwuru.  
\v 12 Nʼoge ahụ aga m emezu ihe niile m kwuru megide Elayị na ezinaụlọ ya, site na mmalite ruo ọgwụgwụ.  
\v 13 Nʼihi na agwara m ya na m ga-ekpe ezinaụlọ ya ikpe, ruo mgbe ebighị ebi, nʼihi mmehie ahụ ọ maara ihe banyere ya. Nʼihi na ụmụ ya mere onwe ha ndị a na-elelị anya,\f + \fr 3:13 \ft \xt 1Sa 2:12,17,22\f* ma o meghị ihe ọbụla ịkwụsị ha.  
\v 14 Ya mere, aṅụọla m iyi nye ụlọ Elayị sị, ‘Ikpe ọmụma dịkwasịrị ụlọ Elayị bụ nke a na-agaghị eji onyinye maọbụ ịchụ aja kpuchie.’ ” 
\p  
\v 15 Samuel dinara ala tutu ruo ụtụtụ. Mgbe chi bọrọ, o meghere ọnụ ụzọ ụlọ nzute \nd Onyenwe anyị\nd* dịka ọ na-eme. Ma egwu tụrụ ya ịgwa Elayị ọhụ ahụ.  
\v 16 Ma Elayị kpọrọ ya sị, “Samuel, nwa m.” 
\p Samuel zara sị, “Lee m nʼebe a.” 
\p  
\v 17 Elayị jụrụ ya sị, “Gịnị ka ọ gwara gị? Ezola ihe ọbụla nʼebe m nọ. Ka Chineke mesoo gị mmeso, otu ọbụla mmeso ahụ si dị njọ, ma ọ bụrụ na i zoo ihe ọbụla ọ gwara gị nʼebe m nọ.”  
\v 18 Ya mere, Samuel gwara ya ihe niile, o zokwaghị ihe ọbụla. Mgbe ahụ Elayị kwuru okwu sị, “Ya onwe ya bụ \nd Onyenwe anyị\nd*, ya meekwa dịka o si dị ya mma nʼanya.” 
\p  
\v 19 \nd Onyenwe anyị\nd* nọnyeere Samuel mgbe ọ na-eto, meekwa ka amụma niile Samuel buru mezuo.  
\v 20 Ndị Izrel niile, site na Dan ruo Bịasheba, matara na Samuel bụ onye amụma \nd Onyenwe anyị\nd* kwesiri ntụkwasị obi.  
\v 21 \nd Onyenwe anyị\nd* gakwara nʼihu na-egosi onwe ya na Shaịlo. Nʼebe ahụ o gosiri onwe ya nye Samuel site nʼokwu ya. 
\c 4  
\p  
\v 1 Okwu Samuel rutere ndị Izrel niile ntị. 
\s1 Ndị Filistia adọta igbe ọgbụgba ndụ nʼagha 
\p Mgbe Izrel pụrụ izute ndị Filistia nʼagha, ha mara ụlọ ikwu ha na Ebeneza, ma ndị Filistia mara nke ha nʼAfek.  
\v 2 Nʼagha a lụrụ nʼụbọchị ahụ, ndị Filistia doro onwe ha nʼusoro izute ndị Izrel, dịka agha na-agbasa, ndị Filistia lụgburu ụmụ Izrel, gbukwaa puku mmadụ anọ nʼime ha.  
\v 3 Mgbe ndị agha Izrel fọdụrụ laghachiri nʼụlọ ikwu ha, ndị okenye Izrel jụrịtara onwe ha sị, “Gịnị mere \nd Onyenwe anyị\nd* ji kwe ka ndị Filistia merie anyị taa. Ka anyị gaa Shaịlo buputa igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*, ka o soro anyị jee agha, ka ọ napụta anyị site nʼaka ndị iro anyị.” 
\p  
\v 4 Ya mere, ha zigara ndị mmadụ ka ha gaa Shaịlo. Ha sitere nʼebe ahụ bute igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, onye ahụ na-anọkwasị nʼoche ebere nʼetiti cherubim. Ụmụ ndị ikom Elayị abụọ, bụ Hofni na Finehaz, nọnyeere igbe ọgbụgba ndụ Chineke ahụ. 
\p  
\v 5 Mgbe e bubatara igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* ahụ nʼebe ndị agha Izrel mara ụlọ ikwu ha, ndị Izrel tiri mkpu mere ka ala maa jijiji.  
\v 6 Mgbe ndị Filistia nụrụ ụda mkpu a, ha jụrụ sị, “Gịnị na-eme? Ọ bụ gịnị kpatara oke iti mkpu a nʼụlọ ikwu ndị Hibru?” 
\p Mgbe a gwara ha na ọ bụ nʼihi na igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* erutela,  
\v 7 ụjọ tụrụ ndị Filistia. Ha sịrị, “Chi abatala nʼọmụma ụlọ ikwu ahụ. Ahụhụ dịrị anyị nʼihi na ihe dị otu a emetụbeghị nʼoge gara aga.  
\v 8 \f + \fr 4:8 \ft Nʼihi na ndị Filistia e kwenyeghị na Chineke, kama ha kweere na chi arụsị.\f*Ahụhụ dịrị anyị! Onye ga-anapụta anyị site nʼaka chi ndị a dị ike? Nʼihi na ọ bụ chi ndị a ji ihe otiti dị iche iche tie ndị Ijipt mgbe ụmụ Izrel nọ nʼọzara.  
\v 9 Unu dị ike, unu ndị Filistia, bụrụkwanụ ndị ikom, ma ọ bụghị otu a, unu ga-aghọ ohu ndị Hibru dịka ha bụụrụ unu ndị ohu. Bụrụnụ ndị ikom, lụọ agha!” 
\p  
\v 10 Ndị Filistia lụrụ ọgụ dịka dike, lụgbuo ndị Izrel. Ndị agha ji ụkwụ eje ọgụ ọnụọgụgụ ha dị iri puku atọ nwụrụ nʼotu ụbọchị ahụ. Ma ndị fọdụrụ gbalara nʼụlọ ikwu ha.  
\v 11 Ndị Filistia dọtara igbe ọgbụgba ndụ Chineke nʼagha, ma gbukwaa Hofni na Finehaz ụmụ Elayị. 
\s1 Ọnwụ Elayị 
\p  
\v 12 Ma otu nwoke onye Benjamin gbapụrụ ọsọ site nʼọgbọ agha ahụ, gbara ruo Shaịlo nʼotu ụbọchị ahụ, o yi uwe dọwara adọwa, aja dịkwa ya nʼisi.  
\v 13 Mgbe o rutere, Elayị nọ nʼoche ya nʼakụkụ ụzọ, na-eche, nʼihi na obi ya na-ama jijiji, nʼihi igbe ọgbụgba ndụ Chineke. Mgbe nwoke ahụ batara nʼime obodo, kọọ ihe mere, mkpu akwa dara nʼobodo ahụ niile. 
\p  
\v 14 Elayị nụrụ iti mkpu ahụ jụọ sị, “Gịnị bụ isi ụzụ a?” 
\p Onyeozi ahụ mere ngwangwa bata gwa Elayị okwu.  
\v 15 Elayị agbaala iri afọ itoolu na afọ asatọ nʼoge a, nke mere na ọ naghị ahụkwa ụzọ.  
\v 16 Nwoke ahụ gwara Elayị sị, “Esi m nʼihu agha gbalata. Anọ m nʼebe ahụ taa hụ ka agha si gaa.” 
\p Elayị jụrụ sị, “Nwa m, ọ bụ gịnị mere?” 
\p  
\v 17 Onyeozi ahụ zara sị, “Izrel sitere nʼihu ndị Filistia gbaa ọsọ. E tigbukwara ọtụtụ nʼime ndị agha ha. Ọzọ, ụmụ gị abụọ, Hofni na Finehaz nwụrụ. E burukwara igbe ọgbụgba ndụ Chineke.” 
\p  
\v 18 Mgbe onyeozi ahụ kwutere maka igbe ọgbụgba ndụ Chineke. Elayị sitere nʼoche ya dalaa azụ nʼakụkụ ọnụ ụzọ ama, dajie olu ya, nwụọ! Nʼihi na o meela nnọọ agadi. Ọ bụkwa onye buru ibu. Ya onwe ya kpekwara\f + \fr 4:18 \ft Maọbụ, \fqa Duru ụmụ Izrel\f* ụmụ Izrel ikpe iri afọ anọ. 
\p  
\v 19 Nwunye nwa ya, bụ nwunye Finehaz, dị ime, nọọkwa nso oge ịmụ nwa ya. Mgbe ọ nụrụ maka obubu e buuru igbe ọgbụgba ndụ Chineke, nụkwa maka ọnwụ nna di ya na di ya, ọ mụpụtara nwa ya nʼike. Ma ọ nwụrụ nʼihi ihe mgbu nke afọ ime.  
\v 20 Ma mgbe ọ na-anwụ, ndị inyom na-eji ya ime, sịrị ya, “Atụla egwu, adala mba, ị mụọla nwa nwoke.” Ma ọ zaghị ha ihe ọbụla. Ọ ṅakwaghị ha ntị. 
\p  
\v 21 Ọ gụrụ nwantakịrị aha, kpọọ ya Ịkabọdụ, kwuo sị, “Ebube esitela nʼIzrel pụọ,” nʼihi obubu e buuru igbe ọgbụgba ndụ Chineke, na nʼihi ọnwụ nna di ya na di ya.  
\v 22 O kwuru sị, “Ebube esitela nʼIzrel pụọ, nʼihi na e buuru igbe Chineke.” 
\c 5  
\s1 Igbe ọgbụgba ndụ nʼAshdọd na Ekrọn 
\p  
\v 1 Mgbe ndị Filistia buuru igbe ọgbụgba ndụ Chineke, ha si Ebeneza buru ya buga Ashdọd.  
\v 2 Ha butere igbe ọgbụgba ndụ Chineke, buba ya nʼime ụlọ Dagọn,\f + \fr 5:2 \ft Dagọn bụ arụsị kachasị arụsị ndị ọzọ nke ndị Filistia na-efe. Gụọ ihe nkọwa banyere ya na \xt Nkp 16:23\f* dọba ya nʼakụkụ Dagọn.  
\v 3 Mgbe ndị Ashdọd tetara nʼisi ụtụtụ echi ya, ma lee, Dagọn adaala, kpuo ihu ya nʼala nʼihu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*. Ha bulikwara Dagọn elu doghachi ya nʼọnọdụ ya.  
\v 4 Ma nʼụtụtụ echi ya, Dagọn adakwala kpuo ihu nʼala nʼihu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*. Isi ya na aka ya abụọ dakapụrụ, tọgbọrọ na mbata ọnụ ụzọ, Ọ bụkwa naanị ogwe ahụ ya fọdụrụ.  
\v 5 Ọ bụ nke a mere, site mgbe ahụ ruo taa, ndị nchụaja Dagọn na ndị niile na-abata nʼụlọ Dagọn, adịghị azọ ụkwụ ha nʼọnụ ụzọ mbata ụlọ Dagọn dị nʼAshdọd. 
\p  
\v 6 Aka \nd Onyenwe anyị\nd* malitere ịdị arọ nʼahụ ndị Ashdọd, ha na obodo ndị ọzọ gbara ya gburugburu, o ji etuto dị iche iche menye ha egwu ma bibiekwa ha nʼAshdọd nʼoke ala ya niile.  
\v 7 Mgbe ndị Ashdọd hụrụ ihe na-eme, ha sịrị, “Anyị achọghị ka igbe ọgbụgba ndụ Chineke nke Izrel dịrị nʼetiti anyị, nʼihi na aka ya dị ike nʼahụ anyị, otu aka ahụkwa na chi anyị Dagọn.”  
\v 8 Ya mere, ha ziri ozi kpọkọta ndịisi ndị Filistia niile, jụọ ha sị, “Gịnị ka anyị ga-eme igbe chi ndị Izrel?” 
\p Ha zara, “Ka e buru igbe chi ndị Izrel buga ya nʼobodo Gat.” Ya mere ha buuru igbe Chineke nke Izrel buga Gat. 
\p  
\v 9 Ma mgbe ha bubatara ya na Gat, aka\f + \fr 5:9 \ft \xt Dit 2:15; 1Sa 5:11; 12:15\f*\nd Onyenwe anyị\nd* malitere imegide obodo ahụ. O tinyere ndị obodo ahụ nʼọnọdụ oke egwu. O tiri ndị bi nʼobodo ahụ ihe otiti, ma nwantakịrị ma dimkpa, etuto dị iche iche toro ha nʼahụ.  
\v 10 Ya mere, ha zilara igbe ahụ Ekrọn. 
\p Ma mgbe igbe ahụ na-abata Ekrọn, ndị Ekrọn kwara akwa sị, “Ha e burula igbe ọgbụgba ndụ chi ndị Izrel butere anyị, ka anyị na ndị anyị nwụsịa!”  
\v 11 Ya mere, ha kpọkọtara ndịisi ndị Filistia niile sị ha, “Sinụ nʼobodo zipụ igbe chi ndị Izrel, maọbụ zighachinụ ya nʼobodo e si bute ya na mbụ, ka ọ hapụ igbuchapụ anyị na ndị anyị.” Nʼihi egwu maka ọnwụ ejidela ndị niile bi nʼobodo. Aka Chineke dịkwa ike nke ukwuu megide obodo ahụ.  
\v 12 Ndị na-anwụghị ka e mere ka etuto jupụta ha nʼahụ, mkpu akwa nke ndị obodo ahụ ruru eluigwe. 
\c 6  
\s1 Mbughachi igbe ọgbụgba ndụ 
\p  
\v 1 Igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* ahụ nọrọ nʼobodo ndị Filistia ọnwa asaa.  
\v 2 Emesịa, ndị Filistia kpọrọ ndị nchụaja ha na ndị na-ajụ mmụọ ase jụọ ha sị, “Gịnị ka anyị ga-eme banyere igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*? Gwa anyị otu anyị ga-esi zilaga ya nʼala ya.” 
\p  
\v 3 Ndị ahụ zara sị, “Ọ bụrụ na unu ezighachi igbe ọgbụgba ndụ chi ndị Izrel, unu ezighachila ya nʼaka efu, kama jirinụ onyinye aja ikpe ọmụma zilaga ya. Unu mee nke a, ihe otiti ndị a ga-ala. Unu ga-amatakwa ihe mere o ji na-ata unu ahụhụ ndị a.” 
\p  
\v 4 Ha jụrụ, “Olee ụdị onyinye aja ikpe ọmụma anyị ga-enye.” 
\p A gwara ha, “Dịka ọnụọgụgụ ndịisi obodo Filistia si dị ise, unu ga-eziga onyinye\f + \fr 6:4 \ft Onyinye ọlaedo ndị ahụ bụ i ji mee ka obi juru Chineke nʼihi etuto ndị ahụ o mere ka o too ha. \xt 1Sa 6:5,6,9,12\f* oyiyi etuto ise nke e jiri ọlaedo kpụọ na oyiyi oke ise nke e jikwa ọlaedo kpụọ, nʼihi na ọ bụ otu ụdị ihe otiti ahụ ka o ji tie unu na ndịisi obodo unu niile.  
\v 5 Jiri ọlaedo kpụọ oyiyi etuto na oke ndị ahụ na-emebi ala unu, si otu a nye chi ndị Izrel nsọpụrụ. Ma eleghị anya ọ ga-ewezuga aka ike ya site nʼebe unu na chi unu dị iche iche na ala unu nọ.  
\v 6 Gịnị mere unu ga-eji nyịchie obi unu dịka ndị Ijipt na Fero mere? Mgbe Chineke mesiri ha ike, ọ bụ na ha ahapụghị ndị Izrel ka ha laa? 
\p  
\v 7 “Wuonụ ụgbọala ọhụrụ, werekwanụ nne ehi abụọ na-enye ụmụ ara kegide nʼụgbọ ahụ. Ehi ndị a ga-abụ ndị a na-ejibeghị kọọ ọrụ ubi mbụ. Mgbe unu kegidere ehi ndị a, chịrịnụ ụmụ ha chụba ha nʼebe a na-edebe ehi.  
\v 8 Werenụ igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* tinye nʼụgbọala ahụ, tinyekwa ihe ọlaedo ndị ahụ unu na-enye ka ọ bụrụ aja ikpe ọmụma unu nʼime igbe nta unu ga-etinye nʼakụkụ ya. Zilaganụ ya nʼụzọ ọ ga-agbaso.  
\v 9 Ma guzonụ na-ele ya anya. Ọ bụrụ na ọ gafee oke ala anyị banye Bet-Shemesh, unu ga-amata na ọ bụ \nd Onyenwe anyị\nd* mere ka ihe ọjọọ ndị a dakwasị anyị. Ma ọ bụrụ na o meghị otu a, ọ bụrụ na ọ lọghachi, anyị ga-amata na ihe otiti a bụ naanị ihe ndaba nke dakwasịrị anyị, o sikwaghị nʼaka \nd Onyenwe anyị\nd*.” 
\p  
\v 10 Ha were dịka okwu ndị a si dị. Ha weere nne ehi abụọ na-enye ụmụ ara kegide ha nʼụgbọala ahụ, werekwa ụmụ ha kpọchie nʼọgba anụ.  
\v 11 Igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* na igbe nta ahụ e tinyere oke na oyiyi etuto ọlaedo ndị ahụ a kpụrụ akpụ ka ha dọkwasịrị nʼelu ụgbọala ahụ.  
\v 12 Ehi ndị ahụ dọkpụrụ ụgbọ ahụ gawa nʼụzọ Bet-Shemesh. Ha na-ebekwa muuu mgbe ha na-aga. Ha sogidere ụzọ ahụ na-aga. Ha echigharịghị gaa aka nri maọbụ aka ekpe. Ndị eze ndị Filistia sogidekwara ha nʼazụ tutu rute nʼoke ala Bet-Shemesh. 
\p  
\v 13 Nʼoge a, ndị Bet-Shemesh nọ nʼubi na-ewe ihe ubi nke ọka wiiti na ndagwurugwu ala ahụ. Mgbe ha lepụrụ anya hụ igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*, ọṅụ juru ha obi.  
\v 14 Mgbe ụgbọala ahụ batara nʼubi nwoke a na-akpọ Joshua na Bet-Shemesh, ọ kwụsịrị nʼakụkụ otu nkume ukwu dị nʼebe ahụ. Ngwangwa, ndị nọ nʼebe ahụ gbuwasịrị osisi e ji mee ụgbọ ahụ, gbukwaa ehi abụọ ahụ, were ha chụọrọ \nd Onyenwe anyị\nd* aja nsure ọkụ.  
\v 15 Ndị ikom Livayị nọ nʼebe ahụ buliri igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* na igbe nta ahụ dị nʼakụkụ ya nke ọlaedo niile a kpụrụ akpụ dị nʼime ya, dọkwasị ha nʼelu nkume. Ndị Bet-Shemesh\f + \fr 6:15 \ft Bet-Shemesh bụ otu nʼime obodo ndị Livayị ketara. \xt Jos 21:16\ft  Ọ bụ naanị ndị Livayị na-ebu igbe ọgbụgba ndụ Chineke. \xt Dit 10:18\f* chụrụ ọtụtụ aja nsure ọkụ na aja ndị ọzọ nye \nd Onyenwe anyị\nd* nʼụbọchị ahụ.  
\v 16 Mgbe ndị eze ise obodo ndị Filistia hụrụ ihe mere, ha laghachiri nʼEkrọn nʼụbọchị ahụ. 
\p  
\v 17 Onyinye etuto ọlaedo ise a kpụrụ akpụ nke ha nyere \nd Onyenwe anyị\nd* dị ka aja ikpe ọmụma nʼihi ihe mere ha bụ maka obodo ndị Filistia ndị a, Ashdọd, Gaza, Ashkelọn, Gat na Ekrọn.  
\v 18 Ha wetakwara oke ọlaedo a dịka ọnụọgụgụ obodo ndị Filistia si dị, bụ nke ndịisi ise ahụ nwere, obodo ndị e wusiri ike, na obodo nta niile ha. Nkume ukwu ahụ ebe a dọkwasịrị igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*, bụ ihe akaebe nʼubi Joshua, onye Bet-Shemesh ruo taa. 
\p  
\v 19 Ma \nd Onyenwe anyị\nd* tigburu iri ndị ikom asaa nʼetiti ndị Bet-Shemesh nʼihi na ha nyobara anya nʼime igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* ahụ. Nʼihi ya ndị Bet-Shemesh ruru ụjụ nʼihi ndị ahụ niile \nd Onyenwe anyị\nd* tigburu.  
\v 20 Ndị Bet-Shemesh jụrụ sị, “Onye pụrụ iguzo nʼihu \nd Onyenwe anyị\nd*, bụ Chineke a dị nsọ? Olee ebe anyị ga-ezigakwa igbe ọgbụgba ndụ a?” 
\p  
\v 21 Ha zipụrụ ndị ozi ka ha gaa gwa ndị Kiriat Jearim sị ha, “Ndị Filistia ezighachila igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*. Bịanụ buru ya gaa nʼobodo unu.” 
\c 7  
\nb  
\v 1 Ya mere, ndị ikom Kiriat Jearim bịara buru igbe ọgbụgba ndụ\f + \fr 7:1 \ft Igbe ọgbụgba ndụ ahụ dịgidere nʼebe a, ruo oge Devid bịara bulata ya na Jerusalem. \xt 1Sa 6:21; Abụ 132:6; 2Sa 6:2-3\f*\nd Onyenwe anyị\nd* bubata ya nʼụlọ Abinadab nke dị nʼelu ugwu. Ha doro Elieza, ọkpara Abinadab nsọ, ka ọ bụrụ onye na-elekọta igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*. 
\s1 Mmeri Samuel meriri ndị Filistia na Mizpa 
\p  
\v 2 Igbe ahụ dịgidere na Kiriat Jearim ogologo oge, iri afọ abụọ zuruoke. Ma nʼoge a niile, ndị Izrel nọ na-eru ụjụ nʼihi \nd Onyenwe anyị\nd*.\f + \fr 7:2 \ft Eleghị anya nʼihi na \+nd Onyenwe anyị\+nd* chepuru ihu ya site nʼebe ha nọ.\f* 
\v 3 Ya mere, Samuel gwara ezinaụlọ Izrel niile sị, “Ọ bụrụ na unu ji obi unu niile na alaghachikwute \nd Onyenwe anyị\nd*, mgbe ahụ, wezuganụ chi niile nke ndị ala ọzọ, na arụsị Ashtọret site nʼetiti unu. Kpebienụ nʼobi unu ịbịakwute \nd Onyenwe anyị\nd*, feekwa naanị ya ofufe. Ọ ga-anapụtakwa unu site nʼaka ndị Filistia.”  
\v 4 Ya mere, ndị Izrel wezugara arụsị Baal na Ashtọret ha, bido ife naanị \nd Onyenwe anyị\nd*. 
\p  
\v 5 Samuel gwara ha sị, “Unu ndị Izrel, zukọtaanụ na Mizpa, ka m rịọọ \nd Onyenwe anyị\nd* arịrịọ nʼisi unu.”  
\v 6 Mgbe ha niile zukọrọ nʼebe ahụ, ha kuuru mmiri wụpụ ya nʼala nʼihu \nd Onyenwe anyị\nd*. Nʼụbọchị ahụ kwa, ha buru ọnụ, kwupụta mmehie sị, “Anyị emehiela megide \nd Onyenwe anyị\nd*.” Ọ bụ na Mizpa ka Samuel malitere ikpe ụmụ Izrel ikpe. 
\p  
\v 7 Mgbe ndị Filistia nụrụ na ụmụ Izrel zukọrọ na Mizpa, ndị eze ndị Filistia chịkọtara ndị agha ha, bịa ibuso Izrel agha. Mgbe ụmụ Izrel nụrụ na ha na-abịa nso, ha tụrụ ụjọ nke ukwuu.  
\v 8 Ha sịrị Samuel, “Akwụsịla itiku \nd Onyenwe anyị\nd* Chineke anyị mkpu akwa nʼihi anyị, kpeekwa ekpere ka ọ zọpụta anyị site nʼaka ndị Filistia.”  
\v 9 Mgbe ahụ, Samuel weere nwa atụrụ na-aṅụ ara jiri ya chụọrọ \nd Onyenwe anyị\nd* aja nsure ọkụ, rịọkwa \nd Onyenwe anyị\nd* ka o nyere Izrel aka. \nd Onyenwe anyị\nd* zara ekpere ya. 
\p  
\v 10 Nʼoge ahụ, mgbe Samuel nọ na-esure aja nsure ọkụ ahụ, ndị Filistia bịaruru nso ibuso Izrel agha, ma \nd Onyenwe anyị\nd* sitere nʼeluigwe were oke olu egbe eluigwe nke dara oke ụda chụsasịa ha. O mere ka ọgbaaghara bata nʼetiti ndị Filistia. Nke a mekwara ka ụmụ Izrel kpochapụ ha,  
\v 11 Ndị ikom Izrel si na Mizpa pụta chụso ndị Filistia ọsọ, na-etigbu ha nʼụzọ ruo na ndịda Bet-Ka. 
\p  
\v 12 Mgbe ahụ, Samuel weere otu nkume doo ya nʼagbata Mizpa na Shen, kpọọ ebe ahụ, Ebeneza, nke pụtara, “Nkume inyeaka,” nʼihi na ọ sịrị, “Nʼezie, \nd Onyenwe anyị\nd* enyerela anyị aka ruo ugbu a.” 
\p  
\v 13 Ya mere, mmeri a e meriri ndị Filistia mere ka ha ghara ibuso Izrel agha ọzọ, nʼihi na \nd Onyenwe anyị\nd* kwụsịrị ha ime nke a ụbọchị niile nke ndụ Samuel.  
\v 14 E nyeghachiri ndị Izrel obodo niile ndị Filistia dọtara nʼagha na mbụ, nke dị site nʼEkrọn ruo Gat. Ndị Izrel napụtara oke ala ndị a site nʼaka ndị Filistia. Nʼụzọ dị otu a, e mere ka udo dị nʼetiti ndị Izrel na ndị Amọrait.\f + \fr 7:14 \ft Ndị Amọrị bụ aha ọzọ eji mara ndị niile bụ ndị Kenan. \xt Jen 14:5-7\f* 
\p  
\v 15 Samuel nọgidere dịka onye ikpe ndị Izrel ụbọchị niile nke ndụ ya.  
\v 16 Afọ niile, ọ na-ejegharị site nʼotu obodo ruo nʼobodo ọzọ, site nʼobodo Betel ruo Gilgal, ruokwa Mizpa.\f + \fr 7:16 \ft Betel, Gilgal na Mizpa bụ obodo atọ ndị so nʼoke ala Benjamin ketara. Ọ bụkwa na mpaghara ala ndị a, ka ụlọnsọ Chineke dị. \xt Jos 18:11-28; Jos 4:19\f* Ọ na-anọkwa nʼobodo ndị a na-ekpe ndị Izrel ikpe.  
\v 17 Ma ọ na-alọghachi na Rema, nʼihi na ọ bụ nʼebe ahụ ka ụlọ ya dị. O kpekwara ndị Izrel ikpe nʼebe ahụ, wuokwara \nd Onyenwe anyị\nd* ebe ịchụ aja nʼebe ahụ. 
\c 8  
\s1 Izrel arịọọ ka e nye ha eze 
\p  
\v 1 Mgbe Samuel ghọrọ agadi, o mere ụmụ ya ndị ikom ka ha bụrụ ndị ikpe ndị Izrel.  
\v 2 Juel, ọkpara ya, na Abija, nke na-eso ya ka ọ họpụtara. Ha nọkwa na Bịasheba na-ekpe ndị Izrel ikpe.  
\v 3 Ma ụmụ ya esoghị ụzọ ya.\f + \fr 8:3 \ft \xt 1Sa 12:3; Jer 22:15-17\f* Ha na-agbaso naanị ihe ga-abara ha.\f + \fr 8:3 \ft \xt Ọpụ 18:21\f* Ha na-erikwa ngarị, na-ekpe ikpe na-ezighị ezi.\f + \fr 8:3 \ft \xt Ọpụ 23:6-8; Dit 16:19\f* 
\p  
\v 4 Nʼihi ya, ndị okenye ụmụ Izrel niile zukọtara, bịakwute Samuel na Rema sị ya,  
\v 5 “I meela agadi, ụmụ gị ndị ikom adịghịkwa eso ụzọ gị. Ugbu a họpụtara anyị onye ga-abụ eze anyị, onye ga na-edu anyị, dịka mba ndị ọzọ.” 
\p  
\v 6 Ma obi adịghị Samuel ụtọ mgbe ha rịọrọ sị, “Nye anyị eze ga-edu anyị.” Nʼihi ya, Samuel kpọkuru \nd Onyenwe anyị\nd* nʼekpere.  
\v 7 \nd Onyenwe anyị\nd* gwara ya, “Gee ntị nʼihe niile ndị a na-agwa gị; ọ bụghị gị ka ha jụrụ, kama ọ bụ mụ onwe m ka ha jụrụ ibu eze ha.  
\v 8 Site nʼụbọchị m mere ka ha si nʼIjipt pụta ruo taa, ha na-agbakụta m azụ, na-efe chi ndị ọzọ. Ọ bụkwa otu a ka ha na-eme gị ugbu a.  
\v 9 Mee dịka ha rịọrọ, ma echefula ịgwa ha ụdị omume eze ahụ ga-achị ha ga-emeso ha.” 
\p  
\v 10 Samuel gwara ndị Izrel na-arịọ ka e nye ha eze ihe \nd Onyenwe anyị\nd* kwuru.  
\v 11 Ọ zara sị ha, “Ihe ndị a bụ ụdị mmeso eze ahụ ga-achị unu ga-emeso unu: Ọ ga-eduru ụmụ unu ndị ikom mee ha ndị na-agba ọsọ nʼihu ụgbọ agha ya na ịnyịnya ya.  
\v 12 Ụfọdụ ka ọ ga-eme ọchịagha, ndị ga-elekọta ọtụtụ puku ndị agha, maọbụ iri ndị agha ise; ndị ụfọdụ ga-abụ ndị ga-akọ ubi ya, ndị ọzọ ga-ewebatakwa ihe owuwe ubi ya, ma ndị ọzọ ga-akpụrụ ya ngwa agha na ihe niile e ji anya ụgbọ agha ya.  
\v 13 Ọ ga-eduru ụmụ unu ndị inyom mee ka ha bụrụ ndị na-esiri ya mmanụ otite na-esi isi ụtọ, na ndị na-esiri ya nri, na ndị na-eghere ya ihe oghịghe.  
\v 14 Ọ ga-anarakwa unu ubi unu, na ubi vaịnị unu, na ubi oliv unu ndị kachasị mma, were ha nye ndị na-ejere ya ozi.  
\v 15 Ọ ga-ewere otu ụzọ nʼime ụzọ iri nke mkpụrụ ubi unu na ubi vaịnị unu nye ndịisi ọrụ ya na ndị na-ejere ya ozi.  
\v 16 Ọ ga-akwagidekwa unu ka unu nye ya ndị ohu unu, ndị ikom nʼime ha, na ndị inyom nʼime ha, ya na anụ ụlọ unu ahụ dị ezi mma, na ịnyịnya ibu unu.  
\v 17 Ọ ga-ewerekwa otu ụzọ nʼụzọ iri nke igwe anụ ụlọ unu, meekwa ka unu onwe unu bụrụkwa ndị ohu ya.  
\v 18 Mgbe ụbọchị ndị ahụ bịara, mgbe ihe ndị a bidoro imezu, unu ga-akwa akwa, rịọọ ka e wezugara unu eze ahụ unu họpụtaara onwe unu, ma \nd Onyenwe anyị\nd* agaghị aṅa unu ntị nʼụbọchị ahụ.” 
\p  
\v 19 Ma ndị Izrel jụrụ ige Samuel ntị. Ha sịrị, “Anyị chọrọ eze ga-achị anyị.  
\v 20 Mgbe ahụ, anyị onwe anyị ga-adị ka ndị mba niile ọzọ, anyị ga-enwe eze ga na-edu anyị, na-aga nʼihu anyị na-ebukwa agha anyị.” 
\p  
\v 21 Samuel gwara \nd Onyenwe anyị\nd* ihe niile ha kwuru.  
\v 22 Ma \nd Onyenwe anyị\nd* zara ya ọzọ sị, “Mee ihe ha kwuru, nye ha eze.” 
\p Mgbe ahụ, Samuel gwara ndị ikom Izrel okwu sị ha, “Laanụ, nwoke ọbụla nʼobodo ya.” 
\c 9  
\s1 Samuel etee Sọl mmanụ ịbụ eze 
\p  
\v 1 E nwere otu nwoke si Benjamin aha ya bụ Kish nwa Abiel, nwa Zeroa, nwa Bekorat, nwa Afia, onye Benjamin, burukwa oke mmadụ a maa ama.  
\v 2 O nwere nwa nwoke aha ya bụ Sọl, onye bụ okorobịa nọ nʼuju ya. O nweghị nwoke ọzọ e ji atụnyere ya nʼIzrel niile. O toro ogologo karịa onye ọbụla site nʼubu ruo nʼisi. 
\p  
\v 3 Otu ụbọchị, ụfọdụ nʼime ịnyịnya ibu Kish nna Sọl nwere kpafuru. Nʼihi ya, Kish kpọrọ Sọl gwa ya okwu sị, “Duru otu odibo ka gị na ya soro ga chọgharịa ịnyịnya ibu ndị a.”  
\v 4 Ha chọrọ ịnyịnya ndị ahụ gaa nʼala ugwu ugwu Ifrem, na nʼakụkụ Shalisha, ma ha ahụghị ha. Ha chọkwara ha gaa nʼakụkụ Shaalim, ma ha ahụghị ha nʼebe ahụ. Emesịa, ha chọrọ ịnyịnya ibu ndị ahụ gaa nʼala niile nke ndị Benjamin, ma ha ahụghị ha ebe ọbụla. 
\p  
\v 5 Nʼikpeazụ, mgbe ha chọọrọ ha rute nʼala Zuf, Sọl gwara onyeozi ahụ ya na ya so, sị, “Ka anyị laghachi, nʼihi na ọ bụrụ na nna m elee anya anyị ma ọ hụghị anyị, ọ ga-amalite iche echiche banyere anyị karịa ịnyịnya ibu ndị a.” 
\p  
\v 6 Ma odibo ahụ zara ya sị, “Lee, e nwere otu onye nke Chineke bi nʼobodo a; ọ bụkwa onye mmadụ niile na-asọpụrụ nʼihi na ihe ọbụla o kwuru na-emezu. Ka anyị gaa hụ ya, ma eleghị anya ọ ga-agwa anyị ụzọ anyị ga-esi.” 
\p  
\v 7 Sọl sịrị odibo ya, “Ọ bụrụ na anyị agaa, gịnị ka anyị ga-enye nwoke ahụ? Nri dị na-akpa anyị agwụla, ọ dịkwaghị onyinye anyị nwere nke anyị ga-enye onye nke Chineke. Gịnị ka anyị nwere?” 
\p  
\v 8 Onyeozi ahụ zara ya ọzọ sị, “Lee, enwere m otu mkpụrụ shekel ọlaọcha. Aga m enye ya onye Chineke a ka ọ gwa anyị ụzọ anyị ga-esi.”  
\v 9 (Na mgbe gara aga nʼIzrel, ọ bụrụ na mmadụ agaa iju Chineke ase, ọ na-asị, “Bịa ka anyị jekwuru onye ọhụ ụzọ,” nʼihi na onye a na-akpọ onye amụma taa, ka a na-akpọ onye ọhụ ụzọ nʼoge ahụ). 
\p  
\v 10 Sọl sịrị odibo ya, “Ọ dị mma, Bịa ka anyị gaa.” Ha biliri gawa nʼobodo ebe onye Chineke ahụ nọ. 
\p  
\v 11 Mgbe ha na-arịgo ugwu ịbanye obodo ahụ, ha zutere ụfọdụ ụmụ agbọghọ ka ha na-apụta iseta mmiri, jụọ ha ajụjụ sị, “Onye ọhụ ụzọ ahụ ọ nọ nʼebe a?” 
\p  
\v 12 Ụmụ agbọghọ ahụ zara ha sị, “E, ọ nọ ya. Lee ya ka ọ na-aga nʼihu unu. Unu jesie ike unu ga-ahụ ya. Ugbu a ka ọ batara obodo anyị, nʼihi na ọ na-aga iso ndị mmadụ gaa ịchụ aja nʼebe dị elu.  
\v 13 Ngwangwa unu banye nʼobodo, unu ga-ahụ ya tupu o gaa nʼebe dị elu iri ihe. Nʼihi na ndị mmadụ agaghị ebido iri ihe tutu ruo mgbe o rutere, nʼihi na ọ ghaghị ịgọzi ihe aja ahụ tupu ndị a kpọrọ oku ebido iri ihe.\f + \fr 9:13 \ft Ọtụtụ oge, iri nri na ịbụ abụ bụ otu nʼime ihe a na-eme ma a chụsịa aja ụfọdụ.\f* Gbagoonụ unu ga-ahụ ya nʼoge dịka nke a.” 
\p  
\v 14 Ya mere, ha mere ngwangwa, baa nʼime obodo ahụ. Dịka ha na-abata nʼime obodo, lee Samuel ka ọ na-abịakwute ha; ọ na-aga nʼebe ahụ dị elu. 
\p  
\v 15 Ma nʼụbọchị bọrọ tupu ụbọchị Sọl na-abịa, \nd Onyenwe anyị\nd* kpughere nke a nye Samuel.  
\v 16 “Dịka mgbe a echi, aga m ezitere gị otu nwoke sị nʼala Benjamin. Ị ga-ete ya mmanụ nke ga-eme ya ka ọ bụrụ onyendu Izrel ndị m. Ọ ga-azọpụta ha site nʼaka ndị Filistia, nʼihi na ahụla m ahụhụ nke ha nọ nʼime ya; anụkwala m ịkwa akwa ha.” 
\p  
\v 17 Mgbe Samuel hụrụ Sọl, \nd Onyenwe anyị\nd* gwara ya sị, “Lee nwoke ahụ m gwara gị ihe banyere ya! Ọ bụ ya ga-achị ndị m.” 
\p  
\v 18 Ma Sọl bịaruru Samuel nso jụọ ya sị, “Biko, zi m ebe ụlọ onye ọhụ ụzọ dị.” 
\p  
\v 19 Samuel zara sị ya, “Mụ onwe m bụ ọhụ ụzọ ahụ. Gaanụ nʼihu m rigoruo nʼebe dị elu, nʼihi na mụ na unu ga-eso rikọọ nri taa. Nʼụtụtụ echi aga m agwa gị ihe dị gị nʼobi. Aga m ezilagakwa gị.  
\v 20 Enyela obi gị nsogbu maka ịnyịnya ibu ndị ahụ furu efu nʼabalị atọ gara aga, nʼihi na a chọtala ha. Ma, onye ka mmadụ ahụ bụ, onye ndị Izrel niile na-achọsi ike? Ọ bụghị gị na ezinaụlọ nna gị.” 
\p  
\v 21 Ma Sọl zara sị, “Ọ bụghị onye Benjamin ka m bụ, onye sitere nʼebo kachasị nta nʼIzrel; ọ bụghị agbụrụ m dịkarịsịrị nta nʼetiti agbụrụ niile ọzọ dị nʼebo Benjamin? Gịnị mere i ji agwa m ụdị okwu dị otu a?” 
\p  
\v 22 Mgbe ahụ, Samuel duuru Sọl na onyeozi ya kpọbata ha nʼime ụlọ ukwu, nye ha ọnọdụ nʼisi oche nʼetiti iri mmadụ atọ ọ kpọrọ oriri.  
\v 23 Samuel gwara onyeisi ndị na-esi nri okwu sị, “Weta anụ ahụ m nyere gị, nke ahụ m sị gị ka ị debe iche.” 
\p  
\v 24 Onye na-esi nri weere ụkwụ anụ ahụ na ihe ndị so ya debe ya nʼihu Sọl. Samuel sịrị, “Lee, ihe ndị e wepụrụ ka e debere gị. Rie, nʼihi na e debere gị ya maka oge akara aka, site nʼoge ahụ m kwuru si, ‘Akpọrọ m ndị mmadụ oku nri.’ ” Sọl sooro Samuel rie nri nʼụbọchị ahụ. 
\p  
\v 25 Mgbe ha sitere nʼebe ahụ dị elu rịdata nʼobodo. Samuel kpanyere Sọl ụka nʼelu ụlọ ya.  
\v 26 Nʼisi ụtụtụ mgbe ha biliri, Samuel kpọrọ Sọl nʼụlọ elu sị, “Jikere, ka m zilaga gị.” Mgbe Sọl kwadoro, ya na Samuel sooro pụọ nʼezi.  
\v 27 Ka ha na-arịda na-abịaru nsọtụ obodo ahụ, Samuel sịrị Sọl, “Gwa onyeozi ahụ ka ọ gafee nʼihu anyị.” Onyeozi ahụ mekwara otu a, ma, “Gị onwe gị chere ntakịrị oge nʼebe a ka m mee ka ị nụrụ ozi sitere nʼaka Chineke.” 
\c 10  
\p  
\v 1 Mgbe ahụ, Samuel weere karama mmanụ wụkwasị ya nʼisi, sutukwa ya ọnụ nʼagba sị ya, “Ọ bụ na \nd Onyenwe anyị\nd* etebeghị gị mmanụ ime gị onyendu ihe nketa ya?  
\v 2 Mgbe ị ga-ahapụ m nʼebe a, ị ga-ahụ ndị ikom abụọ nʼakụkụ ili Rechel na Zelza, nʼala Benjamin, ha ga-agwa gị, ‘A chọtala ịnyịnya ibu ndị ahụ furu efu, ugbu a, nna gị akwụsịla iche ihe gbasara ịnyịnya ibu ya, ma ọ nọkwa na-echegbu onwe ya nʼihi gị, ọ na-ajụ, “Olee ihe m ga-eme banyere ọkpara m?” ’ 
\p  
\v 3 “Mgbe i ruru nʼosisi ukwu Taboa, ị ga-ezute ndị ikom atọ ndị na-aga ife Chineke ofufe na Betel. Otu nʼime ha ga-ebu ụmụ ewu atọ, nke ọzọ ga-eji ogbe achịcha atọ, ma nke atọ ga-eji otu karama mmanya.  
\v 4 Ha ga-ajụ gị banyere ọdịmma gị, nyekwa gị ogbe achịcha abụọ, nke ị ga-anara site nʼaka ha. 
\p  
\v 5 “Emesịa, ị ga-aga Gibea nke Chineke, ebe ndị agha ndị Filistia mara ụlọ ikwu nche. Mgbe ị na-abata obodo ahụ, ị ga-ezute ndị amụma, ndị si nʼebe dị elu ahụ na-arịdata. Ha ga na-akpọ une, na egwu otiti, na ọja, na ụbọ akwara. Ha ga na-ebukwa amụma.  
\v 6 Nʼoge ahụ, mmụọ \nd Onyenwe anyị\nd* ga-abịakwasị gị, ị ga-esorokwa ha buo amụma. Ị ga-abụkwa onye a gbanwere, onye dị iche.  
\v 7 Mgbe ihe ịrịbama ndị a mezuru ị ga na-eme ihe ọbụla i chepụtara nʼobi gị, nʼihi na Chineke nọnyeere gị. 
\p  
\v 8 “Ị ga-aga Gilgal\f + \fr 10:8 \ft Ebe mbụ e wuru ụlọnsọ Chineke nʼime ala Kenan bụ nʼobodo Gilgal. \xt Jos 4:19-24\f* chere m nʼebe ahụ abalị asaa, nʼihi na ana m abịa ịchụ aja nsure ọkụ na aja udo. Aga m agwa gị ihe ị ga-eme mgbe m bịara.” 
\s1 Sọl ebuo amụma 
\p  
\v 9 Mgbe ọ na-atụgharị ka ọ si ebe Samuel nọ pụọ, Chineke gbanwere ya, nye ya obi ọhụrụ, ihe ịrịbama ndị ahụ mezukwara nʼụbọchị ahụ.  
\v 10 Mgbe ya na onye na-ejere ya ozi rutere Gibea, ndị amụma nọ nʼahịrị zutere ha. Mmụọ nke Chineke bịakwasịrị ya nʼebe ọ dị ukwu, o sooro ha malite ibu amụma.  
\v 11 Mgbe ndị niile maara Sọl hụrụ ya ka o so ndị a na-ebu amụma, ha jụrụ onwe ha ajụjụ sị, “Gịnị mere nwa Kish? Sọl, ọ ghọọla otu nʼime ndị amụma?” 
\p  
\v 12 Otu nʼime ndị bi nʼebe ahụ jụrụ sị, “Onye ka nna ha bụ?” Nke a bụ mmalite okwu ahụ a na-ekwu sị, “Sọl ọ ghọọla otu nʼime ndị amụma?”  
\v 13 Mgbe Sọl buchara amụma, ọ rigooro gaa nʼebe ịchụ aja ahụ dị nʼelu ugwu. 
\p  
\v 14 Mgbe nwanne nna ya hụrụ Sọl, ọ jụrụ ya ajụjụ sị, “Olee ebe ị gara?” 
\p Sọl zara ya sị, “Anyị gara ịchọ ịnyịnya ibu ndị ahụ furu efu, ma anyị achọtaghị ha, nʼihi ya anyị gara nʼebe onye amụma a na-akpọ Samuel ịjụta ase ebe ha nọ.” 
\p  
\v 15 Ma nwanne nna Sọl sịrị, “Gwa m ihe Samuel gwara gị.” 
\p  
\v 16 Sọl zara ya sị, “Ọ gwara anyị na a chọtala ịnyịnya ibu ndị ahụ.” Ma okwu gbasara alaeze, dịka Samuel siri kwuo ya, ọ gwaghị ya ihe ọbụla. 
\p  
\v 17 Emesịa, Samuel kpọrọ nzukọ ndị Izrel niile na Mizpa,\f + \fr 10:17 \ft Oge ọbụla ndị Izrel nwere ihe dị mkpa ha ga atule, ọ bụ nʼobodo Mizpa ka ha na-ezukọta \xt Nkp 20:2; 21:1; 1Sa 7:5-6\f* ka ha bịa zute \nd Onyenwe anyị\nd*.  
\v 18 Ọ gwara ha sị, “Otu a ka \nd Onyenwe anyị\nd*, Chineke Izrel kwuru, ‘Mụ onwe m si nʼala Ijipt kpọpụta Izrel ma napụtakwa unu site nʼaka ike ndị Ijipt, na site nʼaka alaeze niile bụ ndị kpagburu unu.’  
\v 19 Ma ugbu a, unu ajụla Chineke unu onye na-azọpụta unu site nʼihe ndakwasị na nhụju anya unu niile. Unu kwukwara sị, ‘Mba, nye anyị eze ga-achị anyị.’ Ugbu a, doonụ onwe unu nʼusoro nʼihu \nd Onyenwe anyị\nd* dịka ebo unu na ikwu unu niile si dị.” 
\p  
\v 20 Samuel mere ka ebo Izrel niile bịaruo nso nʼebo nʼebo, nza\f + \fr 10:20 \ft Ọ bụ site na-ịjụta ase nʼUrim na Tumim ka mmadụ ji amata ihe ọ ga-eme. \xt Ọnụ 27:21; 1Sa 28:6\f* mara ebo Benjamin.  
\v 21 O mere ka ebo Benjamin bịaruo nso nʼagbụrụ nʼagbụrụ, nza mara agbụrụ Matri. Nʼikpeazụ nza ahụ mara Sọl, nwa Kish. Ha chọgharịrị ya ma ha ahụghị ya.  
\v 22 Ha jụrụ \nd Onyenwe anyị\nd* ase ọzọ, “Nwoke ahụ ọ bịala nʼebe a?” 
\p \nd Onyenwe anyị\nd* sịrị, “E, Lee, o zoro onwe ya nʼetiti akpa ndị ahụ.” 
\p  
\v 23 Ha gbaara gaa nʼebe ahụ kpọpụta ya. Mgbe ọ pụtara guzoro nʼetiti ha, ha hụrụ na o toro ogologo karịa onye ọbụla site nʼubu ruo nʼisi.  
\v 24 Samuel gwara ndị ahụ niile okwu sị, “Onye a bụ nwoke ahụ \nd Onyenwe anyị\nd* họpụtara ka ọ bụrụ eze unu. Ọ dịghị onye ọzọ dịka ya nʼIzrel!” 
\p Mgbe ahụ, mmadụ niile tiri mkpu sị, “Ka eze dị ogologo ndụ gaa nʼihu!” 
\p  
\v 25 Ọzọkwa, Samuel gwara ndị Izrel ihe bụ ọrụ eze, na ihe ruuru ya. O dekwara ihe ndị a nʼakwụkwọ, debe akwụkwọ ahụ nʼihu \nd Onyenwe anyị\nd*. Emesịa, Samuel mechiri nzukọ ahụ. Onye ọbụla laghachikwara nʼụlọ ya. 
\p  
\v 26 Mgbe Sọl laghachiri nʼobodo ya, bụ Gibea, ndị ikom ndị Chineke metụrụ aka nʼobi sooro ya.  
\v 27 Ma ụfọdụ ndị efulefu jọgburu onwe ha kwuru sị, “Olee otu nwoke a ga-esi zọpụta anyị?” Ha lelịrị ya anya, jụkwa iwetara ya onyinye ịnata ihuọma. Ma Sọl gbachitere ha nkịtị. 
\c 11  
\s1 Mmeri Sọl meriri ndị Amọn 
\p  
\v 1 Nʼoge ahụ, Nahash, eze ndị Amọn,\f + \fr 11:1 \ft Ndị Amọn bụ ụmụ ụmụ Lọt, \xt Jen 19:38; Dit 2:19\ft  nʼoge Ndị Ikpe na-achị nʼIzrel, ha gbalịrị ibuso ha agha ka ha nara ha ala ha. \xt Nkp 3:13; 11:4-33\f* duuru ndị agha ya bilie imegide ndị Izrel bi nʼala Jebesh Gilead. Ma ndị Jebesh rịọrọ ya sị, “Ka anyị na gị gbaa ndụ, anyị ga-anọ nʼokpuru ọchịchị gị.” 
\p  
\v 2 Ma Nahash, onye Amọn zara sị ha, “Mụ na unu ga-agba ndụ ma ọ bụrụ na unu ekwenye ka m ghụpụta anya aka nri nke onye ọbụla nʼime unu, si otu a wetara Izrel niile ihe nkọcha.” 
\p  
\v 3 Ndị okenye obodo Jebesh zara sị, “Nye anyị abalị asaa ka anyị ziga ndị ozi nʼala Izrel niile. Ọ bụrụ na o nweghị onye kwere ịbịa zọpụta anyị, anyị ga-ewere onwe anyị nyefee gị nʼaka.” 
\p  
\v 4 Mgbe ndị ozi ha zipụrụ bịaruru Gibea, nke bụ obodo Sọl, ha kọọrọ ndị mmadụ ihe ndị a, ha niile dapụrụ nʼakwa.  
\v 5 Ma nʼoge a, Sọl si nʼubi na-alọta, soro ụmụ ehi ya nʼazụ, ọ jụrụ, “Ọ bụ gịnị na-eme onye ọbụla? Gịnị mere na ha ji ebe akwa?” Ha kọọrọ ya ihe banyere ozi e si Jebesh zite. 
\p  
\v 6 Mgbe Sọl nụrụ ozi a, Mmụọ nke Chineke bịakwasịrị ya nʼike, iwe wekwara ya nke ukwuu.  
\v 7 Ọ kpụpụtara ehi abụọ bọkasịa ha, zipụ ndị ozi ka ha buru ha ga obodo niile dị nʼIzrel. Ozi ha ga-ezi ndị obodo ọbụla bụ nke a. “Ọ bụ ihe e mere ehi ndị a ka a ga-eme ehi onye ọbụla jụrụ iso Sọl na Samuel jee ọgụ.” \nd Onyenwe anyị\nd* mere ka egwu jide ndị Izrel niile. Nʼihi ya, ha niile bịakwutere Sọl dịka otu mmadụ.  
\v 8 Mgbe Sọl kpọkọtara ha na Bezek, ọnụọgụgụ ndị ikom Izrel dị narị puku atọ, tinyekwara iri puku mmadụ atọ, ndị sitere na Juda. 
\p  
\v 9 Ha gwara ndị zitere ozi ahụ okwu sị ha, “Zienụ ndị ikom Jebesh Gilead, ‘Echi, tupu anyanwụ achaa nʼuju ya, a ga-anapụta unu.’ ” Mgbe ndị ozi a gara zie ndị ikom Jebesh Gilead ozi a, ha ṅụrịrị ọṅụ nke ukwuu.  
\v 10 Ndị ikom Jebesh ziri ozi gwa ndị Amọn sị ha, “Echi, anyị ga-enye unu onwe anyị, ka unu mee anyị ihe masịrị unu.” 
\p  
\v 11 Ma nʼụtụtụ echi, Sọl na ndị agha ya bịaruru. O kewara ndị agha ya ụzọ atọ, buso ụmụ Amọn agha na mberede nʼisi ụtụtụ. O gbugidere ha ụtụtụ niile ruo mgbe anyanwụ chara nʼuju ya, chụsasịa ndị fọdụrụ nʼime ha. Nke a mere na o nweghị ebe a ga-ahụ ka ndị agha Amọn abụọ nọkọtara. 
\s1 Nnabata Sọl dịka eze 
\p  
\v 12 Ndị Izrel niile bịakwutere Samuel jụọ ya sị, “Olee ndị ahụ sị na Sọl agaghị abụ eze anyị? Kpọpụtara anyị ha ka anyị gbuo ha!” 
\p  
\v 13 Ma Sọl zara sị, “O nweghị onye ọbụla a ga-egbu taa, nʼihi na taa, \nd Onyenwe anyị\nd* anapụtala Izrel!” 
\p  
\v 14 Samuel gwara ha sị, “Bịanụ ka anyị gaa Gilgal mee ịbụ eze a ka ọ dị ọhụrụ ọzọ.”  
\v 15 Ya mere, mmadụ niile gara Gilgal. Na mmemme pụrụ iche, ha mere Sọl eze nʼihu \nd Onyenwe anyị\nd*. Ha chụkwara aja udo nye \nd Onyenwe anyị\nd* nʼebe ahụ. Ọṅụ jupụtakwara nʼobi Sọl na ndị Izrel niile. 
\c 12  
\s1 Okwu ikpeazụ Samuel kwuru 
\p  
\v 1 Mgbe ahụ, Samuel gwara ụmụ Izrel sị, “Lee, emeelara m unu ihe unu rịọrọ, Enyela m unu eze.  
\v 2 Ugbu a, unu enweela eze, onye bụ onyendu unu. Ma nʼebe mụ onwe m nọ, abụrụla m agadi isi awọ, ụmụ m ndị ikom so nọrọkwa nʼetiti unu. Abụ m onyendu unu site na mgbe m bụ okorobịa ruo taa.  
\v 3 Lee m ka m guzo nʼihu unu. Gbaanụ ama megide m nʼihu \nd Onyenwe anyị\nd* na nʼihu onye ya o tere mmanụ. Onye ka m zuuru ehi ya?\f + \fr 12:3 \ft \xt Ọnụ 16:15; Ọrụ 20:33; 1Te 2:5; Ọpụ 23:8; Dit 16:19\f* Onye ka m zuuru ịnyịnya ibu ya? Ọ dị onye m ghọgburu? Ọ dị onye m megburu? Ọ dị onye m si nʼaka ya nara ego aka azụ ime ka m ghara ikpe ikpe ziri ezi? Gwanụ m ma ọ bụrụ na m mere ihe ndị a, aga m emezi ya.” 
\p  
\v 4 Ha zara sị, “Mba ọ dịbeghị mgbe ị ghọgburu anyị, maọbụ kpagbuo anyị, nʼụzọ ọbụla. O nweghịkwa onye i si nʼaka ya were ihe ọbụla.” 
\p  
\v 5 Samuel zara sị ha, “\nd Onyenwe anyị\nd* bụ onye akaebe megide unu. Otu a kwa, onye ya o tere mmanụ bụ onye akaebe taa, na unu achọtaghị ihe ọbụla nʼaka m.” 
\p Ha zara sị, “E, ọ bụ onye akaebe!” 
\p  
\v 6 Samuel gakwara nʼihu nʼokwu ya sị, “Ọ bụ \nd Onyenwe anyị\nd* họpụtara Mosis na Erọn. Ọ bụkwa ya mere ka nna nna unu ha si nʼIjipt pụta.  
\v 7 Ugbu a, guzonụ jụ nʼebe a nʼihu \nd Onyenwe anyị\nd* ka m chetara unu ihe ọma niile \nd Onyenwe anyị\nd* meere unu na nna nna unu ha. 
\p  
\v 8 “Mgbe ụmụ Jekọb batara Ijipt, ha kpọkuru \nd Onyenwe anyị\nd* ka o nyere ha aka. \nd Onyenwe anyị\nd* zitere Mosis na Erọn, ndị kpọpụtara nna nna unu ha site nʼIjipt, mee ka ha bịa biri nʼebe a. 
\p  
\v 9 “Ma ha chefuru \nd Onyenwe anyị\nd* bụ Chineke ha, nʼihi ya o nyefere ha nʼaka Sisera, bụ ọchịagha eze Hazọ, nakwa nʼaka ndị Filistia, na eze ndị Moab, bụ ndị lụsoro ha ọgụ.  
\v 10 Ha tikuru \nd Onyenwe anyị\nd* mkpu akwa, sị ya, ‘Anyị emehiela,\f + \fr 12:10 \ft \xt Nkp 10:10\f* anyị agbakụtala\f + \fr 12:10 \ft \xt Nkp 2:13; 3:7\f*\nd Onyenwe anyị\nd* azụ, fee arụsị Baal na Ashtọret. Ma ugbu a, napụta anyị site nʼaka ndị iro anyị, anyị ga-efekwa gị.’  
\v 11 \nd Onyenwe anyị\nd* zitere Jerub-Baal, na Barak,\f + \fr 12:11 \ft Nʼime akwụkwọ ụfọdụ ihe ị ga-ahụ bụ Bedan\f* na Jefta, na Samuel, ka ha zọpụta unu site nʼaka ndị iro nọ unu gburugburu, mee ka unu biri nʼudo. 
\p  
\v 12 “Ma mgbe unu hụrụ na Nahash, eze ndị Amọn na-achọ ibuso unu agha, unu tụrụ egwu bịakwute m sị m, ‘Mba, anyị chọrọ eze ga-achị anyị,’ nʼagbanyeghị na \nd Onyenwe anyị\nd* Chineke unu bụ eze unu.  
\v 13 Ugbu a, leenụ eze unu họpụtara, nʼihi na ọ bụ unu rịọrọ \nd Onyenwe anyị\nd* ka o nye unu ya; \nd Onyenwe anyị\nd* azakwala arịrịọ unu.  
\v 14 Ugbu a, ọ bụrụ na unu ga-atụ egwu \nd Onyenwe anyị\nd*, fee ya, rubere ya isi, hapụ inupu isi nʼebe iwu ya dị, ọ bụrụkwa na unu na eze unu ga-esogide \nd Onyenwe anyị\nd* Chineke unu, ihe niile ga-adị mma.  
\v 15 Ma ọ bụrụ na unu enupu isi nʼiwu \nd Onyenwe anyị\nd*, jụ ige ya ntị, aka ya ga-abịakwasị unu nʼoke iwe, ọ ga-emekwa unu ihe o mere nna nna unu ha. 
\p  
\v 16 “Ugbu a, na-elenụ anya ka unu hụ ọrụ ịtụnanya niile \nd Onyenwe anyị\nd* na-aga ịrụ.  
\v 17 Unu maara na ugbu a bụ oge a na-aghọ mkpụrụ ọka wiiti, ma aga m ekpe ekpere ka \nd Onyenwe anyị\nd* zite egbe eluigwe na mmiri ozuzo taa, ka unu ghọta ụdị ihe ọjọọ unu mere nʼanya \nd Onyenwe anyị\nd* mgbe unu rịọrọ ya sị ya nye unu eze.” 
\p  
\v 18 Mgbe ahụ Samuel kpọkuru \nd Onyenwe anyị\nd*, \nd Onyenwe anyị\nd* zidatakwara egbe eluigwe na mmiri ozuzo nʼụbọchị ahụ. Nke a mere ka mmadụ niile tụọ \nd Onyenwe anyị\nd* na Samuel egwu. 
\p  
\v 19 Ndị ahụ rịọrọ Samuel arịrịọ sị ya, “Biko kpeere anyị ekpere nye \nd Onyenwe anyị\nd* Chineke gị ka anyị bụ ndị ohu gị ghara ịnwụ. Nʼihi na, nʼezie, anyị ejirila aka anyị mee ka mmehie anyị mụbaa site nʼịrịọ ka e nye anyị eze.” 
\p  
\v 20 Samuel zara sị, “Unu atụla egwu. Unu emeela ihe ọjọọ ndị a niile, ma hụkwanụ na unu ji obi unu niile fee \nd Onyenwe anyị\nd* ofufe. Unu agbakụtakwala ya azụ nʼụzọ ọbụla.  
\v 21 Unu agbasola chi ndị ọzọ, nʼihi na ha abaghị uru. Ha agaghị enyere unu aka maọbụ napụta unu site nʼaka ndị iro unu.  
\v 22 \nd Onyenwe anyị\nd* agaghị ahapụ ndị ya ọ họpụtara, nʼihi na-ime ihe dị otu a bụ iwetara aha ya dị ukwuu ihere. Ọ tọrọ \nd Onyenwe anyị\nd* ụtọ ime unu mba pụrụ iche nye onwe ya.  
\v 23 Ma banyere mụ onwe m, ọ ga-abụrụ m ihe arụ ma a sị na m ga-emehie megide \nd Onyenwe anyị\nd* site nʼịkwụsị ikpere unu ekpere. Aga m anọgidekwa na-ezi unu ihe ndị ahụ dị mma, na ihe ndị ahụ kwesiri ekwesi.  
\v 24 Naanị tụọnụ egwu \nd Onyenwe anyị\nd*, werekwanụ obi unu fee ya ofufe nʼikwesị ntụkwasị obi; chetanụ ihe ukwuu niile o meere unu.  
\v 25 Ma ọ bụrụ na unu anọgide na-eme ihe ọjọọ, unu na eze unu ka a ga-ekpochapụ.” 
\c 13  
\s1 Samuel abaara Sọl mba 
\p  
\v 1 Sọl gbara iri afọ atọ\f + \fr 13:1 \ft Nʼụfọdụ akwụkwọ ndị ọgbara ọhụrụ e nweghị ọnụọgụgụ a\f* mgbe e mere ya eze. Ọ chịkwara dịka eze nʼala Izrel iri afọ anọ na abụọ. 
\p  
\v 2 Sọl sitere nʼetiti ụmụ Izrel họpụta puku ndị ikom atọ ka ha bụrụ ndị agha ya. Sọl na puku abụọ nọ na Mikmash nʼala ugwu ugwu Betel. Otu puku nọnyeere Jonatan na Gibea, nʼala Benjamin. Ndị ikom ndị fọdụrụ ka o zighachiri, onye ọbụla nʼụlọ ha. 
\p  
\v 3 Ma Jonatan busoro ndị agha Filistia nọ na Geba agha. Ndị Filistia nụkwara ihe banyere ya. Mgbe ahụ, Sọl nyere iwu ka e gbuo opi ike nʼala Izrel niile, kwuo sị, “Unu ndị Hibru niile, geenụ ntị.”  
\v 4 Ya mere, ụmụ Izrel niile nụrụ akụkọ ahụ nke kwuru sị, “Sọl ebusola ọmụma ụlọ ikwu ndị agha Filistia agha, nʼihi nke a, ndị Izrel niile abụrụla ndị a kpọrọ asị ugbu a nʼetiti ndị Filistia.” Ya mere, ndị agha Izrel niile pụtakwara soro Sọl gaa Gilgal. 
\p  
\v 5 Ndị Filistia nʼonwe ha chịkọtara ndị agha ha ibuso ndị Izrel agha. Ọnụọgụgụ ụgbọ agha ha dị puku atọ, ndị na-agba ịnyịnya ha nwere dị puku isii; ndị agha ha ndị ọzọ dị ukwu nʼọnụọgụgụ. Nʼezie, ha dị ukwuu dịka aja dị nʼọnụ osimiri. Ha manyere ụlọ ikwu ha na Mikmash nʼọwụwa anyanwụ Bet-Aven.  
\v 6 Mgbe ndị agha Izrel hụrụ na ọnọdụ ha dị njọ nke ukwuu, hụkwa na ndị iro na-emegide ha, ha zoro onwe ha nʼọgba nkume, nʼime oke ọhịa, nʼetiti nkume, nʼime olulu na nʼime oghere ọbụla.  
\v 7 Ndị Hibru ụfọdụ gafere Jọdan ruo nʼala Gad na Gilead. 
\p Nʼoge a, Sọl nọ na Gilgal, ndị agha niile ya na ha nọ na-amakwa jijiji nʼihi ụjọ.  
\v 8 Samuel gwararịị Sọl ka o chere ya ruo abalị asaa, ma mgbe abalị asaa zuru Samuel abịaghị Gilgal. Nʼoge a, ndị agha Sọl malitere na-agbasasị.  
\v 9 Ya mere, Sọl kwuru sị, “Wetaranụ m ihe aja nsure ọkụ na nke aja udo.” Sọl chụkwara aja nsure ọkụ ahụ.  
\v 10 Ngwangwa ọ na-achụcha aja ndị ahụ, Samuel rutere, Sọl pụrụ izute ya, na ikele ya. 
\p  
\v 11 Samuel sịrị, “Gịnị bụ ihe a i mere?” 
\p Sọl zara, “Mgbe m hụrụ na ndị a na-agba aghara aghara, na-esite nʼebe m nọ na-agbapụ, mgbe m lere anya lee, ma ahụghị m ka ị na-abịa dịka i kwuru, mgbe m hụkwara ndị Filistia ka ha nọ na Mikmash, na-akwado ibuso anyị agha,  
\v 12 echeere m, ‘Ugbu a, ndị Filistia ga-arịdakwute m ibuso m agha na Gilgal, ma arịọbeghị m ihuọma \nd Onyenwe anyị\nd*.’ Ya mere m, m jisie ike chụọ aja nsure ọkụ ahụ.” 
\p  
\v 13 Samuel sịrị Sọl, “Ị kpara agwa onye nzuzu. I debeghị ihe \nd Onyenwe anyị\nd* Chineke gị nyere gị nʼiwu idebe. A si na i mere nke a, ọ gaara eme ka alaeze gị guzosie ike nʼebe Izrel nọ ruo mgbe niile.  
\v 14 Ma ugbu a, alaeze gị agaghị adịgide. \nd Onyenwe anyị\nd* achọpụtala otu nwoke dịka ọchịchọ obi ya si dị, ọ họpụtakwala ya ịbụ eze nke ndị ya; nʼihi na ị debeghị ihe \nd Onyenwe anyị\nd* nyere gị nʼiwu.” 
\p  
\v 15 Samuel biliri hapụ Gilgal gaa Gibea nʼala Benjamin. Mgbe Sọl gụrụ ndị agha so ya, ọ chọpụtara na ha dị naanị narị isii. 
\s1 Ngwa agha ọbụla adịghị nʼala Izrel 
\p  
\v 16 Sọl na nwa ya nwoke Jonatan, na narị mmadụ isii ndị soo ha nọ na Geba nʼala Benjamin, ebe ndị Filistia mara ụlọ ikwu ha na Mikmash.  
\v 17 Ụfọdụ nʼime ndị agha Filistia kere onwe ha ụzọ atọ site nʼụlọ ikwu ndị Filistia pụta; otu ụzọ chere ihu nʼụzọ Ofra nʼakụkụ Shual,  
\v 18 nke ọzọ chere ihu ịga Bet-Horon, nke atọ chee ihu nʼụzọ oke ala dị na Ndagwurugwu Zeboiim, nke dị ọzara nso. 
\p  
\v 19 Nʼoge ahụ, e nweghị ike ịchọta otu ọkpụ ụzụ nʼala Izrel, nʼihi na ndị Filistia sịrị, “Ma ọ bụghị otu a, ndị Hibru ga-akpụtara onwe ha mma agha maọbụ ùbe.”  
\v 20 Izrel niile na-ejekwuru ndị Filistia maka ịmụ ọgụ igwuze ala ha, maọbụ mma oge ha, maọbụ anyụike ha, maọbụ mma ha ji ewe ihe ubi.  
\v 21 Ihe ha na-akwụ maka ịmụ ọgụ igwuze ala, na mma oge ha bụ ụzọ abụọ nke shekel e kere ụzọ atọ, maka ịmụ anyụike, na ndụdụ, ya na ịpị ndụdụ e ji achị ehi bụ, otu ụzọ nke shekel e kere ụzọ atọ. 
\p  
\v 22 Nke mere na ahụtaghị mma agha\f + \fr 13:22 \ft \xt Nkp 5:8\f* maọbụ ùbe ọbụla nʼaka ndị agha Izrel nʼụbọchị agha ahụ, ma ọ bụghị naanị nke dị nʼaka Sọl na Jonatan.\f + \fr 13:22 \ft Ọ bụ ụta na àkụ ka ndị Izrel ji lụọ ọgụ.\f* 
\s1 Jonatan ebuso ndị Filistia agha 
\p  
\v 23 Ugbu a ndị Filistia e kewapụtara iche a pụọla gaa nʼụzọ warawara dị na Mikmash. 
\c 14  
\nb  
\v 1 Otu ụbọchị, Jonatan nwa Sọl, kpọrọ nwokorobịa na-ebu ihe agha ya sị, “Bịa, ka anyị gafee ndagwurugwu jeruo nʼụlọ ikwu ndị Filistia.” Ma ọ gwaghị Sọl nna ya. 
\p  
\v 2 Sọl na narị ndị ikom isii ya na-anọdụ nʼebe dị anya site na Gibea, nʼokpuru osisi pomegranet dị na Migrọn.  
\v 3 Otu nʼime ndị so Sọl bụ Ahija onye nchụaja, onye yi efọọd.\f + \fr 14:3 \ft Ọ bụ nʼime efọọd ka ụmụ nkume abụọ e ji ajụta ase nʼihu Chineke, nke bụ Urim na Tumim na-adị. \xt Ọpụ 28:30\f* Ọ bụ nwa Ahitub, onye bụ nwanne Ịkabọdụ. Ahitub bụ nwa nwa Finehaz, onye bụ nwa Elayị, onye nchụaja \nd Onyenwe anyị\nd* na Shaịlo. Ọ dịkwaghị onye ma na Jonatan apụọla. 
\p  
\v 4 Tupu Jonatan eruo ebe ndị Filistia nọ, ọ ghaghị isite na nwa ụzọ warawara dị nʼagbata nkume abụọ, a na-akpọ Bozez na Sene gabiga.  
\v 5 Nkume nke dị nʼakụkụ elu elu, dị nʼihu Mikmash, nke dị nʼakụkụ ndịda dị nʼihu Geba. 
\p  
\v 6 Jonatan gwara nwokorobịa na-ebu ihe agha ya sị, “Bịa, ka anyị gafee ga nʼebe nguzo ndị ahụ a na-ebighị ugwu, ma eleghị anya \nd Onyenwe anyị\nd* ga-alụrụ anyị ọgụ. Nʼihi na ọ dịghị ihe pụrụ igbochi \nd Onyenwe anyị\nd* ịzọpụta, site nʼọtụtụ mmadụ, maọbụ ole na ole.” 
\p  
\v 7 Nwokorobịa ahụ zara sị ya, “Gaa nʼihu, eji m obi m na mmụọ m na-eso gị dịka ọchịchọ gị si dị.” 
\p  
\v 8 Jonatan gwara ya sị, “Bịa ka anyị ga, lee ihe anyị ga-eme. Anyị ga-apụkwuru ndị agha ahụ mee ka ha hụ anyị anya.  
\v 9 Ọ bụrụ na ha asị, ‘Guzonụ ebe ahụ ruo mgbe anyị bịakwutere unu,’ anyị ga-echere ebe anyị nọ, anyị agaghị agakwuru ha.  
\v 10 Ma ọ bụrụ na ha sị, ‘Rigokwutenụ anyị,’ anyị ga-emekwa otu ahụ, nʼihi na ọ ga-abụrụ anyị ihe ama na \nd Onyenwe anyị\nd* enyela ha nʼaka anyị.” 
\p  
\v 11 Ya mere, ha abụọ guzoro ebe ndị Filistia ga-ahụ ha. Mgbe ndị Filistia hụrụ ha, ha tiri mkpu sị, “Lee, ndị Hibru esitela nʼọnụ\f + \fr 14:11 \ft \xt 1Sa 13:6; 14:22\f* ebe ha zoro na-arịpụta.”  
\v 12 Ndị ikom ndị na-anọ nʼebe nguzo ndị nche tikuru Jonatan na onye ahụ na-ebu ngwa agha ya sị, “Rigokwutenụ anyị, ka anyị mee unu ihe.” 
\p Jonatan gwara onye ahụ na-ebu ngwa agha, “Soro m nʼazụ rigota, nʼihi na \nd Onyenwe anyị\nd* ewerela ha nyefee nʼaka Izrel.” 
\p  
\v 13 Ya mere, Jonatan ji ikpere ya na aka ya rigoruo nʼebe ahụ; onye na-ebu ihe agha ya sokwa ya nʼazụ. Ma ndị agha Filistia daghachiri azụ mgbe Jonatan na onye na-ebu ihe agha ya bidoro igbu ha.  
\v 14 Na ogbugbu mbụ ahụ, Jonatan na onye ahụ na-ebu ngwa agha ya gburu ọnụọgụgụ ndị Filistia dị iri abụọ. Ọ bụ nʼihe ha ka nketa ala ruru otu ọkara nʼekaa\f + \fr 14:14 \ft Maọbụ, \fqa ọkara furo nʼọtụtụ\f* nʼọtụtụ. 
\s1 Izrel emerie ndị Filistia 
\p  
\v 15 Oke ọma jijiji dakwasịrị ndị agha niile, na ndị nọ nʼọmụma ụlọ ikwu, ma ndị nọ nʼọhịa, ma ndị nọ nʼebe dịpụrụ adịpụ, ma ndị na-ejegharị ejegharị ibu agha. Ala ahụ niile mara jijiji. Ọ bụ ọma jijiji nke Chineke zitere. 
\p  
\v 16 Ndị nche Sọl, bụ ndị nọ na Gibea nʼime Benjamin, lepụrụ anya hụ igwe ndị agha ka ha malitere ịgba barịị nʼihu na-azụ.  
\v 17 Mgbe ahụ, Sọl gwara ndị agha ya na ha so, “Gụọnụ ndị agha ọnụ, chọpụta onye na-anọghị nʼebe a.” Mgbe ha mere nke a, ha chọpụtara, na Jonatan na onye na-ebu ihe agha ya anọghị nʼebe ahụ. 
\p  
\v 18 Sọl sịrị Ahija, “Bute igbe ọgbụgba ndụ Chineke.” (Nʼoge ahụ igbe ọgbụgba ndụ dị nʼaka ụmụ Izrel.)  
\v 19 Mgbe Sọl na-agwa onye nchụaja okwu, ụzụ na iti mkpu nke na-ada nʼụlọ ikwu ndị Filistia dara karịa, nʼihi ya, Sọl gwara onye nchụaja ahụ okwu sị ya, “Sepụ aka gị.” 
\p  
\v 20 Mgbe ahụ, Sọl na ndị niile ya na ha nọ jikọtara onwe ha baa nʼagha ahụ, ma lee, ndị Filistia ji mma agha na-egburita onwe ha. Ọgbaaghara dịkwa nʼebe niile.  
\v 21 Ma ndị Hibru, ndị so ndị Filistia na-alụ ọgụ, tụgharịrị dịnyere ndị Izrel soro Sọl na Jonatan.  
\v 22 Emesịa, ndị ikom Izrel niile, ndị ahụ zoro onwe ha nʼala ugwu ugwu Ifrem pụtara, mgbe ha hụrụ na ndị Filistia na-agba ọsọ. Ha gbapụtara soro ndị ọzọ ịchụ ndị Filistia ọsọ.  
\v 23 Ya mere, \nd Onyenwe anyị\nd* napụtara ndị Izrel nʼụbọchị ahụ. E buru agha ahụ gabiga Bet-Aven. 
\s1 Jonatan arachaa mmanụ aṅụ 
\p  
\v 24 Ma ndị ikom Izrel nọ ọnọdụ nhụju anya nʼụbọchị ahụ, nʼihi na Sọl jiri ịṅụ iyi kechie ha, mgbe o kwuru sị, “Onye a bụrụ ọnụ ka nwoke ahụ bụ onye ga-eri nri ọbụla site ugbu a ruo anyasị, tutu ruo mgbe m bọsịrị ọbọ megide ndị iro m!” Nʼihi ya, o nweghị onye ọbụla nʼetiti ndị agha ya detụrụ ihe oriri ọnụ. 
\p  
\v 25 Ndị agha ahụ niile banyere nʼọhịa ebe mmanụ aṅụ dị nʼala.  
\v 26 Mgbe ha banyere nʼọhịa, ha hụrụ mmanụ aṅụ ebe ọ na-asọpụta, ma o nweghị onye metụrụ aka nʼọnụ ya, nʼihi na ha tụrụ egwu iyi ahụ ha ṅụrụ.  
\v 27 Ma Jonatan anụghị na nna ya mere ka ndị ahụ ṅụọ iyi, ya mere, o setịpụrụ ọnụ ọnụ mkpanaka dị ya nʼaka rụta mmanụ aṅụ na ugbugbo ya, tinye nʼọnụ ya rachaa. Nke a mere ka ike ya laghachite.  
\v 28 Ma otu onye agha gwara ya sị, “Nna gị ji ịṅụ iyi gbaa ndị agha niile iwu, sị, ‘Onye a bụrụ ọnụ ka nwoke ahụ bụ, onye riri nri taa. Ọ bụ nke a mere ndị mmadụ ji ada mba.’ ” 
\p  
\v 29 Jonatan zara sị, “Nna m esitela nʼiwu dị otu a wetara ala anyị nsogbu. Lee ka m si nweta ike site na mmanụ aṅụ nta m rachara.  
\v 30 Ọ garaghị aka mma ma a sị na ndị ikom riri ihe ha si nʼaka ndị iro ha kwata nʼagha? Ọ bụ na ogbugbu a gaara egbu ndị Filistia agaraghị adị ukwuu karịa?” 
\p  
\v 31 Ma ndị agha Izrel bu agụụ tigbuo ndị Filistia, chụọkwa ha ọsọ site na Mikmash ruo Aijalon. Ha dakwara mba karịa.  
\v 32 Ha dakwasịrị ihe a kwatara nʼagha, gbuo atụrụ na ehi na ụmụ ehi, bido iri anụ ha na ndụ nʼihi agụụ.  
\v 33 Ma otu onye gwara Sọl sị, “Ndị ikom Izrel na-emehie megide \nd Onyenwe anyị\nd* site na iri anụ ọbara ya dị nʼahụ ya.” 
\p Mgbe ahụ, ọ sịrị, “Ihe dị otu a jọgburu onwe ya. Nutenụ nkume ukwuu nʼebe a ugbu a.”  
\v 34 Sọl sịrị, “Gaa nʼetiti ndị ikom a gwa ha, ‘Ka onye ọbụla weta ehi na atụrụ ha chọrọ igbu nʼebe a, ka e gbuo ha nʼebe a, rie anụ ha. Unu emehiela megide \nd Onyenwe anyị\nd* site nʼiri anụ ọbara dị nʼime ya.’ ” 
\p Ya mere, onye ọbụla wetara ehi ya nʼabalị ahụ, gbuo nʼebe ahụ.  
\v 35 Emesịa, Sọl wuuru \nd Onyenwe anyị\nd* ebe ịchụ aja. Nke a bụ ebe ịchụ aja nke mbụ o wuru. 
\p  
\v 36 Mgbe ahụ, Sọl gwara ndị agha ya sị, “Ka anyị gaa chụọ ndị Filistia ọsọ nʼabalị a niile, ma gbukwaa onye ọbụla fọdụrụ nʼime ha.” 
\p Ndị agha ya zara sị, “Ọ dị mma, mee dịka ị kwuru.” 
\p Ma onye nchụaja sịrị, “Ka anyị buru ụzọ jụta ihe bụ uche Chineke.” 
\p  
\v 37 Mgbe ahụ, Sọl jụrụ Chineke sị, “Ọ bụ m rịda gaa chụso ndị Filistia? Ị ga-enyefe ha nʼaka ndị Izrel?” Ma Chineke enyeghị ya ọsịsa ọbụla nʼụbọchị ahụ. 
\p  
\v 38 Sọl gwara ndịisi agha Izrel okwu sị, “Ihe emebiela! Anyị aghaghị ịchọpụta ụdị mmehie anyị mere taa, nke mere \nd Onyenwe anyị\nd* ji jụ inye anyị ọsịsa.  
\v 39 Nʼezie dịka \nd Onyenwe anyị\nd*, onye na-azọpụta Izrel na-adị ndụ, a sịkwarị na ọ bụ nwa m Jonatan ka a chọpụtara na ọ bụ ya ka ikpe mara, ọ ga-anwụ!” Ma ọ dịghị onye gwara ya ihe ọbụla. 
\p  
\v 40 Mgbe ahụ, Sọl gwara ndị Izrel niile okwu sị ha, “Guzonụ onwe unu nʼebe ahụ, mụ na nwa m Jonatan ga-eguzo onwe anyị nʼebe a.” 
\p Ndị ahụ zara sị, “Mee ihe ọbụla dị gị mma.” 
\p  
\v 41 Mgbe ahụ, Sọl kpere ekpere nye \nd Onyenwe anyị\nd*, bụ Chineke Izrel, “Gịnị mere na ị zabeghị ohu gị taa? Ọ bụrụ na ikpe mara m maọbụ nwa m Jonatan, zaa site nʼUrim, ma ọ bụrụ ndị ikom Izrel ka ikpe mara,\f + \fr 14:41 \ft Akwụkwọ ndị Hibru ochie enweghị akụkụ a, nke bidoro na \fq “Gịnị mere na ị zabeghị ohu gị taa? \ft ruo nʼebe asịrị \fqa maọbụ ndị Izrel ka ikpe mara”\fqa .\f* nye ọsịsa site na Tumim.” Nza ahụ mara Jonatan na Sọl, ma ikpe amaghị ndị ikom Izrel.  
\v 42 Mgbe ahụ, Sọl kwuru sị, “Ugbu a feenụ nza nʼetiti mụ na Jonatan, nwa m nwoke.” Nza ahụ mara Jonatan. 
\p  
\v 43 Sọl gwara Jonatan okwu sị ya, “Gwa m ihe i mere.” 
\p Jonatan zara sị ya, “Ọ bụ naanị mmanụ aṅụ ntakịrị ka m ji ọnụ mkpanaka m rụrụ rachaa. Ọ pụtara na m ga-anwụ nʼihi ya?” 
\p  
\v 44 Mgbe ahụ, Sọl zara sị, “Nʼezie Jonatan, ị ghaghị ịnwụ. Ka Chineke meso m mmeso, otu ọbụla mmeso ahụ si sie ike, ma ọ bụrụ na ị nwụghị nʼihi ihe a i mere.” 
\p  
\v 45 Ma ndị ikom ahụ sịrị Sọl, “Jonatan ọ ga-anwụ, bụ onye a wetara nzọpụta a dị ukwuu nʼIzrel? Nke a apụghị ime! Dịka \nd Onyenwe anyị\nd* na-adị ndụ, ọ bụladị otu agịrị isi agaghị esi nʼisi ya dapụ, nʼihi na Chineke ejirila ya rụọ ọrụ ịtụnanya dị ukwuu taa.” Ya mere, ndị agha ahụ zọpụtara Jonatan, e gbukwaghị ya. 
\p  
\v 46 Emesịa, Sọl kwụsịrị ndị agha ya ịchụ ndị Filistia ọsọ. Ndị Filistia nʼonwe ha lakwara nʼala nke ha. 
\p  
\v 47 Site nʼoge Sọl malitere ịchị nʼIzrel, o buru agha megide ndị iro ha nʼakụkụ niile, ndị Moab, ndị Amọn, ndị Edọm, ndị eze Zoba na ndị Filistia. Ebe ọbụla o chere ihu ọ na-alụgbu.  
\v 48 O buru agha dị ukwuu, lụgbuo ndị Amalek; ma zọpụta ndị Izrel site nʼaka ndị niile na-emegbu ha site nʼịpụnarị ha ihe ha nwere. 
\s1 Ezinaụlọ Sọl 
\p  
\v 49 Sọl mụtara ndị ikom atọ; Jonatan, Ishvi na Malkishua. Ọ mụtakwara ụmụ agbọghọ abụọ, Merab na Mikal.  
\v 50 Aha nwunye Sọl bụ Ahinoam, ada Ahimaaz. Ọchịagha Sọl bụ Abna, nwa Nea, nwanne nna Sọl.  
\v 51 Nea, nna Abna, na Kish, nna Sọl bụ ụmụnne. Ha bụ ụmụ Abiel. 
\p  
\v 52 Ndị Izrel na ndị Filistia nọ nʼagha dị egwu ụbọchị niile Sọl bụ eze. Mgbe ọbụla Sọl hụrụ nwoke dị ike, maọbụ dimkpa, ọ na-eduru ya mee ya ka ọ bụrụ otu nʼime ndị agha ya. 
\c 15  
\s1 \nd Onyenwe anyị\nd* ajụ eze Sọl 
\p  
\v 1 Samuel sịrị Sọl, “Mụ ka \nd Onyenwe anyị\nd* zitere ite gị mmanụ ka ị bụrụ eze ndị ya, bụ Izrel. Ya mere, gee ntị nʼozi sitere nʼaka \nd Onyenwe anyị\nd* bịa.  
\v 2 Ihe a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile\f + \fr 15:2 \ft Onye pụrụ ime ihe niile\f* kwuru. ‘Aga m ata ndị Amalek ahụhụ nʼihi ihe ọjọọ niile ha mere Izrel, mgbe ha nọchiri ha nʼụzọ oge ha si Ijipt pụta.  
\v 3 Ugbu a, gaa buso ndị Amalek agha. Gbuchapụ ihe niile\f + \fr 15:3 \fq Gbuchapụ ihe niile \ft nke a, nʼokwu ndị Hibru \fqa pụtara i were ihe niile, tinyere mmadụ na anụ ụlọ, nyefee \nd Onyenwe anyị\nd* kpamkpam na-eleghị anya nʼazụ site ikpochapụ ha. Usoro okwu a dịkwa nʼamaokwu ndị a: \xt 1Sa 15:8,9,15,18,20,21\f* ha nwere. Enwekwala ọmịiko nʼahụ ha. Gbuo ndị ikom niile, ndị inyom niile, ụmụntakịrị niile na ụmụ na-aṅụ ara, igwe ehi na atụrụ, ịnyịnya kamel na ịnyịnya ibu ha niile.’ ” 
\p  
\v 4 Ya mere, Sọl chịkọtara ndị agha ya mee ka ha zukọtaa nʼobodo Telaim. Ọnụọgụgụ ha dị narị puku abụọ, ndị agha ji ụkwụ, tinyere puku ndị ikom iri si na Juda.  
\v 5 Sọl duuru ndị agha ya gaa zoo nʼakụkụ iyi tara ata dị nso nʼobodo ndị Amalek.  
\v 6 Sọl zigaara ndị Ken ozi sị ha, “Sitenụ nʼetiti ndị Amalek wezuga onwe unu ka m ghara ibibikọta unu na ha. Nʼihi na unu gosiri ndị Izrel obiọma mgbe ha si nʼIjipt pụta.” Ya mere, ndị Ken sitere nʼetiti ndị Amalek wezuga onwe ha. 
\p  
\v 7 Sọl busoro ndị Amalek agha site na Havila ruo Shua, nke dị nʼọwụwa anyanwụ Ijipt.  
\v 8 O jidere Agag, eze ndị Amalek na ndụ, ma jiri mma agha gbuchapụ ndị ya niile.  
\v 9 Ma Sọl na ndị agha ya debere Agag ndụ, debekwa atụrụ na ehi kachasị mma, na ụmụ ebule na atụrụ gbara abụba, na ihe ndị ọzọ niile mara mma. Nʼezie, ihe ọbụla dị mma nʼanya ka ha jụrụ ibibi. Ma ihe ndị ọzọ niile nke na-amasịghị ha, na nke na-abaghị uru, ka ha bibiri. 
\p  
\v 10 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* rutere Samuel ntị,  
\v 11 “Ọ na-ewute m na m mere Sọl ka ọ bụrụ eze, nʼihi na o nupuru isi site nʼokwu m, jụ ime ihe m nyere ya nʼiwu.” O wutere Samuel nke ukwuu mgbe ọ nụrụ ihe \nd Onyenwe anyị\nd* kwuru. Ya mere, o tikuru \nd Onyenwe anyị\nd* mkpu akwa abalị ahụ niile. 
\p  
\v 12 Nʼisi ụtụtụ echi ya, Samuel pụrụ gawa ịchọ Sọl. Otu onye gwara ya sị, “Sọl agaala nʼugwu Kamel iwuru onwe ya ihe ncheta. Ọ ga-esitekwa ebe ahụ gaa Gilgal.” 
\p  
\v 13 Nʼikpeazụ, mgbe Samuel hụrụ ya, Sọl ji oke ọṅụ kelee Samuel sị, “Onye \nd Onyenwe anyị\nd* gọziri agọzi ka ị bụ. Lee, emeela m ihe niile \nd Onyenwe anyị\nd* kwuru!” 
\p  
\v 14 Ma Samuel jụrụ ya sị, “Gịnị bụ ube atụrụ ndị a m na-anụ? Ebee ka ube igwe ehi ndị a si na-ada?” 
\p  
\v 15 Sọl zara sị, “Ndị agha m si nʼetiti ndị Amalek chịta ụfọdụ nʼime atụrụ na ehi ndị mara mma nke ha chọrọ iji chụọrọ \nd Onyenwe anyị\nd* Chineke gị aja. Ma anyị bibiri ihe ndị ọzọ fọdụrụnụ.” 
\p  
\v 16 Mgbe ahụ Samuel gwara Sọl sị, “Ekwukwala ọzọ! Gee ntị nụrụ ihe \nd Onyenwe anyị\nd* gwara m nʼabalị!” 
\p Sọl zara ya sị, “Kwuo, gịnị ka ọ gwara gị?” 
\p  
\v 17 Samuel gwara ya sị, “Ọ bụghị ezie nʼagbanyeghị na ị dịrịị ntakịrị nʼanya gị onwe gị, ma ị bụụrụ onyeisi ndị ebo Izrel niile? \nd Onyenwe anyị\nd* tere gị mmanụ ibu eze ndị Izrel.  
\v 18 \nd Onyenwe anyị\nd* ziri gị ijere ya ozi, gwa gị sị, ‘Gaa, laa ndị ajọ omume ahụ, bụ ndị Amalek nʼiyi; buso ha agha ruo mgbe ị kpochapụrụ ha niile.’  
\v 19 Gịnị mere i geghị ntị nʼokwu \nd Onyenwe anyị\nd* ime ihe o kwuru? Gịnị mere i ji chụrụ ihe nkwata gaa, si otu a mee ihe dị njọ nʼanya \nd Onyenwe anyị\nd*?” 
\p  
\v 20 Ma Sọl sịrị ya, “Ma erubeere m \nd Onyenwe anyị\nd* isi. Ejere m ozi ahụ \nd Onyenwe anyị\nd* zigara m. Anwụtara m Agag eze Amalek na ndụ, ma gbuchapụ ndị Amalek niile.  
\v 21 Ndị agha sitere nʼihe a kwatara nʼagha were ụfọdụ atụrụ na ehi, bụ ndị kachasị mma nʼetiti ihe ndị ahụ e debere iche maka ịla ha nʼiyi, iji ha chụọrọ \nd Onyenwe anyị\nd* Chineke gị aja na Gilgal.” 
\p  
\v 22 Ma Samuel sịrị, 
\q1 “Ihe na-atọ \nd Onyenwe anyị\nd* ụtọ ọ bụ onyinye na aja nsure ọkụ 
\q2 dịka nrube isi nye ihe si nʼọnụ \nd Onyenwe anyị\nd* pụta? 
\q1 Nrube isi dị mma karịa ịchụ aja 
\q2 ịṅa ntị dị mma karịa abụba ebule. 
\q1  
\v 23 Nʼihi na nnupu isi dịka mmehie ịgba afa, 
\q2 mpako dịkwa njọ dịka ikpere arụsị. 
\q1 Nʼihi na ị jụla okwu \nd Onyenwe anyị\nd* 
\q2 ya onwe ya ajụkwala gị dịka eze.” 
\p  
\v 24 Sọl zara Samuel sị ya, “Emehiela m. Nʼezie, enupula m isi na ndụmọdụ gị na nʼiwu \nd Onyenwe anyị\nd*. Ọ bụ nʼihi na m tụrụ egwu ndị Izrel ka m ji mee ihe ha chọrọ.  
\v 25 Biko, gbaghara m mmehie m ugbu a, bịakwa soro m ka m gaa fee \nd Onyenwe anyị\nd* ofufe.” 
\p  
\v 26 Ma Samuel sịrị ya, “Agaghị m eso gị laghachi azụ. Ebe ị jụrụ okwu \nd Onyenwe anyị\nd*, \nd Onyenwe anyị\nd* ajụkwala gị dịka eze ndị Izrel!” 
\p  
\v 27 Mgbe Samuel tụgharịrị ka o si nʼebe ahụ pụọ, Sọl jidere ya nʼọnụ ọnụ uwe ya ime ka ọ lọghachi azụ, ma uwe ahụ dọwara.  
\v 28 Mgbe ahụ, Samuel zara sị ya, “Taa \nd Onyenwe anyị\nd* adọwapụla alaeze Izrel site nʼaka gị were ya nyefee otu nʼime ndị agbataobi gị, onye ka gị mma.  
\v 29 Chineke, onye bụ Ebube Izrel, anaghị agha ụgha; ọ nakwaghị agbanwe obi ya, nʼihi na ọ bụghị mmadụ efu!” 
\p  
\v 30 Ma Sọl malitekwara ịrịọ arịrịọ ọzọ sị, “Emehiela m. Ma, sọpụrụ m ugbu a nʼihu ndị okenye ndị m, na nʼihu ndị Izrel. Lọghachi soro m ka m gaa fee \nd Onyenwe anyị\nd* Chineke gị ofufe.”  
\v 31 Ya mere, Samuel kwenyere soro Sọl laghachi, Sọl kpọkwara isiala nye \nd Onyenwe anyị\nd*. 
\p  
\v 32 Mgbe ahụ, Samuel gwara ya okwu sị ya, “Kpọpụtara m Agag, eze ndị Amalek.” 
\p Agag ji ihu ọchị bịakwute ya, nʼihi na o chere sị, “Nʼezie oge ọnwụ agaala.” 
\p  
\v 33 Ma Samuel kwuru sị, 
\q1 “Dịka mma agha gị sị gbawa ndị inyom aka ụmụ 
\q2 otu a ka nne gị ga-esi bụrụ onye na-enweghị nwa nʼetiti ndị inyom.” 
\m Samuel gburu Agag nʼihu \nd Onyenwe anyị\nd* na Gilgal. 
\p  
\v 34 Emesịa, Samuel lara nʼụlọ ya na Rema. Ma Sọl laghachikwara na Gibea, obodo nke aka ya.  
\v 35 Site nʼoge ahụ ruo mgbe Samuel nwụrụ, ọ hụkwaghị Sọl anya ọzọ. Ma o rugidere ụjụ nʼihi Sọl oge ndị a niile. O wutekwara \nd Onyenwe anyị\nd* na o mere Sọl eze ndị Izrel. 
\c 16  
\s1 Samuel etee Devid mmanụ 
\p  
\v 1 Emesịa \nd Onyenwe anyị\nd* sịrị Samuel, “Ruo ole mgbe ka ị ga-anọgide na-eru ụjụ nʼihi Sọl, ebe ọ bụ na m ajụla ya dịka eze ndị Izrel? Ugbu a, gbajuo mmanụ na mpi gị, bilie ije. Ana m eziga gị ka ijekwuru Jesi onye Betlehem, ahọrọla m otu onye ga-abụ eze site nʼetiti ụmụ ya ndị ikom.” 
\p  
\v 2 Ma Samuel zara sị, “Oleekwanụ otu m ga-esi gaa nʼebe ahụ? Ọ bụrụ na Sọl anụ ya, ọ ga-egbu m.” 
\p \nd Onyenwe anyị\nd* sịrị, “Were nwaagbọghọ ehi, jiri ya nʼaka, sị, ‘Abịara m ịchụrụ \nd Onyenwe anyị\nd* aja.’  
\v 3 Ị ga-akpọ Jesi ka ọ bịa soro nʼọchụchụ aja ahụ. Mgbe ahụ, aga m egosi gị ihe ị ga-eme. Ị ga-etekwara m ya mmanụ, bụ onye m nke ga-egosi gị.” 
\p  
\v 4 Samuel mere ihe \nd Onyenwe anyị\nd* kwuru. Mgbe o rutere na Betlehem, ndị okenye obodo ahụ ji ịma jijiji pụta izute ya. Ha jụrụ ya sị “Ọ dịkwa mma? Udo ọ dịkwa?” 
\p  
\v 5 Ma Samuel zara ha sị “E, udo dị, Abịara m ịchụrụ \nd Onyenwe anyị\nd* aja. Doonụ onwe unu nsọ bịa soro m gaa ịchụ aja ahụ.” O dokwara Jesi na ụmụ ya ndị ikom nsọ, gwakwa ha ka ha soro gaa. 
\p  
\v 6 Mgbe ha ruru, Samuel hụrụ Eliab kwuo nʼobi ya sị, “Nʼezie, onye nke \nd Onyenwe anyị\nd* tere mmanụ na-eguzo nʼihu \nd Onyenwe anyị\nd*.” 
\p  
\v 7 Ma \nd Onyenwe anyị\nd* zara Samuel sị ya, “Ejila ihu mmadụ maọbụ ito ogologo ya ekpebi, nʼihi na onye a abụghị ya. \nd Onyenwe anyị\nd* adịghị ahụ ihe dịka mmadụ si ahụ. Mmadụ na-ele anya nʼelu ahụ, ma \nd Onyenwe anyị\nd* na-ele anya nʼobi.” 
\p  
\v 8 Jesi kpọrọ Abinadab ka ọ gafee nʼihu Samuel. Ma Samuel sịrị, “\nd Onyenwe anyị\nd* ahọrọghị onye a.”  
\v 9 Jesi mere ka Shama bịa gafee, ma Samuel sịrị, “Mba \nd Onyenwe anyị\nd* ahọrọghị onye a.”  
\v 10 Ụmụ ndị ikom Jesi asaa si otu a gafee nʼihu Samuel, ma Samuel sịrị ya, “\nd Onyenwe anyị\nd* ahọrọghị ndị a.”  
\v 11 Ọ jụrụ Jesi sị, “Ndị a ọ gwụchaala ụmụ ndị ikom ị mụtara?” 
\p Jesi zara sị “O fọdụrụ ọdụdụ nwa m, ma ọ nọ nʼọhịa na-azụ atụrụ.” 
\p Samuel sịrị, “Ziga ozi kpọlata ya, anyị agaghị anọdụ ala tutu ruo mgbe ọ bịara.” 
\p  
\v 12 Ọ zigara ozi ka akpọọ ya, mee ka ọ bịa. O nwere ụcha ahụ pụrụ iche, nwee anya mara mma, dịkwa mma ile anya. 
\p Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Samuel okwu sị ya, “Ọ bụ onye a, bilie tee ya mmanụ.” 
\p  
\v 13 Ya mere, Samuel weere mpi ahụ mmanụ dị tee ya nʼihu ụmụnne ya. Site nʼụbọchị ahụ Mmụọ \nd Onyenwe anyị\nd* bịakwasịrị Devid nʼebe ọ dị ukwuu. Emesịa, Samuel laghachiri na Rema. 
\s1 Devid aghọọ onye na-ejere Sọl ozi 
\p  
\v 14 Ugbu a, Mmụọ \nd Onyenwe anyị\nd* esitela nʼime Sọl pụọ, \nd Onyenwe anyị\nd* zitekwara mmụọ ọjọọ nke bịara na-esogbu Sọl. 
\p  
\v 15 Ndị na-ejere Sọl ozi gwara ya okwu sị, “Lee, mmụọ ọjọọ si nʼebe Chineke nọ bịa na-enye gị nsogbu.  
\v 16 Biko, ka onyenwe anyị nye ndị ohu ya nọ nʼebe a ike, ka ha gaa chọta onye maara akpọ ụbọ akwara nke ọma. Ọ ga-akpọ ụbọ akwara mgbe ọbụla mmụọ ọjọọ si nʼebe Chineke nọ bịa bịakwasịrị gị, ime ka ahụ dị gị mma.” 
\p  
\v 17 Sọl kwenyere sị ha, “Ọ dị mma, gaanụ chọta ma kpọtara m nwoke na-akpọ ụbọ akwara nke ọma.” 
\p  
\v 18 Otu onye nʼime ndị na-eje ozi kwuru sị, “Lee, ahụla m otu nʼime ụmụ ndị ikom Jesi, onye Betlehem, onye maara akpọ ụbọ akwara nke ọma. Ọ bụ dike na ọka nʼagha. Ọ bụ onye na-ekwu okwu nke ọma, na nwoke mara mma ile anya. \nd Onyenwe anyị\nd* nọnyekwara ya.” 
\p  
\v 19 Sọl zipụrụ ndị ozi ka ha jekwuru Jesi sị ya, “Zitere m nwa gị nwoke Devid, onye na-azụrụ gị atụrụ.”  
\v 20 Ya mere Jesi zipụrụ Devid ka o jekwuru Sọl. O mekwara ka Devid duru otu ịnyịnya ibu nke o bukwasịrị achịcha, na otu karama akpụkpọ mmanya, na otu nwa ewu, onyinye a na-enye Sọl. 
\p  
\v 21 Devid bịakwutere Sọl, banye nʼọrụ ijere ya ozi. Sọl hụrụ ya nʼanya nke ukwuu, nʼihi ya, Devid ghọrọ otu nʼime ndị na-ebu ihe agha Sọl.  
\v 22 Mgbe ahụ, Sọl ziri Jesi ozi sị ya, “Biko, kwere ka Devid bụrụ otu nʼime ndị agha m, nʼihi na ihe ya na-atọ m ụtọ.” 
\p  
\v 23 Mgbe ọbụla mmụọ ọjọọ ahụ si nʼebe Chineke nọ bịa malitere inye Sọl nsogbu, Devid na-akpọ ụbọ akwara ya. Ahụ Sọl na-adajụkwa, mmụọ ọjọọ ahụ na-esitekwa nʼebe ọ nọ wezuga onwe ya. 
\c 17  
\s1 Devid na Golaịat 
\p  
\v 1 Nʼoge a, ndị Filistia chịkọtara ndị agha ha ọnụ, zukọtaa nʼobodo Sokoh nke dị na Juda maka ibu agha. Ha mara ụlọ ikwu ha nʼEfes Damim, nke dị nʼagbata Sokoh na Azeka.  
\v 2 Mgbe ahụ, Sọl na ndị Izrel niile zukọtara maa ụlọ ikwu nke ha na ndagwurugwu Ịla. Ha doro onwe ha nʼusoro agha izute ndị Filistia.  
\v 3 Ndị Filistia doro onwe ha nʼelu ugwu nʼotu akụkụ, ma ndị Izrel dokwara onwe ha nʼelu ugwu nʼakụkụ nke ọzọ. Ndagwurugwu dịkwa nʼetiti ha. 
\p  
\v 4 Mgbe ahụ, otu onye ọka agha aha ya bụ Golaịat,\f + \fr 17:4 \ft Golaịat bụ onye si nʼagbụrụ ndị Anak, ndị Joshua kpochapụrụ nʼala Izrel niile, karịakwa ndị fọdụrụ na Gaza, Ashkelọn na Gat. \xt Jos 11:21-22\f* onye obodo Gat, sitere nʼetiti ụlọ ikwu ndị Filistia pụta. Nwoke a toro ogologo nke ukwuu; ịdị ogologo ya ga-erukwa mita atọ.  
\v 5 O kpu okpu agha e ji bronz kpụọ, ma yiri uwe agha nke ịdị arọ bronz e ji kpụọ ya ga-erukwa iri kilogram ise na asaa.  
\v 6 O yikwa ihe agha o ji kpuchie ụkwụ ya abụọ nke e ji bronz kpụọ, nyakwasịkwa nʼubu ya ùbe e ji bronz kpụọ.  
\v 7 A kpụrụ ùbe ya ka ọ dịrị ka osisi e ji ekwe akwa, jiri igwe ịdị arọ ya ga-eru kilogram asaa kpụọ ọnụ ọnụ ùbe ahụ. Onye na-ebu ọta o ji ekpuchi obi ya nọkwa nʼihu ya. 
\p  
\v 8 Golaịat guzoro kpọkuo ndị agha Izrel sị ha, “Gịnị mere unu ga-eji pụta guzo nʼusoro ibu agha. Ọ bụ na m abụghị onye Filistia? Ọ bụkwa na unu onwe unu abụghị ndị ozi Sọl? Họpụtaranụ onwe unu otu nwoke, ka ọ bịakwute m.  
\v 9 Ọ bụrụ na onye ahụ unu họpụtara etigbuo m, anyị ga-abụrụ unu ndị ohu, ma ọ bụrụkwanụ na m etigbuo ya, unu ga-abụrụ anyị ndị ohu!”  
\v 10 Mgbe ahụ, onye Filistia ahụ sịrị, “Taa, ana m ama usuu ndị agha Izrel aka nʼihu! Kpọpụtaranụ m otu nwoke ka mụ na ya lụọ ọgụ.”  
\v 11 Mgbe Sọl na ndị agha Izrel nụrụ ihe onye Filistia a kwuru, ha mara jijiji tụọkwa oke egwu. 
\p  
\v 12 Ma Devid bụ nwa Jesi, onye Efrat nke Betlehem dị na Juda. Jesi mụtara ndị ikom asatọ. Nʼoge nke Sọl, ọ ghọọla agadi nwoke.  
\v 13 Atọ nʼime ụmụ ndị ikom Jesi, ndị bụ okenye, soro Sọl gaa agha. Aha ha bụ Eliab, ọkpara ya, Abinadab, nwa nke abụọ na Shama, nwa nke atọ.  
\v 14 Devid bụ ọdụdụ nwa. Ụmụnne ya ndị okenye atọ na-eso Sọl.  
\v 15 Ma Devid na-apụ jekwuru Sọl, ma na-alaghachikwa nʼụlọ ịzụ atụrụ nna ya na Betlehem. 
\p  
\v 16 Golaịat, onye Filistia na-abịaru nso ụtụtụ na uhuruchi, na-eguzo onwe ya otu a iri ụbọchị anọ. 
\p  
\v 17 Otu ụbọchị, Jesi gwara Devid okwu sị, “Bịa ka i wegara ụmụnne gị otu akpa ọka ndị a e ghere eghe. Chịrịkwa ogbe achịcha iri ndị a chịlara ha.  
\v 18 Wegakwara onyeisi usuu ha, iri chiizi,\f + \fr 17:18 \ft Mmiri ara ehi kpụkọrọ akpụkọ\f* ndị a. Chọpụta otu ihe si agara ụmụnne gị\f + \fr 17:18 \ft \xt Jen 37:14\f* natakwa ha ihe ị ga-egosi anyị na ha dị ndụ.”  
\v 19 Ha na Sọl na ndị ikom Izrel niile, nọ na ndagwurugwu Ịla, na-ebuso ndị Filistia agha. 
\p  
\v 20 Devid biliri njem nʼisi ụtụtụ, hapụ igwe atụrụ ya nʼaka onye na-elekọta atụrụ, buru onyinye ndị ahụ gawa dịka Jesi nyere ya nʼiwu. Ọ bịarutere ụlọ ikwu ndị Izrel mgbe ha na-apụ nʼihu agha, ha na-etikwa mkpu agha.  
\v 21 Ndị Izrel na ndị Filistia dokwara onwe ha nʼusoro izute onwe ha nʼagha, ndị agha megide ndị agha.  
\v 22 Devid hapụrụ ihe ndị ahụ nʼaka onye na-elekọta akpa niile, gbara ọsọ gaa nʼusoro ndị agha jụọ ụmụnne ya banyere udo ha.  
\v 23 Ma mgbe ha na ya nọ na-akparịta ụka, onye mmeri nʼọgbọ agha, onye Filistia nke Gat, Golaịat bụ aha ya, sitere nʼusoro ndị agha Filistia pụta, kwuokwa okwu niile ahụ dịka ọ na-ekwu na mbụ. Devid nụrụ ihe o kwuru.  
\v 24 Mgbe ndị Izrel niile hụrụ nwoke a, ha gbara ọsọ pụọ nʼihu ya ma tụọkwa oke egwu. 
\p  
\v 25 Ndị Izrel sịrị, “Unu hụrụ nwoke a na-eguzo onwe ya? Ọ bụ ka ọ kparịa nnọọ ndị Izrel ka o ji apụta? Eze kwere nkwa inye onye ọbụla ga-etigbu ya akụ nʼebe ọ bara ụba. Ọ ga-akpọnyekwa ya nwa ya nwanyị ka ọ bụrụ nwunye ya, meekwa ka ndị ezinaụlọ onye ahụ gharakwa ịtụ ụtụ taks ọzọ nʼIzrel!” 
\p  
\v 26 Devid jụrụ ndị ikom nọ ya nso, “Gịnị ka a ga-emere nwoke ga-etigbu onye Filistia a, meekwa ka mkparị a ghara ịdịrị Izrel ọzọ? Onye ka onye Filistia a a na-ebighị ugwu bụ, na ọ ga-apụta na-akparị ndị agha Chineke dị ndụ?” 
\p  
\v 27 Ha gwara ya otu ihe ahụ ha kwuru na mbụ sị ya na ọ bụ ihe ahụ ka a ga-emere onye gburu ya. 
\p  
\v 28 Mgbe Eliab, nwanne Devid nke okenye, nụrụ ka ya na ndị ikom ahụ na-ekwu okwu, o were iwe dị ọkụ megide ya, jụọ ya sị, “Gịnị ka ị bịara ime nʼebe a? Onye kwa ka ị hapụrụ atụrụ ole na ole ndị ahụ nʼọzara? Amaara m ụdị nganga dị nʼime gị na echiche ọjọọ juru gị obi. Ihe ị ji bịa nʼebe a bụ naanị ka ịhụchata ihe na-eme nʼagha.” 
\p  
\v 29 Ma Devid zara sị ya, “Oleekwanụ ihe m mere ugbu a? Adara m iwu nʼihi na m jụrụ ajụjụ?”  
\v 30 Devid chigharịkwara jekwuru onye ọzọ jụọkwa ya otu ajụjụ ahụ. Ọ natakwara otu ụdị ọsịsa ahụ.  
\v 31 Nʼikpeazụ, mgbe a matara ihe bụ uche Devid, e mere ka Sọl mara ihe banyere Devid. Sọl zikwara ozi ka a kpọọ ya. 
\p  
\v 32 Devid sịrị Sọl, “Ka obi onye ọbụla ghara ịda mba nʼihi onye Filistia a; ohu gị ga-aga lụso ya ọgụ.” 
\p  
\v 33 Ma Sọl zaghachiri, “Ị pụghị ibuso onye Filistia a agha, megide ya, nʼihi na i bụ naanị nwantakịrị, ma ya onwe ya bu onye na-ebu agha siterị na mgbe ọ bụ okorobịa.” 
\p  
\v 34 Ma Devid gwara Sọl sị, “Ohu gị bụ onye na-elekọta atụrụ nna ya. Mgbe ọdụm maọbụ anụ ọhịa bịa bịara buru atụrụ site nʼigwe atụrụ ahụ,  
\v 35 achụụrụ m ya, tigbuo ya ma napụtakwa atụrụ ahụ site nʼọnụ ya. Mgbe o biliri imegide m, ejidere m ya nʼajị ya, tie ya ihe, gbuo ya.  
\v 36 Etigburu m ọdụm na anụ ọhịa bịa ahụ, ugbu a, apụkwara m ime onye Filistia a na-amaghị Chineke otu ihe ahụ, nʼihi na ọ kparịala usuu ndị agha Chineke dị ndụ!  
\v 37 \nd Onyenwe anyị\nd* ahụ napụtara m site nʼaka ọdụm na anụ ọhịa bịa ga-anapụtakwa m site nʼaka onye Filistia a!” 
\p Nʼikpeazụ, Sọl sịrị Devid, “Gaa, ka \nd Onyenwe anyị\nd* nọnyere gị.” 
\p  
\v 38 Mgbe ahụ, Sọl yinyere Devid uwe ime ahụ nke ya, yikwasịkwa ya uwe agha igwe, ma kpukwasị ya okpu bronz nʼisi.  
\v 39 Devid fanyere mma agha nʼime uwe ahụ, malite ijegharị ije, nʼihi na ọ maghị otu e si eyi uwe ndị ahụ ejegharị. 
\p Ọ dịghị anya, o gwara Sọl okwu sị, “Agaghị m eyi uwe ndị a nʼihi na o doghị m ahụ.” Ya mere, Devid yipụrụ ha.  
\v 40 Emesịa, o were mkpanaka ya nʼaka ya, site nʼiyi họpụta nkume ise dị mụrụmụrụ tinye ha nʼakpa nta dị nʼime akpa onye ọzụzụ atụrụ ya. O jidere ebe ya nʼaka ya, malite ịpụkwuru onye Filistia ahụ. 
\p  
\v 41 Onye Filistia ahụ, na-abịa nso na-apụkwute Devid, onye ahụ na-ebu ọta ya na-agakwa nʼihu ya.  
\v 42 O lere Devid anya hụ na ọ bụ naanị nwantakịrị nwoke, onye ahụ dị mma, onye mara mma ile anya. Nʼihi ya, o ledara Devid anya.  
\v 43 Ọ sịrị Devid, “Abụ m nkịta, na i ji mkpanaka na-abịakwute m?” Onye Filistia ahụ ji aha chi niile ya bụọ Devid ọnụ.  
\v 44 Ọ sịrị, “Bịa nʼebe a ka m were anụ ahụ gị mere anụ ufe nke eluigwe na anụ ọhịa niile ihe oriri!” 
\p  
\v 45 Ma Devid sịrị onye Filistia ahụ, “I ji mma agha na ùbe igwe na ùbe osisi, na-abịakwute m, ma eji m aha \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, Chineke nke usuu ndị agha Izrel ahụ ị kparịrị, na-abịakwute gị.  
\v 46 Taa ka \nd Onyenwe anyị\nd* ga-enyefe gị nʼaka m. Aga m etigbu gị, bepụkwa gị isi. Taa aga m ewere anụ ahụ ndị agha Filistia niile nyefee nʼaka ụmụ anụ ufe niile nke eluigwe, na ụmụ anụ ọhịa niile nke ụwa. Ụwa niile ga-amatakwa na Chineke nọ nʼIzrel.  
\v 47 Ndị niile guzokwa nʼebe a ga-amata na \nd Onyenwe anyị\nd* adịghị eji mma agha maọbụ ùbe azọpụta. Nʼihi na agha a bụ nke \nd Onyenwe anyị\nd*, ọ ga-ewerekwa unu niile nyefee anyị nʼaka.” 
\p  
\v 48 Mgbe onye Filistia ahụ na-abịa nso ibuso ya agha, Devid jiri ọsọ gbara gaa nʼihu agha izute ya.  
\v 49 Ọ manyere aka nʼime akpa ya wepụta otu nkume, maa ya mata onye Filistia ahụ nʼegedege ihu. Nkume ahụ mikpuru nʼegedege ihu ya, ọ dakwara kpuo ihu nʼala. 
\p  
\v 50 Otu a ka Devid si jiri ebe na nkume merie onye Filistia ahụ. O gburu onye Filistia ahụ ma o jighị mma ọbụla nʼaka ya gbuo ya. 
\p  
\v 51 Devid gbaara ọsọ jeruo nʼebe Golaịat dara, mịịrị mma agha ya site nʼọbọ, jiri ya gbuo ya. O ji ya bepụkwa isi ya! 
\p Mgbe ndị Filistia hụrụ na onye ọka agha ha adaala nwụọ, ha tụgharịrị gbawa ọsọ.  
\v 52 Mgbe ahụ, ndị agha Izrel na Juda tiri mkpu ọṅụ, biliekwa, malite ịchụ ndị Filistia ọsọ. Ha chụrụ ha ọsọ chụruo ha nʼọnụ ụzọ ama Gat, na nʼọnụ ụzọ ama Ekrọn. Ndị Filistia nwụrụ anwụ dara nnọọ aghara aghara nʼụzọ Shaaraim nke gawara Gat na Ekrọn.  
\v 53 Emesịa, ndị Izrel lọghachiri bịa kwakọrọ ihe niile dị nʼụlọ ikwu ndị Filistia, nke ha hapụrụ gbaa ọsọ. 
\p  
\v 54 Devid buuru isi onye Filistia bulata na Jerusalem. Ma dobe ngwa agha onye Filistia ahụ nʼime ụlọ ikwu nke ya. 
\p  
\v 55 Mgbe Sọl nọ na-ele Devid anya ka ọ na-apụ izute onye Filistia ahụ, ọ sịrị Abna, ọchịagha ya, “Abna, nwa onye ka nwokorobịa ahụ bụ?” 
\p Abna zara sị, “Dịka i si adị ndụ, eze, amaghị m.” 
\p  
\v 56 Eze zara sị, “Chọpụta onye mụrụ nwokorobịa a.” 
\p  
\v 57 Mgbe Devid si nʼigbu onye Filistia ahụ lọghachi, Abna duuru ya, dute ya nʼihu Sọl. Isi onye Filistia a dịkwa nʼaka Devid. 
\p  
\v 58 Sọl jụrụ ya sị, “Nwokorobịa, nwa onye ka ị bụ?” 
\p Devid zara sị, “Abụ m nwa ohu gị nwoke Jesi onye Betlehem.” 
\c 18  
\s1 Ekworo Sọl 
\p  
\v 1 Mgbe Devid gwasịrị Sọl okwu, ịhụnanya dị ukwuu malitere nʼetiti Jonatan na Devid. Jonatan hụrụ Devid nʼanya dịka o si hụ onwe ya.  
\v 2 Sọl mere ka Devid nọgide nʼụlọeze. O kwekwaghị ka ọ laghachi nʼụlọ nna ya.  
\v 3 Jonatan na Devid gbara ndụ nʼihi na Jonatan hụrụ Devid nʼanya dịka o si hụ onwe ya.  
\v 4 Jonatan yipụtara uwe o yi nʼahụ nye ya Devid, nyekwa ya uwe ime ahụ ya, na ọ bụladị mma agha ya, ma ụta ya na eriri ukwu\f + \fr 18:4 \ft Maọbụ, \fqa belịt\f* ya. 
\p  
\v 5 Devid jeziri ozi niile Sọl ziri ya, o mere ihe niile nke ọma nke a mere na Sọl nyere ya ọkwa dị elu nʼetiti ndị agha ya. Ọnọdụ a dị mma nʼanya ndị Izrel nakwa nʼanya ndị agha Sọl. 
\p  
\v 6 Mgbe ndị agha ahụ na-alọghachite, mgbe Devid gbusịrị onye Filistia\f + \fr 18:6 \ft Ya bụ, Golaịat\f* ahụ, ndị inyom\f + \fr 18:6 \ft \xt Ọpụ 15:20\f* sitere nʼobodo niile nke Izrel pụta izute eze Sọl. Ha na-abụ abụ na-ete egwu ọṅụ, nke ha ji ụbọ akwara na ihe egwu ndị ọzọ na-eti.  
\v 7 Dịka ha na-ete egwu, ha bụrụ abụ sị, 
\q1 “Sọl egbuola ọtụtụ puku ndị agha 
\q2 ma Devid egbuola iri puku kwụrụ puku ndị agha.” 
\p  
\v 8 Nke a were Sọl iwe nke ukwuu. O kwuru nʼime onwe ya sị, “Gịnị bụ nke a? Ha enyela Devid ugwu dịka onye gburu iri puku kwụrụ puku ndị agha, ma mụ onwe m ka ha nyere naanị ugwu dịka onye gburu ọtụtụ puku ndị agha. Gịnị ọzọ fọdụrụ ya ugbu a, ma ọ bụghị naanị inweta alaeze?”  
\v 9 Site nʼụbọchị ahụ gawa, Sọl malitere ile Devid anya ọjọọ. 
\p  
\v 10 Nʼechi ya, mmụọ ọjọọ Chineke zitere bịara dakwasị Sọl, ọ malitekwara ibu amụma nʼụlọ ya. Ma Devid kpọrọ ụbọ akwara dịka ọ na-eme mgbe ọbụla. Ma nʼoge a, o nwere ùbe dị Sọl nʼaka.  
\v 11 Ọ tụrụ ùbe ahụ, kwuo nʼobi ya sị, “Aga m atụgide Devid nʼaja ụlọ ahụ.” Ma Devid wezugara onwe ya, ugboro abụọ ndị a. 
\p  
\v 12 Sọl na-atụ Devid egwu, nʼihi na \nd Onyenwe anyị\nd* ahapụla Sọl, ma nọnyere Devid.  
\v 13 Emesịa, Sọl mere ihe ga-eme ka ọ ghara ịhụkwa Devid anya ọzọ. O mere Devid ka ọ bụrụ onye na-elekọta puku ndị agha, ndị ọ na-edu na-aga ibu agha.  
\v 14 Ma ihe niile ọ na-eme na-agara ya nke ọma, nʼihi na \nd Onyenwe anyị\nd* na-anọnyere ya.\f + \fr 18:14 \ft \xt Jen 39:2,3,23; Jos 6:27; 1Sa 16:18\f* 
\v 15 Mgbe Sọl hụrụ na ọ bụ onye nwere uche nke ọma, ọ tụrụ ya ụjọ.  
\v 16 Ma Izrel na Juda niile hụrụ Devid nʼanya, nʼihi na ọ na-edu ha nʼagha. 
\p  
\v 17 Sọl gwara Devid okwu sị ya, “Lee ada m nwanyị Merab. Aga m akpọnye gị ya, ka ị lụọ ya. Naanị jeere m ozi, lụọkwa agha \nd Onyenwe anyị\nd*.” Nʼihi na Sọl kwuru nʼime obi ya sị, “Agaghị m ewelite aka m megide ya. Ka ndị Filistia mee nke ahụ.” 
\p  
\v 18 Ma Devid sịrị Sọl, “Onyekwanụ ka m bụ, gịnịkwa bụ ezinaụlọ m maọbụ agbụrụ m nʼIzrel, nke m ga-eji bụrụ ọgọ nwoke eze?”  
\v 19 O ruo, na mgbe a ga-eduru Merab, ada Sọl dunye Devid, akpọrọ ya nye Adriel, onye Mehola ka ọ lụọ. 
\p  
\v 20 Nʼoge a, a chọpụtara na Mikal, ada Sọl hụrụ Devid nʼanya, mgbe e mere ka Sọl mata nke a, obi tọrọ ya ụtọ.  
\v 21 O kwuru nʼobi ya sị, “Aga m akpọnye ya nwa m nwanyị, ka ọ bụrụ ihe ịma nʼọnya nye ya, ka aka ndị Filistia si otu a megide ya.” Ya mere, Sọl gwara Devid sị ya, “Ugbu a i nwekwara ohere ọzọ ịghọ ọgọ m nwoke.” 
\p  
\v 22 Sọl nyere ndị ohu ya iwu sị, “Gwanụ Devid okwu na nzuzo sị ya, ‘Lee, ihe banyere gị masịrị eze, ndị niile na-ejere ya ozi hụkwara gị nʼanya. Ugbu a, kwerenụ ịbụ ọgọ ya.’ ” 
\p  
\v 23 Ha gwara Devid okwu ndị a niile. Ma Devid zara sị, “Ọ bụ ihe nta ịbụ ọgọ eze? Mụ onwe m bụ onye ogbenye, onye a na-amaghị ama.” 
\p  
\v 24 Mgbe ndị ohu Sọl gwara Sọl ihe Devid kwuru,  
\v 25 ọ gwara ha sị, “Gwanụ Devid, ‘Eze achọghị ihe ọzọ dịka ụgwọ isi akụ ọbụla karịa naanị narị apị ndị Filistia. Ka ọ bụrụ ọbọ ọ ga-abọrọ m nʼisi ndị iro m.’ ” Ma ihe Sọl bu nʼobi bụ na a ga-egbu Devid nʼọgụ ahụ. 
\p  
\v 26 Mgbe ndị ohu eze gwara Devid ihe eze kwuru, ọ tọrọ ya ụtọ, nʼihi ya, o kwenyere ịbụ ọgọ eze. Tupu oge ahụ a kara aka eruo,  
\v 27 Devid na ndị agha ya pụrụ gbuo narị ndị Filistia abụọ, werekwa apị ha gosi eze. Sọl kpọnyere Devid Mikal, nwa ya nwanyị, ka ọ bụrụ nwunye ya. 
\p  
\v 28 Mgbe Sọl hụrụ na \nd Onyenwe anyị\nd* na-anọnyere Devid, hụkwa na Mikal nwa ya nwanyị hụrụ Devid nʼanya,  
\v 29 ọ tụrụ Devid ụjọ karịa na mbụ. Sọl kpọkwara Devid asị, gụọ ya dịka onye iro ụbọchị ndụ ya niile. 
\p  
\v 30 Ndịisi agha Filistia na-apụta ibu agha dịka ha na-eme mgbe ọbụla, ma Devid na-eme nke ọma karịa ndị ọchịagha Sọl ndị ọzọ niile. Nke a mere ka Devid ghọọ onye a mara aha ya nʼala ahụ niile. 
\c 19  
\s1 Sọl agbalịa igbu Devid 
\p  
\v 1 Sọl gwara ndị ohu ya na ọkpara ya, Jonatan, ka ha gbuo Devid. Ma nʼihi na ihe banyere Devid masịrị Jonatan,  
\v 2 ọ dọrọ ya aka na ntị, “Nna m Sọl na-achọ ohere igbu gị. Lezie anya chee ndụ gị nche, ụtụtụ echi, gaa nʼebe ị ga-ezo onwe gị nọdụ nʼebe ahụ.  
\v 3 Mụ na nna m ga-eso bịa nʼakụkụ ọhịa ebe ahụ i zoro onwe gị. Aga m agwa ya okwu banyere gị. Ihe ọbụla m chọpụtara, aga m agwa gị.” 
\p  
\v 4 Jonatan kwuru okwu ọma banyere Devid nye Sọl nna ya sị ya, “Ka eze ghara ime ihe ọjọọ megide Devid bụ ohu ya. O nwebeghị ihe ọjọọ o mere gị. Nʼezie, ihe niile o mere bụ ihe baara gị uru nke ukwuu.  
\v 5 Ọ kpọrọ ndụ ya asị mgbe o gburu onye Filistia ahụ. \nd Onyenwe anyị\nd* nyekwara ndị Izrel niile mmeri dị ukwuu. Obi dịkwa gị ụtọ mgbe ị hụrụ nke a. Gịnị mekwaranụ i ga-eji mejọọ nwoke aka ya dị ọcha dịka Devid, site nʼigbu ya ebe ọ bụ na ikpe amaghị\f + \fr 19:5 \ft Maọbụ, \fqa na e nweghị ihe o mere\f* ya?” 
\p  
\v 6 Sọl ṅara Jonatan ntị ṅụọkwa iyi sị, “Dịka \nd Onyenwe anyị\nd* na-adị ndụ, agaghị egbu ya.” 
\p  
\v 7 Emesịa, Jonatan kpọrọ Devid gwa ya ihe mere. Jonatan duuru Devid gaa nʼihu Sọl. Ihe niile dizikwara dịka ọ dị na mbụ. 
\p  
\v 8 Agha ọzọ dakwara. Nʼoge a, Devid duuru ndị agha ya pụọ ibuso ndị Filistia agha. O gburu ọtụtụ nʼime ha, chụọkwa ndị agha Filistia ọsọ. 
\p  
\v 9 Ma mmụọ ọjọọ \nd Onyenwe anyị\nd* zitere bịakwasịrị Sọl dịka ọ nọ nʼime ụlọ ya, ùbe ya dịkwa ya nʼaka. Mgbe Devid na-akpọ nʼụbọ akwara,  
\v 10 Sọl tụrụ ùbe ahụ ka ọ tugbuo Devid nʼahụ aja, ma ọ gbapụrụ site nʼihu Sọl, ma ùbe ahụ manyere nʼaja ụlọ ahụ. Devid gbapụrụ ọsọ zoo onwe ya nʼabalị ahụ. 
\p  
\v 11 Sọl zipụrụ ndị agha ka ha chee ụlọ Devid nche, gbuo ya mgbe ọ pụtara nʼụtụtụ. Ma Mikal nwunye Devid gwara ya sị, “Ọ bụrụ na ị gbapụghị, zoo onwe gị nʼabalị a, onye nwụrụ anwụ ka ị ga-abụ nʼụtụtụ echi.”  
\v 12 Ya mere, Mikal sitere na oghereikuku wetuo Devid, ebe o si gbapụ.  
\v 13 Emesịa, Mikal kwagharịrị ihe ndina Devid, were ihe a kpụrụ akpụ tụkwasị nʼelu ya, werekwa akwa kpuchie ya, tinye ihe ajị ewu nʼebe isi ya. 
\p  
\v 14 Mgbe ndị agha ahụ bịaruru ijide Devid na ịkpụgara ya Sọl, Mikal gwara ha sị, “Ahụ esighị ya ike.” 
\p  
\v 15 Mgbe ahụ, Sọl zighachiri ndị ahụ azụ nʼebe Devid nọ si ha, “Bute ya na ihe ndina o dina nʼelu ya, ka m gbuo ya.”  
\v 16 Mgbe ndị ikom ahụ batara, ha hụrụ ihe a kpụrụ akpụ ka ọ dị nʼelu ihe ndina, hụkwa ajị ewu ka ọ dị nʼakụkụ ebe isi nke ihe ndina ahụ. 
\p  
\v 17 Sọl jụrụ Mikal sị, “Gịnị mere i ji ghọgbuo m otu a, mee ka onye iro m gbalaga?” 
\p Mikal zara, “Ọ bụ ya sịrị m, ‘Hapụ m ka m pụọ, nʼihi gịnị ka m ga-eji gbuo gị?’ ” 
\p  
\v 18 Mgbe Devid gbara ọsọ gbalaga, ọ gakwuru Samuel na Rema, kọrọ ya ihe niile Sọl mere ya. Ya na Samuel gara biri na Naịọt.  
\v 19 Ozi ruru Sọl ntị, “Devid nọ na Naịọt nʼime Rema,”  
\v 20 ya mere, o zipụrụ ndị ikom ka ha gaa jide ya. Ma mgbe ha rutere, ha hụrụ otu ndị amụma ka ha na-ebu amụma, hụkwa Samuel ka ọ na-eguzo nʼebe ahụ dịka onyeisi ha. Mmụọ nke Chineke bịakwasịrị ndị ozi Sọl ahụ, mee ka ha malitekwa ibu amụma.  
\v 21 Mgbe Sọl nụrụ ihe mere, o zipụkwara ndị agha ọzọ, ma ha onwe ha bukwara amụma! Otu ihe ahụ mekwara ndị o zipụrụ nke ugboro atọ.  
\v 22 Nʼikpeazụ ya onwe ya pụrụ gaa Rema, ruo nʼolulu mmiri Seku. Ọ jụrụ, “Ebee ka Samuel na Devid nọ?” 
\p Ha sịrị, “Ha nọ na Naịọt nke Rema.” 
\p  
\v 23 Ya mere, Sọl gara Naịọt nke dị na Rema. Ma Mmụọ nke Chineke bịakwasịrị ya, dịka ọ na-aga nʼụzọ ọ malitere ibu amụma tutu ruo mgbe ọ bịaruru Naịọt.  
\v 24 O yipụrụ uwe ya buo amụma nʼihu Samuel. Ọ gba ọtọ dinara ala nʼebe ahụ ehihie ahụ, na abalị ahụ niile. Ọ bụ nke a mere ndị mmadụ ji sị, “Sọl ọ ghọọla otu nʼime ndị amụma?” 
\c 20  
\s1 Devid na Jonatan 
\p  
\v 1 Devid sitere na Naịọt nʼime Rema gbapụ ọsọ, chọta Jonatan, sị ya, “Ọ bụ gịnị ka m mere? Gịnị bụkwa ihe ọjọọ m mere? Olee ụzọ m si mejọọ nna gị, mere o ji na-achọsi ike ka ọ napụ m ndụ m?” 
\p  
\v 2 Jonatan sịrị ya, “Nke a abụghị eziokwu. Ị gaghị anwụ! Ihe dị otu a adịghị nna m nʼobi, nʼihi na ọ na-agwa m ihe ọbụla ọ na-ezube ime, ọ bụladị ihe ukwu maọbụ ihe ntakịrị. Amakwaara m na ọ gaghị ezonarị m ihe dị otu a. Mba, ọ bụghị eziokwu.” 
\p  
\v 3 Devid ṅụrụ iyi sị, “Nna gị maara nke ọma na m anatala amara nʼebe ị nọ, nʼihi ya, o kwuola nʼime onwe ya sị, ‘Agaghị m agwa Jonatan, ka ọ ghara iwute ya.’ Ma eji m \nd Onyenwe anyị\nd* na mkpụrụobi gị na-aṅụ iyi na-asị na ọ bụ naanị otu nzọ ụkwụ dị ugbu a nʼetiti mụ na ọnwụ.” 
\p  
\v 4 Jonatan sịrị Devid, “Ihe ọbụla ị chọrọ ka m mee, aga m emere gị ya.” 
\p  
\v 5 Devid sịrị ya, “Lee echi ga-abụ mmemme ọnwa ọhụrụ, e kwesiri m iso eze rie nri. Ma hapụ m ka m ga zoo onwe m nʼọhịa tutu ruo uhuruchi nke nwanne echi.  
\v 6 Ọ bụrụ na nna gị ajụọ ase m, sị ya, ‘Devid rịọsiri m arịrịọ ike ka m hapụ ya ka ọ gbaga Betlehem, bụ obodo ya, nʼihi a na-achụ aja nke dịrị agbụrụ ya kwa afọ.’  
\v 7 Ọ bụrụ na ọ sị, ‘Ọ dị mma,’ mgbe ahụ, udo ga-adịrị ohu gị. Ma ọ bụrụ na o wee iwe nke ukwuu, mara nʼezie na o zubere ime m ihe ọjọọ.  
\v 8 Ma gị onwe gị, meere ohu gị ebere, nʼihi na i meela ka o sooro gị baa nʼọgbụgba ndụ nʼihu \nd Onyenwe anyị\nd*. Ọ bụrụ na ikpe mara m, gị onwe gị gbuo m. Nʼihi gịnị ka ị ga-eji nyefee m nʼaka nna gị?” 
\p  
\v 9 Jonatan sịrị, “Agaghị m eme ya, lee, a sịkwa na m maara na nna m na-achọ igbu gị, ọ bụ na m agaghị agwa gị?” 
\p  
\v 10 Devid jụrụ ya, “Onye ga-agwa m ma ọ bụrụ na nna gị aza gị okwu ike ike?” 
\p  
\v 11 Jonatan sịrị ya, “Bịa ka anyị pụọ gaa nʼọhịa.” Ya mere, ha abụọ pụrụ jee nʼọhịa. 
\p  
\v 12 Jonatan gwara Devid sị, “Eji m aha \nd Onyenwe anyị\nd*, Chineke Izrel na-ekwe nkwa na-asị gị, nʼoge ugbu a echi, maọbụ nwanne echi, aga m akpanyere nna m ụka banyere gị, meekwa ka ị mata ihe ọ na-eche banyere gị. Ọ bụrụ na obi dị ya mma nʼebe ị nọ, aga m eme ka ị mata.  
\v 13 Ma ọ bụrụ na nna m na-achọ imerụ gị ahụ, ka \nd Onyenwe anyị\nd* mesoo Jonatan mmeso, otu ọbụla o si dị njọ, ma ọ bụrụ na m abịaghị gwa gị, zilaga gị ka ị laa nʼudo. Ka \nd Onyenwe anyị\nd* nọnyere gị dịka o si nọnyere nna m.  
\v 14 Chetakwa, i ghaghị igosi m ịhụnanya na obi ebere \nd Onyenwe anyị\nd*, ma ọ bụrụ na m anwụọ.  
\v 15 E wezugakwala ịhụnanya gị na obi ebere gị site nʼebe ezinaụlọ m dị, ọ bụladị mgbe \nd Onyenwe anyị\nd* bipụchara ndị iro Devid niile site nʼelu ụwa.” 
\p  
\v 16 Jonatan na ụlọ Devid gbara ndụ. O kwuru sị, “Ka \nd Onyenwe anyị\nd* kpee ndị iro Devid niile ikpe.”  
\v 17 Jonatan mere ka Devid site nʼịhụnanya ọ hụrụ ya ṅụọra ya iyi. Nʼihi na Jonatan hụrụ Devid nʼanya dịka ọ hụrụ onwe ya. 
\p  
\v 18 Mgbe ahụ, Jonatan sịrị Devid, “Echi bụ mmemme ọnwa ọhụrụ. A ga-ele anya gị, nʼihi na ọnọdụ gị ga-atọgbọrọ nʼefu.  
\v 19 Nwanne echi ya, nʼoge uhuruchi, gaa nʼebe ahụ i zoro onwe gị mgbe nsogbu a malitere, chere nʼebe ahụ, nʼakụkụ nkume Ezel.  
\v 20 Aga m abịa gbaa àkụ atọ nʼakụkụ ya dịka a ga-asị na o nwere ihe m chọrọ iji ụta m gbata.  
\v 21 Emesịa, aga m ezipu otu nwantakịrị sị ya, ‘Gaa chọta àkụ ndị ahụ.’ Ọ bụrụ na ị nụ ka m na-agwa ya okwu sị, ‘Lee àkụ ndị a dị nʼakụkụ azụ gị, chita ha ebe a,’ mgbe ahụ, pụta nʼihi, dịka \nd Onyenwe anyị\nd* na-adị ndụ, udo dịrị gị, egwu ọbụla adịghị.  
\v 22 Ma ọ bụrụ na m agwa nwantakịrị ahụ okwu sị ya, ‘Lee, àkụ ahụ dị nʼihu gị,’ ọ pụtara na ị ghaghị isi nʼebe a pụọ, nʼihi na \nd Onyenwe anyị\nd* ezipụla gị.  
\v 23 Ma ihe banyere okwu ahụ anyị kwuru, cheta na \nd Onyenwe anyị\nd* bụ onye akaebe, nʼetiti mụ na gị ruo mgbe ebighị ebi.” 
\p  
\v 24 Ya mere, Devid gara zoo onwe ya nʼọhịa. Mgbe oge mmemme ọnwa ọhụrụ ruru, eze Sọl nọdụrụ ala iri nri.  
\v 25 Ọ nọdụrụ ọdụ nʼakụkụ aja ụlọ, bụ ebe ọ dị mbụ anọ, na ncherita ihu Jonatan. Abna nọdụrụ nʼakụkụ Sọl, ma oche Devid na-anọ enweghị onye nọ ya.  
\v 26 Sọl ekwughị ihe ọbụla banyere ya nʼụbọchị ahụ, nʼihi na o chere na ọ dị ihe ndaba mere, nke tinyere Devid nʼọnọdụ adịghị ọcha.\f + \fr 20:26 \ft \xt Lev 7:20-21; 15:1-5\f* Sọl kwuru nʼobi ya sị, “E, ọ ghaghị ịbụ ihe kpatara ya.”  
\v 27 Ma nʼechi ya, bụ abalị nke abụọ nke ọnwa ọhụrụ, ọnọdụ Devid tọgbọrọ nʼefu ọzọ. Mgbe ahụ, Sọl sịrị nwa ya Jonatan, “Gịnị mere nwa Jesi abịaghị iso rie nri, ma ụnyaahụ ma taa?” 
\p  
\v 28 Jonatan zara sị, “Devid rịọrọ sị m nye ya ike ka ọ gaa Betlehem.  
\v 29 Ọ sịrị m, ‘Kwere ka m gaa nʼihi na ndị ezinaụlọ anyị nwere aja mmemme ha na-eme nʼobodo. Nwanne m nwoke nyere m iwu sị m na m aghaghị ịbịa. Ọ bụrụ na m ahụta amara nʼebe ị nọ, biko kwere ka m gaa hụ ụmụnne m.’ Ọ bụ nke a mere ọ bịaghị na tebul eze.” 
\p  
\v 30 Iwe were Sọl nke ukwuu. Ọ gwara Jonatan okwu nʼiwe sị ya, “Gị nwa nke nwanyị na-enupu isi, nke uche ya gbagọrọ agbagọ. Ị na-eche na m amaghị na i dịnyere nwa Jesi si otu a wetara onwe gị na nne gị ihe ihere?  
\v 31 Nʼihi na ụbọchị niile nwa Jesi dị ndụ nʼụwa a, ọnọdụ gị na alaeze gị agaghị eguzosi ike. Ugbu a, pụọ, zipụ ozi kpọtara m ya ka m gbuo ya!” 
\p  
\v 32 Jonatan jụrụ nna ya Sọl sị, “Gịnị ka o mere? Nʼihi gịnị ka a ga-eji mee ka ọ nwụọ?”  
\v 33 Ma Sọl tụrụ ùbe o ji nʼaka ya ka o jiri ya tugbuo Jonatan, ma Jonatan zere ya. Nke a mere ka Jonatan mata nʼezie na nna ya na-achọ igbu Devid. 
\p  
\v 34 Jonatan si na tebul ahụ bilie nʼoke iwe pụọ, o righịkwa nri nʼụbọchị nke abụọ nke mmemme ahụ, nʼihi na omume ihere nna ya mesoro Devid wutere ya hie nne. 
\p  
\v 35 Nʼụtụtụ echi ya, dịka ha kara aka, Jonatan gara nʼọhịa, ya na nwantakịrị nwoke so gaa.  
\v 36 Ọ sịrị nwantakịrị nwoke ahụ, “Gbara ọsọ gaa chọta àkụ ndị ahụ niile m na-agba.” Mgbe nwantakịrị ahụ na-agba ọsọ na-aga, Jonatan gbapụrụ àkụ, gbafee ya nʼihu nwantakịrị ahụ.  
\v 37 Mgbe nwokorobịa ahụ na-ejeru nso ebe àkụ ahụ Jonatan gbara dị, Jonatan kpọkuru ya sị ya, “Àkụ ahụ dị nʼihu gị.”  
\v 38 Mgbe ahụ, o tiri mkpu sị, “Mee ngwangwa! Gawa ọsịịsọ! Eguzokwala!” Nwokorobịa ahụ chịkọtara àkụ ndị ahụ niile gbaghachikwute nna ya ukwu.  
\v 39 Ma nwantakịrị nwoke ahụ aghọtaghị ihe Jonatan mere; ma Jonatan na Devid maara ihe gara.  
\v 40 Jonatan nyere nwokorobịa ahụ ụta ya na àkụ ndị ahụ ka ọ chighachi ha nʼobodo. 
\p  
\v 41 Mgbe nwokorobịa ahụ lara, Devid biliri site nʼakụkụ ndịda nkume ahụ ebe o zoro onwe kpuo ihu ya nʼala, kpọọ isiala ugboro atọ, nʼihu Jonatan. Ha suritere onwe ha ọnụ, bekọkwaa akwa. Ma Devid kwara akwa karịa. 
\p  
\v 42 Nʼikpeazụ, Jonatan gwara Devid okwu sị, “Gaa nʼudo, nʼihi na anyị ejirila aha \nd Onyenwe anyị\nd* ṅụọ iyi ịbụ enyi nʼetiti onwe anyị, na-asị, ‘\nd Onyenwe anyị\nd* bụ onye akaebe nʼebe mụ na gị, na nʼebe ụmụ ụmụ m, na ụmụ ụmụ gị nọ ruo mgbe ebighị ebi.’ ” Ha kewara. Devid malitere ịpụ, ma Jonatan tụgharịrị baa nʼobodo. 
\c 21  
\s1 Devid nʼobodo Nob 
\p  
\v 1 Devid jere nʼobodo Nob ịhụ Ahimelek, onye nchụaja. Ahimelek mara jijiji mgbe ọ hụrụ Devid. Ọ sịrị Devid, “Gịnị mere naanị gị ji bịa? Gịnị mere o nweghị onye so gị?” 
\p  
\v 2 Devid zara Ahimelek, onye nchụaja sị, “Eze ziri m ozi dị mkpa, ma sị m, ‘Ka onye ọbụla ghara ịma ihe ọbụla banyere ozi a m na-eziga gị.’ Ma banyere ụmụ okorobịa m, agwala m ha ebe ha ga-ezute m.  
\v 3 Ugbu a, olee ihe oriri i nwere? Nye m ogbe achịcha ise maọbụ ihe ọzọ i nwere.” 
\p  
\v 4 Onye nchụaja ahụ zara Devid sị, “Enweghị m achịcha ana edoghị nsọ nʼebe a. Ma otu ọ dị, e nwere ụfọdụ achịcha e doro nsọ nʼebe a, ma ọ bụrụ na ụmụ okorobịa gị na ha so debere onwe ha ọcha, na-emetụghị nwanyị ahụ.”\f + \fr 21:4 \ft \xt Ọpụ 25:30; Lev 24:5-9; Mat 12:4.\f* 
\p  
\v 5 Devid zara sị ya, “Nʼezie, anyị ekwebeghị ka ụmụ nwanyị bịa anyị nso, dịka anyị dị mbụ eme ma anyị na-eje ozi. Ndị ikom ndị a na-edo onwe ha nsọ ọ bụladị mgbe njem anyị na-adịghị nsọ ka ọfọdụzie njem nke taa.”  
\v 6 Ebe nri ọzọ na-adịghị, onye nchụaja ahụ nyere Devid achịcha nsọ, bụ achịcha nke iche nʼIhu \nd Onyenwe anyị\nd*, nke ewepụtara site nʼihu \nd Onyenwe anyị\nd* nʼime ebe ịchụ aja, debekwa achịcha ọhụrụ nke e ji gbanwee nke ochie dị nʼebe ahụ. 
\p  
\v 7 Ma otu onye odibo Sọl nọ nʼebe ahụ nʼụbọchị ahụ, onye e jigidere nʼihu \nd Onyenwe anyị\nd*. Ọ bụ Doeg, onye Edọm onyeisi ndị na-azụ anụ ụlọ Sọl. 
\p  
\v 8 Devid jụrụ Ahimelek ajụjụ sị ya, “I nweghị ùbe maọbụ mma agha nʼebe a? Ewetaghị m mma agha m maọbụ ngwa agha ọzọ, nʼihi na ozi eze ziri anyị dị oke ngwangwa.” 
\p  
\v 9 Onye nchụaja zaghachiri, “Mma agha Golaịat, onye Filistia, onye ahụ i tigburu na ndagwurugwu Ịla dị nʼebe a, a fụchiri ya nʼakwa nʼazụ efọọd. Ọ bụrụ na ị chọrọ ya, were ya, nʼihi na ọ dịghị mma agha ọzọ dị nʼebe a ma ọ bụghị nke ahụ.” 
\p Devid sịrị, “Ọ dịghị nke dịka ya, nye m ya.” 
\s1 Devid nʼobodo Gat 
\p  
\v 10 Nʼụbọchị ahụ, Devid gbapụrụ ọsọ site nʼebe Sọl nọ gbakwuru Akish eze ndị Gat.  
\v 11 Ma ndị ozi Akish sịrị ya, “Onye a ọ bụghị Devid, eze nke ala ahụ? Ọ bụghị ya bụ isi abụ ha na-abụ mgbe ha na-ete egwu na-asị: 
\q1 “ ‘Sọl egbuola ọtụtụ puku ndị iro ya, 
\q2 Devid egbukwaala iri puku kwụrụ puku ndị iro nke ya’?” 
\p  
\v 12 Mgbe Devid nụrụ okwu ndị a, ọ tụrụ egwu ihe Akish eze Gat ga-eme ya.  
\v 13 Nʼihi ya ọ gbanwere omume ya, bido ime dịka onyeisi na-adịghị mma. O bidokwara ịka akara nʼibo, bidokwa na-agụsasị ọnụ mmiri nʼahụọnụ ya. 
\p  
\v 14 Akish gwara ndị ozi ya okwu sị ha, “Leenụ nwoke a! Ọ bụ onyeisi mebiri! Gịnị mere unu ji kpọtara m ya?  
\v 15 Ndị na-ayị ara ha kọrọ m, nke mere unu ji kpọtara m nwoke a nʼebe a ka ọ bịa na-eme ka onye na-ayị ara nʼihu m? O kwesiri ka onye dị otu a bata nʼụlọ m?” 
\c 22  
\s1 Devid nʼobodo Adulam na Mizpa 
\p  
\v 1 Devid hapụrụ Gat gbaba nʼọgba nkume Adulam. Mgbe ụmụnne ya ndị ikom na ndị ezinaụlọ nna ya nụrụ nke a, ha jekwuru ya nʼebe ahụ.  
\v 2 Ndị ọzọ malitekwara ịbịakwute ya nʼebe ahụ, ndị niile nọ na mkpagbu dị iche iche, ndị ji ụgwọ, na ndị ọchịchị Sọl na-adịghị mma. Ha niile jekwuru ya. Ọ dịghị anya Devid ghọọrọ onyendu ha. Ihe ruru narị mmadụ anọ so ya. 
\p  
\v 3 Devid sitere nʼebe ahụ jee Mizpa dị na Moab rịọọ eze obodo ahụ sị, “Biko, ị ga-ekwe ka nna m na nne m pụta bịa biri nʼetiti unu tutu ruo mgbe m matara ihe Chineke na-aga imere m?”  
\v 4 Ya mere, ọ hapụrụ ha ka ha nọdụ na nke eze Moab. Ha na ya nọgidere oge niile Devid bi nʼebe ahụ e wusiri ike. 
\p  
\v 5 Ma Gad onye amụma sịrị Devid, “Anọgidela nʼebe ahụ e wusiri ike, kama laghachi nʼala Juda.” Ya mere, Devid biliri gaa nʼoke ọhịa Heret. 
\s1 Sọl egbuo ndị nchụaja Nob 
\p  
\v 6 Ugbu a Sọl nụrụ na achọtala ebe Devid na ndị ikom na-eso ya nọ. Sọl, onye ji ùbe ya nʼaka nọdụrụ ala nʼokpuru osisi tamarisk nke dị nʼugwu dị na Gibea. Ndị ozi ya guzokwa gburugburu ya.  
\v 7 Sọl gwara ha sị, “Geenụ ntị unu ndị ikom Benjamin! Ọ bụ unu niile ka nwa Jesi ga-enye ala ubi na ubi vaịnị? Ọ bụ unu niile ka ọ ga-eme ndị ọchịagha na-achị ọtụtụ puku ndị agha, na ọchịagha na-achị ọtụtụ narị ndị agha?  
\v 8 Ọ bụ ya mere unu ji dịnyere ya imegide m? Ọ dịghị onye ọbụla nʼime unu gwara m na nwa m na nwa Jesi gbara ndụ. Ọ dịghị onye ọbụla nʼime unu ihe gbasara m na-emetụ nʼobi ịgwa m na nwa m nwoke akpaliela ohu m imegide m, ichebiri m nʼụzọ, dịka o mere nʼụbọchị taa.” 
\p  
\v 9 Ma Doeg onye Edọm, onye so ndị ozi Sọl guzo nʼebe ahụ kwuru sị, “Ahụrụ m mgbe nwa Jesi bịakwutere Ahimelek, nwa Ahitub na Nob.  
\v 10 Ahimelek jụtaara ya ase site nʼaka \nd Onyenwe anyị\nd*, ma nyekwa ya ihe oriri na mma agha Golaịat onye Filistia.” 
\p  
\v 11 Mgbe ahụ, eze Sọl zipụrụ ozi nye Ahimelek nwa Ahitub na ndị ezinaụlọ nna ya niile, ndị bụ ndị nchụaja na Nob. Ha niile bịara guzo nʼihu eze.  
\v 12 Sọl gwara ha okwu sị, “Gee ntị, gị nwa Ahitub.” 
\p Ahimelek zara sị, “Ana m ege ntị, onyenwe m.” 
\p  
\v 13 Sọl jụrụ ya sị, “Gịnị mere gị na nwa Jesi ji gbaa izu imegide m? Gịnị mere i ji nye ya nri na mma agha, jụkwaara ya ase site nʼaka Chineke? Gịnị mere i ji na-agba ya ume ka o nupu isi nʼebe m nọ, na ka ọ bịakwa nʼebe a imegide m taa?” 
\p  
\v 14 Ahimelek zara eze sị, “Onye nʼetiti ndị ohu gị niile bụ onye kwesiri ntụkwasị obi dịka Devid, ọgọ eze, na onyeisi ndị agha na-eche gị nche; ọ bụkwa onye a na-enye nsọpụrụ dị ukwuu nʼezinaụlọ gị?  
\v 15 Nke a ọ bụ ụbọchị mbụ m na-ajụrụ ya ase nʼaka Chineke? Ọ bụghị! Ka eze ghara ibo ohu ya na ezinaụlọ nna m ebubo, nʼihi na ohu gị amaghị ihe ọbụla banyere okwu a niile.” 
\p  
\v 16 Ma eze kwuru sị, “Ị ga-anwụ. Ahimelek gị na ezinaụlọ nna gị niile!” 
\p  
\v 17 O nyere ndị na-eso ya iwu sị ha, “Gbuonụ ndị nchụaja ndị a, nʼihi na ha na Devid agbaala izuzu; ha makwa na o si nʼihu m na-agbapụ, ma ha agwaghị m!” 
\p Ma ndị agha eze jụrụ isetipụ aka ha megide ndị nchụaja \nd Onyenwe anyị\nd*. 
\p  
\v 18 Mgbe ahụ eze nyere Doeg iwu sị ya, “Gị onwe gị, chigharịa gbuo ha.” Ya mere, Doeg onye Edọm chigharịrị tigbuo ha. Nʼụbọchị ahụ, o gburu iri ndị nchụaja asatọ na ise, ndị yi uwe akwa ọcha efọọd.  
\v 19 O ji mma agha jee Nob, obodo ndị nchụaja, gbuo ezinaụlọ ndị nchụaja niile, nwoke na nwanyị, na ụmụntakịrị, na ụmụ na-aṅụ ara. O gbukwara ehi na ịnyịnya ibu na atụrụ ha niile. 
\p  
\v 20 Otu nʼime ụmụ Ahimelek nwa Ahitub, aha ya bụ Abịata gbapụrụ, gbakwuru Devid.  
\v 21 Ọ gwara Devid na Sọl egbuola ndị nchụaja \nd Onyenwe anyị\nd*.  
\v 22 Mgbe ahụ, Devid sịrị Abịata, “Nʼụbọchị ahụ, mgbe Doeg onye Edọm nọ nʼebe ahụ, amaara m na ọ ghaghị ịgwa Sọl. Mụ onwe m kpatara ọnwụ ndị niile nke ndị ezinaụlọ nna gị.  
\v 23 Soro m nọdụ nʼebe a, atụla ụjọ, nʼihi na onye na-achọ ndụ gị na-achọkwa ndụ nke m. Mmekpa ahụ ọbụla agaghị adakwasị gị ma mụ na gị nọdụ.” 
\c 23  
\s1 Devid anapụta obodo Keila 
\p  
\v 1 Otu ụbọchị, ozi rutere Devid ntị na ndị Filistia na-ebuso ndị obodo Keila\f + \fr 23:1 \ft \xt Jos 15:44; Neh 3:17,18\f* agha na-apụnara ha ihe niile ha nwere nke dị nʼebe ịzọcha ọka ha niile.  
\v 2 Devid jụrụ \nd Onyenwe anyị\nd* ase sị, “Ọ bụ m jee buso ndị Filistia a agha?” 
\p \nd Onyenwe anyị\nd* zara ya, “Gaa, buso ndị Filistia agha, zọpụta Keila.” 
\p  
\v 3 Ma ndị agha Devid sịrị ya, “Lee, anyị onwe anyị na-atụ egwu ihe a ga-eme anyị, ọ bụladị nʼime Juda, oleekwanụ otu anyị ga-esi jee buso ndị Filistia niile agha na Keila?” 
\p  
\v 4 Devid jụrụ \nd Onyenwe anyị\nd* ọzọ, ma \nd Onyenwe anyị\nd* zara ya nke ugboro abụọ sị, “Jee, rịdaruo Keila, nʼihi na aga m anọnyere gị; ị ga-emerikwa ndị Filistia.”  
\v 5 Ya mere, Devid na ndị agha ya gara Keila buso ndị Filistia agha. Ndị agha Devid gburu ọtụtụ ndị Filistia kpokọrọ igwe anụ ụlọ ha. Ha zọpụtakwara ndị Keila.  
\v 6 (Ugbu a, Abịata nwa Ahimelek chịkwa efọọd nʼaka gbadaa, mgbe ọ gbakwujere Devid na Keila). 
\s1 Sọl achụso Devid 
\p  
\v 7 Mgbe a gwara Sọl na Devid nọ na Keila, o kwuru sị, “Ahaa! Chineke enyefeela ya nʼaka m, nʼihi na Devid e jirila aka ya kee onwe ya agbụ site nʼịbanye nʼobodo nwere ibo ọnụ ụzọ na mkpọrọ e ji akpọchi ha.”  
\v 8 Sọl chịkọtara ndị agha ya ịga Keila ịnọchibido Devid na ndị ikom ya. 
\p  
\v 9 Mgbe Devid nụrụ ihe Sọl na-achọ ime, ọ gwara Abịata onye nchụaja sị ya, “Chịta efọọd ahụ.”\f + \fr 23:9 \ft \xt Ọnụ 27:21; 1Sa 23:6; 30:7\f* 
\v 10 Devid sịrị, “O! \nd Onyenwe anyị\nd*, Chineke Izrel, anụla m na Sọl na-achọ ịbịa laa Keila na obodo a nʼiyi nʼihi m nọ nʼebe a.  
\v 11 Ndị nwe Keila ha ga-arara m nye nʼaka Sọl? Ọ bụ ezie na Sọl na-abịa dịka m nụrụ? O! \nd Onyenwe anyị\nd*, Chineke Izrel, biko gwa ohu gị.” 
\p Ma \nd Onyenwe anyị\nd* sịrị, “Ọ ga-abịa.” 
\p  
\v 12 Ọzọkwa, Devid jụrụ sị, “Ndị nwe Keila ha ga-arara m na ndị ikom m nye nʼaka Sọl?” 
\p \nd Onyenwe anyị\nd* sịrị, “Ha ga-eme otu a.” 
\p  
\v 13 Nʼihi ya, Devid na ndị ikom ya ọnụọgụgụ ha dị narị ndị ikom isii, hapụrụ Keila pụọ na-awagharị site nʼotu ebe gaa nʼebe ọzọ. Mgbe Sọl nụrụ na Devid esitela na Keila pụọ, o jekwaghị ebe ahụ ọzọ. 
\p  
\v 14 Nʼoge a, Devid nọgidere nʼebe e wusiri ike dị nʼọzara, na nʼala ugwu ugwu nke ọzara Zif. Ụbọchị niile, Sọl chọgharịrị ya ma Chineke enyefeghị Devid nʼaka ya. 
\p  
\v 15 Mgbe Devid nọ na Horesh, nke dị nʼọzara Zif, ọ natara ozi na Sọl na-abịa igbu ya.  
\v 16 Jonatan, nwa Sọl pụrụ ịchọ Devid. Mgbe ọ hụrụ ya na Horesh, ọ gbara ya ume, nyere ya aka iguzosi ike nʼime Chineke.  
\v 17 Jonatan sịrị ya, “Atụla egwu, nna m Sọl apụghị ịchọta gị. Ị ga-abụ eze Izrel. Aga m abụkwa onye na-eso gị dịka Sọl nna m maara nke ọma.”  
\v 18 Ha abụọ gbara ndụ nʼihu \nd Onyenwe anyị\nd*. Devid nọgidere na Horesh, ma Jonatan laghachiri nʼụlọ ya. 
\p  
\v 19 Ma ndị Zif biliri jekwuru Sọl na Gibea sị ya, “Devid o zoghị onwe ya nʼetiti anyị nʼọgba nkume dị nʼọhịa Horesh, nʼugwu Hakila, na ndịda Jeshimọn?  
\v 20 Ugbu a, eze anyị, bịa mgbe ọbụla ị chọrọ, ka anyị gaa jidere gị ya. Ị ga-emekwa ya dịka obi gị sị chọọ.” 
\p  
\v 21 Sọl zara ha sị, “\nd Onyenwe anyị\nd* gọzie unu nʼihi mmetụta ọnọdụ m na-emetụta unu nʼobi.  
\v 22 Gaanụ chọpụta nke ọma ebe ọ na-ezo onwe ya, na onye hụrụ ya, nʼihi na agwara m na ọ bụ onye aghụghọ.  
\v 23 Chọpụtanụ ebe ọ na-ezo onwe ya ma lọghachikwanụ bịa gwa m ihe unu chọpụtara. Mgbe ahụ, aga m eso unu jee. Ọ bụrụ na ọ nọ nʼala ahụ, aga m achọpụta ya; e, aga m enyobanye anya chọọ ya nʼikwu niile nke Juda.” 
\p  
\v 24 Ha biliri buru Sọl ụzọ gawa Zif. Nʼoge a, Devid na ndị agha ya nọ nʼọzara Maon, nʼime Araba, na ndịda Jeshimọn.  
\v 25 Sọl na ndị agha ya bịarutere ebe ahụ malite chọwa Devid. Mgbe a gwara Devid na Sọl na-achọ ya, o duuru ndị agha ya gbada gaa nʼoke nkume ahụ ma nọgide nʼọzara Maon. Mgbe Sọl nụrụ nke a, ọ chụgidekwara Devid ọsọ gaa nʼebe ahụ. 
\p  
\v 26 Mgbe ha ruru nʼebe ahụ, Sọl na ndị agha ya nọ nʼotu akụkụ ugwu ahụ, Devid na ndị agha ya nọkwa nʼakụkụ nke ọzọ, na-eme ngwa ka ha gbanarị Sọl. Ma Sọl na ndị agha ya na-abịa nnọọ nso ijide Devid.  
\v 27 Ma nʼotu mgbe ahụ, onyeozi bịakwutere Sọl sị ya, “Mee ngwangwa, lọta, nʼihi na ndị Filistia apụtala ibuso Izrel agha.”  
\v 28 Ngwangwa, Sọl sitere nʼịchụ Devid chigharịa azụ, lọta ibuso ndị Filistia agha. Site nʼoge ahụ, a kpọrọ ebe ahụ Devid nọ, Sela Hamahlekot, nke pụtara, Nkume Nkewa.  
\v 29 Devid si nʼebe ahụ pụọ gaa biri nʼebe e wusiri ike nke En-Gedi, ebe o zoro onwe ya. 
\c 24  
\s1 Devid edoo Sọl ndụ 
\p  
\v 1 Mgbe Sọl sitere nʼịlụso ndị Filistia agha lọta, a gwara ya sị, “Devid nọ nʼọzara En-Gedi.”  
\v 2 Sọl chịịrị puku ndị agha atọ a zụrụ nke ọma site nʼIzrel niile, pụọ ịchọ Devid na ndị ikom ya nʼetiti ọgba nkume, na nʼakụkụ ụzọ dị warawara nke Ewu Ọhịa. 
\p  
\v 3 Mgbe ọ bịaruru nso nʼọgba atụrụ nke dị nʼụzọ ahụ, otu ọgba nkume dị nʼebe ahụ, Sọl banyere nʼime ya, ịga mposi. Devid na ndị ikom ya nọ nʼime ime ọgba nkume ahụ.  
\v 4 Ndị ikom Devid sịrị ya, “Ahaa ugbu a bụ oge gị! Taa bụ ụbọchị ahụ \nd Onyenwe anyị\nd* kwuru okwu ya, mgbe ọ sịrị, ‘Aghaghị m inyefe gị onye iro gị nʼaka, ka i mee ya dịka o si masị gị.’ ” Ma Devid ji nwayọọ gaa nso ebe Sọl nọ bipụ ọnụ ọnụ uwe mwụda ya. 
\p  
\v 5 Emesịa, obi Devid malitere ịma ya ikpe nʼihi na o bipụrụ ọnụ ọnụ uwe mwụda Sọl.  
\v 6 Ọ gwara ndị ya na ha so okwu sị, “\nd Onyenwe anyị\nd* ekwela na m ga-emeso nna m ukwu, onye \nd Onyenwe anyị\nd* tere mmanụ mmeso dị otu ahụ, maọbụ na m ga-eweli aka imegide ya. Nʼihi na onye \nd Onyenwe anyị\nd* tere mmanụ ka ọ bụ.”  
\v 7 Devid sitere nʼokwu ndị a o kwuru baara ndị so ya mba. O nyeghị ha ohere ibuso Sọl agha. Emesịa, Sọl hapụrụ ọgba nkume ahụ. 
\p  
\v 8 Mgbe Sọl si nʼọgba nkume ahụ pụọ ịga nʼihu nʼije ya, Devid sitere nʼime ọgba nkume ahụ pụta, kpọọ Sọl oku sị ya, “Onyenwe m, eze!” Sọl tụgharịrị ma Devid kpọrọ isiala nye ya, daa nʼala kpuo ihu ya nʼala.  
\v 9 Mgbe ahụ Devid gwara Sọl okwu sị, “Gịnị mere i ji na-aṅa ntị nʼokwu ndị mmadụ na-ekwu, ndị ahụ na-asị Devid na-achọ ụzọ ọ ga-esi merụọ gị ahụ?  
\v 10 Taa, i jirila anya gị hụ na ọ bụghị eziokwu. \nd Onyenwe anyị\nd* nyere gị nʼaka m nʼime ọgba nkume ahụ ị banyere, ụfọdụ ndị mụ na ha so gwara m ka m gbuo gị, ma ahapụrụ m gị ndụ nʼihi na m sịrị, ‘Agaghị m eweli aka m megide nna m ukwu nʼihi na ọ bụ onye \nd Onyenwe anyị\nd* tere mmanụ.’  
\v 11 Lee, nna m, lee iberibe uwe mwụda gị nʼaka m. Ebipụtara m ọnụ ọnụ uwe gị, ma egbughị m gị. Jiri nke a ghọta ma matakwa na ikpe nnupu isi na ajọ omume megide gị amaghị m. O nweghị ụzọ m si mejọọ gị, ma ị nọ na-achọsikwa m ike iwere ndụ m.  
\v 12 Ka \nd Onyenwe anyị\nd* kpebie nʼetiti mụ na gị, ka \nd Onyenwe anyị\nd* bọọ ọbọ ihe ọjọọ niile i mere. Ma agaghị m emetụ gị aka.  
\v 13 Dịka ilu ndị mgbe ochie si dị, ‘Ihe ọjọọ na-esi nʼaka ndị na-eme ihe ọjọọ,’ ma agaghị m emetụ gị aka. 
\p  
\v 14 “Ma onye kwanụ ka eze Izrel na-achọ ijide? Onye ka ọ na-atụfu oge ya ịchọgharị? Ọ bụ ozu nkịta? Ka ọ bụ akpị?  
\v 15 Ka \nd Onyenwe anyị\nd* bụrụ onye ikpe nʼetiti mụ na gị, ya kpebiekwa okwu anyị. Ya leba okwu m anya kpepụta m, ya gosi na m bụ onye ikpe na-amaghị site nʼịnapụta m nʼaka gị.” 
\p  
\v 16 Mgbe Devid kwuchara okwu ndị a, Sọl zara sị ya, “Ọ bụ olu Devid nwa m dị nke ahụ?” Ọ malitekwara ịkwa akwa.  
\v 17 Ọ sịrị Devid, “Ị bụ ezi mmadụ karịa m,\f + \fr 24:17 \ft \xt Jen 38:26\f* nʼihi na i jirila ezi omume kwụghachi m ajọ omume m.  
\v 18 E, i gosila m oke obi ebere taa, nʼihi na mgbe \nd Onyenwe anyị\nd* nyefere m nʼaka gị, ị gbughị m.  
\v 19 Ebee ka onye ahụ nọ nʼụwa niile, nke pụrụ ịhapụ onye iro ya mgbe ọ mara nʼọnya ya? Ka \nd Onyenwe anyị\nd* kwụghachi gị ezi ihe nʼihi obi ebere i gosiri m taa.  
\v 20 Ugbu a, amatala m na ị ghaghị ịbụ eze, ị ga-achịkwa alaeze Izrel.  
\v 21 Biko, ṅụọra m iyi nʼaha \nd Onyenwe anyị\nd* na mgbe oge ahụ ruru, na ị gaghị egbu ụmụ m, maọbụ hichapụ aha m site nʼezinaụlọ nna m.” 
\p  
\v 22 Devid ṅụụrụ Sọl iyi. Emesịa, Sọl laghachiri nʼụlọ ya, ma Devid na ndị ikom ya laghachiri nʼọgba nkume ha. 
\c 25  
\s1 Devid na Nebal na Abigel 
\p  
\v 1 Emesịa Samuel nwụrụ. Izrel niile chịkọtara onwe ha ọnụ zukọta ruo ụjụ nʼihi ọnwụ ya. Ha liri ya nʼụlọ ya dị na Rema. Emesịa, Devid gara nʼọzara Paran biri nʼebe ahụ. 
\p  
\v 2 Otu nwoke dị, onye obodo Maon, onye ikwu Kaleb, nke nwere akụnụba. O nwere igwe atụrụ dị puku atọ, na otu puku ewu, ndị ọ nọ nʼubi nʼoge a na-akpụchapụ ajị ha nʼobodo Kamel.  
\v 3 Aha nwoke a bụ Nebal. Nwunye ya kwa, onye bụ nwanyị mara mma, na onye nwere akọnuche, ka a na-akpọ Abigel. Nwoke a nwere omume ọjọọ; ọ kwara obi nʼazụ, afọ takwara ya mmiri. 
\p  
\v 4 Mgbe Devid nọ nʼọzara nụ na Nebal na-akpụcha ajị igwe ewu na atụrụ ya,  
\v 5 o zipụrụ ndị ikom iri sị ha. “Jekwurunụ Nebal nʼobodo Kamel, jụọ ya otu ihe si aga nʼaha m.  
\v 6 Sịnụ ya, ndụ gị, ndụ ogologo, udo na ahụ ike nye gị na ezinaụlọ gị, udo na ahụ ike nye ihe niile i nwere. 
\p  
\v 7 “ ‘Anụla m na ị na-akpacha ajị igwe ewu na atụrụ gị. Oge ndị ọzụzụ atụrụ gị nọ nʼetiti anyị, anyị emejọghị ha, o nweghị ihe ọbụla funarịrị ha oge ahụ niile ha nọrọ nʼobodo Kamel.  
\v 8 Jụọkwa ndị ikom gị, ha ga-agwa gị ma ihe m kwuru ọ bụ eziokwu. Ya mere gosi ụmụ okorobịa ndị a ihuọma, ebe ọ bụ na ha na-abịakwute gị nʼoge mmemme. Biko, nyetụ ndị ohu gị ndị a, na mụ bụ Devid nwa gị, ihe ọbụla aka gị ruru.’ ” 
\p  
\v 9 Ụmụ okorobịa Devid zipụrụ bịarutere zie Nebal ozi Devid ziri ha. Ha nọgidekwara chere ka onye ha ọsịsa. 
\p  
\v 10 Ma Nebal jụrụ ha sị, “Onye bụ Devid? Onye bụkwa nwa Jesi a? Ọtụtụ ndị ohu dị taa bụ ndị na-esi nʼaka nna ha ukwu na-agbapụ.  
\v 11 M ga-ewere achịcha m, na mmiri m, na anụ m gburu nʼihi ndị na-akpachara m ajị anụ nye ndị m na-amaghị ebe ha sị pụta?” 
\p  
\v 12 Ndị ikom Devid tụgharịrị azụ laghachi ebe ha si bịa. Mgbe ha bịarutere, ha kọrọ akụkọ banyere okwu niile Nebal kwuru.  
\v 13 Devid sịrị ndị ikom ya, “Onye ọbụla nyara mma agha!\f + \fr 25:13 \ft Onye ọbụla kee mma agha ya nʼukwu ya\f*” Ha mere ihe o kwuru. Devid nʼonwe ya nyanyekwara mma agha nke ya. Ihe dị ka narị ndị ikom anọ sooro Devid pụọ, ebe narị mmadụ abụọ ndị ọzọ nọdụrụ na-eche ụlọ ha nche. 
\p  
\v 14 Ma otu nʼime ndị ikom Nebal gara kọọrọ Abigel, nwunye Nebal sị ya, “Lee, Devid esitela nʼọzara zite ndị ozi ka ha nye onyenwe anyị ekele ya, ma ọ kparịrị ha, baakwara ha mba.  
\v 15 Ma ndị ikom ndị a\f + \fr 25:15 \ft Ndị a bụ ụmụ okorobịa na-ejere Devid ozi.\f* mesoro anyị mmeso ọma, ha emejọghị anyị. Oge ahụ niile anyị nọ ha nso nʼọhịa ọ dịghị ihe funarịrị anyị.  
\v 16 Ehihie na abalị, ha bụụrụ anyị mgbidi, ichebe anyị na atụrụ anyị, mgbe ha na-akpa nri nʼakụkụ ebe ha nọ.  
\v 17 Ọ dị mma ka ị mata ma marakwa ihe ị ga-eme ngwangwa; nʼihi nsogbu dị njọ nke na-aga ịdịrị nna anyị ukwu na ezinaụlọ ya niile. Nʼihi ọ bụ nwoke jọgburu onwe ya, na ọ dịghị onye pụrụ ịgwa ya okwu.” 
\p  
\v 18 Abigel mere ngwangwa chịkọta narị ogbe achịcha abụọ, karama akpụkpọ mmanya abụọ, atụrụ ise e doziri edozi, otu bushel ọka e ghere eghe, otu narị ụyọkọ mkpụrụ vaịnị a mịkpọrọ amịkpọ na narị achịcha fiig abụọ, bukwasị ihe ndị a niile nʼelu ịnyịnya ibu.  
\v 19 Ọ sịrị ụmụ okorobịa na-ejere ya ozi, “Na-aganụ nʼihu, ana m abịa nʼazụ.” Ma ọ gwaghị di ya Nebal ihe ọ na-aga ime. 
\p  
\v 20 Mgbe ọ nọ nʼelu ịnyịnya ibu na-agbada ụzọ nke ugwu ahụ ọ hụrụ Devid na ndị agha ya ka ha na-abịa. O zutere ha  
\v 21 ma Devid nọrịị na-ekwu na-asị, “Ọ bụ nʼefu ka anyị nyeere nwoke a aka. Anyị chebere igwe ewu na atụrụ ya nʼọzara; ọ dịkwaghị otu furu efu, ọ dịkwaghị otu nke e zuru ezu, ma o jirila ajọ omume kwụghachi m ihe ọma m meere ya.  
\v 22 Ka Chineke mesoo Devid mmeso, otu ọbụla mmeso ahụ si dị njọ, ma ọ bụrụ na m ahapụ otu mkpụrụ nwoke ndụ nʼetiti ihe niile o nwere na-eku ume, mgbe chi echi bọrọ.” 
\p  
\v 23 Mgbe Abigel hụrụ Devid, o mere ngwangwa si nʼelu ịnyịnya ibu ya rịda, kpuo ihu nʼala, kpọọ isiala nye Devid.  
\v 24 Ọ dara nʼala nʼụkwụ ya, sị, “Ka ajọ omume ahụ dịkwasị nʼisi\f + \fr 25:24 \ft Gbaghara ịta ụta maọbụ ajọ omume nke ohu gị\f* ohu gị, onyenwe m. Biko, kwere ka ohu gị gwa gị okwu, gekwaa ntị nʼihe ohu gị nwere ikwu.  
\v 25 Nebal bụ nwoke nwere obi ọjọọ, biko ka onyenwe m ghara ịgụ ihe ọbụla o kwuru nʼihe. Ọ bụ onye nzuzu, dịka aha ya na-egosi. Aha ya pụtara nzuzu, nzuzu na-esokwa ya. Ma ahụghị m ndị ozi ahụ i zitere, nʼezie ohu gị ahụghị ndị ikom onyenwe m zitere.  
\v 26 Ugbu a, onyenwe m, dịka \nd Onyenwe anyị\nd* na-adị ndụ ma gị onwe gị na-adịkwa ndụ, ebe ọ bụ na \nd Onyenwe anyị\nd* gbochiri gị ka ị ghara ịba nʼikpe ọmụma nke igbu mmadụ, na iji aka gị bọrọ onwe gị ọbọ, ka ndụ ndị iro gị na ndị niile na-achọ ime onyenwe m ihe ọjọọ, dịka Nebal.  
\v 27 Ma kwerekwa ka onyinye a, nke ohu gị nwanyị wetaara nna m ukwu, bụrụ nke a ga-enye ndị ikom na-eso gị. 
\p  
\v 28 “Biko, gbaghara njehie ohu gị nwanyị, nʼihi na \nd Onyenwe anyị\nd* Chineke gị aghaghị imere onyenwe m alaeze nke ga-adịgide, nʼihi na ọ bụ agha \nd Onyenwe anyị\nd* ka ị na-alụ, agaghị ahụta ajọ omume nʼime gị ogologo ụbọchị ndụ gị niile.  
\v 29 Ọ bụ ezie na mmadụ pụrụ ị na-achụ gị ịnapụ gị ndụ gị, ma ndụ onyenwe m ga-abụ ihe \nd Onyenwe anyị\nd* Chineke gị ga-ekechi na ngwungwu ndị dị ndụ. Ma ndụ ndị iro gị ka ọ ga-atụfu dịka nkume esi nʼakpa e ji efe ebe.  
\v 30 Mgbe \nd Onyenwe anyị\nd* mezuru nye onyenwe m ihe ọma niile nke o kwere na nkwa, meekwa ya onyendu ndị Izrel,  
\v 31 onyenwe m agaghị enwe akọnuche nke ga na-esogbu ya nʼihi na o ji aka ya bọọrọ onwe ya ọbọ, maọbụ nke iwufu ọbara. Mgbe \nd Onyenwe anyị\nd* Chineke gị mere ka ihe gaara onyenwe m nke ọma, chetakwa ohu gị nwanyị.” 
\p  
\v 32 Devid zara Abigel sị ya, “Otuto dịrị \nd Onyenwe anyị\nd*, Chineke nke Izrel onye zitere gị taa ka ị bịa zute m.  
\v 33 Ka ngọzị dịrị gị nʼihi ezi uche gị, na nʼihi na i gbochiri m iwufu ọbara taa, gbochiekwa m iji aka m bọrọ onwe m ọbọ.  
\v 34 Ma ọ bụghị otu a, dịka \nd Onyenwe anyị\nd* Chineke nke Izrel na-adị ndụ, bụ onye jidere m site nʼimerụ gị ahụ, ọ bụrụ na ị pụtaghị ngwa izute m, ọ dịghị otu nwoke gaara adị ndụ nʼụlọ Nebal nʼìhè ụtụtụ echi.” 
\p  
\v 35 Devid naara ya ihe ndị ahụ niile o wetara sị ya, “Laghachi nʼụlọ gị nʼudo. Anụla m ihe i kwuru ma meekwa ihe ị rịọrọ.” 
\p  
\v 36 Mgbe Abigel batara nʼụlọ, o jekwuru Nebal ebe ọ nọ nʼoriri ọ kpọrọ, oriri dịka oriri a na-enwe nʼụlọeze. Ọ ṅụọkwala mmanya ṅụbigakwa ya oke; nʼihi ya ọ gwaghị ya ihe ọbụla tutu ruo nʼụtụtụ.  
\v 37 Nʼụtụtụ, mgbe mmanya pụrụ Nebal nʼanya, nwunye ya gwara ya ihe ndị a niile. Nke a mere ka obi ya nwụọ, ka ọ tọgbọrọ dịka nkume.  
\v 38 Mgbe abalị iri gafere, \nd Onyenwe anyị\nd* tiri Nebal ihe otiti, nke mere ka ọ nwụọ. 
\p  
\v 39 Mgbe Devid nụrụ na Nebal anwụọla, ọ sịrị, “Otuto dịrị \nd Onyenwe anyị\nd*, onye kpechitere m okwu m megide Nebal nʼihi nlelị anya o leliri m. O gbochiela ohu ya site nʼime ihe ezighị ezi, ma kwụghachi Nebal ụgwọ mmehie ya.” 
\p Mgbe ahụ Devid zigara ndị ozi ka ha gaa jụọ Abigel ma ọ ga-ekwe ị ghọọ nwunye ya.  
\v 40 Ndị ozi Devid bịakwutere Abigel na Kamel zie ya ozi sị, “Devid zitere anyị bịakwute gị ịlụta gị ka ị ghọọ nwunye ya.” 
\p  
\v 41 Abigel kpuru ihu nʼala sị ya, “Lee ohu gị nwanyị, ejikeere m ijere gị ozi, na ịsacha ụkwụ ndị na-ejere onyenwe m ozi.”  
\v 42 Abigel mere ngwangwa jikere, kpọrọ ụmụ agbọghọ ise na-ejere ya ozi, nọkwasị nʼelu ịnyịnya ibu, soro ndị ahụ Devid zitere lakwuru Devid. Otu a ka Abigel sị ghọọ nwunye Devid.  
\v 43 Devid lụkwara nwanyị ọzọ aha ya bụ Ahinoam,\f + \fr 25:43 \ft Ahinoam bụ nwunye mbụ Devid, onye mụtara ya ọkpara mbụ ya, a na-akpọ Amnọn. \xt 1Sa 27:3; 2Sa 3:2\f* onye Jezril. Ha abụọ bụkwa ndị nwunye ya.  
\v 44 Nʼoge a, Sọl ewerela nwa ya nwanyị Mikal, onye bụ nwunye Devid kpọnye Palti, nwa Laish, onye obodo Galim, dịka nwunye. 
\c 26  
\s1 Devid edebekwa Sọl ndụ ọzọ 
\p  
\v 1 Ndị Zif jekwuru Sọl na Gibea gwa ya na Devid na-ezo onwe ya nʼugwu Hakila nke chere ihu nʼọzara. 
\p  
\v 2 Nʼihi ya, Sọl biliri chịrị puku ndị agha atọ o leziri anya họpụta nʼetiti ndị agha Izrel, duru ha gaa nʼọzara Zif ịchọ Devid.  
\v 3 Sọl mara ụlọ ikwu ya nʼakụkụ ụzọ ugwu nta Hakila na ncherita ihu Jeshimọn nke nọ nʼokporoụzọ. Ma ka Devid nʼonwe ya nọ nʼime ọzara, ọ hụrụ na Sọl chụụrụ ya bata nʼime ọzara,  
\v 4 Devid zipụrụ ndị nledo, matakwa na Sọl bịara nʼezie. 
\p  
\v 5 Emesịa, Devid pụrụ jeruo ebe Sọl mara ụlọ ikwu ya. Ọ hụrụ ebe Sọl na Abna nwa Nea, onyeisi agha dinara ala. Sọl dina nʼime ogige ụlọ ikwu ahụ, ndị agha ya dinakwara gburugburu ya. 
\p  
\v 6 Devid sịrị Ahimelek onye Het, na Abishai, nwa Zeruaya\f + \fr 26:6 \ft Zeruya bụ nwanne nwanyị Devid, onye toro ya nʼusoro ọmụmụ ha. Nke a dị nʼakwụkwọ \xt 1Ih 2:16\ft  Abishai na Joab, ndị bụ ndị ndu ndị agha, tinyere Asahel, bụ ụmụ nwanne nwanyị Devid, nʼihi na ọ bụ Zeruya mụrụ ha, gụọ nke a nʼakwụkwọ \xt 2Sa 2:13,18,24\f* onye bụ nwanne Joab, “Onye ga-eso m gaa nʼogige ebe Sọl na ndị agha ya mara ụlọ ikwu ha?” 
\p Abishai zara sị, “Aga m eso gị gaa.” 
\p  
\v 7 Ya mere, nʼabalị, Devid na Abishai jiri nwayọọ jeruo ebe ndị agha Sọl mara ụlọ ikwu ha. Ha hụrụ Sọl ebe o dinara ala na-arahụ ụra. Ùbe ya ka ọ manyekwara nʼala nʼakụkụ ebe isi ya dị. Abna, na ndị agha ndị ọzọ dina gburugburu Sọl na-arahụ ụra. 
\p  
\v 8 Abishai sịrị Devid, “Nʼezie, Chineke enyefeela gị onye iro gị nʼaka taa. Ugbu a, kwere ka m gaa were ùbe magide ya nʼala otu ugboro; agaghị m atụ ya ugboro abụọ.” 
\p  
\v 9 Ma Devid sịrị Abishai, “Mba egbula ya. Onye ga-eseti aka ya megide onye \nd Onyenwe anyị\nd* tere mmanụ, ghara ị bụ onye ikpe na-amaghị?”  
\v 10 Ọ sịrị, “Nʼezie dịka \nd Onyenwe anyị\nd* na-adị ndụ, ọ bụ \nd Onyenwe anyị\nd* ya onwe ya ga-etida ya, maọbụ oge ya ga-eru mgbe ọ ga-anwụ, ma ọ bụkwanụ ọ gaa agha, ọ nwụfuo.  
\v 11 Ma \nd Onyenwe anyị\nd* ekwela ka m setịpụ aka megide onye \nd Onyenwe anyị\nd* tere mmanụ. Ugbu a, weta ùbe na ihe ịṅụ mmiri nke dị nʼakụkụ isi ya, ka anyị si nʼebe a pụọ.” 
\p  
\v 12 Devid weere ùbe ya na ite mmiri dị nʼakụkụ isi Sọl, ha sitere nʼebe ahụ pụọ. Ọ dịkwaghị onye hụrụ ha. Ọ dịkwaghị onye tetara, nʼihi na \nd Onyenwe anyị\nd* mere ka ha daba nʼoke ụra. 
\p  
\v 13 Mgbe ahụ, Devid pụrụ gafee nʼofe nke ọzọ, guzo onwe ya nʼelu ugwu ebe dị anya, ebe mbara dị nʼetiti ya na ha.  
\v 14 Devid kpọrọ Abna nwa Nea na ndị agha oku sị, “Abna, za m oku!” 
\p Abna jụrụ ya sị, “Onye ka ị bụ i ji si otu a na-eti mkpu ịkpọte eze?” 
\p  
\v 15 Devid sịrị, “Nʼezie, ọ bụghị nwoke ka ị bụ? Onye dịkwa ka gị nʼIzrel niile? Gịnị mere i ji hapụ ichezi onyenwe gị eze nke ọma? Otu onye bịara igbu onyenwe gị, bụ eze.  
\v 16 Ihe a i mere adịghị mma. Nʼeziokwu, dịka \nd Onyenwe anyị\nd* na-adị ndụ, gị na ndị ikom gị kwesiri ọnwụ, nʼihi na gị na ndị gị echebeghị onyenwe unu, bụ onye \nd Onyenwe anyị\nd* tere mmanụ. Ebee ka ùbe eze, na ihe mmiri ọṅụṅụ ya, nke dị nʼakụkụ isi ya dị?” 
\p  
\v 17 Mgbe ahụ, Sọl matara na ọ bụ olu Devid, ọ sịrị, “Ọ bụ gị nwa m, Devid?” 
\p Devid zara sị ya, “E, ọ bụ olu m, onyenwe m, eze.”  
\v 18 Ọ sịkwa, “Nʼihi gịnị ka onyenwe m ji na-achụgharị ohu ya? Gịnị ka m mere? Gịnịkwa bụ ihe ọjọọ ị chọtara nʼaka m?  
\v 19 Ugbu a ka onyenwe m eze gee ntị nʼokwu ohu ya: Ọ bụrụ na \nd Onyenwe anyị\nd* kpaliri gị imegide m, mgbe ahụ arịrịọ m bụ ka \nd Onyenwe anyị\nd* nara onyinye ịnata ihuọma. Otu ọ dị, a si na ọ bụ ndị mmadụ na-akpali gị imegide m, ka ndị dị otu a bụrụ ndị a bụrụ ọnụ nʼihu \nd Onyenwe anyị\nd*. Nʼihi na ha esitela nʼoke m nwere nʼihe nketa \nd Onyenwe anyị\nd* chụpụ m, sị m, ‘Gaa fee chi ndị ọzọ ofufe.’  
\v 20 Ugbu a, ekwela ka ọbara m bụrụ ihe a wufuru nʼala dị anya, na-abụghị nʼihu \nd Onyenwe anyị\nd*. Eze Izrel apụtala ịchọ akpị dịka m, otu dinta si achọgharị ọkwa nʼelu ugwu.” 
\p  
\v 21 Mgbe ahụ, Sọl zara sị, “Emehiela m. Lọghachi nʼụlọ nwa m Devid. Nʼihi na ị gụrụ ndụ m taa dịka ihe dị oke ọnụahịa. Agaghị m emejọ gị ọzọ. Nʼezie, a kpaala m agwa dịka onye nzuzu, meekwa ihe nke ukwuu na-amaghị ama.” 
\p  
\v 22 Devid zara ya sị, “Lee ùbe eze, Zie otu nʼime ndị ikom gị ka ọ bịa were ya.  
\v 23 \nd Onyenwe anyị\nd* na-akwụghachi nwoke ọbụla ezi omume ya na ikwesi ntụkwasị obi ya. \nd Onyenwe anyị\nd* nyere gị nʼaka m taa ma ajụla m igbu onye ya o tere mmanụ.  
\v 24 Ugbu a, ka \nd Onyenwe anyị\nd* zọpụta ndụ m, ọ bụladị dịka m sị zọpụta ndụ nke gị taa. Ka ọ napụtakwa m site na mkpagbu m niile.” 
\p  
\v 25 Sọl sịrị Devid, “Onye a gọziri agọzi ka ị bụ nwa m, Devid. Ị ga-eme oke ihe, bụrụkwa onye na-emeri nʼagha.” 
\p Devid sitere nʼebe ahụ pụọ. Sọl laghachikwara nʼụlọ ya. 
\c 27  
\s1 Devid ebiri nʼetiti ndị Filistia 
\p  
\v 1 Devid chere nʼime onwe ya sị, “Otu ụbọchị Sọl ga-enweta m, bibie m. Ihe ka mma m ga-eme bụ ịgbaga nʼala ndị Filistia. Nke a ga-eme ka Sọl kwụsị ịchọgharị m ebe ọbụla nʼIzrel. Aga m esikwa otu a, nwere onwe m site nʼaka ya.” 
\p  
\v 2 Ya mere, Devid na narị ndị ikom isii ya, na ezinaụlọ ha, biliri jekwuru Akish nwa Maok, eze ndị Gat.  
\v 3 Devid na ndị agha ya sooro Akish biri na Gat. Onye ọbụla du ezinaụlọ ya. Devid nʼonwe ya du ndị inyom abụọ ya: Ahinoam onye Jezril, na Abigel onye Kamel, nwunye ochie Nebal.  
\v 4 Ọ dịghị anya, Sọl nụrụ na Devid agbalaala Gat, nʼihi ya ọ kwụsịrị ịchụso ya. 
\p  
\v 5 Devid gwara Akish sị ya, “Ọ bụrụ na m anatala amara nʼebe ị nọ, ọ ga-adị mma ka enye m otu obodo nʼime obodo nke ala a, ka m biri. Nʼihi gịnị ka ohu gị ga-eji soro gị biri nʼobodo eze?” 
\p  
\v 6 Akish nyere ya Ziklag, nʼihi ya, Ziklag bụ obodo ndị eze Juda ruo taa.  
\v 7 Devid biri nʼoke ala ndị Filistia otu afọ na ọnwa anọ. 
\p  
\v 8 Devid na ndị ikom ya nọgidere oge ahụ niile na-emegide ndị Geshua, ndị Gizi na ndị Amalek. (Site na mgbe ochie ndị a bi nʼala ahụ gbatịrị ruo Shua na Ijipt)  
\v 9 Mgbe ọbụla Devid wakporo akụkụ ọbụla, ọ dịghị ahapụ nwoke maọbụ nwanyị ndụ. Ma ọ na-akpụrụ atụrụ ha, na ehi ha, na ịnyịnya ibu ha, na ịnyịnya kamel ha, nakwa uwe ha. Emesịa, ọ na-alọghachikwuru Akish. 
\p  
\v 10 Ọ bụrụ na Akish ajụọ Devid ajụjụ sị, “Ndị ole ka unu busoro agha taa?” Devid ga-aza sị, “Ọ bụ ndị bi na ndịda Juda”, maọbụ “ndị ndịda Jerahmel”, maọbụ “ndị ndịda Ken.”\f + \fr 27:10 \ft Ndị Jerahmel bụ ụmụ ụmụ Juda site na nwa nwa ya bụ Hezrọn, \xt 1Ih 2:5,9,25\ft  gụọ ihe banyere ndị Ken nʼihe e depụtara nʼakwụkwọ. \xt Nkp 4:11\f* 
\v 11 Ma ọ dịghị nwoke maọbụ nwanyị onye ọ hapụrụ ndụ, nke a ga-akpọta na Gat, nʼihi na o chere nʼobi ya sị, “Ha nwere ike ịbịa kwuo megide anyị, sị, ‘Otu a ka Devid mere.’ ” Otu a ka ọ na-emekwa ọtụtụ oge ahụ niile o bi nʼetiti ndị Filistia.  
\v 12 Akish kwenyere Devid, kwuo nʼobi ya sị, “Devid abụrụla ihe a kpọrọ asị nʼebe ndị nke ya bụ ndị Izrel nọ. Ọ ga-abụkwara m ohu ruo mgbe niile.” 
\c 28  
\p  
\v 1 Nʼoge ahụ, ndị Filistia chịkọtara ndị agha ha jikere ịlụso ndị Izrel agha. Akish eze Gat gwara Devid okwu, “Ghọtakwa na gị na ndị agha gị ga-eso mụ na ndị agha m gaa ibu agha.” 
\p  
\v 2 Devid zara ya sị, “Ị ga-eji anya gị hụrụ ihe ohu gị ga-eme.” 
\p Akish zara sị, “Ọ dị mma aga m eme gị onye nche m ụbọchị ndụ gị niile.” 
\s1 Onye mgbaasị Endọ 
\p  
\v 3 Nʼoge a Samuel anwụọla, ndị Izrel niile rukwara ụjụ nʼihi ya, lie ya nʼobodo ya bụ Rema. Sọl achụpụsịakwala ndị niile na-ajụ mmụọ ndị nwụrụ anwụ ase na ndị dibịa afa site nʼala ahụ. 
\p  
\v 4 Ndị Filistia zukọtara, bịa maa ụlọ ikwu ha na Shunem, ebe Sọl na ndị Izrel niile zukọtakwara maa ụlọ ikwu ha na Gilboa.  
\v 5 Mgbe Sọl hụrụ igwe ndị agha ndị Filistia, oke ụjọ jidere ya.  
\v 6 Ọ jụrụ \nd Onyenwe anyị\nd* ase, ma \nd Onyenwe anyị\nd* azaghị ya. Ọ zaghị na nrọ, maọbụ site nʼUrim, maọbụ site nʼọnụ ndị amụma.  
\v 7 Mgbe ahụ, Sọl sịrị ndị na-ejere ya ozi, “Chọtara m nwanyị onye na-ajụ mmụọ ndị nwụrụ anwụ ase, ka m gakwuru ya jụta ya ase.” 
\p Ha sịrị, “E nwere otu nwanyị dị otu a nʼEndoa.” 
\p  
\v 8 Ya mere, Sọl nwogharịrị onwe ya, yiri uwe ọzọ, o ruo nʼabalị, ya na ndị ikom abụọ gakwuru nwanyị ahụ. Ọ sịrị, “Jụtara m mmụọ ase,\f + \fr 28:8 \ft \xt Dit 18:10-11; 1Ih 10:13; Aịz 8:19\f* kpọlitekwara m onye m ga-akpọ aha ya.” 
\p  
\v 9 Ma nwanyị ahụ sịrị ya, “Nʼezie gị onwe gị maara ihe Sọl mere. Ọ kwụsịla ndị niile na-ajụ mmụọ ndị nwụrụ anwụ ase, na ndị dibịa afa site nʼala a. Nʼihi gịnị ka iji a gbara ndụ m ọnya, ime ka m nwụọ?” 
\p  
\v 10 Ma Sọl jiri \nd Onyenwe anyị\nd* ṅụọra ya iyi, “Dịka \nd Onyenwe anyị\nd* na-adị ndụ, agaghị ata gị ahụhụ nʼihi ihe a.” 
\p  
\v 11 Mgbe ahụ, nwanyị ahụ jụrụ, “Onye ka ị chọrọ ka m mee ka ọ rịgokwute gị?” 
\p Sọl sịrị, “Mee ka Samuel rịgokwute m.” 
\p  
\v 12 Mgbe nwanyị ahụ hụrụ Samuel, o tiri mkpu sị, “Gịnị mere iji ghọgbuo m? Gị onwe gị bụ Sọl!” 
\p  
\v 13 Eze sịrị ya, “Atụla egwu! Gịnị ka ị na-ahụ?” 
\p Nwanyị ahụ sịrị, “A hụrụ m chi\f + \fr 28:13 \ft Maọbụ, \fqa mmụọ\f* ka o si nʼala na-arịgopụta.” 
\p  
\v 14 Sọl jụrụ, “Gịnị ka onye ahụ yiri nʼọdịdị?” 
\p Ọ sịrị, “Ọ bụ agadi nwoke na-arịgota, e ji uwe mwụda kpuchie ahụ ya.” 
\p Mgbe ahụ, Sọl matara na ọ bụ Samuel. O kpuru ihu nʼala, kpọọkwa isiala. 
\p  
\v 15 Samuel sịrị Sọl, “Gịnị mere i ji esogbu m, site na ịkpọlite m?” 
\p Sọl zara, “Anọ m nʼoke nsogbu. Ndị Filistia na-ebuso m agha, ma Chineke esitekwala nʼebe m nọ wezuga onwe ya. Ọ naghị azakwa m ọzọ, maọbụ site na ndị amụma, maọbụ site na nrọ. Nʼihi ya ka m ji kpọọ gị, ịjụ gị ihe m ga-eme.” 
\p  
\v 16 Samuel sịrị, “Nʼihi gịnị ka i ji na-ajụ m, ebe ọ bụ na \nd Onyenwe anyị\nd* ewezugala onwe ya site nʼebe ị nọ, ghọọkwara gị onye iro?  
\v 17 \nd Onyenwe anyị\nd* emeela ihe ọ sị na ọ ga-eme. Ọ napụla gị alaeze gị were ya nye Devid.\f + \fr 28:17 \ft \xt 1Sa 15:28\f* 
\v 18 Ihe ndị a niile na-aga ịdakwasị gị nʼihi na i geghị ntị na ndụmọdụ \nd Onyenwe anyị\nd*, mgbe o were iwe dị ọkụ megide ndị Amalek.  
\v 19 \nd Onyenwe anyị\nd* ga-arara gị na ndị Izrel nyefee nʼaka ndị Filistia, echi gị na ụmụ gị ndị ikom ga-abịa nọnyeere m nʼebe a. \nd Onyenwe anyị\nd* ga-ararakwa ndị agha Izrel nye nʼaka ndị Filistia.” 
\p  
\v 20 Ngwangwa, Sọl dara nʼala, gbatịa onwe ya nʼoke egwu, nʼihi okwu ndị a niile Samuel kwuru. Ike adịghịkwa nʼime ya nʼihi agụụ, ebe ọ bụ na o ribeghị nri ọbụla ụbọchị ahụ niile. 
\p  
\v 21 Mgbe nwanyị a hụrụ ọnọdụ Sọl, ọ gwara ya okwu sị ya, “Onyenwe m, lee, ohu gị rubere isi mee ihe ị sị m mee. Ọ bụkwa ndụ m ka m ji chụọ aja imezu ihe ị rịọrọ m.  
\v 22 Ugbu a, biko, gee ntị nʼihe ohu gị na-aga ịgwa gị. Kwere ka m nye gị nri ka i rie, ka i nweta ike ị ga-eji laghachi.” 
\p  
\v 23 Ma Sọl jụrụ iri nri ọbụla. 
\p Ma ndị ikom ya na ha so malitere ịrịọ ya tutu ruo mgbe o kwenyere bilie, nọdụ ala nʼelu ihe ndina. 
\p  
\v 24 Nwanyị ahụ mere ngwangwa gbuo nwa ehi gbara abụba o nwere nʼụlọ ya. O jikwa ụtụ ọka mee achịcha nke etinyeghị ihe na-eko achịcha nʼime ya,  
\v 25 O doziri nri nʼihu Sọl na ndị ikom ya. Ha rikwara ya. Ha biliri laa nʼabalị ahụ. 
\c 29  
\s1 Akish ezighachi Devid Ziklag 
\p  
\v 1 Ndị Filistia chịkọtara ndị agha ha bịaruo Afek, ma ndị agha Izrel zukọtara nʼakụkụ isi iyi Jezril.  
\v 2 Mgbe ndịisi agha ndị Filistia malitere ịgafesị ha na ndị agha ha, ụfọdụ nʼime ha du ọtụtụ narị ndị agha, ụfọdụ, ọtụtụ puku ndị agha, Devid na ndị agha ya so nʼazụ, ha na Akish, eze ndị Filistia.  
\v 3 Ndịisi agha ndị Filistia jụrụ eze Akish ajụjụ sị, “Gịnị ka ndị Hibru ndị a na-eme nʼebe a?” 
\p Akish gwara ha sị, “Onye a ọ bụghị Devid, onyeozi si nʼaka Sọl eze ndị Izrel gbapụ? Mụ na ya ebiela ihe karịrị otu afọ, ma achọpụtaghị ihe ọbụla dị njọ nʼebe ọ nọ, site nʼụbọchị ahụ ọ hapụrụ Sọl ruo ugbu a.” 
\p  
\v 4 Ma ndịisi agha ndị Filistia were iwe megide ya. Ha sịrị ya, “Zilaga nwoke a, ka ọ laghachi nʼọnọdụ ozi ebe i mere ya onye nlekọta. Anyị na ha agaghị eso jee nʼihu ọgụ, ma ọ bụghị ya ọ ga-atụgharịa megide anyị nʼagha. Olee ụzọ ọzọ ọ ga-esi mee ka ya na nna ya ukwu dị na mma ma ọ bụghị site nʼigbu ndị agha anyị ndị a?”  
\v 5 Onye a ọ bụghị Devid ahụ ndị inyom Izrel ji gụọ egwu sị, 
\q1 “ ‘Sọl egbuola ọtụtụ puku ndị iro ya, 
\q2 ma Devid egbuola iri puku kwụrụ puku ndị iro’?” 
\p  
\v 6 Ya mere, Akish kpọrọ Devid sị ya, “Dịka \nd Onyenwe anyị\nd* na-adị ndụ, ị bụ onye kwesiri ntụkwasị obi. Ọ gaara atọ m ụtọ ka ị soro m buo agha. Site na mgbe ị bịakwutere m tutu ruo ugbu a, o nweghị mmejọ ọbụla m chọpụtara nʼime gị. Ma ndịisi anyị anabataghị gị.  
\v 7 Ugbu a, laghachinụ azụ, laa nʼudo. Unu emeela ihe ọbụla ga-akpasu ndịisi ndị Filistia iwe.” 
\p  
\v 8 Devid jụrụ Akish, “Ma gịnị ka m mere? Gịnịkwa ka ị hụtara megide ohu gị site nʼụbọchị m bịakwutere gị ruo taa? Gịnị ga-eme ka m ghara ịlụso ndị iro onyenwe m, bụ eze agha?” 
\p  
\v 9 Akish zaghachiri, “Ama m nʼonye dị mma ka ị bụ nʼanya m, dịka mmụọ ozi nke Chineke. Nʼagbanyeghị nke a, ọchịagha ndị Filistia asịla, ‘Ọ gaghị eso anyị jee nʼagha.’  
\v 10 Ya mere, bilie nʼisi ụtụtụ, gị na ndị ọrụ onyenwe gị ndị soro gị bịa, bilienụ nʼisi ụtụtụ laghachi mgbe ìhè dịrị unu.” 
\p  
\v 11 Devid na ndị ikom na-eso ya biliri nʼisi ụtụtụ ịlaghachi nʼala ndị Filistia. Ma ndị agha ndị Filistia gara nʼihu jeruo Jezril. 
\c 30  
\s1 Devid ebibie ndị Amalek 
\p  
\v 1 Mgbe Devid na ndị ikom ya rutere obodo Ziklag nʼụbọchị nke atọ, ha hụrụ na ndị Amalek abịala wakporo bi nʼakụkụ ndịda Negev na Ziklag. Ha buru agha megide Ziklag, gbaa obodo ahụ ọkụ,  
\v 2 dọtakwa ndị inyom na ndị niile bi nʼime ya nʼagha, ma okenye ma ụmụntakịrị. Ha egbughị ha egbu, kama ha buuru ha laa. 
\p  
\v 3 Mgbe Devid na ndị ikom ya ruru Ziklag, ha hụrụ na-esuola ya ọkụ, dọkpụrụ ndị inyom ha, na ụmụ ndị ikom na ndị inyom nʼagha.  
\v 4 Ya mere, Devid na ndị ikom ya kwara akwa ruo mgbe ike akwa gwụrụ ha.  
\v 5 Ndị inyom abụọ Devid, Ahinoam onye Jezril na Abigel, nwunye ochie Nebal onye Kamel, sokwa na ndị a dọtara nʼagha ahụ.  
\v 6 Ihe a wetaara Devid oke nsogbu, nʼihi na ndị ikom ya nọ na-ekwu okwu iji nkume tugbuo ya; ha niile nọ nʼobi ilu nʼihi ụmụ ha ndị ikom na ndị inyom. Ma Devid chọtara ike nʼime \nd Onyenwe anyị\nd* Chineke ya. 
\p  
\v 7 Devid sịrị Abịata, bụ onye nchụaja, nwa Ahimelek, “Chịtara m efọọd ahụ.” Ya mere, Abịata chịtara ya nye ya  
\v 8 Mgbe ahụ, Devid jụrụ \nd Onyenwe anyị\nd* ase sị, “Ọ bụ m chụso ndị a na-apụnara ndị mmadụ ihe? Ọ bụrụ na m achụso ha, aga m ejide ha?” 
\p \nd Onyenwe anyị\nd* zara, “E, chụso ha ọsọ, ị ga-achụkwute ha, ma nataghachikwa ihe niile ha were.” 
\p  
\v 9 Mgbe ahụ, Devid na narị ndị agha isii ya bịarutere nʼọdọ mmiri Beso, ebe ha hapụrụ ụfọdụ ndị  
\v 10 narị ndị ikom abụọ nʼime ha enwekwaghị ike ịgafe ndagwurugwu Beso nʼihi ike ọgwụgwụ, ma Devid na narị anọ ndị ọzọ chụsoro ha. 
\p  
\v 11 Ha hụrụ otu nwokorobịa onye Ijipt nʼọhịa, duuru ya bịakwute Devid. Ha nyere ya mmiri ka ọ ṅụọ, nyekwa ya nri ka o rie.  
\v 12 Ihe ha nyere ya bụ achịcha fiig,\f + \fr 30:12 \ft \xt 1Sa 25:18\f* na ụyọkọ mkpụrụ vaịnị abụọ nke a mịkpọrọ amịkpọ. Mgbe o richara ha, o nweghachiri onwe ya, nʼihi na o ribeghị nri ọbụla, maọbụ ṅụọ mmiri ọbụla ụbọchị atọ, ehihie na nʼabalị. 
\p  
\v 13 Mgbe ahụ, Devid jụrụ ya sị, “Ị bụ onye? Ebeekwa ka i si bịa?” 
\p Ọ zara Devid sị, “Abụ m onye Ijipt, bụrụkwa ohu onye Amalek. Onyenwe m hapụrụ m nʼebe a abalị atọ gara aga nʼihi na ahụ adịghị m ike.  
\v 14 Anyị si obodo ebe anyị gara lụọ agha na-alọghachi mgbe ha hapụrụ m nʼebe a. Anyị gara lụgbuo obodo ndị Keret,\f + \fr 30:14 \ft Ndị Keret, ha na ndị Filistia nwere ka ha si bụrụ nwanne \xt Zef 2:5\ft  Ma ndị Keret mesịrị soro Devid na-alụ agha \xt 2Sa 15:18; 20:7; 1Ez 1:38,44\f* nke dị nʼime Negeb, na obodo dị na ndịda ala Juda na ala Kaleb. Anyị gbakwara obodo Ziklag ọkụ.” 
\p  
\v 15 Devid jụrụ ya sị, “I nwere ike duru m gaa ebe ha nọ.” 
\p Nwokorobịa ahụ zara ya sị, “Ọ bụrụ na ị ga-aṅụ iyi nʼaha Chineke na ị gaghị egbu m maọbụ were m nyeghachi onyenwe m, aga m eduru gị gaa ebe ha nọ.” 
\p  
\v 16 O duuru ha jee nʼebe ndị Amalek nọ. Mgbe ha ruru ebe ahụ, ha hụrụ ha ebe ha tụsara onwe ha nʼala na-eri na-aṅụ, na-etekwa egwu ọṅụ, nʼihi ihe dị ukwuu ha kwatara nʼagha site nʼala ndị Filistia, na nʼala Juda.  
\v 17 Devid na ndị agha ya bịakwasịrị ha na mberede gbuo ha site nʼabalị ahụ ruo anyasị echi ya. Ọ dịkwaghị otu nwoke nʼime ha fọdụrụ ndụ ma ọ bụghị narị ndị ikom anọ makwasịrị nʼelu ịnyịnya kamel ha gbalaga.  
\v 18 Devid nwetaghachiri ihe niile ndị Amalek kwatara nʼagha, tinyere ndị inyom ya abụọ.  
\v 19 O nweghị ihe furu efu, ma nke ukwu ma nke nta, ụmụ ndị ikom na ụmụ ndị inyom, ihe a kwatara nʼagha, maọbụ ihe ọbụla ọzọ ndị Amalek dọtara nʼagha. Devid nwetaghachiri ihe niile.  
\v 20 Ọzọkwa, Devid chịkọtara igwe ehi na igwe ewu na atụrụ. Ndị ikom ya chịịrị ha, tinyere anụ ụlọ ndị ọzọ, na-aga, na-asị, “Ndị a bụ ihe Devid kwatara nʼagha.” 
\p  
\v 21 Emesịa, Devid bịarutere ebe narị ndị ikom abụọ ndị ahụ nọ na Ndagwurugwu Beso. Ndị a bụ ndị ahụ na-enweghị ike iso Devid nʼihi na ike gwụrụ ha. Ha pụtara zute Devid na ndị so ya. Mgbe Devid na ndị ikom ya bịara ha nso, ọ jụrụ ha otu ha mere.  
\v 22 Ma ndị ikom ọjọọ ahụ niile, na ndị okwu na ụka nọ nʼetiti ndị na-eso Devid sịrị, “Nʼihi na ndị a esoghị anyị jee, ya mere ha agaghị eso anyị keta ihe ndị a anyị kwatara nʼagha. Nyeghachi ha naanị nwunye ha na ụmụ ha; gwakwa ha ka ha laa.” 
\p  
\v 23 Ma Devid sịrị, “Mba, ụmụnna m, unu ekwesighị isi otu a kee ihe ndị ahụ \nd Onyenwe anyị\nd* nyere anyị. O chebere anyị, nyefee nʼaka anyị ndị agha ahụ niile bịara imegide anyị.  
\v 24 Unu chere na ọ dị onye ga-ege unu ntị mgbe unu na-ekwu okwu dị otu a? Anyị niile ga-eketa oke; oke ndị jere agha na ndị chebere ihe anyị ga-abụ otu.”  
\v 25 Site nʼụbọchị ahụ, Devid mere ka nke a bụrụ iwu nye ndị Izrel niile ruo taa. 
\p  
\v 26 Mgbe ha rutere Ziklag, Devid weere ụfọdụ ihe ha kwatara nʼagha zigara ndị okenye Juda, ndị bụ ndị enyi ya, na-asị, “Lee onyinye ewetaara unu site nʼụfọdụ nʼime ihe anyị kwatara site nʼaka ndị iro \nd Onyenwe anyị\nd*.” 
\p  
\v 27 O zigara ha nye ndị bi na Betel, Ramọt Negev na Jatịa,  
\v 28 nyekwa ndị nọ Aroea, Sifmot, Eshtemoa  
\v 29 na Rakal, nyekwa ndị bi nʼobodo ndị Jerameel na nke ndị Ken,  
\v 30 nyekwa ndị bi na Homa, Bo Ashan, Atak  
\v 31 na Hebrọn na ndị nọ nʼebe niile ndị ahụ ebe Devid na ndị ya wagharịrị. 
\c 31  
\s1 Ọnwụ Sọl na ụmụ ya 
\p  
\v 1 Nʼoge a, ndị Filistia lụsoro ndị Izrel agha, ndị Izrel si nʼihu ha gbaa ọsọ, ma ọtụtụ nʼime ha nwụrụ nʼugwu Gilboa.  
\v 2 Ndị Filistia ji ike chụso Sọl na ụmụ ya. Ha gburu ụmụ ya ndị ikom, Jonatan, Abinadab na Malkishua.  
\v 3 Agha ahụ siri ike nke ukwuu megide Sọl, mgbe ndị na-agba ụta chụkwutere ya ha merụrụ ya ahụ nʼebe ọ dị ukwuu. 
\p  
\v 4 Sọl gwara onye na-ebu ngwa agha ya, sị, “Mịpụta mma agha gị, were ya magbuo m ka ndị a a na-ebighị ugwu ghara ịbịa jiri m mee ihe egwuregwu.” 
\p Ma onye na-ebu ngwa agha ya ekweghị, nʼihi ọnọdụ oke egwu. Nʼihi ya, Sọl were mma agha nke ya, dakwasị nʼelu ya.  
\v 5 Mgbe onye na-ebu ihe agha Sọl hụrụ na ọ nwụọla, ya onwe ya dakwasịkwara nʼelu mma agha nke ya, soro Sọl nwụọ.  
\v 6 Ya mere, Sọl na ụmụ ya ndị ikom atọ, onye na-ebu ihe agha ya na ndị agha ya niile, nwụrụ nʼotu ụbọchị ahụ. 
\p  
\v 7 Mgbe ndị Izrel nọ nʼofe ọzọ nke ndagwurugwu, na ndị nọ nʼofe Jọdan, hụrụ na ndị agha Izrel agbaala ọsọ, na Sọl na ụmụ ya ndị ikom anwụọla, ha hapụrụ obodo ha niile gbapụ ọsọ. Ndị Filistia bịakwara bichie nʼime ha. 
\p  
\v 8 Nʼechi ya, mgbe ndị Filistia bịara iyipụ ndị nwụrụ anwụ ihe ha ga-achịkọrọ, ha hụrụ ozu Sọl na nke ụmụ ya ndị ikom atọ ka ha tọgbọ nʼugwu Gilboa.  
\v 9 Ha bipụrụ Sọl isi, yipụkwa ya ihe agha ya. Ha zipụkwara ndị ozi gara nʼala ndị Filistia niile ikwusa akụkọ ihe mere nʼụlọ arụsị ha nakwa nʼetiti ndị ha niile.\f + \fr 31:9 \ft \xt Nkp 16:23-24; 2Sa 1:20\f* 
\v 10 Ha tinyere ihe agha Sọl nʼụlọ Ashtọret, kpọgidekwa ozu ya nʼaja ụlọ mgbidi obodo Bet-Shan. 
\p  
\v 11 Mgbe ndị obodo Jebesh Gilead\f + \fr 31:11 \ft \xt 1Sa 11:1-13\f* nụrụ ihe ndị Filistia mere Sọl,  
\v 12 ndị ikom ha niile bụ ndị dimkpa, gara njem ogologo abalị ahụ niile jeruo Bet-Shan. Ha sitere nʼelu mgbidi obodo Bet-Shan tọda ozu Sọl na nke ụmụ ya ndị ikom buru ha laa Jebesh ebe ha nọ kpọọ ozu ha ọkụ.  
\v 13 Ha liri ọkpụkpụ ha nʼokpuru osisi Tamarisk dị na Jebesh, buo ọnụ ụbọchị asaa.