\id COL - Ikwerre
\h Ele Kọlosi
\toc1 Ọkwukwo izi Pọlu gbaznennu Ele Kọlosi
\toc2 Ele Kọlosi
\toc3 Kọl
\mt2 Ọkwukwo izi Pọlu
\mt2 gbaznennu
\mt1 Ele Kọlosi
\imt1 Nhne gbasịri ọkwukwo izi ka
\im Kọlosi bụ ẹli-ọhna ke zị mkpa nụ rime Esia Matị. Pọlu nye gbarụ ọkwukwo izi ka znélele Kọlosi, kọvu ọ nụrnu nụ ele Karaịsi zị pịi gwuzosiri rikne n'ọkwnata ovu be (1:3-7; 2:6,7). Be nụrnu izi ọma hite n'ọnu otu nye be kwu Epafarasị nye wu pịi (1:7; 4:12,13), kọvu ya nụ Pọlu zị nụ ikelu (Faịlemoni 23) n'ige Pọlu gbarụ ọkwukwo izi ka (1:14; 4:3,10,18).
\ip Agịda ele zị nụ ọgbako Chiokike ke zị nụ Kọlosi bụ́o ele Ju (1:27), ke kpayarụ agịda okpukpe zị ichne ichne nụ omen'ẹli noopio o megbu be. Pọlu pioru be mahịa nụ Karaịsi zị n'oligwe nẹechi kpakara rikne ke zị n'ọwa (3:1). Ka neegesi nụ be jeekpenu Karaịsi kpọi.
\ip Karaịsi bụ oyiyi ke Chiokike, nye be whnụ́ anya.
\ip Karaịsi bụ nye risi kpakara nhne Chiokike keru.
\ip Ọ masịri Chiokike o mee kpakara nhne wuru nụ rime Karaịsi.
\ip O mernu ka ma ya nụ kpakara nhne zịri n'udno (1:15,19,20a).
\iot Nhne zị n'ọkwukwo izi ka
\io1 Obekwu ikwu \ior (1:1,2)\ior*
\io1 Ọtu mmamma \ior (1:3-14) \ior*
\io1 Badnụ nụ ẹrnu Karaịsi \ior (1:15---2:19) \ior*
\io1 Bụdnu ikne nụ rime Karaịsi \ior (2:20---4:6) \ior*
\io1 Obekwu ikwu ipne-aznụ \ior (4:7-18) \ior*
\c 1
\p 
\v 1 Mawa, Pọlu, nye izi Karaịsi Jizọsi lele kpa echiche Chiokike jiri zị, nụ nnwọ nda aị Timoti,
\v 2 naagbaznenu rụmu Nda aị ele zị nsọ, ele kwesiri ọkwnata mkpọma nụ Karaịsi, ele ke zị nụ Kọlosi ọkwukwo. Oru nụ udno ke Chiokike Nda aị dazịnu anụ.
\s1 Pọlu tụru mmamma
\p 
\v 3 A nọotunu Chiokike mmamma, Nda Nyenwe aị Jizọsi Karaịsi, neekpenu anụ okpukpe ige ọbula.
\v 4 Kwnornu nụ a nụrnu nhne gbasịri ọkwnata mkpọma anụ nụ Karaịsi Jizọsi nụ ọwhnun'anya anụ nwernu hne kpakara ele nsọ Chiokike zị.
\v 5 Olile anya ke be bịtannu anụ n'oligwe neenye anụ ọkwnata mkpọma nụ ọwhnun'anya ka. Anụ nụrnu nhne gbasịri olile anya ka n'ezi ọka ke izi ọma,
\v 6 bụ izi ọma ke vakwnusiri anụ. Izi ọma ka naamịya mkpụru, nooso masị nụ kpakara ọwa, lele kpa o neeme n'esilawụru anụ hite n'ọbochi anụ nụrnu a, ghọhia masị oru Chiokike n'ezi.
\v 7 Anụ nụrnu izi ọma ka n'ọnu Epafarasị nye izi ibne aị a whnụrnu n'anya, nye bụ nye ẹrnu Karaịsi nye kwesiri ọkwnata mkpọma n'ọnodi aị.
\v 8 Ọ kannụ aị nhne gbasịri ọwhnun'anya anụ ke Enine Chiokike nyernu anụ.
\p 
\v 9 Kam kpayarụ, hite n'ọbochi a nụrnu nhne gbasịri anụ, a zị neekpenu anụ okpukpe, nọorio Chiokike ma anụ mahịa echiche a nkarị nkarị hite nụ kpakara akọniche nụ ọghohia ke Enine Chiokike neenye.
\v 10 A nọorio ma anụ wuru bụdnu ke jeegweyanụ Nyenwe aị igwugwu, neeme nhne jaamasị Nyenwe aị n'apna ọbula, naamị mkpụru ọma zị ọdo n'ọdo. Ka jeeme anụ nooso, naamahịa Chiokike nkarị nkarị.
\v 11 Anụ bụru ele gbasịri rikne hite nụ kpakara rikne nụ iknernema ke zị igwugwu Nyenwe aị ma anụ nwehịa ọsnuta mkpọma nụ ndidi. Anụ gweru ovu ọso n'ọnu
\v 12 nọotunu Nda aị mmamma, nye mernu anụ nwernu igwe n'esilawụru rụmu Chiokike zị nsọ n'ẹli-eze ke iwhne.
\v 13 Kwnornu nụ Chiokike dọhiaru aị n'aka nye wam nẹechi nụ rime ọchichiri, kwubnanya aị n'ẹli-eze ke Nnwọ a, nye ọ whnụrnu n'anya.
\v 14 O nyernu aị ọgbahia ke bụ ọgbaru mmehie.
\s1 Karaịsi kakwo kpakara // nhne
\p 
\v 15 Karaịsi bụ oyiyi ke Chiokike, nye be whnụ́ anya. Karaịsi bụ nye risi kpakara nhne Chiokike keru.
\v 16 Chiokike keru kpakara nhne hite n'aka a, kpakara nhne ke zị n'oligwe nụ ọwa, nhne anya nọowhnu nụ nhne anya zá nọowhnu, be bụ ele dazị nụ ngadna eze, mọbu ele nwernu rikne nụ ele nẹechi ẹchi nụ ele nwernu iknernema. Chiokike keru kpakara nhne hite n'aka a, ma kpakara nhne nyee a igwugwu.
\v 17 Ọ zị tụtu nhne ọbula, kpakara nhne jikọtaru n'otu nụ rime a.
\v 18 Ya bụ risi ẹhni a, ke bụ ọgbako Chiokike. Ya bụ ọpanizo nụ mkpụru mbọm ke ele hiri n'ẹnwu lizọ, ma ọ bụru nye risi kpakara nhne.
\v 19 Kwnornu nụ ọ masịri Chiokike o mee ma kpakara nhne ọ bụ, wuru nụ rime Karaịsi.
\v 20 O mernu ka ma ya nụ kpakara nhne zịri n'udno, ma nhne ke zị n'ọwa ma nhne ke zị n'oligwe, ma ya nụ be mee udno hite n'ọvnarna a ke ọ wụsaru n'olu ọgba.
\p 
\v 21 Nụ mbọm, anụ bụ ele zị ikere hne Chiokike zị nụ ele irno n'ovu anụ kwnornu n'ẹrnu ọjo anụ.
\v 22 Kọvu kịtna, o mernu anụ nụ ya zịri n'udno hite n'ẹnwu Karaịsi nwụrnu n'anọ-ẹhni, ma o gweru anụ chete nụ ruwhnu a, ele zị nsọ, nwée ọru mọbu nhne be bnornu be,
\v 23 ọ bụru nụ anụ gwuzosi rikne n'ọkwnata ovu, ele gwuzo kwem, anụ kwé nhne ọbula gweme anụ n'olile anya izi ọma ke anụ kweru. Ka bụ izi ọma ke anụ nụrnu, be kpọru okwo a nụ kpakara mkpururu oligwe, ke me Pọlu bụ nye izi a.
\s1 Ẹrnu Pọlu
\p 
\v 24 M nọonwudna ọnwudna kịtna kwnornu awhnụwhnu me tarụ nụ risi anụ, m ji m anọ-ẹhni m mezu nhne ke gwnarnụ gbasịri awhnụwhnu Karaịsi tarụ, kwnornu ẹhni a, ke bụ ọgbako Chiokike.
\v 25 M ghọru m nye izi ọgbako Chiokike hite n'ẹrnu Chiokike nyernu m me zni anụ ikwu-ọnu Chiokike n'ozuzu oke a.
\v 26 Ikwu-ọnu Chiokike ka bụ nhne ke tugwaru otugwa agịda ige nụ agịda ebiri, kịtna, o kpumennu a ele nsọ a.
\v 27 Ọ masịri Chiokike o mee ele ke a mahịa nhne tugwaru otugwa ke bụ nụ ẹkwnu ke zị igwugwu bụ ke ele bụ́o ele Ju. Ẹkwnu ka bụ Karaịsi nụ rime anụ, bụ olile anya nụ anụ jeekehịa igwe n'ebube a.
\p 
\v 28 A nọokpo okwo gbasịri Karaịsi, nọodo ele badnụ aka nụ nsnị, neezni nye ọbula hite n'akọniche Chiokike nyernu aị, ma a gweru nye ọbula chete nụ ruwhnu Chiokike nụ ozu oke kwnornu Karaịsi.
\v 29 Kam kpayarụ, m ji m kpakara rikne Karaịsi nyernu m ke nọornusi ẹrnu rikne, m nọodogbu ẹhni m n'ẹrnu ka.
\c 2
\p 
\v 1 M pioru m anụ mahịa kpa me nọodogbu ẹhni m n'ẹrnu kwnornu anụ nụ ele zị nụ Laodisia, nụ kpakara ele whnụ́lele m anya.
\v 2 Ka bụ ma be kwnagidne be n'ovu, zịri masị n'otu n'ọwhnun'anya, ma be nwehịa kpakara ẹkwnu ke ọghohia ke zuru ozu, ka jeeme be mahịa nhne tugwaru otugwa ke Chiokike, ke bụ Karaịsi.
\v 3 Kpakara nhne ke tugwaru otugwa zị nụ rime a, ke bụ akọniche nụ nhne ọmuma.
\v 4 M naakanụ anụ ka, anụ kwé nye ọbula duwhu anụ hite n'ikwu-ọnu ke nọoso n'ọnu.
\v 5 Ọ bụ n'ezi nụ me nụ anụ zị́la n'anọ-ẹhni, kọvu me nụ anụ zị nụ enine. Ọ nọoso m kpa me nọowhnu nụ anụ noowu bụdnu lele kpa o kwesiri, noogwuzo kwem n'ọkwnata ovu ke zị nụ Karaịsi.
\s1 Karaịsi neegweya // bụdnu n'ezi
\p 
\v 6 Lele kpa anụ nahịaru Karaịsi Jizọsi lele Nyenwe aị, anụ dazịgidne noowu bụdnu nụ rime a.
\v 7 Anụ gba ẹgwnugwnu nụ rime a, anụ wulizọ ẹhni anụ lele ọro kpa ọ bụ ntụ-ẹli ọro, gbasị rikne n'ọkwnata ovu lele kpa be znirni anụ, ọtu mmamma jihịa ovu anụ.
\p 
\v 8 Anụ kwé badnụ ọbula duwhu anụ hite nụ ikwu-ọnu etekne nụ aghịgho ikwu-ọnu bnána nụ nhne, ke knosịri aka n'omen'ẹli ke ele badnụ nụ rẹnwu ọjo matị matị ke ọwa ka, bụ́o ke Karaịsi.
\p 
\v 9 Kwnornu nụ kpakara nhne Chiokike bụ wu nụ rime Karaịsi n'anọ-ẹhni a.
\v 10 Chiokike mernu anụ sozu nụ badnụ nụ rime Karaịsi, nye bụ risi kpakara ele nwernu rikne nụ ele ọchichi.
\v 11 Be kparụ anụ nka nụ rime a, ke bụ ogweme mmehie anụ, ọ bụ́o nka ke be jiri aka ele badnụ kpa, kọvu nka ke Karaịsi n'iwhuru a kparụ.
\v 12 Hne be likọtaru anụ nụ ya n'ọwuwu-mini, be gwelizọkota anụ hite n'ọkwnata ovu anụ n'iknernema Chiokike, nye mernu Karaịsi hi n'ẹnwu lizọ.
\p 
\v 13 Anụ bụ ele nwụrnu ọnwu nụ rime mmehie, anụ bụ ele bụ́o ele Ju be kpála nka. Kọvu Chiokike mernu anụ snornu Karaịsi zịri bụdnu, kpa ọ gbarụnu aị kpakara mmehie aị.
\v 14 O dọkaru kpakara ọkwukwo be gbarụ nụ kpakara iwu ke megidnernu aị, o gweme be, kpọgidne be n'ọgba Jizọsi.
\v 15 Chiokike nahọru kpakara ele ọchichi nụ ele nwernu rikne iknernema, kpasị be iwhnerne nụ ruwhnu ọhna, neegesi nụ o megburu be hite n'ọgba Jizọsi.
\p 
\v 16 Kam kpayarụ, anụ kwé nye ọbula gweru nhne anụ neeri mọbu nhne anụ nọonwo, mọbu nụ anụ zá naabịta mmemem okpukpe, mọbu ẹnwa ikne, mọbu Ọbochi Ozukwa Inwe, kpe anụ ikpe.
\v 17 Kpakara nhne ka bụ enine nhne ke jaava, kọvu risi nhne bụ Karaịsi.
\v 18 Anụ kwé nye ọbula ke ọ naamasị o gwedna ẹhni a ẹli nụ okpenu ele enine izi mee anụ bụru ele kwésile, ọ bụ n'ezi nụ nye wam ka nụ ọ whnụrnu ọwhnurninya gbasịri be, ovu ke badnụ a mernu a ọ bụru nye nganga n'etekne.
\v 19 Nye wam bụ nye gwemernu ẹhni a nụ Karaịsi, nye bụ risi ẹhni, nye mernu kpakara rụknani nụ rẹkpu ọchi nụ aka knekọta n'otu. Kpa ọ nọoznu kpakara ẹhni, o nooso lele kpa Chiokike neeme a nooso.
\p 
\v 20 Anụ snornu Karaịsi nwụ ẹnwu, o mernu anụ nwernu ẹhni anụ whọga nụ rikne rẹnwu ọjo matị matị ke ọwa ka. Kịni mernu anụ noowu bụdnu lele nụ anụ bụ ke ọwa, naabịta iwu be?
\v 21 Bụ ke karụ, “Anụ kpá ka aka, anụ rátụ a riro, anụ kpá kịyari aka.”
\v 22 Kpakara iwu ka gbasịri nhne ke joowhu kpa ele badnụ jiri be rnụ ẹrnu mọbu rikwo be, iwu ele ka kno aka nụ nhne ele badnụ nyernu n'iwu nụ iznizni be.
\v 23 Kpakara iznizni nụ kpa nụ lele nhne nwernu akọniche, ke bụ okpenu Chiokike lele kpa badnụ karụ be kpenu a, ogwedna ẹhni be n'ẹli, nụ ome anọ-ẹhni nhne rikne, kọvu be nwée rikne bnosni echiche ọjo ke ovu.
\c 3
\s1 Owu bụdnu zị nsọ
\p 
\v 1 Hne ọ bụ nụ anụ nụ Karaịsi hiri n'ẹnwu lizọ n'otu, anụ bịta ovu anụ nụ nhne zị n'olu, hne Karaịsi dazị n'ẹli n'akarikwnunga Chiokike.
\v 2 Anụ neeche echiche nụ nhne zị n'olu, ọ bụ́o nụ nhne zị n'ọwa.
\v 3 Kwnornu nụ anụ nwụrnu ọnwu, bụdnu anụ nụ Karaịsi bụ nhne tugwaru otugwa nụ rime Chiokike.
\v 4 Nga Karaịsi nye bụ bụdnu anụ jọowhuya iwhne, anụ joosno a whụya iwhne, kehịa igwe n'igwugwu a.
\p 
\v 5 Anụ mee ma kpakara nhne ke bụ nhne ọwa nwụ ẹnwu, kpakara ome ọyi, ọ́zi rịchna, ẹgwnurnu nhne ọjo, echiche ọjo nụ anya-kwu, ke nụ lele ọkwa rẹnwu.
\v 6 Kam kpayarụ, ovu owe ẹhni Chiokike naadnakwasị kpakara ele zá noobno nsnị.
\v 7 Ka bụ kpa anụ wuru bụdnu nga anụ bụ ele ke ọwa.
\v 8 Kọvu kịtna, anụ gweme kpakara nhne ka nụ rime anụ, ovu owe ẹhni, ọnuma, irno ovu, ọkaja, nụ ikwu-ọnu zị́la rịchna nụ mgbele-ọnu anụ.
\v 9 Ọ zá nye ọbula ghanụ ibne a aghalaghala, hne anụ gwemernu badnụ ọknani wam nụ kpakara ẹrnu ọjo a.
\v 10 Anụ worulem badnụ ikne lele iwo. Chiokike neeme anụ zịri ikne ma anụ mụhia nhne gbasịri nye kpụru anụ.
\v 11 Ọ zá nhne zị ichne nụ hne nye Giriki mọbu nye Ju zị, nye be kparụ nka nụ nye be kpáge nka, nye izne, nye nụ lele anọhia,\f + \fr 3:11 \fq nye nụ lele anọhia \ft ọkwukwo ke mbọm kwuru: \fq nye Sikitia\f* ọhi mọbu nye bụ́o ọhi, kọvu Karaịsi bụ kpakara nhne, nye zị masị nụ rime kpakara badnụ.
\p 
\v 12 Kam kpayarụ, lele kpa ele Chiokike họhiaru, ele nsọ a, ele ọ whnụrnu n'anya, anụ woru obirizi, ovu ọma, ogwedna ẹhni anụ ẹli, ọzi wọhnernerne nụ ọsnuta ovu lele iwo.
\v 13 Anụ naagidne ibne anụ, gbarụnu ibne anụ nhne ọbula be mehieru anụ. Anụ gbarụnu ibne anụ lele kpa Chiokike n'iwhuru a gbarụnnu anụ.
\v 14 Tụkwasi n'olu kpakara nhne ka ọwhnun'anya, bụ nhne ke neeknegidne kpakara be n'otu n'apna ke zuru ozu.
\p 
\v 15 Anụ kweru ma udno ke Karaịsi nẹechi ovu anụ, lele ele bụ otu badnụ, ele Chiokike sukwuru bna n'udno. Anụ nọotu mmamma.
\v 16 Anụ kweru ma ikwu-ọnu Karaịsi gweru ẹkwnu a wuru nụ rime anụ, kpa anụ ji akọniche neezni ibne anụ nhne, neezni be ezni. Anụ nọogwnu eri ọma, eri ọznarni, nụ eri mkpọma ọso n'ọnu, gweru ovu anụ nọotunu Chiokike mmamma.
\v 17 Nhne ọbula anụ neeme, ọ bụ n'ikwu-ọnu mọbu nhne aka neeme, anụ mee kpakara nhne nụ rẹwhna Nyenwe aị Jizọsi, nọotunu Chiokike Nda mmamma hite nụ a.
\s1 Ezi-nụ-ọro nye Karaịsi
\p 
\v 18 Ele bụ nnwerne, anụ bịta ẹhni anụ nụ mkpururu nzi anụ, kpa o kwesiri ele noosno Nyenwe aị.
\p 
\v 19 Ele bụ nzi, anụ whnụ nnwerne anụ n'anya, anụ mée be nhne rikne.
\p 
\v 20 Ele bụ rụmu, anụ noobnonu ele mụrnu anụ nsnị nụ kpakara nhne, ka bụ nhne Nyenwe aị noopio.
\p 
\v 21 Ele nda, anụ mékọ rụmu anụ ovu owe ẹhni, ọ zị inwe gwụ be.
\p 
\v 22 Ele ọhi, anụ noobnonu ele nwe anụ n'ọwa nsnị nụ kpakara nhne, anụ neeme be, ọ bụ́o nga be neele anụ anya ma anụ bụru ele ọma be, kọvu ma nga be zá neele anụ anya. Anụ gweru ovu anụ nọoso be anya n'ezi, nọotu ogwnu Nyenwe aị.
\v 23 Nhne ọbula anụ neeme, anụ gweru kpakara ovu anụ mee be lele ele nọornunu Nyenwe aị ẹrnu, ọ bụ́o lele ele nọornunu ele badnụ ẹrnu.
\v 24 Anụ magwụ nụ anụ jeekehịa mkpe n'aka Nyenwe aị lele ọgwo ẹrnu, hne ọ bụ Karaịsi bụ nye anụ nọornunu ẹrnu.
\v 25 Nye ọbula ke nọornu ẹrnu ọjo jaanahịa ọgwo ẹrnu ọjo n'aka Chiokike. Chiokike zá neele badnụ anya nụ ruwhnu.
\c 4
\p 
\v 1 Ele nwe ele ọhi, anụ mee ọhi anụ nhne bụru ọma nụ nhne kwesiri, kwnornu nụ anụ nwernu Nyenwe anụ ke zị n'oligwe.
\s1 Agịda ezni
\p 
\v 2 Anụ gwéme aka n'okpe okpukpe, neese nse, nọotu mmamma.
\v 3 Anụ kpenu aị okpukpe masị, ma Chiokike gbamanụ aị ọnuhna o zni izi ọma, ma a kpọ okwo nhne tugwaru otugwa ke Karaịsi. Ka bụ nhne mernu me zị n'ikelu.
\v 4 Anụ kpe okpukpe ma m kpọ m okwo izi ọma ka kpa ele badnụ jọoghohia a, ka bụ ẹrnu me kwesiri ọ rnụ.
\v 5 Anụ gweru akọ kpa agwa ọma n'esilawụru ele bụ́o ele Karaịsi. Anụ gweru oghere ọbula anụ nwernu mee nhne.
\v 6 Anụ mee ma ọtnurita ọtnutnu anụ bụru nhne nwernu ovu ọma, ke nọoso n'ọnu lele arụa, ma anụ mahịa nhne anụ jaasa nye ọbula.
\s1 Obekwu ikwu ipne-aznụ
\p 
\v 7 Taịkikosi, nnwọ nda a whnụrnu n'anya nụ nye ẹrnu Nyenwe aị ke kwesiri ọkwnata ovu, nye izi ibne aị, jaakanụ anụ kpakara nhne gbasịri m.
\v 8 M neeziyanu anụ ya ma anụ mahịa kpa a zị, ma o mee ovu si anụ rikne.
\v 9 Ya nụ Ọnesimosi sno naava, nye bụ nnwọ nda a whnụrnu n'anya kwesiri ọkwnata ovu, nye bụ masị otu nụ rime anụ. Be jaakanụ anụ kpakara nhne ke neeme hna.
\p 
\v 10 Arịsitakosi, nye me nụ a zị n'ikelu neebekwu anụ, ma Makị, nnwọ nwene Banabasị. Anụ nụrnu nhne gbasịri a, anụ nabnanya a nga ọ varụ.
\v 11 Jizọsi, nye be kwu Jọsitosi neebekwu anụ. Ka kwolem ele Ju ibne m me nụ be sno nọornu ẹrnu ẹli-eze Chiokike, be neeme ovu si m rikne.
\p 
\v 12 Epafarasị, nye bụ otu nụ rime anụ nụ nye izi Karaịsi Jizọsi neebekwu anụ. Ọ zị naagba ọtna n'okpukpe nụ risi anụ, naarịasno Chiokike ma anụ gwuzosi rikne n'ome nhne bụ echiche a, bụru masị ele sozuru nụ badnụ.
\v 13 M naagbanụ a akebne nụ ọ nọornusi ẹrnu rikne kwnornu anụ nụ ele zị nụ Laodisia nụ Hịrapolisi.
\v 14 Enyi aị Lukwu wọdibia a whnụrnu n'anya, nụ Demasị neebekwu anụ.
\v 15 Anụ bekwunu m rụmu nda ele zị nụ Laodisia, nụ Nimfa, ma ọgbako Chiokike zị n'ọro a.
\p 
\v 16 Kpa anụ gwnụrnu ọkwukwo izi ka, anụ whnụ nụ be gwnụrnu a n'ọgbako Chiokike ke zị nụ Laodisia. Anụ gwnụ masị ọkwukwo izi me gbannụ ele Laodisia.
\p 
\v 17 Anụ kanụ Akịposi, “Whnụ nụ ị rnụkworu ẹrnu ị naahịaru n'aka Nyenwe aị.”
\p 
\v 18 Mawa, Pọlu, ji aka m gba obekwu ikwu ka. Anụ chenwanya nụ m zị m n'ikelu. Oru Chiokike dazịnu anụ.
