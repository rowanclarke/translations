\id HEB
\h Iɛibraniyyen
\toc1 Iɛibraniyyen
\toc2 Iɛibraniyyen
\toc3 Ɛbr.
\mt1 Iɛibraniyyen
\c 1
\s1 Mmis yuɛřa aṭṭas x lmalakat
\m 
\v 1 Deg wussan iɛdun issiweř AREBBI di kuř řweqt u deg waṭṭas n ibriden ak-d řejdud nneɣ s inabiyyen.
\v 2 Deg wussan-a ineggura aqa issiweř-dd akidneɣ s Mmis, wenni igga d Awrit n kuřci, s Wenni \add ɛawed\add* igga zzmanat. \x ◘ \xo 1:2 \xt Amz. 1:3; Izhd. 33:6; Mt. 21:38; Yḥ. 1:3; Afa. 3:9; Kul. 1:16.\x*
\v 3 Minzi Netta d talellect n uɛuǧi nnes uřa d tteswirt n Simant nnes, u \add Netta d\add* wenni yarebbun marra timesřayin s jjehd n Wawař nnes. Aqa Netta issizdeg ddnub nneɣ di ṭṭbiɛet n Yixef nnes, uca iruḥ iqqim ɣar yefus n Lɛaḍim di řuɛřa. \x ◘ \xo 1:3 \xt 2 Kur. 4:4; Fil. 2:6; Kul. 1:15. \x*
\v 4 Netta yuɛřa aṭṭas x lmalakat am Isem i iṭṭef d řwart, aqa icna x wenni nsen.
\m 
\v 5 Minzi i man ten zi lmalakat inna AREBBI:
\b
\m \qt “Mmi i teǧid Cek,\qt*
\m \qt ass-a Necc jjiɣ-dd Cek!”,\qt*
\b
\m uca ɛawed inna:
\b
\m \qt “Necc ad as iřiɣ d Babas\qt*
\m \qt u Netta ad ayi yiři d Mmi”?\qt* \x ◘ \xo 1:5 \xt 2 Ṣm. 7:14; 1 Im. 17:13; 22:10; Izhd. 2:7; Řex. 13:33; Ɛbr. 5:5. \x*
\b
\m 
\v 6 Uca xenni xmi dd-issidef Amenzu ɣar ddunect, inna:
\b
\m \qt “Ad as sejdent marra lmalakat n AREBBI.”\qt* \x ◘ \xo 1:6 \xt Izhd. 97:7. \x*
\b
\m 
\v 7 \add Maca\add* x lmalakat inna:
\b
\m \qt “Netta igga lmalakat nnes d isemmiḍen,\qt*
\m \qt uca imsexxaren nnes\qt*
\m \qt d ict n tmessi itteḥduduqen”,\qt* \x ◘ \xo 1:7 \xt Izhd. 104:4 \x*
\b
\m 
\v 8 Maca x Mmis:
\b
\m \qt “Řɛarc nnec, \tl a\tl* AREBBI,\qt*
\m \qt aqa iǧa i řebda qaɛ.\qt*
\m \qt Azeǧaḍ n Tgeldit nnec,\qt*
\m \qt aqa-tt d azeǧaḍ iseggden.\qt* \x ◘ \xo 1:8 \xt Izhd. 45:7. \x*
\m 
\v 9 \qt Aqa texsed tasegda, tcarhed řɣar.\qt*
\m \qt S uyenni aqa idhen i c\qt*
\m \qt AREBBI, AREBBI nnec,\qt*
\m \qt s zzect n řefraḥet\qt*
\m \qt sennej i imɛacaren nnec.”\qt* \x ◘ \xo 1:9 \xt Izhd. 45:7, 8 \x*
\b
\m 
\v 10 Uca xenni:
\b
\m \qt “Zeg ubeddu teggid Cek dsas n temmurt,\qt*
\m \qt ijenwan ǧan d řxedmet n ifassen nnec\qt*. \x ◘ \xo 1:10 \xt Izhd. 102:26. \x*
\m 
\v 11 \qt Ina ad ttwateḥḥan, maca Cek ad tdumed,\qt*
\m \qt uca ina marra ad arcan am warruḍ.\qt* \x ◘ \xo 1:11 \xt Ica. 51:6; 2 Bṭ. 3:7, 10. \x*
\m 
\v 12 \qt Amecnaw ijj n useřham ad ten ttḍefsed.\qt*
\m \qt Ad ttwabeddřen \tl am warruḍ\tl*,\qt*
\m \qt maca Cek ad tiřid d wenni\qt*
\m \qt uca iseggʷusa nnec war qeṭṭin ca.”\qt* \x ◘ \xo 1:12 \xt Izhd. 102:26-28. \x*
\b
\m 
\v 13 \add Maca\add* i man ten zi lmalakat inna ijj n wass:
\b
\m \qt “Qqim ɣar yefus inu\qt*
\m \qt ař d ɣa ggeɣ řɛedyan nnec\qt*
\m \qt d tanebdat sadu iḍaren nnec”?\qt* \x ◘ \xo 1:13 \xt Izhd. 110:1; Řex. 2:34; 1 Kur. 15:25; Afa. 1:20; Ɛbr. 10:12. \x*
\b
\m 
\v 14 Ma war ǧint nitenti d arruḥat i tsexxart, ttwassekkent-i-dd ḥima ad sexxarent i yinni ɣa iwarten Tudart?
\b
\b
\c 2
\s1 Yasuɛ Lmasiḥ, Arrays nneɣ yareḥḥmen n ikehhanen
\m 
\v 1 S uyenni ittxeṣṣa aneɣ ad newc taynit ktar i min nesřa, ḥima war nᵉtteffeɣ zeg webrid.
\v 2 Minzi, mařa awař i innan lmalakat tuɣa tbedd u marra wi t isřin, \add maca\add* iɛdu xas, aqa ittwaxeǧeṣ s řḥeqq, \x ◘ \xo 2:2 \xt Amz. 19:17, 26; Aɛwd. 27:26; Řex. 7:53; Gal. 3:19. \x*
\v 3 mammec i ɣa negg ad narweř neccin, mařa nesseḥqara timesřayin i iǧan d Tudart i neccin, \add timesřayin\add* i xef tuɣa issawař Siditneɣ ɣar umezwaru, uca \add xenni\add* ttwaḍemnent aneɣ zeg yinni jaraneɣ i tuɣa \add tent\add* zzayes isřin, \x ◘ \xo 2:3 \xt Mt. 4:17; Mk. 1:14; Ɛbr. 12:25. \x*
\v 4 \add umi\add* AREBBI iched akidsen s řeɛřamat d lmuɛjizat d řeɛjayeb ifarzen u s tmewci n Arruḥ Iqeddsen, tinni immewcen am mammec ixs Netta. \x ◘ \xo 2:4 \xt Mk. 16:20; Řex. 14:3; 19:11. \x*
\v 5 Minzi war issars ca zzman i dd ɣa yasen x tenni nessiweř, sadu \add řumur n\add* lmalakat,
\v 6 maca am mammec cehhdent u qqarent Tira \add Iqeddsen\add*:
\b
\m \qt “Min iɛna bnadem,\qt*
\m \qt aqa Cek i dayes ittxarraṣen,\qt*
\m \qt \tl u min iɛna\tl* Mmis n bnadem,\qt*
\m \qt aqa Cek i dayes itthillan?\qt* \x ◘ \xo 2:6 \xt Izhd. 8:5. \x*
\m 
\v 7 \qt Cek teggid t cwayt sadu lmalakat,\qt*
\m \qt teggid as aɛuǧi d ccan x uxeǧif nnes,\qt*
\m \qt tewcid as ṣṣulṭa x řexdayem n ifassen nnec.\qt* \x ◘ \xo 2:7 \xt Izhd. 8:7\x*
\m 
\v 8 \qt Aqa marra timesřayin teggid tent\qt*
\m \qt sadu iḍaren nnes.”\qt*
\b
\m Umi igga marra timesřayin sadu Netta, aqa war ijji walu war t iggi sadu Netta. Maca řexxu war nẓar ɛad marra ittwagg sadu Netta, \x ◘ \xo 2:8 \xt Izhd. 8:7; Mt. 28:18; 1 Kur. 15:27; Afa. 1:22. \x*
\v 9 maca nettwařa belli Netta, aqa-t d Yasuɛ, tuɣa ittwagg cwayt sadu lmalakat di ssibbet n uweddeb n řmewt nnes, \add nettwařa i-t\add* s ttaj n uɛuǧi d ccan x uzeǧif nnes, maɣar AREBBI iqqas řmewt i marra iwdan ɛlaḥsab arḍa nnes. \x ◘ \xo 2:9 \xt Řex. 2:33; Fil. 2:7, 8. \x*
\m 
\v 10 Minzi tuɣa ittřiq as i Netta s Wenni u i Wenni ǧant marra tmesřayin - Netta d \add Wenni\add* i dd-ittawyen aṭṭas n iḥenjiren ɣar uɛuǧi - maḥend ad ikemmeř Uzeǧif n Tudart nsen s uweddeb nnes.
\v 11 Minzi d Wenni issqeddsen d yinni ittwaqeddsen, nitni marra d ijjen. S uyenni Netta war iseḍḥi ca ad asen iřaɣa awmaten nnes, \x ◘ \xo 2:11 \xt Řex. 17:26. \x*
\v 12 umi inna:
\b
\m \qt “Ad barrḥeɣ i wawmaten inu s Yisem nnec,\qt*
\m \qt di řwesṭ n tmesmunt ad Cek ṣebbḥeɣ.”\qt* \x ◘ \xo 2:12 \xt Izhd. 22:23. \x*
\b
\m 
\v 13 Uca ɛawed:
\b
\m \qt “Necc ad dayes ttiqqeɣ!”\qt*
\b
\m Uca ɛawed:
\b
\m \qt “Aqa da, Necc d tarwa i d ayi iwca AREBBI.”\qt* \x ◘ \xo 2:13 \xt Ica. 8:17, 18. \x*
\b
\m 
\v 14 Minzi tarwa carcen deg weysum d idammen, uřa d Netta icarc ammu kifkif di man aya, ḥima ad ibeṭṭeř s řmewt nnes wenni ɣar teǧa ṣṣulṭa x řmewt, aqa netta d cciṭan, \x ◘ \xo 2:14 \xt Ica. 25:8; Ḥuc. 13:14; Yḥ. 1:14; 1 Kur. 15:54; Fil. 2:7; 2 Tim. 1:10. \x*
\v 15 uca \add xenni\add* ad ifekk inni isseɛddun qaɛ tudart nsen am isemɣan zi tiggʷudi n řmewt. \x ◘ \xo 2:15 \xt Rum. 8:15. \x*
\v 16 Minzi řmewt war ɣares teǧi ṣṣulṭa x lmalakat, maca \add řmewt\add* ɣares ṣṣulṭa x zzariɛet n Ibrahim.
\v 17 S uyenni tuɣa ittxeṣṣa as ad idweř am wawmaten nnes zi marra iɣezdisen, ḥima ad idweř d Arrays n ikehhanen arḥim d amtiqqi di min iǧan i AREBBI, uca ad yiři břa řɛib zi jjihet n ddnub n řgens. \x ◘ \xo 2:17 \xt Fil. 2:7; Ɛbr. 4:15. \x*
\v 18 Minzi min di tuɣa Netta simant nnes iweddeb u ittwajarreb, aqa izemmar ad iɛawen inni ittwajarrben. \x ◘ \xo 2:18 \xt Ɛbr. 4:15, 16. \x*
\b
\b
\c 3
\s1 Yasuɛ Lmasiḥ yuɛřa x Musa
\m 
\v 1 S uyenni, \add a\add* aytma imqeddasen, inni ittwařaɣan s třaɣit n ujenna, xzarem ɣar Rrasul wanita, ɣar Arrays n ikehhanen n cchadet nneɣ, Yasuɛ Lmasiḥ, \f ◼ \fr 3:1 \fk rrasul\ft - niɣ ‘amazan’.\f*  \x ◘ \xo 3:1 \xt Ɛbr. 4:14; 6:20; 8:1; 9:11. \x*
\v 2 wenni d amtiqqi i Wenni i-t-i-dd-issgeɛɛden, am mammec tuɣa Musa \add d amtiqqi\add* di marra taddart nnes. \x ◘ \xo 3:2 \xt Řxř. 12:7. \x*
\v 3 Minzi aɛuǧi n Wanita d ameqqran s waṭṭas x wenni n Musa, am ccan n ubennay n taddart imɣar x ccan n řebni nnes.
\v 4 Minzi marra taddart tᵉttwabna zeg ijjen, maca Wenni ibennan marra d AREBBI. \x ◘ \xo 3:4 \xt 2 Kur. 5:17, 18; Afa. 2:10. \x*
\v 5 Tᵉttwawekkeř i Musa marra taddart nnes am i yijj n umsexxar, maḥend ad iched x tmesřayin min xef ɣa issiweř netta. \x ◘ \xo 3:5 \xt Aɛwd. 18:15, 18. \x*
\v 6 Maca Lmasiḥ am Mmis \add ittwagg\add* x taddart nnes, u taddart nnes d neccin, mařa neqqim nᵉtteṭṭef di řaman u deg uɛuǧi n usitem nnes ař aneggar. \x ◘ \xo 3:6 \xt Rum. 5:2; 1 Kur. 3:16; 6:19; 2 Kur. 6:16; 1 Bṭ. 2:5. \x*
\b
\m 
\v 7 Maca minzi Arruḥ Iqeddsen inna ...
\b
\m \qt “Aqa ass-a mařa tesřim tmijja nnes,\qt* \x ◘ \xo 3:7 \xt Izhd. 95:7; Ɛbr. 4:7. \x*
\m 
\v 8 \qt war ttᵉsseqsiḥem ca uřawen nwem\qt*
\m \qt maḥend ad t tesɛarem,\qt*
\m \qt am inni iɣewwɣen,\qt*
\m \qt am deg wass n ujarreb di řexřa,\qt* \x ◘ \xo 3:8 \xt Uf. 17:2, 7; Izhd. 95:8\x*
\m 
\v 9 \qt umi d ayi jarrben řejdud nwem, qeǧben \tl ayi\tl*,\qt*
\m \qt \tl am\tl* ẓrin timegga inu\qt*
\m \qt arebɛin n iseggʷusa.\qt*
\b
\m 
\v 10 ... s uya ɛiffeɣ zi jjiř nni, nniɣ:
\b
\m \qt ‘Wa d ijj n řgens i iweddaren deg wuř nnes\qt*
\m \qt nitni war ssinen ca ibriden inu!’,\qt*
\m 
\v 11 \qt ařami jjuǧeɣ deg weɣḍab inu:\qt*
\m \qt ‘War dd-ttidfen ca ɣar arraḥet inu!’”\qt* \x ◘ \xo 3:11 \xt Řxř. 14:21-23; Aɛwd. 1:34; Izhd. 95:7-11. \x*
\b
\m 
\v 12 S uyenni, \add a\add* aytma, ḥḍam ḥima ɛemmarṣ war ittiři ḥed zzaywem ɣares uř d aɛeffan i war ittimnen umi ɣa taggʷejem x AREBBI iddaren,
\v 13 maca qeǧbem ixef nwem kuř ass, ař ass umi qqaren: ‘Ass-a!’, ḥima uřa d ijj zzaywem war itteqsiḥ ca s uɣekkwi n ddenb.
\v 14 Minzi nettwassmun \add aṭṭas\add* ak-d Lmasiḥ mařa neqqim ncebbar zeg umezwar ař aneggar di Řɛahd-a i dayes řaman.
\b
\m 
\v 15 S uya ittwanna \add ammu\add*:
\b
\m \qt “Aqa ass-a,\qt*
\m \qt mařa tesřim řḥess n tmijja nnes,\qt*
\m \qt war tesseqsiḥem ca uřawen nwem\qt*
\m \qt maḥend ad t tesɛarem.”\qt* \x ◘ \xo 3:15 \xt Ɛbr. 3:7. \x*
\b
\m 
\v 16 \add Xenni\add* min iɛnan nitni inni isřin t, \add xenni\add* ɣewwɣen? Ma war \add ǧin\add* nitni marra d inni dd-iffɣen zi Miṣra s ufus n Musa?
\v 17 Zi man wen iɛiff Netta \add xenni\add* arebɛin n iseggʷusa? Ma war iǧi zeg yinni ixḍan, inni umi iwḍan iɣsan nsen di řexřa? \x ◘ \xo 3:17 \xt Řxř. 14:36; Izhd. 106:26; 1 Kur. 10:10; Yah. 5. \x*
\v 18 I umi ijjuǧ Netta, belli war dd-ttidfen ca ɣar arraḥet nnes? Ma war iǧi i yinni war d as ttiqqen? \x ◘ \xo 3:18 \xt Aɛwd. 1:34. \x*
\v 19 Aqa nettwařa belli nitni war zemmaren ad adfen x ssibbet n břa l’iman nsen.
\b
\b
\c 4
\s1 Areyyeḥ i řgens n Arebbi
\m 
\v 1 Ejj aneɣ ad neḥḍa xenni, aqa uřa d ijj zzaywem, \add umi ɛad\add* din ijj n lwaɛd n wadaf di arraḥet nnes, ad iḍhar ittɣima ɣar ḍeffar ɣar wadaf.
\v 2 Minzi ittwabarreḥ Řexbar Aṣebḥan ɛawed i neccin, am \add ittwabarreḥ\add* uřa i nitni, maca awař war d asen infiɛ i yinni d as isřin, minzi tuɣa war dd-ittis ca ak-d l’iman deg inni \add d as\add* isřan.
\v 3 Maca neccin, inni yumnen, ad nadef ɣar arraḥet.
\b
\m Maca am mammec inna:
\b
\m \qt “Am mammec jjuǧeɣ deg weɣḍab inu:\qt*
\m \qt ‘Nitni war dd-ttidfen ca ɣar arraḥet inu!’”\qt*
\b
\m U xzar, řexdayem n AREBBI aqa ttwakemmřent zeg wami tᵉttwagg ddunect, \x ◘ \xo 4:3 \xt Izhd. 95:11. \x*
\v 4 am mammec inna x ssebt:
\b
\m \qt “Yareyyeḥ AREBBI zi marra řexdayem nnes\qt*
\m \qt deg wass wiss sebɛa.”\qt* \x ◘ \xo 4:4 \xt Amz. 2:2; Uf. 20:11; 31:17. \x*
\b
\m 
\v 5 \add Ammu\add* i inna ɛawed deg \add wawař-a\add* wanita:
\b
\m \qt “War dd-ttidfen ca ɣar arraḥet inu!”\qt* \x ◘ \xo 4:5 \xt Izhd. 95:11. \x*
\b
\m 
\v 6 Umi teqqim belli marra zemmaren ad dd-adfen \add ɣar arraḥet-a\add*, \add maca\add* inni umi ittwabarreḥ s Řexbar Aṣebḥan ɣar umezwaru, war udifen ca x ssibbet n řmuɛṣiyyet nsen,
\v 7 aqa Netta igga ɛawed, awarni aṭṭas n řweqt, ijj n wass nneɣni, am mammec ittwari qbeř aqa \bd Dawud\bd* inna:
\b
\m \qt “Ass-a mařa tesřim i tmijja nnes,\qt*
\m \qt war seqsiḥem ca uřawen nwem!”\qt* \x ◘ \xo 4:7 \xt Izhd. 95:7; Ɛbr. 3:7. \x*
\b
\m 
\v 8 Minzi mařa tuɣa \bd Yacuwa, mmis n Nun,\bd* issidef i-ten di arraḥet, war ɣares ittiři ɛad řhard \add s uqemmum n Dawud\add* x ijj n wass nneɣni awarni man aya.
\v 9 S uya ad teqqim aqa din ɛad arraḥet n ssebt i řgens n AREBBI.
\v 10 Minzi wi yudfen ɣar arraḥet nnes, yareyyeḥ ɛawed zi řexdayem nnes am mammec AREBBI zi tinni nnes.
\m 
\v 11 S uya jjem aneɣ ad nemkabar ḥima ad nadef ɣar arraḥet nni, maḥend war nweṭṭi am mammec wḍan inni war iṭṭiɛen.
\v 12 Minzi Awař n AREBBI iddar, ixeddem mani ma, iqḍeɛ ktar zi kuř ssif s tnayen n wudmawen, ittakkwaḍ ař abeṭṭu n řeɛmar d arruḥ, ař \add ttasiɛ\add* jar řemfaṣeř, ař \add aymir\add* jar waḍuf d iɣsan, uca iḥekkem x tnawi d ixarriṣen n wuř. \x ◘ \xo 4:12 \xt Amb. 12:11; Ica. 49:2; Afa. 6:17. \x*
\v 13 Uřa d ict n tmesřact i zzayes dd-ittwaxeřqen war zzayes tᵉttwassnuffar ca, maca marra \add timesřayin\add* aqa atent ttwaɛarryent, ttwarezzment ɣar tiṭṭawin n Wenni umi i-k-dd i ɣa negg řeḥsab. \x ◘ \xo 4:13 \xt Izhd. 33:13. \x*
\b
\s1 Yasuɛ d Arrays nneɣ imɣar n ikehhanen
\m 
\v 14 S uyenni, am ɣarneɣ Arrays n ikehhanen imɣar, Yasuɛ Lmasiḥ, Mmis n AREBBI, wenni issgeɛɛden ɣar ujenna, ejj aneɣ ad ncebbar di cchadet nnes. \x ◘ \xo 4:14 \xt Ɛbr. 3:1; 6:20; 8:1; 9:11. \x*
\v 15 Minzi war ɣarneɣ arrays n ikehhanen i war izemmar ad yaca ak-d tuḍɛeft nneɣ, maca Ijjen wenni ittwajarrben di marra am neccin, maca břa ddenb. \x ◘ \xo 4:15 \xt Ica. 53:9; 2 Kur. 5:21; Fil. 2:7; Ɛbr. 2:18; 1 Bṭ. 2:22; 1 Yḥ. 3:5. \x*
\v 16 S uyenni ejj aneɣ ad dd-nqarreb xenni s ttiqqet ɣar řɛarc n arḍa nnes, ḥima ad neksi arreḥmet uca ad naf arḍa di řweqt n řmeḥnet. \x ◘ \xo 4:16 \xt Rum. 3:25. \x*
\b
\b
\c 5
\m 
\v 1 Minzi kuř arrays n ikehhanen \add ittwakkes-dd\add* zeg iwdan, ittwassgeɛɛed di ṭṭweɛ n iwdan x min iǧan n AREBBI, maḥend ad iqeddem tiwhibin d tɣarṣin x ddnub.
\v 2 Izemmar ad immars ixef nnes, ad iḥinn x iqubbaniyyen d imweddaren, minzi uřa d netta simant nnes yarḍ tuḍɛeft.
\v 3 Maɣar s man aya d icten ittxeṣṣa as ad issgeɛɛed tiɣarṣin x ddnub n řgens uca ɛawed x \add ddnub n\add* yixef nnes. \x ◘ \xo 5:3 \xt Lawi 9:7; 16:6; Ɛbr. 7:26. \x*
\v 4 Uřa d ijjen ad iksi i yixef nnes ccan\add -a\add*, mɣir wenni ittwařaɣan zi AREBBI am mammec \add ittwařaɣa\add* Harun. \x ◘ \xo 5:4 \xt Uf. 28:1; 1 Im. 23:13; 2 Im. 26:16. \x*
\v 5 Ammu ɛawed Lmasiḥ war issɛuǧi ca Ixef nnes umi idweř d Arrays n ikehhanen, maca \add issɛuǧa\add* wenni dd ɣares issiwřen:
\b
\m \qt “Cek d Mmi,\qt*
\m \qt Necc jjiɣ-dd Cek ass-a!”\qt* \x ◘ \xo 5:5 \xt Izhd. 2:7; Řex. 13:33; Ɛbr. 1:5. \x*
\b
\m 
\v 6 Am mammec inna ɛawed di mani nneɣni:
\b
\m \qt “Cek d Akehhan i řebda,\qt*
\m \qt deg warwas n Malkiṣadiq.”\qt* \x ◘ \xo 5:6 \xt Izhd. 110:4; Ɛbr. 7:17. \x*
\b
\m 
\v 7 Řami tuɣa yarreḍ \add arrimet n\add* weysum \add nnes\add*, iqeddem tiẓaǧitin d tutra s iɣuyyan aṭṭas u s imeṭṭawen i Wenni tuɣa izemmaren ad t-i-dd-issnekkar zi řmewt i Tudart, uca Netta isřa as. \x ◘ \xo 5:7 \xt Mt. 26:39; 27:46, 50; Yḥ. 17:1. \x*
\v 8 Netta, waxxa tuɣa-t d Mmis, aqa iřmed ṭṭaɛet s tiggʷudi u zeg uweddeb i iksi. \x ◘ \xo 5:8 \xt Fil. 2:6. \x*
\v 9 Ammu i idweř Netta ikemmeř, idweř d ssibbet n Tudart ittduman i marra inni d as i ɣa iṭṭaɛen,
\v 10 uca igga i-t AREBBI d Arrays n ikehhanen deg warwas n Malkiṣadiq. \x ◘ \xo 5:10 \xt Izhd. 110:4\x*
\b
\m 
\v 11 Aqa ɣarneɣ aṭṭas min ɣa nini x Malkiṣadiq wanita, maca iwɛar ad t nfessar, minzi tdewřem tewɛarem ad tesřem.
\v 12 Maɣar tuɣa ittxeṣṣa ad tiřim d imesɣaren zi jjihet n řmijař n řweqt i tḍeffarem tɣuri-ya. Maca řexxu ittxeṣṣa awem ɛad ad třemdem lḥuruf imezwura n beddu n wawařen n AREBBI, kenniw teḥdajem \add ɛad\add* aɣi deg wemcan n macca ijehden. \x ◘ \xo 5:12 \xt 1 Kur. 3:1, 2, 3. \x*
\v 13 Minzi kuř ijjen wenni icarcen deg uɣi, war iqedd x wawař n tsegda, minzi netta d aseymi \add ɛad\add*.
\v 14 Maca macca ijehden iffeɣ-dd i yinni imɣaren, inni aqa nnumen ad darrben tacit nsen ḥima ad farzen řxar x řɣar.
\b
\b
\c 6
\s1 Dsas imten d řwaɛd war ibeddřen
\m 
\v 1 S uyenni ad nejj tamezwarut n wawař n Lmasiḥ, ad nuyur zzat ɣar ukemmeř. Mayemmi xenni texsem ad tessarsem ɛawed dsas nneɣni i ttubet zi řexdayem immuten u i l’iman di AREBBI,
\v 2 u i tɣuri n useɣḍeṣ d usarsi n ifassen uřa i tnukra zi taddart n imettinen d lḥisab i řebda?
\v 3 Mařa \add ad aneɣ\add* ismeḥ SIDI man aya, ad t negg. \x ◘ \xo 6:3 \xt Řex. 18:21; 1 Kur. 4:19; Yaɛ. 4:15. \x*
\m 
\v 4 Maca war d asen izemmar i yinni dd-ihwan i useɣḍeṣ ict n twařa uca qqasen tawhibt n ujenna uca ṭṭfen Arruḥ Iqeddsen, \x ◘ \xo 6:4 \xt Mt. 12:31; Ɛbr. 10:26; 1 Yḥ. 5:16. \x*
\v 5 uca qqasen \add ɛawed\add* awař icnan n AREBBI d jjehd n zzman i dd ɣa yasen,
\v 6 maḥend ad xḍan ɛawed, uca ad ttwassfaqen i ttubet zi jdid, uca ad ṣellben u ad sseḥqaren Mmis n AREBBI ict n twařa nneɣni.
\v 7 Minzi tammurt, tenni isessen anẓar wenni xas iccaten aṭṭas n twařawin, tessɣemmi aɣemmuy icna i yinni umi tᵉttwafeǧeḥ, aqa teksi lbaraka zi AREBBI.
\v 8 Maca mařa tesseɣmi-dd \add temmurt\add* isennanen d tzeggʷart, aqa temmenḍar u tudes i nneɛřet uca aneggar \add n temmurt\add* ad yiři d acmaḍ.
\b
\m 
\v 9 Maca waxxa nessawař ammu, zi jjihet nwem \add a\add* aytma, aqa nettwasseqneɛ aqa din timesřayin icnan ittraḥen nican ak-d Tudart.
\v 10 Minzi AREBBI war iǧi d wenni war iseggden maḥend ad ittu řxedmet nwem d tayri nwem, tini tuɣa tessecnem deg Yisem nnes, i zzayes tuɣa kenniw tsexxarem i imqeddasen uca tᵉttsexxarem \add asen ɛad\add*. \x ◘ \xo 6:10 \xt Awřn. 14:31; Mt. 10:42; 25:40; Mk. 9:41; Yḥ. 13:20. \x*
\v 11 Maca dayneɣ meẓri ḥima kuř ijjen zzaywem ad isscen amḥaḍ d ijj i ukemmeř n usitem ař aneggar,
\v 12 aqa war tᵉddekkwařam d imeɛgaz, maca ad tiřim d imeḍfaren n yinni s l’iman d ttasiɛ n řxaḍar dewřen d iwriten n lwaɛd.
\m 
\v 13 Minzi řami iwaɛd AREBBI Ibrahim, ijjuǧ s Yixef nnes, minzi war din iǧi wenneɣni imɣar xas maḥend ad as ijjaǧ,
\v 14 inna:
\b
\m \qt “S tidett, ad ac barkeɣ\qt*
\m \qt uca ad ac arniɣ aṭṭas s waṭṭas.”\qt* \x ◘ \xo 6:14 \xt Amz. 12:3; 17:4; 22:16-17; Izhd. 105:9; Lk. 1:73. \x*
\b
\m 
\v 15 Uca ammu, am ittṣebbar \add Ibrahim\add*, aqa iksi lwaɛd.
\v 16 Maɣar iwdan jjuǧen ɣar min xasen iǧan d ameqqran u marra amcubbec jar asen ad iqḍa nican s ict n tjaǧit. \x ◘ \xo 6:16 \xt Uf. 22:11. \x*
\v 17 S uyenni tuɣa ixs AREBBI ad isscen s ufeyyeḍ i iwriten belli lwaɛd nnes war ittbeddiř ca, uca iḍmen i-t s ict n tjaǧit.
\v 18 ḥima s tnayen n tmesřayin war ttbeddiřent ca - am war izemmar xenni ad issxarreq AREBBI - ad dayneɣ ittwagg uř s waṭṭas, aqa dayneɣ di neccin inni ɣares arewřen, ḥima ad neṭṭef deg usitem i d aneɣ ittwawaɛden,
\v 19 d wenni ɣarneɣ am yijj n uřeyzim icebbaren s řmetnet di řeɛmar nneɣ, \add ijj n uřeyzim\add* i dd-ittadfen ɣar daxeř n uřeḥḥaf n wadaf.
\v 20 mani yudef Yasuɛ wenni d aneɣ izwaren x tizi nneɣ, aqa idweř d Akehhan i řebda deg warwas n Malkiṣadiq. \x ◘ \xo 6:20 \xt Ɛbr. 3:1; 4:14; 8:1; 9:11. \x*
\b
\b
\c 7
\s1 Malkiṣadiq d Ajeǧid d Akehhan
\m 
\v 1 Malkiṣadiq wanita tuɣa d ajeǧid n Salim, akehhan n AREBBI wenni d Amɛuǧi x kuřci, u netta iffeɣ-dd ḥima ad iřqa Ibrahim řami dd-idweř zi tareẓẓit n ijeǧiden, u netta ibarek \add Ibrahim\add*. \x ◘ \xo 7:1 \xt Amz. 14:17-20. \x*
\v 2 Ibrahim iksi ijj n řeɛcur zi marra min ɣares i netta. Isem nnes ixs ad yini: ‘ajeǧid n tsegda’, u ɛawed: ‘ajeǧid n Salim’, min ixs ad yini ‘ajeǧid n řehna’. \x ◘ \xo 7:2 \xt Izhd. 85:11\x*
\v 3 Nḥřa ma ttwazemmen babas d yemmas deg \add idlisen n\add* jjadira, u nḥřa beddu n wussan nnes niɣ aneggar n tudart nnes, \add maca\add* deg warwas n Mmis n AREBBI, aqa teqqim tukehhant nnes i řebda.
\m 
\v 4 Xzarem řexxu, mecḥař tuɣa imɣar wanita x arrays n řejdud \add nneɣ\add* Ibrahim i t iwcin řeɛcur zi min iṣebḥen qaɛ!
\v 5 Maɣar inni iksin tukehhant zeg ayt n Lawi, aqa ɣarsen tawṣeyyet ɛlaḥsab Ccariɛa ḥima ad ksin řeɛcur zi řgens, iɛna zeg aytmatsen, umi nitni ffɣen-dd ɛawed zi dwaxeř n Ibrahim. \x ◘ \xo 7:5 \xt Řxř. 18:21; Aɛwd. 18:1; Yac. 14:4; 2 Im. 31:5. \x*
\v 6 Maca \add Malkiṣadiq\add* wanita, wenni war izemmen deg idlisen nsen n jjadira, iksi zi Ibrahim řeɛcur uca ibarek i wenni iṭṭfen lwaɛd. \x ◘ \xo 7:6 \xt Amz. 14:20. \x*
\v 7 Aqa břa awař, wenni iǧan qell, aqa ad ittwabarek zeg wenni iǧan ḥsen zzayes.
\v 8 Aqa danita iwdan ifennan kessin řeɛcur, maca dinni ten \add iṭṭef\add* netta, netta d wenni x cehhdent Tira \add Iqeddsen\add*, aqa iddar.
\v 9 Ammu nzemmar ad nini belli Lawi, wenni iksin řeɛcur, aqa iɛeccar \add ɛawed\add* s ufus n Ibrahim,
\v 10 minzi tuɣa-t ɛad di dwaxeř n babas ařami imsagar wanita ak-d Malkiṣadiq.
\b
\s1 Arrays n ikehhanen yuɛřan x Harun
\m 
\v 11 Mařa řekmařet tuɣa-tt s tukehhant n Lawi, minzi tanita tᵉttwaḍmen i řgens s Ccariɛa, mayemmi ɛad ittxeṣṣa ad dd-ikkar ukehhan nneɣni deg warwas n Malkiṣadiq? \add Mařa ammu i teǧa\add*, zeɛma inna Netta belli ad yiři di ṣṣifet n Harun! \x ◘ \xo 7:11 \xt Izhd. 110:4; Gal. 2:21. \x*
\v 12 Maca am mammec tuɣa din ijj n ubeddeř n tukehhant, ammu tuɣa din ɛawed ijj n ubeddeř n Ccariɛa.
\v 13 Minzi Wenni mixef ittwanna aya, aqa ittwaxřeq-dd zi teqbič nneɣnit, i zi uřa d ijj war isexxar ɛemmarṣ ɣar uɛalṭar.
\v 14 Aqa bayen belli Siditneɣ iffeɣ-dd zi Yahuda, zi taqbič i war x issiweř Musa uřa s yijj n wawař x tukehhant. \x ◘ \xo 7:14 \xt Ica. 11:1; Mt. 1:3. \x*
\v 15 S man aya ɛawed tban qaɛ mliḥ, aqa Netta inna belli ad dd-ikkar ukehhan nneɣni deg warwas n Malkiṣadiq,
\v 16 wenni war ittwaggen ɛlaḥsab Ccariɛa n tweṣṣa i itthiman arrimet, maca ɛlaḥsab jjehd n Tudart war ifennan.
\v 17 Minzi Netta iched xas:
\b
\m \qt “Cek d Akehhan i řebda\qt*
\m \qt deg warwas n Malkiṣadiq!”\qt* \x ◘ \xo 7:17 \xt Izhd. 110:4; Ɛbr. 5:6. \x*
\b
\m 
\v 18 Minzi tawṣeyyet tenni tuɣa qbeř tᵉttwaxřef zi ssibbet n tuḍɛeft nnes d břa nnfaɛ nnes.
\v 19 Minzi Ccariɛa war tᵉttiwi qaɛ akemmeř, maca deg wemcan nnes yusa-dd usitem d ameqqran i zi nzemmar ad nades AREBBI, \x ◘ \xo 7:19 \xt Yḥ. 1:17; Řex. 13:39; Rum. 3:21, 28; 8:3; Gal. 2:16. \x*
\v 20 u Netta iḍmen man aya s ict n tjaǧit.
\v 21 Maɣar nitni dewřen d ikehhanen břa tajaǧit, maca Wanita s ict n tjaǧit umi Netta d as inna s \add uqemmum n\add* Dawud:
\b
\m \qt “Aqa SIDI ijjuǧ,\qt*
\m \qt war issxarriq ɛemmarṣ:\qt*
\m \qt ‘Cek d Akehhan i řebda\qt*
\m \qt di ṣṣifet n Malkiṣadiq.’”\qt* \x ◘ \xo 7:21 \xt Izhd. 110:4. \x*
\b
\m 
\v 22 Di marra man aya iǧa Řɛahd-a, i zi idweř Yasuɛ d aḍman, qaɛ ḥsen.
\m 
\v 23 Tuɣa din \add di řweqt nni ɛawed\add* aṭṭas n ikehhanen, minzi nitni mmuten, ttwamenɛen ad qqimen.
\v 24 Maca x Wanita war xas tɛeddu Tukehhant nnes, minzi Netta ad iqqim ibedd i řebda.
\v 25 S uyenni izemmar ad iwc Tudart ittduman i yinni zzayes i dd ɣa qarrben ɣar AREBBI, minzi Netta iddar i řebda uca iwehheb tiẓaǧitin di ṭṭweɛ nneɣ. \x ◘ \xo 7:25 \xt 1 Tim. 2:5; 1 Yḥ. 2:1. \x*
\v 26 Minzi tuɣa ittřiq aneɣ ijj n Ukehhan am Wanita: amezdag, břa řɣecc d taxmuji, ittwafarzen zeg imednab, yuɛřan x ijenwan,
\v 27 wenni war ɣar iǧi řxeṣṣ ass x wass am irruyas n ikehhanen, ḥima ad iqeddem amezwar tiɣarṣin x ddnub n yixef nnes, uca xenni ɛawed x ddnub n řgens, minzi aya igga i-t ict n twařa i řebda qaɛ, řami iwca Ixef nnes d taɣarṣt. \x ◘ \xo 7:27 \xt Lawi 9:7; 16:6; Ɛbr. 5:3. \x*
\v 28 Aqa Ccariɛa tessgeɛɛed iwdan iḍeɛfen d ikehhanen, maca awař n tjaǧit, wenni awarni Ccariɛa, issgeɛɛed Mmis wenni ittwakemmřen i řebda.
\b
\b
\c 8
\s1 Arrays n ikehhanen n ijj n Řɛahd yuɛřan
\m 
\v 1 Lmufid zi marra man aya, aqa ɣarneɣ Arrays n ikehhanen, wenni iqqimen ɣar yefus n řɛarc n Lɛaḍim deg ijenwan. \x ◘ \xo 8:1 \xt Afa. 1:20; Kul. 3:1; Ɛbr. 3:1; 4:14; 6:20; 9:11; 12:2. \x*
\v 2 Netta d Amseyyar n Zzawect Iqeddsen u n Tzeddiɣt Iqeddsen d tidett nni ibna AREBBI, war iǧi d bnadem.
\m 
\v 3 Minzi kuř arrays n ikehhanen ittwassgeɛɛed ḥima ad iwc tiwhibin d tɣarṣin. S uyenni tuɣa ittxeṣṣa as i Wanita ɛawed ad ɣares yiři ca ḥima ad t iwc. \x ◘ \xo 8:3 \xt Afa. 5:2. \x*
\v 4 Meɛlik iǧa di temmurt, Netta war ittiři d akehhan, minzi aqa din ikehhanen \add ɛad\add* inni ittqeddamen tiwhibin ɛlaḥsab Ccariɛa.
\v 5 Nitni sexxaren i umedya d tiři n min iǧan deg ujenna, am mammec ittwanna i Musa umi tuɣa iřha ak-d Uqiḍun Iqeddsen: “Ḥḍat, ad tegged marra am lmital wenni d ac ssecneɣ x wedrar.” \x ◘ \xo 8:5 \xt Uf. 25:40; Řex. 7:44; Kul. 2:17; Ɛbr. 10:1. \x*
\m 
\v 6 \add Maca\add* řexxu Yasuɛ Lmasiḥ iksi tasexxart tecna xas, minzi Řɛahd i zi idweř Netta d Lwasit, aqa ḥsen qaɛ, uca immewc s lwuɛud icnan x yinni \add i dd-ittasen ak-d Řɛahd aqdim\add*. \x ◘ \xo 8:6 \xt 2 Kur. 3:6. \x*
\v 7 Minzi mařa tuɣa \add Řɛahd\add* amezwaru břa řɛib, war ittiři ɛad wemcan i wenni d wiss tnayen.
\v 8 Maɣar Netta yufa daysen řɛib, inna:
\b
\m \qt “Xzar, ad dd-asen wussan, inna SIDI,\qt*
\m \qt xmi ɣa ggeɣ ijj n Řɛahd n Jdid\qt*
\m \qt di řekmaret,\qt*
\m \qt i řaǧ n taddart n Israil\qt*
\m \qt u i řaǧ n taddart n Yahuda,\qt* \x ◘ \xo 8:8 \xt Irm. 31:31-34; Mt. 26:28, Mk. 14:24, Lk. 22:20, 1 Kur. 11:25, 2 Kur. 3:6, Ɛbr. 8:6, 8, 13; 9:15; 12:24\x*
\m 
\v 9 \qt war iǧi am Řɛahd nni wciɣ i řejdud nsen,\qt*
\m \qt deg wass min di ten ṭṭfeɣ zeg ufus,\qt*
\m \qt gewwdeɣ ten zi temmurt n Miṣra.\qt*
\m \qt Minzi nitni war qqimen ca di Řɛahd inu,\qt*
\m \qt nḍareɣ ten, iqqar SIDI.\qt*
\m 
\v 10 \qt Maca d wa d Řɛahd i ɣa wceɣ\qt*
\m \qt i řaǧ n taddart n Israil:\qt*
\m \qt ‘Awarni wussan nni, inna SIDI,\qt*
\m \qt ad ggeɣ izerfan inu di řeɛqeř nsen,\qt*
\m \qt uca ad ten ariɣ deg wuřawen nsen,\qt*
\m \qt uca Necc ad asen iřiɣ d AREBBI,\qt*
\m \qt nitni ad ayi iřin d řgens.\qt*
\m 
\v 11 \qt Uřa d ijjen ad isseřmed\qt*
\m \qt mmis n temmurt niɣ umas,\qt*
\m \qt ad yini: Ssen SIDI!,\qt*
\m \qt minzi marra ad ayi ssnen,\qt*
\m \qt am umeẓyan nsen am umeqqran nsen.\qt* \x ◘ \xo 8:11 \xt Yḥ. 6:45, 65; 1 Yḥ. 2:27. \x*
\m 
\v 12 \qt Minzi Necc ad ten sseṣfiɣ\qt*
\m \qt zi řmuɛṣiyyet nsen,\qt*
\m \qt uca ddnub nsen war daysen ttfekkareɣ ɛad.’”\qt* \x ◘ \xo 8:12 \xt Irm. 31:31-34. \x*
\b
\m 
\v 13 Řami inna: ‘Jdid!’, aqa igga \add Řɛahd\add* amezwaru d aqdim, uca min yarcan u idduysar, aqa ad ifna. \x ◘ \xo 8:13 \xt Irm. 31:31; Mt. 26:28, Mk. 14:24, Lk. 22:20, 1 Kur. 11:25, 2 Kur. 3:6, Ɛbr. 8:6, 8, 13; 9:15; 12:24\x*
\b
\b
\c 9
\s1 Tasexxart n ikehhanen di Tzeddiɣt Iqeddsen
\m 
\v 1 Maca ɣar umezwar tuɣa din řefruḍ i tsexxart u \add tuɣa din\add* ict n Zzawect Iqeddsen di ddunect-a.
\v 2 Minzi Tazeddiɣt tamezwarut i tᵉttwagg, tuɣa dayes řqendiř d tzewḍa d weɣrum n wescan uca qqaren as: ‘Aqeddas’. \x ◘ \xo 9:2 \xt Uf. 26:1; 36:1; Lawi 24:5. \x*
\v 3 Maca Tazeddiɣt n daxeř, awarni i uřeḥḥaf wiss tnayen, qqaren as ‘Aqdas x Uqeddas’. \f ◼ \fr 9:3 \fk ařeḥḥaf\ft - niɣ: ‘arwaq’.\f*
\v 4 Aqa dayes řqecɛet n wureɣ i řebxur uřa d Ttabut n Řɛahd iɣeǧfen s wureɣ ɣar marra iɣezdisen. Tuɣa dayes ijj n uzenbiř n wureɣ dayes ‘manna’, u \add dayes\add* uřa d taɣɣarct n Harun tenni ittwanuwwcen d teřwiḥin \add n weẓru\add* n Řɛahd. \x ◘ \xo 9:4 \xt Uf. 25:10; 34:29; Řxř. 17:25; 1 Ij. 8:9; 2 Im. 5:10. \x*
\v 5 Sennej i man aya aqa din ‘ixiruben’ n řɛezz, inni iddřin taqebbart n weṣřaḥ \add i iǧan x Ttabut\add* s tiři n wafriwen nsen. Maca war ɣarneɣ bu řweqt \add řexxu\add* ḥima ad nessiweř x kuř icten zi tmesřayin-a i ittwasswejden ammu. \x ◘ \xo 9:5 \xt Uf. 25:22. \x*
\v 6 Maca ikehhanen tuɣa ttadfen řebda ɣar Tzeddiɣt nni ɣar barra, \add tenni d tamezwarut\add*, ḥima ad \add dayes\add* kemmřen tasexxart nsen. \x ◘ \xo 9:6 \xt Řxř. 28:3. \x*
\v 7 Maca arrays n ikehhanen tuɣa ittadef ict n twařa deg useggʷas ɣar Tzeddiɣt n daxeř ak-d idammen i iqeddem x yixef nnes uřa x uweddar n řgens. \x ◘ \xo 9:7 \xt Uf. 30:10; Lawi 16:2, 34; Ɛbr. 9:25. \x*
\v 8 S tebridt-a isscen Arruḥ Iqeddsen mliḥ belli abrid iqeddsen ɛad war dd-ittwammeḍhar, umi ɛad Tazeddiɣt tamezwarut tbedd. \x ◘ \xo 9:8 \xt Yḥ. 14:6. \x*
\v 9 Tanita tuɣa d amedya i řweqt nni di tuɣa ttqeddamen ṣṣdaqi d tɣarṣin nni war zemmarent ad awyent řekmaret ɣar tnefsect n wenni i-tent iqeddmen.
\v 10 Aqa atent tuɣa tthimmant mɣir macca d tsessi d ibriden ifarzen n useɣḍas \add deg waman\add*, aqa atent d řefruḍ i itthimman ddat waha, ttwamurent ař řweqt n weɛdař n tsegda. \x ◘ \xo 9:10 \xt Lawi 11:2; Řxř. 19:7-22. \x*
\b
\s1 Akehhan deg ijenwan
\m 
\v 11 Maca Lmasiḥ i dd-yusin, aqa idweř d Arrays n ikehhanen x řxar i igga. Netta yudef ɣar Tzeddiɣt Tameqqrant ikemmřen, tenni war ittwaggen ca s ifassen, war teǧi zi min dd-ittwaxeřqen. \x ◘ \xo 9:11 \xt Ɛbr. 3:1; 4:14; 6:20; 8:1. \x*
\v 12 War yudif ca ak-d idammen n iɣayḍen d iɛejmiyyen n ijj n useggʷas, maca aqa yudef ict n twařa ak-d Idammen n Yixef nnes ɣar Zzawect Iqeddsen u \add ammu i\add* dd-yiwi asenjem ittduman. \x ◘ \xo 9:12 \xt Řex. 20:28; Afa. 1:7; Kul. 1:14; Ɛbr. 10:10; 1 Bṭ. 1:19; Asa. 1:5; 5:9\x*
\m 
\v 13 Minzi mařa idammen n iɣayḍen d ifunasen imeẓyanen d iɣɣeḍ n uɛejmi \add azeggʷaɣ\add* i ittwaruccen x yinni ittwaxemjen, aqa qeddsen u ssizdigen ten zi jjihet n weysum nsen \add n arrimet\add*, \x ◘ \xo 9:13 \xt Lawi 16:14-16; Řxř. 19:4; Ɛbr. 10:4. \x*
\v 14 mecḥař ɛad ad ssizedgen Idammen n Lmasiḥ tanefsect nneɣ zi řexdayem immuten, ḥima ad nexdem AREBBI iddaren, aqa Lmasiḥ wenni iwcin Ixef nnes i AREBBI s Arruḥ n řebda d taɣarṣt war dayes bu řɛib! \x ◘ \xo 9:14 \xt Lk. 1:74; Rum. 6:13; Gal. 1:4; 2:20; Afa. 5:2; Tit. 2:14; 1 Bṭ. 4:2; 1 Yḥ. 1:7; Asa. 1:5. \x*
\v 15 S uyenni aqa Netta d Lwasit n Řɛahd n Jdid, maɣar s řmewt nnes idweř Netta d asenjem i yinni ixeṭṭan ḍidd Řɛahd amezwar, ḥima nitni inni ittwařaɣan i řwart n řebda, ad ṭṭfen lwaɛd. \x ◘ \xo 9:15 \xt Irm. 31:31; Mt. 26:28, Mk. 14:24, Lk. 22:20, 1 Kur. 11:25, 2 Kur. 3:6, Ɛbr. 8:6, 8, 13; 9:15; 12:24; Rum. 5:6; 1 Bṭ. 3:18. \x*
\m 
\v 16 Minzi mani iǧa řɛahd, ittxeṣṣa ad tᵉttwassargeb řmewt n wenni iggin řɛahd.
\v 17 Minzi řɛahd ad idweř iṣřeḥ waha xmi ɣa immet ḥed, war ittiři ca nican min ɣa yekk iddar wenni iggin \add řɛahd\add*. \x ◘ \xo 9:17 \xt Gal. 3:15. \x*
\v 18 S uya uřa d \add Řɛahd\add* amezwar war ittwaḍmen ca břa idammen.
\v 19 Minzi awarni řami kuř tawṣiyyet nni iǧan di Ccariɛa aqa iweṣṣa i řgens s ufus n Musa, iksi netta idammen n ufunas ameẓyan ak-d waman uřa d taḍuft tazeggwaɣt d tɛelǧet, uca irucc i-ten x idlisen ittwannḍen u x marra řgens, \x ◘ \xo 9:19 \xt Uf. 24:6-8\x*
\v 20 inna asen:
\b
\m \qt “Ina d idammen n Řɛahd,\qt*
\m \qt i d awem yumur AREBBI.”\qt* \x ◘ \xo 9:20 \xt Uf. 24:8; Mt. 26:28. \x*
\b
\m 
\v 21 Tuɣa irucc ɛawed Tazeddiɣt Iqeddsen d marra řeqcuɛ n tsexxart s idammen.
\v 22 Maɣar marra timesřayin nni iǧan di Ccariɛa ttwassizedgent s idammen uca břa asizzeř n idammen war din iǧi ca weɣfar.
\m 
\v 23 Tuɣa qaɛ ittxeṣṣa ad ttwassizdegent tmesřayin-a s tɣarṣa i iǧan d řemtuř n timesřayin i iǧan deg ijenwan, maca timesřayin nni iǧan n ujenna simant nsen s tɣarṣin icnan zi tina. \f ◼ \fr 9:23 \fk tiɣarṣin\ft - niɣ ‘ddbayeḥ’.\f*
\v 24 Minzi Lmasiḥ war yudif ca ɣar Zzawect Iqeddsen i ittwaggen s ifassen, d wenni netta d lmital n min iǧan d tidett, maca ɣar ujenna simant nnes, ḥima ad dd-iḍhar di ṭṭweɛ nneɣ qibač i AREBBI.
\v 25 War iǧi ḥima ad iqeddem Ixef nnes aṭṭas n twařawin am mammec tuɣa ittadef arrays n ikehhanen kuř aseggʷas ɣar Zzawect Iqeddsen s idammen war iǧin nnes \x ◘ \xo 9:25 \xt Uf. 30:10; Lawi 16:2,34; Ɛbr. 9:7. \x*
\v 26 - minzi mařa ammu i iǧa, iři ittxeṣṣa ad iweddeb \add Yeccu\add* aṭṭas n twařawin zi beddu n ddunect - maca řexxu, ɣar qeṭṭu n ddunect, iwca Netta Ixef nnes ict n twařa ḥima ad ibeṭṭeř ddnub s tɣarṣt nnes.
\m 
\v 27 Am mammec d ittwassars i iwdan ad mmten ict n twařa, uca xenni awarni i řmewt nsen \add ad dd-yas\add* řḥukm,
\v 28 ammu ɛawed immewc Lmasiḥ ict n twařa d taɣarṣt, iwca deg Yixef nnes taɣarṣt n ddenb i waṭṭas, maca ɣar twasit nnes i twařa wiss tnayen ad ittwaẓar břa ddenb i Tudart n yinni t ittrajan. \x ◘ \xo 9:28 \xt Rum. 5:6, 8; 1 Bṭ. 3:18. \x*
\b
\b
\c 10
\s1 Aṣřaḥ i řebda
\m 
\v 1 Minzi tuɣa Ccariɛa d tiři n řxar i dd ɣa yasen \add waha\add*, war ɣares ṭṭbiɛet n tmesřayin simant nsent. S uyenni war zemmarent tɣarṣa nni, waxxa iwyen tent-i-dd kuř aseggʷas, ad awyent řekmaret x yinni tent dd-ittqarraben. \x ◘ \xo 10:1 \xt Kul. 2:17; Ɛbr. 8:5. \x*
\v 2 Minzi mařa iban-dd aqa tᵉttawyent ɣar řekmaret, ad tiři ttwassbedden nitni zeg uwehheb n tɣarṣa nsen aṭṭas zeg wami, minzi war tᵉttwakkʷur ɛad tnefsect nsen s ddenb awarni řami ttwassizedgen ict n twařa.
\v 3 Maca s man aya ttwassfekkaren asen-dd ddnub nsen kuř aseggʷas,
\v 4 minzi idammen n ifunasen imeẓyanen d iɣayḍen war zemmaren ad ssizdegen zi ddnub. \x ◘ \xo 10:4 \xt Lawi 16:14; Řxř. 19:4; Ɛbr. 9:13. \x*
\v 5 S uyenni řami dd-yudef ɣar ddunect, inna:
\b
\m \qt “Tiɣarṣa niɣ tiwhibin war tent texsed,\qt*
\m \qt maca aqa tessyarḍed ayi ict n arrimet.\qt* \x ◘ \xo 10:5 \xt Izhd. 40:7; Ica. 1:11; Irm. 6:20; Ɛam. 5:21. \x*
\m 
\v 6 \qt Tiɣarṣin n wecmaḍ\qt*
\m \qt ak-d tiɣarṣa n řehna i ddnub\qt*
\m \qt war tent tᵉttared.”\qt*
\b
\m 
\v 7 Řexdenni nniɣ:
\b
\m \qt “Xzar, ad dd-aseɣ!\qt*
\m \qt - minzi yura xafi deg Wedlis ittwanḍen -\qt*
\m \qt ḥima ad ggeɣ min texsed Cek, \tl a\tl* AREBBI!”\qt* \x ◘ \xo 10:7 \xt Izhd. 40:8, 9\x*
\b
\m 
\v 8 Tuɣa inna qbeř: “Tiɣarṣin d tewhibin d tɣarṣin s tmessi d tɣarṣin i ddnub war tent texsed!”, waxxa aqa atent ttwaqeddment ɛlaḥsab Ccariɛa.
\v 9 Awarni man aya inna: “Xzar, usiɣ-dd ḥima ad ggeɣ min texsed Cek, \add a\add* AREBBI.” S uya ikkes amezwar, ḥima ad issgeɛɛed wiss tnayen.
\v 10 Maɣar s man aya, s řxaḍar nnes, aqa nettwaqeddes \add deg\add* ict n twařa s tɣarṣt n Arrimet n Yasuɛ Lmasiḥ. \x ◘ \xo 10:10 \xt Ɛbr. 9:12. \x*
\m 
\v 11 Maɣar kuř akehhan i tuɣa ittsexxar kuř ass, aqa iwehheb aṭṭas n twařawin simant n tɣarṣa, tinni war izemmaren ad ssizedgent zi ddnub.
\v 12 Maca Wanita iqeddem ict n tɣarṣt x ddnub, uca xenni iqqim x yefus n AREBBI i řebda. \x ◘ \xo 10:12 \xt Izhd. 110:1; Řex. 2:34; 1 Kur. 15:25; Afa. 1:20; Kul. 3:1; Ɛbr. 1:13. \x*
\v 13 Zi řexdenni ittraja ař d as ttwaggen řɛedyan nnes d tanebdat sadu iḍaren nnes.
\v 14 Minzi s ict n tɣarṣt aqa yiwi inni zzayes ittwaqeddsen ɣar řekmaret i řebda.
\m 
\v 15 Maca Arruḥ Iqeddsen ɛawed iched i neccin, iqqar:
\b
\m 
\v 16 \qt “D wa d Řɛahd i d asen ɣa wceɣ\qt*
\m \qt awarni i wussan nni, iqqar SIDI:\qt*
\m \qt ‘Ad ggeɣ Ccariɛa inu di řeɛqeř nsen,\qt*
\m \qt ad tt ariɣ ɛawed deg wuřawen nsen,\qt* \x ◘ \xo 10:16 \xt Irm. 31:31-34; Rum. 11:27; Ɛbr. 8:8. \x*
\m 
\v 17 \qt uca ddnub nsen d ixeṭṭan nsen,\qt*
\m \qt ɛemmarṣ ad daysen fekkareɣ \tl ɛad\tl*.’”\qt* \x ◘ \xo 10:17 \xt Irm. 31:33, 34. \x*
\b
\m 
\v 18 Mani ittiři \add xenni\add* weɣfar i ddnub, war din iqqim ɛad tɣarṣt x ddnub.
\v 19 S uyenni, \add a\add* aytma, aqa ɣarneɣ ttiqqet maḥend ad nadef ɣar Zzawect Iqeddsen s Idammen n Yasuɛ, \x ◘ \xo 10:19 \xt Yḥ. 10:9; 14:6; Rum. 5:2; Afa. 2:13; 3:12. \x*
\v 20 x Webrid n jdid iddaren i d aneɣ issewjed am \add Webrid\add* n jdid i dd-ittadfen ɣar daxeř n uřeḥḥaf n tewwart, wenni d weysum nnes,
\v 21 uca aqa ɣarneɣ \add ɛawed\add* Arrays n ikehhanen x Taddart n AREBBI. \x ◘ \xo 10:21 \xt Afa. 2:19; 1 Tim. 3:1; 1 Bṭ. 4:17\x*
\v 22 Ejj aneɣ xenni ad dd-nqarreb s wuř n tidett, di ttiqqet n l’iman, am ttwaruccen wuřawen nneɣ u ttwassizdegen \add ɛawed\add* zi tnefsect taɛeffant, u am tᵉttwassird \add ɛawed\add* arrimet nneɣ s waman iṣfan. \x ◘ \xo 10:22 \xt Ḥiz. 36:25. \x*
\v 23 Ejj aneɣ ad ncebbar di cchadet n usitem nneɣ břa ma ad narjij, minzi d Wenni d aneɣ iwcin lwaɛd, dayes řaman.
\v 24 Ejj aneɣ ad neḥḍa ijj i wenneɣni ḥima ad negg uř deg wayawya ɣar tayri u ɣar řexdayem tiṣebḥanin.
\v 25 War nᵉttejji ca tamesmunt nneɣ am mammec nnumen ca, maca ad nessemḥeḍ ijjen wenneɣni, mahu ɛad xmi ɣa tẓarem aqa ass nni yiweḍ-dd.
\m 
\v 26 Minzi mařa ixḍa ca n ijj neɛmada awarni ma iṭṭef tussna n tidett, xenni war teqqim ɛad tɣarṣt x ddnub, \x ◘ \xo 10:26 \xt Řxř. 15:30; Mt. 12:31; Ɛbr. 6:4; 2 Bṭ. 2:20; 1 Yḥ. 5:16. \x*
\v 27 maca \add mɣir\add* araji n lḥisab issnexřɛen d řɛabuq n tmessi nni i ɣa iccen řɛedyan.
\v 28 Mařa ixḍa ḥed ak-d Ccariɛa n Musa, ittxeṣṣa ad immut břa arreḥmet x uqemmum n tnayen niɣ třata n řechud. \x ◘ \xo 10:28 \xt Řxř. 35:30; Aɛwd. 17:6; 19:15; Mt. 18:16; 2 Kur. 13:1. \x*
\v 29 Mecḥař ktar ittxeṣṣa ad ihwa lɛiqab x uzeǧif n wenni iɛeffsen x Mmis n AREBBI, d wenni iḥessben Idammen n Řɛahd nnes i zi tuɣa ittwaqeddes amecnaw idammen n marra iwdan, d wenni isseḥqaren \add ɛawed\add* Arruḥ n arḍa?
\v 30 Minzi nessen d Wenni innan:
\b
\m \qt “Antaqem i Necc umi iǧa,\qt*
\m \qt Necc ad t xeǧṣeɣ!”\qt*
\b
\m Uca ɛawed:
\b
\m \qt “SIDI ad iḥkem řgens nnes.”\qt* \x ◘ \xo 10:30 \xt Aɛwd. 32:35, 36; Rum. 12:19. \x*
\b
\m 
\v 31 Sseɛd d abarcan i wenni i ɣa iwḍan deg ifassen n AREBBI iddaren.
\v 32 S uya fekkarem deg wussan imezwura řami tᵉttwassɣeḍṣem u tuɣa tarebbum amenɣi ameqqran am mammec xawem tekka řefḍiḥet d řmeḥnet.
\v 33 Tdewřem d ijj n afurrej u tcarcem ak-d inneɣni umi daysen ittwagg ammu kifkif.
\v 34 Minzi teksim amnus x yinni ittwaḥebbsen, uca tqebřem akecceḍ n wagřa nwem s řefraḥet, tessnem belli ɣarwem agřa imɣar i war ifennin deg ijenwan. \x ◘ \xo 10:34 \xt Mt. 5:12; Řex. 21:33. \x*
\v 35 War neṭṭarem ca taryast nwem nni ɣar teǧa ict n řmunet temɣar.
\v 36 Minzi ittxeṣṣa kenniw ṣṣbar ḥima ad teggem min ixs AREBBI u maḥend ad tᵉṭṭfem lwaɛd. \x ◘ \xo 10:36 \xt Lk. 21:19. \x*
\b
\m 
\v 37 \qt “Minzi drus n řweqt i dinni, wah drus,\qt*
\m \qt \tl ař\tl* Wenni dd ɣa yasen ad ixecc,\qt*
\m \qt war ittɛeṭṭař ca.\qt* \x ◘ \xo 10:37 \xt Ḥab. 2:2-3; Ḥag. 2:7; 1 Bṭ. 1:6; 5:10. \x*
\m 
\v 38 \qt Maca amseggad s l’iman inu ad iddar,\qt*
\m \qt maca mařa ismeḥ,\qt*
\m \qt war dayes yareṭṭi řeɛmar inu.”\qt* \x ◘ \xo 10:38 \xt Ḥab. 2:4; Rum. 1:17; Gal. 3:11. \x*
\b
\m 
\v 39 Maca neccin war ɣarneɣ min ɣa negg s tarexxut i ittawyen ɣar txessart, maca ɣarneɣ l’iman i ittawyen ɣar usenjem n řeɛmar nneɣ.
\b
\b
\c 11
\s1 Řechud s l’iman
\m 
\v 1 L’iman řexxu d aḍman n tmesřayin nni di issitim bnadem, axmi tina ɛad xeddment, uřa d asargeb n tmesřayin innuffaren.
\v 2 Minzi s man aya tusa-dd ict n cchadet x imɣaren.
\m 
\v 3 S l’iman nefhem belli zzmanat ttwaggent s wawař n AREBBI, u belli timesřayin-a i dd-ittbanen aqa ttwaggent zi tmesřayin nni innuffaren. \x ◘ \xo 11:3 \xt Amz. 1:1; Izhd. 33:6; Yḥ. 1:10; Rum. 4:17; Afa. 3:9; Kul. 1:16. \x*
\m 
\v 4 S l’iman tuɣa \bd Habil\bd* iqeddem ict n tɣarṣt tecna aṭṭas x min tuɣa iqeddem Qayin i AREBBI. S uya i din teǧa cchadet xas belli tuɣa-t d amseggad. Uca AREBBI iched i tɣarṣt nnes u s uya issawař ɛad, waxxa netta immut. \x ◘ \xo 11:4 \xt Amz. 4:4; Mt. 23:35. \x*
\m 
\v 5 S l’iman immeksi \bd Inux\bd* břa ma iqqas řmewt. War ittwif ɛad, minzi iksi i-t AREBBI. Minzi qbeř ma ad t iksi, tuɣa xas cchadet-a: aqa tuɣa yareṭṭa AREBBI. \x ◘ \xo 11:5 \xt Amz. 5:22, 24. \x*
\v 6 Maca břa l’iman war izemmar bnadem ad yarḍa AREBBI, minzi wenni i ɣa dd-iqarrben ɣar AREBBI, ittxeṣṣa as ad yamen belli Netta aqa-t din, u belli Netta d amxeǧaṣ n yinni xas yarezzun.
\m 
\v 7 S l’iman tuɣa \bd Nuḥ\bd* itteggʷed, awarni řami d as ittwanna min tuɣa war dd-ittbinen, uca igga aɣarrabu i usenjem n iḥenjiren n twacunt nnes. S man aya aqa iḥkem x ddunect uca idweř netta d awrit n tsegda nni iǧan s l’iman. \x ◘ \xo 11:7 \xt Amz. 6:13. \x*
\m 
\v 8 S l’iman tuɣa \bd Ibrahim\bd*, řami dd-ittwařaɣa, iṭṭaɛ uca iffeɣ ɣar wemcan i ɣa iṭṭef d řwart, uca iffeɣ břa ma ad issen mani ɣa yaweḍ. \x ◘ \xo 11:8 \xt Amz. 12:4. \x*
\v 9 S l’iman tuɣa izeddeɣ am umɛezzeb di temmurt i d as ittwawaɛden, am di temmurt n ibarraniyyen. Netta izdeɣ deg iqiḍan ak-d Isḥaq d Yaɛqub, inni d iwriten akides n lwaɛd nni.
\v 10 Minzi ittraja Tandint s dsusa i zi iǧa AREBBI d Bab n řebni d Wenni tt iggin.
\m 
\v 11 S l’iman immewc as i \bd Sara\bd* jjehd maḥend ad teksi ddeyset - waxxa nettat war dd-tᵉttiruw, uca am tt tuɣa ɛad barra i řmijař n tewsar nnes - turuw-dd minzi tuɣa tessen nican belli wenni d as iwaɛden, dayes řaman. \x ◘ \xo 11:11 \xt Amz. 17:19; 21:2; Lk. 1:36. \x*
\v 12 S uyenni ɛawed zeg ijjen, aqa zeg wenni di ibḍeř jjehd nnes s tewsar, ttwařwen as-dd am yitran n ujenna s ubarru nsen u am yijdi x tma n řebḥar i war izemmar ad ittwaḥseb. \x ◘ \xo 11:12 \xt Amz. 15:5; 22:17; Rum. 4:18. \x*
\m 
\v 13 Di l’iman mmuten yina marra břa ma ad ṭṭfen min d asen ittwawaɛden, maca ẓrin t zi řaggʷaj uca farḥen zzayes uca neɛmen belli nitni d ibarraniyyen d imeɛzab x temmurt. \x ◘ \xo 11:13 \xt Amz. 23:4; 47:9; Yḥ. 8:53. \x*
\v 14 \add Minzi\add* inni iqqaren timesřayin am tina, ssecnen mliḥ belli nitni arezzun Tandint nsen.
\v 15 Meɛlik arzun x temmurt manis dd-ffɣen, iři aqa ufin lfurṣa ḥima ad ɛeqben din ɛawed.
\v 16 Maca řexxu iban-dd mliḥ aqa daysen meẓri ɣar \add temmurt\add* nni ḥsen, min ixs ad yini ɣar tenni deg ujenna. S uyenni AREBBI war iseḍḥi ca ad as řaɣan ‘AREBBI nsen’, minzi aqa issewjed asen ict n Tendint. \x ◘ \xo 11:16 \xt Uf. 3:6; Mt. 22:32; Řex. 7:32. \x*
\m 
\v 17 S l’iman iwca \bd Ibrahim\bd*, řami ittwaqeǧeb, Isḥaq d taɣarṣt, uca issars ayenni n mmis nni iṭṭef s lwaɛd, x uɛalṭar. \x ◘ \xo 11:17 \xt Amz. 22:10. \x*
\v 18 Maca ittwanna as:
\b
\m \qt “Di Isḥaq ad ac řaɣan zzariɛet nnec.”\qt* \x ◘ \xo 11:18 \xt Amz. 21:12; Rum. 9:7; Gal. 3:29. \x*
\b
\m 
\v 19 Tuɣa ixarreṣ ak-d ixef nnes, belli AREBBI izemmar ɛawed ad t-i-dd-issnekkar jar imettinen. S uya idweř-dd ɣares ɛawed s webrid n yijj n umedya, \add am s tnukra\add*.
\m 
\v 20 S l’iman zi jjihet n min tuɣa dd-igguren ɛad, ibarek \bd Isḥaq\bd* iḥenjiren nnes, Yaɛqub d Ɛisu. \x ◘ \xo 11:20 \xt Amz. 27:28, 39. \x*
\m 
\v 21 S l’iman tuɣa \bd Yaɛqub\bd*, řami immut, ibarek kuř ijjen zeg iḥenjiren n Yusuf am tuɣa iṭṭef deg ixef n teɣɣarct nnes. \x ◘ \xo 11:21 \xt Amz. 47:31; 48:15. \x*
\m 
\v 22 S l’iman tuɣa \bd Yusuf\bd*, řami tuɣa immut, issiweř x wuffuɣ n ayt n Israil uca iweṣṣa ten x iɣsan nnes. \x ◘ \xo 11:22 \xt Amz. 50:24-25. \x*
\m 
\v 23 S l’iman tuɣa \bd Musa\bd*, řami dd-ixřeq, ittwassnuffar zi lwalidin nnes třata n iyuren, řami ẓrin aḥenjir iṣbeḥ, uca \add s l’iman\add* war ggʷiden ca zeg řumur n ujeǧid. \x ◘ \xo 11:23 \xt Uf. 2:2; Řex. 7:20. \x*
\m 
\v 24 S l’iman yugi Musa, řami imɣar netta, ad as řaɣan ɛad mmis n yeǧis n firɛun.
\v 25 Mři yufa ad yiři ittwazeyyar ak-d řgens n AREBBI uřa d tarrit n meẓri di ddnub i drus n řweqt. \x ◘ \xo 11:25 \xt Izhd. 84:11. \x*
\v 26 Tuɣa iḥesseb aseḥqar n Lmasiḥ d agřa ameqqran sennej i řeknuz n Miṣra, minzi tuɣa ixezzar ɣar zzat ɣar řmunet.
\m 
\v 27 S l’iman ijja Miṣra, war iggʷid ca zeg uxeyyeq n ujeǧid, minzi iziyyar ixef nnes axmi iẓra AREBBI i war ittwaẓaren.
\m 
\v 28 S l’iman igga \add Taɣarṣt n\add* Useɛdu, uca irucc idammen, ḥima amkeḥḥaḍ n imenza nsen war ten ittḥidi ca. \x ◘ \xo 11:28 \xt Uf. 12:21. \x*
\m 
\v 29 S l’iman ẓwan Řebḥar n Uɣanim axmi kkin di řbarr, am ttwaṣarḍen Imiṣriyyen \add zi řebḥar\add* umi tuɣa xsen ad dayes cuqen. \x ◘ \xo 11:29 \xt Uf. 14:22. \x*
\m 
\v 30 S l’iman wḍan řeḥyuḍ n Ariḥa umi kkin sebɛa n wussan, ttennḍen as. \x ◘ \xo 11:30 \xt Yac. 6:20. \x*
\m 
\v 31 S l’iman war thellik ca \bd Raḥab\bd*, tamɣart n farq-ccɣeř ak-d yinni war iṭṭiɛen, am tuɣa tareḥḥeb ibergagen s řehna. \x ◘ \xo 11:31 \xt Yac. 2:1; 6:23; Yaɛ. 2:25. \x*
\m 
\v 32 Uca min ɣa iniɣ ɛad? Minzi řweqt war tqeddi ad ssiwřeɣ x \bd Jidɛun d Barak d Camcun d Yifta d Dawud d Camwil u x inabiyyen inneɣni\bd*, \x ◘ \xo 11:32 \xt Řqḍ. 4:6; 6:11; 11:1; 12:7; 13:24; 1 Ṣm. 17:45; 1 Ṣm. 12:2. \x*
\v 33 inni tuɣa iɣellben x tgeldiwin s l’iman, ggin tasegda, ṭṭfen lwuɛud, qqnen ixenfucen n wayraden, \x ◘ \xo 11:33 \xt Řqḍ. 14:6; 1 Ṣm. 17:34; Dan. 6:23. \x*
\v 34 ssxesyen jjehd n tmessi, arewřen zi řeqḍeɛ n ssif, ksin jjehd di tuḍɛeft, dewřen jehden deg imenɣan u qeřɛen x řemrageḥ n řɛeskar n ibarraniyyen. \x ◘ \xo 11:34 \xt 1 Ṣm. 20:1; 1 Ij. 19:3; 2 Ij. 6:16; Ayub 42:10; Izhd. 6:9; Ica. 38:21. \x*
\v 35 Arrin-dd i temɣarin iḥenjiren nsent s tnukra n imettinen, ca nneɣni mmuten s řeɛdab, tuɣa war ttrijin ad ttwafekken, maca ad ṭṭfen di tnukra icnan ḥsen zi man aya, \x ◘ \xo 11:35 \xt 1 Ij. 17:23; 2 Ij. 4:36; Řex. 22:25. \x*
\v 36 ca nneɣni ksin abehdeř d urekkuḍ, u \add ɛad\add* inneɣni ttwaggen di ssnaseř u di řeḥbes. \x ◘ \xo 11:36 \xt Irm. 20:2. \x*
\v 37 Inneɣni ttwarejmen, ttwaqessen di tnayen, inneɣni mmuten s řeqḍeɛ n ssif, telɛen am arḍen iřmawen n wuǧi d iɣayḍen, daysen řeɣben, ttwaḥṣaren, ttwaḍeřmen. \x ◘ \xo 11:37 \xt 1 Ij. 21:13; 2 Ij. 1:8; Mt. 3:4. \x*
\v 38 Nitni d iwdan i war d asen tessdaheǧ ddunnit \add ḥima ad dayes zedɣen\add*. Nitni dewřen d inni itelɛen di řexřawat, x idurar u deg ifran d ixerdusen n temmurt.
\m 
\v 39 Marra ina mixef tᵉttwaf ict n cchadet n l’iman nsen, war ṭṭifen ca di lwaɛd,
\v 40 minzi AREBBI tuɣa izwar iẓra di ṭṭweɛ nneɣ, aqa nitni war ttikkʷiḍen ca ɣar řekmaret břa neccin.
\b
\b
\c 12
\s1 Ṣṣbar n Yasuɛ Lmasiḥ
\m 
\v 1 S uya neccin ɛawed, umi d aneɣ dd-nnḍen marra řechud-a am iseynuten, ad nenḍar marra ddqeř n ddenb i d aneɣ dd-isswejden i řebda. Ejj aneɣ ad nuyur s ṣṣbar amḥizwar nni xaneɣ dd-immarsen. \x ◘ \xo 12:1 \xt Rum. 6:4; 12:12; 1 Kur. 9:24; Afa. 4:22; Kul. 3:8; Ɛbr. 10:36; 1 Bṭ. 2:1, 2. \x*
\v 2 Ejj aneɣ ad nenḍar tiṭṭawin di Yasuɛ, Amgewwad d Umkemmeř n l’iman nneɣ, wenni, zi ssibbet n řefraḥet i ɣares, yarbu ṣṣalib, war t icqi ubehdeř, uca iqqim x yefus n řɛarc n AREBBI. \f ◼ \fr 12:2 \fk Amgewwad\ft - niɣ: ‘Zzaɛim’.\f*  \x ◘ \xo 12:2 \xt Lk. 24:26; Fil. 2:8-11; Ɛbr. 1:3; 8:1; 1 Bṭ. 1:11. \x*
\v 3 Xzarem mliḥ, mecḥař i iksi Netta zeg imednab, inni d iɣrimen n řeɛmar n yixef nsen, ḥima war tᵉttiḥřem u war tarexxum ca di řeɛmar nwem.
\v 4 Aqa kenniw, war truḥem ca tiggʷejem ak-d ddenb, war temmɛařim ca ař \add usizzeř\add* n idammen \add nwem\add*. \x ◘ \xo 12:4 \xt 1 Kur. 10:13. \x*
\v 5 Tᵉttum taɣuri i xawem issawařen am iḥenjiren:
\b
\m \qt “Mmi inu, war ttegg ca s weɛrur\qt*
\m \qt x ttarbiyyet n SIDI,\qt*
\m \qt war ttiři ca d amarxu di řeɛmar nnec,\qt*
\m \qt xmi ɣa tᵉttwawebbxed zzayes.\qt* \x ◘ \xo 12:5 \xt Ayub 5:17; Awřn. 3:11-12; Asa. 3:19. \x*
\m 
\v 6 \qt Minzi wenni ittexs SIDI,\qt*
\m \qt yarebba i-t s uqessaḥ,\qt*
\m \qt uca iḥenjiren nnes i xas iɛizzen,\qt*
\m \qt iksi ten kuř ijj zzaysen ɣar uɣezdis.”\qt* \x ◘ \xo 12:6 \xt Awřn. 3:11, 12\x*
\b
\m 
\v 7 X uya, ksim ttarbiyyet, minzi AREBBI ittegg awem am iḥenjiren nnes. Minzi man mmis wenni babas war t yarebbi ca s uqessaḥ?
\v 8 Mařa aqa kenniw břa ttarbiyyet i di carcen marra, řexdenni kenniw \add am\add* ibarraniyyen i teǧam, war iǧi d arrawen.
\v 9 Mařa neksi ttarbiyyet zi babatneɣ ɛlaḥsab arrimet uca nweqqar i-ten, mecḥař d aneɣ ittxeṣṣa ad nṭaɛ i Babatneɣ n arruḥat, \add ḥima\add* ad neddar!
\v 10 Minzi nitni webbxen aneɣ ca n wussan am mammec d asen ittɣiř mliḥ, maca AREBBI igga i-tt i tizi nneɣ, ḥima ad ncarc di tqeddast nnes.
\v 11 Aqa war din uřa d ict n ttarbiyyet s uqessaḥ i ittbanen d řefraḥet deɣya, maca d řeḥriq, maca awarni as tiwi-dd řɣiǧet n řehna d tsegda i yinni zzayes ittwadarrben.
\m 
\v 12 S uyenni, sjehdem ifassen nwem yarxun d ifadden nwem yarehfen, \x ◘ \xo 12:12 \xt Ica. 35:3. \x*
\v 13 uca ggem nican iṣuraf n iḍaren nwem, ḥima min iǧan d aqejdaḥ war ittefriɣ ca, maca ad iggenfa.
\m 
\v 14 Ḍfarem-dd řehna d tuqeddsi ak-d marra, tenni břa zzayes war iẓar ḥed Siditneɣ. \x ◘ \xo 12:14 \xt Rum. 12:18; 2 Tim. 2:22. \x*
\v 15 Ɣarwem aqa uřa d ijj jar awem ad ittwaf inqeṣ as arḍa n AREBBI, niɣ aqa ad iɣmi weẓwar n tarzugi, ad kenniw iḍarr uca xenni ad zzayes ttwaxemjen aṭṭas, \x ◘ \xo 12:15 \xt Aɛwd. 29:17; Řex. 17:13; 2 Kur. 6:1; Gal. 5:12. \x*
\v 16 \add uca\add* ḥḍam, aqa war ittwiffi ḥed jar awem wenni d bu-farq-ccɣeř niɣ d ameqjuḥ am Ɛisu nni izzenzen řḥeqq n umenzu nnes x ijj n macca. \x ◘ \xo 12:16 \xt Amz. 25:33; Afa. 5:3; Kul. 3:5; 1 Ts. 4:3. \x*
\v 17 Minzi aqa tessnem, belli awarni man aya tuɣa yarezzu \add ɛad\add* ad iwart lbaraka, maca yugi as, maɣar war yufi ca ttasiɛ i weɛdař, waxxa yarezzu t s imeṭṭawen. \x ◘ \xo 12:17 \xt Amz. 27:36. \x*
\m 
\v 18 Minzi kenniw war tiwiḍem ca ɣar tmessi yarɣin niɣ ɣar wedrar i nzemmar ad nḥada, uřa ɣar tayyut tbarcant d tḥaryaḍt, \x ◘ \xo 12:18 \xt Uf. 19:10, 16; 20:21; Aɛwd. 5:22. \x*
\v 19 niɣ ɣar zzhir n uṣudi deg uyicc \add n icarri\add* uřa ɣar řḥess n wawařen di ssibbet nsen zawgen inni d as isřin, maḥend war ten kisen issiwiř ɛad. \x ◘ \xo 12:19 \xt Uf. 20:19; Aɛwd. 5:25; 18:16. \x*
\v 20 S minzi war zemmaren x ddqeř n tweṣṣa, minzi mařa iqarreb-dd mɣir ijj n umuddar adrar, ad ittwarjem netta. \f ◼ \fr 12:20 \fk amuddar\ft - niɣ ‘lḥayawan’.\f*  \x ◘ \xo 12:20 \xt Uf. 19:13. \x*
\v 21 Min ẓrin tuɣa issaggʷad aṭṭas, ařami inna Musa: “Aqa ggʷedeɣ u ttarjijiɣ!” \x ◘ \xo 12:21 \xt Aɛwd. 9:19\x*
\m 
\v 22 Maca kenniw tiwḍem ɣar wedrar n Ṣihyun, ɣar Tendint n AREBBI iddaren, ɣar Urcalim nni iǧan deg ijenwan u ɣar tmesmunt n ɛecra n řuřufat n lmalakat, \x ◘ \xo 12:22 \xt Gal. 4:26; Asa. 3:12; 21:10-27. \x*
\v 23 ɣar tmesmunt n imenza, inni ittwazemmemen deg ijenwan, u ɣar AREBBI, Řqaḍi x marra u ɣar arruḥat n imseggaden nni iwḍen ɣar řekmaret, \x ◘ \xo 12:23 \xt Lk. 10:20. \x*
\v 24 u ɣar Yasuɛ, Lwasit n Řɛahd n Jdid, u ɣar urucci s Idammen nnes, inni issawařen ḥsen zeg inni n Habil. \x ◘ \xo 12:24 \xt Irm. 31:31; Mt. 26:28, Mk. 14:24, Lk. 22:20, 1 Kur. 11:25, 2 Kur. 3:6, Ɛbr. 8:6, 8, 13; 9:15; 12:24; Amz. 4:10; Ɛbr. 10:22; 11;4; 1 Bṭ. 1:2. \x*
\m 
\v 25 Ɣarwem war tagim ca x Wenni akidwem issawařen, minzi mařa inni war ittwassnejmen ugin Wenni kidsen issawařen di temmurt, mahu ɛad neccin, mařa nḥeyyed x Wenni akidneɣ issawařen zeg ijenwan, \x ◘ \xo 12:25 \xt Ɛbr. 2:3. \x*
\v 26 Wenni tuɣa tmijja nnes tessenhezza tammurt, maca Wenni řexxu iwaɛd, inna:
\b
\m \qt “Ad ssenhezzeɣ ɛawed ict n twařa,\qt*
\m \qt war iǧi tammurt waha, aqa uřa d ajenna.”\qt* \x ◘ \xo 12:26 \xt Ḥag. 2:5. \x*
\b
\m 
\v 27 \add Awař-a\add*: ‘Ict n twařa!’, aqa imřa belli ad ittwakkes min ittenhezzan, minzi man aya ittwagg, ḥima ad qqiment tmesřayin war ttenhezzint.
\v 28 S uya, minzi ad neṭṭef tageldit yarekknen, ejj aneɣ ad neqqim nᵉtteṭṭef di arḍa i zi nettsexxar i AREBBI u nessarḍa i-t s uweqqar d tiggʷudi, \x ◘ \xo 12:28 \xt 1 Bṭ. 2:5. \x*
\v 29 minzi AREBBI nneɣ d ict n timessi ittetten. \x ◘ \xo 12:29 \xt Aɛwd. 4:24. \x*
\b
\b
\c 13
\s1 Awař ɣar uneggar ak-d useǧem
\m 
\v 1 Ejj ad teqqim tayri n tawmat jar awem. \x ◘ \xo 13:1 \xt Rum. 12:10; Afa. 4:3; 1 Bṭ. 1:22; 2:17; 4:8. \x*
\v 2 War tᵉttum ca ad tiřim tecnam ak-d ibarraniyyen, aqa zeɛma s uya areḥḥben ca s lmalakat am war ssinen. \x ◘ \xo 13:2 \xt Amz. 18:1; 19:1; Rum. 12:13; 1 Bṭ. 4:9. \x*
\m 
\v 3 Xarrṣem deg imeḥbas axmi kenniw ḥebbsem akidsen, xarrṣem deg inni ittwaḥsaren, am iwdan \add am\add* kenniw, inni yarḍen aysum \add n arrimet\add*. \x ◘ \xo 13:3 \xt Mt. 25:36. \x*
\m 
\v 4 Ejj ad yiři řemřac d aweqqar ɣar marra, d qama nsen \add n řemřac\add* d amezdag, maca AREBBI ad iḥkem x ayt n farq-ccɣeř u x yinni itteggen zzina.
\m 
\v 5 War tteggem nneyyet nwem di tenɛacin, maca qenɛem s min ɣarwem, minzi SIDI inna:
\b
\m \qt “Necc war cek ttejjiɣ\qt*
\m \qt niɣ ad semmḥeɣ deg ufus nnec.”\qt* \x ◘ \xo 13:5 \xt Amz. 28:15; Uf. 23:8; Aɛwd. 16:19; 31:6, 8; Yac. 1:5; 1 Im. 28:20; Awřn. 15:16; Fil. 4:11; 1 Tim. 6:6, 8. \x*
\b
\m 
\v 6 Man aya \add ittwanna\add* i neccin, maḥend ad nini s teryast:
\b
\m \qt “Sidi d Amɛawen inu, war tteggʷdeɣ ca,\qt*
\m \qt min d ayi ɣa yegg bnadem?”\qt* \x ◘ \xo 13:6 \xt Izhd. 56:5; 118:6. \x*
\b
\m 
\v 7 Ɛeqřem x imgewwaden nwem, inni d awem issiwřen awař n AREBBI. Beqqcem řɣiǧet n tecri nsen uca ḍfarem l’iman nsen. \x ◘ \xo 13:7 \xt Ɛbr. 13:17. \x*
\b
\m 
\v 8 Yasuɛ Lmasiḥ d Netta Netta iḍennaḍ d yiḍa, u i řebda.
\b
\m 
\v 9 War tejjim ad kenniw ɣarren s tɣuriwin ittbeddařen \add n deɣya\add*, minzi řḥajjet n lemliḥ mařa cebbaren wuřawen nneɣ di arḍa, war iǧi di macca, minzi inni tuɣa dayes yeřhan, war dayes ufin bu nnfeɛ. \x ◘ \xo 13:9 \xt Irm. 29:8; Mt. 24:4; Yḥ. 6:27; Rum. 14:17; 16:17; Afa. 4:14; 5:6; Kul. 2:16; 2 Ts. 2:2; 2 Tim. 4:3; 1 Yḥ. 4:1. \x*
\v 10 Ɣarneɣ ijj n uɛalṭar i umi war iɛeddeř ad zzayes ccen inni ittsexxaren di Tzeddiɣt.
\v 11 Minzi zeg imuddaren, inni idammen nsen ttwaksin ɣar Zzawect Iqeddsen s ufus n arrays n ikehhanen, ittwassarɣ weysum nsen barra i řmargeḥ. \f ◼ \fr 13:11 \fk imuddaren\ft - ixs ad yini ‘iwdan’ d ‘lḥayawanat’ d marra min iddaren nni izemmar ad yuyur.\f*  \x ◘ \xo 13:11 \xt Uf. 29:14; Lawi 4:21; 6:30; 16:27; Řxř. 19:3. \x*
\v 12 S uyenni tuɣa Yasuɛ imarret ɛawed barra i tendint, ḥima ad issqeddes řgens s Idammen nnes. \x ◘ \xo 13:12 \xt Yḥ. 19:17, 18. \x*
\v 13 S uyenni ejj aneɣ ad neffeɣ ɣar barra n řmargeḥ, am narebbu řɛar nnes.
\v 14 Minzi war ɣarneɣ da tandint n řebda, maca narezzu x tenni i dd ɣa yasen. \x ◘ \xo 13:14 \xt Fil. 3:20. \x*
\m 
\v 15 Ejj aneɣ řebda ad zzayes nqeddem tiwhibin n usemɣar i AREBBI, řɣiǧet n iyencicen nni dd-ittwayen aqadi i Yisem nnes. \x ◘ \xo 13:15 \xt Ḥuc. 14:3. \x*
\v 16 War ttᵉttum ca arreḥmet uřa d tecrimet i imeẓřaḍ, minzi s tewhibin-a ad yarḍa bnadem AREBBI. \x ◘ \xo 13:16 \xt Fil. 4:18. \x*
\m 
\v 17 Iřim d imtiqqan i yinni i kenniw ittgewwaden, ṭaɛem asen, minzi nitni ttɛessan x řeɛmur nwem am yinni itteggen řeḥsab xawem, ḥima ad tt ggen s řefraḥet, war iǧi s uweḥweḥ, minzi man aya war kenniw ineffeɛ. \x ◘ \xo 13:17 \xt Ḥiz. 3:18; 33:8; Fil. 2:29; 1 Ts. 5:12; 1 Tim. 5:17. \x*
\m 
\v 18 Ẓaǧem xaneɣ, minzi ɣarney ttiqqet belli ɣarneɣ tanefsect tecna, am dayneɣ meẓri, ḥima ad nuyur nican di marra.
\v 19 Ttzawgeɣ kenniw s jjehd ad teggem ammu ɣar umezwaru, ḥima xenni necc deɣya ad ɣarwem dd-dewřeɣ.
\m 
\v 20 AREBBI n řehna wenni dd-issnekkaren Ameksaw Ameqqran n wuǧi, Yasuɛ Lmasiḥ, Siditneɣ, zi taddart n imettinen s Idammen n Řɛahd i řebda, \x ◘ \xo 13:20 \xt Ica. 40:11; Ḥiz. 34:23; Yḥ. 10:11; 1 Bṭ. 5:4. \x*
\v 21 ad kenniw ikemmeř di kuř řxedmet icnan, ḥima ad teggem min ixs Netta. Netta ad dayneɣ igg min iǧan i arḍa nnes s Yasuɛ Lmasiḥ wenni ɣar iǧa uɛuǧi i řebda qaɛ. Amin. \x ◘ \xo 13:21 \xt 2 Kur. 3:5; Fil. 2:13. \x*
\m 
\v 22 Xenni ttzawageɣ zzaywem, \add a\add* aytma inu, qebřem awař-a n usejjeɛ s ttasiɛ n řxaḍar, minzi uriɣ awem-dd s drus.
\m 
\v 23 Snem aqa arxun i umatneɣ Timutiyu. Mařa yusa-dd deɣya, ad kenniw ẓareɣ \add akides\add*.
\m 
\v 24 Seǧmem x marra inni i kenniw ittgewwaden s řeḥna u x marra imqeddasen. Marra \add awmaten\add* n Iṭalya ttseǧamen-dd xawem s řehna.
\m 
\v 25 Arḍa ad kidwem yiři marra. Amin. 
