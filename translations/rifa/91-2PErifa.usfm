\id 2PE
\h 2 بُوطْرُوسْ
\toc1 2 بُوطْرُوسْ
\toc2 2 بُوطْرُوسْ
\toc3 2 بُط.
\mt1 2 بُوطْرُوسْ
\c 1
\s1 ڒْخذْمثْ ن أَربِّي ذڭْ وُوڒْ ن يِينِّي ذَايسْ ؤُمْننْ
\m 
\v 1 شِيمْعُونْ بُوطْرُوسْ، أَمْسخَّارْ ذ رَّاسُولْ ن يَاسُوع لْمَاسِيحْ، إِ إِنِّي إِتّْوَاحسْبنْ أَمْ نشِّينْ سّْذَاهدْجنْ لْ-إِيمَانْ س ثْسڭْذَا ن سِيذِيثْنغْ ذ ؤُمْسنْجمْ نّغْ، يَاسُوع لْمَاسِيحْ، عْلَاحْسَابْ شَّانْ ذ إِجّنْ أَكِيذْنغْ. \f ◼ \fr 1:‏1 \ft \bd ’أَمَازَانْ‘\bd* - نِيغْ ’رَّاسُولْ‘.\f*
\m 
\v 2 أَرْضَا ذ ڒهْنَا أَذْ غَارْومْ مَّارنْينْ خْمِي إِ غَا ثسّْنمْ سِيذِيثْنغْ، يَاسُوع لْمَاسِيحْ، \x ◘ \xo 1:‏2 \xt يُوح. 17‏:‏3؛ رُوم. 1‏:‏7؛ 1 بُط. 1‏:‏2؛ يَاه. 2. \x*
\v 3 أَمْ ونِّي إِوْشِينْ مَارَّا مِينْ إِدْجَانْ زِي جّهْذْ ن أَربِّي، مَاحنْذْ أَذْ يِيوِي ثُوذَارْثْ ذ ثِيڭّْوُوذِي زِي أَربِّي س ثُوسّْنَا ن ونِّي ذ أَنغْ د-إِڒَاغَانْ غَارْ ؤُعُودْجِي نّسْ ذ لْعَاضَامَا نّسْ،
\v 4 ذ ونِّي زَّايسْ نتَّا إِوْشَا أَومْ لْوُوعُوذْ إِمْغَارنْ إِغْڒَانْ أَطَّاسْ، حِيمَا أَذْ زَّايْسنْ ثْشَارْشمْ ذِي طّْبِيعثْ نّسْ ن أَربِّي، أَمْ ثتّْرَاكّْوَارمْ زِي نّشْوَاثْ إِغشّنْ إِ يدْجَانْ ذِي دُّونشْثْ. \x ◘ \xo 1:‏4 \xt إِشا. 56‏:‏5؛ يُوح. 1‏:‏12؛ رُوم. 8‏:‏15؛ ڭال. 3‏:‏26. \x*
\m 
\v 5 أَمْ ثدْجَا ثْمسْڒَاشْثْ أَمُّو، أَرْنِيمْ س مَارَّا شْضَارثْ إِ لْ-إِيمَانْ نْومْ ثْشُونِي إِفيّْضنْ، إِ ثْشُونِي نْومْ إِفيّْضنْ ثُوسّْنَا،
\v 6 إِ ثُوسّْنَا ڒوْعَارثْ، إِ ڒوْعَارثْ صّْبَارْ، إِ صّْبَارْ ثِيڭّْوُوذِي زِي أَربِّي،
\v 7 إِ ثِيڭّْوُوذِي زِي أَربِّي ثَايْرِي إِ وَاوْمَاثنْ ؤُ إِ ثَايْرِي إِ وَاوْمَاثنْ ثَايْرِي.
\v 8 مَاڒَا تّْوَافنْثْ ذَايْومْ ثِيمسْڒَايِينْ-أَ ؤُشَا أَذْ ذَايْومْ فيّْضنْثْ، وَارْ كنِّيوْ تّجِّينْثْ ثخْوَامْ نِيغْ بْڒَا ڒْغِيدْجثْ ذِي ثُوسّْنَا ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏8 \xt ثِيث. 3‏:‏14. \x*
\m 
\v 9 مِينْزِي ونِّي وَارْ غَارْ دْجِينْثْ ثْمسْڒَايِينْ-أَ، أَقَا إِدَّارْغڒْ، مِينْزِي وَارْ إِتّْوِيڒِي إِلَّا إِتُّو أَسِيزْذڭْ ن دّْنُوبْ نّسْ إِنِّي ثُوغَا خَاسْ. \x ◘ \xo 1:‏9 \xt إِشا. 59‏:‏10؛ صَاف. 1‏:‏17. \x*
\v 10 س ؤُينِّي، أَ أَيْثْمَا، شْضَارمْ كْثَارْ حِيمَا أَذْ ثْضمْنمْ ثَاڒَاغِيثْ ذ ؤُسِيخْضَارْ نْومْ س ڒخْذَايمْ ثِيصبْحَانِينْ، مِينْزِي مَاڒَا ثڭّمْ أَيَا، خنِّيعمَّارْصْ أَذْ ثنْقَارْضمْ.
\v 11 مِينْزِي أَمُّو إِ ذ أَومْ غَا إِمَّارْنِي س وَاطَّاسْ وَاذَافْ إِشْنَانْ غَارْ ثْڭلْذِيثْ إِتّْذُومَانْ ن سِيذِيثْنغْ ذ ؤُمْسنْجمْ نّغْ، يَاسُوع لْمَاسِيحْ.
\b
\s1 أَمْثَانْ ن لْ-إِيمَانْ نّغْ
\m 
\v 12 س ؤُينِّي وَارْ تّجِّيغْ أَذْ كنِّيوْ سّْعقْڒغْ زِي مَانْ أَيَا ڒبْذَا، وَاخَّا كنِّيوْ ثسّْنمْ ؤُ أَقَا كنِّيوْ ثْبدّمْ \add خْ ذْسَاسْ ن\add* ثِيذتّْ ثَانِيثَا.
\v 13 مَاشَا إِتّْغِيڒْ أَيِي نِيشَانْ مِينْ غَا كّغْ \add عَاذْ\add* ذِي أَرِّيمثْ-أَ، حِيمَا أَذْ كنِّيوْ سّْفَاقغْ أَمْ سّْعقْڒغْ كنِّيوْ، \x ◘ \xo 1:‏13 \xt 2 بُط. 3‏:‏1. \x*
\v 14 مِينْزِي سّْنغْ أَقَا ثَاكسِّيثْ ن أَرِّيمثْ إِنُو أَذْ د-ثَاسْ ذغْيَا، أَمْ مَامّشْ ذ أَيِي إِسَّارْڭبْ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏14 \xt يُوح. 21‏:‏18، 19؛ 2 تِيم. 4‏:‏6. \x*
\v 15 مَاشَا أَذْ ڭّغْ ثِيزمَّارْ، حِيمَا أَذْ ثْعقْڒمْ خْ ثْمسْڒَايِينْ-أَ أَوَارْنِي ؤُفُّوغْ إِنُو.
\m 
\v 16 مِينْزِي نشِّينْ وَارْ نضْفَارْ شَا ثِيحُوجَا إِسَايْسنْ، ؤُمِي ثُوغَا ذ أَومْ نتّْبَارّحْ جّهْذْ ذ ثْوَاسِيثْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، مَاشَا أَقَا نشْهذْ س ثِيطَّاوِينْ نّغْ خْ لْعَاضَامَا نّسْ. \x ◘ \xo 1:‏16 \xt مت. 17‏:‏1؛ يُوح. 1‏:‏14؛ 1 كُور. 1‏:‏17؛ 2‏:‏1، 4؛ 4‏:‏20؛ 1 يُوح. 1‏:‏1. \x*
\v 17 مِينْزِي نتَّا أَقَا إِطّفْ زِي أَربِّي بَابَاسْ شَّانْ ذ ؤُعُودْجِي ؤُمِي ذ أَسْ د-ثُوسَا ثْمِيجَّا-يَا زڭْ ؤُعُودْجِي إِ د-يُوسِينْ أَكْ-ذ لْعَاضَامَا نّسْ: ”وَا ذ مِّي إِنُو إِعِيزّنْ ونِّي ذَايسْ ؤُفِيغْ أَرْضَا إِنُو.“ \x ◘ \xo 1:‏17 \xt مت. 3‏:‏17؛ 17‏:‏5؛ مك. 1‏:‏11؛ 9‏:‏7؛ لك. 3‏:‏22؛ 9‏:‏35؛ كُول. 1‏:‏13. \x*
\v 18 ؤُڒَا ذ نشِّينْ نسْڒَا ثْمِيجَّا-يَا زڭْ ؤُجنَّا، ؤُمِي ثُوغَا إِسَّاوَاڒْ أَكِيذسْ، ڒَامِي ندْجْ أَكِيذسْ خْ وذْرَارْ إِقدّْسنْ.
\v 19 ؤُڒَا ذ نشِّينْ غَارْنغْ أَوَاڒْ ذ ثِيذتّْ ن إِنَابِييّنْ، \add ؤُ\add* كنِّيوْ أَذْ ثڭّمْ مْلِيحْ مَاڒَا ثوْشِيمْ ثَايْنِيثْ إِ وَاوَاڒْ نِّي أَمْ إِ يِيجّْ ن ڒفْنَارْ يَارقّنْ ذڭْ إِجّْ ن ومْشَانْ إِبُّوبّسْ، أَڒْ غَا إِدُّوقّزْ وَاسّْ ؤُشَا أَذْ ثنْقَارْ ثْفُوشْثْ ذڭْ وُوڒَاونْ نْومْ. \x ◘ \xo 1:‏19 \xt 2 كُور. 4‏:‏6؛ أَسَا. 22‏:‏16. \x*
\v 20 أَمزْوَارْ إِتّْخصَّا كنِّيوْ أَذْ ثسّْنمْ أَقَا وَارْ ذِينْ ؤُڒَا ذ إِشْثْ ن نُّوبُووَا ثنُّوفْسڒْ خْ ثِيرَا نّسْ \add إِقدّْسنْ\add*.
\v 21 مِينْزِي مِينْ إِتّْوَانَابّنْ وَارْ د-إِتّفِّيغْعمَّارْصْ زِي مِينْ إِخْسْ بْنَاذمْ، مَاشَا يُوسَا-د \add زڭْ ؤُقمُّومْ ن\add* يرْيَازنْ إِقدّْسنْ ن أَربِّي نِّي إِسِّيوْڒنْ أَمْ ذ أَسنْ د-إِنْذهْ أَرُّوحْ إِقدّْسنْ. \x ◘ \xo 1:‏21 \xt 2 تِيم. 3‏:‏16. \x*
\b
\b
\c 2
\s1 حْضَامْ إِخفْ نْومْ زڭْ إِمْسڒْمَاذنْ إِسّْخَارِّيقنْ
\m 
\v 1 مَاشَا ثُوغَا ذِينْ عَاوذْ جَارْ ڒْڭنْسْ إِنَابِييّنْ إِسّْخَارِّيقنْ، أَمْ مَامّشْ إِ غَا إِڒِينْ ؤُڒَا ذ إِمسْغَارنْ إِسّْخَارِّيقنْ جَارْ أَومْ، أَذْ سِّيذْفنْ ثِيبْرِيذِينْ إِتَّاردّْدْجنْ، أَذْ نْكَارنْ سِيذِي إِ ثنْ إِسْغِينْ، أَذْ سِّيوْضنْ \add أَمُّو\add* أَريّبْ ذغْيَا خْ يِيخفْ نْسنْ. \x ◘ \xo 2:‏1 \xt أَعَوذ. 13‏:‏2؛ مت. 24‏:‏11؛ ڒخ. 20‏:‏29؛ 1 تِيم. 4‏:‏1؛ 2 تِيم. 3‏:‏1. \x*
\v 2 أَطَّاسْ إِ غَا إِضْفَارنْ ثَاخْمُوجِي نْسنْ أَڒْ غَا إِتّْوَاشقّفْ وبْرِيذْ ن ثِيذتّْ زِي سِّيبّثْ نْسنْ.
\v 3 س طّْمعْ ؤُ س وَاوَاڒنْ إِتّْوَاڭّنْ أَذْ زَّايْومْ ڭّنْ أَمْ زِي سّڒْعثْ، \add مَاشَا\add* ڒْحُوكْمْ خَاسنْ زڭْ وشْحَاڒْ ؤُيَا وَارْ إِبْضِيڒْ شَا ؤُشَا أَهلّكْ نْسنْ وَارْ إِتّْنُوذُومْ شَا. \x ◘ \xo 2:‏3 \xt يَاه. 4. \x*
\m 
\v 4 مِينْزِي مَاڒَا أَربِّي وَارْ إِسَّارْ خْ \bd لْمَالَاكَاثْ\bd* إِ يڭِّينْ دّْنُوبْ، مَاشَا إِنْضَارْ إِ-ثنْ ذِي سّْنَاسڒْ ن ثَادْجسْثْ ذِي ڒَادْجَاغْ يُودْجْغنْ ؤُشَا إِسلّمْ إِ-ثنْ حِيمَا أَذْ تّْوَاخمّْڒنْ أَڒْ ڒْحُوكْمْ ن ؤُعدّبْ، \x ◘ \xo 2:‏4 \xt يَاه. 6؛ أَسَا. 20‏:‏3. \x*
\v 5 ؤُ \add عَاوذْ\add* وَارْ إِسَّارْ خْ \bd دُّونشْثْ ن زِيشْ\bd*، مَاشَا ثُوغَا إِحْضَا نُوحْ، ونِّي ذ وِيسّْ ثْمنْيَا، أَمْبَارّحْ ن ثْسڭْذَا، ڒَامِي د-إِضْڒقْ ڒْحمْڒثْ خْ دُّونشْثْ ن لْكُوفَّارْ، \x ◘ \xo 2:‏5 \xt أَمز. 7‏:‏23؛ 1 بُط. 3‏:‏19. \x*
\v 6 ؤُ \add عَاوذْ\add* ڒَامِي إِسّشْمضْ نتَّا \bd ثِيندَّامْ ن سَاذُومْ ذ عَامُورَّا\bd* ؤُ إِحْكمْ خَاسنْثْ س ؤُنقْڒبْ، أَقَا يَارَّا إِ-ثنْثْ ذ لْمِيثَالْ إِ لْكُوفَّارْ إِ غَا يِيڒِينْ عَاذْ. \x ◘ \xo 2:‏6 \xt أَمز. 19‏:‏24؛ أَعَوذ. 29‏:‏22؛ إِشا. 13‏:‏19؛ إِرْم. 50‏:‏40؛ حِز. 16‏:‏49؛ حُوش. 11‏:‏8؛ عَام. 4‏:‏11؛ يَاه. 7. \x*
\m 
\v 7 عَاوذْ إِسّنْجمْ نتَّا \bd لُوثْ، أَمْسڭَّاذْ\bd*، ونِّي ثُوغَا إِودّْبنْ أَطَّاسْ زِي ثِيشْڒِي إِخمْجنْ ن يِينِّي وَارْ غَارْ ثدْجِي شَّارِيعَا. \x ◘ \xo 2:‏7 \xt أَمز. 19‏:‏7، 8. \x*
\v 8 مَاغَارْ ؤُمِي أَمْسڭّذْ وَانِيثَا إِژْرَا ذ إِسْڒَا ثِيمڭَّا نْسنْ إِ وَارْ د-يُوسِينْ أَكْ-ذ شَّارِيعَا، إِتّْوَاعدَّابْ ڒعْمَارْ \add نّسْ\add* إِسڭّْذنْ زڭْ وَاسّْ أَڒْ وَاسّْ، أَمْ ثُوغَا إِزدّغْ جَارْ أَسنْ. \x ◘ \xo 2:‏8 \xt إِزهد. 119‏:‏158. \x*
\v 9 \add أَمُّو\add* إِ إِسّنْ سِيذِي مَامّشْ إِ غَا إِسُّوفّغْ إِنِّي ث إِتّڭّْوذنْ، زِي ڒْمحْنثْ، \add مَاشَا\add* نتَّا إِحطَّا إِنِّي وَارْ إِسڭّْذنْ حِيمَا أَذْ تّْوَاعدّْبنْ ذڭْ وَاسّْ ن لْحِيسَابْ، \x ◘ \xo 2:‏9 \xt 1 كُور. 10‏:‏13. \x*
\v 10 مَاهُو قَاعْ إِنِّي إِضْفَارنْ دَّاثْ \add نْسنْ\add* أَمْ تّْمژّْرنْ ذِي مِينْ إِخمْجنْ، ؤُ سحْقَارَّانْ صُّولْطَا \add ن إِجنْوَانْ\add*. أَقَا أَثنْ ذ إِمْعفَّارنْ ذ إِمْنفّْخنْ، وَارْ تَّارْجِيجِينْ زَّاثْ مِينْ إِعُودْجنْ أَمْ تّْشقَّافنْ.
\v 11 وَاخَّا لْمَالَاكَاثْ ؤُجَارنْثْ ثنْ ذِي صُّولْطَا ذ جّهْذْ، وَارْ خَاسنْ سِّيوِيضنْثْ ڒْحُوكْمْ ن سِيذِي ذِي سِّيبّثْ ن ؤُشقَّافْ.
\v 12 \add مَاشَا\add* نِيثْنِي \add س ڒْعكْسْ\add* دْجَانْ أَمْ إِمُودَّارنْ إِڭْنَاونْ عْلَاحْسَابْ طّْبِيعثْ، إِنِّي يُورَانْ إِ ثْغَارْصْثْ س ڒْمُوسْ ذ ثَاجيَّافْثْ أَمْ تّْشقَّافنْ ذِي مِينْ ذِي وَارْ فهّْمنْ. أَذْ تّْوَاجيّْفنْ ذِي ثْجيَّافْثْ \add ن يِيخفْ\add* نْسنْ. \f ◼ \fr 2:‏12 \ft \bd ’إِمُودَّارنْ‘\bd* - نِيغْ ’لْحَايَاوَانَاثْ‘.\f*  \x ◘ \xo 2:‏12 \xt إِرْم. 12‏:‏3؛ يَاه. 10. \x*
\v 13 إِنَا ذ إِنِّي خْ ثدْجَا ڒْمُوعْصِييّثْ ذ ڒْمُونثْ إِ ڒْمُوعْصِييّثْ. نِيثْنِي حسْبنْ ثَاوَارِّيثْ ن مژْرِي ذڭْ نّشْوَاثْ س ؤُزِيڒْ ذ أَبَارّعْ أَمْ شُّورنْ نِيثْنِي س إِبقِّيضنْ \add ن ڒوْسخْ\add*. خْمِي تَّارَّانْ نِّيثْنِي مژْرِي ذڭْ ؤُرَارنْ نْسنْ ن ؤُغبِّي، سلّْمنْ إِخفْ نْسنْ غَارْ ثْوَارِّيثْ ن مژْرِي ثَامقّْرَانْثْ.
\v 14 ثِيطَّاوِينْ نْسنْ شُّورنْثْ س زِّينَا ؤُ س دّنْبْ وَارْ إِقطِّينْ، خْمِيغكّْوَانْ نِيثْنِي ڒعْمُورْ ن يِينِّي وَارْ إِبدّنْ نِيشَانْ. أَقَا غَارْسنْ ؤُڒْ إِتّْوَاربَّانْ خْ طّْمعْ، أَقَا نِيثْنِي ذ ثَارْوَا ن نّعْڒثْ،
\v 15 فّْغنْ زڭْ وبْرِيذْ إِسڭّْمنْ، ودَّارنْ، ؤُشَا ضْفَارنْ أَبْرِيذْ نِّي إِكَّا بَالْعَامْ، مِّيسْ ن فَاغُورْ، ونِّي ثُوغَا إِتّخْسنْ ڒْمُونثْ ن ڒْغشّْ. \x ◘ \xo 2:‏15 \xt ڒخْڒ. 22‏:‏7، 21؛ يَاه. 11. \x*
\v 16 مَاشَا نتَّا إِكْسِي أَوبّخْ إِ ڒْمُوعْصِييّثْ نّسْ، مِينْزِي زَّايْڒثْ ثَاڭْنَاوْثْ ثسِّيوڒْ غَارسْ س إِشْثْ ن ثْمِيجَّا ن إِوْذَانْ، ثمْنعْ ثُوبُّوهڒْيَا ن ؤُنَابِي. \x ◘ \xo 2:‏16 \xt ڒخْڒ. 22‏:‏21. \x*
\m 
\v 17 نِيثْنِي ذ ڒْعُونْصَارَاثْ وَارْ ذَايسْ بُو وَامَانْ، ذ إِسيْنُوثنْ تّْوَاعَارّْننْ س ثْحَارْيَاضْثْ، أَقَا ثُوبَّارْشنْثْ ن ثَادْجسْثْ ثتّْوَاسّوْجذْ أَسنْ. \x ◘ \xo 2:‏17 \xt يَاه. 12. \x*
\v 18 مَاغَارْ مَاڒَا سِّيوْڒنْ س نّْعِي ن ڒْهَارْذْ \add نْسنْ\add* إِخْوَانْ، أَقَا نِيثْنِي سّْغكّْوَانْ س نّشْوَاثْ إِخمْجنْ ن أَرِّيمثْ إِنِّي إِڭُّورنْ أَذْ أَروْڒنْ زڭْ إِنِّي إِسلّْمنْ إِخفْ نْسنْ إِ ؤُغكّْوِي.
\v 19 وَاعْذنْ ثنْ س ثِيڒلِّي، وَاخَّا نِيثْنِي سِيمَانْثْ نْسنْ ذ إِسمْغَانْ ن ڒْغشّْ. مِينْزِي وِي زِي إِتّْوَاغلّبْ بْنَاذمْ، أَقَا إِ نتَّا أَذْ يِيڒِي ذ أَمْسخَّارْ. \x ◘ \xo 2:‏19 \xt يُوح. 8‏:‏34؛ رُوم. 6‏:‏16. \x*
\v 20 مَاغَارْ أَوَارْنِي ڒَامِي د-أَروْڒنْ نِيثْنِي زِي ڒخْمجْ ن دُّونشْثْ س ثُوسّْنَا ن سِيذِيثْنغْ ذ أَمْسنْجمْ نّغْ، يَاسُوع لْمَاسِيحْ، أَقَا ذوْڒنْ-د غَارْ ڒخْمجْ نِّي عَاوذْ ؤُشَا تّْوَاغلّْبنْ زَّايسْ ثْوَاڒَا نّغْنِي، أَقَا خنِّي أَنڭَّارْ نْسنْ أَذْ أَسنْ يُورَا مَاهُو خْ ؤُمزْوَارْ. \x ◘ \xo 2:‏20 \xt مت. 12‏:‏45؛ عبر. 6‏:‏4؛ 10‏:‏26. \x*
\v 21 أَقَا حْسنْ أَسنْ معْلِيكْ قِّيمنْ وَارْ سِّيننْ أَبْرِيذْ ن ثْسڭْذَا زِي مِينْ سّْننْ، ؤُشَا ڒخْذنِّي أَذْ فّْغنْ عَاوذْ خْ ثوْصيّثْ إِقدّْسنْ إِ ذ أَسنْ د-إِتّْوَاسلّْمنْ.
\v 22 أَقَا ثمْسَارْ أَسنْ أَمْ ت إِقَّارْ وَاوَاڒْ-أَ ن ثِيذتّْ: ”أَقْزِينْ أَقَا إِذْوڒْ-د خْ مِينْ ثُوغَا د-إِعُوقّْ!“ نِيغْ \add مَامّشْ ذ أَسْ قَّارنْ نّغْنِي\add*: ”ثِيڒفْثْ ثنِّي إِتّْوَاسِّيرْذنْ قَاعْ، \add ثذْوڒْ-د\add* ثتّْمَارَّاغْ ذڭْ ؤُبَارْيُوضْ \add نّسْ\add*!“ \x ◘ \xo 2:‏22 \xt أَوڒن. 26‏:‏11. \x*
\b
\b
\c 3
\s1 أَسّْ ن سِيذِي أَربِّي
\m 
\v 1 \add أَ\add* إِمْعِيزّنْ إِنُو، ثَا ذ ثَابْرَاثْ وِيسّْ ثْنَاينْ إِ ذ أَومْ د-ؤُرِيغْ ڒخُّو، ؤُ \add ذِي ثْنَاينْ ن ثبْرَاثِينْ-أَ\add* أَرزُّوغْ أَذْ سّْفَاقغْ نّيّثْ نْومْ إِصْفَانْ أَمْ كنِّيوْ سّْعقْڒغْ، \x ◘ \xo 3:‏1 \xt 2 بُط. 1‏:‏13. \x*
\v 2 حِيمَا أَذْ ثقِّيمنْ ثتّْفكَّارمْ ذڭْ وَاوَاڒنْ نِّي ثُوغَا إِنَّانْ إِنَابِييّنْ إِقدّْسنْ زِيشْ، ؤُڒَا ذِي ثوْصيَّاثْ ن سِيذِيثْنغْ ذ أَمْسنْجمْ نّغْ، ثِينِّي \add غَارْنغْ د-يِيوْضنْ\add* س رُّوسُولْ.
\v 3 مَانْ أَيَا إِتّْخصَّا أَذْ ثسّْنمْ ذ أَمزْوَارُو، أَقَا ذڭْ وُوسَّانْ إِنڭُّورَا أَذْ د-أَسنْ إِمسْثهْزَاينْ إِنِّي إِسْثهْزَانْ أَمْ ؤُيُورنْ غَارْ نّشْوَاثْ نْسنْ، \x ◘ \xo 3:‏3 \xt 1 تِيم. 4‏:‏1؛ 2 تِيم. 3‏:‏1؛ يَاه. 18. \x*
\v 4 أَذْ إِنِينْ: ”مَانِي إِدْجَا لْوَاعْذْ ن ثْوَاسِيثْ نّسْ؟ زڭْ وَامِي طّْصنْ ڒجْذُوذْ نّغْ، أَمُّو إِ يقِّيمْ كُوڒْشِي أَمْ ثُوغَا إِدْجَا زڭْ ؤُمزْوَارْ ڒَامِي ثتّْوَاڭّْ دُّونشْثْ.“ \x ◘ \xo 3:‏4 \xt حِز. 12‏:‏22. \x*
\v 5 معْلِيكْ ؤُفِينْ أَذْ تُّونْ بلِّي س وَاوَاڒْ ن أَربِّي أَقَا إِجنْوَانْ إِزْوَارنْ أَذْ إِڒِينْ، ؤُ أَقَا ڒْبَارّْ إِڭعّذْ زڭْ وَامَانْ ؤُ س ؤُفُوسْ ن وَامَانْ س وَاوَاڒْ ن أَربِّي، \x ◘ \xo 3:‏5 \xt أَمز. 1‏:‏9؛ إِزهد. 24‏:‏2. \x*
\v 6 \add أَمَانْ\add* إِ زِي ثتّْوَاهلّكْ دُّونشْثْ ن ڒْوقْثْ نِّي ؤُمِي د خَاسْ سّفْينْ وَامَانْ \add ن ڒْحمْڒثْ ذڭْ وُوسَّانْ ن نُوحْ،\add* ؤُشَا ثتّْوَامْحَا. \x ◘ \xo 3:‏6 \xt أَمز. 7‏:‏10، 21. \x*
\v 7 مَاشَا إِجنْوَانْ ذ ثمُّورْثْ ن يِيضَا أَقَا تّْوَاحفْضنْ س وَاوَاڒْ نّسْ، خمّْڒنْ إِ ثْمسِّي أَڒْ أَسّْ ن لْحِيسَابْ ذ ؤُودَّارْ ن لْكُوفَّارْ. \x ◘ \xo 3:‏7 \xt إِزهد. 102‏:‏27؛ إِشا. 51‏:‏6؛ 2 تس. 1‏:‏8؛ عبر. 1‏:‏11؛ 2 بُط. 3‏:‏10. \x*
\m 
\v 8 مَاشَا إِتّْخصَّا كنِّيوْ وَارْ ثتّتُّومْ إِشْثْ ن ڒْحَاجّثْ، \add أَ\add* إِمْعِيزّنْ، أَقَا-ت ذ ثَا: غَارْ سِيذِي إِجّْ ن وَاسّْ أَمْ أَڒفْ ن إِسڭّْوُوسَا ؤُشَا أَڒفْ ن إِسڭّْوُوسَا أَمْ يِيجّْ ن وَاسّْ. \x ◘ \xo 3:‏8 \xt إِزهد. 90‏:‏4. \x*
\v 9 أَقَا سِيذِي وَارْ إِسّْعِيزِّي ذڭْ ؤُسُوفّغْ ن ڒْوُوعُوذْ نّسْ أَمْ مَامّشْ ذ أَسنْ إِتّْغِيڒْ إِ شَا \add ن إِوْذَانْ\add*، مَاشَا نتَّا إِڭُّورْ أَكِيذْومْ س تَّاسِيعْ ن ڒْخَاضَارْ، مِينْزِي نتَّا وَارْ إِتّخْسْ شَا أَذْ يَاريّبْ ؤُڒَا ذ إِجّْ، مَاشَا مَاحنْذْ أَذْ ثُوبنْ مَارَّا. \x ◘ \xo 3:‏9 \xt حِز. 18‏:‏32؛ 33‏:‏11؛ إِشا. 30‏:‏18؛ حَاب. 2‏:‏3؛ رُوم. 2‏:‏4؛ 1 تِيم. 2‏:‏4؛ 1 بُط. 3‏:‏20؛ 2 بُط. 3‏:‏15. \x*
\m 
\v 10 مَاشَا أَسّْ ن سِيذِي أَذْ د-يَاسْ أَمْ ؤُخوَّانْ س دْجِيڒثْ. ذڭْ وَاسّْ نِّي أَذْ ودَّارنْ إِجنْوَانْ س ڒْغفْڒثْ ؤُ ثِيمسْڒَايِينْ ثِيمزْوُورَا \add ن دُّونشْثْ\add* أَذْ فسْينْثْ ذِي ثْمسِّي ؤُشَا ثَامُّورْثْ ذ ڒخْذَايمْ إِ خَاسْ إِدْجَانْ أَذْ تّْوَافنْثْ. \x ◘ \xo 3:‏10 \xt مت. 24‏:‏43،44؛ 1 تس. 5‏:‏2؛ أَسَا. 3‏:‏3؛ 16‏:‏15. \x*
\m 
\v 11 أَمْ مَارَّا ثِيمسْڒَايِينْ-أَ أَذْ فسْينْثْ أَمُّو، مَامّشْ إِتّْشُووَّارْ أَذْ ثُويُورمْ كنِّيوْ س ثْقدَّاسْثْ ذ ثِيڭّْوُوذِي زِي أَربِّي،
\v 12 أَمْ ثتّْرَاجَامْ ثَاوَاسِيثْ ن وَاسّْ ن أَربِّي، أَمْ ثتّْمژْرمْ ذَايسْ، خْمِي غَا فْنَانْ إِجنْوَانْ أَمْ تّْوَاقدْجْبنْ س ثْمسِّي ؤُشَا أَذْ فسْينْثْ ثِيمسْڒَايِينْ ثِيمزْوُورَا \add ن دُّونشْثْ\add* س ڒْعابُوقْ نّسْ. \x ◘ \xo 3:‏12 \xt إِزهد. 50‏:‏3؛ 2 تس. 1‏:‏8. \x*
\v 13 مَاشَا نشِّينْ أَقَا نتّْرَاجَا إِجنْوَانْ ن جْذِيذْ ذ ثمُّورْثْ ن جْذِيذْ مَانِي غَا ثزْذغْ ثْسڭْذَا عْلَاحْسَابْ لْوَاعْذْ نّسْ. \x ◘ \xo 3:‏13 \xt إِشا. 65‏:‏17؛ 66‏:‏22؛ أَسَا. 21‏:‏1. \x*
\m 
\v 14 س ؤُينِّي، \add أَ\add* إِمْعِيزّنْ إِنُو، ؤُمِي كنِّيوْ ثتّْرَاجَامْ مَانْ أَيَا، شْضَارمْ مَاحنْذْ أَذْ ثتّْوَافمْ بْڒَا ڒخْمجْ ؤُ بْڒَا ڒْعِيبْ زَّاثسْ ذِي ڒهْنَا.
\v 15 حسْبمْ تَّاسِيعْ ن ڒْخَاضَارْ ن سِيذِي ذ \add ثَاوَّارْثْ إِ\add* وصْڒَاحْ، أَمْ مَامّشْ ؤُڒَا ذ ؤُمَاثْنغْ إِعِيزّنْ بُولُوسْ ذ أَومْ د-يُورَا عْلَاحْسَابْ ثِيغِيثْ إِ ذ أَسْ إِمّوْشنْ، \x ◘ \xo 3:‏15 \xt رُوم. 2‏:‏4. \x*
\v 16 أَمْ مَامّشْ خَاسْ إِسِّيوڒْ نتَّا ذِي مَارَّا ثِيبْرَاثِينْ نّسْ. أَقَا ذِينْ شَا ن ثْمسْڒَايِينْ إِوْعَارنْ إِ ڒفْهَامثْ، ثِينِّي إِ سّْفَارَّاغنْ ڒْجُوهَّاڒْ ذ يوْذَانْ وَارْ إِمْثِيننْ \add ذڭْ وُوڒْ نْسنْ\add*، أَمْ مَامّشْ ڭِّينْ ؤُڒَا إِ ثِيرَا \add إِقدّْسنْ\add* نّغْنِي إِ وَاريّبْ ن يِيخفْ نْسنْ. \x ◘ \xo 3:‏16 \xt رُوم. 8‏:‏19؛ 1 كُور. 15‏:‏24؛ 1 تس. 4‏:‏15. \x*
\m 
\v 17 س ؤُينِّي كنِّيوْ \add أَ\add* إِمْعِيزّنْ إِنُو، أَمْ ثسّْنمْ مَانْ أَيَا قْبڒْ، حْضَامْ إِخفْ نْومْ، حِيمَا وَارْ ثْضفَّارَامْ أَوَارْنِي إِ ؤُودَّارْ ن يِينِّي إِدْجَانْ بْڒَا شَّارِيعَا ؤُشَا أَذْ ثوْضَامْ وَاخَّا ثُوغَا ثتّْبدَّامْ نِيشَانْ،
\v 18 مَاشَا \add س ڒْعكْسْ حْضَامْ\add* أَذْ ثيْممْ ذڭْ أَرْضَا ذ ثُوسّْنَا ن سِيذِيثْنغْ ذ أَمْسنْجمْ نّغْ، يَاسُوع لْمَاسِيحْ، ؤُ ن أَربِّي، بَابَاسْ، إِ ونِّي ؤُمِي غَا يِيڒِي ؤُعُودْجِي، أَمْ ڒخُّو أَمْ ڒبْذَا، أَڒْ ذڭْ وُوسَّانْ ن ڒبْذَا! أَمِينْ. 
