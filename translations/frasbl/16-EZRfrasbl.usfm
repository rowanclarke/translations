\v 13 \w Mais|strong="H3588"\w* \w le|strong="H3117"\w* \w peuple|strong="H5971"\w* \w est|strong="H5971"\w* \w nombreux|strong="H7227"\w*, \w et|strong="H3117"\w* \w c|strong="H1697"\w*'\w est|strong="H5971"\w* \w la|strong="H3117"\w* \w saison|strong="H6256"\w* \w des|strong="H3117"\w* \w pluies|strong="H1653"\w*, \w et|strong="H3117"\w* \w nous|strong="H3588"\w* \w ne|strong="H3808"\w* \w pouvons|strong="H3808"\w* \w pas|strong="H3808"\w* \w rester|strong="H5975"\w* \w dehors|strong="H2351"\w*. \w De|strong="H3117"\w* \w plus|strong="H3808"\w*, \w ce|strong="H1697"\w* n'\w est|strong="H5971"\w* \w pas|strong="H3808"\w* \w l|strong="H5971"\w*'\w œuvre|strong="H4399"\w* d'\w un|strong="H3117"\w* \w jour|strong="H3117"\w* \w ou|strong="H3117"\w* \w deux|strong="H8147"\w*, \w car|strong="H3588"\w* \w nous|strong="H3588"\w* \w avons|strong="H5971"\w* \w beaucoup|strong="H7227"\w* \w transgressé|strong="H6586"\w* \w dans|strong="H3117"\w* \w cette|strong="H2088"\w* \w affaire|strong="H1697"\w*.  
\v 14 \w Que|strong="H1697"\w* \w nos|strong="H7725"\w* \w princes|strong="H8269"\w* \w soient|strong="H1697"\w* \w donc|strong="H3427"\w* \w établis|strong="H3427"\w* \w pour|strong="H5704"\w* \w toute|strong="H3605"\w* \w l|strong="H5892"\w*'\w assemblée|strong="H6951"\w*, \w et|strong="H7725"\w* \w que|strong="H1697"\w* \w tous|strong="H3605"\w* \w ceux|strong="H3605"\w* \w qui|strong="H1697"\w*, \w dans|strong="H3427"\w* \w nos|strong="H7725"\w* \w villes|strong="H5892"\w*, \w ont|strong="H2205"\w* épousé \w des|strong="H8269"\w* \w femmes|strong="H5975"\w* \w étrangères|strong="H5237"\w*, \w viennent|strong="H6256"\w* \w à|strong="H3427"\w* \w des|strong="H8269"\w* \w époques|strong="H6256"\w* \w fixées|strong="H2163"\w*, \w et|strong="H7725"\w* \w avec|strong="H5973"\w* \w eux|strong="H1697"\w* \w les|strong="H7725"\w* \w anciens|strong="H2205"\w* \w de|strong="H5892"\w* \w chaque|strong="H3605"\w* \w ville|strong="H5892"\w* \w et|strong="H7725"\w* \w ses|strong="H5973"\w* \w juges|strong="H8199"\w*, jusqu'\w à|strong="H3427"\w* \w ce|strong="H1697"\w* \w que|strong="H1697"\w* \w la|strong="H7725"\w* \w colère|strong="H2740"\w* \w ardente|strong="H2740"\w* \w de|strong="H5892"\w* \w notre|strong="H7725"\w* \w Dieu|strong="H1697"\w* \w se|strong="H5892"\w* \w soit|strong="H5892"\w* \w détournée|strong="H7725"\w* \w de|strong="H5892"\w* \w nous|strong="H1697"\w*, jusqu'\w à|strong="H3427"\w* \w ce|strong="H1697"\w* \w que|strong="H1697"\w* \w cette|strong="H2088"\w* \w affaire|strong="H1697"\w* \w soit|strong="H5892"\w* réglée. »   
\p
\v 15 \w Seuls|strong="H5975"\w* \w Jonathan|strong="H3129"\w*, \w fils|strong="H1121"\w* d'Asahel, \w et|strong="H1121"\w* Jachzeja, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* Tikva, s'\w opposèrent|strong="H5975"\w* \w à|strong="H1121"\w* \w cela|strong="H2063"\w* ; \w et|strong="H1121"\w* Meshullam \w et|strong="H1121"\w* \w le|strong="H1121"\w* \w Lévite|strong="H3881"\w* Shabbethaï \w les|strong="H1121"\w* soutinrent.   
\p
\v 16 \w Les|strong="H6213"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w la|strong="H6213"\w* \w captivité|strong="H1473"\w* \w firent|strong="H6213"\w* \w ainsi|strong="H3651"\w*. \w Esdras|strong="H5830"\w* \w le|strong="H6213"\w* \w prêtre|strong="H3548"\w* \w et|strong="H1121"\w* certains \w chefs|strong="H7218"\w* \w de|strong="H1121"\w* \w maisons|strong="H1004"\w* \w paternelles|strong="H1004"\w*, \w selon|strong="H6213"\w* \w les|strong="H6213"\w* \w maisons|strong="H1004"\w* \w de|strong="H1121"\w* \w leurs|strong="H1121"\w* \w pères|strong="H6213"\w*, \w tous|strong="H3605"\w* \w désignés|strong="H8034"\w* \w par|strong="H6213"\w* \w leurs|strong="H1121"\w* \w noms|strong="H8034"\w*, \w furent|strong="H3117"\w* \w mis|strong="H1121"\w* \w à|strong="H6213"\w* \w part|strong="H1697"\w* ; \w et|strong="H1121"\w* \w ils|strong="H1121"\w* s'\w assirent|strong="H3427"\w* \w le|strong="H6213"\w* \w premier|strong="H7218"\w* \w jour|strong="H3117"\w* \w du|strong="H3117"\w* \w dixième|strong="H6224"\w* \w mois|strong="H2320"\w* \w pour|strong="H6213"\w* examiner l'\w affaire|strong="H1697"\w*.  
\v 17 \w Ils|strong="H3117"\w* \w en|strong="H3117"\w* \w eurent|strong="H3427"\w* \w fini|strong="H3615"\w* \w avec|strong="H3427"\w* \w tous|strong="H3605"\w* \w les|strong="H3605"\w* \w hommes|strong="H3117"\w* \w qui|strong="H3117"\w* avaient épousé \w des|strong="H3117"\w* \w femmes|strong="H3117"\w* \w étrangères|strong="H5237"\w* \w le|strong="H3117"\w* \w premier|strong="H7223"\w* \w jour|strong="H3117"\w* \w du|strong="H3117"\w* \w premier|strong="H7223"\w* \w mois|strong="H2320"\w*.   
\p
\v 18 \w Parmi|strong="H4672"\w* \w les|strong="H1121"\w* \w fils|strong="H1121"\w* \w des|strong="H1121"\w* \w prêtres|strong="H3548"\w*, \w il|strong="H3548"\w* s'\w en|strong="H3427"\w* \w trouva|strong="H4672"\w* \w qui|strong="H1121"\w* \w avaient|strong="H1121"\w* épousé \w des|strong="H1121"\w* \w femmes|strong="H1121"\w* \w étrangères|strong="H5237"\w* :  
\li1 des fils de Josué, fils de Jotsadak, et de ses frères : Maaséja, Éliézer, Jarib et Guedalia.  
\v 19 Ils s'engagèrent en donnant la main à renvoyer leurs femmes ; et, se reconnaissant coupables, ils offrirent un bélier du troupeau pour leur culpabilité.   
\li1
\v 20 Des fils d'Immer : Hanani et Zebadia.   
\li1
\v 21 Des fils de Harim : Maaséja, Élie, Shemaja, Jehiel et Ozias.   
\li1
\v 22 Des fils de Pashhur : Élioénaï, Maaséja, Ismaël, Nethaneel, Jozabad et Élasa.   
\li1
\v 23 Parmi les Lévites : Jozabad, Shimeï, Kélaja (c'est-à-dire Kélitha), Pethahja, Juda et Éliézer.   
\li1
\v 24 Parmi les chantres : Éliashib.  
\li1 Parmi les portiers : Shallum, Télem et Uri.   
\li1
\v 25 Et de ceux d'Israël : Des fils de Pareosh : Ramia, Jizzija, Malkija, Mijamin, Éléazar, Malkija et Benaja.   
\li1
\v 26 Des fils d'Élam : Matthania, Zacharie, Jehiel, Abdi, Jerémoth et Élie.   
\li1
\v 27 Des fils de Zatthu : Élioénaï, Éliashib, Matthania, Jerémoth, Zabad et Aziza.   
\li1
\v 28 Des fils de Bébaï : Jochanan, Hanania, Zabbaï et Athlaï.   
\li1
\v 29 Des fils de Bani : Meshullam, Malluc, Adaja, Jashub, Sheal et Jerémoth.   
\li1
\v 30 Des fils de Pahath-Moab : Adna, Kelal, Benaja, Maaséja, Matthania, Betsaleel, Binnuï et Manassé.   
\li1
\v 31 Des fils de Harim : Éliézer, Jishija, Malkija, Shemaja, Siméon,  
\v 32 Benjamin, Malluc et Shemaria.   
\li1
\v 33 Des fils de Hashum : Matthénaï, Matthatha, Zabad, Éliphéleth, Jerémaï, Manassé et Shimeï.   
\li1
\v 34 Des fils de Bani : Maadaï, Amram, Uel,  
\v 35 Benaja, Bédia, Keluhi,  
\v 36 Vania, Merémoth, Éliashib,  
\v 37 Matthania, Matthénaï, Jaasa,  
\v 38 Bani, Binnuï, Shimeï,  
\v 39 Shélémia, Nathan, Adaja,  
\v 40 Macnadbaï, Shashaï, Sharaï,  
\v 41 Azareel, Shélémia, Shemaria,  
\v 42 Shallum, Amaria et Joseph.   
\li1
\v 43 Des fils de Nebo : Jeïel, Matthithia, Zabad, Zebina, Jaddaï, Joël et Benaja.   
\p
\v 44 \w Tous|strong="H3605"\w* \w ceux-là|strong="H3605"\w* \w avaient|strong="H1121"\w* \w pris|strong="H5375"\w* \w des|strong="H1121"\w* \w femmes|strong="H1121"\w* \w étrangères|strong="H5237"\w*. \w Quelques-uns|strong="H1121"\w* \w d|strong="H1992"\w*'\w entre|strong="H7760"\w* \w eux|strong="H1992"\w* \w avaient|strong="H1121"\w* \w des|strong="H1121"\w* \w femmes|strong="H1121"\w* \w dont|strong="H1121"\w* \w ils|strong="H1121"\w* \w avaient|strong="H1121"\w* \w eu|strong="H7760"\w* \w des|strong="H1121"\w* \w enfants|strong="H1121"\w*.   