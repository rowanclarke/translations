\id ECC - Biblica® Open New Serbian Translation Latin 2017
\h Knjiga propovednikova
\toc1 Knjiga propovednikova
\toc2 Knjiga propovednikova
\toc3 Pro
\mt1 Knjiga propovednikova
\c 1
\s1 Sve je prolazno
\p 
\v 1 Reči propovednika, Davidovog sina i cara u Jerusalimu:
\q1 
\v 2 Prolaznost nad prolaznošću – vajka se propovednik –
\q1 prolaznost nad prolaznošću!
\q2 Sve je prolazno!
\b
\q1 
\v 3 U čemu je korist ljudima od sveg njihovog truda
\q2 kojim se upinju pod kapom nebeskom?
\q1 
\v 4 Pokolenje dolazi, pokolenje odlazi,
\q2 a zemlja traje doveka.
\q1 
\v 5 Sunce izlazi, sunce zalazi,
\q2 žuri na svoje mesto odakle izlazi.
\q1 
\v 6 Vetar ide na jug
\q2 i kruži na sever,
\q1 kovitla li kovitla,
\q2 da se ponovo kružeći vrati.
\q1 
\v 7 Sve reke u more teku,
\q2 a more nije puno;
\q2 i tamo odakle teku reke,
\q2 vraćaju se da opet teku.
\q1 
\v 8 Sve je to zamorno
\q2 i niko to ne može da iskaže.
\q1 Oko se nije nagledalo
\q2 i uho se nije zasitilo slušanja.
\q1 
\v 9 Jer šta se već zbilo, opet će da se zbude;
\q2 i šta se radilo, opet će da se radi.
\q2 Baš ništa novo nema pod kapom nebeskom.
\q1 
\v 10 Zar ima nečeg da neko kaže:
\q2 „Vidi, ovo je novo.“
\q1 Već od davnina,
\q2 pre nas toga je bilo.
\q1 
\v 11 Nema sećanja na ono prošlo,
\q2 kao što nema sećanja
\q1 kod onih koji tek dolaze
\q2 na ono što još nije došlo.
\s1 Mudrost je prolazna
\p 
\v 12 Ja, propovednik, bio sam car izrailjski u Jerusalimu.
\v 13 Elem, srcem sam se predao proučavanju i mudrom istraživanju svega što se zbiva pod nebesima. A to je tegoban zadatak koji je Bog dao ljudima da se njime bave.
\v 14 Posmatrao sam sva dela koja se čine pod kapom nebeskom – i gle – sve je prolazno i jurenje vetra!
\q1 
\v 15 Ono što je krivo ne može da se ispravi
\q2 i ono čega nema ne može da se izbroji.
\p 
\v 16 Kazao sam svome srcu: „Gle! Postao sam daleko mudriji od svih koji su pre mene vladali Jerusalimom, i srce mi se nagledalo tolike mudrosti i znanja.“
\v 17 Srcem sam se predao upoznavanju mudrosti, a upoznao sam i bezumlje i glupost. Shvatio sam – i to je jurenje vetra.
\q1 
\v 18 Jer, gde je mnogo mudrosti, mnogo je i strepnje,
\q2 i muku gomila ko gomila znanje.
\c 2
\s1 Uživanje je prolazno
\p 
\v 1 Kazao sam u svom srcu: „Hajde da oprobam uživanje, da dobro uživam.“ Ali, gle, i to je prolazno!
\v 2 Za smeh sam kazao: „Budalast je“; i za uživanje: „Koja mu je svrha?“
\v 3 Duboko sam razmišljao o zadovoljstvu tela u vinu – dok mi je srce mudrošću vođeno bilo – o prihvatanju bezumlja, dok ne otkrijem kakva je korist ljudima od onoga što rade pod nebesima za malo dana života svoga.
\p 
\v 4 Velike sam stvari sebi napravio: izgradio sam kuće, vinograde zasadio.
\v 5 Uredio sam vrtove i parkove, u njima posadio razno voće.
\v 6 Napravio sam jezera sa vodom za natapanje mlade šume.
\v 7 Doveo sam sluge i sluškinje, pored onih koji su mi pripadali po rođenju u kući. Imao sam stoke, mnoga krda i stada, više od svih koji su pre mene vladali u Jerusalimu.
\v 8 Nakupio sam i srebro, zlato, blago od careva i okolnih oblasti. Obezbedio sam pevače, pevačice, uživanja ljudska i mnoge žene.
\v 9 Postao sam moćan, uzvisio sam se više od svih svojih prethodnika u Jerusalimu, a i dalje sam bio mudar:
\q1 
\v 10 Svojim očima nisam uskratio nijednu želju
\q2 i srcu nisam uskratio nijedno uživanje.
\q1 Jer, srce se moje radovalo u svim mojim poduhvatima
\q2 i to mi je bila nagrada za sav trud moj.
\q1 
\v 11 A onda sam razmišljao o svim svojim delima koje sam preduzeo svojeručno,
\q2 o trudu koji sam uložio.
\q1 I gle, sve je prolazno i jurenje vetra,
\q2 bez koristi pod kapom nebeskom!
\s1 I mudrost i ludost prolaze
\q1 
\v 12 Zatim sam se posvetio razmišljanju
\q2 o mudrosti, bezumlju i gluposti.
\q1 Šta više da uradi carev naslednik
\q2 nakon onog što je već urađeno?
\q1 
\v 13 Shvatio sam da je mudrost bolja od gluposti
\q2 kao što je svetlost bolja od tame.
\q1 
\v 14 Mudrome su oči na glavi,
\q2 a bezumnik u tami hoda.
\q1 Ali sam naučio i ovo:
\q2 obojicu zadesi ista sudbina.
\p 
\v 15 I kazao sam u svom srcu:
\q1 „Sudbina bezumnika će i mene zadesiti,
\q2 pa čemu onda tolika moja mudrost?“
\q1 Još sam se vajkao u svom srcu:
\q2 „I to je prolazno!“
\q1 
\v 16 Jer sećanje na mudroga ne traje duže od sećanja na bezumnoga,
\q2 jer će se sve zaboraviti u danima koji stižu.
\q1 I – avaj – mudri će umreti
\q2 baš kao i bezumnik!
\s1 Mukotrpan rad je prolazan
\p 
\v 17 I tako mi je život omrznuo i ono što se pod kapom nebeskom radi postalo mi je mučno. Jer, sve je prolazno i jurenje vetra.
\v 18 Da, omrznuo sam sav svoj mukotrpan rad i trud pod kapom nebeskom, jer ga ostavljam svome nasledniku.
\v 19 I ko zna hoće li on mudar ili lud da bude? Tek, naslediće sav moj trud koji sam uložio i u kom sam mudar bio pod kapom nebeskom. Ali i to je prolazno.
\v 20 Počeo sam da očajavam u srcu nad svim uloženim trudom pod kapom nebeskom.
\v 21 Jer, neko se trudio mudro, sa znanjem i veštinom, i prepušta to onome ko nema udela u tome. Baš je i to prolazno i zlo je veliko.
\v 22 Šta vrede čoveku sav njegov trud i napor njegovog srca kojima mukotrpno radi pod kapom nebeskom?
\v 23 Jer, muči se sve svoje dane i strepi zbog svojih obaveza, pa mu ni noću srce ne miruje. I to je prolazno.
\p 
\v 24 Ništa bolje nema za čoveka nego da jede i pije, da mu duša uživa dobro njegovog truda. Naime, shvatio sam da je i to iz ruke Božije.
\v 25 A ko je to jeo i ko se nauživao mimo njega?
\v 26 Jer \add Gospod\add* svakome bogougodniku daje mudrost, znanje i radovanje. Grešniku daje zadatak da sabira, da skuplja i to da bogougodniku. A to je prolazno i jurenje vetra.
\c 3
\s1 Vreme za sve
\q1 
\v 1 Sve ima svoje doba i svaka stvar pod nebesima ima prikladno vreme:
\b
\q2 
\v 2 vreme rađanja i vreme umiranja;
\q2 vreme sađenja i vreme vađenja posađenog;
\q2 
\v 3 vreme ubijanja i vreme lečenja;
\q2 vreme rušenja i vreme građenja;
\q2 
\v 4 vreme plakanja i vreme smejanja;
\q2 vreme žaljenja i vreme igranja;
\q2 
\v 5 vreme razbacivanja kamenja i vreme sakupljanja kamenja;
\q2 vreme grljenja i vreme rastajanja;
\q2 
\v 6 vreme traganja i vreme mirenja sa gubitkom;
\q2 vreme čuvanja i vreme bacanja;
\q2 
\v 7 vreme cepanja i vreme ušivanja;
\q2 vreme ćutanja i vreme govora;
\q2 
\v 8 vreme ljubavi i vreme mržnje;
\q2 vreme rata i vreme mira.
\p 
\v 9 I kakva je korist trudbeniku od njegovog truda?
\v 10 Posmatrao sam posao koji je Bog dao ljudima da se njime bave.
\v 11 Naime, sve je predivno stvorio u prikladno vreme. Čak im je i večnost stavio u srca, ali ljudi ne mogu da dokuče dela koja Bog čini od početka do svršetka.
\v 12 Otkrio sam da za njih ništa bolje nema nego da se raduju i čine dobro sav svoj život;
\v 13 da svi ljudi jedu i piju, da uživaju korist truda svoga. I to je Božiji dar.
\v 14 Saznao sam da sve što Bog čini ostaje doveka, da tome ništa ne može da se doda i da od toga ništa ne može da se oduzme, da sve što Bog čini jeste da bi ga se ljudi bojali.
\q1 
\v 15 I sve što je bilo, jeste i sada,
\q2 i sve što će tek da bude, već je bilo,
\q2 a Bog traži ono što je minulo.
\p 
\v 16 Još sam video pod kapom nebeskom:
\q1 da na mestu pravde stoji nepravednost
\q2 i na mestu pravednosti stoji nepravednost.
\p 
\v 17 Kazao sam u svom srcu:
\q1 „Bog će da sudi
\q2 i pravedniku i nepravedniku,
\q1 jer postoji prikladno vreme,
\q2 za svaku stvar i delo svako.“
\p 
\v 18 Još sam kazao u svom srcu u vezi ljudi: „Bog ih iskušava, da uvide da su kao stoka, baš oni sami.“
\v 19 Jer, sudbina ljudi i sudbina stoke je jednaka sudbina: umiru i oni, a umire i ona. U svima je isti dah i čovek nije bolji od stoke. Da, jer sve je prolazno.
\v 20 Na isto mesto svi odlaze, jer su svi iz prašine i svi se u prašinu vraćaju.
\v 21 Ko zna odlazi li gore duh ljudi, a duh stoke odlazi li dole, u zemlju?
\p 
\v 22 Shvatio sam da za ljude nema boljeg nego da se raduju u svom poslu, jer to im je dano. Elem, ko će ih vratiti da vide kako će nakon njih biti?
\c 4
\s1 Tlačenje, mukotrpan rad, usamljenost
\p 
\v 1 Opet sam razmišljao o svem tom tlačenju koje se čini pod kapom nebeskom:
\q1 I gle, suze potlačenih,
\q2 a za njih nema tešitelja!
\q1 Nema tešitelja
\q2 za one pod silom ruke tlačitelja.
\q1 
\v 2 Hvalio sam mrtve,
\q2 one već preminule
\q1 više nego žive,
\q2 koji su još u životu.
\q1 
\v 3 I od jednih i od drugih
\q2 bolje je onome ko se rodio nije,
\q1 onome koji nije video zlodelo
\q2 koje se čini pod kapom nebeskom.
\p 
\v 4 Elem, razmišljao sam o svakom trudu, svakoj veštini u poslu: zbog toga svako zavidi bližnjemu svome. A i to je prolazno i jurenje vetra.
\q1 
\v 5 Bezumnik prekrsti svoje ruke
\q2 i onda jede sebe samog.
\q1 
\v 6 Bolja je jedna puna šaka, a u miru
\q2 nego obe pune šake u muci
\q2 i jurenju vetra.
\p 
\v 7 Opet sam razmišljao o prolaznosti pod kapom nebeskom:
\q1 
\v 8 Čovek samac, bez druga,
\q2 bez sina i brata pored sebe,
\q1 ali nema kraja njegovom mukotrpnom radu.
\q2 Oči mu nikada nisu site blaga, pa se vajka:
\q1 „Za koga ja to radim,
\q2 duši svojoj uskraćujem sreću?“
\q1 I to je prolazno
\q2 i tegoban je zadatak.
\b
\q1 
\v 9 Dvojici je bolje nego jednom,
\q2 jer imaju dobru korist od svog truda.
\q1 
\v 10 Jer, padne li jedan,
\q2 drug njegov će ga podignuti.
\q1 I jao onom koji padne,
\q2 a nema druga da ga podigne!
\q1 
\v 11 Elem, toplo im je kad leže udvoje,
\q2 a kako će se jedan ugrejati?
\q1 
\v 12 I ako neko nadvlada jednoga,
\q2 dvojica mogu tog da nadvladaju.
\q1 Tek, trostruko se uže ne iskida brzo.
\s1 I boljitak je prolazan
\p 
\v 13 Bolji je siromašan, a mudar mladić, od budalastog i ostarelog cara što se više ne da savetovati.
\v 14 Jer on je izašao iz zatvora i zacario se, a u svom se carstvu rodio kao siromah.
\v 15 Posmatrao sam sve živo što hoda pod kapom nebeskom i video da pristaju uz ovog drugog, uz mladića koji će ga naslediti.
\v 16 Nebrojeni je sav taj narod, svi koji su bili pred njima. Ali oni što dolaze posle neće mu se radovati. I to je prolazno i jurenje vetra.
\c 5
\s1 Ispuni zavete koje si dao Bogu
\p 
\v 1 Pazi na svoje korake kada ideš u Dom Božiji. Pristupi da slušaš, jer je to bolje od žrtve bezumnika što ne znaju da zlo čine.
\q1 
\v 2 Ne brzaj ustima,
\q2 ne srljaj srcem
\q2 pred Boga sa rečima,
\q1 jer je Bog na nebesima,
\q2 a ti si na zemlji.
\q2 Zato ne govori mnoge reči.
\q1 
\v 3 Jer san dolazi od obilja rada,
\q2 a glas bezumnika od obilja reči.
\p 
\v 4 A kada daš zavet Bogu, ne oklevaj da ga ispuniš, jer Bogu nisu mili bezumnici. Ispuni šta si se zavetovao.
\v 5 Bolje je i da se ne zavetuješ nego da se zavetuješ, a ne ispuniš.
\v 6 Ne daj svojim ustima da te u greh vode i ne reci pred vesnikom\f + \fr 5,6 \ft Ili: \fqa anđelom\ft , što je rešenje koje prate stariji prevodi, dok noviji ističu da je reč o \fqa svešteniku.\f* Božijim: „Ovo je bila nesmotrenost!“ Zašto da se Bog gnevi na tebe i uništi delo ruku tvojih?
\v 7 Jer kao što je prolaznost u obilju snova, tako je i u mnogim rečima. Zato – Boga se boj!
\s1 Bogatstvo je prolazno
\p 
\v 8 Ako u okolnim oblastima vidiš da se tlači siromah i izvrću pravo i pravičnost, ne čudi se toj stvari. Jer i nad visokim ima ko je viši, a nad njima bdije uzvišeniji.
\v 9 Dobrobit od zemlje je za svakog, jer i samom caru se služi od njive.
\q1 
\v 10 Ko god voli srebro, srebrom neće biti zadovoljan;
\q2 ni zaradom onaj što bogatstvo voli.
\q2 I to je prolazno.
\b
\q1 
\v 11 Gde je mnogo imovine,
\q2 mnogo je i onih što je troše.
\q1 U čemu je onda dobit njenim gazdama
\q2 osim što je svojim očima gledaju?
\b
\q1 
\v 12 Trudbeniku je sladak san
\q2 bilo da je malo ili mnogo jeo;
\q1 a bogatstvo bogatome
\q2 miran san ne pruža.
\p 
\v 13 Video sam da pod kapom nebeskom postoji zlo golemo:
\q1 bogatstvo nagomilano za bedu vlasniku svome.
\q2 
\v 14 Elem, propalo je to bogatstvo u poslovima lošim,
\q1 pa takav rođenom sinu ništa
\q2 ne ostavlja u rukama svojim.
\q1 
\v 15 Kakav je iz majčine utrobe izašao – go –
\q2 vratiće se kakav je i došao.
\q1 I ništa u rukama svojim od svog truda
\q2 neće uzeti i poneti.
\p 
\v 16 I ovo je zlo golemo:
\q1 kakav je došao, takav će i otići.
\q2 I u čemu je korist za njega
\q2 što se mučio u vetar?
\q1 
\v 17 Stvarno, jeo je sumoran kroz sve dane svoje,
\q2 uznemiren, veoma bolestan i srdit.
\p 
\v 18 Eto, video sam nešto dobro i korisno za čoveka: da jede i pije, da uživa dobro sveg svog truda kojim se muči pod kapom nebeskom za malo dana svog života koje mu je Bog dao da su njegovi.
\v 19 Svakom čoveku kome je Bog dao imetak i bogatstvo, dao je i ovlašćenje da od toga jede, da primi svoju nagradu i bude srećan u svom trudu – i to je Božiji dar.
\v 20 Jer, on se ne seća često dana svog života, jer ga Bog zaokuplja radostima njegovog srca.
\c 6
\p 
\v 1 Postoji za ljude još jedno veliko zlo koje sam video pod kapom nebeskom:
\v 2 Nekome Bog da imetak, bogatstvo, čast, pa mu duši ništa ne manjka što poželi. Ali mu Bog ne daje da uživa, da jede od toga, već tuđinac jede. To je prolazno i teška je bolest.
\p 
\v 3 Da neko ima stotinu sinova, da živi mnoge godine, da je mnogo dana njegovih godina – čak i groba ne imao, a duša mu se nije nasitila blagostanja – onda tvrdim da je i mrtvorođenče bolje od njega.
\v 4 Jer, ono je uzalud rođeno, u tamu je otišlo i tama mu ime pokriva.
\v 5 Nije videlo sunca i ne zna za njega, a počiva bolje nego onaj drugi;
\v 6 koji, sve da živi i dvaput po hiljadu godina, ne uživa u svome imetku. Najzad, ne idu li svi na isto mesto?
\q1 
\v 7 Sav je čovekov trud za njegova usta,
\q2 ali mu opet duša nije sita.
\q1 
\v 8 Po čemu je mudrom bolje od bezumnog,
\q1 i šta ima siromašak
\q2 koji ume da se vlada pred ljudima?
\q1 
\v 9 Bolje je ono što oči gledaju
\q2 nego ono za čim duša žudi,
\q1 jer je i to prolazno
\q2 i jurenje vetra.
\b
\q1 
\v 10 Ono što se zbilo određeno je i bilo,
\q2 i zna se šta je čovek:
\q1 ne može da se spori
\q2 sa jačim od sebe.
\q1 
\v 11 Tamo gde je mnogo reči
\q2 besmisao biva veći,
\q2 i kakva je od toga čovekova korist?
\p 
\v 12 Jer ko zna šta je dobro za čoveka u malo dana njegovog prolaznog života koji mu iščeznu kao sena? Ko će da kaže čoveku šta će se zbiti nakon njega pod kapom nebeskom?
\c 7
\s1 Mudrost
\q1 
\v 1 Bolje je dobro ime od dobrog mirisnog ulja
\q2 i dan smrti od dana rođenja.
\q1 
\v 2 Bolje je ići u kuću ožalošćenih
\q2 nego u kuću gde je gozba,
\q1 jer je to kraj svakom čoveku.
\q2 Neka to srcem svojim prigrli ko živi.
\q1 
\v 3 Od smeha je strepnja bolja
\q2 jer je u tužnom licu milina srcu.
\q1 
\v 4 Srce mudrih ljudi je u kući ožalošćenih,
\q2 a srce bezumnika u kući gde je gozba.
\q1 
\v 5 Bolje je slušati prekor mudrog
\q2 nego kad neko sluša pesmu bezumnika.
\q1 
\v 6 Naime, smeh bezumnika
\q2 je poput praskanja trnovog granja pod loncem,
\q2 ali i to je prolazno.
\b
\q1 
\v 7 Nasilje i mudrog čini ludim,
\q2 a u mitu srce ogrezne.
\b
\q1 
\v 8 Kraj neke stvari je bolji od njenog početka
\q2 i dugotrpeljivost od bahatosti.
\q1 
\v 9 Ne nagli duhom do jarosti,
\q2 jer jarost počiva u nedrima bezumnika.
\b
\q1 
\v 10 Ne pitaj: „Zašto su dani koji su prošli bolji od dana koji su došli?“,
\q2 jer takvo pitanje nije mudro.
\b
\q1 
\v 11 Mudrost je dobra kao i nasledstvo
\q2 i na korist je onima koje sunce obasjava.
\q1 
\v 12 Jer je u mudrosti zaklon
\q2 kao što je u novcu zaklon,
\q1 ali je prednost poznavanja mudrosti u tome
\q2 što čuva život mudrih.
\p 
\v 13 Razmisli o delu Božijem:
\q1 ko je to kadar da ispravi
\q2 ono što on iskrivi?
\q1 
\v 14 U danu dobrih stvari i ti dobar budi,
\q2 a u danu loših stvari razmisli o ovom:
\q1 Bog je načinio oboje s razlogom,
\q2 da čovek ne zna šta će biti nakon njega.
\p 
\v 15 Baš sam svašta video u danima svoje prolaznosti:
\q1 pravednika koji strada u svojoj pravednosti
\q2 i nepravednika koji istrajava u svojoj nepravednosti.
\q1 
\v 16 Ne budi preterano pravedan
\q2 i ne čini sebe premudrim.
\q3 Zašto bi se upropastio?
\q1 
\v 17 Ne budi preterano zao
\q2 i ne budi lud.
\q3 Zašto bi umro kad ti vreme nije?
\q1 
\v 18 Dobro je da se držiš ovog saveta,
\q2 a i prethodni ne ispuštaj iz ruke.
\q2 Jer ko se boji Boga spasava se od svega.
\b
\q1 
\v 19 Mudrost mudrome pruža više snage
\q2 nego desetorici vladara što su u gradu.
\b
\q1 
\v 20 Stvarno, nema na zemlji pravednog čoveka
\q2 koji čini dobro i ne greši.
\b
\q1 
\v 21 Elem, ne mari za priče što ih ljudi pričaju,
\q2 da ne bi čuo kako te tvoj sluga kune.
\q1 
\v 22 Jer, srce tvoje zna
\q2 da si često i ti kleo druge.
\p 
\v 23 I sve sam to iskušao mudrošću, pa rekoh:
\q1 „Biću mudar!“
\q2 Ali, to je bilo daleko od mene.
\q1 
\v 24 Šta god da se zbiva je daleko i preduboko.
\q2 Ko će to da dokuči?
\q1 
\v 25 Tako sam srcem nastojao da saznam,
\q2 da istražim, da nađem mudrost i smisao,
\q1 da otkrijem glupost nepravde
\q2 i ludost bezumlja.
\b
\q1 
\v 26 I otkrio sam da je žena,
\q2 koja je kao zamka i čije je srce mreža,
\q1 od smrti gorča
\q2 i da su joj ruke kao lanci.
\q1 Bogougodnik od nje beži
\q2 dok grešnika ona hvata.
\p 
\v 27 Gle, to sam otkrio – govori propovednik –
\q1 dok sam stvari po stvari tražio smisao,
\q2 
\v 28 za kojim istrajno tragam dušom
\q2 i ne nalazim ga:
\q1 od njih hiljadu čoveka jednog sam našao,
\q2 ali ženu među svim ovima našao nisam.
\q1 
\v 29 Eto, jedno sam otkrio:
\q2 Bog je ljude stvorio čestitima,
\q2 ali oni kojekakve spletke traže.
\c 8
\q1 
\v 1 Ko je poput mudrog čoveka?
\q2 Ko poznaje značenje stvari?
\q1 Mudrost čoveku obasjava lice
\q2 i tvrdoću mu lica omekšava.
\s1 Poslušnost caru
\p 
\v 2 Kažem ti: carevu zapovest izvrši zbog zaveta pred Bogom.
\v 3 Ne žuri da od njega odeš i ne pristaj na zlu stvar, jer on čini šta god poželi.
\v 4 Naime, njegova reč je vrhovna i ko će da mu kaže: „Šta to radiš?“
\q1 
\v 5 Ko god sluša njegovu zapovest neće doživeti zlo,
\q2 a mudro srce zna i pravo vreme i način.
\q1 
\v 6 Jer za sve postoji pravo vreme i način,
\q2 makar nevolja velika pritiska čoveka.
\b
\q1 
\v 7 Tek, on ne zna šta će da se zbude,
\q2 i ko da mu kaže kad će se šta desiti?
\q1 
\v 8 Nema čoveka koji vlada vetrom,
\q2 koji vetar zauzdava.
\q1 Niko ne vlada danom smrti,
\q2 od boja nema poštede,
\q1 a nepravda ne spasava
\q2 onog nad kim vlada.
\p 
\v 9 Sve to sam video i srcem razmišljao o svemu što se radi pod kapom nebeskom. Nekada čovek vlada čovekom na njegovu štetu.
\v 10 A video sam i zlobnike, već sahranjene, kako dolaze i odlaze sa svetog mesta. Zaboravili su ih u gradu gde su tako radili. A i to je prolazno.
\p 
\v 11 Zato što ih kazna za zlo ne stiže odmah, ljudi su srcem rešeni da čine zlo.
\v 12 Makar da grešnik i stotinu puta učini zlo, pa opet dugo živi, ja znam da će bogobojaznima biti dobro jer se boje Boga.
\v 13 A zlobniku neće biti dobro, neće mu se produžiti dani što su poput senke, jer se Boga ne boji.
\p 
\v 14 I ovo je prolaznost koja se dešava na zemlji: ima pravednika kojima se dešava po delima nepravednika, a ima nepravednika kojima se dešava po delima pravednika. Ali, kažem, i to je prolazno.
\v 15 Tako sam hvalio uživanje, jer za čoveka nema boljeg pod kapom nebeskom nego da jede i pije, da srećan bude; to da ga prati u trudu njegovom kroz dane života njegovog, koji mu je Bog dao pod kapom nebeskom.
\p 
\v 16 Zato sam se srcem predao da upoznam mudrost, da vidim dostignuća što su na zemlji ostvarena – iako zbog njih nekome ni noću ni danju san na oči ne dolazi –
\v 17 razmislio sam o svim Božijim delima: čovek ne može da dokuči urađeno pod kapom nebeskom. On traga s trudom ali ne nalazi. Makar mudar tvrdio da je zna, ipak nije kadar da to dokuči.
\c 9
\s1 Jednaka sudbina za sve
\p 
\v 1 Dakle, svemu tome sam se srcem predao, da sve to razjasnim. Jer, i pravedan i mudar su sa svojim delima u Božijoj ruci. Voljen ili omražen – čovek ne zna ništa od onoga što ga čeka.
\v 2 Svima je ista sudbina: pravednom kao i nepravednom, dobrom i čistom kao i nečistom, onome koji žrtvuje, kao i onome koji ne žrtvuje,
\q1 dobrome kao i grešnome,
\q2 onome koji se zaklinje,
\q2 kao i onome koji se boji zaklinjanja.
\p 
\v 3 Ovo je zlo u svemu što se čini pod kapom nebeskom: svima je ista sudbina, a i srce ljudi je puno zla. Ludost je u njihovom srcu dok god su živi, a nakon toga umiru.
\v 4 Ko god je među svim živima ima nadu, jer je i živom psu bolje nego uginulom lavu.
\q1 
\v 5 Živi znaju da će umreti,
\q2 a umrli ne znaju ništa;
\q1 nagrade za njih više nema
\q2 jer je iščeznuo spomen na njih.
\q1 
\v 6 Odavno su propale njihove ljubavi,
\q2 mržnje i zavisti,
\q1 nemaju više udela doveka
\q2 u svemu što se dešava pod kapom nebeskom.
\p 
\v 7 Hajde, radosno hleb svoj jedi, pij svoje vino s milinom u srcu, jer je Bog već prihvatio dela tvoja!
\v 8 Neka ti odeća uvek bela bude i neka ti ulja na glavi uvek bude.
\v 9 Sa ženom koju voliš uživaj kroz sve dane svog prolaznog života koji ti je dan pod kapom nebeskom u svim tvojim prolaznim danima. Jer ti je to nagrada u životu za tvoj trud koji ulažeš pod kapom nebeskom.
\v 10 Čega god ti latile se ruke, čini koliko možeš, jer nema delovanja i rasuđivanja, znanja i mudrosti u Svetu mrtvih\f + \fr 9,10 \ft U izvornom tekstu \tl Šeol\tl*, ili \fqa podzemlje\ft , gde prebivaju duše umrlih.\f* u koji ideš.
\p 
\v 11 Razmišljao sam i video da pod kapom nebeskom:
\q1 brzi ne pobeđuje u trci
\q2 ni jaki u boju;
\q1 mudar ne dobija hleba
\q2 ni pametan bogatstvo;
\q2 najučenijem ne sleduje naklonost.
\q1 Svakog stignu i vreme i događaji.
\p 
\v 12 Čovek ne zna svoje vreme,
\q1 poput ribe uhvaćene u mrežu zla
\q2 i poput ptice uhvaćene u zamku.
\q1 Da, poput njih su zarobljeni ljudi,
\q2 u zao čas koji se na njih nenadano spušta.
\s1 Mudrost je bolja od ludosti
\p 
\v 13 Elem, pod kapom nebeskom video sam i ovu mudrost koja mi se učinila važnom:
\v 14 Mali grad, u njemu tek nešto žitelja, a veliki car ga napada, opkoljava i protiv njega diže velike nasipe.
\v 15 Tek, u gradu se našao siromašan, ali mudar čovek, koji je mudrošću spasao grad. Pa opet niko ne pamti tog siromaha.
\v 16 Zato sam rekao da je mudrost bolja od sile, ali mudrost siromaha je prezrena i njegove reči nisu poslušali.
\q1 
\v 17 Bolje se čuju tihe reči mudrih
\q2 od vladarevog povika među bezumnicima.
\q1 
\v 18 Mudrost je bolja od ratnog oružja,
\q2 a jedan grešnik može da upropasti mnogo dobrog.
\c 10
\q1 
\v 1 Od uginule muve se usmrdi i užegne apotekarsko ulje.
\q2 Tako je i malo gluposti teže od mnogo mudrosti i od mnogo časti.
\q1 
\v 2 Mudrom je srce s desne strane,
\q2 a bezumniku s leve strane.
\q1 
\v 3 Čak i kada putem ide,
\q2 luda je bez srca,
\q2 pa još kaže svima da je luda.
\q1 
\v 4 Ako se gnev vladarev na tebe podiže,
\q2 ne napuštaj svoje mesto,
\q2 jer smirenost utišava goleme grehe.
\b
\q1 
\v 5 Video sam da pod kapom nebeskom
\q2 postoji zlo nalik grehu koji dolazi od vladara:
\q1 
\v 6 Glupaci su ustoličeni na mnogim visokim mestima,
\q2 dok poštovani zauzimaju niže mesto.
\q1 
\v 7 Video sam sluge na konjima
\q2 i glavare što pešače kao roblje.
\b
\q1 
\v 8 Ko drugome jamu kopa sam u nju upada
\q2 i ko ruši zid uješće ga zmija.
\q1 
\v 9 Kamenje koje se kleše može da povredi klesara,
\q2 a drvo koje se teše može da ugrozi tesara.
\b
\q1 
\v 10 Ako je sekira tupa
\q2 i sečivo joj naoštreno nije,
\q1 čoveku golema snaga treba.
\q2 Znači, mudrost je korisna jer napredak daje.
\b
\q1 
\v 11 Slaba korist za bajača
\q2 pre bajanja ujede li zmija.
\b
\q1 
\v 12 Blažene su reči mudrog,
\q2 a bezumnog njegova usta izjedaju;
\q1 
\v 13 glupost je na početku njegovog govora,
\q2 a suludo zlo na njegovom svršetku.
\q1 
\v 14 Ludak silno brblja,
\q2 a čovek ne zna šta će da se zbude,
\q1 i ko će da mu kaže
\q2 šta dolazi nakon njega?
\b
\q1 
\v 15 Bezumnike trud zamara,
\q2 pa ne znaju ni u grad da uđu.
\b
\q1 
\v 16 Jao tebi, zemljo, s neodraslim carem
\q2 i sa glavarima što se od jutra goste!
\q1 
\v 17 Blažena si, zemljo, s carem plemenitog roda,
\q2 s glavarima što se goste kad je tome vreme,
\q2 ko junaci, a ne ko pijanci.
\b
\q1 
\v 18 Zbog lenjosti i krov se ugiba,
\q2 zbog nemarnih ruku prokišnjava kuća.
\b
\q1 
\v 19 Radi slavlja hleb se mesi,
\q2 vino život uveseljava,
\q2 a novac svemu rešenje pruža.
\b
\q1 
\v 20 Cara nemoj kleti u sebi,
\q2 a u odajama gde počivaš nemoj kleti bogataša;
\q1 jer će ptica nebeska odneti glas,
\q2 odaće stvar vlasnica krila.
\c 11
\s1 Odvaži se i deluj
\q1 
\v 1 Povrh voda hleb svoj baci
\q2 i naći ćeš ga posle dana mnogih.
\q1 
\v 2 Daj imetak sedmorici, pa i osmorici,
\q2 jer ne znaš hoće li zemlju da stigne zlo?
\b
\q1 
\v 3 Ako su oblaci puni kiše,
\q2 na zemlju se izručuju;
\q1 padne li drvo na jug ili na sever,
\q2 tamo gde padne, tamo i ostaje.
\q1 
\v 4 Ko u vetar gleda, odustaje od setve;
\q2 ko oblake prati, odustaje od žetve.
\b
\q1 
\v 5 Kao što ne znaš putanju vetra
\q2 ni kako nastaju kosti u utrobi trudnice,
\q1 tako i delo Boga
\q2 koji sve čini ne poznaješ.
\b
\q1 
\v 6 Od jutra sej seme
\q2 i do večeri ne sklapaj ruke svoje.
\q1 Jer ne znaš hoće li da uspe
\q2 jedno ili drugo,
\q2 ili će oboje ispasti dobro.
\s1 Sećaj se svog Stvoritelja dok si mlad
\q1 
\v 7 Slatko li je svetlo
\q2 i dobro li je kada oči u sunce gledaju.
\q1 
\v 8 Jer, ako čovek već i živi mnoge godine,
\q2 neka u svima njima radostan bude.
\q1 Ali neka se seti da će doći mnogi tmurni dani.
\q2 A prolazno je sve to što dolazi.
\b
\q1 
\v 9 O, mladiću, raduj se u mladosti svojoj!
\q2 Neka ti srce uživa dok si mlad,
\q1 sledi njegove želje
\q2 i htenja očiju svojih.
\q1 Ali znaj da će te zbog svega toga
\q2 Bog dovesti na sud.
\q1 
\v 10 Odbaci strepnju iz svog srca
\q2 i zlo od tela svoga odbaci,
\q2 jer su i mladost i crna kosa prolazni.
\c 12
\q1 
\v 1 Sećaj se Stvoritelja svoga
\q2 u danima mladosti svoje –
\q1 pre nego dođu dani zla
\q2 i pristignu godine za koje ćeš reći:
\q2 „Ne mile mi se“;
\q1 
\v 2 pre nego se zamrači sunce,
\q2 svetlo meseca i zvezda
\q2 i odu oblaci nakon kiše;
\q1 
\v 3 na dan kada se zaljuljaju čuvari kuće
\q2 i presamite se junaci,
\q1 kada stanu malobrojne drobilice
\q2 i zamagle se one što kroz prozore gledaju,
\q1 
\v 4 kada se zatvore ulična vrata
\q2 i utiša zveket mlinskog kamena,
\q1 kada se čovek diže s cvrkutom ptica
\q2 i prorede se pesme;
\q1 
\v 5 kada se čovek boji uzvišenja
\q2 i opasnosti na putu,
\q1 kada procveta badem
\q2 i skakavac se ulenji,
\q2 kada želja umine.
\q1 Jer čovek odlazi u svoju večnu kuću,
\q2 a na ulicu izlaze ožalošćeni.
\b
\q1 
\v 6 \add Sećaj ga se\add* pre nego pukne srebrno uže
\q2 i polomi se zlatna čaša,
\q1 pre nego pukne krčag na vrelu
\q2 i skrši se točak na bunaru.
\q1 
\v 7 Tada se prah zemlji vraća, gde je i bio,
\q2 a duh se vraća Bogu koji ga je dao.
\b
\q1 
\v 8 Prolaznost nad prolaznošću – vajka se propovednik –
\q2 Sve je prolazno!
\s1 Zaključak
\p 
\v 9 I ne samo da je propovednik bio mudar nego je i narod poučavao znanju. Pažljivo je proučavao mnoge priče da bi ih sastavio.
\v 10 Propovednik je tragao za prikladnim rečima, hteo je da tačno zapiše reči istine.
\p 
\v 11 Reči mudrih su poput ostana, poput čvrsto prikucanih eksera su sakupljači priča, što ih je dao jedan pastir.
\v 12 Čuvaj se, sine moj, preterivanja, jer nema kraja pisanju mnogih knjiga. A od silnog učenja i telo klone.
\q1 
\v 13 Zaključak svega što se čulo je:
\q2 Boga se boj
\q1 i njegove zapovesti drži.
\q2 To je sva čovekova \add dužnost\add*.
\q1 
\v 14 Elem, Bog će svako delo dovesti na sud,
\q2 svaku skrivenu stvar,
\q2 bilo dobro ili zlo.
