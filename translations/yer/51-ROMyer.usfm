\id ROM - Tarok 
\h Rom 
\toc3 ARom 
\toc2 ARom 
\toc1 Nlir nnap-nlà aBulus ônəm Inan oga ARom 
\mt2 Nlir nnap-nlà aBulus ônəm Inan oga 
\mt1 ARom 
\c 1  
\s1 Nre-anung 
\p  
\v 1 Awasika va̱ ta̱ fa ka̱ atak aBulus uzwal aYesu kəristi. Uzwal uwórwór va ma va̱n fa ka̱ ashe onəm ka̱kul inok nla nnap-nlà Inan ngga nchang nfe.  
\v 2 Nnap nlà ngga nchang nfe va Inan mor sar nnənap chit matmat ka̱ atak iya̱m va onəm oga *nka̱m nre ka̱tətak ka̱ là chit nzəng ka̱ nlilir ka̱ ashe nnap-nləla nnəna̱n a.  
\v 3 Nnap nlà va̱ ta̱ ka̱ apal ishi aYiyen uPonzhi yi uYesu Kəristi va mí là nnap amar ka̱ ashe izər te, uza̱ fa ka̱kum-jili aDawuda.  
\v 4 Mi i là nnap aRuhu jiwo te, ma nyám chit ka̱ ashe ichumchum pa̱ uza̱ uYa Inan. Ma nyám ka̱ mban ka̱ atak ngwon ka̱ na ka̱ atak ikú.  
\v 5 Ka̱ atak a wà kang mmayi ka̱ nfe nchang nnap nnəna̱n Inan ká̱ inok nre aKəristi, na ka̱kul aɗiɗin te, nkpaktak akum ìjili iga apambin oza̱ a na nnandər ká̱ Inan, oza̱ a nkpak nnap nnəm.  
\v 6 Nna o yà ka̱ ashe onəm owórwór aYesu kəristi kpa. 
\p  
\v 7 Ma lir awasika va̱ ta̱ na a ga atak nkpaktak onəm Inan oma̱nma̱n owórwór oga aRom. 
\p Re nrwa ìgwak, ka̱ nra-ìgwak aPoyi-Inan, ku uPonzhi yi uYesu Kəristi a təm nzəng ká̱ wo. 
\s1 UBulus ɗom nnap ngga aRom 
\p  
\v 8 Ngəshi te, mmami ka̱ nna aɗəngchi íNan mi ka̱kul wo pa̱ kpaktak ka̱ ashe aɗin aYesu kəristi. Ka̱kul ma fe nnap nna nnandər wo chit gang atak pa̱ lat ka̱ ashe apambin.  
\v 9 Inan va mmami ka̱ nnəm inunok iga nla nnap aYiyen ngga nchang nfe ká̱ ìgwak pa̱ izən te, uza̱ i yar anung mi yar pa̱ pa̱ ɗəkər te, mi pat ka̱ nrəng wo ka̱ ashe aduwa mi ka̱t.  
\v 10 Mmami ka̱ nchal pa̱ Inan ka̱ məma̱n te, nɗom nnap ngga atak wo va̱ m pak inok nɗuɗom chit te, nyangmata̱ te, ka̱ ri.  
\v 11 Ka̱kul aɗom nya wo nəm mi byet, na n kap nzəng ká̱ wo imwa ro iga aruhu va i nak wo o kam.  
\v 12 Nna pa̱ mmami ká̱ wo i kam owan yi ka̱ atak nna nnandər owan yi.  
\v 13 Ógənang, n ɗom wo pa̱ o nyi pa̱ nva̱n chit pa̱ nkyak m pak inok nɗa̱mshi izər iga mɓa atak wo. Ka̱ nna kpa te, na ma ma̱n á mi chit ka̱t. N ɗom nya wo na n ya ka̱ ashe wo kpa mmal apir iya̱m va̱ Inan ka̱ nnənəm awo inəna̱n wa nva̱ n ya ka̱ ashe onəm va̱ oYahudi ka̱t a.  
\v 14 Mmami ká̱ iɗək inok ka̱ apal ishi mi ka̱kul nkpaktak onəm, oHeleni ka̱ onəm va̱ oHeleni ka̱t, oga nnyi, ka̱ onəm va̱ yà ka̱ nnyi ka̱t pa̱ kpaktak.  
\v 15 Nna nak te, ngga atak wo lom mi byet, na n là nnap-nlà Inan ngga nchang nfe awo kpa. Mmawo va ka̱ aRom a. 
\s1 Ichumchum nnap-nlà Inan ngga nchang nfe 
\p  
\v 16 Nnap nlà Inan ngga nchang nfe iya̱m va pa̱ ń nəm ìwuswawuswa ka̱t. Ka̱kul nnà ichumchum Inan iga nka̱mshi irirì ánəm va pa̱ kpaktak nna nnandər ka̱. Nnap nlà ngga nchang nfe va̱ ta̱ mmá là óYahudi oma nggəshi. A le te mmá là ónəm va̱ oYahudi ka̱t.  
\v 17 Ka̱kul nnap-nlà ngga nchang nfe va̱ ta̱ nyám asa̱l aga ntong onəna̱n kà̱ mpyal Inan chit. Asa̱l va̱ ta aga nna nnandər. A ɓan ka̱ mɓəɓan a ga chu nkukur te, nna nnandər na chwat wa nva ma lir chit ka̱ ashe nnap-nlà Inan pa̱, <<Unəm va̱ unəna̱n ka̱ mpyal Inan ka̱ atak nna nnandər te, uza̱ i lár.>> 
\s1 Onəm pa̱ kpaktak pat nnap íNan chit 
\p  
\v 18 Mmən-ikum Inan ka̱ nvan ka̱paɓur ka̱ apal ishi nkpaktak nnap nnəm onəm ngga nyang ka̱ ngwa Inan ká̱ ina onəm oga nka̱r nnandər ka̱ atak nnəm ina oza̱.  
\v 19 Ka̱kul iya̱m va̱ ma̱t kà̱ nnyi ka̱ apal ishi Inan ka̱t te, a nyám óza̱ chit ka̱ mban ka̱kul Inan nyám óza̱ chit.  
\v 20 A ɓan ka̱ nfa ka̱ apambin te, nnap nnəm Inan va̱ mí ya ká̱ iwu ka̱t te, a sat nggafak ka̱ atak oza̱ ka̱t. Nnap-nnəm Inan va ichumchum chumchum iga n-yà ka̱ nkur ka̱t a. Nna kpa nnap va̱ kà̱ nnyam pa̱ uza̱ Inan a. Ichumchum ká̱ nnap va̱ ta ma ka̱ n-yiya pa̱ kpátkpát. Ka̱kul mí kpán ipipir kpán ka̱ atak iya̱m va̱ Inan nəm a. Ka̱kul nva̱ ta te, unəm yà ká̱ iya̱m ro pa̱ o là ka̱t.  
\v 21 Kap ka̱ nva̱ pa̱ oza̱ nyinyi pa̱ Inan yìyà te, oza̱ ka̱ nna ichumchum á na wa Inan ka̱t. Oza̱ i na aɗəngchi á na ka̱t kpa. Nrən-nnap oza̱ mmwan pa̱ kpaktak. Igwák oza̱ ipərək pərək fo chit kpa.  
\v 22 Oza̱ i là pa̱ mmawó onəm oga aghan. Oza̱ mpərək te, oza̱ nyi ka̱t.  
\v 23 Ichumchum va mà pa̱ oza̱ a na íNan va i ku ka̱t te, oza̱ na á na ka̱t. Ichə́r va ma nəm fa izər ku unəm va i kuku, ká̱ inyil, ká̱ izhé iga anyin, ká̱ iya̱m iga nkpán ka̱ afu te, oma oza̱ ka̱ nna ichumchum óza̱. 
\p  
\v 24 Nna nak te, Inan le ka̱ oza̱ chit re ka̱ nnəm iya̱m-lakchi va ɗom oza̱ ka̱ nnəm. Oza̱ ka̱ nnəm iya̱m iga ìwuswa ówan oza̱ va ɓyen ndər ka̱t.  
\v 25 Oza̱ ɗom akwam nna ji nnandər Inan. Oza̱ ka̱ ngwop iya̱m va Inan a nəm. Iya̱m va ta oza̱ ka̱ nnəm izwal óza̱ kpa. Inan va uwa nəm iya̱m va̱ ta te, uwa oza̱ yan ngwop ga nkachi. Uza̱ va aɗəngchi təm ajini chit mbyet mbyet a. Nna a təm. 
\p  
\v 26 Ka̱kul nva̱ ta te, Inan le ka̱ oza̱ chit re ka̱ nnəm iya̱m-lakchi iga nnəm-jan va ɗom oza̱ ka̱ nnəm. Ochar oza̱ le ka̱ nnap nnəm ichar swan ka̱ cho a tan təm ka̱ ashe apir nnap nnəm nggafak.  
\v 27 Wanta na kpa onunggwan oza̱ le ka̱ nnap nnəm va mà pa̱ a yà ká̱ ishimshe anunggwan ku uchar te, oza̱ swan ka̱ cho. Nɗom nnəm ilakchi ka̱ onunggwan owan oza̱ kà̱ nnak ishi i won oza̱. Onunggwan ka̱ nnəm iya̱m iga ìwuswa ónunggwan owan oza̱. Oza̱ ka̱ nsa̱m aya nnəm ilakchi oza̱ va̱ ta̱ ka̱ atak iya̱m va ka̱ nya oza̱ a. 
\p  
\v 28 Ka̱kul pa̱ oza̱ yan ka̱ mma̱n pa̱ oza̱ nyi Inan nyi te, Inan le ka̱ oza̱ chit re ka̱ nnəm iya̱m-lakchi. Pa̱ oza̱ a nnəm iya̱m iga ìwuswa.  
\v 29 Oza̱ ka̱ nnəm ina pa̱ gənggəng, ka̱ nɗul-afu, ka̱ aɗom, ka̱ nfar iya̱m-ina ówan onəm. Oza̱ onəm oga ìkpar, ka̱ oga nɗom ngba̱n onəm, ka̱ nɗom ikum, ka̱ ntan atak, ka̱ mɓa̱n ka̱fu nnàndər mɓa̱n. Inok oza̱ nnáp onəm,  
\v 30 ka̱ nvyap aɗin onəm, ka̱ nyang Inan, ka̱ nya amwap onəm, ka̱ nrup ká̱ ishi, ka̱ nyar-bal, ka̱ mmar iya̱m-ina, ka̱ nnyam nlan nnap nnəm ópo oza̱ ka̱ onan oza̱.  
\v 31 Igwak tul óza̱ ka̱ nnap ka̱t. Nnandər oza̱ yə́l awo ka̱t. Oza̱ yà ka̱ mma̱n ka̱t. Oza̱ yà ka̱ nrwa ìgwak ka̱t.  
\v 32 Oza̱ nyi iya̱m va̱ nyi Inan pak chit təm pa̱ unəm va pa̱ kpaktak ka̱ nnəm apir iya̱m va̱ ta̱ te, a mà pa̱ uza̱ a kuku a. ká̱ nnà te, oza̱ ka̱ nnəm nna pa̱ jak. Oza̱ ka̱ ngga mpyal ka̱ nnənəm na chwat ka̱t. Oza̱ ma̱n ka̱ nnəm apir iya̱m va̱ ta̱ ma̱n kpa. 
\c 2  
\s1 Inan gəl akwali wò pa̱ dakdak 
\p  
\v 1 Ka̱kul nva̱ ta te, ánəm, u yà ká̱ iya̱m ro va ɓu bol anung ɓu là ka̱t. Mmaɓu va kpaktak ka̱ nla úwan ɓu pa̱ uza̱ ká̱ mpat a. Ilum va kpaktak ɓu là úwan ɓu pa̱ uza̱ pat te, ya mmaɓu ka̱ nla íshi ɓu pa̱ mmaɓu ká̱ mpat na kpa. Ka̱kul iya̱m va kpaktak ɓu là úwan ɓu pa̱ uza̱ pat te, iya̱m-zəntən va ta mmaɓu ka̱ nnənəm.  
\v 2 I nyinyi pa̱ akwali va̱ Inan gəl ka̱ apal ishi onəm oga nnəm apir iya̱m va̱ ta te, a mà dakdak.  
\v 3 Ánəm, a yà pa̱ mmaɓu ka̱ nla úwan ɓu pa̱ uza̱ ká̱ mpat kan iya̱m-zəntən va ta kpa mmaɓu ka̱ nnənəm te, u rən pa̱ akwali Inan i re ɓu re jiɓu ɗò?  
\v 4 U yar nnyi-nnap Inan mmakmak, ka̱ mməma̱r ka̱ yi pa̱ fəm, ka̱ nka̱r-igugwak pa̱ amwan ɗakɓo? U nyi pa̱ Inan ka̱ nnyam nnyi-nnap aɓu na a dapchi nnap nnəm ɓu a ga atak wò na u ga̱ɓa̱n u re nnəm nnap-mɓá̱ngɓa̱ng ka̱t ɗò?  
\v 5 Te ka̱kul nkak ishi ɓu, ka̱ nva̱ pa̱ ìgwak ɓu ɗom nre nnəm nnap-mɓá̱ngɓa̱ng ka̱t te, mmaɓu ka̱ nram mmən-ikum Inan pa̱ a vang ka̱ apal ishi ɓu ká̱ ilum va̱ mí gəl akwali Inan amàmà ka̱ a.  
\v 6 <<Inan uwa í mwa nza̱ unəm nggo i mà dakdak ká̱ iya̱m va unəm ka̱ nəm a.>>  
\v 7 Onəm va̱ ka̱ nram ichumchum va Inan i na, ká̱ inəm va Inan i nak, ka̱ apir ntəm va ikú yà ka̱t, kan oza̱ i ram ka̱ atak nnəm iya̱m inəna̱n ka̱ nzhin te, Inan i mwa oza̱ ká̱ iriri iga mbyet mbyet.  
\v 8 Onəm oga nɗom ishi, ka̱ oga nyang nnandər, ka̱ oga ntəm ka̱ ashe nlan nnandər te, Inan i mwa oza̱ ka̱ mmən-ikum wò, ka̱ nnyam nfə́l-ìgwak.  
\v 9 Nkpaktak onəm oga nnəm ina te, mɓək anung, ká̱ izər-nrwa nnà ka̱kul oza̱. I yà ka̱kul oYahudi oma mpyal kan onəm va̱ oYahudi ka̱t.  
\v 10 Nkpaktak onəm oga nnəm iya̱m inəna̱n te, ichumchum va Inan i na, ká̱ inəm va Inan i nak, ka̱ nra-ìgwak te, nnà i yà ka̱kul oza̱. I yà ka̱kul oYahudi oma mpyal kan onəm va̱ oYahudi ka̱t.  
\v 11 Ka̱kul Inan i nyám nva̱n nro ka̱t. 
\p  
\v 12 Nkpaktak onəm va̱ nəm nnap-mɓá̱ngɓa̱ng oza̱ nyi iya̱m ro ka̱ apal ishi nnap-mpakpak aMusa ka̱t te, mí zhì oza̱ te, mí nap akwali mí wór aɗin nnap-mpakpak aMusa ro óza̱ ka̱ ka̱t. Nkpaktak onəm va̱ nəm nnap-mɓá̱ngɓa̱ng kap ka̱ nva̱ pa̱ ma na nnap-mpakpak aMusa na. Oza̱ te, mí gəl akwali óza̱ ka̱ nnap-mpakpak va ta.  
\v 13 Ka̱kul nfe nnap-mpakpak ka̱ achwang na chwat i nak Inan i yar unəm ka̱ mpyal wò pa̱ unəna̱n ka̱t. Onəm va ka̱ nkpak nnap-mpakpak te, oma chwat uza̱ i yar oza̱ ka̱ mpyal wò pa̱ onəna̱n.  
\v 14 A yà pa̱ onəm va̱ oYahudi ka̱t kan oza̱ ka̱ nnəm iya̱m va nnap-mpakpak aMusa là pa̱ ma nəm ka̱kul pa̱ oza̱ ya ɓiɓyen pa̱ ma nəm pa kap ka̱ nva̱ pa̱ nnap-mpakpak aMusa pa te, a yar oza̱ ka̱t te, ya oma yà ka̱ nnap-mpakpak na kpa.  
\v 15 Iya̱m va̱ oza̱ ka̱ nnənəm te, ka̱ nnyam pa̱ iya̱m va̱ nnap-mpakpak là pa̱ ma nəm te, nná lir təm ka̱ ashe igwák oza̱. Ìɗimɗim ìgwak oza̱ ka̱ nla nnap nzəngtən va ta óza̱ kpa pa̱ oza̱ nyi nnap-mpakpak nyi. Nrən-nnap oza̱ nnyi te, ka̱ nnyam ifan óza̱ pa̱ ɗəkər ɗəkər pa̱ oza̱ nyi nnap-mpakpak nyi. I yà pa ka̱t te, ya nrən-nnap oza̱ ka̱ nka̱m anung oza̱.  
\v 16 Ka̱lum va̱ ta te, Inan i gəl akwali ónəm pa̱ kpaktak ka̱ apal ishi nrən-nnap ngga igwák oza̱. Uza̱ i gəl ka̱ atak inok aYesu kəristi wa nva nnap-nlà Inan ngga nchang nfe va̱ mmami ka̱ nləla ka̱ nyinyam a. 
\s1 OYahudi ka̱ nnap-mpakpak 
\p  
\v 17 A yà pa̱ unəm là pa̱ mmawò uYahudi, o da̱r nkam wò ka̱ nnap-mpakpak aMusa nzəng ka̱ nnok ka̱kul apir ntəm va ká̱ ishimshe wò ká̱ Inan,  
\v 18 uza̱ nyi iya̱m va̱ nyi Inan ɗom, ma ɗyang iya̱m va̱ ɗyang á na nnap-mpakpak aMusa là, uza̱ nyi nva̱n ishimshe iya̱m va̱ ɓyen ji pa̱ kpaktak nyi, ká̱ iya̱m va̱ ɓyen ka̱t,  
\v 19 har uza̱ nyinyi nnandər pa̱ mmawò unəm uga ndap nkpá nggang ónəm-fofo, mmawò atak atántàn ónəm va̱ ka̱ ashe afa̱p,  
\v 20 mmawò unəm uga nɗyang iya̱m ónəm va̱ aghan yen oza̱ yen, unəm uga nɗyang iya̱m ónəm va ovanba̱k kà̱ nnap awop ka̱kul pa̱ mmawò ká̱ nnap-mpakpak, mmawò ka̱ nnyi va nnyi, pa̱ mmawò ka̱ nnandər kpa va nnandər te,  
\v 21 ánəm uga nɗyang iya̱m óro, ɓu ɗyang íshi ɓu ji ɓu ka̱t ɗò? Ánəm uga nla pa̱ kan ma nəm ayi ka̱t, ɓu nəm ayi jiɓu ka̱t ɗò?  
\v 22 Ánəm uga nla pa̱ kan ma ra ochar onəm ka̱t, ɓu ra uchar anəm jiɓu ka̱t ɗò? Ánəm uga njan ichə́r, ɓu nəm ayi ka̱ ashe nzhi ichə́r ka̱t ɗò?  
\v 23 Ánəm uga nnok ka̱ nnap-mpakpak aMusa, nva̱ ɓu gantal iya̱m va̱ nnap-mpakpak aMusa là te, mmaɓu ka̱ nna ìwuswa íNan ka̱t ɗò?  
\v 24 Nnap va̱ ta̱ mà dakdak ká̱ iya̱m va ma lir ka̱ ashe nnap-nlà Inan pa̱, <<Onəm va̱ oYahudi ka̱t te, oza̱ ka̱ nvyap aɗin Inan ka̱kul wo na.>> 
\p  
\v 25 Mpà ache i yà ka̱ nka̱mshi yà ka̱ atak anəm, a yà pa̱ uza̱ ka̱ nkpak iya̱m va̱ nnap-mpakpak aMusa là a. A ya nnyi pa̱ uza̱ ka̱ nggantal nnap-mpakpak va̱ ta te, ya mpà achəche nnap nlakchi.  
\v 26 A yà pa̱ unəm uga ache *amulur ka̱ nkpak iya̱m va̱ nnap-mpakpak aMusa là te, ya mí kun ishi ká̱ imulur va̱ ta pa̱ mpà ache ka̱t ɗò?  
\v 27 Unəm va̱ ka̱ akum oza̱ mí pà ache ka̱t, kan uza̱ ka̱ nkpak nnap-mpakpak va̱ ta pa̱ dakdak te, nnap-nnənəm nak akwali ri ɓu chit ka̱t ɗò? Nna a yà pa̱ mmaɓu va ká̱ nnap-mpakpak aMusa nlirlir kan akum wo i pà ache pà kan mmaɓu ka̱ nggantal iya̱m va̱ nnap-mpakpak va̱ ta là a.  
\v 28 Ka̱kul unəm va̱ uYahudi unandər te, uza̱ unəm va mí yà uYahudi ka̱ atak awa izər na pa mwan ka̱t. Mpà ache ngga nnandər te, mpà ache va ka̱ agbai ka̱wa izər ka̱t.  
\v 29 Unəm va uYahudi ka̱ ashe ìgwak te, uwa uYahudi unandər. Mpà ache aga nnandər te, nnap va ka̱ ashe ìgwak. Nnap va ngga aruhu a. Nnap va̱ ta mpakpak nlirlir ka̱t. Apir anəm va ta Inan i ɗəngchi na. Unəm uwa i ɗəngchi na ka̱t. 
\c 3  
\s1 Nnandər Inan yə́l awo yə́l 
\p  
\v 1 Unəm va̱ uYahudi te, uza̱ ji ká̱ iza̱ yà? Ka̱t te, mpà ache ka̱ nza̱ nka̱mshi yà?  
\v 2 Nna yà ka̱ nka̱mshi ka̱ ka̱ nza̱ asa̱l-awu nggo. Ngəshi te, oYahudi oma ma ma̱n ka̱ oza̱, ma nak iɗək nla nnap-nlà Inan ka̱ ashe awo oza̱.  
\v 3 A yà pa̱ oro ka̱ ashe oza̱ nəm avyal ka̱ nnap va̱ ta, nnandər oza̱ yə́l awo ka̱t te, a nyan chit san ɗa? Nlan nnandər oza̱ va̱ ta̱ i dan n-yə́l nsar nnap-nlà Inan ɗò?  
\v 4 Ko pa̱ ɗa̱p iya̱m ro yà pa ka̱t. Re ma nyi pa̱ Inan pa te, uza̱ unəm uga nnandər kap ka̱ nva̱ pa̱ nza̱ unəm nggo te, unəm uga akwam wa nva ma lir ka̱ ashe nnap-nlà Inan a. Nna pa̱, 
\q1 <<Na u bol anung wa là 
\q1 nnap te, a nyám pa̱ 
\q1 mmaɓu ka̱ nnandər. 
\q1 Ma nap akwali aɓu te, wa ri.>> 
\m  
\v 5 A yà pa̱ nnap nnəm yi nna nnà ka̱ nnak Inan i mma̱n ka̱ yi pa̱ mmayi onəna̱n ka̱ mpyal wò ì fa pa̱ jakjai te, iza̱ i là yà? A yà pa̱ Inan nyám ntan ayi te, pa̱ uza̱ nəm iya̱m-iɓá̱ngɓa̱ng ɗò? (Mmami ka̱ nnyam ìpir nnàp wa apir nja anəm.)  
\v 6 Ko pa̱ ɗa̱p iya̱m ro ya pa ka̱t. Ka̱kul ka̱ yà pa te, i yar sang kang Inan i nap akwali ápambin yà?  
\v 7 <<A yà pa̱ ka̱kul akwam mi kan nnandər Inan ka̱ nnyam ka̱ mban i ji mmatmat har a nak te ma ka̱ nna ichumchum á na ji mmatmat te, iza̱ nak kan nna ma ka̱ nnap-akwali á mi na pa̱ har ka̱kul pa̱ mmami unəm uga nnap-mɓá̱ngɓa̱ng yà?>>  
\v 8 Pa na te, iza̱ i dan pa̱ i pa ishi ka̱ nnəm iya̱m iɓá̱ngɓa̱ng na a sat ipir mɓa ká̱ iya̱m nənna̱n ayi yà? wantana oro ka̱ nvyap yi i là pa̱ iya̱m va ta mmayi ka̱ nləla. Akwali va̱ mí gəl âpir onəm va̱ ta aga nri oza̱ te, i mal dakdak. 
\s1 Unəm-nəna̱n yà ka̱t 
\p  
\v 9 Te san ɗa? Mmayi oYahudi i ji aɓo onəm ji ɗò? Ko pa̱ ɗa̱p. Ka̱kul ká̱ i là chit matmat pa̱ nkpaktak onəm, oYahudi ka̱ onəm va̱ oYahudi ka̱t te, i nak mpat óza̱ chit pa̱ nnap-mɓá̱ngɓa̱ng nna ka̱ nnəm ka̱ oza̱  
\v 10 wa nva ma lir ka̱ ashe nnap-nlà Inan pa̱, 
\q1 <<Unəm ro yà unəna̱n ka̱t. 
\q1 A yà ka̱ pa̱ uzəng ka̱t. 
\q1  
\v 11 Unəm ro yà uga nkpán ìpir nnàp ka̱t. 
\q1 Unəm ro yà uga nram Inan ka̱t. 
\q1  
\v 12 Oza̱ ga̱ɓa̱n chit pa̱ kpaktak nyan onəm-lakchi. 
\q1 Unəm ro yà ka̱ nnəm iya̱m-inəna̱n ka̱t. 
\q1 A yà ka̱ pa̱ uzəng ka̱t.>> 
\q1  
\v 13 <<Igósa̱l oza̱ wa awap atungtung. 
\q1 Inok aɓələm oza̱ te, nlam onəm na.>> 
\q1 <<Akal ìzwa ka̱sap anung oza̱.>> 
\q1  
\v 14 <<Atam oza̱ yə́l ká̱ mpwat mpwat, ká̱ nnap-nlà nɗulɗul.>> 
\q1  
\v 15 <<Oza̱ gha̱n ashar kà̱ ngga ngba̱l unəm byet. 
\q1  
\v 16 Atak va kpaktak oza̱ i wòl ka̱ te, nlak-atak nzəng ka̱ nlak-ìgwak i wa nva̱n oza̱. 
\q1  
\v 17 Iya̱m va̱ mí wór pa̱ mɓa ka̱ ntəm-ikankan te, oza̱ nyi ka̱t pa̱ kpau.>> 
\q1  
\v 18 <<Nra ayə̀r Inan yà ka̱ ashe ntəm oza̱ ka̱ pa̱ ɗa̱pfinyan ka̱t.>> 
\p  
\v 19 I nyinyi pa̱ iya̱m va pa̱ kpaktak nnap-mpakpak là te, ka̱kul onəm va ka̱ akum ichumchum chumchum ná kan unəm ro a yà ka̱ anung aga nla iya̱m ro ka̱t. Ná apambin pa̱ kpaktak a nyi kpa pa̱ akwali Inan nna yà ka̱kul oza̱.  
\v 20 Unəm ro yà va Inan i là pa̱ uza̱ unəna̱n ka̱ mpyal wò ka̱kul pa̱ uza̱ kpak nnap-mpakpak ɓyen pari ka̱t. Ka̱kul ka̱ atak iya̱m va nnap-mpakpak kà̱ nla te, i nyi pa̱ mmayi ka̱ nnəm nnap-mɓá̱ngɓa̱ng. 
\s1 Nnap-nnəm nnəna̱n i ɓa ka̱ atak nna nnandər 
\p  
\v 21 N-yanmata̱ jiwo te, ma nyám asa̱l aga ntong onəna̱n ka̱ mpyal Inan chit va yar nnap nkpak nnap-mpakpak ka̱t a. Atakarda nnap-mpakpak Inan ka̱ aga nnap-nlà onəm oga *nka̱m nre ka̱tətak oza̱ nyám nnap chit ka̱ apal ishishi.  
\v 22 Ntong onəna̱n ka̱ mpyal Inan va ka̱ atak nna nnandər ku uYesu Kəristi te, ka̱kul nkpaktak onəm oga nna nnandər, nva̱n ro yà ka̱ ka̱t.  
\v 23 Ká̱kúl nkpaktak onəm nəm nnap-mɓá̱ngɓa̱ng chit. Onəm pa̱ kpaktak ka̱ uro ya chu nya ichumchum Inan ka̱t kpa.  
\v 24 Ma tong onəna̱n chit ka̱ mpyal Inan ka̱ atak nka̱m ishi yi va uYesu Kəristi ka̱m, ka̱kul nnap-nəna̱n Inan mmakmak.  
\v 25 Inan yichi uYesu Kəristi sat iya̱m iga mpà ka̱kul mmwa akat aga nyar nnap-mɓá̱ngɓa̱ng. N-yar nnap-mɓá̱ngɓa̱ng va̱ ta̱ pa te, mí ya ka̱ atak nna nnandər ká̱ ikuku. Inan nəm pa na o nyám nnəm nnap wò va yà ka̱ á na ka̱t a. Ka̱kul matmat te, ka̱kul nka̱r-ìgwak na te, uza̱ yar iwu dər nnap-mɓá̱ngɓa̱ng va̱ ma nəm ka̱t.  
\v 26 Inan nəm pa na a nyám ónəm oga ashe nra va̱ ta̱ nnəm-nnap wò va yà ka̱ á na ka̱t a. Na a nyám ka̱ mban pa̱ uza̱ wat te, i nəm iya̱m ka̱səsa̱l. Pa̱ uwa i là únəm uga nna nnandər ku uYesu pa̱ uza̱ unəna̱n ka̱ mpyal Inan. 
\p  
\v 27 Te nnok yi yar ka̱ san nnyi ɗa? Ko pa̱ ɗa̱p ma gəl chit ma re ka̱ cho. Ma gəl ma re ka̱ cho ka̱ nza̱ asa̱l yà? Ma gəl ma re ka̱ cho ka̱kul mɓyen inok yi ɗò? O'o, ma gəl ma re ka̱ cho ka̱ atak nnap nna nnandər na ka̱ nkukwa.  
\v 28 Ka̱kul mmayi ka̱ anung nla pa̱ har pa̱ ka̱ atak nna nnandər na chwat kan Inan i là únəm pa̱ uza̱ ta̱l unəna̱n chit ka̱ mpyal wò. A yar nnap nkpak iya̱m va nnap-mpakpak ka̱ nləla ka̱t.  
\v 29 Inan pa te, uza̱ Inan oYahudi na chwat ɗò? Onəm va̱ oYahudi ka̱t te, uza̱ Inan oza̱ jo oza̱ ka̱t ɗò? Akwam ka̱t, onəm va̱ oYahudi ka̱t te, uza̱ Inan oza̱ na kpa.  
\v 30 Ka̱kul Inan pa̱ izən. Uza̱ i là ónəm oga mpà ache pa̱ oza̱ tong onəna̱n chit ka̱ mpyal wò ka̱ atak nna nnandər va oza̱ na a. Uza̱ i là ónəm oga ache amulur pa̱ oza̱ tong onəna̱n chit ka̱ mpyal wò ka̱ atak nna nnandər na kpa.  
\v 31 A nyan chit pa̱ í nak nnap-mpakpak sat nnap iwali ka̱ atak nna nnandər va̱ chit ɗò? Ko pa̱ ɗa̱p iya̱m ro yà pa ka̱t. Mmayi ka̱ nkam nnap-mpakpak. 
\c 4  
\s1 Nɗyang-nnap ka̱ nnap nnəm aIbərahim 
\p  
\v 1 Iza̱ i là ka̱ apal ishi aIbərahim ukəka yi utəmbərən yà?  
\v 2 Ka̱kul ka̱ ya pa̱ uAbəraham ta̱l unəm-nəna̱n ka̱ mpyal Inan ka̱ atak mɓyen inunok na te, ya uwa ká̱ iya̱m va uza̱ i nok ka̱. Nnunok va̱ ta i yà ka̱ mpyal Inan jiwo ka̱t.  
\v 3 Iza̱ va̱ nnap-nlà Inan ka̱ là yà? Nnap nlà Inan là pa̱, <<UAbəraham na nnandər ká̱ Inan te, ma kun ishi á na ka̱ pa̱ nna nnap nnəm nnəna̱n ka̱ mpyal Inan.>> 
\p  
\v 4 Unəm uga nnəm inok va̱ mí mwa na mwa ka̱kukul te, mí wór amumwa pa̱ imwa ka̱t. Iya̱m va ta mal pa̱ uza̱ a ya.  
\v 5 Unəm va̱ nnyi ka̱ nnəm inok va ka̱kul amwa ka̱t, uza̱ na nnandər na chwat ká̱ Inan va i là únəm uga nnap-mɓá̱ngɓa̱ng pa̱ uza̱ ta̱l unəna̱n chit ka̱ mpyal wò te, mí kun ishi á na ka̱ nna nnandər nandər va̱ ta pa̱ nnap nnəm nnəna̱n ka̱ mpyal Inan.  
\v 6 UDauda ka̱ là nnap nzəngtən va ta̱ nva̱ uza̱ ka̱ là nnáp apir nnap nnəna̱n va ka̱ apal ishi anəm va̱ Inan i kun ishi ka̱ na pa̱ uza̱ ka̱ nnap nnəm nnəna̱n ka̱ mpyal wò ka̱kul mɓyen iya̱m ro va unəm va̱ ta nəm ka̱t a.  
\v 7 Uza̱ là pa̱, 
\q1 <<Nnap-nnəna̱n nna yà 
\q1 ka̱kul onəm va̱ ma yar 
\q1 mpat oza̱ óza̱ chit. 
\q1 Onəm va ma dərkən nnap-mɓá̱ngɓa̱ng oza̱ le óza̱ chit kpa a. 
\q1  
\v 8 Nnap-nnəna̱n təm chit ka̱kul anəm va̱ 
\q1 ka̱ pa̱ ɗa̱p uPonzhi-Inan 
\q1 i kun ishi á na ka̱ nnap-mɓá̱ngɓa̱ng ɓá̱ngɓa̱ng ka̱t a.>> 
\p  
\v 9 Nnap-nnəna̱n va̱ ta ka̱kul onəm oga mpà ache ka̱ nkukwa ɗò? Ka̱t te, a yar onəm oga ache amulur yar kpa? Iya̱m va̱ i pak inok nləla chit te, pa̱, <<Ma kun ishi úIbərahim ka̱ nna nnandər nandər pa̱ nnap nnəm nnəna̱n ka̱ mpyal Inan.>>  
\v 10 A yar sang kang ma kun ishi á na ka̱ yà? Ya kan ma pà ache á na ɗò? Ka̱t te, ka̱ nva̱n va uza̱ pà ache chit? Ko pa̱ ɗa̱p ka̱ nvəva̱ng ka̱t. Ya kan uza̱ i pà ache.  
\v 11 Mpà ache va̱ ma pà á na te, iya̱m iga nre adal aga nnyam nnap na pa mwan. Iya̱m va iga mɓam nnap pa̱ uza̱ ta̱l unəna̱n chit ka̱ mpyal Inan ka̱kul nna nnandər va uza̱ na ká̱ Inan ya uwa pà ache chit ka̱t a. A yà pá na uza̱ a ta̱l upo nkpaktak onəm oga nna nnandər, na ma kun ishi ka̱ oza̱ kpa pa̱ onəna̱n ka̱ mpyal Inan va nkpak pa̱ ma pà ache óza̱ kan ka̱t.  
\v 12 wantana kpa uza̱ a ta̱l upo onəm oga mpà ache va mpà ache na chwat oza̱ ka̱ ka̱t. Oza̱ ka̱ nyar nva̱n aPo yi uAbəraham ka̱ ashe nna nnandər va̱ uza̱ na, ya na ma pà ache á na chit ka̱t a. 
\s1 Mi i tong onəna̱n ka̱ atak nna nnandər 
\p  
\v 13 Nsar nnap-nlà va̱ ma sar úIbərahim ka̱ akum ìjili jili pa̱ uza̱ i wur akup ka̱ apambin te, ka̱kul pa̱ uza̱ kpak nnap-mpakpak nro ka̱t. Ka̱kul pa̱ uza̱ na nnandər na te, Inan yar na pa̱ uza̱ unəm-nəna̱n ka̱ mpyal wò.  
\v 14 Ka̱kul a yà pa̱ onəm va ka̱ nkpak nnap-mpakpak oma i wur akup te, ya nna nnandər sat nnap nlakchi chit kan nsar nnap-nlà Inan va̱ ta sat inəngnəng chit kpa.  
\v 15 Ka̱kul nnap-mpakpak i dap mmən-ikum Inan i ɓa únəm. Atak va̱ nnap-mpakpak ya ka̱ ka̱t te, mpat-nnap i yà ka̱t na kpa. 
\p  
\v 16 Ka̱kul nna te, nnap va̱ ta a yar nna nnandər na chwat, na a yà ka̱kul nnap nnəna̱n Inan. Na a nyám ńkpaktak akum ìjili aIbərahim pa̱ nsar nnap-nlà va̱ ta nnandər. A nyám ónəm oga nkpak nnap-mpakpak na chwat ka̱ ashe oza̱ ka̱t. A nyám ónəm oga nna nnandər apir nja aIbərahim kpa. Uwa upo yi pa̱ kpaktak  
\v 17 wa nva ma lir ka̱ ashe nnap-nlà Inan pa̱, <<N nak ɓu chit u ta̱l upo akum pa̱ kyák.>> Uwa Inan yar na pa̱ upo yi. Inan va uza̱ na nnandər ka̱ na. Inan va i na iriri ônəm okúkú. Uwa kpa i wór iya̱m va̱ ka̱ yà chit ka̱t ɓu là pa̱ nna yà a.  
\v 18 UAbəraham ka̱ gbák nva̱ pa̱ uza̱ a nak ìgwak pa̱ o ya uyen lap ka̱t. Ka̱ nna kpa te, uza̱ nak ìgwak ká̱ Inan ka̱ atak nna nnandər pa̱ o ga nta̱l upo akum pa̱ kyak wa nva ma là á na pa̱, <<Akum ijili ɓu i yà pa̱ kyak.>>  
\v 19 Nna-nnandər nandər vang ká̱ izər ka̱t. Uza̱ məma̱n pa̱ izər wò ɗongɗong ká̱ ikuku ka̱t, ka̱kul pa̱ uza̱ dat chit ká̱ izun igba̱l. Nva̱ pa̱ uchəchar uSaratu watar chit nva̱ pa̱ uza̱ a mar te, a ɗak na ka̱t.  
\v 20 N-yen ka̱ ashe nna nnandər ro ya ka̱ ashishe nva̱ pa̱ a nak na a là pa̱ nsar nnap-nlà Inan va̱ ta akwam ka̱t. Ka̱ɗor nva̱ ta te, nna nnandər nandər a kam məma̱t. Uza̱ na ichumchum íNan.  
\v 21 Uza̱ nyinyi ka̱ ashe ìgwak wò pa̱ Inan uwa yà ká̱ ichumchum iga nnəm iya̱m va̱ uza̱ nsar nnap-nləla.  
\v 22 Nna nak te, <<Ma kun ishi á na ka̱ nna nnandər nandər va̱ ta pa̱ nnap nnəm nnəna̱n ka̱ mpyal Inan.>>  
\v 23 Nnap nlà va̱ pa̱, <<Ma kung ishi á na ka̱.>> Te, ma lir ka̱kul a wà ka̱ nkukwa ka̱t.  
\v 24 Ma lir ka̱kul yi kpa. Mmayi va i na nnandər na ká̱ Inan va wong ka̱ uPonzhi yi uYesu ka̱ atak ikú a.  
\v 25 Uwa ma re ma gba̱l na ka̱kul nnap-mɓá̱ngɓa̱ng yi. Ma won ka̱ na ka̱ atak ikú na ma là pa̱ i tong onəna̱n chit ka̱ mpyal Inan. 
\c 5  
\s1 Nra-ìgwak ka̱ atak Inan 
\p  
\v 1 A ya chit pa̱ ma nak yi chit i tong onəna̱n ka̱ mpyal Inan ka̱ atak nna nnandər te, ya ntəm-ikankan yà chit ká̱ ishimshe yi ká̱ Inan ka̱kul aPonzhi-Yesu Kəristi. 
\p  
\v 2 Ka̱ atətak na i ya asa̱l aga ntar ka̱ ashe nnap nnəna̱n va̱ mmayi ka̱ ashishe ǹyangmata̱ ka̱kul nna nnandər yi a. Mmayi ka̱ nlan ka̱ nnak-ìgwak yi kpa pa̱ i ya atak nsat nchumchum Inan ya.  
\v 3 Nna ta chwat ka̱t. Mmayi ka̱ nlan ka̱ mɓək anung yi kpa. Ka̱kul i nyinyi pa̱ mɓək anung i ɓa ka̱ nka̱r-ìgwak.  
\v 4 Nka̱r-ìgwak nnyi te, i nak unəm i yà ka̱ nnap nnəm. Nnap-nnəm i ɓa ka̱ nnak-ìgwak ká̱ iya̱m.  
\v 5 Nnak-ìgwak yi nnyi te, i na ìwuswa ayi ka̱t. Ka̱kul Inan zuk mma̱n wò ayi chit ka̱ ashe ìgwak yi ka̱ atak inok aRuhu-Nəna̱n va uza̱ na yi chit a. 
\p  
\v 6 Nna ká̱ i kam chit ka̱t te, uKəristi ku kulum va mal pa̱ dakdak ka̱kul onəm oga nyang ngwa Inan.  
\v 7 A kam byet nva̱ pa̱ ma ya unəm a ma̱n a ku ka̱kul anəm uga nnap nnəm nnəna̱n. Mo te, ka̱kul anəm-nəna̱n pa̱ chak te, ìgwak i kam na kam uza̱ i ma̱n i ku ká̱ pá.  
\v 8 Ka̱ nna kpa te, Inan nyám mma̱n wò a yi ka̱ asa̱l va ta̱. Nna ká̱ yà onəm oga nnap mɓá̱ngɓa̱ng te, uKəristi kú ka̱kul yi.  
\v 9 N-yanmata̱ a ya chit pa̱ i tong onəna̱n chit ka̱ mpyal Inan ka̱ atak ikuku te, ya ka̱ atak a wà í ya nka̱mshi pa̱ makmak, mmən ikum Inan i yar yi ka̱t.  
\v 10 Nna ká̱ i yà onəm oga nyang Inan te, ma gwang inal ká̱ ishimshe yi ka̱ na ka̱ atak ikú aYiyen. Ka̱ nva̱ng ngwang inal va̱ ta te, nka̱mshi va̱ i ya, mmən ikum Inan i yar yi ka̱t, ka̱kul pa̱ uza̱ uriri te, ya i mak i jiji pa̱ gənggəng.  
\v 11 Nna ta chwat ka̱t. Mmayi ka̱ nlan ká̱ Inan ka̱ atak aPonzhi yi uYesu Kəristi va ka̱tətak na kang i ya ngwang inal ká̱ Inan ǹyangmata̱ a. 
\s1 Ikú ɓa ka̱ atak Adamu iriri i ɓa ka̱ atak aKəristi 
\p  
\v 12 Te wa nva nnap mɓá̱ngɓa̱ng tar ashe apambin ka̱kul anəm pa̱ uzəng kang ikú ɓa ka̱ atak nnap mɓá̱ngɓa̱ng te, ka̱ asa̱l va ta ikú ya onəm pa̱ kpaktak. Ka̱kul ma nəm nnap mɓá̱ngɓa̱ng chit pa̱ kpaktak.  
\v 13 Kan mí pak nnap mpakpak te, nnap mɓá̱ngɓa̱ng yà chit ka̱ ashe apambin. ká̱ nnà te, ka̱ ya pa̱ nnap-mpakpak yà ka̱t te, ma ká̱ i kun ishi ka̱ nnap-mɓá̱ngɓa̱ng ka̱t.  
\v 14 Ka̱ nna kpa te, a ɓan ku uAdamu ɓa chu nra aMusa te, ikú nəm ichumchum ka̱ apal ishi onəm har ka̱ onəm va gantal iya̱m va̱ nnap-mpakpak là, wa nja Adamu ka̱t a. Uza̱ va sat wa iya̱m iga nnyam apir anəm va̱ ka̱ ngwon nvan a. 
\p  
\v 15 Imwa Inan jiwo te, wa nggantal nnap va ta ka̱t. Ka̱kul a yà pa̱ onəm pa̱ makmak ku ka̱kul pa̱ unəm pa̱ uzəng a gantal nnap-mpakpak te, nnap nnəna̱n Inan ká̱ imumwa va ɓa ka̱kul nnap nnəm anəm pa̱ uzəng uYesu Kəristi te, i zuk i mak pa̱ gənggəng ka̱kul onəm pa̱ kyak.  
\v 16 Kà̱ɗi te, imwa va̱ ta te, ka̱ pa̱ ɗa̱p iya̱m va nnap-mɓá̱ngɓa̱ng anəm uga uzəng va̱ ta ɓa ka̱ ka̱t. Ka̱kul akwali va̱ ma gəl ka̱ nva̱n nnap-mɓá̱ngɓa̱ng anəm uga uzəng va̱ ta te, a ɓa ka̱ nnak akwali ri unəm. Imwa va̱ nnyi ɓa ka̱ nva̱n nggantal nnap-mpakpak nva̱n pa̱ nkyak te, a ɓa ka̱ nnak mí tong onəna̱n ka̱ mpyal Inan.  
\v 17 Ka̱kul a yà pa̱ ka̱ atak nggantal nnap mpakpak anəm uga uzəng va̱ ta kang ikú ka̱ nnəm ichumchum ka̱ unəm ka̱ atak anəm uga uzəng va̱ ta te, onəm va̱ nnyi ka̱m nnap nnəna̱n Inan va mak pa̱ gənggəng ká̱ imwa va ntong onəna̱n ka̱ mpyal Inan te, oza̱ i nəm ichumchum i ji nva̱ ta ji pa̱ makmak ka̱ atak ntəm ká̱ irirì anəm uzəngtəng va̱ ta̱ va uYesu Kəristi a. 
\p  
\v 18 Te wa nva nggantal nnap-mpakpak anəm uga uzəng va̱ ta a ɓa ka̱ akwali ikú ónəm pa̱ kpaktak te, wa nnà ta kpa nnap nnəm nnəna̱n anəm uzəntən va̱ ta, a ta̱l ńkpaktak onəm iya̱m va nak ma tong onəna̱n ka̱ mpyal Inan, ma ya iriri a.  
\v 19 Wa nva onəm pa̱ makmak tong oga nnəm nnap-mɓá̱ngɓa̱ng ka̱ atak nlan nkpak nnap nnəm anəm uga uzəng va̱ ta te, wa nnà ta kpa nkpak nnap nnəm anəm uzəntən va̱ ta i nak onəm pa̱ kyak i tong onəna̱n ka̱ mpyal Inan. 
\p  
\v 20 Ma pak nnap-mpakpak na a jwak nggantal gantal. ká̱ nnà te, atak va̱ nnap-mɓá̱ngɓa̱ng ka̱ mmak ka̱ te, nnap nnəna̱n Inan i mak pa̱ gənggəng.  
\v 21 Ná wa nva nnap-mɓá̱ngɓa̱ng ka̱ nnəm ichumchum ka̱ apal ishi anəm ka̱ atak ikú te, wa nnà ta kpa nnap nnəna̱n Inan ka̱ nnəm ichumchum ka̱ apal ishi anəm ka̱ atak ntong onəna̱n ka̱ mpyal Inan va i ɓa ká̱ iriri iga mbyet mbyet ayi ka̱ atak áYesu kəristi uPonzhi yi a. 
\c 6  
\s1 Nnap-mɓá̱ngɓa̱ng ɓa ká̱ ikú, uYesu te, a ɓa ká̱ iriri 
\p  
\v 1 Te iza̱ i là yà? I ga mpyal ka̱ nnəm nnap-mɓá̱ngɓa̱ng na a ɓa ka̱ mmak nnap nnəna̱n ɗò?  
\v 2 Ko pa̱ ɗa̱p iya̱m ro ya pa ka̱t. Mmayi va i gba̱l ka̱ nnap-mɓá̱ngɓa̱ng chit i re te, í le sang kang í təm ka̱ ashishe na pa̱ har yà?  
\v 3 Ka̱t te, o nyi ka̱t ɗò? Nna pa̱ nkpaktak yi va̱ ma nəm abaptisima ayi chit va gwang yi ku uYesu Kəristi te, abaptisima va̱ ta a nyám chit pa̱ i ku chit kpa nzəng ka̱ na a?  
\v 4 Ka̱kul nva̱ ta te, ya ma li yi chit kpa nzəng ka̱ na ka̱ atak nnəm abaptisima ka̱ ashe ikuku. Ka̱kul wa nva ma wong ka̱ uKəristi ka̱ atak ikú ka̱ ashe ichumchum aPoyi Inan te, wa nnà ta kpa mma wong ka̱ yi chit ka̱ atak ikú na i təm ntəm mpipe. 
\p  
\v 5 A yà chit pa̱ i nyan iya̱m-zəntən chit ka̱ na ka̱ atak iya̱m va̱ ikuku nyám te, ya i yà iya̱m-zəntən ka̱ na chit kpa ka̱ atak ngwuwon ka̱ atak ikú.  
\v 6 Í nyinyi pa̱ ma pak nnap nnəm yi mmatmat chit ka̱ apal akun ikú nzəng ka̱ na, na a nak nnap mɓá̱ngɓa̱ng va̱ ka̱ ashe yi te, a yà ká̱ ichumchum ro lap ka̱t. Ná kang i tong ozwal nnap mɓá̱ngɓa̱ng lap ka̱t.  
\v 7 Ka̱kul unəm va pa̱ kpaktak ku chit te, ma jul na chit ka̱ nnap-mɓá̱ngɓa̱ng. 
\p  
\v 8 A yà pa̱ i ku nzəng ku uKəristi chit te, i na nnandər na pa̱ í lár nzəng ka̱ na na kpa.  
\v 9 I nyinyi pa̱ ma won ku uKəristi chit ka̱ atak ikú. Ka̱kul nva̱ ta te, uza̱ i ku lap ka̱t. Ikú yà ká̱ ichumchum ro lap ka̱ apal ishishi ka̱t.  
\v 10 Ikú va̱ uza̱ ka̱ ku te, uza̱ ku ikú nnap-mɓá̱ngɓa̱ng nva̱n pa̱ nzəng na byet ka̱kul onəm pa̱ kpaktak. Nwuwon ka̱ atak ikú nnyi te, uza̱ won na uza̱ a təm ka̱kul Inan.  
\v 11 Wantana kpa re o yar ishi wo pa̱ o kú ikú nnap mɓá̱ngɓa̱ng chit. Te mmawó ka̱ ntəm ká̱ irirì Înan ka̱ ashe aYesu Kəristi. 
\p  
\v 12 Ka̱kul nva̱ ta te, kan o ma̱n o re nnap-mɓá̱ngɓa̱ng a nəm ichumchum ká̱ izər wo va i ku ka̱t. Ichumchum chumchum va i nak wo ka̱ nnəm iya̱m-lakchi va izər ɗom a.  
\v 13 Kan o yichi oga mɓan-izər wo kà̱ɗi a sat iya̱m-inok ina iga nnəm nnap-mɓá̱ngɓa̱ng ka̱t. Re o yichi ishi wo íNan wa onəm va ma nak oza̱ chit lár ka̱ nva̱n ngwon ka̱ atak ikú a. O yichi nza̱ mɓan-izər wo nggo íNan a sat iya̱m-inok inəna̱n.  
\v 14 Ka̱kul nnap-mɓá̱ngɓa̱ng i yà ka̱ nnəm ichumchum ka̱ apal ishi wo ka̱t. Ka̱kul mmawó onəm va nnap-mpakpak ka̱ nnəm ichumchum ka̱ apal ishi wo ka̱t. Nnap-nnəna̱n Inan nna ka̱ nnəm ichumchum ká̱ wo. 
\s1 Ozwal nnap nnəm nnəna̱n Inan 
\p  
\v 15 Chit te, san ɗa? I nəm nnap-mɓá̱ngɓa̱ng pa̱ shat ka̱kul pa̱ nnap-mpakpak nna ka̱ nnəm ka̱ yi ka̱t, pa̱ nnap nnəna̱n Inan nna ka̱ nnəm ka̱ yi ɗò? Ko pa̱ ɗa̱p iya̱m ro ya pa ka̱t.  
\v 16 O nyi ka̱t ɗò? Nna pa̱ a yà pa̱ o pá ishi únəm ro na o kpak nnap nnəm á na wa ozwal te, ya o tong ozuzwal chit na nna̱n a? O yà ozwal nnap-mɓá̱ngɓa̱ng va nkùkùr ikú, ka̱t te o yà ozwal oga nkpak nnap nnəm va nkùkùr ntong onəna̱n ka̱ mpyal Inan a.  
\v 17 Aɗəngchi təm aji Inan chit. Ka̱kul kap ka̱ nva̱ pa̱ ka̱ o ya ozwal nnap-mɓá̱ngɓa̱ng te, nyangmata̱ te, mmawó ka̱ nkpak nnap nnəm ká̱ ìgwak pa̱ izən âpir nɗyang va̱ ma ka̱ ɗyang awo a.  
\v 18 Ma jul wo ká̱ izwal nnap-mɓá̱ngɓa̱ng te, o tong ozwal inok inəna̱n. 
\p  
\v 19 Mmami ka̱ nna ama̱n nnap-nlà awo ka̱sa̱l va unəm i là nnap ka̱kul igwák wo tul gba̱l ka̱t. Wa nva ka̱ o yichi oga mɓan-izər wo ká̱ izwal iga nnəm ilakchi ká̱ ina ka̱ apal ishi ina te, nyangmata̱ te, ó yichi oga mɓan-izər zəngtəng va̱ ta ka̱ nnəm izwal inok inəna̱n ka̱kul nnəm iya̱m va yà ka̱ adak ka̱t a.  
\v 20 Ko o yà ozwal nnap-mɓá̱ngɓa̱ng te, iya̱m ro ɗak wo ká̱ inok inəna̱n ka̱t.  
\v 21 Chit te, nza̱ apir nka̱mshi ka̱ o ya ka̱ atak nnəm pa yà? Iya̱m va nyangmata̱ te, oza̱ tong iya̱m iga ìwuswa chit ka̱ atak wo a? Akwam ka̱t, nkùr apir nnap nnəm va̱ ta ikú.  
\v 22 N-yanmata̱ nva̱ ma jul wo chit ká̱ izwal nnap-mɓá̱ngɓa̱ng o tong ozwal Inan te, iya̱m va̱ o ya iga nka̱mshi te, i nal wo. Apir nnap nnəm va̱ ta i ɓa ká̱ iriri iga mbyet mbyet.  
\v 23 Ka̱kul amwa nnəm nnap-mɓá̱ngɓa̱ng te, ikú. Imwa Inan jiwo te, iriri iga mbyet mbyet ka̱ ashe Yesu-Kəristi uPonzhi yi. 
\c 7  
\s1 Nnyam ipir-nnap ká̱ ivan 
\p  
\v 1 Ógənang o nyi ka̱t ɗò? Mmami ka̱ nla nnap ónəm va nyi nnap-mpakpak nyi a. Nna pa̱ nnap-mpakpak pa te, ká̱ ichumchum ka̱ apal ishi anəm a yà pa̱ uwa ya ká̱ iriri a.  
\v 2 Re i là wa aghan nnyam ìpir nnàp. Nnap mpakpak ka̱ apal ishi nnap ivan te, a yà pa̱ uchar vang chit te, ivan təm chit ká̱ ishimshe shimshe ku uɓəɓar har ikú anəm va̱ ta. A yà pa̱ unəm va̱ ta won ku re na te, ya ikú va̱ ta fən na chit ka̱ atak nnap-mpakpak ivan va̱ ta.  
\v 3 Nna nak te, a yà pa̱ uɓəɓar uwa ku chit ka̱t, kan uza̱ vang ku ununggwan ukak te, mí wór apir achar va̱ ta pa̱ uchar uga nram onunggwan. A yà pa̱ uɓəɓar ku chit te, ya ma fən na chit ka̱ atak nnap-mpakpak ivan oza̱. A yà pa̱ uza̱ ga vang ku ununggwan ukak te, mí wór na pa̱ uchar uga nram onunggwan jiwo ka̱t. 
\p  
\v 4 wantana kpa ká̱ wo ógənang. O ku ka̱ nnap-mpakpak chit na kpa ka̱ atak nku aKəristi, na unəm ro a nəm ichumchum ká̱ wo. Uza̱ va ma won ka̱ na ka̱ atak ikú a. Na i mar ishi íNan.  
\v 5 Ka̱kul nva̱ ká̱ i təm apir nja anəm te, aɗom nnəm ilakchi va̱ nnap-mpakpak i nak i won inok ka̱ ashe yi te, nna nəm inok ka̱ ashe oga mɓan-izər yi na i mar ishi va iga ikú.  
\v 6 N-yanmata̱ jiwo te, iya̱m va̱ ka̱ pa ikan ayi te, ka̱tətak te, i ku chit. Ma fən yi chit ka̱ atak nnap-mpakpak na i nəm izwal íNan ka̱sa̱l apipye aja aRuhu. Í nəm izwal íNan lap ka̱ asa̱l amatmat aga iya̱m lirlir va ma lir pa̱ ma kpak ka̱t. 
\s1 Mɓək anung ka̱ nnap-mɓá̱ngɓa̱ng 
\p  
\v 7 Te iza̱ i là ɗa? Nnap mpakpak iya̱m iɓa̱ɓa̱n ɗò? Ko pa̱ ɗa̱p iya̱m ro ya pa ka̱t. Ka̱kul ka̱ ya pa̱ nnap-mpakpak ya ka̱t te, ka̱ n nyi iya̱m va̱ mí wór pa̱ nnap-mɓá̱ngɓa̱ng ka̱t. Ka̱ ya pa̱ nnap-mpakpak là pa̱ kang wa gwáng iya̱m anəm ka̱t te, ka̱ n nyi iya̱m va̱ mí wór pa̱ ngwan iya̱m anəm ka̱t.  
\v 8 Nnap-mɓá̱ngɓa̱ng ya mbagar chit pa̱ ka̱ atak iya̱m va̱ nnap-mpakpak là te, a mar apir aɗom pa̱ ɗongɗong aga ngwan iya̱m onəm ka̱ ashe mi. Ka̱kul ka̱ ya pa̱ nnap-mpakpak yà ka̱t te, nnap-mɓá̱ngɓa̱ng ka̱ sat iya̱m-kuku.  
\v 9 Kà̱ yà n nyi nnap-mpakpak chit ka̱t te, kà̱ n yà uriri. N nyi iya̱m va̱ nnap-mpakpak là te, nnap-mɓá̱ngɓa̱ng yà nriri. Mmami nnyi te, n kú.  
\v 10 Iya̱m va̱ nnap-mpakpak là te, n ɗuɗom pa̱ ka̱ ɓa ká̱ iriri á mi. Ka̱ nna kpa te, a dap ikú ɓa á mi.  
\v 11 Ka̱kul pa̱ nnap-mɓá̱ngɓa̱ng yà mbagar ka̱ atak iya̱m va nnap-mpakpak là te, a tan mi har a nak mi n kú ka̱ atak iya̱m va nnap-mpakpak va̱ ta là a.  
\v 12 Ka̱kul nva̱ ta te, nnap-mpakpak pa te, nnəna̱n adak ro yà ka̱ ashishe ka̱t. Iya̱m va̱ nnap-mpakpak ka̱ nləla te, inəna̱n adak ro yà ka̱ ashishe ka̱t na kpa. Iya̱m inəna̱n va dakdak. A ɓyen pari. 
\p  
\v 13 Chit te, a nyan chit pa̱ iya̱m va inəna̱n te, nna nyan iya̱m iga mɓa ká̱ ikú á mi ɗò? O'o ka̱ pa̱ ɗa̱p iya̱m ro ya pa ka̱t. Nnap-mɓá̱ngɓa̱ng nna ɓa ká̱ ikú á mi na a nyám ishi wò pa̱ kpátkpát iya̱m va̱ uza̱ a. Nnap-mɓá̱ngɓa̱ng dapchi ikú ɓa á mi ka̱ atak iya̱m va inəna̱n. Ka̱ atak iya̱m va nnap-mpakpak ka̱ nləla te, nnap-mɓá̱ngɓa̱ng a nyám ishi wò chit pa̱ o ɓəɓa̱n na byet.  
\v 14 I nyinyi pa̱ nnap-mpakpak pa te, iya̱m va nnap ngga aruhu. Mmami jem te, mmami ka̱ ashe nnap nnəm nja anəm. Nnəm izwal ńnap-mɓá̱ngɓa̱ng na mmami ka̱ ashishe.  
\v 15 N kpán ipir iya̱m va̱ mmami ka̱ nnənəm ka̱t. Ka̱kul iya̱m va n ɗom te, nna mmami ka̱ nnənəm ka̱t. Iya̱m va̱ nnyi n ɗom ka̱t te, nna mmami ka̱ nnənəm.  
\v 16 Te a yà pa̱ mmami ka̱ nnəm iya̱m va n ɗom ka̱t te, ya m ma̱n chit pa̱ nnap-mpakpak pa te, iya̱m inəna̱n.  
\v 17 Te ya mmami na ka̱ nnəm iya̱m va̱ ta ka̱t. Nnap-mɓá̱ngɓa̱ng va təm ka̱ ashe mi te, nna i nəm.  
\v 18 Ka̱kul n nyinyi pa̱ iya̱m-inəna̱n ro yà ka̱ ashe mi ka̱t. Mmami ka̱ nla nnap ntəm mi ngga nnap nnəm ngga izər. Ka̱kul a ɗom mi ɗom ká̱ ìgwak pa̱ ń nəm iya̱m va dakdak. Ka̱ nna kpa te, n yà ká̱ ichumchum iga nnənəm ka̱t.  
\v 19 Iya̱m-inəna̱n va n ɗom pa̱ ń nəm te, nna mi nəm ka̱t. Iya̱m-iɓá̱ngɓa̱ng va ɗom mi ka̱ nnəm ka̱t te, nna mmami ka̱ nnənəm.  
\v 20 A ya chit pa̱ mmami ka̱ nnəm iya̱m va ɗom mi ka̱ nnəm ka̱t te, ya mmami na ka̱ nnənəm ka̱t. Nnap-mɓá̱ngɓa̱ng va təm ka̱ ashe mi te, nna ka̱ nnənəm. 
\p  
\v 21 A nak te, n nyi pa̱ nnap va ta̱ ka̱ nnəm inok ka̱ ashe mi. Nna pa̱ ilum va kpaktak mi ɗom nnəm iya̱m-inəna̱n te, mi ya ishi mi ka̱ nnəm iya̱m-iɓá̱ngɓa̱ng a.  
\v 22 Ka̱ ashe ìɗimɗim ìgwak mi te, nnap-mpakpak Inan nnà m ma̱n ka̱.  
\v 23 ká̱ nnà te, n nyinyi pa̱ nnap-nkak na yà ka̱ nnəm inok ka̱ ashe oga mɓan-izər mi. Nnap va ta ka̱ nlun mi ka̱ atak nrən-nnap va̱ mmami ka̱ nrərən. Nnap va̱ ta nak mi n ta̱l uzwal nnap-mɓá̱ngɓa̱ng va ka̱ nnəm inok ka̱ oga mɓan-izər mi.  
\v 24 Mmami unəm va n sat ka̱ nlak-ìgwak. Uda i ka̱mshi mi mi fa ka̱ ashe inok izər va i ga ka̱ mi ka̱ ashe ikú yà?  
\v 25 Aɗəngchi təm aji Inan chit, ka̱kul uYesu Kəristi uPonzhi yi ka̱mshi mi chit. Mmami ká̱ ishi mi ká̱ nrən-nnap mi te, nnap-mpakpak Inan ngga nnandər nna mmami ka̱ nnəm izwal á na. Ká̱ izər mi jiwo te, mmami ka̱ nnəm izwal ńnap-mɓá̱ngɓa̱ng. 
\c 8  
\s1 Ntəm ka̱ atak ichumchum aRuhu 
\p  
\v 1 Ka̱kul nva̱ ta te, nyangmata̱ te, akwali aga nri onəm ro yà ka̱kul onəm va̱ oja aYesu kəristi ka̱t.  
\v 2 Ka̱kul ka̱ atak inok aYesu kəristi te, iya̱m va̱ aRuhu ka̱ nləla pa̱ ma nəm iga mɓa ká̱ iriri te, a fən mi chit n fa ka̱ ashe iya̱m va̱ nnap-mɓá̱ngɓa̱ng ka̱ nləla pa̱ ma nəm iga mɓa ká̱ ikú a.  
\v 3 Iya̱m va̱ ma̱t nnap-mpakpak ka̱ nnəm ka̱kul pa̱ nnap nnəm yi nja anəm a kam chu nnənəm ka̱t te, Inan tul nnap-mɓá̱ngɓa̱ng chit, nva̱ uza̱ nre nre ku uyen wò ká̱ izər wa ijiyi iga nnap-mɓá̱ngɓa̱ng na uza̱ a dərkən nnap-mɓá̱ngɓa̱ng a le ka̱ cho.  
\v 4 Na iya̱m-inəna̱n va̱ nnap-mpakpak Inan là pa̱ ma nəm te, í kpak pa̱ kpaktak ka̱ iro a ɓur ka̱t. Mmayi va ka̱ ashe ntəm yi te, iya̱m va nnap nnəm ngga izər ka̱ nla pa̱ ma nəm te, nnà mmayi ka̱ nnənəm ka̱t. Í nəm ija aRuhu.  
\v 5 Onəm va̱ ka̱ ntəm apir ntəm ngga nnap nnəm ngga izər te, nnap nnəm oza̱ pa̱ kpaktak i ga ká̱ iya̱m va nnap nnəm va̱ ta ɗom. Onəm va̱ nnyi ka̱ ntəm apir ntəm ngga aRuhu te, nnap nnəm oza̱ pa̱ kpaktak i ga ká̱ iya̱m va aRuhu ɗom.  
\v 6 Nnak nnap nnəm pa̱ kpaktak i ga ká̱ iya̱m va nnap nnəm ngga izər te, nkukur ikú. Nnak nnap nnəm pa̱ kpaktak i ga kà̱ nnap aRuhu nnyi te, i ɓa ká̱ iriri iga mbyet mbyet, ka̱ nra-ìgwak.  
\v 7 Ka̱kul nnak nnap nnəm pa̱ kpaktak i ga ká̱ iya̱m va nnap nnəm ngga izər te, nva̱ ta ngwan inal ká̱ Inan ka̱t. I ya ka̱ nkpak nnap-mpakpak Inan ka̱t. Nnənəm i məma̱t.  
\v 8 Onəm oga ntəm apir ntəm nnap nnəm ngga izər te, Inan i fe nchang oza̱ ka̱ pa̱ ɗa̱p ka̱t. 
\p  
\v 9 Mmawo jiwo te, o təm apir ntəm nnap nnəm ngga izər na ka̱t. Mmawo onəm va ka̱ ntəm apir ntəm nja aRuhu, a yà pa̱ aRuhu Inan ka̱ ntəm ka̱ ashe igwák wo a. Unəm va kpaktak yà ka̱ aRuhu aKəristi ka̱t te, ya uza̱ uja aKəristi ka̱t.  
\v 10 A ya nnyi pa̱ uKəristi uwa yà ka̱ ashe igwák wo te, ya izər wo ku chit ka̱ nnap-mɓá̱ngɓa̱ng. Ka̱ nna kpa te, aruhu wo jiwo te, ariri ka̱kul o tong onəna̱n chit ka̱ mpyal Inan.  
\v 11 A yà pa̱ aRuhu Inan va̱ won ku uYesu ka̱ atak ikú ka̱ ntəm ka̱ ashe igwák wo te, ya uza̱ va̱ won ku uYesu Kəristi ka̱ atak ikú te, uza̱ i na iriri ízər wo na na kpa. Izər va i təm mbyet mbyet ka̱t a. Uza̱ i na ka̱ atak aRuhu Ruhu va ka̱ ntəm ka̱ ashe igwák wo a. 
\p  
\v 12 Ka̱kul nva̱ ta te, ógənang, o ya chit pa̱ i ya ka̱ akat nnap nnəm ngga izər ro ká̱ ishi yi na i təm ntətəm ka̱t.  
\v 13 A yà pa̱ o təm apir ntəm ngga nnap nnəm ngga izər te, ó ku. A ya nnyi pa̱ o ji nkam iya̱m va̱ nnap nnəm ngga izər i nəm ka̱ atak ichumchum aRuhu te, ó lár.  
\v 14 Onəm va pa̱ kpaktak aRuhu Inan ka̱ nkpak oza̱ te, oma ovan Inan.  
\v 15 ARuhu va̱ ka̱ o ka̱m te, aga nnak wo ka̱ nnəm izwal ayə̀r kà̱ɗi ka̱t. ARuhu va̱ ta aga nnak mí tong ovan omarmar. A nak te, mmayi ka̱ ngwór awór pa̱ shat pa̱, <<Ábba, uPon.>>  
\v 16 ARuhu ká̱ ishi wò nzəng ká̱ aruhu yi ka̱ nla a yi pa̱ nnandər mmayi ovan Inan.  
\v 17 A yà pa̱ mmayi ovan te, ya i tong ovan oga ngwur iya̱m akup chit kpa. Onəm oga ngwur iya̱m akup Inan va i wur nzəng ká̱ uKəristi a. Nna a yà pa̱ mmayi ka̱ mɓək anung nzəng ka̱ na a. Te í ya atak nsat nchumchum nzəng ka̱ na. 
\s1 Ichumchum iga nra ngga mɓa 
\p  
\v 18 Ka̱ atak nya mi te, mɓək anung va̱ ka̱ ashe nra va̱ ta̱ mmayi ka̱ nfe ka̱ te, mí mal ka̱ atak nsat nchumchum va̱ mí ga nnyinyam ka̱ ashe yi ka̱t.  
\v 19 Nkpaktak iya̱m va̱ Inan nəm te, oza̱ ka̱ nlok ka̱ nzhəng, ilum va̱ mí nyám ovan Inan ka̱ ka̱ mbang.  
\v 20 Nkpaktak iya̱m va̱ Inan nəm te, oza̱ ka̱ nswam pa̱ pitpit ka̱kul a yar aɓəɓan ôza̱ chit. Nva̱ ta nɗom oza̱ ka̱t, nɗom Inan va nəm iya̱m va̱ ta ka̱ nnak ìgwak pa̱  
\v 21 iya̱m va̱ ká̱ ishi wò uza̱ nəm oza̱ te, nna ga mí jul oza̱ ká̱ izwal mwan, na oza̱ a jul apir njul ngga nya atak nsat nchumchum nji ovan Inan.  
\v 22 I nyinyi pa̱ nkpaktak iya̱m va̱ Inan nəm te, ka̱ nɗum ká̱ izər arwa wa nɗum ka̱ nrwa amar ɓa chu nra va̱ ta̱.  
\v 23 Nna ta chwat ka̱t. Mmayi ká̱ ishi yi va̱ i ka̱m aRuhu-Nəna̱n va wa awar aga mmor nyal ka̱ ashe iya̱m va̱ í ga n-yiyá te, mmayi ka̱ nɗum kpa ka̱ ashe igwák yi nva̱ mmayi ka̱ nlok ka̱ nzhin, ilum va̱ mí wur yi i tong ovan omarmar a. Iya̱m va nka̱mshi izər yi va̱ ta̱ a.  
\v 24 Ma ka̱mshi yi i ya iriri te, mmayi ka̱ apir nnak-ìgwak va ta. Nnak-ìgwak kan unəm ya iyəya̱m ya ká̱ iwu te, ya a sat nnap nlakchi chit. Uda i təm ka̱ nnak ìgwak ka̱ apal ishi iya̱m va uza̱ ya chit yà?  
\v 25 A ya nnyi pa̱ mmayi ka̱ nnak ìgwak ka̱ iya̱m va i ya ká̱ iwu chit ka̱t te, ya í lok nya iya̱m va̱ ta nzəng ka̱ nka̱r ìgwak. 
\p  
\v 26 wantana kpa aRuhu ka̱ nka̱mshi yi ka̱ nnəm iya̱m va kpaktak nkam yi chu nnənəm ka̱t a. Ka̱kul i nyi iya̱m va̱ mà pa̱ i chál ka̱t. ARuhu nna ká̱ ishi wò te, uwa ka̱ nchal Inan ayi ka̱ aɗum va aɓələm kur nləla ka̱t a.  
\v 27 Uza̱ va kùr iya̱m va̱ ka̱ ashe igwák yi te, uza̱ nyi iya̱m va̱ nyi aRuhu ɗom nləla. Ka̱kul iya̱m va Inan ɗom te, nna aRuhu i chál ka̱kul onəm Inan. 
\s1 Mmayi onəm oga igwan va ipəpar ya ka̱t 
\p  
\v 28 I nyinyi pa̱ ka̱ ashe nza̱ iya̱m nggo te, Inan ì nak ì yà iga nka̱mshi ka̱ atak onəm va̱ ma̱n na ma̱n, onəm va ma wór oza̱ chit mà dakdak ká̱ iya̱m va uza̱ ɗom a.  
\v 29 Onəm va Inan yak chit matmat te, oma uza̱ nak chit təm pa̱ oza̱ i yar nnap nnəm aYen wò. Na uYen va ta a yà ugəshi ka̱ ashe ogənan wò pa̱ kyak.  
\v 30 Onəm va uza̱ nak chit təm pa̱ i yà ojiwò te, oma uza̱ wór. Onəm va uza̱ wór te, oma uza̱ là óza chit pa̱ oza̱ onəna̱n ka̱ mpyal wò. Onəm va uza̱ là óza̱ chit pa̱ oza̱ onəna̱n ka̱ mpyal wò te, oma uza̱ na atak nsat nchumchum óza̱ chit. 
\p  
\v 31 Te iza̱ i là ka̱ apal ishi nnap va̱ ta̱ yà? A yà pa̱ Inan ka̱ nlə́p asəm yi te, uda kur nlun yi yà?  
\v 32 Uza̱ va gor uyen wò ka̱t, uza̱ na na ká̱ ikú ka̱kul yi pa̱ kpaktak te, uza̱ i na nkpaktak aɓoshi iya̱m ayi kpa pa̱ makmak ka̱t ɗò? Nná iya̱m va uza̱ i na mɓa̱n-fu ro yà ka̱ ka̱t a?  
\v 33 Uda kur nla iya̱m-iɓá̱ngɓa̱ng ro ka̱ apal ishi onəm-yákyàk Inan yà? Unəm ro kur ka̱t. Ka̱kul Inan wa chwat i là pa̱ oza̱ tong onəna̱n chit ka̱ mpyal wò.  
\v 34 Chit te, uda kur nla pa̱ o gəl akwali i ri oza̱ yà? Unəm ro yà kur ka̱t. Ka̱kul uYesu Kəristi va̱ ka̱ ku ma won ka̱ na ka̱ atak ikú kan uwa təm ka̱wo ari Inan te, ka̱ nchal Inan ka̱kul yi.  
\v 35 Uda kur nkap yi ka̱ mma̱n aKəristi yà? Nɗaktak kukur ɗò? Mɓək anung ɗò? Nna idumdum ayi ɗò? Ayang ɗò? Nlang ìlukwan iga mpá ka̱ izər ɗò? Iya̱m iga nri nggom ɗò? Nlung yi ka̱ ndokchi ɗò? 
\p  
\v 36 Wa nva ma lir ka̱ ashe nnap-nlà Inan te, pa na. Nna pa̱, 
\q1 <<Ka̱kul nnap ɓu na ma ka̱ ngbá̱ng yi, alum i ga i tar pa̱ chit na ma ka̱ anunung. 
\q1 Ma yar yi i tong wa itám va mí ga mpə̀pà.>> 
\p  
\v 37 Ka̱ nna kpa te, ka̱ ashe iya̱m va̱ ta pa̱ kpaktak te, mmayi onəm oga igwan va ji nkam nla ji, ka̱ atak ichumchum anəm va̱ ta̱ uwa ka̱ mma̱n yi a.  
\v 38 N nyinyi pa̱ kpátkpát pa̱ iya̱m ro kur nkap yi ka̱ mma̱n aKəristi ka̱t. Ko ikú, ka̱t te iriri, ka̱t te oma̱leka oɓwakan ka̱ ochumchum, ka̱t te nnap ro ngga ashe nra va̱ ta̱, ka̱t te ngga ashe nra ngga mɓa, ka̱t te nza̱ apir ichumchum nggo, ka̱t te  
\v 39 iya̱m va ka̱ apal akúrkúr, ka̱t te ka̱ ashe ache agba̱ngba̱n, ka̱t te aɓoshi iya̱m va pa̱ kpaktak ma nənəm te, a kur nkap yi ka̱ mma̱n Inan ka̱t. Mma̱n va Inan ka̱ nnyinyam ayi ka̱ atak áYesu kəristi uPonzhi a. 
\c 9  
\s1 Inan yak onəm oga aIsa̱rila 
\p  
\v 1 Mmami ka̱ nla nnandər wa anəm va uja aKəristi. Mmami ka̱ nnap akwam ka̱t. Ìɗimɗim ìgwak mi ka̱ atak inok aRuhu-Nəna̱n ka̱ nnyam nnap pa̱  
\v 2 mmami ka̱ ashe nlak-ìgwak pa̱ makmak. Igwak mi ka̱ nfe ká̱ izər nrwa va i ka̱p ka̱t.  
\v 3 A ɓyen á mi pa̱ ma vyap mi, ma gəlchi mi ń le ká̱ izər aKəristi ka̱kul onal mi. Ogənan va í fa ka̱ akum azəngtəng ka̱ oza̱ a.  
\v 4 Oma oIsa̱rila. Nwur onəm, mí tong ovan Inan te, ka̱kul oza̱ ma. N-ya atak nsat nchumchum ngga apaɓur te, ka̱kul oza̱ ma. Oma ká̱ nsar nnap-nlà va̱. Oma kà̱ ka̱m nnap-mpakpak ka̱ atak Inan a. Oma ma nyám asa̱l awop aga ashe Nzhi Inan nchumchum óza̱. Oma kpa ka̱ aɓoshi nsar nnap-nlà.  
\v 5 Okəka omatmat va̱ te, ojo oza̱ ma. Mi i shal akum amar aKəristi ka̱pambin te, ka̱ akum oza̱ ma. Aɗəngchi təm aji Inan chit mbyet mbyet. Uwa ishi ka̱ apal ishi iya̱m pa̱ kpaktak. Nna a təm. 
\p  
\v 6 Iya̱m va̱ nnap-nlà Inan là te, nna ta chwat ka̱t. Ka̱kul nkpaktak onəm va̱ fa ka̱ akum aIsa̱rila te, oIsa̱rila oga nnandər ka̱t.  
\v 7 Ka̱kul pa̱ oza̱ fa ka̱ akum aIbərahim te, a nyan chit pa̱ nkpaktak oza̱ ovan aIbərahim ka̱t. Ma là pa̱, <<Ovan va uIshaku mar te, oma mí kun ishi úIbərahim ka̱ pa̱ nva̱n va uza̱ re.>> 
\p  
\v 8 Nna pa̱ ovan aIbərahim oga afu oma ovan Inan ka̱t. Ovan va Inan ka̱ sar nnap-nləla úIbərahim te, oma ma kun ishi ka̱ pa̱ nva̱n va uAbəraham re.  
\v 9 Ka̱sa̱l va̱ ta̱ ma là nnap nsar nnap-nlà va̱ ta. Pa̱, <<Azhen ka̱ atak wanta̱ te, mi ga nle mɓa. Te uSaratu i ga mmar uyen-nunggwan.>>  
\v 10 Iya̱m va ta chwat ka̱t. Ovan va̱ uRifkatu mar te, upo oza̱ pa̱ uzəng. Uwa ukəka yi uIshaku.  
\v 11 Kan mí mar ovanjen va̱ ta̱, oma nyi iya̱m inəna̱n ká̱ iɓá̱ngɓa̱ng chit ka̱t te, Inan là iya̱m va̱ i ga nfa únan oza̱. Na iya̱m va Inan ɗom ka̱ apal ishi ayàk wò te, nna a yà. Kan a yà ka̱kul nɗak ngga ishi anəm ka̱t. Awór va Inan wór te, nna a yà nnap chwat.  
\v 12 Ma mor ma là únan oza̱ pa̱, <<Unəmgbak i ga nta̱l uzwal aɓwakan.>>  
\v 13 Wa nva ma lir chit ka̱ ashe nnap-nlà Inan pa̱, <<UYakup uwa n yak. UIshuwa te, n yak na ka̱t.>> 
\p  
\v 14 Te iza̱ i là ɗa? Inan yà ka̱ nnandər ka̱t ɗò? Ko pa̱ ɗa̱p iya̱m ro ya pa ka̱t.  
\v 15 Ka̱kul uza̱ là úMusa pa̱, <<Unəm va pa̱ kpaktak n ɗom nnyam nrwa ìgwak á na te, uwa mi nyám á na. Unəm va pa̱ kpaktak n ɗom n nyám afu-rusok rusok á na te, uwa mi nyám á na.>>  
\v 16 Ya yà chit pa, a yar nnap iya̱m va unəm a ɗom, ka̱t te nɗak ngga ishi anəm ka̱t. Nnyam nrwa ìgwak Inan na chwat.  
\v 17 Ka̱kul ka̱ ashe nnap-nlà Inan te, ma lir pa̱ Inan là úFirauna pa̱, <<N nak ɓu u yà uponzhi ka̱kul inan iya̱m pa̱ izən. N ɗom pa̱ ń nyám ichumchum mi ka̱ apal ishi ɓu na ma nyi aɗin mi a gang atak ka̱ ashe apambin.>>  
\v 18 Nna pa̱ unəm va pa̱ kpaktak Inan ɗom nnyam nrwa ìgwak á na te, uza̱ i nyám. Unəm va̱ nnyi uza̱ ɗom ntwat anung igugwak te, uza̱ i nəm. 
\p  
\v 19 Ɗom te, uro ka̱ ashe wo i là pa̱, <<A ya chit wanta te, iza̱ nak kan Inan ka̱ nya mpat mi na pa̱ har yà? Uda kur nɗa̱t na ka̱ nnəm iya̱m va̱ uza̱ ɗom yà?>>  
\v 20 Ánəm u kur wa ada kan ɓu dap atam ká̱ Inan yà? Wi, iya̱m va ma mime te, a kur nla nnap únəm uga mme wò kur pa̱ sang kang u me mi wanta̱ ya ɗò?  
\v 21 Uchar uga mme ngbə́t yà ká̱ ichumchum iga nnuk ame na o kpán ame azəngtəng va̱ ta o me iyá̱m-inok pa̱ ɗongɗong ka̱ ka̱t ɗò? Uza̱ i ɗom te, uza̱ i me iya̱m iga nnəm inok ichumchum. Uza̱ i ɗom te, uza̱ i me ka̱ ame azəngtəng va̱ ta iya̱m-inok va ikyin ka̱t.  
\v 22 wantana ká̱ Inan kpa ka̱t ɗò? A yà pa̱ Inan ɗom nnyam mmən-ikum wò nzəng ka̱ nnak pa̱ ma nyi ichumchum wò kan uza̱ yak pa̱ o ka̱r ìgwak ka̱ nzhin ka̱ onəm va̱ mà pa̱ oza̱ a fe ka̱ mmən-ikum va̱ ta te, pa̱ uza̱ kur ka̱t a? Onəm va pa̱ ka̱ zhìzhì ɗò? Onəm va pa̱ uza̱ a zhì te, pa̱ uza̱ kur nka̱r ìgwak ka̱ oza̱ ka̱t a?  
\v 23 A ya nnyi pa̱ uza̱ ɗom pa̱ ma nyi apir mmak ichumchum wò va ji pa̱ kpaktak ónəm va uza̱ ka̱ nnyam nrwa ìgwak óza̱ te, pa̱ uza̱ kur ka̱t a?  
\v 24 Mmayi na uza̱ wór. Uza̱ wór oYahudi ma chwat ka̱t. Onəm va̱ oYahudi ka̱t te, uza̱ wór oza̱ wór na kpa  
\v 25 wa nva ma lir ka̱ ashe nnap-nləla va uHosiya lir pa̱, 
\q1 <<Onəm va̱ ka̱ yà onəm mi ka̱t te, mi wór oza̱ pa̱ onəm mi. 
\q1 Onəm va̱ ka̱ n yak oza̱ ka̱t te, mi yak oza̱.>> 
\m  
\v 26 Kà̱ɗi te, 
\q1 <<Ka̱ atak azəngtəng va ma là óza̱ pa̱, <Mmawo onəm Inan ka̱t> te, 
\q1 ka̱ atak va ta mí ga ngwór oza̱ pa̱ ovan Inan uga Iriri.>> 
\m  
\v 27 UIshaya là nnap-nlà pa̱ gbá̱ngbá̱n ka̱ apal ishi oIsa̱rila pa̱, 
\q1 <<Ko a yà pa̱ oIsa̱rila a yə́l ìjili a yà wa ashishiri ga anung iwa nggo te, onəm va̱ mí ka̱mshi oza̱ te, i yə́l awo ka̱t. 
\q1  
\v 28 Ka̱kul uPonzhi-Inan i ga nnəm óza̱ pa̱ kəlak kəlak iya̱m va uza̱ gəl akwali kwali ápambin chit a. 
\q1 Uza̱ i nəm uza̱ i re iya̱m ro i ɓur ka̱ ka̱t.>> 
\m  
\v 29 Nnap ta̱ dakdak wa nva uYeshayah là chit pa̱, 
\q1 <<Ká̱ ya pa̱ uPonzhi-Inan uga ichumchum gar aɓo onəm yi ka̱t te, ká̱ i yà lap ka̱t ká̱ inənan wa onəm oga itong aSədom ka̱ aGomorata.>> 
\s1 AIsa̱rila ka̱ nnap-nlà Inan ngga nchang nfe 
\p  
\v 30 Te iza̱ i là ɗa? Onəm va̱ oYahudi ka̱t, oza̱ ka̱ nram pa̱ o tong onəna̱n ka̱ mpyal Inan ka̱t te, oza̱ tong chit. Iya̱m va mí ya ka̱ atak nna nnandər a.  
\v 31 aIsa̱rila va ɗak ka̱ nram ntong onəna̱n ka̱ mpyal Inan te, oza̱ chu n-yiya ka̱t.  
\v 32 Iza̱ nak yà? A ma̱t oza̱ ka̱ nya ka̱kul pa̱ oza̱ ram ka̱ ashe nna nnandər ka̱t. Oza̱ ram na mí ya ka̱ atak nnəm iya̱m inəmnəm iga nɗak ngga ishi anəm. Te oza̱ ləp ifan ká̱ izər iya̱m iga nnak onəm i ləp ifan  
\v 33 wa nva ma lir ka̱ ashe nnap-nlà Inan pa̱, 
\q1 <<O dər, n li ipang chit iga nnak onəm i ləp ifan ka̱ ashe aZiyona. 
\q1 Ipang ichumchum va i nak oza̱ i tak. 
\q1 Unəm va pa̱ kpaktak da̱r nkam wò ká̱ izəzər te, mí na ìwuswa á na ka̱t.>> 
\c 10  
\p  
\v 1 Ógənang, iya̱m va̱ ɗom mi ká̱ ìgwak, ká̱ iya̱m va̱ mmami ka̱ nchal ka̱ atak Inan ka̱kul oIsa̱rila te, pa̱ oza̱ a ya nka̱mshi ngga iriri iga mbyet mbyet.  
\v 2 Mi nyám nnap nyám ka̱ apal ishi oza̱ pa̱ oza̱ zhin ka̱ ngwa Inan byet. Ka̱ nna kpa te, ngwa Inan oza̱ va̱ ta ka̱ ashe nfo.  
\v 3 Ka̱kul oza̱ nyi apir asa̱l aga ntong onəna̱n ka̱ mpyal Inan va̱ chit ka̱t na pa̱ har. A nak te, oza̱ təm ka̱ mpak asa̱l aga ntong onəm nəna̱n ajo oza̱. Oza̱ yan ka̱ asa̱l va̱ Inan pak.  
\v 4 UKəristi uwa nkùr nnap-mpakpak. Ná nza̱ unəm nggo va na nnandər na te, uza̱ a ta̱l unəna̱n ka̱ mpyal Inan. 
\p  
\v 5 Ka̱sa̱l va ta̱ uMusa ka̱ nyám apir ntong onəm nəna̱n ka̱ mpyal Inan va mí ya ka̱ atak nkpak nnap-mpakpak a. Uza̱ là pa̱, <<Unəm va̱ i nəm iya̱m va̱ ta̱ te, ka̱tətak na uza̱ i lár.>>  
\v 6 Ka̱ apal ntong onəm nəna̱n ka̱ mpyal Inan va̱ mí ya ka̱ atak nna nnandər jiwo te, uza̱ là pa̱, <<Kan unəm a là ka̱ ashe ìgwak wò pa̱ uda i kyen i ɓa i ga apaɓur ayi ya ka̱t?>> Nna pa̱ ma kyen ɓa ma vang ku uKəristi a.  
\v 7 Ka̱t te, pa̱, <<Uda i fər akum ka̱ ashe afu mbin ayi ya ka̱t?>> Nna pa̱ ma ga ma won ku uKəristi ka̱ atak ikú a.  
\v 8 Iza̱ nnap-nlà Inan là yà? Nnap nlà là pa̱, <<Nnap nlà na yà pa̱ datkulung ka̱ ɓu. Nnap nlà va̱ ta ka̱ɓələm ɓu. Nnap nlà va̱ ta ka̱ ashe ìgwak ɓu.>> Nnap nlà va̱ ta nna nnap nna nnandər va mmayi ka̱ nləla ónəm a.  
\v 9 Nna pa̱ a yà pa̱ unəm bol anung wò là pa̱, <<UYesu uwa uPonzhi.>> Kang uza̱ na nna nnandər na ka̱ ashe ìgwak wò pa̱ Inan wong ka̱ na chit ka̱ atak ikú te, ya uza̱ i ya nka̱mshi ngga iriri iga mbyet mbyet.  
\v 10 Ka̱kul ka̱ ashe ìgwak yà unəm i na nnandər kang Inan i là á na pa̱ uza̱ ta̱l unəna̱n chit ka̱ mpyal wò. Ka̱ atak mbol anung nla nnap te, uza̱ i ya nka̱mshi ngga iriri iga mbyet mbyet.  
\v 11 Ka̱kul nnap-nlà Inan ka̱ nla pa̱, 
\q1 <<Unəm va pa̱ kpaktak na nnandər ka̱ na te, mí na ìwuswa á na ka̱t.>> 
\m  
\v 12 Nnyam nva̱n ro yà ka̱ ashishe ka̱t, ká̱ ishimshe onəm va̱ oYahudi, ka̱ onəm va̱ oYahudi ka̱t. UPonzhi uzəntən uwa uPonzhi onəm pa̱ kpaktak. Uza̱ i nak nnap nnəna̱n pa̱ makmak ka̱ apal ishi nkpaktak onəm va̱ i wór ka̱ ashe aɗiɗin.  
\v 13 Ka̱kul nnap-nlà Inan là pa̱, 
\q1 <<Unəm va pa̱ kpaktak wór ka̱ ashe aɗin aPonzhi-Yesu te, uza̱ i ya nka̱mshi ngga iriri iga mbyet mbyet.>> 
\p  
\v 14 Chit te, i yar sang kang oza̱ i wór ka̱ ashe aɗin anəm va oza̱ na nnandər ka̱ na ka̱t yà? Nna-nnandər nggo te, i yar sang kang oza̱ i na nnandər ku unəm va̱ oma fe iya̱m ro chit ka̱ apal ishishi ka̱t yà? Nfe nnap nggo ka̱ apal ishi anəm te, i yar sang kang oza̱ i fe a yà pa̱ unəm ro là óza̱ ka̱t yà?  
\v 15 I yar sang kang unəm i là nnap ka̱ oza̱ a yà pa̱ ma re na re ka̱ atak oza̱ ka̱t yà? I ya wa nva ma lir ka̱ ashe nnap-nlà Inan pa̱, 
\q1 <<Mɓa onəm oga nra nggang ka̱ nnap-nlà ngga nchang nfe ka̱ atak te, a ɓyen pari.>> 
\m  
\v 16 Ka̱ nna kpa te, nkpaktak oIsa̱rila ma̱n ka̱ nnap-nlà ngga nchang nfe va̱ ta ka̱t. Ka̱kul uYeshayah ká̱ ishi wò te, uza̱ là pa̱, 
\q1 <<ÁPonzhi-Inan, nza̱ unəm pa̱ wat i na nnandər na ka̱ nnap-nlà yi yà?>> 
\m  
\v 17 Te ya nyám chit pa̱ unəm i na nnandər ka̱ atak nfe nnap-nlà Inan. Nnap nlà va̱ mí fe nnyi te, nnap-nlà aKəristi.  
\v 18 Te re m ɓəp ɗak pa̱ oma fe nnap-nlà va̱ ta chit ka̱t ɗò? Oza̱ fe chit. Ka̱kul nnap-nlà Inan là pa̱, 
\q1 <<Achu onəm oga nre mi gang apambin chit pa̱ lat. 
\q1 Nnap nlà va̱ fa ka̱ɓələm oza̱ te, a chu akum-ɓuɓur chit.>> 
\m  
\v 19 M ɓəp kà̱ɗi pa̱ oIsa̱rila pa te, oza̱ kpán ìpir nnàp nlà va̱ ta ka̱t ɗò? Ngəshi te, uMusa là pa̱, 
\q1 <<Mi nak ìkpar i nəm wo ka̱ atak onəm va̱ kur onəm ka̱t a. 
\q1 Mi nak ìgwak i lak wo ka̱ atak onəm oga mbin va nyi iya̱m ro ka̱t a.>> 
\m  
\v 20 UIshaya ləla nzəng ka̱ nkam ìgwak pa̱ Inan là pa̱, 
\q1 <<Onəm va̱ ram mi ka̱t te, oza̱ ya mi chit. 
\q1 N nyám ishi mi chit ónəm va̱ ɓəp atak mi ka̱t.>> 
\m  
\v 21 Ka̱pal-ishi nnap oIsa̱rila jiwo te, Inan là pa̱, 
\q1 <<N yichi awo mi óza̱ alum a ga tar mi pa̱ chit ka̱nunun. 
\q1 N yichi awo mi ónəm oga nlan nkpak nnap nnəm. 
\q1 Onəm oga nkak ishi oga nfe nnap ka̱t.>> 
\c 11  
\s1 Nnyam nrwa ìgwak Inan  //  ka̱ apal ishi aɓo nva̱n oIsa̱rila 
\p  
\v 1 Te mmami ka̱ n ɓəp pa̱ a nyan chit ɗak pa̱ Inan yan ka̱ onəm wò yan ɗò? Ko pa̱ ɗa̱p iya̱m ro ya pa ka̱t. Mmami ká̱ ishi mi te, mmami uzəntən ka̱ ashe onəm oga akum ìjili aIbərahim. Mmami apir aBenjamin.  
\v 2 Ko pa̱ ɗa̱p Inan ga̱ɓa̱n asəm na ónəm wò va̱ uza̱ yak oza̱ chit matmat kan ma nəm apambin ka̱t. O nyi iya̱m va̱ nnap-nlà Inan là ka̱ atak va̱ ma là nnap ka̱ apal ishi aIliya ka̱t ɗò? Nna asa̱l va̱ uza̱ ga ka̱ ayən ka̱ mpyal Inan ka̱ apal ishi nnap nnəm oIsa̱rila pa̱, 
\q1  
\v 3 <<ÁPonzhi-Inan, 
\q1 oza̱ gba̱ng onəm oga *nka̱m nre ka̱ atak ɓu chit pa̱ kpaktak. 
\q1 Oza̱ shin atak nshi iya̱m awop aɓu chit pa̱ kpaktak kpa. 
\q1 Mmami na pa̱ uzəng ɓur ka̱ nkukwa ka̱ ashe onəm oga nka̱m nre ka̱ atak ɓu. 
\q1 ká̱ nnà te, oza̱ ka̱ nɗak pa̱ na o gba̱l mi kpa.>> 
\m  
\v 4 Ama̱n va ta̱ Inan na á na ka̱t ɗò? Nna pa̱, 
\q1 <<Nna n gar ka̱kul ishi mi onəm ikalong pa̱ ifangshat va oma wop ichər va̱ mí wór pa̱ uBa'al chit ka̱t a.>> 
\m  
\v 5 Wantana ka̱ ashe nra va̱ ta̱ te, aɓo onəm Inan oma yà va uza̱ yak chit ka̱ atak nnap nnəna̱n wò.  
\v 6 A ya chit pa̱ ka̱ atak nnap nnəna̱n te, ya a yar iya̱m-inəmnəm iga nɗak ngga ishi anəm ka̱t. Ka̱ ya pa̱ ka̱ atak iya̱m-inəmnəm iga nɗak ngga ishi anəm na te, ya nnap nnəna̱n sat nnap nnəna̱n lap ka̱t. 
\p  
\v 7 Chit te, san ɗa? Te yà nyám chit pa̱ iya̱m va̱ oIsa̱rila ram oza̱ ya ka̱t te, onəm-yákyàk ya chit, ka̱kul aɓo oza̱ twat anung igwák oza̱  
\v 8 wa nva ma lir ka̱ ashe nnap-nlà Inan pa̱, 
\q1 <<Inan le ka̱ oza̱ re tan təm ka̱ ashe nnap nnəm ngga nku igwák. 
\q1 Uza̱ na iwú óza̱ kan oza̱ i ya atak ka̱t. 
\q1 Uza̱ na achwang oza̱ kan a kpa̱ng i fe iya̱m ro ka̱t. 
\q1 Oza̱ təm pa har ɓa chu nda va̱ ta̱.>> 
\m  
\v 9 UDawuda là pa̱, 
\q1 <<Re nri iya̱m iriri oza̱, ká̱ iwawa a sat ajəp óza̱. 
\q1 Re a sat icá iga nlwàk oza̱ kpa. 
\q1 Re nna a sat ipán iga nnak oza̱ i ru. 
\q1 Iya̱m-ina va̱ oza̱ yar pa̱ o nəm te, a le a təm óma. 
\q1  
\v 10 Iwú oza̱ ka̱ fo na oza̱ ka̱ ya atak ka̱t. 
\q1 Wa gur asəm ka̱ oza̱ ka̱ mɓək anung mbyet mbyet.>> 
\s1 Iriri ka̱kul aɓo onəm 
\p  
\v 11 Mmami ka̱ n ɓəp kà̱ɗi pa̱, oza̱ ləp ifan te, oza̱ ru nru nva pa̱ oza̱ i won lap ka̱t ɗò? Ko pa̱ ɗa̱p pa ka̱t. Ka̱kul nru oza̱ va̱ ta ɓa ka̱ ngwon onəm va̱ oYahudi ka̱t. A nak iriri iga mbyet mbyet sat ijo oza̱, na a nak ìkpar a nəm oIsa̱rila.  
\v 12 A yà pa̱ apambin dur ka̱ atak mpat-nnap oza̱ na, har onəm va̱ oYahudi ka̱t dur ka̱ atak nru oza̱ na kpa te, oza̱ i le atak Inan pa̱ kpaktak te, mí dur i mak nza̱ apir mmak yà? 
\p  
\v 13 Mmami ka̱ nla nnap ká̱ wo onəm va oYahudi ka̱t a. A ya chit pa̱ mmami na unəm uga nre aKəristi ka̱kul onəm va̱ oYahudi ka̱t te, mmami ka̱ nlan ká̱ inok mi ka̱ nkak.  
\v 14 Na a nak ìkpar a nəm oYahudi nzəng ka̱ nrəng pa̱ mo te, ìkpar a nəm onəm yi na oza̱ a ya iriri iga mbyet mbyet.  
\v 15 A yà pa̱ ma ngwan inal ká̱ ishimshe apambin ká̱ Inan ka̱kul mmandar oza̱ va ma mandar te, ya nle nka̱m oza̱ kà̱ɗi i yà ngwon ka̱ atak ikú ka̱t ɗò? 
\p  
\v 16 A yà pa̱ mma̱k iya̱m izhakan va̱ ma kál ma yichi íNan iya̱m inana inəna̱n te, ya aɓo mma̱k va̱ ta nnəna̱n na kpa ka̱t ɗò? Ikun kang alələng anəna̱n te, ya igwong ikún va̱ ta i yà inəna̱n na kpa ka̱t ɗò?  
\v 17 Ma kyen igwong ikún va̱ ta iro chit le atak ma gwang ivang á na ka̱ azaitun aga anyin va mmawó a. Ma gwang ivang awo na o fe nchang nzəng ka̱ oza̱ ndəng ká̱ iya̱m-nrì va alə̀ng ikún azaitun asuksuk va̱ ta ka̱ mɓa ka̱.  
\v 18 Ka̱kul nva̱ ta te, kan o nyám nrup ká̱ ishi igwong va̱ ma kyen le ka̱t. A yà pa̱ o nəm pa jak te, re o fe iya̱m va̱ ta̱. Mmawo na o kpán alə̀ng o sat ka̱ ka̱t. Alə̀ng na kpán wo sat ka̱.  
\v 19 Ɗom te, uro ka̱ ashe wo i là pa̱, <<Ma kyen igón va̱ ta le na a na atak ma gwang ivang mmami na ká̱ izər ikún va̱ ta ka̱t ɗò?>>  
\v 20 M ma̱n pa̱ wa nnà ta. Ka̱ nna kpa te, o nyi pa̱ kpátkpát pa̱ ma kyen oza̱ le ka̱kul nyang ka̱ nna nnandər oza̱. Mmawo nnyi te, o yà ntar ka̱ atak nna nnandər. Kan o fam ka̱t. O ra ayə̀r Inan.  
\v 21 Ka̱kul a yà pa̱ Inan gar igón ikún isuksuk va̱ ta ka̱t te, ya uza̱ i gar wo ka̱t na kpa.  
\v 22 Ka̱kul nva̱ ta te, o dər apir nnyi-nnap Inan ká̱ isəsai. Onəm va̱ le ka̱ asəsa̱l re te, uza̱ ka̱ nsam ka̱ oza̱. Mmawo te, uza̱ ka̱ nnyam nnyi-nnap awo, a yà pa̱ o le ka̱ asəsa̱l o re ka̱t a. Ka̱t te, mí gəl wo i le ká̱ izəzər na kpa.  
\v 23 A yà pa̱ oza̱ ga mpyal ka̱ nyang ka̱ nna nnandər ka̱t te, mí le ka̱ oza̱ i ɓa mí gwang ivang óza̱ ka̱ atak nvəva̱ng. Ka̱kul Inan uwa yà ká̱ ichumchum iga nle ngwang ivang óza̱ kà̱ɗi ka̱ atak nvəva̱ng.  
\v 24 A yà pa̱ ma kyen mmawó va wa azaitun aga anyin ɓa ma gwang ivang awo ka̱ azaitun asuksuk kan a kpəkpán te, mí gwang ivang azaitun asuksuk ká̱ izər inan wò te, i mor i kpán nza̱ apir nkpán yà? Ka̱kul pa̱ wat te, ńkàm kang ngwang ivang îya̱m iga anyin ká̱ isuksuk i kpán. 
\s1 Mi i ka̱mshi oIsa̱rila pa̱ kpaktak 
\p  
\v 25 Ógənang, n ɗom wo ɗom pa̱ o nyi nnap-mbwambwam va̱ ta̱. Ka̱kul kan o rən pa̱ ka̱ nva̱ mmawó ka̱səsa̱l ka̱t. Ntwat anung ìgwak oIsa̱rila mbyet ka̱t. Anun-ìgwak na ka̱ ntwat ka̱ oza̱ na onəm va̱ oYahudi ka̱t, kan oza̱ wa Inan te, oza̱ a ɓa a yə́l oza̱ a chu iyə́l va ma nak chit.  
\v 26 Ka̱sa̱l va ta te, mí ka̱mshi nkpaktak oIsa̱rila ka̱m wa nva ma lir chit ka̱ ashe nnap-nlà Inan pa̱, 
\q1 <<Unəm uga njul onəm i fa ka̱ aZiyona. 
\q1 Uza̱ i ɓak nyang ngwa Inan i fa ka̱ ashe akum ìjili aYakubu. 
\q1  
\v 27 Anung va ta n na óza̱ asóngsóng, nva̱ mi won pa̱ ń yar nnap-mɓá̱ngɓa̱ng oza̱ óza̱ a.>> 
\p  
\v 28 Ka̱ apal nnap mma̱n ka̱ nnap-nlà Inan ngga nchang nfe jiwo te, oza̱ tong onəm oga nyang Inan na a ka̱mshi mmawó na. Ka̱ apal nnap ayàk Inan jiwo te, oza̱ ɓyen ka̱ okəka oza̱ kan oza̱ yà oma̱nma̱n.  
\v 29 Ka̱kul imwa Inan ka̱ awuwór təm ntəm oza̱ chit. Uza̱ i le nva̱n ka̱ oza̱ ka̱t.  
\v 30 Ka̱ ya te, kò ò ya onəm oga nyang nkpak nnap nnəm íNan. Kan nyangmata̱ te, o ya nnyam nrwa ìgwak Inan chit ka̱kul nlan nkpak nnap nnəm oIsa̱rila.  
\v 31 wantana kpa nyangmata̱ oza̱ va ka̱ ashe nlan nkpak nnap nnəm te, nyangmata̱ te, ma nyám nrwa ìgwak Inan óza̱ chit kpa wa nva ma nyám awo a.  
\v 32 Ka̱kul Inan gwang onəm pa̱ kpaktak chit re təm ka̱ ashe nlan nkpak nnap nnəm na o nyám nrwa ìgwak wo óza̱ pa̱ kpaktak. 
\p  
\v 33 Ngbà̱ng aghan Inan ka̱ nnyinyi yà ka̱ nla ka̱t. Akwali va̱ uza̱ i nap te, a gba̱ng nva̱ pa̱ unəm a kpán ipipir ka̱t. Asa̱l va̱ uza̱ i wòl kà̱ te, asa̱l va pa̱ unəm a wa nvəva̱ng a ga a nyi ka̱t. 
\q1  
\v 34 <<Uda nyi iya̱m va̱ nyi ka̱ ashe ìgwak Inan yà? 
\q1 Ka̱t te, unəm ro yìyà uga nna ichən á na ɗò?>> 
\q1  
\v 35 <<Uda kur nna imwa ro íNan pa̱ Inan a mwa akəkat a wò yà?>> 
\p  
\v 36 Ka̱kul ka̱tətak na iya̱m pa̱ kpaktak fa. Ka̱ atətak na kpa mí ya iya̱m pa̱ kpaktak. Iya̱m pa̱ kpaktak ijini. Ichumchum iga iɓyen a təm ijini mbyet mbyet. Nna a təm. 
\c 12  
\s1 Nnap-nnəm ngga mmà unəm uga nnəm inok Inan 
\p  
\v 1 Nna nak te, ógənang, mmami ka̱ nchal wó ka̱kul mmak nrwa ìgwak Inan te, re ó yichi izər wó á na wa iya̱m ipapa iga nshi iga iriri va inəna̱n adak ro ya ka̱ ka̱t a. Iya̱m ipápà va Inan i məma̱n ka̱. Iya̱m va nna awop wo aga nnandər.  
\v 2 Kang ó təm apir ntəm va pa̱ səlak ka̱ nnap nnəm ngga apambin va̱ ta̱ lap ka̱t. Re ó ga̱ɓa̱n nnap nnəm wó ká̱ inənan ka̱ atak apir nrəng nnap mpipe. Nna chit te, ó nyi iya̱m va̱ Inan ɗom inəna̱n, ká̱ iya̱m va uza̱ i kəka̱m, ká̱ iya̱m va̱ kukur. 
\p  
\v 3 Ka̱kul nnap nnəna̱n va Inan na mi te, mmami ka̱ nla nnap ku únza̱ uzəntən wo nggo pa̱ kan unəm a yar ishi wò a ji nkam iya̱m va̱ uza̱ ka̱t. Iya̱m va̱ mà te, re unəm a yar ishi wò a mal dakdak ka̱ atak n-yi wò, a mal ka̱ nnap nnəna̱n va Inan na á na a.  
\v 4 Wa nva oga mɓan-izər pa̱ ɗongɗong gwang ká̱ izər pa̱ izəng te, oga mɓan-izər va̱ ta ka̱ nnəm apir inok pa̱ izəng ka̱t.  
\v 5 wantana ka̱ yi kpa. Ka̱ ashe aKəristi te, mmayi pa̱ kyak kang i gwang chit i nyang wa izər pa̱ izəng. Nza̱ uzəngtəng yi nggo te, uza̱ mɓan-izər awan wò.  
\v 6 Mmayi ka̱ aghan Inan aga nnyi nnəm nnap apir pa̱ ɗongɗong mà dakdak ka̱ nnap nnəna̱n va ma na yi. Ka̱kul nva̱ ta te, re i nəm inok ka̱. A yà pa̱ aghan aga nnyi nnəm nnap va̱ unəm ka̱ aga nnyi nla nnap-nlà va unəm ka̱m ka̱ atak Inan te, re uza̱ a nəm inok ka̱ ka̱ atak n-yi nna nnandər va uza̱ ka̱ a.  
\v 7 A yà pa̱ nnyi nnakshi ka̱ onəm te, re uza̱ a nakshi ka̱ onəm. A yà pa̱ nnyi nɗyang nnap-nlà Inan te, re uza̱ a ɗyang.  
\v 8 A yà pa̱ nnyi nnak ìgwak onəm i kam te, re uza̱ a nak ìgwak a kam onəm. A yà pa̱ nnyi nna iya̱m ka̱kul onəm va̱ ka̱ ashe nlan te, re uza̱ a na ká̱ ìgwak pa̱ izən. A yà pa̱ nnyi ngga ka̱ onəm te, re uza̱ a kpak oza̱ anyan ro a yà ka̱ ashishe ka̱t. A yà pa̱ nnyi nnyam nrwa ìgwak ónəm te, re uza̱ a nyám nzəng ka̱ nchang ìgwak. 
\s1 Iwon ka̱ apal ishi ntəm onəm oga ngwa Inan 
\p  
\v 9 Re mma̱n a ya ngga nnandər. Iya̱m va ina pa̱ kpaktak te, o yan pa̱ gənggəng. Re o bur ka̱ nkam iya̱m va kpaktak inəna̱n a.  
\v 10 Ka̱pal-ishi nnap mma̱n ogənan oga ngwa Inan te, o ma̱n owan wo pa̱ gənggəng. Ka̱ apal nnap nna ichumchum ówan wo te, o nyan owan wo ka̱ nnəna.  
\v 11 Kan nzhin ká̱ inok a rwam wo ka̱t. O ma̱k apər ka̱ nnap ngga aruhu ka̱ nnəm inok aPonzhi-Yesu inəna̱n.  
\v 12 Re nnak-ìgwak wo ká̱ Inan a yà nzəng ka̱ ntəm ka̱ ashe nchang ìgwak. O ka̱r ìgwak ka̱ nɗaktak. O ɗak ka̱ ashe nnəm aduwa.  
\v 13 O ka̱mshi ogənan oga ngwa Inan va̱ ka̱ ashe nlan. O ka̱m onəmchən nzəng ka̱ mɓa̱n-awu ro ka̱t. 
\p  
\v 14 O far nnap nnəna̱n Inan ónəm va̱ ka̱ nnyan ká̱ wo. Kan o far iya̱m ɓá̱ngɓa̱ng óza̱ ka̱t. O far nnap nnəna̱n na óza̱.  
\v 15 Onəm va̱ ka̱ ashe nchang ìgwak te, o ka̱mshi oza̱ ka̱ ntəm ka̱ ashe nchang ìgwak va̱ ta. Onəm va̱ nnyi ka̱ ntəm ka̱ ashe nlak-ìgwak te, o sak oza̱ sak ka̱ nlak-ìgwak va̱ ta.  
\v 16 Kan o gbak izər ka̱t. O təm ntəm ikángkáng ká̱ izəzər. Kan o rup ká̱ ishi ka̱t. Inok a yen wa nsan nggo te, o nənəm. Kan o rən pa̱ aghan wo ka̱ nva̱ ka̱səsa̱l ka̱t ɗò ka̱t.  
\v 17 Onəm a nəm iya̱m ina awo te, kan o pyát akəkat ká̱ iya̱m ina ka̱t. O yar nrən-nnap ka̱ nnəm iya̱m va onəm pa̱ kpaktak i ma̱n ka̱ pa̱ inəna̱n a.  
\v 18 A yà pa̱ i nənəm te, ka̱ re ka̱ anung njiwo te, kò o təm ntəm ngga ikángkáng ka̱ onəm pa̱ kpaktak.  
\v 19 Ónəm mi oma̱nma̱n, kan o pyát akat nnap únəm ro ka̱t. O re kan mmən-ikum Inan i nyi ka̱ oza̱. Ka̱kul ma lir ka̱ ashe nnap-nlà Inan pa̱, 
\q1 <<Mpyát akat nnap te, ka̱kul mi. Mi pyát akat nnap pyát.>> 
\m  
\v 20 Iya̱m va̱ mà pa̱ o nəm te, o nəm wa nva ma là ka̱ ashe nnap-nlà Inan pa, 
\q1 <<A yà pa̱ ayan ka̱ nji unəm uga nyang ɓu te, wa kan na ká̱ iya̱m-nrì. 
\q1 A yà pa̱ ndəng gba̱l na te, wa na ndəng á na a wa. 
\q1 Ka̱kul ka̱ atak nnəm iya̱m inəna̱n va̱ ta á na te, i lok na wa unəm a nak amor apər á na ká̱ ishi.>> 
\m  
\v 21 Kan o ma̱n ina a nəm igwan ka̱ apal ishi wo ka̱t. Re o nəm igwan ka̱ apal ishi ina ka̱ atak nnəm iya̱m inəna̱n. 
\c 13  
\s1 Nkpak nnap nnəm óponzhi 
\p  
\v 1 Ko uza̱ unəm nggo te, uza̱ a kpak nnap nnəm ónəm-chumchum oga nnəm ka̱ mbin. Ka̱kul ichumchum ro yà ka̱t, ya Inan a pak chwat. Ichumchum na pa̱ kpaktak te, Inan a pak təm.  
\v 2 Ka̱kul nva̱ ta te, unəm va̱ yan nfe onəm ochumchum oga nnəm ka̱ mbin te, ya uza̱ yan nfe onəm va Inan a kyep oza̱ a. Onəm oga nnəm apir iya̱m va̱ ta ka̱ ndap akwali íshi oza̱.  
\v 3 Ka̱kul onəm ochumchum oga nnəm ka̱ mbin, onəm oga nyar nlilyat kò onəm oga nnəm iya̱m nənna̱n ka̱t. Onəm oga nnəm iya̱m ɓá̱ngɓa̱ng oma chwat i ra ayə̀r oza̱. U ɗom pa̱ kan ayə̀r anəm uga nnəm ka̱ mbin a nəm ɓu ka̱t ɗò? Ya nəm iya̱m nənna̱n na uza̱ a ɗəngchi ɓu.  
\v 4 Ka̱kul uza̱ unəm uga nnəm inok Inan uga nnəm iya̱m va i ka̱mshi ɓu. A ya nnyi pa̱ mmaɓu ka̱ nnəm iya̱m iɓá̱ngɓa̱ng te, ya nəm ayə̀yə̀r. Ka̱kul ndokchi ichumchum va̱ uza̱ ka̱ te, uza̱ kpán pa mwan ka̱t. Uza̱ unəm uga nnəm inok Inan va i nyám ntan únəm uga nnəm iya̱m ina ka̱ atak nfə́l-ìgwak.  
\v 5 Ka̱kul nva̱ ta te, a mə̀mà pa̱ ma kpak nnap nnəm ónəm-chumchum oga nnəm ka̱ mbin. Mi i kpak óza̱ ka̱kul ayə̀r nnyam ntan na chwat ka̱t. Mi i kpak óza̱ kpa ka̱kul iya̱m va ta ìɗimɗim ìgwak ka̱ nla pa̱ ma nəm a.  
\v 6 Ka̱kul nnap nzəngtən va ta kpa mmawó ka̱ mmwa aga̱ndo. Ka̱kul onəm ochumchum oga nnəm ka̱ mbin oza̱ onəm oga nnəm inok íNan va ma na atak nsat óza̱ chit pa̱ kpaktak ka̱ anung nnəm inok va̱ ta.  
\v 7 Re o mwa únza̱ unəm nggo iya̱m va̱ ɓur. A yà pa̱ aga̱ndo a ɓur te, re o mwa. A yà pa̱ mbwai idur mbin te, re o mwa ónəm oga nkukwap. A yà pa̱ nnak inəm únəm va mə̀mà pa̱ ma nak á na te, re ma nak inəm á na. Unəm va̱ nnyi mà pa̱ ma na ichumchum á na te, re ma na ichumchum á na. 
\p  
\v 8 Kan o re akat iya̱m ro a təm awo ká̱ ishi ka̱t, ya akat mma̱n owan wo chwat. Ka̱kul unəm va̱ ka̱ mma̱n uwan wò te, ya uza̱ gba̱l ka̱ nkpak nnap-mpakpak chit.  
\v 9 Nnap mpakpak va̱ pa̱, <<Kan wa ra uchar anəm ka̱t, kang wa gba̱l unəm ka̱t, kan wa nəm ayi ka̱t, kang wa gwáng iya̱m awan ɓu ka̱t>> ka̱ aɓoshi nnap-mpakpak te, ma gwang oza̱ pa̱ ɓuruk chit ka̱ ashe nnap-nlà ngga nzəng va̱ ta̱. Nna pa̱, <<Wa ma̱n uwan ɓu wa nva mmaɓu ka̱ mma̱n ishi ɓu a.>>  
\v 10 Unəm va̱ ka̱ mma̱n te, i nəm iya̱m-ina ro úwan wò ka̱t. Ka̱kul nva̱ ta te, mma̱n unəm nnà sat n-yə́l nkpak nkpaktak nnap-mpakpak. 
\p  
\v 11 O nəm iya̱m va̱ ta nzəng ka̱ nnyi apir nra va̱ mmayi ka̱ ashishe nyangmata̱. Alum kur chit pa̱ o yenda̱l ká̱ iwu nda. Ka̱kul nyangmata̱ te, nka̱mshi ngga nna iriri iga mbyet mbyet ayi va̱ te, nrəra ɓa datkulung chit ji mmatmat ji, nva̱ ká̱ i na nnandər mpyal a.  
\v 12 Atak dat chit ka̱ ntan. Alum kur n-yenda̱l chit. Ka̱kul nva̱ ta te, re i re nnəm apir iya̱m iga afa̱p. I sham izər ká̱ iya̱m-wór onəm oga atak atántàn na.  
\v 13 Iya̱m va̱ i nəm te, a sat nzwan pa̱ kwar wa iya̱m va ma nəm ka̱ alum. Kang a yà nzwar ka̱ ngba̱p nza̱m ka̱t. Kang a yà nra̱n ka̱ nchè ka̱t. Kang a yà nnəm ilakchi, ka̱ mmai, ka̱ ngba̱ng ikum, ka̱ nkpar ìkpar ka̱t.  
\v 14 Iya̱m va̱ mà pa̱ ma nəm te, re o yar nnap nnəm nja aPonzhi-Yesu Kəristi. Kan o təm ka̱ nrəng asa̱l va̱ o nəm kang o nəm iya̱m va̱ nnap nnəm wo ngga izər ɗom ka̱t. 
\c 14  
\s1 Kan o nak mpat ówan wo ka̱t 
\p  
\v 1 Unəm va̱ nna nnandər nandər na kam chit ka̱t te, o ka̱m na ka̱m wa agənang ka̱ nna. Kan ndap-atam ka̱ apal ishi iya̱m ro a gwang wo ka̱ na ka̱t.  
\v 2 Unəm ro te, nna nnandər nandər ma̱n á na ma̱n pa̱ uza̱ a ri ka̱ iza̱ iya̱m nggo. Uro nnyi te, nna nnandər nandər kam ka̱t te, uza̱ i ri iya̱m-nrì va azáng na chwat.  
\v 3 Unəm va̱ i ri nza̱ iya̱m nggo te, kang uza̱ a ɓak unəm uga ntap iya̱m-nrì ka̱t. Unəm va̱ i yak iya̱m-nrì yak te, kan uza̱ a là únəm uga nri nza̱ iya̱m nggo pa̱ uza̱ pat nnap chit ka̱t. Ka̱kul Inan ma̱n ka̱ na ma̱n.  
\v 4 U kur wa ada nnyi kan ɓu nak mpat úzwal anəm-kak yà? Nsat nkam nggo te, uza̱ i sat únəm ga nzhi wò na. Nləp ifan nggo te, ya uza̱ i ru únəm ga nzhi wò na kpa. Ko pa̱ ɗa̱p uza̱ i ləp ifan ka̱t. Ka̱kul uPonzhi-Inan kukur pa̱ o nak na a sat a kam. 
\p  
\v 5 Unəm ro i yar pa̱ ka̱ ashe nrá te, nro ji ngwan wò ji ka̱kul nva̱ ta n-yə̀yə̀r. Unəm ro nnyi te, nkpaktak oza̱ iya̱m-izəntən ka̱tətak. Iya̱m va pa̱ kpaktak unəm yar pa̱ nna nnap te, re uza̱ a nyi pa̱ kpátkpát ka̱ ashe ìgwak wò pa̱ iya̱m va̱ ta wanta na nna̱n.  
\v 6 Unəm va̱ yar pa̱ nra ro yə̀yə̀r te, uza̱ yar pa ka̱kul nna ichumchum íNan. Unəm va̱ i ri nza̱ apir izhé nggo te, uza̱ ri ka̱kul nna ichumchum íNan. Ka̱kul uza̱ ka̱ nna aɗəngchi íNan ka̱ku-kul. Unəm va̱ nnyi yan ka̱ nri izhé pa̱ vava te, uza̱ nəm ka̱kul nna ichumchum íNan. Ka̱kul uza̱ ka̱ nna aɗəngchi íNan ka̱kukul.  
\v 7 Ka̱kul unəm ro yà ka̱ ashe yi uva təm ka̱kul ishi wò ka̱ nkukwa ka̱t. Unəm ro yà ka̱ ashe yi i ku ká̱ ishi wò ka̱t kpa.  
\v 8 A yà pa̱ nna i yà ka̱ n-yi n-yi te, i təm ka̱kul nna ichumchum íNan. A yà pa̱ i re n-yi n-yi i ku chit te, re i ku ka̱kul nna ichumchum íNan na kpa. Ko a yà pa̱ mmayi ka̱ n-yi n-yi, ka̱ a yà pa̱ mmayi ka̱ n-yi n-yi ka̱t te, mmayi onəm aPonzhi Inan.  
\v 9 Ka̱kul iya̱m va ta na pa̱ wat uKəristi ku. Uza̱ won ka̱ atak ikú na uza̱ a ta̱l uPonzhi onəm va̱ oma ku chit ka̱t, ka̱ onəm va̱ ku chit.  
\v 10 Nna kan mmaɓu nnyi te, sang kang ɓu nak mpat úwan ɓu yà? Iza̱ nak kan ɓu ɓak uwan ɓu yà? Ka̱kul nkpaktak yi i ga ntong ka̱ mpyal atak ntəm ngga nnap-akwali Inan.  
\v 11 Ma lir pa̱ Inan là pa̱, 
\q1 <<N son anung kam pa̱ gənggəng ka̱ aɗin Inan uga Iriri pa̱, 
\q1 <Nza̱ unəm nggo te, i ga nkuchi ká̱ irən ka̱ mpyal mí wop mi.> 
\q1 <Nza̱ unəm nggo te, uza̱ i bol anung i là ká̱ ishi wò pa̱ mmami na Inan.> >> 
\p  
\v 12 Ka̱kul nva̱ ta te, ilum sur ro te, nza̱ uzəntən yi nggo i ga nshal ka̱ mpyal Inan ka̱ anung wò nkpaktak iya̱m va̱ unəm nəm. 
\s1 Kan wa nak uwan ɓu a ləp ifan ka̱t 
\p  
\v 13 Ka̱kul nva̱ ta te, kan i ya owan yi ka̱ mpat ro lap ka̱t. Iya̱m va̱ mà pa̱ unəm a nəm te, re uza̱ a yar ka̱ ashe ìgwak wò pa̱ kan mmawò na o sat iya̱m iga nnak ugənang wò a ləp ifan ka̱t. Kan uza̱ a ma̱n a yà iya̱m iga nzwan asa̱l ku uwan wò ka̱t kpa.  
\v 14 N nyinyi har mi ləla ka̱ ashe aɗin aPonzhi Yesu-Kəristi pa̱ iya̱m-nrì ro yà va pa̱ i yə̀r unəm uga ngwa Inan ka̱t. A yà pa̱ unəm yar apir iya̱m-nrì ro pa̱ i yə̀r wò te, ka̱tətak te, a sat iya̱m iyə̀ryə̀r chit.  
\v 15 A yà pa̱ iya̱m va̱ u yan jak mmaɓu ka̱ nriri kan ka̱ nnak ìgwak awan ɓu ra ka̱t te, ya mma̱n yà ka̱ ashe ntəm ɓu ka̱t. Kan wa ma̱n iya̱m va̱ mmaɓu ka̱ nriri a sat iya̱m iga nnak na a zhì ka̱t. Uza̱ va uKəristi ku chit ka̱ku-kul a.  
\v 16 Ka̱kul nva̱ ta te, iya̱m va̱ u yar pa̱ ɓiɓyen te, kan wa ma̱n ma là pa̱ iya̱m-iɓá̱ngɓa̱ng ka̱t.  
\v 17 Ka̱kul iponzhi Inan pa te, nnap iya̱m irírí ká̱ iya̱m iwawa ka̱t. Iponzhi Inan nnap nta̱l unəna̱n ka̱ mpyal Inan, ka̱ ntəm ka̱ ashe nra-ìgwak, ka̱ ntəm ka̱ ashe nchang ìgwak va̱ aRuhu-Nəna̱n i ɓa ka̱.  
\v 18 Unəm va pa̱ kpaktak ka̱ nnəm inok aKəristi ka̱sa̱l va̱ ta te, ya uza̱ sat unəm va chit Inan i fe nchang ka̱ na. Onəm i ma̱n ka̱ na ma̱n kpa. 
\p  
\v 19 Ka̱kul nva̱ ta te, re i pá apər ka̱ nnəm apir iya̱m va i ɓa ka̱ ntəm-ikankan ka̱ mme onəm i kam.  
\v 20 Kan o ma̱n o vyap inok Inan ka̱kul nnap iya̱m irírí ka̱t. Nza̱ apir iya̱m nggo te, a ɓiɓyen. Ka̱ nna kpa te, a yà pa̱ unəm yan jak i ri iya̱m va i nak uwan wò i ləp ifan te, ya uza̱ nəm ɓyen ka̱t.  
\v 21 Nva̱ pa̱ unəm a ri izhé, ka̱t te uza̱ a wa ndəng ìba̱ngba̱ng, ka̱t te uza̱ a nəm nza̱ apir iya̱m nggo va i nak ugənang i ru te, ya kapkap pa̱ uza̱ a nəm iya̱m va̱ ta ka̱t. Nna ɓyen ji.  
\v 22 Mmaɓu ka̱ nna nnandər ɗò? Re a yà nnap va ká̱ ishimshe ɓu ká̱ Inan. Nnap-nnəna̱n na yà ka̱ apal ishi anəm va̱ igugwak rəra ka̱ anung nnəm iya̱m va̱ nnap-nnənəm nyám á na pa̱ a dakdak a.  
\v 23 Unəm va̱ nnyi ka̱ nkat amar ka̱ apal ishi nri iya̱m-nrì kan uza̱ ri ká̱ nnà te, ya uza̱ pat nnap íNan chit ka̱kul uza̱ ri iya̱m va̱ ta ka̱ ashe ngga̱m, nna nnandər yà ka̱ ka̱t. Iya̱m va pa̱ kpaktak unəm nəm nzəng ka̱ nna nnandər ka̱t te, iya̱m va̱ ta nnap-mɓá̱ngɓa̱ng. 
\c 15  
\s1 Nnak ìgwak awan ɓu pa̱ a chang nna rwa ji 
\p  
\v 1 Mmayi va̱ i kəkam ka̱ ashe nna nnandər te, a mà pa̱ onəm va̱ kam ka̱t te, i təp awo óza̱ kà̱ nyar iɗək nɗaktak oza̱. Kan i nəm iya̱m ka̱ nɗom ishi ka̱t.  
\v 2 Re nza̱ uzəntən yi nggo te, a nəm iya̱m va i chəchan ku uwan wò. Uza̱ a nəm iya̱m va i ka̱mshishi ka̱m, kan i me na me kpa a.  
\v 3 Ka̱kul ka̱ uKəristi ká̱ ishi wò te, iya̱m va̱ uza̱ nəm te, iga nɗom ishi ka̱t. Ma lir ka̱ ashe nnap-nlà Inan pa̱, 
\q1 <<Mpwat va̱ onəm ka̱ pwat ɓu te, a le chit təm mmami na ká̱ ishi.>> 
\m  
\v 4 Iya̱m va pa̱ kpaktak ma lir matmat ka̱ ashe nnap-nlà Inan te, ma lir pa̱ na a ɗyang iya̱m ayi, na asak va̱ ka̱ ashe nnap-nlà Inan i ka̱m nzəng ka̱ nka̱r ìgwak te, oza̱ a nak yi i təm ka̱ ashe nnak-ìgwak.  
\v 5 Re Inan va i na nka̱r-ìgwak ka̱ nkam-ìgwak kpa te, uza̱ a na apir ìgwak awo iga ntəm ntəm ngga ngwan ishi ká̱ izəzər. Uza̱ a na wo ka̱ ashe ntəm wo ngga nyar nva̱n aYesu kəristi,  
\v 6 na o na ichumchum íNan anung wo a yà pa̱ zən. Igwak wo pa̱ kpaktak a məma̱n ka̱ kpa. Inan va uwa Inan kan uwa uPo aPonzhi yi uYesu Kəristi kpa a. 
\s1 Nnap nlà Inan ngga nchang nfe  //  ka̱kul onəm va oYahudi ka̱t 
\p  
\v 7 Ka̱kul nva̱ ta te, o ma̱n ka̱ owan wo ma̱n wa nva uKəristi ma̱n ká̱ wo, na a ɓa ka̱ nna ichumchum íNan.  
\v 8 Re ń là awo. UKəristi ta̱l uzwal oYahudi ka̱kul nnyam nnandər Inan na a nyám pa̱ nkpaktak nsar nnap-nlà va̱ Inan ka̱ sar ókəka yi omatmat te, uza̱ i yə́yə́l.  
\v 9 Onəm va̱ oYahudi ka̱t nnyi te, oza̱ a na ichumchum íNan kpa ka̱kul nrwa-igugwak. A mà dakdak wa nva ma lir ka̱ ashe nnap-nlà Inan pa̱, 
\q1 <<Ka̱kul nva̱ ta te, mi bol anung mi na aɗəngchi aɓu ka̱ mpyal onəm va̱ uYahudi ka̱t. 
\q1 Mi shi nnap-nshì, mi shep aɗin ɓu ka̱ kpa.>> 
\m  
\v 10 Nnap nlà Inan là kà̱ɗi pa̱, 
\q1 <<Ónəm va̱ aYahudi ka̱t, o təm ka̱ ashe nchang ìgwak nzəng ka̱ onənəm. 
\q1 Ónəm va̱ oYahudi ka̱t, o lan nzəng ka̱ onənəm.>> 
\m  
\v 11 A là kà̱ɗi pa̱, 
\q1 <<O na aɗəngchi íNan nkpaktak wo va̱ onəm va oYahudi ka̱t a. 
\q1 Ónəm pa̱ kpaktak, o shi nnap-nshì ngga nna aɗəngchi á na.>> 
\m  
\v 12 Kà̱ɗi te, uYeshayah là kpa pa̱, 
\q1 <<Unəm uga akum ìjili aJesi ka̱ mɓa nfa. 
\q1 Unəm va i fa i nəm ichumchum ka̱ apal ishi nkpaktak oga akum ìjili. 
\q1 Uwa onəm va̱ oYahudi ka̱t te, i nak ìgwak ka̱.>> 
\m  
\v 13 Re Inan va uwa i nak unəm i nak igwák ka̱ nnap te, uza̱ a nak ìgwak wo a chang pa̱ makmak. Uza̱ a na nra-ìgwak mmakmak awo ka̱kul nna nnandər wo. Na o nak igwák wo kù uwa pa̱ gənggəng ka̱ atak ichumchum aRuhu-Nəna̱n. 
\s1 Ntəm ka̱ atak ichumchum aRuhu-Nəna̱n 
\p  
\v 14 Ógənang mi, mmami ká̱ ishi mi te, m məma̱n pa̱ mmawó ká̱ ishi wo te, mmawó onəm oga nnyi-nnap pa̱ gənggəng. Onəm va nnyi iya̱m wo mak pa̱ gənggəng. O kur nɗyang iya̱m ówan wo kur.  
\v 15 Ka̱ nna kpa te, nnap va̱ n lir awo te, n lir nnap kəkam ka̱ apal ishi nró na ń rən awo. N là ka̱kul nnap nnəna̱n va Inan na mi  
\v 16 nva̱ uza̱ nak mi chit unəm uga nnəm inok aYesu kəristi ónəm va oYahudi ka̱t a. Inan nak mi ka̱ nnəm inok nla nnap-nləla ngga nchang nfe wa anəm uga nshi iya̱m awop na onəm va̱ oYahudi ka̱t te, oza̱ a tong wa iya̱m ipápà ka̱kul nshi va Inan məma̱n ka̱. Iya̱m va aRuhu nəna̱n a nal a.  
\v 17 Ka̱kul nva̱ ta te, mi lan ka̱ ashe aYesu kəristi ka̱kul inok va̱ mmami ka̱ nnənəm Inan te, a yìyà ká̱ ipir.  
\v 18 Ko pa̱ ɗa̱p anung i pat ka̱ mi mi là iya̱m ro ka̱t, ya iya̱m va chwat uKəristi nəm ka̱ atak nnəm inok ka̱ mi ka̱kul mɓa ka̱ onəm va̱ oYahudi ka̱t, na oza̱ a kpak nnap nnəm íNan ka̱ atak iya̱m va uKəristi nak mi n là ká̱ iya̱m va̱ n nəm kpa a.  
\v 19 Oza̱ i ya ka̱ atak iya̱m ichumchum iga nɗaktak pa̱ ɗongɗong. Oza̱ i kpak nnap nnəm va̱ ta ka̱ atak ichumchum aRuhu-Nəna̱n. A nak te, a won ka̱ aUrushelima ka̱ aɓo mbin ngga atak va̱ ta ga chu aIlirikum te, n là nnap-nlà aKəristi ngga nchang nfe chit, ka̱ n re aɓuɓo ka̱t.  
\v 20 Nnap va̱ n yar anyinyam te, nna pa̱ ń là nnap-nlà Inan ngga nchang nfe ka̱ atak va na ma fe aɗin aKəristi chit ka̱t. Na a yà pa̱ kan mà me nzhi va unəm ukak a ban akukum ka̱t.  
\v 21 Mi nəm i mal dakdak wa nva ma lir ka̱ ashe nnap-nlà Inan pa̱, 
\q1 <<Onəm va̱ ma là nnənap óza chit ka̱t te, oza̱ i nyi na. 
\q1 Onəm va oma fe nnənap chit ka̱t te, oza̱ i ga nkpán ipipir.>> 
\s1 UBulus ɗa̱mshi izər ka̱kul ngga aRom 
\p  
\v 22 Iya̱m va ta nak te, nva̱n pa̱ nkyak mɓa atak wo nna ka̱ mɓa̱r mi.  
\v 23 N-yanmata̱ jiwo te, n gba̱l inok ka̱ mbin ngga atak va̱ ta̱ chit. Ka̱kul pa̱ ayan nya wo va pak inok nji mi chit izún pa̱ makmak te,  
\v 24 n nak ìgwak nya wo kan mi watar mi ga mbin Asabaniya. Mi sat ka̱ atak wo pa̱ ɗa̱p mi jul izər nzəng ka̱ nfe nchang ntəm nzəng ká̱ wo. Nna chit te, o ka̱mshi mi kà̱ nnap achen mi aga ngga atak va̱ ta.  
\v 25 N-yanmata̱ te, mmami ka̱ ngga aUrushelima ka̱kul ngga ka̱ nka̱mshi ónəm Inan.  
\v 26 Ogənan oga mbin aMakidoniya ka̱ Akaya yà ɓiɓyen ka̱ oza̱ pa̱ oza̱ a kwap iya̱m ka̱kul nka̱mshi ogənan oga nkun ka̱ ashe onəm Inan oga aUrushelima.  
\v 27 Oza̱ ya nnəm pa̱ chəchan ka̱ oza̱. Nnandər te, nnəm pa sat óza̱ wa akat ká̱ ishi. Ka̱kul a yà pa̱ onəm va oYahudi ka̱t kan ka̱ nfe nchang nzəng ka̱ oYahudi nnap-nəna̱n va Inan ka̱ sar nnənap óma chwat te, a sat nnap ga nkpak pa̱ oza̱ a fe nchang iya̱m iga apambin nzəng ka̱ oYahudi.  
\v 28 Ka̱ nva̱ngva̱ mi gba̱l ka̱ ngga ka̱ nre va̱ ta mi yichi nkpaktak kpaktak óza̱ te, mi wòl atak wo kan mi watar mi ga mbin Asabaniya.  
\v 29 N nyinyi pa̱ mi ɓa atak wo te, mi ɓa ka̱ nnap nnəna̱n aKəristi awo aɓuɓo ro i ɓur ka̱t. 
\p  
\v 30 Ógənang, mmami ka̱ nchal wo ka̱ ashe aɗin aPonzhi yi uYesu Kəristi ka̱ mma̱n va̱ aRuhu-Nəna̱n i na te, mmami ka̱ nchal wo pa̱ o ka̱mshi mi ka̱ nnəm aduwa íNan  
\v 31 na uza̱ a nak ń fa ká̱ ikángkáng ka̱ mbin aYahudiya kan onəm va̱ na nnandər ká̱ Inan ka̱t te, oza̱ a nak ishi a nan mi ka̱t. Uza̱ a nak inok mi ka̱ aUrushelima a sat iya̱m va onəm Inan oga atak va̱ ta i məma̱n ka̱ kpa.  
\v 32 Nna chit te, a yà pa̱ Inan məma̱n te, mi ɓa atak wo ka̱ ashe nchang ìgwak na ń jul izər ka̱ atak wo.  
\v 33 Re Inan uga nna nra-ìgwak a təm nzəng ká̱ wo pa̱ kpaktak. Nna a təm. 
\c 16  
\s1 Nre-anung 
\p  
\v 1 N ɗom pa̱ ń là awo pa̱ uFibi ugənang yi uchar uza̱ uchar unandər va i nəm inok ka̱ ashe ikilisiya iga aKankiriya.  
\v 2 O ka̱m na ka̱m ka̱ atak wo ka̱ ashe aɗin aPonzhi-Yesu wa nva a mà nnəm ónəm va̱ oji Inan a. Nka̱mshi va pa̱ kpaktak uza̱ a ram ka̱ atak wò te, o na á na na. Ka̱kul uza̱ ká̱ ishi wò te, uza̱ ka̱mshi onəm chit pa̱ kyak. Mmami uzəntən ka̱ ashe onəm va̱ ta. 
\p  
\v 3 O re anung re úAkila á mi ka̱, ka̱ uchar wò uBərisila. Oza̱ onəm oga nnəm inok aYesu kəristi nzəng ka̱ mi.  
\v 4 Oza̱ yang ká̱ iriri oza̱ ka̱kul mi. Mmami na chwat ka̱ nɗəngchi oza̱ ka̱t. Nkpaktak onəm oga ngwa Inan va̱ oYahudi ka̱t, ka̱ atak pa̱ ɗongɗong ka̱ nna aɗəngchi óza̱ na kpa.  
\v 5 O re anung re á mi ká̱ ikilisiya va̱ ka̱ mɓut ka̱ nzhi oza̱. O re anung re úIpenitus ukpa mi uma̱nma̱n va uwa unəm uga ngəshi va na nnandər ku uKəristi ka̱ ashe mbin Asiya a.  
\v 6 O re anung re úMaryamu ka̱. Uza̱ va nəm inok byet ka̱kul wo a.  
\v 7 O re anung re ónal mi uAnduromikus ku uYumiyus. Oza̱ va ká̱ i yà ka̱ nzhi ikan nzəng ka̱ oza̱. Ka̱ ashe onəm oga nre aKəristi te, oza̱ onəm va nva̱n ka̱t. Oza̱ na nnandər na ku uKəristi mpyal mi.  
\v 8 O re anung re úAmipiliyus. Uza̱ va m ma̱n na ma̱n ka̱ ashe aɗin aPonzhi-Yesu.  
\v 9 O re anung re Úrbanu ka̱. Uza̱ va unəm uga nnəm inok aKəristi nzəng ka̱ yi. O re anung re úSetakis ukpa mi uma̱nma̱n.  
\v 10 O re anung re úApulis. Uza̱ va uKəristi ma̱n ka̱ na ma̱n a. O re anung re úArustobulus ka̱ onəm oga ashe nzhizhi.  
\v 11 O re anung re únal mi uHirudiyan. O re anung re úNarsisas ka̱ onəm oga ashe nzhizhi va oja aPonzhi-Yesu a.  
\v 12 O re anung re úTirifina ku uTirifosa ochar va ka̱ nnəm inok aPonzhi-Yesu ká̱ ìgwak pa̱ izən. O re anung re úParsis ukpa mi uma̱nma̱n. Uchar va nəm inok aPonzhi-Yesu byet kpa ká̱ ìgwak pa̱ izən.  
\v 13 O re anung re úRufas. Unəm aPonzhi-Yesu va nva̱n ka̱t. O re anung únənan ka̱ kpa. Uchar va yar mi wa ayen wò na kpa a.  
\v 14 O re anung re úAsinkirtus, ku uFilegon, ku uHamis, ku uPaturobas, ku uHamas ka̱ aɓo ogənan va̱ nzəng ka̱ oza̱.  
\v 15 O re anung re úFilologus kpa, ku uYuliya, ku uNiriyas, ku ugənang gənang uchar, ku uOlimpas ka̱ nkpaktak aɓo onəm Inan va̱ nzəng ka̱ oza̱.  
\v 16 O re anung ówan wo ka̱ ashe mma̱n. Nkpaktak ikilisiya aKəristi iga atak va̱ ta̱ ka̱ nre awo kpa.  
\v 17 Ógənang, mmami ka̱ nchal wo pa̱ o nəm dakdak ka̱ onəm oga mɓa ka̱ nkap izər, ka̱ onəm oga nnak oro i ləp ifan. Onəm va ka̱ nlun na oza̱ a vyap nɗyang nnəna̱n va̱ ma ka̱ ɗyang awo a. Kan o dat ka̱ apir onəm va̱ ta ka̱t.  
\v 18 Onəm va̱ ta inok aPonzhi-Kəristi oza̱ ka̱ nnənəm ka̱t. Nnap afu oza̱ na chwat rwa oza̱. Ka̱ atak nnap-nlà nchangchan ngga asap-anung, ka̱ nna ndəng ónəm na oza̱ ka̱ nlam onəm oga amwang.  
\v 19 Mmawo te, onəm pa̱ kpaktak fe nnap nkpak nnap nnəm wo fe. Nna nak te, ìgwak chàng mi pa̱ gənggəng ka̱kul wo. Ka̱ nna kpa te, n ɗom wo pa̱ iya̱m na kpaktak inəna̱n te, o yà ka̱ aghan aga nnyi iya̱m va̱ ta. Iya̱m va̱ iɓá̱ngɓa̱ng jiwo te, kan iya̱m ro a gwang wo ka̱ ka̱t.  
\v 20 UPonzhi-Yesu uga mɓa ka̱ ntəm-ikankan dat chit ka̱ nnəm úShetan ka̱ nchang ka̱t, i nak wo o nəm ichumchum ka̱ apal ishishi. Nnap-nnəna̱n aPonzhi yi uYesu Kəristi a təm nzəng ká̱ wo. 
\p  
\v 21 UTimoti unəm uga nnəm inok nzəng ka̱ mi ka̱ nre anung awo. ULusiyus, ka̱ uYason, ká̱ uSosipa onal mi ka̱ nre anung awo kpa.  
\v 22 Mmami uTertiyus va n lir iya̱m va̱ ta̱ te, mmami ka̱ nre anung ajem awo kpa ka̱ ashe aɗin aPonzhi-Yesu. 
\p  
\v 23 UGayus va nzhizhi sat atak va mi ra ka̱, ka̱ atak mɓut ikilisiya ká̱ ishi wò te, uza̱ ka̱ nre anung awo. UIrastus unəm uga nnakshi ka̱ mbwai ìtong va̱ ta̱ ku ugənang yi uKwartus ka̱ nre anung awo. 
\p  
\v 24 Re nnap nnəna̱n aPonzhi yi uYesu Kəristi a təm nzəng ká̱ wo pa̱ kpaktak. Nna a təm. 
\s1 Nwachi nnap-nlà ka̱ nna aɗəngchi 
\p  
\v 25 Re uza̱ va uwa ká̱ ichumchum iga nnak wo pa̱ o kam ka̱ ashe nnap-nlà Inan ngga nchang nfe va̱ ka̱ o fe ka̱ atak mi te, ma na ichumchum á na. Wa nva ka̱ n là awo nva̱ ka̱ n là nnap-nlà aYesu kəristi awo a. Nnap nlà va̱ ta nva ka̱ yà mbwambwam ka̱ nnəm apambin na byet.  
\v 26 N-yanmata̱ te, a fa chit ka̱ mban. Ma nak ma nyi ka̱ atak iya̱m va̱ onəm oga *nka̱m nre ka̱ atak Inan ka̱ lir wa nva Inan là óza̱ pa̱ oza̱ a lir. Inan va təm chit mbyet mbyet jiwo. Ma nyám nnap-mbwambwam va̱ ta ka̱ mban na onəm oga nza̱ akum ìjili nggo te, oza̱ a na nnandər ka̱ na nzəng ka̱ nkpak nnap nnəm á na kpa.  
\v 27 Ichumchum təm iji Inan chit mbyet mbyet. Uwa ji ka̱ aghan pa̱ kpaktak. Ma na ichumchum á na ka̱ ashe aɗin aYesu kəristi. Nna a təm. 