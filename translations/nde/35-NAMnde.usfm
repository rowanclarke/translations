\id NAM - Biblica® Open Ndebele Contemporary Bible
\h UNahume
\toc1 UNahume
\toc2 UNahume
\toc3 Nah
\mt1 UNahume
\c 1
\p 
\v 1 Isiqalekiso ngeNiniva. Incwadi yombono kaNahume umʼElikhoshi.
\b
\s1 Ulaka LukaThixo NgeNiniva
\q1 
\v 2 \nd UThixo\nd* uNkulunkulu olobukhwele lophindiselayo;
\q2 \nd uThixo\nd* uyaphindisela njalo ulolaka olukhulu.
\q1 \nd UThixo\nd* uyaphindisela ezitheni zakhe
\q2 lolaka lwakhe lukhulu ezitheni zakhe.
\q1 
\v 3 \nd UThixo\nd* uyaphuza ukuthukuthela njalo ulamandla amakhulu;
\q2 \nd uThixo\nd* kayikumyekela olecala engajeziswanga.
\q1 Indlela yakhe iphakathi kwesivunguzane lesiphepho,
\q2 amayezi aluthuli lwezinyawo zakhe.
\q1 
\v 4 Ukhuza ulwandle alomise;
\q2 wenza yonke imifula itshe.
\q1 IBhashani leKhameli kuyabuna
\q2 lemiqhakazo yaseLebhanoni ibune.
\q1 
\v 5 Izintaba ziyanyikinyeka phambi kwakhe,
\q2 lamaqaqa ayancibilika.
\q1 Umhlaba uyagedezela ngobukhona bakhe,
\q2 umhlaba labo bonke abahlala kuwo.
\q1 
\v 6 Ngubani ongamelana lentukuthelo yakhe na?
\q2 Ngubani ongalumela ulaka lwakhe oluvuthayo na?
\q1 Ulaka lwakhe luthululeka njengomlilo;
\q2 amadwala ayaqhekezeka phambi kwakhe.
\b
\q1 
\v 7 \nd UThixo\nd* ulungile,
\q2 uyisiphephelo ezikhathini zokuhlupheka.
\q1 Uyabakhathalela abathembele kuye,
\q2 
\v 8 kodwa ngesikhukhula esikhulu
\q1 uzatshabalalisa iNiniva;
\q2 uzaxotshela izitha zakhe emnyameni.
\b
\q1 
\v 9 Loba engamacebo bani abawenza \nd ngoThixo\nd*,
\q2 uzawaqeda;
\q2 ukuhlupheka akuyikubuya kabili.
\q1 
\v 10 Bazathandeleka phakathi kwameva,
\q2 bedakwe liwayini labo;
\q2 bazaqothulwa njengenhlanga ezomileyo.
\q1 
\v 11 Wena Nineve, kuwe sekufike lowo
\q2 oceba okubi \nd ngoThixo\nd*,
\q2 eluleke okubi.
\p 
\v 12 Nanku okutshiwo \nd nguThixo\nd*:
\q1 “Lanxa belababambene labo njalo bebanengi,
\q2 bazaqothulwa banyamalale.
\q1 Lanxa ngikuhluphile, wena Juda,
\q2 kangisayikukuhlupha futhi.
\q1 
\v 13 Khathesi ngizakwephula ijogwe labo elisentanyeni yakho,
\q2 ngiqamule lamaketane akho.”
\b
\q1 
\v 14 \nd UThixo\nd* usekhuphe ilizwi ngawe Nineve elithi,
\q2 “Kawuyikuba lezizukulwane ezibizwa ngebizo lakho.
\q1 Ngizachitha izifanekiso ezibaziweyo lezithombe ezibunjiweyo
\q2 ezisethempelini labonkulunkulu bakho.
\q1 Ngizalungisa ingcwaba lakho,
\q2 ngoba ungcolile.”
\b
\q1 
\v 15 Khangela ezintabeni le,
\q2 inyawo zalowo oletha izindaba ezinhle,
\q2 omemezela ukuthula!
\q1 Thakazelela imikhosi yakho we Juda,
\q2 ugcwalise lezifungo zakho.
\q1 Ababi kabasayikukuhlasela futhi;
\q2 bazachithwa ngokupheleleyo.
\c 2
\s1 INiniva Izachitheka
\q1 
\v 1 Umhlaseli uyasondela kuwe, Nineve.
\q2 Vikela inqaba,
\q2 linda umgwaqo,
\q2 zilungiselele,
\q2 qoqa wonke amandla akho!
\b
\q1 
\v 2 \nd UThixo\nd* uzabuyisela ubuhle bukaJakhobe
\q2 njengobuhle buka-Israyeli,
\q1 lanxa abachithi bebaqothule
\q2 batshabalalisa lezivini zabo.
\b
\q1 
\v 3 Amahawu amabutho akhe abomvu,
\q2 amabutho agqoke okubomvu gebhu.
\q1 Insimbi ezinqoleni zempi iyaphazima
\q2 ngosuku ezilungiselwe ngalo;
\q2 imikhonto yesihlahla sephayini iyazunguzwa.
\q1 
\v 4 Izinqola zempi zihlasela ngesiqubu emigwaqweni,
\q2 zisiya emuva laphambili ezigcawini.
\q1 Zinjengezibane ezikhanyisiweyo;
\q2 ziyaphaziphazima njengombane.
\b
\q1 
\v 5 Ubiza amabutho akhe akhethiweyo
\q2 kodwa ayakhubeka endleleni yawo.
\q1 Agijimela emdulini wedolobho;
\q2 isivikelo silungiswe.
\q1 
\v 6 Amasango omfula ayavulwa,
\q2 indlu yobukhosi ibhidlike.
\q1 
\v 7 Kumiswe ukuthi idolobho lizathunjwa,
\q2 abantu balo basiwe ebugqilini.
\q1 Izintombi zalo eziyizigqili zikhala njengamajuba
\q2 zizitshaya amabele azo.
\q1 
\v 8 INiniva injengesiziba,
\q2 njalo amanzi aso ageleza ehamba.
\q1 Bayaklabalala besithi, “Mana! Mana!”
\q2 Kodwa kakho onyemukulayo.
\q1 
\v 9 Phangani isiliva!
\q2 Phangani igolide!
\q1 Umthapho kawupheli,
\q2 inotho evela eziphaleni zayo zonke!
\q1 
\v 10 Ibhuqiwe, iphangiwe, iphundliwe!
\q2 Inhliziyo ziphela amandla, amadolo ayaxega,
\q2 imizimba iyaqhaqhazela, ubuso bonke bunyukubele.
\b
\q1 
\v 11 Khathesi-ke ungaphi umhome wezilwane,
\q2 lapho ezinikela khona abantwana bazo ukudla,
\q1 lapho okwaya khona isilwane lesilwanekazi,
\q2 kanye lemidlwane, kungekho lutho olwesatshwayo na?
\q1 
\v 12 Isilwane sibulalele imidlwane yaso okwaneleyo
\q2 sabambela lesilwanekazi saso okwenyama yokudliwa,
\q1 sagcwalisa isikhundla saso ngesikujimbileyo
\q2 lomhome waso ngenyama.
\b
\q1 
\v 13 “Ngimelane lawe,”
\q2 kutsho \nd uThixo\nd* uSomandla.
\q1 “Ngizazitshisa izinqola zakho zempi zibe yintuthu;
\q2 lenkemba izakudla izilwane zakho ezisakhulayo.
\q2 Kangiyikukutshiyela ongakubamba ukudle njengenyama emhlabeni.
\q1 Amazwi ezithunywa zakho
\q2 kawasayikuzwakala futhi.”
\c 3
\s1 Maye Kuyo INiniva
\q1 
\v 1 Maye kulo idolobho legazi,
\q2 ligcwele amanga,
\q1 ligcwele ukuphanga,
\q2 kasweleki ohlutshwayo lanini!
\q1 
\v 2 Ukukhala kwezaswebhu,
\q2 ukugodlozela kwamavili,
\q1 ukumatha kwamabhiza
\q2 lokugedlezela kwezinqola zempi!
\q1 
\v 3 Ukuhlasela kwabagadi bamabhiza
\q2 ukuphazima kwezinkemba
\q2 lokubenyezela kwemikhonto.
\q1 Zinengi izinkubela,
\q2 izinqwaba zabafileyo,
\q1 izidumbu ezingabalwayo,
\q2 abantu abakhubeka ezidunjini,
\q1 
\v 4 konke ngenxa yenkanuko embi yesifebe,
\q2 siyakhanga, siyinkosikazi ephethe ubuthakathi,
\q1 esifaka izizwe ebugqilini ngobufebe baso
\q2 labantu ngobuthakathi baso.
\b
\q1 
\v 5 “Ngimelana lawe,” kutsho \nd uThixo\nd* uSomandla.
\q2 “Ngizakwembulela izidwaba zakho ebusweni bakho.
\q1 Ngizatshengisa izizwe ubunqunu bakho,
\q2 lemibuso ihlazo lakho.
\q1 
\v 6 Ngizakujikijela ngamanyala,
\q2 ngizakweyisa,
\q2 njalo ngikwenze ube ngumbukiso.
\q1 
\v 7 Bonke abakubonayo bazakubalekela bathi,
\q2 ‘iNiniva isichithekile, ngubani ozayililela na?’
\q2 Ngingamthola ngaphi ongakududuza na?”
\b
\q1 
\v 8 Wena ungcono na kuleThebesi
\q2 engaseNayili,
\q2 ehonqolozelwe ngamanzi?
\q1 Umfula wawuyisivikelo sayo,
\q2 amanzi engumduli wayo.
\q1 
\v 9 IKhushi leGibhithe kwakungamandla ayo angapheliyo.
\q2 IPhuthi leLibhiya kwakungabanye abancedisi bayo.
\q1 
\v 10 Kodwa yathunjwa
\q2 yaya ebugqilini.
\q1 Izingane zayo zapaklazwa zaba yizicucu
\q2 ekuqaliseni kwemigwaqo yonke.
\q1 Kwenziwa inkatho ngezikhulu zayo,
\q2 wonke amadoda aphakemeyo abotshwa ngamaketane.
\q1 
\v 11 Lawe futhi uzadakwa;
\q2 uzakuyacatsha
\q2 udinge ukuphephela esitheni sakho.
\b
\q1 
\v 12 Zonke izinqola zakho zinjengezihlahla zemikhiwa
\q2 ezilezithelo zazo zakuqala ezivuthiweyo;
\q1 lapho zinyikinywa,
\q2 imikhiwa iwela emlonyeni womudli.
\q1 
\v 13 Khangela amabutho akho wonke,
\q2 ngawesifazane!
\q1 Amasango elizwe lakho
\q2 avulekele izitha zakho aba banzi;
\q2 umlilo uyiqedile imigoqo yawo.
\b
\q1 
\v 14 Donsa amanzi ulungele ukuvimbezela,
\q2 qinisa inqaba zakho.
\q1 Voxa udaka,
\q2 nyathela ibumba,
\q2 lungisa okwakhiwe ngezitina.
\q1 
\v 15 Khonapho umlilo uzakuqeda;
\q2 inkemba izakucakazela phansi,
\q2 ikudle njengesikhongwane.
\q1 Zandise njengesikhongwane,
\q2 uzandise njengentethe.
\q1 
\v 16 Usulandisile inani labathengisi bakho.
\q2 Baze bedlula izinkanyezi zasemkhathini,
\q1 kodwa njengentethe baphundla ilizwe
\q2 basuke bahambe.
\q1 
\v 17 Abalindi bakho banjengentethe,
\q2 izikhulu zakho zinjengemitshitshi yentethe
\q2 ezihlala emidulini mhla kuqanda
\q1 kodwa ilanga lingaphuma ziyaphapha zihambe,
\q2 njalo kakho okwaziyo ukuthi ngaphi.
\b
\q1 
\v 18 Wena nkosi yase-Asiriya, abelusi bakho bayawozela,
\q2 izikhulu zakho zilala phansi ziphumule.
\q1 Abantu bakho bahlakazekile ezintabeni
\q2 kungekho obaqoqayo.
\q1 
\v 19 Akukho okungapholisa amanxeba akho;
\q2 ukulimala kwakho ngokokufa.
\q1 Bonke abezwa izindaba ngawe
\q2 batshaya izandla ngokuwa kwakho,
\q1 ngoba ngubani ongafuthelwanga
\q2 yisihluku sakho esingapheliyo na?
