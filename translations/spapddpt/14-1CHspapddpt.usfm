\p
\v 28 Algunos \w de|strong="H5921"\w* \w éstos|strong="H1992"\w* tenían \w a|strong="H3068"\w* \w su|strong="H1992"\w* cargo \w los|strong="H1992"\w* utensilios \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w ministerio|strong="H5656"\w*, \w los|strong="H1992"\w* cuales eran \w contados|strong="H4557"\w* \w cuando|strong="H3588"\w* \w los|strong="H1992"\w* guardaban \w y|strong="H3588"\w* \w cuando|strong="H3588"\w* \w los|strong="H1992"\w* \w sacaban|strong="H3318"\w*.  
\v 29 Otros tenían \w a|strong="H3068"\w* \w su|strong="H1992"\w* cargo \w el|strong="H5921"\w* mobiliario \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H1992"\w* utensilios \w del|strong="H5921"\w* \w Santuario|strong="H6944"\w*, \w la|strong="H5921"\w* flor \w de|strong="H5921"\w* harina, \w el|strong="H5921"\w* \w vino|strong="H3196"\w*, \w el|strong="H5921"\w* \w aceite|strong="H8081"\w*, \w el|strong="H5921"\w* \w incienso|strong="H3828"\w* \w y|strong="H5921"\w* \w las|strong="H1992"\w* \w especias|strong="H1314"\w*;  
