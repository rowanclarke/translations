\id 2SA - Tarok
\h Nlir aSamuwel Aga aParəm
\toc3 2 ASam
\toc2 2 ASamuwel
\toc1 Nlir aSamuwel Aga aParəm
\mt1 ASamuwel
\mt2 Aga aParəm
\c 1
\s1 UDawuda fe ikú aShawulu
\p 
\v 1 Kà̱ nva̱ngva̱ uShawulu kú chit kang uDawuda le chit ka̱ atak nnəm igwan ká̱ oAmalek te, uza̱ təm nra pa̱ mparəm ka̱ aZiklak.
\v 2 Kà̱ nra ngga nshatɗing te, unəm fa ka̱ apa̱k aShawulu ká̱ ìlukwan ikankan kang ká̱ mɓwang ka̱ ishi wò. Awalang va̱ uza̱ chu atak aDawuda te, uza̱ ru zəp ká̱ afu kà̱ mbin na ô na ichumchum á na.
\p 
\v 3 UDawuda ɓəp na pa̱, <<U fa ka̱ che yà?>>
\p Uza̱ na ama̱n pa̱, <<N chər ka̱ atak apa̱k oIsa̱rila.>>
\p 
\v 4 UDawuda ɓəp na pa̱, <<Iza̱ ka̱ ngga yà? Là á mi.>>
\p Uza̱ na ama̱n pa̱, <<Oshozha chəng chit ka̱ atak ìkum. Mmá gbá̱ng oza̱ pa̱ makmak, kang uShawulu ká̱ uyəyen ununggwan uJonatan kú kpa.>>
\p 
\v 5 UDawuda ɓəp uyen nza̱m va̱ là iya̱m va̱ ta á na pa̱, <<U nəm sang kang u nyi pa̱ uShawulu ká̱ uyəyen ununggwan uJonatan kú yà?>>
\p 
\v 6 UYən nza̱m va̱ ta là á na pa̱, <<Nva̱ngva̱ na ka̱ n yà ka̱ apal aƁam aGilbowa te, n ya uShawulu kà̱ nda̱r izər ka̱ apal aɓár wò, kang oga akeke ipəri okpa ìkukum kà̱ mɓa ndát ká̱ na.
\v 7 Awalang va̱ uza̱ ga̱ɓa̱n kang uza̱ ya mi te, uza̱ wór mi, kang m ma̱n pa̱, <Mmami nata̱, anəm uga nzhi.>
\p 
\v 8 <<Uza̱ ɓəp mi pa̱, <Mmaɓu uda yà?>
\p <<N là á na pa̱, <Mmami unəm oAmalek.>
\p 
\v 9 <<Te uza̱ là á mi pa̱, <Ɓa dat na u gbá̱l mi, ka̱kul mmami ka̱ ashe izər nrwa pa̱ gənggəng, ǹnyi te, na n yà ká̱ iriri.>
\p 
\v 10 <<Te m ɓa dat kang n gbá̱l na, ka̱kul uza̱ ru chit kang n nyi pa̱ uza̱ i lár ka̱t. Kang n tur atagya iponzhi va̱ ka̱ ishishi ká̱ nkalɓang ngga ìgwal va̱ ka̱ ìgugwal kang m ɓa ká̱ pa̱ chatchat a ɓu, anəm uga nzhi mi.>>
\p 
\v 11 Te uDawuda ká̱ nkpaktak onunggwan va̱ nzəng ká̱ na kpan ilukwan oza̱ kan.
\v 12 Oza̱ təm ká̱ aɗor kang oza̱ yə́ng pa̱ gənggəng, oza̱ yar ndəng gbà̱l ga chu arurong ka̱kul aShawulu ká̱ uyəyen ununggwan uJonatan, ká̱ oshozha aYawe, ká̱ nzhi aIsa̱rila, ka̱kul oza̱ kú chit ka̱ atak ndokchi.
\p 
\v 13 UDawuda ɓəp uyen nza̱m va̱ ɓa ka̱ nnap-nlà va̱ ta á na pa̱, <<U fa ka̱ che yà?>>
\p Te uza̱ na ama̱n á na pa̱, <<Mmami uɗyanəm, uya anəm uga aAmalek, va ka̱ ntəm ka̱ ashe mbin ɓu á.>>
\p 
\v 14 UDawuda ɓəp na pa̱, <<Iza̱ nak kang u gha̱p awo ɓu u gbá̱l ugargar àYawe ká̱, ayər nəm ɓu ka̱ ka̱t yà?>>
\p 
\v 15 Te uDawuda là ûro ka̱ ashe onunggwan wò pa̱, <<Ga, gbá̱l na.>> Te uza̱ gəl na ka̱ ndokchi kang uza̱ kú.
\v 16 UDawuda ka̱ là á na chit pa̱, <<Mpyat akat nchə̀r ɓu i təm ka̱ ishiɓu, ka̱kul mmaɓu na ká̱ anung ɓu, u là ka̱ awalang va̱ u là pa̱, <M gbá̱l uva̱ uYawe gar á.> >>
\s1 Nnap nshì aDawuda ngga ǹyə́ng ikú ka̱kul aShawulu ká̱ uJonatan
\p 
\v 17 UDawuda shì ìpyang va̱ ta̱ ka̱kul ikú aShawulu ká̱ uyiyen uJonatan,
\v 18 kang uza̱ nak pa̱ mmá ɗyang nnap-nshì va̱ ta ônəm oga aYahuda, aɗiɗin pa̱ nnap-nshì ngga ìjang, nna yà ka̱ ashe nlir aJashar.
\q1 
\v 19 <<Mmá gbá̱ng onəm oga mpyal ɓu chit áIsa̱rila,
\q2 oma kú ra ka̱ apal oga aɗuktum wó, oshozha okamkam tak chit.
\q1 
\v 20 Kang mmá shet nnap va̱ ta̱ ka̱ aGat ka̱t,
\q2 ka̱t te mmá là ka̱ apal oga asa̱l aAshəkelon\f + \fr 1.20 \ft AGat ká̱ aAshəkelon oga itong ichumchum oFilisti.\f* ka̱t.
\q1 Le kang ovan ochar oFilisti izər á chàng oza̱ ka̱t,
\q2 le kang ovan ochar onəm oga ache amulur izər á chàng oza̱ ka̱t.
\q1 
\v 21 Óga aɓam aGilbowa,
\q2 re kang ìmimyang á ra, ka̱t te iva̱r a pəng ka̱ apal wó ka̱t,
\q1 le kang mbin ndopdop wó a na ìpirkur lap ka̱t.
\q2 Ka̱kul ka̱ta na nggwanggwang ovan onunggwan okamkam mmá vyap kà̱,
\q2 nggwanggwang aShawulu mí ɓəl mmì a na lap ka̱t.
\q1 
\v 22 Ìjang aJonatan iga ngbá̱ng iriri,
\q2 ndokchi aShawulu ngga ǹya ká̱ aɗor ka̱t.
\q1 I gbá̱ng oshozha okamkam,
\q2 i gbá̱ng okpa ìkum.
\q1 
\v 23 Mma ma̱n uShawulu ká̱ uJonatan byet,
\q2 ká̱ irirì oza̱ nzəng, ká̱ ikú oza̱ kap ka̱t.
\q2 Kang oza̱ gha̱n ji oga nkumangga̱p ji, oza̱ kam ji oga ilir ji.
\q1 
\v 24 Óvanɓyen oga aIsa̱rila, ó yə́ng ka̱kul aShawulu,
\q2 uva mwak oga ilukwan inəna̱n a wó iga mbwai,
\q2 uva mwak ilukwan iga iya̱m ìsham iga azənariya a wó.
\q1 
\v 25 Ovan onunggwan ìkum okamkam tak chit ka̱ atak ìkum.
\q2 UJonatan ra chit ukúkú ka̱ apal aɗuktum wó.
\q1 
\v 26 Mmami ká̱ nlak ìgwak pa̱ gənggəng ka̱kul ɓu agənang mi, uJonatan, m ma̱n ɓu byet.
\q2 Mma̱n ɓu ka̱ atak mi a yà ka̱ mmàl ka̱t, a ji mma̱n achar ji ká̱ ununggwan.
\q1 
\v 27 Ovan onunggwan ìkum okamkam tak chit,
\q2 oga iya̱m ìkum zhì chit.>>
\c 2
\s1 Ma kyer uDawuda uponzhi uga aYahuda
\p 
\v 1 Ka̱ nva̱ng va̱ ta te, uDawuda ɓəp uYawe pa̱, <<N ga ìtong iro ka̱ ashe oga itong aYahuda ɗò?>>
\p Te uYawe na ama̱n pa̱, <<À, ga.>>
\p UDawuda ɓəp kà̱ɗi pa̱, <<Nza̱ ìtong n ga yà?>>
\p Kang uYawe na ama̱n pa̱, <<AHebron.>>
\p 
\v 2 Te uDawuda ga ka̱ta ká̱ ochar wò oga oparəm, uAhinoyam uga aJezerel, ká̱ uAbigel, uchar ukpələng aNabal, unəm uga aKarmel.
\v 3 UDawuda wur onunggwan va̱ nzəng ká̱ na kpa, uda nggo ká̱ nzhi wò kang oza̱ ga təm ka̱ aHebron ká̱ itutong.
\v 4 Te onunggwan oga aYahuda ɓa aHebron kang a gar uDawuda yà uponzhi ka̱ apal oYahuda.
\p Awalang va̱ mmá là ûDawuda pa̱ onunggwan oga aJabesh Gileyat li uShawulu chit,
\v 5 te uza̱ re onəm oga nre ká̱ nre ga ôza̱ pa̱, <<Re uYawe a pa̱r wó ka̱kul ikin va̱ ó nyám unəm uga nzhi wó uShawulu, nva̱ ó li na á.
\v 6 Re uYawe á nyám ikin ká̱ nnandər a wó, kang mi nyám ká̱ a wó kpa, ka̱kul iya̱m va̱ ta̱ ó nəm á.
\v 7 Ǹyangmata̱ te, ó nəm nkam ìgwak, ó sat pa̱ kakkərak, ka̱kul uShawulu unəm uga nzhi wó kú chit, kang onəm oga aYahuda gar mi chit uponzhi oza̱.>>
\s1 Mma nak uIshboshet yà uponzhi uga aIsa̱rila
\p 
\v 8 Ǹnyi te, uAbner uya aNer, unəm uga mpyal oshozha aShawulu, ka̱ yar uIshboshet chit uya uShawulu ga ká̱ ka̱ aMahanayim.
\v 9 Ka̱ta uza̱ nak na uponzhi ka̱ apal aGileyat, ká̱ aAshuri ká̱ aJezerel, kang ka̱ apal aEfrayim, ká̱ aBenjamin kpa ká̱ nkpaktak aIsa̱rila.
\p 
\v 10 UIshboshet uya aShawulu ká̱ ìzun ìsəm pa̱ ìneɗing ka̱ awalang va̱ mmá kyer na uponzhi ka̱ apal oIsa̱rila, kang uza̱ nəm iponzhi ìzun pa̱ ìparəm. Ǹnyi te, akum aYahuda ka̱ avəng aDawuda.
\v 11 UDawuda nəm iponzhi ka̱ apal akum aYahuda ka̱ aHebron ìzun pa̱ ìfangshat ká̱ aɓuɓo.
\s1 Ìkum ká̱ ishimshe aIsa̱rila ká̱ aYahuda
\p 
\v 12 UAbner uya aNer, nzəng ká̱ oshozha aIshboshet uya aShawulu, oza̱ wong re aMahanayim ga aGibiyon.
\v 13 UJowap uya aZeruya nzəng ká̱ oshozha aDawuda fa kang à gwang oza̱ ka̱ apyáp aga aGibiyon. Ìdongkong iga ìzəng təm ka̱ a gwong apyáp aro, kang iro təm ka̱ a gwong aro.
\v 14 UAbner là ûJowap pa̱, <<Re í nak ovan nza̱m oro á lung owan oza̱ ka̱ mpyal yi.>>
\p Te uJowap là pa̱, <<Aməma, re oza̱ á lung.>>
\p 
\v 15 Te mmá yak onunggwan pa̱ ogba̱pchi ama̱n pa̱ parəm ka̱ anung aBenjamin ká̱ uIshboshet uya aShawulu, kang pa̱ ogba̱pchi ama̱n pa̱ parəm ka̱ anung aDawuda.
\v 16 Udanggo kpán ukpa ìkum wò ka̱ ishi, kang à kyer ká̱ ndokchi ka̱ alyaklyak, te nkpaktak oza̱ tak kú. Mmá pa aɗin atak va̱ ta ka̱ ashe aGibiyon pa̱, aHelkat Hazurim, ipipir pa̱ agbagba aga ndokchi.
\p 
\v 17 Te ìkum va̱ ta sur byet n̂da va̱ ta, kang onunggwan aDawuda ri uAbner ká̱ onunggwan oga oIsa̱rila ká̱ ìkum.
\p 
\v 18 OVan onunggwan aZeruya oga oshatɗing oma ka̱ yà ka̱ ta, uJowap, ká̱ uAbishayi, ká̱ uAsahel. UAsahel, uva i chər wa nkar,
\v 19 a ɓàn ngwà uAbner, uza̱ lyep awo ari ka̱t te awo apəra̱m ka̱t.
\v 20 UAbner ga̱ɓa̱n kang à ɓəp na pa̱, <<Mmaɓu ɗò áAsahel?>>
\p UAsahel na ama̱n pa̱, <<À, mmami na.>>
\p 
\v 21 UAbner là á na pa̱, <<Ga̱ɓa̱n awo ari ka̱t te awo apəra̱m, na u ɓàk uro ka̱ ashe ovan nza̱m va̱ ta̱, na u vyat iya̱m ìkukum.>> Ǹnyi te, uAsahel re ngwà na ka̱t.
\p 
\v 22 UAbner won na kà̱ɗi pa̱, <<Re mɓàk mi. Mi gba̱l ɓu sang yà? Mi gba̱l ɓu te, mi gwang ìwu ká̱ ugənang ɓu uJowap sang yà?>>
\p 
\v 23 Ǹnyi te, uAsahel yang ká̱ nre ngwà na, kang uAbner tar na ká̱ ìjili aɓar ka̱ afu kang aɓar ga fa ka̱ asəsəm. Uza̱ ru ka̱ta kang uza̱ kú. Unəm va pa̱ kpaktak ɓa chu atak va̱ uAsahel ru kú kà̱ te, i sat i dər.
\p 
\v 24 Ǹnyi te, uJowap ká̱ uAbishayi ɓàk nva̱ng àAbner. Alum ka̱ ntar te, oza̱ chu aɗuktum aAmma dat ká̱ aGiya, ka̱ asa̱l a ga ngga nzam àGibiyon.
\v 25 Te oshozha aAbner ká̱ akum ìjili aBenjamin gwang ishi oza̱ təm ìdongkong pa̱ ìzəng ka̱ apal aɗuktum pa̱ na ó ga ìkum.
\p 
\v 26 UAbner lə́p achu ûJowap pa̱, <<Í ɗa̱mshi nnap yi ká̱ ndokchi na chwat ɗò? U nyi pa̱ nkukur te, iɗuɗul nkpaktak yi ka̱t ɗò? Azəmo ɓu wór onunggwan ɓu i re ngwà oIsa̱rila ogənang oza̱ yà?>>
\p 
\v 27 Te uJowap là á na pa̱, <<N sóng anung chit ká̱ Inan iga iriri, ká̱ yà pa̱ u là nnap va̱ ta̱ ka̱t te, í yar chit pa̱ í ɓàk wó atak i ga i tan.>>
\v 28 Te uJowap ɓur agbəshi kang nkpaktak oshozhashozha tong, oza̱ re ngwa oshozha oIsa̱rila, te oza̱ re nlung ìkum.
\p 
\v 29 Ka̱ ashe nkpaktak ìzwam va̱ ta uAbner ká̱ onunggwan wò le wòl mba̱nda̱m aUrdun. Oza̱ pa̱ng awang, oza̱ ga mpyal ka̱ achen ga chu ipin ikpa̱kkpa̱k ká̱ ìpin, oza̱ tong ka̱t ga chu aMahanayim.
\p 
\v 30 Nva̱ngva̱ uJowap re ngwà uAbner chit, te uza̱ ɓut nkpaktak oshozha wò. Kang uza̱ kúng oza̱ te, uza̱ lang onunggwan wò pa̱ ogba̱pchi ama̱n pa̱ fangzəngtəng gwang ká̱ uAsahel ka̱t.
\v 31 Ǹnyi te, onəm aDawuda gbá̱ng onəm aAbəner ìgba̱l pa̱ ishatɗing ká̱ ìsəm pa̱ ìkpa̱ɗing, nkpaktak oza̱ ka̱ akum ijili àBenjamin.
\v 32 UJowap ká̱ onəm wò yar akúm aAsahel ga aBet-Lehem ka̱, kang oza̱ ga li na ka̱ ashe awap apupon. Te oza̱ wong achen ká̱ izwam va̱ ta, oza̱ ɓa chu aHebron ka̱ atak tantàn.
\c 3
\p 
\v 1 Mmá nəm inok nnəm ìkum gba̱ng nva̱ng pa̱ makmak kà̱ ishimshe onəm oga nzhi àDawuda ká̱ onəm oga nzhi aShawulu. Ǹnyi te, uDawuda kà̱ nkám kà̱ nkám, kang nzhi aShawulu kà̱ nrusok kà̱ nrusok.
\p 
\v 2 Ovan onunggwan va ta̱ mmá mar ûDawuda ka̱ aHebron, uyen uga nggəshi te, uAmnon, uwa unənang uAhinoyam uga aJezerel.
\v 3 Uyen uga uparəm te, uKileyap, uwa unənang uAbigel, uchar àNabal ukpələng, uyen uga ushatɗing te, uAbsalom, uwa unənang uMaka uyen uchar àTalmai, uponzhi uga aGeshur.
\v 4 Uyen uga uneɗing te, uAdonija, uwa unənang uHagit. Uga utukun te, uShefatiya, uwa unənang uAbital.
\v 5 Kang uga ukpa̱ɗing te, uItireyam, uwa unənang uEgla. Nkpaktak ovan onunggwan va̱ ta̱ uDawuda mar ka̱ aHebron.
\s1 UAbner gwang inal ká̱ uDawuda
\p 
\v 6 Ka̱ awalang va̱ ìkum ka̱ yà ka̱ ishimshe nzhi aDawuda ká̱ nzhi aShawulu te, uAbner ka̱ nnak atak nsat wò kà̱ nkam kà̱ nkam ka̱ ashe nzhi aShawulu.
\v 7 UShawulu uwa ka̱ yà ká̱ uchar uro uva uza̱ nak ka̱ nzhi aɗiɗin pa̱, uRizpa, uya àAya uchar. Ká̱ n̂da nro te, uIshboshet ɓəp uAbner pa̱, <<Sang kang ɓu ra ká̱ uchar va̱ aPo mi nak ka̱ nzhi yà?>>
\p 
\v 8 Ìgwak làk uAbner byet ka̱kul iya̱m va̱ uIshboshet là á. Te uza̱ na ama̱n pa̱, <<U rəng pa̱ mi ra ìjili aShawulu ɗò? U rəng pa̱ mmami ka̱ nləp asəm aYahuda ɗò? N̂da va̱ ta̱ na n yà kà̱ nkpak nnap nnəm n̂zhi aPo ɓu uShawulu ká̱ ogənanggənang, ká̱ okpəkpa. Kang na n na ɓu chit ka̱ ashe awo aDawuda ka̱t. Ká̱ nna kpa te, ǹyangmata̱, ka̱ apal achar va ta̱ na ɓu ya mpat mi kà̱ ɗò?
\v 9 Re Inan á yar irirì mi, a yà pa̱ n nəm ûDawuda iya̱m va̱ uYawe yar nsar nnap nləlà á na ka̱ atak nsóng anung ka̱t á,
\v 10 nna pa̱ o tur iponzhi ka̱ nzhi aShawulu kang o pak ìtok iponzhi aDawuda ka̱ apal oIsa̱rila ká̱ aYahuda, i ɓàn ka̱ aDan i ga i chu aBeyersheba.>>
\v 11 UIshboshet là iya̱m iro ûAbner lap ka̱t, ka̱kul uza̱ kà̱ nnəm ayəyər.
\p 
\v 12 Te uAbner re nre ka̱ onəm oga re ga atak aDawuda pa̱ á ɓəp na pa̱, <<Mbin va̱ ta̱ nji a da yà? Yar nsar nnap-nlà ká̱ mi, te mi ka̱mshi ɓu, mi ɓa ká̱ nkpaktak oIsa̱rila i yà ka̱ avəng ɓu.>>
\p 
\v 13 UDawuda na ama̱n pa̱, <<A ɓyen byet, mi yar nsar nnap-nlà yar ká̱ ɓu. Ǹnyi te, n ɗom iya̱m iro pa̱ izəng ka̱ atak ɓu, kang wa ɓa mpyal mi ka̱t, ya ɓu ɓa ká̱ uMikal uya aShawulu uchar kang, awalang va̱ ɓu ɓa ǹya mi á.>>
\v 14 Te uDawuda re onəm oga ǹre ûIshboshet uya aShawulu ununggwan, na á là a na pa̱, <<Na uchar mi uMikal á mi, uva n mwa ìdudur ka̱ oga awa ache oFilisti ìgba̱l.>>
\p 
\v 15 Te uIshboshet nak ga mma yar uMikal ka̱ atak aɓəɓar uPaltiyel, uya aLayish ununggwan.
\v 16 Uɓəɓar yar nva̱ng achar wò ká̱ ayə́ng á ga chu ká̱ ka̱ aBahurim. Te uAbner là á na pa̱, <<Le nzhi.>> Te uza̱ le nzhi.
\p 
\v 17 UAbner nəm ichən ká̱ onəmgbak oIsa̱rila kang à là pa̱, <<A gba̱ng nva̱ng chit nva̱ ka̱ ó ɗom uDawuda pa̱ a yà uPonzhi wó.
\v 18 Ǹyangmata̱ te, o nəm iya̱m va̱ màl, ka̱kul uYawe ka̱ yar nsar nnap-nlà ûDawuda pa̱, <Ka̱ atak aDawuda na mi ka̱mshi onəm mi oIsa̱rila ka̱ ashe awo oFilisti ká̱ nkpaktak aɓo okpa ìkum oza̱.> >>
\p 
\v 19 UAbner là nnap ká̱ akum ìjili aBenjamin kpa. Te uza̱ ga aHebron ka̱ atak aDawuda pa̱ ô là á na iya̱m va̱ oIsa̱rila ká̱ nkpaktak akum ijili aBenjamin ɗom pa̱ ó nəm.
\v 20 Awalang va̱ uAbner ká̱ onəm ìsəm pa̱ ìparəm ga aHebron te, uDawuda nəm iya̱m-nrì iga nchang izər ôza̱.
\v 21 Te uAbner là ûDawuda pa̱, <<Re n ga n wór nkpaktak oIsa̱rila á ɓa atak anəm uga nzhi mi, uponzhi na oza̱ á yar nsar nnap-nlà ká̱ ɓu, kang ɓu nəm iponzhi ka̱ apal oza̱, wa nva ìgwak ɓu ɗom.>> Te uDawuda re uAbner, kang uza̱ le nzhi ká̱ ikángkáng.
\s1 UJowap Gba̱l uAbner
\p 
\v 22 Ta byet te, onəm ìkum aDawuda ká̱ uJowap le ka̱ atak ìkum, kang oza̱ ɓa ká̱ iya̱m iga ngwur ka̱ atak ìkum pa̱ makmak. Ǹnyi te, uAbner yà nzəng ká̱ uDawuda ka̱ aHebron lap ka̱t, ka̱kul uDawuda re na chit, uza̱ ga ká̱ ikángkáng.
\v 23 Awalang va̱ uJowap ká̱ nkpaktak oshozha va̱ nzəng ká̱ na ɓa chu te, uza̱ fe pa̱ uAbner ɓa atak aponzhi kang uza̱ le chit ká̱ ikángkáng.
\p 
\v 24 Te uJowap ga atak aponzhi kang à là á na pa̱, <<Iza̱ u nəm ta̱ yà? Dər uAbner ɓa atak ɓu, sang kang u re na ga yà? Ǹyangmata̱ uza̱ ga chit.
\v 25 U nyi pa̱, uAbner uya aNer ununggwan ɓa pa̱ ô lam ɓu na ô ya achen ɓu ká̱ nkpaktak iya̱m va̱ mmaɓu ka̱ nnənəm.>>
\p 
\v 26 UJowap fa ka̱ atak aDawuda te, uza̱ re onəm oga ǹre pa̱ a ga á ɓa ka̱ uAbner kang oza̱ ga ya na kà̱ ndəng nka̱pka̱p ngga aSira, oza̱ ɓa ká̱ na. Ǹnyi te, uDawuda nyi iya̱m iro ka̱ apəpal ka̱t.
\v 27 Nva̱ uAbner ɓa chu aHebron te, uJowap tar ká̱ na ka̱ ashe nzhi ngga ngba̱k anung asa̱l aga ntar ìtong wa uza̱ ɗom nnəm ichən ká̱ na. Te uza̱ kyer uAbner ka̱ afu a gba̱l na, ka̱kul mpyát akat agənang wò, uAsahel va̱ uza̱ ka̱ gbá̱l á.
\p 
\v 28 UDawuda wong fe nnap va̱ ta̱ te, uza̱ là pa̱, <<UYawe nyinyi pa̱ mmami ká̱ iponzhi mi mbyet, awo yi yà ka̱ ashe ntar nchə̀r aAbner, uya aNer ununggwan ka̱t.
\v 29 Re mpyat akat nchə̀r aAbner á yà ka̱ apal ishi aJowap ká̱ nkpaktak nzhi apupo. Re nza̱ nlwàk nggo ka̱ ashe onəm aJowap kang mma lang unəm uga ngwàr afən, ka̱t te unəm uga nlak, ka̱t te unəm uga nta ká̱ ìdari, ka̱t te unəm va mma gba̱l ka̱ atak ìkum, ka̱t te unəm uga nlang iya̱m-nrì ka̱ ashe onənəm ka̱t.>>
\p 
\v 30 Wa nna ta uJowap ká̱ ugənang wò uAbishayi gbá̱l uAbner ka̱kul agənang oza̱ uAsahel uva uAbner gbá̱l ka̱ atak ìkum ka̱ aGibiyon á.
\p 
\v 31 Te uDawuda là ûJowap ká̱ nkpaktak onəm va̱ nzəng ká̱ na pa̱, <<Ó kan ilukwan wó na ó mwak aryakryak na ó yə́ng ikú aAbner.>> Kang uponzhi uDawuda yar nva̱ng akúm ga ká̱ ka̱ atak awap.
\v 32 Oza̱ li uAbner ka̱ aHebron te, uponzhi tul ayə́ng pa̱ bobo ka̱ anung awap aAbner, kang nkpaktak onəm bà ayə́ng kpa.
\p 
\v 33 Te uponzhi shì ìpyang va̱ ta̱ ûAbner pa̱,
\q1 <<Iza̱ nak kang uAbner ikú wa mpərək yà?
\q2 
\v 34 Mmá ran awo a ɓu ka̱t,
\q1 mmá pá nzwar a ɓu ka̱ ashar ka̱t.
\q2 U kú wa anəm va onəm oɓá̱ngɓa̱ng à gbá̱l.>>
\m Kang nkpaktak onəm yə́ng kà̱ɗi ka̱kul aAbner.
\p 
\v 35 Te nkpaktak onəm ɓa chal uDawuda pa̱ uza̱ á ri iya̱m-nrì ká̱ alum na byet, ǹnyi te, uDawuda sóng anung pa̱, <<Re Inan á yar irirì mi, a yà pa̱ n ri iya̱m iro kang alum i tar á.>>
\p 
\v 36 Nkpaktak onəm dər nnap va̱ ta te, á chàng ká̱ oza̱, nkpaktak iya̱m va̱ uponzhi nəm te, á chəchàng ká̱ oza̱.
\v 37 Ká̱ nda va̱ ta te, nkpaktak onəm va̱ ka̱ ta ká̱ nkpaktak oIsa̱rila nyi pa̱ uponzhi yà ká̱ awo ka̱ ashe ngbá̱l uAbner uya aNer ununggwan ka̱t.
\p 
\v 38 Te uponzhi là ônəm wò pa̱, <<Ó nyinyi pa̱ n̂da va̱ ta̱ unəm uga mpyal ìkum uchumchum ka̱ ashe aIsa̱rila kú chit ka̱t ɗò?
\v 39 Kang n̂da va̱ ta̱, káp ká̱ nva̱ mmami na uponzhi ugargar te, ovan aZeruya onunggwan oga oparəm va̱ ta̱, uJowap ká̱ uAbishayi oza̱ ma̱t mi ma̱t. Re uYawe á pyat akat ûnəm uga nnəm inga ka̱kul ingənga va̱ uza̱ nəm á.>>
\c 4
\s1 Mma gba̱l uIshboshet
\p 
\v 1 Awalang va̱ uIshboshet, uya aShawulu ununggwan fe ikú aAbner ka̱ aHebron te, igwal rusok ka̱ na, kang ayər nəm nkpaktak oIsa̱rila.
\v 2 Ǹyangmata̱ te, uIshboshet uya aShawulu ununggwan uwa ka̱ yà ká̱ onəm pa̱ oparəm, uBana ká̱ uRekap, ova onəm oga mpyal onəm oga mɓa nru atak ká̱ ìkum. Oma ovan aRimmon onunggwan, unəm uga aBerot ka̱ akum ìjili àBenjamin kang mma nak pa̱ aBerot ka̱ ashe mbin aBenjamin,
\v 3 ka̱kul onəm oga aBerot chəng ga aGitayim, oza̱ ga təm ka̱ta wa onəmchən n̂da va̱ ta̱.
\p 
\v 4 UJonatan uya aShawulu ununggwan uwa ka̱ yà ká̱ uyen ununggwan ugurum, aɗiɗin pa̱ uMefiboshet. Uza̱ ka̱ ya ká̱ ìzun pa̱ ìtukun awalang va̱ mmá fe ikú aShawulu ká̱ uJonatan ka̱ atak ìkum ka̱ aJezerel. Te uchar va̱ i nakshi ká̱ uyen va̱ ta yar na ká̱ nggha̱n chə́r ká̱. Uza̱ ka̱ ashe nchə́r te, uyen va̱ ta ru te, yà ugurum.
\p 
\v 5 URekap ká̱ uBana, ovan aRimmon onunggwan unəm oga aBerot, oza̱ ga nzhi aIshboshet ká̱ alum ka̱ apal ndəng ya uza̱ wa ka̱ nra ka̱ njul.
\v 6 Oza̱ táng ashe nzhi na oza̱ kà̱ nɗom pa̱ ó yar ìzangzəng te, oza̱ kyer na ka̱ afu, kang uRekap ká̱ uBana chəng.
\p 
\v 7 Awalang va̱ oza̱ ka̱ ga ashe nzhizhi te, ya uIshboshet uwa ka̱ nra nda ka̱ apal alyer wò. Te oza̱ kyer na, kang oza̱ gbá̱l na, oza̱ gəl ishishi, kang oza̱ yar chen ka̱ ka̱ ashe nkpaktak ìzwam va̱ ta kà̱ mba̱nda̱m aUrdun.
\v 8 Oza̱ ɓa ká̱ ishi aIshboshet ûDawuda ka̱ aHebron, kang oza̱ là ûponzhi pa̱, <<Ishi aIshboshet uya aShawulu ununggwan nata̱, ukpa ìkum ɓu, uva ka̱ ram irirì ɓu á. N̂da va̱ ta̱ uYawe pyát ûnəm uga nzhi yi uponzhi chit ka̱ apal ishi aShawulu ká̱ nzhizhi.>>
\p 
\v 9 Te uDawuda na ama̱n ûRekap ká̱ ugənanggənang uBana, ovan aRimmon onunggwan unəm uga aBerot pa̱, <<Ká̱ nva̱ uYawe uwa yà ká̱ irirì, uva fa ká̱ mi ka̱ ashe nkpaktak nɗaktak,
\v 10 awalang aro te, unəm uro ɓa atak mi ka̱ aZiklak là á mi pa̱, <UShawulu kú chit,> kang uza̱ rəng pa̱ ò ɓa ka̱ nnap ngga nchàng nfe á mi, te n kpan na n gbá̱l. Amumwa na n na á na ta ka̱kul nnap va̱ uza̱ ɓa ka̱ á.
\v 11 Kang mmawó onəm oɓá̱ngɓa̱ng va̱ ta̱, ó gbá̱l unəm unəna̱n ka̱ ashe nzhizhi ka̱ apal iya̱m nrəra, i ga mɓa̱ng a wó i jiji. Mí ram nchə̀chər ka̱ ashe awo wó, kang mí dəkən wó ka̱ apambin va̱ ta̱.>>
\p 
\v 12 Te uDawuda nak oshozha wò pa̱ á gbá̱ng oza̱, kang oza̱ gbá̱ng oza̱. Oza̱ kyen oga awo ká̱ ashar oza̱, kang oza̱ zong izər oza̱ ka̱ anung apyáp ka̱ aHebron. Ǹnyi te, oza̱ yar ishi aIshboshet ga li ka̱ ashe awap aAbner ka̱ aHebron.
\c 5
\s1 UDawuda nyang uponzhi ka̱ apal oIsa̱rila
\p 
\v 1 Nkpaktak akum ìjili oIsa̱rila ga atak aDawuda ka̱ aHebron kang oza̱ là á na pa̱, <<Mmayi ìzhe ɓu, mmayi nchə̀r ɓu.
\v 2 Ká̱ mmatmat, awalang va̱ uShawulu wa ka̱ yà uponzhi ka̱ apal yi te, mmaɓu na ka̱ yà unəm uga nlə́p mpyal oIsa̱rila ka̱ ìkum. Kang uYawe là a ɓu pa̱, <Ɓu ga nkpak onəm mi oIsa̱rila, kang ɓu yà unəm uga mpyal oza̱.> >>
\p 
\v 3 Awalang va̱ nkpaktak onəmgbak oIsa̱rila ɓa atak aPonzhi uDawuda ka̱ aHebron te, uponzhi yar nsar nnap ká̱ oza̱ ka̱ mpyal aYawe, kang oza̱ gar uDawuda uponzhi ka̱ apal oIsa̱rila.
\p 
\v 4 UDawuda ka̱ yà ká̱ ìzun ìsəm pa̱ ishatɗing ka̱ awalang va̱ uza̱ yà uponzhi, kang uza̱ nəm iponzhi ìzun ìsəm pa̱ ìneɗing.
\v 5 Uza̱ nəm iponzhi ka̱ apal aYahuda ka̱ aHebron ìzun pa̱ ìfangshat ká̱ apye pa̱ kpa̱ɗing, kang ka̱ aUrushelima te, uza̱ nəm iponzhi ka̱ apal nkpaktak aIsa̱rila ká̱ aYahuda ìzun ìsəm pa̱ ishatɗing ama̱n pa̱ shatɗing.
\s1 UDawuda ka̱m ìtong aUrushelima ká̱ ìkum
\p 
\v 6 Uponzhi ká̱ onunggwan wò ga aUrushelima ka̱kul pa̱ na ó ru oJebusi ká̱ ìkum va̱ ka̱ ntəm ka̱ta. OJebusi là ûDawuda pa̱, <<Ɓu yà ka̱ ǹtar ka̱ta̱ ka̱t, onəm ofofo ká̱ onəm ogurumgurum kur mɓak ɓu kur.>> Oza̱ rəng pa̱, << UDawuda i tar ka̱ta̱ ka̱t.>>
\v 7 ASiyona na yà ká̱ akamsəlang akamkam, kap ka̱ nna te, uDawuda ri ká̱ ìkum, kang a ta̱l ìTong aDawuda.
\p 
\v 8 N̂da va̱ ta uDawuda là ônəm wò pa̱, <<Unəm va pa̱ kap ɗom pa̱ ô nəm igwan ká̱ oJebusi te, nkpak pa̱ uza̱ i wòl asa̱l ka̱ asa̱l va ndəng inang kà̱, ka̱ asa̱l va ta o ru <onəm ogurumgurum ká̱ ofofo> ova okpa ìkum aDawuda á.>> Nna nak te, oza̱ i là pa̱, <<Onəm ofofo ká̱ ogurumgurum i táng ashe nzhi iponzhi ka̱t.>>
\p 
\v 9 UDawuda nak ìtong iga akamsəlang akamkam va̱ ta təm atak ntətəm, kang uza̱ wór pa̱ ìTong aDawuda. Uza̱ me akamsəlang abalbal gang ìtong va̱ ta, ɓàn ka̱ aMilo, atak va mma yə́l ká̱ mbin ka̱ asa̱l nfa alum aɗuktum.
\v 10 Kang uza̱ yà ká̱ ichumchum pa̱ gənggəng ka̱kul uYawe, Inan uGa ngGatək uwa yà nzəng ká̱ na.
\p 
\v 11 Ǹyangmata̱ te, uHiram uponzhi uga aTaya re nre ká̱ onəm oga ǹre ûDawuda, nzəng ká̱ akún asida, ká̱ onəm oga mpak iya̱m ká̱ akún, ká̱ onəm oga mme nzhi ngga ipang, kang oza̱ me nzhi iponzhi ûDawuda.
\v 12 Te uDawuda nyi pa̱ uYawe nak wò chit ò ta̱l uponzhi ka̱ apal oIsa̱rila, kang uza̱ rup ká̱ iponzhiponzhi chit kpa ka̱kul onənəm oIsa̱rila.
\p 
\v 13 Ka̱ nva̱ngva̱ uDawuda wong re aHebron te, uza̱ ka̱m ochar va mí nak ka̱ ashe nzhi pa kùk kang uza̱ ka̱m ochar oga ìvang ka̱ aUrushelima, kang oza̱ mar ovan onunggwan ká̱ ovan ochar á na pa̱ makmak.
\v 14 Oga aɗin ovan onunggwan va ta̱ mma mar ûDawuda ka̱ aUrushelima, uShammuwa, ká̱ uShobap, ká̱ uNatan, ká̱ uSolomon,
\v 15 ká̱ uIbhar, ká̱ uElishuwa, ká̱ uNefek, ká̱ uJafiya,
\v 16 ká̱ uElishama, ká̱ uEliyada, ká̱ uElifelet.
\s1 UDawuda ri oFilisti ká̱ ikum
\p 
\v 17 Awalang va̱ oFilisti fe chit pa̱ mma kyer uDawuda chit uponzhi ka̱ apal oIsa̱rila, te oza̱ fa pa̱ kpaktak ga nram na. Ǹnyi te, uDawuda fe te, a fa ga atak mbwam.
\v 18 OFilisti ɓa chu te, oza̱ zal ka̱ ashe mba̱nda̱m aRefayim.
\v 19 Te uDawuda ɓəp uYawe pa̱, <<N ga n ru oFilisti ká̱ ìkum ɗò? Ɓu na oza̱ na ka̱ ashe awo mi ɗò?>>
\p Te uYawe na ama̱n a na pa̱, <<Ga, nnandər, mi na oza̱ na ka̱ ashe awo ɓu.>>
\p 
\v 20 Te uDawuda ga aBal Perazim, kang ka̱ta uza̱ nəm igwan ká̱ oFilisti. Uza̱ là pa̱, <<Wa nva ndəng kakchi awang te, uYawe tul onəm ìkum mi chit ka̱ mpyal mi.>> Ka̱kul nva̱ ta te, mí wor atak va̱ ta pa̱, aBal Perazim, ìpipir pa̱ uYawe uwa tul.
\v 21 OFilisti chəng re oga ichər oza̱ ka̱ta, kang uDawuda ká̱ onungwan wò wur oza̱ ga ká̱.
\p 
\v 22 OFilisti le ɓa zal ka̱ mba̱nda̱m aRefayim kà̱ɗi.
\v 23 Te uDawuda ɓəp ka̱ atak aYawe, kang uYawe na ama̱n á na pa̱, <<Kang wa ga ka̱ oza̱ nzwang ka̱t, ǹnyi te, fa ôza̱ ka̱ asa̱l nsəm, kang ɓu ru oza̱ ká̱ ìkum ka̱ mpyal ikun abalsam.
\v 24 Wa fe na byet atak i pyep i chən ka̱ apal ikun abalsam te, wa ga ká̱ nggha̱n ka̱kul nna ta i nyám pa̱ uYawe watar mpyal a ɓu chit pa̱ na ô gbá̱ng oshozha oFilisti.>>
\v 25 Te uDawuda nəm wa nva uYawe ka̱ nak na, kang uza̱ ɓan ngbá̱ng oFilisti ka̱ aGibiyon ga chu aGezer.
\c 6
\s1 UDawuda ɓa ká̱ akwati aga nsar nnap-nlà ka̱ aUrushelima
\p 
\v 1 UDawuda ɓut nkpaktak oshozha oga ǹnyi nnəm ìkum ka̱ɗi oga aIsa̱rila, ìkalong ìsəm pa̱ ishatɗing.
\v 2 Uza̱ ká̱ nkpaktak oshozha wò ga aBala ka̱ aYahuda pa̱ na o ɓa ká̱ akwati aga nsar nnap-nlà Inan va̱ ka̱ ta, ava mí wór ká̱ Aɗin, aɗin àYawe uGa ngGatək, uva təm ka̱ ìtok iponzhi va ka̱ apal akwati aga nsar nnap-nlà ka̱ ishimshe oga akerup\f + \fr 6.2 \fq akerup \ft Iya̱m iga apaɓúr ká̱ abasəm, iva i nyám ǹyà àYawe ká̱ ichumchumchumchum.\f*.
\v 3 Oza̱ yar akwati aga nsar nnap-nlà Inan ka̱ nzhi aAbinadap, nva ka̱ apal aɗuktum, oza̱ nak ka̱ apal akeke apipye va ina i dap. UUza ká̱ uAhiyo, ovan aAbinadap onunggwan, oma ka̱ mpángchí akeke apipye va ina i dap á,
\v 4 nzəng ká̱ akwati aga nsar nnap-nlà Inan ka̱ apəpal, kang uAhiyo uwa kà̱ nchen kà̱ mpipyal.
\v 5 UDawuda ka̱ nkpaktak oIsa̱rila kà̱ nnəm nchang izər ká̱ nkpaktak ìkam oza̱ kà̱ mpyal aYawe, oza̱ kà̱ nshì nnap-nshì, ká̱ nnə́m oga iya̱m wa aɓwa, ká̱ aɓwa acham, ká̱ apa̱ngga̱ng, ká̱ aláláji, ká̱ nchanggong.
\p 
\v 6 Oza̱ ɓa chu atak mpək iya̱m aga aNakon te, uUza yichi awo kpan akwati aga nsar nnap-nlà Inan ká̱ ka̱kul ina va̱ kà̱ ndap akeke va̱ ta ləp ìfang.
\v 7 Te ìgwak làk uYawe ka̱ uUza, ka̱kul uza̱ na ichumchum Înan ka̱t, nva̱ uza̱ kpan akwati va̱ ta á. A nak te, Inan ləp na kang uza̱ ru kú ka̱ ngba̱k akwati va̱ ta.
\p 
\v 8 Te uDawuda mən ìkum, ka̱kul nva̱ uYawe nyám nlak igwak ka̱ apal aUza á, kang ɓa chu n̂da va̱ ta̱ mí wor atak va̱ ta pa̱, aPerez aUza, ìpipir pa̱ ǹnyám nlak ìgwak ka̱ apal aUza.
\p 
\v 9 UDawuda nəm ayər aYawe n̂da va̱ ta, kang uza̱ là pa̱, <<Mi nəm sang kang akwati aga nsar nnap-nlà aYawe va̱ ta̱ i ɓa atak mi yà?>>
\v 10 Uza̱ ɗom pa̱ o yar akwati aYawe va̱ ta a yà nzəng ka̱ wò ka̱ ashe ìTong aDawuda ka̱t. Ka̱ɗor nva̱ ta te, uza̱ ga ká̱ ka̱ nzhi aObet Edom unəm uga aGat.
\v 11 Akwati aYawe təm ka̱ ashe nzhi aObet Edom ape pa̱ shatɗing, kang uYawe pa̱r na ká̱ nkpaktak onənəm.
\p 
\v 12 UPonzhi uDawuda fe pa̱, <<UYawe pa̱r nzhi aObet Edom chit ká̱ nkpaktak iya̱m va̱ uza̱ ka̱, ka̱kul akwati aga nsar nnap-nlà Inan va̱ ta.>> Te uDawuda fa ga pa̱ ô ɓa ká̱ akwati va̱ ta ka̱ ashe ìTong aDawuda ká̱ nchang ìgwak.
\p 
\v 13 Ka̱ nva̱ngva̱ onəm oga ǹyar akwati aga nsar nnap-nlà aYawe va̱ ta ga ka̱ chit ntong ashar pa̱ kpa̱ɗing, te uDawuda yichi nləfər ngga akut ká̱ iya ina va̱ mma kang ka̱ nzhi.
\v 14 UDawuda pá ìlukwan ìkwoksok iga alinin, kang uza̱ gba̱p nza̱m ká̱ kà̱ mpyal aYawe ká̱ kpaktak ikam wò,
\v 15 nva̱ uza̱ ká̱ nkpaktak oIsa̱rila kà̱ mɓa ká̱ akwati aga nsar nnap-nlà aYawe te, oza̱ kà̱ ngham achu ká̱ mɓur oga agbəshi.
\p 
\v 16 Nva̱ akwati aga nsar nnap-nlà aYawe kà̱ ntar ashe ìTong aDawuda te, uMikal uya aShawulu uchar ɓál kà̱ mɓol ayir nzhi. Kang awalang va̱ uza̱ ya uPonzhi uDawuda kà̱ myat kang kà̱ ngba̱p nza̱m kà̱ mpyal aYawe te, uza̱ ɓak na ka̱ ashe ìgwak wò.
\p 
\v 17 Oza̱ ɓa ká̱ akwati aga nsar nnap-nlà aYawe kang oza̱ nak ka̱ ashe aghal va̱ uDawuda pak ka̱kukul á, kang uDawuda yichi oga iya̱m inana iga nshì pa̱ ɗwot ká̱ iga ntəm ikángkáng kà̱ mpyal aYawe.
\v 18 Nva̱ngva̱ uza̱ gba̱l ká̱ ǹyichi oga iya̱m inana iga nshì pa̱ ɗwot ká̱ iga ntəm ikángkáng te, uza̱ pa̱r onəm ka̱ ashe aɗin aYawe uGa ngGatək.
\v 19 Te uza̱ kap nzəngkəng ká̱ awar akulom aɓitɓit ká̱ awar ìba̱ngba̱ng mɓitɓit n̂za̱ unəm nggo ka̱ ashe nkpaktak nggatək oIsa̱rila, nkpaktak onunggwan ká̱ ochar. Kang nkpaktak onəm le oga nzhi oza̱.
\p 
\v 20 Awalang va̱ uDawuda le nzhi pa̱ na ô pa̱r onəm oga ashe nzhi wò te, uMikal uya aShawulu uchar fa pa̱ na ô gwang na, kang à là pa̱, << Uponzhi oIsa̱rila nəm iya̱m ichumchum chit ká̱ n̂da va̱ ta̱, nva̱ uza̱ bol izər re kà̱ mpyal ozwal ovan ochar ozuzwal wa nva nza̱ uyen uga ayə́r nggo i nəm á.>>
\p 
\v 21 UDawuda na ama̱n ûMikal pa̱, <<N gba̱p nza̱m ka̱ mpyal aYawe, uva yak mi ka̱ɗor apo ɓu, ka̱t te nza̱ unəm nggo ka̱ ashe nzhizhi. Uza̱ nak mi chit n sat unəm uga mpyal onəm aYawe chit, oIsa̱rila. Ka̱kul nva̱ ta te, mi nəm nchang izər kà̱ mpyal aYawe.
\v 22 Mi ɓak ishi mi ɓak i ji nva̱ ta̱ kang mi yen ká̱ ishi mi yen ka̱ mpyal ɓu. Ǹnyi te ovan ochar va̱ u là nnap oza̱ te, oza̱ i na ichumchum na á mi.>>
\p 
\v 23 Te uMikal, uya aShawulu uchar mar ka̱t ga kú pa.
\c 7
\s1 Inan yar nsar nnap-nlà ûDawuda
\p 
\v 1 Nva̱ngva̱ uPonzhi uDawuda təm chit ka̱ ashe nzhi iponzhi wò, kang uYawe na njul á na chit ka̱ atak nkpaktak okpa ìkukum va̱ gang na,
\v 2 te uza̱ là ûNatan unəm uga nlà ichu Inan pa̱, <<Dər, mmami ka̱ nra ka̱ ashe nzhi iponzhi ngga akun asida, kang akwati aga nsar nnap-nlà Inan na təm ka̱ ashe aghal.>>
\p 
\v 3 UNatan na ama̱n ûponzhi pa̱, <<Nkpaktak iya̱m va̱ mmaɓu ká̱ ka̱ ashe ìgwak te, wa ga mpyal ká̱, nəm ka̱kul uYawe wa nzəng ká̱ ɓu.>>
\p 
\v 4 Ká̱ izwam va̱ ta te, uYawe là ûNatan pa̱,
\pi1 
\v 5 <<Ga là ûzwal mi uDawuda pa̱, iya̱m va ta̱ uYawe là, <Mmaɓu na ɓu me nzhi á mi nva̱ mi təm ka̱ ashishe ɗò?
\v 6 N na n təm chit ka̱ ashe nzhi nro ka̱t, ɓàn ka̱ n̂da va̱ n fa ká̱ oIsa̱rila ka̱ ashe aMasar ɓa chu nda va̱ ta̱. Mmami ka̱ nranggang pa̱ ɗəkər ka̱ aghal, nna atak ntəm mi.
\v 7 Nkpaktak atak va̱ n ga ka̱ ká̱ oIsa̱rila te, ka̱ n là ûnəm uro chit ka̱ ashe onəm oga mpyal oIsa̱rila va̱ n nak pa̱ á kpak onəm mi oIsa̱rila pa̱, <<Sang kang u me nzhi ngga akun asida a mi ka̱t yà?>> >
\pi1 
\v 8 <<Ǹyangmata̱ te, là ûzwal mi uDawuda pa̱, <Iya̱m va ta̱ uYawe uGa ngGatək là. N yar ɓu ya na mmaɓu kà̱ nkpak iya̱m nkang kang n nak ɓu u yà unəm uga mpyal onəm mi oIsa̱rila.
\v 9 Na ka̱ n yà nzəng ká̱ ɓu ka̱ nza̱ atak nggo va̱ u ga, kang n zhì nkpaktak okpa ìkum ɓu ka̱ mpyal ɓu. Ǹyangmata̱ mi ga nnak aɗin ɓu i dam, wa aɗin onəm odamdam ka̱ ashe apambin.
\v 10 Kang mi ga nna atak ônəm mi oIsa̱rila kang mi nak oza̱ i təm kà̱ na oza̱ a yà ká̱ nzhi ngga ishi oza̱ kang mí ɗak oza̱ lap ka̱t. Onəm oɓá̱ngɓa̱ng i ka̱r oza̱ lap ka̱t, wa nva̱ oza̱ ka̱ nəm ôza̱ mmatmat á,
\v 11 kang oza̱ ka̱ yà ka̱ nnəm pa ka̱ awalang va̱ n nak onəm oga mpyal ônəm mi oIsa̱rila. Mi ga nna njul a ɓu kpa ka̱ atak nkpaktak okpa ìkum ɓu.
\pi1 << <UYawe là a ɓu pa̱, mmawò na ká̱ ishi wò ò ga nnak nzhi ɓu i nəm iponzhi mbyet.
\v 12 Awalang va̱ nra ɓu chu chit kang u kú te, mi ga ngwong ká̱ uro ka̱ ashe akum ijili ɓu pa̱ a yar atak nsat ɓu, kang mi pak iponzhiponzhi ìkam.
\v 13 Uza̱ wa i me nzhi ka̱kul aɗin mi. Kang mi pak itok iponzhiponzhi i təm mbyet.
\v 14 Mi yà upupo, kang uza̱ i yà uyen mi ununggwan. A yà pa̱ uza̱ á nəm mpat te, mi nəm inok ká̱ onəm i nyám ntàn á na. Onəm oma i sat nlilyat á na.
\v 15 Ǹnyi te, mi yar mma̱n mi i le ka̱ apal ishishi ka̱t, wa nva̱ n yar ka̱ le ka̱ apal aShawulu á, uva n tur na le kang n nak ɓu uponzhi á.
\v 16 Nzhi ɓu ká̱ iponzhi ɓu i ga ntəm kà̱ mpyal mi mbyet, kang mi ga mpak ìtok iponzhi ɓu mbyet.> >>
\p 
\v 17 UNatan là ûDawuda nkpaktak oga iya̱m va̱ ka̱ ashe alár va̱ ta̱.
\s1 Afar aDawuda aga aɗəngchi
\p 
\v 18 Te uPonzhi uDawuda tar kang à təm kà̱ mpyal aYawe, kang uza̱ là pa̱,
\pi1 <<Mmami uda yà, uNəm Uga Nzhi uYawe, onəm mi oda yà, kang u gha̱p mi wa nta̱ yà?
\v 19 Kang na ka̱ nna à kúr ka̱ ɓu chit ka̱t, uNəm Uga Nzhi uYawe, u là nnap chit kpa ka̱ apal iya̱m va̱ i ga nyà kà̱ nzhi azwal ɓu ká̱ nnap mpakpak va̱ ta̱. uNəm Uga Nzhi uYawe, wanta̱ na ɓu nəm ûnəmləbər ɗò?
\pi1 
\v 20 <<Iza̱ mi là a ɓu lap yà? Ka̱kul u nyi uzwal ɓu nyi, aYawe uGa iChumchum.
\v 21 Ka̱kul nnap-nlà ɓu kang ka̱ atak nɗom ɓu, u nəm iya̱m ichumchum va̱ ta̱, kang u nak uzwal ɓu nyi.
\pi1 
\v 22 <<Mmaɓu na uga uchumchum, aYawe uGa iChumchum. Unəm uro yà wa nji ɓu ka̱t kang Inan iro yà wa nji ɓu ka̱t, wa nva̱ i fe ká̱ oga achwang yi á.
\v 23 Kang uda wa onəm ɓu oIsa̱rila yà? Mbin nro yà ka̱ apambin nva̱ Inan ga pa̱ ô ka̱m ishi oza̱ îshi wò na ô nəm aɗin îshi wò ka̱t. U nəm iya̱m ichumchum ôza̱ ká̱ iga nɗaktak, ka̱ atak mɓak oga mbin ká̱ oga inan oza̱ ka̱ mpyal onəm ɓu ova u ka̱m ishi oza̱ îshi ɓu ka̱ aMasar á.
\v 24 U nak oIsa̱rila chit tong onəm ɓu mbyet, kang mmaɓu, áYawe, u yà Inan oza̱.
\pi1 
\v 25 <<Kang ǹyangmata̱, áYawe Inan, nəm wa nva u yar nsar nnap-nlà ka̱ apal ishi azwal ɓu ká̱ nzhizhi mbyet. Yəl ká̱ wa nva̱ ka̱ u yar chit,
\v 26 na aɗin ɓu a rup mbyet. Te onəm i là pa̱, <UYawe uGa ngGatək uwa Inan oIsa̱rila.> Kang ɓu ga nnak nzhi azwal ɓu uDawuda i təm ka̱ mpyal ɓu.
\pi1 
\v 27 <<ÁYawe uGa ngGatək, Inan oIsa̱rila, u nyám ká̱ iya̱m va̱ ta̱ chit ûzwal ɓu, u là pa̱, <Mi nak nzhi ɓu i nəm iponzhi mbyet.> A nak te, ìgwak kam ûzwal ɓu pa̱ afar afar va̱ ta̱ a ɓu.
\v 28 ÁYawe uGa iChumchum, mmaɓu na Inan. Nsar nnap-nlà ɓu nnandər, kang u yar nsar nnap-nlà iya̱m inəna̱n va̱ ta̱ ûzwal ɓu.
\v 29 Ǹyangmata̱ wa məma̱n te, wa pa̱r nzhi azwal ɓu na á təm ka̱ mpyal ɓu mbyet. Ka̱kul mmaɓu, uNəm Uga Nzhi uYawe ka̱ u là chit, kang ká̱ mpa̱r ɓu, nzhi azwal ɓu i pa̱r mbyet.>>
\c 8
\s1 Oga igwan aDawuda
\p 
\v 1 Ka̱ ashe ngga te, uDawuda nəm igwan ká̱ oFilisti kang uza̱ ka̱m ìtong aMetek Amma ka̱ atak oFilisti, kang uza̱ nak oza̱ tong ozwal wò.
\p 
\v 2 UDawuda nəm igwan ká̱ oMowap kpa. Uza̱ nak oza̱ ra ka̱ mbin, kang uza̱ màl oza̱ ká̱ mmàl asang. Nza̱ mmàl nggo pa̱ mparəm te, mí gbá̱ng oza̱, kang mmàl ngga nshatɗing te, mí re ká̱ irirì. OMowap təm ozwal aDawuda kang i mwa mbwai mbin á na.
\p 
\v 3 Ka̱ɗi te, uDawuda nəm igwan ká̱ uHadadezer uya aRehop ununggwan, uponzhi uga aZoba, ka̱ awalang va̱ uza̱ ga anung awang aYufriti pa̱ na ká̱ ô le ká̱ atak va̱ ta a yà ka̱ akum ichumchum wò á.
\v 4 UDawuda wur oshozha oga akeke ipəri ìkalong ká̱ ìgba̱l pa̱ ifangshat, ká̱ oshozha oga nchèn ká̱ ashar ìkalong ìsəm pa̱ iparəm. Uza̱ kyèn ashar ipəri va̱ ta pa̱ kpaktak tong igùrum, kang uza̱ re ipəri iga ndap akeke ìgba̱l.
\p 
\v 5 Awalang va̱ onəm oga aSuriya ka̱ aDimaska ɓa pa̱ na ó ka̱mshi aHadadezer uponzhi uga aZoba te, uDawuda gbá̱ng oza̱ ìkalong ìsəm pa̱ ìparəm ama̱n pa̱ parəm.
\v 6 Uza̱ nak oga idongkong oshozha ka̱ ashe mbin aDimaska ka̱ aSuriya, te oSuriya tong ozwal aDawuda, oza̱ i mwa mbwai mbin á na. UYawe na igwan ûDawuda atak va̱ uza̱ i ga kà̱ pa̱ kpaktak á.
\p 
\v 7 UDawuda vyat oga nggwanggwang azənariya onəm oga mpyal ìkum aHadadezer kang à ɓa ká̱ ka̱ aUrushelima.
\v 8 Kang uza̱ wur oga acham arəzang pa̱ makmak ka̱ ashe itong aTeba ká̱ aBerotayi va ka̱ akum iponzhi aHadadezer.
\p 
\v 9 Ka̱ nva̱ngva̱ uToyu uponzhi uga aHamat fe pa̱ uDawuda nəm igwan ká̱ nkpaktak oshozha aHadadezer chit,
\v 10 te uza̱ re uyen wò ununggwan, uJoram ka̱ atak aPonzhi uDawuda pa̱ a re anung á na, na shep na ka̱kul igwan va̱ uza̱ nəm ka̱ apal aHadadezer uva pak inok nlung ikum chit ká̱ uToyu. UJoram ɓa ká̱ imwa oga iya̱m aazurfa ká̱ azənariya, ká̱ acham arəzang ûDawuda.
\p 
\v 11 UPonzhi uDawuda gor oga iya̱m va̱ ta̱ pa̱ kpaktak ûYawe, wa nva uza̱ ka̱ nəm ká̱ aazurfa ká̱ azənariya va̱ uza̱ wur ka̱ atak oga mbin va̱ uza̱ ri ká̱ ìkum á.
\v 12 Oga mbin va ta̱ uza̱ ri ká̱ ìkum, aEdom ká̱ aMowap ká̱ aAmmon ká̱ aFilisti ká̱ aAmalek. Uza̱ gor oga iya̱m va̱ uza̱ wur ka̱ atak ìkum ka̱ atak aHadadezer uya aRehop ununggwan uponzhi uga aZoba kpa.
\p 
\v 13 Kang aɗin aDawuda dam byet, nva̱ngva̱ uza̱ le ka̱ atak ngbá̱ng onəm oga aEdom ìkalong pa̱ igba̱pchi ama̱n pa̱ na̱nne ka̱ ashe Mba̱nda̱m Mman.
\p 
\v 14 Uza̱ nak oga idongkong oshozha ka̱ ashe nkpaktak aEdom kang nkpaktak oEdom təm ka̱ avəng aDawuda. UYawe na igwan ûDawuda ka̱ nkpaktak atak va̱ uza̱ ga kà̱.
\s1 Onəm oga mpyal iponzhi aDawuda
\p 
\v 15 UDawuda nəm iponzhi ka̱ apal nkpaktak oIsa̱rila, uza̱ nap akwali aga nnandər ka̱ apal adanggo.
\v 16 UJowap uya aZeruya ununggwan uwa unəm uga mpyal oshozha, uJehoshafat uya aAhilut ununggwan uwa unəm uga nlir nnap nshetshet ûponzhi.
\v 17 UZadok uya aAhitup ununggwan ká̱ uAhimelek uya aAbiyatar ununggwan oma onəm oga mpyal awop, kang uSeraya uwa unəm uga nlir iya̱m.
\v 18 UBenaya uya aJehoyada ununggwan uwa unəm uga mpyal oKereti ká̱ oPeleti oma oshozha oga mpángchí uponzhi. Kang ovan aDawuda onunggwan tong onəm oga mpyal awop.
\c 9
\s1 UDawuda ka̱ uMefiboshet
\p 
\v 1 N̂da nro te, uDawuda ɓəp pa̱, <<Unəm uro uwa yà lap ka̱ ashe nzhi aShawulu pa̱ na n nyám nnap nnəna̱n á na ka̱kul aJonatan ɗò?>>
\p 
\v 2 Ukpari aShawulu uro uwa yà aɗiɗin pa̱ uZiba, oza̱ ɓa ka̱ na ka̱ atak aDawuda. Kang uponzhi ɓəp na pa̱, <<Mmaɓu na uZiba ɗò?>>
\p Te uza̱ ma̱n pa̱, <<Mmami na ukpari ɓu, áponzhi.>>
\p 
\v 3 Uponzhi ɓəp na pa̱, <<Unəm uro uwa yà lap ká̱ irirì ka̱ ashe nzhi aShawulu pa̱ na n nyám nnap nnəna̱n Inan á na ɗò?>>
\p Te uZiba na ama̱n ûponzhi pa̱, <<Uya aJonatan ununggwan uro uwa yà, uva gurumgurum ka̱ ashar pa̱ kpaktak.>>
\p 
\v 4 Te uponzhi ɓəp pa̱, <<Uza̱ ka̱ che yà?>>
\p UZiba na ama̱n pa̱, <<Uwa ya ka̱ aLo Debar, ka̱ nzhi àMakir, uya aAmiyel ununggwan.>>
\p 
\v 5 Te uPonzhi uDawuda nak pa̱ mma ga mma ɓa ká̱ na ka̱ nzhi àMakir uya aAmiyel ununggwan ka̱ aLo Debar.
\p 
\v 6 Awalang va̱ uMefiboshet uya aJonatan ununggwan ukaka aShawulu ɓa ka̱ mpyal àDawuda te, uza̱ kuchi ka̱ mbin uza̱ na ichumchum á na.
\p Te uDawuda là pa̱, <<ÁMefiboshet.>>
\p Kang uza̱ na ama̱n pa̱, <<Mmami nata̱, ukpari ɓu.>>
\p 
\v 7 Te uDawuda là á na pa̱, <<Kang ayər a nəm ɓu ka̱t, mi ga nnyám nnap nnəna̱n a ɓu ka̱kul apo ɓu uJonatan. Mi ga nna nkpaktak iram va̱ iji akaka ɓu uShawulu a ɓu, kang ɓu ri iya̱m-nrì nzəng ká̱ mi ka̱ atebəl pa̱ ɗəkər.>>
\p 
\v 8 Te uMefiboshet kuchi ka̱ɗi, kang uza̱ là pa̱, <<Uda ukpari ɓu yà? U nyám nnap nnəna̱n á mi, mmami va pa̱ vyakshin á.>>
\p 
\v 9 Te uponzhi wór ukpari aShawulu uZiba, kang uza̱ là á na pa̱, <<N na ûkaka anəm uga nzhi ɓu chit nkpaktak iya̱m va̱ iji aShawulu ká̱ nzhizhi.
\v 10 Mmaɓu ká̱ ovan ɓu onunggwan ká̱ okpari ɓu ó wap iram á na, kang ó ɓa ká̱ iya̱m iram ûkaka anəm uga nzhi wó, na a ya iya̱m-nrì. Kang uMefiboshet, ukaka anəm uga nzhi ɓu, i ri iya̱m-nrì nzəng ká̱ mi pa̱ ɗəkər.>> UZiba ká̱ ovan onunggwan pa̱ ogba̱pchi ama̱n pa̱ tukun, kang ká̱ okpari ìsəm pa̱ ìparəm.
\p 
\v 11 Te uZiba là ûponzhi pa̱, <<Iya̱m va̱ u là ûkpari ɓu pa̱ kpaktak te, mi nənəm, ánəm uga nzhi.>> Te uMefiboshet ri iya̱m-nrì ká̱ uponzhi pa̱ ɗəkər ka̱ atebəl, wa uzəngtəng ka̱ ashe ovan aponzhi onunggwan.
\p 
\v 12 UMefiboshet uwa yà ká̱ uyen ununggwan uɓwakan aɗiɗin pa̱ uMika. Kang nkpaktak onəm va̱ ka̱ ashe nzhi àZiba te, tong okpari aMefiboshet.
\v 13 UMefiboshet təm ka̱ aUrushelima ka̱kul pa̱ ɗəkər te, uza̱ i ri iya̱m-nrì ka̱ atebəl aponzhi. Uza̱ gurumgurum ka̱ nkpaktak ashar.
\c 10
\s1 UDawuda ri oAmmon ká̱ ikum
\p 
\v 1 Ka̱ nva̱ngva̱ uponzhi oAmmon, uNahash kú, te uyiyen uHanun ri iponzhi apo wò.
\v 2 Te uDawuda là pa̱, <<Mi nəm nnap nnəna̱n ûHanun uya aNahash ununggwan, wa nva upupo ka̱ nəm á mi á.>> Te uDawuda re nre ká̱ okpari wò pa̱ na á sak na ka̱kul ikú apupo.
\p Awalang va̱ onəm oga ǹre aDawuda ga ka̱ ashe mbin oAmmon te,
\v 3 onəm oga mpyal oAmmon là ûHanun unəm uga nzhi oza̱ pa̱, <<U rəng pa̱ uDawuda kà̱ nna ichumchum ûpo ɓu nva̱ uza̱ re onəm pa̱, á sak ɓu ka̱kul ikú apo ɓu ɗò? UDawuda re oza̱ pa̱, á ɓa á song ìtong yi, na a dər ìkam yi kang ì kpán ìtong yi ka̱t ɗò?>>
\v 4 Te uHanun wur onəm oga ǹre àDawuda va̱ ta, uza̱ kpat nggyer adanggo ka̱ ashe oza̱ ka̱ ngba̱k kang uza̱ kyen ilukwan oza̱ kà̱ ìjili, kang a ɓàk oza̱ ga.
\p 
\v 5 Awalang va̱ mma là iya̱m va̱ ta̱ ûDawuda, te uza̱ re onəm oga ǹre pa̱ á gwang oza̱ ka̱kul pa̱ mma na iwuswa ôza̱ byet. Uponzhi là pa̱, <<Ó təm ka̱ aJeriko ya nggyer wó á fa kang ô ɓa.>>
\p 
\v 6 Nva̱ngva̱ onəm oga aAmmon ya pa̱ ó lak ìgwak ûDawuda chit pa̱ gənggəng te, oza̱ ga yar oshozha mbwai ka̱ aSuriya ìkalong ìsəm pa̱ ìparəm ka̱ mbin aBet Rehop ká̱ aZoba, ká̱ uponzhi uga aMaka ká̱ oshozhashozha ìkalong pa̱ ìzəng, kang ká̱ oshozha ìkalong pa̱ ìgba̱pchi ama̱n pa̱ parəm ka̱ mbin aTop.
\p 
\v 7 UDawuda kà̱ nfe pa te, uza̱ re uJowap ká̱ nkpaktak oshozha wò pa̱ á lung oza̱.
\v 8 OAmmon gbar izər ka̱kul ìkum fa tong ka̱ anung asa̱l aga ntar ìtong oza̱, ǹnyi te, oSuriya oga aZoba ká̱ aRehop, ká̱ onungwan oga aTop ká̱ aMaka gbar izər ìkum iji oza̱ ka̱ agbagba.
\p 
\v 9 Awalang va̱ uJowap ya chit pa̱ onəm oga ìkum yà chit ka̱ mpyal wò ká̱ nva̱ng wò te, uza̱ yak oshozha oga ǹnyi ìkum oro ka̱ aIsa̱rila ɓa ká̱ oza̱ ka̱ atak wò na oza̱ á lung oSuriya.
\v 10 Uza̱ nak ugənang wò uAbishayi unəm uga mpyal aɓo oshozha pa̱ na oza̱ a ga á ru oAmmon ká̱ ìkum.
\v 11 UJowap là ûAbishayi pa̱, <<A yà pa̱ u ya oSuriya ka̱ nji nkàm mi te, ɓa na u ka̱mshi mi. Kang a yà pa̱ n ya oAmmon ka̱ nji nkàm ɓu ǹnyi te, mi ɓa mi ka̱mshi ɓu.
\v 12 Nəm nkam ìgwak, kang re í tong akam ka̱kul onəm yi ká̱ oga itong Inan yi. UYawe i nəm iya̱m va̱ uza̱ ya ma ká̱ na.>>
\p 
\v 13 Te uJowap ká̱ oshozha wò səng ga na ó lung ìkum, kang oSuriya chəng.
\v 14 Nva̱ngva̱ oAmmon ya oSuriya kà̱ nchəng te, oza̱ chəng kpa ka̱ mpyal aAbishayi le táng ashe ìtong. Te uJowap ká̱ oshozha wò le ka̱ atak nlung oAmmon kang à ɓa aUrushelima.
\p 
\v 15 Nva̱ngva̱ oSuriya ya chit pa̱ oIsa̱rila ri wó chit ká̱ ìkum te, oza̱ ɓut ka̱ anung zəngtəng ka̱ɗi.
\v 16 UPonzhi uHadadezer re ǹre mma ɓa ká̱ oSuriya va̱ ka̱ nfa alum awang aYufriti. Oza̱ ga aHelam kang uShobak unəm uga mpyal oshozha aHadadezer ləp mpyal ôza̱.
\p 
\v 17 Awalang va̱ uDawuda fe iya̱m va̱ ta̱ te, uza̱ ɓut nkpaktak oIsa̱rila, oza̱ pa̱ng agwong awang aUrdun kang oza̱ ga aHelam. OSuriya gbar izər ìkum kang oza̱ ru uDawuda ká̱ ìkum.
\v 18 Ǹnyi te, oSuriya chəng ka̱ mpyal oIsa̱rila kang uDawuda gbá̱ng onəm oga akeke ipəri ìgba̱l pa̱ ìfangshat, ká̱ oshozha oga ashar ìkalong ìsəm pa̱ ìneɗing. Uza̱ gbá̱l uShobak unəm uga mpyal oshozha oza̱ kpa.
\v 19 Awalang va̱ nkpaktak oponzhi va̱ ka̱ avəng aHadadezer ya chit pa̱ oIsa̱rila ri oza̱ chit ká̱ ìkum te, oza̱ gwang inal ká̱ oIsa̱rila kang oza̱ tong ozwal oza̱.
\p Te ayər nəm oSuriya, oza̱ ka̱mshi oAmmon lap ka̱t.
\c 11
\s1 UDawuda ká̱ uBatsheba
\p 
\v 1 Awalang va̱ ìzun ga̱ɓa̱n chit, ka̱ ashe nra va̱ oponzhi i ga ìkum te, uDawuda re uJowap ká̱ onunggwan aponzhi ká̱ nkpaktak oshozha oIsa̱rila pa̱ á ga a lung oAmmon. Te oza̱ ga zhì oAmmon kang oza̱ ra anyimnyal gáng ìtong iga aRaba. Ǹnyi te, uDawuda uwa yà ka̱ aUrushelima.
\p 
\v 2 N̂da nro ka̱ arurong te, uDawuda wong ka̱ atak njul ka̱ apal iya̱m nra kang uza̱ ka̱ nchen ka̱ apal nzhi iponzhi. Ka̱ apal nzhi nva̱ ta te, uza̱ ya uchar uro ka̱ ngwór izər. Uchar va̱ ta ɓyen byet,
\v 3 kang uDawuda re unəm uro pa̱ á gbap uchar va̱ ta á wò. Unəm va̱ ta là á na pa̱, <<Uza̱ uBatsheba, uya aEliyam uchar, uchar aUriya unəm oHiti.>>
\v 4 Te uDawuda re onəm oga ǹre ga ɓa ká̱ na. Uchar va̱ ta ɓa atətak kang uza̱ ra ká̱ na. Te uchar va̱ ta le ga nzhi. Uza̱ wa gba̱l akpar ka̱ ǹyang, kang uza̱ gba̱l ká̱ nnàl izər ka̱ atak akpar wa nva oIsa̱rila i nəm á.
\v 5 Ka̱ nvəva̱ng te, uBatsheba təm ka̱ anyám, kang à re ǹre ûDawuda pa̱, <<Mmami ká̱ izər pa̱ iparəm.>>
\p 
\v 6 Te uDawuda re ǹre ûJowap pa̱, <<Re ǹre á mi ká̱ uUriya uHiti.>> Te uJowap re ǹre ûDawuda ká̱ uUriya.
\v 7 Awalang va̱ uUriya ɓa atətak te, uDawuda ɓəp ikángkáng aJowap ká̱ iji oshozha ká̱ asa̱l awu va̱ ìkum ka̱ ngga ká̱.
\v 8 Te uDawuda là ûUriya pa̱, <<Fa ga nzhi ɓu na u nàl ashar na u jul.>> Te, uUriya fa ka̱ ashe nzhi aponzhi, kang uponzhi re ǹre á na ká̱ imwa iya̱m-nrì ka̱ nva̱ng.
\v 9 Ǹnyi te, uUriya ga nzhi wò ka̱t, uza̱ ra nzəng ká̱ onəm oga mpángchí uponzhi ka̱ anung nkəlang àponzhi.
\p 
\v 10 Mma là ûDawuda pa̱, <<UUriya ga nzhi ka̱t.>> Te uDawuda wór na ɓəp na pa̱, <<Nna u le ka̱ chen ta̱, te sang kang u ga nzhi ka̱t yà?>>
\p 
\v 11 UUriya na ama̱n pa̱, <<Akwati aga nsar nnap-nlà ká̱ oshozha oIsa̱rila ká̱ oga aYahuda oma kà̱ nra ka̱ ashe oga aghal, kang unəm uga mpyal mi uJowap ká̱ oshozha anəm uga nzhi mi, oma ra apa̱k ka̱ agbagba. Mi yar sang kang mi ga nzhi mi, pa̱ na n ri, n ngwa, n nra ká̱ uchar mi yà? Ká̱ nva̱ nna u yà ká̱ irirì te, mi yà ka̱ nnəm apir nnap wa nva̱ ta ka̱t.>>
\p 
\v 12 Te uDawuda là ûUriya pa̱, <<Ra ka̱ta̱ nda ká̱ ipin ikpa̱kkpa̱k kà̱ɗi, te mi re ɓu ɓu le.>> Te uUriya ra ka̱ aUrushelima wa nva̱ uponzhi là á.
\v 13 UDawuda chal na ka̱ nri iya̱m-nrì kang à nak na wa nchè kang nchè gba̱l na. Ǹnyi te, atak la te, uUriya ga nzhi ka̱ atak achar wò ka̱t. Uza̱ ra ka̱ apal ndakal wò nzəng ká̱ okpari aponzhi.
\p 
\v 14 Ka̱ iɓotak te uponzhi lir iya̱m na ûUriya pa̱ a ga a na ûJowap.
\v 15 Ka̱ ashe nlir va̱ ta te, uza̱ lir ûJowap pa̱, <<Nak uUriya ka̱ mpyal ìkum, ka̱ atak va ìkum sur ka̱ pa̱ gənggəng. Te ó le ga nva̱ng o re na ká̱ nkukwa na mmá gba̱l na.>>
\p 
\v 16 Nva̱ uJowap kà̱ nra anyimnyal gáng ìtong va̱ ta te, uza̱ nak uUriya ka̱ atak va onunggwan okpa ìkum oza̱ kà̱.
\v 17 Awalang va̱ oshozha okpa ìkum fa pa̱ ó lung ìkum te, mmá gba̱l uUriya unəm oHiti nzəng ká̱ onəm oga mpyal oshozha oIsa̱rila oro.
\p 
\v 18 UJowap re ǹre mmá là ûDawuda nkpaktak iya̱m va̱ mmá nəm ka̱ atak ìkum.
\v 19 Uza̱ là ûnəm uga nre va̱ uza̱ re pa̱, <<Awalang va̱ wa gbá̱l ká̱ nshal nkpaktak nnap ìkum va̱ ta̱ ûponzhi chit te,
\v 20 ɗom te ìgwak i lak uponzhi kang uza̱ i ɓəp pa̱,<Sang kang o lung ìkum o ga o dat ká̱ ìtong yà? O nyi pa̱ oza̱ i sat ka̱ apal akamsəlang ìtong kang i tat iwar ka̱t ɗò?
\v 21 Uda ka̱ gba̱l uAbimelek uya aJerubeshet ununggwan yà? Uchar wa ka̱ mang na ká̱ awo ako ka̱ izər akamsəlang ká̱ aTebet uza̱ kú ka̱t ɗò?> A yà pa̱ uza̱ a ɓəp ɓu pa̱, <Sang kang ó ga datkulung ká̱ izər akamsəlang yà?> Te wa là á na pa̱, <Mmá gba̱l ukpari ɓu uUriya unəm oHiti kpa.> >>
\p 
\v 22 Te unəm uga nre fa ga, kang awalang va̱ uza̱ chu te a là ûDawuda nkpaktak nnap va̱ uJowap re na pa̱ a là a na á.
\v 23 Unəm uga nre va̱ ta là ûDawuda pa̱, <<Okpa ìkum yi ji nkam yi, fa i lung yi ka̱ agbagba, ǹnyi te, í ɓàk oza̱ le ga anung asa̱l ìtong.
\v 24 Te onəm oga iwar tong ka̱ apal akamsəlang i tat yi, kang onəm oga mpyal oshozha ɓu oro kú. Ka̱ɗi te, mmá gbá̱l ukpari ɓu uUriya unəm oHiti.>>
\p 
\v 25 UDawuda là ûnəm uga nre va̱ ta pa̱, <<Là ûJowap pa̱, <Kang ìchəgwak a ləp ɓu ka̱t, ndokchi i yak onəm yak ka̱t. Ó lung pa̱ gənggəng na ó ri ìtong va̱ ta.> Là a na, na a kám irəng a na.>>
\p 
\v 26 Awalang va̱ uBatsheba uchar aUriya fe pa̱ uɓar wò kú chit te, uza̱ yə́ng ikuku.
\v 27 Nva̱ngva̱ nra nyə́ng ikú watar te, uDawuda re ǹre mmá ɓa ka̱ na ka̱ ashe nzhi wò, uza̱ nyang uchəchar kang a mar uyen nunggwan á na. Ǹnyi te, uYawe fe nchang iya̱m va̱ uDawuda nəm ka̱t.
\c 12
\s1 UNatan ra̱n ká̱ uDawuda
\p 
\v 1 UYawe re uNatan unəm uga nlà ichu Inan ka̱ atak aDawuda. Awalang va̱ uza̱ ɓa atətak te, uza̱ là a na pa̱, <<Onəm oro mmá ka̱ yà pa̱ oparəm ka̱ ashe ìtong iro. Uro unəm uga ìdur kang uro unəm uga nkun.
\v 2 Unəm uga idur va̱ ta uwa yà ká̱ itam ká̱ ina pa̱ makmak,
\v 3 ǹnyi te, unəm uga nkun va̱ ta yà ká̱ iya̱m iro ka̱t, iya ìtam pa̱ izəng ya byet va uza̱ yáp. Uza̱ kang à rup nzəng ka̱ ovəvan. I ri iya̱m nzəng ka̱ na, kang i wa ka̱ ashe ikpəkpang iga ngwa ndəng, oza̱ i ra nzəng. A sat a na wa ayiyen uchar.
\p 
\v 4 <<N̂da nro te, unəm uga ndur va̱ ta ya unəmchən te, ka̱ɗor nva̱ pa̱ uza̱ á gbá̱l ìtam ka̱t te ìna ka̱ ashe iya̱m nkang wò te, uza̱ ga kpan ija anəm uga nkun va̱ ta gbá̱l nəm iya̱m-nrì ûnəmchən wò va̱ ta ká̱.>>
\p 
\v 5 A ra̱m uDawuda pa̱ gənggəng kang uza̱ là ûNatan pa̱, <<N sóng anung ká̱ aɗin aYawe, unəm va̱ nəm nnap nva̱ ta̱ te nkpak pa̱ uza̱ á kú.
\v 6 Uza̱ i mwa ìtam va̱ ta nva̱ng pa̱ ineɗing, ka̱kul iya̱m va̱ uza̱ nəm ta, ka̱ atak nyà ká̱ aɗor ka̱t á.>>
\p 
\v 7 Te uNatan là ûDawuda pa̱, <<Mmaɓu na unəm va̱ ta. Iya̱m va ta̱ uYawe, Inan oIsa̱rila là,<N gar ɓu uponzhi ka̱ apal oIsa̱rila kang m fa ká̱ ɓu ka̱ ashe awo uShawulu.
\v 8 N na nzhi ànəm uga nzhi ɓu, ká̱ ochəchar. N na nkpaktak oIsa̱rila ká̱ oYahuda a ɓu. Kang ká̱ yà pa̱ iya̱m va̱ ta a yiyen ká̱ ɓu te, ká̱ n na iro a ɓu ká̱ jiji.
\v 9 Iza̱ nak kang u ɓak nnap-nlà àYawe, kang u nəm iya̱m iɓá̱ngɓa̱ng va̱ ta̱ ka̱ mpipyal yà? U gbá̱l uUriya unəm oHiti ká̱ ndokchi kang u ka̱m uchəchar sat uji ɓu. U gbá̱l na ká̱ ndokchi oAmmon.
\v 10 Ka̱kul nva̱ ta te, ndokchi i kap ká̱ nzhi ɓu ka̱t, ka̱kul u ɓak mi, kang u ka̱m uchar aUriya unəm oHiti ta̱l uji ɓu.>
\p 
\v 11 <<Iya̱m va ta̱ uYawe là, <Dər, mi ga mɓa ká̱ nɗaktak ka̱ ashe nzhi ɓu. Kà̱ mpyal ɓu mi ga ngwur ochar ɓu mi na ûnəm uro uva dat ká̱ ɓu, kang i ra ká̱ oza̱ ká̱ alum pa̱ agbagba.
\v 12 Ka̱ u nəm ka̱ ayi, ǹnyi te, mi ga nnəm iya̱m va̱ ta̱ ká̱ alum pa̱ agbagba ka̱ mpyal nkpaktak oIsa̱rila.> >>
\p 
\v 13 Te uDawuda là ûNatan pa̱, <<N nəm nnap mɓá̱ngɓa̱ng ûYawe chit.>>
\p Kang uNatan na ama̱n a na pa̱, <<UYawe yar nnap mɓá̱ngɓa̱ng va̱ ta̱ a ɓu chit, ɓu ga nkú ka̱t.
\v 14 Ǹnyi te, ka̱kul iya̱m va̱ ta̱ u nəm te, u ɓak uYawe, uyen va̱ mmá mar a ɓu te i kú.>>
\s1 Uya aDawuda kú
\p 
\v 15 Ka̱ nva̱ngva̱ uNatan le nzhi wò chit te, uYawe la̱p uyen va̱ uchar aUriya mar ûDawuda ká̱ arwa.
\v 16 UDawuda chál Inan pa̱ uza̱ á re irirì ayen va̱ ta. Uza̱ yar ndəng gbà̱l, kang à ra ka̱ mbin atak tan na.
\v 17 Onəmgbak oga nzhizhi ɗak pa̱ na uza̱ a wong ka̱ mbin, ǹnyi te, uza̱ yang kang a ri iya̱m-nrì nzəng ká̱ oza̱ ka̱t.
\p 
\v 18 Kà̱ nra ngga nfangshat te, uyen va̱ ta kú. Te ayər nəm onəm oga nnəm inok ûDawuda ka̱ nləlà á na pa̱ uyən va̱ ta kú chit, ka̱kul oza̱ rəng pa̱, <<Uyen wa ka̱ yà ká̱ irirì te, í là nnap ka̱ na te, uza̱ fe yi ka̱t, kang jwak chit pa̱, a kuku, kang í là á na te uza̱ na aɓang ishi wò ka̱t ɗò?>>
\p 
\v 19 UDawuda ya okpari wò i là nnap ka̱ avəng achwang te, aghan ga na pa̱ uyen va̱ ta kú chit. Kang uza̱ ɓəp pa̱, <<Uyen va̱ kú chit ɗò?>>
\p Te oza̱ ma̱n pa̱, <<À, á kú chit.>>
\p 
\v 20 Te uDawuda wong ka̱ mbin, uza̱ wòr izər, uza̱ ɓəl mmì, uza̱ mwak ìlukwan wò ìkak. Uza̱ ga ashe nzhi awop, kang uza̱ wop uYawe. Ka̱ nva̱ngva̱ te uza̱ le nzhi kang uza̱ ɓəp iya̱m-nrì pa̱ mmá ɓa ká̱ iya̱m-nrì á wò. Oza̱ ɓa ká̱ iya̱m-nrì á na te uza̱ ri.
\p 
\v 21 Te onəm oga nna ichichən ɓəp na pa̱, <<Iza̱ u nəm ta̱ yà? U yar ndəng gbà̱l kang u yə́ng ka̱kul ayen va̱ ta̱, ya uwa ká̱ irirì. Ǹnyi te, uyen va̱ ta kú chit, u re nnəm aɗor kang u ri iya̱m-nrì.>>
\p 
\v 22 Uza̱ na ama̱n pa̱, <<N yar ndəng gbà̱l kang n yə́ng ya uyen va̱ ta uwa ká̱ irirì, ka̱kul n rəng pa̱,<Mwote uYawe uwa i nyám nrwa ìgwak á mi i re irirì ayen va̱ ta.>
\v 23 Kang ǹyangmata̱ uza̱ kú chit. Te mi yar ndəng ngbà̱l ka̱ iza̱ yà? Mi le ká̱ na le lap ɗò? Nna mi ga ka̱ atətak, ǹnyi te uza̱ i le atak mi lap ka̱t.>>
\s1 Amar aSolomon
\p 
\v 24 Te uDawuda sak uchar wò uBatsheba, kang uza̱ ga atak nra ká̱ na. Te uza̱ yar anyám uza̱ mar uyen ununggwan kang uDawuda sok aɗin uyen va̱ ta pa̱ uSolomon. UYawe ma̱n uyen va̱ ta,
\v 25 kang uza̱ re uNatan unəm uga nlà ichu Inan pa̱ aɗin ayen va̱ ta uJedidiya, ipipir pa̱ uYawe ma̱n na, wa nva uYawe nak á.
\s1 UDawuda nəm igwan ká̱ aRaba
\p 
\v 26 Ka̱ ashe ngga te, uJowap ru aRaba ìnang ìtong oAmmon, kang uza̱ ri atak va̱ uponzhi oza̱ i təm kà̱.
\v 27 Te uJowap re onəm oga nre pa̱ á là ûDawuda pa̱, <<N nəm ìkum chit ká̱ aRaba, kang n kpan atak va̱ chit oza̱ i ya ndəng kà̱.
\v 28 Ǹyangmata̱ te, vang ká̱ aɓo oshozha na u ra anyimnyal u gáng na u ri ìtong va̱ ta. Ka̱t te mi ga nri ìtong va̱ ta kang mí wór ká̱ aɗin mi.>>
\p 
\v 29 Te uDawuda ɓut aɓo oshozha uza̱ ga nəm ìkum ká̱ aRaba, kang uza̱ ri.
\v 30 UDawuda tur atagya iponzhi ká̱ ishi aponzhi, kang uza̱ pa ká̱ ishi wò. Atagya va̱ ta mmá nəm ká̱ azənariya ká̱ ipang iməlamməlam, kang iɗəɗək alaba ìsəm pa̱ ifangshat ama̱n pa̱ tukun. UDawuda wur iya̱m iga ngwur ka̱ atak ìkum pa̱ makmak ka̱ ashe ìtong va̱ ta.
\v 31 Uza̱ wur ozwal ká̱ onəm oga aRaba, kang uza̱ nak oza̱ kpa i nəm inok ká̱ ìkpal iga mpà akun, ká̱ adiga ká̱ ìku, kang oro i nəm inok amè i ɓit i wom ka̱kul mme nzhi. UDawuda nəm wanta n̂kpaktak itong oAmmon. Te uza̱ ká̱ nkpaktak oshozha wò le aUrushelima.
\c 13
\s1 UAmnon ká̱ uTamar
\p 
\v 1 Ka̱ ashe ngga te, uAmnon uya aDawuda ununggwan ɗom nra ichar ká̱ uTamar, ugənang aAbsalom uya aDawuda ununggwan uchar uva ɓyen byet.
\p 
\v 2 Nɗom va̱ ta mak byet ga sat a na wa arwa. UTamar uyen ɓyen uva uwa nyi ununggwan chit ka̱t. Kang kà̱ nrəng nnap aAmnon te, a kam ka̱ na byet pa̱ ô nəm iya̱m iro ka̱ na.
\p 
\v 3 UAmnon uwa yà ká̱ ukpa wò uro aɗiɗin pa̱ uJonadap uya aShimeya ununggwan ugənang aDawuda, uJonadap uwa yà ká̱ ntàn mɓá̱ngɓa̱ng.
\v 4 Uza̱ ɓəp uAmnon pa̱, <<Iza̱ nak kang mmaɓu uya aponzhi ɓu yà ká̱ nɗaktak pa̱ ɗəkər yà?>> Ɓu là á mi ka̱t ɗò?
\p Te uAmnon là á na pa̱, <<Aɗom nra ichar ká̱ uTamar ugənang aya apo mi uAbsalom nna i ɗak mi.>>
\p 
\v 5 UJonadap là a na pa̱, <<Ga ɓu ra ka̱ apal à alyer nəm na u rurwa. Awalang va̱ upo ɓu a ɓa ndər ɓu te, wa chál na pa̱, <Re uya apo mi uTamar à nəm iya̱m-nrì a mi ka̱ ìwu mi, n yà ka̱ nyiya, te uza̱ á na mi ká̱ awo wò na n ri.> >>
\p 
\v 6 Te uAmnon ra ka̱ apal alyer wò pa̱ o rurwa. Awalang va̱ uponzhi ɓa ndər na chit te, uAmnon là a na pa̱, <<N ɗom pa̱ u re uya apo mi uchar uTamar a ɓa pə́k iya̱m-nrì á mi ká̱ iwu mi, á na mi ka̱ awo wò na n ri.>>
\p 
\v 7 Te uDawuda re nre ka̱ uTamar ka̱ nzhi, uza̱ là a na pa̱, <<Ga nzhi aya apo ɓu uAmnon na u nəm iya̱m-nrì a na.>>
\v 8 Te uTamar a ga nzhi aya apo wò uAmnon, uva ka̱ nra ka̱ apal alyer. Te uza̱ yar mma̱k uza̱ kál, uza̱ nuk, uza̱ nəm iya̱m-nrì á na kà̱ ìwuwu.
\v 9 Te uza̱ ga ká̱ a na, ǹnyi te, uza̱ yang ká̱ nrìri.
\p UAmnon là pa̱, <<Re udanggo a fa ka̱ ta̱.>> Te onəm fa pa̱ kpaktak re na.
\v 10 Te uza̱ là ûTamar pa̱, <<Ɓa ká̱ iya̱m-nrì va̱ ta á mi ka̱ atak nra mi, kang mi ri ka̱ awo ɓu.>> Te uTamar yar iya̱m-nrì va̱ ta, tar ká̱ ka̱ ashe atak nra aya apo wò uAmnon.
\v 11 Uza̱ yar iya̱m-nrì va̱ ta chit pa o na a na te uAmnon kpan na, là pa̱, <<Ɓa na n ra ká̱ ɓu, aya apo mi.>>
\p 
\v 12 Te uTamar a là pa̱, <<Kang wa nəm ifan á mi ka̱t, aya apo mi, ka̱kul apir nnap wa va̱ ta̱ te, mí nəm ka̱ ashe aIsa̱rila ka̱t. Kang wa nəm iya̱m iwuswa va̱ ta̱ ka̱t.
\v 13 Mi wòl ká̱ iwuswa va̱ ta ka̱ che yà? Mmaɓu kpa, mí wór ɓu pa̱ uyen umaimai ka̱ ashe oIsa̱rila. Wa ma̱n te, là nnap ká̱ uponzhi, uza̱ i yà ká̱ nyáng nna mi a ɓu pa̱ u ka̱m ichar ká̱ mi ka̱t.>>
\v 14 Te uAmnon gwong achwang ka̱ na ka̱t, kang ka̱kul pa̱ uza̱ kam ji na ji te, uza̱ ra ka̱ na ká̱ ifan.
\p 
\v 15 Te uAmnon yang na, nyang mmakmak. Nyang va̱ uza̱ yang na te, aga ji nɗom va̱ ji uza̱ ka̱ ɗom na á. Uza̱ là á na pa̱, <<Fa le á mi ka̱ ta̱.>>
\p 
\v 16 UTamar là a na pa̱, <<Ngwà va̱ ɓu wà mi ta̱ te, a ɓa̱ng ji iya̱m inga va̱ ji u nəm á mi.>>
\p Ǹnyi te, uza̱ gwong achwang ka̱ na ka̱t.
\v 17 Uza̱ wór ukpari wò kang a là á na pa̱, <<Dap uchar va̱ ta̱ fa ká̱, ka̱ gbai, na u vəng anung nzhi.>>
\v 18 Te ukparikpari va̱ ta fa ka̱ na, vəng anung nzhi. UTamar pa ìlukwan iwángwang iga ngwang awo. Ka̱kul wa nnà ta nnap nnəm ovan oponzhi ovan ɓyen i nəm ka̱ ashe nra va̱ ta á.
\v 19 Te uTamar kpan ilukwan wò iga ngwang awo va̱ ta kakchi, uza̱ nak nchwang ká̱ ishi. Uza̱ kat awo ká̱ ishi, uza̱ ka̱ nyə́ng pa̱ bobo i ga nzhi ka̱.
\p 
\v 20 UAbsalom ugənang aTamar ɓəp na pa̱, <<UAmnon, uya apo ɓu, à làk ɓu ɗakɓo? Ma̱r iya̱m ɓu, agənang mi. Uza̱ uya apo ɓu ka̱t ɗò? Kang wa kpan iya̱m ata ka̱ igwak ka̱t.>> Kang uTamar təm ká̱ aɗor kà̱ nzhi agənang wò uAbsalom.
\p 
\v 21 Awalang va̱ uPonzhi UDawuda fe nnap va̱ ta te, a ra̱m na pa̱ gənggəng.
\v 22 Kang uAbsalom là iya̱m iro inəna̱n ka̱t te iɓá̱ngɓa̱ng ûAmnon ka̱t. UAbsalom yang uAmnon ka̱kul uza̱ na iwuswa ûgənang wò uchar uTamar.
\s1 UAbsalom gba̱l uAmnon
\p 
\v 23 Ka̱ nva̱ng ìzun pa̱ parəm te, awalang va̱ uAbsalom kà̱ nkpat akpap iya̱m nkang wò ka̱ atak aro mí wór pa̱ aBaal Hazor dat ka̱ aEfrayim, te uza̱ chál nkpaktak ovan aponzhi onunggwan pa̱ oza̱ a ɓa.
\v 24 Uza̱ ga atak aponzhi, uza̱ là á na pa̱, <<Mmami uzwal ɓu ka̱ ngga nkpat akpap itam mi. N chal pa̱ uponzhi aməma̱n te, a ɓa nzəng ká̱ onəm oga nnəm inok wò.>>
\p 
\v 25 Uponzhi na ama̱n ûAbsalom pa̱, <<O, o, i ga pa̱ kpaktak ka̱t, le kang i nak iɗək a ɓu ka̱t.>> Ká̱ nna kpa te, UAbsalom zhet pa̱ uponzhi ka̱ ga. Uponzhi ga ka̱t, ǹnyi te, a nak nnap nnəna̱n á na.
\p 
\v 26 Te uAbsalom là pa̱, <<A yà pa̱ ɓu ga ka̱t te, re uya apo mi uAmnon à ga nzəng ká̱ yi.>>
\p Uponzhi ɓəp na pa̱, <<Ka̱kul iza̱ kang uza̱ i ga nzəng ká̱ ɓu yà?>>
\v 27 Ǹnyi te, uAbsalom zhet, uponzhi ga ma̱n á na kang uza̱ re uAmnon ká̱ aɓo ovan aponzhi onunggwan ga nzəng ká̱ uAbsalom.
\p 
\v 28 UAbsalom là ôkpari wò chit pa̱, << O gwong achwang. Awalang va̱ uAmnon a wá nchè chit ra̱n na, kang mi là a wó pa̱, <O gba̱l uAmnon,> te o gba̱l na. Kang ayir a nəm wó ka̱t, o nəm pa̱ kakkərak, ka̱kul mmami na n là a wó.>>
\v 29 Te okpari aAbsalom gba̱l uAmnon wa nva uAbsalom là ôza̱. Te aɓo ovan aponzhi onunggwan wong, udanggo kyén alabitəri wò chər.
\p 
\v 30 Oma ka̱ ngga te, mmá là ûDawuda pa̱, <<UAbsalom gbá̱ng ovan aponzhi chit pa̱ chatchat, uro le ka̱ ashe oza̱ ka̱t.>>
\v 31 Te uponzhi wong gakul, kan ìlukwan wò, kang uza̱ ra ka̱ mbin. Nkpaktak okparikpari va̱ təm ka̱ atətak te, kan ilukwan iji oza̱ kpa.
\p 
\v 32 Ǹnyi te, uJonadap uya aShimeya ununggwan, ugənang aDawuda là pa̱, <<Kang unəm uga nzhi mi a rəng pa̱ mmá gbá̱ng nkpaktak ovan aponzhi ka̱t, uAmnon wa byet mmá gba̱l. UAbsalom ka̱ yà ka̱ nggup na, ɓan ká̱ nda va̱, uza̱ ra ká̱ ugənanggənang uTamar ká̱ ifan á.
\v 33 Kang unəm uga nzhi mi a na nnandər ká̱ nva̱ mmá là pa̱ nkpaktak ovan aponzhi à kú. UAmnon uwa byet kú.>>
\p 
\v 34 Mmá ka̱ ashe nva̱ ta te, uAbsalom chər chit.
\p Te unəm uga mpángchí atak ka̱ ya nggatək onəm i ɓa ka̱ ngba̱k aɗuktum ka̱ asa̱l ntar alum. Uza̱ chər là ûponzhi pa̱, <<N ya nggatək onəm oro ka̱ mɓa ka̱ asa̱l aHoronayim ka̱ ngba̱k aɗuktum.>>
\p 
\v 35 UJonadap là ûponzhi pa̱, <<Dər, ovan ɓu onunggwan oma i ɓa cho wa nva̱ uzwal ɓu là á.>>
\p 
\v 36 Uza̱ kà̱ ngba̱l ká̱ nlà nnap na byet te, ovan aponzhi onunggwan ɓa chu ká̱ ayə́ng pa̱ gbá̱nggbá̱ng. Uponzhi ká̱ nkpaktak okpari wò yə́ng pa̱ gənggəng.
\p 
\v 37 UAbsalom chər kang à ga atak aTalmayi uya aAmihut ununggwan uponzhi oga aGeshur. Ǹnyi te, uDawuda yə́ng ikú ayen wò nra pa̱ makmak.
\p 
\v 38 Nva̱ngva̱ uAbsalom chər ga aGeshur te, uza̱ təm ka̱ ta ìzun pa̱ ishatɗing.
\v 39 Nva̱ngva̱ aɗor nlang uAmnon va̱ ta fa ûPonzhi uDawuda chit te, uza̱ ɗom pa̱ na ka̱ ô ya uAbsalom.
\c 14
\s1 UAbsalom le ɓa aUrushelima
\p 
\v 1 Ǹyangmata̱ te, uJowap uya aZeruya nyi chit pa̱ igwak aponzhi ga̱ɓa̱n chit ga atak aAbsalom.
\v 2 Te uJowap re unəm uro ga aTekowa pa̱ a ɓa ká̱ uchar utantan uro ka̱ ta. Uza̱ là a na pa̱, <<Nəm wa achar va ikú gba̱l na. Mwak ìlukwan iga yə́ng ikú, kang wa ɓəl mmì nəna̱n nro ka̱t. Nəm wa achar va ká̱ aɗor chit nra pa̱ makmak.
\v 3 Te wa ga atak aponzhi wa là nnap a ta̱ á na nva̱ mmami ka̱ ngga nləla a ɓu ta̱ à.>> Kang uJowap là iya̱m va̱ á na uza̱ i ga nləla á.
\p 
\v 4 Awalang va̱ uchar uga aTekowa va̱ ta ga atak aponzhi te, uza̱ ru ka̱ mbin na ichumchum a na, kang uza̱ là pa̱, <<Aponzhi nəm nka̱mshi á mi.>>
\p 
\v 5 Uponzhi ɓəp na pa̱ <<Iza̱ nɗaktak ɓu yà?>>
\p Uza̱ là pa̱, <<Mmami uchar ukpələng ka̱kul pa̱ uɓar mi kuku.
\v 6 Mmami uzwal ɓu, ká̱ ovan onunggwan pa̱ oparəm, oza̱ yar ìkum ka̱ ashe nzam, unəm uro yà ka̱ ta pa̱ a dáng oza̱ ka̱t, te uro gba̱l uwan wò.
\v 7 Dər, ǹyangmata̱ te, nkpaktak akum mi ka̱ nlung mi, i là pa̱, <Ɓa ká̱ uyen va̱ ta i gba̱l ka̱kul nva̱ uza̱ gba̱l ugənang wò á. Te i gba̱l unəm uga nri akup ka̱ nzhizhi kpa.> A yà pa̱ n nəm pa te, mi yà ká̱ uyen uro lap ka̱t, te aɗin aɓar mi ká̱ nva̱ng va̱ uza̱ re te i yà ka̱ ashe apambin ka̱t.>>
\p 
\v 8 Te uponzhi là ûchar va̱ ta pa̱, <<Ga nzhi ɓu, mi ga nnak nnap mpakpak ka̱ apal nnap ɓu va̱ ta̱.>>
\p 
\v 9 Ǹnyi te, uchar uga aTekowa va̱ ta là a na pa̱, <<Re unəm uga nzhi mi uponzhi a yar mpat a mi ká̱ nzhi mi, kang re uponzhi ká̱ iponzhi wò a yà ká̱ mpat ka̱t.>>
\p 
\v 10 Uponzhi na ama̱n pa̱, <<A yà pa̱ unəm uro là iya̱m iro a ɓu te, ɓa ka̱ oza̱ a mi, kang oza̱ i ɗak ɓu lap ka̱t.>>
\p 
\v 11 Uchar uga aTekowa va̱ ta là pa̱, <<Re uponzhi a sóng anung ká̱ Inan wò, pa̱ ɓu yà ka̱ nre unəm uro pa̱ a pyát akat nchə̀r va̱ cho lap ka̱t, na kang mmá gba̱l uyen mi. Nɗom ntar nchə̀r nro lap ka̱t.>>
\p Uponzhi là pa̱, <<Nva̱ uYawe uwa yà ká̱ irirì te, akpap ishi ayen ɓu pa̱ zəng i ru ka̱ mbin ka̱t.>>
\p 
\v 12 Te uchar va̱ ta là pa̱, <<Wa ma̱n te m ɓəp iya̱m iro pa̱ zəng ka̱ɗi.>>
\p Te uponzhi là pa̱, <<Ga mpyal ka̱ nnap-nlà ɓu.>>
\p 
\v 13 Uchar va̱ ta là pa̱, <<Sang kang u nəm apir nnap wa nva̱ ta̱ ônəm aYawe yà? Ka̱ apal nnap-nlà va̱ u là ta̱ te u pà akwali ishi ɓu chit. Ka̱kul u yang ka̱ mɓa ká̱ uyen ɓu ka̱ nzhi.
\v 14 Nkpaktak yi i ga nkú, mmayi wa ndəng va tar ka̱ mbin, mí wur lap ka̱t. Ǹnyi te, iya̱m va ta Inan ɗom ka̱t, uza̱ ɗom pa̱ unəm va̱ mmá ɓàk ga təm ka̱ mbin nro te, a təm ka̱ ta mbyet ka̱t.
\p 
\v 15 <<Kang ǹyangmata̱ m ɓa pa̱ n là iva̱ ta̱ ûnəm uga nzhi mi uponzhi ka̱kul onəm na ayir a mi chit. Uzwal ɓu rəng pa̱, <Mi ga nlà nnap ûponzhi mwote uza̱ i mwa nɗom azwal wò a na nggo.
\v 16 Mwote uPonzhi i ma̱n pa̱ ô ka̱mshi azwal wò ka̱ ashe awo anəm uga nɗom pa̱ ô gba̱l mi ká̱ uyen mi na ô kap yi ká̱ iya̱m akup Inan.>
\p 
\v 17 <<Kang ǹyangmata̱ uzwal ɓu là pa̱,<N nyinyi pa̱ nnap-nlà aponzhi i na nra igwak na á mi ka̱kul mmaɓu wa amaleka Inan uva nyi nva̱n iya̱m inəna̱n ká̱ iya̱m iɓá̱ngɓa̱ng. Re uYawe Inan ɓu a təm nzəng ká̱ ɓu.> >>
\p 
\v 18 Te uponzhi là ûchar va̱ ta pa̱, <<Kang wa bwam ama̱n mɓəp va̱ mmami ka̱ ngga mɓəp ɓu ka̱t.>>
\p Uchar va̱ ta là pa̱, <<Re unəm uga nzhi mi uponzhi a là nnap wò.>>
\p 
\v 19 Te uponzhi ɓəp pa̱, <<Anung aJowap na ka̱ ashe nnap ɓu va̱ ta̱ ka̱t ɗò?>>
\p Uchar va̱ ta na ama̱n pa̱, <<Nva̱ nna u yà ká̱ irirì te, unəm uga nzhi mi uponzhi, unəm uro yà i dap ká̱ iya̱m iva̱ unəm uga nzhi mi uponzhi là ka̱t. À, uzwal ɓu uJowap uwa nak mi pa̱ n nəm iya̱m va̱ ta̱, kang uwa nak nkpaktak nnap-nlà va̱ ta̱ ka̱ anung azwal ɓu.
\v 20 UJowap nəm iya̱m va̱ ta̱ ka̱kul pa̱ ô ɗa̱mshi nnap va̱ ta̱. Unəm uga nzhi mi uwa yà ká̱ aghan wa amaleka Inan va nyi iya̱m pa̱ kpaktak va̱ kà̱ nyà ka̱ apambin.>>
\p 
\v 21 Te uponzhi là ûJowap pa̱, <<N fe chit, mi ga nnənəm. Ga ɓa ká̱ uAbsalom, uyen nza̱m va̱ ta.>>
\p 
\v 22 Te uJowap kuchi ka̱ mbin ka̱ mpyal aponzhi na ichumchum á na, uza̱ far nnap nəna̱n á na, uJowap là pa̱, <<Nda ta̱ uzwal ɓu ya nchə̀r mba̱lba̱l chit ka̱ mpyal ɓu anəm uga nzhi mi uponzhi ka̱kul nva̱ u ma̱n ká̱ achal mi va̱ ta̱ á.>>
\p 
\v 23 Te uJowap wong ga aGeshur, kang à ɓa ká̱ uAbsalom ka̱ aUrushelima.
\v 24 Ǹnyi te, uponzhi là pa̱, <<Nkpak pa̱ uAbsalom a ga nzhi wò, uza̱ i ya ìwu mi ka̱t.>> Te uAbsalom ga nzhi wò, uza̱ ya ìwu aponzhi ka̱t.
\p 
\v 25 Ka̱ ashe oIsa̱rila pa̱ kpaktak te unəm uro yà va̱ mí shep iɓiɓyen wa aAbsalom ka̱t. Ɓan ka̱ apal ishishi ga chu ashəshar iya̱m iro ɓa̱p ka̱ ka̱t.
\v 26 Uza̱ i kpat akpap ishi wò nva̱ng pa̱ nzəng ka̱ ashe izun ka̱kul akpap ishi va̱ ta i ɗək ka̱ na. Awalang va̱ uza̱ i kpat akpap ishi wò te, uza̱ i màl iɗəɗək kang i yà ashekel igba̱l pa̱ iparəm\f + \fr 14.26 \fq ashekel igba̱l pa̱ iparəm:\ft Ipipir na ta̱ pa̱ alaba pa̱ tukun.\f* ka̱ atak iya̱m iga mmàl iɗək ka̱ nzhi iponzhi.
\p 
\v 27 UAbsalom ka̱ ovan onunggwan pa̱ oshatɗing ká̱ uyen uchar pa̱ uzəng. Uyəyen uchar va̱ ta aɗiɗin pa̱ uTamar, kang uza̱ uchar uɓyenɓyen.
\p 
\v 28 UAbsalom təm ka̱ ashe aUrushelima izun pa̱ ìparəm, uza̱ ya uponzhi ka̱t.
\v 29 Te uAbsalom re nre ká̱ uJowap pa̱ a ɓa na ô re na ka̱ atak aponzhi te, uJowap yang ká̱ mɓa. Uza̱ re nre mpəpar, ǹnyi te, uza̱ yang ká̱ mɓa.
\v 30 Te uza̱ là ôkpari wò pa̱, <<O dər, iram ìzangzəng aJowap i ya dat ká̱ iji mi. Ó ga na o pa apər kà̱.>> Te okpari aAbsalom ga pa apər ka̱ iram va̱ ta.
\p 
\v 31 Te uJowap ga nzhi aAbsalom kang à ɓəp na pa̱, <<Ka̱kul iza̱ kang okpari ɓu pa apər ka̱ iram mi yà?>>
\p 
\v 32 UAbsalom là ûJowap pa̱, <<Dər, n re nre kà̱ ɓu, n là pa̱, <U ɓa na n re ɓu ka̱ atak aponzhi na u ɓəp na a mi pa̱, <<Iza̱ nak kang u re nre ká̱ mi ka̱ aGeshur pa̱ m ɓa yà? a yà pa̱ u ɗom nya mi ka̱t á.>> > Ǹyangmata̱ te, n ɗom pa̱ n ya uponzhi kang a yà pa̱ na n yà ká̱ mpat nro te, uza̱ a gba̱l mi.>>
\p 
\v 33 Te uJowap ga atak aponzhi kang à là iya̱m va̱ ta̱ a na. Te uponzhi wór uAbsalom, kang uza̱ ɓa kuchi ka̱ mbin na ichumchum ûponzhi. Kang uponzhi wong má njang ûAbsalom.
\c 15
\s1 UAbsalom fa iya̱mkak ká̱ uDawuda
\p 
\v 1 Kà̱ nva̱ngva̱ ta te uAbsalom yáp ipəri ká̱ akeke va ipəri i dap, uza̱ wa yà ká̱ onəm ìsəm pa̱ itukun va i chən ka̱ mpipyal á.
\v 2 Uza̱ i wong ká̱ iɓotak i sat ka̱ anung asa̱l ga ntar ashe ìtong, a yà pa̱ unəm uro ɓa atak aponzhi ká̱ akwali aro te, uAbsalom i ga atətak i ɓəp na pa̱, << U fa ka̱ nza̱ ìtong yà?>> Unəm va̱ ta i na ama̱n pa̱, <<Uzwal ɓu ka̱ akum ìjili iro ka̱ ashe oIsa̱rila.>>
\v 3 Te uAbsalom i là á na pa, <<Dər, nnap-nlà ɓu yar chàng kang ká̱ nnandər kpa, ǹnyi te, unəm uro yà uponzhi nak pa̱ a fe nnap-nlà ɓu ka̱t.>>
\v 4 Uza̱ i là ka̱ kpa pa̱, <<Ká̱ yà pa̱ mmá nak mi pa̱ n nnap-akwali kà̱ mbin va̱ ta̱ te, ká̱ n nnap-akwali aga nnandər n̂kpaktak unəm va̱ i ɓa atak mi.>>
\p 
\v 5 A yà pa̱ unəm i ɓa i ɗom pa̱ ô kuchi ô re anung á na te, uAbsalom i yichi awo i kpan na i fəkchi na i mmá njang á na.
\v 6 Ka̱ asa̱l va ta uAbsalom nəm ka̱ ôIsa̱rila va̱ i ɓa ka̱ atak aponzhi ka̱kul akwali á, wanta na uza̱ dap nnap-nnəm onəm oIsa̱rila ká̱ ga atətak.
\p 
\v 7 Ka̱ nva̱ng izun pa̱ ineɗing te, uAbsalom là ûpo wò uponzhi pa̱, <<Wa ma̱n te wa re mi n ga aHebron na n yə́l nsar nnap-nlà mi va̱ n yar ûYawe á.
\v 8 Awalang va̱ uzwal ɓu ka̱ yà kà̱ ntəm ka̱ aGeshur ka̱ ashe aSuriya te, ká̱ n yar nsar nnap-nlà ûYawe pa̱, <Mi wop na ka̱ aHebron, a yà pa̱ uza̱ a le ká̱ mi ka̱ aUrushelima á.> >>
\p 
\v 9 Uponzhi là á na pa̱, <<Ga ká̱ ikangkang.>> Te uza̱ wong ga aHebron.
\p 
\v 10 Te uAbsalom re onəm oga nre ká̱ ayi ga n̂kpaktak oga akum oIsa̱rila, pa̱ a là pa̱, <<Ká̱ nfe mɓur agbəshi na byet te, o là pa̱, <UAbsalom uwa uponzhi ka̱ aHebron.> >>
\v 11 Onunggwan igba̱l pa̱ ìparəm ga nzəng ká̱ uAbsalom ova̱ fa ka̱ aUrushelima va uza̱ chál oza̱ chál. Onəm va̱ ta ga ká̱ ìgwak pa̱ izəng, oza̱ nyi iya̱m iro ka̱ ashe nrəng nnənap ka̱t.
\v 12 Awalang va̱ uAbsalom kà̱ ǹyichi oga nləfər te, uza̱ re nre ka̱ uAhitofel unəm oGilo, uzəngtəng ka̱ ashe onəm oga nna ichən ûDawuda pa̱ a ɓa ka̱ aGilo ìtutong. Wanta ngbar izər ga nfa iya̱mkak va̱ ta kám, kang onəm oga nyar nva̱ng aAbsalom ga mpyal ká̱ mmak.
\s1 UDawuda chə́r re aUrushelima
\p 
\v 13 Te unəm uga nre uro ɓa atak aDawuda là á na pa̱, <<Igwak oIsa̱rila le chit ga ka̱ atak aAbsalom.>>
\p 
\v 14 UDawuda là ônəm oga mpyal wò va̱ nzəng ka̱ na ka̱ ashe aUrushelima pa̱, <<I chəng, ka̱t te, uAbsalom i ɓa i gbá̱ng yi pa̱ kpaktak. I gha̱n i fa kang uza̱ a ɓa a mul yi, a nəm ìɓa̱ng a yi, kang ì gbá̱ng onəm ka̱ ashe ìtong pa̱ kpaktak ka̱t.>>
\p 
\v 15 Onəm oga mpyal aponzhi na ama̱n pa̱, <<Ozwal ɓu i nəm nkpaktak iya̱m va̱ unəm uga nzhi yi i yàk pa̱ í nəm.>>
\p 
\v 16 Uponzhi fa, kang nkpaktak onəm oga ashe nzhizhi yar nvəva̱ng, ǹnyi te, uza̱ re ochar va mí nak ka̱ ashe nzhi pa kùk pa̱ ogba̱pchi pa̱ à nak ishi ká̱ nzhi.
\v 17 Te uponzhi fa ká̱ nkpaktak onəm va̱ kà̱ nyar nvəva̱ng, kang oza̱ ɓa tong ka̱ nkur ìtong.
\v 18 Nkpaktak okparikpari ləp mpipyal, ká̱ nkpaktak oKereti ka̱ oPeleti, oma i pángchí uponzhi ka̱ nkpaktak oGiti va̱ igba̱l pa̱ ikpa̱ɗing, ova ka̱ yar nvəva̱ng ka̱ aGat ləp mpyal ûponzhi.
\p 
\v 19 Uponzhi là ûItayi unəm oGiti pa̱, <<Sang kang ɓu ga nzəng ká̱ yi yà? Le na u təm ka̱ atak aponzhi upipe, ka̱kul mmaɓu unəmchən u chichər ka̱ mbin ɓu kang u ɓa.
\v 20 U ɓa ká̱ nlám. Kang n̂da ta̱ te mi nak ɓu pa̱ u ranggang nzəng ká̱ yi, nva̱ n na nnyi atak va̱ chit mmami kà̱ ngga kà̱ ka̱t ɗô? Le nva̱ng nzəng ka̱ owan ɓu. Re uYawe a nyám ikin ká̱ nnap nnəna̱n a ɓu.>>
\p 
\v 21 Ǹnyi te, uItayi na ama̱n ûponzhi pa̱, <<Nva̱ uYawe uwa ká̱ irirì kang unəm uga nzhi mi uponzhi uwa yà ká̱ irirì te, nkpaktak atak va̱ unəm uga nzhi mi uponzhi i yà kà̱, ká̱ irirì ka̱t te ikú, te uzwal ɓu i yà ka̱ ta.>>
\p 
\v 22 Te uDawuda là ûItayi pa̱, <<Watar ga.>> Te uItayi unəm oGiti watar ká̱ nkpaktak oshozha wò ká̱ onəm oza̱ va̱ nzəng ká̱ na.
\p 
\v 23 Nkpaktak onəm va̱ ya uponzhi kà̱ nwatar te, bà ayə́ng pa̱ gbá̱ngbá̱ng. Uponzhi ká̱ onəm wò pa̱ng nwangsang aKidron te, oza̱ kpan asa̱l ashe nzam mmaləng.
\p 
\v 24 Dər, uZadok uwa yà ka̱ ta kpa, ká̱ nkpaktak oLawi va̱ nzəng ka̱ na kà̱ nyar akwati aga nsar nnap-nlà Inan á. Oza̱ ɓa nak ka̱ mbin, kang uAbiyata yichi nləfər ka̱ ta, nkpaktak onəm fa watar re ìtong pa̱ chatchat kang.
\p 
\v 25 Te uponzhi là ûZadok pa̱, <<Le ká̱ akwati aga nsar nnap-nlà Inan ka̱ ashe ìtong. A yà pa̱ uYawe ya məmal ká̱ na te, uza̱ i le ká̱ mi pa̱ m ɓa n ya akwati aga nsar nnap-nlà Inan kà̱ɗi ká̱ atak ntətəm.
\v 26 Ǹnyi te, a yà pa̱ uza̱ là pa̱, <N fe nchang ɓu ka̱t,> te mmami na ta̱, uza̱ a nəm ká mi iya̱m va̱ uza̱ ya məmal á.>>
\p 
\v 27 Te uponzhi là ûZadok unəm uga mpyal awop kpa pa̱, <<Mmaɓu unəm uga nkpan ipir nnap. Le ga ashe ìtong ká̱ nnap nnəna̱n mi. Yar uyen ɓu uAhimaz ununggwan nzəng ká̱ ɓu ká̱ uJonatan uya uAbiyata ununggwan kpa. Mmaɓu ká̱ uAbiyata o le ká̱ ovan wó onunggwan.
\v 28 Mi lok ka̱ atak mpa̱l awang ka̱ ashe nzam mmaləng, mi ya nre ka̱ atak ɓu kang.>>
\v 29 Te uZadok ká̱ uAbiyata yar akwati aga nsar nnap-nlà Inan le ká̱ ka̱ aUrushelima, kang oza̱ təm ka̱ ta.
\p 
\v 30 Ǹnyi te, uDawuda ga mpyal ká̱ achen, uza̱ yà ká̱ akwap ka̱ ashar ka̱t, uza̱ gún ishi wò, uza̱ ka̱ nyə́ng nva̱ uza̱ ka̱ nkyen aɓam aZaitun. Nkpaktak onəm va̱ nzəng ká̱ na gún ishi oza̱, oza̱ ka̱ nyə́ng, oza̱ ka̱ nkyen aɓam.
\v 31 Ǹyangmata̱ te, mmá là ûDawuda pa̱, <<UAhitofel unəm uga nna ichən a ɓu uwa yà uzəngtəng ka̱ ashe onəm oga ngwal iya̱m nzəng ká̱ uAbsalom.>> Te uDawuda nəm afar pa̱, <<ÁYawe, re ichən va̱ uAhitofel i na ûAbsalom te, a yà ichən ilakchi.>>
\p 
\v 32 Ka̱ awalang va̱ UDawuda kyen ɓa chu apal aɓam, ka̱ atak va̱ onəm i wop Inan ka̱ te, uHushai, unəm oga aArki ɓa gwang na ka̱ ta, ká̱ ìlukwan ikankan, kang ká̱ mbin ká̱ ishi.
\v 33 UDawuda là a na pa̱, <<A ya pa̱ ɓu ga nzəng ká̱ mi te, ɓu ta̱l iɗək a mi.
\v 34 Ǹnyi te, a ya pa̱ ɓu le, ɓu ga ashe ìtong, kang ɓu là ûAbsalom pa̱, <APonzhi, mi ya ukpari ɓu. Ka̱ ya te, mmami ukpari apo ɓu, kang ǹyangmata̱ te, mi ya ukpari ɓu,> te ɓu ka̱mshi mi ka̱ atak ɓəkchi ichən va̱ uAhitofel i ɓa ká̱ á.
\v 35 UZadok ká̱ uAbiyata onəm oga nshì iya̱m awop oma ya nzəng ká̱ ɓu ka̱t ɗò? Là oza̱ nkpaktak iya̱m va̱ u fe ka̱ ashe nzhi aPonzhi á.
\v 36 Ovan oza̱, uAhimaz uya aZadok ununggwan, ká̱ uJonatan uya aAbiyata ununggwan oma ka̱ ta nzəng ká̱ oza̱. Iya̱m va̱ wa fe pa̱ kpaktak te, wa re oza̱ ká̱ a ɓa a la a mi.>>
\p 
\v 37 Te uHushai, ukpa aDawuda le ga aUrushelima, uza̱ ɓa chu mal dakdak ká̱ awalang va̱ uAbsalom ka̱ ntar ìtong va̱ ta ká̱ á.
\c 16
\s1 UDawuda ká̱ uZiba
\p 
\v 1 Awalang va̱ uDawuda lyam apal aɗuktum va̱ ta pa̱ ɗa̱p te, uZiba, uzwal aMefiboshet gwang na. UZiba uwa ká̱ oga azhaki pa̱ parəm va̱ wur nzəngkəng ìgba̱l pa̱ ìparəm, ká̱ aɓəng awar iba̱ngba̱ng ìgba̱l pa̱ ìzəng, ká̱ awar ikun ipipye ìgba̱l pa̱ izəng, ká̱ izəmɓa̱r ndəng ìba̱ngba̱ng pa̱ ìzəng.
\v 2 Uponzhi ɓəp uZiba pa̱, <<U ɓa ká̱ oga iya̱m va̱ ta̱ ka̱kul iza̱ yà?>> UZiba na ama̱n pa̱, <<Oga azhaki te, ka̱kul pa̱ onəm oga nzhi ɓu á kyen kà̱, nzəngkəng ká̱ oga awar ìkun te, ka̱kul pa̱ onəm á ri, kang ndəng ìba̱ngba̱ng te, ka̱kul unəm va̱ achen ga rwam na ka̱ ashe nzam te, uza̱ á wá.>>
\p 
\v 3 Te uponzhi ɓəp na pa̱, <<UMefiboshet, ukəka anəm uga nzhi ɓu uShawulu ka̱ che yà?>> UZiba na ama̱n pa̱, <<Uwa ka̱ ntəm ka̱ aUrushelima, ka̱kul uza̱ ka̱ nrəng pa̱, <N̂da va̱ ta̱ oIsa̱rila i ga nle ká̱ iponzhi akəka mi á mi.> >>
\p 
\v 4 Te uponzhi là ûZiba pa̱, <<Nkpaktak iya̱m va̱ iji aMefiboshet te, n na á ɓu chit.>>
\p Kang uZiba na ama̱n pa̱, <<Irirì aponzhi a gba̱ng, re n ya nchə̀r mba̱lba̱l ka̱ mpyal ɓu pa̱ ɗəkər, anəm uga nzhi mi.>>
\s1 UShimeyi pwat uDawuda
\p 
\v 5 Awalang va̱ uponzhi uDawuda ɓa chu aBahurim te, unəm uro fa ka̱ ta aɗiɗin pa̱, uShimeyi uya aGera ununggwan ka̱ akum aShawulu, nəm inok mpwat uDawuda.
\v 6 UShimeyi pak inok nkwan uponzhi ká̱ onəm oga nnəm inunok ká̱ ipang, kap ka̱ nva̱ pa̱ onəm oga nnəm inunok ká̱ oshozhashozha gang na gang á.
\v 7 Kang nva̱ uShimeyi ka̱ mpwat na te, i là pa̱ <<Ga cho, Ga cho, anəm uga ngba̱ng onəm, unəm lakchilakchi.
\v 8 UYawe ka̱ mpyat akat nchə̀r va̱ u tar ka̱ nzhi aShawulu, uwa u vyat itok iponzhiponzhi á. Ǹyangmata̱ te, uYawe na iponzhi ɓu chit ka̱ ashe awo ayen ɓu uAbsalom. Kang iya̱m iɓá̱ngɓa̱ng ya ɓu chit, ka̱kul mmaɓu unəm uga ntar nchə̀r.>>
\p 
\v 9 Te uAbishayi uya aZeruya ununggwan a là ûponzhi pa̱, <<Anəm uga nzhi mi, sang kang ɓu re ìva ìkúku va̱ ta̱ i pwat ɓu yà? Re mi n ga na n gəl ishishi.>>
\p 
\v 10 Ǹnyi te, uponzhi na ama̱n pa̱, <<Óvan aZeruya onunggwan, iza̱ yar wó ká̱ nnap nva̱ ta̱ yà? A yà pa̱ uYawe a là á na pa̱ uza̱ a pwat uDawuda te, uda kur mɓəp na pa̱, <Sang kang ɓu nəm pa yà?> >>
\p 
\v 11 Te uDawuda là ûAbishayi ká̱ nkpaktak onəm oga nnəm inunok pa̱, <<Uyen mi va̱ n mar ka̱ afu mi ka̱ nram irirì mi kpa, te nji anəm uga aBenjamin te, ijujwak ka̱t ɗò? Ó re na, uza̱ a pwat mi. Ka̱kul uYawe à là á na pa̱ uza̱ a nəm pa.
\v 12 Mwote uYawe i ya mɓək anung mi, kang uza̱ i nak nnap-nnəna̱n á mi ka̱kul mpwat va̱ uShimeyi pwat mi n̂da va̱ ta̱.>>
\p 
\v 13 Te uDawuda ká̱ onəm wò ga mpyal ká̱ achen. Ǹnyi te, uShimeyi yar ka̱ ngba̱k aɗuktum ɓàk nva̱ng oza̱ ká̱ mpwat uDawuda, i kwan na ká̱ ipang kang i dung mɓwang a na.
\v 14 Awalang va̱ uponzhi ká̱ nkpaktak onəm va̱ nzəng ka̱ na chu aWang aUrdun te, oza̱ bəlak pa̱ gənggəng kang oza̱ jul ka̱ ta.
\s1 Ichən aAhitofel ká̱ uHushai
\p 
\v 15 Te uAbsalom ká̱ nkpaktak onəm oIsa̱rila va̱ nzəng ká̱ na ɓa aUrushelima, kang uAhitofel wa nzəng ká̱ na.
\v 16 Te uHushai, unəm oArki, ukpa aDawuda, ga atak aAbsalom, kang uza̱ là á na pa̱ <<Irirì aponzhi atəm. Irirì aponzhi atəm.>>
\p 
\v 17 Ǹnyi te, uAbsalom ɓəp uHushai pa̱, <<Mma̱n va ta̱ ɓu nyám ûkpa ɓu ɗò? Iza̱ nak kang u ga nzəng ká̱ ukpa ɓu ka̱t yà?>>
\p 
\v 18 Te, uHushai na ama̱n ûAbsalom pa̱, <<Pa ka̱t. Mmami te, mi yar nva̱ng anəm va uYawe, ká̱ nggatək va̱ ta̱, ká̱ nkpaktak oIsa̱rila yak, kang mi təm nzəng ká̱ uwa.
\v 19 Ka̱ɗi te, uda má pa̱ n nəm inok á na yà? Uya aDawuda ka̱t ɗò? Wa nva n nəm upo ɓu te, wa nnà ta, mi nəm a ɓu kpa.>>
\p 
\v 20 Te uAbsalom là ûAhitofel pa̱, <<Na ichən ɓu a yi. Iza̱ i nəm yà?>>
\p 
\v 21 UAhitofel na ama̱n ûAbsalom pa̱, <<Ga, na u ra ká̱ ochar apo ɓu, ochar va mí nak ka̱ ashe nzhi pa kùk va̱ uza̱ re pa̱ a pángchí nzhi á. Te nkpaktak oIsa̱rila i fe pa̱, nɗa̱mshi nro i yà ká̱ ishimshe ɓu, ká̱ upo ɓu lap ka̱t. Iya̱m va̱ ta̱ i na nkam irəng n̂kpaktak onəm oga nyar nva̱ng ɓu.>>
\v 22 Ka̱kul nva̱ ta te, oza̱ pak aghal ka̱ apal nzhi ntátà aponzhi, kang uAbsalom tar ka̱ ashishe, ká̱ ìwu oIsa̱rila pa̱ kpaktak, kang a ga ra ká̱ ochar apo wò, ochar va mí nak ka̱ ashe nzhi pa kùk á.\x - \xo 16.22 \xt 2 aSam 12.11-12\x*
\p 
\v 23 Ka̱ ashe nra va̱ ta te, onəm i ka̱m ichən aAhitofel, ɓu là pa̱ nnap-nlà Inan uza̱ i là. Wa nnà ta uDawuda, ká̱ uAbsalom i ka̱m ichən aAhitofel.
\c 17
\s1 UHushai tàng uAbsalom
\p 
\v 1 Ka̱ɗi te, uAhitofel là ûAbsalom pa̱, <<Re n yak onəm ìkalong pa̱ ìgba̱pchi ama̱n pa̱ pa̱rəm (12,000), na i wà nva̱ng aDawuda ká̱ ìzwam va̱ ta̱.
\v 2 Mi ga mi ru na ká̱ ìkum ya uwa ká̱ nrwam achen ká̱ nchwan izər. Mi gba̱k na pa̱ gənggəng, kang nkpaktak onənəm ichəng. Mi gba̱l uponzhi ka̱ nkukwa,
\v 3 kang mi le ká̱ onəm a ɓu pa̱ kpaktak wa nva mi ga ká̱ ucharɗa̱p ka̱ nzhi aɓəɓar á. Irirì anəm pa̱ uzəng na ká̱ nkukwa mmaɓu kà̱ nrəram, aɓo onəm pa̱ kpaktak te, oza̱ á təm ká̱ ikángkáng.>>
\v 4 Te, ichən va̱ ta chàng ká̱ uAbsalom, ká̱ nkpaktak onəmgbak oga aIsa̱rila.
\p 
\v 5 Ǹnyi te, uAbsalom là pa̱, <<O ɓa ká̱ uHushai, unəm oArki, na i fe iya̱m va̱ uza̱ i là ka̱ apal nnap va̱ ta̱.>>
\p 
\v 6 UHushai ɓa chit te, uAbsalom là á na pa̱, <<Ichən va ta̱ uAhitofel na. I nəm wa nva̱ uza̱ là ɗò? A yà pa̱ inəm pa ka̱t, te wa là nji ɓu a yi.>>
\p 
\v 7 Te, uHushai na ama̱n ûAbsalom pa̱, <<Ichən va̱ uAhitofel na ka̱ awalang va̱ ta̱ te, a ɓyen ka̱t.
\v 8 U nyinyi pa̱ upo ɓu ká̱ onəm va̱ nzəng ka̱ na te, onunggwan ìkum olakchi ka̱t, kang oza̱ i nəm ìkum wa ìdaməng va mmá wur ivan kà̱ na. Upo ɓu unəm va nyi ashar ìkum pa̱ gənggəng, uza̱ i ya ká̱ nra nzəng ká̱ onəm ka̱t.
\v 9 Ǹyangmata̱ te, uwa i yà ka̱ ashe ache aro ka̱t te, uwa i bwam ka̱ atak aro. A yà pa̱ ka̱ ìkum ngga nggəshi na byet kang mmá gba̱ng onəm ɓu pa̱ ɗa̱p te, unəm va̱ pa̱ kap a fe te, i là pa̱, <Mmá gba̱ng onəm aAbsalom chit pa̱ makmak.>
\v 10 Iya̱m wa iva̱ ta i nak ununggwan va̱ kam ìgwak wa ìlir i le i sərak ká̱ ayər. Ka̱kul nkpaktak oIsa̱rila nyinyi pa̱ upo ɓu ununggwan uga nyi ìkum pa̱ gənggəng, kang onəm va̱ nzəng ká̱ na te, oga nkam ìgwak na kpa.
\p 
\v 11 <<Ka̱kul nva̱ ta te, mmami kà̱ nna ichən pa̱, re mmá ɓut nkpaktak oIsa̱rila á ɓu, á ɓan ka̱ aDan a ga achu aBeyersheba. Ìyəl oza̱ i yà wa ashishiri aga anung ìwa, kang mmaɓu ká̱ ishi ɓu te, ɓu ləp mpyal ôza̱, ó ga atak ìkum.
\v 12 Te i ru na ká̱ ìkum ka̱ atak va pa̱ káp i yá na kà̱, kang i zəpchi na wa nva̱ ìmimyang i ra ka̱ mbin á. Uza̱ ká̱ onəm wò te, mí nre unəm uro ká̱ irirì ka̱t.
\v 13 A yà pa̱ uza̱ a chə́r a tar ìtong iro te, nkpaktak oIsa̱rila i ram asang, kang i dap akamsəlang ìtong va̱ ta i ga ká̱ ka̱ ashe aba̱nda̱m, i re ìpang iro ìɓwakan ka̱ apal ìwuwan ka̱t.>>
\p 
\v 14 Te uAbsalom, ká̱ nkpaktak onəm oIsa̱rila là pa̱, <<Ichən va̱ uHushai, unəm oArki na te, a ɓyen ji aji aAhitofel ji.>> Ka̱kul uYawe a nak pa, na o vyap ichən inəna̱n aAhitofel, na ô ɓa ká̱ iya̱m iɓá̱ngɓa̱ng ka̱ apal aAbsalom.
\p 
\v 15 Te, uHushai wong byet, ga là ônəm oga mpyal awop, oma uZadok ká̱ uAbiyata pa̱, <<Ichən va ta̱ uAhitofel na ûAbsalom ká̱ onəmgbak oIsa̱rila pa̱ mmá nəm, ǹnyi te, ichən va̱ n na te nna ta̱.
\v 16 Ǹyangmata̱ te, ó nak nre a ga ûDawuda pa̱ kəlak pa̱, <Kang uza̱ a ra ka̱ anung Awang aUrdun ká̱ ìzwam va̱ ta̱ ka̱t. Ǹnyi te, uza̱ a ɗak a pa̱l agwong a tar nzam, a yà pa ka̱t te, mi zhì uponzhi ká̱ onəm va̱ nzəng ká̱ na pa̱ kpaktak.> >>
\p 
\v 17 UJonatan ká̱ uAhimaz oma ka̱ nlok ka̱ atak mɓəl ndəng nro mi wor pa̱ aEn-Rogel. Mmá nak uyen uchar uzwal uro chit pa̱ uwa i ga i là nre ôza̱, kang oza̱ ǹnyi te, i ga i là nre va̱ ta ûponzhi uDawuda. Oza̱ i nəm pa le kang mmá ya oza̱ ka̱ ntar ka̱ ashe ìtong va̱ ta ka̱t.
\v 18 Ǹnyi te, uyenza̱m uro ya oza̱, kang a ga là ûAbsalom. Te, uJonatan ká̱ uAhimaz chəng ga táng nzhi anəm uro ka̱ aBahurim. Uwa ká̱ ndəng nka̱pkà̱p ka̱ ashe agəla̱n nzhi wò, te oza̱ ɗòng ka̱ ashe ache ndəng nka̱pkà̱p va̱ ta, oza̱ bwam.
\v 19 Te, uchar anəm va̱ ta yar iya̱m kang a nàr ka̱ apal anung ndəng nka̱pkà̱p va̱ ta, te uza̱ nyáp ìkur ka̱ pəpal. Unəm uro nyi iya̱m iro ka̱ apəpal ka̱t.
\p 
\v 20 Awalang va̱ onəm aAbsalom ɓa chu atak achar va̱ ta ka̱ nzhizhi te, oza̱ ɓəp na pa̱, <<UAhimaz ká̱ uJonatan che ya?>>
\p Te uza̱ na ama̱n ôza̱ pa̱, <<Oza̱ pa̱ng awang chit.>> Onəm va̱ ta mwo atak, ǹnyi te, oza̱ ya unəm uro ka̱t, te oza̱ le ga aUrushelima.
\p 
\v 21 Nva̱ng va̱ onəm aAbsalom ga chit te, uAhimaz ká̱ uJonatan fa ka̱ ashe ache ndəng nka̱pkà̱p va̱ ta, oza̱ ga atak aponzhi uDawuda, kang oza̱ là á na pa̱, <<Wong kəlak, na u pa̱l awang aUrdun, ka̱kul ichən va̱ ta̱ uAhitofel na ka̱ apal ishi ɓu.>>
\v 22 Te uDawuda ká̱ nkpaktak onəm va̱ nzəng ká̱ na wong, kang a pa̱ng Awang aUrdun. Atak wong pa̱ ô tan te, unəm uro yà ɓur ka̱ ashe oza̱ uvəngva̱ uwa pa̱l chit ka̱t.
\p 
\v 23 UAhitofel ya chit pa̱ mmá ka̱m ichən wò ka̱t te, uza̱ ɗa̱mshi aZhaki wò, uza̱ kyen le ga nzhi wò ka̱ mbin wò. Nva̱ng va̱ uza̱ ɗa̱mshi ashe nzhi wò gba̱l te, uza̱ zong ishi wò ká̱ asang, uza̱ kú, kang mmá li na ka̱ ashe awap apupo.
\p 
\v 24 Te, uDawuda ga aMahanayim, kang uAbsalom ká̱ nkpaktak onəm oIsa̱rila pa̱ng Awang aUrdun.
\v 25 UAbsalom ka̱ kyer uAmasa chit pa̱ a yà uPonzhi oshozha ka̱ɗor aJowap. UAmasa te, uya aJeta ununggwan va fa ka̱ akum ìjili oIshmayil. Uchar aJeta te, uAbigel uya aNahash uwa ugənang ká̱ uZeruya unang aJowap á.
\v 26 UAbsalom ká̱ onəm oIsa̱rila ləp apa̱k ka̱ mbin aGileyat.
\p 
\v 27 Awalang va̱ uDawuda ɓa chu aMahanayim te, uShobi uya aNahash ununggwan, va̱ fa ka̱ aRaba oAmmon, ká̱ uMakir uya aAmiyel ununggwan va̱ fa ka̱ mbin aLo-Debar, kang ká̱ uBarzilayi unəm oga aGileyat va̱ fa ka̱ aRogelim,
\v 28 Oza̱ ɓa ka̱ oga iya̱m va̱ ta̱ ka̱ awo, oza̱ ɓa ká̱ oga ndakal nra, ká̱ ikpang, ká̱ ngbət. Oza̱ ɓa ká̱ ìzangzəng, ká̱ ibəshi, ká̱ mma̱k, ká̱ ikur iforfor, ká̱ aso, ká̱ aso njiman,
\v 29 ká̱ mmàl irizhe, ka̱ mbyal iya̱m nkang nnəknək, ká̱ itam, ká̱ mbyal ina nnəknək. Oza̱ ɓa ká̱ oga iya̱m va̱ ta̱ ôza̱ pa̱ oza̱ a ri. Ka̱kul oza̱ nyinyi pa̱, uDawuda ká̱ onəm wò oma kà̱ nfe ká̱ ayang, ká̱ nrwam achen, ká̱ ndəng ngbà̱l, ka̱ ashe nzam.
\c 18
\s1 Ikú aAbsalom
\p 
\v 1 Te, uDawuda ɓut oshozha va̱ ka̱ yà nzəng ká̱ na, kang a kap oza̱ idongkong iro ká̱ onəm ìkalong, kang iro ká̱ onəm ìgba̱l. Nna chit te, uza̱ kyep onəm oga mpyal ka̱ apal nza̱ ìdongkong nggo.
\v 2 UDawuda kap oshozha wò idongkong pa̱ ishatɗing. Uza̱ nak ìdongkong iro ka̱ avəng aJowap, ìdongkong ìpəpar ka̱ avəng aAbishayi ugənang aJowap uya aZeruya ununggwan, kang ìdongkong ishishat te, uza̱ nak ka̱ avəng aItayi unəm oGiti. Te, uponzhi là ôshozha wò pa̱, <<Mmami ka̱ ishi mi, mi ga ìkum ta̱ nzəng ká̱ wó.>>
\p 
\v 3 Ǹnyi te, oshozhashozha na ama̱n pa̱, <<Pa ka̱t, ɓu ya ká̱ ngga nzəng ká̱ yi ka̱t. Ka̱kul a yà pa̱ i wong ichəng te, i ɗak onəm aAbsalom kà̱ yi ka̱t. Ka̱t te, a yà pa̱ oza̱ a gba̱ng onəm yi nkap ka̱ ishimshe nggo te, i ɗak oza̱ ka̱t. Oza̱ ɗom mmaɓu na ka̱kul u ji onəm yi ikalong pa̱ igba̱pchi ji. I kakap pa̱ u təm ka̱ ashe ìtong va̱ ta̱, na u re ǹre á yi ká̱ nka̱mshi.>>
\p 
\v 4 Te uponzhi là ôza̱ pa̱, <<Iya̱m va̱ o ya má ká̱ wó pa̱ kap te, mi nəm nna.>>
\p Te uponzhi sat ka̱ ngba̱k anung asa̱l ìtong va̱ ta ka̱ awalang va̱ nkpaktak oshozhashozha ka̱ nwatar ka̱ atak oga idongkong ìgbal-ìgba̱l, ká̱ ìkalong-ìkalong.
\v 5 Te, uponzhi là ûJowap ká̱ uAbishayi, ká̱ uItayi pa̱, <<Ka̱kul mi te, o nəm dakdak ká̱ uyenza̱m va̱ ta uAbsalom á.>> Kang nkpaktak oshozha fe uponzhi fe ka̱ nlà nnap ta ka̱ apal aAbsalom û nza̱ unəm ga mpyal oza̱ nggo.
\p 
\v 6 Te oshozha aDawuda fa ga ashe agbagba na o lung ìkum ká̱ oshozha oga aIsa̱rila, kang oza̱ lung ìkum va̱ ta ka̱ ashe ikun iga aEfrayim.
\v 7 Te, oshozha aDawuda ri oshozha oIsa̱rila ká̱ ìkum. Kang mmá gba̱ng onəm pa̱ makmak ká̱ nda ata. Ìyəl onəm va̱ mmá gba̱ng ká̱ nda va̱ ta te, ìkalong ìsəm pa̱ ìparəm (20,000).
\v 8 Ìkum va̱ ta wong nyanggal ka̱ ashe mbin pa̱ kap, kang onəm va̱ nzam ri te, oza̱ yəl ji onəm va̱ ji mmá gba̱ng ká̱ ndokchi.
\p 
\v 9 Nná mmá ka̱ ashe nlung ìkum va̱ ta te, uAbsalom wong gwang ká̱ oshozha aDawuda. UAbsalom ɗak pa̱ ô chə́r ka̱ apal alabitiri wò te, uza̱ tar ka̱ kum ìkun ro mi wór pa̱ aOak, te ishishi tar gəra̱m ka̱ agong ìkun va̱ ta. Alabitiri ǹnyi te, a chər watar ga iya̱m wò re na uza̱ i zere ka̱ ta.
\v 10 Unəm ro ka̱ ashe onəm aDawuda ya iya̱m va̱ ya uAbsalom, te uza̱ ga là ûJowap pa̱, <<N ya uAbsalom uwa ka̱ nzere ka̱ apal ìkun aOak ka̱ cho.>>
\p 
\v 11 Te uJowap là ûnəm va̱ ɓa là nnap ata á na pa̱, <<Iza̱ á? U ya na á? Iza̱ nak kang ula̱p na, ugba̱l ka̱ ata ka̱t ya? Ká̱ n na imwa aɓu ká̱ aazurfa pa̱ gba̱pchi, ká̱ iya̱m ga nkpan afu ônəm oga nnəm igwan.>>
\v 12 Ǹnyi te, unəm va̱ ta là ûJowap pa̱, <<A yà pa̱ mmá na aazurfa á mi ìkalong pa̱ izəng ka̱ awo te, mi yà ká̱ ngba̱l uya aponzhi ka̱t. Ka̱kul kà̱ achwang yi, i fe uponzhi fe ka̱ nlà â ɓu, ká̱ uAbishayi, ká̱ Itayi pa̱, <O nak ishi nak á mi ká̱ uyenza̱m va̱ ta uAbsalom, kang o gba̱l na ka̱t.>
\v 13 Ka̱ yà pa̱ n pyen nnap va̱ ta kang n gba̱l na te, uponzhi ka̱ wong ka̱ fe, te ká̱ u chə́r ká̱ u gba̱ng ka̱ mi. Ǹnyi te, iya̱m ro ya ibwambwàm ka̱ atak aponzhi ka̱t.>>
\p 
\v 14 Te, uJowap là a na pa̱, <<Mi yà ká̱ nvyap awalang mi nta̱l ká̱ ɓu ká̱ ta̱ ka̱t.>> Te uza̱ wur aɓár pa̱ shatɗing ká̱ awo kang a ga atak aAbsalom, ya uwa ka̱ yà ka̱ nzere ká̱ irirì ka̱ apal ikun aOak, kang a kyep na ká̱ oga aɓár pa̱ shatɗing va̱ ta ka̱ ìkwoksok.
\v 15 Te, ovan nza̱m pa̱ ogba̱pchi oga nwur iya̱m ɓang uJowap gang uAbsalom kang oza̱ nəm na gba̱l.
\v 16 Te uJowap ɓur agbəshi ka̱kul nɗa̱t ìkum, kang oshozhashozha re nwa nva̱ng oshozha oIsa̱rila.
\v 17 Oza̱ yar akúm aAbsalom oza̱ mandar ka̱ ashe ache agbá̱nggbà̱ng ro ka̱ ashe nzam, kang oza̱ wur ipang ɓəp a na ká̱ ishi. Ǹnyi te, nkpaktak oshozha oIsa̱rila chəng ga oga nzhi oza̱.
\p 
\v 18 Ka̱ awalang va̱ uAbsalom wa ka̱ yà ká̱ irirì te, uza̱ ka̱ pak ìpang iro ka̱kul nrəng ká̱ ishi wò ka̱ ashe aba̱nda̱m aponzhi. Uza̱ nəm pa, ka̱kul uza̱ rəng nnap pa̱, <<N yà ká̱ uyen ununggwan uro va̱ i yar aɗin mi ka̱t.>> Uza̱ sok aɗin wò îpang va̱ uza̱ me ta. Nna nak kang na mmá ka̱ nwor ìpang va̱ ta, ìpang aAbsalom ɓa chu nda va̱ ta̱ á.
\s1 UDawuda yə́ng ikú aAbsalom
\p 
\v 19 Te uAhimaz uya aZadok ununggwan là uJowap pa̱, <<Re n chə́r, n ga, n shet uponzhi pa̱ uYawe ka̱m ishishi chit ka̱ awo okpa ìkukum.>>
\p 
\v 20 UJowap na ama̱n a na pa̱, <<O'o, ɓu ga ká̱ nre nda ata̱ ka̱t. Nda aro te, ɓu gəga ká̱ nre, ǹnyi te, ɓu ga ká̱ nre nda ata̱ ka̱t ka̱kul uya aponzhi ununggwan a kú.>>
\p 
\v 21 Te uJowap wór unəm uga aKush\f + \fr 18.21 \ft aKush te n na mi wor pa̱ aEtopiya.\f* ro re na pa̱, <<Ga ɓu là uponzhi iya̱m va̱ u ya á.>> Te unəm uga aKush va̱ ta kuchi ûJowap, kang a wong ga ká̱ nchə́r.
\p 
\v 22 Te uAhimaz uya aZadok ununggwan, á là ûJowap ka̱ɗi pa̱, <<Iya̱m va̱ pa̱ kpaktak i ga nyà te, a ɗak mi ka̱t. Re mi na n ga ká̱ nva̱ng a nəm uga aKush.>> Ǹnyi te, uJowap là á na pa̱, <<Ayen mi, iza̱ nak kang ɓu ɗom pa̱ uga yà? Nna u nyinyi pa̱ nre ta̱ te, imwa yà ka̱ ka̱t á.>>
\p 
\v 23 UAhimaz là pa̱, <<I yà sang nggo te, n ɗuɗom pa̱ n chə́r n ga ká̱ nna.>> Te uJowap là á na pa̱, <<Chə́r ga ɗak.>> Te uAhimaz yar asa̱l va̱ wòl agbagba aUrdun, kang uza̱ chə́r ga watar unəm oga aKush va̱.
\p 
\v 24 UDawuda wa ka̱ yà kà̱ ntəm ka̱ ishimshe oga anung asa̱l pa̱ aparəm aga ìtong va̱ ta te, unəm uga mpángchí atak kyen ɓa ga nkur anung asa̱l ìtong iga akamsəlang va̱ ta. Uza̱ wong ká̱ ishi te, uza̱ ya unəm chit ka̱ nchə́r i ɓa atak oza̱ ká̱ nkukwa.
\v 25 Uza̱ ləp a chu là uponzhi. Te uponzhi là pa̱ <<A yà pa̱ uza̱ ká̱ nkukwa wo te, ya uza̱ ka̱ ǹre nnəna̱n.>> Unəm va̱ ta ɓa datkulung na chwat.
\v 26 Unəm uga mpángchí atak va̱ ta ya unəm ukak chit ka̱ɗi ka̱ nchə́r i ɓa te, uza̱ là unəm ga ndər anung asa̱l ìtong va̱ ta pa̱ <<Dər, unəm uro wa ichə́r i ɓa cho.>>
\p Te uponzhi là pa̱, <<Uza̱ ka̱ mɓa ká̱ nre nnəna̱n na kpa.>>
\p 
\v 27 Unəm uga mpángchi atak va̱ ta là pa̱, <<A nəm á mi na unəm uga nggəshi va̱ ta ka̱ chə́r wa aAhimaz uya aZadok ununggwan.>>
\p Te Uponzhi là pa̱, <<Uza̱ unəm ukin, uza̱ ka̱ mɓa ká̱ ǹre nəna̱n.>>
\p 
\v 28 Te uAhimaz ləp a chu ûponzhi pa̱, <<Ndaktak yà ka̱t.>> Uza̱ kuchi ìwuwu vang asa̱l vəng ka̱ mpyal aponzhi, uza̱ là pa̱, <<Ashep təm aji aYawe Inan ɓu chit, va̱ na onəm va̱ fa iya̱mkak ká̱ ɓu ka̱ ashe awo ɓu anəm uga nzhi mi uponzhi.>>
\p 
\v 29 UPonzhi ɓəp pa̱, <<UAbsalom uyenza̱m va̱ uwa yà ukángkáng ɗò?>>
\p Te uAhimaz na ama̱n pa̱ <<Ka̱ awalang va̱ uJowap ka̱ nre mi te, n ya atak nyanggal. Ǹnyi te, n nyi iya̱m va̱ fa ka̱t.>>
\p 
\v 30 UPonzhi là á na pa̱, <<Sat ka̱ ngba̱k na u lok.>> Te uza̱ le ta̱l ka̱ ngba̱k va̱ pa̱ kwak.
\p 
\v 31 Te unəm oga aKush ɓa kang à là pa̱, <<Anəm uga nzhi mi, uponzhi, fe nnap-nlà nchángchàng. Ká̱ nda ta̱ te uYawe na igwan a ɓu chit ka̱ apal nkpaktak onəm va̱ fa iya̱mkak ká̱ ɓu.>>
\p 
\v 32 Te uponzhi ɓəp na ka̱ɗi pa̱, <<UAbsalom uyenza̱m va̱ uwa yà ukángkáng ɗò?>>
\p Unəm oga aKush na ama̱n pa̱ <<Re okpa ìkum anəm uga nzhi mi uponzhi, ká̱ nkpaktak onəm va yar inga ka̱ apal ɓu a yà wa ayenza̱m va̱ ta.>>
\p 
\v 33 Ichəgwak ləp uponzhi, te uza̱ kyen ɓa ga nzhi ngga apal ngga anung asa̱l ìtong va̱ ta, uza̱ kà̱ nyə́ng i là pa̱, <<Áyen mi uAbsalom, áyen mi, áyen mi uAbsalom, kakap mmami na ka̱ nkú, mmaɓu ka̱t. ÁAbsalom, uyen mi, uyen mi.>>
\c 19
\s1 UJowap ra̱n ká̱ uDawuda
\p 
\v 1 Mmá là ûJowap pa̱ uDawuda ka̱ nyə́ng ikú aAbsalom ká̱ mɓa̱ng ìgwak.
\v 2 Ka̱kul nva̱ ta te, ìgwan va̱ mmá nəm ká̱ n̂da va̱ ta te, a wal aɗor ka̱ atak onəm pa̱ kpaktak, ka̱kul onəm fe pa̱ uponzhi ka̱ nyə́ng ka̱kul ayen wò ununggwan.
\v 3 Oshozha mwom kang i táng ìtong n̂da va̱ ta wa oshozha va mmá ri ká̱ ìkum kang iwuswa nəm oza̱ kà̱ ntáng ìtong á.
\v 4 Uponzhi gún asa̱l awu wò kang i yə́ng pa̱ gbá̱nggbá̱ng, i là kà̱ pa̱, <<Àyen mi uAbsalom, áAbsalom, áyen mi, áyen mi.>>
\p 
\v 5 Te UJowap ga tar nzhi aponzhi kang à là á na pa̱, <<N̂da ta̱ u na iwuswa ôshozha ɓu chit. Oza̱ mà ka̱m ishi irirì ɓu, ká̱ irirì ovan ɓu onunggwan ká̱ ochar, ká̱ ochar ɓu, ká̱ ochar va mí nak ka̱ ashe nzhi pa kùk.
\v 6 U ma̱n unəm uga nkpang ɓu wà, onəm va̱ ma̱n ɓu ǹnyi te, u yang oza̱. N̂da ta̱ u nyám chit mbang pa̱, onəm oga mpyal oshozha ɓu, ká̱ onəm va̱ ka̱ vəng oza̱, a sat iya̱m iro ka̱ mpyal ɓu ka̱t. N ya chit pa̱ ka̱ chəchàng ká̱ ɓu, ká̱ yà pa̱ uAbsalom uwa yà ká̱ iriri kang mmayi te ká̱ kú pa̱ kpaktak.
\v 7 Ǹyangmata̱ wong fa na u kam irəng ônəm ɓu. A yà pa̱ ɓu wong ɓu fa ka̱t te, n sóng anung ká̱ uYawe, unəm uro i yà ká̱ ntəm nzəng ká̱ ɓu ká̱ izwam va̱ ta̱ ka̱t. Nva̱ ta̱ i ga mɓá̱ng i ji oga iya̱m va̱ ji ka̱ ya ɓu ká̱ ivanza̱m ɓu ɓa chu n̂da va̱ ta̱.>>
\p 
\v 8 Te uPonzhi wong fa təm ka̱ atak va̱ mí ɓut kà̱ ka̱ anung asa̱l ìtong. Awalang va̱ mmá là ônəm pa̱, <<Uponzhi uwa təm ka̱ anung asa̱l ìtong.>> Te, onənəm pa̱ kpaktak ɓa atətak.
\p Ǹnyi te, oshozha oIsa̱rila ka̱ chəng chit ka̱ ga oga nzhi oza̱.
\s1 UDawuda le aUrushelima
\p 
\v 9 Onəm oga aIsa̱rila pa̱ kpaktak ka̱ ndap izər ká̱ izər oza̱ pa̱, <<Uponzhi Dawuda wa ka̱m ishi yi ka̱ atak onəm ga nkpang yi oFilisti. Ǹyangmata̱ te, uza̱ chə́r chit, uza̱ re mbin ka̱kul aAbsalom.
\v 10 Kang uAbsalom va̱ i kyer na pa̱ a ya uponzhi yi te, a kú chit ka̱ atak ìkum. Iza̱ nak kang na o là iya̱m iro chit ka̱ apal nle mɓa ká̱ uponzhi ka̱t yà?>>
\v 11 Oga nnap-nlà va̱ ta̱ oIsa̱rila ka̱ nləla tar achwang aPonzhi uDawuda te, uza̱ re ǹre ga atak onəm oga nshì iya̱m awop oma, uZadok ká̱ uAbiyata pa̱ mmá là oza̱ pa̱ oza̱ a ɓəp onəmgbak oYahudi pa̱, <<Iza̱ nak kang oza̱ oma i yà oga nkur anung ka̱ nlà nnap ngga nle ká̱ uponzhi ka̱ nzhizhi yà?
\v 12 Mmawó na ogənang mi, izər ká̱ nchə̀r mi. Iza̱ nak kang mmawó na o tong onəm oga nkur anung ka̱ nle ká̱ uponzhi ka̱ nzhi yà?
\v 13 O là ûAmasa pa̱, <Mmaɓu izər ká̱ nchə̀r mi ka̱t ɗò? Inan á nap-akwali ká̱ mi, a yà pa̱ mmaɓu na uponzhi ìkum oshozha oIsa̱rila ka̱ anung aJowap ka̱t á.> >>
\p 
\v 14 Wantá na uDawuda ga̱ɓa̱n igwak onəm oga aYahudi yà wa igwak anəm pa̱ uzəng. Te oza̱ re ǹre ûponzhi pa̱ uza̱ a le nzhi ka̱ nkpaktak onəm va̱ ka̱ atətak á.
\v 15 Te uponzhi ru asa̱l nzhi uza̱ ɓa chu anung aWang aUrdun.
\p Ǹyangmata̱ te, onəm oga aYahuda ɓa aGilgal ka̱kul pa̱ na o gwang uponzhi, na o ka̱mshi na kà̱ mpa̱l aWang aUrdun.
\v 16 UShimeyi uya aGera ununggwan ka̱ akum ìjili aBenjamin ka̱ aBahurim, gha̱n fa ga nzəng ka̱ onəm oga aYahuda ka̱kul pa̱ na o gwang uponzhi uDawuda.
\v 17 Uza̱ nzəng ká̱ onəm ikalong pa̱ izəng (1,000) ka̱ akum ìjili aBenjamin, nzəng ká̱ uZiba uzwal aponzhi uShawulu, uva̱ ka̱ ovan pa̱ ogba̱pchi ama̱n pa̱ tukun, ká̱ okpari ìsəm pa̱ ìparəm, oza̱ ga aUrdun pa̱ na o gwang uponzhi.
\v 18 Oza̱ pa̱ng awang pa̱ na o pa̱ng onəm aponzhi, na o nəm iya̱m va̱ á na uza̱ ɗom á.
\p Awalang va̱ uShimeyi uya aGera ununggwan pa̱l te, a ɓa ru ka̱ mpyal aponzhi,
\v 19 uza̱ là pa̱, <<M ɓa pá na n chal ɓu ka̱ apal ishi iya̱m inga va̱ n nəm á ɓu ka̱ ilum va̱ u fa ka̱ ashe aUrushelima. Kang wa kpan ka̱ afu ka̱t.
\v 20 N nyinyi pa̱ n nəm nnap-mɓá̱ngɓa̱ng á ɓu, nna nak te mmami na nfa ka̱ ashe nzhi aYusufu mpyal, m ɓa pa̱ na n gwang ɓu aponzhi.>>
\p 
\v 21 Te uAbishayi uya aZeruya là pa̱, <<A mal pa̱ mmá gba̱l uShimeyi ka̱kul uza̱ pwat ɓu uponzhi va uYawe gar á.>>
\p 
\v 22 Ǹnyi te uDawuda na ama̱n á na pa̱, <<Iza̱ gwang mi ká̱ wó yà, óvan aZeruya? O ɗom pa̱ o ɓa ká̱ nɗaktak á mi ɗò? Mmami na uPonzhi oIsa̱rila ǹyangmata̱, ka̱kul nva̱ ta te, unəm uro yà mi gba̱l ka̱ ashe aIsa̱rila nda ata̱ ka̱t.>>
\v 23 Te uponzhi là ûShimeyi pa̱, <<N sóng anung á ɓu pa̱ mi gba̱l ɓu ka̱t.>>
\p 
\v 24 Te uMefiboshet ukəka aShawulu aga nggwang uponzhi, uza̱ nàl ashar wò ka̱t, uza̱ wur asa̱l awu wò ka̱t, kang uza̱ nàl ìlukwan wò ka̱t kpa á ɓan ká̱ ìlum va̱ uponzhi re aUrushelima ga chu ìlum va̱ uza̱ le ɓa ká̱ ikángkáng.
\v 25 Ka̱ awalang va̱ uMefiboshet wong ka̱ aUrushelima ɓa chu atak aponzhi te, uponzhi ɓəp na pa̱, <<ÁMefiboshet, iza̱ nak kang u ga nzəng ká̱ mi ka̱t yà?>>
\v 26 UMefiboshet na ama̱n á na pa̱, <<Anəm uga nzhi mi, uponzhi, u nyinyi pa̱ mmami unəm ugurum. Awalang va̱ n nlà ûzwal mi uZiba pa̱ a ɓak nkongkong á mi ka̱ apal azhaki na n nkyen n ga nzəng ká̱ uPonzhi te, uza̱ lam mi, uza̱ ga.
\v 27 Te uZiba uzwal mi á lak aɗin mi ka̱ mpyal ɓu pa̱, n yang ka̱ ǹyar nva̱ng ɓu. N nyi pa̱ mmaɓu wa aMa̱leka Inan, ka̱kul nva̱ ta te, nəm á mi iya̱m va̱ u ya ma ká̱ ɓu.
\v 28 Ka̱kul onəm oga ashe nzhi akəka mi pa̱ kpaktak te, i nak chit pa̱ ɓu gba̱ng yi ikú, ka̱ɗor nva̱ ta te, u na ichumchum á mi ka̱ ashe onəm va̱ i ri iya̱m-nrì ka̱ apal atebəl nzəng ká̱ ɓu. Te mi là iza̱ uPonzhi lap yà?>>
\p 
\v 29 Te uponzhi uDawuda là á na pa̱, <<Sang kang ɓu là pa yà, iya̱m va̱ nlà chit te nna pa̱, mmaɓu ká̱ uZiba te, o kap mbin aShawulu.>>
\p 
\v 30 Te uMefiboshet là á na pa̱, <<Mmá re á na pa̱ chatchat, nva̱ u le ká̱ ikangkang te á kur mi kur, aponzhi mi.>>
\p 
\v 31 UBarzilayi unəm oga Gileyat uza̱ fa ka̱ aRogelim vang pa̱ na o re uponzhi a pa̱l agwong awang aUrdun kang.
\v 32 Uza̱ unəm gbakgbak u va̱ nəm izun chit ìsəm pa̱ ina̱nne, kang uza̱ unəm ga idur pa makmak. Uza̱ uwa i na iya̱m-nrì uponzhi ilum va̱ uponzhi wa ka̱ yà ka̱ aMahanayim.
\v 33 Uponzhi là ûBarzilayi pa̱, <<Ɓa, i pa̱l awang nzəng, na i ga aUrushelima. Mi nak ishi ká̱ ɓu ka̱ ta.>>
\p 
\v 34 Te uBarzilayi là ûponzhi pa̱, <<Mi nəm izun pa̱ ipəchəng ta̱ lap kang mi ga ntəm ká̱ ɓu ka̱ aUrushelima yà?
\v 35 N̂da ata̱ te, mmami ká̱ ìzun ìsəm pa̱ ina̱nne. N nyi nva̱n iya̱m iɓá̱ngɓa̱ng ká̱ ichángchàng ka̱t, kang mi fe nchàng iya̱m va̱ mi ri ká̱ iya̱m va̱ mi wa lap ka̱t kpa. Mi yà ka̱ nfe nchàng oga nnap nshi lap ka̱t kpa. Mi ga nsat ìɗək á ɓu aponzhi.
\v 36 Nkur pa̱ n ka̱m imwa ichumchum va̱ ta̱ ka̱ awo ɓu ka̱t. Iya̱m va̱ mi nəm te, mi pa̱l agwong awang aUrdun ká̱ ɓu pa̱ ɗa̱p chwat.
\v 37 Te wa re mi na n le n ga ìtong mi na n kú ka̱ ta, mmá li mi ka̱ atak awap apo mi ká̱ unang mi. UKimham wa ta̱ ukpari mi, uwa á ga nzəng ká̱ ɓu, kang ɓu nəm iya̱m va̱ á na u ɗom á.>>
\p 
\v 38 Uponzhi là pa̱, <<Mi ga nzəng ká̱ uKimham, iya̱m va̱ pa̱ kpaktak u ɗom te, mi nəm á na. Kang iya̱m va̱ pa̱ kap u ɗom ka̱ atak mi te, mi nəm á ɓu.>>
\v 39 Te nkpaktak onəm pa̱ng agwong aUrdun ká̱ uponzhi. Ka̱ nva̱ngva̱ uponzhi má njang uBarzilayi chit far nnap-nnəna̱n á na te, uBarzilayi le nzhi wò.
\p 
\v 40 Awalang va̱ uponzhi pa̱l ga aGilgal te, uKimham pa̱l nzəng ká̱ na. Nkpaktak oshozha oYahudi ká̱ nkap iyəl oIsa̱rila ka̱ ishimshe oza̱ pa̱ng agwong awang nzəng ká̱ uponzhi kpa.
\p 
\v 41 Te onəm oIsa̱rila ɓa atak aponzhi là á na pa̱, <<Sang kang ogənang yi oYahudi ɓa yar ɓu pa̱ ɗya ka̱ onəm ɓu pa̱ng agwong ká̱ ka̱ nnyi yi ka̱t yà?>>
\v 42 Onəm oga aYahudi na ama̱n pa̱, <<I nəm pa, ka̱kul uponzhi ugənang yi uga ndatkulung. Yar sang kang nnap va̱ ta̱ i ra̱m wó yà? Iza̱ i ri ka̱ atətak yà? Mwote o fe pa̱ uza̱ na imwa iro a yi ɗa ɓo?>>
\p 
\v 43 Onəm oIsa̱rila là onəm oga aYahudi pa̱, <<I kap wó nva̱ng pa̱ ngba̱pchi ka̱ atak aponzhi uDawuda, á yar sang kang ó ɓak yi yà? Ká̱ mmayi na nggəshi va̱ ɓan là nnap mɓa ká̱ uponzhi ka̱ɗi ka̱t ɗò?>>
\p Oza̱ ga mpyal ka̱ ndap izər, uva̱ ta̱ i là, uva̱ cho i là. Ǹnyi te, nnap-nlà va̱ oga aYahudi là te á rwa ji nji oIsa̱rila ji.
\c 20
\s1 USheba fa iya̱mkak ká̱ uDawuda
\p 
\v 1 Ka̱ ashe oga nra va̱ ta te, unəm ulakchilakchi uro uwa ka̱ yà aɗiɗin pa̱ uSheba uya aBikri ununggwan ka̱ akum ìjili aBenjamin. Uza̱ ɓur agbəshi pa̱,
\q1 <<I yà ká̱ iya̱mkup iro ká̱ ashe aDawuda ka̱t,
\q1 i yà ká̱ iya̱mkup iro ka̱ ashe aya aJese ka̱t,
\q2 udanggo á le aghal wò óIsa̱rila.>>\x - \xo 20.1 \xt 1 oPon 12.16; 2 Nnap Nshet 10.16\x*
\p 
\v 2 Onəm oIsa̱rila le ká̱ uDawuda re oza̱ yar nva̱ng aSheba uya aBikri ununggwan. Ǹnyi te, onəm oga aYahudi sat ka̱ ngbá̱k aponzhi oza̱, kang oza̱ ga nzəng ká̱ na, ɓan ka̱ awang aUrdun, ga chu aUrushelima.
\p 
\v 3 UDawuda ɓa chu nzhi wò ka̱ aUrushelima te, uza̱ wur ochar va mí nak ka̱ ashe nzhi pa kùk pa̱ ogba̱pchi va̱ uza̱ ka̱ re pa̱ apángchí nzhi wò. Uza̱ nak oza̱ ka̱ nzhi nro pa̱ɗi, kang uza̱ nak pa̱ mmá pángchí oza̱. Uza̱ ga mpyal ká̱ mmwa nɗaktak ôza̱, ǹnyi te, á ga atak nra ka̱ oza̱ lap ka̱t. Mmá re oza̱ ka̱ ta ga chu ilum ikú oza̱. Oza̱ təm wa ochar okpələng.
\p 
\v 4 Te uponzhi là ûAmasa pa̱, <<Wor onəm oga aYahudi á mi ka̱ ashe nra pa̱ nshatɗing, mmaɓu te wa ɓa kpa.>>
\v 5 Te uAmasa fa ga pa̱ na o ɓut onəm oYahudi, kang nra va̱ mmá na á na pa̱ nshatɗing te ga watar u wa ɓa chit ka̱t.
\v 6 Te uDawuda là ûAbishayi pa̱, <<USheba uya aBikri ununggwan i ga nna mɓək anung á yi i ji nji aAbsalom ji. Wong pa̱ kəlak ka̱ onəm mi na u wa nvəva̱ng, le kang uza̱ a ram ìtong iga akamsəlang a bwam kà̱ ka̱t.>>
\v 7 Te onəm aJowap ká̱ oKeriti ká̱ oPeleti nzəng ká̱ oshozha va̱ i pángchí uponzhi, oza̱ fa re aUrushelima na o ɓak uSheba uya aBikri ununggwan.
\p 
\v 8 Oza̱ ɓa chu inang ipang va ka̱ aGibiyon te, uAmasa fa gwang oza̱. UJowap te u wa ká̱ ìlukwan oshozha ka̱ izər, kang ka̱ iya̱m iga nkpan aɗəɗək te ìkpal i ya yà ká̱ izəzər. Uza̱ ka̱ ashe achen te, ìkpal va̱ ta tutur fa ka̱ ashe avakchi ru. Te uJowap kuchi yar ká̱ awo apa̱m.
\v 9 UJowap ɓəp uAmasa pa̱, <<Mmaɓu sang yà agənang mi?>> Te uJowap yichi awo ari kpan uAmasa ká̱ ka̱ igyigyel na ô má njang á na.
\v 10 UAmasa nyi pa̱ uza̱ ká̱ ìkpal ka̱ awo apa̱m ka̱t, te uJowap kyer na ká̱ ìkpal va̱ ta ka̱ afu, alyer zuk ka̱ mbin, kang uAmasa kú, uJowap ɗak kyer mpəpar lap ka̱t. UJowap ká̱ ugənang wò uAbishayi re na ka̱ ta, oza̱ ga mpyal ka̱ ngwa nva̱ng aSheba.
\p 
\v 11 Uyenza̱m ro ka̱ ashe oshozha aJowap sat ka̱ ngba̱k akúm aAmasa kang á là pa̱, <<Unəm va̱ pa̱ kap məma̱n ká̱ uJowap, ká̱ unəm va̱ pa̱ kap ka̱ nyar nva̱ng aDawuda te, uza̱ á yar nva̱ng aJowap.>>
\v 12 Te uAmasa ra ka̱ ashe nchə̀r ká̱ ishimshe asa̱l. Unəm va̱ pa̱ kap i ɓa kang i ya na te, i sat i dər. Nva̱ ushozha va̱ ta ya pa̱ onəm i ɓa ka̱ ta kang i tong te, uza̱ dapchi akúm aAmasa tar afəp ká̱, kang uza̱ dang na ká̱ ìlukwan.
\p 
\v 13 Mmá dapchi akúm aAmasa le ka̱ asa̱l te, nkpaktak onəm yar nva̱ng aJowap, na o ɓak nva̱ng aSheba uya aBikri ununggwan.
\p 
\v 14 USheba watar nkpaktak oga akum ìjili oIsa̱rila ga chu aAbel-Bet-Maka, ká̱ nkpaktak nkap mbin oBikri. Oza̱ ɓut, oza̱ yar nvəva̱ng.
\v 15 Nkpaktak onəm va̱ nzəng ká̱ uJowap, oza̱ ɓa, gang uSheba ka̱ ashe ìtong aAbel-Bet-Maka. Oza̱ ɓut mbin màl ikoksok ká̱ akamsəlang ìtong va̱ ta kang oza̱ i ɗak pa̱ na o shin akamsəlang ìtong va̱ ta.
\v 16 Te uchar uga aghan ro ka̱ ashe ìtong va̱ ta là pa̱, <<O gwong achwang kà̱ mi, o là uJowap pa̱ uza̱ á ɓa ka̱ ta̱ na nlà nnap ká̱ na.>>
\v 17 UJowap ɓa datkulung ká̱ uchar va̱ ta te, uza̱ ɓəp pa̱, <<Mmaɓu na uJowap ɗò?>>
\m Uza̱ na ama̱n pa̱, <<À, mmami na.>>
\m Uchar va̱ ta là a na pa̱, <<Gwong achwang ka̱ iya̱m va̱ uzwal ɓu i là.>>
\m Te uza̱ là pa̱, <<Mmami kà̱ ngwong achwang kà̱ ɓu.>>
\p 
\v 18 Uchar va̱ ta là pa̱, <<Ká̱ mmatmat te, onəm i là pa̱, <Mmá a ga aAbel na mmá ka̱m ichən ka̱ ta.> Te nnap va̱ ta i kùr.
\v 19 Mmami uzəngtəng ka̱ ashe onəm ga nɗom ntəm ikangkang ka̱ nva̱n nnandər ka̱ ashe oIsa̱rila. Iza̱ nak kang ɓu ɗom nshìn oga ìtong yi yà? U ɗom pa̱ u shin itong va iji aYawe ɗò?>>
\p 
\v 20 UJowap na a ma̱n á na pa̱, <<Pa ka̱t, mi yà ká̱ nvyap kat te nzhì ìtong wó ka̱t.
\v 21 I yà ká̱ nnəm pa ka̱t. Mmami ka̱ mmwo unəm uro aɗiɗin pa̱ uSheba uya aBikri ununggwan, va̱ fa ka̱ mbin ngga aɗuktum aEfrayim, va fa iya̱mkak ká̱ uponzhi Dawuda. A yà pa̱ o ná na á mi te, mi re ìtong wó.>>
\p Te uchar va̱ ta là ûJowap pa̱, <<Mí ga mmandar ishishi i fa à ɓu ka̱ nsəm akamsəlang.>>
\p 
\v 22 Te uchar va̱ ta ga atak onəm ká̱ ichən inəna̱n, kang oza̱ gəl ishi aSheba uya aBikri ununggwan, oza̱ mandar ûJowap ka̱ nsəm akamsəlang. Te uJowap ɓur agbəshi kang onənəm re ìtong va̱ ta. Udanggo le nzhi wò, ǹnyi te, uJowap le ga atak aponzhi ka̱ aUrushelima.
\s1 Onəm oga mpyal aDawuda
\r (2 aSam 8.15-18; 1 Nnap Nshet 18.14-17)
\p 
\v 23 UJowap uwa uponzhi ìkum oshozha oIsa̱rila pa̱ kpaktak. UBenaya uya aJehoyada ununggwan uwa unəm uga mpyal oKeriti ká̱ oPeleti, oma onəm oga mpángchí nzhi aponzhi.
\v 24 UAdoniram uwa unəm uga mpyal onəm oga nnəm inok nkpak ka̱ ashe mbin pa̱ kpaktak. UJehoshafat uya aAhilut ununggwan uwa unəm uga nlir nnap nshetshet oponzhi.
\v 25 USheva unəm uga nlìlir. UZadok ká̱ uAbiyata onəm oga mpyal awop.
\v 26 UIra unəm oga aJarit uwa ka̱ ashe onəm oga mpyal awop aDawuda.
\c 21
\s1 Mmá pyat akat ôGibiyon
\p 
\v 1 Ka̱ ashe nra va̱ uDawuda ka̱ nnəm iponzhi te, mmá nəm ayang pa̱ makmak ìzun pa̱ ishatɗing ka̱ anung ka̱ anung. Ka̱kul nva̱ ta te, uDawuda mwo asa̱l awu aYawe ka̱ ipir ayang va̱ ta. Te uYawe là á na pa̱, <<Mmá kà̱ mpyat akat nchə̀r va̱ uShawulu ká̱ nzhizhi táng. Ka̱kul uza̱ gbá̱ng oGibiyon.>>
\p 
\v 2 Te uponzhi wór oGibiyon là nnap ká̱ oza̱. OGibiyon pa te, akum ìjili oIsa̱rila ka̱t, oza̱ aɓo oAmori. OIsa̱rila ka̱ sóng anung ôza̱ chit pa̱ o gbá̱ng oza̱ ka̱t. Ǹnyi te, uShawulu ɗak pa̱ o gbá̱ng oza̱ pa̱ chatchat ka̱kul ìkpar va̱ uza̱ ká̱ ka̱ apal oIsa̱rila ká̱ oYahudi.
\v 3 UDawuda ɓəp oGibiyon pa̱, <<Iza̱ mi nəm á wó yà? Ka̱ nza̱ asa̱l mi ɗa̱mshi inga va̱ mmá nəm á wó ta̱, na o far nnap-nnəna̱n ka̱ apal iya̱mkup aYawe yà?>>
\p 
\v 4 Te onəm oga aGibiyon na ama̱n á na pa̱, << I yà ká̱ ichumchum iga nlà pa̱ uShawulu ka̱t te, nzhizhi á na aazurfa ka̱t te, azənariya á yi ka̱kul nnap va̱ ta̱ ka̱t. Ka̱ɗi te, i yà ká̱ ichumchum iga ngba̱l unəm uro ka̱ ashe oIsa̱rila ka̱t.>>
\m UDawuda ɓəp oza̱ pa̱, <<Te, iza̱ o ɗom pa̱ n nəm á wó yà?>>
\p 
\v 5 Te oza̱ na a ma̱n ûPonzhi pa̱, <<Unəm va̱ gbá̱ng yi ta, uwa ɗom pa̱ ká̱ o nzhì yi na kang i yà ká̱ iya̱m iro ka̱ ashe oIsa̱rila ka̱t te,
\v 6 re mmá na ovəvan onunggwan á yi pa̱ ofangshat, na i gbá̱ng oza̱, i zong oza̱ ka̱ mpyal aYawe ka̱ aGibiyon, ìtong aShawulu, uponzhi va uYawe yàk.>>
\p Te uponzhi là pa̱, <<Mi ga nna oza̱ á wó.>>
\p 
\v 7 Ǹnyi te, ka̱kul nsóng anung va̱ ka̱ ishimshe aDawuda ká̱ uJonatan uya aShawulu ununggwan ka̱ mpyal aYawe te, uponzhi va̱n uMefiboshet uya aJonatan ununggwan re.
\v 8 Te uponzhi wur uArmoni ká̱ uMefiboshet ovan aShawulu onunggwan pa̱ oparəm, ova uRizpa uya uAhiya mar á na, nzəng ká̱ ovan aMerab uya uShawulu uchar pa̱ otukun ova uza̱ mar ká̱ uAdriyel uya aBarzilayi ununggwan unəm oga aMehola.
\v 9 Te uDawuda na oza̱ ka̱ ashe awo oGibiyon, kang oGibiyon gbá̱ng oza̱, zong oga akúm oza̱ ka̱ apal ìkun ka̱ apal aɗuktum aro ka̱ mpyal aYawe. Nkpaktak oza̱ pa̱ ofangshat va̱ ta kú nzəng ka̱ ashe nra va mmá ka̱ ɓan mɓən ibəshi.
\p 
\v 10 Te uRizpa uya aAhiya uchar, yar ìlukwan aryakryak kang à nàr ka̱ apal aɗuktum va̱ ta. Á təm ka̱ ta ka̱ mɓan mɓən ibəshi ga chu nra va̱ iva̱r pəng ka̱ apal oga akúm va̱ ta. Uza̱ ma̱n înyil ká̱ alum pa̱ a dok ka̱t, kang ká̱ ká̱ izwam te, uza̱ i ma̱n îzhe iga anyin pa̱ á dok oza̱ ka̱t.
\v 11 Awalang va̱ uDawuda fe iya̱m va̱ uRizpa, uya aAhiya uchar, uchar va uShawulu ka̱m nak ka̱ ashe nzhi pa kùk nəm te,
\v 12 uDawuda ga atak onəm oga aJabesh-Gileyat, uza̱ ka̱m oga akup aShawulu ká̱ iji aJonatan uyəyen ununggwan. Ka̱kul onəm oga Jabesh-Gileyat oma ka̱ wur akúm aShawulu ká̱ uJonatan ká̱ ayi ka̱ agbagba aBet-Shan ká̱ atak va̱ oFilisti ka̱ zong oza̱ kà̱ nva̱ngva̱ oza̱ gbá̱ng oza̱ ka̱ aGilbowa.
\v 13 UDawuda wur oga akup aShawulu, ká̱ iji aJonatan, ká̱ iji onəm oga ofangshat ovəngva̱ oGibiyon gbá̱ng.
\p 
\v 14 Te oza̱ li akup aShawulu ká̱ aji aJonatan ka̱ ashe awap aKish upo aShawulu ka̱ aZela ka̱ mbin aBenjamin, kang oza̱ nəm nkpaktak oga iya̱m va̱ uPonzhi là pa̱ mmá nəm. Ka̱ nva̱ng va̱ ta te, Inan fe ayə́ng ka̱kul mbin va̱ ta.
\s1 Ìkum ká̱ oFilisti
\r (1 Nnap Nshet 20.4-8)
\p 
\v 15 Ka̱ ilum sur ro te, ìkum fa ka̱ ishimshe oFilisti ká̱ oIsa̱rila. UDawuda ká̱ onəm wò fa ga ìkum kà̱ oFilisti, kang uza̱ bəlak.
\v 16 Te uIshbi-Benob uzəngtəng ka̱ ashe oRefayim, onəm va oga agban, yar pa̱ ô gba̱l uDawuda. Uza̱ kpan aɓár va iɗək achəcham akilo pa̱ shatɗing ká̱ aɓuɓo, kang uwa ká̱ ndokchi mpipe.
\v 17 Ǹnyi te, uAbishayi uya aZeruya ununggwan ɓa ka̱m ishishi pa̱ kəlak, uza̱ ləp uFilisti va̱ ta gba̱l. Te onəm aDawuda sóng anung á na pa̱, <<Ɓu yà ká̱ nfa ngga ìkum ka̱ yi lap ka̱t, le kang mmá gba̱l ɓu, izhan iponzhi oIsa̱rila á kú ka̱t.>>
\p 
\v 18 Ka̱ nva̱ng va̱ ta te, mmá lung ìkum iro kà̱ɗi ká̱ oFilisti ka̱ aGob. Mmá kà̱ nlung ìkum te, uSibekayi unəm oga aHusha gba̱l uSaf uzəngtəng ka̱ ashe akum ìjili agban onəm va̱.
\p 
\v 19 Oza̱ lung ìkum iro kà̱ɗi ká̱ oFilisti ka̱ aGob. Te uElhanan uya aJayir ununggwan ka̱ aBet-Lehem gba̱l ugənang aGoliyat oga aGat, akun aɓəɓar mwal wa awo atum.
\p 
\v 20 Mmá lung ìkum iro kà̱ɗi ka̱ aGat te, nkarɓàk nro uwa ka̱ ta ká̱ ifang pa̱ ikpa̱ɗing ka̱ nza̱ awo ká̱ ashar nggo. Pa̱ kpaktak te, uza̱ ká̱ ifang ìsəm pa̱ iparəm ama̱n pa̱ neɗing. Uza̱ fa ka̱ akum ìjili agban onəm.
\v 21 Uza̱ dər oIsa̱rila pa̱ oza̱ iya̱m iro ka̱t. Te uJonatan uya agənang aDawuda uShimeya fa gba̱l na.
\v 22 OFilisti oga oneɗing va̱ ta̱ oza̱ ka̱ akum agban onəm ka̱ aGat, kang uDawuda ka̱ onəm wò gba̱ng oza̱.
\c 22
\s1 Nnap-nshì igwan aDawuda
\r (Nnap Nsh 18.1-50)
\p 
\v 1 Nnap-nshì va ta̱ uDawuda shì ka̱ nva̱ngva̱ uYawe ka̱m ishishi ka̱ ashe awo nkpaktak onəm oga nkpang na, ká̱ uShawulu.
\v 2 Oga nnap-nshì va̱ uza̱ shì te nna ta̱ pa̱,
\q1 <<UYawe uwa ìpang mi ká̱ atak mbwam mi. Uwa unəm uga nka̱m ishi mi.
\q2 
\v 3 Inan mi uwa ìpang va̱ mi bwam kà̱,
\q2 uza̱ uwa ngwangwang mi, ká̱ ikam iga nka̱mshi mi.
\q1 Uza̱ uwa atak mbwam mi, uwa akamsəlang va mbwam mi,
\q2 uza̱ wa i kpak mi, uwa unəm uga nka̱m ishi mi ka̱ ashe awo onəm oga nyang mi.
\q1 
\v 4 Mi wór ka̱ ashe aɗin aYawe uva̱ kukur pa̱ mmá na aɗəngchi á na,
\q2 ka̱kul uza̱ i ka̱m ishi mi ka̱ ashe awo okpa ìkum mi.
\b
\q1 
\v 5 <<Ka̱kul igum ndəng ngga ikú gang mi,
\q2 igum ndəng ngga nzhì onəm kà̱ nnang i watar á mi ká̱ ishi.
\q1 
\v 6 Asang awap chəp mi chit,
\q2 ajip ikú kpan mi chit.
\q1 
\v 7 Ka̱ ashe mɓək anung mi te n wór uYawe,
\q2 n wór Inan mi.
\q1 Ka̱ ashe nzhi awuwop te, uza̱ fe achu mi,
\q2 uza̱ gwong achwang ka̱ ayə́ng mi.
\b
\q1 
\v 8 <<Te apambin tan kang ayənggət,
\q2 mbang apaɓur tan kang ayənggət
\q2 ka̱kul uza̱ mən ìkum.
\q1 
\v 9 Ngu fa ka̱ mɓol alulur,
\q2 aɓələm apər asalsal fa ka̱ ashe atətam,
\q2 amor apər asalsal fa ka̱ ashe atətam.
\q1 
\v 10 Uza̱ kakchi apaɓur fər vang,
\q2 ká̱ ilulu ìkpá̱rkpà̱r ka̱ avəng ashəshar.
\q1 
\v 11 Uza̱ kyen ka̱ apal aKerub uza̱ wong ka̱ pal,
\q2 mmá ya na ka̱ apal abasəm ayər.
\q1 
\v 12 Uza̱ gún ishi wò ká̱ atak akpá̱rkpà̱r,
\q2 ká̱ ilulu ikpá̱rkpà̱r iga iva̱r.
\q1 
\v 13 Ǹnyi te, aməlam fa ka̱ ashe ilulu va̱ ta,
\q2 amor apər fa ka̱ mpipyal.
\q1 
\v 14 UYawe ləp ìgbarman ka̱ apaɓur,
\q2 mmá fe achu Anəm uga Ichumchum.
\q1 
\v 15 Uza̱ tat iwár wò kang à lyanshin okpa ìkum
\q2 uzá̱ re ǹre ká̱ aməlam apər zangtal oza̱.
\q1 
\v 16 Mmá bol akum ìwa ka̱ gbagba,
\q2 kang mbang apambin mmá re ka̱ gbagba,
\q2 ka̱ atak nra̱n aYawe,
\q2 ka̱ atak nyi nkamkam va̱ fa ka̱ alulur.
\b
\q1 
\v 17 <<Ka̱ apaɓur uYawe yichi awo yar mi ká̱,
\q2 uza̱ dapchi mi n fa ka̱ ashe oga ndəng ngbà̱nggbà̱ng.
\q1 
\v 18 Uza̱ fa ká̱ mi ka̱ ashe awo okpa ìkum mi okamkam,
\q2 ka̱ atak okpa ìkum mi va̱ kam ji mi ji.
\q1 
\v 19 Oza̱ ru mi ká̱ ilum ka̱ awalang va̱ mmami ka̱ ashe nɗaktak,
\q2 ǹnyi te, uYawe pángchí mi.
\q1 
\v 20 Uza̱ fa ká̱ mi ga ká̱ ka̱ atak va ikangkang kà̱,
\q2 uza̱ ka̱m ishi mi ka̱kul uza̱ fe nchang mi fe.
\b
\q1 
\v 21 <<UYawe mwa mi ka̱ atak nnap-nnəm mi nnəna̱n,
\q2 uza̱ mwa mi ka̱kul awo mi yà ká̱ adak ka̱t.
\q1 
\v 22 Ka̱kul n kpak nnap-mpakpak aYawe,
\q2 n yà ká̱ mpat ka̱ atak nəm nnap-mɓá̱ngɓa̱ng Înan mi ka̱t.
\q1 
\v 23 N kpak oga nnap-mpakpakpakpak pa̱ kpaktak,
\q2 n re oga nnap-nkpakkpakkpakkpak chit ka̱t.
\q1 
\v 24 N yà ka̱ mpat nro ka̱ mpipyal ka̱t,
\q2 kang n kpak ishi mi ka̱ atak iya̱m inga.
\q1 
\v 25 UYawe mwa mi chit ka̱kul nnandər va̱ mmami ká̱,
\q2 ka̱kul mmami pa̱ satsat ka̱ mpipyal.
\b
\q1 
\v 26 <<Ka̱ atak anəm uga nnandər te, u nyám ishi ɓu unəm uga nnandər,
\q2 ka̱ atak anəm va̱ pa̱ chak te, u nyám ishi ɓu unəm va pa̱ chak.
\q1 
\v 27 Ka̱ atak anəm va̱ yà ká̱ adak kat te, u nyám ishi ɓu pa̱ u yà ká̱ adak ka̱t,
\q2 ǹnyi te, ka̱ atak onəm onga te, u nyám ishi ɓu unəm uga ntan.
\q1 
\v 28 Ɓu ka̱m ishi onəm oga nyen ká̱ ishi,
\q2 ǹnyi te, ìwu ɓu ka̱ ndər onəm oga nrup ká̱ ishi pa̱ na u yen ká̱ oza̱.
\q1 
\v 29 ÁYawe, mmaɓu na atak tantàn mi,
\q2 uYawe ga̱ɓa̱n atak kpa̱rkpa̱r mi sat atak tantàn.
\q1 
\v 30 Nzəng ká̱ nka̱mshi ɓu te, mi nəm igwan nəm ká̱ ìdongkong oshozha,
\q2 ka̱ atak ichumchum aponzhi Inan mi te, mi gantal nza̱ akamsəlang nggo.
\b
\q1 
\v 31 <<Inan pa te, asəsa̱l pa̱ zara̱ra̱.
\q2 Nnap-nləla təm chit wanta,
\q2 uza̱ ngwangwang n̂kpaktak onəm va̱ bwam ka̱ atətak á.
\q1 
\v 32 Uda Inan ká? UYawe uwa Inan byet.
\q2 Uda ìpang ga bwam yi yà? Inan yi uwa byet.
\q1 
\v 33 Inan uwa i na ikam a mi,
\q2 kang i nak asa̱l mi i ga ikángkáng pa̱ sham.
\q1 
\v 34 Uza̱ nak ashar mi á yà wa ashar nkar,
\q2 uza̱ nak mi n sat ka̱ apal oga aɗuktum akúrkúr.
\q1 
\v 35 Uza̱ ɗyáng ashar ìkum âwo mi,
\q2 awo mi i wul ìjang acham arəzang.
\q1 
\v 36 U na ngwangwang ngga ka̱m ishi a mi,
\q2 ka̱ atak nka̱mshi ɓu na n sat unəm uchumchum.
\q1 
\v 37 U nak mi ka̱ asa̱l va yà ká̱ nla̱p ìfang ka̱t,
\q2 le kang ashar mi a málkán ka̱t.
\b
\q1 
\v 38 <<N wà okpa ìkum mi n ga nzhì oza̱,
\q2 n sat ka̱t ga chu awalang va̱ oza̱ zhì kang.
\q1 
\v 39 N zhì oza̱, n tung oza̱ ka̱ mbin ngwong ma̱t oza̱,
\q2 oza̱ tak ka̱ avəng ashar mi.
\q1 
\v 40 U na ikam á mi ka̱kul nlung ìkum,
\q2 u nak okpa ìkum mi ka̱ avəng mi.
\q1 
\v 41 U nak okpa ìkum mi ga̱ɓa̱n chəng ka̱ mpyal mi,
\q2 kang n zhì onəm va̱ yang mi.
\q1 
\v 42 Oza̱ yə́ng i ram nka̱mshi, ǹnyi te, unəm uro ya pa̱ a ka̱m ishi oza̱ ka̱t.
\q2 Oza̱ wór uYawe, ǹnyi te, a ma̱n oza̱ ka̱t.
\q1 
\v 43 N tòng oza̱, oza̱ yal lúkút wa mɓwang.
\q2 N kpà oza̱, kang n tòng oza̱ wa aɓyer aga iwu asa̱l.
\b
\q1 
\v 44 <<U ka̱m ishi mi chit ka̱ atak onəm va̱ fa iya̱mkak ká̱ mi.
\q2 U nak mi n ta̱l uponzhi ka̱ apal ishi oɗyanəm, kang onəm va̱ n nyi ka̱t te, oza̱ nyang ozwal mi chit ǹyangmata̱.>>
\q1 
\v 45 Oɗyanəm ɓa ɓəram á mi ka̱ mpyal,
\q2 nva̱ oza̱ fe izər mi te, oza̱ kpak nnap-nnəm á mi.
\q1 
\v 46 Ichəgwak ləp oza̱,
\q2 Oza̱ fa ka̱ atak mbwam oza̱ ká̱ ntán izər.
\b
\q1 
\v 47 <<UYawe uwa yà ká̱ irirì. Nnap-nnəna̱n a yà îpang mi.
\q2 Ichumchum sat iji Inan mi, ìpang iga ka̱m ishi mi.>>
\q1 
\v 48 Uwa Inan uva i pyát akat á mi,
\q2 uva nak oɗyanəm ka̱ avəng mi.
\q1 
\v 49 Uva fa ká̱ mi ka̱ ashe awo okpa ìkum mi.
\q2 U nak mi ka̱ apal ishi onəm oga nkpang mi,
\q2 u ka̱m ishi mi ka̱ ashe awo anəm uga nsur ìgwak.
\q1 
\v 50 Ka̱kul nva̱ ta̱ te mi shep ɓu ka̱ ashe oɗyanəm.
\q2 Mi shì nnap ngga nshep aɗin ɓu.
\q1 
\v 51 <<Uza̱ na igwan imakmak ûponzhi wò,
\q2 uza̱ nyám mmá̱n pa̱ ɗəkər û nəm va̱ uza̱ gar,
\q2 ûDawuda ká̱ akum ìjilijili mbyet.>>
\c 23
\s1 Nnap-nlà aDawuda ngga nkur anung
\p 
\v 1 Oga nnap-nlà aDawuda ngga nkur anung oma ta̱.
\q1 Oga nnap-nlà aDawuda uya aJese ununggwan,
\q2 nnap-nlà anəm va Inan rup ká̱ na,
\q1 unəm va Inan aYakubu gar pa̱ á yà uponzhi,
\q2 unəm oIsa̱rila uga shì oga nnap-nshì nchángchàng. Á là pa̱.
\b
\q1 
\v 2 <<ARuhu aYawe na nnap-nlà á mi pa̱ n là,
\q1 nnap-nləla ka̱ asap anung mi.>>
\q1 
\v 3 Inan oIsa̱rila á là nnap,
\q2 Ìpang oIsa̱rila á là á mi pa̱,
\q1 <<Unəm va̱ kà̱ nnəm iponzhi ka̱ apal onəm ká̱ nnandər,
\q2 uva kà̱ nnəm iponzhi ká̱ ayər Inan te,
\q1 
\v 4 uza̱ wá atak aghánghan aga anung ìpin va i ɓa nzəng ká̱ nfa alum,
\q2 a va yà ká̱ ìlulu iro kà̱ ka̱t,
\q1 wa atak aghanghan ka̱ nva̱ng ìva̱r
\q2 a va i nak ìpəpa i fa ka̱ mbin.>>
\q1 
\v 5 <<Nnandər, wa ǹna ta nzhi mi ka̱ mpyal Inan ka̱t ɗò?
\q2 Ka̱kul uza̱ yar nsar nnap-nlà ngga mbyet ká̱ mi,
\q2 nsar nnap-nlà va uza̱ ɗa̱mshi kang à yəl.
\q1 Nnandər, uza̱ i nak mi myak,
\q2 ká̱ nkpaktak iya̱m va̱ mmami ka̱ nɗuɗom.
\q1 
\v 6 Ǹnyi te, mi swang nkpaktak onəm onga ka̱ cho wa izú,
\q2 va mi wur ká̱ awo ka̱t.
\q1 
\v 7 Unəm va̱ pa̱ káp i dok izú te,
\q2 ya uza̱ i nəm inok ká̱ iya̱m wa acham ka̱t te akun aɓár.
\q2 Mí shì oza̱ pa̱ chatchat ká̱ apər ka̱ atak va̱ oza̱ ra kà̱.>>
\s1 Oshozha aDawuda oga ǹnyi ìkum
\r (1 Nnap Nshet 11.10-39)
\p 
\v 8 Aɗin oshozha aDawuda oga ǹnyi ìkum oma ta̱.
\p Unəm uga nggəshi te, uJosheb-Bashebet unəm uga aTakemon, uwa unəm uga mpyal oshozha oga oshatɗing va̱. Uza̱ yar aɓár te, a gbá̱ng onəm ká̱ ìgba̱l pa̱ ìna̱nne ka̱ awalang azəngtəng.
\p 
\v 9 Uga nvəva̱ng ka̱ ashe onəm oga oshatɗing va̱ te uEleyazar uya aDodayi ununggwan ka̱ akum aAhohi. Uwa yà nzəng ká̱ uDawuda ká̱ ilum va̱ oza̱ ɓák onəm oga aFilisti va̱ ɓut ka̱kul nlung ìkum. Te onəm oga aIsa̱rila chəng le nva̱ng,
\v 10 ǹnyi te, uEleyazar sat gbá̱ng oFilisti awo ga wom na kang à ma̱t na kà̱ nvachi ka̱ izər ndokchi. UYawe na igwan pa̱ makmak ka̱ nda va̱ ta. Oshozha va̱ ka̱ chəng te, a le ga atak aEleyazar kang oza̱ ga wur iya̱m iga ngwur ka̱ atak ìkum.
\p 
\v 11 Ka̱ nva̱ng aEleyazar te, uShamma uya aAgi ununggwan unəm oHarar. Awalang va̱ oFilisti ɓut ka̱ atak aro va ìram iro va̱ yə́l ká̱ aso njiman kà̱. Te oIsa̱rila chəng oFilisti.
\v 12 Ǹnyi te, uShamma sat ka̱ ishimshe ìram va̱ ta. Uza̱ pá̱ngchí ìram va̱ ta kang a gbá̱ng oFilisti. UYawe na igwan imakmak.
\p 
\v 13 Ka̱ nda ro ka̱ ashe awalang ngga mɓún iya̱m te, onunggwan pa̱ shatɗing ka̱ ashe onunggwan ìsəm pa̱ shatɗing oga ìkum fa ga atak aDawuda ka̱ ashe agba̱k aAdulam. Ka̱ awalang ta te, oFilisti oma ləp apa̱k ka̱ mba̱nda̱m aRefayim.
\p 
\v 14 Ka̱ awalang va̱ ta te uDawuda wa ka̱ atak mbwam, kang ìdongkong oshozha oFilisti ǹnyi te, na ka̱ yà ká̱ aBet-Lehem.
\v 15 Ndəng gba̱l nəm uDawuda te, uza̱ là pa̱, <<Unəm uro ka̱ pa ndəng nká̱pka̱p ngga anung asa̱l ntar aBet-Lehem á mi ká̱ na n wá.>>
\v 16 Te oshozha oga ǹnyi ìkum oga shatɗing va̱ ta kák ka̱ ishimshe apa̱k oFilisti, pa ndəng ka̱ anung asa̱l ga ntar aBet-Lehem, kang à ɓa ká̱ ûDawuda. Ǹnyi te, uza̱ yang ká̱ ngwuwa. Ka̱ ɗor ngwuwa te, uza̱ tar ka̱ mbin ka̱ mpyal aYawe wa iya̱m inana.
\v 17 Uza̱ là kà̱ pa̱, <<UYawe á dang mi ká̱ nnəm apir iya̱m va̱ ta̱, nna pa̱ ngwa nchə̀r onəm va̱ ta̱ ova yáp ká̱ irirì oza̱ á.>> Ka̱kul nva̱ ta te, uDawuda wa ndəng va̱ ta ka̱t. Oga iya̱m ichumchum va ta̱ ovan nunggwan oga oshatɗing va̱ ta̱ nəm á.
\p 
\v 18 UAbishayi uya aZeruya ugənang aJowap uwa unəm uga mpyal ôvan nunggwan oga ìsəm pa̱ ishatɗing oga ǹnyi ìkum va̱\f + \fr 23.18 \ft Oga nlir nro là ka̱ ta̱ pa̱ onəm pa̱ oshatɗing\f*. Ka̱ nda ro te, uza̱ yar aɓár wò te, uza̱ gbá̱ng onəm ìgba̱l pa̱ ishatɗing. Wanta na uza̱ nəm aɗin wa onəm oga ashatɗing va̱ ta̱ kpa.
\v 19 Uza̱ wa aɗiɗin dam ma̱t ka̱ ashe onəm oga shatɗing va̱ ta̱. Ka̱kul nva̱ ta te, uza̱ ta̱l unəm uga mpyal oza̱, kap ka̱ nva̱ pa̱ uza̱ yà ka̱ ashe oga oshatɗing va̱ cho ka̱t.
\p 
\v 20 Te uBenaya uya aJehoyada ununggwan, unəm oga aKapzeyel, unəm uga ǹnyi ìkum á nəm oga iya̱m ichumchum. Uza̱ gbá̱ng onəm oMowap pa̱ oparəm ova i lung ìkum wa ìlir á. Ka̱ nda aro ka̱ awalang va atak i rusok i pə̀ng ká̱ aɗəɗal va̱ mi wor pa̱ asuno te, uza̱ fə́r ga ashe ache aro, kang à gba̱l ilir ka̱ ta.
\v 21 Uza̱ gba̱l m ɓa agbán anəm uro uga aMasar ro uva ká̱ aɓár ka̱ awo. UBenaya ǹnyi te, a ga atətak ká̱ ìdari, kang uza̱ ga vyat aɓár va̱ ka̱ awo anəm uga aMasar va̱ ta kang a gbál na ká̱.
\v 22 Oga iya̱m va ta̱ uBenaya uya aJehoyada ununggwan nəm, kang aɗiɗin dam wa aɗin onunggwan ìkum oga oshatɗing va̱.
\v 23 Mmá shep na ji onəm oga ìsəm pa̱ ishatɗing va̱ ji, ǹnyi te uza̱ chu oga oshatɗing va̱ cho ka̱t. UDawuda nak na sat unəm uga mpyal onəm oga pángchí ikángkáng wò.
\b
\li1 
\v 24 Onəm va̱ ta̱ oma ka̱ ashe onəm ìsəm pa̱ ishatɗing va̱, oma,
\li2 uAsahel ugənang aJowap,
\li2 ká̱ uElhanan uya aDodo ununggwan unəm uga aBet-Lehem,
\li2 
\v 25 ká̱ uShamma
\li2 ká̱ uELika onəm oga aHarot,
\li2 
\v 26 ká̱ uHelez unəm oga aPalti,
\li2 ká̱ uIra uya aIkesh ununggwan unəm oga aTekowa,
\li2 
\v 27 ká̱ uAbiyezer unəm oga aAnatot,
\li2 ká̱ uShibekayi unəm oga aHusha,
\li2 
\v 28 ká̱ uZalmon unəm oga aAhohi,
\li2 ká̱ uMaharayi unəm oga aNetofa,
\li2 
\v 29 ká̱ uHelep uya aBayana ununggwan unəm oga aNetofa,
\li2 ká̱ uItayi uya aRibayi ununggwan unəm oga aGibeya ka̱ akum ìjili aBenjamin,
\li2 
\v 30 ká̱ uBenaya unəm oga aPiraton,
\li2 ká̱ uHidayi ka̱ oga mba̱nda̱m aGayash,
\li2 
\v 31 ká̱ uAbi-Albon unəm oga aArbat,
\li2 ká̱ uAzmavet unəm oga aBahurim,
\li2 
\v 32 ká̱ uEliyaba unəm oga aShayalbon,
\li2 ká̱ ovan aJashen onunggwan,
\li2 ká̱ uJonatan,
\li2 
\v 33 ká̱ uShamma unəm oga aHarar,
\li2 ká̱ uAhiyam uya aSharar ununggwan, unəm oga aHarar,
\li2 
\v 34 ká̱ uElifelet uya aAhasbayi ununggwan unəm oMakati,
\li2 ká̱ uEliyam uya aAhitofel unəm oga aGilo,
\li2 
\v 35 ká̱ uHezro unəm oga aKarmel,
\li2 ká̱ uPayarayi unəm oArba,
\li2 
\v 36 ká̱ uIgal uya aNatan ununggwan unəm oga aZoba,
\li2 ká̱ uBani unəm oGat,
\li2 
\v 37 ká̱ uZelek unəm oAmmon,
\li2 ká̱ uNaharayi unəm oga aBeyerot, uwa unəm uga kpan iya̱m-wór ûJowap uya aZeruya ununggwan,
\li2 
\v 38 ká̱ uIra,
\li2 ká̱ uGarep onəm oga aItiri,
\li2 
\v 39 ká̱ uUriya unəm oHiti.
\li1 Pa̱ kpaktak te, oza̱ ìsəm pa̱ ishatɗing ama̱n pa̱ nfangshat.
\c 24
\s1 UDawuda kung ìyəl oShozha
\r (1 Nnap Nshet 21.1-27)
\p 
\v 1 Mmən ìkum aYawe wong ka̱ɗi ka̱kul oIsa̱rila, kang uza̱ nok uDawuda ka̱ apal oza̱ pa̱ <<Ga, na u kung ìyəl oIsa̱rila ká̱ oga aYahudi.>>
\v 2 Te uponzhi là ûJowap unəm uga mpyal ìkum oshozhashozha va̱ nzəng ká̱ na pa̱, <<Ga nzəng ká̱ aɓo onəm oga mpyal ìkum ka̱ ashe nkpaktak oga akum ìjili oIsa̱rila, ɓan ka̱ aDan, a ga chu aBeyersheba, na ó kung ìyəl onəm oga nlung ìkum na n nyi ìyəl oza̱.>>
\p 
\v 3 Te uJowap na ama̱n ûponzhi pa̱, <<Re uYawe, Inan ɓu a nak onəm oIsa̱rila a myak nva̱ng ìgba̱l a jí ngga ǹyangmata̱. Re iwu anəm uga nzhi mi, uponzhi á ya. Ǹnyi te, iza̱ nak kang uponzhi i ɗom pa̱ o nəm iya̱m wa iva̱ ta̱ yà?>>
\v 4 Te nnap-nlà aponzhi á kà̱r nji aJowap ká̱ nji onəm oga mpyal oShozha. Te oza̱ fa ka̱ mpyal aponzhi ga nkung onəm oIsa̱rila.
\p 
\v 5 Kà̱ nva̱ng va̱ oza̱ pa̱ng awang aUrdun te, oza̱ ləp apa̱k ka̱ nkwandal aArowa, ka̱ ishimshe mba̱nda̱m ìtong va̱ ta, kang oza̱ wòl asa̱l awo aGat, ɓa ga chu aJazer.
\v 6 Te oza̱ lyam ga aGileyat ka̱ mbin aTatim-Hodshi, kang oza̱ ga aDan-Jayan, ga̱ɓa̱n gang aSidon.
\v 7 Te oza̱ ga chu aTaya va̱ ká̱ akamsəlang, ká̱ nkpaktak itong oHivi, ká̱ nji oKanana. Ka̱ nkukur te, oza̱ ga aBeyersheba ka̱ nkwandal aYahuda.
\v 8 Ka̱ nva̱ngva̱ oza̱ gba̱l ka̱ nranggang ka̱ ashe mbin pa̱ chatchat te, oza̱ le aUrushelima ka̱ nva̱ng ape pa̱ fangzəngtəng ka̱ nra ìsəm pa̱ iparəm.
\v 9 Te uJowap là ìyəl onunggwan va̱ kur nlung ìkum chit ûponzhi. Ka̱ aIsa̱rila te, ìkalong ìgba̱l pa̱ ina̱nne (800,000), kang ka̱ aYahuda te, ìkalong ìgba̱l pa̱ itukun (500,000).
\p 
\v 10 Ǹnyi te, ka̱ nva̱ngva̱ uDawuda gba̱l ka̱ nkung onəm chit pa̱ kpaktak te, ìchəgwak ləp na, kang uza̱ là ûYawe pa̱, <<N nəm nnap-mɓá̱ngɓa̱ng á ɓu chit pa̱ makmak ka̱ atak nkung onəm va̱ n nkung ta̱. Ǹyangmata̱ te, mmami ka̱ nchál ɓu aYawe pa̱ u yar mpat ûzwal ɓu, ka̱kul n nəm mpərək mak byet.>>
\p 
\v 11 UDawuda wong pa̱ ó yenda̱l ká̱ ìpin te, uYawe là nnap chit ká̱ uGat unəm uga nka̱m ǹre ka̱ atak Inan, uwa ɗəkər i là ǹre Inan ûDawuda, pa̱,
\v 12 <<Ga na u là uDawuda pa̱, <UYawe là pa̱ ò na iya̱m á ɓu pa̱ shatɗing na u yak pa̱ izəng ka̱ ashishe va̱ mi nyám ntàn á ɓu ká̱.> >>
\p 
\v 13 Te uGat ga atak aDawuda kang a là á na pa̱, <<U ɗom pa̱ ayang á tar mbin ɓu ka̱ apal izun pa̱ ishatɗing ɗò? Ka̱t te, ú nəm inok nchə́r ka̱ mpyal okpa ìkum ɓu ka̱ apal ape pa̱ shatɗing? Ka̱t te, u yak pa̱ arwa aga ngbá̱ng onəm á gang mbin ɓu ka̱ apal nra pa̱ nshatɗing ɗò? Ǹyangmata̱ te, rəng nnap kà̱, na u na ama̱n á mi va̱ mi là uYawe va̱ re mi.>>
\p 
\v 14 Te uDawuda là ûGat pa̱, <<Mmami ka̱ ashe nɗaktak imakmak. I kakap pa̱ i tar awo aYawe, ka̱kul uza̱ unəm ga nrwa igwak. Ǹnyi te, kang uza̱ re yi ka̱ awo anəm ka̱t.>>
\v 15 Te, uYawe re ǹre ká̱ arwa aga ngbá̱ng onəm va ru ka̱ mbin oIsa̱rila, a ɓan ká̱ ìpin va̱ ta ɓa chu nkur ìlum va̱ uYawe nak. Onəm ìkalong ìsəm pa̱ ìfangshat (70,000) kú ɓan ka̱ aDan ga chu aBeyersheba.
\v 16 Awalang va̱ umaleka aYawe yichi awo wò pa̱ o zhì aUrushelima te, mɓək anung oza̱ ga aɗor ûYawe kang uza̱ là ûma̱leka uga nzhì onəm pa̱, <<Akur chit, le ká̱ awo ɓu.>>
\p Ka̱ awalang va̱ ta te, uma̱leka aYawe va̱ ta ka̱ atak-túm aArawuna unəm oJebusi.
\p 
\v 17 UDawuda ya uMa̱leka uga nzhì onəm va̱ te, uza̱ là ûYawe pa̱, <<N nəm nnap-mɓá̱ngɓa̱ng, mmami na n nəm mpat, onəm ta̱ te wa itam. Iza̱ oza̱ nəm kpa yà? N chal pa̱ akwali ɓu á fər ka̱ apal mi ká̱ nzhi mi.>>
\p 
\v 18 Kà̱ ilum va̱ ta te, uGat ɓa atak aDawuda kang a là á na pa̱, <<Ga na u me atak nshì iya̱m awop ûYawe ka̱ atak-túm aArawuna unəm oJebusi.>>
\v 19 Te uDawuda wong ga wà nva uYawe là ka̱ atak aGat á.
\p 
\v 20 Awalang va̱ uArawuna dər kang à ya uponzhi ká̱ onəm inunok kà̱ mɓa atak wò te, uza̱ fa kuchi ká̱ asa̱l iwu ka̱ mbin ka̱ mpyal aponzhi.
\p 
\v 21 UArawuna là ûDawuda pa̱, <<Irirì aponzhi agbà̱ng. Iza̱ ɓa ká̱ uponzhi ka̱ atak mi yà?>>
\p Te uDawuda na ama̱n á na pa̱, <<M ɓa pa̱ na n yáp atak-túm ɓu va̱ ta̱, na n me atak nshì iya̱m awop ûYawe, na arwa ga ngbá̱ng onəm va̱ ta̱ á sat.>>
\p 
\v 22 Te uArawuna là ûDawuda pa̱, <<Re unəm uga nzhi mi, uponzhi, á wur iya̱m va̱ pa̱ káp uza̱ ɗom na uza̱ a nəm awop ká̱. Oga ina oma ta̱ ka̱kul iya̱m ipapa iga nshì, oga akun aga mpək iya̱m oma ta̱, ká̱ akun aga nggantal ina ká̱ ìshak ka̱kul akún aga mma̱k apər.
\v 23 Oga iya̱m va̱ ta̱ pa̱ kpaktak aponzhi, mmami uArawuna n na á ɓu.>>
\p UArawuna là ûponzhi kpa pa̱, <<Re uYawe, Inan ɓu á ka̱m iya̱m inana ɓu.>>
\p 
\v 24 Ǹnyi te, uponzhi na ama̱n uArawuna pa̱, <<O'o, mi yáp ká̱ mbwai. Mi yà ka̱ nná iya̱m inana nləfər ûYawe Inan mi ká̱ iya̱m imwa ka̱t.>> Te, uDawuda yáp atak-túm va̱ ta, ká̱ ina va̱ ta ka̱ nung aazurfa ashekel ìsəm pa̱ ìtukun.
\v 25 UDawuda me atak nshì iya̱m awop ûYawe ka̱ ta. Uza̱ yichi iya̱m inana iga nshì ká̱ iga ntəm ikangkang. Nna chit te uYawe ma̱n afar ka̱kul mbin ɗak, kang arwa-ɓá̱ngɓá̱ng ngga ngbá̱ng oIsa̱rila va̱ gəl.
