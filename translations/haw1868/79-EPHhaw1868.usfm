\id EPH
\h Epeso
\toc1 Epeso
\toc2 Epeso
\toc3 Epeso
\mt1 Epeso
\c 1
\s1 O KA EPISETOLE
\b
\q1 
\v 1 O PAULO, he lunaolelo a Iesu Kristo ma ka makemake o ke Akua, na ka poe haipule e noho ana ma Epeso, a me ka poe manaoio iloko o Iesu Kristo:
\q1 
\v 2 E alohaia oukou, e maluhia hoi i ke Akua ko kakou Makua, a me ka Haku Iesu Kristo.
\b
\q1 
\v 3 E hoomaikaiia ku ke Akua, ka Makua o ko kakou Haku o Iesu Kristo, nana kakou i hoomaikai mai ma na mea maikai a pau o ka Uhane i na wahi lani ma o Kristo la.
\q1 
\v 4 E like me ia i wae mai ai ia kakou ma ona la mamua aku o ka hookumuia mai o ke ao nei i hemolele ai kakou a me ka hala ole imua ona ma ke aloha:
\q1 
\v 5 I koho e mai oia ia kakou mamua no ka hookamaia nana ma o Iesu Kristo la, e like me ka lokomaikai o kona makemake,
\q1 
\v 6 I hoomaikaiia'i ka nani o kona aloha, ana i maliu mai ai ia kakou no ka Mea aloha;
\q1 
\v 7 Nona mai ke ola ia kakou ma kona koko, ke kala ana o na hala, e like me ka lako o kona lokomaikai;
\q1 
\v 8 Ka mea ana i hoomahuahua mai ai ia kakou me ke akamai nui, a me ka naauao.
\q1 
\v 9 Ua hoike mai la oia ia kakou i ka mea ikea ole o koua makemake, e like me kona manao aloha ana i manao ai iloko iho ona;
\q1 
\v 10 I ke aupuni o keia manawa hope, e houluulu i na mea a pau ma kahi hookahi iloko o Kristo, i na mea o ka lani e me na mea o ka honua, iloko ona.
\q1 
\v 11 Ma ona la ua loaa mai ia ma kou ka noho ana, i koho mua ia mai makou o like me ka manao o ka mea nana e hana mai i na mea a pau ma ka manao ku paa o kona makemake;
\q1 
\v 12 I hoomaikai aku ai makou i kona nani, ka poe i manao lana e mamua i ka Mesia.
\q1 
\v 13 O oukou hoi kekahi i manao ia ia, i ko oukou hoolohe ana i ka olelo o ka oiaio, i ka euanelio e ola'i oukou; a i ko oukou manaoio ana ia ia, ua hoailonaia oukou e ka Uhane Hemolele i olelo e ia mai;
\q1 
\v 14 Oia ka hooiaio o ko kakou noho ana, a hiki aku i ke ola i kuaiia mai, i hoomaikaiia'i kona nani.
\b
\q1 
\v 15 Nolaila hoi, i kuu lohe ana'ku i ko oukou manaoio i ka Haku ia Iesu, a me ke aloha i na haipule a pau.
\q1 
\v 16 Aole au e hooki i ka hoomaikai ana aku no oukou, e hoohiki ana ia oukou ma ka'u pule;
\q1 
\v 17 I haawi mai ai ke Akua o ko kakou Haku o Iesu Kristo, ka Makua nona ka nani, ia oukou i ka Uhane hoonaauao a me ka hoike, i ike ai oukou ia ia;
\q1 
\v 18 A hoomalamalamaia na maka o ko oukou naau, i ike ai oukou i ka manaolana ma kona hea ana mai, a me ka nani nui o kona mea e ili mai ana no ka poe haipule,
\q1 
\v 19 A me ka nui loa o kona mana no kakou ka poe manaoio, ma ka hooikaika ana o kona mana ikaika,
\q1 
\v 20 Ana i hana iho ai iloko o Kristo i ka hoala'ua ia ia mai ka make mai, a hoonoho iho la ia ia ma kona lima akau i kahi lani,
\q1 
\v 21 Maluna ae o na alii a pau, o na mea ikaika, o na mea mana, na haku, a me na inoa a pau i kapaia, aole ma keia ao wale no, ma kela ao e hiki mai ana kekahi.
\q1 
\v 22 A ua hoolilo iho la oia i na mea a pau malalo iho o kona mau wawae, ua hoonoho hoi ia ia i poo maluna o na mea a pau no ka ekalesia,
\q1 
\v 23 Oia kona kino, o ka lako o ka mea nana e hoolako mai i na mea a pau ma na mea a pau.
\c 2
\b
\q1 
\v 1 O OUKOU hoi kekahi, oka poe i make iloko o na hala a me na hewa;
\q1 
\v 2 Ma ia mau mea oukou i hele ai mamua, ma ka aoao o keia ao, mamuli o ke alii ikaika o ka lewa, o ka uhane e hooikaika ana iloko o na keiki hoolohe ole.
\q1 
\v 3 Me lakou hoi makou a pau i noho ai mamua ma na kuko newa o ko makou kino, e hana ana i na raakemake o ke kino a mo ka naau; a ma ka aoao maoli he poe keiki makou no ka inainaia, e like me na mea e ae.
\q1 
\v 4 Aka, o ke Akua, ka mea i piha i ko aloha, ma kona makemake nui ana i makemake mai ai ia kakou,
\q1 
\v 5 I ko kakou wa make i na hala, ua hoola mai oia ia kakou pu me Kristo, (ma ka lokomaikai oukou e ola'i;)
\q1 
\v 6 A ua hoala pu ae la, a ua hoonoho pu iho la hoi ia kakou i kahi lani ma o Kristo Iesu la:
\q1 
\v 7 I hoike mai ai oia i na manawa mahope aku i ka nui loa o kona lokomaikai, ma ka hana maikai mai ia kakou ma o Kristo Iesu la.
\q1 
\v 8 No ka mea, e hoolaia oukou i ka lokomaikai ma ka manaoio; aole hoi no oukou iho keia; he mea haawiia mai ia e ke Akua:
\q1 
\v 9 Aole no na hana ana, o kaena auanei kekahi.
\q1 
\v 10 No ka mea, o kakou kana hana i hanaia ma o Kristo Iesu la, no na hana maikai, a ke Akua i hoomakaukau e mai ai, i haele kakou malaila.
\b
\q1 
\v 11 No ia hoi, e hoomanao oukou, he lahuikanaka e oukou mamua ma ke kino, i kapaia he okipoepoe ole e ka poe i kapaia he okipoepoeia ma ke kino e na lima.
\q1 
\v 12 Ia manawa, aole oukou i ike ia Kristo, he poe malihini oukou i ke aupuni o ka Iseraela, a he poe kanaka e i na berita o ka olelo hoopomaikai, aole o oukou manaolana, a he poe mea Akua ole ma koia ao.
\q1 
\v 13 Aka, i neia manawa iloko o Kristo Iesu, o oukou ka poe i mamao aku mamua, ua hookokokeia mai ma ko koko o Kristo.
\q1 
\v 14 No ka mea, oia ko kakou mea hookuikahi, ka i hoolilo i na mea elua i hookahi, a ua wawahi iho hoi i ka paku hookaawale iwaena;
\q1 
\v 15 Ua hoopau ae la hoi oia ma kona kino i ka mea e inaina ai, oia ko kanawai no na kauoha e me na kapu, i hoolilo ai oia i na mea elua i kanaka hou hookahi malalo iho ona, pela e hookuikahi ana;
\q1 
\v 16 I hoomalu ai hoi oia ia laua elua no ke Akua iloko o ke kino hookahi ma ke kea, e hoopau ana malaila i ka mea e inaina ai:
\q1 
\v 17 Ua hele mai hoi, a hai mai la i ka olelo hoomalu ia oukou i ka poe mamao aku a me ka poe kokoke.
\q1 
\v 18 No ia hoi, ua loaa ia kakou i na poe elua ka hookipaia e ia iloko o ka Makua ma ka Uhane hookahi.
\q1 
\v 19 Nolaila hoi, aole oukou he poe malihini a me ka poe kanaka e, aka, he poe kamaaina pu oukou me na haipule a me na ohua o ke Akua:
\q1 
\v 20 Ua kukuluia oukou maluna o ke kahua a na lunaolelo a me na kaula, o Iesu Kristo iho no ka pohaku kumu o ke kihi.
\q1 
\v 21 A ua kapili pono ia ka hale a pau ma o na la, a lilo ae la ia i luakini laa no ka Haku.
\q1 
\v 22 Ilaila hoi oukou i kapili pu ia'i, i wahi e noho ai o ke Akua ma ka Uhane.
\c 3
\b
\q1 
\v 1 NO keia mea, he paahao wau o Paulo na Kristo Iesu, no oukou no ko na aina e;
\q1 
\v 2 No ka mea, ua lohe no oukou i ka oihana lokomaikai o ke Akua ana i haawi mai ai ia'u no oukou.
\q1 
\v 3 Ma ka hoikeia i hoakaka mai ai oia iau i ka mea ikea ole; ka mea a'u i palapala pokolo aku ai mamua;
\q1 
\v 4 A heluhelu oukou, e ike auanei oukou ilaila i kuu ike ana i ka mea ikea ole no Kristo,
\q1 
\v 5 I ka mea i hoike ole ia mai i na keiki a kanaka i na hanauna mamua, e like me ia i hoikeia mai e ka Uhane i neia manawa i kana poe lanaolelo hoano a me na kaula;
\q1 
\v 6 I lilo ai na lahuikanaka e i poe hoahooilina, i kino hookahi, i poe hoalawe pu i ka olelo hoopomaikai no Kristo ma ka euanelio.
\q1 
\v 7 No ia mea i hooliloia'e au i kahuna, ma ka haawina lokomaikai o ke Akua ana i haawi mai ai ia'u, ma ka ikaika o kona mana.
\q1 
\v 8 Ua haawiia mai keia lokomaikai ia'u, i ka mea uuku iho o na haipule uuku loa a pau, e hai aku ai au i na lahuikanaka e i ka waiwai kupanaha o Kristo;
\q1 
\v 9 A e hoike aku hoi i na kanaka a pau i ke ano o ka mea pohihihi i hunaia mai ke kumu mai iloko o ke Akua, nana i hana na mea a pau ma o Iesu Kristo la:
\q1 
\v 10 I hoikeia aku ai ma ka ekalesia i na alii a i na mea mana o ka lani, ka nui loa o ko ke Akua akamai,
\q1 
\v 11 E like me kona manao kahiko loa ana i hooko ai ia Kristo Iesu ko kakou Haku:
\q1 
\v 12 Ua loaa mai ia kakou ma ona la ka olelo wiwo ole, me ka hookipaia a me ka manaolana ma ka manaoio ia ia.
\q1 
\v 13 Nolaila, ke noi aku nei au e pauaho ole oukou i kuu pilikia ana no oukou, o ka oukou ia e pomaikai ai.
\b
\q1 
\v 14 No keia mea, ke kukuli nei no au imua o ka Makua o ko kakou Haku o Iesu Kristo,
\q1 
\v 15 Nona hoi i kapaia mai ka inoa o ka ohana a pau ma ka lani, a ma ka honua,
\q1 
\v 16 I haawi mai ai oia ia oukou, ma ka nui o kona mini, e hooikaika nui ia mai ke kanaka oloko e kona Uhane;
\q1 
\v 17 I noho ai o Kristo iloko o ko oukou naau ma ka manaoio; i hoopaaia oukou i ke aa a i hookumuia ma ke aloha,
\q1 
\v 18 I hiki ia oukou ke ike me na haipule a pau i ka laula, a me ka loa, a me ka hohonu, a me ke kiekie;
\q1 
\v 19 I ike hoi oukou i ke aloha o Kristo, i ka mea e pakela ana i ka ike; i hoopihaia no hoi oukou i ka mea a pau a ke Akua i piha ai.
\b
\q1 
\v 20 A o ka mea nona ka mana e hana mai ai i na mea a pau a kakou e noi aku ai, a e manao iho ai, a nui loa aku hoi, ma ka mana e hooikaika ana iloko o kakou,
\q1 
\v 21 Ia ia ka hoonaniia'ku e ka ekalesia ma o Kristo Iesu la, i na manawa a pau, mahope mau loa aku. Amene.
\c 4
\b
\q1 
\v 1 NO ia mea, owau ka paahao no ka Haku, ke nonoi aku nei ia oukou, e hele oukou ma ka mea e ku i ke koho ana a oukou i kohoia mai ai.
\q1 
\v 2 Me ka haahaa nui o ka naau, a me ke akahai, a me ka hoomanawanui hoi, a e ahonui aku kekahi i kekahi me ke aloha.
\q1 
\v 3 E hooikaika oukou e hoomau i ka lokahi ana o ka manao, ma ke apo o ke kuikabi.
\q1 
\v 4 Hookahi no kino, hookahi hoi Uhane, e like me ka oukou i kohoia mai ai i ka manaolana hookahi o ko oukou kohoia ana:
\q1 
\v 5 Hookahi no Haku, hookahi manaoio, hookahi bapetizo ana;
\q1 
\v 6 Hookahi hoi Akua, ka Makua o na mea a pau, oia maluna o na mea a pau, ma na mea a pau a iloko hoi o kakou a pau.
\q1 
\v 7 Ua haawiia mai hoi ka lokomaikai ia kakou a pau, e like me ke ana a Kristo i haawi mai ai.
\q1 
\v 8 Nolaila, i olelo mai ai oia, I kona pii ana iluna, ua kai pio ia i ka poe i pio, a haawi mai la hoi i na haawina i kanaka.
\q1 
\v 9 (A o keia, Ua pii aku la ia iluna heaha anei ia mea, i ole kela i iho ae mamua i na wahi malalo ae o ka honua?
\q1 
\v 10 O ka mea i iho ae ilalo, oia no ka mea i pii aku maluna ae o ka lani kiekie loa, i hoopiha ai oia i na mea a pau.)
\q1 
\v 11 Ua hoolilo iho la oia i kekahi poe i lunaolelo; a i kekahi poe i kaula; a i kekahi poe i kahuna hai olelo; a i kekahi poe i kahu ekalesia a me na kumu;
\q1 
\v 12 I mea e hooponopono ai i na haipule no ka oihana kahuna, a no ke kukulu paa ana i ke kino o Kristo:
\q1 
\v 13 A hiki aku kakou a pau i ka lokahi ana o ka manaoio, a me ka ike aku i ke Keiki a ke Akua, a lilo i kanaka makua, i poe naauao loa ma na mea o Kristo:
\q1 
\v 14 I kamalii ole ai kakou ma ia hope aku i ka alealeia a me ka lauwiliia e na makani a pau o ka olelo, ma ka apiki a kanaka, a me ka maalea a lakou e imi ai i ka hoopunipuni;
\q1 
\v 15 Aka, e olelo oiaio aku ana me ke aleha, i nui ae kakou i na mea a pau iloko ona, oia o Kristo o ke poo.
\q1 
\v 16 Ua kapili pono ia ke kino a pau e ia a paa i ke kokuaia mai e na ami a pau, ua hoonui ae la oia i ke kino e like me ke ano o ka ikaika o kela lala o keia lala, no ke kukulu paa ana ia ia iho ma ke aloha.
\b
\q1 
\v 17 O keia hoi ka'u e olelo aku nei, a hoike aku hoi ma ka I Haku, mai haele hou oukou e like me na lahuikauaka e ma ka lapuwale o ko lakou naau:
\q1 
\v 18 Ua poeleele ko lakou manao ana, ua mamao loa mai ke ola aku o ke Akua, uo ka naaupo iloko o lakou, a me ka paakiki o ko lakou naau:
\q1 
\v 19 A no ko lakou makau ole, ua hoolilo ia lakou iho i ka makaleho, e hana aku ai i ka haumia a pau me ka makermake.
\q1 
\v 20 Aka, aole pela ka oukou i ao aku ai i ka Kristo:
\q1 
\v 21 Ina paha i lohe oukou i kana, i aoia hoi oukou e ia, e like me ka oiaio iloko o Iesu:
\q1 
\v 22 A no ka noho ana mamna, e haalele aku oukou i ke kanaka kahiko i haumia i na kuko hewa hoopunipuni:
\q1 
\v 23 E hoano hou ia hoi oukou ma ka mauao ana o ko oukou naau;
\q1 
\v 24 E hoaahu iho hoi oukou i ke kanaka hou, i hanaia mamuli o ke Akua ma ka pono a me ka hemolele io.
\b
\q1 
\v 25 Nolaila, e haalele oukou i ka wahahee, e olelo oiaio aku hoi kela mea keia mea a pau i kona hoalauna; no ka mea he mau lala kakou o kekahi me kekahi.
\q1 
\v 26 A i huhu oukou, e ao o hewa auanei: mai hoomau i ko oukou inaina a napoo ka la.
\q1 
\v 27 Aole hoi e haawi aku oukou i kauwahi no ka diabolo.
\q1 
\v 28 O ka mea i aihue, mai aihue hou aku ia: aka hoi, e hana ia, e hooikaika ana me na lima i ka mea maikai, i loaa'i ia ia ka mea e haawi aku na ka mea nele.
\q1 
\v 29 Mai hoopuka ae oukou i ka olelo ino mai loko mai o ko oukou waha; aka, o ka olelomaikai no ke ku paa ana, hooluolu aku ai ia i ka poe lohe.
\q1 
\v 30 Mai hooeha hoi i ka Uhane Hemolele o ke Akua, nana oukou i hoailona mai no ka la e hoolaia mai ai.
\q1 
\v 31 E hookaawaleia na mea awaawa a pau mai o oukou aku, a me ka inaina, ka huhu, ka uwa, ka olelo ino, a me ka manao ino a pau.
\q1 
\v 32 E lokomaikai oukou i kekahi e kekahi, e aloha aku me ka naau, e kala ana hoi kekahi i kekahi, e like me ka ke Akua i kala mai ai i ko oukou ma o Kristo la.
\c 5
\b
\q1 
\v 1 NO ia hoi, e hahai oukou i ke Akua, e like me na keiki punahele;
\q1 
\v 2 E haele hoi oukou me ke aloha, e like me ka Kristo i aloha mai ai ia kakou, a haawi hoi ia ia iho no kakou, i alana a me ka mohai i ke Akua, i mea ala oluolu.
\b
\q1 
\v 3 A o ka moe kolohe, a me na mea haumia a pau, a me ka puniwaiwai, aole loa e hoohikiia ia mau mea iwaena o oukou, me ia o pono ai na haipule;
\q1 
\v 4 Aole hoi ka olelo hilahila, ka olelo lapuwale, a me ka olelo ano lua, na mea pono ole: aka, o ka olelo hoomaikai ka pono.
\q1 
\v 5 No ka mea, ua ike oukou i keia, aole ka mea moe kolohe, aole hoi ka mea haumia, aole hoi ka mea puniwaiwai, oia hoi ka mea hoomana kii, aole loa o lakou noho ana i ke aupuni o Kristo a o ke Akua.
\q1 
\v 6 E ao o hoopunipuni mai kekahi ia oukou i na olelo wehahee: no keia mau mea e hiki mai ana ka inaina o ke Akua maluna o na keiki hoolohe ole.
\q1 
\v 7 Nolaila, mai noho a hoohalike pu me lakou.
\q1 
\v 8 No ka mea, he poeleele ko oukou mamua, i neia manawa hoi ua malamalama oukou i ka Haku: e haele oukou me he kamalii no ka malamalama la:
\q1 
\v 9 (No ka mea, o ka hua na ka Uhane, oia ka maikai a pau, a me ka pono a me ka oiaio:)
\q1 
\v 10 E hooiaio oukou i ka mea a ka Haku i oluolu ai.
\q1 
\v 11 Mai hoolauna pu hoi oukou ma na bana hua ole o ka pouli, e hoohewa aku nae ia mau mea.
\q1 
\v 12 No ka mea, o na mea i hana malu ia e lakou, he mea hilahila ke olelo aku ia mau mea.
\q1 
\v 13 A o na mea a pau e pono ke hoohewaia aku, ua hoakakaia ma ka malamalama; o ka mea hoakaka aku, oia ka malamalama.
\q1 
\v 14 No ka mea, ua oleloia, E ala'e oe, e ka mea hiamoe ana, e ku ae hoi mai ka make mai, na Kristo hoi oe e hoomalamalama mai.
\b
\q1 
\v 15 Nolaila, e nana oukou i hele pono e like me ka poe naauao, aole me ka poe naaupo,
\q1 
\v 16 E malama pono ana i ka manawa; no ka mea, he mau la ino keia.
\q1 
\v 17 No ia mea, mai noho a naaupo oukou, aka, e hoomaopopo i ka makemake o ka Haku.
\q1 
\v 18 Mai noho oukou a ona i ka waina, nolaila mai ka uhauha; aka, e hoopihaia oukou i ka Uhane;
\q1 
\v 19 E olelo ana kekahi i kekahi i na halelu, i na himeni, a me na mele na ka Uhane, e hoolea ana a e hookani ana i ka Haku, iloko o ko oukou naau;
\q1 
\v 20 No na mea a pau, e hoomaikai mau ana i ke Akua ka Makua, ma ka inoa o ko kakou Haku o Iesu Kristo:
\b
\q1 
\v 21 E malama ana i kekahi i kekahi me ka makau i ke Akua.
\b
\q1 
\v 22 E na wahine, e noho malalo o na kane ponoi a oukou, e like me ka ka Haku.
\q1 
\v 23 No ka mea, o ke kano ke poo o ka wahine, e like me Kristo ke poo o ka ekalesia: a oia hoi ke ola no ke kino.
\q1 
\v 24 No ia mea, e like me ka ekalesia e noho ana malalo o Kristo, pela boi na wahine malalo o na kane ponoi a lakou ma na mea a pau.
\q1 
\v 25 E na kane, aloha aku i ka oukou mau wahine, e like me Kristo i aloha mai ai i ka ekalesia, a haawi mai ia ia iho nona;
\q1 
\v 26 I hoolaa mai ai oia ia ia, hoomaemae ana ia ia i ka wai auau, a me ka olelo,
\q1 
\v 27 I hoolilo mai ai oia ia ia nona iho i ekaiesia nani, nole ona wahi paumaele, aole hoi minomino, aole hoi kekahi mea like; aka, i hemolele ia a me ka hala ole.
\q1 
\v 28 Pela e pono ai na kane e aloha aku i ka lakou mau wahine, e like me ko lakou mau kino iho: o ka mea aloha i kana wahine, oia ke aloha ia ia iho.
\q1 
\v 29 No ka mea, aole loa kekahi i inaina i kona kino iho; aka, ua hanai no a me ka malama ia ia, e like me ka Haku i ka ekalesia:
\q1 
\v 30 No ka mea, he mau lala kakou no kona kino, no kona io, a me kona iwi.
\q1 
\v 31 No ia hoi, e haalele ke kanaka i kona makuakane a me ka makuwahine, a e hoopiliia'ku ia i kana wahine, a e lilo laua elua i bookahi to.
\q1 
\v 32 He mea pohihibi nui keia; ke olelo aku nei au no Kristo a me ka ekalesia.
\q1 
\v 33 Aka, e aloha aku kela mea keia mea o oukou a pau i kana wahine e like me ia ia iho: a o ka wahine, e hoomaikai aku ia i kana kane.
\c 6
\b
\q1 
\v 1 E NA keiki, e hoolohe i ko oukou mau makua no ka Haku: no ka mea, he pono keia.
\q1 
\v 2 E hoomaikai oe i kou makuakane a me ka makuwahine; o ke kauoha mua keia, e pili ana me ka olelo e pomaikai ai:
\q1 
\v 3 I pomaikai ai oe, i loihi ai hoi kou noho ana ma ka honua.
\q1 
\v 4 Oukou boi, e na makua, mai hoonaukiuki aku i na keiki a oukou; aka, e alakai ia lakou ma ka hoopono a me ka hoonaauao a ka Haku.
\b
\q1 
\v 5 E na kauwa, e hoolohe oukou i na haku o oukou ma ke kino, me ka makau a me ka weliweli, a me ke kupono o ko oukou naau, e like me ia Kristo:
\q1 
\v 6 Aole ma ka hooikaika ike maka ia mai, e like me ka poe hoolealea i kanaka; aka, e like me na kauwa a Kristo, e hana ana i ka makemake o ke Akua ma ka naau;
\q1 
\v 7 Me ka naau oluolu e hookauwa ana na ka Haku, aole na kanaka.
\q1 
\v 8 E ike hoi oukou, a i haua kekahi i ka mea maikai, e ukuia mai oia e ka Haku, o ka mea paa a me ka mea paa ole.
\q1 
\v 9 Oukou hoi, e na haku, pela hoi oukou e hana aku ai ia lakou, aole ka hooweliweli aku; e manao oukou, aia ka lani ka Haku o oukou iho; aole boi ia ia ka nana mai ma ko ke kanaka kino.
\b
\q1 
\v 10 Eia hoi, o na hoahanau o'u, i ikaika oukou ma ka Haku, a ma ka ikaika o kona mana.
\q1 
\v 11 E aahu iho oukou i ke kahiko a pau a ke Akua, i hiki ia oukou ke kupaa imua o na hana maalea a ka diabolo.
\q1 
\v 12 No ka mea, aole kakou e hakoko ana me ka mea io a me ka mea koko; aka me na alii, na mea ikaika, na haku o ka pouli o keia ao, a me na uhane ino o ka lewa.
\q1 
\v 13 No ia hoi, e lawe oukou i ke kahiko a pau a ke Akua, i pono ia oukou ke kupaa, ke hiki mai ka la ino; a pau ae la na mea i ka hanaia, e kupaa oukou.
\q1 
\v 14 E ku pono hoi oukou, i kakooia ko oukou puhaka i ka oiaio, a pulikiia oukou i ka paleumauma o ka pono:
\q1 
\v 15 I haweleia hoi ko oukou wawae i ka makaukau no ka euanelio e malu ai.
\q1 
\v 16 Maluna oia mau mea a pau, e lawe hoi i ka aabuapoo o ka manaoio, i mea e hiki ai ia oukou ke kinai iho i na iho wela a pau o ka mea ino.
\q1 
\v 17 E lawe hoi i ka mahiole o ke ola, a me ka pahikaua o ka Uhane, oia no ka olelo a ke Akua:
\q1 
\v 18 E pule mau ana i na pule a pau, a me ka nonoi aku ma ka U hane; a no ia mea hoi, e kiai oukou me ka hooikaika mau a me ka pule aku no na haipule a pau;
\q1 
\v 19 A ia'u hoi, i haawiia mai ia'u ka olelo e hai aku ai kuu waha me ka makau ole, e hoike aku i ka mea pohihihi o ka euanelio;
\q1 
\v 20 No ia mea, he elele no wau e paa ana i ke kaulahao: i olelo wiwo ole aku au ilaila, e liko me ka'u pono e ololo aku ai.
\b
\q1 
\v 21 I ike hoi oukou i ka'u mau mea e noho noi, a me ka'u hana ana, na Tukiko he hoahanau aloha, he lawehana malama pono hoi i ka ka Haku, nana e hoike aku i na mea a pau ia oukou:
\q1 
\v 22 Oia ka'u i hoouna aku ai ia oukou no keia mea, i ike ai oukou i ka wakou, i hooluolu aku ai boi oia i ko oukou naau.
\b
\q1 
\v 23 I pomaikai na hoahanau, i aloha hoi me ka manaoio, mai ke Akua ka Makua mai, a me ka Haku Iosu Kristo.
\q1 
\v 24 E alohaia ka poe a pau i aloha io aku i ko kakou Haku ia Iesu Kristo. Amene. 
