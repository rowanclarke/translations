\p
\v 28 \w Entonces|strong="G1161"\w* \w Pedro|strong="G4074"\w* \w le|strong="G4314"\w* respondió: \w Señor|strong="G2962"\w*, \w si|strong="G1487"\w* \w eres|strong="G1510"\w* \w Tú|strong="G4771"\w*, \w manda|strong="G2753"\w* \w que|strong="G3588"\w* \w yo|strong="G1473"\w* \w vaya|strong="G2064"\w* \w a|strong="G4314"\w* Ti \w sobre|strong="G1909"\w* \w las|strong="G3588"\w* \w aguas|strong="G5204"\w*.   
