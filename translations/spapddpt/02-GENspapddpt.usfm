\p
\v 26 \w E|strong="H3068"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Zilpa|strong="H2153"\w*, esclava \w de|strong="H1121"\w* \w Lea|strong="H3812"\w*: \w Gad|strong="H1410"\w* y Aser. Estos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w* \w que|strong="H1121"\w* le \w nacieron|strong="H3205"\w* en Pa-danrama.   
\p
\v 27 \w Jacob|strong="H3290"\w* \w fue|strong="H1931"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre \w Isaac|strong="H3327"\w*, en \w Mamre|strong="H4471"\w*, ciudad de Arba, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w Hebrón|strong="H2275"\w*, precisamente \w donde|strong="H8033"\w* Abraham \w e|strong="H3068"\w* \w Isaac|strong="H3327"\w* peregrinaron.   
\p
\v 28 \w Los|strong="H1961"\w* \w días|strong="H3117"\w* de \w Isaac|strong="H3327"\w* \w fueron|strong="H1961"\w* 180 \w años|strong="H8141"\w*.  
\v 29 \w Isaac|strong="H3327"\w* expiró y fue unido \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*, \w anciano|strong="H2205"\w* y \w lleno|strong="H7649"\w* \w de|strong="H1121"\w* \w días|strong="H3117"\w*. Lo \w sepultaron|strong="H6912"\w* sus \w hijos|strong="H1121"\w* \w Esaú|strong="H6215"\w* y \w Jacob|strong="H3290"\w*.   
\c 36  
\s1 Descendencia de Esaú  
\p
\v 1 \w Estos|strong="H1931"\w* son \w los|strong="H1931"\w* descendientes de \w Esaú|strong="H6215"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* Edom.   
\p
\v 2 \w Esaú|strong="H6215"\w* \w tomó|strong="H3947"\w* sus esposas de entre las \w hijas|strong="H1323"\w* de \w Canaán|strong="H3667"\w*: \w a|strong="H3068"\w* \w Ada|strong="H5711"\w*, \w hija|strong="H1323"\w* de Elón heteo, \w a|strong="H3068"\w* Oholibama, \w hija|strong="H1323"\w* de \w Aná|strong="H6034"\w*, hijo de \w Zibeón|strong="H6649"\w* \w heveo|strong="H2340"\w*,  
\v 3 y \w a|strong="H3068"\w* Bosemat, \w hija|strong="H1323"\w* de \w Ismael|strong="H3458"\w*, hermana de Nebayot.   
\p
\v 4 \w Ada|strong="H5711"\w* le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Elifaz, Bosemat le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Reuel|strong="H7467"\w* y  
\v 5 Oholibama le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Jeús, \w a|strong="H3068"\w* \w Jaalam|strong="H3281"\w* y \w a|strong="H3068"\w* \w Coré|strong="H7141"\w*. Estos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w* \w que|strong="H1121"\w* le \w nacieron|strong="H3205"\w* en la tierra \w de|strong="H1121"\w* \w Canaán|strong="H3667"\w*.   
\p
\v 6 \w Esaú|strong="H6215"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* sus esposas, \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*, \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las \w personas|strong="H5315"\w* \w de|strong="H6440"\w* su \w casa|strong="H1004"\w*, sus rebaños y \w todos|strong="H3605"\w* sus \w animales|strong="H1121"\w*, y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* bienes \w que|strong="H1121"\w* adquirió \w en|strong="H3212"\w* \w la|strong="H3605"\w* tierra \w de|strong="H6440"\w* \w Canaán|strong="H3667"\w*, y \w salió|strong="H3212"\w* \w a|strong="H3068"\w* otra tierra \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* su hermano \w Jacob|strong="H3290"\w*,  
\v 7 \w porque|strong="H3588"\w* \w los|strong="H3427"\w* bienes \w de|strong="H3588"\w* ellos \w eran|strong="H1961"\w* demasiados \w para|strong="H3588"\w* vivir \w juntos|strong="H3162"\w*. \w La|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w su|strong="H3588"\w* peregrinación \w no|strong="H3808"\w* \w los|strong="H3427"\w* \w podía|strong="H3201"\w* \w sostener|strong="H5375"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H3588"\w* sus \w ganados|strong="H4735"\w*.  
\v 8 \w Así|strong="H1931"\w* \w que|strong="H1931"\w* \w Esaú|strong="H6215"\w* \w habitó|strong="H3427"\w* en \w la|strong="H1931"\w* montaña de \w Seír|strong="H8165"\w*. \w Esaú|strong="H6215"\w* \w es|strong="H1931"\w* Edom.   
\p
\v 9 Estos son los descendientes de \w Esaú|strong="H6215"\w*, padre de los idumeos, en la montaña de \w Seír|strong="H8165"\w*.   
\p
\v 10 Estos son \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*: Elifaz, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Ada|strong="H5711"\w*, una esposa \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*, y \w Reuel|strong="H7467"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Bosemat, otra esposa \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*.   
\p
