\s2 All face adversity—foundation determines outcome  
\p
\v 24 “\w Therefore|strong="G3767"\w* \w whoever|strong="G3748"\w* hears \w these|strong="G3778"\w* \w words|strong="G3056"\w* \w of|strong="G3056"\w* \w mine|strong="G1473"\w* \w and|strong="G2532"\w* \w does|strong="G4160"\w* \w them|strong="G3588"\w*, \w I|strong="G1473"\w* \w will|strong="G2532"\w* \w compare|strong="G3666"\w* \w him|strong="G3588"\w* \w to|strong="G2532"\w* \w a|strong="G2532"\w* \w prudent|strong="G5429"\w* \w man|strong="G3778"\w* \w who|strong="G3588"\w* \w built|strong="G3618"\w* \w his|strong="G1438"\w* \w house|strong="G3614"\w* \w on|strong="G1909"\w* \w the|strong="G2532"\w* \w bedrock|strong="G4073"\w*;  
