\v 24 \w But|strong="H3588"\w* \w the|strong="H3588"\w* \w king|strong="H4428"\w* said \w to|strong="H3068"\w* Araunah, “\w No|strong="H3808"\w*, \add I will not take these things as a gift.\add* \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w pay|strong="H3701"\w* \w you|strong="H3588"\w* \w for|strong="H3588"\w* \w it|strong="H3588"\w*. \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w take|strong="H5927"\w* \w sacrifices|strong="H5930"\w* \w that|strong="H3588"\w* \w have|strong="H3068"\w* \w cost|strong="H4242"\w* \w me|strong="H5927"\w* \w nothing|strong="H3808"\w*, \w and|strong="H3068"\w* \w offer|strong="H5927"\w* \w them|strong="H5927"\w* \w to|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w to|strong="H3068"\w* \w be|strong="H3808"\w* completely burned \w on|strong="H3068"\w* \w the|strong="H3588"\w* altar.” \w So|strong="H3808"\w* \w he|strong="H3588"\w* paid 50 \w pieces|strong="H8255"\w* \w of|strong="H4428"\w* \w silver|strong="H3701"\w* \w to|strong="H3068"\w* Araunah \w for|strong="H3588"\w* \w the|strong="H3588"\w* \w oxen|strong="H1241"\w* \w and|strong="H3068"\w* \w the|strong="H3588"\w* ground.
