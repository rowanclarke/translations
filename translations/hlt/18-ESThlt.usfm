\v 9 \w Te|strong="H1931"\w* \w khohnin|strong="H3117"\w* \w ah|strong="H9996"\w* \w Haman|strong="H2001"\w* tah \w kohoe|strong="H8056"\w* \w neh|strong="H9999"\w* \w lungbuei|strong="H3820"\w* \w then|strong="H2896"\w* la \w vuenva|strong="H3318"\w*. \w Tedae|strong="H9999"\w* \w Haman|strong="H2001"\w* loh \w Mordekai|strong="H4782"\w* \w te|strong="H0853"\w* \w manghai|strong="H4428"\w* \w vongka|strong="H8179"\w* \w ah|strong="H9996"\w* a \w hmuh|strong="H7200"\w* \w hatah|strong="H9999"\w* \w thoh|strong="H6965"\w* pah \w pawt|strong="H3808"\w* \w tih|strong="H9999"\w* \w a|strong="H9909"\w* \w taengah|strong="H4480"\w* \w tonga|strong="H2111"\w* \w pawh|strong="H3808"\w*. Te \w dongah|strong="H9999"\w* \w Haman|strong="H2001"\w* loh \w Mordekai|strong="H4782"\w* te \w kosi|strong="H2534"\w* a \w hong|strong="H4390"\w* \w thil|strong="H5921"\w*.  
