\c 1
\p 
\v 1 \w Después|strong="H1961"\w* \w de|strong="H1121"\w* la \w muerte|strong="H4194"\w* \w de|strong="H1121"\w* \w Josué|strong="H3091"\w*, \w aconteció|strong="H1961"\w* \w que|strong="H4310"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w consultaron|strong="H7592"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: ¿\w Quién|strong="H4310"\w* \w de|strong="H1121"\w* nosotros \w subirá|strong="H5927"\w* primero \w a|strong="H3068"\w* combatir \w contra|strong="H3478"\w* \w los|strong="H1121"\w* \w cananeos|strong="H3669"\w*?
\p 
\v 2 \nd \w Yavé|strong="H3068"\w*\nd* dijo: \wj \w Judá|strong="H3063"\w* \w subirá|strong="H5927"\w*. \w Ciertamente|strong="H2009"\w* \w Yo|strong="H2009"\w* \w entregué|strong="H5414"\w* la tierra en su \w mano|strong="H3027"\w*.\wj*
\p 
\v 3 \w Judá|strong="H3063"\w* dijo \w a|strong="H3068"\w* su hermano \w Simeón|strong="H8095"\w*: \w Sube|strong="H5927"\w* conmigo al territorio \w que|strong="H1571"\w* se me adjudicó por sorteo, para \w que|strong="H1571"\w* luchemos contra los \w cananeos|strong="H3669"\w*. Yo \w también|strong="H1571"\w* \w iré|strong="H3212"\w* contigo al territorio \w que|strong="H1571"\w* te corresponde. \w Y|strong="H3068"\w* \w Simeón|strong="H8095"\w* \w fue|strong="H3212"\w* \w con|strong="H1571"\w* \w él|strong="H1571"\w*.
\p 
\v 4 \w Judá|strong="H3063"\w* \w subió|strong="H5927"\w*, y \nd \w Yavé|strong="H3068"\w*\nd* \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* los \w cananeos|strong="H3669"\w* y \w a|strong="H3068"\w* los ferezeos \w en|strong="H5221"\w* su \w mano|strong="H3027"\w*, y \w mataron|strong="H5221"\w* \w a|strong="H3068"\w* 10.000 hombres \w en|strong="H5221"\w* Bezec.
\v 5 \w En|strong="H5221"\w* Bezec encontraron \w a|strong="H3068"\w* Adoni-bezec y lucharon contra él. Derrotaron \w a|strong="H3068"\w* los \w cananeos|strong="H3669"\w* y \w a|strong="H3068"\w* los ferezeos.
\v 6 Adoni-bezec \w huyó|strong="H5127"\w*. Lo \w persiguieron|strong="H7291"\w*, lo detuvieron y le cortaron \w los|strong="H7291"\w* pulgares de sus \w manos|strong="H3027"\w* y sus \w pies|strong="H7272"\w*.
\p 
\v 7 \w Entonces|strong="H3651"\w* Adoni-bezec dijo: 70 \w reyes|strong="H4428"\w*, \w a|strong="H3068"\w* quienes corté \w los|strong="H1961"\w* pulgares \w de|strong="H8478"\w* sus \w manos|strong="H3027"\w* y sus \w pies|strong="H7272"\w*, recogían migajas \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w mi|strong="H3389"\w* \w mesa|strong="H7979"\w*. ¡\w Como|strong="H1961"\w* \w hice|strong="H6213"\w* \w yo|strong="H6213"\w*, \w así|strong="H3651"\w* me \w hizo|strong="H6213"\w* \nd ʼElohim\nd*! \w Lo|strong="H6213"\w* llevaron \w a|strong="H3068"\w* Jerusalén, y \w murió|strong="H4191"\w* \w allí|strong="H8033"\w*.
\p 
\v 8 Luego \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* lucharon contra Jerusalén y la capturaron. La pasaron \w a|strong="H3068"\w* filo \w de|strong="H1121"\w* \w espada|strong="H2719"\w* y le pusieron fuego.
\p 
\v 9 \w Después|strong="H3427"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* \w bajaron|strong="H3381"\w* para luchar contra \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* \w que|strong="H1121"\w* \w vivían|strong="H3427"\w* en la región montañosa, en \w el|strong="H1121"\w* Neguev y la Sefela.
\v 10 Luego \w Judá|strong="H3063"\w* marchó \w contra|strong="H6440"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* que \w vivían|strong="H3427"\w* \w en|strong="H3212"\w* \w Hebrón|strong="H2275"\w*, \w antes|strong="H6440"\w* conocida como Quiriat-arba, y \w mataron|strong="H5221"\w* \w a|strong="H3068"\w* Sesay, Ahimán y Talmay.
\v 11 \w De|strong="H6440"\w* \w allí|strong="H8033"\w* marchó \w contra|strong="H6440"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H6440"\w* \w Debir|strong="H1688"\w*, \w antes|strong="H6440"\w* conocida como Quiriat-sefer.
\p 
\v 12 Entonces \w Caleb|strong="H3612"\w* dijo: Al \w que|strong="H1323"\w* ataque y conquiste \w a|strong="H3068"\w* Quiriat-sefer, le \w daré|strong="H5414"\w* \w a|strong="H3068"\w* mi \w hija|strong="H1323"\w* Acsa como esposa.
\v 13 Otoniel, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Cenez|strong="H7073"\w*, hermano \w menor|strong="H6996"\w* \w de|strong="H4480"\w* \w Caleb|strong="H3612"\w* la conquistó, y \w él|strong="H1121"\w* le \w dio|strong="H5414"\w* \w a|strong="H3068"\w* su \w hija|strong="H1323"\w* Acsa como esposa.
\p 
\v 14 \w Aconteció|strong="H1961"\w* \w que|strong="H4100"\w* \w cuando|strong="H4100"\w* \w ella|strong="H5921"\w* \w se|strong="H1961"\w* iba \w con|strong="H5921"\w* \w él|strong="H5921"\w*, \w la|strong="H5921"\w* incitó \w a|strong="H3068"\w* \w que|strong="H4100"\w* pidiera \w a|strong="H3068"\w* su padre un \w campo|strong="H7704"\w*. \w Ella|strong="H5921"\w* desmontó \w del|strong="H5921"\w* \w asno|strong="H2543"\w*. \w Y|strong="H3068"\w* \w Caleb|strong="H3612"\w* \w le|strong="H5921"\w* \w preguntó|strong="H7592"\w*: ¿\w Qué|strong="H4100"\w* deseas?
\p 
\v 15 \w Y|strong="H3068"\w* le respondió: \w Dame|strong="H5414"\w* una \w bendición|strong="H1293"\w*. \w Ya|strong="H3068"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w diste|strong="H5414"\w* tierra \w de|strong="H3588"\w* sequedales, \w dame|strong="H5414"\w* también fuentes \w de|strong="H3588"\w* \w agua|strong="H4325"\w*. \w Y|strong="H3068"\w* \w Caleb|strong="H3612"\w* le \w dio|strong="H5414"\w* las fuentes \w de|strong="H3588"\w* arriba \w y|strong="H3588"\w* las fuentes \w de|strong="H3588"\w* abajo.
\p 
\v 16 Entonces \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* del ceneo, \w suegro|strong="H2859"\w* \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*, \w subieron|strong="H5927"\w* con \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w de|strong="H1121"\w* la \w ciudad|strong="H5892"\w* \w de|strong="H1121"\w* las \w Palmas|strong="H8558"\w* al \w desierto|strong="H4057"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w que|strong="H5971"\w* \w está|strong="H3427"\w* al sur \w de|strong="H1121"\w* \w Arad|strong="H6166"\w*. \w Fueron|strong="H3212"\w* \w a|strong="H3068"\w* vivir con \w el|strong="H1121"\w* \w pueblo|strong="H5971"\w*.
\p 
\v 17 Luego \w Judá|strong="H3063"\w* prosiguió con su hermano \w Simeón|strong="H8095"\w*, atacaron \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* que \w vivían|strong="H3427"\w* \w en|strong="H3212"\w* Sefat y la \w destruyeron|strong="H2763"\w*. \w Llamaron|strong="H7121"\w* \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w* \w Horma|strong="H2767"\w*.
\v 18 \w Judá|strong="H3063"\w* también conquistó \w Gaza|strong="H5804"\w*, Ascalón y \w Ecrón|strong="H6138"\w* con sus territorios.
\p 
\v 19 \nd \w Yavé|strong="H3068"\w*\nd* \w estaba|strong="H1961"\w* \w con|strong="H3588"\w* \w Judá|strong="H3063"\w*, \w y|strong="H3588"\w* tomó posesión \w de|strong="H3588"\w* \w la|strong="H3588"\w* región montañosa. \w Pero|strong="H3588"\w* \w no|strong="H3808"\w* pudieron echar \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* del \w valle|strong="H6010"\w*, \w porque|strong="H3588"\w* ellos \w tenían|strong="H1961"\w* carruajes \w de|strong="H3588"\w* \w hierro|strong="H1270"\w*.
\v 20 \w Dieron|strong="H5414"\w* \w Hebrón|strong="H2275"\w* \w a|strong="H3068"\w* \w Caleb|strong="H3612"\w*, tal como \w Moisés|strong="H4872"\w* \w habló|strong="H1696"\w*, y \w él|strong="H1121"\w* expulsó \w de|strong="H1121"\w* \w allí|strong="H8033"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w tres|strong="H7969"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Anac.
\v 21 Pero \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Benjamín|strong="H1144"\w* \w no|strong="H3808"\w* \w echaron|strong="H3423"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w jebuseos|strong="H2983"\w* \w que|strong="H3808"\w* \w vivían|strong="H3427"\w* \w en|strong="H5704"\w* Jerusalén, \w así|strong="H2088"\w* \w que|strong="H3808"\w* \w los|strong="H3427"\w* \w jebuseos|strong="H2983"\w* vivieron \w en|strong="H5704"\w* Jerusalén \w con|strong="H5704"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Benjamín|strong="H1144"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.
\p 
\v 22 \w De|strong="H5973"\w* igual manera \w la|strong="H1571"\w* \w familia|strong="H1004"\w* \w de|strong="H5973"\w* \w José|strong="H3130"\w* \w subió|strong="H5927"\w* \w contra|strong="H5973"\w* Bet-ʼEl, \w y|strong="H1571"\w* \nd \w Yavé|strong="H3068"\w*\nd* estuvo \w con|strong="H5973"\w* \w ellos|strong="H1992"\w*.
\v 23 La \w familia|strong="H1004"\w* \w de|strong="H6440"\w* \w José|strong="H3130"\w* envió hombres \w a|strong="H3068"\w* espiar Bet-ʼEl, \w antes|strong="H6440"\w* \w llamada|strong="H8034"\w* \w Luz|strong="H3870"\w*.
\v 24 \w Los|strong="H5973"\w* espías \w vieron|strong="H7200"\w* \w a|strong="H3068"\w* un hombre \w que|strong="H4480"\w* \w salía|strong="H3318"\w* \w de|strong="H4480"\w* \w la|strong="H8104"\w* \w ciudad|strong="H5892"\w*, y \w le|strong="H5973"\w* dijeron: \w Muéstranos|strong="H7200"\w* \w ahora|strong="H4994"\w* \w la|strong="H8104"\w* \w entrada|strong="H3996"\w* \w de|strong="H4480"\w* \w la|strong="H8104"\w* \w ciudad|strong="H5892"\w*, y \w haremos|strong="H6213"\w* \w misericordia|strong="H2617"\w* \w contigo|strong="H5973"\w*.
\v 25 \w El|strong="H3605"\w* les \w mostró|strong="H7200"\w* \w la|strong="H3605"\w* \w entrada|strong="H3996"\w* de \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w*, y \w la|strong="H3605"\w* pasaron \w a|strong="H3068"\w* filo de \w espada|strong="H2719"\w*, pero dejaron libre \w a|strong="H3068"\w* \w aquel|strong="H3605"\w* hombre con \w toda|strong="H3605"\w* su \w familia|strong="H4940"\w*.
\v 26 \w El|strong="H1931"\w* hombre \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra \w de|strong="H5704"\w* \w los|strong="H1931"\w* heteos, \w y|strong="H5704"\w* \w edificó|strong="H1129"\w* una \w ciudad|strong="H5892"\w* \w que|strong="H1931"\w* \w llamó|strong="H7121"\w* \w Luz|strong="H3870"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* \w su|strong="H1931"\w* \w nombre|strong="H8034"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.
\p 
\v 27 Pero \w Manasés|strong="H4519"\w* \w no|strong="H3808"\w* tomó posesión de Bet-seán \w ni|strong="H3808"\w* Taanac \w ni|strong="H3808"\w* sus \w aldeas|strong="H1323"\w*, \w ni|strong="H3808"\w* de \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* y las \w aldeas|strong="H1323"\w* de \w Dor|strong="H1756"\w*, Ibleam \w ni|strong="H3808"\w* Meguido. \w Los|strong="H3427"\w* \w cananeos|strong="H3669"\w* persistieron en vivir en esa tierra.
\v 28 \w Sucedió|strong="H1961"\w* \w que|strong="H3588"\w*, \w cuando|strong="H3588"\w* \w Israel|strong="H3478"\w* \w fue|strong="H1961"\w* fuerte, ellos sometieron \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w cananeos|strong="H3669"\w* \w a|strong="H3068"\w* trabajo forzado, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* quisieron echarlo completamente.
\p 
\v 29 Efraín \w tampoco|strong="H3808"\w* \w echó|strong="H3423"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* \w que|strong="H3808"\w* \w vivían|strong="H3427"\w* en \w Gezer|strong="H1507"\w*. \w Los|strong="H3427"\w* \w cananeos|strong="H3669"\w* vivieron en \w medio|strong="H7130"\w* de ellos en \w Gezer|strong="H1507"\w*.
\v 30 \w Tampoco|strong="H3808"\w* \w Zabulón|strong="H2074"\w* \w echó|strong="H3423"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w que|strong="H3808"\w* \w vivían|strong="H3427"\w* en Quitrón, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* de Naalol. \w Los|strong="H3427"\w* \w cananeos|strong="H3669"\w* vivieron en \w medio|strong="H7130"\w* de ellos y \w fueron|strong="H1961"\w* sometidos \w a|strong="H3068"\w* trabajo forzado.
\v 31 \w Tampoco|strong="H3808"\w* Aser \w echó|strong="H3423"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w que|strong="H3808"\w* \w vivían|strong="H3427"\w* en Aco, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* de \w Sidón|strong="H6721"\w*, Ahlab, Aczib, Helba, Afec y \w Rehob|strong="H7340"\w*.
\v 32 Aser vivió \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* \w que|strong="H3588"\w* \w vivían|strong="H3427"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H3427"\w* \w echaron|strong="H3423"\w*.
\v 33 Neftalí \w tampoco|strong="H3808"\w* \w echó|strong="H3423"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w que|strong="H3808"\w* \w vivían|strong="H3427"\w* en Bet-Semes y en Bet-anat, \w sino|strong="H3808"\w* vivió en \w medio|strong="H7130"\w* de \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* \w que|strong="H3808"\w* \w vivían|strong="H3427"\w* en la tierra. \w Los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de Bet-semes y de Bet-anat \w fueron|strong="H1961"\w* sometidos \w a|strong="H3068"\w* trabajo forzado.
\v 34 \w Los|strong="H1121"\w* amorreos forzaron \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Dan|strong="H1835"\w* hacia \w la|strong="H3588"\w* región montañosa \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H1121"\w* \w dejaron|strong="H5414"\w* bajar al \w valle|strong="H6010"\w*.
\p 
\v 35 \w Los|strong="H3427"\w* amorreos persistieron en vivir en la montaña Heres, Ajalón y Saalbín, pero \w cuando|strong="H1961"\w* la \w familia|strong="H1004"\w* de \w José|strong="H3130"\w* \w fue|strong="H1961"\w* fuerte aquéllos \w fueron|strong="H1961"\w* sometidos \w a|strong="H3068"\w* trabajos forzados.
\v 36 El límite de los amorreos iba desde \w la|strong="H1366"\w* subida de Acrabim, desde Sela \w hacia|strong="H1366"\w* \w arriba|strong="H4605"\w*.
\c 2
\s1 Muerte de Josué
\p 
\v 1 Entonces el \w Ángel|strong="H4397"\w* \w de|strong="H4480"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w subió|strong="H5927"\w* \w de|strong="H4480"\w* \w Gilgal|strong="H1537"\w* \w a|strong="H3068"\w* Bohim y dijo: \wj \w Yo|strong="H4480"\w* los \w saqué|strong="H5927"\w* \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w*, los introduje \w en|strong="H4480"\w* la tierra \w que|strong="H4480"\w* \w juré|strong="H7650"\w* \w a|strong="H3068"\w* sus antepasados y dije: \w Nunca|strong="H3808"\w* quebrantaré mi \w Pacto|strong="H1285"\w* \w con|strong="H4480"\w* ustedes.\wj*
\v 2 \wj Pero ustedes \w no|strong="H3808"\w* \w harán|strong="H6213"\w* \w pacto|strong="H1285"\w* con \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de \w esta|strong="H2063"\w* tierra y derribarán sus \w altares|strong="H4196"\w*. \w Sin|strong="H3808"\w* embargo, \w no|strong="H3808"\w* me \w obedecieron|strong="H8085"\w*. ¿\w Qué|strong="H4100"\w* \w es|strong="H2063"\w* \w esto|strong="H2063"\w* \w que|strong="H4100"\w* \w hicieron|strong="H6213"\w*?\wj*
\v 3 \wj \w Por|strong="H6440"\w* \w lo|strong="H3808"\w* cual dije: \w No|strong="H3808"\w* \w los|strong="H1961"\w* echaré \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ustedes, pero \w ellos|strong="H1571"\w* \w serán|strong="H1961"\w* espinas en su costado, \w y|strong="H1571"\w* sus divinidades \w serán|strong="H1961"\w* una trampa \w para|strong="H1961"\w* ustedes.\wj*
\p 
\v 4 \w Cuando|strong="H1961"\w* \w el|strong="H3605"\w* \w Ángel|strong="H4397"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w habló|strong="H1696"\w* estas \w Palabras|strong="H1697"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w alzó|strong="H5375"\w* su \w voz|strong="H6963"\w* y \w lloró|strong="H1058"\w*.
\p 
\v 5 \w Llamaron|strong="H7121"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* Bohim. \w Allí|strong="H8033"\w* ofrecieron \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 6 Cuando \w Josué|strong="H3091"\w* \w despidió|strong="H7971"\w* al \w pueblo|strong="H5971"\w*, cada uno \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w salió|strong="H3212"\w* \w a|strong="H3068"\w* poseer su \w heredad|strong="H5159"\w*.
