\mt1 Ezra  
\c 1  
\s1 The Decree of Cyrus  
\p
\v 1  \w In|strong="H8141"\w* \w the|strong="H3605"\w* first \w year|strong="H8141"\w* \w of|strong="H4428"\w* \w King|strong="H4428"\w* \w Cyrus|strong="H3566"\w* \w of|strong="H4428"\w* \w Persia|strong="H6539"\w*, \w in|strong="H8141"\w* \w order|strong="H1697"\w* \w to|strong="H3068"\w* \w fulfill|strong="H3615"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*’s\nd* \w message|strong="H1697"\w* \w spoken|strong="H1697"\w* \w through|strong="H5674"\w* \w Jeremiah|strong="H3414"\w*, \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w stirred|strong="H5782"\w* \w the|strong="H3605"\w* \w mind|strong="H7307"\w* \w of|strong="H4428"\w* \w King|strong="H4428"\w* \w Cyrus|strong="H3566"\w* \w of|strong="H4428"\w* \w Persia|strong="H6539"\w*. \w He|strong="H3068"\w* disseminated \w a|strong="H3068"\w* \w proclamation|strong="H6963"\w* \w throughout|strong="H3605"\w* \w his|strong="H3605"\w* \w entire|strong="H3605"\w* \w kingdom|strong="H4438"\w*, announcing \w in|strong="H8141"\w* \w a|strong="H3068"\w* written \w edict|strong="H1697"\w* \w the|strong="H3605"\w* following:   
\p
\v 2 “\w Thus|strong="H3541"\w* \w says|strong="H3541"\w* \w King|strong="H4428"\w* \w Cyrus|strong="H3566"\w* \w of|strong="H4428"\w* \w Persia|strong="H6539"\w*:  
\p “‘\w The|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w God|strong="H3068"\w* \w of|strong="H4428"\w* \w heaven|strong="H8064"\w* \w has|strong="H3068"\w* \w given|strong="H5414"\w* \w me|strong="H5414"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w kingdoms|strong="H4467"\w* \w of|strong="H4428"\w* \w the|strong="H3605"\w* \w earth|strong="H8064"\w*. \w He|strong="H1931"\w* \w has|strong="H3068"\w* instructed \w me|strong="H5414"\w* \w to|strong="H3068"\w* \w build|strong="H1129"\w* \w a|strong="H3068"\w* \w temple|strong="H1004"\w* \w for|strong="H5921"\w* \w him|strong="H5414"\w* \w in|strong="H5921"\w* \w Jerusalem|strong="H3389"\w*, \w which|strong="H1931"\w* \w is|strong="H3068"\w* \w in|strong="H5921"\w* \w Judah|strong="H3063"\w*.  
\v 3  \w Anyone|strong="H3605"\w* \w from|strong="H5927"\w* \w his|strong="H3605"\w* \w people|strong="H5971"\w* \w among|strong="H5973"\w* \w you|strong="H3605"\w* (\w may|strong="H1961"\w* \w his|strong="H3605"\w* \w God|strong="H3068"\w* \w be|strong="H1961"\w* \w with|strong="H5973"\w* \w him|strong="H5973"\w*!) \w may|strong="H1961"\w* \w go|strong="H5927"\w* \w up|strong="H5927"\w* \w to|strong="H3478"\w* \w Jerusalem|strong="H3389"\w*, \w which|strong="H1931"\w* \w is|strong="H3068"\w* \w in|strong="H3478"\w* \w Judah|strong="H3063"\w*, \w and|strong="H3063"\w* \w may|strong="H1961"\w* \w build|strong="H1129"\w* \w the|strong="H3605"\w* \w temple|strong="H1004"\w* \w of|strong="H1004"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w God|strong="H3068"\w* \w of|strong="H1004"\w* \w Israel|strong="H3478"\w* – \w he|strong="H1931"\w* \w is|strong="H3068"\w* \w the|strong="H3605"\w* \w God|strong="H3068"\w* \w who|strong="H4310"\w* \w is|strong="H3068"\w* \w in|strong="H3478"\w* \w Jerusalem|strong="H3389"\w*.  
\v 4  \w Anyone|strong="H3605"\w* \w who|strong="H3605"\w* survives \w in|strong="H1004"\w* \w any|strong="H3605"\w* \w of|strong="H1004"\w* \w those|strong="H3605"\w* \w places|strong="H4725"\w* \w where|strong="H8033"\w* \w he|strong="H1931"\w* \w is|strong="H1931"\w* \w a|strong="H3068"\w* resident foreigner \w must|strong="H5375"\w* \w be|strong="H3389"\w* \w helped|strong="H5375"\w* \w by|strong="H2091"\w* \w his|strong="H3605"\w* neighbors \w with|strong="H5973"\w* \w silver|strong="H3701"\w*, \w gold|strong="H2091"\w*, \w equipment|strong="H7399"\w*, \w and|strong="H3701"\w* animals, \w along|strong="H5973"\w* \w with|strong="H5973"\w* \w voluntary|strong="H5071"\w* \w offerings|strong="H5071"\w* \w for|strong="H1004"\w* \w the|strong="H3605"\w* \w temple|strong="H1004"\w* \w of|strong="H1004"\w* God \w which|strong="H1931"\w* \w is|strong="H1931"\w* \w in|strong="H1004"\w* \w Jerusalem|strong="H3389"\w*.’”   
\s1 The Exiles Prepare to Return to Jerusalem  
\p
\v 5  \w Then|strong="H6965"\w* \w the|strong="H3605"\w* \w leaders|strong="H7218"\w* \w of|strong="H1004"\w* \w Judah|strong="H3063"\w* \w and|strong="H3063"\w* \w Benjamin|strong="H1144"\w*, \w along|strong="H6965"\w* \w with|strong="H1004"\w* \w the|strong="H3605"\w* \w priests|strong="H3548"\w* \w and|strong="H3063"\w* \w the|strong="H3605"\w* \w Levites|strong="H3881"\w* – \w all|strong="H3605"\w* \w those|strong="H3605"\w* \w whose|strong="H1144"\w* \w mind|strong="H7307"\w* \w God|strong="H3068"\w* \w had|strong="H3068"\w* \w stirred|strong="H5782"\w* – \w got|strong="H6965"\w* ready \w to|strong="H3068"\w* \w go|strong="H5927"\w* \w up|strong="H5927"\w* \w in|strong="H3068"\w* order \w to|strong="H3068"\w* \w build|strong="H1129"\w* \w the|strong="H3605"\w* \w temple|strong="H1004"\w* \w of|strong="H1004"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w in|strong="H3068"\w* \w Jerusalem|strong="H3389"\w*.  
\v 6  \w All|strong="H3605"\w* \w their|strong="H3605"\w* neighbors \w assisted|strong="H2388"\w* \w them|strong="H5921"\w* \w with|strong="H5921"\w* \w silver|strong="H3701"\w* \w utensils|strong="H3627"\w*, \w gold|strong="H2091"\w*, \w equipment|strong="H3627"\w*, animals, \w and|strong="H3701"\w* expensive gifts, not \w to|strong="H5921"\w* mention \w all|strong="H3605"\w* \w the|strong="H3605"\w* voluntary \w offerings|strong="H5068"\w*.   
\p
\v 7  \w Then|strong="H3318"\w* \w King|strong="H4428"\w* \w Cyrus|strong="H3566"\w* \w brought|strong="H3318"\w* \w out|strong="H3318"\w* \w the|strong="H5414"\w* \w vessels|strong="H3627"\w* \w of|strong="H4428"\w* \w the|strong="H5414"\w* \nd \+w Lord|strong="H3068"\+w*\nd*’s \w temple|strong="H1004"\w* \w which|strong="H3068"\w* \w Nebuchadnezzar|strong="H5019"\w* \w had|strong="H3068"\w* \w brought|strong="H3318"\w* \w from|strong="H3318"\w* \w Jerusalem|strong="H3389"\w* \w and|strong="H3068"\w* \w had|strong="H3068"\w* \w displayed|strong="H5414"\w* \w in|strong="H3068"\w* \w the|strong="H5414"\w* \w temple|strong="H1004"\w* \w of|strong="H4428"\w* \w his|strong="H5414"\w* gods.  
\v 8  \w King|strong="H4428"\w* \w Cyrus|strong="H3566"\w* \w of|strong="H4428"\w* \w Persia|strong="H6539"\w* \w entrusted|strong="H3318"\w* \w them|strong="H5921"\w* \w to|strong="H3318"\w* \w Mithredath|strong="H4990"\w* \w the|strong="H5921"\w* \w treasurer|strong="H1489"\w*, \w who|strong="H3063"\w* \w counted|strong="H5608"\w* \w them|strong="H5921"\w* \w out|strong="H3318"\w* \w to|strong="H3318"\w* \w Sheshbazzar|strong="H8339"\w* \w the|strong="H5921"\w* \w leader|strong="H5387"\w* \w of|strong="H4428"\w* \w the|strong="H5921"\w* Judahite exiles.   
\p
\v 9  \w The|strong="H4557"\w* inventory \w of|strong="H4557"\w* these items \w was|strong="H2091"\w* \w as|strong="H2091"\w* follows:  
\q1 30 \w gold|strong="H2091"\w* basins,  
