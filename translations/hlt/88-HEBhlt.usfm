\v 13 \x - \xo 1.13 \xt Tgt 110. 1.\x*Te \w dongah|strong="G1161"\w* \w mebang|strong="G5101"\w* \w puencawn|strong="G0032"\w* rhoek \w taengah|strong="G4314"\w* nim, “\w Na|strong="G4675"\w* \w rhal|strong="G2190"\w* rhoek \w te|strong="G3588"\w* \w na|strong="G4675"\w* \w kho|strong="G4228"\w* \w kah|strong="G3588"\w* \w khotloeng|strong="G5286"\w* la ka \w khueh|strong="G5087"\w* \w hlan|strong="G2193"\w* \w atah|strong="G0302"\w* \w kai|strong="G3450"\w* kah \w bantang|strong="G1188"\w* \w ah|strong="G1537"\w* \w ngol|strong="G2521"\w*,” a \w ti|strong="G2046"\w* nah \w noek|strong="G4218"\w*.
\p 
\v 14 \w Khangnah|strong="G4991"\w* te \w pang|strong="G2816"\w* hamla aka \w cai|strong="G3195"\w* \w rhoek|strong="G3588"\w* \w te|strong="G1223"\w* \w bibinah|strong="G1248"\w* \w dongah|strong="G1519"\w* a \w tueih|strong="G0649"\w*, \w mueihla|strong="G4151"\w* \w thothueng|strong="G3010"\w* la \w boeih|strong="G3956"\w* a \w om|strong="G1526"\w* \w moenih|strong="G3780"\w* a?
\c 2
\s1 Vapsa Boeh
\p 
\v 1 \w Te|strong="G5124"\w* \w dongah|strong="G1223"\w* \w mamih|strong="G2248"\w* loh n'\w yaak|strong="G0191"\w* uh \w te|strong="G3588"\w* \w taoe|strong="G4056"\w* \w hnatung|strong="G4337"\w* ham \w om|strong="G1163"\w*. Vik n'\w hloo|strong="G3901"\w* \w ve|strong="G3379"\w*.
\v 2 \w Puencawn|strong="G0032"\w* rhoek \w lamloh|strong="G1223"\w* a \w thui|strong="G2980"\w* \w olka|strong="G3056"\w* \w tah|strong="G3588"\w* \w khangmai|strong="G0949"\w* la a \w om|strong="G1096"\w* \w dongah|strong="G2532"\w* \w boekoeknah|strong="G3847"\w* \w neh|strong="G2532"\w* \w althanah|strong="G3876"\w* loh a \w taphu|strong="G3405"\w* a \w yook|strong="G2983"\w* te \w thuem|strong="G1738"\w*.
\v 3 \w Metla|strong="G4459"\w* \w mamih|strong="G2249"\w* loh te tluk aih la \w khangnah|strong="G4991"\w* n'\w sawtrhoel|strong="G0272"\w* te n'\w poenghal|strong="G1628"\w* aya? \w Boeipa|strong="G2963"\w* \w dong|strong="G3588"\w* \w lamloh|strong="G1223"\w* a \w thui|strong="G2980"\w* bangla a \w tongcuek|strong="G0746"\w* kah a \w dang|strong="G2983"\w* khaw \w te|strong="G3748"\w* loella. Aka \w ya|strong="G0191"\w* \w rhoek|strong="G3588"\w* \w long|strong="G5259"\w* khaw \w mamih|strong="G2248"\w* \w ham|strong="G1519"\w* a \w cak|strong="G0950"\w* sak coeng ta.
\v 4 \w Pathen|strong="G2316"\w* \w kah|strong="G3588"\w* \w miknoek|strong="G4592"\w* \w nen|strong="G5037"\w* \w khaw|strong="G2532"\w*, khobae \w rhambae|strong="G5059"\w* nen \w khaw|strong="G2532"\w*, \w thaomnah|strong="G1411"\w* \w cungkuem|strong="G4164"\w* nen \w khaw|strong="G2532"\w*, \w amah|strong="G0846"\w* kah \w kongaih|strong="G2308"\w* \w bangla|strong="G2596"\w* a \w rhekrha|strong="G3311"\w* \w Mueihla|strong="G4151"\w* \w Cim|strong="G0040"\w* nen khaw a \w phong|strong="G4901"\w* coeng.
\s1 Jesuh neh Hlanghing
\p 
\v 5 Aka \w lo|strong="G3195"\w* ham \w lunglai|strong="G3625"\w* \w te|strong="G3588"\w* \w puencawn|strong="G0032"\w* rhoek taengah \w boengai|strong="G5293"\w* sak \w mahnim|strong="G3756"\w*. \w Te|strong="G3739"\w* \w ni|strong="G4012"\w* n'\w thui|strong="G2980"\w* uh.
\v 6 \x - \xo 2.6 \xt Tgt 8. 4-6.\x*\w Tedae|strong="G1161"\w* \w pakhat|strong="G5100"\w* loh hmuen \w pakhat|strong="G4225"\w* ah \w laipai|strong="G1263"\w* tih, “\w Hlang|strong="G0444"\w* he \w metlam|strong="G5101"\w* a \w om|strong="G2076"\w* \w tih|strong="G3754"\w* \w anih|strong="G0846"\w* te na \w poek|strong="G3403"\w*, \w hlang|strong="G0444"\w* \w capa|strong="G5207"\w* te \w khaw|strong="G2228"\w* metlam a om \w tih|strong="G3754"\w* \w anih|strong="G0846"\w* te na \w hip|strong="G1990"\w*.
\v 7 \w Anih|strong="G0846"\w* te \w puencawn|strong="G0032"\w* rhoek \w lakah|strong="G3844"\w* \w vel|strong="G1024"\w* na \w hlak|strong="G1642"\w* coeng dae \w thangpomnah|strong="G1391"\w* \w neh|strong="G2532"\w* \w hinyahnah|strong="G5092"\w* te \w anih|strong="G0846"\w* na \w khuem|strong="G4737"\w* sak.
\v 8 A \w cungkuem|strong="G3956"\w* te \w a|strong="G0846"\w* \w kho|strong="G4228"\w* \w hmuiah|strong="G5270"\w* boe na \w ngai|strong="G5293"\w* sak,” a \w ti|strong="G3004"\w*.
\p Te \w dongah|strong="G1063"\w* a \w cungkuem|strong="G3956"\w* \w te|strong="G3588"\w* \w a|strong="G0846"\w* taengah boe a \w ngai|strong="G5293"\w* sak \w vaengah|strong="G1722"\w* \w anih|strong="G0846"\w* ham a \w hloh|strong="G0506"\w* pah tih a \w paih|strong="G0863"\w* om \w pawh|strong="G3762"\w*. \w Tedae|strong="G1161"\w* a \w cungkuem|strong="G3956"\w* \w te|strong="G3588"\w* \w anih|strong="G0846"\w* taengah boe a \w ngai|strong="G5293"\w* te \w tahae|strong="G3568"\w* ah m'\w hmu|strong="G3708"\w* uh \w hlan|strong="G3768"\w*.
\v 9 \w Tedae|strong="G1161"\w* \w puencawn|strong="G0032"\w* rhoek \w lakah|strong="G3844"\w* \w tangat|strong="G5100"\w* \w vel|strong="G1024"\w* a \w hlak|strong="G1642"\w* vaengah \w dueknah|strong="G2288"\w* \w dongkah|strong="G3588"\w* \w patangnah|strong="G3804"\w* \w lamloh|strong="G1223"\w* \w thangpomnah|strong="G1391"\w* \w neh|strong="G2532"\w* \w hinyahnah|strong="G5092"\w* \w Jesuh|strong="G2424"\w* a \w khuem|strong="G4737"\w* sak \w te|strong="G3588"\w* m'\w hmuh|strong="G0991"\w* uh. Te \w daengah|strong="G3704"\w* ni \w Pathen|strong="G2316"\w* kah \w lungvatnah|strong="G5485"\w* lamloh a \w cungkuem|strong="G3956"\w* \w yuengla|strong="G5228"\w* \w dueknah|strong="G2288"\w* te a \w ten|strong="G1089"\w* eh.
\v 10 Te tah \w amah|strong="G0846"\w* ham \w tueng|strong="G4241"\w* coeng.A \w cungkuem|strong="G3956"\w* \w tah|strong="G3588"\w* \w amah|strong="G3739"\w* \w ham|strong="G1223"\w* \w neh|strong="G2532"\w* a \w cungkuem|strong="G3956"\w* \w te|strong="G3588"\w* \w amah|strong="G3739"\w* \w lamloh|strong="G1223"\w* om coeng. \w Patangnah|strong="G3804"\w* \w lamloh|strong="G1223"\w* \w amih|strong="G0846"\w* kah \w khangnah|strong="G4991"\w* \w rhuihnun|strong="G0747"\w* \w te|strong="G3588"\w* \w soep|strong="G5048"\w* sak ham \w thangpomnah|strong="G1391"\w* \w khuila|strong="G1519"\w* \w ca|strong="G5207"\w* rhoek te \w muep|strong="G4183"\w* a \w khuen|strong="G0071"\w*.
\v 11 Aka \w ciim|strong="G0037"\w* sak \w neh|strong="G2532"\w* aka \w ciim|strong="G0037"\w* rhoek \w tah|strong="G3588"\w* \w pakhat|strong="G1520"\w* \w kah|strong="G1537"\w* \w boeih|strong="G3956"\w* ni. \w Te|strong="G3739"\w* \w paelnaehnah|strong="G0156"\w* \w nen|strong="G1223"\w* tah \w amih|strong="G0848"\w* te \w manuca|strong="G0080"\w* rhoek la \w khue|strong="G2564"\w* ham \w yak|strong="G1870"\w* \w pawh|strong="G3756"\w*.
\v 12 \x - \xo 2.12 \xt Tgt 22. 22.\x*Te vaengah, “\w Na|strong="G4675"\w* \w ming|strong="G3686"\w* \w te|strong="G3588"\w* \w ka|strong="G3450"\w* \w manuca|strong="G0080"\w* rhoek \w taengah|strong="G3588"\w* ka \w puen|strong="G0518"\w* vetih, \w hlangboel|strong="G1577"\w* \w lakli|strong="G3319"\w* \w ah|strong="G1722"\w* \w nang|strong="G4571"\w* kan \w hlai|strong="G5214"\w* ni,” a \w ti|strong="G3004"\w*.
\v 13 \x - \xo 2.13 \xt Isa 8. 17; \xt Isa 8. 18.\x*Te \w phoeiah|strong="G2532"\w*, “\w Kai|strong="G1473"\w* loh \w amah|strong="G0846"\w* \w te|strong="G1909"\w* ka \w pangtung|strong="G3982"\w* \w ni|strong="G2071"\w*,” \w koep|strong="G3825"\w* a ti. Te \w phoeiah|strong="G2532"\w*, “\w Kai|strong="G1473"\w* \w neh|strong="G2532"\w* \w Pathen|strong="G2316"\w* \w loh|strong="G3588"\w* \w kai|strong="G3427"\w* m'\w paek|strong="G1325"\w* \w camoe|strong="G3813"\w* rhoek \w he|strong="G2400"\w*,” a ti \w bal|strong="G3825"\w*.
\p 
\v 14 Te \w dongah|strong="G1893"\w* \w camoe|strong="G3813"\w* rhoek \w loh|strong="G3588"\w* \w thii|strong="G0129"\w* \w neh|strong="G2532"\w* \w pumsa|strong="G4561"\w* a \w boek|strong="G2841"\w* uh \w coeng|strong="G3767"\w*. \w Amah|strong="G0846"\w* long \w khaw|strong="G2532"\w* \w amih|strong="G0846"\w* \w bangla|strong="G3898"\w* a \w cabol|strong="G3348"\w* coeng. Te \w daengah|strong="G2443"\w* ni \w thaomnah|strong="G2904"\w* aka \w khueh|strong="G2192"\w* \w dueknah|strong="G2288"\w* \w te|strong="G3588"\w* \w dueknah|strong="G2288"\w* \w lamloh|strong="G1223"\w* a \w hmil|strong="G2673"\w* eh. \w Te|strong="G5123"\w* dueknah tah \w rhaithae|strong="G1228"\w* \w ni|strong="G2076"\w*.
\v 15 Te \w phoeiah|strong="G2532"\w* ni \w a|strong="G3588"\w* \w hing|strong="G2198"\w* \w khui|strong="G3956"\w* \w sal|strong="G1397"\w* aka \w bi|strong="G2258"\w* \w kuekluek|strong="G1777"\w* ham rhoek \w te|strong="G5128"\w* \w dueknah|strong="G2288"\w* \w rhihnah|strong="G5401"\w* \w lamloh|strong="G1223"\w* \w boeih|strong="G3745"\w* a \w hlah|strong="G0525"\w* eh.
\v 16 \x - \xo 2.16 \xt Isa 41. 8,9.\x*\w Puencawn|strong="G0032"\w* rhoek te \w rhep|strong="G1222"\w* \w tu|strong="G1949"\w* \w pawt|strong="G3756"\w* \w tih|strong="G0235"\w* \w Abraham|strong="G0011"\w* kah \w tiingan|strong="G4690"\w* ni a \w tuuk|strong="G1949"\w*.
\v 17 Te \w dongah|strong="G3606"\w* \w manuca|strong="G0080"\w* rhoek \w te|strong="G3588"\w* \w boeih|strong="G3956"\w* \w thuidoek|strong="G3666"\w* ham a \w kuek|strong="G3784"\w*. Te \w daengah|strong="G2443"\w* ni \w pilnam|strong="G2992"\w* \w kah|strong="G3588"\w* \w tholhnah|strong="G0266"\w* \w dawth|strong="G2433"\w* pah \w hamla|strong="G1519"\w* \w Pathen|strong="G2316"\w* \w taengah|strong="G4314"\w* \w rhen|strong="G1655"\w* koi \w neh|strong="G2532"\w* \w uepom|strong="G4103"\w* \w khosoihham|strong="G0749"\w* la a \w om|strong="G1096"\w* eh.
\v 18 \w Amah|strong="G0846"\w* loh \w patang|strong="G3958"\w* khaw \w amah|strong="G3739"\w* la a \w noemcai|strong="G3985"\w* coeng dongah a \w noemcai|strong="G3985"\w* rhoek \w te|strong="G3588"\w* \w a \w* \w bom|strong="G0997"\w* \w thai|strong="G1410"\w* \w coeng\w*.
\c 3
\s1 Mamih ham Caeltueih neh Khosoihham
