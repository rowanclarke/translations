\q2 ufayssa yeththi, 
\q2 «GODAA ushachcha kushey 
\q2 wolqqama miish 
\q2 ooththides!» gishe seetettees. 
\q1  
\v 16 GODAA ushachcha kushey 
\q2 dhoqqu dhoqqu gides! 
\q2 GODAA ushachcha kushey 
\q2 wolqqama miish ooththides. 
\b  
\q1  
\v 17 Tani hayqqike 
\q2 shemppora paxa de7ana; 
\q2 GODAY ooththida ooso 
\q2 buroppeka awajjana. 
\q1  
\v 18 GODAY tana keehi qaxxaydes; 
\q2 gido attiin hayqos 
\q2 aaththi immibeenna. 
\b  
\q1  
