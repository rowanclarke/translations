\id JHN
\ide UTF-8
\h Johannes
\toc1 Ngantjani‐Jaura Johanningundru
\toc2 Johanningundru
\toc3 Joh
\mt1 Ngantjani‐Jaura Johanningundru.
\c 1
\lit (Ngantjani‐jaura Jesu dankani ditji parkulani.)
\p 
\v 1 Ngopera jaura nganana wonti, ja jaura Godanto nganana wonti, ja jaura Goda nganana wonti.
\p 
\v 2 Naupini ngopera Godanto nganana wonti.
\p 
\v 3 Nunkangundru warupoto pantjina wonti, ja nunkangupini panini wata kulno pantjina wonti mina pantjina wonti.
\p 
\v 4 Nunkangu tepi nganana wonti, ja tepi kanaia praitji nganana wonti.
\p 
\v 5 Ja praitji mintjiai ngalpurani, ja ngalpurali nina wata patana wonti.
\p 
\v 6 Kana kulno terkakana wonti, nina Godali jinpana wonti, tala nunkani Johannes.
\p 
\v 7 Naupini wokarana wonti tinkaraia, ngangau nulu praitjandru tinkari ngankananto, pratjana nunkangundru morlalu ngundrananto.
\p 
\v 8 Wata nau munta praitji nganana wonti, a‐ai, praitjandru nulu tinkari ngankananto.
\p 
\v 9 Naupini praitji morlalu, Naupini kanani warupotuni mintjiai, mitani wokarananto.
\p 
\v 10 Naupini mitani nganana wonti, ja mita maru nunkangundru pantjina wonti, ja mita marujeli nina wata ngujamana wonti.
\p 
\v 11 Nau wokarana wonti nunkanani, ja tanali nunkanali nina wata patana wonti.
\p 
\v 12 Worderuntjali nina patana wonti, tanangu Nulu ngurula jinkina wonti Godaia kupa pantjinanto, tanali talani nunkanani morlalu ngundranani.
\p 
\v 13 Tanapini wata kumarali, bakana wata palku jertapaterinali, bakana wata materi jertapaterinali, a‐ai, Godandru dankana wonti.
\p 
\v 14 Ja jaura palku pantjina wonti, ja ngaianangunto ngamana wonti, ja ngaiana pirnala nunkani najina wonti, Ngaperi Kunakulnuja pirnalani jeribaka murlali ja morlalu manamiri.
\b
\p 
\v 15 Johannili nunkangundru tinkari ngankana wonti, ja nau maritjina wonti ja jatana wonti: „Naupini Nau nganai, nunkangundru ngani jatana wonti: Nau ngakangu ngadani wokarala nganai ngakangu ngopera wapana wonti; ngangau Nau morla ngopera nganana wonti ngakangu.“
\p 
\v 16 Ja nunkani manamirindru ngaiana pratjanali manina wonti murla ja murla.
\p 
\v 17 Ngangau jirijiribani jaura Nulia Mosili jinkina wonti; murla ja morlalu Jesu Christungundru pantjina wonti.
\p 
\v 18 Wata kulnujeli Goda najina wonti; Ngatamura Kunakulnujeli, Nauja Ngaperaia ngalpani ngamai, Nulia ngaianangu kaukaubana wonti.
\lit (Ngantjani‐jaura G. D. 4. Adventi.)
\p 
\v 19 Ja naupini Johannini tinkari ngankani nganai, matja Juda kanali Jerusalemingundru Priesta ja Levita jinpanala, tanali nina jakalkananto: „Worana jidni nganai?“
\p 
\v 20 Ja nulu morlalu kurana wonti ja wata jedina wonti; ja nulu morlalu kurana wonti: „Wata ngani Christus nganai.“
\p 
\v 21 Ja tanali nina jakalkana wonti: „Worana jidni? Jidni Elias nganai?“ Nau jatana wonti: „Wata ngani nau.“ Jidni Propheta nganai? Ja nulu kalabana wonti: „Pani.“
\p 
\v 22 Tana nunkangu jatana wonti: „Ja worana jidni nganai, ngaiani kalabani jaura tikalkananto tanangu, tanali ngaianina jinpana warai; mina jidni jatai jinkangundru?“
\p 
\v 23 Nau jatana wonti: „Ngani karkanietjaia ngaiala pitarani nganai, Kaparaia palto talku ngankinganimai, worderu Propheta Jesaias jatana wonti.“
\p 
\v 24 Ja tana jinpani Pharisaiandru nganana wonti.
\p 
\v 25 Ja tanali nina jekibana wonti ja nunkangu jatana wonti: „Minandru jundru multibai wata Christus ngananani ja wata Elias ja wata Propheta?“
\p 
\v 26 Johannili kalabana wonti ja tanangu jatana wonti: „Ngato ngapali multibai, ja Nau jurangu terti terkai, nina jura wata ngujamai.
\p 
\v 27 Naupini Nau nganai, Nau ngakangu ngadani wokarala nganai, Nau ngakangu ngopera nganana, nunkangu ngani wata talku nganai tidnaputa jinka nunkani dukarala.“
\p 
\v 28 Jenia Bethabarani pantjina wonti, Jordan kaiarani jerankari, woderi Johannili multibana wonti.
\b
\p 
\v 29 Ditjini kulnuni Johannili najina wonti Jesus nunkangu wokaranani, ja jatana wonti: „Najiau Godaia tjipi kuparu, Nuluwa kana warupotuja madlentji mandrala wapaia!“
\p 
\v 30 Naupini nganai, nunkangundru ngani jatana wonti: „Ngakangu ngadani kana kulno wokarala nganai, Nau ngakangu ngopera wapana wonti; ngangau Nau morla ngopera nganana wonti ngakangu.“
\p 
\v 31 Ja ngato nina wata ngujamana wonti, a‐ai, windri ngangau Juda kanali nina ngujamananto, jendrania ngani wokarana wonti ngapali multibala.
\p 
\v 32 Ja Johannili tinkari ngankana wonti ja jatana wonti: „Ngato najina wonti Jaola pariwilpandru ngarinani mulapara jeribaka, ja Nauja nunkangu ngamana ngarina wonti.“
\p 
\v 33 Ja ngato nina wata ngujamana wonti, a‐ai, windri Naupini, Nulia ngana jinpana wonti ngapali multibala, ngakangu jatana wonti: „Worangu jundru najila nganai Jaola ngarinani ja nunkangu ngamanani, Naupini nganai, Nau Jaolali kulikirieli multibai.“
\p 
\v 34 Ja ngato najina wonti ja tinkari ngankana wonti: Naupini Godaia Ngatamura nganai.
\p 
\v 35 Tankubana ditjini Johannes nakaldra terkana wonti ja nunkani mili mandru.
\p 
\v 36 Ja nulu Jesu palkanani najina wonti ja jatana wonti: „Najiau Godaia Tjipi kuparu!“
\p 
\v 37 Ja mili mandrujeli nina matja ngarana jatanani, pudla Jesungu karipaterina wonti.
\p 
\v 38 Jesus worakalina karitjina wonti ja najina wonti pudlana nunkangu karipaterinani, Nau pudlangu jatana wonti: „Mina judla wontiai?“ Pudla nunkangu jatana wonti: „Rabbi — jenia wondrai ngujangujara jinkinietja — woderi jidni ngamai?“
\p 
\v 39 Nau pudlangu jatana wonti: „Kaperalumai ja najialumai!“ Pudla wokarana wonti ja najina wonti, woderi Nau ngamanani; ja nunkangupini ditjini pudla nunkangunto ngamana wonti. Ja ditji kunarku nganana wonti.
\p 
\v 40 Andreas, Simon Petruni ngatata, pudlangundru kulno nganana wonti, pudlali Johanningundru ngarana warai, ja nunkangu karipaterina warai.
\p 
\v 41 Nulupini ngopera Simon neji nunkani mankamankana wonti, ja nunkangu jatana wonti: „Ngali Messias mankamankana warai, jenia wondrai Christus.“
\p 
\v 42 Nulu nina Jesungu wapalkana wonti. Jesujeli nina matja najina, jatana wonti: „Jidni Simon nganai, Jonani ngatamura; jundru Kephas tala ngamalkala nganai;“ jenia wondrai „Marda.“
\p 
\v 43 Tankubana ditjini Jesujeli ngantjana wonti Galilaiaia palkala, ja Nulu Philippus mankamankana wonti ja nunkangu jatana wonti: „Ngakangu karipateriau!“
\p 
\v 44 Philippus Bethsaidandru nganana wonti, Andreani ja Petruni ngurandru.
\p 
\v 45 Philippula Nathanaeli mankamankana wonti ja nunkangu jatana wonti: „Ninaia, nunkangundru Mosili jirijiribani jaurani ja Prophetali dakana wonti, ninapini ngaiani mankamankana warai, Jesu Josephani ngatamura Nazaretandru.“
\p 
\v 46 Ja Nathanael nunkangu jatana wonti: „Nazaretandru ngumula dunkananto?“ Philippus nunkangu jatana wonti: „Kaparau ja najiau!“
\p 
\v 47 Jesujeli Nathanael nunkangu wokaranani najina wonti, ja nunkangundru jatana wonti: „Najianau Israel kana morlalu, nunkangu jedini pani nganai!“
\p 
\v 48 Nathanael nunkangu jatana wonti: „Woderindru jundru ngana ngujamai?“ Jesujeli nunkangu kalabana wonti ja jatana wonti: „Morla ngopera Philippulu jidna karkana warai, jidni tandra pitani ngananani, ngato jidna najina warai.“
\p 
\v 49 Nathanailali nunkangu kalabana wonti ja jatana wonti: „Rabbi, jidni Godaia Ngatamura nganai, jidni Israelani Kapara nganai!“
\p 
\v 50 Jesujeli nunkangu kalabana wonti ja jatana wonti: „Ngangau ngani jinkangu jatana warai, ngato jidnana najina warai tandra pitani, jundru morlalu ngundrai? Jundru morla pirnala najila nganai nunkangupini.
\p 
\v 51 Ja Nau nunkangu jatana wonti: Morlalu, morlalu, ngani jurangu jatai: Kararindrn jura najila nganai pariwilpa piririnani, ja Godaia angela worana taranani ja ngarinani Godaia Ngatamurani.“
\c 2
\lit (Ngantjani‐jaura G. D. 2. Epiphanias.)
\p 
\v 1 Ja ditji parkulani noapatamalini ditji nganana wonti Kana ngurani Galilaiani; ja Jesuni ngandri naka nganana wonti.
\p 
\v 2 Ja tanali bakana Jesus ja mili nunkani noapatamalini ditjia karkana wonti.
\p 
\v 3 Ja waina matja mudana, Jesuni ngandri nunkangu jatana wonti: „Waina pani morla tanalia ngamalkai.“
\p 
\v 4 Jesus nankangu jatana wonti: „Mina ngakangu ja jinkangu Widlajai? Ditji ngakani wata wokarala wapaia.“
\p 
\v 5 Ngandri nunkani milini jatana wonti: „Mina Nauja jurangu jatai, jenia ngankanau!“
\p 
\v 6 Ja naka mardangapakoko pirna mara wora ja kulno terkana wonti, worderu Juda kanali milingeru ngamalkana wonti kulirkaterila, ja koko pirnali mandrani koko waka mandru kara, parkulu kara patana wonti.
\p 
\v 7 Jesus tanangu jatana wonti: „Ngapakoko manamiri ngankanau ngapali.“ Ja tanali manamiri ngankana wonti.
\p 
\v 8 Ja Nau tanangu jatana wonti: „Kaluanau, ja bukanajinajibanietjani padakanau!“ Ja tanali padakana wonti.
\p 
\v 9 Ja bukanajinajibanietja nina waina, nau ngopera ngapa nganana warai, wontjana wonti, ja nau ko nganana wonti woderindru nau, windri mili milkila nganana wonti, ngangau tanali ngapa manina, bukanajinajibanietjali noangantjanipirna karkana wonti,
\p 
\v 10 Ja nunkangu jatana wonti: „Kana pratjanali waina ngumu ngopera jinkiai, ja tana matja kaljura nganana, ngadani madlentji; jundru waina ngumu kulkana warai kararielu.“
\p 
\v 11 Naupini malka ngopera nganana wonti, nina Jesujeli ngankana wonti Kana ngurani Galilaiani pirnala nunkani wondrala; ja milieli nunkanali morlalu ngundrana wonti nunkangu.
\b
\p 
\v 12 Ngadani Nau Kapernaum nguraia ngarina wonti, Nau ja ngandri nunkani ja ngatata nunkani ja mili nunkani; ja naka tanali windri ditji palpa ngamana wonti.
\p 
\v 13 Ja Juda kanaia Passa karakara nganana wonti, ja Jesus tarana wonti Jerusalemia.
\p 
\v 14 Ja Nulu Godaia pungaia mankamankana wonti tanana nganti pirna ja tjipi ja mulapara burungankanani ja mardatandrakaritjimalkanietja ngamanani.
\p 
\v 15 Ja Nulu jinkandru nandrani jinka wirri ngankana wonti, ja pratjana Godaia pungandru narana wonti, tjipi ja bakana nganti pirna; ja mardatandrakaritjimalkanietjaia marda Nulu nangana wonti, ja karitjimalkani kurli tanani Nulu kokulterkibana wonti.
\p 
\v 16 Ja Nau mulaparaburungankanietjani jatana wonti: „Padakanimai tananapara pratjana ninkidandru, ja wata ngakani Ngaperaia punga burungankani punga karitjimalkanau!“
\p 
\v 17 Milieli nunkanali ngundrana wonti worderu dakanala parai: „Ngantjana pirnali jinkani pungandru ngana tajila nganai.“
\p 
\v 18 Juda kanali kalabana wonti ja nunkangu jatana wonti: „Mina malka jundru ngaianingu wondrai, ngangau jundru ninapini ngankai?“
\p 
\v 19 Jesujeli kalabana wonti ja jatana wonti tanangu: „Ninapini punga wokaribamai, ja ditjini parkulani ngato ninaia terkibana tarala nganai.“
\p 
\v 20 Juda kana jatana wonti: „Ninapini punga tanali 46 kilpawoldrani wotina wonti, ja jundru ninaia ditjini parkulani terkibana tarala nganai?“
\p 
\v 21 Nau jenia jatana wonti nunkani palku pungandru.
\p 
\v 22 Nau matja tepi terkakana warai narindru, milieli nunkanali ngundrana wonti, Nulu jenia tanangu jatana wonti; ja tanali jaurani morlalu ngundrana wonti, ja nunkangupini jaurani nina Jesus jatana wonti.
\p 
\v 23 Nau Jerusalemingu nganana Passa ditji pirnani, marapujeli talani nunkanani morlalu ngundrana wonti, ngangau tanali malka nunkani najina wonti, tanana Nulu ngankana wonti.
\p 
\v 24 Jesujeli tanangu wata morlalu ngundrana wonti, ngangau Nulu pratjana ngujamana wonti.
\p 
\v 25 Ja nunkangu wata kulno jaura jinkinanto kanandru; ngangau Nulu muntali ngujamana wonti, mina kanani nganai.
\c 3
\lit (Ngantjani‐jaura Trinitatis ditjini.)
\p 
\v 1 Kana kulno nganana wonti Pharisaiandru, tala nunkani Nikodemus, Juda kanaia kapara kulno.
\p 
\v 2 Naupini Jesungu wokarana wonti tinkani, ja nunkangu jatana wonti: „Kaparajai, ngaiani milkila, jidni ngujangujara jinkinietja nganai Godandru wokaranala; ngangau wata kulno ngurunguru nganai tananapini malka ngankala, tanana jundru ngankai, Goda wata nunkangunto ngananani.“
\p 
\v 3 Jesujeli kalabana wonti ja nunkangu jatana wonti: „Morlalu, morlalu, ngani jinkangu jatai: Wata kana marra dankanani, nau ngandandariai Godaia milila najila.“
\p 
\v 4 Nikododemus nunkangu jatana wonti: „Worderu kana marra dankala nganai nau pirna ngananani? Nau poto mandrula ngandri mandrani wirinanto marra dankala?“
\p 
\v 5 Jesujeli kalabana wonti: „Morlalu, morlalu, ngani jinkangu jatai: Warle wata marra dankanani ngapali ja Jaolali, nau ngandandarila nganai Godaia mililani wirila.
\p 
\v 6 Mina palkujeli dankai, palku nganai; ja mina Jaolali dankai, Jaola nganai.
\p 
\v 7 Wata ngaruparau, ngangau ngani jinkangu jatana warai: Jura marra dankananto.
\p 
\v 8 Watara ngakai woderi nau jertapateriai ja birungana nunkani jundru ngarai, windri jundru wata ngujamai, woderindru nauja wokarai ja woderi ngakai; jeruja pratjana, tana Jaolandru dankai.“
\p 
\v 9 Nikodemulu kalabana wonti ja nunkangu jatana wonti: „Worderu jenia pantjiai?“
\p 
\v 10 Jesujeli kalabana wonti ja nunkangu jatana wonti: „Jidni ngujangujara jinkinietja nganai Israelani, ja jenia jundru wata ngujamai?
\p 
\v 11 Morlalu, morlalu, ngani jinkangu jatai: Ngaiani jatai mina ngaiani ngujamai, ja kaukaubai mina ngaiani najinala, ja ngaianini tinkari ngankani jura wata patai.
\p 
\v 12 Ngani mitaia potundru jurangu jatanani, jura wata morlalu ngundranani; worderu morla jura wata morlalu ngundrala nganai, ngani pariwilpaia potundru jurangu jatanani?
\p 
\v 13 Ja wata kulno pariwilpaia tarala wapaia, windri Nauja pariwilpandru ngarinala, Kanaia Ngatamura, Nauja pariwilpani nganai.
\p 
\v 14 Ja worderu Mosili pitarani tjutju miri ngankana wonti, jeruja tanali Kanaia Ngatamura miri ngankananto.
\p 
\v 15 Ngangau pratjanali, nunkangu morlalu ngundranani, wata tintaterinanto, a‐ai, tepi ngurali ngamalkananto.
\b
\lit (Ngantjani‐jaura Jaolali ditji mandrulani.)
\p 
\v 16 Ngangau jeruja Godali mitala ngantjana wonti, Nulia Ngatamura Kunakulno nunkani jinkina wonti, ngangau pratjanali tana nunkangu morlalu ngundranani, wata tintaterinanto, a‐ai, tepi ngurali ngamalkananto.
\p 
\v 17 Ngangau Godali Ngatamura nunkani wata mitani jinpana wonti kalala kurala, a‐ai, Nulu mitala kulkananto.
\p 
\v 18 Warlenulu ninaia morlalu ngundranani wata kalala maninani; ja warlenulu wata morlalu ngundranani kalala matja manina, ngangau nulu Godaia Ngatamuraia Kunakulnuja talani wata morlalu ngundrai.
\p 
\v 19 Naupini kalala nganai: Praitji mitani wokarana wonti, ja kanali ngalpuru morla ngantjana wonti praitjani; ngangau ngankana tananani madlentji nganana wonti.
\p 
\v 20 Ngangau warle madlentji ngankai, praitjani kalakalariai, ja wata praitjani wokarai, ngankana nunkani tinkari pantjiati.
\p 
\v 21 Warle morlalulali ngankanani, praitjani wokarala nganai, ngangau ngankana nunkani tinkari pantjinanto, ngangau tanali Godani ngankana warai.“
\b
\p 
\v 22 Ngadani Jesus ja mili nunkani Judaia mitani wokarana wonti; ja naka Nau ngamana wonti tanangunto ja multibana wonti.
\p 
\v 23 Ja bakana Johannili multibana wonti Ainoni, Salimingu karakara, ngangau ngapa marapu naka nganana wonti; ja tana wokarana wonti ja multibanila manina wonti.
\p 
\v 24 Ngangau jendranguta Johannes wata kanjangarini ngamana wonti.
\p 
\v 25 Johannini milindru jatamalina pantjina wonti Juda kanani kulirkanandru.
\p 
\v 26 Ja tana Johanningu wokarana wonti ja nunkangu jatana wonti: „Rabbi, Naupini jinkangu nganana paraia Jordan kaiarani jerankari, nunkangundru jundru tinkari ngankana paraia, mai, Nau multibai, ja pratjana nunkangu wokarai.“
\p 
\v 27 Johannili kalabana wonti ja jatana wonti: „Kana kulnujeli ngandandariai palpa manila, nunkangu wata ngopera jinkinala pariwilpandru.
\p 
\v 28 Jura muntali ngakangu tinkari ngankai, ngani jatana paraia: Ngani wata Christus nganai, a‐ai, Nulu ngana jinpana wonti nunkangu ngopera.
\p 
\v 29 Warle talpadakani noa ngamalkai, nau noangantjanipirna nganai; ja noangantjanipirnaia kamaneli, nau terkai ja nina ngarai, pirna mankiai noangantjanipirnaia ngaialandru. Naupini mankina pirna ngakani karari manamiri nganai.
\p 
\v 30 Nau pirnarinanto, ngani wakarinanto.
\p 
\v 31 Naupini mirindru wokarai morla pirna nganai pratjanani. Worana mitandru nganai, nau mitandru nganai ja mitandru jatai; Nau pariwilpandru wokarai morla pirna nganai pratjanani.
\p 
\v 32 Mina Nulu najina wonti ja ngarana wonti jenia Nulu tinkari ngankai, ja tinkari ngankani nunkani wata kulnujeli patai.
\p 
\v 33 Warle tinkari ngankani nunkani patana warai, nulu jenia morlalu kurana warai Goda morlalu nganai.
\p 
\v 34 Ngangau worana Godali jinpana wonti, Nulu Godaia jaura kaukaubai; ngangau Godali wata Jaola ngalje jinkiai nunkangu.
\p 
\v 35 Ngaperali Ngatamura ngantjai, ja pratjana Nulia marani nunkanani jinkina wonti.
\p 
\v 36 Warlenulu Ngatamurani morlalu ngundrai, nulu tepi ngurali ngamalkai; worana Ngatamurani wata pankiai, nulu tepita wata najila nganai, a‐ai, Godaia tiri nunkangu milingeru parai.“
\c 4
\p 
\v 1 Kaparali matja ngujamana, Pharisaiali ngarana warai Jesujeli morla mili ngankanani ja multibanani Johanningu
\p 
\v 2 — Jesujeli muntali wata multibana wonti, a‐ai, windri milieli nunkanali —
\p 
\v 3 Nau Judaiandru puntina wonti ja nakaldra Galilaiaia palkana wonti.
\p 
\v 4 Nau Samaria mitani palkingananto.
\p 
\v 5 Nau wokarana wonti Samaria ngura kulnuni, tala nunkani Sichar, nunkangupini mitani karakara, nina Jakobali ngatamurani nunkanani Josephangu jinkina wonti.
\p 
\v 6 Naka Jakobani ngapatjili nganana wonti. Ngangau Jesus palkanandru matja walturina, Nau ngamana ngarina wonti ngapatjilini; ja toda nganana wonti.
\p 
\v 7 Samaria widla kulno wokarana wonti ngapa kaluala. Jesus nankangu jatana wonti: „Ngakangu jinkiau tapananto?“
\p 
\v 8 Ngangau mili nunkani nguraia wapana wonti buka burungankala.
\p 
\v 9 Samarita widla nunkangu jatana wonti: „Worderu jenia, jidni Juda kana nganai ja ngatjiai ngakangundru tapala, ngani Samarita widla ngananani?“ Ngangau Juda kana wata manduriai Samaritalani.
\p 
\v 10 Jesujeli kalabana wonti ja jatana wonti nankangu: „Jundru Godaia poto ngujamanani ja worana Nauja nganai, Nauja jinkangu jatai: Jinkiau ngakangu tapananto, jidni nunkangu ngatjila nganai, ja Nulia jinkangu tepia ngapa jinkila nganai.“
\p 
\v 11 Widla nunkangu jatana wonti: „Kaparajai, jundru wata ngapakoko ngamalkai ja ngapatjili mikari nganai; wodajerindru jundru tepia ngapa ngamalkai?
\p 
\v 12 Jidni morla pirna nganai ngaianini ngaperani Jakobangu, nulupini ngaianingu ninaia ngapatjili jinkina wonti, ja nulu muntali nunkangundru tapana wonti ja ngatamurajeli nunkanali ja ngantieli nunkanali?“
\p 
\v 13 Jesujeli kalabana wonti ja nankangu jatana wonti: „Warlepratjana nunkangupini ngapandru tapanani nakaldra tertieli pantjila nganai.
\p 
\v 14 Warle nunkangupini ngapandru tapala nganai, nina ngato nunkangu jinkila nganai, nau ngurali wata tertieli pantjila nganai; a‐ai, naupini ngapa, nina ngato nunkangu jinkila nganai, nunkangu ngapa jukeri pantjila nganai, nau ngurali tepini ngakala nganai.“
\p 
\v 15 Widla nunkangu jatana wonti: „Kaparajai, ninapini ngapa ngakangu jinkiau, ngani wata morla tertieli pantjinanto, ja wata morla ninkida wokarananto kaluala.“
\p 
\v 16 Jesus nankangu jatana wonti: „Wapau, noa jinkani karkau, ja nakaldra ninkida tikau!“
\p 
\v 17 Widlali kalabana wonti ja jatana wonti: „Ngani noa pani.“ Jesus nankangu jatana wonti: „Talku jidni jatana warai, ngani noa pani.
\p 
\v 18 Ngangau jundru noa mara wora matja ngamalkana, ja nau, ninapini jundru karari ngamalkai, wata noa jinkani nganai; jenia jidni morlalu jatana warai.“
\p 
\v 19 Widla nunkangu jatana wonti: „Kaparajai, ngato na jiai, jidni Propheta nganai.
\p 
\v 20 Ngaianini ngaperi nunkangupini mardawonpani ngatjina wonti, ja jura jatai, Jerusalemingu nau piri nganai, woderi ngatjinanto.“
\p 
\v 21 Jesus nankangu jatana wonti: „Widlajai, ngakangu morlalu ngundrau, ditji kulno wokarala nganai, jura wata morla nunkangupini mardawanpani ja wata morla Jerusalemingu Ngapinangu ngatjila nganai.
\p 
\v 22 Jura nunkangu ngatjiai, nina jura wata ngujamai; ngaiani nunkangupini ngatjiai, ninaia ngaiani ngujamai; ngangau Kulkanipirna Juda kanandru wokarai.
\p 
\v 23 Ditji kulno wokarala nganai, ja matja karari nganai, nunkangu tana morlalu ngatjinietja Ngapinangu ngatjila nganai Jaolali ja morlalujeli; ngangau Ngaperali jenipara ngantjai, nunkangu jeruja ngatjinani.
\p 
\v 24 Goda Jaola nganai, ja tana nunkangu ngatjiai, Jaolali ja morlalujeli nunkangu ngatjinanto.“
\p 
\v 25 Widla nunkangu jatana wonti: „Ngani milkila Messias wokarala nganai, nina tanali dikai Christus; Nau wokaranani, Nulu ngaianingu pratjana kaukaubala nganai.“
\p 
\v 26 Jesus nankangu jatana wonti: „Ngani Naujata, Nauja jinkangu jela ngankamalila wapaia.“
\p 
\v 27 Ja jendranguta mili nunkani tikana wonti, ja tana ngaruparana wonti, ngangau Nau widlali ngankamaliai; ja wata kulno jatana wonti: „Mina jundru wontiai kara? Mina jidni nankangu jela ngankamaliai kara?“
\p 
\v 28 Widlali ngapakoko nankani worarana wonti, ja nguraia tikana kurana wonti, ja kanani jatana wonti:
\p 
\v 29 „Kaparanimai ja najianimai kana kulno, Nulupini ngakangu jatana warai pratjana, mina ngato ngankana warai; Naumata kara Christus?“
\p 
\v 30 Tana ngurandru dunkana wonti ja nunkangu wokarana wonti.
\p 
\v 31 Jendranguta mili nunkani nunkangu ngatjina wonti ja jatana wonti: „Rabbi, tajiau!“
\p 
\v 32 Nau tanangu jatana wonti: „Ngato buka ngamalkai tajila ninaia jura wata ngujamai.“
\p 
\v 33 Mili wora jaura ngankamalina wonti: „Kulnujeli nunkangu buka jinkina warai kara?“
\p 
\v 34 Jesus tanangu jatana wonti: „Buka ngakani nganai, ngato jertapaterina nunkani ngankananto, Nulia ngana jinpana wonti, ja ngankana nunkani mudananto.
\p 
\v 35 Wata jura jatai: Pira mandru ja mandruni kampani ditji wokarala nganai? Mai, ngani jurangu jatai, milki jurani miririanau ja maruni najianau, ngangau nau karari talku nganai kampananto.
\p 
\v 36 Kampanietjali kalala maniai ja tandra kampai ngurali tepia; ngangau jelali mankinanto jaupanietja ja kampanietja;
\p 
\v 37 Ngangau ninkina jenia jaura morlalu nganai: Kulno pilki jaupanietja ja kulno pilki kampanietja.
\p 
\v 38 Ngato jurana jinpana wonti kampananto, mina jura wata ngankana warai; kana ngurujeli ngankana wonti, ja jura ngankanani tananani wirina wonti.“
\p 
\v 39 Nunkangupini ngurandru Samaritala marapujeli nunkangu morlalu ngundrana wonti widlaia jaurandru, nandru tinkari ngankana wonti: „Nau ngakangu jatana warai pratjana, mina ngato ngankana wonti.“
\p 
\v 40 Samaritala nunkangu matja wokarana, tana nunkangu ngatjina wonti, Nau tanangunto ngamananto; ja Nau ditji mandru naka ngamana wonti.
\p 
\v 41 Ja morla marapujeli nunkani jaurandru morlalu ngundrana wonti,
\p 
\v 42 Ja widlani tana jatana wonti: „Wata morla jinkani jaurandru ngaiani morlalu ngundrai, a‐ai, muntali ngaiani ngarana warai ja ngujamai, Naupini morlalu Christus, kanaia Kulkanipirna nganai.“
\p 
\v 43 Ditji mandruni Nau nakandru puntina wonti ja Galilaiaia palkana wonti.
\p 
\v 44 Ngangau Jesujeli muntali morlalu kurana wonti, Propheta ngaperalani mitani waka nganai.
\p 
\v 45 Nau Galilaiani matja wokarana, Galilaialali nina patana wonti, ngangau tanali pratjana najina paraia, mina Nulu Jerusalemingu ditji pirnani ngankana paraia; ngangau bakana tana ditji pirnani wokarana wonti.
\p 
\v 46 Jesus nakaldra Kana ngurani Galilaiani wokarana wonti, woderi Nulu ngapandru waina ngankana paraia.
\lit (Ngantjani‐jaura G. D. 21. Trinitatis.)
\p 
\v 47 Ja kapakapara kulno nganana wonti, nunkani ngatamura muntja parana wonti Kapernaum ngurani. Nulu matja ngarana, Jesus Judaiandru Galilaiaia wokaranani, nau nunkangu wapana wonti ja ngatjina wonti, Nau ngarinanto ngatamura nunkani tepi ngankala; ngangau nau ngara wordu parana wonti.
\p 
\v 48 Ja Jesus nunkangu jatana wonti: „Jura wata malka ja pirnala najinani, jura wata morlalu ngundranani.“
\p 
\v 49 Kapakapara nunkangu jatana wonti: „Kaparajai, ngariau, windrila kupa ngakani palinanto.“
\p 
\v 50 Jesus nunkangu jatana wonti: „Tikamai, kupa jinkani matja tepi.“ Nulu nina jaura morlalu ngundrana wonti, nina Jesus nunkangu jatana wonti, ja tikana wonti.
\p 
\v 51 Nau matja ngarina, mili nunkani nunkangu mandurina wonti, ja nunkangu kaukaubana wonti ja jatana wonti: „Kupa jinkani matja tepi.“
\p 
\v 52 Ja nulu tanangundru ditji jakalkana wonti nunkangu nau tepirila wiri; ja tana nunkangu jatana wonti: „Woldrawirdi toda muntjali nina worarala wiri.“
\p 
\v 53 Jeruja ngaperali ngujamana wonti, jenia nunkangupini ditjini nganala wiri, nunkangu Jesus nunkangu jatala wiri: „Ngatamura jinkani matja tepi;“ ja nulu morlalu ngundrana wonti ja ngurala nunkani pratjana.
\p 
\v 54 Naupini malka mandrula nganai Jesujeli matja ngankana, matja Nau Judaiandru Galilaiani wokarana wonti.
\b
\c 5
\p 
\v 1 Ngadani ditji pirna nganana wonti Juda kanani, ja Jesus tarana wonti Jerusalemia.
\p 
\v 2 Jerusalemingu tjipi manani panto kulno nganana wonti, nulu Juda kana talini Bethesda tala ngamalkana wonti, nunkangu punga mara wora nganana wonti.
\p 
\v 3 Tanangupini mandrani parana wonti muntja marapu, butju, tjunduru, jiranga, tanali kalkana wonti ngapa patijiritjinanto.
\p 
\v 4 Ngangau angela kulno pota palpa pantuni ngarina wonti, ja nulu ngapa patijiritjibana wonti. Worana ngopera pantuni wirinani ngapa matja patijiritjinani, nau tepi pantjina wonti, mina muntja nulu ngamalkana wonti.
\p 
\v 5 Kana kulno naka nganana wonti, nau kilpawoldra 38 muntja parana wonti.
\p 
\v 6 Ninapini Jesujeli paranani najina wonti, ja Nulu ngarana wonti, nau ditji marapu jeruja nganana, Nau nunkangu jatana wonti: „Jundru ngantjai tepi pantjila?“
\p 
\v 7 Muntjali nunkangu kalabana wonti: „Kaparajai, ngato kana pani ngamalkai, nulu ngana pantuni worananto, ngapa matja patijiritjibana; ja ngani wokaranani kulno nguru ngakangu ngopera wiriai.“
\p 
\v 8 Jesus nunkangu jatana wonti: „Jiritjiau, turarani piri jinkani maniau ja wirariau!“
\p 
\v 9 Ja nurujeli naupini kana tepirina wonti, ja nulu turarani piri nunkani manina wonti ja wirarina wonti. Ja naupini ditji Sabbat nganana wonti.
\p 
\v 10 Juda kana nunkangu muntjalani jatana wonti: „Karari Sabbat nganai; ja jenia jinkangu wata manuni kurala wapaia turarani piri jinkani waltananto.“
\p 
\v 11 Nulu tanangu kalabana wonti: „Naupini, Nulu ngana tepi ngankana warai, ngakangu jatana warai: Turarani piri jinkani maniau ja wirariau!“
\p 
\v 12 Tanali nina jakalkana wonti: „Worana Naupini kana, Nau jinkangu jatana warai: Turarani piri jinkani maniau ja wirariau!“
\p 
\v 13 Naupini muntjala ko nganana wonti, worana Nau nganai, ngangau Jesus kutingana wonti, ngangau kana wolara nunkangupini pirini nganana wonti.
\p 
\v 14 Ngadani Jesujeli nina Godaia pungani mankamankana wonti ja nunkangu jatana wonti: „Mai, jidni tepirina warai; wata morla madlentji ngankau, jinkangu morla madlentji wokaraiati.“
\p 
\v 15 Naupini kana wapana wonti ja Juda kanani kaukaubana wonti: „Nau Jesus nganai, Nulu ngana tepi ngankana warai.“
\p 
\v 16 Ja Juda kana jendrangundruja Jesungu tirikaripaterina wonti ja wontjana wonti nina naria nandrala, ngangau Nulu jenia ngankana wonti Sabbatani.
\p 
\v 17 Jesujeli kalabana wonti ja tanangu jatana wonti: „Ngaperali ngakanali ngankai kararielu, ja ngato bakana ngankai.“
\p 
\v 18 Jendrangundruja Juda kanali morla wontjana wonti nina naria nandrala, ngangau Nulu wata windri Sabbat wokaribana wonti, a‐ai, Nulu bakana Goda Ngaperi nunkani dikana wonti, ja jeruja munta Goda jeribaka ngankaterina wonti.
\p 
\v 19 Jesujeli kalabana wonti ja tanangu jatana wonti: „Morlalu, morlalu, ngani jurangu jatai: Ngatamura munta ngandandariai ngankala, Nulu wata ngopera najinani Ngaperali ngankanani; ngangau mina Nulupini ngankai, jenia bakana Ngatamurajeli ngankai.
\p 
\v 20 Ngangau Ngaperali Ngatamura ngantjai, ja Nulia pratjana nunkangu wondrai, mina Nulia muntali ngankai; ja ngankana morla pirna tanangu Nulia nunkangu wondrala nganai, jura ngaruparananto.
\p 
\v 21 Ngangau worderu Ngaperali narila jiritjibai ja tepi ngankai; jeruja bakana Ngatamurajeli tepi ngankai tanangu Nauja jertapateriai.
\p 
\v 22 Ngangau Ngaperali wata kulnuni kalala kurani, a‐ai, kalala kurani pratjana Nulia Ngatamurani jinkina wonti,
\p 
\v 23 Ngangau pratjanali Ngatamura pirna ngundrananto, worderu tanali Ngaperi pirna ngundrai. Warlenulu Ngatamurani wata pirna ngundrai, nulu Npaperi wata pirna ngundrai, Nulia ninaia jinpanala.
\p 
\v 24 Morlalu, morlalu, ngani jurangu jatai: Warlenulu jaura ngakani ngarai, ja nunkangu morlalu ngundrai, Nulia ngana jinpanala, nulu tepi ngurali ngamalkai; ja kalalani nau wata wokarai, a‐ai, nau narindru tepia wiringana wonti.
\p 
\v 25 Morlalu, morlalu, ngani jurangu jatai: Ditji kulno wokarala nganai, ja matja karari nganai, narieli Godaia Ngatamuraia ngaiala ngarala nganai, ja tanali ngarai, tana tepirila nganai.
\p 
\v 26 Ngangau worderu Ngaperali muntali nunkangu tepi ngamalkai, jeruja bakana Nulia Ngatamurani jinkina wonti, tepi muntali nunkangu ngamalkala.
\p 
\v 27 Ja Nulia nunkangu ngurula jinkina wonti kalala kurananto; ngangau Nauja Kanaia Ngatamura nganai.
\p 
\v 28 Wata ngaruparanau nunkangupini; ngangau ditji kulno wokarai, nunkangupini pratjanali, tana nari kutuni parai ngaiala nunkani ngarala nganai,
\p 
\v 29 Ja dunkala nganai, tanali ngumu ngankanala tepia terkakala nganai, ja tanali madlentji ngankanala terkakala nganai kalalaia.
\p 
\v 30 Ngani ngandandariai muntali ngakangundru ngankala; a‐ai, worderu ngato ngarai, jeruka ngato kalala kurai; ja kalala kurani ngakani talku nganai, ngangau ngato wata ngakani jertapaterinali wontiai, a‐ai, windri nunkani jertapaterinali, Nulia ngana jinpanala.
\p 
\v 31 Ngato ngakangundru muntali jaura ngamalkanani, jaura ngakani wata morlalu ngananani;
\p 
\v 32 Kulno nguru ngakangundru jaura jatai, ja ngani milkila, jaura nunkani morlalu nganai, ninaia Nulia ngakangundru jatai.
\p 
\v 33 Jura Johanningu jinpana paraia, ja nulu jaura jatana paraia morlaluja.
\p 
\v 34 Ngato wata kanandru jaura morlalu maniai, a‐ai, jenia ngani jatai, jura kulkani ngamalkananto.
\p 
\v 35 Nau jerkini ja mintjini praitji nganana wonti; ja jura ngantjana paraia ditji ngalje murlali nganala praitjani nunkanani.
\p 
\v 36 Ngato jaura morlalu morla pirna ngamalkai Johanningu; ngangau tananapini ngankana, tanana Ngaperali ngakangu jinkinala, ngato tanana mudananto, tananapini ngankana tanana ngato ngankai, ngakangundru morlalu jatai, Ngaperali ngana jinpanala.
\p 
\v 37 Ja Ngaperali, Nulia ngana jinpanala, munta ngakangundru jaura morlalu jatana wonti. Jura wata ngaiala nunkani ngarana wonti, ja wata mudla nunkani najina wonti;
\p 
\v 38 Ja jaura nunkani wata jurangu parala wapaia, ngangau ninaia, ninaia Nulia jinpanala, nunkangu jura wata morlalu ngundrai.
\p 
\v 39 Jura wontiai Godaia jaurani, ngangau jura ngundrai nunkangu tepi ngurali ngamalkala, ja tanapini nganai, tanana ngakangundru kaukaubai.
\p 
\v 40 Ja jura wata ngantjai ngakangu wokarala tepi ngamalkala.
\p 
\v 41 Kanandru wata ngato pirnala maniai.
\p 
\v 42 Ngato jurana ngujamai, jura wata Godaia ngantjana jurangu ngamalkai.
\p 
\v 43 Ngani wokarana wonti Ngaperaia ngakanaia talani, ja jura ngana wata patai; kulno nguru wokaranani jurangu talani nunkanani, nina jura patala nganai.
\p 
\v 44 Worderu jura morlalu ngundrananto jura pirnala manijiribamaliai; ja kulnuja Godaia pirnala jura wata wontiai?
\p 
\v 45 Wata ngundranau ngani jurangundru ngulkuterkala nganai Ngaperani, a‐ai, Moses jurani ngulkuterkanietja nganai, nunkangu jura kalkani jurani kurana warai.
\p 
\v 46 Ngangau jura Mosingu morlalu ngundranani, jura ngakangu morlalu ngundranani, ngangau nulu ngakangundru dakana wonti.
\p 
\v 47 Jura jaurani nunkanani wata morlalu ngundranani, worderu jura jaurani ngakanani morlalu ngundrananto?“
\c 6
\lit (Ngantjani‐jaura Lätare ditjini.)
\p 
\v 1 Ngadani Jesus Galilaia ja Tiberias panto jerankaria pararana wonti.
\p 
\v 2 Ja kana wolara nunkangu karipaterina wonti, ngangau tanali tanana malka najina wonti, tana Nulu muntjani ngankana wonti.
\p 
\v 3 Ja Jesus mardawonpaia tarana wonti, ja naka Nau ngamana ngarina wonti nunkani milinto.
\p 
\v 4 Ja Passa, Juda kanaia ditji pirna, karakara nganana wonti.
\p 
\v 5 Jesus milkieli pariparina wonti ja najina wonti kana wolara nunkangu jurborinani, Nau Philippungu jatana wonti: „Wodajerindru ngaiana buka burungankananto tanali tajinanto?“
\p 
\v 6 Jenia Nau jatana wonti nina wontjana; ngangau Nau munta milkila nganana wonti, mina Nau jertapaterina wonti ngankala.
\p 
\v 7 Philippulu nunkangu kalabana wonti: „200 mardatandrali buka tanangu wata matja nganai, pilkipilki kulnujeli tanangundru windri ngalje maniati.“
\p 
\v 8 Mili kulno nunkani Andreas, Simon Petruni ngatata, nunkangu jatana wonti:
\p 
\v 9 „Kanku kulno ninkida nganai, nulia buka ngunku mara wora ja paru mandru ngamalkai; ja mina jenia tanangu marapuni!“
\p 
\v 10 Jesus jataua wonti: „Ngankanau kana wolara ngamana ngarinanto!“ Nunkangupini pirini kanta marapu nganana wonti. Ja kana 5000 ngamana ngarina wonti.
\p 
\v 11 Jesujeli buka patana wonti, ja Nulu jurakokana wonti, ja tanana milini jinkina wonti, ja milieli tanangu matja ngamana ngarina; jeruja bakana parundru, worderuntja tanali ngantjana wonti.
\p 
\v 12 Tana matja jerturina, Nau milini nunkanani jatana wonti: „Buka worduwordu kampanau, ngangau panila tintananto.“
\p 
\v 13 Tanali kampana wonti, ja billi marapratjana ja mandru buka worduwordujeli manamiri ngankana wonti buka ngunku mara worandru, tanana, tanali matja tajina, pinpana wonti.
\p 
\v 14 Kana worali nina malka, Jesujeli ngankanani matja najina, tana jatana wonti: „Naupini morlalu Nauja Propheta nganni, Nauja mitani wokarananto!“
\p 
\v 15 Jesujeli matja ngujamana, tana jertapaterinani wokarala ja nina patala ja nina mitaia kapara ngankala, Nau nakaldra mardawonpaia kutingana wonti kulnulu.
\p 
\v 16 Matja kalkaurarina, mili nunkani pantuja ngarina wonti,
\p 
\v 17 Ja tana botani wirina wonti ja ngapani Kapernaumia wapana wonti; ja matja ngalpuru ngananani, Jesus wata tanangu wokarana warai;
\p 
\v 18 Ja panto patijiritjina wonti, ngangau watara pirna ngakana wonti.
\p 
\v 19 Tana Statia 25 kara, 30 kara worita wapana, tanali Jesus najina wonti ngapani wapanani ja botani karakara wokaranani; ja tana japali pantjina wonti.
\p 
\v 20 Nau tanangu jatana wonti: „Nganimata Nauja, wata japali ngananau.“
\p 
\v 21 Tana jertapaterina wonti nina botaia manila, ja nurujeli bota dirkalaia pararana wonti, wodajeri tana jertapaterinani pararala.
\p 
\v 22 Ditji kulnuni, tanali kana wolarali panto dirkalani jerankari matja terkana, najina wonti, wata bota nguru naka nganala wiri, windri naupara kulnulu, ja Jesus wata milini nunkanani jela botani wirila wiri, a‐ai, windri mili nunkani pilki wapala wiri
\p 
\v 23 — Bota nguru wokarana warai Tiberiandru nunkangupini pirini karakara, wodajeri tanali buka tajila wiri Kaparaia jurakokanandru—;
\p 
\v 24 Kana worali najina, Jesus wata ninkida ngananani, bakana wata mili nunkani, tana bakana bota worani wirina wonti, ja Kapernaum ngurani wokarana wonti Jesus wontila.
\p 
\v 25 Ja tanali nina pantuni jerutajerra matja mankamankana tana nunkangu jatana wonti: „Rabbi, winta jidni ninkida wokarana warai?“
\p 
\v 26 Jesujeli tanangu kalabana wonti ja jatana wonti: „Morlalu, morlalu, ngani jurangu jatai: Jura ngana wata wontiai, ngangau jura malka najila wiri, a‐ai, ngangau tanangupini bukandru jura tajila wiri ja jerturila wiri.
\p 
\v 27 Wata jenipara buka ngankanau jenia mudai, a‐ai, jenipara buka, jenia tepi nguralini parala nganai, ninapini Kanaia Ngatamurajeli jurangu jinkila nganai; ngangau Ninapini Goda Ngaperali morlalu kurana wonti.“
\p 
\v 28 Tana nunkangu jatana wonti: „Mina ngaiani ngankananto Godaia ngankana ngankala?“
\p 
\v 29 Jesujeli kalabana wonti ja tanangu jatana wonti: „Naupini Godaia ngankana nganai: Jura nunkangu morlalu ngundrananto, ninapini Nulia jinpanala.“
\p 
\v 30 Tana nunkangu jatana wonti: „Mina malka jundru ngankai, ngaiani nina najinanto ja jinkangu morlalu ngundrananto? Mina jundru ngankai?
\p 
\v 31 Ngaianini ngaperi worali pitarani Manna tajina wonti, worderu dakanala parai: Buka pariwilpandru Nulia tanangu tajinanto jinkina wonti.“
\p 
\v 32 Jesus tanangu jatana wonti: „Morlalu, morlalu, ngani jurangu jatai: Wata Mosili jurangu buka pariwilpandru jinkina wonti, a‐ai, Ngaperali ngakanali jurangu buka morlalu pariwilpandru jinkiai.
\p 
\v 33 Ngangau Godaia buka Nauja nganai, Naupini pariwilpandru ngariai, ja mitalani tepi jinkiai.“
\p 
\v 34 Tana nunkangu jatana wonti: „Kaparajai, milingeru ngaianingu ninapini buka jinkiau!“
\p 
\v 35 Jesus tanangu jatana wonti: „Ngani tepia buka nganai; worana ngakangu wokarai nauja wata mauali pantjila nganai; ja warle ngakangu morlalu ngundrai, nauja wata morla tertieli pantjila nganai:
\p 
\v 36 Ngani jurangu jatana warai: Jura ngana najina warai ja wata morlalu ngundrai.
\p 
\v 37 Pratjana mina Ngaperali ngakanali ngakangu jinkiai, ngakangu wokarala nganai, ja worana ngakangu wokarai, ninapini ngato wata narrala nganai.
\p 
\v 38 Ngangau ngani pariwilpandru ngarina wonti wata ngakani jertapaterina ngankala, a‐ai, nunkani jertapaterina, Nulia ngana jinpanala.
\p 
\v 39 Jenia Ngaperaia jertapaterina nganai, Nulia ngana jinpanala: Ngato pratjanandru, mina Nulia ngakangu jinkinala, panila tintananto, a‐ai, ngato jenia ditjini ngadalani jiritjibananto.
\p 
\v 40 Ngangau jenia Ngaperaia ngakanaia jertapaterina nganai: Warle Ngatamura najiai, ja nunkangu morlalu ngundrai, tepi ngurali ngamalkananto; ja ngato nina ditjini ngadalani jiritjibala nganai.“
\p 
\v 41 Juda kana buljubuljurina wonti, ngangau Nau jatana warai: „Ngani jenipara buka nganai, Nau pariwilpandru matja ngarina.“
\p 
\v 42 Ja jatana wonti: „Naupini wata Jesus, Josephani ngatamura, nunkani ngaperi ja ngandri ngaiani ngujamai? Worderu Naupini jatai: Ngani pariwilpandru matja ngarina?“
\p 
\v 43 Jesujeli kalabana wonti ja tanangu jatana wonti: „Wata buljubuljurilkijiribamalianau.
\p 
\v 44 Wata kulno ngurunguru nganai ngakangu wokarala, Ngaperali ngakanali, Nulia ngana matja jinpana, nina wata parumanani; ja ngato nina ditjini ngadalani jiritjibala nganai.
\p 
\v 45 Propheta worani dakanala parai: Ja tana pratjana jenipara nganala nganai, tanali Godandru ngujangujara matja manina; warletanali Ngaperandru matja ngarana ja kirina, ngakangu wokarai.
\p 
\v 46 Wata kulnujeli Ngapina najina warai, a‐ai, windri Nulia, Nauja Ngaperandru nganai, Nulia Ngapina matja najina.
\p 
\v 47 Morlalu, morlalu, ngani jurangu jatai: Warle ngakangu morlalu ngundrai, nulu tepi ngurali ngamalkai.
\p 
\v 48 Ngani tepia buka nganai.
\p 
\v 49 Ngaperi worali juranali pitarani Manna tajina wonti ja palina wonti.
\p 
\v 50 Naupini buka, pariwilpandru matja ngarina, jenipara nganai, tanali nunkangundru tajinanto ja wata palinanto.
\p 
\v 51 Ngani tepia buka nganai, Naupini pariwilpandru matja ngarina; warle nunkangupini bukandru tajila nganai, nulu tepi ngamalkala nganai ngurali; Naupini buka, nina ngato jinkila nganai, ngani palku nganai, ninaia ngani jinkiterila nganai mitalaia tepini.“
\p 
\v 52 Juda kana jatamalina wonti ja jatana wonti: „Worderu Nulupini ngaianingu palku nunkani jinkila nganai tajinanto?“
\p 
\v 53 Jesus tanangu jatana wonti: „Morlalu, morlalu, ngani jurangu jatai: Jura wata Kanaia Ngatamuraia palku tajinani, ja kumari nunkani tapanani, jura wata tepi jurangu ngamalkanani.
\p 
\v 54 Warle ngana palku tajiai, ja ngana kumari tapai, nulu tepi ngurali ngamalkai, ja ngato nina ditjini ngadalani jiritjibala nganai.
\p 
\v 55 Ngangau ngani palku buka morlalu nganai, ja ngani kumari tapani morlalu.
\p 
\v 56 Warle ngana palku tajiai, ja ngana kumari tapai, nau ngakangu ngamai ja ngani nunkangu.
\p 
\v 57 Worderu ngana Ngaperi tepieli jinpanala, ja ngani Ngaperandru tepi nganai; jeruja bakana warle ngana tajiai, nau ngakangundru tepi ngamala nganai.
\p 
\v 58 Naupini jenipara buka nganai, Nauja pariwilpandru matja ngarina; wata jeruja worderu ngaperi worali juranali Manna tajina wonti ja palina wonti; warle ninapini buka tajiai, nau ngurali tepi ngamala nganai.“
\p 
\v 59 Tananapini Nau jatana wonti, Nulu Kapernaum jaura pungani ngujangujara jinkina.
\p 
\v 60 Mili nunkani marapujeli jenia matja ngarana, tana jatana wonti: „Naupini jaura ngurunguru nganai, worana ngurunguru nganai nina ngarala?“
\p 
\v 61 Jesujeli muntali matja ngujamana, mili nunkani jendrangundruja buljubuljurinani, Nau tanangu jatana wonti: „Jendrangundruja jura kintjakintjariai?
\p 
\v 62 Jura najinani Kanaia Ngatamura taranani, wodajeri Nauja ngopera nganana wonti?
\p 
\v 63 Jaola nganai, Nulia tepi ngankai, palku baku nganai; Tananapini jaura, ngato jurangu kaukaubana warai; Jaola ja Tepi tanapini nganai.
\p 
\v 64 Ja palpa jurangundru nganai, tanali wata morlalu ngundrai.“ Ngangau Jesus ngoperandru milkila nganana wonti, warletana nganai, tanali wata morlalu ngundrai, ja warle nina wontawontala nganai.
\p 
\v 65 Ja Nau jatana wonti: „Jendrangundruja ngani jurangu jatana warai: Wata kulno ngurunguru nganai ngakangu wokarala, nunkangu ngopera wata jinkinala Ngaperandru.“
\p 
\v 66 Jendrangundruja mili nunkani marapu tikana wonti, ja wata morla nunkangunto wirarina wonti.
\p 
\v 67 Jesus marapratjana ja mandruni jatana wonti: „Jura bakana jertapateriai ngakangundru wapana kurala?“
\p 
\v 68 Simon Petrulu nunkangu kalabana wonti: „Kaparajai, worangula ngaiani wapananto? Jundru tepi nguralia jaura ngamalkai,
\p 
\v 69 Ja ngaiani morlalu ngundrana warai ja ngujamana warai, jidni Christus Goda tepia Ngatamura nganai.“
\p 
\v 70 Jesujeli tanangu kalabana wonti: „Wata ngato jurana marapratjana ja mandru ngakani kalkalkana wonti? Ja kulno jurangundru kutji nganai.“
\p 
\v 71 Nulu Judas Ischariot Simoni ngatamura ngundrana wonti, ngangau nulupini nina wontawontananto, ja nau marapratjana ja mandrundru kulno nganana wonti.
\c 7
\p 
\v 1 Ja ngadani Jesus Galilaiani wirarina wonti; ngangau Nulu wata ngantjana wonti Judaiani wirarila, ngangau Juda kanali nina wontina wonti naria nandrala.
\p 
\v 2 Juda kanaia pungawalpaia ditji pirna karakara nganana wonti.
\p 
\v 3 Tana ngatata nunkani nunkangu jatana wonti: „Ninkidandru puntiau ja Judaiaia wapau, ngangau bakana milieli jinkanali ngankana jinkani najinanto, tananaia jundru ngankai.
\p 
\v 4 Ngangau wata kulnujeli kurukuru ngankai, ja wontiteriai tinkari pantjinanto. Jundru jenia ngankanani mitalani wondrateriau.“
\p 
\v 5 Ngangau bakana ngatatajeli nunkanali nunkangu wata morlalu ngundrana wonti.
\p 
\v 6 Jesus tanangu jatana wonti: „Miljaru ngakani wata wokarana warai, ditji jurani milingeru nganai.
\p 
\v 7 Mitala ngandandariai jurangu kalakalarila; ngakangu tana kalakalariai, ngangau ngato tanangundru jaura morlalu kurai, ngankana tanani madlentji nganai.“
\p 
\v 8 Jura nunkangupini ditji pirnaia taranau; ngani wata nunkangupini ditji pirnaia tarai, ngangau miljaru ngakani wata kantji wokarana warai.
\p 
\v 9 Nau tananapini tanangu matja jatana, Nau Galilaiani ngamantina wonti.
\p 
\v 10 Ngatata nunkani matja tarana, ngadani Nau bakana ditji pirnaia tarana wonti, wata kantji, a‐ai, kurukuru jeri.
\p 
\v 11 Juda kanali nina wontina wonti ditji pirnani ja jatana wonti: „Wodajeri Nau?“
\p 
\v 12 Kana wolara marapujeli nunkangundru buljubuljurilkijiribamalina wonti. Palpa jatana wonti: „Nau ngumu nganai;“ palpa jatana wonti: „Pani, Nulu kana wolara karkarkai.“
\p 
\v 13 Wata kulno nunkangundru tinkari jatana wonti, ngangau tana Juda kanandru japali nganana wonti.
\p 
\v 14 Ditji pirna worani terti Jesus Godaia pungani tarana wonti ja ngujangujara jinkina wonti.
\p 
\v 15 Ja Juda kana ngaruparana wonti ja jatana wonti: „Worderu Nulupini jauraia kirila ngujamai, wata Nauja ninaia kirina warai?“
\p 
\v 16 Jesujeli tanangu kalabana wonti ja jatana wonti: „Ngakani ngujangujara wata ngakani nganai, a‐ai, nunkani, Nulia ngana jinpanala.
\p 
\v 17 Kulnujeli ngantjanani nunkani jertapaterina ngankala, nulupini ngujamala nganai, naupini ngujangujara Godandru ngananani kara, ngato ngakangundru muntali kaukaubanani kara.
\p 
\v 18 Warle nunkangundru muntali kaukaubai, nulu pirnala nunkani wontiai; warle nunkanipini pirnala wontiai, Nulia ninaia jinpanala, Nauja morlalu nganai, ja madlentji wata nunkangu nganai.
\p 
\v 19 Wata Mosili jurangu jirijiribani jaura jinkina wonti? Ja wata kulnujeli jurangundru jirijiribani jaurani pankiai; Minandru jura wontiai ngana naria nandrala?“
\p 
\v 20 Kana wolarali kalabana wonti ja jatana wonti: „Jundru kutji ngamalkai; warle wontiai, jidna naria nandrala?“
\p 
\v 21 Jesujeli kalabana wonti ja tanangu jatana wonti: „Ngankana kulno ngato ngankana warai, ja jura pratjana ngaruparai.
\p 
\v 22 Jendrangundruja, ngangau Mosili jurangu kaluwali ngankani jinkina wonti, — nau wata Mosingundru, a‐ai, ngaperi worandru — jura bakana Sabbatani karuwali ngankai.
\p 
\v 23 Kana kulnujeli karuwali ngankala Sabbatani maninani, ngangau Mosini jirijiribani jaura wata wokaribananto; ngakangu jura tiririai, ngangau ngato kana kulno tepi ngankana warai Sabbatani?
\p 
\v 24 Wata kalala kuranau milkieli najinandru, a‐ai, kalala talku kuranau?“
\p 
\v 25 Jerusalemala palpa jatana wonti: „Wata Naupini Nauja nganai, ninaia tanali wontiai naria nandrala?
\p 
\v 26 Ja mai, Nulia tinkari kaukaubai, ja tana nunkangu panila jatai. Kana kaparali morlalu ngujamana warai, Naupini Christus nganai?
\p 
\v 27 Ninapini ngaiani ngujamai wodajerindru Nauja nganai; Christus wokaranani, wata kulnujeli ngujamala nganai, wodajerindru Nau nganai.“
\p 
\v 28 Jendranguta Jesus Godaia pungani parparali maritjina wonti ja ngujangujara jinkina wonti ja jatana wonti: „Kau, jura ngana ngujamai, ja bakana milkila wodajerindru ngani nganai; ja ngani wata ngakangundru munta wokarana wonti, a‐ai, Naupini morlalu nganai, Nulia ngana jinpanala, ninapini jura wata ngujamai:
\p 
\v 29 Ngato ninaia ngujamai; ngangau ngani nunkangundru nganai, ja Nulia ngana jinpanala.“
\p 
\v 30 Tanali wontina wonti nina patala, ja wata kulnujeli mara nunkangu kurana wonti; ngangau ditji nunkani wata kantji wokarana warai.
\p 
\v 31 Marapujeli kana wolarandru nunkangu morlalu ngundrana wonti ja jatana wonti: „Christus wokaranani, Nulu morla malka ngankala nganai, Nulupini matja ngankana warai?“
\p 
\v 32 Pharisaiali ngarana wonti kana wolarali jenia nunkangundru buljubuljurilkijiribamalinani. Ja Priesta pirnali ja Pharisaiali mili jinpana wonti nina patananto.
\p 
\v 33 Jesus tanangu jatana wonti: „Windri miljaru wordu morla ngani jurangunto nganai, ja ngani nunkangu wapala nganai, Nulia ngana jinpanala.
\p 
\v 34 Jura ngana wontila nganai ja wata mankamankala nganai; ja wodajeri ngani nganai, nakani jura ngandandariai wokarala.“
\p 
\v 35 Juda kana ngankamalina wonti: „Wodajeri Nulupini ngantjai palkala, ngangau ngaiani ninaia wata mankamankananto? Nulia ngantjai Griekani wapala, tana tjautjau ngamai, Griekani ngujangujara jinkila?
\p 
\v 36 Mina nulupini jaurali wondrai, ninapini Nauja jatana warai: Jura ngana wontila nganai ja wata mankamankala nganai; ja: Wodajeri ngani nganai, nakani jura ngandandariai wokarala?“
\p 
\v 37 Ditji pirnaia mudani ditjini, nau morla pirna nganana wonti, Jesus terkana wonti ja maritjina wonti ja jatana wonti: „Worana tertieli nganai, nau ngakangu wokaraiatimai ja tapaiatimai!
\p 
\v 38 Warle ngakangu morlalu ngundrai, worderu jaura jatai: Nunkani palkundru tepia ngapa kaiari ngakala nganai.“
\p 
\v 39 Jenia Nau Jaolandru jatana wonti, nina tanali maninanto, tana nunkangu morlalu ngundrai; ngangau jendranguta Jaola kulikiri wata kantji wokarana wonti, ngangau Jesus wata pirnala nunkani manina wonti.
\p 
\v 40 Kana wolarandru marapu, tanali tananapini jaura matja ngarana, jatana wonti: „Naupini morlalu Naupara Propheta nganai!“
\p 
\v 41 Palpa jatana wonti: „Naupini Christus nganai;“ palpa jatana wonti: „Wata Galilaiandru Christus wokarai?
\p 
\v 42 Wata Godaia jaura jatai: Davidani ngatamurandru, ja Bethlehem ngura wakandru, wodajeri David nganana wonti, Christus wokarala nganai?“
\p 
\v 43 Jeruja kana wolara tidatida ngankijiribamalina wonti nunkangundru.
\p 
\v 44 Palpali tanangundru ngantjana wonti nina patala, ja wata kulnujeli mara nunkangu kurana wonti.
\p 
\v 45 Mili Priesta pirnani ja Pharisaiani wokarana wonti, ja tana tanangu jatana wonti: „Minandru jura nina wata padakana warai?“
\p 
\v 46 Milieli kalabana wonti: „Wata pota kulno kana kulnujeli kaukaubana warai, Nulupini kanali jeribaka.“
\p 
\v 47 Pharisaiali tanangu kalabana wonti: „Nulu jurana bakana karkarkana warai?
\p 
\v 48 Kapara kulnujeli kara Pharisaia kulnujeli kara nunkangu morlalu ngundrai?
\p 
\v 49 A‐ai, windri tanapini kana wolara, tanali jirijiribani jaura wata ngujamai; jakajai tanangu.“
\p 
\v 50 Nikodemus tanangu jatana wonti, nau tinkani nunkangu wokarana paraia, ja kulno tanangundru nganana wonti:
\p 
\v 51 „Ngaianani jirijiribani jaurali wata kana kulnuni kalala kurai, nina wata ngopera ngaranani ja ngujamanani mina nulu ngankai?“
\p 
\v 52 Tanali kalabana wonti ja nunkangu jatana wonti: „Jidni bakana Galilaiala nganai? Wontjamai ja najiamai, Galilaiandru wata Propheta terkakala nganai.“
\p 
\v 53 Ja pratjana pungaia tananaia wapana wonti.
\c 8
\p 
\v 1 Jesus maninindri mardawonpaia wapana wonti.
\p 
\v 2 Dankudankubana Nau nakaldra Godaia pungani wokarana wonti, ja kana wolara nunkangu wokarana wonti, ja Nau ngamana ngarina wonti ja tanangu ngujangujara jinkina wonti.
\p 
\v 3 Jaura jinkinietjali ja Pharisaiali widla kulno nunkangu wapalkana wonti, tanali nana pinta wokaribanani matja patana, ja nana terti terkibana wonti,
\p 
\v 4 Ja nunkangu jatana wonti: „Ngujangujara jinkinietjajai, nanapini widla tanali patana warai morlalu pinta wokaribanani.
\p 
\v 5 Mosili jirijiribani jaurani ngaianingu jirijiribana wonti, jenipara mardali dakananto, mina jidni jatai?“
\p 
\v 6 Jenia tana nunkangu jatana wonti nina wontjala, ngangau tanali palpa ngamalkananto nunkangundru ngulkuterkala. Jesus buruna ngarina wonti ja marawutjujeli mitani dakana wonti.
\p 
\v 7 Ngangau tana nina milingeru jakalkanani, Nau miririna tarana wonti ja tanangu jatana wonti: „Warle jurangundru madlentji pani ngani, nulia marda ngoperalali nanaia dakananto.“
\p 
\v 8 Ja nakaldra Nau buruna ngarina wonti ja mitani dakana wonti.
\p 
\v 9 Tanali jenia matja ngarana, burka tanangu ngulkuterkana wonti, ja tana dunkana wonti kulnulu kulnulu, pinarandru wonina nakajelu; ja Jesus kulnulu ngamana wonti, ja widla terti terkantinani.
\p 
\v 10 Jesus miririna tarana wonti, ja ngangau Nulu wata kulno najina wonti windri nana widla, Nau nankangu jatana wonti: „Widlajai, woderi jinkani tana ngulkuterkanietja? Wata kulnujeli jinkangu kalala jinkina warai?“
\p 
\v 11 Nani jatana wonti: „Wata kulnujeli Kaparajai!“ Jesus nankangu jatana wonti: „Jeruja bakana ngato jinkangu wata kalala kurala nganai; wapau, ja wata morla madlentji ngankau!“
\p 
\v 12 Nakaldra Jesujeli tanangu kaukaubana wonti ja jatana wonti: „Ngani mitaia praitji nganai; worana ngakangu karipaterila nganai, nau wata ngalpurani wirarila nganai, a‐ai, nulu tepia praitji ngamalkala nganai.“
\p 
\v 13 Pharisaia nunkangu jatana wonti: „Jidni jinkangundru munta tinkari ngankateriai; tinkari ngankani jinkani wata morlalu nganai.“
\p 
\v 14 Jesujeli kalabana wonti ja tanangu jatana wonti: „Bakana ngato ngakangundru muntali tinkari ngankanani, tinkari ngankani ngakani morlalu nganai, ngangau ngani milkila wodajerindru ngani wokarana wonti ja wodajeri ngani wapala nganai; jura wata milkila wodajerindru ngani wokarai ja wodajeri ngani wapai.
\p 
\v 15 Jura palkundru kalala kurai: ngato wata kulnuni kalala kurai.
\p 
\v 16 Ja ngato bakana kalala kuranani, kalala kurani ngakani morlalu ngangai; ngangau ngani wata kulnulu nganai, a‐ai, ngani ja Ngaperi Nulia ngana jinpanala.
\p 
\v 17 Ja bakana jurani jirijiribani jaurani dakanala parai: Kana mandruja tinkari ngankani morlalu nganai.
\p 
\v 18 Ngato ngakangundru muntali tinkari ngankai, ja Ngaperali, Nulia ngana jinpanala, ngakangundru tinkari ngankai.“
\p 
\v 19 Tana nunkangu jatana wonti: „Woderi Ngaperi jinkani nganai?“ Jesujeli kalabana wonti: „Jura wata ngana ja wata Ngaperi ngakani ngujamai; jura ngana ngujamanani, jura bakana Ngaperi ngakani ngujamanani.“
\p 
\v 20 Tananapini jaura Jesujeli mardatandra kokuni karakara jatana wonti, Nulu Godaia pungani ngujangujara jinkinani; ja wata kulnujeli nina patana wonti, ngangau ditji nunkani wata kantji wokarana warai.
\p 
\v 21 Jesus nakaldra tanangu jatana wonti: „Ngani wapai, ja jura ngana wontila nganai, ja madlentjani juranani jura palila nganai; wodajeri ngani wapai, naka jura ngandandariai wokarala.“
\p 
\v 22 Juda kana jatana wonti: „Nulia ngantjai kara munta nari ngankaterila, ngangau Nau jatai: Wodajeri ngani wapai, naka jura ngandandariai wokarala?“
\p 
\v 23 Ja Nau tanangu jatana wonti: „Jura ngarinalundru nganai, ngani mirindru nganai; jura nunkangupini mitandru nganai, ngani wata nunkangupini mitandru nganai.
\p 
\v 24 Ngani jurangu matja jatana warai, jura madlentjani juranani palila nganai; ngangau jura wata morlalu ngundranani ngani Nauja nganai, jura madlentjani juranani palila nganai.“
\p 
\v 25 Tana nunkangu jatana wonti: „Worana jidni nganai?“ Ja Jesus tanangu jatana wonti: „Ngopera jenia, mina ngani jurangu jatai.
\p 
\v 26 Marapu ngato ngamalkai jurangundru jatala ja kalala kurala; ja Nauja, Nulia ngana jinpanala, morlalu nganai, ja mina ngato nunkangundru ngarana wonti, jena ngato mitalani kaukaubai.“
\p 
\v 27 Tanali wata ngujamana wonti, Nau tanangu Ngaperandru jatanani.
\p 
\v 28 Jesus tanangu jatana wonti: „Jura Kanaia Ngatamura matja miri ngankana warai, ngadani jura ngujamala nganai ngani Nauja nganai, ja ngato muntali panila ngankai, a‐ai, worderu Ngaperali ngakangu ngujangujara jinkina wonti, jenia ngato kaukaubai.
\p 
\v 29 Ja Nulia ngana jinpanala, Naupini ngakangunto nganai; ja Ngaperali ngana wata kulnulu worarai, ngangau ngato milingeru ngankai, mina Nulia ngantjai.“
\p 
\v 30 Nulu jenia kaukaubanani, marapujeli nunkangu morlalu ngundrana wonti.
\p 
\v 31 Jesus tanangu Juda kanani, tanali nunkangu morlalu ngundranani, jatana wonti: „Jura jaurani ngakanani wonki ngamanani, jura morlalu mili ngakani ngananani,
\p 
\v 32 Ja jura morlaluta ngujamala nganai, ja morlalulali jurana kurakala nganai.“
\p 
\v 33 Tanali nunkangu kalabana wonti: „Abrahamani ngatamura ngaiani nganai, ja wata pota kulno ngaiani kulnuja mili nganana wonti; worderu jidni jatai: «Jura kurakanila pantjinanto?»“
\p 
\v 34 Jesujeli tanangu kalabana wonti: „Morlalu, morlalu, ngani jurangu jatai: Warle madlentji ngankai, nau madlentjaia mili nganai.
\p 
\v 35 Mili wata ngurali pungani ngamai; Ngatamura ngurali ngamai.
\p 
\v 36 Ngatamurajeli jurana kurakanani, jura kantji kurakanila nganala nganai.
\p 
\v 37 Ngani milkila jura Abrahamani ngatamura nganai; ja jura wontiai ngana naria nandrala, ngangau jaura ngakani wata jurangu wiriai.
\p 
\v 38 Ngato kaukaubai, mina ngato Ngaperani ngakanani najina wonti; ja jura ngankai, mina jura ngaperani juranani najina warai.“
\p 
\v 39 Tanali nunkangu kalabana wonti ja jatana wonti: „Ngaperi ngaianini Abraham nganai.“ Jesus tanangu jatana wonti: „Jura Abrahamani kupa ngananani, jura bakana Abrahamani ngankana ngankananto.
\p 
\v 40 Karari jura ngana wontiai naria nandrala, jenipara kana Nulia jurangu morlalu kaukaubana warai, nina ngato Godandru ngarana wonti; jenia Abrahamali wata ngankana wonti.
\p 
\v 41 Jura ngaperaia juranaia ngankani ngankai.“ Tana nunkangu jatana wonti: „Ngaiani wata palakantjindru dankana wonti; Ngaperi kulno ngaiani ngamalkai, ninaia Goda.“
\p 
\v 42 Jesus tanangu jatana wonti: „Goda Ngaperi jurani ngananani, jura ngana ngantjanani; ngangau ngani Godandru dunkana wonti ja wokarana wonti, ngangau bakana ngani wata munta wokarana wonti, a‐ai, Nulia ngana jinpanala.
\p 
\v 43 Minandru jura jaura ngakani wata ngujamai? Ngangau jura ngandandariai jaura ngakani ngarala.
\p 
\v 44 Jura ngaperi kutjindru nganai, ja ngaperaia juranaia jertapaterina jura jertapateriai ngankala. Naupini kananandranietja ngoperandru nganana wonti, ja morlalulani nau wata terkai, ngangau morlalula wata nunkangu nganai. Nau jedi jatanani, nulu nunkangundru munta jatai, ngangau nau jedikantji nganai ja nunkanipini ngaperi.
\p 
\v 45 Ngangau ngani jurangu jatai, jura ngakangu wata morlalu ngundrai.
\lit (Ngantjani‐jaura Judica ditjini.)
\p 
\v 46 Warle jurangundru ngakangu madlentji kulno wondrai? Ngani morlaluta jatanani, minandru jura ngakangu wata morlalu ngundrai?
\p 
\v 47 Worana Godandru nganai, nulu Godaia jaura ngarai; jendrangundruja jura wata ngarai, ngangau jura wata Godandru nganai.“
\p 
\v 48 Juda kanali kalabana wonti ja nunkangu jatana wonti: „Ngaiani wata talku jatai, jidni Samarita kana nganai ja kutji ngamalkai?“
\p 
\v 49 Jesujeli kalabana wonti: „Ngato wata kutji ngamalkai, a‐ai, ngato Ngaperi ngakani pirna ngundrai, ja jura ngana wata pirna ngundrai.
\p 
\v 50 Ngato wata pirnala ngakani wontiai; Kulno nganai, Nulupini ninaia wontiai ja kalala kurai.
\p 
\v 51 Morlalu, morlalu, ngani jurangu jatai: Kulnujeli jaura ngakani ngamalkanani, nulu ngurali wata nari najila nganai.“
\p 
\v 52 Juda kana nunkangu jatana wonti: „Karari ngaiani ngujamai, jundru kutji ngamalkai; Abraham ja Propheta palina wonti, ja jidni jatai: Kulnujeli jaura ngakani ngamalkanani, nulu ngurali wata nari najila nganai.
\p 
\v 53 Jidni morla pirna nganai ngaianini ngaperani Abrahamangu, nau palina wonti? Ja Propheta wora palina wonti; worana jidni munta ngankateriai?“
\p 
\v 54 Jesujeli kalabana wonti: „Ngani munta pirna ngankaterinani pirnala ngakani pani nganai; Ngaperali ngakanali ngana pirna ngankai, nunkangundru jura jatai, Nauja Goda jurani nganai.
\p 
\v 55 Ja jura ninaia wata ngujamana warai; ngato ninaia ngujamai; ja ngani jatanani, ngato ninaia wata ngujamai, ngani jedikantji nganala nganai jurangu jeribaka; ngato ninaia ngujamai, ja jaura nunkani ngato ngamalkai.
\p 
\v 56 Abraham ngaperi jurani murlali pantjina wonti ditji ngakani najila; ja nulu nina najina wonti ja mankina wonti.“
\p 
\v 57 Juda kana nunkangu jatana wonti: „Jidni wata kilpawoldra 50 nganai? Ja jundru Abraham najina wonti.“
\p 
\v 58 Jesus tanangu jatana wonti: „Morlalu, morlalu, ngani jurangu jatai: Morla ngopera Abrahamangu ngani nganana wonti.“
\p 
\v 59 Tanali marda patana wonti nina dakananto. Jesus kurukurumalkaterina wonti ja Godaia pungandru dunkana wonti, tanangu terti palkingana tarana.
\b
\c 9
\p 
\v 1 Ja Nau wiringanani, Nulu kana kulno najina wonti, nau butju nganana wonti kupandru.
\p 
\v 2 Ja milieli nunkanali nina jakalkana wonti ja jatana wonti: „Rabbi, warle madlentji ngankana wonti, nulupini kara, ngaperali ja ngandrieli nunkanali kara, ngangau nauja butju dankana wonti.“
\p 
\v 3 Jesujeli kalabana wonti: „Wata nulupini madlentji ngankana wonti, bakana wata ngaperali ja ngandrieli nunkanali, a‐ai, Godaia ngankana nunkangu wondraterinanto.
\p 
\v 4 Ngato nunkanipini ngankani ngankananto, Nulia ngana jinpanala, jeruntja ditjiwirdi ngananani; tinka wokarala nganai, nunkangupini kana warupoto ngandandarila nganai ngankala.
\p 
\v 5 Wintaranaia ngani mitani nganai, ngani mitaia praitji nganai.“
\p 
\v 6 Nau jenia matja jatana, Nulu mitani ngaltja worana wonti ja ngaltjandru buluru ngankingana wonti, ja nina buluru butjuni milkini kurana wonti,
\p 
\v 7 Ja nunkangu jatana wonti: „Wapau, ja Siloa pantuni kulirkateriau!“ Jenia wondrai: „Matja jinpana.“ Nau wapana wonti ja kulirkaterina wonti ja najila tikana wonti.
\p 
\v 8 Jenimalinietja, ja tana nina ngopera najina wonti potuni ngatjinani, jatana wonti: „Wata naupini nauja nganai, nauja ngamana warai potuni ngatjila?“
\p 
\v 9 Palpa jatana wonti: „Nauja naumata nganai;“ palpa: „Nauja nunkangu jeribaka;“ nau munta jatana wonti: „Ngani nauja nganai.“
\p 
\v 10 Tana nunkangu jatana wonti: „Worderu milki jinkani piririna warai?“
\p 
\v 11 Nulu kalabana wonti ja jatana wonti: „Kana kulnujeli, tala nunkani Jesus, buluru ngankingana warai ja nina ngakangu milkini kurana warai ja ngakangu jatana warai: Siloah pantuja wapau ja kulirkateriau. Ngani wapana warai ja kulirkaterina warai ja kantji najina warai.“
\p 
\v 12 Tana nunkangu jatana wonti: „Woderi Naupara nganai?“ Nau jatana wonti: „Nganako.“
\p 
\v 13 Tanali nina, nau ngopera butju nganana warai, Pharisaiaia wapalkana wonti.
\p 
\v 14 Jendranguta Sabbat nganana wonti, Jesujeli nina buluru ngankinganani ja milki nunkani piri ngankanani.
\p 
\v 15 Nakaldra nina bakana Pharisaiali jakalkana wonti, worderu nulu nakaldra najina warai. Nau tanangu jatana wonti: „Buluru Nulu ngakangu milkini kurana warai, ja ngani kulirkaterina warai, ja ngato kantji najiai.“
\p 
\v 16 Pharisaia palpa jatana wonti: „Naupini kana wata Godandru nganai, ngangau Nulu Sabbat wata kulikiri ngamalkai.“ Palpa jatana wonti: „Worderu kana madlentji ngurungunu nganai jenia malka ngankala?“ Ja tana tidatida ngankijiribamalina wonti.
\p 
\v 17 Nakaldra tana butjuni jatana wonti: „Mina jidni nunkangundru jatai, ngangau Nulu milki jinkani piri ngankana warai?“ Nau jatana wonti: „Nau Propheta nganai.“
\p 
\v 18 Juda kanali nunkangu, nau butju nganana warai ja nakaldra najina warai, wata morlalu ngundrana wonti, tanali nunkanipini, nulu nakaldra najina warai, ngaperi ja ngandri karkanantulu.
\p 
\v 19 Ja tanali pudlana jakalkana wonti ja jatana wonti: „Naupini judlani kupa nganai, nunkangundru judla jatai, nau butju dankanala? Worderu jenia pantjina warai, ngangau nulia karari najiai?“
\p 
\v 20 Ngaperali ja ngandrieli nunkanali tanangu kalabana wonti ja jatana wonti: „Ngali milkila, naupini ngalini kupa nganai, ja nauja butju dankanala;
\p 
\v 21 Worderu nulia karari kantji najiai ngali ko; warle milki nunkani piri ngankana warai, ngali ko; nauja munta pirna nganai, ninaia munta jakalkanau, nauja nunkangundru muntali kalabananto.“
\p 
\v 22 Jenia ngaperi ja ngandri nunkani jatana wonti, ngangau pudla Juda kanandru japali nganana wonti; ngangau Juda kana kulnukulnuni nganana wonti, warle nina Christus dikanani, nina tanali Godaia milindru worala nganai.
\p 
\v 23 Jendrangundruja ngaperi ja ngandri nunkani jatana wonti: „Nauja munta pirna nganai, ninaia munta jakalkanau.“
\p 
\v 24 Tanali nina kana, nau butju nganana warai, nakaldra pota mandrula karkana wonti ja nunkangu jatana wonti: „Godani pirna ngundrau!“ ngaiani milkila, Naupini kana madlentji nganai.
\p 
\v 25 Nulu kalabana wonti ja jatana wonti: „Nau kana madlentji nganai kara, ngani ko; kulno ngato milkila, ngani butju nganana warai ja karari nakaldra najiai.“
\p 
\v 26 Tana nakaldra nunkangu jatana wonti: „Mina Nulu jinkangu ngankana warai? Worderu Nulu milki jinkani piri ngankana warai?“
\p 
\v 27 Nulu tanangu kalabana wonti: „Ngani jurangu matja jatana warai ja jura bulu ngarana warai. Minandru jura jenia nakaldra ngarananto? Jura bakana ngantjai mili nunkani pantjila?“
\p 
\v 28 Tana nunkangu kaldririna wonti ja jatana wonti: „Jidni mili nunkani nganai, ngaiani Mosini mili nganai.
\p 
\v 29 Ngaiani milkila, Godali Mosingu kaukaubana wonti; nunkangundru ngaiani ko nganai, wodajerindru Nau nganai.“
\p 
\v 30 Nulupini kanali tanangu kalabana wonti ja jatana wonti: „Jenia ngaruparana nganai, ngangau jura ko wodajerindru Nau nganai, ja Nulu milki ngakani piri ngankana warai.
\p 
\v 31 Ngaiani milkila, Godali kana madlentji wata ngarai, a‐ai, kulno Godandru japali ngananani ja jertapaterina nunkani ngankanani, nina Nulia ngarai.
\p 
\v 32 Nguralindru (tanali) wata ngarana wonti, kulnujeli kana butjuja milki, nau butju dankanala, piri ngankana wonti.
\p 
\v 33 Naupini wata Godandru ngananani, Nau ngandandarinani jenia ngankala.“
\p 
\v 34 Tanali kalabana wonti ja nunkangu jatana wonti: „Madlentjani jidni dankanala, ja jundru ngaianingu ngujangujara jinkiai?“ Ja tanali nina tertubana wonti palaraia.
\p 
\v 35 Jesujeli matja ngarana, tanali nina narrana warai, ja Nulu nina matja mankamankana, Nau nunkangu jatana wonti: „Jundru Godaia Ngatamurani morlalu ngundrai?“
\p 
\v 36 Nulu kalabana wonti ja jatana wonti: „Worana Nau nganai, Kaparajai, ngato nunkangu morlalu ngundrananto?“
\p 
\v 37 Jesus nunkangu jatana wonti: „Jundru nina najina warai, ja Nulia jinkangu ngankamalila wapaia, Naumata Nauja nganai.“
\p 
\v 38 Nau jatana wonti: „Kaparajai, ngato morlalu ngundrai;“ ja nau nunkangu pantjaterkana ngarina wonti.
\p 
\v 39 Ja Jesus jatana wonti: „Ngani nunkangupini mitani wokaranala puntibala; ngangau tanali wata najiai najinanto, ja tanali najiai butjurinanto.“
\p 
\v 40 Ja jenia Pharisaia palpali, tana nunkangunto ngananani, ngarana wonti ja nunkangu jatana wonti: „Ngaiani bakana butju nganai kara?“
\p 
\v 41 Jesus tanangu jatana wonti: „Jura butju ngananani, jura wata madlentji ngamalkanani; karari jura jatai: Ngaiani najiai; jeruja madlentji jurani parala nganai.“
\c 10
\lit (Ngantjani‐jaura Jaolaia ditji parkulani.)
\p 
\v 1 Morlalu, morlalu, ngani jurangu jatai: „Warle wata manani wiriai tjipi jaruni, a‐ai, pilki dankaranani, nau kurikantji ja watawatali maninietja nganai.
\p 
\v 2 Warle manani wiriai, nau ngamalkanietja nganai tjipia.
\p 
\v 3 Nunkangupini mana ngamalkanietjali mana walto ngankai, ja tjipieli ngaiala nunkani ngarai, ja nulu tjipi nunkani tala karkai, ja tanana dunkalkai.
\p 
\v 4 Ja nulu tjipi nunkani dunkalkanani, nau tanangu ngopera wapai, ja tjipi nunkangu karipateriai, ngangau tanali ngaiala nunkani ngujamai.
\p 
\v 5 Tulani tana wata karipaterila nganai, a‐ai, nunkangundru japa mindrila nganai; ngangau tulaia ngaiala tanali wata ngujamai.“
\p 
\v 6 Ninapini jeribaka jaura Jesus tanangu jatana wonti; ja tanali wata ngujamana wonti mina jenia wondrai, Nau tanangu matja jatana.
\p 
\v 7 Jesus nakaldra tanangu jatana wonti: „Morlalu, morlalu, ngani jurangu jatai: Ngani mana nganai tjipia.
\p 
\v 8 Worderuntja pratjana ngakangu ngopera wokaranala kurikantji ja watawatali maninietja nganai; ja tjipieli tanana wata ngarai.
\p 
\v 9 Ngani mana nganai: kulno ngakangu wirinani, nulu kulkani ngamalkala nganai, ja nau wirila nganai ja dunkala nganai ja kuljakulja mankamankala nganai.
\p 
\v 10 Kurikantji windri wokarai kurieli manila naria nandrala ja teribala. Ngani wokaranala, tanali tepi ja poto pirna ngamalkananto.
\b
\lit (Ngantjani‐jaura Misericordias Domini ditjini.)
\p 
\v 11 Ngani Ngamalkanietja ngumu nganai. Nauja Ngamalkanietja ngumu tepi nunkani jinkiteriai tjipini.
\p 
\v 12 Nau ngamalkanietja kalalaia, nau wata ngamalkanietja nganai, ja tjipi wata nunkani nganai, nulupini pandipandi wokaranani najinani, nulu tjipi worarai ja japa mindriai, ja pandipandieli tanana patai, ja tjipi piltjaru ngankai.
\p 
\v 13 Ngamalkanietja kalalaia japa mindriai, ngangau nau ngamalkanietja kalalaia nganai, ja ngangau nulu tjipi wata ngundrai.
\p 
\v 14 Ngani Nauja ngamalkanietja ngumu nganai, ja tanana ngakani ngato ngujamai, ja tanali ngakanali ngana ngujamai.
\p 
\v 15 Worderu Ngaperali ngana ngujamai, ja ngato Ngaperi ngujamai; ja ngani tepi ngani jinkiteriai tjipini.
\p 
\v 16 Ja ngato tjipi pilki ngamalkai, tana wata nunkangupini jarundru nganai; bakana tanana ngato wokaralkananto, ja tanali ngaiala ngakani ngarala nganai, ja ngami kulno ja ngamalkanietja kulno pantjila nganai.
\b
\p 
\v 17 Jendrangundruja Ngaperali ngakanali ngana ngantjai, ngangau ngani tepi ngakani jinkiteriai, ninaia nakaldra manila.
\p 
\v 18 Wata kulnujeli ninaia ngakangundru maniai, a‐ai, ngani munta ninaia jinkiteriai. Ngato ngurula ngamalkai ninaia jinkiterila, ja ngato ngurula ngamalkai ninaia nakaldra manila: Ninapini jirijiribani jaura ngato ngakani Ngaperandru maninala.“
\p 
\v 19 Juda kana nakaldra tidatida ngankijiribamalina wonti nunkangupini jaurandru.
\p 
\v 20 Palpa tanangundru jatana wonti: „Nulia kutji ngamalkai, ja jirijiri nganai; minandru jura ninaia ngarai?“
\p 
\v 21 Palpa jatana wonti: „Jenia wata kana kutjintaia jaura nganai; kutji ngurunguru nganai butjuja milki piri ngankala?“
\p 
\v 22 Godaia pungaia kulikiri ngankani ditji Jerusalemingu nganana wonti; ja kilpani nganana wonti.
\p 
\v 23 Ja Jesus Godaia pungani Salomonani pirini wirarina wonti.
\p 
\v 24 Juda kanali nina kapikapina wonti ja nunkangu jatana wonti: „Wintaranaia jundru ngaianina mungara ngandrawalkai? Jidni Christus ngananani ngaianingu talku jatamai!“
\p 
\v 25 Jesujeli tanangu kalabana wonti: „Ngani jenia jurangu jatana warai, ja jura wata morlalu ngundrai; tananaia ngankana, tananaia ngato ngankai Ngaperaia ngakanaia talani, tanalia ngakangundru tinkari ngankai.
\p 
\v 26 Windri jura wata morlalu ngundrai, ngangau jura wata tjipi ngakani nganai, worderu ngani jurangu jatana warai.
\p 
\v 27 Tjipieli ngakanali ngaiala ngakani ngarai, ja ngato tanana ngujamai, ja tana ngakangu karipateriai,
\p 
\v 28 Ja ngato tanangu tepi ngurali jinkiai, ja tana ngurali wata tintaterila nganai, ja wata kulnujeli tanana ngakani marandru manila nganai.
\p 
\v 29 Ngakani Ngaperi, Nulia tanana ngakangu jinkinala, morla pirna nganai warupotuni; ja wata kulno ngurunguru nganai, tanana Ngaperaia ngakanaia marandru manila.
\p 
\v 30 Ngani ja Ngaperi kulno nganai.“
\p 
\v 31 Juda kanali nakaldra marda patana wonti nina dakala.
\p 
\v 32 Jesujeli tanangu kalabana wonti: „Ngankani ngumu marapu ngato jurangu ngakani Ngaperandru wondrana warai; wodatanangundru ngankanandru jura ngana mardali dakai?“
\p 
\v 33 Juda kanali nunkangu kalabana wonti ja jatana wonti: „Ngankani ngumundru ngaiani jidna wata mardali dakai, a‐ai, Godaia ngirkibanandru, ja ngangau jidni, kana ngananani, munta Goda ngankatariai.“
\p 
\v 34 Jesujeli tanangu kalabana wonti: „Wata jurani jirijiribani jaurani dakanala parai: Ngani jatana wonti, jura Goda wora nganai?
\p 
\v 35 Nulia tanana «Goda worana» dikanani, ja dakanala ngandandariai wokaribala;
\p 
\v 36 Jura nunkangu, ninaia Ngaperali kulikiri ngankana wonti ja mitani jinpana wonti, jatanani: «Jundru Goda ngirkibai;» ngangau ngani jatana warai: Godaia Ngatamura ngani nganai?
\p 
\v 37 Ngato Ngaperaia ngakanaia ngankani wata ngankanani, ngakangu wata morlalu ngundranau;
\p 
\v 38 Ngato tananaia ngankanani, jeruja, jura bakana ngakangu wata morlalu ngundranani, tanangu ngankanani morlalu ngundranau! ngangau jura ngujamananto ja morlalu ngundrananto, Ngaperi ngakangu nganai ja ngani nunkangu.“
\p 
\v 39 Tanali nakaldra wontina wonti nina patala, ja Nau tanani marandru kutingana wonti.
\p 
\v 40 Ja Nau nakaldra Jordan kaiari jerankaria wapana wonti, nunkangupini piria, woderi Johannili ngopera multibana wonti; ja Nau naka ngamana wonti.
\p 
\v 41 Ja marapu nunkangu wokarana wonti ja jatana wonti: „Johannili malka pani ngankana paraia; ja pratjana mina Johannes nunkangundru jatana paraia, morlalu nganai.“
\p 
\v 42 Ja marapujeli naka nunkangu morlalu ngundrana wonti.
\c 11
\p 
\v 1 Kulno muntja nganana wonti, Lazarus Bethaniandru, Marianankani ja Marthanankani nankani kakuja ngurani.
\p 
\v 2 Nani Maria nganana wonti, nandru Kapara matja gildieli wiribana, ja tidna nunkani parali nankanali matja muja ngankana, nankani neji Lazarus muntja parana wonti.
\p 
\v 3 Kaku wulali nunkangu jinpana wonti ja jatana wonti: „Kaparajai, mai, nina jundru ngantjai, nau muntja parai.“
\p 
\v 4 Jesujeli jenia matja ngarana, Nau jatana wonti: „Naupini muntja wata naria nganai, a‐ai, Godaia pirnalandru, ngangau Godaia Ngatamura pirna pantjinanto nunkangundru.“
\p 
\v 5 Jesujeli Martha ja kaku nankani ja Lazarus ngantjana wonti.
\p 
\v 6 Nulu matja ngarana, nau muntja, Nau ditji mandru morla nunkangupini pirini, woderi Nau nganana, ngamana wonti.
\p 
\v 7 Ngadani Nau milini nunkanani jatana wonti: „Ngaiana nakaldra Judaiaia palkananto!“
\p 
\v 8 Mili nunkani nunkangu jatana wonti: „Rabbi, kalkani Juda kanali wontina paraia jidna mardali dakala, ja nakaldra jidni jerra palkai?“
\p 
\v 9 Jesujeli kalabana wonti: „Wata ditjiwirdri ditji karitjiai pota marapratjana ja mandru? Worana ditjini wiriai nau wata dakateriai, ngangau nulu nunkanipini mitaia praitji najiai;
\p 
\v 10 Worana tinkani wirariai, nau dakateriai, ngangau praitji wata nunkangu nganai.“
\p 
\v 11 Jenia Nau jatana wonti, ja ngadani Nau tanangu jatana wonti: „Lazarus kamaneli ngaianani mukaturarala wapaia; ja ngani wapai, nina jiritjibala.“
\p 
\v 12 Mili nunkani jatana wonti: „Kaparajai, nau mukaturaranani, nau tepi pantjinani.“
\p 
\v 13 Jesus nunkani narindru jatana wonti: tanali ngundrana wonti, Nau jenia mukandru jatai.
\p 
\v 14 Ngadani Jesus tanangu talku jatana wonti: „Lazarus palila wiri,
\p 
\v 15 Ja ngani mankiai jurangundru, ngani wata naka nganala wiri, ngangau jura morlalu ngundrananto; ngaiana nunkangu palkananto.“
\p 
\v 16 Thomas, nina tanali dikai Didymus, mili nguruni jatana wonti: „Ngaiana bakana palkananto nunkangu jela palila!“
\p 
\v 17 Jesus matja wokarana, Nulu nina mankamankana wonti, nau ditji mandru ja mandru narikutuni paranani.
\p 
\v 18 Bethania Jerusalemingu karakara nganana wonti, Statia marapratjana ja mara wora worita.
\p 
\v 19 Juda kana marapu Marthangu ja Mariangu wokarana wonti pudlana nejini pudlanani ngankalkala.
\p 
\v 20 Marthandru matja ngarana Jesus wokaranani, nani wapana wonti nunkangu mandurila; Maria pungani ngamantina wonti.
\p 
\v 21 Marthani Jesungu jatana wonti: „Kaparajai, jidni ninkida ngananani, neji ngakani wata palinani.
\p 
\v 22 Bakana karari ngani milkila, minakulno jidni Godandru ngatjinani, jenia Godali jinkangu jinkila nganai.“
\p 
\v 23 Jesus nankangu jatana wonti: „Neji jinkani jiritjila nganai.“
\p 
\v 24 Marthani nunkangu jatana wonti: „Ngani milkila, nau jiritjila nganai tepi terkakani, ditjini ngadalani.“
\p 
\v 25 Jesus nankangu jatana wonti: „Ngani tepi terkakani ja tepi nganai. Warle ngakangu morlalu ngundrai, nau tepi ngamala nganai, bakana nau palinani.
\p 
\v 26 Ja worana tepi ngamai ja ngakangu morlalu ngundrai, nau morlalu ngurali wata palila nganai. Jundru jenia morlalu ngundrai?“
\p 
\v 27 Nani nunkangu jatana wonti: „Kau Kaparajai, ngato morlalu ngundrai jidni Christus nganai, Godaia Ngatamura, Nauja mitani wokarananto.“
\p 
\v 28 Ja nani jenia matja jatana, nani wapana wonti ja kaku nankani Mariana kurukuru karkana wonti ja jatana wonti: „Ngujangujara jinkinietja ninkida nganai ja jidna karkai.“
\p 
\v 29 Nandru jenia matja ngarana, nani nurujeli jiritjina wonti ja nunkangu wokarana wonti.
\p 
\v 30 Jesus jendranguta wata ngurani wokarana wonti, a‐ai, Nau nunkangupini pirini nganana wonti, woderi Marthani nunkangu mandurina wonti.
\p 
\v 31 Juda kanali, tana nankangu jela pungani ngamana wonti ja nana ngankalkana wonti, najinani Maria nurujeli jiritjinani ja dunkanani, tana nankangu karipaterina wonti ja jatana wonti: „Nania narikutuja wapai naka jindrala.“
\p 
\v 32 Maria naka wokaranani woderi Jesus nganana wonti, nandru nina matja najina, nani nunkangu tidnani woraterina wonti ja nunkangu jatana wonti: „Kaparajai, jidni ninkida ngananani, neji ngakani wata palinani.“
\p 
\v 33 Jesujeli nana jindranani najina, ja Juda kana, tana nankangunto matja wokarana, bakana jindranani, Nau Jaolali ngara jerkina wonti ja ngaratutututungana wonti.
\p 
\v 34 Ja Nau jatana wonti: „Woderi jura nina kurala wiri?“ Tana nunkangu jatana wonti: „Kaparajai, kaparau ja najiau!“
\p 
\v 35 Ja Jesus wolkarina wonti.
\p 
\v 36 Juda kana jatana wonti: „Najianau worderu Nulia ninaia ngantjana paraia!“
\p 
\v 37 Palpa tanangundru jatana wonti: „Naupara, Nulia butjuja milki piri ngankana paraia, ngandandarina paraia ngankala, bakana Naupini wata palinanto?“
\p 
\v 38 Jesus nakaldra ngara jerkina wonti ja narikutuni wokarana wonti. Nau minka nganana wonti, ja marda nunkangu parana wonti.
\p 
\v 39 Jesus jatana wonti: „Nina marda tirimalkanau.“ Martha, naria kaku, nunkangu jatana wonti: „Kaparajai, nauja matja paniai, ngangau nauja ditji mandru ja mandru parai.“
\p 
\v 40 Jesus nankangu jatana wonti: „Ngani jinkangu wata jatana warai, jundru morlalu ngundranani, jundru Godaia pirnala najila nganai?“
\p 
\v 41 Tanali nina marda tirimalkana wonti, woderi nau nari paranani. Ja Jesus milki tjenmana wonti ja jatana wonti: „Ngaperiai, ngato jidna jurakokala wapaia, ngangau jundru ngana ngarana warai.
\p 
\v 42 Ngani milkila, jundru ngana milingeru ngarai: windri kana wolarandru, tanaia karakara terkai, ngani jenia jatana warai, ngangau tanalia morlalu ngundrananto, jundru ngana jinpanala.“
\p 
\v 43 Ja Nau jenia matja jatana, Nau ngaiala pirnali karkana wonti: „Lazarujai dunkau!“
\p 
\v 44 Ja nau narila dunkana wonti mara ja tidna nari katieli karaterini, ja nunkangu mudlani kangu kati paranani. Jesus tanangu jatana wonti: „Ninaia dukaranau ja worani patanau!“
\p 
\v 45 Juda kana marapujeli tana Mariangu wokarana wonti ja najina wonti mina Jesujeli ngankana wonti, tana nunkangu morlalu ngundrana wonti.
\p 
\v 46 Palpa tanangundru Pharisaiaia wapana wonti ja tanangu kaukaubana wonti mina Jesujeli ngankana warai.
\p 
\v 47 Priesta pirnali ja Pharisaiali kana kapara jurborilkana wonti ja jatana wonti: „Mina ngaiana ngankananto? Nulupini kanali malka marapu ngankai.
\p 
\v 48 Ngaiana nina jeruja worani patanani, tanali pratjanali nunkangu morlalu ngundrala nganai; ja Roma kana wokarala nganai ja ngaianani piri ja kana wolara manila nganai.“
\p 
\v 49 Kulno tanangundru, Kaiphas, nau nunkangupini kilpawoldrani Priesta pirna nganana wonti, tanangu jatana wonti: „Jura panila ngujamai.
\p 
\v 50 Jura bakana wata ngundrai, ngaianangu morla ngumu nganai, kana kulno kana wolarani palinanto, ja wata kana wolara tintaterinanto.“
\p 
\v 51 Jenia nau wata munta jatana wonti, a‐ai, ngangau nau nunkangupini kilpawoldrani Priesta pirna nganana wonti, nulu talpadakana wonti Jesus palinanto kana wolarani.
\p 
\v 52 Ja wata windri kana wolarani, a‐ai, Nulu bakana Godaia kupa, tana piltjaru ngamanani, kulnukulnuni ngankananto.
\p 
\v 53 Nunkangupini ditjindru tana ngankamalina wonti nina naria nandrala.
\p 
\v 54 Jesus wata morla Juda kanani kantji wirarina wonti, a‐ai, Nau nakandruka puntina wonti mita pitaraia karakaraia, ngura kulnuja, tala nunkani Ephraim, ja Nau naka ngamana wonti nunkani milinto.
\p 
\v 55 Juda kanaia Passa karakara nganana wonti, ja marapu nunkangupini mitandru Jerusalemia tarana wonti Passani ngopera, kulirkaterila.
\p 
\v 56 Tanali Jesus wontina wonti, ja Godaia pungani ngankamalina wonti ja jatana wonti: „Mina jura ngundrai? Nau wata ditji pirnani wokarala nganai?“
\p 
\v 57 Priesta pirnali ja bakana Pharisaiali jirijiribani jaura jinkina wonti, woranakulno milkila, woderi Nau nganai, nulu jenia wondrananto, ngangau tanali nina patananto.
\c 12
\p 
\v 1 Ditji mara wora ja kulnuni Passani ngopera Jesus Bethaniani wokarana wonti woderi Lazarus nganana wonti, nina Jesujeli narindru jiritjibana paraia.
\p 
\v 2 Tanali nunkangu naka buka pirna ngankingana wonti, ja Martha mili nganana wonti; Lazarus kulno tanangundru nganana wonti, tana nunkangunto kurlini ngamana wonti.
\p 
\v 3 Marthandru Narda gildi koko kulno ngumu pirnanto manina wonti ja Jesuni tidna wiribana wonti ja tidna nunkani parali nankanali muja ngankana wonti, ja punga manamiri pantjina wonti gildia kuli ngumujeli.
\p 
\v 4 Nunkani milindru kulno, Judas Simon Ischariot, nulu nina wontawontananto, jatana wonti:
\p 
\v 5 „Minandru ninapini gildi wata 300 mardatandraia jinkina warai kalalaia, ja wangiwangini bakujeli jinkina warai?“
\p 
\v 6 Jenia nau wata jatana wonti, ngangau nulu kana wangiwangi ngundrana wonti, a‐ai, ngangau nau kurikantji nganana wonti, ja billi ngamalkana wonti ja patana wonti, mina tanali kurarala.
\p 
\v 7 Jesus jatana wonti: „Nana worani patanau! ngakani todini ditjia nandruja jenia kulkana warai.
\p 
\v 8 Ngangau kana wangiwangi jura milingeru ngamalkai, ngana jura wata milingeru ngamalkai.“
\p 
\v 9 Juda kana wolarali ngarana wonti, Nau naka ngananani; ja tana wata windri Jesungundru wokarana wonti, a‐ai, tanali bakana Lazarus najinanto, nina Nulu narindru jiritjibana paranani.
\p 
\v 10 Priesta pirna wora manamandumandurina wonti bakana nina Lazarus naria nandrala.
\p 
\v 11 Ngangau Juda kana marapu nunkangundru wapana wonti, ja Jesungu morlalu ngundrana wonti.
\p 
\v 12 Ditji kulnuni kana marapujeli, tana ditji pirnani matja wokarana, ngarana wonti Jesus Jerusalemia wokaranani.
\p 
\v 13 Tanali palma pitandru ngunanguna manina wonti ja dunkana wonti nunkangu mandurila ja maritjina wonti: „Hosiana, jurakokani nganaiatimai nunkangu, Nauja wokarai Kaparaia talani Israelaia Kapara!“
\p 
\v 14 Jesujeli donki matja manina, Nau nunkangu ngamana tarana wonti, worderu dakanala parai:
\p 
\v 15 „Wata japali nganau Zionani ngatamurajai, mai, Kapara jinkani wokarala wapaia donki kuparani dukaterina!“
\p 
\v 16 Jenia milieli nunkanali ngopera wata ngujamana wonti, a‐ai, jendranguta Jesujeli pirnala nunkani matja manina, ngadani tanali ngundrana wonti, tananapini nunkangundru dakana wonti, ja tanali nunkangu jenia ngankanala.
\p 
\v 17 Kana wolarali tana nunkangunto nganana, Nulu Lazarus narikutundru karkana paraia ja nina narindru jiritjibana paraia, jenia tinkari ngankana wonti.
\p 
\v 18 Jendrangundruja bakana kana wolara nunkangu mandurina wonti, ngangau tanali ngarana warai, Nulu ninapini malka ngankana paraia.
\p 
\v 19 Pharisaiali ngankamalina wonti: „Jura najiai, jenia jurangu baku nganai; mai, kana warupoto nunkangu wapantina warai.“
\p 
\v 20 Naka Grieka kana palpa nganana wonti tanangundru, tana milingeru tarana wonti ditji pirnani ngatjila.
\p 
\v 21 Tanapini Philippungu wokarana wonti, nau Bethsaida Galilaiandru nganana wonti ja nunkangu ngatjina wonti ja jatana wonti: „Kaparajai, ngaiani ngantjai Jesus najila.“
\p 
\v 22 Philippus wokarai ja Andreangu jenia jatai; ja Andreas ja Philippus jenia nakaldra Jesungu jatai.
\p 
\v 23 Jesujeli kalabana wonti ja tanangu jatana wonti: „Ditji matja wokarana warai, Kanaia Ngatamura pirna pantjinanto.
\lit (Ngantjani‐jaura Laurentius ditjini.)
\p 
\v 24 Morlalu, morlalu, ngani jurangu jatai: Buka tandra matja mitani purina wata palinani, nau kulnulu parai; nau matja palinani, nulu tandra marapu punkibai.
\p 
\v 25 Warle tepi nunkani ngantjai, nulu nina tintala nganai; ja worana nunkani tepini kalakalariai nunkangupini mitani, nulu nina tepi nguralia ngamalkala nganai.
\p 
\v 26 Worana mili ngakani nganai, nau ngakangu karipateriatimai, ja woderi ngani nganai, jerra bakana mili ngakani nganala nganai; ja worana mili ngakani nganala nganai, nina Ngaperali ngakanali pirna ngundrala nganai.
\b
\p 
\v 27 Ngani mungara karari ngaratutututungai. Ja mina ngani jatananto? Ngaperiai, nunkangupini ditjindru ngana kulkamai! Windri jendrangundruja ngani nunkangupini ditjini wokarana warai.
\p 
\v 28 Ngaperiai, tala jinkani pirna ngankamai!“ Ngaiala kulno pariwilpandru wokarana wonti: „Ngato ninaia pirna ngankana warai, ja ninaia nakaldra pirna ngankala nganai.“
\p 
\v 29 Kana wolara tana jerra terkana ja ngarana, jatana wonti: „Talara piltripiltri nganana warai;“ palpa jatana wonti: „Angela kulno nunkangunto ngankamalina warai.“
\p 
\v 30 Jesujeli kalabana wonti ja jatana wonti: „Naupini ngaiala wata ngakangundru, a‐ai, jurangundru pantjina warai.
\p 
\v 31 Karari nunkangupini mitani puntibani nganai; karari Nulia nunkanipini mitaia kapara narrala nganai.
\p 
\v 32 Ja ngani mitandru matja miri ngananani, ngato warupotopratjana ngakangu parumala nganai.“
\p 
\v 33 Jenia Nau jatana wonti wondrala, mina nari Nau palinanto.
\p 
\v 34 Kana wolarali nunkangu kalabana wonti: „Ngaiani jirijiribani jaurandru ngarana warai, Christus ngurali ngamala nganai; ja worderu jidni jatai: Kanaia Ngatamura miri pantjinanto? Worana Naupini Kanaia Ngatamura nganai?“
\p 
\v 35 Jesus tanangu jatana wonti: „Windri miljaru wordu morla praitji jurangunto nganai. Wirarianau jeruntjaia jura praitji ngamalkai, ngangau ngalpurali jurana pataiati. Ja worana ngalpurani wirariai, nau wata milkila wodajeri nau wapai.
\p 
\v 36 Jeruntjaia jura praitji ngamalkai, praitjani morlalu ngundranau, ngangau jura praitjaia kupa pantjinanto.“ Jenia Jesujeli kaukaubana wonti ja wapana wonti ja tanangundru kurukurumalkaterina wonti.
\p 
\v 37 Nulu jeruntja malka tanangu milkini ngankana wonti, ja tanali nunkangu wata morlalu ngundrana wonti,
\p 
\v 38 Ngangau Jesaiani Prophetaia jaura morlalu pantjinanto, nina nau jatana wonti: „Kaparajai, warle ngaianinani ngujangujarani morlalu ngundrana warai? Ja worangu Kaparaia nguna tinkari pantjina warai?“
\p 
\v 39 Jendrangundruja tana ngandandarina wonti morlalu ngundrala, ngangau Jesaias nakaldra jatai:
\p 
\v 40 „Nulia tanani milki butju ngankana wonti ja tanani ngara ngurunguru ngankana wonti, ngangau tanali milkieli wata najinanto ja ngarali wata ngujamananto ja madlentjandru karitjinanto, ngato tanana tepi ngankananto.“
\p 
\v 41 Jenia Jesaias jatana wonti, nulu pirnala nunkani matja najina ja nunkangundru kaukaubana wonti.
\p 
\v 42 Bakana kapara marapujeli nunkangu morlalu ngundrana wonti; windri Pharisaiandru tanali nina wata kantji dikana wonti, tanali tanana Godaia milindru narraiati.
\p 
\v 43 Ngangau tanali kanaia pirnala morla ngantjana wonti Godaia pirnalani.
\p 
\v 44 Jesus parparali karkana wonti ja jatana wonti: „Warle ngakangu morlalu ngundrai, wata ngakangu morlalu ngundrai, a‐ai, windri nunkangu, Nulia ngana jinpanala.
\p 
\v 45 Ja warle ngana najiai, nulu ninaia najiai, Nulia ngana jinpanala.
\p 
\v 46 Ngani mitani wokaranala praitji nganala; ngangau warle ngakangu morlalu ngundrai wata morla ngalpurani nganananto.
\p 
\v 47 Ja warle jaura ngakani bulu ngarai ja wata morlalu ngundrai, nunkangu wata ngato kalala kurai, ngangau ngato wata wokaranala mitalani kalala kurala, a‐ai, mitala kulkala.
\p 
\v 48 Warle ngana worarai, ja jaura ngakani wata patai, nulu nina ngamalkai, nulu nunkangu kalala kurai; nulupini jaurali, nina ngani jatana warai, nunkangu kalala kurala nganai ditjini ngadalani.
\p 
\v 49 Ngangau ngato wata ngakangundru muntali kaukaubana warai, a‐ai, Ngaperali, Nulia ngana jinpanala, ngakangu jirijiribani jaura jinkinala; mina ngato kaukaubananto ja mina ngani jatananto.
\p 
\v 50 Ja ngani milkila, nunkani jirijiribani jaura tepi ngurali nganai. Mina ngani jatala wapaia, jenia ngani jeruja jatai, worderu Ngaperali ngakangu jatanala.“
\c 13
\lit (Ngantjani‐jaura kuljakulja Thursdayni.)
\p 
\v 1 Passa ditji pirnani ngopera Jesus milkila nganana wonti ditji nunkani matja wokarana, Nau nunkangnpini mitandru Ngaperaia wapananto; worderu Nulu nunkanina mitani ngananani, ngantjana wonti, jeruja Nulu tanana narielu ngantjana wonti.
\p 
\v 2 Ja buka matja mudanani, ja kutjieli Judas Ischariot Simonani ngatamurani ngarani matja jinkina, nulu nina wontawontananto,
\p 
\v 3 Ja Jesus matja milkila ngananani, Ngaperali nunkangu pratjana marani jinkina warai, ja Nau Godandru dunkanala ja Godaia tikananto,
\p 
\v 4 Nau bukandru terkakana wonti, ja kati nunkani dukarana wonti ja wirpakati manina wonti ja ngampina wonti;
\p 
\v 5 Ngadani Nulu ngapa ngapakokuni nangana wonti ja wonina wonti militidna kulirkala ja wirpakatieli, nina Nau matja ngampina warai, muja ngankala.
\p 
\v 6 Nau Simon Petrungu wokaranani, nau nunkangu jatana wonti: „Kaparajai, jundru ngana tidna kulirkai?“
\p 
\v 7 Jesujeli kalabana wonti ja nunkangu jatana wonti: „Mina ngato ngankala wapaia jidni karari wata milkila, jundru jenia ngadani ngujamala nganai.“
\p 
\v 8 Petrus nunkangu jatana wonti: „Ngurali jundru wata ngana tidna kulirkananto!“ Jesujeli nunkangu kalabana wonti: „Ngato jidna wata kulirkanani, jundru ngakangunto wata poto ngamalkanani.“
\p 
\v 9 Simon Petrus nunkangu jatana wonti: „Kaparajai, wata windri ngana tidna, a‐ai, bakana mara ja mangatandra.“
\p 
\v 10 Jesus nunkangu jatana wonti: „Worana matja ngaporna, nau wata morla kulirkaterinanto windri tidna kulnulu, ngangau nau pratjanani kulikiri nganai; ja jura kulikiri nganai, windri wata pratjana.“
\p 
\v 11 Ngangau Nulu wontawontanietja nunkani ngujamana wonti; jendrangundruja Nau jatana wonti: „Jura wata pratjana kulikiri nganai.“
\p 
\v 12 Nulu tanana tidna matja kulirkana, ja Nau kati nunkani matja widmaterina ja ngamana ngarina, Nau tanangu jatana wonti: „Jura ngujamai mina ngato jurangu ngankana warai?
\p 
\v 13 Jura ngana Ngujangujara jinkinietja ja Kapara dikai; ja jura talku jatai, ngangau ngani Nauja nganai.
\p 
\v 14 Ngato, Kaparali ja Ngujangujara jinkinietjali juranali jurana tidna kulirkana warai, jeruja bakana jura tidna kulirkijiribamalinanto.
\p 
\v 15 Wondrani malka ngato jurangu jinkina warai, ngangau worderu ngato jurangu ngankana warai, jeruja bakana jura ngankananto.
\b
\p 
\v 16 Morlalu, morlalu, ngani jurangu jatai: Mili wata morla pirna nganai nunkani kaparani, ja Apostel wata morla pirna nganai nunkangu, nulu nina jinpanala.
\p 
\v 17 Jura jenia milkila ngananani, murlali pirna jura nganai, jura jenia ngankanani.
\p 
\v 18 Wata jurangu pratjanandru ngato kaukaubai, ngani milkila, worana ngato kalkalkanala; windri jaura morlalu pantjinanto: «Nulu ngakangunto buka tajila wapaia, nulu tidnawoda nunkani miri ngankana warai ngakangu.»
\p 
\v 19 Karari ngani jurangu jenia jatai, morla ngopera jenia pantjinani, ngangau jura, jenia pantjinani, morlalu ngundrananto, ngani Nauja nganai.
\p 
\v 20 Morlalu, morlalu, ngani jurangu jatai: Warle nina patai, worana ngato jinpai, nulu ngana patai; ja warle ngana patai, nulu ninaia patai, Nulia ngana jinpanala.“
\p 
\v 21 Nau jenia matja jatana, Jesus Jaolali ngaratutututungana wonti, ja Nulu tinkari ngankana wonti ja jatana wonti: „Morlalu, morlalu, ngani jurangu jatai: Kulnujeli jurangundru ngana wontawontala nganai.“
\p 
\v 22 Mili milkieli najimalina karitjina wonti, ja tana wurpuru nganana wonti, worangundru Nauja jenia jatai.
\p 
\v 23 Nunkani mili kulno, nau kurlini Jesuni munambirini ngamana wonti, nina Jesujeli ngantjana wonti;
\p 
\v 24 Nunkangupini Simon Petrulu malka jinkina wonti nulu jakalkananto, worana nauja nganai, nunkangundru Nauja jenia jatai.
\p 
\v 25 Nau Jesu munambirini buruna ngarina wonti ja nunkangu jatana wonti: „Kaparajai, worana nauja nganai?“
\p 
\v 26 Jesujeli kalabana wonti: „Nauja nganai, nunkangu ngato buka waka multibala nganai ja jinkila nganai.“ Ja Nulu buka waka matja multibana, Nulu nina Judas Ischariot Simonani ngatamurani jinkina wonti.
\p 
\v 27 Ja nulu buka waka matja manina, Satan nunkangu wirina wonti. Jesus nunkangu jatana wonti: „Mina jundru ngankai, jenia morla nurujeli ngankai.“
\p 
\v 28 Jenia wata kulnujeli tanangundru, kurlini matja ngamana, ngujamana wonti, minani Nau jenia nunkangu jatana wonti.
\p 
\v 29 Palpali ngundrana wonti, ngangau Judali mardatandra billi ngamalkana wonti, Jesus nunkangu jatai: „Burungankau, mina ngaiani ditji pirnani ngamalkananto,“ nulu wangiwangini palpa jinkinanto kara.
\p 
\v 30 Nulupini buka waka matja manina, nau nurujeli dunkana wonti. Ja tinka nganana wonti.
\p 
\v 31 Nau matja dunkana, Jesus jatana wonti: „Karari Godaia Ngatamura pirna nganai, ja Goda nunkangu pirna nganai.
\p 
\v 32 Goda nunkangu pirna ngananani, jeruja bakana Godali ninaia munta pirna ngankala nganai nunkangu, ja nurujeli Nulia nina pirna ngankala nganai.
\p 
\v 33 Kupa worai! Windri wordu morla ngani jurangunto nganai. Jura ngana wontila nganai, ja worderu ngani Juda kanani jatana warai: Wodajeri ngani wapai, naka jura ngandandariai wokarala; jeruja ngani karari bakana jurangu jatai.
\p 
\v 34 Jirijiribani jaura marra ngato jurangu jinkiai: Jura ngantjamalinanto; worderu ngato jurana ngantjana warai, jeruja bakana jura ngantjamalinanto.
\p 
\v 35 Nunkangundru pratjanali ngujamala nganai, jura mili ngakani nganai, jura ngantjamalinani.“
\p 
\v 36 Simon Petrus nunkangu jatana wonti: „Kaparajai, wodajeri jidni wapai?“ Jesujeli nunkangu kalabana wonti: „Wodajeri ngani wapai, jerra jidni karari ngandandariai ngakangu karipaterila; ngadani jidni ngakangu karipaterila nganai.“
\p 
\v 37 Petrus nunkangu jatana wonti: „Kaparajai, minandru ngani karari ngandandariai jinkangu karipaterila. Ngakani tepi ngani jinkangundru jinkiterila nganai.“
\p 
\v 38 Jesujeli nunkangu kalabana wonti: „Jinkani tepi jundru ngakangundru ngantjai jinkila? Morlalu, morlalu, ngani jinkangu jatai: Windrila paia ngaperi jatananto, jundru ngana pota parkulu jedieli worarala nganai.“
\c 14
\lit (Ngantjani‐jaura Philippi ja Jakobi ditjini.)
\p 
\v 1 Jura ngara wata japali pantjianau! Godani morlalu ngundranau, ja bakana ngakangu morlalu ngundranau.
\p 
\v 2 Ngaperaia ngakanaia pungani piri marapu nganai; wata kantji ngananani, ngani jurangu jenia jatanani. Ngani wapai jurani piri ngankijiribingala;
\p 
\v 3 Ja ngani matja wapana warai, ja jurangu piri ngankijiribingana warai, ngadani ngani nakaldra tikala nganai ja jurana ngakangu manila nganai, ngangau woderi ngani nganai bakana jura nganananto.
\p 
\v 4 Ja wodajeri ngani wapai jura milkila, ja palto jura bakana milkila.
\p 
\v 5 Thomas nunkangu jatana wonti: „Kaparajai, ngaiani ko wodajeri jidni wapai, ja worderu ngaiani palto ngujamananto?“
\p 
\v 6 Jesus nunkangu jatana wonti: „Ngani palto ja morlaluta ja tepi nganai; wata kulno Ngaperani wokarai, a‐ai, windri ngakangundru.
\p 
\v 7 Jura ngana ngujamanani, jura bakana ngakani Ngaperi ngujamanani: ja kararindru jura ninaia ngujamai ja ninaia najina warai.“
\p 
\v 8 Philippus nunkangu jatana wonti: „Ngaperi ngaianingu wondramai, ja ngaianingu matja.“
\p 
\v 9 Jesus nunkangu jatana wonti: „Jeruntjaia ditji ngani jurangunto nganai, ja jundru ngana wata ngujamana warai, Philippujai? Warle ngana najina warai, nulu Ngaperi najina warai; worderu jidni jatai: Ngaianingu Ngaperi wondramai?
\p 
\v 10 Jundru wata morlalu ngundrai ngani Ngaperani ja Ngaperi ngakangu nganai? Tananapini jaura, tanana ngani jurangu jatai, ngani wata ngakangundru munta jatai; Ngaperali, Nauja ngakangu ngamai, Nulia muntali tanana ngankani ngankai.
\p 
\v 11 Ngakangu morlalu ngundranau ngani Ngaperani ja Ngaperi ngakangu nganai; pani kara, ngakangu morlalu ngundranau ngankanandru!
\p 
\v 12 Morlalu, morlalu, ngani jurangu jatai: Warle ngakangu morlalu ngundrai, nulu tanana ngankani bakana ngankala nganai, tanana ngato ngankai, ja ngankani morla pirna nulu ngankala nganai tanangupini, ngangau ngani ngakani Ngaperani wapai.
\p 
\v 13 Ja minakulno jura talani ngakanani ngatjinani, jenia ngato ngankala nganai, ngangau Ngaperi pirna pantjinanto Ngatamurani.
\p 
\v 14 Minakulno jura talani ngakanani ngatjinani, jenia ngato ngankala nganai.
\b
\p 
\v 15 Jura ngana ngantjanani, jirijiribani jaura ngakani ngamalkanau!
\p 
\v 16 Ja ngani Ngaperani ngatjila nganai, ja Nulia jurangu Ngankalkanipirna nguru jinkila nganai, Nauja ngurali jura ngunto nganananto,
\p 
\v 17 Ninaia Jaola morlaluta, ninaia mitala ngandandariai manila, ngangau tanali ninaia wata najiai ja ninaia wata ngujamai; jura ninaia ngujamai, ngangau Nauja jurangunto ngamai, ja jurangu Nauja nganai.
\p 
\v 18 Ngato jurana wata ngamuru worarala nganai; ngani jurangu wokarai.
\p 
\v 19 Wordu morla, ja mitalali ngana wata morla najila nganai; jura ngana najiai, ngangau ngani tepi, ja jura bakana tepi nganala nganai.
\p 
\v 20 Nunkangupini ditjini jura ngujamala nganai, ngani Ngaperani ngakanani, ja jura ngakangu, ja ngani jurangu.
\p 
\v 21 Warle jirijiribani jaura ngakani ngamalkai, ja tanana ngumu ngamalkanani, nau naupini nganai, nulu ngana ngantjai; warle ngana ngantjai, nina Ngaperali ngakanali ngantjala nganai, ja ngato nina ngantjala nganai, ja munta nunkangu wondraterila nganai.“
\p 
\v 22 Nunkangu Judas, wata Ischariot, jatana wonti: „Kaparajai, mina pantjina warai, ngangau jidni jertapateriai ngaianingu wondraterila, ja wata mitalani?“
\lit (Ngantjani‐jaura Jaolaia ditji pirnani.)
\p 
\v 23 Jesujeli kalabana wonti ja nunkangu jatana wonti: „Kulnujeli ngana ngantjanani, nulu jaura ngakani ngamalkala nganai; ja Ngaperali ngakanali nina ngantjala nganai, ja ngali nunkangu wokarala nganai ja nunkangu ngamala nganai.
\p 
\v 24 Warle ngana wata ngantjai, nulu jaura ngakani wata ngamalkai; ja naupini jaura, nina jura ngarala wapaia, wata ngakani nganai, a‐ai, Ngapinanka, Nulia ngana jinpanala.
\p 
\v 25 Ninapini ngani jurangu jatala wapaia, ngangau ngani jurangunto ngamala wapaia.
\p 
\v 26 Ngankalkanipirnali, Jaolali kulikirieli, ninaia Ngaperali ngakanali jinpala nganai talani ngakanani, Nulupini jurana pratjanani ngujangujara jinkila nganai, ja Nulia jurana mangatandra wilpa ngankala nganai pratjanani, mina ngani jurangu jatana warai.
\p 
\v 27 Murla ngato jurangu worarai, murla ngakani ngato jurangu jinkiai; wata jeruja worderu mitalali jinkiai. Jura ngara wata ngaruparanau ja wata japali pantjianau!
\p 
\v 28 Jura matja ngarana, ngani jurangu jatana warai: Ngani wapai ja jurangu tikai. Jura ngana ngantjanani, jura mankinani, ngani jatana warai: Ngaperani ngani tikai; ngangau Ngaperi morla pirna nganai ngakangu.
\p 
\v 29 Ja karari ngani jenia jurangu jatana warai, morla ngopera jenia pantjinani, ngangau jenia pantjinani, jura morlalu ngundrananto.
\p 
\v 30 Ngani wata morla jaura marapu jurangu jatala nganai; ngangau nunkanipini mitaia kapara wokarai, ja panila nulu ngakangu ngamalkai.
\p 
\v 31 Ngangau mitalali ngujamananto, ngato Ngaperi ngantjai, ja jeruja ngankai worderu Ngaperali ngakangu jirijiribanala: Terkakanau ngaiana ninkidandru wapananto.“
\b
\c 15
\p 
\v 1 Ngani waina nindri morlalu nganai, ja Ngaperi ngakani waina maru najinajibanietja nganai.
\p 
\v 2 Waina ngunanguna pilki ja pilki, nulu wata tandra mandranani, nina Nulia dukarai; ja pilki ja pilki nulu tandra mandranani, nina Nulia kulirkai, nulu tandra morla mandrananto.
\p 
\v 3 Jura kulikiri nganai nunkanipini jaurandru, nina ngato jurangu kaukaubana warai.
\p 
\v 4 Ngakangu ngamanau ja ngani jurangu! Worderu waina ngunanguna ngandandariai muntali tandra mandrala nau wata waina nindrini paranani, jeruja bakana jura, jura wata ngakangu ngamanani.
\p 
\v 5 Ngani waina nindri nganai, jura ngunanguna. Worana ngakangu ngamai ja ngani nunkangu, nulupini tandra marapu mandrai; ngangau ngakangu panini jura ngandandariai ngankala.
\p 
\v 6 Kulno wata ngakangu ngamanani, nina Nulia palarani worala nganai ngunanguna jeribaka, ja nau mujarila nganai; ja tanali nina kampala nganai ja nina turuni worala nganai, ja nau jerkila nganai.
\p 
\v 7 Jura ngakangu ngamanani ja jaura ngakani jurangu ngamalkanani: Mina jura jertapateriai jura ngatjinanto, ja jenia jurangu pantjila nganai.
\p 
\v 8 Jeruja Ngaperi ngakani pirna nganai, jura tandra marapu mandranani, ja jura mili ngakani ngananani.
\p 
\v 9 Worderu Ngaperali ngana ngantjana wonti, jeruja ngato jurana ngantjana warai: ngantjanani ngakanani wonki ngamanau!
\p 
\v 10 Jura jirijiribani jaura ngakani ngamalkanani, jura ngantjanani ngakanani ngamanani; worderu ngato Ngaperaia ngakanaia jirijiribani jaura ngamalkana warai, ja ngantjanani nunkanani ngamai.
\p 
\v 11 Tananapini ngato jurangu kaukaubana warai, ngangau ngakani mankini jurangu nganananto, ja jurani mankini manamiri pantjinanto.
\p 
\v 12 Naupini jirijiribani jaura ngakani nganai: Jura ngantjamalinanto, worderu ngato jurana ngantjana warai.
\p 
\v 13 Wata kulnujeli ngantjani morla pirna ngamalkai nunkangu, nau tepi nunkani jinkiteriai kamanelini nunkanani.
\p 
\v 14 Jura kamaneli ngakani nganai, jura ngankanani mina ngato jurangu jirijiribai.
\p 
\v 15 Ngato jurana wata morla mili dikai, ngangau mili wata milkila mina kapara nunkani ngankai; jurana ngato kamaneli dikana warai, ngangau pratjana, mina ngato ngakani Ngaperandru ngaranala, ngato jurangu tinkari ngankana warai.
\p 
\v 16 Wata jura ngana kalkalkana wonti, a‐ai, ngato jurana kalkalkana wonti ja jurana kurana wonti jura wapananto ja tandra mandrananto, ja jurani tandra parananto: Ngangau minakulno jura ngakani talani Ngaperani ngatjinani, Nulia jurangu jinkinani.
\lit (Ngantjani‐jaura Simonani ja Judani ditjini.)
\p 
\v 17 Ninapini ngato jurangu jirijiribai: Jura ngantjamalinanto.
\p 
\v 18 Mitala jurangu kalakalarinani, ngujamanau, tanali ngakangu kalakalarina warai jurangu ngopera.
\p 
\v 19 Jura mitandru ngananani, mitala nunkanina ngantjanani; ngangau jura wata mitandru nganai, a‐ai, ngato jurana mitandru kalkalkana wonti, jendrangundruja mitala jurangu kalakalariai.
\p 
\v 20 Ninapini jaura ngundranau nina ngani jurangu jatana warai: Mili wata morla pirna nganai kaparani nunkanani. Tana ngakangu tirikaripaterina warai tana bakana jurangu tirikaripaterila nganai; tanali jaura ngakani ngamalkana warai, tanali bakana jurani ngamalkala nganai.
\p 
\v 21 Jenia pratjana tanali ngankala nganai ngakani talandru, ngangau tanali nina wata ngujamai, Nulia ngana jinpanala.
\b
\p 
\v 22 Ngani wata wokaranani ja tanangu jaura kaukaubanani, tanali wata madlentji ngamalkanani, karari tanali wata morla jataterila ngamalkai tanani madlentjandru.
\p 
\v 23 Worana ngakangu kalakalariai, bakana ngakani Ngaperani kalakalariai.
\p 
\v 24 Ngato wata tanana ngankani tanangu terti ngankanani, tanana wata kulno ngurujeli ngankana warai, tanana wata madlentji ngamalkanani; karari tanali najina warai ja bakana kalakalarina warai ngakangu ja ngakani Ngaperani.
\p 
\v 25 Ngangau naupini jaura, tanani jirijiribani jaurani dakanala parai, morlalu pantjinanto: Tanali ngakangu baku kalakalarina warai.
\lit (Ngantjani‐jaura Exaudi ditjini.)
\p 
\v 26 Ja Ngankalkanipirna matja wokarana, ninapini ngato jurangu jinpala nganai Ngaperandru, Jaola morlaluta, Nauja Ngaperandru dunkai, Nulia ngakangundru tinkari ngankala nganai.
\p 
\v 27 Ja jura bakana tinkari ngankai, ngangau jura ngoperandru ngakangunto ngamai.
\c 16
\p 
\v 1 Ninapini ngani jurangu jatana warai, jura wata kintjakintjarinanto.
\p 
\v 2 Tanali jurana Godaia milindru narrala nganai; ja ditji wokarala nganai, warlenulu jurana naria nandranani, ngundrala nganai, nulu Godani poto ngumu jinkinani.
\p 
\v 3 Ja jenia tanali jurangu ngankala nganai, ngangau tanali Ngaperi ja ngana wata ngujamana warai.
\p 
\v 4 Jenia ngani jurangu jatana warai, ngangau ditji matja wokaranani, jura ngundrananto, ngani jenia jurangu matja jatana. Ninapini ngani ngoperandru wata jatana warai, ngangau ngani jurangunto ngamana warai.
\b
\lit (Ngantjani‐jaura Cantate ditjini.)
\p 
\v 5 Karari ngani tikai nunkangu, Nulia ngana jinpanala, ja wata kulnujeli jurangundru ngana jakalkai: Wodajeri jidni wapai?
\p 
\v 6 A‐ai, ngangau ngani jenia jurangu jatana warai, ngaurongaurojeli jurani ngara manamiri ngankana warai.
\p 
\v 7 Ngani jurangu jaura morlalu jatai: Jenia jurangu ngumu nganai ngani tikanani; ngangau ngani wata tikanani, Ngankalkanipirna wata jurangu wokaranani; ja ngani matja tikana, ngato ninaia jurangu jinpala nganai.
\p 
\v 8 Ja Nauja matja wokaranani, Nulia mitala kalalu ngankala nganai madlentjandru ja talkalandru ja kalalandru.
\p 
\v 9 Madlentjandru, ngangau tanali wata morlalu ngundrai ngakangu;
\p 
\v 10 Talkulandru, ngangau ngani Ngaperani tikai, ja jura ngana wata morla najila nganai;
\p 
\v 11 Kalalandru, ngangau nunkanipini mitaia kaparali kalala matja manina.
\p 
\v 12 Marapu morla ngato ngamalkai jurangu jatala, ja karari jura ngandandariai jenia pratjana waltala.
\p 
\v 13 Ja Nauja matja wokaranani, Jaola morlaluta, Nulupini jurana morlaluta warupotuni wirilkala nganai; ngangau Nauja wata nunkangundru munta jatala nganai, a‐ai, mina Nulia matja ngarana, jenia Nauja jatala nganai, ja nau wokarani Nulia jurangu kaukaubala nganai.
\p 
\v 14 Nulupini ngana pirna ngankala nganai, ngangau ngakanandru Nulia manila nganai ja jurangu kaukaubala nganai.
\p 
\v 15 Warupoto, mina Ngaperali ngamalkai, ngakani nganai; jendrangundruja ngani jatana warai: Ngakanandru Nulia jenia manila nganai, ja jurangu kaukaubala nganai.
\b
\lit (Ngantjani‐jaura Jubilate ditjini.)
\p 
\v 16 Miljaru wordu, ja jura ngana wata najila nganai, ja nakaldra miljaru wordu, ja jura ngana najila nganai, ngangau ngani Ngaperani wapai.
\p 
\v 17 Mili palpa nunkani ngankamalina wonti: „Mina jenia nganai, mina Nauja jatai ngaianangu: Miljaru wordu, ja jura ngana wata najila nganai, ja nakaldra miljaru wordu, ja jura ngana najila nganai, ja ngani Ngaperani wapai?“
\p 
\v 18 Tana jatana wonti: „Mina jenia nganai, Nauja jatai: Miljaru wordu? Ko ngaiani nganai, mina Nauja jatai.“
\p 
\v 19 Jesujeli ngujamana wonti tana jertapaterina nina jakalkala, ja Nau tanangu jatana wonti: „Jendrangundruja jura jakalkijiribamaliai, ngangau ngani jatana warai: Miljaru wordu, ja jura ngana wata najila nganai, ja nakaldra miljaru wordu, ja jura ngana najila nganai?“
\p 
\v 20 Morlalu, morlalu, ngani jurangu jatai: „Jura jindrala nganai ja juajuangala nganai, ja mitala mankila nganai; ja jura ngaurongauro ngamala nganai, ja ngaurongaurola jurani mankilala karitjila nganai.
\p 
\v 21 Widlali kupa dankanani, nandru ngaurongaurola ngamalkai, ngangau ditji nankani matja wokarana; ja nandra kupa matja dankana, nandru wata morla japa ngundrai mankinandru, ngangau kana kulno mitani matja dankana.
\p 
\v 22 Ja jura karari ngaurongaurola ngamalkai; ja ngato jurana nakaldra najila nganai ja jurani ngara mankila nganai, ja mankini jurani wata kulnujeli jurangundru manila nganai.
\p 
\v 23 Ja nunkangupini ditjini jura ngana wata jakalkala nganai.
\b
\lit (Ngantjani‐jaura Rogate ditjini.)
\m Morlalu, morlalu, ngani jurangu jatai: Minakulno jura Ngaperandru ngatjinani talani ngakanani, Nulia jurangu jinkinani.
\p 
\v 24 Jura kararielu wata ngatjina warai talani ngakanani. Ngatjianimai ja jura manila nganai; jurani mankini manamiri pantjinanto.“
\p 
\v 25 Jenia pratjana ngani jeribaka jaurali jurangu jatana warai; ja ditji wokarala nganai, nunkangu ngani wata morla jeribaka jaurali jurangu jatala nganai, a‐ai, ngato talku jurangu kaukaubala nganai ngakani Ngaperandru.
\p 
\v 26 Nunkangupini diljini jura ngatjila nganai talani ngakanani. Ja ngani wata jurangu jatai, ngani Ngaperani ngatjila nganai jurangundru,
\p 
\v 27 Ngangau Nulia Ngaperali muntali jurana ngantjai, ngangau jura ngana ngantjai ja morlalu ngundrai: Ngani Godandru dunkanala.
\p 
\v 28 Ngani Ngaperandru dunkanala ja mitani wokaranala; nakaldra ngani mitandru puntila nganai ja Ngaperaia tikala nganai.
\p 
\v 29 Mili nunkangu jatana wonti: „Mai, karari jidni talku jatai ja wata jeribaka jaura jatai,
\p 
\v 30 Karari ngaiani ngujamai, warupotuni jidni milkila, ja wata kulnujeli jidna jakalkananto. Jendrangundruja ngaiani morlalu ngundrai: Jidni Godandru dunkanala.“
\b
\p 
\v 31 Jesujeli tanangu kalabana wonti: „Karari jura morlalu ngundrai?“
\p 
\v 32 Mai, ditji wokarai ja karari matja wokarana, jura piltjaru pantjila nganai pilki ja pilki nunkanani, ja ngana kulnulu worani patala nganai, ja ngani wata kulnulu nganai, a‐ai, Ngaperi ngakangunto nganai.
\p 
\v 33 Tananapini ngato jurangu kaukaubana warai, ngangau jura ngakangu murla ngamalkananto. Mitani jura japa ngamalkai; murlali ngananau, ngato mita kalalu ngankana warai.
\c 17
\p 
\v 1 Ninapini Jesujeli kaukaubana wonti ja milkieli nunkanali pariwilpani najina tarana wonti ja jatana wonti: „Ngaperiai, ditji matja wokarana warai; Ngatamura jinkani pirna ngankamai, ngangau Ngatamurajeli jidna pirna ngankananto.
\p 
\v 2 Worderu jundru nunkangu ngurula jinkina wonti palku warupotuja, ngangau pratjana, mina jundru nunkangu jinkina wonti, Nulia tanangu jinkinanto, tepi ngurali.
\p 
\v 3 Naupini tepi ngurali nganai: Tannalia jidnana, kulnolu Goda morlalu, ja ninaia jundru jinpanala, Jesus Christus, ngujamananto.
\p 
\v 4 Ngato jidnana mitani pirna ngankana warai, ja ninaia ngankani mudana warai, ninaia jundru ngakangu jinkina wonti ngato ninaia ngankananto.
\p 
\v 5 Ja Ngaperiai! jundru karari ngana jinkangu pirna ngankamai nulupini pirnalali, ninaia ngato ngamalkana wonti jinkangu, windrila mita nganana wonti.
\p 
\v 6 Ngato jinkani tala tinkari ngankana warai tanangupini kanani, tananaia jundru ngakangu jinkina warai mitandru. Jinkani tanaia nganana wonti, ja ngakangu jundru tananaia jinkina warai, ja jaura jinkani tanalia ngamalkana warai.
\p 
\v 7 Karari tanalia ngujamana warai, jenia pratjana, mina jundru ngakangu jinkina warai, jinkangundru nganai.
\p 
\v 8 Ngangau tananaia jaura, tananaia jundru ngakangu jinkina wonti, ngato tanangu jinkina warai; ja tanalia tananaia patana warai ja morlalu ngundrana warai, ngani jinkangundru dunkanala, ja morlalu ngundrana warai, jundru ngana jinpanala.
\p 
\v 9 Ngato tanangundru ngatjiai; wata mitandru ngani ngatjiai, a‐ai, windri tanangundru, tananaia jundru ngakangu jinkina warai, ngangau tanaia jinkani nganai.
\p 
\v 10 Ja ngakani pratjana jinkani nganai, ja jinkani ngakani nganai, ja ngani tanangu pirna nganai.
\p 
\v 11 Ja ngani wata morla mitani nganai, ja tanapini mitani nganai, ja ngani jinkangu wokarai. Ngaperi kulikiriai! Jinkani talani tananaia ngamalkamai, tananaia jundru ngakangu jinkina warai; ngangau tanaia kulnukulnuni nganananto ngaldrangu jeribaka.
\p 
\v 12 Ngani tanangunto mitani nganana warai, ngato tananaia jinkani talani ngamalkana warai; tananaia, jundru ngakangu matja jinkina, ngato kulkana warai, ja wata kulno tanangundru tintaterina warai, windri tintaterini kupa kulnulu, ngangau jaura morlala pantjinanto.
\p 
\v 13 Karari ngani jinkangu wokarai, ja tananapini ngato mitani kaukaubai, ngangau tanalia ngakani mankini tanangu muntali manamiri ngamalkananto.
\p 
\v 14 Ngato tanangu jaura jinkani jinkina warai, ja mitalali tanangu kalakalarina warai, ngangau tanaia wata mitandru nganai, worderu bakana ngani wata mitandru nganai.
\p 
\v 15 Ngani wata ngatjiai, jundru tananaia mitandru maninanto, a‐ai, jundru tananaia kulkananto Madlentjani.
\p 
\v 16 Tanaia wata mitandru nganai, worderu ngani wata mitandru nganai.
\p 
\v 17 Morlalulali jinkanali tananaia kulikiri ngankamai; jaura jinkani morlalu nganai.
\p 
\v 18 Worderu jundru ngana mitaia jinpanala, jeruja bakana ngato tananaia mitani jinpana warai.
\p 
\v 19 Ja ngani munta kulikiri ngankateriai tanangu, ngangau bakana tanaia kulikiri nganananto morlalulani.
\p 
\v 20 Wata windri tanangupini ngani ngatjiai, a‐ai, bakana tanangu, tanali jaurali tananali morlalu ngundrai ngakangu.
\p 
\v 21 Ngangau pratjana kulnukulnuni nganananto, worderu jidni, Ngaperiai, ngakangu, ja ngani jinkangu, ngangau tana ngaldrangu kulnukulnuni nganananto; ngangau mitalali morlalu ngundrananto jundru ngana jinpanala.
\p 
\v 22 Ja ngato ninapini pirnala, ninaia jundru ngakangu jinkinala, tanangu jinkina warai, ngangau tana kulnukulnuni nganananto, worderu ngaldra kulnukulnuni nganai.
\p 
\v 23 Ngani tanangu ja jidni ngakangu, ngangau tana morlalu nganananto kulnukulnuni, ja ngangau mitalali ngujamananto jundru ngana jinpanala, ja jundru tanana ngantjanala, worderu jundru ngana ngantjanala.
\p 
\v 24 Ngaperiai! Ngato ngantjai, woderi ngani nganai, naka bakana tana nganananto ngakangunto, tanana jundru ngakangu jinkina warai; ngangau tanali pirnala ngakani, ninapini jundru ngakangu jinkinala, najinanto, ngangau jundru ngana ngantjana wonti morla ngopera windrila mita pantjimala.
\p 
\v 25 Ngaperi talkujai! Mitalali jidna wata ngujamana warai; ngato jidnana ngujamana warai, ja tanalipini ngujamana warai, jundru ngana jinpanala.
\p 
\v 26 Ja ngato tanangu tala jinkani tinkari ngankana warai ja tinkari ngankala nganai, ngangau ngantjani, nulupini jundru ngana ngantjanala, tanangu nganananto, ja ngani tanangu.“
\c 18
\p 
\v 1 Jesus jenia matja jatana, Nau milinto dunkana wonti ja Kidron kaiarani pararana wonti; naka garden nganana wonti, nunkangu Nau ja mili nunkani wirina wonti.
\p 
\v 2 Bakana Judas, nulu nina wontawontana wonti, nina piri ngujamana wonti, ngangau Jesus nunkani milinto naka pota marapu jurborina wonti.
\p 
\v 3 Judasali kana wolara ja Priesta pirnaia ja Pharisaia mili matja patana, ja naka wokarana wonti turumanjali praitjali ja tirimalina potujeli.
\p 
\v 4 Ngangau Jesus pratjana matja ngujamana, mina nunkangu wokarananto, Nau dunkana wonti ja tanangu jatana wonti: „Worana jura wontiai?“
\p 
\v 5 Tanali nunkangu kalabana wonti: „Jesus Nazarenala.“ Jesus tanangu jatana wonti: „Ngani Nauja nganai.“ Ja bakana Judas, nulu nina wontawontana wonti, tanangunto terkana wonti.
\p 
\v 6 Worderu Jesus tanangu jatanani: „Ngani Nauja nganai,“ tana ngadatikana wonti ja mitani purina wonti.
\p 
\v 7 Nakaldra Nulu tanana jakalkana wonti: „Worana jura wontiai?“ Tana jatana wonti: „Jesus Nazarenala.“
\p 
\v 8 Jesujeli kalabana wonti: „Ngani jurangu jatana warai, ngani Nauja nganai; jura ngana wontinani, tananaia worani patanau!“
\p 
\v 9 Ngangau naupini jaura morlalu pantjinanto, mina Nau jatana wonti: „Tanangundru, tanana jundru ngakangu jinkinala, ngato wata kulno tintana warai.“
\p 
\v 10 Simon Petrulu mardakirra ngamalkana wonti, ja nulu nina dukarana wonti ja Priesta pirnaia mili nandrana wonti, ja nina talpa ngunari wokaribana wonti; nau mili tala Malchus nganana wonti.
\p 
\v 11 Jesus Petrungu jatana wonti: „Mardakirra jinkani talani widmana tikau. Naupini koko, nina ngakangu Ngapili jinkinala, nina ngato wata tapananto?“
\p 
\v 12 Kana wolarali ja juljaia kaparali ja Juda kanaia milieli Jesu patana wonti ja nina dupudupu ngankana wonti,
\p 
\v 13 Ja tanali nina ngopera Hannasangu wapalkana wonti: Nau Kaiphani taru nganana wonti, nau nunkangupini kilpawoldrani Priesta pirna nganana wonti.
\p 
\v 14 Kaiphas nau nganana wonti, nulu Juda kana kurukurubala wiri, jenia morla ngumu nganai, kana kulno palinanto kana wolarani.
\p 
\v 15 Jesungu Simon Petrus ja mili kulno karipaterina wonti. Ninapini mili Priesta pirnali ngujamana wonti, ja nau Jesungunto wirina wonti Priesta pirnaia pirini.
\p 
\v 16 Petrus manani palarani terkana wonti. Mili kulno, nina Priesta pirnali ngujamana wonti, dunkana wonti ja mana ngamalkanietja widlali ngankamalina wonti, ja Petrus wirilkana wonti.
\p 
\v 17 Mana ngamalkanietja widla Petrungu jatana wonti: „Jidni bakana nunkanipini kanaia mili kulno nganai kara?“ Nau jatana wonti: „Wata ngani.“
\p 
\v 18 (Juda kanaia) mili ja (kaparaia) mili naka terkana wonti, tanali turu billa turu miribana wonti ja talpina wonti, ngangau kilpa nganana wonti. Ja bakana Petrus tanangunto terkana wonti ja talpina wonti.
\p 
\v 19 Priesta pirnali Jesus nunkani milindru ja nunkani ngujangujarandru jakalkana wonti.
\p 
\v 20 Jesujeli nunkangu kalabana wonti: „Ngato tinkari ja talku mitani kaukaubana warai, ngato milingeru jaura pungani ja Godaia pungani ngujangujara jinkina warai woderi Juda kana pratjana jurboriai, ja kurukuru ngato panila kaukaubana warai.
\p 
\v 21 Minandru jundru ngana jakalkai? Tanana jakalkau, tanali ngarana warai, mina ngato tanangu kaukaubana warai; mai, tana milkila mina ngani jatana warai.“
\p 
\v 22 Nau jenia jatana, mili kulno naka terkana, nau Jesus ngadla nandrana wonti ja jatana wonti: „Jeruja jundru Priesta pirnani kalabai?“
\p 
\v 23 Jesujeli nunkangu kalabana wonti: „Ngato madlentji kaukaubanani, tinkari ngankamai, jenia madlentji nganai; ngato manjujeli kaukaubanani, minandru jundru ngana nandrai?“
\p 
\v 24 Hannasali nina dupudupu Kaiphangu Priesta pirnaia jinpana wonti.
\p 
\v 25 Simon Petrus naka terkana wonti ja talpina wonti. Tana nunkangu jatana wonti: „Jidni bakana nunkanipini mili kulno nganai kara?“ Nau jedina wonti ja jatana wonti: „Wata ngani.“
\p 
\v 26 Priesta pirnaia mili kulno, nunkanipini kamaneli nina talpa Petrulu wokaribana wonti, jatana wonti: „Ngato jidnana wata gardenani nunkangunto najina warai?“
\p 
\v 27 Nakaldra Petrus jedina wonti, ja nurujeli paia ngaperi jatana wonti.
\p 
\v 28 Tanali Jesus Kaiphasangundru ngankamalini pungaia wapalkana wonti; ja nguramarani kuperi nganana wonti. Ja tana munta wata ngankamalini pungani wirina wonti, ngangau tana murumuru pantjiati, a‐ai, tanali Passa tajinanto.
\p 
\v 29 Pilatus tanangu dunkana wonti ja jatana wonti: „Mina ngulku jura ngamalkai nunkangupini kanani?“
\p 
\v 30 Tanali kalabana wonti ja nunkangu jatana wonti: „Naupini wata madlentji ngankanietja ngananani, ngaiani ninaia jinkangu wata ngulkujeli jinkinani.“
\p 
\v 31 Pilatus tanangu jatana wonti: „Jura ninaia patanau, ja jurani jirijiribani jaurali ninaia kalala jinkianau!“ Juda kana jatana wonti: „Ngaianingu wata manuni kurala wapaia kulno naria nandrala.“
\p 
\v 32 Ngangau Jesuja jaura morlalu pantjinanto, nina Nau jatana warai wondrala, mina nari Nau palinanto.
\p 
\v 33 Pilatus nakaldra ngankamalini pungani wirina wonti ja Jesus karkana wonti ja nunkangu jatana wonti: „Jidni Juda kanaia Kapara nganai?“
\p 
\v 34 Jesujeli nunkangu kalabana wonti: „Jidni munta jenia jatai kara, kana ngurujeli jenia jinkangu ngakangundru kaukaubana warai kara?“
\p 
\v 35 Pilatulu kalabana wonti: „Ngani Juda kana nganai? Jinkani kana wolarali ja Priesta pirnali jidnana ngakangu ngulkujeli jinkina warai; mina jundru ngankana warai?“
\p 
\v 36 Jesujeli kalabana wonti: „Milila ngakani wata nunkangupini mitandru nganai; milila ngakani nunkangupini mitandru ngananani, ngakani mili tirimalinani, tanali ngana wata Juda kanani ngulkujeli jinkinanto. Jeruja milila ngakani wata ninkidandru nganai.“
\p 
\v 37 Pilatus nunkangu jatana wonti: „Jeruja jidni Kapara nganai?“ Jesujeli kalabana wonti: „Jidni jenia jatai, ngani Kapara nganai. Ngani jendrania dankana wonti ja mitani jendrania wokarana wonti morlalulandru tinkari ngankala; worana morlalundru nganai, nulu ngaiala ngakani ngarai.“
\p 
\v 38 Pilatus nunkangu jatana wonti: „Mina morlalu nganai?“ Ja nau jenia matja jatana, nau nakaldra Juda kanaia dunkana wonti ja tanangu jatana wonti: „Ngato wata madlentji nunkangu mankamankai.
\p 
\v 39 Ngato milingeru jurangu jeruja ngankana warai; ngato jurangu kulno kurakananto Passani: Jura ngantjai, ngato jurangu Juda kanaia Kapaia kurakananto?“
\p 
\v 40 Nakaldra pratjana maritjina wonti ja jatana wonti: „Wata ninapini, a‐ai, nina Barabbas.“ Barabbas watawatali maninietja nganana wonti.
\c 19
\p 
\v 1 Ngadani Pilatus Jesus manina wonti ja nina nandrana wonti.
\p 
\v 2 Mitaia kaparaia mili pirapira dakana wonti dilkandru, ja nunkangu mangatandrani kurana wonti ja nunkangu kati maralje widmana wonti,
\p 
\v 3 Ja jatana wonti: „Murlali nganamai Juda kanaia Kapara!“ Ja nina ngadla nandrana wonti.
\p 
\v 4 Pilatus nakaldra dunkana wonti ja tanangu jatana wonti: „Najianau, ngato ninaia jurangu dunkalkai, jura ngujamananto, ngato nunkangu wata madlentji mankamankai.“
\p 
\v 5 Jesus dunkana wonti ja dilka pirapira ja kati maralje ngamalkana wonti; ja nau tanangu jatana wonti: „Najianau ninaia kana!“
\p 
\v 6 Priesta pirnali ja milieli nina najinani, tana maritjina wonti ja jatana wonti: „Kunarkuni katibamai, kunarkuni katibamai!“ Pilatus tanangu jatana wonti: „Patanau jura ninaia ja kunarkuni katibanau; ngangau ngato nunkangu wata madlentji mankamankai.“
\p 
\v 7 Juda kanali nunkangu kalabana wonti: „Ngaiani jirijiribani jaura ngamalkai, ja ngaianini jirijiribani jaurandru Nauja palinanto, ngangau Nauja munta Godaia Ngatamura ngankaterina warai.“
\p 
\v 8 Pilatulu ninapini jaura matja ngarana, nau morla japali pantjina wonti.
\p 
\v 9 Ja nau nakaldra ngankamalini pungani wirina wonti ja Jesungu jatana wonti: „Wodajerindru jundru nganai?“ Jesujeli nunkangu wata kalabani jaura jinkina wonti.
\p 
\v 10 Pilatus nunkangu jatana wonti: „Wata ngakangu jundru kaukaubai? Jidni wata milkila, ngato ngurula ngamalkai jidnana kunarkuni katibala kara, ja ngurula ngamalkai jidnana kurakala?“
\p 
\v 11 Jesujeli kalabana wonti: „Jundru wata ngurula ngamalkai ngakangu, jundru nina wata mirindru maninani; jendrangundruja nulupini, nulu ngana jinkangu ngulkujeli jinkina warai, morla madlentji ngamalkai.“
\p 
\v 12 Jendrangundruja Pilatulu wontina wonti nina kurakala. Juda kana maritjina wonti ja jatana wonti: „Jundru ninapini kurakanani, jidni wata morla mitaia kaparaia kamaneli nganai; worana munta kapara ngankateriai, nau kaparaia tula nganai.“
\p 
\v 13 Pilatulu ninapini jaura matja ngarana, nulu Jesus dunkalkana wonti ja kalala jinkini pirini ngamana ngarina wonti; ninapini tanali dikai: „Marda piri; Juda kana talini Gabbatha.“
\p 
\v 14 Passa ngankingani ditji nganana wonti, ja ditji dunkani kuperi; ja nau Juda kanani jatana wonti: „Najianau jurani Kapara!“
\p 
\v 15 Tana maritjina wonti: „Woramai, woramai, kunarkuni ninaia katibamai!“ Pilatus tanangu jatana wonti: „Jurani Kapara ngato kunarkuni katibananto?“ Priesta pirnali kalabana wonti: „Ngaiani wata kapara ngamalkai, windri nina kapara Cäsar!“
\p 
\v 16 Ngadani nulu nina tanangu jinkina wonti, tanali nina kunarkuni katibananto. Tanali Jesus manina wonti ja nina wapalkana wonti.
\p 
\v 17 Ja Nulu kunarku nunkani wilimana wonti, ja Nau dunkana wonti nunkangupini piria, nina tanali dikai: „Mangatandra piri; ja Juda kana talini Golgatha.“
\p 
\v 18 Ja naka tanali nina kunarkuni katibana wonti, ja nunkangunto mandru morla, jerra pankini ja jera pankini, ja Jesus terti.
\p 
\v 19 Pilatulu bakana dakani miri dakana wonti, ja nina kunarkuni miri katibana wonti, ja jenia dakani ngananala: „Jesus Nazarethandru Juda Kanaia Kapara.“
\p 
\v 20 Ninapini dakani miri Juda kana marapujeli warapana wonti, ngangau ngurani karakara naupini piri nganana wonti, woderi tanali Jesus kunarkuni katibana wonti, ja dakani parana wonti Juda kana, Grieka kana, ja Roma kana talini.
\p 
\v 21 Juda kanaia Priesta pirna Pilatungu jatana wonti: „Wata dakamai, Juda kanaia Kapara, a‐ai, windri Naupini jatana warai: Ngani Juda kanaia Kapara nganai.“
\p 
\v 22 Pilatulu kalabana wonti: „Mina ngato dakana warai, jenia ngato dakana warai.“
\p 
\v 23 Mitaia kaparaia milieli Jesus kunarkuni matja katibana, tanali kati nunkani manina wonti ja buru mandru ja mandru ngankana wonti, milieli pilki ja pilki wora kulno, ja bakana kati pirna; ja kati pirna wata karpani nganana wonti, a‐ai, mirindru ngarinalujelu ngankana wonti.
\p 
\v 24 Tana ngankamalina wonti: „Ninaia ngaiana wata wokaribananto, a‐ai, nunkangundru ngaiana wontjani malka worananto wani nauja nganananto;“ ngangau jaura morlalu pantjinanto nauja jatai: „Tanali kati ngakani tanali puntibana wonti, ja ngakani kati pirnandru tanali wontjani malka worana wonti.“ Tananapini mitaia kaparaia milieli ngankana wonti.
\p 
\v 25 Jesuni kunarkuni ngandri nunkani ja nunkanaia ngandria kaku, Maria, Kleophani noa, ja Maria Magdalala terkana wonti.
\p 
\v 26 Jesujeli ngandri nunkani, ja nina mili, nina Nulu ngantjanala, naka terkanani najina wonti, Nau ngandrini nunkanani jatana wonti: „Widlajai, najiau jinkani ngatamura!“
\p 
\v 27 Ngadani Nau milini jatana wonti: „Najiau jinkani ngandri!“ Ja nunkangupini ditjindru milieli nana pungaia nunkanaia manina wonti.
\p 
\v 28 Ngadani, ngangau Jesus milkila nganana wonti, pratjana matja mudana warai, ngangau jaura kantji morlalu pantjinanto, Nau jatana wonti: „Ngani tertieli nganai.“
\p 
\v 29 Naka koko kulno kaldrinto manamiri terkana wonti; tanali miritipa kulno kaldrini multibana wonti, ja nina Ysopani kurana wonti, ja nina nunkangu manani kurana tarana wonti.
\p 
\v 30 Jesujeli kaldri matja manina, Nau jatana wonti: „Matja mudai!“ Ja Nau mangatandra buruna ngarina wonti ja palina wonti.
\p 
\v 31 Ngangau ngankingani ditji nganana wonti, ja palku wora wata kunarkuni parananto Sabbat ditjini, ngangau naupini Sabbat ditji pirna nganana wonti, Juda kana Pilatungu ngatjina wonti, tanali tanangu moku wokaribananto ja tanana ngarilkananto.
\p 
\v 32 Mitaia kaparaia mili wokarana wonti, ja ngoperalaia moku wokaribana wonti, ja kulno nguruni, nau nunkangunto kunarkuni parana wonti.
\p 
\v 33 Tana Jesungu wokarana wonti ja najina wonti Nau matia palina warai, tanali nina moku wata wokaribana wonti,
\p 
\v 34 A‐ai, kaparaia mili kulnujeli kaltieli nina pankitiri dakana wonti, ja nurujeli kumari ja ngapa dunkana wonti.
\p 
\v 35 Ja nulia jenia najina wonti, nulia jenia tinkari ngankana wonti, ja tinkari ngankani nunkani morlalu nganai, ja nauja milkila nauja morlalu jatai, ngangau jura morlalu ngundrananto.
\p 
\v 36 Jenia pantjina wonti, ngangau jaura morlalu pantjinanto: „Wata moku kulno tanali nina wokaribananto.“
\p 
\v 37 Ja nakaldra jaura kulno jatai: „Tanali nina najila nganai, nina tanali dakana wonti.“
\p 
\v 38 Ngadani Joseph Arimathiandru, nau Jesuja mili nganana wonti windri kurukuru, ngangau nau Juda kanandru japali nganana wonti, Pilatungu ngatjina wonti, nulu nina manuni kurananto Jesuja palku ngarilkananto. Ja Pilatulu jenia manuni kurana wonti. Nau wokarana wonti ja Jesuja palku ngarilkana wonti.
\p 
\v 39 Bakana Nikodemus wokarana wonti, nau ngopera tinkani Jesungu wokarana paraia ja kaldri pilki ja Aloe marapu matja duldruwana, padakana wonti.
\p 
\v 40 Tanali Jesu palku manina wonti ja nina katieli karana wonti kaldri pilkinto, worderu Juda kanali milingeru todina wonti.
\p 
\v 41 Nunkangu pirini karakara, woderi tanali nina kunarkuni katibana wonti, garden nganana wonti, ja gardenani narikutu marra, nunkangu wata kulno todinala.
\p 
\v 42 Naka tanali Jesu kurana wonti Juda kanaia ngankingani ditjindru, ngangau narikutu karakara nganana wonti.
\c 20
\p 
\v 1 Godaia ditjini Maria Magdalala nguramarani kuperi narikutuni wokarana wonti; ja nandru najina wonti marda narikutundru matja tiringana.
\p 
\v 2 Nani mindrina wonti ja Simon Petrungu, ja mili kulnuni, nina Jesujeli ngantjana wonti, wokarana wonti, ja pudlangu jatana wonti: „Tanali Kapara narikutundru manina warai, ja ngaiani ko, wodajeri tanali nina kurana warai.“
\p 
\v 3 Petrus ja mili kulno dunkana wonti ja narikutuni wokarana wonti.
\p 
\v 4 Pudla jela mindrina wonti, ja mili kulno ngopera nganingana wonti Petrungu, ja nau ngopera narikutuni wokarana wonti.
\p 
\v 5 Ja nulu buruna ngarina wonti, ja nulu kati paranani najina wonti, ja nau wata wirina wonti.
\p 
\v 6 Simon Petrus, nau nunkangu karipaterina, wokarana wonti, ja nau narikutuni wirina wonti ja najina wonti kati paranani,
\p 
\v 7 Ja kangukati, nina tanali nunkangu mangatandrani karala wiri, wata katini jela paranani, a‐ai, nina pilki karana wonti piri kulnuni.
\p 
\v 8 Ngadani bakana mili kulno, nau ngopera narikutuni wokarana warai, wirina wonti, ja nulu najina wonti ja morlalu ngundrana wonti.
\p 
\v 9 Ngangau tanali jaura wata milkila nganana wonti, Nau narindru tepi terkakananto.
\p 
\v 10 Pudla mili nakaldra tikana wonti pungaia.
\p 
\v 11 Maria narikutuni pankini palarani terkana wonti ja jindrana wonti. Nani jindranali narikutuni buruna ngarina wonti,
\p 
\v 12 Ja nandru angela mandru kati bulujeli ngamanani najina wonti, kulno mangatandrani ja kulno tidnani, woderi Jesu palku parana wonti.
\p 
\v 13 Ja pudla nankangu jatana wonti: „Widlajai, minandru jidni jindrai?“ Nani pudlangu jatana wonti: „Ngangau tanali Kapara ngakani manina warai, ja ngani ko, wodajeri tanali nina kurana warai.“
\p 
\v 14 Nani jenia matja jatana, nandru najina karitjina wonti, ja Jesus terkanani najina wonti; ja nani ko nganana wonti Nau Jesus nganai.
\p 
\v 15 Jesus nankangu jatana wonti: „Widlajai, minandru jidni jindrai? Worana jundru wontiai?“ Nandru ngundrana wonti, Nau gardenngamalkanietja nganai, ja nunkangu jatana wonti: „Kaparajai, jundru nina padakana warai? Jatau ngakangu woderi jundru nina kurano warai, ja ngato nina manila nganai.“
\p 
\v 16 Jesus nankangu jatana wonti: „Mariajai!“ Nani karitjina wonti ja nunkangu jatana wonti: „Rabbuni!“ jenia wondrai Ngujangujara jinkinietja.
\p 
\v 17 Jesus nankangu jatana wonti: „Ngana wata patau! ngangau ngani wata tarana warai ngakani Ngaperaia. Wapau ngatatani ngakanani ja tanangu jatau: Ngani tarai ngakani Ngaperani ja jurani Ngaperani, ja ngakani Godani ja jurani Godani.“
\p 
\v 18 Maria Magdalala wokarana wonti ja milini kaukaubana wonti nandru Kapara najina warai, ja Nau jenia nankangu jatana warai.
\lit (Ngantjani‐jaura Quasimodogeniti ditjini.)
\p 
\v 19 Nunkangupini Godaia ditji kalkaurani mili pungani jela nganana wonti mana ngurunguruni, Juda kanandru japali; Jesus wokarana wonti ja tanangu terti terkana wonti, ja tanangu jatana wonti: „Murla jurangunto nganaiatimai!“
\p 
\v 20 Ja Nau jenia matja jatana, Nau tanangu mara panki wondraterina wonti. Ja mili mankina wonti, ngangau tanali nina najina wonti.
\p 
\v 21 Jesus nakaldra tanangu jatana wonti: „Murla jurangunto nganaiatimai! Worderu Ngapili ngana jinpanala, jeruja ngato jurana jinpala wapaia.“
\p 
\v 22 Ja Nau jenia jatana, Nulu tanana pulkana wonti, ja tanangu jatana wonti: „Jaola kulikiri manianimai!
\p 
\v 23 Jura tanangu madlentji kalinganani, tanali tanangu kalingani nganananto; ja jura tanangu madlentji ngamalkanani, tanali tanangu ngamalkani nganananto.“
\b
\lit (Ngantjani‐jaura Thomas ditjini.)
\p 
\v 24 Ja Thomas, marapratjana ja mandrundru kulno, nina tanali dikai Ditymus, wata tanangunto jela nganana wonti Jesus wokaranani.
\p 
\v 25 Ja mili nguru nunkangu jatana wonti: „Ngaiani Kapara najina warai.“ Nau tanangu jatana wonti: „Wata ngato mardatjinpiri nunkani najinani ja nunkangu mardatjinpirani ngana mara wutju kuraterinani, wata ngato jenia morlalu ngundranani.“
\p 
\v 26 Ja ditji mara wora ja parkulani mili nunkani nakaldra jela nganana wonti, ja Thomas tanangunto. Jesus woka rana wonti mana ngurunguruni, ja tanangu terti terkana wonti ja jatana wonti: „Murla jurangunto nganaiatimai!“
\p 
\v 27 Ngadani Nau Thomasangu jatana wonti: „Mara wutju jinkani jera kurana pararamai, ja mara ngakani najiamai, ja mara jinkani jera kurana pararamai, ja nina pankitirini ngakanani kurateriamai, ja wata gilbariamai, a‐ai, morlalu ngundramai!“
\p 
\v 28 Thomas kalabana wonti ja nunkangu jatana wonti: „Ngakani Kaparajai, ngakani Godajai!“
\p 
\v 29 Jesus nunkangu jatana wonti: „Thomajai, jundru morlalu ngundrai; murlali pirna jenipara nganai, tana wata naji, nani ja morlalu ngundranani.“
\p 
\v 30 Bakana malka morla marapu Jesujeli ngankana wonti milini, tanali tanana wata dakana warai nunkangupini jaurani.
\p 
\v 31 Tananapini matja dakana, jura morlalu ngundrananto, Jesus morlalu Christus nganai, Godaia Ngatamura; ja jura morlalu ngundrananto ja tepi ngamalkananto nunkani talani.
\b
\c 21
\p 
\v 1 Ngadani Jesus nakaldra milini wondraterina wonti Tiberias pantuni. Nau jeruja wondraterina wonti:
\p 
\v 2 Naka jelalu nganana wonti Simon Petrus ja Thomas, nina tanali dikai Ditymus, ja Nathanaeli Kanandru Galilaiani ja Zebedäuni ngatamura wulu, ja nunkani mili mandru morla.
\p 
\v 3 Simon Petrus tanangu jatana wonti: „Ngani wapai paru manila.“ Tana nunkangu jatana wonti: „Bakana ngaiani jinkangu jela wapala nganai.“ Tana dunkana wonti ja nurujeli botani wirina wonti, ja nunkangupini tinkani tanali panila patana wonti.
\p 
\v 4 Matja tankubanarina, Jesus dirkalani terkana wonti; ja mili wata milkila nganana wonti Nau Jesus nganai.
\p 
\v 5 Jesus tanangu jatana wonti: „Kupa worajai, jura wata tajila ngamalkai?“ Tanali nunkangu kalabana wonti: „Pani.“
\p 
\v 6 Nau tanangu jatana wonti: „Bota panki ngunarani jama woranau, ja jura mankamankala nganai!“ Tanali worana wonti, ja tana ngandandarina wonti nina parumala paru marapundru.
\p 
\v 7 Naupini mili, nina Jesujeli ngantjana wonti, Petrungu jatana wonti: „Nauja Kapara nganai!“ Simon Petrulu ngarana wonti Nau Kapara ngananani, nau katieli ngampina wonti, ngangau nau balu nganana wonti, ja ngapani kulkungana wonti.
\p 
\v 8 Mili nguru botali wokarana wonti, ngangau tana wata worita nganana wonti dirkalandru, a‐ai, windri tintipitiwidri 200, ja tanali jama parunto parumana wonti.
\p 
\v 9 Tana matja dirkalaia dunkana tarana, tanali najina wonti turubilla turu paranani, ja paru nunkangupini paranani, ja buka.
\p 
\v 10 Jesus tanangu jatana wonti: „Padakanau tanangupini parundru, tananaia jura karari patana warai!“
\p 
\v 11 Simon Petrus wapana wonti, ja jama dirkalaia parumana tarana wonti, paru pirna manamiri 153. Jeruntjajeli jama wata purana wonti.
\p 
\v 12 Jesus tanangu jatana wonti: „Kaparanau, manabuka tajanau.“ Wata mili kulno wontjana wonti nina jakalkala: „Worana jidni?“ Ngangau tana milkila nganana wonti, Nau Kapara nganana wonti.
\p 
\v 13 Jesus wokarana wonti, ja buka patana wonti, ja tanangu jinkina wonti, ja bakana parundru.
\p 
\v 14 Naupini pota parkulu nganai, Jesus milini wondraterina wonti, Nau narindru matja tepi terkakana warai.
\p 
\v 15 Tanali manabuka matja tajina, Jesus Simon Petrungu jatana wonti: „Simoniai, Jonani ngatamurajai! Jundru ngana morla ngantjai tanangupini?“ Nau nunkangu jatana wonti: „Kau Kaparajai, jidni milkila, ngato jidnana ngantjai.“ Nau nunkangu jatana wonti: „Ngakani tjipi kuparu ngamalkau!“
\p 
\v 16 Nau nakaldra pota mandrula nunkangu jatana wonti: „Simon Jonaniai! Jundru ngana ngantjai?“ Nau nuukangu jatana wonti: „Kau Kaparajai, jidni milkila, ngato jidnana ngantjai.“ Nau nunkangu jatana wonti: „Ngakani tjipi ngamalkau!“
\p 
\v 17 Nau pota parkulula nunkangu jatana wonti: „Simon Jonaniai! Jundru ngana ngantjai?“ Petrus ngaurongauro nganana wonti, ngangau Nau pota parkulu nunkangu jatana wonti: „Jundru ngana ngantjai?“ Ja nau nunkangu jatana wonti: „Kaparajai, warupoto jundru milkila, jundru ngujamai, ngato jidnana ngantjai.“ Jesus nunkangu jatana wonti: „Ngakani tjipi ngamalkau!
\p 
\v 18 Morlalu, morlalu, ngani jinkangu jatai: Jidni teri ngananala, jidni munta ngampinala, ja wirarinala woderi jundru ngantjanala; jidni matja pinaru pantjina, jidni mara jinkani ngutaterila nganai, ja kulno ngurujeli jidna ngampipala nganai, ja wapalkala nganai woderu jundru wata ngantjai.“
\p 
\v 19 Ninapini Nau jatana wonti wondrala, mina narieli nulu Goda pirna ngankananto. Ja Nau jenia matja jatana, Nau nunkangu jatana wonti: „Ngakangu karipateriau!“
\lit (Ngantjani‐jaura Johannes ditjini.)
\p 
\v 20 Petrus karitjinawontikana wonti, ja nulu nina mili karipaterinani najina wonti, nina Jesujeli ngantjana wonti, nau bakana bukani nunkangu munambirini jeniterina wonti ja jatana wonti: „Kaparajai, worananau nganai nulu jidna wondawondala nganai?“
\p 
\v 21 Nina Petrulu najina, nau Jesungu jatana wonti: „Kaparajai, mina nunkangupini?“
\p 
\v 22 Jesus nunkangu jatana wonti: „Ngato ngantjanani nauja ngamananto ngani wokaranantulu, mina jenia jinkangu? Jindi ngakangu karipateriau!“
\p 
\v 23 Naupini jaura ngatatani karitjinawontiwontikana wonti: „Naupini mili wata paliai.“ Ja Jesus wata nunkangu jatana wonti: Nauja wata paliai, a‐ai, windri: Ngato ngantjanani nauja nganananto ngani wokaranantulu, mina jenia jinkangu?
\p 
\v 24 Naupini nau mili nganai, nulu tanangundru tinkari ngankai, ja tananapini dakana wonti; ja ngaiani milkila, nunkani tinkari ngankani morlalu nganai.
\p 
\v 25 Marapu morla nganai, mina Jesujeli ngankana wonti, tanali jenia pilki ja pilki dakanani, ngato ngundrai, mitali tanana jaura pratjana, matja dakanani, wata patala nganai.
\b
