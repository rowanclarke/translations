\v 14 \w Si|strong="H1571"\w* \w temen|strong="H3372"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w le|strong="H5921"\w* \w sirven|strong="H5647"\w*, \w obedecen|strong="H8085"\w* su \w voz|strong="H6963"\w* \w y|strong="H1571"\w* \w no|strong="H3808"\w* \w son|strong="H1961"\w* \w rebeldes|strong="H4784"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w Palabra|strong="H6310"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w y|strong="H1571"\w* \w si|strong="H1571"\w* \w tanto|strong="H5921"\w* ustedes \w como|strong="H1571"\w* su \w rey|strong="H4428"\w* \w sirven|strong="H5647"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*, \w harán|strong="H5647"\w* bien.
