\v 30 \w Pero|strong="G2532"\w* ¿\w qué|strong="G3588"\w* \w dice|strong="G3004"\w* \w la|strong="G3588"\w* \w Escritura|strong="G1124"\w*?  
\m Echa \w fuera|strong="G1544"\w* \w a|strong="G3326"\w* \w la|strong="G3588"\w* esclava \w y|strong="G2532"\w* \w a|strong="G3326"\w* \w su|strong="G3588"\w* \w hijo|strong="G5207"\w*, \w porque|strong="G1063"\w* \w de|strong="G3588"\w* \w ningún|strong="G3756"\w* modo \w heredará|strong="G2816"\w* \w el|strong="G3588"\w* \w hijo|strong="G5207"\w* \w de|strong="G3588"\w* \w la|strong="G3588"\w* esclava \w con|strong="G3326"\w* \w el|strong="G3588"\w* \w hijo|strong="G5207"\w* \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w libre|strong="G1658"\w*.   
\p
\v 31 \w Por|strong="G1352"\w* tanto, hermanos, \w no|strong="G3756"\w* somos \w hijos|strong="G5043"\w* \w de|strong="G3588"\w* \add la\add* esclava, sino \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w libre|strong="G1658"\w*.   
\c 5  
\s1 Libertados para la libertad  
\p
\v 1 \w Para|strong="G3361"\w* \w la|strong="G3588"\w* \w libertad|strong="G1657"\w* \w Cristo|strong="G5547"\w* nos libertó. \w Por|strong="G3588"\w* tanto estén \w firmes|strong="G4739"\w* \w y|strong="G2532"\w* \w no|strong="G3361"\w* sean sometidos \w otra|strong="G3825"\w* vez a \w yugo|strong="G2218"\w* \w de|strong="G3588"\w* esclavitud.   
\p
\v 2 Noten \w que|strong="G3754"\w* \w yo|strong="G1473"\w*, \w Pablo|strong="G3972"\w*, les \w digo|strong="G3004"\w* \w que|strong="G3754"\w* \w cuando|strong="G1437"\w* sean circuncidados, \w de|strong="G3754"\w* \w nada|strong="G3762"\w* \w los|strong="G3748"\w* beneficiará \w Cristo|strong="G5547"\w*.  
\v 3 \w Otra|strong="G3825"\w* vez \w a|strong="G1161"\w* \w todo|strong="G3956"\w* \w circuncidado|strong="G4059"\w* le digo \w que|strong="G3754"\w* \w está|strong="G3588"\w* \w obligado|strong="G3781"\w* \w a|strong="G1161"\w* practicar \w toda|strong="G3956"\w* \w la|strong="G3588"\w* \w Ley|strong="G3551"\w*.  
\v 4 \w Los|strong="G3588"\w* \w que|strong="G3588"\w* \w por|strong="G1722"\w* \add la \add*\w Ley|strong="G3551"\w* son declarados justos, fueron desligados \w de|strong="G1722"\w* \w Cristo|strong="G5547"\w*. ¡\w Cayeron|strong="G1601"\w* \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w gracia|strong="G5485"\w*!   
\p
\v 5 \w Porque|strong="G1063"\w* \w nosotros|strong="G2249"\w* \w por|strong="G1537"\w* \w el|strong="G1537"\w* \w Espíritu|strong="G4151"\w* \w de|strong="G1537"\w* \add la \add*\w fe|strong="G4102"\w* aguardamos \w por|strong="G1537"\w* \w fe|strong="G4102"\w* \w la|strong="G1537"\w* \w esperanza|strong="G1680"\w* \w de|strong="G1537"\w* \w la|strong="G1537"\w* \w justicia|strong="G1343"\w*.  
\v 6 \w Pues|strong="G1063"\w* \w en|strong="G1722"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w*, \w ni|strong="G3777"\w* \add la\add* \w circuncisión|strong="G4061"\w* \w vale|strong="G2480"\w* \w algo|strong="G5100"\w*, \w ni|strong="G3777"\w* \add la\add* incircuncisión, sino \add la\add* \w fe|strong="G4102"\w* \w que|strong="G1063"\w* se activa \w por|strong="G1223"\w* \add el \add*amor.   
\p
\v 7 \w Corrían|strong="G5143"\w* \w bien|strong="G2573"\w*. ¿\w Quién|strong="G5101"\w* les estorbó \w para|strong="G3361"\w* \w no|strong="G3361"\w* ser persuadidos \w por|strong="G5101"\w* \add la\add* verdad?  
\v 8 \w Esta|strong="G3588"\w* \w persuasión|strong="G3988"\w* \w no|strong="G3756"\w* \w es|strong="G3756"\w* \w del|strong="G3588"\w* \w que|strong="G3588"\w* \w los|strong="G3588"\w* \w llama|strong="G2564"\w*.  
\v 9 \w Un|strong="G3588"\w* poco \w de|strong="G3588"\w* \w levadura|strong="G2219"\w* \w leuda|strong="G2220"\w* \w toda|strong="G3650"\w* \w la|strong="G3588"\w* \w masa|strong="G5445"\w*.  
\v 10 \w Con|strong="G1722"\w* \w respecto|strong="G1519"\w* \w a|strong="G1519"\w* ustedes, \w me|strong="G1473"\w* convencí \w en|strong="G1722"\w* \add el\add* \w Señor|strong="G2962"\w* \w de|strong="G1722"\w* \w que|strong="G3754"\w* \w ninguna|strong="G3762"\w* \w otra|strong="G1519"\w* \w cosa|strong="G1722"\w* pensarán. \w Pero|strong="G1161"\w* \w el|strong="G3588"\w* \w que|strong="G3754"\w* \w los|strong="G3588"\w* perturba llevará \w la|strong="G3588"\w* sentencia, \w cualquiera|strong="G3748"\w* \w que|strong="G3754"\w* \w sea|strong="G3588"\w*.   
\p
\v 11 \w Yo|strong="G1473"\w*, hermanos, \w si|strong="G1487"\w* \w aún|strong="G2089"\w* \w predico|strong="G2784"\w* \add la \add*\w circuncisión|strong="G4061"\w*, ¿\w por|strong="G3588"\w* \w qué|strong="G3588"\w* soy \w todavía|strong="G2089"\w* perseguido? \w En|strong="G3588"\w* tal caso, \w el|strong="G3588"\w* \w tropiezo|strong="G4625"\w* \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w cruz|strong="G4716"\w* fue abolido.  
\v 12 ¡\w Ojalá|strong="G3785"\w* \w se|strong="G2532"\w* mutilaran \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w los|strong="G3588"\w* perturban!   
\p
\v 13 \w Porque|strong="G1063"\w* ustedes, hermanos, \w a|strong="G1519"\w* \w libertad|strong="G1657"\w* fueron \w llamados|strong="G2564"\w*. \w Solo|strong="G3441"\w* \w que|strong="G3588"\w* \w no|strong="G3361"\w* usen \w la|strong="G3588"\w* \w libertad|strong="G1657"\w* \w como|strong="G1519"\w* base \w de|strong="G1909"\w* abastecimiento \w para|strong="G1519"\w* \w la|strong="G3588"\w* naturaleza pecaminosa, \w sino|strong="G3361"\w* sírvanse \w los|strong="G3588"\w* \w unos|strong="G3588"\w* \w a|strong="G1519"\w* \w los|strong="G3588"\w* \w otros|strong="G3588"\w* \w como|strong="G1519"\w* esclavos \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w del|strong="G3588"\w* amor.  
