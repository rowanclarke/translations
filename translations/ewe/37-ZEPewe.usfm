\h Zefania 
\toc1 Zefania Ж’e agbalбәҪ 
\toc2 Zefania 
\toc3 Zef 
\mt1 Zefania 
\mt2 Ж’e agbalбәҪ 
\c 1  
\p  
\v 1 Esiae nye Yehowa Ж’e nya si va na Zefania, Kusi Ж’e vi. Kusi fofoe nye Hezekia, Hezekia fofoe nye Amaria, eye Amaria fofoe nye Gedalia. Gbedeasi la va le Yuda fia Yosia, Amon Ж’e vi ЕӢЙ”li. 
\b  
\s1 NuxЙ”xlЙ”Мғ amewo tso tsЙ”tsrЙ”Мғ si gbЙ”na la ЕӢuti 
\q1  
\v 2 вҖңMakplЙ” nu sia nu si 
\q2 le miaЖ’e anyigba dzi la Й–a Ж’ioЖ’ioЖ’io.вҖқ 
\q2 Yehowae gblЙ”e. 
\q1  
\v 3 вҖңMatsrЙ”Мғ amewo kple lГЈwo siaa; 
\q2 MatsrЙ”Мғ dziЖ’oxeviwo 
\q2 kple lГЈ siwo le atsiaЖ’u me la hГЈ 
\q2 kple nu vЙ”МғЙ–i wЙ”lawo.вҖқ 
\b  
\q1 вҖңNe metsrЙ”Мғ amegbetЙ”wo katГЈ 
\q2 le anyigba dzi,вҖқ 
\q2 Yehowae gblЙ”e. 
\s1 NugbeЙ–oЙ–o Й–e Yuda ЕӢu 
\q1  
\v 4 вҖңMado nye asi Й–e Yuda 
\q2 kple ame siwo katГЈ le Yerusalem la gbЙ”. 
\q1 MaЙ–e nu siwo katГЈ susЙ” na Baal la Й–a le teЖ’e sia; 
\q2 maЙ–e trЙ”Мғnuawo kple nunЙ”la 
\q2 siwo gasubЙ”a trЙ”Мғ hГЈ Ж’e ЕӢkЙ”wo Й–a, 
\q1  
\v 5 ame siwo dea ta agu le xЙ”wo tame hesubЙ”a dziЖ’oЕӢunuwo, 
\q2 hekpe Й–e ame siwo dea ta agu na Yehowa, 
\q2 gake wogakaa atam na Molek, 
\q1  
\v 6 kple ame siwo trЙ” le Yehowa yome, 
\q2 eye womedinЙӣ alo biaa eta sena o la siaa ЕӢu.вҖқ 
\b  
\q1  
\v 7 Mizi Й–oЙ–oe le AЖ’etЙ” Yehowa ЕӢkume, 
\q2 elabena Yehowa Ж’e ЕӢkeke la tu aЖ’e. 
\q1 Yehowa dzra vЙ”sa Й–o, eye wГІkЙ” ame 
\q2 siwo wГІkpe la hГЈ ЕӢuti. 
\b  
\q1  
\v 8 вҖңLe Yehowa Ж’e vЙ”sagbea la, 
\q2 mahe to na Yuda Ж’e dumegГЈwo kple fiaviЕӢutsuwo, 
\q1 kpakple ame siwo ta dutatЙ”wo Ж’e avЙ”wo. 
\q1  
\v 9 Le ЕӢkeke ma dzi la, 
\q2 mahe to na ame siwo katГЈ tia kpo flЙ”a kpui 
\q1 siwo le trЙ”МғxЙ”wo nu, eye woyЙ”a woЖ’e trЙ”МғxЙ”wo me 
\q2 kple ЕӢutasesбәҪ kple beble.вҖқ 
\q1  
\v 10 Yehowa be: 
\q1 вҖңLe ЕӢkeke ma dzi la, 
\q2 avifafa aЙ–i tso TЙ”melГЈgbo la nu, 
\q1 asiЖ’unu aЙ–i tso dua Ж’e akpa evelia, 
\q2 eye howЙ”wЙ” gГЈ aЙ–e aЙ–i tso togbЙӣwo dzi. 
\q1  
\v 11 Mifa avi, mi ame siwo le asiЙ–oЖ’e Ж’e nutowo me, 
\q2 miaЖ’e asitsalawo katГЈ atsrЙ”Мғ, 
\q2 eye ame siwo katГЈ dzraa klosalonuwo la hГЈ atsrЙ”Мғ. 
\q1  
\v 12 Le ЙЈe ma ЙЈi me la, 
\q2 masi akaЙ–i adi Й–ekematsЙ”lemetЙ”wo 
\q1 le Yerusalem ahe to na wo, 
\q2 ame siwo le abe wain Ж’e aЖ’e ene, 
\q1 eye wogblЙ” le woЖ’e dzi me be, 
\q2 вҖҳYehowa mawЙ” naneke mГӯ, 
\q2 eЙ–anye nyui alo vЙ”Мғ o.вҖҷ 
\q1  
\v 13 Woava ha woЖ’e kesinЙ”nu gbogboawo adzoe, 
\q2 woagbГЈ woЖ’e aЖ’ewo, 
\q1 woatso aЖ’ewo, ke womanЙ” wo me o, 
\q2 woade waingblewo, ke womano wain tso wo me o.вҖқ 
\s1 Yehowa Ж’e ЕӢkeke gГЈ la 
\q1  
\v 14 Yehowa Ж’e ЕӢkeke ma tu aЖ’e vЙ”, 
\q2 egbЙ”na kpuie. 
\q1 MiЙ–o to, 
\q2 le Yehowa Ж’e ЕӢkeke ma dzi la, 
\q1 woado ЙЈli kple vevesese, 
\q2 aКӢawЙ”lawo Ж’e ЙЈlidodo ade dzi le afi ma. 
\q1  
\v 15 Anye ЕӢkeke si dzi woatrЙ” Mawu Ж’e dЙ”medzoe akЙ” Й–e anyi; 
\q2 anye hiГЈgbe kple xaxagbe, 
\q2 anye dzЙ”gbevЙ”Мғe kple tsЙ”tsrЙ”Мғgbe. 
\q1 ЕҠkeke sia anye blukЙ” kple vivitidogbe, 
\q2 afu kple tsizidogbe, 
\q1  
\v 16 Anye aКӢakpбәҪkugbe kple aКӢaЙЈlidogbe, 
\q2 Й–e du siwo woЙ–o gli sesбәҪwo Ж’o xlГЈe 
\q1 kple gbetakpЙ”xЙ” siwo le dzogoe dzi ЕӢu. 
\b  
\q1  
\v 17 вҖңMahe xaxa va ameawo dzi, 
\q2 eye woazЙ” abe ЕӢkugbagbГЈtЙ”wo ene, 
\q2 elabena woda vo Й–e Yehowa ЕӢu. 
\q1 WoЖ’e КӢu akЙ” Й–i abe КӢuКӢudedi ene, 
\q2 eye woЖ’e dЙ”menuwo akaka abe gbeЙ–uЙ–Й” ene. 
\q1  
\v 18 Le Yehowa Ж’e dЙ”medzoeЕӢkeke sia dzi la, 
\q2 woЖ’e klosalo alo sika 
\q2 mate ЕӢu aЙ–e wo o.вҖқ 
\b  
\q1 Yehowa Ж’e ЕӢuКӢaКӢГЈ Ж’e dzo 
\q2 afia xexea me katГЈ, 
\q1 elabena atsrЙ”Мғ ame siwo katГЈ 
\q2 le anyigba dzi la kpata. 
\b  
\c 2  
\q1  
\v 1 MiЖ’o Ж’u! MiЖ’o Ж’u! 
\q2 O, dukЙ” si ЕӢu mekpena o, 
\q1  
\v 2 hafi ЙЈeyiЙЈi si woЙ–o Й–i la naЙ–o, 
\q2 eye ЕӢkeke ma nava gbЙ” mi abe atsa ene, 
\q1 hafi Yehowa Ж’e dziku dziЕӢЙ” la nava dziwГІ, 
\q2 hafi Yehowa Ж’e dЙ”medzoeЕӢkeke la nava dziwГІ. 
\q1  
\v 3 Midi Yehowa, 
\q2 mi anyigbadzitЙ” siwo katГЈ bЙ”bЙ” mia Й–okui, 
\q2 mi ame siwo wЙ”a eЖ’e lЙ”lЙ”Мғnu. 
\q1 Midi dzЙ”dzЙ”enyenye, midi Й–okuibЙ”bЙ”; 
\q2 Й–ewohД© woatsyЙ” nu mia dzi 
\q2 le Yehowa Ж’e dzikuЕӢkeke la dzi. 
\s1 NugbeЙ–oЙ–o Й–e FilistitЙ”wo ЕӢu 
\q1  
\v 4 Gaza azu aЖ’edo, 
\q2 eye Askelon azu gli gbagbГЈ. 
\q1 Le ЕӢdЙ”kutsu me woalЙ” Asdod Ж’ioЖ’ioЖ’io, 
\q2 eye woaho Ekron kple ke. 
\q1  
\v 5 Baba na mi KeretitЙ”wo, 
\q2 mi ame siwo le Ж’uta; 
\q1 O Kanaan, FilistitЙ”wo Ж’e anyigba, Yehowa tsЙ” nya Й–e mia ЕӢu be, 
\q2 вҖңMatsrЙ”Мғ mi keЕӢkeЕӢkeЕӢ, eye ame aЙ–eke masusЙ” o.вҖқ 
\q1  
\v 6 KeretitЙ”wo Ж’e nЙ”Ж’e si le Ж’uta la, 
\q2 azu alбәҪkpo kple nЙ”Ж’e na alбәҪkplЙ”lawo. 
\q1  
\v 7 Anye ame mamlЙӣ siwo susЙ” na Yuda Ж’e aЖ’e la tЙ”, 
\q2 afi mae woakpЙ” lГЈnyiЖ’e le. 
\q1 Le fiбәҪ me la, woamlЙ” AskelontЙ”wo Ж’e aЖ’ewo me. 
\q2 Yehowa, woЖ’e Mawu la 
\q2 akpЙ” wo ta, eye wГІagaЙ–o wo te. 
\s1 NugbeЙ–oЙ–o Й–e Moab kple Amon ЕӢu 
\q1  
\v 8 вҖңMese Moab Ж’e alЙ”meЙ–eЙ–e 
\q2 kple Amon Ж’e viwo Ж’e vlododo, 
\q1 ame siwo dzi nye dukЙ”, 
\q2 eye woЙ–o nugbe Й–e woЖ’e anyigba ЕӢuti. 
\q1  
\v 9 Yehowa ЕҠusбәҪkatГЈtЙ”, Israel Ж’e Mawu la gblЙ” be, 
\q2 Zi ale si meli la, woatsrЙ”Мғ Moab kple Amon 
\q1 abe ale si wotsrЙ”Мғ Sodom kple Gomora ene, 
\q2 eye woazu ЕӢuvedzeЙ–eЖ’e kple gbegbe; 
\q1 nye ame siwo susЙ” la aha wo, 
\q2 eye woaxЙ”e le wo si.вҖқ 
\b  
\q1  
\v 10 WoaxЙ” woЖ’e dada Ж’e fetu, 
\q2 elabena woЙ–u fewu le Yehowa, 
\q2 DziЖ’oКӢakЙ”wo Ж’e AЖ’etЙ” la Ж’e dukЙ” ЕӢuti. 
\q1  
\v 11 Yehowa ana nu vЙ”МғЙ–i geЙ–e nava wo dzi. 
\q2 AtsrЙ”Мғ woЖ’e mawuwo katГЈ 
\q1 kple woЖ’e ЕӢusбәҪ Й–a, eye ame sia ame asubЙ”e le 
\q2 eЖ’e anyigba dzi le xexea me godoo. 
\s1 NugbeЙ–oЙ–o Й–e Kus ЕӢu 
\q1  
\v 12 вҖңMi KustЙ”wo, 
\q2 woatsrЙ”Мғ miawo hГЈ kple yi.вҖқ 
\s1 NugbeЙ–oЙ–o Й–e Asiria ЕӢu 
\q1  
\v 13 Nenema kee nye anyiehetЙ”wo hГЈ; 
\q2 atsrЙ”Мғ Asiria kple eЖ’e toxЙ”du Ninive xЙ”ЕӢkЙ” la gbidigbidi, 
\q2 eye wГІanЙ” abe dzogbe ene. 
\q1  
\v 14 Du xЙ”ЕӢkЙ” sia azu gbeЙ–uЖ’e na alбәҪhawo. 
\q2 GbemelГЈ kple xe vovovowo atsЙ” teЖ’e sia awЙ” wo nЙ”Ж’ee. 
\q1 HlЙ”Мғmadewo aЙ–e do Й–e afi ma, 
\q2 akagawo kple alugewo awЙ” atЙ” Й–e eЖ’e fiasГЈwo me, 
\q1 eye woadzo Й–e eЖ’e fesrewo nu anЙ” xЙ”xlЙ”Мғm; 
\q2 eye akpaviГЈwo adzo Й–e fiasГЈ la Ж’e КӢЙ”truwo nu. 
\q1 MlЙ”eba la, КӢuЖ’o nyui 
\q2 siwo wotsЙ” wЙ” xЙ”a mee la atsi gota ЕӢdЙ” naЙ–u. 
\q1  
\v 15 Esiawoe nye nu siwo ava dzЙ” Й–e du si kpЙ” dzidzedze, 
\q2 eye wГІle tomefafa me la dzi. 
\q1 Du sia gblЙ” na eЙ–okui be, 
\q2 вҖңLe xexea me katГЈ la, 
\q2 du aЙ–eke mekpЙ” ЕӢusбәҪ de nunye o.вҖқ 
\q1 Gake azЙ”, mikpЙ” Й–a, 
\q2 eyae nye du si gbГЈ gudugudu, 
\q2 zu gbegbe na lГЈwo kple xewo! 
\q1 AzЙ” ame sia ame si ava to eЕӢuti la ado tsiГЈ, 
\q2 aКӢuКӢu ta, elabena maxЙ”e ase o. 
\c 3  
\s2 Nya siwo ava dzЙ” Й–e Yerusalem dzi 
\q1  
\v 1 вҖңBaba na du si yЙ” fЕ©u kple ЕӢutasesбәҪ, 
\q2 aglГЈdzedze kple Й–iЖ’oЖ’o. 
\q1  
\v 2 Mesea ame aЙ–eke Ж’e gbe o, 
\q2 eye melЙ”Мғna be woagbe nya na ye hГЈ o. 
\q1 MexЙ” Yehowa dzi se o, 
\q2 eye metena Й–e eЖ’e Mawu la ЕӢu hГЈ o. 
\q1  
\v 3 EЖ’e kplЙ”lawo le abe dzata 
\q2 dЙ”wui si le gbe tem la ene. 
\q1 WoЖ’e КӢЙ”nudrЙ”Мғlawo le abe amegaxi si lГ© nu 
\q2 le zГЈ me, eye wГІЙ–ui vЙ” keЕӢ hafi ЕӢu ke la ene. 
\q1  
\v 4 EЖ’e nyagblЙ”Й–ilawo doa wo Й–okuiwo Й–e dzi, 
\q2 eye wonye ame vЙ”МғЙ–iwo. 
\q1 EЖ’e nunЙ”lawo do gu kЙ”kЙ”eЖ’e la, 
\q2 eye wodo vlo Mawu Ж’e seawo. 
\q1  
\v 5 Ke Yehowae nye dzЙ”dzЙ”etЙ” le wo dome, 
\q2 eye mewЙ”a nu gbegblбәҪ aЙ–eke o. 
\q1 ЕҠdi sia ЕӢdi la, 
\q2 eЙ–ea eЖ’e dzЙ”dzЙ”enyenye Й–e go, 
\q1 eye ЕӢkeke aЙ–eke medanЙӣ Ж’u o. 
\q2 Gake nu vЙ”Мғ wЙ”lawo menya ЕӢukpe o. 
\b  
\q1  
\v 6 вҖңMetsrЙ”Мғ dukЙ” geЙ–ewo, 
\q2 megbГЈ woЖ’e mЙ” sesбәҪwo, 
\q1 mena woЖ’e ablЙ”wo dzi Й–i gbЙ”lo, 
\q2 eye ame aЙ–eke megatoa wo dzi o. 
\q1 WoЖ’e duwo gbГЈ, 
\q2 eye ame Й–eka pЙӣ gЙ”Мғ hГЈ masusЙ” o. 
\q1  
\v 7 MegblЙ” na du la be, 
\q2 вҖҳAzЙ” la, Г vЙ”Мғm vavГЈ, eye nГ xЙ” nye Й–Й”Й–Й”Й–o!вҖҷ 
\q1 Ekema womagatsrЙ”Мғ eЖ’e nЙ”Ж’e 
\q2 alo nye tohehe magava edzi o, 
\q2 gake wogatsi dzi Й–e nu vЙ”Мғ wЙ”wЙ” ЕӢu, 
\q1  
\v 8 eya ta mikpЙ” nye asi nu,вҖқ 
\q2 Yehowae gblЙ”e, 
\q1 вҖңelabena ЕӢkeke li gbЙ”na, 
\q2 matsi tsitre aЙ–i Й–ase. 
\q1 MeЙ–oe be maЖ’o dukЙ”wo katГЈ 
\q2 kple fiaЙ–uЖ’ewo nu Ж’u, 
\q1 eye makЙ” nye dЙ”medzoe 
\q2 kple nye dziku helД©helД© Й–e wo dzi. 
\q1 Ale nye ЕӢuКӢaКӢГЈ Ж’e dzo afia anyigba la katГЈ. 
\b  
\q1  
\v 9 вҖңЖ”e ma ЙЈi la, makЙ” nye amewo Ж’e nuyiwo ЕӢu, 
\q2 ale wo katГЈ woayЙ” Yehowa Ж’e ЕӢkЙ”, 
\q2 eye woasubЙ”e kple nusЙ”sЙ”e. 
\q1  
\v 10 Tso Kus tЙ”sisi la godo ke, nye subЙ”lawo 
\q2 kple nye ame siwo ka hlбәҪ la, 
\q2 atsЙ” woЖ’e nunanawo vЙӣ nam. 
\q1  
\v 11 Le ЙЈe ma ЙЈi la, 
\q2 ЕӢu magakpe mi le miaЖ’e nu vЙ”Мғ 
\q1 siwo katГЈ miewЙ” Й–e ЕӢunye la ta o, 
\q2 elabena maЙ–e ame siwo katГЈ kpЙ”a 
\q1 dzidzЙ” le Й–okuidodoЙ–edzi ЕӢuti la Й–a 
\q2 le dua me, ale be dadala 
\q2 aЙ–eke maganЙ” nye to kЙ”kЙ”e la dzi o. 
\q1  
\v 12 Ke magblбәҪ ame siwo nye ame fafawo 
\q2 kple Й–okuibЙ”bЙ”Й–eanyilawo, 
\q1 ame siwo xЙ” nye, Yehowa 
\q2 Ж’e ЕӢkЙ” dzi se la Й–e mia dome. 
\q1  
\v 13 Israel Ж’e ame mamlЙӣawo magawЙ” vЙ”Мғ o, 
\q2 womada alakpa o, 
\q1 eye womakpЙ” amebeble le woЖ’e nu me o. 
\q2 WoaЙ–u nu, amlЙ” anyi, 
\q2 eye ame aЙ–eke mado ЕӢЙ”dzi na wo o.вҖқ 
\b  
\q1  
\v 14 O Zion vinyЙ”nu, dzi ha, O Israel, do ЙЈli, 
\q2 kpЙ” dzidzЙ”, eye wГІ dzi nayЙ” fЕ©u kple aseyetsotso, 
\q2 O Yerusalem vinyЙ”nuvi! 
\q1  
\v 15 Yehowa Й–e wГІ tohehewo Й–a, 
\q2 eye wГІna wГІ futЙ”wo gbugbЙ”Й–emegbe. 
\q1 Yehowa, Israel Ж’e fia la 
\q2 li kpli wГІ, eya ta vЙ”МғwЙ”ame 
\q2 aЙ–eke mado ЕӢЙ”dzi na wГІ o. 
\q1  
\v 16 Gbe ma gbe la, 
\q2 woagblЙ” na Yerusalem be, 
\q1 вҖңMГЁgavЙ”Мғ o, O Zion, 
\q2 eye mГЁgana wГІ alЙ” nagbЙ”dzЙ” o. 
\q1  
\v 17 Yehowa wГІ Mawu la li kpli wГІ, 
\q2 kalбәҪtЙ” si ate ЕӢu axЙ” na wГІ lae wГІnye. 
\q1 AkpЙ” dzidzЙ” gГЈ aЙ–e Й–e ЕӢuwГІ, 
\q2 atsЙ” eЖ’e lЙ”lЙ”Мғ afa akЙ” na wГІ, 
\q2 eye wГІado dzidzЙ” na wГІ kple hadzidzi.вҖқ 
\b  
\q1  
\v 18 вҖңMaЙ–e konyifafa siwo nЙ”a miaЖ’e takpegbewo la Й–a le mia ЕӢu, 
\q2 elabena wonyea agba kple mokaka na mi. 
\q1  
\v 19 Le ЙЈe ma ЙЈi la, matu nu 
\q2 kple ame siwo katГЈ te mi Й–e anyi la, 
\q1 makpe Й–e ataЕӢeЕӢetЙ”wo ЕӢu, 
\q2 eye maЖ’o ame siwo ka hlбәҪ la nu Ж’u. 
\q1 MatsЙ” kafukafu kple bubu ana wo 
\q2 le anyigba Й–e sia Й–e si dzi wodo ЕӢukpe wo le. 
\q1  
\v 20 Ж”e ma yi la, maЖ’o mia nu Ж’u; 
\q2 ЙЈe ma yi me la, makplЙ” mi va aЖ’ee. 
\q1 MatsЙ” bubu kple kafukafu ana mi le 
\q2 anyigbadzidukЙ”wo katГЈ dome, 
\q1 nenye be megbugbЙ” mi Й–o te le 
\q2 miawo ЕӢutЙ” Ж’e ЕӢkuwo me.вҖқ 
\q2 Yehowae gblЙ”e.