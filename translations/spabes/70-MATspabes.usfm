\v 1 Libro de la genealogía de \w Jesucristo|strong="G2424"\w*, \w hijo|strong="G5207"\w* de \w David|strong="G1138"\w*, \w hijo|strong="G5207"\w* de Abraham.
\p 
\v 2 Abraham fue padre \w de|strong="G3588"\w* \w Isaac|strong="G2464"\w*; \w Isaac|strong="G2464"\w* fue padre \w de|strong="G3588"\w* \w Jacob|strong="G2384"\w*; \w Jacob|strong="G2384"\w* fue padre \w de|strong="G3588"\w* Judá \w y|strong="G2532"\w* \w de|strong="G3588"\w* \w sus|strong="G3588"\w* hermanos;
