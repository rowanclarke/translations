\v 27 \wj \+w El|strong="H3588"\+w* \+w rey|strong="H4428"\+w* lamentará \+w y|strong="H3588"\+w* \+w los|strong="H3588"\+w* magistrados \+w se|strong="H3045"\+w* cubrirán \+w de|strong="H3588"\+w* horror. Temblarán las \+w manos|strong="H3027"\+w* del \+w pueblo|strong="H5971"\+w* \+w de|strong="H3588"\+w* \+w la|strong="H3588"\+w* tierra. \+w Los|strong="H3588"\+w* trataré según \+w su|strong="H3588"\+w* conducta. \+w Los|strong="H3588"\+w* \+w juzgaré|strong="H8199"\+w* según sus \+w juicios|strong="H4941"\+w*. \+w Y|strong="H3068"\+w* \+w sabrán|strong="H3045"\+w* \+w que|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* soy \+nd \+w Yavé|strong="H3068"\+w*\+nd*.\wj*   
\c 8  
\s1 La contaminación de la Casa de \nd Yavé\nd*  
\p
\v 1 \w El|strong="H5921"\w* \w año|strong="H8141"\w* \w sexto|strong="H8345"\w*, \w el|strong="H5921"\w* quinto día \w del|strong="H5921"\w* \w mes|strong="H2320"\w* \w sexto|strong="H8345"\w*, \w cuando|strong="H1961"\w* yo \w estaba|strong="H1961"\w* \w sentado|strong="H3427"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w casa|strong="H1004"\w* \w y|strong="H5921"\w* \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w sentados|strong="H3427"\w* frente \w a|strong="H3068"\w* \w mí|strong="H5921"\w*, \w sucedió|strong="H1961"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd* \w cayó|strong="H5307"\w* \w allí|strong="H8033"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*.  
\v 2 Entonces \w miré|strong="H7200"\w* y \w vi|strong="H7200"\w* una \w figura|strong="H1823"\w* \w como|strong="H1823"\w* \w de|strong="H5869"\w* hombre. Desde su cintura hacia \w abajo|strong="H4295"\w* era \w como|strong="H1823"\w* \w de|strong="H5869"\w* fuego, y desde su cintura hacia \w arriba|strong="H4605"\w* era \w como|strong="H1823"\w* un resplandor, \w como|strong="H1823"\w* un metal refulgente.   
\p
\v 3 \w Extendió|strong="H7971"\w* como la forma de una \w mano|strong="H3027"\w* y me \w tomó|strong="H3947"\w* \w por|strong="H3027"\w* un mechón de \w mi|strong="H3389"\w* \w cabeza|strong="H7218"\w*. El \w Espíritu|strong="H7307"\w* me \w levantó|strong="H5375"\w* \w entre|strong="H8033"\w* la tierra y el \w cielo|strong="H8064"\w*. En \w visiones|strong="H4759"\w* de \nd ʼElohim\nd* me \w llevó|strong="H3947"\w* \w a|strong="H3068"\w* Jerusalén, \w a|strong="H3068"\w* la entrada del \add patio\add* interno \w que|strong="H3027"\w* \w mira|strong="H6437"\w* \w hacia|strong="H8033"\w* el \w norte|strong="H6828"\w*, \w donde|strong="H8033"\w* estaba puesto el ídolo de los celos, el cual provoca celos.  
\v 4 \w Vi|strong="H7200"\w* que la \w gloria|strong="H3519"\w* del \nd ʼElohim\nd* de \w Israel|strong="H3478"\w* \w estaba|strong="H2009"\w* \w allí|strong="H8033"\w*, conforme \w a|strong="H3068"\w* la \w visión|strong="H4758"\w* que \w yo|strong="H2009"\w* tuve en la llanura.   
\p
\v 5 \w Y|strong="H3068"\w* me dijo: \wj \+w Hijo|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w hombre|strong="H1121"\+w*, \+w levanta|strong="H5375"\+w* \+w ahora|strong="H4994"\+w* tus \+w ojos|strong="H5869"\+w* \+w hacia|strong="H1870"\+w* \+w el|strong="H1121"\+w* \+w norte|strong="H6828"\+w*.\wj*  
\p \w Y|strong="H3068"\w* levanté \w mis|strong="H5375"\w* \w ojos|strong="H5869"\w* \w hacia|strong="H1870"\w* \w el|strong="H1121"\w* \w norte|strong="H6828"\w*. Vi \w que|strong="H4994"\w* en la entrada, al \w norte|strong="H6828"\w* \w de|strong="H1121"\w* la \w puerta|strong="H8179"\w* \w del|strong="H4196"\w* \w altar|strong="H4196"\w*, \w estaba|strong="H2009"\w* \w el|strong="H1121"\w* ídolo \w de|strong="H1121"\w* \w los|strong="H1121"\w* celos.   
\p
\v 6 \w Él|strong="H5921"\w* \w me|strong="H5921"\w* dijo: \wj \+w Hijo|strong="H1121"\+w* \+w de|strong="H5921"\+w* \+w hombre|strong="H1121"\+w*, ¿\+w viste|strong="H7200"\+w* \+w lo|strong="H5921"\+w* \+w que|strong="H5921"\+w* \+w ellos|strong="H1992"\+w* \+w hacen|strong="H6213"\+w*? Son \+w las|strong="H1992"\+w* \+w grandes|strong="H1419"\+w* repugnancias \+w que|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w Casa|strong="H1004"\+w* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w* \+w hace|strong="H6213"\+w* \+w aquí|strong="H6311"\+w* \+w para|strong="H5921"\+w* \+w que|strong="H5921"\+w* \+w Yo|strong="H6213"\+w* \+w me|strong="H5921"\+w* aleje \+w de|strong="H5921"\+w* \+w mi|strong="H5921"\+w* \+w Santuario|strong="H4720"\+w*. Pero \+w aún|strong="H5750"\+w* \+w verás|strong="H7200"\+w* repugnancias \+w mayores|strong="H1419"\+w*.\wj*   
\p
\v 7 Entonces me llevó \w a|strong="H3068"\w* la entrada del \w patio|strong="H2691"\w*. Cuando \w miré|strong="H7200"\w*, había un hueco en la \w pared|strong="H7023"\w*.  
\v 8 \w Él|strong="H1121"\w* me dijo: \wj \+w Hijo|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w hombre|strong="H1121"\+w*, perfora \+w ahora|strong="H4994"\+w* \+w el|strong="H1121"\+w* muro.\wj*  
\p \w Y|strong="H3068"\w* cuando perforé \w el|strong="H1121"\w* muro, vi una \w puerta|strong="H6607"\w*.   
\p
\v 9 Me dijo: \wj Entra y \+w ve|strong="H7200"\+w* \+w las|strong="H1992"\+w* perversas repugnancias \+w que|strong="H1992"\+w* \+w ellos|strong="H1992"\+w* cometen \+w aquí|strong="H6311"\+w*.\wj*   
\p
\v 10 Así \w que|strong="H5921"\w* \w entré|strong="H5921"\w* \w y|strong="H5921"\w* observé. \w Vi|strong="H7200"\w* \w toda|strong="H3605"\w* forma \w de|strong="H5921"\w* \w reptiles|strong="H7431"\w* \w y|strong="H5921"\w* animales repugnantes, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w ídolos|strong="H1544"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w pintados|strong="H2707"\w* \w en|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* paredes \w alrededor|strong="H5439"\w*.  
\v 11 \w Delante|strong="H6440"\w* \w de|strong="H6440"\w* \w ellos|strong="H3027"\w* \w estaban|strong="H5975"\w* 70 \w ancianos|strong="H2205"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w en|strong="H8432"\w* \w pie|strong="H5975"\w*, con Jaazanías, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Safán, \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H6440"\w* \w ellos|strong="H3027"\w*, cada uno con su incensario \w en|strong="H8432"\w* la \w mano|strong="H3027"\w*. \w Subía|strong="H5927"\w* una espesa \w nube|strong="H6051"\w* \w de|strong="H6440"\w* incienso.   
\p
\v 12 \w Y|strong="H3068"\w* \w me|strong="H3588"\w* dijo: \wj \+w Hijo|strong="H1121"\+w* \+w de|strong="H3588"\+w* \+w hombre|strong="H1121"\+w*, ¿\+w Viste|strong="H7200"\+w* \+w lo|strong="H6213"\+w* \+w que|strong="H3588"\+w* \+w los|strong="H1121"\+w* \+w ancianos|strong="H2205"\+w* \+w de|strong="H3588"\+w* \+w la|strong="H3588"\+w* \+w Casa|strong="H1004"\+w* \+w de|strong="H3588"\+w* \+w Israel|strong="H3478"\+w* \+w hacen|strong="H6213"\+w* \+w en|strong="H3588"\+w* \+w la|strong="H3588"\+w* \+w oscuridad|strong="H2822"\+w*, cada uno \+w en|strong="H3588"\+w* \+w la|strong="H3588"\+w* \+w cámara|strong="H2315"\+w* \+w de|strong="H3588"\+w* \+w su|strong="H3588"\+w* ídolo? \+w Porque|strong="H3588"\+w* dicen: \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w no|strong="H6213"\+w* nos \+w ve|strong="H7200"\+w*. \+nd \+w Yavé|strong="H3068"\+w*\+nd* abandonó \+w la|strong="H3588"\+w* tierra.\wj*  
\v 13 \w Y|strong="H3068"\w* me dijo: \wj \+w Verás|strong="H7200"\+w* repugnancias \+w aún|strong="H5750"\+w* \+w mayores|strong="H1419"\+w* \+w que|strong="H1992"\+w* \+w ellos|strong="H1992"\+w* cometen.\wj*   
\p
\v 14 Me llevó junto \w a|strong="H3068"\w* la \w puerta|strong="H6607"\w* \w norte|strong="H6828"\w* de la \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*, y vi \w allí|strong="H8033"\w* mujeres \w sentadas|strong="H3427"\w* que llevaban \w a|strong="H3068"\w* Tamuz.\f + \fr 8:14 \ft Tamuz: Deidad siria de origen caldeo.\f*  
\v 15 \w Luego|strong="H7725"\w* me dijo: \wj ¿\+w Ves|strong="H7200"\+w*, \+w hijo|strong="H1121"\+w* \+w de|strong="H5750"\+w* \+w hombre|strong="H1121"\+w*? ¡\+w Pues|strong="H7200"\+w* \+w aún|strong="H5750"\+w* \+w verás|strong="H7200"\+w* \+w mayores|strong="H1419"\+w* repugnancias \+w que|strong="H1121"\+w* éstas!\wj*   
\p
\v 16 Entonces me llevó al \w patio|strong="H2691"\w* interno \w de|strong="H6440"\w* la \w Casa|strong="H1004"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. Vi \w que|strong="H2691"\w* entre \w el|strong="H1992"\w* \w patio|strong="H2691"\w* y \w el|strong="H1992"\w* \w altar|strong="H4196"\w* en la entrada \w de|strong="H6440"\w* la \w Casa|strong="H1004"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* estaban \w unos|strong="H1992"\w* 25 varones con \w sus|strong="H1992"\w* caras \w hacia|strong="H6440"\w* \w el|strong="H1992"\w* \w oriente|strong="H6924"\w*, \w de|strong="H6440"\w* espalda \w a|strong="H3068"\w* la \w Casa|strong="H1004"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. Estaban postrados \w hacia|strong="H6440"\w* \w el|strong="H1992"\w* \w oriente|strong="H6924"\w*, \w hacia|strong="H6440"\w* \w el|strong="H1992"\w* \w sol|strong="H8121"\w*.   
\p
\v 17 \w Y|strong="H3068"\w* \w me|strong="H3588"\w* dijo: \wj ¿\+w Ves|strong="H7200"\+w*, \+w hijo|strong="H1121"\+w* \+w de|strong="H3588"\+w* \+w hombre|strong="H1121"\+w*? ¿Le parece \+w poco|strong="H7043"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H3588"\+w* \+w Casa|strong="H1004"\+w* \+w de|strong="H3588"\+w* \+w Judá|strong="H3063"\+w* cometer las repugnancias \+w que|strong="H3588"\+w* cometen \+w aquí|strong="H6311"\+w*? \+w Porque|strong="H3588"\+w* \+w llenaron|strong="H4390"\+w* \+w la|strong="H3588"\+w* tierra \+w de|strong="H3588"\+w* \+w violencia|strong="H2555"\+w*. \+w Me|strong="H3588"\+w* provocan repetidamente. Míralos \+w ahora|strong="H6311"\+w* \+w cuando|strong="H3588"\+w* ponen \+w la|strong="H3588"\+w* rama \+w en|strong="H3588"\+w* sus fosas nasales.\wj*  
\v 18 \wj Por tanto \+w Yo|strong="H6213"\+w* \+w también|strong="H1571"\+w* los trataré \+w con|strong="H1571"\+w* \+w furor|strong="H2534"\+w*. Mi \+w ojo|strong="H5869"\+w* \+w no|strong="H3808"\+w* tendrá compasión, \+w ni|strong="H3808"\+w* \+w perdonaré|strong="H2550"\+w*. \+w Claman|strong="H7121"\+w* \+w a|strong="H3068"\+w* \+w gran|strong="H1419"\+w* \+w voz|strong="H6963"\+w* \+w a|strong="H3068"\+w* mis \+w oídos|strong="H8085"\+w*, \+w y|strong="H1571"\+w* \+w no|strong="H3808"\+w* los \+w escucho|strong="H8085"\+w*.\wj*   
\c 9  
\s1 Mortandad en Jerusalén  
\p
\v 1 Entonces lo oí proclamar en \w alta|strong="H1419"\w* \w voz|strong="H6963"\w*: \wj ¡Acérquense los verdugos de la \+w ciudad|strong="H5892"\+w*, y empuñe cada uno su arma mortal!\wj*   
\p
\v 2 \w Súbitamente|strong="H2009"\w* llegaron \w seis|strong="H8337"\w* varones \w por|strong="H1870"\w* el \w camino|strong="H1870"\w* \w de|strong="H3847"\w* la \w puerta|strong="H8179"\w* \w de|strong="H3847"\w* arriba, la cual \w mira|strong="H2009"\w* al \w norte|strong="H6828"\w*. Cada uno empuñaba su arma destructora. \w En|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3847"\w* \w ellos|strong="H3027"\w* \w estaba|strong="H5975"\w* un varón cubierto \w de|strong="H3847"\w* lino blanco, con un tintero \w de|strong="H3847"\w* \w escriba|strong="H5608"\w* atado \w a|strong="H3068"\w* su cintura. Entraron y se mantuvieron \w en|strong="H8432"\w* \w pie|strong="H5975"\w* \w junto|strong="H3027"\w* al \w altar|strong="H4196"\w* \w de|strong="H3847"\w* bronce.   
\p
\v 3 Entonces \w la|strong="H5921"\w* \w gloria|strong="H3519"\w* \w del|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w que|strong="H5921"\w* \w estaba|strong="H1961"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w querubines|strong="H3742"\w* \w se|strong="H1961"\w* elevó \w de|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* dirección \w a|strong="H3068"\w* \w la|strong="H5921"\w* entrada \w del|strong="H5921"\w* \w Templo|strong="H1004"\w*. \w Llamó|strong="H7121"\w* \w al|strong="H5921"\w* varón cubierto \w de|strong="H5921"\w* lino blanco, quien \w tenía|strong="H1961"\w* \w el|strong="H5921"\w* tintero \w de|strong="H5921"\w* \w escriba|strong="H5608"\w* atado \w a|strong="H3068"\w* su cintura.  
\v 4 \nd \+w Yavé|strong="H3068"\+w*\nd* \w le|strong="H5921"\w* dijo: \wj \+w Pasa|strong="H5674"\+w* \+w por|strong="H5921"\+w* \+w en|strong="H5921"\+w* \+w medio|strong="H8432"\+w* \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w ciudad|strong="H5892"\+w*, \+w por|strong="H5921"\+w* \+w en|strong="H5921"\+w* \+w medio|strong="H8432"\+w* \+w de|strong="H5921"\+w* Jerusalén. Pon una señal \+w en|strong="H5921"\+w* \+w las|strong="H5921"\+w* frentes \+w de|strong="H5921"\+w* \+w los|strong="H5921"\+w* hombres \+w que|strong="H5921"\+w* gimen \+w y|strong="H5921"\+w* \+w se|strong="H5921"\+w* angustian \+w a|strong="H3068"\+w* causa \+w de|strong="H5921"\+w* \+w todas|strong="H3605"\+w* \+w las|strong="H5921"\+w* repugnancias \+w que|strong="H5921"\+w* \+w se|strong="H5921"\+w* cometen \+w en|strong="H5921"\+w* \+w medio|strong="H8432"\+w* \+w de|strong="H5921"\+w* \+w ella|strong="H5921"\+w*.\wj*   
\p
\v 5 \w Luego|strong="H5674"\w* oí cuando dijo \w a|strong="H3068"\w* \w los|strong="H5921"\w* otros: \wj Pasen \+w por|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w ciudad|strong="H5892"\+w* tras \+w él|strong="H5921"\+w* \+w y|strong="H5921"\+w* maten. Su \+w ojo|strong="H5869"\+w* \+w no|strong="H5921"\+w* \+w perdone|strong="H2347"\+w* ni tenga compasión\wj*  
\v 6 \wj \+w al|strong="H5921"\+w* \+w anciano|strong="H2205"\+w*, \+w al|strong="H5921"\+w* joven, \+w a|strong="H3068"\+w* \+w la|strong="H5921"\+w* doncella, \+w a|strong="H3068"\+w* \+w los|strong="H5921"\+w* \+w niños|strong="H2945"\+w* \+w y|strong="H5921"\+w* \+w a|strong="H3068"\+w* \+w las|strong="H5921"\+w* mujeres. Mátenlos \+w hasta|strong="H5921"\+w* exterminarlos. Pero \+w no|strong="H5921"\+w* toquen \+w a|strong="H3068"\+w* \+w ninguno|strong="H3605"\+w* \+w en|strong="H5921"\+w* \+w quien|strong="H3605"\+w* esté \+w la|strong="H5921"\+w* señal. Comiencen \+w por|strong="H5921"\+w* \+w mi|strong="H5921"\+w* \+w Santuario|strong="H4720"\+w*.\wj*  
\p Así \w que|strong="H5921"\w* \w comenzaron|strong="H2490"\w* \w por|strong="H5921"\w* \w los|strong="H5921"\w* \w ancianos|strong="H2205"\w* \w que|strong="H5921"\w* estaban \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w Templo|strong="H1004"\w*.   
\p
\v 7 \w Y|strong="H3068"\w* Él les ordenó: \wj Contaminen el \+w Templo|strong="H1004"\+w* y llenen los \+w patios|strong="H2691"\+w* de asesinados. ¡\+w Salgan|strong="H3318"\+w* ya!\wj*  
\p \w Y|strong="H3068"\w* \w salieron|strong="H3318"\w* y \w mataron|strong="H5221"\w* \w en|strong="H3318"\w* la \w ciudad|strong="H5892"\w*.  
\v 8 \w Aconteció|strong="H1961"\w* \w que|strong="H5921"\w* yo \w quedé|strong="H7604"\w* solo \w mientras|strong="H3605"\w* \w ellos|strong="H5921"\w* mataban. \w Me|strong="H5921"\w* postré \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w rostro|strong="H6440"\w* \w y|strong="H5921"\w* \w clamé|strong="H2199"\w*: ¡Ah, \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd*! ¿\w Destruirás|strong="H7843"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* remanente \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w al|strong="H5921"\w* derramar \w todo|strong="H3605"\w* tu \w furor|strong="H2534"\w* \w sobre|strong="H5921"\w* Jerusalén?   
\p
