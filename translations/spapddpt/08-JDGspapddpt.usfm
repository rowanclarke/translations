\v 54 Él \w llamó|strong="H7121"\w* apresuradamente \w a|strong="H3068"\w* su joven \w escudero|strong="H5375"\w* y le dijo: Desenvaina tu \w espada|strong="H2719"\w* y mátame, para \w que|strong="H6435"\w* \w no|strong="H6435"\w* \w se|strong="H6435"\w* diga de \w mí|strong="H5375"\w*: ¡Una mujer lo \w mató|strong="H2026"\w*! \w Y|strong="H3068"\w* el \w muchacho|strong="H5288"\w* lo traspasó y \w murió|strong="H4191"\w*.
\v 55 \w Cuando|strong="H3588"\w* \w los|strong="H3588"\w* hombres \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w vieron|strong="H7200"\w* \w que|strong="H3588"\w* Abimelec \w murió|strong="H4191"\w*, cada uno se \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w lugar|strong="H4725"\w*.
\p 
\v 56 Así \nd ʼElohim\nd* retribuyó \w a|strong="H3068"\w* Abimelec \w el|strong="H6213"\w* \w mal|strong="H7451"\w* que \w hizo|strong="H6213"\w* contra su padre, al asesinar \w a|strong="H3068"\w* sus 70 hermanos.
\v 57 También \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w maldad|strong="H7451"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H1121"\w* Siquem \nd ʼElohim\nd* \w la|strong="H3605"\w* hizo caer sobre sus propias \w cabezas|strong="H7218"\w*, \w de|strong="H1121"\w* manera \w que|strong="H1121"\w* vino sobre \w ellos|strong="H3605"\w* \w la|strong="H3605"\w* \w maldición|strong="H7045"\w* \w de|strong="H1121"\w* Jotam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jerobaal|strong="H3378"\w*.
\c 10
\s1 Los jueces Tola y Jaír
\p 
\v 1 \w Después|strong="H3427"\w* \w de|strong="H1121"\w* Abimelec, \w Tola|strong="H8439"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Púa, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Dodo, varón \w de|strong="H1121"\w* Isacar, \w quien|strong="H1931"\w* \w vivía|strong="H3427"\w* en \w Samir|strong="H8069"\w*, en \w la|strong="H1931"\w* región montañosa \w de|strong="H1121"\w* Efraín, \w se|strong="H1931"\w* \w levantó|strong="H6965"\w* para librar \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*.
\v 2 Éste \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* 23 \w años|strong="H8141"\w* y \w murió|strong="H4191"\w*. Fue \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* \w Samir|strong="H8069"\w*.
\p 
\v 3 Tras él se \w levantó|strong="H6965"\w* \w Jaír|strong="H2971"\w* \w galaadita|strong="H1569"\w*, quien \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* 22 \w años|strong="H8141"\w*.
\v 4 \w Tuvo|strong="H1961"\w* 30 \w hijos|strong="H1121"\w* \w que|strong="H5921"\w* cabalgaban \w en|strong="H5921"\w* 30 \w asnos|strong="H5895"\w* \w y|strong="H5921"\w* poseían 30 villas \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Galaad|strong="H1568"\w*, \w que|strong="H5921"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w* \w se|strong="H1961"\w* \w llaman|strong="H7121"\w* Villas \w de|strong="H5921"\w* Jaír.
\v 5 \w Jaír|strong="H2971"\w* \w murió|strong="H4191"\w* y fue \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* Camón.
\p 
\v 6 Pero \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* volvieron \w a|strong="H3068"\w* \w hacer|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* ante \nd \w Yavé|strong="H3068"\w*\nd* y \w sirvieron|strong="H5647"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* baales y \w a|strong="H3068"\w* Astarot, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \tl ʼelohim\tl* \w de|strong="H1121"\w* Siria, \w de|strong="H1121"\w* \w Sidón|strong="H6721"\w*, \w de|strong="H1121"\w* \w Moab|strong="H4124"\w*, \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón y \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w*. Abandonaron \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* y \w no|strong="H3808"\w* \w le|strong="H3254"\w* \w sirvieron|strong="H5647"\w*.
\v 7 Se encendió la ira \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w contra|strong="H3478"\w* \w Israel|strong="H3478"\w* y \w los|strong="H1121"\w* entregó en las \w manos|strong="H3027"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* y \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón,
\v 8 quienes \w a|strong="H3068"\w* partir \w de|strong="H1121"\w* \w aquel|strong="H1931"\w* \w año|strong="H8141"\w* oprimieron y vejaron \w a|strong="H3068"\w* \w los|strong="H1121"\w* israelitas durante 18 \w años|strong="H8141"\w*, \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w que|strong="H1931"\w* vivían al \w otro|strong="H8141"\w* \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w* en \w Galaad|strong="H1568"\w*, \w la|strong="H1931"\w* tierra \w de|strong="H1121"\w* \w los|strong="H1121"\w* amorreos.
\v 9 \w Así|strong="H1571"\w* \w que|strong="H1571"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón cruzaron \w el|strong="H1121"\w* \w Jordán|strong="H3383"\w* para combatir \w contra|strong="H3478"\w* \w Judá|strong="H3063"\w*, \w Benjamín|strong="H1144"\w* \w y|strong="H1571"\w* \w la|strong="H1571"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* Efraín. Esto angustió \w mucho|strong="H3966"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*.
