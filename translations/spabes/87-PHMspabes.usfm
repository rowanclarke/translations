\v 1 \w Pablo|strong="G3972"\w*, \w prisionero|strong="G1198"\w* \w de|strong="G3588"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w*, \w y|strong="G2532"\w* \w el|strong="G3588"\w* hermano \w Timoteo|strong="G5095"\w*, a \w Filemón|strong="G5371"\w*, \w nuestro|strong="G2249"\w* amado \w colaborador|strong="G4904"\w*,   
