\id OBA Azeri-N: Azerbaijani Bible 2008
\h AVDİYA
\toc1 Avdiya Peyğəmbərin Kitabi
\toc2 Avdiya
\toc3 Avd
\mt1 AVDİYA
\mt2 PEYĞƏMBƏRİN KİTABI
\imt1 GİRİŞ
\ip \bk «Avdiya»\bk* Kitabı miladdan əvvəl 586-cı ildə Babillilərin Yerusəlimi zəbt etdiklərindən sonra yazılıb. Yəhudanın qədim düşməni Esavın nəslindən olan Edomlular Yerusəlimin süqutuna sevinib şəhərin talanmasında işğalçılara kömək etdilər. Avdiya peyğəmbər Edomun dağılması və məğlubiyyəti barədə peyğəmbərlik etmişdi.
\iot Kitabın məzmunu:
\io2 1:1-14 Edomun cəzalandırılması
\io2 1:15-21 Rəbbin günü
\c 1
\p 
\v 1 \x * \xo 1:1 \xt Yeş. 34:5-17; 63:1-6; Yer. 49:7-22; Yez. 25:12-14; 35:1-15; Amos 1:11-12; Mal. 1:2-5 \x* Bu, Avdiyaya zühur olan görüntüdür.
\s1 Edom üzərində Allahın məhkəməsi
\q1 Xudavənd Rəbb Edom barəsində belə deyir:
\q1 Biz Rəbdən xəbər eşitdik,
\q1 Millətlər arasına
\q1 «Qalxın, Edoma qarşı döyüşək!» deyən qasid göndərildi.
\q1 
\v 2 «Bax səni millətlər arasında kiçildəcəyəm,
\q1 Hamı sənə xor baxacaq.
\q1 
\v 3 Ey sən qaya \f + \fr 1:3 \fq Qaya \ft – ibrani mətnində \tl sela\tl*\ft kimi səslənir. Sela Edomun paytaxtının adı idi.\f* çatlarında məskən salan,
\q1 Evini yüksəklərdə quran!
\q1 Ürəyinin qüruru səni aldatdı,
\q1 Çünki sən qəlbində “Məni kim yerə yıxa bilər?” dedin.
\q1 
\v 4 Sən qartal kimi yuxarı uçub
\q1 Yuvanı ulduzlar arasında qursan da,
\q1 Səni oradan endirəcəyəm».
\q1 Rəbb bəyan edir.
\b
\q1 
\v 5 «Əgər gecə yanına oğrular, quldurlar gəlsəydi,
\q1 Ancaq öz istədikləri qədər oğurlamazdılarmı?
\q1 Əgər üzüm yığanlar sənin bağına gəlsəydi,
\q1 Bir neçə salxımı saxlamazdılarmı?
\q1 Amma gör səni nə cür müsibətlər gözləyir!
\q1 
\v 6 Esavın hər şeyi talan ediləcək,
\q1 Gizli xəzinələri aşkara çıxarılacaq.
\q1 
\v 7 Səninlə əhd bağlayanların hamısı
\q1 Səni ölkəndən qovacaq,
\q1 Müttəfiqlərin səni aldadıb məğlub edəcək.
\q1 Səninlə çörək yeyənlər sənə tələ quracaq,
\q1 “Onun ağlı haradadır?” deyəcək».
\q1 
\v 8 Rəbb bəyan edir:
\q1 «O gün Edomun hikmətli adamlarını,
\q1 Esav dağındakı müdrikləri məhv edəcəyəm.
\q1 
\v 9 Ey Teman, \f + \fr 1:9 \fq Teman \ft – Edomun şəhərlərindən biri.\f* igid adamların elə qorxuya düşəcək ki,
\q1 Esav dağlarının hər sakini qırğında öldürüləcək.
\b
\q1 
\v 10 Qardaşın Yaquba etdiyin zorakılığa görə
\q1 Sən xəcalət içində qalacaqsan,
\q1 Əbədi məhv olacaqsan. \f + \fr 1:10 \ft Yaqubla Esav doğma qardaş idi. Yaqub İsraillilərin əcdadı idi. Esav Edomluların əcdadı idi.\f*
\q1 
\v 11 Yadellilər onun sərvətini aparanda
\q1 Sən uzaqda durub tamaşa etdin.
\q1 Əcnəbilər onun şəhər darvazalarından girib
\q1 Yerusəlim üçün püşk atanda
\q1 Sən də onlardan biri kimi davrandın.
\q1 
\v 12 Sən gərək Yəhudalı soydaşlarının
\q1 Bədbəxtlik günündən zövq almayaydın,
\q1 Həlak olduqları gün sevinməyəydin,
\q1 O əzablı gündə rişxənd etməyəydin,
\q1 
\v 13 Xalqımın fəlakətli günündə
\q1 Onların şəhər darvazalarından girməyəydin,
\q1 Başlarına bəla gələn gün
\q1 Onların fəlakətini sevinclə seyr etməyəydin,
\q1 Başlarına bəla gələn gün
\q1 Onların malına əl uzatmayaydın!
\q1 
\v 14 Sən gərək qaçan Yəhuda övladlarını öldürmək üçün
\q1 Yol ayrıcında dayanmayaydın,
\q1 O əzablı gün qurtulanları
\q1 Düşmənə təslim etməyəydin!
\s1 Rəbbin günü yaxınlaşır
\q1 
\v 15 Axı bütün millətlər üçün Rəbbin günü yaxınlaşır,
\q1 Ey Edom, sən nə cür etdinsə, sənə də belə ediləcək,
\q1 Əməllərinin əvəzi öz başına gələcək!
\q1 
\v 16 Çünki siz Mənim müqəddəs dağımda içdiyiniz kimi
\q1 Bütün xalqlar durmadan içəcək,
\q1 İçib yox olacaq,
\q1 Sanki əvvəldən yox idi.
\s1 İsrailin zəfəri
\q1 
\v 17 Lakin qurtuluş tapanlar
\q1 Sion dağına toplanacaq,
\q1 O dağ müqəddəs olacaq.
\q1 Yaqub nəsli mülkünə sahib olacaq!
\q1 
\v 18 Yaqub nəsli od,
\q1 Yusif nəsli alov,
\q1 Esav nəsli isə küləş olacaq,
\q1 Yaqub və Yusif nəsli
\q1 Esav nəslini yandırıb məhv edəcək.
\q1 Esav nəslindən qurtulan olmayacaq.
\q1 Çünki Rəbb belə söylədi.
\b
\q1 
\v 19 Negev sakinləri Esav dağını,
\q1 Yamaclı-düzənlikli bölgədə yaşayanlar Filiştlilərin bölgəsini,
\q1 Yəhudalılar Efrayimlə Samariya torpaqlarını,
\q1 Binyaminlilər isə Gileadı zəbt edəcək.
\q1 
\v 20 Xalahda olan İsrail sürgünləri
\q1 Kənanın Sarfata qədər uzanan torpaqlarını,
\q1 Sefaradda olan Yerusəlim sürgünləri
\q1 Negev şəhərlərini zəbt edəcək.
\q1 
\v 21 Xalqı qurtaranlar Sion dağına çıxıb
\q1 Esav dağına hökm edəcək:
\q1 Rəbb səltənət sürəcək». 
