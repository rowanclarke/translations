\id 2PE Ika New Testament 2009
\h 2 Pita
\toc1 Ẹhụhụọ-Ozi Nke Ẹbụọ Pita De
\toc2 Pita, Nke Ẹbụọ
\toc3 2Pi
\mt2 Ẹhụhụọ-Ozi Nke Ẹbụọ
\mt2 Pita
\mt2 De
\mt1 Pita, Nke Ẹbụọ
\c 1
\cl Isi Nke Ohu
\p 
\v 1 Mmẹ wụ Simiọnụ hụn w'a kpọ Pita de ẹhụhụọ-ozini. M wụ igbọn Jizọs' Kraịstị; m wụzịkwọ onyẹ-ozi ẹ pụ-ichẹn. M rị e dejẹnni ndị Osolobuẹ ye okukwe ohu hụ rịkẹnmẹ mkpa hụn ẹnyi lẹ enwẹn ẹnyi nwọn—okukwe hụn wẹ nwọnhẹn makẹni Jesu Kristi wụ Osolobuẹ ẹnyi lẹ Onyẹ-nzụọfụha ẹnyi rị ọchan.
\v 2 Ẹfọma lẹ udọn ya rịnị ọnụ mmagi-mmagi—ebe ụnụ n'a marịn Jizọs' Kraịstị wụ Onyẹ-nwẹni-ẹnyi lẹ Osolobuẹ ẹnyi amarịnwaye.
\s1 Ghọsị Nị Nị Osolobuẹ Kpọ Ụnụ
\p 
\v 3 O gigụọ ikẹn o gi wụrụ Chuku ye ẹnyi ihiẹn ile rị ẹnyi mkpa hụn ẹnyi e gi bi elu lẹ hụn ẹnyi e gi fe Osolobuẹ; ọmarịn ẹnyi marịn ya wụ Jesu, onyẹ hụn kpọ ẹnyi d'e sọn ẹ nwẹ ọghọ a, sọn ẹ rị ọchan hụ ọ rị, kẹ ẹnyi gha nwẹhẹn ihiẹn ndịnị; ẹnyi gha a marịnwaye ẹ, ẹnyi hụ e nwẹwaye ihiẹn ndịnị o ye ẹnyi.
\v 4 Ọghọ a ahụn lẹ ọchan ahụn ọ rị k'o gi nwan kwesọnmẹ ẹnyi okẹn nkwa ndị hụn o kwesọnmẹ ẹnyi, nkwa ihiẹn w'a chọ achọ rị ichẹn-ichẹn hụn ọ chọ nị ẹnyi nwẹrin. O mẹ ẹ kẹni ọnụ gi ihiẹn ndị hụ o kwe nkwa a bịa d'a rị kẹ Osolobuẹ, e bi kẹ ịya, ebe ụnụ nọ wanahịngụụ ụrụ rị imẹ ụwa lẹ ihiẹn ọlịla-ẹnya hụn e buhẹn'ẹ.
\p 
\v 5 Ufiri ọnwan, lịlịma nị nwan ụzọ ile nị ụnụ we ịrị-mma cheni okukwe ụnụ; ụnụ e we ịmarịn-ihiẹn che ni ịrị-mma ụnụ.
\v 6 Wezi ni ikwọndọn-enwẹn-ịhịan che ni ịmarịn-ihiẹn. E nwẹ ni ezigbo-ndidi e che ni ikwọndọn-enwẹn-ịhịan; ụnụ e we ịtụ-egun Osolobuẹ e cheni ezigbo-ndidi.
\v 7 E gi ni obi-nwẹnẹ e sọn ibe ụnụ ndị kwerini—ụnụ e we ọhụn che ni ịtụ-egun Osolobuẹ. E nwẹzi ni ihiẹn-ọsụsụọ hụn ghalẹni e tu e cheni obi-nwẹnẹ.
\p 
\v 8 Makẹni, omẹni ụnụ nwẹ ihiẹn ndịnị ile imẹ ndụn ụnụ, e nwẹwaye wẹ, ụnụ awụkọ ndị marịn Onyẹ-nwẹni-ẹnyi wụ Jesu Kristi bụ w'a ra mị n'a mkpụrụ, w'a ra rụnpụha n'a ihiẹn ọwụlẹ.
\v 9 Kanị, o mẹ nke onyẹ hụn nwọnlẹni ihiẹn ndịnị, ọ rịnị e leghakẹnmẹ ụzọ, ẹnya-mpịn k'ọ wụ. Ọ zọgụọ nị a chanchanpụgụọ w'a njọ mbụ.
\p 
\v 10 Lịlịma nị nwan ụzọ ile, umunẹ m, nị ụnụ ghọsị nị Osolobuẹ kpọ ụnụ nke-esi lẹ ni ọ họrị ụnụ nke-esi. Makẹni, ụnụ mẹ ẹ, o nwọnni ogẹn ụnụ e gi dan!
\v 11 Ụnụ sikọ d'e gi ẹ ru ogo ndị wẹ k'a nabanhan ọhụnma-ọhụnma imẹ Alị-eze itẹbitẹ Jesu Kristi—Di-nwọnni-ẹnyi lẹ Onyẹ-nzụọpụha-ẹnyi.
\s1 Pita Wẹ Gi Ẹnya Hụn Ọghọ Kraịstị
\p 
\v 12 Ya wụ, m chọ nwan nị m'a nyanhan nị ụnụ ihiẹn ndịnị ogẹn ile—ọsụọn'anị ụnụ a marịngụọlẹ wẹ; ọsụọn'a nị ụnụ e turugụọ ọhụnma imẹ ezioku hụ wẹ wẹhẹni ụnụ.
\v 13 E roghọ m'a n'ọ hụghọ mma nị m'a nyanhan nị ụnụ ihiẹn ndịnị wẹ, hụnnị m rịkwọ ndụn imẹ ẹhụnị.
\v 14 Makẹni, a marịngụọ m nị ogẹn m'e gi nwụnhụn, gbụpụ ẹhụnị, a rịgụọ nsue, rịkẹ kẹ Di-nwọnni-ẹnyi wụ Jesu Kristi dọn ghọsị m.
\v 15 Ẹghẹẹ, m k'a nwankẹnmẹ ụzọ ile gi hụn a nị ọnụ k'a sa ẹka a nyanhan ihiẹn ndịnị wẹ, m ghagụụ ẹhụnị pụ—m nwụnhụngụụ.
\p 
\v 16 Makẹni ẹlẹ akịkọ ndị ma kọ akịkọ mẹmẹ kẹ ẹnyi sọnkọ ogẹn ẹnyi gi gwa ọnụ oku ikẹn lẹ ọbịbịa Nna ẹnyi wụ Jizọs' Kraịstị. Mba; ẹnyi gi ẹnya ẹnyi hụn ọghọ a.
\v 17 Chuku-Nẹdi ye Jizọs' ọghọ lẹ ikpẹn ogẹn hụ o gi gha elu-igwee gi olu ẹ ku oku. Olu ahụn lẹ Ọghọ ahụn Kachanrịnnị wị bịa ebe Jizọsị rị. Olu ahụn sị, “Ọnwan wụ ezi Nwa m; ihiẹn ẹ a sụọka m!”
\v 18 Ẹnyi lẹ enwẹn ẹnyi gi ntịn ẹnyi nụ kẹ oluni gha elu-igwee bịa ogẹn ahụn ẹnyi lẹ ịya gi rị elu ugu-nsọ hụ.
\p 
\v 19 Ẹnyi gi ẹ nwan marịn nị ihiẹn ndị-amụma ku imẹ Ẹhụhụọ-nsọ wụ ezioku furu w'e gi dọn ẹnya. Ya wụ, ọ ka ụnụ mma nị ụnụ gi wẹ e dọn—nọkẹ ukpẹ-ẹka rị e nwun imẹ ishi—gi wẹ dọn d'e ru mgbe eki e gi fọn, hụn ukpẹ Onyẹ ahụn wụ Kokisẹ-ụtụntụn e gi timẹ imẹ obi ụnụ.
\s1 Kẹ Ihiẹn Rị Imẹ Ẹkụkwọ-nsọ Dọn Bịa.
\p 
\v 20 Ka ghọha nị ọnwan rịkẹ ihiẹn ibuzọ: nị, o nwọnni ihiẹn ọwụlẹ wẹ ku mọbụ de imẹ Ẹhụhụọ-nsọ hụn wẹ gi uche ịhịan ku mọbụ hụn wẹ gi uche ịhịan a kọwa;
\v 21 makẹni, o nwọnni ihiẹn ọwụlẹ rị imẹ Ẹhụhụọ-nsọ hụn gha uche ịhịan pụha. Kama, Mmọn-nsọ 'ya nu ndị hụn kuni, wẹ nọ ku ihiẹn gha ebe Osolobuẹ rị bịa.
\c 2
\cl Isi Nke Ẹbụọ
\s1 Ndị-amụma-ntụ Lẹ Ndị nkuzi-ntụ
\p 
\v 1 Kanị ndị-amụma-ntụ pụhazịkwọ imẹ ndị Izrẹl' ogẹn mbụ hụ. Ẹrịra kẹ ndị nkuzi-ntụ k'a dọnzị rị imẹ ụnụ. Wẹ k'e gi nzuzue webanhansọnmẹ nkuzi-ntụ hụn e buhẹ ntikpọ, jụdẹ Di-nwọnni-wẹ, hụn ṅọnni wẹ—ọnwan kẹ wẹ k'e gi buhẹkẹnrin ni enwẹn wẹ ntikpọ.
\s1 W'e Dufie Ịhịan, A Tụnarịn Ịhịan Ihiẹn Ẹ
\p 
\v 2 Kanị, ndị bu ọda k'e sọn wẹ bimẹ eje-obibi ifẹnrẹn ahụn wẹ rị e bi. Ịhịan sikọ d'e gi ifiri wẹ kutọ Ụzọ-ezioku.
\v 3 Ẹnya-uku wẹ k'e mẹ wẹ e gi ọnụ-ọma e dufie ụnụ, a tụnarịn ọnụ ihiẹn ọnụ. Ikpe-ọmụma lẹ afụnfụn wẹ butọ nị wẹ edẹi hụ a—ọ nọdịtuni mmaka; ntikpọ Osolobuẹ jẹnkọ d'e tikpọ wẹ a ranhịntuni ụran!
\s1 Osolobuẹ A Marịngụọ Ye Onyẹ-onyẹ Ihiẹn Wẹ Chọ
\p 
\v 4 Ebe o mẹ ni Osolobuẹ ahatuni ndị mmọn-ozi hụ ogẹn ahụn wẹ gi mẹ njọ, kama, ọ tụ wẹ ye imẹ ọkụn-mmọn, kẹnmẹsọnmẹ wẹ, busọnmẹ wẹ che imẹ olu rịsọnmẹ imẹ ishi kachanrịnni d'e ru Ụhụọhịn okinkin-ikpe—kịnị k'o k'e mẹ ndị nkuzi-ntụ ndịnị?
\p 
\v 5 O mẹ nwan nị Osolobuẹ ahatuzikwọnị ụwa mbụ ye, ogẹn hụ o gi zihẹ okẹn mirin d'e tikpọ ụwa ndị-njọ hụ; omẹni ọ zụọpụhaghọ Nụa, hụn e zisọnmẹ wẹ ozi kẹni wẹ mẹ ihiẹn Chuku chọ, ya lẹ madụ ẹsa ndị ọzọ—k'o k'e mẹ ndịnị wẹ?
\p 
\v 6 Omẹni ọ maghọ anị Sodọmụ lẹ alị Gomọra ikpe, gi ọkụn dụnfụ wẹ, wẹ nọ hẹnrin ntụn—nke wụ nị arịzị wẹ, ọ nọ gi wẹ ghọsị ihiẹn jẹnkọ d'e mẹ ndị k'e nupụ isi okpuru oku Osolobuẹ—k'o k'e mẹ ndị nkuzi-ntụnị?
\p 
\v 7 Di-nwọnni-ẹnyi zụọpụha onyẹ rị-ọchan wụ Lọtụ, hụn ize eje-obibi wẹ lẹ obibi ifẹnrẹn wẹ rị e bi e ze ọda-ọda.
\v 8 (Ezioku-ezioku, ogẹn ahụn ile Lọtụ gi bi alị wẹ, ọ hụ a fụgbu onyẹ ezi-omumẹni, obi ẹ hụ rị ọchan hụ a gbawa—makẹni ọ hụ e gi ẹnya a hụn eje-ihiẹn ile wẹ rị e mẹ ụhụọhịn-ụhụọhịn, e gi ntịn a nụ a.)
\p 
\v 9 Ya wụ nị Di-nwọnni-ẹnyi marịn k'o dọn a gbapụha ndị hụn e fen'ẹ imẹ ọnwụnwan, marịnzịkwọ k'o dọn e bu ndị-njọ e che imẹ afụnfụn d'e ru Ụhụọhịn okinkin-ikpe,
\v 10 tụmadụ ndị hụn e mẹ ihiẹn ụrụ a gụnnị wẹ lẹ ndị e ledan ọkịkị.
\s1 W'e Ledan Ọkịkị, E Kutọ Ihiẹn Wẹ Ghọtalẹni
\p Obi ndị nkuzi-ntụ ndịnị e zekẹ, ihiẹn ọwụlẹ obi wẹ ye wẹ kẹ w'e mẹ; egun ịkpari ndị nwọn ọghọ ara tụ wẹ.
\v 11 Kanị, ọsụọn'a nị ndị mmọn-ozi ka e ze, ka ikẹn e nwẹ, w'a ra kpari ndị nwọn ọghọ, w'a ra kutọ wẹ ihun Di-nwọnni-ẹnyi.
\v 12 Kanị, ndịnị nọ kẹ anụ-ọfịa nwọnlẹni uche, anụmanụ hụn ghalẹni e leban ihiẹn ẹnya—hụn wẹ mụhụ nị wẹ nwụnrụn gbu. W'e kutọ ihiẹn wẹ ghọtalẹni. Wẹ k'a la ntikpọ kẹ anụ-ọfịa dọn a la ntikpọ—
\v 13 eje-ihiẹn e kunrun wẹ makẹ eje-ihiẹn ndị wẹ rị e mẹ!
\s1 Ihiẹn Hụn A Gụn Ẹhụ Wẹ Kẹ W'e Mẹ
\p Ọ sụọ wẹ nị wẹ e mẹ ihiẹn-ifẹnrẹn ebe eki rị enu. Unyin lẹ ntụpọ kẹ wẹ wụ imẹ igunrun ụnụ. Ịya kẹ wẹ wụ makẹni w'a nọzịdẹ ebe wẹ n'e sọn ụnụ e ri Oriri Ihiẹn-ọsụsụọ ụnụ e mẹ ihiẹn-ifẹnrẹn lẹ ihiẹn-ndufie ndị ahụn asụọnị wẹ, e mẹpụha wẹ ifọn.
\v 14 Ughẹrẹ jun wẹ ẹnya; ẹfọ imẹ-njọ ara jun wẹ. W'e gi ẹro a dọrị ndị zelẹni. E gigụọ wẹ ẹnya-uku zụn obi wẹ. Ndị wẹ bụ ọnụ kẹ wẹ wụ!
\s1 A Kpahugụọ Wẹ
\p 
\v 15 A lagụọ wẹ ezigbo Ụzọ hụ zinrinni tọ, ghasọnmẹ ụzọ Balam' nwa Beọ, hụn eje-erere a sụọ, a dụ—
\v 16 kanị Osolobuẹ nọ jụgbọ a makẹ njọ a: ebe jaki ghalẹni e ku oku nọ gi olu ịhịan ku oku, hụn wẹ gi jụgbọ ẹra ahụn rị a pụ onyẹ-amụma hụ.
\p 
\v 17 Ndị nkuzi-ntụ ndịnị wụ isi-mirin tahịnị; igirigi ufere bukọ; uwẹ kẹ wẹ dọnmẹ ni ishi hụn kachanrịn.
\s1 Oku-ọnụ Wẹ Asụọka Kanị A Rịzịọlẹ Wẹ Ẹgbụn
\p 
\v 18 Ị nụ oku-ọnụ wẹ, y'e gbu ni wẹ osekpu! Kanị oku wẹ enwẹn anị. W'e gi ihiẹn a na ẹnya a dọrị ndị ghahụ imẹ ndị-mmẹfie gbafụha.
\v 19 W'e kwesọnmẹ wẹ nkwa nị wẹ k'e weri enwẹn wẹ, kanị, uwẹ lẹ enwẹn wẹ wụsọnmẹ igbọn ihiẹn rụnị. Makẹni, ihiẹn rị a kị ịhịan kẹ onyẹ hụ wụ igbọn ẹ.
\p 
\v 20 Makẹni, omẹni wẹ wanahịngụụ ihiẹn ndị e mẹrụ ịhịan hụn rị imẹ ụwa ghahanị ịmarịn Jesu Kristi hụn wụ Di-nwẹni-ẹnyi lẹ Onyẹ-nzụọpụha ẹnyi, anịzị wẹ ihiẹn ndị hụ nwụndọn wẹ, karị wẹ ẹka, ọnọdị ịkpazụụn ndị nọ ẹrịra a kagụọ njọ karị nke ibuzọ.
\v 21 Makẹni, o te ka wẹ mma nị amarịntudẹni wẹ Ụzọ hụ rị ọchan karị nị a marịngụụ w'a, a gbakịtọ wẹ oku lẹ iwu hụ rị nsọ wẹ weye wẹ ẹka azụụn.
\v 22 Ilu hụ wụ ezioku e mẹgụọ nwan ebe wẹ rị, “Nkitẹ e kin azụụn buru ẹgbọ a.” Ọzọzị, “Wẹ chanchanhụ ezin n'o shi imẹ ịkpọtọ d'e gu.”
\c 3
\cl Isi Nke Ẹtọ
\s1 Nkwa Ọbịbịa Di-nwọnni-ẹnyi
\p 
\v 1 Ndị rị m obi, ọnwan mẹ ẹkụkwọ-ozi nke ẹbụọ m dehẹni ụnụ. Imẹ wẹ ẹbụọ, m rị a nwan nị m kpọtiẹn iroro zu oke imẹ ụnụ ghahanị ịnyanhan nị ọnụ ihiẹn.
\v 2 M rị a sị ụnụ nyanhankwọ oku hụ ndị-amụma nsọ Osolobuẹ ku ogẹn mbụ lẹ iwu Onyẹ-nzụọpụha ẹnyi ye ghahanị ndị-ozi pụ-ichẹn o zihẹni ụnụ.
\s1 Ẹlẹni Di-nwọnni-ẹnyi Rị E Bi Mbie
\p 
\v 3 Nke ibuzọ, ghọta nị ọnwan: nị ndị-ẹmụ k'a pụha ogẹn ịkpazụụn, a mụ ẹmụ, e bi k'ọ sụọ wẹ.
\v 4 Wẹ k'a sị, “Elebe kẹ nkwa nwẹn o kwe n'ọ lala alala rị? Ọ bịagụọ nwan? Ndị nẹdi ẹnyi wẹ a ranhịngụọ ụran (ọnwụn) kete-ele-mgbe; ihiẹn ile nọhụ kẹ wẹ rị kete wẹ e kelẹ ụwa!”
\p 
\v 5 A kpachanpụgụọ wẹ ẹnya zọ nị oku-ọnụ Osolobuẹ k'o gi kẹ enu-igwee hụ rị mbụ-mbụ; nị oku-ọnụ k'o gizi gha mirin mẹmẹ akpakalị, gha imẹ mirin wefụha a;
\v 6 ọ nọ gizi oku-ọnụ a mẹ mirin, okẹn-mirin, tikpọ ụwa mbụ hụ la iwi.
\v 7 Kanị, nke elu-igwee lẹ ụwa rị ogẹnni, Osolobuẹ e gigụọ ya wụ oku-ọnụ a bu wẹ dọnmẹ n'o k'a dụn wẹ ọkụn; ọ rị e che Ụhụọhịn ahụn o k'e kin ndị-njọ ikpe, tikpọ wẹ.
\s1 Di-nwọnni-ẹnyi Rị Eche Nị Ịhịan Wanahịn
\p 
\v 8 Kanị, nke ụnụ ndị rị m obi, azọkwọlẹ ni ihiẹn ohuni: nị ebe Di-nwọnni-ẹnyi rị, akp'ọhịn ohu nọkẹ ahụa nnụ-uku (ahụa ọgụn-iri kwasị nnụnaị); ahụa nnụ-uku rịzị kẹ akpụ-ụhụọhịn ohu.
\v 9 Ẹlẹni Di-nwọnni-ẹnyi rị e bie mbie imẹzu nkwa a kẹ ndị hụ dọn a ghọha ibie-mbie; mba, o gi ndidi e sọn ụnụ. Ọ chọnị nị onyẹ ọwụlẹ la iwi, kama, ọ chọ nị onyẹ ọwụlẹ rogharị.
\s1 Ụhụọhịn Di-nwọnni-ẹnyi Lala
\p 
\v 10 Kanị Ụhụọhịn Di-nwọnni-ẹnyi jẹnkọ d'a bịa idẹnmizi lẹkẹ ohin. Ogẹn hụ, igwere sikọ d'e gi okẹn ụzụn fopụ, ọkụn a rịnranpụ ihiẹn ile rị igwere; ụwa lẹ ihiẹn ile ịhịan nọ imẹ ẹ mẹ e kpufụ, pụha ifọn.
\p 
\v 11 Ebe o mẹ ni wẹ k'e tikpọpụ ihiẹn ndịnị ile ẹnịna, elee ụdị ịhịan k'o furu ni ụnụ wụrụ? O furu nị ọnụ e bi obibi rị nsọ, e gi egun Osolobuẹ e bi;
\v 12 e che Ụhụọhịn Osolobuẹ, e mẹ ẹ n'ọ bịakẹnrin, Ụhụọhịn hụ o k'e gi mụ ọkụn ye elu-igwere, dẹnpụ a, gi ẹrịra rịnranpụ ihiẹn ile rịn'a.
\p 
\v 13 Kanị, nọkẹ kẹ Osolobuẹ dọn kwe nkwa, ẹnyi rị a tụ ẹnya enu-igwee ọhụn lẹ ụwa ọhụn—ebẹhụ wụchanrịn ebe obibi ihiẹn ile rị-ọchan.
\p 
\v 14 Ndị rị m obi, ebe o mẹ ni ọnụ rị a tụ ẹnya ihiẹn ndịnị, lịlịma nị nwan nị udọn hụn ụzọ a rị ẹgbata ọnụ lẹ ịya, amamgbe ụnụ gha e nwọn ntụpọ mọbụ nkọrịanị ogẹn ụnụ k'e gi pụha ihun Osolobuẹ.
\v 15 Bun'ẹ obi nị ndidi Di-nwọnni-ẹnyi rị e nwọn wụ oghere nzụọpụha.
\p Ẹnịna kẹ ezi nwẹnẹ ẹnyi wụ Pọlụ dọnzi deni ụnụ ghahanị amamihiẹn Osolobuẹ ye ẹ.
\v 16 O kusọnmẹ oku ihiẹnni imẹ ẹkụkwọ-ozi ẹ ile. O nwọnghọ ihiẹn ndị a fụ ọrụn ọghọta imẹ ihiẹn ndị o de, hụn ndị marịnlẹni ẹnya wẹ lẹ ndị wuzolẹni ọhụnma a fịhutọ—kẹ wẹ e mẹzi ihiẹn ndị ọzọ rị Ẹhụhụọ-nsọ, e gi ẹ e sehẹni enwẹn wẹ ntikpọ.
\p 
\v 17 Ndị rị m obi, a gwatọgụọ wẹ nwan ụnụ ihiẹn ndịnị. Dọnrin ni nwan ẹnya, amamgbe mmẹfie ndị e bi k'ọ sụọ wẹ e dufie ụnụ, mẹ ụnụ ewuzozilẹ kẹ ụnụ dọn nwan wuzo.
\v 18 Ka gi ni ẹfọma Jesu Kristi wụ Di-nwọnni-ẹnyi lẹ Onyẹ-nzụọpụha ẹnyi mẹ e suewaye imẹ okukwe; a marịnwayezikwọ nị Di-nwọnni-ẹnyi.
\p Ọghọ ya rị n'a ogẹnni, rịzịkwọn'a d'e ru Ụhụọhịn hụ k'a tọ jẹnrin ejẹn! Isẹẹ.
