\v 23  \w And|strong="H4872"\w* \w the|strong="H7200"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w said|strong="H1697"\w* \w to|strong="H3068"\w* \w Moses|strong="H4872"\w*, “\w Is|strong="H3068"\w* \w the|strong="H7200"\w* \nd \+w Lord|strong="H3068"\+w*\nd*’s \w hand|strong="H3027"\w* \w shortened|strong="H7114"\w*? \w Now|strong="H6258"\w* \w you|strong="H3808"\w* \w will|strong="H3068"\w* \w see|strong="H7200"\w* \w whether|strong="H7200"\w* \w my|strong="H3068"\w* \w word|strong="H1697"\w* \w to|strong="H3068"\w* \w you|strong="H3808"\w* \w will|strong="H3068"\w* \w come|strong="H7136"\w* \w true|strong="H3068"\w* \w or|strong="H3808"\w* \w not|strong="H3808"\w*!”   
