\id EPH - Wuvulu NT, James & Lois Hafford, 29-Nov-2004
\h Ephesians
\toc1 EPHESIANS
\toc2 Ephesians
\mt1 EPHESIANS
\is1 Warefa'aia
\ip Feni ne'iaa Paul a'a ei Ephesus fi warewareaa fei do'o naraa mei Haidaa, fei ba i figupuinaa minaa ei famamarana i haroo pafea ma yeni malagufu ma Christ hia tabaa ro'ou.
\ip Ei rawarawa lamii feni bu'u ina fama'aia ba i a'a Christ, mei Haidaa, mei Ama na fihupi'inaa ei rafeiana gufuna, futoaa ei hafelo'aa ro'ou ma alaraa ro'ou panii fei hafelo'a.
\ip Odumanu warehanunuia na fama'aia ba a'a Christ na pa'i fihupu'ia a'a ei rama'aa gufuu mei Haidaa. Ei losuu ale'ei pa'afii fei unu ma Christ fei taba, o ei finefinee hepalo humu, o ale'ei mei pifine haroo lalaia ma Christ hia harona. Minaa ei na fa'arewaiaa fei haguaa Christ, fei ma'eana uaa ei hafelo'a, fei rawani'ana ma fei fafa'araiana.
\c 1
\p 
\v 1 Yau, Paul, hemea apostle Christ Jesus a'a fei nunumiaa mei Haidaa.
\b
\p U'a aloawii feni ne'iau a'a hamu'ou ena apunaiaa mei Haidaa yena Ephesus,\f + \fr 1:1 \ft \bd 1:1\bd* Hefi'a ne'ia mina lomi na pa'i \it yena Ephesus\it*.\f* hamu'ou ena hamona oafagugu\f + \fr 1:1 \ft \bd 1:1\bd* O, \it hamona narafawe'i\it*\f* a'a Christ Jesus:
\b
\p 
\v 2 Fei rawani'a ma gutafarawania i dinawii a'a hamu'ou noranamai a'a minaa lagua, mei Haidaa, mei hia Amaa o'ou mawe mei Fasu Jesus Christ.
\s1 A'a Christ O'aa Pa'i ei Hawegiaa fei Spiriti
\p 
\v 3 Fei udugia i dinaa a'a mei Haidaa, mei hia Amaa Jesus Christ mei Fasuu o'ou. Ma mei Haidaa na haweginaa o'ou inamoaa fei haroo pafea a'a minaa ei hawegiaa fei spiriti, ei i nofipuimai a'a Christ.
\v 4 Uaa ei itawe famamaraa feni malagufu, ina rafeinaa o'ou i a'ana ba onei fafa'arai ma ba lomi hepalo tataa o'ou i pudana. A'a fei hagua,\f + \fr 1:4 \ft \bd 1:4\bd* O, \it pudana a'a fei hagua. 5 Hia, inadii\it*\f*
\v 5 inadii bigi'ia ba i taweaa o'ou ale'ei na'una uaa Jesus Christ ba inei wanewaneinaa fei ni'eni'eana ma fei nunumiana—
\v 6 Onei uduginaa mei Haidaa uaa fei rawani'a fana, fei ina fani'uaiaa o'ou a'a Mei hia na haguia.
\v 7 Ma mei na'una na ponohadiwe'inaa o'ou a'a fei namona ba i futoaa ei hafelo'a uaa na bauanai fei rawani'aa mei Haidaa,
\v 8 fei namina hawainaa o'ou fininaa minaa ei apa'a ma apa'ifarawania.
\v 9 Ma inawe\f + \fr 1:9 \ft \bd 1:8,9\bd* O, \it o'ou. Fininaa minaa ei apa'a ma apa'ifarawania 9 inawe\it*\f* fa'arewaia a'a o'ou fei nunumiana, fei nado'o opa'ai, fei i neneraa fei rawani'a naranarana, fei inado'o nunuminia ba i bigi'ia a'a Christ,
\v 10 fei ba i bigi'ia ena inawe nomai fei pa'aa au—ba i pafea ma yeni malagufu i aufipuinaa minaa ei manumanu haroo hemea ua, mei Christ.
\p 
\v 11 I a'ana, ana ina rafeinaa o'ou,\f + \fr 1:11 \ft \bd 1:11\bd* O, \it ana ina fa'oanaa o'ou ale'ei na'u ba i tonaa manumanuu amana\it*\f* ba tamanu fei do'o pagipagiana nei neneraa fei naranaraa mei fi bigi'aa minaa ei manumanu a'a ei nunumiana,
\v 12 si'ei ba hai'ou rawarawa pa'aa fei o'onaia unu a'a Christ, hai'ounei uduginia uaa fei hawerana.
\v 13 Ma hamu'ou anaa, hamonamii oafipui a'a Christ ei hamo'aa guainaa fei fa'uai warea, fei rawani'a wareaa fei tela'anaa hamu'ou. Si'ei ba hamona narafawe'i, ina tama'ainaa hamu'ou a'a hepalo lala, fei Spiriti Apuna, fei inadii fa'unainia ba i aloiamai,
\v 14 ale'ei hepalo uni'uni ba napa'aa fa'uai ba na pa'i ugaa pinee o'ou nopa'aloo fei au ponohadiwe'iaa ei maroaa mei Haidaa—ba u'udugii fei hawerana.
\s1 Ei Warea ‘ta’ ma Lafulafua
\p 
\v 15 A'a ei manumanu ei ma ei u'ado'o guainaa fei narafawe'iaa hamu'ou a'a mei Fasu Jesus ma fei haguaa hamu'ou a'a minaa ei apunaiaa mei Haidaa,
\v 16 lomi una fafaa ware ba ‘ta’ uaa hamu'ou ma una'o nonominaa hamu'ou a'a ei lafulafuau.
\v 17 Una'aida i'igai ba mei Haidaniaa mei Fasuu o'ou Jesus Christ, mei Ama, mei na bauanai hawerana, ba nei fanaa hamu'ou fei Spiritii\f + \fr 1:17 \ft \bd 1:17\bd* O, \it hepalo spiriti\it*\f* apa'a, fei ba nei arewa ei manumanu a'a hamu'ou ba hamo'aa apa'ifarawaninia.
\v 18 Ana una lafulafu ba nei arewa ei naranaraa hamu'ou ba hamo'aa aida ba batanai fei o'onaia unu wagii fei rafeiana hamu'ou, ei baua hawegiana a'a ei apunaia,
\v 19 ma ba fei faufauna a'a o'ou ei ona narafawe'i, lomi tawi'ana. Fei faufau fei, ina ale'ei fei bigi'aa fei baua faufauna,
\v 20 fei ina bigi'ia a'a Christ, ei i fa'asi'ania a'a fei ma'ea ma na fagutania ma'auna a'a fei gufu pafea,
\v 21 namina pafeai laraa minaa ei hapara, forafora, faufaua, fasu ma minaa ei hara a'a feni au feni mawe fena au ataa nomai.
\v 22 Ma mei Haidaa na augaa minaa ei manumanu haroo pinena ma na unia ba hia fasuu minaa ei manumanu wagii fei losuu,
\v 23 ma fei losuu fei, fei ununa ma a'a minaa ei maumauna, ina fapepesunaa minaa ei manumanu tadiwe'aia.
\c 2
\s1 Fei Harenua a'a Christ
\p 
\v 1 Mina, hamu'ou ale'ei ma'ea a'a e'ei tata ma e'ei hafelo'aa hamu'ou,
\v 2 e'ei hamona tatalai wagina ei hamo'aa neneraa ei maumau feni ano mawe ei maumau mei haparaa fei haroo pafea. Fei spiritina fei fi bigi a'a ei rona barafe.
\v 3 Minaa hai'ou anaa, hai'ounado'o guta inamoaa ro'ou fama'a; faho'oaa ei hafelo'a maumau\f + \fr 2:3 \ft \bd 2:3\bd* O, \it faho'oaa ei nunumiaa unuu\it*\f* hai'ou ma neneraa ei nunumiana ma ei naranarana. Ana ale'ei ro'ou, wagii ei pa'aa maumau hai'ou, hai'ou'aa tonaa sibana.
\v 4 Ma'uaa, sifei ba fei baua haguana o'ou, mei Haidaa, mei na rata fei faloloa'iana,
\v 5 na fani harenuaa o'ou i a'a Christ, ei o'aa oa ale'ei ma'ea fininaa ei hafelo'aa o'ou—na fatelaiaa o'ou fei rawani'ana.
\v 6 Ma mei Haidaa na fa'asi'anaa o'ou fipuinaa Christ ma fagutanaa o'ou i a'ana wagii fei gufu pafea i a'a Christ Jesus
\v 7 ba a'a ei arewaa i nomai hinene, i fama'aa fei rawani'ana, fei lomi tawi'ana, i fama'aiaa o'odu fei rawani'ana, i a'a Christ Jesus.
\v 8 Uaa a'a fei rawani'a, hamona tela uaa fei narafawe'ia—ma fei, abaa noramiana a'a hamu'ou—uaa hepalo fanaa mei Haidaa,
\v 9 abaa bigi'uaa rama'a, si'ei, lomi nemea ba i mamagugu wagina.
\v 10 Uaa hamu'ou au'au panii mei Haidaa, hamona mamaramai a'a Christ Jesus ba hamo'aa bigi'aa ei rawani'a bigi'a, ei dii pagi'augaa mei Haidaa ba bigi'aa o'ou.
\s1 Hemea Ua a'a Christ
\p 
\v 11 Si'ei, hamonei nonominia ba hamona waninimai ale'ei Gentile. Ma rona ware ba lomi hamona moro'aa hudii wawanei—ale'ei wareaa ei rona moro'aa hudii wawanei (fei rona bigi'ia a'a ei hudi unuu ei wawane)—
\v 12 Naraia ba mina, hamona farapa a'a Christ ma a'a ba hamu'ou Israel ma hamona raua a'a fei fi'ugaiaa fei fa'unaia, lomi o'onaia unu ma ana lomi Haidaniaa hamu'ou yeni malagufu.
\v 13 Ma'uaa e'eni, a'a Christ Jesus, hamu'ou ena hamonado'o gutafaraua, hamonawe nofarafi'imai uaa fei namoo Christ.
\p 
\v 14 Uaa ana hia mei i farawaninaa o'ou, mei na bigi'ia ba helagui, ale'ei hemea ua ma na birosiaa fei na fafihafeloinaa pafoo lagua
\v 15 a'a fei pigiona na fapedugaa fei law, fei na fafisibainaa lagua fininaa ei warea ma feroia wagina. Fei nunumiana sifei ba i famamaraa hemea manufau rama'a a'a laguei, ba i fagutafarawaninaa lagua,
\v 16 ma a'a hepalo ua hudi unu ina fagutafipuidinaa lagua i a'a mei Haidaa uaa fei hawafolo, fei ina fapedugaa fei fisibaiaa lagua.
\v 17 Ina nomai ma u'ugaa fei gutafarawania a'a hamu'ou ena hamona gutafaraua mawe e'ei rona gutafarafi'i.
\v 18 Uaa i a'ana minaa agua na pa'i tala i dinaa a'a mei Ama wagii hepalo ua Spiriti.
\p 
\v 19 Si'ei, e'eni, fai lo'e ba hamu'ou rama'aa rauaa, o rama'aa hepapa gufu, ma'uaa, hamu'ou ale'ei pa'aa rama'a gufuu mei Haidaa fipuinaa ei apunaia ma ei maroaa fei humuu mei Haidaa,
\v 20 fei na fadu pafoo fei fasu'ufufugoi ei apostle ma ei mamama'a, fei ba Christ Jesus, ana hia, fei pa'aa fafasui fei fasu'ufufugoi.
\v 21 I a'ana, minaa fei humu na fadufitanai ma a'a mei Fasu na ufalarai ale'ei hepalo apunai humuu mei Haidaa.
\v 22 Ma i a'ana, hamu'ou ana ale'ei finefine ina fadufipuinaa hamu'ou ba ale'ei hepalo humu ba wagii fei Spiritina, mei Haidaa i oa i lalona.
\c 3
\s1 Paul, mei U'uga a'a ei Gentile
\p 
\v 1 Sifei, fei pa'afina ba yau Paul na bobo'ai a'a Christ Jesus uaa ba a hadumaa hamu'ou ena Gentile.
\p 
\v 2 Woro ba hamona guaidigaa fei bigi'aa fei rawani'aa mei Haidaa, fei ina fanau ba unei u'ufanaa hamu'ou.
\v 3 Sifei ba, hefei nado'o ude'opa'ai, inawe foiginia ma fa'arewaia a'au, ale'ei ma'idei do'o ne'iau fama'a.
\v 4 Ena hamona igoaa feni, hamopowe apa'ifarawaninaa fei apa'au a'a fei u'ugaa Christ, fei nado'o opa'ai,
\v 5 fei lomi na fa'arewaia a'a ei rama'aa ei tawe i didii, ale'ei i fa'arewaia fei Spiriti a'a ei apostle ma ei mamama'a, ei rona apunai a'a mei Haidaa.
\v 6 Fei manumanu inado'o opa'ai, sifeni ba, a'a fei rawani'a warea, ei Gentile, ro'ou ale'ei pa'aa na'u fipui a'a ei Israel ale'ei maroaa hepalo ua unu ma rona tofipuinaa fei fa'unaia a'a Christ Jesus.
\p 
\v 7 Unawe oanaa nafii feni rawani'a warea uaa fei rawani'aa mei Haidaa, fei na fanau a'a fei bigi'aa fei faufauna.
\v 8 Pa'aa fa'ua ba unamina oanaa pu laraa minaa ei apunaia, ma'uaa, ina fanau feni rawani'a: ba unei u'ufanaa ei Gentile ei watauda rawani'a manumanuu Christ ei na waiwai ba o labagipa'ia
\v 9 ma ba unei fama'aiaa minaa ei rama'a fei bigi'a a'a fei manumanu nado'o opa'ai, fei na ude'opa'ai a'a mei Haidaa fama'a, mei na famamaraiaa minaa ei manumanu.
\v 10 Fei naranarana, sifei ba e'eni, a'a ei losuia, ei watauda mau apa'aa mei Haidaa nei arewa a'a ei hapara mawe ei bauana inamoaa fei haroo pafea,
\v 11 ale'ei ba i neneraa fei nunumiana, fei na ude ranimai, fei inawe bigidigia a'a Christ Jesus, mei Fasuu o'ou.
\v 12 I a'ana ma wagii fei narafawe'ia a'ana, ina rawani ba o'aa nofarafi'ilao a'a mei Haidaa fininaa mamalawiaa naranara ma laugu'ua.
\v 13 Si'ei, a i'iginaa hamu'ou ba hamonei'aa fanunuta a'a ei awatau uaa hamu'ou, hamatee manumanu i farawaninaa hamu'ou.
\s1 Na Lafulafunaa ei Ephesus
\p 
\v 14 Sifei fei pa'afina ba una o'o'ui a'a mei Ama,
\v 15 mei, minaa ei maroana i pafea\f + \fr 3:15 \ft \bd 3:15\bd* O, \it mei, hia amaa minaa ei yei pafea\it*\f* ma yeni malagufu rona to haraa ro'ou a'ana.
\v 16 Una lafulafu ba a'a ei watauda rawani'ana i fawe'iaa hamu'ou laloo ei naranaraa hamu'ou a'a fei faufau noranamai a'a fei Spiriti
\v 17 ba i a'a fei narafawe'ia, Christ i oa laloo iaa hamu'ou. Ma una lafulafu ba hamu'ou, ena ina gugudii waraa fei hagua laloo iaa hamu'ou,
\v 18 hamonei pa'i faufau fipui a'a minaa ei apunaiaa mei Haidaa, hamonei aida ba batanai fei haguaa Christ—fei larena, malana, tarena ma walalona
\v 19 ma ba hamonei aida fei hagua fei, fei na muainaa fei apa'a—ba hamonei pepesu a'a minaa ei maumau mei Haidaa.
\p 
\v 20 Ma i a'ana, mei imina bigi'apoidinaa tamanu o'aa i'iginia o naranaraia wagii fei faufau, fei fi bigi inamoaa o'ou.
\v 21 Inei tonaa hawerana laloo fei losuu mawe Christ Jesus ma a'a minaa ei tawe ranimai ranimai! Amen.
\c 4
\s1 Fihupi'ii wagii fei Hudi Unuu Christ
\p 
\v 1 Si'ei ba yau hemea na bobo'ai uaa mei Fasu, u'ei ware'ai'ai a'a hamu'ou ba wagii ei tatalaiaa hamu'ou, inei rawani ua a'a fei rafeia hamona tonia.
\v 2 Hamoneimina fafafaunaa pu ma madumui; hamonei fawiwi'ai ma fafirawaninaa pafoo hememea hamu'ou fininaa hagua.
\v 3 A'a minaa ei faufau hamu'ou, hamonei panarofawe'ia fei hupi'iaa fei Spiriti wagii fei maumau gutafarawania.
\v 4 Na pa'i hepalo ua hudi unu ma hepalo ua Spiriti—ana ale'ei hamona tonaa hepalo ua o'onaia unu ei i rafeinaa hamu'ou—
\v 5 hemea ua Fasu, hepalo ua narafawe'ia, hepalo ua pudugufaia;
\v 6 hemea ua Haidaa, mei Amaa minaa ei rama'a, mei na pafeainaa minaa ei manumanu ma i a'a minaa e'ei ma i laloo minaa e'ei.
\p 
\v 7 Ma'uaa ina alaginaa fei rawani'ana a'a hememea o'ou ana ale'ei nunumiaa Christ.
\v 8 Si'ei, i\f + \fr 4:8 \ft \bd 4:8\bd* O, \it mei Haidaa i\it*\f* ware ale'ei ba:
\q1 “Ei i dinaa pafea,
\q2 ina tauduginaa ei bobo'aia laloo fei wana
\q2 ma ina fani fana a'a ei rama'a.”
\m 
\v 9 (Mei “ina dinaa pafea” ana na dinaa waduhero.\f + \fr 4:9 \ft \bd 4:9\bd* O, \it dinaa ei walaloaa feni malagufu.\it*\f*
\v 10 Mei na dinaa pu, ana simei mei na dinaa pafoo fei pumanugawe ba nei oa a'a minaa ei manumanu hitani.)
\v 11 Ana hia mei i alaginia ba hefi'a apostle, hefi'a mamama'a, hefi'a u'ugaa fei rawani'a warea ma hefi'a pasta ma feroia,
\v 12 ba ronei fawe'iaa ei apunaia a'a ei bigi'a ba fei pa'afii Christ neipa'aa we'i
\v 13 nopa'aloo fei fihupi'iaa minaa o'ou wagii fei narafawe'ia ma fei apa'aa mei Na'uu mei Haidaa ma opowe a'u ba opowe tonaa minaa ei maumau Christ.
\p 
\v 14 Ma nabaa ale'ei, lomidiai ba o'ou baduu ua ba o lafelao ma lafemai wagii ei mamaua ma waniwanii fei lalarenaa ei feroia ma ei manitoai sifisifii ei rama'a ba ro'aa sifi'aa o'ou.
\v 15 Ma'uaa owe wareaa fei fa'uaia fininaa fei hagua, a'a minaa ei manumanu opowe no'a'ulao a'a mei hia Fasu, mei Christ.
\v 16 I a'ana minaa fei pa'afi na udefipuinaa minaa ei wao hudi unu ma nogipelao ma noma'ualao fininaa fei hagua ei fi bigi'aa fei bigi'ana hepapalo finefinee unu.
\s1 Guta Ale'ei ei Na'uu fei We'ai
\p 
\v 17 Si'ei, a warefanaa hamu'ou feni ba hamonei bigi'ia a'a mei Fasu ba hamonei'aa tatalai ale'ei ei mau talaiaa ei Gentile, ale'ei fei mau hafelo'aa naranaraa ro'ou.
\v 18 Na roroma ei naranaraa ro'ou ma rona di'ininaa fei harenuaa mei Haidaa uaa ina polai tabaa ro'ou hamatee na waiwai tabaa ro'ou.
\v 19 Lomi rona fai nanamuipa'aa unuu ro'ou, si'ei, rona fifaninaa ro'ou a'a ei nunumiaa unuu ro'ou ba ro'aa bigi'aa minaa ei mau toai hafelo'a ma na ude sisii ua haraa ro'ou.
\p 
\v 20 Ma'uaa hamu'ou, lomi hamona apa'aa Christ ale'ei.
\v 21 Hamonapa'aa guainaa fei u'ugana ma hefi'a, rona feroinaa hamu'ou fei fa'uaia a'a Jesus.
\v 22 Rona feroinaa hamu'ou wagii fei tatalaiaa hamu'ou mina ba hamonei siminaa ei maumau hamu'ou mina, ei na tauia loasi a'a ei sifisifi nunumiana;
\v 23 ma ba hamonei tonaa fei manufau naranara
\v 24 ma hamonei fahawaiaa fei manufau maumau, fei na mamaramai ba i ale'ei mei Haidaa a'a fei pa'aa wanewanea ma fafa'araia.
\p 
\v 25 Si'ei, hememea hamu'ou nei siminaa fei mau sifisifi ma warefa'uai a'a mei gufumu, uaa minaa o'ou, maroaa hepalo ua unu.
\v 26 “Fapedugaa fei sibamu, apuna bigifafelo”: Inei pedu fei sibamu ei atawe lolo fei halo
\v 27 ma apuna fani ugaa pinee mei Hani'u.
\v 28 Mei na'aida topa'ai, inei'aa bigidinia, ma'uaa inei biginaa panina ba i pa'i manumanu ba i fani a'a ei lomi rona pa'i.
\p 
\v 29 Inei'aa lele'aa poamu ei hafelo'a warea, ma'uaa tamanu i hadumaa hefi'a a'a tamanu ona aida ba i farawaninaa ro'ou ba inei hadumaa ei rona guai.
\v 30 Ma apuna fanunutaa fei Spiriti Apuna mei Haidaa, fei na oa a'a hamu'ou ale'ei hepalo tamatama nopa'aloo fei arewaa ponohadiwe'ia.
\v 31 Fapedugaa minaa ei para'aa maumau, ei mau fifi'ii unu, ei sibasibaa, ei mau bala'afigii unu, ei mau u'ufafeloaa rama'a ma watauda ei mau ei bidibidii unu.
\v 32 Fafirawanii ma fifaloloa'inaa hememea ma futoaa ei tataa hememea hamu'ou ana ale'ei ba a'a Christ, mei Haidaa na futoaa ei tataa hamu'ou.
\c 5
\p 
\v 1 Si'ei, fei maumau hamu'ou nei fimina'einaa fei maumau mei Haidaa, ale'ei ei baduu, ei ina haguaa ro'ou
\v 2 ma tatalai fininaa fei hagua, ana ale'ei Christ na haguaa o'ou ma rawa'a'afai a'a mei Haidaa uaa o'ou, ale'ei hepalo fana, hepalo na dufa.
\p 
\v 3 Ma'uaa i a'a hamu'ou, inei'aa pa'i ma'ida mau fitatafipa'aia, o hepalo mau hafelo, o mau bagito, uaa ei maumau ei, lomi na rawani a'a ei rama'aa gufuu mei Haidaa, ei rona apunai.
\v 4 Ana hamonei'aa warefafelo, o warefa'a'afoloi, o hafelo'a warefifigaia, ei manumanu abaa rawani'a, ma'uaa hamonei ware ‘ta’ ua.
\v 5 Uaa a'a feni, hamonapa'aa aida ba fa'ua: Lomi i pa'i rama'aa fitatafipa'aia, hafeloia, o bagitoia ba i pa'i gutanana a'a fei haparaiaa Christ mawe mei Haidaa,\f + \fr 5:5 \ft \bd 5:5\bd* O, \it fei haparaiaa mei Christ mawe mei Haidaa\it*\f* uaa nemea ale'ei i haguaa e'ei manumanu e'ei.
\v 6 Apuna guaitonaa sifisifi wareaa nemea, uaa a'a ei manumanu ei, fei sibaa mei Haidaa, i pasinaa pafoo ei rona barafe.
\v 7 Si'ei, apuna rarafiaa ro'ou.
\p 
\v 8 Uaa mina, hamu'ou roromaa, ma'uaa e'eni hamu'ou we'ai a'a mei Fasu. Te, hamonei tatalai ale'ei ei na'uu fei we'ai
\v 9 (uaa ei fuaa fei we'ai, minaa ei rawani'a manumanu, ei na wanewane ma fa'uai)
\v 10 ma hamonei labarainaa tamanu na fani'eni'eaa mei Fasu.
\v 11 Apuna atetea a'a ei bigi'aa fei roromaa, ei lomi fuana, ma'uaa, fa'arewaiaa ro'ou.
\v 12 Uaa manumanuu mamafaa nabaa hamo'aa wareaa tamanu rona bigi'opa'ainia ei barafea.
\v 13 Ma'uaa minaa ei manumanu na fa'arewaia fei we'ai, ona fanunu'apa'ia,
\v 14 uaa fei we'ai na fa'arewaiaa minaa ei manumanu. Si'ei, i ware ale'eni:
\q1 “Wera, mena ma'igua,
\q2 asi'aa a'a ei ma'ea,
\q1 ma Christ i fawe'ainio.”
\p 
\v 15 Si'ei, hamonei talaiwagi'inaa hamu'ou—abaa ale'ei ei lomi rona pa'i apa'a, ma'uaa hamonei ale'ei ei rona pa'i apa'a.
\v 16 Ma hamonei bigifawe'i eni fi pa'i au, uaa eni arewaa e'eni na hafelo.
\v 17 Si'ei, hamonei'aa poapoai, ma'uaa hamonei apa'ifarawaninaa tamanu nunumiaa mei Fasu.
\v 18 Hamonei'aa hunufapoa-poai a'a ei wine, ei i notonaloo hamu'ou a'a ei hafelo'a. Ma'uaa inei didifaa hamu'ou fei Spiriti.
\v 19 Hamonei fiwarewareinaa ei psalm, ei laugaa losuu ma ei laugaa manumanuu fei Spiriti. Lalaugi ma tanu lauga i laloo naranaraa hamu'ou a'a mei Fasu
\v 20 ma ranimai, ware ‘ta’ a'a mei Haidaa, mei Ama wagii minaa ei manumanu a'a fei haraa mei Fasuu o'ou Jesus Christ.
\p 
\v 21 Si'ei ba hamona ma'auaa Christ, hememea hamu'ou nei fafefe a'a nemeadiai.
\s1 Pifine ma Wawane Haroo Lalai
\p 
\v 22 Hamu'ou ena pifine, hamonei fafefenaa ena haroo hamu'ou ana ale'ei hamona fafefenaa mei Fasu.
\v 23 Uaa mei wawane na haroa, hia mei fasuu mei harona ana ale'ei Christ, hia Fasuu fei losuu, fei hudi ununa, fei hia ana fatela'ana.
\v 24 Ma si'ei ba fei losuu na fafefenaa Christ, ana ale'ei ba ei pifine, ronei fafefenaa ei haroo ro'ou a'a minaa ei manumanu.
\p 
\v 25 Hamu'ou ena wawane, hamonei haguaa ei haroo hamu'ou, ana ale'ei Christ na haguaa fei losuu ma na rawa'a'afai wagina
\v 26 ba i fafafa'arainia, ale'ei ba ina fesuia\f + \fr 5:26 \ft \bd 5:26\bd* O, \it fesudigia\it*\f* a'a fei warea,
\v 27 ma ba i fa'ufalarainia i ma'ana ale'ei hepalo fananamai losuu, lomi na pidaa, o hafidu'udu'u, o hepalo lolo, ma'uaa na fafa'arai ma lomi tatana.
\v 28 Ena wawane lalaia, ronei haguaa ei haroo ro'ou ana ale'ei rona haguaa ei hudi unuu ana ro'ou. Mei na haguaa mei harona pifine na haguaa anaia.
\v 29 Uaa lomi hemea i bidibidi ununa a'a fei ana hudi ununa, ma'uaa ina faguia ma oma'aia ana ale'ei na bigi'ia Christ a'a fei losuu—
\v 30 uaa o'ou, maroaa fei pa'afina.
\v 31 Sifei fei pa'afina ba “Hemea wawane i di'ininaa amana ma inana ma i tau a'a mei harona ma lagu'awe pigioinaa hepalo.”
\v 32 Fei, hepalo baua manumanu na ude opa'ai—ma'uaa, u'ei warewareaa Christ ma fei losuu.
\v 33 Ma'uaa hememea hamu'ou nei haguaa mei harona pifine ana ale'ei ina haguaa anaia ma mei harona pifine, inei ma'auaa mei harona.
\c 6
\s1 Ei Baduu, ei Ama ma ei Ina
\p 
\v 1 Ena baduu, guainaa wareaa ei ama ma inaa hamu'ou a'a mei Fasu; uaa fei, ina wanewane.
\v 2 “Ma'auaa amamu ma inamu”—sifei fei rawarawa warea laloo fei law, fei i nofipuimai a'a fei warefa'unaia—
\v 3 “ba o'aa gutafarawani ma gutafamalaa yeni malagufu.”
\p 
\v 4 Ena ama, apuna fasibaiaa ei na'uu hamu'ou; agia, hamonei feroinaa ro'ou a'a ei feroia ma wareaa mei Fasu.
\s1 Ei Humuwa mawe ei Fasu
\p 
\v 5 Ena humuwa, guainaa wareaa ei fasuu hamu'ou yeni malagufu fininaa ma'aua ma honua ma rawani'a naranara, ana ale'ei ba hamona guainaa ei wareaa Christ.
\v 6 Guainaa wareaa ro'ou abaa una fei ba rona fanunuaa hamu'ou, ma'uaa, ale'ei humuwaa Christ, hamonei bigi'aa ei nunumiaa mei Haidaa noranamai i naranaraa hamu'ou.
\v 7 Si'ei, bigifawe'i, ale'ei ba hamona bigibigi a'a mei Fasu ma abaa a'a rama'a,
\v 8 uaa hamona aida ba mei Fasu i fani pono'a a'a hememea wagii tamanu rawani'a na bigi'ia nabaa hia humuwa, o lo'e.
\p 
\v 9 Ma ena fasu, ei rawani'aa hamu'ou nei fimina'ei a'a ei humuwaa hamu'ou. Apuna fararaoaa ro'ou, uaa hamona aida ba mei Fasuu hamu'ou ma ro'ou, hia i pafea ma lomi papa'aa ununa.
\s1 Ei Finefinee Fo'aa a'a mei Haidaa
\p 
\v 10 Fei fapopo'ii wareau sifei ba hamonei oafawe'i a'a mei Fasu ma a'a fei baua faufauna.
\v 11 Fahawaiaa minaa ei finefinee fo'aa a'a mei Haidaa ba hamo'aa ufadugepa'aa ei manitoai mei hani'u.
\v 12 Uaa fei ote'oteiaa o'ou abaa fi fadugeaa ei a'a pigio ma raraa, ma'uaa fi fadugeaa a'a ei hapara ma bauana mawe ei faufau feni ano, feni na roroma ma a'a ei hafelo'a spiriti inamoaa fei haroo pafea anaa.
\v 13 Si'ei, hamonei fahawaiaa minaa ei finefinee fo'aa a'a mei Haidaa ba ena ina nomai fei arewaa hafelo, hamo'aa ufawe'ipa'i ma ena hamona bigipedugaa minaa ei manumanu, hamo'aa ufawegipa'i.
\v 14 Si'ei, hamonei ofafaufau a'a fei adii fa'uaia, fei na adinaa walaa hamu'ou, a'a fei papanii niniwai fei wanewanea
\v 15 ma rafe supinee hamu'ou a'a fei rawani'a wareaa fei gutafarawania.
\v 16 Ma fahononoo minaa ei, tonaa fei rapirapii fei narafawe'ia, fei ina pereaa minaa ei hioo mei hani'u, ei na pa'i hafii umuna.
\v 17 Fahawainaa fei tao tela'ana ma waduu fei Spiriti, fei wareaa mei Haidaa.
\v 18 Ma lafulafu a'a fei Spiriti ranimai a'a watauda ei mau lafulafua ma i'igaia. Ei hamo'ei naranaraiaa e'ei, hamonei oma'ama'a ma u lafulafunaa ei apunaiaa mei Haidaa.
\p 
\v 19 Lafulafunau anaa ba ena una gigiaa umuu, i fani paolaa wareau ba a laugu'ai ena na fa'arewaiaa ei na ude opa'ai a'a fei rawani'a warea,
\v 20 fei u'ei guta bobo'ai wagina ale'ei hemea umuiaa mei Haidaa. Lafulafu ba unei wareia fininaa fei laugu'aia.
\s1 Ei A'apoo Aloana Warea
\p 
\v 21 Tychicus, mei pa'aa lofuu o'ou, mei weweaa nafi a'a mei Fasu, iwe warefanaa hamu'ou minaa ei manumanu ba hamonei aida ba yau batanai ma fi bigi'aa tamanu.
\v 22 Sifei fei pa'afina ei a aloiawau a'a hamu'ou ba hamonei aida ba hai'ou batanai ma ba i fawe'iaa ei naranaraa hamu'ou.
\p 
\v 23 Guapaloeni i dinaa a'a ei lofu: fei gutafarawania ma fei hagua fininaa fei narafawe'ia noranamai a'a mei Haidaa, mei hia Ama mawe mei Fasu, Jesus Christ.
\v 24 Fei rawani'a i dinaa a'a minaa ei lomi i pedutoo fei haguaa ro'ou mei Fasuu o'ou, Jesus Christ. 
