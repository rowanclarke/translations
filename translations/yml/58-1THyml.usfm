\id 1TH NT0108.1T1 IAMALELE (BEAUMONT) - 25-FEB-88; 1-October-2014 
\h 1 TESALONAIKA 
\toc3 1Te 
\toc2 1 Tesalonaika 
\toc1 Faulo yana kiluma nagami me Tesalonaika 'waidie. 
\mt1 1 TESALONAIKA  
\mt2 Faulo yana kiluma nagami me Tesalonaika 'waidie  
\is1 'Eba kiavemageta  
\ip Tutuyanina Faulo i miamia Kolinita, lubulubu de'e nagami i kilumi me Tesalonaika tovetumaganavo faifaidi. Tesalonaika tamu 'atamana bwaikina 'awalawa Masidonia nageneye, 'atamananina balebaleye. Faulo yana lau'age-vuvua 'ana vetonu 'waineye, bei be'ama Vala 'Atumaina i lu'ageyeni me Tesalonaika 'waidie. Yana lau'agenina 'wainega, tamu 'aila'a tovetumagana i souyeni. (Folova 17:1-14) Tovetumagananidi 'ifwaidi me Diu, we'e mali tomotoga kumanidiavo kebu Diu sai'afo moso'idi. We'e me Diunidi 'ifwaidi Iesu yana tafalolo 'ana 'eda'eda 'waineye i damana, begaidi me Diu to'edakumetavo i ve'unumagigi, Faulo ma enavo i sogiedi i nagoi Belia. Mulieta Faulo Timoti i vetunei i nago Tesalonaika. Tutuyanina i vilai i mai valadi 'atumaina i lu'ivoneyeni.  
\ip Lubulubunina nageneye Faulo i vekaiwa Yaubada 'waineye, fai me Tesalonaika ma yadi vetumagana i tokemaiga vita tulina tulina 'waidie wata fai ma yadi nuakalikali Faulo i nuanuani. Faulo nuanuana yana lubulubu 'wainega i na kiavetoketokedi, wata yadi velutoli tovetumagana i wafaga faifaidi i tutuli. Lubulubu de'e 'ana 'idi side bani'odi.  
\io1 Faulo yana vona-vekaiwa. \ior 1:1\ior*  
\io1 I vekaiwa Yaubada 'waineye yadi vetumagana faifaina. \ior 1:2-10\ior*  
\io1 Faulo yana sauluva me Tesalonaika 'awasasadie faifaina. \ior 2:1-12\ior*  
\io1 Faulo i nuanua me Tesalonaika yadi mia faifaina. \ior 2:13-3:13\ior*  
\io1 Sauluvanidi tovetumaganavo 'adi laubwaina. \ior 4:1-12\ior*  
\io1 Ve Iesu yana vila-vaitugana faifaina. \ior 4:13-5:11\ior*  
\io1 Velu'ase'ase 'ifwaidi wata yana 'alanuai. \ior 5:12-28\ior*  
\ie  
\c 1  
\m
\v 1 \x - \xo 1:1 \xt Fol 17:1\x*Emavo, yau Faulo, Sailasa wata Timoti taiadi 'a vekaiwa 'waimie. 'Omi Keliso yana 'Aila'a 'wa miamiani 'atamana Tesalonaika 'waineye, Yaubada Tamada wata 'ada Toveimea Iesu Keliso yadi tomotoga, 'waimie 'a kilukiluma.  
\p 'A vevelu'ui faifaimi, nuanuama Yaubada ma yana nuakalikali i na vevesauluva 'atumaina 'waimie wata nuanua bikana i na velevelemi mia 'atumaina taiadi.   
\s1 Faulo ma enavo i vekaiwa me Tesalonaika yadi sauluva faifaina  
\p
\v 2 Tutuya fuedi 'a vevekaiwa Yaubada 'waineye matatabumi faifaimi, wata 'a vevelu'ui 'waineye bega i na 'i'ivaisemi.  
\v 3 Yama vekaiwa Yaubada Tamada 'waineye faifaimi, fai tutuya fuedi 'a nuanuanimi yami vetumagana ma 'ana 'eba 'isa, yami folova toketokena fai ma yami nuakalikali, wata vita 'waidie 'wa totokemaigemi fai yami vetumagana 'wa yato-vagaseni 'ada Toveimea Iesu Keliso 'waineye.   
\p
\v 4-5 Emavo 'a 'asetai Yaubada i nuakalikaliemi wata i venua'ivinemi, fai tutuyanina Iesu Valana 'Atumaina 'a viweni 'waimie, 'Anu'anunu Magemagetana i 'imoso'ieni bega kebu vona 'aisena 'wainega, wata Yaubada yana toketokena i vemi bega 'wa ve'awamogitana. Yama sauluva 'akonadi 'wa 'asetai tutuyanina taiadi ta miamia, yami 'eba 'isa wata 'ami 'aivaita.   
\p
\v 6 \x - \xo 1:6 \xt Fol 17:5-9\x*Yama sauluvanidi wata 'ada Toveimea Iesu yana sauluva 'wa vetutuyamedi. Avinodi vita fuedi 'wa veluagadi Keliso 'ana tovedumwe'ai'ai 'waidiega, siwe ma yami sosoana 'Anu'anunu Magemagetana 'wainega, taunimi 'wa tauyemi Vala 'Atumaina 'waineye.  
\v 7 Keliso 'ana tovetumaganavo 'awalawa Masidonia wata Akaia\f + \fr 1:7 \ft 'Awalawa bwaikina Kulisi nageneye 'idi 'ailuga, yavalatayega 'awalawa Masidonia wata bolimanayega 'awalawa \fk Akaia\ft . Tesalonaika 'atamana bwaikina Masidonia nageneye. Tutuyanina Faulo i miamia Kolinita lubulubu de'e i kilumi i miamia Kolinita, 'atamananina 'awalawa \+fk Akaia\ft  nageneye. \f* nagedie yami sosoana wata yami tokemaiga i 'isedi yadi 'eba 'isa, nika i na vetutuyamemi.  
\v 8 Bega tutuya de'e 'waineye Toveimea Keliso Valana 'ana awavemogitana 'omi 'waimiega 'akonadi i vevebwaika 'awalawa Masidonia wata Akaia nagedie. We'e yami vetumagana valana i vaganago 'aila'a tulina tulina 'waidie bega tutuyanina 'atamananidi 'waidie 'a le'waga, tomotoga fuedi i veveifufu yami vetumagana faifaina. A noganogai, begaidi kebu i da lubwainema 'waidie wata 'a na veveifufu.  
\v 9 Tomotoganidi i lulu'ivona basenadi ma yami sosoana 'wa lu'uma'umaiema faifaina, wata kumaea 'waidie taunimi 'wa tauyemiga 'akonadi 'wa vedumwe'ai'aiedi. Nika 'wa nuavilami taunimi 'wa tauyemi Yaubada miamia-vagaina 'waineye 'wa vetofolova faifaina. Taunina 'aiseotogina mogitana Yaubada.  
\v 10 Wata tomotoganidi i lulu'ivona 'omi 'wa lulukamata Yaubada Natuna yana vila-vaitugana abamayega faifaina. Natunanina Iesu, kumanina basenadi i sivetovoia wafayega bega i 'i'ita'ita'ieda Yaubada yana nuasako wata yana vematavuloga 'awaie i na souyedi 'waidiega.   
\c 2  
\s1 Faulo yana folova Tesalonaika 'waineye  
\m
\v 1 Emavo, 'akonadi 'wa 'asetai yama wai 'waimie 'wainega 'aivaita 'wa veluagai, kebu 'a da wai-maimaiga.  
\v 2 \x - \xo 2:2 \xt Fol 16:19-24, 17:1-9\x*Wata 'wa 'asetai basenadi 'atamana Filifai 'waineye Keliso 'ana tovedumwe'ai'ai vita bwaikina i velema wata i yagaima siwe yada Yaubada toketokena i velema bega 'a wai 'waimie ma yama venuafoufa'ala Valana 'Atumaina 'a lu'ivona. We'e tovedumwe'ai'ai 'ifwaidi taiadi 'wa miamianiga kebu 'a da kololoyedi bega yama folova 'a da baileni, fai Yaubada yana 'aivaita 'wainega 'a folofolova.  
\v 3 Begaidi 'wa na 'asetai, 'ima 'a lau'agega 'waimie kebu vekaliega, mani 'alo kukua faifaidi 'a da nunua'animi yama veifufu 'waidiega.  
\v 4 'A vonaga fai Yaubada i nuani 'ima i lubwainema Iesu Valana 'Atumaina i tauyeni 'waimeye 'a na lulu'ivona. Kebu tomotoga 'adi kiavesosoana faifaina 'a da vonavona siwe ava'ai Yaubada nuanuana 'ana 'eba kiavesosoana faifaina 'a vonavona, Yaubada yama nuanua matatabuna i 'asetadi, 'atumaidi 'alo sakoidi.  
\v 5 'Omi 'wa 'asetama wata Yaubada i 'asetama kebu 'a da nunua'animi subia-vekavekali 'wainega wata mani faifaina kebu a da veiana-sebesebemi.  
\v 6 Kebu 'ama subia faifaina 'a da folofolova, bega 'omi 'alo mali tomotoga 'wa na subiama.   
\p
\v 7 'Ima Keliso yana tomata'aulelevo 'ama fata 'a da lukakademi 'ani'ani wata nani 'ifwaidi 'wa da velevelema, siwe kebu bani'odi 'a da vevesauluvaga. Tutuyanina taiadi ta miamiani yama sauluva bikana bani'odi vavine natudiavo i 'i'isave'avinidi.  
\v 8 Ma yama nuakalikali Yaubada yana Vona 'a lu'ivona 'waimie. 'A nuakalikaliemi bwaikina begaidi kebu vona 'aisena 'a da velemi, wata taunima 'a tauyema 'a vetofolova 'waimie.   
\p
\v 9 Emavo, 'wa na nuani basenadi yama folova 'waimie. 'Aiata wata lovana 'a folofolova ma yama 'idumwebika, Yaubada yana Vona a lulu'ivona 'waimie wata taunima 'a 'i'isave'avinima 'ani'ani 'wainega fai kebu nuanuama vita 'a na velemi 'ama 'isave'avina faifaina.   
\p
\v 10 Side bani'odi, 'omi Keliso 'ana tovetumaganavo, yama sauluva 'wa 'isedi wata Yaubada i 'isedi, bega 'wa 'asetama kebu tamu tutuya 'a da vekaliemi, yama mia matatabuna 'waidie yama sauluva tonovidi wata 'atumaidi.  
\v 11 Fai yama 'aivaita 'aitamogana 'aitamogana 'waimie 'wa da vo bani'odi tomogo natunavo i da 'i'isave'avinidi.  
\v 12 Yami vetumagana 'a kiavefa'alidi, nuami 'a 'iveagiagidi wata 'a vevelu'ase'asemi yami sauluva i na ve'atumai bega Yaubada i na sosoana faifaimi. I lubwainemi yami sauluva 'atumai'avadi fai Yaubada i venua'ivinemi nuanuana yana 'ai'aiwabu magemagetadi i na velemi, taiadi 'wa na miamia yana 'Eba Veimea nageneye.   
\s1 Me Tesalonaika vita i veluagadi Keliso 'ana tovedumwe'ai'ai 'waidiega  
\p
\v 13 'A vevekaiwa Yaubada 'waineye fai tutuyanina Yaubada yana Vona 'a viweni 'wa nogai nuami i 'ewai, fai 'wa 'asetai vonanina Yaubada yana Vona kebu tomotogaotoga yadi vona, we'e mogitana Yaubada yana vona. Vonanina 'wainega Yaubada i folofolova 'omi tovetumagana nuamie.  
\v 14 \x - \xo 2:14 \xt Fol 17:5\x*Emavo, tutuyanina 'wa tauyemi Keliso 'waineye vita 'wa veluagadi taunimi yami tomotoga 'waidiega, bani'odi basenadi me Iudia 'ifwaidi i vetumagana Iesu Keliso 'waineye i luku Yaubada yana 'Aila'a 'waineye, vita i veluagadi taunidi yadi tomotoga me Diu 'waidiega.  
\v 15 \x - \xo 2:15 \xt Fol 9:23,29, 13:45,50, 14:2,5,19, 17:5,13, 18:12\x*Tovedumwe'ai'ainidi basenadi Yaubada yana tolu'ivonavo i luvewafadi mulieta Toveimea Iesu, we'e 'ima i veugeugema. Tomotoganidi ma yadi nuasako tomotoga matatabuna i vevegaviedi we'e Yaubada kebu i da sosoana faifaidi.  
\v 16 Yadi sakona i 'imoso'ieni igodi i tatalaboda kebu nuanuadi 'a na lalau'age mali tomotoga kumanidiavo kebu Diu 'waidie bega Yaubada i na 'ita'ita'iedi. Yadi sakonanidi i vevebwaika i maiga nika 'asiau Yaubada yana nuasako i souyeni 'waidie i na vematavulogidi.   
\s1 Faulo nuanuana me Tesalonaika i na foge-vaituganidi  
\p
\v 17 Emavo, basenadi 'a 'iawemi kebu maigimi 'a da 'ise'isedi siwe kebu 'a da venuafanimiga. 'A mai kebu tutuya manamanawenaga nuanuama bwaikina 'a da wai 'a da foge-vaituganimi.  
\v 18 Vona mogitana 'a vetafewa 'a da wai faifaina, we'e yau Faulo tutuya fuedi a vetafewa-wayoga fai Seitani yama 'eda i sibodai vita tulina tulina 'waidiega.  
\v 19 'Awaie 'ada Toveimea Iesu i na vilai i na mai fueda ta na tovoi mataneye, 'omi yama 'eba sosoana 'ama subia faifaina. Yama folova 'wainega 'wa vetumagana Keliso 'waineye bega 'a nuani mogitana 'ana tutula 'a na veluagai Yaubada 'wainega.  
\v 20 Vona mogitana 'omi 'ama 'eba subia 'a sososoanemi.   
\c 3  
\s1 Faulo Timoti i vetunei nuanuana me Tesalonaika yadi mia i na 'asetai  
\m
\v 1-3 \x - \xo 3:1-3 \xt Fol 17:15\x*Tutuya manamanawena kebu maigimi 'a da 'ise'isedi wata valami 'a da noganogai begaidi 'a vevenuafouviga faifaimi. 'A nuani yau wata Sailasa 'ama 'ailuga 'a na miamia 'atamana Adeni, we'e Timoti 'a voneni i wai 'waimie. Taunina iada 'ama 'aila'a, ma fuemeye Yaubada faifaina 'a folofolova Keliso Valana 'Atumaina 'a lalau'age-vuvua. 'A vetuneiga i na 'ivaisemi yami vetumagana i na kiavetoketokedi bega tutuyanina vita 'wa na veluagadiga, kebu tamu aitoi 'waimiega Iesu i na baileni i na vilai yana sauluva tuatuaina 'waineye. 'Omi 'akonadi 'wa 'asetai Yaubada vita i tauyedi i na souyedi 'waideye.  
\v 4 'Wa 'asetaiga fai tutuyanina taiadi ta miamia 'a vona-vagasemi 'a vo, 'Awaie Keliso 'ana tovedumwe'ai'ai i na vegavieda vita ta na veluagadi,” ava'ai a voneyeniga 'ana mogitana i sousouyeni 'waimie, 'wa 'iseni nika 'wa nuani.  
\v 5 A toke faifaimi a nuanua fai a 'asetai vita 'wa veveluagadi begaidi Timoti a vetunei i wai i na 'isemi, yami vetumagana toketokena 'alo mweana bega i na mai i na lu'ivona 'waikuye. A kololo i na nunago Seitani yana 'eba sailubu 'wainega i na vekaliemi 'wa na sakona nika yama folova basenadi 'waimie i na venani-'avo'avovo.   
\s1 Timoti yana lu'ivona me Tesalonaika faifaidi  
\p
\v 6 \x - \xo 3:6 \xt Fol 18:5\x*Siwe tutuyanina Timoti i vilai i mai yami vetumagana toketokena wata yami nuakalikali bwaikina valana 'atumaina i lu'ivoneyedi. Wata i voneku tutuya fuedi ma yami sosoana 'wa nunuave'avinima, we'e nuanuami bwaikina 'a na foge-vaituganimi. 'Ima wata bani'odi nuanuama 'a na 'isemi.   
\p
\v 7 Emavo, 'ima vita wata veviga 'a veveluagadi siwe yami vetumagana toketokena valana faifaina mogitana i kiavesosoanima.  
\v 8 Fai ma yami vetumagana 'wa tovotovoi fa'alina Toveimea Iesu 'waineye, begaidi nuafouma i vatu wata yama mia i ve'atumai.  
\v 9 Yami sauluvanina faifaina 'a sosoana-'afo'afo Yaubada mataneye, faifaimi 'a vevekaiwa 'waineye.  
\v 10 'Aiata wata lovana 'a vevelu'ui nuanuama bwaikina tauniotogimi 'a na 'isemi bega yami vetumagana Keliso 'waineye 'a na 'imoso'iedi.   
\p
\v 11 A vevelu'ui nuanuaku yada Yaubada Tamada tauniotogina wata 'ada Toveimea Iesu yama 'eda i na 'idewai 'a na wai 'waimie.  
\v 12 Wata nuanuaku i na 'ivaisemi yami nuakalikali emiavo wata tomotoga 'ifwaidi 'waidie i na vebwaika-'afo'afo, yama nuakalikali 'waimie bani'odi.  
\v 13 Nika i na 'ivaisemi 'wa na vetoketoke bega tutuyanina 'ada Toveimea Iesu i na vila-vaitugani yana tomotoga magemagetadi matatabudi taiadi, yami sauluva 'atumai'avadi wata magemagetadi 'wa na tovoi yada Yaubada Tamada mataneye.   
\c 4  
\s1 Sauluvanidi Yaubada yana 'eba sosoana, kumanina nuanuana  
\m
\v 1-2 Emavo, sai'afoga 'a na 'ailove, siwe nuanuama wata 'a na vonemi. Sauluva tonovidi 'wa 'asetadi 'waidiega 'ana fata Yaubada 'wa na kiavesosoani, fai basenadi 'a awave'ede'edemi Iesu Keliso yana veimea 'wainega. 'Akonadi bani'odi 'wa vevesauluvedi, siwe 'asiau 'ada Toveimea Iesu 'ana wagavayega wata 'a na vonemi, nuanuama bwaikina 'wa na nunuave'avini Yaubada yana nuanua 'wa na 'i'idewai.  
\v 3-4 Yaubada nuanuana yami sauluva magemagetana mataneye, kebu 'wa na sakona bunu 'ana nuanua 'wainega, 'aitamogana 'aitamogana taunina tomogona i na 'i'isave'avini wata yana sauluva 'atumai'avana ma 'ana ve'ililibu.  
\v 5 Kebu nuanuama Yaubada 'ana tobavu yadi sauluva 'wa na vetutuyamedi, i veve'avula-'avo'avovo.  
\v 6 Kebu i da lubwaineni tamu aitoi iana i na vekalieni yana vavine i na luobuyedi, fai egavo bani'odi i sakonaga 'Auvea vematavuloga i na veledi. Naninina faifaina basenadi 'a matakiami.  
\v 7-8 Yaubada i venua'ivineda kebu ta na sakosakona, i venua'ivinedaga ta na vevesauluva tonovina mataneye, bega egavo yama venidi i na vedumwe'ai'aiediga, kebu tomotoga yama veimea 'aisedi i da vedumwe'ai'aiedi, siwe wata Yaubada, kumanina 'Anu'anununa Magemagetana i velemiga, i vedumwe'ai'aieni.   
\p
\v 9 'Omi tovetumagana ma emiavo 'wa vevenuakalikaliga, kebu i da lubwainema faifaina 'a na kiluma 'waimie, fai 'akonadi Yaubada i vemi bani'odi 'wa na munega ma emiavo 'wa na vevenuakalikali.  
\v 10 Vona mogitana 'akonadi bani'odi 'wa vevesauluvedi emiavo tovetumaganavo yami 'awalawa Masidonia matatabuna nageneye 'wa nunuakalikaliedi. 'Wa nunuakalikaliga siwe 'a na velu'ase'asemi, nuanuama yami nuakalikali i na vebwaika-'afo'afo.   
\p
\v 11 Wata nuanuama 'wa na vewavawava yami mia i na ve'atumai, kebu 'wa na tolive'eda tomotoga 'ifwaidi 'waidie, we'e 'ami'ami faifaina taunimi 'wa na folofolova, basenadi bani'odi 'a vonemi.  
\v 12 'Ai'edi bani'odi 'wa na vesauluvediga, egavo kebu i da tauyediga Keliso yana 'Aila'a 'waineye, yami sauluva i na 'isedi nika i na ve'ililibuyemi wata kebu vakeli'ava faifaina 'wa na nuanua.   
\s1 Iesu yana vila-vaitugana faifaina  
\p
\v 13 Emavo, nuanuama 'a na veifufu 'waimie towafa faifaidi bega kebu 'wa na nuavita. Egavo kebu i da vetumaganaga Keliso 'waineye i nunuavita ediavo i wafaga faifaidi fai i nuani kebu wata i na 'isedi, we'e 'ida tovetumagana kebu ta na saladiga.  
\v 14 'Ida ta vetumagana ta 'asetai Iesu i wafa wata i yawasa-vaitugana, begaidi wata ta vetumagana Iesu yana tomotoga i wafaga i na yawasa-vaitugana bega Iesu taiadi Yaubada i na vagavaidi i na maia.   
\p
\v 15 \x - \xo 4:15 \xt 1Ko 15:51-52\x*De'e 'ada Toveimea Iesu yana vona 'a lulu'ivoneyeni 'waimie. Tutuyanina i na vilai i na mai 'ida ma yawaida kebu ta na kumetaga, nagami tovetumagana i wafaga i na kumeta Iesu taiadi i na veluaga.  
\v 16-17 We'e 'aiatanina 'waineye bona bwaikina 'wainega i na veimea, anelose yadi to'edakumeta bonana wata Yaubada yana evulega tomotoga i na nogaidi, nika 'ada Toveimea taunina i na obuma abamayega. Keliso yana 'Aila'a i wafaga nagami i na tovoi, mulieta 'ida ma yawaida ta miamianiga i na si'augida ma fuedeye ta na laka waowa 'waidie Toveimea Iesu taiadi ta na veluaga 'awasasa'aveye. Bega tutuya matatabuna 'ada Toveimea taiadi ta na mia-vagata.  
\v 18 Vona mogitana ta na tovoi wafayega begaidi wafa 'ana tutuye, emiavo 'wa na kiavesosoanidi vona de'e 'wainega.   
\c 5  
\s1 'Wa na 'idewadewa 'ada Toveimea yana vila-vaitugana faifaina  
\m
\v 1-2 \x - \xo 5:1-2 \xt Mad 24:43; Luk 12:39; 2Fi 3:10\x*Emavo, kebu i da lubwainema Iesu yana vila-vaitugana 'ana tutuya faifaina 'a na kiluma 'waimie fai 'aiatanina 'akonadi 'wa 'asetai i na vaimwaimwamo. 'Ai'edi tamu tovainago nuanuana i na vainago lovane kebu i na lu'ivona, i na maimo. Wata bani'odi 'ada Toveimea yana 'aiata kebu i na lu'ivona i na maimo tomotoga yawaidi i na lovoga.  
\v 3 'Ai'edi vavine ma kamodi, kebu i da 'asetai ma'avia i na vebutudi, i na miamiamo nika i na vebutudi. Wata bani'odi kebu ta da 'asetaiga ma'avia Iesu i na souyeni i na mai. Tutuyanina tomotoga i na vo, Yada mia i ve'atumai, vetalaga kebu,” bei i na tala'avuidi nika yawaidi i na lovoga. Kebu tamu aitoi 'ana fata i na dega 'alo ava'aiamo i na nago.   
\p
\v 4 Emavo, we'e 'omi kebu dudubala 'ana tomia, bega kebu i da lubwainemi 'ada Toveimea i na veyawailovogimi yana 'aiata 'waineye.  
\v 5 'Omi matatabumi mageta 'ana tomia wata 'aiata 'ana tomia. 'Ida kebu lovana 'ana tomia, kebu nuanuada dudubala 'ana sauluva.  
\v 6 Begaidi kebu i da lubwaineda ta na 'eno'eno tomotoga 'ifwaidi bani'odi, ta na 'isa'isa wata yada sauluva ta na 'i'isave'avinidi.  
\v 7 We'e lovana tomotoga yadi 'eba 'eno wata lovane tomotoga ufa toketokedi i yemuyemu nuadi i lulugaugaudi.  
\v 8 \x - \xo 5:8 \xt Ais 59:17; Efe 6:13-17\x* We'e 'ida 'aiata 'ana tomia i lubwaineda ta na 'isa'isa wata yada sauluva ta na 'i'isave'avinidi. Yada vetumagana Iesu 'waineye wata 'ana nuakalikali 'asa'aiana tomogoda 'adi velubabala ta na veagei, wata ta na nuani mogitana 'ita'ita'i ta na veluagai Iesu 'wainega, 'asa'aiana 'unu'unuda 'adi velubabala ta na silakaveni.  
\v 9 Yaubada i venua'ivinedaga kebu yana vematavuloga faifaina, i venua'ivineda nuanuana i na 'ita'ita'ieda 'ada Toveimea Iesu Keliso 'wainega.  
\v 10 Taunina i wafa faifaida bega 'ai'edi ma yawaida 'alo ta na wafaga kebu tamu ava'ai, tutuyanina i na vilai i na mai taiadi ta na miamia.  
\v 11 'Akonadi ma emiavo 'wa ve'ivaivaita yami vona 'waidiega, i lubwainemi tutuya fuedi bani'odi 'wa na vevesauluvedi fai ta 'asetai 'awaie Iesu taiadi ta na miamia.   
\s1 Faulo yana nuanua 'ana 'eba ve'a'ava  
\p
\v 12 Emavo, nuanuama bwaikina yami to'edakumetavo 'wa na veve'ililibuyedi, taunidi 'ada Toveimea Iesu i venua'ivinedi yana folova i 'i'idewadi 'awasasamie, i 'i'isave'avinimi wata i veve 'waimie Keliso yana nuanua faifaidi.  
\v 13 Yadi folovanidi faifaidi ma yami nuakalikali 'wa na ve'ililibuyedi. Sauluva bikanega ma emiavo 'wa na veveiana yami mia matatabuna 'waidie.   
\p
\v 14 Emavo, 'a na velu'ase'asemi, nuanuama tovedumwe'ai'ai 'wa na matakiadi i na folofolova, tovenuafouviga 'wa na kunivatuvatudi, egavo i mwea 'wa na 'i'ivaisedi wata 'wa na totokemaiga 'wa na vetofolova tomotoga matatabudi 'waidie.  
\v 15 'Wa na 'i'isave'avinimi bega 'ai'edi egavo i na vesauluva sakoina 'waimie, kebu tamu aitoi 'waimiega wata sakona 'wainega i na tutuli, siwe tutuya fuedi 'wa na vewavawava, 'wa na vevesauluva 'atumaina emiavo wata tomotoga matatabuna 'waidie.   
\p
\v 16 Tutuya matatabuna ma yami sosoana 'wa na miamia.  
\v 17 'Wa na vevelu'ui-vebogi Yaubada 'waineye, kebu 'wa na 'ailove.  
\v 18 'Ai'edi tutuya safailina 'alo tutuya vitana 'waimie, siwe 'wa na vevekaiwamo. 'Omi Iesu Keliso yana tomotoga, begaidi side bani'odi Yaubada nuanuana 'wa na vevesauluvedi.   
\p
\v 19 'Anu'anunu Magemagetana yana folova wata yana 'aivaita kebu 'wa na ve'etobodeni.  
\v 20 'Ai'edi aitoi 'Anu'anununina yana 'alavelevelena 'wainega i na lau'agega, kebu 'wa na sidibidibieni.  
\v 21-22 Venidi wata nani matatabuna nagami 'wa na venua'ivinedi, 'ai'edi mogitana 'atumaina 'wa na 'ive'avini, we'e nani 'aitamogana 'aitamogana sakoidi 'wa na kekesedi.   
\s1 Faulo yana 'alanuai  
\p
\v 23 Yaubada nuanua bikana wata mia 'atumaina i veleveleda, bega a vevelu'ui 'waineye nuanuaku yana 'aivaita 'wainega yami sauluva magemagetana mataneye. Wata nuanuaku yana toketokena 'wainega 'anu'anunumi, yami nuanua wata tomogomi i na 'i'ita'ita'iedi i na nagoga 'ada Toveimea Iesu Keliso yana vila-vaitugana 'waineye kebu tamu 'ami 'eba awavesako.  
\v 24 Yaubada i venua'ivinemiga, taunina naninidi de'e i na 'idewadi faifaimi fai ma 'ana vetumagana, kebu i na baileda.   
\p
\v 25 Emavo, nuanuama faifaima 'wa na vevelu'ui.   
\p
\v 26 Fai 'omi Yaubada yana tomotoga, ma yami nuakalikali emiavo 'wa na sosoanedi venima'abi 'wainega.   
\p
\v 27 'Auvea yana veimea 'wainega a velu'ase'asemi bega lubulubu de'e 'wa na lu'iawawai edavo tovetumagana matatabuna 'waidie.   
\p
\v 28 'A vevelu'ui faifaimi, nuanuaku 'ada Toveimea Iesu Keliso ma yana nuakalikali i na vevesauluva 'atumaina 'waimie.  
\b  
\q1 'Asa'aiana bani'odi,  
\q2 \sig Faulo\sig*   