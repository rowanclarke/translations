\id COL Rough: Sekoumady, Jun 96. Rework: Feb 99. Printed: Oct 00.
\h كْلْسِ
\toc1 عَلَ شَ مَسٍنيِ عَننَبِ ثْلُ نَشَن سّبّ كْلْسِ دَنشَنِيَتْي حَمَ مَ
\toc2 كْلْسِ
\mt1 عَلَ شَ مَسٍنيِ
\mt1 عَننَبِ ثْلُ نَشَن سّبّ
\mt1 كْلْسِ دَنشَنِيَتْي حَمَ مَ
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip يِ كِتَابُي قِندِشِ بَتَاشّ نَن نَ عِسَ شَ شّيرَ ثْلُ نَشَن سّبّ عِسَيَنكَيٍ مَ نَشٍيٍ نُ سَبَتِشِ كْلْسِ تَا كُي. ثْلُ مُ نُ قِندِشِ كَوَندِلَ سِنفٍ شَ رَ نَشَن عِسَ شَ قٍ مَسٍن عٍ بّ، كْنْ عَ عٍ كٌلٌن رْ مَ نّ، عَ نُ نَ فٍيلِ دّننَشّ. عَلَ شَشِلِ سّنِيّنشِ نَشَ مَسٍنيِ ندٍ قِ ثْلُ مَ كْلْسِكَيٍ بّ، عَ نُن عِسَيَنكَيٍ بِرِن بّ نَشٍيٍ نُ سَ قَمَ لُدٍ دُنِحَ بّندّ قُحِ قَرِ. يِ كِتَابُي كُي، مِشِ نْمَ لْننِ فبٍفبٍ سْتْدٍ عِسَ شَ قٍ مَ عَ نُن عِسَيَنكَيٍ حّرّ كِ شَ قٍ مَ.
\ip عَلَ شَ وٌن مَلِ عَ شَ مَسٍنيِ سَابُي رَ عَلَكٌ وٌن شَ سّيوّ سْتْ دُنِحَ مَ، وٌن مَن شَ سّيوّ سْتْ عَلِفِيَمَ. عَمِنَ.
\mt1 عَلَ شَ مَسٍنيِ
\mt1 عَننَبِ ثْلُ نَشَن سّبّ
\mt1 كْلْسِ دَنشَنِيَتْي حَمَ مَ
\cl سٌرَ
\c 1
\s1 شّيبُي
\p 
\v 1 ﭑ تَن ثْلُ نَن يِ كِ، عَلَ عَ رَفِرِشِ نَشَن شَ قِندِ عِسَ شَ شّيرَ رَ. مُشُ نُن تِمٌتٍ نَن يِ بَتَاشّ سّبّقٍ
\v 2 وٌ تَن مَ، كْلْسِكَيٍ سّنِيّنتْييٍ. وٌ بَرَ قِندِ ﭑ نفَشَكٍرٍنيِ دَنشَنِيَتْي رَ بَرِ مَ وٌ لَشِ عَلَ شَ مِشِ سُفَندِشِ رَ. وٌن بَبَ عَلَ شَ هِننّ نُن بْحّسَ قِ وٌ مَ.
\s1 ثْلُ كْلْسِكَيٍ تَنتُقٍ
\p 
\v 3 مُشُ بَرَ عَلَ تَنتُ، وٌن مَرِفِ عِسَ بَبَ. مُشُ عَلَ مَشَندِ مَ وٌ بّ تّمُي بِرِن.
\v 4 مُشُ يِ نَن مّشِ، وٌ بَرَ دَنشَنِيَ عَلَ شَ مِشِ سُفَندِشِ عِسَ مَ، وٌ مَن بَرَ عَلَ شَ سّنِيّنتْي بِرِن شَنُ.
\v 5 وٌ شَشِلِ تِشِ قٍ رَ عَلَ نَشَن نَفَتَشِ وٌ يَ رَ كٌورٍ مَ. وٌ شَ دَنشَنِيَ نُن وٌ شَ شَنُنتٍيَ كٍلِمَ نَ نَن مَ. وٌ بَرَ نَ بِرِن مّ عَلَ شَ نْندِ كُي نَشَن قِندِشِ شِبَارُ قَنيِ رَ.
\v 6 نَ شِبَارُ قَنيِ بَرَ قِندِ فٍينِ رَ دُنِحَ بِرِن بّ. عَ مَن بَرَ قِندِ فٍينِ رَ وٌ بّ وٌ عَلَ شَ هِننّ يَتِ كٌلٌنشِ تّمُي نَشّ.
\v 7 وٌن نفَشَكٍرٍنيِ، مُشُ وَلِبٌورٍ عٍثَقِرَ سِ نَن وٌ شَرَنشِ نَ نْندِ رَ. عَ بَرَ قِندِ عَلَ شَ مِشِ سُفَندِشِ شَ وَلِكّ تِنشِنشِ رَ وٌ بّ.
\v 8 عَ بَرَ عَ مَسٍن مُشُ بّ عَ وٌ مِشِ شَنُمَ عَلَ شَشِلِ سّنِيّنشِ سَابُي رَ.
\s1 ثْلُ كْلْسِكَيٍ رَلِمَنِيَقٍ
\p 
\v 9 نَ نَن عَ تٌشِ، مُشُ قَن، كَقِ مُشُ نَشَ نَ كٌلٌن، مُشُ عَلَ مَشَندِقٍ نّ وٌ بّ تّمُي بِرِن، عَ شَ قَهَامُي نُن شَشِلِ قَنيِ قِ وٌ مَ عَلَكٌ وٌ شَ عَلَ سَفٌ كٌلٌن عَ قَنيِ رَ.
\v 10 وٌ شَ وٌ حّرّ عَلْ وٌن مَرِفِ وَ مَ عَ شْن مَ كِ نَشّ. وٌ شَ قٍ قَنيِ مْولِ بِرِن نَبَ. وٌ شَ عَلَ كٌلٌن عَ قَنيِ رَ.
\v 11 وٌ شَ سّنبّ سْتْ عَ شَ سّنبّ مَفَاشُشِ سَابُي رَ، عَلَكٌ وٌ شَ وٌ تُننَبّشِ، وٌ مَن شَ دِحّ،
\v 12 وٌ مَن شَ بَبَ عَلَ تَنتُ سّيوّ كُي. عَ بَرَ عَ رَفِرِ وٌ شَ نْ سّنِيّنتْييٍ كّ سْتْدٍ نَءِيَلَنيِ كُي.
\v 13 عَ بَرَ وٌن نَمِنِ سٍنتَنّ شَ نْي بُن مَ، نَشَن قِندِشِ دِ مِ رَ، عَ وٌن نَسٌ عَ شَ دِ شَنُشِ شَ مَنفّيَ نِينِ بُن مَ.
\v 14 نَ دِ بَرَ وٌن شُنسَرَ، عَ بَرَ وٌن مَ يُنُبِيٍ شَقَرِ.
\s1 عَلَ شَ مِشِ سُفَندِشِ
\p 
\v 15 عَلَ مُ تٌمَ، كْنْ عَ شَ دِ قِندِشِ عَ مِسَالِ نَن نَ. دَالِ بِرِن قِسَمَنتٍ نَن عَ رَ.
\v 16 عَ تَن نَن سٍ بِرِن دَا، نَشَن نَ كٌورٍ مَ، نَشَن نَ بْشِ مَ، نَشَن تٌمَ، نَشَن مُ تٌمَ، مَنفّيٍ، يَامَرِتْييٍ، نْلَيٍ، سّنبّمَيٍ. نَ بِرِن دَاشِ عَ سَابُي نَن نَ، نَ بِرِن دَاشِ عَ يّتّ نَن بّ.
\v 17 بٍينُن سٍ كٍرٍن شَ دَا، عَ تَن نُ نَ. عَ بِرِن نَ نَ عَ تَن نَن سَابُي رَ.
\v 18 دَنشَنِيَتْي حَمَ شُنيِ نَ عَ تَن نَن نَ. نَ لُمَ نّ عَلْ عَ قَتٍ يَتِ يَتِ. عَ تَن نَن نَ قٍ بِرِن قْلّ رَ. عَ تَن نَن سِنفٍ رَكٍلِ قَشّ مَ، عَلَكٌ عَ شَ قِندِ دُنِحَ قِسَمَنتٍ رَ.
\v 19 عَ نَشَ رَقَن عَلَ مَ عَ شَ عِسَ رَكَمَلِ عَلَ شَ قٍ بِرِن نَ.
\v 20 عَ مَن بَرَ تِن قٍ بِرِن مَسٌدٍ عَ رَ عَ شَ دِ شَ قَشّ سَابُي رَ. بْحّسَ شَ لُ عَلَ نُن دُنِحَ بِرِن تَفِ، نَشَن نَ كٌورٍ نُن بْشِ مَ. نَ لَنيِ بَرَ لُ عٍ تَفِ عَلَ شَ دِ وُلِ سَابُي رَ، نَشَن بَنبَن وُرِ مَفَلَنبُشِ مَ.
\p 
\v 21 سِنفٍ رَ، وٌ تَن نُن عَلَ، وٌ تَفِ نُ عِكُيَ. عَ يَشُييٍ يَتِ يَتِ نَن نُ نَ وٌ رَ، بَرِ مَ وٌ نُ قٍ حَاشِيٍ مَحْشُنمَ، وٌ مَن نُ عٍ رَبَمَ.
\v 22 كْنْ يَكْسِ، لَنيِ بَرَ لُ وٌ تَفِ عَلَ شَ دِ شَ قَشّ سَابُي رَ، عَلَكٌ وٌ شَ سّنِيّن، وٌ شَ تِ عَلَ يَ عِ، تَنتَنيِ نُن مَرَكْرْ سِ يٌ مُ نَ وٌ مَ سْنْن.
\v 23 كْنْ عَ لَنمَ نّ وٌ شَ دَنشَنِيَ شَ سَبَتِ، عَ شَ سّنبّ سْتْ، عَلَكٌ وٌ نَشَ مَكُيَ قٍ قَنيِ رَ نَشَن نَفَتَشِ وٌ بّ عَلَ شَ شِبَارُ قَنيِ سَابُي رَ. نَ شِبَارُ قَنيِ وٌ نَشَن مّشِ، عَ مَسٍنشِ نّ دُنِحَ بِرِن بّ. ﭑ تَن يَتِ وَلِمَ نَ نَن مَ.
\s1 ثْلُ شَ وَلِ
\p 
\v 24 يَكْسِ، ﭑ بَرَ حّلّشِن ﭑ تْورْقٍ مَ وٌ شَ قٍ رَ. ﭑ يّتّ يَتِ قَمَ عَلَ شَ مِشِ سُفَندِشِ عِسَ شَ تْورّ رَكَمَلِدٍ دَنشَنِيَتْي حَمَ شَ قٍ رَ، نَشَن لُشِ عَلْ عَ قَتٍ.
\v 25 ﭑ بَرَ قِندِ دَنشَنِيَتْييٍ حَمَ شَ وَلِكّ رَ. عَلَ بَرَ ﭑ شّي ﭑ شَ عَ شَ مَسٍنيِ بِرِن تَفِ رَبَ وٌ بّ.
\v 26 نَ فُندٌ نُ نْشُنشِ نّ مِشِ بِرِن مَ، كَبِ تّمُي شْننَكُيٍ. كْنْ يَكْسِ، عَلَ بَرَ نَ مَسٍن عَ قِيشّ رَ عَ شَ سّنِيّنتْييٍ بِرِن بّ.
\v 27 عَ وَشِ نّ نَ فُندٌ شَ مَسٍن عٍ بّ سِ بِرِن تَفِ، عٍ شَ عَ شَ نْرّ تٌقَنيِ تٌ. نَ فُندٌ نَن يِ كِ، عَلَ شَ مِشِ سُفَندِشِ نَ وٌ عِ، عَ تَن نَن نْشِ عَ نِيَدٍ وٌ شَ عَ شَ نْرّ سْتْ.
\v 28 مُشُ عَلَ شَ مِشِ سُفَندِشِ نَن مَ قٍ مَسٍنمَ عَدَ مَدِ بِرِن بّ. مُشُ عٍ بِرِن شَرَنمَ نّ لْننِ رَ، عَلَكٌ مِشِ بِرِن شَ كَمَلِ عَلَ شَ مِشِ سُفَندِشِ سَابُي رَ.
\v 29 نَ نَن عَ تٌشِ، ﭑ نَ وَلِقٍ عِسَ سّنبّ رَ، نَشَن ﭑ مَلِمَ عَ قَنيِ رَ.
\c 2
\p 
\v 1 وٌ شَ عَ كٌلٌن ﭑ نَ فٍرٍ مَسٌقٍ وٌ بّ، ﭑ نَ فٍرٍ مَسٌقٍ لَيٌدِ سٍيَكَيٍ نُن دَنشَنِيَتْي بِرِن بّ، نَشٍيٍ ﭑ كٌلٌن كْنْ عٍ مُ ﭑ تٌشِ سِندٍن.
\v 2 ﭑ نَ فٍرٍ مَسٌ كُي عَلَكٌ وٌ بْحّ شَ لِمَنِيَ، وٌ شَ بٌنِ وٌ بٌرٍ رَ شَنُنتٍيَ كُي، وٌ مَن شَ شَشِلِ قَنيِ سْتْ. نَ كُي، وٌ نْمَ نّ عَلَ شَ فُندٌ كٌلٌندٍ. نَ فُندٌ قِندِشِ عَلَ شَ مِشِ سُفَندِشِ نَن نَ.
\v 3 لْننِ قَنيِ نُن قٍ كٌلٌنيِ نْشُنشِ عِسَ نَن مَ قٍ كُي.
\p 
\v 4 ﭑ نَ قَلَشِ نّ، عَلَكٌ مِشِ يٌ نَشَ نْ وٌ مَدَشُدٍ وْيّنيِ تٌقَنيِيٍ رَ.
\v 5 ﭑ مَكُيَ وٌ رَ، كْنْ ﭑ بْحّ نَ وٌ سّيتِ مَ. ﭑ بَرَ حّلّشِن، بَرِ مَ وٌ نَ حّرّقٍ عَ قَنيِ رَ وٌ شَ دَنشَنِيَ كُي. وٌ مُ عَلَ شَ مِشِ سُفَندِشِ بّحِنمَ قٍقٍ مَ.
\b
\s1 ثْلُ كْلْسِكَيٍ رَلِمَنِيَقٍ عَ قِرِن ندٍ
\p 
\v 6 وٌ تٌ بَرَ تِن وٌ مَرِفِ عِسَ شَ قٍ رَ، عَلَ شَ مِشِ سُفَندِشِ، وٌ لَن نّ وٌ شَ بِرَ عَ قْشْ رَ.
\v 7 عِسَ شَ لُ وٌ بّ عَلْ سَنكٍ نَ سَنسِ بّ كِ نَشّ. عَ شَ لُ وٌ بّ عَلْ قَنيٍ، بَنشِ تِمَ نَشَن قَرِ. وٌ شَ دَنشَنِيَ شَ سَبَتِ عَلْ مُشُ وٌ شَرَنشِ كِ نَشّ. وٌ شَ عَلَ تَنتُ تّمُي بِرِن.
\v 8 وٌ نَشَ عَ لُ مِشِ يٌ شَ وٌ مَدَشُ وْيّنيِ حْشُنمّ رَ. نَ وُلٍيٍ قِندِشِ عَدَ مَدِ شَ مَحْشُنيِ نَن نَ. نَ قَتَنشِ دُنِحَ قٍ نَن نَ. عَ مُ كٍلِشِ عَلَ شَ مِشِ سُفَندِشِ شَ مَ قٍوٌ!
\b
\s1 عِسَ مَرَكِسِمَ
\p 
\v 9 عَلَ شَ قٍ كّحَ بِرِن نَ عِسَ يِ رَ.
\v 10 وٌ قَن بَرَ كَمَلِ عِسَ سَابُي رَ، نَشَن قِندِشِ مَنفّ رَ. مَنفّيَ بِرِن نُن سّنبّ مْولِ بِرِن نَ عَ بُن مَ.
\p 
\v 11 عِسَ بَرَ وٌ سُننَ، كْنْ عَ مُ عَ رَبَشِ عَ عَدَ مَ كِ شَ مَ. عَ مُ سٍسٍ بَ وٌ قَتٍ مَ. عَ وٌ سُننَ كِ نَشّ، عَ وٌ سٌندٌنيِ نَن كُي عِشَشِ.
\v 12 وٌ بَرَ وٌ شُنشَ يٍ شْورَ. نَ بَرَ مَنِيَ عَلْ وٌ نُن عِسَ بَرَ رَفَتَ فَبُرِ كٍرٍن كُي. نَ شَنبِ وٌ قَن بَرَ كٍلِ يٍ شْورَ عَلْ عِسَ كٍلِشِ فَبُرِ كُي كِ نَشّ. نَ بِرِن نَبَشِ نّ بَرِ مَ وٌ بَرَ لَ عَلَ سّنبّ رَ، نَشَن عِسَ رَكٍلِشِ قَشّ مَ.
\v 13 وٌ نُ لُشِ نّ عَلْ قَشَمِشِيٍ، وٌ شَ يُنُبِيٍ شَ قٍ رَ نُن وٌ شَ سُننَتَرٍيَ شَ قٍ رَ، كْنْ عَلَ بَرَ وٌ رَكِسِ عِسَ سَابُي رَ. عَ بَرَ دِحّ وٌن مَ يُنُبِ بِرِن مَ.
\v 14 كَلَمُي نَشَن نُ سّبّشِ وٌن شِلِ مَ، نَشَن نُ نْمَ وٌن مَ قٍ كَنَدٍ، عَ بَرَ نَ بَ نَ عَ مَبَنبَنقٍ وُرِ مَفَلَنبُشِ مَ.
\v 15 نَ كُي، عَلَ بَرَ نْ مَنفّيَ نُن سّنبّ مْولِ بِرِن نَ دُنِحَ بِرِن يَ شْرِ، نَشٍيٍ قَتَنشِ سٍنتَنّ رَ، عَ نَشَ شُننَكٍلِ سْتْ نَ وُرِ مَفَلَنبُشِ سَابُي رَ.
\b
\s1 شَرَنيِ نَشَن قِندِشِ وُلٍ رَ
\p 
\v 16 عَوَ، وٌ نَشَ تِن مِشِ يٌ شَ كِيتِ حَاشِ سَ وٌ مَ وٌ شَ دٌنسٍ نُن مِنسٍ شَ قٍ رَ، سَلِ شُنفبٍيٍ شَ قٍ رَ، كِكٍ نّينّ سَلِ شَ قٍ رَ، شَ نَ مُ مَلَبُ لْشْي شَ قٍ رَ.
\v 17 نَ بِرِن قِندِشِ قٍ قَنيِ تْنشُمَ نَن نَ. عَ نُ وَ مَ عَلَ شَ مِشِ سُفَندِشِ شَ قٍ نَن مَسٍنقٍ وٌن بّ، نَشَن قِندِشِ نْندِ يَتِ رَ.
\v 18 وٌ نَشَ تِن مِشِ يٌ شَ وٌ شَ شُننَكٍلِ بَ وٌ يِ رَ. مِشِ ندٍيٍ كَتَمَ نّ نَ رَبَدٍ. عَ لُمَ عَلْ عٍ عٍ يّتّ نَن مَفٌرٌ مَ، كْنْ وُلٍ نَ عَ رَ. عَ لُمَ عَلْ عٍ تَن نُن مَلٍكّيٍ عَلَ نَن بَتُمَ، كْنْ نَ قَن وُلٍ نَن عَ رَ. عٍ بِرَ مَ لَامَتُنيِيٍ قْشْ رَ، كْنْ عٍ عٍ يّتّ عِفبٌمَ قٍ قُقَقُ مَ.
\v 19 عٍ مُ قَتُشِ عِسَ مَ، نَشَن نَ شُنيِ رَ. قَتٍ شُنيِ سَلٌنسٍ بِرِن نَحّرّ مَ. كَنكَن شِرِشِ عٍ بٌورٍ رَ، عَلَ سّنبّ قِمَ عٍ بِرِن مَ عَلْ عَ وَ مَ عَ شْن مَ كِ نَشّ.
\p 
\v 20 شَ وٌ بَرَ قَتَن دُنِحَ قٍيٍ مَ عِسَ سَابُي رَ، مُنقٍ رَ وٌ وٌ يّتّ لُمَ دُنِحَ قٍيٍ شَ يَامَرِ بُن مَ؟
\v 21 نَ يَامَرِ نَشّ، «عَ مُ لَن وٌ شَ يِ تٌنفٌ! عَ مُ لَن وٌ شَ يِ دٌن! وٌ مَن مُ لَن وٌ شَ عَ مَسُشُ!»
\v 22 نَ قٍ بِرِن قَمَ حْندٍ. نَ سّرِيّ مْولِ قَتَنشِ عَدَ مَدِ نَن نَ.
\v 23 نَ قٍ مْولِ مَنِيَ لْننِ رَ، بَرِ مَ بَتُي، يّتّ مَفٌرٍ، نُن قَتٍ تْورْقٍ نَ عَ كُي، كْنْ عٍ تِدٍ يٌ مُ نَ، بَرِ مَ عٍ مُ نْمَ يُنُبِ قٍيٍ بَدٍ مِشِ بْحّ مَ.
\c 3
\s1 عَلَ شَ كِرَ
\p 
\v 1 شَ نْندِ نَ عَ رَ، وٌ نُن عَلَ شَ مِشِ سُفَندِشِ نَن بِرِن نَكٍلِشِ قَشّ مَ، وٌ شَ عَرِيَننَ قٍن، عَلَ شَ مِشِ سُفَندِشِ مَفٌرٌشِ عَلَ يِرٍقَنيِ مَ دّننَشّ.
\v 2 وٌ شَ عَرِيَننَ قٍ قٍن، دُنِحَ قٍ مُ عَ رَ.
\v 3 بَرِ مَ وٌ بَرَ قَشَ، وٌ شَ سِمَيَ قَ نْشُنشِ عَلَ شَ مِشِ سُفَندِشِ شَ قٍ عِ عَلَ شَ قٌنِسِرٍيَ كُي.
\v 4 وٌ رَكِسِمَ عَلَ شَ مِشِ سُفَندِشِ نَ قَ، وٌ قَن لُمَ عَ شَ نْرّ نَن كُي.
\p 
\v 5 نَ نَن عَ تٌشِ وٌ لَنمَ وٌ شَ عَدَ مَدِ شَ قٍ كٌبِ بِرِن نَبّحِن؛ يّنّ قٍ، لَنفٌي قٍ، قٍ سّنِيّنتَرٍ، كٌرِنتٍحَ نَشَن مَنِيَشِ كُيٍ بَتُقٍ رَ.
\v 6 عَلَ شْنْمَ نّ نَ قٍ مْولِ مَ، نُن نَشٍيٍ عٍ رَبَمَ.
\v 7 سِنفٍ رَ نُ، وٌ يَتِ نُ حّرّ مَ نَ كِ نّ.
\p 
\v 8 كْنْ يَكْسِ، وٌ شَ يِ قٍ بِرِن بّحِن؛ بْحّتٍ، فٍرٍ سٌقٍ، قٍ حَاشِ، مِشِ شِلِ كَنَقٍ، نُن كٌنبِ.
\v 9 وٌ نَشَ وُلٍ قَلَ وٌ بٌرٍ بّ. وٌ بَرَ نَ حّرّ كِ قٌرِ بّحِن،
\v 10 عَلَكٌ وٌ شَ حّرّ كِ نّينّ سُشُ، نَشَن لَنمَ عَلَ حّرّ كِ مَ. نَ كُي، وٌ قَمَ عَلَ كٌلٌندٍ عَ قَنيِ رَ. نَ بِرِن لُمَ عَلْ مِشِ نَشَن دُفِ قٌرِ بَمَ عَ مَ، عَ دُفِ نّينّ رَفٌرٌ عَ مَ.
\v 11 نَ كُي، فِرّكِ نُن يُوِقِ عٍ بِرِن كٍرٍن. مِشِ سُننَشِ نُن مِشِ سُننَتَرٍ عٍ بِرِن كٍرٍن. شُنُنتَرٍيٍ، مِشِ شُنُنشِ، كٌنيِ، نُن لَسِرِ، عٍ بِرِن كٍرٍن. عِسَ نَن قِندِشِ عَ بِرِن نَ، عَ مَن نَ عَ بِرِن عِ.
\p 
\v 12 عَلَ وٌ تَن نَن سُفَندِشِ، وٌ بَرَ قِندِ سّنِيّنتْييٍ رَ، عَلَ شَنُنتٍنيِيٍ. وٌ لَن نّ وٌ شَ كِنِكِنِ مِشِ مَ، وٌ بْحّ شَ قَن، وٌ شَ وٌ يّتّ مَفٌرٌ، وٌ بْحّ شَ بّشِ، وٌ شَ دِحّ.
\v 13 وٌ شَ وٌ بٌرٍ سُتُرَ، وٌ مَن شَ هِننّ وٌ بٌرٍ رَ. شَ مِشِ ندٍ بَرَ قٍ حَاشِ رَبَ عَ بٌرٍ رَ، نَ كَنيِ شَ دِحّ عَلْ عَلَ شَ مِشِ سُفَندِشِ دِحّشِ وٌ مَ كِ نَشّ.
\v 14 نَشَن دَنفِ عَ بِرِن نَ، وٌ شَ وٌ بٌرٍ شَنُ بَرِ مَ نَ قِندِ مَ لَنيِ قَنيِ رَ.
\v 15 عَلَ شَ مِشِ سُفَندِشِ نُ وَ مَ لَنيِ نَشَن شْن وٌن بّ، وٌن بْحّ شَ بِرَ نَ لَنيِ قْشْ رَ. عَلَ بَرَ وٌ شِلِ وٌ شَ قِندِ قَتٍ كٍرٍن نَ، لَنيِ شَ لُ وٌ تَفِ. وٌ شَ عَلَ تَنتُ نَ مَ.
\p 
\v 16 عَلَ شَ مِشِ سُفَندِشِ شَ مَسٍنيِ قَنيِ شَ لُ وٌ بْحّ كُي. وٌ شَ وٌ بٌرٍ شَرَن، وٌ مَن شَ مَرَ سِ نُن لْننِ قِ وٌ بٌرٍ مَ. وٌ شَ نَ رَبَ سُوكِ نُن بّيتِ رَ نَشَن قَتَنشِ عَلَ شَشِلِ سّنِيّنشِ رَ. وٌ شَ عَلَ تَنتُ نَ بّيتِيٍ رَ، عٍ شَ كٍلِ وٌ بْحّ يَتِ يَتِ نَن كُي.
\v 17 وٌ قٍ نَشَن بِرِن قَلَمَ، وٌ قٍ نَشَن بِرِن نَبَمَ، وٌ شَ نَ بِرِن نَبَ وٌ مَرِفِ عِسَ شِلِ رَ. وٌ شَ بَبَ عَلَ تَنتُ عِسَ سَابُي رَ.
\b
\s1 دٍنبَيَ سّرِيّ
\p 
\v 18 فِنّيٍ، وٌ شَ لُ وٌ شَ مْرِيٍ شَ يَامَرِ بُن مَ، عَلْ مَرِفِ وَ مَ عَ شْن مَ كِ نَشّ.
\v 19 شّمّيٍ، وٌ شَ وٌ شَ فِنّيٍ شَنُ، وٌ نَشَ حَاشُ عٍ رَ.
\v 20 دِ مّدِيٍ، وٌ شَ وٌ بَرِ مِشِيٍ شُي رَتِنمّ قٍ بِرِن كُي، بَرِ مَ نَ رَقَن مَرِفِ مَ.
\v 21 بَرِ مِشِيٍ، وٌ نَشَ وٌ شَ دِيٍ بْحّ رَحَاشُ عٍ مَ، عَلَكٌ لِمَنِيَ نَشَ بَ عٍ يِ.
\v 22 كٌنيِيٍ، وٌ شَ وٌ مَرِفِيٍ شُي بِرِن نَتِنمّ. وٌ نَشَ وَلِ عٍ يَ تٌدٍ شَ فبَنسَن نَ، عَلَكٌ وٌ شَ رَقَن مِشِيٍ مَ. وٌ شَ وَلِ عٍ بّ وٌ بْحّ قِيشّشِ رَ، بَرِ مَ وٌ فَاشُشِ وٌ مَرِفِ عَلَ يَ رَ.
\v 23 وٌ قٍ نَشَن بِرِن نَبَمَ، وٌ شَ عَ رَبَ وٌ بْحّ قِيشّشِ نَن نَ، عَلْ وٌ عَ رَبَمَ مَرِفِ بّ كِ نَشّ. وٌ مُ عَ رَبَمَ مِشِيٍ شَ بّ.
\v 24 نَ كُي، وٌ شَ عَ كٌلٌن مَرِفِ نَ سَرٍ رَفبِلٍنمَ نّ وٌ مَ، نَشَن قِندِ مَ وٌ كّ رَ. وٌ نَ وَلِقٍ عَلَ شَ مِشِ سُفَندِشِ نَن بّ، وٌ مَرِفِ يَتِ يَتِ.
\v 25 نَشَن قٍ كٌبِ رَبَمَ، مَرِفِ نَ قَن سَرٍ رَفبِلٍنمَ نّ عَ مَ. مِشِ بِرِن عَ فبٍ سْتْمَ نّ، عَلَ مُ مِشِ يٌ رَقِسَ عَ بٌورٍ بّ.
\c 4
\p 
\v 1 كٌنيِ مَرِفِيٍ، وٌ شَ وٌ شَ كٌنيِيٍ مَسُشُ تِنشِنيِ رَ، بَرِ مَ كٌنيِ نَن وٌ قَن نَ. وٌ مَرِفِ نَ كٌورٍ مَ.
\s1 مَرَ سِ دْنشْي
\p 
\v 2 وٌ شَ عَلَ مَشَندِ تّمُي بِرِن. وٌ شَ وٌ يّتّ مَتٌ، وٌ شَ عَلَ تَنتُ.
\v 3 وٌ عَلَ مَشَندِ مُشُ قَن بّ. عَلَ شَ سْونّيَ رَبَ وٌن مَ كَوَندِ كُي، عَلَكٌ ﭑ شَ عَلَ شَ مِشِ سُفَندِشِ شَ فُندٌ مَسٍن بِرِن بّ. ﭑ سَشِ فٍيلِ نَ قٍ نَن مَ.
\v 4 وٌ عَلَ مَشَندِ ﭑ بّ عَلَكٌ ﭑ شَ نَ قَلَ عَ قَنيِ رَ، عَ شَ قِيشّ قْين، عَلْ عَ لَنمَ ﭑ شَ عَ رَبَ كِ نَشّ.
\p 
\v 5 وٌ شَ وٌ حّرّ شَشِلِمَيَ رَ دَنشَنِيَتَرٍيٍ يَ تٌدٍ رَ. وٌ شَ نَ رَبَ سِننَنيِ مَ عَ رَبَ وَشَتِ.
\v 6 وٌ شَ مَسٍنيِ قَنيِ تِ مِشِيٍ بّ، نَشَن قَن. كُرِ سٌ تّمُي، قْشّ سَمَ نّ بَندٍ، عَلَكٌ عَ شَ حْشُن. وٌ قَن شَ قَتَ مِشِ بِرِن يَابِدٍ وْيّنيِ رَ نَشَن قَن.
\s1 شّيبُي دْنشْي
\p 
\v 7 ﭑ نفَشَكٍرٍنيِ تِكِكٍ قِندِشِ ﭑ شَنُنتٍنيِ نَن نَ نَشَن بَرَ ﭑ مَلِ عَ قَنيِ رَ مَرِفِ شَ وَلِ شَ قٍ رَ. عَ قَمَ ﭑ مَ قٍ بِرِن تَفِ رَبَدٍ وٌ بّ.
\v 8 ﭑ عَ شّيشِ نّ وٌ مَ عَلَكٌ عَ شَ مُشُ شَ قٍ تَفِ رَبَ وٌ بّ، عَ مَن شَ وٌ رَلِمَنِيَ.
\v 9 ﭑ مَن بَرَ ﭑ نفَشَكٍرٍنيِ تِنشِنشِ، ﭑ شَنُنتٍنيِ عٌنٍسِمٌ كْلْسِكَ شّي عَ شَ تِكِكٍ مَتِ. عٍ قِرِنيِ قَمَ ﭑ مَ قٍ بِرِن دّنتّفّ سَدٍ وٌ بّ.
\p 
\v 10 عَرِ سِتَرَكِ، مُشُ نُن نَشَن نَ فٍيلِ، عَ وٌ شّيبُ. بَرَنَبَسِ دّيشْ مَرَكِ قَن وٌ شّيبُ. وٌ بَرَ مَرَ سِ سْتْ مَرَكِ شَ قٍ مَ. شَ عَ قَ وٌ شْنيِ، وٌ شَ عَ رَ سّنّ عَ قَنيِ رَ.
\v 11 يٍسُ، نَشَن شِلِ قَلَمَ يُسُتُ، عَ قَن وٌ شّيبُ. يُوِقِ دَنشَنِيَتْي حَمَ بِرِن يَ مَ، يِ مِشِ سَشَنيِ فبَنسَن نَن ﭑ مَلِشِ عَلَ شَ مَنفّيَ نِينِ وَلِ رَبَدٍ. عٍ بَرَ لِمَنِيَ قِ ﭑ مَ.
\p 
\v 12 عٍثَقِرَ سِ، نَشَن قِندِشِ وٌ شْنيِكَ رَ، عَ وٌ شّيبُ. عَلَ شَ مِشِ سُفَندِشِ عِسَ شَ وَلِكّ نَن عَ رَ. عَ عَلَ مَشَندِ مَ وٌ بّ تّمُي بِرِن عَلَكٌ وٌ شَ دَنشَنِيَ شَ سَبَتِ، وٌ شَ عَلَ وَشْنقٍ كٌلٌن، وٌ مَن شَ عَ رَبَ.
\v 13 عَ وَلِ فبٍفبٍ رَبَمَ وٌ بّ، وٌ تَن دَنشَنِيَتْي نَشٍيٍ نَ كْلْسِ، لَيٌدِ سٍيَ، نُن هِيٍرَثٌلِ. ﭑ نَ عَ سٍيدٍ رَ.
\v 14 لُكِ سٍرِبَ، مُشُ شَنُنتٍنيِ وٌ شّيبُ، عَ نُن دٍ مَسِ.
\p 
\v 15 وٌ شَ وٌن نفَشَكٍرٍنيِ لَيٌدِ سٍيَ دَنشَنِيَتْييٍ شّيبُ، نُن نِمِقَ، عَ نُن دَنشَنِيَتْي حَمَ نَشَن عٍ مَلَنمَ عَ شَ بَنشِ كُي.
\v 16 وٌ نَ فّ يِ بَتَاشّ شَرَندٍ وٌ شْنيِ، وٌ شَ عَ سٌ لَيٌدِ سٍيَ دَنشَنِيَتْييٍ قَن يِ رَ، عٍ شَ عَ شَرَن. وٌ تَن قَن، وٌ شَ بَتَاشّ شَرَن ﭑ نَشَن نَسَنبَشِ لَيٌدِ سٍيَكَيٍ مَ.
\v 17 وٌ شَ عَ قَلَ عَرِكِثٍ بّ، «قّنتّن عِ شَ وَلِ مَ، مَرِفِ نَشَن سٌشِ عِ يِ رَ عَلَكٌ عِ شَ نَ رَبَ عَ قَنيِ رَ.»
\p 
\v 18 شّيبُي نَن يِ كِ، ﭑ تَن ثْلُ نَشَن سّبّشِ وٌ مَ ﭑ يّتّ بّلّشّ رَ. وٌ شَ رَتُ عَ مَ ﭑ نَ فٍيلِ نَن كُي يِ كِ. عَلَ شَ هِننّ وٌ بِرِن نَ.
