\p
\v 25 \w Pharaon|strong="H6547"\w* appela \w Moïse|strong="H4872"\w* \w et|strong="H3068"\w* \w Aaron|strong="H4872"\w*, \w et|strong="H3068"\w* \w dit|strong="H3068"\w* : « \w Allez|strong="H3318"\w*, \w offrez|strong="H2076"\w* \w des|strong="H3068"\w* \w sacrifices|strong="H2076"\w* \w à|strong="H3068"\w* \w votre|strong="H7971"\w* \w Dieu|strong="H3068"\w* \w dans|strong="H3068"\w* \w ce|strong="H7971"\w* \w pays|strong="H3068"\w* ! »   
\p
\v 26 \w Moïse|strong="H4872"\w* \w répondit|strong="H4872"\w* : « \w Il|strong="H3068"\w* n'\w est|strong="H3068"\w* \w pas|strong="H3068"\w* convenable \w de|strong="H3318"\w* \w faire|strong="H3068"\w* \w ainsi|strong="H4872"\w* ; car \w ce|strong="H3318"\w* \w que|strong="H3068"\w* \w nous|strong="H3068"\w* sacrifierions \w au|strong="H3068"\w* \w SEIGNEUR|strong="H6547"\w* \w notre|strong="H3318"\w* \w Dieu|strong="H3068"\w* \w est|strong="H3068"\w* \w en|strong="H3068"\w* abomination \w aux|strong="H3068"\w* \w Égyptiens|strong="H3068"\w*. \w Voici|strong="H4872"\w*, si \w nous|strong="H3068"\w* offrons \w sous|strong="H3068"\w* \w leurs|strong="H3318"\w* \w yeux|strong="H3068"\w* \w des|strong="H3068"\w* \w sacrifices|strong="H3068"\w* \w qui|strong="H3068"\w* \w sont|strong="H3068"\w* \w en|strong="H3068"\w* abomination \w aux|strong="H3068"\w* \w Égyptiens|strong="H3068"\w*, \w ne|strong="H3068"\w* \w nous|strong="H3068"\w* \w lapideront-ils|strong="H3068"\w* \w pas|strong="H3068"\w* ?  
\v 27 \w Nous|strong="H3068"\w* \w ferons|strong="H6213"\w* trois jours \w de|strong="H1697"\w* \w marche|strong="H3068"\w* \w dans|strong="H6213"\w* \w le|strong="H3068"\w* désert, \w et|strong="H3068"\w* \w nous|strong="H3068"\w* \w offrirons|strong="H6213"\w* \w des|strong="H3068"\w* \w sacrifices|strong="H3068"\w* \w au|strong="H6213"\w* \w SEIGNEUR|strong="H6547"\w* \w notre|strong="H6213"\w* \w Dieu|strong="H3068"\w*, \w selon|strong="H6213"\w* \w ce|strong="H6213"\w* \w qu|strong="H1697"\w*'\w il|strong="H3068"\w* \w nous|strong="H3068"\w* ordonnera. »   
\p
\v 28 \w Pharaon|strong="H6547"\w* \w dit|strong="H6547"\w* : « \w Je|strong="H3068"\w* \w vous|strong="H3808"\w* \w laisserai|strong="H7971"\w* \w partir|strong="H7971"\w*, \w pour|strong="H7971"\w* \w que|strong="H3808"\w* \w vous|strong="H3808"\w* offriez \w des|strong="H7971"\w* sacrifices \w au|strong="H5971"\w* \w SEIGNEUR|strong="H6547"\w* \w votre|strong="H3808"\w* \w Dieu|strong="H3808"\w* \w dans|strong="H3808"\w* \w le|strong="H7971"\w* désert ; \w seulement|strong="H3808"\w*, \w vous|strong="H3808"\w* \w ne|strong="H3808"\w* \w vous|strong="H3808"\w* éloignerez \w pas|strong="H3808"\w* beaucoup. Priez \w pour|strong="H7971"\w* \w moi|strong="H5971"\w*. »   
\p
\v 29 Moïse répondit : « Voici, je vais sortir de chez toi. \w Je|strong="H3068"\w* prierai le SEIGNEUR, pour que les essaims de mouches s'éloignent demain de Pharaon, de ses serviteurs et de son peuple ; mais que Pharaon ne trompe plus, en refusant de laisser partir le peuple pour offrir des sacrifices au SEIGNEUR. »  
\v 30 Moïse sortit de chez Pharaon, et il pria le SEIGNEUR.  
\v 31 Le SEIGNEUR fit selon la parole de Moïse, et il écarta les essaims de mouches de Pharaon, de ses serviteurs et de son peuple. Il n'en resta pas une seule.  
\v 32 Mais Pharaon s'endurcit le cœur cette fois encore, et il ne laissa pas partir le peuple.   
\c 9
\p
