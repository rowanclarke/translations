\id 1JN - Ikwerre 
\h 1 Jọni 
\toc1 Ọkwukwo izi ke Mbọm Jọni gbarụ 
\toc2 1 Jọni 
\toc3 1 Jọn 
\mt2 Ọkwukwo izi 
\mt2 ke Mbọm 
\mt1 Jọni 
\mt2 gbarụ 
\imt1 Nhne gbasịri ọkwukwo izi ka 
\im Jọni mernu ma ele Karaịsi mahịa nụ ọ bụru a kwuhịa mmehie aị, Chiokike jaagbarụnu aị, vume mmehie aị. 
\ip Nhne neegesi nụ ele Karaịsi nwernu ọkwnata mkpọma bụ ọwhnun'anya be nwernu n'ẹhni badnụ ibne be (3:11-24). Chiokike bụ ọwhnun'anya n'iwhuru a, ele ke a kwesiri ọ nụ lele ya masị (4:1-21). Nhne neegesi nụ a nwernu omegbu mmehie bụ ọwhnun'anya a nwernu n'ẹhni ele berere, a kweru nụ Jizọsi bụ Nnwọ Chiokike, nụ ọ bụ Karaịsi wam n'ezi, nụ ẹnwu a kwnornu aị bụ ezi ọka (5:1-12). 
\iot Nhne zị n'ọkwukwo izi ka 
\io1 Ikwu-ọnu ke neenye bụdnu \ior (1:1-4) \ior* 
\io1 Chiokike bụ iwhne aị, Karaịsi bụ nhne atụ aị \ior (1:5---2:6) \ior* 
\io1 Iwu ikne \ior (2:7-17) \ior* 
\io1 Ele irno Karaịsi nụ ele ke Chiokike \ior (2:18---3:10) \ior* 
\io1 Ọwhnun'anya Chiokike nụ ọwhnun'anya aị \ior (3:11---4:21) \ior* 
\io1 Omegbu ọwa \ior (5:1-21) \ior* 
\c 1  
\s1 Ikwu-ọnu ke neenye bụdnu 
\p  
\v 1 Ikwu-ọnu Chiokike wam ke panịzoru nụ mbọm, bụ ke a nụrnu, ke anya aị whnụrnu, ke a leru anya, bụ ke a kpatụru aka masị, bụ nhne a nọokpo okwo a, bụ ikwu-ọnu ke neenye bụdnu.  
\v 2 Bụdnu wam whụyaru iwhne, a whnụrnu a, gba masị akebne a, a kpọ ọkwo bụdnu kwó okwo ke zị n'aka Nda, omekwo dụ aị.  
\v 3 A nọokpo okwo nhne a whnụrnu, nụrnu masị, ma anụ snornu aị mekọ nhne. Omekọrita aị bụ ke aị nụ Chiokike nụ Nnwọ a Jizọsi Karaịsi.  
\v 4 A gbarụ nhne ka n'ọkwukwo ma ovu ọso n'ọnu aị zu ozu. 
\s1 Chiokike bụ iwhne 
\p  
\v 5 Ka bụ izi a nụrnu n'ọnu a bụ masị ke a znirni anụ. Chiokike bụ iwhne, o zá ọchichiri zị nụ rime a rịa rịa.  
\v 6 Ọ bụru nụ a kaa nụ aị nụ ya neemekọ nhne, kọvu a neezne izne n'ọchichiri, a bụ ele aghalaghala, ezi ọka zị́la aị n'ọnu.  
\v 7 Kọvu, ọ bụru nụ a zne izne n'iwhne, lele kpa o neezne izne n'iwhne, a neenwe mekọrita n'esilawụru aị, ọvnarna Jizọsi Nnwọ a, nọosnusnama kpakara mmehie aị. 
\p  
\v 8 Ọ bụru nụ a kaa nụ a nwée mmehie, a nooduhie ẹhni aị, ezi ọka zị́la aị n'ọnu.  
\v 9 Kọvu, a kwuhịa mmehie aị, Chiokike bụ nye kwesiri ọkwnata ovu nụ nye mee mma, ọ jaagbarụnu aị mmehie aị, ọ snụmakwo kpakara arụru-ẹli aị.  
\v 10 Kọvu, a kaa nụ a méne mmehie, a neeme a nye aghalaghala, ikwu-ọnu a zị́la nụ rime aị rịa rịa. 
\c 2  
\p  
\v 1 Rụmu takịri m, m naagbanụ anụ ọkwukwo ma anụ gharụ o mee mmehie. Kọvu, ọ bụru nụ nye ọbula mehieru, a nwernu nye nookwunu aị ọnu nụ ruwhnu Nda aị, rẹwhna a bụ Jizọsi Karaịsi, nye mee mma.  
\v 2 Jizọsi bụ nye ji ọvnarna a naawhajị-ẹli kwnornu mmehie aị, ọ bụ́o mmehie ke aị kpọi, kọvu mmehie kpakara ele badnụ. 
\p  
\v 3 Ka bụ nhne neegesi nụ a magwụ nye ọ bụ, ọ bụru nụ a bịta kpakara nhne o nyernu n'iwu.  
\v 4 Ọ bụru nụ a kaa nụ a magwụ nye ọ bụ, kọvu a zá naabịta iwu a, a bụ ele aghalaghala, ezi ọka zị́la aị n'ọnu.  
\v 5 Ka bụ nhne neegesi nụ a magwụ Chiokike, ọ bụru nụ a bịta iwu a, ọwhnun'anya Chiokike zuru ozu n'ovu aị.  
\v 6 Nye ọbula ke kaa nụ ọ zị nụ rime a, joowu bụdnu lele kpa Jizọsi wuru. 
\s1 Iwu ikne 
\p  
\v 7 Ele me whnụrnu n'anya, m zá m naagbanụ anụ ọkwukwo iwu ikne, kọvu iwu ọknani. Iwu ọknani ka bụ ke anụ nụrnu hite nụ ọpanizo.  
\v 8 Kọvu m naagbanụ anụ iwu ikne, ezi ọka wam zị nụ rime Jizọsi, nụ rime anụ, kwnornu nụ ọchichiri naagawhe, ezi iwhne wam nọomukwasi aị. 
\p  
\v 9 Nye ọbula ke kaa nụ ọ zị n'iwhne, kọvu, sno nwene a irno, zị kọriri n'ọchichiri.  
\v 10 Nye ọbula ke whnụrnu nwene a n'anya zị n'iwhne wam, ọ zá nhne jeeme a ọ kpọbi ọchi.  
\v 11 Nye ọbula ke snornu nwene a irno zị n'ọchichiri, neezne izne n'ọchichiri, ọ máa hne o neezne kwnornu nụ ọchichiri mernu a okpu isni. 
\q1  
\v 12 Rụmu takịri m, m naagbanụ anụ ọkwukwo, 
\q2 kwnornu nụ Chiokike gbarụnu anụ mmehie kwnornu rẹwhna Karaịsi. 
\q1  
\v 13 Ele nda, m naagbanụ anụ ọkwukwo, 
\q2 kwnornu nụ anụ magwụ Karaịsi, nye zị hite n'ọpanizo. 
\q1 M naagbanụ anụ ọkwukwo, rụmu ikoro, 
\q2 kwnornu nụ anụ megburu nye ọjo wam. 
\q1 Rụmu takịri m, m naagbanụ anụ ọkwukwo, 
\q2 kwnornu nụ anụ magwụ Nda wam. 
\q1  
\v 14 Ele nda, m naagbanụ anụ ọkwukwo, 
\q2 kwnornu nụ anụ magwụ Karaịsi, nye zị hite n'ọpanizo. 
\q1 M naagbanụ anụ ọkwukwo, rụmu ikoro, 
\q2 kwnornu nụ anụ gbasịri rikne, 
\q2 ikwu-ọnu Chiokike zị nụ rime anụ, 
\q2 kwnornu nụ anụ megbulem nye ọjo wam. 
\s1 Anụ whnụ́ nhne ọwa  //  n'anya 
\p  
\v 15 Anụ whnụ́ ọwa n'anya, mọbu nhne zị n'ọwa. Ọ bụru nụ nye ọbula whnụ ọwa n'anya, ọwhnun'anya ke Nda zị́la nụ rime a.  
\v 16 Kpakara nhne zị n'ọwa bụ ẹgwnurnu nhne ọjo ke badnụ, nụ ẹgwnurnu nhne ọjo ke anya, nụ oknomokno ke mkpọma ke badnụ. Nhne ka híge n'aka Nda aị va, o hi n'ọwa va.  
\v 17 Ọwa nụ kpakara ẹgwnurnu nhne ọjo ke zị nụ rime a jaagawhe, kọvu nye ọbula ke neeme echiche Chiokike jaazị bụdnu ọkwnukokwnu. 
\s1 Nye neemegidne Karaịsi 
\p  
\v 18 Rụmu takịri m, ka bụ ige ipne-aznụ, anụ nụrnu nụ nye wam neemegidne Karaịsi vawa, me kanụ anụ, agịda ele neemegidne Karaịsi valẹm. Ka neegesi nụ ige wam zị ndụndu.  
\v 19 Be hiri nụ hne a zị whọga, kwnornu nụ be nụ aị zị́la n'otu n'ezi. Ọ bụru nụ aị nụ be zị n'otu, be znernu adazịgidnenu aị. Ọwhoga be neegesi nụ aị nụ be zị́la n'otu. 
\p  
\v 20 Kọvu, Nye Nsọ wam teru anụ mọno, ka neegesi nụ kpakara anụ mahịaru ezi ọka.  
\v 21 M zá m naagbanụ anụ ọkwukwo ka kwnornu nụ anụ máa ezi ọka, kọvu kwnornu nụ anụ mahịaru ezi ọka. Aghalaghala zị́la n'ezi ọka.  
\v 22 Nyele bụ nye aghalaghala? Ọ bụ nye wam ke gọnahoru nụ Jizọsi bụ Karaịsi. Nye wam bụ nye neemegidne Karaịsi. Ọ gọnahoru Nda nụ Nnwọ a.  
\v 23 Nye ọbula ke gọnahoru Nnwọ máa nye Nda wam bụ, nye ọbula ke magwụ Nnwọ magwụ Nda wam masị. 
\p  
\v 24 Anụ ledu anya nụ nhne anụ nụrnu hite nụ mbọm dazịgidnernu nụ rime anụ. Ọ bụru kpam, anụ jaadazịgidne nụ rime Nnwọ nụ rime Nda.  
\v 25 Bụdnu kwó okwo bụ nhne o kweru aị nụ mkwna. 
\p  
\v 26 M naagba ka n'ọkwukwo kwnornu ele pioru o duwhu anụ.  
\v 27 Kọvu Karaịsi teru anụ mọno Enine Nsọ. O kwésile nye ọbula zni anụ nhne, mọno o teru anụ zị nụ rime anụ neezni anụ kpakara nhne lele kpa otute mọno wam zị ire, ma anụ dazịgidne nụ rime Karaịsi. 
\p  
\v 28 Kịtna, rụmu takịri m, anụ dazịgidne nụ rime a, ma nga ọ jọowhuya iwhne, ovu si aị rikne o gwuzoru nụ ruwhnu a, iwhnerne jọ́otu aị. 
\p  
\v 29 Anụ magwụ nụ Karaịsi bụ nye mee mma, nye ọbula ke neeme mma bụ nnwọ Chiokike. 
\c 3  
\s1 Rụmu Chiokike 
\p  
\v 1 Le, kpa Chiokike jiri whnụ aị n'anya, o sukwu aị rụmu a. Ka bụ nhne a bụ n'ezi. Kam kpayarụ, ele zị n'ọwa máa ele a bụ, lele kpa be máa nye ọ bụ.  
\v 2 Ele me whnụrnu n'anya, a bụ rụmu Chiokike kịtna, nhne a jọobu whọ́ge iwhne kịtna. Kọvu a magwụ nga ọ jaava, a jọonu lele kpa ọ nụ, kwnornu nụ a jọowhnu a kpa ọ nụ.  
\v 3 Nye ọbula ke nwernu olile anya ka neeme ẹhni a zịri snam, lele kpa ọ zị snam. 
\p  
\v 4 Nye ọbula ke neeme mmehie, noolulu iwu, kwnornu nụ mmehie bụ olulu iwu.  
\v 5 Kọvu anụ magwụ nụ ọ whụyaru iwhne ma o gweme kpakara mmehie aị. Ya n'iwhuru a nwée mmehie.  
\v 6 Nye ọbula ke zị bụdnu nụ rime Karaịsi, zá neemezne mmehie. Nye neeme mmehie máa nye Karaịsi bụ, nye wam whnụ́lele a anya. 
\p  
\v 7 Rụmu takịri, anụ kwé nye ọbula duwhu anụ. Nye ọbula ke neeme nhne bụru ọma bụ nye mee mma, lele kpa Karaịsi bụ nye mee mma.  
\v 8 Nye ọbula ke neemezne mmehie bụ nye Ekwensu, kwnornu nụ Ekwensu bụ nye neeme mmehie hite n'ọpanizo. Kam kpayarụ Nnwọ Chiokike jiri whụya iwhne, ma o lulu kpakara ẹrnu ke Ekwensu.  
\v 9 Nye ọbula ke Chiokike mụrnu zá neemezne mmehie, kwnornu nụ mkpụru Chiokike zị nụ rime a, o jéenwe rikne mee mmehie, kwnornu nụ Chiokike bụ Nda a.  
\v 10 Ka bụ nhne rụmu Chiokike jiri zịri ichne nụ hne rụmu Ekwensu zị. Nye ọbula ke zá neeme nhne bụru ọma bụ́o nnwọ Chiokike, ma nye ọbula ke whnụ́ge nwene a n'anya. 
\s1 Anụ whnụ ibne anụ n'anya 
\p  
\v 11 Ka bụ izi anụ nụrnu hite n'ọpanizo, anụ whnụrita ibne anụ n'anya.  
\v 12 Ọ zá nye nụ lele Keni, nye Ekwensu nẹechi o gbu nwene a. Kịni kpayarụ o jiri gbu a? Kwnornu nụ ẹrnu a bụ́o ọma, kọvu ẹrnu nwene a bụru ọma.  
\v 13 Rụmu nda m, ọ gbagwoji anụ anya, ọ bụru nụ ele zị n'ọwa snornu anụ irno.  
\v 14 A magwụ nụ a hiri n'ẹnwu bna nụ bụdnu, kwnornu nụ a whnụrnu rụmu nda aị n'anya. Nye ọbula ke zá nọowhnu n'anya bụ nye nwụrnu ọnwu.  
\v 15 Nye ọbula ke snornu nwene a irno bụ nye noogbu badnụ. Anụ magwụ nye ọbula ke noogbu badnụ nwée bụdnu kwó okwo nụ rime a. 
\p  
\v 16 Ka bụ nhne neegesi ọwhnun'anya, Jizọsi Karaịsi gweru bụdnu a nyee kwnornu aị. A kwesiri o nyee bụdnu aị kwnornu rụmu nwene aị masị.  
\v 17 Ọ bụru nụ nye ọbula nwernu ẹkwnu k'ọwa ka, whnụ nwene a zị nụ mkpa, ọ dọ́la obirizi, nye wam nwée ọwhnun'anya Chiokike nụ rime a.  
\v 18 Rụmu takịri m, a whnụ́ n'anya n'ọnu etekne mọbu n'ikwu-ọnu kpọi, kọvu n'ẹrnu n'ezi ọka. 
\p  
\v 19 Ka bụ nhne neegesi nụ a magwụ ezi ọka, ke neeme mkpọma aị si rikne nụ ruwhnu Chiokike,  
\v 20 ọ bụbedi ovu aị naama aị ikpe, Chiokike kakwo ovu aị, ọ magwụ kpakara nhne.  
\v 21 Ele me whnụrnu n'anya, ọ bụru nụ ovu aị mána ikpe, ovu jeesi aị rikne o gwuzo nụ ruwhnu a.  
\v 22 A jaanahọru a nhne ọbula a nọorio a, kwnornu nụ a naabịta iwu a neeme masị nhne nọoso a ovu n'ọnu.  
\v 23 Ka bụ nhne o nyernu n'iwu, a kweru nụ rẹwhna Nnwọ a Jizọsi Karaịsi, a whnụrita ibne aị n'anya lele kpa o nyernu aị n'iwu.  
\v 24 Ele naabịta iwu a zị bụdnu nụ rime a, ya nụ rime be. Enine Nsọ wam o nyernu aị bụ nhne neegesi nụ ọ zị nụ rime aị. 
\c 4  
\s1 Anụ tule kpakara enine 
\p  
\v 1 Ele me whnụrnu n'anya, anụ kwékọ kpakara enine, anụ tule kpakara enine ma be hi n'aka Chiokike, kwnornu nụ agịda ele ọwhnurninya aghalaghala bnarnụ nụ rime ọwa.  
\v 2 Ka bụ nhne anụ jeeji mahịa Enine Chiokike, enine ọbula ke kwuhịaru nụ Jizọsi Karaịsi varụ n'anọ-ẹhni hi nụ Chiokike va.  
\v 3 Kọvu enine ọbula ke kwéle nụ Jizọsi hiri nụ Chiokike va, enine ka híge nụ Chiokike. Ka bụ enine nye neemegidne Karaịsi, nye anụ nụrnu ọ jaava, ọ zị n'ọwa kịtna. 
\p  
\v 4 Rụmu takịri m, anụ bụ rụmu Chiokike, anụ megbulem ele irno wam, kwnornu nụ nye wam zị nụ rime anụ kakwo nye wam ke zị n'ọwa.  
\v 5 Ele ka hi n'ọwa, be nookwu hite nụ nhne be magwụ n'ọwa, ele zị n'ọwa noobnonu be nsnị.  
\v 6 A hi hne Chiokike zị va, nye ọbula ke magwụ Chiokike nọonu nhne a nookwu. Kọvu nye ke máa Chiokike zá nọonu nhne a nookwu. Ka bụ nhne a jiri mahịa enine ezi ọka nụ enine aghalaghala. 
\s1 Chiokike bụ ọwhnun'anya 
\p  
\v 7 Ele me whnụrnu n'anya, a whnụrita ibne aị n'anya, kwnornu nụ ọwhnun'anya hi nụ Chiokike va. Nye ọbula ke nọowhnu n'anya bụ nye Chiokike mụrnu, nye wam magwụ Chiokike.  
\v 8 Nye ọbula ke whnụ́ n'anya máa Chiokike, kwnornu nụ Chiokike bụ ọwhnun'anya.  
\v 9 Chiokike gesiri aị ọwhnun'anya n'esilawụru aị, kpa o ziyaru Nnwọ ọ mụrnu kpọi n'ọwa, ma a nwernu bụdnu hite nụ rime a.  
\v 10 Ka bụ ọwhnun'anya, ọ bụ́o nụ a whnụrnu Chiokike n'anya, kọvu ọ whnụrnu aị n'anya ziya Nnwọ ma ọ bụru nhne arịohna be jeeji gbarụ mmehie aị.  
\v 11 Ele me whnụrnu n'anya, lele kpa Chiokike whnụrnu aị n'anya, a kwesiri ọ whnụrita ibne aị n'anya.  
\v 12 Ọ zá nye ọbula ke whnụleru Chiokike anya, kọvu ọ bụru nụ a whnụrita ibne aị n'anya, Chiokike wu nụ rime aị, ọwhnun'anya a zuru ozu nụ rime aị. 
\p  
\v 13 A magwụ nụ a wu nụ rime Chiokike, nụ Chiokike wumakọ nụ rime aị, kwnornu nụ o nyernu aị Enine a.  
\v 14 A whnụrnu, gba akebne nụ Nda ziyaru Nnwọ a ma ọ bụru Nye Ọznohia ke ọwa.  
\v 15 Nye ọbula ke kweru nụ Jizọsi bụ Nnwọ Chiokike, Chiokike wu nụ rime nye wam, nye wam masị wu nụ rime Chiokike.  
\v 16 Kam kpayarụ, a magwụ, kweru masị nụ ọwhnun'anya Chiokike bụ n'ezi. 
\p Chiokike bụ ọwhnun'anya. Nye ọbula ke nọowhnun'anya wu nụ rime Chiokike, Chiokike wu masị nụ rime a.  
\v 17 Chiokike mernu ọwhnun'anya a zu ozu n'esilawụru aị, ma a nwernu mkpọma siri rikne n'ọbochi ikpe, kwnornu nụ a nụ lele ya n'ọwa ka.  
\v 18 Ogwnu zị́la n'ọwhnun'anya. Ọwhnun'anya ke zuru ozu nẹechihala ogwnu, kwnornu nụ ogwnu nụ awhnụwhnu nookno aka. Nye ọbula ke nọotu ogwnu zúge ozu n'ọwhnun'anya. 
\p  
\v 19 A nọowhnu n'anya kwnornu nụ Chiokike beru ọsno whnụ aị n'anya.  
\v 20 Nye ọbula ke karụ nụ ọ whnụrnu Chiokike n'anya, kọvu sno nwene a irno bụ nye aghalaghala. Nye ọbula ke whnụ́ge nwene a n'anya, bụ nye ọ nọowhnu anya, nwée rikne whnụ Chiokike nye ọ zá nọowhnu anya n'anya.  
\v 21 Ka bụ nhne o nyernu n'iwu, nye ọbula ke whnụrnu Chiokike n'anya, jọowhnuriri nwene a n'anya. 
\c 5  
\s1 Ọkwnata ovu nụ Nnwọ  //  Chiokike 
\p  
\v 1 Nye ọbula ke kweru nụ Jizọsi bụ Karaịsi hi nụ Chiokike va. Nye ọbula ke whnụrnu Nda n'anya whnụrnu Nnwọ a n'anya masị.  
\v 2 Ka bụ nhne neegesi nụ a whnụrnu rụmu Chiokike n'anya, ọ bụ ọ whnụ Chiokike n'anya, neeme nhne o nyernu n'iwu.  
\v 3 Ka bụ nhne neegesi nụ a whnụrnu Chiokike n'anya, ọ bụru a bịta nhne o nyernu n'iwu, iwu Chiokike zị́la rịnya.  
\v 4 Kwnornu nụ nye ọbula ke bụ nnwọ Chiokike neemegbu ọwa. Ọkwnata ovu aị nụ Chiokike bụ nhne neemegbu ọwa.  
\v 5 Ndaa nye neemegbu ọwa? Ọ bụ nye wam ke kweru nụ Jizọsi bụ Nnwọ Chiokike. 
\p  
\v 6 Jizọsi Karaịsi bụ nye wam jiri ọvnarna nụ mini va. Ọ bụ́o mini kpọi, kọvu ọ varụ hite n'ọvnarna nụ mini. Enine Nsọ naagba akebne a, a magwụ nụ akebne a bụ ezi ọka.  
\v 7 Kwnornu nụ nhne akebne ẹto zị,  
\v 8 Enine, mini nụ ọvnarna.\f + \fr 5:8 \ft Agwna ọkwukwo ke be gbarụ kpa agịda awha whemernu kwu kwno, \fq n'oligwe Nda, Ikwu-ọnu nụ Enine Nsọ. Nhne ẹto ka nookwu otu ọnu. 8 Nhne akebne ẹto zị n'ọwa, Enine, mini nụ ọvnarna.\f* Nhne ẹto ka kwerikọtaru otu nhne.  
\v 9 Ọ bụru a kweru nụ nhne badnụ kwuru, nhne Chiokike kwuru kakwo, kwnornu nụ ọ bụ akebne Chiokike gbarụ gbasịri Nnwọ a.  
\v 10 Nye ọbula ke kweru nụ Nnwọ Chiokike nwernu nhne akebne ka nụ mkpọma a. Nye ọbula ke kwéle nụ Chiokike neeme a nye aghalaghala, kwnornu nụ o kwéle n'akebne Chiokike gbarụ gbasịri Nnwọ a.  
\v 11 Ka bụ akebne wam, Chiokike nyernu aị bụdnu kwó okwo, bụdnu wam zị nụ rime Nnwọ a.  
\v 12 Ka neegesi nụ nye ọbula ke nwernu Nnwọ Chiokike nwernu bụdnu kwó okwo, nye ọbula ke nwée Nnwọ Chiokike nwée bụdnu. 
\s1 Ọka ipne-aznụ 
\p  
\v 13 M naagbanụ anụ ele kweru nụ rẹwhna Nnwọ Chiokike, ma anụ mahịa nụ anụ nwernu bụdnu kwó okwo.  
\v 14 Ka bụ nhne neemesi aị ovu rikne ọ vakwnusi Chiokike. A magwụ nụ a rịo nhne ọbula lele kpa echiche ovu a jiri zị, ọ jọonu aị.  
\v 15 Ọ bụru nụ a magwụ nụ ọ nọonu nhne a nọorio a, ovu siri aị rikne nụ a jeenwehịa nhne nọorio a. 
\p  
\v 16 Ọ bụru nụ nye ọbula whnụrnu nwene a mernu mmehie ke zá noodubna n'ẹnwu, o kpe okpukpe ma Chiokike nyee a bụdnu. M nookwu nhne gbasịri ele neeme mmehie ke zá noodubna n'ẹnwu. Mmehie ke noodubna n'ẹnwu zị. M zá naakaa badnụ kpe okpukpe gbasịri a.  
\v 17 Kpakara nhne bụ́o ọma bụ mmehie, kọvu agwna mmehie zá noodubna n'ẹnwu. 
\p  
\v 18 A magwụ nụ nye ọbula Chiokike mụrnu zá neemezne mmehie. Nnwọ Chiokike naabịta nye ọbula ke Chiokike mụrnu, nye ọjo wam nwée rikne mekasi a nhne. 
\p  
\v 19 A magwụ nụ a bụ rụmu Chiokike, kọvu kpakara ọwa zị nụ mkpururu nye ọjo wam.  
\v 20 A magwụ nụ Jizọsi Karaịsi Nnwọ Chiokike varụ, ma a mahịa nye wam bụ ezi ọka. A zị masị nụ rime nye wam ke bụ ezi ọka, Jizọsi Karaịsi Nnwọ a. Ya n'iwhuru a bụ Chiokike n'ezi nụ bụdnu kwó okwo. 
\p  
\v 21 Rụmu takịri m, anụ gweme ẹhni anụ n'ọkwa rẹnwu.