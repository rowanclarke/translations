\p \w Dans|strong="H06440"\w* \w le|strong="H06440"\w* \w temple|strong="H01964"\w*, \w dans|strong="H06440"\w* \w l|strong="H06440"\w*’\w intérieur|strong="H06442"\w* \w et|strong="H06440"\w* \w dans|strong="H06440"\w* \w le|strong="H06440"\w* \w vestibule|strong="H00197"\w* \w du|strong="H06440"\w* \w parvis|strong="H02691"\w*\f + \fr 41:15 \ft 15. \ft \+it Vestibule du parvis\+it*, donnant sur le parvis.\f*,  
\v 16 \w les|strong="H03680"\w* \w seuils|strong="H05592"\w*, \w les|strong="H03680"\w* \w fenêtres|strong="H02474"\w* \w grillées|strong="H00331"\w* \w et|strong="H06086"\w* \w les|strong="H03680"\w* \w galeries|strong="H00862"\w* \w tout|strong="H05439"\w* \w autour|strong="H05439"\w*, \w pour|strong="H05704"\w* \w tous|strong="H03606"\w* \w les|strong="H03680"\w* \w trois|strong="H07969"\w*, \w étaient|strong="H05975"\w* \w recouverts|strong="H07824"\w*, \w à|strong="H05704"\w* \w la|strong="H03680"\w* \w hauteur|strong="H06967"\w* \w du|strong="H05439"\w* \w seuil|strong="H05592"\w*, \w de|strong="H06086"\w* \w bois|strong="H06086"\w* \w uni|strong="H03477"\w* \w tout|strong="H05439"\w* \w autour|strong="H05439"\w*. \w Le|strong="H03680"\w* \w sol|strong="H00127"\w* jusqu’\w aux|strong="H06086"\w* \w fenêtres|strong="H02474"\w*, — \w et|strong="H06086"\w* \w les|strong="H03680"\w* \w fenêtres|strong="H02474"\w* \w étaient|strong="H05975"\w* \w fermées|strong="H02474"\w*\f + \fr 41:16 \ft 16. Traduction renfermant des détails incertains.\f*, —  
\v 17 jusqu’\w au|strong="H01004"\w* \w dessus|strong="H05921"\w* \w de|strong="H01004"\w* \w la|strong="H05921"\w* \w porte|strong="H06607"\w* \w et|strong="H01004"\w* jusqu’\w au|strong="H01004"\w* \w fond|strong="H03411"\w* \w de|strong="H01004"\w* \w la|strong="H05921"\w* \w maison|strong="H01004"\w*, \w et|strong="H01004"\w* \w au|strong="H01004"\w* \w dehors|strong="H02351"\w* \w sur|strong="H05921"\w* \w chaque|strong="H03605"\w* \w muraille|strong="H07023"\w* \w tout|strong="H03605"\w* \w à|strong="H05704"\w* l’\w entour|strong="H05439"\w*, \w à|strong="H05704"\w* l’\w intérieur|strong="H06442"\w* \w et|strong="H01004"\w*\f + \fr 41:17 \ft 17. \ft \+it À l’intérieur\+it*, dans le Saint des saints, \+it intérieur\+it* par rapport au prophète. — \+it À l’extérieur\+it*, dans le vestibule qui donnait sur le parvis, et était extérieur relativement à Ézéchiel, qui était dans le Saint. — Verset obscur.\f* \w à|strong="H05704"\w* l’\w extérieur|strong="H02435"\w*, \w tout|strong="H03605"\w* \w était|strong="H01004"\w* \w couvert|strong="H03680"\w* \w de|strong="H01004"\w* \w tentures|strong="H04374"\w*,  
