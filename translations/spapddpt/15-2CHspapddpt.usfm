\v 22 En \w el|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w de|strong="H6256"\w* \w su|strong="H1931"\w* aflicción, \w el|strong="H1931"\w* \w rey|strong="H4428"\w* Acaz aumentó \w su|strong="H1931"\w* infidelidad \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*,  
\v 23 \w pues|strong="H3588"\w* \w ofreció|strong="H2076"\w* \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \tl ʼelohim\tl* \w de|strong="H3588"\w* \w los|strong="H1992"\w* damascenos \w que|strong="H3588"\w* \w lo|strong="H1992"\w* vencieron. Decía: \w Ya|strong="H3068"\w* \w que|strong="H3588"\w* \w los|strong="H1992"\w* \tl ʼelohim\tl* \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w reyes|strong="H4428"\w* \w de|strong="H3588"\w* Siria \w los|strong="H1992"\w* \w ayudaron|strong="H5826"\w*, \w yo|strong="H3588"\w* también ofreceré \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* \w ellos|strong="H1992"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* ayuden. \w Pero|strong="H3588"\w* \w éstos|strong="H1992"\w* \w fueron|strong="H1961"\w* \w su|strong="H1992"\w* \w ruina|strong="H3782"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*.   
