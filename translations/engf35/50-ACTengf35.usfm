\v 8 \w So|strong="G1161"\w* \w Peter|strong="G4074"\w* addressed \w her|strong="G1438"\w*, “\w Tell|strong="G3004"\w* \w me|strong="G1473"\w* \w whether|strong="G1487"\w* \w you|strong="G1487"\w* sold \w the|strong="G1161"\w* \w land|strong="G5564"\w* \w for|strong="G4314"\w* \w so|strong="G1161"\w* \w much|strong="G5118"\w*.” \w So|strong="G1161"\w* \w she|strong="G1161"\w* \w said|strong="G3004"\w*, “\w Yes|strong="G3483"\w*, \w for|strong="G4314"\w* \w so|strong="G1161"\w* \w much|strong="G5118"\w*.”
