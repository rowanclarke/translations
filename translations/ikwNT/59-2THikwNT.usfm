\id 2TH - Ikwerre
\h 2 Ele Tẹsalonika
\toc1 Ọkwukwo izi ke Ẹbo Pọlu gbaznennu Ele Tẹsalonika
\toc2 2 Ele Tẹsalonika
\toc3 2 Tẹs
\mt2 Ọkwukwo izi
\mt2 ke Ẹbo
\mt2 Pọlu gbaznennu
\mt1 Ele Tẹsalonika
\imt1 Nhne gbasịri ọkwukwo izi ka
\im Pọlu panịzoru nọotunu Chiokike mmamma kwnornu ọkwnata mkpọma nụ ọwhnun'anya ele Tẹsalonika ke nooso oso ige ọbula (1:3). Ọ bụ n'ezi nụ be naagawhe agịda mmekpẹhni, Pọlu naakanụ be nụ Chiokike nọotule ọkwnata mkpọma be nwernu nụ hne ọ zị, ọ zá naata be awhnụwhnu (1:4,5).
\ip Be whnụrnu ọkwukwo izi ke otu badnụ karụ nụ Pọlu gbarụ, ke nookwu nụ Nyenwe aị valẹm (2:2). Kọvu Pọlu nọodo be aka nụ nsnị be kwékọ nye ọbula duwhu be, kwnornu nụ Nyenwe aị jáava tem “nye ọjo wam” whụya iwhne (2:3).
\ip Pọlu jiri okpukpe mesni ọkwukwo izi ka (3:16).
\iot Nhne zị n'ọkwukwo izi ka
\io1 Obekwu ikwu \ior (1:1,2) \ior*
\io1 Ọtu mmamma nụ okpukpe \ior (1:3-12) \ior*
\io1 Nyenwe aị yáavage \ior (2:1-12) \ior*
\io1 Bụru nye be kwesiri ọkwnata mkpọma \ior (2:13-17) \ior*
\io1 Kpe okpukpe, rnụ masị ẹrnu \ior (3:1-15) \ior*
\io1 Okpukpe ipne-aznụ \ior (3:16-18) \ior*
\c 1
\p 
\v 1 Mawa, Pọlu, nụ Saịlasi nụ Timoti naagba ọkwukwo gbaznenu ọgbako Chiokike ke zị nụ Tẹsalonika, anụ ele Chiokike Nda aị nụ Nyenwe aị Jizọsi Karaịsi.
\v 2 Oru nụ udno ke hi n'aka Chiokike Nda aị nụ Nyenwe aị Jizọsi Karaịsi dazịgidnenu anụ.
\s1 Ọtu mmamma nụ okpukpe
\p 
\v 3 A kwesiri nọotunu Chiokike mmamma nụ risi anụ ige ọbula, ke kakwo kwnornu nụ ọkwnata ovu anụ nooso oso kpakara ọbochi lele kpa ọwhnun'anya anụ nooso masị oso n'ẹhni ibne anụ.
\v 4 A ji anụ noolu ọnu n'esilawụru ọgbako Chiokike kwnornu nụ ọkwnata ovu anụ gwuzo kwem nụ ruwhnu ọkpakna ẹhni nụ nhne ọrnurna anụ naagawhe.
\p 
\v 5 Ka neegesi nụ ikpe Chiokike zị snam, ke kpayarụ, be jọogwnusi anụ nụ ele kwesiri ọ bna ẹli-eze Chiokike ke anụ kwno naata awhnụwhnu.
\v 6 Chiokike bụ nye zị snam. O jaakpakna ele naakpakna anụ ẹhni.
\v 7 O jeeme anụ ele be naakpakna ẹhni zukwaru inwe, ma aịla masị. Ka jọobu nga Nyenwe aị Jizọsi jaava hite n'oligwe, ya nụ ele enine izi a zị rikne nụ lele bẹkwnu noowu va-a-a.
\v 8 Ọ jaata kpakara ele máa Chiokike awhnụwhnu nụ ele zá noobno nsnị izi ọma gbasịri Nyenwe aị Jizọsi.
\v 9 Ọ jaata be awhnụwhnu ọkwnukokwnu, chịma be nụ ruwhnu Nyenwe aị nụ igwugwu ke iknernema a.
\v 10 N'ọbochi ọ jaava, ele ke a zị nsọ nụ kpakara ele kweru nụ ya jeenye a igwugwu, jaa a mma. Anụ joosno ele kweru ekwe kwnornu nụ anụ kweru izi ọma a znirni anụ.
\p 
\v 11 Ka bụ nhne a vu n'ovu neekpenu anụ okpukpe ige ọbula, ma Chiokike aị gwnụsi anụ ele kwesiri osukwu ikwu a, hite n'iknernema a mee kpakara nhne ọma anụ vu n'echiche mezu nụ kpakara nhne anụ neeme bụru nhne hi n'ọkwnata ovu.
\v 12 Ka bụ ma be znarnị rẹwhna Nyenwe aị Jizọsi kwnornu nụ anụ, ma anụ kwnornu ya, hite n'oru Chiokike aị nụ Nyenwe aị Jizọsi Karaịsi.
\c 2
\s1 Badnụ wam // ke noolulu Iwu
\p 
\v 1 Nhne gbasịri ọvuva ke Nyenwe aị Jizọsi Karaịsi nụ kpa a jeeznekwnusi a, a naarịasno anụ rụmu nda aị,
\v 2 mkpọma lákọ anụ mini, ogwnu tụ́ko anụ kwnornu agwna izi ọwhnurninya, mọbu izi berere, mọbu ọkwukwo izi be naakaa nụ a gbarụ, ke naakaa n'ọbochi Nyenwe aị jeehiehna whelem.
\v 3 Anụ kwé nye ọbula duwhu anụ n'apna ọbula, kwnornu nụ ọbochi Nyenwe aị jeehiehna jáava tem okne olulu wam nụ nye wam noolulu iwu va. Nye wam bụ nye Chiokike jaata awhnụwhnu ọkwnukokwnu,
\v 4 O joovulizọ ẹhni a olu megidne kpakara chi ele badnụ neekpenu. O joogwuzote ẹhni a n'Ọro Nsọ Chiokike kaa nụ ọ bụ Chiokike.
\p 
\v 5 Anụ chenwanya nụ m kannụ m anụ nhne ka nga me nụ anụ zị.
\v 6 Anụ magwụ nhne noobnosni a ma ọ gharụ ọ whụya iwhne kịtna, kọvu be jeegesi nye ọjo wam n'ige kwesiri.
\v 7 Kwnornu nụ rikne nye wam noolulu iwu nọornu ẹrnu nụ mgwụgwa kịtna, kọvu nye wam ke noobnosni a jaazị kọriri noobnosni a tem be gweme a n'apna.
\v 8 Ige wam be jookpume nye wam noolulu iwu, nye Nyenwe aị Jizọsi jeeji inwe ke ọnu a gbu nụ hite n'onwu va-a-a ke ọvuva a.
\v 9 Nga nye wam noolulu iwu jaava, Ekwensu jeegesi ẹrnu ndu-ẹhni ọ kpahie anya zị ọdo n'ọdo nụ nhne elekema nụ ẹrnu tụ n'anya,
\v 10 nụ kpakara ẹrnu ọjo o jeeji nooduwhu ele nọonwu ọnwu. Be whu etekne kwnornu nụ be kwéle o kweru ezi ọka ma Chiokike znọhia be.
\v 11 Kam kpayarụ, Chiokike ziznenu be rikne o mee nhne bụ́o ọma ma be kweru aghalaghala,
\v 12 ka bụ ma kpakara ele kwéle o kweru ezi ọka, ele whnụrnu arụru-ẹli n'anya bụru ele ikpe Chiokike marnụ.
\s1 Gwuzosi rikne
\p 
\v 13 Kọvu a nọotunu Chiokike mmamma ige ọbula kwnornu anụ rụmu nda aị, ele Nyenwe aị whnụrnu n'anya. Hite n'ọpanizo, Chiokike họhiaru anụ ma ọ znọhia anụ hite n'ẹrnu Enine Nsọ ke neeme anụ zịri nsọ, kwnornu nụ anụ kweruru ezi ọka.
\v 14 Kam kpayarụ, o sukwuru anụ hite n'izi ọma aị, ma anụ kehịa igwe n'igwugwu Nyenwe aị Jizọsi Karaịsi.
\v 15 Rụmu nda aị, anụ gwuzoru kwem, anụ jikwasi nhne a znirni anụ rikne, hite n'ikwu-ọnu mọbu ọkwukwo izi a gbarụ.
\p 
\v 16 Kịtna, Nyenwe aị Jizọsi Karaịsi n'iwhuru a nụ Chiokike Nda aị, nye whnụrnu aị n'anya, hite n'oru o nyernu aị nụ olile anya bụru ọma, mee a gwuzosi rikne,
\v 17 gba anụ inwe, mee anụ gbasị rikne nụ kpakara ẹrnu ọma nụ ikwu-ọnu.
\c 3
\s1 Anụ kpenu aị okpukpe
\p 
\v 1 Ke ipne-aznụ, rụmu nda aị, anụ kpenu aị okpukpe ma izi Nyenwe aị gbasa k'agịda, nwernu masị igwugwu a lele kpa ọ zị n'esilawụru anụ.
\v 2 Kpe masị ma Chiokike dọhia aị n'aka ele ọjo nụ ele arụru-ẹli, kwnornu nụ ọ bụ́o kpakara badnụ nwernu ọkwnata ovu.
\v 3 Kọvu Chiokike bụ nye kwesiri ọkwnata ovu, o jeenye anụ rikne, kpusni anụ hite n'aka nye ọjo wam.
\v 4 A tụkwasiri Nyenwe aị mkpọma nụ anụ zị kọriri neeme neezne nụ ruwhnu kpakara nhne a nyernu anụ n'iwu.
\v 5 Nyenwe aị duru mkpọma anụ dụ n'ọwhnun'anya Chiokike nụ ọsnuta mkpọma ke zị nụ rime Karaịsi.
\s1 Ọ dọ aka nụ nsnị // gbasịri ime mgwụ
\p 
\v 6 Rụmu nda aị, a ji rẹwhna Nyenwe aị Jizọsi Karaịsi neenye anụ iwu, anụ zeru nnwọ nda ọbula ke bụ nye ime-mgwụ, nye zá noowu bụdnu lele kpa nhne a znirni anụ.
\v 7 Kwnornu nụ anụ magwụ kpa anụ kwesiri o snornu nhne atụ aị. A bụ́o ele ime-mgwụ nga aị nụ anụ zị.
\v 8 A ríge wiri nye ọbula ke a kwụ́la ọgwo. Tnụnuma, a dọgburu ẹhni aị n'ẹrnu iwhnehnie nụ abalị, nọornu ẹrnu ma a gharụ ọ bụru ivu rịnya nyee anụ.
\v 9 Ka bụ́o nụ a nwée rikne nahọru anụ nhne, kọvu ma a bụru ele anụ jọomuhia nhne n'aka be.
\v 10 Nga aị nụ anụ zị, a znirni anụ nhne ka, “Ọ bụru nụ nye ọbula jọ́ornu ẹrnu, o rí wiri.”
\p 
\v 11 A nọonu nụ agwna ele badnụ dazị etekne, be mée nhne ọbula, ele nookwu ọka gbásịla be.
\v 12 A ji rẹwhna Nyenwe aị Jizọsi Karaịsi neenye be iwu, be gbasị rikne, rnụhia nhne be jeeri.
\v 13 Rikne gwụ́ anụ rụmu nda aị n'ome nhne bụru ọma.
\p 
\v 14 Nye ọbula ke zá naabịta nhne a gbarụ n'ọkwukwo izi ka, anụ hnata nye wam ama. Anụ nụ nye wam mékọ nhne ọbula, ma iwhnerne tụ a.
\v 15 Kọvu anụ mée be ele irno anụ, anụ zni be ezni lele rụmu nda.
\s1 Obekwu ikwu ipne-aznụ
\p 
\v 16 Kịtna, Nyenwe aị ke udno n'iwhuru a nyee anụ udno ige ọbula n'apna ọbula. Nyenwe aị dazịgidnenu kpakara anụ.
\p 
\v 17 Mawa, Pọlu, ji aka m gba obekwu ikwu ipne-aznụ ka. Ka bụ nhne neegesi nụ mawa gbarụ obekwu ikwu ipne-aznụ ke me gbarụ.
\p 
\v 18 Oru Nyenwe aị Jizọsi Karaịsi dazịgidnenu kpakara anụ.
