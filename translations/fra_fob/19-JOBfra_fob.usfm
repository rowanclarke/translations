\v 8 \w Maintenant|strong="H6258"\w*, \w prenez|strong="H3947"\w* \w sept|strong="H7651"\w* \w taureaux|strong="H6499"\w* \w et|strong="H3212"\w* \w sept|strong="H7651"\w* \w béliers|strong="H5973"\w*, \w et|strong="H3212"\w* \w allez|strong="H3212"\w* \w vers|strong="H3212"\w* \w mon|strong="H6440"\w* \w serviteur|strong="H5650"\w* \w Job|strong="H3588"\w*, \w offrez|strong="H5927"\w* \w un|strong="H6213"\w* \w holocauste|strong="H5930"\w* \w pour|strong="H6213"\w* \w vous|strong="H6440"\w*, \w et|strong="H3212"\w* \w Job|strong="H3588"\w*, \w mon|strong="H6440"\w* \w serviteur|strong="H5650"\w*, \w priera|strong="H6419"\w* \w pour|strong="H6213"\w* \w vous|strong="H6440"\w*; \w et|strong="H3212"\w* \w par|strong="H6440"\w* \w égard|strong="H5375"\w* \w pour|strong="H6213"\w* \w lui|strong="H6440"\w*, \w je|strong="H3588"\w* \w ne|strong="H3808"\w* \w vous|strong="H6440"\w* \w traiterai|strong="H6213"\w* \w pas|strong="H3808"\w* \w selon|strong="H5921"\w* \w votre|strong="H6440"\w* \w folie|strong="H5039"\w*, \w car|strong="H3588"\w* \w vous|strong="H6440"\w* \w n|strong="H1115"\w*'\w avez|strong="H6440"\w* \w pas|strong="H3808"\w* \w parlé|strong="H1696"\w* \w avec|strong="H6213"\w* \w droiture|strong="H3559"\w* \w devant|strong="H6440"\w* \w moi|strong="H6440"\w*, \w comme|strong="H6213"\w* \w mon|strong="H6440"\w* \w serviteur|strong="H5650"\w* \w Job|strong="H3588"\w*.  
