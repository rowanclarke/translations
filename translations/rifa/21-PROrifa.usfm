\id PRO
\h أَوَاڒنْ إِوزْننْ
\toc1 أَوَاڒنْ إِوزْننْ
\toc2 أَوَاڒنْ إِوزْننْ
\toc3 أَوڒن.
\mt1 أَوَاڒنْ إِوزْننْ
\c 1
\s1 أَوَاڒْ أَمزْوَارُو - لْغَارَاضْ ن وَاوَاڒنْ إِوزْننْ
\m 
\v 1 أَوَاڒنْ إِوزْننْ ن سُولِيمَانْ،
\m مِّيسْ ن ذَاوُوذْ، أَجدْجِيذْ ن إِسْرَائِيل،
\m 
\v 2 حِيمَا أَذْ إِسّنْ \add بْنَاذمْ\add* ثِيغِيثْ ذ تَّارْبِييّثْ،
\m حِيمَا أَذْ إِفْهمْ أَوَاڒنْ \add شُّورنْ س\add* ڒفْهَامثْ،
\m 
\v 3 حِيمَا أَذْ إِقْبڒْ تَّارْبِييّثْ ذ ڒعْقڒْ،
\m ثَاسڭْذَا ذ ڒْحقّْ ذ ڒصْفَايثْ،
\m 
\v 4 حِيمَا أَذْ إِوْشْ أَسْفَارْزْ إِ إِحَافِييّنْ،
\m ثُوسّْنَا ذ ؤُحَاذُورْ إِ ؤُحُوذْرِي.
\m 
\v 5 أجّْ أَمِيغِيسْ أَذْ إِسڒْ
\m ؤُ أَذْ يَارْنِي ذِي ڒفْهَامثْ نّسْ،
\m أجّْ ونِّي إِفهّْمنْ أَذْ إِكْسبْ ڒقْنَاعثْ،
\m 
\v 6 حِيمَا أَذْ إِفْهمْ أَوَاڒْ إِوزْننْ ذ لْمَاثَالْ،
\m أَوَاڒنْ ن إِمِيغِيسنْ
\m ذ ڒمْعَانِي إِنُّوفَارنْ نْسنْ.
\m 
\v 7 ثِيڭّْوُوذِي ن سِيذِي ذ بدُّو ن ثُوسّْنَا،
\m \add مَاشَا\add* إِبُوهَاڒِييّنْ
\m سّحْقَارَانْ ثِيغِيثْ ذ تَّارْبِييّثْ. \x ◘ \xo 1:‏7 \xt أَيُوبْ 28‏:‏28؛ إِزهد. 111‏:‏10؛ أَوڒن. 9‏:‏10؛ أَمب. 12‏:‏13\x*
\b
\s1 شّْوَارْ ن بَابَاسْ إِ مِّيسْ
\m 
\v 8 سڒْ، أَ مِّي، غَارْ تَّارْبِييّثْ ن بَابَاشْ،
\m وَارْ تَّاڭِي شَا ثَاغُورِي ن يمَّاشْ،
\m 
\v 9 مَاغَارْ نِيثنْثِي \add أَذْ إِڒِينْثْ\add*
\m ذ تَّاجْ إِشْنَا خْ ؤُزدْجِيفْ نّشْ،
\m ذ ثْسدّْيِينْ \add إِزوّْقنْ\add* إِ يِيرِي نّشْ.
\m 
\v 10 \add أَ\add* مِّي، مَاڒَا خْسنْ إِمذْنَابْ
\m أَذْ شكْ غْوَانْ،
\m وَارْ ذ أَسنْ تّڭّْ شَا أَرَّايْ.
\m 
\v 11 مَاڒَا نِيثْنِي قَّارنْ:
\m ”ؤُيُورْ أَكِيذْنغْ، أجّْ أَذْ نْحَامَا
\m إِ \add ؤُسِيزّڒْ ن\add* إِذَامّنْ،
\m أجّْ أَنغْ أَذْ نڭّْ إِجّْ ن ڒْفخْ
\m إِ ؤُمزْذَاڭْ، بْڒَا سِّيبّثْ،
\m 
\v 12 أجّْ أَنغْ أَذْ ثنْ نْصَارْضْ أَمْ دَّارنْ،
\m أَمْ مَامّشْ \add ثْصَارضْ\add* ڒَاخَارْثْ،
\m أَمْ كمْڒمْ،
\m أَمْ مَامّشْ إِمْسَارْ
\m أَكْ-ذ يِينِّي إِهكّْوَانْ
\m ذڭْ وحْفُورْ \add ن ونْضڒْ\add*.
\m 
\v 13 أَذْ نَافْ عْڒَامْكُورْ ڒحْوَايجْ يِيغْڒَانْ أَطَّاسْ،
\m ثُوذْرِينْ نّغْ أَذْ ثنْثْ نشُّورْ س ثْكشَّاضْثْ.
\m 
\v 14 شكْ أَذْ ثنْضَارذْ ثَاقدُّوحْثْ نّشْ جَارْ أَنغْ،
\m أَذْ غَارْنغْ \add ثِيڒِي\add* مَارَّا إِشْثْ ن ثشْيَارْثْ.“
\m 
\v 15 \add أَ\add* مِّي، وَارْ كِيذْسنْ ڭُّورْ ذڭْ وبْرِيذْ،
\m سِيڭّْوجْ أَضَارْ نّشْ خْ ؤُمسْرُوقْ نْسنْ،
\m 
\v 16 مَاغَارْ إِضَارنْ نْسنْ تَّازّْڒنْ غَارْ ڒْغَارْ،
\m ؤُ نِيثْنِي تّْقدْجِيقنْ
\m مَاحنْذْ أَذْ سِّيزّْڒنْ إِذَامّنْ. \x ◘ \xo 1:‏16 \xt إِشا. 59‏:‏7؛ رُوم. 3‏:‏15\x*
\m 
\v 17 مَاغَارْ س ڒْبَاطڒْ أَذْ ثتّْوَابزّعْ ثْرَاشَّا،
\m زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا
\m مِينْ غَارْ إِدْجَا وَافْرِيونْ،
\m 
\v 18 \add مَاغَارْ\add* نِيثْنِي تّْحَامَانْ
\m إِذَامّنْ \add ن يِيخفْ\add* نْسنْ،
\m تّڭّنْ ڒْفخْ إِ ڒعْمُورْ \add ن يِيخفْ\add* نْسنْ.
\m 
\v 19 أَمُّو إِ إِدْجَانْ إِبْرِيذنْ ن كُوڒْ إِجّْ
\m ونِّي إِتَّازّْڒنْ غَارْ أَرْبحْ،
\m أَقَا أَيَا إِتّطّفْ ڒعْمَارْ ن سِيذِيسْ. \x ◘ \xo 1:‏19 \xt أَيُوبْ 8‏:‏13\x*
\b
\s1 ثِيغِيثْ
\m 
\v 20 ثِيغِيثْ ثتّْڒَاغَا س جّْهذْ \add ذِيهَا\add* بَارَّا،
\m ثسّْڭعّذْ ثْمِيجَّا نّسْ ذڭْ وَازَّاينْ.
\m 
\v 21 غَارْ ؤُمزْوَارْ ن إِمُوشَانْ إِ ذَايْسنْ ڒْهَارَاجْ،
\m ثتّْبَارَّاحْ نتَّاثْ،
\m غَارْ وَاذَافنْ ن ثوُّورَا ن ثنْذِينْثْ
\m ثسَّاوَاڒْ أَوَاڒنْ نّسْ.
\m 
\v 22 ”أَڒْ مڒْمِي غَا قِّيمنْ
\m إِحَافِييّنْ تّخْسنْ ثَاقُوبَّانشْثْ،
\m \add أَڒْ مڒْمِي\add* ذ أَسنْ إِ غَا إِعْجبْ
\m ؤُحشِّي إِ إِمسْثهْزَاينْ،
\m ؤُ \add أَڒْ مڒْمِي\add* غَا شَارْهنْ
\m إِبُوهَاڒِييّنْ ثُوسّْنَا؟
\m 
\v 23 ذوْڒمْ غَارْ ؤُوبّخْ إِنُو!
\m خْزَارمْ، نشّْ أَذْ خَاومْ سّْفَارّْغغْ
\m أَرُّوحْ إِنُو،
\m أَوَاڒنْ إِنُو أَذْ أَومْ ثنْعڒْمغْ.“
\b
\m 
\v 24 ”أَقَا زعْمَا ڒَاغِيغْ ؤُ كنِّيوْ وَارْ ثخْسمْ،
\m سّْوِيژّْضغْ نشّْ أَفُوسْ إِنُو،
\m \add مَاشَا\add* ؤُڒَا ذ إِجّْ وَارْ ذ أَسْ إِحكَّارْ. \x ◘ \xo 1:‏24 \xt إِشا. 65‏:‏12؛ 66‏:‏4؛ إِرْم. 13‏:‏10\x*
\m 
\v 25 ثنْضَارمْ شّْوَارْ إِنُو،
\m أَوبّخْ إِنُو وَارْ ث ثقْبِيڒمْ.
\m 
\v 26 \add س ؤُينِّي\add* ؤُڒَا ذ نشّْ
\m أَذْ ضحْشغْ خْ ؤُضيّعْ نْومْ،
\m نشّْ أَذْ \add زَّايْومْ\add* سْثهْزغْ
\m خْمِي د غَا يَاسْ ؤُنخْڒِيعْ نْومْ،
\m 
\v 27 خْمِي د غَا يَاسْ ؤُنخْڒِيعْ نْومْ
\m أَمْ يِيجّْ ن ؤُردّدْجْ،
\m أَضيّعْ نْومْ أَمْ يِيشْثْ ن ثْحَارْيَاضْثْ،
\m خْمِي خَاومْ د غَا ثوْضَا
\m ڒحْصَارثْ ذ ثڭّْوُوذِي. \x ◘ \xo 1:‏27 \xt أَيُوبْ 27‏:‏9؛ 35‏:‏12؛ إِشا. 1‏:‏15؛ إِرْم. 11‏:‏11؛ 14‏:‏12؛ حِز. 8‏:‏18؛ مِيخَا 3‏:‏4\x*
\m 
\v 28 خنِّي أَذْ خَافِي د-ڒَْاغَانْ،
\m مَاشَا نشّْ وَارْ د-تَّارِّيغْ،
\m أَذْ خَافِي أَرْزُونْ، \add مَاشَا\add* وَارْ ذ أَيِي تِّيفنْ،
\m 
\v 29 مِينْزِي نِيثْنِي شَارْهنْ ثُوسّْنَا،
\m ؤُ وَارْ إِخْضَارنْ \add أَذْ طّْفنْ ذِي\add* ثِيڭّْوُوذِي ن سِيذِي.
\m 
\v 30 نِيثْنِي وَارْ خْسنْ شَا ڒشْوَارْ إِنُو،
\m مَارَّا أَوبّخْ إِنُو نْضَارنْ ث.
\m 
\v 31 نِيثْنِي أَذْ شّنْ زِي ڒْغِيدْجثْ ن وبْرِيذْ نْسنْ،
\m ؤُ أَذْ جِّيوْننْ س إِخَارِّيصنْ ن يِيخفْ نْسنْ،
\m 
\v 32 مِينْزِي ؤُفُّوغْ ن إِحَافيّنْ
\m \add خْ وبْرِيذْ\add* أَذْ ثنْ إِنغْ،
\m ؤُ أَفْڒَاحْ ن إِبُوهَاڒِييّنْ أَذْ ثنْ إِسّْهلّكْ.
\m 
\v 33 وِي غَارِي إِ غَا إِسْڒنْ، أَذْ إِزْذغْ ذِي ڒَامَانْ،
\m أَذْ يِيڒِي ذِي ڒهْنَا بْڒَا أَنخْڒِيعْ ن ثُوعفّْنَا.“
\b
\b
\c 2
\m 
\v 1 مِّي إِنُو، مَاڒَا ثْقبْڒذْ أَوَاڒنْ إِنُو
\m ؤُ أَذْ ثحْضِيذْ ثِيوصَّا إِنُو غَاركْ،
\m 
\v 2 مَاحنْذْ أَمزُّوغْ نّشْ أَذْ إِوْشْ ثَايْنِيثْ إِ ثِيغِيثْ
\m \add ؤُشَا\add* ؤُڒْ نّشْ أَذْ إِميّڒْ غَارْ ڒفْهَامثْ،
\m 
\v 3 \add وَاهْ،\add* مَاڒَا ثتّْڒَاغِيذْ-د خْ ڒعْقڒْ،
\m أَذْ ثسّْخذْمذْ ثْمِيجَّا نّشْ
\m مَاحنْذْ \add أَذْ ثَافذْ\add* ڒفْهَامثْ،
\m 
\v 4 مَاڒَا ثَارزُّوذْ خَاسْ
\m أَمْ \add ثَارزُّوذْ\add* خْ نُّوقَارْثْ،
\m \add مَاڒَا\add* خَاسْ ثَارزُّوذْ
\m أَمْ خْ ثْخُوبَايْ إِنُّوفَّارنْ، \f ◼ \fr 2:‏4 \ft \bd ’ثِيخُوبَايْ‘\bd* - نِيغْ ’ڒكْنُوزْ‘.\f*  \x ◘ \xo 2:‏4 \xt مت. 13‏:‏44\x*
\m 
\v 5 خنِّي أَذْ ثْفهْمذْ إِ ثِيڭّْوُوذِي ن سِيذِي،
\m ؤُ أَذْ ثَافذْ ثُوسّْنَا ن أَربِّي.
\b
\m 
\v 6 مَاغَارْ سِيذِي إِتِّيشْ ثِيغِيثْ،
\m زڭْ ؤُقمُّومْ نّسْ ثتّفّغْ-د
\m ثُوسّْنَا ذ ڒفْهَامثْ. \x ◘ \xo 2:‏6 \xt 1 إِج. 3‏:‏9، 12؛ يَاع. 1‏:‏5\x*
\m 
\v 7 إِ يِينِّي إِڭُّورنْ نِيشَانْ إِسّوْجذْ أَسنْ ثْوِيزَا،
\m إِ يِينِّي إِڭُّورنْ ذِي ڒكْمَارثْ
\m \add أَقَا-ث\add* ذ ثَاسدَّارْثْ إِ ؤُسڒْقِي،
\m 
\v 8 حِيمَا أَذْ قِّيمنْ تّطّْفنْ
\m ذڭْ إِمسْرَاقْ نْ ڒْحقّْ،
\m ؤُ نتَّا أَذْ إِسَّارْ أَبْرِيذْ
\m ن يِينِّي ذَايْسنْ ڒَامَانْ زَّاثسْ.
\b
\m 
\v 9 خنِّي إِ غَا ثْفهْمذْ ثَاسڭْذَا ذ ڒْحقّْ،
\m ؤُڒَا ذ ڒصْفَايثْ،
\m كُوڒْ ڒَاثَارْ إِصبْحنْ \add مَاحنْذْ أَذْ ث ثضْفَارذْ\add*.
\m 
\v 10 مَاغَارْ ثِيغِيثْ أَذْ ثَاذفْ غَارْ وُوڒْ نّشْ،
\m ؤُ ثُوسّْنَا أَذْ ثَارْضَا خْ ڒعْمَارْ نّشْ.
\m 
\v 11 أَحَاذُورْ أَذْ خَاكْ إِحْضَا،
\m ڒفْهَامثْ أَذْ خَاكْ ثسَّارْ:
\b
\m 
\v 12 ... مَاحنْذْ أَذْ شكْ ثْفكّْ
\m زڭْ وبْرِيذْ ن ؤُعفَّانْ،
\m زڭْ ورْيَازْ نِّي إِقدْجْبنْ أَوَاڒْ نّسْ،
\m 
\v 13 زڭْ إِنِّي إِسمْحنْ
\m ذڭْ إِمسْرَاقْ إِسڭّْمنْ،
\m مَاحنْذْ أَذْ ؤُيُورنْ إِبْرِيذنْ ن طّْڒَامْ،
\m 
\v 14 إِنِّي إِفَارّْحنْ مَاحنْذْ أَذْ ڭّنْ ڒْغَارْ،
\m \add ؤُ\add* سّْڒِيوْڒِيونْ خْ ڒخْذَاعَاثْ ن ڒْغَارْ،
\m 
\v 15 زڭْ يِينِّي فَارْغنْ إِمسْرَاقْ نْسنْ
\m ذ يِينِّي إِميّْڒنْ سَّا ذ سَّا
\m ذِي ڒَاثَارَاثْ \add ن يِيخفْ\add* نْسنْ،
\b
\m 
\v 16 ... مَاحنْذْ أَذْ شكْ ثْفكّْ
\m زِي ثمْغَارْثْ ثْبَارَّانشْثْ،
\m زِي ثمْغَارْثْ زِي بَارَّا إِ إِتّْغَارَّانْ س
\m وَاوَاڒنْ نّسْ، \x ◘ \xo 2:‏16 \xt أَوڒن. 5‏:‏3؛ 6‏:‏24؛ 7‏:‏5\x*
\m 
\v 17 ثنِّي إِسمْحنْ
\m ذڭْ ؤُمدُّوكّڒْ ن ثمْژِي نّسْ،
\m ؤُ ثتُّو ڒْعَاهْذْ ن أَربِّي نّسْ.
\m 
\v 18 مِينْزِي ثْهكّْوَا غَارْ ڒْموْثْ
\m \add جْمِيعْ\add* أَكْ-ذ ثَادَّارْثْ نّسْ،
\m ؤُ ڒَاثَارَاثْ نّسْ \add هكّْوَانْثْ\add*
\m غَارْ ڒخْيَاڒَاثْ \add ن إِمتَّانْ\add*.
\m 
\v 19 مَارَّا إِنِّي غَارسْ غَا يَاذْفنْ،
\m وَارْ د-تّْعِيقِّيبنْعمَّارْصْ،
\m وَارْ تَّاكّْوَاضنْعمَّارْصْ
\m غَارْ إِمسْرَاقْ ن ثُوذَارْثْ.
\b
\m 
\v 20 ... \add وَاهْ،\add* حِيمَا أَذْ ثُويُورذْ
\m أَبْرِيذْ ن إِصبْحَاننْ،
\m ؤُ أَذْ ثطّْفذْ
\m ذڭْ إِمسْرَاقْ ن إِمْسڭَّاذنْ،
\m 
\v 21 مَاغَارْ إِنِّي إِڭُّورنْ نِيشَانْ
\m أَذْ زذْغنْ ذِي ثمُّورْثْ،
\m ؤُ إِنِّي إِڭُّورنْ س ڒكْمَارثْ
\m أَذْ ذَايسْ قِّيمنْ. \x ◘ \xo 2:‏21 \xt إِزهد. 37‏:‏29\x*
\m 
\v 22 \add مَاشَا\add* إِعفَّاننْ
\m أَذْ تّْوَاقضْعنْ زِي ثمُّورْثْ،
\m إِغدَّارنْ أَذْ زَّايسْ تّْوَاقڒْعنْ. \x ◘ \xo 2:‏22 \xt أَيُوبْ 18‏:‏17؛ إِزهد. 104‏:‏35\x*
\b
\b
\c 3
\m 
\v 1 مِّي إِنُو، وَارْ تّتُّو
\m \add ثَاغُورِي\add* إِنُو ن شَّارِيعَا،
\m أجّْ ؤُڒْ نّشْ أَذْ إِحْضَا ثِيوصَّا إِنُو،
\m 
\v 2 مَاغَارْ نِيثنْثِي أَذْ أَشْ د-إِوْينْثْ
\m أَطَّاسْ ن وُوسَّانْ،
\m ؤُڒَا ذ إِسڭّْوُوسَا ن ثُوذَارْثْ ذ ڒهْنَا. \x ◘ \xo 3:‏2 \xt أَعَوذ. 8‏:‏1؛ 30‏:‏20\x*
\m 
\v 3 ثَامخْسِيوْثْ إِشوَّارنْ ذ ڒَامَانْ
\m وَارْ ثنْ ثجِّيذْ أَذْ زَّايكْ فّْغنْ،
\m قّنْ إِ-ثنْ غَارْ يِيرِي نّشْ،
\m أَرِي ثنْ خْ ثڒْوِيحْثْ ن وُوڒْ نّشْ، \x ◘ \xo 3:‏3 \xt ؤُف. 13‏:‏9؛ أَعَوذ. 6‏:‏8\x*
\m 
\v 4 \add خنِّي\add* أَذْ ثَافذْ أَرْضَا
\m ذ ڒفْهَامثْ إِصبْحنْ
\m ذِي ثِيطَّاوِينْ ن أَربِّي ؤُ ن بْنَاذمْ.
\m 
\v 5 ثِيقّْ ذِي سِيذِي س وُوڒْ نّشْ كُوڒْشِي،
\m وَارْ تّْشَاڒَا خْ ڒفْهَامثْ \add ن يِيخفْ\add* نّشْ.
\m 
\v 6 سّنْ إِ-ث ذِي مَارَّا إِبْرِيذنْ نّشْ،
\m \add خنِّي\add* نتَّا أَذْ إِسڭّمْ إِمسْرَاقْ نّشْ. \x ◘ \xo 3:‏6 \xt 1 إِم. 28‏:‏9\x*
\m 
\v 7 وَارْ تّڭّْ إِخفْ نّشْ ذ أَمِيغِيسْ.
\m ڭّْوذْ سِيذِي ؤُ بعّذْ
\m خْ مِينْ إِدْجَانْ ذ أَعفَّانْ. \x ◘ \xo 3:‏7 \xt رُوم. 12‏:‏16\x*
\m 
\v 8 أَيَا أَذْ يِيڒِي ذ أَڭنْفُو
\m إِ إِژوْرَانْ \add ن ثُوذَارْثْ\add* نّشْ،
\m ذ ونْعَاشْ إِ إِغْسَانْ نّشْ.
\m 
\v 9 وقَّارْ سِيذِي س وَاڭْڒَا نّشْ،
\m س ثْمزْوَارُوثْ ن مَارَّا صَّابثْ نّشْ. \x ◘ \xo 3:‏9 \xt ؤُف. 23‏:‏19؛ 34‏:‏26؛ أَعَوذ. 26‏:‏2‏-‏11؛ مـَال. 3‏:‏10؛ لك. 14‏:‏13\x*
\m 
\v 10 \add خنِّي\add* أَذْ تّْوَاشُّورنْ
\m ڒهْرِيثْ نّشْ س ؤُفيّضْ،
\m ؤُ ثِيسِيرِينْ نّشْ \add ن ؤُضِيڒْ\add*
\m أَذْ دُّوقّْزنْ س بِينُو ن جْذِيذْ. \x ◘ \xo 3:‏10 \xt أَعَوذ. 28‏:‏8\x*
\b
\m 
\v 11 مِّي إِنُو، وَارْ نطَّارْ تَّارْبِييّثْ ن سِيذِي،
\m وَارْ تَّارَّا أَعْرُورْ خْ ؤُوبّخْ نّسْ، \x ◘ \xo 3:‏11 \xt أَيُوبْ 5‏:‏17؛ عبر. 12‏:‏5\x*
\m 
\v 12 مَاغَارْ ونِّي إِسّْعِيزَّا سِيذِي،
\m أَذْ ث إِعَاقبْ عَاوذْ،
\m أَمْ إِتّڭّْ بَابَاسْ أَكْ-ذ مِّيسْ
\m ونِّي خْ يَارْضَا. \x ◘ \xo 3:‏12 \xt أَسَا. 3‏:‏19\x*
\b
\m 
\v 13 سّعْذْ ن بْنَاذمْ نِّي إِتَّافنْ ثِيغِيثْ،
\m ؤُڒَا ذ بْنَاذمْ نِّي إِتّْكسَّابنْ ڒفْهَامثْ،
\m 
\v 14 مَاغَارْ مِينْ ثتَّاوِي نتَّاثْ،
\m ثحْڒَا خْ ثْسبَّابْثْ ذِي نُّوقَارْثْ،
\m ؤُ ڒْغِيدْجثْ نّسْ \add ثحْڒَا\add* خْ وُورغْ إِتِّيسِّيقنْ. \x ◘ \xo 3:‏14 \xt أَيُوبْ 28‏:‏15؛ إِزهد. 19‏:‏11؛ أَوڒن. 8‏:‏11، 19؛ 16‏:‏16\x*
\m 
\v 15 نتَّاثْ ثِيغْڒَا خْ ڒْمَارْجَانْ،
\m ؤُ مَارَّا مِينْ ذِي \add ثْزمَّارذْ\add*
\m أَذْ ثمّژْرذْ،
\m وَارْ إِزمَّارْ أَكِيذسْ إِتّمْقُودَّا. \x ◘ \xo 3:‏15 \xt أَوڒن. 8‏:‏11\x*
\m 
\v 16 ثُوزّڭَّارْثْ ن وُوسَّانْ \add غَارسْ\add*
\m ذڭْ ؤُفُوسْ نّسْ،
\m أَڭْڒَا ذ شَّانْ أَقَا أَثنْ خْ ؤُزڒْمَاضْ نّسْ.
\m 
\v 17 إِبْرِيذنْ نّسْ ذ إِبْرِيذنْ ن ڒضْرَافثْ،
\m ؤُ مَارَّا إِمسْرَاقْ نّسْ أَقَا أَثنْ ذ ڒهْنَا.
\m 
\v 18 نتَّاثْ ذ ثَاشجَّارْثْ ن ثُوذَارْثْ
\m إِ يِينِّي غَارسْ إِڒسْقنْ،
\m كُوڒْ إِجّنْ ونِّي ذَايسْ إِتّطّْفنْ،
\m أَذْ يِيڒِي ذ أَمسْعُوذْ. \f ◼ \fr 3:‏18 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*
\b
\m 
\v 19 سِيذِي إِڭَّا ذْسَاسْ ن ثمُّورْثْ س ثِيغِيثْ نّسْ،
\m س ڒفْهَامثْ نّسْ إِڭَّا إِجنْوَانْ.
\m 
\v 20 زِي ثُوسّْنَا نّسْ دُّوقّْزنْ-د
\m \add وَامَانْ\add* إِهوْڒنْ،
\m تّْنشْنِيشنْ-د إِسيْنُوثنْ نّْذَا. \x ◘ \xo 3:‏20 \xt أَمز. 1‏:‏9، 10\x*
\m 
\v 21 مِّي إِنُو، وَارْ ثنْثْ ثجِّيذْ
\m أَذْ فّْغنْثْ زِي ثِيطَّاوِينْ نّشْ،
\m حْضَا أَفْثَانْ ذ ؤُحَاضُورْ، \f ◼ \fr 3:‏21 \fk ثنْثْ\ft - أَوَاڒْ-أَ إِشيَّارْ غَارْ ثِيغِيثْ ذ ڒفْهَامثْ إِ خْ إِسَّاوَاڒْ ؤُمْسڒْمَاذْ ن ثِيغِيثْ ذِي أَيثْ 13 ن وُوذمْ-أَ.\f*
\m 
\v 22 \add مَاغَارْ\add* أَذْ إِڒِينْ ذ ثُوذَارْثْ إِ ڒعْمَارْ نّشْ
\m ؤُڒَا ذ أَرْضَا إِ يِيرِي نّشْ.
\m 
\v 23 خنِّي أَذْ ثُويُورذْ أَبْرِيذْ نّشْ ذِي ڒَامَانْ،
\m وَارْ ثتّْنقْرِيضذْ ذڭْ ؤُضَارْ نّشْ. \x ◘ \xo 3:‏23 \xt إِزهد. 37‏:‏24؛ 91‏:‏11، 12\x*
\m 
\v 24 مَاڒَا ثْرُوحذْ أَذْ ثزّْڒذْ،
\m وَارْ ثنّْخڒْعِيذْ،
\m ؤُ \add خْمِي\add* إِ غَا ثزّْڒذْ، أَذْ يِيژِيذْ يِيضصْ نّشْ. \x ◘ \xo 3:‏24 \xt لَاوِي 6‏:‏19؛ أَيُوبْ 11‏:‏19؛ إِزهد. 3‏:‏6؛ 4‏:‏9؛ 91‏:‏5، 6\x*
\m 
\v 25 وَارْ تّڭّْوذْ زڭْ ؤُنخْڒِيعْ ن ذغْيَا
\m ؤُڒَا زڭْ وَاريّبْ س \add ؤُفُوسْ\add* ن إِعفَّاننْ
\m خْمِي د غَا يَاسْ. \x ◘ \xo 3:‏25 \xt أَيُوبْ 5‏:‏21\x*
\m 
\v 26 مَاغَارْ سِيذِي أَذْ أَشْ يِيڒِي ذ أَسنّذْ نّشْ،
\m نتَّا أَذْ إِحْضَا أَفُوسْ نّشْ زِي ثْسَارِّيفْثْ.
\b
\m 
\v 27 وَارْ قطّعْ ڒْخَارْ خْ بَابْ نّسْ،
\m مَاڒَا أَقَا-ث ذڭْ ؤُفُوسْ نّشْ
\m مَاحنْذْ أَذْ ثڭّذْ \add ڒْخَارْ\add*.
\m 
\v 28 وَارْ قَّارْ إِ جَّارْ نّشْ:
\m ’رُوحْ ؤُشَا عْقبْ-د،
\m ثِيوشَّا أَذْ \add أَشْ ت\add* وْشغْ!‘،
\m مَاڒَا \add ثَامسْڒَاشْثْ\add* أَقَا-ت أَكِيذكْ.
\m 
\v 29 وَارْ نكّْوِي ڒْغَارْ أَكْ-ذ جَّارْ نّشْ،
\m ؤُمِي أَكِيذكْ إِزدّغْ ذِي ڒَامَانْ.
\m 
\v 30 وَارْ ثمْشُوبُّوشْ
\m أَكْ-ذ إِجّْ ن بْنَاذمْ بْڒَا سِّيبّثْ،
\m مَاڒَا نتَّا وَارْ ذ أَشْ إِڭِّي ڒْغَارْ.
\m 
\v 31 وَارْ تَّاسمْ زڭْ إِجّْ ن بُو-ڒخْشُونثْ،
\m حْضَا مَاحنْذْ وَارْ ثتِّيخْضَارذْ
\m ؤُڒَا \add ذ إِجّْ\add* زِي مَارَّا إِبْرِيذنْ نّسْ. \x ◘ \xo 3:‏31 \xt إِزهد. 37‏:‏1؛ 73‏:‏3؛ أَوڒن. 23‏:‏17\x*
\m 
\v 32 مَاغَارْ ونِّي إِتّفّْغنْ زڭْ وبْرِيذْ،
\m أَقَا-ث ذ نّْعِي إِ سِيذِي،
\m \add مَاشَا\add* \add نتَّا إِتّڭّْ\add* ڒَامَانْ نّسْ
\m ذڭْ إِنِّي إِڭُّورنْ نِيشَانْ. \x ◘ \xo 3:‏32 \xt إِزهد. 25‏:‏14\x*
\m 
\v 33 نّعْڒثْ ن سِيذِي
\m \add أَقَا-ت\add* خْ ثَادَّارْثْ ن ؤُعفَّانْ،
\m \add مَاشَا\add* ثَازذِّيغْثْ ن إِمْسڭَّاذنْ
\m أَذْ ت إِبَاركْ. \x ◘ \xo 3:‏33 \xt لَاوِي 26‏:‏14‏-‏45؛ أَعَوذ. 28‏:‏15‏-‏68؛ مـَال. 2‏:‏2\x*
\m 
\v 34 مَاڒَا ذ إِمسْثهْزَاينْ،
\m أَذْ \add زَّايْسنْ\add* إِسّْثهْزَا نتَّا،
\m \add مَاشَا مَاڒَا\add* ذ إِنِّي إِتّْوَاحْصَارنْ،
\m أَذْ \add أَسنْ\add* إِسْشنْ أَرْضَا نّسْ. \x ◘ \xo 3:‏34 \xt يَاع. 4‏:‏6؛ 1 بُط. 5‏:‏5\x*
\m 
\v 35 إِمِيغِيسنْ أَذْ وَارْثنْ شَّانْ،
\m \add مَاشَا\add* إِبُوهَاڒِييّنْ
\m أَذْ سَّارْبُونْ ڒفْضِيحثْ خْ يِيخفْ نْسنْ.
\b
\b
\c 4
\m 
\v 1 سْڒمْ، كنِّيوْ إِحنْجِيرنْ،
\m غَارْ تَّارْبِييّثْ ن بَابَا\add ثْومْ\add*،
\m حكَّارمْ مْلِيحْ
\m مَاحنْذْ أَذْ ثكْسِيمْ ثُوسّْنَا س ڒفْهَامثْ،
\m 
\v 2 مَاغَارْ نشّْ أَذْ أَومْ وْشغْ
\m ثَاغُورِي إِصبْحنْ،
\m وَارْ سمّْحمْ ذِي ثْغُورِي إِنُو.
\m 
\v 3 مَاغَارْ نشّْ ثُوغَا أَيِي ذ مِّيسْ إِ بَابَا،
\m أَرقَّاغْ ذ أَينِّي ن \add مِّيسْ\add*
\m زَّاثْ إِ وُوذمْ ن يمَّا. \x ◘ \xo 4:‏3 \xt 1 إِم. 29‏:‏1\x*
\m 
\v 4 نتَّا إِسّڒْمذْ أَيِي، إِنَّا أَيِي:
\m ”أجّْ ؤُڒْ نّشْ أَذْ إِطّفْ ذڭْ وَاوَاڒنْ إِنُو،
\m حْضَا ثِيوصَّا إِنُو، \add خنِّي\add* أَذْ ثدَّارذْ!“ \x ◘ \xo 4:‏4 \xt 1 إِم. 28‏:‏9\x*
\m 
\v 5 جْبذْ-د غَاركْ ثِيغِيثْ،
\m جْبذْ-د غَاركْ ڒعْقڒْ،
\m وَارْ ثتُّو ؤُ وَارْ ثْحيِّيذْ
\m خْ وَاوَاڒنْ ن ؤُقمُّومْ إِنُو.
\m 
\v 6 وَارْ سمّحْ \add ذِي ثِيغِيثْ\add*،
\m \add خنِّي\add* نتَّاثْ أَذْ شكْ ثحْضَا،
\m سْعِيزّْ إِ-ت ؤُ نتَّاثْ أَذْ شكْ ثسَّارْ. \f ◼ \fr 4:‏6 \ft \bd ’وَارْ سمّحْ \bdit ذِي ثِيغِيثْ\bdit*‘\bd* - س ثْعِيبْرَانِيثْ ’وَارْ سمّحْ ذَايسْ‘.\f*
\m 
\v 7 بدُّو ن ثِيغِيثْ ذ ؤُضُوفْ ن ثِيغِيثْ،
\m طّفْ ڒفْهَامثْ س مَارَّا مِينْ غَاركْ. \x ◘ \xo 4:‏7 \xt أَوڒن. 23‏:‏23\x*
\m 
\v 8 سْڭعّذْ إِ-ت-إِ-د،
\m خنِّي نتَّاثْ أَذْ شكْ ثسّْڭعّذْ،
\m نتَّاثْ أَذْ أَشْ ثڭّْ شَّانْ مَاڒَا ثْذَارّْعذْ أَسْ.
\m 
\v 9 نتَّاثْ أَذْ أَشْ ثوْشْ إِجّْ ن تَّاجْ ثشْنَا
\m خْ ؤُزدْجِيفْ نّشْ،
\m أَذْ أَشْ ثوْشْ إِجّْ ن تَّاجْ إِزوّْقنْ. \x ◘ \xo 4:‏9 \xt أَوڒن. 1‏:‏19\x*
\b
\m 
\v 10 سڒْ، \add أَ\add* مِّي، ؤُ كْسِي أَوَاڒنْ إِنُو،
\m \add خنِّي\add* أَذْ مَّارْنِينْ
\m إِسڭّْوُوسَا ن ثُوذَارْثْ نّشْ.
\m 
\v 11 سّْڒمْذغْ أَشْ أَبْرِيذْ ن ثِيغِيثْ،
\m نذْهغْ شكْ ذِي ڒَاثَارَاثْ إِسڭّْمنْ.
\m 
\v 12 مَاڒَا ثُويُورذْ، أَصُورِيفْ نّشْ
\m وَارْ إِتّْنحْصَّارْ،
\m مَاڒَا ثَازّْڒذْ، وَارْ تّْنقْرِيضذْ.\x ◘ \xo 4:‏12 \xt إِزهد. 91‏:‏11\x*
\m 
\v 13 شبَّارْ ذِي تَّارْبِييّثْ،
\m وَارْ \add خَاسْ\add* ثمّْسبْضَا،
\m حْضَا ت، مَاغَارْ نتَّاثْ ذ ثُوذَارْثْ نّشْ.
\m 
\v 14 وَارْ ڭُّورْ خْ ؤُمسْرُوقْ ن إِعفَّاننْ،
\m وَارْ تِّيذِيفْ أَبْرِيذْ ن يِينِّي إِتّڭّنْ ڒْغَارْ، \x ◘ \xo 4:‏14 \xt إِزهد. 1‏:‏1؛ أَوڒن. 1‏:‏10، 15\x*
\m 
\v 15 حيّذْ خَاسْ، وَارْ خَاسْ ڭُّورْ،
\m فّغْ زَّايسْ ؤُ أَذْ ثكّذْ خَاسْ.
\m 
\v 16 مَاغَارْ نِيثْنِي وَارْ تّطّْصنْ
\m أَمْ وَارْ \add زمَّارنْ\add* أَذْ ڭّنْ ثُوعفّْنَا،
\m إِتّْرَاحْ أَسنْ إِضصْ نْسنْ
\m مَاڒَا وَارْ سّْنقْرِيضنْ حذْ \add عَاذْ\add*،
\m 
\v 17 مَاغَارْ نِيثْنِي تّتّنْ أَغْرُومْ ن ڒْغشّْ،
\m ؤُ نِيثْنِي سسّنْ بِينُو زِي ثْمڭَّا ن ڒخْشُونثْ.
\b
\m 
\v 18 أَمسْرُوقْ ن إِمْسڭَّاذنْ
\m أَمْ ثْفَاوْثْ إِتِّيسِّيقنْ ن ثفُّوثْ،
\m ثنِّي ثَارنِّي ذڭْ ؤُسقْسقْ
\m أَڒْ إِمْغَارْ وَاسّْ قَاعْ.
\m 
\v 19 أَبْرِيذْ ن إِعفَّاننْ أَمْ ثَادْجسْثْ،
\m نِيثْنِي وَارْ سِّيننْ مِينْ ذِي إِ غَا نْقَارْضنْ.
\m 
\v 20 مِّي إِنُو، أوْشْ ثَايْنِيثْ إِ وَاوَاڒنْ إِنُو،
\m أوْشْ أَمزُّوغْ نّشْ إِ وَاوَاڒنْ إِنُو،
\m 
\v 21 وَارْ ثنْ تّجِّي أَذْغفْڒنْ
\m زِي ثِيطَّاوِينْ نّشْ،
\m خمّڒْ إِ-ثنْ ذَاخڒْ ذڭْ وُوڒْ نّشْ،
\m 
\v 22 مَاغَارْ نِيثْنِي ذ ثُوذَارْثْ
\m إِ يِينِّي ثنْ إِ غَا يَافنْ،
\m ؤُڒَا ذ أَڭنْفُو إِ أَرِّيمثْ نْسنْ مَارَّا. \x ◘ \xo 4:‏22 \xt أَوڒن. 4‏:‏13\x*
\b
\m 
\v 23 حْضَا ؤُڒْ نّشْ خْ مَارَّا
\m مِينْ إِزمَّارْ أَذْ إِتّْوَاحْضَا،
\m مَاغَارْ زَّايسْ فّْغنْ إِژوْرَانْ ن ثُوذَارْثْ.
\m 
\v 24 كّسْ إِخَارِّيقنْ ن ؤُقمُّومْ نّشْ،
\m سْبعّذْ خَاكْ أَفَارْيضْ ن إِينْشِيشنْ نّشْ.
\m 
\v 25 أجّْ ثِيطَّاوِينْ نّشْ أَذْ خْزَارنْثْ غَارْ زَّاثْ،
\m \add أجّْ\add* أَبْڒِيونْ نّشْ أَذْ خْزَارنْ
\m غَارْ \add مِينْ إِدْجَانْ\add* أَرنْذَاذْ نّشْ.
\m 
\v 26 وَاطَا ڒَاثَارْ ن ؤُضَارْ نّشْ،
\m أجّْ أَذْ إِڒِينْ مَارَّا إِبْرِيذنْ نّشْ سَارّْحنْ.
\m 
\v 27 وَارْ فَارّغْ \add غَارْ\add* يفُوسْ ؤُڒَا \add غَارْ\add* ؤُزڒْمَاضْ،
\m سْبعّذْ أَضَارْ نّشْ زِي ثُوعفّْنَا. \x ◘ \xo 4:‏27 \xt أَعَوذ. 5‏:‏32؛ 28‏:‏14\x*
\b
\b
\c 5
\s1 أَغكّْوِي زِي ثمْغَارْثْ ثَابَارَّانِيثْ
\m 
\v 1 مِّي إِنُو، أوْشْ ثَايْنِيثْ إِ ثِيغِيثْ إِنُو،
\m أوْشْ أَمزُّوغْ إِ ڒفْهَامثْ إِنُو،
\m 
\v 2 مَاحنْذْ أَذْ ثوْشذْ حَاضُورْ،
\m ؤُ إِينْشِيشنْ نّشْ أَذْ حْضَانْ خْ ثُوسّْنَا.
\m 
\v 3 مِينْزِي إِينْشِيشنْ ن ثمْغَارْثْ ثَابَارَّانِيثْ
\m تُّوذُومنْ س ثَامّنْثْ ن ثغْرَاصْثْ،
\m أَنغْ نّسْ ذ أَڒقَّاغْ خْ زّشْثْ، \x ◘ \xo 5:‏3 \xt أَوڒن. 2‏:‏16؛ 6‏:‏24\x*
\m 
\v 4 مَاشَا غَارْ ؤُنڭَّارْ
\m \add أَقَا-ت\add* ذ ثَامرْزَاڭْثْ أَمْ شِّيحْ،
\m ثقْضعْ أَمْ يِيجّْ ن سِّيفْ
\m س \add ثْنَاينْ ن\add* وُوذْمَاونْ.
\m 
\v 5 إِضَارنْ نّسْ تَّاوْينْ غَارْ ڒْموْثْ،
\m إِصُورَافْ نّسْ ندّْهنْ غَارْ ڒَاخَارْثْ. \x ◘ \xo 5:‏5 \xt أَوڒن. 7‏:‏27\x*
\m 
\v 6 أَڒَامِي وَارْ ثطِّيفذْ \add عمَّارْصْ\add*
\m أَبْرِيذْ ن ثُوذَارْثْ،
\m ڭُّورنْثْ ڒَاثَارَاثْ \add ن إِضَارنْ\add* نّسْ
\m سَّا ذ سَّا بْڒَا مَا ثسّْنذْ شكْ.
\b
\m 
\v 7 خنِّي ڒخُّو، \add أَ\add* إِحنْجِيرنْ، سْڒمْ-د غَارِي،
\m وَارْ ثْحيَّاذمْ شَا
\m خْ وَاوَاڒنْ ن ؤُقمُّومْ إِنُو.
\m 
\v 8 سِيڭّْوجْ أَبْرِيذْ نّشْ خَاسْ،
\m وَارْ تَّاذسْ ثَاوَّارْثْ ن ثَادَّارْثْ نّسْ،
\m 
\v 9 حِيمَا وَارْ ثتِّيشذْ شَّانْ نّشْ إِ إِنّغْنِي،
\m إِسڭّْوُوسَا نّشْ إِ ونِّي إِتّقْسِيحنْ أَطَّاسْ، \x ◘ \xo 5:‏9 \xt أَوڒن. 6‏:‏34، 35\x*
\m 
\v 10 حِيمَا إِبَارَّانِييّنْ
\m وَارْ تّْجَاوَاننْ ذڭْ وَاڭْڒَا نّشْ،
\m ؤُ مَارَّا \add ڒْْغِيدْجثْ ن\add* ؤُمَارّثْ نّشْ
\m وَارْ د-ثتِّيسْ ذِي ثَادَّارْثْ
\m ن ونِّي وَارْ إِتّْوِيسّْننْ،
\m 
\v 11 ؤُ أَذْ ثْزهَّارذْ غَارْ ؤُنڭَّارْ،
\m خْمِي غَا ثتّْوَاشّْ أَرِّيمثْ نّشْ
\m ذ ويْسُومْ نّشْ،
\m 
\v 12 أَذْ ثِينِيذْ: ”مَامّشْ ڭِّيغْ نشّْ
\m شَارْهغْ تَّارْبِييّثْ،
\m \add مَامّشْ\add* إِنْضَارْ ؤُڒْ إِنُو أَوبّخْ؟
\m 
\v 13 \add مَامّشْ\add* وَارْ سْڒِيغْ غَارْ ثْمِيجَّا
\m ن يِينِّي ذ أَيِي إِذَارّْبنْ،
\m وَارْ وْشِيغْ أَمزُّوغْ إِنُو
\m إِ إِمْسڒْمَاذنْ إِنُو؟
\m 
\v 14 عْڒَاحَاڒْ ثُوغَا ؤُفِيغْ إِخفْ إِنُو
\m ذِي عْڒَامْ كُوڒْ ڒْغَارْ،
\m ذِي ڒْوسْطْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add* ؤُ ن ثْمسْمُونْثْ!“
\m 
\v 15 سُووْ أَمَانْ زڭْ وَانُو نّشْ،
\m ؤُڒَا ذ أَمَانْ إِسِّيزّْڒنْ
\m زِي ڒَادْجَاغْ ن ڒْعُونْصَارْ نّشْ.
\m 
\v 16 إِڒِي أَذْ سّفْينْ وَامَانْ
\m \add ن ڒْعُونْصَارْ\add* نّشْ بَارَّا،
\m \add أَمْ\add* ثْغزْرَاثِينْ ن وَامَانْ خْ إِبْرِيذنْ.
\m 
\v 17 أجّْ إِ-ثنْ أَذْ إِڒِينْ إِ شكْ وحّْذكْ،
\m وَارْ إِدْجِي إِ إِبَارَّانِييّنْ إِ ذِينْ زَّاثكْ.
\m 
\v 18 أَذْ إِتّْوَابَاركْ ڒْعُونْصَارْ نّشْ،
\m فَارْحْ إِ ثمْغَارْثْ \add زڭْ وُوسَّانْ\add* ن ثمْژِي نّشْ.
\m 
\v 19 ثُوذَاذْثْ إِعِيزّنْ ؤُڒَا ذ ثِيغيْذثْ ن وزْغَارْ
\m إِشوَّارنْ \add نتَّاثْ\add*!
\m أجّْ إِبَّاشْ نّسْ أَذْ شكْ سّْيِيوْينْ
\m ذِي مَارَّا ؤُسَّانْ،
\m سلّمْ إِخفْ نّشْ ڒبْذَا غَارْ ثَايْرِي نّسْ!
\m 
\v 20 مَايمِّي، \add أَ\add* مِّي،
\m أَذْ شكْ ثغْوَا ثمْغَارْثْ ثَابَارَّانشْثْ،
\m أَذْ ثْذَارّْعذْ إِ وحْسِينْ ن ثمْغَارْثْ
\m وَارْ ثسِّينذْ؟
\m 
\v 21 مَاغَارْ إِبْرِيذنْ ن بْنَاذمْ
\m أَقَا أَثنْ \add ذِينْ\add* زَّاثْ إِ ثِيطَّاوِينْ ن سِيذِي،
\m نتَّا يَارْزُو ذِي مَارَّا إِمسْرَاقْ نّسْ. \x ◘ \xo 5:‏21 \xt 2 إِم. 16‏:‏9؛ أَيُوبْ 31‏:‏4؛ 34‏:‏21؛ أَوڒن. 15‏:‏3؛ إِرْم. 16‏:‏17؛ 32‏:‏19\x*
\m 
\v 22 ڒْمُوعْسِييّثْ \add ن يِيخفْ\add* نّسْ
\m أَذْ ثْحبّسْ أَعفَّانْ،
\m س إِسغْوَانْ ن دّْنُوبْ نّسْ أَذْ إِتّْوَاشدّْ.
\m 
\v 23 نتَّا أَذْ إِمّثْ
\m ؤُمِي وَارْ ذِينْ ثُوغِي تَّارْبِييّثْ،
\m أَذْ إِودَّارْ
\m س ثُوبُّوهڒْيَا نّسْ ثَامقّْرَانْثْ.
\b
\b
\c 6
\m 
\v 1 مِّي إِنُو، مَاڒَا ثْذوْڒذْ
\m ذ أَمَارْهُونْ إِ جَّارْ نّشْ،
\m ثوْشِيذْ ثِيشْثِي نّشْ ن ؤُفُوسْ إِ يِيجّْ ن ؤُبَارَّانِي،
\m 
\v 2 \add مَاڒَا\add* ثْذوْڒذْ ثقّْنذْ
\m زڭْ وَاوَاڒنْ ن ؤُقمُّومْ نّشْ،
\m ثتّْوَاحبّْسذْ زڭْ وَاوَاڒنْ
\m ن ؤُقمُّومْ نّشْ،
\m 
\v 3 \add خنِّي\add* أڭّْ ثَا، \add أَ\add* مِّي، ؤُ فكّْ إِخفْ نّشْ،
\m مَاغَارْ ثْذوْڒذْ غَارْ ؤُفُوسْ ن جَّارْ نّشْ:
\m ؤُيُورْ، بنْذقْ \add خَاسْ\add*
\m ؤُ زيَّارْ خْ ونِّي شكْ يُوذْسنْ.
\m 
\v 4 وَارْ تِّيشْ شَا إِضصْ إِ ثِيطَّاوِينْ نّشْ،
\m ؤُڒَا ذ أَنُوذمْ إِ وَابْڒِيونْ نّشْ. \x ◘ \xo 6:‏4 \xt إِزهد. 132‏:‏4\x*
\m 
\v 5 فكّْ إِخفْ نّشْ زڭْ ؤُفُوسْ \add نّسْ\add*
\m أَمْ ثْغيْضثْ ن وغْزَارْ،
\m أَمْ يِيجّْ ن وجْضِيضْ زڭْ ؤُفُوسْ ن ؤُنڭْمَارْ.
\b
\m 
\v 6 ؤُيُورْ غَارْ ثْكضْفثْ، \add شكْ، أَ\add* أَمعْڭُوزْ،
\m خْزَارْ مَامّشْ ثُويُورْ نتَّاثْ
\m ؤُ ذْوڒْ ذ أَمِيغِيسْ.
\m 
\v 7 وَاخَّا نتَّاثْ وَارْ غَارسْ بُو ؤُمْڭوّذْ،
\m نِيغْ أَوقَّافْ نِيغْ ڒْحَاكمْ،
\m 
\v 8 \add عَاذْ\add* ثسّوْجَاذْ أَغْرُومْ نّسْ ذڭْ ؤُنبْذُو،
\m ثيْرُو مَاشَّا نّسْ ذِي ڒْوقْثْ ن ثْميْرَا.
\m 
\v 9 أَڒْ مڒْمِي غَا ثقِّيمذْ ثزّْڒذْ،
\m \add شكْ، أَ\add* أَمعْڭُوزْ؟
\m مڒْمِي غَا ثكَّارذْ زڭْ إِضصْ نّشْ؟ \x ◘ \xo 6:‏9 \xt أَوڒن. 13‏:‏4؛ 20‏:‏4؛ 24‏:‏33، 34\x*
\m 
\v 10 أَرْنِي شْوَايْثْ ن يِيضصْ،
\m أَرْنِي شْوَايْثْ ن ؤُوَارّشْ،
\m أَرْنِي شْوَايْثْ ن ؤُبُوزّڒْ س إِفَاسّنْ إِمُوننْ، \x ◘ \xo 6:‏10 \xt أَوڒن. 24‏:‏33\x*
\m 
\v 11 \add أَقَا ذَا\add* أَذْ خَاكْ د-إِوْضَا زّڒْضْ
\m أَمْ يِيجّْ ن ؤُخوَّانْ،
\m ڒغْبنْ نّشْ أَمْ يِيجّْ ن ورْيَازْ
\m إِ غَارْ إِدْجَا ڒسْنَاحْ. \x ◘ \xo 6:‏11 \xt أَوڒن. 24‏:‏34\x*
\b
\m 
\v 12 بْنَاذمْ إِ وَارْ إِسكّْوِينْ، أَرْيَازْ ن ڒْغشّْ،
\m إِڭُّورْ س إِجّْ ن ؤُقمُّومْ
\m إِشُّورنْ س مِينْ إِعوْجنْ.
\m 
\v 13 إِغمّزْ س ثِيطَّاوِينْ نّسْ،
\m إِسَّاوَاڒْ س إِضَارنْ نّسْ،
\m إِتّْشيَّارْ س إِضوْضَانْ نّسْ.
\m 
\v 14 ؤُڒْ نّسْ \add إِشُّورْ\add* س ڒخْذَاعَاثْ،
\m إِنكّْوَا ڒبْذَا ڒْغَارْ،
\m إِتّْسبَّابْ إِمنْغِييّنْ.
\m 
\v 15 خْ ؤُيَا ذغْيَا أَذْ د-يَاسْ ؤُضيّعْ نّسْ،
\m ذڭْ إِشْثْ ن ثشْثِي أَذْ إِتّْوَارْژْ
\m أَمْ وَارْ ذِينْ إِتِّيڒِي ؤُڭنْفُو.
\b
\m 
\v 16 ستَّا \add ن ثْمسْڒَايِينْ\add*-أَ إِشَارّهْ إِ-ثنْثْ سِيذِي،
\m \add وَاهْ\add* سبْعَا أَقَا أَثنْثْ ذ نّْعِي إِ ڒعْمَارْ نّسْ:
\m 
\v 17 ثِيطَّاوِينْ ن نّْفَاخثْ،
\m إِجّْ ن يِيڒسْ إِسّْخَارِّيقنْ،
\m ؤُڒَا ذ إِفَاسّنْ إِسَّازَّاڒنْ
\m إِذَامّنْ إِمزْذَاڭنْ، \x ◘ \xo 6:‏17 \xt أَوڒن. 30‏:‏13\x*
\m 
\v 18 ؤُڒْ إِنكّْوَانْ ثِيمعْمَاتْشْ إِغشّنْ،
\m إِضَارنْ نِّي إِتّْقدْجِيقنْ مَاحنْذْ أَذْ أَزّْڒنْ
\m غَارْ مِينْ إِدْجَانْ ذ أَعفَّانْ، \x ◘ \xo 6:‏18 \xt رُوم. 3‏:‏15\x*
\m 
\v 19 أَشهَّاذْ إِسّْخَارِّيقنْ
\m نِّي د-إِذدْجْقنْ إِ إِخَارِّيقنْ،
\m ؤُڒَا ونِّي إِتّْسبَّابنْ
\m إِمنْغِييّنْ جَارْ ثَاوْمَاثْ.
\b
\m 
\v 20 \add أَ\add* مِّي، حْضَا ثَاوْصيّثْ ن بَابَاشْ،
\m ؤُ وَارْ منْضَارْ ثَاغُورِي ن يمَّاشْ. \x ◘ \xo 6:‏20 \xt أَوڒن. 1‏:‏8\x*
\m 
\v 21 قّنْ إِ-ثنْثْ ڒبْذَا خْ وُوڒْ نّشْ،
\m شدّْ إِ-ثنْثْ غَارْ يِيرِي نّشْ. \x ◘ \xo 6:‏21 \xt أَوڒن. 3‏:‏3\x*
\m 
\v 22 مَاڒَا ثڭُّورذْ، أَيَا أَذْ شكْ إِڭوّذْ،
\m مَاڒَا ثزّْرذْ، أَيَا أَذْ شكْ إِحْضَا،
\m مَاڒَا ثْفَاقذْ أَقَا مَانْ أَيَا
\m أَذْ كِيذكْ إِسِّيوڒْ. \x ◘ \xo 6:‏22 \xt أَوڒن. 3‏:‏23، 24\x*
\m 
\v 23 مِينْزِي ثَاوْصيّثْ ذ ڒفْنَارْ
\m ذ ثْغُورِي ذ ثْفَاوْثْ،
\m إِوبَّاخْ ن تَّارْبِييّثْ
\m أَقَا أَثنْ ذ أَبْرِيذْ ن ثُوذَارْثْ \x ◘ \xo 6:‏23 \xt إِزهد. 19‏:‏9؛ 119‏:‏105\x*
\m 
\v 24 نِّي شكْ إِ غَا إِحْضَانْ زِي ثمْغَارْثْ ثَاعفَّانْثْ،
\m زِي ڒهْرُوذْ إِزوّْقنْ
\m ن يِيڒسْ ن ثمْغَارْثْ زِي بَارَّا. \x ◘ \xo 6:‏24 \xt أَوڒن. 2‏:‏16؛ 5‏:‏3؛ 7‏:‏5\x*
\b
\m 
\v 25 وَارْعشّقْ شَا أَژْرِي نّسْ ذڭْ وُوڒْ نّشْ،
\m حْضَا وَارْ شكْ ثحْصِيرْ س وَابْڒِيونْ نّسْ،
\m 
\v 26 مِينْزِي زِي سِّيبّثْ
\m ن إِشْثْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ،
\m \add بْنَاذمْ أَذْ إِكْسِي\add*
\m \add مْغِيرْ\add* إِشْثْ ن ثْخبَّازْثْ ن وغْرُومْ،
\m \add وَاهْ،\add* ثَامْغَارْثْ ن إِجّْ ن ورْيَازْ نّغْنِي
\m أَقَا ثَارزُّو ڒعْمَارْ إِغْڒَانْ.
\m 
\v 27 مَا إِزمَّارْ حذْ أَذْ يَارْبُو ثِيمسِّي
\m ذڭْ وحْسِينْ ن وَارُّوضْ نّسْ،
\m بْڒَا مَا أَذْ يَارْغْ وَارُّوضْ نّسْ؟ \f ◼ \fr 6:‏27 \ft \bd ’أَحْسِينْ‘\bd* - نِيغْ ’أَبحْرُورْ‘.\f*
\m 
\v 28 مَا إِزمَّارْ حذْ
\m أَذْ يُويُورْ خْ ڒفْحمْ \add إِتّحْذُوذُوقنْ\add*،
\m بْڒَا مَا أَذْ شمْضنْ إِضَارنْ نّسْ؟
\m 
\v 29 أَمُّو \add ؤُڒَا ذ\add* ونِّي إِ غَا يَاذْفنْ
\m غَارْ ثمْغَارْثْ ن جَّارْ نّسْ،
\m \add وَاهْ\add* كُوڒْ إِجّنْ ونِّي ت إِ غَا إِهَاذَانْ،
\m وَارْ إِتّْوِيحْسِيبْ ذ أَمزْذَاڭْ.
\m 
\v 30 أَشفَّارْ وَارْ ث سّْحقَّارنْ
\m مَاڒَا يُوشَارْ،
\m حِيمَا أَذْ إِسّْيِيونْ ڒعْمَارْ نّسْ
\m مَاڒَا ذَايسْ ڒَاژْ.
\m 
\v 31 \add مَاشَا\add* مَاڒَا إِتّْوَافْ،
\m أَمُّو خَاسْ إِ غَا إِخدْجصْ سبْعَا ن ثْسقَّارْ.
\m إِتّْخصَّا أَسْ أَذْ إِوْشْ
\m مَارَّا مِينْ غَارسْ ذِي ثَادَّارْثْ.\x ◘ \xo 6:‏31 \xt ؤُف. 22‏:‏1، 4\x*
\m 
\v 32 \add مَاشَا\add* ونِّي إِتّڭّنْ زِّينَا
\m أَكْ-ذ إِشْثْ ن ثمْغَارْثْ،
\m وَارْ غَارسْ بُو وُوڒْ إِمْثنْ.
\m ونِّي إِتّڭّنْ أَيَا،
\m إِتَّاردّدْجْ ڒعْمَارْ نّسْ.
\m 
\v 33 ذْرُوشْثْ ذ ڒفْضِيحثْ أَذْ ثنْ يَافْ،
\m ڒحْيَا نّسْ وَارْ إِمحِّي شَا.
\m 
\v 34 مَاغَارْ ثُوسْمِي \add ثتَّاوِي-د\add* أَسْعَارْ ن ورْيَازْ،
\m نتَّا وَارْ إِتّسّنْ أَحِينِّي
\m ذڭْ وَاسّْ ن ونْثَاقمْ.
\m 
\v 35 وَارْ إِحسّبْ دّيّثْ إِ وصْڒحْ،
\m وَارْ ت إِقبّڒْ، أَذْ يُوڭِي،
\m وَاخَّا ثسّمْغَارِيذْ
\m ذِي ثرْزفْثْ عَاذْ س وَاطَّاسْ.
\b
\b
\c 7
\s1 ثَامْغَارْثْ إِسّْغكّْوَانْ ذ ؤُحُوذْرِي
\m 
\v 1 مِّي إِنُو، حْضَا أَوَاڒنْ إِنُو،
\m خمّڒْ ثِيوصَّا إِنُو غَاركْ.
\m 
\v 2 حْضَا ثِيوصَّا إِنُو
\m ؤُ شكْ أَذْ ثقِّيمذْ ثدَّارذْ،
\m \add حْضَا\add* ثَاغُورِي إِنُو أَمْ مُومُّو ن ثِيطّْ نّشْ. \x ◘ \xo 7:‏2 \xt لَاوِي 18‏:‏5؛ أَوڒن. 4‏:‏4\x*
\m 
\v 3 قّنْ إِ-ثنْثْ غَارْ إِضوْضَانْ نّشْ،
\m أَرِي ثنْثْ خْ ثڒْوِيحْثْ ن وُوڒْ نّشْ. \x ◘ \xo 7:‏3 \xt أَعَوذ. 6‏:‏8؛ 11‏:‏18\x*
\m 
\v 4 إِنِي إِ ثِيغِيثْ: ’شمْ ذ ؤُتْشْمَا!‘،
\m ؤُ سمَّا ڒفْهَامثْ: ’أَمدُّوكّڒْ \add إِنُو\add*!‘،
\m 
\v 5 مَاحنْذْ \add نِيثنْثِي\add* أَذْ شكْ حْضَانْثْ
\m زِي ثمْغَارْثْ ثَابَارَّانشْثْ،
\m زِي ثمْغَارْثْ زِي بَارَّا
\m إِ شكْ إِتّْغَارَّانْ س وَاوَاڒنْ نّسْ. \x ◘ \xo 7:‏5 \xt أَوڒن. 5‏:‏3\x*
\b
\m 
\v 6 مَاغَارْ زِي ڒْكَازِي ن ثَادَّارْثْ إِنُو،
\m جَارْ شّبَّاشْ \add ن ڒْكَازِي\add* سوْضغْ غَارْ وَادَّايْ،
\m 
\v 7 سوْضغْ غَارْ إِحَافِييّنْ \add إِنِّي وَارْ إِتّْحِيكِينْ\add*،
\m جَارْ إِحنْجِيرنْ \add ن بْنَاذمْ\add*
\m حكَّارغْ إِجّْ ن ؤُحُوذْرِي
\m س وُوڒْ وَارْ إِمْثنْ.
\m 
\v 8 نتَّا إِژْوَا أَبْرِيذْ غَارْ ثغْمَارْثْ نّسْ،
\m ؤُ إِطّفْ أَبْرِيذْ غَارْ ثَادَّارْثْ نّسْ.
\m 
\v 9 غَارْ ثْبَامْبَاسْثْ، غَارْ ثْمذِّيثْ ن وَاسّْ،
\m ذِي ڒَادْجَاغْ نْ دْجِيڒثْ ذ ثُوبَّارْشنْثْ،
\m 
\v 10 خْزَارْ، \add أَقَا\add* إِشْثْ ن ثمْغَارْثْ ثُوسَا-د
\m إِ ؤُمْسَاڭَارْ أَكِيذسْ،
\m ذڭْ وَارُّوضْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ
\m ؤُ س ثحْرَايْمشْثْ ن وُوڒْ.
\b
\m 
\v 11 نتَّاثْ ثخْثِيخْ ؤُ ثْغوّغْ،
\m إِضَارنْ نّسْ وَارْ قِّيمنْ عَاذْ ذِي ثَادَّارْثْ. \x ◘ \xo 7:‏11 \xt أَوڒن. 9‏:‏13\x*
\m 
\v 12 إِشْثْ ن ثْوَاڒَا ذِي بَارَّا،
\m \add خنِّي\add* عَاوذْ ذڭْ وَازَّاينْ،
\m غَارْ مَارَّا ثِيغمَّارْ \add ن إِبْرِيذنْ\add* ثتّْحَامَا.
\m 
\v 13 نتَّاثْ ثطّفْ إِ-ث ؤُ ثسُّوذمْ إِ-ث،
\m ثقْجَارْ ؤُذمْ نّسْ، ثنَّا أَسْ:
\m 
\v 14 ”ثُوغَا خَافِي \add مَاحنْذْ أَذْ وْشغْ\add*
\m ثِيوْهِيبِينْ ن ڒهْنَا.
\m أَسّْ-أَ سّْقفْڒغْ لْوُوعُوذْ إِنُو.
\m 
\v 15 خْ ؤُيَا إِ د-فّْغغْ
\m مَاحنْذْ أَذْ شكْ مّْسَاڭَارغْ،
\m مَاحنْذْ أَذْ خَاكْ أَرْزُوغْ ؤُ \add أَمُّو إِ شكْ\add* ؤُفِيغْ.
\m 
\v 16 نشّْ سُّوغْ مَالْثَاثْ خْ قَامَا إِنُو،
\m ڒِْيزَارَاثْ إِزوّْقنْ زِي ڒقْثنْ أَزْذَاذْ زِي مِيصْرَا.
\m 
\v 17 نشّْ رُوشّغْ ثَاسُّوثْ إِنُو
\m \add س\add* مِيرُّو ذ وشْفِيڒْ ذ ڒْقَارْفَا. \x ◘ \xo 7:‏17 \xt إِزْڒِي 4‏:‏14. \x*
\m 
\v 18 أَسْ-د، أجّْ أَنغْ أَذْ نجِّيونْ
\m أَسْحِينّبْ أَڒْ ثُوفُّوثْ،
\m أجّْ أَنغْ أَذْ نَارّْ مژْرِي ذِي ڒِيرَارْثْ ن ثَايْرِي.
\m 
\v 19 مَاغَارْ أَرْيَازْ وَارْ إِدْجِي ذِي ثَادَّارْثْ،
\m نتَّا \add إِسَافَارْ\add* إِڭّْوجْ أَطَّاسْ.
\m 
\v 20 إِكْسِي إِشْثْ ن ثْكمُّوسْثْ
\m \add ن ثْمنْيَاثْ\add* ن نُّوقَارْثْ أَكِيذسْ،
\m أَذْ يَارڭّْوحْ غَارْ وَاسّْ ن ثْزِيرِي إِقفْڒنْ.“
\m 
\v 21 \add أَمُّو\add* إِ ث ثطّفْ س وَاطَّاسْ ن ڒْهَارْذْ نّسْ،
\m ثغْوَا إِ-ث س ڒهْرُوذْ نّسْ إِزوّْقنْ
\m ن إِينْشِيشنْ نّسْ.
\b
\m 
\v 22 ذغْيَا نتَّا يَارْذفْ إِ-ت،
\m أَمْ يِيجّْ ن ؤُفُونَاسْ إِڭُّورنْ غَارْ ڒْڭُورْنثْ،
\m أَمْ إِشْثْ ن سّْنسْڒثْ \add خْ إِضَارنْ\add* \add ن ونِّي إِڭُّورنْ\add*
\m غَارْ ؤُمَارّثْ ن ؤُبُوهَاڒِي
\m 
\v 23 - أَڒَامِي د أَسْ ثْشَارّڭْ فْڒِيثْشَا ثْسَا -
\m أَمْ يِيجّْ ن وجْضِيضْ إِضْوِينْ ذڭْ إِجّْ ن ونْذَايْ،
\m ؤُ وَارْ إِسِّينْ أَقَا وَانِيثَا إِتّْوَاڭّْ
\m ضِيدّْ إِ ثُوذَارْثْ نّسْ. \x ◘ \xo 7:‏23 \xt أَوڒن. 1‏:‏17\x*
\b
\m 
\v 24 \add خنِّي\add* ڒخُّو، \add أَ\add* إِحنْجِيرنْ، سْڒمْ-د غَارِي،
\m ؤُ سْڒمْ غَارْ وَاوَاڒنْ ن ؤُقمُّومْ إِنُو.
\m 
\v 25 أجّْ ؤُڒْ نّشْ وَارْ إِتّْوذِّيرْ
\m ذڭْ إِبْرِيذنْ نّسْ،
\m وَارْ تّْميِّيڒْ غَارْ إِمسْرَاقْ نّسْ.
\m 
\v 26 مَاغَارْ ذڭْ وَاطَّاسْ إِتّْوَايزْمنْ
\m إِنِّي ثغْضرْ،
\m إِمْغَارْ وَاطَّاسْ \add لْعَاذَاذْ ن\add* مَارَّا إِنِّي ثنْغَا.
\m 
\v 27 ثَادَّارْثْ نّسْ \add ثشُّورْ\add*
\m \add س\add* إِبْرِيذنْ غَارْ ڒَاخَارْثْ
\m نِّي إِهكّْوَانْ
\m غَارْ إِخَّامنْ ن ذَاخڒْ ن ڒْموْثْ. \x ◘ \xo 7:‏27 \xt أَوڒن. 2‏:‏18؛ 5‏:‏5\x*
\b
\b
\c 8
\s1 أَڒَاغِي ن ثِيغِيثْ
\m 
\v 1 مَا وَارْ ثتّْڒِيغِي ثِيغِيثْ ؤُ وَارْ ثسْڭِيعِّيذْ
\m ڒفْهَامثْ ثْمِيجَّا نّسْ؟ \x ◘ \xo 8:‏1 \xt أَوڒن. 1‏:‏20، 21\x*
\m 
\v 2 خْ ثْقِيشَّاثْ ن ڒڭْعُوذِي خْ وبْرِيذْ،
\m مَانِي تّمْسڒْقَانْ إِمسْرَاقْ
\m ثْبدّْ نتَّاثْ ذ أَبذِّي.
\m 
\v 3 غَارْ ؤُغزْذِيسْ ن ثوُّورَا،
\m غَارْ وَاذَافْ ن ثنْذِينْثْ،
\m مَانِي غَا ثَاذْفذْ خْ ثوُّورَا،
\m ثتّْڒَاغَا س جّهْذْ:
\b
\m 
\v 4 ”إِ كنِّيوْ، \add أَ\add* إِرْيَازنْ، تّْڒَاغِيغْ،
\m ثْمِيجَّا إِنُو \add ثتّفّغْ\add* غَارْ ثَارْوَا ن بْنَاذمْ.
\m 
\v 5 \add كنِّيوْ\add* إِحَافِييّنْ،
\m فهْممْ \add خنِّي\add* مِينْ إِدْجَانْ ذ أَفْثَانْ،
\m \add كنِّيوْ\add* إِبُوهَاڒِييّنْ،
\m فهْممْ \add س\add* وُوڒْ \add نْومْ\add*.
\m 
\v 6 سْڒمْ، مِينْزِي أَذْ سِّيوْڒغْ
\m أَوَاڒنْ إِ د-إِجبّْذنْ ڒفْثنْ،
\m أَنُورْزمْ ن إِينْشِيشنْ إِنُو
\m \add جبّذْ-د\add* ثِيمسْڒَايِينْ إِسڭّْذنْ،
\m 
\v 7 مَاغَارْ أَنغْ إِنُو أَذْ يِينِي ثِيذتّْ س نّيّثْ،
\m ڒْْهَارْذْ إِعفّْننْ أَقَا-ث ذ نّْعِي
\m إِ إِينْشِيشنْ إِنُو.
\m 
\v 8 مَارَّا أَوَاڒنْ ن ؤُقمُّومْ إِنُو
\m \add تّفّْغنْ-د\add* زِي ثْسڭْذَا،
\m وَارْ ذَايْسنْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ
\m إِخْنُونّسنْ نِيغْ إِفَارْغنْ.
\m 
\v 9 أَقَا أَثنْ مَارَّا صْفَانْ
\m إِ ونِّي ذِي ثدْجَا ڒفْهَامثْ،
\m ؤُڒَا س ڒقْيَاسْ إِ يِينِّي \add إِخْسنْ\add* أَذْ أَفنْ ثُوسّْنَا.
\b
\m 
\v 10 كْسِيمْ تَّارْبِييّثْ إِنُو، وَارْ إِدْجِي نُّوقَارْثْ،
\m ؤُڒَا ثُوسّْنَا كْثَارْ خْ وُورغْ إِقُّورنْ،
\m 
\v 11 مَاغَارْ ثِيغِيثْ حْسنْ زِي ڒْمَارْجَانْ،
\m مَارَّا مِينْ ذِي إِزمَّارْ \add بْنَاذمْ\add*
\m أَذْ إِمژْرِي،
\m وَارْ \add إِزمَّارْ\add* أَذْ ذَايسْ يَارْوسْ. \x ◘ \xo 8:‏11 \xt أَيُوبْ 28‏:‏15؛ إِزهد. 19‏:‏11؛ أَوڒن. 3‏:‏14، 15؛ 16‏:‏16\x*
\m 
\v 12 نشّْ، ثِيغِيثْ، زدّْغغْ غَارْ وفْثَانْ،
\m تَّافغْ ثُوسّْنَا س ؤُحَاذُورْ.
\m 
\v 13 ثِيڭّْوُوذِي ن سِيذِي ذ أَشْرَاهْ ن ڒْغَارْ،
\m نّْفَاخثْ ذ ثْشنَّاعْثْ ذ ؤُمسْرُوقْ أَعفَّانْ،
\m نشّْ شَارّْهغْ ؤُڒَا ذ أَقمُّومْ
\m \add إِشُّورْ س\add* ڒخْذَاعَاثْ.
\m 
\v 14 غَارِي أَشَاوَارْ ذ ثْوِيزَا،
\m نشّْ ذ ڒفْهَامثْ، غَارِي جّهْذْ.
\m 
\v 15 زَّايِي حكّْمنْ إِجدْجِيذنْ،
\m \add زَّايِي\add* تَّاريْسنْ أَيْثْ ن جّهْذْ س ثْسڭْذَا.
\m 
\v 16 زَّايِي حكّْمنْ ڒْحُوكَّامْ
\m ذ ثَارْوَا ن ثَاصِيڒثْ،
\m مَارَّا ڒْقُوضَاثْ ن ثمُّورْثْ.
\m 
\v 17 نشّْ تّخْسغْ مَارَّا
\m إِنِّي ذ أَيِي إِتّخْسنْ،
\m ذ يِينِّي خَافِي يَارزُّونْ زِيشْ، أَذْ أَيِي أَفنْ.
\m 
\v 18 أَڭْڒَا ذ شَّانْ أَقَا أَثنْ غَارِي،
\m أَڭْڒَا إِقِّيمنْ ذ ثْسڭْذَا. \x ◘ \xo 8:‏18 \xt أَوڒن. 3‏:‏16\x*
\m 
\v 19 فْرُوثَا إِنُو ثشْنَا خْ وُورغْ إِتِّيسِّيقنْ،
\m \add وَاهْ\add* خْ وُورغْ أَزْذَاذْ،
\m ڒْْغِيدْجثْ إِنُو ثعْذُو نُّوقَارْثْ إِقُّورنْ.\x ◘ \xo 8:‏19 \xt أَوڒن. 3‏:‏14\x*
\m 
\v 20 نشّْ ڭُّورغْ خْ ؤُمسْرُوقْ ن ثْسڭْذَا،
\m ذِي ڒْوسْطْ ن إِمسْرَاقْ ن ڒْحقّْ،
\m 
\v 21 حِيمَا أَذْ أَرّغْ إِنِّي ذ أَيِي إِتّخْسنْ
\m أَذْ طّْفنْ إِشْثْ ن ثسْغَارْثْ ذ ڒْوَارْثْ،
\m نشّْ أَذْ شُّورغْ إِخَّامنْ ن ثْخُوبَايْ نْسنْ.
\b
\m 
\v 22 سِيذِي إِڭَّا أَيِي، ذ أَمزْوَارُو ن وبْرِيذْ نّسْ،
\m \add عَاذْ\add* قْبڒْ أَمزْوَارُو ن ثْمڭَّا نّسْ
\m زڭْ وشْحَاڒْ ؤُيَا.
\m 
\v 23 زِي ڒبْذَا إِتّْوَازدْجعْ خَافِي \add جّهْذْ\add*،
\m زڭْ ؤُمزْوَارُو،
\m زِي ڒْوقْثْ ن ؤُمزْوَارُو
\m إِ ذِي ثتّْوَاڭّْ ثمُّورْثْ، \x ◘ \xo 8:‏23 \xt يُوح. 1‏:‏1\x*
\m 
\v 24 ؤُمِي وَارْ ذِينْ ثُوغِي عَاذْ \add أَمَانْ\add* إِهوْڒنْ،
\m نشّْ تّْوَاخڒْقغْ-د،
\m ؤُمِي وَارْ ذِينْ ثُوغِي عَاذْ ڒْعُونْصَارَاثْ
\m شُّورنْثْ س وَامَانْ.
\m 
\v 25 قْبڒْ مَا أَذْ تّْوَاڭّنْ إِذُورَارْ،
\m قْبڒْ \add مَا أَذْ إِڒِينْثْ\add* ثوْرِيرِينْ،
\m ثُوغَا خڒْقغْ-د نشّْ.
\m 
\v 26 نتَّا ثُوغَا عَاذْ وَارْ د-إِخْڒِيقْ
\m ثَامُّورْثْ ذ إِيَّارنْ،
\m ؤُڒَا ذ ثَامزْوَارُوثْ ن ثْعجَّاجْثْ ن دُّونشْثْ.
\m 
\v 27 ؤُمِي نتَّا إِڭَّا إِجنْوَانْ، ثُوغَا أَيِي ذِينْ،
\m ؤُمِي نتَّا يَارْشمْ إِشْثْ ن ثْقُورَارشْثْ
\m خْ وُوذمْ ن \add وَامَانْ\add* إِهوْڒنْ. \x ◘ \xo 8:‏27 \xt أَيُوبْ 26‏:‏10\x*
\b
\m 
\v 28 ؤُمِي نتَّا إِڭَّا إِسيْنُوثنْ سنّجْ،
\m ؤُمِي تّْوَاجهْذنْثْ
\m ڒْْعُونْصَارَاثْ ن \add وَامَانْ\add* إِهوْڒنْ، \x ◘ \xo 8:‏28 \xt أَمز. 7‏:‏11\x*
\m 
\v 29 ؤُمِي نتَّا إِڭَّا إِ ڒبْحَارْ أَيْمِيرْ نّسْ،
\m مَاحنْذْ أَمَانْ
\m وَارْ د -عدُّونْ ڒُومُورْ نّسْ،
\m ؤُمِي نتَّا إِعْبَارْ ذْسُوسَا ن ثمُّورْثْ، \x ◘ \xo 8:‏29 \xt أَمز. 1‏:‏9، 10؛ أَيُوبْ 38‏:‏10، 11؛ إِزهد. 104‏:‏9\x*
\m 
\v 30 ثُوغَا أَيِي ذ أَمُوذْرُوسْ إِعِيزّنْ
\m غَارْ ؤُغزْذِيسْ نّسْ.
\m نشّْ ثُوغَا أَيِي مَارَّا ذ ثَارِّيثْ ن مژْرِي
\m أَسّْ خْ وَاسّْ،
\m تِّيرَارغْ زَّاثْ إِ وُوذمْ نّسْ ڒبْذَا، \x ◘ \xo 8:‏30 \xt يُوح. 5‏:‏17\x*
\m 
\v 31 تِّيرَارغْ ذِي مَارَّا ثَامُّورْثْ نّسْ،
\m أَمْ ثُوغَا ثَارِّيثْ ن مژْرِي إِنُو
\m أَكْ-ذ ثَارْوَا ن بْنَاذمْ.
\b
\m 
\v 32 \add خنِّي\add* ڒخُّو، \add أَ\add* إِحنْجِيرنْ \add إِنُو\add*،
\m سْڒمْ-د غَارِي!
\m سّعْذْ ن يِينِّي إِحطَّانْ إِبْرِيذنْ إِنُو. \x ◘ \xo 8:‏32 \xt إِزهد. 119‏:‏1، 2؛ 128‏:‏1؛ لك. 11‏:‏28\x*
\m 
\v 33 سْڒمْ غَارْ تَّارْبِييّثْ
\m ؤُ ذوْڒمْ ذ إِمِيغِيسنْ،
\m وَارْ نطَّارمْ \add تَّارْبِييّثْ\add*.
\m 
\v 34 سّعْذْ ن بْنَاذمْ نِّي غَارِي إِسْڒَانْ،
\m ونِّي إِطّْفنْ أَشْبَارْ غَارْ ثوُّورَا إِنُو
\m زڭْ وَاسّْ أَڒْ وَاسّْ،
\m إِحتَّا خْ ثْغمَّارْ ن ثوُّورَا إِنُو،
\m 
\v 35 مَاغَارْ ونِّي ذ أَيِي يُوفِينْ، أَذْ يَافْ ثُوذَارْثْ،
\m ؤُ أَذْ إِطّفْ أَرْضَا ن سِيذِي. \x ◘ \xo 8:‏35 \xt أَوڒن. 12‏:‏2\x*
\m 
\v 36 ونِّي إِ ذ أَيِي إِخْضَانْ، إِيزّمْ ڒعْمَارْ نّسْ،
\m مَارَّا إِنِّي ذ أَيِي إِشَارّْهنْ، تّخْسنْ ڒْموْثْ.
\b
\b
\c 9
\m 
\v 1 ثِيغِيثْ ثبْنَا ثَادَّارْثْ نّسْ،
\m ثڭَّا ثسُّويْذَا إِپِيلَارنْ نّسْ،
\m \add أَقَا أَثنْ ذِي\add* سبْعَا.
\m 
\v 2 نتَّاثْ ثْغَارْصْ إِ ڒْمَاڒْ نّسْ،
\m ثْخدْجضْ بِينُو نّسْ.
\m عَاوذْ ثسُّو طَّابْڒَا نّسْ.
\m 
\v 3 نتَّاثْ ثسّكّْ
\m ثِيمْسخَّارِينْ نّسْ ثِيمژْيَانِينْ.
\m خْ ثْقِيشَّاثِينْ ن ڒڭْعُوذِي ن ثنْذِينْثْ ثتّْڒَاغَا: \x ◘ \xo 9:‏3 \xt أَوڒن. 8‏:‏2\x*
\m 
\v 4 ”ونِّي إِدْجَانْ ذ أَحَافِي،
\m أجّْ إِ-ث أَذْ د-يَاسْ ذَانِيثَا!“
\m نتَّاثْ ثقَّارْ
\m إِ يِينِّي وَارْ غَارْ إِدْجِي شَا وُوڒْ إِمْثنْ:
\m 
\v 5 ”أَسمْ-د، شّمْ زڭْ وغْرُومْ إِنُو،
\m سْومْ زِي بِينُو نِّي ذ أَومْ د-خدْجْضغْ.
\m 
\v 6 جّمْ ثَاقُوبَّانشْثْ، ؤُشَا دَّارمْ،
\m ضْفَارمْ أَبْرِيذْ ن ڒفْهَامثْ.“
\b
\m 
\v 7 ”ونِّي إِتّْوبّْخنْ أَمسْثهْزِييْ،
\m إِسَّاربُّو ڒفْضِيحثْ إِ يِيخفْ نّسْ،
\m ونِّي إِتّْعَاقَابنْ أَعفَّانْ،
\m أَقَا \add نتَّا يَاربُّو\add* أَبقِّيضْ
\m ن ڒفْضِيحثْ نّسْ.
\m 
\v 8 وَارْ تّْعيَّابْ أَمسْثهْزِييْ
\m حِيمَا نتَّا وَارْ شكْ إِشَارّهْ،
\m عيّبْ \add أَ\add*مِيغِيسْ، خنِّي نتَّا أَذْ شكْ إِخْسْ. \x ◘ \xo 9:‏8 \xt مت. 7‏:‏6\x*
\m 
\v 9 أوْشْ إِ ؤُمِيغِيسْ،
\m \add خنِّي\add* أَذْ إِذْوڒْ ذ مِيغِيسْ كْثَارْ،
\m سْغَارْ ثُوسّْنَا إِ ؤُمْسڭّذْ،
\m \add خنِّي\add* نتَّا أَذْ إِفْهمْ كْثَارْ.“
\m 
\v 10 ثِيڭّْوُوذِي ن سِيذِي ذ بدُّو ن ثِيغِيثْ،
\m ثُوسّْنَا ن ؤُمْقدَّاسْ ذ أَمقّْرَانْ
\m ذ بدُّو ن ڒفْهَامثْ. \x ◘ \xo 9:‏10 \xt أَيُوبْ 28‏:‏28؛ إِزهد. 111‏:‏10؛ أَوڒن. 1‏:‏7\x*
\m 
\v 11 مَاغَارْ زَّايِي أَذْ كْثَارنْ وُوسَّانْ نّشْ،
\m إِسڭّْوُوسَا ن ثُوذَارْثْ أَذْ تّْوَارْنِينْ إِ شكْ. \x ◘ \xo 9:‏11 \xt أَوڒن. 10‏:‏27\x*
\m 
\v 12 مَاڒَا شكْ ذ مِيغِيسْ،
\m \add خنِّي\add* أَذْ ثِيڒِيذْ ذ مِيغِيسْ إِ يِيخفْ نّشْ،
\m ؤُ مَاڒَا ثسْثهزِّيذْ،
\m أَذْ ثَارْبُوذْ أَيَا سِيمَانْثْ نّشْ.“
\b
\m 
\v 13 ثَامْغَارْثْ ثابُوهَاڒشْثْ ثتّْبُوهْڒُويْ،
\m \add نتَّاثْ\add* ذ ثَاقُوبَّانِيثْ، وَارْ ثسّنْ وَالُو. \x ◘ \xo 9:‏13 \xt أَوڒن. 7‏:‏11\x*
\m 
\v 14 نتَّاثْ ثتّْغِيمَا
\m غَارْ ثوَّارْثْ ن ثَادَّارْثْ نّسْ،
\m خْ إِجّْ ن كُورْسِي، \add خْ\add* ڒڭْعُوذِي ن ثنْذِينْثْ
\m 
\v 15 حِيمَا أَذْ ثْڒَاغَا خْ إِنِّي إِعدُّونْ،
\m إِنِّي إِڭُّورنْ نِيشَانْ إِمسْرَاقْ نْسنْ، \add ثنَّا\add*:
\m 
\v 16 ”ونِّي إِدْجَانْ ذ أَحَافِي،
\m أجّْ إِ-ث أَذْ د-يَاسْ ذَانِيثَا!“
\m نتَّاثْ ثقَّارْ
\m إِ يِينِّي وَارْ غَارْ إِدْجِي شَا وُوڒْ إِمْثنْ:
\m 
\v 17 ”أَمَانْ إِتّْوَاشَارنْ ذ إِمِيژِيذنْ،
\m أَغْرُومْ إِنُّوفَّارنْ أَقَا إِشْنَا.“ \x ◘ \xo 9:‏17 \xt أَوڒن. 20‏:‏17\x*
\m 
\v 18 نتَّا وَارْ إِسِّينْ أَقَا ذِينْ ڒخْيَاڒَاثْ،
\m أَقَا إِنوْجِيونْ نّسْ
\m ذڭْ وَادْجَاغْ ن ڒَاخَارْثْ \add إِ إِدْجَانْ\add*. \x ◘ \xo 9:‏18 \xt أَوڒن. 2‏:‏18\x*
\b
\b
\c 10
\s1 أَوَاڒنْ إِوزّْننْ ن سُولِيمَانْ - ثَاسْغَارْثْ 1أَ
\m 
\v 1 \bd أَوَاڒنْ إِوزْننْ ن سُولِيمَانْ\bd*
\b
\m إِجّْ ن مِّيسْ ذ أَمِيغِيسْ إِسّْفَارَّاحْ بَابَاسْ،
\m \add مَاشَا\add* إِجّْ ن ؤُبُوهَاڒِي ن مِّيسْ
\m ذ ونِّي ذ أَمْنُوسْ \add أَمقّْرَانْ\add* ن يمَّاسْ. \x ◘ \xo 10:‏1 \xt أَوڒن. 15‏:‏20\x*
\m 
\v 2 ثِيخُوبَايْ ن ثُوعفّْنَا وَارْ نّفّْعنْثْ،
\m \add مَاشَا\add* ثَاسڭْذَا ثتّْفكَّا زِي ڒْموْثْ. \x ◘ \xo 10:‏2 \xt أَوڒن. 11‏:‏4\x*
\m 
\v 3 سِيذِي وَارْ إِتّجِّي ڒعْمَارْ ن إِمْسڭَّاذنْ
\m أَذْ إِحيّفْ،
\m \add مَاشَا\add* مژْرِي ن إِعفَّاننْ
\m إِعَارّنْ إِ-ث غَارْ ڒَاڭّْوَاجْ.
\m 
\v 4 وِي إِخدّْمنْ س ؤُفُوسْ يَارْخُونْ،
\m إِتَّاوِي-د زّڒْضْ،
\m \add مَاشَا\add* أَفُوسْ ن يِينِّي إِتّْشطَّارنْ
\m إِتَّاوِي-د أَڭْڒَا. \x ◘ \xo 10:‏4 \xt أَوڒن. 12‏:‏24\x*
\m 
\v 5 ونِّي إِيَارّْونْ ذڭْ ؤُنبْذُو
\m ذ إِجّْ ن مِّيسْ إِفهّْمنْ،
\m \add مَاشَا\add* ونِّي إِتّطّْصنْ ذِي ثْميْرَا
\m ذ إِجّْ ن مِّيسْ ن ڒفْضِيحثْ.
\m 
\v 6 لْبَارَاكَاثْ \add أَرسَّانْثْ\add*
\m خْ ؤُزدْجِيفْ ن إِمْسڭَّاذنْ،
\m \add مَاشَا\add* لْعُونْفْ إِسّْذُورُّويْ
\m أَقمُّومْ ن إِعفَّاننْ.
\m 
\v 7 ڒِيذَارثْ إِ ؤُمْسڭّذْ \add أَذْ د-يَاوِي\add* لْبَارَاكَا،
\m \add مَاشَا\add* إِسمْ ن إِعفَّاننْ أَذْ يَارْصُوضْ.
\m 
\v 8 ونِّي ذ أَمِيغِيسْ ذڭْ وُوڒْ،
\m أَذْ إِقْبڒْ ثِيوصَّا،
\m \add مَاشَا\add* ونِّي \add إِسَّاوَاڒنْ\add* ثُوبُّوهڒْيَا
\m س إِينْشِيشنْ نّسْ، أَذْ إِوْضَا. \x ◘ \xo 10:‏8 \xt أَوڒن. 10‏:‏10\x*
\m 
\v 9 ونِّي إِڭُّورنْ ذِي ڒصْفَايثْ،
\m إِڭُّورْ ذِي ڒَامَانْ،
\m \add مَاشَا\add* ونِّي \add إِڭُّورنْ\add* إِبْرِيذنْ إِفَارْغنْ،
\m أَذْ إِتّْوَاسّنْ.
\m 
\v 10 ونِّي إِتّْغمَّازنْ س ثِيطَّاوِينْ،
\m إِتّڭّْ ڒحْرِيقْ،
\m ونِّي \add إِسَّاوَاڒنْ\add* ثُوبُّوهڒْيَا
\m س إِينْشِيشنْ نّسْ، أَذْ إِوْضَا.
\m 
\v 11 أَقمُّومْ ن ؤُمْسڭّذْ ذ ثَاڒَا ن ثُوذَارْثْ،
\m \add مَاشَا\add* لْعُونْفْ إِسّْذُورُّويْ
\m أَقمُّومْ ن إِعفَّاننْ. \x ◘ \xo 10:‏11 \xt أَوڒن. 10‏:‏6، 13‏:‏14\x*
\m 
\v 12 أَشْرَاهْ ثسّكَّارَا-د إِمْشُوبّشنْ،
\m \add مَاشَا\add* ثَايْرِي ثسّْذُورُّويْ مَارَّا إِخطَّانْ. \x ◘ \xo 10:‏12 \xt 1 كُور. 13‏:‏7؛ 1 بُط. 4‏:‏8\x*
\m 
\v 13 خْ إِينْشِيشنْ ن ونِّي غَارْ إِدْجَا ڒفْهَامثْ
\m ثتّْوَافْ ثِيغِيثْ،
\m \add مَاشَا\add* أَعْمُوذْ
\m إِ ونِّي وَارْ غَارْ إِدْجِي بُو ڒعْقڒْ. \x ◘ \xo 10:‏13 \xt أَوڒن. 20‏:‏30\x*
\m 
\v 14 إِمِيغِيسنْ تّْخمَّارنْ ثُوسّْنَا،
\m \add مَاشَا\add* أَقمُّومْ ن ؤُبُوهَاڒِي
\m إِتَّاذسْ غَارْ ؤُهلّكْ.
\m 
\v 15 إِ بُو-وَاڭْڒَا مِينْ إِدْجَانْ نّسْ
\m ذ ثَانْذِينْثْ إِجهْذنْ نّسْ،
\m لبْلَا ن إِمزْڒَاضْ ذ أَهلّكْ نْسنْ.
\m 
\v 16 ڒْغِيدْجثْ ن ؤُمْسڭّذْ أَقَا-ت إِ ثُوذَارْثْ،
\m ڒْمُونثْ ن ؤُعفَّانْ إِ دّنْبْ.
\m 
\v 17 ونِّي إِحطَّانْ تَّارْبِييّثْ،
\m \add أَقَا-ث خْ\add* وبْرِيذْ ن ثُوذَارْثْ،
\m \add مَاشَا\add* ونِّي إِسمّْحنْ ذڭْ ؤُوبّخْ،
\m أَذْ إِودَّارْ.
\m 
\v 18 وِي إِتّفَّارنْ أَشْرَاهِي،
\m غَارسْ إِينْشِيشنْ سّْخَارِّيقنْ،
\m وِي إِتّْشقَّافنْ أَقَا-ث ذ أَبُوهَاڒِي.
\m 
\v 19 غَارْ وَاطَّاسْ ن وَاوَاڒنْ
\m وَارْ إِقِّيمْ ؤُخطُّو إِنقّصْ،
\m \add مَاشَا\add* ونِّي إِمنّْعنْ إِينْشِيشنْ نّسْ،
\m أَقَا \add إِتّڭّْ\add* س ڒعْقڒْ.
\m 
\v 20 نُّوقَارْثْ إِقُّورنْ ذ إِڒسْ ن ؤُمْسڭّذْ،
\m ؤُڒْ ن إِعفَّاننْ وَارْ إِسكّْوِينْ.
\m 
\v 21 إِينْشِيشنْ ن إِمْسڭَّاذنْ سّشَّانْ أَطَّاسْ،
\m \add مَاشَا\add* إِبُوهَاڒِييّنْ مُّوثنْ
\m ؤُمِي وَارْ غَارْسنْ بُو وُوڒْ إِمْثنْ.
\m 
\v 22 لْبَارَاكَا ن سِيذِي ثتَّاوِي-د أَڭْڒَا،
\m أَرْبرْ \add ن بْنَاذمْ\add* وَارْ ذَايسْ يَارنِّي وَالُو.
\m 
\v 23 إِ ؤُبُوهَاڒِي ثَامڭِّيثْ ن ڒفْضِيهثْ
\m أَمْ يِيشْثْ ن ڒُورَارثْ،
\m \add مَاشَا\add* إِ ورْيَازْ ن ڒفْهَامثْ
\m \add أَذبَّارْ\add* س ثِيغِيثْ \add أَمْ مَانْ أَيَا\add*. \x ◘ \xo 10:‏23 \xt أَوڒن. 14‏:‏9\x*
\m 
\v 24 مِينْ زِي إِتّڭّْوذْ ؤُعفَّانْ أَذْ ث إِڒْقفْ،
\m \add مَاشَا\add* أَسِيثمْ ن إِمْسڭَّاذنْ أَذْ يِيڒِي.
\m 
\v 25 مَاڒَا ثعْذُو-د ثْحَارْيَاضْثْ،
\m أَعفَّانْ وَارْ إِتّْغِيمِي،
\m \add مَاشَا\add* أَمْسڭّذْ أَذْ إِقِّيمْ إِمْثنْ إِ ڒبْذَا.
\m 
\v 26 أَمْ بِينُو أَسمَّامْ إِ ثغْمَاسْ
\m ذ دّخَّانْ إِ ثِيطَّاوِينْ،
\m أَمُّو إِ إِڭَّا ؤُمعْڭُوزْ إِ يِينِّي ث إِسّكّنْ.
\m 
\v 27 ثِيڭّْوُوذِي ن سِيذِي ثَارنِّي
\m ذڭْ ؤُسَّانْ \add إِ ثُوذَارْثْ\add*،
\m \add مَاشَا\add* إِسڭّْوُوسَا ن إِعفَّاننْ
\m تّْوَاسّْقُوضّضنْ. \x ◘ \xo 10:‏27 \xt أَوڒن. 9‏:‏11\x*
\m 
\v 28 ثَارَاجِيثْ ن إِمْسڭَّاذنْ ذ ڒفْرَاحثْ،
\m \add مَاشَا\add* ڒَايَاسْ ن إِعفَّاننْ ڭُّورْ أَذْ إِفْنَا. \x ◘ \xo 10:‏28 \xt أَيُوبْ 8‏:‏13، 14؛ 11‏:‏20؛ إِزهد. 112‏:‏10\x*
\m 
\v 29 أَبْرِيذْ ن سِيذِي ذ لْبُورْجْ \add إِجهْذنْ\add*
\m إِ ونِّي إِڭُّورنْ نِيشَانْ،
\m \add مَاشَا\add* ذ أَهلّكْ إِ يِينِّي إِتّڭّنْ ڒْغشّْ. \x ◘ \xo 10:‏29 \xt أَوڒن. 13‏:‏6\x*
\m 
\v 30 أَمْسڭّذْعمَّارْصْ أَذْ إِنْهزّْ إِ ڒبْذَا،
\m \add مَاشَا\add* إِعفَّاننْ وَارْ زدّْغنْ ذِي ثمُّورْثْ.
\m 
\v 31 أَقمُّومْ ن ؤُمْسڭّذْ
\m إِتَّاوِي-د ثِيغِيثْ س وَاطَّاسْ،
\m \add مَاشَا\add* إِجّْ ن يِيڒسْ إِعمَّارْ س ڒخْذَاعَاثْ
\m أَذْ إِتّْوَاقسّْ.
\m 
\v 32 إِينْشِيشنْ ن ؤُمْسڭّذْ سّْننْ مِينْ يَارْضَانْ،
\m \add مَاشَا\add* أَقمُّومْ ن ؤُعفَّانْ
\m \add إِسّنْ\add* ڒخْذَاعَاثْ وَاهَا.
\b
\b
\c 11
\m 
\v 1 ڒْمِيزَانْ أَغشَّاشْ ذ نّْعِي إِ سِيذِي،
\m \add مَاشَا\add* أَژْرُو ن ڒوْزنْ نِيشَانْ
\m إِتَّافْ أَرْضَا نّسْ. \x ◘ \xo 11:‏1 \xt لَاوِي 19‏:‏36؛ أَعَوذ. 25‏:‏13؛ أَوڒن. 16‏:‏11؛ 20‏:‏10، 23\x*
\m 
\v 2 مَاڒَا ثُوسَا-د نّْفَاخثْ،
\m ثُوسَا-د ؤُڒَا ذ ڒفْضِيحثْ،
\m \add مَاشَا\add* غَارْ إِمْوَاضْعنْ \add ثدْجَا\add* ثِيغِيثْ. \x ◘ \xo 11:‏2 \xt أَوڒن. 15‏:‏33؛ 16‏:‏18؛ 18‏:‏12\x*
\m 
\v 3 ڒصْفَايثْ ن إِنِّي إِڭُّورنْ نِيشَانْ
\m ثْندّهْ إِ-ثنْ،
\m \add مَاشَا\add* ثَاحْرَايْمشْثْ ن إِغدَّارنْ
\m ثَاڒدّدْجْ إِ-ثنْ. \x ◘ \xo 11:‏3 \xt أَوڒن. 13‏:‏6\x*
\b
\m 
\v 4 أَڭْڒَا وَارْ إِنفّعْ
\m غَارْ وَاسّْ ن ؤُذُوقّزْ \add ن ؤُفُوڭمْ\add*،
\m \add مَاشَا\add* ثَاسڭْذَا ثتّْفكَّا زِي ڒْموْثْ. \x ◘ \xo 11:‏4 \xt أَوڒن. 10‏:‏2؛ حِز. 7‏:‏19؛ صَاف. 1‏:‏18\x*
\m 
\v 5 ثَاسڭْذَا ن ونِّي إِڭُّورنْ نِيشَانْ
\m إِتَّارَّا أَبْرِيذْ نّسْ نِيشَانْ،
\m \add مَاشَا\add* أَعفَّانْ إِوطَّا س ثُوعفّْنَا نّسْ.
\m 
\v 6 ثَاسڭْذَا ن إِنِّي إِڭُّورنْ نِيشَانْ
\m أَذْ ثنْ ثْفكّْ،
\m \add مَاشَا\add* إِغدَّارنْ أَذْ تّْوَاشَارْفنْ
\m ذڭْ ؤُمژْرِي \add نْسنْ\add*.
\b
\m 
\v 7 مَاڒَا إِمُّوثْ بْنَاذمْ أَعفَّانْ،
\m إِفْنَا ڒَايَاسْ نّسْ،
\m ؤُڒَا ذ مِينْ تّْرَاجَانْ
\m \add يرْيَازنْ\add* ذَايْسنْ ثرْيَاسْثْ أَذْ إِفْنَا.
\m 
\v 8 أَمْسڭّذْ أَذْ د-إِتّْوَافكّْ
\m زِي ڒحْصَارثْ،
\m ؤُشَا \add خنِّي\add* أَعفَّانْ أَذْ د-يَاسْ
\m ذڭْ ومْشَانْ نّسْ.\x ◘ \xo 11:‏8 \xt إِزهد. 34‏:‏20؛ أَوڒن. 21‏:‏18\x*
\m 
\v 9 أَمْنَافقْ إِتَّاردّدْجْ جَّارْ نّسْ
\m س ؤُقمُّومْ نّسْ،
\m \add مَاشَا\add* إِمْسڭَّاذنْ
\m أَذْ تّْوَافكّنْ س ثُوسّْنَا. \f ◼ \fr 11:‏9 \ft \bd ’\bdit بُو\bdit* ثْنَاينْ ن وُوذْمَاونْ‘\bd* - نِيغْ ’لْمُونَافِيقْ‘.\f*
\b
\m 
\v 10 ثَانْذِينْثْ ثتّسْڒِيوْڒِيوْ
\m مَاڒَا إِمْسڭَّاذنْ أَقَا أَثنْ مْلِيحْ،
\m ؤُ مَاڒَا تّْوَاهلّْكنْ إِعفَّاننْ،
\m أَقَا ذِينْ أَسْڒِيوْڒوْ.
\m 
\v 11 ثتّْوَاسّْڭعّذْ ثنْذِينْثْ
\m س لْبَارَاكَا ن إِنِّي إِڭُّورنْ نِيشَانْ،
\m \add مَاشَا\add* س ؤُقمُّومْ ن إِعفَّاننْ
\m أَذْ ثتّْوَاهْذمْ.
\m 
\v 12 ونِّي وَارْ غَارْ إِدْجِي شَا وُوڒْ إِمْثنْ،
\m إِسّحْقَارَا جَّارْ نّسْ،
\m \add مَاشَا\add* أَرْيَازْ ونِّي غَارْ إِدْجَا ڒفْهَامثْ
\m إِتّسْقَارْ.
\m 
\v 13 ونِّي إِڭُّورنْ ذَا ذ ذِيهَا س ثخْبَارْجِيثْ،
\m إِتّْعَارَّا مِينْ إِنُّوفَّارنْ،
\m \add مَاشَا\add* ونِّي \add إِ ذِي إِدْجَا\add* أَرُّوحْ
\m ذَايسْ ڒَامَانْ، أَقَا إِسّْنُوفَّارَا ثَامسْڒَاشْثْ.
\m 
\v 14 مَاڒَا وَارْ ذِينْ أَذبَّارْ، إِوطَّا ڒْڭنْسْ،
\m \add مَاشَا\add* أَذْ يِيڒِي ؤُسنْجمْ س ڒمْغَارثْ ن ؤُمْشَاوَارْ. \x ◘ \xo 11:‏14 \xt 1 إِج. 12‏:‏1‏-‏20\x*
\b
\m 
\v 15 ونِّي إِضمّْننْ ڒْبَارَّانِي،
\m وَارْ د أَسْ ثتّفّغْ شَا مْلِيحْ،
\m \add مَاشَا\add* ونِّي إِشَارّْهنْ
\m إِنِّي إِتّڭّنْ ثِيشْثِي خْ ؤُفُوسْ،
\m أَقَا-ث ذِي ڒَامَانْ.
\m 
\v 16 ثَامْغَارْثْ ثتَّافْ أَرْضَا، ثطّفْ
\m ذِي ڒْعزّْ \add نّسْ\add*،
\m \add مَاشَا\add* أَيْثْ ن بُو-ڒخْشُونثْ
\m تّطّْفنْ ذڭْ وَاڭْڒَا.
\b
\m 
\v 17 بْنَاذمْ س ثْمخْسِيوْثْ إِشوَّارنْ
\m إِتّڭّْ ڒْخَارْ إِ ڒعْمَارْ نّسْ،
\m \add مَاشَا\add* أَقسَّاحْ إِتّْغزَّا
\m أَيْسُومْ \add ن يِيخفْ\add* نّسْ.
\m 
\v 18 أَعفَّانْ إِمجَّارْ ڒْغِيدْجثْ ن ڒْغشّْ،
\m \add مَاشَا\add* ونِّي إِزَارّْعنْ ثَاسڭْذَا،
\m \add إِمجَّارْ\add* إِشْثْ نْ ڒْمُونثْ إِمثْننْ.
\m 
\v 19 ثَاسڭْذَا نِيشَانْ \add ثتَّاوِي غَارْ\add* ثُوذَارْثْ،
\m ونِّي يَاردّْفنْ ڒْغَارْ،
\m \add يَارزُّو\add* ڒْموْثْ نّسْ.
\b
\m 
\v 20 إِنِّي غَارْسنْ ؤُڒْ  إِفَارْغنْ
\m أَقَا أَثنْ ذ نّْعِي إِ سِيذِي،
\m \add مَاشَا\add* إِنِّي إِڭُّورنْ نِيشَانْ
\m نتَّا يَارطَّا ذَايْسنْ.
\m 
\v 21 س ثِيذتّْ، أَعفَّانْ وَارْ إِتّْغِيمِي بْڒَا ڒخْڒَاصْ،
\m \add مَاشَا\add* ثَارْوَا ن إِمْسڭَّاذنْ
\m أَذْ تّْوَاسّْنجْمنْ. \x ◘ \xo 11:‏21 \xt أَوڒن. 16‏:‏5\x*
\m 
\v 22 \add أَمشْنَاوْ\add* إِشْثْ ن ثْخَاذنْثْ ن وُورغْ
\m ذِي ثِينْزَارْ ن يِيڒفْ،
\m \add أَمُّو إِ ثدْجَا\add* إِشْثْ ن ثمْغَارْثْ ثشْنَا
\m وَارْ ذِي إِدْجَا ؤُميّزْ.
\m 
\v 23 مژْرِي ن إِمْسڭَّاذنْ
\m مْغِيرْ غَارْ مِينْ إِصبْحنْ،
\m \add مَاشَا\add* ڒَايَاسْ ن إِعفَّاننْ
\m أَقَا-ث نْهْڒَا ڒعْبَارْ.
\b
\m 
\v 24 أَقَا ذِينْ \add إِجّنْ\add* ونِّي إِبطَّانْ س وشْرِيمْ،
\m \add وَاخَّا أَمنِّي\add* إِتّْوَارْنِي أَسْ عَاذْ كْثَارْ،
\m ؤُ أَقَا ذِينْ \add إِجّنْ\add* ونِّي إِمنّْعنْ \add كْثَارْ\add*
\m خْ مِينْ إِشُووَّارنْ،
\m وَاخَّا مَانْ أَيَا \add إِندّهْ\add* غَارْ زّڒْضْ.
\m 
\v 25 ڒعْمَارْ نِّي إِتّْبَارْكنْ أَذْ إِتّْوَاسّْجِيونْ،
\m ؤُ ونِّي إِتِّيشنْ أَمَانْ،
\m أَذْ أَسْ إِمّوْشْ وَامَانْ
\m إِ نتَّا سِيمَانْثْ نّسْ. \x ◘ \xo 11:‏25 \xt إِزهد. 112‏:‏9؛ 2 كُور. 9‏:‏9\x*
\m 
\v 26 ونِّي إِتّْخمَّاڒنْ إِمنْذِي،
\m إِنعّڒْ إِ-ث شّعْبْ،
\m \add مَاشَا\add* لْبَارَاكَا أَذْ ثِيڒِي
\m خْ ؤُزدْجِيفْ ن ونِّي إِزْنُوزَانْ \add إِمنْذِي\add*.
\b
\m 
\v 27 ونِّي إِتّْشطَّارنْ ذِي طّْوعْ ن
\m مِينْ إِصبْحنْ،
\m يَارزُّو مِينْ يَارْضَانْ،
\m \add مَاشَا\add* ونِّي إِتّْحَامَانْ ڒْغَارْ، أَذْ ث إِڒْقفْ. \x ◘ \xo 11:‏27 \xt إِزهد. 7‏:‏17؛ 9‏:‏16؛ 10‏:‏2؛ 57‏:‏7\x*
\m 
\v 28 ونِّي إِتّْشَاڒنْ خْ وَاڭْڒَا نّسْ، أَذْ إِوْضَا،
\m \add مَاشَا\add* إِمْسڭَّاذنْ تّْنعْنِيعنْ
\m أَمْ إِفثْوَانْ إِزِيزَاونْ.\x ◘ \xo 11:‏28 \xt إِزهد. 1‏:‏3، 4؛ 92‏:‏13\x*
\m 
\v 29 ونِّي إِهكّْوْڒنْ \add أَيْثْبَابْ ن\add* ثَادَّارْثْ نّسْ،
\m أَذْ إِوَارْثْ أَسمِّيضْ،
\m ؤُ أَبُوهَاڒِي \add أَذْ يِيڒِي\add* ذ أَمْسخَّارْ
\m ن ونِّي ذِي إِدْجَا وُوڒْ أَمِيغِيسْ.
\m 
\v 30 ڒْغِيدْجثْ ن ؤُمْسڭَّاذْ
\m ذ إِشْثْ ن ثْشجَّارْثْ ن ثُوذَارْثْ،
\m ونِّي يَاربّْحنْ ڒعْمُورْ أَقَا-ث ذ أَمِيغِيسْ. \f ◼ \fr 11:‏30 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*
\m 
\v 31 خْزَارْ، أَقَا أَذْ إِتّْوَاخدْجصْ
\m ؤُمْسڭّذْ ذِي ثمُّورْثْ،
\m \add خنِّي\add* مَاهُو أَعفَّانْ ذ ؤُمذْنُوبْ. \x ◘ \xo 11:‏31 \xt 1 بُط. 4‏:‏17، 18\x*
\b
\b
\c 12
\m 
\v 1 ونِّي إِتّخْسنْ تَّارْبِييّثْ،
\m إِتّخْسْ ثُوسّْنَا،
\m \add مَاشَا\add* ونِّي إِشَارّْهنْ أَوبّخْ
\m أَقَا نتَّا ذ أَقفُّوحْ.
\m 
\v 2 بْنَاذمْ ذ أَصبْحَانْ إِتَّافْ أَرْضَا ن سِيذِي،
\m \add مَاشَا\add* أَرْيَازْ إِنكّْوَانْ ثَاحْرَايْمشْثْ
\m أَذْ ث إِبَارّحْ ذ بُو-ؤُمَارْوَاسْ.
\m 
\v 3 بْنَاذمْ وَارْ إِزمَّارْ
\m أَذْ إِقِّيمْ إِبدّْ ؤُمِي إِتّڭّْ ڒْغَارْ،
\m \add مَاشَا\add* أَژْوَارْ ن إِمْسڭَّاذنْ
\m وَارْ إِزمَّارْ أَذْ إِنْهزّْ. \x ◘ \xo 12:‏3 \xt أَوڒن. 10‏:‏25\x*
\b
\m 
\v 4 ثَامْغَارْثْ إِمحْضنْ
\m ذ تَّاجْ ن ورْيَازْ نّسْ،
\m \add مَاشَا\add* ثنِّي ث يَارِّينْ إِتّْسضْحَا،
\m \add ذ ثنِّي\add* أَمْ وَارصُّوضْ ذڭْ إِغْسَانْ نّسْ. \x ◘ \xo 12:‏4 \xt 1 كُور. 11‏:‏7\x*
\m 
\v 5 إِخمِّيمنْ ن إِمْسڭَّاذنْ ذ ڒْحقّْ،
\m إِخَارِّيصنْ ن إِعفَّاننْ ذ ڒْغشّْ \add مَارَّا\add*.
\m 
\v 6 أَوَاڒنْ ن إِعفَّاننْ
\m ڒبْثنْ ذڭْ إِذَامّنْ،
\m \add مَاشَا\add* أَقمُّومْ ن يِينِّي إِڭُّورنْ نِيشَانْ
\m أَذْ ثنْ إِسّنْجمْ.\x ◘ \xo 12:‏6 \xt أَوڒن. 1‏:‏11، 18؛ 11‏:‏9\x*
\m 
\v 7 إِعفَّاننْ تّْنقْڒَابنْ ؤُ وَارْ دْجِينْ عَاذْ،
\m \add مَاشَا\add* ثَادَّارْثْ ن إِمْسڭَّاذنْ
\m أَذْ ثقِّيمْ ثْبدّْ. \x ◘ \xo 12:‏7 \xt إِزهد. 37‏:‏36‏-‏40؛ أَوڒن. 11‏:‏21\x*
\m 
\v 8 إِتّْوَاسّمْغَارْ بْنَاذمْ
\m عْلَاحْسَابْ ڒْقدّْ ن ڒعْقڒْ نّسْ،
\m \add مَاشَا\add* ونِّي ذِي إِدْجَا وُوڒْ إِفَارْغنْ،
\m أَذْ إِتّْوَاسّحْقَارْ.
\m 
\v 9 إِحْڒَا ونِّي وَارْ إِحسّْبنْ
\m خْ إِخفْ نّسْ أَطَّاسْ،
\m \add مَاشَا\add* غَارسْ إِجّْ ن ؤُمْسخَّارْ،
\m خْ ونِّي إِتّْشنّْعنْ س إِخفْ نّسْ،
\m \add مَاشَا\add* أَغْرُومْ وَارْ غَارسْ يدْجِي. \x ◘ \xo 12:‏9 \xt أَوڒن. 13‏:‏7\x*
\m 
\v 10 أَمْسڭّذْ إِسّنْ
\m ڒعْمَارْ ن ڒبْهِيمثْ نّسْ،
\m \add مَاشَا\add* أَرّحْمَاثْ ن ؤُعفَّانْ قسْحنْثْ. \x ◘ \xo 12:‏10 \xt أَعَوذ. 25‏:‏4\x*
\m 
\v 11 ونِّي إِشَارّْزنْ ثَامُّورْثْ نّسْ،
\m أَذْ إِجَّاونْ س وغْرُومْ،
\m \add مَاشَا\add* ونِّي يَاردّْفنْ مِينْ إِدْجَانْ إِخْوَانْ،
\m وَارْ غَارسْ شَا وُوڒْ إِمْثنْ. \x ◘ \xo 12:‏11 \xt أَوڒن. 28‏:‏19\x*
\m 
\v 12 أَعفَّانْ إِتّخْسْ \add مِينْ إِدْجَانْ ذِي\add* ثْرَاشَّا
\m ن يِينِّي إِتّڭّنْ ڒْغَارْ،
\m \add مَاشَا\add* أَژْوَارْ ن إِمْسڭَّاذنْ
\m إِتّْغِيمَا إِتِّيشْ.
\b
\m 
\v 13 ذڭْ ؤُخطُّو ن إِينْشِيشنْ
\m \add ذَايسْ\add* إِجّْ ن ڒْفخْ ذ أَعفَّانْ،
\m \add مَاشَا\add* أَمْسڭّذْ أَذْ إِنْجمْ زِي ڒحْصَارثْ. \x ◘ \xo 12:‏13 \xt أَوڒن. 10‏:‏14؛ 18‏:‏7\x*
\m 
\v 14 زِي ڒْغِيدْجثْ ن ؤُقمُّومْ \add نّسْ\add*
\m إِتّْوَاسّْجِيونْ بْنَاذمْ س ڒْخِيرْ،
\m مِينْ د-تَّاوْينْ إِفَاسّنْ ن بْنَاذمْ
\m أَذْ غَارسْ د-إِذْوڒْ. \x ◘ \xo 12:‏14 \xt أَوڒن. 13‏:‏2\x*
\m 
\v 15 أَبْرِيذْ ن ؤُبُوهَاڒِي نِيشَانْ ذِي ثِيطَّاوِينْ نّسْ،
\m \add مَاشَا\add* ونِّي إِتّسْڒَانْ إِ شّْوَارْ،
\m أَقَا نتَّا ذ أَمِيغِيسْ. \x ◘ \xo 12:‏15 \xt أَوڒن. 3‏:‏7\x*
\m 
\v 16 أَبُوهَاڒِي إِسّْشَانَا ڒْهمّْ نّسْ
\m ذڭْ وَاسّْ ذ إِجّْ،
\m \add مَاشَا\add* ونِّي إِفتّْننْ،
\m إِتّْذَاڒَا ڒحْيَا نّسْ.
\m 
\v 17 ونِّي د-إِنطّْقنْ ثِيذتّْ،
\m إِسّْشَانَا ثَاسڭْذَا،
\m \add مَاشَا\add* أَشهَّاذْ إِسّْخَارِّيقنْ
\m \add إِسّْشَانَا\add* أَشْمَاثْ. \x ◘ \xo 12:‏17 \xt أَوڒن. 14‏:‏5\x*
\m 
\v 18 أَقَا ذِينْ ونِّي إِتّْهَارْوَاضنْ
\m أَمْ ثجِّيثْ ن سِّيفْ،
\m \add مَاشَا\add* إِڒسْ ن إِمِيغِيسنْ
\m إِتَّاوِي-د أَڭنْفُو. \x ◘ \xo 12:‏18 \xt إِزهد. 57‏:‏5؛ 59‏:‏8؛ أَوڒن. 16‏:‏27\x*
\m 
\v 19 إِينْشِيشنْ \add إِشُّورنْ س\add* ثِيذتّْ
\m أَذْ تّْوَاضْمنْ إِ ڒبْذَا،
\m \add مَاشَا\add* إِڒسْ إِسّْخَارِّيقنْ \add مْغِيرْ\add*
\m إِ يِيجّْ ن ؤُمُورْ وَاهَا.
\m 
\v 20 أَشْمَاثْ أَقَا-ث ذڭْ وُوڒْ
\m ن يِينِّي إِنكّْوَانْ ثُوعفّْنَا،
\m \add مَاشَا\add* إِ يِينِّي إِنسّْحنْ ڒهْنَا،
\m \add أَقَا ذِينْ\add* ڒفْرَاحثْ.
\m 
\v 21 أَمْسڭّذْ وَارْ ث إِڒقّفْ ڒْغشّْ،
\m \add مَاشَا\add* إِعفَّاننْ أَذْ تّْوَاشُّورنْ س ڒْغَارْ.
\m 
\v 22 إِينْشِيشنْ إِسْخَارِّيقنْ ذ نّْعِي إِ سِيذِي،
\m \add مَاشَا\add* إِنِّي إِتّمْصُورُّوفنْ س ڒَامَانْ
\m يَارْضَانْ أَسْ.
\m 
\v 23 بْنَاذمْ إِفثْننْ إِسّْذُورُّويْ ثُوسّْنَا نّسْ،
\m \add مَاشَا\add* ؤُڒْ ن إِبُوهَاڒِييّنْ
\m إِسْغُويُّو س ثُوبُّوهڒْيَا ذِي ڒخْڒَا. \x ◘ \xo 12:‏23 \xt أَوڒن. 13‏:‏16؛ 15‏:‏2\x*
\m 
\v 24 أَفُوسْ ن ونِّي إِمحْضنْ أَذْ إِحْكمْ،
\m \add مَاشَا\add* ڒعْڭزْ إِندّهْ غَارْ ثسْمُوغِي. \x ◘ \xo 12:‏24 \xt أَوڒن. 10‏:‏4\x*
\m 
\v 25 أَمْنُوسْ ذڭْ وُوڒْ ن بْنَاذمْ
\m إِسّْهكّْوَا إِ-ث،
\m \add مَاشَا\add* أَوَاڒْ إِصبْحنْ إِسّْفَارَّاحْ إِ-ث. \x ◘ \xo 12:‏25 \xt أَوڒن. 15‏:‏13\x*
\m 
\v 26 أَمْسڭَّاذْ إِسّْشَانَا أَبْرِيذْ إِ جَّارْ نّسْ،
\m \add مَاشَا\add* أَبْرِيذْ ن ؤُعفَّانْ
\m يَارَّا إِ-ثنْ أَذْ ودَّارنْ.
\m 
\v 27 أَمعْڭُوزْ وَارْ إِضفَّارْ شَا أَنيْمَارْ نّسْ.
\m \add مَاشَا\add* أَڭْڒَا إِغْڒَانْ ن إِوْذَانْ أَقَا ذ أَمْحَاضْ.
\m 
\v 28 ذڭْ ؤُمسْرُوقْ ن ثْسڭْذَا \add ثدْجَا\add* ثُوذَارْثْ،
\m أَبْرِيذْ ن ڒَاثَارْ نّسْ وَارْ ذَايسْ بُو ڒْموْثْ.
\b
\b
\c 13
\s1 أَوَاڒنْ إِوزّْننْ ن سُولِيمَانْ - ثَاسْغَارْثْ 1ب
\m 
\v 1 إِجّْ ن مِّيسْ ذ أَمِيغِيسْ
\m \add ذ صِّيفثْ ن\add* ؤُوبّخْ ن بَابَاسْ،
\m \add مَاشَا\add* أَمسْثهْزِييْ
\m وَارْ إِتّسْڒِي غَارْ ؤُثخْثِيخْ.
\m 
\v 2 زِي ڒْغِيدْجثْ ن وَاوَاڒنْ نّسْ
\m أَذْ يشّْ بْنَاذمْ ڒْخَارْ،
\m \add مَاشَا\add* ڒعْمَارْ ن إِغدَّارنْ
\m \add أَذْ يشّْ\add* لْعُونْفْ. \x ◘ \xo 13:‏2 \xt أَوڒن. 12‏:‏14\x*
\m 
\v 3 ونِّي يسَّارنْ أَقمُّومْ نّسْ،
\m إِحطَّا ڒعْمَارْ نّسْ،
\m \add مَاشَا\add* ونِّي يَارزّْمنْ
\m إِينْشِيشنْ نّسْ أَطَّاسْ،
\m \add إِتّْرَاجَا\add* ث ؤُهلّكْ.
\m 
\v 4 ڒعْمَارْ ن ؤُمعْڭُوزْ يَارْجفْ،
\m \add وَاخَّا أَيَا\add* وَارْ إِنفّعْ ذِي وَالُو،
\m \add مَاشَا\add* ڒعْمَارْ ن يِينِّي إِتّْشطَّارنْ
\m أَذْ إِتّْوَاسّْجِيوْننْ.
\m 
\v 5 أَوَاڒنْ ن إِخَارِّيقنْ
\m إِشَارّهْ إِ-ثنْ ؤُمْسڭّذْ،
\m \add مَاشَا\add* أَعفَّانْ إِسَّارْزَاڭْ إِخفْ نّسْ
\m ؤُ إِسّْفطَّاحْ \add إِنّغْنِي\add*.
\m 
\v 6 ثَاسڭْذَا ثْحطَّا
\m ونِّي إِڭُّورنْ أَبْرِيذْ \add نّسْ\add* نِيشَانْ،
\m \add مَاشَا\add* ثُوعفّْنَا أَذْ ث إِسّْهلّكْ أَمذْنُوبْ. \x ◘ \xo 13:‏6 \xt أَوڒن. 10‏:‏29؛ 11‏:‏3، 5، 6\x*
\b
\m 
\v 7 أَقَا ذِينْ إِنِّي إِتَّارَّانْ إِخفْ نْسنْ
\m ذ بُو-وَاڭْڒَا، \add وَاخَّا\add* وَارْ غَارْسنْ وَالُو،
\m ؤُ أَقَا ذِينْ إِنِّي إِتَّارَّانْ إِخفْ نْسنْ
\m ذ إِمزْڒَاضْ، \add وَاخَّا\add* غَارْسنْ أَطَّاسْ. \x ◘ \xo 13:‏7 \xt أَوڒن. 12‏:‏9\x*
\m 
\v 8 دّيّثْ إِ ڒعْمَارْ ن شَا ن يِيجّنْ
\m ذ أَڭْڒَا نّسْ،
\m \add مَاشَا\add* أَمزْڒُوضْ وَارْ إِتّسْڒِي شَا
\m ؤُڒَا ذ إِجّْ ن ؤُهُوذِّي.
\b
\m 
\v 9 ثَافَاوْثْ ن إِمْسڭَّاذنْ أَذْ ثَارْغْ س ڒفْرَاحثْ،
\m \add مَاشَا\add* ڒفْنَارْ ن إِعفَّاننْ أَذْ إِخْسِي. \x ◘ \xo 13:‏9 \xt أَيُوبْ 18‏:‏5، 6؛ 21‏:‏17؛ أَوڒن. 4‏:‏18\x*
\m 
\v 10 زِي ثْنفْسشْثْ إِتَّاسْ-د مْغِيرْ ؤُمنْغِي،
\m \add مَاشَا\add* إِنِّي إِكسِّينْ أَشَاوَارْ، غَارْسنْ ثِيغِيثْ.
\m 
\v 11 أَڭْڒَا ن ذغْيَا، أَذْ يِيڒِي ذْرُوسْ،
\m \add مَاشَا\add* ونِّي إِيَارّْونْ س ؤُفُوسْ،
\m أَذْ يَارْبحْ. \x ◘ \xo 13:‏11 \xt أَوڒن. 10‏:‏2؛ 20‏:‏21\x*
\b
\m 
\v 12 ڒَايَاسْ يُويْڒنْ إِسّْعِيدْجْ ؤُڒْ،
\m \add مَاشَا\add* ثْوَارِّيثْ ن مژْرِي إِشُّورنْ،
\m أَقَا ت ذ ثَاشجَّارْثْ ن ثُوذَارْثْ. \f ◼ \fr 13:‏12 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*
\m 
\v 13 ونِّي إِسّحْقَارَانْ أَوَاڒْ،
\m أَذْ زَّايسْ إِتّْوَاقّنْ،
\m \add مَاشَا\add* ونِّي إِتّڭّْوذنْ ثَاوْصيّثْ،
\m أَذْ إِتّْوَاخدْجصْ.
\m 
\v 14 ثَاغُورِي ن ؤُمِيغِيسْ ذ ڒْعُونْصَارْ ن ثُوذَارْثْ،
\m مَاحنْذْ أَذْ يَاڒْوڒْ \add بْنَاذمْ\add*
\m إِ ثخْشِيفِينْ ن ڒْموْثْ. \x ◘ \xo 13:‏14 \xt أَوڒن. 10‏:‏11؛ 14‏:‏27\x*
\b
\m 
\v 15 ڒعْقڒْ إِصبْحنْ إِتَّاوِي-د أَرْضَا،
\m \add مَاشَا\add* أَبْرِيذْ ن إِغدَّارنْ
\m أَقَا إِقْسحْ أَطَّاسْ.
\m 
\v 16 كُوڒْ إِجّنْ ونِّي إِفتّْننْ،
\m إِخدّمْ س ثُوسّْنَا،
\m \add مَاشَا\add* أَبُوهَاڒِي إِتّْبزَّاعْ ثَاغْيُوڒِي \add نّسْ\add*.\x ◘ \xo 13:‏16 \xt أَوڒن. 12‏:‏23؛ 15‏:‏2\x*
\m 
\v 17 أَمْسخَّارْ أَعفَّانْ إِوطَّا ذِي ڒْغَارْ،
\m \add مَاشَا\add* أَمْسخَّارْ ذ أَمْثِيقِّي
\m \add إِتَّاوِي-د\add* أَڭنْفُو.
\m 
\v 18 زّْڒضْ ذ ڒفْضِيحثْ أَقَا أَثنْ
\m إِ ونِّي يُوڭِينْ تَّارْبِييّثْ،
\m \add مَاشَا\add* ونِّي إِكْسِينْ أَوبّخْ
\m \add غَارْ وُوڒْ نّسْ\add*، أَذْ إِتّْوَاوقَّارْ. \x ◘ \xo 13:‏18 \xt أَوڒن. 15‏:‏32\x*
\b
\m 
\v 19 إِجّْ ن ؤُسِيثمْ إِشُّورنْ ذ أَمِيژِيذْ إِ ڒعْمَارْ،
\m \add مَاشَا\add* إِ إِبُوهَاڒِييّنْ ذ نّْعِي
\m مَاحنْذْ أَذْ حيّْذنْ خْ ڒْغَارْ.
\m 
\v 20 ونِّي إِڭُّورنْ أَكْ-ذ إِمِيغِيسنْ،
\m أَذْ إِذْوڒْ ذ أَمِيغِيسْ،
\m \add مَاشَا\add* ونِّي إِتّمْصُورُّوفنْ
\m أَكْ-ذ إِبُوهَاڒِييّنْ، أَذْ ث إِڒْقفْ دّدْجْ.
\m 
\v 21 ڒْغَارْ أَذْ إِضْفَارْ إِمذْنَابْ،
\m \add مَاشَا\add* أَمْسڭّذْ أَذْ ث خدْجْضنْ س ڒْخَارْ.
\m 
\v 22 ونِّي إِصبْحنْ إِتّجَّا ثَاسْغَارْثْ إِ وَايَّاونْ نّسْ،
\m \add مَاشَا\add* أَڭْڒَا ن أَيْثْ-بُو-دّْنُوبْ
\m إِتّْوَاخمّڒْ إِ ؤُمْسڭّذْ. \x ◘ \xo 13:‏22 \xt أَيُوبْ 15‏:‏29؛ 27‏:‏17\x*
\b
\m 
\v 23 أَرْبرْ ن إِمزْڒَاضْ
\m إِتَّاوِي-د مَاشَّا س وَاطَّاسْ،
\m \add مَاشَا\add* أَقَا ذِينْ إِنِّي إِتّْوَاهلّْكنْ
\m ڒَْامِي \add ذِينْ\add* أَنْقَاسْ ن ڒْحقّْ. \x ◘ \xo 13:‏23 \xt أَوڒن. 12‏:‏11؛ 18‏:‏9\x*
\m 
\v 24 ونِّي إِمنّْعنْ أَعْمُوذْ نّسْ،
\m إِشَارْهْ مِّيسْ،
\m \add مَاشَا\add* ونِّي ث إِتّخْسنْ،
\m إِتّكَّارْ أَكِيذسْ إِتّْوبّخْ إِ-ث ذِي ڒْوقْثْ. \x ◘ \xo 13:‏24 \xt أَوڒن. 23‏:‏13\x*
\m 
\v 25 أَمْسڭّذْ أَذْ إِشّْ
\m أَڒْ غَا إِجَّاونْ ڒعْمَارْ نّسْ،
\m \add مَاشَا\add* أَعذِّيسْ ن إِعفَّاننْ
\m أَذْ إِقِّيمْ إِتّحْوَاجَا \add ڒبْذَا\add*.
\b
\b
\c 14
\m 
\v 1 ثِيغِيثْ ن ثمْغَارِينْ
\m ثْبنَّا ثَادَّارْثْ نّسْ،
\m \add مَاشَا\add* ثُوبُّوهڒْيَا ثْهدّمْ إِ-ت
\m س إِفَاسّنْ نّسْ.
\m 
\v 2 ونِّي إِڭُّورنْ ذِي ڒصْفَايثْ نّسْ،
\m إِتّڭّْوذْ سِيذِي،
\m \add مَاشَا\add* ونِّي إِتّفّْغنْ زڭْ إِبْرِيذنْ نّسْ،
\m إِسّحْقَارَا إِ-ث. \x ◘ \xo 14:‏2 \xt أَيُوبْ 12‏:‏4\x*
\m 
\v 3 ذڭْ ؤُقمُّومْ ن ؤُبُوهَاڒِي
\m \add أَقَا ذِينْ\add* ڒْمشْعضْ إِ نّْفَاخثْ \add نّسْ\add*،
\m \add مَاشَا\add* إِينْشِيشنْ ن إِمِيغِيسنْ حطَّانْ ثنْ.
\b
\m 
\v 4 مَانِي وَارْ دْجِينْ إِفُونَاسنْ،
\m إِتّْغِيمَا ڒْمذْوذْ إِخْوَا
\m \add مَاشَا\add* س جّهْذْ ن ؤُفُونَاسْ
\m أَقَا ذِينْ صَّابثْ ثمْغَارْ.
\b
\m 
\v 5 أَشهَّاذْ ذ ثِيذتّْ وَارْ إِسّْخَارِّيقْ شَا،
\m \add مَاشَا\add* أَشهَّاذْ إِسّْخَارِّيقنْ
\m إِتّْسُوضْ إِخَارِّيقنْ. \x ◘ \xo 14:‏5 \xt ؤُف. 23‏:‏1؛ أَوڒن. 12‏:‏17\x*
\m 
\v 6 إِ ؤُمسْثهْزِييْ وَارْ ذِينْ ثِيغِيثْ
\m خْمِي ت يَارزُّو،
\m \add مَاشَا\add* إِ ؤُفهَّامْ إِهْونْ \add خَاسْ\add*،
\m \add مَاحنْذْ أَذْ يَافْ\add* ثُوسّْنَا.
\b
\m 
\v 7 أَڭّْوجْ خْ ورْيَازْ أَبُوهَاڒِي،
\m \add مَاغَارْ\add* شكْ وَارْ \add غَارسْ\add* ثتِّيفذْ شَا
\m إِينْشِيشنْ \add إِ إِسَّاوَاڒنْ\add* ثُوسّْنَا.
\m 
\v 8 ثِيغِيثْ ن ونِّي إِفتّْننْ
\m أَقَا-ت ذ ڒفْهَامثْ
\m ن وبْرِيذْ \add ن يِيخفْ\add* نّسْ،
\m \add مَاشَا\add* ثُوبُّوهڒْيَا ن إِبُوهَاڒِييّنْ ذ أَشْمَاثْ.
\m 
\v 9 إِبُوهَاڒِييّنْ سْثهْزَانْ
\m س \add وعْذَاڒْ\add* ن ؤُمَارْوَاسْ،
\m \add مَاشَا\add* جَارْ إِنِّي إِڭُّورنْ نِيشَانْ
\m إِتّْوَافْ ڒْخَاضَارْ.
\b
\m 
\v 10 ؤُڒْ إِسّنْ ثَارْزُوڭِي نّسْ،
\m ڒْْبَارَّانِي وَارْ إِزمَّارْ
\m أَذْ يَاشَا س ڒفْرَاحثْ نّسْ.
\m 
\v 11 ثَادَّارْثْ ن إِعفَّاننْ أَذْ ثتّْوَاردّدْجْ،
\m \add مَاشَا\add* ثَاقِيضُونْثْ ن إِنِّي إِڭُّورنْ نِيشَانْ
\m أَذْ ثنّوَّارْ.
\m 
\v 12 أَذْ ثَاغْ إِتّْغِيڒْ أَسْ إِ شَا ن يِيجّنْ
\m أَقَا أَبْرِيذْ نِيشَانْ،
\m \add مَاشَا\add* أَنڭَّارْ نّسْ \add مْغِيرْ\add* إِبْرِيذنْ
\m \add إِتَّاوْينْ\add* غَارْ ڒْموْثْ. \x ◘ \xo 14:‏12 \xt أَوڒن. 16‏:‏25\x*
\m 
\v 13 وَاخَّا غَارْ وضْحَاشْ ؤُڒْ إِتّڭّْ ڒحْرِيقْ،
\m \add وَاهْ\add*، أَنڭَّارُو ن ڒفْرَاحثْ
\m ثتَّاكّْوَاضْ-د أَشْضَانْ. \x ◘ \xo 14:‏13 \xt أَوڒن. 5‏:‏4\x*
\b
\m 
\v 14 ونِّي غَارْ إِدْجَا وُوڒْ إِفّْغنْ زڭْ وبْرِيذْ،
\m أَذْ إِتّْوَاسّْجِيونْ س إِبْرِيذنْ نّسْ،
\m ؤُ أَرْيَازْ أَصبْحَانْ س يِيخفْ نّسْ. \x ◘ \xo 14:‏14 \xt أَوڒن. 1‏:‏31\x*
\m 
\v 15 ونِّي إِدْجَانْ ذ أَحَافِي، إِتَّامنْ ذِي كُوڒْ أَوَاڒْ،
\m \add مَاشَا\add* ونِّي إِفتّْننْ إِحطَّا أَصُورِيفْ نّسْ.
\m 
\v 16 أَمِيغِيسْ إِتّڭّْوذْ ؤُ إِتّْحيَّاذْ خْ ڒْغَارْ،
\m \add مَاشَا\add* أَبُوهَاڒِي إِسعَّارْ،
\m ؤُمِي إِتّْغِيڒْ أَسْ أَقَا-ث ذِي ڒَامَانْ.
\m 
\v 17 ونِّي إِتّْخيَّاقنْ ذغْيَا،
\m أَذْ إِڭّْ ثُوبُّوهڒْيَا،
\m ؤُ أَرْيَازْ إِنكّْوَانْ ثَاحْرَايْمشْثْ،
\m أَذْ إِتّْوَاشَارْهْ.
\m 
\v 18 إِحَافِييّنْ أَذْ وَارْثنْ ثُوبُّوهڒْيَا،
\m \add مَاشَا\add* إِنِّي إِفتّْننْ،
\m أَذْ أَسنْ قّْننْ س إِجّْ ن تَّاجْ ن ثُوسّْنَا.
\m 
\v 19 إِغشَّاشنْ أَذْ أَضَارنْ
\m زَّاثْ إِ وُوذمْ ن إِصبْحَاننْ،
\m إِعفَّاننْ \add أَذْ أَضَارنْ\add*
\m زَّاثْ إِ ثوُّورَا ن إِمْسڭَّاذنْ.
\b
\m 
\v 20 أَمزْڒُوضْ إِشَارّهْ إِ-ث \add عَاذْ\add*
\m ؤُمدُّوكّڒْ نّسْ،
\m \add مَاشَا\add* أَطَّاسْ ذ إِنِّي إِتّخْسنْ أَيْثْ ن بُو-وَاڭْڒَا. \x ◘ \xo 14:‏20 \xt أَوڒن. 19‏:‏4، 7\x*
\m 
\v 21 ونِّي إِسّحْقَارَانْ جَّارْ نّسْ،
\m إِتّڭّْ دّْنُوبْ،
\m \add مَاشَا\add* سّعْذْ ن ونِّي إِتّْحِينَّانْ
\m خْ إِنِّي إِتّْوَاحْصَارنْ.
\m 
\v 22 إِنِّي د-إِخدْجْقنْ ڒْغَارْ،
\m مَا وَارْ تّْودَّارِينْ نِيثْنِي؟
\m ثَامخْسِيوْثْ إِشوَّارنْ ذ ڒَامَانْ
\m أَقَا غَارْ يِينِّي إِتّْخَارَّاصنْ
\m ذِي مِينْ إِصبْحنْ. \x ◘ \xo 14:‏22 \xt لك. 6‏:‏38\x*
\b
\m 
\v 23 ذِي مَارَّا ڒْوحْڒَانْ ن وَارْبرْ ذَايسْ ڒفْضڒْ،
\m \add مَاشَا\add* ڒْهَارْذْ ن إِينْشِيشنْ
\m إِندّهْ غَارْ وحْوَاجْ وَاهَا. \f ◼ \fr 14:‏23 \ft \bd ’ڒْهَارْذْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَوَاڒْ‘.\f*
\m 
\v 24 تَّاجْ ن إِمِيغِيسنْ ذ أَڭْڒَا نْسنْ،
\m ثُوبُّوهڒْيَا ن إِبُوهَاڒِييّنْ
\m ذ ثُوبُّوهڒْيَا \add وَاهَا\add*.
\m 
\v 25 أَشهَّاذْ أَمْثِيقِّي إِسّنْجَامْ ڒعْمُورْ،
\m \add مَاشَا\add* ونِّي يَارخُّونْ إِ إِخَارِّيقنْ،
\m إِشمّثْ.
\m 
\v 26 ذِي ثِيڭّْوُوذِي ن سِيذِي \add ذَايسْ\add* تِّيقثْ إِجهْذنْ،
\m نتَّا أَذْ يِيڒِي ذ أَمْشَانْ ن ثَاروْڒَا
\m إِ إِحنْجِيرنْ نّسْ.
\m 
\v 27 ثِيڭّْوُوذِي ن سِيذِي ذ ڒْعُونْصَارْ ن ثُوذَارْثْ،
\m إِ ؤُسنْجمْ زڭْ إِشذِّيينْ ن ڒْموْثْ. \x ◘ \xo 14:‏27 \xt أَوڒن. 10‏:‏11؛ 13‏:‏14\x*
\m 
\v 28 ذڭْ وَاطَّاسْ ن ڒْڭنْسْ
\m \add إِخمّڒْ\add* ؤُشوَّارْ ن ؤُجدْجِيذْ،
\m \add مَاشَا\add* ذِي ثِيكّسْثْ ن شّعْبْ
\m \add إِخمّڒْ\add* ؤُهلّكْ نْ ڒْحَاكمْ.
\m 
\v 29 ونِّي غَارْ إِدْجَا تَّاسِيعْ ن ڒْخَاضَارْ،
\m غَارسْ ڒفْهَامثْ ثمْغَارْ،
\m \add مَاشَا\add* ونِّي ذِي إِدْجَا بُوحْبڒْ إِحْصَارنْ
\m إِسّكَّارْ ثُوبُّوهڒْيَا.
\m 
\v 30 ؤُڒْ إِصّحْ، أَقَا ذ ثُوذَارْثْ إِ أَرِّيمثْ،
\m \add مَاشَا\add* ثُوسْمِي ذ أَرصُّوضْ ن يغْسَانْ.
\m 
\v 31 ونِّي إِحصَّارنْ أَمحْذَاجْ،
\m إِسّحْقَارَا ونِّي ث إِ-د-إِخڒْقنْ،
\m \add مَاشَا\add* ونِّي إِتّْحِينَّانْ خْ ؤُمزْڒُوضْ،
\m إِتّْشنّعْ إِ-ث. \x ◘ \xo 14:‏31 \xt أَوڒن. 14‏:‏21؛ 17‏:‏5\x*
\b
\m 
\v 32 أَعفَّانْ إِتَّاژّڒْ خْ يِيخفْ نّسْ
\m س ڒْغَارْ نّسْ إِ إِتّڭّْ،
\m \add مَاشَا\add* أَمْسڭّذْ غَارسْ مَانِي إِ غَا يَارْوڒْ
\m \add عَاذْ\add* ذِي ڒْموْثْ نّسْ.
\m 
\v 33 ثِيغِيثْ ثَارْسَا ذڭْ وُوڒْ ن إِفهَّامنْ،
\m \add مَاشَا\add* مِينْ إِدْجَانْ
\m ذَاخڒْ ذڭْ إِبُوهَارِييّنْ
\m أَذْ إِتّْوَاسّْننْ. \x ◘ \xo 14:‏33 \xt أَوڒن. 10‏:‏14؛ 12‏:‏23؛ 13‏:‏16\x*
\b
\m 
\v 34 ثَاسڭْذَا ثسّْعُودْجْ ڒْڭنْسْ،
\m \add مَاشَا\add* ڒفْضِيحثْ ن شُّوعُوبْ ذ دّْنُوبْ.
\m 
\v 35 ڒْخَاضَارْ ن ؤُجدْجِيذْ
\m يَارْسَا خْ ؤُمْسخَّارْ إِفهّْمنْ
\m \add مَاشَا\add* ونِّي إِفطّْحنْ
\m إِڒقّفْ إِ-ث ؤُذُوقّزْ نّسْ \add ن ؤُفُوڭمْ\add*.
\b
\b
\c 15
\s1 أَوَاڒنْ إِوزّْننْ ن سُولِيمَانْ - ثَاسْغَارْثْ 1ج
\m 
\v 1 ثْوَارِّيثْ إِفْسُوسنْ
\m ثسّسْمَاضْ أَخيّقْ،
\m \add مَاشَا\add* أَوَاڒْ إِتّقّْسنْ
\m إِسّكَّارَا-د أَخيّقْ. \x ◘ \xo 15:‏1 \xt أَوڒن. 25‏:‏15\x*
\m 
\v 2 إِڒسْ ن إِمِيغِيسنْ إِجبّذْ ثُوسّْنَا
\m غَارْ زَّاثْ،
\m \add مَاشَا\add* أَقمُّومْ ن إِبُوهَاڒِييّنْ
\m إِتَّازّڒْ س ثُوبُّوهڒْيَا. \x ◘ \xo 15:‏2 \xt أَوڒن. 12‏:‏23؛ 13‏:‏16؛ 15‏:‏28\x*
\m 
\v 3 ثِيطَّاوِينْ ن سِيذِي ذِي كُوڒْ أَمْشَانْ،
\m تّْحكَّارنْثْ إِ إِصبْحَاننْ ذ إِعفَّاننْ. \x ◘ \xo 15:‏3 \xt أَيُوبْ 34‏:‏21؛ أَوڒن. 5‏:‏21؛ إِرْم. 16‏:‏17؛ 32‏:‏19\x*
\m 
\v 4 إِڒسْ نِّي إِسّْڭنْفَانْ ذ ثَاشجَّارْثْ ن ثُوذَارْثْ،
\m \add مَاشَا\add* أَرّْهَاجْ نّسْ إِتَّارژَّا بُوحْبڒْ. \f ◼ \fr 15:‏4 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  \x ◘ \xo 15:‏4 \xt أَوڒن. 12‏:‏18؛ 13‏:‏14\x*
\m 
\v 5 أَبُوهَاڒِي إِنطَّارْ تَّارْبِييّثْ ن بَابَاسْ،
\m \add مَاشَا\add* ونِّي إِتّْحكَّارَانْ
\m إِ ؤُوبّخْ، أَقَا إِفْثنْ.
\m 
\v 6 ذِي ثَادَّارْثْ ن ؤُمْسڭَّاذْ -
\m ذَايسْ ڒْكنْزْ إِمْغَارْ،
\m \add مَاشَا\add* ذِي مِينْ د-إِتَّاوِي ؤُعفَّانْ
\m ذَايسْ ثَامَارَا.
\b
\m 
\v 7 إِينْشِيشنْ ن إِمِيغِيسنْ تّْبزَّاعنْ ثُوسّْنَا،
\m \add مَاشَا\add* ؤُڒْ ن إِبُوهَاڒِييّنْ وَارْ إِدْجِي نِيشَانْ.
\m 
\v 8 ثَاغَارْصْثْ إِ إِتّْقدَّامنْ إِعفَّاننْ
\m ذ نّْعِي إِ سِيذِي،
\m \add مَاشَا\add* ثَاژَادْجِيثْ ن إِنِّي إِڭُّورنْ نِيشَانْ
\m أَقَا-ت إِ نتَّا ذ أَرْضَا. \x ◘ \xo 15:‏8 \xt أَوڒن. 21‏:‏27؛ إِشا. 1‏:‏11؛ إِرْم. 6‏:‏20؛ عَام. 5‏:‏21\x*
\m 
\v 9 أَبْرِيذْ ن ؤُعفَّانْ ذ نّْعِي إِ سِيذِي،
\m \add مَاشَا\add* ونِّي إِضفَّارَانْ ثَاسڭْذَا،
\m إِتّخْسْ إِ-ث نتَّا.
\m 
\v 10 تَّارْبِييّثْ إِقسْحنْ ثْڒقّفْ
\m ونِّي إِسمْحنْ ذڭْ وبْرِيذْ،
\m ؤُ ونِّي إِشَارّْهنْ أَوبّخْ،
\m أَذْ إِمّثْ.
\m 
\v 11 ڒَاخَارْثْ ذ \add ثسْرَافْثْ ن\add* ؤُهلّكْ
\m \add أَقَا ذِينْ أَرزْمنْ\add* زَّاثْ إِ سِيذِي،
\m مشْحَاڒْ عَاذْ وُوڒَاونْ ن ثَارْوَا ن بْنَاذمْ؟ \x ◘ \xo 15:‏11 \xt 2 إِم. 6‏:‏30؛ إِزهد. 7‏:‏10؛ 44‏:‏22؛ إِرْم. 17‏:‏9، 10؛ يُوح. 2‏:‏24، 25؛ 21‏:‏17؛ ڒخ. 1‏:‏24\x*
\m 
\v 12 أَمسْثهْزِييْ وَارْ إِتّخْسْ
\m ونِّي ث إِ غَا إِوبّْخنْ،
\m وَارْ إِتّْرِيحْ شَا غَارْ إِمِيغِيسنْ.
\m 
\v 13 ؤُڒْ إِفَارْحنْ إِتّڭّْ ؤُذمْ إِشْنَانْ،
\m \add مَاشَا\add* أَمْنُوسْ ذڭْ وُوڒْ إِسكّفْ بُوحْبڒْ. \x ◘ \xo 15:‏13 \xt أَوڒن. 17‏:‏22؛ 18‏:‏14\x*
\m 
\v 14 ؤُڒْ إِفهّْمنْ يَارزُّو ثُوسّْنَا،
\m \add مَاشَا\add* أَقمُّومْ ن إِبُوهَاڒِييّنْ
\m إِسّشَّا إِخفْ نّسْ س ثُوبُّوهڒْيَا.
\m 
\v 15 إِ يِينِّي إِتّْوَاحْصَارنْ مَارَّا ؤُسَّانْ نْسنْ
\m أَقَا إِعفّْننْ،
\m \add مَاشَا\add* ؤُڒْ إِفَارْحنْ
\m \add أَمْ\add* إِشْثْ ن زَّارْذثْ وَارْ إِقطِّينْ.
\m 
\v 16 إِحْڒَا ذْرُوسْ أَكْ-ذ ثڭّْوُوذِي ن سِيذِي،
\m خْ إِجّْ ن ڒْكنْزْ ذ أَمقّْرَانْ س ڒحْوڒْ. \x ◘ \xo 15:‏16 \xt إِزهد. 37‏:‏16؛ أَوڒن. 16‏:‏8\x*
\m 
\v 17 إِحْڒَا إِجّْ ن طّبْصِي ن ڒْخُوضَارْثْ
\m مَانِي \add ثْحكّمْ\add* ثَايْرِي،
\m خْ إِجّْ ن ؤُينْذُوزْ إِصحّنْ أَكْ-ذ وشْرَاهْ. \x ◘ \xo 15:‏17 \xt أَوڒن. 17‏:‏1\x*
\b
\m 
\v 18 أَرْيَازْ إِتَّارُّوجْذُوذنْ
\m إِسّكَّارَا إِمنْغِييّنْ،
\m \add مَاشَا\add* ونِّي غَارْ إِدْجَا تَّاسِيعْ ن ڒْخَاضَارْ
\m إِسّخْسَايْ أَمنْغِي. \x ◘ \xo 15:‏18 \xt أَوڒن. 28‏:‏25؛ 29‏:‏22\x*
\m 
\v 19 أَبْرِيذْ ن ؤُمعْڭُوزْ
\m أَمْ شْبَارْقْ أَكْ-ذ إِسنَّاننْ،
\m \add مَاشَا\add* أَمسْرُوقْ ن يِينِّي إِڭُّورنْ نِيشَانْ
\m أَقَا إِتّْوَاسّْڭعّذْ.
\b
\m 
\v 20 مِّيسْ أَمِيغِيسْ إِسّْفَارّحْ بَابَاسْ،
\m \add مَاشَا\add* بْنَاذمْ أَبُوهَاڒِي
\m إِسّحْقَارَا يمَّاسْ. \x ◘ \xo 15:‏20 \xt أَوڒن. 10‏:‏1\x*
\m 
\v 21 ثُوبُّوهڒْيَا أَقَا-ت ذ ڒفْرَاحثْ
\m إِ ونِّي وَارْ غَارْ إِدْجِي بُو وُوڒْ إِمْثنْ،
\m \add مَاشَا\add* إِجّْ ن ورْيَازْ ن ڒفْهَامثْ
\m إِڭُّورْ نِيشَانْ. \x ◘ \xo 15:‏21 \xt أَوڒن. 10‏:‏23؛ 14‏:‏9\x*
\m 
\v 22 إِنْوَاينْ فشّْڒنْ
\m مَاڒَا وَارْ ذِينْ إِدْجِي شّْوَارْ،
\m \add مَاشَا\add* س وَاطَّاسْ ن إِمْشَاوَارنْ
\m أَذْ يِيڒِي \add ونْوَايْ\add*. \f ◼ \fr 15:‏22 \ft \bd ’إِنْوَاينْ‘\bd* - نِيغْ ’إِنكّْوَانْ‘ نِيغْ ’إِخَارِّيصنْ‘.\f*  \x ◘ \xo 15:‏22 \xt أَوڒن. 11‏:‏14\x*
\m 
\v 23 أَرْيَازْ غَارسْ ڒفْرَاحثْ
\m ذِي ثمْوَارِّيثْ إِصبْحنْ
\m زڭْ ؤُقمُّومْ نّسْ.
\m مشْحَاڒْ إِصْبحْ وَاوَاڒْ ذِي ڒْوقْثْ نّسْ!
\b
\m 
\v 24 أَبْرِيذْ ن ثُوذَارْثْ \add إِندّهْ\add*
\m غَارْ سنّجْ إِ ؤُفهَّامْ،
\m مَاحنْذْ نتَّا أَذْ إِحيّذْ
\m خْ ڒَاخَارْثْ سْوَادَّايْ.
\m 
\v 25 ثَادَّارْثْ ن بُو-نّْفَاخثْ
\m أَذْ ت إِقْڒعْ سِيذِي،
\m \add مَاشَا\add* أَيْمِيرْ \add ن ييَّارْ\add* ن ثَاجَّاتْشْ
\m إِسّمْثَانْ إِ-ث نتَّا. \x ◘ \xo 15:‏25 \xt أَوڒن. 2‏:‏21، 22؛ 12‏:‏7؛ 14‏:‏11\x*
\m 
\v 26 إِخمِّيمنْ ن ؤُعفَّانْ ذ نّْعِي إِ سِيذِي،
\m \add مَاشَا\add* أَوَاڒنْ إِشوَّارنْ ذ إِمزْذَاڭنْ. \x ◘ \xo 15:‏26 \xt أَوڒن. 6‏:‏18\x*
\m 
\v 27 ونِّي يَارزُّونْ خْ أَرْبحْ
\m إِغطّڒْ ثَادَّارْثْ نّسْ ذِي أَرّْژِييّثْ،
\m \add مَاشَا\add* ونِّي إِشَارّْهنْ ثَارْزِيفِينْ، أَذْ إِدَّارْ. \x ◘ \xo 15:‏27 \xt أَوڒن. 1‏:‏19\x*
\b
\m 
\v 28 ؤُڒْ ن إِمْسڭَّاذنْ إِتّْخَارَّاصْ
\m مَاحنْذْ أَذْ د-يَارّْ،
\m \add مَاشَا\add* أَقمُّومْ ن إِعفَّاننْ
\m إِتّْفيّضْ س ڒْغَارْ.
\m 
\v 29 إِڭّْوجْ سِيذِي خْ إِعفَّاننْ،
\m \add مَاشَا\add* ثَاژَادْجِيثْ ن إِمْسڭَّاذنْ إِتّسْڒَا أَسْ. \x ◘ \xo 15:‏29 \xt إِزهد. 10‏:‏17؛ 34‏:‏19؛ 145‏:‏18، 19\x*
\b
\m 
\v 30 ثَافَاوْثْ \add ذِي\add* ثِيطَّاوِينْ ثسّْفَارّحْ ؤُڒْ،
\m ڒخْبَارْ أَصبْحَانْ إِسّْيُومَا إِغْسَانْ. \x ◘ \xo 15:‏30 \xt أَوڒن. 25‏:‏25\x*
\m 
\v 31 أَمزُّوغْ إِتّسْڒَانْ
\m غَارْ ؤُوبّخْ إِ ثُوذَارْثْ،
\m أَذْ إِسّنْسْ ذِي ڒْوسْطْ ن إِمِيغِيسنْ.
\b
\m 
\v 32 ونِّي إِنطَّارنْ تَّارْبِييّثْ،
\m إِسّحْقَارَا إِخفْ نّسْ،
\m \add مَاشَا\add* ونِّي إِتّسْڒَانْ غَارْ ؤُوبّخْ،
\m إِسّْيَاوَانْ ؤُڒْ \add نّسْ\add*. \x ◘ \xo 15:‏32 \xt أَوڒن. 13‏:‏18\x*
\m 
\v 33 ثِيڭّْوُوذِي ن سِيذِي ذ تَّارْبِييّثْ غَارْ ثِيغِيثْ،
\m ؤُ أَوَاضعْ إِتِّيزْوَارْ إِ شَّانْ. \x ◘ \xo 15:‏33 \xt أَوڒن. 1‏:‏7؛ 9‏:‏10؛ 18‏:‏12\x*
\b
\b
\c 16
\m 
\v 1 بْنَاذمْ غَارسْ إِخَارِّيصنْ
\m ذڭْ وُوڒْ \add نّسْ\add*،
\m \add مَاشَا\add* ثَامْوَارِّيثْ ن يِيڒسْ
\m \add ثتَّاسْ-د\add* زِي سِيذِي. \x ◘ \xo 16:‏1 \xt أَوڒن. 16‏:‏1؛ 19‏:‏21؛ 20‏:‏24؛ إِرْم. 10‏:‏23\x*
\m 
\v 2 مَارَّا إِبْرِيذنْ ن ورْيَازْ
\m صْفَانْ ذِي ثِيطَّاوِينْ نّسْ،
\m \add مَاشَا\add* سِيذِي إِتّْقدْجَابْ بُوحْبڒَاثْ. \x ◘ \xo 16:‏2 \xt أَوڒن. 21‏:‏2\x*
\m 
\v 3 سَارْسْ ڒخْذَايمْ نّشْ إِ سِيذِي،
\m \add خنِّي\add* أَذْ تّْوَاسّْمتّْننْ إِنْوَاينْ نّشْ. \x ◘ \xo 16:‏3 \xt إِزهد. 37‏:‏5؛ 55‏:‏23؛ مت. 6‏:‏25؛ لك. 12‏:‏22؛ 1 بُط. 5‏:‏7\x*
\m 
\v 4 سِيذِي إِخْڒقْ-د مَارَّا إِ لْغَارَاضْ نّسْ،
\m عَاذْ ؤُڒَا ذ أَعفَّانْ \add إِڭَّا إِ-ث\add* إِ وَاسّْ ن ڒْغَارْ.\x ◘ \xo 16:‏4 \xt أَيُوبْ 21‏:‏30\x*
\b
\m 
\v 5 كُوڒْ أَمْعفَّارْ ذ نّْعِي إِ سِيذِي، أَفُوسْ خَاسْ،
\m نتَّا وَارْ إِتّتّْوَابَارِّي \add عمَّارْصْ\add*. \x ◘ \xo 16:‏5 \xt أَوڒن. 6‏:‏17؛ 8‏:‏13؛ 11‏:‏21\x*
\m 
\v 6 س ثْمخْسِيوْثْ إِشوَّارنْ ذ ڒَامَانْ
\m أَذْ إِتّْوَاسّصْڒحْ خْ ڒْغشّْ،
\m ؤُ س ثِيڭّْوُوذِي ن سِيذِي
\m إِتّْحيَّاذْ ورْيَازْ خْ ڒْغَارْ.
\m 
\v 7 مَاڒَا ؤُسِينْ-د إِبْرِيذنْ ن إِجّْ ن ورْيَازْ
\m خْ ڒْخَاضَارْ ن سِيذِي،
\m أَذْ يَارّْ نتَّا ؤُڒَا ذ ڒْعذْيَانْ نّسْ
\m أَذْ كِيذسْ ڭّنْ ڒهْنَا.
\b
\m 
\v 8 إِحْرَا ذْرُوسْ أَكْ-ذ ثْسڭْذَا
\m خْ وَاطَّاسْ ن ڒْغِيدْجثْ بْڒَا ڒْحقّْ. \x ◘ \xo 16:‏8 \xt إِزهد. 37‏:‏16؛ أَوڒن. 15‏:‏16\x*
\m 
\v 9 ؤُڒْ ن بْنَاذمْ إِتّْخَارّصْ أَبْرِيذْ نّسْ،
\m \add مَاشَا\add* سِيذِي إِندّهْ إِصُورَافْ نّسْ. \f ◼ \fr 16:‏9 \ft \bd ’إِصُورَافْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَصُورِيفْ‘.\f*
\m 
\v 10 ڒْحُوكْمْ بْڒَا أَذْوَاڒْ خْ إِينْشِيشنْ ن ؤُجدْجِيذْ،
\m أَقمُّومْ نّسْ وَارْ إِخطِّي ذڭْ وحْكَامْ.
\m 
\v 11 ڒْمِيزَانْ \add نِيشَانْ\add* ذ طَّاوْيَاثْ ن ڒْمِيزَانْ نِيشَانْ
\m أَقَا أَثنْ ن سِيذِي،
\m مَارَّا إِژْرَا ن ڒوْزنْ ذِي ثشْيَارْثْ
\m ذ ڒْخذْمثْ نّسْ. \x ◘ \xo 16:‏11 \xt لَاوِي 19‏:‏36؛ أَعَوذ. 25‏:‏13‏-‏16؛ أَوڒن. 11‏:‏1؛ 20‏:‏10، 23\x*
\m 
\v 12 ذ نّْعِي إِ إِجدْجِيذنْ خْمِي غَا ڭّنْ ڒْغَارْ،
\m مَاغَارْ ڒْعَارْشْ إِتّْوَاسّمْثنْ زِي ثْسڭْذَا.
\b
\m 
\v 13 إِينْشِيشنْ \add إِ إِشُّورنْ\add* س ثْسڭْذَا
\m تّعْجِيبنْ إِ ؤُجدْجِيذْ،
\m ؤُ ونِّي إِسَّاوَاڒنْ نِيشَانْ، إِتّخْسْ إِ-ث نتَّا.
\m 
\v 14 أَسْعَارْ ن ؤُجدْجِيذْ \add أَمْ\add* لْمَالَاكَاثْ نْ ڒْموْثْ،
\m \add مَاشَا\add* أَرْيَازْ أَمِيغِيسْ إِزمَّارْ
\m أَذْ غَارسْ ت إِ-د يَارّْ. \x ◘ \xo 16:‏14 \xt أَوڒن. 19‏:‏12؛ 20‏:‏2\x*
\m 
\v 15 ذِي ثْفَاوْثْ ن وُوذمْ \add إِتِّيسِّيقنْ\add* ن ؤُجدْجِيذْ
\m \add ثدْجَا\add* ثُوذَارْثْ،
\m أَرْضَا نّسْ أَمْ ؤُسيْنُو ن ونْژَارْ
\m ذِي ثفْسُوثْ. \x ◘ \xo 16:‏15 \xt أَوڒن. 19‏:‏12\x*
\b
\m 
\v 16 أَقَا ثحْڒَا ثَارزُّوثْ ن ثِيغِيثْ
\m خْ وُورغْ إِتِّيسِّيقنْ،
\m ؤُ \add مشْحَاڒْ كْثَارْ\add* أَذْ ثِيڒِي ثْوَافِيثْ ن ڒفْهَامثْ
\m سنّجْ خْ \add ثْوَافِيثْ ن\add* نُّوقَارْثْ. \x ◘ \xo 16:‏16 \xt أَيُوبْ 28‏:‏15؛ إِزهد. 19‏:‏11؛ 119‏:‏72؛ أَوڒن. 3‏:‏14، 15؛ 8‏:‏11، 19\x*
\m 
\v 17 أَبْرِيذْ ن يِينِّي إِڭُّورنْ نِيشَانْ
\m إِتّْحيَّاذْ خْ ڒْغَارْ.
\m ونِّي إِحطَّانْ أَبْرِيذْ نّسْ،
\m إِحطَّا ڒعْمَارْ نّسْ.
\m 
\v 18 ثَانفْسشْثْ ثتِّيزْوَارْ-د إِ أَرْژِّييّثْ،
\m ؤُ نّْفَاخثْ ثتَّاسْ-د قْبڒْ إِ ؤُوطُّو. \x ◘ \xo 16:‏18 \xt أَوڒن. 11‏:‏2؛ 17‏:‏19\x*
\m 
\v 19 إِحْڒَا أَقْنَاعْ ن بُوحْبڒْ
\m أَكْ-ذ إِنِّي إِتّْوَاحْصَارنْ،
\m خْ ؤُبطُّو ن ثْكشَّاضْثْ أَكْ-ذ أَيْثْ-نّْفَاخثْ.
\m 
\v 20 ونِّي إِتّْخَارَّاصنْ مْلِيحْ
\m ذِي شَا ن ثْمسْڒَاشْثْ، أَذْ يَافْ ڒْخَارْ،
\m سّعْذْ ن ونِّي إِتّْشَاڒَانْ خْ سِيذِي.\x ◘ \xo 16:‏20 \xt إِزهد. 2‏:‏12؛ 34‏:‏9؛ 125‏:‏1؛ إِشا. 30‏:‏18؛ إِرْم. 17‏:‏7\x*
\b
\m 
\v 21 ونِّي غَارْ إِدْجَا وُوڒْ ذ أَمِيغِيسْ،
\m أَذْ ث سمَّانْ بُو-وفْثَانْ،
\m ؤُ ثَاژْيُوذِي \add ن ڒْهَارْذْ\add* ن إِينْشِيشنْ
\m ثَارنِّي ذِي ڒفْهَامثْ.
\m 
\v 22 ڒعْقڒْ ذ ڒْعُونْصَارْ ن ثُوذَارْثْ إِ بَابْ نّسْ،
\m \add مَاشَا\add* تَّارْبِييّثْ إِ إِبُوهَاڒِييّنْ
\m ذ ثُوبُّوهڒْيَا \add وَاهَا\add*.\x ◘ \xo 16:‏22 \xt أَوڒن. 13‏:‏14\x*
\m 
\v 23 ؤُڒْ ن ؤُمِيغِيسْ إِتَّارَّا أَقمُّومْ نّسْ إِفهّمْ،
\m زڭْ إِينْشِيشنْ نّسْ أَذْ فهْمنْ كْثَارْ.
\m 
\v 24 أَوَاڒنْ إِشوَّارنْ
\m \add ڭِّينْ أَمْ\add* ثَامّنْثْ ن ثغْرَاسْثْ،
\m \add أَقَا أَثنْ\add* ذ إِمِيژِيذنْ إِ ڒعْمَارْ
\m ذ ؤُڭنْفُو إِ يغْسَانْ.
\b
\m 
\v 25 أَذْ ثَاغْ إِتّْغِيڒْ أَسْ إِ شَا ن يِيجّنْ
\m أَقَا أَبْرِيذْ نّسْ نِيشَانْ،
\m \add مَاشَا\add* أَنڭَّارْ نّسْ \add مْغِيرْ\add* إِبْرِيذنْ
\m \add إِتَّاوْينْ\add* غَارْ ڒْموْثْ. \x ◘ \xo 16:‏25 \xt أَوڒن. 14‏:‏12\x*
\m 
\v 26 ڒَاژْ ن ؤُشوَّاڒْ إِخدّمْ أَسْ إِ نتَّا،
\m مَاغَارْ أَقمُّومْ نّسْ إِندّهْ إِ-ث.
\m 
\v 27 أَرْيَازْ إِ وَارْ إِسكّْوِينْ إِغزَّا ڒْغَارْ،
\m خْ إِينْشِيشنْ نّسْ
\m أَمْ يِيشْثْ ن ثْمسِّي إِتّْشعَّاڒنْ. \x ◘ \xo 16:‏27 \xt أَوڒن. 12‏:‏18\x*
\m 
\v 28 أَرْيَازْ \add إِشُّورنْ\add* س ڒخْذَاعَاثْ
\m إِسّكَّارَا أَمنْغِي،
\m ؤُ أَخْبَارْجِي إِتَّاوِي-د \add عَاذْ\add* أَبطُّو
\m أَكْ-ذ ؤُمدُّوكّڒْ إِصبْحنْ أَطَّاسْ. \x ◘ \xo 16:‏28 \xt أَوڒن. 15‏:‏18؛ 26‏:‏21؛ 29‏:‏22\x*
\m 
\v 29 أَرْيَازْ بُو-ڒخْشُونثْ إِتّْغَارَّا جَّارْ نّسْ،
\m إِندّهْ إِ-ث غَارْ إِجّْ ن وبْرِيذْ
\m إِ وَارْ إِدْجِينْ مْلِيحْ.
\m 
\v 30 نتَّا إِتّقّنْ ثِيطَّاوِينْ نّسْ
\m مَاحنْذْ أَذْ إِخَارّصْ
\m مَارَّا دَّارْبَاثْ ن ڒخْذَاعثْ،
\m إِتّْكمّشْ إِينْشِيشنْ نّسْ،
\m \add أَقَا ذَا\add* إِڭَّا ڒْغَارْ. \x ◘ \xo 16:‏30 \xt أَوڒن. 6‏:‏13، 14\x*
\b
\m 
\v 31 أَشُوَّافْ إِشَابنْ ذ إِجّْ ن تَّاجْ إِزوّْقنْ،
\m ثْزمَّارذْ أَذْ ت ثَافذْ خْ وبْرِيذْ ن ثْسڭْذَا.
\m 
\v 32 إِحْڒَا بُو-تَّاسِيعْ ن ڒْخَاضَارْ
\m خْ إِجّْ ن ورْيَازْ إِجهْذنْ
\m ؤُ ونِّي إِتّبَّاثنْ بُوحْبڒْ نّسْ \add إِحْڒَا\add*
\m خْ ونِّي إِحوّْسنْ إِشْثْ ن ثنْذِينْثْ.
\m 
\v 33 ثَاقدُّوحْثْ ثمّنْضَارْ ذڭْ وحْسِينْ،
\m \add مَاشَا\add* مْكُوڒْ أَرَّايْ إِتَّاسْ-د زِي سِيذِي.
\b
\b
\c 17
\m 
\v 1 إِحْڒَا إِجّْ ن ؤُزعِّيفْ ن وغْرُومْ
\m يُوژْغنْ أَكْ-ذ ڒهْنَا،
\m خْ إِشْثْ ن ثَادَّارْثْ ثشُّورْ س ثْغَارْصَا،
\m ذَايسْ أَمنْغِي. \x ◘ \xo 17:‏1 \xt أَوڒن. 15‏:‏17\x*
\m 
\v 2 إِجّْ ن يِيسْمغْ إِفثْننْ أَذْ إِضبَّارْ
\m خْ إِجّْ ن مِّيسْ نِّي إِتَّاوْينْ غَارْ ڒفْضِيحثْ،
\m ذِي ڒْوسْطْ ن يَايْثْمَاسْ أَذْ إِبْضَا نتَّا ڒْوَارْثْ.
\m 
\v 3 أَطنْجِيرْ ن ؤُسفْسِي إِ نُّوقَارْثْ
\m ؤُ أَفَارَّانْ إِ وُورغْ،
\m \add مَاشَا\add* سِيذِي إِتّْجَارَّابْ ؤُڒَاونْ. \x ◘ \xo 17:‏3 \xt أَوڒن. 27‏:‏21؛ إِرْم. 17‏:‏10\x*
\m 
\v 4 أَعفَّانْ إِخزَّارْ غَارْ إِينْشِيشنْ إِعفَّاننْ،
\m بُو-إِخَارِّيقنْ إِتِّيشْ أَمزُّوغْ
\m إِ يِيڒسْ إِشُّورنْ س ڒْغشّْ.
\m 
\v 5 ونِّي إِتّْحشّنْ خْ ؤُمزْڒُوضْ،
\m إِسّْفطّحْ ونِّي ث-إِ-د-إِخڒْقنْ،
\m ونِّي إِفَارّْحنْ خْ أَرْژِييّثْ،
\m وَارْ إِتّْوِيحْسِيبْ ذ أَمزْذَاڭْ. \x ◘ \xo 17:‏5 \xt أَوڒن. 14‏:‏31\x*
\m 
\v 6 تَّاجْ ن إِوسُّورَا ذ أَيَّاونْ،
\m ثَالْوِيزْثْ ن إِحنْجِيرنْ ذ إِبَابَاثنْ نْسنْ.
\b
\m 
\v 7 أَينْشِيشْ ن شَّانْ
\m وَارْ د-إِتِّيسْ أَكْ-ذ ؤُبُوهَاڒِي،
\m \add خنِّي\add*عسَّاكْ عَاذْ أَينْشِيشْ إِسّْخَارِّيقنْ
\m أَكْ-ذ ؤُمْشنّعْ.
\m 
\v 8 ثَارْزفْثْ ن أَرّشْوثْ
\m ذ إِجّْ ن وژْرُو إِزوّْقنْ
\m ذِي ثِيطَّاوِينْ ن بَابْ نّسْ،
\m مَانِي مَا يَارَّا س ؤُزدْجِيفْ، إِتّفْڒِيحْ.
\m 
\v 9 ونِّي إِسّْذُورُّوينْ أَخطُّو،
\m يَارزُّو ثَايْرِي،
\m \add مَاشَا\add* ونِّي إِتّْعَاوَاذنْ
\m إِشْثْ ن ڒْحَاجّثْ زِي جْذِيذْ،
\m إِبطَّا إِمدُّوكَّاڒْ إِشْنَانْ.
\m 
\v 10 إِتّْقَارَّا ؤُثخْثخْ خْ ؤُفهَّامْ
\m أَطَّاسْ خْ مْيَا ن ثيِّيثَا خْ يِيجّْ ن ؤُبُوهَاڒِي.
\b
\m 
\v 11 أَمْغوّغْ يَارزُّو مْغِيرْ خْ ڒْغَارْ،
\m \add خْ ؤُيَا\add* أَذْ غَارسْ د-إِتّْوَاسّكّْ
\m إِجّْ ن ؤُمْسخَّارْ إِقسْحنْ ضِيدّْ نّسْ.
\m 
\v 12 أجّْ أَذْ إِمّڒْقَا شَا ن دُّوبْ
\m إِ ؤُمِي تّْوَاشَارنْ ثَارْوَا أَكْ-ذ شَا ن يِيجّنْ،
\m \add مَاشَا\add* وَارْ إِدْجِي أَبُوهَاڒِي ذِي ثُوبُّوهڒْيَا نّسْ.
\m 
\v 13 ونِّي إِتّْخدْجَاصنْ مِينْ إِصبْحنْ س ڒْغَارْ،
\m وَارْ ثتّْحيِّيذْ أَرْژِييّثْ خْ ثَادَّارْثْ نّسْ. \x ◘ \xo 17:‏13 \xt أَعَوذ. 32‏:‏35؛ أَوڒن. 20‏:‏22؛ 24‏:‏29؛ رُوم. 12‏:‏17؛ 1 تس. 5‏:‏15؛ 1 بُط. 3‏:‏9\x*
\m 
\v 14 بدُّو ن ؤُمنْغِي
\m \add أَمشْنَاوْ\add* أَرْزَامْ ن ڒْحمْڒثْ ن وَامَانْ.
\m أجّْ أَمنْغِي أَذْ يَارْسْ قْبڒْ إِ غَا إِدُّوقّزْ. \x ◘ \xo 17:‏14 \xt أَوڒن. 20‏:‏3\x*
\m 
\v 15 ونِّي إِتّْبَارَّانْ أَعفَّانْ
\m ؤُ ونِّي إِتّْبَارَّاحنْ
\m أَقَا أَمْسڭّذْ ذ أَعفَّانْ،
\m أَقَا نِيثْنِي س ثْنَاينْ إِذْسنْ
\m ذ نّْعِي إِ سِيذِي. \x ◘ \xo 17:‏15 \xt ؤُف. 23‏:‏7؛ أَوڒن. 24‏:‏24؛ إِشا. 5‏:‏23\x*
\b
\m 
\v 16 مَايمِّي ذِينْ إِ غَا إِڒِينْثْ ثْمنْيَاثْ
\m ذڭْ ؤُفُوسْ ن ؤُبُوهَاڒِي
\m مَاحنْذْ أَذْ إِسغْ ثِيغِيثْ،
\m أَمْ وَارْ غَارسْ ؤُڒْ \add إِ مَانْ أَيَا\add*؟
\m 
\v 17 أَمدُّوكّڒْ \add ذ ثِيذتّْ\add* إِتّخْسْ ڒبْذَا،
\m ؤُ ثَاوْمَاثْ ثتّْوَاخْڒقْ-د إِ ڒحْصَارثْ.
\m 
\v 18 بْنَاذمْ نِّي وَارْ غَارْ إِدْجِي وُوڒْ إِمْثنْ،
\m إِشَّاثْ أَفُوسْ،
\m إِتّڭّْ إِخفْ نّسْ ذ أَضْمَانْ إِ جَّارْ نّسْ.
\m 
\v 19 ونِّي إِتّخْسنْ أَخطُّو،
\m إِتّخْسْ أَمْشُوبّشْ،
\m ونِّي إِتّڭّنْ ثَاوَّارْثْ نّسْ ثْڭعّذْ،
\m يَارزُّو ثَارژِّيثْ. \x ◘ \xo 17:‏19 \xt أَوڒن. 16‏:‏18\x*
\m 
\v 20 ونِّي غَارْ إِدْجَا ؤُڒْ إِفَارْغْ،
\m وَارْ إِتِّيفْ مِينْ إِصبْحنْ،
\m ونِّي إِفَارّْغنْ س إِينْشِيشنْ نّسْ،
\m أَذْ إِوْضَا ذِي أَرْژِييّثْ.
\b
\m 
\v 21 ونِّي د-يُورْونْ إِجّْ ن ؤُبُوهَاڒِي،
\m \add إِتَّاوِي-د\add* أَشْضَانْ إِ يِيخفْ نّسْ،
\m بَابَاسْ ن ؤُبُوهَاڒِي وَارْ إِزمَّارْ أَذْ إِفَارْحْ.
\m 
\v 22 ؤُڒْ إِفَارْحنْ إِجبّذْ أَڭنْفُو،
\m \add مَاشَا\add* بُوحْبڒْ إِشضْننْ إِسَّاژَاغْ إِغْسَانْ. \x ◘ \xo 17:‏22 \xt أَوڒن. 15‏:‏13\x*
\m 
\v 23 أَعفَّانْ أَذْ د-إِكْسِي ثَارْزفْثْ \add ن أَرّشْوثْ\add*
\m زڭْ وحْسِينْ،
\m حِيمَا أَذْ إِسّْفَارْغْ إِمسْرَاقْ ن ڒْحقّْ.
\m 
\v 24 أَفهَّامْ \add إِتّڭّْ\add* ثِيغِيثْ زَّاثْ إِ ثْمُوغْڒِي نّسْ،
\m \add مَاشَا\add* ثِيطَّاوِينْ ن ؤُبُوهَاڒِي
\m \add تَّاوْينْثْ\add* أَڒْ طَّارْفْ ن ثمُّورْثْ. \x ◘ \xo 17:‏24 \xt أَمب. 2‏:‏14؛ 8‏:‏1\x*
\b
\m 
\v 25 إِجّْ ن مِّيسْ أَبُوهَاڒِي ذ ڒعْذَابْ إِ بَابَاسْ،
\m ذ إِجّْ ن ڒحْڒِيقْ أَمرْزَاڭْ
\m إِ ونِّي ث-إِ-د يُورْونْ. \x ◘ \xo 17:‏25 \xt أَوڒن. 10‏:‏1؛ 15‏:‏20؛ 19‏:‏13\x*
\m 
\v 26 أَودّبْ ن ؤُمْسڭّذْ وَارْ إِدْجِي نِيشَانْ،
\m \add أَمْ ؤُڒَا ذ\add* ثِييِّيثَا إِ أَيْثْ ن طَّاسِيڒثْ
\m ذِي سِّيبّثْ ن ڒصْفَايثْ \add نْسنْ\add*.
\m 
\v 27 ونِّي غَارْ ثدْجَا ثُوسّْنَا،
\m إِمنّعْ أَوَاڒنْ نّسْ،
\m أَرْيَازْ أَفهَّامْ \add ذَايسْ\add* بُوحْبڒْ نّسْ يَارْسَا.
\m 
\v 28 ؤُڒَا أَبُوهَاڒِي إِسّْغَاذنْ،
\m أَذْ إِتّْوَاحْسبْ ذ أَمِيغِيسْ،
\m ونِّي إِبلّْعنْ إِينْشِيشنْ نّسْ
\m \add أَذْ إِتّْوَاحْسبْ\add* ذ أَفتَّانْ.
\b
\b
\c 18
\m 
\v 1 ونِّي إِعزّْڒنْ إِخفْ نّسْ،
\m يَارزُّو خْ مژْرِي نّسْ،
\m نتَّا إِدُّوقُّوزْ خْ مَارَّا
\m مِينْ إِزمَّارنْ أَذْ يِيڒِي ذ أَذبَّارْ.
\m 
\v 2 أَبُوهَاڒِي وَارْ ذ أَسْ ثتّعْجِيبْ ڒفْهَامثْ،
\m \add إِتّعْجِيبْ أَسْ\add* مْغِيرْ أَعَارِّي ن وُوڒْ نّسْ.
\b
\m 
\v 3 خْمِي د-إِتَّاذفْ ؤُعفَّانْ،
\m إِتَّاسْ-د ؤُڒَا ذ أَسحْقَارْ،
\m ؤُ أَكْ-ذ ڒفْضِيحثْ إِتَّاسْ-د ڒْعَارْ.
\m 
\v 4 أَوَاڒنْ زڭْ ؤُقمُّومْ ن ورْيَازْ
\m \add أَمْ\add* وَامَانْ يُودْجْغنْ،
\m ڒْْعُونْصَارْ ن ثِيغِيثْ ذ \add إِشْثْ ن\add* ثِيغْزَارْثْ إِتَّازّْڒنْ.
\m 
\v 5 وَارْ إِدْجِي شَا مْلِيحْ أَذْ ثسّْعِيزّذْ أَعفَّانْ،
\m مَاحنْذْ أَذْ ثسّْحيّْذذْ
\m أَمْسڭّذْ ذِي شّْرعْ. \x ◘ \xo 18:‏5 \xt لَاوِي 19‏:‏15؛ أَعَوذ. 1‏:‏17؛ 16‏:‏19؛ أَوڒن. 24‏:‏23\x*
\m 
\v 6 إِينْشِيشنْ ن ؤُبُوهَاڒِي ندّْهنْ \add ث\add*
\m غَارْ ؤُمْشبّشْ،
\m أَقمُّومْ نّسْ إِتّْڒَاغَا-د إِ وعْمُوذْ.
\m 
\v 7 أَقمُّومْ ن ؤُبُوهَاڒِي ذ أَهلّكْ نّسْ،
\m إِينْشِيشنْ نّسْ ذ ڒْفخْ إِ ڒعْمَارْ نّسْ. \x ◘ \xo 18:‏7 \xt أَوڒن. 10‏:‏14؛ 12‏:‏13؛ 13‏:‏3\x*
\b
\m 
\v 8 أَوَاڒنْ ن إِخْبَارْجِييّنْ أَمْ حَالَاوِيثْ،
\m هكّْوَانْثْ ذڭْ إِخَّامنْ
\m ن ذَاخڒْ ن ؤُعذِّيسْ. \x ◘ \xo 18:‏8 \xt أَوڒن. 26‏:‏22\x*
\m 
\v 9 ونِّي إِدْجَانْ ذ أَمَارْخُو ذِي ڒْخذْمثْ نّسْ،
\m أَقَا ث ذ ؤُمَاسْ ن بَابْ ن ؤُڒدّدْجْ.
\b
\m 
\v 10 إِسمْ ن سِيذِي ذ إِجّْ ن لْبُورْجْ إِمْثنْ،
\m أَمْسڭّذْ إِتَّازّڒْ غَارْ ذِينِّي،
\m ؤُشَا إِتّْوَاسَّاكّْوَاضْ أَڒْ ذِينْ ذِي ڒَامَانْ. \x ◘ \xo 18:‏10 \xt 2 صم. 22‏:‏51؛ إِزهد. 18‏:‏3؛ 61‏:‏4؛ أَوڒن. 29‏:‏25\x*
\m 
\v 11 أَڭْڒَا ن بُو-وَاڭْڒَا
\m ذ ثَانْذِينْثْ نّسْ إِجهْذنْ،
\m \add ثَانِيثَا\add* أَمْ يِيجّْ ن ڒْحِيضْ يُوعْڒَانْ قَاعْ
\m ذِي ڒْبَاڒْ نّسْ. \x ◘ \xo 18:‏11 \xt أَوڒن. 10‏:‏15\x*
\b
\m 
\v 12 قْبڒْ مَا إِ غَا إِتّْوَارْژْ،
\m إِتّْڭعَّاذْ وُوڒْ نْ بْنَاذمْ،
\m \add مَاشَا\add* أَوَاضعْ إِتِّيزْوَاڒْ أَسْ إِ شَّانْ. \x ◘ \xo 18:‏12 \xt أَوڒن. 11‏:‏2؛ 15‏:‏33؛ 16‏:‏18\x*
\m 
\v 13 ونِّي د-إِتَّارَّانْ أَوَاڒْ
\m قْبڒْ إِ غَا إِسڒْ،
\m ذ مَانْ أَيَا ذ ثُوبُّوهڒْيَا
\m ذ ڒفْضِيحثْ إِ نتَّا.
\m 
\v 14 بُوحْبڒْ ن ورْيَازْ
\m إِتّْسنّذْ إِ-ث غَارْ ڒهْڒَاشْ نّسْ،
\m \add مَاشَا\add* بُوحْبڒْ إِتّْوَارْژنْ،
\m وِي إِزمَّارنْ أَذْ ث إِكْسِي؟
\m 
\v 15 ؤُڒْ ن ؤُفهَّامْ يَارزُّو ثُوسّْنَا،
\m أَمزُّوغْ ن ؤُمِيغِيسْ يَارزُّو ثُوسّْنَا.
\m 
\v 16 ثَارْزفْثْ ن بْنَاذمْ ثَارزّمْ أَسْ ثِيوُّورَا،
\m ثْندّهْ إِ-ث زَّاثْ إِ وُوذمْ ن إِمقّْرَاننْ.
\m 
\v 17 ونِّي ذ أَمزْوَارُو ذِي دّعْوثْ نّسْ
\m إِتّْبَانْ ذ أَمْسڭّذْ،
\m \add مَاشَا خنِّي\add* أَذْ د-يَاسْ جَّارْ نّسْ
\m ؤُشَا إِتّْنشّبْ ذِي ثْمسْڒَاشْثْ. \x ◘ \xo 18:‏17 \xt أَوڒن. 25‏:‏8\x*
\m 
\v 18 ثَاقدُّوحْثْ إِتّجَّانْ إِمنْغَانْ تّْبدَّانْ،
\m ثْبطَّا جَارْ إِنِّي غَارْ ثدْجَا صُّولْطَا.
\m 
\v 19 إِجّْ ن ؤُمَا نِّي ؤُمِي ذِي ڭِّينْ ڒْعِيبْ،
\m \add إِتّْوَاطّفْ كْثَارْ\add* خْ إِشْثْ ن ثنْذِينْثْ إِجهْذنْ،
\m إِمنْغَانْ ڭِّينْ أَمْ زّكْرُونْ ن ڒقْصَارْ.
\b
\m 
\v 20 زِي ڒْغِيدْجثْ ن ؤُقمُّومْ ن إِجّْ ن ورْيَازْ
\m إِتّْيَاوَانْ ؤُعذِّيسْ نّسْ،
\m أَذْ إِجَّاونْ زِي صَّابثْ ن إِينْشِيشنْ نّسْ. \x ◘ \xo 18:‏20 \xt أَوڒن. 12‏:‏14؛ 13‏:‏2\x*
\m 
\v 21 ڒْموْثْ ذ ثُوذَارْثْ ذڭْ ؤُفُوسْ ن يِيڒسْ،
\m كُوڒْ إِجّنْ ونِّي ثنْ إِتّخْسنْ،
\m أَذْ يشّْ رْغِيدْجثْ نْسنْ. \x ◘ \xo 18:‏21 \xt أَوڒن. 21‏:‏23؛ يَاع. 3‏:‏2\x*
\m 
\v 22 ونِّي يُوفِينْ ثَامْغَارْثْ،
\m يُوفَا مِينْ إِصبْحنْ،
\m ؤُ نتَّا إِطّفْ أَرْضَا ن سِيذِي. \x ◘ \xo 18:‏22 \xt أَوڒن. 19‏:‏14\x*
\m 
\v 23 س ؤُحشّمْ إِسَّاوَاڒْ ؤُمزْڒُوضْ،
\m بُو-وَاڭْڒَا إِتَّارَّا-د س ڒقْسَاحثْ.
\m 
\v 24 أَرْيَازْ نِّي غَارْ دْجَانْ إِمدُّوكَّاڒْ \add أَطَّاسْ\add*،
\m أَذْ إِوْضَا ذِي ثَامَارَا،
\m \add مَاشَا\add* شَا ن إِمُورنْ
\m أَمدُّوكّڒْ إِتّخْسْ \add إِ شكْ\add*
\m كْثَارْ زِي ثَاوْمَاثْ. \x ◘ \xo 18:‏24 \xt أَوڒن. 17‏:‏17\x*
\b
\b
\c 19
\m 
\v 1 إِحْڒَا إِجّْ ن ؤُمزْڒُوضْ
\m إِڭُّورنْ ذِي ڒصْفَايثْ نّسْ،
\m خْ ونِّي غَارْ إِدْجَانْ إِينْشِيشنْ فَارْغنْ،
\m ؤُ أَقَا ث ذ أَبُوهَاڒِي \add إِ يدْجَا\add*. \x ◘ \xo 19:‏1 \xt أَوڒن. 28‏:‏6\x*
\m 
\v 2 بْڒَا ثُوسّْنَا ؤُڒَا ذ ڒعْمَارْ وَارْ إِدْجِي شَا مْلِيحْ،
\m ونِّي إِتّْقدْجْقنْ س إِضَارنْ \add نّسْ\add*، أَذْ إِخْضَا.
\m 
\v 3 ثُوبُّوهڒْيَا ن بْنَاذمْ
\m إِسّْفَارَّاغْ أَبْرِيذْ نّسْ،
\m ؤُ \add خنِّي\add* ؤُڒْ نّسْ أَذْ إِسْعَارْ خْ سِيذِي. \x ◘ \xo 19:‏3 \xt يَاع. 1‏:‏13، 14، 15\x*
\m 
\v 4 أَڭْڒَا إِتَّاوِي-د أَطَّاسْ ن إِمدُّوكَّاڒْ،
\m \add مَاشَا\add* أَمزْڒُوضْ إِسمّحْ ذَايسْ
\m ؤُمدُّوكّڒْ نّسْ.\x ◘ \xo 19:‏4 \xt أَوڒن. 14‏:‏20\x*
\b
\m 
\v 5 أَشهَّاذْ إِسّْخَارِّيقنْ
\m وَارْ إِتّْوَاحسّبْ شَا ذ أَمزْذَاڭْ،
\m ونِّي د-يَارخُّونْ إِ إِخَارِّيقنْ،
\m وَارْ إِنجّمْ. \x ◘ \xo 19:‏5 \xt أَعَوذ. 19‏:‏19؛ أَوڒن. 21‏:‏28\x*
\m 
\v 6 أَطَّاسْ تّْزَاوْڭنْ زَّاثْ إِ وُوذمْ ن ؤُمْشنّعْ،
\m كُوڒْ  إِجّْ إِتّخْسْ أَذْ يِيڒِي ذ أَمدُّوكّڒْ
\m ن ورْيَازْ إِ غَارْ إِدْجَا ثرْزِيفِينْ.
\m 
\v 7 مَارَّا أَيْثْمَاسْ ن ؤُمزْڒُوضْ شَارّْهنْ ث،
\m مشْحَاڒْ تِّيڭّْوجّنْ خَاسْ
\m إِمدُّوكَّاڒْ نّسْ!
\m نتَّا إِضفَّارْ أَوَاڒنْ
\m نِّي وَارْ إِسكّْوِينْ وَالُو. \x ◘ \xo 19:‏7 \xt أَوڒن. 14‏:‏20\x*
\m 
\v 8 ونِّي إِطّْفنْ ؤُڒْ \add أَمِيغِيسْ\add*،
\m إِتّخْسْ ڒعْمَارْ نّسْ،
\m ونِّي إِحطَّانْ ڒفْهَامثْ،
\m أَذْ يَافْ مِينْ إِشْنَانْ.
\b
\m 
\v 9 إِجّْ ن ؤُشهَّاذْ إِسّْخَارِّيقنْ
\m وَارْ إِتّْوَاحسّبْ شَا ذ أَمزْذَاڭْ،
\m ونِّي يَارخُّونْ إِ إِخَارِّيقنْ،
\m أَذْ إِتّْوَاهلّكْ.
\m 
\v 10 أَفيّشْ وَارْ د-يُوسِي خْ ؤُبُوهَاڒِي،
\m مَامّشْ عَاذْ خْ ؤُمْسخَّارْ
\m مَاحنْذْ أَذْ إِسلّطْ خْ ڒْحُوكَّامْ. \x ◘ \xo 19:‏10 \xt أَوڒن. 30‏:‏22\x*
\m 
\v 11 ڒعْقڒْ ن بْنَاذمْ إِتَّارَّا إِ-ث
\m أَذْ إِڭّْ س تَّاسِيعْ ن ڒْخَاضَارْ
\m ثُوسَا-د خَاسْ مَاحنْذْ أَذْ إِميّكْ
\m خْ \add ؤُ\add*خطُّو نّسْ.
\m 
\v 12 أَسْخضْ ن ؤُجدْجِيذْ
\m أَمْ زّْهِيرْ ن ويْرَاذْ ذِي ثمْژِي نّسْ،
\m \add مَاشَا\add* أَرْضَا نّسْ أَمْ نّْذَا خْ أَرْبِيعْ. \x ◘ \xo 19:‏12 \xt أَوڒن. 16‏:‏14، 15؛ 20‏:‏2\x*
\m 
\v 13 مِّيسْ أَبُوهَاڒِي ذ أَرْژِييّثْ إِ بَابَاسْ،
\m أَمْشُوبّشْ ن ثمْغَارْثْ إِڭَّا
\m أَمْ ثُوذِّيمْثْ \add ن ثْزقَّا\add* وَارْ إِقطِّينْ. \x ◘ \xo 19:‏13 \xt أَوڒن. 10‏:‏1؛ 15‏:‏20؛ 17‏:‏25؛ 21‏:‏19؛ 27‏:‏15\x*
\m 
\v 14 ثَادَّارْثْ ذ وَاڭْڒَا
\m أَقَا أَثنْ ذ ڒْوَارْثْ ن ڒجْذُوذْ
\m \add مَاشَا\add* إِشْثْ ن ثمْغَارْثْ إِفهّْمنْ
\m أَقَا-ت ن سِيذِي. \x ◘ \xo 19:‏14 \xt أَوڒن. 18‏:‏22\x*
\m 
\v 15 ڒعْڭزْ يَارَّا \add بْنَاذمْ\add*
\m أَذْ إِوْضَا ذڭْ إِضصْ يُودْجْغنْ،
\m ؤُ ڒعْمَارْ \add إِشُّورْ\add* س ڒْغشّْ أَذْ إِدْجَاژْ. \x ◘ \xo 19:‏15 \xt أَوڒن. 6‏:‏9؛ 10‏:‏4؛ 20‏:‏13\x*
\m 
\v 16 ونِّي إِحطَّانْ ثَاوْصيّثْ،
\m إِحطَّا ڒعْمَارْ نّسْ،
\m ونِّي وَارْ إِحطِّينْ إِبْرِيذنْ نّسْ،
\m أَذْ إِمّثْ. \x ◘ \xo 19:‏16 \xt أَوڒن. 3‏:‏21، 22؛ لك. 11‏:‏28\x*
\b
\m 
\v 17 ونِّي إِتّْحِينَّانْ خْ ؤُمزْڒُوضْ،
\m يَارطّڒْ إِ سِيذِي.
\m نتَّا أَذْ أَسْ إِخدْجصْ ڒْخذْمثْ نّسْ.
\m 
\v 18 وبّخْ مِّيشْ، مَاڒَا عَاذْ ذِينْ شَا ن ڒَايَاسْ،
\m \add مَاشَا\add* وَارْ ث نقّْ شَا،
\m وَارْ تّجِّي شَا أَذْ إِكْسِي أَيَا ڒعْمَارْ نّشْ. \x ◘ \xo 19:‏18 \xt أَوڒن. 13‏:‏24؛ 23‏:‏13؛ أَفا. 6‏:‏4\x*
\m 
\v 19 ونِّي إِسْعَارنْ أَطَّاسْ،
\m أَذْ إِتّْوَاخدْجصْ \add إِ مَانَاينِّي\add*،
\m مَاغَارْ مَاڒَا ثخْسذْ أَذْ ث ثْمنْعذْ،
\m خنِّي أَذْ ذَايسْ ثَارنْيذْ \add وَاهَا\add*.
\m 
\v 20 سڒْ شكْ غَارْ ؤُشَاوَارْ
\m ؤُشَا قْبڒْ تَّارْبِييّثْ،
\m مَاحنْذْ أَذْ ثْذوْڒذْ ذ أَمِيغِيسْ
\m غَارْ ؤُنڭَّارْ.
\m 
\v 21 أَقَا ذِينْ أَطَّاسْ ن إِخمِّيمنْ
\m ذڭْ وُوڒْ ن ورْيَازْ،
\m \add مَاشَا\add* شّْوَارْ ن سِيذِي إِتّْغِيمَا إِبدّْ. \x ◘ \xo 19:‏21 \xt أَيُوبْ 23‏:‏13؛ إِزهد. 33‏:‏11؛ 115‏:‏3؛ إِشا. 46‏:‏10\x*
\b
\m 
\v 22 ثَامخْسِيوْثْ إِشوَّارنْ ن بْنَاذمْ
\m ذ ڒضْرَافثْ نّسْ،
\m \add أَمُّو إِ إِدْجَا\add* إِجّْ ن ؤُمزْڒُوضْ حْسنْ
\m خْ إِجّْ ن بُو-إِخَارِّيقنْ.
\m 
\v 23 ثِيڭّْوُوذِي ن سِيذِي ثْندّهْ غَارْ ثُوذَارْثْ،
\m مَاغَارْ إِتّطّصْ إِجِّيونْ،
\m وَارْ غَارسْ د-إِتَّاسْ شَا
\m مِينْ وَارْ إِحْڒِينْ. \x ◘ \xo 19:‏23 \xt إِزهد. 34‏:‏10\x*
\m 
\v 24 أَمعْڭُوزْ إِسّْنُوفَّارْ أَفُوسْ نّسْ ذِي طّبْصِي،
\m وَارْ ث-إِ-د-إِتَّارِّي \add عَاوذْ\add*
\m غَارْ ؤُقمُّومْ نّسْ. \f ◼ \fr 19:‏24 \ft \bd ’أَحْسِينْ‘\bd* - نِيغْ ’أَبحْرُورْ‘.\f*  \x ◘ \xo 19:‏24 \xt أَوڒن. 26‏:‏15\x*
\m 
\v 25 وّثْ أَمسْثهْزِييْ،
\m أَمُّو إِ غَا إِفْثنْ
\m ونِّي وَارْ غَارسْ بُو ڒفْهَامثْ،
\m ؤُ عَاقبْ أَفهَّامْ،
\m \add خنِّي\add* أَذْ إِكْسبْ ڒفْهَامثْ. \x ◘ \xo 19:‏25 \xt أَوڒن. 21‏:‏11\x*
\b
\m 
\v 26 ونِّي إِتّڭّنْغزُّو ذِي بَابَاسْ
\m نِيغْ ونِّي إِسُّوفُّوغنْ يمَّاسْ،
\m أَقَا ذ مِّيسْ نْ ڒفْضِيحثْ
\m نِّي يَارَّانْ \add بْنَاذمْ\add* أَذْ إِسضْحَا.
\m 
\v 27 سْبدّْ-د، أَ مِّي،
\m مَاحنْذْ أَذْ ثسْڒذْ غَارْ ؤُوبّخْ،
\m مَاڒَا ثخْسذْ أَذْ ثْحيّْذذْ
\m خْ وَاوَاڒنْ إِشُّورنْ س ثُوسّْنَا.
\m 
\v 28 إِجّْ ن ؤُشهَّاذْ إِ وَارْ إِسكّْوِينْ
\m إِغطّڒْ زِي ڒْحقّْ،
\m ؤُشَا أَقمُّومْ ن إِعفَّاننْ
\m إِصَارّضْ ڒْغشّْ.
\m 
\v 29 إِمسْثهْزَاينْ ثتّْرَاجَا أَثنْ ڒحْكَامثْ،
\m ؤُ ثِييِيتَّا ذڭْ وعْرُورْ إِ إِبُوهَاڒِييّنْ.
\b
\b
\c 20
\m 
\v 1 بِينُو ذ إِجّْ ن ؤُمسْثهْزِييْ،
\m شّْرَابْ ذ بُو-سّْضعْ،
\m كُوڒْ إِجّنْ ونِّي زَّايسْ إِ غَا إِودَّارنْ،
\m \add عمَّارْصْ\add* وَارْ إِذِّيكّْوِيڒْ ذ أَمِيغِيسْ.
\m 
\v 2 أَهُوذِّي ن ؤُجدْجِيذْ أَمْ زّْهِيرْ ن وَايْرَاذْ:
\m ونِّي ث إِسّعَارنْ،
\m إِخطَّا أَكْ-ذ ڒعْمَارْ نّسْ.\x ◘ \xo 20:‏2 \xt أَوڒن. 16‏:‏14؛ 19‏:‏12\x*
\m 
\v 3 أَسْمَاحْ ذڭْ ؤُمْشُوبّشْ
\m أَقَا ذ شَّانْ إِ ورْيَازْ،
\m \add مَاشَا\add* كُوڒْ أَبُوهَاڒِي أَذْ إِدُّوقّزْ. \x ◘ \xo 20:‏3 \xt أَوڒن. 17‏:‏14\x*
\m 
\v 4 زِي ڒْوقْثْ ن ڒخْرِيفْ وَارْ إِشَارّزْ ؤُمعْڭُوزْ،
\m \add خنِّي\add* أَذْ إِتَّارْ ذِي ڒْوقْثْ ن ثْميْرَا،
\m \add مَاشَا\add* وَارْ إِتِّيفْ وَالُو.
\m 
\v 5 إِخَارِّيصنْ ذڭْ وُوڒْ ن بْنَاذمْ
\m أَمَانْ يُودْجْغنْ،
\m \add مَاشَا\add* إِجّْ ن ورْيَازْ س ڒفْهَامثْ
\m إِسّنْ أَذْ ثنْ يَايمْ. \x ◘ \xo 20:‏5 \xt أَوڒن. 18‏:‏4\x*
\m 
\v 6 أَطَّاسْ ن إِوْذَانْ تّْڒَاغَانْ خْ شَا ن إِجّنْ
\m ’أَمدُّوكّڒْ نْسنْ ذ أَمْثِيقِّي‘،
\m \add مَاشَا\add* أَرْيَازْ ذ أَمْثِيقِّي،
\m مَانْ ونْ ث إِ غَا يَافنْ؟
\m 
\v 7 أَمْسڭّذْ إِڭُّورْ ذِي ڒصْفَايثْ نّسْ،
\m سّعْذْ ن إِحنْجِيرنْ نّسْ
\m \add إِ إِتّجَّا\add* أَوَارْنِي أَسْ.
\b
\m 
\v 8 إِجّْ ن ؤُجدْجِيذْ نِّي إِتّْغِيمَانْ
\m خْ ڒْكُورْسِي ن شّْرعْ،
\m إِتّْصفَّا مَارَّا ڒْغَارْ س ثِيطَّاوِينْ نّسْ. \x ◘ \xo 20:‏8 \xt أَوڒن. 20‏:‏26\x*
\b
\m 
\v 9 وِي إِزمَّارنْ أَذْ يِينِي:
\m ”نشّْ سِّيزذْڭغْ ؤُڒْ إِنُو،
\m نشّْ إِزْذِيڭغْ زِي دّْنُوبْ إِنُو!“؟ \x ◘ \xo 20:‏9 \xt 1 إِج. 8‏:‏46؛ أَيُوبْ 14‏:‏4؛ إِزهد. 51‏:‏7؛ أَمب. 7‏:‏20؛ 1 يُوح. 1‏:‏8\x*
\m 
\v 10 إِجّْ ن ڒوْزنْ ذ إِجّْ ن ڒوْزنْ نّغْنِي،
\m إِجّْ ن إِفَا ذ إِجّْ ن إِفَا نّغْنِي،
\m أَقَا أَثنْ س ثْنَاينْ إِذْسنْ ذ نّْعِي إِ سِيذِي. \x ◘ \xo 20:‏10 \xt أَعَوذ. 25‏:‏13؛ أَوڒن. 11‏:‏1؛ 20‏:‏23\x*
\m 
\v 11 أَحُوذْرِي إِسّْشَانَا ذِي ثْمڭَّا نّسْ،
\m مَا ڒْخذْمثْ نّسْ ثصْفَا
\m نِيغْ أَقَا نِيشَانْ \add إِ ثدْجَا\add*.
\m 
\v 12 أَمزُّوغْ إِتّسْڒَانْ ذ ثِيطّْ إِتّْوَاڒَانْ،
\m سِيذِي إِڭَّا إِ-ثنْ س ثْنَاينْ إِذْسنْ. \x ◘ \xo 20:‏12 \xt ؤُف. 4‏:‏11؛ إِزهد. 94‏:‏9\x*
\m 
\v 13 وَارْ تّخْسْ إِضصْ
\m مَاحنْذْ وَارْ ثذِّيكّْوِيڒذْ ذ أَمزْڒُوضْ،
\m أَرْزمْ ثِيطَّاوِينْ نّشْ،
\m سْيِيونْ إِخفْ نّشْ س وغْرُومْ. \x ◘ \xo 20:‏13 \xt أَوڒن. 19‏:‏15\x*
\b
\m 
\v 14 ’وَارْ إِحْڒِي، وَارْ إِحْڒِي!‘، إِقَّارْ ؤُمْسوّقْ،
\m \add مَاشَا\add* مَاڒَا يُويُورْ،
\m \add أَمُّو إِ\add* إِتّْشنّعْ إِخفْ نّسْ.
\m 
\v 15 ؤُرغْ إِدْجَا، ؤُڒَا ذ أَطَّاسْ ن ڒْمَارْجَانْ،
\m \add مَاشَا\add* إِينْشِيشنْ \add شُّورنْ\add* س ثُوسّْنَا
\m ذ إِشْثْ ن ڒْقشْعثْ إِغْڒَانْ أَطَّاسْ. \x ◘ \xo 20:‏15 \xt أَوڒن. 3‏:‏14، 15\x*
\m 
\v 16 مَاڒَا إِجّنْ إِدَّاكّْوَاڒْ
\m ذ أَضْمَانْ إِ يِيجّْ ن ؤُبَارَّانِي،
\m \add خنِّي\add* كْسِي أَرُّوضْ نّسْ ؤُ كْسِي ث ذ دِّييّثْ
\m إِ يِينِّي وَارْ إِتّْوَاسّْننْ. \x ◘ \xo 20:‏16 \xt أَوڒن. 11‏:‏15؛ 27‏:‏13\x*
\m 
\v 17 ذ أَمِيژِيذْ إِ بْنَاذمْ أَغْرُومْ
\m \add نِّي إِطّفْ س\add* إِخَارِّيقنْ،
\m أَوَارْنِي أَسْ أَذْ إِشُّورْ ؤُقمُّومْ نّسْ
\m س إِقَايَاسنْ. \x ◘ \xo 20:‏17 \xt أَوڒن. 9‏:‏17\x*
\m 
\v 18 إِخمِّيمنْ تّكْمِيڒنْ س ؤُشَاوَارْ،
\m خْ ؤُينِّي نْذهْ أَمنْغِي س ؤُذبَّارْ. \f ◼ \fr 20:‏18 \ft \bd ’إِخمِّيمنْ‘\bd* - نِيغْ ’إِنْوَاينْ‘ نِيغْ ’إِنكّْوَانْ‘ نِيغْ ’إِخَارِّيصنْ‘.\f*
\m 
\v 19 ونِّي إِڭُّورنْ ذَا ذ ذِيهَا س ثخْبَارْجِيثْ،
\m إِتّْعَارَّا مِينْ إِنُّوفَّارنْ،
\m وَارْ ثْسبّبْ أَكْ-ذ ونِّي إِسّْحِينِّيبنْ
\m س إِينْشِيشنْ نّسْ إِصبْهنْ. \x ◘ \xo 20:‏19 \xt أَوڒن. 11‏:‏13\x*
\b
\m 
\v 20 ونِّي إِ غَا إِنعْڒنْ خْ بَابَاسْ ذ يمَّاسْ،
\m ڒفْنَارْ نّسْ أَذْ إِتّْوَاسّخْسِي
\m ذِي ثَادْجسْثْ ثَابَارْشَانْثْ. \x ◘ \xo 20:‏20 \xt ؤُف. 21‏:‏17؛ لَاوِي 20‏:‏9؛ أَعَوذ. 27‏:‏16؛ مت. 15‏:‏4\x*
\m 
\v 21 مَاڒَا ثَاسْغَارْثْ ثتّْوَاكْسبْ ذغْيَا
\m س ثَازْڒَا ذڭْ ؤُمزْوَارُو،
\m وَارْ د-ثِيوضْ ذ لْبَارَاكَا غَارْ ؤُنڭَّارْ. \x ◘ \xo 20:‏21 \xt أَوڒن. 13‏:‏11؛ 28‏:‏20\x*
\m 
\v 22 وَارْ قَّارْ: ”نشّْ أَذْ خڒْفغْ ڒْغَارْ!“
\m \add مَاشَا\add* ثْشڒْ خْ سِيذِي ؤُ نتَّا أَذْ شكْ إِسّنْجمْ. \x ◘ \xo 20:‏22 \xt أَعَوذ. 32‏:‏35؛ أَوڒن. 17‏:‏13؛ 24‏:‏29؛ رُوم. 12‏:‏17؛ 1 تس. 5‏:‏15؛ 1 بُط. 3‏:‏9\x*
\m 
\v 23 إِجّْ ن ڒوْزنْ ذ إِجّْ ن ڒوْزنْ نّغْنِي،
\m أَقَا أَثنْ ذ نّْعِي إِ سِيذِي،
\m ڒْْمِيزَانَاثْ إِغشّنْ وَارْ دْجِينْ شَا مْلِيحْ. \x ◘ \xo 20:‏23 \xt أَوڒن. 20‏:‏10\x*
\m 
\v 24 إِصُورَافْ ن إِجّْ ن ورْيَازْ أَقَا أَثنْ ن سِيذِي،
\m \add خنِّي\add* مَامّشْ غَا يڭّْ بْنَاذمْ
\m أَذْ إِسّنْ أَبْرِيذْ نّسْ؟ \x ◘ \xo 20:‏24 \xt أَيُوبْ 31‏:‏4؛ إِزهد. 37‏:‏23؛ 139‏:‏2، 3؛ إِرْم. 10‏:‏23\x*
\m 
\v 25 أَقَا-ث ذ ڒْفخْ إِ بْنَاذمْ
\m إِ غَا إِڒَاغَانْ س ؤُقدْجقْ ’أَمْقدّسْ‘،
\m ؤُ \add عَاذْ\add* أَوَارْنِي لْوُوعُوذْ نّسْ \add إِ إِڭَّا\add*
\m أَذْ إِخَارّصْ.
\m 
\v 26 إِجّْ ن ؤُجدْجِيذْ أَمِيغِيسْ إِتّْصفَّا إِعفَّاننْ،
\m إِتّجَّا ثَاجَارَّارْثْ
\m \add ن ثڒْوِيحْثْ إِتّحْڒُودْجُوضنْ إِ ؤُسَارْوثْ\add*
\m أَذْ خَاسنْ إِعْقبْ.
\b
\m 
\v 27 ثْوَارِّيثْ ن نّفْسْ ن بُوحْبڒْ ن بْنَاذمْ
\m ذ ڒفْنَارْ ن سِيذِي نِّي يَارزُّونْ
\m ذِي ذَاخڒْ ن إِخَّامنْ ن ؤُعذِّيسْ.
\m 
\v 28 ثَامخْسِيوْثْ إِشوَّارنْ ذ ڒَامَانْ
\m حطَّانْ أَجدْجِيذْ،
\m ؤُ ڒْعَارْشْ نّسْ إِسّجْهذْ إِ-ث
\m س ثْمخْسِيوْثْ إِشوَّارنْ.
\m 
\v 29 ثَالْوِيزْثْ ن إِحُوذْرِييّنْ ذ جّهْذْ نْسنْ،
\m ؤُ لْعَاضَامَا ن إِوسُّورَا ذ أَشُوَّافْ إِشَابنْ. \x ◘ \xo 20:‏29 \xt أَوڒن. 16‏:‏31\x*
\m 
\v 30 إِيزِّيمنْ إِتَّازّْڒنْ س إِذَامّنْ
\m سِّيزْذِيڭنْ \add بْنَاذمْ\add* زِي ڒْغَارْ،
\m ؤُ ثِييِّيثَا \add صفَّانْثْ\add* ؤُڒَا ذ ثَاكْرِيشْثْ.\x ◘ \xo 20:‏30 \xt أَوڒن. 10‏:‏13\x*
\b
\b
\c 21
\m 
\v 1 ؤُڒْ ن ؤُجدْجِيذْ
\m أَمْ ثْغزْرَاثِينْ ن وَامَانْ
\m ذڭْ ؤُفُوسْ ن سِيذِي.
\m نتَّا إِندّهْ إِ-ث، مَانِي مَا إِخْسْ نتَّا.
\b
\m 
\v 2 مَارَّا إِبْرِيذنْ ن بْنَاذمْ
\m نِيشَانْ ذِي ثِيطَّاوِينْ نّسْ،
\m \add مَاشَا\add* سِيذِي إِتّْقدْجَابْ ؤُڒَاونْ. \x ◘ \xo 21:‏2 \xt أَوڒن. 16‏:‏2\x*
\m 
\v 3 ثِيمڭَّا ن ثْسڭْذَا ذ ڒْحقّْ،
\m ذ ثِينَا إِ سِيذِي حْسنْ زِي \add ثوْهِيبْثْ ن\add* ثْغَارْصْثْ. \x ◘ \xo 21:‏3 \xt 1 صم. 15‏:‏22؛ إِزهد. 50‏:‏8، 14؛ إِشا. 1‏:‏11، 16؛ حُوش. 6‏:‏6\x*
\m 
\v 4 نّْفَاخثْ ن ثِيطَّاوِينْ ذ ؤُڒْ أَعفَّارْ،
\m أَرْبرْ ن إِعفَّاننْ ذ دّنْبْ.
\m 
\v 5 إِخمِّيمنْ ن ونِّي إِمحْضنْ
\m \add تَّاوْينْ\add* مْغِيرْ غَارْ ؤُفيّضْ،
\m \add مَاشَا\add* مَارَّا ونِّي إِتّْقدْجِيقنْ أَطَّاسْ
\m \add إِتَّاوِي\add* غَارْ ڒحْوجْ وَاهَا. \x ◘ \xo 21:‏5 \xt أَوڒن. 10‏:‏4؛ 13‏:‏4\x*
\m 
\v 6 أَسْمُونِي ن وَاڭْڒَا س يِيڒسْ إِسّْخَارِّيقنْ،
\m \add أَمُّو إِ ثدْجَا\add* ثْوَارِّيثْ ن نّفْسْ
\m إِعدُّونْ ذغْيَا
\m ن يِينِّي يَارزُّونْ ڒْموْثْ. \x ◘ \xo 21:‏6 \xt أَوڒن. 10‏:‏2، 4؛ 13‏:‏11\x*
\m 
\v 7 لْعُونْفْ ن إِعفَّاننْ إِتّْجَارَّا إِ-ثنْ،
\m مَاغَارْ تَّاڭِينْ أَذْ ڭّنْ مِينْ إِسڭّْمنْ.
\m 
\v 8 أَبْرِيذْ ن بُو-ؤُمَارْوَاسْ إِتّفْرِيغْ،
\m \add مَاشَا\add* أَمزْذَاڭْ إِتّڭّْ مِينْ إِدْجَانْ نِيشَانْ.
\b
\m 
\v 9 إِحْڒَا أَذْ ثْزذْغذْ
\m ذڭْ إِشْثْ ثغْمَارْثْ ن ثْزقَّا، خْ \add ثْزذِّيغْثْ\add*
\m أَكْ-ذ إِشْثْ ن ثمْغَارْثْ إِتّمْشُوبُّوشنْ
\m ذڭْ إِشْثْ ن ثَادَّارْثْ ثْشَارْشْ. \x ◘ \xo 21:‏9 \xt أَوڒن. 21‏:‏19؛ 25‏:‏24؛ 27‏:‏15\x*
\m 
\v 10 ڒعْمَارْ ن إِعفَّاننْ إِتّْمژْرِي ذِي ڒْغَارْ،
\m أَمْقَارّبْ نّسْ وَارْ غَارسْ إِتِّيفْ أَرْضَا
\m ذِي ثِيطَّاوِينْ نّسْ.
\m 
\v 11 مَاڒَا إِتّْوَاخدْجصْ ؤُمسْثهْزِييْ،
\m إِدَّاكّْوَاڒْ ونِّي
\m وَارْ غَارسْ بُو ڒفْهَامثْ ذ أَمِيغِيسْ،
\m مَاڒَا سّْڒمْذنْ أَمِيغِيسْ،
\m إِكسِّي نتَّا ثُوسّْنَا. \x ◘ \xo 21:‏11 \xt أَوڒن. 19‏:‏25\x*
\m 
\v 12 \add إِجّْ ن\add* ؤُمْسڭّذْ إِتّْبقّشْ مْلِيحْ
\m ثَادَّارْثْ ن ؤُعفَّانْ،
\m إِغطّڒْ إِعفَّاننْ ذِي أَرْژِييّثْ.
\m 
\v 13 ونِّي إِتّْبلَّاعنْ أَمزُّوغْ نّسْ
\m غَارْ إِغُويَّانْ ن ؤُمزْڒُوضْ،
\m ؤُڒَا ذ نتَّا أَذْ إِسْغُويْ
\m \add مَاشَا\add* وَارْ خَاسْ د-تَّارَّانْ.
\m 
\v 14 صّذْقثْ ذِي ثْنُوفّْرَا ثصْڒحُّو وغْضَابْ،
\m ثَارْزفْثْ \add إِمّوْشنْ\add* ذڭْ وحْسِينْ \add ن وَارُّوضْ\add*
\m \add ثصْڒحُّو\add* أَخيّقْ إِمْغَارنْ. \x ◘ \xo 21:‏14 \xt أَوڒن. 17‏:‏8؛ 18‏:‏16\x*
\m 
\v 15 أَقَا ذ ڒفْرَاحثْ إِ ؤُمْسڭّذْ
\m مَاحنْذْ أَذْ إِڭّْ مِينْ \add إِدْجَانْ\add* نِيشَانْ،
\m \add مَاشَا\add* ذ أَشڒْوَاوْ إِ يِينِّي إِتّڭّنْ ڒْغشّْ.
\m 
\v 16 بْنَاذمْ نِّي إِتّفّْغنْ
\m زڭْ وبْرِيذْ ن ڒعْقڒْ،
\m أَذْ يَاريّحْ ذڭْ وڭْرَاوْ
\m ن ڒخْيَاڒَاثْ \add ن إِمتَّانْ\add*.
\m 
\v 17 ونِّي إِتّخْسنْ أَفَارَّاجْ، أَذْ إِحْوَاجْ،
\m ونِّي إِتّخْسنْ بِينُو ذ زّشْثْ،
\m وَارْ إِذِّيكّْوِيڒْ ذ بُو وَاڭْڒَا.
\m 
\v 18 أَعفَّانْ ذ دّيّثْ إِ إِمْسڭَّاذنْ،
\m ؤُ أَغدَّارْ أَذْ د-يِيڒِي
\m ذڭْ ومْشَانْ ن يِينِّي إِڭُّورنْ نِيشَانْ. \x ◘ \xo 21:‏18 \xt أَوڒن. 11‏:‏8\x*
\b
\m 
\v 19 إِحْڒَا أَذْ ثْزذْغذْ ذِي ثمُّورْثْ إِخْڒَانْ،
\m خْ \add ثَازذِّيغْثْ\add* أَكْ-ذ إِشْثْ ن ثمْغَارْثْ
\m إِتّمْشُوبُّوشنْ ؤُ إِتّقّْسنْ. \x ◘ \xo 21:‏19 \xt أَوڒن. 21‏:‏9؛ 25‏:‏24\x*
\m 
\v 20 إِجّْ ن ڒْكنْزْ إِتّْوَاحْوَاجنْ ذ زّشْثْ
\m أَقَا أَثنْ ذِي ثْزذِّيغْثْ ن إِمِيغِيسنْ،
\m \add مَاشَا\add* بْنَاذمْ أَبُوهَاڒِي إِصَارّضْ إِ-ث.
\m 
\v 21 ونِّي يَارزُّونْ خْ ثْسڭْذَا
\m ذ ثْمخْسِيوْثْ إِشوَّارنْ،
\m إِتَّافْ ثُوذَارْثْ ذ ثْسڭْذَا ذ شَّانْ.
\m 
\v 22 أَمِيغِيسْ إِتّْڭعَّاذْ
\m خْ ثنْذِينْثْ ن أَيْثْ ن بُو-ثغْڒُوضْثْ،
\m إِغطّڒْ جّهْذْ ن تِّيقثْ نْسنْ ذِي ثمُّورْثْ.
\m 
\v 23 ونِّي إِحطَّانْ أَقمُّومْ ذ يِيڒسْ نّسْ،
\m إِحطَّا ڒعْمَارْ نّسْ زِي ڒحْصَارَاثْ. \x ◘ \xo 21:‏23 \xt أَوڒن. 18‏:‏21\x*
\m 
\v 24 ونِّي ذ بُو-نّْفَاخثْ إِفُّوشّْحنْ
\m تّْڒَاغَانْ أَسْ ’أَمسْثهْزِييْ‘،
\m نتَّا إِتّڭّْ س نّْفَاخثْ بْڒَا ڒقْيَاسْ.
\m 
\v 25 شّهْوثْ ن ؤُمعْڭُوزْ ثْنقّْ إِ-ث،
\m مَاغَارْ إِفَاسّنْ نّسْ ؤُڭِينْ أَذْ خذْمنْ.
\b
\s1 أَوَاڒنْ إِوزّْننْ ن سُولِيمَانْ - ثَاسْغَارْثْ 1د
\m 
\v 26 أَسّْ إِمُونْ إِتّْشهَّا ثِيمسْڒَايِينْ ن ؤُشهِّي،
\m \add مَاشَا\add* أَمْسڭّذْ أَذْ إِوْشْ،
\m وَارْ إِتّْغِيمِي إِتّطّفْ \add ذِي شَا إِ يِيخفْ نّسْ\add*. \x ◘ \xo 21:‏26 \xt إِزهد. 37‏:‏26\x*
\m 
\v 27 ثَاغَارْصْثْ ن ؤُعفَّانْ ذ نّْعِي،
\m مَاهُو مَاڒَا نِيثْنِي أَذْ ت أَوْينْ
\m س ؤُنكّْوِي إِغشّنْ. \x ◘ \xo 21:‏27 \xt أَوڒن. 15‏:‏8؛ إِشا. 1‏:‏13؛ إِرْم. 6‏:‏20؛ عَام. 5‏:‏21\x*
\m 
\v 28 أَشهَّاذْ إِسّْخَارِّيقنْ أَذْ إِتّْوَاهلّكْ،
\m \add مَاشَا\add* أَرْيَازْ نِّي إِتّسْڒَانْ،
\m أَذْ إِسِّيوڒْ \add ثِيذتّْ\add* ڒبْذَا. \x ◘ \xo 21:‏28 \xt أَوڒن. 19‏:‏5، 9\x*
\m 
\v 29 أَرْيَازْ أَعفَّانْ إِسّجْهذْ إِخفْ نّسْ
\m أَكْ-ذ وُوذمْ نّسْ،
\m \add مَاشَا\add* ونِّي إِڭُّورنْ نِيشَانْ
\m إِسّمْثنْ إِبْرِيذنْ نّسْ.
\b
\m 
\v 30 وَارْ ثدْجِي ثِيغِيثْ ؤُڒَا ذ ڒفْهَامثْ،
\m وَارْ ذِينْ إِدْجِي بُو ؤُشَاوَارْ قِيبَاتْشْ إِ سِيذِي.
\m 
\v 31 أَيِيسْ أَذْ أَسْ حزّْمنْ إِ وَاسّْ ن ؤُمنْغِي،
\m \add مَاشَا\add* ڒغْڒبْ غَارْ سِيذِي.\x ◘ \xo 21:‏31 \xt إِزهد. 33‏:‏17\x*
\b
\b
\c 22
\m 
\v 1 إِسمْ أَصبْحَانْ إِحْڒَا
\m خْ وَاطَّاسْ ن وَاڭْڒَا،
\m أَحِينِّي إِحْڒَا خْ نُّوقَارْثْ ذ وُورغْ.\x ◘ \xo 22:‏1 \xt أَمب. 7‏:‏1\x*
\m 
\v 2 بُو-وَاڭْڒَا ذ ؤُمزْڒُوضْ تّمْسَاڭَارنْ،
\m سِيذِي إِ-ثنْ إِڭِّينْ مَارَّا. \x ◘ \xo 22:‏2 \xt أَوڒن. 29‏:‏13\x*
\b
\m 
\v 3 \add بْنَاذمْ\add* إِفتّْننْ إِتّْوَاڒَا ڒْغَارْ
\m ؤُشَا إِتّْنُوفَّارْ،
\m \add مَاشَا\add* إِحَافِييّنْ أَرنِّينْ ڭُّورنْ
\m ؤُشَا أَذْ تّْوَاعَاقَابنْ. \x ◘ \xo 22:‏3 \xt أَوڒن. 27‏:‏12\x*
\m 
\v 4 ڒْمُونثْ إِ ؤُوَاضعْ ذ ثِيڭّْوُوذِي ن سِيذِي،
\m ذ أَڭْڒَا ذ شَّانْ ذ ثُوذَارْثْ.
\m 
\v 5 إِسنَّاننْ ذ ڒفْخُوخْ أَقَا أَثنْ
\m خْ وبْرِيذْ ن ونِّي إِفَارْغنْ،
\m ونِّي إِحطَّانْ ڒعْمَارْ نّسْ،
\m إِتّْغِيمَا غَارْ ڒَاڭّْوَاجْ نْسنْ.
\m 
\v 6 ذَارّبْ أَحُوذْرِي
\m عْلَاحْسَابْ ڒقْيَاسْ ن وبْرِيذْ نّسْ،
\m وَاخَّا نتَّا إِوْسَارْ، وَارْ خَاسْ إِتّْحيِّيذْ شَا.
\m 
\v 7 بُو-وَاڭْڒَا إِتّْصدْجَاضْ خْ إِمزْڒَاضْ،
\m بُو-ؤُمَارْوَاسْ ذ إِسْمغْ
\m ن ونِّي ذ أَسْ يَارطّْڒنْ.
\b
\m 
\v 8 ونِّي إِزَارّْعنْ ڒْغشّْ، أَذْ إِمْجَارْ ڒغْبنْ،
\m أَعْمُوذْ ن ؤُذُوقّزْ نّسْ \add ن ؤُفُوڭمْ\add* أَذْ إِفْنَا. \x ◘ \xo 22:‏8 \xt أَيُوبْ 4‏:‏8؛ Isaiah 14‏:‏5.؛ Psalm 125‏:‏3؛ حُوش. 10‏:‏13\x*
\m 
\v 9 ونِّي غَارْ إِدْجَا ڒْخزْرَاثْ صبْحنْثْ،
\m أَذْ إِتّْوَابَاركْ،
\m مِينْزِي نتَّا إِتِّيشْ إِ إِمزْڒَاضْ
\m زڭْ وغْرُومْ نّسْ. \x ◘ \xo 22:‏9 \xt 2 كُور. 9‏:‏6\x*
\m 
\v 10 أَژّڒْ خْ ؤُمسْثهْزِييْ، أَذْ إِفّغْ ڒْهمّْ،
\m أَقَا إِبدّْ ؤُمْحَارْوَاضْ ذ ڒفْضِيحثْ.
\m 
\v 11 ونِّي إِتّخْسنْ ڒصْفَايثْ ن وُوڒْ،
\m ونِّي غَارْ إِدْجَا إِينْشِيشنْ \add إِشُّورنْ\add* س أَرْضَا،
\m أَجدْجِيذْ أَذْ يِيڒِي ذ أَمدُّوكّڒْ نّسْ. \x ◘ \xo 22:‏11 \xt إِزهد. 101‏:‏6\x*
\m 
\v 12 ثِيطَّاوِينْ ن سِيذِي حطَّانْثْ خْ ثُوسّْنَا،
\m \add مَاشَا\add* أَوَاڒنْ ن ؤُغدَّارْ أَذْ ثنْ إِبْضڒْ.
\m 
\v 13 أَمعْڭُوزْ إِقَّارْ:
\m ”أَقَا ذِينْ إِجّْ ن وَايْرَاذْ ذِي بَارَّا!
\m أَذْ ثَاغْ بَالَاكْ أَذْ تّْوَانْغغْ
\m ذِي ڒْوسْطْ ن وَازَّاينْ!“ \x ◘ \xo 22:‏13 \xt أَوڒن. 26‏:‏13\x*
\m 
\v 14 أَقمُّومْ ن ثمْغَارِينْ ثِيبَارَّانِييِّينْ
\m ذ إِشْثْ ن ثسْرَافْثْ يُودْجْغنْ،
\m ونِّي خْ إِفُّوڭمْ سِيذِي، أَذْ ذَايسْ إِوْضَا. \x ◘ \xo 22:‏14 \xt أَوڒن. 2‏:‏16؛ 5‏:‏3؛ 7‏:‏5؛ 23‏:‏27\x*
\m 
\v 15 ثُوبُّوهڒْيَا \add ثتّْغِيمَا\add* ثْڒسّقْ
\m ذڭْ وُوڒْ ن ؤُحُوذْرِي،
\m أَعْمُوذْ ن ؤُوبّخْ أَذْ ت إِسُّوفّغْ زَّايسْ. \x ◘ \xo 22:‏15 \xt أَوڒن. 13‏:‏24؛ 19‏:‏18؛ 23‏:‏14؛ 29‏:‏15، 17\x*
\m 
\v 16 ونِّي إِحصَّارنْ أَمَارْخُو،
\m أَذْ يَارْنِي ذِي ڒمْغَارثْ نّسْ،
\m ونِّي إِتِّيشنْ إِ بُو-وَاڭْڒَا،
\m أَذْ إِحْوَاجْ \add وَاهَا\add*. \x ◘ \xo 22:‏16 \xt أَوڒن. 14‏:‏31؛ 17‏:‏5\x*
\b
\s1 أَوَاڒنْ إِوزْننْ ن أَيْثْ ن ثِيغِيثْ -ثَاسْغَارْثْ 1
\m 
\v 17 أوْشْ أَمزُّوغْ نّشْ،
\m ؤُشَا سڒْ غَارْ وَاوَاڒنْ ن إِمِيغِيسنْ،
\m أَرّْ ؤُڒْ نّشْ غَارْ ثُوسّْنَا إِنُو.
\m 
\v 18 مَاغَارْ أَقَا مْلِيحْ
\m مَاڒَا ثْخمّْڒذْ ثنْ ذِي ذَاخڒْ نّشْ،
\m \add مَاڒَا\add* أَذْ ثنْ ثسّْوجْذذْ جْمِيعْ
\m خْ إِينْشِيشنْ نّشْ.
\m 
\v 19 مَاحنْذْ أَذْ يِيڒِي ؤُثشْڒِي نّشْ خْ سِيذِي،
\m أَذْ أَشْ ثنْ سّشْنغْ ڒخُّو، وَاهْ إِ شكْ.
\m 
\v 20 مَا زعْمَا وَارْ ذ أَشْ ؤُرِيغْ
\m أَوَاڒنْ إِفَارْزنْ أَطَّاسْ،
\m \add شُّورنْ\add* س شّْوَارْ ذ ثُوسّْنَا،
\m 
\v 21 حِيمَا أَذْ أَشْ سّشْنغْ ڒمْثنْ
\m ن وَاوَاڒنْ ن ثِيذتّْ،
\m مَاحنْذْ ثْزمَّارذْ أَذْ د-ثَارّذْ س ڒَامَانْ
\m خْ ونِّي شكْ د-إِسّكّنْ.
\b
\m 
\v 22 وَارْ تّْكشَّاضْ أَمَارْخُو
\m مَاغَارْ نتَّا ذ أَمَارْخُو،
\m وَارْ ڒبّزْ ڒْمسْكِينْ غَارْ ثوَّارْثْ، \x ◘ \xo 22:‏22 \xt ؤُف. 23‏:‏6؛ أَيُوبْ 31‏:‏13؛ إِزهد. 82‏:‏3، 4؛ زَاك. 7‏:‏10\x*
\m 
\v 23 مَاغَارْ سِيذِي أَذْ أَسنْ يَاغْ ثَاسْغَارْثْ نْسنْ،
\m نتَّا أَذْ إِكشّضْ ڒعْمَارْ
\m ن يِينِّي إِ-ثنْ إِتّْكشَّاضنْ. \x ◘ \xo 22:‏23 \xt ؤُف. 22‏:‏22، 23؛ إِزهد. 10‏:‏18\x*
\m 
\v 24 وَارْ تّمْدُّوكُّوڒْ
\m أَكْ-ذ أَرْيَازْ إِتَّارُّوجْذُوذنْ،
\m وَارْ تِّيذفْ غَارْ بَابْ ن وسْعَارْ،
\m 
\v 25 مَاحنْذْ شكْ وَارْ ثتّْنِيمِيذْ شَا
\m أَكْ-ذ إِمسْرَاقْ نّسْ،
\m أَذْ ثڭّذْ ڒْفخْ إِ ڒعْمَارْ نّشْ.
\m 
\v 26 وَارْ تَّاذفْ جَارْ إِنِّي إِتِّيشنْ أَوَاڒْ
\m س ثْموْشِيوْثْ ن إِفَاسّنْ،
\m جَارْ إِنِّي إِدْجَانْ ذ أَضْمَانْ إِ إِمَارْوُوسَا. \x ◘ \xo 22:‏26 \xt أَوڒن. 6‏:‏1؛ 11‏:‏15\x*
\m 
\v 27 مَاڒَا وَارْ غَاركْ مِينْ زِي غَا ثْخدْجْصذْ،
\m مَايمِّي إِجبّذْ قَامَا نّشْ
\m زِي سَاذُو نّشْ؟ \x ◘ \xo 22:‏27 \xt أَوڒن. 20‏:‏16\x*
\b
\m 
\v 28 وَارْ سْمُوطُّويْ أَيْمِيرْ ن وشْحَاڒْ ؤُيَا،
\m ونِّي ڭِّينْ ڒجْذُوذْ نّشْ. \x ◘ \xo 22:‏28 \xt أَعَوذ. 19‏:‏14؛ 27‏:‏17؛ أَوڒن. 23‏:‏10\x*
\b
\m 
\v 29 مَا ثژْرِيذْ إِجّْ ن ورْيَازْ إِمحْضنْ
\m ذِي ڒْحِيرْفَا نّسْ؟
\m أَذْ ث سّْبدّنْ زَّاثْ إِ وُوذمْ ن إِجدْجِيذنْ،
\m وَارْ إِدْجِي أَذْ إِبدّْ زَّاثْ إِ وُوذمْ
\m ن مِيدّنْ وَارْ ذِي إِدْجِي ڒَامَانْ.
\b
\b
\c 23
\m 
\v 1 مَاڒَا ثقِّيمذْ
\m غَارْ إِجّْ ن ڒْحَاكمْ،
\m مَاحنْذْ أَذْ ثشّذْ \add أَكِيذسْ\add*،
\m حْضَا مْلِيحْ مِينْ \add إِدْجَانْ\add* زَّاثكْ.
\m 
\v 2 أڭّْ إِجّْ ن ڒْمُوسْ خْ يِيڒِي نّشْ،
\m مَاڒَا شكْ ذ إِجّْ ن بُو-ڒمْغَارثْ ن ؤُعذِّيسْ.
\m 
\v 3 وَارْ تّڭّْ مژْرِي ذِي مَاشَّا نّسْ إِشْنَانْ،
\m مَاغَارْ أَقَا-ث ذ مَاشَّا ن ثُوخُّونَا.
\b
\m 
\v 4 وَارْ سِّيحِيڒْ إِخفْ نّشْ
\m حِيمَا أَذْ ثْذوْڒذْ ذ بُو-وَاڭْڒَا،
\m سَارْخُو ذڭْ نّيّثْ نّشْ.
\m 
\v 5 مَاڒَا طَّاونْثْ ثِيطَّاوِينْ غَارسْ،
\m أَقَا وَارْ ذِينْ \add أَڭْڒَا\add* عَاذْ!
\m مَاغَارْ أَذْ إِڭّْ أَفْرِيونْ إِ يِيخفْ نّسْ،
\m أَذْ إِضْوَا غَارْ ؤُجنَّا أَمْ يِيجّْ ن ؤُڭِيذرْ.
\b
\m 
\v 6 وَارْ تّتّْ أَغْرُومْ
\m ن ونِّي ذِي ثدْجَا ثِيطّْ ثَاعفَّانْثْ،
\m وَارْ مژْرِي ذِي مَاشَّا نّسْ إِشْنَانْ.
\m 
\v 7 مَاغَارْ أَمْ مَامّشْ \add ث\add* إِتّْخَارَّاصْ،
\m أَمُّو \add إِ ث إِتّڭّْ\add* نتَّا.
\m إِقَّارْ: ”أشّْ، ثسْوذْ!“،
\m \add مَاشَا\add* ؤُڒْ نّسْ وَارْ أَكِيذكْ إِدْجِي.
\m 
\v 8 أَزعِّيفْ إِ ثشِّيذْ، أَذْ ث-إِ-د-ثْعُوقّذْ،
\m أَوَاڒنْ إِصبْحنْ نّشْ ثْضيّْعذْ ثنْ.
\b
\m 
\v 9 وَارْ سِيوڒْ ذڭْ ؤُمزُّوغْ ن إِجّْ ن ؤُبُوهَاڒِي،
\m مَاغَارْ نتَّا أَذْ إِسّحْقَارْ
\m أَوَاڒنْ ن وفْثَانْ نّشْ. \x ◘ \xo 23:‏9 \xt أَوڒن. 9‏:‏8؛ مت. 7‏:‏6\x*
\b
\m 
\v 10 وَارْ سْمُوطُّويْ أَيْمِيرْ ن وشْحَاڒْ ؤُيَا،
\m وَارْ تَّاذفْ ذڭْ إِيَّارنْ ن إِيُوجِيڒنْ، \x ◘ \xo 23:‏10 \xt أَوڒن. 22‏:‏28\x*
\m 
\v 11 مَاغَارْ أَمفْذِي نْسنْ ذ أَمقّْرَانْ،
\m نتَّا أَذْ د-يَاغْ ثَاسْغَارْثْ نْسنْ زَّايكْ.
\b
\m 
\v 12 أَرّْ ؤُڒْ نّشْ غَارْ ؤُوبّخْ،
\m إِمزُّوغنْ نّشْ غَارْ وَاوَاڒنْ ن ثُوسّْنَا.
\m 
\v 13 وَارْ تّطّفْ تَّارْبِييّثْ خْ ؤُحُوذْرِي،
\m وَاخَّا ثشَّاثذْ ث س وعْمُوذْ،
\m وَارْ إِتّْمتِّي. \x ◘ \xo 23:‏13 \xt أَوڒن. 13‏:‏24؛ 19‏:‏18؛ 22‏:‏15؛ 29‏:‏15، 17\x*
\m 
\v 14 شكْ أَذْ ث ثوْثذْ س وعْمُوذْ،
\m ؤُ أَذْ ثسّْنجْمذْ ڒعْمَارْ نّسْ زِي ڒَاخَارْثْ.
\b
\m 
\v 15 مِّي إِنُو، مَاڒَا ؤُڒْ نّشْ ذ أَمِيغِيسْ،
\m أَذْ إِفَارْحْ ؤُڒَا ذ ؤُڒْ إِنُو أَكِيذسْ.
\m 
\v 16 ثِيژَّاڒْ إِنُو أَذْ نڭْزنْثْ س ڒفْرَاحثْ،
\m مَاڒَا إِينْشِيشنْ نّشْ
\m سِّيوْڒنْ مِينْ إِدْجَانْ إِسڭّْذنْ. \f ◼ \fr 23:‏16 \ft \bd ’ثِيژَّاڒْ‘\bd* - نِيغْ ’ثِيڭژْڒِينْ‘.\f*
\m 
\v 17 أجّْ ؤُڒْ نّشْ وَارْ إِتِّيسِيمْ زڭْ إِمذْنَابْ،
\m مَاشَا \add أجّْ إِ-ث أَذْ يَارّْ أَزدْجِيفْ\add*
\m غَارْ ثِيڭّْوُوذِي ن سِيذِي أَسّْ إِمُونْ! \x ◘ \xo 23:‏17 \xt إِزهد. 37‏:‏1؛ 73‏:‏3؛ أَوڒن. 24‏:‏1\x*
\m 
\v 18 مَاغَارْ خنِّي أَقَا ذِينْ ثِيوشَّا،
\m ؤُ ڒَايَاسْ نّشْ وَارْ إِتَّارژِّي. \x ◘ \xo 23:‏18 \xt أَوڒن. 24‏:‏14\x*
\m 
\v 19 سڒْ-د شكْ، أَ مِّي، إِڒِي ذ أَمِيغِيسْ،
\m نْذهْ ؤُڒْ نّشْ غَارْ وبْرِيذْ.
\m 
\v 20 وَارْ تّْغِيمِي غَارْ إِسْكَارْجِييّنْ،
\m ؤُڒَا غَارْ إِنِّي إِلهّْفنْ ذڭْ ويْسُومْ، \x ◘ \xo 23:‏20 \xt إِشا. 5‏:‏22؛ لك. 21‏:‏34؛ رُوم. 13‏:‏13؛ أَفا. 5‏:‏18\x*
\m 
\v 21 مَاغَارْ أَسْكَارْجِييْ ذ أَملْهُوفْ
\m أَذْ ذوْڒنْ ذ إِمزْڒَاضْ،
\m ؤُ أَنُوذمْ إِسّْيِيرِيضْ ذڭْ إِحْڒُوشنْ.
\b
\m 
\v 22 سڒْ-د شكْ غَارْ بَابَاشْ
\m ونِّي شكْ إِ د-إِجِّينْ،
\m ؤُ وَارْ سّحْقِيرِي يمَّاشْ مَاڒَا ثوْسَارْ. \x ◘ \xo 23:‏22 \xt أَوڒن. 1‏:‏8\x*
\m 
\v 23 سغْ-دّْ ثِيذتّْ، وَارْ \add ت\add* ثزْنُوزَا شَا،
\m \add أَمُّو\add* ؤُڒَا ذ ثِيغِيثْ ذ ؤُوبّخْ ذ ڒفْهَامثْ. \x ◘ \xo 23:‏23 \xt أَوڒن. 4‏:‏7\x*
\m 
\v 24 بَابَاسْ ن ؤُمْسڭّذْ أَذْ إِفَارْحْ س وَاطَّاسْ،
\m ونِّي د-إِجِّينْ إِجّْ \add مِّيسْ\add* ذ أَمِيغِيسْ،
\m أَذْ أَسْ إِفَارْحْ. \x ◘ \xo 23:‏24 \xt أَوڒن. 10‏:‏1؛ 15‏:‏20\x*
\m 
\v 25 أجّْ أَذْ إِفَارْحْ بَابَاشْ ؤُڒَا ذ يمَّاشْ،
\m أجّْ ثنِّي شكْ إِ د-يُورْونْ أَذْ ثْفَارْحْ.
\b
\m 
\v 26 أوْشْ أَيِي ؤُڒْ نّشْ، أَ مِّي،
\m أجّْ ثِيطَّاوِينْ نّشْ أَذْ أَفنْثْ
\m أَرْضَا ذڭْ إِبْرِيذنْ إِنُو.
\m 
\v 27 مَاغَارْ ثَامْغَارْثْ فَارْقْ-شّْغڒْ
\m ذ إِشْثْ ن ثسْرَافْثْ يُودْجْغنْ،
\m ؤُ ثَامْغَارْثْ زِي بَارَّا ذ إِجّْ ن ڒْعُونْصَارْ إِحْسَارْ. \x ◘ \xo 23:‏27 \xt أَوڒن. 22‏:‏14\x*
\m 
\v 28 وَاهْ، نتَّاثْ ثتّْحَامَا
\m أَمْ يِيجّْ ن ؤُخوَّانْ،
\m نتَّاثْ ثَارنِّي
\m ذڭْ إِغدَّارنْ جَارْ إِوْذَانْ.
\b
\m 
\v 29 وِي إِ غَارْ إِدْجَا وشْضَانْ؟
\m وِي إِ غَارْ إِدْجَا زّڒْضْ؟
\m وِي إِ غَارْ إِدْجَا ؤُمْشُوبّشْ؟
\m وِي إِ غَارْ إِدْجَا ؤُشثْشِي؟
\m وِي إِ غَارْ إِدْجَانْ إِيزِّيمنْ بْڒَا سِّيبّثْ؟
\m وِي إِ غَارْ دْجَانْثْ ثِيطَّاوِينْ بَّاروْينْثْ؟
\m 
\v 30 غَارْ إِنِّي إِتّْغِيمَانْ غَارْ بِينُو أَڒْ ثَامذِّيثْ،
\m غَارْ يِينِّي د-يُوسِينْ
\m حِيمَا أَذْ قَّاسنْ بِينُو إِخدْجْضنْ. \x ◘ \xo 23:‏30 \xt إِشا. 5‏:‏11، 22\x*
\m 
\v 31 وَارْ خزَّارْ غَارْ بِينُو، خْمِي إِتّزْوِيغْ،
\m إِتّْڒِيقْڒِيقْ ذِي ڒْكَاسْ ؤُ نتَّا إِهْونْ \add إِ ثِيسِّيثْ\add*.
\m 
\v 32 غَارْ ؤُنڭَّارْ إِتّْغِيمَا إِزعّفْ
\m أَمْ يِيجّْ ن ؤُفِيغَارْ،
\m إِتّْرُوشَّا سّمْ أَمْ ثْڒفْسَا.
\m 
\v 33 ثِيطَّاوِينْ نّشْ أَذْ ثْوَاڒَانْثْ
\m ثِيمْغَارِينْ ثِيبَارَّانِييِّينْ،
\m ؤُ ؤُڒْ نّشْ أَذْ إِسِّيوڒْ س ؤُخَارْوضْ.
\m 
\v 34 شكْ أَذْ ثِيڒِيذْ أَمْ يِيجّنْ
\m إِ إِتّطّْصنْ ذِي ڒْوسْطْ ن ڒبْحَارْ،
\m أَمْ إِجّنْ إِ إِتّطّْصنْ
\m ذِي ثْقِيشَّاثْ ن ثحْنَاشْثْ \add ن ؤُغَارَّابُو\add*
\m 
\v 35 \add أَذْ ثِينِيذْ:\add* ”وْثِينْ أَيِي، \add مَاشَا\add* وَارْ يزْمغْ،
\m ذخْمنْ أَيِي، \add مَاشَا\add* وَارْ ؤُشِيغْ أَكْ-ذ وَالُو.
\m مڒْمِي إِ د غَا فَاقغْ؟
\m نشّْ أَذْ أَرْزُوغْ عَاوذْ \add غَارْ بِينُو\add*!“
\b
\b
\c 24
\m 
\v 1 وَارْ تَّاسمْ.
\m زڭْ إِرْيَازنْ إِعفَّاننْ،
\m وَارْ أَرزُّو شَا ثْمُونثْ أَكِيذْسنْ. \x ◘ \xo 24:‏1 \xt إِزهد. 37‏:‏1؛ أَوڒن. 3‏:‏31؛ 23‏:‏17\x*
\m 
\v 2 مَاغَارْ ؤُڒْ نْسنْ إِتّقّرْ غَارْ ؤُردّدْجْ،
\m أَوَاڒنْ ن إِينْشِيشنْ نْسنْ
\m \add إِ د-إِتّْوَاينْ غَارْ\add* أَرْژِييّثْ. \x ◘ \xo 24:‏2 \xt إِزهد. 10‏:‏7\x*
\m 
\v 3 ثَادَّارْثْ ثتّْوَابْنَا س ثِيغِيثْ،
\m ثتّْوَاسّمْثنْ س ڒفْهَامثْ،
\m 
\v 4 س ثُوسّْنَا تّْوَاعمَّارنْ
\m إِخَّامنْ ن ذَاخڒْ،
\m س مَارَّا أَڭْڒَا إِغْڒَانْ ذ وَاڭْڒَا إِڒِيقّنْ.
\m 
\v 5 أَرْيَازْ أَمِيغِيسْ إِجْهذْ،
\m أَرْيَازْ ن ثُوسّْنَا يَارنِّي ذِي جّهْذْ نّسْ، \x ◘ \xo 24:‏5 \xt أَوڒن. 21‏:‏22\x*
\m 
\v 6 مَاغَارْ إِتّْخصَّا
\m أَذْ إِتّْوَانْذهْ ؤُمنْغِي س ؤُذبَّارْ،
\m ؤُ س ڒمْغَارثْ ن ؤُمْشَاوَارْ أَذْ يِيڒِي ؤُسنْجمْ. \x ◘ \xo 24:‏6 \xt أَوڒن. 11‏:‏14؛ 15‏:‏22؛ 20‏:‏18\x*
\m 
\v 7 ثِيغِيثْ ثُوعْڒَا خْ ؤُبُوهَاڒِي،
\m نتَّا وَارْ يَارزّمْ أَقمُّونْ نّسْ
\m ذِي ثوَّارْثْ \add ن ثنْذِينْثْ\add*. \x ◘ \xo 24:‏7 \xt أَوڒن. 14‏:‏6\x*
\b
\m 
\v 8 ونِّي إِتّْخَارِّيصنْ ذِي ڒْغَارْ،
\m أَذْ أَسْ ڒَاغَانْ أَرَّايْسْ ن بُو-ثحْڒَايْمشْثْ.
\m 
\v 9 ڒمْوَايَاڒْ ن ؤُخَارّصْ ن ؤُبُوهَاڒِي ذ دّنْبْ،
\m ؤُ أَمسْثهْزِييْ ذ نّْعِي إِ بْنَاذمْ.
\m 
\v 10 مَاڒَا ثَارْخُوذْ زڭْ إِخفْ نّشْ
\m ذڭْ وَاسّْ ن ڒحْصَارثْ،
\m أَمُّو ؤُڒَا ذ جّْهذْ نّشْ أَذْ ثتّْوَاحْصَارْ.
\m 
\v 11 سنْجمْ إِنِّي إِتّْوَاطّْفنْ
\m مَاحنْذْ أَذْ تّْوَانْغنْ،
\m إِنِّي ثنْ إِتَّاوْينْ
\m غَارْ مَانِي ثنْ إِ غَا نْغنْ،
\m سْبدّْ إِ-ثنْ! \x ◘ \xo 24:‏11 \xt إِزهد. 82‏:‏4\x*
\m 
\v 12 مَاڒَا شكْ أَذْ ثِينِيذْ:
\m ”خْزَارْ، أَقَا وَارْ نسِّينْ وَالُو خْ مَانْ أَيَا!“،
\m مَا ونِّي إِوزّْننْ ؤُڒَاونْ،
\m وَارْ ث إِسَّارْڭِيبْ؟
\m ونِّي إِحطَّانْ ڒعْمَارْ نّشْ، إِسّنْ إِ-ث!
\m نتَّا أَذْ إِخدْجصْ بْنَاذمْ
\m عْلَاحْسَابْ ڒْخذْمثْ نّسْ. \x ◘ \xo 24:‏12 \xt أَيُوبْ 34‏:‏11؛ إِزهد. 62‏:‏13؛ إِرْم. 32‏:‏19؛ رُوم. 2‏:‏6؛ أَسَا. 22‏:‏12\x*
\b
\m 
\v 13 أشّْ ثَامّنْثْ، أَ مِّي،
\m مَاغَارْ نتَّاثْ ثصْبحْ،
\m ثَامّنْثْ ن ثغْرَاسْثْ
\m أَقَا ذ ثْمِيژِيذْثْ إِ وَانغْ نّشْ.
\m 
\v 14 أَمُّو إِ ثدْجَا ثُوسّْنَا ن ثِيغِيثْ
\m إِ ڒعْمَارْ نّشْ.
\m مَاڒَا ثُوفِيذْ ت، \add خنِّي\add* ثدْجَا ثِيوشَّا،
\m ڒَْايَاسْ نّشْ وَارْ إِتّْوَاقطّعْ شَا. \x ◘ \xo 24:‏14 \xt إِزهد. 19‏:‏11؛ 119‏:‏103؛ أَوڒن. 23‏:‏18\x*
\m 
\v 15 \add أَ\add* أَعفَّانْ، وَارْ ثتّْحَامَا
\m خْ ثْزذِّيغْثْ ن ؤُمْسڭّذْ،
\m وَارْ هدّمْ أَمْشَانْ ن وَاريّحْ نّسْ!
\m 
\v 16 مَاغَارْ أَمْسڭّذْ
\m أَذْ إِوْضَا سبْعَا ن ثْوَاڒَاوِينْ،
\m أَذْ د-إِكَّارْ عَاوذْ،
\m \add مَاشَا\add* إِعفَّاننْ أَذْ نّْقَارْضنْ س ڒْغَارْ. \x ◘ \xo 24:‏16 \xt أَيُوبْ 5‏:‏19؛ إِزهد. 34‏:‏20؛ عَام. 5‏:‏2؛ 8‏:‏14\x*
\m 
\v 17 وَارْ فَارّحْ إِ \add ؤُ\add*وطُّو ن ڒعْذُو نّشْ،
\m مَاڒَا نتَّا إِنْقَارْضْ،
\m أجّْ ؤُڒْ نّشْ وَارْ إِفَارّحْ، \x ◘ \xo 24:‏17 \xt أَيُوبْ 31‏:‏29؛ أَوڒن. 17‏:‏5\x*
\m 
\v 18 مَاحنْذْ سِيذِي وَارْ ث إِژَارّْ
\m ؤُ مَانْ أَيَا أَذْ يِيڒِي ذ ڒْعِيبْ ذِي ثِيطَّاوِينْ نّسْ،
\m \add أَڒَامِي\add* نتَّا أَذْ خَاسْ إِسّْحيّذْ أَغْضَابْ نّسْ.
\m 
\v 19 وَارْ تّْخيِّيقْ أَطَّاسْ
\m خْ ونِّي إِتّڭّنْ ڒْغَارْ،
\m وَارْ تَّاسمْ زڭْ إِعفَّاننْ، \x ◘ \xo 24:‏19 \xt إِزهد. 37‏:‏1؛ 73‏:‏3؛ أَوڒن. 3‏:‏31؛ 23‏:‏17؛ 24‏:‏1\x*
\m 
\v 20 مَاغَارْ أَقَا ونِّي إِتّڭّنْ ڒْغَارْ
\m وَارْ غَارسْ ثِيوشَّا،
\m ڒفْنَارْ ن إِعفَّاننْ أَذْ إِتّْوَاسّخْسِي. \x ◘ \xo 24:‏20 \xt أَيُوبْ 18‏:‏5، 6؛ أَوڒن. 13‏:‏9؛ 20‏:‏20\x*
\m 
\v 21 \add أَ\add* مِّي، ڭّْوذْ سِيذِي ذ ؤُجدْجِيذْ،
\m وَارْ تّْخدْجضْ شَا إِخفْ نّشْ
\m أَكْ-ذ يِينِّي إِخْسنْ أَذْ نْقڒْبنْ \add كُوڒْشِي\add*،
\m 
\v 22 مَاغَارْ أَذْ د-يَاسْ ؤُضيّعْ نْسنْ
\m ذڭْ إِجّْ ن ؤُمُورْ،
\m وِي إِسّْننْ أَنڭَّارُو أَعفَّانْ
\m ن إِسڭّْوُوسَا نْسنْ؟
\b
\s1 أَوَاڒنْ إِوزْننْ ن أَيْثْ ن ثِيغِيثْ -ثَاسْغَارْثْ 2
\m 
\v 23 \bd ؤُڒَا ذ يِينَا ذ \bdit أَوَاڒنْ إِوزْننْ\bdit* ن إِمِيغِيسنْ.\bd*
\m أَسْفَارْزْ ن وُوذْمَاونْ ذِي دّعْوثْ
\m وَارْ إِدْجِي شَا مْلِيحْ. \x ◘ \xo 24:‏23 \xt ؤُف. 23‏:‏3، 6؛ لَاوِي 19‏:‏15؛ أَعَوذ. 1‏:‏17؛ 16‏:‏19؛ أَوڒن. 18‏:‏5؛ 28‏:‏21؛ يُوح. 7‏:‏24؛ يَاع. 2‏:‏1\x*
\m 
\v 24 ونِّي إِقَّارنْ إِ ؤُعفَّانْ: ”شكْ ذ أَمْسڭّذْ!“،
\m وَانِيثَا أَذْ ث نعْڒنْ ڒڭْنُوسْ،
\m أَذْ ث شَارْهنْ شُّوعُوبْ. \x ◘ \xo 24:‏24 \xt أَوڒن. 17‏:‏15؛ إِشا. 5‏:‏23\x*
\m 
\v 25 \add مَاشَا\add* إِنِّي ثنْ إِ غَا إِحَاكْمنْ،
\m أَذْ إِڒِينْ مْلِيحْ،
\m لْبَارَاكَا س \add مَارَّا\add* ڒْخَارْ أَذْ غَارْسنْ د-ثَاسْ.
\m 
\v 26 \add أَمْ إِجّنْ\add* ونِّي إِسُّوذُومنْ إِينْشِيشنْ،
\m \add أَمُّو إِ يدْجَا\add* ونِّي د-إِتَّارَّانْ
\m س وَاوَاڒنْ إِسڭّْمنْ.
\m 
\v 27 سوْجذْ ڒْخذْمثْ نّشْ بَارَّا،
\m كمّڒْ  إِ-ت إِ يِيخفْ نّشْ ذڭْ إِيَّارْ،
\m ؤُشَا بْنَا ثَادَّارْثْ نّشْ أَوَارْنِي مَانْ أَيَا!
\m 
\v 28 وَارْ تِّيڒِي ذ أَشهَّاذْ بْڒَا سِّيبّثْ
\m خْ جَّارْ نّشْ.
\m مَا \add إِعدّڒْ\add* أَذْ ثْغَارّذْ س إِينْشِيشنْ نّشْ؟
\m 
\v 29 وَارْ قَّارْ: ”أَمْ مَامّشْ إِ ذ أَيِي إِڭَّا،
\m أَمُّو إِ د-أَسْ غَا ڭّغْ ؤُڒَا ذ نشّْ!“،
\m \add مَاغَارْ\add* نشّْ أَذْ د-خڒْفغْ زِي كُوڒْ  إِجّنْ
\m عْلَاحْسَابْ ڒْخذْمثْ نّسْ. \x ◘ \xo 24:‏29 \xt رُوم. 12‏:‏17، 19\x*
\b
\m 
\v 30 نشّْ كّغْ خْ ييَّارْ ن إِجّْ ن ؤُمعْڭُوزْ،
\m خْ ؤُمَارْجعْ ن ؤُضِيڒْ ن إِجّْ ن بْنَاذمْ
\m س وُوڒْ نّسْ وَارْ إِمْثِيننْ.
\m 
\v 31 خْزَارْ، ثْڭعّذْ-د خَاسْ مَارَّا ثيْزِيثْ،
\m ثذْڒَا ثْزڭّْوَارْثْ ؤُذمْ ن ثمُّورْثْ نّسْ،
\m أَقَا ڒْحِيضْ نّسْ ن وژْرُو إِتّْوَاهْذمْ.
\m 
\v 32 \add ڒَْامِي\add* ت ژْرِيغْ، كْسِيغْ ت غَارْ وُوڒْ إِنُو،
\m ژْرِيغْ ت ؤُشَا كْسِيغْ ت أَمْ يِيجّْ ن ؤُوبّخْ.
\m 
\v 33 ”أجّْ أَيِي أَذْ طّْصغْ شْوَايْثْ ذْرُوسْثْ،
\m شْوَايْثْ ذْرُوسْثْ ن ؤُنُوذمْ،
\m شْوَايْثْ ذْرُوسْثْ ن ؤُبُوزّڒْ س إِفَاسّنْ ضفْصنْ، \x ◘ \xo 24:‏33 \xt أَوڒن. 6‏:‏10، 11\x*
\m 
\v 34 \add ذِينِّي\add* د غَا يَاسْ زّڒْضْ نّشْ،
\m ؤُڒَا ذ ڒغْبنْ نّشْ
\m أَمْ يِيجّْ ن ورْيَازْ س ڒسْنَاحْ.“ \x ◘ \xo 24:‏34 \xt أَوڒن. 6‏:‏11\x*
\b
\b
\c 25
\s1 أَوَاڒنْ إِوزْننْ ن سُولِيمَانْ - ثَاسْغَارْثْ 2
\m 
\v 1 \bd ؤُڒَا ذ إِنَا ذ أَوَاڒنْ إِوزْننْ ن سُولِيمَانْ\bd*
\m \bd نِّي إِتّْعَاوَاذنْ ؤُرِينْ ثنْ إِرْيَازنْ ن حِيزْقِييَا،\bd*
\m \bd أَجدْجِيذْ ن يَاهُوذَا.\bd*
\m 
\v 2 أَقَا ذ شَّانْ ن أَربِّي
\m مَاحنْذْ أَذْ إِسَّارْ إِشْثْ ن ثْمسْڒَاشْثْ،
\m \add مَاشَا\add* شَّانْ ن إِجدْجِيذنْ
\m ذ أَبقّشْ ذڭْ إِشْثْ ن ثْمسْڒَاشْثْ. \x ◘ \xo 25:‏2 \xt رُوم. 11‏:‏33\x*
\m 
\v 3 ڒُْوعْڒَا ن ؤُجنَّا ذ ڒَادْجَاغْ ن ثمُّورْثْ،
\m ذ وُوڒْ ن إِجدْجِيذنْ وَارْ دْجِينْ إِ ؤُبقّشْ.
\m 
\v 4 كّسْ كُوفُّو زِي نُّوقَارْثْ،
\m أَذْ د-ثفّغْ إِشْثْ نْ ڒْقشْعثْ إِ ومْزِيڒْ.
\m 
\v 5 سْبعّذْ إِعفَّاننْ
\m زِي زَّاثْ ن وُوذمْ ن ؤُجدْجِيذْ،
\m \add خنِّي\add* أَذْ إِتّْوَاسّمْثنْ
\m ڒْْعَارْشْ نّسْ س ثْسڭْذَا. \x ◘ \xo 25:‏5 \xt أَوڒن. 20‏:‏8، 28\x*
\m 
\v 6 وَارْ ثْفيّشْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ،
\m وَارْ تّْبذِّي مَانِي تّْبدَّانْ إِمقّْرَاننْ.
\m 
\v 7 مَاغَارْ إِحْڒَا أَذْ أَشْ إِنِينْ: ”ڭعّذْ-د ذَا!“،
\m ؤُڒَا مَا أَذْ شكْ سّهْوَانْ
\m زَّاثْ إِ وُوذمْ ن إِجّْ ن ؤُمْشنّعْ
\m نِّي ژْرِينْثْ ثِيطَّاوِينْ نّشْ. \x ◘ \xo 25:‏7 \xt لك. 14‏:‏7‏-‏11\x*
\b
\m 
\v 8 وَارْ تّْقدْجِيقْ أَذْ ثذْعِيذْ،
\m مَاغَارْ مِينْ ثخْسذْ أَذْ ثڭّذْ
\m غَارْ ؤُنڭَّارْ نّسْ،
\m مَاڒَا جَّارْ نّشْ أَذْ شكْ إِسّفْضحْ؟ \x ◘ \xo 25:‏8 \xt أَوڒن. 18‏:‏17\x*
\m 
\v 9 شَارّعْ أَكْ-ذ جَّارْ نّشْ،
\m \add مَاشَا\add* وَارْ سُّوفُّوغْ سِّيرّْ ن ونّغْنِي،
\m 
\v 10 حِيمَا ونِّي ذ أَسْ إِتّسْڒَانْ
\m وَارْ شكْ إِسّْحشّمْ شَا،
\m مَاغَارْ \add ڒخْذنِّي\add* وَارْ إِزمَّارْ
\m أَذْ ثتّْوَاسّْبعّذْ ڒفْضِيحثْ نّشْ \add عَاذْ\add*.
\b
\m 
\v 11 \add أَمْ\add* تّفَّاحِينْ ن وُورغْ
\m خْ طّْبَاسَا ن نُّوقَارْثْ،
\m \add أَمُّو دْجَانْ\add* وَاوَاڒنْ سِّيوْڒنْ ثنْ
\m س ڒقْيَاسْ نّسْ.
\m 
\v 12 \add أَمْ\add* إِشْثْ ن ثْخَاذنْثْ ن وُورغْ
\m ؤُ \add أَمْ\add* إِشْثْ ن ثْسدّشْثْ ن وُورغْ إِغْڒَانْ قَاعْ،
\m \add أَمُّو إِ إِدْجَا\add* ؤُوبّخْ أَمِيغِيسْ
\m غَارْ ؤُمزُّوغْ إِتّسْڒَانْ.
\m 
\v 13 أَمْ وذْفڒْ أَسمَّاضْ
\m ذڭْ إِجّْ ن وَاسّْ ن ثْميْرَا،
\m \add أَمُّو إِ\add* إِدْجَا ؤُمْسخَّارْ ذَايسْ ڒَامَانْ
\m إِ ونِّي ث إِسّكَّانْ،
\m \add مَاغَارْ\add* إِسّْفَاقَا ڒعْمَارْ ن بَابْ نّسْ. \x ◘ \xo 25:‏13 \xt أَوڒن. 13‏:‏17\x*
\m 
\v 14 \add أَمْ\add* إِسيْنُوثنْ ذ ؤُسمِّيضْ بْڒَا أَنْژَارْ،
\m \add أَمُّو\add* أَرْيَازْ نِّي إِتّْعفَّارْ
\m ذڭْ إِشْثْ ن ثرْزفْثْ وَارْ إِسكّْوِينْ.
\b
\m 
\v 15 س تَّاسِيعْ ن ڒْخَاضَارْ إِتّْوَاسّقْنعْ ڒْحَاكمْ،
\m إِجّْ ن يِيڒسْ أَمِيژِيذْ إِتَّارژَّا إِغْسَانْ. \x ◘ \xo 25:‏15 \xt أَوڒن. 15‏:‏1؛ 16‏:‏14\x*
\m 
\v 16 \add مَاڒَا\add* ثُوفِيذْ ثَامّنْثْ،
\m أشّْ مِينْ ثحْوَاجذْ وَاهَا،
\m نِيغْ أَذْ ثَافّْ ثشِّيذْ كْثَارْ زِي مِينْ ثحْوَاجذْ،
\m ؤُ بَالَاكْ أَذْ ت-إِ-د ثْعُوقّذْ.
\m 
\v 17 وَارْ سّْرُوسَا أَضَارْ نّشْ
\m أَطَّاسْ ذِي ثَادَّارْثْ ن جَّارْ نّشْ،
\m نِيغْ أَذْ شكْ إِجِّيونْ ؤُ أَذْ شكْ إِعِيفّْ.
\b
\m 
\v 18 \add أَمْ\add* وفْضِيسْ ذ سِّيفْ ذ فْڒِيثْشَا إِقضْعنْ،
\m \add أَمُّو إِ إِدْجَا\add* ورْيَازْ نِّي إِشهّْذنْ
\m س ژُورْ خْ جَّارْ نّسْ. \x ◘ \xo 25:‏18 \xt إِزهد. 11‏:‏2؛ 57‏:‏5؛ 59‏:‏8؛ 120‏:‏4؛ أَوڒن. 12‏:‏18\x*
\m 
\v 19 \add أَمْ\add* ثِيغْمسْثْ يَارْژنْ
\m ؤُ \add أَمْ\add* ؤُضَارْ إِنْقْرَاضنْ،
\m \add أَمُّو\add* إِ إِدْجَا ؤُثشْڒِي
\m خْ ونِّي وَارْ ذِي إِدْجِي تِّيقثْ
\m ذڭْ وَاسّْ ن ڒحْصَارثْ.
\m 
\v 20 \add أَمْ\add* ونِّي إِتّكّْسنْ أَپَارْثسُّو نّسْ
\m ذڭْ إِجّْ ن وَاسّْ إِسْمضْ
\m ؤُ \add أَمْ\add* ڒْخدْجْ إِ تّڭّنْ خْ نِيطْرُونْ،
\m \add أَمُّو إِ إِدْجَا\add* ونِّي إِتّْغنَّاجنْ إِزْڒَانْ
\m زَّاثْ إِ يِيجّنْ س وُوڒْ إِشْضنْ. \x ◘ \xo 25:‏20 \xt رُوم. 12‏:‏15\x*
\m 
\v 21 مَاڒَا إِدْجُوژْ ونِّي شكْ إِشَارّْهنْ،
\m \add خنِّي\add* أوْشْ أَسْ أَغْرُومْ،
\m مَاڒَا إِفُّوذْ، أوْشْ أَسْ أَذْ إِسُو، \x ◘ \xo 25:‏21 \xt ؤُف. 23‏:‏4، 5؛ رُوم. 12‏:‏20\x*
\m 
\v 22 مَاغَارْ أَمُّو إِ ثْيَارّْوذْ
\m ڒفْحمْ \add إِتّحْذُوذُوقنْ\add* خْ ؤُزدْجِيفْ نّسْ،
\m ؤُ سِيذِي أَذْ شكْ إِخدْجصْ.
\b
\m 
\v 23 أَسمِّيضْ زِي شَّامَالْ إِتَّاوِي-د أَنْژَارْ،
\m إِڒسْ أَغدَّارْ \add إِتَّاوِي-د\add* ؤُذْمَاونْ إِخيّْقنْ.
\m 
\v 24 إِحْڒَا أَذْ ثْزذْغذْ
\m ذڭْ إِشْثْ ثغْمَارْثْ ن ثْزقَّا،
\m ؤُڒَا خْ \add ثَازذِّيغْثْ\add*
\m أَكْ-ذ إِشْثْ ن ثمْغَارْثْ إِتّمْشُوبُّوشنْ
\m ذڭْ إِشْثْ ن ثَادَّارْثْ ثْشَارْشْ. \x ◘ \xo 25:‏24 \xt أَوڒن. 21‏:‏9، 19\x*
\m 
\v 25 \add أَمْ\add* وَامَانْ إِصمَّاضنْ
\m إِ يِيجّْ ن ڒعْمَارْ يُوحڒْ،
\m \add أَمُّو إِ إِدْجَا\add* ڒخْبَارْ أَصبْحَانْ
\m زڭْ إِشْثْ ن ثمُّورْثْ ثِيڭّْوجْ.
\m 
\v 26 \add أَمْ\add* إِجّْ ن ڒْعُونْصَارْ إِتّْوَافسْذنْ
\m ؤُ \add أَمْ\add* إِجّْ ن وَانُوغشّنْ ث،
\m \add أَمُّو إِ إِدْجَا\add* ؤُمْسڭّذْ إِتّْزعْزِيعنْ
\m زَّاثْ إِ وُوذمْ ن إِعفَّاننْ.
\m 
\v 27 مَاشَّا ن وَاطَّاسْ ن ثَامّنْثْ
\m وَارْ إِدْجِي شَا مْلِيحْ،
\m \add مَاشَا\add* ثَارزُّوثْ
\m ذِي ثْمسْڒَايِينْ يوْعَارنْ ذ شَّانْ.
\m 
\v 28 \add أَمْ\add* إِشْثْ ن ثنْذِينْثْ إِهذْمنْ بْڒَا ڒْحِيضْ،
\m \add أَمُّو إِ إِدْجَا\add* إِجّْ ن ورْيَازْ
\m وَارْ إِتّطّفْ بُوحْبڒْ نّسْ. \x ◘ \xo 25:‏28 \xt أَوڒن. 16‏:‏32\x*
\b
\b
\c 26
\m 
\v 1 \add أَمْ\add* وذْفڒْ ذڭْ ؤُنبْذُو
\m ؤُ \add أَمْ\add* ونْژَارْ ذِي ثْميْرَا،
\m \add أَمُّو\add* وَارْ د-إِتِّيسْ شَّانْ أَكْ-ذ ؤُبُوهَاڒِي.
\m 
\v 2 أَمْ ژَّاوشْ إِتّْفَارْفَارنْ،
\m أَمْ ثْفَاڒْدْجسْثْ إِطَّاونْ \add سَّا ذ سَّا\add*،
\m أَمُّو إِ ثڭَّا إِشْثْ ن نّعْڒثْ بْڒَا سِّيبّثْ،
\m نتَّاثْ وَارْ ثْڒقّفْ. \f ◼ \fr 26:‏2 \ft \bd ’ژَّاوشْ‘\bd* - نِيغْ ’أَفْرُوخْ‘.\f*
\m 
\v 3 أَركُّوضْ إِ ؤُيِيسْ، سْڒِيمثْ إِ وغْيُوڒْ،
\m ؤُ أَعْمُوذْ إِ وعْرُورْ ن إِبُوهَاڒِييّنْ. \x ◘ \xo 26:‏3 \xt إِزهد. 32‏:‏9، 10؛ أَوڒن. 10‏:‏13\x*
\m 
\v 4 وَارْ د-تَّارِّي خْ ؤُبُوهَاڒِي
\m أَنشْثْ ثُوبُّوهڒْيَا نّسْ،
\m مَاحنْذْ ؤُڒَا ذ شكْ
\m وَارْ ذَايسْ ثَاركّْوسذْ.
\m 
\v 5 أَرّْ-د خْ ؤُبُوهَاڒِي
\m عْلَاحْسَابْ ثُوبُّوهڒْيَا نّسْ،
\m مَاحنْذْ وَارْ إِتّْغِيڒْ نتَّا ذ أَمِيغِيسْ
\m ذِي ثِيطَّاوِينْ نّسْ.
\m 
\v 6 \add أَمْ\add* ونِّي إِتّْقسّنْ إِضَارنْ ن يِيخفْ نّسْ
\m ؤُ \add أَمْ\add* ونِّي إِسسّنْ لْعُونْفْ،
\m \add أَمُّو إِ يدْجَا\add* ونِّي إِسّكَّانْ ثِيبْرَاثِينْ
\m س ؤُفُوسْ ن إِجّْ ن ؤُبُوهَاڒِي.
\m 
\v 7 ثِيمسَّاضِينْ ن ؤُنعْضَابْ أَرهْفنْثْ،
\m \add أَمُّو إِ يدْجَا\add* ؤُڒَا ذ أَوَاڒْ إِوزْننْ
\m ذڭْ ؤُقمُّومْ ن إِبُوهَاڒِييّنْ.
\m 
\v 8 أَمْ ونِّي إِتّْشدَّانْ
\m أَژْرُو إِغْڒَانْ ذڭْ إِدْجِييْ،
\m أَمُّو إِ إِدْجَا ونِّي إِتّڭّنْ شَّانْ إِ ؤُبُوهَاڒِي.
\m 
\v 9 \add أَمْ\add* إِشْثْ ن ثِيونْثْ ن ثْزڭّْوَارْثْ
\m د-إِڭّعّْذنْ ذڭْ ؤُفُوسْ ن ؤُسْكَارْجِي،
\m \add أَمُّو إِ إِدْجَا\add* لْمَاثَالْ
\m ذڭْ ؤُقمُّومْ ن إِبُوهَاڒِييّنْ.
\m 
\v 10 أَطَّاسْ إِزمَّارْ أَذْ د-إِسُّوفّغْ
\m مَارَّا \add زڭْ يِيخفْ نّسْ\add*،
\m \add مَاشَا\add* ڒْمُونثْ ن ؤُبُوهَاڒِي
\m ذ ونِّي ث غَا إِشْرَانْ، أَذْ خْسَارنْ.
\m 
\v 11 أَمْ إِجّْ ن وقْزِينْ إِعقْبنْ غَارْ مِينْ إِعُوقّْ،
\m \add أَمُّو إِ\add* إِتّْعَاوَاذْ إِجّْ ن ؤُبُوهَاڒِي
\m ثُوبُّوهڒْيَا نّسْ. \x ◘ \xo 26:‏11 \xt 2 بُط. 2‏:‏22\x*
\m 
\v 12 مَا ثژْرِيضْ \add عمَّارْصْ\add* إِجّْ ن ورْيَازْ
\m إِ إِتّڭّنْ إِخفْ نّسْ ذ أَمِيغِيسْ؟
\m أَقَا ذِينْ ڒَايَاسْ أَطَّاسْ إِ يِيجّْ ن ؤُبُوهَاڒِي
\m ؤُڒَا خَاسْ. \x ◘ \xo 26:‏12 \xt أَوڒن. 29‏:‏20\x*
\b
\m 
\v 13 أَمعْڭُوزْ إِقَّارْ:
\m ”\add أَقَا ذِينْ\add* إِجّْ ن وَايْرَاذْ إِزهَّارنْ
\m ذڭْ وبْرِيذْ،
\m إِجّْ ن ويْرَاذْ \add يُويُورْ\add* ذڭْ وَازَّاينْ!“ \x ◘ \xo 26:‏13 \xt أَوڒن. 22‏:‏13\x*
\m 
\v 14 \add أَمْ\add* ثوَّارْثْ ثتُّونُّوضْ إِ ثغْمَارْثْ نّسْ،
\m \add أَمُّو إِ إِتُّونُوضْ\add* ؤُڒَا ذ أَمعْڭُوزْ
\m ذِي قَامَا نّسْ.
\m 
\v 15 أَمعْڭُوزْ إِسّْنُوفَّارْ أَفُوسْ نّسْ ذِي طّبْصِي،
\m أَقَا نتَّا يَارْخُو مَاحنْذْ أَذْ ث إِسِّيوضْ
\m غَارْ ؤُقمُّومْ نّسْ. \f ◼ \fr 26:‏15 \ft \bd ’أَحْسِينْ‘\bd* - نِيغْ ’أَبحْرُورْ‘.\f*  \x ◘ \xo 26:‏15 \xt أَوڒن. 19‏:‏24\x*
\m 
\v 16 أَمعْڭُوزْ إِتّْوَاڒَا إِخفْ نّسْ ذ أَمِيغِيسْ،
\m زِي سبْعَا \add إِرْيَازنْ\add* نِّي \add إِزمَّارنْ\add*
\m أَذْ د-أَرّنْ س ڒفْهَامثْ.
\b
\m 
\v 17 \add أَمْ\add* ونِّي إِتّْشبَّارنْ
\m ذڭْ إِمزُّوغنْ ن وقْزِينْ،
\m \add أَمُّو إِ يدْجَا\add* ونِّي إِتَّاذْفنْ
\m ذڭْ ؤُمْشُوبّشْ نِّي وَارْ إِدْجِي نّسْ.
\m 
\v 18 أَمْ إِجّْ ن ؤُمجْنُونْ
\m نِّي إِشَّاثنْ إِصفْضَاونْ
\m ذ فْڒِيثْشَاثْ ذ \add سّمْ\add* إِنقّنْ،
\m 
\v 19 أَمُّو \add إِ إِدْجَا\add* ورْيَازْ نِّي إِشمْثنْ جَّارْ نّسْ،
\m ؤُشَا إِقَّارْ: ”أَقَا تّْقسَّارغْ وَاهَا، نِيغْ لَّا!“
\b
\m 
\v 20 مَاڒَا وَارْ إِدْجِي ؤُكشُّوضْ، أَذْ ثخْسِي ثْمسِّي،
\m ؤُ مَاڒَا وَارْ \add ذِينْ\add* إِدْجِي ؤُخْبَارْجِي،
\m يَارسَّا ؤُمْشُوبّشْ. \x ◘ \xo 26:‏20 \xt أَوڒن. 22‏:‏10\x*
\m 
\v 21 \add أَمْ إِدْجَا\add* ڒفْحمْ إِ ڒفْحمْ إِتّحْذُوذُوقنْ
\m ذ ؤُكشُّوضْ إِ ثْمسِّي،
\m \add أَمُّو إِ\add* يدْجَا إِجّْ ن ورْيَازْ إِتّمْشُوبُّوشنْ،
\m مَاحنْذْ أَذْ د-إِسْنكَّارْ أَمنْغِي. \x ◘ \xo 26:‏21 \xt أَوڒن. 15‏:‏18؛ 29‏:‏22\x*
\m 
\v 22 أَوَاڒنْ ن ؤُخْبَارْجِييْ أَمْ حَالَاوِيثْ،
\m ثِينِّي هكّْوَانْثْ
\m ذڭْ إِخَّامنْ ن ذَاخڒْ ن ؤُعذِّيسْ. \x ◘ \xo 26:‏22 \xt أَوڒن. 18‏:‏8\x*
\m 
\v 23 \add أَمْ\add* كُوفُّو ن نُّوقَارْثْ خْ ؤُشدْجِيقْ ن ثْڒَاخْثْ،
\m \add أَمُّو إِ دْجَانْ\add* إِينْشِيشنْ إِمِيزِيضنْ
\m ن يِيجّنْ س وُوڒْ ذ أَعفَّانْ.
\m 
\v 24 ونِّي ذِي إِدْجَا وشْرَاهْ،
\m إِسّْنُوفَّارَا \add إِ-ث\add* س يِيڒسْ نّسْ
\m \add مَاشَا\add* ذڭْ وُوڒْ نّسْ إِتّْخَارّصْ ذِي ڒْغشّْ.
\m 
\v 25 مَاڒَا نتَّا إِتّْحشّمْ س ثْمِيجَّا نّسْ،
\m وَارْ ث تِّيقِّي شَا،
\m مَاغَارْ سبْعَا ن نّْعَاوَاثْ
\m \add أَقَا ذِينْ\add* ذڭْ وُوڒْ نّسْ.
\m 
\v 26 ؤُڒَا مَاڒَا إِڒحّفْ وشْرَاهْ نّسْ
\m ذڭْ وشْمَاثْ،
\m ثُوعفّْنَا نّسْ أَذْ ثتّْوَاعَارَّا
\m ذڭْ وڭْرَاوْ \add ن ڒْڭنْسْ\add*.
\m 
\v 27 ونِّي إِغْزِينْ \add إِجّْ ن وحْفُورْ ن\add* ثُورْصُوضِي،
\m أَذْ ذَايسْ إِوْضَا سِيمَانْثْ نّسْ
\m ؤُ ثَاصْضَارْثْ أَذْ د-ثذْوڒْ
\m غَارْ ونِّي ت إِسّقْنُونُّوينْ. \x ◘ \xo 26:‏27 \xt إِزهد. 7‏:‏16؛ 9‏:‏16؛ 10‏:‏2؛ 57‏:‏7؛ أَمب. 10‏:‏8\x*
\m 
\v 28 إِڒسْ إِسّْخَارِّيقنْ
\m إِشَارّهْ ونِّي إِتَّاردّْدْجنْ،
\m إِجّْ ن ؤُقمُّومْ أَڒقَّاغْ \add س ثحْرَايْمشْثْ\add*
\m إِتَّاوِي-د ڒْخَارْبثْ.
\b
\b
\c 27
\m 
\v 1 وَارْ تّْفيّشْ زڭْ وَاسّْ ن ثِيوشَّا،
\m مَاغَارْ وَارْ ثسِّينذْ شَا
\m مِينْ د غَا يَاوِي وَاسّْ. \x ◘ \xo 27:‏1 \xt يَاع. 4‏:‏13، 14\x*
\m 
\v 2 أجّْ إِجّْ ن ؤُبَارَّانِي أَذْ شكْ إِشنّعْ،
\m وَارْ إِدْجِي أَقمُّومْ نّشْ،
\m إِجّْ ن مِيدّنْ، وَارْ إِدْجِي إِينْشِيشنْ نّشْ.
\m 
\v 3 أَژْرُو إِذْقڒْ، إِجْذِي إِوزّنْ،
\m \add مَاشَا\add* أَفُوڭمْ ن ؤُبُوهَاڒِي
\m إِذْقڒْ خَاسنْ س ثْنَاينْ إِذْسنْ.
\m 
\v 4 أَسْعَارْ ذ ؤُذُوقّزْ ن وغْضَابْ
\m أَقَا أَثنْ قسْحنْ،
\m \add مَاشَا\add* مَانْ ونْ إِزمَّارنْ
\m أَذْ إِقِّيمْ إِبدّْ غَارْ ثُوسْمِي؟
\m 
\v 5 ثحْڒَا تَّارْبِييّثْ س بْطَايْطَايْ
\m خْ ثَايْرِي إِنُّوفَّارنْ.
\m 
\v 6 إِيزِّيمنْ ن ونِّي \add شكْ\add* إِتّخْسنْ
\m أَقَا ذ \add ڒعْڒَامَاثْ ن\add* ڒَامَانْ،
\m \add مَاشَا\add* إِسُوذِيمنْ ن يِينِّي \add شكْ\add* إِشَارّْهنْ
\m أَقَا ذ أَطَّاسْ.
\b
\m 
\v 7 ونِّي إِجِّيوْننْ، إِعجّنْ
\m خْ ثَامّنْثْ ن ثغْرَاصْثْ،
\m \add مَاشَا\add* إِ ونِّي إِدْجُوژنْ
\m مَارَّا مِينْ يَارزْڭنْ ذ أَمِيژِيذْ. \f ◼ \fr 27:‏7 \ft \bd ’ونِّي‘\bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ‘.\f*
\m 
\v 8 أَمْ إِجّْ ن وجْضِيضْ إِطَّاوْ،
\m \add إِڭّْوذْ\add* زِي ڒْعُوشّْ نّسْ،
\m أَمُّو \add إِ إِدْجَا\add* ورْيَازْ نِّي إِ غَا إِطلّْعنْ
\m بَارَّا خْ ومْشَانْ نّسْ.
\m 
\v 9 زّشْثْ ذ ڒبْخُورْ سّْفَارَّاحنْ ؤُڒْ،
\m \add أَمُّو عَاوذْ\add* ثَامْسعَّافْثْ إِشْنَانْ
\m ن إِجّْ ن ؤُمدُّوكّڒْ زِي شّْوَارْ ن وُوڒْ.
\m 
\v 10 وَارْ سمّحْ ذڭْ ؤُمدُّوكّڒْ نّشْ،
\m ؤُڒَا ذڭْ ؤُمدُّوكّڒْ ن بَابَاشْ،
\m وَارْ تِّيذفْ شَا غَارْ ثَادَّارْثْ ن ؤُمَاشْ
\m ذڭْ وَاسّْ ن أَرْژِييّثْ نّشْ.
\m إِحْڒَا إِجّْ ن وَاجَّارْ يُوذسْ
\m خْ إِجّْ ن ثوْمَاثْ يِيڭّْوجْ. \x ◘ \xo 27:‏10 \xt أَوڒن. 17‏:‏17؛ 18‏:‏24\x*
\b
\m 
\v 11 إِڒِي ذ أَمِيغِيسْ، \add أَ\add* مِّي، ؤُ سْفَارْحْ ؤُڒْ إِنُو،
\m مَاحنْذْ زمَّارغْ أَذْ د-أَرّغْ
\m خْ ونِّي ذ أَيِي غَا إِسّحْقَارنْ.
\m 
\v 12 ونِّي إِفتّْننْ إِتّْوَاڒَا ڒْغَارْ
\m ؤُشَا إِسّْنُوفَّارَا إِخفْ نّسْ،
\m \add مَاشَا\add* إِحَافِييّنْ أَرنِّينْ ڭُّورنْ
\m ؤُشَا إِتّْخصَّا أَذْ تّْوَاعَاقَابنْ. \x ◘ \xo 27:‏12 \xt أَوڒن. 22‏:‏3\x*
\m 
\v 13 كْسِي أَرُّوضْ نّسْ،
\m مَاغَارْ إِدَّاكّْوَاڒْ ذ أَضْمَانْ
\m إِ يِيجّْ ن ؤُبَارَّانِي،
\m كْسِي ث ذ دِّييّثْ
\m إِ يِيشْثْ ن ثمْغَارْثْ زِي بَارَّا. \x ◘ \xo 27:‏13 \xt أَوڒن. 6‏:‏1، 2؛ 11‏:‏15؛ 17‏:‏18؛ 20‏:‏16\x*
\m 
\v 14 ونِّي إِتّْبَارْكنْ أَمدُّوكّڒْ نّسْ زِيشْ
\m غَارْ ثُوفُّوثْ س ثْمِيجَّا إِجهْذنْ،
\m أَقَا مَانْ أَيَا أَذْ أَسْ إِتّْوَاحْسبْ ذ نّعْڒثْ.
\m 
\v 15 \add أَمشْنَاوْ\add* ثُوذِّيمْثْ وَارْ إِتّْبذِّينْ
\m ذڭْ وَاسّْ ن ونْژَارْ إِجهْذنْ،
\m \add أَمُّو إِ ثدْجَا\add* ثمْغَارْثْ إِتّمْشُوبُّوشنْ. \x ◘ \xo 27:‏15 \xt أَوڒن. 19‏:‏13\x*
\m 
\v 16 ونِّي إِتّخْسنْ أَذْ أَسْ إِبلّعْ،
\m \add أَقَا-ث أَمْ ونِّي\add* إِتّخْسنْ
\m أَذْ إِقَالَا إِ ؤُسمِّيضْ،
\m ؤُ أَفُوسْ نّسْ أَفُوسِي
\m أَذْ إِطّفْ زّشْثْ \add إِتّحْرُودْجُوضنْ\add*.
\m 
\v 17 \add أَمْ\add* ونِّي إِسّقْضَاعنْ ؤُزَّاڒْ س وُوزَّاڒْ،
\m \add أَمُّو إِ\add* إِسّقْضَاعْ ورْيَازْ
\m ثِيمڭَّا ن ونِّي ث يُوذْسنْ.
\m 
\v 18 ونِّي إِحطَّانْ خْ إِجّْ ن وَارْثُو،
\m أَذْ إِشّْ ڒْغِيدْجثْ نّسْ،
\m ونِّي إِحطَّانْ بَابْ نّسْ،
\m أَذْ إِتّْوَاشنّعْ.
\m 
\v 19 أَمْ د-إِتّْبَانْ ؤُغمْبُوبْ ذڭْ ؤُغمْبُوبْ
\m ذڭْ وَامَانْ،
\m أَمُّو د-إِتّْبَانْ وُوڒْ نْ بْنَاذمْ
\m خْ بْنَاذمْ عَاوذْ.
\m 
\v 20 \add أَمْ\add* ڒَاخَارْثْ ذ ؤُسْهلّكْ وَارْ تّْيِيوِيننْ،
\m \add أَمُّو\add* ؤُڒَا ذ ثِيطَّاوِينْ ن إِوْذَانْ
\m وَارْ تِّيوْضنْثْ أَذْ جِّيوْننْثْ. \x ◘ \xo 27:‏20 \xt أَمب. 1‏:‏8\x*
\m 
\v 21 أَطنْجِيرْ ن ؤُسفْسِي إِ نُّوقَارْثْ
\m ذ ؤُفَارَّانْ إِ وُورغْ،
\m \add أَمُّو إِ إِدْجَا ؤُڒَا ذ\add* أَرْيَازْ
\m أَمْ مَامّشْ ث تّْمدَّاحنْ. \x ◘ \xo 27:‏21 \xt أَوڒن. 17‏:‏3\x*
\m 
\v 22 مَاڒَا ثدّْزذْ أَبُوهَاڒِي س وزْذُوزْ
\m ذِي ڒْمهْرَازْ جَارْ ڒْحبّْ ن إِمنْذِي،
\m ثُوبُّوهڒْيَا نّسْ وَارْ خَاسْ ثْحيِّيذْ.
\b
\m 
\v 23 حْضَا مَاحنْذْ أَذْ ثسّْنذْ
\m مَامّشْ د-إِتّْبَانْ وُودْجِي نّشْ،
\m وجّهْ ؤُڒْ نّشْ غَارْ ثْحِيمْرِيوِينْ.
\m 
\v 24 مَاغَارْ ڒكْسِيبثْ وَارْ ثتّْغِيمِي إِ ڒبْذَا،
\m نِيغْ مَا أَذْ إِقِّيمْ تَّاجْ \add ن وعْزَاڒْ\add*
\m زِي جِّيڒْ أَڒْ جِّيڒْ نّغْنِي؟
\m 
\v 25 مَاڒَا إِرُوحْ أَرْبِيعْ
\m ؤُشَا إِبَانْ-د ؤُغمُّويْ \add أَزِيزَا\add*،
\m إِتّْوَاحْثشْ أَفْسُو خْ إِذُورَارْ،
\m 
\v 26 \add خنِّي أَذْ إِڒِينْ\add* إِزْمَارنْ إِ وَارُّوضْ نّشْ،
\m ؤُڒَا ذ إِغَايْضنْ إِ ثْمسْغِيوْثْ ن يِيجّْ ن ييَّارْ. \x ◘ \xo 27:‏26 \xt 1 تِيم. 6‏:‏8\x*
\m 
\v 27 ؤُشَا أَذْ غَاركْ يِيڒِي مِينْ ثحْوَاجذْ
\m ن ؤُغِي ن ثْغَايْطِينْ إِ مَاشَّا نّشْ،
\m \add أَذْ يِيڒِي ذ\add* مَاشَّا إِ ثَادَّارْثْ نّشْ،
\m ؤُڒَا ذ ڒعْوتْشْ إِ ثمْسخَّارِينْ نّشْ ثِيمژْيَانِينْ.
\b
\b
\c 28
\m 
\v 1 إِعفَّاننْ تّْرَاكّْوَاڒنْ
\m وَاخَّا وَارْ \add ذِينِّي\add*
\m وِي \add إِ-ثنْ\add* إِضَافَّارنْ،
\m \add مَاشَا\add* إِمْسڭَّاذنْ ذَايْسنْ ثَارْيَاسْثْ
\m أَمْ ن إِجّْ ن وَايْرَاذْ. \x ◘ \xo 28:‏1 \xt لَاوِي 26‏:‏36؛ أَعَوذ. 28‏:‏28؛ إِشا. 57‏:‏21\x*
\m 
\v 2 زِي سِّيبّثْ ن ؤُعذِّي ن ثمُّورْثْ
\m \add أَقَا ذِينْ\add* أَطَّاسْ ن ڒْحُوكَّامْ نّسْ،
\m \add مَاشَا\add* س إِجّْ ن بْنَاذمْ س ڒعْقڒْ ذ ثُوسّْنَا،
\m أَذْ ثقِّيمْ صُّولْطَا \add ثْبدّْ\add*
\m إِ يِيجّْ ن ڒْوقْثْ ذ أَزِيرَارْ.
\m 
\v 3 أَرْيَازْ أَمزْڒُوضْ نِّي إِتّْزيَّارنْ خْ إِمَارْخَا،
\m \add أَمْ\add* ونْژَارْ إِتَّاوْينْ مَارَّا،
\m \add أَڒْ\add* وَارْ إِتّْغِيمِي عَاذْ وغْرُومْ.
\m 
\v 4 إِنِّي إِتّجَّانْ شَّارِيعَا
\m سّمْغَارَانْ أَعفَّانْ،
\m \add مَاشَا\add* إِنِّي إِحطَّانْ شَّارِيعَا
\m تّْمنْغَانْ أَكِيذْسنْ.
\m 
\v 5 إِرْيَازنْ إِعفَّاننْ وَارْ فهّْمنْ ڒْحقّْ،
\m \add مَاشَا\add* إِنِّي يَارزُّونْ سِيذِي،
\m فهّْمنْ إِ كُوڒْشِي.
\m 
\v 6 إِحْڒَا ؤُمزْڒُوضْ نِّي إِڭُّورنْ إِصْفَا،
\m خْ ونِّي إِڭُّورنْ إِفَارْغْ ذِي ثْنَاينْ ن إِبْرِيذنْ،
\m \add وَاخَّا\add* نتَّا غَارسْ أَڭْڒَا. \x ◘ \xo 28:‏6 \xt أَوڒن. 19‏:‏1\x*
\m 
\v 7 ونِّي إِحطَّانْ شَّارِيعَا،
\m ذ إِجّْ ن مِّيسْ إِفهّمْ،
\m \add مَاشَا\add* ونِّي ذ أَمدُّوكّڒْ ن إِملْهَافْ،
\m يَارَّا بَابَاسْ أَذْ إِسضْحَا. \x ◘ \xo 28:‏7 \xt أَوڒن. 29‏:‏3\x*
\m 
\v 8 ونِّي إِسّمْغَارَانْ أَڭْڒَا نّسْ
\m س أَرِّيبَا ذ وَارْبحْ،
\m إِسّْمُونَا أَيَا إِ ونِّي إِتّْحِينَّانْ
\m خْ إِمزْڒَاضْ. \x ◘ \xo 28:‏8 \xt لَاوِي 25‏:‏35‏-‏37\x*
\m 
\v 9 ونِّي إِسّْحيَّاذنْ أَمزُّوغْ نّسْ
\m زڭْ ؤُسدْجِي ن شَّارِيعَا،
\m \add عَاذْ\add* ثَاژَادْجِيثْ نّسْ ذ نّْعِي.
\m 
\v 10 ونِّي إِتَّارَّانْ إِنِّي إِڭُّورنْ نِيشَانْ
\m أَذْ ودَّارنْ خْ إِجّْ ن وبْرِيذْ أَعفَّانْ،
\m نتَّا سِيمَانْثْ نّسْ
\m أَذْ إِوْضَا ذِي ثسْرَافْثْ نّسْ،
\m \add مَاشَا\add* إِنِّي إِ ذِي ثدْجَا ڒكْمَارثْ
\m أَذْ وَارْثنْ مِينْ إِصبْحنْ. \x ◘ \xo 28:‏10 \xt أَوڒن. 26‏:‏27\x*
\m 
\v 11 بُو-وَاڭْڒَا إِتّڭّْ إِخفْ نّسْ ذ أَمِيغِيسْ
\m ذِي ثِيطَّاوِينْ نّسْ،
\m \add مَاشَا\add* إِجّْ ن ؤُمزْڒُوضْ
\m نِّي ذِي ثدْجَا ڒفْهَامثْ،
\m يَارْڭبْ خَاسْ.
\b
\m 
\v 12 مَاڒَا أَذْ سْڒِيوْڒِيونْ إِمْسڭَّاذنْ
\m س ڒفْرَاحثْ،
\m أَقَا ذِينْ أَعُودْجِي أَمقّْرَانْ،
\m \add مَاشَا\add* مَاڒَا كَّارنْ-د إِعفَّاننْ،
\m أَذْ إِسّْنُوفَّارْ بْنَاذمْ \add إِخفْ نّسْ\add*. \x ◘ \xo 28:‏12 \xt أَوڒن. 11‏:‏10، 11\x*
\m 
\v 13 ونِّي إِدَّاڒنْ إِخطَّانْ نّسْ،
\m وَارْ إِتّفْڒِيحْ،
\m \add مَاشَا\add* ونِّي زَّايْسنْ إِنعّْمنْ
\m ؤُ إِتّْحيَّاذْ خَاسنْ، أَذْ يَافْ أَرّحْمثْ. \x ◘ \xo 28:‏13 \xt إِزهد. 32‏:‏3، 5؛ 1 يُوح. 1‏:‏9، 10\x*
\m 
\v 14 سّعْذْ ن بْنَاذمْ
\m نِّي إِتّْوقَّارنْ بْڒَا أَبذِّي،
\m \add مَاشَا\add* ونِّي إِسّقْسَاحنْ ؤُڒْ نّسْ،
\m أَذْ إِوْضَا ذِي ڒْغَارْ.
\m 
\v 15 \add أَمْ\add* إِجّْ ن ويْرَاذْ إِتَّارُّوجْذُوذنْ،
\m \add أَمْ\add* إِجّْ ن دُّوبْ \add إِتّْڒَاژَانْ\add*
\m إِتَّازّْڒنْ زِي سَّا غَارْ ذِيهَا،
\m \add أَمُّو إِ إِدْجَا\add* إِجّْ نْ ڒْحَاكمْ أَعفَّانْ
\m خْ إِجّْ ن ڒْڭنْسْ أَمزْڒُوضْ.
\m 
\v 16 ڒْحَاكمْ نِّي بْڒَا ڒفْهَامثْ،
\m \add أَقَا-ث ذ ڒْحَاكمْ خْ\add* وَاطَّاسْ ن ورْبَاحْ
\m س ؤُبعّجْ،
\m \add مَاشَا\add* ونِّي إِشَارّْهنْ أَرْبحْ،
\m أَذْ إِزُّوڭَّارْثْ ؤُسَّانْ نّسْ.
\m 
\v 17 إِجّْ ن بْنَاذمْ إِتّْوَاحْصَارنْ
\m ؤُمِي إِسِّيزّڒْ إِذَامّنْ ن شَا ن يِيجّنْ،
\m أَذْ يَارْوڒْ غَارْ وحْفُورْ ن ونْضڒْ
\m \add ن يِيخفْ نّسْ\add*.
\m وَارْ تّجِّي حذْ أَذْ ث إِسّْبدّْ!
\m 
\v 18 ونِّي إِڭُّورنْ \add أَبْرِيذْ نّسْ\add* ذِي ڒصْفَايثْ،
\m أَذْ إِنْجمْ،
\m \add مَاشَا\add* ونِّي إِڭُّورنْ
\m إِفَارْغْ ذِي ثْنَاينْ ن إِبْرِيذنْ،
\m وَارْ إِتّْعطَّارْ أَذْ إِوْضَا.
\m 
\v 19 ونِّي إِشَارّْزنْ ثَامُّورْثْ نّسْ،
\m أَذْ إِجَّاونْ س وغْرُومْ،
\m \add مَاشَا\add* ونِّي إِضفَّارنْ أَرْيَازْ إِخْوَانْ،
\m أَذْ إِجَّاونْ زّڒْضْ.
\m 
\v 20 أَرْيَازْ إِ ذِي إِدْجَا ڒَامَانْ أَطَّاسْ
\m \add أَذْ إِكْسِي\add* أَطَّاسْ ن لْبَارَاكَاثْ،
\m \add مَاشَا\add* ونِّي إِتّْقدْجِيقنْ حِيمَا أَذْ إِڭّْ أَڭْڒَا،
\m وَارْ إِتّْوِيحْسِيبْ ذ أَمزْذَاڭْ. \x ◘ \xo 28:‏20 \xt أَوڒن. 13‏:‏11؛ 20‏:‏21؛ 23‏:‏4\x*
\b
\m 
\v 21 أَسْفَارْزْ ن وُوذْمَاونْ وَارْ إِشْنِي شَا،
\m \add مَاغَارْ\add* إِ يِيجّْ ن ؤُڒقُّوزْ ن وغْرُومْ
\m \add إِزمَّارْ\add* شَا ن ورْيَازْ أَذْ إِخْضَا. \x ◘ \xo 28:‏21 \xt أَوڒن. 18‏:‏5؛ 24‏:‏23\x*
\m 
\v 22 أَرْيَازْ س ثِيطّْ ثَاعفَّانْثْ
\m إِتّْقدْجِيقْ غَارْ وَاڭْڒَا،
\m \add مَاشَا\add* نتَّا وَارْ إِسِّينْ
\m أَقَا ڒخْسسْ أَذْ غَارسْ د-يَاسْ.
\m 
\v 23 ونِّي إِتّْعَاقَابنْ إِجّْ ن بْنَاذمْ،
\m أَقَا غَارْ ؤُنڭَّارْ أَذْ يَافْ أَرْضَا كْثَارْ
\m خْ ونِّي إِسّْشَانَانْ ثَاژْيُوضِي س يِيڒسْ نّسْ.
\m 
\v 24 ونِّي إِتّْكشَّاضنْ بَابَاسْ نِيغْ يمَّاسْ
\m ؤُشَا إِقَّارْ: ”وَارْ إِدْجِي ذ دّنْبْ!“،
\m أَقَا-ث ذ أَشْرِيشْ ن إِجّْ ن بُو-ڒَْاخَارْثْ.
\m 
\v 25 ونِّي ذِي إِدْجَا نّْفَاخثْ،
\m إِسّكَّارَا-د أَمْشُوبّشْ،
\m \add مَاشَا\add* ونِّي إِتّْشَاڒَانْ خْ سِيذِي،
\m أَذْ إِذْوڒْ لَابَاسْ خَاسْ. \x ◘ \xo 28:‏25 \xt أَوڒن. 13‏:‏10؛ 15‏:‏18؛ 29‏:‏22\x*
\m 
\v 26 ونِّي إِتّْشَاڒَانْ خْ وُوڒْ نّسْ،
\m أَقَا ذ أَبُوهَاڒِي،
\m \add مَاشَا\add* ونِّي إِڭُّورنْ
\m \add أَبْرِيذْ نّسْ\add* ذِي ثِيغِيثْ،
\m أَذْ إِنْجمْ.
\m 
\v 27 ونِّي إِتِّيشنْ إِ إِمزْڒَاضْ،
\m وَارْ ذَايسْ إِتِّيڒِي بُو ڒغْبنْ،
\m \add مَاشَا\add* ونِّي إِتّقّْننْ ثِيطَّاوِينْ نّسْ،
\m أَذْ إِتّْوَانْعڒْ أَطَّاسْ. \x ◘ \xo 28:‏27 \xt أَعَوذ. 15‏:‏7، 8، 10؛ أَوڒن. 19‏:‏17؛ 22‏:‏9\x*
\m 
\v 28 مَاڒَا كَّارنْ-د إِعفَّاننْ،
\m \add خنِّي\add* إِتّْنُوفَّارْ بْنَاذمْ،
\m \add مَاشَا\add* مَاڒَا تّْوَاهلّْكنْ نِيثْنِي،
\m أَذْ مَّارنْينْ إِمْسڭَّاذنْ.\x ◘ \xo 28:‏28 \xt أَوڒن. 28‏:‏12\x*
\b
\b
\c 29
\m 
\v 1 أَرْيَازْ، ونِّي إِسّقْسْحنْ يِيرِي \add نّسْ\add*
\m أَوَارْنِي ڒَامِي ث عَاقْبنْ
\m أَطَّاسْ ن ثْوَاڒَاوِينْ،
\m أَذْ يَارْژْ ذڭْ إِجّْ ن ؤُمُورْ،
\m \add خنِّي\add* وَارْ ذِينْ إِدْجِي \add عَاذْ\add* ؤُڭنْفُو.
\m 
\v 2 مَاڒَا ذوْڒنْ إِمْسڭَّاذنْ س صُّولْطَا،
\m \add خنِّي\add* إِفَارّحْ ڒْڭنْسْ،
\m \add مَاشَا\add* مَاڒَا إِحكّمْ ؤُعفَّانْ،
\m إِوعّضْ ڒْڭنْسْ. \x ◘ \xo 29:‏2 \xt أَوڒن. 11‏:‏10؛ 28‏:‏12، 28\x*
\m 
\v 3 بْنَاذمْ إِتّخْسنْ ثِيغِيثْ، إِسّْفَارَّاحْ بَابَاسْ،
\m \add مَاشَا\add* ونِّي إِتّْمُونَانْ
\m أَكْ-ذ ثمْغَارِينْ ن فَارْقْ-شّْغڒْ،
\m يَاردّدْجْ أَڭْڒَا \add نّسْ\add*. \x ◘ \xo 29:‏3 \xt أَوڒن. 10‏:‏1؛ 15‏:‏20؛ 28‏:‏7؛ لك. 15‏:‏13\x*
\b
\m 
\v 4 أَجدْجِيذْ إِسّْبدَّا ثَامُّورْثْ س ڒْحقّْ،
\m \add مَاشَا\add* أَرْيَازْ نِّي إِسّْڭعَّاذنْ
\m ضَّارِيبَا أَطَّاسْ ن ثْوَاڒَاوِينْ،
\m إِهدّمْ إِ-ت.
\m 
\v 5 أَرْيَازْ نِّي إِسّْوَاطَانْ جَّارْ نّسْ،
\m إِتّْبزَّاعْ إِشْثْ ن ثْرَاشَّا إِ إِضَارنْ نّسْ.
\m 
\v 6 ذڭْ ؤُعذِّي ن إِجّْ ن ورْيَازْ أَعفَّانْ
\m \add إِنُّوفَّارْ ذَايسْ\add* إِجّْ ن ڒْفخْ،
\m \add مَاشَا\add* أَمْسڭّذْ إِتّسْڒِيوْڒوْ ؤُ إِفَارّحْ.
\m 
\v 7 أَمْسڭّذْ إِسّنْ دّعْوثْ ن إِمَارْخَا،
\m أَعفَّانْ وَارْ إِفهّمْ وَالُو ذِي ثُوسّْنَا. \x ◘ \xo 29:‏7 \xt أَيُوبْ 29‏:‏16\x*
\m 
\v 8 إِمسْثهْزَايّنْ سّكَّارَانْ
\m أَغوّغْ ذِي ثنْذِينْثْ،
\m \add مَاشَا\add* إِمِيغِيسنْ سّْنقْڒَابنْ أَغْضَابْ.
\m 
\v 9 \add مَاڒَا\add* أَمِيغِيسْ إِكْسِي-د ثَانْفُوتْشْ
\m إِ يِيجّْ ن ؤُبُوهَاڒِي،
\m \add خنِّي\add* نتَّا ڭُّورْ أَذْ إِخيّقْ وَانِيثَا
\m ؤُ أَذْ إِضْحشْ، \add مَاشَا\add* وَارْ ذِينْ ڒْهُوذْنثْ.
\b
\m 
\v 10 إِرْيَازنْ ؤُمِي إِتّعْجِيبْ إِذَامّنْ
\m شَارّْهنْ ونِّي إِكمّْڒنْ،
\m \add مَاشَا\add* إِنِّي إِڭُّورنْ نِيشَانْ
\m خزَّارنْ غَارْ ڒعْمَارْ نّسْ.
\m 
\v 11 أَبُوهَاڒِي إِضدْجقْ إِ مَارَّا بُوحْبڒْ نّسْ،
\m \add مَاشَا\add* أَمِيغِيسْ إِتّْقمّعْ إِ-ث. \x ◘ \xo 29:‏11 \xt أَوڒن. 14‏:‏33\x*
\m 
\v 12 ڒْحَاكمْ نِّي إِتِّيشنْ ثَايْنِيثْ
\m إِ ڒْهَارْذْ ن إِخَارِّيقّنْ،
\m زَّايسْ أَذْ إِڒِينْ
\m مَارَّا إِمْسخَّارنْ نّسْ ذ إِعفَّاننْ.
\m 
\v 13 أَمزْڒُوضْ ذ ورْيَازْ إِتّْوَاحْسَارنْ ڒبْذَا،
\m مْسَاڭَارنْ،
\m سِيذِي إِسّْنوَّارْ ثِيطَّاوِينْ نْسنْ
\m س ثْنَاينْ إِذْسنْ. \x ◘ \xo 29:‏13 \xt أَوڒن. 22‏:‏2\x*
\m 
\v 14 أَجدْجِيذْ نِّي إِتِّيشنْ س ثِيذتّْ ثَاسْغَارْثْ
\m إِ إِمَارْخَا ذِي شّْرعْ،
\m ڒْْكُورْسِي نّسْ أَذْ إِقِّيمْ إِبدّْ إِ ڒبْذَا. \x ◘ \xo 29:‏14 \xt أَوڒن. 20‏:‏28؛ 25‏:‏5\x*
\b
\m 
\v 15 أَعْمُوذْ ذ ؤُوبّخْ تِّيشنْ ثِيغِيثْ،
\m \add مَاشَا\add* أَحنْجِيرْ جِّينْ ث إِ يِيخفْ نّسْ،
\m يَارَّا يمَّاسْ أَذْ ثْسضْحَا. \x ◘ \xo 29:‏15 \xt أَوڒن. 10‏:‏1؛ 13‏:‏24؛ 17‏:‏21، 25؛ 22‏:‏15؛ 23‏:‏13\x*
\m 
\v 16 مَاڒَا ذوْڒنْ إِعفَّاننْ جهْذنْ،
\m \add خنِّي\add* يَارنِّي ؤُخطُّو،
\m \add مَاشَا\add* إِمْسڭَّاذنْ
\m أَذْ ژَترنْ وطُّو نْسنْ. \x ◘ \xo 29:‏16 \xt إِزهد. 37‏:‏36؛ 58‏:‏11؛ 91‏:‏8\x*
\m 
\v 17 أَربَّا مِّيشْ ؤُ نتَّا أَذْ شكْ إِسَّاريّحْ،
\m نتَّا أَذْ إِوْشْ \add لْبَارَاكَاثْ\add* ثِيمِيژِيذِينْ
\m إِ ڒعْمَارْ نّشْ. \x ◘ \xo 29:‏17 \xt أَوڒن. 13‏:‏24؛ 22‏:‏15؛ 23‏:‏13، 14\x*
\m 
\v 18 مَاڒَا وَارْ ذِينْ ڒوْحِييْ، إِتّْفُوشُّوحْ ڒْڭنْسْ،
\m سّعْذْ ن ونِّي إِحطَّانْ شَّارِيعَا.
\m 
\v 19 إِجّْ ن إِسْمغْ وَارْ إِتّجِّي
\m أَذْ ث أَرّبَّانْ س وَاوَاڒنْ،
\m مَاغَارْ وَاخَّا نتَّا إِفهّمْ خَاكْ،
\m وَارْ خَاكْ د-إِتَّارِّي شَا.
\m 
\v 20 مَا شكْ \add عمَّارْصْ\add* وَارْ ثژْرِيذْ إِجّْ ن ورْيَازْ
\m إِتّْقدْجِيقْ س وَاوَاڒنْ نّسْ؟
\m أَقَا ذِينْ ڒَايَاسْ كْثَارْ إِ ؤُبُوهَاڒِي ؤُڒَا خَاسْ. \x ◘ \xo 29:‏20 \xt أَوڒن. 26‏:‏12\x*
\m 
\v 21 \add مَاڒَا\add* إِجّنْ إِسُّوبضْ إِسْمغْ نّسْ زِي ثمْژِي،
\m أَذْ إِذْوڒْ غَارْ ؤُنڭَّارْ وَارْ ث إِتّْقِيذِي.
\b
\m 
\v 22 أَرْيَازْ إِتَّارُّوجْذُوذنْ
\m إِسّكَّارَا-د أَمْشُوبّشْ،
\m ؤُ بَابْ ن وسْعَارْ \add إِتّڭّْ\add* أَطَّاسْ ن إِخطَّانْ. \x ◘ \xo 29:‏22 \xt أَوڒن. 15‏:‏18؛ 26‏:‏21\x*
\m 
\v 23 نّْفَاخثْ ن بْنَاذمْ أَذْ ث إِسّْوَاضعْ،
\m \add مَاشَا\add* أَمْوَاضعْ ن بُوحْبڒْ
\m أَذْ أَسْ إِتّْوَاڭّْ شَّانْ. \x ◘ \xo 29:‏23 \xt أَيُوبْ 22‏:‏29؛ أَوڒن. 15‏:‏33؛ 18‏:‏12؛ إِشا. 66‏:‏2؛ مت. 23‏:‏12؛ لك. 14‏:‏11؛ 18‏:‏14؛ يَاع. 4‏:‏6، 10؛ 1 بُط. 5‏:‏5\x*
\m 
\v 24 ونِّي إِبطَّانْ أَكْ-ذ ؤُخوَّانْ،
\m إِشَارّهْ إِخفْ نّسْ،
\m \add مَاغَارْ\add* نتَّا إِتّسْڒَا إِ نّعْڒثْ،
\m \add مَاشَا\add* وَارْ ث إِقَّارْ شَا. \x ◘ \xo 29:‏24 \xt لَاوِي 5‏:‏1\x*
\m 
\v 25 ثِيڭّْوُوذِي زڭْ إِوْذَانْ ثْندّهْ غَارْ ڒْفخْ،
\m \add مَاشَا\add* ونِّي إِتّْشَاڒَانْ خْ سِيذِي،
\m أَذْ إِتّْوَاسّْڭعّذْ ذِي ڒَامَانْ.
\m 
\v 26 أَطَّاسْ أَرزُّونْ ؤُذمْ ن ڒْحَاكمْ،
\m \add وَاخَّا\add* ثَاسْغَارْثْ ن كُوڒْ إِجّْ ثتَّاسْ-د زِي سِيذِي. \x ◘ \xo 29:‏26 \xt أَوڒن. 19‏:‏6\x*
\m 
\v 27 أَرْيَازْ أَغشَّاشْ ذ نّْعِي إِ إِمْسڭَّاذنْ،
\m \add مَاشَا\add* ونِّي إِڭُّورنْ نِيشَانْ
\m ذڭْ وبْرِيذْ نّسْ،
\m أَقَا-ث ذ نّْعِي إِ ؤُعفَّانْ.
\b
\b
\c 30
\s1 أَوَاڒنْ إِوزْننْ ن أَجُورْ
\m 
\v 1 \bd أَوَاڒنْ ن أَجُورْ،\bd*
\m \bd مِّيسْ ن يَاكِي، \bdit زِي ثقْبِيتْشْ\bdit* ن مَاسَّا.\bd*
\m نشّْ أَرْبڒغْ، \add أَ\add* أَربِّي،
\m نشّْ أَرْبڒغْ، \add أَ\add* أَربِّي، ؤُ كمّْڒغْ.
\m 
\v 2 مَاغَارْ نشّْ ذ أَقفُّوحْ، وَارْ إِدْجِي ذ بْنَاذمْ،
\m ڒفْهَامثْ ن بْنَاذمْ وَارْ غَارِي ثدْجِي.
\m 
\v 3 نشّْ وَارْ ڒْمِيذغْ ثِيغِيثْ،
\m مَاحنْذْ أَذْ غَارِي ثِيڒِي ثُوسّْنَا
\m ن ؤُمْقدَّاسْ أَمقّْرَانْ.
\m 
\v 4 وِي إِڭعّْذنْ غَارْ ؤُجنَّا ؤُشَا إِهْوَا-د؟
\m مَانْ ونْ إِيَارّْونْ أَسمِّيضْ
\m ذڭْ إِفَاسّنْ نّسْ؟
\m وِي إِسّنّْضنْ أَمَانْ ذڭْ وَارُّوضْ؟
\m وِي يَاركّْننْ
\m مَارَّا ثِينڭُّورَا ن ثمُّورْثْ؟
\m مَانْ إِسمْ نّسْ ؤُ مَانْ إِسمْ ن مِّيسْ؟
\m شكْ ثسّْنذْ ث، مَا وَارْ إِدْجِي أَمنِّي؟ \x ◘ \xo 30:‏4 \xt أَيُوبْ 38‏:‏4؛ إِزهد. 104‏:‏3؛ إِشا. 40‏:‏12\x*
\b
\m 
\v 5 كُوڒْ أَوَاڒْ ن أَربِّي إِتّْوَاصفَّا،
\m أَقَا نتَّا ذ أَذُورِّي
\m إِ يِينِّي غَارسْ د-يَاركّْوَاڒنْ. \x ◘ \xo 30:‏5 \xt إِزهد. 12‏:‏7؛ 18‏:‏31؛ 19‏:‏9؛ 119‏:‏140، 2 تِيم. 2‏:‏16\x*
\m 
\v 6 وَارْ أَرنِّي غَارْ وَاوَاڒنْ نّسْ،
\m حِيمَا نتَّا وَارْ شكْ إِتّْوبّخْ،
\m ؤُ أَذْ ثْبَانذْ-د شكْ ذ بُو-إِخَارِّيقنْ. \x ◘ \xo 30:‏6 \xt أَعَوذ. 4‏:‏2؛ 12‏:‏32؛ أَسَا. 22‏:‏18\x*
\b
\m 
\v 7 نشّْ تَّارغْ أَشْ ثْنَاينْ ن ثْمسْڒَايِينْ،
\m وَارْ خَافِي ثنْثْ قطّعْ قْبڒْ إِ غَا مّْثغْ.
\m 
\v 8 سِيڭّْوجْ خَافِي مِينْ إِبضْڒنْ
\m ذ ڒْهَارْذْ إِخَارِّيقنْ،
\m وَارْ ذ أَيِي تِّيشْ زّڒْضْ ؤُڒَا ذ وَاڭْڒَا،
\m شَارّڭْ أَيِي ثَاسْغَارْثْ إِنُو
\m إِ ذ أَيِي د-إِتَّاسنْ زڭْ وغْرُومْ،
\m 
\v 9 مَاڒَا لَّا، خْمِي غَا جِّيوْنغْ،
\m أَذْ ثَاغْ أَذْ شكْ نْكَارغْ،
\m أَذْ إِنِيغْ ’وِي إِدْجَانْ سِيذِي؟‘،
\m نِيغْ خنِّي، مَاڒَا زڒْضغْ، أَذْ أَشَارغْ،
\m ؤُ أَذْ ڭّغْ ڒْعِيبْ ذڭْ يِيسمْ ن أَربِّي إِنُو.
\m 
\v 10 وَارْ شقّفْ ذڭْ إِجّْ ن ؤُمْسخَّارْ
\m غَارْ سِيذِيسْ نّسْ،
\m حِيمَا نتَّا وَارْ شكْ إِنعّڒْ
\m ؤُ \add خنِّي\add* شكْ أَذْ ذَايكْ يِيڒِي ڒْعِيبْ.
\b
\m 
\v 11 \add أَقَا ذِينْ\add* إِجّْ ن جِّيڒْ إِ إِنعّْڒنْ بَابَاسْ،
\m ؤُ وَارْ إِتّْبَاركْ يمَّاسْ،
\m 
\v 12 إِجّْ ن جِّيڒْ \add إِ يدْجَانْ\add* ذ أَمزْذَاڭْ
\m ذِي ثِيطَّاوِينْ نّسْ،
\m \add مَاشَا\add* وَارْ إِتّْوَاسِيرْذْ زِي ڒخْمجْ نّسْ،
\m 
\v 13 إِجّْ ن جِّيڒْ س ڒْخزْرَاثْ إِنفْخنْ،
\m س وَابْڒِيونْ نّسْ إِڭعّْذنْ، \x ◘ \xo 30:‏13 \xt أَوڒن. 6‏:‏17\x*
\m 
\v 14 إِجّْ ن جِّيڒْ س ثغْمَاسْ أَمْ ڒسْيُوفْ
\m ذ ثغْمَاسْ ن ثغْمَارْثْ أَمْ ڒمْوَاسْ،
\m حِيمَا أَذْ صَارْضنْ
\m إِنِّي إِتّْوَاحْصَارنْ زِي ثمُّورْثْ
\m ذ إِمزْڒَاضْ زڭْ إِوْذَانْ. \x ◘ \xo 30:‏14 \xt أَوڒن. 12‏:‏18\x*
\b
\m 
\v 15 ثَادَّا غَارسْ ثْنَاينْ ن يسِّيسْ:
\m ’أوْشْ!‘ ’أوْشْ!‘
\m أَقَا ذِينْ ثْڒَاثَا نِّيعمَّارْصْ أَذْ جِّيوْننْ.
\m أَربْعَاعمَّارْصْ أَذْ إِنِينْ: ”شْفَا!“
\m 
\v 16 ڒَاخَارْثْ ذ ڒمْڒَاوثْ إِبلّْعنْ،
\m ثَامُّورْثْ إِ وَارْ إِجِّيوْننْعمَّارْصْ
\m زڭْ وَامَانْ،
\m ؤُڒَا ذ ثْمسِّي
\m وَارْ قَّارنْثْعمَّارْصْ: ”شْفَا!“
\b
\m 
\v 17 ثِيطّْ إِ إِسّْثهْزَانْ زِي بَابَاسْ،
\m ؤُ ثسّحْقَارْ طَّاعثْ إِ يمَّاسْ،
\m أَذْ ت قڒْعنْ إِبَاغْڒِيونْ غَارْ ثغْزَارْثْ،
\m ؤُ إِمژْيَاننْ ن ؤُڭِيذرْ أَذْ ت شّنْ.
\b
\m 
\v 18 ثْڒَاثَا-يَا \add ن ثْمسْڒَايِينْ\add*
\m عْذُونْثْ أَيِي س ڒعْجبْ،
\m أَربْعَا وَارْ ثنْثْ سِّينغْ:
\m 
\v 19 أَبْرِيذْ ن ؤُڭِيذرْ ذڭْ ؤُجنَّا،
\m أَبْرِيذْ ن ؤُفِيغَارْ خْ ثصْضَارْثْ،
\m أَبْرِيذْ ن ؤُغَارَّابُو ذڭْ وُوڒْ ن ڒبْحَارْ،
\m ؤُ أَبْرِيذْ ن ورْيَازْ أَكْ-ذ ثعْزَارشْثْ.
\m 
\v 20 أَمُّو إِ إِتّڭّْ
\m أَبْرِيذْ ن إِشْثْ ن ثمْغَارْثْ إِزنَّانْ:
\m نتَّاثْ ثتّتّْ، ثسِّيرِيذْ أَقمُّومْ نّسْ،
\m ثقَّارْ: ”نشّْ وَارْ ڭِّيغْ وَالُو ذ ڒْغشّْ!“
\b
\m 
\v 21 سَاذُو ثْڒَاثَا \add ن ثْمسْڒَايِينْ-أَ\add*
\m ثنْهزّْ ثمُّورْثْ،
\m سَاذُو أَربْعَا إِ وَارْ ثْزمَّارْ أَذْ ثَارْبُو:
\m 
\v 22 سَاذُو إِجّْ ن ؤُمْسخَّارْ
\m مَاڒَا نتَّا إِذْوڒْ ذْ أَجدْجِيذْ،
\m سَاذُو إِجّْ ن ؤُبُوهَاڒِي
\m مَاڒَا نتَّا إِجِّيونْ أَغْرُومْ،
\m 
\v 23 سَاذُو إِشْثْ ن ثمْغَارْثْ ثتّْوَاسّحْقَارْ
\m مَاڒَا نتَّاثْ ثتّْوَاسّمْڒشْ،
\m ؤُ سَاذُو إِشْثْ ن ثَايَّا
\m مَاڒَا ثطّفْ ڒْوَارْثْ ن لَالَّاسْ.
\b
\m 
\v 24 أَربْعَا-يَا ذ إِمژْيَاننْ قَاعْ خْ ثمُّورْثْ،
\m \add عَاذْ\add* نِيثْنِي ذ إِمِيغِيسنْ قَاعْ:
\m 
\v 25 ثِيكضْفِينْ وَارْ دْجِينْثْ ذ ڒْڭنْسْ إِجهْذنْ،
\m \add مَاشَا عَاذْ\add* نِيثنْثِي سّوْجَاذنْثْ
\m مَاشَّا نْسنْ ذڭْ ؤُنبْذُو. \x ◘ \xo 30:‏25 \xt أَوڒن. 6‏:‏8\x*
\m 
\v 26 إِكَاوْكَاونْ ن ثصْضَارْثْ
\m ذ إِجّْ ن ڒْڭنْسْ نْهْڒَا جّْهذْ،
\m \add مَاشَا\add* نِيثْنِي بنَّانْ
\m ثَازذِّيغْثْ نْسنْ خْ ثصْضَارْثْ.
\m 
\v 27 ثَامُوغْرِي وَارْ غَارسْ بُو أَجدْجِيذْ،
\m \add وَاخَّا أَمنِّي\add* إِفّغْ س ؤُستّفْ مَارَّا.
\m 
\v 28 أَزرْمُومِّي ثْزمَّارذْ
\m أَذْ ث ثطّْفذْ س ثْنَاينْ ن إِفَاسّنْ،
\m \add عَاذْ أَقَا-ث\add* نتَّا ذِي ڒقْصُورْ ن إِجدْجِيذنْ.
\b
\m 
\v 29 ثْڒَاثَا-يَا صُّورُوفنْ س ڒْعزّْ،
\m أَربْعَا ڭُّورنْ س ثشْڒِي ثشْنعْ:
\m 
\v 30 أَيْرَاذْ، بُو-ثغْرُوضْثْ جَارْ ڒْمَارْ،
\m ونِّي وَارْ إِتّْوخِّيرنْ زَّاثْ إِ حذْ،
\m 
\v 31 إِجّْ ن \add ؤُغِيڒَاسْ\add* س ثجْعِينَّاثِينْ نّسْ بيْسنْثْ،
\m نِيغْ إِجّْ ن ؤُمْيَانْ،
\m ؤُ إِجّْ ن ؤُجدْجِيذْ نِّي غَارْ إِدْجَا
\m ؤُڒَاغِي ن ؤُمنْغِي. \x ◘ \xo 30:‏31 \xt أَيُوبْ 39‏:‏19‏-‏28\x*
\b
\m 
\v 32 مَاڒَا شكْ ثڭِّيذْ س ثُوبُّوهڒْيَا
\m ؤُمِي ثسّْڭعّْذذْ إِخفْ نّشْ،
\m نِيغْ ثْخمّمذْ ذِي ثحْرَايْمشْثْ:
\m سَارْسْ \add أَ\add*فُوسْ خْ ؤُقمُّومْ! \x ◘ \xo 30:‏32 \xt أَيُوبْ 21‏:‏5\x*
\m 
\v 33 مَاغَارْ أَسنْذُو ن ؤُغِي إِتَّاوِي-د ثْرُوسِّي،
\m ؤُ أَسنْذُو ن ونْزَارنْ
\m إِتَّاوِي-د إِذَامّنْ،
\m ؤُ أَسنْذُو ن ؤُخيّقْ،
\m إِتَّاوِي-د أَمْشُوبّشْ.
\b
\b
\c 31
\s1 أَوَاڒنْ إِوزْننْ ن يمَّاسْ ن لَامُويِيلْ
\m 
\v 1 \bd أَوَاڒنْ ن لَامُويِيلْ، أَجدْجِيذْ \bdit ن ثقْبِيتْشْ ن\bdit* مَاسَّا،\bd*
\m \bd \bdit إِ زِي ث\bdit* ثْعڒْمذْ يمَّاسْ.\bd*
\b
\m 
\v 2 مِينْ \add ذِينْ\add*، \add أَ\add* مِّي،
\m مِينْ \add ذِينْ\add*، \add أَ\add* مِّي ن وحْسِينْ إِنُو،
\m مِينْ \add إِ غَا ثڭّذْ\add*، \add أَ\add* مِّي ن لْوُوعُوذْ إِنُو؟
\m 
\v 3 وَارْ تِّيشْ ثِيزمَّارْ نّشْ إِ ثمْغَارِينْ،
\m ؤُڒَا إِبْرِيذنْ نّشْ
\m إِ ثِينِّي إِتّْهلَّاكنْ إِجدْجِيذنْ. \x ◘ \xo 31:‏3 \xt أَعَوذ. 17‏:‏17\x*
\m 
\v 4 وَارْ د-ثُوسِي إِ إِجدْجِيذنْ، \add أَ\add* لَامُويِيلْ،
\m وَارْ د-ثُوسِي إِ إِجدْجِيذنْ
\m مَاحنْذْ أَذْ سْونْ بِينُو،
\m ؤُڒَا إِ أَيْثْ ن جّهْذْ
\m مَاحنْذْ أَذْ مژْرنْ ذِي شّْرَابْ.
\m 
\v 5 نِيغْ أَذْ إِسُووْ ؤُ أَذْ إِتُّو لْفَارِيضَا،
\m ؤُ أَذْ إِسّْفَارْغْ ثَانْفُوتْشْ ن مَارَّا إِمْخيّْبنْ.
\m 
\v 6 أوْشْ شّْرَابْ إِ يِينِّي إِ غَا إِتّْوَاهلّْكنْ،
\m ؤُڒَا ذ بِينُو إِ يِينِّي ذ إِمرْزَاڭنْ
\m ذِي ڒعْمَارْ نْسنْ.
\m 
\v 7 أجّْ إِ-ث أَذْ إِسُووْ ؤُ أَذْ إِتُّو زّڒْضْ نّسْ،
\m \add أجّْ إِ-ث\add* وَارْ تّْخَارَّاصْ ذِي ثَامَارَا نّسْ عَاذْ.
\m 
\v 8 أَرْزمْ أَقمُّومْ نّشْ إِ إِزِييْنَانْ،
\m إِ دّعْوثْ ن مَارَّا إِنِّي إِتّْوَاجّنْ.
\m 
\v 9 أَرْزمْ أَقمُّومْ نّشْ،
\m حْكمْ س ڒْحُوكْمْ نِيشَانْ،
\m ؤُشَا أَغْ ثَاسْغَارْثْ إِ ؤُمزْڒُوضْ. \x ◘ \xo 31:‏9 \xt لَاوِي 19‏:‏15؛ أَعَوذ. 1‏:‏16\x*
\b
\s1 أَسمْغَارْ ن ثمْغَارْثْ إِمحْضنْ
\m 
\v 10 \bd أَلِيفْ.\bd* \bd مَانْ ونْ إِ غَا يَافنْ\bd*
\m \bd إِشْثْ ن ثمْغَارْثْ إِمحْضنْ؟\bd*
\m تَّامَانْ نّسْ إِعْذُو مَارَّا ڒْمَارْجَانْ. \x ◘ \xo 31:‏10 \xt أَوڒن. 12‏:‏4\x*
\m 
\v 11 \bd بِيثْ.\bd* خَاسْ إِ إِتّْشَاڒَا وُوڒْ ن ورْيَازْ نّسْ،
\m وَارْ ذ أَسْ إِتّْخصِّي ڒفْضڒْ.
\m 
\v 12 \bd ڭِيملْ.\bd* نتَّاثْ ثتّڭّْ أَسْ مِينْ إِصبْحنْ،
\m وَارْ إِدْجِي ڒْغَارْ،
\m مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّسْ.
\m 
\v 13 \bd ذَالِيثْ.\bd* نتَّاثْ ثَارزُّو ثَاضُوفْثْ ذ ثِيفّسْثْ،
\m ؤُ ثْخدّمْ س إِفَاسّنْ نّسْ إِمحْضنْ.
\m 
\v 14 \bd هِي.\bd* نتَّاثْ ثڭَّا أَمْ ثْغَارُّوبَا ن ؤُسبَّابْ،
\m زِي ڒَاڭّْوَاجْ ثتَّاوِي-د مَاشَّا نّسْ.
\m 
\v 15 \bd وَاوْ.\bd* نتَّاثْ ثتّْنَاكَّارْ
\m ؤُمِي عَاذْ ثدْجَا دْجِيڒثْ،
\m ثتِّيشْ مَاشَّا إِ ثَادَّارْثْ نّسْ،
\m ؤُ ثَاسْغَارْثْ \add نْسنْثْ\add*
\m إِ ثمْسخَّارِينْ نّشْ ثِيمژْيَانِينْ.
\m 
\v 16 \bd زَايِينْ.\bd* نتَّاثْ ثتّْخَارَّاصْ ذڭْ إِيَّارْ
\m ؤُ ثتّطّفْ إِ-ث،
\m زِي ڒْغِيدْجثْ ن إِفَاسّنْ نّسْ
\m ثژُّو ثِيزَايَارِينْ ذڭْ ؤُمَارْجعْ.
\m 
\v 17 \bd خِيثْ.\bd* نتَّاثْ ثْبكّسْ
\m ثِيجْعِينَّاثِينْ نّسْ س جّهْذْ،
\m ؤُ ثسّمْحَاضْ إِغَادْجنْ نّسْ.
\m 
\v 18 \bd ثِيث.\bd* نتَّاثْ ثْحكَّارْ
\m إِ ڒفْضڒْ ن ثْسبَّابْثْ نّسْ،
\m ڒفْنَارْ نّسْ وَارْ إِخسِّي ذِي دْجِيڒثْ.
\m 
\v 19 \bd يُوذْ.\bd* نتَّاثْ ثسّْوِيژّضْ إِفَاسّنْ نّسْ
\m غَارْ ثْرُوكَّا،
\m ؤُ إِفَاسّنْ نّسْ طّْفنْ أَمكُّوكْ ن ؤُخيَّاضْ.
\m 
\v 20 \bd كَافْ.\bd* نتَّاثْ ثَارزّمْ
\m أَفُوسْ نّسْ إِ ؤُمحْذَاجْ،
\m ثسّْوَاژَّاضْ إِفَاسّنْ نّسْ إِ ؤُمزْڒُوضْ.
\m 
\v 21 \bd لَامِيذْ.\bd* نتَّاثْ وَارْ ثتّڭّْوذْ
\m زِي ثَادَّارْثْ نّسْ
\m ذِي سِّيبّثْ ن وذْفڒْ،
\m مَاغَارْ مَارَّا ثَادَّارْثْ نّسْ
\m غَارسْ أَرُّوضْ أَرْجُووَانِي.
\m 
\v 22 \bd مِيمْ.\bd* نتَّاثْ ثڭَّا إِ يِيخفْ نّسْ
\m ثِيسُونْثَاوِينْ ن زْوَاقْ،
\m أَرُّوضْ نّسْ \add س\add* ڒقْطنْ أَزْذَاذْ
\m ذ \add ؤُفِيڒُو\add* أَرْجُووَانِي.
\m 
\v 23 \bd نُونْ.\bd* أَرْيَازْ نّسْ إِتّْوَاسّنْ ذِي ثوُّورَا،
\m خْمِي إِتّْغِيمَا أَكْ-ذ إِمْغَارنْ ن ثمُّورْثْ.
\m 
\v 24 \bd سَامِيخْ.\bd* نتَّاثْ ثتّڭّْ أَرُّوضْ ن ڒقْطنْ
\m ؤُشَا ثزّْنُوزَا \add إِ-ث\add*،
\m نتَّاثْ ثزّْنُوزَا إِبُويَاسْ
\m إِ ؤُسبَّابْ زِي كنْعَانْ.
\m 
\v 25 \bd عَايِينْ.\bd* جّهْذْ ذ ڒْعزّْ ذ أَرُّوضْ نّسْ،
\m نتَّاثْ ثْضحّشْ \add ثسْفَارْنِينْ\add*
\m خْ وَاسّْ إِ د غَا يَاسنْ.
\m 
\v 26 \bd بِي.\bd* نتَّاثْ ثَارزّمْ
\m أَقمُّومْ نّسْ س ثِيغِيثْ،
\m \add أَقَا ذِينْ\add* ثَاغُورِي س ثْمخْسِيوْثْ إِشوَّارنْ
\m خْ يِيڒسْ نّسْ.
\m 
\v 27 \bd ثْسَاذِي.\bd* نتَّاثْ ثْحطَّا
\m خْ مِينْ إِتّمّْسَارَانْ ذِي ثَادَّارْثْ،
\m أَغْرُومْ ن ڒعْڭزْ وَارْ ثتّتّْ.
\m 
\v 28 \bd قُوفْ.\bd* إِحنْجِيرنْ نّسْ تّكَّارنْ،
\m سّمْغَارَانْ ت س ڒفْرَاحثْ،
\m ؤُڒَا ذ أَرْيَازْ نّسْ إِتّْمدّحْ إِ-ت.
\m 
\v 29 \bd رِيخْ.\bd* أَطَّاسْ ن ثْيسِّيثْ
\m ڭِّينْثْ ثِيمڭَّا جهْذنْثْ،
\m \add مَاشَا\add* شمْ ثعْذُوذْ-د ثنْ مَارَّا.
\m 
\v 30 \bd شِينْ.\bd* ڒبْهُوثْ ثْشمّثْ ؤُ أَژْرِي إِتّْغشَّا
\m \add مَاشَا\add* ثَامْغَارْثْ نِّي إِتّڭّْوْذنْ سِيذِي،
\m إِتّْخصَّا أَذْ ت سّمْغَارنْ.
\m 
\v 31 \bd ثَافْ.\bd* وْشمْ أَسْ زِي ڒْغِيدْجثْ ن إِفَاسّنْ نّسْ،
\m جّمْ ثِيمڭَّا نّسْ
\m أَذْ أَسْ صبّْحنْثْ غَارْ ثوُّورَا. 
