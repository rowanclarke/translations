\id ECC - Gamo Full Bible final version
\h Eranchchata Maxaafa
\toc1 Eranchchata Maxaafa
\toc2 Eranchchata Maxaafa
\toc3 Era
\mt1 Eranchchata Maxaafa
\imt1 Giddo Qofa
\ip Eranchchata maxaafan xaafettiday biitta bolla asa duussi qaanth gidoyssafekka bollara daro metoy, qaxa pirdaynne daaburay kumidayssa erida gishshas «Asa de7oy coo hada» giidi qachchida issi era asa qofata. He eranchchazas asa de7o hanota kaalettiza Xoossa ooso xuuray erettontta ixxides. Gido attiin asi ba diza layth ubbaan, baas dandayettida keena minni ooththana malanne Xoossi asaas immida imotatan asi ufayettana mala bessizayssa zorees. Eranchchaza qofatappe dariza baggay misaton qofaninne hidota qanxxon kumidayta; gido attiin\f + \fr 1:0 \ft Misenna giza qaalaza issi issi baggan xuse gishin hara baggan xussa woykko palqqe geetettees.\f* hayssi ha maxaafay Geeshsha Maxaafa garsan beetoy geeshsha maxaafan xaphida ammano haray attoshin hayssa hara dumma qofaynne sidhey izan kumida maxaafaakka gaththi issi bolla oykkana gakkanaas izi aaho gididayssa erisees. Ha maxaafazi asa de7o herega mala bessiza gishshas daro asay hayssa ha maxaafazappe bana minththeththiza miish demmides. Hessaththoka hayta ha qofata bessizay, ha issi geeshsha maxaafay de7os gita birsheth immiza Xoossaan ufays ooththana mala zorizayssa asay erides.
\iot Ha Maxaafay Oykkida Kumeththa Qofa
\io1 Duussa birsheth \ior 1:1—2:26\ior*
\io1 Ubbaas wodey dees \ior 3:1-8\ior*
\io1 De7oy ubba wode lo7o gidontta gishshas akeekan duus \ior 3:9—6:12\ior*
\io1 De7oso kaaleththiza oge \ior 7:1—8:17\ior*
\io1 Sinththafe aazi hananaakko erizay deenna \ior 9:1—11:6\ior*
\io1 Xoos bonchchonne izas azazeteth \ior 11:7—12:14\ior*
\c 1
\s1 Ubbayka Hada
\q1 
\v 1 Hayssi Dawite naa
\q2 Yerusalaamen kawotida
\q2 eranchchaza qaala.
\q1 
\v 2 He eranchchay,
\q2 «Ubbaa miishshi hada;
\q2 hadappeka aadhdhida hada;
\q2 ubbaa miishshika hada» gees.
\q1 
\v 3 Alame bolla asa nay
\q2 daaburza daabura ubbaas
\q2 ay wodhey dizee?
\q1 
\v 4 Yeletay aadhdhi bishin
\q2 hara yeletay yees;
\q2 gido attiin biittaya mernaaskka
\q2 minna de7awus.
\q1 
\v 5 Arshey mokkeessinne wullees;
\q2 qasseka ba mokkizaso baanaas eesotees.
\q1 
\v 6 Carkoy dugeha bagga carkees;
\q2 hara wode pudeha bagga
\q2 simmees;
\q2 qasse yuuyi yuuyi aadhdhidi
\q2 ba losida ogen gelees.
\q1 
\v 7 Shaafa haath ubbay
\q2 biidi abban gelees;
\q2 gido attiin abbay mulekka
\q2 kumi erenna;
\q2 shaafa haaththati kase ba yidaso
\q2 simmi beettes.
\q1 
\v 8 Asi haasayanaas
\q2 dandayzaazappe bollara
\q2 yo7oti ubbay saleththizaaza;
\q2 ayfey xeellidi kalli erenna;
\q2 hayththika siyidi,
\q2 «Taas gidides» gi erenna.
\q1 
\v 9 Kase haniday simmi izi hanana;
\q2 qasse ha7i hanishe dizaykka
\q2 kase hanidayssa.
\q2 Hessa gishshas salo gufanththon
\q2 aykkoyka ooraththa
\q2 miishshi deenna.
\q1 
\v 10 Oonikka, «Be7ite!
\q2 Hayssi ooraththa miishsha» giikko
\q2 hessi ooraththa miish gidenna;
\q2 hessi nuni yelettanaappe
\q2 kasekka diza miishsha.
\q1 
\v 11 Beni wode hanida hanota
\q2 zaaridi hassa7issiza
\q2 miishshi deenna;
\q2 sinththafe yaanaytikka
\q2 isttafe kaalli yaanaytan
\q2 qofettettenna.
\s1 Eranchchazi De7o Loseppe Demmida Timirte
\q1 
\v 12 Tani eranchchazi Yerusalaamen
\q2 Isra7eeles kawo gidada de7adis.
\q1 
\v 13 Tani salo gufanththon diza ubbaa
\q2 shaakka eranaassinne
\q2 aadho erateththan
\q2 pilgga xeellanaas
\q2 ta qofaa qachchadis;
\q2 Xoossi asa nayta toossida toohoy
\q2 ay mala deexoo!
\q1 
\v 14 Salo gufanththon hanida hanota
\q2 ubbaa ta be7adis;
\q2 gido attiin ubbayka hada;
\q2 carko oykkana yedeththiza mala.
\q1 
\v 15 Geellattida miishshi
\q2 sitti gaanawu dandayenna;
\q2 qasse baynda miishshi
\q2 qoodettana dandayenna.
\p 
\v 16 Tanikka ta wozinan, «Taappe kase Yerusalaame haarida ubbatappe tani gitanne aadho eranchcha gidadis; tani aadho erateththaninne eran keeha loohadis» ga qoppadis.\x - \xo 1:16 \xt 1Kawo 4:29-31\x*
\v 17 Qasse tani aadho erateth, gooshshateththinne eeyateth shaakka eranaas keeha baaxetadis; gido attiin wurseththan hessika carko oykkanaas yedeththiza mala hada gididayssa eradis.
\q1 
\v 18 Aadho erateththi darshin
\q2 ceecey darees;
\q2 eray dariza wodekka
\q2 metoy darees.
\c 2
\s1 Bana Xalla Siiqoy Hada
\p 
\v 1 Tani ta wozinan, «Ane taas gita ufays immizay aazakko, qasse lo7o miishshi aazakko eranaas koyays» ga qoppadis; gido attiin hessi hada.
\v 2 Qasseka, «Miichchi eeyateththa; ishalossinne ufayssas ay go7ay dizee?» gadis.
\v 3 Hessi wuri haniinkka aadho erateth demmanaas ta wozinan amottada tana woyne ushshan ufayssanaassinne eeyateth oykkanaas baaxetadis; qasse asay sa7a bolla diza qaanththa layththan salo gufanththon diza miish ubbaa bolla ooththidaakko istta go7izaazi aazakko ta erana koyadis.
\p 
\v 4 Hessa gishshas hara issi gita miishshata ooththadis; taas keeththatakka keexxadis; woyne turakka tokkadis.\x - \xo 2:4-8 \xt 1Kawo 10:23-27; 2Taari 9:22-27\x*
\v 5 Dumma dumma atakilteta, dumma dumma ayfe ayfiza miththata tokkadis; yuuyi ufayettizaso giigsadis.
\v 6 He dicciza miththata ushshanaas haath eelissizaso zeera giigsadis.
\v 7 Attumanne macca aylleta shammadis; taas soon yelettida hara aylletikka deettes; taappe kase Yerusalaamen de7ida oonappeka bollara daro mehe, deyshinne dorsa wude haaradis.\x - \xo 2:7 \xt 1Kawo 4:23\x*
\v 8 Tani dumma dumma biittatappe gita asatappenne kawotappe aqota, worqqanne bira taas dagasadis. Qasse addenne macca yeththanchchata shiishshadis; gujjadakka asaa ufayssanaas daro macca nayta ehadis.\x - \xo 2:8 \xt 1Kawo 10:10; 14:22\x*
\p 
\v 9 Hessa gishshas tani taappe kase Yerusalaamen de7ida ooppenne aadhdhida gita as gidadis; ta aadho erateththayka tanara de7ides.\x - \xo 2:9 \xt 1Taari 29:25\x*
\q1 
\v 10 Ta ayfey xeellidayssa diggabeekke;
\q2 ta wozinay amottidayssa
\q2 ubbaa diggabeekke;
\q2 tani ooththida ubbaan
\q2 ta wozinay ufayettides;
\q2 ta daaburaas wodhey hessa.
\q1 
\v 11 Gido attiin hessa ubbaa
\q2 ooththa simmada
\q2 tani akeekiza wode
\q2 tani keeha demmana gaada
\q2 daaburda daabura ubbaa
\q2 ta qoppiza wode ubbayka hada;
\q2 salo gufanththon
\q2 ay wodheykka deenna;
\q2 ubbayka carko oykkanaas
\q2 yedeththiza mala.
\q1 
\v 12 Hessafe guye
\q2 tani aadho erateththi,
\q2 eeyateththinne gooshshateththi
\q2 aazakko pilgga eranaas
\q2 qofa doommadis;
\q2 kawo sohon kawotida
\q2 hara kawoy
\q2 kase oosettidayssafe
\q2 hara ay ooththanee?
\q1 
\v 13 Tumukka poo7oy
\q2 dhumappe lo7iza mala
\q2 aadho erateththika eeyateththafe
\q2 aadhdhizayssa be7adis.
\q1 
\v 14 Era asa ayfey
\q2 izaades hu7e bolla dees;
\q2 eeyay gidikko
\q2 dhuma giddora hemettees;
\q2 gido attiin
\q2 istta nam7aa qaadaykka
\q2 issino gididayssa akeekadis.
\q1 
\v 15 Tani ta wozinan,
\q2 «Eeya gakkiza qaaday
\q2 tanakka gakkana;
\q2 histtiin tani
\q2 aadho eranchcha gidoyssas
\q2 wodhey aazee?» gaada qoppadis.
\q2 Qasse tani ta wozinan,
\q2 «Hayssi ubbayka hada» gadis.
\q1 
\v 16 Aadho eranchchayka eeyaza mala
\q2 mernaas hassa7ettenna;
\q2 sinththafe yaana layththatan
\q2 nam7ayka dogettana;
\q2 eeyay hayqqiza mala
\q2 aadho eranchchasikka
\q2 hayqoy attenna.
\s1 Asa Dafeteththi Hada
\p 
\v 17 Salo gufanththon haniza miishshi ubbay iitiza gishshas ha sa7a duussay tana iitees; hessi ubbayka hada; carko oykkanaas yedeththiza mala.
\v 18 Salo gufanththon tani keeha daabura demmida ubbaa taappe guyen yiza yeletas yeggada biza gishshas tani daabura demmida ubbay tana iitees.
\v 19 Taappe guyera yaanayssi izi aadho eranchcha gidiin woykko eeya gidiin oonee erizay? Izi oona gidikkoka tani keeha daaburdayssanne ta aadho erateththan tani demmida ubbaa bolla goda gidana; hessika hada.
\p 
\v 20 Hessa gishshas salo gufanththon hayssa keena ays daaburadinaa gaada ta wozinan hidota qanxxo doommadis.
\v 21 Gaasoykka asi ba ubbaa aadho erateththan, eraninne hiillan daaburdi demmidaa ubbaa aykkoka daaburontta asas aggi bees; hessika hadanne gita qoho.
\v 22 Hessa gishshas salo gufanththon asi keehi dafettikonne daaburkko izas ay wodhey dizee?
\v 23 Izi ba de7o layththan daaburza daaburay ubbay waayenne meto xalla; omarsika iza guuggey shempo demmenna; hessi ubbayka hada.\x - \xo 2:23 \xt Iyo 5:7; 14:1\x*
\p 
\v 24 Asas muussafenne ushshafe qasse ba ooththida ooson ufayeteththafe hara lo7iza miishshi deenna; hessika Xoossa kusheppe imettizayssa ta beyadis.\x - \xo 2:24 \xt Era 3:13; 5:18; 9:7; Luqa 12:19; 1Qoro 15:32\x*
\v 25 Iza achchafe imettontta aggiko ooni maanaassinne ufayettanaas dandayzee?
\v 26 Xoossi bana ufayssiza asas aadho erateth, erateththinne ufays immees; gido attiin nagaranchchay Xoossa ufayssizaytas yeggi baana mala aqota dagasanaassinne ooththanaas wolqqa immees; hessika hadanne carko oykkanaas yedeththiza mala.\x - \xo 2:26 \xt Iyo 32:8; Leemi 2:6\x*
\c 3
\s1 Ubbaa Miishshaska Wodey Dees
\q1 
\v 1 Ubbaasikka wodey dees;
\q2 saloppe garsa baggara
\q2 oosettizayssas
\q2 ubbaas wodey dees.
\q1 
\v 2 Hessa gishshas yelettanaas
\q2 wodey dees;
\q2 hayqqanaaskka wodey dees.
\q2 tokkanaas wodey dees;
\q2 shoddanaaskka wodey dees.
\q1 
\v 3 Wodhanaas wodey dees;
\q2 ashshanaaskka wodey dees.
\q2 laallanaas wodey dees;
\q2 gimbanaaskka wodey dees.
\q1 
\v 4 Yeekkanaas wodey dees;
\q2 miiccanaaskka wodey dees.
\q2 kayottanaas wodey dees;
\q2 qasse ufayettishe guppanaaskka wodey dees.
\q1 
\v 5 Shuch laallanaas wodey dees;
\q2 shuch shiishshanaaskka wodey dees.
\q2 Idimettanaas wodey dees;
\q2 shaakettanaaskka wodey dees.
\q1 
\v 6 Koyanaas wodey dees;
\q2 agganaaskka wodey dees.
\q2 Shiishshi oykkanaas wodey dees;
\q2 kessi olanaaska wodey dees.
\q1 
\v 7 Daakkanaas wodey dees;
\q2 sikkanaaska wodey dees.
\q2 Co7u gaanaas wodey dees;
\q2 haasayanaaskka wodey dees.
\q1 
\v 8 Dosanaas wodey dees;
\q2 ixxanaaskka wodey dees.
\q2 Olas wodey dees;
\q2 saron daanaaskka wodey dees.
\p 
\v 9 Histtiin oosanchchay ba dafetti daaburdayssafe ay wodhe demmanee?
\v 10 Tani qasse asaa nayti daaburdi ooththana mala Xoossi immida toohoy keehi deexo gididayssa be7adis.
\v 11 Ubbaa miish iza woden woden lo7eththidi ooththides. Xoossi asaa wozinan mernateth woththides; gidikkoka Xoossi ooththidayssa ubbaa koyroppe wurseth gakkanaas asi ubbaa eranaas dandayenna.
\v 12 Hessa gishshas asi ba de7o layththan lo7o ooso ooththizayssafenne ufayssizaaz ooththizaazappe aadhdhiza hara miishshi bayndayssa tani eradis.
\v 13 Qasse asas izas iza daaburaas waaga gidizay miidinne uyidi bana ufayssizayssa; hessika izas Xoossafe imettida imota.
\p 
\v 14 Xoossay ooththidayssi ubbay mernaas de7anayssa ta erays; izi ooththidayssa bolla gujjanaas woykko izappe guuththanaas dandayettenna. Xoossi hessa ooththiday asay iza bonchchana malassa.
\q1 
\v 15 Ha7i dizayssi
\q2 hayssafe kasekka dizayssa;
\q2 sinththafe hananayssi
\q2 benikka dizayssa;
\q2 Xoossi kase aadhdhidayssa
\q2 zaari koyees.
\q1 
\v 16 Qasseka tani salo gufanththon
\q2 hara miish be7adis;
\q2 pirda sohon
\q2 makkallateththi dees;
\q2 suure pirda sohon geney dees.
\q1 
\v 17 Tanikka ta wozinan,
\q2 «Ubbaa yo7ossinne oosos
\q2 wodey diza gishshas
\q2 Xoossi xillozanne wordanchchaza
\q2 pirdas shiishshana»
\q2 gaada qoppadis.
\p 
\v 18 Qasse tani ta wozinan, «Asi mehe mala gididayssa istti erana mala Xoossi paaccees.
\v 19 Asa qaadaykka meheyssa mala; nam7aa qaadaykka issino; issoy hayqqiza mala hankkoyssika hayqqees; nam7aaska issi qommo peenoy dees; hessa gishshas izi meheppe dummatenna; hessika hada.
\v 20 Nam7ayka issi soho beettes; nam7ayka biittafe medhettida gishshas biittan simmeettes.
\v 21 Histtiin asaa shemppoy pude salo kezizayssa, meheta shemppoyka duge biittan gelizayssa oonee erizay?» gaada qoppadis.
\p 
\v 22 Hessa gishshas asi ba ooththida ooson ufayssafe hara aadhdhiza miishshi bayndayssa ta be7adis; hessika asas imettida qaada; izi hayqqidaappe guye oosettida oosota iza zaari ehidi bessanay oonee?
\c 4
\s1 Qoho, Dafeteth, Bizzateth
\q1 
\v 1 Tani qasseka salo gufanththon diza
\q2 qoho ubbaa
\q2 be7adissinne akeekadis;
\q2 qohettidayta afunth be7adis;
\q2 istta minththeththiza
\q2 asikka deenna;
\q2 wolqqay istta qohiza asata
\q2 kushen dees;
\q2 istta minththeththiza
\q2 asikka deenna.
\q1 
\v 2 Hessa gishshas tani,
\q2 «Ha7i shemppora
\q2 paxa dizaytappe
\q2 kase hayqqidayti kiya» gadis.
\q1 
\v 3 Gido attiin ha nam7atappeka bollara
\q2 mulekka yelettonttayta
\q2 qaaday lo7o;
\q2 gaasoykka istti salo gufanththon
\q2 oosettiza qohoza
\q2 mulekka be7ibeettenna.
\q1 
\v 4 Hessaththoka asay
\q2 ba amottidayssa demmanaas
\q2 keehi daaburdi ooththees;
\q2 gido attiin he daaburay
\q2 ba lagge bolla
\q2 qanaateteththan dendon
\q2 gididayssa tani akeekadis.
\q2 Hessika hada;
\q2 carko oykkanaas
\q2 yedeththiza mala.
\q1 
\v 5 Azallay ba kushe idimmi uttees;
\q2 barkka bana wodhees.
\q1 
\v 6 Coo daaburaninne carko kaalon
\q2 nam7u kushe demmanaappe
\q2 woppan beettiza
\q2 issi kuphphay kiyees.
\q1 
\v 7 Qasseka tani salo gufanththon diza
\q2 miishshi hada gididayssa be7adis.
\q1 
\v 8 Yeloy woykko ishay baynda
\q2 bizza asi dees;
\q2 iza dafeteththaas zaway deenna;
\q2 iza ayfey izas diza
\q2 aqota kallibeenna;
\q2 izikka, «Tani hayssa
\q2 oosi daaburazinaa?
\q2 Tani ta hu7e ufayssanayssa
\q2 ays uuzettazinaa?» gides.
\q2 Hessika hadanne tugga de7o.
\q1 
\v 9 Istta oosoy lo7o ayfe immanaas
\q2 dandayza gishshas
\q2 issino gidanaappe
\q2 nam7u gideththi lo7o.
\q1 
\v 10 Qasse nam7aafe
\q2 issoy kundiko issoy denththees;
\q2 gido attiin kundiko denththiza
\q2 laggey bayndaadey
\q2 ay mala qadheththizee!
\q1 
\v 11 Nam7ay issife ichchiko ho7ees;
\q2 gido attiin barkka ichchidaade
\q2 waani ho7ana dandayzee?
\q1 
\v 12 Asi bizza qohana dandayees;
\q2 nam7u gidikko
\q2 izara eqettana dandayeettes;
\q2 Heedzdzan dooqettida wodoroy
\q2 elle duuxxenna.
\p 
\v 13 Zore ekkontta eeyanne cima kawo gidanaappe aadho erateththi diza naateththa manqoy lo7o.
\v 14 Ays giikko izi he hiyeesa gidida sohoppe dendidi woykko qasho keeththafe kezidi ba biittan kawotanaas dandayees.
\v 15 Tani salo gufanththon dizaytinne simerettizayti ubbay kawo araata laattiza yelagaa kaallizayssa be7adis.
\v 16 Iza sinththan qooday baynda derey dees; kawoteththafe izi kichchiza wode izi ooththidayssas oonikka iza galatenna. Hessika hada; carko oykkanaas yedeththiza mala.
\c 5
\s1 Adinas Eesotoppa
\p 
\v 1 Xoossa Keeth gelashe ne toho shiishsha ekka; siyanaas shiiqoy eeyata yarshofe aadhdhees; ays giikko istti bantta oosoy iita gididayssa erettenna.
\q1 
\v 2 Haasayanawu eesotoppa;
\q2 qasse issi miish Xoossas
\q2 immana gaada eeson geppofa;
\q2 ays giikko Xoossi salon dees;
\q2 neni gidikko sa7an daasa;
\q2 hessa gishshas ne haasayana
\q2 qaalay ginara gido.
\q1 
\v 3 Ooso daron agumoy beettiza mala
\q2 haasaya daron
\q2 eeyateththa qaalay qonccees.
\p 
\v 4 Xoossas neni adinida adina gam7ontta gaththa; eeson polontta attiko izi ufayettenna; hessa gishshas neni adinettidayssa ubbaa pola.\x - \xo 5:4 \xt Maza 66:13-14\x*
\v 5 Issi miish Xoossas adinettidi he adinettidayssa gaththontta agganaappe kase adinettontta agoy lo7o.
\v 6 Nena ne doonay nagaran yeggontta mala ne doona shiishsha; qasse Xoossa Keeththa oosanchcha sinth shiiqada, «Ta hayssa qoppontta adinettadis» gooppa. Xoossa hanqeththada ne ooso ays dhayssisay?
\v 7 Daro agumoynne daro haasayay hada; hessa gishshas neni Xoossas yayya.
\s1 Dureteththi Hada
\p 
\v 8 Dere garsan manqoy sugettiin, pirday pacciin, maatay yedhettiin ne be7ikko heytanttan keeha malalettofa. Issi issi halaqaas izappe bollara halaqay dees; qasse ubbatappe bollara hara halaqati deettes.
\v 9 Biittafe beettiza go7ay ubbaassa; kawoykka ba hu7es hessafe go7ettees.
\q1 
\v 10 Bira siiqiza asas
\q2 biray gidi erenna;
\q2 dureteth koyza asi
\q2 duretidikka kalli erenna;
\q2 hessi ubbayka hada.
\q1 
\v 11 Aqotay dari dari bishin
\q2 mizay darees;
\q2 haaridaades ayfen be7oppe
\q2 hara aaza go7ay dizee?
\q1 
\v 12 Ooso ooththiza asi guuth miikko,
\q2 daro miikko saro dhisko
\q2 dhiski aqees;
\q2 gido attiin dure as
\q2 dureteththi dhisko diggees.
\q1 
\v 13 Salo gufanththon keehi ceecesiza
\q2 iita miish ta be7adis;
\q2 hessika iita woden
\q2 bana maaddo giidi
\q2 asi guye yeggi dagasida miishshi
\q2 izaades meto;
\q2 
\v 14 woykko issi gaason
\q2 coo dhayza dureteththa.
\q2 Izi naa yelikkoka
\q2 he yelettidayssas
\q2 laatissiza miishshi deenna.
\q1 
\v 15 Asi ba aayi uloppe kallo
\q2 yelettida mala kallo bees;
\q2 ay keena daaburkkoka
\q2 izi ba daaburdayssafe
\q2 aykkoka ekkibeenna.\x - \xo 5:15 \xt Iyo 1:21; Maza 49:17; 1Xim 6:7\x*
\q1 
\v 16 Hessika keehippe iita;
\q2 asi ba yida mala simmi bees;
\q2 iza daabura ubbay
\q2 carko oykkiza mala
\q2 hada gidizaa gidikko
\q2 izas ay go7ay dizee?
\q1 
\v 17 Izi ba layth ubbaa ceecen, waayen,
\q2 yiilloninne dhuma
\q2 duussan wursees.
\p 
\v 18 Asa qaaday hessa gidida gishshas salo gufanththon Xoossi asi de7ana mala immida qaanththa layththa garsan asi ba daaburda daaburappe muussinne ushshi lo7onne bessizayssa gididayssa ta akeekadis.
\v 19 Xoossay asas dureteththinne aqo immizay ba daaburda waaga demmidi miidinne uyidi ufayettanaassa. Hessi Xoossafe izas imettida imota.
\v 20 Xoossay iza wozinan ubba wode ufays kunththi woththiza gishshas izi ba de7o layththas daro hirgenna.
\c 6
\p 
\v 1 Salo gufanththon hara iita miish tani be7adis; hessika asas keehi deexo.
\v 2 Asi ba wozinan amottida miish demmana mala Xoossi asas aqota, dureteththinne bonchcho immees; gido attiin keeththaaway isttan ufayettana mala kumeththa maata izas immenna; izi daaburi demmidayssan haray ufayettees; hessika hadanne keehi iita miishsha.
\p 
\v 3 Issi asi xeetu nayta gakkanaas yeli cimmidi adussa layth de7anawu dandayees; gido attiin izi ba aqotan ufayettontta aggikonne hayqqidi wogara moogettontta aggiko izappe awucayay kiya.
\v 4 Gaasoykka coo hada yiidi dhuman bees; iza sunththika dhuman kamettides.
\v 5 Izi eronttanne poo7o be7ontta aggikokka he addezappe izas aadho woppay dees.
\v 6 Ufayssi baynda dishin nam7u shii layth de7ikkoka izas aaza go7ay dizee? Wurseththan nam7ayka issi soho baana deettennee?
\q1 
\v 7 Asi daaburdi ooththiza
\q2 ubbay ulossa;
\q2 gido attiin iza amoy
\q2 mulekka kalli erenna.
\q1 
\v 8 Histtiin aadho eranchchay
\q2 eeyappe aazan aadhdhizee?
\q2 Manqoy harata sinththan
\q2 waani simerettanaakko eroy
\q2 iza ay maaddizee?
\q1 
\v 9 Amon toylattanaappe
\q2 ayfen be7oy kiya;
\q2 hessika hadanne carko oykkanaas
\q2 yedeththiza mala
\q1 
\v 10 Ha7i diza ubbaas
\q2 kaseti sunththi
\q2 imetti uttides;
\q2 asi hananaazi eretti uttides;
\q2 asi baappe minnizayssara
\q2 baaxettenna.
\q1 
\v 11 Haasayay darshin
\q2 hada yo7oy darees;
\q2 histtiin hessi as ay go7anee?
\q1 
\v 12 Hadanne eesho mala elle aadhdhiza
\q2 guuththa layththatan
\q2 asas lo7o miishshi hananayssa
\q2 erizay oonee?
\q2 Qasseka izi hayqqidaappe guye
\q2 salo gufanththon haniza miish
\q2 izas yootana dandayzay oonee?
\c 7
\s1 De7o Gishshas Qofa
\p 
\v 1 Lo7o shittofe
\q2 lo7o sunththi aadhdhees;
\q2 yeleta gallassafe
\q2 hayqo gallassi lo7o.\x - \xo 7:1 \xt Leemi 22:1\x*
\q1 
\v 2 Gibira keeth buussafe
\q2 yeeho keeth buussi lo7o;
\q2 gaasoykka hayqoy
\q2 as ubbaas wurseththa;
\q2 shemppora paxa diza
\q2 asi ubbay
\q2 hessa ba wozinan
\q2 woththanaas bessees.
\q1 
\v 3 Miichchafe kayoy kiya;
\q2 gaasoykka kayoy
\q2 sinth kareththikokka
\q2 wozina poo7isees.
\q1 
\v 4 Aadho eranchcha wozinay
\q2 kayo keeththan dees;
\q2 eeyata wozinay gidikko
\q2 ufayssa keeththan dees.
\q1 
\v 5 Eeyati sabbishe yexxiza
\q2 yeth siyanaappe
\q2 aadho eranchchay seeriza
\q2 seera ezgoy lo7o.
\q1 
\v 6 Eeyata miichchi
\q2 oto garsan eexxishe
\q2 dhuuqettiza agunththa mala;
\q2 hessika hada.
\q1 
\v 7 Gene oosoy aadho eranchcha
\q2 eeya kessees;
\q2 maganxoy asas wozina moorees.
\q1 
\v 8 Issi miishshas doomeththafe
\q2 wurseththi kiya;
\q2 qasse otoranchchafe
\q2 dandayanchchay kiya.
\q1 
\v 9 Eeyata hanqoy
\q2 istta ki7o garsan diza gishshas
\q2 neni hanqos eesotoppa.\x - \xo 7:9 \xt Yaaqo 1:19\x*
\q1 
\v 10 Neni, «Ha wodey
\q2 kase aadhdhida wodetappe
\q2 ays lo7idee?» ga oychchofa;
\q2 heytantta mala oyshata oyshoy
\q2 aadho erateth gidenna.
\q1 
\v 11 Aadho erateththi lo7o xinxxo mala;
\q2 iza go7ay
\q2 poo7o be7iza as ubbaassa.
\q1 
\v 12 Miishshi as iitappe
\q2 kammi ashshiza mala
\q2 aadho erateththi ashshees.
\q2 Hessafe bollarakka
\q2 aadho erateththi
\q2 keeththa aawa shemppo naagees.
\q1 
\v 13 Ane Xoossay ooththidayssa
\q2 wozinan woththa!
\q2 Izi bokkasidayssa
\q2 ooni luulisana dandayzee?
\q1 
\v 14 Nees wodey lo7ishin ufayetta;
\q2 gido attiin wodey iitishin
\q2 hayssa wozinan woththa;
\q2 Xoossi issaa ooththida mala
\q2 harakka ooththides;
\q2 hessa gishshas asi
\q2 sinththafe hanana miish
\q2 aykkoka pilggidi
\q2 erana dandayenna.
\q1 
\v 15 Nagaranchchay ba nagaraara
\q2 adussa layth de7ishin,
\q2 xilloy ba xilloteththara
\q2 eeson hayqqishin
\q2 hada gidida ta de7o layththatan
\q2 hayta be7adis.
\q1 
\v 16 Hessa gishshas ne dhayontta mala
\q2 keeha xillo,
\q2 woykko keeha
\q2 aadho eranchcha gidoppa.
\q1 
\v 17 Qasse keeha iita as,
\q2 woykko ubbaa eeya as gidoppa;
\q2 ne ays wodey baynda hayqqay?
\q1 
\v 18 Issaa oykkidi hankkoyssaka
\q2 yeddontta agoy lo7o;
\q2 Xoossas yayyiza asi
\q2 shikkalateth ixxees.
\q1 
\v 19 Aadho erateththi aadho eranchchas
\q2 immiza wolqqay
\q2 issi kataman dere haariza
\q2 tammatappe aadhdhees.
\q1 
\v 20 Nagara ooththontta
\q2 mulera suure oosoninne
\q2 xilloteththan xalla kanththiza asi
\q2 biitta bolla deenna.
\q1 
\v 21 Haasayettiza qaala ubbaa hayth
\q2 yegga siyoppa;
\q2 ne histtontta aggiko
\q2 ne ashkaray nena qanggishin
\q2 ne siyandasa.
\q1 
\v 22 Qasse nenikka ne hu7en
\q2 harata qanggoyssa
\q2 ne wozinay erees.
\q1 
\v 23 Hayssa ubbaa tani
\q2 aadho erateththan
\q2 pilgga xeellada,
\q2 «Tanikka aadho eranchcha
\q2 gidanaas qachchadis» gadis.
\q2 Gido attiin tani
\q2 gida mala hanibeenna.
\q1 
\v 24 Aadho erateththi ay gidikkoka
\q2 keehi ciimmanne haako;
\q2 histtiin ooni gakki
\q2 erana dandayzee?
\q1 
\v 25 Hessa gishshas aadho erateththinne
\q2 yo7oti hanizayssa pilgga eranaas,
\q2 xanna7anaas nagara
\q2 iitateththinne
\q2 eeyateththi gooshshateth
\q2 gididayssa
\q2 akeekanaas ta wozinan
\q2 yuushsha qoppadis.
\q1 
\v 26 Izis wozinay woximade mala,
\q2 izi kusheti agrimooqe malanne
\q2 yarde mala gidida
\q2 hayqoppe iita
\q2 maccas be7adis;
\q2 izippe kessi ekkanay
\q2 Xoossas yayyiza as xalla;
\q2 nagaranchcha as gidikko
\q2 yarden oykkawus.
\q1 
\v 27 Aadho eranchchazi,
\q2 «Tani kaalla pilgga
\q2 xeellada demmida
\q2 hara miishshi
\q2 hayssafe kaallizayssa.
\q2 Yo7oti hanizayssa
\q2 hiillateththan pilggidi
\q2 demmanaas
\q2 issaa issaa bolla gujjo;
\q1 
\v 28 Hessika tani hach gakkanaas
\q2 pilggashe dhaydayssa
\q2 shii attumasappe
\q2 issi suure as demmadis.
\q2 Gido attiin haytantta giddofe
\q2 issi suure maccas demmabeekke.
\q1 
\v 29 Tani hayssa ubbaafe
\q2 issi miish tamaaradis;
\q2 Xoossi as suure
\q2 histti medhdhides;
\q2 gido attiin asi
\q2 daro gitettidaaz giigsides» gides.
\c 8
\q1 
\v 1 Yo7ota birshana dandayza
\q2 aadho eranchcha mala
\q2 asi oonee?
\q2 Yo7ota ubbaa birsheth
\q2 erizay oonee?
\q2 Aadho erateththi
\q2 asa ayfeso poo7isees;
\q2 xirphotida sinththika birshees.
\s1 Kawos Azazeteth
\p 
\v 2 Ne kase Xoossaa sinththan caaqqida gishshas kawos azazetta.
\p 
\v 3 Kawo sinththafe eeson kezoppa; izi ba dosidayssa ooththanaas dandayza gishshas iita oosos zuppetoppa.
\v 4 Ubbaa miish ooththanaas kawos maatay diza gishshas, «Hayssa ays ooththay?» giidi iza oychchanaas dandayzay oonee?
\q1 
\v 5 Izas azazettiza asi
\q2 ubbay qohettenna;
\q2 aadho erateththi diza wozinay
\q2 likke wodenne bessiza ooso oge
\q2 shaakki erees.
\q1 
\v 6 As metoy keehi un7eththikokka
\q2 ubbaa miishshaska
\q2 likke wodeynne
\q2 bessiza ooso ogey dees.
\q1 
\v 7 Sinththafe hananayssa
\q2 erizay deenna;
\q2 hessa gishshas
\q2 sinththafe hananayssa
\q2 yootanaas dandayzay oonee?
\q1 
\v 8 Asi ba shemppo
\q2 naagi ashshanaas dandayenna;
\q2 woykko ba hayqqana
\q2 gallassa bolla
\q2 maatay diza asi deenna;
\q2 ola gallas oonikka ola yeggidi
\q2 guye simmonttayssa mala
\q2 iita oosoykka
\q2 banara meezetidayta yeddenna.
\s1 Iita Asata Hanotanne Kiya Asata Hanota
\q1 
\v 9 Salo gufanththon
\q2 haniza miish ubbaa
\q2 tani pilgga be7adis;
\q2 asi as qohanaas
\q2 daannatiza wodey dees.
\q1 
\v 10 Qasse iitati bonchchon
\q2 moogettishininne
\q2 geeshsha kataman sabettishin,
\q2 Xoossa asati geeshsha kataman
\q2 dogettishin ta be7adis;
\q2 hessi ubbayka hada.
\p 
\v 11 Iita ooththida asa bolla eeson pirdontta aggiko asa wozinay iita ooththana halchchon kumees.
\v 12 Nagaranchchay xeetuto iita miish ooththishin iza layththay aduqqikokka, Xoossa bonchchizaytassinne Xoossa yayyizaytas lo7oy hananayssa ta erays.
\v 13 Gido attiin iitati Xoossas yayyontta gishshas lo7o miishshi isttas hanenna; istta layththi eesho mala elle aadhdhana.
\p 
\v 14 Sa7a bolla oosettiza haray hada miishshi dees; hessika xilloti iitatas bessiza qixaate, iitati xillotas bessiza lo7o miish ekkeettes. Heyti ubbayka hada.
\v 15 Salo gufanththon asas muussafe, ushshafenne ufayeteththafe aadhdhiza hara miishshi baynda gishshas ba de7o layththan ufayeteththi lo7o gadis; hessa gishshas Xoossi salo gufanththon izas immida layththatan izi ba ooson ufayettana.
\p 
\v 16 Tani aadho erateth eranaassinne asi ha sa7a bollan omarsinne gallas dhiskoy baynda daaburza daaburaa eranaas ta wozinan pilggadis.
\v 17 Hessafe guye Xoossi ooththida ubbaa be7adis; salo gufanththon oosettiza miish oonikka erenna; asi keehi dafettidi pilggi xeellikokka iza birsheththaa demmanaas dandayenna. Aadho eranchchay, «Ta erays» giikkoka ubbaa eranaas dandayenna.
\c 9
\s1 Ubbaas Diza Wurseththa Qaada
\p 
\v 1 Hessa gishshas ha ubbaa yo7ota ta wozinan qoppada aadho eranchchatinne xilloti ooththiza oosoy Xoossa kushenna; gido attiin asi sinththafe bana naagizayssi siiqo gidiin woykko ixo gidiin erenna.
\v 2 Xillota woykko nagaranchchata gidiin, suureta woykko iitata gidiin, geeshshata woykko tunata gidiin, yarsho shiishshizayta woykko yarsho shiishshonttayta gidiin ubbatasikka wurseththa qaaday issino.
\q2 Lo7o asas hanzayssa mala
\q2 nagaranchchaska hanees;
\q2 caaqqizayssas
\q2 hanizayssa malakka
\q2 caaqos babbizaytas hanees.
\p 
\v 3 Salo gufanththon ubbaa bolla gakkiza iitateththi hayssa; ubbaas wurseththa qaaday issino; hessafe bollarakka asa wozinay iitateththan kumidessinne gooyides; wurseththankka hayqqida asan gayttees.
\v 4 Hayqqida gaammofe paxa diza kanay kiya; hessaththoka shemppora paxa dizayta giddon diza asas hidotay dees.
\q1 
\v 5 Shemppora paxa diza asi
\q2 ba hayqqanayssa erees;
\q2 gido attiin hayqqidayti
\q2 aykkoka erettenna;
\q2 istta qofsiza miishshi
\q2 ubbay dogettees;
\q2 istti go7ettana miishshika deenna.
\q1 
\v 6 Istta siiqoy, ixoynne
\q2 qanaatey ubbay
\q2 isttara issife dhaydes.
\q2 Hessa gishshas salo gufanththon
\q2 haniza miish ubbaan
\q2 aykko qaadaykka isttas deenna.
\p 
\v 7 Baada ne kath ufayssan ma; ne woyne ushshaaka ne wozinay ufayettishin uya; ays giikko Xoossi ne ooththida ooson ufayettees.
\v 8 Ubbaa wode ne may7oy booth gido; ne hu7eykka zayten tiyetto.
\v 9 Salo gufanththon Xoossi nees immida guuth gidida ne de7o layththata ubbaan ne siiqiza ne machcheyra ufayssan de7a; ays giikko salo gufanththon ne de7oninne ne daaburda daabura ubbaan hayssi nees qaada.
\v 10 Ne kushey ooththanaas demmidayssa ubbaa ne kumeththa wolqqan ooththa; ays giikko neni baana duufon oosoy, halchchoy, erateththinne aadho erateththi deenna.
\q1 
\v 11 Tani salo gufanththon
\q2 hara miish be7adis;
\q2 woththan xoonoy pilatatas
\q2 olan xoonoy wolqqamatas gidenna;
\q2 kaththi aadho eranchchatas,
\q2 dureteththi kiphatanchchatas,
\q2 sabay eranchchatas gidenna;
\q2 gido attiin ubbatikka wodeynne
\q2 qaaday gaththida mala haneettes.
\q1 
\v 12 Qasseka ba wode eriza asi deenna;
\q2 kafoy yarden geliza mala,
\q2 moley giten oykettiza mala,
\q2 asikka qoppontta dishin yiza
\q2 iita wodetan oykettees.
\s1 Aadho Erateththinne Eeyateth
\p 
\v 13 Hessaththoka tana keehi malalisida hayssa aadho leemiso salo gufanththon be7adis.
\v 14 Hessika issi biittan amarda asati de7iza qeeri katamay dawus; he katamayo olanaas issi wolqqama kawoy worajji dooddides; izi yuushon miixa giigsides.
\v 15 He katamayn aadho eranchcha gidida issi manqo asi dees; izi ba aadho erateththan he katamayo ashshides. Gido attiin he manqozas oonikka qoppibeenna.
\v 16 Hessa gishshas tani, «Aadho erateththi wolqqafe aadhdhees» gadis. Gidikkoka he manqozas diza aadho erateththazi kadhettides; iza qaalaykka siyettibeenna.
\q1 
\v 17 Eeyata ayssiza daanna waasoppe
\q2 aadho eranchchay
\q2 liiqon haasayza
\q2 qaalay seetettees.
\q1 
\v 18 Aadho erateththi
\q2 ola miishshafe aadhdhees;
\q2 gido attiin issi nagaranchchay
\q2 daro lo7o miish dhayssees.
\c 10
\q1 
\v 1 Hayqqida udunxxeti
\q2 shitto zeeqeththeettes;
\q2 hessaththoka guuththa eeyateththi
\q2 aadho erateththinne
\q2 bonchcho kawushshees.
\q1 
\v 2 Aadho eranchcha wozinay
\q2 iza ushach kaaleththees;
\q2 gido attiin eeya wozinay
\q2 hadirs kaaleththees.
\q1 
\v 3 Eeyay oge bishin
\q2 izas akeekay paccees;
\q2 ba eeyateththa oonaska qonccisees.
\q1 
\v 4 Ne goday ne bolla hanqettiko
\q2 ne soho yeddofa;
\q2 gaasoykka dandayay
\q2 gita hanqo
\q2 co7u histtees.
\q1 
\v 5 Salo gufanththon tani be7ida
\q2 iita miishshi dees;
\q2 hessika dere haarizaadefe
\q2 keziza bala.
\q1 
\v 6 Eeyati keehi dhoqqasohon uttiin
\q2 dureti hirki ziqqa sohon uttida.
\q1 
\v 7 Aylleti daannata mala togan bishin
\q2 daannati qasse aylleta mala
\q2 tohon bishin be7adis.
\q1 
\v 8 Olla bookkiza asi he ollan
\q2 izi kundana;
\q2 qasse dirsa laalliza as
\q2 shooshshi dukkana.\x - \xo 10:8 \xt Maza 7:15; Leemi 26:27\x*
\q1 
\v 9 Shuch dhoqallizay
\q2 he shuchchaan deshettees;
\q2 qasse mith qerizay
\q2 he miththaan qohettees.
\q1 
\v 10 Dun7e kaltta leefontta ooththiko
\q2 daro wolqqa wursees;
\q2 gido attiin hiillan ooththiko
\q2 oosoza ayfisees.
\q1 
\v 11 Shooshshi muurennon
\q2 jallanaappe sinththan dukkiko
\q2 muurennizaade aykkoka go7enna.
\q1 
\v 12 Aadho eranchchaa doonappe
\q2 keziza qaalay
\q2 puulan kumidaaza;
\q2 gido attiin eeyay barkka
\q2 ba inxarsan dhayees.
\q1 
\v 13 Koyroppe doommidi
\q2 iza qaalay eeyateththa;
\q2 wurseththankka iita goosh gidees.
\q1 
\v 14 Eeyay haasaya darssees;
\q2 buroppe hananayssa
\q2 erizay deenna;
\q2 hayqqidaades izappe
\q2 guyen hananayssa
\q2 oonee izas yootana dandayzay?
\q1 
\v 15 Eeya oosoy
\q2 ooththizaade daaburssees;
\q2 izi katama
\q2 gaththiza oge erenna.
\q1 
\v 16 Hanne ne kawoy
\q2 yelaga gididaaree!
\q2 Ne daannati wonttara
\q2 gibira giigsiza biittayee
\q2 nees aayye ana!
\q1 
\v 17 Hanne ne kawoy bonchchettida
\q2 zareppe gididaaree!
\q2 maththottanaas
\q2 gidontta minettanaas
\q2 koshshiza wode miza daannati
\q2 diza biittayee!
\q2 Neni anjjettidaaro.
\q1 
\v 18 Addey azalla gidikko
\q2 kaaray yarphattees;
\q2 iza kusheti daaburkko
\q2 keeththi aaththees.
\q1 
\v 19 Gibiray miicisees;
\q2 woyne ushshi as ufayssees;
\q2 miishshi diikko miishshi hanees.
\q1 
\v 20 Qofankka gidiin kawo kadhoppa;
\q2 ne aqiza kifilen dashe
\q2 dure qanggofa;
\q2 qefen piradhdhizaara
\q2 ne gizayssa
\q2 efa gaththana dandayawus.
\c 11
\s1 Aadho Eranchchay Ooththana Bessiza Ooso
\q1 
\v 1 Ne kath haaththan yegga;
\q2 daro gallassatappe guye
\q2 neni zaara demmana.
\q1 
\v 2 Nees diza aqo laappun woykko
\q2 osppun sohon
\q2 shaakereththa woththa;
\q2 ays giikko biitta bolla
\q2 ay iitay yaanaakko neni erakka.
\q1 
\v 3 Shaaray karexxiko
\q2 biittaa bolla iray bukkees.
\q2 Miththi pudeha woykko
\q2 dugeha kundiko
\q2 ba kundidason ichchi attees.
\q1 
\v 4 Carko hanota naagizay zerenna;
\q2 qasse shaara mallizay
\q2 ba kath shiishshenna.
\q1 
\v 5 Carkoy awara bizaakko
\q2 iza oge erakka;
\q2 qasse shemppoy woykko ayanay
\q2 aayi ulon diza medheta giddon
\q2 waani gelizaakko ne erakka.
\q2 Hessaththoka ubbaa
\q2 medhdhida Xoossa ooso
\q2 ne shaakka erana dandayakka.
\q1 
\v 6 Maaladora ne zereth zera;
\q2 omarsika ne kushey
\q2 ooso birshofo;
\q2 gaasoykka hayssi woykko hessi,
\q2 woykko nam7ay lo7anaakko,
\q2 woykko awayssi ayfanaakko
\q2 ne erakka.
\s1 Yelagateththan Nena Medhdhidayssa Qoppa
\q1 
\v 7 Poo7oy lo7o;
\q2 awa ayfe be7oy
\q2 ayfe ufayssees.
\q1 
\v 8 Asi keehi adussa layth
\q2 ha sa7an de7ikko
\q2 he ubbaankka ufayetto.
\q2 Gido attiin dhuma gallassati
\q2 dariza gishshas qoppo;
\q2 buro yaana miishshi
\q2 ubbayka hada.
\q1 
\v 9 Haysso yelagazoo!
\q2 Ne naateteththa
\q2 layththan ufayetta;
\q2 ne naateteththa layththan
\q2 ne wozinan ufayetta;
\q2 ne ayfey xeellida ubbaanne
\q2 ne wozinay amottida ubbaa pola;
\q2 gido attiin ne ooththida ooso
\q2 ubbaa gishshas Xoossi nena
\q2 pirdas shiishshanayssa era.
\q1 
\v 10 Hessa gishshas ne wozinappe
\q2 ceece haassa;
\q2 iita miishshika neeppe digga;
\q2 gaasoykka naateteththinne yelagateththi
\q2 elle aadhdhana.
\c 12
\q1 
\v 1 Meto gallassati yontta dishin
\q2 neni, «Tana ufayssettenna»
\q2 giza wodeti gakkontta dishin
\q2 ne yelagateththa layththan
\q2 nena Medhdhidayssa qoppa.
\q1 
\v 2 Awaynne poo7oy,
\q2 aginaynne xoolinttey
\q2 dhumontta dishin,
\q2 iray bukki simmiin
\q2 shaaray kichchontta dishin
\q2 nena Medhdhidayssa qoppa.
\q1 
\v 3 Keeth naagizayti kokkoriza wode,
\q2 minoti kuunniza wode,
\q2 gaaccizayti qoodan guuth gidida
\q2 gishshas gaachche aggiza wode,
\q2 maskootera xeellizayti
\q2 doljumiza wode,
\q2 
\v 4 dubbushaso efiza ogeti
\q2 gordettiza wode,
\q2 woxay loocetidi
\q2 giireth aggiza wode,
\q2 kafo waasoy as denththiza wode,
\q2 istta yeththika daaburza wode,
\q2 
\v 5 pudunth kessi xooniza wode,
\q2 oge buussi babisiza wode,
\q2 ochcholooney ciiyiza wode,
\q2 booley barkka bana
\q2 goochchiza wode,
\q2 asappe amoy dhayza wode
\q2 asi ba mernaa keeth baana;
\q2 yeekkizaytikka balen yuuyana.
\q1 
\v 6 Bira sansalatay
\q2 duuxxontta dishin,
\q2 worqqa saaney
\q2 meqqontta dishin,
\q2 haaththa otoy pultto achchan
\q2 meqqontta dishin,
\q2 haath ollafe kessiza waagumboy
\q2 meqerettontta dishin,
\q2 
\v 7 biittay duge biittan
\q2 simmontta dishin,
\q2 shemppoy immida Xoossako
\q2 simmontta dishin,
\q2 nena Medhdhida
\q2 Xoossako simma.
\q1 
\v 8 Eranchchazi, «Hada!
\q2 Hadappeka hada!
\q2 Ubbayka hada!» gees.
\s1 Kuushsha Qofa
\p 
\v 9 Eranchchazi ba hu7es aadho eranchcha xalla gidontta asaakka erateth tamaarsides. Daro leemisota pilggi xeellidaappe guyen maaran maaran giigsides.
\v 10 Eranchchazi suure qaala demmanaas pilggides; izi xaafidayssi suurenne tuma.
\p 
\v 11 Aadho eranchcha qaalay cikka mala hoxe; qasse iza tossetikka addafe dhishkettida dhishke mala; heytikka issi heenththanchchafe imettidayta.
\q1 
\v 12 Ta naazoo! Ha ubbaafe bollara
\q2 ay miishshafekka naagetta;
\q2 aykkoka gujjofa;
\q2 daro maxaafata xaafikkoka
\q2 wurseththi deenna;
\q2 xinaate daroy bolla daaburssees.
\q1 
\v 13 Hekko ubbaa miishshi yootettides;
\q2 yo7o ubbaas kuushshi hayssa;
\q2 Xoossas yayya; iza azazo naaga;
\q2 hessika asa naas
\q2 imettida kumeththa ooso.
\q1 
\v 14 Xoossay ooso ubbaa bolla,
\q2 geemmida yo7o ubbaa bolla,
\q2 lo7o gidiin
\q2 iita gidiinkka pirdana.
