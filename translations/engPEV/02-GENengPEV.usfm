\p
\v 23 \w God|strong="H3068"\w* said \w to|strong="H3068"\w* Rebekah,  
\q1 “\w There|strong="H3068"\w* \w are|strong="H1471"\w* 2 babies \w inside|strong="H3068"\w* \w you|strong="H5647"\w*. \w They|strong="H3068"\w* \w will|strong="H3068"\w* grow up \w and|strong="H3068"\w* \w have|strong="H3068"\w* kids, \w and|strong="H3068"\w* \w their|strong="H3068"\w* kids \w will|strong="H3068"\w* \w become|strong="H5647"\w* 2 \w nations|strong="H1471"\w*.  
