\id 1JN  
\h 1 JUAN 
\toc1 √ĎAXAM B…Ö JUN TSA' B…Ö I TS'IJBU JUAN 
\toc2 1 JUAN 
\mt1 √ĎAXAM B…Ö JUN TSA' B…Ö I TS'IJBU JUAN  
\c 1  
\s1 Cuxty Ćlel Ćch jini T'an  
\p
\v 1 Ch Ćncol lojon c ts'ijbube√Īetla cha'an jini am b Ć c' Ćl Ć ti tyejchibal, jini ubibil b Ć lojon c cha'an, jini q'uelel b Ć lojon tic wut, tsa' b Ć lojon c wen q'uele bajche' ti ajni, jini ty Ćl Ćl b Ć lojon tij c' Ćb. Ji√Ī Ćch jini mu' b Ć i tsictisan bajche' an Dios.   
\p
\v 2 Ti tsictiyi i cuxty Ćlel. Ti lojon quil Ć. Ch Ćncol lojon c sub ch Ć b Ć ti lojon j q'uele. Ch Ćncol lojon c sube√Īet cha'an ili cuxty Ćlel mach' Ć yujil jilel, jini am b Ć yic'ot Dios lac Tyat. Ji√Ī Ćch tsa' b Ć p Ćsbentiyon lojon.   
\p
\v 3 Mi lojon c sube√Īetla jini tsa' b Ć lojon quil Ć, tsa' b Ć lojon cubi cha'an mi lac tyem aj√Īel quic'otyetla. Como isujm Ćch mi lac tyem aj√Īel la quic'ot Dios lac Tyat yic'ot i Yalobil. Ji√Ī Ćch Jesucristo.   
\p
\v 4 Jin cha'an mi lojon c ts'ijbube√Īetla ili t'an cha'an √Īoj tijic√Īa mi la' wubin je'el.   
\s1 Dios ji√Ī Ćch i s Ćclel mulawil  
\p
\v 5 Ji√Ī Ćch jini t'an tsa' b Ć lojon c yoque ubi ti' ti' Jesucristo ch Ćncol b Ć c sube√Īetla. Jini mi y Ćl, Dios ji√Ī Ćch i s Ćclel mulawil. Mach'an i sajlic yic'lel.   
\p
\v 6 Mi ti la c Ćl Ć ch Ćncox lac ch'ujbin pero mi ch Ćncol tyo la caj√Īel ti ic't'oj√Īal ch Ćncolonla ti lot che' jini yic'ot ti jini mu' b Ć lac lolon mel tyac.   
\p
\v 7 Pero mi ch Ćncol la caj√Īel ti' s Ćclel Dios che' bajche' mi yaj√Īel Dios, a√Īonla la quic'ot mu' b Ć i ch'ujbi√Īob. Che' jini i ch'ich'el Jesuscristo i Yalobil b Ć Dios mi' lu' poc'be√Īonla loq'uel lac mul.   
\p
\v 8 Mi ti la c Ćl Ć ma'an lac mul ch Ćncol jach c baj√Īel lotin lac b Ć. Mach melel jini lac t'an che' jini.   
\p
\v 9 Pero mi ti lac subu an lac mul, mi' √Īus Ćbe√Īon lac mul Dios como ch'ujbi lac ch'ujbin cha'an junyajlel tyoj bajche' mi' cha'len Dios. Mi' lu' choc loq'uel pejtyel mach' Ć wen ti lac pusic'al.   
\p
\v 10 Mi ti lac lolon al Ć mi ma'an lac mul ch Ćncol jach lac c Ćle' xlot Dios. Ili t'an Dios mach'an ch Ćncol lac ch'ujbin ti √Īoj melel, che' jini.   
\c 2  
\s1 Cristo la cajcotyaya  
\p
\v 1 Calobiletla, mic ts'ijbube√Īetla ili t'an cha'an mach a wotsan la' mul. Pero mi ti cots Ć lac mul anix la cajcotyaya ya' ti' tyojlel Dios lac Tyat. Ji√Ī Ćch Jesucristo jini √Īoj wen b Ć.   
\p
\v 2 Jesucristo ti y Ćc' Ć i b Ć ti sajtyel cha'an i xot'be√Īonla lac mul. Mach cha'anic jach ti lac baj√Īel mul jo√Īonla, pero cha'an ti' mulob pejtyel a√Īo' b Ć ti mulawil.   
\p
\v 3 Mi ch Ćncox lac ch'ujbiben pejtyel i xic'ojel Dios tsa'ix laj c Ć√Ī Ć Jes√ļs, che' jini.   
\p
\v 4 Mi an majch mi y Ćl: Tsa'ix j c Ć√Ī Ć, che'en, mi ma'an mi' jac'ben i xic'ojel Dios, lot jach muc' che' jini. Mach'an melel i t'an.   
\p
\v 5 Pero mi ch Ćncox lac ch'ujbiben i t'an ch Ćncox lac wen p'untyan Dios. Che' jini mux lac √Īa'tyan a√Īonixla ti' tyojlel.   
\p
\v 6 Jini mu' b Ć i y Ćl anix ti' tyojlel Jes√ļs, yom mi yaj√Īel ti tyoj bajche' ti ajni Jes√ļs.   
\s1 Tsiji' b Ć lac xic'ol  
\p
\v 7 Herma√Īujob, mach tsijibic tyo b Ć la' xic'ol ch Ćncol b Ć c ts'ijbube√Īetla, pero ji√Ī Ćch lac xic'ol tsa' b Ć la' wubi c' Ćl Ć ti tyejchibal c' Ćl Ć wale cha'an p'untyaya.   
\p
\v 8 Pero ch Ćncol c cha' ts'ijbube√Īetla tsiji' b Ć la' xic'ol yubil cha'an p'untyaya. Ch Ć' Ćch ti' cha'le p'untyaya Cristo. Ch Ć' Ćch mi la' cha'len p'untyaya je'el. Tsa'ix tsictiyi i s Ćclel Cristo ti jo√Īonla. Ch Ćncolix i √Īumel jini ic't'oj√Īal.   
\p
\v 9 Jini mu' b Ć i y Ćle' ch Ćncox i yaj√Īel ti' s Ćclel, pero mi ts'a' mi yilan i pi' Ćlob ch Ćncol tyo i yaj√Īel ti ic't'oj√Īal.   
\p
\v 10 Jini ch Ćncol b Ć i p'untyan i pi' Ćlob ch Ćncox i yaj√Īel ti' s Ćclel Cristo. Che' jini ma'an ba' mi quejel yotsan i mul.   
\p
\v 11 Pero jini mu' b Ć i ts'a'len i pi' Ćlob an tyo ti ic't'oj√Īal. Ya' tyo ch Ćncol ti x Ćmbal che' jini. Mach'an mi' ch' Ćmben isujm baqui mi quej i majlel. Como jini ic't'oj√Īal che' bajche' mi y Ćq'uen i muts' i wut.   
\p
\v 12 Jatyetla alp'e√Īelob, mic ts'ijbube√Īetla ili t'an como Dios ti' √Īus Ćbeyetla la' mul cha'an ti' xot'beyonla lac mul Jesucristo.   
\p
\v 13 Jatyetla tyaty Ćlet b Ć la, mic ts'ijbube√Īetla ili t'an como tsa'ix la' c Ć√Ī Ć jini am b Ć c' Ćl Ć ti' tyejchibal mulawil. Jatyetla, alobet b Ć la, mic ts'ijbube√Īetla ili t'an como tsa'ix la' ganari i p' Ćty Ćlel xiba. Jatyetla, alp'e√Īelob, mic ts'ijbube√Īetla ili t'an como tsa'ix la' c Ć√Ī Ć Dios lac Tyat.   
\p
\v 14 Jatyetla, taty Ćlet b Ć la, mic ts'ijbube√Īetla ili t'an como tsa'ix la' c Ć√Ī Ć jini am b Ć c' Ćl Ć ti' tyejchibal mulawil. Mic ts'ijbube√Īetla ili t'an alobet b Ć la, como p' Ćty Ćletixla. Ya'an i t'an Dios ti la' pusic'al. Tsa'ix la' ganari i p' Ćty Ćlel jini xiba.   
\p
\v 15 Mach yom mi la' ch Ćc mulan ili mulawil mi jinic an tyac b Ć ti mulawil. Como ili mu' b Ć i mulan ili mulawil ma' mi' p'untyan Dios lac Tyat.   
\p
\v 16 Como mach ya'ic ty Ćlem ti Dios lac Tyat ili i cha'an jach b Ć mulawil. Pero ty Ćlem jach ti mulawil ili i tsuculel lac pusic'al. Jini lolom wen b Ć mi la quilan ti lac wut yic'ot che' mi lac √Īuc isan lac b Ć ti' tyojlel lac pi' Ćlob, i cha'an jach ili mulawil, pejtyelel jini mach b Ć wen.   
\p
\v 17 Ch Ćncox i bej l Ćq'ue' ty Ćlel i yujtibal mulawil yic'ot pejtyelel mach' Ć wen. Pero jini mu' b Ć i mele' bajche' yom Dios mi quej i yaj√Īel ti pejtyel ora.   
\s1 Jini melel b Ć t'an yic'ot jini lot b Ć t'an  
\p
\v 18 P'unty Ćbilet b Ć la calobilob, i yujtibal jachix ili q'uin tyac. Tsa'ix la' wubi tyal juntiquil ajcontra Cristo. Wale anix cab Ćl ajcontra Cristo. Jin cha'an mi lac √Īa'tyan a√Īonixla ti l Ćc' Ćl i jilibal ili q'uin tyac.   
\p
\v 19 W Ć' Ćch ti loq'uiyob w Ć' ba' a√Īonla jini ajcontrajob. Pero mach yoque lac pi' Ćlobic. Tsa'ic yoque ch'ujbiyob bajche' mi lac ch'ujbin, che' jini tsa'ix c Ćyleyob w Ć' ba' a√Īonla. Pero che' √Īac ti loq'uiyob majlel ti tsictiyi che' jini mach'an yoque ch Ćncox i ch'ujbi√Īob bajche' mi lac ch'ujbin.   
\p
\v 20 Pero mach che'ic a√Īetla bajche' jini ajcontrajob. Tsa'ix i y Ćq'uetla Ch'ujul b Ć i Ch'ujlel Cristo. Jin cha'an tsa'ix la' c Ć√Ī Ć jini mero isujm b Ć yi.   
\p
\v 21 Mic ts'ijbube√Īetla ili t'an mach cha'anic mach la' wujil isujm, pero la' wujil Ćch isujm. La' wujil isujm mach ty Ćlemic ti melel b Ć t'an jini lot.   
\p
\v 22 ¬ŅMajchqui jini xlot? Ji√Ī Ćch xlot jini mu' b Ć i lolon ale' mach yajc Ćbilic i cha'an Dios jini Jes√ļs. Jini mach' Ć ba'an mi' ch'ujbin mach jinic jach mi' contrajiben i Yalobil Dios, pero mi' contrajin Dios lac Tyat je'el.   
\p
\v 23 Pejtyel jini mu' b Ć i lolon ale' mach i Yalobil Dios Cristo mach'an mi' ch'ujbin Dios lac Tyat je'el. Jini mu' b Ć i ch'ujbin ti' pusic'al i Yalobil Ćch Dios jini Cristo, ch Ćncol i ch'ujbin Dios lac Tyat je'el.   
\p
\v 24 Jin cha'an yom mi la' ch Ćc ch'ujbin jini tsa' b Ć la' wubi c' Ćl Ć ti √Īaxan. Che' ch Ćncox la' wen ch'ujbin ti la' pusic'al jini tsa' b Ć la' wubi ti √Īaxan, che' jini a√Īetla ti' tyojlel Dios lac Tyat yic'ot i Yalobil.   
\p
\v 25 Jini Jesucristo ti y Ćl Ć cha'an mi quej i y Ćq'ue√Īonla laj cuxty Ćlel mach' Ć yujil jilel.   
\p
\v 26 Tic ts'ijbubeyetla ili t'an como an jini yomo' b Ć i loti√Īetla.   
\p
\v 27 Pero tsa'ix ochi ti jatyetla jini Ch'ujul b Ć i Ch'ujlel tsa' b Ć i y Ćq'uetla Jesucristo. Jin cha'an mach yom yamb Ć la' ajc Ćntisa como jini Ch'ujul b Ć i Ch'ujel mi' c Ćntisa√Īetla ti pejtyel. Como jini mi' sub i sujmlel. Mach ts'in yujil lot. Che' yom mi la' waj√Īel ti Cristo che' bajche' mi' c Ćntisa√Īetla.   
\p
\v 28 Wale calobilob, ch Ćc aj√Īenla ti Cristo cha'an ma'ix lac b Ćq'uen che' mi tsictiyel Cristo. Ma'an mi laj quisnin che' mi cha' ty Ćlel.   
\p
\v 29 La cujila √Īoj wen Jesucristo. √Ďoj wen i melbal. Jin cha'an mi lac √Īa'tyan i yalobilob Ćch Dios jini mu' b Ć i yaj√Īel ti tyoj.   
\c 3  
\s1 1 Yalobilob Dios  
\p
\v 1 Che' jini √Īa'tyanla √Īoj cab Ćl mi' p'untya√Īonla Dios lac Tyat. Mi lac pejc Ćntyel ti yalobilonla Dios. Como melel Ćch i yalobilonla. Jini a√Īo' b Ć ti mulawil mach'an mi' c Ć√Īob Dios lac Tyat. Jin cha'an ma' mi' √Īa'tya√Īob i sujmlel mi i yalobilonla Dios.   
\p
\v 2 P'unty Ćbilet b Ć la herma√Īujob, i yalobilonixla Dios. Pero max tyo √Īoj tsiquil ti ili ora bajche' mi quej la caj√Īel. Pero la cujil Ćch isujm che' mi cha' ty Ćlel Cristo mux lac yoque q'uele'. Che' jini lajal bajche' Cristo mi quejel la caj√Īel.   
\p
\v 3 Pejtyelel ch Ćncol b Ć i pijtyan Jesucristo ch Ćncolix i ch Ćc s Ćc isan i b Ć che' bajche' y Ćlo s Ćc Cristo.   
\p
\v 4 Pero jini i ty Ćlel Ćch b Ć am b Ć ti mulil ch Ćncol i √Īusan i xic'ol ti Dios. Mulil Ćch che' mi lac √Īus Ćben i xic'ojel Dios.   
\p
\v 5 La cujil isujm ti ty Ćli Jesucristo w Ć' ti mulawil cha'an mi' loc's Ćbe√Īon lac mul. La cujil isujm je'el mach sajlic an i mul Jesucristo.   
\p
\v 6 Pejtyelel mu' b Ć i yaj√Īelob ti Cristo mach'anix lajal mi' yotsan i mul che' bajche' i ty Ćlel ti' cha'le wajali. Mi ch Ćncol tyo i ch Ćc otsan i mul mach'an mi' ch'ujbin Cristo che jini.   
\p
\v 7 Calobilob, mach yom lotintiquetla. Mi we√Ī Ćch mi la' cha'len, tyojix a√Īetla che' bajche' tyoj Ćch Jesucristo.   
\p
\v 8 Pero jini i ty Ćlel Ćch b Ć mi' cha'len mulil c' Ćl Ć wajali i cha'a√Ī Ćch xiba como jini xiba c' Ćl Ć ti' tyejchibal mi' cha'len mulil. Jin cha'an ti ty Ćli i Yalobil Dios cha'an mi' jis Ćben i cha'libal xiba.   
\p
\v 9 Mi junticlequic yalobilix b Ć Dios ma'ix bej lajal mi yotsan i mul bajche' ti' cha'le wajali como anix i cuxty Ćlel ti' pusic'al tsa' b Ć aq'uenti ti Dios. Mach ch'ujbi i ch Ćc yaj√Īel ti mulil bajche' i ty Ćlel ti' cha'le wajali como i yalobil Ćch Dios.   
\p
\v 10 Tsiquil Ćch majchqui i yalobil Dios majchqui i yalobil xiba. Mach i cha'anic Dios jini mach' Ć ba'an mi' cha'len ch Ć b Ć tyoj, mach' Ć ba'an mi' p'untyan i pi' Ćlob.   
\s1 La' lac p'untyan lac b Ć  
\p
\v 11 Jini t'an tsa' b Ć la' wubi c' Ćl Ć che' √Īac ti la' wubi i t'an Dios mi y Ćle' yom mi lac p'untyan lac b Ć.   
\p
\v 12 Mach yom mi lac cha'len bajche' ti' cha'le Ca√≠n como i cha'a√Ī Ćch xiba. Ti' ts Ćns Ć i yijts'in jini Ca√≠n. ¬ŅChucoch ti' ts Ćns Ć? Ti' ts Ćns Ć i yijts'in cha'an ti caj wen ti' cha'le pero mach wen ti' cha'le Ca√≠n.   
\p
\v 13 Jin cha'an, herma√Īujob, che' mi' ts'a'le√Īetla jini a√Īo' b Ć ti mulawil mach la' pensalin como i ty Ćlel Ćch.   
\p
\v 14 Che' mi lac p'untyan la querma√Īujob tsiquil colemonixla ti' p' Ćty Ćlel mulil mu' b Ć i y Ćc'onla ti sajtyel. Anix laj cuxty Ćlel. Pero jini mach' Ć ba'an mi' p'untyan i pi' Ćlob c' Ćl Ć sajtyem tyo yubil.   
\p
\v 15 Majchical jach mi' ts'a'len i pi' Ćlob ajts Ćnsaj Ćch che' jini. La cujil Ćch isujm jini ajts Ćnsa mach'an i cuxty Ćlel mach' Ć yujil jilel.   
\p
\v 16 Che' √Īac ti y Ćc' Ć i b Ć ti sajtyel Jesucristo cha'a√Īonla, ti laj c Ć√Ī Ć p'untyaya. Wale yom mi la c Ćc' lac b Ć ti sajtyel cha'an i wenlel la querma√Īujob je'el.   
\p
\v 17 Mi an juntiquil wen an ch Ć b Ć an i cha'an, mi ti yil Ć juntiquil herma√Īu mach' Ć ba'an ch Ć b Ć an i cha'an mi ma' mi' cotyan, ¬Ņch Ćncol ba i p'untyan Dios che' jini? Ma'an mi p'untyan Dios ti' pusic'al.   
\p
\v 18 Calobilob, mach p'untyaya ch Ćncolonla che' ti lac ti' jach mi la c Ćle' pero melel Ćch ch Ćncol lac cha'len p'untyaya che' mi laj cotyan ya√Īo' b Ć.   
\s1 Mach'an lac b Ćq'uen ti' tyojlel Dios  
\p
\v 19 Mi ch Ć' Ćch mi lac cha'len p'untyaya mi quej laj c Ć√Īe' mi a√Īonla ti i sujmlel. Mach'anix mi lac b Ćc'√Īan Dios che' a√Īonla ti' tyojlel.   
\p
\v 20 Pero mi ch Ćncol lac cha' lolon pensalin ti lac pusic'al an tyo lac mul mach wen lac pensal che' jini. Mi ch Ć' Ćch mi lac √Īa'tyan, jinic tyo Dios mach muculic ti' wut. M√°s √Īumen √Īuc Dios. Dios lu' yujil Ćch isujm.   
\p
\v 21 P'unty Ćbilet b Ć la herma√Īujob, mi la cujil Ćch isujm mi mach'an mi baj√Īel al lac pusic'al mi an lac mul mach'anic mi lac b Ćc'√Īan Dios che' a√Īonla ti' tyojlel.   
\p
\v 22 Che' jini che' an ch Ć b Ć mi laj c'ajtin ti oraci√≥n mux i y Ćq'ue√Īonla che' jini. Como ch Ćncox lac ch'ujbiben che' bajche' mi' xic'onla. Ch Ćncox lac mele' mu' b Ć i mulan.   
\p
\v 23 Ji√Ī Ćch i xic'bal: Yom mi lac ch'ujbin Yalobil. Ji√Ī Ćch Jesucristo. Che' je'el yom mi lac p'untyan lac b Ć che' bajche' ti' subeyonla.   
\p
\v 24 Jini mu' b Ć i jac' i xic'bal Dios mi wen aj√Īel ti Dios. Che' je'el Dios mi yaj√Īel ti' pusic'al. La cujil isujm mi yaj√Īel ti jo√Īonla Dios como mi lac √Īa'tyan cha'an ti caj Ch'ujul b Ć i Ch'ujlel tsa' b Ć aq'uentiyonla.   
\c 4  
\s1 C Ćntisa cha'an Ch'ujul b Ć i Ch'ujlel Dios yic'ot i contra Dios  
\p
\v 1 P'unty Ćbilet b Ć la herma√Īujob, mach yom la' ch'ujbin majchical jach mu' b Ć i lolon y Ćle' ty Ćlem ti Ch'ujul b Ć i Ch'ujlel Dios i c Ćntisa. Yom wen xuc'uletla cha'an mi la' √Īa'tyan mi yoque i cha'a√Ī Ćch Ch'ujul b Ć i Ch'ujlel Dios mi mach i cha'anic Dios como w Ć' ti mulawil an cab Ćl xlot b Ć ajc Ćntisa mu' b Ć i lolon ale' ty Ćlem i c Ćntisa ti Dios.   
\p
\v 2 Mic sube√Īetla bajche' mi la' √Īa'tyan mi melel i cha'a√Ī Ćch Ch'ujul b Ć i Ch'ujlel Dios jini ajc Ćntisa. Pejtyel majchical jach mi y Ćle' ti ty Ćli ti yoque i b Ćc'tyal Jesucristo mi che' mi y Ćl, a√Ī Ćch Ch'ujul b Ć i Ch'ujlel Dios yic'ot jini ajc Ćntisa, che' jini.   
\p
\v 3 Pero mi mach che'ic mi y Ćle', mi mach'an mi y Ćle' ti tsictiyi Jes√ļs ti' b Ćc'tyal mach'an i cha'an jini Ch'ujul b Ć i Ch'ujlel Dios jini ajc Ćntisa. Ajcontra Cristoj Ćch che' jini. Tsa'ix la' wubi mux quej i ty Ćlel. Wale anix w Ć' ti mulawil jini ajcontra Cristo.   
\p
\v 4 Jatyetla, calobilob, i cha'a√Īetla Dios. Tsa'ix la' ganari i p' Ćty Ćlel jini ajcontra Cristo como m√°s p' Ćty Ćl Dios am b Ć ti jatyetla bajche' jini xiba am b Ć ti mulawil.   
\p
\v 5 Como jini ajc Ćntisajob i cha'a√Ī Ćch mulawil. Jin cha'an mi' tyajob ti t'an jini am b Ć ti mulawil. Jini a√Īo' b Ć ti mulawil mi' wen √Ī Ćch'ty Ćbe√Īob i t'an.   
\p
\v 6 Jo√Īonla i cha'a√Īonla Dios. Mi mux i √Ī Ćch'ty Ćbe√Īonla i t'an Dios jini ajc Ćntisa che' mi lac suben, tsiquil i cha'an Dios che' jini. Pero mi mach'an mi' √Ī Ćch'ty Ćbe√Īonla, mach i cha'anic Dios. Che' jini mi quej laj c Ćn mi ya' ty Ćlem ti Dios o mi lot jach b Ć ajc Ćntisa.   
\s1 Ya' ty Ćlem p'untyaya ti Dios  
\p
\v 7 P'unty Ćbilet b Ć la herma√Īujob, jin cha'an, yom mi lac p'untyan lac b Ć como ya' ty Ćlem ti Dios pejtyelel lac p'untyaya. Pejtyelel jini mu' b Ć i p'untyan i pi' Ćl i yalobil Ćch Dios. C Ć√Ī Ćlix i cha'an Dios.   
\p
\v 8 Majchical jach mach' Ć ba'an mi' p'untyan i pi' Ćl mach i c Ć√Ī Ć Dios che' jini. Como ya' ty Ćlem p'untyaya ti Dios.   
\p
\v 9 Dios ti' wen p Ćs'eyonla bajche' mi' p'untya√Īonla che' √Īac ti' choco ty Ćlel cojach b Ć i Yalobil w Ć' ti mulawil cha'an mi lac tyaj laj cuxty Ćlel ti' Yalobil.   
\p
\v 10 Jini yoque p'untyaya ji√Ī Ćch che' √Īac Dios ti' p'unty Ćyonla. Max tyo yoque p'untyayajic che' √Īac ti lac p'unty Ć Dios jo√Īonla. Dios ti' choco ty Ćlel cojach b Ć i Yalobil cha'an i sajtyel cha'an i xot'be√Īonla lac mul.   
\p
\v 11 P'unty Ćbilet b Ć la herma√Īujob, che' bajche' ti' p'unty Ćyonla Dios ch Ć' Ćch yom mi lac p'untyan lac b Ć je'el.   
\p
\v 12 Ma'an majch ti yil Ć Dios pero che' mi lac p'untyan lac b Ć w Ć' Ćch an la quic'ot Dios che' jini. Mi lac cha'len p'untyaya che' bajche' yom.   
\p
\v 13 La cujil Ćch isujm a√Īonla ti Dios. Dios an ti jo√Īonla como ti y Ćq'ueyonla Ch'ujul b Ć i Ch'ujlel.   
\p
\v 14 Ti lojon quil Ćbe i Yalobil. Ch Ćncol c sube√Īet lojon Dios lac Tyat ti' choco ty Ćlel cha'an mi' cotya√Īob pejtyelel a√Īo' b Ć ti mulawil.   
\p
\v 15 Majchical jach mu' b Ć i ch'ujbin, mu' b Ć i y Ćle' i Yalobil Ćch Dios jini Jes√ļs, mi yaj√Īel ti Dios. Dios mi yaj√Īel ti jini quixtya√Īu.   
\p
\v 16 Tsa'ix lac ch'ujbi ya' ty Ćlem p'untyaya ti Dios. Che' mic p'untyan lac b Ć a√Īonixla ti Dios. Mi la caj√Īel ti Dios. Dios mi yaj√Īel ti jo√Īonla.   
\p
\v 17 Che' a√Īonla ti Dios mi lac cha'len p'untyaya che' bajche' yom. Che' jini, ma'ix quisintic mi la cubin che' mi laj c'otyel ya' ti' tyojel Dios ti' q'uinil melojel como mi lac cha'len p'untyaya che' w Ć' a√Īonla ti mulawil che' bajche' mi' cha'len p'untyaya Jesucristo.   
\p
\v 18 Che' an majch mi' p'untya√Īonla ma'ix mi lac b Ćc'√Īan che' jini. Mi lu' lajmel pejtyel lac b Ćq'uen cha'an ch Ćncol i p'untya√Īonla. Mi an tyo lac b Ćq'uen ji√Ī Ćch cha'an ch Ćncol tyo lac b Ćc'√Īan lac xot' lac mul. Mi ch Ćncolon tyo la ti b Ćq'uen max tyo mi lac yoque cha'len p'untyaya.   
\p
\v 19 Mi lac p'untyan Dios cha'an √Īaxan ti' p'unty Ćyonla.   
\p
\v 20 Mi an majch mi y Ćl: Ch Ćncol c p'untyan Dios, che'en, pero mi ch Ćncol tyo i ts'a'len i pi' Ćl, lot jach muc'. Como mi ma'an mi' p'untyan i pi' Ćl che' mero ya'an ti' t'ejl jinic tyo Dios mach ch'ujbi i p'untyan como mach'an mi yilan ti' wut.   
\p
\v 21 Dios ti y Ćc'onla ili xic'ol cha'an jini mu' b Ć i p'untyan Dios yom i p'untyan i pi' Ćlob je'el.   
\c 5  
\s1 Bajche' mi lac jotben i p' Ćty Ćlel jini mach' Ć wen am b Ć ti mulawil  
\p
\v 1 Yalobil Ćch Dios majchical jach mu' b Ć i ch'ujbin Jes√ļs yajc Ćbil b Ć i cha'an Dios. Jini mu' b Ć i p'unty Ćben i tyat mux i p'unty Ćbe√Īob i yalobilob je'el.   
\p
\v 2 Como la cujil isujm ch Ćncol lac p'untya√Īob pejtyel i yalobilo' b Ć Dios mi ch Ćncol lac p'untyan Dios mi mux lac jac' lac xic'ol ti Dios.   
\p
\v 3 Mi ch Ćncol lac p'untyan Dios mux lac ch'ujbin lac xic'ol ti Dios che' jini. La cujil mach'an wocol ti ch'ujbintyel.   
\p
\v 4 Pejtyelel jini yalobilob Dios mi' ganarin i p' Ćty Ćlel mach' Ć wen am b Ć ti mulawil. Che' tsa'ix lac ch'ujbi Dios mi la c Ćq'uentyel lac p' Ćty Ćlel cha'an mi lac ganarin i p' Ćty Ćlel mach' Ć wen.   
\p
\v 5 Jini muq'uix b Ć i ch'ujbin i Yalobil Ćch Dios jini Cristo, mi' ganarin i p' Ćty Ćlel mach' Ć wen ti mulawil.   
\s1 T'an mu' b Ć tsictisan cha'an Yalobil Ćch Dios jini Jes√ļs  
\p
\v 6 Jesucristo tsajni w Ć' ti mulawil. Ti tsictiyi Jesucristoj Ćch cha'an ti ja' che' √Īac ti' ch' Ćm Ć ja', cha'an ti' ch'ich'el che' √Īac ti beque i ch'ich'el. Mach ti ja'ic jach pero ti ja' yic'ot ti' ch'ich'el ti tsictiyi mi Jesucristoj Ćch. Ch Ć' Ćch jini Ch'ujul b Ć i Ch'ujlel Dios mi y Ćle' je'el. Como y Ćlo i sujmlel mi' sube'.   
\p
\v 7 Uxchajb t'an ti panchan mu' b Ć p Ćse' mi Jesucristo. Ji√Ī Ćch i t'an Dios lac Tyat, yic'ot je'el Jesucristo mu' b Ć i pejc Ćntyel ti T'an yic'ot je'el Ch'ujul b Ć i Ch'ujlel. Uxchajp i p' Ćty Ćlel pero juntiquil jach Dios.   
\p
\v 8 Uxchajp ti mulawil mu' b Ć i p Ćs i sujmlel mi Jesucristoj Ćch. Ji√Ī Ćch i cha'an Ch'ujul b Ć i Ch'ujlel, jini ja'i, jini i ch'ich'el. Lajal Ćch mi loq'uel i sujmlel ti uxchajplel.   
\p
\v 9 Ch Ćncol lac ch'ujbibe√Īob i t'an quixtya√Īu w Ć'w Ć'i pero m√°s p' Ćty Ćl i t'an Dios cha'an lac ch'ujbin. Dios mi' sube√Īonla ti' t'an cha'an i Yalobil Ćch Dios jini Cristo.   
\p
\v 10 Jini mu' b Ć i ch'ujbin Yalobil Dios mi' √Īa'tyan i sujmlel ti' pusic'al. Jini mach' Ć ba'an mi' ch'ujbin ch Ćncol i cuye' ti xlot Dios como mach'an mi' ch'ujbin tsa' b Ć y Ćl Ć Dios cha'an Yalobil Ćch Dios jini Jes√ļs.   
\p
\v 11 Ji√Ī Ćch tsa' b Ć ajli ji√Ī Ćch iliyi: Tsa'ix i y Ćq'ueyonla Dios laj cuxty Ćlel mach' Ć yujil jilel. Ya' ty Ćlem ti' Yalobil Dios ili laj cuxty Ćlel.   
\p
\v 12 Che' an Yalobil Dios ti lac pusic'al an laj cuxty Ćlel mach' Ć yujil jilel. Jini mach' Ć ba'an i Yalobil Dios ti' pusic'al mach'an i cuxty Ćlel mach' Ć yujil jilel.   
\s1 Cojix b Ć t'an tyac  
\p
\v 13 Mic ts'ijbube√Īetla ili t'an, jatyetla, mu' b Ć la' ch'ujbin i Yalobil Dios, cha'an mi la' √Īa'tyan anix la' cuxty Ćlel mach' Ć yujil jilel.   
\p
\v 14 Che' mi laj c'ajtiben cha'an Dios mi' mel bajche' yom, la cujil Ćch isujm mi' √Ī Ćch'ty Ćbe√Īonla lac t'an che' an ch Ć b Ć mi laj c'ajtiben.   
\p
\v 15 Che' √Īa'ty Ćbilix lac cha'an ch Ćncol i √Ī Ćch'ty Ćbe√Īonla lac oraci√≥n, la cujil isujm mux i y Ćq'ue√Īonla mu' b Ć laj c'ajtiben.   
\p
\v 16 Mi ti la quil Ć juntiquil herma√Īu ch Ćncox b Ć i tyaj i mul mi mach jinic mu' b Ć i y Ćc' ti sajtyel, yom mi laj c'ajtiben Dios ti oraci√≥n cha'an mi' √Īus Ćben i mul cha'an mi y Ćq'uen i cuxty Ćlel. An mulil mu' b Ć i y Ćc'onla ti sajtyel. Jin cha'an mi ti la quila juntiquil herma√Īu ch Ćncox i tyaj i mul mu' b Ć y Ćc' ti sajtyel mach'an mic xiq'uetla la' tyaje' ti oraci√≥n.   
\p
\v 17 Pejtyel mach' Ć wen mi' cha'len lu' mulil Ćch. Pero an mulil mach' Ć ba'an mi y Ćc' ti sajtyel.   
\p
\v 18 La cujil Ćch isujm mi lac Tyaty Ćch Dios mach'an mi lac ch Ćc otsan lac mul che' bajche' i ty Ćlel ti lac cha'le wajali como yalobilonla Dios. Mux i c Ć√Ī Ćtya√Īonla. Jini xiba mach ch'ujbi i ty Ćc'la√Īonla.   
\p
\v 19 La cujil Ćch isujm i yalobilonla Dios. Pero pejtyel mach b Ć i yalobilic Dios a√Īob ti' p' Ćty Ćlel xiba.   
\p
\v 20 Pero la cujil isujm tsajni Yalobil Dios cha'an mi y Ćq'ue√Īonla lac √Īa'ty Ćbal cha'an mi laj c Ć√Īe' jini yoque Isujm b Ć. A√Īonla ti yoque jini i sujmlel b Ć Dios. Ji√Ī Ćch Yalobil Dios jini jesucristo. Ji√Ī Ćch jini y Ćlo i sujmlel b Ć Dios. Ji√Ī Ćch laj cuxty Ćlel mach' Ć yujil jilel.   
\p
\v 21 P'unty Ćbilet b Ć la calobilob, xuc'uletla yom cha'an mach'an mi la' ch'ujutisan jini mu' b Ć i lolon q'uelob ti' diosob. Am√©n.   