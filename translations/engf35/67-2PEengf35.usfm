\v 11 \w whereas|strong="G3699"\w* angels, \w though|strong="G2532"\w* \w being|strong="G1510"\w* \w greater|strong="G3173"\w* \w in|strong="G2596"\w* \w might|strong="G2479"\w* \w and|strong="G2532"\w* \w power|strong="G1411"\w*,\f + \fr 2:11 \ft Greater than unregenerate human beings (presumably not than those seated in Christ—Ephesians 1:20-21, 2:6).\f* \w do|strong="G2532"\w* \w not|strong="G3756"\w* \w bring|strong="G5342"\w* \w a|strong="G2532"\w* reviling \w accusation|strong="G2920"\w* \w against|strong="G2596"\w* \w them|strong="G2532"\w* \w before|strong="G3844"\w* \w the|strong="G2532"\w* \w Lord|strong="G2962"\w*.\f + \fr 2:11 \ft Compare Jude 9.\f*  
