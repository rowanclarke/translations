\id PSA - Kanasi NT [soq] -Papua New Guinea 1996 (DBL 2014) 
\h Sam 
\toc1 Sam 
\toc2 Sam 
\mt1 Sam  
\is1 Waeuwa uawa  
\ip Mapoido apana daitada uara sasa ita raupari buka ema bedewe girumamoiena. Israel apanawa sasa ita raupari ema mampe wadaposintoie. Sasa ita raupari intawa daitada mape winei. Isiwa God sauwa euda osouwo iedia baiwa wadaposisaie ita auwasaie. Isiwa me saumompe oniamompa baiwa ita do kadiu insadabuamompa iririwa. Tane sasa isiwa bedewe mo warereu baiwa rauparintoie God iririsaia mo emalawoau nanaumopie aimopi. Tane isiwa bedewe buka ema girumalena apanawa poka etedia momoduwa ita do nuapareparewa umanawa girumalen. Ita do Iesu gagaloleidie aia isiwa sasa ita raupari ema bedewe wineia do wamodie, tane ekelesia ualena walamawe, God apanawa do epe wadaposintoie.  
\iot Sam sonabala  
\io1 Sam 1; 23; 27; 34; 51; 67; 90; 95.1-11; 100; 103; 110; 119.9-16; 121 ita 139  
\ie  
\c 1  
\s1 Nuaeu ulaipaida mampe  
\q1
\v 1 Nuaeu debama me mampe mida mai  
\q2 kadi dewalala do warorontoipona ba aiau eteipe ruawaleipona;  
\q1 ba kadi dewalala ita do mo mida God wasiwa waia,  
\q2 bedeuwoleipe do deantoipona,   
\q1
\v 2 tane me Iawe God anaanawa nuawadawadasadie,  
\q2 tadina ita walama God aiawa wisialeidie insaisaleidie wandia.   
\q1
\v 3 Apana sa ia maneu tampe inintoie,  
\q2 ita ipau walamau osowe naumoidewantoia rua  
\q1 ita do asiu mai rorontoipe nonosintoipona  
\q2 tane dima uduudu mo dewasaia ipa ipuipua segaleide.\x + \xo 1.3 \xt Ierima 17.8\x*   
\q1
\v 4 Tane apana kadi dewalala mampo mai epe segaleipona!  
\q1 Mo ina tonapa rua lanunu wisedie suaubamode.   
\q1
\v 5 Sa baiwa mo mai Iawe God kotuwa saiepue inantopu,  
\q2 ita me apanawaida do mai deantopu, dia.   
\b  
\q1
\v 6 Iawe God dewa dodomana dewasaia apanawa os ewamodie saumode,  
\q2 tane kadi dewalala bo intawa asiasi antoi.   
\c 23  
\s1 Iawe God sipsip onionia apanawa euda  
\d Dawid sasawa  
\b  
\q1
\v 1 Iawe God me ipa ne onioniana apanawa wande sipsip onionia apanawa euda rua. \fig |alt="1/2 page" src="bk00004c.tif" size="span" ref="23.1" \fig*  
\q2 Sa baiwa ne mai dima abolawantipona, dia.   
\q1
\v 2 Me banlanedio bola euda bedewe antedine,  
\q2 sape esa obasa aleidiawo wanwan euda  
\q3 wainedine bubuadewantedina.\x + \xo 23.2 \xt Gagalo 7.17\x*   
\q1
\v 3 Ne sape wainedine leidino  
\q2 nuana wasileidio muka wadedina.  
\q1 Me dewawa dodomana  
\q2 baiwa ne banlanedio a dewadewantedina.   
\q1
\v 4 Tane ne dewa da badowaida kadineampo boida baiwantepine  
\q2 mai bo ba kadiwa sawanteapa,  
\q1 ipawa Iawe God e ipa ne do  
\q2 mai eneipona, dia;  
\q1 e koinaa mampe bodaneie onianeiana.   
\b  
\q1
\v 5 E nisoneiano emalawoana apanawa ewaneio  
\q2 oda nanawa debama imasaanawo iedina.  
\q1 E ne ituposineaana manawonteapa  
\q2 baiwa mena wadee uanawo memeana;  
\q2 do nana nadine pokanedio wainedina.   
\q1
\v 6 Ita e ne nuawadawadanene dewa euda mainawo dewasana,  
\q2 ita ne e nata duawo wankasantata.   
\c 27  
\s1 Wadaposi raupariwa  
\d Dawid sasawa  
\b  
\q1
\v 1 Iawe God ipa ne sapana, ita inawana,  
\q2 sa baiwa ne mai santeapa.  
\q1 Me ne onianede ando mai kadi donsapa  
\q2 sa baiwa ne mai inguguranteapa.   
\q1
\v 2 Emalawoa apanawa kadi daitada dewalala  
\q2 ne bodaneapu kadineapua baiwa,  
\q2 tane mo muba bagorantopue omepu.   
\q1
\v 3 Mo uara awodeantopue ne onana enapu,  
\q2 tane ne mai mo sauntapa.  
\q1 Mo ne bodaneampo,  
\q2 ne sumanaina Iawe God mampe itupa.   
\b  
\q1
\v 4 Ne Iawe God iririsapo dewa dea os ne baina dewasapi:  
\q2 walama uduudu ne inawana bedewe me duwa bedewe wainepina,  
\q2 ne me euwaa ewapaa menanede  
\q2 ita me duwa kakaiwa bedewe mampe rauparintapa.   
\q1
\v 5 Ne poka mainawo wisempo  
\q2 me bola euda bedewe wereganepi,  
\q2 me duwa bedewe ne onianepi,  
\q2 me nau osowe ionoido itunepi.   
\q1
\v 6 Ne emalawoana apanawa uara enapue pananeapu,  
\q2 tane ne mo onaponteapa.  
\q1 Ne Iawe God duwa bedewe  
\q2 me mampe pue pulontape supa,  
\q2 ne nuaeu mampe ka wape sino epape  
\q2 ita sasantapa Iawe God mampe.   
\b  
\q1
\v 7 Iawe God, manawo rauparintepino etanea,  
\q2 nuaparenaite saunea!   
\q1
\v 8 E ne dianee waanase, “Wine mainawo gagaloitaa.”  
\q2 Sa baiwa tauma ne manawo iedina.   
\q1
\v 9 Ne ipa e nolaa dewalala,  
\q2 mai nuaa kadilepio adia ne mainawo itua,  
\q2 e mai weregaitaa!  
\q1 E ne inaneana,  
\q2 e walama uduudu ne sauneie,  
\q2 sa baiwa tauma mai nebaida enea!  
\q1 Mai eneaiaa!   
\q1
\v 10 Naita ne mamana ita inana  
\q2 adiu ne mainawo itupu,  
\q2 tane Iawe God walama uduudu  
\q2 wadanempe mampeneampa.   
\q1
\v 11 Iawe God, ne emalawoana apanawa  
\q2 wadaneapua baiwantoi,  
\q2 sa baiwa waeuwaneawo waroroepa,  
\q2 e inta dodomana asiasi banlanea.   
\q1
\v 12 Emalawoa apanawa sa ne lagana wai,  
\q2 mo ne kadineapua menamode,  
\q2 sa baiwa e mai mo emowo ne wadaneapu!   
\b  
\q1
\v 13 Ne sumanaintedina Iawe God euda dewasapio ewapa,  
\q2 tawo ema osowe inawaa wainepino me dewasapi.   
\q1
\v 14 Sa baiwa Iawe God sumanaiwaitana,  
\q2 insaisala itune badowa enonuna,  
\q2 Iawe God sumanaiwaitana.   
\c 34  
\s1 Iawe God euda dewasadia sasawa  
\d Walama dea Dawid Abimelek danawe dewalena ewaewa abo oopa rua, sa baiwa me wanaubeno alen. Dewa ema aupe Iawe God Dawid sausana insene ita sasa ema girumalen.  
\b  
\q1
\v 1 Ne walama uduudu Iawe God wadaposisapina  
\q2 ita me asowa wapina.   
\q1
\v 2 Ne me ebowa debamasapina,  
\q2 e apana ituaisilala gagalo ema etane nuaeuitana.   
\q1
\v 3 Iawe God wadaposisata,  
\q2 no awodea me ebowa debamasata!   
\b  
\q1
\v 4 Ne Iawe God mampe rauparinteno ita me ne sipoanen,  
\q2 apana sa ne sauntedina mampo me inanen.   
\q1
\v 5 Apana mida sau baiwa Iawe God mampentoia,  
\q2 mo nuaeuntoi,  
\q2 me walama uduudu mo saumompa.   
\q1
\v 6 Ne poka uara mainawo wimoieno  
\q2 tane Iawe God mampe rauparinteno etanen,  
\q2 ne poka etedino me inanen.   
\q1
\v 7 Apana mida Iawe God wiwirawantoia,  
\q2 me enseliwa mo oniamode,  
\q2 me mo gonaamodio do waimoi.   
\b  
\q1
\v 8 Sa baiwa e Iawe God mampeitane  
\q2 ita me euwaa dauwaida etana.  
\q1 Naita e me onialepia baiwa mampe aitana,  
\q2 e nuaeuitana.\x + \xo 34.8 \xt 1 Pita 2.3\x*   
\q1
\v 9 E sumanailala Iawe God ebowa debamasana.  
\q1 Apana mida me ebowa debamasaia  
\q2 mai dima abolawantopu.   
\q1
\v 10 Walama isiwa pue laion omana tomodio lai,  
\q2 tane mida Iawe God sumanaiwantoia nitu uduudu mampe rua os waimoi  
\q2 mai nitu da abolawantopu, dia.   
\b  
\q1
\v 11 Ne obaina, mainawo winlene gagalona etana.  
\q2 Ne waeuwalepo Iawe God wiwirawaitonuna.   
\q1
\v 12 E wanwan daumawa ita do  
\q2 wanwan euda waina menalempa,   
\q1
\v 13 mai apana wakadisamonuna  
\q2 do mai laga wanuna.   
\q1
\v 14 Kadiwa dewasailana ene tane euda dewasana,  
\q2 ita apana saumono wanwan euda obasa wampu.   
\b  
\q1
\v 15 Iawe God emawa apana dewa dodomana dewasaia osouwo winede,  
\q2 mo sau baiwa me mampe iririntoio etamode.\x + \xo 34.15 \xt 1 Pita 3.10-12\x*   
\q1
\v 16 Tane kadi dewasaia apanawa mampo  
\q2 me namba nambesade,  
\q2 mo bontopuo ando mai mida mo umanau wapi, dia.   
\b  
\q1
\v 17 Iawe God apanawa me mampe sau baiwa iririntompo etamopi,  
\q2 me mo poka uduudu bedewe saumopie inamopi.   
\q1
\v 18 Apana mida insaisau omaomala  
\q2 Iawe God ipa mo do,  
\q2 ita mo mida nuabolantoie insaisau omedia  
\q2 me saumopie insaisau badosapi.   
\b  
\q1
\v 19 Dewa dodomana dewasaia apanawa  
\q2 poka saiwa uara donsai,  
\q2 tane Iawe God walama uduudu mo saumodie inamode.   
\q1
\v 20 Me emawa mo osouwo,  
\q2 sa baiwa mai neaipu da tewapi.\x + \xo 34.20 \xt Ion 19.36\x*   
\b  
\q1
\v 21 Tane kadi dewalala, mo muba kadiwa dewasaia kadimopi,  
\q2 ita apana mida dodomana dewasaio emalawoamoia  
\q2 matangelawa mo wadapu.   
\q1
\v 22 Tane Iawe God me nolawa dewalala inamode.  
\q2 Apana mida Iawe God saumopie inamopia baiwa  
\q2 me mampe antoia mai matangela donsapu, dia.   
\c 51  
\s1 Kadi insadabua raupariwa  
\d Warere Dawid apana ebowa Uria manainapa ebowa Besiba nata ninanton. God perowetawa Natan wisene aia badowa mampe Dawid diaidasan. Me aia ema etene dewawa kadiwa insene ita nuawa pareleno sasa ema girumalen.  
\b  
\q1
\v 1 O God, e nuawadawadaa mai diala,  
\q2 sa baiwa nuaparenaite saunea.  
\q1 E walama uduudu apana nuapareuitiana,  
\q2 sa baiwa kadiwana inseadabuasaa.   
\q1
\v 2 Kadina mitaaubea,  
\q2 ita mitanee eunea.   
\b  
\q1
\v 3 Ne ateina dewa kadiwa dewasana,  
\q2 nainanepe winedio walama uduudu insedina.   
\q1
\v 4 Ne kadiwa e manawo dewasana, dea e os manawo;  
\q2 e emaawo ne eueuwana ipa kadiwa.  
\q1 Sa baiwa e ne diane waanase, “E kadiwa dewasaana!”  
\q2 E ulaipa waiana.  
\q1 E ne matangelanea, sa e dewa dodomana dewasaiana.\x + \xo 51.4 \xt Rom 3.4\x*   
\q1
\v 5 Ne muntena walamawe odene ita tauma ne ipa kadi dewalala,  
\q2 Ne inana bupa bedewe kadi do wainedine.   
\q1
\v 6 Tane e meneedia ne nuana bedewe ulaipa nopesapi  
\q2 sa baiwa nuana bedewe insaisa eubu teamoa.   
\b  
\q1
\v 7 Ne kadiwana mitaaubee ita eunea  
\q2 ita sapaida wapa.   
\q1
\v 8 Ne kadina inseiadabuasaiana umanawa wawo etape  
\q2 ita ulaipa mampe nuaeuntapa;  
\q1 e ne dewaneano neaina nonosinton  
\q2 tane osowe dewaneawo nuaeutapa.   
\q1
\v 9 Ne dewana kadiwa mai ewamona  
\q2 wade nambeidomoa.   
\b  
\q1
\v 10 O God, ne nuana mitee sanaasaa  
\q2 ita ulaipa mampe ne waroroepa.   
\q1
\v 11 Ne mai waaubaneawo eepe anteapa!  
\q2 E Aleua Kakaiwa bedenawo mai wadaaubea!   
\q1
\v 12 Dewaneawo osowe nuaeunteapa, bauta inaneano nuaeutena rua,  
\q2 Ne dewaneawo e aiaa ruawantepina dewawa menaneampa.   
\b  
\q1
\v 13 Ita kadi dewalala mampo e intaa ne waeuwamopina  
\q2 ita mo leuntopue e manawo wimpu.   
\q1
\v 14 O God, e ne inanea,  
\q2 saunee inawana oniea  
\q2 ita ne nuaeu mampe e dewaa dodomana sasawa wapa.   
\q1
\v 15 O Tatana, sauneawo moana wadapaaubepe wadaposiepa.   
\q1
\v 16 Ne pue supe pulonteapa e manawo,  
\q2 tane e mai meneeipona.  
\q2 E mai pulo inainamba sa iririwa waipona, dia.   
\q1
\v 17 Ne neba ituaisinteape iririepo kadina inseadabuasaa,  
\q2 e pulo inainamba ema meneede.  
\q1 O God, ne kadiwana dauwa etane nuaparentene  
\q2 manawo rauparintedina mai leunea.   
\q1
\v 18 O God, bola Saion nuaparewaitee sausaa;  
\q2 me gonaawa tewana osowe wadawo enepi.   
\q1
\v 19 Ita apana amonau nuau dodomana mampe e manawo dewasampo nuaa eulempa;  
\q2 mo pulou daitada sumpe e nuaa eusampa ita kau mona e oltaa osowe pulontompa.   
\c 67  
\s1 Auwa sasawa  
\q1
\v 1 O God, nuaparembaite, sau euda osombo itua.  
\q2 E nana mainimbosae oiwawaitaa.   
\q1
\v 2 Ita apana uduudu tawo osowe waimoia e dewaa atentopu,  
\q2 uwa daitada apanawa atentopu e mo inamoa rua.   
\b  
\q1
\v 3 Uwa daitada apanawa God wadaposiepu,  
\q2 apana uduudu e wadaposiepu!   
\q1
\v 4 Apana uduudu tawo osowe nuaeu mampe sasantopu  
\q2 ipawa e dewaa dodomana mampe  
\q1 uwa daitada apanawa oniamoiana,  
\q2 e apana uduudu tawo osowe oniamona.   
\q1
\v 5 Uwa daitada apanawa God wadaposiepu  
\q2 apana uduudu e wadaposiepu!   
\b  
\q1
\v 6 Ita tawo osowe nana mauralepi  
\q2 ita no Godimba sau debama no osombo itupi.   
\q1
\v 7 Ulaipa, God sau euda no osombosapi  
\q2 ita bola daitada bede wanwanlala me wadaposisana.   
\c 90  
\s1 Apana ando diantopu tane Iawe God ipa wanwankasalala  
\d God nolawa dewalala Moses sasa ema girumalen.  
\b  
\q1
\v 1 Tatamba, e ipa walama uduudu no wanwanimba bolawa.   
\q1
\v 2 E ipa wanwankasalalaida  
\q2 muriwa wadi dewamoana  
\q2 do muriwa tawo uduudu dewamoana.   
\b  
\q1
\v 3 E apana diamoe waanase,  
\q2 “E leuitane popokau wanaitana!”  
\q1 Mo popokau mampe seganton,  
\q2 tane e leumoano popokau wananton.   
\q1
\v 4 E emaawo ena 1,000 ipa walama dea rua,\x + \xo 90.4 \xt 2 Pita 3.8\x*  
\q2 ena sa ipa tadina omowa kampaida rua.   
\q1
\v 5 E apana inawau tauwadea os wadeiaubeiana  
\q2 auen ewawo nuaa tauwadea awawalepia rua.  
\q2 Mo ipa beran tadinaida kelontoia rua.   
\q1
\v 6 Tadinaida beran kelowa ewaewau eubu,  
\q2 tane rawiwa mo rorontoie nonosintoi.   
\b  
\q1
\v 7 E nuakadia debama no kadinede  
\q2 e nuaa no mainimbo kadileidia walamawe e saaidantitana.   
\q1
\v 8 No kadimba uduudu e eweiana,  
\q2 no weregasaitana, tane e sabamo eweiana.   
\q1
\v 9 No wainitano e nuaa kadileide;  
\q2 apana nonaupa itumpaiompa rua  
\q2 e no wanwanimba tauwadea os kampasaana.   
\q1
\v 10 No wantaa enawa ipa 70,  
\q2 tane apana isiwa mukantopua wampuo enau 80 wadepi;  
\q1 no wainite sai uara donsaitana,  
\q2 mai wainipono daumaleipona ita bontitana.   
\b  
\q1
\v 11 Mai mida e nuakadia pokawaaida atenleipona,  
\q2 naita e nuakadia no atendewantepono,  
\q2 e saaidantepona.   
\q1
\v 12 No wanwanimba walamawa kampaida winedia waeuwanewo atentate,  
\q2 ita insadewasa bedewe wainenta.   
\b  
\q1
\v 13 Iawe God, insaisaa leusae nuaparembaitaa!  
\q2 Mai kaino nuaa kadilempa no mainimbo!   
\q1
\v 14 Tadinaida uduudu euwanena  
\q2 e nuawadawadaa no baimba ipa winakasalala,  
\q1 ita no walama uduudu nuaeu mampe  
\q2 sasantonte wainenta.   
\q1
\v 15 E sai debama ena uara bedewe nenaana,  
\q2 tane tauma deawaa dewasae  
\q1 walama dauma bedewe nuaeu nenona!  
\q2 Poka eteitana wadaaubea,  
\q2 ita wanwan euda ena uara bedewe wanta.   
\q1
\v 16 No ipa e nolaa dewalala,  
\q2 e dewaa pokawaa euwanea,  
\q1 no obainimba euwamoa e ipa,  
\q2 mukamukaua ita debamawaida wainiana.   
\q1
\v 17 Tatamba e ipa no Godimba,  
\q2 sau euda osombo itua,  
\q1 no nolamba dewasawo eulepie ipuipua segalepi,  
\q2 oa, e no nolamba dewasawo eulepie ipuipua segalepi.   
\c 95  
\s1 Wadapos sasawa  
\q1
\v 1 Winleno sasantate Iawe God wadaposisata  
\q2 no nuaeu mampe me wadaposisata,  
\q2 me ipa no onioniamba ita saumba.   
\q1
\v 2 No me mampe winte auwasata  
\q2 no sasantate me wadaposisata.   
\b  
\q1
\v 3 Ipawa Iawe God me ipa debamawaida,  
\q2 me ipa warere mukamukaua tawo godiu uduudu aimon.   
\q1
\v 4 Tawo bolawa uduudu ipa me mampea  
\q2 doba nuau iane aidantona  
\q1 ita wadi debama odane aidantona  
\q2 me os witape winei.   
\q1
\v 5 Owa ipa me mebaa, ipawa me dewasan  
\q2 ita do tawo me dewasan.   
\b  
\q1
\v 6 Winleno dunentate Iawe God wadaposisata,  
\q2 Iawe God no dewanena danawe iminimba emmisintata.   
\q1
\v 7 Me ipa no Godimba,  
\q2 no ipa me apanawaida, oniadewasanede,  
\q2 gamowa rua onianedio wainitana.  
\b  
\q1 Ande e me aiawa etanadewaitana!   
\q1
\v 8 Me wadiase, “E mai nosinosila sala makowa bedewe bola Meriba  
\q2 ita Masa bedewe wimone nuau anatene badosaiena ruauitana!\x + \xo 95.8 \xt Ibru 4.7\x* \x + \xo 95.8 \xt Ekisod 17.1-7; Nambas 20.2-13\x*   
\q1
\v 9 Mo ne ginasana emauwoido eweiena,  
\q2 ita mai sumanaintopona,  
\q2 tane rubu osowe ituneiena.\x + \xo 95.9 \xt Ibru 3.15\x*   
\q1
\v 10 Ena 40 bedewe ne mo mampo nuana kadileno wanase,  
\q2 ‘Apana ema nuau nambeido,  
\q2 ne aiana mai ruawantoipona.’   
\q1
\v 11 Sa baiwa nuana kadileno badowa diamone wanase,  
\q2 ‘Ne bubua bolawa mo baibu imaasanawo mai odapu, dia.’”\x + \xo 95.11 \xt Ibru 3.7-11\x* \x + \xo 95.11 \xt Ibru 4.3,5\x*   
\c 100  
\s1 Sasa ema bedewe apana Iawe God auwasai  
\q1
\v 1 Apana uduudu tawo osowe wanwanlala,  
\q2 mukaitane Iawe God mampe sasaitana!   
\q1
\v 2 E winlene nuaeu mampe me wadaposisana,  
\q2 e me danawe nuaeu mampe sasaitana.   
\q1
\v 3 E insene ateitana Iawe ipa God.  
\q2 Me no dewanen; no ipa me apanawa onianedio wainitana,  
\q2 gamo onionia sipsipwa oniamodia rua.   
\b  
\q1
\v 4 E me duwa kakaiwa bedewe aitane me auwasana,  
\q2 e sape aitane me wadaposisana.  
\q2 Me ebowa debamasane ita auwasana,   
\q2
\v 5 ipawa Iawe God me ipa eudida.  
\q1 Me nuawadawadawa apana baibu ipa winakasalala!  
\q2 Me saualena rua, mo mampo euda dewawa mai eipona.   
\c 103  
\s1 Iawe God nuawadawadawa sasawa  
\d Dawid sasawa  
\b  
\q1
\v 1 Ne nuana uduudu mampe Iawe God wadaposisapa.  
\q2 Me ebowa kakaiwa wadaposisapa.   
\q1
\v 2 Ne nuana uduudu mampe Iawe God wadaposisapa,  
\q2 ne walama uduudu me dewa eubu dewamona insamopina.   
\q1
\v 3 Me ne kadiwana uduudu insadabuamode  
\q2 ita kerona uduudu inamode.   
\q1
\v 4 Ne bo baiwantedino me inanen.  
\q2 Me ne nuawadawadanedie  
\q1 ita nuaparenaleidie  
\q2 dewa eubu mainawo dewamode.   
\q1
\v 5 Ne inawaa wainepino me nitu eubu mampe ne sauneampa,  
\q2 ema epe inta ne apana sanaa mukamukaua seganteapa  
\q2 nene inamoia mukamukaua rua.   
\b  
\q1
\v 6 Iawe God apana ewadabualala saumode  
\q2 ipawa me dewawa dodomana;  
\q2 me mo mampo kotuwa dodomana os dewasade.   
\b  
\q1
\v 7 Me dima insedia umanawa Moses euwasan,  
\q2 me dewa pokawaa dewamone mukawa debama  
\q2 sabamosano Israel apanawa eweiena.   
\q1
\v 8 Iawe God nuawa aiaisiwa ita nuaparelala,\x + \xo 103.8 \xt Iems 5.11\x*  
\q2 me mai tauwadea nuawa kadileipona,  
\q2 do me nuawadawadawa mai dialepi.   
\q1
\v 9 Me mai no kadimba kainokaino eweipe enituidaneipona, dia,  
\q2 ita do me nuakadiwa mai winakasaleipona.   
\q1
\v 10 No kadiwa dewasaitana baiwa me matangelaneipona,  
\q2 tane me no kadiwa dewasaitana  
\q2 mai ruaida sipoanepie matangelaidanepi.   
\q1
\v 11 Mo mida me wiwirawantoia mampo  
\q2 me nuawadawadawa ipa debamaia winakasalala;  
\q2 nuawadawada sa ipa iono uba debama winedia rua.   
\q1
\v 12 Omo wisedie nowa daumaia aleidie pamedia rua,  
\q2 epe rua me no kadimba riasadio nambeido aleide.   
\q1
\v 13 Seda mambu obampa mampo  
\q2 nuawa aiaisiwa wandia rua,  
\q1 Iawe God mo mida me sawantoia mampo  
\q2 nuawa aiaisiwa wande,   
\q1
\v 14 ipawa me atemba no popokau mampe dewanen,  
\q2 me atemba no mai apana mukamukaua, dia.   
\q1
\v 15 No ipa beran rua tawo osowe wainitana,  
\q2 no beran kelontoie ita nonosintoia rua,  
\q2 walama kampaida os wainitana.   
\q1
\v 16 Lanunu wiseidie suaubamode,  
\q2 ita tauwadea nonosintoio  
\q2 mai mida ewamoipona.   
\q1
\v 17 Tane Iawe God nuawadawadawa ipa winakasalala,  
\q2 mo mida me sawantoie wiwirawantoia mampo me euda dewasade  
\q2 ita mo bedeuwo mida ando muntompa mampo winakasalepi,   
\q2
\v 18 mo mida saua badowa wadeitue  
\q2 ita anaana sa ruawantoia.   
\b  
\q1
\v 19 Iawe God uba dewasana me kolaiwatawa,  
\q2 osowe waine dewa uduudu oniamode.   
\b  
\q1
\v 20 E ensel mukamukaua uduudu,  
\q2 Iawe God aiawa eteile ruawaitilana,  
\q2 e Iawe God wadaposisana.   
\q1
\v 21 E uboo wanwanlala mukamukaua uduudu  
\q2 e mida me nolawa dewasailana,  
\q2 Iawe God wadaposisana.   
\q1
\v 22 Dewa uduudu me dewamona  
\q2 uboo ita tawo osowe wineia,  
\q1 e uduudu Iawe God wadaposisana.  
\q2 Ne do nuana uduudu mampe Iawe God wadaposisapa.   
\c 110  
\s1 Iawe God ita me warerewa sonabala  
\d Dawid sasawa  
\sp Peroweta gagaloleide apana mampo  
\q1
\v 1 Iawe God ne debamana dieene wanase,  
\sp Iawe God gagaloleide warere mampe  
\q1 “Witana on deneuwe aisite wana  
\q2 ne ideita e emalawoa nanausimope  
\q2 e waa atowe teamopatuapi.”\x + \xo 110.1 \xt Matiu 22.44; Mak 12.36; Luk 20.42,43; Aposel 2.34,35; 1 Korint 15.25; Epesus 1.20-22; Kolosi 3.1; Ibru 1.13; 8.1; 10.12,13\x*   
\sp Peroweta gagaloleide warere mampe  
\q1
\v 2 E Ierusalemwae noe aitono Iawe God dewaepio mukaa debamalepi,  
\q2 ita e emalawoa apanawa onapoite oniamoa.   
\q1
\v 3 E emalawoa apanawa onau enaa walamawe,  
\q2 e apanaaida mo muba nuau wadapuaubepue nomopue bautantopu.  
\q1 E gara kakaiwa mampe benaitaa  
\q2 ita me walama ruawalempe mukaa sanaasampa,  
\q1 kipora esapa sala butasadio tadinaida  
\q2 nitu uduudu sanaantoia rua.   
\sp Peroweta gagaloleide warere mampe  
\q1
\v 4 Iawe God e sauaene wanase,  
\q2 “E ipa pirisi wanwankasalala  
\q1 pirisi Melikisedek rua.”  
\q2 Me saua sa wana mai insaisawa leusapi.\x + \xo 110.4 \xt Ibru 5.6; 6.20; 7.17,21\x*   
\sp Peroweta gagaloleide Iawe God mampe  
\q1
\v 5 O Iawe God, e witaa on deneuwe  
\q2 warere wandia nuawa kadilepio warere uara bomopi.   
\q1
\v 6 Me uwa daitada apanawa matangelamopi ita mo bontoia etepu mo bolau nopesapi.  
\q2 Mo uwau nepa epatuiamopi, tawo uduudu osowe.   
\q1
\v 7 Warere ando into esa alala nampe alempa  
\q2 ita muka wadompa,  
\q2 do me ipa mukawaida segalepi.   
\c 119  
\s1 Iawe God anaanawa  
\q1
\v 9 O Iawe God, apana sanaa ambi wanwan dodomana os wampi?  
\q2 E aiaa ruawalepie wanwan dodomana wampi.   
\q1
\v 10 Ne nuana uduudu mampe rubusadina nolaa dewasapa,  
\q2 sa baiwa mai enewo anaanaa dabuasape epa.   
\q1
\v 11 E aiaa ne nuana bedewe teamono winei,  
\q2 ita dewa kadiwa e manawo mai dewasapa.   
\q1
\v 12 Ne Iawe God wadaposiedina,  
\q2 e anaanaa ne waeuwanea.   
\q1
\v 13 E anaanaa apana wanamoana  
\q2 ne osowesane mukantene wisiantedina.   
\q1
\v 14 Ne e anaanaa ruawantedina mampe nuaeuidantedina,  
\q2 mai maura bedewe nuaeu donsadina rua.   
\q1
\v 15 Ne e anaanaa wisiantepine ewepinadewantepine,  
\q2 ita e waeuwa insepina.   
\q1
\v 16 Ne nuaeuntepina e anaanaa bedewe  
\q2 e aiaa ne mai nuana awawalepi.   
\c 121  
\s1 Iawe God me ipa onioniau apanawa  
\q1
\v 1 Ne sau naepeinta donsapona insene,  
\q2 pisiwane wadi ewamona.   
\q1
\v 2 Ne sau Iawe God mida uba ita tawo dewamona mampee,  
\q2 mainawo wisepio wadapa.   
\q1
\v 3 Sa baiwa me mai eepio omea, dia,  
\q2 walama uduudu eweedio wainiana mai ituleipona,   
\q1
\v 4 Iawe God ipa Israelwa onioniau apanawa,  
\q2 me mai emawa lauleipona ba ituleipona, dia.   
\q1
\v 5 Iawe God ipa e onioniaa apanawa wande,  
\q2 me ipa e tanawoido kadiwa donsano sauepi.   
\q1
\v 6 Walamo omo sapawa e mai kadiepi  
\q2 ita tadino uaboa sapawa mai kadiepi, dia.   
\q1
\v 7 Poka daitada manawo wisempo Iawe God e oniadewasaepi,  
\q2 ita kadiwa mai donsaa, dia.   
\q1
\v 8 E noene aitona ita leuitona bedewe Iawe God emawa ipa e osoawo,  
\q2 me e oniadewasaempa tauma ita ando ita ando bedewe.   
\c 139  
\s1 Iawe God atemba debama ita onionia  
\d Dawid sasawa  
\b  
\q1
\v 1 Iawe God, ne nuana bedewa banuitene ewaana,  
\q2 e ne atenidaneana.   
\q1
\v 2 Ne wainedina ba enedina e atenaida,  
\q2 e nowa dauwoido wainiana tane insaisana uduudu atenaida.   
\q1
\v 3 E ne ewaneiano leidina ba bubuantedina,  
\q2 dewa uduudu dewamodina e atena.   
\q1
\v 4 Muriwa gagalo da moanawo nosepi,  
\q2 e bauta ateitiana muriwa ne wadina.   
\b  
\q1
\v 5 E ipa gonaa rua ne pananeana,  
\q2 e mukaa debama mampe gonaaneana.   
\q1
\v 6 E ne ateineiana atemba ipa debamaia,  
\q2 ne mai atenteapaa rua.   
\b  
\q1
\v 7 Ne naepe anteapo e mai ewanea?  
\q2 Mai bola da wineipona bedewe anteapa,  
\q2 ne naepe antape wampona e sape wainiana.   
\q1
\v 8 Ne odape uboo anteapa, e sape wainiana;  
\q2 ba bolala bolauwo iape anteapa, e sape wainiana.   
\q1
\v 9 Naita ne omo wisediawo anteapa,  
\q2 ba omo pamediawo anteapa,   
\q1
\v 10 e bola sa bedewe ne witana wadae banlanea,  
\q2 ita e mukaa mampe ne gonaanea.   
\b  
\q1
\v 11 Ne dubawa diapo wereganepi,  
\q2 ita sapa diapo iwinlepie dubalepi   
\q1
\v 12 tane dubawa e mai bodeepia rua  
\q2 e manawo dubawa ipa walama sapawa rua.  
\q2 Dubawa ita sapa e manawo ipa deawau os.   
\b  
\q1
\v 13 E ne etena moa daitada dewasaana,  
\q2 ita inana bupa bedewe awodeasae ituneana.   
\q1
\v 14 E dewa pokawaa dewasae dewaneana baiwa wadaposiedina;  
\q2 nitu uduudu e dewamoiana ipa eubuida.  
\q2 Ne nuana uduudu mampe atenten.   
\q1
\v 15 Ne neaina uduudu dewamoana,  
\q2 ita deaitopanee inana bupa bedewe ituneana,  
\q1 sape werego muntedino,  
\q2 e ateiten ne sape wainedine.   
\q1
\v 16 E ne ewaneano muriwa munten.  
\q2 Ne wampaa walamawa  
\q1 umanawa e bukaa bedewe girumaiten  
\q2 ita muriwa walama sa ualen.   
\b  
\q1
\v 17 God e insaisaa uduudu ne mai atentapatuwapia rua,  
\q2 ipawa e insaisaa uarakadinton!   
\q1
\v 18 Ne mai wisiamopa rua  
\q2 ipawa e insaisaa ipa uaraia,  
\q1 nela wisiasiawaia rua!  
\q2 Ne itu bedewe enapawineapa,  
\q2 e ne tainawo onianeiana!   
\b  
\q1
\v 19 God, ne menaidanedia e apana kadi dewasaia bomoa!  
\q2 Ne mainawo wita kadilala tanamowo nambe antopu.   
\q1
\v 20 Mo e wakadisaei,  
\q2 mo e eboa mai wiwirawantoipona.   
\q1
\v 21 Iawe God, mo mida e dabuaeia ne dabuamodina.  
\q2 Mo e aiaa amboitusai.   
\q1
\v 22 Ne nuana kadiidaleide mo mampo;  
\q2 sa baiwa mo ipa ne emalawoana apanawa.   
\q1
\v 23 Ne nuana bedewa banuitee ewaa  
\q2 ita insaisana uduudu ateitaa.   
\q1
\v 24 Naita kadi dewalala intau asiasi antepina waeuwanea,  
\q2 ita e ina winakasala intawa asiasi banlanea.   