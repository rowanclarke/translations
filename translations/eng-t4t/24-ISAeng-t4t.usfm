\q1 \w to|strong="H3117"\w* show \w that|strong="H3117"\w* \w you|strong="H3117"\w* \w were|strong="H3117"\w* sorry \w for|strong="H7121"\w* \w the|strong="H3069"\w* sins \w that|strong="H3117"\w* \w you|strong="H3117"\w* \w had|strong="H6635"\w* committed.   
