\id LEV - Biblica® Open Kurdi Sorani Standard Version
\h لێڤییەکان
\toc1 لێڤییەکان
\toc2 لێڤییەکان
\toc3 لێڤییەکان
\mt1 لێڤییەکان
\mt3 سێیەم پەڕتووکی موسا
\mt4 (ڕێنمایی بۆ پەرستنی خودا و ژیانێکی پیرۆز)
\c 1
\s1 قوربانی سووتاندن
\p 
\v 1 یەزدان موسای بانگکرد و لە چادری چاوپێکەوتن قسەی لەگەڵ کرد و فەرمووی:
\v 2 «لەگەڵ نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”کاتێک یەکێک لە ئێوە قوربانییەکی لە ئاژەڵ بۆ یەزدان پێشکەش کرد، لە گاگەل و لە مێگەل قوربانییەکانتان پێشکەش بکەن.
\p 
\v 3 «”ئەگەر قوربانییەکەی قوربانی سووتاندن\f + \fr 1:3 \ft قوربانی سووتاندن و قوربانی هاوبەشی (بڕوانە بەشی 3) بەردەوام پێشکەش دەکران، هەموو ڕۆژێک، دووپاتکردنەوە و یادکردنەوەی ئامادەبوونی یەزدان بوو لەگەڵ گەلەکەی. بەڵام تایبەتمەندێتی قوربانی سووتاندن لەوەدا بوو، کە هەموو قوربانییەکە پێشکەش بە یەزدان دەکرا.‏\f* لە گاگەل بێت، ئەوا نێری ساغ پێشکەش دەکات و دەیهێنێتە لای دەروازەی چادری چاوپێکەوتن، بۆ ئەوەی مایەی ڕەزامەندی یەزدان بێت،
\v 4 دەستی لەسەر سەری قوربانی سووتاندنەکە دادەنێت و بۆ کەفارەتی\f + \fr 1:4 \ft ئەم قوربانییەی کە تووڕەیی خودا لادەدات.‏\f* لێی وەردەگیرێت.
\v 5 جوانەگاکەش\f + \fr 1:5 \ft لەو کاتەوە گوێرەکەی نێر لە شیر دەبڕدرێتەوە پێ دەڵێن (نۆبەن) یان (جوانەگا).‏\f* لەبەردەم یەزدان سەردەبڕێت، نەوەی هارون کە کاهینەکانن، خوێنەکە دەهێنن و بەسەر هەموو لایەکی ئەو قوربانگایەدا دەیپرژێنن کە لەلای دەروازەکەی چادری چاوپێکەوتنە.
\v 6 قوربانی سووتاندنەکە کەوڵ دەکات و پارچەپارچەی دەکات،
\v 7 نەوەی هارونی کاهین ئاگرێک لەسەر قوربانگاکە دەکەنەوە و دار لەسەر ئاگرەکە ڕێک دەخەن.
\v 8 نەوەی هارونیش کە کاهینەکانن پارچەکانی لەگەڵ سەرەکەی و ئەو پیوەی\f + \fr 1:8 \ft پیوەکەی: واتا بەزەکەی.‏\f* لەسەر دارەکانی سەر ئاگری سەر قوربانگاکەیە ڕێکی دەخەن.
\v 9 هەناو و قاچەکانی بە ئاو دەشۆن و کاهینەکە هەموویان لەسەر قوربانگاکە دەسووتێنێت. قوربانی سووتاندنە، قوربانی بە ئاگرە، ئەو بۆنەی یەزدان پێی خۆشە.\f + \fr 1:9 \ft قوربانی سووتاندن دیارییەکی بەردەوام بوو بۆ یەزدان، کە لە مێژوودا پێی دەگوترا خواردنە بۆ یەزدان، بۆ بۆنکردن و خواردن. هەرچەندە لە ڕاستیدا ئەمەش بە شێوەیەکی بڵاو ناسراو بووە وەک دانانی سیفەتەکانی مرۆڤ بۆ خودا. بڕوانە \xt زەبوورەکان 50‏:7‏-15.‏\xt*\ft ‏\f*
\p 
\v 10 «”ئەگەر قوربانییەکەی لە ماڵات بوو، بەران یان گیسک، قوربانی سووتاندن بوو، ئەوا نێر و ساغ پێشکەش دەکات.
\v 11 لەلای قوربانگاکە ئەوەی بەلای باکوورە لەبەردەم یەزدان سەری دەبڕێت. نەوەی هارونیش کە کاهینەکانن خوێنەکەی بەسەر هەموو لایەکی قوربانگاکەدا دەپرژێنن.
\v 12 پارچەپارچەی دەکات و لەگەڵ سەرەکەی و پیوەکەی، کاهینەکەش لەسەر دارەکانی سەر ئاگری سەر قوربانگاکە ڕێکی دەخات.
\v 13 هەناو و قاچەکانی بە ئاو دەشوات و کاهینەکە هەموویان پێشکەش دەکات و لەسەر قوربانگاکە ئاگریان تێبەردەدات. ئەوەش قوربانی سووتاندنە، قوربانی بە ئاگرە، ئەو بۆنەی یەزدان پێی خۆشە.
\p 
\v 14 «”ئەگەر قوربانییەکەشی بۆ یەزدان لە باڵندە بێت و قوربانی سووتاندن بێت، ئەوا قوربانییەکەی لە کوکوختی یان لە بێچووە کۆتر پێشکەش دەکات.
\v 15 کاهینەکەش بۆ قوربانگاکەی دەهێنێت و سەری دەقرتێنێت، لەسەر قوربانگاکە ئاگر دەکاتەوە، خوێنەکەی لەسەر لێواری قوربانگاکە دەگوشێت.
\v 16 چیکڵدانەکەی\f + \fr 1:16 \ft چیکڵدان: جیقڵدان.‏\f* بەوەش کە لەناویەتی لێیدەکاتەوە و فڕێیدەداتە لای ڕۆژهەڵاتی قوربانگاکە بۆ شوێنی خۆڵەمێشەکە.
\v 17 لەنێوان باڵەکانیەوە کەرتی دەکات، تەواو لێکی ناکاتەوە، ئینجا کاهینەکە لەسەر قوربانگا لەسەر ئەو دارانەی لەسەر ئاگرەکەیە دەیسووتێنێت، قوربانی سووتاندنە، قوربانی بە ئاگرە، ئەو بۆنەی یەزدان پێی خۆشە.
\c 2
\s1 پێشکەشکردنی دانەوێڵە
\p 
\v 1 «”ئەگەر یەکێک پێشکەشکراوی دانەوێڵەی بۆ یەزدان هێنا، دەبێت پێشکەشکراوەکەی لە باشترین ئارد بێت و زەیتی بەسەردا دەکات و بخووری سادەشی دەخاتە سەر و
\v 2 بۆ نەوەی هارون دەیهێنێت کە کاهینەکانن. کاهینەکەش پڕ بە مستی خۆی مستێک لە ئاردەکە و زەیتەکەی لەگەڵ هەموو بخوورەکەی دەبات. کاهینەکە وەک یادەوەری لەسەر قوربانگاکە دەیسووتێنێت، قوربانی بە ئاگرە، ئەو بۆنەی یەزدان پێی خۆشە،
\v 3 ئەوەی لە دانەوێڵەکەش دەمێنێتەوە بۆ هارون و کوڕەکانییەتی، ئەوە بەشی هەرەپیرۆزە لە قوربانی بە ئاگر بۆ یەزدان.
\p 
\v 4 «”ئەگەر پێشکەشکراوێکی دانەوێڵەی بە تەنوور برژاوت هێنا، دەبێت کولێرەی فەتیرەی بە زەیت شێلراو و ناسکە نانی\f + \fr 2:4 \ft ناسکە نان: ناوەشکێنە.‏\f* فەتیرەی بە زەیت چەورکراو بێت.
\v 5 ئەگەر پێشکەشکراوەکەت دانەوێڵەی سەر ساج بێت، دەبێت لە باشترین ئاردی بە زەیت شێلراوی فەتیرە بێت،
\v 6 پارچەپارچەی دەکەیت و زەیتی بەسەردا دەکەیت، ئەوە پێشکەشکراوی دانەوێڵەیە.
\v 7 ئەگەر پێشکەشکراوەکەت دانەوێڵەی ناو تاوە بێت، لە باشترین ئاردی بە زەیت شێلراو دەیکەیت.
\v 8 پێشکەشکراوی دانەوێڵەکەت لەمانە دروستدەکرێت و بۆ یەزدان دەیهێنیت، دەیدەیتە کاهینەکە و ئەویش بۆ لای قوربانگاکەی دەهێنێت.
\v 9 کاهینەکەش لە پێشکەشکراوە دانەوێڵەکە بەشی یادەوەرییەکەی دەبات و لەسەر قوربانگاکە دەیسووتێنێت، قوربانی بە ئاگرە، ئەو بۆنەی یەزدان پێی خۆشە.
\v 10 ئەوەی لە دانەوێڵەکەش دەمێنێتەوە بۆ هارون و کوڕەکانییەتی، ئەوە بەشی هەرەپیرۆزە لە قوربانی بە ئاگر بۆ یەزدان.
\p 
\v 11 «”هەموو ئەو دانەوێڵە پێشکەشکراوانەی بۆ یەزدانی دەبەن، نابێت بە هەویرترش\f + \fr 2:11 \ft هەویرترش: لە جیاتی خومرە بۆ هەوێن بەکارهاتووە.‏\f* بێت، چونکە هیچ شتێکی بە هەویرترش و هیچ هەنگوینێک وەک قوربانی بە ئاگر بۆ یەزدان نابێت بسووتێنن.
\v 12 دەتوانن وەک یەکەمین بەرهەمتان پێشکەش بە یەزدانی بکەن، بەڵام لەسەر قوربانگاکە پێشکەش ناکرێت وەک بۆنی خۆشی.
\v 13 هەموو پێشکەشکراوەکانت لە دانەوێڵە بە خوێ سوێری دەکەیت و با هیچ دانەوێڵەیەکت بەبێ خوێی\f + \fr 2:13 \ft وەک لە کوردەواریش باوە نمەککردنی کەسێک واتای پەیمان بەستنە لەگەڵ ئەو کەسە، خوێیەکەش نیشانەی ئەو پەیمانەیە.‏\f* پەیمانی خودات نەبێت. بۆ هەموو قوربانییەکانت خوێی پێوە دەکەیت.
\p 
\v 14 «”ئەگەر دانەوێڵەت بۆ یەزدان پێشکەش کرد، دانەوێڵەی یەکەمین بەرهەمەکانت پێشکەش دەکەیت، دەبێت گوڵەکەی بێت و برژا بێت، کوتراوە و پاککراوە بێت.
\v 15 زەیتی بەسەردا دەکەیت و بخووری سادەی لەسەر دادەنێیت، ئەوە پێشکەشکراوی دانەوێڵەیە.
\v 16 کاهینیش بەشی یادەوەرییەکەی لە کوتراوەکەی و زەیتەکەی و هەموو بخوورەکەی دەسووتێنێت وەک قوربانی بە ئاگر بۆ یەزدان.
\c 3
\s1 قوربانی بۆ پێکەوە ژیان
\p 
\v 1 «”ئەگەر قوربانییەکەی قوربانی هاوبەشی\f + \fr 3:1 \ft قوربانی هاوبەشی: ئەم قوربانییە هاودەمی قوربانی سووتاندن بوو. تەنها یەک کەس هەڵدەستا بە دابینکردنی ئەم قوربانییە، بەڵام لەگەڵ خەڵکی دیکە بەشی زۆری ئەم قوربانییەیان لەبەردەم خودا دەخوارد وەک هێمایەک بۆ پێکەوە ژیان. بڕوانە \xt لێڤییەکان 7‏:11‏-15.‏\xt*\ft ‏\f* بوو، لە گاگەل پێشکەشی کرد، نێر یان مێ دەبێت ساغ بێت و بیهێنێتە بەردەم یەزدان.
\v 2 دەستی لەسەر سەری قوربانییەکەی دادەنێت و لەلای دەروازەی چادری چاوپێکەوتن سەری دەبڕێت. نەوەی هارون کە کاهینەکانن، خوێنەکەی بەسەر هەموو لایەکی قوربانگاکەدا دەپرژێنن.
\v 3 لە قوربانی هاوبەشیش، بەم جۆرە قوربانی بە ئاگر پێشکەشی یەزدان دەکرێت: هەموو هەناوی و ئەو پیوەی هەناوی داپۆشیوە،
\v 4 لەگەڵ دوو گورچیلەکە و ئەو پیوەی لەسەریانە، ئەوەی لەسەر ناوقەدە، هەروەها ئەو پیوەی لەسەر جگەر و گورچیلەکانە لێی دەکرێتەوە.
\v 5 نەوەی هارونیش لەسەر قوربانگاکە دەیسووتێنن، لەسەر ئەو قوربانی سووتاندنەی لەسەر دارەکانی سەر ئاگرەکەیە، قوربانی بە ئاگرە، ئەو بۆنەی یەزدان پێی خۆشە.
\p 
\v 6 «”ئەگەر قوربانییەکەی لە مەڕوماڵات بوو، قوربانی هاوبەشی بۆ یەزدان، نێر یان مێی ساغ پێشکەش دەکات.
\v 7 ئەگەر قوربانییەکەی بەرخ بوو، لەبەردەم یەزدان پێشکەشی دەکات.
\v 8 دەستی لەسەر سەری قوربانییەکەی دادەنێت و لەبەردەم چادری چاوپێکەوتن سەری دەبڕێت و نەوەی هارون خوێنەکەی بەسەر هەموو لایەکی قوربانگاکەدا دەپرژێنن.
\v 9 لە قوربانی هاوبەشییەکەش پیوەکەی وەک قوربانی بە ئاگر بۆ یەزدان پێشکەش دەکرێت. دوگەکەی\f + \fr 3:9 \ft دوگ یان دونگ.‏\f* بە تەواوی لەلای دوا بڕبڕەی پشتەوە لێ دەکاتەوە لەگەڵ ئەو پیوەی هەناوی داپۆشیوە و هەموو ئەو پیوەی بەسەر هەناویەوەیە،
\v 10 لەگەڵ دوو گورچیلەکە و ئەو پیوەی لەسەریانە، ئەوەی لەسەر ناوقەدە و ئەو پیوەی لەسەر جگەر و گورچیلەکانە لێی دەکاتەوە.
\v 11 کاهینەکەش وەک خواردن لەسەر قوربانگا دەیانسووتێنێت، قوربانی بە ئاگرە بۆ یەزدان.
\p 
\v 12 «”ئەگەر قوربانییەکەشی گیسک بوو، نێر یان مێ، لەبەردەم یەزدان پێشکەشی دەکات،
\v 13 دەستی لەسەر سەری دادەنێت و لەبەردەم چادری چاوپێکەوتن سەری دەبڕێت. نەوەی هارون خوێنەکەی بەسەر هەموو لایەکی قوربانگاکەدا دەپرژێنن،
\v 14 لەوەوە قوربانی بە ئاگرەکەی بۆ یەزدان پێشکەش دەکرێت. ئەو پیوەی هەناوی داپۆشیوە و هەموو ئەو پیوەی لەسەر هەناوەکەیە،
\v 15 لەگەڵ دوو گورچیلەکە و ئەو پیوەی لەسەریانە، ئەوەی لەسەر ناوقەدە و ئەو پیوەی لەسەر جگەر و گورچیلەکانە لێی دەکاتەوە،
\v 16 کاهینەکەش وەک خواردن لەسەر قوربانگا دەیانسووتێنێت. قوربانی بە ئاگرە، بۆنی خۆشییە، هەموو پیوەکە هی یەزدانە.
\p 
\v 17 «”ئەمە فەرزێکی هەتاهەتاییە نەوە دوای نەوە لە هەموو نشینگەکانتاندا، نە پیو و نە خوێن مەخۆن.“»
\c 4
\s1 قوربانی بۆ لێخۆشبوونی گوناهی بێ ئەنقەست
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «لەگەڵ نەوەی ئیسرائیل بدوێ و بڵێ: ”ئەگەر یەکێک بەبێ ئەنقەست گوناهی کرد\f + \fr 4:2 \ft بەبێ ئەنقەست گوناهی کرد: ئەگەر کەسێک بەبێ مەبەست گوناهی کرد چ لە ڕێگەی پشتگوێخستن یان نەزانینەوە بێت، ئەوا لە ڕێگەی قوربانی گوناه لێخۆشبوون بەدەستدەهێنێت. هەروەها ئەگەر کەسێک تووشی گڵاوی بووبێت ئەوا بە هەمان شێوە پاک دەبێتەوە. بڕوانە بەشی 12 و بەشی 15.‏\f* لە یەکێک لەو فەرمانانەی یەزدان کە نابێت بکرێت و یەکێکی لەوانە کرد، ئەمە دەبێت:
\p 
\v 3 «”ئەگەر کاهینی دەستنیشانکراو\f + \fr 4:3 \ft کاهینی دەستنیشانکراو: بڕوانە \xt دەرچوون 30‏:30‏-31.‏\xt*\ft ‏\f* گوناهی کرد و گەلی تووشی تاوان کرد، دەبێت جوانەگایەکی ساغ بۆ یەزدان پێشکەش بکات لەبەر ئەو گوناهەی کە کردوویەتی، قوربانی گوناهە\f + \fr 4:3 \ft قوربانی گوناه: پێشکەشکردنی قوربانی لە پێناو گوناه یاخود تاوان، کاریگەری هەیە لەسەر دووبارە گەڕاندنەوەی مرۆڤ بۆ ناو ژیانی خواپەرستی.‏\f*.
\v 4 جوانەگاکە دەباتە لای دەروازەی چادری چاوپێکەوتن لەبەردەم یەزدان و دەستی لەسەر جوانەگاکە دادەنێت و جوانەگاکە لەبەردەم یەزدان سەردەبڕێت.
\v 5 ئینجا کاهینە دەستنیشانکراوەکە لە خوێنی جوانەگاکە دەبات و دەیباتە ناو چادری چاوپێکەوتن.
\v 6 کاهینەکە پەنجەی دەکاتە ناو خوێنەکە و حەوت جار لەبەردەم یەزدان لێی دەپرژێنێت لەلای پەردەی پیرۆزگا.
\v 7 کاهینەکە هەندێکیش لە خوێنەکە لە قۆچەکانی قوربانگای بخوورە بۆنخۆشەکە دەدات، ئەوەی لە چادری چاوپێکەوتنە لەبەردەم یەزدان، پاشماوەی خوێنی جوانەگاکەش دەڕژێنێتە بنکەی قوربانگای قوربانی سووتاندن کە لەلای دەروازەی چادری چاوپێکەوتنە.
\v 8 هەموو پیوی جوانەگای قوربانی بۆ گوناهەکە دەردەهێنێت، ئەو پیوەی هەناوی داپۆشیوە و هەموو ئەو پیوەی لەسەر هەناوەکەیە،
\v 9 لەگەڵ دوو گورچیلەکە و ئەو پیوەی لەسەریانە، ئەوەی لەسەر ناوقەدە و ئەو پیوەی لەسەر جگەر و گورچیلەکانە لێی دەکاتەوە.
\v 10 هەروەک ئەو پیوەی لە گای\f + \fr 4:10 \ft لە زمانی عیبری ئەو وشەیە بۆ نێر و مێ چێڵ و گا بەکاردێت.‏\f* قوربانی هاوبەشی دەکرێتەوە و کاهینەکە لەسەر قوربانگاکەی قوربانی سووتاندن دەیانسووتێنێت.
\v 11 بەڵام پێستی جوانەگاکە و هەموو گۆشتەکەی و سەر و قاچەکەی و هەناوی و ڕیخۆڵەکەی،
\v 12 هەموو پاشماوەی جوانەگاکە دەباتە دەرەوەی ئۆردوگاکە بۆ شوێنێکی پاک بەپێی ڕێوڕەسم، کە بۆ شوێنی فڕێدانی خۆڵەمێش بێت و لەسەر دار دەیانسووتێنێت، لەسەر شوێنی فڕێدانی خۆڵەمێش دەسووتێنرێ.
\p 
\v 13 «”ئەگەر هەموو کۆمەڵی ئیسرائیل بەبێ ئەنقەست گوناهێکیان کرد و یەکێک لەو شتانەیان کرد کە یەزدان فەرمانی داوە نەکرێت، تەنانەت ئەگەر گوناهەکە لەبەرچاوی ئەنجومەن شاردراوە بوو، ئەوا کاتێک درکیان کرد بەو تاوان و
\v 14 دواتر گوناهەکە زانرا کە کردوویانە، دەبێت ئەنجومەن جوانەگایەک وەک قوربانی گوناه پێشکەش بکات و دەیهێننە بەردەم چادری چاوپێکەوتن.
\v 15 پیرانی کۆمەڵەکە لەبەردەم یەزدان دەستیان لەسەر سەری جوانەگاکە دادەنێن و جوانەگاکە لەبەردەم یەزدان سەردەبڕدرێت.
\v 16 ئینجا کاهینی دەستنیشانکراو لە خوێنی جوانەگاکە دەباتە ناو چادری چاوپێکەوتن،
\v 17 پەنجەی دەخاتە ناو خوێنەکە و حەوت جار لەلای پەردەکە لەبەردەم یەزدان دەیپرژێنێت.
\v 18 هەندێک لە خوێنەکە لە قۆچەکانی قوربانگاکە دەدات کە لەبەردەم یەزدانە لە چادری چاوپێکەوتن و پاشماوەی خوێنەکەش لە بنکەی قوربانگاکەی قوربانی سووتاندن دەڕێژێت کە لەلای دەروازەی چادری چاوپێکەوتنە.
\v 19 هەموو پیوەکەی لێ دەکاتەوە و لەسەر قوربانگاکە دەیسووتێنێت.
\v 20 چی لە جوانەگای قوربانی گوناه کرد ئاواش لەو جوانەگایە دەکات. کاهینەکە کەفارەتیان بۆ دەکات و لێخۆشبوونیان بۆ دەبێت.
\v 21 پاشان جوانەگاکە دەباتە دەرەوەی ئۆردوگاکە و دەیسووتێنێت هەروەک جوانەگای یەکەمی سووتاند، ئەوە قوربانی گوناهی کۆمەڵە.
\p 
\v 22 «”ئەگەر دەسەڵاتدارێک گوناهی کرد و بەبێ ئەنقەست یەکێک لەوانەی کرد کە یەزدانی پەروەردگاری فەرمانی داوە نەکرێت و تاوانبار بوو،
\v 23 پاشان لە گوناهەکەی ئاگادار کرایەوە کە کردوویەتی، دەبێت قوربانییەکەی بهێنێت کە گیسکێکی نێری ساغ بێت.
\v 24 دەستی لەسەر سەری گیسکەکە دابنێت و سەری ببڕێت لەو شوێنەی کە قوربانی سووتاندنی لێ سەردەبڕدرێت لەبەردەم یەزدان. ئەوە قوربانی گوناهە،
\v 25 کاهینەکەش بە پەنجەی لە خوێنی قوربانییەکەی گوناه دەبات و لە قۆچەکانی قوربانگاکەی قوربانی سووتاندنی دەدات، پاشماوەی خوێنەکەی دەڕێژێتە بنکەی قوربانگاکەی قوربانی سووتاندن.
\v 26 هەموو پیوەکەشی لەسەر قوربانگاکە دەسووتێنێت وەک پیوی قوربانی هاوبەشی. کاهینەکە لە گوناهەکەی کەفارەتی بۆ دەکات و لێخۆشبوونی بۆ دەبێت.
\p 
\v 27 «”ئەگەر یەکێک لە کۆمەڵگا بەبێ ئەنقەست گوناهی کرد، بەوەی یەکێک لەوانەی کرد کە یەزدان فەرمانی داوە نەکرێت و تاوانبار بوو،
\v 28 پاشان لە گوناهەکەی ئاگادار کرایەوە کە کردوویەتی، دەبێت قوربانییەکەی بهێنێت کە بزنێکی ساغ بێت، لەبەر گوناهەکەی کە کردوویەتی.
\v 29 لە شوێنی قوربانی سووتاندن دەستی لەسەر سەری قوربانییەکەی گوناه دادەنێت و سەری دەبڕێت.
\v 30 کاهینەکەش بە پەنجەی لە خوێنەکەی دەبات و لەسەر قۆچەکانی قوربانگاکەی قوربانی سووتاندنی دەدات، پاشماوەی خوێنەکەشی دەڕێژێتە بنکەی قوربانگاکە.
\v 31 هەموو پیوەکەشی لێ دەکاتەوە، وەک چۆن ئەو پیوەی لە قوربانی هاوبەشی کردەوە و کاهینەکە لەسەر قوربانگاکە دەیسووتێنێت. ئەو بۆنەی یەزدان پێی خۆشە. کاهینەکە کەفارەتی بۆ دەکات و لێخۆشبوونی بۆ دەبێت.
\p 
\v 32 «”ئەگەر قوربانییەکەی بەرخ بوو بۆ قوربانی گوناه، دەبێت مێینە و ساغ بێت.
\v 33 دەستی لەسەر سەری قوربانییەکەی گوناه دادەنێت و وەک قوربانی گوناه سەری دەبڕێت، لەو شوێنەی قوربانی سووتاندنی تێدا سەردەبڕدرێت.
\v 34 کاهینەکە بە پەنجەی لە خوێنی قوربانییەکەی گوناه دەبات و لەسەری قۆچەکانی قوربانگاکەی قوربانی سووتاندنی دەدات و هەموو خوێنەکەش دەڕێژێتە بنکەی قوربانگاکە.
\v 35 هەموو پیوەکەشی لێ دەکاتەوە هەروەک ئەو پیوەی لە بەرخی قوربانی هاوبەشی دەکرێتەوە، کاهینەکە لەسەر قوربانگاکە لەسەر قوربانییە بە ئاگرەکانی بۆ یەزدان دەیسووتێنێت. بەم شێوەیە کاهینەکە کەفارەتی بۆ دەکات لە گوناهەکەی کە کردوویەتی و لێخۆشبوونی بۆ دەبێت.
\c 5
\p 
\v 1 «”کاتێک کەسێک گوێی لە بانگەوازی ئاشکرا دەبێت بۆ شایەتیدان کە شایەتی بدات، بێدەنگ بوو لەوەی بینیبووی یان زانیبووی، ئەوا ئەو کەسە گوناهی کردووە و تاوانی خۆی لە ئەستۆ دەگرێت.
\p 
\v 2 «”یان ئەگەر یەکێک بەر شتێکی گڵاو کەوت، وەک کەلاکی\f + \fr 5:2 \ft کەلاک: واتا لاشەی مردوو یان کوژراو کە بۆ خواردن ناشێت.‏\f* ئاژەڵێکی کێوی گڵاو یان کەلاکی ئاژەڵێکی ماڵی گڵاو یان کەلاکی خشۆکێکی گڵاو، ئەگەر ئاگای لێ نەبوو و پاشان زانی، ئەوا تاوانبارە.
\v 3 یان ئەگەر دەستی لە شتە گڵاوەکانی کەسێک دا لە هەموو گڵاوییەکانی کە پێی گڵاو دەبێت، ئاگای لێ نەبوو و پاشان زانی، ئەوا تاوانبارە.
\v 4 یان یەکێک هەڵەشە بوو لە سوێندخواردن، بۆ خراپە یان چاکە، لە هەموو ئەوەی مرۆڤ لە کاتی سوێندخواردن پەلەی لێ دەکات، بێ ئەوەی بزانێت و پاشان زانی، ئەوا ئەو کەسە لەو شتە تاوانبارە.
\v 5 ئەگەر یەکێک تاوانبار بوو بە شکاندنی بڕگەیەکی ئەو یاسایانەی کە ئاماژەی پێکرا، ئەوا دان بە گوناهەکەی دەنێت و
\v 6 بە قوربانییەکەیەوە کە مێ بێت، بەرخ یان گیسک، بۆ تاوانەکەی دێتە لای یەزدان لەبەر ئەو گوناهەی کە کردوویەتی، قوربانی گوناه، کاهینەکەش کەفارەت بۆ گوناهەکەی دەکات.
\p 
\v 7 «”ئەگەر دەستکورت بوو بۆ بەرخێک، با دوو کوکوختی یان دوو بێچووە کۆتر وەک قوربانی بۆ یەزدان بهێنێت لەبەر تاوانەکەی کە گوناهی پێکردووە، یەکێکیان قوربانی گوناهە و ئەوەی دیکە قوربانی سووتاندن.
\v 8 دەیانهێنێت بۆ کاهینەکە و ئەویش یەکەم جار ئەوەی بۆ گوناهە پێشکەشی دەکات، سەری لەلای پشتەوە دەقرتێنێت بەڵام بە تەواوی لێی ناکاتەوە.
\v 9 لە خوێنی قوربانی گوناهەکە بە لاتەنیشتی قوربانگاکەدا دەکات، ئەوەشی لە خوێنەکە دەمێنێتەوە، دەگوشرێتە بنکەی قوربانگاکە، ئەوە قوربانی گوناهە.
\v 10 ئەوەی دیکە بەپێی ڕێوڕەسم دەکاتە قوربانی سووتاندن، ئینجا کاهینەکە کەفارەتی بۆ دەکات لە گوناهەکەی کە کردوویەتی و لێخۆشبوونی بۆ دەبێت.
\p 
\v 11 «”ئەگەر دەستکورت بوو دوو کوکوختی یان دوو بێچووە کۆتر بهێنێت، قوربانییەکەی لەبەر ئەو گوناهەی کە کردوویەتی دەیەکی ئێفەیەک\f + \fr 5:11 \ft نزیکەی دوو لیتر.‏\f* لە باشترین ئارد دەبێتە قوربانی گوناه. زەیتی بەسەردا ناکات و بخووری سادەی لەسەر دانانێت، چونکە قوربانی گوناهە.
\v 12 دەیهێنێتە لای کاهینەکە و ئەویش پڕ بە مستی لێی دەبات، بەشی یادەوەرییەکەی و لەسەر قوربانگاکە لەسەر قوربانییە بە ئاگرەکانی بۆ یەزدان دەیسووتێنێت، ئەوە قوربانی گوناهە.
\v 13 بەم شێوەیە کاهینەکە کەفارەتی بۆ دەکات لە گوناهەکەی کە کردوویەتی لە هەر یەکێک لەوانە و لێخۆشبوونی بۆ دەبێت، ئەوەی دەشمێنێتەوە بۆ کاهینەکە دەبێت، وەک چۆن پاشماوەی پێشکەشکراوی دانەوێڵە بە کاهینەکە دەدرێت.“»
\s1 قوربانیدان بۆ تاوان
\p 
\v 14 هەروەها یەزدان بە موسای فەرموو:
\v 15 «ئەگەر یەکێک سەرپێچییەکی کرد و سەبارەت بە شتە پیرۆزکراوەکانی یەزدان\f + \fr 5:15 \ft شتە پیرۆزکراوەکانی یەزدان: لە ڕاستیدا ئەمە جۆرێک بوو لە قوربانی گوناه. ناوەڕۆکی ڕوخساری ئەم قوربانییە تایبەت بوو بە بەکارهێنانی شتە پیرۆزکراوەکان بە شێوەیەکی ناپیرۆز.‏\f* بەبێ ئەنقەست گوناهی کرد، دەبێت لەبەر تاوانەکەی قوربانییەک بۆ یەزدان بهێنێت، بەرانێکی ساغی مێگەل بێت و بەو نرخەی بۆی دادەنێیت بە شاقلی زیو بەپێی شاقلی پیرۆزگا\f + \fr 5:15 \ft شاقلی پیرۆزگا: نزیکەی 11,5 گرام.‏\f*، ئەوە قوربانی تاوانە.
\v 16 هەروەها قەرەبووی ئەو گوناهەش دەکاتەوە کە سەبارەت بە شتە پیرۆزکراوەکان کردوویەتی و پێنج یەکیشی لەسەر دادەنێت و دەیداتە کاهینەکە. کاهینەکە بە بەرانەکەی قوربانی تاوان کەفارەتی بۆ دەکات و لێخۆشبوونی بۆ دەبێت.
\p 
\v 17 «ئەگەر یەکێک گوناهی کرد و یەکێک لەوانەی کرد کە یەزدان فەرمانی داوە نەکرێن و نەیزانی، ئەوا تاوانبارە و تاوانی خۆی لە ئەستۆ دەگرێت.
\v 18 بە بەرانێکی ساغی مێگەل و بەو نرخەی بۆی دادەنێیت، بە قوربانی تاوانەوە بۆ لای کاهینەکە دێت، کاهینەکەش لەو هەڵەیەی کە بەبێ ئەنقەست کردوویەتی کەفارەتی بۆ دەکات و لێخۆشبوونی بۆ دەبێت.
\v 19 ئەوە قوربانی تاوانە، چونکە تاوانێکی سەبارەت بە یەزدان کردووە.»
\c 6
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «ئەگەر یەکێک گوناهی کرد و ناپاکی لە یەزدان کرد، بەوەی فێڵی لە کەسێک کرد، لە شتێک کە لەلای دانرابێت یان ئەمانەتێک یان دزینێک یان دەست بەسەرداگرتنی شتێکی نزیکەکەی،
\v 3 یان شتێکی بزربووی دۆزییەوە و سەبارەت بەوە نکۆڵی کرد، یان بە درۆ سوێندی لەسەر ئەمانە خوارد یان هەر شتێک کە مرۆڤ گوناهی تێدا بکات،
\v 4 ئەگەر گوناهی کرد و تاوانبار بوو، پێویستە شتەکان بگەڕێنێتەوە، ئەوا ئەوەی دزیویەتی یان ئەوەی دەستی بەسەردا گرتووە یان ئەوەی لەلای دانراوە یان ئەوەی بزر ببوو و دۆزییەوە،
\v 5 یان هەر شتێک کە بە درۆ سوێندی لەسەر خواردبێت. سەر بەسەر قەرەبووی دەکاتەوە و پێنج یەکیشی بۆ زیاد دەکات. لە ڕۆژی قوربانی تاوانەکەی دەیداتەوە دەست خاوەنەکەی.
\v 6 لەبری تاوانەکە دەبێت قوربانییەک بۆ کاهین بهێنێت، ئەمە بۆ یەزدانە، قوربانی تاوانەکە بەرانێکی ساغی مێگەل بێت، بەو نرخەی بۆی دادەنێیت،
\v 7 کاهینەکە لەبەردەم یەزدان کەفارەتی بۆ دەکات و لێخۆشبوونی بۆ دەبێت لە هەر شتێک کە کردوویەتی و پێی تاوانبارە.»
\s1 قوربانی سووتاندن
\p 
\v 8 هەروەها یەزدان بە موسای فەرموو:
\v 9 «ئەم فەرمانە بە هارون و کوڕەکانی ڕابگەیەنە: ”ئەمانە ڕێنماییەکانن دەربارەی قوربانی سووتاندن. قوربانی سووتاندن دەبێت بە درێژایی شەو هەتا بەیانی لەسەر ئاگردانەکە بێت لەسەر قوربانگاکە. پێویستە ئاگری قوربانگاکەش بە داگیرساوی بمێنێتەوە.
\v 10 کاهینەکە جلەکانی و دەرپێکەی کە لە کەتانن لەبەر دەکات و خۆڵەمێشی ئەو قوربانی سووتاندنەی کە ئاگرەکە هەڵیلووشی هەڵدەگرێت و لەتەنیشت قوربانگاکە دایدەنێت.
\v 11 ئینجا جلەکانی دادەکەنێت و جلی دیکە لەبەر دەکات و خۆڵەمێشەکە دەباتە دەرەوەی ئۆردوگاکە بۆ شوێنێک بەپێی ڕێوڕەسم پاک بێت.
\v 12 پێویستە ئاگری سەر قوربانگاکەش بە داگیرساوی بمێنێتەوە و نەکوژێتەوە. کاهینەکەش هەموو بەیانییەک داری لەسەر دەسووتێنێت و قوربانی سووتاندنی لەسەر ڕێک دەخات و پیوی قوربانییەکانی هاوبەشی لەسەر دەسووتێنێت.
\v 13 ئاگرێکی بەردەوامە لەسەر قوربانگاکە کراوەتەوە و ناکوژێتەوە.
\s1 پێشکەشکراوی دانەوێڵە
\p 
\v 14 «”ئەمانەش ڕێنماییەکانن دەربارەی پێشکەشکراوی دانەوێڵە، کوڕانی هارون لەبەردەم یەزدان پێشکەشی دەکەن بۆ پێش قوربانگاکە.
\v 15 بە مستی هەندێک ئاردی پێشکەشکراوی دانەوێڵەکە و زەیتەکەی و هەموو بخوورە سادەکەی کە لەسەر پێشکەشکراوە خۆراکەکەیە لێ دەبات و بەشی یادەوەرییەکە لەسەر قوربانگاکە دەسووتێنێت، ئەمەش وەک بۆنی خۆشییە بۆ یەزدان.
\v 16 ئەوەی لێشی دەمێنێتەوە هارون و کوڕانی دەیخۆن. بەڵام بەبێ هەویرترش لە شوێنێکی پیرۆز دەخورێت. لە حەوشەی چادری چاوپێکەوتن دەیخۆن.
\v 17 بە هەویرترش ناکرێت بە نان. کردوومە بە بەشی ئەوان لە قوربانییە بە ئاگرەکانم، ئەوە هەرەپیرۆزە وەک قوربانی گوناه و قوربانی تاوان.
\v 18 هەموو نێرینەیەک لە نەوەی هارون لێی دەخوات، بەشێکی چەسپاوە بۆ نەوەکانتان لە قوربانییە بە ئاگرەکان بۆ یەزدان، هەر شتێکی بەر بکەوێت پیرۆز دەبێت.“»
\p 
\v 19 هەروەها یەزدان بە موسای فەرموو:
\v 20 «ئەمە قوربانی هارون و کوڕەکانییەتی کە لە ڕۆژی دەستنیشانکردن بۆ یەزدانی دەهێنن: دەیەکی ئێفەیەک\f + \fr 6:20 \ft نزیکەی 1,6 کیلۆگرام.‏\f* لە باشترین ئارد لە پێشکەشکراوی دانەوێڵە، بە بەردەوامی نیوەی لە بەیانییان و نیوەی لە ئێواران.
\v 21 لەسەر ساج دروستکراو و بە زەیت شێلراو ساز دەکەیت و دەیهێنیت، بە پارچەپارچەکراوی پێشکەشکراوە دانەوێڵەکە پێشکەش دەکەیت، ئەو بۆنەی یەزدان پێی خۆشە.
\v 22 ئەو کوڕەی جێگەی دەگرێتەوە وەک کاهینی دەستنیشانکراو هەڵدەستێت بەو کارە، بەشێکی چەسپاوە بۆ یەزدان، بە تەواوی دەسووتێنرێ.
\v 23 هەموو پێشکەشکراوێکی دانەوێڵەی کاهین بە تەواوی دەسووتێنرێت و ناخورێت.»
\s1 قوربانی گوناه
\p 
\v 24 هەروەها یەزدان بە موسای فەرموو:
\v 25 «لەگەڵ هارون و کوڕەکانی بدوێ و بڵێ: ”ئەمانە ڕێنماییەکانن دەربارەی قوربانی گوناه، لەو شوێنەی قوربانی سووتاندن سەردەبڕدرێت لەوێش قوربانی گوناه لەبەردەم یەزدان سەردەبڕیت، ئەوە هەرەپیرۆزە.
\v 26 ئەو کاهینەی قوربانییەکە بۆ کەفارەتی گوناه دەکات لێی دەخوات، لە شوێنێکی پیرۆز دەخورێت، لە حەوشەی چادری چاوپێکەوتن.
\v 27 هەر شتێک بەر کەلاکەکە بکەوێت ئەوا پیرۆز دەبێت، ئەگەر پرژەیەک لە خوێنەکە بەر جلێک کەوت، ئەوا پێویستە جلەکە لە شوێنێکی پیرۆز بشۆیت.
\v 28 بەڵام ئەو مەنجەڵە گڵینەی تێیدا لێنراوە، ئەوا دەشکێنرێت، ئەگەر لە مەنجەڵێکی بڕۆنز لێنرا، ئەوا سپی دەکرێتەوە و ئاوی پێدا دەکرێت.
\v 29 هەموو نێرینەیەک لە کاهینەکان لێی دەخوات، ئەوە هەرەپیرۆزە.
\v 30 بەڵام هەموو قوربانییەکی گوناه لە خوێنەکەی دەبردرێتە ناو چادری چاوپێکەوتن و بۆ کەفارەتکردن لە شوێنی پیرۆز، ناخورێت بەڵکو بە ئاگر دەسووتێنرێ.
\c 7
\s1 قوربانیدان بۆ تاوان
\p 
\v 1 «”ئەمانەش ڕێنماییەکانن دەربارەی قوربانی تاوان\f + \fr 7:1 \ft قوربانی تاوان: بڕوانە \xt لێڤییەکان 5‏:15 و دەرچوون 30‏:22‏-38.‏\xt*\ft ‏\f*. ئەمە هەرەپیرۆزە.
\v 2 لەو شوێنەی قوربانی سووتاندن سەردەبڕدرێت هەر لەوێ قوربانی تاوانیش سەردەبڕدرێت. خوێنەکەشی بەسەر هەموو لایەکی قوربانگاکەدا دەڕژێنرێت.
\v 3 هەموو پیوەکەشی پێشکەش دەکرێت، دوگەکەی و ئەو پیوەی هەناوی داپۆشیوە،
\v 4 لەگەڵ دوو گورچیلەکە و ئەو پیوەی لەسەریانە، ئەوەی لەسەر ناوقەدە، هەروەها ئەو پیوەی لەسەر جگەر و گورچیلەکانە لێی دەکرێتەوە.
\v 5 کاهینەکە لەسەر قوربانگاکە دەیانسووتێنێت. قوربانی بە ئاگرە بۆ یەزدان، ئەمە قوربانی تاوانە.
\v 6 هەموو نێرینەیەک لە کاهینەکان لێی دەخوات، بەڵام لە شوێنێکی پیرۆز دەخورێت، ئەمە هەرەپیرۆزە.
\p 
\v 7 «”قوربانی تاوان وەک قوربانی گوناهە، یەک فێرکردن هەیە دەربارەیان، ئەو کاهینەی کەفارەتیان پێ دەکات بۆ ئەو دەبێت،
\v 8 ئەو کاهینەش کە قوربانییەکی سووتاندن بۆ کەسێک دەکات، ئەوا پێستی ئەو قوربانییەی سووتاندن کە دەیکات بۆ ئەو دەبێت.
\v 9 هەموو پێشکەشکراوێکی دانەوێڵەش بە تەنوور کرابێتە نان و هەموو ئەوەی لەناو تاوە دروستکرابێت یان لەسەر ساج بۆ ئەو کاهینە دەبێت کە پێشکەشی دەکات،
\v 10 هەروەها هەموو پێشکەشکراوێکی دانەوێڵەی بە زەیت شێلراو یان وشک، بۆ هەموو کوڕانی هارون دەبێت، هەریەکە وەک براکەی.
\s1 قوربانی هاوبەشی
\p 
\v 11 «”ئەمانەش ڕێنماییەکانن دەربارەی قوربانی هاوبەشی\f + \fr 7:11 \ft قوربانی هاوبەشی: بڕوانە \xt 3‏:1‏\xt*\ft .‏\f*، ئەوەی کەسێک دەتوانێت بۆ یەزدانی بهێنێت.
\p 
\v 12 «”ئەگەر بۆ سوپاسکردن هێنای، ئەوا بۆ قوربانی سوپاسگوزاری کولێرەی فەتیرەی بە زەیت شێلراو و ناسکە نانی\f + \fr 7:12 \ft ناسکە نان: ناوەشکێنە.‏\f* فەتیرەی بە زەیت چەورکراو و باشترین ئاردی شێلراو، کرابێتە کولێرەی بە زەیت شێلراو.
\v 13 لەگەڵ کولێرەی بە هەویرترش، قوربانییەکەی لەسەر قوربانی سوپاسگوزاری بۆ ژیانە هاوبەشییەکەی پێشکەش دەکات.
\v 14 لە هەر جۆرێکیان یەکێک وەک پێشکەشکراوێک دەهێنێت، وەک بەخشینێک بۆ یەزدان، بۆ ئەو کاهینە دەبێت کە خوێنی قوربانی هاوبەشی دەپرژێنێت.
\v 15 گۆشتی قوربانی سوپاسگوزاری بۆ ژیانی هاوبەشییەکەی لە ڕۆژی قوربانییەکەی دەخورێت، هیچی لێ ناهێڵێتەوە بۆ بەیانی.
\p 
\v 16 «”ئەگەر قوربانییەکەی نەزر\f + \fr 7:16 \ft نەزر: داوا لە خودا دەکرێت بۆ ئەنجامدانی کارێک و پابەند دەکرێت بە مەرجێکەوە. ئەگەر خودا ئەو کارە بکات، ئەوا دەرئەنجام ئەمیش ئەو کارە ئەنجام دەدات کە پێیەوە پابەندی کردووە. بڕوانە \xt سەرژمێری 21‏:2‏\xt*\ft ‏.‏\f* بوو یان بە خواستی خۆی بوو، ئەوا ڕۆژی پێشکەشکردنی قوربانییەکە دەخورێت و بۆ سبەینێش ئەوەی لێی ماوەتەوە دەخورێت.
\v 17 بەڵام بەرماوەی گۆشتی قوربانییەکە لە ڕۆژی سێیەم دەسووتێنرێ.
\v 18 ئەگەر لە ڕۆژی سێیەم لە گۆشتی قوربانی هاوبەشییەکە خواردرا، ئەوا قوربانییەکە قبوڵ نییە، ئەوەی پێشکەشی کرد بە چاک بۆی دانانرێت، چونکە قوربانییەکە گڵاو بووە. ئەوەی لێی بخوات ئەوا تاوانی خۆی لە ئەستۆ دەگرێت.
\p 
\v 19 «”ئەو گۆشتەش کە بەر شتێکی گڵاو بکەوێت ئەوا بەپێی ڕێوڕەسم ناخورێت، بە ئاگر دەسووتێنرێت. بەڵام ئەو گۆشتەی کە گڵاو نییە، هەموو کەسێکی پاک بەپێی ڕێوڕەسم دەتوانێت لێی بخوات.
\v 20 هەروەها ئەگەر کەسێک بە شتێک گڵاو بووبێت و لە گۆشتی قوربانی هاوبەشی یەزدان بخوات، ئەوا دەبێت ئەو کەسە لە گەلەکەی داببڕدرێت.
\v 21 ئەگەر هەرکەسێک دەست لە شتێکی گڵاو بدات یان بەر شتێکی گڵاو بکەوێت، گڵاویی مرۆڤێک یان ئاژەڵێکی گڵاو\f + \fr 7:21 \ft بڕوانە بەشی 11.‏\f* یان هەر شتێکی قێزەونی گڵاو، ئینجا لە گۆشتی قوربانی هاوبەشی یەزدان بخوات، ئەوا ئەو کەسە لە گەلەکەی دادەبڕدرێت.“»
\s1 خواردنی پیو و خوێن قەدەغەکراون
\p 
\v 22 هەروەها یەزدان بە موسای فەرموو:
\v 23 «لەگەڵ نەوەی ئیسرائیل بدوێ و بڵێ: ”پیوی ئاژەڵی مێگەل و گاوگۆتاڵ مەخۆن.
\v 24 پیوی ئاژەڵی مردارەوەبوو و پیوی ئەو ئاژەڵەی بووە بە نێچیر ئەوا بۆ هەموو کارێک بەکاردێت، بەڵام ناخورێت.
\v 25 هەر یەکێک لە پیوی ئەو ئاژەڵانەی خوارد کە بۆ یەزدان وەک قوربانی بە ئاگر لێیان پێشکەش دەکرێت، ئەوا ئەو کەسە لە گەلەکەی دادەبڕدرێت.
\v 26 هیچ خوێنێکیش مەخۆن لە هەموو نشینگەکانتان، ئەگەر هی باڵندە بێت یان ئاژەڵ.
\v 27 هەرکەسێک خوێن بخوات، ئەوا ئەو کەسە لە گەلەکەی دادەبڕدرێت.“»
\p 
\v 28 هەروەها یەزدان بە موسای فەرموو:
\v 29 «لەگەڵ نەوەی ئیسرائیل بدوێ و بڵێ: ”ئەوەی قوربانی هاوبەشی بۆ یەزدان پێشکەش دەکات، لە قوربانی هاوبەشییە پێشکەشکراوەکەی بۆ یەزدان دەهێنێت.
\v 30 کەسەکە بە دەستی خۆی قوربانییە بە ئاگرەکانی بۆ یەزدان دەهێنێت. پیوەکە لەگەڵ سنگەکە دەهێنێت. لەبەردەم یەزدان سنگەکە وەک قوربانی بەرزکردنەوە\f + \fr 7:30 \ft قوربانی بەرزکردنەوە: لەم قوربانییەدا کەسەکە چەند جارێک قوربانییەکە بەرز دەکاتەوە کە هێمایەکە بۆ تەرخانکردن بۆ خودا.‏\f* بەرز دەکاتەوە.
\v 31 کاهینەکە پیوەکە لەسەر قوربانگاکە دەسووتێنێت، بەڵام سنگەکە بۆ هارون و کوڕەکانی دەبێت.
\v 32 ڕانی ڕاستەش لە قوربانییەکانی هاوبەشیتان وەک پیتاک دەدەنە کاهینەکە.
\v 33 ئەوەی خوێنی قوربانی هاوبەشی و پیوەکە پێشکەش دەکات لە کوڕانی هارون، ڕانە ڕاستەکە دەبێتە بەشی ئەو،
\v 34 چونکە من لە قوربانییەکانی هاوبەشییان سنگی بەرزکراوە و ڕانە پێشکەشکراوەکەم لە نەوەی ئیسرائیل وەرگرتووە، بە هارونی کاهین و بە کوڕەکانیم داوە. بەشێکی چەسپاوە بۆ نەوەی ئیسرائیل.“»
\p 
\v 35 ئەوە پشکی هارون و کوڕەکانییەتی لە قوربانییە بە ئاگرەکانی بۆ یەزدان، ڕۆژی پێشکەشکردنیان هەتا کاهینیێتی بۆ یەزدان بکەن،
\v 36 لەو ڕۆژەی دەستنیشان کران\f + \fr 7:36 \ft شێوازی ئەم دەستنیشانکردنە بریتی بووە لە زەیت پێداکردن بەسەر سەری کاهینەکە. بڕوانە \xt دەرچوون 29‏:7‏\xt*\ft ‏.‏\f* یەزدان فەرمانی بە نەوەی ئیسرائیل دا بیاندەنێ، وەک بەشێکی چەسپاو بۆ نەوەکانیان.
\p 
\v 37 ئەوە ڕێنماییە بۆ قوربانی سووتاندن و پێشکەشکراوی دانەوێڵە و قوربانی گوناه و قوربانی تاوان و قوربانی ئەرک پێ سپاردن و قوربانی هاوبەشی،
\v 38 کە یەزدان لە شاخی سینا دایە موسا، بۆ ئەوەی فەرمان بە نەوەی ئیسرائیل بکات هەتا لە چۆڵەوانی سینا قوربانییەکانیان بۆ یەزدان پێشکەش بکەن.
\c 8
\s1 ئەرکسپاردن بە هارون و کوڕەکانی
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «هارون و کوڕەکانی ببە، لەگەڵ جلەکان و زەیتی دەستنیشانکردنەکە و جوانەگاکەی قوربانی گوناه و دوو بەرانەکە و سەبەتە نانە فەتیرەکە.
\v 3 هەموو کۆمەڵیش لەلای دەروازەی چادری چاوپێکەوتن کۆبکەرەوە.»
\v 4 موساش وەک یەزدان فەرمانی پێ کرد، ئاوای کرد، ئیتر کۆمەڵەکە لەلای دەروازەی چادری چاوپێکەوتن کۆبوونەوە.
\p 
\v 5 موسا بە کۆمەڵەکەی گوت: «یەزدان فەرمانی داوە ئەمە بکرێت.»
\v 6 ئینجا موسا هارون و کوڕەکانی هێنایە پێشەوە و بە ئاو شوشتنی.
\v 7 کراسەکەی لەبەر هارون کرد و کەمەربەندەکەی بۆ بەست، کەواکەی لەبەری کرد، ئێفۆدەکەی خستە سەر و بە پشتبەستی ئێفۆدەکە بەستی و توندی کرد.
\v 8 بەرسینەکەی لەبەری کرد و ئوریم و تومیمەکەی\f + \fr 8:8 \ft دوو بەردی گرانبەها بوون، لە کاتی بڕیاردان بۆ زانینی خواستی خودا بەکارهێنراون، بڕوانە \xt دەرچوون 28‏:30 و یەکەم ساموئێل 23‏:9‏-12.‏\xt*\ft ‏\f* خستە ناو بەرسینەکە.
\v 9 مێزەرەکەشی خستە سەر سەری هارون. لەسەر مێزەرەکە بەلای پێشەوە پلێتە زێڕەکەی دانا کە تاجەگوڵینەی پیرۆزە، هەروەک یەزدان فەرمانی بە موسا کرد.
\p 
\v 10 ئینجا موسا زەیتی دەستنیشانکردنەکەی هێنا و چادرەکەی پەرستن\f + \fr 8:10 \ft چادری پەرستن: پەرستگایەکی گواستراوە بووە کە گەلی ئیسرائیل لەگەڵ خۆیان دەیانگواستەوە؛ بڕوانە \xt دەرچوون 36‏:8‏-38.‏\xt*\ft ‏\f* و هەرچی تێیدا بوو دەستنیشانی کرد و تەرخانی کرد.
\v 11 حەوت جاریش بەسەر قوربانگاکەدا پرژاندی و قوربانگاکە و هەموو قاپوقاچاغەکانی و حەوزەکە و بنکەکەی دەستنیشان کرد بۆ تەرخانکردنیان.
\v 12 هەندێک لە زەیتی دەستنیشانکردنەکەشی لە سەری هارون دا و دەستنیشانی کرد بۆ تەرخانکردنی.
\v 13 موسا کوڕەکانی هارونی هێنایە پێشەوە و کراسی لەبەرکردن و کەمەربەندی بۆ بەستن و سەرپێچەکانی بۆ توند کردنەوە، هەروەک یەزدان فەرمانی بە موسا کرد.
\p 
\v 14 ئینجا جوانەگاکەی قوربانی گوناهی هێنایە پێشەوە و هارون و کوڕەکانی دەستیان لەسەر سەری جوانەگاکەی گوناه دانا.
\v 15 موسا سەری بڕی و هەندێک لە خوێنەکەی برد و بە پەنجەی دەستی خوێنەکەی لە هەموو قۆچەکانی قوربانگاکە دا بۆ ئەوەی قوربانگاکە پاک بکاتەوە. ئینجا پاشماوەی خوێنەکەی ڕشتە بنکەی قوربانگاکە. ئیتر تەرخانی کرد بۆ کەفارەتکردن بۆی.
\v 16 موسا هەموو ئەو پیوەی کە هەناوی داپۆشیوە لەگەڵ ئەوەی لەسەر جگەر و گورچیلەکانە و هەردوو گورچیلەکەی برد و لەسەر قوربانگاکە سووتاندنی.
\v 17 بەڵام جوانەگاکەی بە پێست و گۆشت و ڕیخۆڵەکەیەوە لە دەرەوەی ئۆردوگاکە بە ئاگر سووتاند، هەروەک یەزدان فەرمانی بە موسا کرد.
\p 
\v 18 ئینجا بەرانەکەی قوربانی سووتاندنی هێنایە پێشەوە و هارون و کوڕەکانی دەستیان لەسەر سەری بەرانەکە دانا.
\v 19 دوای ئەوە موسا سەری بڕی و خوێنەکەی بەسەر هەموو لایەکی قوربانگاکەدا پرژاند.
\v 20 بەرانەکەی پارچەپارچە کرد و موسا سەرەکە و پارچەکان و پیوەکەی سووتاند.
\v 21 بەڵام هەناو و قاچەکانی بە ئاو شوشت، موسا هەموو بەرانەکەی لەسەر قوربانگاکەدا سووتاند، وەک قوربانی بە ئاگر، بۆنی خۆشی، قوربانی بە ئاگر بۆ یەزدان، هەروەک یەزدان فەرمانی بە موسا کرد.
\p 
\v 22 ئینجا بەرانی دووەم، بەرانی ئەرک پێ سپاردنەکەی هێنایە پێشەوە، هارون و کوڕەکانی دەستیان لەسەر سەری بەرانەکە دانا.
\v 23 موسا سەری بڕی و لە خوێنەکەی برد و لە شلکەی گوێی ڕاستی هارونی دا، هەروەها لە پەنجە گەورەی دەستی ڕاست و پەنجە گەورەی پێی ڕاستی.
\v 24 هەروەها کوڕەکانی هارونی هێنایە پێشەوە و لە خوێنەکەی هەڵگرت و لە شلکەی گوێی ڕاستیان و پەنجە گەورەی دەستی ڕاستیان و پەنجە گەورەی پێی ڕاستیانی دا، پاشان خوێنی بەسەر هەموو لایەکی قوربانگاکەدا پرژاند.
\v 25 لەدوای ئەوە پیو و دوگ و هەموو پیوەکەی هەناوی و سەر جگەر و گورچیلەکان و هەردوو گورچیلە و ڕانی ڕاستی برد.
\v 26 هەروەها لە سەبەتەی فەتیرەکە، ئەوەی لەبەردەم یەزدانە، نانێک و کولێرەیەک لەوەی بە زەیتە و ناسکە نانێکی\f + \fr 8:26 \ft ناسکە نان: ناوەشکێنە.‏\f* برد و لەسەر پیوەکە و لەسەر ڕانە ڕاستەکەی دانا.
\v 27 هەمووی خستنە سەر دەستی هارون و کوڕەکانی و لەبەردەم یەزدان وەک قوربانی بەرزکردنەوە بەرزیان کردەوە.
\v 28 ئینجا موسا لە دەستیانی وەرگرت و لەگەڵ قوربانی سووتاندنەکە لەسەر قوربانگاکە سووتاندی، ئەوە قوربانی ئەرک پێ سپاردنە، بۆنی خۆشییە، قوربانی بە ئاگرە بۆ یەزدان.
\v 29 هەروەها موسا سنگی بەرانی ئەرکسپاردنەکەی برد کە بەشی خۆی بوو، وەک قوربانی بەرزکردنەوە\f + \fr 8:29 \ft لەم قوربانییەدا موسا چەند جارێک قوربانییەکە بەرز دەکاتەوە کە هێمایەکە بۆ تەرخانکردن بۆ خودا.‏\f* لەبەردەم یەزدان بەرزی کردەوە، هەروەک یەزدان فەرمانی بە موسا کرد.
\p 
\v 30 پاشان موسا لە زەیتی دەستنیشانکردنەکە و لە خوێنەکەی سەر قوربانگاکەی برد و بەسەر هارون و جلەکانی و بەسەر کوڕەکانی و جلی کوڕەکانی پرژاند. هارون و جلەکانی و کوڕەکانی و جلی کوڕەکانی پێ تەرخان کردن.
\p 
\v 31 ئینجا موسا بە هارون و کوڕەکانی گوت: «گۆشتەکە لەبەردەم دەروازەی چادری چاوپێکەوتن لێبنێن و هەر لەوێش بیخۆن، لەگەڵ ئەو نانەی ناو سەبەتەکەش، قوربانی ئەرکسپاردن، وەک فەرمانم کرد و گوتم: ”هارون و کوڕەکانی بیخۆن.“
\v 32 ئەوەی لە گۆشت و نانەکەش دەمێنێتەوە بە ئاگر بیسووتێنن،
\v 33 لەلای دەروازەی چادری چاوپێکەوتنیش دوور نەکەونەوە، حەوت ڕۆژ هەتا تەواوی ڕۆژەکانی ئەرکسپاردنتان، چونکە حەوت ڕۆژ ئەرکتان پێ دەسپێردرێت.
\v 34 هەروەک لەم ڕۆژەدا کرا، یەزدان فەرمانی داوە کە بکرێت بۆ کەفارەتکردن بۆتان.
\v 35 حەوت شەو و حەوت ڕۆژ لەلای دەروازەی چادری چاوپێکەوتن دەمێننەوە و وریابن بۆ پارێزگاری لە ئەرکەکانی یەزدان، ئیتر نامرن، چونکە ئاوا فەرمانم پێکراوە.»
\p 
\v 36 جا هارون و کوڕەکانی هەموو ئەو شتانەی یەزدان لە ڕێگەی موسا فەرمانی پێ کردبوو، کردیان.
\c 9
\s1 کاهینەکان خزمەتیان دەستپێدەکەن
\p 
\v 1 لە ڕۆژی هەشتەم، موسا هارون و کوڕەکانی و پیرانی ئیسرائیلی بانگکرد و
\v 2 بە هارونی گوت: «جوانەگایەک بۆ خۆت، بۆ قوربانی گوناه و بەرانێک بۆ قوربانی سووتاندن ببە، هەردووکیان ساغ بن و لەبەردەم یەزدان پێشکەشیان بکە.
\v 3 لەگەڵ نەوەی ئیسرائیلیش بدوێ و بڵێ: ”گیسکێکی نێرینە بۆ قوربانی گوناه و جوانەگایەک و بەرخێکی یەک ساڵەی ساغ بۆ قوربانی سووتاندن و
\v 4 گایەک\f + \fr 9:4 \ft لە زمانی عیبری ئەو وشەیە بۆ نێر و مێ چێڵ و گا بەکاردێت، لێرە و لە ئایەتەکانی 18 و 19. بڕوانە \xt 3‏:1‏\xt*\ft .‏\f* و بەرانێک بۆ قوربانی هاوبەشی بۆ سەربڕین لەبەردەم یەزدان ببەن، هەروەها پێشکەشکراوی دانەوێڵەی بە زەیت شێلراو، چونکە ئەمڕۆ یەزدان بۆتان دەردەکەوێت.“»
\p 
\v 5 ئەوەی موسا فەرمانی پێ کردبوو بردیانە پێش چادری چاوپێکەوتن و هەموو کۆمەڵەکە چوونە پێشەوە و لەبەردەم یەزدان وەستان.
\v 6 موسا گوتی: «یەزدان فەرمانی ئەمەی داوە، دەیکەن، ئینجا شکۆمەندی یەزدانتان بۆ دەردەکەوێت.»
\p 
\v 7 پاشان موسا بە هارونی گوت: «بڕۆ پێشەوە بۆ لای قوربانگاکە و قوربانی گوناهت و قوربانی سووتاندنەکەت بکە و کەفارەت بۆ خۆت و گەل بکە و قوربانی گەل بکە و کەفارەتیان بۆ بکە، هەروەک یەزدان فەرمانی دا.»
\p 
\v 8 ئیتر هارون چووە پێشەوە بۆ لای قوربانگەکە و جوانەگاکەی قوربانی گوناهی سەربڕی کە بۆ خۆی بوو.
\v 9 کوڕەکانی هارونیش خوێنەکەیان بۆ هێنا و ئەویش پەنجەی کردە ناو خوێنەکە و لەسەری قۆچەکانی قوربانگاکەی دا و خوێنەکەی ڕشتە بنکەی قوربانگاکە.
\v 10 پیوەکە و گورچیلەکان و ئەو پیوەی لەسەر جگەری قوربانییەکەی گوناه بوو لەسەر قوربانگاکە سووتاندی، هەروەک یەزدان فەرمانی بە موسا کرد،
\v 11 بەڵام کەلاک و پێستەکەی لە دەرەوەی ئۆردوگاکە سووتاند.
\p 
\v 12 ئینجا قوربانی سووتاندنەکەی سەربڕی و کوڕەکانی هارون خوێنەکەیان دایێ، ئەویش بەسەر هەموو لایەکی قوربانگاکەدا پرژاندی.
\v 13 پاشان قوربانی سووتاندنەکەی ئەوانی دایێ بە پارچەکانی و سەرەکەیەوە، ئەویش لەسەر قوربانگاکە سووتاندی.
\v 14 هەناو و قاچەکانیشی شوشت و لەسەر قوربانی سووتاندنەکە لەسەر قوربانگاکە سووتاندی.
\p 
\v 15 ئینجا هارون قوربانییەکەی گەلی پێشکەش کرد، گیسکەکەی برد کە قوربانی بوو بۆ گوناهی گەل، سەری بڕی و بۆ گوناه کردی وەک ئەوەی یەکەم.
\p 
\v 16 هارون بەپێی ڕێوڕەسم قوربانی سووتاندنەکەی پێشکەش کرد.
\v 17 هەروەها پێشکەشکراوەکەی دانەوێڵەی هێنا و مستی لێ پڕکرد و لەسەر قوربانگاکە سووتاندی، بێجگە لە قوربانی سووتاندنی بەیانی.
\p 
\v 18 گایەکە و بەرانەکەی سەربڕی، قوربانی هاوبەشی کە بۆ گەلە و کوڕەکانی هارون خوێنەکەیان پێیدا، ئەویش بەسەر هەموو لایەکی قوربانگاکەدا پرژاندی.
\v 19 هەروەها پیوەکە لە گایەکە و دوگەکە لە بەرانەکە، ئەو پیوەش کە هەناو دادەپۆشێت و گورچیلەکان و ئەو پیوەی لەسەر جگەرە،
\v 20 ئەم پیوانەیان خستە سەر دوو سنگەکە. ئینجا هارون پیوەکەی لەسەر قوربانگاکە سووتاند،
\v 21 بەڵام هەروەک موسا فەرمانی دا، بۆ قوربانی بەرزکردنەوە لەبەردەم یەزدان، دوو سنگەکە و ڕانی ڕاستی بەرز کردەوە.
\p 
\v 22 ئینجا هارون دەستی بەرەو گەل بەرزکردەوە و داوای بەرەکەتی بۆ کردن و لە پێشکەشکردنی قوربانی گوناه و قوربانی سووتاندن و قوربانی هاوبەشی، هاتە خوارەوە.
\p 
\v 23 ئینجا موسا و هارون چوونە ناو چادری چاوپێکەوتن و پاشان هاتنە دەرەوە و داوای بەرەکەتیان بۆ گەل کرد. ئیتر شکۆمەندی یەزدان بۆ هەموو گەل دەرکەوت.
\v 24 ئاگرێک لەلایەن یەزدانەوە کڵپەی کرد، هات و لەسەر قوربانگاکە قوربانی سووتاندنەکە و پیوەکەی سووتاند. هەموو گەلیش بینییان و هاواریان کرد و بەسەر ڕوویاندا کەوتن.
\c 10
\s1 مردنی ناداب و ئەبیهو
\p 
\v 1 دوو کوڕی هارون، ناداب و ئەبیهو، هەریەکە و بخووردانەکەی خۆی برد و ئاگریان تێدا کردەوە و بخووریان بەسەردا کرد. لەبەردەم یەزدان ئاگرێکی نامۆیان پێشکەش کرد، کە ئەو فەرمانی پێیان نەدابوو.
\v 2 ئیتر ئاگرێک لەلایەن یەزدانەوە کڵپەی کرد، هات و ئەوانی هەڵلووشی و لەبەردەم یەزدان مردن.
\v 3 موساش بە هارونی گوت: «ئەمە بوو مەبەستی یەزدان کاتێک فەرمووی:
\q1 «”لەنێو ئەوانەی لێم نزیک دەبنەوە
\q2 پیرۆزی خۆم دەردەخەم و
\q1 لەبەردەم هەموو گەل
\q2 شکۆدار دەبم.“»
\m هارون بێدەنگ بوو.
\p 
\v 4 موسا بانگی میشائیل و ئەلسافانی کرد، دوو کوڕەکەی عوزیێلی مامی هارون و پێی گوتن: «وەرنە پێش، ئامۆزاکانتان لەبەردەم پیرۆزگا هەڵبگرن بۆ دەرەوەی ئۆردوگاکە.»
\v 5 ئەوانیش هاتنە پێش و بە کراسەکانیان هەڵیانگرتن بۆ دەرەوەی ئۆردوگاکە، هەروەک موسا گوتی.
\p 
\v 6 هەروەها موسا بە هارون و ئەلعازار و ئیتاماری کوڕەکانی هارونی گوت: «سەرتان ڕووت مەکەن و جلەکانتان مەدڕێنن، نەوەک بمرن و تووڕەیی یەزدان بێتە سەر هەموو کۆمەڵ. بەڵام کەسوکارتان، هەموو بنەماڵەی ئیسرائیل بۆ ئەوانە بگریێنن کە یەزدان بە ئاگر لەناوی بردوون.
\v 7 لە دەروازەی چادری چاوپێکەوتنیش دەرمەچن، نەوەک بمرن، چونکە زەیتی دەستنیشانکردنی یەزدان لەسەرتانە.» ئەوانیش بەگوێرەی قسەکەی موسایان کرد.
\p 
\v 8 هەروەها یەزدان بە هارونی فەرموو:
\v 9 «شەراب و مەی مەخۆرەوە، خۆت و کوڕەکانیشت، لە کاتی چوونە ژوورەوەتان بۆ ناو چادری چاوپێکەوتن، نەوەک بمرن. ئەمە فەرزێکی هەتاهەتاییە نەوە دوای نەوە،
\v 10 بۆ ئەوەی بتوانن لەنێوان پیرۆز و پیرۆزنەکراو و لەنێوان پاک و گڵاو جیاکاری بکەن،
\v 11 هەروەها بۆ ئەوەی نەوەی ئیسرائیل دەربارەی هەموو فەرزەکان فێر بکەن کە یەزدان لە ڕێگەی موساوە لەگەڵیاندا دوا.»
\p 
\v 12 موساش بە هارونی برای و دوو کوڕەکەی هارون، ئەلعازار و ئیتامار کە مابوونەوە گوتی: «ئەو پێشکەشکراوە دانەوێڵەیەی لە قوربانییە بە ئاگرەکانی بۆ یەزدان ماوەتەوە، بیبەن و لەتەنیشت قوربانگاکە بەبێ هەویرترش بیخۆن، چونکە هەرەپیرۆزە.
\v 13 لە شوێنێکی پیرۆز بیخۆن، چونکە بەشی تۆ و بەشی کوڕەکانتە لە قوربانییە بە ئاگرەکانی بۆ یەزدان، چونکە من بەو شێوەیە فەرمانم داوە.
\v 14 بەڵام سنگی بەرزکراوە و ڕانی پێشکەشکراو لە شوێنێکی پاک دەخۆن، خۆت و کوڕەکانت و کچەکانت، چونکە کراون بە بەشی تۆ و بەشی کوڕەکانت لە قوربانییەکانی هاوبەشی نەوەی ئیسرائیل.
\v 15 ڕانی پێشکەشکراو و سنگی بەرزکراوە لەگەڵ پیوەکانی قوربانی بە ئاگر دەهێنن، هەتا لەبەردەم یەزدان وەک قوربانی بەرزکردنەوە بەرز بکرێنەوە. ئەمانە بۆ تۆ و بۆ کوڕەکانت دەبن کە لەگەڵتدان، بەشێکی چەسپاوە، هەروەک یەزدان فەرمانی دا.»
\p 
\v 16 کاتێک موسا داوای گیسکەکەی قوربانی گوناهی کرد و بۆی دەرکەوت کە سووتێنراوە، لە ئەلعازار و ئیتامار کە دوو کوڕەکەی هارون بوون و مابوونەوە، تووڕە بوو و گوتی:
\v 17 «بۆچی قوربانییەکەی گوناهتان لە پیرۆزگادا نەخوارد؟ بێگومان کە هەرەپیرۆزە و پێتان دراوە بۆ ئەوەی تاوانی کۆمەڵەکە هەڵبگرن بۆ کەفارەت بۆیان لەبەردەم یەزدان،
\v 18 لەو کاتەوە خوێنەکەی بۆ ژوورەوەی شوێنی پیرۆز نەهێنرا، بێگومان دەبووایە لە پیرۆزگا بیخۆن، هەروەک فەرمانم داوە.»
\p 
\v 19 هارون وەڵامی موسای دایەوە: «ئەوان ئەمڕۆ قوربانی گوناهە و قوربانی سووتاندنیان لەبەردەم یەزدان پێشکەش کرد و شتێکی وام تووش بوو. ئەگەر ئەمڕۆ من لە قوربانی گوناهم بخواردایە، ئایا لەبەرچاوی یەزدان ئەمە پەسەند دەبوو؟»
\v 20 کە موسا گوێی لەمە بوو، لەبەرچاوی پەسەند بوو.
\c 11
\s1 ئاژەڵە پاکەکان و ئاژەڵە ناپاکەکان
\p 
\v 1 هەروەها یەزدان لەگەڵ موسا و هارون دوا و پێی فەرموون:
\v 2 «لەگەڵ نەوەی ئیسرائیل بدوێن و بڵێن: ”ئەوانە ئەو گیانلەبەرانەن کە دەیانخۆن، لە هەموو ئاژەڵەکانی سەر زەوی:
\v 3 هەر ئاژەڵێک کە سمی دوو کەرت بێت و کاوێژ بکات، ئەوە دەخۆن.
\p 
\v 4 «”لەوانەی تەنها کاوێژ دەکەن یان تەنها سمیان دوو کەرتە، ئەمانە ناخۆن: وشتر، چونکە کاوێژ دەکات بەڵام سمی دوو کەرت نییە، بۆیە گڵاوە بۆتان؛
\v 5 هەروەها گۆڕهەڵکەنە، چونکە کاوێژ دەکات، بەڵام سمی کەرت نییە، گڵاوە بۆتان؛
\v 6 کەروێشک، چونکە کاوێژ دەکات بەڵام سمی دوو کەرت نییە، بۆیە گڵاوە بۆتان؛
\v 7 بەراز، چونکە سمی کەرت کراوە، بەڵام کاوێژ ناکات، بۆیە گڵاوە بۆتان.
\v 8 نە گۆشتیان بخۆن و نە دەست لە کەلاکیان بدەن، چونکە گڵاوە بۆتان.
\p 
\v 9 «”لە هەموو ئەوانەی لەناو ئاوەکانیشن ئەمانە دەخۆن، هەموو ئەوانەی باڵ و پوولەکەیان هەبێت لەناو ئاوەکان، لەناو دەریاکان و لەناو ڕووبارەکان، ئەوانە دەخۆن.
\v 10 بەڵام هەموو ئەوەی باڵ و پوولەکەی نەبێت لەناو دەریاکان و ڕووبارەکان، لە هەموو خشۆکەکانی ناو ئاوەکان و هەموو زیندەوەرێکی ناو ئاوەکان، قێزەونە بۆتان.
\v 11 بۆتان قێزەون دەبێت، لە گۆشتەکەی ناخۆن و قێزتان لە کەلاکەکەی دەبێتەوە.
\v 12 هەموو ئەوەی باڵ و پوولەکەی نەبێت لەناو ئاوەکان، بۆتان قێزەونە.
\p 
\v 13 «”لە باڵندەکانیش، قێزتان لەمانە دەبێتەوە، ناخورێن، قێزەونن، هەڵۆ و سیسارکە کەچەڵ و داڵاش،
\v 14 واشەی سوور و هەموو جۆرەکانی واشەی ڕەش،
\v 15 هەموو جۆرەکانی قەلەڕەش،
\v 16 کوندەپەپووی شاخدار و بایەقووش\f + \fr 11:16 \ft بایەقووش: جۆرێکە لە کوندەپەپوو.‏\f*، مەلی دەریا، هەموو جۆرەکانی باز،
\v 17 کوندەپەپووی بچووک، مەلی ماسیگرە، کوندەپەپووی گەورە،
\v 18 کوندەپەپووی سپی و کوندەپەپووی بیابان، واشەی ماسیگر،
\v 19 لەقلەق و هەموو جۆرەکانی شاهۆ و پەپوسڵێمانکە و شەمشەمەکوێرە.
\p 
\v 20 «”هەموو مێرووێکی باڵدار کە لەسەر چوار پێ بڕوات بۆ ئێوە قێزەونە.
\v 21 لەنێو هەموو مێرووێکی باڵدار کە لەسەر چوار پێ دەڕوات تەنها ئەمانە دەخۆن، ئەوەی دوو لاقی نوشتاوەی هەیە لەسەر قاچەکانی و پێیان هەڵدەبەزێتەوە لەسەر زەوی،
\v 22 ئەمە بە هەموو جۆرەکانییەوە دەخۆن: کوللە و سۆلام\f + \fr 11:22 \ft سۆلام: باڵدارێکی بچووکی ڕەنگ سەوزە، وەک بێوکە لە شەودا چالاکە و لە ڕۆژدا بەهۆی لێکچوونی لەگەڵ گەڵا، لەژێر گەڵاکاندا خۆی حەشار دەدات.‏\f* و بێوکە\f + \fr 11:22 \ft بێوکە: لە شێوەی کوللەیە و بچووکە، لە شوێنی شێدار دەژیێت، ئێواران زیکەزیک دەکات.‏\f* و پێکوڕە.
\v 23 بەڵام ئەوانی دیکە هەر مێرووێکی باڵدار کە چوارپێی هەبێت قێزەونە بۆتان.
\p 
\v 24 «”بەمانە گڵاو دەبن، هەرکەسێک دەست لە کەلاکیان بدات یان بەر کەلاکیان بکەوێت، ئەوا هەتا ئێوارە گڵاو دەبێت،
\v 25 هەر یەکێک کەلاکیان هەڵبگرێت، دەبێت جلەکانی بشوات و هەتا ئێوارە گڵاو دەبێت.
\p 
\v 26 «”هەموو ئەو ئاژەڵانەش کە سمیان بە تەواوی شەق نەبێت، یان کاوێژ نەکات، ئەوا گڵاوە بۆتان و هەرکەسێک دەست لە کەلاکی هەر یەکێکیان بدات یان بەر کەلاکی هەر یەکێکیان بکەوێت ئەوا گڵاو دەبێت.
\v 27 هەر ئاژەڵێکیش لە چوار پێیەکان کە لەسەر ناولەپی بڕوات، گڵاوە بۆتان و هەرکەسێک دەست لە کەلاکیان بدات یان بەر کەلاکیان بکەوێت، هەتا ئێوارە گڵاو دەبێت،
\v 28 هەرکەسێک کەلاکیان هەڵبگرێت، دەبێت جلەکانی بشوات و هەتا ئێوارە گڵاو دەبێت، ئەوە گڵاوە بۆتان.
\p 
\v 29 «”ئەمەش گڵاوە بۆتان لەوانەی لەسەر زەوی دەخشێن، ڕاسۆ\f + \fr 11:29 \ft ڕاسۆ یان مشکی خورما: گیاندارێکی گۆشتخۆری درێژکۆڵەی قاچ کورتی کلک تووکن و درێژە.‏\f*، جرج\f + \fr 11:29 \ft یان جورج.‏\f*، مارمێلکە بە هەموو جۆرەکانییەوە،
\v 30 قومقمۆکە، بزنمژ، شەوگەرد، مارمێلکەی خشۆک و کامیلۆن.
\v 31 ئەمانە گڵاوەکانن بۆتان لە هەموو خشۆکەکان، هەرکەسێک دەستیان لێ بدات یان بەریان بکەوێت دوای مرداربوونیان، ئەوا هەتا ئێوارە گڵاو دەبێت.
\v 32 هەر شتێکیش یەکێک لەوانەی کەوتە سەری کە مردبوو، ئەو شتە گڵاو دەبێت، لە هەر شتێک، دار بێت یان قوماش یان پێست یان گوش\f + \fr 11:32 \ft ڕیشاڵی ڕووەک بۆ دروستکردنی گوش و گونییە بەکارهاتووە، کە لەو سەردەمە بەرگی ماتەمی لێ دروستدەکرا.‏\f*، هەر شتێک کە کاری پێ بکرێت، دەخرێتە ناو ئاوەوە و هەتا ئێوارە گڵاو دەبێت و پاشان پاک دەبێتەوە.
\v 33 هەر دەفرێکی\f + \fr 11:33 \ft جام یان دەوری بۆ پێداویستی خواردن.‏\f* گڵینیش ئەمانەی بکەوێتە ناوی، هەرچی تێیدایە گڵاو دەبێت و دەفرەکەش دەشکێنن.
\v 34 هەر خواردنێکیش کە بخورێت، لەو دەفرەیە ئاوی بەسەردا بکرێت، گڵاو دەبێت. هەر خواردنەوەیەکیش کە لەو دەفرەیە بخورێتەوە، گڵاو دەبێت.
\v 35 هەر شتێک کەلاکی یەکێک لەوانەی تێبکەوێت، گڵاو دەبێت، ئەگەر تەنوور بێت یان ئاگردان، دەبێت تێکبدرێت، ئەوە گڵاوە و بۆ ئێوە گڵاو دەبێت.
\v 36 تەنها کانی و ئەمباراو کە ئاویان تێدا کۆدەبێتەوە، ئەوان پاک دەبن، بەڵام هەرکەسێک دەست لە کەلاکی هەر یەکێکیان بدات یان بەر کەلاکی هەر یەکێکیان بکەوێت، ئەوا گڵاو دەبێت.
\v 37 ئەگەر کەلاکی یەکێکیان کەوتە سەر هەر تۆوێک کە بچێنرێت، ئەوا تۆوەکە پاکە،
\v 38 بەڵام ئەگەر ئاو لەسەر تۆوەکە هەبوو و کەلاکی یەکێکیانی کەوتە سەر، گڵاوە بۆتان.
\p 
\v 39 «”ئەگەر یەکێک لەو ئاژەڵانەی کە خواردنە بۆتان مرد، هەرکەسێک دەست لە کەلاکی بدات یان بەر کەلاکی بکەوێت، ئەوا هەتا ئێوارە گڵاو دەبێت.
\v 40 هەر یەکێکیش لە کەلاکەکەی بخوات، ئەوا جلەکانی دەشوات و هەتا ئێوارە گڵاو دەبێت، هەر یەکێکیش کەلاکەکەی هەڵبگرێت، ئەوا جلەکانی دەشوات و هەتا ئێوارە گڵاو دەبێت.
\p 
\v 41 «”هەموو خشۆکێکیش کە لەسەر زەوی دەخشێت، ئەوە قێزەونە و ناخورێت.
\v 42 هەرچی لەسەر سکی بڕوات و هەرچی لەسەر چوارپێ بڕوات لەگەڵ هەموو ئەوەی پێی زیاترە، لە هەموو خشۆکەکان کە لەسەر زەوی دەخشێن مەیخۆن، چونکە قێزەونە بۆتان.
\v 43 خۆتان پیس مەکەن بە خشۆکێک کە دەخشێت، خۆتانی پێ گڵاو مەکەن و پێی گڵاو مەبن.
\v 44 من یەزدانی پەروەردگارتانم، خۆتان تەرخان بکەن و پیرۆز بن، چونکە من پیرۆزم. خۆتان بە خشۆکێک کە لەسەر زەوی دەخشێت گڵاو مەکەن.
\v 45 من یەزدانم ئەوەی کە لە خاکی میسرەوە دەریهێنان بۆ ئەوەی ببێتە خوداتان، کەواتە پیرۆز بن، چونکە من پیرۆزم.
\p 
\v 46 «”ئەمانە ڕێنماییەکانن دەربارەی ئاژەڵ و باڵندەکان و هەموو گیانلەبەرێک کە لەناو ئاو دەجوڵێت و هەموو گیانێک کە لەسەر زەوی دەخشێت.
\v 47 پێویستە گڵاو و پاک و ئەو زیندەوەرانەی دەخورێن و ئەو زیندەوەرانەی ناخورێن لێک جیا بکەنەوە.“»
\c 12
\s1 پاکبوونەوەی ژنان لەدوای منداڵبوون
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «لەگەڵ نەوەی ئیسرائیل بدوێ و بڵێ: ”ئەگەر ژنێک سکی پڕ بوو و کوڕێکی بوو، ئەوا بەپێی ڕێوڕەسم بۆ حەوت ڕۆژ گڵاو\f + \fr 12:2 \ft لە پەیمانی کۆن خوێن بە پیرۆز هەژمارد کراوە، بەڵام کاتێک ئافرەت دەکەوتە سووڕی مانگانە و خوێنی لێ دەرچوو، ئەو ماوەیە ئافرەتەکە بە گڵاو هەژمارد دەکرا. خۆشبەختانە لە پەیمانی نوێ بەهۆی عیسای مەسیحەوە بە پاک دادەنرێت. بڕوانە \xt مەرقۆس 7‏:17‏-23.‏\xt*\ft ‏\f* دەبێت، هەروەک لە ڕۆژانی خوێنلێچوونی مانگانەی گڵاو دەبێت.
\v 3 لە ڕۆژی هەشتەمدا کۆرپەکە خەتەنە دەکرێت،
\v 4 ئینجا دایکەکە سی و سێ ڕۆژی دیکە دەمێنێتەوە هەتا لە خوێن لێچوونەکەی پاک ببێتەوە، بەر هیچ شتێکی پیرۆز ناکەوێت و بۆ پیرۆزگا ناچێت، هەتا ڕۆژانی پاکبوونەوەی تەواو دەبێت.
\v 5 ئەگەر کچی بوو، ئەوا دوو هەفتە پاک نابێت، هەروەک لە خوێنلێچوونی بێت، ئینجا شەست و شەش ڕۆژی دیکە دەمێنێتەوە، هەتا لە زەیستانییەکەی\f + \fr 12:5 \ft زەیستانی: منداڵبوون نابێتە هۆی گڵاوی، بەڵام مەبەستی پاکبوونەوەیە لە خوێنی زەیستانی.‏\f* پاک ببێتەوە.
\p 
\v 6 «”کاتێک ڕۆژانی پاکبوونەوەی\f + \fr 12:6 \ft مریەم لە کاتی لەدایکبوونی عیسا ئەم نەریتەی جێبەجێ کرد، بڕوانە \xt لۆقا 2‏:22‏-24.‏\xt*\ft ‏\f* تەواو بوو، ئەگەر کوڕی بووبێت یان کچ، ئەوا بەرخێکی یەک ساڵە وەک قوربانی سووتاندن و بێچووە کۆترێک یان کوکوختییەک وەک قوربانی گوناه\f + \fr 12:6 \ft قوربانی گوناه: پێشکەشکردنی قوربانی لە پێناو گوناه یاخود تاوان، کاریگەری هەیە لەسەر دووبارە گەڕاندنەوەی مرۆڤ بۆ ناو ژیانی خواپەرستی.‏\f* دەهێنێتە بەر دەروازەی چادری چاوپێکەوتن بۆ کاهینەکە.
\v 7 ئەویش لەبەردەم یەزدان پێشکەشی دەکات و کەفارەتی بۆ دەکات، ئینجا بەپێی ڕێوڕەسم لە خوێن لێچوونەکەی پاک دەبێتەوە.\f + \fr 12:7 \ft لە زمان و کەلتوری عیبری خوێن هێمای ژیانە، ژیانیش لەلایەن یەزدانەوە پیرۆزکراوە کە بەخشیویەتی. لەبەر ئەو هۆکارە بووە کە جولەکەکان ڕێگەیان نەدابوو بە خواردنی گۆشت کە خوێنی تێدابێت. (\xt پەیدابوون 9‏:4‏\xt*\ft ‏) هەموو لێچوونێکی خوێنیش پێویست بوو بە باشترین شێوە هەڵسوکەوتی لەگەڵ بکرێت. لەبەر ئەوە کوشتار و خوێنڕشتن بە کۆتایی پێهێنانی ژیان زانراوە، بۆیە لەلایەن یەزدانەوە پێویستی بە لێپرسینەوە هەیە (\xt پەیدابوون 9‏:5‏\xt*\ft ‏).‏\f*
\p «”ئەوە ڕێنماییە بۆ ئەو ژنەی کوڕ یان کچی دەبێت.
\v 8 بەڵام ئەگەر دەستکورت بوو بەرخێک بهێنێت، ئەوا دوو کوکوختی یان دوو بێچووە کۆتر، یەکێکیان بۆ قوربانی سووتاندن و ئەوی دیکە بۆ قوربانی گوناه، بەم شێوەیە کاهینەکە کەفارەتی بۆ دەکات و پاک دەبێتەوە.“»
\c 13
\s1 ڕێنمایی دەربارەی نەخۆشی پێست
\p 
\v 1 هەروەها یەزدان بە موسا و هارونی فەرموو:
\v 2 «ئەگەر کەسێک ئاوسانێک، یان لیرێک یان لەکەیەکی بریقەدار لەسەر پێستی لەشی هەبوو، کە گومانی نەخۆشی گواستراوەی پێستی\f + \fr 13:2 \ft نەخۆشی گواستراوەی پێست: لە زمانی عیبری بە واتای گەڕوگولی و چەند نەخۆشییەکی جیاوازی پێست دێت.‏\f* لێ بکرێت، ئەوا ئەو کەسە دەهێنرێتە لای هارونی کاهین، یان یەکێک لە کوڕە کاهینەکانی.
\v 3 ئەگەر کاهینەکە پشکنی زامەکە لە پێستی لەشە و ئەو مووانەی لەناو زامەکەن سپین و زامەکە لە پێستی لەش قووڵترە، ئەوە نەخۆشی گواستراوەی پێستە. کاتێک کاهینەکە پشکنی، بەپێی ڕێوڕەسم ڕایدەگەیەنێت کە گڵاوە.
\v 4 بەڵام ئەگەر لەکەیەکی بریقەداری سپی بوو لە پێستی لەش و لە پێست قووڵتر نەبوو و ئەو مووانەی لەناو لەکەکەن سپی نەببوون، ئەوا کاهینەکە کەسی تووشبوو حەوت ڕۆژ لە خەڵک جیا دەکاتەوە.
\v 5 ئەگەر کاهینەکە لە ڕۆژی حەوتەم پشکنینی بۆ ئەنجام دا و بینی زامەکە وەک خۆیەتی و لە پێستی تەشەنەی نەکردووە، ئەوا کاهینەکە حەوت ڕۆژی دیکەش جیای دەکاتەوە.
\v 6 ئەگەر کاهینەکە دووبارە لە ڕۆژی حەوتەم پشکنینی بۆ ئەنجام دا و بینییەوە زامەکە کاڵ بووەتەوە و لە پێستی تەشەنەی نەکردووە، ئەوا کاهینەکە ڕایدەگەیەنێت کە پاکە، واتا ئەوە لیرە. ئەو کەسە جلەکانی دەشوات و پاک دەبێت.
\v 7 بەڵام ئەگەر لیرەکە لە پێستی تەشەنەی کرد لەدوای ئەوەی پیشانی کاهینەکە درا بۆ پاککردنەوەی، دەبێت دیسان پیشانی کاهینەکە بدرێتەوە.
\v 8 ئەگەر کاهینەکە پشکنی لیرەکە لە پێستی تەشەنەی کردووە، ئەوا کاهینەکە ڕایدەگەیەنێت کە ئەو کەسە گڵاو بووە، ئەوە نەخۆشییەکی گواستراوەیە.
\p 
\v 9 «ئەگەر کەسێک نەخۆشی گواستراوەی پێستی هەبێت، ئەوا دەهێنرێتە لای کاهین.
\v 10 ئەگەر کاهینەکە پشکنینی بۆ ئەنجام دا و بینی ئاوسانێکی سپی لە پێست هەیە و مووی سپی کردووە و لە شوێنی ئاوسانەکە گۆشتی ڕووت بە دەرەوەیە،
\v 11 ئەوا نەخۆشی پێستی درێژخایەنە لە پێستی لەشی، ئیتر کاهینەکە ڕایدەگەیەنێت کە گڵاوە، دوورەپەرێزی ناکات، چونکە گڵاوە.
\p 
\v 12 «بەڵام ئەگەر نەخۆشییەکە تەشەنەی کردبێت و هەموو پێستی داگرتبوو، لە سەرییەوە هەتا پێیەکانی، بەگوێرەی هەموو ئەوەی چاوی کاهینەکە دەیبینێت،
\v 13 کاهینەکە پشکنینی بۆ ئەنجام دا و بینی وا نەخۆشییەکە هەموو لەشی داگرتووە، ئەوا ڕایدەگەیەنێت کە تووشبووەکە پاکە، لەو کاتەوە هەمووی سپی بووە، ئەوە پاکە.
\v 14 بەڵام هەر کاتێک گۆشتی ڕووتی تێدا بینی، ئەوا گڵاو دەبێت.
\v 15 کاتێک کاهینەکە گۆشتە ڕووتەکەی بینی، ڕایدەگەیەنێت کە گڵاوە. گۆشتی ڕووت گڵاوە، ئەوا کەسەکە نەخۆشییەکی گواستراوەی هەیە.
\v 16 ئەگەر گۆشتە ڕووتەکە جارێکی دیکە سپی بووبێتەوە، ئەوا دێتەوە لای کاهینەکە.
\v 17 ئینجا کە کاهینەکە پشکنی وا شوێنە تووشبووەکە سپی بووە، کاهینەکە ڕایدەگەیەنێت کە تووشبووەکە پاکە، ئەوا کەسەکە پاکە.
\p 
\v 18 «ئەگەر کەسێک لە پێستەکەی دومەڵێک بووبێت و چاک بووبێتەوە،
\v 19 لە شوێنی دومەڵەکەش ئاوسانێکی سپی یان لەکەیەکی بریقەداری سپی سوورباو هەبێت، ئەوا پیشانی کاهینەکە دەدرێت.
\v 20 ئەگەر کاهینەکە پشکنی لە پێست قووڵترە و مووەکانی سپی بووە، ئەوا کاهینەکە ڕایدەگەیەنێت کە گڵاوە. ئەوە نەخۆشی گواستراوەی پێستە کە لە دومەڵەکە بڵاوبووەتەوە.
\v 21 بەڵام ئەگەر کاهینەکە پشکنی مووی سپی تێدا نییە و لە پێست قووڵتر نییە و ڕەنگی ئاساییە، ئەوا کاهینەکە حەوت ڕۆژ جیای دەکاتەوە،
\v 22 بەڵام ئەگەر لە پێست تەشەنەی کردبێت، ئەوا کاهینەکە ڕایدەگەیەنێت کە گڵاوە، ئەوە گواستراوەیە.
\v 23 بەڵام ئەگەر لەکە بریقەدارەکە لە شوێنی خۆی مایەوە و تەشەنەی نەکردووە، ئەوە شوێنەواری دومەڵەکەیە و کاهینەکە ڕایدەگەیەنێت کە پاکە.
\p 
\v 24 «ئەگەر کەسێک لە پێستیدا شوێنێکی سووتاوی بە ئاگر هەبێت، گۆشتە ڕووتەکەی شوێنە سووتاوەکە لەکەیەکی بریقەداری سپی سوورباو یان سپی هەبێت،
\v 25 کاهینەکە پشکنی وا مووی لەکە بریقەدارەکە سپی بووە و لە پێست قووڵترە، ئەوە نەخۆشییەکی گواستراوەیە و لە شوێنە سووتاوەکە بڵاوبووەتەوە. کاهینەکە ڕایدەگەیەنێت کە گڵاوە، ئەوە نەخۆشی گواستراوەی پێستە.
\v 26 بەڵام ئەگەر کاهینەکە پشکنی لە لەکە بریقەدارەکە مووی سپی نییە و لە پێست قووڵتر نییە و ڕەنگی ئاساییە، ئەوا کاهینەکە حەوت ڕۆژ جیای دەکاتەوە.
\v 27 کاهینەکە لە ڕۆژی حەوتەم دەیبینێت، ئەگەر بە پێستدا تەشەنەی کردبێت، ئەوا کاهینەکە ڕایدەگەیەنێت کە گڵاوە، ئەوە نەخۆشی گواستراوەی پێستە.
\v 28 بەڵام ئەگەر لەکە بریقەدارەکە لە شوێنی خۆی مایەوە و لە پێست تەشەنەی نەکردبێت و ڕەنگی ئاسایی بوو، ئەوا ئاوسانی سووتانەکەیە، کاهینەکە ڕایدەگەیەنێت کە پاکە، چونکە شوێنەواری سووتانەکەیە.
\p 
\v 29 «هەروەها ئەگەر ئافرەتێک یان پیاوێک زامێک لە سەری یان لە چەناگەی هەبێت،
\v 30 کاهینەکە زامەکەی پشکنی وا لە پێست قووڵترە و مووی زەردی وردی تێدایە، ئەوا کاهینەکە ڕایدەگەیەنێت کە گڵاوە، ئەوە کەچەڵییە، ئەوە نەخۆشی گواستراوەی سەر یان چەناگەیە.
\v 31 بەڵام ئەگەر کاهینەکە پشکنی تووشبوون بە کەچەڵییەکە لە پێست قووڵتر نییە، بەڵام مووی ڕەشی تێدا نییە، ئەوا کاهینەکە حەوت ڕۆژ کەسی تووشبوو جیا دەکاتەوە.
\v 32 ئەگەر کاهینەکە لە ڕۆژی حەوتەم کەچەڵییەکەی پشکنی، وا تەشەنەی نەکردووە و مووی زەردی تێدا نییە و کەچەڵییەکە لە پێست قووڵتر نییە،
\v 33 با بتاشرێت، بەڵام کەچەڵییەکە نا، کاهینەکەش حەوت ڕۆژی دیکە کەسی تووشبوو جیا دەکاتەوە.
\v 34 ئەگەر کاهینەکە لە ڕۆژی حەوتەم کەچەڵییەکەی پشکنی، وا کەچەڵییەکە لە پێستدا تەشەنەی نەکردووە و لە پێست قووڵتر نییە، ئەوا کاهینەکە ڕایدەگەیەنێت کە کەسی تووشبوو پاکە، جا جلەکانی دەشوات و پاک دەبێت.
\v 35 بەڵام ئەگەر کەچەڵییەکە لە پێستدا تەشەنەی کردبێت لەدوای ئەوەی ڕاگەیەنرا کە پاکە،
\v 36 کاهینەکەش پشکنی وا کەچەڵییەکە لە پێست تەشەنەی کردووە، ئەوا کاهینەکە لەدوای مووی زەرد ناگەڕێت، ئەوە گڵاوە.
\v 37 بەڵام ئەگەر وەک خۆی مایەوە و مووی ڕەشی تێدا ڕوا، ئەوا کەچەڵییەکە چاک بووەتەوە، ئەوە پاکە و کاهینەکە ڕایدەگەیەنێت کە پاکە.
\p 
\v 38 «ئەگەر پیاوێک یان ئافرەتێک لە پێستیدا لەکەی سپی هەبوو،
\v 39 کاهینەکەش پشکنی ئەوا لە پێستی لەشی لەکەی ڕەنگ ئاسایی سپی هەیە، ئەوە لیری بێ زیانە، لە پێستدا تەشەنەی کردووە، ئەوا کەسەکە پاکە.
\p 
\v 40 «ئەگەر کەسێک مووی سەری ڕووتایەوە، ئەوە کەچەڵە، ئەو پاکە.
\v 41 ئەگەر مووی سەری لەلای پێشەوە ڕووتایەوە، ئەوە سەر ڕووتاوە، ئەو پاکە.
\v 42 بەڵام ئەگەر لە کەچەڵییەکە یان ڕووتاوییەکە لەکەی سپی سوورباو هەبوو، ئەوا نەخۆشی گواستراوەیە و لە کەچەڵییەکەی یان ڕووتاوییەکەی تەشەنەی کردووە.
\v 43 ئەگەر کاهینەکە ئەوەی پشکنی و بینی وا ئاوساوی تووشبوونەکە سپی سوورباوە لە کەچەڵییەکەی یان لە ڕووتاوییەکەی وەک نەخۆشی گواستراوەی پێست،
\v 44 ئەوە کەسێکی نەخۆش و گڵاوە. کاهینەکەش ڕایدەگەیەنێت کە گڵاوە، سەری تووش بووە.
\p 
\v 45 «ئەو کەسە تووش بووە، جلی دڕاو لەبەر دەکات و سەری دانەپۆشراو دەبێت و سمێڵی دادەپۆشێت و هاوار دەکات: ”گڵاو! گڵاو!“
\v 46 هەموو ئەو ڕۆژانەی نەخۆشییەکەی پێوەیە گڵاو دەبێت، گڵاوە و بە تەنها دەژیێت، دەرەوەی ئۆردوگا دەبێتە جێی مانەوەی.
\s1 ڕێنمایی سەبارەت بە کەڕوولێدان
\p 
\v 47 «بەڵام ئەگەر جلوبەرگێک کەڕوو لێی دابوو، جلوبەرگی خوری یان کەتان،
\v 48 ئەوەی ڕستراو بێت یان چنراو، لە کەتان و لە خوری، یان لە چەرم\f + \fr 13:48 \ft چەرم: واتا پێستی خۆشکراو، شتومەکی لە چەرم دروستکراو.‏\f*، یان لە هەر دروستکراوێک لە چەرم،
\v 49 لێدانەکەش\f + \fr 13:49 \ft بۆ ئەو شتانەی کە کەڕووی هەڵهێناوە، واتا پیس بوون.‏\f* سەوزباو یان سوورباو بوو، لە جلەکە یان لە چەرمەکە، لە ڕستراو یان لە چنراو یان لە هەر شتێک لە چەرم بێت، ئەوە لێدانی کەڕووە، جا پیشانی کاهین دەدرێت.
\v 50 کاهینەکەش کەڕووەکە دەپشکنێت و لێدراوە تووشبووەکە حەوت ڕۆژ جیا دەکاتەوە.
\v 51 جا کە لە ڕۆژی حەوتەم لێدانەکەی پشکنی وا لە جلەکە بڵاوبووەتەوە، لە ڕستراو یان لە چنراو یان لە چەرم، لە هەموو ئەوانەی لە چەرم دروستدەکرێت بۆ بەکارهێنان، ئەوا لێدانەکە کەڕووە و زیان بەخشە، گڵاوە.
\v 52 جا جلەکە یان ڕستراوەکە یان چنراوەکە لە خوری بێت یان کەتان یان لە هەر شتێکی چەرم دەیسووتێنێت، ئەوەی لێدانەکەی تێدایە، چونکە کەڕووی زیان بەخشە بە ئاگر دەسووتێنرێ.
\p 
\v 53 «بەڵام ئەگەر کاهینەکە پشکنی وا کەڕووەکە لە جلەکە یان ڕستراوەکە یان چنراوەکە یان شتە چەرمەکە بڵاونەبووەتەوە،
\v 54 ئەوا کاهینەکە فەرمان دەدات ئەوەی لێدانەکەی تێدایە بشۆن و حەوت ڕۆژی دیکە جیای دەکاتەوە.
\v 55 ئەگەر کاهینەکە دوای شوشتنی لێدانەکە پشکنی کەڕووەکە دیمەنی نەگۆڕاوە و بڵاونەبووەتەوە، ئەوا گڵاوە. دەبێت بە ئاگر بیسووتێنیت، جا لەناوەوەی بێت یان لە دەرەوەی.
\v 56 بەڵام ئەگەر کاهینەکە پشکنی شوێنی کەڕووەکە ڕەنگی ئاساییە پاش شوشتنی، ئەوا لە جلەکە یان چەرمەکە، ڕستراوەکە یان چنراوەکە دەیدڕێنێت.
\v 57 بەڵام ئەگەر لە جلەکە، لە ڕستراوەکە یان چنراوەکە یان لە شتە چەرمەکە دەرکەوتەوە، ئەوا بڵاوبووەتەوە، ئەوەی کەڕووەکەی تێدایە بە ئاگر دەیسووتێنێت.
\v 58 بەڵام هەر جلێک، ڕستراو یان چنراو، یان شتێکی چەرم، ئەوەی دەیشۆیت و کەڕووەکەی تێدا نامێنێت، ئەوا دووبارە دەشۆردرێتەوە و پاک دەبێتەوە.»
\p 
\v 59 ئەوانە ڕێنماییەکان بوون دەربارەی کەڕوولێدان، لە جلی خوری یان لە کەتان، لە ڕستراو یان لە چنراو یان هەر شتێکی چەرم، بۆ ڕاگەیاندن کە پاکە یان گڵاوە.
\c 14
\s1 پاکبوونەوە لە نەخۆشی گواستراوەی پێست
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «ئەمانە ڕێنماییەکانن دەربارەی ڕێوڕەسمی\f + \fr 14:2 \ft ڕێوڕەسم: مەبەست لە ڕێوڕەسم یان مەراسیمی ئایینی.‏\f* پاکبوونەوە. کاتێک نەخۆشەکە دەهێنرێتە لای کاهین،
\v 3 کاهینەکەش دەچێتە دەرەوەی ئۆردوگاکە، جا ئەگەر کاهینەکە پشکنی کەسەکە چاک بووەتەوە لە نەخۆشی گواستراوەی پێست،
\v 4 کاهینەکە فەرمان دەدات کە دوو چۆلەکەی زیندووی پاک بۆ ئەو کەسەی کە پاک دەبێتەوە ببەن لەگەڵ پارچە دارێکی ئورز و بەنی سووری ئاڵ و زوفا.
\v 5 ئینجا کاهینەکە فەرمان دەدات کە یەکێک لە چۆلەکەکان لە گۆزەیەکی گڵین لەسەر ئاوێکی سازگار سەرببڕدرێت.
\v 6 بەڵام چۆلەکە زیندووەکە لەگەڵ پارچە دارە ئورزەکە و بەنە سوورە ئاڵەکە و زوفاکە دەبات و دەیانخاتە ناو خوێنی چۆلەکە سەربڕدراوەکەی سەر ئاوە سازگارەکە.
\v 7 حەوت جار بەسەر ئەو کەسەدا دەیپرژێنێت کە لە نەخۆشییە گواستراوەکە پاک دەبێتەوە و پاکی دەکاتەوە، ئینجا چۆلەکە زیندووەکە ڕووەو دەشتودەر بەڕەڵا دەکات.
\p 
\v 8 «جا ئەو کەسەی کە پاک دەبێتەوە پێویستە جلەکانی بشوات و هەموو مووی لەشی بتاشێت و بە ئاو خۆی بشوات. ئەو کاتە بەپێی ڕێوڕەسم پاک دەبێتەوە، ئینجا دێتە ناو ئۆردوگاکەوە، بەڵام حەوت ڕۆژ لە دەرەوەی چادرەکەی نیشتەجێ دەبێت.
\v 9 لە ڕۆژی حەوتەم سەری و ڕیشی و برۆکانی و هەموو مووەکانی دەتاشێت، پێویستە جلەکانیشی بشوات و خۆی بە ئاو بشوات، جا پاک دەبێتەوە.
\p 
\v 10 «ئینجا لە ڕۆژی هەشتەمدا دوو بەرخی نێری ساغ و بەرخێکی مێیەی یەک ساڵەی ساغ دەهێنێت، لەگەڵ سێ لە دەی ئێفەیەک\f + \fr 14:10 \ft نزیکەی شەش لیتر و نیو.‏\f* لە باشترین ئاردی پێشکەشکراوی دانەوێڵە کە بە زەیت شێلرابێت و هەروەها لۆگێک\f + \fr 14:10 \ft نزیکەی 0,3 لیتر.‏\f* زەیت.
\v 11 جا ئەو کاهینەی بە پاککردنەوەکە هەڵدەستێت، کەسە پاکبووەوەکە لەگەڵ قوربانی و پێشکەشکراوەکانی لەبەردەم یەزدان، لەلای دەروازەی چادری چاوپێکەوتن ڕادەگرێت.
\p 
\v 12 «ئینجا کاهینەکە یەکێک لە بەرخە نێرەکان دەبات و وەک قوربانی تاوان پێشکەشی دەکات لەگەڵ لۆگە زەیتەکە، لەبەردەم یەزدان بەرزی دەکاتەوە، وەک قوربانی بەرزکردنەوە.
\v 13 بەرخەکەش لەو شوێنە سەردەبڕێت کە قوربانی گوناه و قوربانی سووتاندنی تێدا سەردەبڕدرێت، لە پیرۆزگا، چونکە قوربانی تاوان وەک قوربانی گوناه بۆ کاهینە و هەرەپیرۆزە.
\v 14 ئینجا کاهینەکە لە خوێنی قوربانییەکەی تاوان دەبات و لە شلکەی گوێی ڕاستە و پەنجە گەورەی دەستی ڕاست و پەنجە گەورەی پێی ڕاستەی ئەو کەسەی دەدات کە پاک دەبێتەوە.
\v 15 پاشان کاهینەکە لە لۆگە زەیتەکە هەندێک دەبات و دەیکاتە ناو لەپی دەستی چەپی خۆی،
\v 16 ئینجا کاهینەکە پەنجەیەکی دەستی ڕاستی دەکاتە ناو ئەو زەیتەی ناو لەپی دەستی چەپییەتی و حەوت جار بە پەنجەی زەیتەکە لەبەردەم یەزدان دەپرژێنێت.
\v 17 ئەوەی دەمێنێتەوە لەو زەیتەی ناو لەپی دەستی، کاهینەکە لە شلکەی گوێی ڕاستە و پەنجە گەورەی دەستی ڕاست و پەنجە گەورەی پێی ڕاستی ئەو کەسەی دەدات کە پاک دەبێتەوە، لەسەر خوێنەکەی قوربانی تاوان.
\v 18 ئەوەی دەشمێنێتەوە لەو زەیتەی ناو لەپی دەستی، دەیکات بەسەر سەری ئەو کەسەی کە پاک دەبێتەوە و کاهینەکە لەبەردەم یەزدان کەفارەتی بۆ دەکات.
\p 
\v 19 «ئینجا کاهینەکە قوربانی گوناه دەکات و بۆ ئەو کەسەی کە لە گڵاوییەکەی پاک دەبێتەوە کەفارەت دەکات و پاشان قوربانی سووتاندنەکە سەردەبڕێت.
\v 20 دواتر کاهینەکە قوربانی سووتاندنەکە و پێشکەشکراوی دانەوێڵە بۆ سەر قوربانگاکە سەردەخات و کەفارەتی بۆ دەکات، جا پاک دەبێتەوە.
\p 
\v 21 «بەڵام ئەگەر هەژار و دەستکورت بوو، ئەوا یەک بەرخی نێر دەبات وەک قوربانی تاوان ڕادەوەشێنرێت، بۆ کەفارەتکردن بۆی، لەگەڵ دەیەکێکی ئێفەیەک\f + \fr 14:21 \ft نزیکەی دوو لیتر.‏\f* لە باشترین ئاردی بە زەیت شێلراو بۆ پێشکەشکراوی دانەوێڵە و لۆگێک زەیت،
\v 22 هەروەها دوو کوکوختی یان دوو بێچووە کۆتر، بەپێی توانای دەستی، جا یەکێکیان دەبێتە قوربانی گوناه و ئەوەی دیکە قوربانی سووتاندن.
\p 
\v 23 «لە ڕۆژی هەشتەمدا دەیهێنێتە لای کاهینەکە بۆ پاکبوونەوەی، بۆ لای دەروازەی چادری چاوپێکەوتن لەبەردەم یەزدان.
\v 24 جا کاهینەکە بەرخەکەی بۆ قوربانی تاوان و لۆگە زەیتەکە دەبات و لەبەردەم یەزدان بەرزی دەکاتەوە وەک قوربانی بەرزکردنەوە.
\v 25 ئینجا بەرخەکە بۆ قوربانی تاوان سەردەبڕێت و کاهینەکە لە خوێنی قوربانییەکەی تاوان لە شلکەی گوێی ڕاستە و پەنجە گەورەی دەستی ڕاست و پەنجە گەورەی پێی ڕاستی ئەو کەسەی دەدات کە پاک دەبێتەوە.
\v 26 ئینجا کاهینەکە هەندێک لە زەیتەکە لەناو لەپی دەستی چەپی خۆی دەکات،
\v 27 کاهینەکە بە پەنجەیەکی دەستی ڕاستی لەو زەیتەی لە لەپی دەستی چەپیدایە حەوت جار لەبەردەم یەزدان دەیپرژێنێت.
\v 28 هەروەها کاهینەکە لەو زەیتەی لەناو لەپیەتی، لە شلکەی گوێی ڕاست و پەنجە گەورەی دەستی ڕاست و پەنجە گەورەی پێی ڕاستی ئەو کەسەی دەدات کە پاک دەبێتەوە، لە شوێنی خوێنەکەی قوربانی تاوان.
\v 29 ئەوەی دەمێنێتەوە لەو زەیتەی ناو لەپی کاهینەکە، بەسەر سەری ئەو کەسەی دادەکات کە پاک دەبێتەوە بۆ کەفارەتکردن بۆی لەبەردەم یەزدان.
\v 30 ئینجا یەکێک لە دوو کوکوختییەکە یان یەکێک لە دوو بێچووە کۆترەکان، ئەوەی لە توانای دەستییەتی،
\v 31 یەکێکیان دەکاتە قوربانی گوناه و ئەوی دیکە قوربانی سووتاندن لەگەڵ پێشکەشکراوەکەی دانەوێڵە، کاهینەکە لەبەردەم یەزدان کەفارەت بۆ ئەو کەسە دەکات کە پاک دەبێتەوە.»
\p 
\v 32 ئەوە ڕێنماییە بۆ ئەو کەسەی نەخۆشی گواستراوەی پێستی هەبێت، ئەوەی دەستکورت بێت بۆ پاکبوونەوەکەی.
\s1 پاکبوونەوە لە کەڕوو
\p 
\v 33 هەروەها یەزدان بە موسا و هارونی فەرموو:
\v 34 «لەو کاتەی کە دەچنە خاکی کەنعان، کە من دەتاندەمێ وەک موڵکی خۆتان، وام کرد ماڵێک لەو خاکە تووشی کەڕوو بێت،
\v 35 ئەوەی خاوەنی ماڵەکەیە دەچێت و بە کاهینەکە دەڵێت: ”وابزانم کەڕوو لە ماڵەکەی داوم.“
\v 36 کاهینەکەش فەرمان دەدات ماڵەکە چۆڵ بکرێت، پێش چوونە ژوورەوەی کاهینەکە بۆ پشکنینی لێدانەکە، نەوەک هەموو شتەکانی ماڵەکە گڵاو بێت، پاش ئەوە کاهینەکە بۆ پشکنینی ماڵەکە دەچێتە ژوورەوە.
\v 37 جا ئەگەر پشکنی لێدانەکە لە دیوارەکانی ماڵەکەیە و هەڵکراوێکی سەوزباو یان سوورباوە، لە دیوارەکەش قووڵترە،
\v 38 ئەوا کاهینەکە لە ماڵەکە دێتە دەرەوە و بۆ حەوت ڕۆژ ماڵەکە دادەخات.
\v 39 ئەگەر کاهینەکە لە ڕۆژی حەوتەم گەڕایەوە و پشکنی وا لێدانەکە لە دیوارەکانی ماڵەکە بڵاوبووەتەوە،
\v 40 کاهینەکە فەرمان دەدات، ئەو بەردانە دەربهێنن کە لێدانەکەی تێدایە و فڕێیانبدەنە دەرەوەی شارۆچکەکە لە شوێنێکی گڵاو.
\v 41 ماڵەکەش لە هەر چواردەوری دیوی ژوورەوە دەڕنن، ئەو خۆڵەش کە دەیڕننەوە، فڕێیدەدەنە دەرەوەی شارۆچکەکە لە شوێنێکی گڵاو.
\v 42 بەردی دیکە دەهێنن و لە شوێنی بەردەکان دایاندەنێن و خۆڵی دیکە دێنن و ماڵەکەی پێ سواخ دەدەنەوە.
\p 
\v 43 «جا ئەگەر لێدانەکە گەڕایەوە و لە ماڵەکە بڵاو بووەوە، لەدوای دەرهێنانی بەردەکان و ڕنینی ماڵەکە و سواخدانەوەی،
\v 44 کاهینەکە هات و پشکنی وا لێدانەکە لە ماڵەکەدا بڵاوبووەتەوە، ئەوا کەڕووێکی گەندەڵە لە ماڵەکە، ئەوە گڵاوە.
\v 45 جا ماڵەکە تێکدەدات، بەرد و دارەکانی و هەموو خۆڵی ماڵەکە دەباتە دەرەوەی شارۆچکەکە بۆ شوێنێکی گڵاو.
\p 
\v 46 «ئەوەی لە هەموو ڕۆژانی داخستنی ماڵەکە بچێتە ناوی، ئەوا هەتا ئێوارە گڵاو دەبێت،
\v 47 ئەوەی لە ماڵەکە خەوتبێت، ئەوا دەبێت جلەکانی بشوات و ئەوەی لە ماڵەکە نانی خواردبێت ئەوا دەبێت جلەکانی بشوات.
\p 
\v 48 «بەڵام ئەگەر کاهینەکە هات و پشکنی لێدانەکە لە ماڵەکە بڵاو نەبووەتەوە دوای سواخدانەوەکەی، ئەوا کاهینەکە ڕایدەگەیەنێت ماڵەکە پاکە، چونکە لێدانەکە نەماوە.
\v 49 بۆ پاکبوونەوەی ماڵەکە دوو چۆلەکە لەگەڵ پارچە دارێکی ئورز و بەنی سووری ئاڵ و زوفا دەبات.
\v 50 یەکێک لە چۆلەکەکان لە گۆزەیەکی گڵین سەر دەبڕێت، لەسەر ئاوێکی سازگار.
\v 51 ئینجا پارچە دارە ئورزەکە و زوفاکە و بەنە سوورە ئاڵەکە و چۆلەکە زیندووەکە دەبات و دەیخاتە ناو خوێنی چۆلەکە سەربڕدراوەکە و ئاوە سازگارەکە، حەوت جار بەسەر ماڵەکەدا دەیپرژێنێت.
\v 52 بەم شێوەیە بە خوێنی چۆلەکەکە، ئاوە سازگارەکە، چۆلەکە زیندووەکە، پارچە دارە ئورزەکە، زوفاکە و بەنە سوورە ئاڵەکە ماڵەکە پاک دەکاتەوە.
\v 53 ئینجا چۆلەکە زیندووەکە بۆ دەرەوەی شارۆچکەکە ڕووەو دەشتودەر بەڕەڵای دەکات و کەفارەت بۆ ماڵەکە دەکات، ئیتر پاک دەبێتەوە.»
\p 
\v 54 ئەوە ڕێنماییە بۆ هەموو جۆرە نەخۆشییەکی گواستراوەی پێست و کەچەڵی،
\v 55 کەڕووی جلوبەرگ و ماڵ،
\v 56 ئاوسان و لیر و لەکەی بریقەدار،
\v 57 بۆ یەکلاییکردنەوەی شتێک کە پاک بێت یان گڵاو.
\p ئەوە ڕێنماییە بۆ نەخۆشی گواستراوەی پێست و کەڕوو.
\c 15
\s1 لێچوونە گڵاوەکان
\p 
\v 1 هەروەها یەزدان بە موسا و هارونی فەرموو:
\v 2 «لەگەڵ نەوەی ئیسرائیل بدوێن و پێیان بڵێن: ”هەر پیاوێک لێچوونی هەبێت لە ئەندامی نێرینەی\f + \fr 15:2 \ft لێرەدا لێچوونەکەی لە ئەنجامی نەخۆشی گواستراوەیە.‏\f*، ئەوا لێچوونەکەی گڵاوە،
\v 3 ئەم لێچوونەشی دەبێتە هۆی گڵاوبوونی. ئەگەر ئەندامی نێرینەی لێچوونەکەی بەردەوام بێت یان ڕایگرتبوو، ئەوا گڵاوە.
\p 
\v 4 «”ئەوەی لێچوونەکەی هەیە لەسەر هەر نوێنێک ڕابکشێت، گڵاو دەبێت، لەسەر هەر شتێکیش دانیشێت، گڵاو دەبێت.
\v 5 ئەوەی دەست لە نوێنەکەی بدات، دەبێت جلەکانی بشوات و بە ئاو خۆی بشوات و هەتا ئێوارە گڵاو دەبێت،
\v 6 هەرکەسێک لەسەر شتێک دابنیشێت کە کابرای لێچوو لەسەری دانیشتبوو، دەبێت جلەکانی بشوات و بە ئاو خۆی بشوات، هەتا ئێوارەش گڵاو دەبێت.
\p 
\v 7 «”هەرکەسێک دەستی بەر لەشی کابرای لێچوو بکەوێت، دەبێت جلەکانی بشوات و خۆی بە ئاو بشوات و هەتا ئێوارە گڵاو دەبێت.
\p 
\v 8 «”ئەگەر کابرای لێچوو تفی لە یەکێکی پاک کرد، دەبێت ئەو کەسەی کە پێشتر پاک بووە جلەکانی بشوات و بە ئاو خۆی بشوات و هەتا ئێوارەش گڵاو دەبێت.
\p 
\v 9 «”لە کاتی سواریدا زینەکەی ژێری گڵاو دەبێت،
\v 10 هەرکەسێکیش دەستی لێ بدات، هەتا ئێوارە گڵاو دەبێت، ئەوەی هەڵیانبگرێت، دەبێت جلەکانی بشوات و بە ئاو خۆی بشوات و هەتا ئێوارەش گڵاو دەبێت.
\p 
\v 11 «”هەرکەسێکیش کابرای لێچوو دەستی لێ بدات، بێ ئەوەی دەستی بە ئاو بشوات، دەبێت جلەکانی بشوات و بە ئاو خۆی بشوات و هەتا ئێوارەش گڵاو دەبێت.
\p 
\v 12 «”هەر دەفرێکی گڵین کابرای لێچوو دەستی لێ بدات دەشکێنرێت، هەروەها هەر ئامرازێکی داریش بە ئاو دەشۆردرێت.
\p 
\v 13 «”ئەگەر کابرای لێچوو لە لێچوونەکەی پاک بووەوە، ئەوا حەوت ڕۆژی بۆ دادەنرێت بۆ پاکبوونەوەی و جلەکانی دەشوات و بە ئاوی سازگار خۆی دەشوات، جا پاک دەبێتەوە.
\v 14 جا لە ڕۆژی هەشتەمدا دوو کوکوختی یان دوو بێچووە کۆتر دەهێنێت بۆ بەردەم یەزدان بۆ لای دەروازەی چادری چاوپێکەوتن و دەیاندات بە کاهینەکە.
\v 15 کاهینەکە یەکێکیان دەکاتە قوربانی گوناه و ئەوی دیکەش قوربانی سووتاندن، کاهینەکە لەبەردەم یەزدان کەفارەتی بۆ دەکات لە لێچوونەکەی.
\p 
\v 16 «”ئەگەر پیاوێک تۆوی لێ هاتە دەرەوە، ئەوا هەموو لەشی بە ئاو دەشوات و هەتا ئێوارە گڵاو دەبێت\f + \fr 15:16 \ft گڵاو دەبێت: واتا لەش پیسبوون، بەپێی ڕێوڕەسمی ئایینی دەبێتە هۆی گڵاوبوون.‏\f*،
\v 17 هەر جلێک یان چەرمێک تۆوی بکەوێتە سەر، دەبێت بە ئاو بشۆردرێت و هەتا ئێوارە گڵاو دەبێت.
\v 18 هەروەها ئەو پیاوەی کە لەگەڵ ژنەکەی ڕابکشێت و پیاوەکە تۆوی لێچوو، ئەوا دەبێت هەردووکیان خۆیان بە ئاو بشۆن و هەتا ئێوارەش گڵاو دەبن.
\p 
\v 19 «”ئەگەر ژنێک خوێنلێچوونی\f + \fr 15:19 \ft لێرەدا باس لە خوێنلێچوونی سروشتی سووڕی مانگانەی ئافرەت دەکات و پێویستی بە کەفارەتکردن نەدەکرد لەلای کاهین.‏\f* هەبوو، ئەوا حەوت ڕۆژ لە خوێنلێچوونی مانگانەی دەمێنێتەوە و هەرکەسێک دەستی لێ بدات هەتا ئێوارە گڵاو\f + \fr 15:19 \ft لە پەیمانی کۆن خوێن بە پیرۆز هەژمارد کراوە، بەڵام کاتێک ئافرەت دەکەوتە سووڕی مانگانە و خوێنی لێ دەرچوو، ئەو ماوەیە ئافرەتەکە بە گڵاو هەژمارد دەکرا. خۆشبەختانە لە پەیمانی نوێ بەهۆی عیسای مەسیحەوە بە پاک دادەنرێت. بڕوانە \xt مەرقۆس 7‏:17‏-23.‏\xt*\ft ‏\f* دەبێت.
\p 
\v 20 «”هەموو ئەو شتەی لەسەری ڕادەکشێت یان دادەنیشێت لە کاتی خوێنلێچوونی مانگانەی، گڵاو دەبێت.
\v 21 هەرکەسێکیش دەست لە نوێنەکەی بدات، دەبێت جلەکانی بشوات و بە ئاو خۆی بشوات و هەتا ئێوارە گڵاو دەبێت.
\v 22 هەرکەسێکیش دەست لە شتێک بدات کە ئەو لەسەری دانیشتبێت، دەبێت جلەکانی بشوات و بە ئاو خۆی بشوات و هەتا ئێوارە گڵاو دەبێت؛
\v 23 ئەگەر نوێن بێت یان هەر شتێک کە لەسەری دانیشتووە، هەر کاتێک کەسێکیش دەستی لێ بدات، ئەوا هەتا ئێوارە گڵاو دەبێت.
\p 
\v 24 «”ئەگەر پیاوێکیش لەگەڵی ڕابکشێت، جا لە خوێن لێچوونەکە بەر پیاوەکە بکەوێت، ئەوا پیاوەکە حەوت ڕۆژ گڵاو دەبێت و لەسەر هەر نوێنێکیش ڕابکشێت، گڵاو دەبێت.
\p 
\v 25 «”ئەگەر ئافرەتێک ماوەیەکی درێژ خوێنی لێچوو\f + \fr 15:25 \ft لێرەدا باس لە خوێنلێچوونی ناسروشتی دەکات کە لە ئافرەتدا هەیە، بۆیە پێویستی بە کەفارەتکردن دەکرد لەلای کاهین.‏\f*، بێجگە لە کاتی خوێنلێچوونی مانگانەی، یان ئەگەر دوای کاتی خوێن لێچوونەکەی هەر بەردەوام بوو، ئەوا هەموو ڕۆژانی خوێن لێچوونەکەی وەک کاتی خوێنلێچوونی مانگانەی، گڵاو دەبێت.
\v 26 هەموو نوێنەکەش کە لەسەری ڕادەکشێت لە ڕۆژانی خوێنلێچوونی وەک نوێنی ڕۆژانی خوێنلێچوونی مانگانەیەتی، هەموو ئەو شتانەش کە لەسەری دادەنیشێت، ئەوا گڵاوە وەک گڵاوی خوێنلێچوونی مانگانەی.
\v 27 هەرکەسێکیش دەستیان لێ بدات، گڵاو دەبێت و پێویستە جلەکانی بشوات و بە ئاو خۆی بشوات و هەتا ئێوارە گڵاو دەبێت.
\p 
\v 28 «”ئەگەر لە خوێن لێچوونەکەی پاک بووەوە، ئەوا حەوت ڕۆژ دەژمێرێت، ئینجا بەپێی ڕێوڕەسم پاک دەبێتەوە،
\v 29 لە ڕۆژی هەشتەم دوو کوکوختی یان دوو بێچووە کۆتر دەبات و دەیانهێنێتە لای کاهینەکە، بۆ لای دەروازەی چادری چاوپێکەوتن.
\v 30 ئینجا کاهینەکەش یەکێکیان دەکاتە قوربانی گوناه و ئەوی دیکەش قوربانی سووتاندن. کاهینەکە لەبەردەم یەزدان کەفارەتی بۆ دەکات لە گڵاوی خوێن لێچوونەکەی.
\p 
\v 31 «”جا نەوەی ئیسرائیل جیا بکەنەوە لەو شتانەی گڵاویان دەکات، با لە گڵاویدا نەمرن و نشینگەکەم کە لەنێویاندایە گڵاوی نەکەن.“»
\p 
\v 32 ئەوە ڕێنماییە بۆ ئەمانە: ئەو پیاوەی کە لێچوونی هەبێت، ئەوەی تۆوی لێ دێتە دەرەوە و پێی گڵاو دەبێت،
\v 33 ئەو ئافرەتەی خوێنلێچوونی مانگانەی هەیە، ئەو پیاوەی یان ئەو ئافرەتەی لێچوونێکی هەیە، ئەو پیاوەش کە لەگەڵ ژنێک کە گڵاو بووبێت ڕابکشێت.
\c 16
\s1 ڕۆژی کەفارەت
\p 
\v 1 لەدوای مردنی دوو کوڕەکەی هارون، کاتێک لەبەردەم یەزدان نزیک ببوونەوە و مردبوون، یەزدان لەگەڵ موسا دوا و
\v 2 پێی فەرموو: «بە هارونی برات بڵێ با هەموو کاتێک نەیەتە ناو شوێنی هەرەپیرۆز لە پشت پەردەکەی پێش قەپاغی کەفارەتەکە\f + \fr 16:2 \ft قەپاغێکە بۆ داپۆشینی سندوقی پەیمان، لە ڕۆژی کەفارەت خوێنی قوربانی لەسەر ڕژاوە بۆ لێخوشبوونی گوناه. بڕوانە \xt دەرچوون 25‏:17‏\xt*\ft ‏.‏\f* کە لەسەر سندوقەکەیە، نەوەک بمرێت، چونکە من لە هەوردا لەسەر قەپاغی کەفارەتەکە دەبینرێم.
\p 
\v 3 «هارون بەم شێوەیە بچێتە ناو پیرۆزگاکە: جوانەگایەک بۆ قوربانی گوناه و بەرانێک بۆ قوربانی سووتاندن بهێنێت.
\v 4 کراسێکی کەتان و پیرۆز لەبەر بکات و دەرپێی کەتانی لەبەربێت و بە کەمەربەندی کەتان پشتی ببەستێت و مێزەری کەتانی لەسەر بێت، ئەوە جلوبەرگێکی پیرۆزە، خۆی بە ئاو بشوات و جلەکان لەبەر بکات.
\v 5 لە کۆمەڵی ئیسرائیلیش دوو گیسکی نێرینە\f + \fr 16:5 \ft گیسک: کارەبزن تەمەنی نزیکەی شەش مانگە.‏\f* ببات بۆ قوربانی گوناه و بەرانێک بۆ قوربانی سووتاندن.
\p 
\v 6 «هارون جوانەگاکە پێشکەش بکات بۆ قوربانی گوناهی خۆی و کەفارەت بۆ خۆی و بۆ ماڵەکەی بکات،
\v 7 ئینجا دوو گیسکە نێرینەکەش ببات و لەبەردەم یەزدان لەلای دەروازەی چادری چاوپێکەوتن ڕایانبگرێت.
\v 8 هارون تیروپشک بۆ دوو گیسکەکە بکات، یەکێکیان بۆ یەزدان و ئەوی دیکە بۆ لابردنی گوناه لەسەر کۆمەڵگا.
\v 9 ئەو گیسکەی لە تیروپشک بۆ یەزدان دەرچوو، ئەوا هارون پێشکەشی بکات و بیکاتە قوربانی گوناه.
\v 10 بەڵام ئەو گیسکەی بە تیروپشک بۆ لابردنی گوناه لەسەر کۆمەڵگا دەرچوو، ئەوا بە زیندوویی لەبەردەم یەزدان ڕایبگرێت بۆ کەفارەتکردن لەسەری، بۆ ئەوەی بۆ عەزازێلی\f + \fr 16:10 \ft عەزازێل: بە واتای (گیسکی گواستنەوە) دێت یان ناوی شەیتانێک بێت لە چۆڵەوانی.‏\f* بنێرێتە چۆڵەوانی\f + \fr 16:10 \ft بنێرێت بۆ چۆڵەوانی: وەک هێمایەک بۆ دوورکەوتنەوەی تاوان و گوناه لە کۆمەڵگا.‏\f*.
\p 
\v 11 «پێویستە هارون جوانەگاکەی قوربانی گوناه بهێنێت و سەری ببڕێت، کەفارەت بۆ خۆی و ماڵەکەی بکات.
\v 12 هارون بە پڕی بخووردانەکە پشکۆی ئاگر لەسەر قوربانگاکە لەبەردەم یەزدان ببات، بە پڕی دەستەکانیشی بخووری بۆنخۆشی باش کوتراوە ببات و بیانباتە پشت پەردەکە.
\v 13 ئەو لەبەردەم یەزدان بخوورەکە بەسەر ئاگرەکەدا بکات، هەروەها دووکەڵی بخوورەکە قەپاغەکەی کەفارەت داپۆشێت کە لەسەر سندوقی پەیمانە، ئیتر نامرێت.
\v 14 ئینجا لە خوێنی جوانەگاکە ببات و بە پەنجەی بەسەر ڕووی قەپاغەکەی کەفارەت، بەلای ڕۆژهەڵات بیپرژێنێت، لەلای پێشەوەی قەپاغەکەی کەفارەتیش، حەوت جار بە پەنجەی خوێنەکە بپرژێنێت.
\p 
\v 15 «ئینجا گیسکەکەی قوربانی گوناه کە بۆ گەل سەری ببڕێت و بە خوێنەکەیەوە بچێتە پشت پەردەکە، چی بە خوێنی جوانەگاکە کرد، ئاواش بە خوێنەکەی ئەم بکات و بەسەر قەپاغەکەی کەفارەت و لای پێشەوەی بیپرژێنێت.
\v 16 بەم شێوەیە کەفارەت بۆ شوێنی هەرەپیرۆز بکات لە گڵاوییەکانی نەوەی ئیسرائیل و لە یاخیبوون و هەموو گوناهەکانیان. بۆ چادری چاوپێکەوتنیش کە لەنێویانە ئاوا بکات، لەناوەندی گڵاوییەکانیان.
\v 17 نابێت هیچ کەسێکیش لە چادری چاوپێکەوتن بێت، لە کاتی چوونە ژوورەوەی هارون بۆ کەفارەتکردن لە شوێنی هەرەپیرۆز هەتا کاتی هاتنە دەرەوەی، کەفارەت بۆ خۆی و ماڵەکەی و هەموو کۆمەڵی ئیسرائیل بکات.
\p 
\v 18 «ئینجا بچێتە دەرەوە بۆ لای قوربانگاکەی بەردەم یەزدان و کەفارەتی بۆ بکات، لە خوێنی جوانەگاکە و خوێنی گیسکەکە ببات و بەسەر قۆچەکانی قوربانگاکەیدا بکات.
\v 19 بە پەنجەی حەوت جار لە خوێنەکە بەسەریدا بپرژێنێت و لە گڵاوییەکانی نەوەی ئیسرائیل پاکی بکاتەوە و تەرخانی بکات.
\p 
\v 20 «کاتێک هارون لە کەفارەتکردن بۆ شوێنی هەرەپیرۆز و چادری چاوپێکەوتن و قوربانگاکە تەواو بوو، گیسکە زیندووەکە پێشکەش بکات.
\v 21 هارون هەردوو دەستی لەسەر سەری گیسکە زیندووەکە دابنێت و لەسەری دان بە هەموو تاوان و هەموو یاخیبوونەکان و هەموو گوناهەکانی نەوەی ئیسرائیلدا بنێت، بەمە گوناهەکان دەخاتە سەر گیسکەکە. هارون لەژێر چاودێری ئەو کەسەی هەڵبژێردراوە بۆ ئەم ئیشە گیسکەکە بنێرێتە چۆڵەوانی.
\v 22 گیسکەکە هەموو تاوانەکانیان هەڵدەگرێت بۆ خاکێکی چۆڵ، ئینجا کەسەکە گیسکەکە لە چۆڵەوانی بەڕەڵا بکات.
\p 
\v 23 «ئینجا هارون بچێتە ناو چادری چاوپێکەوتن و جلە کەتانەکانی دابکەنێت کە لە چوونە ژوورەوەی بۆ شوێنی هەرەپیرۆز لەبەری کردبوو، لەوێ دایبنێت.
\v 24 لە شوێنێکی پیرۆز بە ئاو خۆی بشوات. ئینجا جلەکانی لەبەر بکات و بچێتە دەرەوە و قوربانی سووتاندن بۆ خۆی و قوربانی سووتاندن بۆ گەل بکات، کەفارەت بۆ خۆی و بۆ گەل بکات.
\v 25 پیوی قوربانییەکەی گوناهیش لەسەر قوربانگاکە بسووتێنێت.
\p 
\v 26 «ئەو کەسەی گیسکەکەشی بەرەو عەزازێل بەڕەڵا کرد، جلەکانی بشوات و خۆی بە ئاو بشوات، پاشان بچێتە ناو ئۆردوگاکە.
\v 27 جوانەگاکەی قوربانی گوناه و گیسکەکەی قوربانی گوناهیش، ئەوانەی خوێنەکەیان بردرا بۆ کەفارەتکردن لە شوێنی هەرەپیرۆز، ئەوا بیانباتە دەرەوەی ئۆردوگاکە و پێست و گۆشت و ڕیخۆڵەکەیان بە ئاگر بسووتێنن.
\v 28 ئەوەی دەشیانسووتێنێت، جلەکانی بشوات و خۆی بە ئاو بشوات، پاشان بچێتە ناو ئۆردوگاکە.
\p 
\v 29 «ئەمەش دەبێتە فەرزێکی هەتاهەتایی بۆتان، کە ئێوە لە دەی مانگی حەوت گیانی خۆتان زەلیل\f + \fr 16:29 \ft مەبەستی لە خۆبێبەشکردنە لە (خواردن و خواردنەوە یان جووتبوون لەگەڵ هاوسەرەکەت… هتد). لێرەدا زیاتر کات تەرخان دەکەیت بۆ نوێژکردن و پاڕانەوە. بڕوانە یەکەم نامەی پۆڵس بۆ باوەڕدارانی کۆرنسۆس 7‏:5 و \xt یۆحەنا 4‏:34‏\xt*\ft ‏.‏\f* دەکەن و هیچ کارێک ناکەن، نە هاوڵاتی و نە ئەو نامۆیەی لەنێوتانە،
\v 30 چونکە لەم ڕۆژەدا کەفارەتتان بۆ دەکرێت بۆ پاکبوونەوەتان، لە هەموو گوناهەکانتان لەبەردەم یەزدان پاک دەبنەوە.
\v 31 ئەمە شەممەیە، پشوودانە بۆتان، فەرزێکی هەتاهەتاییشە کە گیانی خۆتان زەلیل بکەن.
\v 32 ئەو کاهینەش کە بە زەیت دەستنیشان دەکرێت و ئەرکی پێ دەسپێردرێت بۆ ئەوەی لە جیاتی باوکی ببێتە سەرۆک کاهین کەفارەت بکات، جلە کەتانەکان لەبەر بکات، جلە پیرۆزەکان،
\v 33 کەفارەت بۆ شوێنی هەرەپیرۆز و چادری چاوپێکەوتن و قوربانگاکە بکات. هەروەها کەفارەت بۆ کاهینەکان و هەموو کۆمەڵی گەل بکات.
\p 
\v 34 «ئەمەش دەبێتە فەرزێکی هەتاهەتایی بۆتان بۆ کەفارەتکردن بۆ نەوەی ئیسرائیل لە هەموو گوناهەکانیان، ساڵی جارێک.»
\p ئیتر ئاوا کرا، وەک یەزدان فەرمانی بە موسا کرد.
\c 17
\s1 قوربانیکردن بەبێ ڕێوڕەسمی دیاریکراو
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «لەگەڵ هارون و کوڕەکانی و هەموو نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”ئەمە ئەو فەرمانەیە کە یەزدان فەرمانی پێدەدات و دەفەرموێت،
\v 3 هەرکەسێک لە گەلی ئیسرائیل گایەک یان بەرخێک یان گیسکێک لە ئۆردوگاکە یان لە دەرەوەی ئۆردوگاکە سەرببڕێت و
\v 4 نەیهێنێتە لای دەروازەی چادری چاوپێکەوتن هەتا لەبەردەم چادری پەرستنی یەزدان قوربانی بۆ یەزدان پێشکەش بکات، ئەوا ئەو کەسە تاوانبارە لە خوێنڕشتن، خوێنی ڕشتووە، جا دەبێت ئەو کەسە لە گەلەکەی داببڕدرێت.
\v 5 ئەمەش بۆ ئەوەی نەوەی ئیسرائیل چیتر قوربانییەکانیان لە دەشتودەر سەر نەبڕن و بیانهێنن بۆ بەردەم دەروازەی چادری چاوپێکەوتن و لەلای کاهین پێشکەشی یەزدان بکەن، وەک قوربانی هاوبەشی بۆ یەزدانیان سەرببڕن.
\v 6 کاهینەکەش خوێنەکە بەسەر قوربانگاکەی یەزداندا دەکات لەلای دەروازەی چادری چاوپێکەوتن و پیوەکەی بۆ ئەو بۆنەی یەزدان پێی خۆشە دەیسووتێنێت.
\v 7 پێویستە لەمەودوا قوربانییەکان بۆ ئەو بتانە پێشکەش نەکەن کە لە شێوەی تەگە\f + \fr 17:7 \ft نێری، سابرێن.‏\f* دروستکراون و لەشفرۆشیی\f + \fr 17:7 \ft بە واتای لەشفرۆشی جەستەیی و ڕۆحیش دێت. بەو کەسە دەگوترێت کە لاف لێدەدات بەوەفایە بۆ یەزدان، بەڵام لە هەمان کاتدا ستایش و قوربانی بۆ خودایەکی دیکە دەکات. واتا لە بنەڕەتدا کەسەکە بێوەفایە لەگەڵ یەزدان، هەروەک چۆن پیاوێک بێوەفا بێت بەرامبەر بە ژنەکەی.‏\f* ڕۆحییان بۆ دەکەن. ئەمە دەبێتە فەرزێکی هەتاهەتایی بۆیان لە نەوەکانیان.“
\p 
\v 8 «هەروەها پێیان دەڵێیت: ”هەرکەسێک لە گەلی ئیسرائیل و ئەو نامۆیانەی لەنێوتاندان ئەگەر قوربانی سووتاندن یان قوربانی بکات و
\v 9 نەیهێنێتە لای دەروازەی چادری چاوپێکەوتن، بۆ ئەوەی بۆ یەزدانی بکات، ئەوا ئەو کەسە لە گەلەکەی دادەبڕدرێت.
\s1 خواردنی خوێن قەدەغەیە
\p 
\v 10 «”هەروەها هەرکەسێک لە گەلی ئیسرائیل و ئەو نامۆیانەی لەنێوتاندان، ئەگەر خوێن بخوات، ئەوا ڕووم لەو کەسە وەردەگێڕم کە خوێن دەخوات و لە گەلەکەی ڕیشەکێشی دەکەم،
\v 11 چونکە ژیانی بوونەوەر لە خوێندایە و من لەسەر قوربانگا بە ئێوەی دەدەم بۆ کەفارەتکردن بۆ گیانتان، چونکە خوێن کەفارەت بۆ ژیان دەکات،
\v 12 بۆیە بە نەوەی ئیسرائیل دەڵێم: ’کەس لە ئێوە خوێن نەخوات و ئەو نامۆیەش کە لەنێوتاندایە خوێن نەخوات.‘
\p 
\v 13 «”هەرکەسێک لە نەوەی ئیسرائیل و ئەو نامۆیانەی لەنێوتاندان، کە نێچیرێکی ڕاوکرد، ئاژەڵێکی کێوی یان باڵندەیەک لەوانەی دەخورێن، خوێنەکەی دەڕێژێت و بە خۆڵ دایدەپۆشێت،
\v 14 چونکە ژیانی هەر بوونەوەرێک خوێنەکەیەتی، جا بە نەوەی ئیسرائیلم گوت: ’خوێنی هیچ بوونەوەرێک مەخۆنەوە، چونکە ژیانی هەر بوونەوەرێک خوێنەکەیەتی، هەرکەسێک بیخوات لە گەل دادەبڕدرێت.‘
\p 
\v 15 «”هەرکەسێکیش ئاژەڵێکی مرداربووەوە یان نێچیرێک\f + \fr 17:15 \ft مەبەست لە نێچیری بەردەم ئاژەڵی دڕندەیە.‏\f* بخوات، هاوڵاتی بێت یان نامۆ، دەبێت جلەکانی بشوات و خۆی بە ئاو بشوات و هەتا ئێوارە گڵاو دەبێت، ئینجا پاک دەبێتەوە.
\v 16 بەڵام ئەگەر جلەکانی نەشوات و خۆی نەشوات، تاوانی خۆی لە ئەستۆ دەگرێت.“»
\c 18
\s1 جووتبوونە نادروستەکان
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «لەگەڵ نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”من یەزدانی پەروەردگارتانم.
\v 3 وەک نەریتی خاکی میسر مەکەن کە تێیدا نیشتەجێ بوون و وەک نەریتی خاکی کەنعان مەکەن کە ئێوە دەهێنم بۆی و نەریتەکانیان بەجێمەهێنن.
\v 4 پێویستە ملکەچی یاساکانی من بن و فەرزەکانم بەجێبهێنن بۆ ئەوەی پەیڕەویان بکەن، من یەزدانی پەروەردگارتانم.
\v 5 فەرز و یاساکانم پەیڕەو بکەن، چونکە ئەو کەسەی پەیڕەویان بکات، بە هۆیانەوە دەژیێت، من یەزدانم.
\p 
\v 6 «”هیچ کەسێک لە کەسوکاری خۆی نزیک نەبێتەوە، بۆ جووت بوون لەگەڵی، من یەزدانم.
\p 
\v 7 «”ناموسی باوکت مەبە و ناموسی دایکت مەبە، لەگەڵ دایکت جووت مەبە، چونکە دایکتە.
\p 
\v 8 «”لەگەڵ باوەژنت\f + \fr 18:8 \ft زڕدایک.‏\f* جووت مەبە، ئەوە ناموسی باوکتە.
\p 
\v 9 «”لەگەڵ خوشکت، کچی باوکت یان کچی دایکت جووت مەبە، ئەگەر لە ماڵتان لەدایک بووبێت یان لە دەرەوە.
\p 
\v 10 «”لەگەڵ کچی کوڕەکەت یان کچی کچەکەت جووت مەبە، ئەوە ناموسی تۆیە.
\p 
\v 11 «”لەگەڵ کچی ژنی باوکت کە لە باوکتەوە بووە، جووت مەبە، چونکە خوشکتە.
\p 
\v 12 «”لەگەڵ خوشکی باوکت جووت مەبە، چونکە پوورتە.
\p 
\v 13 «”لەگەڵ خوشکی دایکت جووت مەبە، چونکە پوورتە.
\p 
\v 14 «”ناموسی مامت مەبە، لە ژنەکەی نزیک مەکەوە و لەگەڵی جووت مەبە، چونکە مامۆژنتە.
\p 
\v 15 «”لەگەڵ بووکەکەت جووت مەبە، ژنی کوڕتە، لەگەڵی جووت مەبە.
\p 
\v 16 «”لەگەڵ براژنەکەت جووت مەبە، ئەوە ناموسی براتە.
\p 
\v 17 «”لەگەڵ ژنێک و کچەکەی جووت مەبە، لەگەڵ کچی کوڕەکەی یان کچی کچەکەی جووت مەبە، ئەوان نزیکی ژنەکەن و ئەوە ئەوپەڕی بەدڕەوشتییە.
\p 
\v 18 «”هیچ ژنێکیش بەسەر خوشکەکەی مەخوازە هەتا ببێت بە هەوێی، هەتا لەگەڵی جووت بیت، کاتێک ژنەکەت لە ژیاندایە.
\p 
\v 19 «”لە هیچ ژنێکیش نزیک مەکەوە لە ماوەی گڵاوی خوێنلێچوونی مانگانەی بۆ ئەوەی لەگەڵی جووت بیت.
\p 
\v 20 «”لەگەڵ ژنی کەسێکی دیکە جووت مەبە، پێی گڵاو دەبیت.
\p 
\v 21 «”منداڵەکانت وەک قوربانی مەسووتێنە بۆ ’مۆلەخ‘\f + \fr 18:21 \ft خوداوەندێکی کەنعانییە بتپەرستەکان بووە، بۆ پەرستنی هەستاون بە تێپەڕاندنی منداڵەکانیان بەناو ئاگردا. بڕوانە \xt دووەم پوختەی مێژوو 28‏:3‏\xt*\ft .‏\f*، نەوەک ناوی خودای خۆت بزڕێنیت، من یەزدانم.
\p 
\v 22 «”لەگەڵ نێرێک جووت مەبە وەک جووتبوونت لەگەڵ ژن، ئەوە قێزەونە.
\p 
\v 23 «”لەگەڵ هیچ ئاژەڵێکیش جووت مەبە، پێی گڵاو دەبیت، هیچ ئافرەتێک لەبەردەم ئاژەڵ ئامادە نەبێت بۆ جووتبوون، ئەوە ئەوپەڕی بەدڕەوشتییە.
\p 
\v 24 «”بە هیچ یەکێک لەو ڕەفتارانە خۆتان گڵاو مەکەن، چونکە ئەو نەتەوانەی وا من ڕاویان دەنێم لەبەردەمتان بە هەموو ئەمانە گڵاو بوون.
\v 25 تەنانەت خاکەکە گڵاو بوو، منیش سزای تاوانەکەی دەدەم و خاکەکەش دانیشتووانەکەی دەڕشێنێتەوە.
\v 26 بەڵام ئێوە فەرزەکان بەجێدەهێنن و یاساکانم پەیڕەو دەکەن. هیچ کارێک لە هەموو ئەو کردەوە قێزەونانە ناکەن، نە هاوڵاتی و نە ئەو نامۆیەی لەنێوتاندایە.
\v 27 پێش ئێوە خەڵکی خاکەکە هەموو ئەو کردەوە قێزەونانەیان کردووە، هەر بۆیە خاکەکە گڵاو بوو.
\v 28 ئەگەر خاکەکە گڵاو بکەن، ئەوا ئێوەش دەڕشێنێتەوە، وەک چۆن ئەو نەتەوانەی پێش ئێوەی ڕشاندەوە.
\p 
\v 29 «”بەڵکو هەرکەسێک کارێک لە هەموو ئەو کردەوە قێزەونانە ئەنجام بدات، ئەو کەسەی ئەوە دەکات لە گەلەکەی دادەبڕدرێت.
\v 30 جا فەرزەکانم بەجێبهێنن هەتا هیچ لەو نەریتە قێزەونانە نەکەن و پێی گڵاو نەبن کە پێش ئێوە کراون، من یەزدانی پەروەردگارتانم.“»
\c 19
\s1 یاسا جۆراوجۆرەکان
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «لەگەڵ هەموو کۆمەڵی نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”دەبێت پیرۆز بن، چونکە من پیرۆزم، یەزدانی پەروەردگارتانم.
\p 
\v 3 «”هەر یەکێک لە ئێوە، دەبێت ڕێزی دایک و باوکی خۆی بگرێت و شەممەکانم بپارێزن، من یەزدانی پەروەردگارتانم.
\p 
\v 4 «”ئاوڕ لە بت مەدەنەوە و خوداوەندی لەقاڵبدراو بۆ خۆتان دروستمەکەن، من یەزدانی پەروەردگارتانم.
\p 
\v 5 «”کاتێک قوربانییەکی هاوبەشی بۆ یەزدان سەردەبڕن، با بە شێوەیەک بێت لەبەردەم یەزدان قبوڵ بێت،
\v 6 ئەو ڕۆژەی سەری دەبڕن دەیخۆن لەگەڵ ڕۆژی پاشتر. ئەوەی لێی دەمێنێتەوە بۆ ڕۆژی سێیەم، دەبێت بە ئاگر بسووتێنرێت.
\v 7 ئەگەر لە ڕۆژی سێیەمدا بخورێت، ئەوە گڵاوە و قبوڵ نییە.
\v 8 ئەوەی لێی بخوات ئەوا تاوانی خۆی لە ئەستۆ دەگرێت، چونکە شتێکی پیرۆزی یەزدانی گڵاو کردووە، جا ئەو کەسە لە گەلەکەی دادەبڕدرێت.
\p 
\v 9 «”کاتێک دروێنەی زەوییەکانتان دەکەن، لێوارەکانی کێڵگەکەت مەدورەوە، ئەوەی لە دروێنەکە دەکەوێت، هەڵیمەگرەوە،
\v 10 پاشماوەی هێشووە ترێیەکان لە مێوەکەت مەکەرەوە و ئەوەی دەکەوێت هەڵیمەگرەوە، بۆ هەژار و نامۆی بەجێبهێڵە. من یەزدانی پەروەردگارتانم.
\p 
\v 11 «”مەدزن.
\p «”درۆ مەکەن.
\p «”فێڵ لە یەکتری مەکەن.
\p 
\v 12 «”بە درۆ سوێند بە ناوی من مەخۆن، چونکە ناوی خوداکەت دەزڕێنیت، من یەزدانم.
\p 
\v 13 «”نزیکەکەت فریومەدە و تاڵانی مەکە.
\p «”کرێی کرێگرتەش لەلای خۆت بۆ بەیانی مەهێڵەوە.
\p 
\v 14 «”نەفرەت لە کەڕ مەکە و کۆسپ مەخەرە بەردەم نابینا، بەڵکو لە خودات بترسە، من یەزدانم.
\p 
\v 15 «”لە دادوەریدا ستەم مەکەن، نە لایەنگری هەژار بکەن و نە پشتی کەسی مەزن بگرن، بەڵکو بە دادپەروەری حوکمی بەرامبەرەکەت بدە.
\p 
\v 16 «”لەنێوان خەڵکی قسە مەهێنە و مەبە.
\p «”مەبە هۆی گیان لەدەستدانی نزیکەکەت، من یەزدانم.
\p 
\v 17 «”لە دڵەوە ڕقت لە براکەت نەبێتەوە، ڕاشکاوانە دراوسێکەت سەرزەنشت بکە، بۆ ئەوەی بەشداری لە گوناهی نەکەیت.
\p 
\v 18 «”تۆڵە مەستێنەوە و قین لە دڵ مەبە بەرامبەر کوڕی گەلەکەت، بەڵکو نزیکەکەت وەک خۆت خۆشبوێت. من یەزدانم.
\p 
\v 19 «”فەرزەکانم بەجێبهێنن.
\p «”دوو جۆری جیا لە ئاژەڵەکانت پێکەوە جووت مەکە.
\p «”دوو جۆر تۆو لە کێڵگەکەت مەڕوێنە.
\p «”با جلێکت لەبەر نەبێت کە دوو جۆر بێت.
\p 
\v 20 «”ئەگەر پیاوێک لەگەڵ ئافرەتێک جووت بوو، ئەویش کەنیزەیەکی مارەبڕ بوو بۆ پیاوێکی دیکە، بەڵام نەکڕابووەوە و ئازاد نەکرابوو، پێویستە سزایەکی گونجاو بدرێت. کەسیان ناکوژرێت، چونکە ئافرەتەکە ئازاد نەکراوە.
\v 21 دەبێت پیاوەکە قوربانییەک بۆ تاوانەکەی بۆ لای یەزدان بهێنێتە دەروازەی چادری چاوپێکەوتن، بەرانێک وەک قوربانی تاوان.
\v 22 جا کاهینەکە بە بەرانی قوربانی تاوانەکە لەبەردەم یەزدان کەفارەتی بۆ دەکات لە گوناهەکەی کە کردوویەتی، جا لەو گوناهەی کردوویەتی لێخۆشبوونی بۆ دەبێت.
\p 
\v 23 «”کاتێک چوونە ناو خاکەکە\f + \fr 19:23 \ft مەبەست لە خاکی بەڵێندراوە.‏\f* و هەر دارێکتان بۆ خواردن ڕواند، ئەوا بەرەکەی بە قەدەغەکراو بزانن. سێ ساڵ بۆتان قەدەغەکراوە و لێی ناخورێت،
\v 24 لە ساڵی چوارەمیش هەموو بەروبوومەکەی تەرخانکراو دەبێت بۆ شکۆدارکردنی یەزدان،
\v 25 بەڵام لە ساڵی پێنجەمدا بەرەکەی بخۆن، هەتا داهاتی بۆتان زیاد بکات، من یەزدانی پەروەردگارتانم.
\p 
\v 26 «”هەر گۆشتێک بە خوێنەوە بوو مەیخۆن.
\p «”فاڵ مەگرنەوە و جادووگەری مەکەن.
\p 
\v 27 «”لاتەنیشتەکانی سەرتان مەتاشن و دەستکاری دوو لای ڕیشتان مەکەن.
\p 
\v 28 «”بۆ مردوو خۆتان بریندار مەکەن، نەخش لە لەشی خۆتان مەکوتن، من یەزدانم.
\p 
\v 29 «”کچەکەت سووک مەکە، بەوەی بیکەیت بە لەشفرۆش، نەوەک خاکەکە پڕ بێت لە لەشفرۆشی و بەدڕەوشتی.
\p 
\v 30 «”شەممەکانم بپارێزن و ڕێز لە پیرۆزگاکەم بگرن، من یەزدانم.
\p 
\v 31 «”مەگەڕێنەوە بۆ لای نێوانگر\f + \fr 19:31 \ft لێرە بەو واتایە دێت، کەسێکە کە گوایە هۆی پەیوەندی ڕێکخەرە لەنێوان خەڵکی مردوو و زیندوو. بڕوانە \xt یەکەم ساموئێل 28‏:3‏،7‏،9.‏\xt*\ft ‏\f* و بەدوای ڕۆح ئامادەکاردا\f + \fr 19:31 \ft بەو کەسە دەگوترێت کە ڕۆح ئامادە دەکات. بڕوانە \xt یەکەم ساموئێل 28‏:3 و 8‏–9.‏\xt*\ft ‏\f* مەگەڕێن، پێیان گڵاو دەبن، من یەزدانی پەروەردگارتانم.
\p 
\v 32 «”لەبەر ڕیش سپی هەستە و ڕێزی پیر بگرە و لە خودات بترسە، من یەزدانم.
\p 
\v 33 «”ئەگەر نامۆیەک هاتە خاکەکەتان، ستەمی لێ مەکەن،
\v 34 وەک هاوڵاتییەک ڕەفتاری لەگەڵ بکەن، وەک خۆتت خۆشبوێت، چونکە ئێوەش لە خاکی میسر نامۆ بوون، من یەزدانی پەروەردگارتانم.
\p 
\v 35 «”ساختەکاری مەکەن، نە لە ئەندازەی پێوانە و نە لە کێش و نە لە بڕ،
\v 36 دەبێت تەرازووی ڕاست و کێشانەی ڕاست و ئێفەی\f + \fr 19:36 \ft ئێفە پێوانەی وشک بوو.‏\f* ڕاست و هەینی\f + \fr 19:36 \ft هەین پێوانەی شلەمەنی بوو.‏\f* ڕاستتان هەبێت، من یەزدانی پەروەردگارتانم کە لە خاکی میسر دەریهێنان.
\p 
\v 37 «”هەموو فەرزەکانم بەجێبهێنن و یاساکانم پەیڕەو بکەن و جێبەجێیان بکەن، من یەزدانم.“»
\c 20
\s1 سزادان بۆ گوناه
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «بە نەوەی ئیسرائیل بڵێ: ”هەرکەسێک لە نەوەی ئیسرائیل و لەو نامۆیانەی لە ئیسرائیلن، ئەگەر لە منداڵەکانی بە مۆلەخی\f + \fr 20:2 \ft خوداوەندێکی کەنعانییە بتپەرستەکان بووە، بۆ پەرستنی هەستاون بە تێپەڕاندنی منداڵەکانیان بەناو ئاگردا. بڕوانە \xt دووەم پوختەی مێژوو 28‏:3‏\xt*\ft .‏\f* بەخشی، دەبێت بکوژرێت. دەبێت خەڵکی ناوچەکە بەردبارانی بکەن.
\v 3 منیش ڕووم لەو کەسە وەردەگێڕم و لە گەلەکەی ڕیشەکێشی دەکەم، چونکە لە منداڵەکانی خۆی بە مۆلەخی بەخشی، بۆ ئەوەی پیرۆزگاکەم گڵاو بکات و ناوی پیرۆزم بزڕێنێت.
\v 4 ئەگەر خەڵکی ناوچەکە چاوپۆشییان لەو کەسە کرد، کاتێک یەکێک لە منداڵەکانی خۆی بە مۆلەخ بەخشی، ئینجا نەیانکوشت،
\v 5 ئەوا من ڕووی خۆم لەو کەسە و لە ماڵەکەی وەردەگێڕم و لەنێو گەلەکەیان دەیانبڕمەوە. هەمان شت بەوانەش دەکەم کە لە ڕێگەی پەرستنی مۆلەخەوە، لەشفرۆشیی ڕۆحی دەکەن.
\p 
\v 6 «”من ڕووم لەو کەسە وەردەگێڕم کە دەگەڕێتەوە بۆ لای نێوانگر\f + \fr 20:6 \ft نێوانگر: لێرە و لە ئایەتی 27 بەو واتایە دێت، کەسێکە کە گوایە هۆی پەیوەندی ڕێکخەرە لەنێوان خەڵکی مردوو و زیندوو. بڕوانە \xt یەکەم ساموئێل 28‏:3‏،7‏،9.‏\xt*\ft ‏\f* و ڕۆح ئامادەکار تاکو بە شوێنکەوتنیان لەشفرۆشیی ڕۆحی بکات، ئەوا من ئەو کەسە لە گەلەکەی ڕیشەکێش دەکەم.
\p 
\v 7 «”خۆتان تەرخان بکەن و پیرۆز بن، چونکە من یەزدانی پەروەردگارتانم،
\v 8 فەرزەکانم بەجێبهێنن و جێبەجێیان بکەن، من یەزدانم کە پیرۆزتان دەکات.
\p 
\v 9 «”هەرکەسێک نەفرەت لە باوکی یان دایکی بکات، دەبێت بکوژرێت، نەفرەتی لە باوکی یان دایکی کردووە، خوێنی لە ئەستۆی خۆیەتی.
\p 
\v 10 «”ئەگەر پیاوێک داوێنپیسی لەگەڵ ژنی کەسێکی دیکەدا کرد، کە ژنی نزیکەکەیەتی، ئەوا پیاوەکە و ژنەکەش دەبێت بکوژرێن.
\p 
\v 11 «”ئەگەر پیاوێک لەگەڵ باوەژنی خۆی جووت بوو، ئەوا ناموسی باوکی بردووە، هەردووکیان دەبێت بکوژرێن، خوێنیان لە ئەستۆی خۆیانە.
\p 
\v 12 «”ئەگەر پیاوێک لەگەڵ ژنی کوڕەکەی جووت بوو، ئەوا هەردووکیان دەبێت بکوژرێن، ئەوپەڕی بەدڕەوشتییان کردووە، خوێنیان لە ئەستۆی خۆیانە.
\p 
\v 13 «”ئەگەر پیاوێک وەک ژن لەگەڵ نێرێک ڕاکشا بوو، ئەوا هەردووکیان شتێکی قێزەونیان کردووە و دەبێت بکوژرێن، خوێنیان لە ئەستۆی خۆیانە.
\p 
\v 14 «”ئەگەر پیاوێک ئافرەتێک لەگەڵ دایکەکەی بخوازێت، ئەوە بەدکارییە، پیاوەکە و هەردوو ژنەکە دەبێت بە ئاگر بسووتێنرێن، هەتا بەدکاری لەنێوتاندا نەبێت.
\p 
\v 15 «”ئەگەر پیاوێک لەگەڵ ئاژەڵێکدا جووت بوو، دەبێت پیاوەکە بکوژرێت و ئاژەڵەکەش بکوژرێت.
\p 
\v 16 «”ئەگەر ئافرەتێک لە ئاژەڵێک نزیک بووەوە بۆ جووتبوون، ئەوا ئافرەتەکە و ئاژەڵەکەش بکوژن، خوێنیان لە ئەستۆی خۆیانە.
\p 
\v 17 «”ئەگەر پیاوێک خوشکی خۆی هێنا، کچی باوکی یان کچی دایکی و لەگەڵ یەک جووت بوون، ئەوا ڕیسواییە، دەبێت لەبەرچاوی گەلەکەیان ببڕدرێتەوە، ناموسی خوشکی خۆی بردووە، تاوانی خۆی لە ئەستۆ دەگرێت.
\p 
\v 18 «”ئەگەر پیاوێک لەگەڵ ژنێک جووت بوو لە ڕۆژانی خوێنلێچوونی مانگانەی، ئەوا دەبێت هەردووکیان لە گەلەکەیان داببڕدرێن، چونکە پیاوەکە خوێنلێچوونی ئافرەتەکەی ئاشکرا کردووە و ئافرەتەکەش خوێنلێچوونی خۆی ئاشکرا کردووە.
\p 
\v 19 «”لەگەڵ خوشکی باوکت یان خوشکی دایکت جووت مەبە، ئەوەی وا بکات، ئەوا هەردووکیان تاوانی خۆیان لە ئەستۆ دەگرن، چونکە ناموسی کەسوکاری خۆی بردووە.
\p 
\v 20 «”ئەگەر پیاوێک لەگەڵ مامۆژنی خۆی جووت بوو، ئەوا ناموسی مامی خۆی بردووە، هەردووکیان تاوانیان لە ئەستۆ دەبێت، دەبێت بە وەجاخکوێری بمرن.
\p 
\v 21 «”ئەگەر پیاوێک براژنی خۆی هێنا ئەوا گڵاوییە، ناموسی براکەی بردووە، دەبێت هەردووکیان وەجاخکوێر بن.
\p 
\v 22 «”هەموو فەرزەکانم بەجێبهێنن و یاساکانم پەیڕەو بکەن و جێبەجێیان بکەن، بۆ ئەوەی ئەو خاکە نەتانڕشێنێتەوە کە بۆ نیشتەجێبوون دەتانهێنمە ناوی.
\v 23 بە ڕێی نەریتی ئەو نەتەوانەدا مەڕۆن کە من لەپێشتانەوە دەریاندەکەم، چونکە هەموو ئەم شتانەیان کرد، جا ڕقم لێیان بووەوە.
\v 24 بەڵام بە ئێوەم فەرموو کە دەبنە خاوەنی خاکەکەیان، من دەیدەمە ئێوە هەتا ببنە میراتگری، خاکێک شیر و هەنگوینی لێ بڕژێت، من یەزدانی پەروەردگارتانم کە لەنێو گەلان جیای کردنەوە.
\p 
\v 25 «”لەبەر ئەوە ئێوەش ئاژەڵی پاک و گڵاو لە یەکتر جیا بکەنەوە، هەروەها باڵندەی گڵاو و پاکیش، جا خۆتان گڵاو مەکەن بە ئاژەڵ و باڵندە و هەموو ئەوەی لەسەر زەوی دەخشێت، لەوانەی بۆم جیا کردنەوە، گوتم، گڵاون.
\v 26 دەبێت بۆ من پیرۆز بن، چونکە من پیرۆزم، من یەزدانم، ئێوەم لەنێو گەلان جیا کردەوە هەتا بۆ من بن.
\p 
\v 27 «”ئەگەر پیاوێک یان ئافرەتێک نێوانگر یان ڕۆح ئامادەکار بوو، دەبێت بکوژرێت، بەردبارانیان بکەن، خوێنیان لە ئەستۆی خۆیانە.“»
\c 21
\s1 ڕێساکان بۆ کاهین
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو: «لەگەڵ کاهینەکان بدوێ کە نەوەی هارونن و پێیان بڵێ: ”نابێت بەپێی ڕێوڕەسم کەستان بە مردووێکی هۆزەکەی خۆی گڵاو بکات،
\v 2 تەنها بۆ ئەوانە نەبێت کە زۆر نزیکن لێی، دایکی و باوکی و کوڕی و کچی و برای و
\v 3 خوشکە پاکیزەکەی کە لێی نزیکە، ئەوەی شووی نەکردووە، دەشێت لە پێناویدا گڵاو بێت.
\v 4 نابێت خۆی گڵاو بکات بەوانەی لە ڕێگەی ژنهێنانەوە بوونەتە خزمی ئەو.
\p 
\v 5 «”کاهینەکان نابێت سەریان سفر بکەن و هەردوو لای ڕیشیان بتاشن و خۆیان بریندار بکەن.
\v 6 دەبێت بۆ خوداکەیان پیرۆز بن و ناوی خودایان نەزڕێنن، چونکە قوربانییە بە ئاگرەکان وەک نانی خودایان بۆ یەزدان پێشکەش دەکەن، جا دەبێت پیرۆز بن.
\p 
\v 7 «”نابێت کاهینەکان ئافرەتی لەشفرۆشی بێ ئابڕوو\f + \fr 21:7 \ft لە زمانی عیبری بە واتای گڵاو هاتووە، لێرە و لە ئایەتی 14.‏\f* و تەڵاقدراو بخوازن، چونکە کاهین پیرۆزکراوە بۆ خوداکەی،
\v 8 جا بە پیرۆزی دابنێن، چونکە نانی خوداتان پێشکەش دەکات، پیرۆزکراو دەبێت لەلاتان، چونکە من پیرۆزم. من یەزدانم ئەوەی پیرۆزتان دەکات.
\p 
\v 9 «”ئەگەر کچی کاهین بە لەشفرۆشی گڵاو بوو، ئەوا باوکی گڵاو کردووە، دەبێت کچەکە بە ئاگر بسووتێنرێت.
\p 
\v 10 «”سەرۆکی کاهینان، ئەوەی لەنێو براکانی زەیتی دەستنیشانکردنی بە سەریدا کراوە و ئەرک پێ سپێردراوە بۆ لەبەرکردنی جلەکانی کاهینیێتی، پێویستە سەری ڕووت نەکات و جلەکانی لەبەر خۆی دانەدڕێت.
\v 11 پێویستە نەیەتە ئەو شوێنەی لاشەی مردووی لێیە، نابێت خۆی بۆ دایک و باوکیشی گڵاو بکات.
\v 12 نابێت لە پیرۆزگا دەربچێت، نەوەک پیرۆزگای خوداکەی گڵاو بکات، چونکە بە زەیتی دەستنیشانکردنی خودا نەزرکراوە، من یەزدانم.
\p 
\v 13 «”ئەم دەبێت کچێکی پاکیزە بخوازێت.
\v 14 نابێت بێوەژن و تەڵاقدراو و بێ ئابڕووی لەشفرۆش بخوازێت، بەڵکو دەبێت کچێکی پاکیزە لە خزمەکانی بخوازێت،
\v 15 بۆ ئەوەی وەچەکەی لەنێو گەلەکەی گڵاو نەکات. من یەزدانم، ئەوم پیرۆز کردووە.“»
\p 
\v 16 هەروەها یەزدان بە موسای فەرموو:
\v 17 «لەگەڵ هارون بدوێ و بڵێ: ”ئەگەر پیاوێک لە وەچەی تۆ لە نەوەکانیان کەموکوڕییەکی تێدابوو، با نەیەتە پێشەوە بۆ پێشکەشکردنی نانی خوداکەی.
\v 18 هەر پیاوێک کەموکوڕی تێدابێت، نابێت بێتە پێشەوە، نە پیاوی نابینا و نە شەل و نە دەموچاو خوار و نە شێوە تێکچوو،
\v 19 نە پیاوی دەست یان پێ گۆج،
\v 20 نە قەمبوور، نە کورتەباڵا، نە ئەوەی کە کەموکوڕی لە چاویدا هەیە یان زام و برینێکی بەردەوامی هەیە و نە قۆڕ.
\v 21 هەر پیاوێک لە نەوەی هارونی کاهین کەموکوڕی تێدابێت، نابێت بێتە پێشەوە بۆ پێشکەشکردنی قوربانییە بە ئاگرەکان بۆ یەزدان؛ لەبەر ئەوەی کەموکوڕی تێدایە، پێویستە نەیەتە پێشەوە بۆ پێشکەشکردنی نانی خوداکەی.
\v 22 دەتوانێت لە نانی خوداکەی بخوات، لە پێشکەشکراوە پیرۆزەکە و لە خواردنە هەرەپیرۆزەکانیش؛
\v 23 بەڵام نابێت بێتە لای پەردەکە و لە قوربانگاکەش نزیک بکەوێتەوە، چونکە کەموکوڕی تێدایە، نەوەک پیرۆزگام گڵاو بکات، چونکە من یەزدانم، کە پیرۆزیان دەکەم.“»
\p 
\v 24 ئینجا موسا لەگەڵ هارون و کوڕەکانی و هەموو نەوەی ئیسرائیلدا دوا.
\c 22
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «بە هارون و کوڕەکانی بڵێ: ”با ئاگاداری خۆیان بن لە قوربانییە پیرۆزەکانی نەوەی ئیسرائیل و ناوی پیرۆزی من نەزڕێنن، ئەوانەی بۆ منی تەرخان دەکەن، من یەزدانم.“
\p 
\v 3 «پێیان بڵێ: ”نەوە لەدوای نەوە، ئەگەر هەرکەسێک لە نەوەکانتان بەپێی ڕێوڕەسم گڵاو بێت و لە قوربانییە پیرۆزەکان نزیک بووەوە کە نەوەی ئیسرائیل بۆ یەزدانی تەرخان دەکەن، ئەوا ئەو کەسە لەبەردەمم دوور دەخرێتەوە. من یەزدانم.
\p 
\v 4 «”هەرکەسێک لە نەوەی هارون کە نەخۆشی گواستراوەی پێست یان لێچوونی هەبێت، هەتا پاک دەبێتەوە لە قوربانییە پیرۆزەکان نەخوات. هەر یەکێکیش دەست لە شتێکی گڵاوی مردووێک بدات، یان کەسێک تۆوی لێچووبوو،
\v 5 یان دەستی لە خشۆکێک دابێت کە پێی گڵاو بێت، یان لە مرۆڤێک کە پێی گڵاو بێت لەبەر هەر گڵاوییەک کە هەیەتی،
\v 6 ئەوەی دەست لە هەریەک لەو شتانە بدات ئەوا هەتا ئێوارە گڵاو دەبێت و نابێت لە قوربانییە پیرۆزەکان بخوات هەتا خۆی بە ئاو نەشوات.
\v 7 کاتێک خۆر ئاوا دەبێت، پاک دەبێتەوە و پاشان لە قوربانییە پیرۆزەکان بخوات، چونکە خۆراکی ئەوە.
\v 8 نابێت ئاژەڵی مردارەوەبوو و نێچیر بخوات، چونکە پێی گڵاو دەبێت. من یەزدانم.
\p 
\v 9 «”کاهینەکان دەبێت خواستەکانم بپارێزن، نەوەک گوناهێک هەڵبگرن کە پێی بمرن، ئەگەر بە سووکی ڕەفتاری لەگەڵ بکەن. من یەزدانم کە پیرۆزیان دەکەم.
\p 
\v 10 «”نابێت کەس لە قوربانی پیرۆزکراو بخوات جگە لە کەسوکاری کاهینەکە. میوان و کرێگرتەی کاهینیش نابێت لە قوربانی پیرۆزکراو بخۆن،
\v 11 بەڵام ئەگەر کاهین کۆیلەیەکی بە زیو کڕی، یان کۆیلەیەک لە ماڵەکەی لە دایک بێت، ئەوا ئەو کۆیلەیە دەتوانێت لێی بخوات، ئەوان لە خۆراکەکەی دەخۆن.
\v 12 ئەگەر کچی کاهین شووی بە پیاوێکی جگە لە کاهین کرد، ئەوا نابێت لە بەخشینە پیرۆزەکان بخوات.
\v 13 بەڵام ئەگەر کچی کاهین بوو بە بێوەژن یان تەڵاق درا و هیچ وەچەی نەبوو و هاتەوە ماڵی باوکی، وەک کاتی کچێنی، ئەوا دەتوانێت لە خۆراکی باوکی بخوات. بەڵام نابێت کەسێکی دیکە لێی بخوات، جگە لە کەسوکاری کاهینەکە.
\p 
\v 14 «”ئەگەر کەسێک بە هەڵە قوربانییەکی پێشکەشکراوی خوارد، ئەوا دەبێت پێنجیەکی زیاد بخاتە سەر و قوربانییە پیرۆزەکە بداتە کاهینەکە.
\v 15 کاهینەکان نابێت قوربانییە پیرۆزەکانی نەوەی ئیسرائیل گڵاو بکەن کە لەبەردەم یەزدان دایدەنێن،
\v 16 ئەگەر ڕێیان پێبدەن قوربانییە پیرۆزەکانیان بخۆن ئەوا گوناهیان دەخەنە ئەستۆ، چونکە من یەزدانم کە پیرۆزیان دەکەم.“»
\s1 قوربانی قبوڵ نەکراو
\p 
\v 17 هەروەها یەزدان بە موسای فەرموو:
\v 18 «لەگەڵ هارون و کوڕەکانی و هەموو نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”ئەگەر هەر یەکێکتان، ئیسرائیلی بێت یان بیانییەک کە لە ئیسرائیل نیشتەجێیە، بەخشینێک پێشکەش بە یەزدان بکات وەک قوربانی سووتاندن بۆ ئەنجامدانی نەزر یان بەخشینێک کە بە خواستی خۆی بێت،
\v 19 بۆ ئەوەی لێتان وەربگیرێت، دەبێت نێرێکی ساغ بێت، لە گاگەل یان ماڵات.
\v 20 هەرچییەک کەموکوڕی تێدابێت پێشکەشی مەکەن، چونکە لێتان وەرناگیرێت.
\v 21 ئەگەر کەسێک قوربانی هاوبەشی پێشکەشی یەزدان کرد، بۆ بەجێهێنانی نەزرێکی تایبەت یان بەخشینێکی بە خواستی خۆی، لە گاگەل یان لە مێگەل، دەبێت ساغ بێت بۆ ئەوەی قبوڵ بکرێت. نابێت هیچ کەموکوڕییەکی تێدابێت.
\v 22 کوێر و بریندار و پەلشکاو و بالوکەدار و گەڕ و زامداری بەردەوام، ئەمانە پێشکەش بە یەزدان مەکەن و لێیان مەکەن بە قوربانی بە ئاگر لەسەر قوربانگاکەی یەزدان.
\v 23 بەڵام گا\f + \fr 22:23 \ft گا: لە زمانی عیبری دەشێت ئەم وشەیە بۆ نێر و مێ (چێڵ و گا) بەکاربهێنرێت.‏\f* و بەرانی شێوە تێکچوو و کورتەباڵا دەتوانیت بکەیت بە بەخشینێک بە خواستی خۆت، بەڵام بۆ تەواوبوونی نەزر قبوڵ نابێت.
\v 24 پێویستە ئاژەڵێک نەکەنە قوربانی بۆ یەزدان کە گونی قۆڕ بێت یان خەسابێت یان گونی لێکرابێتەوە یانیش بڕا بێت، لە خاکەکەشتان مەیکەن.
\v 25 لە هەموو ئەمانەش پێویست ناکات بە هەر ئاژەڵێکی دەستی بیانی ڕازی ببن و پێشکەشیان بکەن وەک خواردنی خوداتان. لێتان وەرناگیرێت، چونکە ئەو ئاژەڵانە ناتەواون و کەموکوڕییان تێدایە.“»
\p 
\v 26 هەروەها یەزدان بە موسای فەرموو:
\v 27 «کاتێک گوێرەکەیەک یان بەرخێک یان گیسکێک لەدایک دەبێت، ئەوا حەوت ڕۆژ لەژێر دایکی دەبێت و لە ڕۆژی هەشتەم بەدواوە، وەک قوربانی بە ئاگر بۆ یەزدان قبوڵ دەبێت.
\v 28 مانگا و مەڕیش لە یەک ڕۆژدا لەگەڵ بەچکەکەی سەرمەبڕن.
\p 
\v 29 «کاتێک قوربانی سوپاسگوزاریتان بۆ یەزدان سەربڕی، بە شێوەیەک سەری ببڕن کە لێتان وەربگیرێت،
\v 30 دەبێت لەو ڕۆژەدا بخورێت، بۆ بەیانی لێی مەهێڵنەوە، من یەزدانم.
\p 
\v 31 «”فەرمانەکانم بپارێزن و جێبەجێیان بکەن، من یەزدانم.
\v 32 ناوی پیرۆزیشم مەزڕێنن، دەبێت نەوەی ئیسرائیل دان بە پیرۆزی مندا بنێن. من یەزدانم کە پیرۆزیان دەکەم،
\v 33 ئەوەی لە خاکی میسر دەریهێنان، تاکو ببێتە خوداتان، من یەزدانم.“»
\c 23
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «لەگەڵ نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”ئەمانە جەژنەکانی منن، جەژنەکانی یەزدان کە تێیدا بانگەوازی کۆبوونەوەی پیرۆزبوون\f + \fr 23:2 \ft بیرۆکەی بنەڕەتی سەرجەم جەژنەکان دەگەڕێتەوە بۆ دوو بنەمای سەرەکی: (1) یادکردنەوەی کار و چاکە مەزنەکانی خودا بەرامبەر بە گەلەکەی؛ (2) خۆتەرخانکردن لەم ڕۆژانەدا تەنها بۆ ستایش و پەرستنی خودا و فێربوون.‏\f* دەکەن.
\s1 شەممە
\p 
\v 3 «”شەش ڕۆژ کار بکەن بەڵام ڕۆژی حەوتەم شەممەیە، پشوودانە و کۆبوونەوەی پیرۆزبوونە، هیچ کارێک مەکەن، لە هەموو نشینگەکانتان شەممەیە بۆ یەزدان.
\s1 جەژنی پەسخە و جەژنی فەتیرە
\p 
\v 4 «”ئەمانە جەژنەکانی یەزدانن، کۆبوونەوەی پیرۆزبوونەکان کە دەبێت لە کاتی خۆیدا بانگەوازی بۆ بکەن.
\v 5 لە ئێوارەوە لە چواردەی مانگی یەک، جەژنی پەسخە بۆ یەزدان دەستپێدەکات.
\v 6 لە ڕۆژی پازدەی ئەم مانگەدا جەژنی فەتیرە بۆ یەزدان دەستپێدەکات، دەبێت حەوت ڕۆژ نانی فەتیرە\f + \fr 23:6 \ft نانی فەتیرە: نانی بێ هەویرترش، واتا نانی بێ خومرە.‏\f* بخۆن.
\v 7 لە ڕۆژی یەکەم کۆبوونەوەی پیرۆزبوون ببەستن، هیچ کارێکی ئاسایی مەکەن.
\v 8 حەوت ڕۆژ قوربانی بە ئاگر بۆ یەزدان پێشکەش بکەن، لە ڕۆژی حەوتەمیشدا کۆبوونەوەی پیرۆزبوون ببەستن، هیچ کارێکی ئاسایی مەکەن.“»
\s1 یەکەمین بەرهەم
\p 
\v 9 هەروەها یەزدان بە موسای فەرموو:
\v 10 «لەگەڵ نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”کاتێک هاتنە ئەو خاکەی من پێتانی دەدەم و دەغڵتان دورییەوە، ئەوا یەکەم مەڵۆی\f + \fr 23:10 \ft مەڵۆ: مەبەست لە دەسکە گەنم یان جۆرێکی دیکەی دانەوێڵە بێت.‏\f* دروێنەتان بۆ کاهین بهێنن.
\v 11 ئەویش دەبێت مەڵۆیەکە لەبەردەم یەزدان بەرز بکاتەوە، بۆ ئەوەی لێتان وەربگیرێت، ڕۆژی پاش شەممە کاهین دەبێت بەرزی بکاتەوە.
\v 12 لە ڕۆژی بەرزکردنەوەی مەڵۆیەکە، بەرخێکی ساغی یەک ساڵە بکەنە قوربانی سووتاندن بۆ یەزدان،
\v 13 پێشکەشکراوی دانەوێڵەشی دوو دەیەکی ئێفەیەک\f + \fr 23:13 \ft نزیکەی چوار لیتر و نیو.‏\f* لە باشترین ئاردی بە زەیت شێلراو بکە بە قوربانی بە ئاگر بۆ یەزدان، ئەو بۆنەی یەزدان پێی خۆشە، شەرابە پێشکەشکراوەکەشی، چارەکە هەینێک\f + \fr 23:13 \ft چارەکە هەینێک: نزیکەی یەک لیتر.‏\f* شەرابە.
\v 14 نان و قەرەخەرمان و گەنمی تازە مەخۆن، هەتا ئەو ڕۆژەی قوربانییەکەی خوداتان دەهێنن، فەرزێکی هەتاهەتاییە لە نەوەکانی ئێوە لە هەموو نشینگەکانتان.
\s1 جەژنی هەفتەکان\f + \fr 23:14 \ft جەژنی هەفتەکان، هەروەها وەک جەژنی دروێنەش ناسراوە (بڕوانە \xt دەرچوون 23‏:16‏\xt*\ft ‏)، 50 ڕۆژ لەدوای جەژنی فەتیرە بووە، کە دەکاتە حەوت هەفتە.‏\f*
\p 
\v 15 «”ئینجا لە ڕۆژی دوای شەممەوە، لەو ڕۆژەوەی کە مەڵۆیەکە وەک قوربانی بەرزکردنەوە دەهێنن، حەوت هەفتەی تەواو بژمێرن،
\v 16 هەتا ڕۆژی دوای شەممەی حەوتەم بژمێرن کە پەنجا ڕۆژە، ئینجا پێشکەشکراوێکی دانەوێڵەی نوێ بۆ یەزدان پێشکەش بکەن.
\v 17 لە نشینگەکانتانەوە دوو نانی وەک قوربانی بەرزکردنەوە بهێنن، لە دوو دەیەکی ئێفەیەک لە باشترین ئارد بێت و بە هەویرترشەوە کرابنە نان، یەکەمین بەرهەمە بۆ یەزدان.
\v 18 لەگەڵ نانەکان حەوت بەرخی نێری یەک ساڵەی ساغ و جوانەگایەک\f + \fr 23:18 \ft لەو کاتەوەی کە گوێرەکەی نێر لە شیر دەبڕدرێتەوە پێی دەگوترێت (نۆبەن) یان (جوانەگا).‏\f* و دوو بەران بکەنە قوربانی سووتاندن بۆ یەزدان. لەگەڵ پێشکەشکراوە دانەوێڵەکەیان و شەرابە پێشکەشکراوەکەیان، قوربانی بە ئاگرە، ئەو بۆنەی یەزدان پێی خۆشە.
\v 19 گیسکێکی نێرینەش بکەنە قوربانی گوناه و دوو بەرخی یەک ساڵەش بکەنە قوربانی هاوبەشی.
\v 20 جا کاهینەکە دەبێت دوو بەرخەکە لەگەڵ نانی یەکەمین بەرهەمەکە لەبەردەم یەزدان بەرز بکاتەوە. ئەمانە پێشکەشکراوێکی پیرۆزن بۆ یەزدان، جا دەبێت بۆ کاهینەکە بن.
\v 21 لە هەمان ئەو ڕۆژەدا بانگەواز بکەن و کۆبوونەوەی پیرۆزبوونە بۆتان، هیچ کارێکی ئاسایی مەکەن، فەرزێکی هەتاهەتاییە لە هەموو نشینگەکانتان لە نەوەکانتان.
\p 
\v 22 «”کاتێک دروێنەی زەوییەکانتان دەکەن، لێوارەکانی کێڵگەکەت مەدورەوە، ئەوەی لە دروێنەکە دەکەوێت، هەڵیمەگرەوە، بۆ هەژار و نامۆ بەجێی بهێڵە، من یەزدانی پەروەردگارتانم.“»
\s1 ڕۆژی دەنگی کەڕەنا
\p 
\v 23 هەروەها یەزدان بە موسای فەرموو:
\v 24 «لەگەڵ نەوەی ئیسرائیل بدوێ و بڵێ: ”یەکەم ڕۆژی مانگی حەوت دەبێت پشوو بێت بۆتان، یادی دەنگی کەڕەنایە، کۆبوونەوەی پیرۆزبوونە.
\v 25 هیچ کارێکی ئاسایی مەکەن، بەڵام قوربانی بە ئاگر بۆ یەزدان پێشکەش بکەن.“»
\s1 ڕۆژی کەفارەت
\p 
\v 26 هەروەها یەزدان بە موسای فەرموو:
\v 27 «بەڵام ڕۆژی دەیەمی ئەم مانگی حەوتە، ڕۆژی کەفارەتە، کۆبوونەوەی پیرۆزبوون ببەستن، گیانی خۆتان زەلیل\f + \fr 23:27 \ft مەبەستی لە خۆبێبەشکردنە لە (خواردن و خواردنەوە یان جووتبوون لەگەڵ هاوسەر… هتد). لێرەدا زیاتر کات تەرخان دەکرێت بۆ نوێژکردن و پاڕانەوە. بڕوانە یەکەم نامەی پۆڵس بۆ باوەڕدارانی کۆرنسۆس 7‏:5 و \xt یۆحەنا 4‏:34‏\xt*\ft ‏.‏\f* بکەن و قوربانی بە ئاگر بۆ یەزدان پێشکەش بکەن.
\v 28 لەو ڕۆژەدا هیچ کارێک مەکەن، چونکە ڕۆژی کەفارەتە بۆ کەفارەتکردن بۆتان لەبەردەم یەزدانی پەروەردگارتان.
\v 29 هەرکەسێک لەم ڕۆژەدا خۆی زەلیل نەکات لە گەلەکەی دادەبڕدرێت،
\v 30 هەرکەسێکیش لەم ڕۆژەدا هەر کارێک بکات، ئەوا ئەو کەسە لەنێو گەلەکەی لەناودەبەم.
\v 31 هیچ کارێک مەکەن، فەرزێکی هەتاهەتاییە بۆ نەوەکانتان لە هەموو نشینگەکانتان.
\v 32 شەممەیە، پشووە بۆتان، دەبێت گیانی خۆتان زەلیل بکەن. دەبێت لە کاتی ئێوارەی نۆی مانگدا هەتا ئێوارەی دواتر پشوودانی شەممەتان بێت.»
\s1 جەژنی کەپرەشینە
\p 
\v 33 هەروەها یەزدان بە موسای فەرموو:
\v 34 «لەگەڵ نەوەی ئیسرائیل بدوێ و بڵێ: ”لە ڕۆژی پازدەیەمی ئەم مانگی حەوتە، حەوت ڕۆژ جەژنی کەپرەشینەیە بۆ یەزدان.
\v 35 لە ڕۆژی یەکەمدا کۆبوونەوەی پیرۆزبوونە، هیچ کارێکی ئاسایی مەکەن،
\v 36 حەوت ڕۆژ قوربانی بە ئاگر بۆ یەزدان پێشکەش بکەن. لە ڕۆژی هەشتەمدا کۆبوونەوەی پیرۆزبوون ببەستن و قوربانی بە ئاگر بۆ یەزدان پێشکەش بکەن، ئاهەنگی کۆتایی پێهێنانە، هیچ کارێکی ئاسایی مەکەن.
\p 
\v 37 «”دەبێت لە جەژنەکانتان ئەمانە پێشکەشی یەزدان بکەن کە تێیدا بانگەوازی کۆبوونەوەی پیرۆزبوون دەکەن، بۆ پێشکەشکردنی قوربانی بە ئاگر بۆ یەزدان، قوربانی سووتاندن و پێشکەشکراوی دانەوێڵە و قوربانی سەربڕاو و شەرابی پێشکەشکراو، هەر ڕۆژەو هی خۆی.
\v 38 جیا لە شەممەکانی یەزدان و جیا لە دیارییەکانتان و هەموو نەزرەکانتان و هەموو بەخشینە ئازادەکانتان کە بە یەزدانی دەدەن.
\p 
\v 39 «”ڕۆژی پازدەی مانگی حەوت، پاش ئەوەی بەروبوومی زەوییەکەتان کۆکردەوە، حەوت ڕۆژ جەژن بۆ یەزدان بگێڕن، لە ڕۆژی یەکەمدا شەممەیە و لە ڕۆژی هەشتەمیشدا شەممەیە.
\v 40 لە ڕۆژی یەکەمدا بەروبوومی دارەکانی میوە و پەلکی دار خورما و لقەداری پڕ گەڵا و شۆڕەبی ناو چەمەکان بۆ خۆتان ببەن و حەوت ڕۆژ لەبەردەم یەزدانی پەروەردگارتان خۆشی بگێڕن.
\v 41 حەوت ڕۆژ لە ساڵێکدا بۆ یەزدان بکەن بە جەژن، فەرزێکی هەتاهەتاییە بۆ نەوەکانتان، لە مانگی حەوت بیکەن بە جەژن.
\v 42 حەوت ڕۆژ لە کەپردا نیشتەجێ بن، هەموو هاوڵاتییەکانی ئیسرائیل دەبێت لە کەپردا نیشتەجێ بن،
\v 43 بۆ ئەوەی نەوەکانتان بزانن کە من نەوەی ئیسرائیلم لە کەپردا نیشتەجێ کرد، کاتێک لە خاکی میسرم دەرهێنان، من یەزدانی پەروەردگارتانم.“»
\p 
\v 44 جا موسا سەبارەت بە جەژنەکانی یەزدان بە نەوەی ئیسرائیلی ڕاگەیاند.
\c 24
\s1 ڕێکخستنی زەیت و نان لەبەردەم یەزدان
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو:
\v 2 «فەرمان بە نەوەی ئیسرائیل بکە با زەیتی زەیتوونی سادە و گوشراوت بۆ ڕووناکی بۆ بهێنن، هەتا چرا بەردەوام داگیرساو بێت.
\v 3 لەناو چادری چاوپێکەوتن، لە دەرەوەی پەردەی شوێنی هەرەپیرۆز، هارون لە ئێوارەوە هەتا بەیانی بە بەردەوامی چرادانەکە لەبەردەم یەزدان ڕێک دەخات. فەرزێکی هەتاهەتاییە بۆ نەوەکانتان.
\v 4 چراکە لەسەر چرادانەکەی کە لە زێڕی بێگەردە پێویستە بە بەردەوامی لەبەردەم یەزدان ڕێکبخرێت.
\p 
\v 5 «باشترین ئاردیش دەبەیت و دەیکەیتە دوازدە کولێرە، بۆ هەر کولێرەیەک دوو دەیەکی ئێفەیەک\f + \fr 24:5 \ft نزیکەی چوار لیتر و نیو.‏\f* بەکاردەهێنیت،
\v 6 دەیانکەیت بە دوو ڕیز، هەر ڕیزە و شەش کولێرە، لەسەر مێزە زێڕینە بێگەردەکە لەبەردەم یەزدان.
\v 7 لەسەر هەر ڕیزێکیش بخووری سادەی بێگەرد دادەنێیت، جا لەگەڵ کولێرەکە دەبێتە یادەوەری قوربانی بە ئاگر بۆ یەزدان.
\v 8 ئەم کولێرەیەش بە بەردەوامی هەموو ڕۆژێکی شەممە لەبەردەم یەزدان ڕێکدەخرێت، پەیمانێکی هەتاهەتاییە لە پێناو نەوەی ئیسرائیل.
\v 9 ئەمە بۆ هارون و کوڕەکانی دەبێت و لە شوێنێکی پیرۆز دەیخۆن، چونکە هەرەپیرۆزە لە قوربانییە بە ئاگرەکان بۆ یەزدان، بەشێکی چەسپاوە.»
\s1 بەردبارانی نەفرەتکەرێک
\p 
\v 10 کوڕێک کە دایکی ئیسرائیلی و باوکی میسری بوو چووە نێو نەوەی ئیسرائیل و لە ئۆردوگاکە لەگەڵ پیاوێکی ئیسرائیلی بووە شەڕیان.
\v 11 کوڕی ژنە ئیسرائیلییەکە کفر و نەفرەتی سەبارەت بە ناوی یەزدان کرد، هێنایانە لای موسا، دایکیشی ناوی شەلۆمیتی کچی دبری بوو، لە هۆزی دان.
\v 12 لە شوێنێکیان دانا لەژێر چاودێری پاسەوان، هەتا بڕیاری یەزدانیان پێ ڕابگەیەنرێت.
\p 
\v 13 جا یەزدان بە موسای فەرموو:
\v 14 «ئەوەی نەفرەتی کردووە، بیبە دەرەوەی ئۆردوگاکە، هەموو ئەوانەی گوێیان لێی بوو دەستیان لەسەر سەری دادەنێن و هەموو کۆمەڵەکە بەردبارانی دەکەن.
\v 15 لەگەڵ نەوەی ئیسرائیلیش بدوێ و بڵێ: ”ئەوەی نەفرەت لە خودای خۆی بکات، ئەوا تاوانی لە ئەستۆی خۆی دەبێت.
\v 16 ئەوەی کفر سەبارەت بە ناوی یەزدان بکات، ئەوا دەکوژرێت، هەموو کۆمەڵەکە بەردبارانی دەکەن، بیانی و هاوڵاتی وەک یەک، کاتێک کفر سەبارەت بە ناوی یەزدان بکات، دەکوژرێت.
\p 
\v 17 «”ئەگەر کەسێک کەسێکی کوشت ئەوا دەکوژرێت.
\v 18 ئەوەی ئاژەڵی کەسێکی دیکە بکوژێت، ئەوا قەرەبووی دەکاتەوە، گیان بە گیان.
\v 19 ئەگەر یەکێک شتێکی لە کەسێک کرد، چی کردووە ئاوای لێ دەکرێتەوە،
\v 20 شکان بە شکان و چاو بە چاو و ددان بە ددان، چی لەو کەسە کردووە ئاوای لێ دەکرێتەوە.
\v 21 ئەوەی ئاژەڵێک بکوژێت، قەرەبووی دەکاتەوە، بەڵام ئەوەی کەسێک بکوژێت دەکوژرێتەوە.
\v 22 یەک یاساتان دەبێت، بیانی وەک هاوڵاتی دەبێت، من یەزدانی پەروەردگارتانم.“»
\p 
\v 23 جا موسا بە نەوەی ئیسرائیلی گوت، ئەوەی نەفرەتی کردووە، بیبەنە دەرەوەی ئۆردوگاکە و بەردبارانی بکەن. نەوەی ئیسرائیلیش ئاوایان کرد، هەروەک یەزدان فەرمانی بە موسا کرد.
\c 25
\s1 ساڵی پشوو
\p 
\v 1 هەروەها یەزدان لە شاخی سینا بە موسای فەرموو:
\v 2 «لەگەڵ نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”کاتێک هاتنە ئەو خاکەی من پێتان دەدەم، با خاکەکە شەممە بۆ یەزدان بپارێزێت.
\v 3 شەش ساڵ کێڵگەکەت دەڕوێنیت و شەش ساڵ ڕەزەکەت پەرچ دەکەیت و بەروبوومی کۆدەکەیتەوە.
\v 4 بەڵام لە ساڵی حەوتەم دەبێتە پشووی خاک، شەممەیە بۆ یەزدان، کێڵگەکەت مەڕوێنە و ڕەزەکەت پەرچ مەکە.
\v 5 ئەوەی لە دروێنە لێت کەوتووە و ئێستا ڕواوەتەوە، دروێنەی مەکە، ترێی ڕەزەکەشت، هی ئەو لقانەی پەرچ نەکراون، لێ مەکەرەوە. ساڵی پشوودان دەبێت بۆ خاکەکە.
\v 6 هەر شتێک خاکەکە لە ساڵی پشوودا بە خۆڕستی بەرهەمی دەهێنێت، ئەوا دەبێتە خۆراکتان، بۆ تۆ و کۆیلەکەت و کەنیزەکەت یان کرێگرتەکەت و نیشتەجێی کاتی کە لەلای تۆ دەژیێت،
\v 7 هەروەها بۆ ئاژەڵە ماڵییەکانت و بۆ ئەو ئاژەڵە کێوییە دەبێت کە لە خاکەکەتە. هەموو بەروبوومی خاکەکە دەبێتە خۆراک.
\s1 ساڵی پەنجایەمین ساڵی یۆبیلە
\p 
\v 8 «”حەوت پشووی ساڵانە بۆ خۆت دەژمێریت، حەوت جار حەوت ساڵ، جا ڕۆژانی حەوت پشووە ساڵانەکە بۆ تۆ دەبێتە چل و نۆ ساڵ،
\v 9 ئینجا لە ڕۆژی دەی مانگی حەوت، کەڕەنا لێ دەدەیت لە ڕۆژی کەفارەت، کەڕەنا بە هەموو خاکەکەتان دەگێڕن.
\v 10 ساڵی پەنجایەمین تەرخان دەکەن و بانگەوازی ئازادکردن لە زەوییەکەدا ڕادەگەیەنن بۆ هەموو دانیشتووانەکەی، بۆتان دەبێتە یۆبیل\f + \fr 25:10 \ft 25‏:10 یۆبیل وشەیەکی عیبرییە بە واتای بەران دێت، ساڵی یۆبیل ساڵی ئازادکردنی کۆیلە و لێخۆشبوونە لە قەرز، لەو ساڵەدا کە فوو بە قۆچی بەران دەکەن وەک کەڕەنا ئیتر ئەوە ڕاگەیاندنە بۆ گەڕانەوەی هەموو ماڵوموڵکێک بۆ خاوەنەکەی خۆی.‏\f* و هەریەکە و بۆ موڵکی خۆی دەگەڕێتەوە و هەریەکە و بۆ خێڵەکەی خۆی دەگەڕێتەوە.
\v 11 ساڵی پەنجایەمین یۆبیل، ناڕوێنن و ئەوەی خۆڕسکە نایدروونەوە و ڕەزی پەرچ نەکراو ناڕنن.
\v 12 ئەوە یۆبیلە و پیرۆز دەبێت بۆتان، ئەو ساڵە تەنها ئەوە بخۆن کە ڕاستەوخۆ لە کێڵگەوە دەستتان دەکەوێت.
\p 
\v 13 «”لەم ساڵی یۆبیلە هەرکەسە دەگەڕێتەوە سەر موڵکی خۆی.
\p 
\v 14 «”جا کاتێک زەوی و زارت بە هاونیشتیمانیت فرۆشت یان لێت کڕی، با کەستان ستەم لەوی دیکەتان نەکات.
\v 15 بەگوێرەی ژمارەی ساڵەکانی دوای یۆبیل لە هاونیشتیمانییەکەت دەکڕیت و بەگوێرەی ساڵەکانی کە ماوەتەوە بۆ خەرمانان پێت دەفرۆشێت.
\v 16 بەگوێرەی زۆری ساڵەکان نرخی زیاد دەکەیت و بەگوێرەی کەمی ساڵەکان نرخی کەم دەکەیتەوە، چونکە ژمارەی بەروبوومەکەت پێ دەفرۆشێت.
\v 17 جا ستەم لە یەکتری مەکەن، بەڵکو لە خوداتان بترسن، من یەزدانی پەروەردگارتانم.
\p 
\v 18 «”فەرزەکانم بەجێبهێنن و ئاگاداری ئەوە بن کە گوێڕایەڵی یاساکانم بن و کاریان پێ بکەن، بۆ ئەوەی بە ئاسوودەیی لە خاکەکە نیشتەجێ بن.
\v 19 زەوییەکەش بەروبوومەکەی دەدات، جا هەتا تێر دەبن لێی دەخۆن و بە ئاسوودەیی تێیدا نیشتەجێ دەبن.
\v 20 ئەگەر بڵێن: ’لە ساڵی حەوتەم چی بخۆین، ئەگەر نەچێنین و بەروبووممان کۆنەکەینەوە؟‘
\v 21 ئەوا من فەرمانی بەرەکەتی خۆم دەدەم بۆتان لە ساڵی شەشەمدا، جا بەروبوومی سێ ساڵ دەدات.
\v 22 ساڵی هەشتەم دەچێنن و لە بەروبوومە کۆنەکە دەخۆن، هەتا ساڵی نۆیەم بەروبوومەکەی دەدات لە کۆنەکە دەخۆن.
\p 
\v 23 «”زەوییەکەش هەمیشە هەتاسەر نافرۆشرێت، چونکە زەوییەکە هی منە و ئێوە نامۆ و کرێگرتەی منن،
\v 24 بەڵکو لە هەموو ئەو خاکەی ئەو زەوییەی موڵکتان بووە، پێویستە کڕینەوە بۆ زەوییەکە دابنێن.
\p 
\v 25 «”ئەگەر هاونیشتیمانیێکت هەژار بوو و لە موڵکەکەی خۆی فرۆشت، ئەوا نزیکترین خزمی دێت و فرۆشراوی هاوڵاتییەکەی دەکڕێتەوە.
\v 26 ئەگەر کەسێکیش خزمی نەبێت زەوییەکەی بۆ بکڕێتەوە، بەڵام ئەگەر خۆی توانی و ئەوەندەی دەستکەوتەوە کە بەشی کڕینەوەکە بکات،
\v 27 ئەوا نرخی ئەو ساڵانە دەژمێرێت لە کاتی فرۆشتنەکەوە و ئەوەندەی دەمێنێتەوە بۆ هاوسەنگکردنی نرخەکە دەداتەوە ئەو کەسە کە پێی فرۆشتووە، ئینجا دەگەڕێتەوە بۆ موڵکەکەی.
\v 28 بەڵام ئەگەر ئەوەندەی لە دەست نەبێت کە بۆی بگەڕێنێتەوە، ئەوا لە دەستی کڕیار دەبێت هەتا ساڵی یۆبیل. ئینجا لە یۆبیلدا دەگەڕێتەوە، ئەو کاتە خاوەنەکەی دەتوانێت بگەڕێتەوە بۆ موڵکەکەی.
\p 
\v 29 «”ئەگەر لە شارێکی شوورابەند یەکێک خانووی نیشتەجێبوونی فرۆشت، ئەوا مافی کڕینەوەکەی هەتا تەواوی ساڵێک دەبێت لە کاتی فرۆشتنەوە، لە ماوەی ئەو کاتەدا دەتوانێت بیکڕێتەوە.
\v 30 ئەگەر هەتا تەواوبوونی ئەو ساڵە نەیکڕێتەوە، ئەوا ئەو خانووەی لە شارە شوورابەندەکەیە بە هەمیشەیی هەتاسەر بۆ کڕیارەکە دەبێت، بۆ نەوەکانی و لە یۆبیلدا ناگەڕێتەوە.
\v 31 بەڵام خانوو لە لادێی شوورابەند نەبێت، ئەوا وەک کێڵگە هەژمارد دەکرێت، کڕینەوەی هەیە و لە یۆبیلدا دەگەڕێتەوە.
\p 
\v 32 «”لە شارۆچکەکانی لێڤییەکان، لێڤییەکان هەمیشە مافی کڕینەوەی ماڵەکانیان هەیە، کە موڵکی خۆیانە.
\v 33 ماڵەکانی لێڤییەکان مافی کڕینەوە و گەڕانەوەی\f + \fr 25:33 \ft لێرە فرۆشتن و کڕینەکە تەنها بۆ ماوەیەک دیاریکراو بووە، واتا پێویست بووە کڕیار لە ساڵی یۆبیل فرۆشراوەکە بگەڕێنێتەوە بۆ خاوەنەکەی. تەنها لە شارۆچکەکانی لێڤییەکان بەم شێوازە بووە.‏\f* هەیە، لە ساڵی یۆبیل، چونکە خانووی شارۆچکەکانی لێڤییەکان موڵکی ئەوانە لەنێو نەوەی ئیسرائیل.
\v 34 بەڵام لەوەڕگای دەوروبەری شارۆچکەکانیان نافرۆشرێت، چونکە موڵکێکی هەتاهەتاییە بۆیان.
\p 
\v 35 «”ئەگەر یەکێک لە هاوڵاتیانت هەژار و دەستکورت بوو لەنێوتان، پشتگیری بکە، هەروەک چۆن پشتگیری نامۆ یان نیشتەجێی کاتی دەکەیت، با لەنێوتان بژیێت.
\v 36 نە سووی لێ وەربگرە و نە قازانج، بەڵکو لە خوداکەت بترسە و با هاونیشتیمانیت لەنێوتان بژیێت،
\v 37 نە پارەکەتی بە سوو پێبدە و نە خۆراکەکەتی بە قازانج پێبدە.
\v 38 من یەزدانی پەروەردگارتانم کە لە خاکی میسر دەریهێنان هەتا خاکی کەنعانتان بداتێ و ببێت بە خوداتان.
\p 
\v 39 «”ئەگەر هاوڵاتییەکت لەنێوتان هەژار بوو و خۆی فرۆشتە تۆ، وەک کۆیلە کۆیلایەتی پێ مەکە،
\v 40 بەڵکو وەک کرێگرتە و نیشتەجێی کاتی لەنێوتان دەبێت، هەتا ساڵی یۆبیل لەلات کار دەکات.
\v 41 ئینجا خۆی و کوڕەکانی لەلات ئازاد دەبن و بۆ خێڵەکەی خۆی و بۆ موڵکی باوباپیرانی دەگەڕێتەوە.
\v 42 لەبەر ئەوەی گەلی ئیسرائیل بەندەی منن، ئەوانەی لە خاکی میسرەوە دەرمهێنان، بۆیە نابێت وەک کۆیلە بفرۆشرێن.
\v 43 بە توندوتیژی بەسەریاندا زاڵ مەبە، بەڵکو لە خودات بترسە.
\p 
\v 44 «”بەڵام کۆیلەکانت و کەنیزەکانت ئەوانەی دەبنە هی تۆ، ئەوا لەو گەلانەی دەوروبەرتان دەبن، لەوان کۆیلە و کەنیزە بۆ خۆتان پەیدا دەکەن.
\v 45 هەروەها لە نەوەی ئەوانەی لای ئێوە نیشتەجێی کاتین و لە خێڵەکانیان کە لەنێوتانن پەیدای دەکەن، ئەوانەی لە خاکی ئێوە لەدایک دەبن، ئەوان دەبنە موڵکی ئێوە.
\v 46 دەیانکەنە موڵکی کوڕانتان لەدوای خۆتان وەک میرات بۆیان، هەتاسەر دەیانکەنە کۆیلە، بەڵام براکانتان لە نەوەی ئیسرائیل، ئەوا هیچ کەسێک بە توندوتیژی بەسەر براکەیدا زاڵ نابێت.
\p 
\v 47 «”ئەگەر نامۆیەک یان نیشتەجێیەکی کاتی لەنێوتان دەوڵەمەند بوو، یەکێک لە هاوڵاتیانتان هەژار بوو و خۆی بەو نامۆیە فرۆشت کە لەنێوتان دەژی، یان بە ئەندامی خێڵی نامۆکە،
\v 48 ئەوا دوای فرۆشتنەکەی کڕینەوەی بۆ دەبێت، یەکێک لە خزمەکانی دەیکڕێتەوە.
\v 49 مامی یان ئامۆزای دەیکڕێتەوە، یەکێک لە خزمەکانی لە خێڵەکەی دەیکڕێتەوە، یان ئەگەر توانای ماددی هەبوو ئەوا خۆی دەکڕێتەوە.
\v 50 لەگەڵ کڕیارەکەی لە ساڵی فرۆشتنییەوە هەتا ساڵی یۆبیل دەژمێرێت و نرخی ئازادبوونی بەپێی نرخی پێدانی کرێگرتەیەک دەبێت لە ماوەی ئەو چەند ساڵەدا.
\v 51 ئەگەر ساڵانێکی زۆر مابێت، ئەوا پێویستە ئەو پارەیە بگەڕێنێتەوە لە نرخی کڕینەکەی بەپێی ژمارەی ئەو ساڵانەی کە ماوەتەوە.
\v 52 ئەگەر ساڵانێکی کەم مابێتەوە هەتا ساڵی یۆبیل، ئەوا پێویستە ئەو پارەیە بگەڕێنێتەوە لە نرخی کڕینەکەی بەپێی ژمارەی ئەو ساڵانەی کە ماوەتەوە،
\v 53 وەک کرێگرتەیەک هەڵسوکەوتی لەگەڵ دەکرێت، لە ساڵێکەوە بۆ ساڵێکی دیکە. پێویستە ئاگاداربن خاوەنەکەی بە توندوتیژی بەسەریدا زاڵ نەبێت.
\p 
\v 54 «”ئەگەر بەو شێوازانەی پێشوو نەکڕدرێتەوە، ئەوا لە ساڵی یۆبیل خۆی و منداڵەکانی ئازاد دەکرێن،
\v 55 چونکە نەوەی ئیسرائیل بەندەن بۆ من، ئەوان بەندەی منن، ئەوانەی لە خاکی میسرەوە دەرمهێنان، من یەزدانی پەروەردگارتانم.
\c 26
\s1 پاداشتی گوێڕایەڵی
\p 
\v 1 «”بت بۆ خۆتان دروستمەکەن و پەیکەری تاشراو و بەردی تەرخانکراو\f + \fr 26:1 \ft مەبەست لەو بەردانەیە بە ستوونی ڕاگیراون بۆ پەرستن. بڕوانە دواوتار 16‏:21‏-22.‏\f* دامەمەزرێنن، لە خاکەکەتان بەردی وێنە لەسەر کێشراو دامەنێن، هەتا کڕنۆشی بۆ ببەن، چونکە من یەزدانی پەروەردگارتانم.
\p 
\v 2 «”شەممەکانم بپارێزن و ڕێز لە پیرۆزگاکەم بگرن، من یەزدانم.
\p 
\v 3 «”ئەگەر فەرزەکانم بەجێبهێنن و فەرمانەکانم بەجێبگەیەنن و کاری پێ بکەن،
\v 4 ئەوا لە کاتی خۆی بارانتان دەدەمێ و زەویش بەری خۆی دەدات و درەختەکانی کێڵگەش بەروبووم دەدات.
\v 5 گێرەکردنتان بەردەوام دەبێت هەتا چنینەوەی ترێ و چنینەوەی ترێ بەردەوام دەبێت هەتا چاندن، جا هەر خواردنێکتان حەز لێبوو، دەیخۆن و بە ئاسوودەیی لە خاکەکەتان نیشتەجێ دەبن.
\p 
\v 6 «”ئاشتیش لە خاکەکەدا دەنێمەوە، جا دەخەون و کەس ناتانترسێنێت، گیانلەبەرە دڕندەکانیش لە خاکەکەدا لادەبەم و شمشێر بە خاکەکەتاندا تێناپەرێت.
\v 7 دوژمنەکانتان ڕاودەنێن و لەبەردەمتان بە شمشێر دەکوژرێن.
\v 8 پێنج لە ئێوە سەد ڕاودەنێن و سەد لە ئێوە ڕاوی دە هەزار دەنێن و دوژمنەکانتان لەبەردەمتان بە شمشێر دەکوژرێن.
\p 
\v 9 «”ئاوڕتان لێ دەدەمەوە و بە بەروبوومتان دەکەم و زیادتان دەکەم و پەیمانم لەگەڵتان دەبەمەسەر،
\v 10 جا لە بەروبوومی دروێنەی ساڵی پێشوو دەخۆن و بۆ ئەمبارکردنی بەروبوومی نوێ، کۆنەکە دەردەهێنن.
\v 11 نشینگەکەم لەنێوتان دادەنێم و قێزتان لێ ناکەمەوە،
\v 12 لەنێوتان هاتوچۆ دەکەم و دەبم بە خودای ئێوە و ئێوەش دەبن بە گەلی من.
\v 13 من یەزدانی پەروەردگارتانم کە لە خاکی میسر دەریهێنان، لەوەی کە کۆیلەی ئەوان بوون و کۆتی نیری\f + \fr 26:13 \ft مەبەستی لە بارگرانییە.‏\f* ئێوەی شکاند و بە سەربەرزییەوە بەڕێی کردن.
\s1 سزادان بۆ گوێڕایەڵنەبوون
\p 
\v 14 «”بەڵام ئەگەر گوێم لێ نەگرن و هەموو ئەم فەرمانانە جێبەجێ نەکەن،
\v 15 ئەگەر فەرزەکانم ڕەت بکەنەوە و قێزتان لە یاساکانم ببێتەوە و فەرمانەکانم بەجێنەهێنن، بەڵکو پەیمانەکەم بشکێنن،
\v 16 ئەوا من ئەمەتان پێ دەکەم، ترس و تۆقین و نەخۆشی سیل و تایەکتان دەهێنمە سەر کە چاوتان کوێر بکات و گیانتان بشێوێنێت، بێهوودە کشتوکاڵەکەتان دەچێنن، چونکە دوژمنەکانتان دەیخۆن.
\v 17 من ڕووتان لێ وەردەگێڕم، جا دوژمنەکانتان دەتانشکێنن و ناحەزەکانتان بەسەرتاندا زاڵ دەبن و کەسیش بەدواتانەوە نەبێت هەر هەڵدێن.
\p 
\v 18 «”ئەگەر لەگەڵ ئەوەش هەر گوێم لێ نەگرن، ئەوا حەوت قات بۆ گوناهەکانتان سزاتان دەدەم.
\v 19 جا لەخۆبایی کەللەڕەقیتان دەشکێنم و ئاسمانتان وەک ئاسن لێ دەکەم و زەویتان وەک بڕۆنز،
\v 20 بێهوودە ماندوو دەبن و زەویتان بەری خۆی نادات و درەختی زەوی بەروبوومی نادات.
\p 
\v 21 «”ئەگەر بە پێچەوانە لەگەڵم جوڵانەوە و نەتانویست گوێم لێ بگرن، ئەوا جارێکی دیکە حەوت قات کارەساتەکەتان لەسەر زیاد دەکەم، بەگوێرەی گوناهەکانتان.
\v 22 دڕندەی کێویتان بۆ بەڕەڵا دەکەم و بێ منداڵتان دەکات و مەڕوماڵاتتان قڕ دەکات و کەمتان دەکاتەوە، جا ڕێگاتان چۆڵ دەبێت.
\p 
\v 23 «”ئەگەر بەوەش تەمبێ نەبوون و بەڵکو بە پێچەوانەوە لەگەڵم جوڵانەوە،
\v 24 ئینجا منیش بە پێچەوانەوە لەگەڵتان دەجوڵێمەوە و حەوت قات بۆ گوناهەکانتان ئازارتان دەدەم.
\v 25 شمشێرێکتان دەهێنمە سەر، تۆڵەی تووڕەیی پەیمانەکەتان لێ دەکاتەوە، جا لە شارۆچکەکانتان کۆدەبنەوە و دەرد دەنێرمە نێوانتان و دەدرێنە دەست دوژمن.
\v 26 کە نان بڕاوتان دەکەم، هەموو نانەکەتان بە دە ژن و لە یەک تەنوور دەکرێت، بە پێوانەش بەشی دەکەن و دەیخۆن، بەڵام تێر نابن.
\p 
\v 27 «”ئەگەر بەوەش گوێم لێ نەگرن، بەڵکو بە پێچەوانەوە لەگەڵم جوڵانەوە،
\v 28 ئەوا بە پێچەوانەوە لەگەڵتان دەجوڵێمەوە بە تووڕەییم و حەوت قات بۆ گوناهەکانتان سزاتان دەدەم.
\v 29 جا گۆشتی کوڕ و کچەکانتان دەخۆن.
\v 30 نزرگەکانی سەر بەرزاییتان\f + \fr 26:30 \ft مەبەست لەو شوێنە بەرزانەیە کە بۆ قوربانیکردن و ڕێوڕەسمی پەرستنی بتەکان بووە.‏\f* وێران دەکەم و قوربانگاکانی بخوورتان تەخت دەکەم، لاشەکانتان فڕێدەدەمە سەر لاشەی بتەکانتان و قێزتان لێ دەکەمەوە.
\v 31 شارۆچکەکانتان وێران دەکەم و شوێنە پیرۆزەکانتان دەکەمە چۆڵەوانی، بۆنەکانی خۆشی قوربانی ئێوە دڵخۆشم ناکات.
\v 32 خاکەکە دەکەمە چۆڵەوانی و دوژمنەکانتان کە تێیدا نیشتەجێ دەبن، سەرسام دەبن.
\v 33 بەناو نەتەوەکاندا پەرشوبڵاوتان دەکەمەوە و شمشێرەکەم هەڵدەکێشم و ڕاوتان دەنێم. جا خاکەکەتان دەبێتە چۆڵەوانی و شارۆچکەکانتان وێران دەبێت.
\v 34 پاشان هەموو ڕۆژانی چۆڵبوونی، زەوییەکە پشووی ساڵەکانی\f + \fr 26:34 \ft بڕوانە \xt 25‏:4‏\xt*\ft .‏\f* خۆی وەردەگرێت، ئێوەش لە خاکی دوژمنەکانتان دەبن؛ ئەوسا زەوییەکە پشوو دەدات و سوود لە پشووەکانی وەردەگرێت.
\v 35 هەموو ڕۆژانی چۆڵبوونی پشوو دەدات، ئەو پشووانەی کە ئێوە پێتان نەدەدا، کاتێک تێیدا نیشتەجێ بوون.
\p 
\v 36 «”ئەوانەی لێتان دەمێنێتەوە، ئەوا ترسنۆکی دەخەمە دڵیان لە خاکی دوژمنانیان و دەنگی گەڵایەکی هەڵوەریو دەیانبەزێنێت، جا وەک لە شمشێر هەڵبێن ئاوا هەڵدێن و بێ ئەوەی کەس ڕاویان بنێت دەکەون.
\v 37 بەسەر یەکتردا دەکەون هەروەک لە شمشێر هەڵبێن و بێ ئەوەی کەس ڕاویان بنێت، لەبەردەم دوژمنەکانتان هەستانەوەتان نابێت،
\v 38 جا لەنێو گەلان لەناودەچن و خاکی دوژمنانتان دەتانخوات.
\v 39 ئەوانەی لێتان دەمێنێتەوە ئەوا لە خاکی دوژمنانتان بە گوناهەکانیانەوە لەناودەچن، هەروەها بە گوناهی باوکانیشیانەوە لەناودەچن.
\p 
\v 40 «”بەڵام ئەگەر دانیان بە گوناهەکانی خۆیان و باوک و باپیرانیاندا نا، لەو ناپاکییەی لەگەڵ من کردیان کە بە پێچەوانەوە لەگەڵم جوڵانەوە،
\v 41 لەبەر ئەوە منیش بە پێچەوانەوە لەگەڵیاندا جوڵامەوە و ئەوانم بردە خاکی دوژمنانیان هەتا دڵە خەتەنەنەکراوەکانیان بێفیز بێت و باجی گوناهەکانیان بدەنەوە،
\v 42 ئەوا پەیمانەکەم لەگەڵ یاقوب بەبیر دێتەوە. هەروەها پەیمانەکەم لەگەڵ ئیسحاق و پەیمانەکەم لەگەڵ ئیبراهیم و خاکەکەشم بەبیر دێتەوە.
\v 43 خاکەکەش لەلایەن ئەوانەوە چۆڵ دەکرێت و سوود لە پشووەکانی\f + \fr 26:43 \ft پشووەکان: لە زمانی عیبری بە واتای شەممەکان دێت.‏\f* وەردەگرێت کاتێک بەبێ ئەوان چۆڵەوانییە. ئەوانیش باجی گوناهەکانیان دەدەنەوە، چونکە یاساکانی منیان ڕەتکردەوە و لە ناخەوە قێزیان لە فەرزەکانم بووەوە.
\v 44 بەڵام لەگەڵ ئەوەشدا کاتێک لە خاکی دوژمنانیان بوون، ڕەتم نەکردنەوە و قێزم لێیان نەکردەوە، هەتا بە تەواوی لەناویان ببەم و پەیمانم لەگەڵیان بشکێنم، چونکە من یەزدانی پەروەردگاریانم.
\v 45 بەڵکو لە پێناویان یادی ئەو پەیمانەیان بۆ دەکەمەوە کە لەگەڵ باوباپیرانیان بەستم، ئەوانەی لەبەرچاوی نەتەوەکان لە خاکی میسرەوە دەرمهێنان هەتا ببمە خودای خۆیان. من یەزدانم.“»
\p 
\v 46 ئەوانە فەرز و یاسا و ڕێنماییەکانن کە یەزدان لەنێوان خۆی و نەوەی ئیسرائیلدا داینا، لە شاخی سینا لەسەر دەستی موسا.
\c 27
\s1 کڕینەوەی ئەوەی هی یەزدانە
\p 
\v 1 هەروەها یەزدان بە موسای فەرموو
\v 2 «لەگەڵ نەوەی ئیسرائیل بدوێ و پێیان بڵێ: ”ئەگەر کەسێک کەسێکی بۆ یەزدان نەزر کرد، ئەوا ئاوای دەخەمڵێنێت،
\v 3 ئەگەر خەمڵاندنەکەت بۆ نێرێکی تەمەن بیست هەتا شەست ساڵ بوو، ئەوا خەمڵاندنەکەت پەنجا شاقل\f + \fr 27:3 \ft هەر شاقلێک یازدە گرام و نیوە.‏\f* زیو بەگوێرەی شاقلی پیرۆزگا دەبێت.
\v 4 ئەگەر مێینەش بوو، ئەوا خەمڵاندنەکەت سی شاقل دەبێت.
\v 5 ئەگەر تەمەنی پێنج هەتا بیست ساڵ بوو، ئەوا خەمڵاندنەکەت بیست شاقل بۆ نێر و دە شاقل بۆ مێ دەبێت.
\v 6 ئەگەر تەمەنی مانگێک هەتا پێنج ساڵ بوو، ئەوا خەمڵاندنەکەت پێنج شاقل زیو بۆ نێر و سێ شاقل زیو بۆ مێ دەبێت.
\v 7 ئەگەر تەمەنی شەست ساڵ و بەرەو سەرەوە بوو، ئەوا خەمڵاندنەکەت پازدە شاقل بۆ نێر و دە شاقل بۆ مێ دەبێت.
\v 8 ئەگەر کەسێک نەزری کرد و ئەو کەسە هەژار بوو و ئەو خەمڵاندنەی لە توانادا نەبوو، ئەوا نەزرەکە دەهێنێتە بەردەم کاهین و کاهینەکەش بۆی دەخەمڵێنێت. بەگوێرەی توانای ئەو کەسەی نەزرەکەی کردووە کاهینەکە بۆی دەخەمڵێنێت.
\p 
\v 9 «”ئەگەر نەزرەکە ئاژەڵ بێت، لەوانەی پەسەندە وەک قوربانی بۆ یەزدان، ئەوا هەموو ئەوەی لێی دەدرێت بە یەزدان، پیرۆز دەبێت.
\v 10 پێویستە نەیگۆڕێت و ئاڵوگۆڕی پێ نەکات، باش بە خراپ یان خراپ بە باش، ئەگەر ئاژەڵێکی بە ئاژەڵێکی دیکە ئاڵوگۆڕ کرد، ئەوا هەردوو ئاژەڵەکە پیرۆز دەبن.
\v 11 ئەگەر نەزرەکە بەپێی ڕێوڕەسم ئاژەڵێکی گڵاو بوو، لەوانەی کە قبوڵ نییە وەک قوربانی بۆ یەزدان، ئەوا پێویستە ئاژەڵەکە بهێنرێتە بەردەم کاهین.
\v 12 جا نرخەکەی دەخەمڵێنێت، هەر چۆنێک بێت باش یان خراپ، ئەو نرخەی کاهین دەیخەمڵێنێت، هەر ئەوە دەبێت.
\v 13 جا ئەگەر خاوەنەکەی ویستی ئاژەڵەکە بکڕێتەوە، ئەوا پێویستە پێنج یەک بخاتە سەر خەمڵاندنەکە.
\p 
\v 14 «”ئەگەر یەکێک ماڵەکەی تەرخان کرد هەتا بۆ یەزدان پیرۆزکراو بێت، ئەوا کاهینەکە دەیخەمڵێنێت باش بێت یان خراپ، کاهینەکە چۆنی بخەمڵێنێت ئاوا دەبێت.
\v 15 ئەگەر ئەو کەسە ویستی ماڵە تەرخانکراوەکەی بکڕێتەوە ئەوا پێنج یەکی نرخی خەمڵاندنەکە دەخاتە سەری و دەبێتەوە هی خۆی.
\p 
\v 16 «”ئەگەر کەسێک بەشێکی لە کێڵگەکەی موڵکی خێزانی خۆی بۆ یەزدان تەرخان کرد، ئەوا خەمڵاندنەکە بەگوێرەی تۆوکردن تێیدا دەبێت، جێی حۆمەرێک\f + \fr 27:16 \ft (حۆمەر) نزیکەی 135 کیلۆگرامی تۆوی جۆ. بڕوانە پاشکۆی کتێبەکە.‏\f* تۆوی جۆ بە پەنجا شاقل زیو دەبێت.
\v 17 ئەگەر لە ساڵی یۆبیلدا\f + \fr 27:17 \ft لە ساڵی یۆبیلدا: بڕوانە 25‏:8 هتد.‏\f* کێڵگەکەی تەرخان کرد، ئەوا بەگوێرەی ئەو خەمڵاندنەی کە دانراوە دەمێنێتەوە.
\v 18 بەڵام ئەگەر لەدوای ساڵی یۆبیل کێڵگەکەی تەرخان کرد، ئەوا کاهینەکە بەگوێرەی ئەو ساڵانەی ماوەتەوە بۆ ساڵی ئاییندەی یۆبیل، نرخەکەی بۆ دەژمێرێت. لە خەمڵاندنەکە کەم دەکاتەوە.
\v 19 ئەگەر ئەو کەسەی کێڵگەکەی تەرخان کردووە ویستی کێڵگەکە بکڕێتەوە، ئەوا پێنج یەکی نرخی خەمڵاندنەکە دەخاتە سەری و کێڵگەکە بۆ ئەو دەبێت.
\v 20 بەڵام ئەگەر کێڵگەکەی نەکڕییەوە یان کێڵگەکەی بە کەسێکی دیکە فرۆشت، ئەوا ئیتر ناکڕدرێتەوە،
\v 21 بەڵکو کێڵگەکە لە ساڵی یۆبیل ئازاد دەکرێت، پیرۆز دەبێت، وەک کێڵگەی ڕاگیراو\f + \fr 27:21 \ft بە واتای وەستێنراویش دێت، هەر موڵکێک و هەر گیانلەبەرێک ئاژەڵ بێت یان مرۆڤ کە جیا کرایەوە بۆ خزمەتی خودا، ئیتر هەرگیز گەڕانەوەی بۆ نابێت و کڕین و فرۆشتنی لەسەر ناکرێت. لێرە و لە ئایەتی 28.‏\f* بۆ یەزدان. ئەو کاتە دەبێتە موڵکی کاهینەکان.
\p 
\v 22 «”ئەگەر کێڵگەیەکی کڕاوی بۆ یەزدان تەرخان کرد، کە لە کێڵگەکانی موڵکی خێزانی نەبوو،
\v 23 ئەوا کاهینەکە بڕی خەمڵاندنەکەی بۆ دەژمێرێت هەتا ساڵی یۆبیل، جا کەسەکە لەو ڕۆژە نرخی خەمڵاندنەکە دەدات، وەک تەرخانکراوی پیرۆز بۆ یەزدان.
\v 24 لە ساڵی یۆبیلیش کێڵگەکە دەگەڕێتەوە بۆ ئەوەی لێی کڕیوە، بۆ خاوەنی ڕەسەنی زەوییەکە.
\v 25 هەموو خەمڵاندنەکەش بەپێی شاقلی پیرۆزگا دەبێت، هەر شاقلێک بیست گیرە دەبێت.
\p 
\v 26 «”بەڵام هەر نۆبەرەیەکی ئاژەڵ کە وەک نۆبەرە بۆ یەزدان جیا دەکرێتەوە، با کەس تەرخانی نەکات، گا\f + \fr 27:26 \ft لە زمانی عیبری دەشێت ئەم وشەیە بۆ نێر و مێ (چێڵ و گا) بەکاربهێنرێت.‏\f* بێت یان بەران ئەوا بۆ یەزدانە؛
\v 27 ئەگەر لە ئاژەڵە گڵاوەکان بوو، ئەوا بەگوێرەی خەمڵاندنەکە دەیکڕێتەوە و پێنج یەکیشی دەخاتە سەر. ئەگەر نەیکڕییەوە ئەوا بەگوێرەی خەمڵاندنەکە دەفرۆشرێت.
\p 
\v 28 «”بەڵام هەموو ڕاگیراوێک\f + \fr 27:28 \ft لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان.‏\f* کە مرۆڤ بۆ یەزدانی تەرخان دەکات لە هەموو ئەوانەی هەیەتی، لە خەڵک و ئاژەڵ و کێڵگەکانی موڵکی خۆی، ئەوا نافرۆشرێت و ناکڕدرێتەوە، هەموو ڕاگیراوێک هەرەپیرۆزە بۆ یەزدان.
\p 
\v 29 «”هەرکەسێک تەرخانکراو بێت بۆ قڕکردن\f + \fr 27:29 \ft لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f* بە بارمتە ناکڕدرێتەوە، دەبێت بکوژرێت.
\p 
\v 30 «”هەموو دەیەکی زەوی لە دانەوێڵەی زەوی و بەروبوومی درەختەکان بۆ یەزدانە، پیرۆزە بۆ یەزدان.
\v 31 ئەگەر کەسێک هەندێک لە دەیەکەکەی خۆی کڕییەوە، ئەوا پێنجیەکی دەخاتە سەر،
\v 32 بەڵام گاگەل و مێگەل دەیەمی هەر ئاژەڵێک بەژێر گۆچانی شواندا تێبپەڕێت، ئەوا پیرۆز دەبێت بۆ یەزدان.
\v 33 نابێت تەماشا بکرێت ئاخۆ باشە یان خراپ و ئاڵوگۆڕی پێ ناکات، ئەگەر ئاڵوگۆڕی پێکرد، ئەوا هەردوو ئاژەڵەکە و ئالۆگۆڕکراوەکە پیرۆز دەبن بۆ یەزدان، ناکڕدرێنەوە.“»
\p 
\v 34 ئەمانە ئەو فەرمانانەن کە یەزدان فەرمانی بە موسا کرد بۆ نەوەی ئیسرائیل لە شاخی سینا.
