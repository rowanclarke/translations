\v 29 \w Si|strong="H3808"\w* \w ces|strong="H7971"\w* gens-là \w meurent|strong="H4191"\w* \w comme|strong="H3068"\w* \w tous|strong="H3605"\w* \w les|strong="H3068"\w* \w hommes|strong="H3068"\w* \w meurent|strong="H4191"\w*, \w et|strong="H3068"\w* s'\w ils|strong="H3068"\w* \w sont|strong="H3068"\w* \w punis|strong="H6485"\w* \w comme|strong="H3068"\w* \w tous|strong="H3605"\w* \w les|strong="H3068"\w* \w hommes|strong="H3068"\w* \w le|strong="H3068"\w* \w sont|strong="H3068"\w*, l'\w Éternel|strong="H3068"\w* \w ne|strong="H3808"\w* m'\w a|strong="H3068"\w* \w point|strong="H3808"\w* \w envoyé|strong="H7971"\w*;
\v 30 \w Mais|strong="H3588"\w* \w si|strong="H3588"\w* l'\w Éternel|strong="H3068"\w* \w crée|strong="H1254"\w* \w une|strong="H3068"\w* \w chose|strong="H3068"\w* \w toute|strong="H3605"\w* nouvelle, \w et|strong="H3068"\w* \w que|strong="H3588"\w* \w la|strong="H3068"\w* \w terre|strong="H3068"\w* \w ouvre|strong="H6475"\w* \w sa|strong="H3068"\w* \w bouche|strong="H6310"\w*, \w et|strong="H3068"\w* \w les|strong="H3068"\w* \w engloutisse|strong="H1104"\w* \w avec|strong="H3381"\w* \w tout|strong="H3605"\w* \w ce|strong="H3605"\w* \w qui|strong="H3068"\w* \w leur|strong="H3068"\w* \w appartient|strong="H3068"\w*, \w et|strong="H3068"\w* \w qu|strong="H3588"\w*'\w ils|strong="H6310"\w* \w descendent|strong="H3381"\w* \w vivants|strong="H2416"\w* \w au|strong="H3068"\w* \w Sépulcre|strong="H7585"\w*, \w vous|strong="H3068"\w* \w saurez|strong="H3045"\w* \w que|strong="H3588"\w* \w ces|strong="H3605"\w* \w hommes|strong="H3068"\w* \w ont|strong="H3068"\w* \w méprisé|strong="H5006"\w* l'\w Éternel|strong="H3068"\w*.
\v 31 \w Et|strong="H1697"\w* \w dès|strong="H1697"\w* \w qu|strong="H1697"\w*'\w il|strong="H1697"\w* eut \w achevé|strong="H3615"\w* \w de|strong="H1697"\w* \w prononcer|strong="H1696"\w* \w toutes|strong="H1696"\w* \w ces|strong="H1697"\w* \w paroles|strong="H1697"\w*, \w le|strong="H1696"\w* sol \w qui|strong="H1697"\w* \w était|strong="H1961"\w* \w sous|strong="H8478"\w* \w eux|strong="H1697"\w*, \w se|strong="H1697"\w* \w fendit|strong="H1234"\w*;
\v 32 \w Et|strong="H1004"\w* \w la|strong="H6605"\w* \w terre|strong="H6605"\w* \w ouvrit|strong="H6605"\w* \w sa|strong="H6310"\w* \w bouche|strong="H6310"\w*, \w et|strong="H1004"\w* \w les|strong="H3605"\w* \w engloutit|strong="H1104"\w* \w avec|strong="H6310"\w* \w leurs|strong="H1004"\w* \w familles|strong="H1004"\w*, \w et|strong="H1004"\w* \w tous|strong="H3605"\w* \w les|strong="H3605"\w* \w hommes|strong="H6310"\w* \w qui|strong="H3605"\w* étaient \w à|strong="H1004"\w* Coré, \w et|strong="H1004"\w* \w tout|strong="H3605"\w* \w leur|strong="H3605"\w* bien.
\v 33 \w Ils|strong="H1992"\w* \w descendirent|strong="H3381"\w*, \w eux|strong="H1992"\w* \w et|strong="H5921"\w* \w tout|strong="H3605"\w* \w ce|strong="H3605"\w* \w qui|strong="H1992"\w* \w leur|strong="H3381"\w* appartenait, \w vivants|strong="H2416"\w* \w au|strong="H3381"\w* \w Sépulcre|strong="H7585"\w*, \w et|strong="H5921"\w* \w la|strong="H5921"\w* \w terre|strong="H5921"\w* \w les|strong="H3605"\w* \w couvrit|strong="H3680"\w*; \w et|strong="H5921"\w* \w ils|strong="H1992"\w* périrent \w du|strong="H8432"\w* \w milieu|strong="H8432"\w* \w de|strong="H5921"\w* l'\w assemblée|strong="H6951"\w*.
\v 34 \w Et|strong="H3478"\w* \w tout|strong="H3605"\w* \w Israël|strong="H3478"\w*, \w qui|strong="H3478"\w* \w était|strong="H3478"\w* \w autour|strong="H5439"\w* d'\w eux|strong="H3588"\w*, \w s|strong="H3478"\w*'\w enfuit|strong="H5127"\w* \w à|strong="H3478"\w* \w leur|strong="H3588"\w* \w cri|strong="H6963"\w*; \w car|strong="H3588"\w* \w ils|strong="H3588"\w* disaient: Prenons garde \w que|strong="H3588"\w* \w la|strong="H3478"\w* \w terre|strong="H3588"\w* \w ne|strong="H3478"\w* \w nous|strong="H3588"\w* \w engloutisse|strong="H1104"\w*!
\v 35 \w Et|strong="H3068"\w* \w un|strong="H3068"\w* \w feu|strong="H3068"\w* \w sortit|strong="H3318"\w*, \w de|strong="H3318"\w* \w la|strong="H3068"\w* \w part|strong="H3068"\w* \w de|strong="H3318"\w* l'\w Éternel|strong="H3068"\w*, \w et|strong="H3068"\w* dévora \w les|strong="H3068"\w* \w deux|strong="H3318"\w* \w cent|strong="H3967"\w* \w cinquante|strong="H2572"\w* \w hommes|strong="H3967"\w* \w qui|strong="H3068"\w* \w offraient|strong="H7126"\w* \w le|strong="H3068"\w* \w parfum|strong="H7004"\w*.
\v 36 Puis l'Éternel parla à Moïse, en disant:
\v 37 Dis à Éléazar, fils d'Aaron, le sacrificateur, qu'il ramasse les encensoirs du milieu de l'embrasement, et répands-en le feu au loin; car ils ont été consacrés.
\v 38 Quant aux encensoirs de ceux qui ont péché contre leurs âmes, qu'on en fasse de larges plaques pour couvrir l'autel. Puisqu'ils les ont présentés devant l'Éternel, ils ont été consacrés; et ils serviront de signe aux enfants d'Israël.
\v 39 Éléazar, le sacrificateur, prit donc les encensoirs d'airain qu'avaient présentés ceux qui avaient été brûlés, et l'on en fit des plaques pour couvrir l'autel,
\v 40 En mémorial aux enfants d'Israël, afin qu'un étranger, qui n'est point de la race d'Aaron, ne s'approche point pour faire fumer le parfum devant l'Éternel, et qu'il ne soit comme Coré et comme ceux qui s'assemblèrent avec lui, ainsi que l'Éternel le lui avait dit par Moïse.
\v 41 Or le lendemain, toute l'assemblée des enfants d'Israël murmura contre Moïse et contre Aaron, en disant: Vous avez fait mourir le peuple de l'Éternel.
\v 42 Et il arriva, comme l'assemblée se formait contre Moïse et contre Aaron, qu'ils regardèrent vers le tabernacle d'assignation, et voici, la nuée le couvrit, et la gloire de l'Éternel apparut.
\v 43 Et Moïse et Aaron vinrent devant le tabernacle d'assignation.
\v 44 Et l'Éternel parla à Moïse, en disant:
\v 45 Otez-vous du milieu de cette assemblée, et je les consumerai en un moment. Mais ils tombèrent sur leurs visages,
\v 46 Et Moïse dit à Aaron: Prends l'encensoir, mets-y du feu de dessus l'autel et déposes-y du parfum, et \w va|strong="H3068"\w* promptement vers l'assemblée, et fais l'expiation pour eux; car l'indignation est sortie de devant l'Éternel; la plaie \w a|strong="H3068"\w* commencé.
\v 47 Et Aaron prit l'encensoir, comme Moïse le lui avait dit, et il courut au milieu de l'assemblée; et voici, la plaie avait déjà commencé parmi le peuple. Alors il mit le parfum, et fit l'expiation pour le peuple.
\v 48 Et il se tint entre les morts et les vivants, et la plaie fut arrêtée.
\v 49 Et il y en eut quatorze mille sept cents qui moururent de la plaie, outre ceux qui étaient morts à cause de Coré.
\v 50 Puis Aaron retourna vers Moïse, à l'entrée du tabernacle d'assignation, et la plaie fut arrêtée.
\c 17
\p 
\v 1 \w Puis|strong="H3068"\w* l'\w Éternel|strong="H3068"\w* \w parla|strong="H1696"\w* \w à|strong="H3068"\w* \w Moïse|strong="H4872"\w*, \w en|strong="H3068"\w* disant:
