\s1 The Lord Delivers Israel  
\p
\v 13  \w Now|strong="H3117"\w* \w a|strong="H3068"\w* \w prophet|strong="H5030"\w* \w visited|strong="H5066"\w* \w King|strong="H4428"\w* Ahab \w of|strong="H4428"\w* \w Israel|strong="H3478"\w* \w and|strong="H3478"\w* said, “\w This|strong="H2088"\w* \w is|strong="H3068"\w* \w what|strong="H2088"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w says|strong="H3541"\w*, ‘\w Do|strong="H3068"\w* \w you|strong="H3588"\w* \w see|strong="H7200"\w* \w this|strong="H2088"\w* \w huge|strong="H1995"\w* \w army|strong="H1995"\w*? \w Look|strong="H7200"\w*, \w I|strong="H3588"\w* \w am|strong="H3068"\w* \w going|strong="H2005"\w* \w to|strong="H3478"\w* \w hand|strong="H3027"\w* \w it|strong="H5414"\w* \w over|strong="H3027"\w* \w to|strong="H3478"\w* \w you|strong="H3588"\w* \w this|strong="H2088"\w* \w very|strong="H2088"\w* \w day|strong="H3117"\w*. \w Then|strong="H2009"\w* \w you|strong="H3588"\w* \w will|strong="H3068"\w* \w know|strong="H3045"\w* \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w am|strong="H3068"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd*.’”  
\v 14  Ahab asked, “\w By|strong="H3068"\w* \w whom|strong="H4310"\w* \w will|strong="H3068"\w* \w this|strong="H3541"\w* \w be|strong="H3068"\w* accomplished?” \w He|strong="H3068"\w* answered, “\w This|strong="H3541"\w* \w is|strong="H3068"\w* \w what|strong="H4310"\w* \w the|strong="H3541"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w says|strong="H3541"\w*, ‘\w By|strong="H3068"\w* \w the|strong="H3541"\w* \w servants|strong="H5288"\w* \w of|strong="H3068"\w* \w the|strong="H3541"\w* district \w governors|strong="H8269"\w*.’” Ahab asked, “\w Who|strong="H4310"\w* \w will|strong="H3068"\w* launch \w the|strong="H3541"\w* \w attack|strong="H4421"\w*?” \w He|strong="H3068"\w* answered, “\w You|strong="H4310"\w* \w will|strong="H3068"\w*.”   
\p
\v 15  \w So|strong="H1961"\w* Ahab \w assembled|strong="H6485"\w* \w the|strong="H3605"\w* 232 \w servants|strong="H5288"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* district \w governors|strong="H8269"\w*. \w After|strong="H1961"\w* \w that|strong="H5971"\w* \w he|strong="H3605"\w* \w assembled|strong="H6485"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w Israelite|strong="H3478"\w* \w army|strong="H5971"\w*, numbering 7,000.  
