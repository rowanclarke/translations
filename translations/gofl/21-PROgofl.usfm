\id PRO - Gofa Full Bible Latin Version Final
\h Leemiso Maxaafa
\toc1 Leemiso Maxaafa
\toc3 Leemi
\toc2 Leemiso
\mt1 Leemiso Maxaafa
\imt1 Gaatha Qofa
\ip Leemiso Maxaafay haysenne Leemiso odan giigida, duussa woganne ammano timirte. Ha maxaafape daro baggay gallas gallas ase gakiya hanotata odees. Maxaafay koyro doomishe, “Xoossas yashatethi cincatethas koyro” (\xt 1:7\xt*) yaagis. Ha maxaafay tamaarsey, ammano wogan asi oothanaba xalaala gidonashin, asi ba gallasa duussan hananaw bessiya lo77o kanduwanne oothanaw bessiya lo77o ooso gujidi tamaarsees.
\ip Leemiso maxaafatape baggay asa buzo de7oba odees; baggay issi soo asa duussaba odees; baggay oosobanne zal7eba odees. Leemiso maxaafay xoosse bonchiya asi “Cinca” gidi, Xoosse eronna asi “Eeya” gees. Leemiso maxaafay ashketethaba, cincatethaba, danda7aba qadhebaanne ammanetethaba daro timirte tamaarsees.
\iot Maxaafa Ayfe Qofata
\io1 Leemisota go77a \ior (1:1—9:18)\ior*
\io1 Solomone leemisota \ior (10:1—24:34)\ior*
\io1 Dumma dumma leemisota \ior (25:1—29:27)\ior*
\io1 Agura leemisota \ior (30:1-33)\ior*
\io1 Limu7eela aaye timirte \ior (31:1-31)\ior*
\c 1
\s1 Leemiso Go77a
\p 
\v 1 Haysati Isra7eele kawa Dawita na7aa Solomone leemisota.
\v 2 Leemisoti asay cincatethi, seeranne era haasaya akeekanaw maaddoosona.
\v 3 Enti cincatethi, xillotethi, suure pirdinne suure wozani daana mela tamaarsoosona.
\v 4 Eeyatas akeeka immees; na7atethatas eratethinne kahaamatethi immees.
\v 5 Cincati ha leemisota si7idi, era gujoosona; akeekanchoti lo77o zore ekoosona.
\v 6 Hessan leemisotanne enta birshethaa, cincatetha odaanne enta qan7isheta akeekanaw danda7etees.
\p 
\v 7 Godaas yashshi cincatethas doomethi; shin eeyati cincatethinne seera kadhoosona.
\s1 Cincatethi New Miishe Ootha
\q1 
\v 8 Ta na7aw, ne aawa zoriya si7a;
\q2 ne aaye timirtiya kadhopa.
\q1 
\v 9 Hessi ne huuphiyas boncho kallacha;
\q2 ne qoodhiyas gozda gidana.
\p 
\v 10 Ta na7aw, nena nagaranchoti
\q2 cimmiko ero goopa.
\q1 
\v 11 Enti, “Nuura yedha;
\q2 ase wodhanaw hokidi naagoos;
\q2 xillota wodhanaw qosetoos.
\q1 
\v 12 Si7ooley mitteysada nuka enta paxa mittoos;
\q2 nu enta ollan yegetiya asada oothana.
\q1 
\v 13 Nuuni al7o miishe ubbaa demmana;
\q2 nu keethaa bonqe miishen kunthana.
\q1 
\v 14 Nuura laggeta;
\q2 nu demmidaba issife shaaketana” yaagana.
\q1 
\v 15 Ta na7aw, entara hemetofa;
\q2 enta ogiyara baanaw ne tohuwa denthofa.
\q1 
\v 16 Enti iitabaa oothanaw woxoosona;
\q2 asa suuthi gussanaw yaa haa goosona.
\q1 
\v 17 Kafoy xeellishin,
\q2 iya oykanaw gite yegethi maaddenna.
\q1 
\v 18 Shin enti banta suuthi gussanaw hokosona;
\q2 banta shempuwa wodhanaw qosetoosona.
\q1 
\v 19 Genen go77a demmiya asa wursethi hessa mela;
\q2 enti shiishida shaloy enta shempuwa ekees.
\s1 Cincatethi Xeegees
\q1 
\v 20 Cincatethi daggala bolla eqada xeegawusu;
\q2 dabaaban ba qaala dhoqu oothada sissawusu.
\v 21 Cincatethi asi shiiqiya bessan eqada xeegawusu;
\q2 katamaa geliya pengen eqada haysada yaagawusu.
\q1 
\v 22 “Hinteno, akeeki pacidaysato,
\q2 hinte awude gakanaw eeya gididi daanee?
\q1 Qelqiseysato, awude gakanaw ufaytanee?
\q2 Eeyato, awude gakanaw eratethi ixanee?
\q1 
\v 23 Ta seera hinte si7idaba gidiyako,
\q2 taani ta eraa hinte bolla gussana;
\q2 ta qaalaka hintena tamaarsana.
\q1 
\v 24 Shin ta xeegida wode hinte koyonna ixida gisho;
\q2 taani kushe miccin oonika akeekibona gisho;
\q1 
\v 25 Ta zoriya hinte kadhida gisho;
\q2 ta seeraka ekiboonna gisho;
\q1 
\v 26 Hintena metoy gakiya wode ta miicana;
\q2 hinte dagaman kokoriya wode ta qelqisana.
\v 27 Gadoy uushoda hinte bolla yaa wode,
\q2 metoy goteda hinte bolla eqiya wode,
\q2 un7inne waayey hinte bolla gakiya wode,
\q2 taani hintena qelqisana.
\p 
\v 28 “He wode enti tana xeegana; shin ta koyke;
\q2 enti tana minthidi koyana; shin demmokona.
\v 29 Enti eratethi ixida gisho;
\q2 Godaa yashshi dooriboonna gisho,
\v 30 Ta zoriya ekiboonna gisho;
\q2 ta seera kadhida gisho;
\v 31 Enti banta oosuwa ayfiya maana;
\q2 banta qofaa ayfiya kallana.
\v 32 Akeeki pacidaysata cincatethafe haakeysi wodhees;
\q2 eeyata qelli guussi dhaysees.
\v 33 Shin ta odiyaba si7iya ubbay saro daana;
\q2 meto hirgafeka shempana.”
\c 2
\s1 Cincatetha Go77a
\p 
\v 1 Ta na7aw, ta timirtiya ne ekiko;
\q2 ta kiitaa ne wozanan wothiko;
\v 2 ne haythaa cincatethako zaariko;
\q2 ne wozanaa akeekako zaariko;
\q1 
\v 3 Eratethi xeegiko;
\q2 akeeka dhoqu oothada xeegiko;
\q1 
\v 4 Bira woyko geemmida miishe koyeysada,
\q2 neeni eratethi koyko,
\q1 
\v 5 He wode neeni Godaas yashshi guussi aybeko erana;
\q2 Xoossaa loythada erana.
\q1 
\v 6 Goday cincatethi immees;
\q2 iyape eratethinne akeeki bentees.
\q1 
\v 7 I suuretas maaddiya zore minjees;
\q2 borey baynaysatas gondalle gidees.
\q1 
\v 8 Suure pirda ogiya naagees;
\q2 iyaw ammaneteyisata ogiya minthees.
\q1 
\v 9 He wode neeni xillotethi, suure pirdaa,
\q2 suure ogenne lo77o oosoy aybeko akeekana.
\q1 
\v 10 Cincatethi ne wozana giddo gelana;
\q2 eratethi new ufaysi gidana.
\q1 
\v 11 Shaakidi eroy nena naagana;
\q2 akeeki nena kammana.
\q1 
\v 12 Cincatethi nena iita asata ogiyape naagana;
\q2 geella odape nena ashshana.
\q1 
\v 13 Enti nagara dhuman daanaw,
\q2 xillotetha ogiya aggidosona.
\q1 
\v 14 Iita ooson ufaytoosona;
\q2 geellatethan hashshu goosona.
\q1 
\v 15 Enta oosoy mirqethi;
\q2 enta de7oy geella.
\q1 
\v 16 Cincatethi layma maccasape,
\q2 qaalan cimmiya laggethofe nena ashshana.
\q1 
\v 17 Iya ba na7atetha azina aggaagasu;
\q2 Xoossa sinthan caaqida caaquwa dogasu.
\q1 
\v 18 I soo ogey hayqoko gathees;
\q2 iiko buussi moytilletako gathees.
\q1 
\v 19 Iiko biya oonika guye simmenna;
\q2 de7o oge demmenna.
\q1 
\v 20 Hessa aggada, lo77o asata leemisuwa kaalla;
\q2 xillo asata hemethaa naaga.
\q1 
\v 21 Suure asatinne borey baynaysati,
\q2 biittan adussa laythi daana.
\q1 
\v 22 Shin iitati biittafe shodetana;
\q2 ammanetonaysati dhayana.
\c 3
\s1 Godan Ammaneta
\q1 
\v 1 Ta na7aw, ta timirtiya dogopa;
\q2 ta kiitaa ne wozanan wotha.
\q1 
\v 2 Enti ne laytha adussana;
\q2 injenne sarotethi new gujana.
\q1 
\v 3 Siiqoynne tumatethi neepe haakofo;
\q2 enta ne qoodhen qacha; ne wozanan xaafa.
\q1 
\v 4 Hessa oothiko ne Xoossanne asa sinthan
\q2 sabetananne nashetana.
\q1 
\v 5 Ne kumetha wozanan Godaa ammaneta;
\q2 ne akeekan zempofa.
\q1 
\v 6 Ne ooso ubban iya sinthaya;
\q2 I nena suure oge kaalethana.
\q1 
\v 7 Nena ne huuphen cinca oothofa;
\q2 Godaa yayya; iitape haaka.
\q1 
\v 8 Hessi ne asatethaas payyatethi ehana;
\q2 ne meqethaaka xaalisana.
\q1 
\v 9 Ne shaluwan Godaa boncha;
\q2 koyro ayfida kathaafe
\q2 bayraa immada iya boncha.
\q1 
\v 10 Hessa ne oothiko, ne shaaliyan kathi kumana;
\q2 ne daalloy woyne ushshan kumidi palahana.
\p 
\v 11 Ta na7aw, Godaa seera kadhopa;
\q2 I nena seeriya wode lancofa.
\q1 
\v 12 Aaway ba dosiya na7a seereysada,
\q2 Goday ba dosiya uraa seerees.
\q1 
\v 13 Cincatethi demmeynne,
\q2 akeeka baw miishe oothiya uray anjetidaysa.
\q1 
\v 14 Cincatethi birape aadhidi go77ees;
\q2 worqafe aadhidi maaddees.
\q1 
\v 15 Cincatethi worqafe aadhidi al7o;
\q2 ne demmanaw amotiya ubbay cincatethara ginenna.
\q1 
\v 16 Cincatethi ushacha kushen adussa laythi,
\q2 haddirsa kushen duretethinne boncho oykasu.
\q1 
\v 17 I ogeti ufaysiya ogeta;
\q2 I horogay saro horoga.
\q1 
\v 18 Iya bana oykeysatas de7o mithi;
\q2 iyo minthidi oykiya ubbay anjetidaysata.
\q1 
\v 19 Goday ba cincatethan sa7aa medhis;
\q2 ba akeekan salota minthis.
\q1 
\v 20 Iya eratethan shaafati goggoosona;
\q2 shaaratape iri bukees.
\q1 
\v 21 Ta na7aw, suure pirdanne
\q2 shaakidi ero minthada oyka
\q2 enti neepe shaaketofo.
\q1 
\v 22 Enti new de7o gidana;
\q2 injenne ufaysi immana.
\q1 
\v 23 He wode ne hirgi bayna hemetana;
\q2 ne tohoy dhubetenna.
\q1 
\v 24 Neeni zin7iya wode yayyaka;
\q2 qamma kumethi mal7o dhisko dhiskana.
\q1 
\v 25 Akeekona gakiya gados yayyaka;
\q2 iitati dhayiya dhayuwan dagammaka.
\q1 
\v 26 Goday new zempo gidana;
\q2 ne tohoy xihen oyketonnaada I naagana.
\q1 
\v 27 New wolqi de7ishin,
\q2 metootida uraas lo77oba ooso aggofa.
\q1 
\v 28 Ha77i maaddanaw danda7ashe ne shooruwa,
\q2 “Simmada ya; ta new wonto immana” yaagopa.
\v 29 Nena ammanetidi, ne matan de7iya,
\q2 ne shooruwa bolla gene oothofa.
\q1 
\v 30 Nena qohonna de7ishin,
\q2 ase coo mootopa.
\q1 
\v 31 Gene oothiya asata qanaatopa;
\q2 enta iita oosuwa kaallofa.
\q1 
\v 32 Goday iita oothiya asata ixees;
\q2 shin suureta dosees.
\q1 
\v 33 Goday iita oothiya asaa keethaa baaddees;
\q2 shin suureba oothiya asaa keethaa anjees.
\q1 
\v 34 Otoron qelqiseyisata Goday qelqisees;
\q2 shin bantana kawusheyisata sabbees.
\q1 
\v 35 Cincati boncho demmana;
\q2 shin eeyati kawuyana.
\c 4
\s1 Cincatethi Ubbaafe Bolla
\q1 
\v 1 Ta nayto, hinte aawa zoriya si7ite;
\q2 loythi si7ite; hinte akeeka demmana.
\q1 
\v 2 Ta hintew lo77o timirte immiya gisho,
\q2 ta timirtiya kadhopite.
\q1 
\v 3 Taka ta aawas na7a;
\q2 ta aayes iya dosiya issi na7a.
\q1 
\v 4 Ta aaway tana haysada yaagidi tamaarsis;
\q2 “Ta oday new gelo; ta kiita naaga;
\q2 neeni hessa oothiko de7on daana.
\q1 
\v 5 Cincatethinne akeeka demmanaw minna;
\q2 ta new odiyaba dogopa; iyape kare keyopa.
\q1 
\v 6 Cincatethas zoko zaaropa; iya nena ashshana;
\q2 iyo dosa; iya nena naagana.
\q1 
\v 7 Cincatethi aadhiya gisho iyo demma;
\q2 new de7iyaba wursidi ekikoka akeeka demma.
\q1 
\v 8 Ne iyo boncha;
\q2 iya nena dhoqu dhoqu oothana;
\q2 ne iyo oykiko, iya nena bonchana.
\q1 
\v 9 Iya ne huuphiyas saba gidana;
\q2 boncho kallacha immana” yaagis.
\q1 
\v 10 Ta na7aw, si7a; ta odeysa eka;
\q2 ne laythay aduqana.
\q1 
\v 11 Taani nena cincatetha oge kaalethana;
\q2 suure horoga bessaana.
\q1 
\v 12 Ne hemetiya wode dhubiyabay deenna;
\q2 woxiyakoka dhubetaka.
\q1 
\v 13 Ta timirtiya loytha naaga; yeddofa;
\q2 timirtey new de7o immiya gisho loytha naaga.
\q1 
\v 14 Nagaranchota ogiyara boopa;
\q2 iita asata ogiyan hemetofa.
\q1 
\v 15 Iyape haaka; iyan hemetofa;
\q2 guye simma; ne ogiyan ba.
\q1 
\v 16 Enti iitaba oothonna de7ishin dhiskoy ekenna;
\q2 enti ase dhubbonna de7ishin dhiskoy efenna.
\q1 
\v 17 Enti nagara kathada moosona;
\q2 geellatethi ushshada uyoosona.
\q1 
\v 18 Xillota ogey seeta gallas gakanaw,
\q2 guji guji poo7iya wonta xalqe mela.
\q1 
\v 19 Shin geellata ogey sakana dhuma mela;
\q2 enti aybin dhubetiyakoka erokona.
\q1 
\v 20 Ta na7aw, ta odeysa si7a;
\q2 ne haythaa taako zaara.
\q1 
\v 21 Ne ayfiya sinthafe haassofa;
\q2 ne wozanan naaga.
\q1 
\v 22 Enta demmiya ubbaas enti de7o;
\q2 enti asatethas payyatethi immoosona.
\q1 
\v 23 De7oy iyape pultiya gisho,
\q2 ubbaafe aathada ne wozanaa minthada naaga.
\q1 
\v 24 Ne doonape iita haasaya digga;
\q2 wordo haasaya ne matape haassa.
\q1 
\v 25 Sitti gada sinthe xeella;
\q2 ne ayfey ne sinthan de7iyaba
\q2 tishshi oothidi xeello.
\q1 
\v 26 Ne tohuwa ogiya giigisa;
\q2 suure oge xalaalan hemeta.
\q1 
\v 27 Suure ogepe ushachi haddirsi goopa;
\q2 ne tohoy iita oge boonnada naaga.
\c 5
\s1 Laymatethafe Haaka
\q1 
\v 1 Ta na7aw, ta cincatetha hayza si7a;
\q2 ne haythaa ta timirtiyako zaara.
\q1 
\v 2 Hessi nena wozanaama oothana;
\q2 ne oday ne eratethaa qoncisana.
\q1 
\v 3 Layma maccasa inxarsafe ililo eessi xokees;
\q2 I oday oysape aadhidi looxikees.
\q1 
\v 4 Shin wursethan iya godare uthada cammawusu;
\q2 nam7u baggara qanxiya mashshada qara.
\q1 
\v 5 I tohoy hayqoko bees;
\q2 I tangoy duufo gathees.
\q1 
\v 6 Iya de7o oge qopuku; I ogey geella;
\q2 shin geella gideysa iya eruku.
\q1 
\v 7 Ta na7aw, tana si7a;
\q2 ta odeysafe keyopa.
\q1 
\v 8 Layma maccasa heera boopite;
\q2 I keetha pengiyako shiiqopite.
\q1 
\v 9 Hessi hanonna ixiko hinte bonchuwa harati ekana;
\q2 na7atethan wozana mino asa kushen hinte hayqana.
\q1 
\v 10 Hinte aquwa allagati ekana;
\q2 hinte daaburadi shiishidabay hara asas gidana.
\q1 
\v 11 Wursethan hinte ashoynne
\q2 hinte asatethay wurin hinte yeekana.
\q1 
\v 12 Hinte yaagana; “Ta ayis timirte ixadina?
\q2 Ta wozanay seera ayis kadhidee?
\q1 
\v 13 Taani ta astamaareta si7abike;
\q2 tana zoreyisata zoriya ekabike.
\q1 
\v 14 Hesaa gisho, ta asay shiiqida shiiquwan,
\q2 kawuyanaw matas” yaagana.
\q1 
\v 15 Neeni ne pultuwafe haathe uya;
\q2 ne mache xalaala siiqa.
\q1 
\v 16 Ne pultuwa dabaaban,
\q2 ne olla haatha denban ayis gussay?
\q1 
\v 17 Enta new buzo ootha;
\q2 hara allaga uraara koxofa.
\q1 
\v 18 Ne pultoy new anjeto;
\q2 ne na7atetha machera ufayta.
\q1 
\v 19 Lo77iya gaaredaninne ufaysiya gen7eda
\q2 I dhanthay ubba wode nena alo;
\q2 ubba wode I siiqoy nena di77o.
\q1 
\v 20 Ta na7aw, layma maccasan ayis di7etay?
\q2 Hara asa macho ayis qoommay?
\q1 
\v 21 Asi oothiyaba ubbaa Goday be7ees;
\q2 I hemetiya horoga ubbaa xeellees.
\q1 
\v 22 Nagaranchuwa I oothida nagaray oykees;
\q2 Iya nagaraa gitey iya qachees.
\q1 
\v 23 I ba eeyatethan dhayis;
\q2 bana naagiboonna gisho hayqis.
\c 6
\s1 Eeyatethafe Haaka
\p 
\v 1 Ta na7aw, miishe tal7ida ne shooruwas waase gelidaba gidiko,
\q2 hara asas kushe baqada caaqidaba gidiko,
\q2 
\v 2 ne caaqida ne caaquwan xihen gelidaba gidiko,
\q2 ne doonape keyida qaalan oyketidaba gidiko,
\q2 
\v 3 hiza ne shooruwa kushen geladasa.
\q1 Hessa gisho, ta na7aw, iyape keyanaw koyko,
\q2 ne shooruwa soo bada waasetetha
\q2 ne bollafe wothana mela aaddashada iya woossa.
\q1 
\v 4 Hessa oothonna de7ashe zin7ofa;
\q2 dhiskoyka nena ekofo.
\q1 
\v 5 Shankafe gen7ey kessi ekiyada,
\q2 gitepe kafoy attiyada nena ashsha.
\q1 
\v 6 Neno azallaw, zimadoko ba;
\q2 iyape cincatethi tamaara.
\q1 
\v 7 Zimaddota kiittey baawa,
\q2 halaqi woyko enta haarey baawa.
\q1 
\v 8 Shin bantaw maanaba bone minjoosona;
\q2 kathi cakiya wode bantaw koshshiya kathaa shiishosona.
\q1 
\v 9 Neno azallaw, ne awude gakanaw dhiskay?
\q2 Ne dhiskofe awude barkanee?
\q1 
\v 10 Neeni “guuthu zin7ana; guuthu dhiskana;
\q2 kushe shiisha ekada guuthu shempana” yaagasa.
\q1 
\v 11 He wode manqotethi pangada,
\q2 paci ola miishe oykida asada ne bolla yaana.
\q1 
\v 12 Laafanne iita asi yuuyidi oda mirqees;
\q1 
\v 13 I ba ayfen qam7otees;
\q2 ba tohon bessees; ba biradhen mallees.
\q1 
\v 14 Iya ulon geellatethi de7ees; iitabaa qopees;
\q2 ubba wode ooshshu medhees.
\q1 
\v 15 Hessa gisho dhayoy akeekona iya bolla yaana;
\q2 I hassayonna meqana; zaaridi paxenna.
\q1 
\v 16 Goday ixiya usupun qommoti de7oosona;
\q2 I shaatetiya qommoti laapuna;
\q2 
\v 17 kadhidi xeelliya ayfe,
\q2 wordotiya inxarsi,
\q2 xillo asata wodhiya kushe,
\q2 
\v 18 iitaba maqiya wozanaa,
\q2 iitabaako woxanaw eesotiya toho,
\q1 
\v 19 Wordo bolla wordo gujiya wordo marka,
\q2 ishata giddon ooshshi medhiya asi.
\s1 Laymatethafe Naageta
\p 
\v 20 Ta na7aw, ne aawa kiita pola;
\q2 ne aaye timirtiya aggofa.
\q1 
\v 21 Enta ubba wode ne wozanan oyka;
\q2 ne qoodhiyan qacha.
\q1 
\v 22 Ne hemetiya wode enti nena kaalethana;
\q2 ne zin7iya wode, enti nena naagana;
\q2 ne barkiya wode enti nena zorana.
\q1 
\v 23 Godaa kiitay xompe; iya timirtey poo7o;
\q2 iya seeray de7oko efiya oge.
\q1 
\v 24 Ha timirteti iita maccafenne
\q2 hara cimmiya maccasa inxarsafe nena naagana.
\q1 
\v 25 I mala lo77otethay nena qadhethofo;
\q2 I qam7otoy nena di77ofo.
\q1 
\v 26 Issi addey guutha miishen layma maccas demmanaw danda7ees;
\q2 shin hara asa macho laggethoy shempo ekees.
\q1 
\v 27 Tama idimmin
\q2 iya ma7oy meetetonna attey de7ii?
\q1 
\v 28 Tama bonqo yedhin,
\q2 iya tohoy xuugetonna attey de7ii?
\q1 
\v 29 Asa macho laggethiya uray hessa mela;
\q2 iyo bochiya ubbay seerettonna attenna.
\q1 
\v 30 Kaysoy koshatidi maanaw kaysiko,
\q2 asi iya borenna.
\q1 
\v 31 Shin I oyketiyabaa gidiko,
\q2 laapun kushe qanxana;
\q2 ba son de7iya miishe ubbaa immana.
\q1 
\v 32 Shin maccasara laymatiya asi wozani bayna asi;
\q2 he uray ba shempuwa dhaysees.
\q1 
\v 33 Deshethinne kawushi iya qaada;
\q2 yeelli iyape qushetenna.
\q1 
\v 34 Qanaatey azinas yilo denthethees;
\q2 halo kessiya wode iw qadhetenna.
\q1 
\v 35 I ay acaka ekenna;
\q2 ay mela imotika iya hanquwa doshisenna.
\c 7
\s1 Layma Maccasape Naageta
\p 
\v 1 Ta na7aw, ta qaala naaga;
\q2 ta kiitaa ne wozanan wotha.
\q1 
\v 2 De7on daanaw ta kiita ootha;
\q2 ta timirtiya ne ayfe na77eda naaga.
\q2 
\v 3 Ne kushen enta qacha;
\q2 ne wozanan enta xaafa.
\q1 
\v 4 Cincatethi ne michida,
\q2 akeeka ne mata dabboda xeella.
\q1 
\v 5 Enti nena layma maccasapenne
\q2 ba qaalan cimmiya hara maccasape naagana.
\q1 
\v 6 Issi gallas ta maskootera kare xeellas.
\q1 
\v 7 Eratethi pacida na7atethata be7as;
\q2 enta giddofe issoy daro eeya.
\q1 
\v 8 He na7atethay ogera bishe,
\q2 issi layma maccase keethaa matara aadhees;
\q2 I soo efiya ogiya simmidi I sooko bis.
\q1 
\v 9 He wode sa7i laadees.
\q1 
\v 10 Maccasiya iya demmasu;
\q2 iya layma gideysa I ma7oy erisees;
\q2 iya asa cimmanaw halchada keyasu.
\q1 
\v 11 Iya xaltaamanne yeelli bayna maccas;
\q2 son wopu gada uttuku.
\q1 
\v 12 Iya issi toho ogen, issi toho giyan,
\q2 issi toho dabaaban eqada naagawusu.
\q1 
\v 13 Iya he na7atetha qoommada yeerasu;
\q2 iya tishshi oothada xeellashe haysada yaagasu;
\q1 
\v 14 “Taani ta yarshuwa yarshada,
\q2 ta qangetha hachi gathas.
\q1 
\v 15 Yaatada nena mokanaw keyas;
\q2 nena daro koyas; hiza nena demmas.
\q1 
\v 16 Taani Gibxefe yida,
\q2 alleeqetida afila hiixas.
\q1 
\v 17 Taani ta hiixa,
\q2 karbefe, almunepenne qarafape,
\q2 oosetida shittuwa puukas.
\q1 
\v 18 Haaya; wontana gakanaw siiqo aloos;
\q2 qoometidi ufaytoos.
\q1 
\v 19 Ta azinay son deenna;
\q2 haaho biitta bis.
\q1 
\v 20 Miishe karxiita kunthidi bida gisho,
\q2 ageena kumonna soo simmenna” yaagasu.
\p 
\v 21 Ba mal7o odan iya balethasu;
\q2 ba liiqo inxarsan iya cimmasu.
\q1 
\v 22 Boori shukettanaw beysada,
\q2 gaari eesotidi xihen geleysada,
\q2 I iyo kaallidi bis.
\q1 
\v 23 Toori iya wozanaa caddidaada hanis;
\q2 gite giddo gelida kafo daanis;
\q2 hessi ubbay iya shempuwa dhaysanaw haneysa eribeenna.
\q1 
\v 24 Hiza ta na7aw, tana si7a;
\q2 ta doonape keyiya qaala hayza.
\q2 
\v 25 Ne wozanay maccasa geedo boopo;
\q2 I ogiyan gelada dhayopa.
\q1 
\v 26 Iya cadda yeggidaysati daro;
\q2 iya wodhidaysati guutha gidokona.
\q1 
\v 27 I soy duufoko efiya oge;
\q2 hayqoko kaalethiya horoga.
\c 8
\s1 Cincatetha Oge
\q1 
\v 1 Cincatethi xeegawusu; si7ite;
\q2 akeeki ba qaala dhoqu oothida sissawusu.
\q1 
\v 2 Oge doonan de7iya zumata bollanne
\q2 daggala ogiyan iya eqawusu.
\q1 
\v 3 Dirsa penge matan, katamaa geliya pengen eqada,
\q2 ba qaala dhoqu oothada haysada yaagawusu.
\q1 
\v 4 Asaw, ta hintena xeegayis;
\q2 asa koche ubbaa xeegayis.
\q1 
\v 5 Hinteno eratethi baynaysato eratethi tamaarite;
\q2 hinteno eeyato, akeeka demmite.
\q1 
\v 6 Taani lo77oba odiya gisho si7ite;
\q2 taani doonape suurebay keyees.
\q1 
\v 7 Taani tuma odetayis;
\q2 wordoy ta matan ixetidaba.
\q1 
\v 8 Ta oday tuma;
\q2 geella woyko mirqethi gidenna.
\q1 
\v 9 Akeeki de7iya uraas ta oday like;
\q2 eri de7iya uraas ta oday qonce.
\q1 
\v 10 Birape aathidi ta zoriya doorite;
\q2 geeshsha worqafe aathidi eratethi doorite.
\q1 
\v 11 Cincatethi zo7o al7o shuchafe aadhees;
\q2 ne amotiya ubbay iira liketenna.
\q1 
\v 12 Taw, cincatethas akeeki de7ees;
\q2 eratethinne shaakidi eroy tabaa.
\q1 
\v 13 Godaas yashshi iitatethi ixo;
\q2 taani otoronne ceeqetethi ixayis;
\q2 iita ogenne wordo oda dosike.
\q1 
\v 14 Zoreynne lo77o eray tabaa;
\q2 akeekinne wolqi taw de7ees.
\q1 
\v 15 Kawoti ta baggara kawotoosona;
\q2 haareysati suure higge ta baggara kessoosona.
\q1 
\v 16 Halaqati ta maaddin deriya haaroosona;
\q2 biitta aysiya gita asata ta maaddayis.
\q1 
\v 17 Tana doseyisata ta dosayis;
\q2 tana minthidi koyeysati demmana.
\q1 
\v 18 Duretethinne bonchoy taara de7oosona;
\q2 wuronna shaloynne injey ta matana.
\q1 
\v 19 Hinte taape demmiya go77ay,
\q2 geeshsha worqafenne birape aadhees.
\q1 
\v 20 Ta xillotetha ogen hemetayis;
\q2 suure pirda ogiyara kanthayis.
\q1 
\v 21 Tana doseysatas ta shalo immana;
\q2 enta keethaa duretethan kunthana.
\p 
\v 22 “Goday tana ubbaafe koyro medhis;
\q2 benipeka iya oosuwas doomethay tana.
\q1 
\v 23 Alamey medhetanaape kase
\q2 taani shuumetas.
\q1 
\v 24 Abbay bayna wode, pultoti dhuuqonna
\q2 de7ishin ta yeletas.
\q1 
\v 25 Deretinne zumati medhetanaape
\q2 sinthe ta yeletas.
\v 26 Goday sa7aanne sa7an de7iya ubbaa medhanaape sinthe
\q2 woyko koyro kophe biittay oosetanaape sinthe ta yeletas.
\q1 
\v 27 Goday salota miccida wode,
\q2 abbatape bollara salo gufantho giigisida wode,
\q2 taani yan de7ayis.
\q1 
\v 28 Goday shaarata bollara wothida wode,
\q2 abba pultota dhuusida wode,
\q2 
\v 29 abba haathati imetida zawape pinnidi, bolla aadhonada,
\q2 I enta kiitida wode sa7aa baasuwa minthida wode,
\q2 taani yan de7ayis.
\q1 
\v 30 He wode ta iya matan waanna oosancho;
\q2 ubba wode ta iya ufaysayis;
\q2 tawuka iya sinthan ufaytayis.
\q1 
\v 31 I medhida alamiyan ufaytayis;
\q2 asa naytika tana ufaysoosona.
\b
\q1 
\v 32 “Hiza ta nayto, si7ite;
\q2 ta odeysada ootheysati anjetidaysata.
\q1 
\v 33 Ta timirtiya si7ite; cinca gidite;
\q2 si7idaba dogopite.
\q1 
\v 34 Taani odidaba si7iya uray,
\q2 gallas gallas ta pengiyan bentiya uray,
\q2 ta pengiyan naagiya uray anjetidaysa.
\q1 
\v 35 Tana demmiday de7o demmees;
\q2 Godaape saba ekees.
\q1 
\v 36 Shin tana demmonna uray bana qohees;
\q2 tana ixiya ubbay hayqo dosees.”
\c 9
\s1 Cincatethi, Eratethinne Eeyatethi
\q1 
\v 1 Cincatethi ba keethaa keexasu;
\q2 laapun tuussata ba keethaas essasu.
\q1 
\v 2 Iya ba giigisiya gibiras modho mehe shukasu;
\q2 woyne aggasu; gayta asaa sinthe aathasu.
\q1 
\v 3 Asaa xeeganaw ba aylleta kiittasu;
\q2 oosanchoti katamaa dhoqa bessan eqidi,
\v 4 Hinteno, eri pacidaysato haa gelite! Eeyatako haysada yaagasu.
\v 5 “Haa yiite; ta kathaa miite;
\q2 ta aggida woyniya uyite.
\v 6 Hinte eeyatethi aggidi de7on de7ite;
\q2 akeekidi hemetite” yaagasu.
\p 
\v 7 Qelqisiya uraa seeriya asi cashshe ekees;
\q2 iita uraa zoriya asi baw qohetees.
\q1 
\v 8 Qelqisiya uraa zoropa; I nena ixana;
\q2 cinca uraa zora; I nena dosana.
\v 9 Cincatethi uraa tamaarsa; I cinca gidana;
\q2 Xillo uraa tamaarsa; I era gujana.
\p 
\v 10 Godaas yashshi cincatethas doomethi, Geeshsha Godaa eroy akeeka.
\q1 
\v 11 Ta gaason ne laythay darana;
\q2 ne de7o laythay aduqana.
\q1 
\v 12 Ne cinca gidiko, go7etey nena;
\q2 Ne qelqisiya asi gidiko nena qohaasa.
\p 
\v 13 Eeyo maccasi waaso darawusu;
\q2 iw yeelli baawa; iya aykoka eruku.
\q1 
\v 14 Iya ba karen woyko katamaa dhoqa bessan uttawusu.
\v 15 Banta ogiya biya asaa xeegada,
\v 16 “Hinteno, eri pacidaysato
\q2 taako haa yiite” yaagasu. Eri baynaysatako,
\v 17 “Kaysidi uyaa haathi mal7ees;
\q2 geeman miya kathi lo77ees” yaagasu.
\q1 
\v 18 Shin hayqida asay yan de7eysa,
\q2 I imathatika duufon de7eysa I erenna.
\c 10
\s1 Solomone Leemisota
\p 
\v 1 Haysati Solomone leemisota.
\q1 Cinca na7i ba aawa ufaysees;
\q2 shin eeya na7i ba aayiw azzanthees.
\q1 
\v 2 Nagaran demmida miishey go77enna;
\q2 shin xillotethi hayqope ashshees.
\q1 
\v 3 Goday xillota koshaysenna;
\q2 shin nagaranchota amuwa polisenna.
\q1 
\v 4 Azallatethi manqisees;
\q2 shin minnidi oosoy dureyees.
\q1 
\v 5 Cinca asi ba kathaa bone shiishees;
\q2 shin kathi cakiya wode dhiskiya asi kawuyees.
\q1 
\v 6 Xillo asi anjetees;
\q2 shin nagarancho asi
\q2 ba makallatethaa doonan genthees.
\q1 
\v 7 Xilluwa sunthay anjon xeegetishe de7ees;
\q2 shin nagaranchota sunthay elle dogetees.
\p 
\v 8 Cinca asi kiittidaba oothees;
\q2 shin eeya asi dhayoko bees.
\q1 
\v 9 Suure asi saro de7ees;
\q2 shin geella asi ba gomen oyketees.
\q1 
\v 10 Gene ayfen qam7otiya asi meto ehees;
\q2 shin yayyonna seeriya asi sarotethi medhees.
\p 
\v 11 Xillo asa odi de7o pulto;
\q2 shin nagarancho asa odi makalla genthees.
\q1 
\v 12 Ixoy palama denthethees;
\q2 shin siiqoy bala ubbaa kammees.
\q1 
\v 13 Wozanaama asi cincatethan odees;
\q2 shin eeya asa zokoy xam7as attees.
\q1 
\v 14 Cincati eratethi dagayoosona;
\q2 shin eeyata doonay dhayo dafees.
\q1 
\v 15 Dure asa miishey diretida katamada naagees;
\q2 shin manqotethi manqota dhaysees.
\q1 
\v 16 Xillo asa oosoy iya de7o;
\q2 shin iita asa wursethay dhayo.
\q1 
\v 17 Seerin simmiya asi de7o ogen hemetees;
\q2 shin seerin ixiya asi balees.
\q1 
\v 18 Ixo kammiya asi wordancho;
\q2 zigirsi laaliya asi eeya.
\q1 
\v 19 Daro haasaya giddon nagari dhayenna;
\q2 shin ba doona shiishiya asi cinca.
\q1 
\v 20 Xillo asa inxarsi geeshsha bira mela;
\q2 shin iita asa wozani iitaban kumis.
\q1 
\v 21 Xillo asa odi daro asaa go77ees;
\q2 shin eeyati banta paca wozanan hayqoosona.
\q1 
\v 22 Godaa anjoy dure kessees;
\q2 he duretetha bolla meto gujenna.
\q1 
\v 23 Eeya uraas iitabaa oosoy kaassa mela;
\q2 shin wozanaama asi cincatethan ufaytees.
\q1 
\v 24 Iita asi hirgidabay iya bolla gakana;
\q2 shin xilloy amotidabay imetana.
\q1 
\v 25 Gotey aadhiya wode nagaranchoy bentenna;
\q2 shin xilloti merinaw minnidi daana.
\q1 
\v 26 Caalabay ache, cuyi ayfe qoheysada,
\q2 azalla asi kiittidaysa yiloyees.
\v 27 Godaas yashshi laythi adussees;
\q2 shin nagaranchota laythay qaammees.
\q1 
\v 28 Xillo asi ufaysi yaana gidi naagees;
\q2 shin nagaranchota ufaysay dhayana.
\q1 
\v 29 Godaa ogey xillotas baqatidi attiya besse;
\q2 shin iita oothiya asaas dhayo.
\q1 
\v 30 Xilloti ubba wode qaaxokona;
\q2 shin iitati biitta bolla dookona.
\q1 
\v 31 Xillo asi cincatethan odees;
\q2 shin geellaba odetiya inxarsi qanxetana
\q1 
\v 32 Xillo asa inxarsi bessiya haasaya erees;
\q2 shin iita asaa oday wobbe.
\c 11
\q1 
\v 1 Goday wordo mizaane ixees;
\q2 shin like mizaanen ufaytees.
\q1 
\v 2 Otoroy yaa wode kawushatethi yees;
\q2 shin ashketethan cincatethi yees.
\q1 
\v 3 Xillota enta suuretethay kaalethees;
\q2 shin iita asata enta geellatethay dhaysis.
\q1 
\v 4 Hanqo gallas duretethi go77enna;
\q2 shin xillotethi hayqope ashshees.
\q1 
\v 5 Borey bayna uraa ogiya xillotethay suurisees;
\q2 shin iita uray ba iitatethan kundees.
\p 
\v 6 Suureta enta xillotethay ashshees; shin ammanetonayisata enta amoy xihe gididi oykana.
\p 
\v 7 Iita asi hayqiya wode, I naagiya ufaysay iyara issife hayqees; I ba wolqan ceeqetiyabay ubbayka dhayees.
\p 
\v 8 Xilloy metope attees; iya gisho iitaa bolla metoy yees.
\p 
\v 9 Xoossaa kaddida asi ba doonan asa dhaysis; shin xilloti eran kessi ekoosona.
\p 
\v 10 Xilloti bonchetiya wode, katamay ufaytees; qassi iitati hayqiya wode, hashshu gees.
\p 
\v 11 Xillota anjuwa gaason katamay diccees; shin iita uraa odi katamaa dhaysis.
\p 
\v 12 Ba shooruwa kadhiya uraas wozani baawa; shin akeekancho uray si77i gees.
\p 
\v 13 Zigiriya asi xuuraa laallees; shin ammanetiya asi xuuraa genthees.
\p 
\v 14 Kaalethiyabay dhayiko, kawotethay kundees; shin daro zoreysati de7iko, saroy de7ees.
\p 
\v 15 Erenna uraas waase gidiya asi tumape metootana; hessafe waase gidonna ixeysi lo77o.
\p 
\v 16 Ulo keeha maccasi bonchetawusu; shin iita asi duretetha xalaala duretees.
\p 
\v 17 Keeha asi baw lo77oba oothees; shin wozana mino asi bana qohees.
\p 
\v 18 Iita asi demmiya miishey cimo; shin xillotethaa zeriya uray tuma woyto cakana.
\p 
\v 19 Xillotethan minnidi de7iya uray paxa de7ana; shin iitatethaa kaalliya uray hayqana.
\p 
\v 20 Goday iita qofay de7iya asata ixees; shin suure hemeteysatan ufaytees.
\p 
\v 21 Iita asi seerettonna attenna; shin xillota kochay attana.
\q1 
\v 22 Qofi bayna mala lo77o macca puulatethay
\q2 guduntho sidhen aathida worqaa mela.
\p 
\v 23 Xillota amuwas poloy lo77o xalaala; shin iitata amuwas poloy hanqo xalaala.
\p 
\v 24 Issi issi asati banta miishe asas coo keehosona; shin enta aqoy haa darees. Hara asati qassi banta miishas pala uuzettoosona; shin enta aqoy yaa pacees.
\p 
\v 25 Keeha asi duretana; harata maaddiya asi maadetana.
\p 
\v 26 Kathi al77in bayzanaw minjiya uraa asay baaddees. Shin ba kathaa asay koyiya wode bayziya uraa anjees.
\p 
\v 27 Lo77oba minthidi koyiya uray ufaysaa demmees; shin iitabaa koyiya uraa iitabay demmees.
\p 
\v 28 Ba duretetha ammanetiya asi kundana; shin xilloti balgo mithada.
\p 
\v 29 Ba soo asaa bolla buqethi denthiya uray go7etiyabay aybika baawa. Eeyatika cincatas aylle gidana.
\p 
\v 30 Xillo asi de7o ayfe ayfiya mitha mela; shempo ashsheysati cincata.
\p 
\v 31 Xilloti sa7an banta ooso gate ekiyaba gidiko, iitatinne nagaranchati banta oosuwas ekana gatey waanidi darandeesha!
\c 12
\p 
\v 1 Seera dosiya uray eratethi dosees; shin seera ixiya uray eeya.
\p 
\v 2 Lo77o asi Godaape saba demmees; shin Goday genanchota pirdees.
\p 
\v 3 Asi iitatethan minnidi eqenna;
\q2 shin xillota xaphoy qaaxenna.
\p 
\v 4 Wozanaama machiya ba azinaas kallacha mela; shin ba azina kawushiya machiya meqethi miya ajaaje mela.
\p 
\v 5 Xilluwa qofay suure; shin iitata zorey cimo.
\p 
\v 6 Iitata zoretay asa qohanaasa; shin xillota zoretay enta ashshanaasa.
\p 
\v 7 Iita asati kundana; entaw zerethika attenna; shin xillota kochay minnidi de7ana.
\p 
\v 8 Asi ba cincatetha mela galatetees; shin geella qofay de7iya asi kadhetees.
\p 
\v 9 Dure asi daanidi, meton de7iya asaape coo asa daanidi, oothiiddi ba de7o sugiya asi keeha.
\p 
\v 10 Xillo asi ba mehes qadhetees, shin wozana mino asas qadhey baawa.
\p 
\v 11 Ba biitta minthi oothiya uray kathi kallees; shin pathonnaba yedethiya uray akeeki pacidaysa.
\p 
\v 12 Iitati nagarancho asata di77anaw amottoosona; shin xillota xaphoy daayidi de7ana.
\p 
\v 13 Iita asa iya doonape keyida odi xihe gididi oykees; shin xilloy metope kessi ekees.
\p 
\v 14 Asi ba doonape keyiya qaalan lo77oba kallees; ba oothida ooso gatiya ekees.
\p 
\v 15 Eeya asi biya buussay aw iya huuphen like daanees; shin cinca asi zore si7ees.
\p 
\v 16 Eeya uraa hanqoy ellesidi eretees; shin cinca asi cashshe wuda geenna.
\p 
\v 17 Tumaa haasayiya asi suureba odees; shin wordo markay wordo odees.
\p 
\v 18 Akeekona odetiya odi mashshada caddees;
\q2 shin cinca inxarsay pathees.
\p 
\v 19 Wordo odi guutha wodesa; shin tuma odi merinaw de7ana.
\p 
\v 20 Iita qopiya asaa wozanan cimoy de7ees;
\q2 shin saroba zoreteyisata wozanan ufaysay kumees.
\p 
\v 21 Xillota metoy gakenna; shin iitatas metoy darana.
\p 
\v 22 Goday wordanchota ixees; shin tumancho asatan I ufaytees.
\p 
\v 23 Cinca asi ba eraa qottees; shin eeyati banta eeyatetha odoosona.
\p 
\v 24 Minnidi oothiya uray dere haarees; shin azalla asi haaretees.
\p 
\v 25 Un7an kumida wozani azzano ehees; shin keeha odi iya ufaysees.
\p 
\v 26 Xillo asi ba shooruwa zoridi, suure oge kaalethees; shin iitati oge tumaape haassees.
\p 
\v 27 Azalla asi shankatidi ehida asho kathenna;
\q2 shin minnidi oothiya uray ba miishiyas mishetees.
\p 
\v 28 Xillotethaa ogen de7oy de7ees; he ogen hayqoy baawa.
\c 13
\p 
\v 1 Erancho na7ay ba aawa seera si7ees; shin qelqiseysi seera ekenna.
\p 
\v 2 Asi ba doonape keyiya qaalan lo77oba ekees; shin ammanetonaysati makallaba amottoosona.
\p 
\v 3 Ba doona naagiya uray ba shempuwa naagees;
\q2 shin eeson haasaya uray bana dhaysees.
\p 
\v 4 Azallay amottees; amotikonne aybaka demmenna; shin minnidi ootheysati kallana.
\p 
\v 5 Xillo asati wordo oda ixoosona. Shin iita asata odi yeellayeesinne kawushshees.
\p 
\v 6 Suure de7uwa de7iya uraa iya xillotethay naagees; shin nagarancho iya nagaray ongees.
\p 
\v 7 Bana dure daanisiya asi de7ees; shin iyaw aybinne baawa; qassi bana manqo daanisiya asi de7ees; shin iyaw daro aqoy de7ees.
\p 
\v 8 Asi ba miishen ba shempo wozanaw danda7ees; shin manquwa yashisiyabay baawa.
\p 
\v 9 Xillota poo7oy phoolees;
\q2 shin iitata xompey to7ana.
\p 
\v 10 Otoroy ooshshi yelees; shin zore ekeysati cincata.
\p 
\v 11 Daaburi bayna demmida miishey eeson dhayees; shin minni oothidi demmida aqoy, dari daridi bees.
\p 
\v 12 Koyiyabay poletonna gam7eysi azzanthees; shin amotidabay poleteysi ufaysees.
\p 
\v 13 Zore kadhiya uray meton gelees; shin kiita bonchiya uray saro de7ana.
\p 
\v 14 Cincatethi immiya timirtey de7o pulto; higgey ase hayqo xihepe kessi ekanaw maaddees.
\p 
\v 15 Akeeki de7iya uray bonchetees; shin ammanetona ixoy qohos gathees.
\p 
\v 16 Cinca asi ubbay eran oothees; shin eeyi ba eeyatetha qoncisees.
\p 
\v 17 Iita asati kiitetidi, meton geloosona; shin ammanthiya asati kiitetidi, sarotethi ehoosona.
\p 
\v 18 Seera ixiya asi manqeesinne yeellatees;
\q2 shin seera ekiya uray bonchetees.
\p 
\v 19 Amotidabay poleteysi daro ufaysees;
\q2 shin iitati iitabaape haakanaw koyokona.
\p 
\v 20 Cinca asara hemetiya asi cinca gidees;
\q2 shin eeya asara hemetiya asi meton gelees.
\p 
\v 21 Nagaranchota iita qaaday kaallees;
\q2 shin duretethi xillota woyto.
\p 
\v 22 Lo77o asi ba nayta nayta laatisees;
\q2 shin nagaranchuwa aqoy xilluwas dagayetees.
\p 
\v 23 Manquwa goshshay daro kathi ayfenaw danda7ees;
\q2 shin suure pirda pacan dhayees.
\p 
\v 24 Pircon seeranaw dosonna asi ba na7aa ixees;
\q2 shin ba na7aa siiqiya uray minnidi seerees.
\p 
\v 25 Xilloy, uloy kallana gakanaw mees;
\q2 shin nagaranchoy ubba wode koshatana.
\c 14
\p 
\v 1 Cinca maccasi ba keethaa keexawusu;
\q2 shin eeya maccasiya ba keethaa ba kushen laallawusu.
\p 
\v 2 Suure hemetiya asi Godaa yayyees;
\q2 shin ba oge geellayiya asi Godaa kadhees.
\p 
\v 3 Eeya odi iya zokuwas xam7a ehees;
\q2 shin cincata inxarsay enta naagees.
\p 
\v 4 Boori bayna ixiko shaaley kaysi gidees;
\q2 shin goshsha boori de7iko, ne shaaley kathan kumees.
\p 
\v 5 Ammanetiya marki ubba wode tuma odees;
\q2 shin wordo marki wordo xalaala odetees.
\p 
\v 6 Qelqisiya asi cincatethi koyees, shin demmenna;
\q2 akeeki de7iya asi eratethi demoy waaysenna.
\p 
\v 7 Eeya asape haaka;
\q2 neeni iya odape eratethi demmaka.
\p 
\v 8 Cinca asi cinca gidiya ba oothiyaba erees;
\q2 shin eeya asa eeyatethay iya balethees.
\p 
\v 9 Eeyati nagara oothishe, qiirotanaysa aggidi qelqisoosona;
\q2 shin suureti banta nagaray atto geetetanaw koyoosona.
\p 
\v 10 Issi issi wozani ba azzanuwa erees;
\q2 iya ufaysa oonika iyara koxenna.
\p 
\v 11 Iitata keethay laaletana;
\q2 shin suureta keethay minnidi daana.
\p 
\v 12 Asas like daaniya ogey de7ees;
\q2 shin iya wursethay hayqoko gathees.
\p 
\v 13 Miicha wodeka wozanan azzanoy de7ees;
\q2 ufaysa wursethay azzano gidanaw danda7ees.
\p 
\v 14 Iita asi ba iita oosuwa gate ekana;
\q2 lo77o asika ba lo77o oosuwa gate ekana.
\p 
\v 15 Eeya asi ubbaba ammanees;
\q2 shin cinca asi akeekidi tangees.
\p 
\v 16 Cinca asi Godaa yayyees; iitape haakees;
\q2 shin eeya asi eesotesinne iitape naagetenna.
\p 
\v 17 Elle hanqetiya asi eeya ooso oothees;
\q2 shin cinca asi danda7ancho.
\p 
\v 18 Akeeki bayna asi ba eeyatetha gatiya ekoosona;
\q2 shin cinca asi eratethi kallachada goxoosona.
\p 
\v 19 Iitati lo77ota sinthan gulbatana;
\q2 nagaranchati xillota pengen hokana.
\p 
\v 20 Manqoy ba shooruwan ixetees;
\q2 shin duretas daro laggeti de7oosona.
\p 
\v 21 Ba shooruwa kadhiya asi nagara oothees;
\q2 shin manquwa maaddiya asi anjetidaysa.
\p 
\v 22 Iitabaa maqeteysati baloosona gidokona?
\q2 shin lo77oba oothanaw halcheysati
\q2 ammanetethinne siiqo demmoosona.
\p 
\v 23 Minnidi oothiya ooso ubban wodhey de7ees;
\q2 shin coo odi manqotethi ehees.
\p 
\v 24 Cincatas enta duretethay entaw kallacha;
\q2 shin eeyati guji guji eeyoosona.
\p 
\v 25 Tuma marki shempo ashshees;
\q2 shin wordo marki balethees.
\p 
\v 26 Godaa yayiya asas mino miixay de7ees;
\q2 iya naytas baqatidi attiya bessi de7ees.
\p 
\v 27 Godaa yashshi de7o pulto;
\q2 hayqo xihepe ase ashshees.
\p 
\v 28 Kawo gitatethi I haariya asaa darotethaana;
\q2 shin haaretiya asi dhayiko ika pathenna.
\p 
\v 29 Danda7ancho asas gita akeeki de7ees;
\q2 shin elle hanqetiya asi ba eeyatetha qoncisees.
\p 
\v 30 Saro wozani asatethas payyatethi immees;
\q2 shin qanaatey asatethas ajaaje harge mela.
\p 
\v 31 Manqota naaqiya asi enta medhidaysa cayees;
\q2 shin metootanchotas keehiya asi Xoossaa bonchees.
\p 
\v 32 Iitati banta iita ooson kundana;
\q2 shin xillotas hayqope attiya miixi de7ees.
\p 
\v 33 Akeekancho asa wozanan cincatethi kumis;
\q2 shin eeyati cincatethi aybeko erokona.
\p 
\v 34 Xillotethi issi kawotetha dhoqu dhoqu oothees;
\q2 shin nagari ay asika kawushshees.
\p 
\v 35 Erancho aylletanan kawoy ufaytees;
\q2 shin yeellaya aylley kawa hanqethees.
\c 15
\p 
\v 1 Liiqo inxarsi hanqo zarbisees;
\q2 shin dom7ethiya qaali hanqo denthethees.
\q1 
\v 2 Cincata inxarsay era puulayees;
\q2 shin eeyata doonay eeyatethi pultisees.
\q1 
\v 3 Godaa ayfeti ubba bessi xeelloosona;
\q2 iitatanne lo77ota shaakidi be7oosona.
\q1 
\v 4 Lo77o odi de7o mitha mela;
\q2 shin geella odi ayyaana menthees.
\p 
\v 5 Eeyi ba aawa seera kadhees;
\q2 shin ba aawa seera ekiya asi cinca.
\q1 
\v 6 Xillo uraa keethan daro miishey de7ees;
\q2 shin iitata soo geliya miishey meto ehees.
\q1 
\v 7 Cincata doonay era zerees;
\q2 shin eeyata wozanay hessa mela gidenna.
\q1 
\v 8 Goday iitata yarshuwa ixees;
\q2 shin suureta woosan I ufaytees.
\q1 
\v 9 Goday iita asata ogiya ixees;
\q2 shin xillotethi kaalleyisata I dosees.
\q1 
\v 10 Like ogiya aggida asi pirdi naagees;
\q2 seera ixiya asi hayqees.
\p 
\v 11 Duufoynne dhayoy Godaa sinthan qonce;
\q2 yaatin, asa wozana qofay waani iyape geemmanee?
\q1 
\v 12 Qelqisiya asi seera dosenna;
\q2 cincatape zore oychenna.
\q1 
\v 13 Wozani ufaytin, som7oy poo7ees;
\q2 shin wozani azzaniko, ayyaani meqees.
\q1 
\v 14 Akeeka wozani de7iya asi eratethi koyees;
\q2 shin eeyati banta eeyatethan ufaytoosona.
\p 
\v 15 Manqota de7oy ubba wode baaxe;
\q2 shin ufaytiya asi ubba wode alees.
\q1 
\v 16 Ooshshara de7iya gita aqope
\q2 Godaa yashshara de7iya guuthabay keeha.
\q1 
\v 17 Ooshshi de7iya bessan modho asho maanape
\q2 siiqoy de7iya bessan santhi keeha.
\q1 
\v 18 Hanqoy ooshshi kessees;
\q2 shin danda7i ooshshi irxisees.
\q1 
\v 19 Azalla asa ogey agunthan diretis;
\q2 shin suure asa ogey giiga.
\q1 
\v 20 Cinca na7i ba aawa ufaysees;
\q2 shin eeya na7i ba aayiw kadhees.
\q1 
\v 21 Wozani bayna asi ba eeyatethan ufaytees;
\q2 shin wozanaama asi bessiya ba oothees.
\p 
\v 22 Zorey dhayiko, qopidabay haddirees;
\q2 daro zorey de7iya bessan qopidabay poletees.
\q1 
\v 23 Oyshas bessiya zaaro imoy he uraa ufaysees;
\q2 ba woden odetiya odi ay mela ufaysi!
\q1 
\v 24 Garsan de7iya si7oolepe attana mela
\q2 de7o ogey akeeka uraa pude kaalethees.
\q1 
\v 25 Goday otoranchota keetha laallana;
\q2 shin am7e zawa naagees.
\q1 
\v 26 Goday iitata qofaa ixees;
\q2 shin geeshsha qaalan I ufaytees.
\q1 
\v 27 Wordon wodhe demmanaw aaliya asi
\q2 ba soo asaa bolla meto ehees;
\q2 shin wodhaafe ixiya asi de7on daana.
\q1 
\v 28 Xillo asi odetanape sinthatidi qopees;
\q2 shin iitata inxarsaape iitabay pultees.
\p 
\v 29 Goday iitatape haakees;
\q2 shin xillota woosa si7ees.
\p 
\v 30 Som7oy pashkin wozani ufaytees;
\q2 mishiraachoy meqethi minthees.
\q1 
\v 31 De7o immiya zore si7iya asi
\q2 cincatethara issife daana.
\q1 
\v 32 Seera ixiya asi bana qohees;
\q2 shin seera ekiya asi akeeka demmees.
\q1 
\v 33 Godaas yashshi cincatethi tamaarsees;
\q2 ashketethi bonchofe sinthatees.
\c 16
\p 
\v 1 Asi ba wozanan halchees;
\q2 shin like zaaroy Godaape bentees.
\q1 
\v 2 Asi oothiya ooso ubbay iyaw like daanees;
\q2 shin Goday dendo qofaa be7ees.
\q1 
\v 3 Ne ooso ubbaa Godaas hadara imma;
\q2 neeni qopidabay poletana.
\q1 
\v 4 Goday ubbabay qopidaysatho bana mela oothees;
\q2 hanikoka, makallanchota wursethay dhayo.
\q1 
\v 5 Goday otoranchota ixees;
\q2 enti seerettonna attokona.
\q1 
\v 6 Siiqoninne ammanetethan nagari atto geetetees;
\q2 Godaas yayyidi asi iitabaape attees.
\q1 
\v 7 Asa hemethi Godaa ufaysiyabaa gidiko,
\q2 I ba morketara saro daanada oothees.
\q1 
\v 8 Xillotethan bentiya guuthabay,
\q2 wordon demmiya daro wodhepe lo77o.
\q1 
\v 9 Asi wozanan ba oothanaba halchees;
\q2 shin halchoy Godaa maaden poletees.
\q1 
\v 10 Kawoy Xoossaafe ekida maatan pirdees;
\q2 iya inxarsay suure pirdees.
\q1 
\v 11 Gina mizaanetinne maka miisheti Godaaba;
\q2 bayziyaba ubban geney doonna mela Goday koyees.
\p 
\v 12 Kawoti iita ooso ixoosona;
\q2 enta araatay xillotethan eqees.
\q1 
\v 13 Kawoti xillo inxarsan ufaytoosona;
\q2 tumaa haasaya uraa dosoosona.
\q1 
\v 14 Kawa hanqoy hayqo kiitancho mela;
\q2 shin cinca asi hanquwa irxisees.
\q1 
\v 15 Kawa som7oy poo7iko de7oy de7ees;
\q2 Iya lo77otethay ira ehiya shaara mela.
\q1 
\v 16 Cincatethi demoy worqa demope aadhees;
\q2 akeeka demoy bira demope lo77o.
\q1 
\v 17 Suureta ogey iitape haako;
\q2 ba hemethaa naagiya uray ba shempuwa naagees.
\q1 
\v 18 Otoroy dhayo kaalethees;
\q2 ceeqetethi kundethi ehees.
\q1 
\v 19 Otoranchotara di7o shaaketanaape,
\q2 ashke gididi manqidi de7eysi lo77o.
\q1 
\v 20 Zore si7iya uraas I oothiyaba ubbay injetana;
\q2 Godan ammanetiya uray anjetana.
\q1 
\v 21 Ba qofan cinca gidida asi akeekancho geetetees;
\q2 lo77o qaali eratethi gujees.
\q1 
\v 22 Cinca asas eratethi de7o pulto mela;
\q2 shin eeyata seeroy coo wode wursees.
\q1 
\v 23 Cinca asi odetanaape sinthe qopees;
\q2 iya mettershay eratethi gujees.
\q1 
\v 24 Lo77o qaali eessa ililoda mal7ees;
\q2 shempos mal7o; meqethas paxo gidees.
\q1 
\v 25 Asas suure daaniya ogey de7ees;
\q2 shin wursethan hayqoko gathees.
\q1 
\v 26 Asi minnidi oothana mela oothey katha amo;
\q2 koshi minnidi oothana mela denthethees.
\q1 
\v 27 Kawusha asi iitabaa halchees;
\q2 iya oday tamada xuuggees.
\q1 
\v 28 Wobe asi ooshshi denthethees;
\q2 zigirsi ammanetiya laggeta shaakees.
\q1 
\v 29 Gene asi ba shooruwa cimmees;
\q2 lo77o gidonna oge kaalethees.
\q1 
\v 30 Ba ayfen qam7otiya asi geellaba qopees;
\q2 ba mettersha saxidi mandiya asi iitabaa oothees.
\q1 
\v 31 Puulumida huuphey boncho kallacha;
\q2 hessika bentey xillo de7o de7ina.
\q1 
\v 32 Wolqaama asi gidanaape danda7a asi gidoy lo77o,
\q2 daro katamata olidi oykanaape bana haaroy aadhees.
\q1 
\v 33 Asi saama yeggees;
\q2 shin wursetha zaaroy Godaape bentees.
\c 17
\p 
\v 1 Ooshshi de7iya bessan de7iya gita gibiraape
\q2 saroynne wopi de7iya bessan uytha poqoy lo77o.
\q1 
\v 2 Cinca aylley pathonna ba godaa na7aa haarees;
\q2 iya ishatara issife laata shaaketees.
\q1 
\v 3 Worqinne biri taman paaceteysada;
\q2 Goday asa wozana paacees.
\q1 
\v 4 Iita asi iita haasaya si7ees;
\q2 wordanchoy wordo haasaya hayzees.
\q1 
\v 5 Manqota bolla qelqisiya asi enta medhida Xoossaa cayees;
\q2 hara asi gakiya meton ufaytiya asi seerettonna attenna.
\q1 
\v 6 Na7a na7i cima asas kallacha;
\q2 aawati banta naytas boncho.
\q1 
\v 7 Lo77o odi eeya asas giigenna;
\q2 hessadaka wordo odi ayseysas giigenna.
\q1 
\v 8 Wodhaafe immeysas wodhaafey bita mela;
\q2 I biya bessa ubbay iyaw injetees.
\q1 
\v 9 Qoho genthiya uray siiqo koyees;
\q2 shin oda zaaridi zaaridi woociya uray,
\q2 ammanetiya laggeta shaakees.
\q1 
\v 10 Eeyay xeetu toho lisson shocin ereysafe;
\q2 akeeki de7iya asas coo hanqoy era immees.
\q1 
\v 11 Iita asi ubba wode geella;
\q2 qadhey bayna asi iya bolla kiitetana.
\q1 
\v 12 Eeyara iya eeyatethan gahetanaape
\q2 marati eketida maahera gahetethi lo77o.
\q1 
\v 13 Lo77o oothidaysas iita kushe zaariya
\q2 uraa soope iitabay kichenna.
\q1 
\v 14 Ooshshi doomishe haatha dhawa mentheysa mela;
\q2 hessa gisho ooshshi doomanaape koyrottada palama agga.
\q1 
\v 15 Nagaranchuwa xillisoynne
\q2 xilluwa bolla pirdoy,
\q2 nam7ayka Goday ixiya ooso.
\q1 
\v 16 Cincatethi demmanaw amoy bayna de7ishin,
\q2 eeya kushen de7iya miishey ay iya maaddii?
\q1 
\v 17 Laggey ubba wodeka lagge;
\q2 ishi meto wode maaddanaw yeletees.
\q1 
\v 18 Akeeki bayna asi eronna uraa
\q2 acuwa qanxanaw waase gidees.
\q1 
\v 19 Ooshshu dosiya asi nagara dosees;
\q2 ubba wode ceeqetiya asi ba bolla dhayo xeegees.
\p 
\v 20 Wobe qofi de7iya asi lo77oba demmenna;
\q2 ba inxarsan cimmiya asi meton gelees.
\q1 
\v 21 Eeyaa na7a yelida aawi azzanees;
\q2 eeya na7a aawas ufaysi deenna.
\q1 
\v 22 Ufaytiya wozani asas lo77o dhale;
\q2 shin meqida wozani asas wolqa dhaysees.
\q1 
\v 23 Iita asi pirda geellayanaw
\q2 geeman wodhaafe ekees.
\q1 
\v 24 Akeeka asi cincatethi ba sinthafe haassenna;
\q2 shin eeya asa ayfey sa7a gaxa yuuyees.
\q1 
\v 25 Eaya na7i ba aawa azzanthees;
\q2 ba aayiwuka camisees.
\q1 
\v 26 Xillo asi seeroy bessenna;
\q2 suure asi shocoy lo77o gidenna.
\q1 
\v 27 Guutha qaala haasaya asi erancho;
\q2 wopa ayyaani de7iya asi akeekancho.
\q1 
\v 28 Eeya asi si77i giiko cinca daanees;
\q2 ba doona dooyonna ixiko erancho daanees.
\c 18
\p 
\v 1 Shaahetethi koyiya asi ba amuwa kaallees;
\q2 suure qofa ubbaa ixees.
\q1 
\v 2 Eeya asi ba qofaa xalaala qoncisanaw dosees;
\q2 hara asape era ekanaw dosenna.
\q1 
\v 3 Iitatethi yaa wode kadhey yees;
\q2 kawushatethi yaa wode yeelli yees.
\q1 
\v 4 Asa doonape keya odi,
\q2 ciimmo haatha mela;
\q2 cincatethi goggiya pulto mela.
\q1 
\v 5 Naaqida uraa maaddidi, xilluwa pirdaa
\q2 geellayeysi lo77o gidenna.
\q1 
\v 6 Eeya asa odi ooshshu denthethees;
\q2 iya doonay wadho xeegees.
\q1 
\v 7 Eeya asa odi bana qohees;
\q2 iya oday xihe gididi iya oykees.
\q1 
\v 8 Zigirsi mal7o katha mela;
\q2 ufaysishe duge ganje gakees.
\q1 
\v 9 Azalla asi
\q2 dhaysiya asape aybaka dummatenna.
\q1 
\v 10 Godaa sunthay mino gimbe mela;
\q2 xillo asi yaa woxidi saro attees.
\p 
\v 11 Dure asata duretethay gimbetida katama mela;
\q2 enta qofan enta duretethay
\q2 mino dirsada enta naagiyaba daanees.
\q1 
\v 12 Otoroy kundethafe sinthatees;
\q2 ashketethi boncho ehees.
\q1 
\v 13 Si7onna de7ishe zaaro imoy,
\q2 he uraas eeyatethinne yeella.
\q1 
\v 14 Daana gidi qopiko, iya ayyaanay harge danda7isees;
\q2 shin ufaysi qanxiko iya maaddey baawa.
\q1 
\v 15 Akeeka asi eratethi koyees;
\q2 cinca asa haythi cincatethi si7ees.
\q1 
\v 16 Imoti immeysas oge dooyees;
\q2 gita asatara erisees.
\q1 
\v 17 Daynna sinthan koyro shiiqidi mootiya uray,
\q2 iya morkey yin, iya oychana gakanaw,
\q2 ubba wode bana xillo gidi qopees.
\q1 
\v 18 Saama yegethi palama teqees;
\q2 nam7u palamiya asata shaakees.
\q1 
\v 19 Qohetida ishay gimbetida
\q2 katamape aadhidi minnees;
\q2 iya palamay birata gorde mela.
\q1 
\v 20 Asi ba doona odan ba ulo kunthees;
\q2 ba inxarsaa ayfen kallees.
\q1 
\v 21 Hayqoynne de7oy inxarsana;
\q2 neeni ne inxarsaa ayfiya maana.
\q1 
\v 22 Macho demmiday lo77oba demmis;
\q2 i, Godaape teema demmees.
\q1 
\v 23 Manqo asi aaddashidi odetees;
\q2 shin dure asi otoron zaarees.
\q1 
\v 24 Daro laggey de7iya asi ba bolla meto ehees;
\q2 shin ishape aadhidi matatiya laggey de7ees.
\c 19
\p 
\v 1 Ba doonan wordotiya eeya asape
\q2 ba de7uwan borey bayna manqoy lo77o.
\q1 
\v 2 Eri bayna dafetethi lo77o gidenna;
\q2 eeso daroy oge balethees.
\q1 
\v 3 Asi ba eeyatethan ba de7uwa iissees;
\q2 yaatidi Godaa bolla yilotees.
\q1 
\v 4 Duretethi daro lagge shiishees;
\q2 shin manqotethi de7iya laggeta duuthees.
\q1 
\v 5 Wordo marki seerettonna attenna;
\q2 wordo odetey kessi ekenna.
\q1 
\v 6 Daro asay shuuma som7o koyoosona;
\q2 imota immiya asara asi ubbay dabbotees.
\q1 
\v 7 Manqo asi hari attoshin iya ishati ixoosona;
\q2 iya laggeti iyape haakoosona;
\q2 I enta aaddashinka enti iya koyokona.
\q1 
\v 8 Cincatethi demmiya asi ba shempuwa dosees;
\q2 eratethi minthidi oykiya uraas injetees.
\q1 
\v 9 Wordo marki seerettonna attenna;
\q2 wordo odetey dhayana.
\q1 
\v 10 Eeya asas inje de7oy bessenna;
\q2 aylley halaqata haaroy daro iita.
\q1 
\v 11 Cincatethi ase danda7a tamaarsees;
\q2 qoho kadhidi aadhethi bonchisees.
\q1 
\v 12 Kawa hanqoy gaammo gudetha mela;
\q2 shin iya nashshoy maata aacisiya aka mela.
\q1 
\v 13 Eeya na7i ba aawa dhaysees;
\q2 doonama macha xokiya keetha mela.
\q1 
\v 14 Asi keethenne shalo aawupe laattees;
\q2 shin akeeka macho Goday immees.
\q1 
\v 15 Azallatethi dhisko ehees;
\q2 ooso oothonna asi koshatees.
\q1 
\v 16 Kiita naagiya asi ba shempuwa naagees;
\q2 shin qelli giya asi hayqees.
\q1 
\v 17 Manqos keehiya asi Godaas tal7ees;
\q2 Goday he lo77o oosuwa gisho woytees.
\q1 
\v 18 Simo ufaysi de7ishin ne nayta seera;
\q2 seeronna ixiko, ne enta dhaysaasa.
\q1 
\v 19 Elle shenetiya asi ba gatiya ekanaw bessees;
\q2 neeni iya issi toho ashshiyaba gidiko,
\q2 hara wodeka ne iya hessada ashshanaysi attenna.
\q1 
\v 20 Zore si7a; tamaaranaw koya;
\q2 neeni wursethi gakanaw cinca gidana.
\q1 
\v 21 Asi darobaa halchees;
\q2 shin Goday gidabay poletees.
\q1 
\v 22 Asape koyetey ammanetethi;
\q2 wordo gidanaape manqo gideysi lo77o.
\q1 
\v 23 Godaas yashshi de7oko kaalethees;
\q2 iya yayiya asi kallidi de7ees; iiti iya bochenna.
\q1 
\v 24 Issi issi asi daro azalla;
\q2 hari attoshin woxen tushkida
\q2 uythaa pude baaranaw waayetees.
\q1 
\v 25 Neeni qelqisiya asi shociko,
\q2 akeeki pacidaysi cincatethi tamaarana;
\q2 akeeka asi ne hanqetiko, I eratethi demmana.
\q1 
\v 26 Ba aawa bonqiya na7ay,
\q2 ba aayiw yedethiya na7ay,
\q2 yeellanne kawushatethi ehiya na7a.
\q1 
\v 27 Ta na7aw, ne zore si7onna ixiko,
\q2 era ogiyape haakaasa.
\q1 
\v 28 Wordo marki suure pirda bolla qelqisees;
\q2 iita asa dooni iitatethi mittees.
\q1 
\v 29 Qelqisiya asas pirda
\q2 eeyatas wadho koshshees.
\c 20
\p 
\v 1 Mathoya ushshi eeyanne ooshancho oothees;
\q2 ushshan baletiya asi cinca gidanaw danda7enna.
\p 
\v 2 Kawo hanqoy gaammo gudetha mela;
\q2 iya yiloyiya asi ba shempuwa bolla pirdees.
\q1 
\v 3 Palamape haakeysi boncho;
\q2 shin eeya asi ooyetanaw ellesees.
\q1 
\v 4 Azalla goshshanchoy wode naagidi goyenna;
\q2 kathi cakiya wode I woossanaw koyees;
\q2 shin aybaka demmenna.
\p 
\v 5 Asa wozana halchoy ciimmo haatha mela;
\q2 shin wozanaama asi duuqidi kessees.
\q1 
\v 6 Daro asati banta lo77otetha odoosona;
\q2 shin tuma ammanetiya asi demmanay oonee?
\q1 
\v 7 Xillo asi borey bayna de7o de7ees;
\q2 iya kaalliya iya nayti anjetidaysata.
\q1 
\v 8 Kawoy pirdanaw ba araatan uttiya wode,
\q2 iita ubbaa ba ayfen harqidi kessees.
\q1 
\v 9 “Ta wozanay geeshshi; tanan nagari baawa”
\q2 gaanaw danda7iya asi daanesha?
\q1 
\v 10 Goday wordo mizaanenne
\q2 gina gidonna maka miishen go7eteyisata ixees.
\q1 
\v 11 Na7i geeshshinne suure gideysi
\q2 I oothiya ooson eretees.
\q1 
\v 12 Si7iya haythinne xeelliya ayfe,
\q2 Goday medhis.
\q1 
\v 13 Dhiskon ne wode wursiko ne manqana;
\q2 minnada oothiko ne kathi kallana.
\q1 
\v 14 Shammiya asi, “Qohees! Qohees!” yaagees;
\q2 shin bidaape guye, “Gelan shammas” yaagidi ceeqetees.
\q1 
\v 15 Worqey kumis; al7o shuchika bentees;
\q2 shin eri kumida inxarsi ubbaafe aadhida alleeqo.
\q1 
\v 16 Eronna asas waase geliya uraa ma7uwa qaari ekite;
\q2 imatha asas waase geliya uraa ma7o oykite.
\q1 
\v 17 Wordon demmida kathi mal7ees;
\q2 shin aqidi pee7ishe doonan aceda hanees.
\q1 
\v 18 Zore ekada ne qofaa qacha;
\q2 zore ekonna de7ashe ola boopa.
\q1 
\v 19 Zigiriya asi xuura genthenna;
\q2 hessa gisho, coo haasaya asape haaka.
\q1 
\v 20 Ba aawa woyko ba aayiw baaddiya asa,
\q2 de7o xompey sakana dhuman to7ana.
\q1 
\v 21 Koyrora eeson shiiqida shaloy
\q2 wursethan anjetenna.
\q1 
\v 22 Nena qohida uraa qohada zaarana goopa;
\q2 Godan ammaneta; I nena ashshana.
\q1 
\v 23 Goday nam7u qommo mizaane ixees;
\q2 wordo mizaaney iya ufaysenna.
\q1 
\v 24 Asay baana ogiya Goday kaalethees;
\q2 yaatin, asi ba de7on baana ogiya
\q2 waatidi akeekanaw danda7ii?
\p 
\v 25 Eeson, “Haysa taani Xoossas immas” guussinne
\q2 guyepe qiirotethi asas xihe.
\q1 
\v 26 Cinca kawoy geellata shaakidi erees;
\q2 I enta qadhetonna seerees.
\q1 
\v 27 Asa ayyaani Godaas xompe;
\q2 iya gaatha asatethaa ubbaa pilgidi xeellees.
\q1 
\v 28 Siiqoynne ammanetethi kawa naagoosona;
\q2 iya araatay tuma pirdan minnees.
\q1 
\v 29 Yalagata bonchoy enta wolqaa;
\q2 cimata bonchoy enta puulunthaa.
\q1 
\v 30 Mino seeri iitatethi shoddees;
\q2 wadhoy iita wozana laammees.
\c 21
\p 
\v 1 Kawo wozani Godaa kushena;
\q2 iya wozanaa dhawa haathada
\q2 ba koyida soo zaarees.
\q1 
\v 2 Asi oothiyaba ubbay iyaw like daanees;
\q2 shin Goday iya wozanaa qofaa paacees.
\q1 
\v 3 Yarsho yarshanaape aathidi,
\q2 xillonne suure ootheysa Goday dosees.
\q1 
\v 4 Iitati otoroninne ceeqetethan eretoosona;
\q2 hessi qassi nagara.
\q1 
\v 5 Mino oothiya asa halchoy dureyees;
\q2 shin eesotiya ubbay manqees.
\q1 
\v 6 Wordon dagayida shaloy pentoda dhayees;
\q2 hessa koyeysati hayqo koyoosona.
\q1 
\v 7 Iitati suureba oothanaw koyonna gisho,
\q2 enta geella oosoy enta ekidi bees.
\q1 
\v 8 Nagaranchoti geella ogen hemetoosona;
\q2 shin geeshshati suureba oothosona.
\q1 
\v 9 Doonatiya machira issi keethan daanape
\q2 kare darmachan duussi lo77o.
\q1 
\v 10 Iitati iitaba oothanaw amottoosona;
\q2 banta shoorotas qadhetokona.
\q1 
\v 11 Qelqisiya asi seeretiya wode
\q2 wozani bayna uray cincatethi tamaarees;
\q2 wozanaama uray era demmees.
\q1 
\v 12 Xillo Xoossay iitata son oosetiyaba ubbaa be7ees;
\q2 enta shiri yeggidi dhaysees.
\q1 
\v 13 Manqota waasuwa si7anaape gidi,
\q2 ba haythaa tucciya uray, ika waassana;
\q2 I waassin alliya asi dhayana.
\q1 
\v 14 Geeman immiya imoy hanqo doshisees;
\q2 qosan immida wodhaafey hanqo irxisees.
\q1 
\v 15 Suure pirdi pirdetiya wode,
\q2 xilloti ufaytoosona;
\q2 shin iita ootheyisata daganthees.
\q1 
\v 16 Akeeka ogiya haakiya uraa
\q2 hayqoy naagees.
\q1 
\v 17 Injetin daana giya uray manqees;
\q2 woynenne zayte dosiya uray duretenna.
\q1 
\v 18 Xoossa asata ashshanaw iita asati seeretosona;
\q2 ammanetona asati suure asata gisho seeretosona.
\p 
\v 19 Doonatiyanne yilotiya machira daanape
\q2 bazzon de7oy lo77o.
\q1 
\v 20 Wozanaama uraa son mal7o quminne oysi minjettees;
\q2 shin eeya asi de7iyaba ubbaa midigees.
\q1 
\v 21 Xillotethinne siiqo koyiya uraa laythay aduqees;
\q2 he uray xillotethinne boncho demmees.
\q1 
\v 22 Wozanaama asi wolqaama olanchota katamaa olidi oykees;
\q2 enti ammanetiya mino miixaa laallees.
\q1 
\v 23 Ba doonanne ba inxarsaa
\q2 naagiya asi bana metope naagees.
\q1 
\v 24 Otoreynne ceeqetey qelqisiya asi;
\q2 I otorancho gidida gisho asas qopenna.
\q1 
\v 25 Oothanaw koyonna gisho
\q2 azalla amoy wodhees.
\q1 
\v 26 Azalla asi ubba wode darobaa demmanaw amottees;
\q2 shin xilloy baw ashshona immees.
\q1 
\v 27 Goday iitata yarshuwa ixees;
\q2 enti iyaw iita qofan shiishiya yarshuwa aathidi ixees.
\q1 
\v 28 Wordo marki dhayana;
\q2 shin tuma marki eqidi daana.
\q1 
\v 29 Iita asi bessona xaala xaalees;
\q2 shin suure asi yuushshi qopees.
\q1 
\v 30 Asi ba cincatethan, akeekaninne zoren
\q2 Godaara eqetanaw danda7enna.
\q1 
\v 31 Olas para kooranaw danda7etees;
\q2 shin xoonoy Godaaba.
\c 22
\p 
\v 1 Lo77o sunthi daro duretethafe aadhees;
\q2 bonchoy birapenne worqafe aadhees.
\q1 
\v 2 Durenne manqo Goday medhis;
\q2 hessan enti nam7ay issino.
\q1 
\v 3 Cinca asi iita be7idi qosetidi attees;
\q2 shin akeeki bayna asi meton gelidi qohetees.
\q1 
\v 4 Ashketethinne Godaa yashshi,
\q2 duretethi, bonchonne de7o immees.
\q1 
\v 5 Iitata ogen agunthinne xihey de7ees;
\q2 shin bana naagiya asi entafe haakees.
\q1 
\v 6 Na7i waanidi daanaw bessiyako tamaarsa;
\q2 I cimiya wodeka iyape haakenna.
\q1 
\v 7 Durey manquwa haarees;
\q2 tal7e ekiday tal7e immidaysas aylle gidees.
\q1 
\v 8 Nagara zeriya uray waaye cakees;
\q2 iya hanqo xam7ay meqana.
\q1 
\v 9 Ba kathaa manqotas shaakiya gisho
\q2 keeha asi anjetana.
\q1 
\v 10 Qelqisiya asi diggiko,
\q2 palami, ooshshinne cashshi attana.
\q1 
\v 11 Wozani geeshshi gidida asinne
\q2 lo77o oda dosiya asi kawora dabbotees.
\q1 
\v 12 Godaa ayfey eratethi naagees;
\q2 shin wordanchota qaala shiri yeggees.
\q1 
\v 13 Azalla asi, “Karen gaammoy de7ees;
\q2 tana ogen maana” yaagees.
\q1 
\v 14 Layma maccasa dooni wolqaama olla mela;
\q2 Goday hanqetidaysati iyan kundoosona.
\q1 
\v 15 Eeyatethi na7a wozanan de7ees;
\q2 shin pircoy iyape haassees.
\q1 
\v 16 Shalo shiishanaw manquwa naaqeynne
\q2 dure asas imota immiya nam7ay manqana.
\s1 Hastamu Cinca Zoreta
\r (22:17—24:22)
\p 
\v 17 Ne haytha zaarada cincata qaala si7a;
\q2 ne wozanaa ta timirtiyako zaara.
\q1 
\v 18 Enta ne wozanan wothikonne
\q2 ne doonan enta haasayiko, ne ufaytana.
\q1 
\v 19 Ne ammanoy Godan gidana mela,
\q2 taani nena hachi tamaarsayis.
\q1 
\v 20 Taani new zorenne eratethi kumida
\q2 hastamu leemisota xaafas.
\q1 
\v 21 Nena kiittidaysas like zaaro zaarana mela,
\q2 taani nena tumatethi tamaarsas.
\s2 1
\q1 
\v 22 Manqotas aybika bayna gisho, enta bonqofa;
\q2 pirdan enta maata dhaysofa.
\q1 
\v 23 Goday enta gisho mootetana;
\q2 enta bonqidaysata I bonqana.
\s2 2
\q1 
\v 24 Yilotiya uraara laggetopa;
\q2 elle shenetiya uraara hemetofa.
\q1 
\v 25 Neeni iya yiluwara meezetiko,
\q2 guyepe agganaw danda7aka.
\s2 3
\q1 
\v 26 Asa aco ta qanxana gada
\q2 waase gidopa.
\q1 
\v 27 Ne qanxiyaba dhayiko,
\q2 ne zin7iya hiixay attonna,
\q2 new de7iyaba ubbay eketana.
\s2 4
\q1 
\v 28 Ne mayzati tokida
\q2 beni zawa shoddofa.
\s2 5
\q1 
\v 29 Ba oosuwan loohida asi be7adii?
\q2 I coo asatas gidonashin kawotas oothees.
\c 23
\s2 6
\p 
\v 1 Halaqara kathi maanaw uttiya wode,
\q2 neera de7eysa akeeka.
\q1 
\v 2 Neeni daro yaramba asi gidiko naageta.
\q1 
\v 3 I nena paacanaw danda7iya gisho,
\q2 mal7o kathas yaaretopa.
\s2 7
\q1 
\v 4 Duretana gada daaburopa;
\q2 ne qofaa haaranaw cinca gida.
\q1 
\v 5 Hessa mela duretethi ne xeellishin dhayana;
\q2 qefe kessidi arganthada salo paallana.
\s2 8
\q1 
\v 6 Uuze asa kathi moopa;
\q2 iya mal7o kathay nena amoyopo.
\q1 
\v 7 Qoodhepe qommon “Ma; uya” gees;
\q2 shin iya wozanay neera gidenna.
\q1 
\v 8 Ne mida guutha kathaaka cooyana;
\q2 ne galatay mela gidana.
\s2 9
\q1 
\v 9 Ne cincatetha haasaya kadhiya gisho,
\q2 eeya asas paxaba haasayopa.
\s2 10
\q1 
\v 10 Beni zawa shoddofa;
\q2 yi7o nayta zawa sugopa.
\q1 
\v 11 Enta ashshiya Goday mino gidiya gisho;
\q2 i, enta gisho neera mootetana.
\s2 11
\q1 
\v 12 Ne wozanaa zore qaalako,
\q2 ne haytha timirteko zaara.
\s2 12
\q1 
\v 13 Na7a seeronna aggofa;
\q2 ne iya pircon shociko I hayqenna.
\q1 
\v 14 Ne iya pircon shociko,
\q2 iya shempuwa hayqope ashshaasa.
\s2 13
\q1 
\v 15 Ta na7aw, ne wozanay cinca gidiko,
\q2 ta wozanay ufaytana.
\q1 
\v 16 Ne inxarsay suureba haasaya wode,
\q2 ta gaatha asatethay ufaytees.
\s2 14
\q1 
\v 17 Nagaranchota qanaatopa;
\q2 shin ubba wode Godaa yayya.
\q1 
\v 18 Yaatiko new sintha de7oy suurana;
\q2 ne ufaysay dhayenna.
\s2 15
\q1 
\v 19 Ta na7aw, si7a; cinca gida;
\q2 ne wozanaa suure ogiyan naaga.
\q1 
\v 20 Daro woyne ushshu uyeysataranne
\q2 asho maanaw yaareteysatara hemetofa.
\q1 
\v 21 Mathoteysatinne yarambati manqana;
\q2 dhisko daroy curqa mayzees.
\s2 16
\q1 
\v 22 Nena yelida ne aaway odiyaba si7a;
\q2 ne aayiya cimida wode kadhopa.
\q1 
\v 23 Tumaa, cinca, seeranne
\q2 akeeka shammafe attishin, bayzopa.
\q1 
\v 24 Xillo na7a aawi daro ufaytees;
\q2 wozanaama na7a yelida asi iyan ceeqetees.
\q1 
\v 25 Ne aawaynne ne aayiya nenan ufayto;
\q2 nena yelidaara hashshu go.
\s2 17
\q1 
\v 26 Ta na7aw, ne wozanaa taw imma;
\q2 ne ayfeti ta ogiya kallo.
\q1 
\v 27 Layma maccasi ciimmo haatha mela;
\q2 laggetho maccasi xuntha olla mela.
\q1 
\v 28 Iya paannoda zugada naagawusu;
\q2 ammanetona addeta darsawusu.
\s2 18
\q1 
\v 29 Waasoy oossee? Azzanoy oossee?
\q2 Ooshshi oossee? Zuuzunthi oossee?
\q1 Gaasoy bayna madunxethi oossee?
\q2 Ayfe zo7oy oossee?
\q1 
\v 30 Woyne ushshu uyishe wode ongeysatasa gidennee?
\q2 Walahetida woyne ushsha
\q2 ganxidi be7eysatasa gidennee?
\q1 
\v 31 Woyne ushshi zo7ida wode,
\q2 iya malay birille giddon phooliya wode,
\q2 uyin mal7ishe geliya wode iya xeellofa.
\q1 
\v 32 Wursethan shooshada I dukees;
\q2 iita shooshada ba marziya puukees.
\q1 
\v 33 Ne ayfey be7i eronnabaa be7ana;
\q2 ne wozanay suure qopanaw danda7enna.
\q1 
\v 34 Neeni abba giddon zin7ida,
\q2 markabiya tuussa bolla katida ase daanasa.
\q1 
\v 35 Neeni, “Enti tana dechidosona;
\q2 shin ta qohetabike.
\q1 Enti tana wadhidosona;
\q2 shin taw eretibeenna.
\q1 Hara ushshu uyanaw
\q2 taani awude dendanee?” yaagana.
\c 24
\s2 19
\q1 
\v 1 Ta na7aw, iita asata qanaatopa;
\q2 entara laggetanaw amottofa.
\q1 
\v 2 Enti ubba wode iitabaa maqetoosona;
\q2 banta inxarsan gene haasayoosona.
\s2 20
\q1 
\v 3 Keethi cincatethan keexetees;
\q2 akeekan minnees.
\q1 
\v 4 Eri de7iko, qol7i
\q2 al7obaaninne lo77oban kumees.
\s2 21
\q1 
\v 5 Cinca asi wolqaama asape aadhees;
\q2 era asi mino asape lo77o.
\q1 
\v 6 Olas keyanaape koyro halchanaw koshshees;
\q2 daro zore zoriya asatan xoonoy bentees.
\s2 22
\q1 
\v 7 Eeya asi cincatethi akeekanaw danda7enna;
\q2 shiiqo bessan I odiyabay aybika baawa.
\s2 23
\q1 
\v 8 Iita oothanaw qopiya asi
\q2 gene asi geetetees.
\q1 
\v 9 Eeya asa qofi nagara;
\q2 qelqisiya asi ixetees.
\s2 24
\q1 
\v 10 Meto wode ne dol7iko,
\q2 ne wolqay guutha.
\s2 25
\q1 
\v 11 Pirdi bayna hayqos beyisata ashsha;
\q2 shukettanaw biya wode si77i gada xeellofa.
\q1 
\v 12 Ne, “Ta hessa erike” giiko,
\q2 wozana eriya i, be7ennee?
\q1 Ne de7uwa naageysi erennee?
\q2 Asa ubbaas iya oosuwada oosuwada zaarennee?
\s2 26
\q1 
\v 13 Ta na7aw, eessi lo77o gidiya gisho,
\q2 eessi ma; ililo eessi mal7ees.
\q1 
\v 14 Cincatethika hessada
\q2 ne shempuwas mal7o gideysa era.
\q1 Neeni iya demmiyaba gidiko,
\q2 sinthara yaana keehay nebaa;
\q2 ne ufaysay dhayenna.
\s2 27
\p 
\v 15 Xillo asa keethi bonqanaw naagopa;
\q2 iya aquwa dhaysanaw dendofa.
\q1 
\v 16 Xillo asi laapun toho kundikoka dendees;
\q2 shin iitati gadon dhayana.
\s2 28
\q1 
\v 17 Ne morkey kundiya wode ufaytofa;
\q2 I dhubetiya wode hashshu goopa.
\q1 
\v 18 Goday hessa be7idi ufaytenna;
\q2 iya hanqetonna aggaagana.
\s2 29
\q1 
\v 19 Iita ootheyisata gaason hirgofa;
\q2 enta mela gidarkina gada qopofa.
\q1 
\v 20 Iita asas sinthara yaana keehi baawa;
\q2 iitata xompey to7ana.
\s2 30
\q1 
\v 21 Ta na7aw, Godaanne kawa yayya;
\q2 enta bolla makalleysatara hemetofa.
\q1 
\v 22 Hessa mela asata qoponna metoy gakees;
\q2 kawuwapenne Godaape yaana meto oone erey?
\s1 Hara Cinca Zoreta
\p 
\v 23 Cincati gujidi haysada yaagidosona;
\q1 Som7o be7idi pirdoy lo77o gidenna.
\q1 
\v 24 Qohidaysa lo77o oothadasa
\q2 giya daynna, asi baaddana;
\q2 kawotethati iya ixana.
\q1 
\v 25 Qohidaysa ne bala
\q2 giya daynnati lo77oba ekana
\q2 daro anjo demmana.
\q1 
\v 26 Tuma zaaro zaariya asi,
\q2 tuma lagge mela.
\q1 
\v 27 Kasetada ne gadiya goya; kathi zera;
\q2 hessafe guye, ne keethaa keexa.
\q1 
\v 28 Ne shooruwa bolla gaasoy bayna markatofa;
\q2 ne doonan cimmofa.
\q1 
\v 29 “I taw oothidaysada ta iyaw oothana;
\q2 ta iyaw kushe zaarana” yaagopa.
\q1 
\v 30 Taani booza asa goshshara aadhas;
\q2 azalla addiya woyne gadera kanthas.
\q1 
\v 31 Agunthinne sharaafi goozi wothis;
\q2 yuushon de7iya dirsayka laaletis.
\q1 
\v 32 Taani iya be7ida wode qopas;
\q2 iyape timirte ekas.
\q1 
\v 33 Neeni guuthu liipha; guuthu dhiska;
\q2 ne kushiya shiishada guuthu shempa.
\q1 
\v 34 Shin manqotethi paannoda yaana;
\q2 duussa waayey ola miishe oykida asada puttu gaana.
\c 25
\s1 Hara Solomone Leemisota
\p 
\v 1 Haysati Yihuda kawa Hizqiyaasa asati duuqidi xaafida Solomone leemisota.
\q1 
\v 2 Xuura genthoy Xoossas boncho;
\q2 xuura pilgidi kesoy kawotas boncho.
\q1 
\v 3 Saloy dhoqu gidaysadanne
\q2 sa7i ziqa gididaysada
\q2 kawota qofaa asi eranaw danda7enna.
\q1 
\v 4 Birape qita digga;
\q2 hessafe guye, hiillanchoy loythana.
\q1 
\v 5 Kawo sinthafe iita asata digga;
\q2 iya araatay xillotethan minnidi eqana.
\q1 
\v 6 Kawo sinthan eqiya wode ceeqetofa;
\q2 gita asata giddon new besse koyopa.
\q1 
\v 7 Neepe gitatiya asas besse immanaw
\q2 halaqay nena denthin, kawuyeysafe,
\q2 I nena, “Ha dhoqa bessan utta” geysi lo77o.
\q1 
\v 8 Ne ayfen be7idaba markatanaw
\q2 daynna sinthe baanaw ellesopa.
\q1 Ne markata simmin hara asi
\q2 ne markatethay bala gideysa qoncisiko, ne yeellatana.
\q1 
\v 9 Ne giddoninne ne shooruwa giddon palami medhetiko,
\q2 iyara odetada ne palama wursa;
\q2 hara asa xuura qoncisopa.
\q1 
\v 10 Hessi hanonna ixiko ne odeysa si7ida asi
\q2 nena kawushana;
\q2 ne sunthay zaaridi simmonnaada iitana.
\q1 
\v 11 Bessiya wode odetida like qaali,
\q2 bira miishe bolla tigetida worqa alleeqo mela.
\q1 
\v 12 Era asi zoriya zore si7iya haythas,
\q2 hessi worqafe woyko geeshsha worqafe
\q2 oosetida alleeqo mela.
\q1 
\v 13 Katha cakiya wode irxa haathi uyin aleysada,
\q2 ammanthiya kiitanchoy bana kiittoysa ufaysees.
\q1 
\v 14 Immonnaba immana gidi ceeqetiya asi
\q2 iri bayna shaaranne carko mela.
\q1 
\v 15 Danda7a asi halaqa odidi mayzees;
\q2 liiqo qaali meqethi kanthi gelees.
\q1 
\v 16 Eessi demmiko kallana gakanaw ma;
\q2 shin darsiko nena cooshshana.
\q1 
\v 17 Nena uufishe ixonnaada,
\q2 ne shooruwa soo ubba wode boopa.
\q1 
\v 18 Ba shooruwa bolla wordon markatiya asi,
\q2 xam7i, mashshinne toori qoheysada qohees.
\p 
\v 19 Meto wode ammanetona asan zempoy,
\q2 qaaxiya achan coommiyanne
\q2 silida tohon hemeteysa mela.
\q1 
\v 20 Azzanida asas yethi yexiya asi,
\q2 meego wode ma7o qaariyanne
\q2 maduntha bolla caalaba tigiya asa mela.
\q1 
\v 21 Ne morkey koshatiko muza;
\q2 saamotiko ushsha.
\q1 
\v 22 Ne hessa oothiko iya huuphen tama bonqo
\q2 kaashidi qoleysa mela;
\q2 Goday nena woytana.
\q1 
\v 23 Doloha bagga carkoy ira eheysada,
\q2 zigirsi hanqo ehees.
\q1 
\v 24 Doonatiya machira issi keethan daanape
\q2 kare barandan duussi lo77o.
\q1 
\v 25 Daaburida asi irxa haathi uyidi aleysada,
\q2 haaho biittafe yaa lo77o odi ufaysees.
\q1 
\v 26 Iita asa sinthan gulbatiya xillo asi,
\q2 buullotida pultonne iitida olla haatha mela.
\q1 
\v 27 Daro eessi muussi lo77o gidenna;
\q2 hessadaka, ba boncho koshshi bonchisenna.
\q1 
\v 28 Bana haaronna asi
\q2 dirsi laaletida katama mela.
\c 26
\p 
\v 1 Bone shachi, kathi cakiya wode iri koshshonaysada,
\q2 eeyas boncho koshshenna.
\q1 
\v 2 Kafoti yaanne haanne piradhishe ase qohonnaysada,
\q2 gaasoy bayna baaddiya baadethi ase gakenna.
\q1 
\v 3 Paras lisso, hares bixaala koshsheysada
\q2 eeya zokos xam7a koshshees.
\q1 
\v 4 Eeya asas iya eeyatethaada zaaropa;
\q2 zaariko ne iya mela gidana.
\q1 
\v 5 Eeya asas iya eeyatetha qoncisada zaara;
\q2 hessi hanonna ixiko I bana cinca gidi qopana.
\q1 
\v 6 Eeya asa bolla kiita yedoy,
\q2 ba toho qanxi yeggeysa mela
\q2 woyko wodhiyaba uyeysa mela.
\q1 
\v 7 Eeya asa leemisoy,
\q2 silida toho mela maaddenna.
\q1 
\v 8 Eeya asas boncho imoy,
\q2 shuchu yambarshan qachi wothidi
\q2 yambaranaw paaciya asa mela.
\p 
\v 9 Eeya asa leemisoy
\q2 mathotida asi ba kushe caddida agunthu
\q2 kessanaw baaxeteysa mela.
\p 
\v 10 Eeya asa woyko ba oge biya asi
\q2 une oosisanaw qaxariya asi
\q2 ba toora shaaran xongiya asa mela.
\p 
\v 11 Kani ba cooshshako guye simmidi laaceysada,
\q2 eeya asi ba eeyatetha zaari zaari qoncisees.
\p 
\v 12 Bana cinca oothidi xeelliya asape
\q2 eeya asas lo77o qaadi de7ees.
\p 
\v 13 “Azalla asi ogen gaammoy de7ees;
\q2 yashshiya gaammoy ogen yuuyees” yaagees.
\p 
\v 14 Sanqi maxaafe bolla yaanne haanne qaaxeysada,
\q2 azalla asi ba hiixan yaanne haanne shiretees.
\p 
\v 15 Issi issi azalla asi hari attoshin,
\q2 woxen tushidi baaranaw waayetees.
\p 
\v 16 Azalla asi markara odiya laapun cincatape
\q2 bana aadhida cinca gidi qopees.
\p 
\v 17 Bana gathiyabay baynaban palamiya asi
\q2 ogera biya kana haythi oykiya asa mela.
\p 
\v 18-19 Ba shooruwa, “Taani kaasse gayis”
\q2 yaagidi cimmiya asi,
\q2 gooyidi bonqo tama holiya,
\q2 woyko wodhiya donge toora dukiya asa mela.
\p 
\v 20 Mithi wuriko tami to7ees;
\q2 zigirsi dhayiko ooshshi attees.
\p 
\v 21 Xiifi bonqo darseysadanne
\q2 mithi tama darseysada
\q2 palama darsiya asi ooshshu darsees.
\p 
\v 22 Zigirsa qaali mal7o katha mela
\q2 ufaysishe duge ganje bees.
\p 
\v 23 Wozanan iitabay de7ishin,
\q2 ba inxarsan cimo qaala haasaya asi
\q2 biran lanxetida urqa miishe mela.
\p 
\v 24 Gene asi ba wozanan de7iya iitatethaa
\q2 ba inxarsan genthees.
\p 
\v 25 Iya wozanan laapun tunati kumida gisho,
\q2 I lo77o qaala haasaykoka iya ammanopa.
\p 
\v 26 Ba morketetha I genthikoka,
\q2 I oothiya iitay dabaaban qoncana.
\p 
\v 27 Haratas olla bookiya asi he ollan baw kundana;
\q2 harata bolla shuchu gondorsiya asa bolla
\q2 he shuchay simmidi gondoretana.
\p 
\v 28 Wordotiya inxarsi ba qohida asata ixees;
\q2 cimo odi kundethi kaalethees.
\c 27
\p 
\v 1 Wontoy ehanaba ne eronna gisho
\q2 wontoban ceeqetofa.
\q1 
\v 2 Hara asi nena galatope attishin neeni nena galatopa;
\q2 asi ne gisho markatofe attishin, neeni ne keehatethabaa odopa.
\q1 
\v 3 Shuchi gita tooho; shafey deexo;
\q2 shin eeya asi medhiya ooshshi
\q2 nam7aafeka deexees.
\q1 
\v 4 Hanqos qadhey baawa;
\q2 yiloy dhaysiya di7o mela;
\q2 shin qanaatey ubbaafe iita.
\q1 
\v 5 Geemmida siiqope
\q2 baliya wode qoncen hanqetethi lo77o.
\p 
\v 6 Morkey nena tammu toho yeeranaape
\q2 siiqoy nena madunxiseysi lo77o.
\q1 
\v 7 Kallida asi ililo eessi shaattees;
\q2 shin koshatida uraa cammiyabay mal7ees.
\q1 
\v 8 Ba soo aggidi yuuyiya asi,
\q2 ba keethaa aggada paalliya kafo mela.
\q1 
\v 9 Shittoynne sawiya ixaaney ase ufayseysada
\q2 siiqo lagge zorey hessada ufaysees.
\q1 
\v 10 Ne laggetanne ne aawa laggeta aggofa;
\q2 ne metootida wode ne ishaa soo boopa;
\q2 haahon de7iya ishape matan de7iya shooroy lo77o.
\q1 
\v 11 Ta na7aw, cinca gida; tana ufaysa;
\q2 tana kadhiya asaas ta zaaro immana.
\q1 
\v 12 Cinca asi metoy yaa wode be7idi qosetees;
\q2 shin akeeki bayna asi bidi meton gelees;
\q2 yaatidi guyepe qiirotees.
\q1 
\v 13 Eronna asas waase geliya uraa ma7uwa qaari ekite;
\q2 imatha asas waase gelida uraa ma7uwa oykite.
\q1 
\v 14 Wonta guura ba qaala dhoqu oothidi,
\q2 ba shooruwa sarotey iya baaddiya asa mela.
\q1 
\v 15 Doonatiya machanne
\q2 aathiya keethi issino.
\q1 
\v 16 Carko teqanaw, zayte kuucidi oykanaw danda7etonaysada,
\q2 iyo si77i oothanaw danda7etenna.
\q1 
\v 17 Birati birata posheysada,
\q2 asi issoy issuwafe tamaarees.
\q1 
\v 18 Balase mithi loythidi naagiya asi iya ayfe maana;
\q2 ba halaqaa kaaboya oosanchoy bonchetana.
\q1 
\v 19 Haathi mastooteda som7o besseysada,
\q2 asa wozani iya oonatetha bessees.
\q1 
\v 20 Hayqoynne Duufoy kalli eronnaysada,
\q2 asa ayfey kallidi erenna.
\q1 
\v 21 Birinne worqey taman paacetidi geeyeysada,
\q2 asi ba ekiya galatan paacetees.
\q1 
\v 22 Kathi udulan caddeysada,
\q2 eeya asi udulan caddiyakoka
\q2 iyape eeyatethay kichenna.
\q1 
\v 23 Ne dorsata hanota loythada era;
\q2 ne wudiyaka akeekada heemma.
\q1 
\v 24 Ayis giiko, duretethi merinaw deenna;
\q2 kallachika yeletethafe yeletethaas aadhenna.
\p 
\v 25 Mela maatay buucetin, aaca maati keya wode,
\q2 deriya bolla de7iya maatay shiiqidaape guye,
\q2 
\v 26 dorsata ikisepe ne new ma7o kessana;
\q2 deeshata bayzada gade shammana.
\q1 
\v 27 Attida deeshata maathay new,
\q2 ne soo asaasinne ne macca aylletas kathi gidana.
\c 28
\p 
\v 1 Iitati oonika yedethonna baqatoosona;
\q2 shin xilloti gaammo mela yayyonna de7oosona.
\q1 
\v 2 Issi kawotethay makalliko, haareysati daroosona;
\q2 shin kaaletheysi cincanne akeekancho gidiko,
\q2 sarotethinne wopi de7ees.
\q1 
\v 3 Manqota un7ethiya kawoy
\q2 kathi dhaysiya wolqaama ira mela.
\q1 
\v 4 Higge bonchona asi iita asaa sabbees;
\q2 shin higge bonchiya asi iita asaa ixees.
\q1 
\v 5 Iita asatas suure pirdi gelenna;
\q2 shin Godaa goyinniya asi ubbaa akeekes.
\p 
\v 6 Dure gididi cimmiya asi gidanaape,
\q2 suure asi gididi manqo gideysi lo77o.
\p 
\v 7 Higge naagiya na7ay akeeka na7a;
\q2 shin pathonna asara hemetey ba aawa yeellayees.
\p 
\v 8 Mishe yelon tal7eynne ase bonqidi duretiya asi
\q2 he aquwa manqotas keehiya asas shiishees.
\q1 
\v 9 Higge si7anaape gidi ba haytha tucciya,
\q2 uraa woosay Godaa sinthan ixetidaba.
\q1 
\v 10 Suureta iita ogen kaalethiya uray
\q2 ba bookida ollan kundana;
\q2 shin geeshshati lo77oba laattana.
\q1 
\v 11 Dure asi bana cinca gidi qopees;
\q2 shin akeeki de7iya manqoy iya paacees.
\q1 
\v 12 Xilloti xooniya wode asa ubbay ufaytees;
\q2 shin iitati maata oykiya wode asay qosetees.
\q1 
\v 13 Ba nagaraa genthiya asi aacenna;
\q2 shin paaxeynne nagara aggey maarota ekana.
\q1 
\v 14 Godaa ubba wode yayiya asi anjetidaysa;
\q2 shin ba wozana minthiya asi meton gelana.
\q1 
\v 15 Manqo asaa haariya iita halaqay,
\q2 gudiya gaammonne koshatida babantha mela.
\q1 
\v 16 Akeeki bayna kawoy ba deriya qohees;
\q2 shin ase qohonna halaqi daro laythi haarana.
\q1 
\v 17 Ase wodhiya asi hayqana gakanaw baqatishe de7ees;
\q2 iya oonika maaddenna.
\q1 
\v 18 Borey bayna hemetiya asi qohetenna;
\q2 shin geella asi akeekona kundana.
\q1 
\v 19 Minnidi oothiya asi kathi kallees;
\q2 shin pathonna amo kaalliya asi manqotethi laattana.
\q1 
\v 20 Ammanetiya uray daro anjetana;
\q2 shin duretanaw woxiya asi meto be7ana.
\q1 
\v 21 Som7o be7idi pirdoy lo77o gidenna;
\q2 shin asi baso uytha gisho gidi qohees.
\q1 
\v 22 Yaare asi duretanaw baqetees;
\q2 manqotethi akeekona oykanaysa erenna.
\q1 
\v 23 Ase coo sabbiya asape
\q2 hanqetiya asi guyepe galatetees.
\q1 
\v 24 Ba aawanne ba aayiw kaysotidi, “Nagara oothabike”
\q2 giya asinne demmidaba dhaysiya asi issino.
\q1 
\v 25 Uuze asi ooshshi denthees;
\q2 shin Godan ammanetiya asi kallees.
\q1 
\v 26 Banan ammanetiya asi eeya;
\q2 shin cincatethan hemetiya asi saro de7ees.
\q1 
\v 27 Manqos immiya asi metootenna;
\q2 shin enta be7anaape gidi qilim7ey baadetana.
\q1 
\v 28 Iita asati shuumetiya wode asay qosetees;
\q2 shin enti dhayiya wode xilloti daroosona.
\c 29
\p 
\v 1 Daro wode seeretidi simmonna asi
\q2 hassayonna meqana;
\q2 he uraas paxoy baawa.
\q1 
\v 2 Xillo asati shuumetiya wode asay ufaytees;
\q2 shin iitati biitta haariya wode asay un7etees.
\q1 
\v 3 Cincatethi dosiya asi ba aawa ufaysees;
\q2 shin layma maccasa heeran yuuyiya asi ba miishiya wursees.
\q1 
\v 4 Tuma pirdan kawoy ba kawotethaa wopu oothees;
\q2 shin wodhaafe ekiya kawoy ba kawotethaa dhaysees.
\q1 
\v 5 Ba shooruwa cimon sabbiya asi,
\q2 ba tohos xihe yeggees.
\q1 
\v 6 Iita asi ba nagaran oyketees;
\q2 shin xillo asi ufaytees; yexees.
\q1 
\v 7 Xillo asi manqotas suure pirdees;
\q2 shin iita asati hessa erokona.
\q1 
\v 8 Cayiya asati kataman ooshshu denthoosona;
\q2 shin cinca asati hanqo irxisoosona.
\q1 
\v 9 Cinca asi eeya asa pirda keethi efiko,
\q2 eeyay hanqetees; qidhees; iyaw saroy baawa.
\q1 
\v 10 Suuthu gussanaw saamotiya asati suure asi ixoosona;
\q2 xillo asaa wodhanaw koyoosona.
\q1 
\v 11 Eeya asi ba hanquwa yeddi bessees;
\q2 shin cinca asi bana haarees.
\q1 
\v 12 Shuumay wordo oda si7iyaba gidiko,
\q2 iya moorinnati ubbay iita gidoosona.
\q1 
\v 13 Manqoynne ase naaqiya asi issiba koxoosona;
\q2 enta nam7aas ayfe immiday Godaa.
\q1 
\v 14 Kawoy manqotas suure pirdiko,
\q2 I ba araatan gam7ana.
\q1 
\v 15 Pircon seeri naytas cincatethi immees;
\q2 shin yedan diccida na7i ba aayiw kawushshees.
\q1 
\v 16 Iita asati dariya wode nagari darees;
\q2 shin xilloti enta kundethaa be7ana.
\q1 
\v 17 Ne na7aa seera;
\q2 I new saro immana;
\q2 I nena ufaysana.
\q1 
\v 18 Qoncethi bayna ixiko derey yeda gidees;
\q2 shin higge naagiya asi anjetidaysa.
\q1 
\v 19 Aylley coo oda xalaalan seeretenna;
\q2 iyaw geliyakoka I kiitetenna.
\q1 
\v 20 Eeson haasaya asi be7a eray?
\q2 Iyape eeya asas ufaysi de7ees.
\q1 
\v 21 Ne aylliya na7a yeda dichiko,
\q2 iya wursethay azzano gidana.
\q1 
\v 22 Hanqetiya asi ooshshu denthethees;
\q2 elle yilotiya asi daro nagara oothees.
\q1 
\v 23 Otoroy ase kawushshees;
\q2 shin ashke ayyaani de7iya asi bonchetees.
\q1 
\v 24 Kaysora laggetiya asi bana ixiya asi;
\q2 I dabaaban tuma odiko seeretees;
\q2 I tumaa odonna ixiko Godan baadetana.
\q1 
\v 25 Asas yashshi he uraas xihe gidees;
\q2 shin Godan ammanetiya asi saro de7ees.
\q1 
\v 26 Daroti maati de7iya asape made koyoosona;
\q2 shin suure pirdi Godaape bentees.
\q1 
\v 27 Xilloti nagaranchota shaatettoosona;
\q2 iitati suure asaa ixoosona.
\c 30
\s1 Agura Leemisota
\p 
\v 1 Yaaqe na7aa Agura leemisoti haysafe kaallidi xaafetidaysata. Aguri Iti7eelasinne Ukaalas haysa haasayis.
\v 2 Taani asa ubbaafe aadhida eeya;
\q2 asas de7iya akeeki taw deenna.
\q1 
\v 3 Taani cincatethi tamaarabike;
\q2 Geeshsha Xoossabaaka erike.
\q1 
\v 4 Salo pude keyidi duge wodhiday oonee?
\q2 Carko ba kushen oykiday,
\q2 haathe ba afilan yiiciday,
\q2 sa7aa gaxaa minthidi essiday oonee?
\q1 Iya sunthay oonee?
\q2 Iya na7aa sunthay oonee?
\q2 Iya eriya gidiko ane taw oda?
\q1 
\v 5 Xoossa qaalan borey baawa; ubbay tuma
\q2 iyan ammanetiya ubbaas I gondalle.
\q1 
\v 6 Iya qaala bolla aybaka gujofa;
\q2 gujiko I nena seerana;
\q2 ne wordancho gideysa I qoncisana.
\q1 
\v 7 Godaw, ta nena nam7ubba oychayis;
\q2 ta hayqana gakanaw enta tana diggofa.
\q1 
\v 8 Ta ase cimmonna melanne wordo haasayonna mela tana naaga;
\q2 taw koshshiya kathi immafe attishin, tana dure woyko manqo oothofa.
\q1 
\v 9 Dure gidada, “Goday oonee?” gada nena kaddana;
\q2 manqo gidada, kaysada ta Xoossaa sunthaa cayisana.
\q1 
\v 10 Nena baaddonna melanne
\q2 iya baadethay new gome gidonna mela,
\q2 aylliya iya godaara zigropa.
\q1 
\v 11 Ba aawa baaddiyanne ba aayiw anjona yeletethi de7ees.
\q1 
\v 12 Daro tuna gidi uttidi
\q2 bantana geeshshi oothiya asati de7oosona.
\q1 
\v 13 Otoron kumida asatinne
\q2 ase kadhidi xeelliya asati de7oosona.
\q1 
\v 14 Enta achay mashshe gidin,
\q2 enta gaccoy toora gidin,
\q2 manqotanne metootanchota naaqidi,
\q2 entaba bonqiya asati de7oosona.
\q1 
\v 15 Ullathas nam7u macca nayti de7oosona;
\q2 enti, “Hamma! Hamma!” yaagidi waassoosona.
\q1 Kallidi eronna heedzubati de7oosona;
\q2 oyddanthoy qassi “Gidana” gidi erenna.
\q1 
\v 16 Hessati,
\q2 duufo,
\q2 maynnida maccas,
\q2 haathe kallidi eronna mela biittanne,
\q2 “Gidana!” gidi eronna tama.
\q1 
\v 17 Ba aawa leqiya na7aa ayfiya,
\q2 ba aayiya cimin kadhiya na7aa ayfiya,
\q2 zangaaran de7iya quuroti woocana;
\q2 iya ashuwa ankoti maana.
\q1 
\v 18 Tana heedzubati malaalsoosona;
\q2 oyddanthoy ubba taw gelenna.
\q1 
\v 19 Hessati,
\q2 salora paalliya arganthi,
\q2 zaalla bollara kolxiya shooshi
\q2 abba bollara biya markabenne
\q2 geela7ora shiiqo oyketida adde.
\q1 
\v 20 Layma maccasi haniya hanoyka hessa mela;
\q2 Iya masu; shin ba doona quchada,
\q2 “Taani aykoka balabiike” yaagawusu.
\q1 
\v 21 Heedzuban biitti qaaxees;
\q2 oyddanthuwa ubba tookanaw danda7etenna.
\q1 
\v 22 Hessatika,
\q2 aylley kawotida wode,
\q2 eeya asi kathi kallida wode,
\q2 
\v 23 asi ixida maccasi azina gelida wodenne
\q2 macca aylliya ba godatiw laattida wode medhetiya hanota.
\q1 
\v 24 Sa7a bolla oyddu guutha medhetethati de7oosona;
\q2 shin enti aadhida cinca.
\q1 
\v 25 Hessatika,
\q1 Cuncalley wolqi bayna medhetethi;
\q2 shin bantaw miyaba bone shiishidi, minjoosona.
\q1 
\v 26 Gupaleti wolqi baynayisata;
\q2 shin banta keetha zaalla qophon keexoosona.
\q1 
\v 27 Booletas kawoy baawa;
\q2 shin enti ubbay maaran zattoosona.
\q1 
\v 28 Zareti kushen oyketoosona;
\q2 shin kawo gadhon de7oosona.
\q1 
\v 29 Banta maata bessishe hemetiya heedzu medhetethati de7oosona;
\q2 oyddanthoy lo77o hemethi hemetees.
\q1 
\v 30 Hessika,
\q2 do7a ubbaafe minonne yashshi eronna gaammo.
\q1 
\v 31 Macca kuttota giddon hemetiya adde kutto,
\q2 wude kaalethiya deesha kole;
\q2 ba olanchota giddon qoncen eqiya kawa.
\q1 
\v 32 Neeni eeyada otortidaba gidikoka,
\q2 iita oothanaw halchidaba gidiko,
\q2 ane taki gada qopa.
\q1 
\v 33 Maathi bukey oysu kesseysada,
\q2 siidhe dichin suuthi yeysada,
\q2 hanqo denthethoy ooshshu ehees.
\c 31
\s1 Kawa Limu7eela Leemisota
\p 
\v 1 Haysafe kaallidi xaafetida leemisoy, kawa Limu7eela aayiya kawa Limu7eela tamaarsidaysa.
\q1 
\v 2 Ta na7aw, ta ulope wodhidayso,
\q2 taani qangetada yelidayso,
\q2 
\v 3 maccasan ne wolqaa wursofa;
\q2 kawota dhaysiya maccasatan ne minotethaa dhaysofa.
\q1 
\v 4 “Limu7eela, woyne ushshi kawotas bessenna;
\q2 mathoyiya ushshi shuumatas bessenna.
\q1 
\v 5 Enti uyaa wode higge baloosona;
\q2 naaqetida asaa maata qelli goosona.
\q1 
\v 6 Mathoyaa ushshu hayqana haniya uraasinne
\q2 sa7i iitida uraas immite.
\q1 
\v 7 Enti banta manqotethaanne
\q2 banta waayiya doganaw uyo.
\q1 
\v 8 Banta gisho odetanaw danda7onna asaa gisho ne odeeta;
\q2 maaddiya asi baynayisata gisho ne eqa.
\q1 
\v 9 Enta miyen eqada entaw suure pirda;
\q2 manqotanne metootanchota maata naaga” yaagada tamaarsasu.
\s1 Wozanaama Macho
\p 
\v 10 “Wozanaama macho ooni demmanaw danda7ii?
\q2 I gatey zo7o al7o shuchafe aadhees.
\q1 
\v 11 I azinay iyo ammanetees;
\q2 iyaw koshshiyabaape aybika pacenna.
\q1 
\v 12 Iya ba de7o laytha ubban,
\q2 iyaw lo77obaape attishin, iitaba oothuku.
\q1 
\v 13 Suufenne liino koyada,
\q2 ufaytashe ba kushen oothawusu.
\q1 
\v 14 Iya zal7anchota markabe mela;
\q2 ba kathaa haaho biittafe shiishawusu.
\q1 
\v 15 Iya ba soo asaas kathi giigisanawunne
\q2 ba macca aylletas ooso immanaw,
\q2 sa7i wontonna de7ishin dendawusu.
\q1 
\v 16 Lo77o gade koyada shammawusu;
\q2 ba kushen oothada demmida
\q2 miishen woyne tokawusu.
\q1 
\v 17 Iya ba xeessa minthada dancawusu;
\q2 ba qesiya oosos minthawusu.
\q1 
\v 18 Iya wodhe demmanaw minnada zal7awusu;
\q2 iya oothashe qamisiya gisho I xompey to7enna.
\q1 
\v 19 Iya ba hindziritiya oykawusu;
\q2 ba biradhen loythada suqawusu.
\q1 
\v 20 Iya manqotasinne metootanchotas immawusu.
\q1 
\v 21 I soo asa ubbay ho77iya ma7o ma7iya gisho,
\q2 shachi bukikoka iya hirguku.
\q1 
\v 22 Alga bolla hiixiya ma7o sikawusu;
\q2 liinope oosetida ocha teera daaniya ma7o ma7awusu.
\q1 
\v 23 Biitta cimati shiiqiya dubbushan
\q2 I azinay bonchetida asi.
\q1 
\v 24 Liinope ma7onne danco oothada,
\q2 zal7anchotas bayzawusu.
\q1 
\v 25 Iya minonne boncho asi;
\q2 yaana laytha ubban ufaytada de7awusu.
\q1 
\v 26 Cincatethan ba doona dooyawusu;
\q2 ammanthiya zorey I inxarsan de7ees.
\q1 
\v 27 Iya ba soo asaa de7uwa injeyanaw ubba wode oothawusu;
\q2 azallatethi I bolla bentidi erenna.
\q1 
\v 28 I nayti dendidi, iyo nashshoosona;
\q2 I azinay iyo yaagidi galatees;
\q1 
\v 29 Lo77oba oothiya daro maccasati de7oosona;
\q2 shin ne enta ubbaafe aadhasa” yaagees.
\q1 
\v 30 Mali cimmees;
\q2 yegelssatethi dhayana.
\q1 Shin Godaa yayiya maccasiya,
\q2 iya anjetidaaro.
\q1 
\v 31 Iya oothidaba ubbaas iyo woytite;
\q2 I ooso ubbay dabaaban iyo galatiso.
