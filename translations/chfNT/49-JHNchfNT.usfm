\id JHN
\h SAN JUAN
\toc1 EL SANTO EVANGELIO SEGÚN SAN JUAN
\toc2 SAN JUAN
\toc3 Jn.
\mt2 EL SANTO EVANGELIO SEGÚN
\mt1 SAN JUAN
\c 1
\s1 La Palabra de Dios hecha hombre
\p 
\v 1 Chäcäl najtäcä ajni untu que u yälbinte cache' ni T'an, que u yäle' cache'da an Dios. Ni T'an jini ajni t'oc Dios, ni T'an Dios chich täcä.
\v 2 Jinda T'an ajni chäcäl najtäcä t'oc Dios jinq'uin mach to an u pancab.
\v 3 Une nämte' t'oc Dios u chi upete cua' chichca que ayanba. Jini que utiba, si fuera mach por une, machica uti niump'e cua'.
\v 4 Une chich u yäq'ue' cuxleconla. Jini u yäq'ue' cuxleconlaba, une chich ni junch'äcni tuba cäpetela.
\v 5 Tan it'obni tutz'i ni junch'äcni jini. It'obni mach u täpi u jut ni junch'äcni.
\p 
\v 6 Dios u täsqui untu winic u c'aba' aj Juan.
\v 7 Aj Juanba c'oti u yäle' camba u toja, u yäq'ue' tä ute conoce caxca une ni junch'äcni, uc'a ca' jini u tz'onänob upete uc'a ni t'an que u yäle'ba.
\v 8 Aj Juanba mach une ni junch'äcni; uneba c'oti tuba u yäle' caxcamba ni junch'äcni.
\v 9 Jini totoj junch'äcni c'oti pancabba, jin une ni u chictan upetejob.
\p 
\v 10 Ajni pancab, une u chi u pancab, pero machcatac cuxujob pancab mach yuwijob caxca une.
\v 11 C'oti tu cab, pero u yajcäbnajob mach u sapijob.
\v 12 Upete machcatac u sapi, u yäc'bijob sutwänic de u ch'ocob Dios, machcatac u tz'ombi u c'aba'.
\v 13 Jindajob u sujtäjob de u ch'ocob Dios uc'a u cha'num päncäban, mach ca' u päncäban untu ch'oc pancab, mach uc'a yoli u pap y u na', mach uc'a yoli winic, sec' uc'a Dios.
\p 
\v 14 Jini T'an sutwäni de winic, tä' utz u c'ajalin y tä' toj u t'an. Cuxli t'oc no'onla. Cä chänila u pitzilan. Cä Papla Dios u yäc'bi u pitzilan u juntul Ajlo'.
\v 15 Aj Juan u yäq'ui tä ute conoce, t'oc noj t'an u yäli ca'da:
\p ―Jinda ni cäliba: “Machca ni u te ji'pat que no'on más ajnoja que no'on, uc'a une más najtäcä que no'on”.
\p 
\v 16 Cäpete cä mätanla cua' chichca que an tu c'äb une, jini mach uxupba. Tä' re'i utz u c'ajalin t'oc no'onla.
\v 17 Uc'a ni leyba aj Moisés u yäc'bonla. Aj Jesucristo u ye'bonla ni mero u tojaba. Uneba tä' utz u c'ajalin t'oc no'onla.
\v 18 Niuntu mach bay u chäni Dios. U juntul Ajlo', jini tä' yo u Papba, une u yälbonla cache'da an Dios.
\s1 Juan el Bautista habla en favor de Jesucristo
\r (Mt. 3.11‑12; Mr. 1.7‑8; Lc. 3.15‑17)
\p 
\v 19 Tu toja u yäli aj Juan jinq'uin aj judíosob u täsqui aj Jerusalénob ni palejobba y aj levitasob tuba u c'atbenob:
\p ―¿Caxcajet ane?
\p 
\v 20 U p'ali, mach u muquí. U yäli tu toja:
\p ―Mach no'on ni aj Cristojon que u xe u täscun Diosba.
\p 
\v 21 De ya'i u c'atbijob tä cha'num:
\p ―¿Caxcajet jiq'uin? ¿Ane quira aj Elíaset?
\p U yäli:
\p ―Mach jinon.
\p ―¿Ane quira ni ajt'anet ta Dios jini que u xe tä teba?
\p U p'ali:
\p ―Mach jinon täcä.
\p 
\v 22 U c'atbijob tä cha'num:
\p ―Älbenon t'ocob caxcajet jiq'uin uc'a cälben t'ocob machca u täscon t'ocob. ¿Cache'da a wäle' ane, caxcajet?
\p 
\v 23 Une u yäli:
\p ―No'on ni ajt'anon que cä chen noj t'an bajca mach cuxu niuntu. Ca' chich u yäli aj Isaías, ajt'an ta Diosba, no'on täcä cälbenetla ca'da: “To'esbenla u biji Ajnoja”.
\p 
\v 24 Jini machcatac c'oti bajca an aj Juanba, aj fariseojob u täsqui une.
\v 25 De ya'i u c'atbijob ca'da:
\p ―¿Can uc'a jiq'uin a chen c'ablesia si mach jin aj Cristojet, si mach jin aj Elíaset, si mach jin ni ajt'anet ta Dios?
\p 
\v 26 Aj Juan u yälbijob:
\p ―No'on cä chen c'ablesia t'oc ja'. Tänxin de anela ya'an untu que mach a che conocela.
\v 27 Jinda ni u te ji'pat que no'on, jini más ajnoja que no'onba, ixta no'onba mach jin niump'e cua'on tuba cä p'ämben u täbi u pächi'oc.
\p 
\v 28 Upete ni jinda ya' uti tä Betábara tunxe río Jordán bajca u chi c'ablesia aj Juan.
\s1 Jesús, el Cordero de Dios
\p 
\v 29 Päscab aj Juan u chäni cache' ya' u te aj Jesús bajca an une, u yäli ca'da:
\p ―Chänen ni winic u täsqui Dios tuba u pa'säbenob u tanä a'ajtäjob pancab. Une chich ca' a wälä ni ch'oc oveja que u tzämsinte tuba subbintic Diosba.
\v 30 Jinda ni cäliba: “U te ji'pat que no'on untu winic más ajnoja que no'on, uc'a une más najtäcä que no'on”.
\v 31 No'on mach cä chi conoce. No'on aton cä chen c'ablesia t'oc ja', uc'a ca' jini cä ye'benob aj Israel ni winicda.
\p 
\v 32 Aj Juan u yäli tu toja jinq'uin u yäli ca'da:
\p ―Cä chäni ni Ch'u'ul Pixan cache' ya' ti tä cielo y jaqui ca' untu ixsäcpäcä. C'oti tä wa'tä tan u pam aj Jesús y ya' chich coli.
\v 33 No'onba mach cä chi conoce. Machca u täscon cä chen c'ablesia t'oc ja', une u yälbon ca'da: “Jini a chänen u jaque Ch'u'ul Pixan tuyac'o y u colan tuyac'oba, une ni u chen c'ablesia t'oc Ch'u'ul Pixan”.
\v 34 No'on cä chäni, jin uc'a cä totoj äli cache' jinda u Yajlo' chich Dios.
\s1 Los primeros discípulos de Jesús
\p 
\v 35 Päscab tä cha'num ya'an aj Juan t'oc cha'tu u yajcänt'anob.
\v 36 Aj Juan u chäni cache' nume u chen aj Jesús ya'i, u yäli ca'da:
\p ―Chänen ni winic ni ca' a wälä Ch'oc Oveja ta Dios.
\p 
\v 37 Ni cha'tu ajcänt'anob jiniba, jinq'uin u yubi cache' u yäli aj Juan, bixijob tu pat aj Jesús.
\v 38 U suti uba aj Jesús u chänen cache' ya' u tejob tu pat, u yälbijob ca'da:
\p ―¿Cua' a sacänla?
\p Unejob u p'albi:
\p ―Maestro, ¿cada cuxulet?
\p 
\v 39 Une u yälbijob:
\p ―La'ixla, chänenla.
\p Bixijob chich u chänen bajca cuxu. Colijob nämte' t'oc une jimba q'uin jini, uc'a ochiq'uin.
\p 
\v 40 Untu ni machca u yubi cua' u yäli aj Juan y bixi tu pat aj Jesúsba aj Andrés une, u jitz'in aj Simón Pedro.
\v 41 Aj Andrés une ni bixi u sacän najtäcä aj Simón u säcun chichba, u yälbi ca'da:
\p ―Acä pojli t'ocob ni Mesías ―ni t'andaba u yäle' ca'da: Aj Cristo une, ni u täsqui Diosba.
\p 
\v 42 De ya'i u bisi bajca an aj Jesús. Jinq'uin aj Jesús u chäni, u yälbi ca'da:
\p ―Aneba aj Simónet u yajlo'et aj Jonás. Ane u xe a c'aba' aj Cefas ―ni c'aba'daba aj Pedro une tä griegojt'an.
\s1 Jesús llama a Felipe y a Natanael
\p 
\v 43 Päscab ti tu c'ajalin aj Jesús xic tä Galilea. U nuc'ti aj Felipe, u yälbi ca'da:
\p ―Tzäypätinon.
\p 
\v 44 Aj Felipeba tä Betsaida u cab, ya' chich u cäji aj Andrés y aj Pedro täcä.
\v 45 Aj Felipe u nuc'ti aj Natanael u yälbi ca'da:
\p ―Acä chäni t'ocob ni winic u worin äli aj Moisés tan ni jun u tz'ibiba cache' u xe tä te, jini u yäli täcä ajt'anob ta Dios. Uneba aj Jesús u yajlo' aj José tä Nazaret.
\p 
\v 46 Aj Natanael u yäli:
\p ―¿U xe wäreca tä pase ajt'an ta Dios tä Nazaret?
\p Aj Felipe u yäli:
\p ―La'ix uc'a a chänen.
\p 
\v 47 Jinq'uin aj Jesús u chäni cache' ya' u te aj Natanael bajca an, u yäli ca'da:
\p ―Chänen ya' u te untu totoj aj Israel, uneba mach u che jop'ojti'.
\p 
\v 48 Aj Natanaelba u yäli ca'da:
\p ―¿Cada a chon conoce?
\p Aj Jesús u p'ali:
\p ―Machto u pequet aj Felipe, jinq'uin ya'to anet yaba te' higo, cä chänet.
\p 
\v 49 Aj Natanael u yäli:
\p ―Maestro, ane chich u Yajlo'et Dios, aneba u Yajnojalet aj Israelob.
\p 
\v 50 Aj Jesús u yälbi:
\p ―¿Uc'a quira cälbet cache' cä chänet yaba te' higo a tz'onän? Ya'to a xe a chänen q'uen cua' chichca más pitzi que jinda.
\p 
\v 51 Aj Jesús u yälbi täcä ca'da:
\p ―Totojtoj cälbenetla, cache' ya'to a xe a chänenla jäbä ni cielo y cache' ajc'äncanob ta Dios u t'äbo y u jaque bajca anon no'on que sutwänon de winic.
\c 2
\s1 Una boda en Caná de Galilea
\p 
\v 1 Tu yuxp'elib q'uin ji'pat ajni ump'e lotojan tan caj tä Caná ya'i chich tä Galilea. Ya' ajni täcä u na' aj Jesús ya'i.
\v 2 Jo'qui täcä aj Jesús bajca an ni lotojan, con to'o u yajcänt'anob.
\v 3 Jinq'uin xupi u pa' vinojob, u na' aj Jesús u yälbi ca'da:
\p ―Axupi u pa' vinojob.
\p 
\v 4 Aj Jesús u yälbi:
\p ―Cä na', ¿cua' uc'a a wälbenon no'on? Mach to c'ot q'uin cä ye'e' cä poder.
\p 
\v 5 Pero u na' u yälbi machcatac ya'an tä pucob:
\p ―Chenla upete ca' chich u xe u yälbenetla.
\p 
\v 6 Ajni ya'i seis nuc but'i' ja' de ji'tun t'oc jini ja' que u c'äne'ob aj judíosob tuba ajnic limpio, ca' chich nämä u chenobba. Cada jump'e u tawän chap'e uxp'e nuc p'u de ja'.
\v 7 Aj Jesús u yälbijob:
\p ―Tulesanla ni but'i' ja' t'oc ja'.
\p De ya'i u chäctulesijob ixta tu ti'.
\v 8 De ya'i aj Jesús u yälbijob:
\p ―Lupänla bada, y äc'benla u noja ajpuc vino.
\p Ca' jini chich u chijob.
\v 9 Jinq'uin u noja ajpuc vino u cha'uch'i ni ja' que sutwäni de vinoba, une mach yuwi cache'da uti. Jini ajpucob u but'i ja'ba yuwijob cache'da uti. De ya'i u noja ajpuc vino u joq'ui ajlotojan,
\v 10 u yälbi ca'da:
\p ―Upete winic najtäcä u yäc'ben ajlotayajob jini vino utzba, y cuanta u bon uch'ijobba, u yäq'ue' ni mach yoco utzba. Aneba mach che' a chi. Aneba a ch'ujni ni vino utzba tuba uch'cac ji'pat.
\p 
\v 11 Jinda que u chi aj Jesús tan caj tä Caná ya'i chich tä Galileaba, jin une ni najtäcäl patan que u chi tuba u ye'e' u poder, y tuba u ye'e' u pitzilan u patan. U yajcänt'anob u tz'ombijob une.
\p 
\v 12 Ji'pat bixi tä Capernaum. Bixi nämte' t'oc une u na', u jitz'inob y u yajcänt'anob. Mach tä' jäläcnijob ya'i.
\s1 Jesús purifica el templo
\r (Mt. 21.12‑13; Mr. 11.15‑18; Lc. 19.45‑46)
\p 
\v 13 Jinq'uin natz'äli paxcu' taj judíosob, aj Jesús bixi tä Jerusalén.
\v 14 Tama noj ch'u'ul otot u chäni ajchon beq'uetob, ajchon ovejajob, ajchon ixsäcpäcäjob y ajq'uex taq'uinob ya' chumujtacob.
\v 15 Aj Jesús u chi untz'it jätz'onib de ch'ajan. De ya'i u laj pa'sijob upete tama noj ch'u'ul otot, con to'o oveja, con to'o beq'uet, y u laj t'it'bi u taq'uin ajq'uex taq'uinob u t'elejulbi u mesajob.
\v 16 U yälbi ajchon ixsäcpäcäjob ca'da:
\p ―Pa'senla jinda wida. Mach a chen ca'da u yotot cä Pap ca' otot tuba chono.
\p 
\v 17 Ti tu c'ajalin u yajcänt'anob cache' tz'ibi chich ayan tama u jun Dios ni u yäle' ca'daba: “Tä' re'i coba cä cänäntäbenet a wotot”.
\p 
\v 18 Aj judíosob u yälbijob ca'da:
\p ―¿Cua' jini a xe a chen tuba cä chänen t'ocob si ä'bintet chich a chen ca' jini?
\p 
\v 19 Aj Jesús u yälbijob ca'da:
\p ―Jinesanla ni noj ch'u'ul ototda, y uxp'e q'uin acä tz'osen tä cha'num.
\p 
\v 20 Aj judíosob u yäli:
\p ―Cuarenta y seis año jäläcni ta utic jinda noj ch'u'ul otot, ¿y ane a wäle' que uxp'e q'uin a xe a tz'osen?
\p 
\v 21 Jinq'uin u yäli ca'da, mach jin de ni ch'u'ul otot mu' u yäle'. De une chich ni mu' u yäle'ba.
\v 22 Jinq'uin aj Jesús cuxpi tan ajchämeba, u yajcänt'an u c'ajti'ijob jini t'an u yäliba. U tz'onijob ni t'an ta Dios tz'ibiba, y ni t'an u yäli aj Jesúsba.
\s1 Jesús conoce a todos
\p 
\v 23 Jinq'uin ya'an tä Jerusalén tan ni q'uin ch'uje tuba paxcu', q'uen u tz'ombijob uc'a u chänijob cua'tac u chi tuba u ye'e' u poder.
\v 24 Aj Jesús mach u sapi cache' u totoj tz'onänjob, uc'a yuwi chich cache'da an u pixan upetejob.
\v 25 Mach c'änä uc'a machca u yälben cache'da an u pixan winic, uc'a une chich yuwi cache'da an.
\c 3
\s1 Jesús y Nicodemo
\p 
\v 1 Ajni untu aj fariseo, u c'aba' aj Nicodemo, uneba ajnoja taj judíosob.
\v 2 Ni winicdaba c'oti bajca an aj Jesús ac'äb, u yälbi ca'da:
\p ―Maestro, cuwi t'ocob cache' ane atet bajca an Dios tuba a ye'benon t'ocob u t'an, uc'a niuntu mach u ch'ä u chen ca' a chen aneba t'oc poder si Dios mach'an t'oc une.
\p 
\v 3 Aj Jesús u yälbi ca'da:
\p ―Totojtoj cälbenet, machca mach u cha'num päncäba, mach u ch'ä u chänen bajca u chen manda Dios.
\p 
\v 4 Aj Nicodemo u c'atbi:
\p ―¿Cache'da u ch'e' päncäbac noxib cha'num? ¿U ch'e' quira ochic cha'num tuyac'o u na' uc'a päncäbac?
\p 
\v 5 Aj Jesús u p'ali:
\p ―Totojtoj cälbenet, machca mach uc'abla t'oc ja' y mach u mäta ni Ch'u'ul Pixan tuyac'o, ca' a wälä u c'ablan t'ocba, mach u ch'ä ochic bajca u chen manda Dios.
\v 6 Jini u päncäban uc'a winic, winic chich; jini u päncäban uc'a u poder ni Ch'u'ul Pixan, pixan chich.
\v 7 Mach ch'icwänic a jut uc'a cälbet cache' c'änä cha'num päncäbaquet.
\v 8 Ic' u yustan cachichcada. Ane a ubin, pero mach a wi cada u te, y mach a wi cada u xe. Che' chich täcä machca u päncäban uc'a u poder Ch'u'ul Pixan.
\p 
\v 9 Aj Nicodemo sujli u c'atben aj Jesús:
\p ―¿Cache'da u ch'e' utic jinda?
\p 
\v 10 Aj Jesús u yälbi:
\p ―¿Ane maestrojet taj Israel y mach a wi jinda?
\v 11 Totojtoj cälbenet, ni cuwi t'ocobba acäle', ni cä chäni t'ocobba acä tz'aycun, y anelaba mach a sapäla ni cä t'an t'ocob.
\v 12 Si cälbet cua' chichca tuba u pancab y mach a tz'onä, ¿cache'da a xe a tz'onän si cälbenet cua' chichca que ayan tä cielo?
\p 
\v 13 ’Niuntu mach bay t'äbi tä cielo, sec' jini que ya' pasi tä cielo y jaquiba, no'on une que sutwänon de winic. Ya' chich cä cäji tä cielo.
\v 14 Ca' chich aj Moisés u t'äbsi chan bajca mach cuxu niuntu, che' chich c'änä t'äbsinticon tä cruz no'on que sutwänon de winic.
\v 15 Cä xe tä t'äbsinte tä cruz uc'a upete machca u tz'ombenonba mach sätic, unejob paq'uin cuxlecob.
\s1 El amor de Dios para el mundo
\p 
\v 16 ’Dios tä' u yajna'tan upetejob pancab, jin uc'a u yäq'ui u juntul Ajlo' uc'a upete machcatac u tz'omben uneba mach sätic, unejob paq'uin cuxlecob.
\v 17 Uc'a Dios mach u täsqui u Yajlo' pancab tuba u yäc'benob u toje' u tanä a'ajtäjob pancab, u täsqui tuba u japän a'ajtäjob pancab.
\p 
\v 18 ’Machca u tz'omben uneba, mach u yäc'binti u toje' u tanä. Machca mach u tz'ombeba, u yäc'binte u toje' u tanä, uc'a mach u tz'ombi u c'aba' u juntul Ajlo' Dios.
\v 19 U yäc'binte u toje' u tanäjob, uc'a c'oti pancab aj Jesucristo, ni junch'äcni ta Diosba, pero a'ajtäjob pancab más u yajna'tijob it'obni que ni junch'äcni, uc'a ni cua' u chenobba mach utz.
\v 20 Uc'a upete machca u chen cua' chichca mach utz, mach yo u chänen ni junch'äcni, y mach utajob bajca an junch'äcni täcä tuba mach q'uejpinticob uc'a ni u chenob mach utzba.
\v 21 Machca u chen tu toja u te bajca an junch'äcni uc'a chänintic cache' upete jini u chenba, Dios chich u täclen u chen.
\s1 Juan el Bautista vuelve a hablar de Jesús
\p 
\v 22 Ji'pat aj Jesús c'oti t'oc u yajcänt'anob tama cab tä Judea; colijob t'oc ya'i u chen c'ablesia.
\v 23 Aj Juan täcä ya'an u chen c'ablesia tä Enón nätz'ä t'oc tä Salim uc'a ya'i an q'uen ja'. Q'uen gente c'otijob ya'i tä c'ablescan.
\v 24 Aj Juanba mach to u yä'ca tä cárcel jimba q'uinob jini.
\p 
\v 25 U yajcänt'anob aj Juan ajni tä t'an t'oc aj judíosob uc'a jini aj judíosob u yoli u yubin si jini c'ablan taj Juan más u yäq'ue' untu tu toja.
\v 26 Jini u yajcänt'an aj Juan c'otijob ca'an aj Juan u yälbenob:
\p ―Maestro, jini ajni t'oc ane tunxe Jordánba, ni a wäq'ui tä ute conoceba, ya'an u chen c'ablesia, y upete u c'ote bajca an.
\p 
\v 27 Aj Juan u yäli:
\p ―Niuntu mach u ch'ä u chen niump'e cua' si Dios mach u yäc'ben u chen.
\v 28 Anela a wila cache' cäli: No'on mach jinon ni aj Cristojon. No'on täsquinton najtäcä.
\v 29 Ixlotojan jit'oc chich ajlotojan. Ajlotaya tajlotojan tä' ch'a'a ujin jinq'uin u yubin u t'an jini ajlotojan. Che' chich täcä no'on bada tä' ch'a'a cäjin uc'a juli aj Cristo y upete u yubinob u t'an.
\v 30 Une c'änä xic más ajnoja, y no'onba c'änä ajnicon más ajch'och'ocalon.
\s1 El que viene de arriba
\p 
\v 31 Jini u te tä cieloba, ajnoja une tuba upete. No'onla que päncäbonla pancab, tuba chich u pancabonla, y sec' jini ayan pancab, jin chich cä tz'aycunla, pero jini u te tä cieloba, ajnoja chich tuba upete.
\v 32 Cua'tac u chäni, y cua'tac u yubi tä cielo, jin chich u tz'aycun, pero niuntu mach u tz'ombe u t'an.
\v 33 Machca chichca que u tz'omben u t'an, u ye'e' cache' jini t'an que u tz'ayquiba, u t'an chich Dios une, y cache' toj chich.
\v 34 Machca Dios u täsqui, u t'an chich Dios u yäle'. Diosba mach u yäc'ä p'isi ni Ch'u'ul Pixan.
\v 35 Cä Papla Dios u yajna'tan u Yajlo', y u yäc'bi upete cua' chichca tu c'äb.
\v 36 Machcatac u tz'omben u Yajlo' Dios, paq'uin cuxu ayan; machcatac mach u tz'ombe u Yajlo' Diosba mach uxin tä äc'binte paq'uin cuxlec, uc'a Dios chich u xe u yäc'ben u noj toji'tanä.
\c 4
\s1 Jesús y la mujer de Samaria
\p 
\v 1 Aj fariseojobba u yubijob cache' aj Jesús u yosi más ajcänt'an que aj Juan, y cache' u chi más c'ablesia que aj Juan.
\v 2 Aj Jesúsba mach u chi c'ablesia, u yajcänt'anob une ni u chi c'ablesiaba.
\v 3 Jinq'uin aj Jesús u yubi ca' jini, pasi tä Judea, bixi cha'num tä Galilea.
\p 
\v 4 C'änäli numic tä Samaria.
\v 5 C'oti tama ni cab tä Samaria, tama ump'e yoc caj u c'aba' Sicar, nätz'ä t'oc u cab aj Jacob, jini u yäc'bi u yajlo' aj José oniba.
\v 6 Ya'an ya'i ni ch'en que u chi aj Jacob. C'oti aj Jesús ya' jini tänxin q'uin, y chunwäni ti' ch'en, uc'a bo'o ujin t'oc xämba.
\v 7 C'oti untu ix Samaria u lupän ja'. Aj Jesús u yälbi:
\p ―Benon cuch'en tz'ita' ja'.
\p 
\v 8 U yajcänt'anobba san bixijob tan caj u mäne' cua' tä c'uxcan.
\p 
\v 9 Jini ixic u yälbi aj Jesús ca'da:
\p ―Aneba aj judíoset, ¿cua' ti uc'a a c'atbenon ja'? Uc'a no'on ix Samariajon.
\p U yäli ca' jini uc'a aj judíosobba mach u bisa bijob t'oc aj Samariajob.
\v 10 Aj Jesús u yälbi:
\p ―Si a wina'tan ica cua' une ni matän u yäq'ue' Diosba, y si a chen conoce ica ni machca u yälbenet: “Benon cuch'en tz'ita' ja'ba”, ane u ch'e' a c'atben ja' tuba paq'uin cuxlequet, y une u yäc'benet chich.
\p 
\v 11 Jini ixic u yälben:
\p ―Noxi' winic, tam ni ch'en, y mach'an cua' t'oc a lupän. ¿Cada an ac'a jiq'uin jini ja' ta paq'uin cuxleconba?
\v 12 ¿Ane quira más ajnojalet que cä najtäcäl noxi'papla aj Jacob, ni u yäc'bon t'ocob ni ch'endaba? Jinchichba ja'da u yuch'i une, u ch'ocob, y u yäläq'ui.
\p 
\v 13 Aj Jesús u yälbi:
\p ―Machca chichca u yuch'en ni ja' jini, u sujtä tä tiquin u ti'.
\v 14 Machca u yuch'en ni ja' acä'ben no'onba, mach uni' sutwan tä tiquin u ti'. Ni ja' acä'ben no'on, u xe tä ajtä tuyac'o ca' ump'e ch'en que mach uxup u jä'le, u te tä ancäre tuba u paq'uin äc'ben cuxlec.
\p 
\v 15 Ni ixic u yälben:
\p ―Noxi' winic, äc'benon ni ja' jini, tuba mach ni' tiquic cä ti', y tuba mach ni' ticon wida cä ch'e' ja' täcä.
\p 
\v 16 Aj Jesús u yälbi:
\p ―Cux joc'o a wit'oc, y la'ix t'oc wida.
\p 
\v 17 Ni ixic u p'ali ca'da:
\p ―Mach'an quit'oc.
\p Aj Jesús u yälbi:
\p ―Tu toja chich a wäli cache' mach'an a wit'oc.
\v 18 Uc'a cinco a wit'oc ajnet t'oc, y jini ya'an badaba mach jin a wit'oc. Toj chich lo que a wäli.
\p 
\v 19 Jini ixic u yälbi:
\p ―Noxi' winic, acäle' cache' aneba ajt'anet ta Dios.
\v 20 Cä najtäcäl noxi'pap t'ocob u ch'u'ul c'ajti'ijob Dios pan jini tz'ic. Anelaba a wäle'la cache' tä Jerusalén c'änä ch'u'ul c'ajti'cac.
\p 
\v 21 Aj Jesús u yälbi:
\p ―Ixic, tz'ombenon jini cä xe cälbenetba. U xe tä c'ote q'uin jinq'uin mach uxet a ch'u'ul c'ajti'inla cä Papla Dios tu pam jini tz'ic; y mach uxet a ch'u'ul c'ajti'inla tä Jerusalén täcä.
\v 22 Anelaba mach a wila cua' a ch'u'ul c'ajti'inla. No'on t'ocobba cuwi chich t'ocob cua' cä ch'u'ul c'ajti'in t'ocob, uc'a ni Ajjäpomba u xe tä te tan ni aj judíosob.
\v 23 U xe tä c'ote q'uin, y bada ac'oti chich ni q'uin jini que u xe tä c'oteba, jinq'uin machcatac u totoj ch'u'ul c'ajti'in cä Papla Dios u xe u totoj ch'u'ul c'ajti'in t'oc u pixan y tu tojaba, uc'a ni cä Papla Dios jin chich u sacän machcatac u ch'u'ul c'ajti'in ca' jini.
\v 24 Diosba es pixan une. Machcatac u ch'u'ul c'ajti'in, c'änä u ch'u'ul c'ajti'in t'oc u pixan y tu toja.
\p 
\v 25 Ni ixic u yälben ca'da:
\p ―Cuwi chich cache' u xe tä te ni Mesías, jini u yälbinte aj Cristoba. Tu te uneba, u xe u yälbenonla upete cua' yo Dios utic.
\p 
\v 26 Aj Jesús u yälbi:
\p ―No'on chich ni aj Cristojon, mu' cä chen t'an t'oc ane.
\p 
\v 27 Mu'to u yäle' ca' jini jinq'uin c'oti u yajcänt'anob. Ch'icwäni u jutob u chänen cache' ya'an tä t'an t'oc ixic. Niuntu mach u yäli niump'e cua'. Mach u c'atbijob cua' mu' u yäle', y mach u c'atbijob cua' uc'a u pecän.
\v 28 De ya'i ni ixic u colesi u p'u ti' ch'en, bixi tan caj u yälben u lotob ca'da:
\p 
\v 29 ―La'ixla chänen ya'anda untu winic u yälbon upete cua' acä chiba. ¿Mach wäreca jinda ni aj Cristo?
\p 
\v 30 De ya'i machcatac u yubijobba pasijob tan caj bixijob bajca an aj Jesús.
\v 31 Jinq'uin ni ixic bixi tan cajba, u yajcänt'anob u ch'oc chen ubajob t'oc, u yälben:
\p ―Maestro, c'uxnen.
\p 
\v 32 Aj Jesús u yälbijob:
\p ―No'on cä cänäntan cua' cä c'uxe', anelaba mach a wila.
\p 
\v 33 U yajcänt'anob u maläc äle'ob ca'da:
\p ―¿Täsbinti wäre cua' u c'uxe'?
\p 
\v 34 Aj Jesús u yälbijob:
\p ―Jinq'uin cä chen ca' chich yo machca u täsconba y cä tzupsäben u patan, es ca' a wälä san c'uxnon.
\v 35 ¿Mach quira a wäle'la: “Acoli chämp'e mes tuba ch'uch'intic u jut päc'äbi”? Ubixto, no'on cälbenetla: T'äbsen a jutla, y chänen bajca an ni päc'äbi, ac'ä'ni u jut ni päc'äbi tuba ch'uch'intic.
\v 36 Machca u xe u ch'uch'än, u tojcan. Jini jut päc'äbi, jin une ni machcatac u yosinte tuba paq'uin cuxlec. Ca' jini u mul ch'a'alan ujinob machca u tz'aycäben u t'an Dios najtäcä y machca u yäc'ben u tz'onänob ji'pat.
\v 37 Uc'a che' chich u yälcan y toj chich: “Untu u päq'ue', y otro untu machca u xe u ch'uch'än”.
\v 38 Cä täsquetla a ch'uch'änla bajca anela mach a chi patanla; otrojob u chi patan, anelaba ochetla a ch'uch'änla bajca u chi patanob.
\p 
\v 39 Q'uen aj Samariajob tama jini caj u tz'ombijob aj Jesús uc'a jini ixic u yäli ca'da: “U yälbon upete cua' cä chi”.
\v 40 Jinq'uin aj Samariajob c'otijob bajca an aj Jesús, u ch'oc chi ubajob t'oc, u yälbenob colac ya'i. Coli chich ya'i chap'e q'uin.
\v 41 Q'uen täcä u tz'onijob uc'a u yubijob cua' u yäli aj Jesús.
\v 42 U yälbijob ni ixic:
\p ―Bada cä tz'onän t'ocob mach uc'a a t'an aneba, cä tz'onän t'ocob uc'a no'on chich acubi t'ocob u t'an aj Jesús, y bada cuwi chich t'ocob cache' jinda ni Ajjäpom tuba a'ajtäjob pancab, ni aj Cristoba.
\s1 Jesús sana al hijo de un empleado del gobierno
\p 
\v 43 Chap'e q'uin ji'pat, pasi ya'i aj Jesús tä Samaria, bixi tä Galilea.
\v 44 Uc'a aj Jesús chich u yäli cache' untu ajt'an ta Dios mach u tz'ombinti u t'an tan u cab.
\v 45 Tu c'ote tä Galilea, aj galileojob u yosijob chich, uc'a u chänijob upete cache' u chi tä Jerusalén tan q'uin ch'uje. Unejob täcä ya' chich ajnijob tan jini q'uin ch'uje.
\p 
\v 46 C'oti cha'num aj Jesús tan caj tä Caná ya'i chich tä Galilea, bajca u yäc'bi sujlec de vino ni ja'. Ajni tan ni caj tä Capernaum, ya'i chich tä Galilea, untu ajtäclaya tuba ni ajnoja que c'ojo u yajlo'.
\v 47 Jinq'uin u yubi cache' aj Jesús pasi tä Judea y c'oti tä Galilea, bixi u nuc'tan u ch'oc pecän aj Jesús tuba xic u tz'äcälben u yajlo', uc'a chämo u chen.
\v 48 Aj Jesús u yälbi:
\p ―Si mach a chänenla cua' chichca cä chen tuba cä ye'e' cä poder, y si mach a chänenla jini cä chen que mach u che trebe u chen niuntu winicba, mach a tz'onäla.
\p 
\v 49 Ajtäclaya tajnoja u yälbi:
\p ―Noxi' winic, seb cola uc'a mach chämic cajlo'.
\p 
\v 50 Aj Jesús u yälbi:
\p ―Cux, a wajlo' san chich u pojli uba.
\p Jini winic u tz'ombi u t'an aj Jesús, bixi.
\v 51 Jinq'uin u chen tä c'ote tu yotot, u yajpatanob bixi u nuc'tanob, u yälbijob ca'da:
\p ―A wajlo' u pojli uba.
\p 
\v 52 De ya'i une u c'atbijob cua' hora u täq'ui u pojlen uba. Unejob u yälbi:
\p ―Äc'bi numi tänxin q'uin tz'ita' täpi u ticwa.
\p 
\v 53 Jimba rato jini ti tu c'ajalin u pap jini ajyaj cache' jimba hora jini u yälbi aj Jesús ca'da: “A wajlo' san u pojli uba”. Une u tz'oni, y upetejob tan yotot.
\p 
\v 54 Jinda u cha'petz'ib u chi aj Jesús tuba u ye'e' u poder jinq'uin pasi tä Judea c'oti tä Galileaba.
\c 5
\s1 Jesús sana al paralítico de Betesda
\p 
\v 1 Ji'pat ajni ump'e q'uin ch'uje tuba aj judíosob. Jimba q'uin jini aj Jesús sujli tä Jerusalén.
\v 2 Tä Jerusalén ya'an ump'e u ti' ni caj que u yälbinte cache' u yochiba oveja. Nätz'ä ya'i ya'an ump'e u noj yajliba ja' u c'aba' tä hebreojt'an Betesda. Bajca an jini ja' ya'an cinco boch'.
\v 3 Ya' ajnijob ch'a'a tu yaba ni boch' q'uen ajc'ojpanob, ajchoc', machcatac mach u ch'ä u chen xämba utz, ajchämen c'äb, ajchämen oc, u pitänob u nicän uba ja'.
\v 4 Uc'a untu ángelo ta Dios u p'elaj q'uin jaque tama u yajliba ja' u nicän ja'. Machca najtäcä u jaque tama ni ja' cuanta aniquintiba, u pojlen uba t'oc cua' chichca yaj que u cänäntan tuyac'o.
\v 5 Ajni ya'i untu winic u cänäntan treinta y ocho año c'ojo.
\v 6 Jinq'uin aj Jesús u chäni cache' ya' ch'a'a, yuwi chich cache' ajäläcni c'ojo ni winic jini y u yälbi ca'da:
\p ―¿A wo quira a pojlen aba?
\p 
\v 7 Ajc'ojpan u p'ali:
\p ―Noxi' winic, mach'an machca u yäq'ue'on tama jini ja' jinq'uin u niquinte ni ja'. Uc'a mu'to cä jaque no'onba, otroba san chich ajaqui.
\p 
\v 8 Aj Jesús u yälbi:
\p ―Ch'oyen, ch'ä a ch'a'lib, chen xämba.
\p 
\v 9 Seb u pojli uba jini winic, u ch'i u ch'a'lib, bixi tä xämba. Tu q'uin ch'ämbäji une jinq'uin aj Jesús u tz'äcäli.
\v 10 De ya'i aj judíosob u yälbi ni machca tz'äcälquiba:
\p ―U q'uin ch'ämbäji sami. Mach utz a bisan a ch'a'lib, uc'a ley u yäle' que mach u ch'ä cä chen patanla tu q'uini ch'ämbäji.
\p 
\v 11 Une u p'ali:
\p ―Machca u tz'äcälon, une chich u yälbon: “Ch'ä a ch'a'lib y chen xämba”.
\p 
\v 12 Ni aj judíosob u c'atbijob:
\p ―¿Caxcone u yälbet: “Ch'ä a ch'a'lib y chen xämba”?
\p 
\v 13 Machca tz'äcälquiba mach yuwi caxca une, uc'a aj Jesús u tz'eji uba bajca an ni noj q'uenel gente.
\v 14 Ji'pat aj Jesús u chäni cha'num ni winic tan noj ch'u'ul otot, y u yälbi ca'da:
\p ―Ubixto, bada a pojli aba, mach a ni' chen a tanä uc'a mach tic ta'wac'o ump'e cosa peor.
\p 
\v 15 Jinq'uin u yubi jini winic, bixi u yälben aj judíosob cache' aj Jesús une ni u tz'äcäliba.
\v 16 Jin uc'a aj judíosob u sacänob cache'da u tz'ibajtesan aj Jesús y u tzämsenob, uc'a u chi ca' jini tu q'uini ch'ämbäji.
\v 17 Aj Jesús u yälbijob:
\p ―Cä Pap ixta bada u chen u patan, jin uc'a no'on täcä cä chen cä patan.
\p 
\v 18 Jin uc'a aj judíosob tä' u yoli u tzämsenob, mach sec' uc'a mach u cänänta u q'uini ch'ämbäji, uc'a täcä u yäle' cache' u Papba Dios une, y ca' jini u chen uba cache' Dios.
\s1 La autoridad del Hijo de Dios
\p 
\v 19 Aj Jesús u yälbijob:
\p ―Totojtoj cälbenetla: Mach u ch'ä u chen u Yajlo' Dios niump'e cua' si mach äc'bintic u chen. Ca' chich u chäni u chen u Pap, che' chich u chen täcä, uc'a upete jini u chen u Papba, che' chich u chen täcä u Yajlo' Dios.
\v 20 Uc'a cä Papla Dios tä' yoba u Yajlo', jin uc'a u ye'ben upete cua' u chen; y más noj patan u xe u ye'ben u chen une, ixta anela u xe tä tajch'ictä a jutla.
\v 21 Uc'a ca' chich cä Papla Dios u tz'osen ajchämejob, y u yäc'ben cuxlecob, che' chich täcä u Yajlo' Dios u yäc'ben cuxlec machca yo u yäc'benba.
\v 22 Uc'a cä Papla Dios mach u yälä catac an tu toja, catac mach'an tu toja. Une u yäc'bi u Yajlo' u yäle'.
\v 23 Uc'a cä Papla Dios yo que upetejob u yajna'tan u Yajlo', ca' chich u yajna'tinte uneba. Machca mach u yajna'ta u Yajlo' Dios ni u täsquiba, mach u yajna'ta cä Papla Dios täcä.
\p 
\v 24 ’Totojtoj cälbenetla: Machca u yubin cä t'an, y machca u tz'omben machca u täsconba, paq'uin cuxu ayan; mach u yäc'binti u toje' u tanä. Ca' a wälä chämen ajni, y bada cuxpi cha'num.
\v 25 Totojtoj cälbenetla: U xe tä c'ote q'uin y bada chich ac'oti ni q'uin jini que u xe tä c'oteba, jinq'uin ajchämejob u xe u yubin u t'an u Yajlo' Dios, y machcatac u yubin u xe tä cuxpan.
\v 26 Uc'a ca' chich cä Papla Dios u juntuma chich cuxu, y mach c'änä machca u yäc'ben cuxlec, che' chich täcä u yäc'bi u Yajlo' ajnic ca' jini.
\v 27 U yäc'bi täcä u poder tuba u yäle' catac an tu toja, catac mach'an tu toja, uc'a une ni sutwäni de winicba.
\v 28 Mach ch'icwänic a jutla uc'a mu' a ubinla ca' jini, uc'a u xe tä c'ote q'uin jinq'uin upete machcatac ya'an tu muclibajob u xe u yubinob u t'an.
\v 29 U xe tä pasejob tan u mucliba, y machcatac u chi utz u xe tä tz'osintejob tuba cuxlecob, y machcatac mach u chi utzba u xe tä tz'osintejob tuba äc'bintic u toje' u tanä.
\s1 Pruebas de la autoridad de Jesús
\p 
\v 30 ’Mach u ch'ä cä chen niump'e cua' si mach äc'binticon cä chen. Ca' chich acubin, che' chich acäle' catac an tu toja, catac mach'an tu toja. Tu toja cä chen upete. Uc'a mach cä che ca' chich co no'onba. Cä chen ca' chich yo machca u täscon.
\v 31 Si no'on cäle' machcajon, mach'an cua' uc'a tz'onintic ni cäle'ba.
\v 32 Otro une ni u yäle' machcajonba, cuwi chich cache' toj jini u yäle'ba.
\v 33 Anela a täsquila tä c'atbinte aj Juan machcajon, y une u yäli tu toja.
\v 34 No'onba mach c'änä cäc'a niuntu tuba u yäle' caxcajon, pero ni mu' cäle'ba es tuba a tz'onänla y ca' jini a japän abala.
\v 35 Aj Juanba ca' a wälä ump'e chictaya une, que u tile u c'ac'a y u chictan; anelaba ch'a'ali tz'ita' ajinla bajca u chictan.
\v 36 Ya'an cua' u yäle' más tu toja machcajon que ni u yäle' aj Juanba. Ni patan u yäc'bon cä Pap cä tzupsenba, jinchichba patan u ye'e' cache' cä Pap u täscon.
\v 37 Ni cä Pap Dios que u täsconba, une chich täcä u yäli machcajon. Uneba mach bay a ubila u t'an, y mach bay a chämbila u jut.
\v 38 U t'an uneba mach u yoch ta' c'ajalinla, uc'a mach a tz'ombela jini u täscun uneba.
\v 39 A bon tzique'la ni u t'an Dios tz'ibiba, uc'a a wäle'la cache' ca' jini a xe tä äc'binte paq'uin cuxlequetla. Jinchichba u t'an Dios u yäle' machcajon.
\v 40 Pero mach a wo a sapänonla tuba bintiquet paq'uin cuxlequetla.
\p 
\v 41 ’Mach co que winic u yäle' cache' tä' utz cua' cä chen.
\v 42 Cuwi chich cache'da anetla, y cache' anelaba mach a yajna'tala Dios.
\v 43 No'onba aton uc'a cä Pap Dios u täscon, y mach a saponla. Si tic otro sin que Dios u täscunba, jiniba a sapänla.
\v 44 ¿Cache' u ch'e' a tz'ombenla u t'an Dios jinq'uin a wola u yäle' a lotla cache' pitzi cua' a chen, y mach a sapäla jini u yäle' Dios cache' utzba?
\v 45 Mach a wäle'la cache' no'on acä xe cä sube'etla bajca an cä Pap Dios. Ni u xe u sube'etlaba, aj Moisés chich une, jini que tä' a wo a tz'ombenla u t'anba.
\v 46 Si fuera a totoj tz'ombenla u t'an aj Moisésba, a tz'ombenonla ica täcä, uc'a ni jun u tz'ibi aj Moisésba u yäle' caxcajon.
\v 47 Si mach a tz'onäla ni t'an u tz'ibi aj Moisésba, ¿cache'da a xe a tz'onänla cä t'an?
\c 6
\s1 Jesús da de comer a cinco mil hombres
\r (Mt. 14.13‑21; Mr. 6.30‑44; Lc. 9.10‑17)
\p 
\v 1 Ji'pat aj Jesús bixi tunxe nab tä Galilea, u c'aba' täcä Tiberias.
\v 2 Noj q'uelen gente u bixejob tu pat, uc'a u chänijob cache' an u poder tuba u tz'äcälin ajc'ojpanob.
\v 3 Aj Jesús t'äbi pan tz'ic tä chumtä nämte' t'oc u yajcänt'anob.
\v 4 Anatz'äli ni noj paxcu', jini q'uin ch'uje taj judíosobba.
\v 5 Jinq'uin aj Jesús u t'äbsi u jut u chäni cache' ya' u te noj q'uelen gente bajca an, y u yälbi aj Felipe ca'da:
\p ―¿Cada cä mäne'la waj tuba cä'benla u c'uxe' ni gente que ya' u tejob jini?
\p 
\v 6 Jinda u yäli tuba u yubin cache' u xe u p'alän aj Felipe, uc'a uneba yuwi chich cua' u xe u chen.
\v 7 Aj Felipe u p'ali:
\p ―Doscientos taq'uin de waj mach u yäc'ä tuba äc'binticob que sea tz'ita' cua' tä c'uxcan upete ni genteda.
\p 
\v 8 Untu u yajcänt'an aj Jesús u c'aba' aj Andrésba, jitz'in aj Simón Pedroba, u yäli ca'da:
\p 
\v 9 ―Ya'anda untu ajlo' que u cänäntan cinco cebadaj waj, y cha'tu yoc buch'. ¿Cua' tuba jinda, mach u yäc'ä tuba upete?
\p 
\v 10 Aj Jesús u yäli:
\p ―Äc'ben chunwänicob ni gente.
\p Ayan q'uen tz'utz' bänäla bajca anob. Chunwänijob ca' cinco mil wincärejob.
\v 11 Aj Jesús u ch'i jini waj u yälbi Dios que uc'adios u chi. De ya'i u yäc'bi u yajcänt'anob, y u yajcänt'anobba u pucbi machcatac ya' chumujtacba. Che' chich täcä u chijob t'oc ni buch', u pucbijob bäyexca u yolijob.
\v 12 Jinq'uin na'ijob, aj Jesús u yälbi u yajcänt'anob:
\p ―Woyola u colob uc'a mach sätic niump'e cua'.
\p 
\v 13 U woyijob chich u colob, y u tulesijob doce chach de u colob ni cebadaj waj, jin une ni coli bajca c'uxnijob upete ni gente.
\v 14 Jinq'uin jini gentejob u chäni cua' u chi aj Jesús tuba u ye'e' u poder, u yälijob ca'da:
\p ―Totoj jinda ni ajt'an ta Dios u xe tä te pancabba.
\p 
\v 15 Aj Jesúsba yuwi chich cache' u xe tä tejob ni gente u cocoj ch'e'ob tuba u yosen de ajnoja, jin uc'a bixi u juntuma pan tz'ic.
\s1 Jesús camina sobre el agua
\r (Mt. 14.22‑27; Mr. 6.45‑52)
\p 
\v 16 Ochiq'uin u yajcänt'anob jaquijob tu ti' nab.
\v 17 Ochijob tan jucub tuba bixicjob tunxe nab tä Capernaum. A'it'obni, y aj Jesúsba machto c'ot bajca anob.
\v 18 Ch'oyi noj t'olja' tama ni nab uc'a noj gran ic' u yustan.
\v 19 Unejobba anät'ijob tä bab ca' tuba seis kilómetros. De ya'i u chänijob aj Jesús cache' ya' u te tä xämba pan ja' u natz'än jucub, y bäc'tijob.
\v 20 Aj Jesús u yälbijob:
\p ―¡No'on chich! ¡Mach bäc'taquetla!
\p 
\v 21 Unejob ch'a'a ujinob y u yosijob tan jucub; y seb c'oti ni jucub tä cab bajca u xejob.
\s1 La gente busca a Jesús
\p 
\v 22 Päscab jini noj q'uenel gente colijob tunxe nabba ti tu c'ajalinob cache' ump'emp'e jucub ajni ya'i, y cache' aj Jesús täcä mach ochi tama jini jucub, sec' u yajcänt'anob namás bixijob.
\v 23 Jimba q'uin jini c'otijob otros jucub nätz'ä bajca u c'uxijob ni wajba, ya'i chich bajca Cajnojala u yälbi Dios que uc'adios u chi. Ni jucub jini ya' tijob tä Tiberias.
\v 24 Jinq'uin ni gente u chäni cache' mach'an aj Jesús, y mach'an u yajcänt'anob täcä, ochijob tama jini jucub y bixijob tä Capernaum u sacän aj Jesús.
\s1 Jesús, el pan de la vida
\p 
\v 25 Jinq'uin u pojlijob tunxe nab, u c'atbijob:
\p ―Maestro, ¿caq'uin julet wida?
\p 
\v 26 Aj Jesús u p'albijob:
\p ―Totojtoj cälbenetla, a sacänonla mach uc'a a chänila cache' cä ye'i cä poder. A sacänonla uc'a a c'uxila a pa' wajla y bon na'étla.
\v 27 Chen patanla mach tuba a sacänla ni cua' tä c'uxcan que u sätoba. Chenla tuba a sacänla ni cua' tä c'uxcan que u yäq'ue' paq'uin cuxlequetlaba, jin ni cä xe cä'benetla no'on que sutwänon de winicba, uc'a jin chich u yäc'bon cä chen cä Papla Dios, y une u yäle' cache' utz ni cua' cä chen.
\p 
\v 28 Unejob u yälbi:
\p ―¿Cua' patan u ch'e' cä chen t'ocob tuba cä cherben t'ocob u patan Dios?
\p 
\v 29 Aj Jesús u yälbijob:
\p ―Jinda ni Dios yo que a chenlaba, a tz'ombenla ni machca Dios u täsquiba.
\p 
\v 30 Unejob u yälbi:
\p ―¿Cua' jini a chen ane tuba a ye'e' a poder, uc'a cä chänen t'ocob y cä tz'onän t'ocob? ¿Cuaxca patan a cherben Dios?
\v 31 Cä papla oni u c'uxijob maná bajca mach cuxu niuntu, ca' chich tz'ibi tan u jun Dios, ni u yäle' ca'daba: “Waj ti tä cielo une Dios u yäc'bijob tuba u c'uxe'ob”.
\p 
\v 32 Aj Jesús u yälbijob:
\p ―Totojtoj cälbenetla: Aj Moisés mach u yäc'betla ni mero waj que u te tä cieloba. Cä Papla Dios ni u yäc'benetla ni totoj waj que u te tä cieloba.
\v 33 Uc'a jini waj que Dios u yäq'ue'ba, jin une ni ya' ti tä cieloba, jini que u yäq'ue' cuxlec a'ajtäjob pancabba.
\p 
\v 34 Unejob u yälbi:
\p ―Cajnoja, paq'uin äc'benon t'ocob jini waj.
\p 
\v 35 Aj Jesús u yälbijob:
\p ―No'on ni wajon tuba cuxlequetla. Machca u te bajca anon mach uni' xin tä jitz'an, machca u tz'ombenon mach uni' xin tä tiquin u ti'.
\v 36 Bada cälbenetla cache' a chänonla pero mach a tz'onäla.
\v 37 Upete machcatac u yäc'benon cä Papba u te bajca anon; y machca u te bajca anon mach cä pa'se.
\v 38 Uc'a jacon tä cielo mach tuba cä chen cua' co no'on, aton cä chen ca' chich yo cä chen ni machca u täsconba.
\v 39 Jinda yo cä chen cä Pap jini que u täsconba, cä cuxpesan tu xupiba q'uin upete ni u yäc'bon, y mach sätic niuntu.
\v 40 Jinda yo ni machca u täsconba, paq'uin cuxlecob upete machcatac u chänen u Yajlo' y u tz'omben, y no'on cä xe cä cuxpesan tu xupiba q'uin.
\p 
\v 41 Aj judíosob bänäcnajob tä t'an tuyac'o uc'a u yäli: “No'on ni wajon que pason tä cielo jacon pancabba”.
\v 42 U yäle'ob ca'da:
\p ―¿Mach quira jinda ni aj Jesús, u yajlo' aj José, u pap y u na' cä chen conocela? ¿Can uc'a jiq'uin u yäle': “Pason tä cielo jacon pancabba”?
\p 
\v 43 Aj Jesús u yälbijob:
\p ―Mach ajniquetla tä bänäcne tä t'an.
\v 44 Niuntu mach u ch'ä tic bajca anon si mach u yäc'be tic cä Pap ni u täsconba, y ca' jini no'on cä xe cä cuxpesan tu xupiba q'uin.
\v 45 Ajt'anob ta Dios u tz'ibi ca'da: “Dios chich u xe u ye'benob upetejob u t'an”. Jin uc'a upete machcatac u yubi u t'an cä Papla Diosba y machcatac u cäni, u te chich bajca anon.
\p 
\v 46 ’Niuntu mach bay u chäni cä Papla Dios, sec' machca ti bajca an Diosba. Une ni u chäni cä Papla Dios.
\v 47 Totojtoj cälbenetla: Machca u tz'ombenon, paq'uin cuxu u xe tä ajtä.
\v 48 No'on ni wajon que u yäq'ue' paq'uin cuxlec untu.
\v 49 A papla ajni oniba u c'uxijob ni maná bajca mach cuxu niuntu. Mach uc'a ca' jini äc'binti paq'uin cuxlec. Laj chämijob chich.
\v 50 Pero machca u c'uxe' ni waj que pasi tä cielo y jaqui pancabba mach ucham une.
\v 51 No'on une ni wajon que pason tä cielo y jacon pancabba. No'on une cäq'ue' paq'uin cuxlec untuba. Machca u c'uxe' ni wajdaba, u xe tä ajtä paq'uin cuxu. Ni waj cäq'ue' no'onba, cä bec'ta une, acäq'ue' tuba cuxlec a'ajtäjob pancab.
\p 
\v 52 Aj judíosob u maläc täq'uijob päpä' t'an, u yäle'ob:
\p ―Jinda winic ¿cache'da u ch'e' u yäc'benonla u bec'ta tuba cä c'uxe'la?
\p 
\v 53 Aj Jesús u yälbijob:
\p ―Totojtoj cälbenetla si mach a c'uxe'la cä bec'ta no'on que sutwänon de winic, y si mach a wuch'enla cä ch'ich'e, mach uxet tä äc'bintela paq'uin cuxlequetla.
\v 54 Machca u c'uxe' cä bec'ta, machca u yuch'en cä ch'ich'e, paq'uin cuxu ayan; y no'on cä xe cä cuxpesan tu xupiba q'uin.
\v 55 Uc'a cä bec'ta ni totoj we'e, cä ch'ich'e ni totoj buc'a.
\v 56 Machca u c'uxe' cä bec'ta, machca u yuch'en cä ch'ich'e, une paq'uin t'oc no'on ayan, y no'on paq'uin t'oc une ayanon.
\v 57 Ca' chich u täscon cä Papla Dios ni cuxu ayanba, y no'on täcä cuxulon uc'a une, che' chich täcä machca u c'uxe' cä bec'ta, une täcä u xe tä ajtä cuxu, uc'a no'on cä xe cä'ben cuxlec.
\v 58 No'on une ni waj que pason tä cielo y jacon pancabba, mach ca' ni maná u c'uxijob a papla que ajni oniba, jini que chämen ayanob badaba. Machca u c'uxe' ni wajdaba u xe tä ajtä paq'uin cuxu.
\p 
\v 59 Jintacda u yäli tan ch'u'ul otot, bajca u ye'e' u t'an Dios tä Capernaum.
\s1 Palabras de vida eterna
\p 
\v 60 Q'uen u yajcänt'anob, tu yubinob ca' jini, u yälijob:
\p ―Cach ni t'an jini, ¿caxca une u xe u tz'onän?
\p 
\v 61 Aj Jesús yuwi chich tan u pixan cache' u yajcänt'anob bänäcnajob tä t'an uc'a jini u yäliba, y u yälbijob ca'da:
\p ―¿U yäc'benetla quira sujlequetla ta' pat ni acäliba?
\v 62 ¿Cua' ti jini a xe a chenla si a chänenla jiq'uin cache' no'on que sutwänon de winic t'äbicon tä cielo bajca ajnon najtäcä?
\v 63 Pixan u yäq'ue' cuxlec untu, cuerpoba mach u yäc'ä. Jini t'an acälbetlaba tuba a pixanla une, y tuba paq'uin cuxlequetla.
\v 64 Tulaj anetla que mach a tz'onäla.
\p Jinda u yäli uc'a aj Jesús worin yuwi chich machcatac mach u tz'onä, y machca u xe u yäq'ue' tä c'äbä.
\v 65 Aj Jesús u yäli täcä:
\p ―Jin uc'a cälbetla que niuntu mach u ch'ä tic bajca anon si mach u yäc'be tic cä Papla Dios.
\p 
\v 66 Uc'a ni t'anda que u yäliba, q'uen u yajcänt'anob sutwänijob tu pat, y mach uni' numob t'oc.
\v 67 De ya'i aj Jesús u yälbijob ni doceba ca'da:
\p ―¿A wola quira bixiquetla täcä?
\p 
\v 68 Aj Simón Pedro u p'albi:
\p ―Cajnoja, ¿caxca t'oc jiq'uin cä xe t'ocob? A t'an ane u yäq'ue' paq'uin cuxlecon t'ocob.
\v 69 No'on t'ocob cä tz'onän t'ocob, y cuwi t'ocob cache' ane aj Cristojet, u Yajlo'et ni Dios cuxuba.
\p 
\v 70 Aj Jesús u yälbi:
\p ―¿Mach quira cä yaquetla anelaba doce, y untu de anelaba tuba ni diablo une?
\p 
\v 71 Jinda u yäli uc'a aj Judas Iscariote, u yajlo' aj Simón, u xe u yäq'ue' tä c'äbä, y uneba untu de ni docejobba.
\c 7
\s1 Los hermanos de Jesús no le creían
\p 
\v 1 Ji'pat coli aj Jesús tä Galilea, mach u yoli xic tä Judea uc'a aj judíosob u sacänob cache'da u tzämsen.
\v 2 Anatz'äli q'uin ch'uje taj judíosob, jini q'uin ch'uje ta boch'.
\v 3 U jitz'inob aj Jesús u yälbijob ca'da:
\p ―Pasen wida cux tä Judea tuba u chänenob a wajcänt'anob ya'iba cua' patan a chen.
\v 4 Machca yo ubcac cua' u chen, mach mucu u chen u patan. Si ane a chen cua' chichca tuba chäninticba, chen tuba u chänen upete.
\p 
\v 5 U jitz'inob u yälijob ca'da uc'a unejob täcä mach u tz'onä.
\v 6 Aj Jesús u yälbijob:
\p ―Mach to c'ot q'uin ta xicon. Anelaba u ch'e' xiquetla cachichcamba q'uin.
\v 7 A'ajtäjob pancab mach u cräxna'tetla. No'onba u cräxna'tanonob uc'a cäle' tu toja cache' mach utz cua' u chenob.
\v 8 Anelaba cuxla tä q'uin ch'uje. No'onba mach to xon bajca an ni q'uin ch'uje jini uc'a mach to c'ot q'uin xicon.
\p 
\v 9 Cuantu yälbijob ca'da, une coli tä Galilea.
\s1 Jesús en la fiesta de las chozas
\p 
\v 10 Ji'pat que bixi u jitz'inob tä q'uin ch'uje, bixi täcä c'äs mucu, y mach u ye'i uba.
\v 11 Aj judíosob cayi u sacänob tan q'uin ch'uje, u yäle'ob ca'da:
\p ―¿Cada wäre an jini winic?
\p 
\v 12 Ni noj q'uenel gente ju'lawjob uc'a u tulaj äle'ob ca'da: “Utz u chen jini winic”. Y otrosjob u yäle'ob ca'da: “Mach une. Ni winic jiniba u sucpecänonla”.
\p 
\v 13 Niuntu mach yo u tz'aycun aj Jesús uc'a u bäc'tanob aj judíosob.
\p 
\v 14 La mitad to u colan ta xupic ni q'uin ch'uje, aj Jesús ochi tan noj ch'u'ul otot u ye'e' u t'an Dios.
\v 15 Aj judíosob tajch'icwäni u jutob u yubin cua' u yäle', y u yäle'ob ca'da:
\p ―¿Cache'da yuwi q'uen cua' chichca jini winic, y mach ajni u cäne'?
\p 
\v 16 Aj Jesús u yälbijob:
\p ―Jini cä ye'e'ba mach jin cä t'an une. Cä ye'e' u t'an machca u täscon.
\v 17 Machca chichca yo u chen cua' yo Dios, u xe chich yuwina'tan si ni cä ye'e'ba tuba Dios, o si no'on chich acä pa'si täj c'ajalin.
\v 18 Machca u yäle' jini u te tu c'ajalinba, une chich u sacän älbintic cache' pitzi cua' u chen. Pero machca u sacän cache' ch'u'ul c'ajti'cac ni Dios u täsquiba, jin une ni u tojaba. Y mach'an jop'ojti' t'oc.
\p 
\v 19 ’¿Mach quira u yäc'betla ni ley aj Moisés? Y niuntu de anela mach a chela tu toja ca' u yäle' jini ley. ¿Cua' uc'a a sacänla cache' a xe a tzämsenonla?
\p 
\v 20 Ni gente u yälbijob ca'da:
\p ―Ane a cänäntan tzuc pixan ta'wac'o. ¿Caxcone u sacän u tzämsenet?
\p 
\v 21 Aj Jesús u yälbijob:
\p ―Tajch'icwäni a jutla a chänen jini cä chi t'oc poder tu q'uini ch'ämbäji.
\v 22 Aj Moisés u yäc'betla ni circuncisión, mach uc'a aj Moisés u yäq'ui, a najtäcäl noxi'papla u yäq'ui; y tu q'uini ch'ämbäji a wäq'ue' tä ute circuncisa untu.
\v 23 Si anela a chen circuncisa untu ch'oc tu q'uini ch'ämbäji uc'a mach a säte'la t'oc ni ley taj Moisés, ¿cäräxetla quira t'oc no'on uc'a tu q'uini ch'ämbäji cä tz'äcäli untu winic?
\v 24 Mach a päpä' äle'la si mach tu toja cua' u chen untu jinq'uin a taj chänenla y mach totoj a wila. Äläla jinq'uin a wila chich si tu toja o mach tu toja.
\s1 Jesús habla de su origen
\p 
\v 25 Aj Jerusalénob u tulaj älijob ca'da:
\p ―¿Mach quira jinda ni mu' u saquinte ta tzämsinticba?
\v 26 Chänen cache' u chen t'an tuba u yubin upete, y mach u yälbinti cua'. ¿Yuwijob wäreca ajnojajob cache' totoj jinda naj Cristo, ni u xe u täscun Diosba?
\v 27 Pero ni winicdaba cuwila chich cada an u cäji. Jinq'uin u xe tä te aj Cristoba, niuntu mach uxin u wina'tan cada u xe tä te.
\p 
\v 28 Aj Jesúsba t'oc noj t'an u ye'e' u t'an Dios tan noj ch'u'ul otot, u yäle' ca'da:
\p ―¡No'onba a chenonla conoce, a wila chich cada an cä cäji! Pero mach uc'a cä pa'si täj c'ajalin no'on ticon, täsquinte acä chi. Machca u täsconba, une ni mero Dios. Anela mach a che conocela.
\v 29 No'onba acä chen conoce uc'a ya' aton bajca an, y une u täscon.
\p 
\v 30 De ya'i u sacänob cache' u q'ueche'. Pero niuntu mach u jup'i u c'äb u q'ueche' uc'a mach to c'ot q'uin ta q'uechcac.
\v 31 Q'uen machca u tz'ombijob, y u yäle'ob ca'da:
\p ―Jinq'uin u xe tä te aj Cristoba, ¿u xe u ye'e' más u poder a wäle' que jinda winic?
\s1 Los fariseos mandan policías a llevarse preso a Jesús
\p 
\v 32 Aj fariseojob u yubijob cache' ni gente bänäcnajob tä t'an u tz'aycunob aj Jesús. Ajnojajob ta palejob y aj fariseojob u täsqui u yajc'äncanob tuba u q'ueche'.
\v 33 Aj Jesús u yäli:
\p ―Cä xe tä ajtä chap'e uxp'e q'uin t'oc anela, de ya'i cä xe tä bixe bajca an machca u täscon.
\v 34 A xe a sacänonla, y mach uxet a pojlenonla. Bajca cä xe tä ajtä, anelaba mach u ch'ä xiquetla.
\p 
\v 35 De ya'i aj judíosob u maläc älijob:
\p ―¿Cada u xe jinda winic que mach cä pojlenla? ¿Ya' wäre u xe bajca nonoj bixijob aj judíos ca'an aj griegojob tuba u ye'benob u t'an Dios aj griegojob?
\v 36 Cua' ti jini u yäli: “A xe a sacänonla, mach uxet a pojlenonla; bajca cä xe tä ajtä, anela mach u ch'ä xiquetla”.
\s1 Ríos de agua viva
\p 
\v 37 Tu xupiba q'uin ta ni q'uin ch'uje, jini mero q'uin tuba ni q'uin ch'ujeba, aj Jesús wa'wäni y t'oc noj t'an u yäli:
\p ―Machca chichca tiquin u ti', tic bajca anon tä buc'a.
\v 38 Machca u tz'ombenon cä t'an ca' chich u yäle' ni jun ta Dios tz'ibiba, ca' a wälä noj q'uelen ja' u xe tä pase tu pixan tuba u yäc'ben paq'uin cuxlec y tuba cuxlec täcä u lotob.
\p 
\v 39 Jinda u yäli cache' Ch'u'ul Pixan u xe tä äc'bintejob machcatac u tz'omben uneba; uc'a mach to jul ni Ch'u'ul Pixan uc'a aj Jesús mach to bix tä cielo tuba äc'bintic u pitzilan.
\s1 División entre la gente
\p 
\v 40 Jinq'uin u yubijob ni t'anda, u tulaj älijob:
\p ―Totoj jinda ni ajt'an ta Dios.
\p 
\v 41 Otros u yälijob:
\p ―Jinda ni aj Cristo.
\p Otros u yälijob:
\p ―¿Tä Galilea quira u xe tä te ni aj Cristo?
\v 42 ¿Mach quira u yäle' ni jun ta Dios tz'ibiba cache' aj Cristo u xe tä te de u familiajob aj David, tä Belén bajca u cäji aj David?
\p 
\v 43 Ni gente u jec'li ubajob tä t'an uc'a aj Jesús.
\v 44 Ajni machca u yolijob u q'ueche', pero niuntu mach u jup'i u c'äb u q'ueche'.
\s1 Las autoridades no creen en Jesús
\p 
\v 45 Ajc'äncanob c'otijob bajca an ajnojajob ta palejob y bajca an aj fariseojob. Unejob u yälbi ni ajc'äncanob:
\p ―¿Can uc'a mach a täsila?
\p 
\v 46 Ajc'äncanob u p'ali:
\p ―¡Mach bay u chi t'an niuntu winic ca' u chen ni winicba jini!
\p 
\v 47 Aj fariseojob u p'ali:
\p ―¿U sucpequetla quira anela täcä?
\v 48 ¿Mach quira a chänila cache' mach'an niuntu ajnojajob o aj fariseojob que u tz'ombijob?
\v 49 Jini gente que mach yuwijob ni leyba, mach jin tuba Dios.
\p 
\v 50 Aj Nicodemo, jini aj Nicodemo c'oti bajca an aj Jesús ac'äbba, une täcä es untu de ni ajnojajob, une u yälbenob ca'da:
\p 
\v 51 ―¿Ni ley täc'ala, u yäc'ben quira u toje' u tanä untu si mach to cheque cua' u chi? Mach une.
\p 
\v 52 Unejob u yälbijob:
\p ―¿Ane täcä aj galileojet quira? Sacän tan u jun Dios, iran cache' tä Galilea mach bay pasi niuntu tuba xic de ajt'an ta Dios.
\p 
\v 53 De ya'i cada juntu laj bixijob tu yotot.
\c 8
\s1 La mujer adúltera
\p 
\v 1 Aj Jesús bixi tu pam jini tz'ic u c'aba' Olivas.
\v 2 Päscab isapan sutwäni tan noj ch'u'ul otot. Upete ni gente c'otijob bajca an. Chunwäni u ye'benob u t'an Dios.
\v 3 Jinq'uin jini que u ye'e' ni leyba nämte' t'oc aj fariseojob u c'osbijob untu ixic q'uechqui t'oc winic; u yäq'uijob tänxin gente.
\v 4 U yälbenob aj Jesús:
\p ―Maestro, jinda ixic aq'uechqui t'oc winic y mach jin jit'oc.
\v 5 Aj Moisés u yäli tuyac'o ley tzämsintic t'oc ji'tun machca u chen ca' jini. ¿Aneba, cache' a wäle'?
\p 
\v 6 Jinda u yälijob uc'a u yubinob cache' u xe u p'alän, tuba ajnic cache'da u sube'ob aj Jesús si mach u p'alä tu toja. Aj Jesús tinwäni u tz'ibän t'oc u ni'c'äb tä cab.
\v 7 Uc'a u bon c'atbenob, wa'wäni aj Jesús u yälbenob:
\p ―Machca de anelaba mach'an u tanä u julben najtäcä ni ji'tun tuyac'o.
\p 
\v 8 Tinwäni tä cha'num u tz'ibän tä cab.
\v 9 Jinq'uin u yubijob ca' jini, u ch'i quisin tu c'ajalinob, u täq'uijob tulaj bixe noxibilba ixta que laj bixi upetejob. Coli u juntuma aj Jesús t'oc jini ixic que u yäq'uijob tänxinba.
\v 10 Wa'wäni aj Jesús u chänen cache' mach'an machca sec' ixic u juntuma, u yälbi jini ixic:
\p ―¿Cada an machcatac u sube'et? ¿Mach quira coli niuntu machcatac u c'atän a toje' a tanä?
\p 
\v 11 Une u yäli:
\p ―Noxi' winic, mach ni' an niuntu.
\p Aj Jesús u yälbi:
\p ―Ni no'on täcä mach cä'bet a toje' a tanä. Cux, mach a ni' chen a tanä.
\s1 Jesús, la luz del mundo
\p 
\v 12 Ji'pat aj Jesús u pequijob ni gente tä cha'num, u yälbijob:
\p ―No'on ni junch'äcnilon tuba machcatac cuxujob pancab. Machca u tzäypätinon mach uxin tä nume tan it'obni, une u xe u cänäntan junch'äcni ta paq'uin cuxlec.
\p 
\v 13 Jinq'uin aj fariseojob u yälbi:
\p ―Ane chich mu' a wäle' machcajet. Jini a wäle'ba mach toj une.
\p 
\v 14 Aj Jesús u yälbijob:
\p ―Mach u che si no'on chich acäle' machcajon, jini acäle'ba toj une, uc'a cuwi cada ton y cada cä xe. Anelaba mach a wila cada ton, y mach a wila cada cä xe.
\v 15 Jinq'uin a wäle'la catac an tu toja, catac mach'an tu toja, ta' c'ajalinla chich a pa'senla. No'onba mach cälä catac an tu toja, catac mach'an tu toja.
\v 16 Y si no'on cäle' catac an tu toja, catac mach'an tu toja, ni cäle'ba toj une; uc'a mach sec' no'on cäle'. Cä Pap, ni u täsconba, che' chich u yäle' täcä.
\v 17 Ya' chich tz'ibi tuyac'o ley ta'ala ni u yäle' ca'daba: “U t'an cha'tu winicba toj une”.
\v 18 No'on chich cäle' machcajon y cä Pap täcä, ni u täsconba, u yäle' machcajon.
\p 
\v 19 De ya'i u c'atbijob:
\p ―¿Cada an a Pap?
\p Aj Jesús u p'ali:
\p ―Mach a chon conocela; cä Pap täcä mach a che conocela. Si fuera no'on a chenon conocela, cä Pap täcä a chen conocela ica.
\p 
\v 20 Jinda t'an u yäli aj Jesús bajca u yälo taq'uin jinq'uin ya'an u ye'e' u t'an Dios tan noj ch'u'ul otot. Niuntu mach u q'uechi uc'a mach to c'ot q'uin ta q'uechcac.
\s1 “A donde yo voy, ustedes no pueden ir”
\p 
\v 21 Aj Jesús u yälbijob tä cha'num:
\p ―No'on acä bixe, y a xe a sacänonla. T'oc a tanäla a xe tä chämola; bajca cä xe no'onba, anelaba mach u ch'ä xiquetla.
\p 
\v 22 Aj judíosob u yälijob ca'da:
\p ―¿U xe wäreca u tzämsen uba, jin uc'a u yäle': “Bajca cä xe, anela mach u ch'ä xiquetla”?
\p 
\v 23 Une u yälbijob:
\p ―Anela päncäbetla pancab, no'on ton tä cielo; anela tuba jinda u pancabetla, no'on mach tuba jinda u pancabon.
\v 24 Jin uc'a cälbetla a xe tä chämola t'oc a tanä, uc'a si mach a tz'onäla cache' no'on aj Cristojon a xe tä chämola t'oc a tanä.
\p 
\v 25 Unejob u c'atbenob:
\p ―¿Caxcajet ane?
\p Aj Jesús u yälbijob:
\p ―Jin chich na cälbetla najtäcäba.
\v 26 Q'uen ayan cua' cäle' y quiran si tu toja ayanetla. Machca u täsconba, toj u t'an une; jin acubi u yäle' uneba, jin chich acäle' pancab.
\p 
\v 27 Mach u chi entendejob cache' jini u yäliba de cä Papla Dios une.
\v 28 Aj Jesús u yälbijob:
\p ―Jinq'uin a xe a t'äbsenonla tä cruz no'on que sutwänon de winic, jinq'uin u xe tä te ta' c'ajalinla cache' no'on ni aj Cristojon, ni u täscon Diosba, y u xe tä te ta' c'ajalinla cache' no'on mach cä che niump'e cua' si mach a'binton cä chen. Ca' chich u ye'bon cä Pap, jin chich acäle'.
\v 29 Uc'a machca u täscon ya' chich an t'oc no'on. Cä Pap mach u yäcton cä juntuma uc'a no'on cä paq'uin chen cua' chichca yo.
\p 
\v 30 Tu yäle' jinda t'an, q'uen u tz'ombijob.
\s1 Los hijos de Dios y los esclavos del pecado
\p 
\v 31 Aj Jesús u yälbijob aj judíosob jini que u tz'onijobba:
\p ―Si anela paq'uin colaquetla t'oc cä t'an, anela chich totoj cajcänt'anetla.
\v 32 A xe a wina'tanla camba u toja, y jini u t'an Dios tojba u xe u pa'senetla tu c'äb a yumla.
\p 
\v 33 Unejob u p'ali:
\p ―U ch'ocob aj Abrahanon t'ocob, mach bay ajnon t'ocob tu c'äb cä yum t'ocob. ¿Cua' uc'a a wäle' ca' jini: “A xe tä pa'sintela tu c'äb a yumla”?
\p 
\v 34 Aj Jesús u yälbijob:
\p ―Totojtoj cälbenetla, upete machcatac u chen u tanä, u tanä chich u chen manda, ca' a wälä u yum.
\v 35 U yajpatan untu winic mach u nonoj col tan yotot u yum; u yajlo' jini winicba u colan une.
\v 36 Jin uc'a si u Yajlo' Dios u pa'senetla tu c'äb a yumla, totoj pa'sintetla chich.
\v 37 Cuwi cache' u ch'ocob aj Abrahanetla, pero a sacän cache' a tzämsenonla uc'a mach uyoch cä t'an ta' c'ajalinla.
\v 38 No'on cäle' cua' acä chäni bajca an cä Pap, anelaba a chenla cua' a ubila t'oc a papla.
\p 
\v 39 Unejob u p'albijob:
\p ―Cä pap t'ocob aj Abraham une.
\p Aj Jesús u yälbijob:
\p ―Si toj ica cache' u ch'ocobetla aj Abraham, ca' chich u chi aj Abraham, che' chich ica a chenla täcä.
\v 40 Pero anelaba a sacänla cache' a tzämsenonla, no'on une ni cälbetla u toja, jin acubi t'oc Diosba. Aj Abraham mach u chi ca' jini.
\v 41 Anela a chenla ca' chich u chen a papla.
\p Jinq'uin unejob u yälbi ca'da:
\p ―Mach jin u ch'ocobon t'ocob ajtz'ijte'ba; tontu cä pap t'ocob, Dios une.
\p 
\v 42 Aj Jesús u yälbijob:
\p ―Si toj ica cache' Dios a paplaba, a yajna'tanonla ica, uc'a no'on bajca an Dios apason, ya' chich aton. Mach uc'a no'on cä pa'si täj c'ajalin ticon. Une u täscon.
\v 43 ¿Cua' uc'a mach a che entendela cua' cäle'? Uc'a mach a wo a ubinla cä t'an.
\v 44 A papla anelaba diablo une; ca' chich yo a pap, che' chich a wo a chenla. Uneba ajtzämsa chäcäl najtäcä, y mach u chi tu toja, uc'a mach t'oc u toja ayan. Jinq'uin u chen jop'ojti', u chen uc'a che' chich nämä u chen, uc'a ajjop'ojti' une; uneba es ca' a wälä u papob ajjop'ojti' uc'a une u yäq'ui ajnic ajjop'ojti'job.
\v 45 No'onba uc'a cäle' tu toja, mach a tz'ombonla.
\v 46 ¿Caxca une de anela u ch'e' u yäle' cache' an cä tanä? Si toj ni cäle'ba, ¿cua' uc'a mach a tz'ombonla?
\v 47 Machca ta Diosba, u t'an Dios u yubin. Jin uc'a anelaba mach a ubila, uc'a mach ta Diosetla.
\s1 Cristo existió antes que Abraham
\p 
\v 48 Jinq'uin u p'albijob aj judíosob u yälbi ca'da:
\p ―¿Mach ca toj cäli t'ocob cache' ane aj samaritanojet, a cänäntan tzuc pixan ta'wac'o?
\p 
\v 49 Aj Jesús u p'ali:
\p ―Mach cä cänänta tzuc pixan täjcac'o. No'onba cäle' cache' utz cua' u chen cä Pap. Pero anelaba mach a wäläla cache' utz cua' cä chen.
\v 50 No'onba mach cä sacä älbinticon cache' utz cua' cä chen. Ya'an machca u yäle', y une chich u xe u yäle' camba u toja.
\v 51 Totojtoj cälbenetla, machca u tz'ombenon cä t'an, mach bay uni' xin u jiran chämo.
\p 
\v 52 De ya'i aj judíosob u yälbijob:
\p ―Bada cuwi chich t'ocob cache' a cänäntan tzuc pixan ta'wac'o. Aj Abraham chämi, ajt'anob ta Dios chämijob täcä, y aneba a wäle' ca'da: “Machca u tz'ombenon cä t'an, mach bay uni' xin u jiran chämo”.
\v 53 ¿Ane quira más ajnojalet que cä papla aj Abraham ni chämiba? Ajt'anob ta Dios chämijob täcä. ¿Aneba jiq'uin, caxcajet a wäle'?
\p 
\v 54 Aj Jesús u p'ali:
\p ―Si no'on cäle' cache' pitzi cua' mu' cä chenba, ni cäle'ba mach u che vale cua' une. Cä Pap une ni u yäle' cache' pitzi cua' mu' cä chenba, jini a wäle'la cache' a Dioslaba.
\v 55 Mach a che conocela. No'onba cä chen conoce. Si fuera cäle' cache' mach cä che conoce, ajjop'ojti'on ica täcä ca' chich anela. No'onba cä chen chich conoce y no'on cä tz'omben u t'an.
\v 56 A papla aj Abraham ch'a'a ujin u pitän ticon pancab. Ch'a'ali chich ujin uc'a u chäni cache' julon.
\p 
\v 57 De ya'i aj judíos u yälbijob:
\p ―Aneba mach to a cänänta cincuenta año, ¿y a wäle' que a chäni aj Abraham?
\p 
\v 58 Aj Jesús u yälbijob:
\p ―Totojtoj cälbenetla, mach to an aj Abraham, no'onba ya' chich anon.
\p 
\v 59 U ch'ijob ji'tun tuba u jule'ob t'oc, pero aj Jesús mucu pasi tan noj ch'u'ul otot, numi tänxin de unejob y bixi.
\c 9
\s1 Jesús sana a un hombre que nació ciego
\p 
\v 1 Bajca u nume aj Jesús u chäni untu ajchoc'. Jini ajchoc' che' chich päncäbi.
\v 2 U yajcänt'anob u c'atbijob ca'da:
\p ―Maestro, ¿caxca une an u tanä tuba päncäbac ni winicda de ajchoc'? ¿Ayan quira u tanä u pap y u na', o ayan u tanä uneba?
\p 
\v 3 Aj Jesús u p'ali:
\p ―Mach uc'a an u tanä ni winicda, mach uc'a an u tanä u pap y u na'. Päncäbi de ajchoc' sec' uc'a chäncac cache' Dios u ch'e' u tz'äcälin.
\v 4 C'änä cä cherben u patan machca u täscon, bada que an to q'uin. U xe tä oche ac'äb jinq'uin niuntu mach u ch'ä u chen patan.
\v 5 Ya'to anon pancab, junch'äcnilon tuba a'ajtäjob pancab.
\p 
\v 6 Jinda u yäli y de ya'i u chi u tub tä cab, u chi pusu t'oc u c'äbti', y u tatz'bi tu jut ajchoc'.
\v 7 U yälbi:
\p ―Cux poco tan ni u yajliba ja' Siloé ―ni t'an Siloéba u yäle' ca'da: Täsquinti une.
\p Bixi u poque'. Jinq'uin sutwäniba, u chen chanä.
\v 8 Jinq'uin u yajnätz'älajob, y machcatac u chäni najtäcä cache' ajchoc' jini winic, u yälijob:
\p ―¿Mach quira jinda ni u chumtä u c'atän u matänba?
\p 
\v 9 U tulaj älijob:
\p ―Une chich.
\p Otrosjob u yäli:
\p ―Jin chich u jut a wälä.
\p Pero uneba u yäli:
\p ―No'on chich.
\p 
\v 10 Unejob u yälben:
\p ―¿Caxca u yäc'bet a chen chanä?
\p 
\v 11 Une u yäli:
\p ―Ni winic u c'aba' aj Jesúsba u chi pusu, u tatz'bon cä jut, u yälbon: “Cux tä Siloé poco”. Ajnon cä poque', y u jäbi uba cä jut.
\p 
\v 12 De ya'i u yälbijob:
\p ―¿Cada an ni winic jini?
\p Une u yäli:
\p ―Mach cuwi.
\s1 Los fariseos interrogan al ciego que fue sanado
\p 
\v 13 U bisijob bajca an aj fariseojob jini winic que ajchoc' ajniba.
\v 14 U q'uin ch'ämbäji jinq'uin aj Jesús u chi jini pusu, y u yäc'bi u chen chanä ni ajchoc'.
\v 15 Aj fariseojob täcä sutwäni u c'atbenob cache'da jäbqui u jut. Une u yälbijob:
\p ―U yäq'ui pusu täc jut, cä poqui, y bada cä chen chanä.
\p 
\v 16 Jinq'uin u tulaj äle'ob aj fariseojob:
\p ―Jinda winic mach ta Dios, uc'a mach u cänänta u q'uin ch'ämbäji.
\p Otrosjob u yäle'ob:
\p ―¿Cache' u ch'e' untu winic ajcherajtanä u chen ca'da?
\p U jec'li ubajob tä t'an.
\v 17 Sutwäni u yälbenob ajchoc' ca'da:
\p ―Aneba, ¿cache' a wäle' t'oc ni machca u jäbbet a jutba?
\p Une u yäli:
\p ―Ajt'an ta Dios acäle'.
\p 
\v 18 Aj judíosob mach u tz'onijob cache' jini winic ajni de ajchoc', y cache' äc'binti u chen chanä, ixta que u joc'bijob u pap y u na' ni machca äc'binti u chen chanäba.
\v 19 U c'atbijob ca'da:
\p ―¿Jinda quira na wajlo', a wäle'la cache' päncäbi ajchoc'ba? ¿Cache'da jiq'uin u chen chanä badaba?
\p 
\v 20 U pap y u na' u yäli:
\p ―Cuwi chich t'ocob cache' jinda ni cajlo' y que päncäbi ajchoc'ba.
\v 21 Bada u chen chanä, mach cuwi t'ocob cache'da, mach cuwi t'ocob caxca u jäbbi u jut. Uneba noxi' winic, u ch'e' a c'atbenla. Une chich u xe u yäle'.
\p 
\v 22 Ca'da u yäli u pap y u na' uc'a bäc'tajob t'oc aj judíosob; uc'a aj judíosob u worin älijob cache' u xe tä pa'sinte tan ch'u'ul otot machca u yäle' cache' aj Jesús ni Mesías, jini u xe u täscun Diosba.
\v 23 Jin uc'a u pap y u na' u yäli ca'da: “Uneba noxi' winic, u ch'e' a c'atbenla”.
\p 
\v 24 U joq'uijob cha'num ni winic ajni de ajchoc'ba, u yälbijob:
\p ―C'ajti'in Dios. Cuwi chich t'ocob cache' ni winic jini ajcherajtanä.
\p 
\v 25 Une u yäli ca'da:
\p ―Mach cuwi si ajcherajtanä. Ni cuwiba, cache' no'on ajchoc' ajnon, bada acä chen chanä.
\p 
\v 26 Sutwänijob u cha'num c'atben:
\p ―¿Cache' u cherbet? ¿Cache'da u jäbbet a jut?
\p 
\v 27 Une u p'ali:
\p ―San cälbetla, y mach a ubila. ¿Cua' uc'a a wo a ubinla tä cha'num? ¿A wola quira täcä xiquet de u yajcänt'an?
\p 
\v 28 Unejob u q'uejpijob, u yälbenob ca'da:
\p ―Aneba u yajcänt'anet. No'on t'ocobba ajcänt'anon t'ocob taj Moisés.
\v 29 Cuwi chich t'ocob cache' Dios u pequi aj Moisés. Jindaba, mach cuwi t'ocob cada ti.
\p 
\v 30 U p'ali jini winic, u yälbijob:
\p ―Mach bay u yubca ca' jini, a wäle'la cache' mach a wila cada ti, y une u jäbbon cä jut.
\v 31 Cuwila cache' Dios mach u yubi u c'änti'ya ajcherajtanäjob. Machca u tz'omben Dios, machca u chen ca' chich yo Diosba, jin une u yubin u c'änti'ya.
\v 32 Mach bay ubqui pancab ajnic machca u jäbben u jut machca päncäbi ajchoc'.
\v 33 Si jini winic mach ajnic ica t'oc Dios, mach u ch'ä u chen ica niump'e cua'.
\p 
\v 34 Unejob u yälbi:
\p ―Ane päncäbet t'oc a noj q'uenel tanä, ¿y a ye'benon t'ocob u t'an Dios?
\p De ya'i u pa'sijob tan noj ch'u'ul otot.
\s1 Ciegos espirituales
\p 
\v 35 Jinq'uin aj Jesús u yubi cache' pa'sinti, bixi u nuc'tan, u yälbi ca'da:
\p ―¿A tz'omben ane u Yajlo' Dios?
\p 
\v 36 Une u p'ali:
\p ―¿Caxcone, noxi' winic, uc'a cä tz'onän?
\p 
\v 37 Aj Jesús u yälbi:
\p ―A chäni chich y une chich mu' u t'an t'oc ane.
\p 
\v 38 Une u yäle':
\p ―Cä tz'onän chich, Cajnoja.
\p Y u ch'u'ul c'ajti'i.
\p 
\v 39 Aj Jesús u yäli:
\p ―No'on aton pancab cäle' catac an tu toja, catac mach'an tu toja, uc'a machcatac mach u che chanäba u chen chanä, y machcatac u chen chanä sutwänic ca' ajchoc'.
\p 
\v 40 Jinq'uin u yubi jinda, aj fariseojob ni ya'an t'ocba u tulaj älijob:
\p ―¿Ajchoc'on quira t'ocob täcä?
\p 
\v 41 Aj Jesús u yälbijob:
\p ―Si fuera ajchoq'uetla icaba, mach ica an a tanäla. Bada uc'a a wäle'la a chen chanäla, jin uc'a ya'to an a tanäla.
\c 10
\s1 El ejemplo del corral
\p 
\v 1 ’Totojtoj cälbenetla, machca mach uyoch tu ti' bojte' tuba oveja ajxuch' une. U yoche bajca mach'an u ti' bojte' tuba u ch'e' ni mach jin tubaba.
\v 2 Machca u yoche tu ti' bojte'ba, ajcänän oveja une.
\v 3 Ajcänän ti' bojte' u jäbben tuba ochic ni ajcänän oveja. Ovejajob u yubin u t'an ni ajcänän oveja. U joq'ue' tu c'aba' u ovejajob tuba u pa'sen.
\v 4 Cuanta u laj pa'si ni tubaba, une u nume pänte', y oveja u bixejob tu pat uc'a u cherben conoce u t'an.
\v 5 Päpä' winicba mach ubixob ni oveja tu pat; u putz'tan une uc'a mach u cherbe conoce u t'an.
\p 
\v 6 Jinda tz'aji aj Jesús u cherbijob. Unejob mach u chi entendejob cua' uc'a u yälbijob ca' jini.
\s1 Jesús, el buen pastor
\p 
\v 7 Aj Jesús u yälbijob tä cha'num:
\p ―Totojtoj cälbenetla: Machcatac u tz'ombenonba ca' a wälä ovejajob une, y no'onba ca' a wälä u ti'on ni bojte' bajca u yoche ni oveja.
\v 8 Upete machcatac juli najtäcä que no'on ajxuch' une, u ch'e' ni mach jin tubaba. Ovejajob mach u yubijob u t'an.
\v 9 No'on u ti'on ni bojte'; machca u yoche t'oc no'on, u xe tä japinte; u yoche, u pase, y u pojlen cua' u c'uxe'.
\p 
\v 10 ’Ajxuch' u te chich tä xuch', tä tzämsa, tuba u tzupsen cua'tac ayan. No'onba aton tuba cä'ben cuxlecob machcatac u tz'ombenon, y c'alin cuxlecob.
\v 11 No'on une ni ajcänän ovejajon utzba; ni ajcänänya utzba u yäq'ue' uba tä chämo uc'a u japän u ovejajob.
\v 12 Jini winic u tojcanba mach jin mero ajcänän oveja. Jinq'uin u chänen que ya' u te ajlobo tu pat oveja, une u yäctan oveja u pase tä putz'e, uc'a mach jin mero u yum oveja. Ajlobo u nume u q'ueche' oveja, y oveja u puclan ubajob.
\v 13 Jini winic u tojcanba u putz'e, uc'a ajgana une, mach u cänänta utz jini oveja.
\p 
\v 14 ’No'on ni ajcänän ovejajon utzba, cä chen conoce cä ovejajob, unejob täcä u chenon conoce.
\v 15 Ca' chich u chenon conoce cä Pap, che' chich täcä no'on cä chen conoce cä Pap. Cäq'ue' cäba tä chämo uc'a cä japän ni ovejajob.
\v 16 Cä cänäntan täcä otro ovejajob que mach'an tama jinda bojte'. Unejob täcä c'änä chich cä täsen. U xe u yubinob cä t'an; u xe tä ajtäjob tomp'e t'oc untu machca u cänäntanob.
\p 
\v 17 ’Jin uc'a u yajna'tanon cä Pap, uc'a no'on acäq'ue' cäba tä chämo tuba sutwänicon tä cuxpan.
\v 18 Niuntu mach u tzämson, no'on chich cäq'ue' cäba tä chämo. An cä poder cäq'ue' cäba tä chämo, an cä poder ta cuxpacon tä cha'num. Jin chich u yäc'bon cä Pap cä chen.
\p 
\v 19 Sutwäni cha'num u jec'lan ubajob aj judíosob uc'a ni t'anda que u yäliba.
\v 20 Q'uen u yäle'ob:
\p ―Tzuc pixan ya'an tuyac'o; ajsinc'ajalin une. ¿Cua' tuba cubinla u t'an?
\p 
\v 21 U tulaj äle'ob:
\p ―Jinda t'an mach u yälä machca u cänäntan tzuc pixan tuyac'o. ¿U ch'e' quira tzuc pixan u jäbben u jut ajchoc'?
\s1 Los judíos rechazan a Jesús
\p 
\v 22 Jinq'uin ajni q'uin ch'uje tä Jerusalén tuba c'ajti'cac cache' ch'u'ul cherqui noj ch'u'ul otot, tu q'uini sisi une.
\v 23 Jinq'uinba, aj Jesús u nume tan noj ch'u'ul otot tä corredor taj Salomón.
\v 24 Aj judíosob u woyi ubajob bajca an, u yälbijob ca'da:
\p ―¿Ca jun q'uin a wäctan a jobän cä c'ajalin t'ocob? Si ane aj Cristojet, älbenon t'ocob tu toja.
\p 
\v 25 Aj Jesús u yälbijob:
\p ―Acälbetla chich, pero anela mach a tz'onäla. Ni patan cä chenba cä Pap u yäc'bon cä chen une, y jinda u ye'e' tu toja machcajon.
\v 26 Anela mach a tz'onäla uc'a mach jin cä ovejajetla, ca' chich cälbetlaba.
\v 27 Cä ovejajob u yubinob cä t'an, no'on cä chen conocejob täcä, y unejob u bixejob täc pat.
\v 28 No'on cä'ben paq'uin cuxlecob; mach uni' xin tä sätojob, y niuntu mach uxin u pa'senob täj c'äb täcä.
\v 29 Cä Pap ni u yäc'bonba, une más ajnoja que upete; niuntu mach u ch'ä u pa'senob tu c'äb cä Pap.
\v 30 No'on t'oc cä Pap tontulon t'ocob.
\p 
\v 31 De ya'i u ch'ijob cha'num ji'tun aj judíosob tuba u jule'ob t'oc.
\v 32 Aj Jesús u yälbijob:
\p ―Q'uen cä patan utzba acä ye'betla, u patan cä Pap une. ¿Caxcamba de ni patanda utzba que cä chi, y jin uc'a a wo a jule'onla t'oc ji'tun?
\p 
\v 33 Aj judíosob u p'ali:
\p ―Mach uc'a a patan utz acä jule'et t'ocob t'oc ji'tun, sec' uc'a a tzuc t'an. Ane winiquet, y a chen aba cache' Dioset.
\p 
\v 34 Aj Jesús u p'albijob:
\p ―¿Mach quira a wila cache' ya' tz'ibi tama ni ley ta'ala ca'da: “Cäli cache' diosetla”?
\v 35 U yälbijob cache' diosob machcatac binti u t'an Dios, y ni tz'ibiba mach u ch'ä älcac cache' mach toj.
\v 36 Cä Pap u yäc'bon ch'u'ul ajnicon u täscon pancab. ¿A wäle'la quira cache' tzuc t'an cä chen uc'a no'on cäli cache' u Yajlo' Dioson?
\v 37 Si mach jin u patan cä Pap cä chenba, mach a tz'ombenonla.
\v 38 Si u patan cä Pap cä chenba, y no'on mach a tz'ombonla, tz'onänla jini patan, uc'a a wina'tanla y a tz'onänla cache' cä Pap ya'an t'oc no'on, y no'on t'oc cä Pap.
\p 
\v 39 U sacänob tä cha'num cache' u q'ueche', pero une pasi bajca anob.
\p 
\v 40 Bixi tä cha'num tunxe río Jordán bajca u chi c'ablesia aj Juan najtäcä; ya' coli ya'i.
\v 41 Q'uen c'otijob bajca an, u yäle'ob:
\p ―Aj Juan niump'e cua' mach u chi tuba u ye'e' u poder, pero upete cua' u yäli aj Juan de jini winicdaba, toj une.
\p 
\v 42 Q'uen machcatac u tz'ombijob ya'i.
\c 11
\s1 Muerte de Lázaro
\p 
\v 1 Ajni untu winic c'ojo, u c'aba' aj Lázaro. Tä Betania u cäji. Ya'an t'oc u cha'tuma u chich, ix María y ix Marta.
\v 2 Ni ix Maríada c'ojo jitz'inba, jin une u tatz'i Ajnoja t'oc jätz'äcnib, y u sucbi yoc t'oc u tzuc.
\v 3 Ni u chichob aj Lázaroba u täsqui tä älbintejob aj Jesús:
\p ―Cajnoja, ubixto, jini a yajna'tanba c'ojo ayan une.
\p 
\v 4 Jinq'uin u yubi aj Jesús, u yäli ca'da:
\p ―Jinda yaj mach tuba u tzämsen; ni yajdaba tuba chäncac u pitzil patan Dios, y uc'a chänintic täcä cua' u xe u chen u Yajlo' Dios.
\p 
\v 5 Aj Jesús u yajna'tan ix Marta, y u jitz'in ix María, y aj Lázaro.
\v 6 Jinq'uin u yubi cache' c'ojo, coli to chap'e q'uin bajca ayan.
\v 7 Ji'pat u yälbi u yajcänt'anob:
\p ―Cola tä Judea tä cha'num.
\p 
\v 8 U yajcänt'anob u yälbi:
\p ―Maestro, mach to nat' q'uin aj judíosob u yäli u tzämsenetob t'oc ji'tun, ¿y a xe cha'num ya'i?
\p 
\v 9 Aj Jesús u p'ali:
\p ―¿Mach quira u cänänta doce hora ni q'uin? Machca u nume tä q'uin, mach u päcteq'ue cua', uc'a u chänen ni junch'äcni tuba jinda u pancab.
\v 10 Machca u nume ac'äb u päcyälo uc'a mach'an junch'äcni bajca an une.
\p 
\v 11 Cuanta u yäli ca'da, u yälbijob tä cha'num:
\p ―Cä lotla aj Lázaro mu' u wäye; acä xe cä p'isan bajca an tä wäye.
\p 
\v 12 De ya'i u yajcänt'anob u yälbi:
\p ―Cajnoja, si wäye u chen u xe u pojlen uba.
\p 
\v 13 Ni u yäli aj Jesúsba, cache' achämi chich; unejobba u yäli tan u c'ajalin cache' ni u yäliba mu' u totoj ch'e' uba tä wäye.
\v 14 De ya'i aj Jesús u chectesbijob:
\p ―Aj Lázaro achämi une.
\v 15 Ch'a'a cäjin mach anon ya'i achämi, uc'a ca' jini ajnic cache' a tz'onänla más. Bada cola bajca an.
\p 
\v 16 Jinq'uin aj Tomás, jini u yälbinte ajwacu'ba, u yälbi u lotob:
\p ―Cola täcä uc'a chämiconla nämte' t'oc une.
\s1 Jesús es la resurrección y la vida
\p 
\v 17 Jinq'uin c'oti aj Jesús, u yubi cache' u cänäntan chämp'e q'uin u mujcan aj Lázaro.
\v 18 Betania nätz'ä t'oc Jerusalén, ca' tuba uxp'e kilómetros u nät'an.
\v 19 Q'uen aj judíosob c'otijob bajca an ix Marta y ix María u ch'a'alesbenob ujin uc'a chämi jitz'in.
\v 20 Jinq'uin ix Marta u yubi cache' ya' u te aj Jesús, pasi u nuc'tan. Ix Maríaba coli tä chumtä tan otot.
\v 21 Ix Marta u yälbi aj Jesús:
\p ―Cajnoja, si ajniquet ica wida, mach ica chämi quitz'in.
\v 22 Cuwi chich täcä bada upete cua' a c'atben Dios, Dios chich u yäc'benet.
\p 
\v 23 Aj Jesús u yälbi:
\p ―U xe tä cuxpan a witz'in.
\p 
\v 24 Ix Marta u yälbi:
\p ―Cuwi chich cache' u xe tä cuxpan tu cuxpan upete tu xupiba q'uin.
\p 
\v 25 Aj Jesús u yälbi:
\p ―No'on ni ajcuxpesialon, no'on cäq'ue' cuxlec untu. Machca u tz'ombenon, si chämic u sujtä tä cuxpan.
\v 26 Upete machca cuxu y u tz'ombenon mach bay uxin tä chämo. ¿A tz'onän jinda?
\p 
\v 27 Une u yälbi:
\p ―Cajnoja, acä tz'onän chich cache' ane aj Cristojet, u Yajlo' Dioset atet pancab.
\s1 Jesús llora junto al sepulcro de Lázaro
\p 
\v 28 Jinq'uin u yäli jinda, bixi u joq'ue' mucu jitz'in ix María u yälben:
\p ―Cä Maestrola ya'anda, u joq'ue'et.
\p 
\v 29 Jinq'uin u yubi ix María, seb ch'oyi bixi bajca an aj Jesús.
\v 30 Aj Jesús mach to yoch tan caj, ya'to an bajca u nuc'ti ix Marta.
\v 31 Ni aj judíosob ya'an tan otot t'oc uneba u ch'a'alesbenob ujinba, jinq'uin u chäni cache' seb ch'oyi ix María bixi, bixijob tu pat uc'a u yäle'ob cache' ya' u xe bajca mujqui u yuc'tan ya'i.
\p 
\v 32 Jinq'uin ix María c'oti bajca an aj Jesús, nocwäni tu yoc, u yälbi:
\p ―Cajnoja, si ajniquet ica wida, mach ica chämi quitz'in.
\p 
\v 33 Jinq'uin aj Jesús u chäni cache' mu' u yuq'ue, y aj judíosob c'oti t'oc täcäba tä uq'uejob täcä, ch'ocomi u pixan, y triste'i.
\v 34 U c'ati:
\p ―¿Cada a wäq'uila?
\p Unejob u yälben:
\p ―Cajnoja, la'ix chänen.
\p 
\v 35 Jinq'uin u chäni aj Jesús, u chi uq'ue.
\v 36 De ya'i aj judíosob u yälijob:
\p ―Chänen cache' tä' u yajna'tan.
\p 
\v 37 U tulaj älijob:
\p ―Ni winicda u jäbbi u jut ajchoc'ba, ¿mach wäreca u ch'ä u yäq'ue' que mach chämic aj Lázaro?
\s1 Resurrección de Lázaro
\p 
\v 38 Aj Jesús ch'ocomi u pixan tä cha'num, c'oti bajca mucu aj Lázaro. Bajca mucuba, ump'e ch'en une tu näc' tz'ic t'oc ump'e ji'tun tu ti'.
\v 39 Aj Jesús u yäli:
\p ―Pa'senla ni ji'tun.
\p Ix Marta, u chich najchämeba, u yälben:
\p ―Cajnoja, u chi uba yutz'u, u cänäntan chämp'e q'uin u chämo.
\p 
\v 40 Aj Jesús u yälbi:
\p ―¿Mach quira cälbet, si a tz'onän a xe a chänen u poder Dios?
\p 
\v 41 De ya'i u pa'sijob ni ji'tun bajca äc'qui ajchäme. Aj Jesús u t'äbsi u jut isqui y u yäli:
\p ―Cä Pap, cälbenet uc'adios uc'a a ubi cä t'an.
\v 42 Cuwi chich cache' a paq'uin ubin cä t'an; pero uc'a ni noj q'uenel gente ya'andaba, jin uc'a cäli ca' jini, tuba u tz'onänob cache' ane a täscon.
\p 
\v 43 Cuanta u yäli jinda, u yäli t'oc noj t'an:
\p ―¡Lázaro, pasen ya'i bajca anet!
\p 
\v 44 Machca ajni chämenba pasi, tz'otojtac u c'äb, yoc, t'oc noc'; t'unu u jut t'oc ump'e noc'. Aj Jesús u yälbijob:
\p ―P'ämbenla, äctan bixic.
\s1 Conspiración para prender a Jesús
\r (Mt. 26.1‑5; Mr. 14.1‑2; Lc. 22.1‑2)
\p 
\v 45 Jinq'uin q'uen aj judíosob ni ajnijob bajca an ix Maríaba u chänijob cua' u chi aj Jesús, u tz'ombijob.
\v 46 Tulaj bixijob bajca an aj fariseojob tuba u yälbenob cua' u chi aj Jesús.
\v 47 Ajnojajob ta palejob y aj fariseojob u woyi ubajob tomp'e t'oc ajt'äbäla a'äc'c'ajalinob. U yälijob ca'da:
\p ―¿Cache' cä xe cä chenla? Uc'a jinda winic q'uen cua' u chen tuba u ye'e' u poder.
\v 48 Si cäctanla ca'da, upete u xe u tz'omben. U xe tä te aj romanojob u jajbenonla cä ch'u'ul ototla y cä cäjila.
\p 
\v 49 Aj Caifás, untu no' ajnoja pale tuba jini año, u yälbijob ca'da:
\p ―Mach a wila cua'.
\v 50 Mach uta ta' c'ajalinla cache' c'änä chämic untu winic uc'a caj, y mach sätic upete.
\p 
\v 51 Jinda u yäli mach uc'a une u pa'si tu c'ajalin. Uneba no' ajnoja pale tuba jini año, jin uc'a Dios u worin äc'bi u yäle' cache' aj Jesús u xe tä chämo uc'a caj.
\v 52 Y mach sec' uc'a jini caj u xe tä chämo, uc'a täcä woycac tomp'e u ch'ocob Dios bajcatac ayanob.
\v 53 De ya'i jinchichba q'uin u täq'ui u maläc ch'e' u c'ajalinob cache' u xe u tzämsenob.
\p 
\v 54 Jin uc'a aj Jesús mach uni' num tu jut aj judíosob. Pasi ya'i bixi bajca an jini cab nätz'ä bajca mach cuxu niuntu, bajca an jini caj u c'aba' Efraín. Ya'i coli t'oc u yajcänt'anob.
\p 
\v 55 Anatz'äli noj paxcu' taj judíosob. Q'uen pasijob tä cabil cab bixijob tä Jerusalén antes de tä'cac jini q'uin ch'uje ta paxcu', uc'a c'änä u chenob jini u yäle' noxibilba uticba tuba ajnicob tu toja.
\v 56 Cayi u sacänob aj Jesús. U maläc äle'ob machcatac ya'an tan noj ch'u'ul otot:
\p ―¿Cache' a wäle'la, mach wäreca uta wida tä q'uin ch'uje?
\p 
\v 57 Ajnojajob ta palejob y aj fariseojob u yälijob si machca chichca yuwi caxcada ayan, u yäle', uc'a xic tä q'uechcan.
\c 12
\s1 Una mujer unge a Jesús
\r (Mt. 26.6‑13; Mr. 14.3‑9)
\p 
\v 1 Yo to seis día tuba c'otic u q'uini paxcu', c'oti aj Jesús tä Betania. Ya' jini u cäji aj Lázaro ni chämiba, jini que cuxpi tan ajchämeba.
\v 2 Ya'i cherbinti cua' u c'uxe'. Ix Marta u tuse' ni cua' tä c'uxcan. Aj Lázaro täcä chunwäni nämte' t'oc aj Jesús tä mesa.
\v 3 De ya'i ix María u ch'i unxot' botella de jätz'äcnib u c'aba' nardo, tä' choj u valor. U numsäbi tu yoc aj Jesús, u sucbi yoc t'oc u tzuc. De ya'i u laj puqui uba u yutz'u ni jätz'äcnib tan otot.
\v 4 Aj Judas, u yajlo' aj Simón Iscariote, untu u yajcänt'an aj Jesús, jini u xe u yäq'ue' tä c'äbäba, u yäli ca'da:
\p 
\v 5 ―¿Cua' uc'a mach achonqui jini jätz'äcnib por tres cientos taq'uin tuba pucbintic pobrejilba ni taq'uin?
\p 
\v 6 Ni u yäliba, mach uc'a u ch'ämben yajin pobrejilba, u yäli uc'a ajxuch' une; une u cänäntan ni ch'uji' taq'uin, y u xuch'än jini taq'uin que u yä'can tamaba.
\v 7 Aj Jesús u yäli:
\p ―Mach a jaq'uesben ujin ni ixic. Uneba u worin chi ni jini tuba jinq'uin cä xe tä mujcan.
\v 8 Pobrejilba ya' chich paq'uin an t'oc anela, pero no'onba mach paq'uin anon t'oc anela.
\s1 Conspiración contra Lázaro
\p 
\v 9 Q'uen aj judíosob u yubi cache' ya'an ya'i; c'otijob mach sec' uc'a u chänenob aj Jesús, uc'a täcä u chänenob aj Lázaro, jini u cuxpesi tan ajchämejobba.
\v 10 Ajnoja palejob u ch'ijob u c'ajalin tuba u tzämsenob täcä aj Lázaro,
\v 11 uc'a q'uen aj judíosob u tz'eji ubajob t'oc u lot tuba u tz'omben aj Jesús, uc'a cuxpi aj Lázaro.
\s1 Jesús entra en Jerusalén
\r (Mt. 21.1‑11; Mr. 11.1‑11; Lc. 19.28‑40)
\p 
\v 12 Päscab ni noj q'uenel gente que c'otijob tä q'uin ch'ujeba, jinq'uin u yubijob cache' aj Jesús ya' u te tä Jerusalén,
\v 13 u ch'ijob c'äb xan, bixijob u nuc'tan. T'oc noj t'an u yäle'ob:
\p ―¡Hosanna! ¡Ch'u'ul c'ajti'cac jini u te tu c'aba' Cajnojala Dios, jini Ajnoja taj Israelobba!
\p 
\v 14 Aj Jesús u pojli untu yoc p'i' tzimim. U chumti, uc'a che' chich u yäle' ni jun ta Dios tz'ibiba:
\q1 
\v 15 Mach bäc'taquetla, anela tä Sión;
\q1 chänen, a Wajnojala u te
\q1 chumu tu pat untu p'i' tzimim.
\p 
\v 16 Jinda mach u se'in chi entendejob u yajcänt'anob. Jinq'uin cuxpi aj Jesús, jinq'uinba ti tu c'ajalinob cache' jinda ya' chich tz'ibi tan u jun Dios que u xe tä cherbinte.
\p 
\v 17 Jini gente que ajni jinq'uin jo'qui aj Lázaro bajca ajni tan ch'en y cuxpesqui tan ajchämejobba, unejob u yälijob tu toja cache' u chi aj Jesús.
\v 18 Jin uc'a noj q'uenel gente bixi u nuc'tan, uc'a u yubijob cache' u chi jinda tuba u ye'e' u poder.
\v 19 Aj fariseojob u maläc älijob:
\p ―¿A chänila cache' mach a chela cua'? Iranba, upete u bixejob tu pat.
\s1 Unos griegos buscan a Jesús
\p 
\v 20 Tulaj c'otijob täcä aj griego tuba u ch'u'ul c'ajti'in Dios tama jini q'uin ch'uje.
\v 21 Jinijob c'oti bajca an aj Felipe, jini aj Felipe u cab tä Betsaida tama noj cab tä Galileaba. U c'atänob:
\p ―Noxi' winic, tä' co cä chänen t'ocob aj Jesús.
\p 
\v 22 Bixi aj Felipe u yälben aj Andrés. Aj Andrés t'oc aj Felipe u yälbenob aj Jesús.
\v 23 Aj Jesús u yälbijob:
\p ―Ac'oti q'uin ta ch'u'ul c'ajti'cacon, no'on que sutwänon de winic.
\v 24 Totojtoj cälbenetla, si unxim trigo mach pä'cac tä cab tuba la'mac u bec'ta, u colan u juntuma. Si la'macba y wetic jini u cha', u yäq'ue' q'uen u jut.
\v 25 Machca tä' yoba cuxlec utz pancab u xe tä säto. Machca mach u yajna'ta cuxlec tuyac'o jinda u pancabba, u xe tä ajtä paq'uin cuxu.
\v 26 Machca yo xic tuba cajpatan, tic täc pat. Bajca cä xe tä ajtä, ya' chich u xe tä ajtä cajpatan täcä. Cä Papla Dios u xe u yäle' cache' utz cua' u chen jini cajpatan.
\s1 Jesús anuncia su muerte
\p 
\v 27 ’Bada u ch'ocoman cä pixan. ¿Cache' cä xe cäle'? ¿Cä xe quira cälben cä Pap ca'da: “Cä Pap, japänon t'oc jini u te täjcac'o jimba horada”? Mach uxon cälben ca' jini, uc'a jin chich tuba aton jimba horada.
\v 28 Cä Pap, äc'ä tä ch'u'ul c'ajti'can a c'aba'.
\p De ya'i ubqui ump'e t'an tä cielo, u yäle' ca'da:
\p ―No'on chich acäq'ui tä ch'u'ul c'ajti'can cä c'aba', y acä xe cäq'ue' tä ch'u'ul c'ajti'can tä cha'num.
\p 
\v 29 Ni noj q'uenel gente que u yubijobba u yälijob cache' chawäc. Otrosjob u tulaj älijob cache' ángelo ta Dios u pequi.
\p 
\v 30 Aj Jesús u yäli:
\p ―A'uti ni t'an jini tuba a ubinla ane, mach uc'a c'änä cubin no'onba.
\v 31 Bada u xe tä chectan jini u chenob a'ajtä pancab que mach utzba, bada ni ajnoja tuba jinda u pancab u xe tä pa'sinte.
\v 32 Si no'on äc'cacon tä cruz q'uen u xe u tz'ombenonjob.
\p 
\v 33 Jinda u yäli uc'a u yäle' cache'da u xe tä chämo.
\v 34 U p'albijob ni gente:
\p ―Acubi t'ocob cache' u yäle' ni ley cache' aj Cristo paq'uin ayan. ¿Cuaxca uc'a a wäle' aneba cache' jini sujli de winicba c'änä äc'cac tä cruz? ¿Caxcone jini sujli de winicba?
\p 
\v 35 Aj Jesús u yälbijob:
\p ―Acoli tz'ita' q'uin tuba ajnicon t'oc anela de junch'äcni. Numenla t'oc no'on ni junch'äcnilon ya'toca anon t'oc anela, uc'a mach u q'ueche'etla it'obni. Uc'a machca u nume tan it'obni mach yuwi cada u xe.
\v 36 Ya'toca anon t'oc anela de junch'äcni, tz'ombenonla uc'a ajniquetla de cä ch'ocob.
\p Jintacda u yäli aj Jesús, pasi bajca anob, u muquí uba.
\s1 Por qué los judíos no creían en Jesús
\p 
\v 37 Q'uen cua'tac u chi tu jutob tuba u ye'e' u poder. Unejob mach u tz'onijob.
\v 38 Ca' jini pasi toj ca' chich u worin äli aj Isaías, ajt'an ta Diosba:
\q1 Cajnoja, niuntu mach u tz'oni cä t'anla.
\q1 Mach uta tu c'ajalinob cache' an a poder.
\m 
\v 39 Jin uc'a mach u ch'ä u tz'onänob, uc'a aj Isaías chich u yäli täcä ca'da:
\q1 
\v 40 Dios u mäcbi u jutob, u tzätz'esbi u pixanob
\q1 uc'a mach u chen chanä t'oc u jutob
\q1 y uc'a mach u sapän tu pixanob
\q1 y uc'a mach u q'uexe' u c'ajalinob tuba japintic.
\m 
\v 41 Jinda u yäli aj Isaías jinq'uin u chämbi u pitzilan Cajnojala y u yäli cache' an une.
\p 
\v 42 Pero q'uen ajnojajob chich u tz'ombijob aj Jesús. Mach yo u yäle'ob uc'a bäc'ta t'oc aj fariseojob, uc'a mach xic tä pa'sintejob tan ch'u'ul otot.
\v 43 Uc'a más u yoli que u lotob u yäle' cache' tä' pitzi cua' u chenob, y mach u che t'oc unejob si Dios u yäle' cache' pitzi cua' u chenob.
\s1 Las palabras de Jesús juzgarán a la gente
\p 
\v 44 Aj Jesús u chi noj t'an u yäli:
\p ―Machca u tz'ombenon, mach sec' no'on u tz'ombenon, u tz'omben täcä machca u täscon.
\v 45 Machca u chänenon, u chänen machca u täscon.
\v 46 Tuba ajnicon de junch'äcni, jin uc'a aton pancab, uc'a upete machcatac u tz'ombenon mach colac tan it'obni.
\v 47 Machca u yubin cä t'an y mach u tz'onä, no'onba mach cä'be u toje' u tanä, uc'a mach aton cä'ben u toje' u tanä a'ajtäjob pancab, aton cä japän a'ajtäjob pancab.
\v 48 Machca u quitz'e' uba t'oc no'on y mach u sapä cä t'an, ya'an machca u yäc'ben u toje' u tanä. Ni t'an cäliba, jinda u xe u yäc'ben u toje' u tanä tu xupiba q'uin.
\v 49 Ni t'anda cäliba mach no'on cä pa'si täj c'ajalin. Cä Pap ni u täsconba, une u yäc'bon cua' cäle' y cache'da cä xe cäle'.
\v 50 Cuwi chich cache' u t'an uneba u yäq'ue' paq'uin cuxlequetla. Jin uc'a jini t'an acäle'ba, ca' chich u yälbon cä Pap, che' chich acäle'.
\c 13
\s1 Jesús lava los pies de sus discípulos
\p 
\v 1 Mach to c'ot q'uin ch'uje ta paxcu', aj Jesús yuwi chich cache' ac'oti q'uin pasic une pancab, bixic ca'an u Pap; u yajna'ti ni tubajobba ni ya'anob pancabba, y mäx u yajna'tan ixta tu xupiba q'uin.
\p 
\v 2 Jinq'uin ya'anob tä c'uxnan, ni diabloba san chich u yäc'bi u c'ajalin aj Judas u yajlo' aj Simón Iscariote tuba u yäq'ue' tä c'äbä aj Jesús.
\v 3 Aj Jesús yuwi cache' u Pap u yäc'bi upete tu c'äb y yuwi täcä cache' une pasi ca'an Dios, y ya' chich u sujtä ca'an Dios.
\v 4 Ch'oyi bajca an tä c'uxnan, u pochi u buc, u ch'i ump'e noc' u cächi tu näc'.
\v 5 De ya'i u yäq'ui ja' tama ump'e c'ämbita, u täq'ui u pocben yoc u yajcänt'anob u sucbenob t'oc ni noc' ya' cächä tu näc'ba.
\p 
\v 6 C'oti bajca an aj Simón Pedro. Aj Simón Pedro u yälben ca'da:
\p ―Cajnoja, ¿ane quira a pocbenon coc?
\p 
\v 7 Aj Jesús u yälbi:
\p ―Jini cä chen no'onba, mach a wi une bada. Ji'pat to a xe a wina'tan.
\p 
\v 8 Aj Pedro u yälbi:
\p ―No'on mach bay uxet a pocbenon coc.
\p Aj Jesús u p'ali:
\p ―Si mach a wäcta cä pocbenet a woc, mach anet t'oc no'on.
\p 
\v 9 Aj Simón Pedro u yälbi:
\p ―Cajnoja, mach seq'uen coc, cä c'äb y cä pam täcä co a pocbenon.
\p 
\v 10 Aj Jesús u yälbi:
\p ―Machca múqui, mach ni' c'änä muquic, sec' u poque' yoc, poco an entero untu. Anelaba poco anetla, pero mach apetela.
\p 
\v 11 Uc'a une yuwi caxcone u xe u yäq'ue' tä c'äbä. Jin uc'a u yäli: “Mach poco anetla apetela”.
\p 
\v 12 Cuanta u pocbijob yoc, u xoji u buc, chunwäni tä cha'num tä mesa, u yälbijob:
\p ―¿A wila cua' acä cherbetla?
\v 13 Anela a wälbenonla cache' Maestrojon y Ajnojalon. Utz chich cua' a wäle'la, uc'a jinon chich.
\v 14 Si no'on a Maestrojon y a Wajnojalon acä pocbet a wocla, che' chich c'änä a chenla täcä, a maläc poque' a wocla.
\v 15 Jin uc'a cä ye'betla ca' jini, uc'a ca' chich acä cherbetla, che' chich a chenla täcä.
\v 16 Totojtoj cälbenetla, ajpatan mach jin más ajnoja que u yum; ajtäsquinte mach jin más ajnoja que machca u täsqui.
\v 17 Ya'an ch'a'aljin ta'ala si a wila jinda y si a chenla.
\p 
\v 18 ’Mach cälä jinda tuba apetela. No'on cuwi machcatac acä yaqui. C'änä pasic toj ca' chich tz'ibi tä jun ni u yäle' ca'daba: “Machca u mul c'uxe' waj t'oc no'on ca' a wälä u t'äbsi u tun'oc u juli täjcac'o”.
\v 19 Bada cä worin älbenetla cua' u xe u chen pasa, uc'a jinq'uin u xe u chen pasa, a tz'onänla cache' no'on chich ni aj Cristojon.
\v 20 Totojtoj cälbenetla, machca u sapän ni cä täscunba, no'on une ni u sapänon, y machca no'on u sapänon u sapän täcä machca u täscon.
\s1 Jesús anuncia que Judas lo traicionará
\r (Mt. 26.20‑25; Mr. 14.17‑21; Lc. 22.21‑23)
\p 
\v 21 Jinq'uin aj Jesús u yäli ca'da, ch'ocomi u pixan, u yäli:
\p ―Totojtoj cälbenetla, untu de anelaba a xe a wäq'ue'on tä c'äbä.
\p 
\v 22 De ya'i u yajcänt'anob u maläc chänen u jutob, uc'a mach yuwijob caxcone u yälbinte.
\v 23 Untu u yajcänt'an aj Jesús ni tä' u yajna'tanba ya' t'ele an tu ch'ejpa aj Jesús.
\v 24 Aj Simón Pedro u cherbi u c'äb najcänt'an ya'an tu ch'ejpa aj Jesúsba tuba u c'atben aj Jesús caxca une ni mu' u yälben.
\v 25 Jinq'uin ni ya' t'ele tu ch'ejpaba u c'atbi ca'da:
\p ―Cajnoja, ¿caxca une?
\p 
\v 26 Aj Jesús u p'ali:
\p ―Jin une, machca cä xe cä'ben maja' waj.
\p De ya'i u maji waj, u yäc'bi aj Judas ajlo' taj Simón Iscariote.
\v 27 Cuanta u c'uxi jini waj, ochi aj Satanás tuyac'o. Jinq'uin aj Jesús u yälbi:
\p ―Ni a xe a chenba, seb a nonoj chen.
\p 
\v 28 Niuntu ni ya'an tä mesaba mach yuwijob cua' uc'a u yälbi ca' jini.
\v 29 U tulaj äli tu c'ajalinob cache' aj Jesús u yälbi que u mäne' cuaxca c'änä ta q'uin ch'uje o u yäc'ben cua' chichca pobrejilba, uc'a une u cänäntan ni ch'uji' taq'uin.
\v 30 Cuanta u c'uxi jini waj, seb bixi; ac'äb une.
\s1 El nuevo mandamiento
\p 
\v 31 Jinq'uin bixiba, aj Jesús u yäli:
\p ―Bada u xe tä chäninte cä poder, no'on que sutwänon de winic, y u xe tä chäninte u poder Dios täjcac'o.
\v 32 Si u chäninte u poder Dios täjcac'oba, Dios chich täcä u xe u yäq'ue' tä chäninte jini poder que cä cänäntanba, y seb u xe u yäq'ue' tä chäninte jini poder.
\v 33 Cä bij ch'oc, acolobi tz'ita' q'uin tuba ajnicon t'oc anela. A xe a sacänonla. Ca' chich cälbi aj judíosob: Bajca cä xe no'onba, anela mach u ch'ä xiquetla. Che' chich acälbenetla täcä bada.
\v 34 Ump'e tzib manda acä'benetla, a maläc yajna'tan abala, ca' chich acä yajna'tetla, che' chich anela täcä a maläc yajna'tan abala.
\v 35 Ca' jini u xe u wina'tan upete cache' cajcänt'anetla, si a maläc yajna'tan abala.
\s1 Jesús anuncia que Pedro le negará
\r (Mt. 26.31‑35; Mr. 14.27‑31; Lc. 22.31‑34)
\p 
\v 36 Aj Simón Pedro u yälbi:
\p ―Cajnoja, ¿cada a xe?
\p Aj Jesús u p'albi:
\p ―Bajca cä xe no'on, mach u ch'ä xiquet bada täc pat; ji'pat to a xe a tzäypätinon.
\p 
\v 37 Aj Simón Pedro u yälbi:
\p ―Cajnoja, ¿cuaxca uc'a mach u ch'ä cä tzäypätinet bada? Ixta cäq'ue' cäba tä chämo uc'a ane.
\p 
\v 38 Aj Jesús u p'albi:
\p ―¿A wäq'ue' aba tä chämo uc'a no'on? Totojtoj cälbenet, mach to u che uq'ue ajtze, a xe a wäle' uxpetz' cache' no'on mach a chon conoce.
\c 14
\s1 Jesús, el camino al Padre
\p 
\v 1 ’Mach ch'ocomac a pixanla. Tz'ombenla Dios, y tz'ombenonla täcä.
\v 2 Tan yotot cä Pap q'uen cuxliba ayan. Si mach ica ajnic, mach ica cälbetla. Acä xe cä tuse' bajca a xe tä ajtäla.
\v 3 Si bixicon cä tuse' bajca a xe tä ajtäla, no'on chich acä sujtä tä cha'num cä ch'e'etla, uc'a ajniquetla täcä bajca anon.
\v 4 A wila chich cada cä xe, a wila chich bij.
\p 
\v 5 Aj Tomás u yälbi:
\p ―Cajnoja, mach cuwi t'ocob cada a xe. ¿Cache' cä xe cuwina'tan t'ocob ni bij?
\p 
\v 6 Aj Jesús u yälbi:
\p ―No'on ni bijon, no'on u tojalon, no'on une cäq'ue' cuxlequetla. Niuntu mach uta ca'an cä Pap si mach uc'a no'on.
\v 7 Si no'on ica a chon conocela, a chi conocela ica täcä cä Pap. Pero bada a chen chich conocela y a chänila chich.
\p 
\v 8 Aj Felipe u yälbi:
\p ―Cajnoja, ye'benon t'ocob ni cä Papla, y an t'oc.
\p 
\v 9 Aj Jesús u yälbi:
\p ―Abon jäläcnon t'oc anela, ¿y mach quira a chon conoce, Felipe? Machca no'on u chänon, cä Pap täcä u chäni. ¿Cua' uc'a a wäle' aneba: “Ye'benon t'ocob cä Papla”?
\v 10 ¿Mach quira a tz'onä cache' no'on anon t'oc cä Pap, y cä Pap t'oc no'on? Jini t'an ni cälbenetlaba, mach no'on acä pa'si täj c'ajalin. Cä Pap ya'an t'oc no'onba, une u chen upete cua' chichca.
\v 11 Tz'ombenon cache' no'on anon t'oc cä Pap, y cä Pap t'oc no'on. Tz'ombenon uc'a täcä ni cua' chichca cä chenba.
\v 12 Totojtoj acälbenetla, machca no'on u tz'ombenon, jini cua' chichca que cä chenba, une täcä u xe u chen; más pitzi cua' u xe u chen une uc'a no'onba cä xe ca'an cä Pap.
\v 13 Upete cua'tac a c'atbenla cä Pap täj c'aba', jin chich acä xe cä chen, tuba ch'u'ul c'ajti'cac cä Pap uc'a no'on.
\v 14 Cuaxca a c'atän täj c'aba', no'on chich cä xe cä chen.
\s1 Jesús promete enviar el Espíritu Santo
\p 
\v 15 ’Si a yajna'tanon, tz'ombenon cä t'an.
\v 16 Cä xe cä c'atben cä Pap que une u yäc'benetla otro untu Ajlotaya uc'a paq'uin ajnic t'oc anela. Jin une ni Ch'u'ul Pixan que u ye'e' ni u tojaba.
\v 17 Machcatac cuxujob pancab mach u ch'ä u sapän, uc'a mach u chänejob, y mach u che conocejob täcä. Anelaba a chenla conoce, uc'a ya'an t'oc anela, y u xe tä ajtä ta'wac'ola.
\v 18 Mach uxon cäctanetla ca' neba' ch'oc. Acä te chich bajca anetla.
\v 19 Acolobi tz'ita' q'uin a'ajtäjob pancab mach uni' sutwan u chänenon; anelaba a xe a chänenonla. Uc'a no'on cuxulon, anela täcä a xela tä ajtä cuxu.
\v 20 Jinq'uinba a xe a wina'tanla cache' no'on anon t'oc cä Pap, anela t'oc no'on, no'on t'oc anela.
\v 21 Machca u sapi cä t'an y u tz'onän, jin une ni u yajna'tanon; machca u yajna'tanon, cä Pap u xe u yajna'tan täcä, y no'on cä xe cä yajna'tan, y cä xe cä ye'e' cä poder bajca an.
\p 
\v 22 Aj Judas, ni mach jin aj Iscarioteba, u yälben:
\p ―Cajnoja, ¿can uc'a a xe a ye'e' a poder bajca anon t'ocob, y mach bajca an jini que tubajob u pancab?
\p 
\v 23 Aj Jesús u yälbi:
\p ―Machca u yajna'tanon, u xe u tz'ombenon cä t'an; cä Pap täcä u xe u yajna'tan; acä xe tä te t'ocob bajca an, cä xe tä ajtä t'ocob tomp'e t'oc une.
\v 24 Machca mach u yajna'ton, mach u tz'onä cä t'an. Ni t'an a ubilaba mach jin täc'a, tuba cä Pap une ni u täsconba. Une u yäc'bon cäle'.
\p 
\v 25 ’Jinda ni acälbenetla ya'toca anon t'oc anela.
\v 26 Ni Ajlotayaba, ni Ch'u'ul Pixanba, jini que u xe u täscun cä Pap täj c'aba'ba, une u xe u ye'benetla upete, u xe u c'ajti'benetla upete cua'tac cälbetla.
\p 
\v 27 ’Cä'benetla ajnic ch'ijcab a c'ajalinla. Ca' chich ch'in an cä c'ajalin, che' chich acä'benetla ajniquetla. Mach ca' u yäq'ue' a'ajtäjob pancab, acä'benetla no'onba. Mach ch'ocomac a pixanla, mach bäc'taquetla.
\v 28 A ubila chich cache' cälbenetla, acä bixe, y acä sujtä bajca anetla. Si a yajna'tanonla u totoj ch'a'alan chich ajinla uc'a cäli cä xe ca'an cä Pap, uc'a cä Papba más ajnoja que no'on.
\v 29 Bada cä worin älbetla cua' u xe u chen pasa antes que utic, uc'a jinq'uin u xe tä ute, a tz'onänla chich.
\p 
\v 30 ’Mach uni' xon cä chen q'uen t'an t'oc anela, uc'a ajnoja tuba jinda u pancab ya' u te. Uneba mach u cänänta cua' t'oc no'on.
\v 31 Ca' chich u yälbon cä Pap, che' chich acä chen uc'a yuwina'tanob pancab cache' acä yajna'tan cä Pap. Ch'oyenla, cola tä pasela wida bajca anonla.
\c 15
\s1 La planta de uva y sus ramas
\p 
\v 1 ’No'on ni ca' a wälä totoj te'uvajon, cä Pap ni ajsis'uva.
\v 2 Upete cä c'äb ya'an täjcac'oba ni mach u che u jutba, u pa'sen. Upete ni u chen u jutba, u sisän, uc'a u chen más q'uen u jut. Ca' jini ayan machcatac u tz'ombenon.
\v 3 Bada anelaba ca' a wälä sisi ayanetla, uc'a a sapila ni cä t'an cälbetlaba.
\v 4 Ajniquetla t'oc no'on y no'on t'oc anela. Ca' ni c'äb te' mach u ch'ä u chen u jut u juntuma si mach ajnic tuyac'o u te'e, che' chich anela täcä mach u ch'ä a chen niump'e cua' si mach ajniquetla t'oc no'on.
\p 
\v 5 ’No'on ca' a wälä ni te'uvajon, anelaba ca' a wälä cä c'äb. Machca ya'an täjcac'o, y no'on tuyac'o, jinda ni u yäq'ue' q'uen u jut. Si mach ajniquetla t'oc no'on, mach u ch'ä a chenla niump'e cua'.
\v 6 Machca mach'an t'oc no'on, u chojcan ca' cäb te' tä tiquin; y de ya'i u ch'ämcan ta julcac tan c'ac' tä pule.
\p 
\v 7 ’Si ajniquetla t'oc no'on, y cä t'an ajnic ta' pixanla, c'atänla upete cua'tac a wola y a xe chich tä ä'bintela.
\v 8 Ca' jini u xe chich tä ch'u'ul c'ajti'can cä Pap, si a chenla q'uen cua' yo Dios a chenla. Ca' jini cheque cache' mero cajcänt'anetla.
\v 9 Ca' chich u yajna'tanon cä Pap, che' chich täcä acä yajna'tanetla. Co que ajniquetla t'oc no'on uc'a cä paq'uin yajna'tanetla.
\v 10 Si a tz'ombenonla cä t'an, ya' chich anetla t'oc no'on y cä paq'uin yajna'tanetla, ca' chich no'on täcä cä tz'ombi u t'an cä Pap, y ya'anon t'oc une y une u paq'uin yajna'tanon.
\p 
\v 11 ’Jinda cälbetla uc'a ajniquetla tä' ch'a'a ajinla ca' chich no'on tä' ch'a'a cäjin.
\v 12 Jinda ni manda cä'benetla: Maläc yajna'tan abala ca' chich cä yajna'tetla.
\v 13 Machca u yäq'ue' uba tä chämo uc'a mach chämic u lot, ca' jini cheque cache' tä' u yajna'tan jini u lot. Mach'an cua' más u ch'e' u chen tuba u ye'e' cache' u yajna'tan u lot.
\v 14 Anela cä lotetla si a chenla ca' acälbenetla.
\v 15 Mach uni' xon cälbenetla cache' cajpatanetla, uc'a ajpatanba mach yuwi cua' u chen u yum. Cä xe cälbenetla cache' cä lotetla, uc'a upete ni cubi t'oc cä Papba, jin chich acälbetla.
\v 16 Anela mach a yaconla. No'on ni cä yaquetla, cä'bet xiquetla a chen u patan Dios, y que upete jini a chenlaba ajnic utz tu jut Dios, uc'a upete cua' a c'atbenla cä Pap täj c'aba'ba, une u yäc'benetla.
\v 17 Jinda cälbenetla: maläc yajna'tan abala.
\s1 El mundo odia a Jesús y a los suyos
\p 
\v 18 ’Si a'ajtäjob pancab u cräxna'tanetla, a wila chich cache' no'on täcä u cräxna'tonob najtäcä.
\v 19 Si fuera tuba u pancabetla, a'ajtäjob pancab u yajna'tanetla ica, uc'a unejob chich u maläc yajna'tan ubajob. A'ajtäjob pancab u cräxna'tanetla uc'a mach tuba u pancabetla, no'onba cä yaquetla uc'a mach ni' ajniquetla tuba u pancab.
\v 20 C'ajna'tanla ni cä t'an cälbetlaba: “Ajpatan mach jin más ajnoja que u yum”. Si no'on u tz'ibajtesonob, anela täcä u xe u tz'ibajtesanetla. Si u tz'onijob cä t'an, che' chich u xe u tz'onänob ta'ala täcä.
\v 21 Upete jinda u xe u cherbenetla uc'a a tz'ombenonla, uc'a mach u che conocejob machca u täscon.
\p 
\v 22 ’Si machica ticon cälbenob, machica an u tanä; bada mach'an cache' u japän ubajob t'oc u tanä.
\v 23 Machca no'on u cräxna'tanon, u cräxna'tan täcä cä Pap.
\v 24 Si machica cä chen niump'e cua' bajca anob que niuntu mach bay u chi, machica an u tanäjob; pero bada u chänijob cua' cä chi, y u cräxna'tanonjob y cä Pap täcä u cräxna'tanob.
\v 25 U chi pasa ca'da uc'a pasic toj ca' chich tz'ibi tama ley tubajob jini u yäle' ca'daba: “U cräxna'tanonjob, pero mach'an cua' uc'a”.
\p 
\v 26 ’Cuanta juli jini Ajlotaya, jini que u xe u yäc'benon cä Pap ta cä täscäbenetlaba, jini Ch'u'ul Pixan que u ye'e' ni u tojaba, jini u te ca'an cä Papba, une u xe u yäle' machcajon.
\v 27 Anela täcä a xe a wäle'la machcajon, uc'a ajnetla t'oc no'on najtäcä ixta bada.
\c 16
\p 
\v 1 ’Jinda cälbetla uc'a mach sujlequet ta' patla.
\v 2 A xe tä pa'sintela tama ch'uj tuba aj judíosob. U xe tä c'ote q'uin jinq'uin machcatac u tzämsenetla u xe u yäle' cache' tuba Dios u chen.
\v 3 Jinda u xe u cherbenetob uc'a mach u che conocejob cä Pap, ni no'on täcä.
\v 4 Jinda cälbetla, uc'a tu c'ote q'uin utic ca' jini a c'ajna'tanla cache' che' chich acälbetla.
\s1 Lo que hace el Espíritu Santo
\p ’Jinda mach cälbetla najtäcä uc'a ya'to anon t'oc anela.
\v 5 Bada cä xe bajca an machca u täsconba. Niuntu de anela mach a ni' c'atbonla: “¿Cada a xe?”
\v 6 Uc'a cälbetla ca' jini, tä' triste an a pixanla.
\v 7 No'onba cälbenetla tu toja: Mäx c'änä bixicon. Si no'on mach bixicon, Ajlotaya mach uta bajca anetla. Bixiconba, cä täscun bajca anetla.
\v 8 Tu te uneba, u xe u chectesbenob a'ajtäjob pancab cua' jini u tanäjob, camba ni u toja, y cua' une ni toji'tanä.
\v 9 U xe u chectesbenob ni u tanäjobba uc'a mach u tz'ombonob une.
\v 10 U xe u ye'e' camba ni u toja, uc'a cä xe ca'an cä Pap, y mach uni' sutwanet a chänenonla.
\v 11 U xe u ye'e' cua' une ni toji'tanä, uc'a ajnoja tuba jinda u pancab u xe chich tä äc'binte u toje' u tanä.
\p 
\v 12 ’Ya'to an q'uen cua' cälbenetla, pero mach to u ch'ä ochic ta' c'ajalinla bada.
\v 13 Tu te ni Ch'u'ul Pixanba, une u xe u ye'benetla upete ni u tojaba; uc'a mach tu c'ajalin u pa'sen cua' jini u xe u yäle'; upete cua' u yubinba, jini u xe u yäle'; u xe u worin älbenetla cua'tac u xe tä ajtä.
\v 14 Une u xe u yäq'ue' que ch'u'ul c'ajti'cacon, uc'a cä t'an chich u xe u yäc'benet a wina'tanla.
\v 15 Upete ni t'an tuba cä Papba, täc'a chich täcä, jin uc'a cäli cache' ni Ch'u'ul Pixan chich u xe u yäc'benet a wina'tanla cä t'an.
\s1 La tristeza se cambiará en alegría
\p 
\v 16 ’Acoli tz'ita' q'uin ta bixicon, y mach uxet a chänenonla; pero otros tz'ita' q'uin tä cha'num a xe chich a chänenonla, uc'a no'on ya' cä xe ca'an cä Pap.
\p 
\v 17 De ya'i u tulaj maläc älijob u yajcänt'anob:
\p ―¿Cua' wäre jini u yälbenonla? U yäle' cache' acoli tz'ita' q'uin ta bixic y mach uxon cä chänenla; pero otros tz'ita' q'uin tä cha'num cä xe cä chänenla une, uc'a u xe ca'an u Pap.
\v 18 ¿Cua' wäre jini u yäle' jinq'uin u yäli ca'da: “Acoli tz'ita'”? Mach cä che entendela cua' jini u yäli.
\p 
\v 19 Aj Jesús yuwi chich cache' yo u c'atbenob cua' jini u yäle', jin uc'a u yäli ca'da:
\p ―¿A maläc c'atben abala quira cua' jini ni acäli: “Acoli tz'ita' q'uin ta bixicon y mach uxet a chänenonla, pero otros tz'ita' q'uin tä cha'num a xe a chänenonla”?
\v 20 Totojtoj cälbenetla, anela a xe tä uc'nanla, y tä ch'ocoman a pixanla, pero jini que tuba u pancabba u xe tä ch'a'alan ujinob. Anela a xela tä triste'anla, pero jini tristejle ta'alaba u xe tä sujtä de ch'a'aljin.
\v 21 Ixic jinq'uin ac'oti hora ta c'ojpac, u na'tan c'uxe. Pero cuanta päncäbi jini ch'oc, mach u ni' c'ajna'ta jini c'uxe. U ch'a'alan ujin uc'a san päncäbi untu ch'oc pancab.
\v 22 Bada anela täcä triste anetla, pero täc te cä chänenetla tä cha'num, u xe tä ch'a'alan ujin a pixanla, y niuntu mach uxin u pa'säbenetla jini ch'a'aljin.
\p 
\v 23 ’Jinq'uinba, mach uxet a c'atbenonla niump'e cua'. Totojtoj cälbenetla, upete cua' a c'atbenla cä Pap täj c'aba', u xe chich u yäc'benetla.
\v 24 Badaba mach to a c'atäla niump'e cua' täj c'aba'. C'atänla y a xe chich tä ä'bintela tuba paq'uin ajnic a ch'a'aljinla.
\s1 Jesucristo, vencedor del mundo
\p 
\v 25 ’Jintacda cälbetla t'oc balä' tz'aji. U xe tä c'ote q'uin mach uni' xon cälbenetla t'oc balä' tz'aji. Cä xe cä totoj chectesbenetla cache'da ayan cä Pap.
\v 26 Jinq'uinba a xe a c'atänla täj c'aba'. Mach ni' c'änä ajnicon de ajnumsajt'an ta'ala t'oc cä Pap.
\v 27 Uc'a cä Pap chich u yajna'tanetla, uc'a anela täcä a yajna'tonla y a tz'onila cache' ya' aton bajca an Dios.
\v 28 Ya' chich aton bajca an cä Pap, julon pancab. Bada cha'num cäctan u pancab y cä bixe bajca an cä Pap.
\p 
\v 29 U yajcänt'anob u yäle':
\p ―Bada cheque chich cua' a wäle'. Niump'e balä' tz'aji mach a ni' che.
\v 30 Bada cuwi t'ocob cache' a wi chich upete, y mach c'änä cä ni' c'atbenet t'ocob cua' a wäle'. Jin uc'a acä tz'onän t'ocob cache' ya' chich atet bajca an Dios.
\p 
\v 31 Aj Jesús u yälbijob:
\p ―¿Bada a totoj tz'onänla?
\v 32 Ubinla, u xe tä c'ote q'uin, y bada ac'oti chich jini q'uin jinq'uin a xe a puclan abala, y a xe tä bixela cachichcada. A xe a wäctanonla cä juntuma täcä, pero mach cä juntuma cä xe tä colan, uc'a cä Pap ya'an t'oc no'on.
\v 33 Jinda cälbetla uc'a co cä'benetla ajnic ch'ijcab a c'ajalinla. Tu pancab a xe tä tz'ibajtescanla, pero mach bäc'taquetla, no'onba acä chi trebe cä tzupsäben u poder jini ajnoja tuba u pancab.
\c 17
\s1 Jesús ora por sus discípulos
\p 
\v 1 Jintacda u yäli aj Jesús, de ya'i u t'äbsi u jut tä cielo u yäli ca'da:
\p ―Cä Pap, ac'oti q'uin, äc'ä tä chäninte cä poder, no'on a Wajlo'on, uc'a ca' jini cäq'ue' tä chäninte a poder täcä.
\v 2 Uc'a ane a wäc'bon täj c'äb upetejob machcatac a yaquijob pancab tuba cä'ben paq'uin cuxlecob.
\v 3 Upete machcatac u chenet conoce y u chenon conoce täcä, jin une ni paq'uin cuxu ayanob, uc'a ane ni mero Dioset y no'on ni aj Jesucristo que a täsconba.
\p 
\v 4 ’Cäq'ui tä chäninte pancab cache' an a poder. Acä tzupsi ni patan a'bon cä chenba.
\v 5 Bada cä Pap, äc'ä tä chäninte cache' ayan chich cä poder bajca ayanet täcä, jinchichba poder que cä cänänti jinq'uin ya'anon bajca anet jinq'uin mach to an u pancab.
\p 
\v 6 ’Cä chectesbijob chich jini winicob a yaqui pancabba cache' ane ni Dioset. Ta'ajob chich, y a'bon täj c'äb, y u tz'onijob a t'an.
\v 7 Bada yuwijob cache' ta' c'äb ati upete cua'tac a'bon.
\v 8 Uc'a ni t'an a'bonba, cä ye'bijob. Unejob u sapi, y bada yuwijob chich cache' aton bajca anet, y u tz'onijob cache' ane a täscon.
\p 
\v 9 ’Cä c'atän que a täclenob, mach cä c'atä tuba jini que tuba u pancabobba. Cä c'atän tuba machcatac a'bonba, uc'a ta'ajob chich.
\v 10 Upetejob jini täc'aba, ta'a chich; y upetejob jini ta'aba, täc'a chich. Ca' jini cä ch'u'ul c'ajti'can, uc'a lo que u chenob.
\p 
\v 11 ’Mach uni' xon tä ajtä pancab. Jindajobba ya'to anob pancab, y no'onba cä te bajca anet. Cä ch'u'ul Pap, cänäntanob t'oc a poder ni a'bonba uc'a ajnicob tomp'e t'oc ane ca' chich anonla.
\v 12 Jinq'uin ya'to anon t'oc unejob pancab, cä cänäntijob t'oc a poder; machcatac a'bonba, cä cänäntijob chich, y niuntu mach säti sec' jini ajlo' tuba chich ajsätoba, uc'a pasic toj ca' chich tz'ibi tama a jun.
\p 
\v 13 ’Bada cä te bajca anet. Jinda cäle' ya'toca anon pancab uc'a ajnicob tä' ch'a'a ujinob ca' chich no'on tä' ch'a'a cäjin.
\v 14 No'on cälbijob a t'an. Jinijob tubajob u pancabba u cräxna'tijob uc'a mach tuba u pancabob, ca' chich no'on täcä mach tuba u pancabon.
\v 15 Mach cä c'atä a pa'senob pancab, cä c'atbenet a cänäntanob uc'a mach u cherbenob cua' tzuc pixan.
\v 16 Unejob mach tuba u pancabob, ca' chich no'on mach tuba u pancabon.
\v 17 Äc'ben ochic a t'an tu c'ajalinob, y ca' jini ajnicob seq'uen ta'a y tu toja; a t'an aneba toj chich.
\v 18 Ca' chich ane a täscon cäle' a t'an pancab, che' chich täcä cä täscunob u yäle' a t'an pancab.
\v 19 Cäq'ue' cäba ajnicon seq'uen ta'a, uc'a unejob totoj ajnicob seq'uen ta'a.
\p 
\v 20 ’Mach sec' tuba jinijob cä c'atbenet. Cä c'atbenet täcä tuba machcatac u xe u tz'ombenonob uc'a u t'anob.
\v 21 Uc'a upetejob ajnic tomp'e, ca' chich ane cä Pap tomp'e ayanet t'oc no'on, y no'on t'oc ane, y ajnicob täcä tomp'e t'oc no'onla, tuba u tz'onänob a'ajtäjob pancab cache' ane a täscon.
\v 22 Ni poder a'bonba, jin chich acä'bijob uc'a ajnicob tomp'e, ca' chich anonla tomp'e.
\v 23 No'on tomp'e ayanon t'oc unejob, y ane t'oc no'on, tuba nonoj ajnicob tomp'e t'oc no'onla, uc'a ca' jini yuwina'tanob a'ajtäjob pancab cache' ane a täscon, y cache' ane a yajna'tanob, ca' chich no'on a yajna'ton.
\p 
\v 24 ’Cä Pap, machcatac a'bon co ajnicob täcä t'oc no'on bajca anon uc'a u chänenob cä poder a'bonba, uc'a mach to an u pancab a yajna'tanon.
\v 25 Cä Pap que a chen tu tojaba, a'ajtäjob pancab mach u chet conoce; no'onba cä chenet chich conoce; y jindajob yuwijob cache' ane a täscon.
\v 26 No'on cä chectesbijob cache'da anet aneba, y cä xe chich cä chectesbenob más, uc'a yuwina'tanob cache' a yajna'tanob ca' chich ane a yajna'tanon, y uc'a ca' jini ajnicon tu pixanob.
\c 18
\s1 Llevan preso a Jesús
\r (Mt. 26.47‑56; Mr. 14.43‑50; Lc. 22.47‑53)
\p 
\v 1 Cuanta u yäli jinda aj Jesús, bixi t'oc u yajcänt'anob tunxe ni pa' u c'aba' Cedrón, c'oti bajca an ump'e bojte' ta päc'äbi. Ya'i ochi aj Jesús t'oc u yajcänt'anob.
\v 2 Aj Judas ni u yäq'ui tä c'äbä aj Jesúsba, yuwi chich täcä cada an ni päc'äbi jini, uc'a aj Jesús a'uti u woylan ubajob ya'i t'oc u yajcänt'anob.
\v 3 Aj Judas u woyli uba t'oc noj q'uenel soldado y ajc'äncanob täcä tuba u yajnojajob pale y tuba aj fariseojob, c'otijob ya'i t'oc u chictaya, t'oc u te' y t'oc u machitob.
\v 4 Aj Jesúsba yuwi chich upete cua'tac u te tuyac'o, pänte'i u c'atbenob:
\p ―¿Caxcone a sacänla?
\p 
\v 5 U p'alijob:
\p ―Aj Jesús aj nazarenoba.
\p Aj Jesús u yälbenob:
\p ―No'on une.
\p Aj Judas ni u yäq'ui tä c'äbäba ya' chich an täcä t'oc unejob.
\v 6 Uc'a u yäli aj Jesús: “No'on une”, sutwäni tu patob, yälijob tä cab.
\v 7 De ya'i aj Jesús sutwäni u c'atbenob:
\p ―¿Caxcone a sacänla?
\p Unejob u yäli:
\p ―Aj Jesús aj nazarenoba.
\p 
\v 8 Aj Jesús u p'ali:
\p ―San cälbetla cache' no'on chich; si no'on a sacänonla, äctanla tä bixe jindajob.
\p 
\v 9 U yäli ca' jini uc'a pasic toj ca' chich u yäli uneba: “Niuntu mach cä säti ni a'bonba”.
\v 10 De ya'i aj Simón Pedro u pa'si u machit tama u pat u chunjätz'bi u chiquin tu nojba u yajpatan no' ajnoja pale. U c'aba' ni ajpatan jini aj Malco.
\v 11 De ya'i aj Jesús u yälbi aj Simón Pedro:
\p ―Äc'ä a machit tan u pat. Ni tz'ibajtesia que u yäq'ui cä Pap äc'binticonba, ¿a wäle' quira que mach uxon cä ch'e'?
\s1 Jesús ante el jefe de los sacerdotes
\r (Mt. 26.57‑58; Mr. 14.53‑54; Lc. 22.54)
\p 
\v 12 De ya'i jini soldadojob y ajnoja ta soldadojob y u yajc'äncanob aj judíosob u q'uechijob aj Jesús y u cächijob.
\v 13 Najtäcä u bisijob bajca an aj Anás, uc'a aj Anásba jichan aj Caifás. Aj Caifásba no' ajnoja pale jimba año jini.
\v 14 Aj Caifás une ni u yäc'bi c'ajalin aj judíosob cache' c'änä chämic untu uc'a mach sätic entero caj.
\s1 Pedro niega conocer a Jesús
\r (Mt. 26.69‑70; Mr. 14.66‑68; Lc. 22.55‑57)
\p 
\v 15 Aj Simón Pedro bixi tu pat aj Jesús t'oc otro untu ajcänt'an. Jini ajcänt'an u chen chich conoce no' ajnoja pale. Jin uc'a ochi t'oc aj Jesús tan yotot no' ajnoja pale.
\v 16 Aj Pedroba ya' coli tä wa'tä päti ti' otot. Pasi jini ajcänt'an u chen conoce no' ajnoja paleba, y u pequi ixcänän ti'otot tuba u yosen aj Pedro.
\v 17 Ixcänän ti'otot u yälbi aj Pedro ca'da:
\p ―¿Mach quira ane täcä ajcänt'anet tuba jinda winic?
\p Une u yäli:
\p ―Mach jinon.
\p 
\v 18 Ajpatanob y ajc'äncanob tuba aj judíosob u tz'äbijob c'ac' uc'a sis. Wa'wänijob ti' c'ac' u ticwesan ubajob. Ya' wa'ca aj Pedro täcä t'oc unejob u ticwesan uba.
\s1 El jefe de los sacerdotes interroga a Jesús
\r (Mt. 26.59‑66; Mr. 14.55‑64; Lc. 22.66‑71)
\p 
\v 19 No' ajnoja pale u c'atbi aj Jesús si an u yajcänt'anob y cua'tac u ye'e'.
\v 20 Aj Jesús u p'ali:
\p ―No'on mach mucu cä chi t'an pancab. No'on cä paq'uin ye'i u t'an Dios tama ch'uj taj judíosob y tama noj ch'u'ul otot bajca u woylan uba upete aj judíosob. Mach cäli niump'e cua' mucu.
\v 21 ¿Can uc'a a c'atbenon no'on? C'atbenob machcatac u yubi cua'tac cälbijob. Unejob chich yuwi cua'tac cäli.
\p 
\v 22 Uc'a xi u yäle' ca'da, untu soldado que ya' wa'ca ya'i u t'äbsi u c'äb y u cuni aj Jesús, u yäli ca'da:
\p ―¿Ca' jini a xe a p'alben u t'an no' ajnoja pale?
\p 
\v 23 Aj Jesús u p'ali:
\p ―Si mach utz cua' acäli, älä cache'da mach utz. Y si utzba, ¿cua' uc'a a cune'on?
\p 
\v 24 De ya'i aj Anás u täsqui cächä aj Jesús bajca an aj Caifás, no' ajnoja pale.
\s1 Pedro niega otra vez a Jesús
\r (Mt. 26.71‑75; Mr. 14.66‑72; Lc. 22.58‑62)
\p 
\v 25 Aj Pedro ya'to wa'ca u ticwesan uba. U yälbijob ca'da:
\p ―¿Mach quira ane täcä u yajcänt'anet?
\p Une u yäli:
\p ―Mach jinon.
\p 
\v 26 Untu u yajpatan no' ajnoja pale, u familia chich ni u chunjätz'bi u chiquin aj Pedroba, u yälbi täcä ca'da:
\p ―¿Mach quira cä chänet t'oc tan bojte' ta päc'äbi?
\p 
\v 27 Aj Pedro u yäli tä cha'num cache' mach toj. De ya'i seb u chi uq'ue ajtze.
\s1 Jesús delante de Pilato
\r (Mt. 27.1‑2, 11‑14; Mr. 15.1‑5; Lc. 23.1‑5)
\p 
\v 28 Isapanto u pa'sijob aj Jesús tu yotot aj Caifás, u bisijob tu yotot aj Pilato. Aj judíosob mach ochijob tan yotot aj Pilato uc'a mach u xac'än ubajob t'oc aj gentil, uc'a ca' jini u ch'e' c'uxnacob ta noj paxcu'.
\v 29 De ya'i aj Pilato pasi päjna bajca anob u yäli ca'da:
\p ―¿Cua' sub a täsila tuyac'o jinda winic?
\p 
\v 30 Unejob u yäli ca'da:
\p ―Si fuera mach ajnic u tanä, machica cä täsbet t'ocob.
\p 
\v 31 Aj Pilato u yälbijob:
\p ―Ch'äla anela, cherbenla ca' chich an tuyac'o ley ta'ala.
\p Aj judíosob u yäli:
\p ―Mach u ch'ä cäq'ue' t'ocob tä tzämsinte niuntu.
\p 
\v 32 Upete ni jini u chi pasa uc'a pasic toj ca' chich u worin äli aj Jesús, jinq'uin u yäli cache'da u xe tä chämo.
\v 33 De ya'i aj Pilato ochi cha'num tan yotot, u joq'ui aj Jesús u c'atben:
\p ―¿Ane quira ni Ajnojalet taj judíosob?
\p 
\v 34 Aj Jesús u p'ali:
\p ―¿Ane chich ta' c'ajalin quira a pa'si jinda, o älbinte a chi caxcajon?
\p 
\v 35 Aj Pilato u p'ali:
\p ―¿Aj judíojon quira no'on? A wajcäbnajob y ajnojajob ta pale u yäq'uetob täj c'äb. ¿Cuaxca tanä a chi?
\p 
\v 36 Aj Jesús u p'ali:
\p ―Bajca cä chen manda no'onba mach pancab. Si fuera jimba u pancabda cä chen mandaba, cajpatanob u chen ica jo'yan u japänon tu c'äb aj judíosob. Jin uc'a bajca cä chen manda no'onba mach wida une.
\p 
\v 37 De ya'i aj Pilato u yälbi:
\p ―¿Ajnojalet quira ane?
\p Aj Jesús u p'ali:
\p ―Jinon chich, ca' chich mu' a wäle' cache' ajnojalon. Jin tuba päncäbon, jin tuba ton pancab, tuba cäle' ni u tojaba. Upete machcatac ayan t'oc ni u tojaba u yubin cä t'an.
\p 
\v 38 Aj Pilato u yälbi:
\p ―¿Cua' jini ni u tojaba?
\s1 Jesús es sentenciado a muerte
\r (Mt. 27.15‑31; Mr. 15.6‑20; Lc. 23.13‑25)
\p Jinq'uin u yälbi jinda t'an, pasi cha'num aj Pilato u pecän aj judíosob, u yälbenob ca'da:
\p ―Mach cä pojläbe niump'e u tanä.
\v 39 Anelaba nämäletla cä chajbenetla untu tan paxcu'. ¿A wola quira cä chajbenetla Ajnoja taj judíosob?
\p 
\v 40 Upetejob u chijob noj t'an tä cha'num, u yäle'ob:
\p ―¡Mach a chaje' jindaba! ¡Chajbenon t'ocob aj Barrabás!
\p Aj Barrabásba ajxuch' une.
\c 19
\p 
\v 1 De ya'i aj Pilato u ch'i aj Jesús u yäq'ui tä jätz'can.
\v 2 Soldadojob u jit'bi u corona de ch'ix, u yäc'bijob tan u pam, u xojbijob ump'e u ic'puq'uen buc tuyac'o.
\v 3 U tze'tanob y u yälbenob ca'da:
\p ―¡Ch'u'ul c'ajti'caquet, Ajnoja taj judíosob!
\p Y u cune'ob t'oc u c'äb.
\p 
\v 4 Aj Pilato pasi cha'num päti u yälbenob ni gente:
\p ―Ubixtola, cä xe cä täsbenetla päti uc'a a wina'tanla cache' mach cä pojläbe niump'e u tanä.
\p 
\v 5 Aj Jesús pasi päti t'oc u ch'ixil corona tan u pam y t'oc u ic'puq'uen buc. Aj Pilato u yälbenob ca'da:
\p ―¡Ya'anda ni winicda!
\p 
\v 6 Jinq'uin ajnojajob ta pale y ni soldadojob u chänijob, t'oc noj t'an u yälijob:
\p ―¡Äc'ä tä cruz! ¡äc'ä tä cruz!
\p Aj Pilato u yälbenob:
\p ―Ch'äla anela äc'äla tä cruz, uc'a mach cä pojläbe no'on niump'e u tanä.
\p 
\v 7 Aj judíosob u p'ali:
\p ―Ya'an cä ley t'ocob, cä ley t'ocob u yäle' chämic, uc'a une u chi uba ca' u Yajlo' Dios.
\p 
\v 8 Jinq'uin aj Pilato u yubi jinda t'an, más bäc'ti.
\v 9 Ochi cha'num tan yotot u c'atbi aj Jesús:
\p ―¿Caxcadajet ane?
\p Aj Jesús mach u p'ali cua'.
\p 
\v 10 De ya'i aj Pilato u yälbi:
\p ―¿Cua' uc'a mach a p'alä cä t'an? ¿Mach quira a wi cache' no'on an cä poder cäq'ue'et tä tzämsinte tä cruz y an cä poder cä chaje'et?
\p 
\v 11 Aj Jesús u p'ali:
\p ―Ane mach u ch'ä a chen niump'e cua' täjcac'o si mach u yäc'bet Dios tä cielo a chen. Jin uc'a más an u tanä machca u yäc'on ta' c'äb.
\p 
\v 12 Desde jimba hora jini aj Pilato u sacän cache' u xe u chaje'. Pero aj judíosobba t'oc noj t'an u yälijob:
\p ―¡Si jinda winic a chaje', mach anet t'oc aj César! ¡Machca chichca u chen uba de ajnoja ca' u chi ni winic jini, u jule' uba tuyac'o aj César!
\p 
\v 13 Jinq'uin aj Pilato u yubi jinda t'an, u pa'si päjna aj Jesús, chunwäni tu chumlib juez bajca u c'aba' ya'i tä hebreoba Gabata. Jini t'an yo u yäle' cache' puro ji'tun.
\v 14 Jimba q'uindaba, tusbäji ta noj paxcu', u chen tä c'ote tänxin q'uin. U yälbi aj judíosob:
\p ―¡Ya'anda ni a wajnojala!
\p 
\v 15 Unejob t'oc noj t'an u yälijob:
\p ―¡Pa'sen! ¡Pa'sen! ¡äc'ä tä cruz!
\p Aj Pilato u yälbenob:
\p ―¿A wola quira cäq'ue' tä cruz ni a wajnojala?
\p Ajnojajob ta pale u yälijob:
\p ―Mach'an otro cajnoja t'ocob, sec' aj César une.
\p 
\v 16 De ya'i aj Pilato u yäc'bi tu c'äbob tuba u yäq'ue' tä cruz. Ni gente u ch'ijob aj Jesús y u bisijob.
\s1 La crucifixión
\r (Mt. 27.32‑44; Mr. 15.21‑32; Lc. 23.26‑43)
\p 
\v 17 Aj Jesús pasi t'oc u cruz u bisi bajca u yälbinte tä bäc pam tiquinba, tä hebreojt'anba Gólgota.
\v 18 Ya'i u yäq'uijob tä cruz. U yäq'uijob tu cruzob täcä otros cha'tu bajca an une, untu tu noj, untu tu tz'ej, aj Jesús tänxin.
\v 19 Aj Pilato u tz'ibi ump'e c'aba' täcä, u yäq'ui tu pam u cruz aj Jesús. Tz'ibi ca'da: “Aj Jesús aj nazareno, Ajnoja taj judíosob”.
\v 20 Q'uen aj judíosob u tziquijob jini c'aba', uc'a nätz'ä t'oc caj bajca äc'qui tä cruz aj Jesús. Tz'ibi tä hebreo, tä griego, y tä latín.
\v 21 Ajnojajob pale taj judíosob u yälbijob aj Pilato:
\p ―Mach a tz'ibän: “Ajnoja taj judíosob”. Tz'ibän ca'da: “Jinda winic u yäli cache' une Ajnoja taj judíosob”.
\p 
\v 22 Aj Pilato u p'ali:
\p ―Ni cä tz'ibiba, acä tz'ibi chich une y mach uxon cä q'uexe'.
\p 
\v 23 Ni chäntu soldadojob, cuanta u yäq'ui tä cruz aj Jesús, u ch'ämbijob u buc, u puclijob ajump'e juntu. U ch'ämbijob täcä u buc tu pamba. Jini u buc tu pamba mach chuyu une, jit'i une entero ump'e desde isqui ixta emä.
\v 24 U maläc älijob:
\p ―Mach cä tajala, cola cä pa'senla suerte quiranla caxca une u xe u ch'e'.
\p Jinda u chijob tuba pasic toj ca' chich tz'ibi tama u jun Dios ca'da: “U puclijob cä buc. Ni cä buc tu pamba u yäläsijob tuba u jiran caxca une u xe u ch'e'”. Che' chich u chi ni soldadojob.
\p 
\v 25 Ya' wa'ca u na' aj Jesús bajca an tä cruz. Ya'anob ya'i täcä u chich u na', ix María jit'oc aj Cleofas, y ix María Magdalena.
\v 26 Jinq'uin aj Jesús u chäni u na' y jini u yajcänt'an tä' u yajna'tanba ya' wa'cajob t'oc, u yälbi u na' ca'da:
\p ―Cä na', ya'an jini a wajlo'.
\p 
\v 27 De ya'i u yälben u yajcänt'an:
\p ―Ya'an jini a na'.
\p Jinchichba hora jini ni ajcänt'an u ch'i ni ixic jini u bisi tu yotot.
\s1 Muerte de Jesús
\r (Mt. 27.45‑56; Mr. 15.33‑41; Lc. 23.44‑49)
\p 
\v 28 De ya'i aj Jesús yuwi chich cache' axupi tä ute upete lo que Dios u yäc'bi u chen. U yäli:
\p ―Tiquin cä ti'.
\p Ca' jini u yäli uc'a pasic toj ca' chich tz'ibi tan u jun Dios.
\p 
\v 29 Ajni ya'i ump'e jotz tulu t'oc pajäl c'äb uva. U majijob ump'e tz'u'i' ja' tama jini pajäl c'äb uva, u yäq'uijob tuyac'o untz'it te', y u yäc'bijob tu ti'.
\v 30 Cuanta u yuch'i jini pajäl c'äb uva, aj Jesús u yäli ca'da:
\p ―Acä tzupsi cä chen upete ca' chich u yäc'bon Dios cä chen.
\p De ya'i u chinjatz'i u pam y chämi.
\s1 Un soldado abre con su lanza el costado de Jesús
\p 
\v 31 De ya'i aj judíosob, uc'a u q'uini tusbäji ta paxcu', u c'atbijob aj Pilato xulcac yoc u yuxtumajob y pa'sintic tä cruz cuanta chämijob, uc'a mach colacob tä cruz tu q'uin ch'ämbäji, uc'a jini q'uin ch'ämbäji noj q'uin ch'uj une.
\v 32 C'otijob soldadojob, u xulbijob yoc untu che' chich täcä ni otro untuba, ni äc'qui tä cruz jinq'uin äc'qui tä cruz aj Jesúsba.
\v 33 Jinq'uin c'otijob bajca an aj Jesús, u chänijob cache' san chämi. Jin uc'a mach u xulbijob yoc.
\p 
\v 34 Untu soldado u xec'bi tu ch'ejpa t'oc untz'it xec'onib, seb pasi ch'ich' y ja'.
\v 35 No'on aj Juanon cäle' tu toja cache'da uti, uc'a no'on chich cä chäni, y jini cäle'ba, toj une. Cuwi chich cache' toj cua' cäle', uc'a a tz'onänla täcä anela.
\v 36 Jinda uti uc'a pasic toj ca' chich tz'ibi tama u jun Dios ni u yäle' ca'daba: “U bäque mach uxin tä xulcan”.
\v 37 U yäle' täcä ca'da: “U xe chich u chänenob jini winic que xec'quiba”.
\s1 Jesús es sepultado
\r (Mt. 27.57‑61; Mr. 15.42‑47; Lc. 23.50‑56)
\p 
\v 38 Ji'pat aj José, u cab tä Arimatea, c'oti u c'atben aj Pilato si u ch'e' u pa'sen u cuerpo c'äsi' aj Jesús tu cruz tuba u muque'. Aj José u yajcänt'an aj Jesús, pero mach u yälä si ayan t'oc, uc'a u bäc'tan aj judíosob. Aj Pilato u yäc'bi chich u pa'sen. De ya'i c'oti u pa'sen u cuerpo c'äsi' aj Jesús.
\v 39 C'oti täcä aj Nicodemo, jini ajni najtäcä bajca an aj Jesús ac'äbba, u c'osi ump'e jätz'äcnib u c'aba' mirra xäbä t'oc áloes, ca' ta treinta kilos.
\v 40 U ch'ijob c'äsi' aj Jesús, u tz'otijob t'oc noc' y u tatz'ijob t'oc jini jätz'äcnib, ca' chich u muque' ajchäme aj judíosob.
\v 41 Nätz'ä bajca äc'qui tä cruz ajni ump'e bojte' ta päc'äbi. Tama jini bojte' ajni ump'e u ch'ena ajchäme tzijib que uti tuyac'o ji'tun tu näc' tz'ic, mach to u yä'ca niuntu tama.
\v 42 Ya'i jiq'uin u yäq'uijob u cuerpo c'äsi' aj Jesús, uc'a jini u ch'ena ajchäme nätz'ä ayan. Jimba q'uin jiniba, tusbäji ta paxcu' taj judíosob.
\c 20
\s1 La resurrección de Jesús
\r (Mt. 28.1‑10; Mr. 16.1‑8; Lc. 24.1‑12)
\p 
\v 1 Najtäcäl q'uin ta semana, isapanto, jinq'uin mach to junch'äcna c'oti ix María Magdalena bajca mujqui aj Jesús. U chäni cache' apa'sinti ni ji'tun tu ti' ch'en bajca mujquiba.
\v 2 Bixi t'oc ancäre, c'oti ca'an aj Simón Pedro t'oc jini otro ajcänt'an tä' u yajna'tan aj Jesúsba, u yälbenob:
\p ―Ach'ämqui Cajnojala bajca mujqui, mach cuwila cada u yäq'uijob.
\p 
\v 3 Pasi aj Pedro t'oc jini otro ajcänt'an, bixijob bajca mujqui aj Jesús.
\v 4 U cha'tumajob tä ancäre; ni ajcänt'an untuba más seb ancäri que aj Pedro, c'oti najtäcä ti' ch'en bajca mujqui.
\v 5 Tinwäni u chänen, u chäni ya'an noc' tan ni mucliba y mach ochi.
\v 6 Aj Simón Pedro c'oti ji'pat. Uneba ochi tama ni mujquiba u chäni cache' ya'an ni noc' t'unqui t'oc aj Jesúsba.
\v 7 Ni noc' ajni cächä t'oc u pam c'äsi' aj Jesúsba mach ajni tomp'e, yänä ajni tupu.
\v 8 Jinq'uin ochi täcä ni otro ajcänt'an, jini c'oti najtäcä bajca an ni mujquibaba, u chäni, y u tz'oni.
\v 9 Uc'a ixta jinq'uin mach to u che entendejob ni jun ta Dios tz'ibiba, ni u yäle' cache' c'änä cuxpac tan ajchämejobba.
\v 10 De ya'i jini ajcänt'anob sutwänijob tu yototob.
\s1 Jesús se aparece a María Magdalena
\r (Mr. 16.9‑11)
\p 
\v 11 Ix Maríaba ya'an tä uq'ue nätz'ä bajca mucli, t'oc uq'ue tinwäni u chänen tan ch'en.
\v 12 U chäni cha'tu ángelo ta Dios, t'oc u säsäc bucob ya' chumcajob, untu tu pam, untu tu yoc bajca ajni c'äsi' aj Jesús.
\v 13 U yälbijob:
\p ―Ixic, ¿cua' uc'a a chen uq'ue?
\p Une u yäli:
\p ―Uc'a u bisijob Cajnoja, y mach cuwi cada u yäq'uijob.
\p 
\v 14 Cuanta u yäli jinda, u suti uba y u chäni cache' ya' wa'ca aj Jesús. Uneba mach yuwi si aj Jesús.
\v 15 Aj Jesús u yälbi:
\p ―Ixic, ¿cua' uc'a a chen uq'ue? ¿Caxcone a sacän?
\p Une u yäli tan u c'ajalin cache' bay ajcänän päc'äbi, y u yälbi:
\p ―Noxi' winic, si ane a bisi, älbenon cada a wäq'ui, uc'a cä bisan no'on.
\p 
\v 16 Aj Jesús u yälbi:
\p ―¡María!
\p Une u suti uba u yälben:
\p ―¡Raboni! ―uc'a a wina'tan tä yocot'anba: Maestro.
\p 
\v 17 Aj Jesús u yälbi:
\p ―Mach a täle'on uc'a mach to t'abon ca'an cä Pap. Cux ane bajca an ni hermanojob que u tz'ombi u t'an Diosba, y älbenob ca'da: “Cä t'äbo ca'an cä Pap, y ca'an a Papla, ca'an cä Dios, y ca'an a Diosla”.
\p 
\v 18 Ix María Magdalena bixi u yälben u yajcänt'anob cache' u chäni Ajnoja, y cua'tac u yälbi.
\s1 Jesús se aparece a los discípulos
\r (Mt. 28.16‑20; Mr. 16.14‑18; Lc. 24.36‑49)
\p 
\v 19 Jinchichba q'uin jini, ochiq'uin, najtäcäl q'uin ta semana, mäcä uc'ajob ti' otot bajca an ni ajcänt'anob uc'a u bäc'tan aj judíosob. C'oti aj Jesús tä wa'tä tänxin de unejob. U yälbijob ca'da:
\p ―Ajnic ch'ijcab a c'ajalinla.
\p 
\v 20 Cuanta u yäli jinda, u ye'bijob u c'äb y u ch'ejpa. U yajcänt'anob ch'a'ali ujinob u chänenob ni Ajnoja.
\v 21 Aj Jesús u yälbijob tä cha'num:
\p ―Ajnic ch'ijcab a c'ajalinla. Ca' chich u täscon cä Pap cä tz'aycäben u t'an, che' chich täcä acä täscunetla a tz'aycunla u t'an Dios.
\p 
\v 22 Cuanta u yäli jinda, u yustijob y u yälbijob:
\p ―Ch'äla ni Ch'u'ul Pixan.
\v 23 Machca chichca a wäle'la que perdonado ayan u tanä, Dios chich u chen perdona. Y machca chichca a wäle'la que mach perdonado an u tanä, Dios mach u cherbe perdona.
\s1 Tomás ve al Señor resucitado
\p 
\v 24 Aj Tomás mach ajni ya'i jinq'uin c'oti aj Jesús. Une untu de ni docejob, ni u yälbinte cache' ajwacu'ba.
\v 25 U yälbijob jini ajcänt'anob u lotobba:
\p ―Cajnojala acä chäni t'ocob.
\p Une u yälbijob ca'da:
\p ―Si mach cä chänen tu c'äb bajca ajni clavo, si mach cä jup'e' cä ni'c'äb bajca u lowi clavo, si mach cä jup'e' cä c'äb tan u ch'ejpa, mach cä tz'onä.
\p 
\v 26 Ocho día ji'pat, ya'anob tä cha'num tan otot u yajcänt'anob. Jinq'uinba, aj Tomás täcä ya'an t'oc unejob. Mäcä ti' otot bajca anob, c'oti aj Jesús tä wa'tä tänxin bajca anob, u yäli ca'da:
\p ―Ajnic ch'ijcab a c'ajalinla.
\p 
\v 27 De ya'i aj Jesús u yälbi aj Tomás:
\p ―Jup'u a ni'c'äb wida, chänen cä c'äb, sätz'ä a c'äb jup'u täc ch'ejpa. Mach a wäle' que mach a tz'onä, tz'onän chich.
\p 
\v 28 De ya'i aj Tomás u yäli ca'da:
\p ―¡Cajnojalet y cä Dioset!
\p 
\v 29 Aj Jesús u yälbi:
\p ―¿Uc'a quira a chänon, Tomás, a tz'onän bada? Ch'a'a ujinob machca mach u chänonjob, y u tz'onijob.
\s1 El porqué de este libro
\p 
\v 30 Aj Jesús u chi täcä tu jut u yajcänt'anob q'uen cua' chichca tuba u ye'e' u poder que mach tz'ibi tama jinda jun.
\v 31 Jindaba tz'ibinti uc'a a tz'onänla cache' aj Jesús aj Cristo une, u Yajlo' Dios, uc'a si a tz'onänlaba, a xe tä paq'uin ajtäla cuxu nämte' t'oc une.
\c 21
\s1 Jesús se aparece a siete de sus discípulos
\p 
\v 1 Ji'pat aj Jesús u ye'i uba tä cha'num bajca an u yajcänt'anob ti' nab u c'aba' Tiberias. Ca'da u chi pasa jinq'uin u ye'i uba:
\v 2 Aj Simón Pedro, aj Tomás jini u yälbinte cache' ajwacu'ba, y aj Natanael jini u cab tä Caná tama noj cab tä Galileaba, y u ch'ocob aj Zebedeo, y otros cha'tu u yajcänt'an ajnijob tomp'e jimba q'uin jini.
\v 3 Aj Simón Pedro u yälbi u lotob:
\p ―Ya cä xe no'on tä q'uechbuch'.
\p U lotob täcä u yäli:
\p ―Acä xe t'ocob täcä t'oc ane.
\p Bixijob, ochijob tama ump'e jucub. Jini ac'äb mach u q'uechijob cua'.
\v 4 Mu' u junch'äcnan c'oti aj Jesús tä wa'tä ti' nab. U yajcänt'anobba mach yuwijob si aj Jesús.
\v 5 U yälbijob ca'da:
\p ―Cä bijch'oc, ¿a q'uechila quira cua' tä c'uxcan?
\p U p'alijob:
\p ―Mach acä q'uechi t'ocob cua'.
\p 
\v 6 Aj Jesús u yälbijob:
\p ―Julula chim ta' noj, y a xe a q'ueche'la.
\p U julijob chich. De ya'i mach u chi trebejob u ch'o'e' uc'a tä' q'uen ni buch' ochi tama.
\v 7 Jini u yajcänt'an aj Jesús tä' u yajna'tanba u yälbi aj Pedro:
\p ―Cajnojala une.
\p Aj Simón Pedro, jinq'uin u yubi cache' Ajnoja, u xoji u buc uc'a sin buc ayan, y u juli uba tä ja' tuba c'otic bajca an.
\v 8 Ni otro u yajcänt'anobba c'otijob tä cab t'oc jucub, uc'a mach nat t'oc cab bajca ayanob, ca' ta cien metros u nät'an, u täsen u jolänob ni chim t'oc buch'.
\v 9 Jinq'uin t'äbijob tä cab, u chänijob cache' ya'an jut c'ac', ya'an buch' y waj tu pam ni jut c'ac'.
\v 10 Aj Jesús u yälbijob:
\p ―Täsen tz'ita' ni buch' a totaj q'uechilaba.
\p 
\v 11 Aj Simón Pedro ochi tan jucub u jolän ni chim tä cab, tulu t'oc nuc buch'. Ajni ciento cincuenta y tres buch' tama ni chim. Tä' q'uen, y mach xet'qui ni chim.
\v 12 Aj Jesús u yälbijob:
\p ―La'ixla tä c'uxnan.
\p Pero niuntu u yajcänt'an mach u yoli u c'atben ca'da: “¿Caxcajet ane?” Uc'a yuwijob chich cache' Ajnoja.
\v 13 Aj Jesús u ch'i ni waj u yäc'benob, che' chich täcä ni buch'.
\p 
\v 14 Jinda u yuxpetz'ib u ye'i uba aj Jesús bajca an u yajcänt'anob desde jinq'uin cuxpi tan ajchäme.
\s1 Jesús habla con Simón Pedro
\p 
\v 15 Cuanta ac'uxnijob, aj Jesús u yälbi aj Simón Pedro:
\p ―Simón, ane ajlo'et taj Jonás, ¿a yajna'tanon quira más que jindajob?
\p Une u p'ali:
\p ―Cajnoja, a wi chich cache' tä' colet.
\p Aj Jesús u yälbi:
\p ―C'uxnesan cä ch'oc ovejajob, jini machcatac u tz'ombenonjob.
\p 
\v 16 Aj Jesús sutwäni u c'atben tä cha'num:
\p ―Simón, ajlo'et taj Jonás, ¿a yajna'tanon?
\p Une u p'ali:
\p ―Cajnoja, a wi chich cache' tä' colet.
\p Aj Jesús u yälben:
\p ―Cänäntan cä ovejajob.
\p 
\v 17 U c'atben u yuxpetz'ib:
\p ―¿Simón, ajlo'et taj Jonás, a wolon?
\p Aj Pedro triste'i uc'a xi u c'atben u yuxpetz'ib si u yoli. U yälben:
\p ―Cajnoja, ane a wi upete cua' chichca. A wi chich cache' tä' colet.
\p Aj Jesús u yälben:
\p ―C'uxnesan cä ovejajob.
\v 18 Totojtoj cälbenet jinq'uin ch'oc ajlo'et to, ane chich a xoji a buc, y a bixe cachichcada a woli. Pero cuanta noxibétba, a xe a tech'e' a c'äb, otro u xe u xojbenet a buc, y u xe u bisanet bajca mach uxet a wolin xiquet.
\p 
\v 19 Jinda u yäli, uc'a u yälben cache'da u xe tä chämo tuba u yäq'ue' tä chäncan u poder Dios. De ya'i u yälbi täcä:
\p ―Tzäypätinon y chen ca' chich cä chen no'on.
\s1 El discípulo amado
\p 
\v 20 U suti uba aj Pedro u chänen jini ajcänt'an tä' u yajna'tan aj Jesúsba cache' u te tu patob, jini ajni t'ele tu ch'ejpa aj Jesús jinq'uin ya'anob tä c'uxnanba, jini que u yälbi täcä ca'daba: “Cajnoja, ¿caxca une ni u xe u yäq'ue'et tä c'äbäba?”
\v 21 Aj Pedro, jinq'uin u chäni jinda winic, u yälbi aj Jesús ca'da:
\p ―Cajnoja, ¿jindaba, cache'da u xe u chen pasa une?
\p 
\v 22 Aj Jesús u yäli:
\p ―Si co colac ixta sujlecon, ¿cua' u chi t'oc ane? Tzäypätinon ane y chen ca' chich cä chen no'on.
\p 
\v 23 Jin uc'a älqui tan u lotob cache' jini ajcänt'an mach uxin tä chämo. Aj Jesúsba mach u yälbi cache' mach uxin tä chämo, sec' u yälbi ca'da: “Si co colac ixta que sujlecon, ¿cua' u chi t'oc ane?”
\p 
\v 24 No'on une ni ajcänt'anon que cäle' cache'da xi upete ni jindaba, no'on chich cä tz'ibi täcä ni junda. Cuwi chich cache' toj upete lo que cäli.
\p 
\v 25 Q'uen cua'tac u chi aj Jesús täcä, si tz'ibintic tä jun upete cua'tac u chi, cäle' tan cä c'ajalin cache' mach u tawä tu pancab upete ni jun tz'ibinticba. Che' chich ajnic.
