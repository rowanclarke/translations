\id COL
\h إِكُولُوسِييّنْ
\toc1 إِكُولُوسِييّنْ
\toc2 إِكُولُوسِييّنْ
\toc3 كُول.
\mt1 إِكُولُوسِييّنْ
\c 1
\s1 أَسدْجمْ غَارْ ؤُمزْوَارُو ذ ثْژَادْجِيثْ أَكْ-ذ ؤُقَاذِي
\m 
\v 1 بُولُوسْ، رَّاسُولْ ن يَاسُوع لْمَاسِيحْ س ڒْخَاضَارْ ن أَربِّي، ذ ثَاوْمَاثْ ثِيمُوثِييُو. \f ◼ \fr 1:‏1 \ft \bd ’رَّاسُولْ‘\bd* - نِيغْ ’أَمَازَانْ‘.\f*
\v 2 إِ إِنِّي إِدْجَانْ ذِي كُولُوسِّي، أَوْمَاثنْ إِمْقدَّاسنْ ذ يِينِّي يُومْننْ ذِي يَاسُوع لْمَاسِيحْ: ڒهْنَا ذ أَرْضَا أَذْ كِيومْ إِڒِينْ زِي أَربِّي، بَابَاثْنغْ. \x ◘ \xo 1:‏2 \xt رُوم. 1‏:‏7؛ ڭال. 1‏:‏3؛ أَفا. 1‏:‏2؛ 1 بُط. 1‏:‏2. \x*
\b
\m 
\v 3 ڒبْذَا نتّْقَاذَا أَربِّي، بَابَاسْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، ؤُشَا نتّْژَادْجْ خَاومْ. \x ◘ \xo 1:‏3 \xt أَفا. 1‏:‏15؛ فِيل. 1‏:‏3؛ 1 تس. 1‏:‏2؛ 2 تس. 1‏:‏3. \x*
\v 4 خْزَارْ، نسْڒَا خْ لْ-إِيمَانْ نْومْ ذِي يَاسُوع لْمَاسِيحْ ؤُ خْ ثَايْرِي نْومْ إِ مَارَّا إِمْقدَّاسنْ،
\v 5 خْ سِّيبّثْ ن ؤُسِيثمْ إِ ذ أَومْ إِسّْوجْذنْ ذڭْ إِجنْوَانْ، إِ خْ ثِيزَّارمْ ثسْڒَامْ زڭْ ؤُمزْوَارُو س وَاوَاڒْ ن ثِيذتّْ ن ڒخْبَارْ أَصبْحَانْ. \x ◘ \xo 1:‏5 \xt 1 بُط. 1‏:‏4. \x*
\v 6 \add أَوَاڒْ\add*-أَ إِتّْوَابَارّحْ أَومْ ؤُ إِ دُّونشْثْ مَارَّا، ؤُشَا إِڭمَّا ؤُشَا إِتَّاوِي-د ڒْغِيدْجثْ، أَمْ مَامّشْ إِ يڭَّا \add وَاوَاڒْ-أَ\add* عَاوذْ جَارْ أَومْ زڭْ وَاسّْ ؤُمِي ث ثسْڒِيمْ ؤُ ثسّْنمْ أَرْضَا ن أَربِّي ذِي ثِيذتّْ، \x ◘ \xo 1:‏6 \xt مك. 4‏:‏8؛ يُوح. 15‏:‏16. \x*
\v 7 أَمْ مَامّشْ ث ثْڒمْذمْ زِي إِبَافْرَاسْ، أَمْسخَّارْ أَمْعَاشَارْ نّغْ إِعِيزّنْ، ونِّي ذ أَمْسخَّارْ ذ أَمْثِيقِّي ن لْمَاسِيحْ إِ كنِّيوْ. \x ◘ \xo 1:‏7 \xt كُول. 4‏:‏12؛ فلمن. 23. \x*
\v 8 نتَّا إِسَّارْڭبْ أَنغْ-د خْ ثَايْرِي نْومْ ذِي أَرُّوحْ.
\m 
\v 9 س ؤُينِّي، ؤُڒَا ذ نشِّينْ، زڭْ وَاسّْ ؤُمِي نسْڒَا خْ مَانْ أَيَا، وَارْ نسّْبذِّي شَا ثَاژَادْجِيثْ خَاومْ، نتّتَّارْ أَذْ ثْذوْڒمْ ثشُّورمْ س ثُوسّْنَا ن ڒْخَاضَارْ ن أَربِّي، ذِي مَارَّا ثِيغِيثْ ذ ڒفْهَامثْ ن أَرُّوحْ، \x ◘ \xo 1:‏9 \xt ؤُف. 31‏:‏3؛ 35؛13؛ إِشا. 11‏:‏2؛ 1 كُور. 1‏:‏5؛ 12‏:‏8؛ أَفا. 1‏:‏15. \x*
\v 10 حِيمَا أَذْ ثُويُورمْ أَمْ مَامّشْ إِسْذَاهدْجْ، أَذْ ثَارْضَامْ أَربِّي ذِي مَارَّا ڒخْذَايمْ ثِيصبْحَانِينْ، ؤُ حِيمَا أَذْ د-ثَاوْيمْ ڒْغِيدْجثْ ؤُشَا أَذْ ثيْمَامْ ذِي ثُوسّْنَا ن أَربِّي، \f ◼ \fr 1:‏10 \ft \bd ’ثيْمَانْ‘\bd* - نِيغْ ’ثڭْمَامْ‘.\f*  \x ◘ \xo 1:‏10 \xt أَمز. 17‏:‏1؛ يُوح. 15‏:‏16؛ 1 كُور. 7‏:‏20؛ أَفا. 4‏:‏1؛ فِيل. 1‏:‏27؛ 1 تس. 2‏:‏12. \x*
\v 11 أَذْ ثتّْوَاسّْجهْذمْ س مَارَّا جّهْذْ عْلَاحْسَابْ ڒمْغَارثْ ن ؤُعُودْجِي نّسْ، س مَارَّا صّْبَارْ ذ تَّاسِيعْ ن ڒْخَاضَارْ ذ ڒفْرَاحثْ.
\v 12 قَاذَامْ أَربِّي، بَابَاثْنغْ، ونِّي ذ أَنغْ إِسّْوجْذنْ حِيمَا أَذْ نسّْذَاهدْجْ أَذْ نْشَارْشْ ذِي ڒْوَارْثْ ن إِمْقدَّاسنْ ذِي ثْفَاوْثْ.
\v 13 نتَّا إِسّنْجمْ أَنغْ زِي صُّولْطَا ن ثَادْجسْثْ ؤُ إِسّْمُوطِّييْ أَنغْ غَارْ ثْڭلْذِيثْ ن مِّيسْ نّسْ إِعِيزّنْ، \x ◘ \xo 1:‏13 \xt مت. 3‏:‏17؛ 17‏:‏5؛ أَفا. 2‏:‏4؛ 1 تس. 2‏:‏12؛ 2 بُط. 1‏:‏17. \x*
\v 14 ونِّي ذَايسْ غَارْنغْ أَسنْجمْ ذ وغْفَارْ ن دّْنُوبْ. \x ◘ \xo 1:‏14 \xt ڒخ. 20‏:‏28؛ أَفا. 1‏:‏7؛ عبر. 9‏:‏14؛ 1 بُط. 1‏:‏19. \x*
\b
\s1 لْمَاسِيحْ ذ صِّيفثْ ن أَربِّي إِ وَارْ نژْرِي
\m 
\v 15 وَانِيثَا ذ صِّيفثْ ن أَربِّي إِ وَارْ نتّْوِيڒِي شَا، أَمنْزُو خْ مَارَّا مِينْ د-إِتّْوَاخڒْقنْ، \f ◼ \fr 1:‏15 \ft \bd ’وَانِيثَا‘\bd* - إِخْسْ أَذْ يِينِي ’مِّيسْ‘، خْزَارْ أَيثْ 13.\f*  \x ◘ \xo 1:‏15 \xt 2 كُور. 4‏:‏4؛ فِيل. 2‏:‏6؛ عبر. 1‏:‏3؛ أَسَا. 3‏:‏14. \x*
\v 16 زَّايسْ د-إِتّْوَاخْڒقْ مَارَّا مِينْ إِدْجَانْ ذڭْ إِجنْوَانْ ذ مِينْ إِدْجَانْ ذِي ثمُّورْثْ، مِينْ نتّْوَاڒَا ذ مِينْ وَارْ نتّْوِيڒِي شَا: ڒكْرَاسِي ن إِجدْجِيذنْ نِيغْ ثِيصدْجَاضِينْ نِيغْ ڒحْكَامَاثْ ؤُڒَا ذ صُّولَاطَاثْ، مَارَّا مِينْ إِدْجَانْ أَقَا إِتّْوَاخْڒقْ-د س ؤُفُوسْ نّسْ ؤُ زَّايسْ نتَّا. \x ◘ \xo 1:‏16 \xt أَمز. 1‏:‏3؛ إِزهد. 33‏:‏6؛ يُوح. 1‏:‏3؛ أَفا. 3‏:‏9؛ عبر. 1‏:‏2. \x*
\v 17 نتَّا ثُوغَا-ث قْبڒْ مَارَّا مِينْ إِدْجَانْ، ؤُشَا مَارَّا مِينْ إِدْجَانْ أَقَا-ث زَّايسْ.
\v 18 نتَّا ذ أَزدْجِيفْ ن أَرِّيمثْ، ثنِّي إِدْجَانْ ذ ثَامسْمُونْثْ. نتَّا ذ أَزدْجِيفْ ذ مِّيسْ أَمنْزُو إِ د-إِتّْوَاخڒْقنْ زِي ثَادَّارْثْ ن إِمتِّيننْ، حِيمَا أَذْ يِيڒِي ذ أَمزْوَارْ ذِي كُوڒْشِي. \x ◘ \xo 1:‏18 \xt 1 كُور. 15‏:‏20؛ أَفا. 1‏:‏22؛ 4‏:‏15؛ 5‏:‏23؛ أَسَا. 1‏:‏5. \x*
\v 19 مِينْزِي ثُوسَا أَسْ-د إِ ڒْخَاضَارْ إِ مَارَّا أَعمَّارْ مَاحنْذْ أَذْ إِزْذغْ ذَايسْ، \f ◼ \fr 1:‏19 \ft \bd ’مَارَّا أَعمَّارْ‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي، أَقَا ثَابَابَاثْ ذ ثَامّمِيثْ ذ أَرُّوحْ إِقدّْسنْ زدّْغنْ ذِي أَرِّيمثْ ن لْمَاسِيحْ.\f*  \x ◘ \xo 1:‏19 \xt يُوح. 1‏:‏14، 16؛ كُول. 2‏:‏9. \x*
\v 20 \add مَاحنْذْ\add* أَذْ زَّايسْ إِسّصْڒحْ مَارَّا مِينْ إِدْجَانْ أَكْ-ذ يِيخفْ نّسْ، ؤُ \add مَاحنْذْ\add* أَذْ إِڭّْ ڒهْنَا س إِذَامّنْ ن صَّالِيبْ نّسْ، أَمْ إِ يِينِّي إِدْجَانْ ذِي ثمُّورْثْ أَمْ إِ يِينِّي إِدْجَانْ ذڭْ إِجنْوَانْ. \x ◘ \xo 1:‏20 \xt إِزهد. 85‏:‏11؛ إِشا. 9‏:‏6؛ يُوح. 16‏:‏33؛ ڒخ. 10‏:‏36؛ رُوم. 5‏:‏1؛ 2 كُور. 5‏:‏18؛ أَفا. 2‏:‏14؛ عبر. 9‏:‏27؛ 1 يُوح. 4‏:‏10. \x*
\m 
\v 21 ؤُڒَا إِ كنِّيوْ - إِنِّي ثُوغَا قْبڒْ ذ إِبَارَّانِييّنْ ذ ڒْعذْيَانْ ذڭْ إِخَارِّيصنْ نْومْ زِي سِّيبّثْ ن ڒخْذَايمْ نْومْ ثِيعفَّانِينْ - إِوْشَا ڒخُّو ڒهْنَا
\v 22 س أَرِّيمثْ ن ويْسُومْ نّسْ ؤُ ن ڒْموْثْ نّسْ، حِيمَا أَذْ كنِّيوْ إِسّْبدّْ ذ إِمْقدَّاسنْ قِيبَاتْشْ نّسْ، بْڒَا مَا أَذْ ذَايْومْ إِتّْوَافْ ڒَا ذ إِجّْ نْ ڒخْمجْ ؤُڒَا ذ إِجّْ ن ڒْعِيبْ، \x ◘ \xo 1:‏22 \xt لك. 1‏:‏75؛ أَفا. 1‏:‏4؛ 5‏:‏27؛ 2 تِيم. 1‏:‏9؛ ثِيث. 2‏:‏12. \x*
\v 23 مَاڒَا ثقِّيممْ ثُويُورمْ ذِي لْ-إِيمَانْ نْومْ، أَمْ ذْسَاسْ نْومْ إِقِّيمْ إِمْثنْ، وَارْ ثْسمّْحمْ شَا ذڭْ ؤُسِيثمْ ن لْ-إِنْجِيلْ إِ ثسْڒِيمْ، ونِّي زِي إِتّْوَابَارَّاحْ غَارْ مَارَّا مِينْ د-إِتّْوَاخڒْقنْ نِّي إِدْجَانْ سَاذُو ؤُجنَّا، ونِّي زِي ذوْڒغْ نشّْ، بُولُوسْ، ذ أَمْسخَّارْ. \x ◘ \xo 1:‏23 \xt يُوح. 15‏:‏6. \x*
\b
\s1 ڒْخذْمثْ ن ثْسخَّارْثْ ن بُولُوسْ إِ ثْمسْمُونْثْ ن يَاسُوع لْمَاسِيحْ
\m 
\v 24 أَقَا أَيِي فَارْحغْ أَمْ كسِّيغْ ثَامَارَا خَاومْ ؤُ تّْكمّْڒغْ ذِي أَرِّيمثْ إِنُو مِينْ إِقِّيمنْ زِي ڒمْحَايمْ ن لْمَاسِيحْ ذِي طّْوعْ ن أَرِّيمثْ نّسْ ثنِّي ذ ثَامسْمُونْثْ، \x ◘ \xo 1:‏24 \xt رُوم. 12‏:‏5؛ 1 كُور. 12‏:‏27؛ 2 كُور. 7‏:‏4؛ أَفا. 3‏:‏13؛ 4‏:‏12؛ 5‏:‏23؛ فِيل. 2‏:‏17؛ 2 تِيم. 2‏:‏10. \x*
\v 25 إِ زِي ذوْڒغْ ذ أَمْسخَّارْ عْلَاحْسَابْ أَوكّڒْ إِ ذ أَيِي إِمّوْشنْ خَاومْ زِي أَربِّي، حِيمَا أَذْ سِّيوْضغْ \add ثَابَارّحْثْ ن\add* وَاوَاڒْ ن أَربِّي غَارْ ڒكْمَارثْ، \x ◘ \xo 1:‏25 \xt رُوم. 16‏:‏25؛ أَفا. 1‏:‏9؛ 3‏:‏9؛ 2 تِيم. 1‏:‏10؛ ثِيث. 1‏:‏3؛ 1 بُط. 1‏:‏20. \x*
\v 26 سِّيرّْ إِ ثُوغَا إِنُّوفَارنْ ذِي زّْمَانَاثْ ذ ڒْجِيڒَاثْ \add ن زِيشْ\add*، مَاشَا إِتّْوَاسَّارْڭبْ ڒخُّو إِ إِمْقدَّاسنْ نّسْ، \x ◘ \xo 1:‏26 \xt مت. 13‏:‏11. \x*
\v 27 إِنِّي ؤُمِي إِخْسْ أَربِّي أَذْ أَسنْ إِسّْشنْ إِڭڒْوَانْ ن ؤُعُودْجِي ن سِّيرّْ-أَ جَارْ ڒڭْنُوسْ، ونِّي إِدْجَانْ ذ لْمَاسِيحْ ذَايْومْ، أَسِيثمْ ن ؤُعُودْجِي نّغْ. \x ◘ \xo 1:‏27 \xt 2 كُور. 2‏:‏14؛ 1 تِيم. 1‏:‏1. \x*
\v 28 أَقَا نتّْبَارّحْ زَّايسْ، ؤُ زَّايسْ نتَّا نسّڒْمَاذْ ؤُ نْعدْجمْ إِ كُوڒْ بْنَاذمْ س مَارَّا ثِيغِيثْ، حِيمَا أَذْ نسّْبدّْ كُوڒْ بْنَاذمْ نِيشَانْ قِيبَاتْشْ إِ يَاسُوع لْمَاسِيحْ.
\v 29 إِ مَانْ أَيَا ؤُمِي جهّْذغْ ؤُ تّْمنْغِيغْ س ؤُفُوسْ ن جّهْذْ إِ ذ أَيِي إِمّوْشنْ.
\b
\b
\c 2
\m 
\v 1 مِينْزِي خْسغْ أَذْ ثسّْنمْ مشْحَاڒْ ذ أَمقّْرَانْ أَمنْغِي إِ تّڭّغْ خَاومْ ؤُ خْ يِينِّي ذِي لَايُوذِيكِييَا ؤُ خْ مَارَّا إِنِّي وَارْ ذ أَيِي ژْرِينْ شَا س أَرِّيمثْ ذ وُوذمْ إِنُو،
\v 2 حِيمَا أَذْ يَاذفْ ؤُفوّجْ غَارْ وُوڒَاونْ نْسنْ ؤُ حِيمَا أَذْ أَوْضنْ نِيثْنِي س ثَايْرِي غَارْ مَارَّا وَاڭْڒَا ن ڒَامَانْ، ؤُ غَارْ ڒفْهَامثْ ن ثُوسّْنَا ن سِّيرّْ ن أَربِّي، بَابَاثْنغْ، ؤُ ن لْمَاسِيحْ \x ◘ \xo 2:‏2 \xt إِشا. 53‏:‏11؛ إِرْم. 9‏:‏22؛ يُوح. 17‏:‏3؛ فِيل. 3‏:‏8. \x*
\v 3 نِّي ذِي نُّوفَّارنْ مَارَّا ڒكْنُوزْ ن ثِيغِيثْ ذ ثُوسّْنَا. \x ◘ \xo 2:‏3 \xt 1 كُور. 1‏:‏24. \x*
\b
\s1 إِعْڒَامنْ غَارْ ڒْمُومِينْ خْ ثْغُورِي إِسّْخَارِّيقنْ
\m 
\v 4 مَانْ أَيَا قَّارغْ ث، حِيمَا ؤُڒَا ذ إِجّْ وَارْ كنِّيوْ إِغكّْوِي شَا س وَاوَاڒنْ إِزوّْقنْ. \x ◘ \xo 2:‏4 \xt أَفا. 5‏:‏6؛ كُول. 2‏:‏18. \x*
\v 5 مَاغَارْ وَاخَّا أَقَا أَيِي غَابغْ زِي جِّيهثْ ن أَرِّيمثْ، نِيشَانْ أَقَا أَيِي أَكِيذْومْ زِي جِّيهثْ ن أَرُّوحْ ؤُشَا فَارّْحغْ أَمْ تّْوَاڒِيغْ أَستّفْ ذ لْ-إِيمَانْ نْومْ نِيشَانْ ذِي لْمَاسِيحْ. \x ◘ \xo 2:‏5 \xt 1 كُور. 5‏:‏3؛ 14‏:‏40. \x*
\m 
\v 6 أَمْ مَامّشْ ثْقبْڒمْ يَاسُوع لْمَاسِيحْ، سِيذِيثْنغْ، ؤُيُورمْ ذَايسْ،
\v 7 أَمْ ثوْثِيمْ إِژوْرَانْ ؤُ ثتّْوَابْنَامْ ذَايسْ ؤُشَا ثتّْوَاضْممْ ذِي لْ-إِيمَانْ إِ ذِي ثتّْوَاسّڒْمَاذمْ، أَمْ ثتّْفيّْضمْ س ؤُقَاذِي. \x ◘ \xo 2:‏7 \xt 1 كُور. 1‏:‏5؛ أَفا. 3‏:‏17. \x*
\v 8 حْضَامْ ؤُڒَا ذ إِجّْ وَارْ كنِّيوْ إِغكّْوِي شَا ؤُمِي إِتّخّْسْ ثِيغِيثْ \add ن يِيخفْ نّسْ\add* نِيغْ أَشْمَاثْ إِخْوَانْ عْلَاحْسَابْ ثَاغُورِي ن إِوْذَانْ ؤُ عْلَاحْسَابْ لْفَارَايِيضْ ن دُّونشْثْ، وَارْ إِدْجِي عْلَاحْسَابْ لْمَاسِيحْ. \x ◘ \xo 2:‏8 \xt رُوم. 16‏:‏17؛ عبر. 13‏:‏9. \x*
\v 9 مِينْزِي ذَايسْ إِزدّغْ قَاعْ أَعمَّارْ ن أَربِّي ذِي صِّيفثْ ن أَرِّيمثْ.
\v 10 أَقَا ذَايسْ ثدْجَامْ ثْكمّْڒمْ عَاوذْ، مَاغَارْ نتَّا ذ أَزدْجِيفْ خْ قَاعْ ڒحْكَامَاثْ ذ صُّولَاطَاثْ. \x ◘ \xo 2:‏10 \xt يُوح. 1‏:‏16. \x*
\m 
\v 11 أَقَا ثتّْوَاخثْنمْ ذَايسْ عَاوذْ س يِيجّْ ن وخْثَانْ، وَارْ إِدْجِي س إِفَاسّنْ \add ن إِوْذَانْ\add*، مَاشَا ؤُمِي إِتّْوَاكّسْ زَّايْومْ ويْسُومْ \add ن أَرِّيمثْ\add* ن دّْنُوبْ س وخْثَانْ ن لْمَاسِيحْ. \x ◘ \xo 2:‏11 \xt أَعَوذ. 10‏:‏16؛ إِرْم. 4‏:‏4؛ رُوم. 2‏:‏29؛ فِيل. 3‏:‏3. \x*
\v 12 كنِّيوْ ثتّْوَانضْڒمْ أَكِيذسْ ذڭْ ؤُسغْضصْ، ؤُ زَّايسْ ثتّْوَاسّْنكَّارمْ عَاوذْ أَكِيذسْ، مِينْزِي ثُومْنمْ ذِي جّهْذْ ن أَربِّي، ونِّي ث-إِ-د-إِسّْنكَّارنْ زِي ثَادَّارْثْ ن إِمتِّيننْ. \x ◘ \xo 2:‏12 \xt رُوم. 6‏:‏4؛ ڭال. 3‏:‏27؛ أَفا. 1‏:‏19؛ 3‏:‏7. \x*
\v 13 أَقَا نتَّا يَارَّا كنِّيوْ، إِنِّي ثُوغَا ذ إِمتِّيننْ س دّْنُوبْ نْومْ ؤُ س بْڒَا أَخْثَانْ ن ويْسُومْ نْومْ، غَارْ ثُوذَارْثْ أَكِيذسْ، ؤُشَا إِغْفَارْ أَنغْ مَارَّا دّْنُوبْ نّغْ. \x ◘ \xo 2:‏13 \xt أَفا. 2‏:‏1. \x*
\v 14 أَقَا إِمْسحْ ثَابْرَاثْ نّغْ ن ثنْفُوتْشْ، ثنِّي ذ أَنغْ إِتّهْمنْ أَكْ-ذ مَارَّا ثِيوصَّا نّسْ، أَقَا إِكْسِي ت زِي ڒْوسْطْ أَمْ ت إِسمَّارْ خْ صَّالِيبْ نّسْ.
\v 15 أَمْ إِسَّارْسْ أَرِّيمثْ نّسْ، أَقَا إِسّْعَارَّا ڒحْكَامَاثْ ذ صُّولَاطَاثْ بْطَايْطَايْ ؤُشَا يَارَّا إِ-ثنْثْ أَذْ سضْحَانْثْ س طّْبِيعثْ ن مُومُّو ن يِيخفْ نّسْ. \x ◘ \xo 2:‏15 \xt أَمز. 3‏:‏15؛ مت. 12‏:‏29؛ لك. 11‏:‏22؛ يُوح. 12‏:‏31؛ 16‏:‏11. \x*
\b
\m 
\v 16 وَارْ ثجِّيمْ أَذْ كنِّيوْ إِسّهْوڒْ ؤُڒَا ذ إِجّْ، نِيغْ ذِي مَاشَّا ڒَا ذِي ثِيسِّيثْ، نِيغْ ذِي ڒْفَارْزْ ذڭْ \add وُوسَّانْ ن\add* ڒعْيُوذَاثْ ڒَا ذڭْ \add وَاسّْ ن\add* ؤُيُورْ ن جْذِيذْ ؤُڒَا ذڭْ \add وُوسَّانْ ن\add* سّبْثْ، \x ◘ \xo 2:‏16 \xt لَاوِي 11‏:‏2؛ 23‏:‏2؛ رُوم. 14‏:‏2؛ ڭال. 4‏:‏10. \x*
\v 17 مَاغَارْ ثِينَا ذ ثِيڒِيوِينْ ن مِينْ إِ د غَا يَاسنْ، مَاشَا لْمَاسِيحْ أَقَا-ث ذ أَرِّيمثْ \add إِ ذ أَسنْثْ د-إِتّْڒِيقنْ\add*. \x ◘ \xo 2:‏17 \xt عبر. 8‏:‏5 10‏:‏1. \x*
\v 18 وَارْ تّجِّيمْ حذْ أَذْ يَارْزُو مَاحنْذْ أَذْ خَاومْ يڭّْ بزّزْ مَاحنْذْ أَذْ ثسّْوَاضْعمْ إِخفْ نْومْ إِ وعْبَاذْ ن لْمَالَاكَاثْ، ؤُمِي نتَّا إِسّْنِيعْمِيڒْ أَقَا غَارسْ ڒْبَاڒْ إِمَّارْسْ، \add مَاشَا س ثِيذتّْ\add* يَارزُّو س زَّاعْمثْ نّسْ أَذْ د-يَاذفْ ذِي مِينْ وَارْ إِژْرِي. أَقَا نتَّا إِخْوَا ذِي ثُوفّثْ نّسْ س نّيّثْ نّسْ ن ويْسُومْ ن بْنَاذمْ، \x ◘ \xo 2:‏18 \xt إِرْم. 29‏:‏8؛ مت. 24‏:‏4؛ أَفا. 5‏:‏6؛ 2 تس. 2‏:‏3؛ 1 يُوح. 4‏:‏1. \x*
\v 19 أَمْ وَارْ إِتّْشبَّارْ ذڭْ ؤُزدْجِيفْ إِ زِي ثْيمَّا قَاعْ أَرِّيمثْ س ڒمْغَارثْ إِ ذ أَسْ إِتِّيشْ أَربِّي، أَمْ ثتّْوَابْنَا ؤُ ثتّْوَاسنّذْ س ڒمْفَاصڒْ ذ إِغزْذِيسنْ \add نّسْ\add*.
\m 
\v 20 مَاغَارْ مَاڒَا ثمُّوثمْ أَكْ-ذ لْمَاسِيحْ إِ لْفَارَايِيضْ ن دُّونشْثْ، مَايمِّي ثتّْوَاحَاكَاممْ أَخْمِي ثدَّارمْ \add عَاذْ\add* ذِي دُّونشْثْ؟ \x ◘ \xo 2:‏20 \xt ڭال. 4‏:‏9. \x*
\v 21 ’وَارْ ثْحَاذَا!‘، ’وَارْ ثْقَاسَا!‘، ؤُ ’وَارْ تّطّفْ!‘،
\v 22 أَقَا أَثنْثْ ذ ثِينَامِيثِينْ أَذْ ودَّارنْثْ، أَقَا أَثنْثْ ذ ثِيوصَّا ذ ثْغُورِي ن إِوْذَانْ. \x ◘ \xo 2:‏22 \xt إِشا. 29‏:‏13؛ مت. 15‏:‏9؛ ثِيث. 1‏:‏14. \x*
\v 23 أَقَا-ثنْثْ تّْبَاننْثْ أَخْمِي غَارْسنْ إِشْثْ ن ثْغُورِي ثَامِيغِيسْثْ، س وُوذمْ ن ؤُوَاضعْ ذ نّيّثْ ثَاذِييَانشْثْ، نْهْڒَا أَشطَّارْ خْ أَرِّيمثْ، مَاشَا وَارْ إِدْجِي إِ مِينْ إِشنّْعنْ، مَاشَا إِ ثْيَاوَانْثْ نّشْوَاثْ ن ويْسُومْ \add ن يِيخفْ نْسنْ\add*. \x ◘ \xo 2:‏23 \xt 1 تِيم. 4‏:‏8؛ 5‏:‏23. \x*
\b
\b
\c 3
\s1 ثُوذَارْثْ نّغْ ثْنُوفَّارْ أَكْ-ذ لْمَاسِيحْ ذِي أَربِّي
\m 
\v 1 مَاڒَا ثتّْوَاسّْنكَّارمْ-د أَكْ-ذ لْمَاسِيحْ، خنِّي أَرْزُومْ مِينْ إِدْجَانْ سنّجْ، مَانِي إِقِّيمْ لْمَاسِيحْ خْ ؤُفُوسِي ن أَربِّي. \x ◘ \xo 3:‏1 \xt أَفا. 1‏:‏20. \x*
\v 2 عقْڒمْ مِينْ إِدْجَانْ سنّجْ، وَارْ إِدْجِي مِينْ إِدْجَانْ ذِي ثمُّورْثْ،
\v 3 مِينْزِي كنِّيوْ أَقَا ثمُّوثمْ ؤُشَا ثُوذَارْثْ نْومْ ثنُّوفَّارْ أَكْ-ذ لْمَاسِيحْ ذِي أَربِّي. \x ◘ \xo 3:‏3 \xt رُوم. 6‏:‏2؛ 8‏:‏24؛ 2 كُور. 5‏:‏7. \x*
\v 4 خْمِي د غَا إِضْهَارْ لْمَاسِيحْ، ونِّي إِدْجَانْ ذ ثُوذَارْثْ نّغْ، ڒخْذنِّي ؤُڒَا ذ كنِّيوْ أَذْ كِيذسْ د-ثضْهَارمْ ذڭْ ؤُعُودْجِي. \x ◘ \xo 3:‏4 \xt فِيل. 3‏:‏21؛ 1 يُوح. 3‏:‏2. \x*
\b
\m 
\v 5 س ؤُينِّي نْغمْ إِغزْذِيسنْ \add ن أَرِّيمثْ\add* نْومْ إِنِّي خْ ثمُّورْثْ: فَارْقْ-شّْغڒْ، ڒخْمجْ، أَشَاهِي، نّشْوَاثْ ثِيعفَّانِينْ ذ طّْمعْ، ونِّي ذ أَعْبَاذْ إِ لْ-أَصْنَامْ، \x ◘ \xo 3:‏5 \xt رُوم. 7‏:‏5، 23؛ أَفا. 4‏:‏22؛ 5‏:‏3، 5؛ 1 تس. 4‏:‏5. \x*
\v 6 س مِينْزِي أَذْ د-يَاسْ وغْضَابْ ن أَربِّي خْ أَيْثْ ن ڒْمُوعْصِييّثْ. \x ◘ \xo 3:‏6 \xt 1 كُور. 6‏:‏10؛ ڭال. 5‏:‏19؛ أَفا. 5‏:‏5؛ أَسَا. 22‏:‏15. \x*
\v 7 ؤُڒَا ذ كنِّيوْ ثُوغَا ثڭُّورمْ أَمُّو زِيشْ، ؤُمِي كنِّيوْ ثُوغَا ثدَّارمْ \add عَاذْ\add* ذِي ثْمسْڒَايِينْ نِّي. \x ◘ \xo 3:‏7 \xt 1 كُور. 6‏:‏11؛ أَفا. 2‏:‏1؛ ثِيث. 3‏:‏3. \x*
\v 8 مَاشَا ڒخُّو، سَارْسمْ مَانْ أَيَا \add مَارَّا\add* خْ ؤُغزْذِيسْ: أَغْضَابْ ذ ثفْقحْثْ ذ ثُوعفّْنَا ذ ؤُشقّفْ ذ ڒْهَارْذْ إِخْمجْ. \x ◘ \xo 3:‏8 \xt أَفا. 4‏:‏22؛ عبر. 12‏:‏1؛ يَاع. 1‏:‏21؛ 1 بُط. 2‏:‏1. \x*
\v 9 وَارْ سْخَارِّيقمْ شَا خْ وَايَاوْيَا، مَاشَا سَارْسمْ غَارْ ؤُغزْذِيسْ بْنَاذمْ أَقْذِيمْ أَكْ-ذ مَارَّا إِبْرِيذنْ نّسْ، \x ◘ \xo 3:‏9 \xt أَفا. 4‏:‏25. \x*
\v 10 ؤُ ثْيَارّْضمْ \add بْنَاذمْ\add* ن جْذِيذْ، ونِّي إِدّكّْوَاڒنْ جْذِيذْ س ثُوسّْنَا \add زَّايسْ نتَّا\add*، غَارْ صِّيفثْ ن ونِّي إِ-ث-إِ-د-إِخڒْقنْ. \x ◘ \xo 3:‏10 \xt أَمز. 1‏:‏26؛ 5‏:‏1؛ 9‏:‏6؛ رُوم. 6‏:‏4؛ 1 كُور. 11‏:‏7. \x*
\v 11 ذَايسْ وَارْ إِدْجِي وُوذَايْ ڒَا ذ أَرَامِي، ڒَا ذ أَخْثَانْ، ڒَا بْڒَا أَخْثَانْ، ڒَا ذ أَيُونَانِييْ، ڒَا ڒْبَارَّانِي، ڒَا ذ إِسْمغْ ؤُڒَا ذ حُورّْ، مَاشَا لْمَاسِيحْ ذ كُوڒْشِي ؤُ ذِي كُوڒْ إِجّنْ. \x ◘ \xo 3:‏11 \xt 1 كُور. 7‏:‏21، 22؛ 12‏:‏13؛ ڭال. 3‏:‏28؛ 5‏:‏6؛ 6‏:‏15. \x*
\b
\m 
\v 12 خْ ؤُينِّي، كنِّيوْ، \add أَ\add* إِمْقدَّاسنْ ذ إِمْعِيزّنْ إِنِّي إِتّْوَافَارْزنْ زِي أَربِّي، أَرْضمْ س أَرّحْمثْ ذ ڒحْنُونشْثْ ذ ڒضْرَافثْ ذ ؤُوَاضعْ ن أَرُّوحْ ذ ثمْهِينْثْ ذ تَّاسِيعْ ن ڒْخَاضَارْ. \x ◘ \xo 3:‏12 \xt أَفا. 4‏:‏32؛ 6‏:‏11؛ 1 تس. 1‏:‏4. \x*
\v 13 قبْڒمْ ؤُ سَامْحمْ إِ وَايَاوْيَا. مَاڒَا شَا ن يِيجّنْ غَارسْ أَشثْشِي خْ ونِّي ذ أَسْ يُوذْسنْ، غْفَارمْ كنِّيوْ إِجّْ إِ ونّغْنِي، أَمْ مَامّشْ إِ ذ أَومْ إِغْفَارْ لْمَاسِيحْ. \x ◘ \xo 3:‏13 \xt مت. 6‏:‏14؛ مك. 11‏:‏25؛ أَفا. 4‏:‏32. \x*
\v 14 ؤُشَا أَكْ-ذ مَارَّا أَيَا، أَرْنِيمْ ثَايْرِي ثنِّي ذ ثَاخَاذنْثْ ن ڒكْمَاڒثْ. \x ◘ \xo 3:‏14 \xt يُوح. 13‏:‏34؛ 15‏:‏12؛ أَفا. 4‏:‏3؛ 5‏:‏2؛ كُول. 2‏:‏2؛ 1 تس. 4‏:‏9؛ 1 يُوح. 3‏:‏23؛ 4‏:‏21؛ 2 يُوح. 1‏:‏6.\x*
\m 
\v 15 \add خنِّي\add* أَذْ إِحْكمْ ڒهْنَا ن لْمَاسِيحْ ذڭْ وُوڒَاونْ نْومْ، \add ڒهْنَا\add* نِّي غَارْ ثتّْوَاڒَاغَامْ ذڭْ إِشْثْ ن أَرِّيمثْ، ؤُشَا قَاذَامْ إِ لْمَاسِيحْ.
\v 16 جّمْ أَوَاڒْ نّسْ أَذْ ذَايْومْ إِزْذغْ س مَارَّا ثِيغِيثْ. سْڒمْذمْ، سجّْعمْ إِجّْ ونّغْنِي س ؤُغنّجْ نْ إِزهِّيذنْ ذ ثسْبِيحْ ذ إِزْڒَانْ ن أَرُّوحْ، ؤُغنّْجمْ إِ أَربِّي س وُوڒَاونْ نْومْ شُّورنْ س أَرْضَا.
\v 17 مَارَّا مِينْ ثتّڭّمْ س وَاوَاڒْ نِيغْ س ثْمڭَّا، ڭّمْ ث س يِيسمْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ ؤُ شكَّارمْ زَّايسْ أَربِّي، بَابَاثْنغْ. \x ◘ \xo 3:‏17 \xt أَفا. 5‏:‏20؛ 1 تس. 5‏:‏18. \x*
\b
\m 
\v 18 أَ ثِيمْغَارِينْ، ذوْڒنْثْ سَاذُو إِرْيَازنْ نْكنْثْ أَمْ مَامّشْ د-إِتَّاسْ أَكْ-ذ لْمَاسِيحْ. \x ◘ \xo 3:‏18 \xt أَمز. 3‏:‏16؛ 1 كُور. 14‏:‏34؛ أَفا. 5‏:‏22؛ ثِيث. 2‏:‏5؛ 1 بُط. 3‏:‏1. \x*
\m 
\v 19 \add أَ\add* إِرْيَازنْ، خْسمْ ثِيمْغَارِينْ نْومْ، وَارْ تّْقسْحمْ ذَايْسنْثْ س ثَارْزُوڭِي. \x ◘ \xo 3:‏19 \xt أَفا. 5‏:‏25. \x*
\m 
\v 20 \add أَ\add* إِحنْجِيرنْ، طَاعمْ إِ لْوَالِيذِينْ نْومْ ذِي مَارَّا، مِينْزِي مَانْ أَيَا يَارطَّا إِ سِيذِيثْنغْ. \x ◘ \xo 3:‏20 \xt أَفا. 6‏:‏1. \x*
\m 
\v 21 \add أَ\add* لْوَالِيذِينْ، وَارْ ذَارَّاشمْ شَا إِحنْجِيرنْ نْومْ، حِيمَا وَارْ ذ أَسنْ ثتّْرَاحْ ثرْيَاسْثْ.
\m 
\v 22 \add أَ\add* إِمْسخَّارنْ، طَاعمْ إِ يِينِّي إِدْجَانْ ذ أَيْثْبَابْ نْومْ ذِي ثمُّورْثْ ذِي مَارَّا، وَارْ تّْسخَّارمْ شَا إِ ثِيطَّاوِينْ ن إِوْذَانْ أَمْ يِينِّي إِخْسنْ أَذْ أَرْضَانْ إِوْذَانْ \add وَاهَا\add*، مَاشَا \add سخَّارمْ\add* س ڒصْفَايثْ ن وُوڒْ ؤُ زِي ثِيڭّْوُوذِي ن سِيذِي. \x ◘ \xo 3:‏22 \xt أَفا. 6‏:‏5؛ 1 تِيم. 6‏:‏1؛ ثِيث. 2‏:‏9؛ 1 بُط. 2‏:‏18. \x*
\v 23 قَاعْ مِينْ غَا ثڭّمْ، ڭّمْ ث س مَارَّا ڒعْمَارْ نْومْ، \add ڭّمْ ث\add* أَخْمِي إِ سِيذِيثْنغْ، وَارْ إِدْجِي إِ إِوْذَانْ.
\v 24 سْنمْ أَقَا أَذْ ثكْسِيمْ ڒخْڒَاصْ زِي سِيذِيثْنغْ ذِي ڒْوَارْثْ، مَاغَارْ ثتّْسخَّارمْ إِ سِيذِي، لْمَاسِيحْ.
\v 25 مِينْزِي ونِّي إِتّڭّنْ ڒْغشّْ، أَذْ إِتّْوَاخْڒفْ عْلَاحْسَابْ ڒْغشّْ إِ يڭَّا، مِينْزِي وَارْ ذِينْ إِدْجِي ڒْفَارْزْ ن بْنَاذمْ.
\b
\b
\c 4
\s1 ثَاژَادْجِيثْ ذ ثْبَارّحْثْ ن وَاوَاڒْ ن أَربِّي
\m 
\v 1 كنِّيوْ، \add أَ\add* أَيْثْبَابْ، ڭّمْ س ؤُوقَّارْ ذ ثْسڭْذَا أَكْ-ذ إِمْسخَّارنْ نْومْ. سْنمْ، بلِّي كنِّيوْ غَارْومْ عَاوذْ سِيذِي ذڭْ ؤُجنَّا. \x ◘ \xo 4:‏1 \xt أَفا. 6‏:‏9. \x*
\m 
\v 2 صْبَارمْ ذِي ثْژَادْجِيثْ، حْضَامْ ذَايسْ ؤُ وْشمْ أَقَاذِي \add إِ أَربِّي\add*. \x ◘ \xo 4:‏2 \xt لك. 18‏:‏1؛ رُوم. 12‏:‏12؛ أَفا. 6‏:‏18؛ 1 تس. 5‏:‏17. \x*
\v 3 ژَتدْجمْ عَاوذْ إِ نشِّينْ، حِيمَا أَربِّي أَذْ أَنغْ يَارْزمْ ثَاوَّارْثْ ن وَاوَاڒْ، حِيمَا أَذْ نسِّيوڒْ خْ سِّيرّْ ن لْمَاسِيحْ، ونِّي ؤُمِي دْجِيغْ عَاوذْ \add ذ أَمحْبُوسْ\add* ذِي سّْنَاسڒْ، \x ◘ \xo 4:‏3 \xt أَفا. 6‏:‏19؛ 2 تس. 3‏:‏1. \x*
\v 4 حِيمَا أَذْ ث سَّارڭْبغْ ؤُشَا أَذْ زَّايسْ سِّيوْڒغْ نِيشَانْ أَمْ مَامّشْ إِ خَافِي إِشُووَّارْ.
\m 
\v 5 ؤُيُورمْ ذِي ثِيغِيثْ أَكْ-ذ يِينِّي ن بَارَّا، أَربْحمْ ڒْوقْثْ إِ يدْجَانْ. \x ◘ \xo 4:‏5 \xt أَفا. 5‏:‏15، 16. \x*
\v 6 أَذْ يِيڒِي وَاوَاڒْ نْومْ ڒبْذَا س ڒْخَاضَارْ، مدْجْحمْ ث س ثْمدْجَاحْثْ، ؤُ سّْنمْ مِينْ زِي غَا د-ثَارّمْ نِيشَانْ خْ كُوڒْ إِجّنْ. \x ◘ \xo 4:‏6 \xt مك. 9‏:‏50. \x*
\b
\s1 أَوَاڒْ غَارْ ؤُنڭَّارُو ذ ؤُسدْجمْ
\m 
\v 7 ثِيشِيكُوسْ، ؤُمَا إِعِيزّنْ ذ ؤُمْسخَّارْ أَمْثِيقِّي، ونِّي ذ أَمْسخَّارْ أَمْعَاشَارْ نّغْ ذِي سِيذِي، أَذْ كنِّيوْ إِسَّارْڭبْ خْ ؤُمدُّورْ إِنُو. \x ◘ \xo 4:‏7 \xt ڒخ. 20‏:‏4؛ أَفا. 6‏:‏21؛ 2 تِيم. 4‏:‏12. \x*
\v 8 سّكّغْ ث غَارْومْ، حِيمَا أَذْ إِسّنْ مَامّشْ ثدْجَامْ ؤُ حِيمَا أَذْ إِسَّاريّحْ ؤُڒَاونْ نْومْ،
\v 9 \add جْمِيعْ\add* أَكْ-ذ ؤُنِيسِيمُوسْ، ؤُمَاثْنغْ أَمْثِيقِّي إِعِيزّنْ، ونِّي إِدْجَانْ ذ إِجّنْ زَّايْومْ. نِيثْنِي أَذْ كنِّيوْ سَّارڭْبنْ مَامّشْ ندْجْ نشِّينْ. \x ◘ \xo 4:‏9 \xt فلمن. 10. \x*
\m 
\v 10 أَرِيسْثَارْخُوسْ ونِّي ذِي ڒحْبسْ أَكِيذِي، إِتّْسدْجَامْ-د خَاومْ س ڒهْنَا، أَمْ مَامّشْ خَاومْ إِتّْسدْجَامْ ؤُڒَا ذ مَارْكُوسْ، أَيَّاوْ ن بَارْ-نَابَا ونِّي خْ ثكْسِيمْ كنِّيوْ ثِيوصَّا - مَاڒَا يُوسَا-د غَارْومْ، قبْڒمْ ث - \x ◘ \xo 4:‏10 \xt ڒخ. 15‏:‏37؛ 27‏:‏2؛ 2 تِيم. 4‏:‏11. \x*
\v 11 ذ يَاسُوع، ؤُمِي ذ أَسْ قَّارنْ يُوسْثُوسْ. نِيثْنِي دْجَانْ زڭْ وخْثَانْ. نِيثْنِي وحّذْسنْ عَاوْننْ أَيِي ذِي \add ثْمسْڒَاشْثْ ن\add* ثْڭلْذِيثْ ن أَربِّي ؤُشَا سّْفوّْجنْ أَيِي.
\m 
\v 12 إِتّْسدْجَامْ-د خَاومْ إِبَافْرَاسْ س ڒهْنَا. نتَّا ذ إِجّنْ زَّايْومْ، أَقَا-ث ذ أَمْسخَّارْ ن لْمَاسِيحْ، إِتّذْعَا أَومْ ڒبْذَا ذِي ثْژَادْجِيثْ نّسْ س جّهْذْ، حِيمَا أَذْ ثْبدّمْ نِيشَانْ، أَذْ ثِيڒِيمْ ثْكمّْڒنْ ذِي مَارَّا مِينْ إِخْسْ أَربِّي. \x ◘ \xo 4:‏12 \xt كُول. 1‏:‏7؛ فلمن. 23. \x*
\v 13 مِينْزِي شهّْذغْ خَاسْ، أَقَا نتَّا أَطَّاسْ إِ خَاومْ إِكْسِي ؤُڒَا خْ يِينِّي ذِي لَايُوذِيكِييَا ذ يِينِّي ذِي هِيرَاپُولِيسْ.
\m 
\v 14 لُوكَا، أَضْبِيبْ نّغْ إِعِيزّنْ، ذ ذِيمَاسْ تّْسدْجَامنْ-د خَاومْ س ڒهْنَا. \x ◘ \xo 4:‏14 \xt 2 تِيم. 4‏:‏10، 11\x*
\m 
\v 15 سدْجْممْ خْ وَاوْمَاثنْ إِنِّي إِدْجَانْ ذِي لَايُوذِيكِييَا س ڒهْنَا، خْ نِيمْفَاسْ ؤُ خْ ثْمسْمُونْثْ ذِي ثَادَّارْثْ نّسْ.
\m 
\v 16 خْمِي غَا ثتّْوَاسّْغَارْ ثبْرَاثْ-أَ جَارْ أَومْ، خنِّي حْضَامْ أَذْ ثتّْوَاسّْغَارْ عَاوذْ ذِي ثْمسْمُونْثْ ن لَايُوذِيكِييَا ؤُشَا أَذْ ثْغَارمْ كنِّيوْ عَاوذْ ثنِّي زِي لَايُوذِيكِييَا.
\m 
\v 17 إِنِي إِ أَرْخِيبُّوسْ: ”حْضَا أَذْ ثْكمّْڒذْ ڒْخذْمثْ ن ثْسخَّارْثْ إِ ثكْسِيذْ زِي سِيذِيثْنغْ!“
\m 
\v 18 سْڒَامْ وَانِيثَا \add ؤُرِيغْ ث\add* س ؤُفُوسْ إِنُو، زِي بُولُوسْ.عقْڒمْ خْ سّْنَاسڒْ إِنُو. أَذْ كِيومْ يِيڒِي أَرْضَا. أَمِينْ. \x ◘ \xo 4:‏18 \xt 2 تس. 3‏:‏17؛ عبر. 13‏:‏3. \x* 
