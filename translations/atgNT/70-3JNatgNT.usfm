\id 3JN - Okphela
\h 3 iJọni
\toc1 3 iJọni
\toc2 3 iJọni
\toc3 3 iJọn
\mt2 Ebe onuzi-esẹ ni
\mt1 IJọni
\mt2 Ọ kẹkẹ
\c 1
\p 
\v 1 Mhẹmhẹ ni mhi khi ọgbhali.\f + \fr 1:1 \ft Li zẹ \fq Ika 19.29; iRom 16.23; 1 iKọri 1.14\f*
\p Mhia kẹkẹ ebe ona ghi ọmọle mhẹ iGayusi ni mhi nono ingme oyọli egbegbọ.
\p 
\v 2 Ọmọle mhẹ, mhi sọ iromhi nẹ, Ẹshinẹgba ọ ka rẹ ze, ali emhikpa e ke je odalo nẹ onete abi ayẹmhẹ oyẹ o liẹ je odalo shi ọ.
\v 3 Egbe ma mu mhẹ gba abi eni anye ga miesuọ eghuo e rọ bhale ya bino anye, ni e rọ guele khi u ma mu igẹsikia mhuẹ ali khi u kiele ẹ ngeli angeli igẹsikia.
\v 4 Emhese ẹa la ọ ni o rẹmhẹ ẹ ghẹlẹ, abinẹ khi ini mhi suọ khi imi mhẹ e la angeli igẹsikia.
\p 
\v 5 Ọmọle mhẹ, u ga ri igẹsikia riẹlẹ emhi ebubu rọ kpaghiẹ inyọghuo awa ni awa ga miesuọ obọ, abi e ririẹ khi epfẹse.
\v 6 Eni ẹgbọ e she gue ingme inono oyẹ ye igbaa oyi eni e mie iJesu iKirisiti suọ ni o la akana. Kpẹkpẹ kpaghiẹ wẹ obọ ni e dobẹ ri oni okiali ke je odalo abi o li ghọle Ẹshinẹgba.
\v 7 Itobọ oni Eva ona, e rọ vu oni okiali ona, ni o khia khi ẹa lama mie eni ẹa mie Ẹshinẹgba suọ ikpaghiobọ.
\v 8 Irarighọ, awa ẹgbọ eyi iKirisiti, awa khi eni e mema ya kpaghiẹ eni ẹgbọ eghọghọ obọ, ni awa kugbe wẹ ọ gbe oni akanya, shi igẹsikia.
\p 
\v 9 Mhi kpẹ kẹkẹ ebe ghi igbaa oyi eni e mie iJesu iKirisiti suọ ni o la ẹoli oyẹ, ama iDiotefisi ni ọ kie kpẹ lighọ nono ni lọli ralo na eni igbaa oyi eni e mie iJesu iKirisiti suọ, ọa lama ri emini mhi gueyẹ ọli gbe akanya.
\v 10 Irarighọ, mhi kha bhale, mhi ya guele emini ọ riẹlẹ le gboo. Abi ọ liẹ gue anye ẹzọ, ni ọ liẹ kiẹnọ ẹgbhọli ma anye. Oghọ ọa ga bu ọli, ama ọa gbo lama mie apfọwa ni awa ga miesuọ. Eri ọ ga khu ẹgbọ ni ẹ nono ni wẹwẹ e mie wẹ shi owa ya fiẹ igbaa oyi eni e mie iJesu iKirisiti suọ.
\p 
\v 11 Ọmọle mhẹ khi ke khọnya angeli obe, ama khọnya eminete. Ọni ọ da riẹlẹ eminete ne, Omi Ẹshinẹgba ọ khi. Ọnini ọ da riẹlẹ onobe, ọa lẹsẹ Ẹshinẹgba.
\p 
\v 12 Ọgbọkpa ọọ ngme onete oyi iDẹmẹtiriusi. Egbegbi angeli igẹsikia oyọli o gbo pfi ọtsẹlẹ na li. Anye gbo ri ọtsẹlẹ oyanye ma ọ. A lẹsẹ khi ọtsẹlẹ oyanye khi igẹsikia o khi.
\s1 Otsẹ ni o kpukhokho
\p 
\v 13 Emhi ebubu e la ọ ni mhi kha kẹkẹ ghi ẹ, ama mhi aa nono ni mhi kẹkẹ wẹ shi ebe.
\v 14 Mhi sa khi mhi ya kẹlẹ bhale ya mẹ, ni awa mẹ egbe imialo nu egbe ngme.
\v 15 Opfọmhẹ o ka nu ẹ la. Emọle ẹ ni e la oola, ẹẹ tsẹ ẹ. Kpẹkpẹ tsẹ emọle anye nya ni e la oobọ, ọtuọghuọghuo.
