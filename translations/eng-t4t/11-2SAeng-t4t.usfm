\v 10 \w You|strong="H5921"\w* \w and|strong="H1121"\w* \w your|strong="H5921"\w* 15 \w sons|strong="H1121"\w* \w and|strong="H1121"\w* \w your|strong="H5921"\w* 20 \w servants|strong="H5650"\w* \w must|strong="H1121"\w* \w till|strong="H5647"\w*/plow \w the|strong="H5921"\w* land \w for|strong="H5921"\w* \w Mephibosheth|strong="H4648"\w*’s \add family\add*, \w and|strong="H1121"\w* \add plant crops\add* \w and|strong="H1121"\w* harvest \w them|strong="H5921"\w*, \w in|strong="H5921"\w* order \w that|strong="H1121"\w* \w they|strong="H5921"\w* \w will|strong="H1961"\w* \w have|strong="H1961"\w* \w food|strong="H3899"\w* \w to|strong="H1961"\w* \w eat|strong="H3899"\w*. \w But|strong="H1961"\w* \w Mephibosheth|strong="H4648"\w* \w will|strong="H1961"\w* \w eat|strong="H3899"\w* \w food|strong="H3899"\w* \w with|strong="H5921"\w* \w me|strong="H5921"\w* \w at|strong="H5921"\w* \w my|strong="H5921"\w* house.”
\p 
