\mt1 Le livre du prophète Malachie  
\c 1
\s1 \sc Chap. i, 1 : Titre.\sc*  
\p
\v 1 \w Sentence|strong="H01697"\w*. \w Parole|strong="H01697"\w* \w de|strong="H01697"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w à|strong="H03068"\w* \w Israël|strong="H03478"\w*\f + \fr 1:1 \ft À Israël, à tout le peuple revenu de l’exil et composé surtout de Judéens.\f* \w par|strong="H03027"\w* l’\w intermédiaire|strong="H03027"\w* \w de|strong="H01697"\w* \w Malachie|strong="H04401"\w*.   
\s1 \sc 1. Chap. i, 2-5 : L’amour de Yahweh pour son peuple.\sc*  
\p
\v 2 \w Je|strong="H05315"\w* \w vous|strong="H03068"\w* \w ai|strong="H05857"\w* \w aimés|strong="H00157"\w*, \w dit|strong="H05002"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* ; \w et|strong="H03068"\w* \w vous|strong="H03068"\w* \w dites|strong="H00559"\w*\f + \fr 1:2 \ft \+it Vous dites\+it* : c’est sa misère présente qui fait parler ainsi Israël.\f* : « \w En|strong="H03068"\w* \w quoi|strong="H04100"\w* \w nous|strong="H03068"\w* \w as-tu|strong="H00375"\w* \w aimés|strong="H00157"\w* ? » — \w Esaü|strong="H06215"\w* n’\w est-il|strong="H03068"\w* \w pas|strong="H03808"\w* \w frère|strong="H00251"\w* \w de|strong="H05002"\w* \w Jacob|strong="H03290"\w* ? — \w oracle|strong="H04853"\w* \w de|strong="H05002"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* ; \w et|strong="H03068"\w* \w j|strong="H03068"\w*’\w ai|strong="H03068"\w* \w aimé|strong="H00157"\w* \w Jacob|strong="H03290"\w*,  
\v 3 \w mais|strong="H00199"\w* j’ai \w haï|strong="H08130"\w* \w Esaü|strong="H06215"\w* ; j’ai \w fait|strong="H07760"\w* \w de|strong="H02022"\w* \w ses|strong="H07760"\w* \w montagnes|strong="H02022"\w* \w une|strong="H07760"\w* \w solitude|strong="H08077"\w*, \w et|strong="H02022"\w* \w \+add livré\+add*\w* \w son|strong="H07760"\w* \w héritage|strong="H05159"\w* \w aux|strong="H05159"\w* \w chacals|strong="H08568"\w* \w du|strong="H07760"\w* \w désert|strong="H04057"\w*\f + \fr 1:3 \ft \+it Aux chacals du désert\+it* ; LXX, \+it en prairies du désert\+it*.\f*.  
\v 4 \w Si|strong="H03588"\w* \w Edom|strong="H00123"\w* \w dit|strong="H00559"\w* : « \w Nous|strong="H03068"\w* \w avons|strong="H03426"\w* \w été|strong="H07019"\w* \w détruits|strong="H07567"\w*, \w mais|strong="H03588"\w* \w nous|strong="H03068"\w* rebâtirons \w les|strong="H07725"\w* \w ruines|strong="H02723"\w*, » — \w ainsi|strong="H03541"\w* \w parle|strong="H00559"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w* : \w Eux|strong="H01992"\w*, \w ils|strong="H01992"\w* \w bâtiront|strong="H01129"\w*, \w et|strong="H07725"\w* \w moi|strong="H06440"\w*, \w je|strong="H07725"\w* \w renverserai|strong="H02040"\w* ; \w et|strong="H07725"\w* \w l|strong="H05971"\w*’\w on|strong="H05971"\w* \w dira|strong="H00559"\w* \w d|strong="H01992"\w*’\w eux|strong="H01992"\w* : « \w Territoire|strong="H01366"\w* \w d|strong="H01992"\w*’\w iniquité|strong="H07564"\w*, \w peuple|strong="H05971"\w* \w contre|strong="H03068"\w* \w lequel|strong="H00834"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w est|strong="H03068"\w* \w irrité|strong="H02194"\w* \w pour|strong="H05704"\w* \w toujours|strong="H05769"\w*. »  
\v 5 \w Vos|strong="H07200"\w* \w yeux|strong="H05869"\w* \w le|strong="H07200"\w* \w verront|strong="H07200"\w*, \w et|strong="H03478"\w* \w vous|strong="H03068"\w* \w vous|strong="H03068"\w* \w direz|strong="H00559"\w* : « \w Que|strong="H07200"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w soit|strong="H03068"\w* \w glorifié|strong="H01431"\w*\f + \fr 1:5 \ft \+it Que Yahweh soit glorifié\+it* ou \+it Yahweh est grand\+it*. — \+it Sur le territoire d’Israël\+it*. D’autres : \+it au delà du territoire d’Israël\+it*.\f* \w sur|strong="H03068"\w* \w le|strong="H07200"\w* \w territoire|strong="H01366"\w* d’\w Israël|strong="H03478"\w* ! »   
\s1 \sc 2. Chap. i, 6-14 : Aux prêtres, à propos des offrandes.\sc* — Loin d’honorer Yahweh, les prêtres lui présentent des victimes indignes de lui (i, 6-9) : mieux vaudrait qu’il n’y eût plus de sacrifices (i, 10). Le sacrifice universel (i, 11). Contraste avec ce que font les prêtres (i, 12-14).  
\p
\v 6 \w Un|strong="H01121"\w* \w fils|strong="H01121"\w* \w honore|strong="H03513"\w* \w son|strong="H03513"\w* \w père|strong="H00001"\w*, \w et|strong="H01121"\w* \w un|strong="H01121"\w* \w serviteur|strong="H05650"\w* \w son|strong="H03513"\w* \w maître|strong="H00113"\w*. \w Or|strong="H02091"\w*, \w si|strong="H03863"\w* \w je|strong="H05650"\w* \w suis|strong="H01961"\w* \w père|strong="H00001"\w*, \w moi|strong="H06440"\w*, \w où|strong="H05650"\w* \w est|strong="H03068"\w* l’\w honneur|strong="H03519"\w* \w qui|strong="H03548"\w* m’\w \+add appartient\+add*\w* ? \w Et|strong="H01121"\w* \w si|strong="H03863"\w* \w je|strong="H05650"\w* \w suis|strong="H01961"\w* \w Seigneur|strong="H00136"\w*, \w où|strong="H05650"\w* \w est|strong="H03068"\w* \w la|strong="H03068"\w* \w crainte|strong="H04172"\w* \w qui|strong="H03548"\w* m’\add est due\add* ? \w dit|strong="H00559"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*, \w à|strong="H03068"\w* \w vous|strong="H03068"\w*, \w prêtres|strong="H03548"\w*, \w qui|strong="H03548"\w* \w méprisez|strong="H03988"\w* \w mon|strong="H03068"\w* \w nom|strong="H08034"\w*. \w Vous|strong="H03068"\w* \w dites|strong="H00559"\w* : « \w En|strong="H03548"\w* \w quoi|strong="H04100"\w* \w avons-nous|strong="H02403"\w* \w méprisé|strong="H03988"\w* \w ton|strong="H03513"\w* \w nom|strong="H08034"\w* ? »  
\v 7 \w En|strong="H03068"\w* \w ce|strong="H01931"\w* \w que|strong="H01931"\w* \w vous|strong="H03068"\w* \w apportez|strong="H00935"\w* \w sur|strong="H03068"\w* \w mon|strong="H03068"\w* \w autel|strong="H04196"\w* \w un|strong="H03068"\w* \w pain|strong="H03899"\w* \w souillé|strong="H01351"\w*\f + \fr 1:7 \ft \+it Un pain souillé\+it*, expression désignant toutes les offrandes. — \+it En quoi t’avons-nous souillé ?\+it* LXX, \+it en quoi l’avons-nous souillé ?\+it* — \+it En ce que vous dites\+it* etc. : \+it vous agissez comme si vous pensiez que la table de Yahweh\+it*, c.-à-d. l’autel, est chose vile, dont on n’a pas à se soucier beaucoup, puisqu’elle ne rapporte aucun profit.\f*. \w Et|strong="H03068"\w* \w vous|strong="H03068"\w* \w dites|strong="H00559"\w* : « \w En|strong="H03068"\w* \w quoi|strong="H04100"\w* t’avons-nous \w souillé|strong="H01351"\w* ? » \add En ce que\add* \w vous|strong="H03068"\w* \w dites|strong="H00559"\w* : « \w La|strong="H03068"\w* \w table|strong="H07979"\w* \w de|strong="H03899"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w est|strong="H03068"\w* \w chose|strong="H01697"\w* vile. »  
\v 8 \w Quand|strong="H03588"\w* \w vous|strong="H03068"\w* \w présentez|strong="H07126"\w* \w une|strong="H05375"\w* \add bête\add* \w aveugle|strong="H05787"\w* \w pour|strong="H06440"\w* \add la\add* \w sacrifier|strong="H02076"\w*, \w il|strong="H03068"\w* n’\w y|strong="H03068"\w* \w a|strong="H03068"\w* \w pas|strong="H04994"\w* \w de|strong="H06440"\w* \w mal|strong="H07451"\w* ! \w Et|strong="H03068"\w* \w quand|strong="H03588"\w* \w vous|strong="H03068"\w* \add en\add* \w amenez|strong="H05066"\w* \w une|strong="H05375"\w* \w boiteuse|strong="H06455"\w* \w et|strong="H03068"\w* \w malade|strong="H02470"\w*, \w il|strong="H03068"\w* n’\w y|strong="H03068"\w* \w a|strong="H03068"\w* \w pas|strong="H04994"\w* \w de|strong="H06440"\w* \w mal|strong="H07451"\w* ! \w Va|strong="H03068"\w* \w donc|strong="H00645"\w* \w l|strong="H06440"\w*’\w offrir|strong="H02076"\w* \w à|strong="H03068"\w* \w ton|strong="H06440"\w* \w gouverneur|strong="H06346"\w* ? \w T|strong="H06440"\w*’agréera-t-il\f + \fr 1:8 \ft \+it T’agréera-t-il ?\+it* LXX (Alex, et Sinait.), Vulg. \+it L’agréera-t-il ?\+it*\f* ? \w Te|strong="H03068"\w* \w sera-t-il|strong="H07451"\w* \w favorable|strong="H07521"\w* ? \w dit|strong="H00559"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*.  
\v 9 \w Et|strong="H03068"\w* \w maintenant|strong="H06258"\w*, suppliez \w donc|strong="H03027"\w* \w Dieu|strong="H03068"\w* \w d|strong="H06440"\w*’\w avoir|strong="H03068"\w* \w pitié|strong="H02603"\w* \w de|strong="H03027"\w* \w vous|strong="H03068"\w* ! C’\w est|strong="H03068"\w* \w par|strong="H03027"\w* \w votre|strong="H06440"\w* \w main|strong="H03027"\w* \w que|strong="H06440"\w* \w cela|strong="H02063"\w* s’\w est|strong="H03068"\w* \w fait|strong="H03068"\w* ; \w sera-t-il|strong="H07451"\w* \w amené|strong="H00935"\w* \w par|strong="H03027"\w* \w vous|strong="H03068"\w* \w à|strong="H03068"\w* \w avoir|strong="H00310"\w* \w des|strong="H03068"\w* \w égards|strong="H04856"\w* ? \w dit|strong="H00559"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*.   
\p
\v 10 \w Que|strong="H03027"\w* \w l|strong="H04503"\w*’\w un|strong="H03068"\w* d’\w entre|strong="H03068"\w* \w vous|strong="H03068"\w* \w ne|strong="H03068"\w* ferme-t-il \w plutôt|strong="H00408"\w* \w les|strong="H03068"\w* \w portes|strong="H01817"\w*, \w pour|strong="H03027"\w* \w que|strong="H03027"\w* \w vous|strong="H03068"\w* n’embrasiez \w pas|strong="H03808"\w* \w mon|strong="H03068"\w* \w autel|strong="H04196"\w* \w en|strong="H03068"\w* \w pure|strong="H02889"\w* \w perte|strong="H07451"\w* ! \w Je|strong="H01571"\w* \w ne|strong="H03068"\w* \w prends|strong="H03947"\w* \w pas|strong="H03808"\w* \w plaisir|strong="H07521"\w* \w en|strong="H03068"\w* \w vous|strong="H03068"\w*, \w dit|strong="H00559"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*, \w et|strong="H03068"\w* \w je|strong="H01571"\w* n’\w agrée|strong="H07521"\w* \w pas|strong="H03808"\w* d’\w offrande|strong="H04503"\w* \w de|strong="H03027"\w* \w votre|strong="H03808"\w* \w main|strong="H03027"\w*.\f + \fr 1:10 \ft Mieux vaudrait supprimer tout à fait les sacrifices, en fermant les portes du parvis intérieur, où se trouvait l’autel des holocaustes.\f*  
\v 11 \w Car|strong="H03588"\w*, \w du|strong="H08034"\w* \w lever|strong="H04217"\w* \w du|strong="H08034"\w* \w soleil|strong="H08121"\w* \w à|strong="H03068"\w* \w son|strong="H05066"\w* \w coucher|strong="H03996"\w*, \w mon|strong="H03068"\w* \w nom|strong="H08034"\w* \w est|strong="H03068"\w* \w grand|strong="H01419"\w* \w parmi|strong="H08432"\w* \w les|strong="H03068"\w* \w nations|strong="H01471"\w*, \w et|strong="H01419"\w* \w en|strong="H03068"\w* \w tout|strong="H03605"\w* \w lieu|strong="H04725"\w* \w on|strong="H04725"\w* \w offre|strong="H07126"\w* \w à|strong="H03068"\w* \w mon|strong="H03068"\w* \w nom|strong="H08034"\w* \w de|strong="H08034"\w* \w l|strong="H04503"\w*’\w encens|strong="H06999"\w* \w et|strong="H01419"\w* \w une|strong="H03068"\w* oblation \w pure|strong="H02889"\w*, \w car|strong="H03588"\w* \w mon|strong="H03068"\w* \w nom|strong="H08034"\w* \w est|strong="H03068"\w* \w grand|strong="H01419"\w* \w parmi|strong="H08432"\w* \w les|strong="H03068"\w* \w nations|strong="H01471"\w*, \w dit|strong="H00559"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*.\f + \fr 1:11 \ft Ce verset est appliqué par la tradition catholique au sacrifice de la loi nouvelle. — \+it On offre à mon nom de l’encens et une oblation pure\+it*. Vulg. \+it On fait des sacrifices et on offre à mon nom une oblation pure\+it*. Les LXX sont pareils à l’hébreu ; le mot \+it minchâh\+it*, \+it oblation\+it* est rendu par θυσία.\f*  
\v 12 \w Et|strong="H02490"\w* \w vous|strong="H03068"\w*, \w vous|strong="H03068"\w* \w le|strong="H02490"\w* \w profanez|strong="H02490"\w* \w quand|strong="H06256"\w* \w vous|strong="H03068"\w* \w dites|strong="H00559"\w* : « \w La|strong="H02490"\w* \w table|strong="H07979"\w* \w du|strong="H07979"\w* \w Seigneur|strong="H00136"\w* \w est|strong="H01931"\w* \w souillée|strong="H01351"\w*, \w et|strong="H02490"\w* \w ce|strong="H01931"\w* qu’\w elle|strong="H01931"\w* \w rapporte|strong="H05108"\w* n’\w est|strong="H01931"\w* qu’une \w méprisable|strong="H00959"\w* \w nourriture|strong="H03899"\w*\f + \fr 1:12 \ft \+it Et ce qu’elle rapporte n’est qu’une nourriture méprisable\+it* ; m. à m., \+it et son revenu est méprisable, sa nourriture\+it*.\f*. »  
\v 13 \w Et|strong="H03068"\w* \w vous|strong="H03068"\w* \w dites|strong="H00559"\w* : « \w Voici|strong="H02009"\w* ! \w Quel|strong="H00335"\w* ennui ! » \w et|strong="H03068"\w* \w vous|strong="H03068"\w* \w la|strong="H03068"\w* \w dédaignez|strong="H05301"\w*, \w dit|strong="H00559"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*. \w Et|strong="H03068"\w* \w vous|strong="H03068"\w* \w amenez|strong="H00935"\w* \w ce|strong="H02470"\w* \w qui|strong="H03068"\w* \w est|strong="H03068"\w* \w dérobé|strong="H01497"\w*\f + \fr 1:13 \ft \+it Dérobé\+it*, ou peut-être, selon le sens de la même racine en arabe, \+it mutilé\+it*.\f*, \w ce|strong="H02470"\w* \w qui|strong="H03068"\w* \w est|strong="H03068"\w* \w boiteux|strong="H06455"\w* \w et|strong="H03068"\w* \w ce|strong="H02470"\w* \w qui|strong="H03068"\w* \w est|strong="H03068"\w* \w malade|strong="H02470"\w*, \w et|strong="H03068"\w* \w vous|strong="H03068"\w* \w présentez|strong="H03320"\w* \w cette|strong="H03027"\w* \w offrande|strong="H04503"\w* ! \w Puis-je|strong="H03068"\w* \w l|strong="H04503"\w*’\w agréer|strong="H07521"\w* \w de|strong="H03027"\w* \w votre|strong="H03947"\w* \w main|strong="H03027"\w* ? \w dit|strong="H00559"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd*.  
\v 14 \w Maudit|strong="H00779"\w* \w soit|strong="H03068"\w* \w le|strong="H03068"\w* fraudeur, \w celui|strong="H08034"\w* \w qui|strong="H03068"\w*, \w ayant|strong="H03701"\w* \w dans|strong="H08034"\w* \w son|strong="H04428"\w* \w troupeau|strong="H05739"\w* \w un|strong="H03068"\w* \w mâle|strong="H02145"\w*, \w fait|strong="H03068"\w* \w un|strong="H03068"\w* \w vœu|strong="H05087"\w*, \w et|strong="H01419"\w* \w sacrifie|strong="H02076"\w* \w au|strong="H03068"\w* \w Seigneur|strong="H00136"\w* \w une|strong="H03068"\w* \w \+add bête\+add*\w* \w chétive|strong="H07843"\w* ! \w Car|strong="H03588"\w* \w je|strong="H03588"\w* \w suis|strong="H03426"\w* \w un|strong="H03068"\w* \w grand|strong="H01419"\w* \w roi|strong="H04428"\w*, \w dit|strong="H00559"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*, \w et|strong="H01419"\w* \w mon|strong="H04428"\w* \w nom|strong="H08034"\w* \w est|strong="H03068"\w* \w redouté|strong="H03372"\w* \w chez|strong="H00935"\w* \w les|strong="H03068"\w* \w nations|strong="H01471"\w*.   
\c 2
\s1 3. \sc Chap, ii, 1-9 : Châtiment des prêtres\sc* — Malédiction (ii, 1-3). Fidélité de Lévi à l’alliance (11, 4-7) ; les prêtres l’ont pervertie (11, 8, 9).  
\p
\v 1 \w Maintenant|strong="H06258"\w* \w donc|strong="H00645"\w*, \add c’est\add* \w pour|strong="H03548"\w* \w vous|strong="H03068"\w* \add qu’est\add* \w ce|strong="H02063"\w* \w décret|strong="H03792"\w*, \w ô|strong="H00577"\w* \w prêtres|strong="H03548"\w*.  
\v 2 \w Si|strong="H03808"\w* \w vous|strong="H03068"\w* n’\w écoutez|strong="H08085"\w* \w pas|strong="H03808"\w* \w et|strong="H03068"\w* \w si|strong="H03808"\w* \w vous|strong="H03068"\w* \w ne|strong="H03068"\w* \w prenez|strong="H07760"\w* \w pas|strong="H03808"\w* \w à|strong="H03068"\w* \w cœur|strong="H03820"\w* \w de|strong="H08034"\w* \w donner|strong="H05414"\w* \w gloire|strong="H03519"\w* \w à|strong="H03068"\w* \w mon|strong="H05414"\w* \w nom|strong="H08034"\w*, \w dit|strong="H05414"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*, \w j|strong="H01571"\w*’\w enverrai|strong="H07971"\w* \w contre|strong="H07971"\w* \w vous|strong="H03068"\w* \w la|strong="H08085"\w* \w malédiction|strong="H03994"\w*, \w et|strong="H03068"\w* \w je|strong="H01571"\w* \w maudirai|strong="H00779"\w*\f + \fr 2:2 \ft \+it Je maudirai\+it*, je changerai en malédiction.\f* \w vos|strong="H05414"\w* \w bénédictions|strong="H01293"\w* ; — \w et|strong="H03068"\w* \w déjà|strong="H03528"\w* \w je|strong="H01571"\w* \w les|strong="H08085"\w* \w ai|strong="H05857"\w* \w maudites|strong="H00779"\w*, \w parce|strong="H06903"\w* \w que|strong="H08085"\w* \w vous|strong="H03068"\w* n’\w avez|strong="H03068"\w* \w pas|strong="H03808"\w* \w pris|strong="H05414"\w* \w à|strong="H03068"\w* \w cœur|strong="H03820"\w* ! —  
\v 3 \w Voici|strong="H02005"\w* \w que|strong="H06440"\w* \w je|strong="H02005"\w* \w ferai|strong="H06213"\w* \w manquer|strong="H05737"\w* \w vos|strong="H05375"\w* \w semences|strong="H02233"\w*\f + \fr 2:3 \ft \+it Je ferai manquer vos semences\+it*, les semences du peuple dont les prêtres ont la dime. LXX et Vulg., \+it je vous retirerai l’épaule de la victime\+it* : sens en meilleur rapport avec le contexte.\f*, \w je|strong="H02005"\w* \w répandrai|strong="H02219"\w* \w du|strong="H06440"\w* \w fumier|strong="H01828"\w* \w sur|strong="H06440"\w* \w vos|strong="H05375"\w* \w visages|strong="H06440"\w*, \w le|strong="H06440"\w* \w fumier|strong="H01828"\w* \w de|strong="H06440"\w* \w vos|strong="H05375"\w* \w fêtes|strong="H02282"\w*, \w et|strong="H06440"\w* \w on|strong="H00376"\w* \w vous|strong="H06440"\w* \w emportera|strong="H05375"\w* \w avec|strong="H06440"\w* \w lui|strong="H06440"\w*.  
\v 4 \w Vous|strong="H03068"\w* \w saurez|strong="H03045"\w* \w alors|strong="H00116"\w* \w que|strong="H03588"\w* \w je|strong="H03588"\w* \w vous|strong="H03068"\w* \w ai|strong="H05857"\w* \w adressé|strong="H07971"\w* \w ce|strong="H07971"\w* \w décret|strong="H03792"\w*, \w afin|strong="H04616"\w* \w que|strong="H03588"\w* \w mon|strong="H07971"\w* \w alliance|strong="H01285"\w* \w avec|strong="H01285"\w* \w Lévi|strong="H03878"\w* \w demeure|strong="H03427"\w*\f + \fr 2:4 \ft \+it Demeure\+it*, ce qui ne peut être obtenu que par la punition des prêtres prévaricateurs.\f*, \w dit|strong="H00559"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*.  
