\v 8 \nd \w Yavé|strong="H3068"\w*\nd* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w va|strong="H3068"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w ti|strong="H5973"\w*. \w Él|strong="H1931"\w* \w estará|strong="H1961"\w* \w contigo|strong="H5973"\w*. \w No|strong="H3808"\w* \w te|strong="H5973"\w* \w dejará|strong="H5800"\w*, \w ni|strong="H3808"\w* \w te|strong="H5973"\w* \w desamparará|strong="H5800"\w*. \w No|strong="H3808"\w* \w temas|strong="H3372"\w*, \w ni|strong="H3808"\w* \w desmayes|strong="H2865"\w*.
