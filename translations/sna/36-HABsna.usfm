\id HAB - Biblica® Open Shona Contemporary Bible 2017 
\h Habhakuki 
\toc1 Habhakuki 
\toc2 Habhakuki 
\toc3 Habha 
\mt1 HABHAKUKI 
\c 1  
\p  
\v 1 Chirevo chakaratidzwa muprofita Habhakuki. 
\s1 Kugununʼuna kwaHabhakuki 
\q1  
\v 2 Haiwa Jehovha, ndicharamba ndichidanidzira, ndichitsvaka rubatsiro kusvikira riniko, 
\q2 asi musingandinzwi? 
\q1 Kana kudana kwamuri ndichiti, “Ndorwiswa!” 
\q2 asi hamundiponesi? 
\q1  
\v 3 Sei muchiita kuti ndione kusaruramisira? 
\q2 Sei muchirega zvakaipa zvichingoitwa? 
\q1 Kuparadza nokuita nechisimba zviri pamberi pangu; 
\q2 pano kukakavara, uye kurwa kuri kuwanda. 
\q1  
\v 4 Naizvozvo murayiro hauchisina simba, 
\q2 uye kutonga kwakarurama hakuchaonekwi. 
\q1 Vakaipa vanokomba vakarurama, 
\q2 zvokuti kururamisira kunominamiswa. 
\s1 Mhinduro yaJehovha 
\q1  
\v 5 “Tarisa ndudzi dzavanhu, ucherechedze, 
\q2 ugoshamiswa zvirokwazvo. 
\q1 Nokuti ndichaita chimwe chinhu pamazuva ako 
\q2 chawanga usingazobvumi, kunyange dai waichiudzwa. 
\q1  
\v 6 Ndiri kumutsa vaBhabhironi 
\q2 ruya rudzi rune utsinye, rune hasha, 
\q1 runopararira pasi pose 
\q2 kuti rubvute nzvimbo dzokugara dzisiri dzavo. 
\q1  
\v 7 Vanhu vanotyisa uye vanovhundukwa; 
\q2 vasina murayiro unovatonga 
\q2 uye vanongozvitsvakira kukudzwa. 
\q1  
\v 8 Mabhiza avo anomhanya kukunda ingwe, 
\q2 anotyisa kukunda mhumhi mumadekwana. 
\q1 Mauto avo amabhiza anomhanya asingadzoki; 
\q2 vatasvi vamabhiza vanobva kure kure. 
\q1 Vanobhururuka segora rinotsvaka kuparadza; 
\q2  
\v 9 vanouya vose kuzoita zvechisimba. 
\q1 Mapoka avo ehondo anouya semhepo inovhuvhuta mugwenga 
\q2 vachiunganidza nhapwa sejecha. 
\q1  
\v 10 Vanozvidza madzimambo 
\q2 uye vanomhura vatongi. 
\q1 Vanoseka maguta ose akasimbiswa; 
\q2 vanovaka zvikomo zvevhu voatapa. 
\q1  
\v 11 Ipapo vanopfuura semhepo, vanopfuura vasingamiri, 
\q2 varume vane mhosva, simba ravo ndiye mwari wavo.” 
\s1 Habhakuki anogununʼunazve 
\q1  
\v 12 Haiwa Jehovha, ko hamugari nokusingaperi here? 
\q2 Mwari wangu, mutsvene wangu, hatingatongofi. 
\q1 Haiwa Jehovha, makavagadza kuti vatonge; 
\q2 imi Dombo, makavagadza kuti varange. 
\q1  
\v 13 Meso enyu akachena zvokuti haangatarisi zvakaipa; 
\q2 hamungatenderi zvakaipa. 
\q1 Sei zvino muchitendera vanyengeri? 
\q2 Ko, munonyararirei kana vakaipa 
\q2 vachimedza vanovapfuura mukururama? 
\q1  
\v 14 Sei makaita kuti vanhu vave sehove dzegungwa, 
\q2 sezvisikwa zvegungwa zvisina mutongi. 
\q1  
\v 15 Muvengi anovaredza vose nezviredzo, 
\q2 anovabata mumumbure wake, 
\q1 achivakokorodza murutava rwake; 
\q2 naizvozvo anopembera nomufaro. 
\q1  
\v 16 Naizvozvo anopisira zvibayiro kumumbure wake, 
\q2 uye anopisira zvinonhuhwira kumumbure wake, 
\q1 nokuti anogarika nokuda kwomumbure wake, 
\q2 anodya zvokudya zvakaisvonaka. 
\q1  
\v 17 Ko, acharamba achingodurura zviri mumumbure wake, 
\q2 achingoparadza ndudzi asina tsitsi here? 
\c 2  
\q1  
\v 1 Ndichandomira panzvimbo yangu yokurinda 
\q2 ndichazviisa panzvimbo yakakwirira; 
\q1 ndichatarisa ndione zvaachareva kwandiri 
\q2 uye zvandingapindura pamusoro pokuchema uku. 
\s1 Mhinduro yaJehovha 
\p  
\v 2 Ipapo Jehovha akapindura achiti: 
\q1 “Nyora chiratidzo ichi, 
\q2 uite kuti chionekwe kwazvo pamahwendefa 
\q2 kuti anoverenga agoverenga achimhanya. 
\q1  
\v 3 Nokuti chiratidzo ichi chakamirira nguva yakatarwa; 
\q2 chinotaura nezvamagumo 
\q2 uye hachingarevi nhema. 
\q1 Kunyange dai chikanonoka, chimirire; 
\q2 zvirokwazvo chichauya, hachizononoki. 
\b  
\q1  
\v 4 “Tarira, ana manyawi; 
\q2 zvido zvake hazvina kururama, 
\q2 asi akarurama achararama nokutenda kwake. 
\q1  
\v 5 Zvirokwazvo, waini inomupandukira; 
\q2 anozvikudza uye haazombozorori. 
\q1 Nokuti anokara sezvinoita guva 
\q2 uye sorufu haaguti, 
\q1 anozviunganidzira ndudzi dzose 
\q2 uye anotapa marudzi ose avanhu. 
\s1 Matambudziko aVakaipa 
\p  
\v 6 “Ko, vakatapwa vose havangazomuseki here nezvirahwe zvokumushora vachiti, 
\q1 “ ‘Ane nhamo anozviunganidzira zvakabiwa 
\q2 anozvipfumisa nepfuma yakapambwa! 
\q2 Zvicharamba zvakadai kusvikira riniko?’ 
\q1  
\v 7 Ko, vamakakwereta havangazosimuki pakarepo here? 
\q2 Havangazomuki vakakuvhundutsai here? 
\q2 Ipapo ndimi muchava vakapambwa. 
\q1  
\v 8 Nokuti makapamba ndudzi zhinji, 
\q2 vakasara vachakupambai, 
\q1 nokuda kweropa ravanhu ramakateura; 
\q2 makaparadza nyika namaguta pamwe chete navageremo. 
\b  
\q1  
\v 9 “Ane nhamo anovaka umambo hwake nepfuma yakabiwa, 
\q2 achivaka dendere rake pakakwirira, 
\q2 kuti anzvenge kuparadzwa! 
\q1  
\v 10 Makarangana kuparadza ndudzi dzakawanda, 
\q2 muchinyadzisa imba yenyu, 
\q2 uye muchiparadza upenyu hwenyu. 
\q1  
\v 11 Mabwe ari murusvingo achadanidzira, 
\q2 ipapo matanda edenga remba achadairira namaungira. 
\b  
\q1  
\v 12 “Ane nhamo anovaka guta nokudeura ropa 
\q2 uye anosimbisa guta nezvakaipa. 
\q1  
\v 13 Tarirai, hazvina kubva kuna Jehovha Wamasimba Ose here 
\q2 kuti vanhu vanoshandira zvinoparadzwa nomoto, 
\q2 uye kuti marudzi avanhu anongozvinetesa nezvisina maturo? 
\q1  
\v 14 Nokuti nyika yose ichazadzwa nokuziva kubwinya kwaJehovha, 
\q2 sezvakaita mvura kuzadza kwayakaita gungwa. 
\b  
\q1  
\v 15 “Ane nhamo anopa vavakidzani vake zvinodhaka, 
\q2 achizvidurura kubva mumatende ewaini kusvikira vadhakwa, 
\q2 kuti aone kushama kwavo. 
\q1  
\v 16 Muchazadzwa nenyadzi pachinzvimbo chokukudzwa. 
\q2 Nhasi ndimiwo! Chinwai kuti mudzedzereke! 
\q1 Mukombe unobva kuruoko rwaJehovha rworudyi uri kuuya kwamuri, 
\q2 kunyadziswa kuchafukidza kukudzwa kwenyu. 
\q1  
\v 17 Nokuti kuita nechisimba kwamakaitira Rebhanoni kuchakukundai, 
\q2 uye kuparadza kwamakaita mhuka kuchakutyisai. 
\q1 Nokuti makateura ropa ravanhu; 
\q2 makaparadza nyika namaguta navose vakanga vageremo! 
\b  
\q1  
\v 18 “Chifananidzo chakavezwa chinobatsireiko, zvachakangogadzirwa nomuvezi? 
\q2 Kana chifananidzo chakaumbwa, chinodzidzisa nhema? 
\q1 Nokuti uyo anochiita anovimba nechaakazviumbira; 
\q2 anoita zvifananidzo zvisingagoni kutaura. 
\q1  
\v 19 Ane nhamo anoti kudanda, ‘Rarama!’ 
\q2 Kana kubwe risingagoni kutaura, ‘Muka!’ 
\q1 Ko, zvingadzidzisa here? 
\q2 Tarira, chakafukidzwa negoridhe nesirivha; 
\q2 hachina mweya mukati macho napaduku. 
\q1  
\v 20 Asi Jehovha ari mutemberi yake tsvene; 
\q2 nyika yose ngairambe inyerere pamberi pake.” 
\c 3  
\s1 Munyengetero waHabhakuki 
\p  
\v 1 Munyengetero wamuprofita Habhakuki unoimbwa neshigionoti. 
\q1  
\v 2 Jehovha, ndakanzwa zvomukurumbira wenyu; 
\q2 haiwa Jehovha, ndinomira ndichitya mabasa enyu. 
\q1 Avandudzei pamazuva edu, 
\q2 panguva yedu ngaaziviswe; 
\q2 pakutsamwa kwenyu rangarirai tsitsi. 
\b  
\q1  
\v 3 Mwari akabva kuTemani, 
\q2 iye Mutsvene akabva kuGomo reParani. \qs Sera \qs* 
\q1 Umambo hwake hwakazadza matenga 
\q2 uye mbiri yake yakazadza nyika. 
\q1  
\v 4 Kubwinya kwake kwakaita sokubuda kwezuva; 
\q2 bwerazuva hwakapenya huchibva muruoko rwake, 
\q2 makanga makavigwa simba rake. 
\q1  
\v 5 Hosha yakaenda ichibva pamberi pake; 
\q2 denda rakatevera nhambwe dzake. 
\q1  
\v 6 Akamira, akazungunusa nyika; 
\q2 akatarisa, akabvundisa ndudzi dzavanhu. 
\q1 Makomo akare kare akakoromoka 
\q2 uye zvikomo zvakare zvakawira pasi. 
\q2 Nzira dzake dzinogara nokusingaperi. 
\q1  
\v 7 Ndakaona matende eKushani ari panhamo, 
\q2 nzvimbo dzokugara dzeMidhiani dziri pakutambudzika. 
\b  
\q1  
\v 8 Ko, makanga matsamwira nzizi here, nhai Jehovha? 
\q2 Makanga matsamwira zvikova here, nhai Jehovha? 
\q1 Makatsamwira gungwa here 
\q2 pamakafambisa mabhiza enyu 
\q2 nengoro dzenyu dzokukunda? 
\q1  
\v 9 Makabudisa pachena uta hwenyu, 
\q2 mukadaidzira miseve mizhinji. \qs Sera \qs* 
\q1 Makatsemura nyika nenzizi; 
\q2  
\v 10 makomo akakuonai akadedera. 
\q1 Mvura zhinji yakapfuura; 
\q2 kwakadzika kwakatinhira 
\q2 kukasimudza mafungu pamusoro. 
\b  
\q1  
\v 11 Zuva nomwedzi zvakambomira kumatenga 
\q2 zvichiona kuvaima kwemiseve yenyu yaipfuura, 
\q2 zvichiona kupenya kwepfumo renyu rinobwinya. 
\q1  
\v 12 Mukutsamwa kwenyu makapfuura napanyika 
\q2 uye mukushatirwa kwenyu makarasa ndudzi. 
\q1  
\v 13 Makauya kuzonunura vanhu venyu, 
\q2 kuzoponesa muzodziwa wenyu. 
\q1 Makaparadza mutungamiri wenyika yavakaipa, 
\q2 mukamufukura kubva kumusoro kusvika kutsoka. \qs Sera \qs* 
\q1  
\v 14 Nepfumo rake chairo makabaya musoro wake, 
\q2 pakauya varwi vake sechamupupuri kuzotiparadzira, 
\q1 vachifara savanoda kuparadza 
\q2 vanotambudzika vakanga vakavanda. 
\q1  
\v 15 Makatsika-tsika gungwa namabhiza enyu, 
\q2 mukabvongodza mvura zhinji. 
\b  
\q1  
\v 16 Ndakazvinzwa, hana yangu ikarova, 
\q2 miromo yangu yakadedera pandakanzwa maungira; 
\q1 kuora kwakapinda mumapfupa angu, 
\q2 makumbo angu akadedera. 
\q1 Asi ndichamirira hangu zuva renjodzi 
\q2 kuti riuye pamusoro porudzi ruchatirwisa. 
\q1  
\v 17 Kunyange dai muonde ukasatunga maruva, 
\q2 uye mizambiringa ikashayiwa zvibereko, 
\q1 kunyange kubereka kwomuorivhi kukakona, 
\q2 uye minda ikasabereka zvokudya, 
\q1 kunyange dai kukasava namakwai muchirugu 
\q2 uye mombe dzikashayikwa mumatanga, 
\q1  
\v 18 kunyange zvakadaro, ndichafara muna Jehovha, 
\q2 ndichava nomufaro muna Mwari Muponesi wangu. 
\b  
\q1  
\v 19 Ishe Jehovha ndiye simba rangu; 
\q2 anoita kuti tsoka dzangu dziite setsoka dzenondo, 
\q2 anondifambisa pamatunhu akakwirira. 
\b  
\q1 Kumutungamiri wokuimba, nemitengeranwa yangu.