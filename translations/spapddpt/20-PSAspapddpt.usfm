\v 8 \w Pero|strong="H3588"\w* Tú, \w oh|strong="H4310"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w te|strong="H3588"\w* ríes \w de|strong="H3588"\w* ellos.
\q1 \w Te|strong="H3588"\w* burlas \w de|strong="H3588"\w* todas las naciones.
\b
\q1 
