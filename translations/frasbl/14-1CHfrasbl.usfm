\v 10 Jabez \w invoqua|strong="H7121"\w* \w le|strong="H6213"\w* \w Dieu|strong="H6213"\w*\f + \fr 4.10 \ft Le mot hébreu rendu par « Dieu » est « אֱלֹהִ֑ים » (Elohim).\f* d'\w Israël|strong="H3478"\w* \w et|strong="H3478"\w* \w dit|strong="H3478"\w* : « \w Que|strong="H3027"\w* \w tu|strong="H3027"\w* \w me|strong="H3027"\w* bénisses \w et|strong="H3478"\w* \w que|strong="H3027"\w* \w tu|strong="H3027"\w* \w étendes|strong="H7235"\w* \w mon|strong="H7121"\w* \w territoire|strong="H1366"\w* ! \w Que|strong="H3027"\w* \w ta|strong="H6213"\w* \w main|strong="H3027"\w* \w soit|strong="H1961"\w* \w avec|strong="H6213"\w* \w moi|strong="H3027"\w*, \w et|strong="H3478"\w* \w que|strong="H3027"\w* \w tu|strong="H3027"\w* \w me|strong="H3027"\w* \w gardes|strong="H7121"\w* \w du|strong="H3027"\w* \w mal|strong="H7451"\w*, \w afin|strong="H1115"\w* \w que|strong="H3027"\w* \w je|strong="H3027"\w* \w ne|strong="H3478"\w* \w fasse|strong="H6213"\w* \w pas|strong="H6213"\w* \w de|strong="H3027"\w* \w mal|strong="H7451"\w* ! ».
\p \w Dieu|strong="H6213"\w* \w lui|strong="H3027"\w* \w a|strong="H3068"\w* \w accordé|strong="H6213"\w* \w ce|strong="H6213"\w* \w qu|strong="H1115"\w*'\w il|strong="H3027"\w* \w demandait|strong="H7592"\w*.
\p 
