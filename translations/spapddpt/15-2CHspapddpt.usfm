\v 9 Entonces Ezequías preguntó \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* montones.  
\v 10 \w El|strong="H3588"\w* \w sumo|strong="H7218"\w* \w sacerdote|strong="H3548"\w* \w Azarías|strong="H5838"\w*, \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Sadoc|strong="H6659"\w*, le respondió: \w Desde|strong="H5704"\w* \w cuando|strong="H3588"\w* \w comenzaron|strong="H2490"\w* \w a|strong="H3068"\w* traer las \w ofrendas|strong="H8641"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w Casa|strong="H1004"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, comimos, nos saciamos \w y|strong="H3588"\w* sobró \w mucho|strong="H7230"\w*, \w porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w bendijo|strong="H1288"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w*. Sobró \w esta|strong="H2088"\w* gran cantidad.   
\p
\v 11 Ezequías mandó que prepararan \w cámaras|strong="H3957"\w* en la \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*, y fueron preparadas.  
\v 12 Llevaban fielmente \w las|strong="H5921"\w* \w ofrendas|strong="H8641"\w*, \w los|strong="H5921"\w* diezmos \w y|strong="H5921"\w* \w las|strong="H5921"\w* cosas consagradas.  
\p Encargaron \w al|strong="H5921"\w* \w levita|strong="H3881"\w* Conanías \w como|strong="H5921"\w* jefe \w de|strong="H5921"\w* esto, \w y|strong="H5921"\w* \w como|strong="H5921"\w* \w segundo|strong="H4932"\w*, \w a|strong="H3068"\w* su hermano Simei.  
\v 13 Jeiel, \w Azazías|strong="H5812"\w*, Nahat, \w Asael|strong="H6214"\w*, Jerimot, \w Jozabad|strong="H3107"\w*, Eliel, Ismaquías, Mahat, y \w Benaía|strong="H1141"\w* eran supervisores bajo la dirección \w de|strong="H5057"\w* Conanías y su hermano Simei, \w por|strong="H3027"\w* orden del \w rey|strong="H4428"\w* Ezequías y \w Azarías|strong="H5838"\w*, \w jefe|strong="H6496"\w* \w de|strong="H5057"\w* la \w Casa|strong="H1004"\w* \w de|strong="H5057"\w* \nd ʼElohim\nd*.   
\p
\v 14 \w El|strong="H5921"\w* \w levita|strong="H3881"\w* Coré, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Imna|strong="H3232"\w*, \w portero|strong="H7778"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* puerta \w oriental|strong="H4217"\w*, tenía \w a|strong="H3068"\w* su cargo \w las|strong="H5921"\w* \w ofrendas|strong="H8641"\w* \w voluntarias|strong="H5071"\w* \w para|strong="H5921"\w* \nd ʼElohim\nd*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* distribución \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w ofrendas|strong="H8641"\w* dedicadas \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w y|strong="H5921"\w* \w las|strong="H5921"\w* cosas santísimas.  
\v 15 Edén, \w Miniamín|strong="H4509"\w*, \w Jesúa|strong="H3442"\w*, \w Semaías|strong="H8098"\w*, Amarías \w y|strong="H5921"\w* Secanías estaban \w a|strong="H3068"\w* su servicio \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w para|strong="H5921"\w* repartir fielmente \w a|strong="H3068"\w* sus hermanos, \w según|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w les|strong="H5921"\w* correspondía, \w tanto|strong="H5921"\w* \w al|strong="H5921"\w* \w grande|strong="H1419"\w* \w como|strong="H5921"\w* \w al|strong="H5921"\w* \w pequeño|strong="H6996"\w*.   
\p
\v 16 Además estaban \w los|strong="H1121"\w* \w varones|strong="H2145"\w* anotados \w por|strong="H1697"\w* su genealogía masculina, \w de|strong="H1121"\w* \w tres|strong="H7969"\w* \w años|strong="H8141"\w* \w arriba|strong="H4605"\w*, y \w de|strong="H1121"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H1697"\w* entraba \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w a|strong="H3068"\w* realizar su \w tarea|strong="H5656"\w* \w diaria|strong="H3117"\w* en su \w ministerio|strong="H5656"\w* según sus oficios y \w clases|strong="H4931"\w*.   
\p
\v 17 También estaban \w los|strong="H1121"\w* \w que|strong="H1121"\w* eran contados entre \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* según sus \w casas|strong="H1004"\w* paternas, y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w de|strong="H1121"\w* 20 \w años|strong="H8141"\w* \w arriba|strong="H4605"\w* según su oficio y \w por|strong="H3881"\w* sus \w clases|strong="H4931"\w*.  
\v 18 \w Ellos|strong="H3605"\w* fueron contados \w con|strong="H3588"\w* \w todos|strong="H3605"\w* sus pequeños, sus esposas, sus \w hijos|strong="H1121"\w* \w y|strong="H3588"\w* sus \w hijas|strong="H1323"\w*, \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w multitud|strong="H6951"\w*, \w porque|strong="H3588"\w* se \w consagraban|strong="H6942"\w* fielmente \w en|strong="H3588"\w* \w santidad|strong="H6944"\w*.   
\p
\v 19 También \w para|strong="H5414"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón, \w los|strong="H1121"\w* cuales vivían en \w los|strong="H1121"\w* \w campos|strong="H7704"\w* alrededor \w de|strong="H1121"\w* sus \w ciudades|strong="H5892"\w*, \w los|strong="H1121"\w* \w varones|strong="H2145"\w* designados tenían \w el|strong="H3605"\w* encargo \w de|strong="H1121"\w* darles sus \w porciones|strong="H4490"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*, y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H1121"\w* eran \w de|strong="H1121"\w* las familias \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*.   
\p
\v 20 Ezequías \w hizo|strong="H6213"\w* \w de|strong="H6440"\w* \w esta|strong="H2063"\w* manera en \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w* y obró \w lo|strong="H6213"\w* \w bueno|strong="H2896"\w*, \w recto|strong="H3477"\w* y verdadero \w ante|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd*.  
\v 21 \w Buscó|strong="H1875"\w* \w a|strong="H3068"\w* su \nd ʼElohim\nd* con \w todo|strong="H3605"\w* su \w corazón|strong="H3824"\w* en \w lo|strong="H6213"\w* \w que|strong="H3605"\w* emprendió en \w el|strong="H3605"\w* servicio de \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd ʼElohim\nd*, según \w la|strong="H3605"\w* \w Ley|strong="H8451"\w* y \w los|strong="H3605"\w* \w Mandamientos|strong="H4687"\w*. Fue \w prosperado|strong="H6743"\w*.   
\c 32  
\s1 Invasión de Senaquerib  
\p
\v 1 \w Después|strong="H5921"\w* \w de|strong="H5921"\w* estas \w cosas|strong="H1697"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w esta|strong="H5921"\w* fidelidad, Senaquerib, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, llegó \w e|strong="H3068"\w* invadió \w Judá|strong="H3063"\w*. Sitió \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* propuso dominarlas.  
\v 2 \w Al|strong="H5921"\w* \w ver|strong="H7200"\w* Ezequías \w que|strong="H3588"\w* Senaquerib llegó \w con|strong="H5921"\w* intención \w de|strong="H5921"\w* \w combatir|strong="H4421"\w* \w contra|strong="H5921"\w* Jerusalén,  
\v 3 resolvió \w con|strong="H5973"\w* sus \w jefes|strong="H8269"\w* y sus \w valientes|strong="H1368"\w* cegar \w los|strong="H5973"\w* manantiales \w que|strong="H4325"\w* \w estaban|strong="H4325"\w* \w fuera|strong="H2351"\w* \w de|strong="H5973"\w* la \w ciudad|strong="H5892"\w*, y ellos lo apoyaron.  
\v 4 \w Mucho|strong="H7227"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* \w juntó|strong="H6908"\w* y \w cegaron|strong="H5640"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* manantiales, y también \w el|strong="H3605"\w* \w arroyo|strong="H5158"\w* \w que|strong="H4100"\w* fluía \w a|strong="H3068"\w* través del territorio, \w pues|strong="H6908"\w* dijeron: ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* \w de|strong="H5971"\w* Asiria deben \w hallar|strong="H4672"\w* \w agua|strong="H4325"\w* \w cuando|strong="H4100"\w* vengan?   
\p
\v 5 Ezequías \w se|strong="H5921"\w* \w animó|strong="H2388"\w*, reconstruyó \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w* \w que|strong="H5921"\w* estaba \w derribado|strong="H6555"\w* \w y|strong="H5921"\w* levantó \w torres|strong="H4026"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*. Levantó otro \w muro|strong="H2346"\w* \w por|strong="H5921"\w* \w fuera|strong="H2351"\w*, \w fortificó|strong="H2388"\w* \w el|strong="H5921"\w* terraplén \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Ciudad|strong="H5892"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w muchas|strong="H7230"\w* espadas \w y|strong="H5921"\w* \w escudos|strong="H4043"\w*.   
\p
\v 6 Designó \w jefes|strong="H8269"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w*. \w Los|strong="H5921"\w* reunió ante \w él|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* plaza \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w habló|strong="H1696"\w* \w al|strong="H5921"\w* \w corazón|strong="H3824"\w*:  
\v 7 ¡\w Esfuércense|strong="H2388"\w* \w y|strong="H3588"\w* sean valientes! \w No|strong="H3588"\w* \w teman|strong="H3372"\w* \w ni|strong="H5973"\w* desmayen \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Asiria \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w multitud|strong="H1995"\w* \w que|strong="H3588"\w* está \w con|strong="H5973"\w* \w él|strong="H5973"\w*, \w porque|strong="H3588"\w* \w más|strong="H3588"\w* \w son|strong="H3588"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* están \w con|strong="H5973"\w* \w nosotros|strong="H3605"\w* \w que|strong="H3588"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* están \w con|strong="H5973"\w* \w él|strong="H5973"\w*.  
\v 8 \w Con|strong="H5973"\w* \w él|strong="H5921"\w* \w está|strong="H5921"\w* un \w brazo|strong="H2220"\w* \w de|strong="H5921"\w* \w carne|strong="H1320"\w*, pero \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w* \w está|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd* \w para|strong="H5921"\w* ayudarnos \w y|strong="H5921"\w* pelear nuestras \w batallas|strong="H4421"\w*. \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* tuvo confianza \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w de|strong="H5921"\w* Ezequías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.   
\p
\v 9 \w Después|strong="H5921"\w* \w de|strong="H5921"\w* \w esto|strong="H2088"\w*, Senaquerib, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, \w quien|strong="H3605"\w* había sitiado Laquis \w con|strong="H5973"\w* \w todas|strong="H3605"\w* \w sus|strong="H1931"\w* fuerzas, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w sus|strong="H1931"\w* esclavos \w a|strong="H3068"\w* Jerusalén, \w a|strong="H3068"\w* Ezequías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w que|strong="H1931"\w* estaban \w en|strong="H5921"\w* Jerusalén, \w y|strong="H5921"\w* dijeron:   
\p
\v 10 Senaquerib, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, dice: ¿\w En|strong="H5921"\w* \w qué|strong="H4100"\w* confían ustedes quienes \w se|strong="H5921"\w* quedan sitiados \w en|strong="H5921"\w* Jerusalén?  
\v 11 ¿\w No|strong="H3808"\w* los engaña Ezequías \w para|strong="H5414"\w* entregarlos \w a|strong="H3068"\w* \w morir|strong="H4191"\w* \w de|strong="H5414"\w* \w hambre|strong="H7458"\w* y \w de|strong="H5414"\w* \w sed|strong="H6772"\w*, \w al|strong="H4428"\w* decir: \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd* nos \w librará|strong="H5337"\w* \w de|strong="H5414"\w* \w mano|strong="H3709"\w* del \w rey|strong="H4428"\w* \w de|strong="H5414"\w* Asiria?  
\v 12 ¿\w No|strong="H3808"\w* \w es|strong="H1931"\w* \w este|strong="H1931"\w* Ezequías \w el|strong="H1931"\w* \w mismo|strong="H1931"\w* \w que|strong="H1931"\w* \w quitó|strong="H5493"\w* \w sus|strong="H1931"\w* lugares \w altos|strong="H1116"\w* \w y|strong="H5921"\w* \w sus|strong="H1931"\w* \w altares|strong="H4196"\w*, \w y|strong="H5921"\w* ordenó \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* Jerusalén: \w Ante|strong="H6440"\w* \w este|strong="H1931"\w* único \w altar|strong="H4196"\w* \w se|strong="H1931"\w* postrarán, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w* quemarán incienso?  
\v 13 ¿\w No|strong="H3808"\w* \w saben|strong="H3045"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* \w yo|strong="H6213"\w* y mis antepasados \w hicimos|strong="H6213"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w* \w de|strong="H5971"\w* \w la|strong="H3605"\w* tierra? ¿\w Pudieron|strong="H3201"\w* \w los|strong="H3605"\w* \tl ʼelohim\tl* \w de|strong="H5971"\w* \w naciones|strong="H1471"\w* \w librar|strong="H5337"\w* su tierra \w de|strong="H5971"\w* mi \w mano|strong="H3027"\w*?  
\v 14 ¿\w Cuál|strong="H4310"\w* \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \tl ʼelohim\tl* \w de|strong="H3588"\w* las \w naciones|strong="H1471"\w* \w que|strong="H3588"\w* mis antepasados \w destruyeron|strong="H2763"\w* completamente, \w pudo|strong="H3201"\w* \w librar|strong="H5337"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w de|strong="H3588"\w* mi \w mano|strong="H3027"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* \nd ʼElohim\nd* \w pueda|strong="H3201"\w* librarlos \w a|strong="H3068"\w* ustedes \w de|strong="H3588"\w* mi \w mano|strong="H3027"\w*?   
\p
\v 15 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, \w no|strong="H3808"\w* \w los|strong="H3605"\w* \w engañe|strong="H5377"\w* Ezequías \w ni|strong="H3808"\w* \w los|strong="H3605"\w* persuada \w de|strong="H3588"\w* \w esta|strong="H2063"\w* manera, \w ni|strong="H3808"\w* le crean \w porque|strong="H3588"\w* \w ningún|strong="H3605"\w* \tl ʼelohim\tl* \w de|strong="H3588"\w* \w todas|strong="H3605"\w* aquellas \w naciones|strong="H1471"\w* \w o|strong="H3068"\w* \w reinos|strong="H4467"\w* \w pudo|strong="H3201"\w* \w librar|strong="H5337"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w de|strong="H3588"\w* mi \w mano|strong="H3027"\w*, \w ni|strong="H3808"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* mis antepasados. ¡\w Cuánto|strong="H3588"\w* \w menos|strong="H3588"\w* \w su|strong="H3588"\w* \nd ʼElohim\nd* \w podrá|strong="H3201"\w* librarlos \w de|strong="H3588"\w* mi \w mano|strong="H3027"\w*!   
\p
\v 16 Sus esclavos \w hablaron|strong="H1696"\w* muchas otras cosas \w contra|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w y|strong="H5921"\w* su esclavo Ezequías.  
\v 17 \w También|strong="H3651"\w* \w escribió|strong="H3789"\w* \w cartas|strong="H5612"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* cuales \w blasfemaba|strong="H2778"\w* \w contra|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*, ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* hablaba \w contra|strong="H5921"\w* \w Él|strong="H5921"\w* \w de|strong="H5921"\w* este modo: \w Así|strong="H3651"\w* \w como|strong="H5921"\w* \w los|strong="H5921"\w* \tl ʼelohim\tl* \w de|strong="H5921"\w* otras \w naciones|strong="H1471"\w* \w no|strong="H3808"\w* \w libraron|strong="H5337"\w* \w a|strong="H3068"\w* sus \w pueblos|strong="H5971"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*, \w tampoco|strong="H3808"\w* \w el|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* Ezequías \w librará|strong="H5337"\w* \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*.  
\v 18 Clamaban \w a|strong="H3068"\w* \w gran|strong="H1419"\w* \w voz|strong="H6963"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* lengua \w de|strong="H5921"\w* Judá \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* Jerusalén \w que|strong="H5921"\w* estaba \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w*, \w para|strong="H4616"\w* intimidarlos \w y|strong="H5921"\w* aterrorizarlos \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* tomar \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*.  
\v 19 \w Hablaron|strong="H1696"\w* \w del|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* Jerusalén \w como|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* son \tl ʼelohim\tl* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w obra|strong="H4639"\w* \w de|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* hombres.   
\p
