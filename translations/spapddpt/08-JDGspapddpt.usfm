\v 31 Así mantuvieron erigida \w para|strong="H1961"\w* \w ellos|strong="H3605"\w* \w la|strong="H3605"\w* \w imagen|strong="H6459"\w* tallada \w que|strong="H3117"\w* Micaía \w hizo|strong="H6213"\w*, \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w tiempo|strong="H3117"\w* \w que|strong="H3117"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd ʼElohim\nd* \w estuvo|strong="H1961"\w* en \w Silo|strong="H7887"\w*.
\c 19
\s1 El crimen de los benjamitas
\p 
\v 1 En \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w cuando|strong="H3117"\w* \w no|strong="H1961"\w* \w había|strong="H1961"\w* \w rey|strong="H4428"\w* en \w Israel|strong="H3478"\w*, \w sucedió|strong="H1961"\w* también \w que|strong="H3117"\w* cierto varón \w levita|strong="H3881"\w* \w que|strong="H3117"\w* residía en \w los|strong="H1992"\w* confines de la región montañosa de Efraín, \w tomó|strong="H3947"\w* \w como|strong="H1961"\w* \w concubina|strong="H6370"\w* \w a|strong="H3068"\w* una mujer de Belén de \w Judá|strong="H3063"\w*.
\v 2 Pero su \w concubina|strong="H6370"\w* cometió adulterio \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* abandonó. \w Se|strong="H1961"\w* \w fue|strong="H1961"\w* \w a|strong="H3068"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* su padre \w en|strong="H5921"\w* Belén \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w estuvo|strong="H1961"\w* \w allí|strong="H8033"\w* cuatro \w meses|strong="H2320"\w*.
\v 3 Pero su marido \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w siguió|strong="H3212"\w* \w para|strong="H5921"\w* \w hablarle|strong="H1696"\w* cariñosamente \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* \w que|strong="H5921"\w* volviera. Llevó \w consigo|strong="H5973"\w* \w a|strong="H3068"\w* un esclavo \w y|strong="H5921"\w* una yunta \w de|strong="H5921"\w* \w asnos|strong="H2543"\w*, \w y|strong="H5921"\w* \w ella|strong="H5921"\w* \w lo|strong="H5921"\w* invitó \w a|strong="H3068"\w* entrar \w en|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* su padre.
\v 4 \w Cuando|strong="H3117"\w* lo vio \w el|strong="H3427"\w* padre de la joven salió \w a|strong="H3068"\w* recibirlo gozoso y su \w suegro|strong="H2859"\w* lo detuvo, \w el|strong="H3427"\w* padre de la joven, y se \w quedó|strong="H3427"\w* en su casa \w tres|strong="H7969"\w* \w días|strong="H3117"\w*. Comía y bebía, y se alojaba \w allí|strong="H8033"\w*.
\p 
\v 5 \w Sucedió|strong="H1961"\w* el \w cuarto|strong="H7243"\w* \w día|strong="H3117"\w* \w que|strong="H3117"\w* \w se|strong="H1961"\w* \w levantaron|strong="H6965"\w* temprano por la \w mañana|strong="H1242"\w*, y él \w se|strong="H1961"\w* preparó \w para|strong="H1961"\w* salir. Pero el padre de la joven dijo \w a|strong="H3068"\w* su \w yerno|strong="H2860"\w*: Susténtate con un bocado de \w pan|strong="H3899"\w*, y \w después|strong="H1961"\w* pueden irse.
\v 6 Se \w sentaron|strong="H3427"\w*, \w pues|strong="H4994"\w*, y comieron \w los|strong="H3427"\w* \w dos|strong="H8147"\w* \w juntos|strong="H3162"\w* y \w bebieron|strong="H8354"\w*. \w Y|strong="H3068"\w* \w el|strong="H3427"\w* padre de la joven dijo al hombre: Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* pases aquí la noche y \w que|strong="H4994"\w* se alegre tu \w corazón|strong="H3820"\w*.
\v 7 \w El|strong="H3885"\w* hombre se \w levantó|strong="H6965"\w* para irse, pero su \w suegro|strong="H2859"\w* le insistió, y \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* pernoctar \w allí|strong="H8033"\w*.
\v 8 El \w quinto|strong="H2549"\w* \w día|strong="H3117"\w* se levantó \w de|strong="H5704"\w* \w mañana|strong="H1242"\w* \w para|strong="H5704"\w* salir, pero el padre \w de|strong="H5704"\w* la joven \w le|strong="H1242"\w* dijo: Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* te sustentes, \w y|strong="H5704"\w* esperes \w hasta|strong="H5704"\w* la noche. \w Y|strong="H3068"\w* \w ambos|strong="H8147"\w* comieron juntos.
\p 
\v 9 \w Cuando|strong="H3117"\w* \w el|strong="H1931"\w* hombre \w se|strong="H1931"\w* \w levantó|strong="H6965"\w* para salir con \w su|strong="H1931"\w* \w concubina|strong="H6370"\w* y \w su|strong="H1931"\w* esclavo, \w su|strong="H1931"\w* \w suegro|strong="H2859"\w*, \w el|strong="H1931"\w* padre de \w la|strong="H1931"\w* joven, \w le|strong="H1931"\w* dijo: \w Mira|strong="H2009"\w*, \w ya|strong="H4994"\w* llega \w la|strong="H1931"\w* noche. Quédate, te \w lo|strong="H1931"\w* \w ruego|strong="H4994"\w*, toda \w la|strong="H1931"\w* noche \add porque\add* \w el|strong="H1931"\w* \w día|strong="H3117"\w* declinó. Pasa \w aquí|strong="H6311"\w* \w la|strong="H1931"\w* noche y alégrese tu \w corazón|strong="H3824"\w*. \w Mañana|strong="H4279"\w* emprenderán temprano \w su|strong="H1931"\w* \w viaje|strong="H1870"\w*, y te \w irás|strong="H3212"\w* \w a|strong="H3068"\w* tu tienda.
\v 10 Pero \w el|strong="H1931"\w* hombre \w no|strong="H3808"\w* aceptó pasar allí \w la|strong="H1931"\w* noche, \w sino|strong="H3808"\w* \w se|strong="H1931"\w* \w levantó|strong="H6965"\w* \w y|strong="H5704"\w*, \w después|strong="H5704"\w* \w de|strong="H5973"\w* tomar camino, \w llegó|strong="H3212"\w* \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* frente \w de|strong="H5973"\w* Jebus, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* Jerusalén. Llevaba \w consigo|strong="H5973"\w* \w su|strong="H1931"\w* yunta \w de|strong="H5973"\w* \w asnos|strong="H2543"\w* \w enalbardados|strong="H2280"\w* \w y|strong="H5704"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w concubina|strong="H6370"\w*.
\p 
\v 11 \w Cuando|strong="H3117"\w* estuvieron \w junto|strong="H5973"\w* \w a|strong="H3068"\w* \w Jebus|strong="H2983"\w* \w se|strong="H1992"\w* acababa \w el|strong="H5973"\w* \w día|strong="H3117"\w*, por \w lo|strong="H1992"\w* \w cual|strong="H5973"\w* \w el|strong="H5973"\w* esclavo dijo \w a|strong="H3068"\w* \w su|strong="H1992"\w* \tl ʼadon\tl*: \w Ven|strong="H3212"\w*, \w te|strong="H5973"\w* \w ruego|strong="H4994"\w*, y desviémonos hacia \w aquella|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w de|strong="H5973"\w* \w los|strong="H1992"\w* \w jebuseos|strong="H2983"\w*, y pernoctemos \w en|strong="H5973"\w* ella.
\p 
\v 12 Pero su \tl ʼadón\tl* le respondió: \w No|strong="H3808"\w* nos desviaremos \w a|strong="H3068"\w* \w ninguna|strong="H3808"\w* \w ciudad|strong="H5892"\w* \w de|strong="H5704"\w* \w extranjeros|strong="H1121"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w son|strong="H3808"\w* \w de|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*, \w sino|strong="H3808"\w* seguiremos \w hasta|strong="H5704"\w* \w Gabaa|strong="H1390"\w*.
\v 13 \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* su esclavo: \w Ven|strong="H3212"\w*, nos acercamos \w a|strong="H3068"\w* uno de esos \w lugares|strong="H4725"\w* y pasaremos la noche \w en|strong="H3212"\w* \w Gabaa|strong="H1390"\w* \w o|strong="H3068"\w* \w en|strong="H3212"\w* \w Ramá|strong="H7414"\w*.
\v 14 Así que siguieron su camino, y \w el|strong="H5674"\w* \w sol|strong="H8121"\w* se les ocultó cerca de \w Gabaa|strong="H1390"\w*, que era de \w Benjamín|strong="H1144"\w*.
\v 15 Entraron \w para|strong="H5493"\w* pasar la noche \w en|strong="H5493"\w* \w Gabaa|strong="H1390"\w* y se \w sentaron|strong="H3427"\w* \w en|strong="H5493"\w* la plaza de la \w ciudad|strong="H5892"\w*, \w porque|strong="H8033"\w* no hubo quien \w los|strong="H3427"\w* recibiera \w en|strong="H5493"\w* su \w casa|strong="H1004"\w* \w para|strong="H5493"\w* pasar la noche.
\p 
\v 16 \w Y|strong="H3068"\w* \w mira|strong="H2009"\w*, regresaba un \w anciano|strong="H2205"\w* \w de|strong="H4480"\w* \w su|strong="H1931"\w* faena \w en|strong="H4480"\w* \w el|strong="H1931"\w* \w campo|strong="H7704"\w* \w al|strong="H4480"\w* anochecer. \w El|strong="H1931"\w* hombre \w era|strong="H1931"\w* \w de|strong="H4480"\w* \w la|strong="H1931"\w* región montañosa \w de|strong="H4480"\w* Efraín y \w se|strong="H1931"\w* albergaba \w en|strong="H4480"\w* \w Gabaa|strong="H1390"\w*, pero las gentes \w del|strong="H4480"\w* \w lugar|strong="H4725"\w* eran benjamitas.
\v 17 \w Levantó|strong="H5375"\w* sus \w ojos|strong="H5869"\w*, y al \w ver|strong="H7200"\w* al viajero \w en|strong="H3212"\w* la plaza \w de|strong="H5869"\w* la \w ciudad|strong="H5892"\w*, el \w anciano|strong="H2205"\w* preguntó: ¿\w A|strong="H3068"\w* dónde \w vas|strong="H3212"\w* y \w de|strong="H5869"\w* dónde \w vienes|strong="H3212"\w*?
\p 
\v 18 \w Y|strong="H3068"\w* le contestó: Estamos \w de|strong="H5704"\w* \w paso|strong="H5674"\w* \w desde|strong="H5704"\w* Belén \w de|strong="H5704"\w* \w Judá|strong="H3063"\w* \w hacia|strong="H8033"\w* la parte \w más|strong="H5704"\w* remota \w de|strong="H5704"\w* la región montañosa \w de|strong="H5704"\w* Efraín, \w de|strong="H5704"\w* \w donde|strong="H8033"\w* soy. \w Fui|strong="H3212"\w* \w a|strong="H3068"\w* Belén \w de|strong="H5704"\w* \w Judá|strong="H3063"\w* \w y|strong="H5704"\w* ahora \w voy|strong="H1980"\w* \w a|strong="H3068"\w* la \w Casa|strong="H1004"\w* \w de|strong="H5704"\w* \nd \w Yavé|strong="H3068"\w*\nd*, pero no hay quien me reciba \w en|strong="H5704"\w* su \w casa|strong="H1004"\w*.
\v 19 \w Tenemos|strong="H3426"\w* pasto \w y|strong="H1571"\w* \w forraje|strong="H4554"\w* \w para|strong="H5973"\w* nuestros \w asnos|strong="H2543"\w*, \w así|strong="H1571"\w* \w como|strong="H1571"\w* \w pan|strong="H3899"\w* \w y|strong="H1571"\w* \w vino|strong="H3196"\w* \w para|strong="H5973"\w* mí, \w para|strong="H5973"\w* \w tu|strong="H3426"\w* esclava \w y|strong="H1571"\w* \w para|strong="H5973"\w* \w el|strong="H5973"\w* esclavo \w que|strong="H1571"\w* \w va|strong="H3068"\w* \w con|strong="H5973"\w* \w tu|strong="H3426"\w* esclava. \w Nada|strong="H1697"\w* nos \w falta|strong="H4270"\w*.
\p 
\v 20 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* hombre \w anciano|strong="H2205"\w* dijo: ¡\w Paz|strong="H7965"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*! \w Toda|strong="H3605"\w* tu necesidad \w estará|strong="H3605"\w* exclusivamente \w a|strong="H3068"\w* \w mi|strong="H5921"\w* cargo, \w solo|strong="H7535"\w* \w que|strong="H5921"\w* \w no|strong="H5921"\w* pases \w la|strong="H5921"\w* noche \w en|strong="H5921"\w* \w la|strong="H5921"\w* plaza abierta.
\v 21 Los llevó \w a|strong="H3068"\w* su \w casa|strong="H1004"\w* y dio forraje \w a|strong="H3068"\w* sus \w asnos|strong="H2543"\w*. Luego se lavaron los \w pies|strong="H7272"\w*, comieron y \w bebieron|strong="H8354"\w*.
\p 
\v 22 Mientras celebraban, llegaron ahí \w unos|strong="H1992"\w* \w hombres|strong="H1121"\w* \w perversos|strong="H1121"\w* \w de|strong="H5921"\w* \w aquella|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w que|strong="H5921"\w* rodearon \w la|strong="H5921"\w* \w casa|strong="H1004"\w*. \w Se|strong="H3045"\w* agolparon \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H1817"\w* \w y|strong="H5921"\w* hablaron \w al|strong="H5921"\w* \w anciano|strong="H2205"\w* \w dueño|strong="H1167"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*, \w y|strong="H5921"\w* dijeron: ¡Sácanos \w al|strong="H5921"\w* \w hombre|strong="H1121"\w* \w que|strong="H5921"\w* entró \w a|strong="H3068"\w* tu \w casa|strong="H1004"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* tengamos relaciones sexuales \w con|strong="H5921"\w* \w él|strong="H5921"\w*!
\p 
\v 23 \w El|strong="H6213"\w* \w dueño|strong="H1167"\w* de \w la|strong="H2063"\w* \w casa|strong="H1004"\w* \w salió|strong="H3318"\w* \w a|strong="H3068"\w* ellos y les dijo: \w No|strong="H6213"\w*, hermanos míos, les \w ruego|strong="H4994"\w*. \w No|strong="H6213"\w* \w hagan|strong="H6213"\w* \w esta|strong="H2063"\w* \w maldad|strong="H5039"\w* puesto \w que|strong="H4994"\w* \w este|strong="H2088"\w* hombre entró \w en|strong="H3318"\w* \w mi|strong="H4994"\w* \w casa|strong="H1004"\w*. \w No|strong="H6213"\w* cometan \w tal|strong="H2088"\w* infamia.
\v 24 \w Aquí|strong="H2009"\w* \w está|strong="H2063"\w* \w mi|strong="H2009"\w* \w hija|strong="H1323"\w* \w virgen|strong="H1330"\w* y \w la|strong="H2063"\w* \w concubina|strong="H6370"\w* \w de|strong="H1697"\w* \w él|strong="H6213"\w*. \w A|strong="H3068"\w* \w éstas|strong="H2088"\w* les sacaré \w si|strong="H3808"\w* les \w place|strong="H2896"\w*, y humíllenlas. \w Hagan|strong="H6213"\w* con \w ellas|strong="H2009"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* les parezca \w bien|strong="H2896"\w*, pero \w a|strong="H3068"\w* \w este|strong="H2088"\w* hombre \w no|strong="H3808"\w* \w le|strong="H5869"\w* \w hagan|strong="H6213"\w* \w tal|strong="H2088"\w* infamia.
\p 
\v 25 Pero \w los|strong="H3605"\w* hombres \w no|strong="H3808"\w* quisieron escucharlo, \w por|strong="H5704"\w* \w lo|strong="H3808"\w* cual \w el|strong="H3605"\w* hombre obligó \w a|strong="H3068"\w* su \w concubina|strong="H6370"\w* \w y|strong="H5704"\w* \w la|strong="H3605"\w* \w hizo|strong="H5927"\w* \w salir|strong="H3318"\w* \w a|strong="H3068"\w* \w ellos|strong="H3605"\w*, \w los|strong="H3605"\w* cuales abusaron sexualmente \w de|strong="H5704"\w* \w ella|strong="H3605"\w* \w toda|strong="H3605"\w* aquella \w noche|strong="H3915"\w* \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* \w mañana|strong="H1242"\w* \w y|strong="H5704"\w* \w la|strong="H3605"\w* dejaron \w al|strong="H5704"\w* \w rayar|strong="H5927"\w* \w el|strong="H3605"\w* alba.
