\q2 \w et|strong="H3212"\w* \w fleuriront|strong="H1961"\w* \w comme|strong="H1961"\w* \w la|strong="H3212"\w* vigne.  
\q2 \w Leur|strong="H1961"\w* \w parfum|strong="H7381"\w* \w sera|strong="H1961"\w* \w comme|strong="H1961"\w* \w le|strong="H1961"\w* \w vin|strong="H3212"\w* \w du|strong="H3212"\w* \w Liban|strong="H3844"\w*.   
\q1
\v 8 Éphraïm, qu'ai-je \w encore|strong="H7725"\w* \w à|strong="H3427"\w* \w faire|strong="H3427"\w* \w avec|strong="H3427"\w* \w les|strong="H7725"\w* \w idoles|strong="H7725"\w* ?  
\q2 \w Je|strong="H3068"\w* \w lui|strong="H7725"\w* \w réponds|strong="H7725"\w*, \w et|strong="H7725"\w* \w je|strong="H7725"\w* prendrai soin \w de|strong="H3427"\w* \w lui|strong="H7725"\w*.  
