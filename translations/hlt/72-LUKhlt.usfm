\s1 Pharisee neh Mangmucoi Kah Thangthuinah  
\p
\v 9 \w A\w* \w dueng|strong="G1342"\w* \w la\w* \w om|strong="G1526"\w* \w ham|strong="G3754"\w* \w amah|strong="G1438"\w* \w neh|strong="G1909"\w* \w amah \w* \w pangtung|strong="G3982"\w* \w tih|strong="G2532"\w* \w a\w* \w tloe|strong="G3062"\w* \w aka \w*\w hnaelcoe|strong="G1848"\w* \w hlangvang|strong="G5100"\w* \w rhoek \w* \w te|strong="G4314"\w* \w khaw|strong="G2532"\w* \w hekah|strong="G5026"\w* \w nuettahnah|strong="G3850"\w* neh,  
\v 10 “\wj \+w Hlang|strong="G0444"\+w* \+w panit|strong="G1417"\+w* tah \+w thangthui|strong="G4336"\+w* ham \+w bawkim|strong="G2411"\+w* \+w la|strong="G1519"\+w* \+w cet|strong="G0305"\+w* rhoi. \+w Pakhat|strong="G1520"\+w* \+w tah|strong="G3588"\+w* \+w Pharisee|strong="G5330"\+w* \+w tih|strong="G2532"\+w* \+w pakhat|strong="G2087"\+w* \+w te|strong="G3588"\+w* \+w mangmu|strong="G5057"\+w* aka coi ni\wj*.  
\v 11 \wj \+w Pharisee|strong="G5330"\+w* \+w tah|strong="G3588"\+w* \+w amah|strong="G1438"\+w* \+w la|strong="G4314"\+w* \+w pai|strong="G2476"\+w* tih\wj*, \wj “ \+w Hlang|strong="G0444"\+w* \+w tloe|strong="G3062"\+w* \+w kutveet|strong="G0727"\+w* aka khueh, \+w halang|strong="G0094"\+w* rhoek, \+w samphaih|strong="G3432"\+w* rhoek, \+w neh|strong="G2228"\+w* \+w he|strong="G3778"\+w* kah \+w mangmucoi|strong="G5057"\+w* \+w bangla|strong="G5613"\+w* ka \+w om|strong="G1510"\+w* \+w pawt|strong="G3756"\+w* \+w dongah|strong="G3754"\+w* \+w Pathen|strong="G2316"\+w* \+w nang|strong="G4671"\+w* he kan \+w uem|strong="G2168"\+w*\wj*,  
