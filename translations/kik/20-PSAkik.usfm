\id PSA - Biblica® Open Kikuyu Holy Word of God
\h Thaburi
\toc1 Thaburi
\toc2 Thaburi
\toc3 Thab
\mt1 THABURI
\c 1
\ms1 Ibuku rĩa Mbere
\mr Thaburi 1–41
\s1 Gĩkeno Kĩrĩa kĩa Ma
\q1 
\v 1 Kũrathimwo-rĩ, nĩ mũndũ
\q2 ũrĩa ũtatwaranaga na ũtaaro wa andũ arĩa aaganu,
\q1 kana akarũgama njĩra-inĩ ya andũ arĩa mehagia,
\q2 o na kana agaikarĩra gĩtĩ kĩa arĩa manyũrũranagia.
\q1 
\v 2 No rĩrĩ, nĩ watho wa Jehova akenagĩra,
\q2 na agecũũranagia ũhoro wa watho wake kũrĩ mũthenya kana ũtukũ.
\q1 
\v 3 Mũndũ ũcio ahaana ta mũtĩ mũhaande tũmĩtaro-inĩ twa maaĩ,
\q2 naguo ũciaraga maciaro maguo hĩndĩ ya mo yakinya,
\q1 namo mathangũ maguo matihoohaga.
\q2 Na rĩrĩ, ũndũ o wothe ekaga nĩũgaacagĩra.
\b
\q1 
\v 4 No andũ arĩa aaganu matihaana ũguo!
\q2 Mahaana ta mũũngũ
\q2 ũrĩa ũmbũragwo nĩ rũhuho.
\q1 
\v 5 Nĩ ũndũ ũcio andũ arĩa aaganu matigetiiria ciira-inĩ,
\q2 kana andũ arĩa ehia metiirie kĩũngano-inĩ kĩa andũ arĩa athingu.
\b
\q1 
\v 6 Nĩgũkorwo Jehova nĩamenyagĩrĩra njĩra ya andũ arĩa athingu,
\q2 no andũ arĩa aaganu marĩ njĩra-inĩ ya kũũra.
\c 2
\s1 Mũthamaki ũrĩa Ũthuurĩtwo nĩ Ngai
\q1 
\v 1 Nĩ kĩĩ gĩtũmaga ndũrĩrĩ iciirĩre gwĩka ũũru
\q2 na andũ mathugunde maũndũ ma tũhũ?
\q1 
\v 2 Athamaki a thĩ nĩmatuĩte itua,
\q2 na aathani magacookania ndundu nĩguo mookĩrĩre Jehova,
\q2 na mookĩrĩre Ũrĩa wake Mũitĩrĩrie Maguta.
\q1 
\v 3 Moigaga atĩrĩ, “Nĩtwĩohorei mĩnyororo yao,
\q2 na mabĩngũ mao tũmate matweherere.”
\b
\q1 
\v 4 Ũrĩa ũikarĩire gĩtĩ kĩa ũnene kũu igũrũ no gũtheka aratheka;
\q2 We Mwathani-rĩ, nĩkũnyũrũria aramanyũrũria.
\q1 
\v 5 Ningĩ agacooka akamakũũma arakarĩte,
\q2 na akamekĩra guoya mũnene angʼũrĩkĩte akameera atĩrĩ,
\q1 
\v 6 “Niĩ nĩ niĩ njigĩte Mũthamaki wakwa
\q2 kũu Zayuni, kĩrĩma-inĩ gĩakwa kĩrĩa kĩamũre.”
\b
\q2 
\v 7 Niĩ nĩngwanĩrĩra itua rĩa Jehova:
\q1 Jehova aanjĩĩrire atĩrĩ, “Wee nĩwe Mũrũ wakwa,
\q2 ũmũthĩ nĩndatuĩka thoguo.
\q1 
\v 8 Hooya niĩ,
\q2 na nĩngũkũhe ndũrĩrĩ ituĩke igai rĩaku,
\q2 nacio ituri cia thĩ ituĩke ciaku kĩũmbe.
\q1 
\v 9 Nĩũgaciunanga na njũgũma ya kĩgera ya ũthamaki;
\q2 ũgaacihehenja ihaane ta tũcunjĩ twa nyũngũ ya rĩũmba.”
\b
\q1 
\v 10 Nĩ ũndũ ũcio, inyuĩ athamaki ta kĩũhĩgeei,
\q2 inyuĩ aathani a thĩ mũtaarĩke.
\q1 
\v 11 Tungatĩrai Jehova mũkĩmwĩtigagĩra,
\q2 na mũkene o mũkĩinainaga.
\q1 
\v 12 Mumunyai Mũriũ, ndakae kũrakara,
\q2 na inyuĩ mũniinĩrwo njĩra-inĩ,
\q1 nĩgũkorwo mangʼũrĩ make maahota kũrĩrĩmbũka o rĩmwe.
\q2 Kũrathimwo-rĩ, nĩ arĩa othe moragĩra harĩ we.
\c 3
\s1 Ihooya rĩa Rũciinĩ rĩa kũũria Ũteithio
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, kaĩ thũ ciakwa nĩ nyingĩ-ĩ!
\q2 Andũ arĩa manjũkĩrĩire nĩ aingĩ mũno!
\q1 
\v 2 Aingĩ nĩ arĩa maraaria ũhoro wakwa, makoiga atĩrĩ,
\q2 “Ngai ndangĩmũhonokia.”
\b
\q1 
\v 3 No rĩrĩ, Wee Jehova nĩwe ngo ya kũngitĩra mĩena yothe;
\q2 Wee nowe ũũheaga riiri na ũgatũũgĩria mũtwe wakwa.
\q1 
\v 4 Ngayagĩra Jehova na mũgambo mũnene,
\q2 nake akanjĩtĩka arĩ kĩrĩma-inĩ gĩake kĩamũre.
\b
\q1 
\v 5 Niĩ ngomaga na ngoona toro;
\q2 ngacooka ngokĩra rĩngĩ, tondũ Jehova nĩwe ũndũũragia.
\q1 
\v 6 Ndingĩĩtigĩra andũ makũmi ma ngiri,
\q2 acio mehaarĩirie kũnjũkĩrĩra na mĩena yothe.
\b
\q1 
\v 7 Arahũka, Wee Jehova!
\q2 Wee Ngai wakwa, honokia!
\q1 Thũ ciakwa ciothe nĩwe ũcigũthĩte thĩa,
\q2 na ũkoinanga magego ma andũ arĩa aaganu.
\b
\q1 
\v 8 Ũhonokio uumaga harĩ Jehova.
\q2 Irathimo ciaku irotũũra na andũ aku.
\c 4
\s1 Ihooya rĩa Hwaĩ-inĩ
\d Thaburi ya Daudi
\q1 
\v 1 Njĩtĩka rĩrĩa ndagũkaĩra,
\q2 Wee Ngai wakwa, o Wee mũthingu.
\q1 Ũndeithagie rĩrĩa ndĩ mĩnyamaro-inĩ;
\q2 njiguĩra tha na ũigue mahooya makwa.
\b
\q1 
\v 2 Inyuĩ, andũ aya, nĩ nginya rĩ mũgũtũũra mũtũmaga riiri wakwa ũnyararwo?
\q2 Nĩ nginya rĩ mũgũtũũra mwendete maũndũ ma tũhũ,
\q2 na mũkarongoragia ngai cia maheeni?
\q1 
\v 3 Menyai atĩ Jehova nĩeyamũrĩire arĩa mamwendete;
\q2 Jehova nĩarĩiguaga rĩrĩa ndamũkaĩra.
\b
\q1 
\v 4 Mũngĩrakara mũtikehie;
\q2 rĩrĩa mũrĩ marĩrĩ-inĩ manyu-rĩ,
\q2 thuthuuragiai ngoro cianyu mwĩkirĩire.
\q1 
\v 5 Rutagai magongona marĩa magĩrĩire,
\q2 na mwĩhokage Jehova.
\b
\q1 
\v 6 Kũrĩ andũ aingĩ maroria atĩrĩ,
\q2 “Nũũ ũngĩtuonia maũndũ mega?”
\q2 Wee Jehova reke ũtheri wa gĩthiithi gĩaku ũtwarĩre.
\q1 
\v 7 Wee nĩũnjiyũrĩtie gĩkeno kĩnene ngoro-inĩ yakwa,
\q2 gũkĩra kĩrĩa makoragwo nakĩo hĩndĩ ya bũthi wa ngano na ndibei ya mũhihano.
\q1 
\v 8 Niĩ ndĩrĩkomaga na nyonage toro ndĩ na thayũ,
\q2 nĩgũkorwo Wee Jehova nĩwe
\q2 ũikaraga ũũmenyereire wega.
\c 5
\s1 Ihooya rĩa kũũria Ũgitĩri kuuma kũrĩ Thũ
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, igua ciugo ciakwa,
\q2 na ũigue gũcaaya gwakwa.
\q1 
\v 2 Thikĩrĩria ngĩgũkaĩra ũndeithie,
\q2 Mũthamaki wakwa na Ngai wakwa,
\q2 nĩgũkorwo nĩwe ndĩrahooya.
\q1 
\v 3 Wee Jehova-rĩ, o rũciinĩ ũrĩiguaga mũgambo wakwa;
\q2 o kĩrooko ndĩrĩigaga mabataro makwa mbere yaku,
\q2 na ngeterera macookio ndĩ na kĩĩrĩgĩrĩro.
\b
\q1 
\v 4 Nĩgũkorwo Wee ndũrĩ Mũrungu wa gũkenera ũũru;
\q2 ningĩ andũ arĩa aaganu ndũngĩtũũrania nao.
\q1 
\v 5 Andũ arĩa etĩĩi matingĩrũgama mbere yaku;
\q2 andũ arĩa othe mekaga maũndũ mooru nĩũmathũire.
\q1 
\v 6 Andũ arĩa maaragia maheeni nĩũmaniinaga;
\q2 nao arĩa maitaga thakame na makaheenania,
\q2 Jehova nĩamathũire.
\b
\q1 
\v 7 No niĩ-rĩ, nĩ ũndũ wa tha ciaku nyingĩ,
\q2 nĩngũũka ndoonye nyũmba yaku;
\q2 ndĩnyiihĩtie nyinamĩrĩre ndorete hekarũ-inĩ yaku theru.
\q1 
\v 8 Wee Jehova-rĩ, ndongoria na ũthingu waku;
\q2 nĩ ũndũ wa thũ ciakwa-rĩ,
\q2 rũngaria njĩra yaku mbere yakwa.
\b
\q1 
\v 9 Tũnua twacio tũtiaragia ũhoro ũngĩĩhokwo;
\q2 ngoro ciacio ciyũrĩte mwanangĩko.
\q1 Mĩmero yacio nĩ ta mbĩrĩra ngunũre;
\q2 ciaragia maheeni na rũrĩmĩ rwacio.
\q1 
\v 10 Wee Ngai, matue nĩmahĩtĩtie!
\q2 Reke magũithio nĩ mĩbango ĩyo yao ya ungumania.
\q1 Maingate nĩ ũndũ wa mehia mao maingĩ,
\q2 nĩgũkorwo nĩmakũremeire.
\b
\q1 
\v 11 No rĩrĩ, reke arĩa moragĩra harĩwe makene;
\q2 nĩmarekwo mainage hĩndĩ ciothe nĩ gũkena.
\q1 Tambũrũkia ũgitĩri waku igũrũ rĩao,
\q2 nĩguo arĩa mendete rĩĩtwa rĩaku magũkenagĩre.
\q1 
\v 12 Nĩ ũndũ ti-itherũ Wee Jehova nĩũrathimaga andũ arĩa athingu;
\q2 ũtũũraga ũmairigĩire na wega waku taarĩ ngo.
\c 6
\s1 Ihooya rĩa kũũria Ũteithio Hĩndĩ ya Thĩĩna
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, ndũkandũithie ũrĩ na marakara,
\q2 o na kana ũũherithie ũrĩ na mangʼũrĩ.
\q1 
\v 2 Jehova, njiguĩra tha, nĩgũkorwo nĩthirĩtwo nĩ hinya;
\q2 Wee Jehova honia, nĩgũkorwo mahĩndĩ makwa marĩ na ruo rũnene.
\q1 
\v 3 O nayo ngoro yakwa ĩrĩ na ruo rũnene.
\q2 Nĩ nginya rĩ, Wee Jehova, nĩ nginya rĩ?
\b
\q1 
\v 4 Wee Jehova, cooka, ũka ũũthare;
\q2 honokia tondũ wa wendo waku ũrĩa ũtathiraga.
\q1 
\v 5 Gũtirĩ mũndũ ũngĩkũririkana arĩ mũkuũ.
\q2 Nũũ ũkũgoocaga arĩ thĩinĩ wa mbĩrĩra?
\b
\q1 
\v 6 Niĩ ndĩ mũnogu mũno nĩ ũndũ wa gũcaaya;
\q2 ũtukũ wothe njihũgagia ũrĩrĩ wakwa na kĩrĩro,
\q2 na ngaconjoria gĩtĩ gĩakwa na maithori.
\q1 
\v 7 Maitho makwa matirona wega nĩ ũndũ wa ihooru;
\q2 nĩmaroora nĩ ũndũ wa thũ ciakwa ciothe.
\b
\q1 
\v 8 Njehererai inyuĩ arĩa othe mwĩkaga ũũru,
\q2 nĩgũkorwo Jehova nĩaiguĩte kĩrĩro gĩakwa.
\q1 
\v 9 Jehova nĩaiguĩte ngĩmũthaitha anjiguĩre tha;
\q2 Jehova nĩetĩkĩrĩte ihooya rĩakwa.
\q1 
\v 10 Thũ ciakwa ciothe nĩigaconoka na imake;
\q2 igaacooka na thuutha o rĩmwe iconokete.
\c 7
\s1 Ihooya rĩa kũũria Gũtharwo Kuuma kũrĩ Thũ
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova Ngai wakwa, nĩngwĩhitha harĩwe;
\q2 honokia na ũũthare kuuma kũrĩ arĩa othe manyingatithagia,
\q1 
\v 2 tondũ waga gwĩka ũguo mekũndembũranga o ta mũrũũthi,
\q1 o na mandinangie icunjĩ hatarĩ mũndũ ũngĩndeithia.
\b
\q1 
\v 3 Wee Jehova Ngai wakwa, ingĩkorwo nĩnjĩkĩte ũndũ ũcio,
\q2 na ngorwo njĩkĩte ũũru na moko makwa,
\q1 
\v 4 na ingĩkorwo njĩkĩte mũndũ ũũru ũrĩa ũtarĩ na haaro na niĩ,
\q2 kana ngatunya thũ yakwa kĩndũ hatarĩ gĩtũmi-rĩ,
\q1 
\v 5 hĩndĩ ĩyo kĩreke thũ yakwa ĩnyiingatithie na ĩĩnyiite;
\q2 tũma ĩrangĩrĩrie muoyo wakwa tĩĩri-inĩ,
\q2 na ĩtũme ngome rũkũngũ-inĩ.
\b
\q1 
\v 6 Arahũka Wee Jehova, marakara-inĩ maku;
\q2 rũgama ũũkĩrĩre thũ ciakwa na marũrũ.
\q2 Ũkĩra Wee Ngai wakwa, ũtuanĩre ciira na kĩhooto.
\q1 
\v 7 Andũ a ndũrĩrĩ arĩa monganĩte nĩmagũthiũrũrũkĩrie.
\q2 Mathamakĩre ũrĩ kũu igũrũ;
\q2 
\v 8 Jehova nĩagĩtuĩre andũ othe ciira.
\q1 Wee Jehova, nduĩra ciira, kũringana na ũthingu wakwa,
\q2 na kũringana na ũrũngĩrĩru wakwa, Wee Ũrĩ-Igũrũ-Mũno.
\q1 
\v 9 Wee Ngai mũthingu,
\q2 o Wee ũthuthuuragia meciiria na ngoro,
\q1 kinyia ũhinya wa andũ arĩa aaganu mũthia,
\q2 na ũtũme andũ arĩa athingu matũũre na thayũ.
\b
\q1 
\v 10 Ngai-Ũrĩa-ũrĩ-Igũrũ-Mũno nĩwe ngo yakwa,
\q2 ũrĩa ũhonokagia arĩa arũngĩrĩru ngoro.
\q1 
\v 11 Ngai nĩwe ũtuanagĩra ciira na kĩhooto,
\q2 nĩ Mũrungu ũrĩa wonanagia marakara make o mũthenya.
\q1 
\v 12 Mũndũ angĩaga kũgarũrũka,
\q2 nĩekũmũnoorera rũhiũ rwake rwa njora;
\q2 ũta wake nĩaũtungĩte na akaũgeeta.
\q1 
\v 13 Nĩahaarĩirie indo ciake cia mbaara cia kũũragana;
\q2 akahaarĩria mĩguĩ yake ĩkũrĩrĩmbũka mwaki.
\b
\q1 
\v 14 Mũndũ ũrĩa ũgĩte nda ya waganu,
\q2 na akooha nda ya thĩĩna, aciaraga maheeni.
\q1 
\v 15 Mũndũ ũrĩa wenjaga irima na akarĩthikũria,
\q2 agũũaga o irima rĩu enjete.
\q1 
\v 16 Thĩĩna ũrĩa aambĩrĩirie ũmũcookagĩrĩra we mwene,
\q2 haaro yake ĩkamũgwĩra mũtwe wake mwene.
\b
\q1 
\v 17 Nĩngũcookeria Jehova ngaatho tondũ wa ũthingu wake,
\q2 na ngooce rĩĩtwa rĩa Jehova Ũrĩa-ũrĩ-Igũrũ-Mũno na rwĩmbo.
\c 8
\s1 Ũũmbi Wonanagia Riiri wa Ngai
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, o Wee Mwathani witũ,
\q2 kaĩ rĩĩtwa rĩaku nĩ inene gũkũ thĩ yothe-ĩ!
\b
\q1 Nĩũigĩte riiri waku o igũrũ matu-inĩ.
\q1 
\v 2 Nĩũtũmĩte rũgooco ruume tũnua-inĩ twa ciana na twa ngenge,
\q1 nĩ tondũ wa thũ ciaku,
\q2 nĩguo ũkirie ũrĩa ũrĩ muku nawe o na mwĩrĩhĩria.
\b
\q1 
\v 3 Rĩrĩa ndecũũrania ũhoro ũkoniĩ igũrũ rĩu rĩaku,
\q2 ngoona wĩra wa ciara ciaku,
\q1 mweri na njata icio wĩkĩrĩte kuo-rĩ,
\q1 
\v 4 mũndũ akĩrĩ kĩ tondũ ũikaraga ũkĩmwĩciiragia,
\q2 nake mũrũ wa mũndũ akĩrĩ kĩ atĩ nĩkĩo ũmũmenyagĩrĩra?
\q1 
\v 5 Watũmire atigie o hanini aiganane nawe,
\q2 na ũkĩmũhumba thũmbĩ ya riiri o na gĩtĩĩo.
\b
\q1 
\v 6 Wamũtuire wa gwathaga mawĩra ma moko maku;
\q2 ũkĩiga indo ciothe rungu rwa makinya make:
\q1 
\v 7 ndũũru ciothe cia mbũri na cia ngʼombe,
\q2 na nyamũ cia gĩthaka,
\q1 
\v 8 na nyoni cia rĩera-inĩ,
\q2 na thamaki cia iria-inĩ,
\q2 na kĩrĩa gĩothe kĩgeragĩra kũu iria-inĩ thĩinĩ.
\b
\q1 
\v 9 Wee Jehova, o Wee Mwathani witũ,
\q2 kaĩ rĩĩtwa rĩaku nĩ inene gũkũ thĩ yothe-ĩ!
\c 9
\s1 Wathani wa Ngai wa Kĩhooto
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, nĩngũkũgooca na ngoro yakwa yothe;
\q2 nĩngũgana maũndũ maku mothe ma magegania marĩa wĩkĩte.
\q1 
\v 2 Nĩngũcanjamũka na ngene nĩ ũndũ waku.
\q2 Nĩngũina rwĩmbo ngooce rĩĩtwa rĩaku, Wee Ũrĩ-Igũrũ-Mũno.
\b
\q1 
\v 3 Thũ ciakwa icookaga na thuutha,
\q2 ikahĩngwo igathira irĩ mbere yaku.
\q1 
\v 4 Nĩgũkorwo nĩũtiirĩrĩire kĩhooto gĩakwa na ciira wakwa;
\q2 nĩũikarĩire gĩtĩ gĩaku kĩa ũnene, na ũgatua ciira na ũthingu.
\q1 
\v 5 Nĩũrũithĩtie ndũrĩrĩ na ũkaniina andũ arĩa aaganu;
\q2 namo marĩĩtwa mao ũkamatharia tene na tene.
\q1 
\v 6 Thũ nĩũcikinyĩirie mwanangĩko ũtathiraga,
\q2 nĩwanangĩte matũũra macio manene;
\q2 o na kũririkanwo kwao nĩgũthirĩte.
\b
\q1 
\v 7 Jehova athamakaga nginya tene;
\q2 nĩahaandĩte gĩtĩ gĩake kĩa ũnene nĩguo atuanĩre ciira.
\q1 
\v 8 Nĩagatuĩra andũ a thĩ ciira na kĩhooto;
\q2 nĩagathamakĩra ndũrĩrĩ o ta ũrĩa kwagĩrĩire.
\q1 
\v 9 Jehova nĩwe rĩũrĩro rĩa arĩa ahinyĩrĩrie,
\q2 kĩĩhitho kĩrĩ hinya hĩndĩ ya mathĩĩna.
\q1 
\v 10 Arĩa mooĩ rĩĩtwa rĩaku nĩmarĩkwĩhokaga,
\q2 nĩgũkorwo Jehova ndũrĩ watiganĩria arĩa makũrongoragia.
\b
\q1 
\v 11 Inĩrai Jehova nyĩmbo mũmũgooce,
\q2 o ũcio ũikarĩire gĩtĩ gĩake kĩa ũnene kũu Zayuni;
\q2 umbũrĩrai andũ a ndũrĩrĩ maũndũ marĩa ekĩte.
\q1 
\v 12 Nĩgũkorwo ũcio ũrĩhanagĩria thakame nĩamaririkanaga;
\q2 kĩrĩro kĩa andũ arĩa ahinyĩrĩrĩku ndakariganĩrwo nĩkĩo.
\b
\q1 
\v 13 Wee Jehova, ta rora wone ũrĩa thũ ciakwa iranyariira!
\q2 Njiguĩra tha, ũnjoe na igũrũ, ũndute kuuma ihingo-inĩ cia gĩkuũ,
\q1 
\v 14 nĩguo nyumbũre ũgooci waku
\q2 ndĩ kũu ihingo-inĩ cia Mwarĩ wa Zayuni,
\q2 na ndĩ kũu ngenagĩre ũhonokio waku.
\q1 
\v 15 Ndũrĩrĩ nĩigwĩte o irima rĩrĩa cienjete;
\q2 magũrũ maacio nĩmanyiitĩtwo nĩ wabu o ũcio ihithĩte wa gũtegana.
\q1 
\v 16 Jehova nĩemenyithanĩtie na ũndũ wa gũtuanĩra ciira na kĩhooto gĩake;
\q2 andũ arĩa aaganu nĩmetegete na wĩra wa moko mao ene.
\b
\q1 
\v 17 Andũ arĩa aaganu macookaga o mbĩrĩra-inĩ,
\q2 ĩĩ-ni, ndũrĩrĩ iria ciothe iriganagĩrwo nĩ Ngai.
\q1 
\v 18 No rĩrĩ, andũ arĩa abatari matigũtũũra mariganĩire,
\q2 na kana mwĩhoko wa arĩa ahinyĩrĩrie ũthire nginya tene.
\b
\q1 
\v 19 Wee Jehova, arahũka, Ndũkareke mũndũ agĩe na ũhootani;
\q2 reke ndũrĩrĩ ituĩrwo ciira irĩ mbere yaku.
\q1 
\v 20 Wee Jehova, maiguithie guoya,
\q2 ũreke ndũrĩrĩ imenye atĩ cio no andũ.
\c 10
\s1 Ũnene wa Ngai
\q1 
\v 1 Wee Jehova, ũkũrũgama haraaya nĩkĩ?
\q2 Wĩhithaga nĩkĩ hĩndĩ ya mathĩĩna?
\b
\q1 
\v 2 Mũndũ ũrĩa mwaganu etĩĩaga rĩrĩa ekũhĩta andũ arĩa matarĩ hinya,
\q2 rĩrĩa magwatio nĩ mĩbango ĩyo mathugundĩte.
\q1 
\v 3 Mũndũ ũrĩa mwaganu erahagĩra merirĩria ma ngoro yake;
\q2 arathimaga andũ arĩa akoroku, na akaruma Jehova.
\q1 
\v 4 Mũndũ ũcio mwĩtĩĩi ndarongoragia Ngai;
\q2 meciiria-inĩ make mothe ndeciiragia ũhoro wa Ngai.
\q1 
\v 5 Njĩra ciake ciikaraga igaacĩire hĩndĩ ciothe;
\q2 we nĩ mwĩtĩĩi mũno, namo mawatho maku nĩmamũraihĩrĩirie;
\q2 we nĩkũnyũrũria anyũrũragia arĩa marĩ ũthũ nake.
\q1 
\v 6 Eĩĩraga na ngoro yake atĩrĩ, “Gũtirĩ ũndũ ũngĩnyinainia;
\q2 ndĩrĩkoragwo ndĩ mũkenu hĩndĩ ciothe na gũtirĩ hĩndĩ ngoona thĩĩna.”
\q1 
\v 7 Kanua gake kaiyũrĩte irumi na maheeni, o na kũguoyohithania;
\q2 mĩtangĩko na mĩario mĩũru ĩrĩ rũrĩmĩ-inĩ rwake.
\q1 
\v 8 Aikaraga oheirie andũ hakuhĩ na matũũra:
\q2 ageterera arĩa matarĩ na ũũru akamooraga,
\q2 aikaraga acũthĩrĩirie na hitho mũndũ ũrĩa ũtarĩ na mũmũteithia.
\q1 
\v 9 Aikaraga oheirie o ta mũrũũthi ũrĩ kĩmamo-inĩ kĩaguo;
\q2 agaikara oheirie nĩguo anyiite arĩa matarĩ na hinya;
\q2 anyiitaga arĩa matarĩ na hinya, akamakururia akamatwara mũtego-inĩ wake.
\q1 
\v 10 Ahehenjaga andũ acio matarĩ na wa kũmateithia, makaringĩka;
\q2 magũũaga thĩ nĩ ũndũ wa hinya wake.
\q1 
\v 11 Eĩĩraga na ngoro atĩrĩ, “Mũrungu nĩariganĩirwo:
\q2 nĩehumbĩrĩte ũthiũ na ndoonaga.”
\b
\q1 
\v 12 Arahũka, Jehova!
\q2 Ambararia guoko gwaku na igũrũ, Wee Mũrungu.
\q2 Tiga kũriganĩrwo nĩ arĩa matarĩ na hinya.
\q1 
\v 13 Nĩ kĩĩ gĩtũmaga mũndũ ũrĩa mwaganu arume Ngai?
\q2 Nĩ kĩĩ gĩtũmaga eĩĩre na ngoro atĩrĩ,
\q2 “We ndangĩrĩhania?”
\q1 
\v 14 No rĩrĩ, Wee Ngai, Wee nĩwonaga mathĩĩna o na kĩeha,
\q2 ũkoona ũhoro ũcio ũkawamũkĩra moko-inĩ maku.
\q1 Mũndũ ũrĩa ũtarĩ wa kũmũteithia eneanaga harĩwe.
\q2 Wee nĩwe mũteithia wa andũ arĩa matarĩ maithe mao.
\q1 
\v 15 Una guoko kwa mũndũ ũrĩa mwaganu na kwa ũrĩa mũũru;
\q2 mũrĩhie nĩ ũndũ wa waganu wake ũcio ũtangĩmenyeka.
\q1 
\v 16 Jehova nĩwe Mũthamaki wa nginya tene;
\q2 ndũrĩrĩ nĩigathira ciehere bũrũri-inĩ wake.
\q1 
\v 17 Wee Jehova, nĩũiguaga wendi wa andũ arĩa anyamaarie;
\q2 nĩũmomagĩrĩria, na ũgathikĩrĩria gũkaya kwao,
\q1 
\v 18 ũgitagĩra andũ arĩa matarĩ maithe na arĩa ahinyĩrĩrie,
\q2 nĩgeetha mũndũ, ũrĩa ũrĩ o wa thĩ, ndagacooke gwĩkanĩra guoya.
\c 11
\s1 Rwĩmbo rwa Kwĩhoka Jehova
\d Thaburi ya Daudi
\q1 
\v 1 Niĩ njũragĩra harĩ Jehova.
\q2 Mwahota atĩa kũnjĩĩra atĩrĩ:
\q2 “Ũmbũka ta nyoni ũũrĩre kĩrĩma-inĩ gĩaku.
\q1 
\v 2 Ta rora, andũ arĩa aaganu nĩmageetete mota mao,
\q2 makahagĩka mĩguĩ yao ndigi-inĩ
\q1 nĩguo mehithĩte nduma-inĩ
\q2 marathe andũ arĩa atheru ngoro.
\q1 
\v 3 Hĩndĩ ĩrĩa mĩthingi ĩraanangwo-rĩ,
\q2 andũ arĩa athingu mangĩhota gwĩka atĩa?”
\b
\q1 
\v 4 Jehova arĩ thĩinĩ wa hekarũ yake theru;
\q2 Jehova arĩ gĩtĩ-inĩ gĩake kĩa ũnene kũu igũrũ.
\q1 Acũthagĩrĩria ariũ a andũ;
\q2 maitho make nĩmamaroragia.
\q1 
\v 5 Jehova nĩaroragia andũ arĩa athingu,
\q2 no andũ arĩa aaganu na arĩa mendete haaro-rĩ,
\q2 ngoro yake nĩĩmathũire.
\q1 
\v 6 Andũ arĩa aaganu nĩakamoirĩria
\q2 marakara maraakana na ũbiriti ũgwakana;
\q2 igai rĩao nĩ rũhuho rũrĩa rũcinaga.
\b
\q1 
\v 7 Nĩgũkorwo Jehova nĩ mũthingu,
\q2 na nĩendete ciira wa kĩhooto;
\q2 andũ arĩa arũngĩrĩru nĩo marĩonaga ũthiũ wake.
\c 12
\s1 Ihooya rĩa kũũria Ũteithio
\d Thaburi ya Daudi
\q1 
\v 1 Jehova, tũteithie, nĩgũkorwo andũ arĩa etigĩri Ngai nĩmaniinĩtwo;
\q2 andũ arĩa ehokeku nĩmathirĩte makoima gatagatĩ-inĩ ka andũ.
\q1 
\v 2 O mũndũ aheenagia mũndũ wa itũũra rĩake;
\q2 mĩromo yao ya ũhinga yaragia maheeni.
\b
\q1 
\v 3 Jehova aroeheria mĩromo yothe ya ũhinga,
\q2 o na nĩmĩ ciothe iria ciaragia na mwĩgaatho,
\q1 
\v 4 iria ciugaga atĩrĩ, “Tũkũhootana nĩ ũndũ wa nĩmĩ ciitũ;
\q2 mĩromo ĩno tũrĩ nayo nĩ iitũ; mwathi witũ akĩrĩ ũ?”
\b
\q1 
\v 5 “Tondũ wa kũhinyĩrĩrio kwa andũ arĩa matarĩ hinya,
\q2 na gũcaaya kwa arĩa abatari-rĩ,
\q1 rĩu nĩngwarahũka,” ũguo nĩguo Jehova ekuuga.
\q2 “Nĩngũmagitĩra kuuma kũrĩ andũ arĩa mamacambagia.”
\q1 
\v 6 Nacio ciugo cia Jehova itirĩ mahĩtia,
\q2 ihaana ta betha ĩthereirio kĩrugutĩro-inĩ kĩa rĩũmba,
\q2 ĩtheretio maita mũgwanja.
\b
\q1 
\v 7 Wee Jehova nĩũrĩtũmenyagĩrĩra wega,
\q2 na ũtũgitagĩre kuuma kũrĩ andũ ta acio nginya tene.
\q1 
\v 8 Andũ arĩa aaganu macangacangaga marĩ na mwĩtĩĩo,
\q2 rĩrĩa ũndũ ũrĩa mũũru ũragathĩrĩrio nĩ andũ.
\c 13
\s1 Gweterera Ũhonokio wa Ngai
\d Thaburi ya Daudi
\q1 
\v 1 Nĩ nginya rĩ, Wee Jehova?
\q2 Ũgũtũũra ũriganĩirwo nĩ niĩ nginya tene?
\q2 Nĩ nginya rĩ ũgũtũũra ũũhithĩte ũthiũ waku?
\q1 
\v 2 Nĩ nginya rĩ ngũtũũra ngianaga na meciiria makwa,
\q2 na o mũthenya ngoragwo na ihooru ngoro-inĩ yakwa?
\q2 Nĩ nginya rĩ thũ yakwa ĩgũtũũra ĩĩhootaga?
\b
\q1 
\v 3 Wee Jehova, Ngai wakwa, ndora na ũnjookerie ũhoro.
\q2 Tũma maitho makwa mone, nĩguo ndikae gũkoma toro wa gĩkuũ;
\q1 
\v 4 nĩguo thũ yakwa ndĩkoige atĩrĩ, “Nĩndĩmũhootete,”
\q2 nao arĩa marĩ muku na niĩ magĩkenere kũgũa gwakwa.
\b
\q1 
\v 5 No niĩ ndĩhokete wendo waku ũrĩa ũtathiraga;
\q2 ngoro yakwa ĩkenagĩra ũhonokio waku.
\q1 
\v 6 Nĩngũinĩra Jehova,
\q2 nĩgũkorwo nĩanjĩkĩte wega mũno.
\c 14
\s1 Ngai ndakenagio nĩ Irimũ
\d Thaburi ya Daudi
\q1 
\v 1 Kĩrimũ kĩĩraga na ngoro atĩrĩ,
\q2 “Gũtirĩ Ngai.”
\q1 Nĩ amaramari, ciĩko ciao nĩ njũru;
\q2 gũtirĩ mũndũ o na ũmwe wĩkaga wega.
\b
\q1 
\v 2 Jehova aroraga ciana cia ariũ a andũ arĩ o igũrũ,
\q2 one kana nĩ harĩ ũrĩ na ũmenyo,
\q2 o na kana nĩ harĩ ũrongoragia Ngai.
\q1 
\v 3 Othe-rĩ, nĩmorĩte njĩra,
\q2 magatuĩka amaramari marĩ hamwe;
\q1 gũtirĩ mũndũ o na ũmwe wĩkaga wega,
\q2 gũtirĩ o na ũmwe.
\b
\q1 
\v 4 Andũ acio mekaga maũndũ mooru kaĩ matamenyaga,
\q2 o acio marĩĩaga andũ akwa o ta ũrĩa andũ marĩĩaga irio,
\q2 o acio matakayagĩra Jehova?
\q1 
\v 5 Hau nĩho marĩ manyiitĩtwo nĩ guoya mũnene,
\q2 nĩgũkorwo Ngai aikaraga hamwe na thiritũ ya arĩa athingu.
\q1 
\v 6 Inyuĩ andũ aya aaganu nĩmũthũkagia mĩbango ya arĩa athĩĩni,
\q2 no Jehova nĩwe rĩũrĩro rĩao.
\b
\q1 
\v 7 Naarĩ korwo ũhonokio wa Isiraeli no ũgĩũke kuuma Zayuni!
\q2 Rĩrĩa Jehova agaacookeria andũ ake indo ciao-rĩ,
\q2 Jakubu nĩagĩkene, na Isiraeli acanjamũke.
\c 15
\s1 Maũndũ marĩa Jehova Endaga
\d Thaburi ya Daudi
\q1 
\v 1 Jehova, nũũ ũngĩtũũra hema-inĩ yaku?
\q2 Nũũ ũngĩtũũra kĩrĩma-inĩ gĩaku kĩrĩa kĩamũre?
\b
\q1 
\v 2 Nĩ mũndũ ũrĩa mĩthiĩre yake ĩtarĩ ũcuuke,
\q2 na ũrĩa wĩkaga maũndũ ma ũthingu,
\q1 na kwaria aragia ũhoro wa ma kuuma ngoro-inĩ yake,
\q2 
\v 3 na ndarĩ njambanio rũrĩmĩ-inĩ rwake,
\q1 na ndeekaga mũndũ wa itũũra rĩake ũũru,
\q2 o na kana akamenereria mũndũ ũrĩa ũngĩ;
\q1 
\v 4 mũndũ ũcio nĩathũire mũndũ ũrĩa wĩkaga maũndũ mooru,
\q2 no nĩatĩĩte arĩa etigĩri Jehova,
\q1 na ndagaga kũhingia mwĩhĩtwa wake,
\q2 o na ũngĩkorwo ũrĩ wa kũmũtuuria,
\q1 
\v 5 ndakombanagĩra mbeeca ciake nĩguo one uumithio,
\q2 na ndangĩoya ihaki nĩguo ahatĩrĩrie mũndũ ũteehĩtie.
\b
\q1 Mũndũ ũrĩa wĩkaga maũndũ ta macio
\q2 ndarĩ hĩndĩ akeenyenyeka.
\c 16
\s1 Mwathani nĩwe Rĩũrĩro Rĩakwa
\d Thaburi ya Daudi
\q1 
\v 1 Wee Mũrungu, ngitagĩra,
\q2 nĩgũkorwo nĩ harĩwe njũragĩra.
\b
\q1 
\v 2 Ndeerire Jehova atĩrĩ, “Wee nĩwe Mwathani wakwa;
\q2 hatirĩ ũndũ mwega ingĩona ũtoimĩte harĩwe.”
\q1 
\v 3 Ha ũhoro wa andũ arĩa aamũre arĩa marĩ bũrũri-inĩ,
\q2 acio nĩo andũ arĩa marĩ riiri, na nĩo ngenagĩra mũno.
\q1 
\v 4 Andũ arĩa matengʼeragĩra ngai ingĩ-rĩ,
\q2 kĩeha kĩao nĩgĩkaingĩha.
\q1 Ndirĩ hĩndĩ ngarutĩra ngai icio magongona ma gũita thakame,\f + \fr 16:4 \ft Ndibei nĩyo yarutagwo igongona rĩa gũitwo. Andũ a Ndũrĩrĩ nĩmatukanagia thakame ya ũrĩa woragwo na ndibei, nĩguo ĩgatuĩka igongona rĩa gũitwo.\f*
\q2 o na kana ngwete marĩĩtwa maacio na mĩromo yakwa.
\b
\q1 
\v 5 Jehova nĩwe ũnjigĩire rwĩga rwakwa, na gĩkombe gĩakwa;\f + \fr 16:5 \ft Gĩkombe gĩkĩ nĩ kĩrĩa mũndũ aaheagwo hĩndĩ ya gũkũngũĩra maũndũ.\f*
\q2 Wee nĩwe ũgitagĩra igai rĩakwa.
\q1 
\v 6 Ũnjatũrĩire ithaka kũndũ kũrĩa kwega;
\q2 ti-itherũ igai rĩakwa nĩrĩngenagia mũno.
\b
\q1 
\v 7 Nĩngũgooca Jehova, ũrĩa ũũheaga kĩrĩra;
\q2 o na ũtukũ ngoro yakwa nĩĩndaaraga.
\q1 
\v 8 Jehova akoragwo arĩ mbere yakwa hĩndĩ ciothe.
\q2 Tondũ arĩ guoko-inĩ gwakwa kwa ũrĩo-rĩ,
\q2 ndingĩenyenyeka.
\b
\q1 
\v 9 Nĩ ũndũ ũcio ngoro yakwa nĩnjanjamũku, na rũrĩmĩ rwakwa rũgakena;
\q2 o naguo mwĩrĩ wakwa nĩ ũgaatũũra ũrĩ na thayũ,
\q1 
\v 10 tondũ ndũkandiganĩria mbĩrĩra-inĩ,
\q2 o na kana ũreke Ũrĩa-waku-Mũtheru abuthe.
\q1 
\v 11 Nĩũũmenyithĩtie njĩra ya gũthiĩ muoyo-inĩ;
\q2 nĩũkanjiyũria gĩkeno ndĩ harĩa ũrĩ,
\q2 hamwe na mwago wa tene na tene ndĩ guoko-inĩ gwaku kwa ũrĩo.
\c 17
\s1 Ihooya rĩa Mũndũ Ũtarĩ Ũcuuke
\d Ihooya rĩa Daudi
\q1 
\v 1 Wee Jehova, ta igua gũthaithana gwakwa kwa ũthingu;
\q2 thikĩrĩria gũkaya gwakwa.
\q1 Tega gũtũ ũigue ihooya rĩakwa,
\q2 tondũ rĩtiumanĩte na mĩromo ya maheeni.
\q1 
\v 2 Ituĩro rĩakwa rĩa kĩhooto nĩrĩkiume kũrĩ wee;
\q2 maitho maku nĩmakĩone o ũndũ ũrĩa wagĩrĩire.
\b
\q1 
\v 3 O na ũngĩthuthuuria ngoro yakwa na ũnduĩrie ũtukũ,
\q2 o na ũngĩngeria, ndũrĩ ũndũ mũũru ũngĩona;
\q2 nĩnduĩte atĩ ndikehia na kanua gakwa.
\q1 
\v 4 Ha ũhoro wa ciĩko cia andũ,
\q2 na ũndũ wa uuge wa mĩromo yaku
\q1 niĩ ndũũrĩte ndĩrigagĩrĩria
\q2 njĩra cia andũ arĩa mendete haaro.
\q1 
\v 5 Makinya makwa nĩmarũmĩtie njĩra ciaku;
\q2 magũrũ makwa matirĩ matenderũka.
\b
\q1 
\v 6 Wee Mũrungu, ngũkayagĩra tondũ nĩũnjĩtĩkaga;
\q2 ndegera gũtũ na ũigue ihooya rĩakwa.
\q1 
\v 7 Tũma magegania ma wendo waku mũnene monekane,
\q2 Wee ũhonokanagia na guoko gwaku kwa ũrĩo
\q2 arĩa moragĩra harĩwe kuuma kũrĩ thũ ciao.
\q1 
\v 8 Menyagĩrĩra niĩ ta kĩũma kĩa riitho rĩaku;
\q2 hitha kĩĩruru-inĩ kĩa mathagu maku
\q1 
\v 9 ndigakorwo nĩ andũ arĩa aaganu arĩa maatharĩkagĩra,
\q2 na kuuma kũrĩ thũ cia muoyo wakwa iria cindigiicĩirie.
\b
\q1 
\v 10 Nĩmahinganĩtie ngoro ciao nyũmũ,
\q2 na tuo tũnua twao tũkaaria na mwĩgaatho.
\q1 
\v 11 Maahĩtĩte, rĩu nĩmandigiicĩirie,
\q2 mangũũrĩire maitho, mone mweke wa kũnũnda.
\q1 
\v 12 Mahaana ta mũrũũthi ũhũtĩire ndĩa yaguo,
\q2 makahaana ta mũrũũthi mũnene woheirie kĩrĩa ũrenda kũnyiita.
\b
\q1 
\v 13 Arahũka, Wee Jehova, mangʼethere, ũmahoote;
\q2 ndeithũra na rũhiũ rwaku rwa njora kuuma kũrĩ andũ arĩa aaganu.
\q1 
\v 14 Wee Jehova, honokia na guoko gwaku kuuma kũrĩ andũ ta acio,
\q2 ũũhonokie kuuma kũrĩ andũ a thĩ ĩno arĩa irĩhi rĩao rĩrĩ o muoyo-inĩ ũyũ tũrĩ.
\b
\q1 Ũniinagĩra andũ arĩa wendete ngʼaragu ũkamahũũnia;
\q2 ciana ciao irĩ na cia kũigana,
\q2 na nĩmaigagĩra ciana cia ciana ciao mũthiithũ.
\q1 
\v 15 Na niĩ-rĩ, nĩngeyonera ũthiũ waku na ũthingu;
\q2 rĩrĩa ngokĩra-rĩ, nĩngaĩiganwo nĩgũkuona ũrĩa ũtariĩ.
\c 18
\s1 Rwĩmbo rwa Gũcookia Ngaatho nĩ ũndũ wa Ũhootani
\d Thaburi ya Daudi
\q1 
\v 1 Nĩngwendete, Wee Jehova, o Wee hinya wakwa.
\b
\q1 
\v 2 Jehova nĩwe rwaro rwakwa rwa ihiga, na rũirigo rwakwa rwa hinya, na mũkũũri wakwa;
\q2 Mũrungu wakwa nĩwe rwaro rwakwa rwa ihiga, o we rĩũrĩro rĩakwa.
\q2 Nĩwe ngo yakwa, na rũhĩa rwa ũhonokio wakwa, o na kĩĩhitho gĩakwa kĩrũmu.
\q1 
\v 3 Ngayagĩra Jehova, ũrĩa wagĩrĩire nĩkũgoocwo,
\q2 na ngahonokio kuuma kũrĩ thũ ciakwa.
\b
\q1 
\v 4 Mĩhĩndo ya gĩkuũ nĩyandigiicire;
\q2 kĩguũ kĩa mwanangĩko gĩkĩĩhubĩkania.
\q1 
\v 5 Mĩhĩndo ya mbĩrĩra ĩgĩĩthiororokeria;
\q2 nayo mĩtego ya gĩkuũ ĩkĩnjĩhotorera.
\q1 
\v 6 Mĩnyamaro-inĩ yakwa ndakaĩire Jehova;
\q2 ngĩrĩrĩra Ngai wakwa aandeithie.
\q1 Arĩ hekarũ-inĩ yake nĩ aaiguire mũgambo wakwa;
\q2 kĩrĩro gĩakwa gĩgĩkinya harĩ we, o matũ-inĩ make.
\b
\q1 
\v 7 Thĩ ĩkĩinaina na ĩgĩthingitha,
\q2 nayo mĩthingi ya irĩma ĩkĩenyenya;
\q2 ĩkĩinaina tondũ aarĩ mũrakaru.
\q1 
\v 8 Ndogo ĩkiuma maniũrũ-inĩ make ĩkĩambata na igũrũ;
\q2 mwaki wa kũniinana ũkiuma kanua-inĩ gake,
\q2 kanua-inĩ gake hakiuma makara mekũrĩrĩmbũka.
\q1 
\v 9 Aahingũrire igũrũ agĩikũrũka thĩ;
\q2 matu matumanu maarĩ rungu rwa makinya make.
\q1 
\v 10 Aathiire akuuĩtwo nĩ ikerubi\f + \fr 18:10 \ft Akerubi nĩ ciũmbe cia matu-inĩ na nĩcio ciakuuaga gĩtĩ kĩa Ngai kĩa ũnene.\f* akĩũmbũka;
\q2 akĩambata na igũrũ na mathagu ma rũhuho.
\q1 
\v 11 Aatuire nduma kĩndũ gĩake gĩa kwĩhumbĩra,
\q2 hema ya kũmũthiũrũrũkĩria,
\q2 o matu marĩa mathimbu ma mbura.
\q1 
\v 12 Kuuma ũkengi ũrĩa warĩ harĩ we,
\q2 mbura ya mbembe na heni igũtũrĩkanĩria matu-inĩ make.
\q1 
\v 13 Jehova akĩruruma arĩ kũu igũrũ;
\q2 mũgambo wa Ũrĩa-ũrĩ-Igũrũ-Mũno ũkĩiguuo.
\q1 
\v 14 Aikirie mĩguĩ yake, akĩharagania thũ,
\q2 agĩciikĩria heni nene, agĩcingatithia.
\q1 
\v 15 Mĩkuru ya iria ĩkĩguũrio,
\q2 nayo mĩthingi ya thĩ ĩkĩhumbũrio
\q1 nĩ ũndũ wa irũithia rĩaku, Wee Jehova,
\q2 na nĩ ũndũ wa ihurutana rĩa mĩhũmũ ya maniũrũ maku.
\b
\q1 
\v 16 Agĩtambũrũkia guoko gwake kuuma o kũu igũrũ, akĩĩnyiita;
\q2 akĩnguucia, akĩnduta maaĩ-inĩ kũrĩa kũriku.
\q1 
\v 17 Andeithũrire harĩ thũ yakwa ĩrĩ hinya,
\q2 akĩndeithũra kũrĩ arĩa maathũire, o acio maangĩrĩtie hinya.
\q1 
\v 18 Manjĩhotoreire mũthenya ũrĩa ndaarĩ na mũtino,
\q2 no Jehova nĩwe warĩ mũtiirĩrĩri wakwa.
\q1 
\v 19 Andeehire kũndũ kwariĩ;
\q2 akĩndeithũra nĩ tondũ nĩakenetio nĩ niĩ.
\b
\q1 
\v 20 Jehova anjĩkĩire maũndũ kũringana na ũthingu wakwa;
\q2 andĩhĩte kũringana na ũtheru wa moko makwa.
\q1 
\v 21 Nĩgũkorwo nĩnũmĩtie njĩra cia Jehova;
\q2 ndiĩkĩte ũũru ngahutatĩra Ngai wakwa.
\q1 
\v 22 Mawatho make mothe marĩ mbere yakwa;
\q2 ndihutatĩire irĩra cia watho wake wa kũrũmĩrĩrwo.
\q1 
\v 23 Ngoretwo itarĩ na ũcuuke ndĩ mbere yake,
\q2 na ngemenyerera ndikehie.
\q1 
\v 24 Jehova andĩhĩte kũringana na ũthingu wakwa,
\q2 akandĩha kũringana na ũtheru wa moko makwa maitho-inĩ make.
\b
\q1 
\v 25 Kũrĩ mũndũ ũrĩa mwĩhokeku ũrĩĩonanagia ũrĩ mwĩhokeku,
\q2 na kũrĩ ũrĩa ũtarĩ ũcuuke ũrĩĩonanagia ndũrĩ ũcuuke,
\q1 
\v 26 kũrĩ ũrĩa wĩtheragia, ũrĩĩonanagia ũrĩ mũtheru,
\q2 no kũrĩ ũrĩa ũrĩ mĩthiĩre mĩogomu, ũrĩĩonanagia ũrĩ mũmũhutatĩri.
\q1 
\v 27 Wee ũhonokagia andũ arĩa enyiihia,
\q2 no arĩa marĩ maitho ma mwĩtĩĩo ũkamaconorithia.
\q1 
\v 28 Wee Jehova, ũigaga tawa wakwa wakanĩte;
\q2 Ngai wakwa atũmaga nduma yakwa ĩtuĩke ũtheri.
\q1 
\v 29 Ndĩ na ũteithio waku no hote gũtharĩkĩra mbũtũ ya ita;
\q2 ndĩ na Ngai wakwa no hote kũrũga rũthingo.
\b
\q1 
\v 30 Mũrungu-rĩ, njĩra ciake nĩnginyanĩru;
\q2 kiugo kĩa Jehova gĩtirĩ ihĩtia.
\q1 We nĩwe ngo ya arĩa othe mehithaga harĩ we.
\q1 
\v 31 Nĩ ũndũ-rĩ, nũũ Mũrungu tiga Jehova?
\q2 Na nũũ Rwaro rwa Ihiga tiga Ngai witũ?
\q1 
\v 32 Nĩ Mũrungu ũũheaga hinya
\q2 na agatũma njĩra yakwa ĩkinyanĩre.
\q1 
\v 33 Atũmaga magũrũ makwa magĩe ihenya ta ma thwariga;
\q2 aahotithagia kũrũgama kũndũ kũrĩa kũraihu.
\q1 
\v 34 We nĩwe wonagia moko makwa mũrũĩre wa mbaara;
\q2 moko makwa no mageete ũta wa gĩcango.
\q1 
\v 35 Ũũheaga ngo yaku ya ũhootani,
\q2 guoko gwaku kwa ũrĩo nĩkuo kũndiiragĩrĩra;
\q2 ũinamagĩrĩra ũkaanenehia.
\q1 
\v 36 Ũnjaramagĩria njĩra ya kũrĩa thiiagĩra,
\q2 nĩgeetha magũrũ makwa matigatirũke.
\b
\q1 
\v 37 Ndaingatithirie thũ ciakwa ngĩcikinyĩra;
\q2 ndiacookire na thuutha nginya rĩrĩa cianiinirwo.
\q1 
\v 38 Ndacihehenjire ikĩremwo nĩ gũũkĩra;
\q2 ciagũire thĩ wa magũrũ makwa.
\q1 
\v 39 Wee waheire hinya wa kũrũa mbaara;
\q2 ũgĩgĩtũma thũ ciakwa ciinamĩrĩre magũrũ-inĩ makwa.
\q1 
\v 40 Watũmire thũ ciakwa ihũndũke ciũre,
\q2 na niĩ ngĩniina arĩa maathũire.
\q1 
\v 41 Maakaire mateithio, no hatiarĩ na wa kũmahonokia,
\q2 maakaĩire Jehova no ndaametĩkire.
\q1 
\v 42 Ndaamahũũrire makĩhinya ta rũkũngũ rũmbũrĩtwo nĩ rũhuho;
\q2 ngĩmaita njĩra-inĩ ta ndooro.
\b
\q1 
\v 43 Nĩũũhonoketie ngaaga gũtharĩkĩrwo nĩ andũ;
\q2 ũnduĩte mũtongoria wa ndũrĩrĩ;
\q2 andũ itooĩ nĩmandungatagĩra.
\q1 
\v 44 O rĩrĩa maigua ngumo yakwa, nĩmanjathĩkagĩra;
\q2 andũ a kũngĩ mehetaga marĩ mbere yakwa.
\q1 
\v 45 Othe makuuaga ngoro;
\q2 mookaga makĩinainaga moimĩte ciĩhitho ciao cia hinya.
\b
\q1 
\v 46 Jehova atũũraga muoyo!
\q2 O we Rwaro rwakwa rwa Ihiga arogoocwo!
\q2 Ngai o we Mũhonokia wakwa arotũgĩrio!
\q1 
\v 47 We nĩwe Mũrungu ũrĩa ũndĩhagĩria,
\q2 agatooria ndũrĩrĩ, agaciiga rungu rwakwa,
\q2 
\v 48 o we ũũhonokagia kuuma kũrĩ thũ ciakwa.
\q1 Wandũgĩririe igũrũ rĩa andũ arĩa maathũire;
\q2 ũkĩndeithũra kuuma kũrĩ andũ arĩa mahũthagĩra hinya.
\q1 
\v 49 Nĩ ũndũ ũcio, Wee Jehova, nĩndĩrĩkũgoocaga ndĩ gatagatĩ ka ndũrĩrĩ,
\q2 ndĩrĩinaga ngagooca rĩĩtwa rĩaku.
\q1 
\v 50 Aheaga mũthamaki wake ũhootani mũnene;
\q2 onanagia ũtugi wake ũtathiraga kũrĩ ũcio wake mũitĩrĩrie maguta,
\q2 kũrĩ Daudi na njiaro ciake nginya tene.
\c 19
\s1 Ũũmbi wa Ngai Wonanagia Riiri Wake
\d Thaburi ya Daudi
\q1 
\v 1 Igũrũ riumbũraga riiri wa Mũrungu;
\q2 namo matu mamemerekagia wĩra wa moko make.
\q1 
\v 2 Mũthenya ũkinyagĩria mũthenya ũrĩa ũngĩ ũhoro;
\q2 naguo ũtukũ ũkamenyithia ũtukũ ũrĩa ũngĩ ũhoro wa riiri ũcio.
\q1 
\v 3 Gũtirĩ mĩario kana rũthiomi
\q2 kũrĩa mũgambo wacio ũtaiguĩkaga.
\q1 
\v 4 Mũgambo wacio ũthiiaga thĩ yothe,
\q2 nacio ciugo ciacio igakinya ituri cia thĩ.
\b
\q1 Ngai nĩambĩire riũa hema kũu igũrũ,
\q2 
\v 5 narĩo riumaga rĩhaana ta mũhikania akiuma nyũmba yake,
\q2 o na kana ta mũtengʼeri njoorua akĩhĩĩahĩĩa gũtengʼera.
\q1 
\v 6 Rĩrathagĩra mwena-inĩ ũmwe wa kũu igũrũ,
\q2 na rĩgathiũrũrũka nginya mwena ũrĩa ũngĩ;
\q2 gũtirĩ kĩndũ gĩtakinyagĩrwo nĩ ũrugarĩ warĩo.
\b
\q1 
\v 7 Watho wa Jehova nĩ mũkinyanĩru,
\q2 ũriũkagia ngoro ya mũndũ.
\q1 Kĩrĩra kĩa Jehova nĩ gĩa kwĩhokeka,
\q2 nĩkĩũhĩgagia mũndũ ũrĩa ũtarĩ mũũgĩ.
\q1 
\v 8 Mataaro ma Jehova nĩmarũngĩrĩru,
\q2 nĩ makenagia ngoro.
\q1 Maathani ma Jehova nĩ macangararu,
\q2 maheaga maitho ũtheri.
\q1 
\v 9 Gwĩtigĩra Jehova nĩ ũndũ mũtheru,
\q2 gũtũũraga nginya tene.
\q1 Matua ma Jehova nĩ ma ma,
\q2 na mothe nĩ ma kĩhooto.
\q1 
\v 10 Maũndũ macio nĩ ma goro gũkĩra thahabu,
\q2 o na gũkĩra thahabu ĩrĩa therie mũno;
\q1 marĩ mũrĩo gũkĩra ũũkĩ,
\q2 o ũũkĩ ũrĩa uumĩte igua-inĩ.
\q1 
\v 11 Ningĩ nĩmo mataaraga ndungata yaku;
\q2 kũmamenyerera nĩ ũndũ ũrĩ irĩhi inene.
\b
\q1 
\v 12 Nũũ ũngĩhota gũkũũrana mahĩtia make?
\q1 Ndekera mahĩtia makwa ma hitho-inĩ.
\q1 
\v 13 Ningĩ rigagĩrĩria ndungata yaku ndĩkeehie mehia ma mwĩĩro o namo;
\q2 ndũkanareke mehia macio manjathe.
\q1 Nĩguo ndĩrĩikaraga itarĩ na ũcuuke,
\q2 na itarĩ na mehia ma kwagarara watho.
\b
\q1 
\v 14 Ciugo cia kanua gakwa na matarania ma ngoro yakwa
\q2 irogũkenia maitho-inĩ maku,
\q2 Wee Jehova, o Wee Rwaro rwakwa rwa Ihiga, na Mũkũũri wakwa.
\c 20
\s1 Ihooya rĩa kũũria Ũhootani
\d Thaburi ya Daudi
\q1 
\v 1 Jehova arogwĩtĩka rĩrĩa ũrĩ mĩnyamaro-inĩ;
\q2 rĩĩtwa rĩa Ngai wa Jakubu rĩrokũgitĩra.
\q1 
\v 2 Arokũrehere ũteithio kuuma handũ harĩa hake haamũre,
\q2 na agũtiirĩrĩre arĩ kũu Zayuni.
\q1 
\v 3 Aroririkana magongona maku mothe,
\q2 na etĩkĩre maruta maku ma njino.
\q1 
\v 4 Arokũhe maũndũ marĩa ngoro yaku ĩĩrirĩirie,
\q2 na atũme mĩbango yaku yothe ĩgaacĩre.
\q1 
\v 5 Rĩrĩa ũkaahootana nĩtũkoigĩrĩria na gĩkeno,
\q2 na tuoye bendera ciitũ na igũrũ nĩ ũndũ wa rĩĩtwa rĩa Ngai witũ.
\q1 Jehova arokũhingĩria maũndũ marĩa mothe ũmũhooete.
\b
\q1 
\v 6 Rĩu nĩmenyete atĩ Jehova nĩahonokagia ũrĩa wake mũitĩrĩrie maguta;
\q2 nĩamwĩtĩkaga arĩ kũu igũrũ rĩake rĩamũre,
\q2 arĩ na ũhoti wa kũhonokania ũrĩa ũrĩ guoko-inĩ gwake kwa ũrĩo.
\q1 
\v 7 Andũ amwe mehokaga ngaari cia ita, na angĩ makehoka mbarathi,
\q2 no ithuĩ twĩhokaga rĩĩtwa rĩa Jehova Ngai witũ.
\q1 
\v 8 Makurumaga makagũa thĩ,
\q2 no ithuĩ tũrũgamaga tũkehaanda.
\b
\q1 
\v 9 Wee Jehova, honokia mũthamaki!
\q2 Twĩtĩkage rĩrĩa twagũkaĩra!
\c 21
\s1 Ũhootani wa Jehova
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, mũthamaki nĩakeneire hinya waku.
\q2 Kaĩ gĩkeno kĩa ũhootani kĩrĩa ũmũheaga gĩkĩrĩ kĩnene-ĩ!
\q1 
\v 2 Nĩũmũhingĩirie wendi wa ngoro yake,
\q2 naguo ũndũ ũrĩa akũhooete na mĩromo yake ndũmũimĩte.
\q1 
\v 3 Wamwamũkĩrire na irathimo nyingĩ,
\q2 na ũkĩmwĩkĩra thũmbĩ ya thahabu ĩrĩa therie mũtwe.
\q1 
\v 4 Aakũhooire atũũre muoyo, nawe ũkĩmũhe muoyo,
\q2 ũkĩmũhe matukũ maingĩ atũũre nginya tene na tene.
\q1 
\v 5 Riiri wake nĩ mũnene nĩ ũndũ wa ũhootani ũrĩa ũmũheete;
\q2 nĩũmũheete riiri na igweta.
\q1 
\v 6 Ti-itherũ nĩũmũrathimĩte na irathimo cia gũtũũra nginya tene,
\q2 na ũgatũma acanjamũke nĩ gĩkeno gĩa gũikara harĩwe.
\q1 
\v 7 Nĩgũkorwo mũthamaki ehokaga Jehova;
\q2 nĩ ũndũ wa wendo wa Ũrĩa-ũrĩ-Igũrũ-Mũno
\q2 ndangĩenyenyeka.
\b
\q1 
\v 8 Guoko gwaku nĩgũkanyiita thũ ciaku ciothe;
\q2 guoko gwaku kwa ũrĩo gũgaakumbata arĩa marĩ muku nawe.
\q1 
\v 9 Hĩndĩ ĩrĩa ũkaamoimĩrĩra
\q2 ũgaatũma mahaane ta icua rĩa mwaki mũnene.
\q1 Nĩ ũndũ wa mangʼũrĩ make-rĩ, Jehova nĩakamameria,
\q2 naguo mwaki wake ũmaniine.
\q1 
\v 10 Nĩũkaniina njiaro ciao ithire gũkũ thĩ,
\q2 na ciana cia ciana ciao ũciniine kuuma kũrĩ andũ.
\q1 
\v 11 O na mangĩgagũciirĩra magwĩke ũũru,
\q2 na mathugunde maũndũ ma waganu, matikahootana,
\q1 
\v 12 nĩgũkorwo nĩũgatũma mahũndũke moore
\q2 rĩrĩa makoona ũgeetete ũta waku ũmarathe.
\b
\q1 
\v 13 No gĩtũũgĩre Wee Jehova, nĩ ũndũ wa hinya waku;
\q2 na ithuĩ nĩtũine na tũgooce hinya waku.
\c 22
\s1 Ruo Rũnene na Rwĩmbo rwa Kũgooca
\d Thaburi ya Daudi
\q1 
\v 1 Ngai wakwa, Ngai wakwa, ũndiganĩirie nĩkĩ?
\q2 Ũndaihĩrĩirie ũguo nĩkĩ, ũkaaga kũũhonokia,
\q2 ũkaraihĩrĩria ciugo cia mũcaayo wakwa?
\q1 
\v 2 Wee Ngai wakwa, ngũkayagĩra mũthenya, no ndũnjĩtĩkaga,
\q2 ngũkayagĩra ũtukũ, na ndingĩkira.
\b
\q1 
\v 3 No rĩrĩ, Wee ũrĩ Mũtheru, Wee ũikarĩire gĩtĩ kĩa ũnene;
\q2 Wee nĩwe ũgoocagwo nĩ Isiraeli.
\q1 
\v 4 Maithe maitũ nĩwe meehokaga;
\q2 maakwĩhokire nawe ũkĩmahonokia.
\q1 
\v 5 Maagũkaĩire nao makĩhonokio;
\q2 maakwĩhokire na matiigana gũconorithio.
\b
\q1 
\v 6 No niĩ nduĩkĩte o ta kĩgunyũ, no ti ta mũndũ,
\q2 nganyararwo nĩ andũ na ngamenwo nĩ kĩrĩndĩ.
\q1 
\v 7 Andũ arĩa othe maanyonaga nĩmanyũrũragia;
\q2 makaanuma makĩinainagia mĩtwe, makoiga atĩrĩ:
\q1 
\v 8 “Ehokaga Jehova; Jehova nĩakĩmũhatũre.
\q2 Nĩakĩmũteithũre, nĩgũkorwo nĩakenagio nĩwe.”
\b
\q1 
\v 9 No rĩrĩ, Wee nĩwe wandutire nda ya maitũ;
\q2 watũmire ngwĩhoke ndĩ o nyondo-inĩ cia maitũ.
\q1 
\v 10 Kuuma ndaaciarwo ndaikirio o harĩwe;
\q2 kuuma ndoima nda ya maitũ ũkoretwo ũrĩ Mũrungu wakwa.
\q1 
\v 11 Ndũkandaihĩrĩrie,
\q2 nĩgũkorwo thĩĩna ũrĩ o hakuhĩ,
\q2 na gũtirĩ mũndũ o na ũmwe wa kũndeithia.
\b
\q1 
\v 12 Ndegwa nyingĩ nĩindigicĩirie;
\q2 thiũrũrũkĩirio nĩ ndegwa irĩ hinya cia Bashani.\f + \fr 22:12 \ft Bashani kwarĩ mwena wa gathigathini-irathĩro wa Palestina; nĩ kwoĩkaine nĩ ũndũ wa ndegwa ciakuo cia hinya na ngʼombe noru.\f*
\q1 
\v 13 Mĩrũũthi ĩkũrarama, ĩgĩtambuuranga kĩrĩa ĩgwatĩtie,
\q2 ĩnjathamĩirie tũnua twayo.
\q1 
\v 14 Njitĩtwo thĩ ta maaĩ,
\q2 namo mahĩndĩ makwa mothe nĩmarekanĩtie.
\q1 Ngoro yakwa yororoete ta mũhũra;
\q2 ĩtwekete ĩrĩ thĩinĩ wakwa.
\q1 
\v 15 Hinya wakwa ũniarĩte ta rũgĩo,
\q2 naruo rũrĩmĩ rwakwa rũkanyiitana na karakara nĩkũngʼara;
\q2 ũngometie rũkũngũ-inĩ rwa gĩkuũ.
\q1 
\v 16 Ndĩĩmũrigiicĩrie nĩ magui;
\q2 ndĩĩmũthiũrũrũkĩrie nĩ gĩkundi kĩa andũ arĩa meekaga ũũru,
\q2 nĩmatheecangĩte moko na magũrũ makwa.
\q1 
\v 17 Mahĩndĩ makwa no hote kũmatara mothe;
\q2 andũ marandora na makangũũrĩra maitho.
\q1 
\v 18 Maragayana nguo ciakwa,
\q2 nayo kanjũ yakwa makamĩcuukĩra mĩtĩ.
\b
\q1 
\v 19 No rĩrĩ, Wee Jehova, ndũkandaihĩrĩrie mũno;
\q2 Wee Hinya wakwa, hiũha ũũke ũndeithie.
\q1 
\v 20 Teithũra muoyo wakwa kuuma harĩ rũhiũ rwa njora,
\q2 ũteithũre muoyo wakwa wa goro harĩ hinya wa magui.
\q1 
\v 21 Thara kuuma kanua-inĩ ka mĩrũũthi;
\q2 honokia kuuma hĩa-inĩ cia mbogo.
\b
\q1 
\v 22 Nĩngumbũra rĩĩtwa rĩaku kũrĩ ariũ a baba;
\q2 ndĩrĩkũgoocaga ndĩ kĩũngano-inĩ.
\q1 
\v 23 Inyuĩ andũ aya mwĩtigĩrĩte Jehova, mũgoocei!
\q2 Inyuothe a njiaro cia Jakubu, mũkumiei,
\q2 inyuĩ a njiaro cia Isiraeli, mũtĩĩei.
\q1 
\v 24 Nĩgũkorwo we ndaamenire
\q2 kana akĩnyarara gũthĩĩnĩka kwa ũrĩa mũnyamarĩku;
\q1 ndaahithire ũthiũ wake kuuma kũrĩ we,
\q2 no nĩathikĩrĩirie kĩrĩro gĩake.
\b
\q1 
\v 25 Gĩtũmi kĩa ngũgooce ũrĩa ngũgoocaga ndĩ kĩũngano-inĩ kĩnene kiumĩte harĩwe;
\q2 niĩ nĩndĩrĩhingagia mĩĩhĩtwa yakwa ndĩ mbere ya arĩa magwĩtigĩrĩte.
\q1 
\v 26 Andũ arĩa athĩĩni marĩrĩĩaga na makahũũna,
\q2 arĩa marongoragia Jehova, nĩmarĩmũgoocaga;
\q2 ngoro cianyu irotũũra nginya tene.
\q1 
\v 27 Andũ arĩa othe matũũraga ituri ciothe cia thĩ
\q2 nĩmakaririkana na macookerere Jehova,
\q1 andũ a nyũmba ciothe cia ndũrĩrĩ
\q2 nĩmakainamĩrĩra mbere yake,
\q1 
\v 28 nĩgũkorwo ũthamaki nĩ wa Jehova,
\q2 na nĩwe wathaga ndũrĩrĩ ciothe.
\b
\q1 
\v 29 Andũ arĩa othe atongu a thĩ makaarĩa na mamũhooe;
\q2 arĩa othe makuuaga magathikwo nĩmagaturia ndu mbere yake,
\q2 o acio matangĩhota gwĩtũũria muoyo.
\q1 
\v 30 Ciana nĩikamũtungatĩra;
\q2 nacio nĩikaahe njiarwa iria igooka ũhoro wa Mwathani.
\q1 
\v 31 Acio nĩmakahunjia ũthingu wake
\q2 kũrĩ andũ arĩa magaaciarwo,
\q2 nĩgũkorwo nĩwe wĩkĩte ũguo.
\c 23
\s1 Jehova nĩwe Mũrĩithi Wakwa
\d Thaburi ya Daudi
\q1 
\v 1 Jehova nĩwe mũrĩithi wakwa, ndirĩ kĩndũ ingĩaga.
\q2 
\v 2 Atũmaga njarahe ũrĩithio-inĩ ũrĩ nyeki nduru,
\q1 aandongoragia maaĩ-inĩ marĩ na ũhurũko.
\q2 
\v 3 Nĩariũkagia ngoro yakwa,
\q1 akandongoragia njĩra-inĩ cia ũthingu,
\q2 nĩ ũndũ wa rĩĩtwa rĩake.
\q1 
\v 4 O na ingĩtuĩka ndĩrahungurĩra
\q2 mũkuru ũrĩ nduma ta ya gĩkuũ,
\q1 ndirĩ ũũru ingĩĩtigĩra,
\q2 nĩgũkorwo ũrĩ hamwe na niĩ;
\q1 thiarĩ waku na mũthĩgi waku
\q2 nĩciihooreragia.
\b
\q1 
\v 5 Ũnjaragĩra metha mbere yakwa
\q2 o harĩa thũ ciakwa irĩ.\f + \fr 23:5 \ft Matukũ ma tene irĩkanĩro ciahũũragwo mũhũũri na ũhoro wa kũrĩanĩra irio cia kuonania gĩkeno na ũrata.\f*
\q1 Ũnjitagĩrĩria maguta mũtwe;\f + \fr 23:5 \ft Mũgeni wa gĩtĩĩo nĩahakagwo maguta manungi wega mũtwe hĩndĩ ya iruga.\f*
\q2 gĩkombe gĩakwa nĩkĩiyũrĩrĩire.
\q1 
\v 6 Ti-itherũ wega na wendani nĩirĩrũmanagĩrĩra na niĩ
\q2 matukũ mothe ma muoyo wakwa,
\q1 na niĩ ngũtũũra nyũmba ya Jehova nginya tene.
\c 24
\s1 Jehova nĩ Mũthamaki Mũnene
\d Thaburi ya Daudi
\q1 
\v 1 Thĩ nĩ ya Jehova, na kĩrĩa gĩothe kĩrĩ thĩinĩ wayo,
\q2 mabũrũri mothe o na arĩa matũũraga kuo;
\q1 
\v 2 nĩgũkorwo nĩwe waakire mũthingi wayo igũrũ rĩa maria,
\q2 na akĩmĩrũmia ĩikare igũrũ rĩa maaĩ.
\b
\q1 
\v 3 Nũũ ũngĩambata kĩrĩma-inĩ kĩa Jehova?
\q2 Nũũ ũngĩrũgama handũ harĩa hake haamũre?
\q1 
\v 4 Nĩ mũndũ ũrĩa ũrĩ na moko matheru na akaaga ũũru ngoro,
\q2 na ũrĩa ngoro yake ĩtahooyaga mũhianano,
\q2 o na kana akeehĩta na maheeni.
\q1 
\v 5 Mũndũ ũcio nĩarĩamũkagĩra kĩrathimo kuuma kũrĩ Jehova,
\q2 na onagwo atarĩ mũhĩtia nĩ Ngai, Mũhonokia wake.
\q1 
\v 6 Ũguo nĩguo rũciaro rwa arĩa mamũrongoragia rũtariĩ,
\q2 o rũrĩa rũrongoragia ũthiũ waku, Wee Ngai wa Jakubu.
\b
\q1 
\v 7 Ambarariai mĩtwe yanyu, inyuĩ ihingo ici,
\q2 ambararioi inyuĩ mĩrango ĩno ya tene,
\q2 nĩguo Mũthamaki wa riiri atoonye thĩinĩ.
\q1 
\v 8 Mũthamaki ũcio wa riiri nĩwe ũũ?
\q2 Nĩwe Jehova ũrĩa ũrĩ hinya na nĩ njamba,
\q2 nĩwe Jehova ũrĩa njamba ita-inĩ.
\q1 
\v 9 Ambarariai mĩtwe yanyu, inyuĩ ihingo ici,
\q2 mĩambarariei inyuĩ mĩrango ĩno ya tene,
\q2 nĩguo Mũthamaki wa riiri atoonye thĩinĩ.
\q1 
\v 10 Mũthamaki ũcio wa riiri nĩwe ũ?
\q2 Jehova Mwene-Hinya-Wothe-rĩ,
\q2 nĩwe Mũthamaki wa riiri.
\c 25
\s1 Ihooya rĩa kũũria Gũtongorio na Kũgitĩrwo
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, ngoro yakwa ndĩmĩroretie na igũrũ kũrĩ we;
\q2 
\v 2 Wee Ngai wakwa, nowe ndĩhokete.
\q1 Ndũkareke njonorithio,
\q2 o na kana ũreke thũ ciakwa ingenerere.
\q1 
\v 3 Gũtirĩ mũndũ ũkwĩhokete
\q2 ũgaaconorithio o na rĩ,
\q1 no arĩa mekaga andũ ũũru hatarĩ gĩtũmi-rĩ,
\q2 acio nĩo magaconorithio.
\b
\q1 
\v 4 Wee Jehova, nyonia mĩthiĩre yaku,
\q2 ũũmenyithie njĩra ciaku;
\q1 
\v 5 ndongoria ũhoro-inĩ waku wa ma na ũndutage,
\q2 nĩgũkorwo nĩwe Ngai ũrĩa ũũhonokagia,
\q2 na nĩwe kĩĩrĩgĩrĩro gĩakwa mũthenya wothe.
\q1 
\v 6 Jehova, ririkana tha ciaku nyingĩ o na wendo waku,
\q2 nĩgũkorwo nĩ cia kuuma o tene.
\q1 
\v 7 Ndũkaririkane mehia ma ũnini wakwa,
\q2 o na kana mehia makwa ma ũremi;
\q1 ndirikana kũringana na wendani waku,
\q2 nĩ ũndũ wa wega waku, Wee Jehova.
\b
\q1 
\v 8 Jehova nĩ mwega na nĩ mũrũngĩrĩru;
\q2 nĩ ũndũ ũcio andũ arĩa ehia nĩarĩmonagĩrĩria njĩra ciake.
\q1 
\v 9 Atongoragia andũ arĩa menyiihagia na njĩra ĩrĩa yagĩrĩire,
\q2 na akamarutaga njĩra yake.
\q1 
\v 10 Njĩra ciothe cia Jehova nĩ cia wendani na wĩhokeku,
\q2 harĩ arĩa mamenyagĩrĩra kĩrĩkanĩro gĩake.
\q1 
\v 11 Wee Jehova, nĩ ũndũ wa rĩĩtwa rĩaku-rĩ,
\q2 ndekera mehia makwa, o na gũtuĩka nĩ manene.
\q1 
\v 12 Mũndũ ũrĩa mwĩtigĩri Jehova nũũ?
\q2 Mũndũ ũcio nĩarĩmuonagĩrĩria njĩra ĩrĩa aagĩrĩirwo nĩ kũgera.
\q1 
\v 13 Mũndũ ũcio egũtũũra matukũ make agaacĩire,
\q2 nacio njiaro ciake nĩikaagaya bũrũri.
\q1 
\v 14 Jehova nĩehokaga andũ arĩa mamwĩtigagĩra;
\q2 nĩo amenyithagia kĩrĩkanĩro gĩake.
\q1 
\v 15 Maitho makwa maikaraga hĩndĩ ciothe macũthĩrĩirie Jehova,
\q2 nĩgũkorwo nowe wiki ũngĩteithũkithia magũrũ makwa mũtego-inĩ.
\b
\q1 
\v 16 Hũgũkĩra, ũnyonie ũtugi waku,
\q2 nĩgũkorwo ndĩ o nyiki na ndĩ mũnyamarĩku.
\q1 
\v 17 Mathĩĩna ma ngoro yakwa nĩmaingĩhĩte;
\q2 niinĩra ruo rũrĩa ndĩ naruo.
\q1 
\v 18 Rora mĩnyamaro yakwa o na gũtangĩka gwakwa,
\q2 ũkĩndekere mehia makwa mothe.
\q1 
\v 19 Rora thũ ciakwa wone ũrĩa cingĩhĩte,
\q2 nacio iithũire na rũthũũro rũtarĩ tha!
\q1 
\v 20 Menyagĩrĩra muoyo wakwa na ũũthare;
\q2 ndũkareke njonorithio,
\q2 nĩgũkorwo nĩ harĩwe njũragĩra.
\q1 
\v 21 Wĩkindĩru wa ngoro na ũrũngĩrĩru irongitagĩra,
\q2 tondũ nĩwe njĩrĩgagĩrĩra.
\b
\q1 
\v 22 Wee Ngai, gĩkũũre andũ a Isiraeli,
\q2 moime mathĩĩna-inĩ mao mothe!
\c 26
\s1 Ihooya rĩa Mũndũ Mwega
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, nduĩra itua rĩa kĩhooto,
\q2 nĩgũkorwo mĩthiĩre yakwa nĩmĩkindĩrĩku;
\q1 ndũũrĩte ndĩhokete Jehova itegũthangania.
\q1 
\v 2 Wee Jehova, ngeria na ũndorie,
\q2 tuĩria ngoro yakwa o na meciiria makwa;
\q1 
\v 3 nĩgũkorwo wendo waku ũkoragwo ũrĩ mbere yakwa,
\q2 na ngeragĩra njĩra-inĩ yaku ya ũhoro wa ma.
\q1 
\v 4 Ndiikaranagia na andũ a maheeni,
\q2 o na kana ngagwatanĩra na andũ arĩa marĩ ũhinga.
\q1 
\v 5 Nĩthũire kĩũngano kĩa andũ arĩa mekaga ũũru,
\q2 na ngarega gũikarania na andũ arĩa aaganu.
\q1 
\v 6 Ngwĩthamba moko nyonanie ndirĩ na mahĩtia,\f + \fr 26:6 \ft Gwĩthamba moko mbere ya mũingĩ kuonanagia atĩ mũndũ ũcio ndeekĩte ngero ĩyo.\f*
\q2 thiũrũrũke kĩgongona gĩaku, Wee Jehova,
\q1 
\v 7 nyine nyanĩrĩire rwĩmbo rwa gũcookia ngaatho,
\q2 na heane ũhoro wa ciĩko ciaku ciothe cia magegania.
\q1 
\v 8 Wee Jehova, nĩnyendete nyũmba ĩrĩa ũtũũraga,
\q2 o handũ harĩa riiri waku ũikaraga.
\b
\q1 
\v 9 Ndũkeherie ngoro yakwa hamwe na ya arĩa mehagia,
\q2 kana muoyo wakwa hamwe na wa andũ arĩa maitaga thakame,
\q1 
\v 10 arĩa marĩ na maũndũ ma waganu moko-inĩ mao,
\q2 o arĩa moko mao ma ũrĩo maiyũrĩte mahaki.
\q1 
\v 11 No niĩ-rĩ, ndũũraga mũtũũrĩre ũtarĩ ũcuuke;
\q2 kĩngũũre na ũnjiguĩre tha.
\b
\q1 
\v 12 Magũrũ makwa marũgamĩte handũ harĩa haigananu;
\q2 nĩndĩrĩgoocaga Jehova ndĩ kĩũngano-inĩ kĩnene.
\c 27
\s1 Kũgĩa na Ũũmĩrĩru harĩ Jehova
\d Thaburi ya Daudi
\q1 
\v 1 Jehova nĩwe ũtheri wakwa na ũhonokio wakwa;
\q2 ingĩgĩĩtigĩra ũ?
\q1 Jehova nĩwe kĩĩhitho kĩa muoyo wakwa;
\q2 ingĩkĩmakio nũũ?
\q1 
\v 2 Rĩrĩa andũ arĩa ooru manjũkĩrĩra
\q2 nĩguo matambuure nyama cia mwĩrĩ wakwa,
\q1 o acio thũ ciakwa na arĩa marĩ muku na niĩ maatharĩkĩra-rĩ,
\q2 marĩhĩngagwo makagũa.
\q1 
\v 3 O na mbũtũ cia ita ingĩndigiicĩria,
\q2 ngoro yakwa ndĩngĩĩtigĩra;
\q2 o na ingĩũkĩrĩrwo nĩ ita,
\q2 ndingĩgĩa na nganja.
\b
\q1 
\v 4 Ndĩ o ũndũ ũmwe njũũragia harĩ Jehova,
\q2 na noguo thingataga:
\q1 atĩ njikarage nyũmba ya Jehova
\q2 matukũ mothe ma muoyo wakwa,
\q1 ndĩĩonagĩre wega wa Jehova,
\q2 na nduĩragie kĩrĩra ndĩ thĩinĩ wa hekarũ yake.
\q1 
\v 5 Nĩgũkorwo mũthenya wa thĩĩna-rĩ,
\q2 akaangitĩra ndĩ hau gĩikaro-inĩ gĩake;
\q1 nĩakahitha kĩĩgunyĩ-inĩ kĩa hema yake,
\q2 na andũgamie igũrũ wa rwaro rwa ihiga.
\q1 
\v 6 Hĩndĩ ĩyo mũtwe wakwa nĩũkambarario
\q2 igũrũ wa thũ iria iithiũrũrũkĩirie;
\q1 nĩngaruta igongona ngĩanagĩrĩra na gĩkeno ndĩ hema-inĩ yake;
\q2 nĩngainĩra Jehova na ndĩmũgooce.
\b
\q1 
\v 7 Wee Jehova, igua mũgambo wakwa rĩrĩa ndagũkaĩra;
\q2 njiguagĩra tha na ũnjĩtĩkage.
\q1 
\v 8 Ha ũhoro waku, ngoro yakwa yugaga atĩrĩ, “Rongoria ũthiũ wake!”
\q2 Na niĩ ngoiga atĩrĩ, Wee Jehova, ũthiũ waku nĩguo ndĩ rongoragia.
\q1 
\v 9 Ndũkaahithe ũthiũ waku,
\q2 tiga kũingata ndungata yaku na marakara;
\q2 Wee nĩwe ũtũũrĩte ũndeithagia.
\q1 Ndũkandege kana ũndiganĩrie,
\q2 Wee Ngai Mũhonokia wakwa.
\q1 
\v 10 O na baba na maitũ mangĩndiganĩria,
\q2 Jehova nĩakanyamũkĩra.
\q1 
\v 11 Wee Jehova nyonagĩrĩria njĩra yaku,
\q2 na ũngeragĩrie njĩra ĩrĩa nũngarũ,
\q2 nĩ ũndũ wa thũ ciakwa.
\q1 
\v 12 Ndũkaneane kũrĩ arĩa marĩ muku na niĩ,
\q2 nĩgũkorwo aira a maheeni nĩmanjũkĩrĩire,
\q2 makaheeha mĩheehũ ya kũnjĩka ũũru.
\b
\q1 
\v 13 Niĩ nĩnjĩtĩkĩtie ũũ:
\q2 atĩ nĩngeyonera wega wa Jehova
\q2 ndĩ bũrũri wa arĩa marĩ muoyo.
\q1 
\v 14 Eterera o Jehova:
\q2 gĩa na hinya na ũũmĩrĩrie ngoro,
\q2 na weterere Jehova.
\c 28
\s1 Ihooya rĩa kũũria Ũteithio
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, nĩwe ndĩrakaĩra, Wee Rwaro rwakwa rwa Ihiga;
\q2 ndũkarege gũũthikĩrĩria.
\q1 Nĩgũkorwo ũngĩngirĩra,
\q2 ingĩhaana ta arĩa maikũrũkĩte magatoonya irima.
\q1 
\v 2 Igua gũthaithana gwakwa ngĩgũkaĩra ũndeithie,
\q2 o nyambararĩtie moko makwa
\q2 ndĩmerekeirie harĩa haku Hatheru-Mũno.
\b
\q1 
\v 3 Ndũkanguucũrũranie hamwe na andũ arĩa aaganu,
\q2 atĩ ũndwaranĩrie hamwe na arĩa mekaga ũũru,
\q2 o arĩa maaragia ndeto cia thayũ na andũ a itũũra,
\q2 no marĩ na ũũru ngoro-inĩ ciao.
\q1 
\v 4 Andũ acio marĩhe nĩ ũndũ wa ciĩko ciao,
\q2 na nĩ ũndũ wa wĩra wao mũũru;
\q1 marĩhe nĩ ũndũ wa wĩra wa moko mao,
\q2 ũmarĩhe o kĩrĩa kĩmagĩrĩire.
\q1 
\v 5 Tondũ matirũmbũyagia mawĩko ma Jehova
\q2 o na wĩra wa moko make,
\q1 we nĩakamatharũria na ndakamaaka rĩngĩ.
\b
\q1 
\v 6 Jehova arogoocwo,
\q2 nĩgũkorwo nĩaiguĩte ngĩmũthaitha anjiguĩre tha.
\q1 
\v 7 Jehova nĩwe hinya wakwa na nowe ngo yakwa;
\q2 ngoro yakwa nĩwe ĩĩhokete, na nĩandeithĩtie.
\q1 Ngoro yakwa nĩĩrarũũhia nĩ gĩkeno,
\q2 na nĩngũmũinĩra rwĩmbo rwa kũmũcookeria ngaatho.
\b
\q1 
\v 8 Jehova nĩwe hinya wa andũ ake,
\q2 na kũrĩ ũrĩa wake mũitĩrĩrie maguta nĩ kĩirigo kĩa hinya kĩa ũhonokio.
\q1 
\v 9 Honokia andũ aku na ũrathime igai rĩĩrĩ rĩaku,
\q2 tuĩka mũrĩithi wao na ũmakuuage nginya tene.
\c 29
\s1 Ũhootani wa Jehova
\d Thaburi ya Daudi
\q1 
\v 1 Rahai Jehova, inyuĩ ciũmbe cia igũrũ,
\q2 rahai Jehova tondũ nĩwe ũrĩ riiri na hinya.
\q1 
\v 2 Rahai Jehova, mũheane ũhoro wa riiri wa rĩĩtwa rĩake;
\q2 thathaiyai Jehova thĩinĩ wa ũkengi wa ũthingu wake.
\b
\q1 
\v 3 Mũgambo wa Jehova ũragamba na kũu iria-inĩ;
\q2 Mũrungu ũcio wa riiri nĩararuruma,
\q2 Jehova araruruma igũrũ rĩa maaĩ maingĩ.
\q1 
\v 4 Mũgambo wa Jehova nĩ ũrĩ ũhoti;
\q2 mũgambo wa Jehova ũiyũrĩte riiri.
\q1 
\v 5 Mũgambo wa Jehova unangaga mĩtarakwa;
\q2 Jehova oinangaga mĩtarakwa ya Lebanoni ĩgatuĩka tũcunjĩ.
\q1 
\v 6 Atũmaga bũrũri wa Lebanoni ũtũũhe ta njaũ,
\q2 nakĩo Kĩrĩma gĩa Sirioni\f + \fr 29:6 \ft Sirioni nĩ rĩĩtwa rĩngĩ rĩa Herimoni na rũthiomi rwa Finicia.\f* gĩgatũũha ta njaũ ya mbogo.
\q1 
\v 7 Mũgambo wa Jehova ũhenũkaga nĩnĩmbĩ cia mwaki.
\q1 
\v 8 Mũgambo wa Jehova ũinainagia werũ;
\q2 Jehova ainainagia Werũ wa Kadeshi.
\q1 
\v 9 Mũgambo wa Jehova ũthioraga mĩtĩ ya mĩgandi,
\q2 na ũgatũma mĩtitũ ĩhũrũrũke ĩgatigwo ũtheri.
\q1 Nakuo hekarũ-inĩ yake arĩa othe marĩ kuo makaanĩrĩra
\q2 makoiga, “Kaĩ arĩ riiri-ĩ!”
\b
\q1 
\v 10 Jehova arĩ igũrũ rĩa mũiyũro wa maaĩ aikarĩire gĩtĩ kĩa ũnene;
\q2 Jehova egũtũũra aikarĩire gĩtĩ kĩa ũnene arĩ Mũthamaki nginya tene.
\q1 
\v 11 Jehova aheaga andũ ake hinya;
\q2 Jehova arathimaga andũ ake magaikara na thayũ.
\c 30
\s1 Ihooya rĩa Gũcookia Ngaatho
\q1 
\v 1 Wee Jehova-rĩ, nĩngũgũtũũgĩria
\q2 nĩgũkorwo wandutire kũrĩa kũriku,
\q2 na ũkĩgiria thũ ciakwa ingenerere.
\q1 
\v 2 Wee Jehova Ngai wakwa,
\q2 ndagũkaĩire ũndeithie nawe ũkĩĩhonia.
\q1 
\v 3 Wee Jehova, wandutire kuuma mbĩrĩra-inĩ;
\q2 ũkĩgiria njikũrũke, ndoonye irima.
\b
\q1 
\v 4 Inĩrai Jehova mũmũgooce, inyuĩ andũ ake aamũre;
\q2 mũgooce rĩĩtwa rĩu rĩake itheru,
\q1 
\v 5 nĩgũkorwo marakara make nĩ ma kahinda o kanini,
\q2 no ũtugi wake nĩwagũtũũria mũndũ muoyo;
\q1 kĩrĩro no kĩraarĩre ũtukũ wothe
\q2 no rũciinĩ gwakĩa kũrooke gĩkeno.
\b
\q1 
\v 6 Hĩndĩ ĩrĩa ndagaacĩire, ndoigire atĩrĩ,
\q2 “Ndirĩ hĩndĩ ngenyenyeka.”
\q1 
\v 7 Wee Jehova, rĩrĩa wanyonirie ũtugi waku-rĩ,
\q2 watũmire ndĩhaande o ta kĩrĩma;
\q1 no rĩrĩa wahithire ũthiũ waku-rĩ,
\q2 nĩndamakire.
\b
\q1 
\v 8 Wee Jehova nĩwe ndakaĩire;
\q2 ngĩthaitha Mwathani anjiguĩre tha:
\q1 
\v 9 “Mwanangĩko wakwa ũngĩkorwo na uumithio ũrĩkũ,
\q2 ingĩtoonyerera irima-inĩ?
\q1 Rũkũngũ-rĩ, no rũkũgooce?
\q2 No rwanĩrĩre wĩhokeku waku?
\q1 
\v 10 Wee Jehova, thikĩrĩria na ũnjiguĩre tha;
\q2 Wee Jehova, tuĩka ũteithio wakwa.”
\b
\q1 
\v 11 Wagarũrire kĩgirĩko gĩakwa gĩgĩtuĩka rwĩmbo rwa gĩkeno;
\q2 ũkĩnduta nguo yakwa ya ikũnia, ũkĩhumba gĩkeno,
\q1 
\v 12 nĩgeetha ngoro yakwa ĩkũinĩre na ndĩgakire.
\q2 Wee Jehova Ngai wakwa, ngũtũũra ngũcookagĩria ngaatho nginya tene.
\c 31
\s1 Ihooya rĩa Kwĩhoka Jehova
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, nĩ harĩwe njũrĩire;
\q2 ndũkanareke njonorithio;
\q2 nĩ ũndũ wa ũthingu waku-rĩ, ndeithũra.
\q1 
\v 2 Ndegera gũtũ
\q2 na ũhiũhe ũũke ũũhatũre;
\q1 tuĩka rwaro rwakwa rwa ihiga rwa kũũrĩra,
\q2 ũtuĩke gĩikaro kĩirigĩre na hinya, ũũhonokie.
\q1 
\v 3 Nĩgũkorwo Wee nĩwe Rwaro rwakwa rwa Ihiga
\q2 na gĩikaro gĩakwa kĩirigĩre na hinya,
\q2 nĩ ũndũ wa rĩĩtwa rĩaku, ndongoria na ũnyonie njĩra.
\q1 
\v 4 Ndeithũkithia mũtego-inĩ ũrĩa nyambĩirwo,
\q2 nĩgũkorwo nĩwe rĩũrĩro rĩakwa.
\q1 
\v 5 Roho wakwa ndaũiga moko-inĩ maku;
\q2 Wee Jehova, ngũũra, o Wee Mũrungu ũrĩa wa ma.
\b
\q1 
\v 6 Nĩthũire arĩa mahooyaga ngai cia mĩhianano ĩtarĩ kĩene;
\q2 niĩ ndĩhokete o Jehova.
\q1 
\v 7 Niĩ nĩngũcanjamũka na ngenage nĩ ũndũ wa wendo waku,
\q2 nĩgũkorwo nĩwonire mĩnyamaro yakwa,
\q2 na ũkĩmenya ruo rũnene rwa ngoro yakwa.
\q1 
\v 8 Ndũũneanĩte kũrĩ thũ,
\q2 no nĩũkinyithĩtie magũrũ makwa handũ haariĩ.
\b
\q1 
\v 9 Njiguĩra tha, Wee Jehova, nĩgũkorwo ndĩ mũnyamarĩku;
\q2 maitho makwa nĩmaroorwo nĩ hinya nĩ ũndũ wa kĩeha,
\q2 ngoro yakwa na mwĩrĩ wakwa ikoorwo nĩ hinya nĩ ũndũ wa ihooru.
\q1 
\v 10 Muoyo wakwa nĩũniinĩtwo nĩ ruo rũnene,
\q2 na mĩaka yakwa ĩkaniinwo nĩ gũcaaya;
\q1 nĩnjũrĩtwo nĩ hinya nĩ ũndũ wa mĩnyamaro yakwa,
\q2 namo mahĩndĩ makwa makaaga hinya.
\q1 
\v 11 Nĩ ũndũ wa thũ ciakwa ciothe,
\q2 nduĩkĩte wa kũnyararwo nĩ andũ a itũũra rĩakwa;
\q1 nduĩkĩte kĩndũ gĩa gwĩtigĩrwo nĩ arata akwa,
\q2 nao arĩa maanyona njĩra-inĩ nĩ kũũra moraga.
\q1 
\v 12 Nĩmariganĩirwo nĩ niĩ o ta mũndũ ũkuĩte;
\q2 ngakĩhaana o ta nyũngũ nguũ.
\q1 
\v 13 Nĩgũkorwo nĩndĩraigua njambanio ya andũ aingĩ;
\q2 guoya mũnene ũkĩnyumaga na mĩena yothe;
\q1 marathugunda manjĩke ũũru,
\q2 makagĩa ndundu ya ũrĩa mangĩnjũraga.
\b
\q1 
\v 14 No niĩ nĩwe ndĩhokete, Wee Jehova,
\q2 ngoiga atĩrĩ, “Wee nĩwe Ngai wakwa.”
\q1 
\v 15 Mahinda makwa marĩ moko-inĩ maku;
\q2 ndeithũra kuuma kũrĩ thũ ciakwa,
\q2 na kuuma kũrĩ arĩa maathingataga.
\q1 
\v 16 Tũma ũthiũ waku warĩre ndungata yaku;
\q2 honokia nĩ ũndũ wa wendo waku ũtathiraga.
\q1 
\v 17 Wee Jehova, ndũkareke njonorithio,
\q2 nĩgũkorwo nĩwe ngayagĩra;
\q1 no andũ arĩa aaganu ũreke maconorithio
\q2 na makome mbĩrĩra-inĩ makirĩte ki.
\q1 
\v 18 Tũma mĩromo yao ya kũheenania ĩkirio,
\q2 nĩgũkorwo maaragia na mwĩtĩĩo na kĩnyararo,
\q2 maaragia na mwĩgaatho magookĩrĩra andũ arĩa athingu.
\b
\q1 
\v 19 Kaĩ wega waku ũrĩa ũigĩire arĩa magwĩtigĩrĩte, nĩ mũingĩ-ĩ,
\q2 o wega ũrĩa ũheaga andũ arĩa moragĩra harĩwe andũ othe makĩonaga.
\q1 
\v 20 Ũmahithaga harĩa Wee ũrĩ o harĩa hegitĩtie,
\q2 kuuma kũrĩ arĩa mamaciiragĩra kũmeka ũũru;
\q1 ũmaigaga gĩikaro-inĩ gĩaku,
\q2 ũkamagitĩra harĩ nĩmĩ iria icambanagia.
\b
\q1 
\v 21 Jehova arogoocwo,
\q2 nĩgũkorwo nĩanyonirie wendo wake wa magegania
\q2 rĩrĩa ndaarĩ itũũra inene rĩrigiicĩirio nĩ thũ.
\q1 
\v 22 Rĩrĩa ndaarĩ mũmaku, ndoigire atĩrĩ,
\q2 “Nĩnjeheretio maitho-inĩ maku!”
\q1 No nĩwaiguire ngĩgũthaitha ũnjiguĩre tha,
\q2 rĩrĩa ndagũkaĩire ũndeithie.
\b
\q1 
\v 23 Endai Jehova inyuĩ andũ ake aamũre!
\q2 Jehova nĩamenyagĩrĩra arĩa ehokeku,
\q2 no ũrĩa mwĩtĩĩi amũrĩhaga o ũrĩa kwagĩrĩire.
\q1 
\v 24 Gĩai na hinya na mwĩyũmĩrĩrie ngoro,
\q2 inyuĩ inyuothe arĩa mwĩhokete Jehova.
\c 32
\s1 Gĩkeno gĩa Kũrekerwo Mehia
\d Thaburi ya Daudi
\q1 
\v 1 Kũrathimwo-rĩ,
\q2 nĩ ũrĩa ũrekeirwo mahĩtia make,
\q2 o ũrĩa mehia make mahumbĩrĩtwo.
\q1 
\v 2 Kũrathimwo-rĩ,
\q2 nĩ mũndũ ũrĩa Jehova atatuaga mwĩhia,
\q2 na ũrĩa ũtarĩ ũhinga ngoro.
\b
\q1 
\v 3 Rĩrĩa ndakirĩte ki,
\q2 mahĩndĩ makwa nĩmahinyarire
\q2 nĩ ũndũ wa gũcaaya gwakwa mũthenya wothe.
\q1 
\v 4 Nĩgũkorwo guoko gwaku
\q2 nĩ kwanditũhagĩra mũthenya na ũtukũ;
\q1 hinya wakwa wathirire
\q2 o ta ũrĩa ime rĩthiraga hĩndĩ ya riũa.
\q1 
\v 5 Hĩndĩ ĩyo ngĩkumbũrĩra mehia makwa,
\q2 na ndiahithire waganu wakwa,
\q1 ndoigire atĩrĩ, “Nĩngumbũra mahĩtia makwa kũrĩ Jehova,”
\q2 nawe ũkĩndekera ũũru wa mehia makwa.
\b
\q1 
\v 6 Nĩ ũndũ ũcio mũndũ wothe mwĩtigĩri Ngai
\q2 nĩakũhooe rĩrĩa ũngĩoneka;
\q1 ti-itherũ rĩrĩa maaĩ maingĩ marĩ hinya maambũrũrũka,
\q2 matingĩmũkinyĩra.
\q1 
\v 7 Wee nĩwe kĩĩhitho gĩakwa;
\q2 nĩũkangitĩra hĩndĩ ya mathĩĩna,
\q2 na ũũthiũrũrũkĩrie na nyĩmbo cia ũhonokio.
\b
\q1 
\v 8 Nĩndĩrĩkũrutaga na ngakuonereria njĩra ĩrĩa wagĩrĩirwo nĩ kũgera;
\q2 ndĩrĩgũtaaraga na ngũmenyagĩrĩre.
\q1 
\v 9 Ndũkahaane ta mbarathi kana nyũmbũ,
\q2 iria itarĩ ũmenyo,
\q1 iria arĩ o nginya ciĩkĩrwo matamu na mĩkwa kanua,
\q2 kwaga ũguo itingĩgũkuhĩrĩria.
\q1 
\v 10 Andũ arĩa aaganu monaga maruo maingĩ,
\q2 no mũndũ ũrĩa wĩhokaga Jehova
\q2 egũtũũra arigiicĩirio nĩ wendo ũrĩa ũtathiraga.
\b
\q1 
\v 11 Inyuĩ arĩa athingu kenerai Jehova na mũcanjamũke;
\q2 mũinĩrei, inyuothe arĩa arũngĩrĩru ngoro!
\c 33
\s1 Rwĩmbo rwa Kũgooca
\q1 
\v 1 Inĩrai Jehova mũkenete, inyuĩ andũ arĩa athingu;
\q2 andũ arĩa arũngĩrĩru ngoro nĩo maagĩrĩirwo nĩkũmũgooca.
\q1 
\v 2 Goocai Jehova na kĩnanda kĩa mũgeeto;
\q2 mũinĩrei na kĩnanda kĩrĩa kĩgeete na nga ikũmi.
\q1 
\v 3 Mũinĩrei rwĩmbo rwerũ;
\q2 hũũrai inanda mũrĩ na ũũgĩ, na mwanĩrĩre nĩ gũkena.
\b
\q1 
\v 4 Nĩgũkorwo kiugo kĩa Jehova nĩkĩerekereru na nĩ kĩa ma;
\q2 we nĩ mwĩhokeku maũndũ-inĩ mothe marĩa ekaga.
\q1 
\v 5 Jehova nĩendete ũthingu na ciira wa kĩhooto;
\q2 thĩ yothe ĩiyũrĩte wendani wake ũrĩa ũtathiraga.
\b
\q1 
\v 6 Igũrũ rĩombirwo na ũndũ wa kiugo kĩa Jehova,
\q2 mbũtũ cia igũrũ ikĩũmbwo na mĩhũmũ ya kanua gake.
\q1 
\v 7 Aacookanĩrĩirie maaĩ ma iria inene ndigithũ-inĩ;
\q2 maaĩ ma kũrĩa kũriku aamaigire thĩinĩ wa makũmbĩ.
\q1 
\v 8 Thĩ yothe nĩĩtigĩre Jehova;
\q2 andũ othe a thĩ nĩmamũtĩĩe.
\q1 
\v 9 Nĩgũkorwo aaririe, thĩ ĩkĩgĩa kuo;
\q2 aathanire, ĩkĩĩhaanda, ĩkĩrũma wega.
\q1 
\v 10 Jehova nĩarigiicaga mĩbango ya ndũrĩrĩ;
\q2 nĩathũkagia mĩoroto ya andũ.
\q1 
\v 11 No mĩbango ya Jehova ĩĩhaandaga wega nginya tene,
\q2 mĩoroto ya ngoro yake ĩgakinyĩra njiarwa na njiarwa.
\b
\q1 
\v 12 Kũrathimwo-rĩ, nĩ rũrĩrĩ rũrĩa Jehova arĩ we Ngai waruo,
\q2 andũ arĩa eethuurĩire matuĩke igai rĩake.
\q1 
\v 13 Jehova arĩ igũrũ aroraga thĩ
\q2 akoona andũ othe;
\q1 
\v 14 acũthagĩrĩria arĩa othe matũũraga gũkũ thĩ,
\q2 arĩ o kũu gĩikaro-inĩ gĩake,
\q1 
\v 15 we nĩwe mũũmbi wa ngoro ciao othe,
\q2 na nĩoĩ mawĩra mao mothe.
\q1 
\v 16 Gũtirĩ mũthamaki ũhonokagio nĩ mũigana wa ita rĩake,
\q2 na gũtirĩ njamba ya ita ĩĩteithũraga nĩ ũndũ wa hinya wayo mũnene.
\q1 
\v 17 Ha ũhoro wa kũhonokania-rĩ,
\q2 mbarathi cia mbaara nĩ mwĩhoko wa tũhũ;
\q2 o na ĩrĩ na hinya mũingĩ ndĩngĩhonokania.
\q1 
\v 18 No rĩrĩ, maitho ma Jehova macũthagĩrĩria andũ arĩa mamwĩtigagĩra,
\q2 o acio maikaraga mehokete wendo wake ũrĩa ũtathiraga,
\q1 
\v 19 akamateithũra gĩkuũ-inĩ,
\q2 na akamatũũria muoyo hĩndĩ ya ngʼaragu.
\b
\q1 
\v 20 Ithuĩ twetagĩrĩra Jehova tũrĩ na mwĩhoko;
\q2 nĩwe ũteithio witũ o na ngo iitũ.
\q1 
\v 21 Ngoro ciitũ nĩcikenete nĩ ũndũ wake,
\q2 nĩgũkorwo twĩhokete rĩĩtwa rĩake itheru.
\q1 
\v 22 Wee Jehova-rĩ, wendo waku ũrĩa ũtathiraga ũroikarania na ithuĩ,
\q2 o ta ũrĩa ithuĩ tũkwĩrĩgĩrĩire.
\c 34
\s1 Kũgooca Jehova nĩ ũndũ wa Ũhonokio Wake
\d Thaburi ya Daudi
\q1 
\v 1 Ndĩrĩkumagia Jehova hĩndĩ ciothe;
\q2 ndĩrĩmũgoocaga na kanua gakwa hĩndĩ ciothe.
\q1 
\v 2 Ngoro yakwa nĩ Jehova ĩrĩĩrahaga;
\q2 arĩa anyamaarĩku marĩiguaga ũguo magakena.
\q1 
\v 3 Goocai Jehova mũmũnenehie mũrĩ hamwe na niĩ;
\q2 rekei tũtũũgĩrie rĩĩtwa rĩake tũrĩ hamwe.
\b
\q1 
\v 4 Ndarongoririe Jehova, nake akĩnjĩtĩka,
\q2 akĩndeithũra kuuma kũrĩ maũndũ marĩa mothe maanjĩkagĩra guoya.
\q1 
\v 5 Andũ arĩa mamũcũthagĩrĩria matheragĩrwo nĩ ũtheri;
\q2 mothiũ mao gũtirĩ hĩndĩ magaaconorithio.
\q1 
\v 6 Mũndũ ũyũ mũthĩĩni aakaĩire Jehova, nake Jehova akĩmũigua,
\q2 akĩmũhonokia mathĩĩna-inĩ make mothe.
\q1 
\v 7 Mũraika wa Jehova aikaraga arangĩire arĩa othe mamwĩtigagĩra,
\q2 na akamateithũra othe.
\b
\q1 
\v 8 Camai muone atĩ Jehova nĩ mwega;
\q2 kũrathimwo nĩ mũndũ ũrĩa ũragĩra harĩ we.
\q1 
\v 9 Mwĩtigĩrei Jehova, inyuĩ andũ ake aamũre,
\q2 nĩgũkorwo arĩa mamwĩtigĩrĩte gũtirĩ kĩndũ maagaga.
\q1 
\v 10 Mĩrũũthi no yage gĩa kũrĩa ĩhũte,
\q2 no arĩa marongoragia Jehova gũtirĩ kĩndũ kĩega maagaga.
\b
\q1 
\v 11 Ũkai ciana ciakwa, mũthikĩrĩrie ũrĩa nguuga;
\q2 nĩngũmũruta gwĩtigĩra Jehova.
\q1 
\v 12 Mũndũ ũrĩa wanyu ũngĩenda gũtũũra muoyo,
\q2 na erirĩrie kuona matukũ maingĩ mega,
\q1 
\v 13 nĩakĩmenyerere rũrĩmĩ rwake rũtikoige ũũru,
\q2 na mĩromo yake ndĩkaarie maheeni.
\q1 
\v 14 Garũrũka utige gwĩka ũũru na wĩke ũrĩa kwagĩrĩire;
\q2 caragia thayũ na ũũthingatage.
\b
\q1 
\v 15 Maitho ma Jehova macũthagĩrĩria andũ arĩa athingu,
\q2 na matũ make magathikĩrĩria kĩrĩro kĩao;
\q1 
\v 16 ũthiũ wa Jehova ũũkagĩrĩra andũ arĩa mekaga ũũru,
\q2 nĩguo moima thĩ matikanaririkanwo.
\b
\q1 
\v 17 Andũ arĩa athingu makayaga, Jehova akamaigua;
\q2 amateithũraga kuuma mathĩĩna-inĩ mao mothe.
\q1 
\v 18 Jehova akoragwo arĩ hakuhĩ na andũ arĩa ahehenjeku ngoro,
\q2 na akahonokia arĩa athuthĩku roho.
\b
\q1 
\v 19 Mũndũ ũrĩa mũthingu no akorwo arĩ na mathĩĩna maingĩ,
\q2 no Jehova amũteithũraga harĩ mo mothe;
\q1 
\v 20 agitagĩra mahĩndĩ make mothe,
\q2 gũtirĩ o na rĩmwe rĩngiunĩka.
\b
\q1 
\v 21 Andũ arĩa aaganu makooragwo nĩ ũũru;
\q2 nao arĩa mathũire andũ arĩa athingu nĩmagatuĩrwo ciira.
\q1 
\v 22 Jehova akũũraga ndungata ciake;
\q2 arĩa othe moragĩra harĩ we gũtirĩ ũgaatuĩrwo ciira.
\c 35
\s1 Kũhooya Kũhonokio kuuma kũrĩ Thũ
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, hũũrana na arĩa marahũũrana na niĩ;
\q2 rũa na arĩa mararũa na niĩ.
\q1 
\v 2 Oya ngo nene na gako kanini;
\q2 arahũka ũũke ũndeithie.
\q1 
\v 3 Hiũria itimũ na mĩcengi,
\q2 ũũkĩrĩre arĩa maathingatĩte.
\q1 Ĩra ngoro yakwa atĩrĩ,
\q2 “Niĩ nĩ niĩ ũhonokio waku.”
\b
\q1 
\v 4 Andũ arĩa mendaga kũnduta muoyo
\q2 maroconorithio na maagithio gĩtĩĩo,
\q1 arĩa mathugundaga kũnyũnũha
\q2 marocookio na thuutha mamakĩte.
\q1 
\v 5 Marohaana ta mahuti mombũrĩtwo nĩ rũhuho,
\q2 na mũraika wa Jehova amaingatithĩtie;
\q1 
\v 6 njĩra yao ĩrogĩa nduma na ĩtendere,
\q2 nake mũraika wa Jehova ahanyũkanie nao.
\b
\q1 
\v 7 Kuona atĩ nĩmahithĩire wabu wa kũndega hatarĩ gĩtũmi,
\q2 na makanyenjera irima hatarĩ gĩtũmi,
\q1 
\v 8 marokorererwo nĩ mwanangĩko matehaarĩirie,
\q2 wabu ũcio manyambĩire ũromanyiita o ene,
\q2 marogwa irima rĩu manyenjeire.
\q1 
\v 9 Hĩndĩ ĩyo ngoro yakwa ĩgaacanjamũka nĩ ũndũ wa Jehova,
\q2 na ĩkenagĩre ũhonokio wake.
\q1 
\v 10 Nĩngwanĩrĩra na ngoro yakwa yothe, njũũrie atĩrĩ,
\q2 “Nũũ ũhaana tawe, Wee Jehova?
\q1 O Wee ũhatũraga andũ arĩa athĩĩni harĩ arĩa marĩ hinya kũmakĩra,
\q2 ũkahatũra athĩĩni na abatari harĩ arĩa mamatunyaga indo.”
\b
\q1 
\v 11 Nĩkuumĩrĩte aira a maheeni,
\q2 makanjũũria ũhoro wa maũndũ itooĩ.
\q1 
\v 12 Wega wakwa mandĩhaga na ũũru,
\q2 magatiga ngoro yakwa ĩrĩ na ihooru.
\q1 
\v 13 No rĩrĩa o maarĩ arũaru, niĩ ndehumbire nguo ya ikũnia,
\q2 na ngĩĩnyiihia na ũndũ wa kwĩhinga kũrĩa irio.
\q1 Rĩrĩa mahooya makwa maagire macookio-rĩ,
\q2 
\v 14 ndaikarire ngĩcakayaga,
\q2 o taarĩ mũrata wakwa kana mũrũ wa maitũ ndaacakayagĩra.
\q1 Ndethikĩire ndĩ na ihooru,
\q2 o taarĩ mũndũ ũracakaĩra nyina.
\q1 
\v 15 No rĩrĩa ndahĩngirwo ngĩgwa, o moonganire hamwe mangenerere;
\q2 atharĩkĩri makĩũngana maatharĩkĩre itekũmenya.
\q2 Manjaambirie mategũtigithĩria.
\q1 
\v 16 Maanyũrũragia ta andũ matooĩ Ngai,
\q2 makaahagaranĩria magego mao.
\q1 
\v 17 Wee Jehova-rĩ, nĩ nginya rĩ ũgũikara wĩroreire?
\q2 Hatũra muoyo wakwa kuuma harĩ wanangi wao,
\q2 ũhatũre muoyo wakwa wa goro kuuma harĩ mĩrũũthi ĩno.
\q1 
\v 18 Nĩ niĩ ngũgũcookeria ngaatho kĩũngano-inĩ kĩrĩa kĩnene;
\q2 ndĩkũgoocaga ndĩ gatagatĩ ka andũ aingĩ.
\b
\q1 
\v 19 Ndũkareke arĩa maathũire tũhũ
\q2 mangũũrĩre maitho, mangenerere;
\q1 kana acio maamenete hatarĩ gĩtũmi
\q2 moinanĩre maitho.
\q1 
\v 20 Matiaragia ndeto cia thayũ,
\q2 no mathugundaga maũndũ ma maheeni,
\q2 ma gũũkĩrĩra andũ arĩa maikaraga na thayũ bũrũri-inĩ.
\q1 
\v 21 Manjathamagĩria tũnua twao makoiga atĩrĩ,
\q2 “Haiya! Haiya! Maitho maitũ nĩmeyoneire ũguo.”
\b
\q1 
\v 22 Wee Jehova, nĩwĩoneire ũguo; tiga gũkira.
\q2 Wee Mwathani-rĩ, ndũgaikare haraaya na niĩ.
\q1 
\v 23 Arahũka, ũkĩra ũngitĩre!
\q2 Hũũranĩra, Wee Ngai wakwa na Mwathani wakwa.
\q1 
\v 24 Wee Jehova, nduĩra kũringana na ũthingu waku, Wee Ngai wakwa;
\q2 ndũkareke mangũũrĩre maitho, mangenerere.
\q1 
\v 25 Ndũkareke meciirie atĩrĩ, “Haiya, ũguo noguo tũrendaga gwĩkĩke!”
\q2 Kana moige atĩrĩ, “Nĩtũmũmeretie.”
\b
\q1 
\v 26 Arĩa othe mangũũragĩra maitho mangenerere nĩ ũndũ wa mĩnyamaro yakwa
\q2 maroconorithio na manyiitwo nĩ kĩrigiicano;
\q1 arĩa othe metũũgagĩria igũrũ rĩakwa
\q2 maroconorithio na maagithio gĩtĩĩo.
\q1 
\v 27 Arĩa makenaga ndaatuĩrwo ciira na kĩhooto,
\q2 nĩmanĩrĩre na gĩkeno na gũcanjamũka;
\q1 nĩmatũũre moigaga atĩrĩ, “Jehova arotũgĩrio,
\q2 o we ũkenagĩra ũgaacĩru wa ndungata yake.”
\q1 
\v 28 Rũrĩmĩ rwakwa rũrĩaragia ũhoro wa ũthingu waku,
\q2 na ngũgoocage mũthenya wothe.
\c 36
\s1 Waganu wa Andũ
\d Thaburi ya Daudi
\q1 
\v 1 Ndĩ na ndũmĩrĩri nditũ ngoro-inĩ yakwa,
\q2 ĩkoniĩ wĩhia wa mũndũ ũrĩa mwaganu:
\q1 Nĩ atĩrĩ, hatirĩ wĩtigĩri Ngai
\q2 maitho-inĩ make.
\q1 
\v 2 Nĩ gũkorwo maitho-inĩ make mwene erahaga mũno,
\q2 ũũ atĩ ndangĩhota gũkũũrana o na kana athũũre mehia make.
\q1 
\v 3 Ciugo cia kanua gake nĩ cia waganu na nĩ cia maheeni;
\q2 nĩatigĩte gũtuĩka mũndũ mũũgĩ na wa gwĩkaga wega.
\q1 
\v 4 O na arĩ ũrĩrĩ-inĩ wake athugundaga o maũndũ mooru;
\q2 eheanaga njĩra-inĩ ya kũmwerekeria gwĩka ũũru,
\q2 na ndathũũraga ũndũ mũũru.
\b
\q1 
\v 5 Wee Jehova-rĩ, wendani waku ũkinyĩte o igũrũ,
\q2 naguo wĩhokeku waku ũgakinya o matu-inĩ.
\q1 
\v 6 Ũthingu waku ũhaana ta irĩma iria nene,
\q2 kĩhooto gĩaku gĩkarikĩra ta kũrĩa kũriku.
\q1 Wee Jehova-rĩ, ũmenyagĩrĩra mũndũ o na nyamũ.
\q2 
\v 7 Hĩ! Kaĩ wendo waku ũrĩa ũtathiraga nĩ wa goro mũno-ĩ!
\q1 Andũ othe anene na anini
\q2 moragĩra kĩĩgunyĩ-inĩ kĩa mathagu maku.
\q1 
\v 8 Marĩĩaga makaigania kuumana na ũingĩ wa nyũmba yaku;
\q2 ũmaheaga gĩa kũnyua kuuma rũũĩ-inĩ rwaku rwa gĩkeno.
\q1 
\v 9 Nĩgũkorwo gĩthima kĩa muoyo kĩrĩ kũrĩ we;
\q2 ũtheri-inĩ waku nĩho tuonaga ũtheri.
\b
\q1 
\v 10 Kĩrĩrĩria kwenda arĩa makũũĩ,
\q2 naguo ũthingu waku ũtũũre na arĩa arũngĩrĩru ngoro.
\q1 
\v 11 Ikinya rĩa ũrĩa mwĩtĩĩi rĩroaga kũnjũkĩrĩra,
\q2 o na kana guoko kwa ũrĩa mwaganu kũnyingate.
\q1 
\v 12 Ta rora wone ũrĩa andũ arĩa mekaga ũũru magwĩte thĩ;
\q2 maikanĩtio thĩ, na matingĩhota gũũkĩra!
\c 37
\s1 Marigĩrĩrio ma Andũ arĩa Athingu na arĩa Aaganu
\d Thaburi ya Daudi
\q1 
\v 1 Tigaga gũthĩĩnĩka ngoro nĩ ũndũ wa andũ arĩa mekaga ũũru,
\q2 o na kana ũiguage ũiru nĩ ũndũ wa arĩa mekaga mahĩtia;
\q1 
\v 2 nĩgũkorwo acio makaahooha o narua o ta ũrĩa nyeki ĩhoohaga,
\q2 na makue narua o ta ũrĩa riya rĩhoohaga rĩamunywo.
\b
\q1 
\v 3 Wĩhoke Jehova na wĩkage wega;
\q2 tũũra bũrũri-inĩ ũkenagĩra ũrĩithio wa thayũ.
\q1 
\v 4 Ĩkaga maũndũ ma gũkenia Jehova,
\q2 na nĩarĩkũhingagĩria merirĩria ma ngoro yaku.
\b
\q1 
\v 5 Rekagĩrĩria Jehova njĩra yaku;
\q2 mwĩhokage o we, nake nĩarĩĩkaga maũndũ maya:
\q1 
\v 6 Nĩarĩtũmaga ũthingu waku ware o ta rũciinĩ,
\q2 nakĩo kĩhooto gĩa ciira waku kĩare o ta riũa rĩa mũthenya barigici.
\b
\q1 
\v 7 Hoorera mbere ya Jehova na ũmweterere ũtegũthethũka;
\q2 ndũgathĩĩnĩke ngoro rĩrĩa andũ magaacĩra mĩthiĩre-inĩ yao,
\q2 rĩrĩa mekũhingia mathugunda mao ma gwĩka ũũru.
\b
\q1 
\v 8 Tigaga kũrakara na wĩrigagĩrĩrie mangʼũrĩ;
\q2 tigaga gũthĩĩnĩka ngoro, tondũ ũndũ ũcio no ũtũme wĩke ũũru.
\q1 
\v 9 Nĩgũkorwo andũ ooru nĩmakaniinwo,
\q2 no arĩa mehokete Jehova nĩmakagaya bũrũri.
\b
\q1 
\v 10 No kahinda kanini, arĩa aaganu mage kuoneka rĩngĩ;
\q2 o na mũngĩmacaria, mũtingĩmoona.
\q1 
\v 11 No arĩa ahooreri nĩo makaagaya bũrũri,
\q2 na matũũre makenete nĩkũingĩhĩrwo nĩ thayũ.
\b
\q1 
\v 12 Andũ arĩa aaganu mathugundaga mokĩrĩre andũ arĩa athingu,
\q2 na makamahagaranĩria magego;
\q1 
\v 13 no Mwathani athekagĩrĩra andũ acio aaganu,
\q2 nĩgũkorwo nĩoĩ mũthenya wao nĩũrooka.
\b
\q1 
\v 14 Andũ arĩa aaganu macomorete hiũ cia njora,
\q2 na makageeta ũta
\q1 nĩguo maniine mũndũ ũrĩa mũthĩĩni na mũbatari,
\q2 na moorage andũ arĩa njĩra ciao irũngĩrĩirie.
\q1 
\v 15 No hiũ icio ciao cia njora igaatheeca ngoro ciao ene,
\q2 na mota mao moinangwo.
\b
\q1 
\v 16 Nĩ kaba kĩndũ kĩnini kĩrĩ na andũ arĩa athingu,
\q2 gũkĩra ũtonga mũingĩ wa andũ aaganu;
\q1 
\v 17 nĩgũkorwo hinya wa andũ arĩa aaganu nĩũkaniinwo,
\q2 no Jehova atiiragĩrĩra andũ arĩa athingu.
\b
\q1 
\v 18 Matukũ ma andũ arĩa matarĩ ũcuuke nĩmooĩo nĩ Jehova,
\q2 na igai rĩao rĩgũtũũra nginya tene.
\q1 
\v 19 Hĩndĩ ya mwanangĩko matikoona ũũru;
\q2 na hĩndĩ ya ngʼaragu magaakorwo na irio cia kũigana.
\b
\q1 
\v 20 No andũ arĩa aaganu nĩmagathira:
\q2 Thũ cia Jehova igaathira ta ũrĩa ũthaka wa mĩgũnda ũthiraga,
\q2 nĩikabuĩria, ibuĩrie o ta ndogo.
\b
\q1 
\v 21 Andũ arĩa aaganu makoombaga na matirĩhaga,
\q2 no arĩa athingu maheanaga na ũtaana;
\q1 
\v 22 andũ arĩa Jehova arathimĩte nĩmakagaya bũrũri,
\q2 no arĩa arumĩte nĩmakaniinwo.
\b
\q1 
\v 23 Jehova angĩkenio nĩ mũthiĩre wa mũndũ,
\q2 atũmaga makinya make marũme wega;
\q1 
\v 24 o na angĩhĩngwo, ndangĩgũa,
\q2 nĩgũkorwo Jehova amũnyiitagĩrĩra na guoko gwake.
\b
\q1 
\v 25 Ndaarĩ mũnini, na rĩu ndĩ mũkũrũ,
\q2 no ndirĩ ndoona andũ arĩa athingu matiganĩirio,
\q2 kana ciana ciao ikĩhooya irio.
\q1 
\v 26 Hĩndĩ ciothe makoragwo marĩ ataana,
\q2 na makombanagĩra matekwenda uumithio;
\q2 ciana ciao nĩ ikaarathimwo.
\b
\q1 
\v 27 Theemaga ũũru, na wĩkage wega,
\q2 nawe ũtũũre bũrũri-inĩ nginya tene.
\q1 
\v 28 Nĩgũkorwo Jehova endete o kĩhooto,
\q2 na ndagatiganĩria arĩa ake ehokeku.
\b
\q1 Acio megũtũũra magitĩirwo nginya tene,
\q2 no ciana cia arĩa aaganu nĩikaniinwo.
\q1 
\v 29 Andũ arĩa athingu nĩo makaagaya bũrũri,
\q2 na matũũre kuo nginya tene.
\b
\q1 
\v 30 Kanua ka mũndũ mũthingu gatumũkaga ndeto cia ũũgĩ,
\q2 naruo rũrĩmĩ rwake rũkaaria kĩhooto.
\q1 
\v 31 Watho wa Ngai wake ũrĩ o ngoro-inĩ yake;
\q2 makinya make matingĩtenderũka.
\b
\q1 
\v 32 Andũ arĩa aaganu maikaraga moheirie arĩa athingu,
\q2 magĩcaria o ũrĩa mangĩmooraga;
\q1 
\v 33 no Jehova ndakamatiganĩria moko-inĩ ma andũ acio aaganu,
\q2 kana areke matuĩrwo atĩ nĩ ehia rĩrĩa magaaciirithio.
\b
\q1 
\v 34 Etagĩrĩra Jehova
\q2 na ũrũmagĩrĩre njĩra yake.
\q1 Nĩagagũtũũgĩria nĩguo ũgae bũrũri;
\q2 rĩrĩa andũ arĩa aaganu makaaniinwo-rĩ,
\q2 wee nĩũkeyonera ũndũ ũcio.
\b
\q1 
\v 35 Nĩnyonete mũndũ mwaganu na mũndũ ũtarĩ tha
\q2 agaacĩire ta mũtĩ mũruru ũrĩ o imerero-inĩ rĩaguo,
\q1 
\v 36 no thuutha wa kahinda o kanini akĩehera,
\q2 akĩaga gũkorwo ho rĩngĩ;
\q2 o na gũtuĩka nĩndamũcaririe, ndiigana kũmuona.
\b
\q1 
\v 37 Cũrania ũhoro wa mũndũ ũrĩa ũtarĩ ũcuuke,
\q2 na ũrore ũrĩa mũrũngĩrĩru,
\q2 ũhoro wake wa matukũ marĩa magooka nĩ ũhoro wa thayũ.
\q1 
\v 38 No rĩrĩ, andũ arĩa ehia othe nĩmakaniinwo;
\q2 no andũ arĩa aaganu mũthia wao nĩ kũũragwo makooragwo.
\b
\q1 
\v 39 Ũhonokio wa andũ arĩa athingu uumaga kũrĩ Jehova;
\q2 we nĩwe kĩĩhitho kĩao kĩa hinya hĩndĩ ya mathĩĩna.
\q1 
\v 40 Jehova nĩamateithagia na akamateithũra;
\q2 amateithũraga kuuma kũrĩ andũ arĩa aaganu na akamahonokia,
\q2 tondũ moragĩra harĩ we.
\c 38
\s1 Ihooya rĩa Mũndũ Ũrathĩĩnĩka
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, ndũkandũithie ũrĩ na marakara,
\q2 kana ũũherithie ũrĩ na mangʼũrĩ.
\q1 
\v 2 Nĩgũkorwo mĩguĩ yaku nĩĩtheceete,
\q2 na guoko gwaku nĩ kũũhũrĩte mũno.
\q1 
\v 3 Ndirĩ na ũgima wa mwĩrĩ tondũ wa mangʼũrĩ maku;
\q2 mahĩndĩ makwa nĩmarũaru nĩ ũndũ wa mehia makwa.
\q1 
\v 4 Mahĩtia makwa nĩmanditũhĩire mũno
\q2 o ta mũrigo mũritũ itangĩhota gũkuua.
\b
\q1 
\v 5 Ironda ciakwa nĩitogotete na ikanunga
\q2 nĩ tondũ wa ũrimũ wakwa wa mehia.
\q1 
\v 6 Thiiaga ndĩĩhacĩte, ngakungĩrĩra mũno,
\q2 mũthenya wothe ndindaga ngĩcakaya.
\q1 
\v 7 Mũgongo wakwa ũiyũrĩtwo nĩ ruo ta rwa mwaki;
\q2 ndirĩ na ũgima wa mwĩrĩ.
\q1 
\v 8 Ndĩ mũmocu na ngathuthĩka biũ;
\q2 ndĩracaaya nĩ ruo rwa ngoro.
\b
\q1 
\v 9 Wee Mwathani, wendi wakwa wothe ũrĩ o mbere yaku;
\q2 gũcaaya gwakwa ti kũhitharu harĩwe.
\q1 
\v 10 Ngoro yakwa nĩĩratuuma mũno,
\q2 naguo hinya wakwa nĩgũthira ũrathira;
\q2 o na ũtheri nĩumĩte maitho-inĩ makwa.
\q1 
\v 11 Arata na athiritũ akwa matiendaga kũnguhĩrĩria
\q2 nĩ ũndũ wa ironda ciakwa;
\q2 o na andũ a itũũra rĩakwa manjikaraga haraihu.
\q1 
\v 12 Andũ arĩa mendaga kũnjũraga nĩ mĩtego mandegagĩra,
\q2 arĩa mendaga kũnjĩka ũũru maaragia ũrĩa mangĩnyũnũha;
\q2 mũthenya wothe mathugundaga o maheeni.
\b
\q1 
\v 13 Niĩ haana ta mũndũ gĩtaigua, ũrĩa ũtaiguaga,
\q2 ngahaana ta mũndũ ũtaaragia, ũrĩa ũtangĩtumũra kanua gake;
\q1 
\v 14 nduĩkĩte ta mũndũ ũtaiguaga,
\q2 ũrĩa kanua gake gatarĩ ũndũ kangĩhota gũcookia.
\q1 
\v 15 Wee Jehova, Wee nĩwe njetagĩrĩra;
\q2 Wee Mwathani Ngai wakwa, Wee nĩwe ũkũnjookeria ũhoro.
\q1 
\v 16 Nĩgũkorwo ndoigire atĩrĩ, “Ndũkanareke thũ ciakwa ingenerere,
\q2 o na kana ciĩtũũgĩrie igũrũ rĩakwa rĩrĩa kũgũrũ gwakwa gwatenderũka.”
\b
\q1 
\v 17 Nĩgũkorwo ngirie kũgũa,
\q2 na njikaraga ndĩ na ruo hĩndĩ ciothe.
\q1 
\v 18 Nĩngumbũra waganu wakwa;
\q2 nĩthĩĩnĩtio nĩ mehia makwa.
\q1 
\v 19 Thũ ciakwa iria irĩ kĩyo nĩcio nyingĩ;
\q2 arĩa maathũire hatarĩ gĩtũmi nĩ aingĩ.
\q1 
\v 20 Andũ arĩa mandĩhaga wega wakwa na ũũru
\q2 manjambagia rĩrĩa niĩ ngũthingata ũndũ ũrĩa mwega.
\b
\q1 
\v 21 Wee Jehova, ndũkandiganĩrie;
\q2 Wee Ngai wakwa, ndũgaikare haraihu na niĩ.
\q1 
\v 22 Ũka narua ũndeithie,
\q2 Wee Mwathani, Mũhonokia wakwa.
\c 39
\s1 Kuumbũra Mehia kwa Mũndũ Mũthĩĩnĩku
\d Thaburi ya Daudi
\q1 
\v 1 Ndoigire atĩrĩ, “Ndĩĩmenyagĩrĩra mĩthiĩre yakwa,
\q2 ndĩrigagĩrĩrie ndikehie na rũrĩmĩ rwakwa;
\q1 nĩnguoha kanua gakwa
\q2 rĩrĩa rĩothe mũndũ mwaganu arĩ harĩa ndĩ.”
\q1 
\v 2 No rĩrĩa ndakirĩte na ngahoorera,
\q2 itekwaria o na ũndũ mwega-rĩ,
\q2 ruo rwakwa rũgĩkĩrĩrĩria kuongerereka.
\q1 
\v 3 Ngoro yakwa yahĩĩahĩaga thĩinĩ wakwa,
\q2 na o rĩrĩa ndecũũranagia, mwaki ũgĩakana;
\q2 hĩndĩ ĩyo ngĩaria na rũrĩmĩ rwakwa, ngiuga atĩrĩ:
\b
\q1 
\v 4 “Wee Jehova, nyonia mũthia wa mũtũũrĩre wakwa,
\q2 o na mũigana wa matukũ makwa;
\q2 nĩngĩmenye ũrĩa mũtũũrĩre wakwa ũrĩ wa gũthira na ihenya.
\q1 
\v 5 Ũtũmĩte matukũ makwa makuhĩhe ta rũhĩ;
\q2 mũigana wa mĩaka yakwa ti ta kĩndũ harĩwe.
\q2 Mũndũ o wothe ũrĩ muoyo o na rĩrĩa ehaandĩte wega nĩ kĩndũ gĩa tũhũ.
\q1 
\v 6 Ti-itherũ mũndũ nĩ ta kĩĩruru rĩrĩa egũcangacanga:
\q2 Mĩhangʼo ĩrĩa ehangʼagia nayo no ya tũhũ;
\q2 eigagĩra ũtonga, no ndooĩ nũũ ũkeeguna naguo.
\b
\q1 
\v 7 “No rĩu, Mwathani-rĩ, nĩ kĩĩ njetereire?
\q2 Wee nĩwe mwĩhoko wakwa.
\q1 
\v 8 Honokia kuuma mehia-inĩ makwa mothe;
\q2 ndũkareke thekererwo nĩ andũ arĩa akĩĩgu.
\q1 
\v 9 Ndakirĩte ki; ndingĩatumũrire kanua gakwa,
\q2 nĩgũkorwo nĩwe wekĩte ũguo.
\q1 
\v 10 Njehereria ihũũra rĩaku;
\q2 nĩhootetwo nĩ iringa rĩa guoko gwaku.
\q1 
\v 11 We ũrũithagia na ũkaherithia andũ nĩ ũndũ wa mehia mao;
\q2 ũniinaga ũtonga wao ta memenyi;
\q2 mũndũ no ta kĩndũ gĩa tũhũ.
\b
\q1 
\v 12 “Igua ihooya rĩakwa, Wee Jehova,
\q2 thikĩrĩria ngĩgũkaĩra ũndeithie;
\q2 ndũkarege kũigua kĩrĩro gĩakwa.
\q1 Nĩgũkorwo njikaranagia nawe ta ndĩ mũgeni,
\q2 ngahaana ta mũndũ ũthaamĩire kuo,
\q2 o ta ũrĩa maithe makwa mothe maatariĩ.
\q1 
\v 13 Wĩhũgũre na kũngĩ ũtige kũnyona, nĩguo ngĩkene rĩngĩ,
\q2 itanathiĩ njage gũkorwo ho rĩngĩ.”
\c 40
\s1 Rwĩmbo rwa Gũcookia Ngaatho
\d Thaburi ya Daudi
\q1 
\v 1 Ndetereire Jehova o ngirĩrĩirie;
\q2 nake agĩĩthikĩrĩria akĩigua kĩrĩro gĩakwa.
\q1 
\v 2 Nĩ aandutire irima rĩa mũũro,
\q2 thĩinĩ wa ndoro yarĩ ndenderũ,
\q1 agĩkinyithia magũrũ makwa igũrũ rĩa rwaro rwa ihiga,
\q2 na agĩtũma ndĩhaande wega.
\q1 
\v 3 Eekĩrire rwĩmbo rwerũ kanua-inĩ gakwa,
\q2 rwĩmbo rwa kũgoocaga Ngai witũ naruo.
\q1 Andũ aingĩ marĩonaga ũguo magetigĩra,
\q2 nao makehoka Jehova.
\b
\q1 
\v 4 Kũrathimwo nĩ mũndũ
\q2 ũrĩa ũtuĩte atĩ arĩĩhokaga o Jehova,
\q1 na nderĩgagĩrĩra andũ arĩa etĩĩi,
\q2 o acio marũmagĩrĩra ngai cia maheeni.
\q1 
\v 5 Wee Jehova Ngai wakwa-rĩ,
\q2 magegania marĩa wĩkĩte nĩ maingĩ.
\q1 Maũndũ marĩa ũtũbangĩire
\q2 gũtirĩ mũndũ ũngĩhota gũgũtaarĩria;
\q1 korwo ndaaria heane ũhoro wamo-rĩ,
\q2 mangĩkorwo marĩ maingĩ mũno kũmoiga.
\b
\q1 
\v 6 Wee-rĩ, ti magongona na maruta weriragĩria,
\q2 no nĩũũheete matũ ma gũkũigua;
\q2 maruta ma njino na maruta ma kũhoroheria mehia
\q2 ti mo maakũbatairie.
\q1 
\v 7 Ningĩ ngiuga atĩrĩ, “Niĩ ũyũ haha, nĩndooka,
\q2 o ta ũrĩa kwandĩkĩtwo ũhoro wakwa ibuku-inĩ rĩa gĩkũnjo.
\q1 
\v 8 Niĩ ndĩriragĩria gwĩka wendi waku, Wee Ngai wakwa;
\q2 watho waku ũrĩ ngoro-inĩ yakwa.”
\b
\q1 
\v 9 Nyanagĩrĩra ũhoro wa ũthingu ndĩ kĩũngano-inĩ kĩnene;
\q2 o ta ũrĩa ũũĩ, Wee Jehova,
\q2 niĩ ndihingaga mĩromo yakwa.
\q1 
\v 10 Niĩ ndihithagĩrĩra ũthingu waku ngoro-inĩ yakwa;
\q2 njaragia ũhoro wa wĩhokeku na ũhonokio waku.
\q1 Wendo waku na ũhoro waku wa ma
\q2 ndirĩ ndacihitha kĩũngano kĩrĩa kĩnene.
\b
\q1 
\v 11 Wee Jehova-rĩ, ndũkagirĩrĩrie tha ciaku inginyĩrĩre;
\q2 wendo waku na ũhoro waku wa ma irongitagĩra hĩndĩ ciothe.
\q1 
\v 12 Nĩgũkorwo mathĩĩna matangĩtarĩka nĩmandigiicĩirie;
\q2 mehia makwa nĩmanginyĩrĩire, ngaremwo nĩkuona.
\q1 Maingĩhĩte gũkĩra njuĩrĩ cia mũtwe wakwa,
\q2 na ngoro yakwa nĩyũrĩtwo nĩ hinya.
\b
\q1 
\v 13 Wee Jehova-rĩ, ĩtĩkĩra kũũhonokia,
\q2 Wee Jehova-rĩ, ũka narua ũndeithie.
\q1 
\v 14 Andũ arĩa othe mendaga kũnjũraga
\q2 maroconorithio na manyiitwo nĩ kĩrigiicano;
\q1 arĩa othe mendaga nyanangwo
\q2 marocooka na thuutha maconokete.
\q1 
\v 15 Andũ arĩa maathekagĩrĩra makiugaga atĩrĩ, “Haiya! Haiya!”
\q2 Maroiyũrwo nĩ ihooru nĩ ũndũ wa thoni ciao.
\q1 
\v 16 No arĩa makũrongoragia
\q2 marokena na macanjamũke nĩ ũndũ waku;
\q1 arĩa mendete ũhonokio waku marotũũra moigaga atĩrĩ,
\q2 “Jehova arotũgĩrio!”
\b
\q1 
\v 17 No rĩrĩ, niĩ ndĩ mũthĩĩni na mũbatari;
\q2 Mwathani arondirikana.
\q1 Wee nĩwe ũteithio wakwa na mũndeithũri;
\q2 Wee Ngai wakwa-rĩ, hiuha ũkĩndeithie.
\c 41
\s1 Ihooya rĩa Mũndũ Mũrũaru
\d Thaburi ya Daudi
\q1 
\v 1 Kũrathimwo-rĩ, nĩ mũndũ ũrĩa ũrũmbũyagia andũ arĩa matarĩ hinya;
\q2 ũcio-rĩ, Jehova nĩamũhatũraga hĩndĩ ya mathĩĩna.
\q1 
\v 2 Jehova nĩarĩmũgitagĩra na amũtũũragie muoyo;
\q2 nĩarĩmũrathimaga bũrũri-inĩ,
\q2 na ndakamũrekereria kũrĩ merirĩria ma thũ ciake.
\q1 
\v 3 Jehova nĩarĩmũmenyagĩrĩra arĩ ũrĩrĩ-inĩ arĩ mũrũaru,
\q2 na acooke amũhonie arĩ o hau ũrĩrĩ-inĩ wake.
\b
\q1 
\v 4 Ndoigire atĩrĩ, “Wee Jehova, njiguĩra tha;
\q2 honia, nĩgũkorwo Wee nĩwe njĩhĩirie.”
\q1 
\v 5 Thũ ciakwa ciaragia ũhoro wakwa na rũmena ikooria atĩrĩ,
\q2 “Agakua rĩ, rĩĩtwa rĩake rĩthire?”
\q1 
\v 6 Rĩrĩa rĩothe mũndũ ooka kũnyona,
\q2 aaheaga ũhoro wa maheeni, o rĩrĩa ngoro yake ĩrahũnga ndeto cia kũnjambia;
\q2 agacooka agathiĩ gũcimemeerekia kũndũ guothe.
\b
\q1 
\v 7 Thũ ciakwa ciothe iheehanagĩra nĩguo iinjũkĩrĩre;
\q2 injiiragĩrĩra maũndũ mooru mũno, ikoiga atĩrĩ,
\q1 
\v 8 “Mũrimũ mũũru nĩũmũnyiitĩte;
\q2 ndarĩ hĩndĩ agokĩra hau akomete.”
\q1 
\v 9 O na mũrata wakwa wa hakuhĩ, ũrĩa ndĩrehokete,
\q2 o ũrĩa tũrĩĩanagĩra irio nake nĩangarũrũkĩte.
\b
\q1 
\v 10 No rĩrĩ, Wee Jehova, njiguĩra tha;
\q2 njarahũra, nĩguo ndĩĩrĩhĩrie harĩo.
\q1 
\v 11 Nĩnjũũĩ atĩ nĩũkenetio nĩ niĩ,
\q2 nĩgũkorwo thũ yakwa ndĩndooretie.
\q1 
\v 12 We nĩũũnyiitĩrĩire nĩ ũndũ wa wagĩrĩru wakwa,
\q2 na ũkanjiga harĩwe nginya tene.
\b
\q1 
\v 13 Jehova, o we Ngai wa Isiraeli, arogoocwo,
\q2 kuuma tene wa tene nginya tene na tene.
\q2 Ameni, na ningĩ Ameni.
\c 42
\ms1 Ibuku rĩa Keerĩ
\mr Thaburi 42–72
\d Kwĩhoka Ũhonokio wa Mwathani. Thaburi ya Ariũ a Kora
\q1 
\v 1 O ta ũrĩa thwariga ĩnyootagĩra tũrũũĩ twa maaĩ,
\q2 no taguo ngoro yakwa ĩkũnyootagĩra, Wee Ngai.
\q1 
\v 2 Ngoro yakwa nĩ Ngai ĩnyootagĩra, O we Mũrungu ũrĩa ũrĩ muoyo.
\q2 Ĩ nĩ rĩ ngaathiĩ ngacemanie na Ngai?
\q1 
\v 3 Maithori makwa matuĩkĩte nĩmo irio ciakwa
\q2 mũthenya o na ũtukũ,
\q1 nao andũ manjũũragia mũthenya wothe atĩrĩ,
\q2 “Ngai waku akĩrĩ ha?”
\q1 
\v 4 Maũndũ maya ndĩmaririkanaga
\q2 o ngĩitũrũraga ngoro yakwa:
\q1 ngaririkana ũrĩa ndatwaranaga na kĩrĩndĩ,
\q2 ndongoretie mũtongoro nginya nyũmba-inĩ ya Ngai,
\q1 tũkĩanagĩrĩra na gĩkeno na tũgĩcookagia ngaatho,
\q2 ndĩ kĩrĩndĩ-inĩ hĩndĩ ya ciathĩ.
\b
\q1 
\v 5 Wee ngoro yakwa, ũkĩritũhĩirwo nĩkĩ?
\q2 Ũrathĩĩnĩka ũguo nĩkĩ ũrĩ thĩinĩ wakwa?
\q1 Wĩrĩgagĩrĩre Ngai, nĩgũkorwo no ndĩrĩmũgoocaga,
\q2 o we Mũhonokia wakwa, na Ngai wakwa.
\b
\q1 
\v 6 Ngoro yakwa nĩnditũhĩre ĩrĩ thĩinĩ wakwa;
\q2 nĩ ũndũ ũcio nĩngũkũririkana
\q1 ndĩ bũrũri wa Jorodani,
\q2 o kũu irĩma-inĩ cia Herimoni,\f + \fr 42:6 \ft Herimoni kwarĩ mũhaka-inĩ wa mwena wa gathigathini wa bũrũri wa Isiraeli.\f* kuuma Kĩrĩma-inĩ kĩa Mizari.
\q1 
\v 7 Ndia ĩmwe nĩĩreta ndia ĩrĩa ĩngĩ
\q2 na mũgambo wa mũrurumo wa ndururumo ciaku cia maaĩ;
\q1 makũmbĩ maku mothe o na ndiihũ nĩciũkĩte, ikaahubanĩria.
\b
\q1 
\v 8 Mũthenya-rĩ, Jehova nĩarĩathagĩrĩra wendo wake harĩ niĩ,
\q2 na ũtukũ nĩ rwĩmbo ndĩrĩmũinagĩra,
\q2 rũrĩ ihooya rĩa kũhooya Mũrungu wa muoyo wakwa.
\b
\q1 
\v 9 Njũũragia Mũrungu, o we rwaro rwakwa rwa Ihiga, atĩrĩ,
\q2 “Ũriganĩirwo nĩ niĩ nĩkĩ?
\q1 Ingĩthiĩ ngĩcakayaga nĩkĩ,
\q2 nĩ ũndũ wa kũhinyĩrĩirio nĩ thũ?”
\q1 
\v 10 Nĩ ta ngũhehenjwo mahĩndĩ makwa,
\q2 rĩrĩa amuku akwa mekũnyũrũria,
\q1 magatinda mũthenya wothe makĩnjũũria atĩrĩ,
\q2 “Ngai waku akĩrĩ ha?”
\b
\q1 
\v 11 Wee ngoro yakwa, ũkĩritũhĩirwo nĩkĩ?
\q2 Ũrathĩĩnĩka ũguo nĩkĩ ũrĩ thĩinĩ wakwa?
\q1 Wĩrĩgagĩrĩre Ngai,
\q2 nĩgũkorwo no ndĩrĩmũgoocaga,
\q1 o we Mũhonokia wakwa na Ngai wakwa.
\c 43
\s1 Kwĩhoka Ũhonokio wa Mwathani
\q1 
\v 1 Nduĩra ciira wakwa, Wee Ngai,
\q2 na ũnjiirĩrĩre harĩ rũrĩrĩ rũrũ rũtagwĩtĩkĩtie;
\q2 ndeithũra kuuma kũrĩ andũ aya aaganu na maaragia maheeni.
\q1 
\v 2 Wee Ngai nĩwe kĩirigo gĩakwa kĩa hinya.
\q2 Ũndiganĩirie nĩkĩ?
\q1 Ingĩthiĩ ngĩcakayaga nĩkĩ
\q2 nĩ ũndũ wa kũhinyĩrĩirio nĩ thũ?
\q1 
\v 3 Tũma ũtheri waku na ũhoro waku wa ma,
\q2 ũreke indongorie arĩ cio;
\q1 reke inginyie kĩrĩma-inĩ gĩaku kĩrĩa kĩamũre,
\q2 o kũu gĩikaro-inĩ gĩaku.
\q1 
\v 4 Hĩndĩ ĩyo nĩngathiĩ kĩgongona-inĩ kĩa Ngai,
\q2 nginye harĩ Mũrungu, o we gĩkeno gĩakwa, na o we ngenagĩra.
\q1 Nĩndĩrĩkũgoocaga ngĩhũũraga kĩnanda kĩa mũgeeto,
\q2 Wee Ngai, o Wee Ngai wakwa.
\b
\q1 
\v 5 Wee ngoro yakwa, ũkĩritũhĩirwo nĩkĩ?
\q2 Ũrathĩĩnĩka ũguo nĩkĩ ũrĩ thĩinĩ wakwa?
\q1 Wĩrĩgagĩrĩre o Ngai,
\q2 nĩgũkorwo no ndĩrĩmũgoocaga,
\q2 o we Mũhonokia wakwa na Ngai wakwa.
\c 44
\q1 
\v 1 Twanaigua na matũ maitũ Wee Ngai,
\q2 tũkĩĩrwo nĩ maithe maitũ
\q1 ũrĩa wekire matukũ-inĩ mao,
\q2 o matukũ macio ma tene.
\q1 
\v 2 Nĩwaingatire ndũrĩrĩ na guoko gwaku,
\q2 na ũgĩcooka kũhaanda maithe maitũ kuo;
\q1 Wee nĩwanyariirire irĩndĩ iria ingĩ,
\q2 na ũgĩtũma maithe maitũ magaacĩre.
\q1 
\v 3 Matiegwatĩire bũrũri ũcio na hinya wa rũhiũ rwao,
\q2 o na ti icoka ciao ciamaheire ũhootani;
\q1 no nĩ guoko gwaku kwa ũrĩo, ĩĩ nĩ gĩcoka gĩaku,
\q2 na ũtheri wa gĩthiithi gĩaku, nĩgũkorwo nĩwamendete.
\b
\q1 
\v 4 Wee nĩwe Mũthamaki wakwa na Ngai wakwa,
\q2 ũrĩa wathagĩrĩra Jakubu ũhootani.
\q1 
\v 5 Wee nĩwe ũtũhotithagia kũhoota thũ ciitũ;
\q2 nĩ ũndũ wa rĩĩtwa rĩaku tũrangagĩrĩria arĩa marĩ muku na ithuĩ.
\q1 
\v 6 Ndiĩhokaga ũta wakwa,
\q2 rũhiũ rwakwa rwa njora ti ruo rũngĩĩhootanĩra;
\q1 
\v 7 no Wee nĩwe ũtũtooranagĩria harĩ thũ ciitũ,
\q2 ũgagĩconorithia acio matũthũire.
\q1 
\v 8 Ngai nĩwe tũtindaga tũkĩĩrahĩra mũthenya wothe,
\q2 na tũgũtũũra tũgoocaga rĩĩtwa rĩaku nginya tene.
\b
\q1 
\v 9 No rĩu nĩũtũtiganĩirie na ũgatũconorithia;
\q2 nĩũtigĩte gũtwaranaga na mbũtũ ciitũ cia ita.
\q1 
\v 10 Nĩwatũmire tũũrĩre thũ ciitũ,
\q2 o icio itũthũire igetahĩra indo ciitũ.
\q1 
\v 11 Ũtũrekereirie tũtambuurwo ta ngʼondu,
\q2 na ũgatũhurunja harĩ ndũrĩrĩ.
\q1 
\v 12 Wendetie andũ aku ta kĩndũ tũhũ,
\q2 ndũrĩ uumithio wonete nĩ ũguo ũmendetie.
\b
\q1 
\v 13 Nĩũtũmĩte tũmenwo nĩ andũ arĩa tũhakanĩte nao,
\q2 tũgatuĩka a kũnyararwo na gũthekererwo nĩ arĩa matũthiũrũrũkĩirie.
\q1 
\v 14 Nĩũtũmĩte tũtuĩke a kuunagwo thimo nĩ ndũrĩrĩ;
\q2 tũgagĩtuĩka a kũinainagĩrio mĩtwe nĩ andũ.
\q1 
\v 15 Ndindaga njonokete mũthenya wothe,
\q2 ngahumbwo nĩ thoni ũthiũ wothe,
\q1 
\v 16 nĩ ũndũ wa inyũrũri cia andũ arĩa maanyũrũragia na makaanuma,
\q2 tondũ wa thũ ĩrĩa ĩrenda kwĩrĩhĩria.
\b
\q1 
\v 17 Twakorirwo nĩ maũndũ macio mothe,
\q2 o na gũtuĩka tũtiariganĩirwo nĩwe,
\q2 o na kana tũgĩthaahia kĩrĩkanĩro gĩaku.
\q1 
\v 18 Ngoro ciitũ iticookete na thuutha;
\q2 makinya maitũ matiumĩte njĩra-inĩ yaku.
\q1 
\v 19 No ũtũhehenjete, na ũgatũtua imamo cia mbwe,
\q2 na ũgatũhumbĩra na nduma nene.
\b
\q1 
\v 20 Tũngĩkorwo nĩtwariganĩirwo nĩ rĩĩtwa rĩa Ngai witũ,
\q2 o na kana tũkĩambararia moko kũrĩ ngai ngʼeni-rĩ,
\q1 
\v 21 githĩ Ngai ndangĩamenyire ũhoro ũcio,
\q2 kuona atĩ nĩamenyaga hitho cia ngoro?
\q1 
\v 22 No nĩ ũndũ waku tũtindaga tũngʼetheire gĩkuũ mũthenya wothe;
\q2 tũtuĩtwo ta ngʼondu cia gũthĩnjwo.
\b
\q1 
\v 23 Wee Mwathani, arahũka! Ũgĩkomete nĩkĩ?
\q2 Wĩyarahũre! Ndũgatũtiganĩrie nginya tene.
\q1 
\v 24 Ũhithĩte ũthiũ waku nĩkĩ,
\q2 na ũkariganĩrwo nĩ mathĩĩna maitũ na kũhinyĩrĩrio gwitũ?
\b
\q1 
\v 25 Tũrũndĩtwo rũkũngũ-inĩ;
\q2 mĩĩrĩ iitũ ĩkĩnyiitanĩte na thĩ.
\q1 
\v 26 Arahũka ũtũteithie;
\q2 tũkũũre tondũ wa wendani waku ũtathiraga.
\c 45
\s1 Rwĩmbo rwa Kũinĩra Mũthamaki Akĩhikania
\d Thaburi ya Ariũ a Kora
\q1 
\v 1 Ngoro yakwa ĩiyũrĩtwo nĩ ũhoro mwega
\q2 rĩrĩa ngũinĩra mũthamaki rwĩmbo rũrũ;
\q2 rũrĩmĩ rwakwa no ta karamu ka mwandĩki ũrĩa mũũgĩ.
\b
\q1 
\v 2 Wee ũrĩ mũthaka mũno gũkĩra andũ othe,
\q2 nacio iromo ciaku nĩciitĩrĩirio maũndũ ma ũtugi,
\q2 kuona atĩ Ngai nĩakũrathimĩte nginya tene.
\q1 
\v 3 Wĩohe rũhiũ rwaku rwa njora njohero,
\q2 Wee njamba ĩno ĩrĩ hinya;
\q2 wĩhumbe ũkaru waku o na ũnene.
\q1 
\v 4 Ũrĩ thĩinĩ wa ũnene waku thiĩ ũhaicĩte mbarathi,
\q2 ũkĩhootanaga nĩ ũndũ wa ũhoro wa ma, na wa kwĩnyiihia, o na wa ũthingu;
\q2 reke guoko gwaku kwa ũrĩo kuonanie ciĩko cia kũmakania.
\q1 
\v 5 Mĩguĩ yaku ĩrĩa mĩũgĩ nĩĩtheece thũ cia mũthamaki o ngoro-inĩ;
\q2 ndũrĩrĩ nĩigwe magũrũ-inĩ maku.
\q1 
\v 6 Wee Ngai, gĩtĩ gĩaku kĩa ũnene gĩgũtũũra tene na tene;
\q2 mũthĩgi waku wa kĩhooto nĩguo ũgaatuĩka mũthĩgi wa ũthamaki waku.
\q1 
\v 7 Wee wendete ũthingu no ũgathũũra waganu;
\q2 nĩ ũndũ ũcio Ngai, o we Ngai waku,
\q2 nĩakwambararĩtie gũkĩra athiritũ aku othe
\q2 na ũndũ wa gũgũitĩrĩria maguta ma gĩkeno.
\q1 
\v 8 Nguo ciaku ciothe inungĩte o manemane, na thubiri, na mũndarathini;\f + \fr 45:8 \ft Nguo nĩciaitagĩrĩrio maguta manungi wega.\f*
\q2 nĩũrakenio nĩ aini a nyĩmbo na inanda cia nga
\q2 marĩ ciikaro-inĩ cia mũthamaki iria igemetio na mĩguongo.
\q1 
\v 9 Thĩinĩ wa andũ-a-nja aku arĩa atĩĩku harĩ na aarĩ a athamaki;
\q2 mũhiki ũcio wa mũthamaki aikarĩte mwena waku wa ũrĩo
\q2 egemetie na thahabu ya Ofiri.
\b
\q1 
\v 10 Ta thikĩrĩria, wee mwarĩ ũyũ, wĩcũũranie na ũigue:
\q2 Riganĩrwo nĩ andũ anyu o na nyũmba ya thoguo.
\q1 
\v 11 Mũthamaki nĩakenetio mũno nĩ ũthaka waku;
\q2 mũtĩĩe, nĩgũkorwo nĩwe mwathi waku.
\q1 
\v 12 Mwarĩ wa Turo nĩagakũrehera kĩheo,
\q2 o nao andũ arĩa atongu mũno magatuĩka a kwĩyendithia harĩwe.
\b
\q1 
\v 13 Mwarĩ wa mũthamaki no riiri mũtheri arĩ naguo arĩ thĩinĩ wa nyũmba yake,
\q2 nguo yake ĩtumĩtwo na ndigi cia thahabu.
\q1 
\v 14 Aratwarwo harĩ mũthamaki ehumbĩte nguo ngʼemie;
\q2 oimĩtwo thuutha nĩ airĩtu gathirange a thiritũ yake,
\q2 na othe marooka kũrĩ we.
\q1 
\v 15 Mararehwo na gĩkeno na ndũhiũ;
\q2 nĩmatoonye nyũmba ya mũthamaki.
\b
\q1 
\v 16 Ciana cianyu nĩcio igaacooka ithenya rĩa maithe manyu;
\q2 ũkaamatua anene bũrũri-inĩ guothe.
\q1 
\v 17 Nĩngũtũma ũtũũre ũririkanagwo nĩ njiarwa na njiarwa;
\q2 nĩ ũndũ ũcio ndũrĩrĩ igaatũũra igũkumagia tene na tene.
\c 46
\s1 Ngai arĩ Hamwe na Ithuĩ
\d Thaburi ya Ariũ a Kora
\q1 
\v 1 Ngai nĩwe rĩũrĩro riitũ o na hinya witũ,
\q2 o we ũteithio witũ hĩndĩ ya mathĩĩna.
\q1 
\v 2 Tondũ ũcio tũtingĩĩtigĩra, o na thĩ ĩngĩthingitha,
\q2 na irĩma igwe iria-inĩ,
\q1 
\v 3 o na maaĩ marĩo mangĩruruma na mahũyũke,
\q2 nginya irĩma igathingithio nĩ nditi yamo.
\b
\q1 
\v 4 Nĩ kũrĩ rũũĩ rũrĩa tũrũũĩ twaruo tũkenagia itũũra rĩa Ngai,
\q2 gĩikaro kĩu kĩamũre kĩa Ũrĩa-ũrĩ-Igũrũ-Mũno.
\q1 
\v 5 Ngai arĩ kũu thĩinĩ wa itũũra rĩu, na rĩtikenyenyeka;
\q2 Ngai nĩwe ũkaarĩteithia kĩrooko gũgĩkĩa.
\q1 
\v 6 Ndũrĩrĩ nĩiraronja, namo mothamaki makenyenya;
\q2 nake agũũthũka-rĩ, thĩ ĩgatweka.
\b
\q1 
\v 7 Jehova Mwene-Hinya-Wothe arĩ hamwe na ithuĩ;
\q2 Ngai wa Jakubu nĩwe kĩirigo giitũ kĩa hinya.
\b
\q1 
\v 8 Ũkai muone ciĩko iria Jehova ekĩte,
\q2 ũkai muone ũrĩa akirĩtie thĩ ihooru.
\q1 
\v 9 Aniinaga mbaara nginya ituri cia thĩ;
\q2 oinaga ũta na agathethera itimũ,
\q2 na agacina ngo na mwaki.
\q1 
\v 10 “Hoorerai, na mũmenye atĩ niĩ nĩ niĩ Ngai;
\q2 nĩngatũũgĩrio ndũrĩrĩ-inĩ,
\q2 na ndũũgĩrio thĩ yothe.”
\b
\q1 
\v 11 Jehova Mwene-Hinya-Wothe arĩ hamwe na ithuĩ;
\q2 Ngai wa Jakubu nĩwe kĩirigo giitũ kĩa hinya.
\c 47
\s1 Jehova nĩwe Mũthamaki wa Thĩ Yothe
\d Thaburi ya Ariũ a Kora
\q1 
\v 1 Inyuĩ andũ a ndũrĩrĩ ciothe, hũũrai hĩ;
\q2 ugĩrĩriai nĩ ũndũ wa Ngai, na mwanĩrĩre mũrĩ na gĩkeno.
\q1 
\v 2 Jehova Ũrĩa-Ũrĩ-Igũrũ-Mũno kaĩ nĩ wa gwĩtigĩrwo-ĩ,
\q2 O we Mũthamaki mũnene ũrĩa wathaga thĩ yothe!
\q1 
\v 3 Atooragia ndũrĩrĩ igaikara rungu rwitũ,
\q2 irĩndĩ igaikara rungu rwa makinya maitũ.
\q1 
\v 4 Nĩwe watũthuurĩire igai riitũ,
\q2 ithuĩ gĩkeno kĩa Jakubu, o ũcio eendete.
\b
\q1 
\v 5 Ngai nĩambatĩte, o agĩkũngũyagĩrwo na gĩkeno,
\q2 Jehova akaambata akĩhuhagĩrwo tũrumbeta.
\q1 
\v 6 Inĩrai Ngai mũmũgooce na nyĩmbo, mũinĩrei mũmũgooce;
\q2 inĩrai Mũthamaki witũ mũmũgooce, mũinĩrei mũmũgooce.\f + \fr 47:6 \ft Andũ nĩmainagĩra Ngai kĩambĩrĩria kĩa o mwaka na rũhĩa rwarĩ kayũ kanene rwetagwo shofari.\f*
\b
\q1 
\v 7 Nĩgũkorwo Ngai nĩwe Mũthamaki wa thĩ yothe;
\q2 mũgoocei na nyĩmbo.
\q1 
\v 8 Ngai nĩwe ũthamakagĩra ndũrĩrĩ;
\q2 Ngai aikarĩire gĩtĩ gĩake kĩrĩa gĩtheru kĩa ũnene.
\q1 
\v 9 Andũ a ndũrĩrĩ arĩa marĩ igweta nĩmonganĩte
\q2 matuĩke ta andũ a Ngai wa Iburahĩmu,
\q1 nĩgũkorwo athamaki a thĩ nĩ a Ngai;
\q2 we nĩwe ũtũũgĩrĩtio mũno.
\c 48
\s1 Zayuni Itũũra rĩa Jehova
\d Thaburi ya Ariũ a Kora
\q1 
\v 1 Jehova nĩ mũnene, na nĩ wa kũgoocwo mũno,
\q2 arĩ kũu thĩinĩ wa itũũra inene rĩa Ngai witũ,
\q2 o kĩrĩma-inĩ gĩake kĩrĩa kĩamũre.
\q1 
\v 2 Kĩrĩma kĩu kĩa Ngai nĩ gĩthaka na gĩkaraiha na igũrũ,
\q2 na nĩkĩo gĩkeno gĩa thĩ yothe.
\q1 O ta ũrĩa Zafoni gũtũgĩrĩte na igũrũ mũno,
\q2 no taguo Kĩrĩma gĩa Zayuni kĩhaana,
\q2 itũũra rĩu inene rĩa Mũthamaki ũrĩa Mũnene.
\q1 
\v 3 Ngai arĩ thĩinĩ wa ciikaro iria ngitĩre cia mũthamaki;
\q2 nake nĩeyonanĩtie atĩ nĩwe kĩirigo gĩacio kĩa hinya.
\b
\q1 
\v 4 Rĩrĩa athamaki maanyiitanire hamwe
\q2 na magĩthiĩ magatharĩkĩre itũũra rĩu,
\q1 
\v 5 maarĩonire, magĩtuĩka nda;
\q2 makĩũra nĩ kĩmako kĩnene.
\q1 
\v 6 O hau-hau makĩnyiitwo nĩ kũinaina,
\q2 makĩgĩa na ruo ta rwa mũndũ-wa-nja akĩrũmwo.
\q1 
\v 7 Wamanangire o ta ũrĩa marikabu cia Tarishishi cianangagwo
\q2 nĩ rũhuho ruumĩte mwena wa irathĩro.
\b
\q1 
\v 8 O ta ũrĩa tũiguĩte,
\q2 ũguo noguo tuonete
\q1 thĩinĩ wa itũũra inene rĩa Jehova Mwene-Hinya-Wothe,
\q2 itũũra rĩu inene rĩa Ngai witũ:
\q2 Ngai egũtũũra arĩgitagĩra nginya tene.
\b
\q1 
\v 9 Tũrĩ thĩinĩ wa hekarũ yaku, Wee Ngai,
\q2 twĩcũũranagia ũhoro wa wendo waku ũrĩa ũtathiraga.
\q1 
\v 10 O ta ũrĩa rĩĩtwa rĩaku rĩtariĩ, Wee Ngai,
\q2 ũguo noguo ngumo yaku ĩigana o nginya ituri-inĩ cia thĩ;
\q2 guoko gwaku kwa ũrĩo kũiyũrĩtwo nĩ ũthingu.
\q1 
\v 11 Kĩrĩma gĩa Zayuni nĩgĩkenaga,
\q2 namo matũũra ma Juda magacanjamũka
\q2 nĩ ũndũ wa matuĩro maku ma ciira.
\b
\q1 
\v 12 Ceeraceerai Zayuni, mũrĩthiũrũrũke,
\q2 mũtare mĩthiringo yarĩo ĩrĩa mĩraihu na igũrũ,
\q1 
\v 13 mũrore ũrĩa kũirigĩtwo na hinya,
\q2 na mũrore ciikaro iria ngitĩre cia mũthamaki,
\q2 nĩgeetha mũkeeraga rũciaro rũrĩa rũgooka ũhoro wacio.
\q1 
\v 14 Nĩgũkorwo Ngai ũyũ nĩwe Ngai witũ nginya tene na tene;
\q2 egũtũũra atũtongoragia nginya hĩndĩ ĩtagathira.
\c 49
\s1 Ũrimũ wa Kwĩhoka Ũtonga
\d Thaburi ya Ariũ a Kora
\q1 
\v 1 Iguai ũhoro ũyũ, inyuĩ ndũrĩrĩ ciothe;
\q2 thikĩrĩriai, inyuothe mũtũũraga gũkũ thĩ,
\q1 
\v 2 inyuĩ mũtarĩ igweta na arĩa mũrĩ igweta,
\q2 inyuĩ itonga na athĩĩni mũigue hamwe:
\q1 
\v 3 Kanua gakwa nĩgekwaria ciugo cia ũũgĩ,
\q2 mĩario ya ngoro yakwa ĩkorwo na ũtaũku.
\q1 
\v 4 Nĩngũtega gũtũ ndĩĩiguĩre thimo;
\q2 njooke ndaũre ndaĩ ĩno ngĩhũũraga kĩnanda kĩa mũgeeto:
\b
\q1 
\v 5 Nĩ kĩĩ kĩngĩtũma ndĩtigĩre hĩndĩ ya mathĩĩna,
\q2 rĩrĩa andũ aaganu acio maheenanagia maathiũrũrũkĩirie,
\q1 
\v 6 o acio mehokaga ũtonga wao,
\q2 na makeeraha nĩ ũingĩ wa indo ciao?
\q1 
\v 7 Gũtirĩ mũndũ ũngĩhota gũkũũra muoyo wa mũndũ ũngĩ,
\q2 kana arutĩre Ngai kĩndũ gĩa gũkũũra mũndũ ũcio,
\q1 
\v 8 nĩgũkorwo ũkũũri wa muoyo nĩ ũndũ wa goro mũno,
\q2 gũtirĩ irĩhi rĩngĩigana o na atĩa,
\q1 
\v 9 atĩ nĩguo mũndũ atũũre muoyo nginya tene,
\q2 na ndakanabuthe.
\q1 
\v 10 Nĩgũkorwo andũ othe nĩmonaga atĩ o na andũ arĩa oogĩ nĩmakuuaga;
\q2 mũndũ mũkĩĩgu na mũndũ kĩrimũ o nao nĩmakuaga,
\q2 magatigĩra andũ angĩ ũtonga wao.
\q1 
\v 11 Mbĩrĩra ciao igũtũũra irĩ nyũmba ciao nginya tene,
\q2 ituĩke ciikaro ciao njiarwa na njiarwa,
\q2 o na gũtuĩka maarĩ na mĩgũnda yao ene.
\b
\q1 
\v 12 No mũndũ-rĩ, o na arĩ na indo nyingĩ, ndatũũraga;
\q2 akuuaga o ta ũrĩa nyamũ ĩkuuaga ĩgathira.
\b
\q1 
\v 13 Ũyũ nĩguo ũndũ ũrĩa wathĩrĩirio arĩa meĩhokaga o ene,
\q2 na arũmĩrĩri ao, arĩa metĩkanagia na mĩario yao.
\q1 
\v 14 Maathĩrĩirio mbĩrĩra o ta ngʼondu cia gũthĩnjwo,
\q2 na gĩkuũ nĩkĩo gĩgaatũĩka mũrĩithi wao.
\q1 Magaathagwo nĩ andũ arĩa arũngĩrĩru rũciinĩ;
\q2 ciimba ciao ikaabuthĩra mbĩrĩra-inĩ,
\q2 irĩ kũraihu na nyũmba ciao nene.
\q1 
\v 15 No Ngai nĩagakũũra muoyo wakwa kuuma mbĩrĩra-inĩ;
\q2 ti-itherũ nĩwe ũkaanyamũkĩra.
\b
\q1 
\v 16 Ndũkanetigĩre mũndũ rĩrĩa aatuĩka gĩtonga,
\q2 rĩrĩa riiri wa nyũmba yake wongerereka;
\q1 
\v 17 nĩgũkorwo ndarĩ kĩndũ agaathiĩ nakĩo akua,
\q2 riiri wake ndagaikũrũka naguo.
\q1 
\v 18 O na gũtuĩka rĩrĩa aarĩ muoyo eyoonaga arĩ mũrathime,
\q2 nĩgũkorwo andũ nĩmagũkumagia rĩrĩa wagaacĩra,
\q1 
\v 19 agakua athiĩ kũrĩ maithe mao,
\q2 acio matagacooka kuona ũtheri rĩngĩ.
\b
\q1 
\v 20 Mũndũ mũtongu ũtarĩ na ũmenyo
\q2 atariĩ o ta nyamũ iria ikuuaga igathira.
\c 50
\s1 Ngoro Ĩiyũrĩtwo nĩ Ngaatho
\d Thaburi ya Asafu
\q1 
\v 1 Jehova, o we Ngai ũcio Mwene-Hinya,
\q2 nĩaraaria, ageeta thĩ yothe
\q2 kuuma irathĩro rĩa riũa nginya kũrĩa rĩthũagĩra.
\q1 
\v 2 Ngai aracangarara arĩ Zayuni
\q2 itũũra rĩu ithaka mũno.
\q1 
\v 3 Ngai witũ nĩ gũũka arooka na ndegũkira;
\q2 mbere yake nĩ mwaki ũrakana,
\q2 na akarigiicĩrio nĩ kĩhuhũkanio kĩnene.
\q1 
\v 4 Areeta igũrũ na thĩ
\q2 nĩguo ituĩke aira agĩciirithia andũ ake:
\q1 
\v 5 “Cookanĩrĩrai harĩ niĩ inyuĩ andũ akwa aamũre,
\q2 o inyuĩ mwagĩire kĩrĩkanĩro na niĩ na ũndũ wa kũndutĩra igongona.”
\q1 
\v 6 Narĩo igũrũ rĩanagĩrĩra ũthingu wake,
\q2 nĩgũkorwo Ngai we mwene nĩwe mũtuanĩri ciira.
\b
\q1 
\v 7 “Inyuĩ andũ akwa, thikĩrĩriai na nĩngwaria,
\q2 ũthikĩrĩrie, wee Isiraeli, na nĩngũruta ũira wa gũgũthita:
\q2 nĩ niĩ Ngai, o Ngai waku.
\q1 
\v 8 Ndirakũrũithia nĩ ũndũ wa magongona maku,
\q2 o na kana nĩ ũndũ wa maruta maku ma njino,
\q2 marĩa makoragwo mbere yakwa hĩndĩ ciothe.
\q1 
\v 9 Ndibatarĩtio nĩ ndegwa yumĩte kiugũ gĩaku,
\q2 kana mbũri ciumĩte ciugũ ciaku,
\q1 
\v 10 nĩgũkorwo nyamũ ciothe cia gĩthaka nĩ ciakwa,
\q2 na ngʼombe iria irĩ tũrĩma-inĩ ngiri na ngiri.
\q1 
\v 11 Nyoni ciothe iria irĩ kũu irĩma-inĩ, gũtirĩ o na ĩmwe itooĩ,
\q2 na ciũmbe ciothe cia werũ-inĩ nĩ ciakwa.
\q1 
\v 12 Ingĩkorwo hũtiĩ, ndingĩkwĩra, nĩgũkorwo thĩ nĩ yakwa,
\q2 na kĩrĩa gĩothe kĩrĩ thĩinĩ wayo.
\q1 
\v 13 Niĩ nĩndĩĩaga nyama cia ndegwa,
\q2 o na kana nganyua thakame ya mbũri?
\q1 
\v 14 Rutĩra Ngai igongona rĩa gũcookia ngaatho,
\q2 na ũhingagĩrie Ũrĩa-ũrĩ-Igũrũ-Mũno mĩĩhĩtwa yaku,
\q1 
\v 15 na ũngayagĩre mũthenya wa mĩnyamaro;
\q2 na nĩndĩrĩkũhonokagia, nawe ũngoocage.”
\b
\q2 
\v 16 No rĩrĩ, mũndũ ũrĩa mwaganu Ngai ekũmũũria atĩrĩ:
\b
\q1 “Ũrĩ na kĩhooto kĩrĩkũ gĩa kuuga mawatho makwa,
\q2 kana kwaria ũhoro wa kĩrĩkanĩro gĩakwa?
\q1 
\v 17 Nĩũmenete ũrutani wakwa,
\q2 na ũgateanĩria ciugo ciakwa.
\q1 
\v 18 Rĩrĩa wona mũici, ũnyiitanagĩra nake;
\q2 na ũgĩĩaga ũrũmwe na itharia.
\q1 
\v 19 Ũhũthagĩra kanua gaku kwaria ndeto njũru,
\q2 na rũrĩmĩ rwaku naruo rũkaaragia maheeni.
\q1 
\v 20 Hĩndĩ ciothe waragia ndeto cia gũũkĩrĩra mũrũ wa thoguo,
\q2 ũgagĩcambia mũrũ-wa-nyũkwa.
\q1 
\v 21 Maũndũ macio ũmekaga o ngirĩte,
\q2 nawe ũgeciiria atĩ niĩ ndariĩ o tawe.
\q1 No rĩrĩ, rĩu nĩngũkũrũithia,
\q2 nguonie maũndũ marĩa wĩkĩte.
\b
\q1 
\v 22 “Mwĩcũraniei ũhoro ũyũ, inyuĩ mũriganagĩrwo nĩ Ngai,
\q2 nĩguo ndikamũtambuure, na haage mũndũ wa kũmũteithũra.
\q1 
\v 23 Mũndũ ũrĩa ũrutaga igongona rĩa gũcookia ngaatho nĩ niĩ atĩĩaga,
\q2 na akahaarĩria njĩra
\q2 nĩgeetha ndĩmuonie ũhonokanio wa Ngai.”
\c 51
\s1 Kũhooya Gũtherio na Kũrekerwo
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai-rĩ, njiguĩra tha,
\q2 kũringana na wendo waku ũrĩa ũtathiraga;
\q1 kũringana na tha ciaku nyingĩ-rĩ,
\q2 tharia mahĩtia makwa mathire.
\q1 
\v 2 Thambia mahĩtia makwa mothe,
\q2 na ũũtherie mehia makwa.
\b
\q1 
\v 3 Nĩgũkorwo nĩnjũũĩ mahĩtia makwa,
\q2 namo mehia makwa makoragwo mbere yakwa hĩndĩ ciothe.
\q1 
\v 4 Wee nĩwe njĩhĩirie, o Wee wiki,
\q2 na ngeeka ũndũ mũũru maitho-inĩ maku,
\q1 nĩguo Wee wonekage ũtarĩ na mahĩtia rĩrĩa ũkwaria,
\q2 na ũrĩ wa kĩhooto rĩrĩa ũgũtua ciira.
\q1 
\v 5 Ti-itherũ ndaciarirwo ndĩ mwĩhia;
\q2 maitũ aagĩire nda ya kũnjiara arĩ o na mehia.
\q1 
\v 6 Ti-itherũ, Wee wendaga ũhoro wa ma kuuma ngoro thĩinĩ;
\q2 nĩ ũndũ ũcio ũndutaga kũgĩa na ũũgĩ ngoro-inĩ yakwa.
\b
\q1 
\v 7 Theria na mũthobi,\f + \fr 51:7 \ft Mũthobi nĩguo watũmagĩrwo kũminjaminjĩria andũ thakame ya kũmatheria.\f* na nĩngũthera;
\q2 thaambia, na nĩngwerũha gũkĩra ira.
\q1 
\v 8 Tũma ngene na njanjamũke;
\q2 mahĩndĩ marĩa ũthetherete nĩmagĩkene.
\q1 
\v 9 Hitha ũthiũ waku ndũkoone mehia makwa,
\q2 na ũtharie mahĩtia makwa mothe.
\b
\q1 
\v 10 Wee Ngai-rĩ, nyũmbĩra ngoro theru thĩinĩ wakwa,
\q2 na ũnjerũhĩrie roho wa kwĩhokeka thĩinĩ wakwa.
\q1 
\v 11 Ndũkanyingate nyume harĩwe,
\q2 o na kana weherie Roho waku Mũtheru kuuma thĩinĩ wakwa.
\q1 
\v 12 Njookeria gĩkeno kĩrĩa kĩa ũhonokio waku,
\q2 na ũũhe roho wa kũndũũria ngwathĩkagĩra.
\b
\q1 
\v 13 Hĩndĩ ĩyo nĩngaruta andũ arĩa aremi nĩguo mamenye njĩra ciaku,
\q2 nao ehia magũcookerere.
\q1 
\v 14 Wee Ngai, o Wee Ngai ũrĩa ũũhonokagia-rĩ,
\q2 honokia kuumana na ũiti thakame,
\q2 naruo rũrĩmĩ rwakwa nĩrũkaina ũhoro wa ũthingu waku.
\q1 
\v 15 Wee Mwathani, tumũra mĩromo yakwa,
\q2 nako kanua gakwa koimbũre ũgooci waku.
\q1 
\v 16 Wee ndũkenagio nĩ kũrutĩrwo igongona,
\q2 korwo nĩũkenagio nĩrĩo no ngũrutĩre;
\q2 o na ndũkenagio nĩ magongona ma njino.
\q1 
\v 17 Magongona marĩa Ngai etĩkagĩra nĩ roho ũrĩa mũthuthĩku;
\q2 ngoro ĩrĩa thuthĩku na ĩkahera-rĩ,
\q2 Wee Ngai ndũngĩmĩrega.
\b
\q1 
\v 18 Tũma itũũra rĩa Zayuni rĩgaacĩre nĩ ũndũ wa wega waku;
\q2 aka thingo cia Jerusalemu rĩngĩ.
\q1 
\v 19 Hĩndĩ ĩyo nĩũgakenagĩra magongona ma ũthingu,
\q2 na maruta ma njino o marĩa macinagwo magathira biũ;
\q2 ningĩ magongona ma ndegwa nĩmakarutagĩrwo kĩgongona-inĩ gĩaku.
\c 52
\s1 Wega wa Ngai na Gũtuanĩra Ciira Gwake
\d Thaburi ya Daudi
\q1 
\v 1 Wee njamba ĩno ĩrĩ hinya,
\q2 ũreegana nĩ ũndũ wa maũndũ mooru nĩkĩ?
\q1 Ũtindaga wĩrahĩte mũthenya wothe nĩkĩ,
\q2 o wee ũtuĩkĩte gĩconoko maitho-nĩ ma Ngai?
\q1 
\v 2 Rũrĩmĩ rwaku rũthugundaga mwanangĩko;
\q2 rũhaana ta rwenji rũnoore,
\q2 o wee wĩkaga maũndũ ma maheeni.
\q1 
\v 3 Wendete maũndũ mooru gũkĩra marĩa mega,
\q2 ũkenda maheeni gũkĩra kwaria ma.
\q1 
\v 4 Wendete ciugo o ciothe ithũkagia andũ,
\q2 wee rũrĩmĩ rũrũ rwa maheeni!
\b
\q1 
\v 5 Ti-itherũ Mũrungu nĩagakwananga nginya tene na tene:
\q2 Agakũnyiita, akũhurie na akũrute hema-inĩ yaku;
\q2 agakũmunya akweherie bũrũri wa arĩa marĩ muoyo.
\q1 
\v 6 Andũ arĩa athingu nĩmakona ũguo metigĩre;
\q2 nao magathekerera mũndũ ũcio, moige atĩrĩ,
\q1 
\v 7 “Ũyũ nĩwe mũndũ
\q2 ũrĩa wagire gũtua Ngai kĩĩhitho gĩake kĩa hinya,
\q1 no eehokire ũtonga wake mũingĩ,
\q2 na akĩgĩa hinya nĩ ũndũ wa kũniina andũ arĩa angĩ!”
\b
\q1 
\v 8 No rĩrĩ, niĩ ndariĩ ta mũtĩ wa mũtamaiyũ,
\q2 ũrĩa ũrakũra wega ũrĩ thĩinĩ wa nyũmba ya Ngai;
\q1 ndĩhokete wendo wa Ngai ũrĩa ũtathiraga
\q2 nginya tene na tene.
\q1 
\v 9 Ngũtũũra ngũgoocaga nginya tene nĩ ũndũ wa ũrĩa wĩkĩte;
\q2 ndĩrĩĩhokaga rĩĩtwa rĩaku, nĩgũkorwo rĩĩtwa rĩaku nĩ rĩega.
\q2 Ndĩrĩkũgoocaga ndĩ mbere ya andũ aku arĩa aamũre.
\c 53
\s1 Ngai Ndakenagio nĩ Irimũ
\d Thaburi ya Daudi
\q1 
\v 1 Kĩrimũ kĩĩraga na ngoro atĩrĩ,
\q2 “Gũtirĩ Ngai.”
\q1 Nao amaramari, ciĩko ciao irĩ magigi;
\q2 gũtirĩ mũndũ o na ũmwe wĩkaga wega.
\b
\q1 
\v 2 Ngai aroraga ciana cia andũ
\q2 arĩ o igũrũ,
\q1 one kana nĩ harĩ ũrĩ na ũmenyo,
\q2 o na kana nĩ harĩ ũrongoragia Ngai.
\q1 
\v 3 Othe nĩmacookete na thuutha,
\q2 othe marĩ hamwe nĩmatuĩkĩte amaramari;
\q1 gũtirĩ o na ũmwe wĩkaga wega,
\q2 gũtirĩ o na ũmwe.
\b
\q1 
\v 4 Andũ acio mekaga maũndũ mooru kaĩ matarĩ ũmenyo,
\q2 o acio marĩĩaga andũ akwa o ta ũrĩa andũ marĩĩaga irio,
\q2 o acio matakayagĩra Ngai?
\q1 
\v 5 O hau-rĩ, makanyiitwo nĩ guoya mũnene,
\q2 o na gũtarĩ kĩndũ gĩa gũtũma metigĩre.
\q1 Nĩgũkorwo Ngai nĩahurunjĩte mahĩndĩ ma andũ acio magũtharĩkĩire;
\q2 nĩwamaconorithirie, nĩgũkorwo Ngai nĩamamenete.
\b
\q1 
\v 6 Naarĩ korwo ũhonokio wa Isiraeli no ũgĩũke kuuma Zayuni!
\q2 Rĩrĩa Ngai agacookereria andũ ake na indo ciao-rĩ,
\q2 Jakubu nĩagakena na Isiraeli acanjamũke!
\c 54
\s1 Ngai Nĩwe Ũteithio Wakwa
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai, honokia nĩ ũndũ wa rĩĩtwa rĩaku;
\q2 ndĩhĩria na hinya waku.
\q1 
\v 2 Wee Ngai, igua ihooya rĩakwa;
\q2 thikĩrĩria ciugo cia kanua gakwa.
\b
\q1 
\v 3 Andũ ageni nĩmanjũkĩrĩire;
\q2 nao andũ matarĩ tha nĩmaracaria muoyo wakwa,
\q2 o andũ acio matarũmbũyagia Ngai.
\b
\q1 
\v 4 Ti-itherũ Ngai nĩwe ũteithio wakwa;
\q2 Mwathani nĩwe ũndiiragĩrĩra.
\b
\q1 
\v 5 Cookereria andũ arĩa manjambagia ũũru wao;
\q2 Wee maniine nĩ ũndũ wa wĩhokeku waku.
\b
\q1 
\v 6 Nĩngũkũrutĩra igongona rĩa kwĩyendera;
\q2 nĩngũgooca rĩĩtwa rĩaku, Wee Jehova,
\q2 tondũ nĩ rĩega.
\q1 
\v 7 Nĩgũkorwo nĩahonoketie mathĩĩna-inĩ makwa mothe,
\q2 na maitho makwa nĩmeyoneire gũtoorio gwa thũ ciakwa.
\c 55
\s1 Mwathani Nĩatiiragĩrĩra Andũ arĩa Athingu
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai, thikĩrĩria ihooya rĩakwa,
\q2 ndũkaage kũigua ithaithana rĩakwa;
\q2 
\v 2 njigua na ũnjĩtĩke.
\q1 Meciiria makwa nĩmathĩĩnĩtie na ndĩ mũgiĩku
\q2 
\v 3 nĩ ũndũ wa mũgambo wa thũ,
\q2 nĩ ũndũ wa gũkũũrĩrwo maitho nĩ andũ arĩa aaganu;
\q1 tondũ o mandehagĩra o mathĩĩna,
\q2 na makaanyũrũria marakarĩte.
\b
\q1 
\v 4 Ngoro yakwa ĩrĩ na ruo rũnene thĩinĩ wakwa,
\q2 nganyiitwo nĩ imakania nene cia gĩkuũ.
\q1 
\v 5 Guoya na kũinaina nĩcindigiicĩirie;
\q2 hubanĩirio nĩ kĩmako kĩnene.
\q1 
\v 6 Na niĩ ngiuga atĩrĩ, “Hĩ, naarĩ korwo ndĩ na mathagu ta ndutura!
\q2 Ingĩũmbũka thiĩ ngahurũke,
\q1 
\v 7 ingĩũra thiĩ kũndũ kũraya,
\q2 ngaikare werũ-inĩ;
\q1 
\v 8 ingĩhiũha thiĩ handũ harĩa ingĩĩgitia,
\q2 kũraihu na rũhuho rũu rũnene na kĩhuhũkanio.”
\b
\q1 
\v 9 Wee Mwathani, andũ arĩa aaganu nĩmanyiitwo nĩ kĩrigiicano,
\q2 ũhĩngĩcanie mĩario yao,
\q2 nĩgũkorwo itũũra-inĩ inene nyonaga o haaro na ngũĩ.
\q1 
\v 10 Mũthenya na ũtukũ, andũ acio aaganu macangacangaga thingo-inĩ cia itũũra rĩu;
\q2 narĩo rĩiyũrĩtwo nĩ rũmena na irumi.
\q1 
\v 11 Thĩinĩ wa itũũra rĩu inene no mwanangĩko ũrĩ kuo;
\q2 kwĩhĩtanĩra na kũheenania ciyũrĩte njĩra-inĩ ciarĩo.
\b
\q1 
\v 12 Korwo nĩ thũ ĩranuma-rĩ,
\q2 no ngirĩrĩrie;
\q1 korwo nĩ thũ ĩranjũkĩrĩra-rĩ,
\q2 no ndĩhithe ndĩkanyone.
\q1 
\v 13 No rĩrĩ, nĩwe mũndũ wa riika rĩakwa,
\q2 mũthiritũ wakwa, mũrata wakwa ũrĩa twendanĩte mũno,
\q1 
\v 14 o wee twanakenanĩra tũrĩ na ngwatanĩro njega,
\q2 tũgĩthiĩ hamwe na andũ arĩa angĩ nyũmba-inĩ ya Ngai.
\b
\q1 
\v 15 Gĩkuũ kĩrohubanĩria thũ ciakwa o rĩmwe;
\q2 iroikũrũka mbĩrĩra irĩ muoyo,
\q2 tondũ ũũru ũkoragwo ngoro-inĩ ciacio.
\b
\q1 
\v 16 No rĩrĩ, niĩ nĩ Ngai ngayagĩra,
\q2 nake Jehova nĩahonokagia.
\q1 
\v 17 Hwaĩ-inĩ, na rũciinĩ, o na mĩaraho,
\q2 ngayaga ndĩ mĩnyamaro-inĩ,
\q2 nake nĩaiguaga mũgambo wakwa.
\q1 
\v 18 We angũũraga kuuma mbaara-inĩ ĩrĩa ndũithagio,
\q2 ngoima itagurarĩtio,
\q2 o na gwakorwo nĩ andũ aingĩ mandũithagia.
\q1 
\v 19 Mũrungu ũrĩa ũtũũrĩte aikarĩire gĩtĩ kĩa ũnene nginya tene,
\q2 nĩekũmaigua na amaherithie,
\q1 andũ acio matagarũragĩra mĩthiĩre yao,
\q2 o acio matetigagĩra Ngai.
\b
\q1 
\v 20 Mũndũ ũcio tũrĩ thiritũ nake atharĩkagĩra arata ake,
\q2 na agathũkia kĩrĩkanĩro gĩake.
\q1 
\v 21 Mĩario yake ĩnyorokete o ta thiagĩ,
\q2 no rĩrĩ, mbaara ĩrĩ ngoro-inĩ yake;
\q1 ciugo ciake ihooranagĩria gũkĩra maguta,
\q2 no icio nĩ hiũ cia njora irĩ njomore.
\b
\q1 
\v 22 Rekereria Jehova maũndũ marĩa magũtangaga,
\q2 na nĩegũgũtiirĩrĩra;
\q2 ndarĩ hĩndĩ akaareka mũndũ ũrĩa mũthingu agwe.
\q1 
\v 23 No rĩrĩ, Wee Ngai, nĩũkaharũrũkia andũ arĩa aaganu
\q2 irima-inĩ rĩa ũmaramari;
\q1 andũ arĩa manyootagĩra thakame na andũ a maheeni
\q2 matigaakinyia nuthu ya matukũ mao.
\b
\q1 No niĩ hakwa-rĩ, Wee nĩwe ndĩĩhokete.
\c 56
\s1 Kwĩhoka Ngai
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai, njiguĩra tha,
\q2 nĩgũkorwo andũ nĩmaingatanĩte na niĩ mũno;
\q2 mũthenya wothe mendaga o gũũtharĩkĩra.
\q1 
\v 2 Andũ arĩa manjambagia
\q2 maingatanaga na niĩ mũthenya wothe;
\q2 aingĩ nĩ arĩa maraatharĩkĩra na mwĩtĩĩo.
\b
\q1 
\v 3 Rĩrĩa ndetigĩra-rĩ,
\q2 nĩwe ndĩrĩhokaga.
\q1 
\v 4 Nĩ ũndũ wa hinya wa Ngai, nĩndĩrĩgoocaga kiugo gĩake,
\q2 ndĩhokete o Ngai; ndingĩĩtigĩra.
\q2 Mũndũ ũrĩ na mwĩrĩ angĩnjĩka atĩa?
\b
\q1 
\v 5 Mũthenya wothe matindaga makĩogomia ciugo ciakwa;
\q2 hĩndĩ ciothe mathugundaga kũnjĩka ũũru.
\q1 
\v 6 Manjiiragĩra na makanjoheria,
\q2 na makarĩithania na mĩthiĩre yakwa,
\q2 makĩenda kũnjũraga.
\b
\q1 
\v 7 Wee Ngai, ndũkareke mahonoke o na atĩa;
\q2 ngʼaũrania ndũrĩrĩ na marakara maku.
\q1 
\v 8 Andĩka ũhoro wa gũcakaya gwakwa;
\q2 maithori makwa mekĩre cuba-inĩ yaku,
\q2 githĩ matirĩ maandĩko-inĩ maku?
\b
\q1 
\v 9 Rĩrĩa ngaakaya ndeithio
\q2 thũ ciakwa nĩikahũndũka.
\q2 Ũndũ ũcio nĩũgatũma menye atĩ Ngai arĩ hamwe na niĩ.
\q1 
\v 10 Nĩ ũndũ wa hinya wa Ngai, ũrĩa ngoocaga kiugo gĩake,
\q2 nĩ ũndũ wa hinya wa Jehova, ũrĩa ngoocaga kiugo gĩake,
\q1 
\v 11 ndĩhokete o Ngai; ndingĩĩtigĩra.
\q2 Mũndũ-rĩ, angĩnjĩka atĩa?
\b
\q1 
\v 12 Wee Ngai, mĩĩhĩtwa ĩrĩa ndĩĩhĩtĩte ndĩ o nayo,
\q2 nĩndĩrĩkũrutagĩra maruta ma gũgũcookeria ngaatho.
\q1 
\v 13 Nĩgũkorwo nĩũũhonoketie kuuma gĩkuũ-inĩ,
\q2 na ũkagirĩrĩria magũrũ makwa kũhĩngwo,
\q1 nĩguo thiiage mbere ya Ngai
\q2 ngĩonaga ũtheri ũrĩa wonagwo nĩ arĩa marĩ muoyo.
\c 57
\s1 Ihooya rĩa kũũria Ngai Ũteithio
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai, njiguĩra tha, ũnjiguĩre tha,
\q2 nĩgũkorwo nĩ harĩwe njũragĩra.
\q1 Niĩ ngũũrĩra kĩĩruru-inĩ kĩa mathagu maku,
\q2 o nginya mwanangĩko ũhĩtũke.
\b
\q1 
\v 2 Ngũkaĩra Ngai-Ũrĩa-ũrĩ-Igũrũ-Mũno,
\q2 o kũrĩ Mũrungu, ũrĩa ũũhingagĩria maũndũ.
\q1 
\v 3 Atũmaga ũteithio kuuma igũrũ akaahonokia,
\q2 akarũithia arĩa maahanyũkagia mũno;
\q2 Ngai agakĩndũmĩra wendani na wĩhokeku wake.
\b
\q1 
\v 4 Niĩ ndĩ gatagatĩ-inĩ ka mĩrũũthi;
\q2 ngomete gatagatĩ ka nyamũ ndĩĩani,
\q1 na nĩo andũ arĩa magego mao mahaana ta matimũ na mĩguĩ,
\q2 o acio nĩmĩ ciao ihaana ta hiũ cia njora njũgĩ.
\b
\q1 
\v 5 Wee Ngai, tũũgĩra, ũtũũgĩrio igũrũ rĩa igũrũ;
\q2 riiri waku nĩũgĩe igũrũ rĩa thĩ yothe.
\b
\q1 
\v 6 Thũ ciakwa nĩciambĩire magũrũ makwa mũtego wa wabu,
\q2 na niĩ ngĩĩthikĩra nĩ kũnyamarĩka.
\q1 Cienjete irima njĩra-inĩ yakwa,
\q2 no nĩcio igũĩte thĩinĩ warĩo.
\b
\q1 
\v 7 Wee Ngai, ngoro yakwa nĩĩkindĩirie,
\q2 ngoro yakwa no ĩkindĩirie;
\q2 nĩkũina ngũina, ngũgooce na rwĩmbo.
\q1 
\v 8 Wee muoyo wakwa arahũka!
\q2 Arahũka wee kĩnanda kĩa mũgeeto, o nawe kĩnanda gĩa kĩnũbi!
\q2 Ngwarahũka ruoro rũgĩtema.
\b
\q1 
\v 9 Wee Mwathani, nĩngũkũgooca, gatagatĩ-inĩ ka ndũrĩrĩ;
\q2 nĩngũkũinĩra ngũgooce ndĩ gatagatĩ-inĩ ka andũ.
\q1 
\v 10 Nĩgũkorwo wendo waku nĩ mũnene, ũgagĩkinya o igũrũ;
\q2 wĩhokeku waku ũkinyĩte o matu-inĩ.
\b
\q1 
\v 11 Wee Ngai, tũũgĩra, ũtũũgĩrio igũrũ rĩa igũrũ;
\q2 riiri waku nĩũgĩe igũrũ rĩa thĩ yothe.
\c 58
\s1 Ihooya rĩa kũũria Ngai Aherithie Andũ arĩa Aaganu
\d Thaburi ya Daudi
\q1 
\v 1 Inyuĩ aathani aya-rĩ, ti-itherũ nĩmwaragia maũndũ ma kĩhooto?
\q2 Nĩmũtuagĩra andũ ciira ũrĩa kwagĩrĩire na kĩhooto?
\q1 
\v 2 Aca, ngoro-inĩ cianyu mũthugundaga maũndũ matarĩ ma kĩhooto,
\q2 na moko manyu mageeka maũndũ ma kũruta haaro gũkũ thĩ.
\q1 
\v 3 O kuuma gũciarwo andũ arĩa aaganu nĩmahĩtagia njĩra;
\q2 matũũraga marĩ imaramari kuuma gũciarwo, na maaragia maheeni.
\q1 
\v 4 Ũrũrũ wao nĩ ta ũrũrũ wa nyoka,
\q2 ũhaana ta thumu wa nduĩra ĩthingĩte matũ mayo,
\q1 
\v 5 ĩrĩa ĩtangĩigua rwĩmbo rwa mũmĩthuuthĩri,
\q2 o na angĩkorwo aramĩthuuthĩra arĩ na ũũgĩ mũnene atĩa.
\b
\q1 
\v 6 Wee Ngai, unanga magego marĩa marĩ tũnua twao;
\q2 Wee Jehova, munya mĩthangiri ya mĩrũũthi ĩyo!
\q1 
\v 7 Nĩmabuĩrie o ta maaĩ marĩa mathereraga makabuĩria;
\q2 rĩrĩa magereka ũta-rĩ, mĩguĩ yao nĩĩkoragwo ĩrĩ mĩtuuhu.
\q1 
\v 8 Marotuĩka ta ndinoho ĩrĩa ĩtwekaga o ĩgĩthiiaga,
\q2 matuĩke ta kĩhuno kĩrĩa gĩtoonaga riũa.
\b
\q1 
\v 9 Andũ arĩa aaganu makeeherio narua,
\q2 gũkĩra ũrĩa nyũngũ cianyu ingĩhiũhio nĩ mwaki wa mĩigua,
\q2 ĩrĩ mĩigũ kana ĩrĩ mĩũmũ.
\q1 
\v 10 Andũ arĩa athingu nĩmagakena maarĩhĩrio,
\q2 rĩrĩa magathambia nyarĩrĩ ciao thakame-inĩ ya arĩa aaganu.
\q1 
\v 11 Hĩndĩ ĩyo andũ nĩmakoiga atĩrĩ,
\q2 “Ti-itherũ nĩ kũrĩ na irĩhi rĩa arĩa athingu;
\q2 ti-itherũ nĩ kũrĩ Ngai ũrĩa ũtuagĩra andũ a thĩ ciira.”
\c 59
\s1 Ihooya rĩa kũhooya Ũgitĩri
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai, honokia kuuma kũrĩ thũ ciakwa;
\q2 ngitĩra harĩ arĩa manjũkagĩrĩra.
\q1 
\v 2 Honokia kuuma kũrĩ arĩa mekaga ũũru,
\q2 na ũũhonokie kuuma kũrĩ acio aiti thakame.
\b
\q1 
\v 3 Ta kĩone ũrĩa manjoheirie!
\q2 Andũ ooru maranjiirĩra manjũkĩrĩre,
\q2 o na itekĩte ũũru kana ngehia, Wee Jehova.
\q1 
\v 4 Ndirĩ ũndũ mũũru njĩkĩte,
\q2 no rĩrĩ, nĩmehaarĩirie maatharĩkĩre.
\q2 Arahũka ũndeithie; wĩonere ũrĩa thĩĩnĩkĩte!
\q1 
\v 5 Wee Jehova, Ngai Mwene-Hinya-Wothe, o Wee Ngai wa Isiraeli,
\q2 arahũka ũherithie ndũrĩrĩ ciothe;
\q2 ndũkaiguĩre andũ aaganu tha, o acio makunyanagĩra andũ arĩa angĩ.
\b
\q1 
\v 6 Macookaga hwaĩ-inĩ makĩraramaga ta ngui,
\q2 makĩũrũraga itũũra-inĩ inene.
\q1 
\v 7 Ta kĩone kĩrĩa marerũka na tũnua twao,
\q2 nĩ ta marerũka hiũ cia njora kuuma mĩromo-inĩ yao,
\q2 makooria atĩrĩ, “Nũũ ũngĩtũigua?”
\q1 
\v 8 No Wee Jehova-rĩ, mathekerere;
\q2 ndũrĩrĩ icio ciothe nĩũcinyararĩte.
\b
\q1 
\v 9 Wee Hinya wakwa-rĩ, nowe njũũthĩrĩirie;
\q2 Wee Ngai-rĩ, nĩwe kĩirigo gĩakwa kĩa hinya,
\q2 o Wee Ngai wakwa mũnyendi.
\b
\q1 
\v 10 Ngai nĩegũthiĩ mbere yakwa,
\q2 na nĩekũnjĩtĩkĩria ngenerere arĩa manjambagia.
\q1 
\v 11 No ndũkamoorage,
\q2 nĩguo andũ akwa matikanariganĩrwo.
\q1 Nĩ ũndũ wa hinya waku, tũma matũũre morũũraga,
\q2 nginya ũmatoorie, Wee Mwathani ngo iitũ.
\q1 
\v 12 Nĩ ũndũ wa mehia ma tũnua twao,
\q2 na nĩ ũndũ wa ciugo cia mĩromo yao,
\q2 tũma magwatio nĩ mũtego wa mwĩtĩĩo wao.
\q1 Nĩ ũndũ wa irumi na maheeni marĩa maaragia,
\q2 
\v 13 maniine na marakara maku,
\q2 maniine nginya mathire biũ.
\q1 Hĩndĩ ĩyo nĩgũkamenyeka nginya ituri cia thĩ,
\q2 atĩ Ngai nĩwe wathaga Jakubu.
\b
\q1 
\v 14 Macookaga hwaĩ-inĩ makĩraramaga ta ngui,
\q2 makĩũrũraga itũũra-inĩ inene.
\q1 
\v 15 Morũũraga magĩcaria irio,
\q2 na makoigĩrĩria maga kũhũũna.
\q1 
\v 16 No niĩ-rĩ, ndĩinaga ũhoro wa hinya waku,
\q2 o rũciinĩ ngaina ũhoro wa wendo waku;
\q1 nĩgũkorwo Wee nĩwe kĩirigo gĩakwa kĩa hinya,
\q2 na rĩũrĩro rĩakwa hĩndĩ ya mathĩĩna.
\b
\q1 
\v 17 Wee Hinya wakwa-rĩ, nĩngũkũinĩra ngũgooce;
\q2 nĩgũkorwo Wee nĩwe kĩirigo gĩakwa kĩa hinya,
\q2 o Wee Ngai ũrĩa ũnyendete.
\c 60
\s1 Ihooya rĩa kũũria Ũtoorania
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai nĩũtũtiganĩirie na ũgatũharagania;
\q2 ũkoretwo ũtũrakarĩire, no rĩu tũcookerere!
\q1 
\v 2 Nĩũthingithĩtie bũrũri na ũkawatũra;
\q2 thinga mĩatũka yaguo, nĩgũkorwo nĩũrenyenya.
\q1 
\v 3 Nĩũtũmĩte andũ aku makorwo na mahinda maritũ;
\q2 ũmanyuithĩtie ndibei magathiĩ magĩtũgũũgaga.
\b
\q1 
\v 4 No rĩrĩ, andũ arĩa magwĩtigĩrĩte-rĩ, nĩũmahaicĩirie bendera,
\q2 nĩguo metharagĩre harĩ yo mona arĩa mamarathaga na ũta.
\b
\q1 
\v 5 Tũhonokie na ũtũteithie na guoko gwaku kwa ũrĩo,
\q2 nĩguo arĩa wendete mahonoke.
\q1 
\v 6 Ngai nĩarĩtie arĩ handũ hake harĩa haamũre, akoiga atĩrĩ:
\q2 “Nĩngatũranga Shekemu\f + \fr 60:6 \ft Shekemu nĩrĩo rĩarĩ itũũra inene rĩa Isiraeli matukũ-inĩ ma tene.\f* ndĩ na gĩkeno kĩingĩ,
\q2 na thimĩre andũ akwa Gĩtuamba gĩa Sukothu.
\q1 
\v 7 Gileadi nĩ gwakwa, o na Manase no gwakwa;\f + \fr 60:7 \ft Gileadi na Manase kwarĩ mwena wa irathĩro wa bũrũri wa Isiraeli.\f*
\q2 Efiraimu nĩ ngũbia yakwa ya kĩgera,
\q2 na Juda nĩ rũthanju rwakwa rwa ũthamaki.
\q1 
\v 8 Moabi nĩ kĩraĩ gĩakwa gĩa gwĩthambĩra,
\q2 na Edomu nĩho njikagia kĩraatũ gĩakwa;
\q2 nyanagĩrĩra nĩ ũrĩa ndooretie bũrũri wa Filistia.”
\b
\q1 
\v 9 Nũũ ũkũnginyia itũũra rĩrĩa inene rĩirigĩre?
\q2 Nũũ ũkũndongoria andware Edomu?
\q1 
\v 10 Githĩ tiwe, Wee Ngai, o Wee ũtũregete,
\q2 na ũgatiga gũtwarana na mbũtũ ciitũ cia ita?
\q1 
\v 11 Tũteithie, ũtũhootanĩre harĩ thũ ciitũ,
\q2 nĩgũkorwo ũteithio wa mũndũ nĩ wa tũhũ.
\q1 
\v 12 Ngai arĩ hamwe na ithuĩ nĩtũkũhootana,
\q2 na nĩakarangĩrĩria thũ ciitũ thĩ.
\c 61
\s1 Kũhooya Ũgitĩri wa Ngai
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai, igua kĩrĩro gĩakwa;
\q2 thikĩrĩria ihooya rĩakwa.
\b
\q1 
\v 2 Ndĩragũkaĩra kuuma ituri cia thĩ,
\q2 ndĩragũkaĩra o ngoro yakwa ĩgĩthiragwo nĩ hinya;
\q2 ndongoria nginye rwaro-inĩ rwa ihiga rũrĩa rũraihu na igũrũ kũngĩra.
\q1 
\v 3 Nĩgũkorwo nĩwe ũkoretwo ũrĩ rĩũrĩro rĩakwa,
\q2 mũthiringo mũraihu na igũrũ wa hinya wa kwĩhitha kuuma kũrĩ thũ.
\b
\q1 
\v 4 Ndĩĩriragĩria gũtũũra hema-inĩ yaku nginya tene,
\q2 na ndĩĩhithage kĩĩruru-inĩ kĩa mathagu maku.
\q1 
\v 5 Nĩgũkorwo Wee Ngai nĩũiguĩte mĩĩhĩtwa yakwa,
\q2 nĩũngaĩire igai rĩa andũ arĩa metigĩrĩte rĩĩtwa rĩaku.
\b
\q1 
\v 6 Ongerera matukũ ma mũthamaki ma gũtũũra muoyo,
\q2 mĩaka yake ĩigane ta ya njiarwa nyingĩ.
\q1 
\v 7 Aroikarĩra gĩtĩ kĩa ũnene arĩ mbere ya Ngai nginya tene;
\q2 tũma wendo na wĩhokeku waku imũgitagĩre.
\b
\q1 
\v 8 Hĩndĩ ĩyo ngatũũra nyinaga rwĩmbo rwa kũgooca rĩĩtwa rĩaku,
\q2 na hingagie mĩĩhĩtwa yakwa mũthenya o mũthenya.
\c 62
\s1 Kwĩhoka Ngai arĩ o We Wiki
\d Thaburi ya Daudi
\q1 
\v 1 Ngoro yakwa yetagĩrĩra Ngai o we wiki;
\q2 ũhonokio wakwa uumaga harĩ we.
\q1 
\v 2 O we wiki nĩwe rwaro rwakwa rwa ihiga na ũhonokio wakwa;
\q2 nĩwe kĩirigo gĩakwa kĩa hinya, ndirĩ hĩndĩ ngenyenyeka.
\b
\q1 
\v 3 Nĩ nginya rĩ mũgũtũũra mũtharĩkagĩra mũndũ?
\q2 Mwamũũraga inyuothe, taarĩ rũthingo rũinamu
\q2 kana rũirigo rũrenda kũgũa?
\q1 
\v 4 Nĩmatuĩte itua mamweherie ũnene-inĩ wake;
\q2 makenagio nĩ maheeni.
\q1 Marathimanaga na tũnua twao,
\q2 no ngoro-inĩ ciao makarumana.
\b
\q1 
\v 5 Wee ngoro yakwa, etha ũhurũko harĩ Ngai o we wiki,
\q2 kĩĩrĩgĩrĩro gĩakwa kĩrĩ harĩ we.
\q1 
\v 6 O we wiki nĩwe rwaro rwakwa rwa ihiga na ũhonokio wakwa;
\q2 nĩwe kĩirigo gĩakwa kĩa hinya ndirĩ hĩndĩ ngenyenyeka.
\q1 
\v 7 Ũhonokio wakwa na gĩtĩĩo gĩakwa ciumaga kũrĩ Ngai;
\q2 nĩwe rwaro rwakwa rwa ihiga rũrĩ hinya, na rĩũrĩro rĩakwa.
\q1 
\v 8 Inyuĩ andũ aya, mwĩhokagei o we hĩndĩ ciothe;
\q2 itũrũragai ngoro cianyu harĩ we,
\q2 nĩgũkorwo Ngai nĩwe rĩũrĩro riitũ.
\b
\q1 
\v 9 Andũ arĩa matarĩ igweta no mĩhũmũ tu,
\q2 na arĩa marĩ igweta no maheeni tu;
\q1 mangĩthimwo na ratiri-rĩ, o no kĩndũ gĩa tũhũ;
\q2 othe marĩ hamwe no mĩhũmũ mĩtheri.
\q1 
\v 10 Mũtikehoke ũtunyani
\q2 kana mwĩtĩĩe na indo cia kũiya;
\q1 o na ũtonga wanyu ũngĩingĩha-rĩ,
\q2 mũtikawĩhoke.
\q1 
\v 11 Harĩ ũndũ ũmwe Ngai oigĩte,
\q2 o na nĩ maũndũ meerĩ njiguĩte:
\q1 atĩ Wee Ngai, nĩ ũrĩ hinya,
\q2 
\v 12 na atĩ Wee Mwathani, ũrĩ mwendani.
\q1 Ti-itherũ nĩũkarĩha o mũndũ
\q2 kũringana na wĩra wake.
\c 63
\s1 Kũnyootera Ngai
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai, nĩwe Mũrungu wakwa,
\q2 Wee-rĩ, nĩwe nongoragia na kĩyo;
\q1 ngoro yakwa nĩwe ĩnyootagĩra,
\q2 na mwĩrĩ wakwa nĩwe wĩriragĩria,
\q1 ndĩ bũrũri-inĩ ũyũ mũũmũ na wa mĩnoga,
\q2 o ũyũ ũtarĩ maaĩ.
\b
\q1 
\v 2 Nĩnguonete ũrĩ handũ-harĩa-haamũre,
\q2 na ngeyonera hinya waku na riiri waku.
\q1 
\v 3 Tondũ wendo waku nĩ mwega gũkĩra muoyo guo mwene-rĩ,
\q2 mĩromo yakwa nĩĩrĩkũgoocaga.
\q1 
\v 4 Ndĩrĩkũgoocaga hĩndĩ ĩrĩa yothe ngũtũũra muoyo,
\q2 ngoocage rĩĩtwa rĩaku nyambararĩtie moko makwa.
\q1 
\v 5 Ngoro yakwa ĩiganĩire ta ĩrĩĩte irio iria njega mũno;
\q2 nako kanua gakwa nĩkarĩkũgoocaga, mĩromo yakwa ĩgakũinĩra.
\b
\q1 
\v 6 Ngũririkanaga ndĩ ũrĩrĩ;
\q2 ndĩciiragia ũhoro waku ũtukũ wothe.
\q1 
\v 7 Tondũ Wee nĩwe ũteithio wakwa-rĩ,
\q2 nyinagĩra kĩĩruru-inĩ kĩa mathagu maku.
\q1 
\v 8 Ngoro yakwa nĩĩnyiitĩrĩire harĩwe;
\q2 guoko gwaku kwa ũrĩo gũkaanyiitĩrĩra.
\b
\q1 
\v 9 Andũ arĩa macaragia muoyo wakwa nĩguo maũniine nĩmakanangwo;
\q2 magaatoonyerera na thĩ nginya kũrĩa kũriku mũno.
\q1 
\v 10 Makooragwo na rũhiũ rwa njora
\q2 matuĩke irio cia mbwe.
\b
\q1 
\v 11 No rĩrĩ, mũthamaki nĩagakena nĩ ũndũ wa Ngai;
\q2 andũ arĩa othe mehĩtaga makĩgwetaga rĩĩtwa rĩa Ngai nĩmakamũgooca,
\q2 natuo tũnua twa arĩa maaragia maheeni nĩtũgaakirio.
\c 64
\s1 Ihooya rĩa kũũria Ũgitĩri
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai, igua mũgambo wakwa ngĩkwĩra mateta makwa;
\q2 gitĩra muoyo wakwa harĩ kwĩhĩtĩrwo nĩ thũ.
\q1 
\v 2 Kĩĩhithe kuuma kũrĩ ndundu ya andũ arĩa aaganu,
\q2 ũũhithe kuuma kũrĩ inegene rĩa mũingĩ ũrĩa wĩkaga ũũru.
\b
\q1 
\v 3 Manooraga nĩmĩ ciao ta hiũ cia njora,
\q2 na makaaria ciugo njũru itariĩ ta mĩguĩ ĩrĩ ũrũrũ.
\q1 
\v 4 Mehithagĩra mũndũ ũtehĩtie makamũratha na mĩguĩ;
\q2 mamũrathaga o rĩmwe mategwĩtigĩra.
\b
\q1 
\v 5 Momanagĩrĩria magĩthugunda mĩbango mĩũru,
\q2 meranaga ũrĩa mekũhitha mĩtego yao;
\q2 mooragia atĩrĩ, “Nũũ ũngĩmĩona?”
\q1 
\v 6 Mathugundaga maũndũ matarĩ ma kĩhooto, makoiga atĩrĩ,
\q2 “Kaĩ nĩtũbangĩte mũbango mwagĩrĩru-ĩ!”
\q2 Ti-itherũ meciiria ma mũndũ na ngoro yake itingĩtuĩrĩka.
\b
\q1 
\v 7 No rĩrĩ, Ngai nĩekũmaratha na mĩguĩ yake,
\q2 amathece o rĩmwe.
\q1 
\v 8 Akaamarehithĩria mwanangĩko
\q2 nĩ ũndũ wa ciugo njũru iria maaragia na tũnua twao;
\q1 andũ arĩa othe makamoona makaamanyũrũria,
\q2 mamainainĩrie mĩtwe.
\b
\q1 
\v 9 Andũ othe nĩmagetigĩra;
\q2 nĩmakaheana ũhoro wa wĩra wa Ngai,
\q2 na meciirie ũhoro wa maũndũ marĩa ekĩte.
\q1 
\v 10 Andũ arĩa athingu nĩmagĩkenere Jehova
\q2 na moragĩre harĩ we;
\q2 andũ arĩa othe arũngĩrĩru ngoro nĩmamũgooce!
\c 65
\s1 Gũcookia Ngaatho nĩ ũndũ wa Irathimo
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai, twetereire gũkũgooca tũrĩ Zayuni;
\q2 nĩ harĩwe mĩĩhĩtwa iitũ ĩkaahingio.
\q1 
\v 2 Wee ũiguaga mahooya-rĩ,
\q2 andũ othe marĩũkaga harĩwe.
\q1 
\v 3 Rĩrĩa twahubanĩirio nĩ mehia,
\q2 Wee nĩwatũrekeire mahĩtia maitũ.
\q1 
\v 4 Kũrathimwo-rĩ, nĩ andũ arĩa ũthuurĩte,
\q2 na ũkamarehe hakuhĩ matũũrage kũu nja ciaku!
\q1 Ithuĩ tũrĩiganagĩra nĩ maũndũ mega ma nyũmba yaku,
\q2 o macio ma hekarũ yaku theru.
\b
\q1 
\v 5 Ũtũcookagĩria ũhoro na ciĩko cia magegania na cia kĩhooto,
\q2 Wee Ngai Mũhonokia witũ,
\q1 o Wee nĩwe mwĩhoko wa andũ arĩa marĩ ituri-inĩ ciothe cia thĩ,
\q2 na arĩa marĩ iria-inĩ kũndũ kũraya mũno,
\q1 
\v 6 o Wee wombire irĩma na hinya waku,
\q2 wĩohete ũhoti taarĩ mũcibi,
\q1 
\v 7 o Wee wahooreririe mũrurumo wa maria,
\q2 ũkĩhooreria mũrurumo wa ndiihũ ciamo,
\q2 na ũgĩkiria inegene rĩa ndũrĩrĩ.
\q1 
\v 8 Andũ arĩa matũũraga kũraya nĩmetigagĩra magegania maku;
\q2 ũtũmaga thĩ yothe ĩkene,
\q2 kuuma kũrĩa rũciinĩ rũrathaga nginya kũrĩa hwaĩ-inĩ ũthũaga.
\b
\q1 
\v 9 Wee nĩwe ũmenyagĩrĩra thĩ na ũkamiurĩria mbura;
\q2 ũtũmaga ĩgĩe na bũthi mũingĩ.
\q1 Rũũĩ rwa Ngai rũiyũrĩte maaĩ
\q2 ma gũkũrĩria andũ irio,
\q2 nĩgũkorwo ũguo nĩguo wathĩrĩirie gwĩkagwo.
\q1 
\v 10 Ũiyũragia mĩtaro yakuo maaĩ,
\q2 na ũkaaragania mĩkũmũkũmũ yakuo;
\q1 ũmĩororoagia na mbura ya rũthuthuũ,
\q2 na ũkarathima kĩmera kĩayo.
\q1 
\v 11 Mwaka ũwĩkĩrĩte thũmbĩ ya wega waku,
\q2 namo makaari maku makaiyũrĩrĩra bũthi mũingĩ.
\q1 
\v 12 Nyeki ya werũ nĩ nduru mũno,
\q2 natuo tũrĩma tũiyũrĩtwo nĩ gĩkeno.
\q1 
\v 13 Cieni ciyũrĩte ndũũru cia ngʼondu,
\q2 nacio ituamba ikaiyũra ngano;
\q2 indo ciothe iroigĩrĩria ikaina nĩ gũkena.
\c 66
\s1 Rwĩmbo rwa Kũgooca Ngai nĩ ũndũ wa Wega Wake
\d Rwĩmbo rwa Thaburi
\q1 
\v 1 Anĩrĩrai Ngai mũkenete mũrĩ mbere ya Jehova, inyuĩ andũ othe a thĩ!
\q2 
\v 2 Inai mũrahe riiri wa rĩĩtwa rĩake;
\q2 gũkumio gwake tũmai kũgĩe na riiri!
\q1 
\v 3 Ĩrai Ngai atĩrĩ, “Kaĩ ciĩko ciaku nĩ cia magegania-ĩ!
\q2 Ũhoti waku nĩ mũnene mũno nginya
\q2 ũgatũma thũ ciaku ciĩhetage nĩ guoya irĩ mbere yaku.
\q1 
\v 4 Andũ othe a thĩ nĩwe mainamagĩrĩra;
\q2 mainaga magakũgooca,
\q2 mainaga makagooca rĩĩtwa rĩaku.”
\b
\q1 
\v 5 Ũkai muone ũrĩa Ngai ekĩte,
\q2 maũndũ marĩa ekagĩra andũ matikĩrĩ ma kũmakania!
\q1 
\v 6 Aagarũrire iria rĩgĩtuĩka thĩ nyũmũ,
\q2 nao andũ makĩhĩtũkĩra kũu maaĩ-inĩ na magũrũ;
\q2 ũkai, tũmũkenere.
\q1 
\v 7 Nĩ ũndũ wa hinya wake, egũtũũra aathanaga nginya tene,
\q2 maitho make maikaraga marorete ndũrĩrĩ,
\q2 nĩguo andũ arĩa aremi matikagerie kũmũũkĩrĩra.
\b
\q1 
\v 8 Goocai Ngai witũ, inyuĩ andũ a ndũrĩrĩ,
\q2 mũgambo wake wa kũmũgooca nĩũiguĩke;
\q1 
\v 9 nĩatũtũũrĩtie muoyo na akagirĩrĩria magũrũ maitũ matirũke.
\q1 
\v 10 Nĩgũkorwo Wee Ngai nĩũtũgeretie;
\q2 ũtũtheragia ta ũrĩa betha ĩtheragio na mwaki.
\q1 
\v 11 Nĩwatũmire tũtwarwo njeera
\q2 na ũgĩtũkuuithia mĩrigo mĩritũ.
\q1 
\v 12 Warekire andũ matũikarĩre mĩtwe;
\q2 twagĩtuĩkanirie mwaki-inĩ o na maaĩ-inĩ,
\q2 no ũgĩcooka ũgĩtũrehe kũndũ kũrĩ bũthi.
\b
\q1 
\v 13 Nĩngũũka hekarũ-inĩ yaku ndĩ na maruta ma njino,
\q2 nĩguo hingie mĩĩhĩtwa yakwa harĩwe,
\q1 
\v 14 mĩĩhĩtwa ĩrĩa mĩromo yakwa yeranĩire, na ngĩmĩaria na kanua gakwa,
\q2 rĩrĩa ndaarĩ thĩĩna-inĩ.
\q1 
\v 15 Ngũkũrutĩra igongona rĩa nyamũ iria noru,
\q2 na ndute iruta rĩa ndũrũme;
\q2 ngũkũrutĩra igongona rĩa ndegwa na mbũri.
\b
\q1 
\v 16 Ũkai mũthikĩrĩrie inyuothe arĩa mwĩtigĩrĩte Ngai;
\q2 rekei ndĩmũhe ũhoro wa ũrĩa anjĩkĩire.
\q1 
\v 17 Ndamũkaĩire na kanua gakwa,
\q2 ngĩmũgooca na rũrĩmĩ rwakwa.
\q1 
\v 18 Korwo ndaarĩ na mehia ngoro-inĩ yakwa-rĩ,
\q2 Mwathani ndangĩanjiguire;
\q1 
\v 19 no ti-itherũ Ngai nĩathikĩrĩirie,
\q2 na akĩigua mũgambo wakwa ngĩmũhooya.
\q1 
\v 20 Ngai arogoocwo,
\q2 o we ũtaaregire kũigua ihooya rĩakwa,
\q2 o na kana akĩaga kũnyonia wendo wake!
\c 67
\s1 Rwĩmbo rwa Kũgooca Ngai
\d Rwĩmbo rwa Thaburi
\q1 
\v 1 Ngai arotũkinyĩria wega wake, na atũrathime,
\q2 na atũme ũthiũ wake ũtwarĩre,
\q1 
\v 2 nĩguo njĩra ciaku imenyeke gũkũ thĩ,
\q2 ũhonokio waku ũmenywo nĩ ndũrĩrĩ ciothe.
\b
\q1 
\v 3 Andũ marokũgooca, Wee Ngai;
\q2 andũ othe marogũkumia.
\q1 
\v 4 Ndũrĩrĩ nĩicanjamũke na cikũinĩre nĩ gũkena,
\q2 nĩgũkorwo wathaga andũ na kĩhooto,
\q2 na ũgatongoria ndũrĩrĩ iria irĩ gũkũ thĩ.
\q1 
\v 5 Andũ marokũgooca, Wee Ngai;
\q2 andũ othe marogũkumia.
\b
\q1 
\v 6 Hĩndĩ ĩyo bũrũri nĩũkaruta magetha maguo,
\q2 na Ngai, o we Ngai witũ, nĩagatũrathima.
\q1 
\v 7 Ngai nĩagatũrathima,
\q2 nacio ituri ciothe cia thĩ nĩikamwĩtigĩra.
\c 68
\s1 Rwĩmbo rwa Gũcookia Ngaatho
\d Thaburi ya Daudi
\q1 
\v 1 Ngai nĩakĩarahũke, ahurunje thũ ciake;
\q2 nao arĩa mamũthũire nĩmoore mehere mbere yake.
\q1 
\v 2 O ta ũrĩa ndogo yũmbũragwo nĩ rũhuho-rĩ,
\q2 ũromombũra;
\q1 o ta ũrĩa mũhũra ũringũkagio nĩ mwaki-rĩ,
\q2 andũ arĩa aaganu marothira marĩ mbere ya Ngai.
\q1 
\v 3 No rĩrĩ, arĩa athingu marocanjamũka
\q2 na makene marĩ mbere ya Ngai;
\q2 marorũũhia nĩ gũkena.
\b
\q1 
\v 4 Inĩrai Ngai, mũine mũgooce rĩĩtwa rĩake,
\q2 kumiai ũcio ũhaicaga matu ta mbarathi,
\q1 rĩĩtwa rĩake nĩ Jehova;
\q2 gĩcanjamũkei mũrĩ mbere yake.
\q1 
\v 5 Ngai ũrĩa ũikaraga gĩikaro gĩake gĩtheru-rĩ,
\q2 nĩwe ithe wa ciana cia ngoriai, na mũgitĩri wa atumia a ndigwa.
\q1 
\v 6 Ngai nĩatũmaga arĩa maikaraga marĩ oiki magĩe na mĩciĩ,
\q2 arĩa ohe amohorithagia na akamoimagaria;
\q2 no andũ arĩa aremi matũũraga bũrũri mũũmũ.
\b
\q1 
\v 7 Wee Ngai rĩrĩa woimagarire ũrĩ mbere ya andũ aku,
\q2 hĩndĩ ĩrĩa watuĩkanĩirie rũngʼũrĩ-inĩ-rĩ,
\q1 
\v 8 thĩ nĩyathingithire,
\q2 narĩo igũrũ rĩkiuria mbura,
\q1 nĩ ũndũ wa gũũka kwa Ngai, o Ũcio Ngai wa Sinai,
\q2 na nĩ ũndũ wa gũũka kwa Ngai, Ngai wa Isiraeli.
\q1 
\v 9 Wee Ngai-rĩ, nĩwoiririe mbura nyingĩ,
\q2 ũkĩnyootora bũrũri ũcio wa igai rĩaku ũrĩa wangʼarĩte.
\q1 
\v 10 Andũ aku magĩtũũra kuo,
\q2 na kuumana na ũingĩ wa indo ciaku, Wee Ngai-rĩ,
\q2 ũgĩtanahĩra athĩĩni acio.
\b
\q1 
\v 11 Mwathani nĩaheanire ũhoro,
\q2 nao arĩa maawanĩrĩire maarĩ gĩkundi kĩnene:
\q1 
\v 12 “Athamaki na mbũtũ cia ita moraga na ihenya;
\q2 nakuo kambĩ-inĩ andũ magayanaga indo cia ndaho.
\q1 
\v 13 O na rĩrĩa mũkomete hakuhĩ na mwaki wa gĩikaro kĩa nja,
\q2 mũhaana o ta mathagu ma ndutura magemetio na betha,
\q2 nacio njoya ciayo ikagemio na thahabu ĩkũhenia.”
\q1 
\v 14 Rĩrĩa Mwene-Hinya-Wothe aahurunjire athamaki bũrũri-inĩ-rĩ,
\q2 kwahaanaga o ta rĩrĩa tharunji ĩgwĩte kĩrĩma-inĩ gĩa Zalimoni.
\b
\q1 
\v 15 Ĩ irĩma cia Bashani ti irĩma irĩ riiri;
\q2 irĩma cia Bashani irĩ tũcũmbĩrĩ tũingĩ.
\q1 
\v 16 Inyuĩ irĩma ici irĩ tũcũmbĩrĩ tũingĩ-rĩ, mũrarora na ũiru nĩkĩ,
\q2 kĩrĩma kĩrĩa Ngai athuurĩte gĩtuĩke gĩikaro gĩake,
\q2 o kũrĩa Jehova we mwene egũtũũra nginya tene?
\q1 
\v 17 Ngaari cia Ngai cia ita nĩ makũmi ma ngiri,
\q2 na ngiri cia ngiri;
\q1 Mwathani nĩokĩte arĩ gatagatĩ ga cio oimĩte Kĩrĩma gĩa Sinai,
\q2 agatoonya handũ hake haamũre.
\q1 
\v 18 Rĩrĩa wambatire igũrũ,
\q2 nĩwatongoririe arĩa maatahĩtwo mũtongoro-inĩ waku;
\q2 nĩwamũkĩrire iheo kuuma kũrĩ andũ,
\q1 o na ũgĩciamũkĩra kuuma kũrĩ andũ arĩa aremi,
\q2 nĩgeetha Wee, Jehova Ngai, ũtũũre kuo.
\b
\q1 
\v 19 Goocai Mwathani, o we Mũrungu Mũhonokia witũ,
\q2 o we ũkuuaga mĩrigo iitũ mũthenya o mũthenya.
\q1 
\v 20 Ngai witũ nĩ Mũrungu ũhonokanagia;
\q2 Mwathani Jehova nĩwe rĩũrĩro rĩa kuuma gĩkuũ-inĩ.
\b
\q1 
\v 21 Ti-itherũ Ngai nĩakamemenda ciongo cia thũ ciake,
\q2 amemende ruototia rwa arĩa mathiiaga na mbere kwĩhia.
\q1 
\v 22 Mwathani ekuuga atĩrĩ, “Nĩngaruta thũ cianyu kuuma Bashani;
\q2 ndĩcirute iria-inĩ kũrĩa kũriku,
\q1 
\v 23 nĩgeetha mũtobokie makinya manyu thakame-inĩ ya thũ cianyu,
\q2 o nacio nĩmĩ cia ngui cianyu igĩe na igai rĩacio.”
\b
\q1 
\v 24 Wee Ngai-rĩ, mũtongoro waku nĩwonekete,
\q2 o mũtongoro wa Mũrungu wakwa na Mũthamaki
\q2 agĩtoonya handũ-harĩa-haamũre.
\q1 
\v 25 Aini a nyĩmbo nĩo matongoretie,
\q2 makarũmĩrĩrwo nĩ ahũũri inanda;
\q2 hamwe nao nĩ airĩtu arĩa marahũũra tũhembe.
\q1 
\v 26 Goocai Ngai, kĩũngano-inĩ kĩrĩa kĩnene;
\q2 mũgooce Jehova kĩũngano-inĩ gĩa Isiraeli.
\q1 
\v 27 Mũhĩrĩga ũrĩa mũnini wa Benjamini nĩguo ũcio ũmatongoretie,
\q2 kĩrĩndĩ kĩnene kĩa athamaki a Juda kĩrĩ ho,
\q2 na makarũmĩrĩrwo nĩ athamaki a Zebuluni na a Nafitali.
\b
\q1 
\v 28 Wee Ngai-rĩ, onania ũhoti waku;
\q2 tuonie hinya waku, Wee Ngai, ta ũrĩa waneka.
\q1 
\v 29 Tondũ wa hekarũ yaku ĩrĩa ĩrĩ kũu Jerusalemu-rĩ,
\q2 athamaki nĩmagakũrehagĩra iheo.
\b
\q1 
\v 30 Rũithia nyamũ ĩrĩa ĩrĩ ithanjĩ-inĩ,
\q2 ũkĩrũithie rũũru rwa ndegwa rũrĩa rũrĩ thĩinĩ wa tũcaũ twa ndũrĩrĩ.
\q1 Ĩkwĩnyiihĩrie, na ĩkũrehere icunjĩ cia betha.
\q2 Hurunja ndũrĩrĩ iria ikenagĩra mbaara.
\q1 
\v 31 Abarũthi nĩmagooka moimĩte bũrũri wa Misiri;
\q2 naguo bũrũri wa Kushi nĩũkenyiihĩria Ngai.
\b
\q1 
\v 32 Inĩrai Ngai, inyuĩ mothamaki ma thĩ,
\q2 inai mũgooce Mwathani,
\q1 
\v 33 ũcio ũthiiaga ahaicĩte matu macio ma igũrũ ma tene,
\q2 ũcio ũrurumaga na mũgambo mũnene.
\q1 
\v 34 Anĩrĩrai hinya wa Ngai,
\q2 we ũrĩa ũnene wake arĩ guo ũrũgamĩrĩire Isiraeli,
\q2 o ũcio ũhoti wake ũrĩ kũu matu-inĩ.
\q1 
\v 35 Wee Ngai-rĩ, ũrĩ wa gwĩtigĩrwo, ũrĩ handũ hau haku haamũre;
\q2 Mũrungu wa Isiraeli nĩaheaga andũ ake ũhoti o na hinya.
\b
\q1 Ngai arogoocwo!
\c 69
\s1 Ihooya rĩa kũũria Ũteithio
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai-rĩ, honokia,
\q2 nĩgũkorwo maaĩ maanginyĩte o ngingo.
\q1 
\v 2 Ndĩratoonyerera mũtondo-inĩ mũriku,
\q2 handũ hatarĩ na ha gũkinyithia kũgũrũ.
\q1 Nginyĩte maaĩ-inĩ harĩa hariku;
\q2 mũiyũro wa maaĩ nĩũhumbĩkanĩtie.
\q1 
\v 3 Nĩnogete mũno nĩ gũkaya ndeithio;
\q2 mũmero wakwa nĩ mũngʼaru.
\q1 Maitho makwa nĩmorĩtwo nĩ hinya
\q2 nĩgũcũthĩrĩria Ngai wakwa.
\q1 
\v 4 Andũ arĩa maathũire hatarĩ gĩtũmi
\q2 nĩ aingĩ gũkĩra njuĩrĩ cia mũtwe wakwa;
\q1 thũ ciakwa iria iithũire hatarĩ gĩtũmi nĩ nyingĩ,
\q2 o icio injaragia iniine.
\q1 Hatagĩrĩrio njookie kĩndũ itaiyĩte.
\b
\q1 
\v 5 Wee Ngai nĩũũĩ ũrimũ wakwa;
\q2 mahĩtia makwa matingĩhithĩka harĩwe.
\b
\q1 
\v 6 Andũ arĩa makwĩhokete,
\q2 maroaga gũconorithio nĩ ũndũ wakwa,
\q2 Wee Mwathani, Jehova Mwene-Hinya-wothe;
\q1 arĩa makũrongoragia
\q2 maroaga kũnyararwo nĩ ũndũ wakwa,
\q2 Wee Ngai wa Isiraeli.
\q1 
\v 7 Nĩgũkorwo nĩngirĩrĩirie kũmenwo nĩ ũndũ waku,
\q2 naguo ũthiũ wakwa nĩũhumbĩtwo thoni.
\q1 
\v 8 Nduĩkĩte ta mũgeni harĩ ariũ a baba,
\q2 ngatuĩka ta mũndũ wa kũngĩ harĩ ariũ a maitũ;
\q1 
\v 9 kĩyo kĩrĩa ndĩ nakĩo kĩa nyũmba yaku nĩkĩo kĩrandĩa,
\q2 irumi cia arĩa makũrumaga nĩ niĩ igũĩrĩire.
\q1 
\v 10 Rĩrĩa ngũrĩra na ngehinga kũrĩa irio,
\q2 no nginya ngirĩrĩrie kũnyũrũrio;
\q1 
\v 11 rĩrĩa ndehumba nguo ya ikũnia,
\q2 andũ no gũũthekerera.
\q1 
\v 12 Andũ arĩa maikaraga kĩhingo-inĩ gĩa itũũra nĩ niĩ manyũrũragia,
\q2 na nduĩkĩte rwĩmbo rwa arĩĩu.
\b
\q1 
\v 13 Wee Jehova, nĩndakũhooya
\q2 hĩndĩ ĩrĩa ya gwĩtĩkĩrĩka nĩwe;
\q1 Wee Ngai, nĩ ũndũ wa wendo waku mũnene,
\q2 ũnjĩtĩke na ũhonokio waku wa ma.
\q1 
\v 14 Honokia ũndute mũtondo-inĩ,
\q2 ndũkareke ndoonyerere;
\q1 ndeithũra kuuma kũrĩ arĩa maathũire,
\q2 ũndute kuuma maaĩ-inĩ marĩa mariku.
\q1 
\v 15 Ndũkareke mũiyũro wa maaĩ ũũhubĩkanie,
\q2 kana merio nĩ kũrĩa kũriku,
\q2 o na kana ndumĩrio kanua nĩ irima rĩa gĩkuũ.
\q1 
\v 16 Wee Jehova, njĩtĩka nĩ ũndũ wa wega wa wendo waku;
\q2 nĩ ũndũ wa tha ciaku nyingĩ wĩhũgũre ũnjookerere.
\q1 
\v 17 Ndũkahithe ndungata yaku ũthiũ waku;
\q2 njĩtĩka narua, nĩgũkorwo ndĩ thĩĩna-inĩ.
\q1 
\v 18 Ũka hakuhĩ ũndeithũre;
\q2 honokia kuuma kũrĩ thũ ciakwa.
\b
\q1 
\v 19 We nĩũũĩ ũrĩa nyũrũrĩtio, na ngaconorithio na ngahumbwo thoni;
\q2 thũ ciakwa ciothe irĩ mbere yaku.
\q1 
\v 20 Kũnyũrũrio nĩ gũũthuthĩte ngoro
\q2 ngatigwo itarĩ na mwĩhoko;
\q1 ndeetereire nyone wa kũnjiguĩra tha, no ndiigana kũmuona,
\q2 ngĩeterera nyone andũ a kũũhooreria, no ndiamonire.
\q1 
\v 21 Maanjĩkĩrĩire maaĩ ma nyongo irio-inĩ ciakwa,
\q2 na ndanyoota makĩĩhe thiki nyue.
\b
\q1 
\v 22 Metha ĩrĩa maarĩirwo ĩrotuĩka mũtego;
\q2 ĩrotuĩka ihũũra o na mũtego wa kũmagwatia.
\q1 
\v 23 Maitho mao marogĩa nduma matige gũcooka kuona,
\q2 nayo mĩgongo yao ĩrohocerera nginya tene.
\q1 
\v 24 Maitũrũrĩre mangʼũrĩ maku;
\q2 makinyĩrie marakara maku mahiũ.
\q1 
\v 25 Mĩciĩ yao ĩrokira ihooru;
\q2 kũroaga mũndũ wa gũtũũra hema-inĩ ciao.
\q1 
\v 26 Nĩgũkorwo manyariiraga arĩa wee ũgurarĩtie,
\q2 na makaaria ũhoro wa ruo rwa arĩa ũtiihĩtie.
\q1 
\v 27 Mathitangĩre o ngero thuutha wa ĩrĩa ĩngĩ;
\q2 ndũkanareke magatoonya ũhonokanio-inĩ waku.
\q1 
\v 28 Marothario ibuku-inĩ rĩa muoyo,
\q2 mage kwandĩkwo mũtaratara-inĩ wa andũ arĩa athingu.
\b
\q1 
\v 29 Ndĩ na ruo na ngathĩĩnĩka;
\q2 Wee Ngai kĩĩhonokie na ũngitĩre.
\b
\q1 
\v 30 Nĩngũgooca rĩĩtwa rĩa Ngai na rwĩmbo,
\q2 na ndĩmũtũũgĩrie ngĩmũcookagĩria ngaatho.
\q1 
\v 31 Naguo ũndũ ũcio nĩũgũgĩkenia Jehova gũkĩra kũmũhe ndegwa,
\q2 na gũkĩra ndegwa nene ĩrĩ na hĩa na mahũngũ.
\q1 
\v 32 Andũ arĩa athĩĩni mona ũguo nĩmagakena;
\q2 inyuĩ arĩa mũrongoragia Ngai, ngoro cianyu iroarahũka!
\q1 
\v 33 Jehova nĩathikagĩrĩria arĩa abatari,
\q2 na ndangĩnyarara andũ ake moohetwo.
\b
\q1 
\v 34 Igũrũ na thĩ nĩimũgooce,
\q2 o na maria marĩa manene na kĩrĩa gĩothe gĩthiiagĩra thĩinĩ wamo,
\q1 
\v 35 nĩgũkorwo Ngai nĩakahonokia Zayuni,
\q2 na aake matũũra marĩa manene ma Juda rĩngĩ.
\q1 Hĩndĩ ĩyo andũ nĩmagatũũra kuo na makwĩgwatĩre;
\q2 
\v 36 ciana cia ndungata ciake nĩigakũgaya,
\q2 nao arĩa mendete rĩĩtwa rĩake nĩmagatũũra kuo.
\c 70
\s1 Rwĩmbo rwa kũũria Ũteithio
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai, hiũha ũũhonokie;
\q2 Wee Jehova ũka narua ũndeithie.
\q1 
\v 2 Andũ arĩa mendaga kũnjũraga
\q2 maroconorithio na manyiitwo nĩ kĩrigiicano;
\q1 arĩa othe mendaga nyanangwo
\q2 marocooka na thuutha maconokete.
\q1 
\v 3 Andũ arĩa mathekagĩrĩra makiugaga atĩrĩ, “Haiya! Haiya!”
\q2 marocooka na thuutha maconokete.
\q1 
\v 4 No arĩa othe makũrongoragia
\q2 marokena na macanjamũke;
\q1 arĩa mendete ũhonokio waku marotũũra moigaga atĩrĩ,
\q2 “Ngai arotũgĩrio!”
\b
\q1 
\v 5 No rĩrĩ, niĩ ndĩ mũthĩĩni na mũbatari;
\q2 Wee Ngai, hiuha ũũke kũrĩ niĩ.
\q1 Wee nĩwe ũteithio wakwa na mũhonokia wakwa;
\q2 Wee Jehova, ndũkagonderere gũũka kũndeithia.
\c 71
\s1 Ihooya rĩa kũũria Ũgitĩri
\q1 
\v 1 Wee Jehova-rĩ, njũrĩire harĩwe;
\q2 ndũkanakĩreke njonorithio.
\q1 
\v 2 Ndeithũra na ũũhonokie nĩ ũndũ wa ũthingu waku;
\q2 thikĩrĩria ũũhonokie.
\q1 
\v 3 Tuĩka rwaro rwakwa rwa ihiga rwa kũũrĩra,
\q2 harĩa ingĩthiĩ hĩndĩ ciothe;
\q1 athana honokio,
\q2 nĩgũkorwo nĩwe rwaro rwakwa rwa ihiga na kĩirigo gĩakwa kĩa hinya.
\q1 
\v 4 Honokia, Wee Ngai wakwa, kuuma guoko-inĩ kwa andũ arĩa aaganu,
\q2 ũndeithũre kuuma ngumbaco ya andũ arĩa ooru na matarĩ tha.
\b
\q1 
\v 5 Nĩgũkorwo ũkoretwo ũrĩ kĩĩrĩgĩrĩro gĩakwa, Wee Mwathani Jehova,
\q2 ũtũũrĩte ũrĩ mwĩhoko wakwa kuuma ndĩ o mũnini.
\q1 
\v 6 Kuuma gũciarwo gwakwa ndũũrĩte ngwĩhokete;
\q2 nĩwe wandutire nda ya maitũ.
\q2 Ngũtũũra ngũgoocaga.
\q1 
\v 7 Nĩnduĩkĩte ta kĩndũ gĩa kũgegania harĩ andũ aingĩ,
\q2 no nĩwe rĩũrĩro rĩakwa rĩa hinya.
\q1 
\v 8 Kanua gakwa kaiyũrĩte ũgooci waku,
\q2 gatindaga gakĩgana riiri waku mũthenya wothe.
\b
\q1 
\v 9 Ndũkande hĩndĩ ya ũkũrũ;
\q2 ndũkanandiganĩrie rĩrĩa itarĩ na hinya.
\q1 
\v 10 Nĩgũkorwo thũ ciakwa ciaragia ũhoro wa kũnjũkĩrĩra;
\q2 acio metagĩrĩra kũnjũraga nĩmacokanĩtie ndundu.
\q1 
\v 11 Moigaga atĩrĩ, “Ngai nĩamũtiganĩirie;
\q2 hanyũkaniai nake mũmũnyiite,
\q2 nĩgũkorwo ndarĩ mũndũ wa kũmũteithũra.”
\q1 
\v 12 Wee Ngai, tiga kũndaihĩrĩria;
\q2 Wee Ngai wakwa, ũka narua ũndeithie.
\q1 
\v 13 Acio maathitangaga-rĩ, maroconoka na maniinwo;
\q2 acio mendaga kũnjĩka ũũru,
\q2 maronyararwo na maconorwo.
\b
\q1 
\v 14 No niĩ-rĩ, ndĩrĩkoragwo na kĩĩrĩgĩrĩro hĩndĩ ciothe;
\q2 ndĩrĩkĩragĩrĩria gũkũgooca mũno makĩria.
\q1 
\v 15 Kanua gakwa karĩganaga ũthingu waku,
\q2 ndindage o ngĩgana ũhonokio waku mũthenya wothe,
\q2 o na gũtuĩka ndiũĩ mũigana waguo.
\q1 
\v 16 Wee Mwathani Jehova, ngũũka ngĩanagĩrĩra ciĩko ciaku cia hinya,
\q2 nyanĩrĩre ũthingu waku, o ũthingu waku wiki.
\q1 
\v 17 Kuuma ndĩ o mũnini, Wee Ngai, ũtũũrĩte ũndutaga,
\q2 na nginyagia ũmũthĩ no nyumbũraga ciĩko ciaku cia magegania.
\q1 
\v 18 Wee Ngai, o na ndakũra ngĩe mbuĩ,
\q2 ndũkanandiganĩrie,
\q1 o nginya nyumbũre ũhoro wa ũhoti waku kũrĩ rũciaro rũrĩa rũrooka,
\q2 na nyumbũre ũhoro wa hinya waku kũrĩ arĩa othe magooka thuutha.
\b
\q1 
\v 19 Wee Ngai-rĩ, ũthingu waku ũkinyĩte o matu-inĩ,
\q2 Wee wĩkĩte maũndũ manene.
\q2 Wee Ngai-rĩ, nũũ ũngĩ ũhaana ta we?
\q1 
\v 20 O na gũtuĩka nĩũtũmĩte nyone mathĩĩna maingĩ na marũrũ-rĩ,
\q2 nĩũkariũkia muoyo wakwa rĩngĩ;
\q1 nĩũkandiũkia rĩngĩ
\q2 kuuma thĩ kũrĩa kũriku.
\q1 
\v 21 Nĩũkongerera gĩtĩĩo gĩakwa,
\q2 na ũũhoorerie o rĩngĩ.
\b
\q1 
\v 22 Ndĩrĩkũgoocaga na kĩnanda kĩa mũgeeto
\q2 nĩ ũndũ wa wĩhokeku waku, Wee Ngai wakwa;
\q1 ndĩrĩinaga ngũgoocage na kĩnanda gĩa kĩnũbi,
\q1 Wee Mũtheru wa Isiraeli.
\q1 
\v 23 Mĩromo yakwa nĩrĩanagĩrĩra nĩ gũkena
\q2 rĩrĩa ngũina ngũgooce,
\q2 o niĩ, ũrĩa Wee ũkũũrĩte.
\q1 
\v 24 Rũrĩmĩ rwakwa rũrĩrahaga ũhoro wa ciĩko ciaku cia ũthingu
\q2 mũthenya wothe,
\q1 nĩgũkorwo arĩa meendaga kũnjĩka ũũru
\q2 nĩmaconorithĩtio na makarigiicwo.
\c 72
\s1 Ihooya rĩa Kũhoera Mũthamaki
\d Thaburi ya Solomoni
\q1 
\v 1 Wee Ngai, he mũthamaki ũhoti wa gũtuuanagĩra ciira na kĩhooto,
\q2 na mũrũ wa mũthamaki ũkĩmũhe ũthingu waku.
\q1 
\v 2 Nake nĩarĩciiragĩra andũ aku na ũthingu,
\q2 andũ aku arĩa anyamaarĩku amatuagĩre ciira na kĩhooto.
\q1 
\v 3 Irĩma igaatũmaga andũ magaacĩre,
\q2 natuo tũrĩma tũciarage matunda ma ũthingu.
\q1 
\v 4 Nĩarĩgitagĩra andũ arĩa anyamaarĩku gatagatĩ ka andũ,
\q2 na ahonokie ciana cia arĩa abatari;
\q2 nĩakahehenja arĩa mamahinyagĩrĩria.
\b
\q1 
\v 5 Mũthamaki arotũũra hĩndĩ ĩrĩa yothe riũa rĩgũtũũra,
\q2 na rĩrĩa rĩothe mweri ũgũtũũra nginya njiarwa na njiarwa.
\q1 
\v 6 Arĩhaanaga ta mbura ĩkiurĩra mũgũnda mũtũgũte,
\q2 ahaane ta rũthuthuũ ũrĩa rũihũgagia thĩ.
\q1 
\v 7 Matukũ-inĩ make andũ arĩa athingu nĩmagatheerema;
\q2 naguo ũgaacĩru ũingĩhe o nginya rĩrĩa mweri ũgaakorwo ũtarĩ ho.
\b
\q1 
\v 8 Agaathanaga kuuma iria rĩmwe nginya rĩrĩa rĩngĩ,
\q2 na kuuma Rũũĩ rwa Farati\f + \fr 72:8 \ft Rũũĩ rwa Farati rwarĩ mwena wa irathĩro wa bũrũri wa Isiraeli hĩndĩ ya wathani wa Mũthamaki Solomoni.\f* o nginya ituri cia thĩ.
\q1 
\v 9 Ndũrĩrĩ cia werũ-inĩ nĩikainamĩrĩra mbere yake,
\q2 nacio thũ ciake icũne rũkũngũ.
\q1 
\v 10 Athamaki a Tarishishi\f + \fr 72:10 \ft Tarishishi kwoĩkaine taarĩ kuo kwarĩ mũthia wa thĩ.\f* na a mabũrũri marĩa marĩ hũgũrũrũ-inĩ cia kũraya
\q2 nĩmakamũrehagĩra igooti;
\q1 nao athamaki a Sheba na Seba
\q2 nĩmakamũrehagĩra iheo.
\q1 
\v 11 Athamaki othe makaamũinamĩrĩra,
\q2 nacio ndũrĩrĩ ciothe imũtungatagĩre.
\b
\q1 
\v 12 Nĩgũkorwo nĩakahonokia abatari maamũkaĩra,
\q2 o na arĩa anyamaarie matarĩ na wa kũmateithia.
\q1 
\v 13 Nĩakaiguagĩra tha arĩa matarĩ hinya na arĩa abatari,
\q2 na ahonokie arĩa athĩĩni kuuma kũrĩ gĩkuũ.
\q1 
\v 14 Nĩakamateithũra kuuma kũrĩ arĩa mamahinyagĩrĩria na kuuma haaro-inĩ,
\q2 nĩgũkorwo thakame yao ĩrĩ bata mũno maitho-inĩ make.
\b
\q1 
\v 15 Arogĩtũũra hĩndĩ ndaaya!
\q2 Aroheagwo thahabu ya kuuma Sheba.
\q1 Arotũũra ahooyagĩrwo nĩ andũ hĩndĩ ciothe,
\q2 na mamũrathimage mũthenya wothe.
\q1 
\v 16 Bũrũri ũrogĩa na bũthi wa ngano kũndũ guothe;
\q2 ĩrorirũkĩra tũrĩma-igũrũ.
\q1 Maciaro makuo marothegea ta ma Lebanoni;
\q2 nakuo matũũra-inĩ andũ marotheerema ta nyeki ya gĩthaka.
\q1 
\v 17 Rĩĩtwa rĩake rĩrotũũra nginya tene;
\q2 rĩrotũũra o ta ũrĩa riũa rĩgũtũũra.
\b
\q1 Ndũrĩrĩ ciothe nĩikarathimwo nĩ ũndũ wake,
\q2 nacio imwĩtage mũndũ mũrathime.
\b
\q1 
\v 18 Goocai Jehova Ngai, o we Ngai wa Isiraeli,
\q2 o we wiki wĩkaga maũndũ ma magegania.
\q1 
\v 19 Rĩĩtwa rĩake rĩu rĩrĩ riiri rĩrogoocagwo nginya tene;
\q2 nayo thĩ yothe ĩroiyũrwo nĩ riiri wake.
\qc Ameni, na ningĩ Ameni.
\m 
\v 20 Ũcio nĩguo mũthia wa mahooya ma Daudi, mũrũ wa Jesii.
\c 73
\ms1 Ibuku rĩa Gatatũ
\mr Thaburi 73–89
\s1 Ihooya rĩa kũũria Ũgitĩri
\d Thaburi ya Asafu
\q1 
\v 1 Ti-itherũ Ngai nĩ mwega harĩ andũ a Isiraeli,
\q2 harĩ andũ arĩa atheru ngoro.
\b
\q1 
\v 2 No niĩ-rĩ, magũrũ makwa maratigĩtie hanini matenderũke;
\q2 ndaarĩ o hakuhĩ kũgũa.
\q1 
\v 3 Nĩgũkorwo nĩndaiguagĩra arĩa etĩĩi ũiru,
\q2 rĩrĩa ndonire kũgaacĩra kwa andũ arĩa aaganu.
\b
\q1 
\v 4 Nĩgũkorwo matithĩĩnĩkaga;
\q2 mĩĩrĩ yao nĩ mĩgima na ĩkoragwo na hinya.
\q1 
\v 5 Matikoragwo na moritũ ta andũ arĩa angĩ,
\q2 na matikoragwo nĩ mathĩĩna marĩa makoraga andũ.
\q1 
\v 6 Nĩ ũndũ ũcio mwĩtĩĩo nĩguo mũgathĩ wao;
\q2 o ene mehumbaga ũhinya.
\q1 
\v 7 Ũmũ wa ngoro ciao ũtherũkaga o ũmaramari;
\q2 meciiria mao mooru matirĩ mũhaka.
\q1 
\v 8 Nĩ andũ a kĩnyũrũri, na maaragia ndeto cia rũmena;
\q2 maaragia na mwĩtĩĩo ũhoro wa kũhinyĩrĩria andũ arĩa angĩ.
\q1 
\v 9 Tũnua twao twaragia ũũru wa gũũkĩrĩra igũrũ,
\q2 nacio nĩmĩ ciao ikegwatĩra thĩ yothe.
\q1 
\v 10 Nĩ ũndũ ũcio andũ ao nĩmakamacokerera
\q2 na metĩkie ũrĩa wothe makoiga.
\q1 
\v 11 Makoiga atĩrĩ, “Mũrungu angĩmenya atĩa?
\q2 Ũrĩa-ũrĩ-Igũrũ-Mũno nĩarĩ na ũmenyo?”
\b
\q1 
\v 12 Ũũ nĩguo andũ arĩa aaganu matariĩ:
\q2 tondũ gũtirĩ ũndũ ũmamakagia, makĩragĩrĩria o gũtonga.
\b
\q1 
\v 13 Ti-itherũ, nĩnjigĩte ngoro yakwa ĩrĩ theru o tũhũ;
\q2 thambĩtie moko makwa makaaga gwĩka ũũru o tũhũ.
\q1 
\v 14 Nĩgũkorwo ndindaga na mĩnyamaro mũthenya wothe;
\q2 herithĩtio rũciinĩ o rũciinĩ.
\b
\q1 
\v 15 Ingĩoigire atĩrĩ, “Nĩngwaria o ũũ,”
\q2 nĩingĩakunyanĩire ciana ciaku.
\q1 
\v 16 No rĩrĩa ndageragia gũtaũkĩrwo nĩ ũhoro ũcio wothe,
\q2 watuĩkire wa kũũhinyĩrĩria,
\q1 
\v 17 o nginya rĩrĩa ndatoonyire handũ-harĩa-haamũre ha Mũrungu;
\q2 hĩndĩ ĩyo ngĩkĩmenya ũrĩa makaarĩkĩrĩria.
\b
\q1 
\v 18 Ti-itherũ ũmaigaga kũndũ kũrĩa gũtenderũ;
\q2 ũmagũithagia thĩ makaanangĩka.
\q1 
\v 19 Hĩ! Kaĩ nĩmakanangwo o rĩmwe-ĩ!
\q2 Makaaniinwo biũ nĩ imakania!
\q1 
\v 20 O ta ũrĩa kĩroto gĩthiraga mũndũ okĩra,
\q2 no taguo makahaana rĩrĩa Wee Mwathani ũkaarahũka,
\q2 ũkaamaagĩra bata o ta irooto.
\b
\q1 
\v 21 Rĩrĩa ngoro yakwa yarĩ na kĩeha
\q2 na roho wakwa ũgatuurwo,
\q1 
\v 22 ndiarĩ na meciiria magima, na ndiarĩ na ũmenyo;
\q2 ndahaanaga o ta nyamũ ndĩ mbere yaku.
\b
\q1 
\v 23 No rĩrĩ, ngoragwo nawe hĩndĩ ciothe;
\q2 nĩũũnyiitĩte guoko gwakwa kwa ũrĩo.
\q1 
\v 24 Nĩũndongoragia na ũtaaro waku,
\q2 na thuutha ũcio nĩũkanyamũkĩra riiri-inĩ waku.
\q1 
\v 25 Nũũ ũngĩ ndĩ nake kũu igũrũ tiga Wee?
\q2 Gũkũ thĩ ndirĩ na kĩndũ ĩngĩĩrirĩria tiga o Wee.
\q1 
\v 26 Mwĩrĩ wakwa na ngoro yakwa no ciage hinya,
\q2 no rĩrĩ, Ngai nĩwe hinya wa ngoro yakwa,
\q2 na nĩwe rwĩga rwakwa nginya tene.
\b
\q1 
\v 27 Ti-itherũ arĩa magũtiganagĩria nĩmagathira;
\q2 nĩũkanangaga arĩa othe matakwĩhokete.
\q1 
\v 28 No ha ũhoro wakwa-rĩ, nĩ wega gũkuhĩrĩria Ngai.
\q2 Nĩnduĩte Mwathani Jehova rĩũrĩro rĩakwa;
\q2 nĩndĩrĩheanaga ũhoro wa ciĩko ciaku ciothe.
\c 74
\s1 Gũthaithanĩrĩra Bũrũri Hĩndĩ ya Thĩĩna
\d Thaburi ya Asafu
\q1 
\v 1 Wee Ngai-rĩ, nĩ kĩĩ gĩtũmĩte ũtũtiganĩrie nginya tene?
\q2 Nĩ kĩĩ gĩtũmaga marakara maku macine ngʼondu cia rũũru rwaku?
\q1 
\v 2 Ririkana andũ arĩa wegũrĩire o tene,
\q2 arĩa wakũũrire magĩtuĩka mũhĩrĩga ũrĩa wegaĩire,
\q1 na ũririkane Kĩrĩma gĩa Zayuni, o kũrĩa watũũrĩte.
\q1 
\v 3 Erekeria makinya maku kũrĩ mwanangĩko ũyũ ũtũũrĩte kuo,
\q2 wone ũrĩa handũ harĩa haku haamũre hathũkangĩtio nĩ thũ.
\b
\q1 
\v 4 Amuku aku mararamĩire harĩa wacemanĩirie na ithuĩ;
\q2 maahaandire bendera ciao irĩ imenyithia.
\q1 
\v 5 Metuĩte ta andũ mekũhiũria mathanwa
\q2 mateme mĩtĩ ya mũtitũ.
\q1 
\v 6 Mbaũ iria ciothe ciagemetio magĩciunanga
\q2 na mathanwa na ibũi ciao.
\q1 
\v 7 Nĩmacinire handũ-haku-harĩa-haamũre hakĩmomoka,
\q2 magĩthaahia gĩikaro kĩa Rĩĩtwa rĩaku.
\q1 
\v 8 Moigire atĩrĩ na ngoro ciao, “Tũkũmahehenja mathire!”
\q2 Maacinire handũ harĩa hothe Mũrungu aahooyagĩrwo kũu bũrũri-inĩ.
\q1 
\v 9 Gũtirĩ ciama tũringagĩrwo mahinda maya;
\q2 anabii nĩmathirĩte,
\q2 na gũtirĩ witũ ũũĩ nĩ nginya rĩ gũgũikara ũguo.
\b
\q1 
\v 10 Wee Ngai, thũ ĩgũtũũra ĩgũthirĩkagia nginya rĩ?
\q2 Mũmuku no atũũre acambagia rĩĩtwa rĩaku nginya tene?
\q1 
\v 11 Nĩ kĩĩ gĩtũmĩte ũthune guoko gwaku, o guoko kũu gwaku kwa ũrĩo?
\q2 Kũrute mĩkũnjo-inĩ ya nguo ciaku ũmaniine!
\b
\q1 
\v 12 No rĩrĩ, Wee Ngai, nĩwe mũthamaki wakwa kuuma tene;
\q2 nĩwĩkaga maũndũ ma kũhonokania gũkũ thĩ.
\q1 
\v 13 Wee-rĩ, nĩwe wagayanirie iria na ũhoti waku,
\q2 ũkĩhehenja mĩtwe ya nyamũ iria nene kũu maaĩ-inĩ.
\q1 
\v 14 Wee-rĩ, nĩwe wahehenjire mĩtwe ya Leviathani,
\q2 ũkĩmĩheana ĩtuĩke irio cia ciũmbe cia werũ-inĩ.
\q1 
\v 15 Wee-rĩ, nĩwe watũmire ithima itherũke na tũrũũĩ tũtherere,
\q2 ũkĩhũithia njũũĩ iria itahũaga.
\q1 
\v 16 Mũthenya nĩ waku o na ũtukũ no waku;
\q2 Wee nĩwe wahaandire riũa na mweri.
\q1 
\v 17 Wee-rĩ, nĩwe wekĩrire mĩhaka yothe ya thĩ;
\q2 nĩwe watũmire kũgĩe hĩndĩ ya riũa na hĩndĩ ya heho.
\b
\q1 
\v 18 Ririkana ũrĩa thũ ĩkũnyũrũrĩtie, Wee Jehova,
\q2 na ũrĩa andũ arĩa akĩĩgu macambĩtie rĩĩtwa rĩaku.
\q1 
\v 19 Ndũkaneane muoyo wa ndirahũgĩ yaku kũrĩ nyamũ cia gĩthaka;
\q2 ndũkariganĩrwo nĩ mĩoyo ya andũ aku arĩa manyariirĩtwo nginya tene.
\q1 
\v 20 Ririkana kĩrĩkanĩro gĩaku,
\q2 tondũ kũndũ guothe kũrĩa kũrĩ nduma bũrũri-inĩ kũiyũrĩte haaro.
\q1 
\v 21 Ndũkareke mũndũ ũrĩa mũhinyĩrĩrie acooke na thuutha aconokete;
\q2 andũ arĩa athĩĩni na arĩa abatari nĩmagooce rĩĩtwa rĩaku.
\q1 
\v 22 Arahũka, Wee Ngai, ũrũgamĩrĩre kĩhooto gĩaku;
\q2 ririkana ũrĩa andũ arĩa akĩĩgu magũthirĩkagia mũthenya wothe.
\q1 
\v 23 Ndũkariganĩrwo nĩ mbugĩrĩrio ya amuku aku,
\q2 o inegene rĩa thũ ciaku, rĩrĩa iranegena itegũtigithĩria.
\c 75
\s1 Ngai nĩ wa Kĩhooto
\d Thaburi ya Asafu
\q1 
\v 1 Wee Ngai, nĩtwagũcookeria ngaatho,
\q2 twagũcookeria ngaatho, nĩgũkorwo Rĩĩtwa rĩaku rĩrĩ hakuhĩ;
\q2 andũ maheanaga ũhoro wa ciĩko ciaku cia magegania.
\b
\q1 
\v 2 Uugaga atĩrĩ, “Nĩ niĩ thuuraga hĩndĩ ĩrĩa njagĩrĩru;
\q2 nĩ niĩ nduanagĩra ciira na kĩhooto.
\q1 
\v 3 Rĩrĩa thĩ na andũ ayo othe maathingitha,
\q2 nĩ niĩ nyiitagĩrĩra itugĩ ciayo ngacirũmia.
\q1 
\v 4 Andũ arĩa etĩĩi ngũmeera atĩrĩ, ‘Mũtigacooke kwĩraha,’
\q2 na arĩa aaganu ngameera atĩrĩ, ‘Mũtikambararie hĩa cianyu.
\q1 
\v 5 Tigai kwambararia hĩa cianyu na igũrũ,
\q2 mũtige kwaria mũũmĩtie ngingo.’ ”
\b
\q1 
\v 6 Nĩ ũndũ-rĩ, ũhoro wa gũtũũgĩria mũndũ nduumaga na irathĩro kana ithũĩro,
\q2 o na kana kuuma werũ-inĩ.
\q1 
\v 7 No rĩrĩ, nĩ Ngai ũtuanagĩra ciira:
\q2 Anyiihagia mũndũ ũmwe, na agatũũgĩria ũrĩa ũngĩ.
\q1 
\v 8 Jehova anyiitĩte gĩkombe kĩiyũrĩte ndibei ĩrĩ na mũhũũyũ,
\q2 ĩtukanĩtio na mahuti manungi wega;
\q1 amĩonoragia, nao andũ othe aaganu a thĩ makamĩnyua,
\q2 makainĩkĩrĩra nginya itata rĩa mũthia.
\b
\q1 
\v 9 No niĩ-rĩ, nĩngumbũra ũhoro ũyũ nginya tene;
\q2 ndĩrĩinaga ũgooci kũrĩ Ngai wa Jakubu.
\q1 
\v 10 Nĩngarenga hĩa cia andũ arĩa othe aaganu,
\q2 no hĩa cia arĩa athingu nĩikambarario.
\c 76
\s1 Jehova Nĩwe Ngai wa Jakubu
\d Thaburi ya Asafu
\q1 
\v 1 Kũu Juda Ngai nĩoĩkaine;
\q2 rĩĩtwa rĩake nĩ inene thĩinĩ wa Isiraeli.
\q1 
\v 2 Hema yake ĩrĩ kũu Salemu,
\q2 gĩikaro gĩake kĩrĩ Zayuni.
\q1 
\v 3 Kũu nĩkuo oinangĩire mĩguĩ ya ũta ĩkũhenia,
\q2 akiunanga ngo na hiũ ciao cia njora,
\q2 o na indo ciao ciothe cia mbaara.
\b
\q1 
\v 4 Wee ũcangararĩte nĩ ũtheri,
\q2 ũkagĩa na ũkaru gũkĩra irĩma irĩ na ũtonga wa nyamũ cia iguĩma.
\q1 
\v 5 Andũ arĩa njamba magwĩte magatunywo indo,
\q2 magakoma toro wao wa gĩkuũ;
\q1 gũtirĩ o na ũmwe wa njamba cia ita
\q2 ũngĩambararia moko make.
\q1 
\v 6 Nĩ ũndũ wa ikũũma rĩaku, Wee Ngai wa Jakubu,
\q2 mbarathi o ũndũ ũmwe na ngaari cia ita igwĩte thĩ ikaaga kwĩigua.
\q1 
\v 7 Wee nowe wa gwĩtigĩrwo.
\q2 Nũũ ũngĩrũgama mbere yaku rĩrĩa ũrĩ mũrakaru?
\q1 
\v 8 Wamenyithanirie itua rĩaku ũrĩ o kũu igũrũ,
\q2 nayo thĩ ĩgĩĩtigĩra na ĩgĩkira ki,
\q1 
\v 9 rĩrĩa Wee Ngai, warũgamire ũtuanĩre ciira,
\q2 nĩguo ũhonokie arĩa othe anyamaarĩku a bũrũri.
\b
\q1 
\v 10 Ti-itherũ mangʼũrĩ ma andũ nĩmagakũgoocithia,
\q2 na ũkeyoha matigari ma mangʼũrĩ maku ta mũcibi.
\b
\q1 
\v 11 Mwĩhĩtei mĩĩhĩtwa harĩ Jehova Ngai wanyu na mũmĩhingie;
\q2 rekei mabũrũri marĩa mothe mũriganĩtie namo
\q2 marehere ũcio wa gwĩtigĩrwo iheo.
\q1 
\v 12 Athuthaga roho wa arĩa maathanaga;
\q2 etigagĩrwo nĩ athamaki a thĩ.
\c 77
\s1 Kũririkana Ciĩko cia Ngai cia Hinya
\d Thaburi ya Asafu
\q1 
\v 1 Ndakaĩire Ngai andeithie;
\q2 ndakaĩire Ngai nĩguo anjigue.
\q1 
\v 2 Rĩrĩa ndaarĩ mĩnyamaro-inĩ, nĩ Mwathani ndarongoririe;
\q2 ũtukũ ndamwambararĩirie moko itekũnoga,
\q2 no muoyo wakwa ũkĩrega kũhoorerio.
\b
\q1 
\v 3 Wee Ngai, ndakũririkanire ngĩcaaya;
\q2 ndataranirie maũndũ, naguo roho wakwa ũkĩringĩka.
\q1 
\v 4 Wee watũmire njũrwo nĩ toro,
\q2 ngĩthĩĩnĩka mũno, ngĩremwo nĩ kwaria.
\q1 
\v 5 Ndeciiririe ũhoro wa matukũ ma tene,
\q2 ngĩririkana mĩaka o ĩrĩa yarĩ ya tene;
\q1 
\v 6 ngĩkĩĩririkania ũrĩa ndainaga ũtukũ,
\q2 ngoro yakwa ĩgĩtarania maũndũ,
\q2 naguo roho wakwa ũkĩyũũria atĩrĩ:
\b
\q1 
\v 7 “Mwathani egũtũũra atũregete nginya tene?
\q2 Ndarĩ hĩndĩ agacooka gũtũkenera?
\q1 
\v 8 Wendo wake ũtathiraga-rĩ, nĩkũbuĩria ũbuĩrĩtie nginya tene?
\q2 Kĩĩranĩro gĩake gĩgũtũũra gĩtahingĩte nginya tene?
\q1 
\v 9 Kaĩ Mũrungu ariganĩirwo nĩkũiguanĩra tha?
\q2 Kaĩ marakara make matũmĩte atige gũtugana?”
\b
\q1 
\v 10 Ngĩcooka ngĩĩciiria atĩrĩ, “Ũndũ ũyũ nĩguo ngwĩtiiria naguo:
\q2 kũririkana mĩaka ya guoko kwa ũrĩo kwa Ũrĩa-ũrĩ-Igũrũ-Mũno.”
\q1 
\v 11 Nĩngũririkana ciĩko cia Jehova;
\q2 ĩĩ nĩguo, nĩngũririkana ciama ciaku cia tene.
\q1 
\v 12 Ndĩrĩtaranagia mawĩra maku mothe,
\q2 na ngecũũrania ũhoro wa ciĩko ciaku cia hinya.
\b
\q1 
\v 13 Njĩra ciaku, Wee Ngai, nĩ theru.
\q2 Nĩ ngai ĩrĩkũ nene ta Ngai witũ?
\q1 
\v 14 Wee nĩwe Mũrungu ũrĩa ũringaga ciama;
\q2 wonanagia ũhoti waku kũrĩ ndũrĩrĩ.
\q1 
\v 15 Nĩwakũũrire andũ aku na guoko gwaku kwa hinya,
\q2 o acio njiaro cia Jakubu na Jusufu.
\b
\q1 
\v 16 Maaĩ nĩmakuonire, Wee Ngai,
\q2 maaĩ macio maakuonire makĩigua guoya,
\q2 nakuo kũrĩa kũriku mũno gũkĩĩnyogonda.
\q1 
\v 17 Matu mooiririe mbura,
\q2 nacio ngwa ikĩruruma igũrũ guothe;
\q2 heni ciahenũkire ikĩrathũka mĩena yothe
\q1 
\v 18 Ngwa yaku yaiguĩkanire kĩhuhũkanio-inĩ,
\q2 rũheni rwaku rũkĩmũrĩka thĩ yothe,
\q2 nayo thĩ ĩkĩinaina na ĩgĩthingitha.
\q1 
\v 19 Njĩra yaku yatuĩkanĩirie iria-inĩ,
\q2 njĩra yaku ĩgĩtuĩkanĩria maaĩ-inĩ maingĩ,
\q2 o na gũtuĩka makinya maku mationekire.
\b
\q1 
\v 20 Watongoririe andũ aku o ta ũrĩa mũrĩithi atongoragia rũũru,
\q2 ũkĩmatongoria na guoko kwa Musa na kwa Harũni.
\c 78
\s1 Rũgano rwa Ngai na Andũ ake a Isiraeli
\d Thaburi ya Asafu
\q1 
\v 1 Inyuĩ andũ akwa, iguai ũrutani wakwa;
\q2 thikĩrĩriai ciugo cia kanua gakwa.
\q1 
\v 2 Ngũtumũra kanua gakwa njarie na ngerekano,
\q2 ngũgweta maũndũ mahithe, maũndũ ma kuuma o tene:
\q1 
\v 3 maũndũ marĩa twanaigua na tũkamenya,
\q2 o marĩa maithe maitũ maanatwĩra.
\q1 
\v 4 Tũtingĩhitha ciana ciao maũndũ macio;
\q2 nĩtũrĩĩraga rũciaro rũrĩa rũgooka
\q1 ũhoro wa ciĩko cia Jehova cia kũmũgoocithia,
\q2 na ũhoti wake, na magegania marĩa aaneka.
\q1 
\v 5 Aaheire Jakubu mawatho,
\q2 na akĩhaanda watho thĩinĩ wa Isiraeli,
\q1 ũrĩa aathire maithe maitũ
\q2 atĩ maũrutage ciana ciao,
\q1 
\v 6 nĩguo rũciaro rũrĩa rũgooka thuutha rũkaamenya watho ũcio,
\q2 o hamwe na ciana iria itaciarĩtwo,
\q2 nĩguo nacio ikeera ciana ciacio.
\q1 
\v 7 Hĩndĩ ĩyo ciĩhoke Ngai
\q2 na ciage kũriganĩrwo nĩ ciĩko ciake,
\q2 no kũrũmia irũmagie maathani make.
\q1 
\v 8 Nacio itikahaane ta maithe macio ma tene,
\q2 arĩa maarĩ a rũciaro rũremi na rũngʼathia,
\q1 rũrĩa ngoro ciaruo itaathĩkagĩra Mũrungu,
\q2 o rũu maroho maaruo mataamwĩhokire.
\b
\q1 
\v 9 Andũ a Efiraimu, o na maarĩ na mota ma kũrũa,
\q2 nĩmahũndũkire mũthenya ũrĩa wa mbaara;
\q1 
\v 10 matiarũmirie kĩrĩkanĩro kĩao na Ngai,
\q2 na nĩmaregire kũrũmĩrĩra watho wake.
\q1 
\v 11 Nĩmariganĩirwo nĩ maũndũ marĩa ekĩte,
\q2 na makĩriganĩrwo nĩ magegania marĩa aamonetie.
\q1 
\v 12 Nĩaringire ciama maithe mao makĩĩonagĩra
\q2 marĩ kũu bũrũri wa Misiri, kũu werũ-inĩ wa Zoani.
\q1 
\v 13 Aagayanirie iria, akĩmaringia;
\q2 aatũmire maaĩ marũgame ta rũthingo.
\q1 
\v 14 Mũthenya aamatongoragia na itu,
\q2 naguo ũtukũ wothe akamatongoria na ũtheri wa mwaki.
\q1 
\v 15 Nĩatũranirie mahiga kũu werũ-inĩ,
\q2 na akĩmahe maaĩ maingĩ o ta ma iria;
\q1 
\v 16 nĩatũmire tũrũũĩ tuume rwaro-inĩ rwa ihiga,
\q2 na agĩtũma maaĩ matherere ta njũũĩ.
\b
\q1 
\v 17 No-o maathiire o na mbere kwĩhĩria Ngai,
\q2 magĩkĩremera Ũrĩa-ũrĩ-Igũrũ-Mũno marĩ kũu werũ-inĩ.
\q1 
\v 18 Nao makĩgeria Mũrungu makĩendaga,
\q2 na ũndũ wa gwĩtia irio iria meeriragĩria kũrĩa.
\q1 
\v 19 Magĩũkĩrĩra Ngai na mĩario, makĩũrania atĩrĩ,
\q2 “Mũrungu no ahote kwara metha werũ-inĩ?
\q1 
\v 20 Rĩrĩa aagũthire ihiga, maaĩ nĩmatothokire boo,
\q2 natuo tũrũũĩ tũgĩtherera tũiyũrĩte maaĩ maingĩ.
\q1 No rĩrĩ, no ahote gũtũhe o na irio?
\q2 No ahe andũ ake nyama?”
\q1 
\v 21 Rĩrĩa Jehova aiguire ũguo, akĩrakara;
\q2 agĩtharĩkĩra Jakubu na mwaki wake,
\q2 namo mangʼũrĩ make magĩũkĩrĩra Isiraeli,
\q1 
\v 22 nĩgũkorwo matiigana gwĩtĩkia Ngai,
\q2 kana kwĩhoka ũhonokania wake.
\q1 
\v 23 No rĩrĩ, we nĩathire matu ma igũrũ
\q2 na akĩhingũra mĩrango ya igũrũ;
\q1 
\v 24 oirĩirie andũ mana ta mbura marĩe,
\q2 na akĩmahe ngano ya kũu igũrũ.
\q1 
\v 25 Andũ makĩrĩa irio cia araika;
\q2 akĩmahe irio iria ciothe mangĩahotire kũrĩa.
\q1 
\v 26 O na ningĩ akĩerekeria rũhuho rwa mwena wa irathĩro kuuma igũrũ,
\q2 na akĩrehithia rũhuho rwa mwena wa gũthini na ũndũ wa hinya wake.
\q1 
\v 27 Akĩmaharũrũkĩria nyama nyingĩ ta rũkũngũ,
\q2 nyoni cia rĩera-inĩ ciaingĩhĩte ta mũthanga wa iria-inĩ.
\q1 
\v 28 Agĩtũma igwe thĩinĩ wa kambĩ yao,
\q2 igĩthiũrũrũkĩria hema ciao.
\q1 
\v 29 Maarĩire o nginya makĩhũũna,
\q2 nĩgũkorwo aamaheire kĩrĩa merirĩirie kũrĩa.
\q1 
\v 30 No matanarĩkia kũrĩa irio icio meriragĩria,
\q2 o irĩ tũnua-inĩ twao-rĩ,
\q1 
\v 31 marakara ma Ngai makĩmokĩrĩra;
\q2 akĩũraga arĩa maarĩ na hinya mũno gatagatĩ kao,
\q2 akĩniina andũ ethĩ a Isiraeli.
\b
\q1 
\v 32 O na amekĩte ũguo wothe-rĩ, mathiire o na mbere kwĩhia;
\q2 o na ekĩte magegania make, matiamwĩtĩkirie.
\q1 
\v 33 Nĩ ũndũ ũcio agĩtũma matukũ mao mathire o ũguo tũhũ,
\q2 na mĩaka yao ĩgĩthira nĩ ihooru rĩa kũmaka.
\q1 
\v 34 Rĩrĩa rĩothe Mũrungu ooraga amwe ao nĩmamũmaathaga;
\q2 mamũrongoragia na makamũcookerera na kĩyo.
\q1 
\v 35 Nao makaririkana atĩ Ngai nĩwe warĩ Rwaro rwao rwa Ihiga,
\q2 na atĩ Mũrungu Ũrĩa-ũrĩ-Igũrũ-Mũno nĩwe warĩ Mũkũũri wao.
\q1 
\v 36 No-o makeyendithĩrĩria harĩ we na tũnua twao,
\q2 makamũheenagia na nĩmĩ ciao;
\q1 
\v 37 ngoro ciao itiarĩ njĩhokeku kũrĩ we,
\q2 na matiarĩ eehokeku harĩ kĩrĩkanĩro gĩake.
\q1 
\v 38 Nowe no aaiyũrĩtwo nĩ tha;
\q2 akĩmarekera waganu wao,
\q2 na ndaigana kũmaniina.
\q1 Kaingĩ na kaingĩ nĩagiragĩrĩria marakara make,
\q2 na ndaigana kwarahũra mangʼũrĩ make mothe.
\q1 
\v 39 Nĩaaririkanire atĩ maarĩ o andũ tu,
\q2 karũhuho karĩa kahĩtũkaga na gaticooke rĩngĩ.
\b
\q1 
\v 40 Nĩ maita maingĩ atĩa maamũremagĩra marĩ kũu werũ-inĩ,
\q2 na makamũiguithia kĩeha marĩ kũu rũngʼũrĩ-inĩ.
\q1 
\v 41 Mahinda maingĩ nĩmageririe Mũrungu;
\q2 maathirĩkirie Ũrĩa-Mũtheru-wa-Isiraeli.
\q1 
\v 42 Matiaririkanire ũhoti wake:
\q2 mũthenya ũrĩa aamakũũrire kuuma kũrĩ arĩa maamahinyagĩrĩria,
\q1 
\v 43 kana mũthenya ũrĩa onanirie ciama ciake kũu bũrũri wa Misiri,
\q2 kana magegania make marĩa onanirie kũu werũ-inĩ wa Zoani.
\q1 
\v 44 Nĩagarũrire njũũĩ cia bũrũri wa Misiri igĩtuĩka thakame;
\q2 matingĩahotire kũnyua maaĩ ma tũrũũĩ twao.
\q1 
\v 45 Akĩmatũmĩra mĩrumbĩ mĩingĩ ya ngi ikĩmarĩa,
\q2 o na ciũra iria ciamaanangire.
\q1 
\v 46 Irio cia mĩgũnda yao aaciheire itono,
\q2 na maciaro mao akĩmarekereria ngigĩ.
\q1 
\v 47 Aanangire mĩthabibũ yao na mbura ya mbembe,
\q2 na mĩkũyũ yao akĩmĩcina na mbaa.
\q1 
\v 48 Ngʼombe ciao aaciũragire na mbura ya mbembe,
\q2 na mahiũ mao akĩmahũũra na ngwa.
\q1 
\v 49 Aamaitĩrĩirie marakara make mahiũ,
\q2 na mangʼũrĩ, na marũrũ, na muku:
\q2 akĩmarekereria mbũtũ ya araika arĩa maniinanaga.
\q1 
\v 50 Nĩaatemeire marakara make njĩra;
\q2 ndamahonokirie kũrĩ gĩkuũ,
\q2 no nĩamarekereirie kũrĩ mũthiro.
\q1 
\v 51 Akĩũraga marigithathi mothe ma bũrũri wa Misiri,
\q2 arĩ mo maciaro ma mbere ma mũndũ thĩinĩ wa hema cia Hamu.
\q1 
\v 52 No akĩruta andũ ake kuo ta rũũru;
\q2 akĩmatongoria o ta ũrĩa mũrĩithi atongoragia ngʼondu magĩtuĩkanĩria kũu werũ-inĩ.
\q1 
\v 53 Aamatongoririe amamenyereire, nĩ ũndũ ũcio matietigĩrire;
\q2 no thũ ciao ikĩhubĩkanio nĩ iria.
\q1 
\v 54 Nĩ ũndũ ũcio akĩmakinyia mũhaka-inĩ wa bũrũri wake ũcio mũtheru,
\q2 akĩmakinyia bũrũri wa irĩma ũrĩa guoko gwake kwa ũrĩo kwegwatĩire.
\q1 
\v 55 Ningĩ akĩrutũrũra ndũrĩrĩ ciehere mbere yao,
\q2 na akĩmagaĩra bũrũri ũcio wa ndũrĩrĩ ũtuĩke igai rĩao;
\q2 akĩhe mĩhĩrĩga ya Isiraeli mĩciĩ yao.
\b
\q1 
\v 56 No nĩmageririe Ngai
\q2 na makĩremera Ũrĩa-ũrĩ-Igũrũ-Mũno;
\q2 matiathikĩrĩirie mawatho make.
\q1 
\v 57 Nĩmagire wĩhokeku na makĩaga wĩtĩkio o ta maithe mao,
\q2 makĩaga kwĩhokeka o ta ũta mũgathũku ũrĩa ũtangĩĩhokwo.
\q1 
\v 58 Nĩmamũrakaririe nĩ ũndũ wa gũkorwo na kũndũ kwao gũtũũgĩru gwa kũhooyagĩra;
\q2 makĩarahũra ũiru wake nĩ ũndũ wa mĩhianano yao.
\q1 
\v 59 Rĩrĩa Ngai aamaiguire, nĩarakarire mũno;
\q2 nake agĩtiganĩria Isiraeli o biũ.
\q1 
\v 60 Agĩthaama Hema-ya-Gũtũnganwo ĩrĩa yarĩ Shilo,\f + \fr 78:60 \ft Matukũ-inĩ ma tene mũno, Shilo nĩrĩo rĩarĩ itũũra itheru, na ithandũkũ rĩa kĩrĩkanĩro rĩaigĩtwo kuo.\f*
\q2 hema ĩrĩa aahaandĩte atũũranagie na andũ.
\q1 
\v 61 Akĩrekereria ithandũkũ rĩa kĩrĩkanĩro rĩrĩa rĩa hinya wake rĩthaamio,
\q2 riiri ũcio wake akĩũneana moko-inĩ ma thũ.
\q1 
\v 62 Andũ ake nao akĩmarekereria rũhiũ rwa njora;
\q2 nĩarakarĩtio mũno nĩ igai rĩake.
\q1 
\v 63 Mwaki ũgĩcina aanake ao,
\q2 nao airĩtu ao makĩaga kũinagĩrwo nyĩmbo cia ũhiki;
\q1 
\v 64 athĩnjĩri-Ngai ao makĩũragwo na rũhiũ rwa njora,
\q2 na atumia ao a ndigwa makĩaga kũmacakaĩra.
\b
\q1 
\v 65 Ningĩ Mwathani akĩarahũka ta mũndũ woima toro,
\q2 ta njamba ya ita ĩgĩũkĩra thuutha wa kũrĩĩo nĩ ndibei.
\q1 
\v 66 Aahũũrire thũ ciake agĩcihũndũra;
\q2 aaciconorithirie nginya tene.
\q1 
\v 67 Ningĩ akĩrega hema cia Jusufu,
\q2 na ndathuurire mũhĩrĩga wa Efiraimu;
\q1 
\v 68 no rĩrĩ, nĩathuurire mũhĩrĩga wa Juda,
\q2 na Kĩrĩma gĩa Zayuni kĩrĩa endete.
\q1 
\v 69 Nĩaakire handũ harĩa hake haamũre hakĩhaana ta irĩma iria ndaaya,
\q2 hakĩhaana ta thĩ ĩrĩa aahaandire ĩtũũre ĩrũmĩte nginya tene.
\q1 
\v 70 Aathuurire Daudi ndungata yake
\q2 na akĩmũruta ciugũ-inĩ cia ngʼondu;
\q1 
\v 71 akĩmũtigithia kũrĩithia ngʼondu,
\q2 akĩmutua mũrĩithi wa andũ ake, nĩo mbarĩ ya Jakubu,
\q2 arĩithagie Isiraeli igai rĩake.
\q1 
\v 72 Nake Daudi akĩmarĩithia arĩ na wagĩrĩru wa ngoro;
\q2 aamatongoragia na ũũgĩ wa moko make.
\c 79
\s1 Ihooya rĩa kũũria Ngai Ahonokie Rũrĩrĩ
\d Thaburi ya Asafu
\q1 
\v 1 Wee Ngai, ndũrĩrĩ nĩitharĩkĩire igai rĩaku;
\q2 nĩithaahĩtie hekarũ yaku theru,
\q2 imomorete itũũra rĩa Jerusalemu rĩgatuĩka irũndo cia mahiga.
\q1 
\v 2 Ciimba cia ndungata ciaku macineanĩte
\q2 ituĩke irio cia nyoni cia rĩera-inĩ,
\q2 na mĩĩrĩ ya andũ aku aamũre makamĩheana kũrĩ nyamũ cia gĩthaka.
\q1 
\v 3 Maitĩte thakame ya andũ aku ta maaĩ
\q2 Jerusalemu guothe,
\q2 na gũtirĩ mũndũ wa gũthika arĩa makuĩte.
\q1 
\v 4 Tũtuĩkĩte andũ a kũmenwo nĩ arĩa tũriganĩtie nao,
\q2 tũgatuĩka andũ a kũnyararwo na gũthekererwo nĩ arĩa matũthiũrũrũkĩirie.
\b
\q1 
\v 5 Wee Jehova-rĩ, nĩ nginya rĩ? Ũgũtũũra ũrĩ mũrakaru nginya tene?
\q2 Nĩ nginya rĩ ũiru waku ũgũtũũra wakanĩte ta mwaki?
\q1 
\v 6 Itĩrĩria ndũrĩrĩ iria itakũũĩ mangʼũrĩ maku,
\q2 ũmaitĩrĩrie mothamaki marĩa matakayagĩra rĩĩtwa rĩaku;
\q1 
\v 7 nĩgũkorwo nĩmatambuurĩte Jakubu
\q2 na makaananga bũrũri wake.
\q1 
\v 8 Ndũgatũherithie nĩ ũndũ wa mehia ma maithe maitũ;
\q2 tha ciaku irohiũha itũkinyĩrĩre,
\q2 nĩgũkorwo tũrĩ ahinyĩrĩrĩku mũno.
\b
\q1 
\v 9 Tũteithie, Wee Ngai Mũhonokia witũ;
\q2 nĩ ũndũ wa riiri wa rĩĩtwa rĩaku;
\q1 tũteithũre na ũtũrekere mehia maitũ
\q2 nĩ ũndũ wa rĩĩtwa rĩaku.
\q1 
\v 10 Nĩ kĩĩ gĩgũtũma ndũrĩrĩ ciũrie atĩrĩ,
\q2 “Ngai wao akĩrĩ ha?”
\q1 Menyithania kũrĩ ndũrĩrĩ tũkĩĩonagĩra na maitho maitũ
\q2 atĩ nĩũrĩhanagĩria thakame ya ndungata ciaku ĩrĩa ĩitĩtwo.
\q1 
\v 11 Mũcaayo wa arĩa moohetwo njeera ũrogũkinyĩra;
\q2 nĩ ũndũ wa hinya wa guoko gwaku
\q2 gitĩra arĩa matuĩrĩirwo gũkua.
\b
\q1 
\v 12 Wĩrĩhĩrie maita mũgwanja harĩ ndũrĩrĩ iria tũriganĩtie nacio,
\q2 nĩ ũndũ wa rũmena rũrĩa makũmenete naruo, Wee Mwathani.
\q1 
\v 13 Na ithuĩ andũ aku, o ithuĩ ngʼondu cia rũũru rwaku,
\q2 tũkũgoocage nginya tene na tene;
\q1 nĩtũrahage ũgooci waku,
\q2 kuuma njiarwa na njiarwa.
\c 80
\s1 Kũhoera Rũrĩrĩ Rũgaacĩre Rĩngĩ
\d Thaburi ya Asafu
\q1 
\v 1 Wee Mũrĩithi wa Isiraeli, tũigue,
\q2 o Wee ũtongoragia Jusufu ta ũrĩa mũrĩithi atongoragia rũũru;
\q1 Wee ũikarĩire gĩtĩ kĩa ũnene gatagatĩ ka makerubi-rĩ, cangarara
\q2 
\v 2 ũrĩ mbere ya Efiraimu, na Benjamini, na Manase.\f + \fr 80:2 \ft Mĩhĩrĩga ĩno ĩtatũ yarĩ njiarwa cia Rakeli, na nĩcio ciarĩ cia mbere kũrũmĩrĩra ithandũkũ rĩa kĩrĩkanĩro rĩrĩa Isiraeli mangĩoimagarire marĩ werũ-inĩ.\f*
\q1 Arahũra ũhoti waku,
\q2 ũũke ũtũhonokie.
\b
\q1 
\v 3 Wee Ngai-rĩ, tũma tũgaacĩre rĩngĩ;
\q2 tũma ũthiũ waku ũtwarĩre,
\q2 nĩguo tũhonoke.
\b
\q1 
\v 4 Wee Jehova Ngai mwene hinya wothe,
\q2 marakara maku megũtooga nginya rĩ
\q2 ũgĩũkĩrĩra mahooya ma andũ aku?
\q1 
\v 5 Nĩũmahũũnĩtie na irio cia maithori;
\q2 ũtũmĩte manyue maithori maiyũrĩte mbakũri riita.
\q1 
\v 6 Ũtũtuĩte kĩndũ gĩa kũrũagĩrwo nĩ arĩa tũriganĩtie nao,
\q2 nacio thũ ciitũ igatũnyũrũria.
\b
\q1 
\v 7 Wee Ngai-Mwene-Hinya-Wothe-rĩ, tũma tũgaacĩre rĩngĩ;
\q2 tũma ũthiũ waku ũtwarĩre,
\q2 nĩguo tũhonoke.
\b
\q1 
\v 8 Wareehire mũthabibũ kuuma bũrũri wa Misiri;
\q2 warutũrũrire ndũrĩrĩ ũkĩũhaanda arĩ guo.
\q1 
\v 9 Nĩwaũthereirie mũgũnda,
\q2 naguo ũkĩgwata, na ũkĩiyũra bũrũri wothe.
\q1 
\v 10 Irĩma nĩciahumbĩrirwo nĩ kĩĩruru kĩaguo,
\q2 nayo mĩtarakwa ĩrĩa mĩnene ĩkĩhumbĩrwo nĩ honge ciaguo.
\q1 
\v 11 Watambũrũkirie honge ciaguo o nginya Iria-inĩ rĩrĩa Inene,
\q2 na thuuna ciaguo ũgĩcikinyia o nginya Rũũĩ-inĩ rwa Farati.\f + \fr 80:11 \ft Ũthamaki wa Daudi na Solomoni woimĩte Iria rĩrĩa Inene nginya Rũũĩ rwa Farati.\f*
\b
\q1 
\v 12 Nĩ kĩĩ gĩtũmĩte ũmomore njirigo ciaguo,
\q2 ũgagĩtũma ehĩtũkĩri othe matuage thabibũ ciaguo?
\q1 
\v 13 Ũrangarangagwo nĩ ngũrwe cia gĩthaka,
\q2 na ũkarĩĩo nĩ nyamũ cia werũ-inĩ.
\q1 
\v 14 Wee Ngai Mwene-Hinya-Wothe, tũcookerere!
\q2 Rora ũrĩ igũrũ wone!
\q1 Rũmbũiya mũthabibũ ũyũ,
\q2 
\v 15 mũri ũrĩa guoko gwaku kwa ũrĩo kwahaandire,
\q2 mũriũ ũrĩa wee mwene wĩrereire.
\b
\q1 
\v 16 Mũthabibũ waku nĩũtemetwo, ũgacinwo na mwaki;
\q2 thũ ciaku irothira nĩ ũndũ wa irũithia rĩaku.
\q1 
\v 17 Guoko gwaku kũroikara na mũndũ ũrĩa ũrĩ guoko-inĩ gwaku kwa ũrĩo,
\q2 ũcio mũrũ wa mũndũ wĩrereire wee mwene.
\q1 
\v 18 No ithuĩ-rĩ, tũtigatigana nawe o rĩ;
\q2 tũrurumũkie na nĩtũrĩkayagĩra rĩĩtwa rĩaku.
\b
\q1 
\v 19 Wee Jehova Ngai Mwene-Hinya-Wothe, tũma tũgaacĩre rĩngĩ;
\q2 tũma ũthiũ waku ũtwarĩre,
\q2 nĩguo tũhonoke.
\c 81
\s1 Rwĩmbo rwa Gũkũngũĩra Gĩathĩ
\d Thaburi ya Asafu
\q1 
\v 1 Inĩrai Ngai, o we hinya witũ, nĩ ũndũ wa gũkena;
\q2 anĩrĩrai mũinĩre Ngai wa Jakubu!
\q1 
\v 2 Ambĩrĩriai kũina, hũũrai kĩhembe,
\q2 na mũhũũre kĩnanda kĩa mũgeeto kĩrĩa kĩgambi wega, o na gĩa kĩnũbi.
\b
\q1 
\v 3 Huhai coro hĩndĩ ya Karũgamo ka Mweri,
\q2 na ningĩ rĩrĩa mweri waiganana, mũthenya ũrĩa wa Gĩathĩ giitũ;
\q1 
\v 4 ũyũ nĩ watho wa kĩrĩra gĩa kũrũmĩrĩrwo kũrĩ Isiraeli,
\q2 o guo watho wa Ngai wa Jakubu.
\q1 
\v 5 We nĩaũhaandire ũtuĩke kĩrĩra harĩ Jusufu
\q2 hĩndĩ ĩrĩa aathiire gũtharĩkĩra bũrũri wa Misiri,
\q2 kũrĩa twaiguire mwario tũtaamenyire.
\b
\q1 
\v 6 Ekuuga atĩrĩ, “Nĩndeheririe mũrigo kuuma ciande-inĩ ciao;
\q2 moko mao nĩndameheririe kuuma thĩinĩ wa gĩkabũ.
\q1 
\v 7 Wangaĩire ũrĩ na mĩnyamaro na niĩ ngĩkũhatũra,
\q2 ngĩgwĩtĩka ndĩ thĩinĩ wa mũrurumo wa ngwa;
\q2 ndakũgeririe ũrĩ kũu maaĩ-inĩ ma Meriba.
\b
\q1 
\v 8 “Inyuĩ andũ akwa, iguai ngĩmũkaania,
\q2 naarĩ korwo no mũũthikĩrĩrie, inyuĩ Isiraeli!
\q1 
\v 9 Mũtikanagĩe na ngai ngʼeni gatagatĩ-inĩ kanyu;
\q2 mũtikanainamĩrĩre ngai ya kũngĩ.
\q1 
\v 10 Nĩ niĩ Jehova Ngai waku,
\q2 ũrĩa wakũrutire bũrũri wa Misiri.
\q2 Athamia kanua gaku na nĩngũkũhe gĩa kũrĩa.
\b
\q1 
\v 11 “No andũ akwa matiigana gũũthikĩrĩria;
\q2 Isiraeli ndaigana kũnjathĩkĩra.
\q1 
\v 12 Nĩ ũndũ ũcio ngĩmarekereria marũmĩrĩre ũremi wa ngoro ciao,
\q2 na marũmagĩrĩre mwĩĩro wao ene.
\b
\q1 
\v 13 “Korwo andũ akwa no maathikĩrĩrie,
\q2 korwo Isiraeli no marũmĩrĩre njĩra ciakwa,
\q1 
\v 14 ndamatooreria thũ ciao o na ihenya,
\q2 na njũkĩrĩre andũ arĩa marĩ muku nao na ũndũ wa guoko gwakwa!
\q1 
\v 15 Andũ arĩa mathũire Jehova mangĩĩthuna marĩ mbere yake,
\q2 na iherithia rĩao rĩtũũre nginya tene.
\q1 
\v 16 No inyuĩ ingĩmũhe ngano ĩrĩa njega mũno mũrĩĩage;
\q2 ingĩmũhũũnagia na ũũkĩ wa kuuma rwaro-inĩ rwa ihiga.”
\c 82
\s1 Kũhooya Ciira wa Kĩhooto
\d Thaburi ya Asafu
\q1 
\v 1 Ngai arũgamĩte kĩũngano-inĩ kĩrĩa kĩnene;
\q2 aratuĩra “ngai” ciira arĩ gatagatĩ ga cio.
\b
\q1 
\v 2 “Nĩ nginya rĩ mũgũtũũra mũciiragĩrĩra andũ arĩa matarũgamagĩrĩra kĩhooto,
\q2 na mũgatĩĩra arĩa aaganu maũthĩ?
\b
\q1 
\v 3 “Ciiragĩrĩrai kĩhooto kĩa arĩa matarĩ hinya na arĩa matarĩ maithe;
\q2 tũũriai ihooto cia andũ arĩa athĩĩni o na arĩa ahinyĩrĩrie.
\q1 
\v 4 Hatũragai arĩa matarĩ hinya na arĩa abatari;
\q2 mateithũrei kuuma moko-inĩ ma arĩa aaganu.
\b
\q1 
\v 5 “Andũ acio matirĩ ũndũ mooĩ, na matirĩ ũndũ makũũranaga.
\q2 Macangacangaga nduma-inĩ;
\q2 mĩthingi yothe ya thĩ nĩyenyenyete.
\b
\q1 
\v 6 “Ndoigire atĩrĩ, ‘Inyuĩ mũrĩ “ngai”;
\q2 inyuothe mũrĩ ariũ a Ũrĩa-ũrĩ-Igũrũ-Mũno.’
\q1 
\v 7 No mũgaakua o ta ũrĩa andũ makuuaga;
\q2 mũkaagũa o ta aathani arĩa angĩ.”
\b
\q1 
\v 8 Arahũka, Wee Ngai, ũtuĩre thĩ ciira,
\q2 nĩgũkorwo ndũrĩrĩ ciothe nĩ igai rĩaku.
\c 83
\s1 Kũhooya Ngai ahoote Thũ cia Isiraeli
\d Thaburi ya Asafu
\q1 
\v 1 Wee Ngai-rĩ, ndũgakire;
\q2 tiga gũikara ũtumĩtie, Wee Mũrungu,
\q2 ndũgaikare wĩnyiitanĩirie.
\q1 
\v 2 Ta rora wone ũrĩa thũ ciaku iranegena,
\q2 acio magũthũire makambararia mĩtwe yao.
\q1 
\v 3 Mathugundaga ndundu ya gũũkĩrĩra andũ aku na wara;
\q2 maciiragĩrĩra gũũkĩrĩra andũ arĩa wendete.
\q1 
\v 4 Meranaga atĩrĩ, “Ũkai, tũmaniine matige gũtuĩka rũrĩrĩ,
\q2 nĩguo rĩĩtwa rĩa Isiraeli rĩtikanacooke kũririkanwo rĩngĩ.”
\b
\q1 
\v 5 Maciiraga marĩ na ngoro ĩmwe;
\q2 maiguithanagĩria magũũkĩrĩre:
\q1 
\v 6 andũ a hema cia Edomu, na cia Aishumaeli,
\q2 na cia Moabi, na cia Ahagari,
\q1 
\v 7 na cia Gebali, na cia Amoni, na cia Amaleki,
\q2 na cia Filistia, hamwe na andũ a Turo.
\q1 
\v 8 O na Ashuri nĩmegwatanĩtie nao
\q2 nĩguo mateithĩrĩrie njiaro cia Loti.
\b
\q1 
\v 9 Meeke o ta ũrĩa wekire Amidiani,
\q2 na o ta ũrĩa wekire Sisera na Jabini rũũĩ-inĩ rwa Kishoni,
\q1 
\v 10 o acio maaniinĩirwo Enidoru,
\q2 na magĩtuĩka ta thumu wa kũnoria tĩĩri.
\q1 
\v 11 Tũma andũ ao arĩa marĩ igweta mahaane ta Orebu na Zeebu,\f + \fr 83:11 \ft Orebu na Zeebu maarĩ athamaki a Midiani, na maahootirwo ni Gideoni.\f*
\q2 anene ao othe ũmahaananie na Zeba na Zalimuna,
\q1 
\v 12 arĩa moigire atĩrĩ, “Nĩtwĩgwatĩrei bũrũri
\q2 wa ũrĩithio wa Ngai ũtuĩke witũ.”
\b
\q1 
\v 13 Wee Ngai wakwa, matue ta rũkũngũ rũrĩa rũgũrũkagio,
\q2 mahaane o ta mũũngũ ũmbũrĩtwo nĩ rũhuho.
\q1 
\v 14 O ta ũrĩa mwaki ũcinaga mũtitũ
\q2 kana ta rũrĩrĩmbĩ rũgĩcina irĩma-rĩ,
\q1 
\v 15 maingatithie o ro ũguo na kĩhuhũkanio gĩaku,
\q2 na ũmamakie mũno na huho ciaku nene.
\q1 
\v 16 Humba mothiũ mao thoni,
\q2 nĩgeetha andũ marongorie rĩĩtwa rĩaku, Wee Jehova.
\b
\q1 
\v 17 Marotũũra maconokete na marĩ amaku;
\q2 marokua na gĩconoko kĩnene.
\q1 
\v 18 Tũma mamenye atĩ Wee, o Wee wĩtagwo Jehova,
\q2 atĩ Wee nĩwe Ũrĩa-ũrĩ-Igũrũ-Mũno, o igũrũ rĩa thĩ yothe.
\c 84
\s1 Kwĩrirĩria Gũthiĩ Nyũmba ya Ngai
\d Thaburi ya Ariũ a Kora
\q1 
\v 1 Wee Jehova Mwene-Hinya-Wothe-rĩ,
\q2 kaĩ gĩikaro gĩaku nĩ gĩthaka-ĩ!
\q1 
\v 2 Muoyo wakwa wĩriragĩria mũno, ĩĩ o na ũkoorwo nĩ hinya,
\q2 nĩ ũndũ wa kwĩrirĩria nja cia Jehova;
\q1 ngoro yakwa na mwĩrĩ wakwa irakaĩra
\q2 Mũrungu ũrĩa ũtũũraga muoyo.
\b
\q1 
\v 3 O na kanyoni-ka-nja nĩkoonete mũciĩ,
\q2 nayo thũngũrũrũ ĩkeyonera gĩtara,
\q2 harĩa ĩngĩikaria tũcui twayo,
\q1 o hau hakuhĩ na kĩgongona gĩaku,
\q2 Wee Jehova Mwene-Hinya-Wothe,
\q2 o Wee Mũthamaki wakwa na Ngai wakwa.
\q1 
\v 4 Kũrathimwo-rĩ, nĩ andũ arĩa matũũraga nyũmba yaku;
\q2 matũũraga makũgoocaga.
\b
\q1 
\v 5 Kũrathimwo-rĩ, nĩ andũ arĩa maheagwo hinya nĩwe,
\q2 o arĩa matuĩte na ngoro ciao gũthiĩ Zayuni.
\q1 
\v 6 Rĩrĩa megũtuĩkanĩria Gĩtuamba kĩa Baka,
\q2 matũmaga kũgĩe na ithima;
\q2 mbura ya maguna-ngʼombe o nayo ĩkũhumbĩraga na tũria twa maaĩ.
\q1 
\v 7 Mathiiaga magĩkĩragĩrĩria kũgĩa na hinya,
\q2 nginya o mũndũ o mũndũ agakinya mbere ya Ngai kũu Zayuni.
\b
\q1 
\v 8 Igua ihooya rĩakwa, Wee Jehova Ngai-Mwene-Hinya-Wothe;
\q2 thikĩrĩria, Wee Ngai wa Jakubu.
\q1 
\v 9 Wee Ngai, ta rora ngo iitũ;
\q2 tiirĩra ũrĩa waku ũitĩrĩirie maguta gĩthiithi.
\b
\q1 
\v 10 Kaba mũthenya ũmwe nja-inĩ ciaku,
\q2 gũkĩra gũikara mĩthenya ngiri handũ hangĩ o hothe;
\q1 kaba ngorwo ndĩ mũrangĩri wa kĩhingo kĩa nyũmba ya Ngai wakwa,
\q2 gũkĩra ndũũre thĩinĩ wa hema cia andũ arĩa aaganu.
\q1 
\v 11 Nĩgũkorwo Jehova Ngai nĩ riũa na ngo;
\q2 Jehova nĩarĩtũtugaga na agatwĩka maũndũ mega;
\q1 arĩa mĩthiĩre yao ĩtarĩ ũcuuke
\q2 ndarĩ ũndũ mwega angĩmaima.
\b
\q1 
\v 12 Wee Jehova Mwene-Hinya-Wothe,
\q2 kũrathimwo nĩ mũndũ ũrĩa ũkwĩhokaga.
\c 85
\s1 Ihooya rĩa kũũria Ũtugi wa Ngai
\d Thaburi ya Ariũ a Kora
\q1 
\v 1 Wee Jehova, nĩ wekire bũrũri waku wega;
\q2 nĩwacookeirie Jakubu ũtonga wake.
\q1 
\v 2 Nĩwarekeire andũ aku waganu wao,
\q2 na ũkĩhumbĩra mehia mao mothe.
\q1 
\v 3 Nĩweheririe mangʼũrĩ maku mothe,
\q2 na ũgĩthirwo nĩ marakara maku mahiũ.
\b
\q1 
\v 4 Tũma tũgaacĩre rĩngĩ, Wee Ngai Mũhonokia witũ,
\q2 na ũtige gũikara ũtũrakarĩire.
\q1 
\v 5 Ũgũtũũra ũtũrakarĩire nginya tene?
\q2 Marakara maku megũkinyĩra njiarwa na njiarwa?
\q1 
\v 6 Kaĩ ũtangĩtũrurumũkia ngoro ciitũ,
\q2 nĩguo andũ aku magũkenere?
\q1 
\v 7 Wee Jehova-rĩ, tuonie wendo waku ũrĩa ũtathiraga,
\q2 na ũtũhe ũhonokio waku.
\b
\q1 
\v 8 Nĩngũthikĩrĩria njigue ũrĩa Mũrungu, o we Jehova, ekuuga;
\q2 eranagĩra thayũ kũrĩ andũ ake, o acio ake aamũre:
\q2 no ndũkareke macookerere ũrimũ wao.
\q1 
\v 9 Ti-itherũ ũhonokio wake ũrĩ hakuhĩ na arĩa mamwĩtigĩrĩte,
\q2 nĩgeetha riiri wake ũtũũre bũrũri-inĩ witũ.
\b
\q1 
\v 10 Wendo na wĩhokeku nĩicemanĩtie;
\q2 ũthingu na thayũ nĩikĩmumunyanĩte.
\q1 
\v 11 Wĩhokeku ũkunũkaga kuuma na thĩ,
\q2 naguo ũthingu ũcũthagĩrĩrie ũrĩ o igũrũ.
\q1 
\v 12 Ti-itherũ Jehova no aheane kĩndũ o gĩothe kĩega,
\q2 naguo bũrũri witũ ũciarage magetha maguo.
\q1 
\v 13 Ũthingu nĩguo ũmũthiiaga mbere,
\q2 ũkahaaragĩria makinya make njĩra.
\c 86
\s1 Ihooya rĩa Ũteithio wa gũtooria Thũ
\d Ihooya rĩa Daudi
\q1 
\v 1 Wee Jehova, njigua na ũnjĩtĩke,
\q2 nĩgũkorwo ndĩ mũthĩĩni na mũbatari.
\q1 
\v 2 Gitĩra muoyo wakwa,
\q2 nĩgũkorwo nĩndĩheanĩte harĩwe.
\q1 Wee nĩwe Ngai wakwa;
\q2 honokia ndungata yaku ĩno ĩkwĩhokete.
\q1 
\v 3 Njiguĩra tha, Wee Mwathani,
\q2 nĩgũkorwo ngũkayagĩra mũthenya wothe.
\q1 
\v 4 He ndungata yaku gĩkeno,
\q2 nĩgũkorwo nĩ kũrĩ we, Wee Mwathani,
\q2 ndorereirie ngoro yakwa.
\b
\q1 
\v 5 Nĩgũkorwo Wee Mwathani ũrĩ mwega na nĩũrekanagĩra,
\q2 ũkaingĩhia wendo kũrĩ arĩa othe magũkayagĩra.
\q1 
\v 6 Igua ihooya rĩakwa, Wee Jehova;
\q2 thikĩrĩria ikaya rĩakwa ũnjiguĩre tha.
\q1 
\v 7 Mũthenya ũrĩa ngaakorwo na thĩĩna nĩngagũkaĩra,
\q2 nĩgũkorwo nĩũkanjĩtĩka.
\b
\q1 
\v 8 Wee Mwathani, thĩinĩ wa ngai ciothe gũtirĩ ĩngĩ tawe;
\q2 gũtirĩ ciĩko ingĩhaananio na ciaku.
\q1 
\v 9 Ndũrĩrĩ ciothe iria ũmbĩte
\q2 nĩigooka igũthathaiye irĩ mbere yaku, Wee Mwathani;
\q2 nĩikarehera rĩĩtwa rĩaku riiri.
\q1 
\v 10 Nĩgũkorwo Wee ũrĩ mũnene, na nĩwĩkaga ciĩko cia kũgegania;
\q2 Wee wiki nowe Ngai.
\b
\q1 
\v 11 Wee Jehova, nyonagĩrĩria njĩra ciaku,
\q2 nĩgeetha thiiage na mĩthiĩre ya ma;
\q1 he ngoro ĩĩrutĩire kũna,
\q2 nĩguo ndĩĩtigagĩre rĩĩtwa rĩaku.
\q1 
\v 12 Nĩndĩrĩkũgoocaga na ngoro yakwa yothe,
\q2 Wee Mwathani Ngai wakwa;
\q2 ngũtũũra ngumagia rĩĩtwa rĩaku nginya tene.
\q1 
\v 13 Nĩgũkorwo wendo waku nĩ mũnene harĩ niĩ;
\q2 nĩũndeithũrĩte kuuma mbĩrĩra-inĩ o kũrĩa kũriku mũno.
\b
\q1 
\v 14 Wee Ngai, andũ arĩa etĩĩi nĩmaraatharĩkĩra;
\q2 gĩkundi kĩa andũ matarĩ tha nĩmaracaria muoyo wakwa,
\q2 o andũ acio matakũrũmbũyagia.
\q1 
\v 15 No Wee, Wee Mwathani, ũrĩ Mũrungu mũigua tha na ũrĩ mũtugi,
\q2 ndũhiũhaga kũrakara, na ũiyũrĩtwo nĩ wendo na wĩhokeku.
\q1 
\v 16 Wĩhũgũre ũndore na ũnjiguĩre tha;
\q2 he ndungata ĩno yaku hinya waku,
\q2 na ũhonokie mũriũ wa ndungata yaku ya mũndũ-wa-nja.
\q1 
\v 17 Nyonia kĩmenyithia kĩa wega waku,
\q2 nĩguo thũ ciakwa ikĩone iconorithio,
\q2 nĩgũkorwo Wee, Wee Jehova, nĩũndeithĩtie na ũkaahooreria.
\c 87
\s1 Gĩkeno gĩa Gũtũũra Zayuni
\d Thaburi ya Ariũ a Kora
\q1 
\v 1 Nĩahaandĩte mũthingi wa itũũra rĩake igũrũ rĩa kĩrĩma kĩrĩa kĩamũre;
\q2 
\v 2 Jehova nĩendete ihingo cia Zayuni
\q2 gũkĩra ciikaro iria ingĩ ciothe cia Jakubu.
\q1 
\v 3 Maũndũ mega nĩmaragio igũrũ rĩaku,
\q2 wee itũũra inene rĩa Ngai:
\q1 
\v 4 “Nĩngwandĩka ũhoro wa Rahabu na wa Babuloni
\q2 thĩinĩ wa arĩa manjũũĩ,
\q1 Filistia o nakuo, na Turo, hamwe na Kushi,
\q2 njuge atĩrĩ, ‘Ũyũ aaciarĩirwo Zayuni.’ ”
\b
\q1 
\v 5 Ti-itherũ, ũhoro wa Zayuni ũkĩario nĩgũkagwetagwo atĩrĩ,
\q2 “Ũyũ o na ũũrĩa maaciarĩirwo kuo,
\q2 na Ũrĩa-ũrĩ-Igũrũ-Mũno we mwene nĩagatũma gũtũũre kũrĩ kũrũmu.”
\q1 
\v 6 Jehova nĩakandĩka ibuku-inĩ rĩa kĩrĩndĩ ũũ:
\q2 “Ũyũ aaciarĩirwo Zayuni.”
\q1 
\v 7 Nao magĩtunga nyĩmbo makaina atĩrĩ,
\q2 “Ithima ciakwa ciothe irĩ thĩinĩ waku.”
\c 88
\s1 Ihooya rĩa kũũria Ũteithio Hĩndĩ ya Kũhinyĩrĩrĩka
\d Thaburi ya Ariũ a Kora
\q1 
\v 1 Wee Jehova, o Wee Ngai ũrĩa ũũhonokagia,
\q2 ngũkayagĩra mũthenya na ũtukũ ndĩ mbere yaku.
\q1 
\v 2 Ihooya rĩakwa rĩrokinya harĩwe;
\q2 inamĩrĩria gũtũ gwaku ũigue gũkaya gwakwa.
\b
\q1 
\v 3 Nĩgũkorwo muoyo wakwa ũiyũrĩtwo nĩ thĩĩna,
\q2 na niĩ ngirie gũkua.
\q1 
\v 4 Niĩ ndaranĩirio na arĩa makiriĩ gũkua;
\q2 haana ta mũndũ ũtarĩ na hinya.
\q1 
\v 5 Niĩ njiganĩirio na arĩa akuũ,
\q2 o ta arĩa moragĩtwo magakoma mbĩrĩra,
\q1 o acio ũtacookaga kũririkana,
\q2 arĩa meheretio kuuma ũmenyereri-inĩ waku.
\b
\q1 
\v 6 Ũnjikĩtie irima rĩrĩa iriku mũno,
\q2 o kũu kũriku kũrĩ nduma ndumanu.
\q1 
\v 7 Mangʼũrĩ maku nĩmanditũhĩire mũno;
\q2 nĩũũhubĩkanĩtie na ndiihũ ciaku ciothe.
\q1 
\v 8 Nĩũnjehereirie arata akwa arĩa twendanĩte mũno,
\q2 na ũgatũma nduĩke kĩndũ kĩrĩ magigi harĩo.
\q1 Ndĩĩmũhingĩrĩrie ndingĩhota kũũra;
\q2 
\v 9 maitho makwa nĩmaroora nĩ kĩeha.
\b
\q1 Wee Jehova, ngũkayagĩra o mũthenya;
\q2 ngũtambũrũkagĩria moko makwa.
\q1 
\v 10 Andũ arĩa akuũ-rĩ, wee nĩũmonagia magegania maku?
\q2 Acio makuĩte-rĩ, nĩmarahũkaga, magakũgooca?
\q1 
\v 11 Wendo waku nĩumbũragwo mbĩrĩra-inĩ,
\q2 kana wĩhokeku waku ũgakiumbũrwo Mwanangĩko-inĩ?\f + \fr 88:11 \ft Nĩ Abadoni na Kĩhibirania\f*
\q1 
\v 12 Magegania maku nĩmonagwo kũndũ kũu kwa nduma,
\q2 kana ciĩko ciaku cia ũthingu ikamenyeka
\q2 bũrũri-inĩ ũcio wa kĩriganĩro?
\b
\q1 
\v 13 No nĩngũgũkaĩra ũndeithie, Wee Jehova;
\q2 rũciinĩ mahooya makwa mokaga harĩwe.
\q1 
\v 14 Wee Jehova, nĩ kĩĩ gĩtũmĩte ũndiganĩrie
\q2 na ũkaahitha ũthiũ waku?
\b
\q1 
\v 15 Kuuma o ũnini wakwa ndũũrĩte nyamarĩtio na ngakuhĩrĩria gĩkuũ;
\q2 nĩnyamaarĩkĩte nĩ imakania ciaku, igatũma njage mwĩhoko.
\q1 
\v 16 Mangʼũrĩ maku nĩmahubĩkanĩtie,
\q2 nacio imakania ciaku ikanyananga.
\q1 
\v 17 Maathiũrũrũkagĩria mũthenya wothe ta mũiyũro wa maaĩ;
\q2 hingĩrĩirio nĩmo na mĩena yothe.
\q1 
\v 18 Nĩũnjehereirie athiritũ akwa na arĩa nyendete;
\q2 nduma nĩyo mũrata wakwa ũrĩa ũnguhĩrĩirie mũno.
\c 89
\s1 Kĩrĩkanĩro kĩa Ngai na Daudi
\d Thaburi ya Ethani wa mbarĩ ya Ezara
\q1 
\v 1 Ngũtũũra nyinaga ũhoro wa wendo mũnene wa Jehova nginya tene;
\q2 ndĩrĩmenyithanagia wĩhokeku waku na kanua gakwa kũrĩ njiarwa na njiarwa.
\q1 
\v 2 Nĩngumbũra atĩ wendo waku ũtũũraga ũrĩ mũrũmu nginya tene,
\q2 nyumbũre atĩ wĩhokeku waku nĩũũhaandĩte o kũu igũrũ.
\b
\q1 
\v 3 Woigire atĩrĩ, “Nĩngĩte kĩrĩkanĩro na ũrĩa niĩ ndĩthuurĩire,
\q2 na ngeehĩta na mwĩhĩtwa harĩ Daudi ndungata yakwa ngamwĩra atĩrĩ,
\q1 
\v 4 ‘Nĩngatũma rũciaro rwaku rũtũũre rwĩhaandĩte nginya tene,
\q2 na ndũme gĩtĩ gĩaku kĩa ũnene gĩtũũre kĩrĩ kĩrũmu njiarwa na njiarwa.’ ”
\b
\q1 
\v 5 Wee Jehova-rĩ, igũrũ nĩrĩkumagia magegania maku,
\q2 na rĩkagaathĩrĩria wĩhokeku waku o naguo, kĩũngano-inĩ kĩa acio atheru.
\q1 
\v 6 Nĩ ũndũ-rĩ, kũu matu-inĩ igũrũ nũũ ũngĩgerekanio na Jehova?
\q2 Nũũ ũkĩhaana ta Jehova harĩ ciũmbe iria irĩ igũrũ?
\q1 
\v 7 Kĩama-inĩ kĩa acio atheru, Mũrungu nĩetigĩrĩtwo mũno;
\q2 nĩ wa gwĩtigĩrwo gũkĩra arĩa othe mamũrigiicĩirie.
\q1 
\v 8 Wee Jehova Ngai Mwene-Hinya-Wothe, nũũ ũkĩhaana tawe?
\q2 Wee Jehova, nĩ ũrĩ hinya, na wĩhokeku waku ũtũũraga ũkũrigiicĩirie.
\b
\q1 
\v 9 Nĩwe wathaga kĩhuhũkanio kĩa iria rĩrĩa inene;
\q2 rĩrĩa makũmbĩ marĩo mookĩra na igũrũ, nĩũmahooreragia.
\q1 
\v 10 Wahehenjire Rahabu agĩtuĩka o ta ũmwe wa arĩa moragĩtwo;
\q2 wahurunjire thũ ciaku na guoko gwaku kũrĩ hinya.
\q1 
\v 11 Igũrũ nĩ rĩaku, o na thĩ no yaku;
\q2 Wee nĩwe wombire thĩ na kĩrĩa gĩothe kĩrĩ thĩinĩ wayo.
\q1 
\v 12 Nĩwe wombire mwena wa gathigathini na wa gũthini;
\q2 Taboru na Herimoni ciinaga ikenete nĩ ũndũ wa rĩĩtwa rĩaku.
\q1 
\v 13 Gĩcoka gĩaku nĩ kĩrĩ ũhoti;
\q2 guoko gwaku kũrĩ hinya, guoko gwaku kwa ũrĩo nĩgũtũgĩrie.
\b
\q1 
\v 14 Ũthingu na kĩhooto nĩcio mũthingi wa gĩtĩ gĩaku kĩa ũnene;
\q2 wendo na wĩhokeku nĩigũtongoragia.
\q1 
\v 15 Kũrathimwo-rĩ, nĩ andũ arĩa mooĩ gũkũgooca na nyĩmbo,
\q2 o arĩa mathiiaga na ũtheri waku, Wee Jehova.
\q1 
\v 16 Makenagĩra rĩĩtwa rĩaku mũthenya wothe;
\q2 magũtũũgagĩria nĩ ũndũ wa ũthingu waku.
\q1 
\v 17 Nĩgũkorwo Wee nĩwe riiri na hinya wao,
\q2 na tondũ wa ũtugi waku nĩũtũũgagĩria rũhĩa rwitũ.
\q1 
\v 18 Ti-itherũ, ngo iitũ ĩrĩ na Jehova,
\q2 mũthamaki witũ nĩ wa Ũrĩa-Mũtheru-wa-Isiraeli.
\b
\q1 
\v 19 Hĩndĩ ĩmwe nĩwaririe na njĩra ya kĩoneki,
\q2 ũkĩĩra andũ aku arĩa ehokeku atĩrĩ,
\q1 “Nĩheete njamba ĩmwe ya ita hinya;
\q2 nĩndũgĩrĩtie mwanake gatagatĩ ka andũ.
\q1 
\v 20 Nĩndĩĩoneire Daudi ndungata yakwa;
\q2 nĩndĩmũitĩrĩirie maguta makwa maamũre.
\q1 
\v 21 Guoko gwakwa nĩkũrĩmũtiiragĩrĩra;
\q2 ti-itherũ gĩcoka gĩakwa nĩkĩrĩmwĩkagĩra hinya.
\q1 
\v 22 Gũtirĩ thũ ĩkaamwĩtia igooti.
\q2 gũtirĩ mũndũ mwaganu ũkaamũhinyĩrĩria.
\q1 
\v 23 Nĩngahehenja thũ ciake mbere yake,
\q2 na njũrage arĩa othe mamũthũire.
\q1 
\v 24 Wendo wakwa wa kwĩhokeka ũrĩkoragwo hamwe nake,
\q2 na nĩ ũndũ wa rĩĩtwa rĩakwa rũhĩa rwake nĩrũrĩtũũgagĩrio.
\q1 
\v 25 Nĩngatambũrũkia guoko gwake igũrũ rĩa iria,
\q2 na guoko gwake kwa ũrĩo ndĩkũige igũrũ rĩa njũũĩ.
\q1 
\v 26 Nĩakanjĩta anjĩĩre atĩrĩ, ‘Wee nĩwe Baba,
\q2 na Mũrungu wakwa, o Rwaro rwa Ihiga, Mũhonokia wakwa.’
\q1 
\v 27 Ningĩ nĩngamwamũra atuĩke irigithathi rĩakwa,
\q2 na ndũme atũũgĩrio gũkĩra athamaki a thĩ.
\q1 
\v 28 Nĩngũtũũria wendo wakwa harĩ we nginya tene,
\q2 na kĩrĩkanĩro gĩakwa nake gĩtũũre kĩrĩ gĩa kwĩhokeka.
\q1 
\v 29 Nĩngahaanda rũciaro rwake nginya tene,
\q2 na gĩtĩ gĩake kĩa ũnene ndĩkĩhaande rĩrĩa rĩothe igũrũ rĩgũtũũra.
\b
\q1 
\v 30 “Ariũ ake mangĩgatirika watho wakwa
\q2 na mage kũrũmĩrĩra kĩrĩra gĩakwa,
\q1 
\v 31 mangĩgathũkia kĩrĩra kĩa watho wakwa wa kũrũmĩrĩrwo
\q2 na mage kũmenyerera maathani makwa,
\q1 
\v 32 nĩngaherithia wĩhia wao na rũthanju,
\q2 herithie waganu wao na kũmahũũra iboko;
\q1 
\v 33 no ndirĩ hĩndĩ ngaamwehereria wendo wakwa,
\q2 o na kana thaahie wĩhokeku wakwa o na rĩ.
\q1 
\v 34 Ndigathũkia kĩrĩkanĩro gĩakwa
\q2 kana ngarũrĩre ũrĩa iromo ciakwa ciarĩtie.
\q1 
\v 35 Nĩndĩhĩtĩte ngĩgwetaga ũtheru wakwa, rĩmwe rĩa kũigana,
\q2 na ndirĩ hĩndĩ ngaaheenia Daudi,
\q1 
\v 36 atĩ rũciaro rwake rũgũtũũra nginya tene,
\q2 na gĩtĩ gĩake kĩa ũnene gĩtũũre kĩrĩ kĩrũmu mbere yakwa ta riũa;
\q1 
\v 37 gĩgũtũũra kĩrĩ kĩrũmu nginya tene o ta mweri,
\q2 mũira ũrĩa ũrĩ matu-inĩ nĩ mwĩhokeku.”
\b
\q1 
\v 38 No rĩrĩ, wee nĩũregete, na ũgatiganĩria,
\q2 o na ũgakĩrakarĩra ũcio ũitĩrĩirie maguta.
\q1 
\v 39 Wee nĩũkanĩte kĩrĩkanĩro kĩrĩa ũrĩkanĩire na ndungata yaku,
\q2 na ũkarangĩrĩria thũmbĩ yake rũkũngũ-inĩ.
\q1 
\v 40 Wee ũmomorete thingo ciake ciothe
\q2 na ũkaananga ciĩhitho ciake iria cia hinya.
\q1 
\v 41 Ehĩtũkĩri othe nĩmatahĩte indo ciake;
\q2 atuĩkĩte wa kũnyararwo nĩ andũ arĩa mariganĩtie nake.
\q1 
\v 42 Wee nĩũtũũgĩrĩtie guoko kwa ũrĩo kwa arĩa mamũthũire;
\q2 nĩũtũmĩte thũ ciake ciothe ikene.
\q1 
\v 43 Ũũgĩ wa rũhiũ rwake rwa njora nĩũũhũndũrĩte,
\q2 na ũkaaga kũmũteithĩrĩria mbaara-inĩ.
\q1 
\v 44 Nĩũniinĩte riiri wake ũgathira,
\q2 na ũgaikania gĩtĩ gĩake kĩa ũnene thĩ.
\q1 
\v 45 Nĩũnyiihĩtie matukũ ma wĩthĩ wake;
\q2 ũmũhumbĩte thoni o ta nguo.
\b
\q1 
\v 46 Nĩ nginya rĩ, Wee Jehova? Ũgũtũũra wĩhithĩte nginya tene?
\q2 Nĩ nginya rĩ mangʼũrĩ maku megũtũũra maakanĩte ta mwaki?
\q1 
\v 47 Ririkana ũrĩa mũtũũrĩre wakwa ũrĩ wa gũthira o narua.
\q2 Kaĩ akĩrĩ ũndũ wa tũhũ watũmire ũmbe andũ othe!
\q1 
\v 48 Nĩ mũndũ ũrĩkũ ũngĩtũũra muoyo na ndonane na gĩkuũ,
\q2 kana ehonokie kuuma kũrĩ hinya wa mbĩrĩra?
\q1 
\v 49 Wee Mwathani, wendo waku mũnene ũrĩa wa tene ũkĩrĩ kũ,
\q2 ũrĩa wehĩtire, ũkĩĩrĩra Daudi na ũndũ wa wĩhokeku waku?
\q1 
\v 50 Mwathani, ririkana ũrĩa ndungata yaku ĩnyũrũrĩtio,
\q2 na ũrĩa nyũmĩrĩirie irumi iria numĩtwo nĩ ndũrĩrĩ ciothe ngoro-inĩ yakwa,
\q1 
\v 51 o irumi iria thũ ciaku iinyũrũrĩtie nacio, Wee Jehova,
\q2 iria itũire inyũrũrĩtie makinya ma ũrĩa wee ũitĩrĩirie maguta nacio.
\b
\q1 
\v 52 Jehova arogoocwo nginya tene!
\qc Ameni, na ningĩ Ameni.
\c 90
\ms1 Ibuku rĩa Kana
\mr Thaburi 90–106
\s1 Matukũ ma Mũndũ
\d Ihooya rĩa Musa, ndungata ya Ngai
\q1 
\v 1 JEHOVA, nĩwe ũtũũrĩte ũrĩ gĩikaro giitũ
\q2 kuuma njiarwa na njiarwa.
\q1 
\v 2 O mbere ya irĩma kũgĩa kuo
\q2 kana ũkĩũmba thĩ na mabũrũri,
\q2 kuuma tene nginya tene, Wee ũrĩ o Mũrungu.
\b
\q1 
\v 3 Wee ũcookagia andũ magatuĩka rũkũngũ,
\q2 ũkoiga atĩrĩ, “Cookai rũkũngũ-inĩ, inyuĩ ciana ici cia andũ.”
\q1 
\v 4 Nĩgũkorwo mĩaka ngiri harĩwe
\q2 no ta mũthenya wa ira ũrĩa ũrahĩtũkire,
\q2 kana ta ituanĩra rĩmwe rĩa arangĩri a ũtukũ.
\q1 
\v 5 Ũhaataga andũ, ũkameeheria, magakoma toro wa gĩkuũ;
\q2 andũ mahaana ta nyeki ĩrĩa ĩringũkaga rũciinĩ:
\q1 
\v 6 o na gũtuĩka rũciinĩ nĩĩringũkaga,
\q2 hwaĩ-inĩ ĩhoohaga, ĩkooma.
\b
\q1 
\v 7 Tũniinagwo nĩ marakara maku,
\q2 na tũkamakio mũno nĩ marũrũ maku.
\q1 
\v 8 Nĩũigĩte wĩhia witũ o mbere yaku,
\q2 mehia maitũ marĩa mahithe ũkamoimĩria o ũtheri-inĩ hau mbere yaku.
\q1 
\v 9 Matukũ maitũ mothe maniinagwo nĩ mangʼũrĩ maku;
\q2 tũninũkagia mĩaka iitũ na gũcaaya.
\q1 
\v 10 Mũigana wa matukũ maitũ-rĩ, nĩ mĩaka mĩrongo mũgwanja,
\q2 kana mĩrongo ĩnana, tũngĩkorwo tũrĩ na hinya;
\q1 no rĩrĩ, mũigana wamo no thĩĩna na kĩeha,
\q2 nĩgũkorwo mathiraga o narua, na ithuĩ tũgathiĩ, tũkabuĩria.
\b
\q1 
\v 11 Nũũ ũũĩ hinya wa marakara maku?
\q2 Nĩgũkorwo mangʼũrĩ maku nĩ manene o ta gwĩtigĩrwo kũrĩa wagĩrĩire.
\q1 
\v 12 Tuonie gũtara matukũ maitũ wega,
\q2 nĩgeetha tũgĩe na ngoro ya ũũgĩ.
\b
\q1 
\v 13 Wee Jehova, hoorera! Nĩ nginya rĩ?
\q2 Iguĩra ndungata ciaku tha.
\q1 
\v 14 Rũciinĩ tũhũũnagie na wendo waku ũtathiraga,
\q2 nĩguo tũinage nĩ gũkena na tũcanjamũkage matukũ maitũ mothe.
\q1 
\v 15 Tũma tũkene matukũ maingĩ o ta marĩa ũtũnyamarĩtie,
\q2 na mĩaka mĩingĩ o ta ĩrĩa tuonete thĩĩna.
\q1 
\v 16 Ndungata ciaku irokĩonio ciĩko ciaku,
\q2 naguo riiri waku wonio ciana ciao.
\b
\q1 
\v 17 Wega wa Mwathani Ngai witũ ũrogĩa na ithuĩ;
\q2 tũma wĩra wa moko maitũ ũgaacĩre,
\q2 ĩĩ-ni, kĩrũmie wĩra wa moko maitũ.
\c 91
\s1 Ngai Nĩwe Mũgitĩri Witũ
\q1 
\v 1 Mũndũ ũrĩa ũikaraga agitĩirwo nĩ Ũrĩa-ũrĩ-Igũrũ-Mũno
\q2 arĩhurũkaga kĩĩruru-inĩ kĩa Mwene-Hinya-Wothe.
\q1 
\v 2 Ngũkiuga ũhoro wa Jehova atĩrĩ,
\q2 “Wee nĩwe rĩũrĩro rĩakwa na kĩirigo gĩakwa kĩrĩ hinya,
\q2 nĩwe Ngai wakwa, ũrĩa ndĩĩhokete.”
\b
\q1 
\v 3 Ti-itherũ nĩegũgũteithũra gĩkerenge-inĩ kĩa mũtegi,
\q2 o na kuuma mũrimũ-inĩ ũrĩa mũũru wa kũũraga.
\q1 
\v 4 Arĩkũhumbagĩra na njoya ciake,
\q2 na rungu rwa mathagu make nĩho ũrĩĩgitagia;
\q2 wĩhokeku wake nĩũgatuĩka ngo yaku na kĩĩhitho gĩaku.
\q1 
\v 5 Ndũrĩĩtigagĩra imakania cia ũtukũ,
\q2 kana mũguĩ ũrĩa ũthĩrĩrĩkaga mũthenya,
\q1 
\v 6 o na kana mũrimũ ũrĩa ũceemaga nduma-inĩ,
\q2 kana mũthiro ũrĩa ũniinanaga mũthenya gatagatĩ.
\q1 
\v 7 Andũ ngiri no magũe mwena waku,
\q2 nao ngiri ikũmi magũe guoko-inĩ gwaku kwa ũrĩo,
\q2 no ndũngĩkuhĩrĩrio nĩguo.
\q1 
\v 8 Wee no kwĩrorera ũkerorera na maitho maku
\q2 wĩonere iherithia rĩa andũ arĩa aaganu.
\b
\q1 
\v 9 Ũngĩtua Ũrĩa-ũrĩ-Igũrũ-Mũno gĩikaro gĩaku,
\q2 o we Jehova, ũrĩa arĩ we rĩũrĩro rĩakwa,
\q1 
\v 10 hĩndĩ ĩyo gũtirĩ ũũru ũgaagũkorerera,
\q2 gũtirĩ mwanangĩko ũgaakuhĩrĩria hema yaku.
\q1 
\v 11 Nĩgũkorwo nĩagaatha araika ake nĩ ũndũ waku,
\q2 makũgitagĩre mĩthiĩre-inĩ yaku yothe;
\q1 
\v 12 nĩmagakuoya na igũrũ na moko mao
\q2 nĩgeetha ndũkaringwo kũgũrũ nĩ ihiga.
\q1 
\v 13 Nĩũgakinyĩrĩria mũrũũthi, o na nduĩra;
\q2 ũkarangĩrĩria mũrũũthi ũrĩa mũnene, o na nyoka.
\b
\q1 
\v 14 Jehova ekuuga atĩrĩ, “Kuona atĩ nĩanyendete,
\q2 nĩngamũhatũra hatĩka-inĩ;
\q2 nĩndĩrĩmũgitagĩra, nĩgũkorwo nĩamenyete rĩĩtwa rĩakwa.
\q1 
\v 15 Arĩngayagĩra, na niĩ ngamwĩtĩka;
\q2 ndĩrĩkoragwo hamwe nake hĩndĩ ya thĩĩna,
\q2 ndĩrĩmũteithũraga na ngamũtĩĩithia.
\q1 
\v 16 Ngũmũtũũria muoyo matukũ maingĩ nginya aiganie,
\q2 na ndĩmuonagie ũhonokio wakwa.”
\c 92
\s1 Rwĩmbo rwa Gũcookia Ngaatho
\q1 
\v 1 Nĩ wega mũno gũcookagĩria Jehova ngaatho
\q2 o na gũkumagia rĩĩtwa rĩaku na rwĩmbo,
\q2 Wee Ũrĩa-ũrĩ-Igũrũ-Mũno,
\q1 
\v 2 nĩ wega mũno kwanagĩrĩra wendo waku o rũciinĩ,
\q2 o na kwanĩrĩra wĩhokeku waku ũtukũ,
\q1 
\v 3 tũkĩinagia kĩnanda gĩa kĩnũbi kĩa ndigi ikũmi,
\q2 o hamwe na kĩnanda kĩa mũgeeto kĩrĩa kĩgambi wega.
\b
\q1 
\v 4 Nĩgũkorwo, Wee Jehova, nĩũngenetie nĩ ũndũ wa ciĩko ciaku;
\q2 nĩngũina ngenete nĩ ũndũ wa wĩra wa moko maku.
\q1 
\v 5 Ĩĩ mawĩra maku matikĩrĩ manene, Wee Jehova,
\q2 meciiria maku-rĩ, matikĩrĩ marikĩru!
\q1 
\v 6 Mũndũ ũrĩa ũtarĩ ũũgĩ ndangĩmamenya,
\q2 mũndũ mũkĩĩgu ndangĩkũũrana ũndũ ũyũ,
\q1 
\v 7 atĩ o na arĩa aaganu mangĩkũra ta nyeki,
\q2 o na arĩa othe mekaga ũũru mangĩgaacĩra,
\q1 makaaniinwo nginya tene na tene.
\b
\q1 
\v 8 No Wee Jehova, ũtũũraga ũtũũgĩrĩtio nginya tene.
\b
\q1 
\v 9 Nĩgũkorwo thũ ciaku, Wee Jehova,
\q2 ti-itherũ thũ ciaku nĩigathira;
\q2 arĩa othe mekaga ũũru nĩmakaharaganio.
\q1 
\v 10 Wee nĩwambararĩtie rũhĩa rwakwa o ta rwa mbogo;
\q2 ndĩĩmũitĩrĩrie maguta marĩa mega mũno.
\q1 
\v 11 Maitho makwa nĩmeyoneire gũtoorio gwa thũ ciakwa;
\q2 matũ makwa nĩmeiguĩrĩire ũrĩa thũ ciakwa icio njaganu itooretio.
\b
\q1 
\v 12 Andũ arĩa athingu marĩtheeremaga o ta mũtĩ wa mũkĩndũ,
\q2 makũre o ta mũtarakwa wa Lebanoni;
\q1 
\v 13 mahaandĩtwo kũu nyũmba-inĩ ya Jehova,
\q2 marĩtheeremaga kũu nja-inĩ cia Ngai witũ.
\q1 
\v 14 Magatũũra maciaraga maciaro o na marĩ akũrũ,
\q2 matũũre marĩ na hinya wa wĩthĩ wao, na marĩ aruru,
\q1 
\v 15 maanagĩrĩre, makiugaga atĩrĩ, “Jehova nĩ mũrũngĩrĩru;
\q2 we nĩwe Rwaro rwakwa rwa Ihiga,
\q2 na gũtirĩ waganu ũngĩoneka thĩinĩ wake.”
\c 93
\s1 Ũkaru wa Wathani wa Ngai
\q1 
\v 1 Jehova nĩarathamaka, ehumbĩte ũkaru;
\q2 Jehova ehumbĩte ũkaru
\q2 na akeoha hinya ta mũcibi.
\q1 Thĩ nĩĩhaandĩtwo ĩkarũma ki,
\q2 ndĩrĩ hĩndĩ ĩngĩenyenyeka.
\q1 
\v 2 Gĩtĩ gĩaku kĩa ũnene gĩtũũrĩte kĩrĩ kĩrũmu kuuma o tene;
\q2 wee ũtũũrĩte kuo kuuma tene na tene.
\b
\q1 
\v 3 Wee Jehova-rĩ, maria nĩmaranĩrĩra,
\q2 maria maranĩrĩra na mĩgambo yamo;
\q2 maria maranĩrĩra makahũũrithia makũmbĩ.
\q1 
\v 4 We nĩarĩ hinya gũkĩra makũmbĩ ma iria,
\q2 arĩ hinya gũkĩra marurumĩ macio ma maaĩ maingĩ,
\q2 Jehova arĩ igũrũ nĩ arĩ hinya.
\b
\q1 
\v 5 Wee Jehova, mawatho maku maikaraga marĩ marũmu;
\q2 naguo ũtheru ũgũtũũra ũgemetie nyũmba yaku
\q2 matukũ matarĩ mũthia.
\c 94
\s1 Ngai Nĩwe Ũrĩhagĩria arĩa Athingu
\q1 
\v 1 Wee Jehova, o Wee Mũrungu ũrĩa ũrĩhanagĩria,
\q2 Wee Mũrungu ũrĩa ũrĩhanagĩria-rĩ, cangarara.
\q1 
\v 2 Arahũka, Wee mũtuanĩri ciira wa andũ othe a thĩ;
\q2 kĩrĩhe andũ arĩa etĩĩi o kĩrĩa kĩmagĩrĩire.
\q1 
\v 3 Wee Jehova-rĩ, nĩ nginya rĩ andũ arĩa aaganu megũtũũra makenete,
\q2 nĩ nginya rĩ andũ arĩa aaganu megũtũũra marũũhagia?
\b
\q1 
\v 4 Maaragia ndeto cia mwĩgaatho;
\q2 andũ arĩa othe meekaga ũũru, o maiyũrĩtwo nĩ mwĩtĩĩo.
\q1 
\v 5 Mahehenjaga andũ aku, Wee Jehova,
\q2 makahinyĩrĩria igai rĩaku.
\q1 
\v 6 Mooragaga mũtumia wa ndigwa, na mũndũ wa kũngĩ;
\q2 mooragaga ciana iria itarĩ maithe.
\q1 
\v 7 Moigaga atĩrĩ, “Jehova ndangĩona;
\q2 Ngai wa Jakubu-rĩ, ndangĩrũmbũiya.”
\b
\q1 
\v 8 Mwĩmenyererei inyuĩ arĩa mwagĩte ũũgĩ mũrĩ gatagatĩ-inĩ ka andũ;
\q2 inyuĩ andũ aya akĩĩgu, mũgaakĩũhĩga rĩ?
\q1 
\v 9 Ũrĩa wombire gũtũ-rĩ, ndangĩigua?
\q2 Ũcio wombire riitho-rĩ, ndangĩona?
\q1 
\v 10 Ũcio ũrũithagia ndũrĩrĩ-rĩ, ndangĩherithania?
\q2 O ũcio ũrutaga andũ-rĩ, ndarĩ ũmenyo?
\q1 
\v 11 Jehova nĩoĩ meciiria ma mũndũ;
\q2 ĩĩ, oĩ atĩ meciiria mao nĩ ma tũhũ.
\b
\q1 
\v 12 Wee Jehova, kũrathimwo-rĩ, nĩ mũndũ ũrĩa Wee ũtaaraga,
\q2 o mũndũ ũcio ũrutaga watho waku;
\q1 
\v 13 nĩũgaatũma ahoorere matukũ-inĩ ma thĩĩna,
\q2 o nginya rĩrĩa mũndũ ũrĩa mwaganu akenjerwo irima.
\q1 
\v 14 Nĩgũkorwo Jehova ndagatiganĩria andũ ake;
\q2 igai rĩake ndarĩ hĩndĩ angĩrĩtirika.
\q1 
\v 15 Ũtuanĩri ciira wa kĩhooto nĩũgakwo rĩngĩ igũrũ rĩa ũthingu,
\q2 nao andũ othe arĩa arũngĩrĩru ngoro maũrũmagĩrĩre.
\b
\q1 
\v 16 Nũũ ũkwarahũka, andũĩrĩre harĩ arĩa aaganu?
\q2 Nũũ ũkũndũgamĩrĩra, andũĩrĩre harĩ arĩa meekaga ũũru?
\q1 
\v 17 Tiga Jehova aandeithirie-rĩ,
\q2 ingĩakuire o narua, ngatũũre kũu ũkiri-inĩ.
\q1 
\v 18 Rĩrĩa ndoigire atĩrĩ, “Kũgũrũ gwakwa nĩkũratenderũka,”
\q2 wendani waku, Wee Jehova, nĩwandiirĩrĩire.
\q1 
\v 19 Rĩrĩa mĩtangĩko yaingĩhire thĩinĩ wakwa-rĩ,
\q2 Wee wahooreririe, ũgĩkenia ngoro yakwa.
\b
\q1 
\v 20 Gĩtĩ kĩa ũnene kĩa ungumania-rĩ, hihi no kĩgĩe na ngwatanĩro nawe,
\q2 o kĩrĩa kĩrehanagĩra mĩnyamaro nĩ ũndũ wa matuĩro ma kĩo?
\q1 
\v 21 Monganaga hamwe nĩguo mokĩrĩre mũndũ ũrĩa mũthingu,
\q2 na magatuĩra mũndũ ũtehĩtie ooragwo.
\q1 
\v 22 No Jehova nĩwe ũtuĩkĩte kĩirigo gĩakwa kĩa hinya,
\q2 na Ngai wakwa, o we rwaro rwakwa rwa ihiga harĩa njũragĩra.
\q1 
\v 23 We nĩakamaherithia nĩ ũndũ wa mehia mao
\q2 na amaniine nĩ ũndũ wa waganu wao;
\q2 Jehova Ngai witũ nĩakamaniina.
\c 95
\s1 Rwĩmbo rwa gwĩta Andũ Magooce Jehova
\q1 
\v 1 Ũkai, tũinĩre Jehova nĩ gũkena;
\q2 tũkĩanĩrĩre ũcio Rwaro rwa Ihiga rwa ũhonokio witũ.
\q1 
\v 2 Nĩtũũkei mbere yake tũgĩcookagia ngaatho,
\q2 na tũmũinĩre nyĩmbo cia kũmũkumia.
\b
\q1 
\v 3 Nĩgũkorwo Jehova nĩ Mũrungu mũnene,
\q2 o we Mũthamaki mũnene ũkĩrĩte ngai ciothe.
\q1 
\v 4 Thĩ kũrĩa kũriku mũno kũrĩ guoko-inĩ gwake,
\q2 o na tũcũmbĩrĩ twa irĩma no twake.
\q1 
\v 5 Iria nĩ rĩake, nĩgũkorwo nĩwe warĩũmbire,
\q2 na moko make nĩmo moombire thĩ nyũmũ.
\b
\q1 
\v 6 Ũkai, tũmũinamĩrĩre tũmũhooe,
\q2 nĩtũturĩrie Jehova o we Mũtũũmbi ndu;
\q1 
\v 7 nĩgũkorwo nĩwe Ngai witũ,
\q2 na ithuĩ tũrĩ andũ a ũrĩithio wake,
\q2 rũũru rũrĩa we mwene arĩithagia.
\b
\q1 Ũmũthĩ mũngĩigua mũgambo wake,
\q2 
\v 8 mũtikoomie ngoro cianyu
\q2 ta ũrĩa mwekire mũrĩ Meriba,
\q2 o na ta ũrĩa mwekire mũthenya ũrĩa mwarĩ Masa kũu werũ-inĩ,
\q1 
\v 9 kũrĩa maithe manyu maangeririe na makĩngararia,
\q2 o na gũtuĩka nĩmoonete ũrĩa wothe ndaamekĩire.
\q1 
\v 10 Nĩgũkorwo ndaatũũrĩte ndakarĩire rũciaro rũu mĩaka mĩrongo ĩna;
\q2 ngiuga atĩrĩ, “Aya nĩ andũ arĩa ngoro ciao ciũrĩte,
\q2 na nĩmagĩte kũmenya njĩra ciakwa.”
\q1 
\v 11 Nĩ ũndũ ũcio ngĩĩhĩta ndakarĩte, ngiuga atĩrĩ,
\q2 “Matirĩ hĩndĩ magaatoonya kĩhurũko-inĩ gĩakwa.”
\c 96
\s1 Kũgooca Ngai Ũrĩa Mũtuanĩri Ciira
\q1 
\v 1 Inĩrai Jehova rwĩmbo rwerũ;
\q2 inĩrai Jehova, inyuĩ andũ a thĩ yothe.
\q1 
\v 2 Inĩrai Jehova, goocai rĩĩtwa rĩake;
\q2 hunjagiai ũhonokio wake mũthenya o mũthenya.
\q1 
\v 3 Umbũrai riiri wake kũrĩ ndũrĩrĩ,
\q2 mumbũre mawĩko make ma kũgegania kũrĩ andũ othe.
\b
\q1 
\v 4 Nĩgũkorwo Jehova nĩ mũnene, na nĩ wa kũgoocwo mũno;
\q2 nĩwe wa gwĩtigĩrwo gũkĩra ngai ciothe.
\q1 
\v 5 Nĩgũkorwo ngai ciothe cia ndũrĩrĩ nĩ mĩhianano,
\q2 no Jehova nĩwe wombire igũrũ.
\q1 
\v 6 Riiri na ũnene irĩ mbere yake;
\q2 hinya na riiri irĩ handũ hake harĩa haamũre.
\b
\q1 
\v 7 Tũũgĩriai Jehova, inyuĩ mĩhĩrĩga ya ndũrĩrĩ,
\q2 mũtũgĩrie Jehova nĩ ũndũ wa riiri na hinya wake.
\q1 
\v 8 Tũũgĩriai Jehova nĩ ũndũ wa riiri ũrĩa wagĩrĩire rĩĩtwa rĩake;
\q2 mũreherei maruta na mũũke nja-inĩ ciake.
\q1 
\v 9 Hooyai Jehova thĩinĩ wa riiri wa ũtheru wake;
\q2 inainai mũrĩ mbere yake, inyuĩ andũ a thĩ yothe.
\b
\q1 
\v 10 Ĩrai ndũrĩrĩ atĩrĩ, “Jehova nĩarathamaka.”
\q2 Thĩ nĩĩhaandĩtwo ĩkarũma, ndĩngĩenyenyeka;
\q2 agatuĩra kĩrĩndĩ ciira akĩigananĩtie.
\q1 
\v 11 Igũrũ nĩrĩkene, thĩ nĩĩcanjamũke;
\q2 iria nĩrĩrurume, na indo iria ciothe irĩ thĩinĩ warĩo;
\q2 
\v 12 mĩgũnda nĩĩkenerũrũke, na indo iria ciothe irĩ thĩinĩ wayo.
\q1 Hĩndĩ ĩyo mĩtĩ yothe ya mũtitũ nĩĩkaina nĩ gũkena;
\q2 
\v 13 ĩkaina ĩrĩ mbere ya Jehova, nĩgũkorwo nĩarooka,
\q2 arooka gũtuĩra thĩ ciira.
\q1 Agaatuĩra thĩ ciira na ũthingu,
\q2 na kĩrĩndĩ agĩtuĩre na ma yake.
\c 97
\s1 Riiri wa Wathani wa Ngai
\q1 
\v 1 Jehova nĩarathamaka, thĩ nĩĩgĩkene;
\q2 mabũrũri marĩa marĩ ndwere-inĩ cia iria nĩmacanjamũke.
\b
\q1 
\v 2 Athiũrũrũkĩirio nĩ matu na nduma ndumanu;
\q2 ũthingu na kĩhooto nĩcio mũthingi wa gĩtĩ gĩake kĩa ũnene.
\q1 
\v 3 Mwaki ũmũthiiaga mbere
\q2 ũgĩcinaga thũ ciake na mĩena yothe.
\q1 
\v 4 Heni ciake imũrĩkaga thĩ yothe;
\q2 thĩ ĩcionaga ĩkainaina.
\q1 
\v 5 Irĩma itwekaga o ta mũhũra mbere ya Jehova,
\q2 igatweka irĩ mbere ya Mwathani wa thĩ yothe.
\q1 
\v 6 Igũrũ rĩanagĩrĩra ũthingu wake,
\q2 nao andũ othe makoona riiri wake.
\b
\q1 
\v 7 Andũ arĩa othe mahooyaga mĩhianano mĩicũhie nĩmaconorithagio,
\q2 acio meerahaga na mĩhianano:
\q2 inyuĩ ngai ici, mũinamĩrĩrei mũmũhooe.
\b
\q1 
\v 8 Zayuni ĩiguaga ũguo ĩgakena,
\q2 namo matũũra ma Juda magacanjamũka,
\q2 tondũ wa matuĩro maku ma ciira, Wee Jehova.
\q1 
\v 9 Nĩgũkorwo Wee Jehova, nĩwe Ũrĩa-Ũrĩ-Igũrũ-Mũno wa thĩ yothe;
\q2 wee nĩũtũũgĩrĩtio mũno igũrũ rĩa ngai ciothe.
\b
\q1 
\v 10 Arĩa endi Jehova nĩmathũũre ũũru,
\q2 nĩgũkorwo nĩagitagĩra mĩoyo ya arĩa ake ehokeku,
\q2 na akamateithũra kuuma moko-inĩ ma arĩa aaganu.
\q1 
\v 11 Ũtheri nĩwarĩire arĩa athingu
\q2 na arĩa arũngĩrĩru ngoro makaiyũrwo nĩ gĩkeno.
\q1 
\v 12 Kenerai Jehova, inyuĩ arĩa athingu,
\q2 mũkĩgooce rĩĩtwa rĩake rĩamũre.
\c 98
\s1 Ngai Nĩwe wathaga Thĩ Yothe
\q1 
\v 1 Inĩrai Jehova rwĩmbo rwerũ,
\q2 nĩgũkorwo nĩekĩte maũndũ ma kũgegania;
\q1 guoko gwake kwa ũrĩo na gĩcoka gĩake gĩtheru
\q2 nĩcio imũhonokanĩirie.
\q1 
\v 2 Jehova nĩamenyithanĩtie ũhonokio wake
\q2 na akaguũria ũthingu wake kũrĩ andũ a ndũrĩrĩ.
\q1 
\v 3 Nĩaririkanĩte wendo wake
\q2 na wĩhokeku wake ũrĩa erĩire nyũmba ya Isiraeli;
\q1 ituri ciothe cia thĩ nĩcionete
\q2 ũhonokanio wa Ngai witũ.
\b
\q1 
\v 4 Anĩrĩrai mũkenete mũrĩ mbere ya Jehova, inyuĩ andũ othe a thĩ,
\q2 tumũkai mũkenũrũrũke na nyĩmbo mũkĩinaga;
\q1 
\v 5 inĩrai Jehova na kĩnanda kĩa mũgeeto,
\q2 mũmũinĩre na kĩnanda kĩa mũgeeto
\q2 o na mũgambo ũrĩa mwega mũno,
\q1 
\v 6 inai na tũrumbeta, na mũgambo wa coro:
\q2 anĩrĩrai na gĩkeno mũrĩ mbere ya Jehova, o ũcio Mũthamaki.
\b
\q1 
\v 7 Iria rĩrĩa inene nĩrĩrurume, na kĩrĩa gĩothe kĩrĩ thĩinĩ warĩo,
\q2 mabũrũri mothe, na arĩa othe matũũraga kuo.
\q1 
\v 8 Njũũĩ nacio nĩikĩhũũre hĩ,
\q2 o nacio irĩma nĩciine hamwe nĩ gũkena;
\q1 
\v 9 nĩciine irĩ mbere ya Jehova,
\q2 nĩgũkorwo nĩarooka nĩguo athamakĩre thĩ.
\q1 Agatuĩra mabũrũri ciira na ũthingu,
\q2 nakĩo kĩrĩndĩ agĩtuithanagie na werekereru.
\c 99
\s1 Kũgooca Ngai nĩ ũndũ wa Ũthingu Wake
\q1 
\v 1 Jehova nĩarathamaka,
\q2 ndũrĩrĩ nĩcikĩinaine;
\q1 aikarĩire gĩtĩ kĩa ũnene arĩ gatagatĩ ka makerubi,
\q2 thĩ nĩĩthingithe.
\q1 
\v 2 Jehova nĩ mũnene Zayuni;
\q2 nĩatũũgĩrĩte igũrũ rĩa ndũrĩrĩ ciothe.
\q1 
\v 3 Andũ nĩmakĩgooce rĩĩtwa rĩaku inene na rĩa gwĩtigĩrwo:
\q2 we nĩwe mũtheru.
\b
\q1 
\v 4 Mũthamaki nĩ arĩ hinya, na nĩendete kĩhooto:
\q2 nĩũrũmĩtie ũtuithania wa ciira ũrĩa mwerekereru;
\q1 nĩwĩkĩte maũndũ ma kĩhooto na ma ũthingu
\q2 thĩinĩ wa Jakubu.
\q1 
\v 5 Tũũgĩriai Jehova Ngai witũ,
\q2 na mũmũinamĩrĩre, mũmũhooe mũrĩ gĩturwa-inĩ kĩa makinya make;
\q2 we nĩwe mũtheru.
\b
\q1 
\v 6 Musa na Harũni maarĩ amwe a athĩnjĩri-Ngai ake,
\q2 nake Samũeli aarĩ ũmwe wa arĩa maakayagĩra rĩĩtwa rĩake;
\q1 maakayagĩra Jehova
\q2 nake akametĩka.
\q1 
\v 7 Aamaragĩria arĩ thĩinĩ wa gĩtugĩ kĩa itu;
\q2 makĩrũmia mawatho make
\q2 na kĩrĩra kĩa watho wake wa kũrũmĩrĩrwo kĩrĩa aamaheete.
\b
\q1 
\v 8 Wee Jehova Ngai witũ-rĩ,
\q2 nĩwametĩkaga;
\q1 harĩ Isiraeli warĩ Mũrungu mũrekanĩri,
\q2 o na gũtuĩka nĩwamaherithagia nĩ ũndũ wa ciĩko ciao njũru.
\q1 
\v 9 Tũũgĩriai Jehova Ngai witũ,
\q2 na mũmũhooyage mũrĩ kĩrĩma-inĩ gĩake kĩamũre,
\q2 nĩgũkorwo Jehova Ngai witũ nĩ mũtheru.
\c 100
\s1 Rwĩmbo rwa Kũgooca Ngai
\q1 
\v 1 Anĩrĩrai mũkenete mũrĩ mbere ya Jehova, inyuĩ andũ othe a thĩ.
\q2 
\v 2 Thathaiyai Jehova mũcanjamũkĩte;
\q2 ũkai mbere yake mũkĩinaga mũkenete.
\q1 
\v 3 Menyai atĩ Jehova nĩwe Ngai.
\q2 Nĩwe watũũmbire, na ithuĩ tũrĩ ake,
\q2 tũrĩ andũ ake, ngʼondu cia ũrĩithio wake.
\b
\q1 
\v 4 Tonyerai ihingo ciake mũrĩ na ngaatho,
\q2 mũtoonye nja ciake mũkĩmũgoocaga;
\q2 mũcookeriei ngaatho na mũgooce rĩĩtwa rĩake.
\q1 
\v 5 Nĩgũkorwo Jehova nĩ mwega,
\q2 wendo wake ũtũũraga nginya tene na tene;
\q2 wĩhokeku wake nĩ wa nginya njiarwa na njiarwa.
\c 101
\s1 Wĩhokeku wa Mũthamaki harĩ Ngai
\d Thaburi ya Daudi
\q1 
\v 1 Niĩ ndĩinaga ũhoro wa wendo na wa kĩhooto gĩaku;
\q2 Wee Jehova nĩwe ndĩrĩgoocaga na rwĩmbo.
\q1 
\v 2 Nĩngwĩmenyerera ndũũre mũtũũrĩre ũtarĩ ũcuuke:
\q2 nĩ rĩ ũgaagĩũka kũrĩ niĩ?
\b
\q1 Nĩndĩrĩikaraga mũciĩ gwakwa
\q2 ndĩ na ngoro ĩtarĩ ũcuuke.
\q1 
\v 3 Gũtirĩ ũndũ mũũru
\q2 ndĩrĩigaga mbere ya maitho makwa.
\b
\q1 Nĩthũire ciĩko cia andũ arĩa matarĩ wĩtĩkio;
\q2 ndingĩĩtĩkĩra menyiitĩrĩre harĩ niĩ.
\q1 
\v 4 Ndĩrĩikaraga haraihu na andũ arĩa marĩ ngoro nemi;
\q2 ũũru-rĩ, ndirĩ hĩndĩ ngaanyiitanĩra naguo.
\b
\q1 
\v 5 Mũndũ o wothe ũngĩcambia mũndũ wa itũũra rĩake na hitho,
\q2 ũcio nĩngamũniina;
\q1 mũndũ o wothe ũrĩ maitho ma rũngʼathio na ngoro ya mwĩtĩĩo,
\q2 ũcio ndikamũkirĩrĩria.
\b
\q1 
\v 6 Maitho makwa-rĩ, marĩroraga andũ arĩa ehokeku bũrũri-inĩ,
\q2 nĩguo maikaranagie na niĩ;
\q1 mũndũ ũrĩa mĩthiĩre yake ĩtarĩ ũcuuke-rĩ,
\q2 ũcio nĩarĩndungatagĩra.
\b
\q1 
\v 7 Gũtirĩ mũndũ wĩkaga maũndũ ma mawara
\q2 ũgaikara nyũmba-inĩ yakwa;
\q1 gũtirĩ mũndũ waragia maheeni
\q2 ũkaarũgama mbere yakwa.
\b
\q1 
\v 8 O rũciinĩ nĩndĩrĩkiragia
\q2 arĩa othe aaganu bũrũri-inĩ;
\q1 nĩngeheria andũ arĩa othe mekaga ũũru
\q2 mathire itũũra-inĩ rĩrĩa inene rĩa Jehova.
\c 102
\s1 Ihooya rĩa Mũndũ Mũnyamarĩku
\q1 
\v 1 Wee Jehova, igua ihooya rĩakwa;
\q2 reke gũkaya gwakwa ngĩhooya ũteithio gũgũkinyĩre.
\q1 
\v 2 Tiga kũũhitha ũthiũ waku
\q2 rĩrĩa ndĩ mĩnyamaro-inĩ.
\q1 Inamĩrĩria gũtũ gwaku ũnjigue;
\q2 ndagũkaĩra, njĩtĩka o narua.
\b
\q1 
\v 3 Nĩgũkorwo matukũ makwa marathira
\q2 o ta ũrĩa ndogo ĩthiraga;
\q2 namo mahĩndĩ makwa maraakana o ta gĩcinga.
\q1 
\v 4 Ngoro yakwa ĩringĩkĩte na ĩkahooha o ta nyeki;
\q2 ndiganĩirwo o na nĩ kũrĩa irio.
\q1 
\v 5 Tondũ wa ũrĩa ndĩracaaya nyanĩrĩire,
\q2 hĩnjĩte ngatigara o gĩkonde na mahĩndĩ.
\q1 
\v 6 Haana ta ndundu ya werũ-inĩ,
\q2 ngahaana ta ndundu ĩrĩa ĩikaraga kũrĩa kwanangĩku.
\q1 
\v 7 Ndaaraga itarĩ toro;
\q2 haanĩte ta nyoni ĩrĩ o iiki nyũmba igũrũ.
\q1 
\v 8 Mũthenya wothe thũ ciakwa itindaga igĩĩthirĩkia;
\q2 acio maanyũrũragia mahũthagĩra rĩĩtwa rĩakwa taarĩ kĩrumi.
\q1 
\v 9 Nĩgũkorwo ndĩĩaga mũhu taarĩ irio ciakwa,
\q2 na kĩrĩa nyuuaga ngagĩtukania na maithori,
\q1 
\v 10 tondũ wa mangʼũrĩ maku manene,
\q2 ũnjoete na igũrũ ũkanjikia mwena-inĩ.
\q1 
\v 11 Matukũ makwa mahaana o ta kĩĩruru kĩa hwaĩ-inĩ;
\q2 hoohaga ta nyeki.
\b
\q1 
\v 12 No rĩrĩ, Wee Jehova ũgũtũũra ũikarĩire gĩtĩ kĩa ũnene nginya tene na tene;
\q2 ngumo yaku ĩgũtũũra njiarwa na njiarwa.
\q1 
\v 13 Wee nĩũkwarahũka ũiguĩre itũũra rĩa Zayuni tha,
\q2 nĩgũkorwo ihinda rĩa kũrĩĩka wega nĩ ikinyu;
\q2 ihinda rĩrĩa rĩathĩrĩre nĩ ikinyu.
\q1 
\v 14 Nĩgũkorwo mahiga makuo nĩmakenagĩrwo nĩ ndungata ciaku;
\q2 o na rũkũngũ rwakuo nĩrũtũmaga iringwo nĩ tha.
\q1 
\v 15 Ndũrĩrĩ nĩigeetigĩra rĩĩtwa rĩa Jehova,
\q2 athamaki othe a thĩ mekĩrĩre riiri waku.
\q1 
\v 16 Nĩgũkorwo Jehova nĩagaaka itũũra rĩa Zayuni rĩngĩ,
\q2 na eyumĩrie arĩ na riiri wake.
\q1 
\v 17 Nĩakaigua mahooya ma andũ arĩa aagi;
\q2 ndakanyarara mahooya mao.
\b
\q1 
\v 18 Ũhoro ũyũ nĩwandĩkwo nĩ ũndũ wa rũciaro rũrĩa rũgooka,
\q2 nĩguo andũ arĩa mataciarĩtwo makaagooca Jehova:
\q1 
\v 19 “Jehova nĩacũthĩrĩirie thĩ arĩ harĩa hake haamũre kũu igũrũ;
\q2 arĩ kũu igũrũ Jehova nĩkũrora aarorire thĩ,
\q1 
\v 20 nĩguo aigue gũcaaya kwa arĩa moheetwo,
\q2 na ohorithie arĩa maatuĩrĩirwo gũkua.”
\q1 
\v 21 Nĩ ũndũ ũcio rĩĩtwa rĩa Jehova nĩrĩkoimbũrwo kũu Zayuni,
\q2 na nĩakagoocwo kũu Jerusalemu
\q1 
\v 22 rĩrĩa andũ a ndũrĩrĩ na mothamaki
\q2 makoongana, mathathaiye Jehova.
\b
\q1 
\v 23 Hĩndĩ ya mũtũũrĩre wakwa nĩanyiihirie hinya wakwa;
\q2 nĩakuhĩhirie matukũ makwa.
\q1 
\v 24 Nĩ ũndũ ũcio ngĩkiuga atĩrĩ:
\q2 “Wee Ngai wakwa, ndũkanjũrage o rĩrĩa ndaiganĩria matukũ makwa;
\q2 wee-rĩ, mĩaka yaku ĩthiiaga o na mbere nginya njiarwa na njiarwa.
\q1 
\v 25 O kĩambĩrĩria-inĩ, nĩwaarire mĩthingi ya thĩ,
\q2 o narĩo igũrũ nĩ wĩra wa moko maku.
\q1 
\v 26 Icio nĩgũthira igaathira, no wee nĩgũtũũra ũgaatũũra;
\q2 igaakũra o ta nguo, ithire.
\q1 Ũgaacigarũrĩra ta nguo,
\q2 icooke iteeo.
\q1 
\v 27 No Wee ndũgarũrũkaga,
\q2 nayo mĩaka yaku ndĩrĩ mũthia.
\q1 
\v 28 Ciana cia ndungata ciaku igaatũũra na thayũ mbere yaku;
\q2 nacio njiaro ciacio cigaikara irũmĩte irĩ mbere yaku.”
\c 103
\s1 Gũcookia Ngaatho nĩ ũndũ wa Wega wa Ngai
\d Thaburi ya Daudi
\q1 
\v 1 Gooca Jehova, wee ngoro yakwa;
\q2 kĩrĩa gĩothe kĩrĩ thĩinĩ wakwa, gooca rĩĩtwa rĩake itheru.
\q1 
\v 2 Gooca Jehova, wee ngoro yakwa,
\q2 na ndũkariganĩrwo nĩ maũndũ mothe marĩa aanagwĩka:
\q1 
\v 3 o ũrĩa ũkũrekagĩra mehia maku mothe,
\q2 na agakũhonia mĩrimũ yaku yothe,
\q1 
\v 4 ũrĩa ũkũũraga muoyo waku kuuma irima rĩa gĩkuũ,
\q2 na agakũhumba wendo na tha taarĩ thũmbĩ ya ũnene,
\q1 
\v 5 o we ũkũhũũnagia na maũndũ mega
\q2 nĩgeetha waanake waku werũhagio o ta wa nderi.\f + \fr 103:5 \ft Nderi yũĩkaine nĩ ũndũ wa hinya wayo, na nĩ ũndũ wa gũtũũra mũno.\f*
\b
\q1 
\v 6 Jehova ekaga maũndũ ma ũthingu,
\q2 na akarũgamĩrĩra kĩhooto kũrĩ arĩa othe ahinyĩrĩrie.
\b
\q1 
\v 7 Nĩamenyithirie Musa njĩra ciake,
\q2 nacio ciĩko ciake agĩcimenyithia andũ a Isiraeli:
\q1 
\v 8 Jehova nĩ mũigua tha na nĩ mũtugi,
\q2 ndahiũhaga kũrakara, na nĩaiyũirwo nĩ wendo mũingĩ.
\q1 
\v 9 We ndaciirithanagia hĩndĩ ciothe,
\q2 o na kana agatũũra arakarĩte nginya tene;
\q1 
\v 10 Ndatũherithagia ta ũrĩa mehia maitũ magĩrĩirwo,
\q2 o na kana agatũrĩhia kũringana na waganu witũ ũrĩa ũigana.
\q1 
\v 11 O ta ũrĩa igũrũ rĩraihanĩrĩirie na thĩ,
\q2 ũguo no taguo wendo wake ũrĩ mũnene kũrĩ arĩa mamwĩtigĩrĩte;
\q1 
\v 12 o ta ũrĩa irathĩro kũraihanĩrĩirie na ithũĩro-rĩ,
\q2 ũguo no taguo atwehereirie mehia maitũ magatũraihĩrĩria.
\q1 
\v 13 O ta ũrĩa mũthuuri aiguagĩra ciana ciake tha,
\q2 ũguo no taguo Jehova aiguagĩra tha arĩa mamwĩtigĩrĩte;
\q1 
\v 14 nĩgũkorwo we nĩoĩ ũrĩa tuombirwo,
\q2 nĩaririkanaga atĩ ithuĩ tũrĩ o rũkũngũ.
\q1 
\v 15 Ha ũhoro wa mũndũ-rĩ, matukũ make mahaana o ta nyeki,
\q2 we acanũkaga o ta ihũa rĩa gĩthaka;
\q1 
\v 16 rĩhurutagwo nĩ rũhuho rĩkehera,
\q2 na harĩa rĩraarĩ rĩtingĩcooka kuonwo rĩngĩ.
\q1 
\v 17 No rĩrĩ, kuuma tene nginya tene
\q2 wendo wa Jehova ũtũũraga harĩ arĩa mamwĩtigĩrĩte,
\q2 naguo ũthingu wake ũgakinyĩra ciana cia ciana ciao,
\q1 
\v 18 o acio mamenyagĩrĩra kĩrĩkanĩro gĩake,
\q2 na makaririkanaga gwathĩkĩra watho wake.
\b
\q1 
\v 19 Jehova nĩahaandĩte gĩtĩ gĩake kĩa ũnene kũu igũrũ,
\q2 na ũthamaki wake wathaga maũndũ mothe.
\b
\q1 
\v 20 Goocai Jehova, inyuĩ araika ake,
\q2 inyuĩ njamba irĩ hinya, inyuĩ mwĩkaga ũrĩa oigĩte,
\q2 o inyuĩ mwathĩkagĩra kiugo gĩake.
\q1 
\v 21 Goocai Jehova, inyuĩ mbũtũ ciake ciothe cia igũrũ,
\q2 o inyuĩ ndungata ciake iria ciĩkaga ũrĩa endaga.
\q1 
\v 22 Goocai Jehova, inyuĩ mawĩra make mothe
\q2 mũrĩ kũrĩa guothe athamakaga.
\b
\q1 Wee ngoro yakwa, gooca Jehova.
\c 104
\s1 Jehova ũrĩa Mũũmbi na Mũheani
\q1 
\v 1 Gooca Jehova, wee ngoro yakwa.
\b
\q1 Wee Jehova Ngai wakwa, Wee ũrĩ mũnene mũno;
\q2 wĩhumbĩte riiri na ũkaru.
\q1 
\v 2 Ehumbĩte ũtheri taarĩ nguo;
\q2 we atambũrũkagia igũrũ taarĩ hema,
\q2 
\v 3 na akaara mĩgamba ya tũnyũmba twake twa ngoroba igũrũ rĩa maaĩ.
\q1 We atũmaga matu matuĩke ngaari yake ya ita,
\q2 na agakuuo nĩ mathagu ma rũhuho.
\q1 
\v 4 Nĩwe ũtũmaga rũhuho rũtuĩke arekio ake,
\q2 nacio nĩnĩmbĩ cia mwaki agacitua ndungata ciake.
\b
\q1 
\v 5 We aahaandire thĩ igũrũ rĩa mĩthingi yayo;
\q2 ndĩrĩ hĩndĩ ĩngĩenyenyeka.
\q1 
\v 6 Wamĩhumbĩrire na iria rĩrĩa inene taarĩ nguo;
\q2 maaĩ maikarire makunĩkĩire irĩma.
\q1 
\v 7 No rĩrĩ, wakũũmire maaĩ makĩũra,
\q2 nacio ngwa ciaku ciagamba magĩĩthara;
\q1 
\v 8 magĩtherera igũrũ wa irĩma,
\q2 magĩikũrũka cianda-inĩ,
\q2 magĩtherera na kũrĩa watuĩte mathiĩ.
\q1 
\v 9 Wee nĩwe wekĩrire mũhaka ũrĩa matangĩkĩra;
\q2 gũtirĩ hĩndĩ magaacooka kũhumbĩra thĩ.
\b
\q1 
\v 10 We atũmaga ithima ciitĩrĩre maaĩ mĩkuru-inĩ;
\q2 mathereraga gatagatĩ-inĩ ka irĩma.
\q1 
\v 11 Nĩcio iheaga nyamũ ciothe cia gĩthaka maaĩ ma kũnyua;
\q2 nĩkuo njagĩ cia werũ-inĩ inyootoragĩrwo.
\q1 
\v 12 Nyoni cia rĩera-inĩ ciakaga itara hakuhĩ na maaĩ macio;
\q2 ciinaga irĩ honge-inĩ cia mĩtĩ.
\q1 
\v 13 We aitagĩrĩria irĩma maaĩ moimĩte nyũmba-inĩ ciake iria irĩ igũrũ;
\q2 thĩ nĩĩiganagwo nĩ maciaro ma wĩra wake.
\q1 
\v 14 We atũmaga nyeki ĩkũre nĩ ũndũ wa kũrĩĩo nĩ mahiũ,
\q2 na agakũria mĩmera ĩrĩa andũ mahaandaga,
\q2 tĩĩri-inĩ gũgakiumaga irio:
\q1 
\v 15 ndibei ĩrĩa ĩkenagia ngoro ya mũndũ
\q2 na maguta ma gũtũma ũthiũ wake ũkenge,
\q2 o na irio iria ciĩkagĩra ngoro yake hinya.
\q1 
\v 16 Mĩtĩ ya Jehova nĩyuragĩrio mbura wega,
\q2 mĩtarakwa ĩyo ya Lebanoni o ĩrĩa aahaandire.
\q1 
\v 17 Kũu nĩkuo nyoni ciakaga itara ciacio;
\q2 nayo njũũ, nyũmba yayo ĩrĩ kũu mĩkarakaba-inĩ.
\q1 
\v 18 Irĩma-inĩ iria ndaaya nĩkuo mbũri cia gĩthaka ciikaraga;
\q2 mĩatũka-inĩ ya mahiga nĩkuo ikami ciĩhithaga.
\b
\q1 
\v 19 Mweri nĩguo ũmenyithanagia hĩndĩ ya imera,
\q2 narĩo riũa nĩrĩmenyaga hĩndĩ yarĩo ya gũthũa.
\q1 
\v 20 Wee nĩwe ũtũmaga kũgĩe nduma, gũgatuĩka ũtukũ,
\q2 nacio nyamũ ciothe cia gĩthaka ikoimĩra icemeete.
\q1 
\v 21 Mĩrũũthi ĩrĩa mĩĩthĩ ĩraramaga ĩkĩhĩta,
\q2 na ĩgacaria irio ciayo kuuma harĩ Mũrungu.
\q1 
\v 22 Riũa rĩrathaga, nayo ĩgeethiĩra;
\q2 ĩthiiaga ĩgakoma imamo-inĩ ciayo.
\q1 
\v 23 Hĩndĩ ĩyo mũndũ agathiĩ kũruta wĩra wake,
\q2 agakĩruta wĩra o nginya hwaĩ-inĩ.
\b
\q1 
\v 24 Wee Jehova, kaĩ mawĩra maku nĩ maingĩ-ĩ!
\q2 Mothe ũmarutĩte na ũũgĩ;
\q2 nayo thĩ ĩiyũrĩte ciũmbe ciaku.
\q1 
\v 25 Rĩĩrĩa nĩrĩo iria rĩrĩa inene na rĩariĩ,
\q2 rĩiyũrĩte ciũmbe irĩ muoyo itangĩtarĩka,
\q2 iria nene na iria nini.
\q1 
\v 26 Marikabu nĩkuo igeragĩra igĩthiĩ na igĩcooka,
\q2 o na nyamũ ĩrĩa ĩĩtagwo Leviathani,
\q2 ĩrĩa wombire nĩguo ĩtũũhagĩre kuo.
\b
\q1 
\v 27 Icio ciothe nĩwe icũthagĩrĩria
\q2 nĩguo ũcihe irio ciacio hĩndĩ ĩrĩa yagĩrĩire.
\q1 
\v 28 Na rĩrĩa wacihe irio,
\q2 cioyaga ikarĩa;
\q1 rĩrĩa watambũrũkia guoko gwaku,
\q2 ũcihũũnagia na indo njega.
\q1 
\v 29 Rĩrĩa wahitha ũthiũ waku,
\q2 inyiitagwo nĩ guoya;
\q1 rĩrĩa weheria mĩhũmũ yacio,
\q2 ikuuaga igaacooka rũkũngũ-inĩ.
\q1 
\v 30 Rĩrĩa watũma Roho waku,
\q2 ikagĩa kuo,
\q2 nawe ũkerũhia maũndũ mothe gũkũ thĩ.
\b
\q1 
\v 31 Riiri wa Jehova ũrotũũra nginya tene;
\q2 Jehova arokenagĩra mawĩra make:
\q1 
\v 32 o we ũcio ũroraga thĩ, nayo ĩkainaina,
\q2 o we ũhutagia irĩma, nacio ikoima ndogo.
\b
\q1 
\v 33 Ngũtũũra nyinagĩra Jehova matukũ mothe ma muoyo wakwa;
\q2 ndĩrĩinaga ngĩgoocaga Ngai wakwa hĩndĩ ĩrĩa yothe ngũtũũra muoyo.
\q1 
\v 34 Jehova arokenio nĩ mecũũrania makwa,
\q2 rĩrĩa ndĩrĩkenaga nĩ ũndũ wake.
\q1 
\v 35 No rĩrĩ, ehia maroniinwo kuuma thĩ,
\q2 na andũ arĩa aaganu mathire biũ.
\b
\q1 Wee ngoro yakwa, gooca Jehova.
\b
\q2 Goocai Jehova.
\c 105
\s1 Wĩhokeku wa Ngai kũrĩ Isiraeli
\q1 
\v 1 Cookeria Jehova ngaatho, kaĩrai rĩĩtwa rĩake;
\q2 menyithiai ndũrĩrĩ maũndũ marĩa ekĩte.
\q1 
\v 2 Mũinĩrei, mũmũinĩre mũkĩmũgoocaga;
\q2 heanai ũhoro wa ciĩko ciake ciothe cia magegania.
\q1 
\v 3 Mwĩrahei nĩ ũndũ wa rĩĩtwa rĩake itheru;
\q2 ngoro cia arĩa marongoragia Jehova nĩikene.
\q1 
\v 4 Cũthĩrĩriai Jehova na hinya wake;
\q2 mathaai ũthiũ wake hĩndĩ ciothe.
\b
\q1 
\v 5 Ririkanai magegania marĩa ekĩte,
\q2 na ciama ciake, na matuĩro ma ciira marĩa atuĩte,
\q1 
\v 6 inyuĩ njiaro cia Iburahĩmu ndungata yake,
\q2 o inyuĩ ciana cia Jakubu, inyuĩ ake athuure.
\q1 
\v 7 Jehova nĩwe Ngai witũ;
\q2 matuĩro make ma ciira marĩ thĩ yothe.
\b
\q1 
\v 8 Nĩaririkanaga kĩrĩkanĩro gĩake nginya tene,
\q2 nĩkĩo kiugo kĩrĩa aathanire, nĩ ũndũ wa njiarwa ngiri,
\q1 
\v 9 kĩrĩkanĩro kĩrĩa aarĩkanĩire na Iburahĩmu,
\q2 na noguo mwĩhĩtwa ũrĩa eehĩtire harĩ Isaaka.
\q1 
\v 10 Nĩagĩĩkĩrire hinya harĩ Jakubu kĩrĩ kĩrĩra gĩake kĩa watho wa kũrũmagĩrĩrwo,
\q2 agĩgĩĩkĩra hinya harĩ Isiraeli kĩrĩ kĩrĩkanĩro gĩa gũtũũra tene na tene:
\q1 
\v 11 “Wee nĩwe ngaahe bũrũri wa Kaanani ũtuĩke igai rĩrĩa ũkaagaya.”
\b
\q1 
\v 12 Hĩndĩ ĩrĩa maarĩ o anini magĩtarwo,
\q2 o anini biũ, na marĩ ageni kuo-rĩ,
\q1 
\v 13 morũũraga kuuma rũrĩrĩ rũmwe nginya rũrĩa rũngĩ,
\q2 na kuuma ũthamaki-inĩ ũmwe nginya ũrĩa ũngĩ.
\q1 
\v 14 Ndarĩ mũndũ o na ũmwe eetĩkĩririe amanyariire;
\q2 nĩ ũndũ wao akĩrũithia athamaki, akĩmeera atĩrĩ:
\q1 
\v 15 “Mũtikanahutie andũ arĩa akwa aitĩrĩrie maguta;
\q2 mũtikaneke anabii akwa ũũru.”
\b
\q1 
\v 16 Agĩtũma bũrũri ũcio ũgĩe ngʼaragu,
\q2 na akĩniina mĩthiithũ yao yothe ya irio;
\q1 
\v 17 agĩtũma mũndũ athiĩ mbere yao:
\q2 nĩwe Jusufu, ũrĩa wendirio arĩ ngombo.
\q1 
\v 18 Nĩmamũtiihirie magũrũ na bĩngũ,
\q2 na makĩmuoha ngingo na igera,
\q1 
\v 19 nginya ũrĩa oigĩte ũgĩkinyanĩra,
\q2 nginya kiugo kĩa Jehova gĩkĩonania atĩ aarĩ mũndũ wa ma.
\q1 
\v 20 Mũthamaki agĩtũmana na akĩmuohorithia,
\q2 mwathi ũcio wa ndũrĩrĩ akĩmũrekereria.
\q1 
\v 21 Akĩmũtua mwathi wa indo cia nyũmba yake,
\q2 na mũrori wa indo iria ciothe aarĩ nacio,
\q1 
\v 22 nĩguo ataarage anene ake o ũrĩa angĩonire kwagĩrĩire,
\q2 na arutage athuuri ake ũũgĩ.
\b
\q1 
\v 23 Hĩndĩ ĩyo Isiraeli agĩthiĩ Misiri;
\q2 Jakubu agĩtũũra arĩ mũgeni bũrũri-inĩ ũcio wa Hamu.
\q1 
\v 24 Jehova agĩtũma andũ ake maciarane mũno;
\q2 agĩtũma maingĩhe mũno gũkĩra thũ ciao,
\q1 
\v 25 iria aagarũrire ngoro ciao agĩtũma ithũũre andũ ake,
\q2 agĩtũma ithugundĩre ndungata ciake ũũru.
\q1 
\v 26 Aatũmire Musa ndungata yake,
\q2 na Harũni, ũrĩa aathurĩte.
\q1 
\v 27 Nao makĩringa ciama ciake gatagatĩ-inĩ kao,
\q2 magĩĩka magegania make bũrũri-inĩ wa Hamu.
\q1 
\v 28 Agĩtũma kũgĩe nduma naguo bũrũri ũcio ũgĩtumana,
\q2 tondũ-rĩ, githĩ ti ciugo ciake maaremeire?
\q1 
\v 29 Akĩgarũra maaĩ mao magĩtuĩka thakame,
\q2 agĩtũma thamaki ciao ikue.
\q1 
\v 30 Bũrũri wao ũkĩiyũra ciũra,
\q2 iria ciatoonyire nginya tũnyũmba twa toro twa anene ao.
\q1 
\v 31 Aaririe, gũgĩũka mĩrumbĩ ya ngi,
\q2 na rwagĩ rũkĩiyũra bũrũri wao wothe.
\q1 
\v 32 Akĩgarũra mbura yao ĩgĩtuĩka ya mbembe,
\q2 na heni ikĩhenũka bũrũri-inĩ wao wothe;
\q1 
\v 33 akĩrũnda mĩthabibũ yao, na mĩkũyũ,
\q2 na akiunanga mĩtĩ ya bũrũri wao.
\q1 
\v 34 Aaririe, nacio ngigĩ igĩũka,
\q2 na ndaahi itangĩtarĩka;
\q1 
\v 35 ikĩrĩa kĩndũ gĩothe kĩarĩ kĩĩruru bũrũri-inĩ wao,
\q2 na ikĩrĩa maciaro ma tĩĩri wao.
\q1 
\v 36 Ningĩ akĩũraga marigithathi mothe ma bũrũri wao,
\q2 maciaro ma mbere ma ũciari wao wothe.
\b
\q1 
\v 37 Nĩaarutire Isiraeli makiuma kuo, makuuĩte betha na thahabu,
\q2 na gatagatĩ ka mĩhĩrĩga yao hatiarĩ mũndũ o na ũmwe warĩ mũhinyaru.
\q1 
\v 38 Andũ a Misiri nĩmakenire moima kuo,
\q2 tondũ nĩmanyiitĩtwo nĩ guoya wa andũ acio a Isiraeli.
\q1 
\v 39 Nĩatambũrũkirie itu rĩmahumbagĩre,
\q2 o na mwaki wa kũmamũrĩkagĩra ũtukũ.
\q1 
\v 40 Metirie irio, nake akĩmarehere tũmakia-arũme,
\q2 na akĩmahũũnia na irio cia igũrũ.
\q1 
\v 41 Aatũranirie rwaro rwa ihiga, namo maaĩ magĩtothoka;
\q2 magĩgĩtherera ta rũũĩ kũu werũ-inĩ.
\b
\q1 
\v 42 Nĩgũkorwo nĩaririkanire kĩĩranĩro gĩake gĩtheru
\q2 kĩrĩa aarĩkanĩire na ndungata yake Iburahĩmu.
\q1 
\v 43 Nĩaarutire andũ ake makiuma kũu makenete,
\q2 akĩruta acio ake athuure makĩanagĩrĩra nĩ gũkena;
\q1 
\v 44 akĩmahe mabũrũri ma ndũrĩrĩ,
\q2 nao magĩtuĩka a kũgaya kĩrĩa andũ angĩ maanogeire,
\q1 
\v 45 nĩguo marũmagie mataaro make,
\q2 na maathĩkagĩre mawatho make.
\b
\q1 Goocai Jehova.
\c 106
\s1 Kuumbũra Mehia ma Isiraeli
\q1 
\v 1 Goocai Jehova.
\b
\q1 Cookeriai Jehova ngaatho, nĩgũkorwo nĩ mwega;
\q2 wendo wake ũtũũraga nginya tene.
\q1 
\v 2 Nũũ ũngiuga ciĩko cia hinya cia Jehova,
\q2 kana aanĩrĩre kũna ũgooci wake wothe?
\q1 
\v 3 Kũrathimwo-rĩ, nĩ arĩa marũmagia kĩhooto,
\q2 arĩa meekaga ũrĩa kwagĩrĩire hĩndĩ ciothe.
\q1 
\v 4 Ndirikanaga, Wee Jehova, hĩndĩ ĩrĩa ũgwĩka andũ aku wega,
\q2 ũndeithagie rĩrĩa ũkũmahonokia,
\q1 
\v 5 nĩguo ngenagĩre ũgaacĩru wa andũ aku athuure,
\q2 nĩguo ngwatanagĩre gĩkeno-inĩ kĩa rũrĩrĩ rwaku,
\q2 na nyiitanagĩre na igai rĩaku tũgĩkũgooca.
\b
\q1 
\v 6 Ithuĩ nĩtwĩhĩtie, o ta ũrĩa maithe maitũ meehirie;
\q2 nĩtwĩkĩte ũũru na tũkaagana.
\q1 
\v 7 Rĩrĩa maithe maitũ maarĩ Misiri,
\q2 matiarũmbũirie ciama ciaku;
\q1 matiigana kũririkana ũtugi waku mũingĩ,
\q2 na makĩrema marĩ hũgũrũrũ-inĩ cia iria, o Iria rĩu Itune.
\q1 
\v 8 No nĩamahonokirie nĩ ũndũ wa rĩĩtwa rĩake,
\q2 nĩguo atũme hinya wake mũnene ũmenyeke.
\q1 
\v 9 Nĩakũũmire Iria Itune, narĩo rĩkĩhũa;
\q2 akĩmagereria kũu kũriku taarĩ werũ-inĩ.
\q1 
\v 10 Nĩamahonokirie guoko-inĩ kwa andũ arĩa maamathũire;
\q2 akĩmakũũra kuuma guoko-inĩ gwa thũ.
\q1 
\v 11 Maaĩ macio nĩmahubanĩirie amuku ao;
\q2 gũtirĩ o na ũmwe wao watigarire.
\q1 
\v 12 Hĩndĩ ĩyo magĩĩtĩkia ciĩranĩro ciake,
\q2 na makĩmũinĩra, makĩmũgooca.
\b
\q1 
\v 13 No makĩriganĩrwo o narua nĩ ũrĩa ekĩte,
\q2 na matiigana gweterera ũtaaro wake.
\q1 
\v 14 Marĩ kũu werũ-inĩ makĩnyiitwo nĩ thuti;
\q2 makĩgeria Mũrungu marĩ kũu gũtagĩĩaga kĩndũ.
\q1 
\v 15 Nĩ ũndũ ũcio akĩmahe kĩrĩa maamwĩtirie,
\q2 no akĩmatũmĩra mũrimũ wa kũmanyariira.
\b
\q1 
\v 16 Ningĩ nĩmaiguĩrĩire Musa ũiru marĩ kũu kambĩ-inĩ,
\q2 o na makĩiguĩra Harũni ũiru, o ũcio wamũrĩirwo Jehova.
\q1 
\v 17 Thĩ ĩgĩatũka na ĩkĩmeria Dathani;
\q2 ningĩ ĩgĩthika thiritũ ya Abiramu.
\q1 
\v 18 Mwaki ũgĩakana gatagatĩ-inĩ ka arũmĩrĩri ao;
\q2 rũrĩrĩmbĩ rũgĩcina andũ acio aaganu.
\b
\q1 
\v 19 Nĩmathondekire gacaũ marĩ kũu Horebu,
\q2 makĩhooya mũhianano ũtweketio kuuma kũrĩ kĩgera.
\q1 
\v 20 Maakũũranirie Riiri wa Ngai
\q2 na mũhianano wa ndegwa ĩrĩa ĩrĩĩaga nyeki.
\q1 
\v 21 Makĩriganĩrwo nĩ Mũrungu ũrĩa wamahonokirie,
\q2 ũrĩa wekĩte maũndũ manene kũu bũrũri wa Misiri,
\q1 
\v 22 akĩringa ciama bũrũri wa Hamu,
\q2 na agĩĩka mawĩko ma gwĩtigĩrwo Iria-inĩ Itune.
\q1 
\v 23 Nĩ ũndũ ũcio akiuga nĩekũmaniina,
\q2 tiga nĩ Musa, ũrĩa we aathurĩte,
\q1 warũgamire mbere yake,
\q2 akĩmũthaitha ndakamaniine na mangʼũrĩ make.
\b
\q1 
\v 24 Ningĩ makĩnyarara bũrũri ũcio mwega,
\q2 makĩaga gwĩtĩkia kĩĩranĩro gĩake.
\q1 
\v 25 Makĩnuguna marĩ hema-inĩ ciao,
\q2 na makĩaga gwathĩkĩra Jehova.
\q1 
\v 26 Nĩ ũndũ ũcio akĩoya guoko na igũrũ,
\q2 akĩĩhĩta atĩ nĩakamangʼaũranĩria kũu werũ-inĩ,
\q1 
\v 27 angʼaũranĩrie njiaro ciao kũu gatagatĩ-inĩ ka ndũrĩrĩ,
\q2 aciharaganĩrie kũu mabũrũri-inĩ guothe.
\b
\q1 
\v 28 Nĩmeyohanirie na Baali ya Peoru,
\q2 na makĩrĩa magongona maarutĩirwo ngai itarĩ muoyo;
\q1 
\v 29 magĩtũma Jehova arakare nĩ ũndũ wa ciĩko ciao cia waganu,
\q2 naguo mũthiro ũgĩtuthũka gatagatĩ-inĩ kao.
\q1 
\v 30 No Finehasi akĩrũgama na igũrũ, akĩherithia arĩa maarĩ na mahĩtia,
\q2 naguo mũthiro ũgĩthira.
\q1 
\v 31 Ũhoro ũcio ũgĩtũma atuuo nĩ mũthingu
\q2 kũrĩ njiarwa na njiarwa nginya tene.
\b
\q1 
\v 32 Nao makĩrakaria Jehova hau maaĩ-inĩ ma Meriba,
\q2 nake Musa agĩkinyĩrĩrwo nĩ thĩĩna nĩ ũndũ wao;
\q1 
\v 33 nĩgũkorwo nĩmaremeire Roho wa Ngai,
\q2 nake Musa akĩaria ciugo itaagĩrĩire.
\b
\q1 
\v 34 Matiigana kũniina ndũrĩrĩ icio
\q2 ta ũrĩa Jehova aamaathĩte,
\q1 
\v 35 no nĩgũtukana maatukanire na ndũrĩrĩ,
\q2 na makĩrũmĩrĩra mĩtugo yao.
\q1 
\v 36 Makĩhooya mĩhianano yao,
\q2 ĩrĩa yatuĩkire mũtego kũrĩ o.
\q1 
\v 37 Makĩrutĩra ndaimono
\q2 aanake na airĩtu ao marĩ magongona.
\q1 
\v 38 Magĩita thakame ĩteehĩtie,
\q2 thakame ya aanake na airĩtu ao,
\q1 arĩa maarutire marĩ magongona kũrĩ mĩhianano ya Kaanani,
\q2 naguo bũrũri ũgĩthaahio nĩ thakame yao.
\q1 
\v 39 Nĩmethaahirie o ene nĩ gwĩka ũguo meekire;
\q2 na ũndũ wa ciĩko ciao makĩhũũra ũmaraya.
\b
\q1 
\v 40 Nĩ ũndũ ũcio Jehova akĩrakarĩra andũ ake,
\q2 na agĩthũũra igai rĩake mũno.
\q1 
\v 41 Akĩmaneana kũrĩ ndũrĩrĩ,
\q2 nĩguo maathagwo nĩ thũ ciao.
\q1 
\v 42 Thũ ciao ikĩmahinyĩrĩria,
\q2 na ikĩmaiga rungu rwa wathani wao.
\q1 
\v 43 Nake akĩmateithũra mahinda maingĩ,
\q2 no-o makĩrema,
\q2 makĩrikĩra mehia-inĩ mao.
\b
\q1 
\v 44 Nowe akĩona mĩnyamaro yao
\q2 rĩrĩa aaiguire magĩkaya;
\q1 
\v 45 nĩ ũndũ wao akĩririkana kĩrĩkanĩro gĩake,
\q2 na nĩ ũndũ wa wendo wake mũnene akĩringwo nĩ tha.
\q1 
\v 46 Agĩtũma maiguĩrwo tha
\q2 nĩ arĩa othe maamatahĩte.
\b
\q1 
\v 47 Tũhonokie, Wee Jehova Ngai witũ,
\q2 na ũtũcookanĩrĩrie ũtũrute kũrĩ ndũrĩrĩ,
\q1 nĩguo tũcookagĩrie rĩĩtwa rĩaku itheru ngaatho,
\q2 na twĩrahagĩre ũgooci waku.
\b
\q1 
\v 48 Jehova arogoocwo, o we Ngai wa Isiraeli,
\q2 kuuma tene wa tene, nginya o tene na tene.
\q1 Nao andũ othe nĩmakiuge, “Ameni!”
\b
\q1 Goocai Jehova.
\c 107
\ms1 Ibuku rĩa Gatano
\mr Thaburi 107–150
\s1 Gũcookia Ngaatho nĩ ũndũ wa Kũhonokio Mathĩĩna-inĩ Maingĩ
\q1 
\v 1 Cookeriai Jehova ngaatho, nĩgũkorwo nĩ mwega;
\q2 wendo wake ũtũũraga tene na tene.
\q1 
\v 2 Andũ arĩa makũũrĩtwo nĩ Jehova nĩmakiuge ũguo:
\q2 o acio akũũrĩte kuuma guoko-inĩ gwa thũ,
\q1 
\v 3 o acio aacookanĩrĩirie amarutĩte mabũrũri-inĩ,
\q2 kuuma mwena wa irathĩro na wa ithũĩro,
\q2 na kuuma mwena wa gathigathini na wa gũthini.
\b
\q1 
\v 4 Amwe morũũrire werũ-inĩ ũtarĩ kĩndũ,
\q2 maagĩte njĩra ya kũmakinyia itũũra inene kũrĩa mangĩatũũrire.
\q1 
\v 5 Maarĩ ahũtu na makanyoota,
\q2 na makaaga mwĩhoko thĩinĩ wao.
\q1 
\v 6 Nao magĩkaĩra Jehova marĩ mĩnyamaro-inĩ,
\q2 nake akĩmahonokia kuuma thĩĩna-inĩ.
\q1 
\v 7 Aamagereirie njĩra nũngarũ,
\q2 nginya magĩkinya itũũra inene kũrĩa mangĩonire gwa gũtũũra.
\q1 
\v 8 Nĩmagĩcookerie Jehova ngaatho nĩ ũndũ wa wendo wake ũrĩa ũtathiraga,
\q2 na mawĩko make ma magegania marĩa eekĩire andũ,
\q1 
\v 9 nĩgũkorwo nĩwe ũnyootoraga andũ arĩa anyootu,
\q2 na akahũũnia arĩa ahũtu na maũndũ mega.
\b
\q1 
\v 10 Amwe maaikarĩte nduma-inĩ o na nduma-inĩ nene mũno,
\q2 makĩnyamarĩka marĩ ohe na mĩnyororo ya kĩgera,
\q1 
\v 11 nĩgũkorwo nĩmaremeire ciugo cia Mũrungu,
\q2 o na makĩagĩra kĩrĩra kĩa Ũrĩa-ũrĩ-Igũrũ-Mũno bata.
\q1 
\v 12 Nĩ ũndũ ũcio akĩmarutithia wĩra wa hinya;
\q2 nao makĩhĩngwo na gũkĩaga wa kũmateithia.
\q1 
\v 13 Hĩndĩ ĩyo magĩkaĩra Jehova marĩ thĩĩna-inĩ,
\q2 nake akĩmahonokia kuuma mĩnyamaro-inĩ.
\q1 
\v 14 Nake aamarutire nduma-inĩ, akĩmaruta kũu nduma-inĩ nene mũno,
\q2 na agĩtuanga mĩnyororo ĩrĩa moohetwo nayo.
\q1 
\v 15 Nĩmagĩcookerie Jehova ngaatho nĩ ũndũ wa wendo wake ũrĩa ũtathiraga,
\q2 na mawĩko make ma magegania marĩa eekĩire andũ,
\q1 
\v 16 nĩgũkorwo nĩoinangaga ihingo cia gĩcango
\q2 na akoinanga mĩgĩĩko ya kĩgera.
\b
\q1 
\v 17 Amwe maatuĩkire andũ akĩĩgu nĩ ũndũ wa mĩthiĩre yao ya ũremi,
\q2 o na nĩ ũndũ wa waganu wao magĩtuĩka a gũthĩĩnĩka.
\q1 
\v 18 Magĩtuĩka a kũira ngoro mona irio o ciothe,
\q2 nao magĩkuhĩrĩria ihingo cia gĩkuũ.
\q1 
\v 19 Hĩndĩ ĩyo magĩkaĩra Jehova marĩ mĩnyamaro-inĩ,
\q2 nake akĩmaruta thĩĩna-inĩ.
\q1 
\v 20 Aatũmire kiugo gĩake akĩmahonia;
\q2 aamateithũrire kuuma mbĩrĩra-inĩ.
\q1 
\v 21 Nĩmagĩcookerie Jehova ngaatho nĩ ũndũ wa wendo wake ũrĩa ũtathiraga,
\q2 na mawĩko make ma magegania marĩa eekĩire andũ.
\q1 
\v 22 Nĩmakĩrute igongona rĩa gũcookia ngaatho,
\q2 na mamenyithanie mawĩko make makĩinaga nyĩmbo cia gĩkeno.
\b
\q1 
\v 23 Angĩ maagereire iria-inĩ marĩ marikabu-inĩ;
\q2 maathiiaga wonjoria kũu maria-inĩ manene.
\q1 
\v 24 Nĩmoonire mawĩko ma Jehova,
\q2 makĩona ciĩko ciake cia magegania kũu kũriku.
\q1 
\v 25 Nĩgũkorwo aaririe, akĩarahũra kĩhuhũkanio
\q2 kĩrĩa gĩatũmire iria rĩgĩe na makũmbĩ.
\q1 
\v 26 Marikabu igĩikanio na igũrũ, na igĩcooka igĩikanio na kũu thĩ kũrĩa kũriku;
\q2 andũ acio magĩkua ngoro nĩ ũndũ marĩ ũgwati-inĩ mũnene.
\q1 
\v 27 Makĩagaga na magĩtũgũũga ta andũ arĩĩu;
\q2 ũũgĩ wao wothe nĩwakinyĩte mũthia.
\q1 
\v 28 Hĩndĩ ĩyo magĩkaĩra Jehova marĩ thĩĩna-inĩ,
\q2 nake akĩmahonokia kuuma mĩnyamaro-inĩ.
\q1 
\v 29 Nake akĩhooreria kĩhuhũkanio kĩu kĩnene;
\q2 namo makũmbĩ ma iria rĩu magĩkirio ki.
\q1 
\v 30 Nao magĩkena nĩ iria rĩu kũhoorera,
\q2 nake akĩmakinyia nginya gĩcukĩro-inĩ kĩa marikabu kĩrĩa merirĩirie gũkinya.
\q1 
\v 31 Nĩmagĩcookerie Jehova ngaatho nĩ ũndũ wa wendo wake ũrĩa ũtathiraga,
\q2 na mawĩko make ma magegania marĩa eekĩire andũ.
\q1 
\v 32 Nĩmamũtũũgĩrie kĩũngano-inĩ kĩa andũ,
\q2 na mamũgooce marĩ kĩama-inĩ kĩa athuuri.
\b
\q1 
\v 33 Aagarũrire kũrĩa kwarĩ njũũĩ gũgĩtuĩka werũ,
\q2 nakuo kũrĩa kwarĩ ithima ciathereraga gũgĩtuĩka kũndũ kũngʼaru,
\q1 
\v 34 naguo bũrũri ũrĩa woimaga irio mũno akĩũtua werũ wa igata ũtaarĩ kĩndũ,
\q2 tondũ wa waganu wa andũ arĩa maatũũraga kuo.
\q1 
\v 35 Aagarũrire kũrĩa kwarĩ werũ gũkĩgĩa tũria twa maaĩ,
\q2 nakuo kũrĩa kwarĩ kũngʼaru agĩtũma gũkunũke ithima;
\q1 
\v 36 nao andũ arĩa maarĩ ahũtu akĩmarehe kuo,
\q2 nao magĩaka itũũra inene rĩa gũikara.
\q1 
\v 37 Maarĩmire mĩgũnda na makĩhaanda mĩthabibũ,
\q2 ĩrĩa yaciarire magetha maingĩ;
\q1 
\v 38 aamarathimire nao makĩingĩha mũno,
\q2 na ndaarekire mahiũ mao manyiihe.
\b
\q1 
\v 39 Mũigana wao ũgĩcooka ũkĩnyiiha, na makĩagithio hinya,
\q2 nĩ kũhinyĩrĩrio, na kũnyariirĩka, o na kĩeha;
\q1 
\v 40 we ũrĩa ũnyararithagia andũ arĩa marĩ igweta-rĩ,
\q2 agĩtũma morũũre kũndũ gũtaarĩ njĩra.
\q1 
\v 41 No rĩrĩ, nĩarutire andũ arĩa abatari mathĩĩna-inĩ,
\q2 na andũ a nyũmba ciao akĩmaingĩhia o ta mahiũ.
\q1 
\v 42 Andũ arĩa arũngĩrĩru monaga ũguo magakena,
\q2 no arĩa othe aaganu nĩgũkirio makiragio.
\b
\q1 
\v 43 Mũndũ o wothe mũũgĩ-rĩ, nĩarũmbũiye maũndũ macio,
\q2 na ecũũranie ũhoro wa wendo mũnene wa Jehova.
\c 108
\s1 Ihooya rĩa kũũria Ũtoorania
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai, ngoro yakwa nĩĩkindĩirie;
\q2 nĩkũina ngũina, ngũgooce na rwĩmbo na muoyo wakwa wothe.
\q1 
\v 2 Arahũka, wee kĩnanda kĩa mũgeeto na gĩa kĩnũbi!
\q2 Ngwarahũka ruoro rũgĩtema.
\q1 
\v 3 Wee Jehova nĩngũkũgooca, ngũgooce gatagatĩ-inĩ ka ndũrĩrĩ;
\q2 nĩngũkũinĩra ndĩ gatagatĩ-inĩ ka andũ.
\q1 
\v 4 Nĩgũkorwo wendo waku nĩ mũnene, ũkaraiha gũkĩra igũrũ;
\q2 wĩhokeku waku ũkinyaga o matu-inĩ.
\q1 
\v 5 Wee Ngai tũũgĩra, ũtũũgĩrio igũrũ rĩa igũrũ,
\q2 riiri waku nĩũgĩe igũrũ rĩa thĩ yothe.
\b
\q1 
\v 6 Tũhonokie na ũtũteithie na guoko gwaku kwa ũrĩo,
\q2 nĩguo ũteithũre arĩa wendete.
\q1 
\v 7 Ngai nĩarĩtie arĩ handũ hake harĩa haamũre, akoiga atĩrĩ:
\q2 “Nĩngatũranga Shekemu ndĩ na gĩkeno kĩingĩ,
\q2 na thimĩre andũ akwa Gĩtuamba gĩa Sukothu.
\q1 
\v 8 Gileadi nĩ gwakwa, o na Manase no gwakwa;
\q2 Efiraimu nĩ ngũbia yakwa ya kĩgera,
\q2 na Juda nĩ mũthĩgi wakwa wa ũthamaki.
\q1 
\v 9 Moabi nĩ kĩraĩ gĩakwa gĩa gwĩthambĩra,
\q2 na Edomu nĩho njikagia kĩraatũ gĩakwa;
\q2 nĩngwanĩrĩra nĩ ũrĩa ndooretie bũrũri wa Filistia.”
\b
\q1 
\v 10 Nũũ ũkũnginyia itũũra rĩrĩa inene rĩirigĩre?
\q2 Nũũ ũkũndongoria andware Edomu?
\q1 
\v 11 Githĩ tiwe, Wee Ngai, o Wee ũtũtiganĩirie,
\q2 na ũgatiga gũtwarana na mbũtũ ciitũ cia ita?
\q1 
\v 12 Tũteithie ũtũhootanĩre harĩ thũ ciitũ,
\q2 nĩgũkorwo ũteithio wa mũndũ nĩ wa tũhũ.
\q1 
\v 13 Ngai arĩ hamwe na ithuĩ nĩtũkũhootana,
\q2 na nĩakarangĩrĩria thũ ciitũ thĩ.
\c 109
\s1 Ihooya rĩa Mũndũ kũũria Arĩhĩrio
\d Thaburi ya Daudi
\q1 
\v 1 Wee Ngai, ũrĩa ngoocaga,
\q2 ndũgaakire,
\q1 
\v 2 nĩgũkorwo andũ arĩa aaganu na a maheeni
\q2 nĩmathamĩtie tũnua nĩguo manjũkĩrĩre;
\q2 nĩmarĩtie ũhoro wakwa na rũrĩmĩ rwa maheeni.
\q1 
\v 3 Mandigicĩirie makĩaragia ndeto cia rũthũũro;
\q2 maatharĩkagĩra hatarĩ gĩtũmi.
\q1 
\v 4 Handũ ha wendo ũrĩa ndĩmendete naguo,
\q2 o nĩ gũũthitanga maathitangaga,
\q2 no niĩ nĩkũhooya ndĩmahooyagĩra.
\q1 
\v 5 Mandĩhaga wega na ũũru,
\q2 na makandĩha wendani na rũthũũro.
\b
\q1 
\v 6 Mũndũ ũrĩa wĩkĩte ũguo mũigĩre mũndũ mũũru amũũkĩrĩre;
\q2 mwena wake wa ũrĩo nĩkũrũgame mũndũ wa kũmũthitanga.
\q1 
\v 7 Aacirithio-rĩ, nĩatuuagwo mwĩhia,
\q2 na kũhooya gwake gũgĩtuĩke no kwĩhia.
\q1 
\v 8 Matukũ make maronyiiha;
\q2 ũtongoria wake ũrooywo nĩ mũndũ ũngĩ.
\q1 
\v 9 Ciana ciake irotuĩka cia ngoriai,
\q2 na mũtumia wake atuĩke wa ndigwa.
\q1 
\v 10 Ciana ciake irotuĩka njara-rũhĩ cia gũcangacanga;
\q2 iroingatwo ciume mĩciĩ yao ĩyo mĩanangĩku.
\q1 
\v 11 Indo ciake ciothe irotahwo nĩ mũndũ ũrĩa marĩ thiirĩ nake;
\q2 andũ a kũngĩ nĩmeyoere maciaro ma wĩra wake.
\q1 
\v 12 Aroaga mũndũ ũngĩmwonia ũtugi,
\q2 o na kana mũndũ ũngĩiguĩra ciana icio ciake cia ngoriai tha.
\q1 
\v 13 Njiaro ciake iroeherio,
\q2 na marĩĩtwa maacio mathario kuuma rũciaro-inĩ rũrĩa rũgooka.
\q1 
\v 14 Waganu wa maithe make ũrotũũra ũririkanagwo nĩ Jehova;
\q2 wĩhia wa nyina ũroaga gũgaathario o na rĩ.
\q1 
\v 15 Mehia mao marotũũra hĩndĩ ciothe marĩ mbere ya Jehova,
\q2 nĩguo akaaniina kũririkanwo kwao gũkũ thĩ.
\b
\q1 
\v 16 Nĩgũkorwo mũndũ ũcio we ndarĩ hĩndĩ eciiragia ũhoro wa gũtugana,
\q2 no aingatithagia mũndũ ũrĩa mũthĩĩni, na ũrĩa mũbatari,
\q2 o na ũrĩa mũthuthĩku ngoro, o nginya akamooraga.
\q1 
\v 17 Aronyiitwo nĩ kĩrumi,
\q2 tondũ we endete o kũruma andũ manyiitwo nĩ kĩrumi;
\q1 kĩrathimo kĩromũraihĩrĩria,
\q2 tondũ we ndendaga kũrathimana.
\q1 
\v 18 Ehumbaga kĩrumi taarĩ nguo;
\q2 kĩamũtoonyire mwĩrĩ ta maaĩ,
\q2 o na gĩkĩmũtoonya mahĩndĩ-inĩ taarĩ maguta.
\q1 
\v 19 Kĩrotuĩka taarĩ nguo ya igũrũ erigiicĩirie,
\q2 na gĩtuĩke taarĩ mũcibi ehotorete nginya tene.
\q1 
\v 20 Rĩrĩ nĩrĩtuĩke irĩhi rĩa Jehova kũrĩ arĩa maathitangaga,
\q2 o kũrĩ arĩa maaragia ũũru igũrũ rĩakwa.
\q1 
\v 21 No rĩrĩ, Wee Mwathani Jehova,
\q2 njĩka maũndũ mega nĩ ũndũ wa rĩĩtwa rĩaku;
\q2 ndeithũra tondũ wa wega wa wendo waku.
\q1 
\v 22 Nĩgũkorwo ndĩ mũthĩĩni na mũbatari,
\q2 nayo ngoro yakwa nĩĩgurarĩtio thĩinĩ wakwa.
\q1 
\v 23 Ndĩ hakuhĩ kũbuĩria o ta kĩĩruru kĩa hwaĩ-inĩ;
\q2 hurutagwo nĩ rũhuho o ta ngigĩ.
\q1 
\v 24 Maru makwa nĩmaregerete nĩ kwĩima kũrĩa;
\q2 mwĩrĩ wakwa ũhĩnjĩte nĩ kwaga maguta.
\q1 
\v 25 Nduĩkĩte kĩndũ gĩa kũnyũrũrio nĩ andũ arĩa maathitangaga;
\q2 rĩrĩa maanyona, mainainagia mĩtwe.
\b
\q1 
\v 26 Wee Jehova Ngai wakwa, ndeithia;
\q2 honokia kũringana na wendo waku.
\q1 
\v 27 Tũma mamenye atĩ kũu nĩ guoko gwaku,
\q2 mamenye atĩ Wee Jehova, nĩwe wĩkĩte ũguo.
\q1 
\v 28 O nĩ marumanage, no wee ũrathimanage;
\q2 rĩrĩa maatharĩkĩra nĩmarĩconorithagio,
\q2 no ndungata yaku no gũkena ĩrĩkenaga.
\q1 
\v 29 Arĩa maathitangaga makaahumbwo njono
\q2 na mohwo thoni taarĩ nguo ya igũrũ.
\b
\q1 
\v 30 Nĩndĩrĩkumagia Jehova mũno na kanua gakwa;
\q2 nĩndĩrĩmũgoocaga ndĩ kĩrĩndĩ-inĩ kĩnene.
\q1 
\v 31 Nĩgũkorwo arũgamaga guoko-inĩ kwa ũrĩo kwa mũndũ ũrĩa mũbatari,
\q2 nĩguo ahonokagie muoyo wake harĩ andũ arĩa mangĩmũtua nĩ mwĩhia.
\c 110
\s1 Ũhootani wa Mũthamaki Ũrĩa Mũthĩnjĩri-Ngai
\d Thaburi ya Daudi
\q1 
\v 1 Jehova nĩerire Mwathani wakwa atĩrĩ:
\q2 “Ikara guoko-inĩ gwakwa kwa ũrĩo,
\q1 nginya rĩrĩa ngaatũma thũ ciaku
\q2 ituĩke gaturwa ka makinya maku.”\f + \fr 110:1 \ft Itĩ cia ũnene cia tene ciakoragwo handũ hatũũgĩru harĩa haambatagwo na ngathĩ.\f*
\b
\q1 
\v 2 Mũthĩgi wa hinya waku-rĩ,
\q2 Jehova nĩakaũtambũrũkia kuuma Zayuni;
\q2 nĩũgaathana ũrĩ gatagatĩ ga thũ ciaku.
\q1 
\v 3 Ikundi ciaku cia ita nĩikerutĩra
\q2 mũthenya waku wa mbaara.
\q1 Igooka irĩ na ũgemu wa ũtheru,
\q2 aanake aku mahaana ta ime rĩoima nda
\q2 ya rũciinĩ ruoro rũgĩtema.
\b
\q1 
\v 4 Jehova nĩehĩtĩte
\q2 na ndangĩĩricũkwo, akoiga atĩrĩ:
\q1 “Wee ũrĩ mũthĩnjĩri-Ngai nginya tene,
\q2 o ta ũrĩa Melikisedeki aatariĩ.”
\b
\q1 
\v 5 Mwathani arĩ guoko-inĩ gwaku kwa ũrĩo;
\q2 nĩakahehenja athamaki mũthenya wa mangʼũrĩ make.
\q1 
\v 6 Nĩagatuĩra ndũrĩrĩ ciira, aige ciimba irũndo,
\q2 na ahehenje aathani a thĩ yothe.
\q1 
\v 7 Nĩakanyua maaĩ ma karũũĩ karĩ mũkĩra-inĩ;
\q2 nĩ ũndũ ũcio nĩakambararia mũtwe wake.
\c 111
\s1 Kũgaathĩrĩria Ciĩko cia Ngai cia Kũgegania
\q1 
\v 1 Goocai Jehova.
\b
\q1 Nĩngũkumia Jehova na ngoro yakwa yothe
\q2 ndĩ thiritũ-inĩ ya arĩa arũngĩrĩru, o na kĩũngano-inĩ.
\b
\q1 
\v 2 Ciĩko cia Jehova nĩ cia magegania;
\q2 nĩicũũranagio nĩ arĩa othe makenagio nĩcio.
\q1 
\v 3 Ciĩko ciake ciyũrĩte riiri na ũkaru,
\q2 naguo ũthingu wake ũtũũraga nginya tene.
\q1 
\v 4 Nĩatũmĩte magegania make maririkanwo;
\q2 Jehova nĩ mũtugi na nĩ mũigua tha.
\q1 
\v 5 Arĩa mamwĩtigagĩra nĩamaheaga irio;
\q2 egũtũũra aririkanaga kĩrĩkanĩro gĩake nginya tene.
\q1 
\v 6 Nĩonetie andũ ake mawĩra make ma hinya,
\q2 nĩ ũndũ wa kũmahe mabũrũri ma ndũrĩrĩ iria ingĩ.
\q1 
\v 7 Mawĩra ma moko make nĩ ma kwĩhokeka, na nĩ ma kĩhooto;
\q2 mataaro make mothe nĩ ma kwĩhokwo.
\q1 
\v 8 Nĩ marũmu nginya tene na tene,
\q2 maheanĩtwo na wĩhokeku na ũrũngĩrĩru.
\q1 
\v 9 Nĩakinyĩirie andũ ake ũkũũri;
\q2 aamũrire kĩrĩkanĩro gĩake kĩrĩ gĩa gũtũũra nginya tene:
\q2 rĩĩtwa rĩake nĩ itheru na nĩ rĩa gwĩtigĩrwo.
\b
\q1 
\v 10 Kĩambĩrĩria kĩa ũũgĩ nĩ gwĩtigĩra Jehova;
\q2 arĩa othe marũmagĩrĩra mataaro make nĩmagĩĩaga na ũmenyo mwega.
\q2 Kũgoocwo nĩ gwake tene na tene.
\c 112
\s1 Irathimo cia Andũ arĩa Athingu
\q1 
\v 1 Goocai Jehova.
\b
\q1 Kũrathimwo nĩ mũndũ ũrĩa wĩtigagĩra Jehova,
\q2 ũrĩa ũkenagĩra maathani make mũno.
\b
\q1 
\v 2 Ciana ciake nĩigatuĩka cia bata bũrũri-inĩ;
\q2 rũciaro rwa arĩa arũngĩrĩru nĩrũkarathimwo.
\q1 
\v 3 Gwake mũciĩ gũkoragwo na ũtonga na indo nyingĩ,
\q2 naguo ũthingu wake ũtũũraga nginya tene.
\q1 
\v 4 Mũndũ ũrĩa mũrũngĩrĩru o na arĩ nduma-inĩ nĩatheragĩrwo nĩ ũtheri,
\q2 ũgatherera mũndũ ũcio mũtugani, ningĩ arĩ tha, o na nĩ mũthingu.
\q1 
\v 5 Mũndũ ũcio mũtugani na ũheanaga o ũguo tũhũ,
\q2 o ũcio wĩkaga maũndũ make na kĩhooto-rĩ, nĩarĩonaga maũndũ mega.
\q1 
\v 6 Ti-itherũ mũndũ ũcio ndakenyenyeka;
\q2 mũndũ mũthingu atũũraga aririkanagwo nginya tene.
\q1 
\v 7 Angĩigua ũhoro mũũru ndangĩĩtigĩra;
\q2 ngoro yake nĩĩkindĩire, aikaraga ehokete o Jehova.
\q1 
\v 8 Ngoro yake nĩngitĩre, ndangĩĩtigĩra;
\q2 marigĩrĩrio-inĩ nĩakoona gũtoorio gwa thũ ciake.
\q1 
\v 9 Nĩahurunjĩte iheo ciake akahe andũ arĩa athĩĩni,
\q2 naguo ũthingu wake ũtũũraga nginya tene;
\q2 rũhĩa rwake nĩrũkambarario na igũrũ, aheo gĩtĩĩo.
\b
\q1 
\v 10 Mũndũ ũrĩa mwaganu nĩakoona ũguo na arakare,
\q2 nĩakahagarania magego make, acooke abuĩrie;
\q2 merirĩria ma arĩa aaganu matigaakinyanĩra.
\c 113
\s1 Ngai Mũteithia wa Andũ arĩa Abatari
\q1 
\v 1 Goocai Jehova.
\b
\q1 Mũgoocei, inyuĩ ndungata cia Jehova,
\q2 mũgooce rĩĩtwa rĩa Jehova.
\q1 
\v 2 Rĩĩtwa rĩa Jehova rĩrogoocwo,
\q2 kuuma rĩu nginya tene na tene.
\q1 
\v 3 Kuuma o irathĩro rĩa riũa nginya ithũĩro rĩarĩo,
\q2 rĩĩtwa rĩa Jehova nĩrĩgoocagwo.
\b
\q1 
\v 4 Jehova nĩatũũgĩrĩtio igũrũ rĩa ndũrĩrĩ ciothe,
\q2 riiri wake ũrĩ igũrũ rĩa igũrũ.
\q1 
\v 5 Nũũ ũhaana ta Jehova Ngai witũ,
\q2 o Ũcio ũikaragĩra gĩtĩ kĩa ũnene kũu igũrũ,
\q1 
\v 6 o ũcio ũinamagĩrĩra arorererie
\q2 maũndũ ma igũrũ o na ma thĩ?
\b
\q1 
\v 7 Oyaga athĩĩni na igũrũ kuuma rũkũngũ-inĩ,
\q2 na agokĩria arĩa abatari, akamaruta kĩhumbu-inĩ kĩa mũhu;
\q1 
\v 8 amaikaragia hamwe na anene,
\q2 o hamwe na anene a andũ ao.
\q1 
\v 9 Atũmaga mũtumia thaata atũũre gwake mũciĩ,
\q2 agatuĩka nyina wa ciana, agakenaga.
\b
\q1 Goocai Jehova.
\c 114
\s1 Rwĩmbo rwa Bathaka
\q1 
\v 1 Rĩrĩa Isiraeli moimire bũrũri wa Misiri,
\q2 nyũmba ya Jakubu ĩkiuma kũrĩ andũ a rũthiomi rũngĩ-rĩ,
\q1 
\v 2 Juda gwatuĩkire handũ ha Ngai haamũre,
\q2 na Isiraeli gũgĩtuĩka nĩkuo arĩathanaga.
\b
\q1 
\v 3 Iria rĩonire ũguo rĩkĩũra,
\q2 naruo Rũũĩ rwa Jorodani rũgĩcooka na thuutha;
\q1 
\v 4 Irĩma igĩtũhatũũha ta ndũrũme,
\q2 natuo tũrĩma tũgĩtũhatũũha ta tũgondu.
\b
\q1 
\v 5 Kaĩ wonire atĩa, wee iria, nĩguo ũre,
\q2 nawe Jorodani, tondũ wacookire na thuutha?
\q1 
\v 6 Inyuĩ irĩma, muonete kĩ, nĩguo mũtũhatũũhe ta ndũrũme,
\q2 na inyuĩ tũrĩma, nĩguo mũtũhatũũhe ta tũgondu?
\b
\q1 
\v 7 Wee thĩ, ta kĩinaine ũrĩ mbere ya Mwathani,
\q2 ũrĩ hau mbere ya Ngai ũcio wa Jakubu,
\q1 
\v 8 o we ũcio wagarũrire rwaro rwa ihiga rũgĩtuĩka karia ka maaĩ,
\q2 narĩo ihiga rĩũmũ rĩgĩtuĩka ithima cia maaĩ.
\c 115
\s1 Ũnene wa Ngai, na Mĩhianano kwaga Kĩene
\q1 
\v 1 Ti ithuĩ, Wee Jehova, ti ithuĩ twagĩrĩire kũgoocwo,
\q2 no goocithia rĩĩtwa rĩaku,
\q2 tondũ wa wendo na wĩhokeku waku.
\b
\q1 
\v 2 Nĩ kĩĩ gĩtũmaga ndũrĩrĩ ciũrie atĩrĩ,
\q2 “Ngai wao akĩrĩ ha?”
\q1 
\v 3 Ngai witũ arĩ o igũrũ;
\q2 we ekaga o ũrĩa endaga.
\q1 
\v 4 No mĩhianano yao nĩ betha na thahabu,
\q2 wĩra ũthondeketwo na moko ma andũ.
\q1 
\v 5 Nĩĩrĩ tũnua, no ndĩaragia,
\q2 nĩĩrĩ maitho, no ndĩonaga;
\q1 
\v 6 nĩĩrĩ matũ, no ndĩiguaga,
\q2 nĩĩrĩ na maniũrũ, no ndĩiguaga mũnungo;
\q1 
\v 7 nĩĩrĩ moko, no ndĩngĩhambata kĩndũ,
\q2 nĩĩrĩ magũrũ, no ndĩngĩĩtwara;
\q2 o na nĩĩrĩ mĩmero, no ndĩngĩnyuria.
\q1 
\v 8 Andũ arĩa mamĩthondekaga makaahaana o tayo,
\q2 na noguo arĩa othe mamĩĩhokaga makaahaana.
\b
\q1 
\v 9 Wee nyũmba ya Isiraeli, wĩhokage Jehova:
\q2 we nĩwe ũteithio wao o na ngo yao.
\q1 
\v 10 Wee nyũmba ya Harũni, wĩhokage Jehova:
\q2 we nĩwe ũteithio wao o na ngo yao.
\q1 
\v 11 Inyuĩ arĩa mũmwĩtigĩrĩte, mwĩhokagei Jehova:
\q2 we nĩwe ũteithio wao na ngo yao.
\b
\q1 
\v 12 Jehova nĩatũririkanĩte na nĩegũtũrathima:
\q2 Nĩekũrathima nyũmba ya Isiraeli,
\q2 nĩekũrathima nyũmba ya Harũni,
\q1 
\v 13 nĩekũrathima arĩa metigĩrĩte Jehova,
\q2 anini na anene o ũndũ ũmwe.
\b
\q1 
\v 14 Jehova arotũma mũingĩhe,
\q2 inyuĩ na ciana cianyu.
\q1 
\v 15 Mũrorathimwo nĩ Jehova,
\q2 Mũmbi wa igũrũ na thĩ.
\b
\q1 
\v 16 Kũu igũrũ mũno nĩ kwa Jehova,
\q2 no thĩ nĩamĩheanĩte kũrĩ andũ.
\q1 
\v 17 Andũ arĩa akuũ matigoocaga Jehova,
\q2 acio maikũrũkaga kũu ũkiri-inĩ;
\q1 
\v 18 nĩ ithuĩ tũrĩkumagia Jehova,
\q2 kuuma rĩu nginya tene na tene.
\b
\q1 Goocai Jehova.
\c 116
\s1 Kũgooca Ngai nĩ ũndũ wa Kũhonio Ndwari
\q1 
\v 1 Nĩnyendete Jehova, nĩgũkorwo nĩaiguĩte mũgambo wakwa;
\q2 nĩaiguire ngĩmũthaitha anjiguĩre tha.
\q1 
\v 2 Tondũ nĩathikĩrĩirie-rĩ,
\q2 ndĩrĩmũkayagĩra rĩrĩa rĩothe ngũtũũra muoyo.
\b
\q1 
\v 3 Ndarigiicĩirio nĩ mĩhĩndo ya gĩkuũ,
\q2 ngĩkinyĩrĩrwo nĩ ruo rwa mbĩrĩra;
\q2 ngĩhootwo nĩ mĩtangĩko o na kĩeha.
\q1 
\v 4 Hĩndĩ ĩyo ngĩkaĩra rĩĩtwa rĩa Jehova, ngĩmwĩra atĩrĩ:
\q2 “Wee Jehova, honokia!”
\b
\q1 
\v 5 Jehova nĩ mũtugi na nĩ mũthingu;
\q2 Ngai witũ aiyũrĩtwo nĩ tha.
\q1 
\v 6 Jehova nĩagitagĩra andũ arĩa matarĩ oogĩ;
\q2 rĩrĩa ndahinyĩrĩirio mũno, nĩahonokirie.
\b
\q1 
\v 7 Wee ngoro yakwa-rĩ, cookerera ũhurũko waku,
\q2 nĩgũkorwo Jehova nĩagwĩkĩte wega.
\b
\q1 
\v 8 Nĩgũkorwo Wee Jehova nĩũhonoketie muoyo wakwa kuuma kũrĩ gĩkuũ,
\q2 namo maitho makwa ũkamagiria maithori,
\q2 na ũkagiria magũrũ makwa mahĩngwo,
\q1 
\v 9 nĩgeetha thiiage ndĩ mbere ya Jehova
\q2 bũrũri-inĩ wa arĩa marĩ muoyo.
\q1 
\v 10 No ndetĩkirie ũhoro wake; nĩ ũndũ ũcio ndoigire atĩrĩ,
\q2 “Nĩthĩĩnĩkĩte mũno.”
\q1 
\v 11 Nĩ ũndũ wa ũrĩa ndamakĩte, ngiuga atĩrĩ,
\q2 “Andũ othe nĩ a maheeni.”
\b
\q1 
\v 12 Nĩ kĩĩ ingĩthukĩra Jehova nakĩo
\q2 nĩ ũndũ wa wega wake wothe ũrĩa anjĩkĩte?
\q1 
\v 13 Nĩkuoya nguoya gĩkombe kĩa ũhonokio na igũrũ,
\q2 ngaĩre rĩĩtwa rĩa Jehova.
\q1 
\v 14 Nĩngũhingĩria Jehova mĩĩhĩtwa ĩrĩa ndehĩtire,
\q2 andũ ake othe marĩ ho.
\b
\q1 
\v 15 Andũ arĩa athingu marĩ bata mũno harĩ Jehova,
\q2 nĩ ũndũ ũcio ndakenaga rĩrĩa makua o ro ũguo.
\q1 
\v 16 Wee Jehova, ti-itherũ niĩ ndĩ ndungata yaku;
\q2 niĩ ndĩ ndungata yaku, mũriũ wa ndungata yaku ya mũndũ-wa-nja;
\q2 wee nĩũnjohorithĩtie mĩnyororo-inĩ.
\b
\q1 
\v 17 Nĩngũkũrutĩra igongona rĩa gũgũcookeria ngaatho,
\q2 na ngaĩre rĩĩtwa rĩa Jehova.
\q1 
\v 18 Nĩngũhingĩria Jehova mĩĩhĩtwa ĩrĩa ndehĩtire
\q2 andũ ake othe marĩ ho,
\q1 
\v 19 kũu nja-inĩ cia nyũmba ya Jehova,
\q2 o thĩinĩ waku, wee Jerusalemu.
\b
\q1 Goocai Jehova.
\c 117
\s1 Ndũrĩrĩ Ciothe kũũrio Igooce Ngai
\q1 
\v 1 Goocai Jehova, inyuĩ ndũrĩrĩ ciothe;
\q2 mũkumiei, inyuĩ andũ othe.
\q1 
\v 2 Nĩgũkorwo wendo wake nĩ mũnene harĩ ithuĩ,
\q2 na wĩhokeku wa Jehova nĩ wa gũtũũra nginya tene.
\b
\q1 Goocai Jehova.
\c 118
\s1 Gũcookia Ngaatho nĩ ũndũ wa Ũhootani
\q1 
\v 1 Cookeriai Jehova ngaatho nĩgũkorwo nĩ mwega;
\q2 wendo wake nĩ wa tene na tene.
\b
\q1 
\v 2 Andũ a Isiraeli nĩmoige atĩrĩ,
\q2 “Wendo wake nĩ wa tene na tene.”
\q1 
\v 3 Nyũmba ya Harũni nĩyuuge atĩrĩ,
\q2 “Wendo wake nĩ wa tene na tene.”
\q1 
\v 4 Andũ arĩa metigĩrĩte Jehova nĩmoige atĩrĩ,
\q2 “Wendo wake nĩ wa tene na tene.”
\b
\q1 
\v 5 Ndakaĩire Jehova ndĩ mĩnyamaro-inĩ,
\q2 nake akĩnjĩtĩka na akĩndeithũra.
\q1 
\v 6 Jehova arĩ hamwe na niĩ; ndingĩĩtigĩra.
\q2 Mũndũ-rĩ, nĩ atĩa angĩhota kũnjĩka?
\q1 
\v 7 Jehova arĩ hamwe na niĩ; nĩwe mũndeithia.
\q2 Nĩngerorera thũ ciakwa ikĩhootwo.
\b
\q1 
\v 8 Nĩ kaba kũũrĩra harĩ Jehova,
\q2 gũkĩra kwĩhoka mũndũ.
\q1 
\v 9 Nĩ kaba kũũrĩra harĩ Jehova,
\q2 gũkĩra kwĩhoka anene.
\b
\q1 
\v 10 Ndarigiicĩirio nĩ ndũrĩrĩ ciothe,
\q2 no tondũ wa kwĩhoka rĩĩtwa rĩa Jehova, ngĩciananga.
\q1 
\v 11 Ciandigiicĩirie mĩena yothe,
\q2 no tondũ wa kwĩhoka rĩĩtwa rĩa Jehova, ngĩciananga.
\q1 
\v 12 Ciathiũrũrũkĩirie na mĩena yothe ta njũkĩ,
\q2 no ikĩhora narua o ta mwaki wa mĩigua;
\q2 tondũ wa kwĩhoka rĩĩtwa rĩa Jehova ngĩciananga.
\b
\q1 
\v 13 Ndahatĩkĩtwo mũno nĩ thũ hakuhĩ ngwe,
\q2 no Jehova akĩndeithia.
\q1 
\v 14 Jehova nĩwe hinya wakwa na nĩwe ũtũmaga nyine;
\q2 nake nĩatuĩkĩte ũhonokio wakwa.
\b
\q1 
\v 15 Mbugĩrĩrio ya gĩkeno na ya ũhootani
\q2 ĩiyũrĩte hema-inĩ cia andũ arĩa athingu, atĩ:
\q1 “Guoko kwa ũrĩo kwa Jehova nĩ gwĩkĩte maũndũ manene!
\q2 
\v 16 Guoko kwa ũrĩo kwa Jehova nĩ kwambararie;
\q2 guoko kwa ũrĩo kwa Jehova nĩ gwĩkĩte maũndũ manene!”
\b
\q1 
\v 17 Niĩ gũkua ndigũkua, no nĩngũtũũra muoyo,
\q2 ngʼanage ũrĩa Jehova ekĩte.
\q1 
\v 18 Jehova nĩaherithĩtie mũno,
\q2 no ndandekereirie ngue.
\b
\q1 
\v 19 Hingũrĩrai ihingo cia ũthingu;
\q2 nĩngũtoonya njookerie Jehova ngaatho.
\q1 
\v 20 Gĩkĩ nĩkĩo kĩhingo kĩa Jehova
\q2 kĩrĩa andũ arĩa athingu mangĩtoonyera.
\q1 
\v 21 Nĩ ngaatho ngũgũcookeria, nĩgũkorwo nĩwanjĩtĩkire;
\q2 nĩũtuĩkĩte ũhonokio wakwa.
\b
\q1 
\v 22 Ihiga rĩrĩa aaki maaregire
\q2 nĩrĩo rĩtuĩkĩte ihiga inene rĩa koine;
\q1 
\v 23 Jehova nĩwe wĩkĩte ũndũ ũcio,
\q2 naguo nĩ wa magegania tũkĩwona.
\q1 
\v 24 Mũthenya ũyũ nĩ Jehova ũtũmĩte ũgĩe;
\q2 nĩtũcanjamũkei, tũkĩũkenere.
\b
\q1 
\v 25 Wee Jehova, tũhonokie;
\q2 Wee Jehova, tũma tũgaacĩre.
\q1 
\v 26 Kũrathimwo-rĩ, nĩ mũndũ ũrĩa ũgũũka na rĩĩtwa rĩa Jehova.
\q2 Ithuĩ nĩtwamũrathima tũrĩ thĩinĩ wa nyũmba ya Jehova.
\q1 
\v 27 Jehova nĩwe Mũrungu,
\q2 na nĩatũmĩte ũtheri wake ũtwarĩre.
\q1 Ambĩrĩriai gũkũngũiya, mũrĩ na mathĩgĩ moko,
\q2 mũthiĩ nginya hĩa-inĩ cia kĩgongona.
\b
\q1 
\v 28 Wee nĩwe Mũrungu wakwa, nĩngũgũcookeria ngaatho;
\q2 Wee nĩwe Ngai wakwa, nĩngũgũtũũgĩria.
\b
\q1 
\v 29 Cookeriai Jehova ngaatho, nĩgũkorwo we nĩ mwega;
\q2 wendo wake nĩ wa tene na tene.
\c 119
\s1 Ũkengu wa Watho wa Jehova
\q1 
\v 1 Kũrathimwo-rĩ, nĩ andũ arĩa mĩthiĩre yao ĩtarĩ ũcuuke,
\q2 o arĩa mathiiaga kũringana na watho wa Jehova.
\q1 
\v 2 Kũrathimwo-rĩ, nĩ andũ arĩa marũmagia kĩrĩra gĩake,
\q2 o arĩa mamũrongoragia na ngoro yothe.
\q1 
\v 3 Matirĩ ũndũ mũũru mekaga;
\q2 no kũgera mageragĩra njĩra ciake.
\q1 
\v 4 Wee nĩũheanĩte mawatho
\q2 marĩa marĩ ma gwathĩkagĩrwo na kĩyo.
\q1 
\v 5 Naarĩ korwo mĩthiĩre yakwa ĩkĩrĩ mĩkindĩrĩku
\q2 ũhoro-inĩ wa gwathĩkagĩra kĩrĩra gĩaku!
\q1 
\v 6 Hĩndĩ ĩyo ndingĩconorithio
\q2 rĩrĩa ngũcũũrania maathani maku mothe.
\q1 
\v 7 Nĩndĩrĩkũgoocaga ndĩ na ngoro nũngĩrĩru,
\q2 o ngĩĩrutaga ũhoro wa mawatho maku ma kĩhooto.
\q1 
\v 8 Nĩndĩrĩathĩkagĩra kĩrĩra kĩa watho waku;
\q2 ndũgakĩndiganĩrie o biũ.
\s1 Gwathĩkĩra Kiugo kĩa Jehova
\q1 
\v 9 Mũndũ mwĩthĩ-rĩ, angĩiga mũtũũrĩre wake ũrĩ mũtheru atĩa?
\q2 Nĩ na ũndũ wa gũtũũra athĩkagĩra kiugo gĩaku.
\q1 
\v 10 Ngũrongoragia na ngoro yakwa yothe;
\q2 ndũkanareke njũrũũre ndigane na maathani maku.
\q1 
\v 11 Nĩhithĩte kiugo gĩaku thĩinĩ wa ngoro yakwa,
\q2 nĩguo ndikae gũkwĩhĩria.
\q1 
\v 12 Wee Jehova, ũrokĩgoocwo;
\q2 kĩndute kĩrĩra kĩa watho waku.
\q1 
\v 13 Nĩndĩriugaga na ngacookera na mĩromo yakwa
\q2 ũhoro wa mawatho mothe marĩa moimĩte kanua gaku.
\q1 
\v 14 Nĩngenagio nĩkũrũmĩrĩra kĩrĩra gĩaku,
\q2 o ta ũrĩa mũndũ akenagĩra kũgĩa na ũtonga mũnene.
\q1 
\v 15 Nĩndĩrĩcũũranagia mawatho maku
\q2 na ngatarania njĩra yaku.
\q1 
\v 16 Nĩngenagĩra kĩrĩra kĩa watho waku;
\q2 ndigatiganĩria kiugo gĩaku.
\s1 Watho wa Jehova Ũrehaga Gĩkeno
\q1 
\v 17 Niĩ ndungata yaku njĩka wega, na nĩngũtũũra muoyo;
\q2 niĩ nĩndĩrĩathĩkagĩra kiugo gĩaku.
\q1 
\v 18 Hingũra maitho makwa nĩguo nyone
\q2 maũndũ ma magegania marĩa marĩ watho-inĩ waku.
\q1 
\v 19 Niĩ ndĩ mũgeni gũkũ thĩ;
\q2 ndũkaahithe maathani maku.
\q1 
\v 20 Ngoro yakwa nĩĩrahĩĩahĩĩa
\q2 nĩ kwĩrirĩria mawatho maku o mahinda mothe.
\q1 
\v 21 Wee nĩũkũũmaga arĩa etĩĩi, o acio manyiitĩtwo nĩ kĩrumi,
\q2 na arĩa morũũraga magatiga maathani maku.
\q1 
\v 22 Njehereria kĩnyũrũri na kũmenwo,
\q2 nĩgũkorwo ndũũrĩte nũmĩtie kĩrĩra gĩaku.
\q1 
\v 23 O na gũtuĩka aathani maikaraga thĩ hamwe makanjambia,
\q2 ndungata yaku nĩĩrĩcũũranagia kĩrĩra kĩa watho waku.
\q1 
\v 24 Kĩrĩra gĩaku nĩkĩo ngenagĩra;
\q2 nĩkĩo kĩĩheaga mataaro.
\s1 Gwathĩkĩra Watho wa Jehova
\q1 
\v 25 Ngometio thĩ rũkũngũ-inĩ;
\q2 tũũria muoyo wakwa kũringana na kiugo gĩaku.
\q1 
\v 26 Nĩndakwĩrire mĩthiĩre yakwa nawe ũkĩnjĩtĩka;
\q2 nduta kĩrĩra kĩa watho waku.
\q1 
\v 27 Menyithia ũrutani wa mawatho maku;
\q2 na niĩ nĩndĩrĩcũũranagia ũhoro wa magegania maku.
\q1 
\v 28 Ngoro yakwa nĩ nogu nĩ ũndũ wa kĩeha;
\q2 njĩkĩra hinya kũringana na kiugo gĩaku.
\q1 
\v 29 Njeheranĩria na mĩthiĩre ya maheeni;
\q2 nĩ ũndũ wa ũtugi waku nduta watho waku.
\q1 
\v 30 Niĩ-rĩ, ndĩĩthuurĩire njĩra ya ma;
\q2 matua maku ndĩmaigĩte ngoro-inĩ yakwa.
\q1 
\v 31 Wee Jehova, nĩnũmĩtie kĩrĩra gĩaku;
\q2 ndũkanareke njonorithio.
\q1 
\v 32 Hanyũkaga o na njĩra ya maathani maku,
\q2 nĩgũkorwo nĩwohorithĩtie ngoro yakwa.
\s1 Kũhooya Kũmenya Watho
\q1 
\v 33 Wee Jehova, nduta kũrũmĩrĩra kĩrĩra kĩa watho waku,
\q2 na niĩ ndĩkĩrũmie nginya mũthia.
\q1 
\v 34 He ũmenyo, na nĩndĩrĩrũmagia watho waku
\q2 na ndĩwathĩkagĩre na ngoro yakwa yothe.
\q1 
\v 35 Ngeragĩria njĩra-inĩ cia maathani maku,
\q2 nĩgũkorwo nĩmo ngenagĩra.
\q1 
\v 36 Erekeria ngoro yakwa kũrĩ kĩrĩra gĩaku,
\q2 nĩguo ĩtige kwerekera ũhoro-inĩ wa gwĩtongia.
\q1 
\v 37 Girĩrĩria maitho makwa matige kwĩrorera maũndũ ma tũhũ;
\q2 tũũria muoyo wakwa kũringana na kiugo gĩaku.
\q1 
\v 38 Hingĩria ndungata yaku kĩĩranĩro gĩaku,
\q2 nĩgeetha wĩtigagĩrwo.
\q1 
\v 39 Njehereria njono iria ndĩĩtigagĩra,
\q2 nĩgũkorwo mawatho maku nĩ mega.
\q1 
\v 40 Kaĩ nĩndĩĩriragĩria mawatho maku-ĩ!
\q2 Tũũria muoyo wakwa nĩ ũndũ wa ũthingu waku.
\s1 Kwĩhoka Watho wa Jehova
\q1 
\v 41 Wee Jehova, wendo waku ũrĩa ũtathiraga ũronginyĩra,
\q2 ũhonokio waku ũnginyĩre kũringana na kĩĩranĩro gĩaku;
\q1 
\v 42 nĩguo ngoragwo na ũndũ wa gũcookeria andũ arĩa maanyũrũragia,
\q2 nĩgũkorwo niĩ ndĩhokete kiugo gĩaku.
\q1 
\v 43 Ndũkandunye kiugo kĩa ma kuuma kanua-inĩ gakwa,
\q2 nĩgũkorwo njigĩte mwĩhoko wakwa mawatho-inĩ maku.
\q1 
\v 44 Ngũtũũra njathĩkagĩra watho waku,
\q2 nginya tene na tene.
\q1 
\v 45 Ndĩrĩthiiaga ndĩ na wĩyathi,
\q2 nĩgũkorwo nĩmaathaga mawatho maku.
\q1 
\v 46 Nĩndĩrĩaragia ũhoro wa kĩrĩra gĩaku
\q2 mbere ya athamaki na ndirĩconokaga,
\q1 
\v 47 nĩgũkorwo nĩngenagĩra maathani maku
\q2 tondũ nĩndĩmendete.
\q1 
\v 48 Ndĩrĩambararagia moko makwa kũrĩ maathani maku marĩa nyendete,
\q2 na ndĩcũũranagie igũrũ rĩa kĩrĩra kĩa watho waku.
\s1 Kũgĩa na Mwĩhoko Watho-inĩ wa Jehova
\q1 
\v 49 Ririkana kiugo gĩaku kũrĩ ndungata yaku,
\q2 nĩgũkorwo nĩũũheete kĩĩrĩgĩrĩro.
\q1 
\v 50 Ũndũ ũrĩa ũũhooreragia ndĩ mĩnyamaro-inĩ nĩ ũyũ:
\q2 atĩ kĩĩranĩro gĩaku nĩkĩo gĩtũũragia muoyo wakwa.
\q1 
\v 51 Andũ arĩa etĩĩi maanyũrũragia matekwĩgirĩrĩria,
\q2 no nditiganagĩria watho waku.
\q1 
\v 52 Nĩndirikanaga mawatho maku ma tene, Wee Jehova,
\q2 namo nĩmahooreragia.
\q1 
\v 53 Nyiitagwo nĩ mangʼũrĩ nĩ ũndũ wa andũ arĩa aaganu,
\q2 o acio maatiganĩirie watho waku.
\q1 
\v 54 Ũhoro wa kĩrĩra gĩaku nĩguo ũtuĩkĩte rwĩmbo rwakwa,
\q2 o kũrĩa guothe ingĩikara.
\q1 
\v 55 Ũtukũ ndirikanaga rĩĩtwa rĩaku,
\q2 ngakĩrũmia watho waku Wee Jehova.
\q1 
\v 56 Ũũ nĩguo ngoretwo ngĩĩka:
\q2 nĩnjathĩkagĩra mawatho maku.
\s1 Kwĩrutĩra nĩ ũndũ wa Watho wa Jehova
\q1 
\v 57 Wee Jehova, Wee nĩwe igai rĩakwa;
\q2 nĩngwĩrĩte atĩ ndĩathĩkagĩra ciugo ciaku.
\q1 
\v 58 Maathĩĩte ũthiũ waku na ngoro yakwa yothe;
\q2 nginyagĩria wega waku o ta ũrĩa wĩranĩire.
\q1 
\v 59 Nĩndĩcũũranĩtie ũhoro wa mĩthiĩre yakwa,
\q2 ngagĩcookia makinya makwa kũrĩ kĩrĩra gĩaku.
\q1 
\v 60 Nĩngũhiũha na ndigũcererwo
\q2 gwathĩkĩra maathani maku.
\q1 
\v 61 O na kũngĩtuĩka atĩ andũ arĩa aaganu no manjohe na mĩhĩndo-rĩ,
\q2 ndingĩriganĩrwo nĩ watho waku.
\q1 
\v 62 Ũtukũ gatagatĩ njarahũkaga ngũcookerie ngaatho
\q2 nĩ ũndũ wa mawatho maku ma kĩhooto.
\q1 
\v 63 Niĩ ndĩ mũrata wa andũ arĩa othe magwĩtigĩrĩte,
\q2 o arĩa othe marũmagĩrĩra mawatho maku.
\q1 
\v 64 Wee Jehova, thĩ ĩiyũrĩtwo nĩ wendo waku;
\q2 nduta kĩrĩra kĩa watho waku.
\s1 Watho wa Jehova nĩ wa Bata
\q1 
\v 65 Wee Jehova, ĩka ndungata yaku
\q2 kũringana na kiugo gĩaku.
\q1 
\v 66 Nduta gũkũũrana maũndũ wega o na kũmamenya,
\q2 nĩgũkorwo nĩnjĩtĩkĩtie maathani maku.
\q1 
\v 67 Mbere itanoona thĩĩna nĩndahĩtagia,
\q2 no rĩu nĩnjathĩkagĩra kiugo gĩaku.
\q1 
\v 68 Wee ũrĩ mwega, na nĩwĩkaga o wega;
\q2 nduta kĩrĩra kĩa watho waku.
\q1 
\v 69 O na gũtuĩka andũ arĩa etĩĩi nĩmahakĩte gĩko na ndeto cia maheeni,
\q2 ngũtũũra nũmĩtie mawatho maku na ngoro yakwa yothe.
\q1 
\v 70 Ngoro ciao nĩ nyũmũ na itirĩ tha,
\q2 no niĩ ngenagĩra watho waku.
\q1 
\v 71 Warĩ ũndũ mwega niĩ nyone thĩĩna,
\q2 nĩgeetha ndĩĩrute kĩrĩra kĩa watho waku.
\q1 
\v 72 Watho ũrĩa uumĩte kanua gaku nĩ wa bata mũno harĩ niĩ,
\q2 gũkĩra ngiri cia icunjĩ cia betha na thahabu.
\s1 Watho wa Jehova nĩ wa Kĩhooto
\q1 
\v 73 Moko maku nĩmo manyũmbire na magĩĩthondeka ũguo ndariĩ;
\q2 he ũtaũku nĩguo ndĩĩrute maathani maku.
\q1 
\v 74 Andũ arĩa magwĩtigĩrĩte marokenaga rĩrĩa maanyona,
\q2 nĩgũkorwo nĩnjigĩte mwĩhoko wakwa harĩ kiugo gĩaku.
\q1 
\v 75 Jehova, nĩnjũũĩ atĩ mawatho maku nĩ ma ũthingu,
\q2 na ũnyonetie thĩĩna nĩ ũndũ wa wĩhokeku waku.
\q1 
\v 76 Wendani waku ũrĩa ũtathiraga ũrotuĩka wa kũũhooreria,
\q2 kũringana na kĩĩranĩro gĩaku kĩrĩa werĩire ndungata yaku.
\q1 
\v 77 Ĩtĩkĩra tha ciaku inginyĩre nĩguo ndũũre muoyo,
\q2 nĩgũkorwo watho waku nĩguo ngenagĩra.
\q1 
\v 78 Andũ arĩa etĩĩi maroconorithio nĩ ũndũ wa kũnjĩka ũũru hatarĩ gĩtũmi;
\q2 no niĩ-rĩ, ndĩrĩcũũranagia ũhoro wa mawatho maku.
\q1 
\v 79 Andũ arĩa magwĩtigĩrĩte maronjookerera,
\q2 o acio mataũkĩirwo nĩ kĩrĩra gĩaku.
\q1 
\v 80 Ngoro yakwa ĩroaga ũcuuke ũhoro-inĩ wa kĩrĩra kĩa watho waku,
\q2 nĩguo ndikanaconorithio.
\s1 Ihooya rĩa kũũria Ũhonokio
\q1 
\v 81 Ngoro yakwa ĩringĩkaga nĩ kwĩrirĩria ũhonokio waku,
\q2 no niĩ njigĩte mwĩhoko wakwa harĩ kiugo gĩaku.
\q1 
\v 82 Maitho makwa nĩmaraaga hinya nĩ gũtũũra njũthĩrĩirie kĩĩranĩro gĩaku;
\q2 ngakĩũria atĩrĩ, “Ũgaakĩĩhooreria rĩ?”
\q1 
\v 83 O na gũtuĩka haana ta mondo ya rũũa ya ndibei ĩigĩtwo ndogo-inĩ,\f + \fr 119:83 \ft Mondo cia njũa irĩ na ndibei ĩtarĩ ngagatu ciacuuragio itara nĩguo ndibei ĩgagate na ihenya.\f*
\q2 ndiriganagĩrwo nĩ kĩrĩra kĩa watho waku.
\q1 
\v 84 Niĩ ndungata yaku-rĩ, ngweterera nginya rĩ?
\q2 Arĩa maanyariiraga ũkaamaherithia rĩ?
\q1 
\v 85 Andũ arĩa etĩĩi manyenjeire marima nĩguo ngwe kuo,
\q2 o acio makararagia watho waku.
\q1 
\v 86 Maathani maku mothe nĩ ma kwĩhokwo;
\q2 ndeithia, nĩgũkorwo andũ maanyariiraga hatarĩ gĩtũmi.
\q1 
\v 87 Maatigĩtie hanini maaniine nyume thĩ ĩno,
\q2 no nditiganĩirie mawatho maku.
\q1 
\v 88 Menyerera muoyo wakwa kũringana na wendo waku,
\q2 na ndĩathĩkagĩra kĩrĩra gĩa kanua gaku.
\s1 Gwĩtĩkia Watho wa Jehova
\q1 
\v 89 Wee Jehova, kiugo gĩaku gĩtũũraga tene na tene;
\q2 gĩtũũraga kĩĩhaandĩte wega kũu igũrũ.
\q1 
\v 90 Wĩhokeku waku nĩ wa kuuma njiarwa nginya njiarwa;
\q2 nĩwe warũmirie thĩ, nayo ĩgagĩikara o ĩrũmĩte.
\q1 
\v 91 Mawatho maku matũũraga nginya ũmũthĩ,
\q2 nĩgũkorwo indo ciothe nĩwe itungataga.
\q1 
\v 92 Korwo watho waku tiguo ũngenagia,
\q2 ingĩanathira nĩ mĩnyamaro yakwa.
\q1 
\v 93 Niĩ ndirĩ hĩndĩ ngaariganĩrwo nĩ mawatho maku,
\q2 nĩgũkorwo ũndũũrĩtie muoyo nĩ ũndũ wamo.
\q1 
\v 94 Honokia, nĩgũkorwo ndĩ waku,
\q2 na nĩĩmaathĩte mawatho maku.
\q1 
\v 95 Andũ arĩa aaganu manjoheirie nĩguo maaniine,
\q2 no niĩ ndĩrĩĩcũũranagia o ũhoro wa kĩrĩra gĩaku.
\q1 
\v 96 Ũndũ o wothe mũkinyanĩru wega, nĩnyonete nĩ ũrĩ mũthia;
\q2 no maathani maku matirĩ mũhaka.
\s1 Kwenda Watho wa Jehova
\q1 
\v 97 Kaĩ nĩnyendete watho waku-ĩ!
\q2 Ndindaga ngĩtarania ũhoro waguo mũthenya wothe.
\q1 
\v 98 Maathani maku matũmaga njũhĩge gũkĩra thũ ciakwa,
\q2 nĩgũkorwo makoragwo hamwe na niĩ hĩndĩ ciothe.
\q1 
\v 99 Niĩ ndĩ na ũmenyo mũingĩ gũkĩra arutani akwa othe,
\q2 nĩgũkorwo ndaranagia ũhoro wa mawatho maku.
\q1 
\v 100 Niĩ ndĩ na ũmenyo mũingĩ gũkĩra athuuri,
\q2 nĩgũkorwo njathĩkagĩra kĩrĩra gĩaku.
\q1 
\v 101 Nĩndigagĩrĩria magũrũ makwa matikagerere njĩra o yothe njũru,
\q2 nĩgeetha njathĩkagĩre kiugo gĩaku.
\q1 
\v 102 Niĩ nditiganĩirie mawatho maku,
\q2 nĩgũkorwo Wee nĩwe ũndutĩte ũhoro ũcio.
\q1 
\v 103 Kaĩ ciugo ciaku irĩ mũrĩo ngĩcicama-ĩ,
\q2 irĩ mũrĩo gũkĩra ũũkĩ ũrĩ kanua-inĩ gakwa!
\q1 
\v 104 Ngĩĩaga na ũtaũku nĩ ũndũ wa kĩrĩra gĩaku;
\q2 nĩ ũndũ ũcio nĩthũire njĩra o yothe njũru.
\s1 Ũtheri ũrĩa Uumanaga na Watho wa Jehova
\q1 
\v 105 Kiugo gĩaku nĩkĩo tawa wa magũrũ makwa,
\q2 na ũtheri wa kũmũrĩka njĩra yakwa.
\q1 
\v 106 Nĩndĩĩhĩtĩte mwĩhĩtwa na ngagwatĩria,
\q2 atĩ nĩndĩrĩrũmagĩrĩra mawatho maku ma ũthingu.
\q1 
\v 107 Nĩthĩĩnĩkĩte mũno;
\q2 Wee Jehova, tũũria muoyo wakwa, kũringana na kiugo gĩaku.
\q1 
\v 108 Wee Jehova, ĩtĩkĩra ũgooci wa kwĩyendera wa kanua gakwa,
\q2 na ũkĩndute mawatho maku.
\q1 
\v 109 O na gũtuĩka ndũũraga nyiitĩrĩire muoyo wakwa moko-inĩ makwa-rĩ,
\q2 ndingĩriganĩrwo nĩ watho waku.
\q1 
\v 110 Andũ arĩa aaganu nĩmanyambĩire mũtego,
\q2 no ndirĩ ndahĩtia kĩrĩra gĩaku.
\q1 
\v 111 Mawatho maku nĩmo igai rĩakwa nginya tene;
\q2 nĩmo gĩkeno kĩa ngoro yakwa.
\q1 
\v 112 Ngoro yakwa nĩĩtuĩte kũrũmagia kĩrĩra kĩa watho waku
\q2 o nginya mũthia.
\s1 Ũgitĩri ũrĩa Uumanaga na Watho wa Jehova
\q1 
\v 113 Nĩthũire andũ a ngoro igĩrĩ,
\q2 no nĩnyendete watho waku.
\q1 
\v 114 Wee nĩwe rĩũrĩro rĩakwa na ngo yakwa;
\q2 njigĩte mwĩhoko wakwa kiugo-inĩ gĩaku.
\q1 
\v 115 Njehererai, inyuĩ eeki ũũru,
\q2 nĩguo ngĩrũmie maathani ma Ngai wakwa!
\q1 
\v 116 Nyiitagĩrĩra kũringana na kĩĩranĩro gĩaku, na nĩngũtũũra muoyo;
\q2 ndũkareke kĩĩrĩgĩrĩro gĩakwa kĩharagane.
\q1 
\v 117 Ndiiragĩrĩra, na nĩngũhonokio;
\q2 ngũtũũra ndĩĩte uuge waku.
\q1 
\v 118 Nĩũregaga arĩa othe matiganaga na kĩrĩra kĩa watho waku,
\q2 nĩgũkorwo kwĩheenia kũu meheenagia nakuo nĩ gwa tũhũ.
\q1 
\v 119 Arĩa othe aaganu a gũkũ thĩ ũmateaga ta gĩko;
\q2 nĩ ũndũ ũcio niĩ nĩnyendete kĩrĩra kĩa watho waku.
\q1 
\v 120 Mwĩrĩ wakwa nĩũinainaga nĩgũgwĩtigĩra;
\q2 njikaraga na guoya mũnene nĩ ũndũ wa mawatho maku.
\s1 Gwathĩkĩra Watho wa Jehova
\q1 
\v 121 Niĩ njĩkĩte maũndũ ma ũthingu na ma kĩhooto;
\q2 ndũkandiganĩrie harĩ arĩa maahinyagĩrĩria.
\q1 
\v 122 Menyerera ũgima wa ndungata yaku;
\q2 ndũkareke andũ arĩa etĩĩi maahinyĩrĩrie.
\q1 
\v 123 Maitho makwa nĩmaraaga hinya nĩgũtũũra njũũthĩrĩirie ũhonokio waku,
\q2 ngacũthĩrĩria kĩĩranĩro gĩaku kĩa ũthingu.
\q1 
\v 124 Ĩkaga ndungata yaku kũringana na wendo waku,
\q2 na ũndutage kĩrĩra kĩa watho waku.
\q1 
\v 125 Niĩ ndĩ ndungata yaku; he gũkũũrana maũndũ,
\q2 nĩguo hote gũtaũkĩrwo nĩ kĩrĩra gĩaku.
\q1 
\v 126 Wee Jehova, hĩndĩ nĩnginyu wĩke ũndũ,
\q2 tondũ andũ nĩmathũkĩtie watho waku.
\q1 
\v 127 Tondũ nĩnyendete maathani maku gũkĩra thahabu,
\q2 ngamenda mũno gũkĩra thahabu ĩrĩa therie,
\q1 
\v 128 na tondũ nĩnduĩte mawatho maku mothe nĩmagĩrĩire,
\q2 nĩthũire njĩra o yothe ĩtarĩ ya ma.
\s1 Kwenda Gwathĩkĩra Watho wa Jehova
\q1 
\v 129 Kĩrĩra gĩaku nĩ kĩa magegania;
\q2 nĩ ũndũ ũcio nĩndĩrĩgĩathĩkagĩra.
\q1 
\v 130 Ciugo ciaku ciataũrwo nĩirehaga ũtheri;
\q2 nĩciũhĩgagia andũ arĩa matarĩ oogĩ.
\q1 
\v 131 Njathamĩtie kanua gakwa ngahũma
\q2 nĩ ũndũ wa kwĩrirĩria maathani maku.
\q1 
\v 132 Njerekera na ũnjiguĩre tha,
\q2 o ta ũrĩa wĩkaga andũ arĩa mendete rĩĩtwa rĩaku.
\q1 
\v 133 Rũngagĩrĩria makinya makwa kũringana na kiugo gĩaku;
\q2 ndũkareke njathagwo nĩ wĩhia o na ũrĩkũ.
\q1 
\v 134 Ngũũra kuuma ũhiinyanĩrĩria wa andũ,
\q2 nĩguo njathĩkagĩre mawatho maku.
\q1 
\v 135 Tũma ũthiũ waku warĩre ndungata yaku,
\q2 na ũndutage kĩrĩra kĩa watho waku.
\q1 
\v 136 Maitho makwa manyũrũrũkagia maithori ta rũũĩ,
\q2 nĩgũkorwo andũ matirathĩkĩra watho waku.
\s1 Watho wa Jehova nĩ wa Kĩhooto
\q1 
\v 137 Wee Jehova, ũrĩ mũthingu,
\q2 na mawatho maku nĩmagĩrĩire.
\q1 
\v 138 Mawatho marĩa ũheanĩte nĩ ma ũthingu;
\q2 nĩ ma kwĩhokwo kũna.
\q1 
\v 139 Kĩyo gĩakwa nĩkĩĩnogetie,
\q2 nĩgũkorwo thũ ciakwa nĩcitiganĩirie ciugo ciaku.
\q1 
\v 140 Ciĩranĩro ciaku nĩthuuranĩre o biũ,
\q2 na ndungata yaku nĩĩciendete.
\q1 
\v 141 O na gũtuĩka ndirĩ bata na nĩnyararĩtwo-rĩ,
\q2 ndiriganagĩrwo nĩ mawatho maku.
\q1 
\v 142 Ũthingu waku nĩ wa gũtũũra tene na tene,
\q2 naguo watho waku nĩ wa ma.
\q1 
\v 143 Ngoretwo nĩ mathĩĩna na mĩnyamaro,
\q2 no maathani maku nĩmo ngenagĩra.
\q1 
\v 144 Kĩrĩra gĩaku nĩ kĩa ma nginya tene;
\q2 kĩĩhe ũtaũku nĩguo ndũũre muoyo.
\s1 Ihooya rĩa kũũria Ũhonokio
\q1 
\v 145 Ndĩragũkaĩra na ngoro yakwa yothe, Wee Jehova, njĩtĩka,
\q2 na nĩndĩrĩathĩkagĩra kĩrĩra kĩa watho waku.
\q1 
\v 146 Wee nĩwe ndĩrakaĩra,
\q2 honokia na nĩndĩrĩmenyagĩrĩra mawatho maku.
\q1 
\v 147 Njũkagĩra tene gũtanakĩa, ngakũrĩrĩra nĩguo ũndeithie;
\q2 njigĩte mwĩhoko wakwa kiugo-inĩ gĩaku.
\q1 
\v 148 Maitho makwa maikaraga mahingũkĩte matuanĩra-inĩ mothe ma arangĩri,
\q2 nĩguo ndaranagie ũhoro wa ciĩranĩro ciaku.
\q1 
\v 149 Igua mũgambo wakwa kũringana na wendo waku;
\q2 Wee Jehova, tũũria muoyo wakwa, kũringana na mawatho maku.
\q1 
\v 150 Andũ arĩa mathugundaga maũndũ ma wĩki naaĩ nĩmanguhĩrĩirie,
\q2 no-o nĩmaraihanĩrĩirie na watho waku.
\q1 
\v 151 No Wee Jehova, ũikaraga hakuhĩ,
\q2 na maathani maku mothe nĩ ma ma.
\q1 
\v 152 Matukũ-inĩ ma tene nĩndamenyire kuuma kĩrĩra-inĩ gĩaku,
\q2 atĩ wagĩthondekire kĩrĩ gĩa gũtũũra nginya tene.
\s1 Kũhooya Ũteithio
\q1 
\v 153 Rora gũthĩĩnĩka gwakwa na ũndeithũre,
\q2 nĩgũkorwo ndiriganĩirwo nĩ watho waku.
\q1 
\v 154 Ndũĩrĩra na ũkĩngũũre;
\q2 tũũria muoyo wakwa kũringana na kĩĩranĩro gĩaku.
\q1 
\v 155 Ũhonokio nĩũraihĩrĩirie andũ arĩa aaganu,
\q2 nĩgũkorwo matirongoragia kĩrĩra kĩa watho waku.
\q1 
\v 156 Wee Jehova, tha ciaku nĩ nyingĩ;
\q2 tũũria muoyo wakwa kũringana na mawatho maku.
\q1 
\v 157 Andũ arĩa maanyariiraga nĩ aingĩ,
\q2 no ndirĩ ndahutatĩra kĩrĩra gĩaku.
\q1 
\v 158 Njũthagĩrĩria arĩa matarĩ na wĩtĩkio ngoro,
\q2 nĩgũkorwo matiathĩkagĩra kiugo gĩaku.
\q1 
\v 159 Ta kĩone ũrĩa nyendete mawatho maku;
\q2 tũũria muoyo wakwa, Wee Jehova, kũringana na wendo waku.
\q1 
\v 160 Ciugo ciaku ciothe nĩ cia ma;
\q2 mawatho maku mothe nĩ ma ũthingu na nĩ ma gũtũũra tene na tene.
\s1 Kũhingia Watho wa Jehova
\q1 
\v 161 Aathani maanyariiraga hatarĩ gĩtũmi,
\q2 no ngoro yakwa ĩinainagio nĩ kiugo gĩaku.
\q1 
\v 162 Ngenagĩra kĩĩranĩro gĩaku,
\q2 o ta ũrĩa mũndũ atahĩte indo nyingĩ akenaga.
\q1 
\v 163 Nĩmenete na ngathũũra maheeni,
\q2 no nĩnyendete watho waku.
\q1 
\v 164 O mũthenya ngũgoocaga maita mũgwanja
\q2 nĩ ũndũ wa mawatho maku ma ũthingu.
\q1 
\v 165 Arĩa mendete watho waku nĩ marĩ thayũ mũingĩ,
\q2 na gũtirĩ kĩndũ kĩngĩtũma mahĩngwo.
\q1 
\v 166 Njetagĩrĩra ũhonokio waku, Wee Jehova,
\q2 na ngarũmĩrĩra maathani maku.
\q1 
\v 167 Njathĩkagĩra kĩrĩra gĩaku,
\q2 nĩgũkorwo nĩndĩkĩendete mũno.
\q1 
\v 168 Njathĩkagĩra mawatho maku na kĩrĩra gĩaku,
\q2 nĩgũkorwo mĩthiĩre yakwa yothe nĩũmĩũĩ.
\s1 Ihooya rĩa kũũria Ũteithio
\q1 
\v 169 Wee Jehova-rĩ, gũkaya gwakwa kũrokinya harĩwe;
\q2 he gũtaũkĩrwo kũringana na kiugo gĩaku.
\q1 
\v 170 Mathaithana makwa marokinya harĩwe;
\q2 ndeithũra kũringana na kĩĩranĩro gĩaku.
\q1 
\v 171 Mĩromo yakwa ĩrĩkũgoocaga hĩndĩ ciothe,
\q2 nĩgũkorwo nĩũndutaga kĩrĩra kĩa watho waku.
\q1 
\v 172 Rũrĩmĩ rwakwa nĩrũkĩine ũhoro wa kiugo gĩaku,
\q2 nĩgũkorwo maathani maku mothe nĩ ma ũthingu.
\q1 
\v 173 Guoko gwaku nĩgũkĩĩhaarĩrie kũndeithia,
\q2 nĩgũkorwo mawatho maku nĩmo niĩ ndĩthuurĩire.
\q1 
\v 174 Ũhonokio waku nĩguo ndĩĩriragĩria, Wee Jehova,
\q2 naguo watho waku nĩguo ngenagĩra.
\q1 
\v 175 Ndĩrogĩtũũra muoyo nĩguo ngũgoocage,
\q2 namo mawatho maku nĩmatũũre mandeithagia.
\q1 
\v 176 Niĩ nĩhĩtĩtie njĩra ta ngʼondu yũrĩte.
\q2 Gĩcarie ndungata yaku,
\q2 nĩgũkorwo ndiriganĩirwo nĩ maathani maku.
\c 120
\s1 Ihooya rĩa kũũria Ũteithio
\d Thaburi ya Agendi
\q1 
\v 1 Ndakaĩire Jehova ndĩ mĩnyamaro-inĩ,
\q2 nake akĩnjĩtĩka.
\q1 
\v 2 Wee Jehova, honokia harĩ mĩromo ĩrĩa yaragia maheeni,
\q2 na harĩ nĩmĩ iria iheenanagia.
\b
\q1 
\v 3 Agaagwĩka atĩa, na nĩ atĩa ũngĩ makĩria ya ũguo,
\q2 wee rũrĩmĩ rũrũ rũheenanagia?
\q1 
\v 4 Agaakũherithia na mĩguĩ mĩnoore ya njamba ya ita,
\q2 na makara marĩrĩmbũkĩte mwaki ma mũtĩ wa mũkoigo.
\b
\q1 
\v 5 Kaĩ ndĩ na haaro-ĩ, nĩgũtũũra gũkũ Mesheki,
\q2 na ngaikara hema-inĩ cia Kedari-ĩ!
\q1 
\v 6 Nĩndũũrĩte hĩndĩ ndaaya
\q2 gatagatĩ-inĩ ka arĩa mathũire thayũ.
\q1 
\v 7 Niĩ ndĩ mũndũ wa thayũ;
\q2 no rĩrĩa ndaaria-rĩ, o mendaga o mbaara.
\c 121
\s1 Ũgitĩri wa Ngai
\d Thaburi ya Agendi
\q1 
\v 1 Nĩngũtiira maitho makwa ndore irĩma-inĩ:
\q2 ũteithio wakwa ũngiuma na kũ?
\q1 
\v 2 Ũteithio wakwa uumaga kũrĩ Jehova,
\q2 o we Mũũmbi wa igũrũ na thĩ.
\b
\q1 
\v 3 We ndangĩreka kũgũrũ gwaku gũtirũke:
\q2 ũcio mũmenyereri waku ndarĩ hĩndĩ angĩcũnga;
\q1 
\v 4 ti-itherũ, ũcio mũmenyereri wa Isiraeli
\q2 ndarĩ hĩndĩ angĩcũnga, kana ahĩtwo nĩ toro.
\b
\q1 
\v 5 Jehova nĩwe ũkũmenyagĩrĩra:
\q2 Jehova nĩwe kĩĩruru gĩaku guoko-inĩ gwaku kwa ũrĩo;
\q1 
\v 6 mũthenya wee ndũngĩringĩka nĩ riũa,
\q2 kana ũringĩke nĩ mweri ũtukũ.
\b
\q1 
\v 7 Jehova nĩarĩkũgitagĩra kuuma ũũru-inĩ wothe:
\q2 nĩarĩĩmenyagĩrĩra muoyo waku;
\q1 
\v 8 Jehova nĩarĩkũmenyagĩrĩra ũkiumagara na ũgĩcooka,
\q2 kuuma rĩu nginya tene na tene.
\c 122
\s1 Rwĩmbo rwa Kũgaathĩrĩria Jerusalemu
\d Thaburi ya Daudi
\q1 
\v 1 Nĩndakenire hamwe na arĩa maanjĩĩrire atĩrĩ,
\q2 “Nĩtũthiĩ nyũmba ya Jehova.”
\q1 
\v 2 Magũrũ maitũ marũgamĩte
\q2 ihingo-inĩ ciaku, wee Jerusalemu.
\b
\q1 
\v 3 Jerusalemu rĩakĩtwo ta itũũra inene
\q2 rĩnyitithanĩtio wega.
\q1 
\v 4 Kũu nĩkuo mĩhĩrĩga yambataga,
\q2 o yo mĩhĩrĩga ya Jehova,
\q1 ĩgathiĩ kũgooca rĩĩtwa rĩa Jehova
\q2 kũringana na mawatho marĩa aheete Isiraeli.
\q1 
\v 5 Kũu nĩkuo kũigĩtwo itĩ cia ũnene cia atuanĩri ciira,
\q2 o cio itĩ cia ũnene cia nyũmba ya Daudi.
\b
\q1 
\v 6 Hoerai Jerusalemu thayũ:
\q2 “Arĩa makwendete marotũũra na thayũ.
\q1 
\v 7 Kũrĩa thingo ciaku ciirigĩire kũrogĩa na thayũ,
\q2 naguo ũgitĩri ũgĩe ciikaro-inĩ ciaku cia ũthamaki.”
\q1 
\v 8 Nĩ ũndũ wa ariũ a baba na arata, nguuga atĩrĩ,
\q2 “Thayũ ũrogĩa thĩinĩ waku.”
\q1 
\v 9 Nĩ ũndũ wa nyũmba ya Jehova Ngai witũ,
\q2 caragia ũgaacĩru waku.
\c 123
\s1 Ihooya rĩa kũũria Tha cia Ngai
\d Thaburi ya Agendi
\q1 
\v 1 Nĩngũtiira maitho makwa na kũrĩ we,
\q2 o Wee ũikarĩire gĩtĩ gĩaku kĩa ũnene kũu igũrũ.
\q1 
\v 2 O ta ũrĩa maitho ma ndungata maroragĩrĩria guoko kwa mwathi wayo,
\q2 na o ta ũrĩa maitho ma mũirĩtu ndungata maroragĩrĩria guoko kwa mũtumia mwathi wayo,\f + \fr 123:2 \ft Aathi a ngombo maaciaragĩria na maitho kana na moko.\f*
\q1 ũguo noguo maitho maitũ maroragĩrĩria Jehova Ngai witũ,
\q2 o nginya atũiguĩre tha ciake.
\b
\q1 
\v 3 Tũiguĩre tha, Wee Jehova, tũiguĩre tha,
\q2 nĩgũkorwo nĩtũkirĩrĩirie kũnyararwo kũnene.
\q1 
\v 4 Nĩtũkirĩrĩirie kĩnyũrũri kĩnene kĩa andũ arĩa menenehagia,
\q2 o na rũmena rũingĩ rwa andũ arĩa etĩĩi.
\c 124
\s1 Gũcookia Ngaatho nĩ ũndũ wa Ũgitĩri
\d Thaburi ya Daudi
\q1 
\v 1 Korwo Jehova ndaakoretwo arĩ mwena witũ;
\q2 Isiraeli nĩmakiuge ũguo:
\q1 
\v 2 Korwo Jehova ndaarĩ mwena witũ
\q2 rĩrĩa andũ maatũtharĩkĩire-rĩ,
\q1 
\v 3 nĩmangĩatũmeririe tũrĩ muoyo;
\q2 rĩrĩa marakara mao maatũrĩrĩmbũkĩire-rĩ,
\q1 
\v 4 mũiyũro wa maaĩ nĩũngĩatũhubanĩirie,
\q2 tũhumbwo nĩ nditi ya maaĩ macio;
\q1 
\v 5 maaĩ macio maathereraga na hinya mũno
\q2 nĩmangĩatũthereririe.
\b
\q1 
\v 6 Jehova arogoocwo,
\q2 o we ũtaatũrekereirie tũtambuurangwo nĩ magego mao.
\q1 
\v 7 Ithuĩ tũhonokete ta nyoni
\q2 ĩhonokete mũtego-inĩ wa mũmĩtegi;
\q1 mũtego nĩunangĩtwo,
\q2 na ithuĩ nĩtũhonokete.
\q1 
\v 8 Ũteithio witũ uumaga harĩ Jehova,
\q2 o we Mũũmbi wa igũrũ na thĩ.
\c 125
\s1 Thayũ wa Andũ a Ngai
\q1 
\v 1 Andũ arĩa mehokete Jehova matariĩ ta Kĩrĩma gĩa Zayuni,
\q2 kĩrĩa gĩtangĩenyenyeka, no gĩtũũraga nginya tene.
\q1 
\v 2 O ta ũrĩa irĩma ithiũrũrũkĩirie Jerusalemu
\q2 ũguo noguo Jehova athiũrũrũkagĩria andũ ake,
\q2 kuuma rĩu nginya tene na tene.
\b
\q1 
\v 3 Mũthĩgi wa andũ arĩa aaganu ndũgũtũũra wathanaga
\q2 bũrũri ũrĩa ũgaĩirwo andũ arĩa athingu,
\q1 nĩguo andũ acio athingu
\q2 matikae gũtambũrũkia moko mao meeke ũũru.
\b
\q1 
\v 4 Wee Jehova, andũ arĩa ega mekaga o maũndũ mega,
\q2 o acio arũngĩrĩru ngoro.
\q1 
\v 5 No rĩrĩ, andũ arĩa maahũkaga makagera njĩra iria njogomu-rĩ,
\q2 Jehova nĩakamaingatanĩria hamwe na arĩa mekaga ũũru.
\b
\q1 Isiraeli kũrogĩa thayũ.
\c 126
\s1 Magetha ma Gĩkeno
\d Thaburi ya Agendi
\q1 
\v 1 Rĩrĩa Jehova aacookirie andũ a Zayuni arĩa maatahĩtwo akĩmainũkia-rĩ,
\q2 twahaanire ta andũ mekũroota.
\q1 
\v 2 Tũnua twitũ twaiyũrire mĩtheko,
\q2 nacio nĩmĩ ciitũ ikĩina nyĩmbo cia gĩkeno.
\q1 Hĩndĩ ĩyo ndũrĩrĩ-inĩ gũkĩĩranwo atĩrĩ,
\q2 “Jehova nĩekĩire andũ aya maũndũ manene.”
\q1 
\v 3 Jehova nĩatwĩkĩire maũndũ manene,
\q2 na ithuĩ tũkaiyũrwo nĩ gĩkeno.
\b
\q1 
\v 4 Tũma tũgaacĩre rĩngĩ, Wee Jehova,
\q2 ta ũrĩa njũũĩ cia Negevu icookaga kũiyũra.
\q1 
\v 5 Andũ arĩa mahaandaga na maithori,
\q2 nĩmakagetha makĩinaga nyĩmbo cia gĩkeno.
\q1 
\v 6 Mũndũ o na angiumagara akĩrĩraga,
\q2 akuuĩte mbeũ cia kũhaanda,
\q1 agaacooka akĩinaga nyĩmbo cia gĩkeno,
\q2 akuuĩte itĩĩa ciake cia ngano.
\c 127
\s1 Kũgaatha Ngai nĩ ũndũ wa Wega Wake
\q1 
\v 1 Tiga nyũmba yakirwo nĩ Jehova,
\q2 andũ arĩa mamĩakaga marutaga wĩra o wa tũhũ.
\q1 Tiga itũũra inene rĩmenyereirwo nĩ Jehova,
\q2 arangĩri maraaraga mehũũgĩte o tũhũ.
\q1 
\v 2 Nĩ tũhũ andũ kũrooka gũũkĩra rũciinĩ tene,
\q2 na gũkoma magakoma macereirwo,
\q1 makĩnogera irio cia kũrĩa,
\q2 nĩgũkorwo andũ arĩa Jehova endete,
\q1 we nĩamaheaga o na marĩ toro.
\b
\q1 
\v 3 Ciana nĩ igai kuuma kũrĩ Jehova,
\q2 ciana nĩ kĩheo kuuma kũrĩ we.
\q1 
\v 4 Ciana iria mũndũ aciarĩte arĩ mũnini
\q2 no ta mĩguĩ ĩrĩ moko-inĩ ma njamba ya ita.
\q1 
\v 5 Kũrathimwo nĩ mũndũ
\q2 ũrĩa thiaka wake ũiyũrĩte mĩguĩ.
\q1 Matigaaconorithio
\q2 rĩrĩa magaakorwo magĩciira na thũ ciao hau kĩhingo-inĩ.
\c 128
\s1 Kĩrathimo kĩa Mũciĩ Wĩtigĩrĩte Jehova
\d Thaburi ya Agendi
\q1 
\v 1 Kũrathimwo nĩ mũndũ o wothe wĩtigĩrĩte Jehova,
\q2 o ũcio ũgeragĩra njĩra ciake.
\q1 
\v 2 Nĩũkarĩĩaga maciaro ma wĩra waku;
\q2 irathimo na kũgaacĩra nĩigatuĩka ciaku.
\q1 
\v 3 Mũtumia waku egũtuĩka ta mũthabibũ ũrĩa ũciaraga mũno
\q2 arĩ kũu nyũmba-inĩ yaku thĩinĩ;
\q1 ciana ciaku ituĩke ta thuuna cia mũtamaiyũ
\q2 ithiũrũrũkĩirie metha yaku.
\q1 
\v 4 Ũguo nĩguo mũndũ arĩrathimagwo,
\q2 ũrĩa wĩtigĩrĩte Jehova.
\b
\q1 
\v 5 Jehova arokũrathimaga arĩ Zayuni
\q2 matukũ mothe ma muoyo waku;
\q1 ũroona kũgaacĩra kwa Jerusalemu,
\q2 
\v 6 na ũtũũre muoyo, ũkoona ciana cia ciana ciaku.
\b
\q1 Thayũ ũrogĩa Isiraeli.
\c 129
\s1 Ihooya rĩa kũũria Ngai okĩrĩre Thũ cia Isiraeli
\d Thaburi ya Agendi
\q1 
\v 1 Maanahinyĩrĩria mũno kuuma ũnini-inĩ wakwa,
\q2 Isiraeli nĩmakiuge ũguo,
\q1 
\v 2 maanahinyĩrĩria mũno kuuma ũnini-inĩ wakwa,
\q2 no rĩrĩ, matirĩ maahota kũndooria.
\q1 
\v 3 Andũ arĩa marĩmaga na mũraũ marĩmĩte ngʼongʼo wakwa,
\q2 magatema mĩtaro mĩraihu.
\q1 
\v 4 No rĩrĩ, Jehova nĩ mũthingu;
\q2 nĩanjohorithĩtie harĩ mĩhĩndo ya andũ arĩa aaganu.
\b
\q1 
\v 5 Andũ arĩa othe mathũire Zayuni
\q2 marocookio na thuutha maconokete.
\q1 
\v 6 Marohaana ta nyeki ĩrĩ nyũmba igũrũ,
\q2 ĩrĩa ĩhoohaga ĩtanamera;\f + \fr 129:6 \ft Riya nĩrĩameraga nyũmba igũrũ no rĩkooma o na ihenya nĩ ũndũ wa kwaga tĩĩri.\f*
\q1 
\v 7 mũmĩtui ndangĩmĩiyũria hĩ-inĩ ciake,
\q2 o na kana ũrĩa ũmĩũnganagia amĩiyũrie moko-inĩ make.
\q1 
\v 8 Andũ arĩa mahĩtũkagĩra kuo maroaga kuuga atĩrĩ,
\q2 “Kĩrathimo kĩa Jehova kĩrogĩa igũrũ rĩanyu;
\q1 nĩtwamũrathima thĩinĩ wa rĩĩtwa rĩa Jehova.”
\c 130
\s1 Ihooya rĩa kũũria Ũteithio
\d Thaburi ya Agendi
\q1 
\v 1 Wee Jehova-rĩ, ndĩragũkaĩra ndĩ o kũrĩa kũriku;
\q2 
\v 2 Wee Jehova, igua mũgambo wakwa.
\q1 Matũ maku nĩmaigue
\q2 ngĩgũkaĩra ũnjiguĩre tha.
\b
\q1 
\v 3 Wee Jehova, korwo no ũtare maita marĩa tũkwĩhagĩria-rĩ,
\q2 nũũ ũngĩgwĩtiiria, Wee Jehova?
\q1 
\v 4 No rĩrĩ, Wee nĩũrekanagĩra;
\q2 nĩ ũndũ ũcio nĩwĩtigĩrĩtwo.
\b
\q1 
\v 5 Njetagĩrĩra Jehova, ngoro yakwa nĩĩmwetereire,
\q2 niĩ ndĩĩhokaga kiugo gĩake.
\q1 
\v 6 Ngoro yakwa yetagĩrĩra Jehova,
\q2 gũkĩra ũrĩa arangĩri metagĩrĩra rũciinĩ gũkĩe,
\q2 ĩĩ-ni, gũkĩra ũrĩa arangĩri metagĩrĩra rũciinĩ gũkĩe.
\b
\q1 
\v 7 Wee Isiraeli, wĩhokage Jehova,
\q2 nĩgũkorwo harĩ Jehova he wendo ũrĩa ũtathiraga,
\q2 na ningĩ harĩ we harĩ na ũhonokio kũna.
\q1 
\v 8 We mwene nĩagakũũra Isiraeli
\q2 kuuma mehia-inĩ mao mothe.
\c 131
\s1 Ihooya rĩa Kwĩnyiihĩria Ngai
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, ngoro yakwa ndĩrĩ na mwĩgaatho,
\q2 o na maitho makwa ti ma mwĩtũũgĩrio;
\q1 niĩ ndirũmbũyanagia na maũndũ manene,
\q2 o na kana maũndũ ma magegania marĩa mangĩrĩte.
\q1 
\v 2 No rĩrĩ, nĩhooreretie na ngakiria ngoro yakwa;
\q2 o ta kaana gatuithĩtio iria gakuuĩtwo nĩ nyina,
\q2 o ta kaana gatuithĩtio iria nĩguo ngoro yakwa ĩhaana ĩrĩ thĩinĩ wakwa.
\b
\q1 
\v 3 Atĩrĩrĩ wee Isiraeli, wĩhokage Jehova
\q2 rĩu na nginya tene.
\c 132
\s1 Gĩikaro kĩa Ngai gĩa Tene na Tene kũu Zayuni
\d Thaburi ya Agendi
\q1 
\v 1 Wee Jehova, ririkana Daudi
\q2 na mathĩĩna marĩa mothe omĩrĩirie.
\b
\q1 
\v 2 Nĩehĩtire mwĩhĩtwa harĩ Jehova,
\q2 akĩĩhĩta harĩ ũcio Mwene-Hinya,
\q2 o we Ngai wa Jakubu, akiuga ũũ:
\q1 
\v 3 “Ndigatoonya nyũmba yakwa,
\q2 kana haice ũrĩrĩ wakwa,
\q1 
\v 4 ndikaareke maitho makwa mone toro,
\q2 kana ndeke imone ciakwa icũnge,
\q1 
\v 5 o nginya ngoonera Jehova handũ ha gũikara,
\q2 ũcio Mwene-Hinya, o we Ngai wa Jakubu,
\q2 ndĩmuonere gĩikaro.”
\b
\q1 
\v 6 Nĩtwaiguire ũhoro tũrĩ Efiratha,
\q2 na tũkĩũkora mĩgũnda-inĩ ya Kiriathu Jearimu.
\q1 
\v 7 Tũkiuga atĩrĩ, “Nĩtũthiĩi gĩikaro-inĩ gĩake;
\q2 nĩtũinamĩrĩre tũmũhooe tũrĩ gaturwa-inĩ ka makinya make;
\q1 
\v 8 arahũka, Wee Jehova, ũũke kĩhurũko-inĩ gĩaku,
\q2 wee na ithandũkũ rĩa kĩrĩkanĩro rĩa hinya waku.
\q1 
\v 9 Athĩnjĩri aku marohumbwo na ũthingu;
\q2 andũ aku aamũre nĩmakĩine nĩ gũkena.”
\b
\q1 
\v 10 Nĩ ũndũ wa ndungata yaku Daudi,
\q2 ndũkarega ũrĩa we ũitĩrĩirie maguta.
\b
\q1 
\v 11 Jehova nĩehĩtire na mwĩhĩtwa harĩ Daudi,
\q2 mwĩhĩtwa atangĩĩricũkwo, akĩmwĩra atĩrĩ:
\q1 “Nĩngaikarĩria ũmwe wa rũciaro rwaku
\q2 Gĩtĩ-inĩ gĩaku kĩa ũnene,
\q1 
\v 12 ariũ aku mangĩkaamenyerera kĩrĩkanĩro gĩakwa
\q2 na mawatho makwa marĩa ndĩrĩmarutaga,
\q1 hĩndĩ ĩyo ariũ ao nĩmagaikarĩra
\q2 gĩtĩ gĩaku kĩa ũnene nginya tene na tene.”
\b
\q1 
\v 13 Nĩgũkorwo Jehova nĩathuurĩte Zayuni,
\q2 akerirĩria gũtuĩke gĩikaro gĩake, akoiga atĩrĩ:
\q1 
\v 14 “Gĩkĩ nĩkĩo kĩhurũko gĩakwa nginya tene na tene;
\q2 gũkũ nĩkuo ngũtũũra njikarĩire gĩtĩ kĩa ũnene,
\q2 nĩgũkorwo nĩ niĩ ndĩyendeire;
\q1 
\v 15 nĩngakũrathima na ũmaathi mũingĩ mũno;
\q2 athĩĩni akuo ndĩmahũũnie na irio.
\q1 
\v 16 Nĩngahumba athĩnjĩri-Ngai akuo ũhonokio,
\q2 na andũ akuo arĩa aamũre matũũre mainaga nĩ gũkena.
\b
\q1 
\v 17 “Kũu nĩkuo ngaatũma rũhĩa rwa Daudi rũthundũke
\q2 na njigĩre ũrĩa njitĩrĩirie maguta tawa ũgwakana.
\q1 
\v 18 Thũ ciake nĩngacihumba thoni,
\q2 no thũmbĩ ya ũnene ĩrĩa ĩrĩ mũtwe wake nĩĩgakenga na riiri.”
\c 133
\s1 Kĩrathimo gĩa Gũikara Andũ Maiguuanĩte
\d Thaburi ya Daudi
\q1 
\v 1 Nĩ ũhoro mwega atĩa, o na ũrĩ gĩkeno,
\q2 rĩrĩa andũ a nyũmba ĩmwe maikarania maiguanĩte!
\q1 
\v 2 Nĩ ta maguta manungi wega maitĩrĩirio mũtwe,
\q2 makĩnyũrũrũkĩra nderu-inĩ,
\q1 o nderu-inĩ cia Harũni,
\q2 makanyũrũrũka nginya ngingo-inĩ ya kanjũ yake.
\q1 
\v 3 Ningĩ nĩ ta ime rĩa Herimoni
\q2 rĩkĩgwĩra Kĩrĩma gĩa Zayuni.
\q1 Nĩgũkorwo kũu nĩkuo Jehova eranĩire kĩrathimo gĩake,
\q2 nĩkĩo muoyo wa tene na tene.
\c 134
\s1 Rwĩmbo rwa Kũgooca Ngai Ũtukũ
\d Thaburi ya Agendi
\q1 
\v 1 Goocai Jehova, inyuothe ndungata cia Jehova,
\q2 inyuĩ mũtungataga mũrĩ nyũmba-inĩ ya Jehova ũtukũ.
\q1 
\v 2 Ambarariai moko manyu mũrĩ thĩinĩ wa handũ-harĩa-haamũre
\q2 mũgooce Jehova.
\b
\q1 
\v 3 Jehova, o we Mũũmbi wa igũrũ na thĩ
\q2 aromũrathima arĩ kũu Zayuni.
\c 135
\s1 Kũgooca Ngai nĩ ũndũ wa Ũnene Wake
\q1 
\v 1 Goocai Jehova.
\b
\q1 Goocai rĩĩtwa rĩa Jehova;
\q2 inyuĩ ndungata cia Jehova-rĩ, mũgoocei,
\q1 
\v 2 inyuĩ mũtungataga thĩinĩ wa nyũmba ya Jehova,
\q2 o inyuĩ mũrũgamaga nja-inĩ cia nyũmba ya Ngai witũ.
\b
\q1 
\v 3 Goocai Jehova, nĩgũkorwo Jehova nĩ mwega;
\q2 inai mũgooce rĩĩtwa rĩake, nĩgũkorwo nĩ rĩega.
\q1 
\v 4 Nĩgũkorwo Jehova nĩethuurĩire Jakubu atuĩke wake,
\q2 agathuura Isiraeli atuĩke igai rĩake kĩũmbe.
\b
\q1 
\v 5 Niĩ nĩnjũũĩ atĩ Jehova nĩ mũnene,
\q2 atĩ Mwathani witũ nĩ mũnene gũkĩra ngai ciothe.
\q1 
\v 6 Jehova ekaga ũrĩa wothe ekwenda,
\q2 kũu igũrũ na gũkũ thĩ,
\q2 o na kũu iria-inĩ o na kũrĩa guothe kũriku mũno.
\q1 
\v 7 Nĩwe ũtũmaga matu mambate kuuma ituri-inĩ cia thĩ;
\q2 nĩwe ũtũmaga kũgĩe heni irehanĩte na mbura,
\q2 na akarehe rũhuho kuuma mĩthithũ-inĩ yake.
\b
\q1 
\v 8 Nĩwe waringire marigithathi ma Misiri,
\q2 marigithathi ma andũ na ma nyamũ.
\q1 
\v 9 Wee Misiri, nĩwe watũmire thĩinĩ waku kũringwo ciama na morirũ,
\q2 agĩũkĩrĩra Firaũni na ndungata ciake ciothe.
\q1 
\v 10 Nĩwe waringire ndũrĩrĩ nyingĩ
\q2 na akĩũraga athamaki maarĩ hinya:
\q1 
\v 11 nĩo Sihoni mũthamaki wa Aamori,
\q2 na Ogu mũthamaki wa Bashani,
\q2 o na athamaki othe a Kaanani;
\q1 
\v 12 akĩheana bũrũri wao ũtuĩke igai,
\q2 ũtuĩke igai kũrĩ andũ ake a Isiraeli.
\b
\q1 
\v 13 Rĩĩtwa rĩaku, Wee Jehova, rĩtũũraga nginya tene,
\q2 ngumo yaku, Wee Jehova, ĩgakinyĩra njiarwa na njiarwa.
\q1 
\v 14 Nĩgũkorwo Jehova nĩagaciirĩrĩra andũ ake,
\q2 na aiguĩre ndungata ciake tha.
\b
\q1 
\v 15 Mĩhianano ya ndũrĩrĩ ĩthondeketwo na betha na thahabu,
\q2 o wĩra wa moko ma andũ.
\q1 
\v 16 Nĩĩrĩ tũnua, no ndĩaragia,
\q2 nĩĩrĩ maitho, no ndĩonaga;
\q1 
\v 17 nĩĩrĩ matũ, no ndĩiguaga,
\q2 o na ndĩrĩ mĩhũmũ tũnua-inĩ twayo.
\q1 
\v 18 Andũ arĩa mamĩthondekaga makaahaana o tayo,
\q2 na noguo arĩa othe mamĩĩhokaga makaahaana.
\b
\q1 
\v 19 Inyuĩ nyũmba ya Isiraeli, goocai Jehova;
\q2 Inyuĩ nyũmba ya Harũni, goocai Jehova;
\q1 
\v 20 Inyuĩ nyũmba ya Lawi, goocai Jehova;
\q2 inyuĩ arĩa mũmwĩtigĩrĩte, goocai Jehova.
\q1 
\v 21 Jehova arogoocwo kuuma Zayuni,
\q2 o we ũtũũraga kũu Jerusalemu.
\b
\q1 Goocai Jehova.
\c 136
\s1 Rwĩmbo rwa Gũcookia Ngaatho
\q1 
\v 1 Cookeriai Jehova ngaatho, tondũ nĩ mwega.
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 2 Cookeriai Ngai wa ngai iria ingĩ ngaatho.
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 3 Cookeriai Mwathani wa aathani ngaatho:
\q4 Wendo wake nĩ wa tene na tene.
\b
\q1 
\v 4 we wiki nĩwe wĩkaga maũndũ manene ma magegania,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 5 nĩwe wombire igũrũ na ũndũ wa ũmenyo wake,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 6 nĩwe watambũrũkirie thĩ nyũmũ igũrũ rĩa maaĩ,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 7 nĩwe wombire imũrĩ iria nene,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 8 riũa rĩathage mũthenya,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 9 naguo mweri na njata ciathage ũtukũ;
\q4 Wendo wake nĩ wa tene na tene.
\b
\q1 
\v 10 nĩwe waringire marigithathi ma Misiri,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 11 akĩruta Isiraeli gatagatĩ-inĩ kao,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 12 na guoko kwa hinya na atambũrũkĩtie gĩcoka gĩake,
\q4 Wendo wake nĩ wa tene na tene.
\b
\q1 
\v 13 nĩwe wagayũkanirie Iria Itune rĩgĩtigana,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 14 agĩtũma andũ a Isiraeli matuĩkanie gatagatĩ karĩo,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 15 no Firaũni na ita rĩake akĩmahubĩkanĩria kũu Iria-inĩ Itune;
\q4 Wendo wake nĩ wa tene na tene.
\b
\q1 
\v 16 nĩwe watongoririe andũ ake magĩtuĩkanĩria werũ-inĩ,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 17 nĩwe waringire athamaki maarĩ anene,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 18 na akĩũraga athamaki maarĩ ngumo:
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 19 nĩo Sihoni mũthamaki wa Aamori,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 20 na Ogu mũthamaki wa Bashani;
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 21 na akĩheana bũrũri wao ũtuĩke igai,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 22 ũgĩtuĩka igai rĩa Isiraeli ndungata yake;
\q4 Wendo wake nĩ wa tene na tene.
\b
\q1 
\v 23 nĩwe watũririkanire rĩrĩa twahatĩrĩirio,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 24 na agĩtũhonokia kuuma kũrĩ thũ ciitũ,
\q4 Wendo wake nĩ wa tene na tene.
\q1 
\v 25 nĩwe ũheaga ciũmbe ciothe irio.
\q4 Wendo wake nĩ wa tene na tene.
\b
\q1 
\v 26 Cookeriai Mũrungu wa igũrũ ngaatho.
\q4 Wendo wake nĩ wa tene na tene.
\c 137
\s1 Gũcakaya kwa Isiraeli rĩrĩa Maatahĩtwo
\q1 
\v 1 Ngurumo-inĩ cia njũũĩ cia Babuloni nĩkuo twaikaraga thĩ tũkarĩra,
\q2 twaririkana Zayuni.
\q1 
\v 2 Kũu mĩtĩ-inĩ ya mĩethia nĩkuo
\q2 twacuuragia inanda ciitũ cia mũgeeto,
\q1 
\v 3 nĩgũkorwo tũrĩ kũu andũ arĩa maatũtahĩte nĩmatwĩraga tũmainĩre nyĩmbo,
\q2 o acio atũnyariiri magatwĩra tũmainĩre nyĩmbo tũkenete,
\q2 magatwĩra atĩrĩ, “Tũinĩrei rwĩmbo rũmwe rwa iria mwainaga mũrĩ Zayuni!”
\b
\q1 
\v 4 Tũngĩhota atĩa kũina nyĩmbo cia Jehova
\q2 tũrĩ bũrũri wa ũgeni?
\q1 
\v 5 Ingĩkariganĩrwo nĩwe, Wee Jerusalemu-rĩ,
\q2 guoko gwakwa kwa ũrĩo kũrokĩriganĩrwo nĩ ũũgĩ wakuo wa gwĩka maũndũ.
\q1 
\v 6 Rũrĩmĩ rwakwa rũronyiitana na karakara
\q2 ingĩkaaga gũkũririkana,
\q1 ingĩkaaga gũtua Jerusalemu
\q2 gĩkeno gĩakwa kĩrĩa kĩnene.
\b
\q1 
\v 7 Wee Jehova, ririkana ũrĩa andũ a Edomu\f + \fr 137:7 \ft Andũ a Edomu maarĩ a rũciaro rwa Esaũ.\f* meekire,
\q2 mũthenya ũrĩa itũũra rĩa Jerusalemu rĩanyiitirwo.
\q1 Maanĩrĩire, makiuga atĩrĩ, “Rĩmomorei,
\q2 rĩmomorei o nginya mũthingi-inĩ warĩo!”
\b
\q1 
\v 8 Wee mwarĩ wa Babuloni, o wee ũtuĩrĩirwo kũniinwo,
\q2 gũkena nĩ mũndũ ũrĩa ũgũgwĩka
\q2 o ta ũguo ũtwĩkĩte:
\q1 
\v 9 gũkena nĩ mũndũ ũrĩa ũhuragia tũkenge twaku,
\q2 agatũgũthithia ndwaro-inĩ cia mahiga.\f + \fr 137:9 \ft Nĩguo njiaro cia andũ arĩa maatoorio mbaara-inĩ ithire-rĩ, tũkenge twaringithagio mĩtwe mahiga-inĩ tũgakua.\f*
\c 138
\s1 Ihooya rĩa Gũcookia Ngaatho
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, nĩngũkũgooca na ngoro yakwa yothe;
\q2 ngũkũinĩra ngũgooce ngai iria ingĩ irĩ o ho.
\q1 
\v 2 Ngũinamĩrĩra njerekeire hekarũ-inĩ yaku ĩrĩa nyamũre,
\q2 ngooce rĩĩtwa rĩaku,
\q2 nĩ ũndũ wa wendo waku na wĩhokeku waku,
\q1 nĩgũkorwo nĩũtũũgĩrĩtie rĩĩtwa rĩaku,
\q2 na ũgatũũgĩria kiugo gĩaku
\q2 makĩria ya maũndũ marĩa mangĩ mothe.
\q1 
\v 3 Hĩndĩ ĩrĩa ndagwĩtire, nĩwanjĩtĩkire;
\q2 wanyũmĩrĩirie na ũkĩnjĩkĩra hinya ngoro.
\b
\q1 
\v 4 Wee Jehova-rĩ, athamaki othe a thĩ nĩmakũgoocage,
\q2 rĩrĩa maigua ciugo cia kanua gaku.
\q1 
\v 5 Nĩmaganage ũhoro wa njĩra cia Jehova,
\q2 nĩgũkorwo riiri wa Jehova nĩ mũnene.
\b
\q1 
\v 6 O na gũtũĩka Jehova arĩ igũrũ-rĩ,
\q2 nĩaroraga andũ arĩa enyiihia,
\q2 no arĩa etĩĩi akamenya ũhoro wao arĩ o kũraya.
\q1 
\v 7 O na ingĩgerera mathĩĩna-inĩ,
\q2 Wee nĩũmenyagĩrĩra muoyo wakwa;
\q1 ũtambũrũkagia guoko gwaku ũgookĩrĩra marakara ma thũ ciakwa,
\q2 ũkaahonokia na guoko gwaku kwa ũrĩo.
\q1 
\v 8 Jehova nĩakahingia muoroto wake harĩ niĩ;
\q2 wendo waku, Wee Jehova, nĩ wa tene na tene;
\q2 nĩ ũndũ ũcio ndũgatiganĩrie wĩra wa moko maku.
\c 139
\s1 Ngai Ũrĩa Ũtangĩũrĩrwo
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova-rĩ, nĩũũthuthuurĩtie
\q2 na ũkaamenya.
\q1 
\v 2 Nĩũĩ rĩrĩa njikarĩte thĩ na rĩrĩa njũkĩrĩte
\q2 ũkamenya meciiria makwa ũrĩ o kũraya.
\q1 
\v 3 Nĩũũĩ ngiumagara o na ngĩkoma;
\q2 Wee nĩũũĩ mĩthiĩre yakwa yothe.
\q1 
\v 4 Wee Jehova-rĩ, itanagweta kiugo na rũrĩmĩ rwakwa,
\q2 Wee nĩũkoragwo ũkĩũĩ biũ.
\b
\q1 
\v 5 Nĩũnjirigĩire mbere na thuutha;
\q2 nĩũnjigĩrĩire guoko gwaku.
\q1 
\v 6 Ũmenyo ta ũcio nĩ wa magegania mũno harĩ niĩ,
\q2 ũrĩ igũrũ mũno ndingĩũkinyĩra.
\b
\q1 
\v 7 Nĩ kũ ingĩthiĩ njeherere Roho waku?
\q2 Ingĩũrĩra kũ nyume ũthiũ-inĩ waku?
\q1 
\v 8 Ingĩambata thiĩ igũrũ, Wee ũrĩ kuo;
\q2 ingĩara ũrĩrĩ wakwa kũrĩa kũriku mũno, Wee ũrĩ o kuo.
\b
\q1 
\v 9 Ingĩũmbũka na mathagu ma gũgĩkĩa,
\q2 ingĩthiĩ gũtũũra mũrĩmo ũrĩa ũngĩ wa iria, kũndũ kũraya mũno,
\q1 
\v 10 o na kũu guoko gwakwa nokuo kũngĩndongoria,
\q2 guoko gwaku kwa ũrĩo gũkĩĩnyiite kũnũmĩtie.
\b
\q1 
\v 11 Ingiuga atĩrĩ, “Ti-itherũ nduma nĩĩkũũhitha,
\q2 naguo ũtheri ũyũ ũũthiũrũrũkĩirie ũtuĩke ũtukũ,”
\q1 
\v 12 o na nduma ndĩrĩ hĩndĩ ĩngĩgũtumanĩra;
\q2 ũtukũ ũkwara ta mũthenya,
\q2 nĩgũkorwo nduma kũrĩ we nĩ ta ũtheri.
\b
\q1 
\v 13 Nĩgũkorwo nĩwe wombire ciĩga ciakwa cia na thĩinĩ;
\q2 wanyiitithanirie ndĩ o nda ya maitũ.
\q1 
\v 14 Nĩngũkũgooca nĩ ũndũ mũũmbĩre ũrĩa nyũmbĩtwo naguo
\q2 nĩ wa kũmakania na wa magegania;
\q1 ciĩko ciaku nĩ cia magegania,
\q2 niĩ mwene nĩnjũũĩ ũguo o wega.
\q1 
\v 15 Mahĩndĩ makwa matiahithĩkĩte harĩwe,
\q2 rĩrĩa ndoombĩirwo kũrĩa kũhitharu.
\q1 Rĩrĩa ndanyiitithanagio hamwe ndĩ thĩ kũrĩa kũriku mũno-rĩ,
\q2 
\v 16 maitho maku nĩmonaga mwĩrĩ wakwa ũtanombwo biũ.
\q1 Matukũ mothe marĩa nyamũrĩirwo
\q2 nĩmandĩkĩtwo ibuku-inĩ rĩaku
\q2 o na mbere ya ũmwe wamo kũgĩa.
\b
\q1 
\v 17 Hĩ! Ĩ meciiria maku matikĩrĩ ma bata harĩ niĩ, Wee Mũrungu!
\q2 Kaĩ mũigana wamo nĩ mũnene-ĩ!
\q1 
\v 18 Ingĩtua kũmatara,
\q2 no maingĩhe gũkĩra mũthanga.
\q1 Hĩndĩ ĩrĩa ndokĩra,
\q2 ndĩ o hamwe nawe.
\b
\q1 
\v 19 Wee Ngai-rĩ, naarĩ korwo woraga arĩa aaganu!
\q2 Njehererai, inyuĩ mũnyootagĩra gũita thakame!
\q1 
\v 20 Maaragia ũhoro waku marĩ na meciiria mooru;
\q2 arĩa magũthũire mahũthagĩra rĩĩtwa rĩaku ũũru.
\q1 
\v 21 Wee Jehova, githĩ ndithũire arĩa magũthũire,
\q2 na ngamena arĩa magũũkagĩrĩra?
\q1 
\v 22 Gũthũũra ndĩmathũire o biũ;
\q2 ndĩmatuaga thũ ciakwa.
\b
\q1 
\v 23 Wee Mũrungu, thuthuuria, ũmenye ngoro yakwa;
\q2 ngeria ũmenye meciiria makwa.
\q1 
\v 24 Rora wone kana nĩ harĩ mĩthiĩre mĩũru thĩinĩ wakwa,
\q2 na ũkĩndongorie na njĩra ĩrĩa ya tene na tene.
\c 140
\s1 Ihooya rĩa kũũria Ũgitĩri
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, hatũra kuuma moko-inĩ ma andũ arĩa ooru;
\q2 ngitĩra harĩ andũ arĩa mahũthagĩra ũhinya,
\q1 
\v 2 o acio mathugundaga maũndũ mooru ngoro-inĩ ciao,
\q2 na magathugunda mbaara o mũthenya.
\q1 
\v 3 Manooraga nĩmĩ ciao ikohĩga ta rũrĩmĩ rwa nyoka;
\q2 mĩromo yao yaragia maũndũ marũrũ ta thumu wa nduĩra.
\b
\q1 
\v 4 Wee Jehova, njeheria moko-inĩ ma andũ arĩa aaganu;
\q2 ngitĩra kuuma harĩ andũ arĩa mahũthagĩra ũhinya,
\q2 o acio mabangaga ũrĩa mangĩhĩnga magũrũ makwa.
\q1 
\v 5 Andũ arĩa etĩĩi nĩmanyambĩire mũtego;
\q2 nĩmatambũrũkĩtie ndigi cia wabu wao,
\q2 na makanjigĩra mĩtego njĩra-inĩ yakwa.
\b
\q1 
\v 6 Wee Jehova, nguuga atĩrĩ, “Wee nĩwe Mũrungu wakwa.”
\q2 Wee Jehova-rĩ, igua ngĩgũkaĩra nĩguo, ũnjiguĩre tha.
\q1 
\v 7 Wee Mwathani Jehova, o Wee ũrĩa mũũhonokia ũrĩ hinya,
\q2 Wee ũgitagĩra mũtwe wakwa mũthenya wa mbaara:
\q1 
\v 8 Wee Jehova, ndũkahingĩrie arĩa aaganu merirĩria mao,
\q2 ndũkareke mĩbango yao ĩgaacĩre,
\q2 matikae gwĩtĩĩa.
\b
\q1 
\v 9 Mĩtwe ya arĩa mandigicĩirie
\q2 ĩrohumbĩkanio na mathĩĩna marĩa marehetwo nĩ mĩromo yao.
\q1 
\v 10 Marogwĩrwo nĩ makara me gwakana;
\q2 maroikio mwaki-inĩ,
\q2 maikio marima marĩ mũtondo, kũrĩa matakoima o na rĩ.
\q1 
\v 11 Ndũkanareke arĩa macambanagia magaacĩre bũrũri-inĩ;
\q2 mwanangĩko ũrothingata andũ arĩa mahũthagĩra ũhinya.
\b
\q1 
\v 12 Niĩ nĩnjũũĩ atĩ Jehova nĩarũagĩra kĩhooto kĩa arĩa athĩĩni,
\q2 na akagitĩra kĩhooto kĩa arĩa abatari.
\q1 
\v 13 Ti-itherũ arĩa athingu nĩmarĩgoocaga rĩĩtwa rĩaku,
\q2 na arĩa arũngĩrĩru nĩmagatũũra ũthiũ-inĩ waku.
\c 141
\s1 Ihooya rĩa Kũgitĩrwo kuuma Ũũru-inĩ
\d Thaburi ya Daudi
\q1 
\v 1 Wee Jehova, nĩwe ndĩrakaĩra; hiũha ũũke kũrĩ niĩ.
\q2 Igua mũgambo wakwa ngĩgũkaĩra.
\q1 
\v 2 Ihooya rĩakwa rĩroambata mbere yaku ta mũtararĩko wa ũbumba;
\q2 nakuo kwambararia moko makwa kũrotuĩka ta igongona rĩa hwaĩ-inĩ.
\b
\q1 
\v 3 Wee Jehova, iga mũrangĩri kanua-inĩ gakwa,
\q2 rangagĩra mũrango ũyũ wa mĩromo yakwa.
\q1 
\v 4 Ndũkareke ngoro yakwa ĩguucĩrĩrio ũndũ-inĩ mũũru,
\q2 ndigatuĩke wa gwĩka ciĩko cia waganu
\q1 hamwe na andũ arĩa amaramari;
\q2 Ndũkareke ndĩe irio ciao iria irĩ mũrĩo.
\b
\q1 
\v 5 Mũndũ mũthingu nĩakĩĩninge: ũndũ ũcio nĩ wa kũnyonia ũtugi;
\q2 kũndũithia nĩakĩndũithie: ũguo no ta kũnjitĩrĩria maguta mũtwe wakwa.
\q2 Mũtwe wakwa ndũngĩrega gũitĩrĩrio maguta macio.
\b
\q1 No rĩrĩ, ihooya rĩakwa nĩ rĩa gũtũũra ndeganĩte na ciĩko cia andũ arĩa meekaga ũũru;
\q2 
\v 6 aathani ao magaikio thĩ kuuma igũrũ rĩa rwaro rwa ihiga,
\q2 nao arĩa aaganu nĩmakamenya atĩ ciugo ciakwa ciarĩ cia ma.
\q1 
\v 7 Nĩmakoiga atĩrĩ, “O ta ũrĩa mũndũ acimbaga mũgũnda na akahũũra hianyũ,
\q2 no taguo mahĩndĩ maitũ maharaganĩtio mũromo-inĩ wa mbĩrĩra.”
\b
\q1 
\v 8 No rĩrĩ, maitho makwa nĩwe macũthĩrĩirie, Wee Mwathani Jehova;
\q2 nĩ harĩwe njũragĩra; nĩ ũndũ ũcio ndũkareke ngue.
\q1 
\v 9 Ngitĩra ndikanyiitwo nĩ mĩtego ĩrĩa nyambĩirwo,
\q2 ũnjehanĩrĩrie na mĩtego ya andũ arĩa mekaga ũũru.
\q1 
\v 10 Andũ acio aaganu maroogwa wabu-inĩ wao ene,
\q2 no niĩ ngĩhĩtũkage itekuona ũgwati.
\c 142
\s1 Ihooya rĩa kũũria Gũkũũrwo kuuma Mĩnyamaro-inĩ
\d Thaburi ya Daudi
\q1 
\v 1 Ngayagĩra Jehova nyanĩrĩire;
\q2 ngwambararia mũgambo wakwa kũrĩ Jehova anjiguĩre tha.
\q1 
\v 2 Njitũrũraga mateta makwa mbere yake;
\q2 ndĩrĩmwĩraga thĩĩna wakwa ndĩ mbere yake.
\b
\q1 
\v 3 Rĩrĩa roho wakwa waringĩka thĩinĩ wakwa,
\q2 Wee nĩwe ũmenyaga njĩra ĩrĩa ndĩrĩgera.
\q1 Njĩra-inĩ ĩrĩa thiiagĩra-rĩ,
\q2 andũ nĩmahithĩire mũtego.
\q1 
\v 4 Ta rora mwena wakwa wa ũrĩo wone;
\q2 gũtirĩ o na ũmwe ũranũmbũiya.
\q1 Ndirĩ na ha kũũrĩra;
\q2 muoyo wakwa gũtirĩ mũndũ o na ũmwe ũngĩũmenyerera.
\b
\q1 
\v 5 Wee Jehova, nĩwe ngayagĩra;
\q2 njugaga atĩrĩ, “Wee nĩwe rĩũrĩro rĩakwa,
\q2 na igai rĩakwa bũrũri-inĩ wa arĩa marĩ muoyo.”
\q1 
\v 6 Thikĩrĩria gũkaya gwakwa,
\q2 nĩgũkorwo ndĩĩmũhinyĩrĩrie mũno;
\q1 ndeithũra kuuma kũrĩ andũ arĩa mathingatanĩte na niĩ,
\q2 nĩgũkorwo marĩ na hinya mũno kũngĩra.
\q1 
\v 7 Njohorithia kuuma kĩoho-inĩ gĩakwa,
\q2 nĩguo ngoocage rĩĩtwa rĩaku.
\b
\q1 Hĩndĩ ĩyo andũ arĩa athingu nĩmakandigiicĩria,
\q2 nĩ ũndũ wa ũrĩa ũnjĩkĩte wega.
\c 143
\s1 Ihooya rĩa kũũria Kũhonokio
\d Thaburi ya Daudi
\q1 
\v 1 Igua ihooya rĩakwa, Wee Jehova,
\q2 thikĩrĩria kĩrĩro gĩakwa ũnjiguĩre tha;
\q1 ũka ũndeithie,
\q2 nĩ ũndũ wa wĩhokeku waku na ũthingu waku.
\q1 
\v 2 Ndũgaciirithie ndungata yaku,
\q2 nĩgũkorwo maitho-inĩ maku gũtirĩ mũndũ ũrĩ muoyo ũngĩtuuo mũthingu.
\b
\q1 
\v 3 Thũ nĩĩthingatĩte,
\q2 ĩkangurumania thĩ tĩĩri-inĩ;
\q1 ĩtũmaga ndũũre nduma-inĩ
\q2 ta arĩa maakuire tene.
\q1 
\v 4 Nĩ ũndũ ũcio roho wakwa ũkaringĩka thĩinĩ wakwa;
\q2 ngoro yakwa nĩĩmakĩte mũno thĩinĩ wakwa.
\b
\q1 
\v 5 Nĩndĩrĩririkanaga matukũ marĩa ma tene;
\q2 ndĩrĩcũũranagia mawĩko maku mothe
\q2 na ngatarania maũndũ marĩa moko maku meekĩte.
\q1 
\v 6 Ndambũrũkĩtie moko makwa na kũrĩ we;
\q2 muoyo wakwa ũkũnyootagĩra ta bũrũri ũrĩa mũũmũ.
\b
\q1 
\v 7 Wee Jehova, hiũha kũnjĩtĩka;
\q2 roho wakwa nĩũthirĩtwo nĩ hinya.
\q1 Tiga kũũhitha ũthiũ waku,
\q2 ndikahaane ta arĩa matoonyaga irima.
\q1 
\v 8 O rũciinĩ reke njiguage kiugo kĩa wendo waku ũrĩa ũtathiraga,
\q2 nĩgũkorwo nĩwe ndĩĩhokete.
\q1 Nyonia njĩra ĩrĩa njagĩrĩirwo nĩkũgera,
\q2 nĩgũkorwo muoyo wakwa ndĩwerekeirie igũrũ kũrĩ we.
\q1 
\v 9 Ndeithũra kuuma kũrĩ thũ ciakwa, Wee Jehova,
\q2 nĩgũkorwo ndĩĩhithaga harĩwe.
\q1 
\v 10 Nduta gwĩkaga wendi waku,
\q2 nĩgũkorwo Wee nĩwe Ngai wakwa;
\q1 Roho waku mwega arondongoragia,
\q2 ngeragĩre kũrĩa kwaraganu.
\b
\q1 
\v 11 Wee Jehova, nĩ ũndũ wa rĩĩtwa rĩaku, tũũria muoyo wakwa;
\q2 nĩ ũndũ wa ũthingu waku-rĩ, nduta kuuma mĩnyamaro-inĩ.
\q1 
\v 12 Nĩ ũndũ wa wendo waku ũtathiraga, kiria thũ ciakwa;
\q2 niina arĩa othe maathũire,
\q2 nĩgũkorwo niĩ ndĩ ndungata yaku.
\c 144
\s1 Mũthamaki kũhooya Ngai Amũteithie
\d Thaburi ya Daudi
\q1 
\v 1 Jehova arogoocwo, o we Rwaro rwakwa rwa Ihiga,
\q2 o we ũmenyithagia moko makwa mũrũĩre wa mbaara,
\q2 agakĩruta ciara ciakwa kũrũa mbaara.
\q1 
\v 2 Nĩwe Ngai ũrĩa ũnyendete, na nĩwe kĩirigo gĩakwa kĩa hinya,
\q2 o we kĩĩhitho gĩakwa na mũhonokia wakwa,
\q1 ningĩ nĩwe ngo yakwa, na nĩ harĩ we njũragĩra,
\q2 o we ũtũmaga andũ a ndũrĩrĩ maathĩke marĩ rungu rwakwa.
\b
\q1 
\v 3 Wee Jehova, mũndũ akĩrĩ kĩ nĩguo ũmũmenyagĩrĩre,
\q2 nake mũrũ wa mũndũ akĩrĩ kĩ nĩgeetha ũmũrũmbũyagie?
\q1 
\v 4 Mũndũ no ta mĩhũmũ;
\q2 matukũ make mathiraga na ihenya o ta kĩĩruru.
\b
\q1 
\v 5 Wee Jehova, hingũra igũrũ ũikũrũke;
\q2 hutia irĩma, nĩgeetha irute ndogo.
\q1 
\v 6 Henũkia rũheni ũhurunje thũ ciaku;
\q2 ikia mĩguĩ yaku ũcingatithie.
\q1 
\v 7 Tambũrũkia guoko gwaku ũrĩ igũrũ;
\q2 ndeithũra na ũũthare
\q1 kuuma kũrĩ maaĩ maya maingĩ,
\q2 ũndute kuuma moko-inĩ ma andũ a kũngĩ
\q1 
\v 8 arĩa tũnua twao twaragia maheeni,
\q2 o acio moko mao ma ũrĩo marĩ na wara.
\b
\q1 
\v 9 Wee Ngai, nĩngũkũinĩra rwĩmbo rwerũ;
\q2 ngũkũinĩra na kĩnanda kĩrĩa kĩgeetetwo na nga ikũmi,
\q1 
\v 10 nyinĩre Ũrĩa ũhootanagĩra athamaki,
\q2 o we ũhonokagia Daudi ndungata yake
\q2 harĩ rũhiũ rwa njora rwa ũragani.
\b
\q1 
\v 11 Ndeithũra na ũũthare,
\q2 ũndute kuuma moko-inĩ ma andũ a kũngĩ,
\q1 arĩa tũnua twao twaragia maheeni,
\q2 o acio moko mao ma ũrĩo marĩ ma wara.
\b
\q1 
\v 12 Hĩndĩ ĩyo aanake aitũ
\q2 magaatuĩka ta mĩmera mĩrore wega wĩthĩ-inĩ wao,
\q1 nao airĩtu aitũ mahaane ta itugĩ
\q2 ciacũhĩtio cia kũgemia nyũmba ya ũthamaki.
\q1 
\v 13 Makũmbĩ maitũ makaiyũragio
\q2 irio cia mĩthemba yothe.
\q1 Ngʼondu ciitũ ikaingĩha ikinye ngiri nyingĩ,
\q2 cingĩhe ikinye makũmi ma ngiri kũu mĩgũnda-inĩ iitũ;
\q2 
\v 14 nacio ndegwa ciitũ nĩigakuuaga mĩrigo mĩritũ.
\q1 Thingo itigakorwo na mĩanya,
\q2 kana gũtahwo tũtwarwo ũkombo-inĩ,
\q2 o na gũtigakorwo na kĩrĩro kĩa mĩnyamaro njĩra-inĩ cia matũũra.
\b
\q1 
\v 15 Kũrathimwo nĩ andũ arĩa matariĩ ta ũguo;
\q2 kũrathimwo nĩ andũ arĩa Ngai wao arĩ we Jehova.
\c 145
\s1 Ũnene na Wega wa Ngai
\d Thaburi ya Daudi
\q1 
\v 1 Nĩngũgũtũũgĩria, Wee Ngai wakwa Mũthamaki;
\q2 ndĩrĩĩgoocaga rĩĩtwa rĩaku tene na tene.
\q1 
\v 2 O mũthenya ndĩrĩkũgoocaga
\q2 na ngumagie rĩĩtwa rĩaku tene na tene.
\b
\q1 
\v 3 Jehova nĩwe mũnene, na nowe wagĩrĩire kũgoocwo mũno;
\q2 ũnene wake gũtirĩ mũndũ ũngĩhota kũũtuĩria.
\q1 
\v 4 Rũciaro rũmwe nĩrũkarahĩra rũrĩa rũngĩ maũndũ marĩa waneka;
\q2 nĩrũkamenyithanagia ũhoro wa ciĩko ciaku cia hinya.
\q1 
\v 5 Nĩmakaaria ũhoro wa ũkaru wa ũnene waku ũrĩa ũrĩ riiri,
\q2 na niĩ ndaranagie ũhoro wa ciĩko ciaku cia magegania.
\q1 
\v 6 Nĩmarĩheanaga ũhoro wa ũhoti wa maũndũ maku ma kũmakania,
\q2 na niĩ hunjagie ũhoro wa ũnene wa ciĩko ciaku.
\q1 
\v 7 Nĩmagakũngũĩra wega waku mũingĩ,
\q2 na maine ũhoro wa ũthingu waku makenete.
\b
\q1 
\v 8 Jehova nĩ mũtugi na nĩ mũigua-tha,
\q2 ndahiũhaga kũrakara, na aiyũrĩtwo nĩ wendo.
\q1 
\v 9 Jehova nĩ mwega harĩ andũ othe;
\q2 nĩaiguagĩra tha kĩrĩa gĩothe ombĩte.
\q1 
\v 10 Wee Jehova, kĩrĩa gĩothe ũmbĩte nĩkĩrĩkũgoocaga;
\q2 andũ aku arĩa aamũre nĩmarĩgũkumagia.
\q1 
\v 11 Nĩmarĩheanaga ũhoro wa riiri wa ũthamaki waku,
\q2 na maaragie ũhoro wa hinya waku,
\q1 
\v 12 nĩgeetha andũ othe mamenye ũhoro wa ciĩko ciaku cia hinya,
\q2 o na ũkaru wa ũthamaki waku, ũrĩa ũrĩ riiri.
\q1 
\v 13 Ũthamaki waku nĩ ũthamaki wa gũtũũra tene na tene,
\q2 naguo wathani waku ũtũũraga nginya njiarwa ciothe.
\b
\q1 Jehova nĩ mwĩhokeku harĩ ciĩranĩro ciake ciothe,
\q2 na nĩendete kĩrĩa gĩothe ombĩte.
\q1 
\v 14 Jehova nĩanyiitagĩrĩra arĩa othe maragũa,
\q2 na agatiira arĩa othe mainamĩte.
\q1 
\v 15 Maitho ma andũ othe nĩwe macũthĩrĩirie,
\q2 na nĩũmaheaga irio ciao hĩndĩ ĩrĩa yagĩrĩire.
\q1 
\v 16 Ũkũnjũraga guoko gwaku,
\q2 na ũkahingĩria kĩndũ gĩothe kĩrĩ muoyo mabataro makĩo.
\b
\q1 
\v 17 Jehova nĩ mũthingu njĩra-inĩ ciake ciothe,
\q2 na nĩendete kĩrĩa gĩothe ombĩte.
\q1 
\v 18 Jehova arĩ hakuhĩ na andũ arĩa othe mamũkayagĩra,
\q2 arĩa othe mamũkayagĩra na ma.
\q1 
\v 19 Arĩa othe mamwĩtigagĩra nĩamahingagĩria mabataro mao;
\q2 nĩaiguaga kĩrĩro kĩao na akamahonokia.
\q1 
\v 20 Jehova nĩamenyagĩrĩra arĩa othe mamwendete,
\q2 no arĩa othe aaganu nĩkũniina akaamaniina.
\b
\q1 
\v 21 Kanua gakwa karĩaragia gakagooca Jehova.
\q2 Kĩũmbe o gĩothe nĩgĩkĩgooce rĩĩtwa rĩake itheru
\q2 nginya tene na tene.
\c 146
\s1 Kũgooca Ngai nĩ ũndũ wa Ũteithio Wake
\q1 
\v 1 Goocai Jehova.
\b
\q2 Wee ngoro yakwa-rĩ, gooca Jehova.
\q2 
\v 2 Ndĩgoocaga Jehova hĩndĩ ĩrĩa yothe ngũtũũra muoyo;
\q2 ndĩrĩinaga, ngoocage Ngai wakwa rĩrĩa rĩothe ngũtũũra muoyo.
\b
\q1 
\v 3 Ndũkanaige mwĩhoko waku harĩ anene,
\q2 kana harĩ andũ, arĩa matangĩhota kũhonokania.
\q1 
\v 4 Rĩrĩa roho wao wameherera, macookaga o tĩĩri-inĩ;
\q2 mũthenya o ro ũcio mĩbango yao ĩtuĩkaga ya tũhũ.
\b
\q1 
\v 5 Kũrathimwo-rĩ, nĩ mũndũ ũrĩa ũteithio wake
\q2 uumaga kũrĩ Mũrungu wa Jakubu,
\q2 ũrĩa mwĩhoko wake ũrĩ harĩ Jehova Ngai wake,
\q1 
\v 6 Mũũmbi wa igũrũ na thĩ,
\q2 na iria, na kĩrĩa gĩothe gĩtũũraga thĩinĩ wacio:
\q2 ũcio nĩwe Jehova, ũrĩa ũtũũraga arĩ mwĩhokeku nginya tene.
\q1 
\v 7 Nĩarũgamagĩrĩra kĩhooto kĩa arĩa ahatĩrĩrie,
\q2 na akahe arĩa ahũtu irio.
\q1 Jehova nĩwe wohoraga arĩa mohetwo,
\q2 
\v 8 Jehova nĩahingũraga maitho ma arĩa atumumu,
\q1 Jehova nĩatiiraga arĩa mainamĩte,
\q2 Jehova nĩendete andũ arĩa athingu.
\q1 
\v 9 Jehova nĩamenyagĩrĩra andũ a kũngĩ,
\q2 na agatũũria ciana cia ngoriai o na mũtumia wa ndigwa,
\q2 no njĩra cia andũ arĩa aaganu nĩacirigiicaga.
\b
\q1 
\v 10 Jehova egũtũũra athamakaga nginya tene,
\q2 Ngai waku, wee Zayuni, athamakage njiarwa na njiarwa.
\b
\q1 Goocai Jehova.
\c 147
\s1 Kũgooca Ngai nĩ ũndũ wa Kũmenyerera Jerusalemu
\q1 
\v 1 Goocai Jehova.
\b
\q1 Kaĩ nĩ ũndũ mwega kũgooca Ngai witũ na rwĩmbo-ĩ,
\q2 kaĩ nĩ ũndũ mwega na mwagĩrĩru kũmũgooca-ĩ!
\b
\q1 
\v 2 Jehova nĩwe wakaga Jerusalemu;
\q1 nĩwe ũcookagĩrĩria andũ a Isiraeli arĩa matahĩtwo.
\q1 
\v 3 Nĩwe ũhonagia arĩa athuthĩku ngoro,
\q2 na akamooha ironda ciao.
\b
\q1 
\v 4 Nĩwe ũmenyaga mũigana wa njata,
\q2 na akahe njata o njata rĩĩtwa rĩayo.
\q1 
\v 5 Mwathani witũ nĩwe mũnene na nĩ arĩ hinya mũingĩ;
\q2 ũmenyo wake ndũrĩ mũthia.
\q1 
\v 6 Jehova nĩwe ũtiiragĩrĩra andũ arĩa ahooreri,
\q2 no arĩa aaganu amatungumanagia thĩ.
\b
\q1 
\v 7 Inĩrai Jehova mũmũcookerie ngaatho;
\q2 inĩrai Ngai witũ na kĩnanda kĩa mũgeeto.
\q1 
\v 8 Nĩahumbagĩra igũrũ na matu;
\q2 nĩwe uuragĩria thĩ mbura,
\q2 na agatũma nyeki ĩmere tũrĩma-inĩ.
\q1 
\v 9 Nĩwe ũheaga ngʼombe irio,
\q2 na akahe tũcui twa mahuru irio rĩrĩa twamũkaĩra.
\b
\q1 
\v 10 We ndakenagĩra hinya wa mbarathi,
\q2 o na kana agakenera magũrũ ma mũndũ;
\q1 
\v 11 Jehova akenagio nĩ andũ arĩa mamwĩtigagĩra,
\q2 o arĩa maigaga mwĩhoko wao harĩ wendo wake ũrĩa ũtathiraga.
\b
\q1 
\v 12 Wee Jerusalemu, kumia Jehova;
\q2 gooca Ngai waku, wee Zayuni,
\q1 
\v 13 nĩgũkorwo nĩwe wĩkagĩra mĩgĩĩko ya ihingo ciaku hinya,
\q2 na akarathima andũ aku arĩa marĩ thĩinĩ waku.
\q1 
\v 14 Nĩatũmĩte kũgĩe thayũ mĩhaka-inĩ yaku,
\q2 na agakũhũũnia na ngano ĩrĩa njega mũno.
\b
\q1 
\v 15 Atũmaga wathani wake ũkinye gũkũ thĩ;
\q2 kiugo gĩake kĩhanyũkaga narua mũno.
\q1 
\v 16 Oiragia tharunji ĩhaana ta guoya mwerũ cua,
\q2 nayo mbaa akamĩhurunja ta mũhu.
\q1 
\v 17 Mbura ya mbembe amiuragia taarĩ kagoto karoira.
\q2 Nũũ ũngĩhota gwĩtiiria heho ĩyo yake?
\q1 
\v 18 Atũmaga kiugo gĩake agatũma itwekũke;
\q2 ahurutithanagia rũhuho, namo maaĩ magatherera.
\b
\q1 
\v 19 Nĩaguũrĩtie kiugo gĩake harĩ Jakubu,
\q2 akaguũrĩria Isiraeli mawatho make
\q2 na kĩrĩra kĩa watho wake wa kũrũmĩrĩrwo.
\q1 
\v 20 Ndarĩ ekĩra rũrĩrĩ rũngĩ ta ũguo,
\q2 mawatho macio make ndũrĩrĩ itirĩ ciamamenya.
\b
\q1 Goocai Jehova.
\c 148
\s1 Indo Ciothe Nĩcigooce Jehova
\q1 
\v 1 Goocai Jehova.
\b
\q1 Goocai Jehova mũrĩ kũu igũrũ,
\q2 mũmũgooce mũrĩ kũu gũtũũgĩru mũno.
\q1 
\v 2 Mũgoocei, inyuĩ araika ake othe,
\q2 mũmũgooce, inyuothe mbũtũ ciake cia igũrũ.
\q1 
\v 3 Mũgoocei, inyuĩ riũa na mweri,
\q2 mũgoocei, inyuothe njata iria icangararaga.
\q1 
\v 4 Mũgoocei, inyuĩ igũrũ rĩa igũrũ,
\q2 o na inyuĩ maaĩ ma kũu igũrũ wa matu.
\q1 
\v 5 Indo ciothe nĩikĩgooce rĩĩtwa rĩa Jehova,
\q2 nĩgũkorwo nĩwe wathanire na cio ikĩgĩa kuo.
\q1 
\v 6 Aaciigire handũ hacio itũũre ho tene na tene;
\q2 aaheanire kĩrĩra kĩa watho wa kũrũmĩrĩrwo kĩrĩa gĩtagathira.
\b
\q1 
\v 7 Goocai Jehova gũkũ thĩ,
\q2 inyuĩ ciũmbe cia iria-inĩ, na ũriku wothe wa maria marĩa manene,
\q1 
\v 8 rũheni, na mbura ya mbembe, na tharunji, na matu,
\q2 na ihuhũkanio cia huho iria ihingagia kĩrĩra gĩake,
\q1 
\v 9 inyuĩ irĩma, na tũrĩma tuothe,
\q2 na mĩtĩ ya matunda, na mĩtarakwa yothe,
\q1 
\v 10 nyamũ cia gĩthaka, na ngʼombe ciothe,
\q2 na ciũmbe iria nini, o na nyoni iria ciũmbũkaga,
\q1 
\v 11 athamaki a thĩ, na ndũrĩrĩ ciothe,
\q2 na inyuĩ anene, na aathani othe a thĩ,
\q1 
\v 12 aanake, na airĩtu,
\q2 na andũ arĩa akũrũ, o na ciana.
\b
\q1 
\v 13 Othe nĩmagoocage rĩĩtwa rĩa Jehova,
\q2 nĩgũkorwo rĩĩtwa rĩake riiki nĩrĩo rĩtũũgĩrie;
\q2 riiri wake ũrĩ igũrũ rĩa thĩ o na rĩa matu.
\q1 
\v 14 Nĩambararĩtie rũhĩa nĩ ũndũ wa andũ ake,
\q2 nĩruo ũgooci wa andũ ake arĩa aamũre,
\q2 nĩo andũ a Isiraeli, andũ arĩa marĩ hakuhĩ na ngoro yake.
\b
\q1 Goocai Jehova.
\c 149
\s1 Kũgooca Ngai nĩ ũndũ wa Wega Wake kũrĩ Isiraeli
\q1 
\v 1 Goocai Jehova.
\b
\q1 Inĩrai Jehova rwĩmbo rwerũ,
\q2 mũmũgooce mũrĩ kĩũngano-inĩ kĩa arĩa aamũre.
\b
\q1 
\v 2 Andũ a Isiraeli nĩmakenere ũcio wamombire;
\q2 andũ a Zayuni nĩmacanjamũke nĩ ũndũ wa Mũthamaki wao.
\q1 
\v 3 Nĩmagooce rĩĩtwa rĩake makĩrũgarũgaga,
\q2 na mamũinĩre na tũhembe, na kĩnanda kĩa mũgeeto.
\q1 
\v 4 Nĩgũkorwo Jehova nĩakenagio nĩ andũ ake;
\q2 andũ arĩa ahooreri amahumbaga thũmbĩ ya ũhonokio.
\q1 
\v 5 Andũ arĩa aamũre nĩmakenere gĩtĩĩo kĩu,
\q2 na maine macanjamũkĩte marĩ o marĩrĩ-inĩ mao.
\b
\q1 
\v 6 Ũgooci wa Mũrungu ũrokorwo tũnua-inĩ twao,
\q2 na rũhiũ rwa njora rũnoore mĩena yeerĩ rũkorwo moko-inĩ mao,
\q1 
\v 7 nĩguo meerĩhĩrie harĩ ndũrĩrĩ,
\q2 na maherithie kĩrĩndĩ gĩa thĩ,
\q1 
\v 8 nĩguo moohe athamaki ao na mĩnyororo,
\q2 na moohe andũ ao arĩa marĩ igweta na bĩngũ cia kĩgera,
\q1 
\v 9 nĩguo mamakinyĩrie ituĩro rĩrĩa mandĩkĩirwo.
\q2 Ũcio nĩguo riiri wa andũ ake othe arĩa aamũre.
\b
\q1 Goocai Jehova.
\c 150
\s1 Kũgooca Ngai nĩ ũndũ wa Ũnene Wake Mũkĩru
\q1 
\v 1 Goocai Jehova.
\b
\q1 Goocai Mũrungu mũrĩ harĩa hake haamũre;
\q2 mũgoocei mũrĩ kũu igũrũ, o kũu kwa hinya wake.
\q1 
\v 2 Mũgoocei nĩ ũndũ wa ciĩko ciake cia hinya;
\q2 mũgoocei nĩ ũndũ wa ũnene wake mũingĩ mũno.
\q1 
\v 3 Mũgoocei mũkĩhuhaga karumbeta,
\q2 mũmũgooce na kĩnanda kĩa mũgeeto, na gĩa kĩnũbi,
\q1 
\v 4 mũgoocei na tũhembe mũkĩrũgarũgaga,
\q2 mũmũgooce na inanda cia nga mũkĩhuhaga mĩtũrirũ,
\q1 
\v 5 mũgoocei mũkĩhũũrithanagia thaani cia rũthuku iria ngʼambi,
\q2 mũmũgooce na thaani ikũgamba o ta rũgambi.
\b
\q1 
\v 6 Kĩndũ gĩothe kĩrĩ mĩhũmũ nĩkĩgooce Jehova.
\b
\q1 Goocai Jehova.
