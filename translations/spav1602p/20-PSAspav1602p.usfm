\v 6 \w El|strong="H3588"\w* \w consejo|strong="H6098"\w* del \w pobre|strong="H6041"\w* habéis avergonzado, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w* \w es|strong="H3588"\w* \w su|strong="H3588"\w* refugio.
\m 
\v 7 ¡\w Oh|strong="H4310"\w* \w que|strong="H4310"\w* \w de|strong="H5971"\w* \w Sión|strong="H6726"\w* \add viniese\add* la salvación \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*! Cuando \w el|strong="H4310"\w* \w SEÑOR|strong="H3068"\w* hiciere \w volver|strong="H7725"\w* la \w cautividad|strong="H7622"\w* \w de|strong="H5971"\w* su \w pueblo|strong="H5971"\w*, \w Jacob|strong="H3290"\w* \w se|strong="H5971"\w* regocijará, \add y\add* \w se|strong="H5971"\w* alegrará \w Israel|strong="H3478"\w*.
\c 15
\d Salmo de David.
\m 
\v 1 \w SEÑOR|strong="H3068"\w*, ¿\w quién|strong="H4310"\w* \w habitará|strong="H7931"\w* en tu tabernáculo? ¿\w Quién|strong="H4310"\w* \w morará|strong="H7931"\w* en tu \w santo|strong="H6944"\w* \w monte|strong="H2022"\w*?
\m 
\v 2 El que \w camina|strong="H1980"\w* rectamente, y \w obra|strong="H6466"\w* \w justicia|strong="H6664"\w*, y \w habla|strong="H1696"\w* la verdad \w en|strong="H8549"\w* su \w corazón|strong="H3824"\w*.
\m 
\v 3 \add El que\add* \w no|strong="H3808"\w* calumnia \w con|strong="H5921"\w* su len­gua, \w ni|strong="H3808"\w* \w hace|strong="H6213"\w* \w mal|strong="H7451"\w* \w a|strong="H3068"\w* su \w prójimo|strong="H7453"\w*, \w ni|strong="H3808"\w* \w contra|strong="H5921"\w* su \w prójimo|strong="H7453"\w* acoge \w oprobio|strong="H2781"\w* alguno.
\m 
\v 4 En cuyos \w ojos|strong="H5869"\w* es despreciado el vil; pero \w honra|strong="H3513"\w* \w a|strong="H3068"\w* los \w que|strong="H3808"\w* temen al \w SEÑOR|strong="H3068"\w*; \add el que\add* \w jura|strong="H7650"\w* para \add su propio\add* daño, y \w no|strong="H3808"\w* cambia.
\m 
\v 5 \w Quién|strong="H6213"\w* su \w dinero|strong="H3701"\w* \w no|strong="H3808"\w* \w da|strong="H5414"\w* \w a|strong="H3068"\w* \w usura|strong="H5392"\w*, \w ni|strong="H3808"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w inocente|strong="H5355"\w* \w toma|strong="H3947"\w* \w soborno|strong="H7810"\w*. \w El|strong="H5921"\w* \w que|strong="H3808"\w* \w hace|strong="H6213"\w* \w estas|strong="H6213"\w* \add cosas\add* \w nunca|strong="H3808"\w* \w será|strong="H3808"\w* movido.
\c 16
\d Mictam de David.
\m 
\v 1 \w GUÁRDAME|strong="H8104"\w*, oh Dios, \w porque|strong="H3588"\w* \w en|strong="H3588"\w* ti pongo mi confianza.
\m 
\v 2 Dijiste, \add oh alma mía\add*, \w al|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*: Tú \add eres\add* \w mi|strong="H5921"\w* \w Señor|strong="H3068"\w*: \w mi|strong="H5921"\w* bondad \w no|strong="H1077"\w* \add se extiende\add* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*;
\m 
\v 3 \add Sino\add* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w santos|strong="H6918"\w* \w que|strong="H1992"\w* \add están\add* en \w la|strong="H3605"\w* tierra, y \add a\add* \w los|strong="H1992"\w* excelentes; en quienes \w está|strong="H1992"\w* \w todo|strong="H3605"\w* mi \w deleite|strong="H2656"\w*.
\m 
\v 4 \w Se|strong="H5921"\w* multiplicarán \w los|strong="H5921"\w* dolores \w de|strong="H5921"\w* aquellos \w que|strong="H5921"\w* \w se|strong="H5921"\w* apresuran \w a|strong="H3068"\w* \w otro|strong="H8193"\w* \add dios\add*: \w no|strong="H1077"\w* \w ofreceré|strong="H5262"\w* yo sus liba­ciones \w de|strong="H5921"\w* \w sangre|strong="H1818"\w*, \w ni|strong="H1077"\w* \w en|strong="H5921"\w* \w mis|strong="H5375"\w* \w labios|strong="H8193"\w* \w tomaré|strong="H5375"\w* sus \w nombres|strong="H8034"\w*.
\m 
\v 5 El \w SEÑOR|strong="H3068"\w* \add es\add* la \w porción|strong="H4490"\w* de mi herencia y de mi copa; tú susten­tas mi \w suerte|strong="H1486"\w*.
\m 
\v 6 \w Las|strong="H5921"\w* líneas \w me|strong="H5921"\w* \w cayeron|strong="H5307"\w* \w en|strong="H5921"\w* lugares agradables; \w sí|strong="H5921"\w*, \w tengo|strong="H5921"\w* una buena \w heredad|strong="H5159"\w*.
\m 
\v 7 \w Bendeciré|strong="H1288"\w* al \w SEÑOR|strong="H3068"\w* que me aconseja: aun en las \w noches|strong="H3915"\w* me enseñan mis entrañas.
\m 
\v 8 Al \w SEÑOR|strong="H3068"\w* he \w puesto|strong="H3588"\w* \w siempre|strong="H8548"\w* \w delante|strong="H5048"\w* \w de|strong="H3588"\w* mí: \w porque|strong="H3588"\w* \add está\add* \w a|strong="H3068"\w* mi \w diestra|strong="H3225"\w*, \w no|strong="H1077"\w* seré movido.
\m 
\v 9 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, mi \w corazón|strong="H3820"\w* \w se|strong="H3651"\w* \w alegra|strong="H8055"\w*, \w y|strong="H3519"\w* \w se|strong="H3651"\w* regocija mi \w gloria|strong="H3519"\w*: \w también|strong="H3651"\w* mi \w carne|strong="H1320"\w* \w reposará|strong="H7931"\w* segura.
\m 
\v 10 \w Porque|strong="H3588"\w* \w no|strong="H3808"\w* \w dejarás|strong="H5800"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* infierno; \w ni|strong="H3808"\w* \w permitirás|strong="H5414"\w* \w que|strong="H3588"\w* tu \w Santo|strong="H2623"\w* \w vea|strong="H7200"\w* \w corrupción|strong="H7845"\w*.
\m 
\v 11 Me mostrarás la senda \w de|strong="H6440"\w* la \w vida|strong="H2416"\w*: plenitud \w de|strong="H6440"\w* \w gozo|strong="H8057"\w* hay en tu \w presencia|strong="H6440"\w*; placeres \w a|strong="H3068"\w* tu \w diestra|strong="H3225"\w* para siempre.
\c 17
\d Oración de David.
\m 
\v 1 *\w OYE|strong="H8085"\w*, oh \w SEÑOR|strong="H3068"\w*, la causa justa; \w atiende|strong="H7181"\w* \w a|strong="H3068"\w* mi \w clamor|strong="H7440"\w*; \w escucha|strong="H8085"\w* mi \w oración|strong="H8605"\w*, \add que\add* \w no|strong="H3808"\w* \add sale\add* de \w labios|strong="H8193"\w* fingidos.
\m 
\v 2 Que \w proceda|strong="H3318"\w* \w de|strong="H6440"\w* tu \w presencia|strong="H6440"\w* mi \w sentencia|strong="H4941"\w*; \w vean|strong="H2372"\w* tus \w ojos|strong="H5869"\w* las cosas que son rectas.
\m 
\v 3 Tú has probado mi \w corazón|strong="H3820"\w*, \add me\add* has visitado de \w noche|strong="H3915"\w*; me has puesto \w a|strong="H3068"\w* prueba, \add y\add* \w no|strong="H1077"\w* \w hallarás|strong="H4672"\w* nada; me he propuesto \add que\add* mi \w boca|strong="H6310"\w* \w no|strong="H1077"\w* transgredirá.
\m 
\v 4 En cuanto \w a|strong="H3068"\w* las obras \w de|strong="H1697"\w* los hombres, \w por|strong="H1697"\w* \w la|strong="H8104"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* tus \w labios|strong="H8193"\w* yo \add me\add* he \w guardado|strong="H8104"\w* \w de|strong="H1697"\w* las vías del destruc­tor.
\m 
\v 5 \w Sustenta|strong="H8551"\w* mis pasos en tus \w caminos|strong="H4570"\w*, \add para que\add* mis \w pies|strong="H6471"\w* \w no|strong="H1077"\w* res­balen.
\m 
\v 6 \w Yo|strong="H3588"\w* \w te|strong="H3588"\w* he \w invocado|strong="H7121"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* tú \w me|strong="H3588"\w* \w oirás|strong="H8085"\w*, oh Dios: \w inclina|strong="H5186"\w* \w a|strong="H3068"\w* \w mí|strong="H6030"\w* tu \w oído|strong="H8085"\w*, \w escucha|strong="H8085"\w* \w mi|strong="H6030"\w* palabra.
\m 
\v 7 Muestra tu maravillosa benignidad, tú que salvas por tu \w diestra|strong="H3225"\w* \w a|strong="H3068"\w* los que \add en ti\add* confían de los que se \w levantan|strong="H6965"\w* \add contra ellos\add*.
\m 
\v 8 \w Guárdame|strong="H8104"\w* como \w a|strong="H3068"\w* \w la|strong="H8104"\w* niña \w de|strong="H5869"\w* tu \w ojo|strong="H5869"\w*, \w escóndeme|strong="H5641"\w* bajo \w la|strong="H8104"\w* \w sombra|strong="H6738"\w* \w de|strong="H5869"\w* tus \w alas|strong="H3671"\w*,
\m 
\v 9 \w De|strong="H5921"\w* \w los|strong="H5921"\w* \w impíos|strong="H7563"\w* \w que|strong="H2098"\w* \w me|strong="H5921"\w* oprimen, \add de\add* mis enemigos mortales \add que\add* \w me|strong="H5921"\w* rodean.
\m 
\v 10 \w Cerrados|strong="H5462"\w* están en su grosu­ra; con su \w boca|strong="H6310"\w* \w hablan|strong="H1696"\w* soberbia­mente.
\m 
\v 11 Han cercado nuestros pasos \w ahora|strong="H6258"\w*: \w puestos|strong="H7896"\w* tienen sus \w ojos|strong="H5869"\w* inclinándose \w a|strong="H3068"\w* la tierra.
\m 
\v 12 \w Como|strong="H3715"\w* un león que desea hacer presa, y \w como|strong="H3715"\w* un \w leoncillo|strong="H3715"\w* acechando en su escondite.
\m 
\v 13 \w Levántate|strong="H6965"\w*, oh \w SEÑOR|strong="H3068"\w*; frústralo, derríbale: \w libra|strong="H6403"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* del \w impío|strong="H7563"\w*, \add que es\add* tu \w espada|strong="H2719"\w*;
\m 
\v 14 \w De|strong="H1121"\w* \w los|strong="H1121"\w* \w hombres|strong="H4962"\w* \add que son\add* tu \w mano|strong="H3027"\w*, \w oh|strong="H1121"\w* \w SEÑOR|strong="H3068"\w*, \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hombres|strong="H4962"\w* del mundo, cuya \w parte|strong="H2506"\w* \add es\add* en esta \w vida|strong="H2416"\w*, y cuyo vientre \w hinches|strong="H4390"\w* \w de|strong="H1121"\w* tu \add tesoro\add* oculto: están hartos \w de|strong="H1121"\w* \w hijos|strong="H1121"\w*, y dejan \w el|strong="H1121"\w* \w resto|strong="H3499"\w* \w de|strong="H1121"\w* su \add substancia\add* \w a|strong="H3068"\w* sus \w chiquitos|strong="H5768"\w*.
\m 
\v 15 En cuanto \w a|strong="H3068"\w* mí, yo en \w justicia|strong="H6664"\w* \w veré|strong="H2372"\w* tu \w rostro|strong="H6440"\w*: seré satisfecho cuando despierte \w a|strong="H3068"\w* tu \w semejanza|strong="H8544"\w*.
\c 18
\d Al Músico principal: Salmo de David, siervo del SEÑOR, el cual profirió al SEÑOR las palabras de este cántico el día que le libró el SEÑOR de mano de todos sus enemigos, y de mano de Saúl. Entonces dijo:
\m 
\v 1 Te amaré, oh \w SEÑOR|strong="H3068"\w*, fortaleza mía.
\m 
\v 2 El \w SEÑOR|strong="H3068"\w* \add es\add* mi roca, mi baluarte, y mi libertador; mi \w Dios|strong="H3068"\w*, mi \w fortaleza|strong="H2391"\w* en quien confiaré; mi escudo, y el cuerno de mi salvación, \add y\add* mi torre alta.
\m 
\v 3 Invocaré al \w SEÑOR|strong="H3068"\w*, \add quien es digno\add* de ser alabado, y así seré salvo de mis enemigos.
\m 
\v 4 Cercáronme dolores \w de|strong="H4480"\w* muerte, y torrentes \w de|strong="H4480"\w* hombres impíos \w me|strong="H4480"\w* atemorizaron.
\m 
\v 5 \w Dolores|strong="H2256"\w* del infierno me rodea­ron, me previnieron lazos de \w muerte|strong="H4194"\w*.
\m 
\v 6 En mi angustia invoqué al SEÑOR, y clamé \w a|strong="H3068"\w* mi Dios: él oyó mi voz desde su templo, y mi clamor llegó \w delante|strong="H6923"\w* de él, \w a|strong="H3068"\w* sus oídos.
\m 
\v 7 Entonces la tierra se estremeció y tembló; también los fundamentos \w de|strong="H6440"\w* las colinas se movieron y se estremecieron, \w porque|strong="H6440"\w* se indignó él.
\m 
\v 8 Humo subió \w de|strong="H3588"\w* \w su|strong="H3588"\w* nariz, \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* boca fuego devoró; carbones fueron \w por|strong="H3588"\w* \w él|strong="H3588"\w* encendidos.
\m 
\v 9 \w E|strong="H3068"\w* inclinó los cielos \w y|strong="H1197"\w* descendió; \w y|strong="H1197"\w* \w la|strong="H1197"\w* oscuridad \add estaba\add* debajo \w de|strong="H4480"\w* sus pies.
\m 
\v 10 \w Y|strong="H3068"\w* cabalgó sobre un querubín, y voló: sí, él voló sobre las alas del viento.
\m 
\v 11 Hizo \w de|strong="H5921"\w* \w las|strong="H5921"\w* tinieblas su escondedero, su pabellón \w en|strong="H5921"\w* derredor \w de|strong="H5921"\w* \w sí|strong="H5921"\w* \add eran\add* aguas oscuras \add y\add* nubes espesas \w de|strong="H5921"\w* \w los|strong="H5921"\w* cielos.
\m 
\v 12 Por el resplandor delante \w de|strong="H4325"\w* él, sus \w nubes|strong="H5645"\w* espesas pasaron; granizo y carbones \w de|strong="H4325"\w* fuego.
\m 
\v 13 \w Y|strong="H3068"\w* tronó en los cielos \w el|strong="H5674"\w* SEÑOR, y \w el|strong="H5674"\w* Altísimo dio su voz; \w granizo|strong="H1259"\w* y \w carbones|strong="H1513"\w* \w de|strong="H5048"\w* fuego.
\m 
\v 14 Sí, envió sus saetas, y los dispersó, él lanzó relámpagos y los desconcertó.
\m 
\v 15 Entonces fueron vistos los canales de aguas, y fueron descubiertos las fundaciones del mundo \w a|strong="H3068"\w* tu reprensión, oh SEÑOR, por el soplo del aliento de tu nariz.
\m 
\v 16 Envió desde lo alto; tomóme, sacóme \w de|strong="H5397"\w* las muchas \w aguas|strong="H4325"\w*.
\m 
\v 17 Libróme \w de|strong="H4325"\w* mi poderoso ene­migo, y \w de|strong="H4325"\w* los \w que|strong="H4325"\w* me aborrecí­an, \w pues|strong="H7971"\w* eran ellos \w más|strong="H7227"\w* fuertes \w que|strong="H4325"\w* yo.
\m 
\v 18 \w Me|strong="H4480"\w* impidieron \w en|strong="H4480"\w* \w el|strong="H3588"\w* día \w de|strong="H4480"\w* mi calamidad; \w pero|strong="H3588"\w* \w el|strong="H3588"\w* SEÑOR fue mi apoyo.
\m 
\v 19 \w Y|strong="H3068"\w* sacóme \w a|strong="H3068"\w* lugar espacioso; libróme porque \w se|strong="H1961"\w* deleitó en \w mí|strong="H1961"\w*.
\m 
\v 20 \w Me|strong="H3588"\w* recompensó \w el|strong="H3588"\w* SEÑOR conforme \w a|strong="H3068"\w* mi justicia: conforme \w a|strong="H3068"\w* \w la|strong="H3588"\w* limpieza \w de|strong="H3588"\w* mis manos \w me|strong="H3588"\w* ha recompensado.
\m 
\v 21 Porque yo he guardado los caminos del \w SEÑOR|strong="H3068"\w*, y no me aparté impíamente de mi \w Dios|strong="H3068"\w*.
\m 
\v 22 \w Pues|strong="H3588"\w* todos sus juicios \add estuvie­ron\add* delante \w de|strong="H3588"\w* mí, \w y|strong="H3588"\w* \w no|strong="H3808"\w* eché \w de|strong="H3588"\w* mí sus estatutos.
\m 
\v 23 También \w fui|strong="H3808"\w* recto \w delante|strong="H5048"\w* \w de|strong="H4480"\w* \w él|strong="H3588"\w*, \w y|strong="H3588"\w* \w me|strong="H4480"\w* guardé \w de|strong="H4480"\w* mi iniquidad.
\m 
\v 24 Por tanto \w me|strong="H5973"\w* ha recompensado \w el|strong="H5973"\w* SEÑOR conforme \w a|strong="H3068"\w* \w mi|strong="H1961"\w* justicia; conforme \w a|strong="H3068"\w* \w la|strong="H8104"\w* limpieza \w de|strong="H5973"\w* mis manos delan­\w te|strong="H5973"\w* \w de|strong="H5973"\w* sus ojos.
\m 
\v 25 Con el misericordioso \w te|strong="H5869"\w* mos­trarás misericordioso, y recto para con el hombre recto.
\m 
\v 26 Puro \w te|strong="H5973"\w* mostrarás \w para|strong="H5973"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* puro, y desagradable \w te|strong="H5973"\w* mostrarás \w para|strong="H5973"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* perverso.
\m 
\v 27 Pues tú salvarás al \w pueblo|strong="H5973"\w* afligido, y humillarás \w los|strong="H5973"\w* ojos altivos.
\m 
\v 28 Tú \w pues|strong="H3588"\w* alumbrarás mi lám­\w para|strong="H3588"\w*: \w el|strong="H3588"\w* SEÑOR mi Dios alum­brará mis tinieblas.
\m 
\v 29 \w Pues|strong="H3588"\w* \w por|strong="H3588"\w* ti he corrido \w a|strong="H3068"\w* través \w de|strong="H3588"\w* una tropa; \w y|strong="H3588"\w* \w por|strong="H3588"\w* mi \w Dios|strong="H3068"\w* he saltado \w sobre|strong="H5050"\w* un muro.
\m 
\v 30 \add En cuanto a\add* Dios, perfecto \add es\add* \w su|strong="H3588"\w* camino: \w la|strong="H3588"\w* palabra del SEÑOR \add es\add* refinada: \w él|strong="H3588"\w* \add es\add* escudo \w a|strong="H3068"\w* todos \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w él|strong="H3588"\w* confían.
\m 
\v 31 Porque ¿\w quién|strong="H3605"\w* \add es\add* \w Dios|strong="H3068"\w* fuera del \w SEÑOR|strong="H3068"\w*? ¿\w O|strong="H3068"\w* \w quién|strong="H3605"\w* \add es\add* una roca fuera de nuestro \w Dios|strong="H3068"\w*?
\m 
\v 32 \w Dios|strong="H3068"\w* \add es\add* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* ciñe \w de|strong="H3588"\w* fuerza, \w y|strong="H3588"\w* hace perfecto mi cami­\w no|strong="H3588"\w*.
\m 
\v 33 Él hace \w mis|strong="H5414"\w* pies como \w de|strong="H5414"\w* ciervas, y me pone sobre \w mis|strong="H5414"\w* alturas.
\m 
\v 34 \w Él|strong="H5921"\w* enseña mis manos \w para|strong="H5921"\w* \w la|strong="H5921"\w* guerra, \w de|strong="H5921"\w* modo \w que|strong="H5921"\w* \w es|strong="H5975"\w* quebrado \w con|strong="H5921"\w* mis brazos \w el|strong="H5921"\w* arco \w de|strong="H5921"\w* acero.
\m 
\v 35 Tú me diste asimismo el escudo de tu salvación: y tu diestra me sustentó, y tu gentileza me ha engrandecido.
\m 
\v 36 Ensanchaste \w mis|strong="H5414"\w* pasos debajo \w de|strong="H5414"\w* mí, \w para|strong="H5414"\w* que \w mis|strong="H5414"\w* pies no resbalasen.
\m 
\v 37 Yo he perseguido \w a|strong="H3068"\w* mis enemigos, y los he atrapado: y \w no|strong="H3808"\w* me volví hasta \w que|strong="H3808"\w* fueron consumidos.
\m 
\v 38 Yo \w los|strong="H7291"\w* herí, \w de|strong="H5704"\w* modo \w que|strong="H3808"\w* \w no|strong="H3808"\w* pudieron levantarse: \w son|strong="H3808"\w* caídos debajo \w de|strong="H5704"\w* mis pies.
\m 
\v 39 Pues, me ceñiste con fuerza para la batalla; has sometido \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* mí \w a|strong="H3068"\w* los \w que|strong="H3808"\w* \w se|strong="H3808"\w* \w levantaron|strong="H6965"\w* contra mí.
\m 
\v 40 También me has dado la cerviz \w de|strong="H8478"\w* mis enemigos, para que yo destruya \w a|strong="H3068"\w* los que me aborrecen.
\m 
\v 41 Clamaron, pero no \add hubo\add* quien \add los\add* salvase: \add aun\add* al SEÑOR, pero él no les respondió.
\m 
\v 42 Entonces \w los|strong="H5921"\w* molí \w como|strong="H5921"\w* polvo \w delante|strong="H5921"\w* \w del|strong="H5921"\w* viento, \w los|strong="H5921"\w* arrojé \w como|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w en|strong="H5921"\w* \w las|strong="H5921"\w* calles.
\m 
\v 43 \w Me|strong="H5921"\w* libraste \w de|strong="H5921"\w* \w las|strong="H5921"\w* contiendas \w del|strong="H5921"\w* pueblo: \w me|strong="H5921"\w* has puesto \w por|strong="H5921"\w* cabecera \w de|strong="H5921"\w* \w los|strong="H5921"\w* paganos: un pueblo \add que\add* \w no|strong="H5921"\w* he conocido \w me|strong="H5921"\w* servirá.
\m 
\v 44 Así \w que|strong="H3808"\w* oigan \w de|strong="H5971"\w* mí, me obedecerán: los extranjeros \w se|strong="H3045"\w* someterán \w a|strong="H3068"\w* mí.
\m 
\v 45 \w Los|strong="H1121"\w* \w extranjeros|strong="H1121"\w* se desvanecerán, y se atemorizarán \w de|strong="H1121"\w* sus escondrijos.
\m 
\v 46 Vive \w el|strong="H1121"\w* SEÑOR, y \add sea\add* bendita mi roca; y exaltado sea \w el|strong="H1121"\w* Dios \w de|strong="H1121"\w* mi salvación.
\m 
\v 47 \add Es\add* \w Dios|strong="H3068"\w* el que me venga y somete \w a|strong="H3068"\w* la gente debajo de mí.
\m 
\v 48 Me libra \w de|strong="H8478"\w* \w mis|strong="H5414"\w* enemigos: sí, tú me enalteces sobre los \w que|strong="H5971"\w* \w se|strong="H5971"\w* levantan contra mí; me \w has|strong="H5414"\w* librado del hombre violento.
\m 
\v 49 \w Por|strong="H4480"\w* tanto \w yo|strong="H4480"\w* \w te|strong="H4480"\w* daré gracias \w entre|strong="H4480"\w* los paganos, oh SEÑOR, y cantaré alabanzas \w a|strong="H3068"\w* tu nombre.
\m 
\v 50 Grande liberación da \w a|strong="H3068"\w* su rey, \w y|strong="H5921"\w* muestra misericordia \w a|strong="H3068"\w* su ungido, \w a|strong="H3068"\w* David \w y|strong="H5921"\w* \w a|strong="H3068"\w* su simiente, \w para|strong="H5921"\w* \w siempre|strong="H5921"\w*.
\c 19
\d Al Músico principal: Salmo de David.
\m 
\v 1 LOS cielos declaran la gloria de Dios, y el firmamento muestra la obra de sus manos.
\m 
\v 2 Día tras día emite palabra; noche tras noche \w muestra|strong="H5046"\w* conocimiento.
\m 
\v 3 No \add hay\add* habla ni lenguaje, \add donde\add* no es oída su voz.
\m 
\v 4 \w Por|strong="H1697"\w* toda la tierra salió su hilo, y al cabo del mundo sus pala­bras. En ellos puso un tabernáculo para el sol.
\m 
\v 5 \w Lo|strong="H4405"\w* cual como un novio \w que|strong="H3605"\w* \w sale|strong="H3318"\w* de su tálamo, \add y\add* se regocija como hombre fuerte para correr una carrera.
\m 
\v 6 Del cabo del cielo \add es\add* \w su|strong="H1931"\w* \w salida|strong="H3318"\w*, y \w su|strong="H1931"\w* curso \w hasta|strong="H1931"\w* \w el|strong="H1931"\w* cabo de \w él|strong="H1931"\w*: y no hay \w quién|strong="H1931"\w* \w se|strong="H1931"\w* esconda de \w su|strong="H1931"\w* calor.
\m 
\v 7 \w La|strong="H5921"\w* ley \w del|strong="H5921"\w* SEÑOR \add es\add* perfecta, \w que|strong="H5921"\w* convierte \w el|strong="H5921"\w* alma: \w el|strong="H5921"\w* testimo­nio \w del|strong="H5921"\w* SEÑOR \add es\add* seguro, \w que|strong="H5921"\w* hace sabio \w al|strong="H5921"\w* simple.
\m 
\v 8 Los estatutos del \w SEÑOR|strong="H3068"\w* \add son\add* rectos, que regocijan el \w corazón|strong="H5315"\w*: el mandamiento del \w SEÑOR|strong="H3068"\w* \add es\add* puro, que alumbra los ojos.
\m 
\v 9 El temor del \w SEÑOR|strong="H3068"\w* \add es\add* \w limpio|strong="H1249"\w*, que permanece para siempre; los juicios del \w SEÑOR|strong="H3068"\w* \add son\add* verdad, todos justos.
\m 
\v 10 Deseables \add son\add* más que el oro, sí, más que mucho oro afinado: \w también|strong="H3162"\w* más dulces que la miel, y el panal.
\m 
\v 11 Tu siervo es además amones­tado por ellos: \add y\add* en guardarlos \add hay\add* \w grande|strong="H7227"\w* galardón.
\m 
\v 12 ¿Quién puede entender \add sus\add* errores? Límpiame de \add faltas\add* ocultas.
\m 
\v 13 Detén asimismo \w a|strong="H3068"\w* tu siervo de \add pecados\add* presuntuosos; no dejes \w que|strong="H4310"\w* tengan dominio sobre mí: Entonces seré recto, y seré inocente de la gran transgresión.
\m 
\v 14 Sean aceptables las palabras de mi boca \w y|strong="H1571"\w* \w la|strong="H1571"\w* meditación de mi cora­zón delante de ti, oh SEÑOR, fortaleza mía, \w y|strong="H1571"\w* redentor mío.
\c 20
\d Al Músico principal: Salmo de David.
\m 
\v 1 OIGATE el SEÑOR en el día de angustia; defiéndate el nombre del Dios de Jacob.
\m 
\v 2 Envíete ayuda desde el santua­rio, y desde Sión te fortalezca.
\m 
\v 3 Haga memoria de todas tus ofrendas, y acepte tu holocausto. Selah
\m 
\v 4 Concédete \w conforme|strong="H5930"\w* \w a|strong="H3068"\w* tu corazón, y cumpla \w todo|strong="H3605"\w* tu consejo.
\m 
\v 5 \w Nosotros|strong="H3605"\w* nos regocijaremos en tu salvación, y pondremos \add nuestros\add* pendones en \w el|strong="H3605"\w* nombre \w de|strong="H5414"\w* nuestro Dios: \w cumpla|strong="H4390"\w* \w el|strong="H3605"\w* SEÑOR \w todas|strong="H3605"\w* tus peti­ciones.
\m 
\v 6 Ahora sé \w que|strong="H3605"\w* \w el|strong="H3605"\w* \w SEÑOR|strong="H3068"\w* salva \w a|strong="H3068"\w* su ungido: \w él|strong="H3605"\w* \w lo|strong="H3605"\w* oirá desde su santo cielo con \w la|strong="H3605"\w* fuerza salvadora de su diestra.
\m 
\v 7 Algunos \add confían\add* \w en|strong="H3588"\w* carros, \w y|strong="H3588"\w* algunos \w en|strong="H3588"\w* caballos: \w pero|strong="H3588"\w* nosotros del nombre del \w SEÑOR|strong="H3068"\w* nuestro \w Dios|strong="H3068"\w* tendremos memo­ria.
\m 
\v 8 Ellos son derribados y caídos: pero nosotros somos levantados y estamos rectos.
\m 
\v 9 Salva, SEÑOR: \w que|strong="H1992"\w* \w el|strong="H5307"\w* rey nos oiga cuando \w lo|strong="H1992"\w* invoquemos.
\c 21
\d Al Músico principal: Salmo de David.
\m 
\v 1 ALEGRARÁSE el rey en tu fortaleza, oh SEÑOR; y en tu salvación se gozará mucho.
\m 
\v 2 El deseo de su corazón le diste, \w y|strong="H5797"\w* \w no|strong="H4100"\w* le negaste \w lo|strong="H4100"\w* \w que|strong="H4100"\w* sus labios pronunciaron. Selah
\m 
\v 3 Pues le \w has|strong="H5414"\w* salido al encuentro con bendiciones \w de|strong="H5414"\w* bien: corona \w de|strong="H5414"\w* oro fino \w has|strong="H5414"\w* \w puesto|strong="H5414"\w* sobre su cabeza.
\m 
\v 4 Vida \w te|strong="H3588"\w* pidió, \w y|strong="H3588"\w* dístele largura \w de|strong="H3588"\w* días \w por|strong="H3588"\w* siempre jamás.
\m 
\v 5 Grande es su gloria \w en|strong="H4480"\w* tu salva­ción: honra y majestad \w has|strong="H5414"\w* \w pues|strong="H4480"\w*­to \w sobre|strong="H4480"\w* él.
\m 
\v 6 \w Porque|strong="H5921"\w* \w lo|strong="H5921"\w* has bendecido \w para|strong="H5921"\w* \w siempre|strong="H5921"\w*; llenástelo \w de|strong="H5921"\w* alegría \w con|strong="H5921"\w* tu rostro.
\m 
\v 7 \w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w el|strong="H3588"\w* rey confía \w en|strong="H3588"\w* \w el|strong="H3588"\w* SEÑOR, \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* misericordia del Altísimo, \w no|strong="H3588"\w* \w será|strong="H1293"\w* conmovido.
\m 
\v 8 Alcanzará tu mano \w a|strong="H3068"\w* todos tus enemigos; tu diestra alcanzará \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* aborrecen.
\m 
\v 9 Ponerlos has como horno de fuego en \w el|strong="H3605"\w* tiempo de tu ira: \w el|strong="H3605"\w* SEÑOR \w los|strong="H3605"\w* deshará en su furor, y fuego \w los|strong="H3605"\w* consumirá.
\m 
\v 10 Su fruto destruirás \w de|strong="H6440"\w* la tierra, y su simiente \w de|strong="H6440"\w* entre los hijos \w de|strong="H6440"\w* los hombres.
\m 
\v 11 Porque trazaron \w el|strong="H1121"\w* mal contra ti: fraguaron maquinaciones, \add mas\add* no prevalecerán.
\m 
\v 12 \w Pues|strong="H3588"\w* tú \w los|strong="H5921"\w* pondrás \w en|strong="H5921"\w* fuga, \add cuando\add* aparejares \w en|strong="H5921"\w* tus cuerdas \add las saetas\add* \w contra|strong="H5921"\w* sus rostros.
\m 
\v 13 Ensálzate, oh SEÑOR, \w con|strong="H5921"\w* tu fortaleza: cantaremos \w y|strong="H3588"\w* alabare­mos tu poderío.
\c 22
\d Al Músico principal, sobre Ajelet-sahar: Salmo de David.
\m 
\v 1 DIOS \w mío|strong="H5921"\w*, Dios \w mío|strong="H5921"\w*, ¿\w por|strong="H5921"\w* \w qué|strong="H5921"\w* \w me|strong="H5921"\w* has desamparado? ¿\add Por qué estás tan\add* lejos \w de|strong="H5921"\w* \w mi|strong="H5921"\w* auxilio, \add y de\add* \w las|strong="H5921"\w* palabras \w de|strong="H5921"\w* \w mi|strong="H5921"\w* clamor?
\m 
\v 2 Dios mío, clamo \w de|strong="H1697"\w* día, y \w no|strong="H4100"\w* oyes; y \w de|strong="H1697"\w* noche, y \w no|strong="H4100"\w* hay para mí silencio.
\m 
\v 3 Pero tú eres santo, tú \w que|strong="H3808"\w* habitas \add entre\add* las alabanzas de Israel.
\m 
\v 4 En ti esperaron nuestros padres: esperaron, y tú \w los|strong="H3427"\w* libras­te.
\m 
\v 5 Clamaron \w a|strong="H3068"\w* ti, y fueron \w libra|strong="H6403"\w*­dos: esperaron en ti, y no se aver­gonzaron.
\m 
\v 6 \w Mas|strong="H3808"\w* yo soy gusano, y \w no|strong="H3808"\w* hom­bre; oprobio de los hombres, y desecho del pueblo.
\m 
\v 7 Todos los \w que|strong="H3808"\w* me ven, escarne­cen \w de|strong="H5971"\w* mí; estiran los labios, menean la cabeza, \add diciendo\add*:
\m 
\v 8 Remítese al SEÑOR, líbrelo; sálvele, puesto \w que|strong="H3605"\w* en \w él|strong="H3605"\w* se com­placía.
\m 
\v 9 \w Pero|strong="H3588"\w* tú eres \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* sacó del vientre, \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* haces esperar \add desde que estaba\add* \w a|strong="H3068"\w* \w los|strong="H3588"\w* pechos \w de|strong="H3588"\w* mi madre.
\m 
\v 10 \w Sobre|strong="H5921"\w* \w ti|strong="H5921"\w* fui echado \w desde|strong="H5921"\w* \w la|strong="H5921"\w* matriz: \w desde|strong="H5921"\w* \w el|strong="H5921"\w* vientre \w de|strong="H5921"\w* \w mi|strong="H5921"\w* madre, tú eres \w mi|strong="H5921"\w* Dios.
\m 
\v 11 \w No|strong="H5921"\w* \w te|strong="H5921"\w* alejes \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w porque|strong="H5921"\w* \w la|strong="H5921"\w* angustia \w está|strong="H5921"\w* \w cerca|strong="H5921"\w*; \w porque|strong="H5921"\w* \w no|strong="H5921"\w* hay quien ayude.
\m 
\v 12 Hanme rodeado muchos toros; fuertes toros \w de|strong="H4480"\w* Basán \w me|strong="H4480"\w* han cercado.
\m 
\v 13 Abrieron sobre mí su boca, \add como\add* león rapante y rugiente.
\m 
\v 14 Heme escurrido \w como|strong="H5921"\w* aguas, \w y|strong="H5921"\w* todos mis huesos \w se|strong="H5921"\w* descoyun­taron: \w mi|strong="H5921"\w* corazón fue \w como|strong="H5921"\w* cera, desliéndose \w en|strong="H5921"\w* medio \w de|strong="H5921"\w* mis entrañas.
\m 
\v 15 Secóse \w como|strong="H1961"\w* un tiesto \w mi|strong="H1961"\w* vigor, y \w mi|strong="H1961"\w* lengua \w se|strong="H1961"\w* pegó \w a|strong="H3068"\w* \w mi|strong="H1961"\w* paladar; y me has puesto \w en|strong="H8432"\w* \w el|strong="H3605"\w* polvo \w de|strong="H4325"\w* \w la|strong="H3605"\w* muerte.
\m 
\v 16 Porque perros me han rodea­do, hame cercado asamblea de malignos: horadaron mis manos y mis pies.
\m 
\v 17 Contar puedo todos mis hue­sos; \w ellos|strong="H3027"\w* miran, considéranme.
\m 
\v 18 Partieron entre sí mis \w vestiduras|strong="H1992"\w*, y sobre mi ropa echaron suertes.
\m 
\v 19 \w Mas|strong="H5921"\w* tú, oh SEÑOR, \w no|strong="H5921"\w* \w te|strong="H5921"\w* alejes; fortaleza mía, apresúrate \w para|strong="H5921"\w* \w mi|strong="H5921"\w* ayuda.
\m 
\v 20 Libra de la espada mi alma; del poder del perro mi única.
\m 
\v 21 Sálvame de la boca del león, y óyeme \add librándome\add* de los cuer­nos de los unicornios.
\m 
\v 22 Anunciaré tu nombre \w a|strong="H3068"\w* mis hermanos: en medio de la con­gregación te alabaré.
\m 
\v 23 Los \w que|strong="H6951"\w* teméis al SEÑOR, \w alabadle|strong="H1984"\w*; glorificadle, simiente toda de Jacob; y temed de él, vosotros, simiente toda de Israel.
\m 
\v 24 Porque no menospreció ni abominó \w la|strong="H3605"\w* aflicción \w del|strong="H4480"\w* afligido, ni \w de|strong="H4480"\w* \w él|strong="H3605"\w* escondió su rostro; Sino \w que|strong="H4480"\w* cuando clamó \w a|strong="H3068"\w* \w él|strong="H3605"\w*, oyóle.
\m 
\v 25 \w De|strong="H4480"\w* \w ti|strong="H4480"\w* \w será|strong="H3808"\w* mi alabanza \w en|strong="H4480"\w* \w la|strong="H3588"\w* grande congregación; mis votos pagaré \w delante|strong="H6440"\w* \w de|strong="H4480"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* le temen.
\m 
\v 26 Comerán los pobres, y serán saciados: alabarán al SEÑOR los \w que|strong="H6951"\w* le buscan: vivirá vuestro corazón para siempre.
\m 
\v 27 Acordarse han, y volveránse al \w SEÑOR|strong="H3068"\w* todos los términos \w de|strong="H7646"\w* \w la|strong="H7646"\w* tierra; y se humillarán delante \w de|strong="H7646"\w* ti todas las familias \w de|strong="H7646"\w* las naciones.
\m 
\v 28 \w Porque|strong="H6440"\w* del \w SEÑOR|strong="H3068"\w* es \w el|strong="H3605"\w* reino; y \w él|strong="H3605"\w* se enseñoreará \w de|strong="H6440"\w* las \w naciones|strong="H1471"\w*.
\m 
\v 29 Comerán \w y|strong="H3588"\w* adorarán todos \w los|strong="H3588"\w* poderosos \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra: postrarán­se delante \w de|strong="H3588"\w* \w él|strong="H3588"\w* todos \w los|strong="H3588"\w* \w que|strong="H3588"\w* descienden al polvo, \w si|strong="H3588"\w* \w bien|strong="H3588"\w* nin­guno puede conservar \w la|strong="H3588"\w* vida \w a|strong="H3068"\w* \w su|strong="H3588"\w* propia alma.
\m 
\v 30 Una simiente le servirá; \w será|strong="H3808"\w* \w ella|strong="H3605"\w* contada \w por|strong="H6440"\w* una generación al Señor.
\m 
\v 31 Vendrán, y anunciarán al pue­blo que naciere, su justicia que él hizo.
\c 23
\d Salmo de David.
\m 
\v 1 EL \w SEÑOR|strong="H3068"\w* \add es\add* mi \w pastor|strong="H7462"\w*; \w nada|strong="H3808"\w* me faltará.
\m 
\v 2 \w En|strong="H5921"\w* lugares \w de|strong="H5921"\w* delicados pastos \w me|strong="H5921"\w* hace yacer: \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w aguas|strong="H4325"\w* \w de|strong="H5921"\w* \w reposo|strong="H4496"\w* \w me|strong="H5921"\w* lleva.
\m 
\v 3 Restaura \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*; me guía \w por|strong="H4616"\w* sendas de \w justicia|strong="H6664"\w* \w por|strong="H4616"\w* amor de su \w nombre|strong="H8034"\w*.
\m 
\v 4 \w Aunque|strong="H3588"\w* \w ande|strong="H3212"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w valle|strong="H1516"\w* \w de|strong="H3588"\w* \w la|strong="H1571"\w* sombra \w de|strong="H3588"\w* \w muerte|strong="H6757"\w*, \w no|strong="H3808"\w* \w temeré|strong="H3372"\w* \w mal|strong="H7451"\w* alguno; \w porque|strong="H3588"\w* tú \add estás\add* \w con|strong="H3588"\w*­migo: tu \w vara|strong="H7626"\w* \w y|strong="H1571"\w* tu \w cayado|strong="H4938"\w* \w me|strong="H3588"\w* infunden aliento.
\m 
\v 5 Aderezas \w mesa|strong="H7979"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* mí en \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* mis enemigos: unges mi \w cabeza|strong="H7218"\w* con \w aceite|strong="H8081"\w*: mi copa está rebosando.
\m 
\v 6 Ciertamente \w el|strong="H3605"\w* \w bien|strong="H2896"\w* y \w la|strong="H3605"\w* mise­ricordia me seguirán \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w días|strong="H3117"\w* de mi \w vida|strong="H2416"\w*: y en \w la|strong="H3605"\w* \w casa|strong="H1004"\w* del \w SEÑOR|strong="H3068"\w* \w moraré|strong="H3427"\w* por \w siempre|strong="H3605"\w*.
\c 24
\d Salmo de David.
\m 
\v 1 DEL \w SEÑOR|strong="H3068"\w* es la tierra y su plenitud; \w el|strong="H3427"\w* \w mundo|strong="H8398"\w*, y \w los|strong="H3427"\w* que en \w él|strong="H3427"\w* \w habitan|strong="H3427"\w*.
\m 
\v 2 \w Porque|strong="H3588"\w* \w él|strong="H1931"\w* \w la|strong="H1931"\w* \w fundó|strong="H3245"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w mares|strong="H3220"\w*, \w y|strong="H3588"\w* \w la|strong="H1931"\w* estableció \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* ríos.
\m 
\v 3 ¿\w Quién|strong="H4310"\w* \w subirá|strong="H5927"\w* al \w monte|strong="H2022"\w* del \w SEÑOR|strong="H3068"\w*? ¿y \w quién|strong="H4310"\w* \w estará|strong="H6965"\w* en \w el|strong="H4310"\w* \w lugar|strong="H4725"\w* de su \w santidad|strong="H6944"\w*?
\m 
\v 4 El \w limpio|strong="H1249"\w* de \w manos|strong="H3709"\w*, \w y|strong="H5355"\w* \w puro|strong="H1249"\w* de \w corazón|strong="H3824"\w*: el \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w ha|strong="H3808"\w* elevado su \w alma|strong="H5315"\w* \w a|strong="H3068"\w* la \w vanidad|strong="H7723"\w*, \w ni|strong="H3808"\w* \w jurado|strong="H7650"\w* con \w engaño|strong="H4820"\w*.
\m 
\v 5 Él recibirá \w bendición|strong="H1293"\w* del \w SEÑOR|strong="H3068"\w*, y \w justicia|strong="H6666"\w* del \w Dios|strong="H3068"\w* de salvación.
\m 
