\id ACT Printed: Jul 99.
\h شّيرَيٍ شَ تَرُشُي
\toc1 عِسَ شَ شّيرَيٍ شَ تَرُشُي
\toc2 تَرُشُي
\mt1 عِسَ شَ شّيرَيٍ شَ تَرُشُي
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip عَننَبِ لُكِ نَشَن عِنيِلَ عِسَ سّبّ، عَ نَشَ كِتَابُي قِرِن ندٍ سّبّ نَشَن شِلِ «عِسَ شَ شّيرَيٍ شَ تَرُشُي». عِنيِلَ عِسَ عَ مَسٍنمَ وٌن بّ عِسَ قٍ نَشَن نَبَشِ عَ شَ سِمَيَ كُي. يِ كِتَابُي قِرِن ندٍ قْلْشِ بٌورٍ كِتَابُي دَنشِ دّننَشّ، عَ قَن عَ مَسٍنمَ وٌن بّ عِسَ قْشِرَبِرّيٍ نُن عَ شَ شّيرَيٍ نَشَن نَبَ عَلَكٌ عِسَ شَ مَسٍنيِ شَ يٍنسٍن دُنِحَ بِرِن نَ.
\ip بٍينُن عِسَ شَ عَ شَ شّيرَيٍ شّي عٍ شَ عَ شَ مَسٍنيِ كَوَندِ دُنِحَ بِرِن بّ، عَ نَشَ عَلَ شَشِلِ سّنِيّنشِ رَفٌرٌ عٍ مَ عَلَكٌ عٍ شَ سّنبّ سْتْ عَ شَ وَلِ رَبَقٍ مَ. عٍ تٌ نَ سْتْ، عٍ نَشَ كَوَندِ تِ قْلْ دَرِ سَلَمُ. مِشِ فبٍفبٍ نَشَ لَ عٍ شَ مَسٍنيِ رَ، عٍ قِندِ عِسَ قْشِرَبِرّيٍ رَ. كَابَنَكٌ فبٍفبٍ نَشَ رَبَ عَلَكٌ مِشِ شَ لَ عِسَ شَ شّيرَيٍ شَ مَسٍنيِ رَ.
\ip نَ كَوَندِ نُ سّنبّ سْتْقٍ دَرِ سَلَمُ تّمُي نَشّ، عِسَ يَشُييٍ نَشَ دَنشَنِيَتْييٍ تْورْ قْلْ. نَ كُي، عِسَ قْشِرَبِرّيٍ نَشَ يٍنسٍن دَرِ سَلَمُ قَرِ مَ. عٍ نَشَ سِفَ كَوَندِ تِ رَ يُدَيَ نُن سَمَرِ بْشِ مَ. سٌرَ سِنفٍ هَن سٌرَ قُ نُن قِرِن ندٍ، نَ وَلِ نَن مَسٍنشِ وٌن بّ. ثِيّرِ تِدٍ فبٌ نَ تَرُشُي كُي.
\ip نَ شَنبِ عَلَ نَشَ شّيرَ فبّتّ شِلِ نَشَن قِندِشِ ثْلُ رَ. بٍينُن عَلَ شَ عَ شِلِ، ثْلُ نُ عِسَ قْشِرَبِرّيٍ حَشَنكَتَمَ عِسِرَيِلَ شَ دِينّ شِلِ رَ. كْنْ عِسَ نَشَ عَ يّتّ مَسٍن ثْلُ بّ، عَ قَ عَ شّي حَمَنّ فبّتّيٍ مَ. نَ كُي، عِسَ شَ شِبَارُ بَرَ دَنفِ عِسِرَيِلَ نَانِنيِ رَ سِفَقٍ رَ بْشِيٍ مَ سِ فبّتّيٍ نُ نَ دّننَشّ.
\ip ثْلُ نَشَ نَ وَلِ رَبَ يِرٍ وُيَشِ، كٍلِ دَرِ سَلَمُ هَن رْ مَ. يُوِقِيٍ نَشَ عَ حَشَنكَتَ كِ قَنيِ، كْنْ عٍ مُ نْ عَ رَ. عَ نُ كَوَندِ تِمَ يُوِقِيٍ شَ سَلِدٍيٍ نَن كُي، عَ مَن نُ عَ تِ سِ فبّتّيٍ شَ سَلِدٍيٍ كُي. عَ نَ رَبَ نّ عَلَكٌ دُنِحَ بِرِن شَ عَ كٌلٌن عِسَ بَرَ نَشَن نَبَ عٍ بّ.
\ip نَ بِرِن كُي، تٌ دَنشَنِيَتْييٍ نْمَ عَ كٌلٌندٍ عِسَ قْشِرَبِرّ سِنفٍيٍ دُنِحَ عِفِرِشِ كِ نَشّ. عٍ شَ وَلِ شَ قِندِ مِسَالِ رَ وٌن بّ. عَلَ شَ وٌن مَلِ شَشِلِ سْتْقٍ رَ يِ كِتَابُي سَابُي رَ. عَمِنَ.
\mt1 عِسَ شَ شّيرَيٍ شَ تَرُشُي
\cl سٌرَ
\c 1
\s1 عِسَ تٍقٍ كٌورٍ مَ
\p 
\v 1 تٍيٌقِلٌ، ﭑ بَرَ عَ مَسٍن ﭑ مَ كِتَابُي سِنفٍ كُي عِسَ نَشَن بِرِن قَلَشِ نُن عَ نَشَن نَبَشِ كَبِ عَ قْلّ
\v 2 هَن عَ تٍ لْشْي كٌورٍ مَ. بٍينُن عَ شَ تٍ كٌورٍ مَ، عَ نَشَ يَامَرِ قِ عَ شَ شّيرَ سُفَندِشِيٍ مَ، عَلَ شَشِلِ سّنِيّنشِ سَابُي رَ.
\p 
\v 3 عَ شَ حَشَنكَتّ شَنبِ، عَ نَشَ مِنِ عٍ مَ شِ تٌنفٌ نَانِ بُن مَ، عَ عَ يّتّ مَسٍنمَ عٍ بّ كِرَيَ وُيَشِ عَ عَ حِحّ نَ عَ رَ. عَ نُ قَ عَلَ شَ مَنفّيَ نِينِ قٍ قَلَ عٍ بّ.
\v 4 عَ نُ عٍ يَ مَ تّمُي نَشّ، عَ نَشَ عَ قَلَ عٍ بّ، «وٌ نَشَ وٌ مَكُيَ دَرِ سَلَمُ رَ. وٌ شَ لُ بٍ هَن بَبَ عَلَ عَ شَ لَايِدِ رَكَمَلِمَ تّمُي نَشّ، عَلْ ﭑ نَ مَسٍنشِ وٌ بّ كِ نَشّ.
\v 5 يَيَ وٌ شُنشَ يٍ نَن شْورَ، كْنْ عَلَ شَشِلِ سّنِيّنشِ نَن قَمَ فٌرٌدٍ وٌ مَ يِ سَشَنيِ.»
\p 
\v 6 عَوَ، شّيرَيٍ تٌ عٍ مَلَن، عٍ نَشَ عِسَ مَشْرِن، «مَرِفِ، عِ عِسِرَيِلَ مَنفّيَ رَفبِلٍنمَ عَ رَ يِ تّمُي نّ؟»
\v 7 عِسَ نَشَ عٍ يَابِ، «نَ وَشَتِ كٌلٌنقٍ مُ نَ وٌ تَن شَ مَ. نَ نَتّ نَ بَبَ عَلَ كٍرٍن ثٍتِ نَن يِ رَ.
\v 8 كْنْ، وٌ سّنبّ سْتْمَ عَلَ شَشِلِ سّنِيّنشِ نَ قَ وٌ مَ تّمُي نَشّ. وٌ قِندِ مَ ﭑ مَ سٍيدٍيٍ نَن نَ دَرِ سَلَمُ نُن يُدَيَ بِرِن، سَمَرِ، هَن دُنِحَ دَندٍ.»
\p 
\v 9 عَ تٌ فّ نَ مَسٍنيِ تِدٍ، عَلَ نَشَ عَ رَتٍ كٌورٍ مَ عٍ يَ شْرِ، نُشُي قَ عَ نْشُن عٍ يَ تٌدٍ رَ.
\v 10 عٍ تٌ نُ عَ مَتٌمَ عَ تٍقٍ كٌورٍ مَ، شّمّ قِرِن نَشَ مِنِ عٍ مَ، سٌسٍ قِيشّ رَفٌرٌشِ عٍ مَ.
\v 11 عٍ نَشَ عَ مَسٍن عِسَ قْشِرَبِرّيٍ بّ، «وٌ تَن فَلِلٍكَيٍ، مُنقٍ رَ وٌ تِشِ بٍ وٌ نُ قَ كٌورٍ مَتٌ؟ يِ عِسَ نَشَن تٌنفٌشِ وٌ تَفِ تٍقٍ كٌورٍ مَ، عَ مَن قَمَ نّ عَلْ وٌ عَ تٌشِ سِفَ رَ كِ نَشّ.»
\s1 يُدَ سِ حْشْي
\p 
\v 12 نَ شَنبِ عٍ نَشَ فبِلٍن دَرِ سَلَمُ، كٍلِقٍ فٍيَ مَ نَشَن شِلِ عٌلِوِ فٍيَ. كٍلِقٍ نَ فٍيَ مَ هَن دَرِ سَلَمُ، يَامِلّ كٍرٍن نَ عَ رَ.
\v 13 عٍ نَشَ سٌ كٌورٍ بَنشِ كُي، عٍ نُ دَرِشِ عٍ مَلَن نَ دّننَشّ. نَشٍيٍ نُ نَ نَ؛ ثِيّرِ، يَيَ، يَكِ، عَندِرٍ، قِلِثُ، تٌمَسِ، بَرٌتٌلٌمٍ، مَتِيُ، يَكِ عَلِقَ شَ دِ، سِمْن نَشَن قِندِ سٍلٌتِ رَ، نُن يُدَ سِ، يَكِ شَ دِ.
\v 14 عٍ بِرِن نُ عَلَ مَشَندِ مَ حَنِفٍ كٍرٍن نَ، عٍ نُن فِنّيٍ، عَ نُن مَرِيَمَ، عِسَ نفَ، عَ نُن عِسَ شُنيَيٍ.
\p 
\v 15 لْشْ ندٍ ثِيّرِ نَشَ كٍلِ، عَ تِ عَ نفَشَكٍرٍنيِيٍ تَفِ. مِشِ كّمّ مِشِ مْشْحّن حْندْن نُ مَلَنشِ نَا. عَ نَشَ عَ قَلَ عٍ بّ،
\v 16 «ﭑ نفَشَكٍرٍنيِيٍ، عَلَ شَشِلِ سّنِيّنشِ نَشَن مَسٍنشِ كِتَابُي كُي دَوُدَ سَابُي رَ، يُدَ سِ شَ قٍ رَ، نَشَن تِ مِشِيٍ يَ رَ عِسَ سُشُقٍ مَ، نَ بِرِن بَرَ كَمَلِ.
\v 17 عَ نُ نَ مُشُ تَن شّيرَيٍ نَن يَ مَ. مُشُ بِرِن نَن نُ شّيرَ وَلِ رَبَمَ.
\v 18 عٍ نَشَ بْشِ سَرَ يِ شّمّ شَ قٍ كٌبِ رَبَشِ سَرٍ رَ. يُدَ سِ نَشَ قَشَ مّننِ، عَ بِرَ، عَ قُرِ بُلَ، عَ قُرِنفّيٍ نَشَ مِنِ عَ رَ.
\v 19 دَرِ سَلَمُكَيٍ بِرِن نَشَ يِ قٍ كٌلٌن. عٍ نَشَ نَ بْشِ شِلِ قَلَ عَكٍلٍدَ مَ، نَ نَن قَلَشِ عٍ شَ شُي ‹وُلِ بْشِ›.»
\p 
\v 20 «عَ سّبّشِ يَبُرَ دَوُدَ كُي، ‹عَ شَ بَنشِ شَ بَلَن، مِشِ يٌ نَشَ سَبَتِ نَا.› عَ مَن سّبّشِ، ‹شّيرَ فبّتّ شَ تِ عَ حْشْي رَ.›
\v 21‏-22 عَوَ نَ كُي، عَ لَنمَ شّمّ كٍرٍن شَ سُفَندِ نَشَن نْمَ مُشُ مَلِدٍ سٍيدٍيَ رَبَدٍ عِسَ شَ مَرَكٍلِ شَ قٍ رَ. عَ لَنمَ وٌن شَ مِشِ سُفَندِ نَشَن نُ نَ وٌن يَ مَ، وٌن نُن مَرِفِ عِسَ تٌ نُ عَ رَ، كٍلِقٍ يَيَ عِسَ شُنشَ يٍ شْورَ تّمُي نَشّ، هَن عِسَ تٍ كٌورٍ مَ تّمُي نَشّ.»
\p 
\v 23 عٍ نَشَ مِشِ قِرِن مَسٍن؛ يُسُقُ نَشَن نُ شِلِ بَرَ سَبَ، عٍ مَن نُ نَشَن شِلِ قَلَمَ يُسُتُ، عَ نُن مَتِيَسِ.
\v 24 نَ شَنبِ عٍ نَشَ عَلَ مَشَندِ، «مَرِفِ، عِ تَن نَشَن بِرِن بْحّ مَ قٍ كٌلٌن، عَ مَسٍن مُشُ بّ عِ مِشِ نَشَن سُفَندِشِ يِ قِرِنيِيٍ تَفِ.
\v 25 نَ شَ قِندِ يُدَ سِ حْشْي رَ شّيرَيَ نُن وَلِ رَبَقٍ رَ، بَرِ مَ يُدَ سِ بَرَ سِفَ عَ سِفَدٍ.»
\v 26 عٍ نَشَ مَتِيَسِ سُفَندِ عَلَ شَ مَلِ رَ. عَ نَشَ سَ يِ شّيرَ قُ نُن كٍرٍنيِيٍ شُن مَ.
\c 2
\s1 عَلَ شَشِلِ سّنِيّنشِ فٌرٌقٍ دَنشَنِيَتْييٍ مَ
\p 
\v 1 شّ شَبّ سَلِ تٌ عَ لِ، عِسَ قْشِرَبِرّيٍ بِرِن نُ مَلَنشِ يِرٍ كٍرٍن.
\v 2 شُي ندٍ نَشَ مِنِ كٌورٍ مَ كٍرٍن نَ عَلْ قٌيٍ شُنفبٍ شُي. عَ نَشَ بَنشِ كُي بِرِن نَقٍ عٍ نُ دْشْشِ دّننَشّ.
\v 3 عٍ نَشَ سٍ ندٍيٍ تٌ نَشٍيٍ مَنِيَ نّنيِيٍ رَ، تّ نَ عٍ مَ. نَ سٍيٍ نَشَ عِتَشُن، كٍرٍن كٍرٍن نَشَ دْشْ كَنكَن شُنيِ مَ.
\v 4 عَلَ شَشِلِ سّنِيّنشِ نَشَ فٌرٌ قْشِرَبِرّيٍ بِرِن مَ، عٍ نَشَ سٌ شُي فبّتّيٍ قَلَقٍ عَلَ شَشِلِ سّنِيّنشِ سَابُي رَ.
\p 
\v 5 يُوِقِ دِينّلَيٍ كٍلِقٍ حَمَنّ بِرِن مَ، عٍ نُ مَلَنشِ دَرِ سَلَمُ نَ سَشَنيِ.
\v 6 حَمَ تٌ يِ شُي مّ، عٍ نَشَ قَ عٍ فِ رَ. عٍ نَشَ كَابَ بَرِ مَ كَنكَن نُ عِسَ قْشِرَبِرّيٍ شُي مّمَ عٍ بَرِ شُي يَتِ نَن نَ.
\v 7 عٍ دّ نَشَ عِشَرَ، عٍ قَ عَ قَلَ، «ثٍ، يِ مِشِيٍ نَشٍيٍ وْيّنمَ يِ كِ، فَلِلٍكَيٍ شَ مُ عٍ بِرِن نَ؟
\v 8 وٌن قَ وٌن بَرِ شُي مّقٍ عٍ رَ دِ؟
\v 9 ثَرَتٌكَيٍ، مٍدٍكَيٍ، عٍلَمَكَيٍ، نَشٍيٍ سَبَتِشِ مٍسٌثٌتَمِيَ، يُدَيَ، كَثَدٌ سٍ، ثٌنتُ، عَسِ،
\v 10 قِرِفِيَ، ثَنقِلِيَ، مِسِرَ، لِبِيَ، سِرٍنِ بْشِ قّ مَ، عَ نُن نَشٍيٍ كٍلِ رْ مَ، يُوِقِيٍ عَ نُن مِشِ نَشٍيٍ سٌشِ عٍ شَ دِينّ يَ مَ، كِرّتِكَيٍ عَ نُن عَرَبُيٍ،
\v 11 وٌن بِرِن نَ عٍ شُي مّقٍ وٌن بَرِ شُي يَتِ نَن نَ. عٍ نَ عَلَ شَ كَابَنَكٌ قٍيٍ قَلَقٍ وٌن مَ شُييٍ. نَ رَبَشِ دِ؟»
\v 12 عٍ بِرِن دّ نَشَ عِشَرَ، عٍ نَشَ عِقُ. عٍ نُ عَ قَلَ عٍ بٌرٍ بّ، «مُنقٍ يِ كِ؟»
\v 13 كْنْ ندٍيٍ نَشَ عٍ مَيٍلٍ، عٍ نُ قَ عَ قَلَ، «عٍ سِيسِشِ نّ يِ كِ.»
\s1 ثِيّرِ شَ كَوَندِ
\p 
\v 14 نَ شَنبِ ثِيّرِ نُن يِ شّيرَ قُ نُن كٍرٍنيِيٍ نَشَ كٍلِ. ثِيّرِ نَشَ عَ مَسٍن حَمَ بّ عَ شُي عِتٍشِ رَ، «يُوِقِيٍ، عَ نُن وٌ تَن نَشَن بِرِن نَ دَرِ سَلَمُ، وٌ شَ وٌ تُلِ مَتِ ﭑ نَ. وٌ شَ عَ كٌلٌن،
\v 15 يِ مِشِيٍ مُ سِيسِشِ شّ دٍ عَلْ وٌ عَ مَحْشُنشِ كِ نَشّ، بَرِ مَ فّيسّفّ نَ عَ رَ يِ كِ.»
\p 
\v 16 «عَننَبِ يٌوٍلِ يِ مَسٍنيِ نَن تِ.
\q1 
\v 17 ‹عَلَ نَشّ،
\q1 ﭑ قَمَ ﭑ شَشِلِ تَشُندٍ مِشِ بِرِن نَ لْشْي دْنشْييٍ.
\q1 وٌ شَ دِ شّمّيٍ نُن وٌ شَ دِ فِنّيٍ
\q1 وْيّنمَ نّ ﭑ تَن عَلَ شِلِ رَ.
\q1 وٌ شَ سّفّتَلَيٍ تٌ تِمَ نّ قٍيٍ رَ،
\q1 وٌ شَ قٌرِيٍ قَن شِيٍيٍ سَ.
\q1 
\v 18 نَ وَشَتِ،
\q1 ﭑ قَمَ ﭑ شَشِلِ رَفٌرٌدٍ ﭑ مَ كٌنيِ شّمّيٍ
\q1 نُن ﭑ مَ كٌنيِ فِنّيٍ مَ.
\q1 عٍ وْيّنمَ نّ ﭑ تَن عَلَ شِلِ رَ.
\q1 
\v 19 ﭑ كَابَنَكٌييٍ رَبَمَ نّ كٌورٍ مَ،
\q1 ﭑ تْنشُمَيٍ مَسٍنمَ نّ بْشِ قَرِ،
\q1 نَشٍيٍ قِندِ مَ وُلِ، تّ، نُن تُورِ رَ.
\q1 
\v 20 سٌفٍ دِ مِمَ نّ،
\q1 كِكٍ فبٍيلِمَ نّ عَلْ وُلِ
\q1 بٍينُن مَرِفِ شَ لْشْي شَ عَ لِ،
\q1 نَ دَرِيّ لْشْي شُنفبٍ.
\q1 
\v 21 مِشِ يٌ نَشَن مَرِفِ شِلِ مَشَندِ مَ،
\q1 نَ كَنيِ كِسِمَ نّ.›»
\b
\p 
\v 22 «عِسِرَيِلَكَيٍ، وٌ وٌ تُلِ مَتِ يِ مَسٍنيِ رَ. عِسَ نَسَرّتِكَ عَلَ شَ مِشِ سُفَندِشِ نَن نُ عَ رَ. عَلَ نَشَ نَ مَسٍن كَابَنَكٌييٍ، قٍ مَفَاشُشِيٍ، نُن تْنشُمَيٍ رَ، عِسَ نَشَن نَبَشِ وٌ تَفِ. وٌ بِرِن نَ قٍيٍ كٌلٌن.
\v 23 عَلَ بَرَ عَ رَفِرِ كَاقِرِيٍ شَ كَقُ وٌ مَ، عَلَكٌ وٌ شَ يِ شّمّ قَشَ، وٌ عَ بَنبَن وُرِ مَفَلَنبُشِ مَ، عَلْ عَلَ نُ عَ حَنِفٍشِ كِ نَشّ.
\v 24 كْنْ نَ شَنبِ، عَلَ بَرَ عَ رَكٍلِ، عَ قَشّ لُوتِ بَ عَ مَ، بَرِ مَ قَشّ مُ نُ نْمَ كَنكَندٍ عَ مَ.»
\p 
\v 25 «دَوُدَ نُ عِسَ شَ قٍ نَن قَلَقٍ يِ مَسٍنيِ رَ.
\q1 ‹ﭑ مَرِفِ تٌمَ تّمُي بِرِن ﭑ يَ عِ.
\q1 عَ تٌ نَ ﭑ سّيتِ مَ، ﭑ مُ نْمَ بِرَدٍ.
\q1 
\v 26 نَ نَن عَ تٌشِ ﭑ بْحّ نَ سّيوّ كُي،
\q1 ﭑ دّ قَن عَ شَ قٍ مَسٍنمَ حّلّشِنيِ رَ.
\q1 ﭑ قَتٍ قَن مَلَبُمَ نّ بْحّسَ كُي،
\q1 
\v 27 بَرِ مَ عِ مُ ﭑ نِي بّحِنمَ عَلِفِيَمَ،
\q1 عِ مُ عِ شَ سّنِيّنتْي لُمَ فَبُرِ كُي، عَ شَ بْرْ.
\q1 
\v 28 عِ بَرَ عَ نِيَ ﭑ شَ كِسِ كِرَ كٌلٌن.
\q1 عِ سّيوّ قِمَ نّ ﭑ مَ عِ يِرٍ.›»
\b
\p 
\v 29 ثِيّرِ مَن نَشَ عَ قَلَ، «ﭑ نفَشَكٍرٍنيِيٍ، وٌ عَ لُ ﭑ شَ وٌن بٍنبَ دَوُدَ شَ قٍ قَلَ وٌ بّ. عَ قَشَ نّ، عَ نَشَ رَفَتَ، عَ شَ فَبُرِ مَن نَ وٌن تَفِ بٍ هَن تٌ.
\v 30 نَمِحْنمّ تٌ نُ عَ رَ، عَ نُ عَ كٌلٌن عَلَ بَرَ لَايِدِ تٌنفٌ عَ بّ. عَلَ نَشَ عَ كَلِ عَ دَوُدَ شَ مَمَدِ ندٍ دْشْمَ نّ عَ شَ مَنفّ كِبَنيِ.
\v 31 نَ كُي، دَوُدَ نُ عَ كٌلٌن عَلَ شَ مِشِ سُفَندِشِ قَمَ نّ كٍلِدٍ قَشّ مَ. عَلَ مُ نّيمُمَ عَ مَ عَلِفِيَمَ، عَ قَتٍ مُ بْرْ مَ فَبُرِ كُي.
\v 32 عَلَ نَن عِسَ رَكٍلِشِ قَشّ مَ. وٌن بِرِن قِندِشِ سٍيدٍ رَ نَ قٍ مَ.
\v 33 عَ تٌ رَتٍ عَلَ يِرٍقَنيِ مَ، عَ نَشَ عَلَ شَشِلِ سّنِيّنشِ سْتْ بَبَ عَلَ رَ، عَلْ عَلَ لَايِدِ تٌنفٌشِ كِ نَشّ. عَ مَن بَرَ عَلَ شَشِلِ سّنِيّنشِ رَفٌرٌ وٌن مَ. وٌ نَ نَن تٌقٍ، وٌ نَ نَن مّقٍ يِ كِ.»
\p 
\v 34 «دَوُدَ مُ تٍشِ كٌورٍ مَ، كْنْ عَ تَن نَن عَ قَلَ،
\q1 ‹مَرِفِ نَشَ عَ قَلَ ﭑ مَرِفِ بّ،
\q1 دْشْ ﭑ يِرٍقَنيِ مَ،
\q1 
\v 35 هَن ﭑ شَ عِ سَنيِ تِ عِ يَشُييٍ قَرِ.›»
\p 
\v 36 «نَ كُي، عِسِرَيِلَكَ بِرِن شَ لَ عَ رَ، عَلَ بَرَ عِسَ قِندِ مَرِفِ رَ، نُن عَ شَ مِشِ سُفَندِشِ رَ. كْنْ وٌ بَرَ عَ بَنبَن وُرِ مَفَلَنبُشِ مَ.»
\p 
\v 37 يِ مَسٍنيِ نَشَ حَمَ بْحّ تْورْ كِ قَنيِ رَ. عٍ نَشَ عَ قَلَ ثِيّرِ نُن شّيرَ بٌورٍيٍ بّ، «ﭑ نفَشَكٍرٍنيِيٍ، عَ لَنمَ مُشُ شَ مُنسٍ رَبَ قَ؟»
\v 38 ثِيّرِ نَشَ عَ قَلَ عٍ بّ، «وٌ شَ تُوبِ، وٌ بِرِن شَ وٌ شُنشَ يٍ شْورَ عِسَ شِلِ رَ، عَلَ شَ مِشِ سُفَندِشِ، عَلَكٌ وٌ شَ يُنُبِيٍ شَ شَقَرِ، وٌ مَن شَ عَلَ شَشِلِ سّنِيّنشِ سْتْ.
\v 39 عَلَ بَرَ يِ لَايِدِ تٌنفٌ وٌ بّ، وٌ شَ دِيٍ بّ، نُن مِشِ بِرِن بّ عَ نَشٍيٍ شِلِمَ، هَلِ نَشٍيٍ نَ يِرٍ مَكُيٍ.»
\v 40 ثِيّرِ مَن نَشَ عٍ رَ سِ، عَ نَشَ عٍ رَلِمَنِيَ مَسٍنيِ وُيَشِ رَ. عَ نَشَ عٍ مَشَندِ، «وٌ وٌ مّينِ يِ وَشَتِ مِشِ تِنشِنتَرٍيٍ مَ.»
\p 
\v 41 نَشٍيٍ تِن عَ شَ مَسٍنيِ رَ، عٍ نَشَ عٍ شُنشَ يٍ شْورَ. نَ لْشْي مِشِ وُلُ سَشَن حْندْن نَشَ سَ عِسَ قْشِرَبِرّيٍ شُن مَ.
\v 42 عٍ نُ عٍ تُننَبّشِمَ شّيرَيٍ شَ شَرَنيِ مَ. عٍ نَشَ لُ نفَشَكٍرٍنيَ كُي. عٍ مَن نَشَ عٍ تُننَبّشِ تَامِ عِتَشُنقٍ نُن عَلَ مَشَندِقٍ مَ.
\v 43 فَاشُي نَشَ عٍ بِرِن سُشُ. شّيرَيٍ نَشَ كَابَنَكٌ نُن تْنشُمَ فبٍفبٍ رَبَ.
\v 44 دَنشَنِيَتْييٍ بِرِن نُ مَلَنشِ يِرٍ كٍرٍن. شَ مِشِ كٍرٍن سٍ سْتْ، نَ بَرَ قِندِ عٍ بِرِن فبٍ رَ.
\v 45 عٍ عٍ شَ سٍيٍ مَتِمَ، عٍ نُ عٍ هَرِفٍ عِتَشُن عٍ بٌرٍ مَ، كَنكَن نُ عَ هَيِ قَن نَ كُي.
\v 46 لْشْ يٌ لْشْ عٍ نُ عٍ مَلَنمَ هْرْ مْبَنشِ كُي، عٍ نُ دٌنسٍ دٌن عٍ شْنيِ سّيوّ نُن بْحّسَ كُي.
\v 47 عٍ نُ عَلَ مَتْشْمَ. عٍ نَشَ رَقَن بِرِن مَ. لْشْ يٌ لْشْ مَرِفِ نُ ندٍ سَمَ دَنشَنِيَتْي حَمَ كْنتِ شُن مَ.
\c 3
\s1 نَمَتّ رَيَلَنقٍ
\p 
\v 1 لْشْ ندٍ ثِيّرِ نُن يَيَ نُ تٍقٍ هْرْ مْبَنشِ كُي، سَلِ تّمُي فّيسّفّ.
\v 2 هْرْ مْبَنشِ نَادّ رَ نَشَن شِلِ «نَادّ تٌقَنيِ»، شّمّ ندٍ نُ نَ نَشَن نُ نَمَتَشِ كَبِ عَ بَرِ لْشْي. عٍ نُ عَ دْشْمَ نَ لْشْي بِرِن عَلَكٌ عَ شَ نُ كْبِرِ مَكُلَ مِشِيٍ مَ نَشٍيٍ سٌمَ هْرْ مْبَنشِ كُي.
\v 3 عَ تٌ ثِيّرِ نُن يَيَ تٌ سٌ رَ هْرْ مْبَنشِ كُي، عَ نَشَ كْبِرِ مَكُلَ عٍ مَ.
\p 
\v 4 ثِيّرِ نُن يَيَ نَشَ عٍ يَ تِ عَ رَ. ثِيّرِ نَشَ عَ قَلَ عَ بّ، «مُشُ مَتٌ.»
\v 5 شّمّ نَشَ عٍ مَتٌ، عَ حْشْ نَشَ لُ عَ مَ عٍ نَ كْبِرِ نَن قِقٍ عَ مَ.
\v 6 ثِيّرِ قَ عَ قَلَ عَ بّ، «فبٍتِ مُ نَ ﭑ يِ، شّيمَ مُ نَ ﭑ يِ، كْنْ نَشَن نَ ﭑ يِ رَ، ﭑ عَ قِمَ عِ مَ. ﭑ بَرَ عِ يَامَرِ عِسَ نَسَرّتِكَ شِلِ رَ، نَشَن قِندِشِ عَلَ شَ مِشِ سُفَندِشِ رَ، كٍلِ، عِ عِ حّرّ!»
\v 7 عَ نَشَ عَ سُشُ عَ يِرٍقَنيِ بّلّشّ مَ، عَ عَ رَكٍلِ. عَ سَنيِيٍ نُن عَ سَنكْنيِيٍ نَشَ سّنبّ سْتْ كٍرٍن نَ.
\v 8 نَ عِكْرّشِ رَ، عَ نَشَ كٍلِ، عَ نَشَ سٌ عَ حّرّقٍ. عَ نَشَ سٌ ثِيّرِ نُن يَيَ قْشْ رَ هْرْ مْبَنشِ كُي. عَ حّرّ مَ، عَ تُفَنمَ، عَ عَلَ تَنتُمَ.
\p 
\v 9 بِرِن نَشَ عَ تٌ، عَ عَ حّرّ مَ، عَ عَلَ مَتْشْمَ.
\v 10 عٍ نَشَ عَ كٌلٌن عَ تَن نَن نُ دْشْمَ هْرْ مْبَنشِ «نَادّ تٌقَنيِ» دّ رَ كُلّ مَتِدٍ. بِرِن نَشَ كَابَ، عٍ تّرّننَ يِ قٍ رَ نَشَن بَرَ رَبَ عَ بّ.
\v 11 عَ قَن نَشَ بِرَ ثِيّرِ نُن يَيَ قْشْ رَ. حَمَ بِرِن نَشَ كَابَ، عٍ نَشَ عٍ فِ سِفَقٍ رَ عٍ يِرٍ سُلٍمَنِ شَ بُنتُنيِ رَ.
\p 
\v 12 ثِيّرِ تٌ نَ تٌ، عَ نَشَ حَمَ مَشْرِن، «وٌ تَن عِسِرَيِلَكَيٍ، مُنقٍ رَ وٌ كَابَمَ يِ قٍ مَ؟ مُنقٍ رَ وٌ وٌ يَيٍ بَنبَنشِ مُشُ رَ عَلْ مُشُ يِ شّمّ رَحّرّشِ مُشُ يّتّ سّنبّ نَن نَ، شَ نَ مُ عَ رَ مُشُ شَ تِنشِنيِ رَ؟
\v 13 عَننَبِ عِبُرَهِمَ، عَننَبِ عِسِيَفَ، نُن عَننَبِ يَشُبَ مَرِفِ عَلَ، وٌن بٍنبَيٍ مَرِفِ عَلَ، عَ بَرَ عَ شَ دَرِيّ قِ عَ شَ كٌنيِ عِسَ مَ، وٌ نَشَن يَنقَ، وٌ قَ مّي عَ رَ ثِلَتِ يَ عِ، نَشَن نُ وَ مَ عَ رَبّحِنقٍ.
\v 14 وٌ بَرَ عَلَ شَ سّنِيّنتْي نُن عَ شَ تِنشِنتْي يَنقَ. وٌ مَن قَ مَشَندِ تِ ثِلَتِ شَ قَشّتِ ندٍ رَبّحِن وٌ بّ.
\v 15 وٌ بَرَ مَرَكِسِمَ قَشَ، عَلَ نَشَ عَ رَكٍلِ قَشّ مَ. مُشُ نَ نَ قٍ سٍيدٍ رَ.
\v 16 يِ شّمّ نَشَن يِ كِ، وٌ نَشَن كٌلٌن، وٌ نَشَن تٌشِ، عَ بَرَ سّنبّ سْتْ دَنشَنِيَ كُي عِسَ شِلِ سَابُي رَ. عَ شَ دَنشَنِيَ عِسَ مَ، نَ نَن عَ يَلَنشِ وٌ بِرِن يَ شْرِ.»
\p 
\v 17 «يَكْسِ، ﭑ نفَشَكٍرٍنيِيٍ، ﭑ عَ كٌلٌن وٌ نَشَن نَبَشِ عِسَ رَ، وٌ بَرَ عَ رَبَ عَ كٌلٌنتَرٍيَ مَ، وٌ نُن وٌ شَ مَنفّيٍ.
\v 18 كْنْ عَلَ نَن يِ بِرِن نَفِرِشِ، عَلَكٌ عَ شَ وْيّنيِ شَ رَكَمَلِ، عَ نُ بَرَ نَشَن مَسٍن وَشَتِ دَنفِشِ عَ شَ نَمِحْنمّيٍ دّ رَ، عَ قَلَقٍ عَ عَ شَ مِشِ سُفَندِشِ قَمَ نّ تْورْدٍ.
\v 19 عَوَ، وٌ تُوبِ، وٌ فبِلٍن عَلَ مَ، عَلَكٌ وٌ شَ يُنُبِيٍ شَ شَقَرِ،
\v 20 عَلَكٌ مَرِفِ شَ قَ بْحّسَ وَشَتِ رَ، عَ مَن شَ عِسَ شّي، عَ بَرَ نَشَن سُفَندِ وٌ بّ.
\v 21 كْنْ عِسَ، عَلَ شَ مِشِ سُفَندِشِ شَ لُ كٌورٍ مَ سِندٍن، هَن بٍينُن قٍ بِرِن شَ يَءِلَن، عَلْ عَلَ عَ مَسٍن كِ نَشّ عَ شَ نَمِحْنمّ سّنِيّنشِيٍ كّرّ رَ كَقِ عَ شْننَكُيٍ رَ.»
\p 
\v 22 «عَننَبِ مُنسَ نَشَ عَ قَلَ، ‹وٌ مَرِفِ عَلَ نَمِحْنمّ ندٍ شّيمَ نّ وٌ مَ عَلْ ﭑ تَن. وٌن نفَشَكٍرٍنيِ نَن لَنشِ عَ مَ. عَ نَشَن بِرِن قَلَمَ وٌ بّ، وٌ شَ عَ سُشُ.
\v 23 نَشَن يٌ مُ نَ نَمِحْنمّ شُي سُشُ، نَ كَنيِ بَمَ نّ عَلَ شَ حَمَ يَ مَ، عَ قَشَ.›»
\p 
\v 24 «نَمِحْنمّ نَشٍيٍ بِرِن بَرَ وْيّن كَبِ عَننَبِ سَمُوٍلِ شَ تّمُي، عٍ بِرِن بَرَ يِ لْشْييٍ شَ قٍ قَلَ.
\v 25 سَاتّ دِيٍ نُن نَمِحْنمّ دِيٍ نَن نَ وٌ رَ. عَلَ بَرَ سَاتّ تٌنفٌ وٌن بَبَيٍ بّ. عَ عَ قَلَ نّ عِبُرَهِمَ بّ، ‹دُنِحَ بِرِن قَمَ هّيرِ سْتْدٍ عِ بْنسْي نَن سَابُي رَ.›
\v 26 عَلَ تٌ بَرَ عَ شَ كٌنيِ رَكٍلِ قَشّ مَ، عَ عَ شّي وٌ تَن نَن سِنفٍ مَ، عَ شَ دُبَ وٌ بّ، عَ شَ كَنكَن نَفبِلٍن قٍ كٌبِيٍ قْشْ رَ.»
\c 4
\s1 ثِيّرِ نُن يَيَ مَكِيتِقٍ
\p 
\v 1 يَيَ نُن ثِيّرِ تٌ نُ وْيّنمَ مِشِيٍ بّ، سّرّشّدُبّيٍ، هْرْ مْبَنشِ سْورِ يَرٍرَتِ، نُن سَدُ سٍنِيٍ نَشَ قَ.
\v 2 عٍ بْحّ نَشَ تٍ بَرِ مَ ثِيّرِ نُن يَيَ نُ حَمَ شَرَنقٍ، عَ قَلَقٍ مِشِ قَشَشِيٍ قَمَ نّ رَكٍلِدٍ عَلْ عِسَ رَكٍلِشِ كِ نَشّ.
\v 3 عٍ نَشَ عٍ سُشُ، عٍ عٍ سَ فٍيلِ هَن نَ كُيٍ عِبَ، بَرِ مَ كْي نُ بَرَ سٌ.
\v 4 كْنْ مِشِ وُيَشِ نَشٍيٍ نَ وْيّنيِ مّ، عٍ نَشَ عَ سُشُ. دَنشَنِيَتْييٍ شُن نَشَ مَسَ، هَن شّمّيٍ كْنتِ نَشَ وُلُ سُولِ حْندْن لِ.
\p 
\v 5 نَ كُيٍ عِبَ، يُوِقِ يَرٍرَتِيٍ، قٌرِيٍ، نُن سّرِيّ كَرَ مْشْيٍ نَشَ عٍ مَلَن دَرِ سَلَمُ،
\v 6 عَ نُن عَنَنِ سّرّشّدُبّ كُنتِفِ، نُن كَيَقَ، يَيَ، عَلٍسَندِرٍ، عَ نُن نَشٍيٍ بِرِن نَ سّرّشّدُبّ كُنتِفِ بْنسْي.
\v 7 عٍ نَشَ ثِيّرِ نُن يَيَ تِ عٍ تَفِ، عٍ نَشَ عٍ مَشْرِن، «وٌ نْشِ يِ رَيَلَندٍ دِ؟ وٌ عَ رَيَلَنشِ سَابُي مُندُن نَ؟»
\p 
\v 8 ثِيّرِ نَشَ عَ مَسٍن عٍ بّ مُشُ عَ رَيَلَنشِ عَلَ شَشِلِ سّنِيّنشِ نَن سَابُي رَ،
\v 9 «عِسِرَيِلَ قٌرِيٍ نُن كُنتِفِيٍ، وٌ بَرَ مُشُ مَشْرِن يِ نَمَتّ شَ قٍ قَنيِ سْتْي مَ، عَ يَلَنشِ كِ نَشّ.
\v 10 وٌ تَن نُن عِسِرَيِلَكَيٍ بِرِن شَ عَ كٌلٌن يِ شّمّ يَلَنشِ عِسَ نَسَرّتِكَ، عَلَ شَ مِشِ سُفَندِشِ، شِلِ سَابُي نَن نَ. وٌ عِسَ نَشَن بَنبَن وُرِ مَفَلَنبُشِ مَ، عَلَ نَشَن نَكٍلِ قَشّ مَ، عَ تَن نَن شِلِ يِ نَمَتّ رَيَلَنشِ.
\v 11 عِسَ مَنِيَشِ ‹فّمّ نَن نَ نَشَن تِدٍ فبٌ دَنفِ فّمّ بِرِن نَ، كْنْ وٌ تَن بَنشِتِيٍ بَرَ مّي نَ فّمّ رَ.›
\v 12 كِسِ مُ سْتْمَ ندٍندٍ رَ قٌ عَ تَن، بَرِ مَ شِلِ فبّتّ يٌ مُ نَ دُنِحَ، وٌن كِسِمَ نَشَن سَابُي رَ.»
\p 
\v 13 عٍ نَشَ كَابَ ثِيّرِ نُن يَيَ شَ لِمَنِيَ مَ، بَرِ مَ شَرَنتَرٍيٍ نَن نُ عٍ رَ. عٍ نَشَ عَ كٌلٌن عٍ نُ بَرَ بِرَ عِسَ قْشْ رَ عَ نُ نَ دُنِحَ مَ تّمُي نَشّ.
\v 14 كْنْ شّمّ تٌ نُ تِشِ عٍ سّيتِ مَ، عَ يَلَنشِ، عٍ مُ نْ سٍسٍ قَلَدٍ.
\v 15 عٍ نَشَ ثِيّرِ، يَيَ، نُن نَ شّمّ يَامَرِ عٍ شَ مِنِ يُوِقِ كِيتِسَيٍ يَ مَ. عٍ نُ قَ وْيّن عٍ بٌرٍ تَفِ.
\v 16 عٍ نَشَ عٍ بٌرٍ مَشْرِن، «وٌن شَ مُنسٍ رَبَ يِ مِشِيٍ رَ؟ دَرِ سَلَمُكَيٍ بِرِن بَرَ عَ كٌلٌن عٍ كَابَنَكٌ شُنفبٍ نَن نَبَشِ. وٌن قَن مُ نْمَ نَ مَتَندِدٍ.
\v 17 كْنْ عَلَكٌ يِ قٍ نَشَ يٍنسٍن يّ مِشِيٍ رَ، وٌن شَ عٍ رَتْن عَ شْرْشْي رَ، عٍ نَشَ وْيّن عِسَ شِلِ رَ سْنْن.»
\p 
\v 18 عٍ نَشَ ثِيّرِ، يَيَ، نُن نَ شّمّ شِلِ. عٍ نَشَ وْيّن عٍ بّ عَ شْرْشْي رَ، عَ عٍ نَشَ مَسٍنيِ يٌ تِ، عٍ نَشَ مِشِ يٌ شَرَن عِسَ شِلِ رَ سْنْن.
\v 19 ثِيّرِ نُن يَيَ نَشَ عٍ يَابِ، «وٌ عَ مَتٌ، عَ لَنمَ مُشُ شَ بِرَ وٌ تَن نَن قْشْ رَ بَ، كَ عَلَ؟
\v 20 مُشُ مُ نْمَ دُندُدٍ قٍ مَ مُشُ بَرَ نَشَن تٌ، مُشُ بَرَ نَشَن مّ.»
\v 21 عٍ مَن نَشَ شَاحّ عٍ مَ، كْنْ حَمَ بِرِن تٌ نُ عَلَ مَتْشْمَ قٍ مَ نَشَن بَرَ رَبَ، عٍ مُ نْ لَندٍ عَ مَ عَ لَنمَ عٍ شَ عٍ حَشَنكَتَ كِ نَشّ. عٍ نَشَ عٍ رَبّحِن.
\v 22 يِ شّمّ نَشَن نَيَلَنشِ، عَ شَ سِمَيَ نُ بَرَ دَنفِ حّ تٌنفٌ نَانِ رَ.
\s1 تٌفٌندِيَتْييٍ عَلَ مَشَندِقٍ
\p 
\v 23 عٍ تٌ عٍ بّحِن، ثِيّرِ نُن يَيَ نَشَ سِفَ عٍ بٌورٍيٍ يِرٍ. عٍ نَشَ قٍ بِرِن يَبَ عٍ بّ سّرّشّدُبّ كُنتِفِيٍ نُن قٌرِيٍ نَشَن قَلَ عٍ بّ.
\v 24 عٍ تٌ نَ مّ، عٍ بِرِن نَشَ عٍ شُي عِتٍ عَلَ مَ حَنِفٍ كٍرٍن قَرِ. عٍ نَشَ عَ مَشَندِ، «مَرِفِ، عِ تَن نَشَن كٌورٍ دَا، عَ نُن بْشِ، عَ نُن بَا، عَ نُن سٍ نَشَن بِرِن نَ دُنِحَ،
\v 25 عِ تَن نَن عَ قَلَ عَلَ شَشِلِ سّنِيّنشِ سَابُي رَ، عِ شَ كٌنيِ دَوُدَ دّ رَ، مُشُ بَبَ،
\b
\q1 ‹مُنقٍ رَ سِيٍ بْحّ تٍشِ قُقَقُ؟
\q1 مُنقٍ رَ حَمَيٍ مَتَندِ تِقٍ؟
\q1 
\v 26 دُنِحَ مَنفّيٍ بَرَ كٍلِ،
\q1 شُنمَتِيٍ بَرَ تِ مَرِفِ
\q1 نُن عَ شَ مِشِ سُفَندِشِ كَنكٍ.›»
\b
\p 
\v 27 «نْندِ نَ عَ رَ، هٍرٌدٍ، ثٌنسِ ثِلَتِ، شْحّيٍ، عَ نُن عِسِرَيِلَ بْنسْييٍ بَرَ تِ عِ شَ كٌنيِ سّنِيّنشِ عِسَ كَنكٍ، عِ نَشَن سُفَندِشِ،
\v 28 عَلَكٌ عٍ شَ قٍ بِرِن نَبَ عِ سِنفٍ نُ بَرَ نَتّ تٌنفٌ عَ نُ لَن نَشَن شَ رَبَ.
\v 29 يَكْسِ، مَرِفِ، عِ شَ عَ مَتٌ عٍ شَاحّشِ كِ نَشّ. سّنبّ قِ عِ شَ كٌنيِيٍ مَ، عَلَكٌ عٍ شَ نْ عِ شَ وْيّنيِ مَسٍندٍ لِمَنِيَ رَ.
\v 30 عِ بّلّشّ عِتَلَ، عَلَكٌ مِشِ شَ رَيَلَن، كَابَنَكٌييٍ نُن تْنشُمَيٍ شَ رَبَ عِ شَ كٌنيِ سّنِيّنشِ عِسَ شِلِ رَ.»
\p 
\v 31 عٍ تٌ فّ عَلَ مَشَندِدٍ، عٍ نُ مَلَنشِ دّننَشّ، نَ نَشَ سّرّن. عَلَ شَشِلِ سّنِيّنشِ نَشَ فٌرٌ عٍ بِرِن مَ. عٍ نَشَ سٌ عَلَ شَ وْيّنيِ مَسٍنقٍ لِمَنِيَ رَ.
\s1 تٌفٌندِيَتْييٍ شَ لَنيِ
\p 
\v 32 دَنشَنِيَتْي حَمَ بِرِن بْحّ مَ قٍ نَشَ لُ كٍرٍن. مِشِ يٌ مُ عَ قَلَمَ عَ كٍرٍن فبٍ نَن نَ سٍ ندٍ رَ، كْنْ سٍ بِرِن نَشَ قِندِ بِرِن فبٍ رَ.
\v 33 شّيرَيٍ نَشَ مَرِفِ عِسَ شَ مَرَكٍلِ مَسٍن مِشِيٍ بّ سّنبّ رَ. عَلَ نَشَ هِننّ عٍ رَ عَ قَنيِ رَ.
\v 34 سٍتَرٍ يٌ مُ نُ نَ عٍ يَ مَ، بَرِ مَ شّيٍ نُن بَنشِيٍ نُ نَ نَشٍيٍ بِرِن يِ رَ، عٍ نُ عٍ مَتِمَ نّ،
\v 35 عٍ نُ عَ سَرٍ دّنتّفّ شّيرَيٍ بّ. نٍيٍ نُ قَ عَ عِتَشُن كَنكَن هَيِ بّرّ مَ.
\p 
\v 36 مِشِ ندٍ نُ نَ نَشَن شِلِ يُسُقُ، لٍوِ دِ نَشَن بَرِشِ سِثِرِ. شّيرَيٍ نُ عَ شِلِ قَلَمَ نّ بَرَنَبَسِ، نَ نَن قَلَشِ «مِشِ رَلِمَنِيَ».
\v 37 عَ نَشَ شّ مَتِ نَشَن نُ نَ عَ يِ، عَ نَشَ قَ عَ كْبِرِ رَ، عَ عَ دّنتّفّ شّيرَيٍ بّ.
\c 5
\s1 عَنَنِيَسِ نُن سَقِرَ
\p 
\v 1 شّمّ ندٍ نَشَن شِلِ عَنَنِيَسِ، عَ نُن عَ شَ فِنّ سَقِرَ، نٍيٍ قَن نَشَ عٍ شَ شّ مَتِ.
\v 2 عَنَنِيَسِ نُن عَ شَ فِنّ نَشَ لَن عَ مَ عٍ شَ شّ سَرٍ ندٍ رَفَتَ عٍ يّتّ بّ. عَنَنِيَسِ نَشَ كْبِرِ دْنشْي شَنِن، عَ عَ دّنتّفّ شّيرَيٍ بّ.
\v 3 ثِيّرِ نَشَ عَ قَلَ عَ بّ، «عَنَنِيَسِ، مُنقٍ رَ سٍنتَنّ عِ مَدَشُشِ هَن عِ بَرَ وُلٍ قَلَ عَلَ شَشِلِ سّنِيّنشِ بّ يِ شّ سَرٍ ندٍ نْشُنقٍ رَ؟
\v 4 بٍينُن عِ شَ يِ شّ مَتِ، عِ فبٍ شَ مُ نُ نَ شّ رَ؟ عِ كْبِرِ نَشَن سْتْشِ، عِ فبٍ شَ مُ نُ نَ قَن نَ؟ مُنقٍ رَ عِ يِ قٍ مْولِ رَبَشِ؟ عِ مُ وُلٍ قَلَشِ مِشِيٍ شَ بّ، عِ وُلٍ قَلَشِ عَلَ نَن بّ.»
\p 
\v 5 عَنَنِيَسِ تٌ نَ وْيّنيِ مّ، عَ نَشَ بِرَ كٍرٍن نَ، عَ قَشَ. نَشٍيٍ بِرِن نَ قٍ مّ، عٍ نَشَ فَاشُ.
\v 6 سّفّتَلَيٍ تٌ كٍلِ، عٍ نَشَ عَ كَسَنفٍ، عٍ عَ شَنِن، عٍ سَ عَ رَفَتَ.
\p 
\v 7 وَشَتِ سَشَن تٌ دَنفِ، عَ شَ فِنّ نَشَ سٌ، عَ مُ نُ عَ كٌلٌن قٍ نَشَن نَبَشِ.
\v 8 ثِيّرِ نَشَ عَ قَلَ عَ بّ، «عَ قَلَ ﭑ بّ، شَ وٌ شّ مَتِشِ يِ شَسَبِ نَن نَ، وٌ نَشَن دّنتّفّشِ يِ كِ؟» عَ نَشَ عَ يَابِ، «عِيٌ، مُشُ عَ مَتِشِ يِ كْبِرِ نَن نَ.»
\v 9 عَوَ، ثِيّرِ نَشَ عَ قَلَ عَ بّ، «مُنقٍ رَ وٌ لَنشِ عَ مَ وٌ شَ عَلَ شَشِلِ مَدَشُ؟ نَشٍيٍ عِ شَ مْرِ رَفَتَشِ، عٍ تَن نَن تِشِ نَادّ رَ يِ كِ، عٍ عِ قَن شَنِنمَ يَ.»
\p 
\v 10 عَ نَشَ بِرَ شّيرَ بُن مَ كٍرٍن نَ، عَ قَشَ. سّفّتَلَيٍ تٌ سٌ، عٍ نَشَ عَ لِ عَ قَن بَرَ قَشَ. عٍ نَشَ عَ شَنِن، عٍ سَ عَ قَن نَفَتَ عَ شَ مْرِ قّ مَ.
\v 11 فَاشُي شُنفبٍ نَشَ دَنشَنِيَتْي حَمَ بِرِن سُشُ، عَ نُن نَشٍيٍ بِرِن يِ قٍ مّ.
\s1 تْنشُمَيٍ نُن كَابَنَكٌييٍ
\p 
\v 12 كَابَنَكٌ وُيَشِ نُن تْنشُمَيٍ نُ رَبَمَ حَمَ تَفِ شّيرَيٍ سَابُي رَ. تٌفٌندِيَتْي بِرِن نُ عٍ مَلَنمَ سُلٍمَنِ شَ بُنتُنيِ رَ.
\v 13 مِشِ فبّتّ يٌ مُ نُ سُو سَمَ سُنبُدٍ عٍ رَ، كْنْ مِشِيٍ نُ عٍ بِنيَمَ عَ قَنيِ رَ.
\v 14 نَشٍيٍ نُ دَنشَنِيَشِ مَرِفِ مَ، شّمّيٍ نُن فِنّيٍ، عٍ كْنتِ شُن نُ مَسَمَ تّمُي بِرِن.
\v 15 نَ قٍيٍ مَ، مِشِيٍ نُ قَمَ نّ قُرٍ مَيٍ رَ سَدٍ نُن دَفِيٍ مَ كِرَ شْن، عَلَكٌ ثِيّرِ نّ دَنفِمَ تّمُي نَشّ، عَ نِينِ شَ تِ عٍ مَ.
\v 16 حَمَ نُ كٍلِمَ دَرِ سَلَمُ رَبِلِنيِ، عٍ نُ قَ قُرٍ مَيٍ رَ نُن حِننّ قُرٍ كَنيِيٍ. عٍ بِرِن نَشَ يَلَن.
\s1 شّيرَيٍ مَكَنكَنقٍ
\p 
\v 17 نَ تّمُي سّرّشّدُبّ كُنتِفِ، عَ نُن نَشٍيٍ نُ نَ عَ قْشْ رَ، نَشٍيٍ قِندِشِ سَدُ سٍنِيٍ رَ، عٍ نَشَ نَتّ تٌنفٌ تْونّ مَ.
\v 18 عٍ نَشَ شّيرَيٍ سُشُ، عٍ عٍ وٌلِ فٍيلِ.
\v 19 كْنْ مَرِفِ شَ مَلٍكّ نَشَ قَ كْي رَ، عَ نَشَ فٍيلِ نَادّ رَبِ، عَ قَ عٍ رَ مِنِ. عَ نَشَ عَ قَلَ عٍ بّ،
\v 20 «وٌ سِفَ، وٌ سَ تِ هْرْ مْبَنشِ كُي، وٌ عَلَ شَ كِرَ نّينّ شَ قٍ بِرِن تَفِ رَبَ حَمَ بّ.»
\v 21 عٍ تٌ نَ مّ، عٍ نَشَ سٌ هْرْ مْبَنشِ كُي سُبَشّ مَ، عٍ كَوَندِ تِ قْلْ.
\p سّرّشّدُبّ كُنتِفِ نُن نَشٍيٍ نُ نَ عَ قْشْ رَ، عٍ تٌ قَ، عٍ نَشَ يُوِقِ كِيتِسَيٍ نُن عِسِرَيِلَ قٌرِ بِرِن مَلَن. عٍ نَشَ مِشِيٍ رَ سِفَ شّيرَيٍ تٌنفٌدٍ فٍيلِ كُي.
\v 22 سْرِيٍ تٌ سِفَ، عٍ مُ عٍ لِ فٍيلِ كُي. عٍ نَشَ فبِلٍن، عٍ سَ دّنتّفّ سَ.
\v 23 عٍ نَشّ، «مُشُ بَرَ فٍيلِ لِ عَ بَلَنشِ عَ قَنيِ رَ، فٍيلِ كَنتَمَيٍ تِشِ نَادّ رَ، كْنْ مُشُ تٌ عَ رَبِ، مُشُ مُ مِشِ يٌ لِشِ عَ كُي.»
\p 
\v 24 هْرْ مْبَنشِ سْورِيٍ شَ مَنفّ نُن سّرّشّدُبّ كُنتِفِيٍ تٌ نَ قٍ مّ، عٍ دّ نَشَ عِشَرَ. عٍ نُ قَ عٍ بٌرٍ مَشْرِن، «مُنقٍ يِ رَ؟»
\v 25 مِشِ ندٍ نَشَ قَ عَ قَلَ عٍ بّ، «وٌ قَ عَ مَتٌ، وٌ شّمّ نَشٍيٍ سَ فٍيلِ، عٍ نَ هْرْ مْبَنشِ كُي عٍ مِشِيٍ شَرَنقٍ.»
\v 26 عَوَ، سْورِ شُنمَتِ نُن عَ شَ سْورِيٍ نَشَ سِفَ، عٍ سَ قَ شّيرَيٍ رَ. كْنْ عٍ مُ عٍ سّنبّ رَ مِنِ عٍ مَ، بَرِ مَ عٍ نُ فَاشُشِ حَمَ قَ عٍ مَفْنْقٍ فّمّ رَ.
\p 
\v 27 عٍ تٌ بَرَ عٍ شَنِن يُوِقِ كِيتِسَيٍ يِرٍ، سّرّشّدُبّ كُنتِفِ نَشَ عٍ مَشْرِن،
\v 28 «مُشُ بَرَ وٌ رَتْن عَ شْرْشْي رَ، وٌ نَشَ شَرَنيِ رَبَ يِ شّمّ شِلِ رَ، كْنْ وٌ بَرَ وٌ شَ شَرَنيِ رَلَنتَن دَرِ سَلَمُ بِرِن نَ. وٌ وَ مَ عَ شَ قَشّ سَقٍ مُشُ تَن نَن شُن!»
\v 29 ثِيّرِ نُن شّيرَيٍ نَشَ عٍ يَابِ، «عَ لَنمَ مُشُ شَ عَلَ شُي نَن نَبَتُ دَنفِقٍ مِشِيٍ شُي رَ.
\v 30 وٌن بَبَيٍ مَرِفِ عَلَ بَرَ عِسَ رَكٍلِ، وٌ نَشَن قَشَ، وٌ نَشَن بَنبَن وُرِ مَ.
\v 31 عَلَ بَرَ عَ رَتٍ عَ يِرٍقَنيِ مَ عَ شَ قِندِ مَنفّ نُن مَرَكِسِمَ رَ، عَلَكٌ عِسِرَيِلَ شَ نْ تُوبِدٍ، عٍ شَ يُنُبِ شَ شَقَرِ.
\v 32 مُشُ نُن عَلَ شَشِلِ سّنِيّنشِ نَ يِ قٍ سٍيدٍيٍ رَ. عَلَ شَشِلِ سّنِيّنشِ قِمَ مِشِ نَن مَ، نَشَن نَ عَ شُي رَبَتُ.»
\p 
\v 33 عٍ تٌ يِ مَسٍنيِ مّ، عٍ نَشَ شْنْ هَن عٍ نَشَ وَ شّيرَيٍ قَشَقٍ.
\v 34 كْنْ قَرِ سّنِ ندٍ نَشَن شِلِ فَمَلِيّلِ، سّرِيّ كَرَ مْشْ كُنتِفِ نَشَن نُ رَقَن حَمَ بِرِن مَ، نَ نَشَ كٍلِ يُوِقِ كِيتِسَيٍ تَفِ. عَ نَشَ يَامَرِ قِ عٍ شَ شّيرَيٍ رَ مِنِ سِندٍن.
\v 35 عَوَ، عَ نَشَ عَ قَلَ كِيتِسَيٍ بّ، «عِسِرَيِلَكَيٍ، وٌ مّينِ قٍ مَ وٌ نَشَن نَبَمَ يِ مِشِيٍ رَ.
\v 36 وَشَتِ دَنفِشِ شّمّ ندٍ نَشَن شِلِ تُدَ سِ نَشَ عَ يّتّ عِفبٌ. مِشِ كّمّ نَانِ نَن نُ بِرَشِ عَ قْشْ رَ، كْنْ عَ تٌ قَشَ عٍ بِرِن نَشَ يٍنسٍن يّ. عَ شَ قٍ مُ قِندِ قٍقٍ رَ.»
\p 
\v 37 «نَ تٌ دَنفِ، يُدَ سِ فَلِلٍكَ نَشَ مِنِ شِلِ سّبّ تّمُي. عَ نَشَ مِشِ وُيَشِ بّندُن عَ مَ، كْنْ عَ قَن نَشَ قَشَ، عَ قْشِرَبِرّيٍ بِرِن نَشَ يٍنسٍن يّ.
\v 38 يَكْسِ ﭑ عَ قَلَمَ وٌ بّ، وٌ نَشَ قٍقٍ رَبَ يِ مِشِيٍ رَ. وٌ فبِلٍن عٍ قْشْ رَ. شَ يِ قٍ بِرِن قَتَنشِ مِشِيٍ نَن نَ، عَ مُ سْونّيَمَ.
\v 39 كْنْ، شَ عَ قَتَنشِ عَلَ نَن نَ، وٌ مُ نْمَ عَ شُن نَكَنَدٍ. وٌ وٌ حّرّ كِ مَتٌ عَ قَنيِ رَ، وٌ نُن عَلَ نَشَ قَ فٍرٍ.»
\p 
\v 40 عٍ تٌ لَن قٍ كٍرٍن مَ، عٍ نَشَ شّيرَيٍ شِلِ، عٍ عٍ بْنبْ. عٍ نَشَ عٍ رَتْن وْيّنقٍ رَ عِسَ شِلِ رَ، عٍ قَ عٍ رَبّحِن.
\p 
\v 41 شّيرَيٍ تٌ مِنِ يُوِقِ كِيتِسَيٍ تَفِ، عٍ نَشَ حّلّشِن بَرِ مَ عَلَ عٍ تَن نَن سُفَندِشِ، عٍ شَ تْورْ عِسَ شِلِ شَ قٍ رَ.
\v 42 لْشْ يٌ لْشْ، عٍ نُ كَوَندِ تِمَ هْرْ مْبَنشِ كُي، عٍ مَن مِشِيٍ شَرَنمَ عٍ شْنيِ. عٍ نُ عِسَ، عَلَ شَ مِشِ سُفَندِشِ شَ شِبَارُ قَنيِ مَسٍنمَ نّ تّمُي بِرِن.
\c 6
\s1 شّيرَ مَلِمَ سٌلٌقٍرٍ
\p 
\v 1 نَ تّمُي، عِسَ قْشِرَبِرّيٍ كْنتِ شُن تٌ نُ مَسَمَ، يُوِقِيٍ نَشٍيٍ فِرّكِ شُي قَلَمَ، عٍ نَشَ عٍ مَوَ يُوِقِيٍ شْن نَشٍيٍ عٍبُرُ شُي قَلَمَ، بَرِ مَ لْشْ يٌ لْشْ دٌنسٍ عِتَشُنمَ تّمُي نَشّ، عٍ نُ نّيمُمَ نّ كَاحّ فِنّيٍ مَ نَشٍيٍ فِرّكِ شُي قَلَمَ.
\v 2 شّيرَ قُ نُن قِرِنيِ نَشَ عِسَ قْشِرَبِرّيٍ مَلَن، عٍ نَشَ عَ قَلَ عٍ بّ، «عَ مُ لَن مُشُ شَ عَلَ شَ مَسٍنيِ كَوَندِقٍ رَبٌلٌ دٌنسٍ عِتَشُن قٍ رَ.
\v 3 نَ نَن عَ رَ، ﭑ نفَشَكٍرٍنيِيٍ، وٌ شّمّ سٌلٌقٍرٍ سُفَندِ وٌ يَ مَ، مِشِ بِنيٍيٍ، شَشِلِمَيَ نُن عَلَ شَشِلِ سّنِيّنشِ نَ نَشٍيٍ بّ. مُشُ شَ يِ دٌنسٍ عِتَشُنقٍ سٌ عٍ يِ رَ،
\v 4 عَلَكٌ مُشُ تَن شَ نُ لُ عَلَ مَشَندِ رَ نُن عَلَ شُي كَوَندِ رَ.»
\p 
\v 5 نَ مَسٍنيِ نَشَ رَقَن بِرِن مَ. عٍ نَشَ عٍتِيّن سُفَندِ، شّمّ نَشَن شَ دَنشَنِيَ نُ فبٌ، عَلَ شَشِلِ سّنِيّنشِ مَن نُ فٌرٌشِ نَشَن مَ. عٍ مَن نَشَ قِلِثُ، ثِرٌكٌرُ، نِكَنٌرٌ، تِمٌن، نُن ثَرَ مٍنَسِ سُفَندِ، عَ نُن نِكٌلَسِ عَنتِيْكِكَ نَشَن سٌشِ يُوِقِيٍ شَ دِينّ يَ مَ.
\v 6 عٍ نَشَ عٍ دّنتّفّ شّيرَيٍ بّ. شّيرَيٍ نَشَ عٍ بّلّشّ سَ عٍ شُنيِيٍ مَ، عٍ نَشَ عَلَ مَشَندِ عٍ بّ.
\p 
\v 7 عَلَ شَ مَسٍنيِ نَشَ يٍنسٍن يّ. عِسَ قْشِرَبِرّيٍ شُن نُ مَسَمَ عَ فبٍفبٍ رَ دَرِ سَلَمُ. سّرّشّدُبّ وُيَشِ قَن نُ دَنشَنِيَقٍ.
\s1 عٍتِيّن سُشُقٍ
\p 
\v 8 عَلَ نَشَ عَ شَ هِننّ نُن سّنبّ قِ عٍتِيّن مَ. عَ نُ تْنشُمَيٍ نُن كَابَنَكٌ شُنفبٍيٍ رَبَمَ حَمَ تَفِ.
\v 9 سِرٍنِكَيٍ نُن عَلٍسَندِرٍكَ نَشٍيٍ نُ سَلِمَ سَلِدٍ كُي، نَشَن شِلِ «شْرّيَ مِشِ شَ سَلِدٍ»، عَ نُن يُوِقِيٍ نَشٍيٍ كٍلِشِ سِلِسِ نُن عَسِ، عٍ نَشَ سْنشْ عٍتِيّن مَ.
\v 10 كْنْ عٍ مُ نْ عٍتِيّن شَ وْيّنيِ رَ، بَرِ مَ عَلَ شَشِلِ سّنِيّنشِ نَن نُ شَشِلِمَيَ قِمَ عَ مَ.
\p 
\v 11 عَوَ، عٍ نَشَ شّمّ ندٍيٍ سَرٍ قِ، عٍ شَ عَ قَلَ، «مُشُ بَرَ عَ شُي مّ عَ وْيّنيِ قَلَمَ نَشَن مُ دَشَ عَننَبِ مُنسَ نُن عَلَ مَبِرِ.»
\v 12 عٍ نَشَ حَمَ، قٌرِيٍ، نُن سّرِيّ كَرَ مْشْيٍ كُي عِسٌ. عٍ نَشَ بَفَن عَ مَ، عٍ عَ سُشُ، عٍ عَ شَنِن يُوِقِ كِيتِسَيٍ يِرٍ.
\v 13 عٍ نَشَ تْوحّفّلَيٍ رَ مِنِ، نَشٍيٍ عَ قَلَ، «يِ شّمّ مُ بَمَ وْيّنيِ حَاشِيٍ قَلَقٍ هْرْ مْبَنشِ نُن عَلَ شَ سّرِيّ شَ قٍ رَ.
\v 14 مُشُ بَرَ عَ شُي مّ، عَ عَ قَلَمَ عِسَ نَسَرّتِكَ قَمَ يِ هْرْ مْبَنشِ كَنَدٍ، عَ مَن نَامُنيِيٍ مَسَرَ مَ عَننَبِ مُنسَ نَشٍيٍ قِشِ وٌن مَ.»
\v 15 يُوِقِ كِيتِسَيٍ بِرِن نَشَ عٍ يَ بَنبَن عٍتِيّن نَ، عَ يَتَفِ نَشَ لُ عٍ بّ عَلْ مَلٍكّ.
\c 7
\s1 عٍتِيّن شَ مَسٍنيِ
\p 
\v 1 سّرّشّدُبّ كُنتِفِ نَشَ عٍتِيّن مَشْرِن، «نَشَن قَلَشِ عِ شُن مَ، نْندِ نَ عَ رَ؟»
\v 2 عٍتِيّن نَشَ عٍ يَابِ، «ﭑ نفَشَكٍرٍنيِيٍ نُن ﭑ بَبَيٍ، وٌ وٌ تُلِ مَتِ ﭑ نَ. عَلَ دَرِيّ كَنيِ مِنِ نّ وٌن بَبَ عِبُرَهِمَ مَ عَ نُ نَ مٍسٌثٌتَمِيَ بْشِ مَ تّمُي نَشّ، بٍينُن عَ شَ سَبَتِ شَرَنِ.
\v 3 عَلَ نَشَ عَ قَلَ عَ بّ، ‹كٍلِ عِ شَ بْشِ نُن عِ شَبِلّ شُن، سِفَ بْشِ مَ ﭑ دّننَشّ مَسٍنمَ عِ بّ.›
\v 4 عَوَ، عَ نَشَ مِنِ كَلِدِ بْشِ رَ، عَ سَ سَبَتِ شَرَنِ. مّننِ، عَ بَبَ قَشَ شَنبِ، عَلَ نَشَ عَ رَدَنفِ يِ بْشِ مَ وٌ سَبَتِشِ دّننَشّ يِ كِ تٌ.
\v 5 عَ مُ لِنفِرَ يٌ قِ عَ مَ يِ بْشِ كُي هَلِ سَنتِدٍ. كْنْ عَ نَشَ لَايِدِ تٌنفٌ عَ بّ، عَ قَمَ يِ بْشِ قِدٍ عَ تَن نُن عَ بْنسْي نَن مَ، هَلِ عَ قَشَ شَنبِ. نَ وَشَتِ دِ يٌ مُ نُ نَ عَ بّ سِندٍن.»
\p 
\v 6 «عَلَ نَشَ عَ قَلَ عَ بّ، ‹عِ بْنسْي سَبَتِمَ بْشِ فبّتّ نَن مَ. مّننِ عٍ قِندِ مَ نّ كٌنيِيٍ رَ. عٍ عٍ حَشَنكَتَ حّ كّمّ نَانِ بُن.›
\v 7 عَلَ مَن نَشَ عَ قَلَ، ‹ﭑ قَمَ نَ سِ مَكِيتِدٍ نَشَن عٍ رَ سٌمَ كٌنيِيَ كُي. نَ دَنفِ شَنبِ، عٍ كٍلِمَ نّ نَا، عٍ قَ ﭑ بَتُ بٍ.›»
\p 
\v 8 «عَوَ، عَلَ نَشَ سُننَ سَاتّ قِ عِبُرَهِمَ مَ. عِبُرَهِمَ تٌ عِسِيَفَ بَرِ، عَ نَشَ عَ سُننَ عَ شِ سٌلٌمَسَشَن ندٍ مَ. عِسِيَفَ تٌ يَشُبَ بَرِ، عَ نَشَ عَ قَن سُننَ. يَشُبَ قَن نَشَ وٌن بٍنبَ قُ نُن قِرِنيِيٍ سُننَ.»
\p 
\v 9 «وٌن بٍنبَيٍ نَشَ يُسُقُ تْونّ، عٍ نَشَ عَ مَتِ، عَ نَشَ قِندِ كٌنيِ رَ مِسِرَ بْشِ مَ.
\v 10 كْنْ عَلَ نَشَ لُ عَ قْشْ رَ. عَ نَشَ عَ رَ مِنِ عَ شَ كْنتْقِلِ بِرِن كُي. عَ نَشَ هِننّ نُن شَشِلِمَيَ قِ عَ مَ، عَلَكٌ عَ شَ رَقَن مِسِرَ مَنفّ مَ، نَشَن عَ قِندِ مِسِرَ فٌمِنَ نُن عَ شَ بَنشِ بِرِن شُنمَتِ رَ.»
\p 
\v 11 «كَامّ شُنفبٍ نَشَ سٌ مِسِرَ بْشِ مَ عَ نُن كَنَان بْشِ. وٌن بَبَيٍ مُ نُ بَلٌي سْتْمَ، تْورّ نَشَ فبٌ.
\v 12 يَشُبَ نَشَ عَ مّ عَ مّنفِ نَ مِسِرَ بْشِ مَ. عَ نَشَ وٌن بَبَيٍ شّي نَا عَ سِنفٍ.
\v 13 عٍ شَ سِفّ قِرِن ندٍ، يُسُقُ نَشَ عَ يّتّ مَسٍن عَ قَقَشَكٍرٍنيِيٍ بّ، مِسِرَ مَنفّ قَن نَشَ يُسُقُ شَبِلّ رَكٌلٌن.
\v 14 عَوَ، يُسُقُ نَشَ عٍ شّي عَ بَبَ يَشُبَ تٌنفٌدٍ نُن عَ شَ دٍنبَيَ بِرِن. عٍ كْنتِ نُ سِفَشِ هَن مِشِ تٌنفٌ سٌلٌقٍرٍ عَ نُن سُولِ.
\v 15 يَشُبَ نَشَ فٌرٌ مِسِرَ، عَ قَشَ دّننَشّ عَ نُن وٌن بَبَيٍ.
\v 16 عٍ قُرٍيٍ نَشَ رَفبِلٍن سِكٍمِ، عٍ عٍ رَفَتَ فَبُرِ نَن كُي، عِبُرَهِمَ نَشَن سَرَ كْبِرِ رَ شَمٌرِ شَ دِيٍ مَ.»
\p 
\v 17 «عَلَ شَ لَايِدِ رَكَمَلِ وَشَتِ تٌ مَكْرّ، لَايِدِ نَشَن تٌنفٌشِ عِبُرَهِمَ بّ، وٌن مَ حَمَ شُن نَشَ مَسَ مِسِرَ بْشِ مَ.
\v 18 كْنْ نَ شَنبِ مَنفّ فبّتّ نَشَ تِ نَشَن مُ نُ يُسُقُ شَ قٍ كٌلٌن.
\v 19 نَ مَنفّ نَشَ وٌن مَ حَمَ يَنقَ. عَ نَشَ وٌن بٍنبَيٍ حَشَنكَتَ، هَن عَ نَشَ عٍ يَامَرِ عٍ شَ عٍ شَ دِيْرّيٍ وْلّ، عَلَكٌ عٍ شَ قَشَ.
\v 20 نَ تّمُي عَننَبِ مُنسَ نَشَ بَرِ، عَلَ هِننّ نَشَن نَ. كِكٍ سَشَن عَ رَبَلٌقٍ عَ بَبَ شَ بَنشِ كُي.
\v 21 نَ شَنبِ عَ نَشَ عَ بّلّشّ بَ عَ مَ. مِسِرَ مَنفّ شَ دِ فِنّ قَ عَ تٌنفٌ، عَ نَشَ عَ رَ مْ عَلْ عَ شَ دِ.
\v 22 عَننَبِ مُنسَ نَشَ كٌلٌن سْتْ مِسِرَ شَ قٍ بِرِن مَ. عَ وْيّن كِ نُن عَ حّرّ كِ نَشَ سّنبّ سْتْ.»
\p 
\v 23 «عَ تٌ حّ تٌنفٌ نَانِ سْتْ، عَ نَشَ وَ عَ نفَشَكٍرٍنيِيٍ كٌلٌنقٍ. عَ نَشَ سِفَ عَ بٌورٍ عِسِرَيِلَكَيٍ يِرٍ مَتٌدٍ.
\v 24 عَ تٌ مِسِرَكَ تٌ عَ قٍ حَاشِ نِيَقٍ عِسِرَيِلَكَ ندٍ رَ، عَننَبِ مُنسَ نَشَ عَ نفَشَكٍرٍنيِ شَ فٍرٍ سٌ، عَ نَشَ مِسِرَكَ قَشَ.
\v 25 عَ نَشَ عَ مَحْشُن عَ عَ نفَشَكٍرٍنيِيٍ عَ كٌلٌنمَ نّ عَلَ شْرّيَ قِمَ عٍ مَ عَ سَابُي نَن نَ، كْنْ عٍ مُ كٌلٌن سْتْ نَ مَ.
\v 26 نَ كُيٍ عِبَ، عَننَبِ مُنسَ نَشَ عِسِرَيِلَكَ قِرِن تٌ، عٍ نَ فٍرٍقٍ. عَ نَشَ كَتَ عٍ شَ لَن عٍ بٌرٍ مَ، عَ نَشَ عَ قَلَ عٍ بّ، ‹نفَشَكٍرٍنمَيٍ نَن نَ وٌ رَ. مُنقٍ رَ وٌ قٍ حَاشِ نِيَمَ وٌ بٌرٍ رَ؟›
\v 27 كْنْ نَشَن نُ قٍ حَاشِ رَبَقٍ عَ نفَشَكٍرٍنيِ رَ، عَ نَشَ عَننَبِ مُنسَ رَدِن يّ، عَ عَ قَلَ عَ بّ، ‹ندٍ عِ تِشِ مَنفّ نُن كِيتِسَ رَ مُشُ شُن مَ؟
\v 28 عِ وَشِ ﭑ قَشَقٍ نّ عَلْ عِ مِسِرَكَ قَشَشِ كِ نَشّ شٌرٌ؟›
\v 29 عَننَبِ مُنسَ تٌ نَ وْيّنيِ مّ، عَ نَشَ عَ فِ. عَ نَشَ سَبَتِ مَدِيَن بْشِ مَ، عَ نَشَ دِ قِرِن بَرِ مّننِ.»
\p 
\v 30 «حّ تٌنفٌ نَانِ دَنفِ شَنبِ، مَلٍكّ نَشَ مِنِ عَ مَ تّ شْورَ نَشَن نُ سَنسِ بِلِ فَنقٍ فبٍنفبٍرٍنيِ مَ، سِنَيِ فٍيَ قَرِ.
\v 31 عَننَبِ مُنسَ تٌ نَ قٍ تٌ، عَ نَشَ كَابَ. عَ تٌ عَ مَسٌ عَ رَ، عَ شَ عَ عِفبّ، عَ نَشَ مَرِفِ شُي مّ.
\v 32 ‹عِ بَبَيٍ مَرِفِ عَلَ نَن ﭑ نَ، عِبُرَهِمَ، عِسِيَفَ، نُن يَشُبَ مَرِفِ عَلَ.› عَننَبِ مُنسَ نَشَ سّرّن، عَ نَشَ فَاشُ عَ عِفبّقٍ مَ.
\v 33 مَرِفِ نَشَ عَ قَلَ عَ بّ، ‹سَنكِرِ بَ عِ سَنيِ، بَرِ مَ عِ تِشِ دّننَشّ، بْشِ سّنِيّنشِ نَ عَ رَ.
\v 34 ﭑ بَرَ ﭑ مَ حَمَ شَ تْورّ تٌ مِسِرَ، ﭑ بَرَ عٍ كُتُن شُي مّ. ﭑ بَرَ فٌرٌ ﭑ شَ شْرّيَ قِ عٍ مَ. يَكْسِ، ﭑ شَ عِ شّي مِسِرَ.›
\v 35 عَلَ عَننَبِ مُنسَ شّي نّ، عٍ عَ قَلَ نَشَن بّ، ‹ندٍ عِ تِشِ مَنفّ نُن كِيتِسَ رَ مُشُ شُن مَ.› مَلٍكّ نَشَن مِنِشِ عَ مَ تّ شْورَ عَ نَشَ عَ مَسٍن عَ بّ عَ شَ قِندِ مَنفّ نُن مَرَكِسِمَ رَ.»
\p 
\v 36 «عَننَبِ مُنسَ نَن عِسِرَيِلَكَيٍ رَ مِنِ مِسِرَ بْشِ رَ. حّ تٌنفٌ نَانِ بُن مَ، عَ نَشَ تْنشُمَيٍ نُن كَابَنَكٌييٍ رَبَ مِسِرَ، شُلُنيُمِ بَا، نُن فبٍنفبٍرٍنيِ مَ.
\v 37 عَننَبِ مُنسَ تَن نَشَ عَ قَلَ عِسِرَيِلَ بّ، ‹عَلَ نَمِحْنمّ رَ مِنِمَ وٌ نفَشَكٍرٍنيِيٍ نَن يَ مَ نَشَن لُمَ عَلْ ﭑ تَن.›
\v 38 وٌن بٍنبَيٍ حَمَ عٍ تٌ نُ مَلَنشِ فبٍنفبٍرٍنيِ مَ، مَلٍكّ نَشَ وْيّن عَننَبِ مُنسَ بّ سِنَيِ فٍيَ قَرِ. عَ سّرِيّ نَشَن مّشِ، عَ نَشَ نَ رَدَنفِ وٌن مَ.»
\p 
\v 39 «كْنْ وٌن بٍنبَيٍ مُ تِن عَ شَ يَامَرِ سُشُدٍ. عٍ نَشَ عَ مَتَندِ، عٍ عٍ بْحّ تِ مِسِرَ رَ.
\v 40 عٍ نَشَ عَ قَلَ هَرُنَ بّ، ‹عَلَيٍ يَءِلَن وٌن بّ، نَشٍيٍ حّرّ مَ وٌن يَ رَ، بَرِ مَ يِ مُنسَ نَشَن وٌن نَمِنِشِ مِسِرَ، وٌن مُ عَ كٌلٌن سٍ نَشَن عَ سْتْشِ.›
\v 41 عٍ نَشَ كُيٍ يَءِلَن نِنفٍ مِسَالِ رَ، عٍ قَ سّرّشّ بَ عَ بّ. عٍ نَشَ حّلّشِن نَ رَ، عٍ نَشَن يَءِلَنشِ عٍ بّلّشّيٍ رَ.»
\p 
\v 42 «عَوَ، عَلَ نَشَ عَ كٌبٍ سٌ عٍ رَ، عَ نَشَ عٍ رَبٌلٌ، عٍ شَ تُنبُييٍ بَتُ، عَلْ عَ سّبّشِ نَمِحْنمّ شَ كِتَابُي كُي كِ نَشّ.
\q1 ‹عِسِرَيِلَ بْنسْي،
\q1 وٌ سّرّشّيٍ بَ ﭑ تَن نَن بّ
\q1 حّ تٌنفٌ نَانِ بُن مَ فبٍنفبٍرٍنيِ مَ؟
\q1 
\v 43 وٌ بَرَ مْلْكْ كُيٍ بَتُ،
\q1 وٌ بَرَ رٍ مٍقَن تُنبُي كُيٍ بَتُ،
\q1 وٌ كُيٍ نَشٍيٍ يَءِلَنشِ وٌ بّلّشّ رَ.
\q1 نَ نَن عَ تٌشِ ﭑ قَن وٌ شَنِنمَ بَبِلْن شَنبِ رَ.›»
\p 
\v 44 «عَلَ شَ هْرْ مْلِنفِرَ، عَ شَ سٍيدٍحْشْيَ سّبّلِ نَ دّننَشّ، نَ نُ نَ وٌن بٍنبَيٍ تَفِ فبٍنفبٍرٍنيِ مَ. عَلَ نُ بَرَ عَ مِسَالِ مَسٍن عَننَبِ مُنسَ بّ، عَ نَشَ عَ يَامَرِ عَ شَ عَ يَءِلَن نَ كِ.
\v 45 وٌن بٍنبَيٍ تٌ هْرْ مْلِنفِرَ سْتْ، عٍ نَشَ عَ شَنِن بْشِ مَ عَلَ سِ فبّتّيٍ كٍرِ دّننَشّ، يٌسُوٍ شَ يَامَرِ بُن مَ. عَ نَشَ لُ نَا هَن دَوُدَ شَ وَشَتِ.»
\p 
\v 46 «دَوُدَ نَشَن نَقَنشِ عَلَ مَ، نَ نَشَ عَ مَشْرِن عَ شَ لِنفِرَ تِ عَ تَن يَشُبَ مَرِفِ عَلَ بّ.
\v 47 كْنْ سُلٍمَنِ نَن قَ نَ لِنفِرَ تِ عَلَ بّ.
\v 48 كْنْ عَلَ شِلِ شُنفبٍ كَنيِ مُ سَبَتِمَ عَدَ مَ شَ بَنشِ تِشِ كُي. نَمِحْنمّ نَ نَن مَسٍنشِ،
\q1 
\v 49 ‹وٌ مَرِفِ نَشّ،
\q1 كٌورٍ، ﭑ مَ كِبَنيِ،
\q1 بْشِ، ﭑ سَنتِدٍ.
\q1 وٌ بَنشِ مُندُن تِمَ ﭑ بّ؟
\q1 وٌ يِرٍ مُندُن قِندِ مَ ﭑ مَ مَلَبُدٍ رَ؟
\q1 
\v 50 ﭑ تَن شَ مُ نَ بِرِن يَءِلَنشِ؟›»
\p 
\v 51 «وٌ شَشِلِ نُن وٌ تُلِ شْرْشْ، وٌ سٌندٌنيِ مُ قَن. وٌ عَلَ شَشِلِ سّنِيّنشِ مَتَندِ مَ تّمُي بِرِن عَلْ وٌ بٍنبَيٍ عَ رَبَ كِ نَشّ.
\v 52 وٌ بٍنبَيٍ نَمِحْنمّيٍ بِرِن حَشَنكَتَ نّ. عٍ نَمِحْنمّيٍ قَشَ نّ، نَشٍيٍ نُ عَلَ شَ تِنشِنتْي شَ قَقٍ قَلَمَ. يَكْسِ وٌ بَرَ نَ قَن قَشَ.
\v 53 وٌ تَن نَشٍيٍ بَرَ عَلَ شَ سّرِيّ سْتْ مَلٍكّيٍ سَابُي رَ، وٌ مُ عَ رَبَتُشِ!»
\s1 عٍتِيّن شَ قَشّ
\p 
\v 54 عٍ تٌ يِ مَسٍنيِ مّ، عٍ نَشَ شْنْ هَن عٍ نُ عٍ حِنيِيٍ رَشِن.
\v 55 كْنْ عَلَ شَشِلِ سّنِيّنشِ نَشَ فٌرٌ عٍتِيّن مَ. عٍتِيّن تٌ عَ يَ بَنبَن كٌورٍ مَ، عَ نَشَ عَلَ شَ دَرِيّ تٌ، عَ مَن نَشَ عِسَ تٌ عَ تِشِ عَلَ يِرٍقَنيِ مَ.
\v 56 عَ نَشَ عَ مَسٍن، «ﭑ بَرَ كٌورٍ رَبِشِ تٌ، عَدَ مَ شَ دِ تِشِ عَلَ يِرٍقَنيِ مَ.»
\v 57 حَمَ نَشَ سْنشْي رَتٍ، عٍ نَشَ عٍ تُلِ دّ سّ. عٍ بِرِن نَشَ بَفَن عَ مَ.
\v 58 عٍ نَشَ مِنِ عَ بُبُ رَ سِفَقٍ رَ تَا قَرِ مَ، عٍ عَ مَفْنْ هَن عَ نَشَ قَشَ. سٍيدٍيٍ نَشَ عٍ شَ دٌنمَيٍ سَ سّفّتَلَ ندٍ سَن مَ، نَشَن شِلِ سْلُ.
\v 59 عٍ نُ نَ عَ مَفْنْقٍ تّمُي نَشّ، عٍتِيّن نَشَ عَلَ مَشَندِ، «ﭑ مَرِفِ عِسَ، ﭑ نِي رَ سّنّ.»
\v 60 نَ شَنبِ عَ نَشَ عَ شِنبِ سِن، عَ نَشَ عَ شُي عِتٍ، «ﭑ مَرِفِ، عِ نَشَ عٍ سُشُ يِ يُنُبِ مَ!» عَ فّ نَ قَلَدٍ تَن مُ عَ رَ، عَ نَشَ تَا مَسَرَ. سْلُ قَن نُ نَ عٍتِيّن قَشَقٍ كُي.
\c 8
\s1 دَنشَنِيَتْييٍ شَ تْورّ
\p 
\v 1 نَ لْشْي، حَشَنكَتّ شُنفبٍ نَشَ دَرِ سَلَمُ دَنشَنِيَتْي حَمَ سُشُ. عٍ بِرِن نَشَ يٍنسٍن سَمَرِ نُن يُدَيَ بْشِ مَ قٌ شّيرَيٍ، نٍيٍ نَن فبَنسَن لُ نَا.
\v 2 شّمّ تِنشِنشِيٍ نَشَ عٍتِيّن نَفَتَ. عٍ نَشَ وَ عَ شَ قَشّ مَ.
\v 3 كْنْ سْلُ تَن نَشَ دَنشَنِيَتْي حَمَ تْورْ. عَ نُ سٌمَ بَنشِيٍ كُي، عَ نُ دَنشَنِيَتْي شّمّيٍ نُن فِنّيٍ رَ مِنِ، عَ نُ قَ عٍ سَ فٍيلِ.
\v 4 دَنشَنِيَتْي تٌ يٍنسٍن يّ، عٍ نَشَ شِبَارُ قَنيِ كَوَندِ تِ يِرٍ بِرِن.
\s1 شِبَارُ قَنيِ كَوَندِقٍ سَمَرِ
\p 
\v 5 قِلِثُ تٌ فٌرٌ سَمَرِ تَا ندٍ كُي، عَ نَشَ عَلَ شَ مِشِ سُفَندِشِ شَ قٍ مَسٍن نَاكَيٍ بّ.
\v 6 حَمَ تٌ قِلِثُ شَ كَابَنَكٌييٍ تٌ، عٍ نَشَ عٍ تُلِ مَتِ عَ رَ عَ قَنيِ رَ.
\v 7 حِننّيٍ نَشَ فبِلٍن قُرٍ مَيٍ قْشْ رَ، عٍ نُ قَ فبٍلٍفبٍلٍ. مَبّنيِ نُن نَمَتّ وُيَشِ نَشَ يَلَن.
\v 8 نَاكَيٍ نَشَ سّيوَ عَ قَنيِ رَ.
\p 
\v 9 شّمّ ندٍ نُ نَ نَ تَا كُي نَشَن شِلِ سِمْن. عَ نُ دُورٍيَ رَبَمَ نَشَن سَمَرِكَيٍ بِرِن نَكَابَمَ، عَ نُ قَ عَ يّتّ عِفبٌ.
\v 10 عٍ بِرِن، دِ مّدِيٍ نُن قٌرِيٍ، عَ شُي رَ مّشِ عَ قَنيِ رَ. عٍ نُ عَ قَلَ، «يِ شّمّ عَلَ سّنبّ نَ عَ رَ، وٌن نَشَن شِلِ قَلَمَ سّنبّ شُنفبٍ.»
\v 11 عٍ نُ بَرَ بِرَ عَ قْشْ رَ كَبِ عَ شْننَكُيٍ بَرِ مَ عَ نُ عٍ رَكَابَمَ عَ شَ دُورٍيَ رَ.
\v 12 كْنْ عٍ تٌ لَ قِلِثُ رَ، نَشَن عَلَ شَ مَنفّيَ نِينِ نُن عِسَ عَلَ شَ مِشِ سُفَندِشِ شَ شِبَارُ قَنيِ كَوَندِ رَبَمَ، شّمّيٍ نُن فِنّيٍ نَشَ عٍ شُنشَ يٍ شْورَ.
\v 13 سِمْن يَتِ نَشَ دَنشَنِيَ، عَ قَن نَشَ عَ شُنشَ يٍ شْورَ. عَ نَشَ بِرَ قِلِثُ قْشْ رَ. عَ نَشَ كَابَ عَ شَ تْنشُمَيٍ نُن كَابَنَكٌ شُنفبٍيٍ مَ.
\p 
\v 14 شّيرَيٍ، نَشٍيٍ نُ نَ دَرِ سَلَمُ، عٍ تٌ عَ مّ سَمَرِكَيٍ بَرَ تِن عَلَ شَ مَسٍنيِ رَ، عٍ نَشَ ثِيّرِ نُن يَيَ شّي نَا.
\v 15 عٍ تٌ سٌ نَا، عٍ نَشَ عَلَ مَشَندِ عَلَكٌ سَمَرِكَيٍ شَ عَلَ شَشِلِ سّنِيّنشِ سْتْ،
\v 16 بَرِ مَ عَلَ شَشِلِ سّنِيّنشِ مُ نُ فٌرٌشِ مِشِ يٌ مَ عٍ يَ مَ سِندٍن. عٍ نُ شُنشَشِ يٍ نَن فبَنسَن شْورَ عِسَ شِلِ شَ قٍ رَ.
\v 17 عَوَ، ثِيّرِ نُن يَيَ نَشَ عٍ بّلّشّ سَ عٍ مَ، عٍ نَشَ عَلَ شَشِلِ سّنِيّنشِ سْتْ.
\p 
\v 18 سِمْن تٌ عَ تٌ عَلَ شَشِلِ سّنِيّنشِ نُ سْتْمَ شّيرَيٍ بّلّشّيٍ نَن سَابُي رَ، عَ نَشَ كْبِرِ مَسٍن عٍ بّ، عَ قَ عَ قَلَ،
\v 19 «وٌ يِ سّنبّ قِ ﭑ قَن مَ، عَلَكٌ ﭑ نَ ﭑ بّلّشّيٍ سَ نَشَن مَ، عَ شَ عَلَ شَشِلِ سّنِيّنشِ سْتْ.»
\v 20 ثِيّرِ نَشَ عَ يَابِ، «عِ تَن نُن عِ شَ كْبِرِ شُن شَ رَكَنَ، بَرِ مَ عِ عَ مَحْشُنشِ نّ عَلَ شَ كِ سْتْمَ كْبِرِ نَن نَ.
\v 21 عِ فبٍ يٌ مُ نَ يِ قٍ يَ مَ، بَرِ مَ عِ سٌندٌنيِ مُ قِيشّشِ عَلَ بّ.
\v 22 فبِلٍن يِ قٍ حَاشِ قْشْ رَ. عِ مَن شَ مَرِفِ مَشَندِ عَلَكٌ عَ شَ دِحّ عِ مَ عِ شَ يِ مَحْشُنيِ شَ قٍ رَ، شَ عَ سَ تِنمَ.
\v 23 ﭑ عَ تٌشِ نّ يِ كِ، عِ نَ قٍ حَاشِ فبٍفبٍ كُي. عِ بَرَ قِندِ سٍنتَنّ شَ كٌنيِ رَ.»
\p 
\v 24 سِمْن نَشَ عَ يَابِ، «وٌ يّتّ شَ مَرِفِ مَشَندِ ﭑ بّ عَلَكٌ وٌ قٍ نَشٍيٍ بِرِن قَلَشِ عَ نَشَ ﭑ لِ.»
\v 25 عٍ تٌ فّ سٍيدٍحْشْيَ بَدٍ مَرِفِ شَ مَسٍنيِ رَ، ثِيّرِ نُن يَيَ نَشَ فبِلٍن دَرِ سَلَمُ. كِرَ قَن نَ، عٍ نَشَ شِبَارُ قَنيِ كَوَندِ تِ سَمَرِ تَا وُيَشِ كُي.
\s1 عٍتِيٌثِ شُنمَتِ ندٍ شُنشَقٍ يٍ شْورَ
\p 
\v 26 مَرِفِ شَ مَلٍكّ نَشَ عَ قَلَ قِلِثُ بّ، «كٍلِ، سِفَ يِرٍقَنيِ بِرِ رَ، فبٍنفبٍرٍن كِرَ شْن، نَشَن فٌرٌ مَ فَسَ، كٍلِقٍ دَرِ سَلَمُ.»
\v 27 عَ نَشَ كٍلِ، عَ نَشَ عٍتِيٌثِكَ ندٍ لِ كِرَ رَ. شّمّ نَن نُ عَ رَ نَشَن مُ نُ نْمَ فِنّ قٍ رَبَدٍ. عَ قِندِشِ كَندَ سِ، عٍتِيٌثِ مَنفّ فِنّ شُنمَتِ نَن نَ. عَ تَن نَن نُ عَ شَ نَاقُلِ بِرِن كَنتَمَ. عَ نُ قَشِ سَلِدٍ نّ دَرِ سَلَمُ.
\v 28 عَ نَ فبِلٍنقٍ عَ شْنيِ، عَ دْشْشِ عَ شَ مَحّرّ سٍ كُي، عَ نَ عَننَبِ عٍسَيِ شَ كِتَابُي شَرَنقٍ.
\p 
\v 29 عَلَ شَشِلِ سّنِيّنشِ نَشَ عَ مَسٍن قِلِثُ بّ، «سِفَ، عِ عِ مَكْرّ نَ مَحّرّ سٍ رَ.»
\v 30 قِلِثُ نَشَ سِفَ عَ فِ رَ. عَ نَشَ عٍتِيٌثِكَ شُي مّ، عَ نُ عَننَبِ عٍسَيِ شَ كِتَابُي شَرَنقٍ. عَ نَشَ عَ مَشْرِن، «عِ نَشَن شَرَنقٍ يِ كِ، عِ عَ قَهَامُشِ؟»
\v 31 عَ نَشَ عَ يَابِ، «ﭑ نْمَ نَ رَ دِ، شَ مِشِ يٌ مُ نَ نَشَن عَ تَفِ رَبَمَ ﭑ بّ؟» عَ نَشَ عَ قَلَ قِلِثُ بّ عَ شَ دْشْ عَ سّيتِ مَ.
\v 32 عَ نُ نَ يِ سّبّلِ نَن شَرَنقٍ كِتَابُي كُي؛
\q1 «عٍ عَ شَنِنشِ تّمُي نَشّ عَ شَ قَشَ
\q1 عَ نَشَ لُ عَلْ يّشّي نَشَن شَنِنمَ قَشَدٍ.
\q1 عَ مُ عَ شُي يٌ رَ مِنِ،
\q1 عَلْ يّشّي نَشَن تِمَ عَ شَبٍ مَشَبَمَ يَ رَ.
\q1 
\v 33 عَ شَ مَرَيَافِ كُي،
\q1 عٍ نَشَ عَ مَكِيتِ سّرِيّ شَنبِ.
\q1 ندٍ نْمَ عَ شَ تَرُشُي قَلَدٍ؟
\q1 عَ شَ سِمَيَ بَرَ حْن بْشِ قَرِ.»
\p 
\v 34 نَ عٍتِيٌثِكَ نَشَ عَ قَلَ قِلِثُ بّ، «يَندِ، عَ مَسٍن ﭑ بّ، عَننَبِ عٍسَيِ ندٍ شَ قٍ قَلَمَ يِ كِ؟ عَ يّتّ بَ، كَ مِشِ فبّتّ؟»
\v 35 عَوَ، قِلِثُ نَشَ عَ قْلْ نَ سّبّلِ مَ، عَ نَشَ عَ كَوَندِ عِسَ شَ شِبَارُ قَنيِ رَ.
\p 
\v 36 عٍ نَ سِفَقٍ كِرَ شْن، عٍ نَشَ يٍ لِ. نَ عٍتِيٌثِكَ نَشَ عَ قَلَ قِلِثُ بّ، «يٍ نَن يَ. نَنسٍ عَ نِيَمَ ﭑ مُ شُنشَمَ يٍ شْورَ؟»
\v 37 قِلِثُ نَشَ عَ يَابِ، «شَ عِ دَنشَنِيَ عِ بْحّ بِرِن نَ، عِ نْمَ نَ رَ.» نَ عٍتِيٌثِكَ نَشَ عَ يَابِ، «ﭑ لَشِ عَ رَ، عَلَ شَ دِ نَن لَنشِ عِسَ مَ.»
\v 38 عَ نَشَ مَحّرّ سٍ رَتِ، عٍ قِرِن بِرِن نَشَ فٌرٌ يٍ مَ. قِلِثُ نَشَ نَ عٍتِيٌثِكَ شُنشَ يٍ شْورَ.
\v 39 عٍ تٌ تٍ يٍ شْورَ، مَرِفِ شَشِلِ نَشَ قِلِثُ تٌنفٌ، عَ عَ شَنِن. نَ عٍتِيٌثِكَ مُ قَ عَ تٌ سْنْن. عَ نَشَ سِفَ سّيوّ كُي.
\p 
\v 40 قِلِثُ نَشَ مِنِ عَسٌتُ تَا كُي. عَ مَن نَشَ سِفَ سٍسَرٍ. عَ نَشَ شِبَارُ قَنيِ كَوَندِ تِ تَا بِرِن كُي عَ نُ دَنفِمَ دّننَشّ.
\c 9
\s1 سْلُ شُنشَقٍ يٍ شْورَ
\p 
\v 1 نَ تّمُي بِرِن، سْلُ نُ كْنكْشِ مَرِفِ قْشِرَبِرّيٍ مَ، عَ شَ عٍ قَشَ. عَ نَشَ سِفَ سّرّشّدُبّ كُنتِفِ شْن
\v 2 كّيدِ مَشْرِندٍ كَتَرَبِ دَ مَسِ سَلِدٍ يَرٍرَتِيٍ مَ، عَلَكٌ شَ عَ نَشٍيٍ لِ نَا، عٍ بِرَشِ عِسَ شَ كِرَ قْشْ رَ، شّمّيٍ نُن فِنّيٍ، عَ شَ قَ عٍ شِرِشِ رَ دَرِ سَلَمُ.
\v 3 عَ نَ مَكْرّقٍ دَ مَسِ رَ، يَنبّ نَشَ مِنِ عَ مَ كٍلِ كٌورٍ مَ، عَ عَ رَبِلِن.
\v 4 عَ نَشَ بِرَ بْشِ مَ، عَ نَشَ شُي ندٍ مّ، «سْلُ، سْلُ، عِ نَ ﭑ حَشَنكَتَقٍ مُنقٍ رَ؟»
\v 5 سْلُ نَشَ عَ يَابِ، «مَرِفِ، ندٍ عِ رَ؟» عَ نَشَ عَ يَابِ، «عِسَ نَن ﭑ نَ، عِ نَشَن حَشَنكَتَقٍ.
\v 6 كٍلِ، سٌ تَا كُي، عٍ قَمَ عَ قَلَدٍ عِ بّ عَ لَنمَ عِ شَ نَشَن نَبَ.»
\v 7 شّمّيٍ نَشٍيٍ نُ عَ قْشْ رَ، نٍيٍ دّ نَشَ بٌبٌ عَ رَ فَاشُي بّ. عٍ نُ شُي مّمَ، كْنْ عٍ مُ نُ مِشِ يٌ تٌمَ.
\v 8 سْلُ نَشَ كٍلِ بْشِ مَ، عَ يَ رَبِشِ، كْنْ عَ يَ مُ سٍ تٌمَ. عٍ نَشَ عَ بّلّشّ سُشُ، عٍ عَ مَتِ دَ مَسِ.
\p 
\v 9 عَ نَشَ لُ شِ سَشَن عَ مُ سٍسٍ تٌ، عَ مُ سٍسٍ دٌن، عَ مُ سٍسٍ مِن.
\v 10 عِسَ قْشِرَبِرّ ندٍ نُ نَ دَ مَسِ، نَشَن شِلِ عَنَنِيَسِ. مَرِفِ نَشَ عَ شِلِ لَامَتُنيِ كُي، «عَنَنِيَسِ!» عَنَنِيَسِ نَشَ عَ رَتِن، «مَرِفِ، ﭑ تَن نَن يَ.»
\v 11 مَرِفِ نَشَ عَ قَلَ عَ بّ، «كٍلِ، سِفَ كِرَ رَ نَشَن شِلِ ‹كِرَ تِنشِنشِ›، عِ شَ شّمّ قٍن يُدَ سِ شَ بَنشِ كُي، نَشَن شِلِ سْلُ تَرِ سٍكَ. عَ نَ عَلَ مَشَندِقٍ.
\v 12 عَ بَرَ مِشِ ندٍ تٌ لَامَتُنيِ كُي، نَشَن شِلِ عَنَنِيَسِ، عَ نَ عَ بّلّشّ سَقٍ عَ مَ عَلَكٌ عَ مَن شَ سٍ تٌ.»
\v 13 عَنَنِيَسِ نَشَ عَ يَابِ، «مَرِفِ، ﭑ بَرَ يِ شّمّ شَ قٍ مّ مِشِ وُيَشِ رَ، عَ بَرَ قٍ كٌبِ نَشَن نَبَ عِ شَ مِشِ سّنِيّنشِيٍ رَ دَرِ سَلَمُ.
\v 14 سّرّشّدُبّ كُنتِفِيٍ بَرَ نْي سٌ عَ يِ رَ، عَ شَ بِرِن سُشُ نَشٍيٍ عِ شِلِ مَشَندِ مَ.»
\p 
\v 15 كْنْ مَرِفِ نَشَ عَنَنِيَسِ يَابِ، «سِفَ، بَرِ مَ ﭑ بَرَ يِ شّمّ سُفَندِ شّيرَ رَ، عَ شَ ﭑ شِلِ مَسٍن سِ بِرِن بّ، عٍ شَ مَنفّيٍ بّ، عَ نُن عِسِرَيِلَ دِيٍ بِرِن بّ.
\v 16 ﭑ عَ مَسٍنمَ نّ عَ بّ، عَ قَمَ تْورْدٍ كِ نَشّ ﭑ شِلِ شَ قٍ رَ.»
\v 17 عَنَنِيَسِ نَشَ سِفَ نَ بَنشِ. عَ تٌ سٌ، عَ نَشَ عَ بّلّشّ سَ سْلُ مَ. عَ نَشَ عَ قَلَ عَ بّ، «ﭑ نفَشَكٍرٍنيِ سْلُ، مَرِفِ عِسَ نَشَن مِنِ عِ مَ كِرَ رَ، عَ تَن نَن ﭑ شّيشِ عِ مَ، عَلَكٌ عِ شَ سٍ تٌ، عِ مَن شَ عَلَ شَشِلِ سّنِيّنشِ سْتْ.»
\v 18 سٍ ندٍ نَشَ بَ عَ يَ مَ كٍرٍن نَ عَلْ شَلٍيٍ، عَ يَ نَشَ سٍ تٌ. عَ نَشَ كٍلِ، عَ قَ عَ شُنشَ يٍ شْورَ.
\v 19 نَ شَنبِ عَ نَشَ عَ دّفٍ، عَ قَ سّنبّ سْتْ.
\s1 سْلُ كَوَندِ رَبَقٍ دَ مَسِ
\p سْلُ نَشَ سَشَنيِ رَبَ دَ مَسِ عَ نُن عِسَ قْشِرَبِرّيٍ.
\v 20 عَ نَشَ بْنبْ كَوَندِ تِقٍ رَ كٍرٍن نَ سَلِدٍيٍ كُي عَ نُ عَ مَسٍن عَ عَلَ شَ دِ نَن لَنشِ عِسَ مَ.
\v 21 نَشٍيٍ بِرِن عَ شُي مّ، عٍ دّ نَشَ عِشَرَ. عٍ نَشَ عَ قَلَ، «يِ شّمّ شَ مُ نُ مِشِيٍ حَشَنكَتَمَ دَرِ سَلَمُ، نَشٍيٍ نُ مَشَندِ تِمَ عِسَ شِلِ رَ؟ عَ مُ قَشِ شّ بٍ، عَ شَ عٍ شَنِن عٍ شِرِشِ رَ سّرّشّدُبّ كُنتِفِيٍ شْن؟»
\v 22 سْلُ نَشَ سّنبّ سْتْ. عَ شَ مَسٍنيِ نَشَ دَ مَسِ يُوِقِيٍ عِقُ، عَ قَلَقٍ عَ عِسَ نَن لَنشِ عَلَ شَ مِشِ سُفَندِشِ مَ.
\p 
\v 23 تّمُي ندٍ تٌ دَنفِ، يُوِقِيٍ نَشَ لَن عَ مَ عٍ شَ سْلُ قَشَ.
\v 24 سْلُ نَشَ عٍ شَ فُندٌ كٌلٌن. عٍ نُ تَا سٌدٍ دّ كَنتَمَ كْي نُن يَنيِ عَلَكٌ عٍ شَ عَ قَشَ.
\v 25 كْنْ كْي ندٍ رَ، عِسَ قْشِرَبِرّيٍ نَشَ عَ رَفٌرٌ تّتّ قَرِ مَ سَفَ كُي.
\s1 سْلُ سِفَقٍ دَرِ سَلَمُ
\p 
\v 26 سْلُ تٌ سِفَ دَرِ سَلَمُ، عَ نَشَ وَ بٌنِقٍ عِسَ قْشِرَبِرّيٍ رَ، كْنْ عٍ بِرِن نُ فَاشُشِ عَ يَ رَ. عٍ مُ نُ لَشِ عَ رَ شَ عِسَ قْشِرَبِرّ نَن يَتِ عَ رَ.
\v 27 عَوَ، بَرَنَبَسِ نَشَ عَ شَنِن شّيرَيٍ شْن. عَ نَشَ عَ تَفِ رَبَ عٍ بّ سْلُ مَرِفِ تٌشِ كِ نَشّ، عَ مَن عَ شُي مّشِ كِرَ رَ كِ نَشّ. عَ نَشَ عَ مَسٍن عٍ بّ سْلُ بَرَ كَوَندِ نَشَن نَبَ عِسَ شِلِ رَ دَ مَسِ تَا كُي.
\v 28 عٍ بِرِن نَشَ دْشْ يِرٍ كٍرٍن دَرِ سَلَمُ. سْلُ نُ مَرِفِ شِلِ كَوَندِ مَ سّنبّ رَ.
\v 29 عٍ نُن يُوِقِيٍ قَن نَشَ وْيّن عٍ نُ شْرْشْ، يُوِقِ نَشٍيٍ فِرّكِ شُي قَلَمَ، كْنْ نٍيٍ نُ كَتَقٍ عٍ شَ سْلُ قَشَ.
\v 30 عَ نفَشَكٍرٍنيِ عِسَيَنكَيٍ تٌ نَ قٍ مّ، عٍ نَشَ عَ شَنِن سٍسَرٍ، عٍ قَ عَ رَ سِفَ تَرِ سٍ.
\v 31 دَنشَنِيَتْي حَمَ نَشَ لُ بْحّسَ كُي يُدَيَ، فَلِلٍ، نُن سَمَرِ بْشِ بِرِن مَ. عٍ نُ لُمَ عٍ بٌرٍ رَلِمَنِيَ رَ، عٍ نُ عٍ حّرّ مَرِفِ شَ يَرَفَاشُي كُي. عٍ شُن نُ مَسَمَ عَلَ شَشِلِ سّنِيّنشِ سَابُي رَ.
\s1 ثِيّرِ سِفَقٍ لِدَ نُن يَقَ
\p 
\v 32 ثِيّرِ تٌ نُ بْشِ عِحّرّ مَ، عَ نَشَ فٌرٌ سّنِيّنتْييٍ يِرٍ لِدَ.
\v 33 عَ نَشَ شّمّ نَمَتَشِ ندٍ لِ نَا، نَشَن شِلِ عٍنٍ، عَ نُ سَشِ سَدٍ مَ كَبِ حّ سٌلٌمَسَشَن.
\v 34 ثِيّرِ نَشَ عَ قَلَ عَ بّ، «عٍنٍ، عِسَ عَلَ شَ مِشِ سُفَندِشِ بَرَ عِ رَيَلَن. كٍلِ، عِ عِ شَ سَدٍ يَءِلَن.» عَ نَشَ كٍلِ كٍرٍن نَ.
\v 35 لِدَكَيٍ نُن سَرْنكَ بِرِن تٌ يِ قٍ تٌ، عٍ نَشَ تُوبِ مَرِفِ مَ.
\p 
\v 36 فِنّ ندٍ نُ نَ يَقَ عِسَ قْشِرَبِرّيٍ يَ مَ. عَ نُ شِلِ تَبِتَ، نَشَن قَلَشِ دْرَكَسِ. عَ نُ قٍ قَنيِ فبٍفبٍ رَبَمَ، عَ نُ تْورْ مِشِيٍ كِ.
\v 37 نَ تّمُي، قُرٍ نَشَ عَ سُشُ، عَ نَشَ قَشَ. عٍ تٌ عَ مَشَ، عٍ نَشَ عَ سَ كٌورٍ بَنشِ دّكِ قِرِن ندٍ.
\v 38 عِسَ قْشِرَبِرّيٍ نَشٍيٍ نُ نَ يَقَ، عٍ نَشَ عَ مّ عَ ثِيّرِ نَ لِدَ. لِدَ مُ مَكُيَ يَقَ رَ. عَوَ، عٍ نَشَ شّمّ قِرِن شّي ثِيّرِ مَ، عٍ شَ عَ مَيَندِ عَ شَ قَ عٍ شْنيِ مَقُرٍن.
\v 39 ثِيّرِ نَشَ كٍلِ، عٍ نُن نَ شّمّيٍ نَشَ سِفَ. عٍ تٌ سٌ، عٍ نَشَ عَ شَنِن كٌورٍ بَنشِ كْن نَ. كَاحّ فِنّيٍ نَشَ عَ رَبِلِن، عٍ وَ مَ. عٍ نَشَ دُفِيٍ نُن سٌسٍيٍ مَسٍن عَ بّ دْرَكَسِ نَشٍيٍ يَءِلَن عَ نُ نَ عٍ يَ مَ تّمُي نَشّ.
\v 40 ثِيّرِ نَشَ عٍ بِرِن نَمِنِ تَندٍ. عَ نَشَ عَ شِنبِ سِن، عَ عَلَ مَشَندِ. نَ شَنبِ، عَ نَشَ عَ مَقِندِ قُرٍ مَبِرِ رَ. عَ نَشَ عَ قَلَ، «تَبِتَ، كٍلِ.» تَبِتَ نَشَ عَ يَ رَبِ. عَ تٌ ثِيّرِ تٌ، عَ نَشَ كٍلِ.
\v 41 ثِيّرِ نَشَ عَ بّلّشّ سُشُ، عَ عَ رَكٍلِ. عَ نَشَ سّنِيّنتْييٍ نُن كَاحّ فِنّيٍ شِلِ. عَ نَشَ عَ حِحّ دّنتّفّ عٍ بّ.
\v 42 يَقَكَيٍ بِرِن نَشَ نَ قٍ مّ. مِشِ وُيَشِ نَشَ دَنشَنِيَ مَرِفِ مَ.
\v 43 ثِيّرِ نَشَ شِ وُيَشِ رَبَ يَقَ، سِمْن فَرَنفٍ شْنيِ.
\c 10
\s1 كٌرٌنٍلِيٌ شُنشَقٍ يٍ شْورَ
\p 
\v 1 شّمّ ندٍ نُ نَ سٍسَرٍ نَشَن نُ شِلِ كٌرٌنٍلِيٌ. سْورِ كّمّ شُنمَتِ نَن نُ عَ رَ عِتَلِ سْورِ فَلِ يَ مَ.
\v 2 دِينّلَ نَن نُ عَ رَ. عَ تَن نُن عَ شَ مِشِ بِرِن نُ فَاشُشِ عَلَ يَ رَ. عَ نُ سٍتَرٍيٍ مَلِمَ عَ فبٍفبٍ رَ، عَ مَن نُ عَلَ مَشَندِ مَ تّمُي بِرِن.
\p 
\v 3 نُنمَرٍ رَ، عَ نَشَ عَلَ شَ مَلٍكّ ندٍ تٌ لَامَتُنيِ رَ، عَ سٌقٍ عَ شْنيِ. مَلٍكّ نَشَ عَ شِلِ، «كٌرٌنٍلِيٌ.»
\v 4 كٌرٌنٍلِيٌ تٌ عَ تٌ، عَ نَشَ فَاشُ. عَ نَشَ عَ قَلَ، «مَرِفِ، مُنسٍ نِيَشِ؟» مَلٍكّ نَشَ عَ قَلَ عَ بّ، «عَلَ بَرَ عِ شَ مَشَندِ سُشُ. عَ بَرَ رَتُ عِ مَ، عِ بَرَ نَشَن نَبَ سٍتَرٍيٍ بّ.
\v 5 يَكْسِ، عِ شَ مِشِ ندٍيٍ شّي يَقَ عٍ شَ قَ سِمْن نَ، نَشَن شِلِ قَلَمَ ثِيّرِ.
\v 6 عَ يِفِيَشِ سِمْن فَرَنفٍ شْنيِ بَا دّ رَ.»
\p 
\v 7 مَلٍكّ تٌ فّ وْيّندٍ، عَ نَشَ سِفَ. كٌرٌنٍلِيٌ نَشَ كٌنيِ قِرِن شِلِ، عَ نُن عَ شَ سْورِ دِينّلَ، نَشَن نُ وَلِمَ عَ بّ.
\v 8 عَ نَشَ يِ قٍ بِرِن يَبَ عٍ بّ، عَ قَ عٍ شّي يَقَ.
\v 9 نَ كُيٍ عِبَ يَنيِ تَفِ حْندْن، عٍ نُ نَ كِرَ شْن مَ تّمُي نَشّ، عٍ مَكْرّ تَا رَ، ثِيّرِ نَشَ تٍ كٌورٍ بَنشِ قَرِ عَ شَ عَلَ مَشَندِ.
\v 10 نَ تّمُي كَامّ نَشَ عَ سُشُ، عَ نُ وَ مَ عَ دّفٍقٍ. بٍينُن دٌنسٍ شَ فّ يَءِلَندٍ، عَ نَشَ لَامَتُنيِ تٌ.
\p 
\v 11 عَ نَشَ كٌورٍ تٌ عَ رَبِشِ، سٍ ندٍ نَشَ فٌرٌ بْشِ عَلْ دُفِ، عَ شِرِشِ عَ تُنشُن نَانِيٍ مَ.
\v 12 سُبٍيٍ، بُبُسٍيٍ، نُن شْنِ بِرِن نُ نَ نَ دُفِ كُي.
\v 13 شُي ندٍ نَشَ عَ قَلَ، «ثِيّرِ، كٍلِ، عِ سُبٍ ندٍ قَشَ، عِ شَ عَ دٌن.»
\v 14 كْنْ ثِيّرِ نَشَ عَ يَابِ، «عَدٍ، مَرِفِ. ﭑ مُ نُ سٍ رَهَرَ مُشِ دٌن سِندٍن، شَ نَ مُ عَ رَ سٍ سّنِيّنتَرٍ.»
\v 15 شُي نَشَ وْيّن عَ بّ عَ قِرِن ندٍ، «عَلَ بَرَ سٍ نَشَن نَسّنِيّن عِ نَشَ عَ قَلَ عَ سّنِيّنتَرٍ.»
\v 16 نَ نَشَ رَبَ سَنيَ سَشَن. نَ شَنبِ، نَ دُفِ مَن نَشَ تٍ كٌورٍ مَ.
\p 
\v 17 ثِيّرِ تٌ نُ عَ مَحْشُنقٍ نَ لَامَتُنيِ مَ، عَ وَ مَ نَشَن مَسٍنقٍ، كٌرٌنٍلِيٌ شَ شّيرَيٍ نُ بَرَ سِمْن شْنيِ مَشْرِن. عٍ نَشَ تِ نَادّ رَ.
\v 18 عٍ نَشَ مَشْرِنيِ تِ شَ سِمْن يِفِيَشِ نَا نّ، عٍ نَشَن شِلِ قَلَمَ ثِيّرِ.
\v 19 ثِيّرِ نُ عَ مَحْشُنقٍ لَامَتُنيِ مَ تّمُي نَشّ، عَلَ شَشِلِ نَشَ عَ مَسٍن عَ بّ، «شّمّ سَشَن نَ عِ مَشْرِنقٍ.
\v 20 كٍلِ، عِ شَ فٌرٌ، وٌ بِرِن شَ سِفَ. عِ نَشَ سِيكّ، بَرِ مَ ﭑ تَن نَن عٍ شّيشِ.»
\v 21 عَوَ، ثِيّرِ نَشَ فٌرٌ، عَ نَشَ عَ قَلَ نَ شّمّيٍ بّ، «ﭑ تَن نَن يِ كِ وٌ نَشَن قٍنقٍ. وٌ قَشِ مُنقٍ مَ؟»
\v 22 عٍ نَشَ دّنتّفّ سَ، «كٌرٌنٍلِيٌ، سْورِ مِشِ كّمّ شُنمَتِ، نَن مُشُ شّيشِ. شّمّ تِنشِنشِ نَ عَ رَ، نَشَن فَاشُشِ عَلَ يَ رَ. يُوِقِيٍ بِرِن عَ شِلِ قَنيِ قَلَمَ. عَلَ شَ مَلٍكّ سّنِيّنشِ بَرَ عَ مَسٍن عَ بّ عَ شَ عِ رَقَ عَ شْنيِ عَلَكٌ عَ شَ عِ شَ مَسٍنيِ رَ مّ.»
\v 23 عَوَ، ثِيّرِ نَشَ عٍ يِفِيَ. نَ كُيٍ عِبَ، عَ نَشَ كٍلِ، عٍ بِرِن نَشَ سِفَ. يَقَكَ دَنشَنِيَتْي ندٍيٍ قَن نَشَ عٍ مَتِ.
\p 
\v 24 نَ كُيٍ عِبَ، عٍ نَشَ سٌ سٍسَرٍ، كٌرٌنٍلِيٌ نُ عٍ مَمّقٍ دّننَشّ. عَ نُ بَرَ عَ شَ مِشِيٍ نُن عَ بٌورٍ قَنيِيٍ مَلَن.
\v 25 ثِيّرِ تٌ سٌ، كٌرٌنٍلِيٌ نَشَ عَ رَلَن، عَ نَشَ عَ يّتّ مَفٌرٌ عَ بّ.
\v 26 كْنْ ثِيّرِ نَشَ عَ رَكٍلِ، عَ نَشَ عَ قَلَ، «كٍلِ، مِشِ نَن نَ ﭑ قَن نَ.»
\v 27 عٍ نَشَ سٌ بَنشِ عٍ وْيّنمَ عٍ بٌرٍ رَ. ثِيّرِ نَشَ مِشِ فبٍفبٍ مَلَنشِ لِ نَا.
\v 28 عَ نَشَ عَ قَلَ عٍ بّ، «وٌ عَ كٌلٌن تْنيِ دْشْشِ يُوِقِيٍ مَ عٍ نُن سِ فبّتّ بْنسْي نَشَ لُ يِرٍ كٍرٍن، شَ نَ مُ عَ رَ سٌقٍ رَ عٍ شْنيِ. كْنْ عَلَ بَرَ عَ مَسٍن ﭑ بّ عَ ﭑ نَشَ مِشِ يٌ مَحْشُن سّنِيّنتَرٍ رَ.
\v 29 نَ نَ عَ رَ، وٌ تٌ ﭑ شِلِ، ﭑ مُ تٌندِ قَدٍ. عَوَ، وٌ ﭑ شِلِشِ مُنقٍ مَ؟»
\v 30 كٌرٌنٍلِيٌ نَشَ عَ مَسٍن عَ بّ، «نَ شِ نَانِ نَن يِ كِ، ﭑ نُ سَلِقٍ ﭑ مَ بَنشِ كُي نُنمَرٍ تّمُي. شّمّ ندٍ نَشَ مِنِ ﭑ مَ، عَ شَ سٌسٍيٍ يَنبَمَ.
\v 31 عَ نَشَ عَ مَسٍن ﭑ بّ، ‹كٌرٌنٍلِيٌ، عَلَ بَرَ عِ شَ مَشَندِ سُشُ. عَ بَرَ رَتُ عَ مَ عِ بَرَ نَشَن نَبَ سٍتَرٍيٍ بّ.
\v 32 عَوَ، مِشِيٍ شّي يَقَ، عٍ شَ قَ سِمْن ثِيّرِ رَ بٍ. عَ يِفِيَشِ سِمْن فَرَنفٍ شَ بَنشِ كُي، بَا دّ رَ.›
\v 33 ﭑ نَشَ مِشِيٍ شّي كٍرٍن نَ. مُشُ بَرَ حّلّشِن كِ قَنيِ عِ قَقٍ رَ. عَوَ، يَكْسِ مُشُ بِرِن نَ عَلَ يَ عِ. عِ شَ مَسٍنيِ تِ مُشُ بّ، مَرِفِ بَرَ عِ يَمَرِ نَشَن بِرِن نَ.»
\p 
\v 34 عَوَ، وْيّنيِ تٌ سٌ ثِيّرِ يِ، عَ نَشَ عَ مَسٍن، «يَكْسِ ﭑ بَرَ عَ كٌلٌن نْندِ نَن يَتِ عَ رَ، عَلَ مُ مِشِ يٌ رَقِسَشِ عَ بٌورٍ بّ.
\v 35 عَ وَ مَ مِشِ بِرِن شْن، سِيٍ بِرِن يَ مَ، نَشٍيٍ فَاشُمَ عَ يَ رَ، نَشٍيٍ تِنشِن.
\v 36 عَلَ بَرَ شِبَارُ قَنيِ مَسٍن عِسِرَيِلَ حَمَ بّ. عَ بَرَ عَ مَسٍن عٍ بّ عَ بْحّسَ سْتْمَ دُنِحَ مَرِفِ عِسَ، عَلَ شَ مِشِ سُفَندِشِ نَن نَ.
\v 37 وٌ عَ كٌلٌن نَشَن نَبَشِ قْلْقٍ فَلِلٍ بْشِ مَ، دْشْقٍ يُدَيَ بِرِن نَ. يَيَ نُ بَرَ كَوَندِ تِ مِشِيٍ شَ عٍ شُنشَ يٍ شْورَ.
\v 38 نَ تّمُي عَلَ نَشَ عِسَ نَسَرّتِكَ سُفَندِ، عَلَ شَشِلِ سّنِيّنشِ نُن سّنبّ نَشَ فٌرٌ عَ مَ. عِسَ نَشَ سِفَ يِرٍ بِرِن، عَ نُ قٍ قَنيِ رَبَ، عَ نُ مِشِ بِرِن نَيَلَن نَشٍيٍ نُ نَ عِبُلِسَ شَ كٌنيِيَ بُن. عَلَ نُ نَ عَ قْشْ رَ.»
\p 
\v 39 «يِ قٍ بِرِن سٍيدٍ نَن مُشُ رَ عَ نَشَن نَبَ يُوِقِيٍ شَ بْشِ مَ نُن دَرِ سَلَمُ. عٍ نَشَ عَ بَنبَن وُرِ مَ، عَ قَشَ.
\v 40 كْنْ عَلَ نَشَ عَ رَكٍلِ قَشّ مَ شِ سَشَن لْشْي، دُنِحَ شَ عَ تٌ.
\v 41 عَ مُ تِن عَ مَكّنّندٍ بِرِن بّ، كْنْ عَ نَشَ عَ يّتّ مَسٍن مُشُ بّ، عَلَ نَشٍيٍ سُفَندِشِ عٍ شَ قِندِ سٍيدٍيٍ رَ. مُشُ نُن عِسَ بَرَ دٌنسٍ دٌن، مُشُ بَرَ يٍ مِن عَ كٍلِ شَنبِ قَشّ مَ.
\v 42 عِسَ نَشَ مُشُ يَمَرِ، مُشُ شَ كَوَندِ تِ مِشِيٍ بّ، عٍ شَ عَ كٌلٌن عَلَ نَن عِسَ تِشِ كِيتِسَ رَ مِشِ بَلٌشِيٍ نُن مِشِ قَشَشِيٍ شُن مَ.
\v 43 نَمِحْنمّ بِرِن نُ بَرَ عَ شَ قٍ قَلَ، نَشَن نَ دَنشَنِيَ عَ مَ نَ كَنيِ شَ يُنُبِ شَقَرِ مَ نّ عَ شِلِ سَابُي رَ.»
\p 
\v 44 ثِيّرِ تٌ نُ وْيّنمَ، نَشٍيٍ بِرِن نُ يِ مَسٍنيِ رَ مّقٍ، عَلَ شَشِلِ سّنِيّنشِ نَشَ فٌرٌ عٍ مَ.
\v 45 دَنشَنِيَتْي سُننَشِيٍ نَشٍيٍ ثِيّرِ مَتِ نَا، عٍ نَشَ كَابَ يِ قٍ مَ، عَلَ شَشِلِ سّنِيّنشِ فٌرٌقٍ سُننَتَرٍيٍ قَن مَ،
\v 46 بَرِ مَ عٍ نَشَ عٍ شُي مّ عٍ نَ عَلَ مَتْشْقٍ شُي فبّتّيٍ رَ.
\v 47 عَوَ، ثِيّرِ نَشَ مَشْرِنيِ تِ، «مِشِ ندٍ نْمَ تٌندِدٍ يِ مِشِيٍ شَ شُنشَ يٍ شْورَ؟ عٍ قَن بَرَ عَلَ شَشِلِ سّنِيّنشِ سْتْ عَلْ وٌن قَن عَ سْتْشِ كِ نَشّ.»
\v 48 عَ نَشَ يَامَرِ قِ قَ عٍ شَ عٍ شُنشَ يٍ شْورَ عِسَ شِلِ رَ. نَ شَنبِ عٍ نَشَ ثِيّرِ مَيَندِ عَ شَ لُ عٍ شْنيِ نَ سَشَنيِ.
\c 11
\s1 ثِيّرِ شُنمَقَلَقٍ
\p 
\v 1 شّيرَيٍ نُن نفَشَكٍرٍنيِيٍ نَشٍيٍ نُ نَ يُدَيَ، عٍ نَشَ عَ مّ عَ سِ فبّتّيٍ قَن بَرَ تِن عَلَ شَ مَسٍنيِ رَ.
\v 2 ثِيّرِ تٌ تٍ دَرِ سَلَمُ، يُوِقِ دَنشَنِيَتْييٍ نَشَ عَ كَلَمُ، «عِ بَرَ سٌ سُننَتَرٍيٍ شْنيِ،
\v 3 وٌ بِرِن بَرَ وٌ دّفٍ!»
\p 
\v 4 عَوَ ثِيّرِ نَشَ قٍ بِرِن تَفِ رَبَ عٍ بّ عَ دَنفِشِ كِ نَشّ.
\v 5 عَ نَشَ عَ مَسٍن، «ﭑ نُ نَ يَقَ تَا نَن كُي. ﭑ نَ عَلَ مَشَندِقٍ تّمُي نَشّ، ﭑ نَشَ لَامَتُنيِ تٌ. سٍ ندٍ نَشَن مَنِيَشِ دُفِ شُنفبٍ رَ، عَ شِرِشِ عَ تُنشُن نَانِيٍ مَ، نَ نَشَ فٌرٌ كٍلِ كٌورٍ مَ هَن ﭑ يِرٍ.
\v 6 ﭑ نَشَ عَ عِفبّ عَ قَنيِ رَ. ﭑ نَشَ شُرُ سٍيٍ، وُلَ سُبٍيٍ، بُبُسٍيٍ، نُن شْنِ بِرِن تٌ عَ كُي.
\v 7 شُي ندٍ نَشَ عَ قَلَ، ‹ثِيّرِ، كٍلِ، عِ سُبٍ ندٍ قَشَ، عِ شَ عَ دٌن.›
\v 8 كْنْ ﭑ نَشَ عَ قَلَ، ‹عَدٍ، مَرِفِ. ﭑ مُ نُ سٍ رَهَرَ مُشِ دٌن سِندٍن، شَ نَ مُ عَ رَ سٍ سّنِيّنتَرٍ.›
\v 9 شُي نَشَ وْيّن ﭑ بّ عَ قِرِن ندٍ، ‹عَلَ بَرَ نَشَن نَسّنِيّن عِ نَشَ عَ قَلَ عَ سّنِيّنتَرٍ.›
\v 10 نَ نَشَ رَبَ سَنيَ سَشَن. نَ شَنبِ، عَ بِرِن مَن نَشَ تٍ كٌورٍ مَ.»
\p 
\v 11 «نَ تّمُي مِشِ سَشَن، نَشٍيٍ نُ شّيشِ ﭑ يِرٍ كٍلِقٍ سٍسَرٍ، عٍ نَشَ تِ مُشُ شَ بَنشِ نَادّ رَ.
\v 12 عَلَ شَشِلِ نَشَ عَ مَسٍن ﭑ بّ عَ مُشُ بِرِن شَ سِفَ، عَ هَلِ ﭑ مُ سِيكّ. يِ شّمّ سٍننِ نَشٍيٍ يِ كِ، عٍ قَن نَشَ ﭑ مَتِ نَا. مُشُ تٌ سٌ كٌرٌنٍلِيٌ شْنيِ،
\v 13 عَ نَشَ عَ يَبَ مُشُ بّ عَ مَلٍكّ تٌشِ عَ شَ بَنشِ كُي كِ نَشّ. مَلٍكّ نَشَ عَ مَسٍن عَ بّ، ‹مِشِ شّي يَقَ، عَ شَ قَ سِمْن نَ، عٍ نَشَن شِلِ قَلَمَ ثِيّرِ.
\v 14 عَ قَمَ مَسٍنيِ تِدٍ عِ بّ، عِ تَن نُن عِ شَ مِشِ بِرِن كِسِمَ نَشَن سَابُي رَ.›»
\p 
\v 15 «ﭑ تٌ سٌ وْيّنقٍ، عَلَ شَشِلِ سّنِيّنشِ نَشَ فٌرٌ عٍ مَ عَلْ عَ فٌرٌ وٌن مَ كِ نَشّ عَ قْلّ.
\v 16 ﭑ قَ رَتُ مَرِفِ شَ مَسٍنيِ مَ، ‹يَيَ بَرَ مِشِ شُنشَ يٍ شْورَ، كْنْ عَلَ شَشِلِ سّنِيّنشِ قَمَ فٌرٌدٍ وٌ مَ.›
\v 17 عَلَ تٌ بَرَ عٍ كِ عَلْ عَ وٌن كِشِ كِ نَشّ، وٌن تَن نَشٍيٍ دَنشَنِيَشِ عِسَ عَلَ شَ مِشِ سُفَندِشِ مَ، عَ نُ لَن ﭑ شَ عَلَ مَتَندِ؟»
\p 
\v 18 عٍ تٌ نَ مّ، عٍ نَشَ دُندُ، عٍ نَشَ عَلَ مَتْشْ، «عَلَ بَرَ تُوبِ رَفِرِ سِ فبّتّيٍ قَن بّ، عَلَكٌ عٍ قَن شَ كِسِ.»
\s1 بَرَنَبَسِ نُن سْلُ سِفَقٍ عَنتِيْكِ
\p 
\v 19 عِسَ قْشِرَبِرّ نَشٍيٍ يٍنسٍن عٍتِيّن قَشَ شَنبِ حَشَنكَتّ سَابُي رَ، عٍ نَشَ سِفَ هَن قٍنِسِيَ، سِثِرِ، نُن عَنتِيْكِ. عٍ نُ عَلَ شَ مَسٍنيِ كَوَندِ مَ يُوِقِيٍ نَن بّ.
\v 20 كْنْ سِثِرِكَيٍ نُن سِرٍنِكَيٍ نَشٍيٍ نُ نَ عٍ يَ مَ، عٍ تٌ سِفَ عَنتِيْكِ، عٍ نَشَ مَرِفِ عِسَ شَ شِبَارُ قَنيِ مَسٍن فِرّكِكَيٍ قَن بّ.
\v 21 مَرِفِ شْنيّ نُ نَ عٍ مَ. مِشِ فبٍفبٍ نَشَ دَنشَنِيَ، عٍ نَشَ تُوبِ مَرِفِ مَ.
\p 
\v 22 دَرِ سَلَمُ دَنشَنِيَتْي حَمَ تٌ نَ قٍ مّ، عٍ نَشَ بَرَنَبَسِ شّي عَنتِيْكِ.
\v 23 عَ تٌ سٌ نَا، عَ نَشَ حّلّشِن عَلَ شَ هِننّ تٌقٍ رَ. عَ نَشَ عٍ رَلِمَنِيَ، عٍ شَ دَنشَنِيَ مَرِفِ مَ.
\v 24 بَرَنَبَسِ، مِشِ قَنيِ نَن نُ عَ رَ. عَ نُ رَقٍشِ دَنشَنِيَ نُن عَلَ شَشِلِ سّنِيّنشِ رَ. حَمَ فبٍفبٍ نَشَ دَنشَنِيَ مَرِفِ مَ.
\p 
\v 25 نَ شَنبِ، بَرَنَبَسِ نَشَ سِفَ تَرِ سٍ سْلُ قٍندٍ.
\v 26 عَ تٌ عَ تٌ، عَ نَشَ قَ عَ رَ عَنتِيْكِ. عٍ نُن دَنشَنِيَتْييٍ نَن نُ عٍ مَلَنمَ نَا حّ كٍرٍن بِرِن بُن مَ. عٍ نَشَ مِشِ فبٍفبٍ شَرَن. عِسَ قْشِرَبِرّ نَشٍيٍ نُ نَ عَنتِيْكِ، نٍيٍ نَن سِنفٍ «عِسَيَنكَ» شِلِ سْتْ.
\p 
\v 27 نَ تّمُي، نَمِحْنمّ ندٍيٍ نَشَ فٌرٌ عَنتِيْكِ، كٍلِقٍ دَرِ سَلَمُ.
\v 28 نَشَن نُ شِلِ عَفَبُ، نَ نَشَ تِ، عَ قَ عَ قَلَ عَلَ شَشِلِ سّنِيّنشِ سَابُي رَ، عَ كَامّ شُنفبٍ قَمَ سِندٍ دُنِحَ بِرِن مَ. نَ قٍ رَبَ مَنفّ كِلْدِ شَ وَشَتِ نّ.
\v 29 عِسَ قْشِرَبِرّيٍ نَشَ لَن عَ مَ عٍ شَ يُدَيَ نفَشَكٍرٍنيِيٍ مَلِ هَرِفٍ رَ، كَنكَن نْمَ نَشَن نَ.
\v 30 عٍ نَشَ عَ سٌ بَرَنَبَسِ نُن سْلُ يِ رَ كَتَرَبِ كُنتِفِيٍ مَ.
\c 12
\s1 تْورّ مَن شّيرَيٍ لِقٍ
\p 
\v 1 نَ تّمُي مَنفّ هٍرٌدٍ نَشَ سٌ دَنشَنِيَتْي حَمَ مِشِ ندٍيٍ تْورْقٍ.
\v 2 عَ نَشَ يَكِ، يَيَ تَارَ، قَشَ سَنتِدّفّمَ رَ.
\v 3 عَ تٌ عَ تٌ نَ نُ رَقَن يُوِقِيٍ مَ، عَ مَن نَشَ ثِيّرِ سُشُ تَامِ لّبِنِتَرٍ سَلِ.
\v 4 عَ تٌ عَ سُشُ، عَ نَشَ عَ سَ فٍيلِ كُي. عَ نَشَ سْورِ نَانِ نَانِ تٌنفٌ شُندّ نَانِ كُي، عَ نٍيٍ يَمَرِ، عٍ شَ عَ كَنتَ. هٍرٌدٍ نُ وَشِ ثِيّرِ شَ مَكِيتِ حَمَ يَ شْرِ سَيَمَلٍكّ دَنفِ سَلِ نَ بَ عَ رَ.
\v 5 ثِيّرِ نُ نَ فٍيلِ كُي، كْنْ دَنشَنِيَتْي حَمَ نُ نَ عَلَ مَشَندِقٍ عَ بّ.
\p 
\v 6 كْي رَ، بٍينُن هٍرٌدٍ شَ ثِيّرِ مَكِيتِ، عَ نُ شِقٍ سْورِ قِرِن تَفِ، يْلْنشْنيِ بَلَنشِ عَ مَ. سْورِ فبّتّيٍ قَن نُ فٍيلِ نَادّ كَنتَقٍ.
\v 7 مَرِفِ شَ مَلٍكّ ندٍ نَشَ مِنِ عَ مَ تّرّننَ رَ. يَنبّ نَشَ فٍيلِ كُي عِيَلَن. مَلٍكّ نَشَ ثِيّرِ سّيتِ مَبْنبْ، عَ شَ شُنُ، عَ قَ عَ قَلَ عَ بّ، «كٍلِ، عِ شُلُن!» يْلْنشْنيِيٍ نَشَ يٌلٌن عَ بّلّشّ رَ كٍرٍن نَ.
\v 8 مَلٍكّ نَشَ عَ قَلَ عَ بّ، «عِ مَشِرِ، عِ شَ سَنكِرِيٍ سٌ.» عَ تٌ نَ رَبَ، مَلٍكّ مَن نَشَ عَ قَلَ عَ بّ، «دٌنمَ قٍلٍن عِ مَ، بِرَ ﭑ قْشْ رَ.»
\v 9 ثِيّرِ نَشَ مِنِ، عَ بِرَ مَلٍكّ قْشْ رَ، كْنْ عَ مُ عَ كٌلٌن شَ نَ قٍ قِندِشِ نْندِ نَن نَ. عَ نُ بَرَ عَ مَحْشُن، تّمُندٍ عَ قِندِشِ لَامَتُنيِ نَن نَ.
\v 10 عٍ تٌ بَرَ دَنفِ سْورِيٍ سِنفٍ عٍ نُن عَ قِرِن ندٍيٍ رَ، عٍ نَشَ وُرٍ نَادّ لِ نَشَن دّ رَبِشِ تَا مَ، نَ نَشَ رَبِ عَ يّتّ رَ. عٍ نَشَ مِنِ. عٍ مُ نُ عَ عِكُيَشِ كِرَ شْن مَ، مَلٍكّ نَشَ كٍلِ ثِيّرِ شُن.
\p 
\v 11 ثِيّرِ تٌ شَشِلِ سْتْ نَ قٍ مَ، عَ نَشَ عَ قَلَ، «يَكْسِ، ﭑ بَرَ عَ كٌلٌن مَرِفِ نَن عَ شَ مَلٍكّ شّيشِ، عَ شَ ﭑ بَ هٍرٌدٍ يِ رَ. عَ بَرَ ﭑ نَتَنفَ يُوِقِيٍ بّلّشّ.»
\v 12 عَ تٌ كٌلٌن سْتْ يِ قٍ مَ، عَ نَشَ سِفَ يَيَ نفَ مَرِيَمَ شْنيِ، يَيَ نَشَن مَن شِلِ مَرَكِ. مِشِ وُيَشِ نُ مَلَنشِ نَا، عٍ نَ عَلَ مَشَندِقٍ.
\v 13 عَ تٌ نَادّ كْنكْن، كٌنيِ فِنّ ندٍ، نَشَن شِلِ رٌدَ، عَ نَشَ قَ نَادّ رَبِدٍ.
\v 14 عَ تٌ ثِيّرِ شُي مّ، عَ نَشَ حّلّشِن هَن عَ نَشَ نّيمُ نَادّ رَبِقٍ مَ. عَ نَشَ عَ فِ عَ شَ سَ عَ قَلَ بٌورٍيٍ بّ ثِيّرِ نَ نَادّ رَ.
\v 15 عٍ نَشَ عَ قَلَ عَ بّ، «عِ بَرَ دَشُ.» كْنْ عَ تٌ عٍ كَرَشَن، عٍ نَشَ عَ قَلَ، «عَ شَ مَلٍكّ نَ عَ رَ.»
\v 16 نَ تّمُي بِرِن ثِيّرِ نُ نَ نَادّ كْنكْنقٍ. عٍ تٌ نَادّ رَبِ، عٍ نَشَ كَابَ عَ تٌقٍ مَ.
\v 17 ثِيّرِ تٌ عٍ مَسَبَرِ عَ بّلّشّ رَ، عَ نَشَ عَ يَبَ عٍ بّ مَرِفِ عَ رَ مِنِشِ فٍيلِ كُي كِ نَشّ. عَ نَشَ عَ قَلَ، «وٌ يِ قٍ رَفبِلٍن يَكِ نُن نفَشَكٍرٍنيِيٍ مَ.» نَ شَنبِ، عَ نَشَ مِنِ، عَ شَ سِفَ يِرٍ فبّتّ.
\p 
\v 18 كُيٍ تٌ عِبَ، سْورِيٍ نَشَ لُ مَءِمَشّ شُنفبٍ كُي، عَ كٌلٌنقٍ رَ ثِيّرِ شَ قٍ نِيَشِ كِ نَشّ.
\v 19 هٍرٌدٍ نَشَ عَ قٍن، كْنْ عَ مُ عَ تٌ. عَ نَشَ سْورِيٍ مَكِيتِ، عَ نَشَ يَامَرِ قِ عَ عٍ بِرِن شَ قَشَ. نَ شَنبِ، عَ نَشَ كٍلِ يُدَيَ، عَ نَشَ فٌرٌ سٍسَرٍ، عَ شَ سَشَنيِ رَدَنفِ مّننِ.
\s1 هٍرٌدٍ شَ قَشّ
\p 
\v 20 تِرٍكَيٍ نُن سِدْنكَيٍ نُ نَ لَنتَرٍيَ كُي عٍ نُن هٍرٌدٍ رَ نَ تّمُي. عٍ نَشَ لَن عٍ بٌرٍ مَ، عٍ شَ سِفَ هٍرٌدٍ يِرٍ، عٍ شَ وْيّن. عٍ تٌ بَرَ بِلَسِتُ مَسْتْ، مَنفّ شَ بَتُلَ كُنتِفِ، عٍ نَشَ هٍرٌدٍ مَيَندِ لَنيِ شِرِقٍ رَ عٍ تَفِ، بَرِ مَ عٍ شَ بْشِ شَشِلِ نُ تِشِ هٍرٌدٍ شَ بْشِ بَلٌي نَن نَ.
\v 21 مَلَن لْشْي، هٍرٌدٍ نُ مَشِرِشِ عَ شَ مَنفّ سٌسٍيٍ كُي، عَ نَشَ مَسٍنيِ تِ حَمَ بّ، عَ دْشْشِ مَنفّ كِبَنيِ كُي.
\v 22 مِشِيٍ نَشَ سْنشْي رَتٍ، «عَلَ شُي نَن يِ كِ، عَدَ مَ شُي مُ عَ رَ.»
\v 23 مَرِفِ شَ مَلٍكّ ندٍ نَشَ عَ رَقُرَ كٍرٍن نَ، بَرِ مَ عَ مُ عَلَ مَتْشْ. كُلِيٍ نَشَ عَ دٌن، عَ نَشَ قَشَ.
\p 
\v 24 نَ وَشَتِ مِشِ فبٍفبٍ نَشَ عَلَ شَ وْيّنيِ رَ مّ، دَنشَنِيَتْييٍ كْنتِ شُن نَشَ مَسَ.
\v 25 بَرَنَبَسِ نُن سْلُ تٌ فّ شّيرَ عِبَدٍ دَرِ سَلَمُ، عٍ نَشَ فبِلٍن يَيَ شَنِن نَ عٍ شُن مَ، عٍ نَشَن شِلِ قَلَمَ مَرَكِ.
\c 13
\s1 بَرَنَبَسِ نُن سْلُ سُفَندِقٍ
\p 
\v 1 نَمِحْنمّيٍ نُن كَرَ مْشْيٍ نُ نَ عَنتِيْكِ دَنشَنِيَتْي حَمَ تَفِ؛ بَرَنَبَسِ، سِمٍيْن نَشَن شِلِ سَ نِفٍرِ، لُسُسِ سِرٍنِكَ، مَنَهّن، نُن سْلُ. مَنَهّن نُن مَنفّ هٍرٌدٍ نَن شُرُ يِرٍ كٍرٍن.
\v 2 عٍ تٌ نُ مَرِفِ بَتُقٍ، عٍ مَن نُ سُنقٍ، عَلَ شَشِلِ سّنِيّنشِ نَشَ عَ قَلَ عٍ بّ، «وٌ بَرَنَبَسِ نُن سْلُ تِ ﭑ بّ عٍ شَتِ مَ، وَلِ شَ قٍ مَ ﭑ عٍ شِلِشِ نَشَن مَ.»
\v 3 عَوَ، عٍ تٌ فّ سُندٍ، نُن عَلَ مَشَندِدٍ، عٍ نَشَ عٍ بّلّشّ سَ بَرَنَبَسِ نُن سْلُ مَ، عٍ شَ عٍ تَشُ عَلَ رَ. نَ شَنبِ، عٍ نَشَ عٍ بّحِن، عٍ سِفَ.
\s1 عٍ سِفَقٍ سِثِرِ
\p 
\v 4 عَلَ شَشِلِ سّنِيّنشِ تٌ بَرَنَبَسِ نُن سْلُ شّي، عٍ نَشَ فٌرٌ سٍلُسِيَ، عٍ قَ بَكِ كُنكُي كُي سِفَقٍ رَ سِثِرِ سُرِ مَ.
\v 5 عٍ تٌ سٌ سَلَمِن، عٍ نَشَ سٌ عَلَ شَ مَسٍنيِ كَوَندِقٍ يُوِقِيٍ شَ سَلِدٍ كُي. يَيَ نَن نُ عٍ مَلِمَ رَ.
\v 6 عٍ تٌ بَرَ سُرِ عِفِرِ هَن ثَقٌسِ، عٍ نَشَ دُورٍ ندٍ لِ نَا، يُوِقِ نَشَن نُ عَ يّتّ قِندِشِ نَمِحْنمّ وُلٍ قَلّ رَ، نَشَن نُ شِلِ بَرِ يٍسُ شَ دِ.
\v 7 عَ نُ نَ مَنفّ سّرِفُ ثْلُ سّيتِ مَ، نَشَن شَشِلِ نُ قَن. نَ تَن نَشَ بَرَنَبَسِ نُن سْلُ شِلِ، بَرِ مَ عَ نُ وَ مَ عَلَ شَ مَسٍنيِ رَ مّقٍ.
\p 
\v 8 كْنْ نَ دُورٍ عٍ نَشَن مَ عٍلِمَسِ، عَ شِلِ وَ مَ عَ مَسٍنقٍ عَ دُورٍ نَن عَ رَ، عَ نَشَ عٍ مَتَندِ. عَ نُ كَتَقٍ نّ عَلَكٌ عَ شَ مَنفّ شَ بَ دَنشَنِيَ كِرَ شْن مَ.
\v 9 عَوَ سْلُ، نَشَن مَن شِلِ ثْلُ، عَلَ شَشِلِ سّنِيّنشِ تٌ فٌرٌ عَ مَ، عَ نَشَ عَ يَ بَنبَن عَ رَ،
\v 10 عَ نَشَ عَ قَلَ عَ بّ، «كَلَبَنتٍ نُن يَنقَنتٍ نَن عِ رَ. عِبُلِسَ شَ دِ، تِنشِنتَرٍ، عِ مُ بَمَ مَرِفِ شَ كِرَ تِنشِنشِ دَلِنقٍ؟
\v 11 عَوَ يَكْسِ، مَرِفِ بَرَ عَ بّلّشّ سَ عِ مَ. عِ قَمَ نّ دْنشُدٍ. وَشَتِ ندٍ بُن مَ، عِ مُ سٌفٍ تٌمَ.» دِ مِ نَشَ دُ سُ عَ شُن نَ كٍرٍن نَ. عَ نَشَ سٌ مِلِمَلَقٍ نَ مَ، عَ نُ مِشِيٍ قٍن نَشٍيٍ عَ يِ رَ سُشُمَ.
\v 12 عَوَ، مَنفّ سّرِفُ ثْلُ تٌ نَ تٌ، عَ نَشَ دَنشَنِيَ مَرِفِ شَ سّرِيّ مَ.
\s1 عٍ سِفَقٍ ثِسِدِيَ بْشِ مَ
\p 
\v 13 ثْلُ نُن عَ بٌورٍيٍ تٌ بَكِ كُنكُي كُي ثَقٌسِ، عٍ نَشَ سِفَ ثّرِفَ نَشَن نَ ثَنقِلِيَ بْشِ مَ. يَيَ نَشَ عَ بَ عٍ مَ، عَ نَشَ فبِلٍن دَرِ سَلَمُ.
\v 14 مّننِ عٍ نَشَ تِ كِرَ شْن. عٍ نَشَ سٌ عَنتِيْكِ نَشَن نَ ثِسِدِيَ بْشِ مَ. عٍ تٌ سٌ سَلِدٍ كُي مَلَبُ لْشْي، عٍ نَشَ عٍ مَفٌرٌ.
\v 15 تَوُرٍتَ مُنسَ نُن نَمِحْنمّيٍ شَ كِتَابُي شَرَنيِ تٌ بَ عَ رَ، سَلِدٍ شُنمَتِيٍ نَشَ شّيرَ تِ عٍ مَ، عٍ نُ عَ قَلَ، «وٌن نفَشَكٍرٍنيِيٍ، شَ مَرَ سِ ندٍ نَ وٌ يِ رَ حَمَ بّ، وٌ عَ قَلَ.»
\v 16 ثْلُ تٌ كٍلِ، عَ نَشَ عٍ مَسَبَرِ، عَ قَ عَ قَلَ، «عِسِرَيِلَكَيٍ نُن وٌ تَن نَشٍيٍ فَاشُشِ عَلَ يَ رَ، وٌ وٌ تُلِ مَتِ.
\v 17 عِسِرَيِلَ حَمَ مَرِفِ عَلَ بَرَ وٌن بَبَيٍ سُفَندِ. عَ نَشَ عٍ رَوُيَ مِسِرَ بْشِ مَ. نَ شَنبِ عَ نَشَ عٍ رَ مِنِ نَا عَ سّنبّ رَ.
\v 18 عَ نَشَ عٍ رَبَلٌ حّ تٌنفٌ نَانِ حْندْن فبٍنفبٍرٍنيِ مَ.
\v 19 عَ تٌ سِ سٌلٌقٍرٍ هَلَكِ كَنَان بْشِ مَ، عَ نَشَ نَ بْشِيٍ قِ عِسِرَيِلَكَيٍ مَ.
\v 20 حّ كّمّ نَانِ حّ تٌنفٌ سُولِ بُن مَ، عَ نَشَ مَنفّيٍ تِ عٍ شُن مَ هَن عَننَبِ سَمُوٍلِ شَ تّمُي.
\v 21 عَوَ، عٍ تٌ وَ مَنفّ بٍلٍبٍلٍ شْن مَ، عَلَ نَشَ كِسُ شَ دِ، سْلُ، نَشَن قَتَن بُنيَمِن بْنسْي رَ، عَ نَشَ نَ تِ عٍ شُن مَ. عَ شَ مَنفّيَ نَشَ بُ حّ تٌنفٌ نَانِ.
\v 22 عَ تٌ سْلُ بَ مَنفّيَ رَ، عَ نَشَ دَوُدَ قِندِ مَنفّ رَ عٍ شُن. عَ يِ سٍيدٍيَ مَسٍن نَ نَن مَ، ‹ﭑ بَرَ دَوُدَ تٌ، يِسَيِ شَ دِ، نَشَن كّحَ رَقَن ﭑ مَ. عَ تَن نَن ﭑ سَفٌ بِرِن نَكَمَلِمَ.›»
\p 
\v 23 «عَلَ عِسِرَيِلَ رَكِسِمَ رَ مِنِشِ دَوُدَ بْنسْي نَن يَ مَ، نَشَن لَنشِ عِسَ مَ، عَلْ عَ لَايِدِ تٌنفٌشِ كِ نَشّ.
\v 24 بٍينُن عِسَ شَ قَ، يَيَ نُ بَرَ مِشِيٍ كَوَندِ عٍ شَ تُوبِ، عٍ شَ عٍ شُنشَ يٍ شْورَ.
\v 25 عَ شَ وَلِ رَحْن تّمُي، عَ نَشَ عَ قَلَ، ‹ﭑ مُ قِندِشِ مِشِ شَ رَ، وٌ نَشَن مَحْشُنشِ. نَ كَنيِ قَمَ ﭑ شَنبِ رَ. نَ بِنيّ مُ نَ ﭑ يِ رَ ﭑ شَ عَ شَ سَنكِرِ مَقُلُن.›»
\p 
\v 26 «ﭑ نفَشَكٍرٍنيِيٍ، عِبُرَهِمَ بْنسْي شَ دِيٍ نُن وٌ تَن نَشٍيٍ فَاشُمَ عَلَ يَ رَ، يِ كِسِ مَسٍنيِ رَ سَنبَشِ وٌن تَن نَن مَ.
\v 27 دَرِ سَلَمُكَيٍ نُن عٍ شُنمَتِيٍ مُ تِن عِسَ رَ. عٍ مُ قَهَامُي سْتْ نَمِحْنمّيٍ شَ مَسٍنيِ مَ، نَشَن شَرَنمَ مَلَبُ لْشْي بِرِن. كْنْ عٍ نَشَ نَ مَسٍنيِ يَتِ رَكَمَلِ عِسَ تْوحّفّقٍ رَ.
\v 28 هَلِ عٍ تٌ مُ سٍسٍ تٌ عَ لَنمَ عَ شَ قَشَ نَشَن مَ، عٍ نَشَ ثِلَتِ مَشَندِ عَ شَ عَ قَشَ.
\v 29 نَ كُي، عٍ نَشَ قٍ بِرِن نَكَمَلِ نَشٍيٍ سّبّشِ عَ شُن. عٍ مَن نَشَ عَ رَفٌرٌ وُرِ مَفَلَنبُشِ مَ، عٍ عَ قُرٍ سَ فَبُرِ كُي.
\v 30 كْنْ عَلَ نَشَ عَ رَكٍلِ قَشّ مَ.
\v 31 مِشِ فبٍفبٍ نَشٍيٍ عِسَ مَتِ كٍلِقٍ فَلِلٍ سِفَقٍ دَرِ سَلَمُ، نٍيٍ نَشَ عَ تٌ شِ وُيَشِ بُن مَ. يَكْسِ عٍ بَرَ قِندِ عَ شَ سٍيدٍيٍ رَ حَمَ تَفِ.»
\p 
\v 32 «عَوَ، مُشُ تَن قَن يِ شِبَارُ قَنيِ مَسٍنمَ نّ وٌ بّ، عَلَ لَايِدِ نَشَن تٌنفٌ وٌن بٍنبَيٍ بّ.
\v 33 عَلَ بَرَ عَ رَكَمَلِ وٌن تَن بّ، عٍ شَ دِيٍ. عَ بَرَ عِسَ رَكٍلِ قَشّ مَ عَلْ عَ سّبّشِ يَبُرَ سٌرَ قِرِن ندٍ كُي كِ نَشّ. عَ نَشّ، ‹ﭑ مَ دِ نَن عِ رَ. ﭑ بَرَ قِندِ عِ بَبَ رَ تٌ.›
\v 34 عَ بَرَ عَ رَكٍلِ قَشّ مَ، عَلَكٌ عَ نَشَ بْرْ. عَ نَ نَن مَسٍنشِ يِ كِ، ‹لَايِدِ سّنِيّنشِيٍ، نَشٍيٍ مُ كَنَمَ، ﭑ نَشٍيٍ تٌنفٌشِ دَوُدَ بّ، ﭑ نٍيٍ تٌنفٌمَ نّ وٌ قَن بّ.›
\v 35 نَ نَ عَ رَ، عَ مَن نَ مَسٍنيِ قَلَشِ يِرٍ فبّتّ. عَ نَشّ، ‹عِ مُ عِ شَنُنتٍنيِ لُمَ فَبُرِ كُي.›
\v 36 دَوُدَ تٌ فّ عَلَ سَفٌ رَبَدٍ عَ شَ وَشَتِ، عَ قَشَ نّ، عَ عَ بٍنبَيٍ لِ فَبُرِ كُي، عَ مَن بْرْ نَا.
\v 37 كْنْ عَلَ مِشِ نَشَن نَكٍلِشِ قَشّ مَ، نَ تَن مُ بْرْ.»
\p 
\v 38 «ﭑ نفَشَكٍرٍنيِيٍ، نَشَن كَوَندِشِ وٌ بّ، وٌ شَ عَ كٌلٌن يُنُبِ شَقَرِ مَ عَ تَن نَن سَابُي رَ.
\v 39 نَشَن يٌ دَنشَنِيَ، نَ كَنيِ بَرَ كِسِ يُنُبِيٍ مَ، عَننَبِ مُنسَ شَ سّرِيّ مُ نْ وٌ رَكِسِدٍ نَشٍيٍ مَ.
\v 40 نَ كُي، وٌ وٌ مّينِ نَشَن قَلَشِ نَمِحْنمّيٍ شَ كِتَابُييٍ كُي، عَ نَشَ قَ وٌ لِ. عٍ نَشّ،
\v 41 ‹وٌ عَ مَتٌ، وٌ تَن مِشِ مَيٍلٍيٍ، وٌ دّ شَ عِشَرَ، وٌ بَرَ لْي، بَرِ مَ ﭑ قَمَ كّوَلِ رَبَدٍ وٌ شَ لْشْييٍ نَن مَ، وٌ مُ لَمَ نَشَن نَ هَلِ عٍ عَ يَبَ وٌ بّ.›»
\p 
\v 42 سْلُ نُن بَرَنَبَسِ تٌ مِنِ، مِشِيٍ نَشَ عٍ مَشَندِ عٍ مَن شَ يِ مَسٍنيِ تِ مَلَبُ لْشْي نَشَن مَن قَمَ كْرّ.
\v 43 عَوَ، حَمَ تٌ يٍنسٍن، يُوِقِ وُيَشِ نُن مِشِ نَشٍيٍ نُ سٌشِ يُوِقِ شَ دِينّ كُي، نٍيٍ نَشَ بِرَ ثْلُ نُن بَرَنَبَسِ قْشْ رَ. ثْلُ نُن بَرَنَبَسِ نَشَ عٍ رَ سِ عٍ شَ لُ عَلَ شَ هِننّ كُي.
\v 44 نَ مَلَبُ لْشْي شُنفبِلٍنيِ، تَاكَيٍ بِرِن نَشَ عٍ مَلَن عَلَ شَ مَسٍنيِ رَ مّدٍ.
\v 45 يُوِقِيٍ تٌ حَمَ تٌ، تْونّ نَشَ عٍ سُشُ. عٍ نَشَ تِ ثْلُ كَنكٍ، عٍ نُ عَ شَ وْيّنيِ مَتَندِ، عٍ نُ عَ كٌنبِ.
\v 46 ثْلُ نُن بَرَنَبَسِ نَشَ عَ قَلَ عٍ بّ حَمَ تَفِ، «عَ لَنمَ عَلَ شَ مَسٍنيِ شَ مَسٍن وٌ تَن نَن سِنفٍ بّ، كْنْ وٌ بَرَ تٌندِ عَ رَ. نَ كُي، وٌ يّتّ بَرَ عَ قَلَ عَ مُ دَشَ وٌ شَ كِسِ سْتْ. يَكْسِ مُشُ مُشُ يَ رَقِندِ مَ سِ فبّتّيٍ نَن مَ،
\v 47 عَلْ مَرِفِ مُشُ يَمَرِشِ كِ نَشّ. عَ نَشّ،
\q1 ‹ﭑ بَرَ عِ تِ عِ شَ قِندِ نَءِيَلَنيِ رَ سِيٍ بّ،
\q1 كِسِ شَنِنقٍ رَ هَن دُنِحَ دَنيِ.›»
\p 
\v 48 مِشِ نَشٍيٍ مُ قِندِشِ يُوِقِ رَ، نٍيٍ تٌ نَ مّ، عٍ نَشَ سّيوَ. عٍ نَشَ عٍ مَرِفِ شَ وْيّنيِ مَتْشْ. نَشٍيٍ بِرِن نُ سُفَندِشِ كِسِ قٍ رَ، نٍيٍ نَشَ دَنشَنِيَ.
\p 
\v 49 مَرِفِ شَ مَسٍنيِ نَشَ يٍنسٍن بْشِ بِرِن كُي.
\v 50 كْنْ يُوِقِيٍ نَشَ فِنّ هَفِفّيٍ، نَشٍيٍ نُ سٌشِ يُوِقِيٍ شَ دِينّ كُي، نُن نَ تَا كُنتِفِيٍ، عٍ نَشَ نٍيٍ بْحّيٍ رَتٍ. عٍ نَشَ تْورّ دْشْ ثْلُ نُن بَرَنَبَسِ مَ هَن عٍ نَشَ عٍ كٍرِ عٍ شَ بْشِ مَ.
\v 51 ثْلُ نُن بَرَنَبَسِ نَشَ عٍ سَنيِ رَكٌنكٌن، نَ شَ قِندِ سٍيدٍ رَ عَ لَنتَرٍيَ نَ عٍ تَفِ. نَ شَنبِ عٍ نَشَ سِفَ عِكٌنِيٌن.
\v 52 عِسَ قْشِرَبِرّيٍ نَشَ سّيوَ، عٍ مَن نُ قَ عَلَ شَشِلِ سّنِيّنشِ سْتْ.
\c 14
\s1 عٍ سِفَقٍ عِكٌنِيٌن
\p 
\v 1 ثْلُ نُن بَرَنَبَسِ نَشَ سٌ يُوِقِيٍ شَ سَلِدٍ كُي عِكٌنِيٌن. عٍ نَشَ وْيّن عَ قَنيِ رَ هَن يُوِقِيٍ نُن فِرّكِكَ فبٍفبٍ نَشَ دَنشَنِيَ.
\v 2 كْنْ يُوِقِيٍ نَشٍيٍ مُ دَنشَنِيَ، نٍيٍ نَشَ فِرّكِكَيٍ كُي عِسٌ، عَلَكٌ عٍ بْحّ شَ تٍ دَنشَنِيَتْييٍ شِلِ مَ.
\v 3 ثْلُ نُن بَرَنَبَسِ نَشَ تّمُي شْنكُيٍ رَبَ عِكٌنِيٌن، عٍ نُ وْيّن لَنلَنتٍيَ كُي. مَرِفِ نَشَ تْنشُمَيٍ نُن كَابَنَكٌي رَبَ عٍ سَابُي رَ، عٍ تَن نَشٍيٍ قِندِشِ سٍيدٍ رَ عَلَ شَ مَسٍنيِ بّ، عَ شَ هِننّ شَ قٍ رَ.
\v 4 تَاكَيٍ نَشَ عِتَشُن دْشْ قِرِن. ندٍيٍ نَشَ لُ يُوِقِيٍ شَ سّيتِ، ندٍيٍ قَن نَشَ لُ شّيرَيٍ شَ سّيتِ.
\v 5 فِرّكِكَيٍ نُن يُوِقِيٍ نُن عٍ شَ مَنفّيٍ نَشَ لَن عٍ شَ قٍ حَاشِ دْشْ عٍ مَ، عٍ مَن شَ عٍ مَفْنْ هَن عٍ شَ قَشَ.
\v 6 ثْلُ نُن بَرَنَبَسِ تٌ نَ كٌلٌن، عٍ نَشَ عٍ فِ، عٍ سِفَ لِكَيٌنِ تَايٍ كُي، لِسِتِرٍ نُن دٍرِبٍ، عَ نُن نَ رَبِلِنيِ.
\v 7 عٍ نَشَ شِبَارُ قَنيِ كَوَندِ تِ نَا.
\s1 عٍ سِفَقٍ لِسِتِرٍ
\p 
\v 8 مِشِ ندٍ نُ دْشْشِ لِسِتِرٍ، نَمَتّ نَن نُ عَ رَ، عَ بَرِ نَ كِ نّ لَنيُرُ كُي. عَ مُ نُ نْمَ عَ حّرّدٍ هَلِ كٍرٍن.
\v 9 عَ نُ عَ تُلِ مَتِمَ ثْلُ شَ مَسٍنيِ نَن نَ. ثْلُ نَشَ عَ يَ تِ عَ رَ. عَ نَشَ عَ تٌ عَ دَنشَنِيَشِ عَ يَلَن قٍ مَ.
\v 10 عَ نَشَ عَ قَلَ عَ شُي عِتٍشِ رَ، «كٍلِ، عِ تِ عِ سَنيِيٍ شُن نَ. عَ نَشَ كٍلِ كٍرٍن نَ، عَ حّرّ.»
\v 11 حَمَ تٌ نَ تٌ، ثْلُ نَشَن نَبَشِ، عٍ نَشَ عَ قَلَ لِكَيٌنِ شُي، «عَلَيٍ بَرَ عٍ قَلِن مِشِيٍ، عٍ فٌرٌ وٌن تَفِ.»
\v 12 عٍ نَشَ شِلِ ندٍ شَبُ عٍ شُن، عٍ بَرَنَبَسِ شِلِ نَشَ سَ سٍيُسِ، ثْلُ قَن هٍرٍ مّسِ، بَرِ مَ عَ تَن نَن نُ وْيّنمَ.
\v 13 سٍيُسِ شَ سّرّشّدُبّ، نَشَن شَ سَلِدٍ نُ نَ تَا سٌدٍ دّ رَ، نَ نَشَ قَ تُورَيٍ نُن قُفٍيٍ رَ نَادّيٍ بِرِ رَ. عَ تَن نُن حَمَ نَشَ وَ سّرّشّ بَقٍ عٍ بّ.
\p 
\v 14 شّيرَيٍ بَرَنَبَسِ نُن ثْلُ تٌ نَ كٌلٌن، عٍ نَشَ عٍ شَ سٌسٍيٍ عِبْو، عٍ مَن قَ فبٍلٍفبٍلٍ حَمَ رَ.
\v 15 عٍ نَشَ عَ قَلَ، «وٌ تَن، مُنقٍ رَ وٌ يِ قٍ مْولِ رَبَمَ؟ مِشِ نَن مُشُ رَ، عَلْ وٌ تَن. مُشُ قَشِ شِبَارُ قَنيِ نَن نَ وٌ بّ. مُشُ وٌ رَ سِمَ وٌ شَ بَ يِ قُقَقُ قٍيٍ مَ عَلَكٌ وٌ شَ بِرَ عَلَ شَ كِرَ قْشْ رَ، نَشَن كٌورٍ نُن بْشِ، بَا نُن سٍ بِرِن دَا.
\v 16 تّمُي دَنفِشِ عَلَ عَ لُ نّ سِ بِرِن شَ بِرَ عٍ يّتّ كَن شَ كِرَيٍ قْشْ رَ.
\v 17 هَلِ نَ بِرِن كُي، عَ نُ قٍ قَنيِ رَبَمَ نَشَن قِندِ سٍيدٍ رَ عَ شَ قٍ رَ. تُنّ يٍ نُ قَمَ كٍلِ كٌورٍ مَ. سَنسِيٍ نُ قَنمَ عَ تّمُي عَلَكٌ وٌ شَ بَلٌ، وٌ مَن شَ سّيوَ وٌ بْحّ كُي.»
\v 18 ثْلُ نُن بَرَنَبَسِ نَشَ كَتَ كِ قَنيِ رَ عَلَكٌ عٍ نَشَ سّرّشّ بَ عٍ بّ.
\p 
\v 19 عَوَ، يُوِقِيٍ نَشَ قَ كٍلِ عَنتِيْكِ نُن عِكٌنِيٌن. عٍ نَشَ حَمَ كُي عِسٌ هَن عٍ نَشَ ثْلُ مَفْنْ عَ شَ قَشَ. عٍ نَشَ مِنِ عَ بُبُ رَ تَا قَرِ مَ بَرِ مَ عٍ تَن بّ عَ بَرَ فّ قَشَدٍ.
\v 20 كْنْ عِسَ قْشِرَبِرّيٍ تٌ عَ رَبِلِن، عَ نَشَ كٍلِ، عَ مَن نَشَ فبِلٍن تَا كُي.
\s1 عٍ فبِلٍنقٍ عَنتِيْكِ سِرِيَ بْشِ مَ
\p 
\v 21 كُيٍ تٌ عِبَ، ثْلُ نُن بَرَنَبَسِ نَشَ سِفَ دٍرِبٍ. عٍ تٌ فّ كَوَندِ تِدٍ تَا كُي، مِشِ فبٍفبٍ نَشَ قِندِ عِسَ قْشِرَبِرّيٍ رَ. نَ شَنبِ عٍ نَشَ فبِلٍن لِسِتِرٍ، عِكٌنِيٌن، نُن عَنتِيْكِ.
\v 22 عٍ نُ عِسَ قْشِرَبِرّيٍ رَلِمَنِيَ. عٍ مَن نُ عٍ رَ سِ عٍ شَ سَبَتِ دَنشَنِيَ كُي. عٍ نُ عَ قَلَ، «وٌن مُ سٌمَ عَلَ شَ مَنفّيَ نِينِ بُن مَ قٌ وٌن شَ تْورْ.»
\v 23 عٍ نَشَ كُنتِفِيٍ سُفَندِ دَنشَنِيَتْي حَمَ كٍرٍن كٍرٍن مَ بّ. عٍ تٌ فّ سَلِدٍ نُن سُندٍ، عٍ نَشَ عٍ تَشُ مَرِفِ رَ، عٍ نُ دَنشَنِيَشِ نَشَن مَ.
\v 24 عَوَ، عٍ تٌ ثِسِدِيَ عِفِرِ، عٍ نَشَ قَ ثَنقِلِيَ.
\v 25 عٍ نَشَ كَوَندِ تِ ثّرِفَ، عٍ نَشَ فٌرٌ عَتَلٍيَ.
\p 
\v 26 عٍ تٌ كٍلِ مّننِ، عٍ نَشَ بَكِ كُنكُي كُي سِفَقٍ رَ عَنتِيْكِ، عٍ نُ تَشُشِ عَلَ شَ هِننّ رَ دّننَشّ. عٍ نُ بَرَ فّ نَ وَلِ بِرِن نَبَدٍ.
\v 27 عٍ تٌ سٌ، عٍ نَشَ دَنشَنِيَتْي حَمَ مَلَن. عٍ نَشَ قٍ بِرِن دّنتّفّ سَ عٍ بّ عَلَ نَشَن نَبَشِ عٍ سَابُي رَ، نُن عَلَ دَنشَنِيَ نَادّ رَبِشِ سِ فبّتّيٍ بّ كِ نَشّ.
\v 28 عٍ نُن عِسَ قْشِرَبِرّيٍ نَشَ بُ عٍ بٌرٍ رَ.
\c 15
\s1 دَرِ سَلَمُ مَلَنيِ
\p 
\v 1 مِشِ ندٍيٍ نَشٍيٍ كٍلِ يُدَيَ، عٍ نَشَ عَ قَلَ عِسَ قْشِرَبِرّيٍ بّ، «شَ وٌ مُ وٌ سُننَ عَننَبِ مُنسَ شَ نَامُنيِ كِ مَ، وٌ مُ نْمَ كِسِدٍ.»
\v 2 ثْلُ نُن بَرَنَبَسِ نَشَ وْيّنيِ شْرْشْي قَلَ عٍ بّ. عٍ نَشَ نَتّ تٌنفٌ ثْلُ نُن بَرَنَبَسِ نُن مِشِ ندٍيٍ شَ تٍ دَرِ سَلَمُ شّيرَيٍ نُن كُنتِفِيٍ مَشْرِندٍ يِ قٍ مَ.
\v 3 دَنشَنِيَتْي حَمَ نَشَ عٍ شّي. عٍ دَنفِشِ قٍنِسِيَ نُن سَمَرِ رَ تّمُي نَشّ، عٍ نَشَ عَ مَسٍن مّننِكَيٍ بّ، مِشِ نَشٍيٍ كٍلِشِ سِ فبّتّيٍ مَ، نٍيٍ دَنشَنِيَشِ كِ نَشّ. يِ مَسٍنيِ نَشَ عِسَ قْشِرَبِرّيٍ رَحّلّشِن.
\v 4 عٍ تٌ سٌ دَرِ سَلَمُ، دَنشَنِيَتْي حَمَ نُن شّيرَيٍ، نُن كُنتِفِيٍ نَشَ عٍ رَ سّنّ. عَلَ نَشَن بِرِن نَبَ عٍ سَابُي رَ، عٍ نَشَ نَ يَبَ عٍ بّ.
\v 5 عَوَ، قَرِ سّنِ ندٍ نَشٍيٍ نُ بَرَ دَنشَنِيَ، عٍ نَشَ كٍلِ، عٍ نُ قَ عَ قَلَ، عَ لَنمَ نّ سِ فبّتّ مِشِيٍ شَ سُننَ، عٍ شَ بِرَ عَننَبِ مُنسَ شَ سّرِيّ قْشْ رَ.
\p 
\v 6 شّيرَيٍ نُن كُنتِفِيٍ نَشَ عٍ مَلَن عٍ شَ نَ قٍ مَتٌ.
\v 7 عٍ تٌ نَ قٍ عِسْنشْ سْنشْ، ثِيّرِ نَشَ كٍلِ، عَ عَ قَلَ عٍ بّ، «ﭑ نفَشَكٍرٍنيِيٍ، وٌ عَ كٌلٌن كَقِ تّمُي شْنكُيٍ عَلَ بَرَ ﭑ سُفَندِ وٌ تَفِ، عَلَكٌ سِ فبّتّ مِشِيٍ شَ شِبَارُ قَنيِ مّ ﭑ دّ رَ، عٍ شَ دَنشَنِيَ.
\v 8 عَوَ، عَلَ نَشَن مِشِ سٌندٌنيِ كٌلٌن، نَ بَرَ سٍيدٍيَ رَبَ عٍ بّ، عَ عَ شَشِلِ سّنِيّنشِ قِ عٍ مَ عَلْ وٌن تَن.
\v 9 عَ مُ مِشِ يٌ رَقِسَ عَ بٌورٍ بّ عٍ تَن نُن وٌن تَن تَفِ، بَرِ مَ عَ بَرَ عٍ سٌندٌنيِ رَ سّنِيّن دَنشَنِيَ رَ.
\v 10 يَكْسِ، مُنقٍ رَ وٌ عَلَ مَتٌمَ؟ وٌ نَ كٌتٍ دْشْقٍ عِسَ قْشِرَبِرّيٍ شُن، وٌن بٍنبَيٍ نُن وٌن تَن مُ نَشَن نْمَ.
\v 11 وٌ شَ عَ كٌلٌن عَ وٌن نَكِسِشِ مَرِفِ عِسَ شَ هِننّ نَن نَ عَلْ عٍ تَن قَن.»
\p 
\v 12 حَمَ بِرِن نَشَ دُندُ، عٍ نَشَ عٍ تُلِ مَتِ ثْلُ نُن بَرَنَبَسِ رَ. ثْلُ نُن بَرَنَبَسِ نَشَ عَ تَفِ رَبَ بٌورٍيٍ بّ عَلَ كَابَنَكٌي نُن تْنشُمَيٍ نَشٍيٍ بِرِن نَبَ عٍ سَابُي رَ سِ فبّتّيٍ تَفِ.
\v 13 عٍ تٌ فّ وْيّندٍ، يَكِ نَشَ وْيّنيِ تٌنفٌ، عَ نَشّ،
\v 14 «ﭑ نفَشَكٍرٍنيِيٍ، وٌ وٌ تُلِ مَتِ ﭑ نَ. سِمْن بَرَ عَ يَبَ عَلَ مِشِيٍ سُفَندِ مَ كِ نَشّ سِيٍ يَ مَ، عَ شِلِ سَمَ نَشٍيٍ شُن مَ.
\v 15 نَمِحْنمّيٍ بِرِن شَ مَسٍنيِ لَنشِ نَ نَن مَ. عَ سّبّشِ،
\q1 
\v 16 ‹نَ شَنبِ ﭑ قَمَ نّ
\q1 دَوُدَ شَ بَنشِ بِرَشِ رَكٍلِدٍ.
\q1 ﭑ نَ يِرٍ كَنَشِيٍ رَقَلَمَ نّ،
\q1 ﭑ نَ رَكٍلِمَ نّ،
\q1 
\v 17 عَلَكٌ مِشِ نَشٍيٍ لُشِ عٍ شَ نْ مَرِفِ قٍندٍ،
\q1 سِ فبّتّ نَشٍيٍ بِرِن قِندِ مَ ﭑ فبٍ رَ.
\q1 
\v 18 مَرِفِ شَ مَسٍنيِ نَن نَ كِ،
\q1 نَشَن يِ قٍ كٌلٌن كَبِ عَ قْلّ،
\q1 نَشَن يِ قٍ بِرِن نَفِرِ مَ.›»
\p 
\v 19 «نَ نَ عَ رَ، عَ مُ لَنمَ عَ شَ قِندِ قٍ شْرْشْي رَ سِ فبّتّيٍ بّ نَشٍيٍ وَ مَ بِرَقٍ عَلَ قْشْ رَ.
\v 20 كْنْ وٌن شَ بَتَاشّ سّبّ عٍ مَ، عٍ نَشَ سٍيٍ دٌن نَشٍيٍ بَشِ سّرّشّ رَ كُيٍيٍ بّ. عٍ مَن شَ بَ يّنّ مَ، عَ نُن عٍ نَشَ سُبٍ يُقَشِ دٌن، عٍ مَن نَشَ وُلِ مِن.
\v 21 بَرِ مَ كَبِ وٌن بٍنبَيٍ شَ وَشَتِ، مِشِيٍ نَ تَا بِرِن كُي، نَشٍيٍ عَننَبِ مُنسَ شَ سّرِيّ شَرَنمَ سَلِدٍيٍ كُي مَلَبُ لْشْي.»
\p 
\v 22 عَوَ، شّيرَيٍ نُن كُنتِفِيٍ نُن دَنشَنِيَتْي حَمَ بِرِن نَشَ لَن عَ مَ عٍ شَ مِشِ ندٍيٍ شّي عَنتِيْكِ، نَشٍيٍ ثْلُ نُن بَرَنَبَسِ مَتِمَ. عٍ نَشَ يُدَ سِ نَشَن شِلِ بَرَ سَبَ، نُن سِلَسِ سُفَندِ، شّمّ بِنيٍيٍ نفَشَكٍرٍنيِيٍ يَ مَ.
\v 23 عٍ نَشَ بَتَاشّ كٍرٍن سٌ عٍ يِ رَ نَشَن سّبّشِ، «شّيرَيٍ نُن كُنتِفِيٍ، نَشٍيٍ لَنشِ وٌ نفَشَكٍرٍنيِيٍ مَ، كَتَرَبِ وٌن نفَشَكٍرٍنيِيٍ مَ سِ فبّتّيٍ يَ مَ، نَشٍيٍ نَ عَنتِيْكِ، سِرِيَ، نُن سِلِسِ، مُشُ بَرَ وٌ شّيبُ.
\v 24 مُشُ بَرَ عَ مّ عَ مِشِ ندٍيٍ نَشٍيٍ كٍلِشِ مُشُ يَ مَ، مُشُ مُ حُنفُي سَشِ نَشٍيٍ مَ، عَ نٍيٍ بَرَ وٌ رَكْنتْقِلِ عٍ شَ وْيّنيِ رَ. عٍ بَرَ وٌ بْحّ عِقُ.»
\p 
\v 25 «نَ نَ عَ رَ، مُشُ بَرَ لَن عَ مَ مُشُ شَ شّيرَيٍ شّي وٌ مَ، سَ ثْلُ نُن بَرَنَبَسِ قَرِ، مُشُ شَنُنتٍنيِيٍ،
\v 26 نَشٍيٍ بَرَ مّي عٍ نِي رَ وٌن مَرِفِ عِسَ شَ قٍ رَ، عَلَ شَ مِشِ سُفَندِشِ.
\v 27 مُشُ بَرَ يُدَ سِ نُن سِلَسِ قَن شّي، نَشٍيٍ يِ قٍيٍ تَفِ رَبَمَ وٌ بّ.
\v 28 عَلَ شَشِلِ سّنِيّنشِ نُن مُشُ تَن بَرَ لَن عَ مَ مُشُ نَشَ كٌتٍ فبّتّ دْشْ وٌ شُن قٌ نَشَن دَشَ.
\v 29 عَ تَن نَن يِ كِ؛ وٌ نَشَ سُبٍ دٌن نَشَن بَشِ سّرّشّ رَ كُيٍيٍ بّ، نُن سُبٍ يُقَشِيٍ، وٌ نَشَ وُلِ قَن مِن. وٌ مَن نَشَ يّنّ قَن نَبَ. وٌ لَن وٌ شَ فبِلٍن يِ قٍ بِرِن قْشْ رَ. وٌ سَلَمُ.»
\p 
\v 30 عَوَ، عٍ تٌ بَرَ عٍ حُنفُ حَمَ مَ، عٍ نَشَ سِفَ عَنتِيْكِ، عٍ نَشَ سَ بَتَاشّ سٌ دَنشَنِيَتْي حَمَ يِ رَ.
\v 31 نفَشَكٍرٍنيِيٍ تٌ عَ شَرَن، عٍ نَشَ حّلّشِن، عٍ نَشَ لِمَنِيَ.
\v 32 يُدَ سِ نُن سِلَسِ، نَشٍيٍ يَتِ نُ قِندِشِ نَمِحْنمّيٍ رَ، عٍ نَشَ عٍ كَوَندِ، عٍ نُ عٍ رَلِمَنِيَ وْيّن وُيَشِ رَ.
\v 33 وَشَتِ ندٍ تٌ دَنفِ، عٍ نفَشَكٍرٍنيِيٍ نَشَ عٍ بّحِن بْحّسَ كُي فبِلٍنقٍ عٍ شّيمَيٍ مَ.
\v 34 كْنْ سِلَسِ تَن نَشَ لُ نَا.
\v 35 ثْلُ نُن بَرَنَبَسِ نَشَ لُ عَنتِيْكِ، عٍ نُن عٍ بٌورٍ وُيَشِ عٍ نُ قَ مِشِيٍ شَرَن، عٍ مَن نُ مَرِفِ شَ شِبَارُ قَنيِ كَوَندِ تِ.
\s1 ثْلُ نُن بَرَنَبَسِ قَتَنقٍ
\p 
\v 36 لْشْي ندٍيٍ تٌ دَنفِ، ثْلُ نَشَ عَ قَلَ بَرَنَبَسِ بّ، «وٌن شَ فبِلٍن تَا بِرِن كُي وٌن مَرِفِ شَ مَسٍنيِ كَوَندِشِ دّننَشّ، وٌن شَ عَ مَتٌ وٌن نفَشَكٍرٍنيِيٍ دَنشَنِيَتْييٍ نَ كِ نَشّ نَا.»
\v 37 بَرَنَبَسِ نُ وَ مَ يَيَ قَن شَنِنقٍ، نَشَن شِلِ مَرَكِ.
\v 38 كْنْ ثْلُ نَشَ عَ قَلَ عَ مُ لَن عٍ شَ مِشِ شَنِن عٍ شُن مَ نَشَن كٍلِ عٍ شُن مَ ثَنقِلِيَ، عَ مُ تِن بِرَدٍ عٍ قْشْ رَ عٍ شَ وَلِ كُي.
\v 39 نَ لَنتَرٍيَ نَشَ شْرْشْ هَن عَ نَشَ قِندِ قَتَنيِ رَ. بَرَنَبَسِ نَشَ مَرَكِ تٌنفٌ، عٍ نَشَ بَكِ كُنكُي كُي سِفَقٍ رَ سِثِرِ سُرِ مَ.
\v 40 عٍ نفَشَكٍرٍنيِيٍ تٌ عٍ تَشُ مَرِفِ شَ هِننّ رَ، ثْلُ نَشَ سِلَسِ تٌنفٌ، عٍ نَشَ سِفَ
\v 41 سِرِيَ نُن سِلِسِ بْشِيٍ مَ، عٍ دَنشَنِيَتْي حَمَيٍ رَلِمَنِيَ.
\c 16
\s1 تِمٌتٍ بِرَقٍ ثْلُ نُن سِلَسِ قْشْ رَ
\p 
\v 1 ثْلُ نَشَ سِفَ دٍرِبٍ نُن لِسِتِرٍ. عِسَ قْشِرَبِرّ ندٍ نُ نَ، عَ شِلِ تِمٌتٍ. يُوِقِ فِنّ دَنشَنِيَتْي ندٍ شَ دِ نَن نُ عَ رَ. عَ بَبَ فِرّكِكَ نَن نُ عَ رَ.
\v 2 لِسِتِرٍ نُن عِكٌنِيٌن نفَشَكٍرٍنيِيٍ نُ عَ شِلِ قَنيِ قَلَمَ.
\v 3 ثْلُ تٌ وَ عَ شَنِنقٍ عَ شُن، عَ نَشَ عَ سُننَ يُوِقِيٍ شَ قٍ رَ نَشٍيٍ نُ نَ مّننِ، بَرِ مَ بِرِن نُ عَ كٌلٌن عَ بَبَ فِرّكِكَ نَ عَ رَ.
\p 
\v 4 عٍ نَشَ شّيرَيٍ نُن عِسَ قْشِرَبِرّيٍ كُنتِفِ نَشٍيٍ نُ نَ دَرِ سَلَمُ، عٍ نَشَ نٍيٍ شَ نَتّ مَسٍن دَنشَنِيَتْييٍ بّ نَ تَايٍ كُي، عٍ شَ عَ رَبَتُ.
\v 5 دَنشَنِيَتْي حَمَيٍ شَ دَنشَنِيَ سّنبّ شُن نُ مَسَمَ، دَنشَنِيَتْي كْنتِ قَن شُن نُ مَسَ لْشْ يٌ لْشْ.
\s1 ثْلُ لَامَتُنيِ تٌقٍ تِرٌيَسِ
\p 
\v 6 عَلَ شَشِلِ سّنِيّنشِ تٌ مُ تِن عٍ شَ كَوَندِ تِ عَسِ بْشِ مَ، عٍ نَشَ قِرِفِيَ نُن فَلَتِ بْشِ عِفِرِ.
\v 7 عٍ تٌ مَكْرّ مِسِ بْشِ رَ، عٍ نَشَ وَ سٌقٍ بِتِنِيَ، كْنْ عِسَ شَشِلِ مُ تِن عٍ شَ سِفَ نَا.
\v 8 عَوَ، عٍ نَشَ مِسِ عِفِرِ، عٍ نَشَ فٌرٌ تِرٌيَسِ.
\v 9 كْي رَ، ثْلُ نَشَ لَامَتُنيِ تٌ. مَسٍدٌنكَ ندٍ نَشَ كٍلِ، عَ قَ عَ مَشَندِ، «قَ مَسٍدٌن بْشِ مَ، عِ شَ قَ مُشُ مَلِ.»
\v 10 ثْلُ لَامَتُنيِ تٌ شَنبِ، مُشُ نَشَ لَ عَ رَ عَ مَرِفِ بَرَ مُشُ شِلِ شِبَارُ قَنيِ كَوَندِقٍ رَ نَا. مُشُ نَشَ كَتَ سِفَقٍ رَ مَسٍدٌن كٍرٍن نَ.
\s1 لِدِ شُنشَقٍ يٍ شْورَ
\p 
\v 11 مُشُ تٌ كٍلِ تِرٌيَسِ، مُشُ نَشَ بَكِ كُنكُي كُي، مُشُ نَشَ مُشُ يَ رَقِندِ سَمٌتِرَ سِ مَ كٍرٍن نَ. نَ كُيٍ عِبَ، مُشُ نَشَ تِ نٍيَثٌلِ.
\v 12 مُشُ تٌ كٍلِ نَا، مُشُ نَشَ سِفَ قِلِثِ، مَسٍدٌن تَا سِنفٍ. عٍ نُ نَ رْ مَكَيٍ شَ مَنفّيَ نَن بُن مَ. مُشُ نَشَ سَشَنيِ رَدَنفِ نَ تَا كُي.
\p 
\v 13 مَلَبُ لْشْي، مُشُ نَشَ سِفَ تَا قَرِ مَ شُرٍ دّ رَ، مُشُ دّننَشّ مَحْشُن سَلِدٍ رَ. مُشُ تٌ دْشْ، مُشُ نَشَ وْيّن فِنّيٍ رَ نَشٍيٍ نُ مَلَنشِ نَا.
\v 14 فِنّ ندٍ نُ نَ عٍ يَ مَ نَشَن شِلِ لِدِ، فَرّ دُفِ مَتِ. تِيَتِرٍكَ نَن نُ عَ رَ. عَ فَاشُ عَلَ يَ رَ. عَ تٌ عَ تُلِ مَتِ، مَرِفِ نَشَ عَ بْحّ رَبِ عَلَكٌ ثْلُ نَشَن قَلَمَ عَ شَ سٌ عَ شَشِلِ مَ.
\v 15 عَ تٌ عَ شُنشَ يٍ شْورَ، عَ نُن عَ شَ دٍنبَيَ، عَ نَشَ مُشُ مَيَندِ، «شَ وٌ سَ لَشِ عَ رَ ﭑ بَرَ دَنشَنِيَ مَرِفِ مَ، وٌ قَ لُ ﭑ مَ بَنشِ كُي يِ سَشَنيِ.» عَ نَشَ مُشُ كَرَشَن مَيَندِ رَ.
\s1 عٍ نَ فٍيلِ كُي قِلِثِ
\p 
\v 16 مُشُ تٌ نُ سِفَمَ سَلِدٍ، كٌنيِ فِنّ ندٍ نَشَ قَ مُشُ يَ رَ. حِننّ كَنيِ نَن نُ عَ رَ، حِننّ نَشَن شِلِ تِنّ، نَشَن سٍ مَتٌمَ. نَ فِنّ نُ نَاقُلِ شُنفبٍ رَ سٌمَ عَ كَنيِيٍ مَ.
\v 17 عَ نَشَ سٌ بِرَقٍ مُشُ قْشْ رَ، ثْلُ نُن مُشُ تَن. عَ نُ سْنشْي رَتٍ، «يِ مِشِيٍ عَلَ شِلِ شُنفبٍ كَنيِ شَ كٌنيِيٍ نَن عٍ رَ. عٍ وٌ تِقٍ كِسِ كِرَ نَن شْن مَ.»
\v 18 عَ نَشَ نَ رَبَ شِ وُيَشِ. ثْلُ تٌ شْنْ، عَ نَشَ عَ يَ رَقِندِ، عَ نَشَ عَ قَلَ حِننّ بّ، «ﭑ بَرَ عِ يَمَرِ عِسَ شِلِ رَ، عَلَ شَ مِشِ سُفَندِشِ، فبِلٍن يِ فِنّ قْشْ رَ.» حِننّ نَشَ فبِلٍن عَ قْشْ رَ كٍرٍن نَ.
\p 
\v 19 نَ كٌنيِ فِنّ كَنيِيٍ تٌ عَ تٌ عٍ شَ فٍينِ بَرَ كَنَ، عٍ نَشَ ثْلُ نُن سِلَسِ سُشُ. عٍ نَشَ عٍ شَنِن كِيتِسَيٍ يِرٍ.
\v 20 عٍ نَشَ عٍ دّنتّفّ كِيتِسَيٍ بّ، عٍ نَشّ، «يِ مِشِيٍ نَن وٌن مَ تَا يَ عِسٌقٍ.
\v 21 يُوِقِ نَن عٍ رَ نَشٍيٍ نَامُنيِيٍ شَ قٍ مَسٍنمَ وٌن مُ تِنشِ نَشٍيٍ رَ، وٌن تَن رْ مَكَيٍ.»
\v 22 حَمَ قَن نَشَ كٍلِ عٍ رَ، نُن كِيتِسَيٍ. عٍ نَشَ عٍ مَكٌيّن، عٍ نَشَ يَامَرِ قِ عٍ شَ عٍ بْنبْ لُشُسِنيِ رَ.
\v 23 عٍ تٌ فّ عٍ بْنبْدٍ، عٍ نَشَ عٍ وٌلِ فٍيلِ كُي. عٍ نَشَ كْسِبِلِ يَمَرِ عَ شَ عٍ كَنتَ عَ قَنيِ رَ.
\v 24 نَ كْسِبِلِ تٌ نَ يَامَرِ سْتْ، عَ نَشَ ثْلُ نُن سِلَسِ سَ فٍيلِ كُي، عَ يْلْنشْنيِيٍ سَ عٍ مَ.
\v 25 كْي تَفِ تٌ عَ لِ، ثْلُ نُن سِلَسِ نُ عَلَ مَشَندِقٍ، عٍ نُ عَلَ مَتْشْقٍ بّيتِ رَ. فٍيلِمَنِيٍ نُ عٍ شُي مّشِ.
\v 26 بْشِ نَشَ سّرّن كٍرٍن نَ، فٍيلِ سَنبُنيِ نَشَ عَ رَ مَشَ. نَ تّمُي كٍرٍنيِ كُي، نَادّ بِرِن نَشَ رَبِ. فٍيلِمَنِيٍ بِرِن شَ يْلْنشْنيِيٍ نَشَ مَبٌلٌن.
\v 27 كْسِبِلِ نَشَ شُنُ. عَ تٌ فٍيلِ نَادّيٍ تٌ عٍ رَبِشِ، عَ نَشَ عَ شَ سَنتِدّفّمَ بّندُن عَ تّي عَ شَ عَ يّتّ قَشَ، عَ حْشْ عَ مَ عَ فٍيلِمَنِيٍ نُ بَرَ عٍ فِ.
\p 
\v 28 كْنْ ثْلُ نَشَ سْنشْ عَ شُي عِتٍشِ رَ، «عِ نَشَ قٍ شْنّ نِيَ عِ يّتّ رَ، مُشُ بِرِن نَ بٍ.»
\v 29 عَوَ، كْسِبِلِ تٌ تّ مَشِلِ، عَ نَشَ سٌ مَقُرٍن. عَ نَشَ عَ شِنبِ سِن ثْلُ نُن سِلَسِ بُن مَ، عَ سّرّنمَ.
\v 30 عَ نَشَ عٍ رَ مِنِ، عَ عٍ مَشْرِن، «مَرِفِيٍ، عَ لَنمَ ﭑ شَ مُنسٍ رَبَ عَلَكٌ ﭑ شَ كِسِ؟»
\v 31 ثْلُ نُن سِلَسِ نَشَ عَ يَابِ، «عِ شَ دَنشَنِيَ مَرِفِ عِسَ مَ. نَ نَن عَ تٌمَ عِ كِسِمَ، عِ تَن نُن عِ شَ دٍنبَيَ.»
\v 32 عٍ نَشَ مَرِفِ شَ وْيّنيِ مَسٍن عَ بّ عَ نُن عَ شَ مِشِيٍ.
\v 33 عَ نَشَ عٍ شَنِن عَ شُن مَ كٍرٍن نَ كْي كُي، عَ نَشَ عٍ شَ قِيٍ يَيٍ شَ. نَ وَشَتِ يَتِ عَ نَشَ شُنشَ يٍ شْورَ، عَ تَن نُن عَ شَ مِشِ بِرِن.
\v 34 عَ نَشَ عٍ يِفِيَ عَ شَ بَنشِ كُي، عَ مَن قَ دٌنسٍ قِ عٍ مَ. عَ نَشَ حّلّشِن عَ قَنيِ رَ، عَ نُن عَ شَ دٍنبَيَ بِرِن بَرِ مَ عٍ بَرَ دَنشَنِيَ عَلَ مَ.
\p 
\v 35 كُيٍ تٌ عِبَ، كِيتِسَيٍ نَشَ سْورِيٍ شّي عٍ شَ سَ عَ قَلَ كْسِبِلِ بّ عَ شَ نَ مِشِيٍ رَبٌلٌ.
\v 36 كْسِبِلِ نَشَ عَ قَلَ ثْلُ بّ، «كِيتِسَيٍ بَرَ شّيرَ تِ عَ وٌ شَ رَبّحِن. عَوَ، يَكْسِ وٌ مِنِ، وٌ شَ سِفَ بْحّسَ كُي.»
\v 37 كْنْ ثْلُ نَشَ عَ قَلَ سْورِيٍ بّ، «مُشُ تَن نَشٍيٍ قِندِشِ رْ مَكَيٍ رَ، عٍ بَرَ مُشُ سَ فٍيلِ عٍ مُ مُشُ مَكِيتِ. عٍ نَشَ مُشُ سَ فٍيلِ، يَكْسِ عٍ وَ مَ مُشُ رَ مِنِقٍ فُندٌ رَ؟ نَ مُ لَنمَ قٍوٌ! عٍ يّتّ يَتِ نَن قَمَ مُشُ رَبٌلٌدٍ.»
\v 38 سْورِيٍ نَشَ يِ وْيّنيِيٍ رَفبِلٍن كِيتِسَيٍ مَ. عٍ تٌ عَ مّ عَ رْ مَكَيٍ نَن عٍ رَ، عٍ نَشَ فَاشُ.
\v 39 عٍ نَشَ قَ عٍ مَيَندِ، عٍ عٍ رَبٌلٌ. عٍ قَن نَشَ عٍ مَشَندِ عَ عٍ شَ كٍلِ نَ تَا.
\p 
\v 40 عٍ تٌ مِنِ فٍيلِ كُي، عٍ نَشَ سٌ لِدِ شْنيِ. عٍ تٌ بَرَ فّ عٍ نفَشَكٍرٍنيِيٍ رَلِمَنِيَدٍ، عٍ نَشَ سِفَ.
\c 17
\s1 عٍ سِفَقٍ تّسَلٌنِكِ
\p 
\v 1 ثْلُ نُن سِلَسِ تٌ دَنفِ عَنقِثٌلِ نُن عَثٌلٌنِيَ رَ، عٍ نَشَ سٌ تّسَلٌنِكِ تَا كُي، يُوِقِيٍ شَ سَلِدٍ ندٍ نُ نَ دّننَشّ.
\v 2 ثْلُ نَشَ سٌ نَا عَلْ عَ دَرِشِ نَشَن نَ. مَلَبُ لْشْي شِ سَشَن بُن مَ، عٍ نُن ثْلُ نَشَ كِتَابُي شَ قٍ قَلَ.
\v 3 عَ نُ عَ تَفِ رَبَ عٍ بّ عَ عَ لَنمَ عَلَ شَ مِشِ سُفَندِشِ شَ تْورْ كِ نَشّ، عَ مَن شَ كٍلِ قَشّ مَ. عَ نَشَ عَ قَلَ، «عِسَ، ﭑ نَشَن مَ قٍ قَلَقٍ وٌ بّ يِ كِ، عَ تَن نَن عَلَ شَ مِشِ سُفَندِشِ رَ.»
\v 4 ندٍيٍ نَشَ لَ عَ رَ عٍ يَ مَ. عٍ نَشَ بِرَ ثْلُ نُن سِلَسِ قْشْ رَ. فِرّكِكَ فبٍفبٍ قَن نَشٍيٍ نُ فَاشُشِ عَلَ يَ رَ، نٍيٍ قَن نَشَ لَ عَ رَ، عٍ نُن فِنّ هَفِفّ فبٍفبٍ.
\v 5 كْنْ يُوِقِ تْونّشِ ندٍيٍ نَشَ مِشِ حَاشِ ندٍيٍ تٌنفٌ عٍ شَ حَمَ يَ عِسٌ تَا كُي. عٍ نَشَ سِفَ يَسٌن شْنيِ ثْلُ نُن سِلَسِ قٍندٍ عَلَكٌ عٍ شَ عٍ شَنِن كِيتِسَيٍ شْن مَ.
\v 6 عٍ تٌ مُ عٍ تٌ، عٍ نَشَ يَسٌن نُن عَ نفَشَكٍرٍنيِيٍ ندٍيٍ مَبّندُن نَ تَا كِيتِسَيٍ يِرٍ. عٍ نُ سْنشْي رَتٍ، عٍ نَشّ، «يِ مِشِيٍ نَشٍيٍ دُنِحَ عِقُمَ، عٍ بَرَ قَ بٍ قَن. يَسٌن بَرَ عٍ يِفِيَ.
\v 7 عٍ بِرِن رْ مَكَ مَنفّ شَ وْيّنيِ نَن فبٍسٍن بَمَ، عٍ مَن عَ قَلَمَ عَ مَنفّ فبّتّ ندٍ نَ نَشَن شِلِ عِسَ.»
\v 8 عٍ نَشَ حَمَ نُن كِيتِسَيٍ بْحّ رَتٍ نَ وْيّنيِيٍ رَ.
\v 9 بٍينُن عٍ شَ يَسٌن نُن عَ بٌورٍيٍ بّحِن، قٌ عٍ تٌ كْبِرِ بَ.
\s1 عٍ سِفَقٍ بٍيرٍ تَا
\p 
\v 10 نَ كْي رَ، عٍ نفَشَكٍرٍنيِيٍ نَشَ ثْلُ نُن سِلَسِ رَ سِفَ بٍيرٍ تَا. عٍ تٌ سٌ نَا، عٍ نَشَ سٌ يُوِقِيٍ شَ سَلِدٍ كُي.
\v 11 نَ يُوِقِيٍ شَشِلِ نُ مَتِنسٍ دَنفِ تّسَلٌنِكِكَيٍ رَ. عٍ حَن فبَتَ نّ نَ مَسٍنيِ كٌلٌندٍ، عٍ مَن كِتَابُي كُي مَتٌ لْشْ يٌ لْشْ عَلَكٌ عٍ شَ عَ كٌلٌن عٍ نَشَن قَلَمَ عٍ بّ شَ نْندِ يَتِ نَن عَ رَ.
\v 12 يُوِقِ وُيَشِ نَشَ دَنشَنِيَ عٍ يَ مَ، نُن فِرّكِكَ فِنّ فٌرٌبٌنّ وُيَشِ، نُن شّمّ وُيَشِ.
\p 
\v 13 كْنْ يُوِقِيٍ تّسَلٌنِكِكَيٍ تٌ عَ كٌلٌن عَ ثْلُ نَ عَلَ شَ وْيّنيِ كَوَندِقٍ بٍيرٍ تَا قَن، عٍ نَشَ قَ نَا، عٍ قَ حَمَ يَ عِسٌ.
\v 14 عَوَ، دَنشَنِيَتْييٍ نَشَ ثْلُ تٌنفٌ كٍرٍن نَ، عٍ نَشَ سِفَ عَ رَ بَا قّ مَ، كْنْ سِلَسِ نُن تِمٌتٍ نَشَ لُ بٍيرٍ تَا.
\v 15 نَشٍيٍ ثْلُ مَتِ، عٍ نَشَ سِفَ عَ رَ هَن عَتّن. نَ شَنبِ عٍ نَشَ فبِلٍن عٍ حُنفُي رَ سِلَسِ نُن تِمٌتٍ شْن مَ، عٍ شَ ثْلُ لِ سِننَنيِ مَ عَتّن.
\s1 ثْلُ كَوَندِ تِقٍ عَتّن
\p 
\v 16 ثْلُ نُ سِلَسِ نُن تِمٌتٍ مَمّقٍ عَتّن. عَ بْحّ نَشَ مَحَاشُ عَ رَ نَ تَا شَ كُيٍيٍ شَ قٍ رَ.
\v 17 نَ كُي، عَ نَشَ دّ مَسَرَ عٍ نُن يُوِقِيٍ رَ، عَ نُن مِشِيٍ نَشٍيٍ فَاشُشِ عَلَ يَ رَ سَلِدٍ كُي. عَ مَن نَشَ وْيّن مِشِيٍ رَ عَ نَرَلَنمَ نَشٍيٍ رَ مَلَن يِرٍ تَا كُي لْشْ يٌ لْشْ.
\v 18 عٍثِكُرِ نُن سِتٌيِسِ كَرَ مْشْيٍ نَشَ سٌ وْيّنقٍ ثْلُ رَ، عٍ نُ عَ قَلَ، «يِ وْيّنلَ مُنسٍ قَلَقٍ؟» ندٍيٍ تٌ ثْلُ شُي مّ عَ عِسَ شَ شِبَارُ مَسٍنمَ، عَ مَن نُ قَ مَرَكٍلِ قٍيٍ قَلَقٍ، عٍ نَشّ، «عَ لُشِ نّ عَلْ عَ عَلَ فبّتّيٍ نَن مَ قٍيٍ قَلَمَ.»
\p 
\v 19 عَوَ، عٍ نَشَ عَ تٌنفٌ، عٍ نَشَ سِفَ عَ رَ عَرٍيٌثَفٌ مَلَن يِرٍ، عٍ نَشَ عَ مَشْرِن، «يِ لْننِ نّينّ عِ نَشَن مَسٍنمَ، مُشُ نْمَ عَ كٌلٌندٍ دِ؟
\v 20 بَرِ مَ مُشُ قٍ نّينّ نَن مّقٍ يِ كِ، مُشُ وَ مَ نَ قَسَرِ نَن كٌلٌنقٍ.»
\v 21 عَتّنكَيٍ نُن شْحّيٍ نَشٍيٍ سَبَتِشِ عَتّن، عٍ نُ دَرِشِ عٍ تُلِ مَتِقٍ رَ وْيّن نّينّ رَ نَشٍيٍ مَسٍنمَ.
\p 
\v 22 ثْلُ نَشَ تِ عَرٍيٌثَفٌ تَفِ، عَ نَشَ عَ قَلَ، «عَتّنكَيٍ، ﭑ بَرَ عَ تٌ دِينّلَيٍ يَتِ يَتِ نَن وٌ رَ.
\v 23 ﭑ بَرَ سٍيٍ تٌ وٌ نَشٍيٍ بَتُمَ. ﭑ مَن بَرَ سّرّشّبَدٍ ندٍ تٌ، عَ سّبّشِ نَشَن مَ، ‹عَلَ نَشَن مُ كٌلٌنشِ!› وٌ نَشَن بَتُمَ، عَ قَ لُ وٌ مُ عَ كٌلٌن، ﭑ نَ نَن مَ قٍ مَسٍنقٍ وٌ بّ.
\v 24 عَلَ نَشَن دُنِحَ دَاشِ، عَ نُن سٍ نَشَن بِرِن نَ عَ كُي، عَ تَن نَشَن كٌورٍ نُن بْشِ مَرِفِ رَ، عَ مُ سَبَتِشِ بَنشِ كُي مِشِ بّلّشّ نَشَن نَقَلَشِ.
\v 25 عَ هَيِ مُ نَ سٍيٍ مَ عَدَ مَ نَشَن شَنِنمَ عَ شْن مَ. عَ تَن نَن بَلٌي نُن حّنفِ نُن سٍ بِرِن قِمَ مِشِ مَ.
\v 26 عَ تَن نَن عَ نِيَ مِشِ بِرِن شَ مِنِ بٍنبَ كٍرٍن قَتٍ. عَ نَشَ عٍ رَ سَبَتِ بْشِ بِرِن مَ. عَ مَن نَشَ عٍ شَ وَشَتِ نُن عٍ لُدٍ نَانِنيِيٍ سَ،
\v 27 عَلَكٌ عٍ شَ عَلَ قٍن، عٍ شَ كَتَ عَ كٌلٌندٍ، هَلِ عَ تٌ مُ مَكُيَ وٌن نَ.
\v 28 وٌ شَ لْننِلَيٍ يَتِ قَن بَرَ عَ قَلَ، ‹وٌن بَلٌشِ عَ تَن نّ، وٌن قٍ بِرِن نَبَمَ عَ تَن نَن سَابُي رَ، نُن وٌن مِنِشِ عَ تَن نّ. عَ بْنسْي نَن وٌن نَ.›
\v 29 عَوَ شَ وٌن كٍلِشِ عَ بْنسْي نّ، عَ مُ لَنمَ وٌن شَ عَ مَحْشُن عَ عَلَ مَنِيَشِ شّيمَ، فبٍتِ، شَ نَ مُ فّمّ نَن نَ، مِشِ بّلّشّ نَشَن سٌلِشِ عٍ شَشِلِ رَ.
\v 30 عَلَ مُ نُ نَ قٍ كٌلٌنتَرٍيَ تّمُي مَتٌشِ، كْنْ يَكْسِ عَ بَرَ عَ قَلَ مِشِ بِرِن بّ، يِرٍ بِرِن، عٍ شَ تُوبِ،
\v 31 بَرِ مَ عَ بَرَ لْشْي كٍرٍن سُفَندِ، عَ قَمَ دُنِحَ مَكِيتِدٍ نَشَن مَ تِنشِنيِ رَ، مِشِ ندٍ سَابُي رَ عَ بَرَ عَ رَفِرِ نَشَن مَ. عَ بَرَ نَ كَنيِ مَتْنشُمَشِ رَكٍلِ قَشَمِشِيٍ يَ مَ.»
\v 32 عٍ تٌ يِ قٍ مّ، قَ عَ قَلَ مِشِ كٍلِمَ قَشّ مَ، ندٍيٍ نَشَ سٌ عَ مَيٍلٍقٍ. ندٍيٍ نَشَ عَ قَلَ، «مُشُ قَمَ مُشُ تُلِ مَتِدٍ عِ رَ لْشْي فبّتّ.»
\v 33 عَوَ، ثْلُ نَشَ مِنِ عٍ يَ مَ.
\v 34 ندٍيٍ نَشَ لُ عَ مَبِرِ رَ، عٍ نَشَ دَنشَنِيَ، عَلْ دٍنِسِيٌ، نَشَن نُ نَ عَرٍيٌثَفٌ مِشِيٍ يَ مَ، نُن فِنّ ندٍ نَشَن شِلِ دَ مَرِ سِ، عٍ نُن مِشِ فبّتّيٍ رَ.
\c 18
\s1 عٍ سِفَقٍ كٌرِنتِ
\p 
\v 1 نَ شَنبِ، ثْلُ نَشَ كٍلِ عَتّن، عَ نَشَ سِفَ كٌرِنتِ.
\v 2 عَ نَشَ يُوِقِ كٍرٍن لِ نَا، عَ شِلِ عَكِلَ، ثٌنتُكَ نَن عَ رَ. عَ نُ بَشِ قَدٍ كٍلِ عِتَلِ عَ نُن عَ شَ فِنّ ثِرِ سِلَ، بَرِ مَ كِلْدِ نُ بَرَ يُوِقِ بِرِن يَامَرِ عٍ شَ مِنِ رْ مَ. ثْلُ نَشَ كَقُ عٍ مَ،
\v 3 بَرِ مَ عٍ نُ وَلِ كٍرٍن نَن نَبَمَ، كِرِ بَنشِ رَقَلَقٍ. عَ نَشَ لُ عٍ شْنيِ، عٍ نُ وَلِ نَا.
\v 4 ثْلُ نُ وْيّنمَ سَلِدٍ كُي مَلَبُ لْشْي بِرِن. عَ نُ يُوِقِيٍ نُن فِرّكِكَيٍ رَدَنشَنِيَ.
\v 5 سِلَسِ نُن تِمٌتٍ تٌ سٌ، كٍلِ مَسٍدٌن، ثْلُ نَشَ عَ يّتّ قِ كَوَندِ رَبَقٍ فبَنسَن مَ. عَ نُ عَ قَلَ يُوِقِيٍ بّ عَ عِسَ نَن عَلَ شَ مِشِ سُفَندِشِ رَ.
\v 6 كْنْ يُوِقِيٍ تٌ نَ مَتَندِ كٌنبِ رَ، ثْلُ نَشَ عَ شَ دٌنمَ عِكٌنكٌن تْنشُمَ رَ، عَ نَشَ عَ قَلَ عٍ بّ، «شَ وٌ لْي، وٌ تَن نَن قْشِ نَ نَ رَ. ﭑ تَن بَرَ نَ كٌتٍ بَ ﭑ شُن. يَكْسِ ﭑ سِفَمَ نّ سِ فبّتّيٍ مَ.»
\p 
\v 7 عَ تٌ كٍلِ نَا، عَ نَشَ سٌ مِشِ ندٍ شْنيِ، عَ كَنيِ شِلِ تِتِ يُسُتُ، عَ فَاشُ عَلَ يَ رَ. عَ شَ بَنشِ نُ نَ سَلِدٍ قّ مَ.
\v 8 نَ تّمُي، كِرِ سِثُ سَلِدٍ شُنمَتِ نَشَ دَنشَنِيَ مَرِفِ مَ عَ نُن عَ شَ دٍنبَيَ بِرِن. كٌرِنتِكَيٍ وُيَشِ نَشٍيٍ نُ ثْلُ شُي مّشِ، عٍ قَن نَشَ دَنشَنِيَ، عٍ نَشَ عٍ شُنشَ يٍ شْورَ.
\p 
\v 9 مَرِفِ نَشَ عَ قَلَ ثْلُ بّ لَامَتُنيِ رَ كْي كُي، «عِ نَشَ فَاشُ مُكُ! وْيّن! عِ نَشَ دُندُ،
\v 10 بَرِ مَ ﭑ نَ عِ قْشْ رَ. مِشِ يٌ بّلّشّ مُ عِ لِمَ عَ شَ قٍ حَاشِ رَبَ عِ رَ، بَرِ مَ مِشِ فبٍفبٍ نَ ﭑ بّ يِ تَا كُي.»
\v 11 ثْلُ نَشَ لُ نَا حّ كٍرٍن كِكٍ سٍننِ. عَ نُ كٌرِنتِكَيٍ شَرَن عَلَ شَ مَسٍنيِ رَ.
\p 
\v 12 فَلِيٌن تٌ نُ نَ عَكَيِ مَنفّ رَ، يُوِقِيٍ نَشَ يَنقَنتٍيَ شِرِ ثْلُ شُن، عٍ نَشَ عَ شَنِن كِيتِسَيٍ يِرٍ.
\v 13 عٍ نَشَ عَ قَلَ، «يِ دِ نَن مِشِيٍ كُي عِسٌمَ عٍ شَ عَلَ بَتُ كِ فبّتّ نَشَن مُ سّرِيّ كِ رَ.»
\v 14 ثْلُ تٌ وْيّن قْلْ، فَلِيٌن نَشَ عَ قَلَ يُوِقِيٍ بّ، «شَ عَ سَ لِ تِنشِنتَرٍيَ نَ عَ رَ، شَ نَ مُ عَ رَ وَلِ كٌبِ ندٍ، ﭑ ﭑ تُلِ مَتِمَ نّ وٌ رَ نُ،
\v 15 كْنْ شَ عَ سَ لِ بٌورٍ مَتَندِ نَ عَ رَ وْيّنيِ مَ، شَ نَ مُ عَ رَ شِلِيٍ مَ، عَ نُن وٌ شَ سّرِيّ مَ، نَ نَ وٌ تَن نَن مَ. ﭑ مُ وَ مَ قِندِقٍ نَ قٍ مَكِيتِمَ رَ.»
\v 16 نَ كُي، عَ نَشَ عٍ كٍرِ كِيتِ بَنشِ كُي.
\v 17 حَمَ نَشَ سَلِدٍ شُنمَتِ سٌسِتٍنٍ سُشُ، عٍ عَ بْنبْ كِيتِ بَنشِ تَندٍ مَ، كْنْ فَلِيٌن مُ عٍ هَنسَ.
\s1 عٍ فبِلٍنقٍ عَنتِيْكِ
\p 
\v 18 ثْلُ تٌ بُ كٌرِنتِ كِ قَنيِ رَ، عَ نَشَ كٍلِ عَ نفَشَكٍرٍنيِيٍ شُن مَ. عَ نَشَ بَكِ كُنكُي كُي عَ نُن ثِرِ سِلَ نُن عَكِلَ، عٍ سِفَ سِرِيَ. عَ نَشَ عَ شُنيِ بِ سٍنشٍرٍيَ، بَرِ مَ عَ نُ بَرَ لَايِدِ تٌنفٌ عَلَ بّ.
\v 19 عٍ تٌ سٌ عٍقّسّ، ثْلُ نَشَ عَ حّرّبٌورٍيٍ لُ نَا. عَ نَشَ سٌ سَلِدٍ كُي، عٍ نُن يُوِقِيٍ نَشَ سُمُن.
\v 20 عٍ نَشَ عَ مَيَندِ عَ شَ بُ نَا،
\v 21 كْنْ نَ مُ عَ شُنيِ سُشُ. عَ نَشَ عَ حُنفُ عٍ مَ. عَ نَشّ، «قٌ ﭑ شَ سَ سَلِ دَرِ سَلَمُ نّ. شَ عَلَ تِن، ﭑ مَن قَمَ وٌ شْنيِ.»
\v 22 عَوَ، عَ نَشَ بَكِ كُنكُي كُي، عَ كٍلِ عٍقّسّ، عَ سِفَ سٍسَرٍ. عَ تٌ فّ دَنشَنِيَتْي حَمَ شّيبُدٍ، عَ نَشَ فٌرٌ عَنتِيْكِ.
\s1 ثْلُ شَ بِيَاسِ سَشَن ندٍ
\p 
\v 23 ثْلُ تٌ بَرَ سَشَنيِ رَدَنفِ عَنتِيْكِ، عَ نَشَ كِرَ تٌنفٌ، عَ نَشَ فَلَتِ نُن قِرِفِيَ بْشِ بِرِن عِسَ، عَ نُ عِسَ قْشِرَبِرّيٍ رَلِمَنِيَ.
\p 
\v 24 عَثٌلٌسِ، يُوِقِ ندٍ نَشَن بَرِشِ عَلٍسَندِرٍ، عَ نَشَ عٍقّسّ لِ. عَ نُ قَتَ وْيّندٍ، عَ كِتَابُي قَن كٌلٌن.
\v 25 عَ نُ شَرَنشِ مَرِفِ شَ كِرَيَ رَ. عَ نَشَ عِسَ شَ قٍ مَسٍن عَ قَنيِ رَ، كْنْ عَ نُ يَيَ شَ شَرَنيِ نَن فبَنسَن كٌلٌن شُنشَ تِقٍ يٍ شْورَ.
\v 26 عَ نَشَ سٌ وْيّنقٍ عَ رَوَ سَشِ رَ سَلِدٍ كُي. عَكِلَ نُن ثِرِ سِلَ تٌ عَ شُي مّ، عٍ نَشَ كَقُ عَ مَ عَلَكٌ عٍ شَ عَلَ شَ كِرَيَ مَسٍن عَ بّ عَ كِ مَ.
\v 27 نَ شَنبِ عَ تٌ نُ وَ مَ دَنفِقٍ عَكَيِ، عَ نفَشَكٍرٍنيِيٍ نَشَ عَ رَلِمَنِيَ. عٍ نَشَ بَتَاشّ سّبّ عِسَ قْشِرَبِرّيٍ مَ عَ عٍ شَ عَ رَ سّنّ. عَ شَ سِفّ نَشَ قِندِ قٍ قَنيِ رَ دَنشَنِيَتْييٍ بّ عَكَيِ بْشِ مَ، نَشٍيٍ دَنشَنِيَ عَلَ شَ هِننّ سَابُي رَ.
\v 28 عَثٌلٌسِ نَشَ يُوِقِيٍ مَتَندِ سّنبّ رَ كّنّ مَ، عَ نَشَ عَ مَسٍن كِتَابُي رَ عَ عِسَ نَن عَلَ شَ مِشِ سُفَندِشِ رَ.
\c 19
\s1 ثْلُ سِفَقٍ عٍقّسّ
\p 
\v 1 عَثٌلٌسِ نُ نَ كٌرِنتِ. ثْلُ تٌ بَرَ فّ عَسِ قُفٍ بِرِ عِسَدٍ، عَ نَشَ قَ عٍقّسّ. عَ تٌ نَرَلَن عِسَ قْشِرَبِرّ ندٍيٍ رَ،
\v 2 عَ نَشَ عٍ مَشْرِن، «وٌ بَرَ عَلَ شَشِلِ سّنِيّنشِ سْتْ وٌ تٌ دَنشَنِيَ؟» عٍ نَشَ عَ يَابِ، «مُشُ حَن مُ نُ نَ مّ سِندٍن شَ عَلَ شَشِلِ سّنِيّنشِ نَ نَ.»
\v 3 عَ نَشَ عٍ مَشْرِن، «وٌ وٌ شُنشَ يٍ شْورَ مُنقٍ مَ؟» عٍ نَشَ عَ يَابِ، «مُشُ بَرَ مُشُ شُنشَ يٍ شْورَ عَلْ يَيَ عَ مَسٍنشِ كِ نَشّ.»
\v 4 عَوَ، ثْلُ نَشَ عَ قَلَ، «يَيَ نُ مِشِ شُنشَمَ يٍ شْورَ نّ تُوبِ شَ قٍ رَ. عَ نُ عَ قَلَ مِشِيٍ بّ، عٍ شَ دَنشَنِيَ مِشِ ندٍ مَ نَشَن قَمَ عَ تَن شَنبِ رَ. نَ نَن لَنشِ عِسَ مَ.»
\v 5 نَ مَسٍنيِ مَ عٍ نَشَ عٍ شُنشَ يٍ شْورَ مَرِفِ عِسَ شِلِ رَ.
\v 6 ثْلُ تٌ عَ بّلّشّ سَ عٍ مَ، عَلَ شَشِلِ سّنِيّنشِ نَشَ قَ عٍ مَ. عٍ نَشَ سٌ شُي فبّتّيٍ قَلَقٍ، عٍ مَن نُ عَلَ شَ مَسٍنيِ قَلَ.
\v 7 عٍ بِرِن نَلَنشِ، شّمّ قُ نُن قِرِن نَن نُ عٍ رَ.
\p 
\v 8 نَ دَنفِ شَنبِ، ثْلُ نَشَ سٌ سَلِدٍ كُي، عَ كَوَندِ تِ. عَ نُ قٍ تَفِ رَبَ عٍ بّ عَلَ شَ مَنفّيَ نِينِ شَ قٍ رَ كِكٍ سَشَن بُن مَ. عَ نُ كَتَ عَ شَ مِشِيٍ نْ نَشٍيٍ تُلِ نُ مَتِشِ عَ رَ.
\v 9 كْنْ ندٍيٍ شَشِلِ نُ شْرْشْ، عٍ مُ لَ عَ رَ. عٍ نَشَ مَرِفِ شَ كِرَ بّشُ حَمَ يَ عِ. ثْلُ نَشَ مِنِ عٍ يَ مَ، عَ نَشَ عِسَ قْشِرَبِرّيٍ تٌنفٌ عَ شُن، عَلَكٌ عَ شَ عٍ شَرَن لْشْ يٌ لْشْ تِرَنُسِ شَ شَرَندٍ كُي.
\v 10 نَ نَشَ سِفَ هَن حّ قِرِن. يُوِقِيٍ نُن فِرّكِكَ نَشٍيٍ بِرِن نُ سَبَتِشِ عَسِ، عٍ مَرِفِ شَ مَسٍنيِ رَ مّ نَ نَن كُي.
\v 11 عَلَ نُ كَابَنَكٌ شُنفبٍيٍ رَبَمَ ثْلُ بّلّشّيٍ رَ
\v 12 هَن عٍ نُ دُفِ نُن شُنشُرِيٍ سَ قُرٍ مَيٍ مَ، ثْلُ نُ بَرَ دِن نَشٍيٍ رَ. قُرٍ نُ بَ نّ عٍ مَ، حِننّ نُ مِنِ مِشِيٍ عِ.
\s1 سٍبَ شَ دِيٍ
\p 
\v 13 يُوِقِيٍ ندٍيٍ نَشٍيٍ حِننّ رَ مِنِمَ مِشِيٍ يِرٍ بِرِن، عٍ نَشَ كَتَ مَرِفِ عِسَ شِلِ رَوَلِدٍ حِننّ كَنيِيٍ بّ. عٍ عَ قَلَ، «ﭑ بَرَ وٌ يَامَرِ عِسَ شِلِ رَ ثْلُ نَشَن شَ قٍ كَوَندِ مَ.»
\v 14 سٍبَ، يُوِقِيٍ سّرّشّدُبّ كُنتِفِ ندٍ، شَ دِ سٌلٌقٍرٍ نَن نُ نَ قٍ رَبَمَ.
\v 15 حِننّ نَشَ عٍ يَابِ، «ﭑ عِسَ نُن ثْلُ كٌلٌن، كْنْ ﭑ مُ وٌ تَن كٌلٌن قٍوٌ!»
\v 16 نَ حِننّ كَنيِ نَشَ بَفَن عٍ مَ، عَ نَشَ عٍ بْنبْ هَن عٍ نَشَ عٍ فِ بَنشِ كُي عٍ رَفٍلِ نُن عٍ مَشْنْشِ رَ.
\p 
\v 17 يُوِقِ نُن فِرّكِكَ نَشٍيٍ بِرِن نُ سَبَتِشِ عٍقّسّ، عٍ نَشَ نَ قٍ كٌلٌن. فَاشُي نَشَ عٍ بِرِن سُشُ. مَرِفِ عِسَ شِلِ دَرِيّ نَشَ مَتٍ.
\v 18 دَنشَنِيَتْي وُيَشِ نَشَ قَ، عٍ نَشَ عٍ تِ عٍ شَ يُنُبِيٍ رَ، عٍ نَشَ عٍ شَ قٍ حَاشِ بِرِن قَلَ كّنّ مَ.
\v 19 دُورٍيٍ قَن نَشَ قَ عٍ شَ بُكِيٍ رَ، عٍ نَشَ عٍ فَن بِرِن يَ شْرِ. عٍ نَشَ بُكِيٍ سَرٍ كْنتِ، كْبِرِ كٌلٍ وُلُ تٌنفٌ سُولِ نَن نُ عَ رَ.
\v 20 مَرِفِ شَ مَسٍنيِ نُ يِرِوَ مَ نَ كِ نّ سّنبّ رَ.
\s1 فِرِنبَنيِ بِرَقٍ عٍقّسّ
\p 
\v 21 يِ قٍيٍ تٌ دَنفِ، ثْلُ نَشَ نَتّ تٌنفٌ عَ شَ سِفَ دَرِ سَلَمُ. نَ بِيَاسِ كُي قٌ عَ شَ مَسٍدٌن نُن عَكَيِ بْشِ عِبٌلٌن. عَ نَشَ عَ قَلَ، «ﭑ نَ سِفَ دَرِ سَلَمُ، قٌ ﭑ شَ رْ مَ قَن لِ.»
\v 22 عَ نَشَ عَ مَلِمَ قِرِن شّي مَسٍدٌن، تِمٌتٍ نُن عٍرَ سِتٌ، كْنْ عَ تَن نَشَ لُ عَسِ سِندٍن.
\p 
\v 23 نَ تّمُي سْنشْي شُنفبٍ نَشَ رَبَ نَا مَرِفِ شَ كِرَ شَ قٍ مَ.
\v 24 شَبُي ندٍ، نَشَن شِلِ دٍ مٍتِرِ، عَ نُ عَلَ عَرِتٍمِ شَ سَلِدٍ مِسَالِ لَنمَدِ يَءِلَنمَ فبٍتِ رَ. نَ شَبُي مْولِيٍ نُ كْبِرِ فبٍفبٍ سْتْمَ نَ وَلِ كُي.
\v 25 عَ نَشَ عَ وَلِبٌورٍيٍ مَلَن، عَ عَ قَلَ عٍ بّ، «وٌ عَ كٌلٌن، وٌن بَلٌشِ يِ وَلِ نَن كُي.
\v 26 وٌ بَرَ عَ تٌ، وٌ بَرَ عَ مّ، يِ ثْلُ بَرَ مِشِ فبٍفبٍ مَدَشُ عَسِ بْشِ بِرِن مَ، عٍقّسّ فبَنسَن شَ مُ عَ رَ. عَ نَشّ عَ عَلَيٍ نَشٍيٍ رَقَلَشِ مِشِيٍ بّلّشّ رَ، عَ عَلَ مُ عٍ رَ.
\v 27 نَ كُي وٌن مَ وَلِ قَمَ نّ شِلِ حَاشِ سْتْدٍ. وٌن مَ عَلَ عَرِتٍمِ شَ سَلِدٍ قَن شُن نَكَنَمَ نّ. ندٍ بَمَ نّ عَرِتٍمِ شَ بِنيّ رَ عَسِ بْشِ نُن دُنِحَ مَ.»
\p 
\v 28 عَ تٌ نَ قَلَ، عٍ نَشَ شْنْ، عٍ نَشَ سٌ سْنشْي رَتٍقٍ، «عٍقّسّكَيٍ شَ عَلَ عَرِتٍمِ نَن فبٌ.»
\v 29 تَا بِرِن يَ نَشَ عِسٌ. عٍ نَشَ فَيُ نُن عَرِ سِتَرَكِ، ثْلُ حّرّبٌورٍ مَسٍدٌنكَيٍ، شَنِن مَلَندٍ شُنفبٍ كُي.
\v 30 ثْلُ نَشَ وَ سِفَقٍ نَا، كْنْ عِسَ قْشِرَبِرّيٍ مُ تِن.
\v 31 عَ بٌورٍيٍ عَسِكَيٍ شُنمَتِيٍ قَن نَشَ شّيرَ تِ ثْلُ مَ، عٍ عَ مَيَندِ عَ نَشَ سِفَ مَلَن يِرٍ.
\v 32 ندٍيٍ نُ سْنشْمَ عٍ فبٍ كِ مَ. بٌورٍيٍ قَن سْنشْمَ عٍ فبٍ كِ. لَنتَرٍيَ نُ نَ مَلَنيِ يَ مَ. مِشِ وُيَشِ مُ نُ عَ كٌلٌن عٍ مَلَنشِ قٍ نَشَن مَ.
\p 
\v 33 عَوَ، يُوِقِيٍ نَشَ عَلٍسَندِرٍ تُتُن يَرٍ عَ شَ وْيّن. عَ نَشَ حَمَ مَسَبَرِ عَ بّلّشّ رَ عَلَكٌ عَ شَ مَسٍنيِ تِ.
\v 34 كْنْ، عٍ تٌ عَ كٌلٌن عَ يُوِقِ نَن عَ رَ، عٍ بِرِن نَلَنشِ نَشَ سْنشْي رَتٍ لّيرِ قِرِن بُن مَ. عٍ نَشّ، «عٍقّسّكَيٍ شَ عَلَ عَرِتٍمِ نَن فبٌ.»
\v 35 نَ شَنبِ، تَا كُنتِفِ ندٍ نَشَ حَمَ مَسَبَرِ، عَ نَشَ عَ قَلَ، «عٍقّسّكَيٍ، دُنِحَ بِرِن عَ كٌلٌن عَ عٍقّسّ تَا نَن عَرِتٍمِ شَ سَلِدٍ كَنتَمَ عَ نُن عَرِتٍمِ مَنِيّ، نَشَن فٌرٌشِ كٍلِ كٌورٍ مَ.
\v 36 مِشِ يٌ مُ نَ مَتَندِ مَ. عَ لَنمَ وٌ شَ دُندُ. وٌ نَشَ فبَتَ قٍقٍ رَبَدٍ.
\v 37 وٌ بَرَ قَ يِ مِشِيٍ رَ بٍ، كْنْ عٍ مُ عَرِتٍمِ مُحَ، عٍ مُ عَ كٌنبِ.
\v 38 شَ دٍ مٍتِرِ نُن عَ وَلِبٌورٍيٍ وَ مَ مِشِ ندٍ كَلَمُقٍ، عٍ شَ نَ مَسٍن كِيتِسَيٍ بّ كِيتِ لْشْييٍ.
\v 39 شَ وٌ وَ مَ قٍ فبّتّ نَن شْن، نَ قَن يَ عِبَمَ وٌن مَ مَلَن لْشْي.
\v 40 عٍ نْمَ وٌن سُشُدٍ وٌن مَ بْحّتٍ مَ نَشَن دَنفِشِ تٌ، بَرِ مَ نْندِ يٌ مُ نَ وٌن بّ يِ مَلَنيِ رَبَقٍ مَ.» عَ تٌ فّ، عَ نَشَ مَلَنيِ رَيٍنسٍن.
\c 20
\s1 عَ سِفَقٍ مَسٍدٌن نُن فِرّكِ بْشِيٍ مَ
\p 
\v 1 سْنشْي تٌ بَرَ حْن، ثْلُ نَشَ عِسَ قْشِرَبِرّيٍ مَلَن عٍ رَ سِقٍ مَ. عَ تٌ عَ حُنفُ عٍ مَ، عَ نَشَ سِفَ مَسٍدٌن.
\v 2 عَ نَشَ نَ بْشِ عِسَ، عَ نُ عِسَ قْشِرَبِرّيٍ رَ سِ مَرَ سِ وُيَشِ رَ. نَ دَنفِ شَنبِ، عَ نَشَ سِفَ فِرّكِ بْشِ مَ.
\v 3 عَ تٌ لُ نَا كِكٍ سَشَن، عَ نَشَ وَ سِفَقٍ سِرِيَ كُنكُي كُي، كْنْ يُوِقِيٍ نُ بَرَ يَنقَنتٍيَ يَءِلَن عَ شِلِ مَ. نَ كُي، عَ نَشَ نَتّ تٌنفٌ عَ شَ فبِلٍن مَسٍدٌن كِرَ رَ.
\v 4 نَشٍيٍ عَ مَتِ هَن عَسِ نٍيٍ نَن يِ كِ؛ سٌثَتٍرِ، بٍيرٍكَ ثِرُ سِ شَ دِ، عَرِ سِتَرَكِ نُن سٍكٌندُ تّسَلٌنِكِكَيٍ، فَيُ دٍرِبٍكَ نُن تِمٌتٍ، تِكِكٍ نُن تِرٌقِمٌ عَسِكَيٍ.
\v 5 نٍيٍ نَشَ تِ يَرٍ، عٍ نَشَ سَ مُشُ مَمّ تِرٌيَسِ.
\v 6 تَامِ لّبِنِتَرٍ سَلِ لْشْي دَنفِ شَنبِ، مُشُ نَشَ بَكِ كُنكُي كُي قِلِثِ. بٍينُن شِ سُولِ، مُشُ نَشَ عٍ لِ تِرٌيَسِ. مُشُ نَشَ لُ نَا شِ سٌلٌقٍرٍ.
\s1 ثْلُ عٍيُتِكِ رَكٍلِقٍ قَشّ مَ
\p 
\v 7 سَندٍ لْشْي مُشُ نَشَ مَلَن تَامِ عِفِرَقٍ رَ. ثْلُ نَشَ كَوَندِ تِ عِسَ قْشِرَبِرّيٍ بّ هَن كْي تَفِ. عَ لَن نّ عَ شَ سِفَ كُيٍ نَ عِبَ.
\v 8 لَنثُي فبٍفبٍ نُ نَ نَ كٌورٍ بَنشِ كُي، مُشُ نُ مَلَنشِ دّننَشّ.
\v 9 سّفّتَلَ ندٍ نَشَن شِلِ عٍيُتِكِ نُ دْشْشِ وُندّرِ رَ. ثْلُ شَ كَوَندِ شْن تٌ كُيَ، شِ شْلِ نَشَ عَ سُشُ عَ قَنيِ رَ، عَ بِرَ بْشِ مَ كٍلِقٍ بَنشِ دّكِ سَشَن ندٍ. عٍ نَشَ عَ لِ، عَ بَرَ قَشَ.
\v 10 ثْلُ تٌ فٌرٌ، عَ نَشَ عَ قٍلٍن عَ شُن. عَ نَشَ عَ تٌنفٌ، عَ عَ قَلَ عٍ بّ، «وٌ نَشَ كْنتْقِلِ، بَرِ مَ عَ مُ قَشَشِ.»
\v 11 ثْلُ تٌ تٍ، عَ نَشَ تَامِ عِفِرَ، عَ نَشَ عَ دٌن. عَ مَن نَشَ وْيّن هَن فّيسّفّ. نَ فّيسّفّ، عَ نَشَ سِفَ.
\v 12 دَنشَنِيَتْييٍ نَشَ سّفّتَلَ شَنِن عَ حِحّ رَ بْحّسَ كُي.
\s1 ثْلُ عَ حُنفُقٍ عٍقّسّكَيٍ مَ
\p 
\v 13 مُشُ نَشَ كُنكُي بّلَ رَكٍلِ سِفَقٍ رَ عَسٌسِ ثْلُ يَ رَ عَلْ مُشُ لَنشِ عَ مَ كِ نَشّ. عَ نَشَ وَ سِفَقٍ عَ سَنيِ رَ.
\v 14 عَ تٌ مُشُ لِ عَسٌسِ، مُشُ نَشَ عَ بَكِ كُنكُي كُي سِفَقٍ مِتِلّنِ.
\v 15 كٍلِ مّننِ، مُشُ نَشَ سِفَ بَا كِرَ رَ. نَ قَن كُيٍ عِبَ، مُشُ نَشَ كِيٌ لِ. نَ شَنبِ، مُشُ نَشَ سِفَ هَن سَمٌسِ. نَ لْشْي كُيٍ عِبَ، مُشُ نَشَ مِلٍتٌ لِ.
\v 16 ثْلُ نُ بَرَ نَتّ تٌنفٌ عَ شَ دَنفِ عٍقّسّ مَبِرِ عَلَكٌ عَ نَشَ بُ عَسِ بْشِ مَ. عَ نُ فبَتَشِ عَ شَ سٌ دَرِ سَلَمُ شّ شَبّ سَلِ لْشْي شَ عَ سَ سْونّيَمَ عَ بّ.
\p 
\v 17 ثْلُ تٌ مِلٍتٌ لِ، عَ نَشَ شّيرَ تِ عَ عٍقّسّ دَنشَنِيَتْي حَمَ كُنتِفِيٍ شَ قَ.
\v 18 عٍ تٌ قَ عَ يِرٍ، عَ نَشَ عَ قَلَ عٍ بّ، «وٌ عَ كٌلٌن ﭑ حّرّشِ وٌ تَفِ كِ نَشّ. كَبِ ﭑ سٌ عَسِ،
\v 19 ﭑ مَرِفِ شَ وَلِ رَبَ يّتّ مَفٌرٌي نَن كُي. ﭑ يَيٍ بَرَ مِنِ، ﭑ بَرَ تْورْ يُوِقِيٍ شَ وَلِ حَاشِ سَابُي رَ.
\v 20 وٌ عَ كٌلٌن عَ ﭑ مُ وٌ مُنَقَن سٍ يٌ نْشُن وٌ مَ. ﭑ بَرَ كَوَندِ تِ وٌ بّ كّنّ مَ نُن وٌ شَ بَنشِيٍ كُي.
\v 21 ﭑ نُ عَ قَلَمَ نّ يُوِقِيٍ نُن فِرّكِكَيٍ بّ عٍ شَ تٌفٌندِيَ عَلَ مَ، عٍ شَ دَنشَنِيَ وٌن مَرِفِ عِسَ، عَلَ شَ مِشِ سُفَندِشِ مَ.»
\p 
\v 22 «يَكْسِ عَلَ شَشِلِ سّنِيّنشِ وَ مَ نّ ﭑ شَ سِفَ دَرِ سَلَمُ، كْنْ ﭑ مُ عَ كٌلٌن نَشَن سِفَمَ ﭑ سْتْدٍ نَا.
\v 23 تَا بِرِن كُي عَلَ شَشِلِ سّنِيّنشِ بَرَ ﭑ نَكٌلٌن عَ فٍيلِ نُن تْورّ قَمَ نّ ﭑ لِدٍ نَا.
\v 24 كْنْ ﭑ نِي تِدٍ يٌ مُ نَ ﭑ بّ. ﭑ شَ ﭑ مَ شّيرَيَ رَكَمَلِ، ﭑ مَرِفِ عِسَ نَشَن تَشُشِ ﭑ نَ. ﭑ شَ قِندِ عَلَ شَ هِننّ سٍيدٍحْشْيَ بَ رَ، نَشَن قِندِشِ شِبَارُ قَنيِ رَ.»
\p 
\v 25 «يَكْسِ ﭑ عَ كٌلٌن وٌ مُ ﭑ يَتَفِ تٌمَ سْنْن، وٌ تَن نَشٍيٍ بِرِن وٌ تُلِ مَتِشِ ﭑ مَ كَوَندِ رَ، عَلَ شَ مَنفّيَ نِينِ شَ قٍ رَ.
\v 26 نَ نَ عَ رَ، ﭑ عَ قَلَمَ وٌ بّ تٌ، وٌ شَ كٌتٍ يٌ مُ نَ ﭑ شُن،
\v 27 بَرِ مَ ﭑ بَرَ عَلَ سَفٌ بِرِن مَسٍن وٌ بّ، ﭑ مُ سٍسٍ نْشُن وٌ مَ.
\v 28 عَوَ، وٌ شَ مّينِ وٌ يّتّ مَ عَ نُن دَنشَنِيَتْي بِرِن، عَلَ شَشِلِ سّنِيّنشِ وٌ قِندِشِ نَشٍيٍ شَ شُنمَتِ رَ، عَلَكٌ وٌ شَ مّينِ مَرِفِ شَ دَنشَنِيَتْي حَمَ مَ، عَ نَشَن سْتْشِ عَ يّتّ وُلِ رَ. وٌ شَ عٍ كَنتَ عَلْ شُرُ سٍيٍ دّ مَدٌنيِ فْورّ كَنتَمَ كِ نَشّ.
\v 29 ﭑ نَ كٌلٌن، ﭑ نَ سِفَ، مِشِ حَاشِيٍ قَمَ نّ سٌدٍ وٌ تَفِ، عَلْ وُلَ بَرٍيٍ سٌمَ فْورّ يَ مَ كِ نَشّ.
\v 30 مِشِ ندٍيٍ سٌمَ وٌ تَفِ، عٍ شَ شَرَنيِ حَاشِ تِ عَلَكٌ عٍ شَ عِسَ قْشِرَبِرّيٍ بّندُن عٍ مَ.
\v 31 وٌ شَ وٌ مّينِ. وٌ شَ رَتُ يِ حّ سَشَنيِ بُن مَ ﭑ مُ وٌ كَوَندِقٍ عِتِ كْي نُن يَنيِ. ﭑ نَ بِرِن نَبَشِ يَيٍ نَن كُي.»
\p 
\v 32 «عَوَ يَكْسِ، ﭑ وٌ تَشُمَ عَلَ رَ نُن عَ شَ هِننّ مَسٍنيِ رَ، نَشَن نْمَ سّنبّ نُن كّ قَنيِ قِدٍ سّنِيّنتْي بِرِن مَ.
\v 33 ﭑ مُ نُ وَ مَ وٌ شَ كْبِرِ شَ شْن، شَ نَ مُ عَ رَ وٌ شَ شّيمَ، وٌ شَ سٌسٍيٍ.
\v 34 وٌ يّتّ يَتِ عَ كٌلٌن عَ ﭑ وَلِ يِ بّلّشّيٍ نَن نَ عَلَكٌ ﭑ شَ بَلٌ ﭑ نُن ﭑ حّرّبٌورٍيٍ.
\v 35 ﭑ بَرَ عَ مَسٍن وٌ بّ مْولِ بِرِن نَ، عَ وٌن لَن نّ وٌن شَ وَلِ عَلَكٌ وٌن شَ سٍتَرٍيٍ مَلِ. وٌ شَ رَتُ مَرِفِ عِسَ شَ وْيّنيِ مَ، عَ نَشّ، ‹حّلّشِنيِ نَ كِ نَن كُي، دَنفِقٍ عَ سْتْقٍ رَ.›»
\p 
\v 36 عَ تٌ فّ وْيّندٍ، عَ نَشَ عَ شِنبِ سِن، عٍ بِرِن نَشَ عَلَ مَشَندِ.
\v 37 عٍ بِرِن نَشَ سٌ وَقٍ. عٍ نَشَ قِندِفِلِن ثْلُ كْنيِ مَ، عٍ عَ مَسُنبُ.
\v 38 عٍ سُننُن نّ بَرِ مَ عَ بَرَ عَ قَلَ عٍ مُ نْمَ عَ تٌدٍ سْنْن. عٍ نَشَ عَ مَتِ هَن كُنكُي دّ رَ.
\c 21
\s1 ثْلُ سِفَقٍ دَرِ سَلَمُ
\p 
\v 1 مُشُ تٌ قَتَن، مُشُ نَشَ سِفَ كٍرٍن نَ كٌسِ كُنكُي كُي. نَ كُيٍ عِبَ، مُشُ نَشَ سِفَ رٌدِ. مُشُ تٌ كٍلِ رٌدِ، مُشُ نَشَ سِفَ ثَتَرَ.
\v 2 مُشُ تٌ كُنكُي تٌ نَا، نَشَن نُ بَا عِفِرِقٍ سِفَقٍ قٍنِسِيَ بِرِ رَ، مُشُ نَشَ بَكِ نَ كُي.
\v 3 مُشُ تٌ بَرَ سِثِرِ سُرِ تٌ، مُشُ نَشَ دَنفِ نَ رَ كْولَ مَ، سِفَقٍ سِرِيَ بِرِ رَ. مُشُ نَشَ تِ تِرٍ عَلَكٌ كٌتٍ شَ رَفٌرٌ.
\v 4 مُشُ نَشَ عِسَ قْشِرَبِرّيٍ ندٍيٍ لِ نَا. مُشُ نَشَ شِ سٌلٌقٍرٍ رَدَنفِ عٍ شْنيِ. عَلَ شَشِلِ سّنِيّنشِ نَشَ فٌرٌ عِسَ قْشِرَبِرّيٍ مَ، عٍ شَ عَ قَلَ ثْلُ بّ عَ نَشَ تٍ دَرِ سَلَمُ.
\p 
\v 5 كْنْ شِ سٌلٌقٍرٍ كَمَلِ لْشْي، مُشُ نَشَ كِرَ تٌنفٌ سِفَقٍ رَ. عٍ بِرِن نَشَ مُشُ مَتِ، عَ نُن عٍ شَ فِنّيٍ نُن عٍ شَ دِيٍ رَ، هَن تَا قَرِ مَ. مُشُ نَشَ مُشُ شِنبِ سِن بَا دّ رَ عَلَ مَشَندِقٍ رَ.
\v 6 حُنفُي تٌ حْن، مُشُ نَشَ بَكِ كُنكُي كُي. بٌورٍيٍ تَن نَشَ فبِلٍن عٍ شْنيِ.
\v 7 مُشُ نَشَ كٍلِ تِرٍ سِفَقٍ رَ ثِتٌلٌمَيِ. مُشُ نَشَ نفَشَكٍرٍنيِيٍ شّيبُ مّننِ، مُشُ نَشَ قّيحّن نَا.
\p 
\v 8 نَ كُيٍ عِبَ، مُشُ نَشَ سِفَ سٍسَرٍ، قِلِثُ شِبَارُ قَنيِ كَوَندِلَ شْنيِ، نَشَن نُ نَ مِشِ سُفَندِشِ سٌلٌقٍرٍ يَ مَ.
\v 9 عَ شَ دِ فِنّ نَانِ نُ نَ نَشٍيٍ مُ نُ دْشْ شّمّ تَا. عٍ نُ نَمِحْنمّ وَلِ رَبَمَ.
\v 10 مُشُ تٌ بَرَ شِ وُيَشِ رَبَ نَا، عَلَ شَ نَمِحْنمّ نَشَن شِلِ عَفَبُ، نَشَ قَ مُشُ شْنيِ كٍلِقٍ يُدَيَ.
\v 11 عَ نَشَ ثْلُ شَ بّلّتِ تٌنفٌ، عَ نَشَ عَ يّتّ كَن سَنيِيٍ نُن عَ بّلّشّيٍ شِرِ. عَ نَشَ عَ قَلَ، «عَلَ شَشِلِ سّنِيّنشِ يِ نَن مَسٍنشِ. شّمّ نَشَن فبٍ يِ بّلّتِ رَ، يُوِقِيٍ عَ شِرِ مَ يِ مْولِ نَن نَ دَرِ سَلَمُ، عٍ عَ سٌ مِشِيٍ يِ رَ نَشٍيٍ قِندِ سِ فبّتّيٍ رَ.»
\p 
\v 12 مُشُ تٌ نَ مّ، مُشُ نُن نَاكَيٍ نَشَ ثْلُ مَشَندِ عَ نَشَ تٍ دَرِ سَلَمُ.
\v 13 عَ نَشَ مُشُ يَابِ، «مُنقٍ رَ وٌ وَ مَ ﭑ بْحّ مَحَاشُقٍ وٌ يَيٍ رَ؟ ﭑ بَرَ تِن عٍ شَ ﭑ شِرِ دَرِ سَلَمُ، عٍ شَ ﭑ قَشَ، مَرِفِ عِسَ شِلِ شَ قٍ رَ.»
\v 14 عَ تٌ مُ تِن مُشُ شُي سُشُدٍ، مُشُ مُ تِن عَ كَرَشَندٍ. مُشُ نَشَ عَ قَلَ، «مَرِفِ سَفٌ شَ رَبَ.»
\p 
\v 15 نَ لْشْييٍ تٌ دَنفِ، مُشُ نَشَ مُشُ يَءِلَن، مُشُ نَشَ تٍ دَرِ سَلَمُ.
\v 16 عِسَ قْشِرَبِرّيٍ ندٍيٍ سٍسَرٍكَيٍ نَشَ مُشُ مَتِ. عٍ نَشَ مُشُ شَنِن مٍنَسٌن سِثِرِكَ شْنيِ، نَشَن قِندِشِ عِسَ قْشِرَبِرّ رَ عَ رَكُيَ. عَ نَشَ مُشُ يِفِيَ.
\s1 ثْلُ يَكِ شّيبُقٍ
\p 
\v 17 مُشُ تٌ سٌ دَرِ سَلَمُ، عِسَ قْشِرَبِرّيٍ نَشَ مُشُ رَ سّنّ حّلّشِنيِ رَ.
\v 18 نَ كُيٍ عِبَ، مُشُ نُن ثْلُ نَشَ سِفَ يَكِ شْنيِ. دَنشَنِيَتْي حَمَ كُنتِفِ بِرِن نَشَ عٍ مَلَن نَا.
\v 19 عَ تٌ فّ عٍ شّيبُدٍ، ثْلُ نَشَ عَ شَ وَلِ دّنتّفّ سَ عَلَ نَشَن نَبَشِ سِ فبّتّيٍ تَفِ عَ سَابُي رَ.
\v 20 عٍ تٌ نَ مّ، عٍ نَشَ عَلَ مَتْشْ. عٍ نَشّ، «مُشُ نفَشَكٍرٍنيِ، عِ بَرَ عَ تٌ يُوِقِ وُلُ وُيَشِ بَرَ دَنشَنِيَ، كْنْ عٍ مَن عٍ تُننَبّشِشِ بِرَقٍ عَننَبِ مُنسَ شَ سّرِيّ قْشْ رَ.
\v 21 مِشِ ندٍيٍ بَرَ عَ قَلَ عٍ بّ عَ عِ يُوِقِيٍ شَرَنمَ، نَشٍيٍ نَ سِ فبّتّيٍ يَ مَ، عَ عٍ شَ فبِلٍن عَننَبِ مُنسَ شَ سّرِيّيٍ قْشْ رَ، عَ عٍ نَشَ عٍ شَ دِيٍ سُننَ، عَ عٍ نَشَ بِرَ يُوِقِيٍ شَ نَامُنيِيٍ قْشْ رَ.»
\p 
\v 22 «وٌن نَ مَ دِ؟ سِيكّ يٌ مُ نَ، حَمَ عَ كٌلٌنمَ نّ عَ عِ بَرَ قَ.
\v 23 نَ نَ عَ رَ، مُشُ نَشَن قَلَمَ عِ بّ عِ شَ عَ رَبَ. مِشِ نَانِ نَ مُشُ يَ مَ، نَشٍيٍ بَرَ لَايِدِ تٌنفٌ عَلَ بّ.
\v 24 عِ شَ كَقُ عٍ مَ، وٌ بِرِن شَ وٌ يّتّ رَ سّنِيّن، عِ مَن شَ عٍ سَرٍ قِ، عٍ شَ عٍ شُنيِ بِ. نَ نَ عَ رَ بِرِن عَ كٌلٌنمَ عَ مِشِيٍ نَشَن قَلَشِ عِ شُن مَ، وُلٍ نَ عَ رَ. عٍ شَ عَ كٌلٌن عِ قَن بِرَشِ عَننَبِ مُنسَ شَ سّرِيّ نَن قْشْ رَ.
\v 25 مُشُ نَشَ نَتّ تٌنفٌ، مُشُ مَن قَ نَ سّبّ. دَنشَنِيَتْييٍ نَشٍيٍ كٍلِ سِ فبّتّيٍ مَ، عٍ نَشَ سُبٍ دٌن نَشَن بَشِ سّرّشّ رَ كُيٍيٍ بّ، نُن سُبٍ يُقَشِيٍ. عٍ نَشَ وُلِ قَن مِن. عٍ مَن نَشَ يّنّ قَن نَبَ.»
\p 
\v 26 عَوَ نَ كُيٍ عِبَ، ثْلُ نَشَ نَ مِشِيٍ تٌنفٌ، عٍ نَشَ عٍ يّتّ رَ سّنِيّن. نَ شَنبِ عَ نَشَ سٌ هْرْ مْبَنشِ كُي، عَ شَ عَ مَسٍن، مَرَ سّنِيّنيِ رَكَمَلِمَ لْشْي نَشَن مَ، عَ نُن سّرّشّ نَشَن بَمَ كَنكَن بّ.
\s1 ثْلُ سَقٍ فٍيلِ كُي
\p 
\v 27 نَ شِ سٌلٌقٍرٍ رَحْنيِ، يُوِقِيٍ عَسِكَيٍ تٌ ثْلُ تٌ هْرْ مْبَنشِ كُي، عٍ نَشَ حَمَ بِرِن يَ عِسٌ، عٍ مَن نَشَ ثْلُ سُشُ.
\v 28 عٍ نُ سْنشْي رَتٍ، «عِسِرَيِلَكَيٍ، وٌ مُشُ مَلِ! نَ شّمّ نَن يِ كِ نَشَن كَوَندِ حَاشِ رَبَمَ يِرٍ بِرِن مِشِ بِرِن بّ، يُوِقِيٍ، نُن عَننَبِ مُنسَ شَ سّرِيّ، نُن يِ هْرْ مْبَنشِ شَ قٍ رَ. عَ مَن بَرَ فِرّكِكَيٍ رَ سٌ هْرْ مْبَنشِ كُي. نَ بَرَ يِ يِرٍ سّنِيّنشِ قِندِ يِرٍ سّنِيّنتَرٍ رَ.»
\v 29 عٍ نَ قَلَ نّ بَرِ مَ عٍ نُ بَرَ ثْلُ نُن تِرٌقِمٌ عٍقّسّكَ تٌ عٍ بٌورٍ قْشْ رَ تَا كُي. عٍ نَشَ عَ مَحْشُن عَ ثْلُ عَ رَ سٌ نّ هْرْ مْبَنشِ كُي.
\p 
\v 30 تَا كُي بِرِن يَ نَشَ عِسٌ. مِشِيٍ نَشَ قَ عٍ فِ رَ كٍلِ يِرٍ بِرِن. عٍ نَشَ ثْلُ سُشُ، عٍ نَشَ مِنِ عَ بُبُ رَ تَندٍ مَ. عٍ نَشَ نَادّيٍ رَفَلِ كٍرٍن نَ.
\v 31 عٍ نُ وَ مَ ثْلُ قَشَقٍ نّ. سْورِ مَنفّ نَشَ عَ كٌلٌن دَرِ سَلَمُ بِرِن يَ عِسٌشِ.
\v 32 سْورِ مَنفّ نَشَ سْورِيٍ نُن عٍ شَ شُنمَتِيٍ تٌنفٌ، عٍ سِفَ ثْلُ قْشْ رَ كٍرٍن نَ. حَمَ تٌ سْورِيٍ تٌ، عٍ نَشَ بَ ثْلُ بْنبْقٍ.
\v 33 عَوَ، سْورِ مَنفّ نَشَ يَامَرِ قِ عٍ شَ عَ شِرِ يْلْنشْنيِ قِرِن نَ. عَ نَشَ مَشْرِنيِ تِ قَ ندٍ عَ رَ، نُن عَ مُنقٍ رَبَشِ.
\v 34 حَمَ سّيتِ ندٍ سْنشْمَ عٍ فبٍ كِ، بٌورٍيٍ قَن سْنشْمَ عٍ فبٍ كِ. عَ تٌ مُ نْ قٍ قِيشّ سْتْدٍ عٍ رَ سْنشْي شَ قٍ رَ، عَ نَشَ عَ قَلَ عٍ شَ ثْلُ شَنِن سْورِ بَنشِ كُي.
\v 35 ثْلُ تٌ تِ بَنشِ دّ رَ، سْورِيٍ نَشَ عَ تٌنفٌ حَمَ شَ حَاشُي مَ،
\v 36 بَرِ مَ مِشِ فَلِ نَن نُ بِرَشِ عٍ قْشْ رَ، عٍ نُ قَ عَ قَلَ عٍ شُي عِتٍشِ رَ، «عَ شَ قَشَ!»
\s1 ثْلُ عَ يّتّ شُن مَقَلَقٍ
\p 
\v 37 عٍ وَ مَ عَ رَ سٌقٍ سْورِ بَنشِ كُي تّمُي نَشّ، ثْلُ نَشَ سْورِ مَنفّ مَشْرِن، «عِ نْمَ ﭑ سَفٌ سَدٍ ﭑ شَ قٍ ندٍ قَلَ عِ بّ؟» سْورِ مَنفّ نَشَ عَ يَابِ، «عِ فِرّكِ شُي مّمَ؟
\v 38 عِ تَن شَ مُ نَ مِسِرَكَ رَ، نَشَن مِشِيٍ يَ عِسٌ يِ دْنشْي رَ، عَ نَشَ سُوتٍ وُلُ نَانِ شَنِن وُلَ كُي؟»
\v 39 ثْلُ نَشَ عَ يَابِ، «يُوِقِ نَن ﭑ نَ، تَرِ سٍكَ. نَ تَا شُنفبٍ عَ مُنَقَنيِ فبٌ سِلِسِ بْشِ مَ. ﭑ سَفٌ سَ ﭑ شَ وْيّن يِ فَلِ بّ.»
\p 
\v 40 سْورِ مَنفّ تٌ عَ سَفٌ سَ، ثْلُ تِشِ بَنشِ تٍدٍ دّ رَ، عَ نَشَ مِشِيٍ مَسَبَرِ عَ بّلّشّ رَ. كُيٍ نَشَ بٌلٌن يٍن! ثْلُ نَشَ وْيّن عٍبُرُ شُي.
\c 22
\p 
\v 1 «ﭑ نفَشَكٍرٍنيِيٍ، ﭑ بَبَيٍ، وٌ شَ وٌ تُلِ مَتِ ﭑ نَ، ﭑ شَ ﭑ يّتّ كَن شُن مَقَلَ.»
\v 2 عٍ تٌ عَ مّ عَ عٍبُرُ شُي قَلَمَ، عٍ نَشَ دُندُ دَنفِ سِنفٍ رَ. ثْلُ نَشَ عَ قَلَ،
\v 3 «يُوِقِ نَن ﭑ نَ، ﭑ بَرِشِ تَرِ سٍ نّ، سِلِسِ بْشِ مَ، كْنْ ﭑ مْشِ بٍ نّ. فَمَلِيّلِ نَشَ ﭑ شَرَن عَلَكٌ ﭑ شَ بِرَ وٌن بَبَيٍ شَ سّرِيّ قْشْ رَ. عَلَ شَ قٍ نُ ﭑ بْحّ سُشُمَ عَلْ عَ وٌ قَن سُشُمَ كِ نَشّ تٌ.
\v 4 ﭑ مِشِيٍ تْورْ نّ هَن ﭑ نَشَ عٍ قَشَ، نَشٍيٍ نُ بِرَشِ عِسَ شَ كِرَ قْشْ رَ. ﭑ نَشَ فِنّيٍ نُن شّمّيٍ سُشُ، ﭑ نَشَ عٍ سَ فٍيلِ كُي.
\v 5 سّرّشّدُبّ كُنتِفِ نُن دِينّ قٌرِيٍ بِرِن نَ ﭑ سٍيدٍيٍ رَ. عٍ نَشَ كّيدِيٍ سٌ ﭑ يِ رَ كَتَرَبِ عٍ نفَشَكٍرٍنيِيٍ مَ دَ مَسِ عَلَكٌ ﭑ نَ دَنشَنِيَتْييٍ تٌ، ﭑ شَ عٍ شِرِ، ﭑ شَ قَ عٍ رَ دَرِ سَلَمُ، ﭑ شَ عٍ حَشَنكَتَ.»
\p 
\v 6 «ﭑ تٌ مَكْرّ دَ مَسِ رَ يَنيِ تَفِ، يَنبّ شُنفبٍ نَشَ فٌرٌ ﭑ مَ كٍلِقٍ كٌورٍ مَ.
\v 7 ﭑ نَشَ بِرَ بْشِ. ﭑ نَشَ شُي مّ نَشَن نُ عَ قَلَمَ ﭑ بّ، ‹سْلُ، سْلُ، مُنقٍ رَ عِ ﭑ حَشَنكَتَمَ؟›
\v 8 ﭑ نَشَ عَ يَابِ، ‹ندٍ عِ رَ، مَرِفِ؟› عَ نَشَ ﭑ يَابِ، ‹عِسَ نَسَرّتِكَ نَن ﭑ نَ، عِ نَشَن حَشَنكَتَقٍ.›
\v 9 نَشٍيٍ نُ نَ ﭑ قْشْ رَ، عٍ نَشَ يَنبّ تٌ، كْنْ نَشَن نُ وْيّنقٍ، عٍ مُ نَ تَن شُي مّ. عَوَ، ﭑ نَشَ عَ قَلَ،
\v 10 ‹ﭑ شَ مُنسٍ رَبَ، مَرِفِ؟› مَرِفِ نَشَ عَ قَلَ ﭑ بّ، ‹كٍلِ، عِ سِفَ دَ مَسِ. مّننِ عَ قَمَ قَلَدٍ عِ بّ عِ لَن عِ شَ نَشَن نَبَ.›
\v 11 ﭑ مُ نُ سٍ تٌمَ نَ يَنبّ شَ نَءِيَلَنيِ سَابُي رَ. نَشٍيٍ نُ نَ ﭑ قْشْ رَ، عٍ نَشَ ﭑ بّلّشّ رَ سُشُ هَن دَ مَسِ.»
\p 
\v 12 «عَوَ، شّمّ ندٍ نَشَن شِلِ عَنَنِيَسِ، مِشِ تِنشِنشِ نَ عَ رَ عَلَ شَ سّرِيّ كِ مَ، نَشَن نَقَنشِ دَ مَسِ يُوِقِيٍ مَ،
\v 13 عَ نَشَ قَ ﭑ يِرٍ. عَ نَشَ عَ قَلَ، ‹ﭑ نفَشَكٍرٍنيِ سْلُ، تٌ تِ.› ﭑ يَ نَشَ رَبِ كٍرٍن نَ، ﭑ نَشَ سٍ بِرِن تٌ.
\v 14 عَ نَشَ عَ قَلَ، ‹وٌن بَبَيٍ مَرِفِ عَلَ بَرَ عِ سُفَندِ عِ شَ عَ سَفٌ كٌلٌن، عِ شَ تِنشِنتْي تٌ، نُن عِ شَ عَ وْيّنيِ مّ عَ تَن يَتِ دّ رَ،
\v 15 بَرِ مَ عِ قِندِ مَ عَ شَ سٍيدٍ نَن نَ مِشِ بِرِن يَ عِ، عِ قٍيٍ نَشٍيٍ تٌشِ نُن عِ نَشٍيٍ مّشِ.
\v 16 يَكْسِ، عِ مُنسٍ مَمّقٍ؟ كٍلِ، عِ شَ عِ شُنشَ يٍ شْورَ، عِ شَ يُنُبِ شَ بَ عِ مَ، عِ شَ مَرِفِ شِلِ مَشَندِ.›»
\p 
\v 17 «ﭑ نَشَ فبِلٍن دَرِ سَلَمُ. ﭑ تٌ نُ نَ عَلَ مَشَندِقٍ هْرْ مْبَنشِ كُي، ﭑ نَشَ لَامَتُنيِ تٌ.
\v 18 مَرِفِ نَشَ عَ قَلَ ﭑ بّ، ‹عِ شَ مِنِ مَقُرٍن دَرِ سَلَمُ، بَرِ مَ عٍ مُ تِنمَ عِ شَ سٍيدٍيَ رَ ﭑ مَ قٍ رَ.›
\v 19 ﭑ نَشَ عَ قَلَ، ‹مَرِفِ، عٍ يَتِ عَ كٌلٌن عَ ﭑ نُ سِفَمَ سَلِدٍيٍ كُي دَنشَنِيَتْييٍ قٍندٍ عَلَكٌ ﭑ شَ عٍ سَ فٍيلِ، ﭑ مَن شَ عٍ بْنبْ.
\v 20 عٍ تٌ نُ عِ شَ سٍيدٍ عٍتِيّن قَشَمَ، ﭑ تَن يَتِ نُ نَ، ﭑ نُ حّلّشِنشِ نَ رَ. ﭑ تَن نَن مَن نُ بٌورٍيٍ شَ دُفِيٍ سُشُشِ.›
\v 21 عَوَ، مَرِفِ نَشَ عَ قَلَ ﭑ بّ، ‹سِفَ، ﭑ عِ شّيمَ يِرٍ مَكُيٍ سِ فبّتّيٍ مَ.›»
\p 
\v 22 عٍ نَشَ عٍ تُلِ مَتِ عَ شَ مَسٍنيِ بِرِن نَ، هَن عَ يِ وْيّنيِ قَلَشِ تّمُي نَشّ. عٍ قَ فبٍلٍفبٍلٍ، «وٌ يِ شّمّ قَشَ. عَ مُ لَن عَ شَ بَلٌ.»
\v 23 عٍ نَشَ سْنشْي رَتٍ، عٍ نُ عٍ شَ دٌنمَيٍ رَتٍ عٍ مَ، عٍ نُ شُبٍ عِتٍ كُيٍ عِ.
\v 24 سْورِ مَنفّ نَشَ عَ قَلَ عَ عٍ شَ ثْلُ رَ سٌ سْورِ بَنشِ كُي، عٍ مَن شَ عَ بْنبْ لُشُسِنيِ رَ عَلَكٌ عٍ شَ عَ كٌلٌن حَمَ سْنشْمَ قٍ نَشَن مَ.
\p 
\v 25 عٍ تٌ نُ عَ شِرِقٍ عَلَكٌ عٍ شَ عَ بْنبْ، ثْلُ نَشَ سْورِ مِشِ كّمّ شُنمَتِ مَشْرِن نَشَن نُ تِشِ نَا، «سّرِيّ نَ وٌ يِ رَ نَشَن عَ مَسٍنشِ عَ وٌ شَ رْ مَكَ بْنبْ لُشُسِنيِ رَ هَلِ عَ مُ مَكِيتِشِ؟»
\v 26 سْورِ كّمّ شُنمَتِ تٌ نَ مّ، عَ نَشَ سَ سْورِ مَنفّ رَكٌلٌن. عَ نَشّ، «يِ شّمّ رْ مَكَ لَسِرِ نَ عَ رَ. وٌن نَ مَ دِ؟»
\v 27 سْورِ مَنفّ نَشَ قَ، عَ نَشَ ثْلُ مَشْرِن، «عَ قَلَ ﭑ بّ شَ رْ مَكَ نَ عِ رَ؟» ثْلُ نَشَ عَ يَابِ، «عِيٌ شّ.»
\v 28 سْورِ مَنفّ مَن نَشَ عَ قَلَ، «ﭑ تَن نَاقُلِ فبٍفبٍ نَن بَشِ، ﭑ قَ قِندِ رْ مَكَ لَسِرِ رَ.» ثْلُ نَشَ عَ قَلَ عَ بّ، «ﭑ تَن بَرِشِ لَسِرِيَ نَن كُي نّ.»
\v 29 كَبِ نَ رَبَ، نَشٍيٍ نُ وَ مَ عَ بْنبْقٍ عَلَكٌ عَ شَ وْيّن، عٍ بِرِن نَشَ عٍ مَفبِلٍن. سْورِ مَنفّ يّتّ نَشَ فَاشُ عَ كٌلٌنقٍ رَ ثْلُ رْ مَكَ نَ عَ رَ، عَ نَشَن شِرِ يْلْنشْنيِ رَ.
\s1 يُوِقِيٍ ثْلُ مَكِيتِقٍ
\p 
\v 30 نَ كُيٍ عِبَ، سْورِ مَنفّ تٌ وَ عَ كٌلٌنقٍ عَ قِيشّ رَ يُوِقِيٍ ثْلُ كَلَمُشِ قٍ نَشَن مَ، عَ نَشَ عَ قُلُن. عَ نَشَ يَامَرِ قِ، سّرّشّدُبّ كُنتِفِيٍ نُن يُوِقِ كِيتِسَيٍ بِرِن شَ مَلَن. عَ نَشَ ثْلُ رَفٌرٌ، عَ تِ عٍ تَفِ.
\c 23
\p 
\v 1 ثْلُ نَشَ عَ يَ تِ يُوِقِ كِيتِسَيٍ رَ. عَ نَشَ عَ مَسٍن، «ﭑ نفَشَكٍرٍنيِيٍ، ﭑ نَشَن نَبَشِ هَن تٌ، ﭑ عَ رَبَشِ ﭑ بْحّ قِيشّ نَن نَ عَلَ يَ شْرِ»
\v 2 سّرّشّدُبّ كُنتِفِ، عَنَنِيَسِ نَشَ مِشِيٍ يَامَرِ، نَشٍيٍ نُ نَ عَ قّ مَ، عٍ شَ عَ دّ رَفَرِن.
\v 3 عَوَ، ثْلُ نَشَ عَ قَلَ عَ بّ، «عَلَ نَن قَمَ عِ تَن بْنبْدٍ. عِ لُشِ نّ عَلْ بَنشِ نَشَن قَرِ قِيشّ كْنْ عَ كُي نْشْشِ. عِ بَرَ وَ ﭑ مَكِيتِقٍ كِيتِ سّرِيّ رَ، كْنْ عِ تٌ يَامَرِ قِشِ عٍ شَ ﭑ بْنبْ، عِ بَرَ سّرِيّ مَتَندِ.»
\v 4 نَشٍيٍ نُ نَ عَ قّ مَ، عٍ نَشَ عَ قَلَ عَ بّ، «عِ عَلَ شَ سّرّشّدُبّ كُنتِفِ نَن كٌنبِمَ يِ كِ!»
\v 5 ثْلُ نَشَ عَ قَلَ، «ﭑ نفَشَكٍرٍنيِيٍ، ﭑ مُ نُ عَ كٌلٌن شَ سّرّشّدُبّ كُنتِفِ نَ عَ رَ، بَرِ مَ عَ سّبّشِ، ‹عِ نَشَ وْيّن كٌبِ قَلَ حَمَ مَنفّ بّ.›»
\p 
\v 6 ثْلُ تٌ عَ كٌلٌن سَدُ سٍنِيٍ نُن قَرِ سّنِيٍ نُ نَ يُوِقِ كِيتِسَيٍ شَ مَلَنيِ كُي، عَ نَشَ عَ قَلَ عَ شُي عِتٍشِ رَ، «ﭑ نفَشَكٍرٍنيِيٍ، قَرِ سّنِ نَن ﭑ نَ. ﭑ بَبَ قَن قَرِ سّنِ نَن نُ عَ رَ. تٌ ﭑ نَ كِيتِ بَنشِ بَرِ مَ ﭑ لَشِ عَ رَ عَلَ قَمَ وٌن نَكٍلِدٍ قَشّ مَ كِيتِ لْشْي.»
\v 7 عَ تٌ نَ قَلَ، بٌورٍ مَتَندِ نَشَ لُ قَرِ سّنِيٍ نُن سَدُ سٍنِيٍ تَفِ. حَمَ نَشَ عِتَشُن.
\v 8 سَدُ سٍنِيٍ تَن بّ، مِشِ مُ كٍلِمَ قَشّ مَ. عٍ مَن مُ لَشِ مَلٍكّيٍ نُن حِننّيٍ شَ قٍ رَ. كْنْ قَرِ سّنِيٍ تَن لَ نٍيٍ بِرِن شَ قٍ رَ.
\v 9 سْنشْي شُنفبٍ نَشَ مِنِ. سّرِيّ كَرَ مْشْ ندٍيٍ قَرِ سّنِيٍ تَفِ عٍ نَشَ وْيّن شْرْشْي قَلَ. عٍ نَشّ، «مُشُ مُ قٍقٍ حَاشِ يٌ رَكْرْ سِشِ يِ شّمّ مَ. تّمُندٍ حِننّ ندٍ، شَ نَ مُ عَ رَ مَلٍكّ ندٍ، نَن وْيّنشِ عَ رَ.»
\v 10 سْنشْي تٌ نُ سِفَمَ فبٌ رَ، سْورِ مَنفّ نَشَ فَاشُ عٍ قَ ثْلُ قَشَقٍ. عَ نَشَ سْورِيٍ رَفٌرٌ عٍ شَ ثْلُ تٌنفٌ عٍ تَفِ، عٍ شَ عَ شَنِن سْورِ بَنشِ كُي.
\p 
\v 11 نَ كْي رَ، مَرِفِ نَشَ مِنِ ثْلُ مَ. عَ نَشَ عَ قَلَ عَ بّ، «عِ شَ لِمَنِيَ بَرِ مَ عِ قِندِ مَ ﭑ مَ سٍيدٍ نَن نَ رْ مَ عَلْ عِ عَ رَبَشِ دَرِ سَلَمُ كِ نَشّ.»
\s1 عٍ لَنيِ شِرِقٍ ثْلُ قَشَقٍ رَ
\p 
\v 12 كُيٍ تٌ عِبَ، يُوِقِيٍ نَشَ لَنيِ شِرِ كَلِ رَ، عٍ نَشَ عٍ دّفٍ، عٍ نَشَ عٍ مِن سِندٍن، عَ قٌ عٍ شَ ثْلُ قَشَ.
\v 13 نَشٍيٍ نَ لَنيِ شِرِ، عٍ نُ دَنفِ مِشِ تٌنفٌ نَانِ رَ.
\v 14 عٍ نَشَ عَ مَسٍن سّرّشّدُبّ كُنتِفِيٍ نُن قٌرِيٍ بّ، «مُشُ بَرَ مُشُ كَلِ عَلَ رَ، مُشُ مُ سٍسٍ دٌنمَ سِندٍن قٌ مُشُ شَ ثْلُ قَشَ.
\v 15 عَوَ، يَكْسِ، وٌ تَن نُن يُوِقِ كِيتِسَيٍ شَ مَنفّ مَيَندِ عَ شَ قَ عَ رَ عَلَكٌ وٌ شَ عَ شَ قٍ مَتٌ عَ قَنيِ رَ. نَ كُي، مُشُ تَن عَ قَشَمَ كِرَ رَ.»
\p 
\v 16 ثْلُ مَافِنّ شَ دِ نَشَ نَ يَنقّ كٌلٌن. عَ نَشَ سِفَ سْورِ بَنشِ كُي، عَ نَشَ نَ بِرِن مَسٍن ثْلُ بّ.
\v 17 ثْلُ نَشَ سْورِ مِشِ كّمّ شُنمَتِ ندٍ شِلِ، عَ نَشّ، «يِ سّفّتَلَ شَنِن سْورِ مَنفّ شْن مَ، عَلَكٌ عَ شَ قٍ ندٍ قَلَ عَ بّ.»
\v 18 سْورِ كّمّ شُنمَتِ نَشَ سّفّتَلَ تٌنفٌ، عَ نَشَ عَ شَنِن سْورِ مَنفّ شْن مَ. عَ نَشّ، «ثْلُ، فٍيلِمَنِ نَن ﭑ شِلِشِ، عَ نَشَ ﭑ مَيَندِ عَ ﭑ شَ قَ يِ سّفّتَلَ رَ عِ شْن مَ، عَ شَ قٍ ندٍ مَسٍن عِ بّ.»
\v 19 سْورِ مَنفّ نَشَ سّفّتَلَ تٌنفٌ، عٍ نَشَ عٍ مَمِنِ. مَنفّ نَشّ، «عِ وَ مَ مُنسٍ قَلَقٍ ﭑ بّ؟»
\v 20 عَ نَشَ عَ يَابِ، «يُوِقِيٍ بَرَ لَن عَ مَ، عٍ شَ عِ مَشَندِ عِ شَ ثْلُ شَنِن يُوِقِ كِيتِسَيٍ يِرٍ، عَلَكٌ عٍ مَن شَ مَشْرِنيِ ندٍ تِ عَ مَ.
\v 21 عِ نَشَ عِ تُلِ مَتِ عٍ رَ، بَرِ مَ مِشِ تٌنفٌ نَانِ نُن ندٍ بَرَ يَنقّ شِرِ عَ شُن عٍ يَ مَ. عٍ بَرَ عٍ كَلِ عَ عٍ مُ سٍسٍ دٌنمَ، عٍ مُ سٍسٍ مِنمَ عَ قٌ عٍ نَ ثْلُ قَشَ تّمُي نَشّ. يَكْسِ عٍ بَرَ فّ عٍ يَءِلَندٍ، عٍ قَ عِ سَفٌ نَن مَمّقٍ.»
\v 22 سْورِ مَنفّ نَشَ سّفّتَلَ رَبٌلٌ، عَ نَشَ تْنيِ دْشْ عَ مَ، قَ قَلَ، عَ قٍ نَشَن قَلَشِ عَ بّ، عَ نَشَ نَ قَلَ مِشِ يٌ بّ.
\s1 عٍ ثْلُ شّيقٍ مَنفّ قٍلِسِ شْن
\p 
\v 23 عَ نَشَ سْورِ مِشِ كّمّ شُنمَتِ قِرِن شِلِ، عَ نَشَ عَ قَلَ عٍ بّ، «وٌ سْورِ كّمّ قِرِن يَءِلَن، سْورِ سٌي رَفِيٍ تٌنفٌ سٌلٌقٍرٍ، نُن شَلِ وٌلِ كّمّ قِرِن. وٌ شَ عٍ يَءِلَن سِفَقٍ رَ سٍسَرٍ تٌ كْي رَ.
\v 24 وٌ شَ سٌي ندٍ يَءِلَن ثْلُ بّ، عَلَكٌ عَ شَ مَنفّ قٍلِسِ لِ هّيرِ كُي.»
\p 
\v 25 سْورِ مَنفّ نَشَ يِ قٍ سّبّ بَتَاشّ رَ.
\v 26 «ﭑ تَن كِلْدِ لِسِيَ، عِ تَن مَنفّ قٍلِسِ مَقَنشِ، ﭑ بَرَ عِ شّيبُ.
\v 27 يِ شّمّ يُوِقِيٍ نَن عَ سُشُشِ. عٍ نَشَ وَ عَ قَشَقٍ. ﭑ تٌ عَ كٌلٌن عَ رْ مَكَ نَ عَ رَ، ﭑ نُن سْورِيٍ نَشَ قَ، مُشُ نَشَ عَ بَ عٍ يِ.
\v 28 ﭑ تٌ وَ عَ كٌلٌنقٍ عٍ عَ سُشُشِ نَشَن مَ، ﭑ نَشَ سِفَ عَ رَ عٍ شَ كِيتِسَيٍ يِرٍ.
\v 29 ﭑ نَشَ عَ لِ عٍ عَ كَلَمُشِ عٍ شَ سّرِيّ شَ قٍ نَن مَ، كْنْ عَ مُ قٍ كٌبِ يٌ رَبَشِ عَ لَنمَ عَ شَ قَشَ نَشَن مَ، شَ نَ مُ عَ رَ عَ شَ سَ فٍيلِ كُي.
\v 30 ﭑ تٌ بَرَ عَ مّ عَ يُوِقِيٍ بَرَ فَلِ مَلَن عَ شِلِ مَ، ﭑ نَشَ عَ رَ سَنبَ عِ مَ كٍرٍن نَ. ﭑ عَ كَلَمُمَيٍ رَكٌلٌنمَ عٍ يّتّ كَن شَ سَ عَ كَلَمُ عِ شْن عَ شَ قٍ رَ. وٌ سَلَمُ.»
\p 
\v 31 سْورِيٍ نَشَ ثْلُ تٌنفٌ عَلْ عٍ يَمَرِشِ كِ نَشّ. عٍ نَشَ عَ شَنِن كْي رَ هَن عَنتِثَتِرِ.
\v 32 نَ كُيٍ عِبَ، سْورِيٍ نَشَ فبِلٍن سْورِ بَنشِ. سٌي رَفِيٍ نَشَ ثْلُ تٌنفٌ.
\v 33 عٍ تٌ سٌ سٍسَرٍ، سٌي رَفِيٍ نَشَ بَتَاشّ نُن ثْلُ سٌ مَنفّ يِ رَ.
\v 34 مَنفّ تٌ فّ بَتَاشّ شَرَندٍ، عَ نَشَ ثْلُ مَشْرِن عَ كٍلِ دّننَشّ. عَ تٌ بَرَ عَ مّ عَ سِلِسِكَ نَ عَ رَ، عَ نَشَ عَ قَلَ،
\v 35 «ﭑ قَمَ نّ عِ مَكِيتِدٍ عِ تْوحّفّلَيٍ نَ قَ تّمُي نَشّ.» عَ نَشَ يَامَرِ قِ عٍ شَ ثْلُ شَنِن فٍيلِ بَنشِ هٍرٌدٍ نَشَن تِشِ.
\c 24
\s1 قٍلِسِ كِيتِ سَقٍ ثْلُ شَ قٍ رَ
\p 
\v 1 شِ سُولِ دَنفِ شَنبِ، عَنَنِيَسِ، نَشَن قِندِشِ سّرّشّدُبّ كُنتِفِ رَ، نُن قٌرِيٍ نَشَ قَ عٍ نُن شُنمَقَلّ ندٍ، نَشَن شِلِ تٍرِتُلٌ. عٍ نَشَ ثْلُ كَلَمُ مَنفّ شْن مَ.
\v 2 عٍ تٌ ثْلُ شِلِ، تٍرِتُلٌ نَشَ سٌ عَ تْوحّفّقٍ يِ مَسٍنيِ رَ.
\p «قٍلِسِ مَنفّ قَنيِ، يِ بْشِ بِرِن دْشْشِ بْحّسَ كُي عِ شَ قٍ كٌلٌنيِ نُن عِ شَ شَشِلِ قَنيِ نَن سَابُي رَ.
\v 3 عِ بَرَ مُشُ رَ سّيوَ هّيرِ شُنفبٍ رَ.
\v 4 ﭑ مُ وَ مَ عِ رَبُقٍ، كْنْ ﭑ بَرَ عِ مَشَندِ عِ شَ عِ تُلِ مَتِ مُشُ شَ مَسٍنيِ رَ دٌندٌرٌنتِ.
\v 5 مُشُ بَرَ عَ تٌ يِ شّمّ مِشِ حَاشِ نَ عَ رَ. عَ يُوِقِيٍ تَفِ عِسٌمَ نَشٍيٍ نَ دُنِحَ بِرِن. عَ تَن نَن نَ عِسَ نَسَرّتِكَ شَ حَمَ شُنيِ رَ.
\v 6 عَ مَن نَشَ وَ هْرْ مْبَنشِ مَبٍرٍقٍ. مُشُ نَشَ عَ سُشُ. مُشُ نَشَ وَ عَ مَكِيتِقٍ مُشُ شَ سّرِيّ كِ مَ،
\v 7 كْنْ سْورِ مَنفّ لِسِيَ نَشَ قَ، عَ نَشَ عَ بَ مُشُ يِ سّنبّ شُنفبٍ رَ.
\v 8 عَ نَشَ عَ كَلَمُلَيٍ يَامَرِ عٍ شَ قَ عِ شْن مَ. شَ عِ قَن ثْلُ مَشْرِن، عِ قَمَ عَ كٌلٌندٍ مُشُ عَ سُشُشِ قٍ نَشَن مَ.»
\v 9 يُوِقِيٍ نَشَ تِن نَ مَسٍنيِ رَ، عٍ قَن نَشَ عَ قَلَ عَ نَ نَ كِ نّ.
\p 
\v 10 مَنفّ نَشَ ثْلُ يَامَرِ عَ قَن شَ وْيّن. ثْلُ نَشَ عَ مَسٍن عَ بّ، «ﭑ عَ كٌلٌن، يِ بْشِ مَكِيتِمَ نَن عِ رَ كَبِ حّ وُيَشِ. نَ كُي، ﭑ نَن مَ قٍ شُنمَقَلَمَ نّ عِ بّ لَنلَنتٍيَ كُي.
\v 11 شِ قُ نُن قِرِن مُ دَنفِ كَبِ ﭑ نَشَ سِفَ دَرِ سَلَمُ سَلِدٍ.
\v 12 عٍ مُ نُ مُشُ نُن مِشِ لِ سْنشْ رَ هْرْ مْبَنشِ كُي، شَ نَ مُ عَ رَ سَلِدٍ شُنشُرِيٍ كُي. ﭑ مُ سْنشْي رَتٍشِ تَا كُي، ﭑ مُ فَلِ كُي عِسٌشِ.
\v 13 عٍ مُ نْمَ سٍسٍ مَسٍندٍ، عٍ ﭑ كَلَمُمَ نَشَن مَ.
\v 14 ﭑ نَشَن مَسٍنمَ عِ بّ نَ نَن يَ. ﭑ نَن ﭑ بٍنبَيٍ مَرِفِ عَلَ نَن بَتُمَ عَلْ عِسَ شَ كِرَ عَ مَسٍنشِ كِ نَشّ، عٍ عَ قَلَمَ كِرَ نَشَن بّ عَ وُلٍ كِرَ. نَشَن سّبّشِ تَوُرٍتَ مُنسَ نُن نَمِحْنمّيٍ شَ كِتَابُي كُي، ﭑ لَ نَ بِرِن نَ.
\v 15 ﭑ لَشِ عَلَ شَ مَسٍنيِ رَ نَشَن مَسٍنشِ عَ تِنشِنتْييٍ نُن تِنشِنتَرٍ بِرِن قَمَ نّ كٍلِدٍ قَشّ مَ. يُوِقِيٍ قَن لَشِ نَ رَ.
\v 16 نَ نَن عَ تٌشِ ﭑ نَن ﭑ يّتّ كَرَشَنمَ عَلَكٌ ﭑ شَ ﭑ مَ سِمَيَ رَدَنفِ بْحّ قِيشّ كُي عَلَ نُن مِشِيٍ تَفِ.
\v 17 ﭑ مُ نُ نَ بٍ حّ وُيَشِ بُن مَ، كْنْ يَكْسِ ﭑ قَشِ هَرِفٍ ندٍ رَ ﭑ بْنسْي بّ. ﭑ قَن قَشِ سّرّشّ بَدٍ عَلَ بّ.
\v 18 عٍ ﭑ لِشِ نَ تّمُي نّ هْرْ مْبَنشِ كُي، ﭑ سّنِيّنشِ، فَلِ مُ نَ ﭑ قْشْ رَ، سْنشْي يٌ قَن مُ كٍلِ ﭑ سَابُي رَ.
\v 19 كْنْ يُوِقِ ندٍ نَشٍيٍ كٍلِ عَسِ بْشِ مَ، عٍ مُ تِن ﭑ مَ قٍ رَ. عٍ تَن شَ عٍ يّتّ مَسٍن عِ بّ، شَ قٍ ندٍ نَ عٍ بّ ﭑ مَ قٍ رَ.
\v 20 شَ نَ مُ عَ رَ نَشٍيٍ نَ بٍ، عٍ شَ عَ مَسٍن عِ بّ عٍ ﭑ تٌشِ قٍ حَاشِ نَشَن شُن، ﭑ تٌ سِفَ يُوِقِ كِيتِسَيٍ يِرٍ.
\v 21 ﭑ وْيّنيِ نَشَن قَلَشِ عٍ تَفِ نَ نَن يَ؛ ‹وٌ ﭑ مَكِيتِمَ نّ تٌ بَرِ مَ ﭑ لَشِ عَ رَ عَلَ قَمَ نّ مِشِ قَشَشِيٍ رَكٍلِدٍ.›»
\p 
\v 22 قٍلِسِ نَشَن نُ عِسَ شَ كِرَ كٌلٌن عَ قَنيِ رَ، عَ نَشَ عٍ شَ قٍ سَ سِندٍن. عَ نَشّ، «مَنفّ لِسِيَ نَ قَ، ﭑ وٌ شَ قٍ مَتٌمَ.»
\v 23 عَ نَشَ سْورِ مِشِ كّمّ شُنمَتِ يَمَرِ عَ شَ ثْلُ كَنتَ، عَ نَشَ عَ تْورْ، عَ مَن نَشَ عَ شَ مِشِ يٌ رَتْن قٍ قَنيِ رَبَقٍ رَ عَ بّ.
\p 
\v 24 شِ ندٍيٍ تٌ دَنفِ، قٍلِسِ نُن عَ شَ فِنّ دِرُ سِلَ، نَشَن نَ يُوِقِ رَ، عٍ نَشَ قَ. قٍلِسِ نَشَ ثْلُ شِلِ كَوَندِ رَبَدٍ عِسَ عَلَ شَ مِشِ سُفَندِشِ شَ قٍ رَ. ثْلُ نَشَ دَنشَنِيَ شَ قٍ قَلَ عٍ بّ عِسَ مَ،
\v 25 كْنْ عَ شَ مَسٍنيِ تٌ نُ بِنيَشِ تِنشِنيِ مَ، نُن يّتّ شُرُقٍ مَ، نُن عَلَ شَ كِيتِ نَشَن قَمَ، قٍلِسِ نَشَ فَاشُ. عَ نَشّ، «سِفَ سِندٍن. ﭑ نَ ﭑ يّتّ مَسْتْ تّمُي نَشّ، ﭑ مَن عِ شِلِمَ.»
\v 26 عَ مَن نُ وَشِ نّ ثْلُ شَ كْبِرِ قِ عَ مَ. عَ نُ عَ شِلِمَ نَ نَن مَ تّمُي بِرِن، عٍ شَ سَ عٍ بٌرٍ تٌ.
\p 
\v 27 حّ قِرِن تٌ دَنفِ، قٍلِسِ مَسَرَ مَ نَشَ قَ، ثْرُ سُ قّسِتُ. قٍلِسِ تٌ وَ عَ يّتّ مَقَنقٍ يُوِقِيٍ بّ، عَ نَشَ ثْلُ لُ فٍيلِ كُي.
\c 25
\s1 قّسِتُ ثْلُ مَكِيتِقٍ
\p 
\v 1 قّسِتُ نَشَ شِ سَشَن نَبَ سٍسَرٍ. نَ شَنبِ، عَ نَشَ تٍ دَرِ سَلَمُ.
\v 2 سّرّشّدُبّ كُنتِفِ نُن يُوِقِ كُنتِفِيٍ نَشَ ثْلُ كَلَمُ قّسِتُ بّ.
\v 3 عٍ نَشَ قّسِتُ مَيَندِ عَ شَ قَ عَ رَ دَرِ سَلَمُ. عٍ نُ وَ مَ نّ عٍ شَ عَ قَشَ كِرَ رَ.
\v 4 قّسِتُ نَشَ عٍ يَابِ، «ثْلُ مَكَنتَشِ سٍسَرٍ. عَ فبٍفبٍ مُ لُشِ ﭑ تَن قَن شَ سِفَ نَا.
\v 5 وٌ شَ يَرٍرَتِ ندٍيٍ شَ ﭑ مَتِ، وٌ شَ ثْلُ كَلَمُ نَا شَ عَ بَرَ سَ قٍ حَاشِ ندٍ رَبَ.»
\p 
\v 6 قّسِتُ مُ سٍ سَ شِ سٌلٌمَسَشَن قَرِ، شَ نَ مُ عَ رَ شِ قُ دَرِ سَلَمُ، عَ نَشَ فٌرٌ سٍسَرٍ. نَ كُيٍ عِبَ، عَ نَشَ دْشْ عَ شَ كِيتِ كِبَنيِ مَ. عَ نَشَ يَامَرِ قِ عٍ شَ قَ ثْلُ رَ.
\v 7 عَ تٌ قَ، يُوِقِيٍ نَشٍيٍ قَ كٍلِ دَرِ سَلَمُ، عٍ نَشَ عَ رَبِلِن. عٍ نَشَ تْوحّفّ فبٍفبٍ سَ عَ شُن، عٍ مُ نُ نْمَ نَشَن مَسٍندٍ نْندِ رَ.
\v 8 ثْلُ نَشَ سٌ عَ يّتّ شُنمَقَلَقٍ، عَ نُ عَ قَلَ، «ﭑ مُ قٍ حَاشِ يٌ رَبَشِ يُوِقِيٍ شَ سّرِيّ رَ، شَ نَ مُ هْرْ مْبَنشِ رَ، شَ نَ مُ عَ رَ رْ مَ مَنفّ رَ.»
\v 9 قّسِتُ تٌ وَ عَ يّتّ مَقَنقٍ يُوِقِيٍ شْن، عَ نَشَ ثْلُ مَشْرِن، «عِ وَ مَ تٍقٍ دَرِ سَلَمُ عِ شَ سَ مَكِيتِ يِ قٍيٍ مَ ﭑ يَ شْرِ؟»
\v 10 ثْلُ نَشَ عَ يَابِ، «ﭑ لَنمَ ﭑ شَ مَكِيتِ مَنفَسَنيِ شَ كِيتِ بَنشِ نَن كُي، ﭑ تِشِ دّننَشّ يِ كِ. ﭑ مُ قٍ كٌبِ يٌ رَبَشِ يُوِقِيٍ رَ. عِ قَن نَ كٌلٌن عَ قَنيِ رَ.
\v 11 شَ ﭑ بَرَ قٍ حَاشِ رَبَ عَ لَنمَ ﭑ شَ قَشَ نَشَن مَ، ﭑ مُ تٌندِ مَ ﭑ شَ قَشَ، كْنْ شَ عٍ نَشَن قَلَمَ وُلٍ نَ عَ رَ، عَ مُ لَن مِشِ يٌ شَ ﭑ سٌ عٍ يِ رَ. مَنفّ شُنفبٍ شَ سَ ﭑ مَكِيتِ رْ مَ.»
\v 12 قّسِتُ تٌ وْيّن عَ رَ سِمَيٍ رَ، عَ نَشَ عَ قَلَ ثْلُ بّ، «عِ بَرَ وَ سِفَقٍ مَنفّ شُنفبٍ شْن. عَوَ، عِ سِفَمَ نّ.»
\s1 ثْلُ مَسٍنقٍ عَفِرِثَ نُن بٍرِنِسِ بّ
\p 
\v 13 شِ ندٍ تٌ دَنفِ، مَنفّ عَفِرِثَ نُن بٍرِنِسِ نَشَ سٌ سٍسَرٍ قّسِتُ شّيبُدٍ.
\v 14 عٍ تٌ بَرَ شِ وُيَشِ رَدَنفِ نَا، قّسِتُ نَشَ ثْلُ شَ قٍ قَلَ مَنفّ عَفِرِثَ بّ. عَ نَشّ، «قٍلِسِ بَرَ فٍيلِمَنِ ندٍ لُ بٍ.
\v 15 ﭑ نُ نَ دَرِ سَلَمُ تّمُي نَشّ، سّرّشّدُبّ كُنتِفِيٍ نُن يُوِقِيٍ قٌرِيٍ نَشَ عَ كَلَمُ، عٍ مَن نَشَ وَ عَ شَ قَشَ.
\v 16 ﭑ نَشَ عٍ يَابِ عَ رْ مَكَيٍ شَ سّرِيّ مُ مِشِ قَشَمَ، قٌ عَ شَ عَ فبٍ قَلَ كَلَمُسَيٍ بّ كِيتِسَ يَ شْرِ.
\v 17 نَ قٍ نَن عٍ رَقَشِ بٍ. ﭑ قَن مُ دُفُندِ. نَ كُيٍ عِبَ، ﭑ نَشَ دْشْ ﭑ مَ كِيتِ بَنشِ. ﭑ نَشَ يَامَرِ قِ عٍ شَ قَ نَ شّمّ رَ.
\v 18 كَلَمُسَيٍ تٌ عٍ دّنتّفّ، عٍ مُ قٍ حَاشِ يٌ قَلَ عَ شُن مَ، ﭑ نُ نَشٍيٍ مَحْشُنشِ.
\v 19 عٍ نُ شْرْشْمَ عٍ شَ دِينّ نَن مَ قٍ رَ، عَ نُن عِسَ شَ قٍ رَ. عٍ نَشّ عَ بَرَ قَشَ، كْنْ ثْلُ نَشّ عَ بَلٌشِ.
\v 20 عَوَ، ﭑ تٌ مُ عَ كٌلٌن عَ لَن ﭑ شَ نَشَن نَبَ، ﭑ نَشَ عَ مَشْرِن شَ عَ وَ مَ سِفَقٍ دَرِ سَلَمُ، عَ شَ مَكِيتِ نَا.
\v 21 كْنْ ثْلُ نَشَ وَ عَ شَ قٍ شَنِنقٍ مَنفّ شُنفبٍ شْن مَ. نَ تّمُي ﭑ نَشَ يَامَرِ قِ عٍ شَ عَ كَنتَ هَن ﭑ عَ رَ سَنبَمَ مَنفّ شُنفبٍ مَ تّمُي نَشّ.»
\p 
\v 22 عَفِرِثَ نَشَ عَ قَلَ قّسِتُ بّ، «ﭑ قَن وَ مَ ﭑ تُلِ مَتِقٍ نَ شّمّ رَ.» قّسِتُ نَشَ عَ يَابِ، «تِنَ، عِ عَ شُي مّمَ.»
\v 23 عَوَ، نَ كُيٍ عِبَ، عَفِرِثَ نُن بٍرِنِسِ نَشَ سٌ مَلَن يِرٍ عٍ نُن تَا كُنتِفِيٍ. عٍ نُ مَشِرِشِ عَ قَنيِ رَ. قّسِتُ شَ يَامَرِ مَ، عٍ نَشَ قَ ثْلُ رَ.
\v 24 قّسِتُ نَشَ عَ قَلَ، «مَنفّ عَفِرِثَ نُن وٌ تَن نَشٍيٍ بِرِن نَ بٍ، وٌ بَرَ يِ شّمّ تٌ يُوِقِ نَشَن بِرِن كَلَمُشِ ﭑ شْن دَرِ سَلَمُ نُن بٍ. عٍ نَشّ عَ عَ شَ قَشَ.
\v 25 ﭑ تَن بّ، عَ مُ قٍقٍ رَبَشِ عَ لَن عَ شَ قَشَ نَشَن مَ، كْنْ عَ تَن يَتِ بَرَ مَيَندِ تِ سِفَقٍ رَ مَنفّ شُنفبٍ شْنيِ رْ مَ. عَوَ، ﭑ قَن بَرَ تِن نَ رَ.
\v 26 ﭑ مُ قٍ شْرِ يٌ سْتْشِ نَشَن سّبّمَ مَنفّ شُنفبٍ مَ عَ شَ قٍ رَ. نَ نَ عَ رَ، ﭑ عَ رَ مِنِشِ وٌ يَ عِ، عَ فبٍنفبٍنيِ عِ تَن مَنفّ عَفِرِثَ، عَلَكٌ وٌن نَ فّ عَ مَشْرِندٍ ﭑ شَ عَ كٌلٌن عَ لَنمَ ﭑ شَ نَشَن سّبّ.
\v 27 ﭑ مُ نْمَ فٍيلِمَنِ رَ سَنبَدٍ مَنفّ مَ، ﭑ مُ عَ مَسٍن عَ نَشَن نَبَشِ.»
\c 26
\s1 ثْلُ عَ يّتّ شُن مَقَلَقٍ
\p 
\v 1 عَفِرِثَ نَشَ عَ قَلَ ثْلُ بّ، «عِ شَ عِ يّتّ شُن مَقَلَ.» ثْلُ تٌ عَ بّلّشّ عِتٍ، عَ نَشَ عَ يّتّ رَقِيشّ يِ مَسٍنيِ رَ.
\v 2 «مَنفّ عَفِرِثَ، تٌ ﭑ حّلّشِنشِ ﭑ مَ قٍ رَقِيشّقٍ رَ يُوِقِيٍ ﭑ كَلَمُشِ نَشَن مَ.
\v 3 عِ عٍ شَ دِينّ نُن عٍ شَ سّرِيّ كٌلٌن كِ قَنيِ رَ. عَوَ يَندِ، عِ شَ عِ تُلِ مَتِ ﭑ نَ.
\v 4 كَبِ ﭑ دِ مّدِ تّمُي، ﭑ نُ نَ دَرِ سَلَمُ ﭑ بْنسْي يَ مَ. يُوِقِ بِرِن ﭑ حّرّ كِ كٌلٌن
\v 5 عَ رَكُيَ. عٍ مَن عَ كٌلٌن قَرِ سّنِ نَن نُ ﭑ نَ دِينّلَ تَفِ نَشٍيٍ شَ قٍ مَشْرْشْ. عٍ نْمَ نَ سٍيدٍحْشْيَ بَدٍ.
\v 6 يَكْسِ، عٍ ﭑ نَكِيتِقٍ بَرِ مَ ﭑ لَشِ عَلَ شَ لَايِدِ رَ عَ نَشَن تٌنفٌشِ مُشُ بٍنبَيٍ بّ،
\v 7 مُشُ بْنسْي قُ نُن قِرِنيِ نَشَن مَمّقٍ. عٍ عَلَ بَتُمَ تّمُي بِرِن، كْي نُن يَنيِ. ﭑ لَشِ نَ لَايِدِ نَن نَ. مَنفّ، يُوِقِيٍ ﭑ كَلَمُشِ نَ نَن مَ.
\v 8 وٌ نْمَ لَدٍ عَ رَ عَ عَلَ مِشِ قَشَشِيٍ رَكٍلِمَ؟»
\p 
\v 9 «ﭑ تَن كَتَ نّ كِرَ مْولِ بِرِن نَ ﭑ شَ عِسَ نَسَرّتِكَ شِلِ كَنَ.
\v 10 ﭑ نَ نَن نَبَ دَرِ سَلَمُ. سّرّشّدُبّ كُنتِفِيٍ نَشَ تِن ﭑ شَ سّنِيّنتْي وُيَشِ سَ فٍيلِ كُي. ﭑ مَن نَشَ تِن عٍ شَ قَشَ.
\v 11 ﭑ نُ سِفَمَ سَلِدٍ بَنشِيٍ كُي عَلَكٌ ﭑ شَ عٍ تْورْ، عٍ شَ فبِلٍن عٍ شَ دَنشَنِيَ قْشْ رَ. ﭑ مَ شْنّ كُي، ﭑ نُ عٍ تْورْ هَلِ تَا فبّتّيٍ كُي.»
\p 
\v 12 «سّرّشّدُبّ كُنتِفِيٍ نَشَ تِن ﭑ شَ سِفَ دَ مَسِ نَ قٍ مَ.
\v 13 مَنفّ، يَنيِ تَفِ ﭑ نَشَ يَنبّ تٌ كِرَ شْن مَ كٍلِقٍ كٌورٍ، ﭑ تَن نُن ﭑ بٌورٍيٍ رَبِلِنيِ. عَ يَنبّ نُ دَنفِ سٌفٍ رَ.
\v 14 مُشُ نَشَ بِرَ بْشِ مَ. ﭑ نَشَ شُي ندٍ مّ نَشَن نُ عَ قَلَمَ ﭑ بّ عٍبُرُ شُي، ‹سْلُ، سْلُ، مُنقٍ رَ عِ ﭑ حَشَنكَتَمَ؟ نَ قٍ شْرْشْمَ نّ عِ بّ.›
\v 15 ﭑ نَشَ عَ يَابِ، ‹مَرِفِ، ندٍ عِ رَ؟› مَرِفِ نَشَ ﭑ يَابِ، ‹عِسَ نَن ﭑ نَ، عِ نَشَن حَشَنكَتَقٍ.
\v 16 كٍلِ، تِ عِ سَنيِيٍ شُن نَ. ﭑ مِنِشِ نّ عِ مَ عَلَكٌ ﭑ شَ عِ قِندِ وَلِكّ نُن سٍيدٍ رَ قٍيٍ مَ عِ نَشٍيٍ تٌشِ نُن عِ قَمَ نَشٍيٍ تٌدٍ.
\v 17 ﭑ عِ رَتَنفَمَ نّ يُوِقِيٍ مَ نُن سِ فبّتّيٍ مَ، ﭑ عِ شّيمَ نَشٍيٍ مَ، عَلَكٌ عِ شَ عٍ يَيٍ رَبِ،
\v 18 عٍ شَ مِنِ دِ مِ كُي، عٍ شَ سٌ نَءِيَلَنيِ كُي. عٍ شَ كٍلِ سٍنتَنّ شَ نْي بُن، عٍ شَ سٌ عَلَ شَ مَنفّيَ نِينِ بُن مَ. نَ كُي، عٍ شَ يُنُبِ شَقَرِ مَ نّ، عٍ مَن قَمَ نّ كّ سْتْدٍ سّنِيّنتْييٍ يَ مَ نَشٍيٍ دَنشَنِيَشِ ﭑ مَ.›»
\p 
\v 19 «نَ كُي، مَنفّ عَفِرِثَ، ﭑ مُ تٌندِ نَ شّيرَيَ رَ نَشَن كٍلِ كٌورٍ مَ.
\v 20 ﭑ نَشَ نَ كَوَندِ تِ دَ مَسِ، دَرِ سَلَمُ، يُدَيَ، نُن سِ فبّتّيٍ تَفِ. ﭑ نَشَ عَ مَسٍن عٍ بّ عٍ شَ تُوبِ، عٍ شَ دَنشَنِيَ عَلَ مَ، نُن عٍ شَ وَلِ قَنيِ رَبَ نَشَن عٍ شَ تٌفٌندِيَ مَسٍنمَ.»
\p 
\v 21 «يُوِقِيٍ نَشَ ﭑ سُشُ هْرْ مْبَنشِ كُي، عٍ وَشِ ﭑ قَشَقٍ نَ نَن مَ.
\v 22 كْنْ، عَلَ تَنتُ، ﭑ بَلٌشِ عَ تَن نَن سَابُي رَ هَن تٌ. ﭑ نَشَ نَ سٍيدٍحْشْيَ بَ دِ مّيٍ نُن قٌرِيٍ بِرِن بّ. ﭑ مُ قٍقٍ فبّتّ قَلَشِ قٌ نَمِحْنمّيٍ نُن عَننَبِ مُنسَ نُ نَشٍيٍ قَلَمَ عَ عٍ قَمَ نّ رَبَدٍ.
\v 23 عٍ نَشَ عَ مَسٍن عَلَ شَ مِشِ سُفَندِشِ تْورْ مَ نّ، عَ سِنفٍ نَن كٍلِمَ قَشَمِشِيٍ يَ مَ، عَ نُن عَ يُوِقِيٍ نُن سِ فبّتّيٍ كَوَندِ مَ كِسِ رَ.»
\p 
\v 24 عَ تٌ نُ وْيّنقٍ عَ يّتّ رَقِيشّقٍ رَ، قّسِتُ نَشَ عَ قَلَ عَ شُي عِتٍشِ رَ، «ثْلُ، عِ دَشُ! عِ شَ قٍ فبٍفبٍ كٌلٌنيِ بَرَ عِ قِندِ دَشُي رَ.»
\v 25 ثْلُ نَشَ عَ يَابِ، «قّسِتُ مَقَنشِ، دَشُي مُ نَ ﭑ نَ. ﭑ نْندِ نُن لْننِ نَن مَسٍنقٍ.
\v 26 مَنفّ عَفِرِثَ تَن يِ قٍيٍ كٌلٌن. ﭑ يِ بِرِن قَلَمَ عَ تَن نَن بّ، بَرِ مَ عَ حَن عَ كٌلٌن، عَ عَ مُ رَبَ فُندٌ شَ كُي.»
\v 27 ثْلُ نَشَ عَ قَلَ عَفِرِثَ بّ، «مَنفّ عَفِرِثَ، عِ لَشِ نَمِحْنمّيٍ رَ؟ عِ لَ عٍ رَ، ﭑ نَ كٌلٌن.»
\p 
\v 28 عَفِرِثَ نَشَ عَ قَلَ ثْلُ بّ، «عَ فبٍ مُ لُشِ عِ شَ ﭑ قَن قِندِ عِسَيَنكَ رَ!»
\v 29 ثْلُ نَشَ عَ يَابِ، «عَ قَ قِندِ يَكْسِ رَ، شَ نَ مُ تّمُي فبّتّ، ﭑ مَرِفِ مَشَندِ مَ نّ عَلَكٌ عِ تَن يٌ، عَ نُن نَشَن بِرِن ﭑ شُي رَ مّقٍ بٍ تٌ، وٌ قَن شَ لُ عَلْ ﭑ تَن، بَ يِ يْلْنشْنيِ رَ نَشَن نَ ﭑ مَ.»
\p 
\v 30 مَنفّ عَفِرِثَ، مَنفّ قّسِتُ، بٍرِنِسِ، نُن نَشٍيٍ بِرِن نُ دْشْشِ عٍ سّيتِ مَ، عٍ نَشَ كٍلِ.
\v 31 عٍ تٌ نُ سِفَمَ، عٍ نَشَ عَ قَلَ عٍ بٌرٍ بّ، «يِ شّمّ مُ قٍقٍ رَبَشِ عَ لَنمَ عَ شَ قَشَ نَشَن مَ، شَ نَ مُ عَ رَ عَ لَنمَ عَ شَ سَ فٍيلِ كُي نَشَن مَ.»
\v 32 عَفِرِثَ نَشَ عَ قَلَ قّسِتُ بّ، «يِ شّمّ نُ لَن عَ شَ بّحِن، كْنْ عَ بَرَ مَشَندِ تِ مَنفّ شُنفبٍ شَ عَ مَكِيتِ.»
\c 27
\s1 ثْلُ سِفَقٍ رْ مَ
\p 
\v 1 عٍ تٌ نَتّ تٌنفٌ مُشُ شَ بَكِ كُنكُي كُي سِفَقٍ رَ عِتَلِ، عٍ نَشَ ثْلُ نُن فٍيلِمَنِ ندٍيٍ سٌ سْورِ مِشِ كّمّ شُنمَتِ يِ رَ نَشَن شِلِ يُلِيُسِ، نَشَن نَ مَنفّ شُنفبٍ شَ سْورِيٍ يَ مَ.
\v 2 مُشُ نُن عَرِ سِتَرَكِ، نَشَن كٍلِ تّسَلٌنِكِ مَسٍدٌن بْشِ مَ، نَشَ بَكِ كُنكُي كُي نَشَن كٍلِ عَدِرَ مِتِ. عَ نُ لَن عَ شَ دَنفِ عَسِ سّيتِ مَ.
\v 3 نَ كُيٍ عِبَ، مُشُ نَشَ كِلْن سِدْن. يُلِيُسِ، نَشَن نُ عَ حْشْ سَشِ ثْلُ شْن مَ عَ قَنيِ رَ، عَ نَشَ عَ سَفٌ سَ عَ شَ سِفَ عَ بٌورٍيٍ شْنيِ بِيَاسِ قَندّ قٍندٍ.
\v 4 مُشُ تٌ كٍلِ نَا، مُشُ نَشَ دَنفِ سِثِرِ سُرِ مَ، بَرِ مَ قٌيٍ مُ نُ تِنشِ مُشُ بّ.
\v 5 مُشُ تٌ سِلِسِ نُن ثَنقِلِيَ بَا عِفِرِ، مُشُ نَشَ سٌ مِرَ، لِسِ بْشِ مَ.
\v 6 مّننِ، سْورِ مِشِ كّمّ شُنمَتِ نَشَ كُنكُي تٌ نَشَن كٍلِ عَلٍسَندِرٍ، عَ سِفَقٍ عِتَلِ. مُشُ نَشَ بَكِ نَ كُي.
\p 
\v 7 شِ وُيَشِ بُن مَ كُنكُي نُ تْورْ مَ حّرّدٍ. كَتَ نُن كَتَ مُشُ قَ سِنِدِ لِ كْنْ قٌيٍ مُ تِن مُشُ شَ كِلْن نَا. نَ نَن عَ تٌ مُشُ نَشَ دَنفِ كِرّتِ سُرِ لَابٍ رَ، سَلٍمٌنٍ سّيتِ مَ.
\v 8 نَا عِحّرّقٍ نُ شْرْشْ. مُشُ نَشَ يِرٍ ندٍ لِ، نَشَن شِلِ وَقُ تٌقَنيِ، لَسٍيَ قّ مَ.
\p 
\v 9 مُشُ نَشَ بُ نَا. حّرّ مَن نُ شْرْشْ بَرِ مَ سُنيِ تّمُي نُ بَرَ دَنفِ.
\v 10 نَ نَ عَ رَ، ثْلُ نَشَ عَ قَلَ، «ﭑ بِيَاسِبٌورٍيٍ، ﭑ بَرَ عَ كٌلٌن وٌن مَ حّرّ قَمَ نّ شْرْشْدٍ. كٌتٍيٍ، كُنكُي، نُن مِشِيٍ قَمَ نّ تْورْدٍ.»
\v 11 سْورِ كّمّ شُنمَتِ نَشَ عَ تُلِ مَتِ كّثِنِ نُن كُنكُي كَنيِ شَ وْيّنيِ رَ، عَ تٌندِ ثْلُ شَ مَرَ سِ رَ.
\v 12 مِشِ فبٍفبٍ نَشَ وَ قٍنِكِ لِقٍ، بَرِ مَ عٍ نُ نَ وَقُ دّننَشّ، مّننِ مُ نُ قَن حّمّ رَدَنفِدٍ رَ. قٍنِكِ، كِرّتِ سُرِ وَقُ نَن عَ رَ، نَشَن يَ رَقِندِشِ سٌفٍفٌرٌدٍ بِرِ مَ. عٍ نَشَ وَ عٍ شَ حّمّ رَدَنفِ نَا.
\p 
\v 13 قٌيٍ دِ ندٍ نَشَ مِنِ كٍلِ كْولَ مَ. عٍ نَشَ عَ مَحْشُن عَ بِيَاسِ بَرَ قَن. عٍ نَشَ هَنفَ بّندُن، عٍ كُنكُي رَدَنفِ كِرّتِ سُرِ قّ مَ.
\v 14 كْنْ نَ تّمُي قٌيٍ شُنفبٍ، نَشَن شِلِ يُرَكِلْن، عَ نَشَ قَ كٍلِ سُرِ مَ.
\v 15 قٌيٍ نَشَ كُنكُي تُتُن، هَن كُنكُي مُ نُ نْمَ مَتِنشِندٍ. مُشُ نَشَ مُشُ رَشَرَ قٌيٍ يِ رَ.
\v 16 مُشُ نَشَ دَنفِ سُرِ لَنمَدِ لَابٍ رَ، نَشَن شِلِ كِلٌدَ. مُشُ نَشَ تْورْ كُنكُي لَنمَ مَسْتْقٍ رَ.
\v 17 عٍ تٌ فّ عَ رَتٍدٍ، عٍ نَشَ لُوتِ مَقِلِن كُنكُي مَ. عٍ تٌ نُ فَاشُشِ دْشْقٍ رَ سِرِتٍ بّنكِ مَ، عٍ نَشَ بّلَ رَفٌرٌ، قٌيٍ نُ قَ سِفَ مُشُ رَ.
\v 18 قٌيٍ نَشَ مُشُ بْنبْ عَ قَنيِ رَ. نَ كُيٍ عِبَ، مُشُ نَشَ كٌتٍ ندٍ وٌلِ بَا مَ.
\v 19 شِ سَشَن تٌ دَنفِ، مُشُ يَتِ نَشَ كُنكُي عِسٍيٍ بِرِن نَفٌرٌ يٍ مَ.
\v 20 شِ وُيَشِ نَشَ دَنفِ، سٌفٍ مُ نَ، تُنبُييٍ مُ نَ، قٌيٍ سّنبّ نُ فبٌمَ نَن تُي. مُشُ مُ نُ لَشِ مُشُ كِسِقٍ رَ سْنْن.
\p 
\v 21 كَبِ شِ وُيَشِ مُشُ مُ نُ دٌنسٍ دٌنمَ. عَوَ ثْلُ نَشَ تِ مِشِيٍ تَفِ، عَ نَشَ عَ قَلَ عٍ بّ، «ﭑ بٌورٍيٍ، شَ وٌ وٌ تُلِ مَتِ ﭑ نَ نُ، وٌن مُ كٍلِمَ كِرّتِ نُ، وٌن مُ يِ كَسَرّ نُن لْسِ سْتْمَ نُ.
\v 22 كْنْ يَكْسِ، ﭑ وٌ رَ سِمَ نّ، وٌ شَ لِمَنِيَ، بَرِ مَ مِشِ يٌ مُ قَشَمَ وٌ يَ مَ، كُنكُي نَن فبَنسَن كَسَرَ مَ.
\v 23 ﭑ مَرِفِ عَلَ، ﭑ وَلِمَ نَشَن بّ، عَ شَ مَلٍكّ ندٍ بَرَ مِنِ ﭑ مَ يِ كْي رَ.
\v 24 عَ نَشَ عَ قَلَ ﭑ بّ، ‹ثْلُ، عِ نَشَ فَاشُ، قٌ عِ شَ تِ نّ مَنفّ شُنفبٍ يَ عِ. عَلَ بَرَ تِن عِ بِيَاسِبٌورٍ بِرِن نَتَنفَدٍ.›
\v 25 نَ نَ عَ رَ، وٌ شَ لِمَنِيَ بَرِ مَ ﭑ لَشِ عَلَ شَ مَسٍنيِ رَ.
\v 26 وٌن قَمَ سُرِ ندٍ لِدٍ.»
\p 
\v 27 كْي قُ نُن نَانِ ندٍ، مُشُ نَشَ عَدِرِيَتِكٍ بَا لِ. نَ كْي تَفِ كُنكُي رَحّرّ نَشَ سٌفِ عَ مُشُ بَرَ مَكْرّ بْشِ ندٍ رَ.
\v 28 عٍ تٌ يٍ تِلِنيِ مَنِيَسٍ رَفٌرٌ، عٍ نَشَ كَنكٍ يَ مْشْحّن سْتْ. عٍ تٌ مَكُيَ دٌندٌرٌنتِ، عٍ مَن نَشَ عَ رَفٌرٌ، عٍ نَشَ كَنكٍ يَ قُ نُن سُولِ سْتْ.
\v 29 عٍ تٌ فَاشُ فَرِندٍ قَنيٍ ندٍ رَ، عٍ نَشَ هَنفَ نَانِ وٌلِ كُنكُي شَنبِ رَ. عٍ نَشَ فبَتَ كُيٍ عِبَقٍ رَ.
\v 30 كْنْ كُنكُي رَحّرّيٍ نُ وَ مَ كٍلِقٍ كُنكُي شُن. عٍ نَشَ كُنكُي لَنمَ رَفٌرٌ بَا مَ عَلْ عٍ نَ هَنفَيٍ نَن نَفٌرٌقٍ كُنكُي يَ رَ.
\v 31 ثْلُ نَشَ عَ قَلَ سْورِ مِشِ كّمّ شُنمَتِ نُن سْورِيٍ بّ، «شَ يِ مِشِيٍ مُ لُ كُنكُي كُي، وٌ مُ نْمَ كِسِدٍ.»
\v 32 عَوَ، سْورِيٍ نَشَ كُنكُي لَنمَ لُوتِ بٌلٌن، عٍ نَشَ عَ رَبّحِن عَ شَ سِفَ.
\p 
\v 33 بٍينُن كُيٍ شَ عِبَ، ثْلُ نَشَ عٍ بِرِن نَسِ عٍ شَ دٌنسٍ دٌن. عَ نَشَ عَ قَلَ عٍ بّ، «عَ شِ قُ نُن نَانِ نَن تٌ وٌ مَمّ تِقٍ، وٌ مُ تِنشِ وٌ دّفٍدٍ.
\v 34 ﭑ بَرَ وٌ رَ سِ وٌ شَ دٌنسٍ دٌن، بَرِ مَ نَ نَن قَن وٌ قَتٍ بّ. مِشِ يٌ مُ هَلَكِمَ، هَلِ وٌ شُنسّشّ كٍرٍن مُ لْيمَ.»
\v 35 عَ تٌ نَ قَلَ، عَ نَشَ تَامِ تٌنفٌ، عَ عَلَ نُوَلِ سَ عٍ بِرِن يَ شْرِ، عَ تَامِ عِفِرَ، عَ نَشَ عَ دٌن قْلْ.
\v 36 نَ تّمُي عٍ بِرِن نَشَ لِمَنِيَ، عٍ قَن نَشَ سٌ تَامِ دٌنقٍ.
\v 37 مُشُ مِشِ كّمّ قِرِن مِشِ تٌنفٌ سٌلٌقٍرٍ عَ نُن سٍننِ نَن نُ نَ كُنكُي كُي.
\v 38 عٍ تٌ وَ سَ دٌنسٍ رَ، عٍ نَشَ قَرِن وٌلِ بَا مَ عَلَكٌ كُنكُي شَ يٍلٍبُ.
\p 
\v 39 كُيٍ تٌ عِبَ، عٍ مُ عَ كٌلٌن عٍ نَ دّننَشّ، كْنْ عٍ نَشَ بْشِ ندٍ تٌ. عٍ نَشَ نَتّ تٌنفٌ عٍ شَ كَتَ كُنكُي رَ سِفَدٍ نَا.
\v 40 عٍ نَشَ هَنفَيٍ قُلُن، عٍ شَ سِن بَا مَ. عٍ نَشَ قّيَ لُوتِيٍ قَن بٌلٌن. عٍ نَشَ يَرٍ بّلَ رَتٍ، عٍ شَ عٍ شُن سَ شَرٍ مَ.
\v 41 كْنْ عٍ نَشَ بّنكِ لِ، كُنكُي نَشَ كَنكَن. كُنكُي شُنيِ تٌ كَنكَن، مْرْنيِ نَشَ عَ شْرّ كَنَ سّنبّ رَ.
\v 42 سْورِيٍ نَشَ لَن فٍيلِمَنِيٍ قَشَقٍ مَ، عَلَكٌ عٍ نَشَ يٍ مَسَ، عٍ عٍ فِ.
\v 43 كْنْ سْورِيٍ كّمّ شُنمَتِ، نَشَن نُ وَ مَ ثْلُ رَكِسِقٍ، عَ نَشَ عٍ رَتْن. عَ نَشَ يَامَرِ قِ عٍ مَ عَ نَشٍيٍ قَتَ يٍ مَسَدٍ، عٍ سِنفٍ شَ بَفَن يٍ مَ عَلَكٌ عٍ شَ شَرٍ مَسْتْ.
\v 44 بٌورٍيٍ شَ فبَكُ شٍبٍنيِيٍ رَ، شَ نَ مُ عَ رَ كُنكُي شُنتُنيِيٍ رَ. عٍ بِرِن نَشَ شَرٍ مَسْتْ هّيرِ كُي.
\c 28
\s1 ثْلُ مَلِتَ سُرِ لِقٍ
\p 
\v 1 مُشُ تٌ شَرٍ مَسْتْ، مُشُ نَشَ عَ كٌلٌن عَ نَ سُرِ شِلِ مَلِتَ.
\v 2 مَلِتَكَيٍ نَشَ سّيوَ مُشُ رَ كِ قَنيِ رَ. عٍ نَشَ مُشُ بِرِن مَلَن تّ شُنفبٍ قّ مَ، عٍ نُ نَشَن شُرُشِ، بَرِ مَ تُنّ نُ قَقٍ نُن شِنبٍلِ فبٍفبٍ رَ.
\v 3 ثْلُ تٌ بٌلٍيٍ مَتٌنفٌ سَقٍ تّ عِ، بْشِمَسٍ نَشَ مِنِ نَ تّ وُيٍنيِ شَ قٍ رَ، عَ نَشَ عَ بّلّشّ شِن.
\v 4 مَلِتَكَيٍ تٌ بْشِمَسٍ تٌ، عَ بَرَ عَ بّلّشّ شِن عَ سِنفَنشِ عَ رَ، عٍ نَشَ عَ قَلَ عٍ بٌرٍ بّ، «نْندِ رَ، نِبَ نَن يِ مِشِ رَ، بَرِ مَ هَاكّ مُ تِنشِ عَ شَ بَلٌ، هَلِ عَ تٌ تَنفَشِ بَا مَ.»
\v 5 ثْلُ نَشَ بْشِمَسٍ رَلِسَن تّ، سٍسٍ مُ عَ تٌ.
\v 6 نَ مِشِيٍ نُ مَمّ تِقٍ نّ عَ شِندٍ شَ قُنتُ، شَ نَ مُ عَ رَ عَ شَ قَشَ كٍرٍن نَ، كْنْ سٍسٍ مُ عَ تٌ. عٍ تٌ مَمّ تِ، عٍ نَشَ عٍ شَ مَحْشُنيِ مَسَرَ. عٍ نَشَ عَ قَلَ عَلَ ندٍ نَن عَ رَ.
\p 
\v 7 سُرِ كُنتِفِ شُنفبٍ، نَشَن شِلِ ثُبِلِيُ، نَشَ مُشُ يِفِيَ عَ قَنيِ رَ عَ شْنيِ شِ سَشَن بُن مَ.
\v 8 ثُبِلِيُ بَبَ نُ سَشِ، عَ قُرَشِ، مَنفَقَشّ نُ نَ عَ مَ. ثْلُ تٌ عَ مَكْرّ عَ رَ، عَ نَشَ عَ بّلّشّ سَ عَ مَ، عَ عَلَ مَشَندِ، عَ نَشَ عَ رَيَلَن.
\v 9 نَ شَنبِ، سُرِ قُرٍ مَ فبّتّيٍ نَشَ قَ، ثْلُ نَشَ عٍ قَن نَيَلَن.
\v 10 عٍ نَشَ مُشُ بِنيَ عَ قَنيِ رَ. مُشُ تٌ كٍلِ سِفَدٍ، عٍ نَشَ قَندّ قِ مُشُ مَ.
\s1 ثْلُ سِفَقٍ رْ مَ
\p 
\v 11 مُشُ تٌ كِكٍ سَشَن نَدَنفِ نَا، مُشُ نَشَ بَكِ كُنكُي كُي، نَشَن كٍلِ عَلٍسَندِرٍ. عَ نُ بَرَ حّمّ رَدَنفِ سُرِ مَ. تْنشُمَ نُ عَ مَ نَشَن قِندِشِ كُيٍ مَسٌلِشِ قِرِنيِ رَ.
\v 12 مُشُ تٌ سٌ كِلْن سِرَكُسِ، مُشُ نَشَ لُ نَا شِ سَشَن.
\v 13 مُشُ تٌ كٍلِ نَا، مُشُ نَشَ سِفَ رٍفِيٌ بَا دّ رَ. قٌيٍ تٌ كٍلِ يِرٍقَنيِ مَ نَ كُيٍ عِبَ، مُشُ نَشَ شِ قِرِن حّرّ رَبَ هَن ثُسٌلِ.
\v 14 مُشُ نَشَ نفَشَكٍرٍنيِيٍ لِ نَا نَشٍيٍ مُشُ مَيَندِ شِ سٌلٌقٍرٍ رَدَنفِقٍ رَ عٍ شْنيِ. نَ تّمُي مُشُ سِفَ نّ هَن رْ مَ.
\v 15 مُشُ نفَشَكٍرٍنيِ رْ مَكَيٍ، نَشٍيٍ مُشُ شَ قٍ مّ، عٍ نَشَ قَ مُشُ رَلَندٍ، كٍلِ رْ مَ هَن عَثِيُسِ مَلَن يِرٍ نُن تَا نَشَن شِلِ بَنشِ سَشَنيِيٍ. ثْلُ تٌ عٍ تٌ عَ نَشَ عَلَ نُوَلِ سَ، عَ نَشَ لِمَنِيَ.
\p 
\v 16 مُشُ تٌ سٌ رْ مَ، سْورِ مِشِ كّمّ شُنمَتِ نَشَ فٍيلِمَنِيٍ سٌ مَنفّ يِ رَ، كْنْ عَ نَشَ ثْلُ لُ عَ كٍرٍنيِ مَ، عَ نُن سْورِ كٍرٍن نَشَن عَ كَنتَمَ.
\v 17 شِ سَشَن تٌ دَنفِ، ثْلُ نَشَ يُوِقِ كُنتِفِيٍ شِلِ. عٍ تٌ مَلَن، عَ نَشَ يِ وْيّنيِ تِ عٍ بّ، «ﭑ نفَشَكٍرٍنيِيٍ، هَلِ ﭑ تٌ مُ قٍقٍ رَبَشِ وٌن مَ مِشِيٍ رَ، نُن وٌن بٍنبَيٍ شَ نَامُنيِيٍ رَ، يُوِقِيٍ بَرَ ﭑ سَ فٍيلِ كُي دَرِ سَلَمُ، نَ شَنبِ عٍ مَن قَ ﭑ سٌ رْ مَكَيٍ يِ رَ.
\v 18 عٍ تٌ فّ ﭑ مَشْرِندٍ، عٍ نُ وَ مَ ﭑ نَبٌلٌقٍ نّ، بَرِ مَ عٍ مُ سٍسٍ تٌشِ ﭑ قَشَمَ نَشَن مَ.
\v 19 كْنْ يُوِقِيٍ مُ تِن. نَ مَ، ﭑ نَشَ مَنفّ شُنفبٍ شَ كِيتِ مَشَندِ، كْنْ ﭑ مُ وَ ﭑ بْنسْي نَن كَلَمُقٍ.
\v 20 نَ نَ عَ رَ، ﭑ نَشَ وَ وٌ تٌقٍ عَلَكٌ ﭑ شَ وْيّن وٌ رَ، بَرِ مَ عِسِرَيِلَكَيٍ شَشِلِ تِشِ شّيرَ نَشَن نَ، نَ شَ قٍ نَن عَ تٌشِ عٍ يِ يْلْنشْنيِ سَشِ ﭑ مَ.»
\p 
\v 21 عٍ نَشَ عَ يَابِ، «مُشُ مُ بَتَاشّ يٌ سْتْشِ عِ شَ قٍ رَ كٍلِ يُدَيَ. وٌن نفَشَكٍرٍنيِ يٌ مُ قَشِ قٍ حَاشِ قَلَدٍ عِ شَ قٍ رَ.
\v 22 كْنْ، مُشُ وَ مَ عَ كٌلٌنقٍ نّ عِ نَشَن مَحْشُنشِ، بَرِ مَ مُشُ عَ كٌلٌن عٍ يِ دِينّ شَ قٍ عِبَشَنتِنمَ يِرٍ بِرِن.»
\p 
\v 23 ثْلُ نَشَ لْشْي كٍرٍن سٌ عٍ يِ. مِشِ وُيَشِ تٌ قَ عَ شْنيِ، ثْلُ نَشَ عَلَ شَ مَنفّيَ سٍيدٍحْشْيَ بَ. عَ نَشَ عِسَ شَ قٍ مَسٍن عٍ بّ تَوُرٍتَ مُنسَ نُن نَمِحْنمّيٍ شَ كِتَابُي سَابُي رَ كٍلِ فّيسّفّ هَن نُنمَرٍ.
\v 24 ندٍيٍ نَشَ لَ عَ رَ، كْنْ بٌورٍيٍ مُ دَنشَنِيَ.
\v 25 عٍ تٌ نُ قَتَنمَ لَنتَرٍيَ كُي، ثْلُ نَشَ يِ مَسٍنيِ سَ عَ قَرِ، «عَلَ شَشِلِ سّنِيّنشِ عَ قَلَ نّ وٌ بٍنبَيٍ بّ نْندِ كِ مَ عَننَبِ عٍسَيِ سَابُي رَ. عَ نَشّ،
\q1 
\v 26 ‹سِفَ يِ مِشِيٍ شْن مَ، عِ شَ عَ قَلَ عٍ بّ؛
\q1 “وٌ عَ مّمَ وٌ تُلِيٍ رَ، كْنْ وٌ مُ عَ قَهَامُمَ.
\q1 وٌ عَ تٌمَ وٌ يَيٍ رَ، كْنْ وٌ مُ عَ عِفبّمَ.”
\q1 
\v 27 بَرِ مَ يِ مِشِيٍ سٌندٌنيِ بَرَ شْرْشْ.
\q1 عٍ بَرَ عٍ تُلِيٍ دّ سّ.
\q1 عٍ بَرَ عٍ يَيٍ رَشِ،
\q1 عَلَكٌ عٍ نَشَ عَ تٌ عٍ يَيٍ رَ،
\q1 عٍ نَشَ عَ مّ عٍ تُلِيٍ رَ،
\q1 عٍ نَشَ عَ قَهَامُ عٍ شَشِلِ رَ.
\q1 شَ نَ مُ عَ رَ عٍ عٍ سٌندٌنيِ مَقِندِ مَ نّ،
\q1 عَلَكٌ عَلَ شَ عٍ رَيَلَن.›»
\b
\p 
\v 28 «عَوَ، وٌ شَ عَ كٌلٌن عَ عَلَ شَ كِسِ بَرَ رَ سَنبَ سِ فبّتّيٍ مَ. عٍ قَمَ عٍ تُلِ مَتِدٍ عَ رَ.»
\v 29 عَ تٌ نَ قَلَ، يُوِقِيٍ نَشَ سِفَ شْرْشْي كُي عٍ بٌورٍيٍ تَفِ.
\p 
\v 30 ثْلُ نَشَ لُ بَنشِ ندٍ كُي حّ قِرِن، عَ نُ عَ سَرٍ قِ. نَشٍيٍ بِرِن نُ قَمَ عَ تٌدٍ، عَ نُ عٍ بِرِن نَسّنّمَ.
\v 31 عَ نُ عَلَ شَ مَنفّيَ نِينِ شَ قٍ نَن كَوَندِ مَ عَ نُن مَرِفِ عِسَ شَ قٍ، عَلَ شَ مِشِ سُفَندِشِ. عَ نَشَ نَ بِرِن نَبَ لِمَنِيَ رَ، مِشِ يٌ مُ عَ تْورْ.
