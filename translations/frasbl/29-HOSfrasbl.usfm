\q1
\v 2 \w Prends|strong="H3068"\w* \w avec|strong="H3068"\w* \w toi|strong="H3068"\w* \w des|strong="H3068"\w* \w paroles|strong="H3068"\w*, \w et|strong="H3068"\w* \w reviens|strong="H7725"\w* \w au|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w*.  
\q2 Dis-lui : « Pardonne \w toute|strong="H7725"\w* \w iniquité|strong="H5771"\w*,  
