\id RUT - Mbembe Okohm [MFNOk]
\h Rut
\toc2 Rut
\toc1 Nnwẹr kwa Rut
\mt1 Nnwẹr kwa Rut
\ip Idik s'iyini sa bẹ akkẹri ma nnwẹr nwa, iyini k'ogbe kw'anọng p'Israẹl akk'adima k'irek sa Kenaan, kw'ode irek s'Ibinọkpaabyi ochekhi ọnang bẹ. M'ogbe nwa, asi-ẹjaakhi p'Ibinọkpaabyi p'ade Mosẹs ttara Jọshua, akk'apa; ogbe otzim opyiri, kw'Ibinọkpaabyi ọ́nang anọng p'Israẹl avaarnọng. M'ogbe nwuma, bẹ ayeri anọng p'adabhi Israẹl “asi-aponga.” Wa ode ogbe kwa ngọhr, ọmaana kw'ihem.
\c 1
\s1 Ẹlimẹlẹk ọmaana ẹhọhmmọr chẹ bẹ achin k'ẹkhọma cha Moab
\p 
\v 1 K'ogbe kw'iwa asi-aponga adabhi Israẹl, wa okwo f'ideden owobh m'irerek nna. Ojinọng wani kw'ofon Bẹtẹlẹhẹm k'ẹkhọma cha Juda, obina ttara kwanọng kwẹ, ọmaana va pẹ p'ijinọng afa, bẹ atza aruk k'irerek sa Moab.
\v 2 Ojinọng nwuma okpen Ẹlimẹlẹk, kwanọng kwẹ okpena Naomi, va pẹ p'ijinọng afa, akpena Malọn ọmaana Kiliyọn. Wa bẹ biphyir ade ammaana p'Ẹphrat p'arukhi k'obhon kwa Bẹtẹlẹhẹm k'ẹkhọma cha Juda. Wa bẹ achin k'irek sa Moab, atza aruk mẹ.
\p 
\v 3 Ẹlimẹlẹk, kw'ode odim kwa Naomi okwu ope ọjẹ-ẹ va p'ijinọng afa.
\v 4 Malọn ọmaana Kiliyọn akwu atzọkha aMoab-panọng p'akpen Ọpa ọmaana Rut, abẹ aruk mẹ, ọttọhk ka cho jobh,
\v 5 matzẹmaa Malọn ọmaana Kiliyọn abira ape, Naomi odim ọmaana va, dọk kọkhaam.
\s1 Naomi ọmaana Rut akpa nnam ka Bẹtẹlẹhẹm
\p 
\v 6 K'ogbe kwa Naomi ọbhaang ka Moab bi, Ọvaar Ibinọkpaabyi okk'anọng pẹ ọda ttara ọchattọhk. Naomi ttara panọng pa va pẹ, ado for bi abhana.
\v 7 Mando kwa Naomi obin orenga ttara panọng pa va pẹ afa, abẹ achina k'ẹkhọma cha Juda.
\p 
\v 8 Mẹ wọ, Naomi on-oben panọng pa va pẹ bi, “Ọnọng-ọnọng ọrọhng k'ọkka k'ọhọhm. Tte Ọvaar Ibinọkpaabyi osi ọphyaam ọnang bọng, macha bọng akk'asa ttara apfuranọng pabọng, ọmaana kaam.
\v 9 Tte Ọvaar Ibinọkpaabyi ọnang ọnọng-ọnọng ẹwọhng-kwokha k'ọhọhm kw'odim kwẹ ọbhakwẹ.”
\p Mando wọ kwa Naomi ọbaakha bẹ, abẹ abhom ẹmọng k'ẹrọng,
\v 10 aben-ẹ bi, “Mma e, maman ọ́tzọn-ọ abẹ otzor anọng pọ e.”
\p 
\v 11 Mẹ wọ, Naomi oben panọng pa va pẹ bi, “Va paam, bọng kpa nnam e. Okhuri yan kwa bọng achibhi bi bọng atzọn-m abẹ o? Bọng achibhi bi na kaam mbiri ifha ndima ibhọr, sa mbiri mmaan ajinọng p'abira akwu ade adim pabọng o?
\v 12 Va paam, bọng kpa nnam arọhng, okhuri bi, kaam nkk'ndama kpọng nyọhnga edimba. Kaambi ira nna mbiri mba odim k'erungiwu cha mayina, mmaan va p'ijinọng,
\v 13 na bọng atzik maa bẹ abar o? Na bọng akpa for sabọng edimba o? Mma e, va paam, kwẹ ọmma kaam ọyọhnga bọng e, okhuri bi, Ọvaar Ibinọkpaabyi okk'nnam ọkpa ọbọr-m.”
\p 
\v 14 Mẹ wọ, bẹ abira abhom amọng k'ẹrọng. Ọpa ọbaakha ọkka-maan-odim kwẹ, ọkpa nnam otzor anọng pẹ. Yina, Rut ochina ororo ọgbana bi, kẹ ọtzọn Naomi abẹ.
\v 15 Mẹ wọ, Naomi oben Rut bi, “Kker e, oyokh-ọbhọbha okk'anọng pẹ, ọmaana akha pẹ otzora, kọ tzọn-ẹ abẹ arọhng e.”
\p 
\v 16 Rut on-obhina Naomi bi, “Kaam dọk kàben bi ntte kọ ọbọhk, mkpa nnam. Ibe kpenamkpen s'achin, mẹ kwa kaam ńchina. Ibe kpenamkpen s'ayim, sẹ rọ sa kaam ńyima. Anọng pọ án-ade anọng paam, Ibinọkpaabyi kw'akpobh, kẹ wọ kwa kaam ḿkpobha.
\v 17 Ibe s'ape, mẹ kwa kaam ḿpe, mẹ kwa bẹ ábira ánọhng-m. Tte Ọvaar Ibinọkpaabyi ọnang-m ihem k'odem kpenamkpen kw'ọdaakh-ẹ, idikha oni obo kẹ-khẹ ode, ọ́bhaangi kaam ọmaana kọ.”
\v 18 Mada Naomi ore bi, Rut ọkk'for ọda bi ọtzọn-ẹ abẹ, Naomi ọn-ọttẹ-ẹ ọbọhk.
\p 
\v 19 Bẹ anọng afa arenga maa apyiri ka Bẹtẹlẹhẹm. Mada bẹ an-apyiri Bẹtẹlẹhẹm, obhon biphyir owuri ẹmọng. Panọng an-abọbh bi, “Manya Naomi wọ ma raa?”
\p 
\v 20 Naomi obhina bi, “Bọng kaam Naomi dọk kàyeri, bọng na yer-m Mara\f + \fr 1.20 \ft K'eHiburu, che cha \ft \bd Naomi\bd* eyini ọttọhk f'ojibh-ojibh, ọdaam ọnọng ettem. Che cha \bd Mara\bd* eyini ijojobhi.\f*, okhuri bi, Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir ọkk'aam ọmmamma ọnanga k'akpen paam.
\v 21 Wa mbin ma ttara ọhaabh, manya, Ọvaar Ibinọkpaabyi okk'aam otzima okhuna mbọhk-mbọhk. Ka yan kwa bọng abira ayer-m Naomi o? Ọvaar Ibinọkpaabyi okk'aam ọmmamma ọnanga e; Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir okk'nnam ọkpa ọbọr-m e.”
\p 
\v 22 Mẹ wọ, Naomi otzima Rut kw'ofon Moab, obiro ode kwanọng kwa nnwa kwẹ, ofona ka Moab akhuna ka Bẹtẹlẹhẹm, k'ittẹwọr s'ọphagbe kw'erezi-dem ch'ekpen, \it barli\it*. \fig Bẹ asi ipha|alt="Two people harvesting" src="lb00098c.tif" size="col" loc="1.22" ref="1.22"\fig*
\c 2
\s1 Rut okhebha Boaz
\p 
\v 1 Iwa Naomi ọkhaam ochimmanọng wani, kw'ode ofonanọng kw'Ẹlimẹlẹk. Ojinọng nwa okpen Boaz, kẹ wa ode ọkkọkkaa kw'ọtza che.
\p 
\v 2 Iwa Rut kw'ofon Moab, oben Naomi bi, “Tte nchina k'iwoni, ifha ndor anọng nnam ndungi abarli-mọma p'am-atto, ode na ńne ọnọng kw'osi ọphyaam ọnang-m o.”
\p Naomi obhin-ẹ bi, “Nnwa kwaam, china ororo, si mach'abeni.”
\v 3 Mẹ wọ, Rut ofona ochina k'owoni, ọttẹwọr om-odungi abarli-mọma otzor anọng p'asi ipha nnam. K'odem kw'idik im-ide, kẹ wa om-osi ọtzọhm k'owoni kwa Boaz, kw'ofon k'efonamma ch'Ẹlimẹlẹk. \fig Erezi-dem ch'ekpen, barli|alt="Heads of barley" src="lb00102c.tif" size="col" loc="2.3" ref="2.3"\fig*
\p 
\v 4 Ogbe kobhiri, Boaz ofona ka Bẹtẹlẹhẹm opyiri, orima atzọhmnọng p'asi ipha bi, “Tte Ọvaar Ibinọkpaabyi obiro odo bọng!”
\p Bẹ amọnga erima aben bi, “Tte Ọvaar Ibinọkpaabyi obiro odo kọ.”
\p 
\v 5 Boaz ọbọbh okker-atzọhmnọng pẹ bi, “Ominanwa kw'anyi wọ kana?”
\p 
\v 6 Okker-atzọhmnọng obhin-ẹ bi, “Kẹ ode ominanwa kw'ofon Moab kw'ọtzọni Naomi abẹ, ofona ka Moab okhuna.
\v 7 Kẹ ophyem-m bi, nttẹ-ẹ ọbọhk otzor atzọhmnọng mba nnam odungi abarli-mọma. Mada ira ottẹttẹwọr ọtzọhm k'ekpebha mapyiri ma, okwok ọwọhng ibebaa.” \fig |alt="Grain sheaves" src="hk00100c.tif" size="col" loc="2.7" ref="2.7"\fig*
\p 
\v 8 Mẹ wọ, Boaz oben Rut bi, “Nnwa kwaam, yong-m itzọhng. Kọ k'owoni ọdọdọk kàchina bi, atza asi ọtzọhm, owoni nwa ọbọhk kàbira atte. Kọ wobha ma ttara atzọhmnọng paam p'ipanọng.
\v 9 Kkeri owoni kw'atzọhmnọng am-asi ipha, atzor atzọhmnọng p'ipanọng nnam. Nkk'ajinọng mba itzọhng ndọra bi, bẹ aning-ọ agbọri. Idikha asi adaakh-ọ, rọhng atza agwo ka nsijọ s'ajinọng mba akk'asi akhaabha akhe.”
\p 
\v 10 Mẹ wọ, Rut ọrakha ottima itzitzikha k'irerek oben-ẹ bi, “Kaam nde okhekhennọng, oreng yan kw'asi ọphyaam-dema mva anang-m o?”
\p 
\v 11 Boaz obhin-ẹ bi, “Bẹ akk'aam ejibha kpenamkpen agbaakha, ch'akk'asa anang ọkka-maan-odim kwọ e. Ttẹwọr mada iwa odim kwọ ope-ope, abina aji atte ttara akka, ọmaana anọng pọ, ọmaana obhon kwọ, akwu aruk ttara anọng p'iwa anarong.
\v 12 Tte Ọvaar Ibinọkpaabyi ochor-ọ k'ọtzọhm f'akk'asa. Tte Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'anọng p'Israẹl, kw'akk'arọbha akwu ajena, ọdọ-ọ ejibh-ejibha.”
\p 
\v 13 Rut obhin-ẹ bi, “Itta kwaam, tte ọphyaam fọ ochina ororo obeng-m ekkema. Kọ akk'aam ottem-bara ananga, abira agbaakh-m attemdini-tzim, kaambi ode bi ebenga-mbọhk kinde ttara atzọhmnọng pọ p'ipanọng.”
\p 
\v 14 K'ogbe kw'ọchattọhk, Boaz oben Rut bi, “Kwu tzọkha brẹd abọhnga k'atzuk mba achi.”
\p Mada Rut okk'ẹwọr k'ottem kw'atzọhmnọng owobha, Boaz ọnang-ẹ abarli-bhaabha, ochi maa ọdọhbh, bẹ arik.
\v 15 Mada obin bi otza osi ọtzọhm, Boaz oben atzọhmnọng pẹ bi, “Kaambi odungi k'ottem kw'akhe, bọng kẹ kàkkaam.
\v 16 Bọng tza arọbha agwọk bani k'akhe anang-ẹ, bọng abira attẹ-ẹ ọbọhk odungi, bọng kẹ kàkkaam o.”
\p 
\v 17 Rut osi ọtzọhm m'owoni nwa maa ẹchọhkha etto. Ọkhaani abarli-mọma p'okk'odungi maa bẹ an-arikh-orik afu ẹgbangbang-dim.
\v 18 Otzini abarli-mọma mba otzima okhuna k'ẹttọhma. Rut ọkhọkha ọkka-maan-odim abarli-mọma haabha p'okk'odungi, obiro ọnang-ẹ ọchattọhk f'ira ochi orik.
\p 
\v 19 Ọkka-maan-odim ọbọbh-ẹ bi, “Kọ maan wọ kw'ira ayini mayina? Maan kw'ira asi ọtzọhm o? Tte ẹdaa ewobha ẹnang ọnọng nwuma kw'ọkhọ-ọ otzum.”
\p Mẹ wọ, Rut ọgbaak ọkka-maan-odim odik okhuri ọnọng kw'ira osi ọtzọhm k'ibe sẹ, oben bi “Ojinọng kwa nsi ọtzọhm ttara mayina, okpen Boaz.”
\p 
\v 20 Mẹ wọ e, Naomi oben kwanọng kwa nnwa kwẹ bi, “Tte Ọvaar Ibinọkpaabyi odo Boaz, kẹ kw'ochin ororo ọkhọkha ekpen-jibha chẹ ọnang anọng p'arukhi akpen, ọmaana p'akk'apa. Ojinọng nwa ode ochimmanọng kwaman, obiro ode ọkkaan-echimma kwaman.”
\p 
\v 21 Mẹ wọ, Rut kw'ofon Moab oben bi, “Ayongi mẹ, ojinọng nwuma oben-m bi, kaam ndungi ndor atzọhmnọng pẹ nnam maa ipha iha.”
\p 
\v 22 Naomi oben Rut kw'ode kwanọng kwa nnwa kwẹ bi, “Nnwa kwaam, ójibh-ojibh bi asi ọtzọhm ttara atzọhmnọng pẹ p'ipanọng, idikha achin k'owoni kw'ọnọng ọdọdọk bẹ ákkaam-ọ ọkkaam e.”
\p 
\v 23 Iwa Rut osi ọtzọhm ọbaanga atzọhmnọng pa Boaz p'ipanọng, maa ipha s'abarli ọmaana erezi-dem ch'ekpen wit, iha. Ogbe nwa biphyir, wa Rut orukhi ttara ọkka-maan-odim kwẹ.\fig Erezi-dem ch'ekpen, wit|alt="Heads of wheat" src="hk00099c.tif" size="col" loc="2.23" ref="2.23"\fig*
\c 3
\s1 Naomi osi nttọhna sa Rut ọba odim
\p 
\v 1 Iwa ewu dani Naomi, kw'ode ọkka-maan-odim kwa Rut, oben Rut bi, “Nnwa kwaam, ọbaan bi nnor odim nnang-ọ kw'ọfha okker-ọ e.
\v 2 Boaz nwa kw'am-asi ọtzọhm ttara atzọhmnọng pẹ p'ipanọng, ode ochimmanọng kwaman. Ronga bi, erungiwu cha mayina ọ́khaani abarli-mọma k'ibe sa bẹ am-awobha agwuma abarli-mọma.
\v 3 Rọhng atza agbobha asi, akpaan ana p'adaami eruk, affọra ẹnya chọ ọkkakka, yina achina k'ibe sa bẹ am-awobha agwuma abarli-mọma. Kàkhera bi ọrọ-ọ, matzẹmaa okyera ọchattọhk ochichi obiro ogwo atzuk.
\v 4 Kẹ otzum k'eden ọkkakka, are ibe sa kẹ oyima. Okk'oyima, rọhng atza agwong-ẹ ibara ayim-ẹ ma mmokpatzọkhi. Kẹ ọ́gbaakh-ọ ọgbaak odem kw'asi.”\fig Bẹ akhaani abarli-mọma|alt="Winnowing grain" src="hk00097c.tif" size="col" loc="3.4" ref="3.4"\fig*
\p 
\v 5 Rut obhin-ẹ bi, “Odik kpenamkpen kw'aben-m bi nsi, ńsi-osi mando.”
\p 
\v 6 Mando kw'ofon ochina k'ibe sa bẹ am-awobha agwuma abarli-mọma, osi odik kpenamkpen otzor k'odem kw'ọkka-maan-odim kwẹ oben-ẹ.
\p 
\v 7 K'ogbe kwa Boaz ọkk'ọttọhk ọcha biphyir, obiro ogwo atzuk, ettem ẹdaam-ẹ, otza oyima k'okhung kw'abarli-mọma mbuma ọttaabha. Rut ọbẹkhi \it bi bẹm\it* okwu ogwonga ibara s'ibubh mmokpatzọkhi sa Boaz, oyima.
\v 8 M'orungittem, Boaz ogbe k'ọda, on-okkon-ẹ da ore kwanọng kw'oyim-ẹ ka mmokpatzọkhi.
\p 
\v 9 Ọbọbh bi, “Kọ anyi wọ?”
\p Rut obhina bi, “Kaam Rut ọtzọhmnọng kwọ e. Mẹma ẹbaramma ch'ibara sọ, abubh-m, mada ode bi kọ wọ ade ọkkaan-echimma kwaman.”
\p 
\v 10 Boaz oben bi, “Nnwa kwaam, tte Ọvaar Ibinọkpaabyi ọdọ-ọ. Ejibha nda ẹyọhng ch'ira achi eden asi. Kọ adikkobh, p'ojibh-ojibh obiro ode p'ogbor-ogbor, kakhubhi.
\v 11 Mẹ wọ, nnwa kwaam, oning-ọ ojor. Kaam ńsi ọttọhk kpenamkpen osi f'abọbh-m nnang-ọ, okhuri bi, ayokh-obhon paam biphyir arong bi, kọ ade kwanọng kw'ojibhi ẹmmáanà.
\v 12 K'odik ọkkakka, kaam nde ọkkaan-echimma e, yina, ọnọng ọdọdọk owobh kẹ kw'ode ọkkaan-echimma ọyọhnga kaam e.
\v 13 Yima ma m'erungiwu nda, ewu ekk'ehobha, idikha okher bi obhek eho chọ, obiro ojibh. Oni for odo s'obhekh-ọ, odem nwa kw'Ọvaar Ibinọkpaabyi orukhi akpen, kaam ḿmekh-ọ obhek. Yima ma maa ewu ehobha.”
\p 
\v 14 Mẹ wọ, Rut oyima kẹ da ohokhi mmokpatzọkhi maa ewu ehobha, yina, obina yina ewu ẹn-ẹttaani ch'ọnọng otzini oyok. Boaz oben-ẹ bi, “Tte ọnọng manda wani oningi orong bi, kwanọng okwu oyima m'ibe sa bẹ am-agwuma abarli-mọma o.”
\p 
\v 15 Obiro oben-ẹ bi, “Tzima ibara nnuma s'abubh mẹ kwu, mẹma sẹ.” Mada okk'mando ọsa, Boaz okpokhi abarli-mọma p'afu okhiriba ọzadani owon-ẹ m'ibara, otzini ọyẹ-ẹ. Ọkpa nnam ọbhana k'obhon.
\p 
\v 16 Mada Rut opyiri k'ọhọhm, ọkka-maan-odim ọbọbh bi, “Nnwa kwaam, ira kwẹ ode yan kẹ?”
\p Mẹ wọ, Rut ọgbaakh-ẹ odik kpenamkpen kwa Boaz ọkk'ọsa ọnang-ẹ,
\v 17 obiro ọgbaakh-ẹ bi, “Ọnang-m okhiriba mva ọzadani f'abarli-mọma, oben-m bi, nningi nnam mkpa ndor ọkka-maan-odim kwaam ttara abọhk-kpakpa.”
\p 
\v 18 Mẹ wọ e, Naomi oben bi, “Nnwa kwaam, wobha atzik maa are odem kwa kwẹ ode, okhuri bi, ojinọng nwa ọwọhng kókwokha, maa odik nwa ọkhaama okkoni mayina.”
\c 4
\s1 Ọbada kwa Boaz ọmaana Rut
\p 
\v 1 Mẹ wọ, Boaz obina ochina k'ipha otza owobha ẹwọr kẹ. Mada ọkkaan-echimma kw'obeni ọkk'ọkwa, Boaz oben bi, “Ayi kwaam, kwuna kanya, akwu awobha ẹwọr.” Mẹ wọ, ọkkaan-echimma otza owobha ẹwọr.
\p 
\v 2 Boaz oyeri adeden-nọng p'obhon anọng jobh, oben bi, “Bọng wobha ẹwọr manya.” Bẹ awobha ẹwọr.
\v 3 Mẹ wọ, Boaz oben ọkkaan-echimma bi, “Naomi kw'ofon ka Moab okhuna obeni bi, on-okpe irerek s'ọgbaanotte kwaman, Ẹlimẹlẹk.
\v 4 Kẹ kwa nchibhi bi nsi aronga, ifha adebh sẹ k'itzitzikha s'anọng p'awobh ma, ọmaana k'itzitzikha s'adeden-nọng p'anọng paam. Idikha ọdaakh-ọ bi abhek sẹ, kọ bhek, ọn-ọdaakhi, gbaakh-m, ifha nnonga. Ọnọng ọdọdọk kw'ọkhaam ẹfa bi, obhek sẹ kw'oyongi kọ kode, kaam wọ ndor-ọ nnam.”
\p Ọkkaan-echimma obhina bi, “Kaam ḿmek sẹ obhek.”
\p 
\v 5 Mẹ wọ e, Boaz oben bi, “Ewu ch'adebh irerek nnuma ka mbọhk sa Naomi, kọ abira abhek Rut kw'ode oMoab kwanọng kw'ode opopa kw'opfunọng, ifha ode mẹ, motzera che ch'ọnọng kwaman kw'ọkk'ọpa, ifha ẹkhakhaama chẹ eningi edimi.”
\p 
\v 6 Mẹ wọ, ọkkaan-echimma oben bi, “Ode mando, kaam sẹ kimfha ḿmek na nkwu nge ẹkhakhaama chaam ka dama-dama. Kaam sẹ kiḿmek e.”
\p 
\v 7 K'ogbe nwuma, wa ode ẹmmáanà ch'anọng p'Israẹl bi, yina aninga abhek ọttọhk, ọnọng wani ọkhaambi ọwọra ọkpaikkobho kwẹ ọnang oyok. Mando kw'iwa anọng p'Israẹl am-arenga abhek ekpo k'ayok.
\p 
\v 8 Mẹ wọ, ọkkaan-echimma oben Boaz bi, “Kọ bhek sẹ ka for sọ.” Ọwọra ọkpaikkobho ọnang Boaz.
\p 
\v 9 Mẹ wọ, Boaz ọgbaak adeden-nọng p'obhon bi, “Mayina, bọbọng ade awobha-re paam bi, kaam nkk'ẹkhakhaama ch'Ẹlimẹlẹk biphyir, ọmaana cha Kiliyọn ttara cha Malọn, mmekha ka mbọhk sa Naomi e.
\v 10 Kaam nkk'Rut mmekha, kw'ofon Moab obiro ode opopa kwa Malọn, mbiri ndọkh-ẹ macha kwanọng kwaam, ifha ode mẹ motzera che ch'ọnọng kwaman kw'ọkk'ọpa, ttara ẹkhakhaama chẹ, ifha che chẹ eningi edimi k'ottem kw'echimma chẹ, ọmaana k'obhon kwẹ.” Mayina bọbọng ade awobha-re.
\p 
\v 11 Mẹ wọ, adeden-nọng mbuma, ttara anọng mbongo p'awobh m'ipha, aben-ẹ bi, “Iya, maman mode awobha-re. Tte Ọvaar Ibinọkpaabyi osi kwanọng nwa kw'ódim m'ọhọhm kwọ, ode macha Rachẹl ọmaana Lea p'abhun mbọhk asi efonamma ch'Israẹl ẹbar. Tte kọ akhaama ẹkhakhaama k'Ẹphrat, abira atza che ka Bẹtẹlẹhẹm.
\v 12 Tte Ọvaar Ibinọkpaabyi orenga ma va pa kwanọng nwa ọ́mmaan, osi efonamma chọ ẹbar ekher cha Pẹrẹz kw'iwa Tamar ọmaani ọnang Juda.”
\s1 Rut ọmaana Boaz atzọk ayok
\p 
\v 13 Mẹ wọ, Boaz ọtzọkha Rut ode kwanọng kwẹ. Wa bẹ atzọn ayima, Ọvaar Ibinọkpaabyi ọsẹ-ẹ otzima ibhọr, ọmaan ojinọng.
\v 14 Mẹ wọ, panọng aben Naomi bi, “Tte mọnang Ọvaar Ibinọkpaabyi ẹtzọhnga mayina, kw'ọkk'ọ ọkkaan-echimma ọnanga. Tte nnwa nwa ọtza che k'obhon kw'Israẹl makhọra.
\v 15 Kẹ wọ óbhona akpen pọ, óbiro ókker-ọ k'atzam. Ọnyẹ kwa kọ adaakhi idik, kw'ojibhi ọyọhnga va p'ijinọng azenamfa, kẹ wọ ọmmaan-ẹ.”
\p 
\v 16 Mẹ wọ, Naomi ọtzọkha nnwa nwa oji ka ndaak ọrọk.
\v 17 Panọng p'arukhi mẹ aben bi, “Naomi okk'ojinọng ọkhaama e.” Abẹ akpẹ-ẹ Ọbẹd. Wa Ọbẹd okwu ode otte kwa Jẹsẹ. Jẹsẹ ode otte kwa Devid.
\s1 Abatte pa Devid
\p 
\v 18 Mẹ wọ, ẹnọmma cha Pẹrẹz ede bi:
\li1 iwa Pẹrẹz obhoni Hẹzrọn
\li1 
\v 19 Hẹzrọn obhon Ram,
\li1 Ram obhon Aminadab,
\li1 
\v 20 Aminadab obhon Nashọn,
\li1 Nashọn obhon Salmọn,
\li1 
\v 21 Salmọn obhon Boaz,
\li1 Boaz obhon Ọbẹd,
\li1 
\v 22 Ọbẹd obhon Jẹsẹ,
\li1 yina Jẹsẹ on-ode otte kwa Devid.
