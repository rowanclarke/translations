\v 6 \w So|strong="H6440"\w* \w they|strong="H3117"\w* \w all|strong="H6908"\w* met \w together|strong="H6908"\w* \w at|strong="H3478"\w* \w Mizpah|strong="H4709"\w*. \w They|strong="H3117"\w* got \w some|strong="H8033"\w* \w water|strong="H4325"\w* \w from|strong="H6440"\w* \w a|strong="H3068"\w* \w spring|strong="H4325"\w* \w and|strong="H1121"\w* \w poured|strong="H8210"\w* \w it|strong="H1931"\w* \w on|strong="H3117"\w* \w the|strong="H6440"\w* \w ground|strong="H6440"\w*. \w That|strong="H3117"\w* \w was|strong="H3068"\w* \w their|strong="H3068"\w* \w way|strong="H6440"\w* \w to|strong="H3478"\w* tell \w God|strong="H3068"\w* \w that|strong="H3117"\w* \w they|strong="H3117"\w* felt shamed. \w They|strong="H3117"\w* \w were|strong="H3478"\w* sorry \w that|strong="H3117"\w* \w they|strong="H3117"\w* showed \w respect|strong="H6440"\w* \w to|strong="H3478"\w* \w those|strong="H1121"\w* statues. \w On|strong="H3117"\w* \w that|strong="H3117"\w* \w day|strong="H3117"\w* \w they|strong="H3117"\w* didn’t eat \w any|strong="H6440"\w* food \w as|strong="H3117"\w* \w they|strong="H3117"\w* prayed \w to|strong="H3478"\w* \w him|strong="H6440"\w*. \w They|strong="H3117"\w* prayed \w like|strong="H3478"\w* \w this|strong="H1931"\w*, “\w Our|strong="H3068"\w* \w God|strong="H3068"\w*, \w we|strong="H3068"\w* \w did|strong="H3478"\w* \w wrong|strong="H2398"\w* \w things|strong="H3478"\w*. \w We|strong="H3117"\w* didn’t \w follow|strong="H3068"\w* \w your|strong="H3068"\w* \w way|strong="H6440"\w*.” \w That|strong="H3117"\w*’s \w the|strong="H6440"\w* \w way|strong="H6440"\w* \w Samuel|strong="H8050"\w* \w led|strong="H8199"\w* \w the|strong="H6440"\w* \w people|strong="H1121"\w* \w to|strong="H3478"\w* \w go|strong="H3068"\w* \w the|strong="H6440"\w* \w right|strong="H3478"\w* \w way|strong="H6440"\w*.
\p 
\v 7 \w After|strong="H3588"\w* \w the|strong="H6440"\w* bosses \w from|strong="H6440"\w* Philistia \w heard|strong="H8085"\w* \w that|strong="H3588"\w* \w the|strong="H6440"\w* \w Israel|strong="H3478"\w* mob \w came|strong="H5927"\w* \w together|strong="H6908"\w* \w at|strong="H3478"\w* \w Mizpah|strong="H4709"\w*, \w they|strong="H3588"\w* \w took|strong="H5927"\w* \w their|strong="H8085"\w* \w soldiers|strong="H1121"\w* \w to|strong="H3478"\w* \w that|strong="H3588"\w* place. \w The|strong="H6440"\w* \w Israel|strong="H3478"\w* mob \w heard|strong="H8085"\w* \w they|strong="H3588"\w* \w were|strong="H3478"\w* \w coming|strong="H5927"\w*, \w and|strong="H1121"\w* \w they|strong="H3588"\w* \w got|strong="H5927"\w* \w frightened|strong="H3372"\w*.
\v 8 \w So|strong="H4480"\w* \w they|strong="H3068"\w* \w said|strong="H2790"\w* \w to|strong="H3478"\w* \w Samuel|strong="H8050"\w*, “\w Pray|strong="H2199"\w* \w to|strong="H3478"\w* \w God|strong="H3068"\w* \w for|strong="H3027"\w* \w us|strong="H3027"\w*. \w Keep|strong="H2790"\w* \w on|strong="H3027"\w* praying, don’t stop. Ask \w him|strong="H3027"\w* \w to|strong="H3478"\w* \w save|strong="H3467"\w* \w us|strong="H3027"\w* \w from|strong="H4480"\w* \w the|strong="H3068"\w* Philistia mob.”
\v 9 \w Then|strong="H6030"\w* \w Samuel|strong="H8050"\w* \w got|strong="H3947"\w* \w a|strong="H3068"\w* young \w sheep|strong="H5927"\w*, \w and|strong="H3478"\w* \w he|strong="H3068"\w* \w burned|strong="H3632"\w* \w all|strong="H3632"\w* \w of|strong="H3068"\w* \w it|strong="H5927"\w* \w to|strong="H3478"\w* \w give|strong="H6030"\w* \w it|strong="H5927"\w* \w to|strong="H3478"\w* \w God|strong="H3068"\w*. \w He|strong="H3068"\w* kept \w on|strong="H3068"\w* praying \w for|strong="H1157"\w* \w the|strong="H3947"\w* \w Israel|strong="H3478"\w* mob, \w and|strong="H3478"\w* \w God|strong="H3068"\w* \w took|strong="H3947"\w* notice \w of|strong="H3068"\w* \w him|strong="H3947"\w*.
\p 
\v 10 \w God|strong="H3068"\w* \w heard|strong="H6963"\w* \w Samuel|strong="H8050"\w*’s prayer. \w While|strong="H1961"\w* \w he|strong="H1931"\w* burned \w the|strong="H6440"\w* \w young|strong="H3117"\w* \w sheep|strong="H5927"\w*, \w the|strong="H6440"\w* Philistia mob \w came|strong="H1961"\w* \w close|strong="H5066"\w*, ready \w to|strong="H3478"\w* \w attack|strong="H5927"\w* \w the|strong="H6440"\w* \w Israel|strong="H3478"\w* mob. \w But|strong="H1961"\w* suddenly \w God|strong="H3068"\w* \w made|strong="H1961"\w* \w a|strong="H3068"\w* really \w loud|strong="H1419"\w* \w noise|strong="H6963"\w*, \w and|strong="H3478"\w* \w it|strong="H1931"\w* \w sounded|strong="H6963"\w* \w like|strong="H1961"\w* \w thunder|strong="H6963"\w*. \w The|strong="H6440"\w* Philistia mob \w got|strong="H5927"\w* really frightened \w and|strong="H3478"\w* \w confused|strong="H2000"\w*, \w so|strong="H1961"\w* \w the|strong="H6440"\w* \w Israel|strong="H3478"\w* mob easily beat \w them|strong="H5921"\w*.
\v 11 \w They|strong="H5704"\w* \w chased|strong="H7291"\w* \w them|strong="H5221"\w* \w from|strong="H4480"\w* \w Mizpah|strong="H4709"\w* almost \w as|strong="H5704"\w* \w far|strong="H5704"\w* \w as|strong="H5704"\w* \w a|strong="H3068"\w* \w place|strong="H8478"\w* called \w Beth-Car|strong="H1033"\w*, \w and|strong="H3478"\w* \w they|strong="H5704"\w* \w killed|strong="H5221"\w* lots \w of|strong="H4480"\w* people dead \w along|strong="H5704"\w* \w the|strong="H5221"\w* \w way|strong="H5704"\w*.
\v 12-13 The Philistia mob ran away and went home. Then Samuel got \w a|strong="H3068"\w* big stone, and stood it up half-way between 2 places, Mizpah and Shen, so that everybody will remember the things that happened. And he said, “God was helping us.” So he called the stone \em Ebenezer\em*. That name means \em stone that belongs to the one that helps us\em*. The Philistia mob sat quiet for \w a|strong="H3068"\w* long time. They didn’t come back to the Israel mob’s country.
\p So God saved them from the Philistia mob for \w a|strong="H3068"\w* long time, until Samuel became an old man.
\b
\iex (We have not yet translated 7:14-17.)
\c 8
\s1 The Israel mob asked for a big boss
\p 
\v 1-2 Samuel had 2 sons. His older son was called Joel, his younger son was called Abijah. After Samuel became an old man, he picked them to be bosses for the Israel mob. They were court judges, working at the place called Beersheba.
\v 3 \w But|strong="H3808"\w* \w they|strong="H3808"\w* \w were|strong="H1121"\w* \w not|strong="H3808"\w* \w like|strong="H1870"\w* \w their|strong="H3947"\w* \w father|strong="H1121"\w*. \w They|strong="H3808"\w* \w were|strong="H1121"\w* greedy. \w They|strong="H3808"\w* thought only \w about|strong="H1980"\w* money. Bad \w men|strong="H1121"\w* \w used|strong="H3947"\w* \w to|strong="H1980"\w* \w give|strong="H5186"\w* \w them|strong="H3947"\w* money \w in|strong="H1980"\w* \w a|strong="H3068"\w* quiet \w way|strong="H1870"\w*, \w and|strong="H1121"\w* \w then|strong="H1980"\w* \w they|strong="H3808"\w* \w used|strong="H3947"\w* \w to|strong="H1980"\w* \w let|strong="H3808"\w* \w those|strong="H1121"\w* bad \w men|strong="H1121"\w* \w go|strong="H1980"\w* free.
\p 
\v 4 So \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w elders|strong="H2205"\w* \w of|strong="H2205"\w* \w Israel|strong="H3478"\w* met \w together|strong="H6908"\w* \w at|strong="H3478"\w* \w the|strong="H3605"\w* town called \w Ramah|strong="H7414"\w*, \w to|strong="H3478"\w* talk \w to|strong="H3478"\w* \w Samuel|strong="H8050"\w*.
\v 5 \w They|strong="H3808"\w* said, “\w You|strong="H3605"\w* \w are|strong="H1121"\w* \w an|strong="H7760"\w* \w old|strong="H1121"\w* \w man|strong="H1121"\w* \w now|strong="H6258"\w*. \w Your|strong="H3605"\w* \w sons|strong="H1121"\w* don’t \w live|strong="H1980"\w* straight \w like|strong="H1870"\w* \w you|strong="H3605"\w*, \w so|strong="H1980"\w* \w they|strong="H3808"\w* shouldn’t \w be|strong="H3808"\w* \w judges|strong="H8199"\w* \w for|strong="H1121"\w* \w us|strong="H7760"\w*. \w You|strong="H3605"\w* \w have|strong="H1121"\w* \w to|strong="H1980"\w* pick \w one|strong="H3605"\w* \w man|strong="H1121"\w* \w to|strong="H1980"\w* \w be|strong="H3808"\w* \w the|strong="H3605"\w* big boss \w for|strong="H1121"\w* \w us|strong="H7760"\w*. \w In|strong="H1980"\w* \w other|strong="H3605"\w* countries \w they|strong="H3808"\w* \w have|strong="H1121"\w* \w one|strong="H3605"\w* big boss. \w We|strong="H6258"\w* \w want|strong="H3808"\w* \w to|strong="H1980"\w* \w be|strong="H3808"\w* \w the|strong="H3605"\w* same \w as|strong="H1121"\w* \w them|strong="H7760"\w*.”\x * \xo 8:5 \xt Deuteronomy 17:14\x*
\p 
\v 6 \w Samuel|strong="H8050"\w* wasn’t happy \w about|strong="H1697"\w* \w that|strong="H3068"\w*, \w so|strong="H5414"\w* \w he|strong="H3068"\w* \w prayed|strong="H6419"\w* \w to|strong="H3068"\w* \w God|strong="H3068"\w*.
