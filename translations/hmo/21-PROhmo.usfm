\id PRO PROVERBS, Hiri Motu Bible, PNG, 6/92 
\h AONEGA HEREVADIA 
\toc1 AONEGA HEREVADIA 
\toc2 AONEGA HEREVADIA 
\mt1 AONEGA HEREVADIA  
\c 1  
\s1 Aonega hereva edia namo  
\p
\v 1 Solomona be Davida ena natuna, bona ia be Israela ena king. Iena aonega herevadia be inai:   
\q1
\v 2 Inai aonega herevadia ese umui do idia durua,  
\q1 vadaeni aonega bona sisiba namona do umui diba,  
\q1 bona laloa dobu hereva edia anina do umui diba.   
\q1
\v 3 Inai hereva ese umui idia hadibaia diba,  
\q1 vadaeni umui be mai emui aonega danu do umui noho.  
\q1 Vadaeni do umui laloa maoromaoro,  
\q1 bona do umui koikoi lasi,  
\q1 ma taunimanima ibounai dekenai,  
\q1 mai maka tamona danu,  
\q1 kara namodia do umui karaia.   
\q1
\v 4 Aonega herevadia ese,  
\q1 diba maragi taudia dekenai aonega idia henia diba,  
\q1 bona eregabe taudia dekenai,  
\q1 diba bona laloa goada idia henia diba.   
\q1
\v 5 Inai aonega herevadia danu ese,  
\q1 aonega taudia idia durua diba,  
\q1 bona sikuli bada taudia edia diba idia habadaia diba.   
\q1
\v 6 Inai hereva ese ita do idia durua,  
\q1 aonega herevadia edia anina,  
\q1 hunia gaudia do ita diba.  
\q1 Ma inai diba ese parabole,  
\q1 bona aonega taudia edia laloa auka gaudia edia anina,  
\q1 ita dekenai do ia hedinaraia.   
\s1 Sisiba eregabe taudia dekenai  
\q1
\v 7 Bema oi ura aonega abia neganai,  
\q1 Dirava dekenai do oi gari henia guna.  
\q1 Kavakava taudia ese,  
\q1 aonega bona hadibaia hereva idia ura henia lasi.   
\q1
\v 8 Lauegu natuna e,  
\q1 oiemu tamana bona sinana,  
\q1 edia hadibaia hereva do oi kamonai henia.   
\q1
\v 9 Idia edia hadibaia hereva ese,  
\q1 oiemu kara do idia hanamoa,  
\q1 oiemu kwarana ena herahera,  
\q1 bona ageva ese oiemu toana idia hanamoa bamona.   
\b  
\q1
\v 10 Egu natuna e, kara dika taudia ese,  
\q1 oiemu lalona idia koia gwauraia neganai,  
\q1 edia ura do oi abia dae lasi.   
\q1
\v 11 Bema idia gwau, “Oi mai, ita lao,  
\q1 tau ta do ita alaia,  
\q1 bona kerere lasi taudia do ita tuari henia.  
\q1 Inai bamona do ita karaia kava, gadara bamona.   
\q1
\v 12 Do ita davaridia neganai idia be mai mauri danu,  
\q1 to do ita hadikadia neganai,  
\q1 idia be mase taudia.   
\q1
\v 13 Vadaeni idia edia kohu namodia ibounai do ita abia,  
\q1 bona ita dadia gaudia dekena amo,  
\q1 iseda ruma do ita hahonua.   
\q1
\v 14 Oi mai, ai danu do ita haboua,  
\q1 vadaeni ita henaoa gaudia do ita haria hegeregere.”   
\q1
\v 15 Egu natuna e, unai bamona taudia,  
\q1 idia danu do oi lao lasi.  
\q1 Idia dekena amo do oi raka siri.   
\q1
\v 16 Idia be kara dika karaia totona idia haraga momo.  
\q1 Idia be nega ibounai,  
\q1 taunimanima alaia totona idia hegaegae noho.   
\q1
\v 17 Bema oi abia gwauraia manuna ese,  
\q1 oi ia itaia noho neganai,  
\q1 tarapu do oi atoa be anina lasi.   
\q1
\v 18 To unai bamona taudia ese,  
\q1 sibodia edia tarapu idia karaia noho,  
\q1 bona unai tarapu lalonai do idia mase.   
\q1
\v 19 Dagedage dekena amo kohu idia dadia taudia ibounai,  
\q1 edia dokona be unai bamona.  
\q1 Unai kara ese edia mauri ia hadikaia ore.   
\s1 Aonega do umui negea lasi  
\q1
\v 20 Kamonai! Aonega be ia boiboi noho,  
\q1 hanua ena huanai bona hoihoi gabudia dekenai,   
\q1
\v 21 hanua ena magu iduara dekenai,  
\q1 bona taunimanima idia haboua gabudia ibounai dekenai. Ia gwau:   
\b  
\q1
\v 22 “Kavakava taudia e,  
\q1 do umui kavakava noho ela bona edena negai?  
\q1 Umui ese diba bona laloa kehoa,  
\q1 be do umui ura henia lasi ela bona edena negai?   
\q1
\v 23 Lauegu sisiba hereva do umui kamonai henia,  
\q1 badina sisiba namona umui dekenai do lau gwauraia,  
\q1 bona egu diba namona umui dekenai do lau henia.   
\q1
\v 24 Lau be lau boiboi,  
\q1 to umui ura lasi kamonai.  
\q1 Lau ura lau dekenai umui mai,  
\q1 to umui ura lasi.   
\q1
\v 25 Lauegu hagoadaia hereva ibounai,  
\q1 be umui ese umui negea.  
\q1 Lauegu sisiba hereva ta be umui abia dae lasi.   
\q1
\v 26 Bema kerere umui davaria neganai,  
\q1 do lau kirikiri umui dekenai.  
\q1 Gari ese umui dekenai ia ginidae neganai,  
\q1 do lau hevaseha umui dekenai.   
\q1
\v 27 Gari bona kerere ese umui do ia hadikaia,  
\q1 lai dikana bamona.  
\q1 Bona hisihisi bona laloa metau,  
\q1 koehirihiri bamona umui dekenai do ia mai.   
\b  
\q1
\v 28 “Unai neganai umui ese aonega totona,  
\q1 lau dekenai do umui boiboi,  
\q1 to lau be do lau haere lasi.  
\q1 Kahana kahana ibounai dekenai lau do umui tahua,  
\q1 to lau do umui davaria lasi.   
\q1
\v 29 Badina be umui ese aonega umui ura henia lasi,  
\q1 bona Lohiabada gari henia kara danu umui ura lasi.   
\q1
\v 30 Egu hagoadaia hereva ta umui abia dae lasi,  
\q1 bona egu sisiba hereva ibounai umui negea vadaeni.   
\q1
\v 31 Unai dainai emui kamonai lasi hegeregerena,  
\q1 davana do umui davaria,  
\q1 bona emui kara dika ese emui gorere do idia havaraia.   
\q1
\v 32 Laloa kehoa lasi taudia,  
\q1 be aonega idia negea dainai idia mase noho,  
\q1 bona kavakava taudia ese,  
\q1 aonega idia tahua lasi dainai dika idia davaria noho.   
\q1
\v 33 To lau dekenai do ia kamonai tauna,  
\q1 be do ia noho mai mauri danu.  
\q1 Ia be do ia noho namonamo, gari ta lasi.”   
\c 2  
\s1 Aonega ena davana namona  
\q1
\v 1 Egu natuna e, lau, aonega,  
\q1 egu hadibaia hereva do oi tahua,  
\q1 bona egu oda do oi laloaboio lasi.   
\q1
\v 2 Aonega herevadia do oi kamonai,  
\q1 bona oiemu kudouna ese laloa kehoa do ia ura henia.   
\q1
\v 3 Bema oi ese aonega totona oi noinoi,  
\q1 bona bema laloa kehoa totona oi boiboi goada,   
\q1
\v 4 bema oi tahua, siliva do oi tahua bamona,  
\q1 bema oi tahua goada, kohu momo,  
\q1 idia hunia gaudia, do oi tahua bamona,   
\q1
\v 5 unai neganai Lohiabada gari henia kara do oi diba,  
\q1 bona Dirava do oi diba.   
\q1
\v 6 Badina be Lohiabada ese aonega,  
\q1 be oi dekenai ia henia noho,  
\q1 bona iena uduna dekena amo,  
\q1 diba bona laloa kehoa idia mai noho.   
\q1
\v 7 Dirava ese kara maoromaoro mai laloa momokani taudia,  
\q1 ia durua bona ia gimaia noho.   
\q1
\v 8 Dirava ese, mai maoromaoro danu taunimanima idia durua taudia,  
\q1 be ia gimaia noho,  
\q1 bona iena helaga momokani taudia edia dala,  
\q1 be ia naria namonamo noho.   
\b  
\q1
\v 9 Bema oi ese lau, aonega, dekenai oi kamonai henia neganai,  
\q1 oi be kara maoromaoro, kota maorona,  
\q1 bona davana korikori henia dalana do oi diba.  
\q1 Dala namodia ibounai karaia dalana danu do oi diba.   
\q1
\v 10 Oi ese aonega do oi davaria,  
\q1 bona inai diba ese oiemu laumana do ia hamoalea.   
\q1
\v 11 Oiemu laloa kehoa bona oiemu diba maoro ese,  
\q1 oiemu mauri do idia naria namonamo,   
\q1
\v 12 vadaeni kara dikadia dekena amo,  
\q1 oi do idia hamauria,  
\q1 ma edia hereva dekena amo kerere idia havaraia taudia,  
\q1 dekena amo danu oi do idia hamauria.   
\q1
\v 13 Inai dika taudia ese,  
\q1 kara maoromaoro daladia idia rakatania,  
\q1 bona dibura daladia lalonai idia raka noho.   
\q1
\v 14 Idia be kara dika karadia dekenai idia moale noho,  
\q1 bona kara dika ena dala gagevagageva,  
\q1 be idia ura henia bada noho.   
\q1
\v 15 Edia kara ibounai be gagevagageva bona kerere.   
\b  
\q1
\v 16 Aonega ese danu,  
\q1 heudahanai hahine dekena amo oi do ia hamauria,  
\q1 bona ariara hahine ena koikoi hereva dekena amo danu.   
\q1
\v 17 Unai hahine ese iena adavana ia rakatania,  
\q1 bona Dirava ena vairana dekenai,  
\q1 ia gwauraia gwauhamata ia laloaboio.   
\q1
\v 18 Bema iena ruma dekenai oi lao neganai,  
\q1 oi be mase dalana dekenai oi raka noho.  
\q1 Unai dala be mase taudia edia gabu,  
\q1 dekenai ia lao noho.   
\q1
\v 19 Unai hahine dekenai idia lao taudia,  
\q1 be ta ese do ia giroa mai lasi mauri dalana dekenai.   
\b  
\q1
\v 20 Unai dainai taunimanima namodia,  
\q1 edia dala dekenai do oi raka,  
\q1 bona kara maoromaoro taudia edia dala do oi badinaia.   
\q1
\v 21 Badina be kara maoromaoro taudia,  
\q1 be inai tano dekenai do idia mauri noho,  
\q1 bona laloa maoromaoro taudia be,  
\q1 inai tano lalonai do idia noho momokani.   
\q1
\v 22 To kara dika taudia be tano dekena amo,  
\q1 Dirava ese do ia abidia siri,  
\q1 bona kara koikoi taudia be,  
\q1 tano dekena amo do ia kokidia momokani.   
\c 3  
\s1 Uhau taudia dekenai sisiba hereva  
\q1
\v 1 Egu natuna e, egu hadibaia hereva,  
\q1 be do oi laloaboio lasi.  
\q1 Egu oda hereva,  
\q1 be oiemu kudouna lalonai do oi dogoatao noho.   
\q1
\v 2 Egu hadibaia hereva ese,  
\q1 oiemu mauri dinadia do idia halataia,  
\q1 bona noho namona momokani,  
\q1 oi dekenai do idia henia.   
\b  
\q1
\v 3 Bogahisihisi karadia bona abidadama kara danu,  
\q1 be do oi rakatania lasi.  
\q1 Oiemu aiona dekenai do oi kwatua,  
\q1 ma idia ruaosi be oiemu kudouna ena latanai do oi torea.   
\q1
\v 4 Bema inai bamona oi karaia neganai,  
\q1 Dirava bona taunimanima ese oi dekenai do idia moale.   
\b  
\q1
\v 5 Lohiabada do oi abidadama henia,  
\q1 mai emu kudouna ibounai.  
\q1 Oi sibona oiemu diba do oi abidadama henia lasi.   
\q1
\v 6 Oi karaia gaudia ibounai lalonai,  
\q1 Lohiabada do oi laloa,  
\q1 vadaeni ia ese dala maorona,  
\q1 be oi dekenai do ia hadibaia.   
\b  
\q1
\v 7 Oi sibona do oi laloa lasi oi be mai emu aonega,  
\q1 to Lohiabada dekenai do oi gari henia,  
\q1 bona kara dika dekena amo do oi raka siri.   
\q1
\v 8 Unai bamona oi karaia neganai,  
\q1 inai be muramura bamona,  
\q1 oiemu bero do ia hanamoa,  
\q1 bona oiemu hisihisi do ia kokia.   
\b  
\q1
\v 9 Oiemu uma ena anina namodia,  
\q1 be Lohiabada dekenai do oi henia,  
\q1 oiemu matauraia karana Lohiabada dekenai be unai.   
\q1
\v 10 Bema unai bamona oi karaia neganai,  
\q1 oiemu aniani haboua gabuna be do ia honu,  
\q1 bona uaina be momo herea dainai,  
\q1 haboua gabuna dekenai atoa be ia hegeregere lasi.   
\q1
\v 11 Egu natuna e,  
\q1 Lohiabada ena matakani oi dekenai,  
\q1 be do oi abia dae,  
\q1 bona iena sisiba dekenai do oi hesiku lasi.   
\q1
\v 12 Badina be Lohiabada ese ia lalokau henia taudia,  
\q1 be ia matakani henidia noho,  
\q1 tamana ta ese iena natuna,  
\q1 ia lalokau henia merona,  
\q1 ia matakani henia bamona.   
\b  
\q1
\v 13 Aonega ia davaria tauna be mai moale danu.  
\q1 Ia ese lalona kehoa ia davaria vadaeni.   
\q1
\v 14 Badina be aonega ena namo ese,  
\q1 siliva ena namo ia hereaia,  
\q1 bona aonega ena davana ese,  
\q1 golo ena davana ia hereaia.   
\q1
\v 15 Aonega ena davana ese,  
\q1 davana bada herahera nadi edia davana ia hereaia,  
\q1 bona oi ura henia gaudia ibounai edia huanai,  
\q1 ta ese aonega ia hereaia diba lasi.   
\q1
\v 16 Mauri daudau be aonega dekena amo do oi abia.  
\q1 Kohu momo bona mataurai danu,  
\q1 be aonega dekena amo do oi davaria.   
\q1
\v 17 Aonega ese oiemu mauri do ia hanamoa,  
\q1 bona aonega dainai,  
\q1 oiemu mauri be mai maino danu do oi noho.   
\q1
\v 18 Aonega idia davaria taudia be idia moale,  
\q1 bona aonega ese mauri namona,  
\q1 idia dekenai do ia henia.   
\b  
\q1
\v 19 Lohiabada ese aonega dekena amo tanobada ia karaia.  
\q1 Iena diba dekena amo,  
\q1 guba be ena gabu dekenai ia atoa.   
\q1
\v 20 Dirava ena aonega dainai,  
\q1 sinavai be idia heau lao,  
\q1 bona ori ese medu be tano ena latanai idia hadihoa.   
\b  
\q1
\v 21 Egu natuna e, aonega namona,  
\q1 bona laloa kehoa do oi dogoatao noho.  
\q1 Idia do oi naria namonamo,  
\q1 idia ese oi do idia rakatania garina.   
\q1
\v 22 Idia ese oiemu lauma do idia hamauria,  
\q1 bona noho namo,  
\q1 mai moale danu oi dekenai do idia henia.   
\q1
\v 23 Unai neganai oiemu dala,  
\q1 be do oi raka lao mai maino danu,  
\q1 bona oiemu aena do idia hekwakwanai lasi.   
\q1
\v 24 Geda dekenai oi hekure neganai do oi gari lasi,  
\q1 bona hanuaboi lalonai do oi mahuta namonamo.   
\q1
\v 25 Mase haraga dekenai do oi gari lasi.  
\q1 Kara dika taudia ese,  
\q1 dika bada do idia havaraia neganai,  
\q1 unai danu be do oi gari henia lasi,   
\q1
\v 26 badina be oi ese Lohiabada dekenai oi abidadama henia,  
\q1 unai neganai ia ese oi do ia hamauria.  
\q1 Ia ese tarapu ena dika dekena amo,  
\q1 oiemu aena do ia naria.   
\q1
\v 27 Bema dika ese taunimanima namodia ia hadikaia,  
\q1 bona bema oi be mai oiemu dala do oi durudia neganai,  
\q1 oiemu durua do oi koua lasi.   
\q1
\v 28 Bema oiemu badibadina dekenai ia noho tauna,  
\q1 be hari dina oi durua diba neganai,  
\q1 do oi hamaoroa lasi,  
\q1 “Do oi naria ela bona kerukeru.”   
\q1
\v 29 Oiemu badibadina dekenai ia noho tauna,  
\q1 hadikaia dalana do oi tahua lasi.  
\q1 Ia be oi kahirakahira ia noho,  
\q1 bona ia ese oi dekenai ia abidadama henia noho.   
\q1
\v 30 Tau ta do oi heai henia kava lasi,  
\q1 bema ia ese oi ia hadikaia lasi neganai.   
\b  
\q1
\v 31 Dagedage taudia do oi mama henia lasi.  
\q1 Edia mauri daladia ta danu do oi ura henia lasi,   
\q1
\v 32 badina be Lohiabada ese kara gagevagageva taudia,  
\q1 ia ura henia lasi momokani,  
\q1 to kara maoromaoro taudia be ia ese ia abidadama henia noho.   
\b  
\q1
\v 33 Lohiabada ese kara dika taudia edia ruma,  
\q1 be ia hadikadia noho,  
\q1 to ia ese kara maoromaoro taudia edia ruma ibounai,  
\q1 be ia hanamoa noho.   
\q1
\v 34 Lohiabada ese hekokoroku taudia ia ura henia lasi,  
\q1 to ia ese manau taudia dekenai ia laloa namo.   
\q1
\v 35 Aonega taudia edia davana be matauraia namona,  
\q1 to kavakava taudia ese hemarai do idia davaria.   
\c 4  
\s1 Aonega be gau badana momokani  
\q1
\v 1 Egu natuna tau ibounai e,  
\q1 lau, emui tamana, egu hadibaia hereva do umui kamonai.  
\q1 Egu hereva edia anina do umui tahua,  
\q1 bona laloa kehoa do umui davaria.   
\q1
\v 2 Badina be lau ese hadibaia hereva namodia,  
\q1 be umui dekenai lau henia noho.  
\q1 Egu hadibaia hereva do umui rakatania lasi.   
\q1
\v 3 Lau be mero neganai, lau danu be mai egu tamana.  
\q1 Lau be egu sinana ena natuna tamona,  
\q1 bona ia ese lau ia lalokau henia bada.   
\q1
\v 4 Unai neganai egu tamana ese lau ia hadibaia, ia gwau,  
\q1 “Egu hereva be oiemu kudouna dekenai do oi dogoatao goada.  
\q1 Egu oda hereva do oi badinaia,  
\q1 bona oi be do oi mauri.   
\q1
\v 5 Aonega bona laloa kehoa do oi abia.  
\q1 Egu hereva do oi laloaboio lasi,  
\q1 bona idia dekena amo do oi raka siri lasi.   
\q1
\v 6 Aonega do oi rakatania lasi,  
\q1 bona ia ese oi do ia naria.  
\q1 Aonega do oi ura henia,  
\q1 bona ia ese oi do ia gimaia.   
\q1
\v 7 Gau badana momokani be aonega.  
\q1 Sedira do oi abia totona oiemu kohu,  
\q1 oiemu moni bona gau ibounai do oi negea haorea,  
\q1 to laloa kehoa do oi tahua bona abia.   
\q1
\v 8 Aonega do oi ura henia,  
\q1 bona ia ese oi do ia hanamoa bada.  
\q1 Aonega do oi dogoatao auka,  
\q1 bona ia ese oiemu ladana do ia habadaia.   
\q1
\v 9 Ia ese oi dekenai hairai,  
\q1 bona matauraia do ia henia.”   
\b  
\q1
\v 10 Egu natuna e, kamonai, lau aonega,  
\q1 egu hereva do oi abia dae,  
\q1 bona oiemu mauri lagani do idia momo.   
\q1
\v 11 Aonega ena dala oi dekenai lau hadibaia vadaeni,  
\q1 bona noho mauri ena dala maorona dekenai,  
\q1 oi lau hakaua vadaeni.   
\q1
\v 12 Bema mai aonega danu oi raka neganai,  
\q1 gau ta ese oiemu dala do ia koua lasi,  
\q1 bona do oi heau neganai do oi hekwakwanai lasi.   
\q1
\v 13 Egu hadibaia hereva do oi dogoatao,  
\q1 do oi rakatania lasi.  
\q1 Inai diba do oi gimaia,  
\q1 badina ia be oiemu mauri ena badina.   
\q1
\v 14 Kara dika taudia edia dala dekenai,  
\q1 do oi raka vareai lasi.  
\q1 Kerere taudia edia kara do oi karaia lasi.   
\q1
\v 15 Unai edia dala dekena amo do oi siri,  
\q1 ia dekenai do oi raka lasi.  
\q1 Unai dala do oi rakatania momokani,  
\q1 bona oiemu dala dekenai do oi lao.   
\q1
\v 16 Badina unai dika taudia idia mahuta diba lasi,  
\q1 ela bona kerere ta idia karaia vadaeni.  
\q1 Mahuta idia davaria lasi,  
\q1 ela bona tau ta idia hadikaia vadaeni.   
\q1
\v 17 Kara dika bona dagedage,  
\q1 be edia aniani bona edia ranu bamona.   
\q1
\v 18 To kara maoromaoro taudia idia raka noho dalana,  
\q1 be daba rere bamona.  
\q1 Edia dala ena diari be ia bada lao noho,  
\q1 ela bona dina tubua momokani ia hedinarai.   
\q1
\v 19 Kara dika taudia edia dala,  
\q1 be dibura masemase bamona.  
\q1 Idia be idia moru noho,  
\q1 to idia hekwakwanai gauna idia itaia diba lasi.   
\q1
\v 20 Egu natuna e, egu hereva,  
\q1 be do oi kamonai henia namonamo.   
\q1
\v 21 Oi naridia noho,  
\q1 oi dekena amo do idia boio garina.  
\q1 Oiemu kudouna lalonai,  
\q1 egu hereva do oi dogoatao noho,   
\q1
\v 22 badina idia davaridia taudia dekenai,  
\q1 inai aonega herevadia be mauri,  
\q1 bona idia ese tau ta ena tauanina,  
\q1 be idia hanamoa noho.   
\q1
\v 23 To gau badana momokani, oiemu kudouna,  
\q1 oiemu laloa ia havaraia gauna, do oi naria namonamo,  
\q1 badina be oiemu laloa dekena amo,  
\q1 oiemu mauri be ia heau noho.   
\q1
\v 24 Hereva gagevagageva be,  
\q1 oi dekena amo do oi atoa siri.  
\q1 Hereva koikoi be nega ta do oi gwauraia lasi.   
\q1
\v 25 Oiemu matana dekena amo.  
\q1 vairana kahana do oi itaia noho.  
\q1 Mai laloa maoromaoro danu gau do oi itaia noho.   
\q1
\v 26 Do oi karaia gaudia,  
\q1 be do oi laloa namonamo guna,  
\q1 unai neganai emu kara ibounai be do idia maoro.   
\q1
\v 27 Dala maoromaorona dekenai do oi raka,  
\q1 idiba kahana o lauri kahana dekenai do oi raka lasi.  
\q1 Oiemu aena be kara dika dekena amo,  
\q1 do idia raka siri.   
\c 5  
\s1 Heudahanai do oi karaia lasi  
\q1
\v 1 Egu natuna tau e,  
\q1 egu aonega bona laloa kehoa dekenai,  
\q1 do oi kamonai bona laloa namonamo.   
\q1
\v 2 Unai neganai kara maorodia do oi karaia,  
\q1 bona oiemu hereva ese,  
\q1 oiemu diba namona do idia hedinaraia.   
\q1
\v 3 Sedira tau ma ta ena adavana ena bibina,  
\q1 be gaiho momokani, hani bamona,  
\q1 bona iena hereva ena digarana ese,  
\q1 dehoro ena digarana idia hereaia,   
\q1
\v 4 to gabeai, unai hahine ena mamina oi dekenai,  
\q1 be dika, mamina dika muramura bamona,  
\q1 mai matana momokani,  
\q1 isena ruaosi idia segea tuari kaia bamona.   
\q1
\v 5 Unai hahine ese mase taudia edia gabu dekenai,  
\q1 oi do ia hakaua lao.  
\q1 Mase dekenai ia lao dalana dekenai ia raka noho.   
\q1
\v 6 Mauri dalana be unai hahine ese ia laloa lasi,  
\q1 to ia raka kava, raka kava noho,  
\q1 bona iena dala ia diba lasi.   
\b  
\q1
\v 7 Egu natuna tau e,  
\q1 lau dekenai do oi kamonai.  
\q1 Egu hereva gaudia do oi rakatania lasi.   
\q1
\v 8 Unai bamona hahine dekena amo do oi raka siri.  
\q1 Iena ruma ena iduara kahirakahira do oi lao lasi,   
\q1
\v 9 oi ese oiemu goada,  
\q1 be idau taudia dekenai do oi henia garina,  
\q1 bona oiemu mauri lagani,  
\q1 be bogahisihisi lasi taudia ese do idia hakwadogia garina.   
\q1
\v 10 Io, idau taudia ese oiemu kohu dainai do idia goada,  
\q1 bona oiemu hekwarahi ena anina ese,  
\q1 idau tauna ena ruma do ia hanamoa garina,   
\q1
\v 11 ela bona oiemu mauri ena dokona dekenai do oi taitai,  
\q1 oiemu hidiona bona oiemu tauanina,  
\q1 be do idia ore lao neganai.   
\q1
\v 12 Unai neganai do oi gwau,  
\q1 “Badina dahaka matakani lau negea,  
\q1 bona edena bamona sisiba hereva lau ura henia lasi?   
\q1
\v 13 Lau ese egu hadibaia taudia edia hereva lau kamonai lasi,  
\q1 bona lau dekenai sisiba ia henia tauna,  
\q1 ena hereva lau abia dae lasi.   
\q1
\v 14 Unai dainai harihari taunimanima ibounai edia vairana dekenai,  
\q1 dika bona hemarai lau davaria inai.”   
\b  
\q1
\v 15 Oiemu adavana korikori dekenai do oi kara momokani,  
\q1 bona ia sibona do oi ura henia.   
\q1
\v 16 Bema idau hahine dekena amo natudia do oi havaraia,  
\q1 unai natudia ese oiemu noho do idia hanamoa lasi.   
\q1
\v 17 Oiemu natuna ese oi sibona do idia durua be namo,  
\q1 idau taudia lasi.   
\q1
\v 18 Unai dainai oiemu adavana korikori danu do umui moale,  
\q1 bona oiemu eregabe dinadia neganai,  
\q1 oi adavaia hahine do oi moalelaia.   
\q1
\v 19 Ia be dia hahine,  
\q1 bona dia ena natuna namo herea bamona oi dekenai.  
\q1 Do oi ura henia momokani,  
\q1 vadaeni iena ratana ese oi do idia hamoalea nega ibounai.  
\q1 Iena lalokau dekenai do oi moale bada noho hanaihanai.   
\q1
\v 20 Egu natuna e,  
\q1 anina be dahaka idau hahine dekenai do oi ura henia?  
\q1 Badina be dahaka tau ma ta ena adavana do oi rosia?   
\b  
\q1
\v 21 Badina be tau ta ta edia kara be Lohiabada ese ia itaia noho.  
\q1 Lohiabada ese taunimanima ta ta ibounai,  
\q1 edia dala ibounai ia tahua noho.   
\q1
\v 22 Kara dika tauna ena kara dika be tarapu,  
\q1 bona unai tarapu, sibona ia karaia kara dikadia,  
\q1 ese unai tau do idia abia, do idia hadikaia.   
\q1
\v 23 Matakani ena sisiba momokani ia kamonai henia lasi,  
\q1 unai dainai unai tau ia mase noho.  
\q1 Iena kavakava bada herea dainai,  
\q1 unai tau ia boio vadaeni.   
\c 6  
\s1 Kavakava kara garina sisiba hereva  
\q1
\v 1 Egu natuna tau e, oi ese oi gwauhamata vadaeni,  
\q1 tau ta ena abiatorehai davana do oi karaia, a?   
\q1
\v 2 Oi ese oi hereva kava dainai,  
\q1 gwauhamata ta oi gwauraia, bona inai gwauhamata be oi dekenai tarapu ta,  
\q1 oiemu uduna ena hereva ese,  
\q1 hekwakwanai gauna oi dekenai ia havaraia, a?   
\q1
\v 3 Inai bamona oi karaia neganai,  
\q1 oi be unai tau ena siahu henunai.  
\q1 To inai tarapu dekena amo,  
\q1 do oi heau mauri dalana be inai:  
\q1 Unai tau dekenai do oi lao haraga,  
\q1 bona do oi noia, oiemu gwauhamata dekena amo oi do ia ruhaia.   
\q1
\v 4 Do oi mahuta lasi,  
\q1 bona do oi hekure diho lasi.   
\q1
\v 5 Unai tarapu dekena amo do oi roho mauri,  
\q1 manu ta o dia ta ese labana tauna,  
\q1 dekena amo ia roho mauri bamona.   
\s1 Lahedo taudia dekenai sisiba hereva  
\q1
\v 6 Lahedo taudia ese,  
\q1 dimairi edia kara bamona do idia karaia be namo.   
\q1
\v 7 Dimairi be mai edia king lasi,  
\q1 mai edia lohia ta lasi,  
\q1 bona mai edia biaguna lasi.   
\q1
\v 8 To medu lasi neganai edia aniani idia haboua,  
\q1 bona medu ena nega totona idia hegaegae noho.   
\q1
\v 9 Lahedo tauna e,  
\q1 oi hekure kava ela bona edena negai?  
\q1 Edena negai mahuta dekena amo do oi noga?   
\q1
\v 10 Oi gwau, “Lau be laga-ani totona,  
\q1 nega sisina sibona do lau hekure.  
\q1 Lauegu imana do lau lokua, do lau laga-ani sisina.”   
\q1
\v 11 To oi mahuta neganai,  
\q1 ogogami ese oi dekenai do ia ginidae,  
\q1 dadidadi tauna bamona.   
\s1 Kerere idia havaraia taudia  
\q1
\v 12 Kara kava taudia, kara dika taudia,  
\q1 be idia raka lao,  
\q1 hereva koikoi idia gwauraia loaloa noho.   
\q1
\v 13 Edia matana dekena amo toa idia karaia noho.  
\q1 Edia aena bona edia imadia kwakikwakidia,  
\q1 dekena amo danu toa idia karaia noho.   
\q1
\v 14 Edia laloa koikoi dekena amo,  
\q1 kara dika karaia daladia danu idia tahua noho,  
\q1 bona kerere, mai heai danu idia havaraia noho.   
\q1
\v 15 Unai dainai dika bada ese,  
\q1 idia dekenai do ia vara haraga,  
\q1 bona do ia hadikadia ore,  
\q1 ta do ia mauri lasi.   
\s1 Lohiabada ia ura lasi gaudia  
\q1
\v 16 Lohiabada ia ura lasi gaudia 7 be inai:   
\q1
\v 17 Hekokoroku ena toana.  
\q1 Uduna mai ena koikoi.  
\q1 Kerere lasi taudia alaia karana.   
\q1
\v 18 Kara dika karaia totona laloa idia karaia taudia.  
\q1 Kara dika karaia totona idia haraga momo taudia.   
\q1
\v 19 Uitnesi koikoi tauna.  
\q1 Iena turana edia huanai, kerere ia havaraia tauna.   
\s1 Heudahanai do oi karaia lasi  
\q1
\v 20 Egu natuna tau e,  
\q1 oiemu tamana ena oda hereva do oi kamonai henia,  
\q1 bona oiemu sinana ena hadibaia hereva,  
\q1 be do oi rakatania lasi.   
\q1
\v 21 Nega ibounai edia hereva do oi dogoatao noho.  
\q1 Oiemu kudouna dekenai do oi kwatudia.   
\q1
\v 22 Oi raka loaloa neganai,  
\q1 inai edia hereva ese oi do idia hakaua.  
\q1 Do oi hekure neganai,  
\q1 edia sisiba ese oi do idia naria.  
\q1 Oi noga neganai,  
\q1 idia ese oi dekenai do idia hereva henia.   
\q1
\v 23 Badina edia oda be lamepa bamona,  
\q1 bona edia hadibaia hereva be diari,  
\q1 bona edia matakani be mauri dalana.   
\q1
\v 24 Io, oiemu tamana bona sinana edia sisiba herevadia ese,  
\q1 hahine dikana dekena amo oi do idia hamauria,  
\q1 bona ariara hahine edia hereva koikoi dekena amo danu.   
\q1
\v 25 Unai bamona hahine edia hairai do oi ura henia lasi,  
\q1 bona do oi naria namonamo,  
\q1 edia matadia dekena amo oi do idia koia garina.   
\q1
\v 26 Badina be ariara hahine dainai,  
\q1 tau ta be ogogami tauna do ia lao,  
\q1 bona heudahanai hahine dainai,  
\q1 tau ta ese iena mauri do ia haboioa.   
\q1
\v 27 Tau ta ese lahi ena gida,  
\q1 be iena kemena dekenai do ia abia loaloa, a?  
\q1 Iena dabua do idia gabua lasi, a?   
\q1
\v 28 Tau ta ese lahi ena gida,  
\q1 edia latanai do ia raka, a?  
\q1 Iena aena do idia gabua lasi, a?   
\q1
\v 29 Tau ma ta ena adavana ia sihari henia tauna,  
\q1 danu be unai bamona.  
\q1 Ia ese unai hahine ia abia dainai,  
\q1 iena kerere davana do ia davaria momokani.   
\b  
\q1
\v 30 Hitolo dainai tau ta ese aniani ia henaoa neganai,  
\q1 taunimanima ese unai tau idia gwauraia dika momokani lasi.   
\q1
\v 31 To bema idia davaria neganai,  
\q1 unai henaoa tauna ese ia henaoa gauna,  
\q1 ena davana nega 7 do ia henia lou.  
\q1 Iena ruma ena kohu ibounai do ia henia haorea.   
\q1
\v 32 Ia heudahanai noho tauna be mai ena aonega lasi.  
\q1 Ia ese sibona ena mauri ia hadikaia ore noho.   
\q1
\v 33 Bero bona hemarai do ia davaria,  
\q1 bona iena hemarai be do ia noho hanaihanai,  
\q1 doko lasi.   
\q1
\v 34 Badina be mama ese,  
\q1 tau ta ena lalona ia habadua momokani,  
\q1 bona ia ese davana do ia henia neganai,  
\q1 ia be do ia bogahisihisi henia diba lasi.   
\q1
\v 35 Moni davana do ia abia dae lasi,  
\q1 bona harihari gaudia momo dekena amo,  
\q1 iena badu do oi hakerua diba lasi.   
\c 7  
\s1 Heudahanai idia karaia hahine dekenai sisiba  
\q1
\v 1 Egu natuna e,  
\q1 lauegu hereva do oi badinaia,  
\q1 bona dahaka do oi karaia totona lau hamaoroa gaudia,  
\q1 be do oi laloaboio lasi.   
\q1
\v 2 Lauegu hereva do oi badinaia,  
\q1 vadaeni mauri do oi davaria.  
\q1 Lauegu hadibaia hereva do oi naria,  
\q1 oiemu matana oi naria noho bamona.   
\q1
\v 3 Egu sisiba do oi dogoatao noho nega ibounai,  
\q1 oiemu kudouna dekenai do oi torea.   
\q1
\v 4 Aonega do oi hamaoroa, oi gwau,  
\q1 “Oi be lauegu taihuna.”  
\q1 Bona lalona kehoa be oiemu turana do oi halaoa.   
\q1
\v 5 Aonega ese lebulebu hahine,  
\q1 dekena amo oi do ia abia siri,  
\q1 bona ariara hahine ena hereva mamina namo,  
\q1 dekena amo danu.   
\b  
\q1
\v 6 Dina ta lauegu ruma ena uindo dekena amo,  
\q1 lauegu matana lau negea,   
\q1
\v 7 bona aonega lasi taudia edia huanai,  
\q1 eregabe tauna ta lau itaia,  
\q1 ia be mai ena laloa kavakava.   
\q1
\v 8 Unai tau be hahine ta ia noho rumana kahirakahira,  
\q1 ia raka noho, ariara ena kona dekenai.   
\q1
\v 9 Unai be dina ia diho ena murinai, dibura neganai.   
\b  
\q1
\v 10 Unai neganai hahine ta danu ia hedavari.  
\q1 Hahine ena dabua ia kwatua ena toana,  
\q1 be lebulebu hahine bamona,  
\q1 bona iena kudouna lalonai be mai ena laloa dika.   
\q1
\v 11 Ia be hereva momo, bona hemarai lasi hahine,  
\q1 bona ariara dekenai ia loaloa momo,   
\q1
\v 12 nega haida ariara dekenai,  
\q1 nega haida dala ena kona dekenai,  
\q1 nega haida be hoihoi gabuna dekenai.   
\q1
\v 13 Ia ese unai eregabe tauna ia rosia,  
\q1 ia kisi henia,  
\q1 ia hereva henia, mai kiri danu, ia gwau,   
\b  
\q1
\v 14 “Lauegu boubou gaudia be hari dina lau karaia vadaeni,  
\q1 bona boubou ena vamu haida,  
\q1 be lau dekenai ia noho.   
\q1
\v 15 Unai dainai lau mai murimuri dekenai,  
\q1 oi do lau davaria totona.  
\q1 Mai moale danu oi lau tahua,  
\q1 bona harihari oi lau davaria vadaeni.   
\q1
\v 16 Lauegu mahuta patana be,  
\q1 Aigupito ena dabua namona dekena amo lau koua vadaeni.   
\q1
\v 17 Lauegu mahuta patana dekenai,  
\q1 bonana namo muramura dekena amo lau hanamoa vadaeni,  
\q1 muro, bona aloe, bona kinamono.   
\q1
\v 18 Oi mai, hari hanuaboi do ita sihari ia lao bona dabai.  
\q1 Ita ta ta dekenai do ita ura henia,  
\q1 mai iseda moale danu.   
\q1
\v 19 Badina be lauegu tau,  
\q1 be ruma dekenai ia noho lasi.  
\q1 Ia be gabu daudau dekenai ia lao.   
\q1
\v 20 Ia ese moni momo ia danu ia abia,  
\q1 bona pura rua bamona do ia giroa mai lasi.”   
\b  
\q1
\v 21 Hedibagani hereva momo dekena amo,  
\q1 unai tau ena lalona ia veria,  
\q1 bona iena hereva be mai mamina namo dainai,  
\q1 unai tau ese ia abia dae.   
\q1
\v 22 Vadaeni unai eregabe tauna,  
\q1 be karaharaga hahine ena murinai ia lao,  
\q1 hegeregere boromakau be do idia alaia gabuna,  
\q1 dekenai ia lao bamona,  
\q1 o dia ese tarapu dekenai ia moru bamona.   
\q1
\v 23 Unai tarapu lalonai diba ese,  
\q1 unai tau ena bogana do ia gwadaia.  
\q1 Ia be manu bamona,  
\q1 reke ena lalona dekenai ia roho vareai bamona.  
\q1 Ia diba lasi iena mauri be ia dika vadaeni.   
\b  
\q1
\v 24 Egu natuna tau e,  
\q1 lau dekenai do umui kamonai.  
\q1 Lauegu hereva do umui badinaia.   
\q1
\v 25 Unai bamona hahine ena dala dekenai,  
\q1 do umui raka lao lasi.  
\q1 Umui emui kudoudia be ia dekenai do umui henia lasi.   
\q1
\v 26 Badina be ia ese tatau momo,  
\q1 be inai kara dekena amo ia hadikadia ore vadaeni.  
\q1 Oibe, ia ese ia aladia taudia be momo herea,  
\q1 duahia diba lasi.   
\q1
\v 27 Bema iena ruma dekenai umui lao neganai,  
\q1 umui be mase gabuna dekenai umui lao noho.  
\q1 Ia be mase haraga dalana.   
\c 8  
\s1 Aonega be gau namo herea  
\q1
\v 1 Kamonai! Aonega be ia boiboi noho.  
\q1 Diba namona ese iena gadona ia habadaia noho.   
\q1
\v 2 Dala kahirakahira ororo gabudia edia ataiai dekenai,  
\q1 bona dala idia hakapua gabudia dekenai,  
\q1 aonega be ia gini noho.   
\q1
\v 3 Hanua ena magu iduara dekenai,  
\q1 bona ruma edia iduara dekenai aonega ia boiboi noho, ia gwau:   
\q1
\v 4 “Taunimanima e, lau inai, aonega,  
\q1 umui dekenai lau noinoi noho.  
\q1 Tanobada dekenai idia noho taudia ibounai e,  
\q1 umui dekenai lau boiboi noho.   
\q1
\v 5 Umui be aonega lasi, a?  
\q1 Aonega do umui tahua.  
\q1 Umui be kavakava, a?  
\q1 Diba namona do umui tahua.   
\q1
\v 6 Lauegu hereva namodia do umui kamonai.  
\q1 Lauegu hereva ibounai be maoromaoro.   
\q1
\v 7 Lau gwauraia noho hereva be momokani.  
\q1 Hereva koikoi be lau ura lasi momokani.   
\q1
\v 8 Lauegu hereva ibounai be momokani.  
\q1 Egu hereva ta ia koikoi lasi,  
\q1 bona egu hereva ta ia kerere lasi.   
\q1
\v 9 Mai ena diba maorona tauna dekenai,  
\q1 lauegu aonega hereva edia anina ibounai idia hedinarai namonamo.  
\q1 Aonega ia davaria vadaeni tauna dekenai,  
\q1 lauegu hereva be maoro momokani.   
\q1
\v 10 Lauegu hadibaia hereva do oi abia dae,  
\q1 siliva do oi abia dae lasi.  
\q1 Aonega do oi abia dae,  
\q1 to golo namo herea do oi negea.   
\q1
\v 11 Lau be aonega inai,  
\q1 lauegu namo ese herahera nadi namodia edia namo ia hereaia.  
\q1 Oi ura henia gaudia ibounai edia namo ese,  
\q1 lauegu namo idia hereaia diba lasi.   
\b  
\q1
\v 12 “Lau be aonega inai,  
\q1 lauegu diba be maoro.  
\q1 Lau be mai egu laloa diari.  
\q1 Lau be maoro bona kerere edia idau lau diba momokani.   
\q1
\v 13 Bema Lohiabada ita gari henia neganai,  
\q1 ita be kara dika do ita ura henia lasi, momokani.  
\q1 Hekokoroku, bona manau lasi karadia,  
\q1 kara dikadia bona hereva dikadia lau ura henia lasi.   
\q1
\v 14 Lau ese palani lau karaia noho,  
\q1 bona inai palani be lau karaia haorea.  
\q1 Lau be mai egu aonega bona mai egu siahu.   
\q1
\v 15 Lauegu durua dainai,  
\q1 king taudia ese edia bese taudia idia naria noho.  
\q1 Bona egu durua dainai,  
\q1 lohia taudia ese taravatu namodia idia karaia noho.   
\q1
\v 16 Lohia taudia ibounai ese lauegu durua dainai,  
\q1 edia tano ena taudia idia biagua noho.  
\q1 Gavana taudia ibounai be lau dainai,  
\q1 edia dagi idia dogoatao noho.   
\q1
\v 17 Lau dekenai idia ura henia taudia,  
\q1 be lau ese lau ura henidia noho,  
\q1 bona lau idia tahua noho taudia ese,  
\q1 lau do idia davaria.   
\q1
\v 18 Lau ese kohu momo bona matauraia lau henia noho.  
\q1 Lau ese mauri namona bona kwalimu lau henia noho.   
\q1
\v 19 Lau ese oi dekenai lau henia gauna,  
\q1 ena namo ese golo ia hereaia,  
\q1 ia ese siliva namo herea danu ia hereaia noho.   
\q1
\v 20 Lau be kara maoromaoro ena dala dekenai lau raka noho,  
\q1 bona mai laloa maoromaoro danu kota lau naria noho.   
\q1
\v 21 Lau idia ura henia taudia dekenai,  
\q1 be lau ese kohu momo lau henia.  
\q1 Edia ruma be kohu momo dekenai lau hahonua.   
\b  
\q1
\v 22 “Lohiabada ese gau ibounai ia karaia neganai,  
\q1 ia ese lau ia karaia guna.   
\q1
\v 23 Gunaguna momokani Lohiabada ese lau ia karaia.  
\q1 Tanobada ia do karaia lasi neganai,  
\q1 ia ese lau ia karaia guna.   
\q1
\v 24 Davara badana be do lasi neganai,  
\q1 Dirava ese lau ia karaia.  
\q1 Ranu lohilohi gabudia idia do noho lasi neganai,   
\q1
\v 25 bona ororo badadia be do lasi neganai,  
\q1 Dirava ese lau ia havaraia.  
\q1 Ororo maragidia be edia gabu dekenai idia do noho lasi,  
\q1 unai neganai lau be lau vara.   
\q1
\v 26 Tanobada, bona ena rei gabudia,  
\q1 be Dirava ese do ia karaia lasi neganai,  
\q1 bona tano ena kahu be do lasi neganai,  
\q1 lau be lau noho.   
\q1
\v 27 Guba be Dirava ese ia karaia neganai,  
\q1 lau be unuseni,  
\q1 davara badana ena hetoa gabudia,  
\q1 be Dirava ese ia karaia neganai danu.   
\q1
\v 28 Dirava ese ori guba dekenai ia atodia neganai,  
\q1 bona davara ena ranu lohilohi gabudia ia kehoa neganai,  
\q1 lau be lau noho.   
\q1
\v 29 Davara ena hetoa gabudia,  
\q1 ia hanaia diba lasi gabudia,  
\q1 be Dirava ese ia oda henia,  
\q1 bona ia ese tanobada ena hamatamaia nadi ia atoa neganai,  
\q1 lau be unuseni.   
\q1
\v 30 Unai neganai lau be Dirava ena badibadinai lau noho,  
\q1 gaukara karaia tauna bamona.  
\q1 Dina ibounai Dirava be lau dekenai ia moale,  
\q1 bona lau be iena vairana dekenai,  
\q1 lau moale noho nega ibounai.   
\q1
\v 31 Dirava ena tanobada,  
\q1 mai ena noho taudia ibounai dekenai lau moale noho.   
\b  
\q1
\v 32 “Lauegu natuna tau e,  
\q1 harihari lau dekenai do umui kamonai.  
\q1 Lauegu dala do umui badinaia, vadaeni do umui moale.   
\q1
\v 33 Lauegu hadibaia hereva do umui kamonai henia,  
\q1 vadaeni aonega do umui davaria.  
\q1 Lauegu hadibaia hereva do umui negea lasi.   
\q1
\v 34 Lau dekenai ia kamonai henia tauna be do ia moale.  
\q1 Dina ibounai ia ese lauegu iduara dekenai ia gini noho.  
\q1 Lauegu iduara dekenai ia naria noho.   
\q1
\v 35 Badina be lau ia davaria tauna ese,  
\q1 mauri ia davaria,  
\q1 bona Lohiabada ese ia do ia moalelaia.   
\q1
\v 36 Lau be aonega inai, lau ia davaria lasi tauna,  
\q1 ese sibona ia hadikaia noho.  
\q1 Lau ia badu henia noho tauna ese mase,  
\q1 ia ura henia noho.”   
\c 9  
\s1 Aonega bona kavakava  
\q1
\v 1 Aonega ese ena ruma badana ia haginia vadaeni.  
\q1 Ruma ena du ibounai 7 ia haginidia vadaeni.   
\q1
\v 2 Ena vamu be ia alaia mase vadaeni,  
\q1 iena uaina danu ia mikisi vadaeni,  
\q1 bona aniani patana danu ia karaia hegaegae.   
\q1
\v 3 Aonega ese danu iena hesiai kekeni ia siaia lao vadaeni,  
\q1 hanua lalonai ataiai gabudia dekena amo do idia boiboi,  
\q1 do idia gwau,   
\q1
\v 4 “Daika be aonega lasi, ia be iniseni do ia raka vareai.”  
\q1 Bona kavakava taudia dekenai aonega ia gwau,   
\q1
\v 5 “Umui mai,  
\q1 egu aniani do umui ania,  
\q1 bona lau mikisi vadaeni uaina do umui inua.   
\q1
\v 6 Emui kavakava daladia do umui rakatania, bona do umui mauri.  
\q1 Lalona kehoa ena dala dekenai do umui raka.   
\b  
\q1
\v 7 “Bema oi ese hekokoroku tauna oi sisiba henia,  
\q1 ia ese oi dekenai do ia hereva dika.  
\q1 Bema oi ese kara dika tauna oi gwau henia neganai,  
\q1 bero do oi davaria.   
\q1
\v 8 Hekokoroku tauna do oi gwau henia lasi,  
\q1 badina ia ese oi do ia hadikaia gwauraia.  
\q1 To aonega tauna do oi gwau henia,  
\q1 vadaeni ia ese oi do ia lalokau henia.   
\q1
\v 9 Aonega tauna do oi hadibaia,  
\q1 vadaeni iena aonega do ia bada lao.  
\q1 Kara maoromaoro tauna do oi hadibaia,  
\q1 vadaeni iena diba do ia bada lao.   
\b  
\q1
\v 10 “Lohiabada gari henia kara be aonega ena hamatamaia dalana,  
\q1 bona bema Helaga Dirava oi diba neganai,  
\q1 laloa kehoa oi davaria vadaeni inai.   
\q1
\v 11 Badina be lau, aonega,  
\q1 ese oiemu mauri dinadia do lau halataia.  
\q1 Oiemu mauri lagani edia namba do lau habadaia.   
\q1
\v 12 Bema oi be aonega,  
\q1 oiemu aonega ese oi do ia hanamoa.  
\q1 Bema oi ese aonega oi negea,  
\q1 oi sibona ese hisihisi ena metau do oi davaria.”   
\b  
\q1
\v 13 Kavakava hahine be ia boiboi momo noho.  
\q1 Ia be mai lebulebu danu,  
\q1 bona ia hemarai diba lasi.   
\q1
\v 14 Iena ruma ena iduara dekenai ia helai noho,  
\q1 hanua ena ataiai gabuna dekenai ia helai noho.   
\q1
\v 15 Raka hanaia taudia,  
\q1 sibodia edia dala idia raka maoromaoro noho taudia dekenai,  
\q1 unai hahine ese ia boiboi henidia, ia gwau,   
\q1
\v 16 “Daika be mai edia aonega lasi,  
\q1 ia be iniseni do ia raka vareai.”  
\q1 Bona mai ena lalona lasi tauna dekenai,  
\q1 ia hereva henia noho, ia gwau,   
\q1
\v 17 “Idia henaoa ranu ena mamina be namo,  
\q1 mai ena gaiho,  
\q1 bona hunia dekenai idia ania paraoa ena mamina be namo.”   
\q1
\v 18 To unai hahine ia kamonai tauna ia diba lasi,  
\q1 unai hahine ena ruma idia raka vareai taudia,  
\q1 be idia mase noho,  
\q1 bona ia diba lasi unai hahine ena vadivadi taudia,  
\q1 be mase taudia edia dobu gabuna dekenai idia diho lao vadaeni.   
\c 10  
\s1 Solomona ena aonega herevadia  
\q1
\v 1 Solomona ena aonega herevadia be inai:  
\b  
\q1 Aonega merona ese iena tamana ia hamoalea noho,  
\q1 to kavakava merona ese,  
\q1 iena sinana ena lalona ia hisihisi henia noho.   
\b  
\q1
\v 2 Koikoi karadia dekena amo idia abia moni o kohu,  
\q1 ese namo ia havaraia diba lasi,  
\q1 to kara maoromaoro ese,  
\q1 mase dekena amo oi do ia hamauria diba.   
\b  
\q1
\v 3 Lohiabada ese kara maoromaoro taudia dekenai hitolo ia siaia lasi,  
\q1 to kara dika taudia idia ura dikadika gauna,  
\q1 be ia henidia lasi.   
\b  
\q1
\v 4 Bema oi lahedo neganai oi be do oi ogogami,  
\q1 to bema oi gaukara auka neganai,  
\q1 oi be kohu momo do oi abia.   
\b  
\q1
\v 5 Aniani ia mage neganai,  
\q1 ia haboua merona be aonega merona,  
\q1 to aniani haboua neganai ia mahuta noho merona,  
\q1 ese hemarai ia havaraia noho.   
\b  
\q1
\v 6 Kara maoromaoro tauna ese hanamoa do ia davaria,  
\q1 to kara dika tauna ena dagedage karadia ese,  
\q1 iena hereva gwauraia dalana idia koua noho.   
\b  
\q1
\v 7 Kara maoromaoro tauna ta ia mase murinai,  
\q1 taunimanima ese ia idia laloatao neganai,  
\q1 moale bona hanamoa idia davaria noho,  
\q1 to kara dika tauna ena ladana,  
\q1 be taunimanima do idia laloaboio.   
\b  
\q1
\v 8 Aonega tauna ese sisiba ia abia dae noho,  
\q1 to hereva momo kavakava tauna,  
\q1 ese dika do ia davaria.   
\b  
\q1
\v 9 Laloa maoromaoro bona momokani taudia,  
\q1 edia noho be namo, mai gari lasi danu,  
\q1 to kara gagevagageva taudia ese,  
\q1 edia kerere idia hunia diba lasi.   
\b  
\q1
\v 10 Hereva momokani ia koua noho tauna ese,  
\q1 kerere ia havaraia noho,  
\q1 to sisiba hereva ia gwauraia,  
\q1 ia gari lasi tauna,  
\q1 ese maino ia havaraia noho.   
\b  
\q1
\v 11 Kara maoromaoro tauna ena uduna dekena amo,  
\q1 mauri hereva idia mai noho,  
\q1 to kara dika tauna ena dagedage karadia ese,  
\q1 iena hereva gwauraia dalana idia koua noho.   
\b  
\q1
\v 12 Badu ese heai ia havaraia noho,  
\q1 to lalokau ese kerere ibounai ia koua noho.   
\b  
\q1
\v 13 Laloa kehoa tauna ese aonega hereva ia gwauraia noho,  
\q1 to kavakava tauna be do idia dadabaia be namo.   
\b  
\q1
\v 14 Aonega taudia ese edia diba idia habadaia noho,  
\q1 to kavakava tauna ena hereva momo,  
\q1 ese kerere ia mailaia noho.   
\b  
\q1
\v 15 Kohu momo tauna ena moni bona kohu,  
\q1 ese ia idia gimaia noho,  
\q1 to ogogami ese ogogami tauna ia hadikaia ore noho.   
\b  
\q1
\v 16 Kara maoromaoro taudia ese,  
\q1 edia gaukara davana be mauri abia totona idia henia,  
\q1 to kara dika taudia edia gaukara davana ese,  
\q1 edia dika ia habadaia noho.   
\b  
\q1
\v 17 Hadibaia hereva ia kamonai henia noho tauna,  
\q1 be mauri dala dekenai ia raka noho,  
\q1 to sisiba hereva ia negea tauna be ia raka kerere noho.   
\b  
\q1
\v 18 Iena badu ia hunia noho tauna,  
\q1 be hereva koikoi tauna,  
\q1 bona samania kava hereva ia gwauraia noho tauna be kavakava.   
\b  
\q1
\v 19 Hereva momo ese kara kerere idia havaraia noho,  
\q1 to iena uduna ena hereva ia koua noho tauna,  
\q1 be mai ena aonega.   
\b  
\q1
\v 20 Kara maoromaoro tauna ena hereva,  
\q1 be siliva namo herea bamona,  
\q1 to kara dika tauna ena laloa gaudia be anina lasi.   
\b  
\q1
\v 21 Kara maoromaoro tauna ena hereva,  
\q1 ese taunimanima do idia hanamodia,  
\q1 to kavakava taudia be mai edia lalodia lasi dainai,  
\q1 idia mase noho.   
\b  
\q1
\v 22 Lohiabada ena hanamoa sibona ese,  
\q1 kohu momo oi dekenai ia henia noho,  
\q1 bona unai kohu danu,  
\q1 ese lalohisihisi sisina oi dekenai do ia henia lasi.   
\b  
\q1
\v 23 Kavakava tauna ese,  
\q1 kara dika be iena gadara gauna ia halaoa noho,  
\q1 to laloa kehoa tauna ese,  
\q1 aonega karadia ia moalelaia noho.   
\b  
\q1
\v 24 Kara dika tauna ese ia gari henia gauna,  
\q1 be ia dekenai do ia vara,  
\q1 to kara maoromaoro tauna ena ura gauna,  
\q1 be do ia abia.   
\b  
\q1
\v 25 Lai guba do ia toa murinai,  
\q1 kara dika tauna ia boio,  
\q1 to kara maoromaoro tauna do ia gini goada noho hanaihanai.   
\b  
\q1
\v 26 Oiemu gaukara karaia totona,  
\q1 lahedo tauna do oi abia lasi,  
\q1 badina ia ese oi do ia hisihisi henia,  
\q1 vinega ese isena ia hahisia bamona,  
\q1 bona kwalahu ese matana ia hahisia bamona.   
\b  
\q1
\v 27 Lohiabada do oi gari henia,  
\q1 bona ia ese oiemu mauri lagani do ia halataia,  
\q1 to kara dika taudia edia mauri lagani,  
\q1 be do idia kwadogi.   
\b  
\q1
\v 28 Kara maoromaoro tauna ese ia diba,  
\q1 do ia abia gauna be moale momokani,  
\q1 to kara dika tauna ese,  
\q1 do ia naria noho gauna be anina lasi.   
\b  
\q1
\v 29 Lohiabada ese laloa maoromaoro bona momokani taudia ia gimaia noho,  
\q1 to ia ese kara dika taudia ia hadikaia ore noho.   
\b  
\q1
\v 30 Kara maoromaoro taudia be do idia noho namo,  
\q1 mai maino danu hanaihanai,  
\q1 to kara dika taudia,  
\q1 be tano dekenai do idia noho lasi.   
\b  
\q1
\v 31 Kara maoromaoro tauna ena uduna dekena amo,  
\q1 aonega ia gwauraia noho,  
\q1 to hereva gagevagageva ia gwauraia tauna,  
\q1 ena malana do idia utua oho.   
\b  
\q1
\v 32 Kara maoromaoro taudia,  
\q1 be taunimanima durua hereva idia gwauraia noho diba,  
\q1 to kara dika taudia ese,  
\q1 taunimanima hadikaia hereva sibona idia gwauraia noho.   
\b  
\c 11  
\q1
\v 1 Metau sikele koikoidia idia gaukaralaia noho taudia,  
\q1 be Lohiabada ese ia badu henidia noho,  
\q1 to sikele maoromaorodia dekenai Lohiabada ia moale noho.   
\b  
\q1
\v 2 Hekokoroku taudia ese hemarai idia davaria noho,  
\q1 to manau taudia ese aonega idia davaria noho.   
\b  
\q1
\v 3 Kara maoromaoro taudia be,  
\q1 edia laloa maoromaoro ese ia hakaudia noho,  
\q1 to kara kerere mai koikoi danu taudia,  
\q1 be sibodia edia laloa gagevagageva ese ia hadikadia ore noho.   
\b  
\q1
\v 4 Dirava ena Kota bada dinana dekenai,  
\q1 oiemu kohu bada ese gau namona ta,  
\q1 oi dekenai do idia henia lasi,  
\q1 to kara maoromaoro ese,  
\q1 mase dekena amo oi ia hamauria diba.   
\b  
\q1
\v 5 Kerere lasi tauna ena kara maoromaoro.  
\q1 ese iena noho ia hanamoa noho,  
\q1 to kara dika tauna be sibona ena dika,  
\q1 ese iena noho ia hadikaia noho momokani.   
\b  
\q1
\v 6 Kara maoromaoro taudia,  
\q1 be edia kara maoromaoro ese ia hamauridia noho,  
\q1 to kara kerere mai koikoi danu taudia,  
\q1 be sibodia edia ura dikadia ese ia hadikadia ore noho.   
\b  
\q1
\v 7 Kara dika tauna ia mase neganai,  
\q1 ia ese ia naria gau namodia be ia danu idia mase noho,  
\q1 bona iena mauri neganai iena siahu dekena amo,  
\q1 ia laloa do ia abia gau namodia,  
\q1 be anina lasi momokani.   
\b  
\q1
\v 8 Kara maoromaoro tauna be hisihisi dekena amo,  
\q1 Dirava ese ia hamauria noho,  
\q1 to unai hisihisi be kara dika tauna ia davaria noho.   
\b  
\q1
\v 9 Dirava ia gari henia lasi tauna ese,  
\q1 iena hereva dekena amo,  
\q1 iena badibadinai tauna ia hadikaia ore noho,  
\q1 to aonega kara dekena amo,  
\q1 kara maoromaoro taudia idia heau mauri noho.   
\b  
\q1
\v 10 Kara maoromaoro bona momokani taudia edia noho be namo neganai,  
\q1 hanua taudia idia moale noho,  
\q1 to kara dika taudia idia mase neganai,  
\q1 hanua taudia idia moale bada noho.   
\b  
\q1
\v 11 Kara maoromaoro taudia ese hanua ta idia hanamoa neganai,  
\q1 unai hanua be do ia namo,  
\q1 to kara dika taudia edia hereva dekena amo,  
\q1 hanua be do ia dika.   
\b  
\q1
\v 12 Kavakava tauna ese iena badibadinai tauna ia herevalaia dika,  
\q1 to aonega tauna be hereva ta do ia gwauraia lasi.   
\b  
\q1
\v 13 Hereva kava, hereva kava noho tauna ese,  
\q1 hunia herevadia ia hedinaraia noho,  
\q1 to oi abidadama henia diba tauna ese,  
\q1 hunia hereva do ia hedinaraia lasi.   
\b  
\q1
\v 14 Bema bese ta be mai edia gunalaia tauna lasi neganai,  
\q1 unai bese taudia be do idia moru,  
\q1 to bema sisiba namona taudia be momo neganai,  
\q1 bese taudia edia noho be namo.   
\b  
\q1
\v 15 Bema oi gwauhamata,  
\q1 idau tauna ena abiatorehai ena davana do oi henia neganai,  
\q1 lalohisihisi do oi davaria.  
\q1 Unai bamona gwauhamata do oi karaia lasi neganai,  
\q1 dika do oi davaria lasi.   
\b  
\q1
\v 16 Mai ena bogahisihisi hahine,  
\q1 be taunimanima ese do idia matauraia,  
\q1 to dagedage tauna ese,  
\q1 tanobada ena kohu sibona do ia davaria.   
\b  
\q1
\v 17 Mai ena bogahisihisi tauna ese,  
\q1 sibona ena namo ia havaraia noho,  
\q1 to dagedage tauna ese,  
\q1 ia sibona ia hisihisi henia noho.   
\b  
\q1
\v 18 Kara dika tauna ena davana be davana momokani lasi,  
\q1 to kara maoromaoro idia karaia taudia ese,  
\q1 davana namona momokani idia davaria noho.   
\b  
\q1
\v 19 Kara maoromaoro ia ura momokani tauna ese,  
\q1 mauri ia davaria noho,  
\q1 to kara dika ia ura karaia tauna,  
\q1 be do ia mase.   
\b  
\q1
\v 20 Edia kudouna dekenai laloa dika ia noho taudia,  
\q1 be Lohiabada ese ia ura henia lasi momokani,  
\q1 to edia dala be kerere lasi taudia,  
\q1 be Lohiabada ese ia ura henidia momokani.   
\b  
\q1
\v 21 Inai hereva be momokani:  
\q1 Kara dika taudia ese edia kerere davana,  
\q1 dekena amo do idia heau mauri lasi,  
\q1 to kara maoromaoro taudia be do idia heau mauri.   
\b  
\q1
\v 22 Bema hahine ta be mai ena hairaina,  
\q1 to mai ena lalona lasi neganai,  
\q1 ia be golo rini,  
\q1 boroma ena udu baubauna lalonai bamona.   
\b  
\q1
\v 23 Dirava ese taunimanima ibounai edia ura ia diba.  
\q1 Kara maoromaoro taudia edia ura be namo dainai,  
\q1 Dirava ese namo ia havaraia idia totona,  
\q1 to kara dika taudia edia ura be dika dainai,  
\q1 Dirava ese edia kerere davana do ia henia.   
\b  
\q1
\v 24 Tau ta ese iena moni momo,  
\q1 be harihari gauna bamona ia henia noho,  
\q1 to iena kohu bona moni idia bada lao noho.  
\q1 Ma tau ta ese iena moni ia naria noho,  
\q1 bona ia henia momo lasi,  
\q1 to unai tau be ia ogogami noho.   
\b  
\q1
\v 25 Oiemu moni do oi henia bada noho,  
\q1 vadaeni do oi noho namo.  
\q1 Taunimanima haida do oi durua,  
\q1 vadaeni haida ese oi do idia durua.   
\b  
\q1
\v 26 Davana bada abia totona uiti ia haboua noho tauna,  
\q1 be taunimanima ese idia hereva dika henia noho,  
\q1 to iena uiti ia hoia lao haragaharaga tauna,  
\q1 be idia hanamoa noho.   
\b  
\q1
\v 27 Namo do oi tahua neganai,  
\q1 taunimanima ese oi do idia matauraia,  
\q1 to bema dika oi tahua neganai,  
\q1 dika ese oi do ia davaria.   
\b  
\q1
\v 28 Iena moni bona kohu ia abidadama henia tauna,  
\q1 be au raurau masena bamona do ia moru,  
\q1 to kara maoromaoro tauna be do ia tubu,  
\q1 au raurau matamatana bamona.   
\b  
\q1
\v 29 Iena ruma bese taudia edia latanai kerere ia mailaia tauna,  
\q1 be dokona neganai do ia anina lasi.  
\q1 Kavakava taudia be nega ibounai,  
\q1 aonega taudia edia hesiai taudia do idia lao.   
\b  
\q1
\v 30 Kara maoromaoro ese mauri ia henia noho,  
\q1 bona taunimanima edia laumadia,  
\q1 be mauri dekenai ia veria tauna be mai ena aonega.   
\b  
\q1
\v 31 Kara maoromaoro taudia ese,  
\q1 edia kerere davana be inai tanobada dekenai idia abia noho.  
\q1 Unai dainai kara dika bona kerere taudia,  
\q1 edia kerere davana be do ia bada herea, ani?   
\b  
\c 12  
\q1
\v 1 Matakani ia ura henia tauna ese,  
\q1 aonega ia ura henia noho,  
\q1 to sisiba hereva dekenai idia badu taudia be kavakava.   
\b  
\q1
\v 2 Tau namona be Lohiabada dekena amo,  
\q1 hariharibada ia abia noho,  
\q1 to dika karaia totona ia laloa noho tauna,  
\q1 be Lohiabada ese dika tauna ia gwauraia noho.   
\b  
\q1
\v 3 Kara dika ese tau ta dekenai,  
\q1 noho namo do ia henia lasi,  
\q1 to kara maoromaoro taudia be idia gini goada noho.   
\b  
\q1
\v 4 Hahine namona ese iena adavana dekenai,  
\q1 matauraia bona moale ia henia noho,  
\q1 to iena adavana dekenai hemarai ia havaraia hahine ese,  
\q1 iena tau ia hisihisi henia noho,  
\q1 turia hamanokaia gorere bamona.   
\b  
\q1
\v 5 Kara maoromaoro taudia edia laloa be maoromaoro,  
\q1 to kara dika taudia edia sisiba be mai koikoi danu.   
\b  
\q1
\v 6 Kara dika taudia edia hereva,  
\q1 be taunimanima alaia totona ena hereva,  
\q1 to kara maoromaoro taudia edia ududia hereva ese,  
\q1 taunimanima idia hamauria noho.   
\b  
\q1
\v 7 Kara dika taudia idia moru noho,  
\q1 bona idia boio momokani,  
\q1 to kara maoromaoro taudia edia ruma bese taudia,  
\q1 be do idia mauri noho momokani.   
\b  
\q1
\v 8 Bema oi be mai aonega danu neganai,  
\q1 taunimanima ese oi do idia hanamoa,  
\q1 to bema oi be kavakava neganai,  
\q1 taunimanima ese oi do idia negea.   
\b  
\q1
\v 9 Dagi maragi dekenai oi noho,  
\q1 to mai oiemu aniani be namo,  
\q1 to oi sibona lohia tauna oi gwauraia,  
\q1 to oi be hitolo noho, be dika.   
\b  
\q1
\v 10 Kara maoromaoro tauna ese,  
\q1 iena boromakau ia bogahisihisi henia noho,  
\q1 to kara dika taudia edia kudouna,  
\q1 be mai dagedage danu.   
\b  
\q1
\v 11 Iena tano ia gaukaralaia namonamo tauna,  
\q1 ese aniani momo do ia davaria,  
\q1 to anina lasi karadia dekenai,  
\q1 iena nega ia haorea tauna be kavakava.   
\b  
\q1
\v 12 Kara dika taudia edia ura tamona,  
\q1 be dika do idia karaia noho,  
\q1 to kara maoromaoro taudia ese namo idia havaraia noho.   
\b  
\q1
\v 13 Kara dika tauna be sibona ena hereva ese,  
\q1 do idia hadikaia, tarapu ese do ia hadikaia bamona,  
\q1 to kara maoromaoro tauna ese,  
\q1 kerere dekena amo ia roho mauri noho.   
\b  
\q1
\v 14 Oiemu davana be oiemu hereva bona oiemu kara hegeregerena,  
\q1 ma oiemu gaukara hegeregerena ahuna do oi abia.   
\b  
\q1
\v 15 Kavakava tauna ese ia laloa iena dala be maoro,  
\q1 to aonega tauna ese sisiba do ia kamonai henia.   
\b  
\q1
\v 16 Kavakava tauna ese iena badu ia hedinaraia haraga noho,  
\q1 to laloa kehoa tauna ese,  
\q1 ia dekenai idia hereva dika henia neganai do ia laloa lasi.   
\b  
\q1
\v 17 Hereva momokani tauna ese,  
\q1 hereva maoromaoro ia gwauraia hedinarai noho,  
\q1 to hereva koikoi gwauraia tauna ese,  
\q1 kara maoromaoro dalana ia hadikaia noho.   
\b  
\q1
\v 18 Ia hereva haraga tauna ena hereva,  
\q1 be tuari kaia ia gwadaia noho bamona,  
\q1 to aonega tauna ena hereva ese,  
\q1 taunimanima idia hamauria diba.   
\b  
\q1
\v 19 Hereva koikoi be nega sisina sibona do idia abia dae,  
\q1 to hereva momokani be do idia noho,  
\q1 ela bona hanaihanai.   
\b  
\q1
\v 20 Kara dika karaia dala idia tahua taudia,  
\q1 edia kudoudia be mai koikoi danu,  
\q1 to kara namodia karaia dala idia tahua taudia ese,  
\q1 moale bada do idia davaria.   
\b  
\q1
\v 21 Kara maoromaoro taudia dekenai dika ia vara noho lasi,  
\q1 to kara dika taudia be idia hekwakwanai momo noho.   
\b  
\q1
\v 22 Lohiabada ese hereva koikoi taudia ia badu henia noho,  
\q1 to idia kara momokani noho taudia dekenai,  
\q1 Lohiabada ia moale noho.   
\b  
\q1
\v 23 Aonega taudia ese edia diba idia hunia noho,  
\q1 to kavakava taudia ese,  
\q1 edia kavakava idia gwauraia hedinarai noho.   
\b  
\q1
\v 24 Bema oi gaukara auka neganai,  
\q1 siahu bona goada do oi davaria,  
\q1 to oi lahedo neganai,  
\q1 hesiai tauna mai guia danu do oi lao.   
\b  
\q1
\v 25 Laloa metau ese oiemu moale do ia koua,  
\q1 to hereva namodia ese oi idia hamoalea diba.   
\b  
\q1
\v 26 Kara maoromaoro tauna ese,  
\q1 iena turana be dala maoromaorona dekenai ia hakaua noho,  
\q1 to kara dika tauna ese,  
\q1 iena turana ia hakaua kerere noho.   
\b  
\q1
\v 27 Bema oi lahedo neganai,  
\q1 oiemu ura gauna do oi davaria lasi,  
\q1 to bema oi gaukara auka neganai,  
\q1 kohu momo namo herea do oi davaria.   
\b  
\q1
\v 28 Kara maoromaoro ena dala,  
\q1 be mauri dekenai ia lao noho,  
\q1 to kara kerere ena dala,  
\q1 be mase dekenai ia lao noho.   
\c 13  
\q1
\v 1 Aonega merona ese,  
\q1 iena tamana ena hadibaia hereva ia kamonai henia noho,  
\q1 to hekokoroku tauna ese,  
\q1 sisiba hereva dekenai ia kamonai lasi.   
\b  
\q1
\v 2 Tau namona ena hereva gaudia ese,  
\q1 mauri namona ia dekenai idia henia noho,  
\q1 to koikoi tauna ese dagedage ia ura dikadika noho.   
\b  
\q1
\v 3 Iena uduna bibina ena hereva ia naria namonamo noho tauna,  
\q1 ese iena lauma ia naria noho,  
\q1 to iena hereva ia naria lasi tauna ese,  
\q1 sibona ia hadikaia noho.   
\b  
\q1
\v 4 Lahedo tauna ese gau ia ura dikadika,  
\q1 to gau ta ia abia lasi.  
\q1 Gaukara auka tauna ese,  
\q1 ia ura henia gaudia ibounai do ia davaria.   
\b  
\q1
\v 5 Kara maoromaoro taudia ese,  
\q1 koikoi idia ura henia lasi momokani,  
\q1 to kara dika taudia ese,  
\q1 hemarai bona dika idia havaraia noho.   
\b  
\q1
\v 6 Kara maoromaoro ese laloa maoromaoro tauna,  
\q1 dika dekena amo ia naria noho,  
\q1 to dika ese kara dika tauna ia hamorua noho.   
\b  
\q1
\v 7 Taunimanima haida idia gwau idia be mai moni momo,  
\q1 to idia be ogogami,  
\q1 bona taunimanima haida idia gwau idia be ogogami,  
\q1 to idia be kohu momo taudia.   
\b  
\q1
\v 8 Kohu momo tauna be haida ese idia hadikaia gwauraia neganai,  
\q1 iena moni ia halusia, iena mauri abia totona,  
\q1 to ogogami tauna be,  
\q1 haida ese do idia hadikaia gwauraia lasi.   
\b  
\q1
\v 9 Kara maoromaoro tauna,  
\q1 be lamepa mai ena diari namona bamona,  
\q1 to kara dika tauna be lamepa ia bodo noho bamona.   
\b  
\q1
\v 10 Hekokoroku ese heai bona heatu ia havaraia noho,  
\q1 to aonega tauna ese sisiba ia tahua noho.   
\b  
\q1
\v 11 Abia kava moni bona kohu,  
\q1 be do ia ore haragaharaga,  
\q1 to iena kohu ia haboua metairametaira tauna,  
\q1 ese do ia habadaia.   
\b  
\q1
\v 12 Bema tau ta ia laloa gau namona ta do ia abia,  
\q1 to unai gau totona nega daudau ia naria kava,  
\q1 unai be lalohisihisi ia davaria noho,  
\q1 to bema unai tau ese,  
\q1 ia ura henia gauna ia abia neganai,  
\q1 moale momokani do ia davaria.   
\b  
\q1
\v 13 Bema sisiba namona oi negea, kerere do oi davaria,  
\q1 to bema sisiba namona oi badinaia,  
\q1 mauri do oi davaria.   
\b  
\q1
\v 14 Aonega tauna ena hadibaia hereva,  
\q1 be mauri ia henia ranu bamona.  
\q1 Inai hereva ese oi do idia durua,  
\q1 vadaeni mase dekena amo do oi heau mauri diba.   
\b  
\q1
\v 15 Taunimanima ese aonega tauna idia matauraia noho,  
\q1 to taunimanima idia abidadama henia diba lasi tauna ese,  
\q1 dika momokani do ia davaria.   
\b  
\q1
\v 16 Aonega tauna ese sibona do ia laloa namonamo guna,  
\q1 vadaeni kara do ia karaia,  
\q1 to kavakava tauna ese iena kavakava ia gwauraia hedinarai.   
\b  
\q1
\v 17 Hereva ia mailaia tau dikana ese,  
\q1 koikoi dainai kerere ia havaraia noho,  
\q1 to hereva ia mailaia mai momokani danu tauna ese,  
\q1 mauri namona ia mailaia noho.   
\b  
\q1
\v 18 Hadibaia hereva ia kamonai lasi tauna,  
\q1 be do ia ogogami,  
\q1 bona mai ena hemarai danu,  
\q1 to sisiba hereva ia abia dae noho tauna,  
\q1 be do idia matauraia.   
\b  
\q1
\v 19 Oiemu ura gauna ena anina oi davaria neganai,  
\q1 lalo namo do oi davaria,  
\q1 to kavakava taudia ese,  
\q1 kara dika rakatania kara idia ura lasi momokani.   
\b  
\q1
\v 20 Aonega tauna danu ia raka hebou noho tauna,  
\q1 be do ia aonega,  
\q1 to kavakava taudia danu oi turana karaia neganai,  
\q1 dika do oi davaria.   
\b  
\q1
\v 21 Dika bona kerere ese,  
\q1 kara dika tauna ena murina dekenai idia lao noho,  
\q1 to kara maoromaoro tauna ena davana,  
\q1 be mauri namona mai kohu danu.   
\b  
\q1
\v 22 Tau namona be ia mase neganai,  
\q1 ia ese iena kohu be iena tubuna dekenai ia henia,  
\q1 to kara dika taudia edia kohu bona moni,  
\q1 be kara maoromaoro taudia ese do idia abia.   
\b  
\q1
\v 23 Sedira ogogami tauna ena uma ese,  
\q1 aniani momo do ia havaraia,  
\q1 to kota maoromaoro lasi taudia ese,  
\q1 ogogami tauna ena kohu idia kokia noho.   
\b  
\q1
\v 24 Iena natuna ia kwadia lasi tauna ese,  
\q1 iena natuna ia hadikaia noho,  
\q1 to iena natuna ia lalokau henia tauna ese,  
\q1 iena natuna ia matakani henia noho.   
\b  
\q1
\v 25 Kara maoromaoro tauna be do ia aniani boga kunu noho,  
\q1 to kara dika tauna be do ia hitolo noho.   
\b  
\c 14  
\q1
\v 1 Aonega hahine ese gaukara namona ia karaia,  
\q1 bona iena famili taudia ia haginidia goada.  
\q1 To kavakava hahine ese,  
\q1 iena ruma bona famili ia hadikaia noho.   
\b  
\q1
\v 2 Bema oi kara maoromaoro,  
\q1 oi be Lohiabada oi gari henia noho,  
\q1 to bema oi kara kerere,  
\q1 oi be Lohiabada oi gari henia lasi.   
\b  
\q1
\v 3 Kavakava tauna be ia hekokoroku dainai,  
\q1 ia hereva kava momo noho,  
\q1 to aonega tauna ena hereva ese ia do idia gimaia noho.   
\b  
\q1
\v 4 Bema boromakau tau be lasi,  
\q1 boromakau ruma be do ia goeva noho,  
\q1 to boromakau tau idia noho neganai,  
\q1 koni aniani momo danu idia noho.   
\b  
\q1
\v 5 Uitnesi tauna maoromaorona ese,  
\q1 hereva momokani ia gwauraia noho,  
\q1 to uitnesi tauna maoromaorona lasi ese,  
\q1 nega ibounai koikoi ia gwauraia noho.   
\b  
\q1
\v 6 Hekokoroku taudia ese aonega idia davaria diba lasi,  
\q1 to laloa kehoa tauna ese,  
\q1 aonega do ia davaria haraga.   
\b  
\q1
\v 7 Kavakava taudia dekena amo do oi noho siri,  
\q1 badina be idia dekena amo,  
\q1 aonega do oi davaria lasi.   
\b  
\q1
\v 8 Badina dahaka laloa kehoa tauna be mai ena aonega danu?  
\q1 Badina be kara maorona dalana be ia diba momokani.  
\q1 Badina dahaka kavakava tauna be ia kavakava noho?  
\q1 Badina be kara maorona ena dala ia diba momokani lasi.   
\b  
\q1
\v 9 Kavakava taudia be edia kara dika dainai,  
\q1 edia lalona idia giroa lasi,  
\q1 idia laloa unai be gau ta lasi,  
\q1 to kara maoromaoro taudia ese,  
\q1 edia kara dika ena gwauatao dalana idia tahua noho.   
\b  
\q1
\v 10 Oiemu moale be oi sibona oiemu.  
\q1 Oiemu lalohisihisi be oi sibona oiemu.  
\q1 Idau tauna ta ese oi danu umui abia hebou diba lasi.   
\b  
\q1
\v 11 Kara dika tauna ena ruma be do idia hadikaia,  
\q1 to kara maoromaoro tauna ena ruma,  
\q1 be do ia gini noho, namo herea.   
\b  
\q1
\v 12 Dala ta ia noho,  
\q1 sedira iena toana oi dekenai be maoro,  
\q1 to iena dokona be mase dekenai do ia lao.   
\b  
\q1
\v 13 Sedira kiri ese lalohisihisi do ia hunia,  
\q1 to moale ia ore neganai,  
\q1 lalohisihisi be do noho.   
\b  
\q1
\v 14 Dala maorona ia rakatania tauna ese,  
\q1 iena davana metauna do ia davaria,  
\q1 to tau namona ese davana namona do ia davaria.   
\b  
\q1
\v 15 Mai ena lalona kehoa lasi tauna ese,  
\q1 hereva ibounai ia hamomokania noho,  
\q1 to laloa kehoa tauna ese,  
\q1 iena raka dalana ia laloa namonamo noho.   
\b  
\q1
\v 16 Aonega tauna ese Dirava dekenai ia gari noho,  
\q1 bona dika dekena amo ia raka siri noho,  
\q1 to kavakava tauna ese haheauka ia negea,  
\q1 bona karaharaga ia kara kava noho.   
\b  
\q1
\v 17 Badu haraga tauna be ia kavakava noho,  
\q1 bona laloa dika tauna,  
\q1 be taunimanima ese idia badu henia noho.   
\b  
\q1
\v 18 Laloa kehoa lasi taudia edia davana be kavakava,  
\q1 to laloa kehoa taudia ese aonega idia davaria noho.   
\b  
\q1
\v 19 Kara dika taudia be,  
\q1 kara namo taudia edia vairanai do idia tui diho.  
\q1 Kerere bada taudia ese kara maoromaoro taudia edia vairanai,  
\q1 edia kwaradia do idia atoa diho.   
\b  
\q1
\v 20 Ogogami tauna be taunimanima ibounai idia ura henia lasi,  
\q1 iena badibadinai noho tauna danu,  
\q1 to kohu momo tauna ena turana be momo herea.   
\b  
\q1
\v 21 Iena badibadinai noho tauna ia negea tauna,  
\q1 be tau dikana,  
\q1 to ogogami taudia ia bogahisihisi henia tauna,  
\q1 be ia moale noho.   
\b  
\q1
\v 22 Kara dika karaia dala idia tahua taudia,  
\q1 be idia kerere, ani?  
\q1 To kara namo karaia dala idia tahua taudia ese,  
\q1 bogahisihisi bona abidadama ena maino do idia davaria.   
\b  
\q1
\v 23 Hekwarahi ibounai ese davana namona idia henia noho,  
\q1 to hereva kava ese ogogami ia havaraia noho.   
\b  
\q1
\v 24 Aonega taudia edia davana be moni bona kohu,  
\q1 to kavakava taudia edia davana be kavakava sibona.   
\b  
\q1
\v 25 Hereva momokani ia gwauraia hedinarai tauna ese,  
\q1 taunimanima ia hamauria noho,  
\q1 to hereva koikoi ia gwauraia tauna ese,  
\q1 taunimanima ia hadikaia noho.   
\b  
\q1
\v 26 Lohiabada ia gari henia tauna ese,  
\q1 abidadama goada tauna do ia lao,  
\q1 bona unai abidadama dainai,  
\q1 unai tau ena natuna do idia noho namo,  
\q1 mai maino danu.   
\b  
\q1
\v 27 Oi ura mase dekena amo do oi raka siri, a?  
\q1 Lohiabada gari henia kara ese mauri ia havaraia noho.   
\b  
\q1
\v 28 Bema iena taunimanima be momo neganai,  
\q1 king ena hairaina be bada,  
\q1 to king ta be mai ena taunimanima lasi neganai,  
\q1 ia be gau ta lasi.   
\b  
\q1
\v 29 Iena badu ia hakerua tauna,  
\q1 be mai ena aonega danu,  
\q1 to bema ia badu haraga neganai,  
\q1 tau ta ese iena kavakava do ia habadaia.   
\b  
\q1
\v 30 Bema oiemu kudouna be mai ena maino danu neganai,  
\q1 oiemu tauanina do ia noho namo,  
\q1 to mama ese oiemu gorere dikana do ia havaraia.   
\b  
\q1
\v 31 Bema ogogami taudia oi dagedage henia neganai,  
\q1 oi ia karaia Dirava oi hereva dika henia noho,  
\q1 to ogogami taudia dekenai bogahisihisi ia henia tauna ese,  
\q1 Dirava ia matauraia noho.   
\b  
\q1
\v 32 Kara dika taudia be edia kara dika ese,  
\q1 idia ia hadikaia noho,  
\q1 to kara maoromaoro taudia,  
\q1 be edia laloa maoromaoro ese do ia hamauridia.   
\b  
\q1
\v 33 Aonega be laloa kehoa tauna ena kudouna lalonai ia noho,  
\q1 to kavakava taudia edia kudoudia lalonai,  
\q1 aonega be idia diba lasi.   
\b  
\q1
\v 34 Kara maoromaoro ese bese ta ia hanamoa noho,  
\q1 to kara dika ese,  
\q1 bese ta dekenai hemarai ia havaraia noho.   
\b  
\q1
\v 35 Bema iena hesiai tauna be mai ena aonega neganai,  
\q1 king ese ia do ia laloa namo henia,  
\q1 to hemarai karadia ia karaia tauna ena latanai,  
\q1 king ena badu do ia ginidae.   
\b  
\c 15  
\q1
\v 1 Mai manau danu ia haere tauna,  
\q1 ese badu ia koua noho,  
\q1 to hereva auka ese badu ia havaraia noho.   
\b  
\q1
\v 2 Aonega tauna ia hereva neganai,  
\q1 ia ese aonega bona diba ia habadaia noho,  
\q1 to kavakava taudia ese,  
\q1 hereva kavakava sibona idia gwauraia noho.   
\b  
\q1
\v 3 Lohiabada ese gabu ibounai ia itaia noho,  
\q1 bona dahaka idia vara gaudia ibounai ia diba.  
\q1 Iseda kara ibounai ia itaia noho,  
\q1 kara dikadia bona kara namodia danu.   
\b  
\q1
\v 4 Hereva mai bogahisihisi danu ese,  
\q1 mauri idia havaraia noho,  
\q1 to hereva dagedage ese,  
\q1 tau ena mauri dalana ia koua noho.   
\b  
\q1
\v 5 Bema oiemu tamana ena sisiba hereva oi kamonai henia lasi,  
\q1 oi be kavakava,  
\q1 to bema iena matakani kara oi abia dae, oi be aonega.   
\b  
\q1
\v 6 Kara maoromaoro tauna ena ruma dekenai kohu momo idia noho,  
\q1 to kara dika taudia be nega dikadia neganai,  
\q1 edia kohu idia boio.   
\b  
\q1
\v 7 Aonega taudia ese diba namona idia habadaia noho,  
\q1 to kavakava taudia ese unai bamona idia karaia lasi.   
\b  
\q1
\v 8 Taunimanima namodia idia guriguri neganai,  
\q1 Lohiabada ia moale noho,  
\q1 to kara dika tauna ena boubou gauna,  
\q1 be Lohiabada ese ia ura henia lasi momokani.   
\b  
\q1
\v 9 Lohiabada ese kara dika taudia edia dala,  
\q1 dekenai ia badu noho,  
\q1 to kara maoromaoro taudia ia lalokau henidia noho.   
\b  
\q1
\v 10 Dala maorona ia rakatania tauna ese,  
\q1 matakani auka do ia davaria.  
\q1 Sisiba dekenai ia badu tauna be do ia mase.   
\b  
\q1
\v 11 Mase gabuna bona hel gabuna danu,  
\q1 be Lohiabada ena vairana dekenai idia hedinarai noho.  
\q1 Unai dainai edena bamona tau ta ese,  
\q1 iena kudouna ena laloa Dirava dekena amo ia hunia diba?   
\b  
\q1
\v 12 Hekokoroku taudia be,  
\q1 idia ura lasi haida ese idia sisiba henidia.  
\q1 Idia ese aonega taudia edia sisiba idia tahua lasi.   
\b  
\q1
\v 13 Tau ena kudouna ia moale neganai ia kiri noho,  
\q1 to lalohisihisi ese,  
\q1 unai tau ena lauma ia hamanokaia noho.   
\b  
\q1
\v 14 Laloa kehoa tauna ese aonega ia tahua noho,  
\q1 to kavakava taudia be,  
\q1 kavakava sibona dekenai idia moale noho.   
\b  
\q1
\v 15 Iena hisihisi ia laloa noho tauna,  
\q1 ena mauri dinadia ibounai be dika,  
\q1 to kudouna dekenai ia moale tauna ese,  
\q1 nega ibounai iena noho ia moalelaia noho.   
\b  
\q1
\v 16 Do oi ogogami,  
\q1 bona Dirava do oi gari henia noho be namo,  
\q1 to do oi kohu momo, bona mai oiemu hekwakwanai be dika.   
\b  
\q1
\v 17 Raisi sibona,  
\q1 oiemu lalokau taudia danu do oi ania be namo,  
\q1 to vamu namo herea,  
\q1 badu noho taudia danu do oi ania be dika.   
\b  
\q1
\v 18 Badu haraga tauna ese heai ia havaraia noho,  
\q1 to haheauka tauna ese maino ia havaraia noho.   
\b  
\q1
\v 19 Lahedo tauna ena dala,  
\q1 be mai hekwakwanai gaudia momo danu,  
\q1 to gaukara momokani tauna ena dala,  
\q1 be namo bona mai daradara lasi.   
\b  
\q1
\v 20 Aonega merona ese iena tamana ia hamoalea noho,  
\q1 to kavakava tauna ese iena sinana ia negea noho.   
\b  
\q1
\v 21 Kavakava taudia be edia kavakava dekenai idia moale noho,  
\q1 to aonega taudia ese kara maoromaoro idia karaia noho.   
\b  
\q1
\v 22 Sisiba momo do oi tahua noho,  
\q1 bona do oi kwalimu,  
\q1 to sisiba do oi abia lasi neganai, do oi moru.   
\b  
\q1
\v 23 Iena haere maorona ese tau ta do ia hamoalea,  
\q1 bona ena nega korikori dekenai,  
\q1 hereva namona ta ia gwauraia, be namo bada!   
\b  
\q1
\v 24 Aonega tauna ese mauri dekenai ia lao dalana,  
\q1 ia raka daekau noho.  
\q1 Ia be mase dekenai ia lao dalana,  
\q1 ia raka diho noho lasi.   
\b  
\q1
\v 25 Lohiabada ese hekokoroku tauna ena ruma ia veria diho noho,  
\q1 to vabu ena tano do ia naria namo herea.   
\b  
\q1
\v 26 Lohiabada ese kara dika taudia edia laloa gaudia,  
\q1 be ia badu henia noho,  
\q1 to laloa maoromaoro taudia edia hereva,  
\q1 be Lohiabada ese ia moalelaia noho.   
\b  
\q1
\v 27 Bema koikoi dekena amo moni oi abia neganai,  
\q1 oiemu famili taudia dekenai hekwakwanai do oi havaraia.  
\q1 Kara dika karaia totona moni do oi abia lasi,  
\q1 unai neganai do oi mauri daudau.   
\b  
\q1
\v 28 Kara maoromaoro taudia ese,  
\q1 haere idia henia neganai idia laloa namonamo guna.  
\q1 Kara dika taudia ese idia haere henia haraga,  
\q1 to kerere idia havaraia noho.   
\b  
\q1
\v 29 Lohiabada ese kara namo taudia edia guriguri  
\q1 be ia kamonai henia noho,  
\q1 to kara dika taudia edia noinoi,  
\q1 be ia kamonai henia lasi.   
\b  
\q1
\v 30 Iena vairana be mai kiri tauna ese,  
\q1 oi ia hamoalea noho,  
\q1 bona sivarai namodia ese,  
\q1 oiemu lalona ena mamina do ia hanamoa.   
\b  
\q1
\v 31 Bema sisiba hereva namona do oi kamonai henia neganai,  
\q1 oi be aonega oi davaria unai.   
\b  
\q1
\v 32 Matakani ia abia dae lasi tauna ese,  
\q1 sibona ena mauri ia negea noho,  
\q1 to sisiba hereva ia kamonai noho tauna ese,  
\q1 laloa kehoa ia davaria noho.   
\b  
\q1
\v 33 Lohiabada gari henia kara be aonega davaria dalana,  
\q1 bona manau kara ese matauraia kara ia hereaia noho.   
\b  
\c 16  
\q1
\v 1 Ita taunimanima ese palani ita karaia noho,  
\q1 to Dirava sibona ese iseda palani,  
\q1 ena anina ia havaraia noho.   
\b  
\q1
\v 2 Sedira do oi laloa oiemu kara ibounai be maoro,  
\q1 to Lohiabada ese oiemu laloa ibounai ia tahua noho.   
\b  
\q1
\v 3 Oi ura karaia gaudia ibounai totona,  
\q1 Lohiabada do oi noia,  
\q1 ia ese do ia hanamoa gwauraia,  
\q1 unai neganai oiemu palani ibounai  
\q1 edia anina do idia vara momokani.   
\b  
\q1
\v 4 Lohiabada ese gau ibounai ia karaia vadaeni,  
\q1 ta ta mai edia dokona.  
\q1 Kara dika taudia danu be ia ese ia karaia,  
\q1 edia dokona be, dika do idia davaria.   
\b  
\q1
\v 5 Hekokoroku taudia ibounai,  
\q1 be Lohiabada ese ia badu henidia momokani.  
\q1 Ia ese edia kerere davana dekena amo,  
\q1 heau mauri dalana ta do ia henidia lasi, lasi momokani.   
\b  
\q1
\v 6 Tau ta ena bogahisihisi kara bona abidadama kara dainai,  
\q1 Dirava ese iena kara dika do ia gwauatao,  
\q1 bona bema Lohiabada oi gari henia neganai,  
\q1 oi be kara dika dekena amo oi siri noho.   
\b  
\q1
\v 7 Bema oiemu kara ese Lohiabada idia hamoalea noho neganai,  
\q1 oi idia hadikaia gwauraia taudia,  
\q1 be Lohiabada ese oiemu turana do ia halaoa.   
\b  
\q1
\v 8 Bema tau ta be mai ena kohu maragina sibona,  
\q1 to mai ena kara maoromaoro danu, be namo.  
\q1 To bema tau ta be mai ena kohu bada herea,  
\q1 to mai kara kerere bona koikoi danu, be dika.   
\b  
\q1
\v 9 Tau ta ese iena kudouna lalonai,  
\q1 iena dala ia palania noho,  
\q1 to Lohiabada ese unai tau ena raka dalana,  
\q1 dekenai ia hakaua noho.   
\b  
\q1
\v 10 King ena hereva be mai siahu danu,  
\q1 Dirava ena siahu dekena amo.  
\q1 King ena kota hereva be idia kerere lasi.   
\b  
\q1
\v 11 Lohiabada ia ura gau edia bada,  
\q1 bona edia metau tohoa sikele,  
\q1 be do idia maoromaoro momokani.  
\q1 Hoihoi kara ibounai danu,  
\q1 ia ura be mai maoromaoro bona momokani danu.   
\b  
\q1
\v 12 King taudia ese kara dika idia badu henia noho,  
\q1 badina be basileia ta be kara maoromaoro dekena amo,  
\q1 do ia gini goada noho.   
\b  
\q1
\v 13 King ese hereva maoromaoro bona momokani ia ura henia noho.  
\q1 Ia ese hereva momokani tauna ia lalokau henia noho.   
\b  
\q1
\v 14 Aonega tauna ese,  
\q1 iena king do ia hamoalea noho be namo,  
\q1 badina bema king ia badu neganai,  
\q1 sedira tau ta do ia mase.   
\b  
\q1
\v 15 King ia moale neganai,  
\q1 iena taunimanima do idia mauri.  
\q1 King ena lalona namo,  
\q1 be laurabada neganai medu ia diho bamona.   
\b  
\q1
\v 16 Aonega ena namo ese,  
\q1 golo ena namo ia hereaia noho.  
\q1 Laloa kehoa ena namo ese,  
\q1 siliva ena namo ia hereaia noho.   
\b  
\q1
\v 17 Kara maoromaoro tauna ese,  
\q1 dika ia noho lasi dalana dekenai ia raka noho.  
\q1 Unai dainai oi raka lao noho dalana,  
\q1 be do oi naria namonamo,  
\q1 mauri do oi davaria totona.   
\b  
\q1
\v 18 Hekokoroku be hadikaia gabuna dekenai ia lao noho,  
\q1 bona sibona ia gwauraia bada tauna,  
\q1 be do ia moru momokani.   
\b  
\q1
\v 19 Ogogami taudia danu,  
\q1 mai manau danu do oi noho be namo,  
\q1 to hekokoroku taudia danu, idia dadia kohu do oi haria be dika.   
\b  
\q1
\v 20 Oiemu hadibaia tauna ena hereva do oi kamonai henia,  
\q1 vadaeni do oi kwalimu.  
\q1 Lohiabada do oi abidadama henia,  
\q1 vadaeni do oi moale.   
\b  
\q1
\v 21 Aonega tauna be taunimanima ese,  
\q1 laloa kehoa tauna idia gwauraia noho.  
\q1 Iena hereva be namo dainai,  
\q1 ia be hadibaia tauna namo herea.   
\b  
\q1
\v 22 Aonega be mauri davaria dalana, aonega tauna dekenai,  
\q1 to bema kavakava tauna oi hadibaia neganai,  
\q1 oiemu nega oi haorea kava.   
\b  
\q1
\v 23 Aonega tauna ena kudouna ese,  
\q1 iena hereva ia hamaoromaoroa noho,  
\q1 bona iena hereva ese,  
\q1 iena diba idia habadaia noho.   
\b  
\q1
\v 24 Hereva namodia mai bogahisihisi danu, be hani bamona,  
\q1 edia mamina be namo,  
\q1 lauma dekenai, bona tauanina dekenai danu.   
\b  
\q1
\v 25 Dala ta ia noho,  
\q1 sedira iena toana oi dekenai be maoro,  
\q1 to iena dokona be mase dekenai do ia lao.   
\b  
\q1
\v 26 Gaukara tauna be aniani ia laloa dainai,  
\q1 ia gaukara goada noho,  
\q1 badina ia ura iena hitolo do ia hanamoa.   
\b  
\q1
\v 27 Kara dika tauna ese,  
\q1 dika karaia dalana ia laloa noho,  
\q1 bona iena hereva be lahi,  
\q1 siahu bada gauna bamona.   
\b  
\q1
\v 28 Laloa kerere tauna ese heai ia havaraia noho,  
\q1 bona hadikaia hereva kava gwauraia tauna ese,  
\q1 turana korikori taudia edia turana dala ia hamakohia noho.   
\b  
\q1
\v 29 Dagedage tauna ese iena badibadinai tauna ia koia noho,  
\q1 bona dika ena dala dekenai ia hakaua noho.   
\b  
\q1
\v 30 Iena matana dekena amo,  
\q1 toa dikana ia karaia noho tauna,  
\q1 ese kerere do ia karaia dalana ia laloa noho.  
\q1 Ma iena bibina ia hakapua auka tauna ese,  
\q1 kara dika do ia havaraia noho.   
\b  
\q1
\v 31 Kara maoromaoro taudia edia mauri dinadia, be do idia momo,  
\q1 bona buruka taudia edia huina kurokuro, be matauraia gauna.   
\b  
\q1
\v 32 Haheauka tauna ese,  
\q1 tuari tauna goadana ia hereaia noho,  
\q1 bona ia sibona ena lalona ia biagua noho tauna,  
\q1 ese tuari dekenai hanua ia halusia tauna ia hereaia noho.   
\b  
\q1
\v 33 Edia dala diba totona taunimanima ese,  
\q1 laki gadara idia karaia noho,  
\q1 to Dirava sibona ese edia dala ia havaraia noho.   
\b  
\c 17  
\q1
\v 1 Beredi kaukau mai maino danu do oi ania be namo,  
\q1 to aria badana mai heai bona hepapahuahu danu be dika.   
\b  
\q1
\v 2 Hesiai tauna mai ena aonega danu ese,  
\q1 ruma biaguna ena natuna, hemarai karadia ia karaia noho,  
\q1 do ia biagua.  
\q1 Unai hesiai tauna ese,  
\q1 iena biaguna ena ahuna do ia abia, tadikaka ta bamona.   
\b  
\q1
\v 3 Golo bona siliva be lahi ese,  
\q1 ia tohoa bona ia hagoevaia,  
\q1 bona tau ta ena kudouna be Lohiabada ese,  
\q1 ia tohoa bona ia hagoevaia noho.   
\b  
\q1
\v 4 Kara dika taudia ese,  
\q1 ma dika taudia haida edia laloa idia ura henia noho,  
\q1 bona koikoi taudia ese,  
\q1 hereva kerere gaudia idia kamonai henia noho.   
\b  
\q1
\v 5 Bema ogogami taudia oi kirikirilaia neganai,  
\q1 oi ese idia ia karaia Dirava danu oi kirikirilaia noho.  
\q1 Bema haida edia hisihisi dekenai oi kiri neganai,  
\q1 Dirava ese oi do ia matakani henia.   
\b  
\q1
\v 6 Tau buruka ese iena tubuna ia heagilaia noho.  
\q1 Memero danu ese edia tamadia dekenai idia heagi noho.   
\b  
\q1
\v 7 Hereva koikoi be hegeregere lasi king ena uduna dekena amo,  
\q1 ma hereva goeva danu be hegeregere lasi, kavakava tauna dekena amo.   
\b  
\q1
\v 8 Bema tau ta ese ma tau ta dekenai,  
\q1 lalona veria moni ia henia,  
\q1 kara dikana ta do ia karaia totona,  
\q1 unai moni ia henia tauna ia laloa,  
\q1 unai moni ese meamea bamona,  
\q1 iena ura gaudia ibounai do ia karaia.   
\b  
\q1
\v 9 Dika ia gwauatao tauna ese lalokau ia havaraia noho,  
\q1 to unai dika ia gwauraia loaloa tauna ese,  
\q1 turana dala ia hadikaia noho.   
\b  
\q1
\v 10 Sisiba hereva tamona ese,  
\q1 laloa kehoa tauna dekenai aonega bada ia henia noho,  
\q1 to kavakava tauna be nega 100 idia botaia neganai,  
\q1 aonega sisina sibona do ia davaria.   
\b  
\q1
\v 11 Kara dika tauna ese dagedage ia tahua noho.  
\q1 Unai dainai unai tau koua totona,  
\q1 bogahisihisi diba lasi tauna ta do idia siaia lao.   
\b  
\q1
\v 12 Bema oi ese bea hahine,  
\q1 iena natuna idia dadia vadaeni gauna do oi hedavari,  
\q1 unai be sisina dika.  
\q1 To kavakava tauna ese,  
\q1 kavakava kara ia karaia noho neganai,  
\q1 bema oi davaria, unai be dika momokani.   
\b  
\q1
\v 13 Bema oi ese dika do oi karaia,  
\q1 namo ena davana totona,  
\q1 unai neganai dika ese,  
\q1 oiemu ruma do ia rakatania lasi momokani.   
\b  
\q1
\v 14 Heai hamatamaia kara,  
\q1 be ranu bada gabuna ena magu makohia kara bamona.  
\q1 Unai dainai heai do ia vara lasi neganai,  
\q1 do oi raka siri.   
\b  
\q1
\v 15 Kara dika tauna ia gwauraia maoro tauna,  
\q1 bona kara maoromaoro tauna ia gwauraia dika tauna,  
\q1 unai tau ruaosi be Lohiabada ese ia badu henidia momokani.   
\b  
\q1
\v 16 Kavakava tauna ese,  
\q1 moni dekena amo diba do ia tahua be anina lasi.  
\q1 Namo ta do ia davaria lasi,  
\q1 badina be ia ese aonega ia ura henia lasi.   
\b  
\q1
\v 17 Tau ta ena turana ese ia lalokau henia noho,  
\q1 nega ibounai,  
\q1 bona nega dika ia vara neganai,  
\q1 oiemu tadikakana ese iena lalokau ia hedinaraia noho.   
\b  
\q1
\v 18 Laloa kehoa lasi tauna sibona ese do ia gwauhamata,  
\q1 tau ta ena abiatorehai davana do ia henia.   
\b  
\q1
\v 19 Kara dika ia ura henia noho tauna ese,  
\q1 heai danu ia ura henia noho.  
\q1 Bema nega ibounai mai hekokoroku danu hereva oi gwauraia neganai,  
\q1 oi ese dika bada oi tahua noho.   
\b  
\q1
\v 20 Iena lalona ia gagevagageva tauna,  
\q1 be iena gaukara ena anina ia vara noho lasi.  
\q1 Iena malana ese koikoi ia gwauraia tauna,  
\q1 ese kerere do ia davaria.   
\b  
\q1
\v 21 Kavakava merona ese iena tamana ena lalona ia hisihisi henia noho.  
\q1 Laloa kehoa lasi merona ena tamana be ia moale lasi.   
\b  
\q1
\v 22 Iena kudouna ia moale tauna ese namo ia havaraia noho,  
\q1 muramura namona bamona,  
\q1 to laloa metau tauna ese turia dika gorere ia havaraia noho.   
\b  
\q1
\v 23 Kota biaguna dikana ese,  
\q1 lalona veria moni ia abia hunia dekenai,  
\q1 ia ese kota maoromaorona do ia karaia lasi totona.   
\b  
\q1
\v 24 Laloa kehoa tauna ese aonega karadia edia dala ia tahua noho,  
\q1 to kavakava tauna be dala idauidau momo ia laloa noho,  
\q1 ia davaria diba lasi gaudia ia tahua noho.   
\b  
\q1
\v 25 Kavakava merona ese,  
\q1 iena tamana ena lalona ia hisihisi henia noho,  
\q1 bona ia ese ia havaraia hahine,  
\q1 ena lalona ia hadikaia noho.   
\b  
\q1
\v 26 Kara maoromaoro tauna idia panisia kara be namo lasi.  
\q1 Bema tau namona idia dadabaia,  
\q1 kota maoromaorona idia hadikaia unai.   
\b  
\q1
\v 27 Aonega tauna ese hereva momo ia gwauraia noho lasi,  
\q1 bona ia badu haraga lasi tauna,  
\q1 be mai ena lalona kehoa.   
\b  
\q1
\v 28 Kavakava tauna bema ia hereva lasi neganai,  
\q1 taunimanima do idia laloa ia be aonega tauna.  
\q1 Bema iena uduna ia hakapua neganai,  
\q1 do idia gwau ia be mai lalona tauna.   
\b  
\c 18  
\q1
\v 1 Ia sibona ia noho, turana lasi tauna,  
\q1 ese sibona ena ura mo ia tahua noho.  
\q1 Ia ese taunimanima haida edia laloa namodia ia ura lasi.   
\b  
\q1
\v 2 Kavakava tauna ese laloa kehoa ia moalelaia lasi,  
\q1 to ia ura ia sibona ena laloa do ia gwauraia,  
\q1 mai hekokoroku danu.   
\b  
\q1
\v 3 Kara dika ese hemarai ia havaraia noho,  
\q1 bona bema hemarai karadia oi karaia neganai,  
\q1 taunimanima ese oi do idia negea.   
\b  
\q1
\v 4 Aonega tauna ena hereva be momokani,  
\q1 bona laloa namodia dekenai idia honu,  
\q1 ranu dobudia idia honu neganai idia lohilohi,  
\q1 bona idia heau goada noho bamona.   
\b  
\q1
\v 5 Kara dika tauna do oi gwauraia namo be dika,  
\q1 bona kerere lasi tauna do oi gwauraia kerere,  
\q1 unai danu be dika.   
\b  
\q1
\v 6 Kavakava tauna ena hereva ese heai idia havaraia noho.  
\q1 Iena hereva dainai taunimanima do idia toreisi,  
\q1 bona botaia auna ena hisihisi do ia davaria.   
\b  
\q1
\v 7 Kavakava tauna ena uduna ese ia do ia hadikaia,  
\q1 bona iena bibina ena hereva,  
\q1 be iena lauma ena tarapu gauna.   
\b  
\q1
\v 8 Anina lasi kiki,  
\q1 tau ta ena ladana hadikaia totona,  
\q1 be ita ura bada, ani?  
\q1 Ia be mamina namo aniani bamona,  
\q1 bona ita ania haraga noho, ani?   
\b  
\q1
\v 9 Gaukara dekenai ia lahedo tauna,  
\q1 be gau namodia ia hadikaia noho tauna hegeregerena.   
\q1
\v 10 Lohiabada be kohoro goadana hegeregerena.  
\q1 Kara maoromaoro taudia be unuseni do idia heau vareai,  
\q1 bona do idia mauri noho.   
\b  
\q1
\v 11 Kohu momo tauna ena kohu bona moni,  
\q1 be hanua aukana hegeregerena ia dekenai,  
\q1 bona ia laloa idia be magu badana bamona,  
\q1 idia ese ia idia gimaia noho.   
\b  
\q1
\v 12 Bema oi be manau neganai, taunimanima ese oi do idia hanamoa,  
\q1 to hekokoroku taudia edia dokona dekenai,  
\q1 dika momokani do idia davaria.   
\b  
\q1
\v 13 Hereva do oi kamonai guna,  
\q1 gabeai do oi haere.  
\q1 Bema oi haere haraga,  
\q1 oi be kavakava, bona hemarai do oi davaria.   
\b  
\q1
\v 14 Tau ta do ia gorere neganai,  
\q1 do ia haheauka diba,  
\q1 to iena lauma ena goada ia ore neganai,  
\q1 tau be edena bamona do ia haheauka diba?   
\b  
\q1
\v 15 Lalona kehoa tauna ese,  
\q1 nega ibounai diba ia davaria noho.  
\q1 Aonega tauna ese,  
\q1 danu nega ibounai diba ia tahua noho.   
\b  
\q1
\v 16 Oi ura lohia tauna badana ta danu do oi hedavari?  
\q1 Harihari gauna ta do oi henia,  
\q1 vadaeni unai tau do oi davaria haraga.   
\b  
\q1
\v 17 Kota lalonai hereva ia gwauraia tauna ginigunana,  
\q1 ena hereva ena mamina be momokani,  
\q1 vadaeni idia laloa inai hereva be ia uini.  
\q1 To gabeai tau ta ma ese ia tahua neganai,  
\q1 unai hereva ena mamina be idau,  
\q1 vadaeni idia diba lasi daika ia uini.   
\b  
\q1
\v 18 Bema goada taudia rua ese idia kota neganai,  
\q1 laki gadara dekena amo unai kota idia hamaoromaoroa diba.   
\b  
\q1
\v 19 Oiemu tadikakana do oi durua,  
\q1 vadaeni ia ese oi do ia gimaia,  
\q1 hanua ena magu aukana bamona.  
\q1 To bema oiemu tadikakana oi habadua neganai,  
\q1 emui turana kara do umui hamatamaia lou dalana be auka.   
\b  
\q1
\v 20 Mai aonega danu sisiba oi henia neganai,  
\q1 oiemu lalona ese goada ia abia noho,  
\q1 bona unai sisiba ena anina ia vara neganai,  
\q1 oi be do oi moale.   
\b  
\q1
\v 21 Oiemu hereva ese mauri ia henia diba,  
\q1 bona mase ia mailaia diba.  
\q1 Oiemu hereva ese idia havaraia gaudia,  
\q1 be oi dekenai lalohisihisi o moale do idia henia.   
\b  
\q1
\v 22 Hahine do ia adavaia tauna ese,  
\q1 gau namona ia davaria inai.  
\q1 Lohiabada ese unai tau do ia hanamoa.   
\b  
\q1
\v 23 Ogogami tauna ese mai manau danu ia noinoi noho,  
\q1 to kohu momo tauna ese,  
\q1 mai hereva aukadia danu ia haere henia noho.   
\b  
\q1
\v 24 Turana haida be turana koikoi taudia sibona,  
\q1 to turana ta ia noho, iena turana kara,  
\q1 ese tadikaka ta ena lalokau ia hereaia noho.   
\b  
\c 19  
\q1
\v 1 Oi be ogogami tauna,  
\q1 to mai oiemu kara maoromaoro be namo.  
\q1 Oi be kohu momo tauna,  
\q1 to mai oiemu kavakava bona hereva koikoi be dika.   
\b  
\q1
\v 2 Tau ta mai ena ura bada,  
\q1 to mai ena aonega lasi, be namo lasi.  
\q1 Ia haheauka lasi, to ia kara haraga kava tauna,  
\q1 be do ia kerere.   
\b  
\q1
\v 3 Taunimanima haida be sibodia edia kavakava,  
\q1 ese idia ia hakererea.  
\q1 Unai neganai idia ese Lohiabada idia badu henia noho.   
\b  
\q1
\v 4 Kohu momo tauna ese turana momo ia davaria noho,  
\q1 to ogogami tauna be iena turana ese,  
\q1 idia rakatania noho.   
\b  
\q1
\v 5 Kota lalonai hereva gwauraia koikoi tauna,  
\q1 be do idia panisia momokani,  
\q1 bona hereva koikoi tauna be do ia heau mauri diba lasi.   
\b  
\q1
\v 6 Lohia tauna badana be taunimanima momo ese,  
\q1 ia dekenai idia noinoi henia noho,  
\q1 bona harihari gaudia momo ia henia noho tauna be,  
\q1 taunimanima momo ese ia dekenai idia turana karaia noho.   
\b  
\q1
\v 7 Ogogami tauna be iena tadikakana ibounai ese,  
\q1 idia ura henia lasi momokani.  
\q1 Unai tau ena turana danu be lasi momokani.  
\q1 Idia rakatania neganai ia boiboi henidia,  
\q1 to idia mai lasi.   
\b  
\q1
\v 8 Aonega ia abia vadaeni tauna ese,  
\q1 sibona ena lauma ia ura henia noho.  
\q1 Laloa kehoa ia dogoatao noho tauna ese,  
\q1 noho namo do ia davaria.   
\b  
\q1
\v 9 Kota lalonai hereva gwauraia koikoi tauna,  
\q1 be do idia panisia momokani.  
\q1 Hereva koikoi tauna be do ia mase ore.   
\b  
\q1
\v 10 Kavakava tauna do ia noho namo,  
\q1 mai kohu momo danu be hegeregere lasi,  
\q1 bona hesiai tauna ese lohia do ia biagua,  
\q1 be hegeregere lasi momokani.   
\b  
\q1
\v 11 Tau ta ena aonega ese haheauka ia henia noho,  
\q1 vadaeni ia badu haraga lasi.  
\q1 Bema tau ta ese oi dekenai ia kara dika,  
\q1 do oi laloaboio be kara namona momokani.   
\b  
\q1
\v 12 King ena badu be laiona ena boiboi bamona,  
\q1 to iena lalona namona be medu namo herea bamona.   
\b  
\q1
\v 13 Kavakava merona ese iena tamana ia hadikaia ore diba,  
\q1 bona tau ena hahine ese ia hepapahuahu henia noho,  
\q1 be ranu ia diho noho sisina sisina nega ibounai,  
\q1 doko lasi, bamona.   
\b  
\q1
\v 14 Tamana ese iena natuna tau dekenai,  
\q1 ruma bona kohu ia henia diba,  
\q1 to Lohiabada sibona ese,  
\q1 unai mero dekenai hahine mai aonegana ta ia henia diba.   
\b  
\q1
\v 15 Lahedo tauna be do ia mahuta mase,  
\q1 bona lahedo tauna be do ia hitolo.   
\b  
\q1
\v 16 Dirava ena taravatu do oi badinaia,  
\q1 vadaeni mauri do oi davaria.  
\q1 To bema Dirava ena taravatu oi laloa lasi,  
\q1 oi be do oi mase.   
\b  
\q1
\v 17 Bema ogogami taudia dekenai oi bogahisihisi henia neganai,  
\q1 oi ese Lohiabada dekenai oi heniatorehai noho.  
\q1 Lohiabada ese unai davana oi dekenai do ia henia lou.   
\b  
\q1
\v 18 Oiemu natuna idia maragi neganai,  
\q1 do oi matakani henidia.  
\q1 Bema unai bamona oi karaia lasi,  
\q1 idia sibodia ese edia mauri do idia hadikaia ore,  
\q1 bona unai dala be oi ese oi durua unai.   
\b  
\q1
\v 19 Badu dikadika tauna ese,  
\q1 sibona ena kerere davana do ia abia be namo,  
\q1 badina bema nega ta kerere dekena amo oi hamauria,  
\q1 oi ese ma nega momo do oi karaia lou.   
\b  
\q1
\v 20 Bema oi ura bada diba do oi abia,  
\q1 bona sisiba oi kamonai henia noho neganai,  
\q1 oi ese dina ta aonega do oi davaria.   
\b  
\q1
\v 21 Taunimanima ese palani momo idia karaia noho,  
\q1 to Lohiabada ena ura sibona do ia vara.   
\b  
\q1
\v 22 Taunimanima edia lalona dekenai,  
\q1 ita ura henia bada kara, be bogahisihisi.  
\q1 Ogogami tauna ena namo,  
\q1 ese koikoi tauna ena namo ia hereaia noho.   
\b  
\q1
\v 23 Lohiabada do oi gari henia,  
\q1 vadaeni mauri do oi davaria.  
\q1 Unai neganai oiemu lalona do ia namo,  
\q1 bona dika ta oi dekenai do ia ginidae lasi.   
\b  
\q1
\v 24 Taunimanima haida be lahedo momo dainai,  
\q1 sibodia edia uduna dekenai aniani idia atoa lasi.   
\b  
\q1
\v 25 Hekokoroku tauna do umui panisia,  
\q1 unai neganai diba maragi taudia ese diba do idia davaria.  
\q1 Laloa kehoa tauna do oi sisiba henia,  
\q1 vadaeni iena aonega do ia habadaia.   
\b  
\q1
\v 26 Iena tamana ia dagedage henia,  
\q1 bona iena sinana ia lulua noho merona,  
\q1 ese hemarai bona dika ia havaraia noho.   
\b  
\q1
\v 27 Egu natuna e,  
\q1 bema hadibaia hereva kamonai henia kara oi hadokoa neganai,  
\q1 oi ese aonega hereva dekena amo do oi raka siri.   
\b  
\q1
\v 28 Bema hereva gwauraia tauna ese,  
\q1 hereva gagevagageva ia gwauraia neganai,  
\q1 kota maoromaorona do ia hadikaia.  
\q1 Dika taudia ese,  
\q1 dika ena mamina idia ura henia noho.   
\b  
\q1
\v 29 Hekokoroku taudia ese edia kerere davana do idia davaria,  
\q1 bona kavakava taudia be do idia dadabaia.   
\c 20  
\b  
\q1
\v 1 Uaina bona kekero muramura ese,  
\q1 kerere bona heai idia havaraia noho.  
\q1 Inua kekero ese ia hakaua kerere taudia be kavakava.   
\b  
\q1
\v 2 King ena badu do oi gari henia,  
\q1 ia boiboi noho laiona dekenai oi gari henia hegeregerena.  
\q1 Bema oi habadua neganai, oiemu mauri be ia ore.   
\b  
\q1
\v 3 Heatu dekena amo ia raka siri tauna be do idia matauraia noho,  
\q1 to kavakava taudia ibounai do idia heai noho.   
\b  
\q1
\v 4 Bema lahedo tauna ese,  
\q1 hadoa nega korikori dekenai iena tano ia hadoa lasi neganai,  
\q1 anina haboua neganai ia be do ia tahua,  
\q1 to gau ta do ia davaria lasi.   
\b  
\q1
\v 5 Taunimanima edia laloa gaudia be hunia,  
\q1 ranu dobuna bamona,  
\q1 to mai ena diba bada tauna ese,  
\q1 unai laloa gaudia ia davaria diba.   
\b  
\q1
\v 6 Taunimanima momo ese,  
\q1 sibodia edia kara momokani bona lalokau idia gwauraia noho,  
\q1 to kara momokani bona lalokau momokani tauna,  
\q1 be daika ese do ia davaria diba?   
\b  
\q1
\v 7 Bema tamana ta be kara maoromaoro tauna,  
\q1 bona iena kara ibounai,  
\q1 be mai laloa maoromaoro danu ia karaia neganai,  
\q1 unai tau ena natuna taudia,  
\q1 be mai moale danu do idia noho.   
\b  
\q1
\v 8 King ese kota gabuna dekenai ia helai noho,  
\q1 bona iena matana ese dika ibounai idia itaia noho.   
\b  
\q1
\v 9 Daika do ia hereva diba, do ia gwau,  
\q1 “Egu lalona be ia maoromaoro noho,  
\q1 egu dika dekena amo lau be goeva vadaeni?”   
\b  
\q1
\v 10 Metau tohoa sikele koikoidia, bona bada tohoa gaudia koikoidia,  
\q1 idia ruaosi idia gaukaralaia taudia dekenai,  
\q1 Lohiabada be ia badu momokani noho.   
\b  
\q1
\v 11 Mero maragina ese iena kara dekena amo,  
\q1 sibona ena mauri ia hedinaraia noho.  
\q1 Iena kara dekena amo do oi diba,  
\q1 unai mero ia goeva bona ia maoro, o lasi.   
\b  
\q1
\v 12 Ia kamonai noho taiana,  
\q1 bona ia itaia noho matana,  
\q1 be Lohiabada ese idia ruaosi ia karaia vadaeni.   
\b  
\q1
\v 13 Mahuta do oi ura henia lasi,  
\q1 do oi ogogami garina.  
\q1 Oiemu matana do oi kehoa,  
\q1 bona aniani hegeregerena do oi davaria.   
\b  
\q1
\v 14 Gau ia hoia mai tauna ese,  
\q1 inai bamona ia gwau noho,  
\q1 “Inai be dika, inai be dika.”  
\q1 Gabeai ia raka lao,  
\q1 bona ia hoia gauna ia herevalaia mai hekokoroku danu.   
\b  
\q1
\v 15 Bema oi herevalaia gauna ena anina oi diba momokani,  
\q1 inai diba ena namo ese,  
\q1 golo bona davana bada nadi edia namo ia hereaia noho.   
\b  
\q1
\v 16 Bema tau ta ese,  
\q1 idau tauna ena abiatorehai totona gwauhamata ia karaia neganai,  
\q1 unai tau ena kouti,  
\q1 be gwauhamata toana totona do oi abia.  
\q1 Bona bema ia ese idau bese tauna totona,  
\q1 unai bamona gwauhamata ia karaia neganai,  
\q1 unai tau ena gau namona ta be do oi dogoatao momokani.   
\b  
\q1
\v 17 Koikoi dekena amo ia abia aniani ena mamina be namo,  
\q1 ia abia tauna ena uduna lalonai,  
\q1 to gabeai iena uduna be miri dekenai do ia honu.   
\b  
\q1
\v 18 Bema kara ta ena palani oi karaia neganai,  
\q1 sisiba namona do oi abia guna,  
\q1 bona tuari do oi karaia gwauraia neganai,  
\q1 sisiba namona do oi tahua guna.   
\b  
\q1
\v 19 Taunimanima hadikaia totona hereva ia gwauraia tauna ese,  
\q1 hunia herevadia ia hunia lasi,  
\q1 to ia gwauraia hedinarai.  
\q1 Unai dainai hereva kavakava ia gwauraia noho tauna danu,  
\q1 do oi turana karaia lasi.   
\b  
\q1
\v 20 Bema oiemu tamana bona sinana oi hereva dika henia neganai,  
\q1 oiemu mauri be do ia doko,  
\q1 dibura lalonai lamepa ia bodo bamona.   
\b  
\q1
\v 21 Bema tau ta ena tamana sinana burukadia do mauri noho neganai,  
\q1 ia ese edia kohu momo ia abia haraga neganai,  
\q1 dokona dekenai unai kara ena anina namona do ia vara lasi,  
\q1 badina Dirava ese unai kohu do ia hanamoa lasi.   
\b  
\q1
\v 22 Tau ta ena kara dika davana do oi henia lasi,  
\q1 to Lohiabada do oi abidadama henia,  
\q1 ia ese unai kara do ia hamaoromaoroa.   
\b  
\q1
\v 23 Metau tohoa sikele koikoidia bona bada tohoa gaudia koikoidia,  
\q1 idia ruaosi idia gaukaralaia taudia dekenai,  
\q1 Lohiabada be ia badu momokani noho.   
\b  
\q1
\v 24 Iseda raka be Lohiabada ese ia hakaua bona naria noho.  
\q1 Unai dainai edena bamona ita sibona ese,  
\q1 iseda mauri ena dala do ita diba?   
\b  
\q1
\v 25 Bema gau ta Lohiabada dekenai do oi henia,  
\q1 ena gwauhamata do oi karaia gwauraia neganai,  
\q1 do oi laloa namonamo guna.  
\q1 Gabeai, bema oi karaia lasi neganai,  
\q1 sedira oiemu lalona be do ia hisihisi.   
\b  
\q1
\v 26 King mai ena aonega ese,  
\q1 dika taudia do ia tahua bona davaria,  
\q1 bona ia ese edia dika ena davana,  
\q1 do ia henia momokani.   
\b  
\q1
\v 27 Lohiabada ena lamepa ese taunimanima edia laumadia ia tahua noho,  
\q1 bona tau ta ese iena lalona ia hunia diba lasi.   
\b  
\q1
\v 28 Bema mai lalokau, kota maoromaoro, bona kara momokani danu,  
\q1 iena basileia ia naria noho neganai,  
\q1 king ese iena king siahuna do ia dogoatao noho,  
\q1 ela bona nega daudau.   
\b  
\q1
\v 29 Eregabe taudia edia hairaina be edia goada.  
\q1 To buruka taudia edia hairaina be edia huina kurokuro.   
\b  
\q1
\v 30 Kwadia bona bero ese dika idia huria ore noho.  
\q1 Idia dadabaia vadaeni taudia edia lalodia be do idia goeva.   
\b  
\c 21  
\q1
\v 1 Lohiabada ese king ena lalona ia biagua noho,  
\q1 Lohiabada ese ia hakaua noho,  
\q1 ia ese sinavai ena ranu ia haheaua noho hegeregerena.   
\b  
\q1
\v 2 Sedira oi laloa oiemu dala ibounai be idia maoro noho,  
\q1 to Lohiabada ese oiemu lalona gaudia ia tohoa noho.   
\b  
\q1
\v 3 Kara maoromaoro bona momokani do oi karaia.  
\q1 Lohiabada ese unai kara ia ura henia bada noho,  
\q1 to boubou gaudia ia ura henia sisina.   
\b  
\q1
\v 4 Kara dika taudia ese sibodia idia habadaia noho,  
\q1 bona inai edia hekokoroku ese,  
\q1 edia kara ia biagua noho.  
\q1 Inai be kara dika.   
\b  
\q1
\v 5 Mai haheauka danu ia gaukara noho tauna ena laloa,  
\q1 ese anina ia havaraia bada noho,  
\q1 to laloa haraga taudia be do idia ogogami.   
\b  
\q1
\v 6 Hereva koikoi dekena amo oi abia kohu momo,  
\q1 be do idia boio haraga,  
\q1 bona idia ese mase ena tarapu dekenai,  
\q1 oi do idia hakaua.   
\b  
\q1
\v 7 Kara dika taudia edia dagedage ese do ia hadikadia,  
\q1 badina idia ura lasi momokani kara maoromaoro do idia karaia.   
\b  
\q1
\v 8 Kerere tauna ena dala be gagevagageva,  
\q1 to laloa maoromaoro tauna ena kara be maoromaoro.   
\b  
\q1
\v 9 Ruma ena guhi dekenai do oi noho be namo,  
\q1 to hereva momo hahine danu,  
\q1 ruma lalonai oi noho be dika.   
\b  
\q1
\v 10 Kara dika tauna ena lauma ese,  
\q1 dika ia ura henia noho,  
\q1 bona ia ese iena badibadinai ia noho tauna,  
\q1 do ia bogahisihisi henia lasi.   
\b  
\q1
\v 11 Hekokoroku tauna idia panisia neganai,  
\q1 diba maragi tauna ese aonega ia abia noho.  
\q1 Aonega tauna idia hadibaia neganai,  
\q1 ia ese iena lalona kehoa ia habadaia noho.   
\b  
\q1
\v 12 Kara maoromaoro ena Dirava ese,  
\q1 kara dika tauna ena ruma dekenai idia vara karadia ia itaia,  
\q1 bona ia laloa noho,  
\q1 bona Dirava ese unai dika tauna ena dika dainai,  
\q1 do ia hadikaia ore.   
\b  
\q1
\v 13 Bema oi ese ogogami taudia edia taitai,  
\q1 be oi kamonai henia lasi neganai,  
\q1 oi sibona do oi tai neganai,  
\q1 tau ta do ia kamonai henia lasi.   
\b  
\q1
\v 14 Bema tau ta oi dekenai ia badu neganai,  
\q1 harihari gauna, hunia dekenai do oi henia,  
\q1 bona iena badu do ia keru,  
\q1 bona lalona veria moni hunia dekenai oi henia,  
\q1 ese iena badu aukana do ia hadokoa.   
\b  
\q1
\v 15 Kota maoromaoro ese kara maoromaoro taudia ia hamoalea noho,  
\q1 to kota maoromaorona dekenai,  
\q1 kara dika taudia idia gari dikadika noho.   
\b  
\q1
\v 16 Laloa kehoa ena dala ia rakatania tauna ese,  
\q1 mase taudia edia hebou dekenai do ia noho.   
\b  
\q1
\v 17 Moale kava ia ura henia tauna be do ia ogogami,  
\q1 bona uaina bona davana bada aniani,  
\q1 ia ura bada herea tauna,  
\q1 be kohu momo tauna do ia lao lasi.   
\b  
\q1
\v 18 Kara dika taudia ese,  
\q1 kara namo taudia idia hisihisi henidia noho,  
\q1 to unai idia henia noho hisihisi be Dirava ese,  
\q1 unai kara dika taudia dekenai ma do ia henidia.   
\b  
\q1
\v 19 Taunimanima idia noho lasi tano dekenai,  
\q1 do oi noho be namo,  
\q1 to ia hereva momo bona ia maumau noho hahine,  
\q1 danu do oi noho be dika.   
\b  
\q1
\v 20 Aonega tauna ena ruma lalonai,  
\q1 be aniani momo bona dehoro danu idia noho,  
\q1 to kavakava tauna ese iena gau ibounai,  
\q1 ia haorea kava noho.   
\b  
\q1
\v 21 Kara maoromaoro bona bogahisihisi kara do oi karaia neganai,  
\q1 oiemu mauri dinadia be do idia momo,  
\q1 bona taunimanima ese noho namo,  
\q1 kara maoromaoro bona matauraia oi dekenai do idia henia.   
\b  
\q1
\v 22 Tuari biaguna mai aonega danu ese,  
\q1 goada taudia edia hanua ia halusia diba.  
\q1 Edia ruma aukana,  
\q1 idia abidadama henia noho gauna ia veria diho diba.   
\b  
\q1
\v 23 Iena hereva ia naria namonamo tauna be,  
\q1 hekwakwanai bona kerere do ia davaria lasi.   
\b  
\q1
\v 24 Ia sibona ia gwauraia bada tauna be mai hekokoroku,  
\q1 ia be mai heagi bada,  
\q1 bona ia ese haida ia hereva dika henia,  
\q1 ma idia ia kirikirilaia.   
\b  
\q1
\v 25 Lahedo tauna ena ura ese ia hamasea noho,  
\q1 badina be ia ura lasi gaukara do ia karaia.   
\b  
\q1
\v 26 Lahedo tauna be nega ibounai gau momo,  
\q1 ia ura dikadika kava noho.  
\q1 To kara maoromaoro tauna ese,  
\q1 gau be taunimanima dekenai ia henia diba,  
\q1 bona ia ese mai lalokau danu ia henia noho.   
\b  
\q1
\v 27 Kara dika taudia edia boubou,  
\q1 be Lohiabada ia ura henia lasi,  
\q1 badina idia ese unai bamona idia karaia,  
\q1 edia ura dikadia do idia vara totona.   
\b  
\q1
\v 28 Kota hereva ia gwauraia hedinarai koikoi tauna,  
\q1 be do ia mase,  
\q1 to Dirava ia kamonai henia noho tauna ena hereva,  
\q1 be nega ibounai do ia momokani.   
\b  
\q1
\v 29 Kara dika tauna be mai laloa auka,  
\q1 sibona ena ura ia karaia noho,  
\q1 to kara maoromaoro tauna ese,  
\q1 Dirava ena dala ia badinaia noho.   
\b  
\q1
\v 30 Taunimanima edia aonega, edia laloa kehoa,  
\q1 bona edia laloa ese,  
\q1 Lohiabada ena ura do idia koua diba lasi,  
\q1 lasi momokani.   
\b  
\q1
\v 31 Tuari totona hosi umui abia hegaegae diba,  
\q1 to Lohiabada sibona ese kwalimu ia henia noho.   
\b  
\c 22  
\q1
\v 1 Ladana namona tauna ese,  
\q1 kohu momo tauna ia hereaia noho.  
\q1 Bema ladana namo bona kohu momo ruaosi,  
\q1 edia huanai ta oi abia hidi neganai,  
\q1 ladana namona do oi abia hidi.   
\b  
\q1
\v 2 Kohu momo tauna bona ogogami tauna,  
\q1 be dala ta dekenai edia mauri be tamona.  
\q1 Gauna be inai: Lohiabada ese idia ruaosi ia karaia.   
\b  
\q1
\v 3 Aonega tauna ese dika ia itaia noho,  
\q1 bona unai dika dekena amo ia raka siri,  
\q1 to aonega lasi tauna,  
\q1 be unai dika dekenai do ia raka lao,  
\q1 bona gabeai hisihisi do ia davaria.   
\b  
\q1
\v 4 Lohiabada do oi gari henia,  
\q1 bona do oi manau.  
\q1 Inai bamona oi karaia neganai,  
\q1 kohu, bona matauraia, bona mauri do oi davaria.   
\b  
\q1
\v 5 Tau dikana ena mauri dalana dekenai be hekwakwanai,  
\q1 bona tarapu idia noho,  
\q1 to iena lauma ia naria noho tauna,  
\q1 be unai gaudia dekena amo ia raka siri noho.   
\b  
\q1
\v 6 Mero dekenai mauri dala maorona do oi hadibaia,  
\q1 vadaeni ia buruka neganai,  
\q1 unai dala do ia rakatania lasi.   
\b  
\q1
\v 7 Kohu momo tauna ese ogogami tauna ia biagua noho,  
\q1 bona moni ia abiatorehai tauna ese,  
\q1 heniatorehai tauna ena hesiai gaukara ia karaia noho.   
\b  
\q1
\v 8 Kara kerere ia hadoa tauna ese,  
\q1 ena anina, dika momokani, do ia davaria,  
\q1 bona ia ese taunimanima ia dagedage henia vadaeni dainai,  
\q1 Dirava ese ia do ia hadikaia ore.   
\b  
\q1
\v 9 Gau bona aniani be ogogami taudia dekenai do oi henia,  
\q1 badina Dirava ese,  
\q1 unai bamona idia karaia taudia do ia hanamoa.   
\b  
\q1
\v 10 Hekokoroku tauna,  
\q1 hereva dika ia gwauraia noho tauna,  
\q1 be do umui lulua siri,  
\q1 vadaeni heai do ia ore,  
\q1 heatu, bona ladana hadikaia hereva, danu do idia doko.   
\b  
\q1
\v 11 Bema laloa goevagoeva oi ura henia,  
\q1 bona oi hereva manada neganai,  
\q1 oi be king ena turana do oi lao.   
\b  
\q1
\v 12 Lohiabada ese aonega hereva ia itaia noho,  
\q1 bona ia durua noho,  
\q1 to koikoi taudia edia hereva ia koua noho.   
\b  
\q1
\v 13 Lahedo tauna be ruma dekenai ia helai noho.  
\q1 Ia gwau, “Bema murimurina dekenai lau lao neganai,  
\q1 laiona ta ese lau do ia alaia mase.”   
\b  
\q1
\v 14 Heudahanai kara be tarapu dobuna bamona.  
\q1 Lohiabada ese ia badu henia noho taudia,  
\q1 be unai tarapu lalonai do idia moru momokani.   
\b  
\q1
\v 15 Natuna maragidia ibounai ese kavakava idia karaia noho,  
\q1 to emu natuna oi kwadia neganai,  
\q1 inai kavakava kara do ia rakatania momokani.   
\b  
\q1
\v 16 Bema ogogami taudia oi dagedage henia,  
\q1 oi sibona kohu momo do oi abia totona,  
\q1 o bema kohu momo taudia dekenai,  
\q1 harihari gaudia oi henia neganai,  
\q1 oi sibona be do oi ogogami.   
\s1 Aonega tauna ena hereva  
\q1
\v 17 Oiemu taiana do oi kehoa,  
\q1 aonega taudia edia hereva do oi kamonai.  
\q1 Edia hadibaia hereva oiemu kudouna dekenai do oi abia dae.   
\q1
\v 18 Badina bema emu kudouna lalonai inai hereva oi dogoatao,  
\q1 bona idia oi gwauraia diba neganai,  
\q1 lalo namo do oi davaria.   
\q1
\v 19 Lau ura oi ese Lohiabada do oi abidadama henia.  
\q1 Unai dainai hari dina,  
\q1 inai hereva oi dekenai lau hadibaia noho.   
\q1
\v 20 Sisiba bona aonega hereva ibounai 30,  
\q1 be oi dekenai lau torea vadaeni,   
\q1
\v 21 bona idia ese kara maoromaoro bona kara momokani,  
\q1 oi dekenai do idia hadibaia.  
\q1 Vadaeni oi ia siaia tauna dekenai oi giroa lou neganai,  
\q1 haere maorodia do oi henia.   
\q1
\v 22 Ogogami taudia dekena amo do oi henaoa lasi,  
\q1 badina idia be ogogami,  
\q1 bona gau lasi taudia be kota lalonai,  
\q1 do oi hadikadia ore lasi.   
\q1
\v 23 Badina be Lohiabada ese edia kota hereva do ia durua,  
\q1 bona edia kohu ia henaoa tauna do ia alaia mase.   
\b  
\q1
\v 24 Badu haraga tauna danu do oi turana karaia lasi,  
\q1 bona dagedage tauna danu do oi noho lasi,   
\q1
\v 25 edia dala dekenai do oi manada garina,  
\q1 bona idia be tarapu oi dekenai garina.   
\b  
\q1
\v 26 Tau ta ena abiatorehai henia lou gwauhamata, be do oi karaia lasi,   
\q1
\v 27 badina be bema unai moni oi henia lasi neganai,  
\q1 oiemu mahuta patana do idia abia lao.   
\b  
\q1
\v 28 Tano ena hetoana gunana,  
\q1 oiemu sene taudia idia atoa gauna,  
\q1 be do oi kokia lao lasi.   
\b  
\q1
\v 29 Iena gaukara ia karaia namonamo tauna oi itaia noho, a?  
\q1 Ia ese taunimanima momo ia hereaia noho,  
\q1 bona ia ese king taudia edia vairana dekenai do ia gini.   
\b  
\c 23  
\q1
\v 1 King danu do umui aniani hebou neganai,  
\q1 oiemu vairana dekenai ia helai tauna ena dagi,  
\q1 be do oi laloa namonamo.   
\q1
\v 2 Bema oi be aniani ania bada tauna,  
\q1 inai kara do oi koua,  
\q1 metairametaira do oi aniani.   
\q1
\v 3 King ena aniani namodia do oi ura dikadika lasi,  
\q1 unai aniani ese oi do ia koia,  
\q1 bona king ia ura lasi kara do oi karaia garina.   
\b  
\q1
\v 4 Kohu momo abia totona do oi hekwarahi bada lasi.  
\q1 Bema oi be aonega, unai bamona do oi karaia lasi,   
\q1
\v 5 Badina kohu momo be do idia ore haraga diba,  
\q1 ugava manu ese ena hanina ia abia isi,  
\q1 bona ia roho lao haraga bamona.   
\b  
\q1
\v 6 Sibona ena gau ia dogoatao auka,  
\q1 ia ura lasi ia henia tauna,  
\q1 ena aniani do oi ania lasi.  
\q1 Iena aniani namodia do oi ura dikadika lasi.   
\q1
\v 7 Badina be ia ese,  
\q1 nega ibounai unai aniani ena davana ia laloa noho,  
\q1 ia gwau, “Do oi aniani, do oi inuinu.”  
\q1 To inai bamona ia ura lasi, ia koikoi noho.   
\q1
\v 8 Inai tau ena kara oi diba momokani neganai,  
\q1 oi ese oi ania vadaeni gaudia,  
\q1 be do oi mumuta negea,  
\q1 bona oiemu tanikiu hereva be do idia anina lasi.   
\b  
\q1
\v 9 Kavakava tauna ena vairana dekenai do oi hereva lasi,  
\q1 badina be oiemu aonega ena namo,  
\q1 be ia ese do ia davaria diba lasi.   
\b  
\q1
\v 10 Tano hetoana gunana do oi kokia lao lasi,  
\q1 bona tamana sinana lasi maragidia edia tano,  
\q1 be do oi abia lasi.   
\q1
\v 11 Badina Lohiabada be edia Hamauria Dirava mai siahuna,  
\q1 bona ia ese edia kota hereva do ia durua,  
\q1 oi do ia halusia totona.   
\b  
\q1
\v 12 Mai oiemu kudouna danu, hadibaia hereva do oi tahua,  
\q1 bona aonega hereva dekenai do oi kamonai namonamo.   
\b  
\q1
\v 13 Oi daradara lasi,  
\q1 to oiemu natuna do oi matakani henia.  
\q1 Au dekena amo do oi kwadia neganai,  
\q1 ia be do ia mase lasi.   
\q1
\v 14 Au dekena amo do oi kwadia,  
\q1 unai neganai oi ese oiemu natuna ena lauma,  
\q1 be mase dekena amo do oi hamauria.   
\b  
\q1
\v 15 Egu natuna tau e,  
\q1 bema oiemu kudouna be mai ena aonega,  
\q1 unai neganai egu lalona do ia moale.   
\q1
\v 16 Oi ese hereva maoromaoro do oi gwauraia neganai,  
\q1 egu laumana be do ia moale.   
\b  
\q1
\v 17 Oiemu kudouna ese,  
\q1 kara dika taudia do ia mama henidia lasi,  
\q1 to nega ibounai oi ese,  
\q1 Lohiabada do oi gari henia noho, mai momokani danu.   
\q1
\v 18 Bema inai bamona oi karaia neganai,  
\q1 oi ura davaria gau namodia,  
\q1 be Dirava ese oi dekenai do ia koua lasi.   
\b  
\q1
\v 19 Lauegu natuna e, egu sisiba do oi kamonai,  
\q1 vadaeni aonega do oi davaria.  
\q1 Mauri dala maorona do oi raka totona,  
\q1 do oi laloa namonamo.   
\q1
\v 20 Kekero muramura momo idia inua taudia,  
\q1 danu do oi inua hebou lasi,  
\q1 bona aniani idia ania momo taudia,  
\q1 danu do oi noho lasi.   
\q1
\v 21 Kekero taudia bona idia aniani momo taudia,  
\q1 be do idia ogogami,  
\q1 bona mahuta momo taudia,  
\q1 be momoru dabua do idia karaia.   
\b  
\q1
\v 22 Oiemu tamana, ia ese oi ia havaraia tauna,  
\q1 do oi kamonai henia,  
\q1 bona oiemu sinana ia buruka neganai do oi matauraia.   
\q1
\v 23 Hereva momokani do oi hoia mai,  
\q1 bona tau haida dekenai do oi hoia lao lasi.  
\q1 Aonega bona diba namona bona lalona kehoa,  
\q1 danu do oi hoia, do oi abia.   
\q1
\v 24 Kara maoromaoro tauna ena tamana,  
\q1 be do ia moale bada,  
\q1 bona bema iena natuna be mai aonega danu,  
\q1 unai tamana ese do ia moalelaia.   
\q1
\v 25 Oiemu tamana bona sinana do oi hamaoalea.  
\q1 Oi ia havaraia hahinena,  
\q1 be oi dekenai do ia moale bada be namo!   
\b  
\q1
\v 26 Lauegu natuna e, lauegu hereva do oi kamonai,  
\q1 bona lauegu dala do oi raka,  
\q1 mai oiemu kudouna ibounai danu.   
\q1
\v 27 Badina be ariara hahine be tarapu,  
\q1 mase gauna bamona,  
\q1 bona lebulebu hahine be guri dobuna bamona.   
\q1
\v 28 Idia ese dadidadi taudia bamona,  
\q1 hunia dekenai idia naria,  
\q1 bona tatau momo idia hakaua kerere,  
\q1 edia adavana idia koia noho.   
\b  
\q1
\v 29 Daika ia laloa metau noho?  
\q1 Daika be lalohisihisi noho?  
\q1 Daika be ia heai kava noho?  
\q1 Daika be ia laloa hekwarahi noho?  
\q1 Daika be ia bero kava, bero kava noho?  
\q1 Daika be iena matana idia kakakaka noho?   
\q1
\v 30 Kekero muramura idia inua daudau taudia,  
\q1 bona uaina idauidau idia mikisi,  
\q1 vadaeni idia inua toho taudia.   
\q1
\v 31 Do oi naria namonamo,  
\q1 uaina ese oi do ia koia garina.  
\q1 Uaina be kapusi lalonai ia kakakaka namo herea,  
\q1 be do oi ura henia momo lasi.  
\q1 Iena mamina namo herea do oi laloa lasi.   
\q1
\v 32 Badina be dokona neganai,  
\q1 uaina ese gaigai bamona oi do ia koria,  
\q1 bona gaigai korema hegeregerena,  
\q1 oiemu kopina be poisini dekenai do ia kodoa.   
\q1
\v 33 Oiemu matana ese idau gaudia do idia itaia,  
\q1 bona oiemu laloa, bona oiemu hereva,  
\q1 be do idia gagevagageva.   
\q1
\v 34 Oi be davara bada ena latanai oi mahuta tauna bamona,  
\q1 lagatoi ena au tubua ataiai palai,  
\q1 dekenai oi hekure bamona.   
\q1
\v 35 Bona gabeai do oi gwau,  
\q1 “Idia ese lau idia botaia,  
\q1 to mamina lau abia lasi.  
\q1 Edena bamona lau noga diba lasi?  
\q1 Manoka garina kekero muramura ma ta do lau tahua.”   
\b  
\c 24  
\q1
\v 1 Kara dika taudia dekenai do umui mama henia lasi.  
\q1 Idia dekenai umui turana karaia gwauraia lasi.   
\q1
\v 2 Badina kerere havaraia totona idia laloa karaia noho,  
\q1 bona taunimanima hadikaia totona idia herevahereva noho.   
\b  
\q1
\v 3 Aonega bona laloa kehoa tauna ese  
\q1 ruma ia haginia noho,  
\q1 bona iena famili idia tubu goada noho.   
\q1
\v 4 Inai tau ena diba dainai,  
\q1 ruma ena daiutu be davana bada kohu,  
\q1 bona gau namodia dekenai ia hahonua noho.   
\b  
\q1
\v 5 Aonega tauna ese goada tauna ia hereaia noho,  
\q1 bona diba namona tauna ese,  
\q1 tauanina goada tauna ia hereaia noho.   
\q1
\v 6 Badina be tuari do umui karaia namonamo dalana,  
\q1 be palani namodia do umui karaia guna,  
\q1 bona tuari do umui kwalimu totona,  
\q1 sisiba namona do umui kamonai henia namonamo guna.   
\b  
\q1
\v 7 Aonega hereva be dobu momokani,  
\q1 bona kavakava tauna ese edia anina ia davaria diba lasi.  
\q1 Hebou lalonai hereva badadia idia herevalaia neganai,  
\q1 ia be ia hereva lasi noho.   
\b  
\q1
\v 8 Bema kara dika karaia dalana,  
\q1 be nega ibounai oi laloa noho neganai,  
\q1 taunimanima ese kerere havaraia tauna oi do idia gwauraia.   
\q1
\v 9 Kavakava tauna ese ia laloa noho palani be kara dika,  
\q1 bona tau haida dekenai ia hereva dika henia tauna,  
\q1 be taunimanima ese idia badu henia noho.   
\b  
\q1
\v 10 Bema hekwakwanai neganai oi manoka neganai,  
\q1 oiemu goada be maragimaragi momokani.   
\b  
\q1
\v 11 Bema kerere lasi tauna,  
\q1 be do idia hamasea gwauraia neganai,  
\q1 unai tau do oi hamauria haraga.  
\q1 Mase dekenai kahirakahira idia moru taudia,  
\q1 be do oi veria mauri.   
\q1
\v 12 Bema oi koikoi, oi gwau,  
\q1 “Lau be inai gau lau diba lasi,”  
\q1 laloa ibounai Dirava ese,  
\q1 inai koikoi ia itaia lasi, a?  
\q1 Oiemu lauma ia naria noho Dirava ia diba lasi, a?  
\q1 Ia ese taunimanima edia davana,  
\q1 be edia kara hegeregerena do ia henia.   
\b  
\q1
\v 13 Egu natuna e, hani do oi ania,  
\q1 badina ia be namo.  
\q1 Hanibi edia ruma dekena amo ia mai hani,  
\q1 be mai ena mamina namo oiemu uduna dekenai.   
\q1
\v 14 Kamonai, aonega be unai bamona, oiemu laumana dekenai.  
\q1 Bema aonega oi davaria neganai,  
\q1 vaira dinadia be do idia namo,  
\q1 bona oi ura davaria gau namodia,  
\q1 be oi dekenai Dirava ese do ia henia.   
\b  
\q1
\v 15 Kara maoromaoro tauna dekena amo henaoa totona,  
\q1 o iena ruma abia totona,  
\q1 hunia dekenai do oi naria noho lasi.  
\q1 Unai be kerere bada taudia idia karaia bamona.   
\q1
\v 16 Badina be kara maoromaoro tauna,  
\q1 be nega momo do ia moru,  
\q1 to ma do ia toreisi.  
\q1 To kara dika tauna be hisihisi ese,  
\q1 do ia hadikaia ore momokani.   
\b  
\q1
\v 17 Oi dekenai ia tuari tauna ia moru neganai,  
\q1 do oi moale lasi.  
\q1 Ia hekwakwanai neganai, do oi moale bada lasi.   
\q1
\v 18 Lohiabada ese oiemu moale do ia itaia,  
\q1 vadaeni do ia badu,  
\q1 bona unai neganai Lohiabada ese oi ia tuari henia tauna,  
\q1 ena kerere davana do ia henia lasi.   
\b  
\q1
\v 19 Oiemu lalona do ia hekwarahi lasi,  
\q1 kara dika taudia dainai,  
\q1 bona kerere idia karaia noho taudia,  
\q1 be do oi mama henia lasi.   
\q1
\v 20 Badina be kara dika taudia,  
\q1 be do idia mauri noho daudau diba lasi,  
\q1 bona kerere idia karaia noho taudia edia lamepa,  
\q1 be do idia bodo haraga.   
\b  
\q1
\v 21 Egu natuna e, Lohiabada do oi gari henia,  
\q1 bona king do oi matauraia.  
\q1 Bona haida ese Lohiabada bona king idia dagedage henia neganai,  
\q1 unai dika taudia do oi durudia lasi.   
\q1
\v 22 Unai bamona taudia be Lohiabada bona king ese,  
\q1 do idia hadikaia ore haraga.  
\q1 Idia ruaosi, Lohiabada bona king ese idia mailaia dika,  
\q1 be daika do ia diba?   
\s1 Aonega taudia edia hereva ma haida  
\q1
\v 23 Aonega taudia edia hereva ma haida be inai:  
\q1 Kota maoromaorona lasi be dika.   
\q1
\v 24 Bema kota biaguna ta ese kerere tauna ia hamaoroa,  
\q1 ia gwau, “Oi be kerere lasi” neganai,  
\q1 unai kota biaguna be taunimanima ibounai bona bese ibounai,  
\q1 ese do idia badu henia momokani.   
\q1
\v 25 To idia ese kerere taudia edia kerere davana,  
\q1 be idia henia momokani neganai,  
\q1 kota biagudia ese hanamoa bada bona ladana namo,  
\q1 do idia abia.   
\b  
\q1
\v 26 Haere maoromaorona bona momokani oi dekenai ia henia tauna,  
\q1 be turana korikori ena kara ia karaia noho.   
\b  
\q1
\v 27 Oiemu tano hanamoa gaukara do oi haorea,  
\q1 bona oiemu uma gabuna do oi abia hegaegae.  
\q1 Unai murinai, oiemu noho rumana do oi haginia.   
\b  
\q1
\v 28 Oiemu badibadinai noho tauna do oi samania kava lasi,  
\q1 bona ia totona do oi hereva koikoi lasi.   
\q1
\v 29 Do oi hereva lasi inai bamona:  
\q1 “Ia ese lau dekenai ia karaia hegeregerena,  
\q1 be lau ese ia dekenai do lau karaia.  
\q1 Lau ese iena dika davana do lau henia.”   
\b  
\q1
\v 30 Lahedo tauna ena uma gabuna lau raka hanaia,  
\q1 unai kavakava tauna ena vain audia danu lau raka hanaia.   
\q1
\v 31 Vadaeni lau itaia,  
\q1 au ginigini ese idia koua momokani,  
\q1 ava ginigini ese tano idia hahonua momokani,  
\q1 bona iena nadi maguna be ia makohia vadaeni.   
\q1
\v 32 Unai gabu lau itaia dainai lau laloa namonamo,  
\q1 bona unai dekena amo,  
\q1 diba bona laloa kehoa lau davaria.   
\q1
\v 33 Lahedo tauna ese inai bamona ia hereva, ia gwau,  
\q1 “Egu mahuta do lau halataia,  
\q1 do lau laga-ani sisina,  
\q1 bona nega sisina egu imana do lau lokua,  
\q1 do lau mahuta totona.”   
\q1
\v 34 Vadaeni ogogami ese ia do ia abia,  
\q1 dadia tauna ia mai bamona,  
\q1 bona gau lasi ena nega,  
\q1 be ia dekenai do ia ginidae,  
\q1 tuari tauna ia ginidae bamona.   
\c 25  
\s1 Solomona ena aonega herevadia ma haida  
\q1
\v 1 Inai danu be Solomona ena aonega herevadia,  
\q1 Hesekaia, Iuda ena king,  
\q1 ena orea taudia ese idia torea hanai:   
\b  
\q1
\v 2 Dirava ese gau haida ia hunia noho dainai,  
\q1 ita ese ita matauraia bona hanamoa noho,  
\q1 bona king ese gau edia anina idia tahua noho dainai,  
\q1 ita ese idia ita matauraia bona hanamoa noho.   
\q1
\v 3 Guba be ataiai ia daekau noho,  
\q1 bona tanobada be dobu gabudia ia diho noho hegeregerena,  
\q1 king ena laloa gaudia ita tahua diba lasi.   
\b  
\q1
\v 4 Siliva do idia havevea neganai,  
\q1 miro ibounai do idia kokia.  
\q1 Unai neganai siliva gaukaralaia tauna ese,  
\q1 hairai gauna ta do ia karaia diba.   
\q1
\v 5 Iena sisiba henia tau dikadia,  
\q1 be king ena vairana dekena amo do umui kokia,  
\q1 vadaeni unai king ese mai kara maoromaoro danu,  
\q1 iena basileia do ia naria.   
\b  
\q1
\v 6 King ena vairana dekenai do oi hekokoroku lasi,  
\q1 bona lohia taudia edia huanai,  
\q1 helai gabu badana do oi tahua lasi,   
\q1
\v 7 badina be oi do ia hamaoroa, do ia gwau,  
\q1 “Iniseni do oi daekau mai,” be namo,  
\q1 to king ena vairana dekenai,  
\q1 henunai gabuna dekenai oi do idia siaia lao be dika.   
\b  
\q1
\v 8 Kara ta oi itaia vadaeni totona,  
\q1 kota dekenai do oi lao haraga lasi,  
\q1 badina dokona neganai edena bamona do oi karaia,  
\q1 bema oiemu badibadinai tauna ese oi do ia hahemaraia neganai?   
\b  
\q1
\v 9 Oiemu badibadinai tauna sibona danu,  
\q1 emui hepapahuahu do umui herevalaia hebou,  
\q1 bona tau ta dekenai,  
\q1 oiemu badibadinai tauna ena hunia hereva do oi hamaoroa lasi.   
\q1
\v 10 Badina unai hereva ia kamonai tauna ese,  
\q1 oi do ia hahemaraia,  
\q1 bona oiemu ladana be do ia dika noho,  
\q1 ela bona nega ibounai garina.   
\b  
\q1
\v 11 Hereva maorona gwauraia namonamo karana,  
\q1 be golo herahera siliva bosea latanai bamona.   
\b  
\q1
\v 12 Bema aonega tauna ena sisiba hereva,  
\q1 be tau ta ese ia kamonai henia neganai,  
\q1 unai hereva be golo rini o golo herahera gauna ta bamona.   
\b  
\q1
\v 13 Hereva mailaia tauna namona ese,  
\q1 iena biaguna ena lalona ia hamatamataia lou,  
\q1 ranu keruma ese uma anina idia utua taudia ia hanamoa bamona,  
\q1 idia siahu bada neganai.   
\b  
\q1
\v 14 Bema tau ta ia gwauhamata,  
\q1 harihari gauna do ia henia, to ia henia lasi,  
\q1 unai tau be dika,  
\q1 medu idia mailaia lasi ori bona lai bamona.   
\b  
\q1
\v 15 Haheauka ese taunimanima aukadia edia lalona ia hamanadaia diba,  
\q1 bona hereva manada ese,  
\q1 lohia tauna ena lalona ia veria diba.   
\b  
\q1
\v 16 Bema hani oi davaria neganai,  
\q1 hegeregerena sibona do oi ania,  
\q1 momo do oi ania lasi,  
\q1 do oi mumuta garina.   
\q1
\v 17 Oiemu badibadinai tauna ena ruma,  
\q1 be do oi raka vareai nega momo lasi,  
\q1 ia ese do ia hesiku,  
\q1 bona oi do ia badu henia garina.   
\b  
\q1
\v 18 Iena badibadinai tauna ia samania koikoi tauna,  
\q1 be tuari kaia, kepata, o diba mai matana bamona.   
\b  
\q1
\v 19 Hekwakwanai neganai bema koikoi tauna oi abidadama henia,  
\q1 unai be isena mai ena hisihisi,  
\q1 o aena ia dika noho bamona.   
\b  
\q1
\v 20 Lalohisihisi tauna dekenai ane do oi abia neganai,  
\q1 unai be keru neganai iena dabua oi kokia,  
\q1 o iena berona be damena dekena amo oi kakasia bamona.   
\b  
\q1
\v 21 Bema oi dekenai ia tuari tauna ia hitolo neganai,  
\q1 aniani do oi henia,  
\q1 bona bema ia be ranu mase,  
\q1 ranu do oi henia.   
\q1
\v 22 Bema inai bamona oi karaia,  
\q1 oi ese lahi gida iena kwarana dekenai do oi haboua,  
\q1 bona Lohiabada ese oiemu davana namona do ia henia.   
\b  
\q1
\v 23 Lahara ese medu ia mailaia noho,  
\q1 bona hereva dikana ese badu ia havaraia noho.   
\b  
\q1
\v 24 Ruma ena guhi dekenai do oi noho be namo,  
\q1 to hereva momo hahine danu,  
\q1 ruma lalonai do oi noho be dika.   
\b  
\q1
\v 25 Sivarai namona gabu daudau dekena amo,  
\q1 be ranu keru momokani, ranu mase tauna dekenai bamona.   
\b  
\q1
\v 26 Kara maoromaoro tauna ese,  
\q1 kara dika taudia edia dala ia koua lasi neganai,  
\q1 unai be ranu guri ena ranu ia miro,  
\q1 o ranu bodaga ia lohilohi noho bamona.   
\b  
\q1
\v 27 Hani momo do oi ania be namo lasi.  
\q1 Unai bamona danu, oi sibona dekenai,  
\q1 hanamoa momo do oi tahua be namo lasi.   
\b  
\q1
\v 28 Ia badu neganai mai ena haheauka lasi tauna,  
\q1 be hanua ta mai ena magu lasi bamona,  
\q1 idia hadikaia ore vadaeni.   
\b  
\c 26  
\b  
\q1
\v 1 Kavakava tauna do idia matauraia be hegeregere lasi,  
\q1 sinou ia moru siahu neganai,  
\q1 o medu ia diho anina utua neganai bamona.   
\b  
\q1
\v 2 Bisini manu ia roho loaloa noho,  
\q1 o aibisi manu ia roho lao noho hegeregerena,  
\q1 hereva dika mai badina lasi,  
\q1 be gabu ta dekenai do ia kamokau noho lasi.  
\q1 Vadaeni mai ena kerere lasi tauna,  
\q1 be hereva dika ese ia hadikaia diba lasi.   
\b  
\q1
\v 3 Hosi be kwadia varona dekenai do oi kwadia,  
\q1 doniki be hakaua varona dekenai do oi kwadia,  
\q1 bona kavakava tauna ena doruna,  
\q1 be kwadia auna dekenai do oi kwadia.   
\b  
\q1
\v 4 Kavakava tauna be,  
\q1 iena kavakava hegeregerena do oi haere henia lasi,  
\q1 ia danu do oi hegeregere garina.   
\b  
\q1
\v 5 Ma kavakava tauna be,  
\q1 iena kavakava hegeregerena do oi haere henia,  
\q1 ia sibona do ia laloa ia be mai ena aonega garina.   
\b  
\q1
\v 6 Bema kavakava tauna oi siaia,  
\q1 hereva do ia gwauraia totona,  
\q1 unai be oiemu aena oi utua oho,  
\q1 o poisini do oi inua bamona.   
\b  
\q1
\v 7 Aonega hereva, kavakava tauna ena uduna dekenai,  
\q1 be anina lasi,  
\q1 aena dika tauna ena aena be anina lasi hegeregerena.   
\b  
\q1
\v 8 Bema kavakava tauna oi matauraia neganai,  
\q1 unai be nadi negea varona dekenai,  
\q1 nadi oi kwatua kau bamona.   
\b  
\q1
\v 9 Aonega hereva ena anina,  
\q1 be kavakava tauna ese ia gwauraia neganai be,  
\q1 kekero tauna ese,  
\q1 iena imana ia gwadaia ginigini ia kokia toho bamona.   
\b  
\q1
\v 10 Biaguna ta, iena gaukara karaia totona,  
\q1 bema kavakava tauna o kekero tauna ia abia hidi,  
\q1 be peva tauna taunimanima ibounai ia haberoa kava noho bamona.   
\b  
\q1
\v 11 Kavakava tauna ese,  
\q1 iena kara kava ma ia karaia lou noho,  
\q1 iena mumuta dekenai ia giroa lou noho sisia bamona.   
\b  
\q1
\v 12 Tau ta oi itaia,  
\q1 ia sibona aonega ia gwauraia noho?  
\q1 Kavakava tauna be sisina ia namo,  
\q1 to unai tau be ia namo diba lasi.   
\b  
\q1
\v 13 Lahedo tauna be badina dahaka iena ruma ia rakatania lasi?  
\q1 Ia be dahaka dekenai ia gari?  
\q1 Laiona dekenai ia gari, a?   
\b  
\q1
\v 14 Iduara ese iena hinisi ia rakatania lasi hegeregerena,  
\q1 lahedo tauna ese iena mahuta patana ia rakatania lasi.   
\b  
\q1
\v 15 Taunimanima haida be lahedo momo dainai,  
\q1 sibodia edia uduna dekenai aniani idia atoa lasi.   
\b  
\q1
\v 16 Lahedo tauna sibona ia laloa iena aonega ese,  
\q1 tau 7 edia aonega ia hereaia noho.  
\q1 Edia laloa kehoa bona haere namodia,  
\q1 be gau ta lasi, ia gwau.   
\b  
\q1
\v 17 Tau haida edia heai lalonai ia vareai noho tauna,  
\q1 be ia raka hanaia tauna ese,  
\q1 sisia ena taiana ia dogoatao noho bamona.   
\b  
\q1
\v 18-19 Tau ta ese iena badibadinai tauna ia koia,  
\q1 bona ia gwau ia hevaseha sibona,  
\q1 be kavakava tauna ese diba bona lahi,  
\q1 mase gaudia, ia pidia bona negea noho kava bamona.   
\b  
\q1
\v 20 Bema au be lasi neganai,  
\q1 lahi be ia bodo noho,  
\q1 bona bema hadikaia hereva be lasi neganai,  
\q1 heai be do ia doko.   
\b  
\q1
\v 21 Gida ese guma idia hasiahua noho,  
\q1 au ese lahi ia habadaia noho,  
\q1 bona badu haraga tauna ese heai ia havaraia noho.   
\b  
\q1
\v 22 Anina lasi kiki,  
\q1 tau ta ena ladana hadikaia totona,  
\q1 be ita ura bada, ani?  
\q1 Ia be mamina namo aniani bamona,  
\q1 bona ita ania haraga noho, ani?   
\b  
\q1
\v 23 Hereva manada ia gwauraia,  
\q1 to iena lalona be dika tauna,  
\q1 be uro dikana mai ena kopina siliva manadana bamona.   
\b  
\q1
\v 24 Badu tauna ese hereva manada dekenai,  
\q1 iena badu ia hunia noho,  
\q1 to iena kudouna lalonai be koikoi ia noho,   
\q1
\v 25 vadaeni bema hereva manada ia gwauraia neganai,  
\q1 do oi kamonai henia lasi,  
\q1 badina be iena kudouna,  
\q1 be badu dekenai ia honu momokani.   
\q1
\v 26 Momokani, iena badu ia hunia noho,  
\q1 to gabeai iena dika,  
\q1 be taunimanima edia hebou lalonai do ia hedinaraia.   
\b  
\q1
\v 27 Guri ia geia,  
\q1 haida be ia lalonai do idia moru totona tauna,  
\q1 be ia sibona unai guri lalonai do ia moru.  
\q1 Bona nadi ia keia hamatamaia tauna,  
\q1 be ia sibona unai nadi ese do ia hadikaia ore.   
\b  
\q1
\v 28 Koikoi ia gwauraia tauna ese,  
\q1 ia koia taudia ia badu henidia noho,  
\q1 bona hanamoa koikoi hereva ia gwauraia noho tauna ese,  
\q1 dika momokani ia havaraia noho.   
\b  
\c 27  
\q1
\v 1 Kerukeru gaudia totona do oi hekokoroku lasi,  
\q1 badina be oi diba lasi,  
\q1 dina ta dekenai dahaka do ia vara.   
\b  
\q1
\v 2 Tau ta ese oi do ia hanamoa be namo,  
\q1 to oi sibona do oi hanamoa lasi.  
\q1 Idau tauna ena hereva ese oi do ia hanamoa,  
\q1 oi sibona emu hereva ese be lasi.   
\b  
\q1
\v 3 Nadi be metau, miri danu be metau,  
\q1 to kavakava tauna ese ia havaraia kererena,  
\q1 be metau herea.   
\b  
\q1
\v 4 Badu be mai ena dagedage,  
\q1 bona ia ese taunimanima ia hadikaia noho,  
\q1 to mama ena dika ese,  
\q1 badu ena dika ia hanaia momokani.   
\b  
\q1
\v 5 Tau ta do oi sisiba henia neganai,  
\q1 iena vairana dekenai do oi gwauraia hedinarai.  
\q1 Namo lasi unai tau do ia laloa,  
\q1 oi ese ia dekenai oi laloa lasi momokani.   
\b  
\q1
\v 6 Bema oiemu turana ese oi ia hahisia neganai,  
\q1 unai be oi do ia hanamoa totona.  
\q1 To bema oi ia dagedage henia tauna ese,  
\q1 oi ia kisi henia neganai, koikoi be unai.   
\b  
\q1
\v 7 Bema oi boga kunu neganai,  
\q1 hani do oi ura henia lasi momokani,  
\q1 to bema oi hitolo neganai,  
\q1 mamina dika momokani aniani danu do oi ania.   
\b  
\q1
\v 8 Iena noho ruma ia rakatania tauna be,  
\q1 manu ta, iena noho ruma,  
\q1 dekena amo ia heautania bamona.   
\b  
\q1
\v 9 Dehoro bona bonana namo muramura ese,  
\q1 taunimanima edia kudouna idia hamoalea noho.  
\q1 Unai bamona danu tau ta ena hereva namona ese,  
\q1 iena turana ia hamoalea noho.   
\b  
\q1
\v 10 Oiemu turana, bona oiemu tamana ena turana,  
\q1 be do oi laloaboio lasi.  
\q1 To bema oi dekenai hisihisi ia vara neganai,  
\q1 oiemu tadikakana ena ruma dekenai do oi lao lasi.  
\q1 Badina oiemu badibadinai noho tauna be ia noho kahirakahira,  
\q1 unai dainai ia ese oi do ia durua haraga diba,  
\q1 to oiemu varavara idia noho daudau.   
\b  
\q1
\v 11 Egu natuna e, do oi aonega, vadaeni do lau moale,  
\q1 bona unai dainai, bema tau ta ese lau ia gwauraia kerere neganai,  
\q1 lau ese iena hereva do lau halusia diba.   
\b  
\q1
\v 12 Aonega tauna ese dika ia itaia noho,  
\q1 bona unai dika dekena amo ia raka siri,  
\q1 to aonega lasi tauna,  
\q1 be unai dika dekenai do ia raka lao,  
\q1 bona gabeai hisihisi do ia davaria.   
\b  
\q1
\v 13 Bema tau ta ese,  
\q1 idau tauna ena abiatorehai totona, gwauhamata ia karaia neganai,  
\q1 unai tau ena kouti be,  
\q1 gwauhamata toana totona do oi abia.  
\q1 Bona bema ia ese idau bese tauna totona,  
\q1 unai bamona gwauhamata ia karaia neganai,  
\q1 unai tau ena gau namona ta,  
\q1 be do oi dogoatao momokani.   
\b  
\q1
\v 14 Bema daba maragi neganai,  
\q1 oiemu turana oi hanamoa mai boiboi bada danu,  
\q1 unai be oi ese,  
\q1 ia dekenai hadikaia hereva oi gwauraia bamona.   
\b  
\q1
\v 15 Tau ta ena hahine ese ia hepapahuahu henia noho,  
\q1 be ranu ia diho noho sisina sisina nega ibounai,  
\q1 doko lasi bamona.   
\q1
\v 16 Unai hahine ena hereva momo,  
\q1 be edena bamona do oi koua diba?  
\q1 Oi ese lai oi hadokoa diba, a?  
\q1 Oi ese olive dehoro oiemu imana dekenai oi dogoatao diba, a?   
\b  
\q1
\v 17 Tau ta ese ma tau ta dekena amo,  
\q1 diba ia davaria noho,  
\q1 auri ta ese ma auri ta ia segea noho bamona.   
\b  
\q1
\v 18 Fig auna do oi naria,  
\q1 vadaeni fig huahua do oi ania,  
\q1 bona hesiai tauna ese,  
\q1 iena biaguna do ia naria namonamo neganai, davana namona do ia davaria.   
\b  
\q1
\v 19 Ranu ese tau ta ena vairana ena laulau ia hedinaraia noho,  
\q1 ma unai bamona danu tau ta ena kudouna ese,  
\q1 sibona ena lalona ia hedinaraia noho.   
\b  
\q1
\v 20 Mase taudia edia gabu be ia honu haorea diba lasi,  
\q1 bona taunimanima edia ura dikadia idia doko lasi,  
\q1 edia ura idia davaria haorea diba lasi.   
\b  
\q1
\v 21 Lahi ese golo bona siliva ena namo ia tohoa noho,  
\q1 bona taunimanima ese tau ta idia hanamoa henia neganai,  
\q1 unai tau ese iena namo o iena dika,  
\q1 be do ia hedinaraia noho.   
\b  
\q1
\v 22 Sedira kavakava tauna do idia kwadia,  
\q1 ela bona kahirakahira ia mase,  
\q1 to iena kavakava be ia dekena amo idia kokia diba lasi.   
\b  
\q1
\v 23 Oiemu mamoe edia noho do oi itaia namonamo.  
\q1 Oiemu boromakau danu do oi naridia namonamo,   
\q1
\v 24 badina be kohu bona moni,  
\q1 be nega hanaihanai do idia noho lasi,  
\q1 bona king ena basileia danu be nega ibounai do ia gini lasi.   
\q1
\v 25 Rei do ia kaukau,  
\q1 unai murinai rei matamata do ia vara,  
\q1 bona ororo edia avadia do idia haboua.   
\q1
\v 26 Unai neganai mamoe edia natudia dekena amo,  
\q1 emu dabua do oi abia,  
\q1 bona emu nanigosi haida do oi hoia lao,  
\q1 dekena amo tano ta do oi hoia mai.   
\q1
\v 27 Oiemu nanigosi oredia edia rata dekena amo,  
\q1 oi bona oiemu famili do oi ubua,  
\q1 oiemu hesiai kekenidia danu.   
\b  
\c 28  
\q1
\v 1 Kara dika taudia be ta ese,  
\q1 ia luludia lasi neganai idia heau kava noho,  
\q1 to kara maoromaoro taudia be idia gari lasi noho,  
\q1 laiona bamona.   
\b  
\q1
\v 2 Basileia ta ena taunimanima bema idia kara dika neganai,  
\q1 unai basileia ena king be momo,  
\q1 to aonega bona laloa kehoa tauna ese ia gunalaia neganai,  
\q1 basileia be nega daudau do ia gini goada noho.   
\b  
\q1
\v 3 Bema ogogami tauna ta ese,  
\q1 ogogami tauna ma ta ia dagedage henia,  
\q1 unai dagedage tauna be medu dikana,  
\q1 aniani ia hadikaia meduna, bamona.   
\b  
\q1
\v 4 Bema taravatu oi rakatania,  
\q1 oi ese kara dika taudia oi hanamoa noho,  
\q1 to taravatu oi badinaia neganai,  
\q1 oi ese kara dika taudia oi heatu henidia noho.   
\b  
\q1
\v 5 Kara dika taudia be kota maoromaoro ena anina idia diba lasi,  
\q1 to Lohiabada idia tahua noho taudia ese,  
\q1 kota maoromaoro idia diba momokani.   
\b  
\q1
\v 6 Ogogami tauna be iena kara maoromaoro dekenai ia noho be namo,  
\q1 to kohu momo tauna be iena kara koikoi dekenai ia noho be dika.   
\b  
\q1
\v 7 Taravatu ia badinaia noho merona be aonega merona,  
\q1 to heatu kava taudia danu ia turana karaia merona,  
\q1 ese iena tamana ia hahemaraia noho.   
\b  
\q1
\v 8 Bema atoa kau moni dekena amo,  
\q1 oiemu kohu do oi habadaia neganai,  
\q1 unai oi haboua vadaeni kohu be,  
\q1 ogogami taudia ia bogahisihisi henia tauna ta ese do ia abia.   
\b  
\q1
\v 9 Bema Dirava ena taravatu ita kamonai henia lasi,  
\q1 ia ese iseda guriguri do ia kamonai henia lasi.   
\b  
\q1
\v 10 Kara maoromaoro taudia,  
\q1 bema tau ta ese kara dika ena dala dekenai ia hakaudia kerere,  
\q1 unai tau be sibona ena guri lalonai do ia moru diho,  
\q1 to kerere lasi taudia ese davana namona do idia davaria.   
\b  
\q1
\v 11 Kohu momo taudia ese,  
\q1 idia laloa idia be aonega taudia,  
\q1 to ogogami tauna mai ena laloa kehoa ese,  
\q1 unai taudia edia kara momokani ia diba.   
\b  
\q1
\v 12 Kara maoromaoro taudia idia kwalimu noho neganai,  
\q1 taunimanima idia moale bada noho,  
\q1 to kara dika taudia idia toreisi noho neganai,  
\q1 taunimanima be idia hunia noho.   
\b  
\q1
\v 13 Bema oiemu kara dika oi hunia noho neganai,  
\q1 namo ta do oi davaria lasi.  
\q1 Oiemu kara dika do oi gwauraia hedinarai,  
\q1 bona dika do oi rakatania,  
\q1 unai neganai Dirava ese oi do ia bogahisihisi henia.   
\b  
\q1
\v 14 Nega ibounai Lohiabada do oi gari henia,  
\q1 vadaeni do oi moale,  
\q1 to bema oiemu kudouna oi ha-aukaia neganai,  
\q1 dika momokani do oi davaria.   
\b  
\q1
\v 15 King dikana ese ogogami taudia ia biagua,  
\q1 be laiona ia boiboi noho,  
\q1 o bea ia dagedage noho bamona.   
\b  
\q1
\v 16 King mai ena laloa kehoa lasi ese,  
\q1 taunimanima ia hisihisi henidia bada noho.  
\q1 To ia ura lasi koikoi dekena amo,  
\q1 kohu do ia abia tauna,  
\q1 be nega daudau, dina momo, do ia mauri noho.   
\b  
\q1
\v 17 Tau ta ese ma tau ta ia alaia mase neganai,  
\q1 unai ala-ala tauna be heau tauna do ia lao,  
\q1 ela bona ia mase.  
\q1 Tau ta ese ia do ia durua lasi.   
\b  
\q1
\v 18 Kara maoromaoro dalana dekenai ia raka noho tauna,  
\q1 be do ia mauri,  
\q1 to kara kerere tauna,  
\q1 be guri lalonai do ia moru diho haragaharaga.   
\b  
\q1
\v 19 Iena tano dekenai ia gaukara auka tauna ese,  
\q1 aniani momo do ia ania,  
\q1 to anina lasi karadia ia karaia noho tauna,  
\q1 be do ia ogogami momokani.   
\b  
\q1
\v 20 Kara maoromaoro tauna ese,  
\q1 gau namodia momo do ia davaria,  
\q1 to bema kohu momo oi tahua haraga haraga,  
\q1 oi ese matakani do oi davaria.   
\b  
\q1
\v 21 Taunimanima ibounai maka tamona do oi kara henidia lasi,  
\q1 be kara dika,  
\q1 bona kota biagudia haida ese,  
\q1 beredi tamona ena davana totona kerere do idia karaia.   
\b  
\q1
\v 22 Ena moni sibona ia laloa tauna ese,  
\q1 ia ura kohu momo do ia davaria haraga,  
\q1 to ia diba lasi ogogami ese do ia davaria.   
\b  
\q1
\v 23 Tau ta ia sisiba henia tauna ese,  
\q1 gabeai lalo namo bada do ia abia,  
\q1 to iena uduna dekenai ia hanamoa koikoi tauna ese,  
\q1 lalo namo maragi sibona do ia abia.   
\b  
\q1
\v 24 Iena tamana o sinana ena gau ia henaoa noho,  
\q1 bona ia gwau, “Inai be kerere lasi”,  
\q1 be ala-ala tauna ena turana.   
\b  
\q1
\v 25 Hekokoroku tauna ese heai ia havaraia noho,  
\q1 to Lohiabada ia abidadama henia noho tauna ese,  
\q1 kohu momo do ia davaria.   
\b  
\q1
\v 26 Sibona ena lalona dekenai ia abidadama henia tauna be kavakava,  
\q1 to aonega ena dala dekenai ia raka tauna,  
\q1 be do ia mauri.   
\b  
\q1
\v 27 Ogogami taudia dekenai durua do oi henia,  
\q1 bona do oi ogogami lasi,  
\q1 to bema ogogami taudia dekenai,  
\q1 oiemu matana oi koua neganai,  
\q1 taunimanima ese hereva dika mai badu danu,  
\q1 oiemu latanai do idia gwauraia.   
\b  
\q1
\v 28 Kara dika taudia ese,  
\q1 basileia naria siahu idia abia neganai,  
\q1 taunimanima be do idia hunia,  
\q1 to unai kara dika taudia idia mase neganai,  
\q1 kara maoromaoro taudia be, ma momo do idia noho.   
\b  
\c 29  
\q1
\v 1 Bema nega momo oi do idia sisiba henia,  
\q1 to oi ese sisiba oi abia dae lasi momokani,  
\q1 unai neganai dika do oi davaria haraga,  
\q1 bona unai dika dekena amo,  
\q1 hanamoa lou dala be lasi momokani.   
\b  
\q1
\v 2 Kara maoromaoro taudia idia goada noho neganai,  
\q1 taunimanima idia moale noho,  
\q1 to bema kara dika tauna ia king neganai,  
\q1 taunimanima idia lalohisihisi momokani.   
\b  
\q1
\v 3 Aonega ia ura henia noho tauna ese,  
\q1 iena tamana ia hamoalea noho,  
\q1 to ariara hahine danu ia noho hebou tauna ese,  
\q1 iena moni ia negea kava noho.   
\b  
\q1
\v 4 Kota maoromaoro dekena amo king ta ese,  
\q1 iena basileia ia hagoadaia noho,  
\q1 to taunimanima edia harihari gaudia ia tahua dikadika king ese,  
\q1 iena basileia do ia hadikaia ore.   
\b  
\q1
\v 5 Bema oiemu turana oi hanamoa koikoi neganai,  
\q1 oi ese oi sibona oiemu tarapu oi karaia noho inai.   
\b  
\q1
\v 6 Kara dika tauna be ia sibona ena kara dika ese,  
\q1 idia koia bona hadikaia noho,  
\q1 to kara maoromaoro tauna ese ane ia abia noho,  
\q1 mai ena moale bada danu.   
\b  
\q1
\v 7 Kara maoromaoro tauna ese,  
\q1 ogogami taudia dekenai kota maoromaoro ia henidia noho,  
\q1 to kara dika tauna ese,  
\q1 ogogami taudia dekenai ia laloa lasi.   
\b  
\q1
\v 8 Hekokoroku mai badu kava danu taudia ese,  
\q1 hanua dekenai heai bona heatu idia havaraia noho,  
\q1 to aonega taudia ese badu idia hakerua noho.   
\b  
\q1
\v 9 Bema aonega tauna be kavakava tauna danu idia hepapahuahu neganai,  
\q1 kavakava tauna be ia badu noho bona ia kiri noho,  
\q1 bona maino do ia vara diba lasi.   
\b  
\q1
\v 10 Ala-ala idia ura noho taudia ese,  
\q1 kerere lasi tauna idia badu henia noho,  
\q1 to kara maoromaoro taudia ese,  
\q1 unai tau hamauria dalana idia tahua noho.   
\b  
\q1
\v 11 Kavakava tauna ese iena badu ia hedinaraia noho,  
\q1 to aonega tauna ese sibona ena badu ia koua,  
\q1 ia haheauka noho.   
\b  
\q1
\v 12 Bema king ta ese hereva koikoi ia kamonai henia neganai,  
\q1 iena basileia taudia ibounai do idia kara dika.   
\b  
\q1
\v 13 Ogogami tauna,  
\q1 bona ogogami tauna ia dagedage henia noho tauna,  
\q1 ruaosi be inai dala dekenai idia hegeregere:  
\q1 Lohiabada ese idia ruaosi dekenai edia matadia ia henia.   
\b  
\q1
\v 14 Bema king ta ese ogogami taudia ia kota henidia,  
\q1 mai maoromaoro danu neganai,  
\q1 iena terona be nega ibounai do ia gini goada noho.   
\b  
\q1
\v 15 Kwadia auna bona sisiba hereva ese,  
\q1 natuna dekenai aonega ia havaraia noho,  
\q1 to sibona ena ura ia karaia noho merona ese,  
\q1 iena sinana do ia hahemaraia.   
\b  
\q1
\v 16 Kara dika taudia ese basileia idia naria neganai,  
\q1 kara kerere ia bada lao noho,  
\q1 to kara maoromaoro taudia ese,  
\q1 unai dika taudia edia moru do idia itaia.   
\b  
\q1
\v 17 Oiemu natuna tau do oi matakani henia,  
\q1 vadaeni ia ese laga-ani oi dekenai do ia henia.  
\q1 Ia ese oiemu laumana do oi hamoalea.   
\b  
\q1
\v 18 Bema Dirava ena hereva ena namo bona siahu,  
\q1 be bese taudia idia itaia lasi neganai,  
\q1 unai bese taudia be do idia kara kava, nega ibounai.  
\q1 To Dirava ena taravatu ia badinaia noho tauna ese,  
\q1 namo do ia davaria.   
\b  
\q1
\v 19 Emu hesiai tauna be hereva sibona,  
\q1 dekena amo oi matakani henia diba lasi.  
\q1 Momokani, oiemu hereva edia anina do ia diba,  
\q1 to ia ese idia do ia kamonai henia lasi.   
\b  
\q1
\v 20 Iena laloa ia gwauraia haragaharaga tauna oi itaia, a?  
\q1 Kavakava tauna be sedira ia namo diba,  
\q1 to unai tau ia namo diba lasi.   
\b  
\q1
\v 21 Bema tau ta ese iena hesiai tauna ia mero neganai,  
\q1 iena ura gaudia ibounai ia henia,  
\q1 dokona neganai unai tau ese unai mero dainai,  
\q1 hekwarahi do ia davaria.   
\b  
\q1
\v 22 Badu tauna ese heai ia havaraia noho,  
\q1 bona badu momo tauna ese,  
\q1 kara dika momo ia havaraia noho.   
\b  
\q1
\v 23 Bema oi hekokoroku neganai oi be do oi moru,  
\q1 to bema oi manau neganai,  
\q1 taunimanima ese oi do idia matauraia.   
\b  
\q1
\v 24 Henaoa tauna ia durua tauna ese,  
\q1 sibona ena mauri ia hadikaia noho,  
\q1 badina kota lalonai ia hereva momokani neganai,  
\q1 kerere do ia davaria,  
\q1 bona bema kota lalonai ia hereva koikoi neganai,  
\q1 Dirava ese iena kerere davana do ia henia.   
\b  
\q1
\v 25 Taunimanima do oi gari henia neganai,  
\q1 dika do oi davaria,  
\q1 tarapu lalonai oi moru bamona.  
\q1 To bema Lohiabada oi abidadama henia neganai,  
\q1 mauri do oi davaria noho.   
\b  
\q1
\v 26 Taunimanima momo ese king ena laloa namo idia tahua noho,  
\q1 to Lohiabada sibona dekena amo kota maoromaoro do oi davaria.   
\b  
\q1
\v 27 Kara gagevagageva tauna be kara maoromaoro taudia ese,  
\q1 idia badu henia noho,  
\q1 bona dala maoromaoro ia raka noho tauna,  
\q1 be kara dika taudia ese idia badu henia noho.   
\c 30  
\s1 Aguru ena hereva  
\q1
\v 1 Aguru Iake, ena peroveta hereva be inai:  
\b  
\q1 “Dirava e, lau hesiku noho, lau hesiku noho,  
\q1 Dirava e, egu goada ia ore vadaeni.   
\b  
\q1
\v 2 “Momokani, lau be kavakava maragi lasi.  
\q1 Lau be taunimanima bamona lasi.  
\q1 Egu lalona be taunimanima edia lalona bamona lasi.   
\q1
\v 3 Aonega be lau davaria lasi,  
\q1 Helaga ena Dirava danu lau diba lasi.   
\q1
\v 4 Daika be guba dekenai ia daekau lao vadaeni,  
\q1 bona ma ia diho mai?  
\q1 Daika ese lai be iena imana lalonai ia dogoatao vadaeni?  
\q1 Daika ese davara be iena dabua dekena amo,  
\q1 ia kumia vadaeni?  
\q1 Daika ese tanobada ena hetoa gabudia ia atoa vadaeni?  
\q1 Iena ladana be daika,  
\q1 bona iena natuna edia ladadia be daika?  
\q1 Momokani oi diba, ani?   
\b  
\q1
\v 5 “Dirava ena hereva ibounai be goeva momokani,  
\q1 bona Dirava ese ia dekenai idia heau mauri taudia,  
\q1 ia naria bona gimaia noho.   
\q1
\v 6 Dirava ena hereva edia latanai,  
\q1 be hereva ta do oi atoa kau lasi,  
\q1 ia ese oi do ia gwau henia,  
\q1 bona oiemu koikoi do ia hedinaraia garina.   
\s1 Aonega hereva ma haida  
\q1
\v 7 “Lohiabada e, gau rua oi dekenai lau noia,  
\q1 lau do mase lasi neganai,  
\q1 mani idia ruaosi lau dekenai do oi henia:   
\q1
\v 8 Koikoi kara bona koikoi hereva,  
\q1 be lau dekena amo do oi abia siri,  
\q1 bona ogogami o kohu momo lau dekenai do oi henia lasi.  
\q1 To egu hitolo hegeregerena sibona,  
\q1 aniani lau dekenai do oi henia.   
\q1
\v 9 Badina bema egu aniani bona kohu momo idia noho neganai,  
\q1 sedira lau be inai bamona do lau gwau garina, ‘Lohiabada be daika?’  
\q1 O sedira bema lau ogogami neganai do lau henaoa,  
\q1 bona egu Dirava ena ladana do lau hahemaraia garina.   
\b  
\q1
\v 10 “Hesiai tauna be iena biaguna dekenai do oi samania koikoi lasi,  
\q1 ia ese iena hereva dekena amo oi do ia hadikaia,  
\q1 bona kerere do oi davaria garina.   
\b  
\q1
\v 11 “Tau haida ese edia tamadia idia hereva dika henia noho,  
\q1 bona idia ese edia sinadia idia hanamoa lasi.   
\q1
\v 12 Ma tau haida ese,  
\q1 sibodia idia gwauraia idia be goeva momokani,  
\q1 to gau be, edia miro ia bada momokani.   
\q1
\v 13 Ma haida be edia matadia dekena amo,  
\q1 edia hekokoroku idia hedinaraia noho.  
\q1 Edia matadia huina idia abia isi noho,  
\q1 mai hekokoroku danu.   
\q1
\v 14 Ma haida edia isedia be tuari kaia,  
\q1 edia aukidia dekenai be kaia idia noho.  
\q1 Idia ese ogogami taudia,  
\q1 be tanobada dekena amo idia ania ore noho,  
\q1 bona gau lasi taudia be,  
\q1 taunimanima edia huanai dekena amo idia anidia ore danu.   
\b  
\q1
\v 15 “Doma ta be mai ena natuna hahine rua.  
\q1 Idia boiboi noho, idia gwau,  
\q1 ‘Ai dekenai henia, ai dekenai henia!’  
\b  
\q1 “Gau 4 edia bogadia idia kunu diba lasi:  
\q1 Idia be nega ta,  
\q1 ‘Vadaeni’ idia gwauraia diba lasi.   
\q1
\v 16 Gaudia be inai:  
\q1 Mase taudia edia gabu.  
\q1 Hahine ta, madi mai ena natuna lasi.  
\q1 Tano kaukau, medu ia diho lasi dainai,  
\q1 bona lahi, nega ta ‘Vadaeni’ ia gwauraia lasi.   
\b  
\q1
\v 17 “Iena tamana ena ladana dekenai ia hevaseha tauna,  
\q1 o iena sinana ia kamonai henia lasi tauna,  
\q1 be galo manu ese iena matana do ia gwadaia,  
\q1 bona ugava manu ese unai tau do idia ania ore.   
\b  
\q1
\v 18 “Gau 4 be mai edia hoa lau dekenai,  
\q1 edia dala be lau diba lasi.  
\q1 Gaudia be inai:  
\q1 Ugava ena roho dalana guba dekenai.   
\q1
\v 19 Gaigai ena heau dalana nadi badana ena latanai.  
\q1 Lagatoi ena dala, davara badana dekenai.  
\q1 Bona uhau tauna ena dala, kekeni ia ura henia neganai.   
\b  
\q1
\v 20 “Heudahanai hahine ena dala be inai:  
\q1 Ia aniani, vadaeni iena uduna ia dahua.  
\q1 Unai murinai ia gwau,  
\q1 ‘Kerere ta lau karaia lasi.’   
\b  
\q1
\v 21 “Gau 4 dekenai tanobada taudia idia haheauka diba lasi,   
\q1
\v 22 gaudia be inai:  
\q1 Hesiai mai guia danu tauna, king ena dagi ia abia neganai.  
\q1 Kavakava tauna, iena ura henia aniani ibounai ia ania neganai.   
\q1
\v 23 Badu hahinena ta, ia headava neganai,  
\q1 bona hesiai kekeni, iena biaguna hahine ena gabu ia abia neganai.   
\b  
\q1
\v 24 “Gau 4 be tanobada dekenai idia maragi momokani,  
\q1 to idia be aonega herea:   
\q1
\v 25 Dimairi be goada lasi,  
\q1 to edia aniani be tano lalonai idia haboua noho.   
\q1
\v 26 Mada danu be goada lasi,  
\q1 to edia ruma be tano lalonai idia karaia noho.   
\q1
\v 27 Kwadi be mai edia king lasi,  
\q1 to idia raka hebou noho, tuari orea bamona.   
\q1
\v 28 Vaboha be oiemu imana dekenai oi dogoatao diba,  
\q1 to ia be king edia ruma lalonai ia noho.   
\b  
\q1
\v 29 “Gau 4 edia raka ena toana be namo herea,   
\q1
\v 30 gaudia be inai:  
\q1 Laiona, uda gaudia edia huanai ia sibona be namo herea,  
\q1 bona goada gauna ta dekena amo do ia heau lasi.   
\q1
\v 31 Bona kokoroku tau, bona nanigosi tau,  
\q1 bona king ta, iena tuari orea ia gunalaia noho neganai.   
\b  
\q1
\v 32 “Bema oi sibona mai kavakava danu oi hekokoroku,  
\q1 bona kara dika karaia dalana oi laloa neganai,  
\q1 oiemu imana dekena amo oiemu uduna do oi koua!   
\q1
\v 33 Badina be rata do oi giroagiroa neganai,  
\q1 bata do oi davaria,  
\q1 bona udu baubauna do oi gigia neganai,  
\q1 rara do ia diho.  
\q1 Bona badu do oi hatoreisia neganai,  
\q1 heai do ia vara.”   
\c 31  
\s1 Sisiba namona king ta dekenai  
\p
\v 1 King Lemuela ena sinana ese inai peroveta hereva be iena natuna dekenai ia hadibaia:   
\b  
\q1
\v 2 “Egu natuna e, egu bogana dekena amo oi vara merona,  
\q1 egu natuna e, egu guriguri dainai lau abia merona.  
\q1 Oi dekenai dahaka do lau gwau?   
\q1
\v 3 Oiemu goada be hahine dekenai,  
\q1 sihari henidia totona do oi haorea lasi.  
\q1 Hahine unai bamona ese,  
\q1 king taudia idia hadikaia ore vadaeni.   
\b  
\q1
\v 4 “Lemuela e, king ese uaina do idia inua be dika,  
\q1 bona lohia taudia ese,  
\q1 muramura aukadia do idia inua be dika,   
\q1
\v 5 idia be do idia inua,  
\q1 bona taravatu do idia laloaboio garina,  
\q1 bona haida ese idia dagedage henidia vadaeni taudia,  
\q1 edia hisihisi be lohia ese do idia laloa lasi,  
\q1 bona haida edia ahuna korikori,  
\q1 be king ese do idia haidaua garina.   
\q1
\v 6 Kekero muramura be,  
\q1 kahirakahira idia mase taudia dekenai do oi henia,  
\q1 bona uaina be idia hisihisi noho taudia sibona,  
\q1 dekenai do oi henia.   
\q1
\v 7 Do idia inua, vadaeni edia ogogami do idia laloaboio,  
\q1 bona edia hisihisi do idia laloatao lasi.   
\b  
\q1
\v 8 “Hereva diba lasi taudia dainai hereva do oi gwauraia.  
\q1 Mai edia durua tauna lasi manoka taudia danu dekenai,  
\q1 edia ahuna korikori do oi henia.   
\q1
\v 9 Idia dainai hereva do oi gwauraia,  
\q1 bona kota maoromaoro do oi karaia.  
\q1 Ogogami bona mai edia gau lasi taudia do oi durua,  
\q1 bona edia ahuna korikori do oi henidia.”   
\s1 Hahine namona ena toana  
\q1
\v 10 Hahine namona be daika ese ia davaria diba?  
\q1 Iena namo ese davana bada herahera nadi,  
\q1 edia namo ia hereaia noho.   
\q1
\v 11 Iena adavana ese ia dekenai ia abidadama henia noho,  
\q1 bona unai tau ese ogogami do ia davaria lasi.   
\q1
\v 12 Unai bamona hahine ese iena tau ia hanamoa noho,  
\q1 ia hadikaia lasi,  
\q1 bona inai bamona ia karaia noho iena mauri dinadia ibounai.   
\q1
\v 13 Mamoe ena huina bona dabua ia karaia varona,  
\q1 be ia ese ia abia hidi noho,  
\q1 bona iena imana dekenai ia gaukaralaia goada noho.   
\q1
\v 14 Ia ese daudau gabudia dekena amo,  
\q1 aniani ia abia mai noho,  
\q1 hoihoi taudia edia lagatoi ese idia karaia bamona.   
\q1
\v 15 Dina do ia daekau lasi neganai ia toreisi,  
\q1 iena bese edia aniani ia nadua totona,  
\q1 bona iena hesiai kekeni edia gaukara do ia henidia totona.   
\q1
\v 16 Ia ese tano ta ia itaia namonamo,  
\q1 vadaeni ia hoia,  
\q1 bona iena gaukara dekenai ia davaria moni dekena amo,  
\q1 vain huahua umana ia hadoa noho.   
\q1
\v 17 Ia be gaukara auka hahinena,  
\q1 bona mai ena imana goada danu,  
\q1 iena gaukara ia karaia namonamo noho.   
\q1
\v 18 Ia karaia gaudia ibounai edia davana ia diba,  
\q1 bona ia gaukara noho ela bona hanuaboi momokani.   
\q1
\v 19 Ia ese sibona ena dabua turia varona ia karaia noho,  
\q1 bona ia sibona ese dabua ia karaia noho.   
\q1
\v 20 Ia ese ogogami taudia bona gau lasi taudia,  
\q1 dekenai durua ia henia noho.   
\q1
\v 21 Bema sinou ia diho neganai ia laloa momo lasi,  
\q1 badina be iena bese ibounai be mai edia keru dabua rua.   
\q1
\v 22 Ia ese mahuta patana koua dabuana ia karaia,  
\q1 bona dabua namodia, edia kala kakakaka,  
\q1 be ia ese ia atoa noho.   
\q1
\v 23 Iena adavana be taunimanima ibounai ese idia matauraia noho.  
\q1 Ia be hanua ena tau badana ta.   
\q1
\v 24 Ma unai hahine namona ese,  
\q1 dabua namo herea idaudia ia karaia,  
\q1 do ia hoia totona.  
\q1 Gaba gaudia danu ia karaia noho,  
\q1 hoihoi taudia dekenai ia hoidia lao.   
\q1
\v 25 Ia be mai ena goada,  
\q1 bona mai ena kwalimu.  
\q1 Gabeai do idia vara gaudia dekenai ia gari lasi.   
\q1
\v 26 Ia be mai aonega danu ia hereva noho,  
\q1 bona iena hadibaia hereva be maoromaoro,  
\q1 bona mai momokani danu.   
\q1
\v 27 Ia be nega ibounai ia gaukara noho,  
\q1 bona iena famili ia naridia namonamo noho.   
\q1
\v 28 Iena natuna ese ia idia tanikiu henia noho,  
\q1 bona iena adavana ese,  
\q1 ia dekenai ia hanamoa henia noho.   
\q1
\v 29 Ia gwau, “Hahine momo edia kara be namo,  
\q1 to oi sibona ese idia ibounai oi hereaia noho.”   
\q1
\v 30 Hahine momo edia hereva namodia be koikoi bamona,  
\q1 bona edia hairaina be do ia ore haraga.  
\q1 To Lohiabada dekenai ia gari hahinena,  
\q1 be do idia matauraia.   
\q1
\v 31 Unai hahine do umui hanamoa,  
\q1 bona davana namona do umui henia.  
\q1 Taunimanima ibounai ese ia do idia matauraia be namo.   