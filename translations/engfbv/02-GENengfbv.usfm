\v 14 \w God|strong="H8064"\w* said, “\w Let|strong="H1961"\w* \w there|strong="H1961"\w* \w be|strong="H1961"\w* \w lights|strong="H3974"\w* \w in|strong="H8141"\w* \w the|strong="H3117"\w* \w sky|strong="H8064"\w* \w to|strong="H1961"\w* separate \w day|strong="H3117"\w* \w from|strong="H3117"\w* \w night|strong="H3915"\w*, \w and|strong="H3117"\w* \w to|strong="H1961"\w* provide \w a|strong="H3068"\w* way \w to|strong="H1961"\w* mark \w seasons|strong="H4150"\w*, \w days|strong="H3117"\w*, \w and|strong="H3117"\w* \w years|strong="H8141"\w*.  
