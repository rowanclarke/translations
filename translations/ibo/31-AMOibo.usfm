\id AMO - Biblica® Open Igbo Contemporary Bible 2020 
\h Emọs 
\toc1 Emọs 
\toc2 Emọs 
\toc3 Ems 
\mt1 Emọs 
\c 1  
\p  
\v 1 Okwu ndị Emọs kwuru, onye bụ otu nʼime ndị ọzụzụ atụrụ nke obodo Tekoa. Ndị a bụ ọhụ ọ hụrụ banyere Izrel. Ọ hụrụ ọhụ a mgbe Uzaya bụ eze ndị Juda. Nʼoge ahụ kwa ka Jeroboam nwa Joash na-achị Izrel. Ọ hụrụ ọhụ a afọ abụọ tupu oke ala ọma jijiji ahụ adịrị. 
\b  
\b  
\p  
\v 2 Ọ sịrị, 
\q1 \nd Onyenwe anyị\nd* si nʼugwu Zayọn na-ebigbọ, 
\q2 o si na Jerusalem na-eme ka olu ya daa ụda. 
\q1 Ebe ịta nri nke ndị ọzụzụ atụrụ ga-eru ụjụ. 
\q2 Elu ugwu Kamel ga-akpọnwụkwa. 
\s1 Ikpe ọmụma dịrị ndị agbataobi Izrel 
\p  
\v 3 Otu a ka \nd Onyenwe anyị\nd* na-ekwu, 
\q1 “Nʼihi njehie atọ nke Damaskọs, 
\q2 na nʼihi njehie ha nke ugboro anọ, agaghị m ahapụ inye ya ntaramahụhụ. 
\q1 Nʼihi na ha azọpịala ndị m nʼime Gilead, 
\q2 ha ji igwe ịzọcha mkpụrụ ọka nwere eze. 
\q1  
\v 4 Nʼihi ya, aga m esunye ọkụ nʼụlọeze Hazael; 
\q2 ọkụ a ga-erepịakwa ebe niile e wusiri ike nke Ben-Hadad. 
\q1  
\v 5 Aga m etiji ibo ọnụ ụzọ ama Damaskọs, 
\q2 aga m ekpochapụkwa ndị niile bi na Ndagwurugwu Aven, 
\q1 na onye ahụ mkpara eze dị nʼaka ya, nke nọ na Bet-Eden. 
\q2 Ndị Aram ga-abụkwa ndị a dọtara nʼagha, ndị a ga-adọkpụrụ gaa Kia.” 
\q2 Ka \nd Onyenwe anyị\nd* kwuru. 
\p  
\v 6 Otu a ka \nd Onyenwe anyị\nd* na-ekwu, 
\q1 “Nʼihi njehie atọ nke Gaza, 
\q2 e, nʼihi njehie nke anọ, agaghị m ahapụ inye ya ntaramahụhụ, 
\q1 nʼihi na ha dọtara mmadụ niile nʼagha, 
\q2 ranye nʼaka ndị Edọm. 
\q1  
\v 7 Nʼihi ya, aga m esunye ọkụ na mgbidi niile nke Gaza, 
\q2 ebe ya niile e wusiri ike ga-agba ọkụ. 
\q1  
\v 8 Aga m egbu ndị Ashdọd, 
\q2 ma bibiekwa onye ahụ na-achị Ashkelọn. 
\q1 Aga eweli aka m megide ndị Ekrọn, 
\q2 ruo mgbe ndị Filistia fọdụrụ ga-ala nʼiyi.” 
\q2 Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị. 
\p  
\v 9 Otu a ka \nd Onyenwe anyị\nd* na-ekwu, 
\q1 “Nʼihi njehie atọ nke Taịa, 
\q2 e, nʼihi nke anọ, agaghị m ahapụ inye ya ntaramahụhụ. 
\q1 Nʼihi na ha dọkpụrụ ọgbakọ ndị mmadụ renye nʼaka Edọm dịka ohu, 
\q2 ma chefuo ọgbụgba ndụ nwanne na nwanne dị nʼetiti ha. 
\q1  
\v 10 Nʼihi nke a, aga m esunye ọkụ na mgbidi niile nke Taịa; 
\q2 ọ ga-eredakwa ebe ha niile e wusiri ike.” 
\p  
\v 11 \nd Onyenwe anyị\nd* na-ekwu, 
\q1 “Nʼihi njehie atọ nke Edọm, 
\q2 e, nʼihi nke anọ, agaghị m ahapụ inye ya ntaramahụhụ. 
\q1 Nʼihi na o ji mma agha chụọ nwanne ya ọsọ, 
\q2 o meghị ebere, 
\q1 kama, o mere ka iwe ya dịgidesie ike; 
\q2 nrubiga oke nke ọnụma ya akwụsịkwaghị akwụsị. 
\q1  
\v 12 Nʼihi ya, aga m esunye ọkụ na Teman; 
\q2 ọ ga-erekwa nʼebe niile e wusiri ike nke Bozra.” 
\p  
\v 13 Ma otu a ka \nd Onyenwe anyị\nd* na-ekwu, 
\q1 “Nʼihi njehie atọ nke Amọn, 
\q2 e, nʼihi nke anọ, agaghị m ahapụ inye ya ntaramahụhụ, 
\q1 nʼihi na ha were mma agha ha bọwaa afọ ụmụ nwanyị Gilead dị ime, 
\q2 nʼihi ime ka oke ala ha saa mbara. 
\q1  
\v 14 Nʼihi nke a, aga m esunye ọkụ na mgbidi niile nke Raba. 
\q2 Ọ ga-erepịakwa ebe ya niile e wusiri ike. 
\q1 Oke ụzụ agha nke ga-ada dịka ụzụ oke ifufe, 
\q2 na ụzụ egbe eluigwe ga na-ada nʼụbọchị ahụ. 
\q1  
\v 15 Eze ha na ndịisi ọchịchị ya ga-abụ ndị a dọtara nʼagha, 
\q2 ndị ga-aga biri nʼala ọzọ.” 
\q2 Ka \nd Onyenwe anyị\nd* sịrị. 
\c 2  
\p  
\v 1 Otu a ka \nd Onyenwe anyị\nd* sịrị, 
\q1 “Nʼihi njehie atọ nke Moab, 
\q2 e, nʼihi nke anọ, agaghị m ahapụ inye ya ntaramahụhụ. 
\q1 Nʼihi na ha surere ọkpụkpụ eze ndị Edọm ọkụ, 
\q2 mee ha ka ha ghọọ ntụ. 
\q1  
\v 2 Ya mere, aga m ezite ọkụ na Moab, 
\q2 nke ga-erepịa ebe niile e wusiri ike nke Keriọt. 
\q1 Moab ga-anwụ nʼime ọgbaaghara, 
\q2 nʼetiti mkpu agha, na ụda opi ike. 
\q1  
\v 3 Aga m ala onyeisi ọchịchị ya nʼiyi, 
\q2 gbukwaa ndị ozi niile nọ nʼokpuru ya.” 
\q2 Ọ bụ \nd Onyenwe anyị\nd* na-ekwu. 
\p  
\v 4 Otu a ka \nd Onyenwe anyị\nd* sịrị, 
\q1 “Nʼihi njehie atọ nke Juda, 
\q2 e, nʼihi nke anọ, agaghị m ahapụ inye ya ntaramahụhụ. 
\q1 Nʼihi na ha ajụla iwu \nd Onyenwe anyị\nd*. 
\q2 Ha ajụkwala irube isi ha nʼụkpụrụ ya. 
\q1 Ha abụrụla ndị e ji okwu ụgha duhie, 
\q2 bụ okwu ụgha ndị ahụ nna nna ha gbasoro. 
\q1  
\v 5 Nʼihi nke a, aga m esunye ọkụ na Juda, 
\q2 ọ ga-erepịa ebe niile e wusiri ike nke Jerusalem.” 
\s1 Ikpe ọmụma dịrị Izrel 
\p  
\v 6 Otu a ka \nd Onyenwe anyị\nd* sịrị, 
\q1 “Nʼihi njehie atọ nke Izrel, 
\q2 e, nʼihi nke anọ, agaghị m ahapụ inye ya ntaramahụhụ. 
\q1 Ha na-ere ndị ezi omume nʼihi ọlaọcha, 
\q2 reekwa ụmụ ogbenye nʼọnụ ahịa e ji azụ akpụkpọụkwụ abụọ. 
\q1  
\v 7 Ha na-azọpịa isi ndị ike na-adịghị, 
\q2 na-echi ha ọnụ nʼaja, 
\q2 na-ewezuga ndị dị umeala nʼụzọ ezi ihe. 
\q1 Nwoke na nna ya na-edinakwuru otu nwaagbọghọ, 
\q2 si otu a merụọ aha nsọ m. 
\q1  
\v 8 Ha na-edina nʼakụkụ ebe ịchụ aja ọbụla, 
\q2 nʼelu uwe ndị anatara na mbe. 
\q1 Nʼime ụlọnsọ chi ha, 
\q2 ha na-aṅụ mmanya ha natara dịka ihe nra. 
\b  
\q1  
\v 9 “Ma a lara m ndị Amọrait nʼiyi nʼihu ha, 
\q2 ndị ahụ dị ogologo dịka osisi sida, 
\q2 ndị sikwara ike dịka osisi ook. 
\q1 Alara m mkpụrụ ha dị nʼelu, 
\q2 na mgbọrọgwụ ha niile dị nʼokpuru nʼiyi. 
\q1  
\v 10 Esitere m nʼala Ijipt kpọpụta unu, 
\q2 duru unu gafee nʼọzara iri afọ anọ, 
\q2 ime ka unu nweta ala ndị Amọrait. 
\b  
\q1  
\v 11 “Ahọpụtara m ụmụ unu ụfọdụ ka ha bụrụ ndị amụma, 
\q2 họpụtakwa ụfọdụ ndị okorobịa unu ka ha bụrụ Nazirait. 
\q1 Unu ndị Izrel, unu ga-agọ na nke a abụghị eziokwu?” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara ya. 
\q1  
\v 12 “Ma unu mere\f + \fr 2:12 \ft Maọbụ, \fqa kwagidere\f* ka ndị Nazirait ahụ ṅụọ mmanya. 
\q2 Unu nyekwara ndị amụma iwu ka ha kwụsị ibu amụma. 
\b  
\q1  
\v 13 “Nʼihi ya, aga m abịada unu nʼala nʼọnọdụ unu, 
\q2 dịka ụgbọala nke e bujuru ukwu ọka si abịada. 
\q1  
\v 14 Ịgba ọsọ agaghị azọpụta ọ bụladị ndị dị nwe ụkwụ ọsọ, 
\q2 ndị dị ike agaghị agba onwe ha ume, 
\q2 ndị bụ dike nʼagha agaghị azọpụta onwe ha. 
\q1  
\v 15 Ndị na-agba ụta agaghị agbata ihe ọbụla, 
\q2 ndị nwere ụkwụ ọsọ agaghị enwekwa ike ịgba ọsọ. 
\q2 Ọ bụladị onye ịgba ịnyịnya doro anya agakwaghị enwe ike ịgbanarị ihe mberede nke ga-abịakwasị ya. 
\q1  
\v 16 Ndị obi siri ike nʼetiti ndị dike unu, 
\q2 ga-agbara ọtọ gbapụ ọsọ nʼụbọchị ahụ.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\c 3  
\s1 Ndị ama megide Izrel 
\p  
\v 1 Nụrụnụ okwu ndị a nke \nd Onyenwe anyị\nd* kwuru megide unu, unu ndị Izrel, megidekwa ezinaụlọ ahụ niile nke m kpọpụtara site nʼala Ijipt. 
\q1  
\v 2 “Naanị unu ka m họọrọ 
\q2 nʼime ezinaụlọ niile nke nọ nʼelu ụwa; 
\q1 Ọ bụ nʼihi nke a ka m ga-eji nye unu ahụhụ 
\q2 nʼihi mmehie unu niile.” 
\b  
\q1  
\v 3 Mmadụ abụọ ga-esi aṅaa jekọọ ije 
\q2 ma ọ bụrụ na ha enweghị nkwekọrịta? 
\q1  
\v 4 Ọdụm ọ na-agbọ ụja nʼọhịa 
\q2 ma ọ bụrụ na o nweghị anụ ọ hụrụ? 
\q1 Nwa ọdụm ọ na-ebigbọ nʼime olulu ya, 
\q2 mgbe ọ dịghị anụ ọ dọgburu? 
\q1  
\v 5 Nnụnụ ọ na-ama nʼọnya dị nʼala 
\q2 ma ọ bụrụ na o nweghị ọnya e siri ijide ya? 
\q1 Ọnya e siiri anụ ọ na-akụchi 
\q2 ma ọ bụrụ na o nweghị ihe ọ matara? 
\q1  
\v 6 Mgbe a fụrụ opi nʼobodo, 
\q2 ọ bụ na ndị bi nʼime ya adịghị ama jijiji? 
\q1 Mgbe mbibi na ịla nʼiyi dakwasịrị obodo ọbụla 
\q2 ọ bụghị \nd Onyenwe anyị\nd* mere ka ọ dị? 
\b  
\q1  
\v 7 Nʼezie Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* adịghị eme ihe ọbụla 
\q2 tutu ruo mgbe o buru ụzọ gosi ya 
\q2 ndị na-ejere ya ozi bụ ndị amụma. 
\b  
\q1  
\v 8 Ọdụm agbọọla ụja, 
\q2 o nwere onye na-agaghị atụ egwu? 
\q1 Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ekwuola okwu, 
\q2 onye ga-ahapụ ibu amụma? 
\b  
\q1  
\v 9 Kwusaanụ ya nʼobodo niile e wusiri ike nke Ashdọd 
\q2 na ebe niile e wusiri ike nke Ijipt, sị, 
\q1 “Zukọtanụ\f + \fr 3:9 \ft Maọbụ, \fqa Werenụ ọnọdụ unu\f* nʼelu ugwu niile nke Sameria 
\q2 ka unu hụ oke ọgbaaghara nke dị nʼetiti ya 
\q2 na mmegbu niile nke dị nʼetiti ndị ya.\f + \fr 3:9 \ft A na-eme nʼime ya\f*” 
\b  
\q1  
\v 10 “Ha echezọọla ime ezi ihe.” Otu a ka \nd Onyenwe anyị\nd* kwupụtara, 
\q2 “bụ ndị ahụ na-akpakọba ihe e zutere nʼohi na ihe e sitere nʼaka ike pụnara ndị mmadụ 
\q2 nʼime nʼụlọ ha niile e wusiri ike.” 
\p  
\v 11 Nʼihi ya nke a bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, 
\q1 “Onye iro na-abịa! Ọ ga-agba ala gị gburugburu; 
\q2 ọ ga-akwatu ebe niile gị bụ nke e wusiri ike, 
\q2 ma kwakọrọkwa ihe niile dị nʼụlọ gị ndị ahụ e wusiri ike.” 
\p  
\v 12 Otu a ka \nd Onyenwe anyị\nd* sịrị, 
\q1 “Dịka onye ọzụzụ atụrụ si anapụta 
\q2 naanị ọkpụkpụ ụkwụ abụọ maọbụ iberibe ntị site nʼọnụ ọdụm, 
\q1 otu a ka a ga-esi zọpụta ụmụ Izrel bi na Sameria, 
\q2 na nkuku isi ihe ndina\f + \fr 3:12 \ft Ndị na-edina nʼelu akwa dara oke ọnụahịa\f* 
\q2 na nʼiberibe akwa ọma site nʼelu ihe ndina.\f + \fr 3:12 \ft Ọ bụ nʼọnụ akụkụ ihe ndina na akwa ha\f*” 
\p  
\v 13 “Nụrụ nke a, ma gbaanụ ama megide ụmụ Jekọb,” ọ bụ otu a ka Onyenwe anyị, bụ \nd Onyenwe anyị\nd* Chineke Onye pụrụ ime ihe niile, kwubiri. 
\q1  
\v 14 “Nʼụbọchị ahụ, m ga-enye Izrel ahụhụ nʼihi mmehie ha, 
\q2 aghaghị m imebikwa ebe ịchụ aja nke dị na Betel. 
\q1 Mpi dị nʼebe ịchụ aja ka a ga-ebipụkwa, 
\q2 mee ka ha daa nʼala. 
\q1  
\v 15 Aga m etida ụlọ ndị niile ha wuru maka oge oyi, 
\q2 na nke ha wuru maka oge okpomọkụ; 
\q1 aga m ebibikwa ụlọ ndị ahụ niile ha ji ọdụ enyi wuo. 
\q2 Ọtụtụ ebe obibi ha niile ka a ga-etitukwa.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\c 4  
\s1 Izrel alọghachibeghị nʼebe Chineke nọ 
\q1  
\v 1 Nụrụ okwu a, unu nne ehi nke Bashan, ndị na-ebi nʼelu ugwu Sameria, 
\q2 unu ndị inyom na-emegbu ndị ogbenye, ma zọpịakwa ndị mkpa na-akpa, 
\q2 ndị na-asị di ha, “welatara anyị ihe ọṅụṅụ” 
\q1  
\v 2 Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ewerela ịdị nsọ ya ṅụọ iyi, sị, 
\q2 “Ụbọchị ahụ aghaghị ịbịa 
\q1 mgbe a ga-eji nko dọkpụrụ unu pụọ; 
\q2 jiri nko azụ dọkpụrụ ọ bụladị onye ikpeazụ nʼime unu. 
\q1  
\v 3 Ọ bụ site nʼoghere dị iche iche e mere na mgbidi obodo, 
\q2 ka onye ọbụla ga-esi nʼahịrị nʼahịrị pụọ, 
\q2 a ga-atụga unu nʼụzọ Hamon.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1  
\v 4 “Gaanụ na Betel, ma jehie. 
\q2 Jeenụ Gilgal mee ka mmehie baa ụba. 
\q1 Butenụ ihe aja unu ụtụtụ niile. 
\q2 Webatakwanụ onyinye otu ụzọ nʼụzọ iri unu nʼụbọchị atọ\f + \fr 4:4 \ft Maọbụ, \fqa nʼafọ atọ\f* ọbụla. 
\q1  
\v 5 Chụọnụ aja nsure ọkụ dịka aja ekele, site nʼachịcha koro eko; 
\q2 kpọsaakwanụ banyere onyinye afọ ofufu niile unu na-enye, 
\q1 nyaanụ isi banyere ha, unu bụ ndị Izrel, 
\q2 nʼihi na nke a bụ ihe unu hụrụ nʼanya ime.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\b  
\q1  
\v 6 “E mere m ka unu nwee eze dị ọcha\f + \fr 4:6 \ft Eze ha dị ọcha nʼihi erighị nri ọbụla\f* nʼobodo unu niile, 
\q2 mekwa ka ụkọ nri dị nʼọnụmara unu niile 
\q2 ma unu alọghachikwuteghị m.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\b  
\q1  
\v 7 “Ọzọkwa, Mụ onwe m gbochikwara\f + \fr 4:7 \ft Maọbụ, \fqa kwụsịkwara\f* mmiri izoro unu, 
\q2 mgbe ọ fọdụrụ ọnwa atọ tupu owuwe ihe ubi ebido. 
\q1 Enyere m otu obodo mmiri ozuzo, 
\q2 ma gbochie ya izoro obodo nke ọzọ. 
\q1 Mmiri zoro nʼotu ubi, 
\q2 ma nke mmiri ezoghị na ya kpọnwụrụ. 
\q1  
\v 8 Ndị si obodo abụọ maọbụ atọ chọrọ mmiri ọṅụṅụ jee nʼobodo ọzọ, 
\q2 ma ha enwetaghị nke ha ji aṅụju afọ, 
\q2 ma nʼime ihe ndị a niile unu alọghachikwuteghị m.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\b  
\q1  
\v 9 “Ezitere m ọrịa nchakpọ nʼubi unu niile a gbara ogige, ya na ubi vaịnị unu niile, ọtụtụ oge, 
\q2 werekwa ọrịa na-eripịa ihe ubi na ọmụma ebu bibie ha, 
\q1 zitekwa igurube nke richapụrụ osisi fiig na osisi oliv unu niile, 
\q2 ma nke a emeghị ka unu lọghachikwute m.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\b  
\q1  
\v 10 “Ezitere m nʼetiti unu ajọ ọrịa na-efe efe 
\q2 dịka ndị ahụ m zitere ndị Ijipt. 
\q1 Ejiri m mma agha gbuo ụmụ okorobịa unu, 
\q2 mee ka a dọta ịnyịnya agha unu nʼagha. 
\q1 Emere m ka isisi ọjọọ ndị niile nwuru nʼọmụma ụlọ ikwu\f + \fr 4:10 \ft Maọbụ, \fqa ebe obibi\f* unu jupụta imi unu, 
\q2 ma nke a emeghị ka unu lọghachikwute m.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\b  
\q1  
\v 11 “Akwaturu m ụfọdụ nʼime unu 
\q2 dịka mgbe Chineke kwaturu Sọdọm na Gọmọra. 
\q1 Unu dịka ọlọkọ nkụ ọkụ alọpụtara site nʼọkụ, 
\q2 ma unu alọghachikwuteghị m,” 
\q2 otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\b  
\q1  
\v 12 “Nʼihi ya, ihe ndị a ka m na-aga ime gị, gị bụ Izrel. 
\q2 Ebe ọ bụkwa na ejikerela m ime gị ihe ndị a, 
\q2 jikere, O Izrel, izute Chineke gị.” 
\b  
\q1  
\v 13 Ma lee, onye na-akpụ ugwu niile, 
\q2 onye na-ekekwa ifufe, 
\q2 nke na-ekpughekwa echiche uche ya nye mmadụ, 
\q1 onye na-emekwa ka chi ọbụbọ\f + \fr 4:13 \ft Ya bụ, ụtụtụ\f* ghọọ ọchịchịrị, 
\q2 na-azọchakwa ugwu niile nʼọbụụkwụ ya, 
\q2 Onyenwe anyị Chineke Onye pụrụ ime ihe niile bụ aha ya. 
\c 5  
\s1 Abụ akwa na ịkpọ oku maka nchegharị 
\p  
\v 1 Nụrụnụ okwu ndị a, nke a ka m na-ekwu megide unu, ọ bụ mkpu akwa maka gị ezinaụlọ nke Izrel: 
\q1  
\v 2 “Izrel, nwaagbọghọ na-amaghị nwoke, a daala, 
\q2 ọ gaghị ebilite ọzọ, 
\q1 onye a gbahapụrụ nʼala nke aka ya, 
\q2 ọ dịkwaghị onye ga-ekulite ya.” 
\p  
\v 3 Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-asị Izrel, 
\q1 “Obodo unu nke na-ezipụ puku ndị ike, 
\q2 ka naanị narị ga-afọdụ, 
\q1 obodo unu na-ezipụ narị ndị ike 
\q2 ka naanị iri ga-afọdụrụ.” 
\s1 Chọsienụ Chineke ike ka unu dị ndụ 
\p  
\v 4 Ihe ndị a bụ okwu \nd Onyenwe anyị\nd* na-agwa ụlọ Izrel, 
\q1 “Chọọnụ m, ka unu dịrị ndụ. 
\q2  
\v 5 Unu achọla Betel, 
\q1 unu abanyekwala na Gilgal, 
\q2 maọbụ ga ije ruo Bịasheba. 
\q1 Nʼihi na Gilgal aghaghị ije biri nʼala ọzọ, 
\q2 ebe Betel ga-aghọ ebe tọgbọrọ nʼefu.”\f + \fr 5:5 \ft Maọbụ, \fqa ajọ ihe\f* 
\q1  
\v 6 Chọọnụ \nd Onyenwe anyị\nd*, ka unu dịrị ndụ, 
\q2 ka ọ gharakwa iji ike bịakwasị ụlọ Josef, dịka ire ọkụ, 
\q1 ọ ga-erepịa ha. 
\q2 Betel agaghị enwe onye ga-emenyụ. 
\b  
\q1  
\v 7 Unu ndị na-eme ikpe ziri ezi ka ọ ghọọ ihe ilu, 
\q2 na-ekpukwa ezi omume ihu nʼala. 
\b  
\q1  
\v 8 Onye mere kpakpando pleiades na orion, 
\q2 onye na-emekwa ka oke ọchịchịrị ghọọ ụtụtụ, 
\q2 na-emekwa ka ụbọchị ghọọ abalị, 
\q1 onye na-akpọ mmiri nke osimiri oku, 
\q2 wụsa ha nʼelu ala akọrọ, 
\q2 \nd Onyenwe anyị\nd* bụ aha ya. 
\q1  
\v 9 Onye na-eme ka ịla nʼiyi bịakwasị ndị dị ike nʼotu ntabi anya, 
\q2 na-emekwa ka ịla nʼiyi bịakwasị ebe ahụ niile e wusiri ike. 
\b  
\q1  
\v 10 Ọ dị ndị na-akpọ onye na-edebe ikpe ziri ezi nʼụlọikpe asị, 
\q2 na-elelịkwa onye na-ekwu eziokwu anya. 
\b  
\q1  
\v 11 Unu na-azọpịa ndị ogbenye, 
\q2 na-anapụ ha ukwu ọka wiiti ha. 
\q1 Unu ewuolara onwe unu ụlọ nkume a wara awa, 
\q2 ma unu agaghị ebi nʼime ha. 
\q1 Unu akụọla ubi vaịnị mara mma, 
\q2 ma unu agaghị aṅụ ihe ọṅụṅụ ọbụla sitere nʼime ha. 
\q1  
\v 12 Nʼihi na amaara m njehie unu niile, ka ha si baa ụba, 
\q2 matakwa ọtụtụ mmehie unu niile. 
\b  
\q1 Unu na-emegbu ndị ezi omume, na-erikwa ngarị. 
\q2 Ma na-achụpụkwa ndị ọ dịghị nke ha nwere nʼọnụ ụzọ ama. 
\q1  
\v 13 Nʼihi ya, onye nwere uche na-ekpuchi ọnụ ya nʼoge ahụ, 
\q2 nʼihi na oge ndị ahụ dị njọ. 
\b  
\q1  
\v 14 Chọsienụ ezi ihe ike, ọ bụghị ihe ọjọọ; 
\q2 ka unu dịrị ndụ. 
\q1 Mgbe ahụ ka \nd Onyenwe anyị\nd* Chineke, Onye pụrụ ime ihe niile ga-anọnyere unu, 
\q2 dịka unu si kwuo. 
\q1  
\v 15 Kpọọnụ ihe ọjọọ asị, ma hụnụ ezi ihe nʼanya. 
\q2 Meenụ ka ikpe ziri ezi guzosie ike nʼụlọikpe unu. 
\q1 O nwere ike bụrụ na \nd Onyenwe anyị\nd* Chineke Onye pụrụ ime ihe niile 
\q2 ga-enwe amara nʼahụ ndị fọdụụrụ Josef. 
\p  
\v 16 Nʼihi ya, nke a ka \nd Onyenwe anyị,\nd* Chineke Onye pụrụ ime ihe niile, bụ Onyenwe anyị na-asị, 
\q1 “Oke iti mkpu akwa aghaghị ịdị nʼokporoụzọ niile; 
\q2 ọ bụkwa nʼama niile ka ha ga-asị, azịgbakwa, azịgbakwa. 
\q1 A ga-akpọ ndị ọrụ ubi ka ha bịa kwaa akwa, 
\q2 kpọọkwa ndị na-eru ụjụ ka ha bịa tie mkpu akwa. 
\q1  
\v 17 A ga-enwe iti mkpu akwa nʼime ubi vaịnị niile, 
\q2 nʼihi na aga m esi nʼetiti unu gafee,” 
\q2 ka \nd Onyenwe anyị\nd* kwuru. 
\s1 Ụbọchị \nd Onyenwe anyị\nd* 
\q1  
\v 18 Ahụhụ dịrị unu,\f + \fr 5:18 \ft Maọbụ, \fqa Azịgba unu\f* 
\q2 ndị ahụ na-achọsi ụbọchị \nd Onyenwe anyị\nd* ike. 
\q1 Gịnị mere unu ji achọ ụbọchị nke \nd Onyenwe anyị\nd* ahụ? 
\q2 Ụbọchị ahụ ga-abụ ọchịchịrị, ọ bụghị ìhè. 
\q1  
\v 19 Ọ ga-adị ka onye si nʼihu ọdụm na-agbapụ 
\q2 ma zute anụ ọhịa bịa, 
\q1 maọbụ onye gbabara nʼụlọ ya izuike 
\q2 ma tụkwasị aka ya nʼaja ụlọ, 
\q2 agwọ ataa ya. 
\q1  
\v 20 Ụbọchị \nd Onyenwe anyị\nd* ọ gaghị abụ ụbọchị ọchịchịrị, na-abụghị ìhè, 
\q2 nke oke ọchịchịrị, a na-agaghị enwe ìhè ọbụla na ya? 
\b  
\q1  
\v 21 “Akpọrọ m mmemme oriri na ọṅụṅụ unu asị, ajụla m ya. 
\q2 Nnọkọ nke oke nzukọ unu adịghị atọkwa m ụtọ. 
\q1  
\v 22 A sịkwarị na unu bunyere m aja nsure ọkụ unu na aja mkpụrụ ọka unu, 
\q2 agaghị m anabata ha. 
\q1 Aja udo nke anụ unu gbara abụba 
\q2 abụrụghị m ihe ọbụla. 
\q1  
\v 23 Sitenụ nʼebe m nọ wezuga ụzụ ịbụ abụ unu. 
\q2 Agaghị m ege ntị nʼabụ ụbọ akwara unu. 
\q1  
\v 24 Kama meenụ ka ikpe ziri ezi na-asọgharị dịka mmiri, 
\q2 ka ezi omume na-asọgharịbiga oke dịka iyi nke na-adịghị ata ata. 
\b  
\q1  
\v 25 “Iri afọ anọ ndị ahụ unu nọ nʼọzara, 
\q2 unu chụụrụ m aja, unu o wetara m onyinye, unu ụlọ Izrel? 
\q1  
\v 26 Unu ga-ebuli eze unu Sakut elu, 
\q2 na arụsị Kayiwan, chi kpakpando unu, 
\q2 bụ onyinyo unu, na chi niile a kpụrụ akpụ, 
\q2 nke unu kpụrụ nye onwe unu. 
\q1  
\v 27 Ya mere, aghaghị m ime ka e buru unu gaa nʼala ndị ọzọ, nʼofe Damaskọs,” 
\q2 ka \nd Onyenwe anyị\nd*, Onye ahụ aha ya bụ Chineke, Onye pụrụ ime ihe niile kwuru. 
\c 6  
\s1 Ahụhụ dịrị ndị na-ebi ndụ dị jụụ 
\q1  
\v 1 Ahụhụ dịrị ndị ahụ na-enweghị nsogbu nʼime Zayọn, 
\q2 na ndị ahụ na-ebi nʼizuoke nʼugwu Sameria, 
\q1 bụ ndị a maara aha ha na isi mba nke mba niile, 
\q2 ndị agbụrụ Izrel niile na-abịakwute. 
\q1  
\v 2 Gaanụ Kalne, ka unu lee ya anya, 
\q2 site nʼebe ahụ unu jeruo Hamat, obodo ukwu ahụ, 
\q2 mgbe ahụ unu gbada jeruokwa Gat nke dị na Filistia 
\q1 Ha ọ kacha alaeze abụọ unu mma? 
\q2 Ka ala ha ọ karịrị ndị nke unu? 
\q1  
\v 3 Unu na-ewezuga ụbọchị ọjọọ ahụ 
\q2 ma na-eme ka ụbọchị ihe ike bịa ngwangwa. 
\q1  
\v 4 Azịgba unu ndị na-edina nʼelu akwa ọdụ enyi, 
\q2 na-agbatị onwe ha nʼelu ihe ndina ha, 
\q1 na-erikwa anụ ụmụ atụrụ dị mma 
\q2 na ụmụ ehi e mere ka ha gbaa abụba. 
\q1  
\v 5 Ndị na-abụ abụ nke na-abaghị nʼụda ụbọ akwara, 
\q2 ma were aka ha rụọra onwe ha ngwa egwu dịka Devid mere. 
\q1  
\v 6 Unu na-aṅụ mmanya site nʼọba; 
\q2 na-ete mmanụ makarịsịrị mma, 
\q2 ma ịla nʼiyi nke Josef adịghị ewute ha. 
\q1  
\v 7 Nʼihi ya, unu ga-abụ ndị a ga-ebu ụzọ mee ka ha jee biri nʼala ndị ọzọ. 
\q2 Na mberede, oke oriri unu na idina ala setịa onwe unu ga-akwụsị. 
\s1 Mpako bụ ihe arụ nʼihu \nd Onyenwe anyị\nd* 
\p  
\v 8 Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ewerela onwe ya ṅụọ iyi, \nd Onyenwe anyị\nd* Chineke Onye pụrụ ime ihe niile ekwupụtala sị, 
\q1 “Ihe arụ ka mfụli elu nke Jekọb bụrụ m; 
\q2 ana m akpọkwa ebe ya niile e wusiri ike asị. 
\q1 Nʼihi ya, aghaghị m iwere obodo a 
\q2 na ihe niile dị ya nʼime nyefee nʼaka ndị ọzọ.” 
\p  
\v 9 Ma ọ bụrụ na mmadụ iri afọdụ nʼime otu ụlọ, ha niile aghaghị ịnwụ.  
\v 10 Ma ọ bụrụ na nwanna, bụ onye nke na-aga ịkpọ anụ ahụ ndị a ọkụ, abata ibupụ ha nʼezi, ọ jụọ otu onye nọ nʼime ime ụlọ ahụ sị, “O nwere onye ọzọ gị na ya nọ?” Onye ahụ zaa, “Ọ dịghị,” mgbe ahụ nwanna ahụ ga-asị, “Nọọ jụụ. Anyị agaghị akpọ aha \nd Onyenwe anyị\nd*.” 
\q1  
\v 11 Nʼihi na lee, \nd Onyenwe anyị\nd* e nyela iwu. 
\q2 Ọ ghaghị itikpọsị ụlọ ukwu ndị ahụ, 
\q2 tiriekwa ụlọ nta ndị ahụ niile. 
\b  
\q1  
\v 12 Ịnyịnya ọ na-agba ọsọ nʼelu nkume? 
\q2 Mmadụ ọ na-eji ehi abụọ e jikọtara ọnụ akọ elu osimiri? 
\q1 Ma unu atụgharịala ikpe ziri ezi mee ya ka ọ ghọọ nsi, 
\q2 mkpụrụ nke ezi omume ka unu mekwara ka ọ ghọọ ihe ilu. 
\q1  
\v 13 Unu ndị na-aṅụrị ọṅụ nʼihi na unu meriri obodo Lo Deba,\f + \fr 6:13 \ft Ya bụ, ihe na-abaghị uru\f* 
\q2 ndị na-asị, “Ọ bụghị site nʼike aka anyị ka anyị nwetakwara Kanaịm?”\f + \fr 6:13 \fq Kanaịm \ft pụtara \fqa mpi; \fqa mpi \ft nʼebe mpi na-egosi ịdị ike.\f* 
\b  
\q1  
\v 14 “Ma lee, aghaghị m ime ka otu mba bilie imegide unu, ụlọ Izrel,” 
\q2 otu a ka \nd Onyenwe anyị\nd* Chineke Onye pụrụ ime ihe niile kwubiri ya. 
\q1 “Ha ga-emekpa unu ahụ site nʼụzọ niile 
\q2 site na Lebo Hamat ruo ndagwurugwu Araba.” 
\c 7  
\s1 Igurube, ọkụ na ihe ịtụ mgbidi 
\p  
\v 1 Ihe a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* mere ka m hụ. Lee, ọ na-akwado igwe igurube nke ga-abịa bibie ihe ubi niile ga-etopụta mgbe e burula ụzọ wee ihe ubi nke mbụ nke a na-enye eze, dịka ihe ruuru ya.  
\v 2 Mgbe ha tachara ahịhịa niile dị nʼala ahụ, etiri m mkpu: “Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* biko arịọọ m gị, gbaghara. Jekọb ọ ga-esi aṅa guzosie ike? Lee, ọ dịkarịrị nta.” 
\p  
\v 3 \nd Onyenwe anyị\nd* chegharịrị banyere ihe ndị a. 
\p \nd Onyenwe anyị\nd* kwuru sị, “Ihe dị otu a agaghị emekwa.” 
\p  
\v 4 Ihe a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* gosiri m: Lee, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-akpọku ọkụ iji ya kpee ikpe. Ọkụ ahụ repịara ogbu mmiri, repịakwa ala ahụ niile.  
\v 5 Mgbe ahụ, asịrị m, “Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* biko, arịọọ m gị kwụsị! Olee otu Jekọb ga-esi guzosie ike? Lee na ọ dịkarịrị nta!” 
\p  
\v 6 \nd Onyenwe anyị\nd* chegharịrị banyere ihe ndị a. 
\p Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, “Ihe dị otu a agaghị emekwa.” 
\b  
\p  
\v 7 Nke a ka o gosiri m, lee, Onyenwe anyị na-eguzo nʼakụkụ mgbidi nke e ji ihe ịtụ mgbidi tụọ nke ọma, o jikwa ihe ịtụ mgbidi nʼaka ya.  
\v 8 \nd Onyenwe anyị\nd* sịrị m, “Emọs, gịnị ka ị na-ahụ?” 
\p Asịrị m, “Ihe ịtụ mgbidi.” 
\p Mgbe ahụ, Onyenwe anyị kwuru, “Lee, mụ onwe m na-edo ihe ịtụ mgbidi nʼetiti ndị m bụ Izrel, agaghịkwa m esi ebe ha nọ gafee. 
\q1  
\v 9 “Ebe niile e wuliri elu nke Aịzik aghaghị ịbụ ebe e mebiri emebi, 
\q2 ebe nsọ niile nke Izrel aghaghị ịbụ ebe tọgbọrọ nʼefu, 
\q2 aghakwaghị m iweli mma agha m elu iji megide ụlọ Jeroboam.” 
\s1 Emọs na Amazaya 
\p  
\v 10 Mgbe ahụ, Amazaya onye nchụaja nọ na Betel zigaara Jeroboam bụ eze Izrel ozi na-asị, “Emọs na-akwalị izu nzuzo ka ọ megide gị nʼetiti ụlọ Izrel, ala apụghị ibu okwu niile sị ya nʼọnụ apụta.  
\v 11 Nke bụ ihe Emọs nọ na-asị, 
\q1 “ ‘Jeroboam aghaghị ịnwụ site na mma agha, 
\q2 Izrel aghakwaghị isite nʼala amụrụ ha jee biri nʼala ọzọ, 
\q2 dịka ndị a dọtara nʼagha.’ ” 
\p  
\v 12 Mgbe ahụ, Amazaya gwara Emọs, “Gị onye ọhụ ụzọ, gbara ọsọ gbalaa ala Juda. Jee nʼebe ahụ, rie achịcha nke sitere nʼibu amụma gị, nọrọkwa nʼebe ahụ buo amụma gị.  
\v 13 Ebula amụma ọzọ na Betel, nʼihi na ọ bụ ebe nsọ nke eze, ọ bụkwa ụlọnsọ ukwu nke alaeze ya.” 
\p  
\v 14 Mgbe ahụ, Emọs zaghachiri Amazaya, “Ọ dịghị mgbe m bụ onye amụma, abụkwaghị m nwa onye amụma, kama abụ m onye na-elekọta igwe ewu na atụrụ, na onye ọrụ na-azụ osisi sikamọ.  
\v 15 Ma \nd Onyenwe anyị\nd* sitere nʼebe ịzụ igwe ewu na atụrụ kpọpụta m, Onyenwe anyị sịrị m: ‘Gaa buoro ndị m Izrel amụma.’  
\v 16 Nʼihi ya, ugbu a nụrụ okwu \nd Onyenwe anyị\nd*, ma unu na-asị, 
\q1 “ ‘Ebula amụma megide Izrel, 
\q2 ekwukwala okwu megide ụlọ Aịzik.’ 
\p  
\v 17 “Ya mere, otu a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “ ‘Nwunye gị ga-aghọ nwanyị na-agba akwụna nʼime obodo. 
\q2 Ụmụ gị ndị nwoke na ndị nwanyị ka a ga-eji mma agha gbuo. 
\q1 A ga-atụ ala gị nʼihe ọtụtụ, kewasịa ya nye ndị ọzọ, 
\q2 ma gị onwe gị ga-anwụ nʼala rụrụ arụ. 
\q1 A ghakwaghị ịdọta Izrel nʼagha 
\q2 mee ka ha gaa biri nʼala ndị mba ọzọ.’ ” 
\c 8  
\s1 Nkata mkpụrụ chara acha 
\p  
\v 1 Ihe a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* gosiri m. Otu nkata nke mkpụrụ osisi ọkọchị chara acha jupụtara.  
\v 2 Ọ sịrị m, “Emọs, gịnị ka ị na-ahụ?” 
\p A sịrị m: “Otu nkata nke mkpụrụ osisi chara acha jupụtara nʼime ya.” 
\p Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị m, “Oge ọgwụgwụ abịakwasịla ndị m, Izrel. Agaghị m ewezugakwa ntaramahụhụ dịrị ha.” 
\p  
\v 3 Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara, “Nʼụbọchị ahụ, abụ niile nke a na-abụ nʼime ụlọnsọ ukwu ga-aghọ iti mkpu akwa. Ọtụtụ, ọtụtụ ozu ndị nwụrụ anwụ, nʼebe niile ọbụla ka atụpụsịrị ha! Mkpọtụ ọbụla adịghịkwa!”\f + \fr 8:3 \ft Ya bụ, ebe ọbụla dere juu\f* 
\q1  
\v 4 Nụrụnụ nke a, unu ndị na-azọpịa ndị mkpa na-akpa, 
\q2 na-emekwa ka ụmụ ogbenye dị nʼala a gwụsịa, 
\m  
\v 5 na-asị, 
\q1 “Olee mgbe ọnwa ọhụrụ ga-agafe 
\q2 ka anyị ree mkpụrụ ubi, 
\q1 na mgbe ụbọchị izuike ga-agwụ 
\q2 ka anyị ree ọka wiiti?” 
\q1 Ka anyị jiri ihe ọtụtụ dị nta, 
\q2 na ibuli ọnụ ngwa ahịa elu, 
\q2 na aghụghọ site nʼiji ihe ọtụtụ na-ezughị ezu. 
\q1  
\v 6 Jiri ọlaọcha zụta ụmụ ogbenye, 
\q2 jirikwa akpụkpọụkwụ abụọ anyị zụta ndị mkpa na-akpa, 
\q2 ma reekọta ọka wiiti anyị zachatara nʼala ya na ezi ọka wiiti. 
\p  
\v 7 \nd Onyenwe anyị\nd* ewerela nganga Jekọb ṅụọ iyi, “Nʼezie, agaghị m echefu, ọ bụladị otu nʼime ọrụ niile ha rụrụ.” 
\q1  
\v 8 Ọ bụ na ala agaghị ama jijiji nʼihi nke a, 
\q2 ndị niile bi nʼime ya ha agaghị eru ụjụ? 
\q1 Ala a niile ga-etoju dịka osimiri Naịl, 
\q2 a ga-eme ka ọ magharịa malie elu, ma tachaa 
\q2 dịka iyi Ijipt. 
\p  
\v 9 “Ma nʼụbọchị ahụ,” otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya, 
\q1 “Aga m eme ka anyanwụ daa\f + \fr 8:9 \ft Ya bụ, ime ka chi jie\f* nʼetiti ehihie, 
\q2 ime ka ọchịchịrị dịrị nʼetiti oke ehihie nke ụbọchị. 
\q1  
\v 10 Aghaghị m ime ka ụbọchị oke oriri unu ghọọ ụbọchị iru ụjụ; 
\q2 gbanwee abụ unu niile ka ha ghọọ abụ akwa. 
\q1 Aga m eme ka onye ọbụla nʼime unu yiri akwa mkpe, 
\q2 meekwa ka unu kpụchaa isi unu. 
\q1 Aga m eme ka ụbọchị ahụ dịrị ka ụbọchị a na-eru ụjụ, nʼihi otu mkpụrụ nwa nwoke nwụrụ anwụ. 
\q2 Ọgwụgwụ ya ga-adịka ụbọchị na-elu ilu ilu. 
\b  
\q1  
\v 11 “Lee, ụbọchị ndị ahụ na-abịa,” otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya, 
\q2 “mgbe m ga-eziga oke ụnwụ nʼelu ala, 
\q1 ọ bụghị ụnwụ nke nri maọbụ nke akpịrị ịkpọ nkụ nke mmiri, 
\q2 kama ọ bụ oke ụnwụ nke ịnụ okwu niile nke \nd Onyenwe anyị\nd*. 
\q1  
\v 12 Ha ga-awagharị site nʼotu osimiri ruo nʼosimiri ọzọ, 
\q2 sitekwa nʼugwu ruo nʼọwụwa anyanwụ; 
\q1 ha ga-agbagharị nʼelu na ala ịchọ okwu \nd Onyenwe anyị\nd*, 
\q2 ma ha agaghị achọta ya. 
\p  
\v 13 “Nʼụbọchị ahụ, 
\q1 “ụmụ agbọghọ ndị mara mma ile anya, na ụmụ okorobịa ndị dị ike 
\q2 ga-ada mba nʼihi akpịrị ịkpọ nkụ. 
\q1  
\v 14 Ndị ahụ na-eji mmehie Sameria na-aṅụ iyi,\f + \fr 8:14 \ft Nʼaha Ashima bụ arụsị\f* 
\q2 ndị na-asị, ‘Dịka chi gị na-adị ndụ, gị Dan,’ 
\q2 nakwa, ‘Ebe ọ bụ na chi ndị Bịasheba na-adị ndụ,’ 
\q2 ha ga-ada, ha agakwaghị ebilite ọzọ.” 
\c 9  
\s1 A ga-ebibi Izrel 
\p  
\v 1 Ahụrụ m Onyenwe anyị ka ọ guzo nʼakụkụ ebe ịchụ aja, ọ sịrị, 
\q1 “Tie ọnụ ogidi ndị a ihe, 
\q2 ruo mgbe mbata ọnụ ụzọ ha niile mara jijiji. 
\q1 Tipịasịa ha nʼisi mmadụ niile; 
\q2 aga m ejikwa mma agha gbuo ndị niile fọdụrụ. 
\q1 Ọ dịghị onye ga-agbapụ, 
\q2 ọ dịkwaghị onye ga-ewezuga onwe ya. 
\q1  
\v 2 Ọ bụrụ na ha egwuo ala ruo nʼala mmụọ, 
\q2 site nʼebe ahụ ka aka m ga-esi dọlie ha, 
\q1 ọ bụrụkwa na ha arịgoruo ime eluigwe, 
\q2 site nʼebe ahụ ka m ga-esi wedata ha nʼala. 
\q1  
\v 3 Ọ bụrụkwa na ha ezoo onwe ha nʼelu Kamel 
\q2 nʼebe ahụ ka m ga-esi chọpụta ha, kpụrụ ha, 
\q1 a sịkwa na ha ezoo onwe ha nʼala oke osimiri, 
\q2 nʼebe ahụ ka m ga-enye ajụala nke mmiri iwu ka ọ taa ha. 
\q1  
\v 4 Ọ bụrụ na a dọta ha nʼagha mee ka ha gaa biri nʼala ndị mba ọzọ, 
\q2 nʼebe ahụ aga m enye mma agha iwu ka o gbuo ha. 
\b  
\q1 “Aga m elekwasị ha anya m abụọ 
\q2 nʼihi ime ha ihe ọjọọ, ọ bụghị ihe ọma.” 
\b  
\q1  
\v 5 Onyenwe anyị, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, 
\q1 onye na-emetụ ala aka mee ka ọ gbazee, 
\q2 ime ka ndị niile bi nʼala ruo ụjụ; 
\q1 ala ya niile bilie na-ebili dịka mmiri nke osimiri Naịl, 
\q2 nke na-emesịakwa dajụọ dịka mmiri Ijipt. 
\q1  
\v 6 Onye na-ewu ụlọ elu ya nʼeluigwe niile, 
\q2 na-eme ka ntọala ya dị nʼụwa. 
\q1 Onye na-akpọ mmiri nke osimiri oku, 
\q2 ma na-awụsa ha nʼala, 
\q2 aha ya bụ \nd Onyenwe anyị\nd*. 
\b  
\q1  
\v 7 “Ọ bụ na unu ndị Izrel 
\q2 adịghị ka ndị Kush nʼebe m nọ?” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1 “Ọ bụ na-esighị m nʼala Ijipt kpọpụta Izrel, 
\q2 site na Kafto kpọpụta ndị Filistia, 
\q2 ma kpọpụtakwa ndị Aram site na Kia? 
\b  
\q1  
\v 8 “Nʼezie, anya Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* dịkwasịrị 
\q2 nʼahụ alaeze ahụ nke na-emehie. 
\q1 Aghaghị m ịla ya nʼiyi, 
\q2 kpochapụ ya site nʼelu ụwa, 
\q1 naanị na m agaghị ebibicha 
\q2 ụlọ Jekọb kpamkpam.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1  
\v 9 “Ma lee, mụ onwe m gaje inye iwu, 
\q2 aga m ayọgharị ụlọ Izrel 
\q2 nʼetiti mba niile 
\q1 dịka e si ayọgharị ọka nʼime nyọ, 
\q2 ma ọ dịghị otu mkpụrụ ọka nʼime ya nke ga-ada nʼala. 
\q1  
\v 10 Ma ndị mmehie ahụ niile nọ nʼetiti ndị m, 
\q2 ndị ahụ na-asị, ‘Mbibi agaghị erute anyị, 
\q1 anyị agaghị ezute ya, 
\q2 aghaghị ịnwụ site na mma agha.’ 
\s1 Nlọta ndị Izrel 
\p  
\v 11 “Nʼụbọchị ahụ, 
\q1 “aga m emekwa ka ụlọ ikwu Devid dara ada guzoziekwa. 
\q2 Aga m emezi akụkụ ya niile gbajiri agbaji, 
\q2 mee ka akụkụ ya niile dakpọsịrị adakpọsị guzozie dịka ọ dị na mbụ. 
\q2 Aga m ewugharịkwa ya, mee ka ọ dịrị ka ọ dị na mbụ. 
\q1  
\v 12 Ka ha nwee ike inweta ndị fọdụrụ nʼEdọm 
\q2 tinyere mba niile dị iche iche bụ nke a kpọkwasịrị aha m.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* onye ga-emezu ihe ndị a niile kwubiri ya. 
\p  
\v 13 “Ụbọchị ndị ahụ na-abịa, otu a ka \nd Onyenwe anyị\nd* kwubiri, 
\q1 “Mgbe onye na-akọ ubi ga-agafe onye na-ewe ihe ubi, 
\q2 onye na-agha mkpụrụ ka onye na-azọcha mkpụrụ vaịnị ga-agafekwa. 
\q1 Mmanya ọhụrụ ga-esitekwa nʼelu ugwu na-atapụta, 
\q2 ọ ga-esitekwa nʼugwu nta niile na-asọpụta. 
\q2  
\v 14 Aga m emekwa ka ndị m bụ Izrel site nʼobodo a dọtara ha nʼagha lọta.\f + \fr 9:14 \ft Aga m emekwa ka ndị m Izrel nwetakwa ihe ọma niile.\f* 
\b  
\q1 “Ha ga-ewugharị obodo niile tọgbọrọ nʼefu, birikwa nʼime ha. 
\q2 Ha ga-akụ ubi vaịnị a gbara ogige, ṅụọkwa mmanya si na ya. 
\q2 Ha ga-arụkwa ubi a gbara ogige, riekwa mkpụrụ si na ya. 
\q1  
\v 15 Aga m akụ Izrel nʼala ha.\f + \fr 9:15 \ft Ya bụ, ime ka ha biri nʼala ha\f* 
\q2 A gaghị ehopukwa ha ọzọ 
\q2 site nʼala ahụ bụ nke m nyere ha.” 
\m Ọ bụ ihe \nd Onyenwe anyị\nd* Chineke unu kwuru.