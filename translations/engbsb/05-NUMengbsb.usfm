\pmo
\v 16 \w The|strong="H3605"\w* \w total|strong="H3605"\w* \w number|strong="H6485"\w* \w of|strong="H6635"\w* \w men|strong="H3605"\w* \w in|strong="H6635"\w* \w the|strong="H3605"\w* divisions \w of|strong="H6635"\w* \w the|strong="H3605"\w* \w camp|strong="H4264"\w* \w of|strong="H6635"\w* \w Reuben|strong="H7205"\w* \w is|strong="H3605"\w* 151,450; \w they|strong="H3605"\w* \w shall|strong="H6635"\w* \w set|strong="H5265"\w* \w out|strong="H5265"\w* \w second|strong="H8145"\w*.   
