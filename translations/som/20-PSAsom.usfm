\id PSA
\h SABUURRADII
\mt1 SABUURRADII
\c 1
\ms1 Kitaabka Kowaad
\mr Sabuurrada 1-41
\q1 
\v 1 Waxaa barakaysan ninkii aan ku socon talada kuwa sharka leh,
\q1 Oo aan istaagin jidka dembilayaasha,
\q1 Oo aan ku fadhiisan kursiga kuwa wax quudhsada.
\q1 
\v 2 Laakiinse waxaa isaga ka farxiya sharciga Rabbiga,
\q1 Oo habeen iyo maalinba sharcigiisuu ka fikiraa.
\q1 
\v 3 Oo wuxuu ahaan doonaa sida geed lagu beeray durdurrada biyaha agtooda,
\q1 Oo midhihiisa dhala xilligooda,
\q1 Oo aan caleentiisuna engegin.
\q1 Oo wax alla wuxuu sameeyoba wuu ku liibaani doonaa.
\q1 
\v 4 Laakiinse kuwa sharka lahu sidaas ma aha,
\q1 Iyaguse waxay la mid yihiin buunshaha dabayshu kaxayso.
\q1 
\v 5 Sidaas daraaddeed kuwa sharka lahu isma dhex taagi doonaan xukunka,
\q1 Dembilayaashuna sooma dhex geli doonaan kuwa xaqa ah ururkooda.
\q1 
\v 6 Waayo, Rabbigu waa yaqaan kuwa xaqa ah jidkooda,
\q1 Laakiinse kuwa sharka ah jidkoodu waa baabbi'i doonaa.
\b
\c 2
\q1 
\v 1 Bal quruumuhu maxay u cadhoodaan,
\q1 Dadkuna maxay ugu fikiraan wax aan waxba ahayn?
\q1 
\v 2 Boqorrada dhulku col bay u taagan yihiin,
\q1 Taliyayaashuna waxay u wada tashadaan
\q1 Rabbiga iyo Masiixiisa, iyagoo leh,
\q1 
\v 3 Silsiladahooda aan gooyno
\q1 Oo xadhkahoodana aan iska fogayno.
\q1 
\v 4 Kan samada fadhiyaa wuu qosli doonaa,
\q1 Oo Sayidku iyaga wuu ku majaajiloon doonaa.
\q1 
\v 5 Markaasuu isagoo cadhaysan iyaga la hadli doonaa,
\q1 Oo wuxuu iyaga ku dhibi doonaa dhirifkiisa isagoo leh,
\q1 
\v 6 Anigu boqorkaygii waxaan fadhiisiyey
\q1 Buurtayda quduuska ah oo Siyoon.
\q1 
\v 7 Amarkii ayaan wax ka sheegi doonaa,
\q1 Rabbigu wuxuu igu yidhi, Adigu waxaad tahay wiilkayga,
\q1 Maantaan ku dhalay.
\q1 
\v 8 I bari oo waxaan dhaxal ahaan kuu siin doonaa quruumaha,
\q1 Oo dunida meelaha ugu fogfogna hanti ahaan baan kuu siin doonaa.
\q1 
\v 9 Waxaad iyaga ku jejebin doontaa ul bir ah,
\q1 Oo waxaad u burburin doontaa sida weelka dheryasameeyaha.
\q1 
\v 10 Haddaba sidaas daraaddeed, Boqorradow, caqli yeesha,
\q1 Oo xaakinnada dhulkow, edeb yeesha.
\q1 
\v 11 Rabbiga cabsi ugu adeega,
\q1 Oo reyreeya idinkoo gariiraya.
\q1 
\v 12 Wiilka dhunkada, waaba intaasoo uu idiin cadhoodaa oo aad jidka ku baabba'daane.
\q1 Waayo, cadhadiisu haddiiba way kululaan doontaa.
\q1 Waxaa barakaysan kuwa isaga isku halleeya oo dhan.
\c 3
\s2 Kanu waa sabuur Daa'uud tiriyey markuu wiilkiisa Absaaloom ka cararay.
\q1 
\v 1 Rabbiyow, cadaawayaashaydu fara badanaa!
\q1 Kuwa igu kacaa aad bay u badan yihiin.
\q1 
\v 2 Way badan yihiin kuwa naftayda wax ka sheegaa, iyagoo leh,
\q1 Ilaah isaga caawin maayo. (Selaah)
\q1 
\v 3 Laakiinse, Rabbiyow, adigu waxaad tahay gaashaan igu wareegsan,
\q1 Iyo sharaftayda, iyo kan madaxayga kor u qaada.
\q1 
\v 4 Codkayga ayaan Rabbiga ugu qayliyaa,
\q1 Oo isaguna wuxuu iiga jawaabaa buurtiisa quduuska ah. (Selaah)
\q1 
\v 5 Anigu waan jiifsaday oo waan iska seexday,
\q1 Oo haddana waan soo toosay, waayo, Rabbiga ayaa i xannaaneeya.
\q1 
\v 6 Ka baqi maayo dadka kumanyaalkaa,
\q1 Oo gees kasta iga hareereeyey.
\q1 
\v 7 Kac, Rabbiyow, oo i badbaadi, Ilaahayow,
\q1 Waayo, cadaawayaashaydii oo dhan waxaad ku dhufatay dhabanka,
\q1 Oo kuwa sharka leh ilkahoodiina waad jejebisay.
\q1 
\v 8 Badbaado waxaa leh Rabbiga,
\q1 Barakadaadu dadkaaga ha ku soo degto. (Selaah)
\c 4
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu qaadaa alaab xadhko leh oo muusiko ah.
\q1 
\v 1 Ilaaha xaqnimadaydow, markii aan ku baryo i maqal,
\q1 Markii aan cidhiidhi ku jirayba meel baad ii bannaysay,
\q1 Ii naxariiso oo baryadayda maqal.
\q1 
\v 2 Binu-aadmigow, ilaa goormaa sharaftaydu sharafjab u rogmanaysaa?
\q1 Ilaa goormaad wax aan micne lahayn jeclaanaysaan?
\q1 Oo ilaa goormaad been doondoonaysaan? (Selaah)
\q1 
\v 3 Laakiinse ogaada in Rabbigu gooni ahaan isugu soocay kii cibaado leh,
\q1 Rabbigu wuu maqli doonaa markii aan u yeedho isaga.
\q1 
\v 4 Cadhooda oo ha dembaabina,
\q1 Qalbigiinna la hadla markii aad sariirtiinna ku jiiftaan, oo aamusa. (Selaah)
\b
\q1 
\v 5 Bixiya allabaryadii xaqnimada,
\q1 Oo Rabbiga isku halleeya.
\q1 
\v 6 Waxaa jira kuwo badan oo yidhaahda, Bal yaa wanaag na tusaya?
\q1 Rabbiyow, iftiinka wejigaaga nagu ifi.
\q1 
\v 7 Waxaad qalbigayga gelisay farxad
\q1 Ka sii badan tan ay helaan markii hadhuudhkooda iyo khamrigoodu ay kordhaan.
\q1 
\v 8 Nabad baan ku jiifsanayaa oo aan ku seexanayaa,
\q1 Waayo, Rabbiyow, adigoo keliya ayaa ammaan igu bariiya.
\c 5
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu qaadaa alaab la afuufo oo muusika ah.
\q1 
\v 1 Rabbiyow, bal hadalladayda dhegta u dhig,
\q1 Oo ka fiirso fikirradayda.
\q1 
\v 2 Boqorkayga iyo Ilaahaygow, bal maqal codka baryadayda,
\q1 Waayo, adigaan kuu tukanayaa.
\q1 
\v 3 Rabbiyow, codkayga aroorta baad maqli doontaa,
\q1 Oo aroorta ayaan tukashadayda kugu soo hagaajin doonaa, oo waan soo jeedi doonaa.
\q1 
\v 4 Waayo, adigu ma ihid Ilaah xumaanta ku farxa,
\q1 Oo shar adiga kula jiri maayo.
\q1 
\v 5 Kan ismadax-weyneeya hortaada soo istaagi maayo,
\q1 Oo waxaad neceb tahay xumaanfalayaasha oo dhan.
\q1 
\v 6 Waad wada baabbi'in doontaa kuwa beenta ku hadla,
\q1 Rabbigu aad buu u karhaa kan dhiigyacabka ah iyo khaa'inkaba.
\q1 
\v 7 Laakiinse anigu kalgacaylkaaga badan ayaan gurigaaga ku soo gelayaa,
\q1 Oo anigoo kaa cabsanaya ayaan xagga macbudkaaga quduuska ah u soo tukan doonaa.
\q1 
\v 8 Rabbiyow, cadaawayaashayda daraaddood xaqnimadaada igu hoggaami,
\q1 Oo jidkaaga hortayda ku toosi.
\q1 
\v 9 Waayo, afkooda daacadnimo kuma jirto,
\q1 Oo uurkooda hoosena waa xumaan miidhan,
\q1 Hungurigooduna waa qabri af bannaan,
\q1 Oo carrabkooduna waa sasabasho miidhan.
\q1 
\v 10 Ilaahow, iyaga kuwo eed leh ku tiri,
\q1 Oo iyagu taladooda ha ku baabbe'een,
\q1 Oo xadgudubkooda batay daraaddiis u tuur iyaga,
\q1 Waayo, way kugu caasiyoobeen.
\q1 
\v 11 Laakiinse kuwa adiga isku kaa halleeya oo dhammu ha reyreeyeen,
\q1 Oo farxad ha ku qayliyeen weligoodba, maxaa yeelay, adigaa daafaca iyaga,
\q1 Kuwa magacaaga jeceluna adiga ha kugu farxeen.
\q1 
\v 12 Waayo, Rabbiyow, kii xaq ah waad barakayn doontaa,
\q1 Oo waxaad hareerihiisa ku wareejinaysaa raallinimo sidii gaashaan oo kale.
\c 6
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu qaadaa alaab xadhko leh oo muusiko ah, oo Shemiiniid lagu luuqeeyo.
\q1 
\v 1 Rabbiyow, cadhadaada ha igu canaanan,
\q1 Oo dhirifkaaga kululna ha igu edbin.
\q1 
\v 2 Rabbiyow, ii naxariiso, waayo, anigu waan taagdaranahay,
\q1 Rabbiyow, i bogsii, waayo, lafahaygu way dhib qabaan.
\q1 
\v 3 Oo weliba naftayduna aad iyo aad bay u dhibaataysan tahay,
\q1 Adiguse, Rabbiyow, ilaa goormaad sugaysaa?
\q1 
\v 4 Rabbiyow, soo noqo oo naftayda samatabbixi,
\q1 Oo igu badbaadi raxmaddaada daraaddeed.
\q1 
\v 5 Waayo, geeridu ma leh xusuus adiga lagugu xusuusto,
\q1 Bal yaase She'ool kaaga mahadnaqi doona?
\q1 
\v 6 Waxaan la daalay jibaadkayga,
\q1 Habeen kasta sariirtayda oohin baan ku qoyaa.
\q1 Gogoshaydana waxaan ku qoyaa ilmadayda.
\q1 
\v 7 Ishaydu waxay la gudhaysaa tiiraanyo,
\q1 Oo cadaawayaashayda daraaddood ayay la gabowdaa.
\q1 
\v 8 Iga taga, kuwiinna xaqdarrada ka shaqeeya oo dhammow,
\q1 Waayo, Rabbigu waa maqlay codkii oohintayda.
\q1 
\v 9 Rabbigu waa maqlay baryootankaygii,
\q1 Oo Rabbigu waa aqbalayaa tukashadayda.
\q1 
\v 10 Cadaawayaashayda oo dhammu way wada ceeboobi doonaan, oo aad iyo aad bay u dhibtoon doonaan,
\q1 Dib bay u noqon doonaan, oo si kediso ah ayay u ceeboobi doonaan.
\c 7
\s2 Kanu waa sabuur Shiggayoon ah oo Daa'uud Rabbiga ugu gabyay, oo ku saabsan Kuush oo ahaa reer Benyaamiin.
\q1 
\v 1 Rabbiyow, Ilaahayow, adigaan isku kaa halleeyaa,
\q1 Haddaba iga badbaadi kuwa i eryanaya oo dhan, oo iga samatabbixi,
\q1 
\v 2 Waaba intaasoo ay naftayda sida libaax oo kale u kala dildillaaciyaane,
\q1 Oo ay i kala jeexjeexaan intii aanay jirin cid iga samatabbixisaa.
\q1 
\v 3 Rabbiyow, Ilaahayow, haddii aan waxan sameeyey,
\q1 Haddii xumaanu gacmahayga ku jirto,
\q1 
\v 4 Haddii aan shar ugu abaalguday mid ila nabad ah,
\q1 (Haah, oo waxaan samatabbixiyey kii sababla'aan cadowga iigu ahaa,)
\q1 
\v 5 De markaas cadowgu naftayda ha eryado, oo ha qabsado,
\q1 Oo isagu ha igu tunto,
\q1 Oo sharaftaydana ciidda ha ku rido. (Selaah)
\q1 
\v 6 Rabbiyow, cadhadaada la kac,
\q1 Oo ku kac dhirifka cadaawayaashayda,
\q1 Aniga daraadday u sara joogso, waayo, waxaad amartay xukun.
\q1 
\v 7 Oo dadyowga ururradoodu ha ku hareereeyeen,
\q1 Oo adna iyaga xagga sare uga noqo.
\q1 
\v 8 Rabbigu dadyowga buu u garsooraa,
\q1 Rabbiyow, ii xukun siday xaqnimadaydu tahay, iyo siday daacadnimadayda igu jirtaa tahay.
\q1 
\v 9 Kuwa sharka leh sharkoodu ha dhammaado, laakiinse xoogee kuwa xaqa ah,
\q1 Waayo, Ilaaha xaqa ahu wuxuu imtixaamaa qalbiga iyo uurka.
\q1 
\v 10 Gaashaankaygu wuxuu la jiraa Ilaaha
\q1 Badbaadiya kuwa qalbigoodu qumman yahay.
\q1 
\v 11 Ilaah waa xaakin xaq ah,
\q1 Oo waa Ilaah maalin kasta dhirifsan.
\q1 
\v 12 Haddii aan laga noqon, isagu seeftiisuu afaysan doonaa,
\q1 Qaansadiisana wuu xootay, oo wuu diyaarsaday.
\q1 
\v 13 Oo weliba wuxuu diyaarsaday alaabtii dhimashada,
\q1 Oo fallaadhihiisana wuxuu ka dhigtaa kuwo ololaya.
\q1 
\v 14 Bal eega, ninku wuxuu la dhibtoodaa xumaan,
\q1 Oo wuxuu wallacay belaayo, oo wuxuu dhalay been.
\q1 
\v 15 Booraan buu sameeyey, oo uu qoday,
\q1 Oo wuxuu ku dhacay bohoshii uu isagu sameeyey.
\q1 
\v 16 Belaayadiisu waxay dib ugu noqonaysaa madaxiisa,
\q1 Oo dulmigiisuna dhaladiisuu ku soo degayaa.
\q1 
\v 17 Rabbiga waan ugu mahadnaqayaa sida ay xaqnimadiisu tahay,
\q1 Oo waxaan u ammaanayaa magaca Rabbiga ah Ilaaha ugu sarreeya.
\c 8
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu luuqeeyaa Gitiid.
\q1 
\v 1 Rabbiyow, Sayidkayagiiyow,
\q1 Magacaagu dunida oo dhan ku fiicanaa!
\q1 Waayo, sharaftaadii waxaad ka sarraysiisay samooyinka.
\q1 
\v 2 Waxaad xoog u yeeshay afka ilmaha yaryar iyo caanonuugga,
\q1 Waana cadaawayaashaada daraaddood,
\q1 Si aad u aamusiisid cadowga iyo aardoonka.
\q1 
\v 3 Markaan ka fiirsado samooyinka farahaaga lagu sameeyey,
\q1 Iyo dayaxa iyo xiddigaha aad amartay,
\q1 
\v 4 Bal waa maxay dadku oo aad u xusuusataa isaga?
\q1 Iyo wiilka aadanaha oo aad u soo booqataa?
\q1 
\v 5 Waayo, waxaad isaga wax yar ka hoosaysiisay malaa'igaha,
\q1 Waxaanad taaj uga dhigtay ammaan iyo murwad.
\q1 
\v 6 Oo waxaad isaga ka dhigtay inuu u taliyo shuqullada gacmahaaga,
\q1 Oo wax walbana cagihiisaad ka hoosaysiisay,
\q1 
\v 7 Idaha iyo lo'da oo dhan,
\q1 Iyo xayawaanka duurka joogaba,
\q1 
\v 8 Iyo haadka hawada, iyo kalluunka badda,
\q1 Iyo wax alla waxa ku dhex socda waddooyinka badaha.
\q1 
\v 9 Rabbiyow, Sayidkayagiiyow,
\q1 Magacaagu dunida oo dhan ku fiicanaa!
\c 9
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu luuqeeyaa Muutlabbeen.
\q1 
\v 1 Qalbigayga oo dhan ayaan Rabbiga ugu mahadnaqi doonaa,
\q1 Waxaan muujin doonaa shuqulladaada yaabka leh oo dhan.
\q1 
\v 2 Waan kugu farxi doonaa oo kugu rayrayn doonaa,
\q1 Kaaga ah kan ugu sarreeyow, magacaaga ayaan ammaan ugu gabyi doonaa.
\q1 
\v 3 Cadaawayaashaydu markii ay dib u noqdaan,
\q1 Way kufaan, oo waxay ku halligmaan hortaada.
\q1 
\v 4 Waayo, adigu xaqaygii iyo dacwadaydiiba waad ilaalisay,
\q1 Carshigaad ku fadhiday adigoo si xaq ah wax u xukumaya.
\q1 
\v 5 Quruumaha ayaad canaanatay, oo kuwa sharka lehna waad baabbi'isay,
\q1 Oo magacoodiina waad tirtirtay weligiis iyo weligiis.
\q1 
\v 6 Cadaawayaashii way dhammaadeen, oo weligoodba waa baabba',
\q1 Oo magaalooyinkii aad afgembidayna
\q1 Xataa xusuustoodii waa baabba'day.
\q1 
\v 7 Laakiinse Rabbigu wuxuu weligiis u fadhiyaa sida boqor,
\q1 Oo carshigiisiina wuxuu u diyaarsaday garsoorid.
\q1 
\v 8 Oo dunida xaqnimuu ku xukumi doonaa.
\q1 Oo dadyowgana qummanaan buu ugu garsoori doonaa.
\q1 
\v 9 Oo weliba Rabbigu wuxuu kuwa la dulmay u noqon doonaa magangal.
\q1 Oo kolkii ay dhibaataysan yihiinna magangal buu u ahaan doonaa,
\q1 
\v 10 Oo kuwa magacaaga yaqaanna way isku kaa hallayn doonaan,
\q1 Waayo, adigu Rabbiyow, ma aad dayrisid kuwa ku doondoona.
\q1 
\v 11 Rabbiga Siyoon deggan ammaan ugu gabya,
\q1 Oo waxyaalahuu sameeyey dadka dhexdiisa ka caddeeya.
\q1 
\v 12 Waayo, waxaa iyaga xusuusta ka dhiigga ka aarguda,
\q1 Oo isagu ma illoobo qaylada masaakiinta.
\q1 
\v 13 Rabbiyow, ii naxariiso,
\q1 Bal eeg dhibaatada ay kuwa i necebu igu hayaan.
\q1 Waxaad kor iiga qaaddaa irdaha dhimashada,
\q1 
\v 14 Si aan u muujiyo ammaantaada oo dhan,
\q1 Badbaadadaada aawadeed ayaan ugu farxi doonaa irdaha Siyoon.
\q1 
\v 15 Quruumihii waxay ku dheceen yamayskii ay qodeen,
\q1 Oo cagtoodiina waxaa qabsaday shabaggii ay qariyeen.
\q1 
\v 16 Rabbigu waa ismuujiyey, oo xukun buu dejiyey,
\q1 Kii shar lahaa waxaa dabay shuqulkii gacmihiisa. (Higgayoon. Selaah)
\q1 
\v 17 Kuwa sharka lahu waxay ku noqonayaan She'ool,
\q1 Waana quruumaha Ilaah illoobay oo dhan.
\q1 
\v 18 Waayo, kan baahan mar walba lama illoobi doono,
\q1 Oo masaakiinta waxfilashadooduna weligeed ma baabba'sanaan doonto.
\q1 
\v 19 Rabbiyow, sara joogso, oo dadku yaanay adkaan.
\q1 Quruumaha hortaada ha lagu xukumo.
\q1 
\v 20 Rabbiyow, iyaga cabsi geli,
\q1 Oo quruumuhu ha is-ogaadeen inay dad uun yihiin. (Selaah)
\b
\c 10
\q1 
\v 1 Rabbiyow, maxaad meesha fog u istaagtay?
\q1 Oo maxaad u dhuumataa markii dhibaato jirto?
\q1 
\v 2 Kii shar leh oo kibir badan ayaa miskiinka si kulul u eryada,
\q1 Xeeladdii ay hindiseen iyaga ha la rogmato.
\q1 
\v 3 Waayo, kii shar lahu wuxuu ku faanaa waxa qalbigiisu jecel yahay,
\q1 Oo kii damaci ahuna Rabbiga wuu nacaa, wuuna quudhsadaa.
\q1 
\v 4 Kii shar lahu isagoo wejigiisa kibir ka muuqdo wuxuu yidhaahdaa,
\q1 Isagu waxba i weyddiisan maayo.
\q1 Fikirradiisa oo dhammu waxaa weeye, Ilaah ma jiro.
\q1 
\v 5 Jidadkiisuu ku adag yahay had iyo goorba,
\q1 Xukummadaaduna waa ka sarreeyaan isaga, waana ka fog yihiin,
\q1 Oo cadaawayaashiisa oo dhanna wuu wada fudaydsadaa.
\q1 
\v 6 Oo wuxuu isyidhaahdaa, Anigu weligay dhaqdhaqaaqi maayo,
\q1 Oo tan iyo ka ab ka ab xumaanu i heli mayso.
\q1 
\v 7 Afkiisa waxaa ka buuxa habaar iyo khiyaano iyo dulmi,
\q1 Oo carrabkiisana waxaa ku hoos jira belaayo iyo xumaan.
\q1 
\v 8 Isagu wuxuu fadhiistaa tuulooyinka meelahooda lagu dhuunto,
\q1 Oo kan aan xaqa qabinna wuxuu ku dilaa meelaha qarsoon,
\q1 Oo indhihiisuna waxay si qarsoon hoos uga fiiriyaan miskiinka.
\q1 
\v 9 Isagu wuxuu ku dhuuntaa meel qarsoon sida libaax godkiisa ku jira,
\q1 Oo wuxuu u gaadaa inuu miskiinka qabsado,
\q1 Oo intuu miskiinka qabsado ayuu ku soo jiitaa shabaggiisa.
\q1 
\v 10 Wuu foororsadaa, oo hoos isu gaabiyaa,
\q1 Oo masaakiinta waxaa ridda gacanta kuwiisa xoogga badan.
\q1 
\v 11 Oo wuxuu isyidhaahdaa, Ilaah waa i illoobay,
\q1 Oo wejigiisiina wuu qariyey, weligiisna ima arki doono.
\q1 
\v 12 Rabbiyow, Ilaahow, sara joogso, oo gacantaada kor u qaad,
\q1 Oo masaakiinta ha illoobin.
\q1 
\v 13 Bal kii shar lahu muxuu Ilaah u quudhsadaa?
\q1 Oo muxuu qalbigiisa uga leeyahay, Adigu waxba i weyddiisan maysid?
\q1 
\v 14 Waxaas baad aragtay, waayo, waad u jeeddaa belaayada iyo xanaaqa, inaad gacantaada ku aargudatid aawadeed,
\q1 Miskiinku adiguu isu kaa dhiibaa,
\q1 Waayo, adigu waxaad tahay agoonka kaalmeeyihiisa.
\q1 
\v 15 Kii shar leh gacantiisa jebi,
\q1 Oo sharrowga xumaantiisana doondoon ilaa aad mid dambe weydid.
\q1 
\v 16 Rabbigu waa boqor weligiis iyo weligiisba,
\q1 Oo quruumaha oo dhammuna dalkiisa way ka wada baabba'aan.
\q1 
\v 17 Rabbiyow, waad maqashay waxay kuwa is-hoosaysiiyaa doonayaan,
\q1 Oo qalbigooda waad diyaarin doontaa, oo dhegtaadana waad u dhigi doontaa,
\q1 
\v 18 Si aad gartooda u naqdid agoonta iyo kuwa la dulmay,
\q1 Si aan dadka dunidu mar dambe u noqon kuwo laga cabsado.
\c 11
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Anigu Rabbigaan isku halleeyaa,
\q1 Haddaba idinku sidee baad naftayda ugu tidhaahdaan,
\q1 Sida shimbir oo kale buurtiinnii ku carara?
\q1 
\v 2 Waayo, bal eega, kuwa sharka lahu waxay xoodaan qaansada,
\q1 Fallaadhoodana waxay ku diyaariyaan xadhigga,
\q1 Inay kan qalbiga ka qumman goor gudcur ah ku ganaan.
\q1 
\v 3 Haddii aasaaska la dumiyo,
\q1 Kan xaqa ahu bal muxuu samayn karaa?
\q1 
\v 4 Rabbigu wuxuu ku jiraa macbudkiisa quduuska ah,
\q1 Rabbiga carshigiisu wuxuu yaal samada,
\q1 Indhihiisu way eegaan, oo indhihiisa daboolkooduna way imtixaamaan binu-aadmiga.
\q1 
\v 5 Rabbigu waa tijaabiyaa kii xaq ah,
\q1 Laakiinse kii shar leh iyo kii dulmi jecelba naftiisu way neceb tahay.
\q1 
\v 6 Kuwa shar leh wuxuu ku soo kor daadin doonaa dabinno,
\q1 Oo qaybta koobkooduna waxaa weeye dab iyo baaruud iyo dabayl hanfi ah.
\q1 
\v 7 Waayo, Rabbigu waa xaq, oo isagu xaqnimaduu jecel yahay,
\q1 Kuwa qummanuna wejigiisay arki doonaan.
\c 12
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha oo waxaa lagu luuqeeyaa Shemiiniid.
\q1 
\v 1 Rabbiyow, dadkaaga caawi, waayo, nin cibaado leh waa la waayayaa,
\q1 Waayo, binu-aadmiga intii aaminka ahayd way ka dhammaadeen.
\q1 
\v 2 Mid walba deriskiisa wuxuu kula hadlaa been,
\q1 Oo waxay ku hadlaan bushimo sasabasho miidhan ah iyo laba qalbi.
\q1 
\v 3 Rabbigu wuxuu wada baabbi'in doonaa bushimaha sasabashada badan oo dhan,
\q1 Iyo carrabka waxyaalaha waaweyn ku hadlaba.
\q1 
\v 4 Kuwaasu waxay yidhaahdeen, Annagu waxaan ku adkaan doonnaa carrabkayaga,
\q1 Oo bushimahayagana annagaa iska leh. Haddaba bal yaa annaga sayid noo ah?
\q1 
\v 5 Rabbigu wuxuu leeyahay, Anigu haatan waxaan u kacayaa
\q1 Masaakiinta la dhacayo, iyo kuwa baahan taahiddooda daraaddood,
\q1 Oo kan ay fudaydsanayaanna waan ammaan gelinayaa.
\q1 
\v 6 Rabbiga erayadiisu waa erayo daahir ah,
\q1 Oo waa sida lacag foorno kulul oo dhulka ku taal lagu kala miiray,
\q1 Oo toddoba jeer la safeeyey.
\q1 
\v 7 Rabbiyow, waad dhawri doontaa,
\q1 Oo qarnigan ayaad iyaga ka xannaanayn doontaa weligood.
\q1 
\v 8 Markii nijaasta binu-aadmiga dhexdiisa lagu jecel yahay,
\q1 Kuwa sharka lahu waxay ku socdaan dhinac kasta.
\c 13
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Rabbiyow, ilaa goormaad i illoobaysaa? Ma weligaa baa?
\q1 Oo ilaa goormaad wejigaaga iga qarinaysaa?
\q1 
\v 2 Ilaa goormaan naftayda la tashanayaa,
\q1 Anigoo maalinta oo dhan calool xun?
\q1 Ilaa goormuu cadowgaygu iga sarraynayaa?
\q1 
\v 3 Rabbiyow Ilaahayow, waxaas u fiirso, oo ii jawaab,
\q1 Indhahayga iftiimi, yaanan hurdadii geerida seexanine,
\q1 
\v 4 Waaba intaasoo cadowgaygu yidhaahdaa, Anigu isagaan ka adkaaday,
\q1 Oo ay cadaawayaashaydu farxaan markii lay dhaqaajiyo.
\q1 
\v 5 Laakiinse anigu waxaan isku halleeyey naxariistaada,
\q1 Oo qalbigayguna wuxuu ku rayrayn doonaa badbaadintaada.
\q1 
\v 6 Rabbigaan u gabyi doonaa,
\q1 Maxaa yeelay, wax badan oo wanaagsan buu ii sameeyey.
\c 14
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Nacasku wuxuu qalbigiisa iska yidhaahdaa, Ilaah ma jiro.
\q1 Iyagu way kharriban yihiin, oo waxay sameeyeen shuqullo karaahiyo ah,
\q1 Ma jiro mid wanaag sameeya.
\q1 
\v 2 Rabbigu samaduu ka soo fiiriyey binu-aadmiga,
\q1 Inuu arko haddii ay jiraan kuwo wax garanaya,
\q1 Oo Ilaah doondoona.
\q1 
\v 3 Dhammaantood gees bay u wada leexdeen, oo way wada nijaasoobeen,
\q1 Mid wanaag falaa ma jiro, midnaba.
\q1 
\v 4 Xumaanfalayaasha oo dhammu miyaanay aqoon lahayn?
\q1 Iyagoo dadkayga cuna, siday kibista u cunaan,
\q1 Mana ay baryaan Rabbiga.
\q1 
\v 5 Halkaasay aad ugu cabsadeen,
\q1 Maxaa yeelay, Ilaah wuxuu la jiraa qarniga xaqa ah.
\q1 
\v 6 Idinku waxaad ceebaysaan talada miskiinka,
\q1 Laakiin Rabbigu waa magangalkiisa.
\q1 
\v 7 Badbaadada reer binu Israa'iil bal may Siyoon ka timaado!
\q1 Marka Rabbigu dadkiisa maxaabiisnimada ka soo celiyo,
\q1 Ayaa reer Yacquub rayrayn doonaa, oo reer binu Israa'iilna farxi doonaa.
\c 15
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Rabbiyow, bal yaa taambuuggaaga ku fadhiyaya?
\q1 Oo bal yaa buurtaada quduuska ah degganaanaya?
\q1 
\v 2 Waa kii si qumman u socda, oo xaqnimo sameeya,
\q1 Oo qalbigiisa run kaga hadla.
\q1 
\v 3 Waana kii aan carrabkiisa wax ku xaman,
\q1 Ama aan saaxiibkiis xumaan ku samayn,
\q1 Ama aan deriskiisa cay ku soo hadal qaadin,
\q1 
\v 4 Kii indhihiisu ay nejiska quudhsadaan,
\q1 Oo isagu murweeya kuwa Rabbiga ka cabsada,
\q1 Kii hadduu dhaarto oo ay waxyeello ku tahay, aan isbeddelin,
\q1 
\v 5 Kii aan lacagtiisa u soo bixin korsocod,
\q1 Ama aan laaluush u qaadan inuu wax yeelo kuwa aan xaqa qabin.
\q1 Kii waxyaalahaas sameeya weligiis lama dhaqaajin doono.
\c 16
\s2 Kanu waa gabay Mikhtaam ah oo Daa'uud tiriyey.
\q1 
\v 1 Ilaahow, i dhawr, waayo, adigaan isku kaa halleeyaa.
\q1 
\v 2 Waxaan Rabbiga ku idhi, Sayidkayga baad tahay,
\q1 Oo innaba wanaag ma haysto la'aantaa.
\q1 
\v 3 Quduusiinta dhulka joogtaa
\q1 Waxaa weeye kuwa sharafta leh oo aan aad iyo aad ula faraxsanahay.
\q1 
\v 4 Kuwa ilaaha kale u dheereeya murugtoodu waa badnaan doontaa,
\q1 Laakiinse anigu bixin maayo qurbaankooda cabniinka oo dhiigga ah,
\q1 Oo magacyadoodana bushimahayga ku soo qaadi maayo.
\q1 
\v 5 Rabbigu waxaa weeye qaybtii dhaxalkayga iyo koobkayga,
\q1 Adigu qaybtayda waad xannaanaysaa.
\q1 
\v 6 Dhulqaybsigii meelo wacan baan ku helay,
\q1 Haah, oo waxaan leeyahay dhaxal wanaagsan.
\q1 
\v 7 Anigu waxaan ammaanayaa Rabbiga i waaniyey,
\q1 Habeenkiina uurkaygu wax buu i baraa.
\q1 
\v 8 Had iyo jeerba Rabbigaan hortayda ku xusuustaa,
\q1 Oo anigu innaba dhaqdhaqaaqi maayo,
\q1 Maxaa yeelay, isagu wuxuu joogaa midigtayda.
\q1 
\v 9 Taas aawadeed qalbigaygu waa faraxsan yahay oo naftayduna way rayraysaa,
\q1 Oo weliba jidhkayguna ammaan buu ku jiri doonaa.
\q1 
\v 10 Maxaa yeelay, naftayda She'ool kuma dayn doontid,
\q1 Kaaga quduuska ahna uma dayn doontid inuu qudhun arko.
\q1 
\v 11 Waxaad i tusi doontaa jidka nolosha,
\q1 Hortaada farxad baa ka buuxda,
\q1 Gacantaada midigna nimco baa ku jirta weligeed.
\c 17
\s2 Baryootankii Daa'uud.
\q1 
\v 1 Rabbiyow, xaqa maqal, oo qayladayda u jeeso,
\q1 Oo baryadayda dhegta u dhig, taasoo aan ka bixin bushimo khiyaano leh.
\q1 
\v 2 Xukunkaygu ha ka yimaado hortaada,
\q1 Oo indhahaaguna caddaalad ha fiiriyeen.
\q1 
\v 3 Qalbigayga waad tijaabisay, oo habeennimaad i soo booqatay,
\q1 Waad i imtixaantay, oo wax shar ah igama aad helin,
\q1 Waxaan u qasdiyey inaanu afkaygu xadgudbin.
\q1 
\v 4 Shuqulladii dadkana waan ka hadhay,
\q1 Oo erayada bushimahaaga ayaan kaga joogsaday jidadkii kuwa wax dulma oo dhan.
\q1 
\v 5 Si aanay cagahaygu u simbiriirixan,
\q1 Tallaabooyinkayga ku adkee waddooyinkaaga.
\q1 
\v 6 Ilaahow, waan ku baryay, waayo, waad ii jawaabi doontaa,
\q1 Bal dhegta ii dhig, oo hadalkayga maqal.
\q1 
\v 7 Bal muuji raxmaddaada yaabka leh,
\q1 Adigoo kuwa isku kaa halleeya gacantaada midig kaga badbaadiya
\q1 Kuwa ku kaca iyaga.
\q1 
\v 8 Ii dhawr sida isha inankeeda,
\q1 Oo igu qari hooska baalashaada.
\q1 
\v 9 Waxaad iga qarisaa kuwa sharka leh oo i kharriba,
\q1 Kuwaas oo ah cadaawayaasha naftayda oo hareerahayga ku wareegsan.
\q1 
\v 10 Qalbigooday xidheen,
\q1 Oo afkooduna wuxuu ku hadlaa waxyaalo kibir miidhan ah.
\q1 
\v 11 Oo haatan waxay cidhiidhiyeen tallaabooyinkayagii,
\q1 Oo waxay noogu dhaygageen inay dhulka nagu tuuraan aawadeed.
\q1 
\v 12 Isagu waa sida aar libaax ugaadhsi damacsan,
\q1 Iyo sida aaran libaax oo meelo qarsoon ku dhuunta.
\q1 
\v 13 Rabbiyow, kac,
\q1 Oo isaga ka hor tag, oo dhulka hoos ugu tuur,
\q1 Oo naftaydana kan sharka leh seeftaada kaga samatabbixi,
\q1 
\v 14 Rabbiyow, waxaad dadka igaga samatabbixisaa gacantaada,
\q1 Kuwaas oo ah dadka dunida, oo qaybtoodu ku jirto nolosha adduunkan,
\q1 Oo aad calooshooda ka buuxisaa khasnaddaada,
\q1 Iyagu waxay ka dhergeen carruur,
\q1 Oo maalkooda hadhayna waxay uga tagaan dhallaankooda.
\q1 
\v 15 Laakiinse anigu xaqnimaan wejigaaga ku fiirin doonaa,
\q1 Oo waa i deeqi doonaa markii aan ammaantaada arko, oo aan ekaantaada la soo tooso.
\c 18
\s2 Kanu waa sabuur addoonkii Rabbiga oo Daa'uud ahaa u tiriyey madaxdii muusikaystayaasha, oo wuxuu Rabbiga kula hadlay erayada gabaygan maalintii Rabbigu ka samatabbixiyey gacantii cadaawayaashiisa oo dhan, iyo gacantii Saa'uulba, oo wuxuu yidhi,
\q1 
\v 1 Rabbiyow, xooggaygiiyow, anigu waan ku jeclahay.
\q1 
\v 2 Rabbigu waa dhagax weyn oo ii gabbaad ah iyo qalcaddayda, iyo samatabbixiyahayga,
\q1 Iyo Ilaahay, iyo gabbaadkayga adag, oo isagaan isku hallayn doonaa,
\q1 Isagu waa gaashaankayga, iyo geeska badbaadadayda, iyo munaaraddayda dheer.
\q1 
\v 3 Waxaan baryayaa Rabbiga istaahila in la ammaano,
\q1 Oo sidaasaan cadaawayaashayda kaga badbaadi doonaa.
\q1 
\v 4 Waxaa i hareereeyey xadhkihii dhimashada,
\q1 Oo waxaa i cabsiiyey daadkii cibaadala'aanta.
\q1 
\v 5 Waxaa igu wareegsanaa xadhkihii She'ool,
\q1 Oo waxaa i qabsaday dabinnadii dhimashada.
\q1 
\v 6 Anigoo cidhiidhi ku jira ayaan Rabbiga baryay,
\q1 Oo waxaan u qayshaday Ilaahay,
\q1 Isna codkayguu macbudkiisa ka maqlay,
\q1 Oo qayladayda hortiisa ka yeedhaysaana dhegihiisay gashay.
\q1 
\v 7 Markaasaa dhulku ruxmay oo gariiray,
\q1 Oo buuraha aasaaskoodiina wuu dhaqdhaqaaqay,
\q1 Oo wuu ruxmay, maxaa yeelay, Ilaah waa cadhaysnaa.
\q1 
\v 8 Dulalka sankiisa waxaa ka soo baxay qiiq,
\q1 Afkiisana waxaa ka soo baxay dab wax gubaya, oo dhuxulaa ka shidmay isaga.
\q1 
\v 9 Oo weliba samooyinka wuu soo foorarshay, oo hoos buu u soo degay,
\q1 Oo cagihiisana waxaa hoos yiil gudcur weyn.
\q1 
\v 10 Oo wuxuu fuulay keruub, wuuna duulay,
\q1 Haah, oo wuxuu si dheeraysa ugu duulay oo fuulay dabaysha baalasheeda.
\q1 
\v 11 Wuxuu gudcurka ka dhigtay meeshiisii dhuumashada, iyo taambuuggiisa hareerihiisa ku wareegsan,
\q1 Iyo biyo gudcur ah, iyo daruuraha qarada waaweyn oo cirka.
\q1 
\v 12 Nuurkii hortiisa yiil aawadiis ayay daruurihii qarada waaweynaa tageen,
\q1 Roobkii dhagaxyada lahaa iyo dhuxulihii dabka ahaana way carareen.
\q1 
\v 13 Rabbiguna wuxuu ka onkoday samooyinka,
\q1 Sarreeyuhuna wuxuu ku hadlay codkiisii,
\q1 Oo soo daayay roob dhagaxyaale iyo dhuxulo dab ah.
\q1 
\v 14 Markaasuu fallaadhihiisii soo ganay oo kala firdhiyey iyagii,
\q1 Haah, oo wuxuu u soo diray hillaac badan, wuuna baabbi'iyey iyagii.
\q1 
\v 15 Rabbiyow, canaantaadii aawadeed iyo dulalka sankaaga neefta ka soo baxaysa aawadeed
\q1 Ayaa durdurradii biyuhu la muuqdeen,
\q1 Oo aasaaskii duniduna wuu soo bannaan baxay.
\q1 
\v 16 Xagga sare ayuu cid ka soo diray, oo wuu i qaaday,
\q1 Oo wuxuu iga soo dhex bixiyey biyo badan.
\q1 
\v 17 Wuxuu iga samatabbixiyey cadowgaygii xoogga badnaa,
\q1 Iyo kuwii i necbaaba, waayo, iyagu way iga xoog badnaayeen.
\q1 
\v 18 Waxay igu soo kediyeen maalintii aan belaayaysnaa,
\q1 Laakiinse Rabbigu wuxuu ii ahaa tiir.
\q1 
\v 19 Oo weliba wuxuu i keenay meel ballaadhan,
\q1 Wuu i soo samatabbixiyey, maxaa yeelay, wuu igu farxay.
\q1 
\v 20 Rabbigu wuxuu iigu abaalguday sidii ay xaqnimadaydii ahayd,
\q1 Oo sidii ay nadiifsanaantii gacmahaygu ahayd ayuu iigu abaalguday.
\q1 
\v 21 Waayo, anigu waan xajiyey jidadkii Rabbiga,
\q1 Oo Ilaahayna si caasinimo ah ugama tegin.
\q1 
\v 22 Waayo, xukummadiisii oo dhammu hortayday yiilleen,
\q1 Oo qaynuunnadiisiina anigu iskama tuurin.
\q1 
\v 23 Oo weliba xaggiisana waan ku qummanaa,
\q1 Oo waan iska dhawray xumaantaydii.
\q1 
\v 24 Sidaas daraaddeed ayaa Rabbigu iigu abaalguday sidii ay xaqnimadaydii ahayd,
\q1 Iyo sidii nadiifsanaanta gacmahaygu ay ku ahayd indhihiisa hortooda.
\q1 
\v 25 Kii naxariis leh waad u naxariisanaysaa,
\q1 Oo ninkii qummanna waad u qummanaanaysaa.
\q1 
\v 26 Kii daahir ahna daahir baad u ahaanaysaa,
\q1 Oo kii qalloocanna mid maroorsan baad u ahaanaysaa.
\q1 
\v 27 Waayo, waxaad badbaadinaysaa dadka dhibaataysan,
\q1 Laakiinse indhaha kibirsan waad soo dejinaysaa.
\q1 
\v 28 Waayo, waxaad daaraysaa laambaddayda,
\q1 Rabbiga Ilaahayga ah ayaa gudcurkayga iftiiminaya.
\q1 
\v 29 Waayo, adaan col kuugu dhex ordaa,
\q1 Oo Ilaahay caawimaaddiisa ayaan derbi kaga boodaa.
\q1 
\v 30 Ilaah jidkiisu waa qumman yahay,
\q1 Rabbiga eraygiisuna waa mid la tijaabiyey,
\q1 Isagu wuxuu gaashaan u yahay kuwa isaga isku halleeya oo dhan.
\q1 
\v 31 Waayo, bal yaa Ilaah ah, Rabbiga mooyaane?
\q1 Oo bal yaa dhagax weyn ah, Ilaahayaga mooyaane?
\q1 
\v 32 Kaasoo ah Ilaaha ii guntiya xoog,
\q1 Jidkaygana qummaatiya.
\q1 
\v 33 Isagu cagahayga wuxuu ka dhigaa sida cagaha deerada,
\q1 Oo wuxuu igu fadhiisiyaa meelahayga sare.
\q1 
\v 34 Gacmahaygana wuxuu baraa dagaalka,
\q1 Oo sidaas daraaddeed gacmahaygu waxay xoodaan qaanso naxaas ah.
\q1 
\v 35 Weliba waxaad kaloo i siisay gaashaankii badbaadintaada,
\q1 Oo waxaa kor ii qaadday gacantaada midig,
\q1 Oo roonaantaada ayaa i weynaysay.
\q1 
\v 36 Adigu tallaabooyinkayga waxaad ku ballaadhisay hoostayda,
\q1 Oo cagahayguna ma ay simbiriirixan.
\q1 
\v 37 Anigu waxaan eryan doonaa cadaawayaashayda, oo waan gaadhi doonaa,
\q1 Oo jeeray wada baabba'aanna dib uga soo noqon maayo.
\q1 
\v 38 Waan wada layn doonaa si aanay mar dambe u awoodin inay kacaan,
\q1 Oo cagahaygay ku soo hoos dhici doonaan.
\q1 
\v 39 Waayo, xoog baad iigu guntisay dagaalka aawadiis,
\q1 Oo kuwii igu kacayna hoostaydaad ku soo tuurtay.
\q1 
\v 40 Oo weliba cadaawayaashaydii waxaad ka dhigtay inay dhabarka ii jeediyaan,
\q1 Si aan u kala gooyo kuwa i neceb.
\q1 
\v 41 Iyagu way qayshadeen, laakiinse way waayeen mid iyaga badbaadiya,
\q1 Oo xataa Rabbiga way baryeen, laakiinse uma uu jawaabin.
\q1 
\v 42 Markaasaan iyagii u duqeeyey sida boodhka dabaysha hor kaca,
\q1 Oo waxaan iyagii dibadda ugu tuuray sidii dhoobada jidadka taal oo kale.
\q1 
\v 43 Waxaad iga samatabbixisay murankii dadka,
\q1 Oo waxaad iga dhigtay quruumaha madaxdoodii,
\q1 Oo dad aanan aqoon ayaa ii adeegi doona.
\q1 
\v 44 Oo mar alla markii ay warkayga maqlaan way i addeeci doonaan,
\q1 Oo shisheeyayaashuna way isu kay dhiibi doonaan,
\q1 
\v 45 Shisheeyayaashu way libdhi doonaan,
\q1 Oo iyagoo gariiraya ayay qolalkooda ka soo bixi doonaan.
\q1 
\v 46 Rabbigu waa nool yahay, oo mahad waxaa leh dhagaxayga weyn,
\q1 Oo Ilaaha i badbaadiyeyna ha sarreeyo,
\q1 
\v 47 Kaasoo ah Ilaaha aniga ii aarguda,
\q1 Oo dadkana hoostayda ku soo tuura.
\q1 
\v 48 Isagu wuxuu iga badbaadiyaa cadaawayaashayda,
\q1 Haah, oo adigu waxaad iga sara marisaa kuwa igu kaca,
\q1 Oo waxaad iga samatabbixisaa ninka dulmiga badan.
\q1 
\v 49 Sidaas daraaddeed, Rabbiyow, anigu waxaan kuugu mahadnaqi doonaa quruumaha dhexdooda,
\q1 Oo magacaaga ammaan baan ugu gabyi doonaa.
\q1 
\v 50 Rabbigu si weyn buu boqorkiisa u samatabbixiyaa,
\q1 Oo wuxuu weligiis raxmad u sameeyaa kii uu subkaday,
\q1 Kaasoo ah Daa'uud, iyo farcankiisaba weligiis iyo weligiis.
\c 19
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Samooyinku waxay caddeeyaan ammaanta Ilaah,
\q1 Cirkuna wuxuu muujiyaa sancadii gacantiisa.
\q1 
\v 2 Maalinba maalinta ka dambaysaa waxay ku hadashaa hadal,
\q1 Oo habeenba habeenka ka dambeeyaa wuxuu caddeeyaa aqoon.
\q1 
\v 3 Ma jiro hadal ama af
\q1 Aan codkooda laga maqlin.
\q1 
\v 4 Codkoodii wuxuu dhex maray dhulka oo dhan,
\q1 Hadalkoodiina wuxuu gaadhay dunida meesha ugu dambaysa.
\q1 Oo dhexdooda wuxuu taambuug u dhigay qorraxda,
\q1 
\v 5 Taasoo la mid ah aroos qolladdiisii ka soo baxaya,
\q1 Oo waxay u faraxdaa sida nin xoog leh oo baratamaya.
\q1 
\v 6 Waxay ka soo baxdaa samada darafkeeda,
\q1 Oo waxay ku soo wareegtaa hareeraheeda,
\q1 Oo kulaylkeedana wax ka qarsoonu ma jiraan.
\q1 
\v 7 Sharciga Rabbigu waa kaamil, oo nafta wuu soo celiyaa,
\q1 Maragfurka Rabbigu waa aamin, oo garaadlaawaha ayuu u caqliyeeyaa.
\q1 
\v 8 Qaynuunnada Rabbigu waa hagaagsan yihiin, oo qalbiga ayay ka farxiyaan,
\q1 Amarka Rabbigu waa daahir oo indhaha ayuu nuuriyaa.
\q1 
\v 9 Cabsida Rabbigu waa nadiif, weligeedna way raagtaa,
\q1 Xukummada Rabbigu waa run, waana wada xaq dhammaantood.
\q1 
\v 10 Iyagu waa wax xataa dahab laga sii jeclaado, haah, xataa dahab badan oo saafi ah,
\q1 Oo weliba way ka sii macaan yihiin malab iyo awlallada malabka.
\q1 
\v 11 Oo weliba addoonkaagana iyagaa loogu digay,
\q1 Oo xajintoodana waxaa ku jira abaalgud weyn.
\q1 
\v 12 Bal yaa qaladdadiisa garan kara?
\q1 Rabbow, iga nadiifi dembiyo qarsoon.
\q1 
\v 13 Anoo addoonkaaga ah iga hay waxyaalo aan ku kibro,
\q1 Oo yaanay ii talin,
\q1 Oo markaas kaamil baan ahaan doonaa,
\q1 Oo xadgudub weynna daahir baan ka ahaan doonaa.
\q1 
\v 14 Rabbiyow, xooggayga iyo bixiyahaygiiyow,
\q1 Erayada afkayga iyo fikirka qalbigaygu ha ahaadeen kuwo hortaada lagu aqbalo.
\c 20
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Rabbigu ha kuu jawaabo maalinta dhibta,
\q1 Ilaaha Yacquub magiciisu meel sare ha ku taago,
\q1 
\v 2 Caawimaadna ha kaaga soo diro meesha quduuska ah,
\q1 Oo Siyoonna ha kaa xoogeeyo,
\q1 
\v 3 Ha xusuusto qurbaannadaadii oo dhan,
\q1 Oo ha aqbalo allabarigaagii gubnaa, (Selaah)
\q1 
\v 4 Oo ha ku siiyo waxa qalbigaagu doono,
\q1 Oo ha kuu yeelo muraadkaaga oo dhan.
\q1 
\v 5 Innagu waxaynu ku guulaysanaynaa badbaadintaada,
\q1 Oo calammadeennana waxaynu ku sudhaynaa magaca Ilaaheenna,
\q1 Rabbigu ha ku siiyo waxaad weyddiisato oo dhan.
\q1 
\v 6 Anigu hadda waan ogahay in Rabbigu badbaadiyo kii uu isagu subkaday,
\q1 Oo wuxuu isaga uga soo jawaabi doonaa samadiisa quduuska ah,
\q1 Oo wuxuuna ugu jawaabi doonaa xooggiisa wax badbaadiya oo gacantiisa midig.
\q1 
\v 7 Qaar waxay isku halleeyaan gaadhifardoodyo, qaarna waxay isku halleeyaan fardo,
\q1 Laakiinse innagu waxaynu xusuusanaynaa magaca Rabbiga Ilaaheenna ah.
\q1 
\v 8 Iyagu way foororsadeen, wayna dheceen,
\q1 Laakiinse innagu waynu kacnay, oo waynu taagan nahay.
\q1 
\v 9 Rabbiyow, ina badbaadi,
\q1 Oo Boqorku ha inoo jawaabo markii aynu u qayshanno.
\c 21
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Rabbiyow, boqorku wuxuu ku farxi doonaa xooggaaga,
\q1 Oo badbaadintaadana aad buu ugu rayrayn doonaa.
\q1 
\v 2 Waxaad isaga siisay wixii qalbigiisu doonayay,
\q1 Oo wixii bushimihiisu ku weyddiisteenna uma aad diidin. (Selaah)
\q1 
\v 3 Waayo, waxaad isaga hor dhigtaa barakooyinka wanaagga,
\q1 Oo madaxiisana waxaad saartaa taaj dahab saafi ah.
\q1 
\v 4 Wuxuu kaa baryay nolol, oo adna waad siisay isaga,
\q1 Oo waxaad siisay cimri dheer oo waaraya weligiis iyo weligiisba.
\q1 
\v 5 Ammaantiisu waxay ku weyn tahay xagga badbaadintaada,
\q1 Oo waxaad isaga saartaa murwad iyo haybad.
\q1 
\v 6 Waayo, waxaad isaga ka dhigtaa mid weligiisba aad u barakaysan,
\q1 Oo waxaad ka dhigtaa inuu hortaada farxad kula reyreeyo.
\q1 
\v 7 Waayo, boqorku wuxuu isku halleeyaa Rabbiga,
\q1 Oo Ilaaha ugu sarreeya raxmaddiisa aawadeed isaga innaba lama dhaqaajin doono.
\q1 
\v 8 Gacantaadu waxay heli doontaa cadaawayaashaada oo dhan,
\q1 Oo midigtaaduna waxay heli doontaa kuwa ku neceb.
\q1 
\v 9 Oo markii aad cadhootid waxaad iyaga ka dhigi doontaa sida foorno dab ah.
\q1 Oo Rabbigu wuxuu iyaga ku liqi doonaa cadhadiisa,
\q1 Oo dab baa gubi doona.
\q1 
\v 10 Midhahooda dhulkaad ka baabbi'inaysaa,
\q1 Farcankoodana binu-aadmiga dhexdiisa.
\q1 
\v 11 Waayo, iyagu waxay ku talo jireen inay xumaan kugu sameeyaan,
\q1 Oo waxay hindiseen xeel ayan iyagu dhammayn karin.
\q1 
\v 12 Waayo, waxaad iyaga ka dhigi doontaa inay dib u jeestaan,
\q1 Oo xadhigga qaansadaadana waxaad ku diyaarin doontaa wejigooda hortiisa.
\q1 
\v 13 Rabbiyow, adigu xooggaaga ku sarree,
\q1 Markaasaannu gabyi doonnaa, oo waxaannu ammaani doonnaa itaalkaaga.
\c 22
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu luuqeeyaa Ayeled Shaxar.
\q1 
\v 1 Ilaahayow, Ilaahayow, maxaad ii dayrisay?
\q1 Oo aad uga fogaatay caawimaaddayda iyo hadalka hinraaggayga?
\q1 
\v 2 Ilaahayow, maalintii waan kuu qayshadaa, adiguse iima jawaabtid,
\q1 Oo habeennimadana waan qayliyaa oo ma nasto.
\q1 
\v 3 Laakiinse adigu quduus baad tahay,
\q1 Oo kursigaaga waxaad ka dhigtaa ammaanta reer binu Israa'iil.
\q1 
\v 4 Awowayaashayo adigay isku kaa halleeyeen,
\q1 Iyagu way isku kaa halleeyeen, oo adna waad samatabbixisay.
\q1 
\v 5 Adigay kuu qayshadeen, oo way samatabbexeen,
\q1 Way isku kaa halleeyeen, oo mana ay ceeboobin.
\q1 
\v 6 Laakiinse anigu waxaan ahay dixiri, oo dad ma ahi,
\q1 Waxaan ahay mid la caayo, oo dadku quudhsado.
\q1 
\v 7 Oo kuwa i arka oo dhammu way igu qoslaan,
\q1 Bushimahay yuubaan, oo madaxay lulaan, iyagoo leh,
\q1 
\v 8 Rabbiguu isku halleeyey, ha samatabbixiyo,
\q1 Bal isagu waa kan ku faraxsane hadda ha samatabbixiyo.
\q1 
\v 9 Laakiinse adigu waxaad tahay kii uurka iga soo bixiyey,
\q1 Oo intaan naasaha hooyaday nuugayay, waxaad iga dhigtay mid ku aaminsan.
\q1 
\v 10 Aniga dushaadaa laygu soo tuuray markaan uurka ka soo baxay,
\q1 Xataa tan iyo intaan uurkii hooyaday ku jiray, Ilaahaygaad ahayd.
\q1 
\v 11 Ha iga fogaan, waayo, dhib baa soo dhow,
\q1 Qof i caawiyaana ma jiro.
\q1 
\v 12 Waxaa i hareereeyey dibiyo badan,
\q1 Oo kuwii Baashaan oo xoogga badnaa ayaa hareerahayga isku wareejiyey.
\q1 
\v 13 Afkooday iigu fureen,
\q1 Sidii libaax hamuunsan oo ciyaya.
\q1 
\v 14 Waxaan u shubmay sidii biyo oo kale,
\q1 Oo lafahaygii oo dhammuna xubnihii way ka kala bexeen,
\q1 Oo qalbigaygii wuxuu noqday sidii shamac oo kale,
\q1 Oo wuxuu ku dhex dhalaalay xiidmahayga.
\q1 
\v 15 Xooggaygii wuxuu u engegay sidii dheri burburkiisa oo kale,
\q1 Oo carrabkaygiina daamankayguu ku dhegay,
\q1 Oo waxaad i gelisay ciiddii dhimashada.
\q1 
\v 16 Waayo, waxaa i hareereeyey eeyo,
\q1 Oo waxaa hareerahayga isku wareejiyey shirkii xumaanfalayaasha,
\q1 Oo waxay iga mudeen gacmaha iyo cagaha.
\q1 
\v 17 Lafahaygii oo dhan waan tirin karaa,
\q1 Oo iyagu way i fiiriyaan oo igu dhaygagaan,
\q1 
\v 18 Dharkayga bay qaybsadaan,
\q1 Oo maradaydana saami bay u ritaan.
\q1 
\v 19 Laakiinse, Rabbiyow, ha iga fogaan,
\q1 Tageerehaygiiyow, dhaqso ii caawi.
\q1 
\v 20 Naftayda ka samatabbixi seefta,
\q1 Noloshaydana ka samatabbixi xoogga eeyga.
\q1 
\v 21 Iga badbaadi libaaxa afkiisa,
\q1 Haah, xataa geesihii gisiyada waad iiga jawaabtay.
\q1 
\v 22 Magacaaga waan u sheegi doonaa walaalahay,
\q1 Oo ururka dhexdiisa ayaan kugu ammaani doonaa.
\q1 
\v 23 Kuwiinna Rabbiga ka cabsadow, ammaana isaga,
\q1 Farcanka Yacquubow, sharfa isaga,
\q1 Oo kuwiinna Israa'iil ka soo farcamayow, isaga ka wada cabsada.
\q1 
\v 24 Waayo, isagu ma quudhsan, mana karhin kan la dhibay dhibkiisa,
\q1 Oo wejigiisiina kama uu qarin isagii,
\q1 Laakiinse markuu u qayshaday ayuu maqlay.
\q1 
\v 25 Xaggaaga ayaa ammaantaydu kaga imanaysaa shirka weyn dhexdiisa,
\q1 Oo nidarradayda waxaan ku bixinayaa kuwa isaga ka cabsada hortooda.
\q1 
\v 26 Oo waxaa wax cuni doona oo ka dhergi doona kuwa camalka qabow,
\q1 Kuwa Rabbiga doondoonaa isagay ammaani doonaan,
\q1 Qalbigiinnu weligiis ha noolaado.
\q1 
\v 27 Dunida darafyadeeda oo dhammu waxay soo xusuusan doonaan oo u soo jeesan doonaan Rabbiga.
\q1 Oo qolooyinka quruumaha oo dhammu waxay ku sujuudi doonaan hortaada.
\q1 
\v 28 Waayo, boqortooyada waxaa leh Rabbiga,
\q1 Oo isagu waa taliyihii quruumaha.
\q1 
\v 29 Dunida kuweeda buurbuuran oo dhammu wax bay cuni oo Ilaah bay caabudi doonaan,
\q1 Oo inta ciidda gasha oo dhammuna hortiisay ku sujuudi doonaan,
\q1 Xataa kii aan naftiisa sii noolayn karin.
\q1 
\v 30 Farcan baa isaga u adeegi doona,
\q1 Oo Sayidka waxaa looga sheekayn doonaa qarniga iman doona.
\q1 
\v 31 Oo iyagu way iman doonaan oo waxay dadka dhalan doona u sheegi doonaan
\q1 Xaqnimadiisa iyo inuu sameeyeyba.
\c 23
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Rabbigu waa adhijirka i jira; waxba u baahan maayo.
\q1 
\v 2 Wuxuu i fadhiisiyaa doog qoyan dhexdiis,
\q1 Oo wuxuu ii hoggaamiyaa biyaha deggan dhinacooda.
\q1 
\v 3 Naftayda wuu soo celiyaa.
\q1 Oo magiciisa aawadiis wuxuu igu hor kacaa waddooyinka xaqnimada.
\q1 
\v 4 In kastoo aan ku dhex socdo dooxada hooska dhimashada,
\q1 Sharna ka baqi maayo, waayo, waad ila jirtaa,
\q1 Ushaada iyo hangoolkaaga ayaa ii raaxeeya.
\q1 
\v 5 Cadaawayaashayda hortooda waxaad iigu diyaarisaa miis,
\q1 Oo saliid baad madaxayga ku subagtaa, koobkayguna waa buuxdhaafaa.
\q1 
\v 6 Hubaal cimrigayga oo dhan waxaa i raaci doona wanaag iyo naxariis,
\q1 Oo weligay guriga Rabbiga ayaan degganaan doonaa.
\c 24
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Rabbigaa iska leh dhulka iyo waxa ka buuxa oo dhan,
\q1 Iyo dunida iyo kuwa degganba.
\q1 
\v 2 Waayo, isagaa badaha dushooda ka aasaasay,
\q1 Oo wuxuu ka dul dhisay webiyaasha.
\q1 
\v 3 Bal yaa fuuli doona Rabbiga buurtiisa?
\q1 Oo bal yaa dhex istaagi doona meeshiisa quduuska ah?
\q1 
\v 4 Waa kii gacmihiisu nadiifsan yihiin, oo qalbigiisu daahir yahay,
\q1 Oo aan naftiisa hawo been ah kor ugu qaadin,
\q1 Oo aan si khiyaano leh u dhaaran.
\q1 
\v 5 Kaasu wuxuu Rabbiga ka heli doonaa barako,
\q1 Ilaaha badbaadadiisana xaqnimo.
\q1 
\v 6 Kanu waxaa weeye qarnigii kuwa isaga doondoona,
\q1 Oo waa kuwa wejigaaga doondoona, Ilaaha Yacquubow. (Selaah)
\q1 
\v 7 Irdahow, madaxiinna kor u qaada,
\q1 Oo albaabbada daa'imiska ahow, kor ha laydiin qaado,
\q1 Oo waxaa soo geli doona Boqorka ammaanta.
\q1 
\v 8 Bal waa ayo Boqorka ammaantu?
\q1 Waa Rabbiga xoog iyo itaal badan,
\q1 Waa Rabbiga dagaalka ku xoog badan.
\q1 
\v 9 Irdahow, madaxiinna kor u qaada,
\q1 Oo albaabbada daa'imiska ahow, madaxiinna kor u qaada,
\q1 Oo waxaa soo geli doona Boqorka ammaanta.
\q1 
\v 10 Bal waa ayo Boqorkan ammaantu?
\q1 Waa Rabbiga ciidammada,
\q1 Isaga weeye Boqorka ammaantu. (Selaah)
\c 25
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Rabbiyow, naftayda xaggaagaan kor ugu qaadaa.
\q1 
\v 2 Ilaahayow, adigaan isku kaa halleeyey,
\q1 Haddaba yaanan ceeboobin,
\q1 Oo yaan cadaawayaashaydu ii faanin.
\q1 
\v 3 Kuwa adiga ku suga midkoodna ceeboobi maayo,
\q1 Laakiinse waxaa ceeboobi doona kuwa khiyaanada ku macaamilooda sababla'aan.
\q1 
\v 4 Rabbiyow, jidadkaaga i tus,
\q1 Oo waddooyinkaagana i bar.
\q1 
\v 5 Runtaada igu hoggaami, oo i bar,
\q1 Waayo, waxaad tahay Ilaaha badbaadadayda,
\q1 Oo maalinta oo dhan adaan ku sugaa.
\q1 
\v 6 Rabbiyow, xusuuso naxariistaada iyo raxmaddaada,
\q1 Waayo, weligoodba way jireen.
\q1 
\v 7 Ha xusuusan dembiyadii dhallinyaranimadayda iyo xadgudubyadaydii,
\q1 Laakiinse ii xusuuso sida raxmaddaadu tahay,
\q1 Iyo wanaaggaaga aawadiis, Rabbiyow.
\q1 
\v 8 Rabbigu waa wanaagsan yahay, waana qumman yahay,
\q1 Sidaas daraaddeed wuxuu dembilayaasha ku hanuunin doonaa jidka.
\q1 
\v 9 Kuwa camalka qabow wuxuu ku hanuunin doonaa xaqa,
\q1 Oo kuwa camalka qabow wuxuu bari doonaa jidkiisa.
\q1 
\v 10 Rabbiga waddooyinkiisa oo dhammu waxay raxmad iyo run u yihiin
\q1 Kuwa axdigiisa iyo markhaatifurkiisa xajiya.
\q1 
\v 11 Rabbiyow, dembigayga iga cafi magacaaga daraaddiis,
\q1 Waayo, aad buu u weyn yahay.
\q1 
\v 12 Bal waa ayo ninka Rabbiga ka cabsadaa?
\q1 Kaas wuxuu ku hanuunin doonaa jidkii uu isagu doorto.
\q1 
\v 13 Naftiisu wanaag bay ku jiri doontaa,
\q1 Oo farcankiisuna wuxuu dhaxli doonaa dalka.
\q1 
\v 14 Rabbiga taladiisa qarsoon waxay la jirtaa kuwa isaga ka cabsada,
\q1 Oo wuxuu iyaga tusi doonaa axdigiisa.
\q1 
\v 15 Weligayba indhahaygu waxay u jeedaan xagga Rabbiga,
\q1 Waayo, wuxuu cagahayga ka bixin doonaa dabinka.
\q1 
\v 16 Bal xaggayga u soo jeeso, oo ii naxariiso,
\q1 Waayo, waan cidloobay, oo dhib baa i haysa.
\q1 
\v 17 Dhibaatooyinka qalbigaygu way sii ballaadheen,
\q1 Cidhiidhigayga iga bixi.
\q1 
\v 18 Bal fiiri dhibkayga iyo qaxarkayga,
\q1 Oo dembiyadayda oo dhan iga cafi.
\q1 
\v 19 Bal fiiri cadaawayaashayda, waayo, way badan yihiin,
\q1 Oo waxay igu neceb yihiin nacayb dulmi miidhan ah.
\q1 
\v 20 Naftayda dhawr, oo i samatabbixi,
\q1 Oo yaanan ceeboobin, waayo, waan isku kaa halleeyaa.
\q1 
\v 21 Daacadnimo iyo qummanaanu ha i dhawreen,
\q1 Waayo, adaan ku sugaa.
\q1 
\v 22 Ilaahow, reer binu Israa'iil ka samatabbixi
\q1 Dhibaatooyinkooda oo dhan.
\c 26
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Rabbiyow, i xukun, waayo, waxaan ku socday daacadnimadayda,
\q1 Oo weliba waxaan Rabbiga isugu halleeyey rogrogmashola'aan.
\q1 
\v 2 Rabbiyow, i imtixaan, oo i tijaabi,
\q1 Oo uurkayga iyo qalbigaygana baadh.
\q1 
\v 3 Waayo, raxmaddaadu waxay taal indhahayga hortooda,
\q1 Oo waxaan ku socday runtaada.
\q1 
\v 4 Lama aan fadhiisan waxmatarayaal,
\q1 Oo kuwa isyeelyeelana gudaha la geli maayo.
\q1 
\v 5 Waan necbahay ururka xumaanfalayaasha,
\q1 Oo kuwa sharka lehna la fadhiisan maayo.
\q1 
\v 6 Gacmahayga waxaan ku maydhan doonaa eedla'aanta,
\q1 Markaasaan ku wareegi doonaa meeshaada allabariga, Rabbiyow,
\q1 
\v 7 Si aan codka mahadnaqidda dadka u maqashiiyo,
\q1 Oo aan uga sheekeeyo shuqulladaada yaabka leh oo dhan.
\q1 
\v 8 Rabbiyow, rugta gurigaaga waan jeclahay,
\q1 Iyo meesha ammaantaadu joogto.
\q1 
\v 9 Naftayda ha la ururin dembilayaal,
\q1 Noloshaydana ha la ururin dhiigyocabyada,
\q1 
\v 10 Gacmahooda belaayadu ku jirto,
\q1 Gacantooda midigna laaluush ka buuxo.
\q1 
\v 11 Laakiinse anigu waxaan ku socon doonaa daacadnimadayda,
\q1 Haddaba i madaxfuro, oo ii naxariiso.
\q1 
\v 12 Cagtaydu waxay ku taagan tahay meel siman,
\q1 Oo Rabbigaan ku ammaani doonaa shirarka dhexdooda.
\c 27
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Rabbigu waa nuurkayga iyo badbaadadayda, bal yaan ka cabsadaa?
\q1 Oo Rabbigu waa xoogga noloshayda, bal yaan ka baqaa?
\q1 
\v 2 Markii xumaanfalayaashu iigu yimaadeen inay hilibkayga cunaan,
\q1 Kuwaasoo ah cadaawayaashayda iyo colkayga, way turunturoodeen, wayna dheceen.
\q1 
\v 3 In kastoo ciidan col ah i ag dego,
\q1 Qalbigaygu cabsan maayo,
\q1 In kastoo dagaal igu soo kaco,
\q1 Xataa markaas waan kalsoonaanayaa.
\q1 
\v 4 Wax keliya ayaan Rabbiga ka baryay, oo taas aad baan u doonayaa,
\q1 Waana inaan cimrigayga oo dhan dhex degganaado guriga Rabbiga,
\q1 Oo aan fiiriyo Rabbiga quruxdiisa, oo aan wax ku baryo macbudkiisa.
\q1 
\v 5 Waayo, isagu maalinta dhibta wuxuu igu qarin doonaa teendhadiisa,
\q1 Oo meesha qarsoon oo taambuuggiisa ayuu igu xasayn doonaa,
\q1 Kor buu ii qaadi doonaa oo dhagax weyn buu i saari doonaa.
\q1 
\v 6 Imminka waxaa madaxayga laga sarraysiin doonaa cadaawayaashayda igu wareegsan,
\q1 Oo waxaan taambuugga Rabbiga ku dhex bixin doonaa allabari dhawaaq farxadeed leh,
\q1 Waan gabyi doonaa, haah, ammaan baan Rabbiga ugu gabyi doonaa.
\q1 
\v 7 Rabbiyow, markaan codkayga ku qayliyo, i maqal,
\q1 Weliba ii naxariiso, oo ii jawaab.
\q1 
\v 8 Markaad tidhi, Wejigayga doondoona, ayaa qalbigaygu wuxuu kugu yidhi,
\q1 Rabbiyow, wejigaaga waan doondoonayaa.
\q1 
\v 9 Ilaaha badbaadadaydow, wejigaaga ha iga qarin,
\q1 Anoo addoonkaaga ah cadho ha igu eryin,
\q1 Caawimaad baad ii ahayde,
\q1 Ha i xoorin, hana i dayrin.
\q1 
\v 10 Waayo, aabbahay iyo hooyaday way i dayriyeen,
\q1 Laakiinse Rabbigaa i qaadan doona.
\q1 
\v 11 Rabbiyow, cadaawayaashayda daraaddood
\q1 Jidkaaga i bar,
\q1 Oo igu hoggaami waddo bannaan.
\q1 
\v 12 Oo gacanta ha ii gelin cadaawayaashayda,
\q1 Waayo, waxaa igu kacay markhaatiyaal been ah iyo kuwa nacweynaanta ku hadla.
\q1 
\v 13 Waan itaal darnaan lahaa haddaanan rumaysnayn
\q1 Inaan wanaagga Rabbiga ku arkayo dalka kuwa nool.
\q1 
\v 14 Rabbiga sug,
\q1 Adkayso, oo qalbigaagu ha dhiirranaado,
\q1 Haah, Rabbiga sug.
\c 28
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Rabbiyow, adigaan kuu qayshan doonaa,
\q1 Dhagaxayga weynow, ha iska kay dhega tirin,
\q1 Waaba intaas oo haddaad iga aamusto,
\q1 Aan noqdaa sida kuwa yamayska hoos ugu dhaadhaca.
\q1 
\v 2 Maqal codka baryootankayga markaan kuu qayshado,
\q1 Oo aan gacmahayga u soo taago xagga meeshaada quduuska ah.
\q1 
\v 3 Ha ila jiidin kuwa sharka leh,
\q1 Iyo xumaanfalayaasha
\q1 Oo deriskooda nabadda kula hadla,
\q1 Laakiinse belaayadu qalbigooda ku jirto.
\q1 
\v 4 Iyaga u abaalmari sida shuqulkoodu yahay, iyo sida ay xumaanta falimahoodu tahay,
\q1 Iyaga u abaalmari sida shuqulka gacmahoodu yahay,
\q1 Oo waxa ay galabsadaan sii.
\q1 
\v 5 Iyaga wuu dumin doonaa, mana uu dhisi doono mar dambe,
\q1 Maxaa yeelay, kama ay fikirin Rabbiga shuqulladiisii
\q1 Iyo hawshii gacmihiisa toona.
\q1 
\v 6 Mahad waxaa leh Rabbiga,
\q1 Maxaa yeelay, codkii baryootankayguu maqlay.
\q1 
\v 7 Rabbigu waa xooggayga iyo gaashaankayga,
\q1 Qalbigaygu isaguu isku halleeyey, oo waa lay caawiyey,
\q1 Sidaas daraaddeed qalbigaygu aad iyo aad buu u reyreeyey,
\q1 Oo gabaygaygaan isaga ku ammaani doonaa.
\q1 
\v 8 Rabbigu wuxuu dadkiisa u yahay xoog,
\q1 Oo kiisa subkanna wuxuu u yahay qalcad lagu badbaado.
\q1 
\v 9 Dadkaaga badbaadi, oo dhaxalkaagana barakee,
\q1 Oo weliba quudi, oo weligaaba kor u hay.
\c 29
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Kuwiinna carruurta Ilaah ahow, Rabbiga ammaana,
\q1 Rabbiga ka sheega ammaan iyo xoog.
\q1 
\v 2 Rabbiga ku ammaana ammaanta magiciisu mudan yahay,
\q1 Rabbiga ku caabuda quruxda quduuska ah.
\q1 
\v 3 Rabbiga codkiisu wuxuu dul joogaa biyaha,
\q1 Ilaaha ammaantu wuu onkodaa,
\q1 Oo xataa Rabbigu wuxuu ka kor onkodaa biyo badan.
\q1 
\v 4 Rabbiga codkiisu waa xoog badan yahay,
\q1 Rabbiga codkiisu waa haybad badan yahay.
\q1 
\v 5 Rabbiga codkiisu wuxuu jebiyaa geedaha kedarka ah,
\q1 Haah, oo Rabbigu wuxuu kala jebjebiyaa geedaha kedarka ah oo Lubnaan.
\q1 
\v 6 Oo weliba wuxuu iyaga ka dhigaa inay u boodboodaan sida weyl oo kale,
\q1 Lubnaan iyo Siryonba wuxuu ka dhigaa sida gisi yar.
\q1 
\v 7 Rabbiga codkiisu wuxuu googooyaa ololka dabka.
\q1 
\v 8 Rabbiga codkiisu wuxuu ruxruxaa cidlada,
\q1 Rabbigu wuxuu ruxruxaa cidlada Qaadeesh.
\q1 
\v 9 Rabbiga codkiisu wuxuu dhaliyaa deerooyinka,
\q1 Oo kayntana caleemaha wuu ka daadiyaa,
\q1 Oo wax kasta oo macbudkiisa ku jiraana waxay yidhaahdaan, Ammaan.
\q1 
\v 10 Rabbigu wuxuu dul fadhiyaa daadka,
\q1 Haah, oo Rabbigu wuxuu weligiisba u fadhiyaa sida boqor oo kale.
\q1 
\v 11 Rabbigu dadkiisuu xoogayn doonaa,
\q1 Oo Rabbigu nabad buu dadkiisa ku barakayn doonaa.
\c 30
\s2 Kanu waa sabuur Daa'uud tiriyey in la gabyo markii Gurigii loo furay Ilaah.
\q1 
\v 1 Rabbiyow, waan ku sarraysiinayaa, waayo, kor baad iga yeeshay,
\q1 Oo weliba igama aad dhigin in cadaawayaashaydu ii faanaan.
\q1 
\v 2 Rabbiyow, Ilaahayow,
\q1 Waan kuu qayshaday oo adna waad i bogsiisay.
\q1 
\v 3 Rabbiyow, waxaad naftaydii kor uga qaadday She'ool,
\q1 Oo waad i sii noolaysay si aanan yamayska ugu dhicin.
\q1 
\v 4 Quduusiintiisoy, Rabbiga ammaan ugu gabya,
\q1 Oo mahad ku naqa magiciisa quduuska ah.
\q1 
\v 5 Waayo, cadhadiisu waa daqiiqad keliya,
\q1 Laakiinse raallinimadiisu waa cimriga,
\q1 Habeenka waxaa jirta oohin,
\q1 Laakiinse aroorta farxad baa timaada.
\q1 
\v 6 Aniguse intaan barwaaqaysnaa waxaan idhi,
\q1 Weligay dhaqdhaqaaqi maayo.
\q1 
\v 7 Rabbiyow, raallinimadaada aawadeed ayaad buurtayda ka dhigtay inay si adag u taagnaato,
\q1 Wejigaagaad qarisay, oo anna waan argaggaxay.
\q1 
\v 8 Rabbiyow, adigaan kuu soo qayshaday,
\q1 Oo baryootankaygii waxaan gaadhsiiyey Rabbiga.
\q1 
\v 9 Bal markaan yamayska ku dego, maxaa faa'iido ah oo dhiiggayga ku jirta?
\q1 Ma ciiddaa ku ammaanaysa? Oo ma runtaaday sheegaysaa?
\q1 
\v 10 Rabbiyow, i maqal oo ii naxariiso,
\q1 Rabbiyow, kaalmeeyahayga ahow.
\q1 
\v 11 Baroortaydii waxaad iigu beddeshay cayaar,
\q1 Oo dharkaygii joonyadaha ahaana waad iga furtay, oo waxaad ii guntisay farxad,
\q1 
\v 12 Taasuna waa si nafsaddaydu ay ammaan kuugu gabaydo, oo aanay u aamusin.
\q1 Rabbiyow, Ilaahayow, weligayba waan kugu mahadnaqayaa.
\c 31
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Rabbiyow, adigaan isku kaa halleeyaa, yaanan weligayba ceeboobin,
\q1 Oo xaqnimadaada igu samatabbixi.
\q1 
\v 2 Dhegtaada ii soo dhig, oo dhaqso ii samatabbixi,
\q1 Dhagax weyn oo xoog leh ii ahow, iyo guri laysku daafaco si aad ii badbaadisid.
\q1 
\v 3 Waayo, waxaad tahay dhagax weyn oo ii gabbaad ah iyo qalcaddayda,
\q1 Haddaba magacaaga daraaddiis ii hoggaami oo ii hanuuni.
\q1 
\v 4 Oo iga bixi shabagga dabinka ah oo ay qarsoodiga iigu dhigeen,
\q1 Waayo, waxaad tahay qalcaddayda.
\q1 
\v 5 Gacantaada ayaan ruuxayga u dhiibayaa,
\q1 Waayo, waad i soo furatay, Rabbiyow, Ilaaha runta ahow.
\q1 
\v 6 Waan neceb ahay kuwa hawada beenta ah ka fikira,
\q1 Laakiinse Rabbigaan isku halleeyaa.
\q1 
\v 7 Naxariistaada waan ku farxi doonaa, waanan ku rayrayn doonaa,
\q1 Waayo, dhibaatadii igu dhacday waad aragtay,
\q1 Waanad ogayd qaxarka naftaydu ku jirtay,
\q1 
\v 8 Oo weliba iguma aad xidhin gacantii cadowga,
\q1 Oo cagtayda waxaad taagtay meel ballaadhan.
\q1 
\v 9 Rabbiyow, ii naxariiso, waayo, cidhiidhi baan ku jiraa,
\q1 Oo murug baan la il go'aa, oo naftayda iyo jidhkayguba way taag darnaadaan.
\q1 
\v 10 Waayo, noloshaydu waxay ku dhammaatay caloolxumo, cimrigayguna taahid,
\q1 Oo dembigayga daraaddiis ayaa xooggaygii ii gabay, lafahaygiina way wada kharribmeen.
\q1 
\v 11 Cadaawayaashayda oo dhan daraaddood ayaan waxaan noqday mid ceebaysan,
\q1 Xataa deriskayga aad iyo aad baan ugu hor ceeboobay, oo kuwa i yaqaanna way iga cabsadeen,
\q1 Oo xataa kuwii dibadda igu arkay way iga carareen.
\q1 
\v 12 Sida qof dhintay oo laga samray ayaa layska kay illoobay,
\q1 Oo waxaan ahay sida weel jabay.
\q1 
\v 13 Waayo, waxaan maqlay kuwo badan oo caytamaya,
\q1 Iyo cabsi dhan kasta igaga wareegsan,
\q1 Oo intay ii wada tashadeen,
\q1 Ayay waxay ku arrinsadeen inay nafta iga qaadaan.
\q1 
\v 14 Laakiinse Rabbiyow, adigaan isku kaa halleeyey,
\q1 Oo waxaan idhi, Waxaad tahay Ilaahay.
\q1 
\v 15 Wakhtigaygu gacantaaduu ku jiraa,
\q1 Haddaba iga samatabbixi gacanta cadaawayaashayda, iyo weliba kuwa i silciya gacantooda.
\q1 
\v 16 Wejigaaga anoo addoonkaaga ah igu iftiimi,
\q1 Oo igu badbaadi raxmaddaada.
\q1 
\v 17 Rabbiyow, yaanan ceeboobin, waayo, adigaan kuu qayshaday,
\q1 Kuwa sharka lahu ha ceeboobeen, oo She'ool ha ku dhex aamuseen.
\q1 
\v 18 Ha carrab beeleen kuwa beenta sheegaa,
\q1 Oo kan xaqa ah si qallafsan wax uga sheega,
\q1 Iyagoo kibir iyo quudhsasho leh.
\q1 
\v 19 Wanaaggaagu weynaan badanaa, kan aad u kaydisay kuwa kaa cabsada,
\q1 Oo weliba aad binu-aadmiga hortiisa ugu diyaarisay kuwa isku kaa halleeya.
\q1 
\v 20 Dadka sirqoolladiisa waxaad iyaga kaga qarinaysaa joogistaada qarsoon,
\q1 Oo carrabka dirirtiisana waxaad iyaga kaga qarinaysaa taambuug.
\q1 
\v 21 Mahad waxaa leh Rabbiga,
\q1 Waayo, wuxuu raxmaddiisa yaabka leh igu tusay magaalo xoog weyn.
\q1 
\v 22 Laakiinse anigu waxaan degdeg ku idhi, Indhahaaga hortooda waan ka go'ay,
\q1 Habase yeeshee, codkii baryootankayga waad maqashay markii aan kuu qayshaday.
\q1 
\v 23 Quduusiintiisa oo dhammay, Rabbiga jeclaada,
\q1 Rabbigu wuu ilaaliyaa kuwa aaminka ah,
\q1 Kan waxa kibirka ah falase aad iyo aad buu u abaalmariyaa.
\q1 
\v 24 Kuwiinna Rabbiga wax ka rajaynaya oo dhammow,
\q1 Adkaysta, oo qalbigiinnu ha dhiirranaado.
\c 32
\s2 Kanu waa sabuur Daa'uud tiriyey. Maskiil.
\q1 
\v 1 Waxaa barakaysan kii xadgudubkiisa la cafiyey, oo dembigiisa la daboolay.
\q1 
\v 2 Waxaa barakaysan ninkii aanu Rabbigu dembi ku tirin,
\q1 Oo ruuxiisa aanay khiyaano ku jirin.
\q1 
\v 3 Markii aan iska aamusay, lafahaygii way gaboobeen,
\q1 Maxaa yeelay, maalintii oo dhan baan cabaadayay.
\q1 
\v 4 Waayo, habeen iyo maalinba gacantaadu way igu cuslayd,
\q1 Oo qoyaankaygii wuxuu u beddelmay sidii engegga diraacda. (Selaah)
\q1 
\v 5 Dembigaygii adigaan kuu qirtay, oo xumaantaydiina ma aan qarin,
\q1 Waxaan idhi, Xadgudubkayga waxaan u qiranayaa Rabbiga,
\q1 Oo adna waad iga cafiday xumaanta dembigayga. (Selaah)
\q1 
\v 6 Taas daraaddeed mid kastoo cibaado lahu ha ku soo baryo wakhti lagu heli karo,
\q1 Hubaal markii biyaha badanu dhulka qarqiyaan, isaga sooma ay gaadhi doonaan.
\q1 
\v 7 Waxaad tahay meeshaan ku dhuunto, oo dhib baad iga ilaalin doontaa,
\q1 Oo waxaad igu wareejin doontaa gabayadii samatabbixinta. (Selaah)
\q1 
\v 8 Waan ku hanuunin doonaa oo waxaan ku bari doonaa jidka aad ku socon lahayd,
\q1 Oo waxaan kula talin doonaa iyadoo ay ishaydu kula jirto.
\q1 
\v 9 Ha noqonina sida faraska ama baqalka aan garaadka lahayn,
\q1 Kuwaasoo hoggaankoodu yahay xakame iyo birtiisa in lagu hayo,
\q1 Haddii kalese innaba kuu soo dhowaan maayaan.
\q1 
\v 10 Kii shar leh waxaa ku dhici doona waxyaalo badan oo murug leh,
\q1 Laakiinse kii Rabbiga isku halleeya waxaa ku wareegsanaan doona naxariis.
\q1 
\v 11 Kuwiinna xaqa ahow, Rabbiga ku farxa oo reyreeya,
\q1 Oo inta qalbigoodu qumman yahayow, kulligiin farxad la dhawaaqa.
\b
\c 33
\q1 
\v 1 Kuwiinna xaqa ahow, Rabbiga ku reyreeya,
\q1 Waayo, kuwa qumman ammaan baa u habboon.
\q1 
\v 2 Rabbiga ugu mahadnaqa kataarad,
\q1 Oo isaga ammaan ugu heesa idinkoo ka dhawaajinaya shareerad toban xadhig leh.
\q1 
\v 3 Gabay cusub isaga ugu gabya,
\q1 Oo si farsamo wanaagsan ugaga dhawaajiya cod weyn.
\q1 
\v 4 Waayo, Rabbiga eraygiisu waa toosan yahay,
\q1 Oo shuqulkiisa oo dhanna waxaa lagu sameeyey aaminnimo.
\q1 
\v 5 Wuxuu jecel yahay xaqnimo iyo caddaalad,
\q1 Dhulka waxaa ka buuxda Rabbiga raxmaddiisa.
\q1 
\v 6 Samooyinka waxaa lagu sameeyey Rabbiga eraygiisa,
\q1 Oo guutooyinkooda oo dhanna waxaa lagu uumay neefta afkiisa.
\q1 
\v 7 Isagu biyaha badda intuu isku ururiyo ayuu wuxuu ka dhigaa sidii taallo oo kale,
\q1 Oo moolalka dhaadheerna wuxuu dhex dhigaa maqsinno.
\q1 
\v 8 Inta dhulka joogta oo dhammu Rabbiga ha ka cabsadeen,
\q1 Inta dunida deggan oo dhammu isaga ha ka baqeen.
\q1 
\v 9 Waayo, isagu wuu hadlay, wayna noqotay,
\q1 Oo wuu amray, wayna adkaatay.
\q1 
\v 10 Rabbigu quruumaha taladooda wuu baabbi'iyaa,
\q1 Oo dadyowga fikirradoodana wuu buriyaa.
\q1 
\v 11 Laakiinse Rabbiga taladiisu weligeedba way adkaataa,
\q1 Oo fikirrada qalbigiisuna waxay adkaadaan tan iyo ka ab ka ab.
\q1 
\v 12 Waxaa barakaysan quruunta Ilaaheedu Rabbiga yahay,
\q1 Taasoo ah dadka uu isagu u doortay dhaxalkiisa.
\q1 
\v 13 Rabbigu samaduu wax ka soo fiiriyaa,
\q1 Oo wuxuu arkaa binu-aadmiga oo dhan,
\q1 
\v 14 Oo meesha isaga rugta u ah
\q1 Ayuu wuxuu ka soo fiiriyaa kuwa dhulka deggan oo dhan,
\q1 
\v 15 Waa isaga kan qalbiyadooda oo dhan sameeya,
\q1 Oo shuqulladooda oo dhan u wada fiirsada.
\q1 
\v 16 Ma jiro boqor ku badbaada ciidan weyn,
\q1 Ninkii xoog badanuna iskuma samatabbixiyo xoog badan.
\q1 
\v 17 Faras waa waxmatare in badbaado laysugu halleeyo,
\q1 Oo weliba ninnaba kuma samatabbixiyo xooggiisa badan.
\q1 
\v 18 Bal eega, Rabbiga ishiisu waxay la jirtaa kuwa isaga ka cabsada,
\q1 Waana kuwa naxariistiisa rajeeya,
\q1 
\v 19 Inuu naftooda dhimashada ka samatabbixiyo,
\q1 Iyo inuu wakhtiga abaartaa sii nooleeyo iyaga.
\q1 
\v 20 Nafteennu waxay sugtay Rabbiga,
\q1 Waayo, isagu wuxuu inoo yahay caawimaad iyo gaashaan.
\q1 
\v 21 Haddaba qalbigeennu isaguu ku rayrayn doonaa,
\q1 Maxaa yeelay, innagu waxaynu isku halleeynay magiciisa quduuska ah.
\q1 
\v 22 Rabbiyow, naxariistaadu ha noogu soo degto,
\q1 Sidii aannu kaa rajaynay.
\c 34
\s2 Kanu waa sabuur Daa'uud tiriyey markii uu asluubtiisa ku hor beddelay Abiimeleg oo isaga eryay, dabadeedna wuu iska tegey.
\q1 
\v 1 Wakhti kasta ayaan Rabbiga ammaani doonaa,
\q1 Oo had iyo goorba ammaantiisu afkaygay ku jiri doontaa.
\q1 
\v 2 Naftaydu waxay ku faani doontaa Rabbiga,
\q1 Oo waxaa maqli doona kuwa camalka qabow, oo weliba way ku farxi doonaan.
\q1 
\v 3 Rabbiga ila weyneeya,
\q1 Oo aynu magiciisa wada sarraysiinno.
\q1 
\v 4 Rabbigaan doondoonay, oo isna wuu ii jawaabay,
\q1 Oo wuxuu iga samatabbixiyey waxyaalihii aan ka cabsaday oo dhan.
\q1 
\v 5 Iyagu waxay fiiriyeen isaga, oo way iftiimeen,
\q1 Oo wejigooduna weligood ceeboobi maayo.
\q1 
\v 6 Ninkan miskiinka ahu wuu qayshaday, oo Rabbiguna wuu maqlay,
\q1 Oo wuxuu ka badbaadshay dhibaatooyinkiisii oo dhan.
\q1 
\v 7 Malaa'igta Rabbigu waxay hareeraysaa kuwa isaga ka cabsada,
\q1 Oo weliba way samatabbixisaa.
\q1 
\v 8 Bal dhadhamiya oo arka in Rabbigu wanaagsan yahay,
\q1 Waxaa barakaysan ninkii isaga isku halleeya.
\q1 
\v 9 Kuwiinna quduusiintiisa ahow; Rabbiga ka cabsada,
\q1 Waayo, kuwa isaga ka cabsadaa waxba uma baahna.
\q1 
\v 10 Aaranka libaaxa wax baa ka dhimman, wayna gaajoodaan,
\q1 Laakiinse kuwa Rabbiga doondoonaa wax wanaagsan uma baahnaan doonaan.
\q1 
\v 11 Carruurtoy, kaalaya oo i dhegaysta,
\q1 Oo anna waxaan idin bari doonaa Rabbiga ka cabsashadiisa.
\q1 
\v 12 Bal waa ayo ninka nolol jecel,
\q1 Oo cimriga dheer doonayaa,
\q1 Si uu wanaag u arko?
\q1 
\v 13 Carrabkaaga shar ka jooji,
\q1 Bushimahaagana inay khiyaano ku hadlaan ka ilaali.
\q1 
\v 14 Shar ka leexo, oo wanaag samee,
\q1 Nabad doondoon, oo raacdayso iyada.
\q1 
\v 15 Rabbiga indhihiisu waxay fiiriyaan kuwa xaqa ah,
\q1 Oo dhegihiisuna waxay u furan yihiin baryadooda.
\q1 
\v 16 Wejiga Rabbigu waa ka gees kuwa sharka sameeya
\q1 Inuu iyaga xusuustooda dhulka ka baabbi'iyo.
\q1 
\v 17 Kuwa xaqa ahu way qayshadeen, oo Rabbigaa maqlay,
\q1 Oo wuxuu iyaga ka samatabbixiyey dhibaatooyinkoodii oo dhan.
\q1 
\v 18 Rabbigu waa u dhow yahay kuwa dembigooda ka caloolyaysan,
\q1 Oo kuwa ruuxoodu qoomamaysan yahayna wuu badbaadiyaa.
\q1 
\v 19 Kan xaqa ah dhibaatooyinkiisu way tiro badan yihiin,
\q1 Laakiinse Rabbigu waa ka samatabbixiyaa dhammaantoodba.
\q1 
\v 20 Isagu wuxuu dhawraa lafihiisa oo dhan,
\q1 Oo middoodna ma jabna.
\q1 
\v 21 Xumaan baa dili doonta kuwa sharka leh,
\q1 Oo kuwa neceb kan xaqa ahna waa la eedayn doonaa.
\q1 
\v 22 Rabbigu nafta addoommadiisa wuu soo furtaa,
\q1 Oo kuwa isaga isku halleeya, midkoodna lama eedayn doono.
\c 35
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Rabbiyow, la dirir kuwa ila dirira,
\q1 Oo la dagaallan kuwa ila dagaallama.
\q1 
\v 2 Gaashaan iyo gabbaad qaado.
\q1 Oo caawimaaddayda daraaddeed u istaag.
\q1 
\v 3 Waran la soo bax, oo kuwa i eryanaya jidka ka goo,
\q1 Oo naftayda waxaad ku tidhaahdaa, Anigu waxaan ahay badbaadadaada.
\q1 
\v 4 Kuwa naftayda doondoonayaa ha ceeboobeen, oo sharafdarro ha ku soo degto,
\q1 Oo kuwa waxyeelladayda u arrinsanayana dib ha loo celiyo, oo ha wareereen.
\q1 
\v 5 Ha noqdeen sida buunshe dabaysha hor socda,
\q1 Oo malaa'igta Rabbigu horay u sii kaxaynayso.
\q1 
\v 6 Jidkoodu ha noqdo gudcur iyo meel simbiriirixo leh,
\q1 Oo malaa'igta Rabbigu ha eryato.
\q1 
\v 7 Waayo, iyagu sababla'aan bay dabin god iigu qarsheen,
\q1 Oo sababla'aan bay naftayda god ugu qodeen.
\q1 
\v 8 Isagoo aan iska jirin halligaadu ha ku soo degto,
\q1 Oo dabinkiisuu qariyey isaga ha qabsado,
\q1 Oo isagu halligaaddaas ha ku dhaco.
\q1 
\v 9 Oo naftayduna Rabbigay aad ugu farxi doontaa,
\q1 Oo waxay ku rayrayn doontaa badbaadintiisa.
\q1 
\v 10 Lafahayga oo dhammu waxay odhan doonaan, Rabbiyow, bal yaa kula mid ah?
\q1 Kaaga kii miskiin ah ka samatabbixiya kii isaga ka xoog badan,
\q1 Haah, oo kii miskiin ah iyo kan baahanba ka samatabbixiya kii dhaca.
\q1 
\v 11 Waxaa kaca markhaatiyaal xaqdarro ah,
\q1 Oo waxay i weyddiiyaan waxyaalo aanan ogayn.
\q1 
\v 12 Wanaag xumaan bay iigaga abaalgudaan
\q1 Oo naftayda way gacal tiraan.
\q1 
\v 13 Laakiinse markay bukeen, dharkaygu wuxuu ahaa joonyado,
\q1 Oo naftaydana soon baan ku dhibay,
\q1 Oo tukashadayduna laabtayday ku soo noqotay.
\q1 
\v 14 Anigu waxaan u qaatay sidii isagoo ah saaxiibkay ama walaalkay,
\q1 Oo waxaan la foororsaday baroorasho sida mid hooyadiis u baroorta.
\q1 
\v 15 Laakiinse anigu markaan turunturooday ayay reyreeyeen, oo way isa soo wada urursadeen,
\q1 Oo waxmatarayaashii ayaa dhammaantood ii wada shiray, oo anna ma aan ogayn innaba,
\q1 Way i dildillaacsadeen oo imana ay dayn.
\q1 
\v 16 Sida labawejiilayaashu diyaafado uga dhex majaajiloodaan
\q1 Ayay igu ilko jirriqsadeen.
\q1 
\v 17 Sayidow, ilaa goormaad sii fiirinaysaa?
\q1 Naftayda halligaaddooda ka badbaadi,
\q1 Noloshaydana libaaxyada ka badbaadi.
\q1 
\v 18 Waxaan kaaga mahadnaqi doonaa shirka weyn dhexdiisa,
\q1 Oo dad fara badan dhexdooda ayaan kugu ammaani doonaa.
\q1 
\v 19 Kuwa sida qaladka ah cadowga iigu ahi, yaanay igu rayrayn,
\q1 Oo kuwa sababla'aanta ii necebuna yaanay isu il jebin.
\q1 
\v 20 Waayo, iyagu nabad kuma hadlaan,
\q1 Laakiinse waxay hadallo khiyaano miidhan ah ugu hindisaan kuwa dalka ku xasilloon.
\q1 
\v 21 Afkoodii aad bay iigu fureen,
\q1 Oo waxay yidhaahdeen, Ahaa, ahaa, annagaa indhahayaga ku aragnay.
\q1 
\v 22 Rabbiyow, adigu waad aragtay, haddaba ha iska aamusin,
\q1 Sayidow, ha iga fogaan.
\q1 
\v 23 Sara joogso, oo garsooriddayda u toos,
\q1 Oo dacwadayda dhegayso, Ilaahayow, Sayidkayow.
\q1 
\v 24 Rabbiyow, Ilaahayow, igu xukun sida ay xaqnimadaadu tahay,
\q1 Oo yaanay igu rayrayn.
\q1 
\v 25 Yaanay qalbigooda iska odhan, Ahaa, sidaasaannu doonaynaa,
\q1 Yaanay odhan, Isagii waannu liqnay.
\q1 
\v 26 Kuwa waxyeelladayda ku reyreeyaa ha wada ceeboobeen oo ha isku wareereen dhammaantood,
\q1 Oo iyagu ha huwadeen ceeb iyo sharafdarro kuwa iska kay weynaysiiyaa.
\q1 
\v 27 Kuwa xaqnimadayda jecelu farxad ha ku dhawaaqeen, oo ha farxeen,
\q1 Oo had iyo goorba ha yidhaahdeen, Rabbiga ha la weyneeyo,
\q1 Waayo, isagu wuxuu ku farxaa barwaaqada addoonkiisa.
\q1 
\v 28 Oo maalinta oo dhan carrabkaygu wuxuu ka hadli doonaa
\q1 Xaqnimadaada iyo ammaantaadaba.
\c 36
\s2 Kanu waa sabuur uu Daa'uud oo ahaa addoonkii Rabbiga u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Kii shar leh xadgudubkiisu wuxuu qalbigiisa ka yidhaahdaa,
\q1 Ilaah ka cabsashadiisu indhahayga ma hor taal.
\q1 
\v 2 Waayo, wuu isfaaniyaa inaan dembigiisa la garan karin
\q1 Oo aan la nebcaanayn.
\q1 
\v 3 Erayada afkiisu waa xumaan iyo khiyaano,
\q1 Oo inuu caqliyaysto iyo inuu wax wanaagsan sameeyoba wuu iska daayay.
\q1 
\v 4 Wuxuu sariirtiisa ku hindisaa xumaan,
\q1 Oo wuxuu joogsadaa jid aan wanaagsanayn,
\q1 Oo weliba sharka ma naco.
\q1 
\v 5 Rabbiyow, raxmaddaadu samooyinkay ku jirtaa,
\q1 Aaminnimadaaduna daruurahay gaadhaa.
\q1 
\v 6 Xaqnimadaadu waa sida buuraha Ilaah,
\q1 Oo xukummadaaduna waa mool dheer,
\q1 Rabbiyow, waxaad nabad gelisaa dadka iyo duunyadaba.
\q1 
\v 7 Ilaahow, raxmaddaadu qaalisanaa!
\q1 Oo binu-aadmiguna wuxuu magangalaa hooska baalashaada.
\q1 
\v 8 Aad bay uga dhergi doonaan barwaaqada gurigaaga,
\q1 Oo waxaad iyaga ka waraabin doontaa webiga farxaddaada.
\q1 
\v 9 Waayo, isha noloshu aday kula jirtaa,
\q1 Oo iftiinkaagaannu iftiin ku aragnaa.
\q1 
\v 10 Raxmaddaada ugu sii wad kuwa ku yaqaan,
\q1 Oo xaqnimadaadana kuwa qalbigoodu qumman yahay.
\q1 
\v 11 Cagta kuwa kibirsan yaanay ii iman,
\q1 Oo kuwa sharka leh gacantooduna yaanay i eryin.
\q1 
\v 12 Xumaanfalayaashu halkaasay ku dhaceen,
\q1 Iyaga hoos baa loo riday, oo mana ay kari doonaan inay mar dambe soo kacaan.
\c 37
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Ha isku dhibin xumaanfalayaasha aawadood,
\q1 Hana uga hinaasin kuwa xaqdarrada sameeya.
\q1 
\v 2 Waayo, iyaga haddiiba waxaa loo jari doonaa sida cawska oo kale,
\q1 Oo waxay u engegi doonaan sida geedo yaryar oo qoyan.
\q1 
\v 3 Rabbiga isku hallee oo wanaag samee,
\q1 Oo sidaasaad dalka ku degganaan doontaa, oo ammaan baad ku daaqi doontaa.
\q1 
\v 4 Haddaba Rabbiga ku farax,
\q1 Oo wuxuu ku siin doonaa waxa qalbigaagu doonayo.
\q1 
\v 5 Jidkaaga Rabbiga ku aamin,
\q1 Isagana isku hallee, wuuna samaynayaaye.
\q1 
\v 6 Xaqnimadaada wuxuu u soo bixin doonaa sida nuurka oo kale,
\q1 Gartaadana sida duhurka oo kale.
\q1 
\v 7 Rabbiga ku hor xasilloonow, oo isaga samir ku sug,
\q1 Oo ha isku dhibin kii jidkiisa ku barwaaqaysan
\q1 Iyo ninkii hindisooyin shar ah sameeya toona.
\q1 
\v 8 Cadhada ka joogso, oo dhirifka ka tag,
\q1 Hana isku dhibin inaad shar samaysid.
\q1 
\v 9 Waayo, xumaanfalayaashu way go'i doonaan,
\q1 Laakiinse kuwa Rabbiga sugaa dalkay dhaxli doonaan.
\q1 
\v 10 Wakhti yar dabadeedna kan sharka lahu ma jiri doono,
\q1 Bal meeshiisa aad baad ugu fiirsan doontaa, oo isna ma jiri doono.
\q1 
\v 11 Laakiinse kuwa camalka qabow dalkay dhaxli doonaan,
\q1 Oo waxay ku farxi doonaan nabad badan.
\q1 
\v 12 Kan sharka lahu wuxuu shirqool u dhigaa kan xaqa ah,
\q1 Oo isaga ayuu u ilko jirriqsadaa.
\q1 
\v 13 Oo Sayidku wuu ku qosli doonaa isaga,
\q1 Waayo, wuxuu arkaa in maalintiisu soo dhowaanayso.
\q1 
\v 14 Kuwa sharka lahu waxay la bexeen seeftoodii, qaansadoodiina way xooteen,
\q1 Si ay miskiinka iyo kan baahan hoos ugu tuuraan,
\q1 Oo ay laayaan kuwa jidkooda ku qumman.
\q1 
\v 15 Seeftoodu waxay mudi doontaa wadnahooda,
\q1 Oo qaansooyinkooduna way kala jebi doonaan.
\q1 
\v 16 Inta yar oo mid xaq ahu haystaa
\q1 Way ka sii wanaagsan tahay kuwa sharka leh maalkooda badan.
\q1 
\v 17 Waayo, kuwa sharka leh gacmahoodu way jebi doonaan,
\q1 Laakiinse Rabbigu kuwa xaqa ah wuu tiiriyaa.
\q1 
\v 18 Rabbigu wuu yaqaan kuwa kaamilka ah cimrigooda,
\q1 Oo dhaxalkooduna weligiisba wuu waarayaa.
\q1 
\v 19 Iyagu ma ceeboobi doonaan wakhtiga shar jiro,
\q1 Oo wakhtiga abaaru dhacdona way dhergi doonaan.
\q1 
\v 20 Laakiinse kuwa sharka lahu way halligmi doonaan,
\q1 Cadaawayaasha Rabbiguna waxay ahaan doonaan sida inta wanaagsan oo doogga,
\q1 Way baabbi'i doonaan, sida qiiqa oo kale way u baabbi'i doonaan.
\q1 
\v 21 Kii shar lahu wax buu amaahdaa, mana bixiyo mar dambe,
\q1 Laakiinse kan xaqa ahu wuu naxariistaa, waxna wuu bixiyaa.
\q1 
\v 22 Oo kuwuu barakeeyo ayaa dalka dhaxli doona,
\q1 Laakiinse kuwuu habaaraa way go'i doonaan.
\q1 
\v 23 Dadka socodkiisa waxaa hagaajiya Rabbiga,
\q1 Oo jidkiisuu ku farxaa.
\q1 
\v 24 Oo in kastoo uu kufo, haddana ma wada dhici doono,
\q1 Waayo, Rabbiga ayaa gacantiisa ku tiiriya.
\q1 
\v 25 Waan dhallin yaraan jiray, oo haatanna waan gaboobay,
\q1 Oo weligay ma arag mid xaq ah oo la dayriyey,
\q1 Ama carruurtiisa oo cunto tuugsanaysa.
\q1 
\v 26 Maalinta oo dhan wuu naxariistaa oo wax buu amaahiyaa,
\q1 Oo carruurtiisuna way barakaysan yihiin.
\q1 
\v 27 Sharka ka fogow, oo wanaag samee,
\q1 Oo weligaa baad degganaan doontaa.
\q1 
\v 28 Waayo, Rabbigu wuxuu jecel yahay caddaaladda,
\q1 Mana uu dayrsho quduusiintiisa,
\q1 Laakiinse iyaga weligoodba waa la ilaashaa,
\q1 Illowse kuwa sharka leh carruurtoodu way go'i doonaan.
\q1 
\v 29 Kuwa xaqa ahu dalkay dhaxli doonaan,
\q1 Oo weligoodna way dhex degganaan doonaan.
\q1 
\v 30 Kan xaqa ah afkiisu wuxuu ka hadlaa xigmadda,
\q1 Carrabkiisuna wuxuu ku hadlaa caddaaladda.
\q1 
\v 31 Oo Ilaahiisa sharcigiisu waa ku jiraa qalbigiisa,
\q1 Oo tallaabooyinkiisana midnaba dib uma simbiriirixan doonto.
\q1 
\v 32 Kan sharka lahu wuxuu fiiriyaa kan xaqa ah,
\q1 Oo wuxuu doondoonaa inuu isaga dilo.
\q1 
\v 33 Rabbigu isaga gacantiisa ku dayn maayo,
\q1 Oo eedayn maayo marka la xukumo isaga.
\q1 
\v 34 Rabbiga sug, oo jidkiisa xaji,
\q1 Oo wuxuu kuu sara marin doonaa inaad dalka dhaxasho,
\q1 Waad arki doontaa marka kuwa sharka lahu go'aan.
\q1 
\v 35 Waxaan arkay ku shar leh oo dulun badan,
\q1 Oo isu kala bixiya sida geed cagaar ah oo dhulkiisii ka baxay.
\q1 
\v 36 Laakiin waa la ag maray, oo isagii lama arag,
\q1 Oo waan doondoonay, laakiinse waa la waayay.
\q1 
\v 37 Bal fiiri ninka kaamilka ah, oo bal eeg, kan qumman,
\q1 Waayo, ninkaas ugu dambaystiisu waa nabad.
\q1 
\v 38 Laakiinse kuwa xadgudbaa dhammaantood wadajir bay u baabbi'i doonaan,
\q1 Oo kuwa sharka lahuna ugu dambaystooda way go'i doonaan.
\q1 
\v 39 Kuwa xaqa ahse badbaadadoodu waa xagga Rabbiga,
\q1 Oo wakhtiga dhibaatada isagu waa qalcaddooda.
\q1 
\v 40 Oo Rabbigu iyaguu caawiyaa, wuuna samatabbixiyaa,
\q1 Oo wuxuu iyaga ka samatabbixiyaa kuwa sharka leh, wuuna badbaadiyaa,
\q1 Maxaa yeelay, isagay magangaleen.
\c 38
\s2 Kanu waa sabuur Daa'uud tiriyey inuu wax ku xusuusto.
\q1 
\v 1 Rabbiyow, cadhadaada ha igu canaanan,
\q1 Oo dhirifkaaga kululna ha igu edbin.
\q1 
\v 2 Waayo, fallaadhahaagii aad bay ii mudeen,
\q1 Oo gacantaaduna way igu soo degtay.
\q1 
\v 3 Jidhkaygu fayoobaan ma leh, waana xanaaqaaga daraaddiis,
\q1 Oo lafahayguna caafimaad ma leh, waana dembigayga daraaddiis.
\q1 
\v 4 Waayo, xumaatooyinkaygii waxay ka sare mareen madaxayga,
\q1 Sida rar culus ayay igu culus yihiin aad iyo aad.
\q1 
\v 5 Nabrahaygu way urayaan, wayna qudhmuun yihiin,
\q1 Waana nacasnimadayda daraaddeed.
\q1 
\v 6 Waan xanuunsanayaa, oo aad baan hoos ugu gotay,
\q1 Oo maalinta oo dhanna oohin baan la wareegaa.
\q1 
\v 7 Waayo, dhexdayda waxaa ka buuxa olol,
\q1 Oo jidhkayguna fayoobaan ma leh.
\q1 
\v 8 Waan itaal daranahay, oo aad baan u burbursanahay,
\q1 Oo waxaan la cabaaday buuqa qalbigayga ku jira.
\q1 
\v 9 Sayidow, waxaan jeclahay oo dhammu waxay yaalliin hortaada,
\q1 Oo taahiddayduna kaama qarsoona.
\q1 
\v 10 Wadnahaa i fig leh, oo xooggaygiina waa i gabay,
\q1 Oo weliba iftiinkii indhahayguna waa iga tegey.
\q1 
\v 11 Kuwa i jecel iyo saaxiibbadayba belaayadayda way ka durkaan,
\q1 Oo xigaaladaydiina meel fog bay istaagaan.
\q1 
\v 12 Oo kuwa naftayda doondoonaana dabinno bay ii dhigaan,
\q1 Oo kuwa inay wax i yeelaan doonayaana waxay ku hadlaan waxyaalo xun,
\q1 Oo maalinta oo dhan waxay ku tashadaan khiyaano.
\q1 
\v 13 Laakiinse anigu waxba kama maqlo sida nin dhega la',
\q1 Oo waxaan la mid ahay nin carrab la' oo aan afkiisa kala qaadin.
\q1 
\v 14 Haah, oo waxaan la mid ahay nin aan waxba maqlin,
\q1 Oo aan afkiisa murammo ku jirin.
\q1 
\v 15 Waayo, Rabbiyow, adaan wax kaa rajaynayaa,
\q1 Oo adna waad ii jawaabi doontaa, Sayidow Ilaahaygiiyow.
\q1 
\v 16 Waayo, waxaan idhi, Yaanay igu rayrayn,
\q1 Oo markii cagtaydu simbiriirixato, yaanay iska kay weynayn.
\q1 
\v 17 Waayo, waxaan ku dhowahay inaan dhaco,
\q1 Oo tiiraanyadayduna had iyo goorba way i hor taalaa.
\q1 
\v 18 Haddaba anigu xumaantayda waan sheegi doonaa,
\q1 Oo dembigaygana waan ka qoomamoon doonaa.
\q1 
\v 19 Laakiinse cadaawayaashaydu waa dadaal badan yihiin, xoogna way leeyihiin,
\q1 Oo kuwa gardarrada igu necebuna way tarmeen.
\q1 
\v 20 Oo weliba kuwa sharka wanaagga ku gudaana
\q1 Waa cadaawayaashayda, maxaa yeelay, waxaan raacaa waxa wanaagsan.
\q1 
\v 21 Rabbiyow, ha i dayrin,
\q1 Ilaahayow, ha iga fogaan.
\q1 
\v 22 Soo dhaqso oo i caawi,
\q1 Sayidow, badbaadadaydow.
\c 39
\s2 Kanu waa sabuur Daa'uud u tiriyey Yeduutuun oo ahaa madaxdii muusikaystayaasha.
\q1 
\v 1 Waxaan idhi, Jidadkaygaan iska jiri doonaa,
\q1 Si aanan carrabkayga ugu dembaabin,
\q1 Oo afkayga waxaan ku qaban doonaa xakame inta kii shar lahu i hor joogo.
\q1 
\v 2 Waan carrab beelay oo shib baan iska idhi, oo waan ka aamusay xataa wixii wanaagsanaa,
\q1 Tiiraanyadaydiina waa kacday.
\q1 
\v 3 Qalbigaygu uurkayguu ku kululaaday,
\q1 Oo intii aan fikirayay ayaa dabkii shidmay,
\q1 Markaasaan carrabkaygii ku hadlay, oo idhi,
\q1 
\v 4 Rabbiyow, i ogaysii ugu dambaystayda
\q1 Iyo cimrigayga dhererkiisu intuu yahay,
\q1 Oo i ogaysii inta tabardarradaydu tahay.
\q1 
\v 5 Bal eeg, maalmahayga waxaad ka dhigtay calaacal ballaadhkeed
\q1 Oo cimrigayguna hortaada waxba kuma aha,
\q1 Hubaal nin kastaba marka xaalkiisu ugu wanaagsan yahay dhammaantiis waa bilaash. (Selaah)
\q1 
\v 6 Hubaal nin kastaaba wuxuu ku socdaa hawo been ah,
\q1 Hubaal waxay ku rabshaysan yihiin hawo been ah,
\q1 Isagu maal buu tuulaa, mana uu yaqaan kii urursan doona.
\q1 
\v 7 Haddaba Sayidow, bal maxaan sugaa?
\q1 Waayo, rajadaydu adigay kugu xidhan tahay.
\q1 
\v 8 Xadgudubyadayda oo dhan iga samatabbixi,
\q1 Oo ha iga dhigin mid nacasyadu caayaan.
\q1 
\v 9 Anigu waan carrab la'aa, oo afkaygana ma aan kala qaadin,
\q1 Maxaa yeelay, sidaasaad yeeshay.
\q1 
\v 10 Haddaba belaayadaada iga durki,
\q1 Maxaa yeelay, waxaa i baabbi'iyey weerarka gacantaada.
\q1 
\v 11 Markaad dadka canaanta ku edbisid xumaanta daraaddeed,
\q1 Waxaad quruxdiisa ka dhigtaa inay u baabba'do sidii balanbaallis oo kale,
\q1 Hubaal nin kastaaba waa bilaash. (Selaah)
\q1 
\v 12 Rabbiyow, baryadayda maqal, oo qayladaydana dhegta u dhig,
\q1 Oo ilmadaydana ha iskaga aamusin,
\q1 Waayo, waxaan ahay qariib kula jooga
\q1 Oo masaafir ah, sidii awowayaashay oo dhammu ay ahaan jireen.
\q1 
\v 13 Ii tudh, itaalkaygu mar ha igu soo noqdee,
\q1 Intaanan meesha tegin oo aanan mar dambe ka soo noqonayn.
\c 40
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Anigu Rabbiga samir baan ku sugay,
\q1 Oo isna wuu i soo jalleecay, qayladaydiina wuu maqlay,
\q1 
\v 2 Oo weliba wuxuu iga soo bixiyey yamays baabba' ah, iyo dhoobada dhiriqda ah,
\q1 Oo wuxuu cagaha ii saaray dhagax weyn, oo socodkaygiina wuu xoogeeyey.
\q1 
\v 3 Oo afkaygiina wuxuu geliyey gabay cusub, kaas oo ah ammaanta Ilaaheenna.
\q1 Kuwo badan baa arki doona, wayna cabsan doonaan,
\q1 Rabbigayna isku hallayn doonaan.
\q1 
\v 4 Waxaa barakaysan ninkii Rabbiga isku halleeya,
\q1 Oo aan u jeedin kuwa kibirsan ama kuwa beenta ku leexda.
\q1 
\v 5 Rabbiyow, Ilaahayow, shuqullada yaabka badan oo aad samaysay way badan yihiin,
\q1 Oo fikirradaada aad naga qabtidna way badan yihiin,
\q1 Oo iyaga lama xisaabi karo,
\q1 Haddii aan sheego oo ka hadlo,
\q1 Iyagu way ka sii badan yihiin wax la tirin karo.
\q1 
\v 6 Allabari iyo qurbaan kuma aad faraxsanid,
\q1 Oo anna dhegahaygii waad ii furtay,
\q1 Qurbaan la gubo iyo qurbaanka dembiga midna ima aad weyddiisan.
\q1 
\v 7 Oo markaasaan idhi, Bal eeg, anigu waan imid,
\q1 Oo kitaabka duudduuban wax igu saabsan baa ku qoran.
\q1 
\v 8 Ilaahayow, waxaan jeclahay inaan sameeyo doonistaada,
\q1 Haah, oo sharcigaagu wuxuu ku dhex jiraa qalbigayga.
\q1 
\v 9 Xaqnimo baan shirka weyn ku dhex wacdiyey,
\q1 Oo bal eeg, inaanan bushimahayga ka joojin,
\q1 Waad og tahay, Rabbiyow.
\q1 
\v 10 Xaqnimadaada qalbigayga kuma aan qarin,
\q1 Aaminnimadaada iyo badbaadintaadana waan sheegay,
\q1 Oo raxmaddaada iyo runtaadana kama aan qarin shirka weyn.
\q1 
\v 11 Rabbiyow, naxariistaada ha iga ceshan,
\q1 Raxmaddaada iyo runtaaduna had iyo goorba ha i dhawreen.
\q1 
\v 12 Waayo, xumaatooyin aan la tirin karin ayaa i hareereeyey,
\q1 Oo dembiyadaydii ayaa i qabsaday, sidaas daraaddeed kor ma fiirin karo,
\q1 Iyagu way ka badan yihiin timaha madaxayga, oo qalbigaygiina waa i gabay.
\q1 
\v 13 Rabbiyow, waan ku baryayaaye, i samatabbixi,
\q1 Rabbiyow, u soo dhaqso inaad i caawiso.
\q1 
\v 14 Kuwa doonaya inay naftayda halligaan ha ceeboobeen,
\q1 Oo dhammaantood ha wareereen,
\q1 Oo kuwa waxyeelladayda ku farxana
\q1 Dib ha loo celiyo, oo sharafdarro ha ku soo degto.
\q1 
\v 15 Kuwa aniga, Ahaa, Ahaa, igu yidhaahda,
\q1 Ceebtooda daraaddeed ha la fajeceen.
\q1 
\v 16 Kuwa adiga ku doondoona oo dhammu ha reyreeyeen oo ha kugu farxeen,
\q1 Oo kuwa badbaadintaada jecelu had iyo goorba ha yidhaahdeen,
\q1 Rabbiga ha la weyneeyo!
\q1 
\v 17 Laakiinse anigu waxaan ahay miskiin iyo mid baahan,
\q1 Sayidkuse waa i xusuustaa.
\q1 Ilaahayow, waxaad tahay caawimaaddayda iyo samatabbixiyahayga,
\q1 Haddaba ha iga raagin.
\c 41
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Waxaa barakaysan kii ka fikira miskiinka,
\q1 Maalinta shar jiro Rabbigu waa samatabbixin doonaa isaga.
\q1 
\v 2 Rabbigu wuu dhawri doonaa, wuuna sii noolayn doonaa, oo isaguna dhulkuu ku barakaysnaan doonaa.
\q1 Rabbow, isaga ha u gacangelin sida cadaawayaashiisu rabaan.
\q1 
\v 3 Rabbigu wuxuu isaga ku gargaari doonaa sariirta taagdarradiisa.
\q1 Oo markuu bukana sariirtiisa oo dhan waad u hagaajisaa.
\q1 
\v 4 Anigu waxaan idhi, Rabbiyow, ii naxariiso,
\q1 Oo naftayda bogsii, waayo, waan kugu dembaabay.
\q1 
\v 5 Cadaawayaashaydu shar bay iga sheegaan, oo waxay yidhaahdaan,
\q1 War goormuu dhiman doonaa, oo magiciisu baabbi'i doonaa?
\q1 
\v 6 Oo midkood hadduu i soo booqdona been buu ku hadlaa,
\q1 Oo qalbigiisuna xumaatuu urursadaa; oo markuu dibadda u baxo ayuu ka warramaa.
\q1 
\v 7 Kuwa i neceb oo dhammu anigay ii wada faqaan,
\q1 Oo waxay iigu wada tashadaan si ay wax ii yeelaan.
\q1 
\v 8 Waxay yidhaahdaan, Cudur xun baa isagii ku dhacay,
\q1 Oo haatan wuu jiifaa, mar dambena sooma uu kici doono.
\q1 
\v 9 Xataa saaxiibkaygii aan isku halleeyey, oo kibistaydii cunay,
\q1 Ayaa cedhibtiisa ii qaaday.
\q1 
\v 10 Laakiinse, Rabbiyow, ii naxariiso, oo mar i sara jooji,
\q1 Aan iyaga ka aar goostee.
\q1 
\v 11 Tan ayaan ku garanayaa inaad igu faraxsan tahay,
\q1 Maxaa yeelay, cadowgaygu igama guulaysto.
\q1 
\v 12 Laakiinse aniga waxaad ii tiirisaa daacadnimadayda aawadeed,
\q1 Oo weligaaba waxaad i fadhiisisaa wejigaaga hortiisa.
\q1 
\v 13 Weligiis iyo weligiisba
\q1 Waxaa mahad leh Rabbiga ah Ilaaha Israa'iil.
\q1 Aamiin iyo Aamiin.
\c 42
\s1 Kitaabka Labaad
\s2 Sabuurrada 42-72
\s2 Kanu waa gabay Maskiil ah oo ay reer Qorax u tiriyeen madaxdii muusikaystayaasha.
\q1 
\v 1 Sida deeradu biyaha durdurka ugu harraaddo,
\q1 Ayay naftaydu kuugu harraaddaa, Ilaahayow.
\q1 
\v 2 Naftaydu waxay u oomman tahay Ilaah, kaasoo ah Ilaaha nool.
\q1 Goormaan u tegi doonaa oo aan Ilaah hortiisa ka muuqan doonaa?
\q1 
\v 3 Habeen iyo maalinba waxaa cunto ii noqday ilmadaydii,
\q1 Intay had iyo goorba i leeyihiin, Ilaahaagu meeh?
\q1 
\v 4 Haddaba waan qarracmaa markaan soo xusuusto waxyaalahan,
\q1 Sidaan guutada u raaci jiray, oo aan iyaga ugu hor kici jiray guriga Ilaah,
\q1 Annagoo ku heesayna cod farxad ah iyo ammaan, oo ah dad fara badan oo iidaya.
\q1 
\v 5 Naftaydoy, bal maxaad u murugaysan tahay?
\q1 Oo bal maxaad gudahayga ugu rabshaysan tahay?
\q1 Ilaah ku kalsoonow, waayo, weli waxaan isaga u ammaanayaa caawimaadda wejigiisa.
\q1 
\v 6 Ilaahayow, naftaydu waa igu murugaysan tahay,
\q1 Oo sidaas daraaddeed waxaan ka xusuusnahay dalkii Urdun,
\q1 Iyo fiiqfiiqyada Buur Xermoon iyo Buur Miscaar.
\q1 
\v 7 Moolba mool buu u yeedhaa markay biya dhacu qaylinayaan,
\q1 Hirarkaagii iyo mawjadahaagii oo dhammu dushayday mareen.
\q1 
\v 8 Laakiinse Rabbigu maalinnimada wuxuu soo diri doonaa raxmaddiisa,
\q1 Oo habeennimadana waxaa ila jiri doona gabaygiisa,
\q1 Iyo baryootanka aan Ilaaha noloshayda baryo.
\q1 
\v 9 Waxaan Ilaaha dhagaxayga weyn ah ku odhan doonaa, Bal maxaad ii illowday?
\q1 Dulmiga cadowga daraaddiis bal maxaan ula sii cabaadaa?
\q1 
\v 10 Sida iyadoo seefu lafahayga burburinayso, ayaa cadaawayaashaydu i caayaan,
\q1 Intay had iyo goorba i leeyihiin, Ilaahaagu meeh?
\q1 
\v 11 Naftaydoy, bal maxaad u murugaysan tahay?
\q1 Oo bal maxaad gudahayga ugu rabshaysan tahay?
\q1 Ilaah ku kalsoonow, waayo, weli waxaan ammaanayaa
\q1 Isagoo ah caawimaadda wejigayga iyo Ilaahay.
\b
\c 43
\q1 
\v 1 Ilaahow, ii gar soor, oo dacwadayda kala muddac quruun aan cibaado lahayn,
\q1 Iga samatabbixi ninka khiyaanada badan oo xaqa daran.
\q1 
\v 2 Waayo, waxaad tahay Ilaaha xoogga ii ah, bal maxaad ii xoortay?
\q1 Dulmiga cadowga daraaddiis bal maxaan ula sii cabaadaa?
\q1 
\v 3 Nuurkaaga iyo runtaada ii soo dir, oo ha i hoggaamiyeen,
\q1 Oo ha i keeneen buurtaada quduuska ah, iyo taambuugyadaada.
\q1 
\v 4 Oo markaasaan tegi doonaa meesha allabariga Ilaah,
\q1 Iyo Ilaaha ah farxaddayda weyn,
\q1 Ilaahow, Ilaahaygiiyow, kataaradda waan kugu ammaani doonaa.
\q1 
\v 5 Naftaydoy, bal maxaad u murugaysan tahay?
\q1 Oo bal maxaad gudahayga ugu rabshaysan tahay?
\q1 Ilaah ku kalsoonow, waayo, weli waxaan ammaanayaa
\q1 Isagoo ah caawimaadda wejigayga iyo Ilaahay.
\c 44
\s2 Kanu waa sabuur Maskiil ah oo reer Qorax u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Ilaahow, dhegahayagaannu ku maqallay, oo waxaa noo sheegay awowayaashayo
\q1 Shuqulkii aad samaysay wakhtigoodii oo ahaa waa hore.
\q1 
\v 2 Quruumihii gacantaadaad ku eriday, oo meeshoodii awowayaashayo baad ku beertay,
\q1 Dadyowgii waad dhibtay, oo dibaddaad ku kala firdhisay.
\q1 
\v 3 Waayo, iyagu dalka kuma hantiyin seeftooda,
\q1 Oo cududdooduna ma ay badbaadin,
\q1 Laakiinse midigtaada iyo cududdaada iyo nuurka wejigaaga ayaa badbaadshay iyaga,
\q1 Maxaa yeelay, raalli baad ka ahayd.
\q1 
\v 4 Ilaahow, waxaad tahay boqorkayga,
\q1 Haddaba reer Yacquub samatabbixin u amar.
\q1 
\v 5 Adiga daraaddaa ayaannu cadaawayaashayada hoos ugu riixaynaa,
\q1 Oo magacaaga daraaddiis ayaan kula tumanaynaa kuwa nagu kaca.
\q1 
\v 6 Waayo, qaansadayda isku hallayn maayo,
\q1 Oo seeftayduna i badbaadin mayso.
\q1 
\v 7 Laakiinse adigu cadaawayaashayadaad naga badbaadisay,
\q1 Oo kuwa na necebna waad ceebaysay.
\q1 
\v 8 Maalinta oo dhan waxaannu ku faannaa Ilaah,
\q1 Oo annana weligayo waxaannu ku mahadnaqaynaa magacaaga. (Selaah)
\q1 
\v 9 Laakiinse haatan waad na xoortay, oo sharafdarrona waad nagu soo dejisay,
\q1 Oo weliba ciidammadayadana ma aad hor kacdid.
\q1 
\v 10 Waxaa dib nooga celisaa cadowgayaga hortiisa,
\q1 Oo kuwa na necebuna way na dhacaan.
\q1 
\v 11 Waxaad naga dhigtay sidii ido la qalayo,
\q1 Oo waxaad nagu kala firdhisay quruumaha dhexdooda.
\q1 
\v 12 Dadkaaga qiimola'aan baad ku iibisaa,
\q1 Oo maalkaagana kuma aad kordhin qiimahoodii.
\q1 
\v 13 Deriskayaga waxaad nooga dhigtaa cay,
\q1 Oo kuwa hareerahayaga ku wareegsanna waxaad nooga dhigtaa quudhsasho iyo qosol.
\q1 
\v 14 Quruumaha dhexdooda waxaad nooga dhigtaa halqabsi,
\q1 Dadyowga dhexdoodana waxaad nooga dhigtaa kuwa madaxa laga lulo.
\q1 
\v 15 Maalinta oo dhan sharafdarradaydu way i hor taal,
\q1 Oo waxaa iga muuqatay ceebtii wejigayga,
\q1 
\v 16 Waayo, sababtu waxaa weeye codka kan i caaya oo i af xumeeya,
\q1 Iyo cadowga iyo kan iga aarguta daraaddood.
\q1 
\v 17 Waxyaalahaas oo dhammu way nagu dhaceen, laakiinse weli kuma aannu illoobin,
\q1 Axdigaagana khiyaano kuma aannu samayn.
\q1 
\v 18 Qalbigayagu dib uma noqon,
\q1 Oo tallaabooyinkayaguna jidkaaga kama baydhin,
\q1 
\v 19 Adiguse waxaad si xun noogu jebisay meeshii dawacooyinka,
\q1 Oo waxaad nagu qarisay hooskii dhimashada.
\q1 
\v 20 Haddii aannu illownay magicii Ilaahayaga,
\q1 Ama aannu gacmahayaga u kala bixinnay ilaah qalaad,
\q1 
\v 21 Ilaah miyaanu waxaas baadhayn?
\q1 Waayo, isagu waa wada og yahay qalbiga waxyaalihiisa qarsoon.
\q1 
\v 22 Haah, oo adiga daraaddaa ayaa naloo laayaa maalinta oo dhan,
\q1 Oo waxaannu noqonnaa sida ido la qalayo.
\q1 
\v 23 Toos, maxaad u huruddaa, Sayidow?
\q1 Sara joogso, oo ha na xoorin weligaa.
\q1 
\v 24 Bal maxaad wejiga nooga qarsanaysaa,
\q1 Oo aad u illoobaysaa dhibaatada iyo dulmiga aan ku dhex jirno?
\q1 
\v 25 Waayo, naftayadu ciidday ku foororsatay,
\q1 Oo calooshayaduna dhulkay ku dhegtaa.
\q1 
\v 26 Caawimaaddayada daraaddeed u sara joogso,
\q1 Oo raxmaddaada daraaddeed noo furo.
\c 45
\s2 Kanu waa sabuur Maskiil ah oo ay reer Qorax u tiriyeen madaxdii muusikaystayaasha, waana gabay jacayl ku saabsan oo lagu luuqeeyo Shoshanniim.
\q1 
\v 1 Qalbigaygu wuxuu la buuxdhaafaa hadal wanaagsan,
\q1 Oo waxaan boqorka u sheegayaa waxyaalihii aan sameeyey,
\q1 Carrabkaygu waa sida karraani dhaqsiyo badan qalinkiis.
\q1 
\v 2 Adigu waad ka sii quruxsan tahay binu-aadmiga,
\q1 Oo bushimahaaga waxaa ka buuxda nimco,
\q1 Sidaas daraaddeed ayaa Ilaah kuu barakeeyey weligaaba.
\q1 
\v 3 Seeftaadu bowdadaada ha saarnaato, kaaga xoogga badanow,
\q1 Oo quruxda iyo haybadda lahow.
\q1 
\v 4 Runta iyo camalqabowga iyo xaqnimada daraaddood,
\q1 Waxaad faraskaaga ku fuushaa haybad adigoo barwaaqaysan,
\q1 Oo gacantaada midigna waxay ku bari doontaa waxyaalo cabsi badan.
\q1 
\v 5 Fallaadhahaagu waa af badan yihiin,
\q1 Oo waxay wadnaha ka mudaan boqorka cadaawayaashiisa,
\q1 Dadyowguna hoostaaday ku soo dhacaan.
\q1 
\v 6 Carshigaagu, Ilaahow, waa weligiis iyo weligiis,
\q1 Oo ul caddaaladdeedna waa usha boqortooyadaada.
\q1 
\v 7 Adigu xaqnimada waad jeclayd, oo xumaantana waad necbayd,
\q1 Sidaas daraaddeed Ilaaha Ilaahaaga ahi wuxuu kuugu subkay
\q1 Saliidda farxadda, oo kuwa ku weheliyana wuu kaa sarraysiiyey.
\q1 
\v 8 Dharkaaga oo dhan waxaa ka soo carfa malmal, iyo cuud, iyo qasica.
\q1 Oo qasriyo fool maroodi ah ayaa kaaga farxiyey alaab muusiko xadhko leh.
\q1 
\v 9 Dumarkaaga sharafta leh waxaa ku jira gabdhaha boqorrada,
\q1 Midigtaadana waxaa taagan boqoradda oo isku sharraxday dahabkii Oofir.
\q1 
\v 10 Haddaba, gabadhoy, bal i maqal, oo fiirso, oo dhegta soo dhig,
\q1 Oo weliba waxaad illowdaa dadkaagii iyo gurigii aabbahaa;
\q1 
\v 11 Markaasuu boqorku quruxdaada jeclaanayaa,
\q1 Waayo, isagu waa sayidkaaga, oo adna isaga u sujuud.
\q1 
\v 12 Oo waxaa halkaas joogi doonta gabadha reer Turos, iyadoo hadiyad wadda,
\q1 Xataa taajiriinta dadka ku jirtaa waxay kaa baryi doonaan raallinimo.
\q1 
\v 13 Gabadha boqorka oo hoyga boqorka joogtaa waa qurux miidhan,
\q1 Dharkeeda dahab baa lagu dhex sameeyey.
\q1 
\v 14 Waxaa boqorka loo geeyn doonaa iyadoo sharraxan,
\q1 Bikradaha saaxiibadaheeda ah oo iyada daba socdana waa laguu keeni doonaa.
\q1 
\v 15 Waxaa iyaga lagu hoggaamin doonaa farxad iyo rayrayn,
\q1 Oo waxay soo geli doonaan hoyga boqorka.
\q1 
\v 16 Meeshii awowayaashaa waxaa joogi doona wiilashaada,
\q1 Kuwaas oo aad dunida oo dhan amiirro uga dhigi doonto.
\q1 
\v 17 Magacaaga waxaan ka dhigi doonaa mid ka ab ka ab la xusuusto,
\q1 Sidaas daraaddeed dadyowgu mahad bay kuu naqi doonaan weligood iyo weligood.
\c 46
\s2 Kanu waa sabuur ay reer Qorax u tiriyeen madaxdii muusikaystayaasha, oo waa gabay lagu luuqeeyo Calaamood
\q1 
\v 1 Ilaah waa magangalkeenna iyo xooggeenna,
\q1 Oo waa caawimaad inoo diyaar ah wakhtiga dhibaatada.
\q1 
\v 2 Sidaas daraaddeed cabsan mayno in kastoo dhulku beddelmo,
\q1 Iyo in kastoo buurahu badda uurkeeda ku dhex dhaqaaqaan,
\q1 
\v 3 Iyo in kastoo biyaheedu guuxaan oo qasmaan,
\q1 Iyo in kastoo ay buurahu kibirkooda la ruxruxmaan. (Selaah)
\q1 
\v 4 Waxaa jira webi durdurradiisu ay ka farxiyaan magaalada Ilaah,
\q1 Taasoo ah meesha quduuska ah ee Ilaaha ugu sarreeya taambuugyadiisa.
\q1 
\v 5 Ilaah baa iyada ku dhex jira, mana ay dhaqaaqi doonto,
\q1 Oo Ilaah baa iyada ku caawin doona marka waagu beryo.
\q1 
\v 6 Quruumihii way cabaadeen, oo boqortooyooyinkiina way dhaqdhaqaaqeen,
\q1 Codkiisii buu ku hadlay, oo dhulkii baa dhalaalay.
\q1 
\v 7 Rabbiga ciidammadu waa inala jiraa,
\q1 Oo Ilaaha Yacquub baa magangalkeenna ah. (Selaah)
\q1 
\v 8 Bal kaalaya arka shuqullada Rabbiga,
\q1 Iyo halaagga uu ku sameeyey dhulka.
\q1 
\v 9 Dagaallada wuu ku joojiyaa tan iyo dunida meesha ugu dambaysa,
\q1 Qaansada wuu jebiyaa, oo warankana wuu jaraa,
\q1 Oo gaadhifardoodkana dab buu ku gubaa.
\q1 
\v 10 Iska daaya oo ogaada inaan anigu Ilaah ahay,
\q1 Waa laygu sarraysiin doonaa quruumaha dhexdooda, dhulkana waa laygu sarraysiin doonaa.
\q1 
\v 11 Rabbiga ciidammadu waa inala jiraa,
\q1 Oo Ilaaha Yacquub baa magangalkeenna ah. (Selaah)
\c 47
\s2 Kanu waa sabuur ay reer Qorax u tiriyeen madaxdii muusikaystayaasha.
\q1 
\v 1 Dadyowga oo dhammow, kulligiin sacabka tuma,
\q1 Oo Ilaah cod guuleed ugu qayliya.
\q1 
\v 2 Waayo, Rabbiga ah Ilaaha ugu sarreeya waa cabsi miidhan,
\q1 Oo isagu waa boqor weyn oo dhulka oo dhan u taliya.
\q1 
\v 3 Isagu dadyowga wuxuu gelin doonaa hoosteenna,
\q1 Quruumahana wuxuu ka hoos marin doonaa cagaheenna.
\q1 
\v 4 Isagu dhaxalkeenna ayuu inoo dooran doonaa,
\q1 Kaasoo ah ammaanta Yacquub uu jecel yahay. (Selaah)
\q1 
\v 5 Ilaah qaylo buu la kacay,
\q1 Oo wuxuu Rabbiguna la kacay dhawaaqa buunka.
\q1 
\v 6 Ilaah ammaan ugu heesa, ammaan ugu heesa,
\q1 Ammaan ugu heesa Boqorkeenna, ammaan heesa.
\q1 
\v 7 Waayo, Ilaah waa dunida oo dhan Boqorkeeda,
\q1 Haddaba sabuur ammaan ah ku heesa.
\q1 
\v 8 Ilaah wuxuu u taliyaa quruumaha,
\q1 Ilaahna carshigiisa quduuska ah ayuu ku fadhiistaa.
\q1 
\v 9 Dadyowga amiirradoodii oo dhammu waxay isu soo wada urursadeen
\q1 Inay dadka Ilaaha Ibraahim noqdaan,
\q1 Waayo, dhulka gaashaammadiisa waxaa iska leh Ilaah.
\q1 Oo isaga aad iyo aad baa loo sarraysiiyey.
\c 48
\s2 Kanu waa gabay, waana sabuur ay reer Qorax tiriyeen.
\q1 
\v 1 Rabbigu waa weyn yahay, waana in aad loogu ammaanaa
\q1 Ilaaheenna magaaladiisa, iyo buurtiisa quduuska ah.
\q1 
\v 2 Waxaa dhererka ku quruxsan, oo farxad u ah dunida oo dhan
\q1 Buur Siyoon oo dhanka woqooyi ah,
\q1 Meeshaas oo ah magaalada Boqorka weyn.
\q1 
\v 3 Ilaah wuxuu daaraheeda dhaadheer isku muujiyey inuu magangal yahay.
\q1 
\v 4 Waayo, bal eeg, boqorradii way iswada urursadeen,
\q1 Dhammaantood way wada dhaafeen.
\q1 
\v 5 Oo kolkay arkeen ayay yaabeen,
\q1 Oo argaggexeen, markaasay haddiiba carareen.
\q1 
\v 6 Iyagii halkaasay ku gariireen,
\q1 Wayna ku xanuunsadeen sida naag foolanaysa.
\q1 
\v 7 Doonniyaha Tarshiish waxaad ku jejebisaa
\q1 Dabaysha bari.
\q1 
\v 8 Annagu sidaan maqalnay, ayaan ku dhex aragnay
\q1 Magaalada Rabbiga ciidammada, taasoo ah magaalada Ilaaheenna,
\q1 Ilaah ayaa weligeedba adkayn doona. (Selaah)
\q1 
\v 9 Ilaahow, raxmaddaada ayaan ka fikirnay
\q1 Markaan macbudkaaga ku jirnay.
\q1 
\v 10 Ilaahow, sida magacaagu yahay
\q1 Ayaa ammaantaaduna ku tahay dhulka darafyadiisa oo dhan,
\q1 Gacantaada midigna waxaa ka buuxda xaqnimo.
\q1 
\v 11 Buur Siyoon ha faraxdo,
\q1 Oo gabdhaha reer Yahuudah ha ku reyreeyeen xukummadaada daraaddood.
\q1 
\v 12 Siyoon hareeraheeda socda, oo ku soo wareega,
\q1 Oo munaaradaheeda tiriya.
\q1 
\v 13 Bal aad ugu fiirsada qalcadaheeda,
\q1 Oo ka fikira daaraheeda dhaadheer,
\q1 Si aad ugu sheekaysaan farcanka soo socda.
\q1 
\v 14 Waayo, weligiis iyo weligiisba Ilaahan ayaa Ilaah inoo ah,
\q1 Oo isagaa hoggaamiye inoo ahaan doona xataa tan iyo dhimashada.
\c 49
\s2 Kanu waa sabuur ay reer Qorax u tiriyeen madaxdii muusikaystayaasha.
\q1 
\v 1 Dadyowga oo dhammow, bal tan maqla,
\q1 Dunida kuwiinna degganow, kulligiin dhegta u dhiga,
\q1 
\v 2 Kuwiinna hoose iyo kuwiinna sare,
\q1 Taajirrada iyo masaakiintoy, dhammaantiin wada maqla.
\q1 
\v 3 Afkaygu wuxuu ku hadli doonaa xigmad,
\q1 Qalbigayguna wuxuu ka fikiri doonaa waxgarasho.
\q1 
\v 4 Dhegtayda waxaan u dhigi doonaa masaal,
\q1 Xujadaydana waxaan ku muujin doonaa kataaradda.
\q1 
\v 5 Haddaba bal maxaan u cabsanayaa wakhtiga shar jiro,
\q1 Markii xumaanu cedhbahayga ku wareegsanto?
\q1 
\v 6 Kuwa maalkooda isku halleeya,
\q1 Oo ku faana hodantinimadooda faraha badan,
\q1 
\v 7 Midkoodna walaalkiis ma furan karo,
\q1 Daraaddiisna Ilaah madaxfurasho uma siin karo,
\q1 
\v 8 (Waayo, furashada naftoodu waa qaali aad iyo aad,
\q1 Kumana filna weligeedba,)
\q1 
\v 9 Inuu isagu weligiis sii noolaado,
\q1 Oo aanu halligaad arkin weligiis.
\q1 
\v 10 Waayo, isagu wuxuu arkaa inay dadka xigmadda lahu wada dhintaan,
\q1 Iyo in nacasyada iyo doqonnaduba ay wada baabba'aan,
\q1 Oo ay maalkooda kuwa kale uga tagaan.
\q1 
\v 11 Waxay ismoodsiiyaan inay guryahoodu weligoodba sii jirayaan,
\q1 Iyo in meelaha rugtooda ahu ay sii raagayaan tan iyo qarniyada oo dhan,
\q1 Oo dhulalkoodana way isku magacaabaan.
\q1 
\v 12 Laakiinse binu-aadmigu sharaf kuma waaro,
\q1 Wuxuu la mid yahay sida xayawaanka iska baabba'a.
\q1 
\v 13 Jidkoodanu waa kalsoonidooda nacasnimada ah,
\q1 Laakiinse dadka iyaga ka dambeeya ayaa hadalkoodii u boga. (Selaah)
\q1 
\v 14 Iyagu waxaa weeye adhi She'ool loo wado,
\q1 Oo waxaa sida adhijir u ahaan doona dhimasho,
\q1 Oo kuwa qumman ayaa iyaga subaxda u talin doona,
\q1 Oo quruxdoodana waxaa baabbi'in doona She'ool, inaanay iyagu rug yeelan innaba.
\q1 
\v 15 Laakiinse Ilaah naftayda wuu ka soo furan doonaa xoogga She'ool,
\q1 Waayo, wuu i aqbali doonaa. (Selaah)
\q1 
\v 16 Ha baqin markii mid taajiroobo,
\q1 Oo ammaanta reerkiisu aad u korodho,
\q1 
\v 17 Waayo, isagu markuu dhinto waxba sii qaadan maayo,
\q1 Oo ammaantiisuna ka daba geli mayso.
\q1 
\v 18 In kastoo uu naftiisa u duceeyey markuu noolaa,
\q1 Oo dad adiga ku ammaana, kolkaad wax wanaagsan isu samaysid,
\q1 
\v 19 Isagu wuxuu u tegi doonaa qarniyadii awowayaashiis,
\q1 Oo iyana weligood iftiinka ma ay arki doonaan.
\q1 
\v 20 Ninkii sharaf leh oo aan garaad lahaynu
\q1 Wuxuu la mid yahay sida xayawaanka iska baabba'a.
\c 50
\s2 Kanu waa sabuur Aasaaf tiriyey.
\q1 
\v 1 Ilaah, oo ah Ilaaha Rabbiga ah ayaa hadlay,
\q1 Oo qorrax-soo-baxa ilaa qorraxdhaca dhulkuu u yeedhay.
\q1 
\v 2 Siyoon oo ah meesha quruxda kaamilka ah
\q1 Ayaa Ilaah ka soo iftiimay.
\q1 
\v 3 Ilaaheen wuu iman doonaa, iskamana aamusi doono,
\q1 Hortiisa ayaa dab wax baabbi'in doonaa,
\q1 Hareerihiisana waxaa jiri doona duufaan weyn.
\q1 
\v 4 Isagu wuxuu u yeedhi doonaa samooyinka sare,
\q1 Iyo dhulkaba, inuu dadkiisa xukumo aawadeed.
\q1 
\v 5 Oo wuxuu odhan doonaa, Quduusiintayda ii soo wada ururiya,
\q1 Kuwii axdi igula dhigtay allabari.
\q1 
\v 6 Oo samooyinka ayaa xaqnimadiisa sheegi doona,
\q1 Waayo, Ilaah qudhiisu waa xaakin. (Selaah)
\q1 
\v 7 Dadkaygiiyow, i maqla, oo anna waan hadli doonaa,
\q1 Israa'iilow, i maqal oo anna waan kuu markhaati furi doonaa,
\q1 Anigu waxaan ahay Ilaah, oo ah Ilaahaaga.
\q1 
\v 8 Anigu kugu canaanan maayo allabaryadaada,
\q1 Oo qurbaannadaada gubanu had iyo goorba hortayday yaalliin.
\q1 
\v 9 Reerkaaga dibi ka qaadan maayo,
\q1 Xerooyinkaagana orgi kala bixi maayo.
\q1 
\v 10 Waayo, xayawaanka duudda jooga oo dhan anigaa iska leh,
\q1 Iyo xataa xoolaha kunka buurood jooga oo dhan.
\q1 
\v 11 Waan wada aqaan haadda buuraha joogta oo dhan,
\q1 Oo dugaagga duurka jooga oo dhanna anigaa iska leh.
\q1 
\v 12 Haddaan gaajaysnahay, kuuma aan sheegeen,
\q1 Waayo, dunida iyo waxa ka buuxaba anigaa iska leh.
\q1 
\v 13 Miyaan cuni doonaa hilibka dibida,
\q1 Miyaanse cabbi doonaa dhiigga riyaha?
\q1 
\v 14 Ilaah u bixi allabariga mahadnaqiddaa,
\q1 Oo Ilaaha ugu sarreeyana nidarradaadii u oofi,
\q1 
\v 15 Oo i bari maalinta dhibi jirto,
\q1 Oo anna waan ku samatabbixin doonaa, kolkaasaad i ammaani doontaa.
\q1 
\v 16 Laakiinse Ilaah wuxuu kan sharka leh ku yidhaahdaa,
\q1 Maxaad qaynuunnadayda u sheegaysaa,
\q1 Oo aad axdigayga afkaaga ugu soo qaadaysaa?
\q1 
\v 17 Adigoo tacliinta neceb,
\q1 Oo weliba erayadaydana dabadaada ku tuura.
\q1 
\v 18 Markaad tuug aragtay waad oggolaatay,
\q1 Oo waxaad la qayb qaadatay dhillayo.
\q1 
\v 19 Afkaaga waxaad u daysaa inuu shar ku hadlo,
\q1 Oo carrabkaaguna wuxuu hindisaa khiyaano.
\q1 
\v 20 Waad fadhiisataa oo wax ka sheegtaa walaalkaa,
\q1 Oo weliba waxaad xamataa inahooyadaa.
\q1 
\v 21 Waxyaalahaas baad samaysay, oo anna waan iska aamusay,
\q1 Waxaad moodday inaan ahay mid kula mid ah,
\q1 Laakiinse waan ku canaanan doonaa, oo iyaga ayaan indhahaaga hortooda ku hagaajin doonaa.
\q1 
\v 22 Kuwiinna Ilaah illoobayow, bal waxan ka fiirsada,
\q1 Waaba intaasoo aan cadcad idiin jeexjeexaaye, oo aad wax idin samatabbixiya weydaane,
\q1 
\v 23 Ku alla kii allabariga mahadnaqidda bixiyaa waa i ammaanaa,
\q1 Oo kii socodkiisa si qumman u hagaajiyana
\q1 Waxaan tusi doonaa badbaadinta Ilaah.
\c 51
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha markii nebi Naataan u yimid, kolkuu Batshebac u tegey dabadeed.
\q1 
\v 1 Ilaahow, iigu naxariiso sida raxmaddaadu tahay,
\q1 Oo xadgudubyadaydana igaga tirtir sida naxariistaada badnaanteedu tahay.
\q1 
\v 2 Xumaantayda iga wada maydh,
\q1 Oo iga nadiifi dembigayga.
\q1 
\v 3 Waayo, anigu waan ogahay xadgudubyadayda,
\q1 Oo dembigayguna hortayduu yaallaa had iyo goorba.
\q1 
\v 4 Adiga keliya ayaan kugu dembaabay,
\q1 Oo waxaan sameeyey wax hortaada ku xun,
\q1 Inaad xaq ahaatid markaad hadashid,
\q1 Oo aad daahir ahaatid markaad wax xukunto.
\q1 
\v 5 Bal eeg, aniga waxaa laygu qabanqaabiyey xumaan,
\q1 Oo waxaa hooyaday igu uuraysatay dembi.
\q1 
\v 6 Bal eeg, waxaad uurka ka jeceshahay run,
\q1 Oo meesha qarsoon waxaad iga ogeysiinaysaa xigmad.
\q1 
\v 7 Haddaba geed husob ah igu daahiri, oo anna nadiif baan ahaan doonaa,
\q1 I maydh, oo anna baraf cad waan ka sii caddaan doonaa.
\q1 
\v 8 I maqashii farxad iyo rayrayn,
\q1 Inay lafihii aad jejebisay farxaan.
\q1 
\v 9 Wejigaaga ka qari dembiyadayda,
\q1 Oo iga tirtir xumaatooyinkayga oo dhan.
\q1 
\v 10 Ilaahow, igu dhex abuur qalbi nadiif ah,
\q1 Oo igu dhex cusboonaysii ruux qumman.
\q1 
\v 11 Hortaada ha iga xoorin,
\q1 Oo Ruuxaaga quduuska ah ha iga qaadin.
\q1 
\v 12 Farxaddii badbaadintaada ii soo celi,
\q1 Oo ruux raalli ah igu tiiri.
\q1 
\v 13 Oo markaas kuwa xadgudba jidkaagaan bari doonaa,
\q1 Oo dembilayaashuna adigay kuu soo noqon doonaan.
\q1 
\v 14 Ilaahow, Ilaaha badbaadadaydow, dhiiggelidda iga samatabbixi,
\q1 Markaasaa carrabkaygu wuxuu aad uga gabyi doonaa xaqnimadaada.
\q1 
\v 15 Sayidow, bushimahayga fur,
\q1 Oo afkaygu wuxuu ku hadli doonaa ammaantaada.
\q1 
\v 16 Waayo, adigu kuma faraxdid allabari, haddii kalese waan bixin lahaa,
\q1 Qurbaan gubanna kuma cajebiyo.
\q1 
\v 17 Allabaryada Ilaah waa ruux is-hoosaysiintiisa,
\q1 Ilaahow, adigu quudhsan maysid qalbi hoosaysan oo qoomamaysan.
\q1 
\v 18 Siyoon wanaag ugu samee sidaad doonayso,
\q1 Oo Yeruusaalem derbiyadeedana dhis.
\q1 
\v 19 Oo markaas adigu waxaad ku farxi doontaa allabaryada xaqnimada iyo qurbaan guban, iyo allabari wada guban dhammaantiis,
\q1 Oo markaasay dibiyo ku dul bixin doonaan meeshaada allabariga.
\c 52
\s2 Kanu waa gabay Maskiil ah oo Daa'uud u tiriyey madaxdii muusikaystayaasha, markii Do'eeg oo reer Edom ahaa uu Saa'uul u yimid oo u sheegay oo ku yidhi, Daa'uud waa yimid Axiimeleg gurigiisa.
\q1 
\v 1 Ninka xoogga badanow, bal maxaad xumaanta ugu faanaysaa?
\q1 Naxariista Ilaah had iyo goorba way sii waartaa.
\q1 
\v 2 Carrabkaagu wuxuu hindisaa xumaato weyn,
\q1 Oo sida mandiil afaysan ayuu ka shaqeeyaa khiyaano.
\q1 
\v 3 Wanaagga waxaad ka jeceshahay xumaanta,
\q1 Oo inaad xaqnimo ku hadashidna waxaad ka jeceshahay beensheegidda. (Selaah)
\q1 
\v 4 Waxaad jeceshahay erayada wax baabbi'iya oo dhan,
\q1 Iyo carrab khiyaano miidhan ah.
\q1 
\v 5 Ilaahna sidaas oo kaluu kuu halligi doonaa weligaaba,
\q1 Oo isna kor buu kuu qaadi doonaa, oo wuxuu kaa bixin doonaa teendhadaada,
\q1 Oo wuxuu kaa saari doonaa kuwa nool dalkooda. (Selaah)
\q1 
\v 6 Kuwa xaqa ahuna way arki doonaan, oo way cabsan doonaan,
\q1 Wayna ku qosli doonaan, oo waxay odhan doonaan,
\q1 
\v 7 Waa kan ninkii aan Ilaah xooggiisa ka dhiganu,
\q1 Laakiinse wuxuu isku halleeyey hodantinimadiisa badan,
\q1 Oo wuxuu ku xoogaystay xumaatadiisii.
\q1 
\v 8 Laakiinse anigu waxaan la mid ahay sida geed qoyan oo saytuun ah, oo guriga Ilaah ku dhex yaal,
\q1 Anigu weligay iyo weligayba waxaan isku hallaynayaa naxariista Ilaah.
\q1 
\v 9 Weligayba waan kugu mahadnaqayaa, maxaa yeelay, adigu waad samaysay,
\q1 Oo magacaaga ayaan wax ku rajaynayaa, waayo, wuu ku wanaagsan yahay quduusiintaada hortooda.
\c 53
\s2 Kanu waa gabay Maskiil ah oo Daa'uud u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu luuqeeyaa Mahalad.
\q1 
\v 1 Nacaskaa qalbigiisa iska yidhi, Ilaah ma jiro.
\q1 Iyagu waa qudhun, oo waxay faleen xumaan karaahiyo ah,
\q1 Oo mid wanaag falaa ma jiro.
\q1 
\v 2 Ilaah wuxuu samada hoos uga soo fiiriyey binu-aadmiga,
\q1 Bal inuu arko hadday kuwo wax garanaya oo Ilaah doondoonaa jiraan.
\q1 
\v 3 Midkood kastaaba dib buu u noqday, oo dhammaantood waxay wada noqdeen dad nijaas ah,
\q1 Oo mid wanaag falaa ma jiro, midnaba.
\q1 
\v 4 Miyaanay aqoon lahayn xumaanfalayaasha dadkaygii u cuna siday kibista u cunaan,
\q1 Oo aanay Ilaah baryin?
\q1 
\v 5 Iyagu halkaasay aad ugu cabsadeen meel aan cabsiyu jirin,
\q1 Waayo, kii ku ag degay inuu kugu soo duulo Ilaah baa lafihiisii kala firdhiyey,
\q1 Oo iyagaad ceebaysay, maxaa yeelay, Ilaah baa iyaga diiday.
\q1 
\v 6 Badbaadada reer binu Israa'iil bal may Siyoon ka timaado!
\q1 Marka Ilaah dadkiisa maxaabiisnimada ka soo celiyo,
\q1 Ayaa reer Yacquub rayrayn doonaa oo reer binu Israa'iilna farxi doonaa.
\c 54
\s2 Kanu waa gabay Maskiil ah oo Daa'uud u tiriyey madaxdii muusikaystayaasha, markii ay reer Sif Saa'uul u yimaadeen oo ay ku yidhaahdeen, Daa'uud miyaanu dhuumasho noo dhex joogin? Waxaana lagu qaadaa alaab xadhko leh oo muusiko ah.
\q1 
\v 1 Ilaahow, magacaaga igu badbaadi,
\q1 Oo xooggaaga iigu garsoor.
\q1 
\v 2 Ilaahow, baryadayda maqal,
\q1 Oo erayada afkayga dhegta u dhig,
\q1 
\v 3 Waayo, shisheeyayaal baa igu kacay,
\q1 Oo rag dulmi badan ayaa doonayay inay nafta iga qaadaan,
\q1 Iyagu Ilaah kama fikirin. (Selaah)
\q1 
\v 4 Bal eega, Ilaah waa gargaarahayga,
\q1 Oo Sayidkuna wuxuu la jiraa kuwa naftayda tiiriya.
\q1 
\v 5 Isagu sharka wuxuu ku celin doonaa cadaawayaashayda,
\q1 Iyaga runtaada ku baabbi'i.
\q1 
\v 6 Waxaan kuu qali doonaa qurbaan ikhtiyaar ah,
\q1 Rabbiyow, magacaaga waan ku mahadnaqi doonaa, waayo wuu wanaagsan yahay.
\q1 
\v 7 Waayo, isagu wuxuu iga samatabbixiyey dhibaato oo dhan,
\q1 Oo ishayduna waxay cadaawayaashayda ku aragtay wixii aan doonayay.
\c 55
\s2 Kanu waa gabay Maskiil ah oo Daa'uud u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu qaadaa alaab xadhko leh oo muusiko ah.
\q1 
\v 1 Ilaahow, tukashadayda dhegta u dhig,
\q1 Oo baryootankaygana ha iska qarin.
\q1 
\v 2 I maqal, oo ii jawaab,
\q1 Waxaan la nasan waayaa calaacalkayga, waanan la taahaa,
\q1 
\v 3 Sababtuna waxaa weeye codka cadowga daraaddiis,
\q1 Iyo kan sharka leh cadaadintiisa daraaddeed,
\q1 Waayo, iyagu xumaan bay igu tuuraan,
\q1 Maxaa yeelay, cadho ayay igu silciyaan.
\q1 
\v 4 Wadnuhu aad buu ii xanuunayaa,
\q1 Oo waxaa igu dhacday cabsida dhimashada.
\q1 
\v 5 Baqdin iyo gariir ayaa igu soo degay,
\q1 Oo naxdin baa i dabooshay.
\q1 
\v 6 Oo anna waxaan is-idhi, Waxaan jeclaan lahaa inaan baalal yeesho sida qoolley oo kale!
\q1 Markaasaan iska duuli lahaa oo nasan lahaa.
\q1 
\v 7 Bal eeg, markaasaan iska warwareegi lahaa meel fog,
\q1 Oo waxaan degganaan lahaa cidlada. (Selaah)
\q1 
\v 8 Waxaan gabbaad kaga carari lahaa
\q1 Dabaysha hufada ah iyo duufaanka.
\q1 
\v 9 Sayidow, iyaga baabbi'i, oo afafkoodana kala duw
\q1 Waayo, waxaan magaalada ku arkay dulmi iyo dirir.
\q1 
\v 10 Maalin iyo habeenba derbiyadeeday ku dul wareegaan,
\q1 Oo weliba waxaa ku dhex jira xumaan iyo belaayo.
\q1 
\v 11 Dhexdeedana waxaa ku jira shar,
\q1 Dulmi iyo khiyaanona kama tagaan jidadkeeda.
\q1 
\v 12 Waayo, kii i caayay cadaawe ma ahayn,
\q1 Maxaa yeelay, waan u adkaysan kari lahaa,
\q1 Mana ahayn kii i necbaa oo iska kay weyneeyey,
\q1 Maxaa yeelay, waan ka dhuuman lahaa isaga,
\q1 
\v 13 Laakiinse wuxuu ahaa adiga oo ah nin ila mid ah,
\q1 Iyo jaalkay iyo saaxiibkay.
\q1 
\v 14 Si wanaagsan baynu u wada sheekaysan jirnay,
\q1 Oo waxaynu ku dhex socon jirnay guriga Ilaah, innagoo guuto badan la soconna.
\q1 
\v 15 Dhimasho ha ku soo kediso iyaga,
\q1 Oo iyagoo noolnool She'ool ha ku dhaceen,
\q1 Waayo, xumaan baa ku jirta hoygooda iyo dhexdooda.
\q1 
\v 16 Laakiinse anigu Ilaah baan baryi doonaa,
\q1 Oo Rabbigaa i badbaadin doona.
\q1 
\v 17 Fiidka, iyo subaxda, iyo duhurkaba, anigu waan cataabi doonaa, oo waan taahi doonaa,
\q1 Oo isna codkayguu maqli doonaa.
\q1 
\v 18 Naftayda nabadduu kaga samatabbixiyey dagaalkii iga geesta ahaa,
\q1 Waayo, kuwii ila diriray way badnaayeen.
\q1 
\v 19 Ilaah oo ah kan weligiis waara,
\q1 Wuu maqli doonaa oo u jawaabi doonaa iyaga,
\q1 Kuwaas oo aan beddelmin, (Selaah)
\q1 Oo aan Ilaah ka cabsan.
\q1 
\v 20 Isagu wuxuu u gacan qaaday kii isaga heshiiska la ahaa,
\q1 Oo axdigiisiina wuu buriyey.
\q1 
\v 21 Afkiisu wuxuu u nuglaa sidii subag oo kale,
\q1 Laakiinse qalbigiisu wuxuu ahaa dagaal,
\q1 Erayadiisu saliid way ka jilicsanaayeen,
\q1 Laakiinse waxay ahaayeen seefo galkii laga siibay.
\q1 
\v 22 Culaabtaada Rabbiga saar, oo isna wuu ku xanaanayn doonaa,
\q1 Waayo, isagu kan xaqa ah marnaba u dayn maayo in la dhaqaajiyo.
\q1 
\v 23 Laakiinse, Ilaahow, iyaga waxaad ku dhaadhicin doontaa yamayska halligaadda,
\q1 Dhiigyocabyada iyo dadka khaa'innada ahu cimrigooda nus ma kadban doonaan,
\q1 Laakiinse anigu waan isku kaa hallayn doonaa.
\c 56
\s2 Kanu waa sabuur Mikhtaam ah oo Daa'uud u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu luuqeeyaa Yoonad elem rexoqiim. Wuxuuna tiriyey markii reer Falastiin ay isaga Gad ku qabteen.
\q1 
\v 1 Ilaahow, ii naxariiso, waayo dad baa waxay doonayaan inay i liqaan;
\q1 Maalinta oo dhan isagoo diriraya ayuu i dulmaa.
\q1 
\v 2 Cadaawayaashaydu maalinta oo dhan waxay doonayaan inay i liqaan,
\q1 Waayo, kuwa kibirka igula diriraa waa tiro badan yihiin.
\q1 
\v 3 Markaan cabsado,
\q1 Waan isku kaa hallaynayaa.
\q1 
\v 4 Ilaah caawimaaddiisa ayaan eraygiisa ku ammaani doonaa,
\q1 Waayo, Ilaah baan isku halleeyey, oo innaba baqi maayo,
\q1 Haddaba bal binu-aadmigu muxuu igu samayn karaa?
\q1 
\v 5 Maalinta oo dhan erayadayda way qalloociyaan,
\q1 Fikirradooda oo dhammu waa igu col si ay shar iigu sameeyaan.
\q1 
\v 6 Way isa soo wada urursadaan, oo way dhuuntaan,
\q1 Oo waxay fiirsadaan tallaabooyinkayga,
\q1 Markay gaadayaan naftayda.
\q1 
\v 7 Iyagu ma xumaan bay ku baxsan doonaan?
\q1 Ilaahow, dadyowga adoo cadhaysan hoos u tuur.
\q1 
\v 8 Waad og tahay warwareeggayga,
\q1 Bal ilmadayda qaruuraddaada ku shub,
\q1 Waayo, miyaanay buuggaaga ku qorrayn?
\q1 
\v 9 Markaasaa cadaawayaashaydu dib u noqon doonaan maalinta aan kuu yeedho,
\q1 Waayo, waxaan ogahay in Ilaah ila jiro.
\q1 
\v 10 Ilaah caawimaaddiisa ayaan eraygiisa ku ammaani doonaa,
\q1 Oo Rabbigana caawimaaddiisa ayaan eraygiisa ku ammaani doonaa.
\q1 
\v 11 Ilaah baan isku halleeyey, oo innaba baqi maayo,
\q1 Haddaba bal dad muxuu igu samayn karaa?
\q1 
\v 12 Ilaahow, nidarradaada waan qabaa,
\q1 Oo waxaan kuu bixinayaa qurbaanno mahadnaqid ah.
\q1 
\v 13 Waayo, naftaydaad ka samatabbixisay dhimasho,
\q1 Sow cagahayga dhicitin kama aad samatabbixin?
\q1 Inaan Ilaah hortiisa ku socdo
\q1 Iftiinka kuwa nool.
\c 57
\s2 Kanu waa sabuur Mikhtaam ah oo Daa'uud u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu luuqeeyaa Altashed. Wuxuuna tiriyey markii uu Saa'uul ka cararay, oo uu godka galay.
\q1 
\v 1 Ii naxariiso, Ilaahow, ii naxariiso,
\q1 Waayo, naftaydu adigay ku magan gashaa,
\q1 Haah, waxaan magangeli doonaa hooska baalashaada,
\q1 Ilaa ay belaayooyinkanu gudbayaan.
\q1 
\v 2 Waxaan u qayshanayaa Ilaaha ugu sarreeya,
\q1 Oo ah Ilaaha wax kasta ii sameeya.
\q1 
\v 3 Isagu samaduu caawimaad ka soo diri doonaa, wuuna i badbaadin doonaa,
\q1 Markuu kan i liqi lahaa i caayo, (Selaah)
\q1 Ilaah wuxuu soo diri doonaa naxariistiisa iyo runtiisa.
\q1 
\v 4 Naftaydu waxay ku dhex jirtaa libaaxyo,
\q1 Oo anigu waxaan dhex jiifaa kuwo dab lagu shiday,
\q1 Kuwaasoo ah binu-aadmiga oo ilkahoodu yihiin warmo iyo fallaadho,
\q1 Oo carrabkooduna yahay seef af badan.
\q1 
\v 5 Ilaahow, samooyinka ka sara mar,
\q1 Oo ammaantaaduna dhulka oo dhan ha ka sarrayso.
\q1 
\v 6 Dabin bay cagahayga u diyaariyeen,
\q1 Oo naftaydii baa foororsatay,
\q1 Oo waxay hortayda ka qodeen god,
\q1 Oo iyaga qudhoodii baa ku dhex dhacay. (Selaah)
\q1 
\v 7 Qalbigaa ii fadhiya, Ilaahow, qalbigaa ii fadhiya,
\q1 Haddaba waan gabyi doonaa, haah, ammaan baan ku gabyi doonaa.
\q1 
\v 8 Naftaydoy, toos, shareerad iyo kataaradoy, toosa,
\q1 Aniga qudhayduna waxaan toosi doonaa aroor hore.
\q1 
\v 9 Sayidow, dadyowga dhexdooda ayaan kaaga mahadnaqi doonaa,
\q1 Oo quruumaha dhexdooda ayaan ammaan kuugu gabyi doonaa.
\q1 
\v 10 Waayo, naxariistaadu waa weyn tahay oo waxay gaadhaa samooyinka,
\q1 Oo runtaaduna waxay gaadhaa daruuraha.
\q1 
\v 11 Ilaahow, samooyinka ka sara mar,
\q1 Oo ammaantaaduna dhulka oo dhan ha ka sarrayso.
\c 58
\s2 Kanu waa sabuur Mikhtaam ah oo Daa'uud u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu luuqeeyaa Altashed
\q1 
\v 1 Hubaal xaqnimada aamusnaan ma ku sheegtaan?
\q1 Binu-aadmigow, si qumman wax ma u xukuntaan?
\q1 
\v 2 Hubaal qalbiga waxaad ka samaysaan xumaato,
\q1 Oo waxaad ka fikirtaan dulmiga gacmihiinna oo aad dhulka ku samaysaan.
\q1 
\v 3 Kuwa sharka lahu waxay qalaad ku noqdaan uurkii hooyadood,
\q1 Oo mar alla markii ay dhashaan ayay habaabaan iyagoo been sheegaya.
\q1 
\v 4 Suntoodu waa sida abeesada waabaydeeda oo kale,
\q1 Iyagu waa sida jilbis dhega la' oo dhegihiisa fureeya,
\q1 
\v 5 Kaasoo aan maqlin codka saaxiriinta,
\q1 Iyagoo si caqli ah u sixraya.
\q1 
\v 6 Ilaahow, ilkahooda afkooda ku dhex burburi,
\q1 Rabbiyow, libaaxyada aaranka ah miciyahooda jejebi.
\q1 
\v 7 Ha u dhalaaleen sida biyo aad u durduraya.
\q1 Markuu fallaadhihiisa wax ku liishaamo, ha noqdeen sida wax kala jabay.
\q1 
\v 8 Ha noqdeen sida alalaxayda dhalaasha oo iska baabba'da,
\q1 Iyo sida dhicis naageed oo aan qorraxda arkin.
\q1 
\v 9 Intaan dheryihiinnu qodxaha taaban,
\q1 Ayuu kuwa qoyan iyo kuwa ololayaba ku kala firdhin doonaa dabayl cirwareen ah.
\q1 
\v 10 Kan xaqa ahu wuu rayrayn doonaa markuu arko aargudashada,
\q1 Oo wuxuu ku cago maydhan doonaa kan sharka leh dhiiggiisa.
\q1 
\v 11 Sidaas daraaddeed dadku wuxuu odhan doonaa, Hubaal kii xaq ahu abaalgud buu leeyahay,
\q1 Hubaal waxaa jira Ilaah dhulka xukuma.
\c 59
\s2 Kanu waa sabuur Mikhtaam ah oo Daa'uud u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu luuqeeyaa Altashed. Wuxuu tiriyey markii Saa'uul cid u diray, oo ay gurigii ilaaliyeen inay isaga dilaan.
\q1 
\v 1 Ilaahayow, cadaawayaashayda iga samatabbixi,
\q1 Oo kuwa igu kacayna meel sare iga saar.
\q1 
\v 2 Iga samatabbixi xumaanfalayaasha,
\q1 Oo dadka dhiigyocabyada ahna iga badbaadi.
\q1 
\v 3 Waayo, bal eeg, waxay gaadaan naftayda,
\q1 Oo kuwa xoogga badanuna way isu kay wada urursadaan,
\q1 Rabbiyow, weliba ma aha xadgudubkayga aawadiis iyo dembigayga aawadiis toona.
\q1 
\v 4 Waxay u ordaan oo isu diyaariyaan wax aanan eed ku lahayn,
\q1 Dartay u kac inaad i caawiso oo aad i eegto.
\q1 
\v 5 Rabbiyow, Ilaaha ciidammadow, Ilaaha reer binu Israa'iilow,
\q1 Sara joogso oo quruumaha oo dhan soo booqo,
\q1 Oo innaba ha u naxariisan xadgudbayaasha. (Selaah)
\q1 
\v 6 Fiidkay soo noqdaan, oo waxay u ciyaan sida eey oo kale,
\q1 Oo waxay ku warwareegaan magaalada hareeraheeda.
\q1 
\v 7 Afkooda waxaa ka qubmaysa cay,
\q1 Bushimahoodana waxaa ku jira seefo,
\q1 Waayo, waxay isyidhaahdaan, Bal yaa na maqla?
\q1 
\v 8 Laakiinse Rabbiyow, iyagaad ku qosli doontaa,
\q1 Quruumaha oo dhan waad quudhsan doontaa.
\q1 
\v 9 Xooggaygiiyow, adigaan ku sugi doonaa,
\q1 Waayo, Ilaah waa qalcaddayda.
\q1 
\v 10 Ilaahayga naxariista leh ayaa i hor iman doona,
\q1 Oo waxaan doonayana Ilaah wuxuu iga tusi doonaa cadaawayaashayda.
\q1 
\v 11 Sayidow, gaashaankayagiiyow,
\q1 Iyaga ha layn, waaba intaasoo ay dadkaygu illoobaane,
\q1 Laakiinse iyaga xooggaaga ku kala firdhi, oo hoos u soo deji.
\q1 
\v 12 Kibirkoodu iyaga ha dabo
\q1 Dembiga afkooda iyo erayada bushimahooda aawadood,
\q1 Iyo weliba habaarka iyo beenta ay ku hadlaan aawadood.
\q1 
\v 13 Iyaga cadho ku baabbi'i, si aanay mar dambe u jirin iyaga baabbi'i,
\q1 Oo ha ogaadeen in Ilaah u taliyo reer Yacquub
\q1 Tan iyo dhulka darafkiisa. (Selaah)
\q1 
\v 14 Oo iyagu fiidka ha soo noqdeen, oo sida eey oo kale ha u ciyeen,
\q1 Oo magaalada hareeraheeda ha ku warwareegeen.
\q1 
\v 15 Waxay u warwareegayaan inay cunto helaan,
\q1 Oo haddaanay dherginna habeenkii oo dhan way sii joogayaan.
\q1 
\v 16 Laakiinse anigu waxaan ka gabyi doonaa xooggaaga,
\q1 Haah, oo aroortii ayaan naxariistaada aad uga gabyi doonaa,
\q1 Waayo, waxaad ahayd qalcaddaydii,
\q1 Oo maalintii aan dhibaataysnaana magangal baad ii ahayd.
\q1 
\v 17 Xooggaygiiyow, adigaan ammaan kuugu gabyi doonaa,
\q1 Waayo, Ilaah waa qalcaddayda, waana Ilaaha naxariistayda.
\c 60
\s2 Kanu waa sabuur Mikhtaam ah oo Daa'uud u tiriyey madaxdii muusikaystayaasha inuu wax ku baro, oo waxaa lagu luuqeeyaa Shuushan Ceeduud. Wuxuuna tiriyey markii uu la diriray Aram Nahara'im iyo Aram Soobaah, oo uu Yoo'aab soo noqday oo uu reer Edom Dooxadii Cusbada kaga laayay laba iyo tobanka kun.
\q1 
\v 1 Ilaahow, adigu waad na xoortay, oo waad na dudumisay,
\q1 Oo waad nagu cadhootay, haddaba bal mar na soo celi.
\q1 
\v 2 Dhulkii waad gariirisay, oo waad kala dildillaacisay,
\q1 Haddaba dildillaaciisa bogsii, waayo, wuu ruxmadaa.
\q1 
\v 3 Dadkaagii waxaad tustay waxyaalo adag,
\q1 Oo waxaad na cabsiisay khamri lala dhacdhaco.
\q1 
\v 4 Calan baad siisay kuwa kaa cabsada,
\q1 In runta loo soo bandhigo aawadeed. (Selaah)
\q1 
\v 5 Si ay kuwaad jeceshahay u samatabbaxaan,
\q1 Gacantaada midig ku badbaadi oo ii jawaab.
\q1 
\v 6 Ilaah wuxuu ku hadlay quduusnimadiisa oo yidhi, Anigu waan farxi doonaa,
\q1 Shekem waan kala qaybin doonaa, oo waxaan qiyaasi doonaa dooxada Sukod.
\q1 
\v 7 Gilecaad anigaa iska leh, Manasehna anigaa iska leh,
\q1 Oo weliba Efrayimna waa daafacaaddii madaxayga,
\q1 Yahuudahna waa ushayda boqornimo.
\q1 
\v 8 Moo'aab waa weelkaygii aan ku maydhan jiray,
\q1 Edomna kabahaygaan ku dul tuuri doonaa,
\q1 Falastiinay, qayli aawaday.
\q1 
\v 9 Bal yaa i geeyn doona magaalada xoogga leh?
\q1 Yaase xagga Edom ii kaxayn doona?
\q1 
\v 10 Ilaahow, sow nama aadan xoorin?
\q1 Ilaahow, lama soo baxdid ciidammadayada.
\q1 
\v 11 Cadowga naga caawi,
\q1 Waayo, binu-aadmiga caawimaaddiisu waxtar ma leh.
\q1 
\v 12 Ilaah caawimaaddiisa ayaannu wax xoog leh ku samayn doonaa,
\q1 Waayo, isagaa ah kan cadaawayaashayada ku tuman doona.
\c 61
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu qaadaa alaab xadhko leh oo muusiko ah.
\q1 
\v 1 Ilaahow, qayladayda maqal,
\q1 Oo baryadaydana dhegta u dhig.
\q1 
\v 2 Markii qalbigaygu itaal darnaado, waxaan kaaga qayshan doonaa darafka dhulka ugu shisheeya,
\q1 Ii hoggaami dhagaxa iga dheer.
\q1 
\v 3 Waayo, waxaad ii ahayd magangal,
\q1 Iyo qalcad adag oo aan cadowga ka galo.
\q1 
\v 4 Anigu weligayba waxaan degganaan doonaa taambuuggaaga,
\q1 Oo waxaan magangeli doonaa baalashaada meeshooda qarsoon. (Selaah)
\q1 
\v 5 Waayo, Ilaahow, nidarradaydii waad maqashay,
\q1 Oo waxaad i siisay kuwa magacaaga ka cabsada dhaxalkooda.
\q1 
\v 6 Boqorka noloshiisa waad dheeraynaysaa,
\q1 Oo cimrigiisuna wuxuu noqon doonaa sida qarniyo badan.
\q1 
\v 7 Oo weligiisba wuxuu joogi doonaa Ilaah hortiisa,
\q1 Raxmad iyo run u diyaari, inay isaga dhawraan.
\q1 
\v 8 Markaasaan weligayba magacaaga ammaan ugu gabyi doonaa,
\q1 Si aan maalin kasta nidarradayda u oofiyo.
\c 62
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha. Oo wuxuu u tiriyey sidii Yeduutuun.
\q1 
\v 1 Naftaydu waxay sugtaa Ilaah oo keliya,
\q1 Oo badbaadadayduna waxay ka timaadaa xaggiisa.
\q1 
\v 2 Isaga oo qudha ayaa dhagaxayga weyn iyo badbaadadaydaba ah,
\q1 Isagu waa munaaraddayda, oo aniga aad lay dhaqaajin maayo.
\q1 
\v 3 Balse idinku ilaa goormaad nin ku weeraraysaan,
\q1 Inaad kulligiin isaga dumisaan,
\q1 Sida derbi dhacaya, iyo deyr ligliganaya?
\q1 
\v 4 Iyagu waxay keliyahoo ku tashadaan si ay isaga sharaftiisa uga dejiyaan,
\q1 Oo waxay ku farxaan beensheegidda,
\q1 Afka way ka duceeyaan, laakiinse uurka way ka habaartamaan. (Selaah)
\q1 
\v 5 Naftaydoy, Ilaah oo qudha sug,
\q1 Waayo, isagaan wax ka filanayaa.
\q1 
\v 6 Isaga oo qudha ayaa dhagaxayga weyn iyo badbaadadaydaba ah,
\q1 Isagu waa munaaraddayda, oo aniga layma dhaqaajin doono.
\q1 
\v 7 Badbaadadayda iyo ammaantayduba waxay la jiraan Ilaah,
\q1 Dhagaxii xooggayga iyo magangalkaygaba waa xagga Ilaah.
\q1 
\v 8 Dadkow, isaga isku halleeya wakhti kastaba,
\q1 Oo qalbigiinna waxba ha kula hadhina Ilaah hortiisa,
\q1 Waayo, Ilaah baa magangal inoo ah. (Selaah)
\q1 
\v 9 Hubaal dad gun ahu waa xumbo,
\q1 Oo dad gob ahuna waa been,
\q1 Markii la miisaamo way kor mari doonaan,
\q1 Oo iyagu dhammaantood xumbo way ka fudud yihiin.
\q1 
\v 10 Dulmiga ha isku hallaynina,
\q1 Waxdhiciddana ha ku kibrina.
\q1 Maal hadduu idinku batona qalbigiinna ha raacinina.
\q1 
\v 11 Ilaah mar buu hadlay,
\q1 Oo laba goor baan maqlay,
\q1 In Ilaah xoogga iska leeyahay,
\q1 
\v 12 Oo weliba, Sayidow, adigu naxariis baad leedahay,
\q1 Waayo, nin kasta waxaad ugu abaalguddaa sidii camalladiisu ahaayeen.
\c 63
\s2 Kanu waa sabuur Daa'uud tiriyey markuu joogay cidlada reer Yahuudah.
\q1 
\v 1 Ilaahow, waxaad tahay Ilaahay, oo anna goor hore ayaan ku doondooni doonaa,
\q1 Naftaydu adigay kuu oomman tahay, jidhkayguna aduu kuu xiisoodaa,
\q1 Anoo jooga dhul engegan oo daal miidhan ah oo aan biyo lahayn.
\q1 
\v 2 Si aan u arko xooggaaga iyo ammaantaadaba aawadeed,
\q1 Ayaan kaa fiiriyey meesha quduuska ah.
\q1 
\v 3 Waayo, raxmaddaadu way ka sii wanaagsan tahay nolol,
\q1 Haddaba bushimahaygu way ku ammaani doonaan.
\q1 
\v 4 Sidaas daraaddeed waan kugu mahadnaqayaa intaan noolahay,
\q1 Oo gacmahaygana kor baan ugu qaadi doonaa magacaaga aawadiis.
\q1 
\v 5 Naftaydu waxay u dhergi doontaa sida mid dhuux iyo baruur uga dhergo,
\q1 Oo afkayguna wuxuu kugu ammaani doonaa bushimo faraxsan
\q1 
\v 6 Kolkaan sariirtayda kugu soo xusuusto
\q1 Oo aan kaa fikiro habeenka markaan soo jeedo.
\q1 
\v 7 Waayo, waxaad ii ahayd caawimaad,
\q1 Oo hooska baalashaada ayaan ku rayrayn doonaa.
\q1 
\v 8 Naftaydu adigay ku raacdaa,
\q1 Oo gacantaada midigna way i tiirisaa. (Selaah)
\q1 
\v 9 Laakiinse kuwa naftayda u doondoonaya inay halligaan aawadeed,
\q1 Waxay geli doonaan dhulka meelaha ugu hooseeya.
\q1 
\v 10 Waxaa iyaga loo gacangelin doonaa xoogga seefta,
\q1 Oo waxay qayb u noqon doonaan dawacooyinka.
\q1 
\v 11 Laakiinse boqorku wuxuu ku rayrayn doonaa Ilaah,
\q1 Mid kasta oo isaga ku dhaartaa wuu faani doonaa,
\q1 Waayo, kuwa beenta sheega afkooda waa la aamusiin doonaa.
\c 64
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Ilaahow, codkayga maqal markii aan kuu soo cawdo,
\q1 Oo naftayda ka ilaali cadowga cabsidiisa.
\q1 
\v 2 Oo iga qari talada qarsoon oo kuwa sharka ka shaqeeya,
\q1 Iyo tirabadnaanta xumaanfalayaasha,
\q1 
\v 3 Oo carrabkooda u afeeyey sidii seef oo kale,
\q1 Oo fallaadhahoodii liishaamay kuwaas oo ah erayo qadhaadh,
\q1 
\v 4 Si ay meelo qarsoon kan qumman fallaadh ugaga ganaan,
\q1 Haddiiba si kedis ah ayay ugu ganaan, mana cabsadaan.
\q1 
\v 5 Qasdi shar ah bay isku dhiirrigeliyaan,
\q1 Waxay ku arrinsadaan inay si qarsoon dabinno u dhigaan,
\q1 Oo ay isyidhaahdaan, Bal yaa arki doona?
\q1 
\v 6 Waxay baadhaan xumaatooyin, iyagoo leh, Annagu baadhid caqli ah ayaannu ebinnay,
\q1 Fikirka ku jira uurka nin walba iyo qalbiguba waa mool dheer yihiin.
\q1 
\v 7 Laakiinse Ilaah waa toogan doonaa,
\q1 Oo haddiiba iyaga waxaa dhaawici doonta fallaadh.
\q1 
\v 8 Sidaas daraaddeed waa la kufin doonaa, iyagoo carrabkoodu col u yahay naftooda,
\q1 Wax alla wixii iyaga arka oo dhammu way carari doonaan.
\q1 
\v 9 Oo dadka oo dhammu way cabsan doonaan,
\q1 Oo waxay sheegi doonaan shuqulka Ilaah,
\q1 Oo si caqli ah ayay uga fikiri doonaan wuxuu sameeyey.
\q1 
\v 10 Kuwa xaqa ahu waxay ku farxi doonaan Rabbiga, oo isagay isku hallayn doonaan,
\q1 Oo inta qalbigoodu toosan yahay oo dhammuna way faani doonaan.
\c 65
\s2 Kanu waa sabuur gabay ah oo Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Ilaahow, ammaan baa Siyoon kugu sugaysa,
\q1 Oo nidarkana waa in adiga laguu oofiyo.
\q1 
\v 2 Kaaga baryootanka maqlow,
\q1 Dadka oo dhammu adigay kuu iman doonaan.
\q1 
\v 3 Waxaa iga adkaada xumaatooyin,
\q1 Xadgudubkayagase waad naga nadiifin doontaa.
\q1 
\v 4 Waxaa barakaysan ninkii aad dooratid, oo aad ka dhigto inuu kuu soo dhowaado,
\q1 Inuu degganaado barxadahaaga.
\q1 Waxaan ka dhergi doonnaa wanaagga gurigaaga,
\q1 Kaas oo ah meesha quduuska ah oo macbudkaaga.
\q1 
\v 5 Ilaaha badbaadadayadow,
\q1 Waxyaalo cabsi badan ayaad xaqnimo noogu jawaabi doontaa,
\q1 Waxaad tahay kalsoonida kuwa dunida darfaheeda oo dhan,
\q1 Iyo kuwa badda fogba,
\q1 
\v 6 Kaas oo xooggiisa buuraha ku adkeeya,
\q1 Isagoo dhexda xoog ku xidhay.
\q1 
\v 7 Wuxuu aamusiiyaa guuxa badaha, iyo guuxa hirarkooda,
\q1 Iyo dadyowga buuqooda.
\q1 
\v 8 Oo weliba kuwa dhulka meelaha ugu fog deggan waxay ka cabsadaan calaamooyinkaaga,
\q1 Oo adigu waad ka farxisaa meelaha ay subaxda iyo fiidkaba ka baxaan.
\q1 
\v 9 Dhulka waad soo booqataa, oo waad biyaysaa,
\q1 Oo aad baad u barwaaqaysaa,
\q1 Webiga Ilaahna biyaa ka buuxa,
\q1 Waxaad iyaga siisaa hadhuudh, markii aad dhulka sidaas u diyaarisay.
\q1 
\v 10 Adigu beerta jeexjeexeeda aad baad u waraabisaa,
\q1 Oo waxaad dejisaa jeexjeexa tuurahooda,
\q1 Oo tiixtiix baad ku jilcisaa,
\q1 Oo waxa ka soo baxana waad barakaysaa.
\q1 
\v 11 Sannadda waxaad taaj uga dhigtaa wanaaggaaga,
\q1 Oo waddooyinkaagana waxaa ka tifqa subag.
\q1 
\v 12 Waxay ku tifqaan daaqa cidlada,
\q1 Oo buuruhuna waxay guntadaan farxad.
\q1 
\v 13 Berrimmada daaqu waxay huwadaan tirooyin adhyo ah,
\q1 Dooxooyinkana waxaa qariya hadhuudh,
\q1 Markaasay farxad la qayliyaan, oo weliba gabyaan.
\c 66
\s2 Kanu waa sabuur gabay ah oo loo tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Dadka dhulka oo dhammow, Ilaah farxad ugu qayliya,
\q1 
\v 2 Oo ammaanta magiciisa ku gabya,
\q1 Ammaantiisana qurxiya.
\q1 
\v 3 Ilaah waxaad ku tidhaahdaan, Shuqulladaadu cabsi badanaa!
\q1 Weynaanta xooggaaga aawadiis ayaa cadaawayaashaadu isugu kaa dhiibi doonaan.
\q1 
\v 4 Dadka dhulka oo dhammu adigay ku caabudi doonaan,
\q1 Wayna kuu gabyi doonaan,
\q1 Magacaagay u gabyi doonaan. (Selaah)
\q1 
\v 5 Bal kaalaya, oo arka shuqullada Ilaah,
\q1 Xagga binu-aadmiga wuxuu ku sameeyey waa cabsi badan yihiin.
\q1 
\v 6 Wuxuu baddii ka dhigay dhul engegan,
\q1 Oo iyagu webiga dhexdiisa waxay ku mareen lug,
\q1 Oo halkaasaan isaga ku rayraynay.
\q1 
\v 7 Isagu weligiisba wuxuu ku taliyaa xooggiisa,
\q1 Oo indhihiisuna waxay fiiriyaan quruumaha,
\q1 Haddaba caasiyiintu yaanay kor isu qaadin. (Selaah)
\q1 
\v 8 Dadyahow, Ilaaheenna ammaana,
\q1 Oo codka ammaantiisa ha la maqlo,
\q1 
\v 9 Kaasoo nafteenna nolol ku haya,
\q1 Oo cagaheennana aan u oggolayn in la dhaqdhaqaajiyo.
\q1 
\v 10 Waayo, Ilaahow, adigu waad na imtixaantay,
\q1 Oo waxaad noo tijaabisay sida lacagta loo tijaabiyo.
\q1 
\v 11 Waxaad na gelisay shabagga dabinka ah,
\q1 Oo waxaad simaha naga saartay culaab weyn.
\q1 
\v 12 Dad baad madaxa naga saartay,
\q1 Oo waxaannu dhex galnay dab iyo biyo,
\q1 Laakiinse ugudambaysta waxaad na keentay meel barwaaqo ah.
\q1 
\v 13 Haddaba anigu gurigaaga waxaan la soo geli doonaa allabaryo la gubo,
\q1 Oo waxaan kuu oofinayaa nidarradaydii
\q1 
\v 14 Bushimahaygu ay ku hadleen,
\q1 Oo afkaygu sheegay markii aan dhibaataysnaa.
\q1 
\v 15 Oo waxaan allabaryo la gubo kuugu soo bixinayaa xoolo buurbuuran
\q1 Iyo wanan iyo fooxood,
\q1 Oo waxaan kuu soo bixin doonaa dibiyo iyo orgiyo. (Selaah)
\q1 
\v 16 Kulli intiinna Ilaah ka cabsataay, kaalaya oo maqla,
\q1 Oo waxaan sheegayaa wuxuu naftayda u sameeyeye.
\q1 
\v 17 Isagaan afkayga ugu qayshaday,
\q1 Oo waxaan ku ammaanay carrabkayga.
\q1 
\v 18 Haddaan dembi qalbigayga ku arkay,
\q1 Sayidku ima uu maqleen,
\q1 
\v 19 Laakiinse sida runta ah Ilaah waa i maqlay,
\q1 Oo codkii baryadaydana dhegtuu u dhigay.
\q1 
\v 20 Mahad waxaa leh Ilaaha
\q1 Aan baryadayda diidin oo aan naxariistiisana gees iga marin.
\c 67
\s2 Kanu waa sabuur gabay ah oo loo tiriyey madaxdii muusikaystayaasha, waxaana lagu qaadaa alaab xadhko leh oo muusiko ah.
\q1 
\v 1 Ilaahow, noo naxariiso, oo na barakee,
\q1 Oo wejigaaguna ha na iftiimiyo, (Selaah)
\q1 
\v 2 In jidkaaga laga ogaado dhulka,
\q1 Quruumaha oo dhan dhexdoodana laga wada ogaado caafimaadkaaga wax badbaadiya.
\q1 
\v 3 Ilaahow, dadyowgu ha ku ammaaneen,
\q1 Dadyowga oo dhammu ha ku ammaaneen.
\q1 
\v 4 Quruumuhu ha farxeen oo ha gabyeen farxad aawadeed,
\q1 Waayo, dadyowga waxaad ku xukumi doontaa caddaalad,
\q1 Oo quruumahana dhulkaad ugu talin doontaa. (Selaah)
\q1 
\v 5 Ilaahow, dadyowgu ha ku ammaaneen,
\q1 Dadyowga oo dhammu ha ku ammaaneen.
\q1 
\v 6 Dhulku wuxuu soo saaray midhihiisii,
\q1 Waxaa ina barakayn doona Ilaah, oo ah Ilaaheenna qudhiisa.
\q1 
\v 7 Ilaah waa ina barakayn doonaa,
\q1 Oo dhulka darafyadiisa oo dhammuna way ka cabsan doonaan isaga.
\c 68
\s2 Kanu waa sabuur gabay ah oo Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Ilaah ha sara joogsado, oo cadaawayaashiisuna ha kala firdheen,
\q1 Kuwa necebuna hortiisa ha ka carareen.
\q1 
\v 2 Sida qiiqu u kala firdho, iyagana sidaasoo kale u kala firdhi,
\q1 Sida shamacu dabka ugu dhalaalo,
\q1 Sidaasoo kale kuwa sharka lahu Ilaah hortiisa ha ku baabbe'een.
\q1 
\v 3 Laakiinse kuwa xaqa ahu ha farxeen, oo Ilaah hortiisa ha ku reyreeyeen,
\q1 Haah, oo farxad ha ku reyreeyeen.
\q1 
\v 4 Ilaah u gabya, oo magiciisa ammaan ugu gabya,
\q1 Kan lamadegaanka dhex mara jid weyn u fala,
\q1 Magiciisu waa Yaah, ee hortiisa ku reyreeya.
\q1 
\v 5 Ilaah wuxuu rugtiisa quduuskaa ku yahay
\q1 Agoonta aabbahood iyo carmallada xaakinkooda.
\q1 
\v 6 Kuwa cidlaysan Ilaah reero ayuu u yeelaa,
\q1 Oo maxaabiistana intuu soo bixiyo ayuu barwaaqo dhex geeyaa,
\q1 Laakiinse caasiyiintu waxay degganaadaan dhul oommane ah.
\q1 
\v 7 Ilaahow, markaad dadkaaga hor kacday,
\q1 Markaad lamadegaanka ku dhex socotay, (Selaah)
\q1 
\v 8 Dhulku waa gariiray,
\q1 Samooyinkuna waxay ku de'een Ilaah hortiisa,
\q1 Xataa Buur Siinay nafteedu waxay ka gariirtay Ilaah hortiisa, kaasoo ah Ilaaha Israa'iil.
\q1 
\v 9 Ilaahow, waxaad soo daysay roob badan,
\q1 Oo kuwa dhaxalkaagu markay daallanaayeenna waad xoogaysay.
\q1 
\v 10 Ururkaagu halkaasuu dhex degganaa,
\q1 Ilaahow, wanaaggaaga aawadiis wax baad u diyaarisay masaakiinta.
\q1 
\v 11 Sayidku wuxuu bixiyey erayga,
\q1 Kuwa warka faafiyaana waa guuto weyn.
\q1 
\v 12 Boqorrada ciidammadu way cararaan, way cararaan,
\q1 Oo tan guriga ku hadha ayaa dhaca qaybisa.
\q1 
\v 13 Xeryaha idaha miyaad iska dhex jiifaysaan,
\q1 Sidii baadad qoolley oo lacag lagu dahaadhay,
\q1 Iyo baalasheeda oo dahab cas lagu dahaadhay?
\q1 
\v 14 Markii Qaadirku boqorrada halkaas ku kala dhex firdhiyey,
\q1 Waxay ahayd sida marka baraf cad ku da'o Salmoon.
\q1 
\v 15 Buur Ilaah waxaa ah Buur Baashaan.
\q1 Oo buur dheer waxaa ah Buur Baashaan.
\q1 
\v 16 Buurihiinnan dhaadheerow, bal maxaad u quudhsanaysaan
\q1 Buurta Ilaah uu jeclaaday inuu hoygiisii ka dhigto?
\q1 Haah, oo Rabbigu halkaasuu degganaan doonaa weligiisba.
\q1 
\v 17 Ilaah gaadhifardoodyadiisu waa labaatan kun, iyo xataa kumanyaal iyo kumaankun,
\q1 Sayidku wuu ku dhex jiraa iyaga, siduu Siinay ugu jiri jiray xagga meesha quduuska ah.
\q1 
\v 18 Adigu kor baad u baxday, oo waxaad qabatay oo kaxaysay kuwii maxaabiista ahaan jiray.
\q1 Oo waxaad hadiyado ka qaadatay dadka dhexdiisa,
\q1 Iyo xataa caasiyiintaba, in Rabbiga Ilaah ahu halkaas joogo aawadeed.
\q1 
\v 19 Waxaa mahad leh Sayidka maalin kasta culaabteenna inoo qaada,
\q1 Kaasoo ah Ilaaha ina badbaadiya. (Selaah)
\q1 
\v 20 Ilaah wuxuu inoo yahay Ilaaha samatabbixinta,
\q1 Ilaaha Sayidka ah ayaa iska leh dhimashada kabixiddeeda.
\q1 
\v 21 Laakiinse Ilaah wuxuu wax ku dhufan doonaa madaxa cadaawayaashiisa,
\q1 Iyo dhalada timaha leh oo kan xadgudubyadiisa ku sii socdaba.
\q1 
\v 22 Sayidku wuxuu yidhi, Waxaan iyaga ka soo celin doonaa xagga Baashaan,
\q1 Oo waxaan ka soo bixin doonaa badda moolkeeda,
\q1 
\v 23 Inaad cagtaada dhiig darsatid,
\q1 Iyo in eeyahaaga carrabkoodu uu qayb ka helo cadaawayaashaada.
\q1 
\v 24 Ilaahow, waxay arkeen tegiddaadii,
\q1 Taas oo ah tegiddii Ilaahay oo ah Boqorkayga oo uu galay meesha quduuska ah.
\q1 
\v 25 Gabayayaashii way hor mareen, muusikaystayaashiina way raaceen,
\q1 Dhexdana waxaa ku jiray hablo daf ku cayaaraya.
\q1 
\v 26 Kuwiinnan isha Israa'iil ka soo farcamayow,
\q1 Shirarka ku dhex ammaana Ilaaha Sayidka ah.
\q1 
\v 27 Waxaa jooga Benyaamiin yar oo ah taliyahooda,
\q1 Iyo amiirrada reer Yahuudah iyo guddigooda,
\q1 Iyo amiirrada reer Sebulun iyo amiirrada reer Naftaali.
\q1 
\v 28 Ilaahaagu xooggaaguu amray,
\q1 Ilaahow, waxaad noo samaysay noo xoogee.
\q1 
\v 29 Macbudkaaga Yeruusaalem ku yaal daraaddiis
\q1 Ayaa boqorro waxay kuugu keeni doonaan hadiyado.
\q1 
\v 30 Canaano dugaagga cawsduurka ku dhex jira,
\q1 Iyo dibida tirada badan, iyo weylaha dadka
\q1 Oo ku tumanaya lacagta gogo'a ah,
\q1 Isagu wuu kala firdhiyey dadyowga dagaalka jecel.
\q1 
\v 31 Masar waxaa ka iman doona amiirro,
\q1 Itoobiyana haddiiba gacmaheeday u hoorsan doontaa Ilaah.
\q1 
\v 32 Boqortooyooyinka dhulkow, Ilaah u gabya,
\q1 Ammaan ugu gabya Sayidka, (Selaah)
\q1 
\v 33 Kaasoo kor fuushan samada samooyinka sare, oo weligoodba jiray,
\q1 Bal eega, wuxuu ku hadlaa codkiisa, oo weliba codkiisu waa xoog badan yahay.
\q1 
\v 34 Ilaah xoog ka sheega,
\q1 Waayo, sharaftiisu waxay dul joogtaa reer binu Israa'iil,
\q1 Oo xooggiisuna wuxuu ku jiraa samooyinka.
\q1 
\v 35 Ilaahow, meelahaaga quduuska ah waxaad ka tahay mid laga cabsado,
\q1 Ilaaha reer binu Israa'iil wuxuu dadkiisa siiyaa xoog iyo itaal.
\q1 Mahad waxaa leh Ilaah.
\c 69
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu luuqeeyaa Shoshanniim.
\q1 
\v 1 Ilaahow, i badbaadi,
\q1 Waayo, biyaa naftii ii keenay.
\q1 
\v 2 Waxaan ku dhex liimbadaa dhoobo mool dheer oo aan lahayn meel laysku taago,
\q1 Waxaan ku dhacay biyo mool dheer, oo daad baa halkaas igu qarqinaya.
\q1 
\v 3 Waxaan ku daalay qayladaydii, oo hungurigaygu waa qallalay,
\q1 Oo intii aan Ilaahay sugayo ayay indhahaygu dem yidhaahdaan.
\q1 
\v 4 Kuwa sababla'aanta ii nebcaadaa way ka sii badan yihiin timaha madaxayga,
\q1 Kuwa doonaya inay i baabbi'iyaan iyagoo cadaawayaashayda gardarro igu ah waa xoog badan yihiin,
\q1 Markaasaan magdhabay wax aanan qaadan.
\q1 
\v 5 Ilaahow, waad og tahay nacasnimadayda,
\q1 Oo dembiyadayduna kaama qarsoona.
\q1 
\v 6 Sayidow, Ilaaha ciidammadow, kuwa ku sugaya yaanan ceeb u soo jiidin,
\q1 Ilaaha reer binu Israa'iilow, kuwa ku doondoonaya yaanan sharafjab u soo jiidin.
\q1 
\v 7 Maxaa yeelay, adiga daraaddaa ayaan cay u qaaday,
\q1 Oo waxaa wejigaygii ka muuqatay ceeb.
\q1 
\v 8 Waxaan walaalahay u noqday shisheeye,
\q1 Oo ilma hooyadayna waxaan u noqday ajanabi.
\q1 
\v 9 Qiiradii aan gurigaaga u qabay ayaa i gubtay,
\q1 Oo caydii kuwii ku caayay ayaa igu kor dhacday.
\q1 
\v 10 Markaan ooyay, oo aan naftayda soon ku edbiyey,
\q1 Taasu waxay igu noqotay ceeb.
\q1 
\v 11 Markaan joonyado dhar ka dhigtayna,
\q1 Waxaan iyagii u noqday masaal.
\q1 
\v 12 Kuwa iridda fadhfadhiyaa way igu sheekaystaan,
\q1 Oo kuwa sakhraanka ahuna way igu gabyaan.
\q1 
\v 13 Laakiinse adigaan ku baryayaa wakhti la aqbali karo, Rabbiyow,
\q1 Ilaahow, naxariistaada badan
\q1 Iyo runta badbaadintaada iigu jawaab.
\q1 
\v 14 Dhoobada iga samatabbixi, oo yaanan ku liimban,
\q1 Oo ha layga samatabbixiyo kuwa i neceb, iyo biyaha moolka dheer.
\q1 
\v 15 Biyaha daadka ahuna yaanay i qarqin,
\q1 Oo yaan moolku i liqin,
\q1 Oo yamayskuna yaanu afkiisa igu qabsan.
\q1 
\v 16 Rabbiyow, ii jawaab, waayo, raxmaddaadu waa wanaagsan tahay,
\q1 Naxariistaada badnaanteeda aawadeed iigu soo jeeso.
\q1 
\v 17 Oo wejigaaga ha iga qarin anoo addoonkaaga ah,
\q1 Waayo, waan dhibaataysnahay, ee haddiiba ii jawaab.
\q1 
\v 18 Naftayda u soo dhowow, oo furo,
\q1 Oo cadaawayaashayda daraaddood ii samatabbixi.
\q1 
\v 19 Waad og tahay caydayda iyo ceebtayda iyo sharafdarradayda,
\q1 Oo cadaawayaashayda oo dhammu hortaaday joogaan.
\q1 
\v 20 Cay baa i qalbi jebisay, waanan quusanayaa,
\q1 Oo waxaan doondoonay mid ii jixinjixa, laakiinse waan waayay,
\q1 Oo waxaan doondoonay kuwo i qalbi qaboojiya, laakiinse ma aanan helin.
\q1 
\v 21 Oo weliba waxay cunto ahaan ii siiyeen xammeeti,
\q1 Oo markaan harraadsanaana waxay i cabsiiyeen khal.
\q1 
\v 22 Miiskoodu hortooda ha ku noqdo dabin,
\q1 Oo markay nabdoon yihiinna shirqool ha ku noqdo.
\q1 
\v 23 Indhahoodu ha madoobaadeen si aanay waxba u arkin,
\q1 Oo simahooduna had iyo goorba ha gariireen.
\q1 
\v 24 Xanaaqaaga iyaga ku deji,
\q1 Oo cadhadaada kulaylkeeduna ha qabsado.
\q1 
\v 25 Gurigoodu cidla ha noqdo,
\q1 Ninnana yaanu teendhooyinkooda degin,
\q1 
\v 26 Waayo, iyagu waxay silciyaan kii aad dishay,
\q1 Oo waxay ka sheekeeyaan kuwaad dhaawacday murugtooda.
\q1 
\v 27 Xumaantooda xumaan ugu sii dar,
\q1 Oo yaanay xaqnimadaada soo gelin.
\q1 
\v 28 Magacooda ha laga tirtiro kitaabka kuwa nool,
\q1 Oo yaan iyaga lala qorin kuwa xaqa ah.
\q1 
\v 29 Laakiinse anigu miskiin baan ahay, waanan murug badnahay,
\q1 Ilaahow, badbaadintaadu meel sare ha i saarto.
\q1 
\v 30 Rabbiga magiciisa ayaan gabay ku ammaani doonaa,
\q1 Oo waxaan isaga ku weynayn doonaa mahadnaqid.
\q1 
\v 31 Oo taasuna Rabbiga way ka farxin doontaa in ka sii wanaagsan intii uu ku farxi lahaa dibi,
\q1 Ama dibi sange ah oo geeso iyo qoobab leh.
\q1 
\v 32 Kuwa camal qabow way arkeen, waana faraxsan yihiin,
\q1 Kuwiinna Ilaah doondoonow, qalbigiinnu ha noolaado.
\q1 
\v 33 Waayo, Rabbigu wuu maqlaa kuwa baahan,
\q1 Oo maxaabiistiisana ma uu quudhsado.
\q1 
\v 34 Samada, iyo dhulka, iyo badaha,
\q1 Iyo waxa ku dhex dhaqaaqa oo dhammuba isaga ha ammaaneen.
\q1 
\v 35 Waayo, Ilaah Siyoon wuu badbaadin doonaa, oo magaalooyinka reer Yahuudahna wuu dhisi doonaa,
\q1 Oo iyana halkaasay degi doonaan, oo hanti ahaan bay u lahaan doonaan.
\q1 
\v 36 Oo weliba waxaa halkaas dhaxli doona farcanka addoommadiisa,
\q1 Oo kuwa magiciisa jecelna way dhex degganaan doonaan.
\c 70
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha, si wax loogu xusuusto.
\q1 
\v 1 Ilaahow, soo dhaqso oo i samatabbixi,
\q1 Rabbiyow, soo dhaqso oo i caawi.
\q1 
\v 2 Kuwa doondoonaya inay naftayda iga qaadaan
\q1 Ha ceeboobeen oo ha wareereen,
\q1 Oo kuwa waxyeelladayda ku farxaana
\q1 Dib ha u noqdeen oo ha sharaf beeleen.
\q1 
\v 3 Kuwa Ahaa, Ahaa, lahu,
\q1 Ceebtooda dib ha ula noqdeen.
\q1 
\v 4 Kuwa adiga ku doondoona oo dhammu ha reyreeyeen oo ha kugu farxeen,
\q1 Oo kuwa badbaadintaada jeceluna had iyo goorba ha yidhaahdeen,
\q1 Ilaah ha la weyneeyo.
\q1 
\v 5 Laakiinse miskiin iyo mid baahan baan ahay,
\q1 Ilaahow, ii soo dhaqso,
\q1 Waxaad tahay caawimaaddayda iyo samatabbixiyahayga.
\q1 Rabbiyow, ha iga raagin.
\b
\c 71
\q1 
\v 1 Rabbiyow, adigaan isku kaa halleeyaa,
\q1 Yaanan weligay wareerin.
\q1 
\v 2 Xaqnimadaada igu samatabbixi oo i nabad geli,
\q1 Dhegta ii dhig, oo i badbaadi.
\q1 
\v 3 Ii noqo dhagax weyn oo rug ah, oo aan had iyo goorba ku noqnoqdo,
\q1 Waxaad amar ku bixisay in lay badbaadsho,
\q1 Waayo, adigu waxaad tahay dhagax weyn oo ii gabbaad ah iyo qalcaddayda.
\q1 
\v 4 Ilaahayow, iga badbaadi kan sharka leh gacantiisa,
\q1 Iyo gacanta xaqlaawaha iyo ninka nacabkaa.
\q1 
\v 5 Waayo, Sayidow Ilaahow, waxaad tahay rajadayda,
\q1 Oo waxaad tahay kii aan isku hallaynayay tan iyo yaraantaydii.
\q1 
\v 6 Tan iyo uurkii hooyaday adigaa i tiirinayay,
\q1 Waxaad tahay kii iga soo bixiyey uurkii hooyaday,
\q1 Had iyo goorba adigaan ku ammaani doonaa.
\q1 
\v 7 Anigu kuwo badan baan u ahay sidii wax yaab leh,
\q1 Laakiinse adigu waxaad ii tahay magangal xoog leh.
\q1 
\v 8 Maalin kasta waxaa afkayga ka buuxi doona
\q1 Ammaantaada iyo sharaftaada.
\q1 
\v 9 Ha i tuurin markaan gaboobo,
\q1 Oo ha i dayrin markaan itaal darnaado.
\q1 
\v 10 Waayo, cadaawayaashaydu waxay ka hadlaan wax igu saabsan,
\q1 Oo kuwa naftayda inay iga qaadaan doonayaana way wada arrinsadaan,
\q1 
\v 11 Oo waxay isyidhaahdaan, Ilaah baa dayriyey,
\q1 Haddaba ka daba taga oo qabta, waayo, ma jiro mid samatabbixinayaa.
\q1 
\v 12 Ilaahow, ha iga fogaan,
\q1 Ilaahayow, soo dhaqso oo i caawi.
\q1 
\v 13 Kuwa naftayda cadaawayaal ku ahu ha ceeboobeen oo ha baabba'een,
\q1 Oo kuwa waxyeelladayda doondoonayana ceeb iyo sharafdarro ha ku bateen.
\q1 
\v 14 Laakiinse anigu had iyo goorba wax baan rajaynayaa,
\q1 Oo weliba waan kuu sii ammaanayaa aad iyo aad.
\q1 
\v 15 Afkaygu wuxuu maalinta oo dhan ka sheekayn doonaa xaqnimadaada, iyo badbaadintaada,
\q1 Waayo, anigu ma aqaan intay tiro le'eg yihiin.
\q1 
\v 16 Waxaan la imanayaa Sayidka Ilaahaa shuqulladiisa xoogga leh,
\q1 Oo waxaan ka hadli doonaa xaqnimadaada, taasoo ah taada oo keliya.
\q1 
\v 17 Ilaahow, wax baad i bari jirtay tan iyo yaraantaydii,
\q1 Oo ilaa haatanna waxaan caddayn jiray shuqulladaada yaabka badan.
\q1 
\v 18 Ilaahow, ha i dayrin, xataa markaan gaboobo oo madaxaygu cirroobo,
\q1 Jeeraan xooggaaga uga warramo farcanka dambe
\q1 Oo aan itaalkaaga uga sheekeeyo mid kasta oo hadda ka dib imanaya.
\q1 
\v 19 Ilaahow, xaqnimadaadu aad iyo aad bay u sarraysaa,
\q1 Ilaahow, adiga oo waxyaalaha waaweyn sameeyey,
\q1 Bal yaa kula mid ah?
\q1 
\v 20 Adiga oo na tusay dhibaatooyin badan oo aad u xun,
\q1 Ayaa haddana na noolayn doona,
\q1 Oo haddana waxaad naga soo saari doontaa dhulka moolkiisa.
\q1 
\v 21 Weynaantayda ii sii kordhi,
\q1 Oo intaad soo jeesatid i qalbi qabooji.
\q1 
\v 22 Ilaahow, waxaan kugu ammaani doonaa alaab muusiko ah,
\q1 Oo runtaadaan ammaani doonaa,
\q1 Israa'iil kiisa Quduuska ahow,
\q1 Waxaan ammaan kuugula gabyi doonaa kataarad.
\q1 
\v 23 Bushimahaygu aad bay ugu farxi doonaan, markaan ammaan kuugu gabyo,
\q1 Oo xataa naftaydii aad soo furatayna way rayrayn doonta.
\q1 
\v 24 Oo weliba carrabkayguna maalinta oo dhan wuxuu ka sheekayn doonaa xaqnimadaada,
\q1 Waayo, kuwa waxyeelladayda doondoonayaa way ceeboobaan, oo way isku wareeraan.
\c 72
\s2 Kanu waa sabuur uu Sulaymaan tiriyey.
\q1 
\v 1 Ilaahow, boqorka xukummadaada sii,
\q1 Oo wiilka boqorkana xaqnimadaada sii.
\q1 
\v 2 Isagu dadkaaga wuxuu ku xukumi doonaa xaqnimo,
\q1 Oo masaakiintaadana caddaalad.
\q1 
\v 3 Buuruhu waxay dadka u keeni doonaan nabad,
\q1 Kuruhuna waxay nabad ugu keeni doonaan xaqnimada.
\q1 
\v 4 Isagu wuxuu u garsoori doonaa dadka masaakiintiisa,
\q1 Oo wuxuu badbaadin doonaa ka baahan carruurtiisa,
\q1 Oo kan wax dulmana cadcad buu u kala jejebin doonaa.
\q1 
\v 5 Way kaa cabsan doonaan inta qorraxdu jirto,
\q1 Iyo inta dayaxu jiro tan iyo ka ab ka ab.
\q1 
\v 6 Isagu wuxuu u soo degi doonaa sida roob caws la jaray ku dul hoora,
\q1 Iyo sida tiixyo dhulka biyeeya.
\q1 
\v 7 Wakhtigiisa ayaa kan xaqa ahu barwaaqoobi doonaa,
\q1 Oo nabadduna way badan doontaa tan iyo inta dayaxu aanu mar dambe jiri doonin.
\q1 
\v 8 Oo isagu wuxuu u talin doonaa bad ilaa ka bad,
\q1 Iyo tan iyo Webiga iyo ilaa dhulka darfihiisa.
\q1 
\v 9 Kuwa cidlada degganu hortiisay ku sujuudi doonaan;
\q1 Oo cadaawayaashiisuna ciidday leefleefi doonaan.
\q1 
\v 10 Boqorrada Tarshiish iyo kuwa gasiiraduhuba waxay isaga u keeni doonaan gabbaro,
\q1 Boqorrada Shebaa iyo kuwa Sebaana waxay isaga siin doonaan hadiyado.
\q1 
\v 11 Haah, oo boqorrada oo dhammu hortiisay ku wada sujuudi doonaan,
\q1 Oo quruumaha oo dhammuna isagay u adeegi doonaan.
\q1 
\v 12 Waayo, isagu wuxuu samatabbixin doonaa kan baahan markuu qayliyo,
\q1 Iyo miskiinka aan mid caawiya lahayn.
\q1 
\v 13 Wuxuu u nixi doonaa miskiinka iyo kan baahan,
\q1 Oo kuwa baahan naftoodana wuu badbaadin doonaa.
\q1 
\v 14 Naftooduu ka furan doonaa khiyaano iyo dulmi,
\q1 Oo dhiiggooduna hortiisuu qaali ku ahaan doonaa,
\q1 
\v 15 Oo isagu wuu noolaan doonaa, oo waxaa la siin doonaa dahabka Shebaa;
\q1 Had iyo goorba dadku way u ducayn doonaan,
\q1 Oo weliba maalinta oo dhan isagay ammaani doonaan.
\q1 
\v 16 Oo dhulka waxaa jiri doona hadhuudh badan xagga buuraha dushooda,
\q1 Oo midhihiisuna waxay u soo ruxmi doonaan sida Lubnaan oo kale,
\q1 Oo kuwa magaalada joogaana waxay u barwaaqoobi doonaan sida doogga dhulka.
\q1 
\v 17 Magiciisu weligiis buu waari doonaa,
\q1 Magiciisu waa sii jiri doonaa in alla intay qorraxdu jirto;
\q1 Oo dadku way ku barakoobi doonaan isaga,
\q1 Quruumaha oo dhammuna waxay ugu yeedhi doonaan farxaan.
\q1 
\v 18 Mahad waxaa leh Rabbiga Ilaahaa oo ah Ilaaha reer binu Israa'iil,
\q1 Oo keligiis sameeya waxyaalo yaab badan,
\q1 
\v 19 Magiciisa ammaanta badanu mahad ha lahaado weligiisba,
\q1 Oo dhulka oo dhanna ammaantiisu ha ka buuxsanto.
\q1 Aamiin iyo Aamiin.
\q1 
\v 20 Daa'uud ina Yesay baryootannadiisii way dhammaadeen.
\c 73
\s1 Kitaabka Saddexaad
\s2 Sabuurrada 73-89
\s2 Kanu waa sabuur Aasaaf tiriyey.
\q1 
\v 1 Hubaal Ilaah waa u roon yahay reer binu Israa'iil,
\q1 Iyo xataa kuwa qalbigoodu daahirka yahay.
\q1 
\v 2 Laakiinse anigu waan turunturoon gaadhay,
\q1 Oo tallaabooyinkayguna waxay u dhowaadeen inay simbiriirixdaan.
\q1 
\v 3 Waayo, waxaan ka hinaasay kuwa qabka weyn,
\q1 Markaan arkay barwaaqada ay kuwa sharka lahu haystaan.
\q1 
\v 4 Waayo, geeridoodu xanuun ma leh,
\q1 Laakiinse xooggoodu waa adag yahay.
\q1 
\v 5 Iyagu dhib kuma jiraan sida dadka kale,
\q1 Oo sida dadka kalena uma belaayaysna.
\q1 
\v 6 Sidaas daraaddeed kibir wuxuu yahay sida silsilad qoorta u sudhan,
\q1 Oo dulmi bay sida maro u huwan yihiin.
\q1 
\v 7 Indhahoodu baruur bay la bararsan yihiin,
\q1 Oo waxay haystaan in ka sii badan waxa qalbigoodu doonayo.
\q1 
\v 8 Wax bay ku qoslaan, oo xumaan daraaddeed dulmi bay ku hadlaan,
\q1 Waxay hadlaan iyagoo kor isu qaadaya.
\q1 
\v 9 Afkoodii waxay gaadhsiiyeen samooyinka,
\q1 Oo carrabkooduna wuxuu dhex maraa dhulka oo dhan.
\q1 
\v 10 Sidaas daraaddeed dadkiisii halkanay ku soo noqdaan,
\q1 Oo koob biyo ka buuxa ayay madhsadeen.
\q1 
\v 11 Oo waxay yidhaahdaan, Ilaah sidee buu wax u yaqaan?
\q1 Kan ugu sarreeyana aqoonu ma ku jirtaa?
\q1 
\v 12 Bal eeg, kuwanu waa kuwa sharka leh,
\q1 Oo mar kasta iyagoo istareexsan ayay hodantinimadoodu sii korodhaa.
\q1 
\v 13 Hubaal wax aan micne lahayn ayaan qalbigaygii ku nadiifshay,
\q1 Oo aan ku faraxashay anigoo aan eed lahayn,
\q1 
\v 14 Waayo, maalintii oo dhan waa lay dhibayay,
\q1 Oo subax kastana waa lay edbinayay.
\q1 
\v 15 Haddaan odhan lahaa, Sidaasaan ku hadli doonaa,
\q1 Bal eeg, waan khiyaanayn lahaa farcanka carruurtaada.
\q1 
\v 16 Markaan ku fikiray si aan tan ku ogaado,
\q1 Aad bay iigu xanuun badnayd,
\q1 
\v 17 Ilaa aan galay meesha quduuska ah ee Ilaah,
\q1 Oo aan ka fiirsaday ugudambaystooda.
\q1 
\v 18 Hubaal waxaad iyaga ku taagtaa meelo sibiibix ah,
\q1 Oo waxaad hoos ugu tuurtaa si ay u baabba'aan.
\q1 
\v 19 Sidee bay daqiiqad ugu noqdeen meel cidla ah!
\q1 Dhammaantood waxay ku baabba'een cabsi.
\q1 
\v 20 Sayidow, sidii mid riyo ka toosay
\q1 Markaad toostid, waxaad quudhsan doontaa ekaantooda.
\q1 
\v 21 Waayo, qalbigaygu wuu murugooday,
\q1 Oo waxaa layga muday kelyaha,
\q1 
\v 22 Waxaan ahaa doqon iyo jaahil,
\q1 Oo hortaada waxaan ku ahaa sidii xoolo oo kale.
\q1 
\v 23 Habase yeeshee had iyo goorba waan kula joogaa,
\q1 Oo waxaad i qabatay gacanta midig.
\q1 
\v 24 Waxaad igu hoggaamin doontaa taladaada,
\q1 Oo dabadeedna waxaad igu dhowayn doontaa ammaanta.
\q1 
\v 25 Bal, yaan samada ku leeyahay adiga mooyaane?
\q1 Oo dhulkana laguma arko mid aan kaa jeclahay.
\q1 
\v 26 Jiidhkayga iyo qalbigayguba waa itaal darnaadeen,
\q1 Laakiinse Ilaah wuxuu weligiis ii yahay xooggii qalbigayga iyo qaybtayda.
\q1 
\v 27 Waayo, bal eeg, kuwa kaa fogu way halligmi doonaan,
\q1 Oo waad wada baabbi'isay kuwii kaa caasiyoobay oo dhan.
\q1 
\v 28 Laakiinse aniga waxaa ii roon inaan Ilaah u soo dhowaado,
\q1 Waayo, Sayidka Ilaahaa waxaan ka dhigtay magangalkayga,
\q1 Inaan ka sheekeeyo shuqulladaada oo dhan.
\c 74
\s2 Kanu waa sabuur Maskiil ah oo Aasaaf tiriyey.
\q1 
\v 1 Ilaahow, bal maxaad weligaaba noo xoortay?
\q1 Oo bal maxaa cadhadaadu ugu kululaataa idaha daaqsintaada?
\q1 
\v 2 Bal soo xusuuso ururkaaga aad waa hore soo iibsatay,
\q1 Oo aad u soo furatay inay ahaadaan qabiilkaad dhaxashay,
\q1 Oo weliba Buur Siyoon oo aad degganaatana soo xusuuso.
\q1 
\v 3 Tallaabooyinkaaga u soo qaad xagga baabba'a weligiis ah,
\q1 Iyo xagga xumaanta uu cadowgu meesha quduuska ah ku sameeyey oo dhan.
\q1 
\v 4 Cadaawayaashaadii waxay ka qayliyeen shirkaaga dhexdiisa,
\q1 Oo waxay calaamad ahaan u qotonsadeen calammadoodii.
\q1 
\v 5 Waxay u ekaadeen sidii niman faasas u qaatay hawd jiq ah.
\q1 
\v 6 Haddaba shuqulkiisii la qoray oo dhan
\q1 Waxay ku wada dumiyaan gudmo iyo dubbayaal.
\q1 
\v 7 Meeshaada quduuska ah dab bay ku dhejiyeen,
\q1 Oo waxay wada nijaaseeyeen meeshii magacaaga hoyga u ahayd.
\q1 
\v 8 Waxay qalbigooda iska yidhaahdeen, Kaalaya aan dhammaantood baabbi'innee,
\q1 Waxay wada gubeen sunagogyadii Ilaah oo dalka ku dhex yiil oo dhan.
\q1 
\v 9 Annagu calaamadahayagii ma aragno,
\q1 Oo innaba mar dambe nebi ma jiro,
\q1 Dhexdayadana ma joogo mid garanaya ilaa goorma.
\q1 
\v 10 Ilaahow, ilaa goormaa cadowgu caytamayaa?
\q1 Cadowgu miyuu magacaaga caayayaa weligiisba?
\q1 
\v 11 Bal maxaad gacantaada midig dib ugu celisaa?
\q1 Laabtaada ka soo bixi oo iyaga baabbi'i.
\q1 
\v 12 Laakiinse Ilaah waa boqorkayga tan iyo waa hore,
\q1 Isagoo badbaadin ka dhex samaynaya dhulka.
\q1 
\v 13 Xooggaagaad badda ku kala qaybisay,
\q1 Oo masbadeedyada ku dhex jirana madaxaad ka jebisaa.
\q1 
\v 14 Waxaad kala burburisay madaxyada bahalbadeedyada oo Lewiiyaataan la odhan jiray,
\q1 Oo cunto ahaan ayaad u siisay dadkii cidlada degganaa.
\q1 
\v 15 Waxaad kala furtay ilo iyo durdurro,
\q1 Oo waxaad qallajisay webiyo waaweyn.
\q1 
\v 16 Maalinta adigaa iska leh, habeenkana adigaa iska leh,
\q1 Oo adigaa diyaariyey iftiinka iyo qorraxdaba.
\q1 
\v 17 Adigu waxaad samaysay dhulka soohdimihiisa oo dhan,
\q1 Oo adigaa sameeyey diraac iyo xagaaba.
\q1 
\v 18 Rabbiyow, xusuuso in cadowgu caytamay,
\q1 Iyo in dad nacas ahu magacaaga caayay.
\q1 
\v 19 Qoolleydaada nafteeda ha u gacangelin dugaagga,
\q1 Weligaaba ha illoobin nafta masaakiintaada,
\q1 
\v 20 Bal soo fiiri axdigaaga,
\q1 Dhulka meelihiisa gudcurka ah waxaa ka buuxa hoyaalka dulmiga.
\q1 
\v 21 Kuwa la dulmay yaanay dib u noqon iyagoo ceeboobay,
\q1 Miskiinka iyo kan baahanu magacaaga ha ammaaneen.
\q1 
\v 22 Ilaahow, sara joogso, oo dacwadaada u muddac.
\q1 Bal xusuuso siday dadka nacaska ahu maalinta oo dhan kuu caayaan.
\q1 
\v 23 Ha illoobin codka cadaawayaashaada,
\q1 Kuwa kugu kaca buuqoodu had iyo goorba wuu soo kacaa.
\c 75
\s2 Kanu waa sabuur gabay ah oo Aasaaf u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu luuqeeyaa Altashed.
\q1 
\v 1 Ilaahow, adaan kuu mahadnaqnaa,
\q1 Waannu kuu mahadnaqnaa, waayo, magacaagu waa noo dhow yahay,
\q1 Dadku waxay ka sheekeeyaan shuqulladaada yaabka badan.
\q1 
\v 2 Wakhtiga aan qawimay,
\q1 Ayaan si qumman wax u xukumi doonaa.
\q1 
\v 3 Dhulka iyo waxa kor deggan oo dhammuba way wada dhalaaleen,
\q1 Tiirarkiisa anigaa qotomiyey. (Selaah)
\q1 
\v 4 Kuwa kibirka leh waxaan ku idhi, Ha kibrina,
\q1 Kuwa sharka lehna waxaan ku idhi, Geeskiinna kor ha u taagina,
\q1 
\v 5 Geeskiinna kor ha u taagina,
\q1 Oo madaxadayg ha ku hadlina.
\q1 
\v 6 Waayo, sarrayntu kama timaado xagga bari ama xagga galbeed,
\q1 Ama xataa xagga koonfureed toona.
\q1 
\v 7 Laakiinse Ilaah baa xaakin ah,
\q1 Isagu mid buu dejiyaa, ku kalena wuu sarraysiiyaa.
\q1 
\v 8 Waayo, Rabbiga gacantiisa waxaa ku jira koob, oo waxaa ka xumbaynaysa khamri,
\q1 Oo waxaa ka buuxa wax laysku qooshay, oo kaasuu wax ka shubaa,
\q1 Hubaal huubadiisa waxaa heenheensan doona oo cabbi doona dunida kuweeda sharka leh oo dhan.
\q1 
\v 9 Laakiinse anigu weligayba waan rayrayn doonaa,
\q1 Oo waxaan ammaan ugu gabyi doonaa Ilaaha Yacquub.
\q1 
\v 10 Oo weliba kuwa sharka leh geesahooda oo dhan waan wada jejebin doonaa,
\q1 Laakiinse kuwa xaqa ah geesahooda waa la sarraysiin doonaa.
\c 76
\s2 Kanu waa sabuur gabay ah oo Aasaaf u tiriyey madaxdii muusikaystayaasha, waxaa lagu qaadaa alaab xadhko leh oo muusiko ah.
\q1 
\v 1 Ilaah baa reer Yahuudah lagu dhex yaqaan,
\q1 Oo magiciisuna reer binu Israa'iil dhexdooda waa ku weyn yahay.
\q1 
\v 2 Oo taambuuggiisu wuxuu ku yaal Saalem,
\q1 Hoygiisuna wuxuu ku yaal Siyoon.
\q1 
\v 3 Oo halkaas wuxuu ku jejebiyey fallaadhihii qaansada,
\q1 Iyo gaashaankii, iyo seeftii, iyo dagaalkiiba. (Selaah)
\q1 
\v 4 Adigu waxaad ka ammaan iyo haybad badan tahay buuraha ugaadha leh.
\q1 
\v 5 Kuwii qalbiga adkaa waa la dhacay, oo hurdadoodii ayay wada gam'een,
\q1 Oo raggii xoogga badnaana midkoodna gacmihiisii waxba kuma samayn.
\q1 
\v 6 Ilaaha Yacquubow, canaantaadii aawadeed
\q1 Ayaa gaadhifardood iyo fardoba waxay kula dhex dheceen hurdo weyn.
\q1 
\v 7 Adigase waa in lagaa cabsadaa,
\q1 Bal yaa hortaada istaagi kara mar haddaad cadhootid?
\q1 
\v 8 Waxaad ka dhigtay in xukun samada laga maqlo,
\q1 Oo dhulkiina waa baqay, oo wuu aamusay,
\q1 
\v 9 Markuu Ilaah xukunka u sara kacay
\q1 Inuu badbaadsho kuwa camalka qabow oo dhulka jooga oo dhan. (Selaah)
\q1 
\v 10 Hubaal waxaa ku ammaani doonta dadka cadhadiisa,
\q1 Oo waxaad dhexda ku xidhan doontaa cadhada inteeda hadhay.
\q1 
\v 11 Rabbiga Ilaahiin ah wax u nidra, oo u oofiya,
\q1 Inta hareerihiisa ku wareegsan oo dhammu isaga hadiyado ha u keeneen kan ay waajibka tahay in laga cabsado.
\q1 
\v 12 Isagu wuxuu gooyn doonaa amiirrada ruuxooda,
\q1 Boqorrada dunidana wuu u cabsi badan yahay.
\c 77
\s2 Kanu waa sabuur Aasaaf u tiriyey madaxdii muusikaystayaasha. Oo wuxuu u tiriyey sidii Yeduutuun.
\q1 
\v 1 Anigu codkaygaan Ilaah ugu qayshan doonaa,
\q1 Xataa Ilaah ayaan codkayga ugu qayshan doonaa, oo isaguna wuu i dhegaysan doonaa.
\q1 
\v 2 Maalintii aan dhibaataysnaa waxaan doondoonay Sayidka,
\q1 Gacantaydu way fidsanayd habeennimadii, mana ay nasan,
\q1 Oo naftaydiina way diidday in la qaboojiyo.
\q1 
\v 3 Waxaan soo xusuustaa Ilaah, markaasaan welwelaa,
\q1 Waan cawdaa, markaasay naftaydu taag darnaataa. (Selaah)
\q1 
\v 4 Indhahaygii waad soo jeedisay,
\q1 Aad baan u dhibaataysnahay si aanan u hadli karin.
\q1 
\v 5 Waxaan ka fikiray wakhtigii hore,
\q1 Iyo sannadihii waa hore ahaa.
\q1 
\v 6 Habeenka waxaan soo xusuustaa gabaygayga,
\q1 Oo waxaan la sheekaystaa qalbigayga,
\q1 Oo ruuxaygiina aad buu wax u doondoonay.
\q1 
\v 7 Sayidku weligiisba ma i xoorayaa?
\q1 Oo miyaanu mar dambe raalli iga ahaanaynin?
\q1 
\v 8 Naxariistiisii miyey wada dhammaatay weligeedba?
\q1 Ballankiisiina miyuu baaqanayaa ka ab ka ab?
\q1 
\v 9 Ilaah miyuu illoobay inuu ahaado mid raxmad badan?
\q1 Naxariistiisiina ma isagoo cadhaysan buu xidhay? (Selaah)
\q1 
\v 10 Oo weliba waxaan idhi, Tanu waa itaaldarradayda,
\q1 Laakiinse waxaan xusuusan doonaa sannadihii gacanta midig oo Ilaaha ugu sarreeya.
\q1 
\v 11 Waxaan ka soo sheekayn doonaa Rabbiga falimihiisa,
\q1 Waayo, waxaan soo xusuusan doonaa cajaa'ibyadaadii hore.
\q1 
\v 12 Waxaan ka fikiri doonaa shuqulkaaga oo dhan,
\q1 Oo falimahaaga oo dhanna waan u fiirsan doonaa.
\q1 
\v 13 Ilaahow, jidkaagu wuxuu ku dhex yaal meesha quduuska ah,
\q1 Ilaahee baa sida Ilaah u weyn?
\q1 
\v 14 Waxaad tahay Ilaah cajaa'ibyo sameeya,
\q1 Xooggaagii waxaad ogeysiisay dadyowga.
\q1 
\v 15 Gacantaadaad dadkaagii ku soo furatay,
\q1 Kuwaasoo ah ilma Yacquub iyo Yuusuf. (Selaah)
\q1 
\v 16 Ilaahow, biyuhu way ku arkeen,
\q1 Biyuhu way ku arkeen, oo way cabsadeen,
\q1 Oo moolalkuna way gariireen.
\q1 
\v 17 Daruuruhuna biyay soo daayeen,
\q1 Cirkuna wuxuu diray dhawaaq,
\q1 Oo weliba fallaadhahaaguna way bexeen.
\q1 
\v 18 Codkii onkodkaaguna wuxuu ku dhex jiray cirwareenta,
\q1 Hillaacuna wuxuu iftiimiyey dunida,
\q1 Dhulkuna wuu gariiray oo wuu ruxmaday.
\q1 
\v 19 Jidkaaguna badduu dhex maray,
\q1 Waddooyinkaaguna waxay dhex mareen biyo badan,
\q1 Oo raadadkaagana lama aqoon.
\q1 
\v 20 Dadkaaga waxaad u hor kacday sidii adhi oo kale,
\q1 Oo waxaad iyaga ku hoggaamisay gacanta Muuse iyo tan Haaruun.
\c 78
\s2 Kanu waa sabuur Maskiil ah oo Aasaaf tiriyey.
\q1 
\v 1 Dadkaygiiyow, sharcigayga dhegaysta,
\q1 Oo dhegahana u dhiga erayada afkayga.
\q1 
\v 2 Afkayga waxaan ku furi doonaa masaal,
\q1 Oo waxaan ku dhawaaqi doonaa xujooyin hore,
\q1 
\v 3 Kuwaasoo aynu maqalnay oo aynu niqiin,
\q1 Oo ay awowayaasheen inoo sheegeen.
\q1 
\v 4 Ka qarin mayno carruurtooda,
\q1 Laakiin waxaynu farcanka soo socda u sheegaynaa Rabbiga ammaantiisa,
\q1 Iyo xooggiisa, iyo shuqulladiisii yaabka badnaa oo uu sameeyey.
\q1 
\v 5 Waayo, markhaati buu reer Yacquub ka dhex dhisay,
\q1 Oo sharci buu reer binu Israa'iil u dejiyey,
\q1 Kaasoo uu ku amray awowayaasheen,
\q1 Inay carruurtooda dambe ogeysiiyaan aawadeed,
\q1 
\v 6 Iyo in farcanka soo socdaa ay iyaga ogaadaan, kuwaasoo ah carruurta hadda ka dib dhalanaysa,
\q1 Kuwaasoo iyana kici doona oo carruurtooda u sheegi doona,
\q1 
\v 7 Inay rajadooda Ilaah ku xidhaan,
\q1 Oo aanay illoobin Ilaah shuqulladiisii,
\q1 Laakiinse ay xajiyaan amarradiisa,
\q1 
\v 8 Oo aanay sidii awowayaashood oo kale noqon
\q1 Farcan madax adag oo caasi badan,
\q1 Kaasoo ah farcan aan qalbigoodu qummanayn,
\q1 Oo naftooduna aanay xagga Ilaah aamin ku ahayn.
\q1 
\v 9 Reer Efrayim iyagoo hub iyo qaansooyin sita
\q1 Ayay maalintii dagaalka dib u noqdeen.
\q1 
\v 10 Axdigii Ilaah ma ay xajin,
\q1 Oo waxay diideen inay sharcigiisii ku socdaan,
\q1 
\v 11 Oo waxay illoobeen falimihiisa
\q1 Iyo shuqulladiisii yaabka badnaa oo uu iyaga tusay.
\q1 
\v 12 Waxyaalo yaab badan ayuu awowayaashood ku hor sameeyey,
\q1 Markay joogeen dalkii Masar iyo berrinkii Socan.
\q1 
\v 13 Isagu badduu kala gooyay, oo iyagii dhex marsiiyey,
\q1 Oo biyihiina wuxuu ka dhigay inay sidii taallo u taagnaadaan.
\q1 
\v 14 Oo weliba maalinnimadii wuxuu ku hoggaamiyey daruur,
\q1 Oo habeennimadii oo dhanna wuxuu ku hoggaamiyey dab iftiinkiis.
\q1 
\v 15 Wuxuu kala jebiyey dhagaxyadii cidlada,
\q1 Oo wuxuu iyaga ka siiyey cabniin aad u badan oo ah sidii kan moolka laga helo.
\q1 
\v 16 Oo weliba wuxuu dhagaxa weyn ka soo faruuray durdurro,
\q1 Oo wuxuu biyo u qulquliyey sidii webiyada oo kale.
\q1 
\v 17 Laakiinse iyagu weli way ku sii socdeen inay isaga ku dembaabaan,
\q1 Inay ku caasiyoobaan Ilaaha ugu sarreeya intii ay cidladii joogeen.
\q1 
\v 18 Oo weliba Ilaah waxay ku tijaabiyeen qalbigooda
\q1 Kolkii ay hilib u weyddiisteen damacooda aawadiis.
\q1 
\v 19 Oo Ilaah bay wax ka sheegeen,
\q1 Oo waxay yidhaahdeen, Ilaah ma miis buu cidlada ku diyaarin karaa?
\q1 
\v 20 Bal eeg, dhagaxii ayuu wax ku dhuftay, markaasaa biyo ka soo buqdeen
\q1 Oo durdurraa ka soo buuxdhaafay,
\q1 Haddaba miyuu kibisna bixin karaa?
\q1 Miyuu dadkiisa hilib siin karaa?
\q1 
\v 21 Sidaas daraaddeed Rabbigu taas buu maqlay, wuuna cadhooday,
\q1 Oo reer Yacquub dab baa ku shidmay,
\q1 Reer binu Israa'iilna cadhaa ku dhacday,
\q1 
\v 22 Maxaa yeelay, Ilaah ma ay rumaysan,
\q1 Oo badbaadintiisana iskuma ay hallayn.
\q1 
\v 23 Laakiin isagu wuxuu amray cirka sare
\q1 Oo albaabbadii samadana wuu furay;
\q1 
\v 24 Oo wuxuu ku soo daayay maanna ay cunaan,
\q1 Oo wuxuu iyagii wax ka siiyey hadhuudhkii samada.
\q1 
\v 25 Dadkii waxay cuneen kibistii malaa'igaha,
\q1 Oo weliba wuxuu iyaga u soo diray hilib ay ka dhergaan.
\q1 
\v 26 Isagu wuxuu samada ka kiciyey dabaysha bari,
\q1 Oo dabaysha koonfureedna xooggiisuu ku hoggaamiyey.
\q1 
\v 27 Oo korkoodana hilib buu ugu soo daadiyey sidii ciidda oo kale,
\q1 Oo wuxuu ku soo daayay haad baalal leh oo ah sidii cammuudda badaha,
\q1 
\v 28 Oo wuxuu ku soo daadiyey xeradooda dhexdeeda,
\q1 Iyo rugahooda hareerahooda.
\q1 
\v 29 Sidaas daraaddeed iyagii way cuneen, oo aad bay uga dhergeen,
\q1 Oo isna wuxuu iyagii siiyey wixii ay u jeellanaayeen.
\q1 
\v 30 Iyagu jeelkii damacooda kama ay xiisa dhicin,
\q1 Oo cuntadoodii weli afkooday ku jirtay,
\q1 
\v 31 Markii cadhada Ilaah ay iyaga ku dhacday,
\q1 Oo ay dishay kuwii iyaga ugu buurbuurnaa,
\q1 Oo ay laysay raggii dhallinyarada ahaa oo reer binu Israa'iil.
\q1 
\v 32 In kastoo waxyaalahaas oo dhammu ay ku dheceen,
\q1 Weli way sii dembaabeen,
\q1 Oo mana ay rumaysan shuqulladiisii yaabka badnaa.
\q1 
\v 33 Sidaas daraaddeed maalmahoodii wuxuu ku dhammeeyey wax aan waxtar lahayn,
\q1 Cimrigoodiina cabsi.
\q1 
\v 34 Markii uu iyaga laayay ayay isaga dooneen,
\q1 Oo haddiiba way soo noqdeen oo Ilaah goor hore doondooneen.
\q1 
\v 35 Oo waxay xusuusteen in Ilaah ahaa dhagaxoodii weynaa,
\q1 Iyo in Ilaaha ugu sarreeyaa uu ahaa Bixiyahooda.
\q1 
\v 36 Laakiinse waxay isaga ku faansheen afkooda,
\q1 Oo carrabkoodana been bay ugu sheegeen.
\q1 
\v 37 Waayo, qalbigoodu xaggiisa kuma hagaagsanayn,
\q1 Oo axdigiisiina daacad uma ay ahayn.
\q1 
\v 38 Laakiinse isagoo raxmad miidhan ah ayuu xumaantoodii cafiyey, oo mana uu baabbi'in iyagii,
\q1 Haah, oo marar badan ayuu cadhadiisii ka leexiyey,
\q1 Oo cadhadiisii oo dhanna ma uu wada kicin.
\q1 
\v 39 Oo wuxuu xusuustay inay iyagu yihiin binu-aadmi,
\q1 Iyo dabayl iska gudubta oo aan mar dambe soo noqon.
\q1 
\v 40 Immisa jeer bay isaga ku caasiyoobeen markay cidlada joogeen,
\q1 Oo immisa jeer bay calool xumeeyeen markay lamadegaanka dhex joogeen!
\q1 
\v 41 Oo haddana way soo noqdeen oo waxay tijaabiyeen Ilaah,
\q1 Oo waxay ka xanaajiyeen reer binu Israa'iil Kooda Quduuska ah.
\q1 
\v 42 Sooma ay xusuusan gacantiisii,
\q1 Iyo maalintii uu iyaga ka soo furtay cadowga toona,
\q1 
\v 43 Iyo xataa siduu calaamooyinkiisii Masar ugu dhex sameeyey,
\q1 Yaababkiisiina berrinkii Socan.
\q1 
\v 44 Iyo siduu webiyaashoodii dhiigga ugu beddelay,
\q1 Durdurradoodiina, si aanay waxba uga cabbi karin.
\q1 
\v 45 Wuxuu ku soo dhex daayay duqsiyo badan, wayna cuneen,
\q1 Iyo xataa rahyo, oo iyana way baabbi'iyeen.
\q1 
\v 46 Oo weliba wixii u baxay wuxuu siiyey diir,
\q1 Oo waxay ku hawshoodeenna wuxuu siiyey ayax.
\q1 
\v 47 Geedcanabkoodii wuxuu ku baabbi'iyey roobdhagaxyaale,
\q1 Oo dhirtoodii darayga ahaydna wuxuu ku baabbi'iyey sayax barafoobay.
\q1 
\v 48 Xoolahoodii wuxuu ku soo daayay roobdhagaxyaalaha,
\q1 Adhyahoodiina danabyo kulul.
\q1 
\v 49 Oo wuxuu ku soo daayay kulaylkii cadhadiisa,
\q1 Iyo xanaaq, iyo dhirif, iyo dhib,
\q1 Iyo guuto ah malaa'igo shar ah.
\q1 
\v 50 Isagu cadhadiisii wadduu u sameeyey,
\q1 Oo naftoodiina dhimasho ugama uu lexejeclaan,
\q1 Laakiinse noloshoodii wuxuu u daayay belaayada,
\q1 
\v 51 Oo wuxuu dalkii Masar ku laayay curadyadii oo dhan,
\q1 Kuwaas oo ahaa xooggoodii u horreeyey oo uu ku dhex laayay teendhooyinkii Xaam,
\q1 
\v 52 Laakiinse isagu dadkiisii sidii ido oo kale ayuu u hor kacay,
\q1 Oo cidladuu ku dhex hoggaamiyey iyaga sidii adhi oo kale.
\q1 
\v 53 Oo ammaan buu ku hoggaamiyey, si aanay u baqin,
\q1 Laakiinse cadaawayaashoodii baddaa qarqisay.
\q1 
\v 54 Oo wuxuu iyagii keenay xuduudkii meeshiisa quduuska ah,
\q1 Iyo ilaa buurtan ay midigtiisu iibsatay.
\q1 
\v 55 Oo weliba hortoodana wuxuu ka eryay quruumaha,
\q1 Oo dhaxal ahaan buu ugu qaybiyey.
\q1 Oo qabiilooyinkii reer binu Israa'iilna wuxuu dejiyey teendhooyinkoodii.
\q1 
\v 56 Laakiin way jirrabeen oo ku caasiyoobeen Ilaaha ugu sarreeya,
\q1 Oo markhaatifurkiisiina ma ay xajin,
\q1 
\v 57 Laakiinse dib bay u noqdeen, oo sidii awowayaashood ayay si aan daacad ahayn ula dhaqmeen,
\q1 Oo iyagu waxay u leexdeen sidii qaanso khiyaano badan.
\q1 
\v 58 Waayo, waxay isaga kaga xanaajiyeen meelahoodii sarsare,
\q1 Oo waxay isaga uga hinaasiyeen sanamyadooda la qoray.
\q1 
\v 59 Ilaah markuu taas maqlay ayuu cadhooday,
\q1 Oo aad buu reer binu Israa'iil u karhay,
\q1 
\v 60 Sidaas daraaddeed taambuuggii Shiiloh wuu dayriyey,
\q1 Kaasoo ah teendhadii uu dadka dhex dhigay,
\q1 
\v 61 Oo xooggiisii wuxuu u gacangeliyey maxaabiisnimo,
\q1 Ammaantiisiina wuxuu ku riday cadowga gacantiisii.
\q1 
\v 62 Dadkiisiina wuxuu u gacangeliyey seef,
\q1 Oo wuxuu u cadhooday dhaxalkiisii.
\q1 
\v 63 Raggoodii dhallinyarada ahaa dab baa laastay,
\q1 Gabdhahoodiina buraanbur aroos looma tirin.
\q1 
\v 64 Wadaaddadoodii waxay ku dhinteen seef,
\q1 Carmalladoodiina uma ay barooran.
\q1 
\v 65 Markaasaa Sayidku wuxuu u kacay sidii mid hurdo ka toosay,
\q1 Sidii nin xoog badan oo la qaylinaya khamri daraaddiis.
\q1 
\v 66 Cadaawayaashiisiina wuu ku dhuftay oo dib buu u celiyey,
\q1 Oo wuxuu saaray ceeb aan weligeed ka hadhayn.
\q1 
\v 67 Oo weliba wuu diiday teendhadii reer Yuusuf,
\q1 Qabiilkii reer Efrayimna ma uu dooran,
\q1 
\v 68 Laakiinse wuxuu doortay qabiilkii reer Yahuudah,
\q1 Iyo Buur Siyoon oo uu jeclaaday.
\q1 
\v 69 Oo meeshiisii quduuska ahayd wuxuu u dhisay sidii meelaha sare,
\q1 Iyo sidii dhulka uu weligiis adkeeyey.
\q1 
\v 70 Wuxuuna doortay addoonkiisii Daa'uud,
\q1 Oo wuxuu isaga ka soo waday xeryaha idaha,
\q1 
\v 71 Wuxuu ka soo waday laxihii ilmo nuujinayay oo uu raacayay,
\q1 Inuu daajiyo reer Yacquub oo dadkiisa ah, iyo reer binu Israa'iil oo dhaxalkiisa ah.
\q1 
\v 72 Haddaba wuxuu u daajinayay si waafaqsan daacadnimada qalbigiisa,
\q1 Oo wuxuu ku hoggaaminayay farsamada gacmihiisa.
\c 79
\s2 Kanu waa sabuur Aasaaf tiriyey.
\q1 
\v 1 Ilaahow, quruumihii kale waxay u soo galeen dhaxalkaagii,
\q1 Macbudkaagii quduuska ahaana way nijaaseeyeen,
\q1 Oo Yeruusaalemna waxay ka dhigeen tuulmooyin.
\q1 
\v 2 Meydadkii addoommadaada waxay cunto uga dhigeen haadka samada,
\q1 Oo hilibkii quduusiintaadana waxay cunto uga dhigeen dugaagga dhulka.
\q1 
\v 3 Dhiiggoodiina waxay Yeruusaalem hareeraheeda ugu daadiyeen sidii biyo oo kale,
\q1 Cid aastaana ma jirin.
\q1 
\v 4 Waxaannu cay u noqonnay derisyadayadii,
\q1 Kuwa nagu wareegsanna wax la quudhsado oo lagu qoslo.
\q1 
\v 5 Rabbiyow, ilaa goormaad noo cadhaysnaan doontaa? Ma weligaa baa?
\q1 Masayrkaagu ma sida dab buu u ololi doonaa?
\q1 
\v 6 Cadhadaada ku soo deji quruumaha aan ku aqoon,
\q1 Iyo boqortooyooyinka aan magacaaga kugu baryin.
\q1 
\v 7 Waayo, waxay laayeen reer Yacquub,
\q1 Rugtoodiina way baabbi'iyeen.
\q1 
\v 8 Ha noo xusuusnaan dembiyadii awowayaashayo,
\q1 Naxariistaadu dhaqsiyo ha noogu timaado,
\q1 Waayo, aad baa lanoo dhibay.
\q1 
\v 9 Ilaaha badbaadadayadow, magacaaga ammaantiisa daraaddeed noo caawi,
\q1 Oo magacaaga daraaddiis noo samatabbixi, oo dembiyadayada naga nadiifi.
\q1 
\v 10 Bal maxaa quruumuhu u leeyihiin, Ilaahoodu meeh?
\q1 Dhiiggii addoommadaada oo ay daadiyeen aargoosashadiisii
\q1 Ha lagu ogaado quruumaha dhexdooda annagoo arkayna.
\q1 
\v 11 Maxbuuska taahiisu hortaada ha yimaado,
\q1 Xooggaaga weynaantiisa ku badbaadi kuwa dhimashada lagu xukumay.
\q1 
\v 12 Sayidow, derisyadayada toddoba jibbaar ugu abaalmari,
\q1 Oo laabta u geli caydii ay kugu caayeen.
\q1 
\v 13 Haddaba annagoo ah dadkaaga iyo idihii daaqsintaada
\q1 Waannu kugu mahadnaqaynaa weligayo,
\q1 Oo ammaantaada waannu ka sheekaysan doonnaa tan iyo ka ab ka ab.
\c 80
\s2 Kanu waa sabuur Aasaaf u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu luuqeeyaa Shoshanniim Ceduud.
\q1 
\v 1 Na maqal, Adhijirka reer binu Israa'iil jirow,
\q1 Kaaga reer Yuusuf sida adhi u hor kacow,
\q1 Kaaga Keruubiimta ku dul fadhiyow, soo iftiin.
\q1 
\v 2 Reer Efrayim iyo reer Benyaamiin iyo reer Manaseh hortooda xooggaaga ku kici,
\q1 Oo kaalay oo na badbaadi.
\q1 
\v 3 Ilaahow, mar kale na soo celi,
\q1 Oo wejigaaga noo iftiimi, oo waannu badbaadi doonnaa.
\q1 
\v 4 Rabbiyow Ilaaha ciidammadow,
\q1 Ilaa goormaad u cadhaysnaan doontaa baryootanka dadkaaga?
\q1 
\v 5 Waxaad ku quudisay kibistii ilmada,
\q1 Oo ilmo aad u badanna ayaad cabsiisay.
\q1 
\v 6 Waxaad nala dirirsiisay derisyadayada,
\q1 Oo cadaawayaashayadiina way nagu qoslaan.
\q1 
\v 7 Ilaaha ciidammadow, mar kale na soo celi,
\q1 Oo wejigaaga noo iftiimi, oo waannu badbaadi doonnaa.
\q1 
\v 8 Geed canab ah ayaad dalkii Masar ka keentay,
\q1 Oo intaad quruumihii ka eriday ayaad meel ku beertay.
\q1 
\v 9 Meel baad hortiisa ku diyaarisay,
\q1 Oo wuxuu yeeshay xididdo dhaadheer, kolkaasuu dhulkii buuxiyey.
\q1 
\v 10 Oo buurihii waxaa qariyey hooskiisii,
\q1 Oo laamihiisiina waxay noqdeen sidii geedaha la yidhaahdo kedar oo Ilaah.
\q1 
\v 11 Laamihiisii wuxuu gaadhsiiyey tan iyo badda,
\q1 Dhudihiisiina waxay gaadheen tan iyo Webiga.
\q1 
\v 12 Bal maxaad deyrkiisii u dumisay
\q1 Si ay kuwa jidka maraa oo dhammu u goostaan?
\q1 
\v 13 Waxaa kharriba doofaarka kaynta,
\q1 Oo waxaa iska daaqda ugaadha duurka.
\q1 
\v 14 Ilaaha ciidammadow, waannu ku baryaynaaye noo soo noqo,
\q1 Samada hoos nooga soo fiiri oo intaad soo eegtid, geedkan canabka ah soo booqo,
\q1 
\v 15 Oo ilaali wixii ay gacantaada midig beertay,
\q1 Iyo laantii aad adkaysatay.
\q1 
\v 16 Dab baa lagu gubay, oo waa la gooyay,
\q1 Oo waxay ku halligmeen canaantii jaahaaga.
\q1 
\v 17 Gacantaadu ha kor saarnaato ninka gacantaada midig jooga,
\q1 Iyo binu-aadmigii aad nafsaddaada u xoogaysatay.
\q1 
\v 18 Markaas dib kaaga noqon mayno,
\q1 Na noolee, oo markaasaannu magacaaga ku baryootamaynaa.
\q1 
\v 19 Rabbiyow Ilaaha ciidammadow, mar kale na soo celi,
\q1 Oo wejigaaga noo iftiimi, oo waannu badbaadi doonnaa.
\c 81
\s2 Kanu waa sabuur Aasaaf u tiriyey madaxdii muusikaystayaasha, oo waxaa lagu luuqeeyaa Gitiid.
\q1 
\v 1 Aad ugu gabya Ilaaha xooggeenna ah,
\q1 Oo farxad ugu qayliya Ilaaha Yacquub.
\q1 
\v 2 Sabuurka kor u qaada, oo waxaad halkan keentaan dafka,
\q1 Iyo kataaradda lagu farxo, iyo shareeradda.
\q1 
\v 3 Buunka afuufa markay bishu dhalato,
\q1 Iyo markuu dayaxu caddo buuxda yahay, iyo maalinta iiddeenna quduuska ah.
\q1 
\v 4 Waayo, taasu qaynuun bay u tahay reer binu Israa'iil,
\q1 Waana amar ka yimid Ilaaha Yacquub.
\q1 
\v 5 Oo wuxuu reer Yuusuf dhexdooda ka dhigay markhaati,
\q1 Markii uu dalkii Masar ku soo baxay,
\q1 Halkaas oo aan ka maqlay af aanan aqoon.
\q1 
\v 6 Garbihiisa waxaan ka qaaday culaabtii saarnayd,
\q1 Gacmihiisana waxaa laga xoreeyey dambiishii.
\q1 
\v 7 Waad ii dhawaaqatay markii dhib kuu yimid, oo anna waan ku soo samatabbixiyey,
\q1 Waxaan kaaga jawaabay onkodka meeshiisa qarsoon,
\q1 Oo waxaan kugu tijaabiyey biyihii Meriibaah. (Selaah)
\q1 
\v 8 Dadkaygiiyow, bal i maqla,
\q1 Oo anna waan idiin digi doonaa,
\q1 Reer binu Israa'iilow, bal haddaad i maqli lahaydeen!
\q1 
\v 9 Waa inaan ilaah qalaad idinku dhex jirin,
\q1 Oo waa inaydaan innaba ilaah qalaad caabudin.
\q1 
\v 10 Anigu waxaan ahay Rabbiga Ilaahaaga ah,
\q1 Oo kaa soo bixiyey dalkii Masar,
\q1 Afkaaga aad u kala qaad, oo anna waan buuxin doonaa.
\q1 
\v 11 Laakiinse dadkaygii ma ay dhegaysan codkaygii,
\q1 Oo reer binu Israa'iilna ima aqbalin.
\q1 
\v 12 Sidaas daraaddeed waxaan u daayay inay ku socdaan madaxadayggooda.
\q1 Si ay taladooda ugu socdaan.
\q1 
\v 13 Bal may dadkaygu i dhegaystaan,
\q1 Oo reer binu Israa'iil bal may jidkayga ku socdaan!
\q1 
\v 14 Oo waxaan haddiiba jebin lahaa cadaawayaashooda,
\q1 Oo gacantaydana waan ku jeedin lahaa colkooda.
\q1 
\v 15 Kuwa Rabbiga necebu waxay hoos geli lahaayeen isaga,
\q1 Laakiinse wakhtigoodu weligiis wuu waari lahaa.
\q1 
\v 16 Oo weliba wuxuu iyaga ku quudin lahaa sarreenka ugu wanaagsan,
\q1 Oo waxaan ka dhergin lahaa malabka dhagaxa ka soo baxa.
\c 82
\s2 Kanu waa sabuur uu Aasaaf tiriyey.
\q1 
\v 1 Ilaah wuxuu dhex istaagaa ururka Ilaah,
\q1 Oo wuxuu wax ku xukumaa ilaahyada dhexdooda,
\q1 
\v 2 Ilaa goormaad xaqdarro wax ku xukumaysaan?
\q1 Oo ilaa goormaad kuwa sharka leh u eexanaysaan? (Selaah)
\q1 
\v 3 Miskiinka iyo agoonka gar siiya,
\q1 Oo caddaalad ugu garsoora kan dhibaataysan iyo saboolka.
\q1 
\v 4 Badbaadiya miskiinka iyo kan baahan,
\q1 Oo ka samatabbixiya gacanta kuwa sharka leh.
\q1 
\v 5 Iyagu waxba ma yaqaaniin, waxna garan maayaan,
\q1 Oo gudcur bay hor iyo dib ugu socdaan,
\q1 Dhulka aasaaskiisii oo dhammu waa wada dhaqdhaqaaqay.
\q1 
\v 6 Waxaan idhi, Idinku waxaad tihiin ilaahyo,
\q1 Oo dhammaantiin waxaad tihiin Ilaaha uga sarreeya wiilashiisii.
\q1 
\v 7 Habase yeeshee waxaad u dhiman doontaan sida dadka oo kale,
\q1 Oo waxaad u dhici doontaan sida amiirrada midkood.
\q1 
\v 8 Ilaahow, sara joogso oo dhulka xukun,
\q1 Waayo, waxaad dhaxli doontaa quruumaha oo dhan.
\c 83
\s2 Kanu waa sabuur gabay ah oo Aasaaf tiriyey.
\q1 
\v 1 Ilaahow, shib ha odhan,
\q1 Oo ha aamusin, afkana ha haysan, Ilaahow.
\q1 
\v 2 Waayo, bal eeg, cadaawayaashaadu way buuqaan,
\q1 Oo kuwii ku nebcaana madaxay kor u qaadeen.
\q1 
\v 3 Dadkaagay xeelad ugu tashadaan,
\q1 Oo waxay dhammaantood u arrinsadaan kuwaad qarisay.
\q1 
\v 4 Waxay isku yidhaahdeen, Kaalaya, aan baabbi'innee, yaanay mar dambe quruun ahaanine.
\q1 Si aan magaca Israa'iil dib loogu soo xusuusan.
\q1 
\v 5 Waayo, iyagoo isku waafaqsan ayay ku arrinsadeen,
\q1 Oo axdi kaa gees ah ayay isla dhigtaan,
\q1 
\v 6 Teendhooyinkii reer Edom iyo reer Ismaaciil,
\q1 Iyo reer Moo'aab iyo reer Hagariim,
\q1 
\v 7 Reer Gebal iyo reer Cammoon iyo reer Camaaleq,
\q1 Reer Falastiin iyo kuwii Turos degganaa,
\q1 
\v 8 Oo xataa reer Ashuurna way ku darsameen,
\q1 Oo waxay kaalmeeyeen ilma Luud. (Selaah)
\q1 
\v 9 Iyaga ku samee wixii aad ku samaysay reer Midyaan,
\q1 Iyo Siiseraa iyo Yaabiin markii ay ag joogeen Webi Qiishoon,
\q1 
\v 10 Waxay ku halligmeen Ceyn Door,
\q1 Oo waxay dhulka u noqdeen digo.
\q1 
\v 11 Nimankooda gobta ah oo dhan waxaad ka dhigtaa sida Cooreeb iyo Se'eeb,
\q1 Oo amiirradooda oo dhanna sida Sebah iyo Salmunnac,
\q1 
\v 12 Kuwaas oo isyidhi, War aan iska qaadanno oo hantinno Ilaah degmooyinkiisa.
\q1 
\v 13 Ilaahayow, iyaga ka dhig sida boodhka warwareega,
\q1 Iyo sida xaab dabaysha ka horreeya,
\q1 
\v 14 Sida dabka duurka guba,
\q1 Iyo sida ololka buuraha huriya,
\q1 
\v 15 Sidaasoo kale iyaga duufaankaaga ku eri,
\q1 Hufadaadana ku cabsii.
\q1 
\v 16 Rabbiyow, wejigoodu wareer ha ka buuxsamo,
\q1 Si ay magacaaga u doondoonaan.
\q1 
\v 17 Weligood ha ceeboobeen, hana baqeen,
\q1 Ha wareereen, hana baabbe'een,
\q1 
\v 18 Si ay u ogaadaan in adigoo magacaagu Ilaah yahay
\q1 Aad tahay Ilaaha ugu sarreeya dunida oo dhan.
\c 84
\s2 Kanu waa sabuur ay reer Qorax u tiriyeen madaxdii muusikaystayaasha, oo Gitiid lagu luuqeeyo.
\q1 
\v 1 Rabbiga ciidammadow, taambuugyadaadu sidee bay u yihiin wax la jeclaado!
\q1 
\v 2 Naftaydu waxay u xiisaysan tahay Rabbiga barxadihiisa,
\q1 Qalbigayga iyo jiidhkayguba waxay u dhawaaqaan Ilaaha nool.
\q1 
\v 3 Haah, shimbirtu waxay nafsaddeeda u heshay guri,
\q1 Dabafallaadhuna buul ay yaryarkeeda ku dhasho,
\q1 Kaas oo ah meelaha allabarigaaga, Rabbiga ciidammadow,
\q1 Boqorkaygiiyow, Ilaahaygiiyow.
\q1 
\v 4 Waxaa barakaysan kuwa gurigaaga deggan,
\q1 Weligoodba way ku sii ammaani doonaan.
\q1 
\v 5 Waxaa barakaysan ninkii xooggiisu xaggaaga ka yimaado,
\q1 Oo ay jidadka sare oo Siyoon qalbigiisa ku jiraan.
\q1 
\v 6 Markay dhex maraan Dooxadii Oohinta waxay ka dhigaan meel ilo badan leh,
\q1 Haah, oo roobka hore ayaa barakooyin ka buuxiya.
\q1 
\v 7 Way xoogaystaan, oo weliba way sii xoogaystaan,
\q1 Oo midkood kastaaba Ilaah buu ka hor muuqdaa Siyoon dhexdeeda.
\q1 
\v 8 Rabbiyow, Ilaaha ciidammadow, baryadayda maqal,
\q1 Ilaaha Yacquubow, bal dhegta ii dhig, (Selaah)
\q1 
\v 9 Ilaahow, gaashaankayagiiyow, bal eeg,
\q1 Oo bal kaaga la subkay wejigiisa fiiri.
\q1 
\v 10 Waayo, maalin barxadahaaga la joogo way ka sii wanaagsan tahay kun maalmood oo kale.
\q1 Intaan teendhooyinka sharka joogi lahaa,
\q1 Waxaan ka sii jeclaan lahaa inaan guriga Ilaah iridjooge u ahaado.
\q1 
\v 11 Waayo, Rabbiga Ilaaha ahu waxa weeye qorrax iyo gaashaan,
\q1 Rabbigu wax wanaagsan kalama hadhi doono kuwa si qumman u socda.
\q1 Wuxuuna siin doonaa naxariis iyo sharaf.
\q1 
\v 12 Rabbiga ciidammadow,
\q1 Waxaa barakaysan ninkii isku kaa halleeya.
\c 85
\s2 Kanu waa sabuur ay reer Qorax u tiriyeen madaxdii muusikaystayaasha.
\q1 
\v 1 Rabbiyow, dalkaagii waad u roonaatay,
\q1 Oo waxaad soo celisay maxaabiistii reer Yacquub.
\q1 
\v 2 Xumaantii dadkaagana waad cafiday,
\q1 Oo dembigoodii oo dhanna waad qarisay. (Selaah)
\q1 
\v 3 Cadhadaadii oo dhan waad fogaysay,
\q1 Oo waad ka soo noqotay kulaylkii xanaaqaaga.
\q1 
\v 4 Ilaaha Badbaadadayadow, na soo celi,
\q1 Oo dhirifkaaga naga jooji.
\q1 
\v 5 Miyaad weligaaba noo cadhaysnaanaysaa?
\q1 Oo xanaaqaaga miyaad sii dheeraynaysaa tan iyo ka ab ka ab?
\q1 
\v 6 Miyaanad mar dambe na soo noolaynayn,
\q1 Si ay dadkaagu kuugu reyreeyaan?
\q1 
\v 7 Rabbiyow, naxariistaada na tus,
\q1 Oo badbaadadaada na sii.
\q1 
\v 8 Waan maqli doonaa waxa Ilaaha Rabbiga ahu ku hadlo,
\q1 Waayo, nabad buu kula hadli doonaa dadkiisa iyo quduusiintiisa,
\q1 Laakiin yaanay nacasnimo ku noqon.
\q1 
\v 9 Hubaal badbaadadiisu way u dhow dahay kuwa isaga ka cabsada,
\q1 Si ay ammaanu dalkayaga u degganaato.
\q1 
\v 10 Naxariis iyo runu way isla kulmeen,
\q1 Xaqnimo iyo nabaduna way isdhunkadeen.
\q1 
\v 11 Runtu waxay ka soo baxdaa dhulka,
\q1 Xaqnimaduna waxay hoos ka soo fiirisaa samada.
\q1 
\v 12 Haah, Rabbigu wuxuu ina siin doonaa waxa wanaagsan,
\q1 Oo dalkeennuna wuxuu soo bixin doonaa midhihiisa.
\q1 
\v 13 Hortiisa waxaa socon doonta xaqnimo,
\q1 Oo waxay tallaabooyinkiisa ka dhigi doontaa jid la maro.
\c 86
\s2 Baryootankii Daa'uud.
\q1 
\v 1 Rabbiyow, dhegtaada ii soo dhig, oo ii jawaab,
\q1 Waayo, waxaan ahay miskiin iyo mid baahane.
\q1 
\v 2 Naftayda dhawr, waayo, waxaan ahay mid cibaado leh,
\q1 Ilaahayow, i badbaadi anigoo ah addoonkaaga isku kaa halleeya.
\q1 
\v 3 Sayidow, ii naxariiso,
\q1 Waayo, maalinta oo dhan adaan kuu qayshadaa.
\q1 
\v 4 Sayidow, addoonkaaga naftiisa ka farxi,
\q1 Waayo, naftayda adigaan kor kuugu soo qaadaa.
\q1 
\v 5 Waayo, Sayidow, waad wanaagsan tahay, oo waxaad diyaar u tahay inaad dembidhaafto,
\q1 Waanad u naxariis badan tahay kuwa ku barya oo dhan.
\q1 
\v 6 Rabbiyow, baryadayda dhegta u dhig,
\q1 Oo codka baryootankayga maqal.
\q1 
\v 7 Maalinta aan dhibaataysnahay adaan ku baryi doonaa,
\q1 Waayo, waad ii jawaabi doontaa.
\q1 
\v 8 Sayidow, adigoo kale ilaahyada kuma jiro,
\q1 Oo shuqulladaadana wax la mid ahu ma jiraan.
\q1 
\v 9 Sayidow, quruumihii aad samaysay oo dhammu way iman doonaan oo hortaaday ku sujuudi doonaan,
\q1 Waxay ammaani doonaan magacaaga.
\q1 
\v 10 Waayo, adigu waad weyn tahay, oo waxyaalo yaab badanna waad samaysaa,
\q1 Oo adiga keliya ayaa Ilaah ah.
\q1 
\v 11 Rabbiyow, jidkaaga i bar, oo anna runtaadaan ku socon doonaa,
\q1 Qalbigayga mid ka dhig si aan magacaaga uga cabsado.
\q1 
\v 12 Sayidow Ilaahayow, qalbigayga oo dhan waan kugu ammaanayaa,
\q1 Oo weligayba waxaan ammaani doonaa magacaaga.
\q1 
\v 13 Waayo, naxariistaadu xaggayga way ku weyn tahay,
\q1 Naftaydana waxaad ka soo samatabbixisay She'oolka ugu hooseeya.
\q1 
\v 14 Ilaahow, kuwa kibirka lahu way igu keceen,
\q1 Ururka dadka dulmiga badanna waxay doonayeen inay nafta iga qaadaan,
\q1 Oo adigana kuuma ay soo jeesan.
\q1 
\v 15 Laakiinse adigu Sayidow, waxaad tahay Ilaah ay raxmad iyo nimco ka buuxaan,
\q1 Oo cadhada u gaabiya, oo naxariis iyo runba badan.
\q1 
\v 16 Ii soo jeeso, oo ii naxariiso,
\q1 Oo anoo addoonkaaga ah xoog i sii,
\q1 Oo i badbaadi anoo wiilka addoontaada ah.
\q1 
\v 17 Calaamad wanaaggaaga lagu garto i tus,
\q1 Si ay kuwa i necebu u arkaan, oo ay u ceeboobaan,
\q1 Maxaa yeelay, Rabbiyow, waad i caawisay, oo waad i qalbi qaboojisay.
\c 87
\s2 Kanu waa sabuur gabay ah oo ay reer Qorax tiriyeen.
\q1 
\v 1 Aasaaskiisu wuxuu ku jiraa buuraha quduuska ah.
\q1 
\v 2 Rabbigu degmooyinka reer Yacquub oo dhan
\q1 Wuxuu ka jecel yahay irdaha Siyoon.
\q1 
\v 3 Magaalada Ilaahay,
\q1 Waxyaalo ammaan badan ayaa lagaa sheegaa. (Selaah)
\q1 
\v 4 Anigu waxaan ka sheekayn doonaa Rahab iyo Baabuloon sidii kuwo i yaqaan,
\q1 Bal eeg, Falastiin, iyo Turos, iyo Itoobiya.
\q1 Midkanu halkaasuu ku dhashay.
\q1 
\v 5 Haah, oo Siyoonna waxaa laga odhan doonaa, Midkan iyo midkaasuba iyaduu ku dhashay,
\q1 Oo Ilaaha ugu sarreeya ayaa iyada dhisi doona.
\q1 
\v 6 Rabbigu wuu tirin doonaa markuu dadka qorayo,
\q1 Midkanu halkaasuu ku dhashay. (Selaah)
\q1 
\v 7 Kuwa gabya iyo kuwa cayaaraaba waxay odhan doonaan,
\q1 Waxaa kugu jira ilahayga oo dhan.
\c 88
\s2 Kanu waa sabuur gabay ah oo ay reer Qorax u tiriyeen madaxdii muusikaystayaasha, oo waxaa lagu luuqeeyaa Maxalad Lecannod. Oo waa Maskiil tacliin ah oo Heemaankii reer Cesraax.
\q1 
\v 1 Rabbiyow, Ilaaha badbaadadaydow,
\q1 Habeen iyo maalinba hortaadaan ka qayliyey,
\q1 
\v 2 Baryootankaygu hortaada ha yimaado,
\q1 Oo qayladayda dhegta u dhig,
\q1 
\v 3 Waayo, naftayda waxaa ka buuxa dhibaatooyin,
\q1 Oo noloshayduna waxay ku dhowaanaysaa She'ool.
\q1 
\v 4 Waxaa laygu tiiriyey kuwa hoos ugu dhaadhaca yamayska,
\q1 Oo waxaan ahay sida nin aan xoog lahayn,
\q1 
\v 5 Oo meydadka lagu dhex tuuray,
\q1 Sida kuwa la laayay oo xabaalaha yaal,
\q1 Oo aanad mar dambe soo xusuusnayn,
\q1 Kuwaas oo ah kuwa gacantaada ka go'ay.
\q1 
\v 6 Waxaad igu ridday yamayska ugu hooseeya,
\q1 Iyo gudcurka, iyo meelaha dhaadheer.
\q1 
\v 7 Cadhadaadii baa igu soo degtay,
\q1 Oo waxaad igu dhibtay hirarkaagii oo dhan. (Selaah)
\q1 
\v 8 Kuwii aan iqiin waad iga fogaysay,
\q1 Oo karaahiyaad iga dhigtay xaggooda.
\q1 Waa lay xidhay, oo sooma aan bixi karo.
\q1 
\v 9 Indhahaygu waxay la gudheen dhibaatada daraaddeed,
\q1 Rabbiyow, maalin kasta waan kuu yeedhay,
\q1 Oo gacmahaygana adigaan kuu hoorsaday.
\q1 
\v 10 Ma yaabab baad tusaysaa meydadka?
\q1 Kuwii dhintay miyey soo sara kacayaan oo ku ammaanayaan? (Selaah)
\q1 
\v 11 Raxmaddaada miyaa qabriga lagu sheegayaa?
\q1 Aaminnimadaadana miyaa halligaadda laga dhex sheegayaa?
\q1 
\v 12 Yaababkaaga miyaa gudcurka lagu ogaanayaa?
\q1 Xaqnimadaadana ma waxaa lagu ogaanayaa dalka illoobidda?
\q1 
\v 13 Laakiinse Rabbiyow, adigaan kuu qayshaday,
\q1 Oo baryootankayguna subaxduu hortaada imanayaa.
\q1 
\v 14 Rabbiyow, bal maxaad naftayda u xooraysaa?
\q1 Oo bal maxaad wejigaaga iiga qarinaysaa?
\q1 
\v 15 Waan dhibaataysnaa oo waxaan ku dhowaa inaan dhinto tan iyo yaraantaydiiba,
\q1 Intaad cabsidaada igu riddayna waan caataysnaa.
\q1 
\v 16 Cadhadaadii kululayd ayaa i kor martay,
\q1 Oo waxaa i baabbi'iyey waxyaalihii aad igu cabsiisay.
\q1 
\v 17 Maalintii oo dhan waxay hareerahayga ugu wareegsanaayeen sidii biyo oo kale,
\q1 Dhammaantood way i wada hareereeyeen.
\q1 
\v 18 Kii i jeclaa iyo saaxiibkayba waad iga fogaysay,
\q1 Oo kuwii aan iqiinna gudcur baad iga gelisay.
\c 89
\s2 Kanu waa sabuur Maskiil ah oo uu Eetaan kii reer Cesraax tiriyey.
\q1 
\v 1 Anigu weligayba waxaan ku gabyi doonaa Rabbiga waxyaalihiisa naxariista leh,
\q1 Oo aaminnimadaadana afkaygaan ka ab ka ab ku ogeysiinayaa.
\q1 
\v 2 Waayo, waxaan idhi, Naxariistu weligeedba way dhisnaan doontaa,
\q1 Oo aaminnimadaadana waxaad ku adkayn doontaa samooyinka qudhooda.
\q1 
\v 3 Axdi baan la dhigtay kii aan doortay,
\q1 Oo waxaan u dhaartay addoonkaygii Daa'uud, oo ku idhi,
\q1 
\v 4 Farcankaaga weligayba waan sii adkayn doonaa,
\q1 Oo carshigaaguna wuu dhisnaan doonaa tan iyo ka ab ka ab. (Selaah)
\q1 
\v 5 Rabbiyow, samooyinku waxay ammaani doonaan yaababkaaga,
\q1 Oo weliba aaminnimadaadana waxaa laga dhex sheegi doonaa shirka kuwa quduuska ah.
\q1 
\v 6 Waayo, bal yaa cirka ku jira oo Rabbiga lala simi karaa?
\q1 Bal yaase ku dhex jira wiilasha kuwa xoogga badan oo Rabbiga la mid ah,
\q1 
\v 7 Kaas oo ah Ilaaha ugu cabsida badan guddiga kuwa quduuska ah,
\q1 Oo waajibka tahay in kuwa hareerihiisa ku wareegsan oo dhammu ay ka cabsadaan.
\q1 
\v 8 Rabbiyow Ilaaha ciidammadow,
\q1 Bal yaa sidaada u xoog badan, Rabbiyow?
\q1 Aaminnimadaadu hareerahaagay ku wareegsan tahay.
\q1 
\v 9 Adigaa u taliya badda kibirkeeda,
\q1 Oo markii hirarkeedu kacaan adigaa dejiya.
\q1 
\v 10 Rahab waxaad u kala burburisay sidii mid la dilay,
\q1 Oo cadaawayaashaadiina waxaad ku kala firdhisay gacanta xooggaaga.
\q1 
\v 11 Samooyinka adigaa iska leh, dhulkana adigaa iska leh,
\q1 Dunida iyo waxaa ka buuxana adigaa aasaasay.
\q1 
\v 12 Woqooyi iyo koonfurba adigaa abuuray,
\q1 Taaboor iyo Xermoonba magacaagay ku reyreeyaan.
\q1 
\v 13 Adigu waxaad leedahay dhudhun itaal weyn,
\q1 Gacantaaduna way xoog badan tahay, midigtaaduna way sarraysaa.
\q1 
\v 14 Carshigaaga aasaaskiisu waxa weeye xaq iyo caddaalad,
\q1 Oo naxariista iyo runtuna way ku hor socdaan.
\q1 
\v 15 Waxaa barakaysan dadka yaqaan dhawaaqa farxadda leh,
\q1 Rabbiyow, waxay ku socdaan wejigaaga iftiinkiisa,
\q1 
\v 16 Maalinta oo dhan waxay ku reyreeyaan magacaaga,
\q1 Oo waxay ku sara marayaan xaqnimadaada.
\q1 
\v 17 Waayo, waxaad tahay ammaantii xooggooda,
\q1 Oo raallinimadaada daraaddeed ayaa geeskayaga kor loogu sarraysiin doonaa.
\q1 
\v 18 Waayo, gaashaankayaga waxaa iska leh Rabbiga,
\q1 Oo boqorkayagana waxaa iska leh Kan quduuska ah oo reer binu Israa'iil.
\q1 
\v 19 Markaas quduusiintaada waxaad kula hadashay muuqasho,
\q1 Oo waxaad ku tidhi, Waxaan caawimaad kor saaray mid xoog badan,
\q1 Oo waxaan sarraysiiyey mid dadka laga doortay.
\q1 
\v 20 Waxaan helay addoonkaygii Daa'uud ahaa,
\q1 Oo waxaan ku subkay saliiddaydii quduuska ahayd,
\q1 
\v 21 Oo gacantaydu isagay la jiri doontaa,
\q1 Dhudhunkayguna isaguu xoogayn doonaa.
\q1 
\v 22 Cadowgu ma dulmi doono,
\q1 Wiilka sharnimaduna ma dhibi doono.
\q1 
\v 23 Oo cadaawayaashiisa hortiisaan ku wada burburin doonaa,
\q1 Oo kuwa isaga necebna waan layn doonaa.
\q1 
\v 24 Laakiinse aaminnimadayda iyo naxariistaydu isagay la jiri doonaan,
\q1 Oo geeskiisana waxaa lagu sarraysiin doonaa magacayga.
\q1 
\v 25 Oo weliba gacantiisa waxaan ka sarraysiin doonaa badda,
\q1 Midigtiisana webiyaasha.
\q1 
\v 26 Aniguu ii qayshan doonaa, oo wuxuu odhan doonaa, Adigu waxaad tahay aabbahay,
\q1 Iyo Ilaahay, iyo dhagaxii weynaa oo badbaadadayda.
\q1 
\v 27 Oo weliba waxaan isaga ka dhigi doonaa curadkayga,
\q1 Oo wuxuu ahaan doonaa boqorrada dunida kan ugu wada sarreeya.
\q1 
\v 28 Weligayba waxaan isaga u hayn doonaa naxariistayda,
\q1 Oo axdigayguna isaguu ku sii adkaan doona.
\q1 
\v 29 Oo weliba farcankiisana waxaan ka dhigi doonaa mid weligiis waara,
\q1 Carshigiisana sida wakhtiga samada.
\q1 
\v 30 Carruurtiisu hadday sharcigayga ka tagaan,
\q1 Oo aanay ku socon xukummadayda,
\q1 
\v 31 Hadday qaynuunnadayda jebiyaan,
\q1 Oo aanay amarradayda dhawrin,
\q1 
\v 32 Markaas xadgudubkooda waxaan kaga abaalmarin doonaa ul,
\q1 Xumaantoodana jeedal.
\q1 
\v 33 Laakiinse naxariistayda oo dhan kama wada qaadi doono,
\q1 Aaminnimadayduna inay isaga gabto uma oggolaan doono.
\q1 
\v 34 Axdigayga ma jebin doono,
\q1 Oo wixii afkayga ka soo baxayna ma beddeli doono.
\q1 
\v 35 Mar baan waxaan ku dhaartay quduusnimadayda,
\q1 Oo Daa'uud been uma sheegi doono,
\q1 
\v 36 Farcankiisu weligiisuu waari doonaa,
\q1 Carshigiisuna wuxuu u waari doonaa sida qorraxda hortayda ka ifaysa.
\q1 
\v 37 Oo wuxuu weligiisba u sii jiri doonaa sida dayaxa,
\q1 Iyo sida markhaatiga daacadda ah oo cirka jooga. (Selaah)
\q1 
\v 38 Laakiinse adigu waad xoortay oo waad nacday,
\q1 Oo waxaad u cadhootay kaaga subkan.
\q1 
\v 39 Axdigii addoonkaaga waad nacday,
\q1 Oo taajkiisiina waad nijaasaysay oo dhulka ku tuurtay.
\q1 
\v 40 Deyrarkiisii oo dhan waad dumisay,
\q1 Oo qalcadihiisii oo dhanna waad burburisay.
\q1 
\v 41 Wax alla wixii jidka soo mara oo dhanba isagay dhacaan,
\q1 Oo derisyadiisana wuxuu u noqday cay.
\q1 
\v 42 Waxaad kor u qaadday midigtii kuwii dulmayay,
\q1 Cadaawayaashiisii oo dhanna waad ka farxisay.
\q1 
\v 43 Oo weliba afka seeftiisana dib baad u celisaa,
\q1 Isagiina kama aad dhigin inuu dagaalka ku sii adkaysto.
\q1 
\v 44 Iftiinkiisii waad demisay,
\q1 Carshigiisiina dhulkaad ku tuurtay.
\q1 
\v 45 Cimrigii dhallinyaranimadiisii waad soo gaabisay,
\q1 Oo waxaad isagii ka muujisay ceeb. (Selaah)
\q1 
\v 46 Rabbiyow, ilaa goormaad isqarin doontaa? Ma weligaa baa?
\q1 Oo ilaa goormay cadhadaadu sida dab u ololi doontaa?
\q1 
\v 47 Bal xusuuso sida wakhtigaygu u gaaban yahay,
\q1 Waayo, sidaad binu-aadmiga oo dhan u abuurtay micnedarnaa!
\q1 
\v 48 Bal waa ninkee kan iska noolaan doona isagoo aan dhimasho arkin,
\q1 Oo naftiisa ka samatabbixin doona xoogga She'ool? (Selaah)
\q1 
\v 49 Sayidow, meeday naxariistaadii hore,
\q1 Oo aad Daa'uud aaminnimadaada ugu dhaaratay?
\q1 
\v 50 Sayidow, bal soo xusuuso cayda addoommadaada,
\q1 Iyo sida aan laabta ugu sido cayda dadka badan oo dhan,
\q1 
\v 51 Rabbiyow, waana tii ay cadaawayaashaadu igu caayeen,
\q1 Oo waa tii ay ku caayeen tallaabooyinka kaaga subkan.
\q1 
\v 52 Mahad waxaa leh Rabbiga tan iyo weligiisba.
\q1 Aamiin, iyo aamiin.
\c 90
\s1 Kitaabka Afraad
\s2 Sabuurrada 90-106
\s2 Kanu waa baryootankii Muuse oo ahaa ninkii Ilaah.
\q1 
\v 1 Rabbiyow, tan iyo ka ab ka ab
\q1 Adigu waxaad noo ahayd meesha aannu degganaanno.
\q1 
\v 2 Intaan buuruhu dhalan ka hor,
\q1 Iyo intaanad samayn dhulka iyo dunida,
\q1 Iyo xataa weligeed iyo weligeedba adigu waxaad tahay Ilaah.
\q1 
\v 3 Dadka waxaad ku soo celisaa baabba',
\q1 Oo waxaad ku tidhaahdaa, Noqda, binu-aadmigow.
\q1 
\v 4 Waayo, kun sannadood waxay hortaada ku yihiin
\q1 Sida shalay oo kale markay dhammaadaan.
\q1 Oo waxay la mid yihiin sida wakhti la soo jeedo oo habeennimo.
\q1 
\v 5 Waxaad iyaga u qaaddaa sida daadku wax u qaado, oo iyagu waxa weeye sida hurdo oo kale,
\q1 Oo subaxdana waxay u baxaan sida doog oo kale.
\q1 
\v 6 Subaxda way cagaaraan, wayna soo baxaan,
\q1 Oo fiidkana waa la jaraa, wayna engegaan.
\q1 
\v 7 Waayo, annagu cadhadaadii baannu ku baabba'nay,
\q1 Oo waxaan ku dhibtoonnay xanaaqaagii.
\q1 
\v 8 Xumaatooyinkayagii waxaad dhigtay hortaada,
\q1 Oo dembiyadayadii qarsoonaana waxaad dhigtay iftiinka wejigaaga.
\q1 
\v 9 Waayo, maalmahayagii oo dhammu waxay nagu dhaafeen cadhadaada,
\q1 Oo cimrigayagiina wuxuu u dhammaaday sidii sheeko la sheegay.
\q1 
\v 10 Waayo, wakhtiga cimrigayagu waxa weeye toddobaatan sannadood,
\q1 Oo xataa hadduu xoog aawadiis ku sii dheeraado waa siddeetan sannadood,
\q1 Laakiinse faankiisu waa hawl iyo caloolxumo miidhan,
\q1 Waayo, haddiiba wuu iska dhammaadaa, oo annana waannu duulnaa.
\q1 
\v 11 Bal yaa yaqaan cadhadaada xooggeeda,
\q1 Iyo xanaaqaaga kaas oo waafaqsan cabsida kugu habboon in lagaa cabsado?
\q1 
\v 12 Haddaba na bar inaannu tirinno maalmaha cimrigayaga,
\q1 Si aannu u helno qalbi xigmad leh.
\q1 
\v 13 Rabbiyow, soo noqo, ilaa goormaad soo noqonaysaa?
\q1 Oo raalli ka ahow addoommadaada.
\q1 
\v 14 Aroorta naxariistaada naga dhergi,
\q1 Si aannu u rayrayno oo aannu u faraxsanaano maalmaha cimrigayaga oo dhan.
\q1 
\v 15 Nooga farxi intii ay ahaayeen maalmihii aad na dhibtay,
\q1 Iyo sannadihii aan sharka aragnay in le'eg.
\q1 
\v 16 Shuqulkaagu ha u muuqdo addoommadaada,
\q1 Ammaantaaduna carruurtooda.
\q1 
\v 17 Oo Rabbiga Ilaahayaga ah nicmadiisu ha na dul joogto,
\q1 Oo korkayaga ku adkee shuqulka gacmahayaga,
\q1 Haah, shuqulka gacmahayaga adkee.
\b
\c 91
\q1 
\v 1 Kan dega Ilaaha ugu sarreeya meeshiisa qarsoon
\q1 Wuxuu joogi doonaa hooska Qaadirka.
\q1 
\v 2 Waxaan Rabbiga ka odhan doonaa,
\q1 Isagu waa magangalkayga iyo qalcaddayda
\q1 Oo waa Ilaahayga aan isku halleeyo.
\q1 
\v 3 Waayo, wuxuu kaa samatabbixin doonaa dabinka ugaadhsadaha,
\q1 Iyo belaayada aad u xun.
\q1 
\v 4 Oo wuxuu kugu dedi doonaa baalashiisa,
\q1 Oo waxaad magangeli doontaa baadadkiisa,
\q1 Runtiisuna waxay tahay gaashaan iyo gabbaad.
\q1 
\v 5 Waa inaanad ka cabsan naxdinta habeennimada,
\q1 Iyo fallaadha dharaarnimada duulaysa toona,
\q1 
\v 6 Ama belaayada gudcurka ku socota,
\q1 Iyo halligaadda duhurka wax baabbi'isa.
\q1 
\v 7 Dhinacaaga waxaa ku dhici doona kun,
\q1 Midigtaadana waxaa ku ag dhici doona toban kun,
\q1 Innabase kuuma soo dhowaan doonto.
\q1 
\v 8 Laakiinse indhaha uun baad ku fiirin doontaa,
\q1 Oo waxaad arki doontaa kuwa sharka leh abaalgudkooda.
\q1 
\v 9 Waayo, waxaad tidhi, Rabbigu waa magangalkayga,
\q1 Oo Kan ugu sarreeya ayaa degmadayda ah.
\q1 
\v 10 Shar kuguma dhici doono,
\q1 Belaayona teendhadaada uma soo dhowaan doonto.
\q1 
\v 11 Waayo, isagu wuxuu malaa'igihiisa ku amri doonaa
\q1 Inay jidadkaaga oo dhan kugu ilaaliyaan.
\q1 
\v 12 Oo iyaguna gacmahooday sare kuugu qaban doonaan
\q1 Inaanay cagtaadu dhagax ku dhicin.
\q1 
\v 13 Libaaxa iyo jilbiska ayaad ku joogsan doontaa,
\q1 Oo waxaad ku tuman doontaa aaran libaax iyo abeesada.
\q1 
\v 14 Rabbigu wuxuu yidhi, Isagu aad buu ii jeclaaday, oo sidaas daraaddeed ayaan u samatabbixin doonaa,
\q1 Meel sare ayaan ku fadhiisin doonaa, maxaa yeelay, magacayguu yiqiin.
\q1 
\v 15 Wuu i baryi doonaa, oo waan u jawaabi doonaa,
\q1 Oo markuu dhibaataysan yahay, waan la jiri doonaa,
\q1 Oo waan samatabbixin doonaa, waanan murwayn doonaa.
\q1 
\v 16 Cimri dheer ayaan ka dhergin doonaa,
\q1 Oo waxaan tusi doonaa badbaadintayda.
\c 92
\s2 Kanu waa sabuur gabay ah oo loo tiriyey maalinta Sabtida.
\q1 
\v 1 Waa wanaagsan tahay in Rabbiga lagu mahadnaqo,
\q1 Iyo in magacaaga ammaan loogu gabyo, Ilaaha ugu sarreeyow,
\q1 
\v 2 Iyo in raxmaddaada aroorta la muujiyo,
\q1 Habeen kastana aaminnimadaada,
\q1 
\v 3 Iyo in loogu heeso alaabta muusikada oo tobanka xadhig leh, iyo shareeradda,
\q1 Iyo dhawaaqa kataaradda.
\q1 
\v 4 Waayo, Rabbiyow, waxaad igaga farxisay shuqulkaagii,
\q1 Oo shuqullada gacmahaagana waan ku guulaysan doonaa.
\q1 
\v 5 Rabbiyow, shuqulladaadu waaweynaa!
\q1 Oo fikirradaaduna aad bay u mool dheer yihiin.
\q1 
\v 6 Doqonku taas ma yaqaan,
\q1 Kii nacas ahuna ma garan karo.
\q1 
\v 7 Kuwa sharka lahu markii ay sida doog u soo baxaan,
\q1 Iyo markii xumaanfalayaasha oo dhammu ay barwaaqoobaan,
\q1 Waa in weligoodba la baabbi'iyo,
\q1 
\v 8 Laakiinse Rabbiyow, adigu waad sarraysaa weligaa iyo weligaaba.
\q1 
\v 9 Waayo, Rabbiyow, bal eeg cadaawayaashaada,
\q1 Bal eeg, cadaawayaashaadu way wada baabbi'i doonaane,
\q1 Oo xumaanfalayaasha oo dhammuna way kala firidhsanaan doonaan.
\q1 
\v 10 Laakiinse geeskayga waxaad u sarraysiisay sida geeska gisiga
\q1 Oo waxaa laygu subkay saliid cusub.
\q1 
\v 11 Indhahayguna waxay arkeen wixii aan cadaawayaashayda la jeclaa,
\q1 Oo dhegahayguna waxay maqleen wixii aan la jeclaa sharfalayaasha igu kaca.
\q1 
\v 12 Kii xaq ahu wuxuu u barwaaqoobi doonaa sida geed timireed,
\q1 Oo wuxuu u bixi doonaa sida geed kedar la yidhaahdo oo Lubnaan.
\q1 
\v 13 Kuwa guriga Rabbiga lagu dhex beeray
\q1 Waxay ku barwaaqoobi doonaan barxadaha Ilaahayaga.
\q1 
\v 14 Oo weliba midho bay dhali doonaan iyagoo gaboobay,
\q1 Oo waxaa ka buuxi doona muud, wayna cagaari doonaan,
\q1 
\v 15 Si ay u muujiyaan in Rabbigu qumman yahay,
\q1 Isagu waa dhagaxayga gabbaadka ah, oo xaqdarro kuma jirto.
\b
\c 93
\q1 
\v 1 Rabbigaa taliya, oo wuxuu huwan yahay haybad,
\q1 Rabbigu waa huwan yahay, oo wuxuu dhexda ku xidhay xoog,
\q1 Duniduna waxay u dhisan tahay si aan la dhaqaajin karin.
\q1 
\v 2 Carshigaagu wuxuu dhismay waa hore,
\q1 Oo adiguna waxaad jirtay tan iyo weligaa.
\q1 
\v 3 Rabbiyow, webiyadii kor bay u kaceen,
\q1 Webiyadii codkooday kor u qaadeen,
\q1 Oo webiyadii waxay kor u qaadeen hirarkoodii.
\q1 
\v 4 Biyaha badan codkooda,
\q1 Iyo mawjadaha badda oo waaweynba
\q1 Waxaa ka sii xoog badan Rabbiga sare.
\q1 
\v 5 Rabbiyow, markhaatifurkaagu waa hubaal,
\q1 Oo weligaaba waxaa gurigaaga ku habboon quduusnimo.
\b
\c 94
\q1 
\v 1 Rabbiyow, Ilaaha aargudashada lahow,
\q1 Ilaaha aargudashada lahow, soo iftiin.
\q1 
\v 2 Xaakinka dunidow, sara joogso,
\q1 Oo kuwa kibray abaalkooda mari.
\q1 
\v 3 Rabbiyow, kuwa sharka lahu ilaa goormay,
\q1 Kuwa sharka lahu ilaa goormay guulaysanayaan?
\q1 
\v 4 Way bulxamaan, oo kibir bay ku hadlaan,
\q1 Oo xumaanfalayaasha oo dhammu way faanaan.
\q1 
\v 5 Rabbiyow, iyagu waxay burburiyaan dadkaaga,
\q1 Oo dhaxalkaagay silciyaan.
\q1 
\v 6 Carmalka iyo shisheeyaha ayay laayaan,
\q1 Oo agoontay nafta ka qaadaan.
\q1 
\v 7 Oo waxay isyidhaahdaan, Waxan Rabbigu ma arki doono,
\q1 Oo Ilaaha reer Yacquubna kama fikiri doono.
\q1 
\v 8 Kuwiinna doqonnada ah oo dadka ku dhex jirow, fiirsada,
\q1 Oo kuwiinna nacasyada ahow, goormaad caqli yeelanaysaan?
\q1 
\v 9 Kii dhegta abuuray, sow wax maqli maayo?
\q1 Kii isha sameeyeyna, sow wax arki maayo?
\q1 
\v 10 Kan quruumaha edbiyaa, sow wax hagaajin maayo?
\q1 Kaasoo ah kan dadka aqoonta bara?
\q1 
\v 11 Rabbigu waa og yahay fikirrada binu-aadmigu
\q1 Inay micnela'aan yihiin.
\q1 
\v 12 Rabbiyow, waxaa barakaysan ninkii aad edbiso,
\q1 Oo aad sharcigaaga wax ka barto,
\q1 
\v 13 Si aad uga nasiso maalmaha belaayada
\q1 Inta kan sharka lahaa godka loo qodayo.
\q1 
\v 14 Waayo, Rabbigu dadkiisa xoori maayo,
\q1 Oo dhaxalkiisana dayrin maayo.
\q1 
\v 15 Waayo, garsooriddu waxay ku soo noqon doontaa xaqnimada,
\q1 Oo inta qalbigoodu qumman yahay oo dhammuna way raaci doonaan.
\q1 
\v 16 Bal yaa ii kacaya oo sharfalayaasha iga hor joogsanaya?
\q1 Oo yaa ii soo istaagaya oo xumaanfalayaasha iga celinaya?
\q1 
\v 17 Rabbigu haddaanu i caawin,
\q1 Hadda naftaydu waxay joogi lahayd meesha aamusnaanta.
\q1 
\v 18 Markaan idhi, Rabbiyow, cagtaydu waa simbiriirixanaysaa,
\q1 Waxaa kor ii qaadday naxariistaada.
\q1 
\v 19 Kolkay fikirro badan igu dhex jiraan
\q1 Waxaa naftayda ka farxiya qalbiqaboojintaada.
\q1 
\v 20 Carshiga sharnimadu ma xidhiidh buu kula yeelanayaa,
\q1 Kaasoo belaayo qaynuun ku qabanqaabiya?
\q1 
\v 21 Waxay dhammaantood isu soo wada urursadaan kan xaqa ah naftiisa,
\q1 Oo waxay xukumaan dhiig aan eed lahayn.
\q1 
\v 22 Laakiinse Rabbigu waxa weeye munaaraddayda,
\q1 Ilaahayna waa dhagaxii magangalkayga.
\q1 
\v 23 Oo wuxuu dushooda ku soo celiyey xumaatadoodii,
\q1 Oo wuxuu iyaga ku dhex baabbi'in doonaa sharnimadooda,
\q1 Rabbiga Ilaaheenna ahu wuu wada baabbi'in doonaa.
\b
\c 95
\q1 
\v 1 Kaalaya, aynu Rabbiga u gabaynee,
\q1 Oo aynu farxad ugu qaylinno dhagaxa badbaadadeenna.
\q1 
\v 2 Aynu hortiisa la nimaadno mahadnaq,
\q1 Oo aynu isaga farxad ugu qaylinno innagoo sabuurro ugu gabyayna.
\q1 
\v 3 Waayo, Rabbigu waa Ilaah weyn,
\q1 Waana boqor weyn oo ilaahyada oo dhan ka wada sarreeya.
\q1 
\v 4 Dhulka meelihiisa ugu mool dheeru gacantiisay ku jiraan,
\q1 Oo buuraha dheeraantoodana isagaa iska leh.
\q1 
\v 5 Baddana isagaa iska leh, oo isagaa sameeyey,
\q1 Oo dhulka engeganna isagaa gacmihiisa ku sameeyey.
\q1 
\v 6 Haddaba kaalaya aynu isaga caabudnee oo u sujuudnee,
\q1 Oo Rabbiga ina abuuray aan hortiisa ku jilba joogsanno,
\q1 
\v 7 Waayo, isagu waa Ilaaheen,
\q1 Oo innaguna waxaynu nahay dadkii daaqsintiisa, iyo idaha gacantiisa ku jira.
\q1 Bal maanta maad codkiisa maqashaan!
\q1 
\v 8 Qalbigiinna ha adkaynina, sidii markii Meriibaah la joogay,
\q1 Iyo sidii maalintii la joogay Masaah oo cidlada ku dhex taal,
\q1 
\v 9 Markay awowayaashiin i jirrabeen,
\q1 Oo ay i tijaabiyeen, oo ay shuqulkaygii arkeen.
\q1 
\v 10 Dadkii qarnigaas afartan sannadood waan u cadhaysnaa,
\q1 Oo waxaan idhi, Waa dad qalbigooda ka qaldama,
\q1 Oo iyagu ma ay aqoon jidadkaygii,
\q1 
\v 11 Sidaas daraaddeed anigoo cadhaysan waxaan ku dhaartay
\q1 Inaanay nasashadayda gelin.
\b
\c 96
\q1 
\v 1 Rabbiga gabay cusub ugu gabya,
\q1 Dadka dhulka oo dhammow, Rabbiga u gabya.
\q1 
\v 2 Rabbiga u gabya, oo magiciisa ammaana,
\q1 Oo badbaadintiisana muujiya maalin ka maalin.
\q1 
\v 3 Ammaantiisa quruumaha dhexdooda ka sheega,
\q1 Oo shuqulkiisa yaabka badanna dadyowga oo dhan ka dhex sheega.
\q1 
\v 4 Waayo, Rabbigu waa weyn yahay, waana mudan yahay in aad loo ammaano.
\q1 Isaga waa in laga cabsadaa in ka sii badan ilaahyada oo dhan.
\q1 
\v 5 Waayo, dadyowga ilaahyadooda oo dhammu waa sanamyo,
\q1 Laakiinse Rabbigu isagaa sameeyey samooyinka.
\q1 
\v 6 Sharaf iyo haybaduba hortiisay yaalliin,
\q1 Xoog iyo quruxuna meeshiisa quduuska ah ayay ku jiraan.
\q1 
\v 7 Dadka qolooyinkiisow, Rabbiga ammaana,
\q1 Waxaad Rabbiga ka sheegtaan ammaan iyo xoog.
\q1 
\v 8 Waxaad Rabbiga ka sheegtaan ammaanta magiciisu mudan yahay,
\q1 Qurbaan keena, oo barxadihiisa soo gala.
\q1 
\v 9 Rabbiga ku caabuda quruxda quduusnimada,
\q1 Dadka dhulka oo dhammow, hortiisa ku gariira.
\q1 
\v 10 Quruumaha dhexdooda waxaad ka tidhaahdaan, Rabbigaa taliya,
\q1 Oo duniduna waxay u dhisan tahay si aan la dhaqaajin karin,
\q1 Dadyowgana wuxuu ugu garsoori doonaa caddaalad.
\q1 
\v 11 Haddaba samooyinku ha farxeen, dhulkuna ha reyreeyo,
\q1 Oo badda iyo waxa ka buuxaaba, ha guuxeen,
\q1 
\v 12 Berriga iyo waxa ku jira oo dhammuna ha farxeen,
\q1 Oo markaasay dhirta duurka oo dhammu Rabbiga hortiisa ku gabyi doonaan farxad daraaddeed,
\q1 
\v 13 Waayo, isagu waa imanayaa,
\q1 Oo wuxuu u imanayaa inuu dunida xukumo.
\q1 Isagu wuxuu dunida ku xukumi doonaa xaqnimo,
\q1 Dadyowgana runtiisa.
\b
\c 97
\q1 
\v 1 Rabbigu isagaa taliya, haddaba dhulku ha reyreeyo,
\q1 Oo gasiiradaha badanuna ha wada farxeen.
\q1 
\v 2 Isaga waxaa ku wareegsan daruuro iyo gudcur,
\q1 Oo carshigiisana waxaa aasaas u ah xaqnimo iyo garsoorid.
\q1 
\v 3 Waxaa hortiisa socda dab,
\q1 Oo wuxuu wada gubaa cadaawayaashiisa ku wareegsan.
\q1 
\v 4 Hillaaciisii ayaa dunida iftiimiyey,
\q1 Dhulkuna wuu arkay, wuuna gariiray.
\q1 
\v 5 Buurihii waxay Rabbiga hortiisa ugu dhalaaleen sidii shamac oo kale,
\q1 Iyagoo hor jooga Sayidka dhulka oo dhan.
\q1 
\v 6 Samooyinku waxay sheegaan xaqnimadiisa,
\q1 Oo dadyowga oo dhammuna waxay arkaan ammaantiisa.
\q1 
\v 7 Kuwa sanamyada la qoray u adeega
\q1 Iyo weliba kuwa sanamyada ku faana oo dhammu ha ceeboobeen,
\q1 Ilaahyada oo dhammow, isaga caabuda.
\q1 
\v 8 Rabbiyow, Siyoon way maqashay, wayna faraxday,
\q1 Oo gabdhihii reer Yahuudahna waxay ku reyreeyeen garsooriddaadii.
\q1 
\v 9 Waayo, Rabbiyow, adigu waad ka sarraysaa dhulka oo dhan,
\q1 Oo aad baa lagaaga sarraysiiyey ilaahyada oo dhan.
\q1 
\v 10 Kuwiinna Rabbiga jeclow, sharka nebcaada,
\q1 Isagu wuxuu dhawraa nafaha quduusiintiisa,
\q1 Oo wuxuu iyaga ka samatabbixiyaa gacanta kuwa sharka leh.
\q1 
\v 11 Waxaa kuwa xaqa ah loo beeray iftiin,
\q1 Kuwa qalbigoodu qumman yahayna, farxad.
\q1 
\v 12 Kuwiinna xaqa ahow, Rabbiga ku farxa,
\q1 Oo magiciisa quduuska ah ku mahadnaqa.
\c 98
\s1 Sabuur
\q1 
\v 1 Rabbiga gabay cusub ugu gabya,
\q1 Waayo, isagu wuxuu sameeyey waxyaalo yaab badan,
\q1 Gacantiisa midig iyo dhudhunkiisa quduuska ahuna waxay keeneen badbaado.
\q1 
\v 2 Rabbigu wuxuu dadka ogeysiiyey badbaadadiisii,
\q1 Oo xaqnimadiisiina wuxuu bayaan ugu muujiyey quruumaha hortooda.
\q1 
\v 3 Oo wuxuu soo xusuustay naxariistiisii iyo aaminnimadiisii uu u qabay reerka binu Israa'iil,
\q1 Dadka dhulka darfihiisa jooga oo dhammu way wada arkeen badbaadinta Ilaaheenna.
\q1 
\v 4 Inta dhulka joogta oo dhammay, Rabbiga farxad ugu qayliya,
\q1 Dhawaaqa, oo farxad ku gabya, oo ammaan ku gabya.
\q1 
\v 5 Rabbiga ammaan ugu gabya idinkoo kataarad haysta,
\q1 Kataarad iyo codka heeska ugu gabya.
\q1 
\v 6 Boqorka Rabbiga ah hortiisa farxad kaga dhawaajiya
\q1 Turumbooyin iyo buunan.
\q1 
\v 7 Badda iyo waxa ka buuxaaba ha guuxeen,
\q1 Dunida iyo kuwa dhex deggan oo dhammuna ha dhawaaqeen,
\q1 
\v 8 Webiyadu ha sacbiyeen,
\q1 Oo buuruhuna dhammaantood farxad ha kaga gabyeen Rabbiga hortiisa,
\q1 
\v 9 Waayo, isagu wuxuu u imanayaa inuu dhulka xukumo,
\q1 Wuxuu dunida ku xukumi doonaa xaqnimo,
\q1 Dadyowgana caddaalad.
\b
\c 99
\q1 
\v 1 Rabbigu isagaa taliya, dadyowgu ha gariireen,
\q1 Isagu wuxuu ku fadhiyaa keruubiimta, dhulku ha dhaqdhaqaaqo.
\q1 
\v 2 Rabbigu Siyoon dhexdeeda waa ku weyn yahay,
\q1 Oo dadyowga oo dhanna wuu ka wada sarreeyaa.
\q1 
\v 3 Iyagu ha ammaaneen magacaaga weyn oo laga cabsado,
\q1 Isagu waa quduus.
\q1 
\v 4 Oo weliba boqorka xooggiisu wuxuu jecel yahay garsoorid,
\q1 Caddaalad baad adkaysaa,
\q1 Garsoorid iyo xaqnimo baad u samaysaa reer Yacquub.
\q1 
\v 5 Rabbiga Ilaaheenna ah sarraysiiya,
\q1 Oo meeshuu cagaha saartona ku sujuuda,
\q1 Isagu waa quduus.
\q1 
\v 6 Muuse iyo Haaruun waxay ka mid ahaayeen wadaaddadiisa,
\q1 Samuu'eelna wuxuu ka mid ahaa kuwa magiciisa u yeedha,
\q1 Iyagu waxay baryeen Rabbiga, oo isna wuu u jawaabay.
\q1 
\v 7 Wuxuu iyagii kala dhex hadlay tiirkii daruurta ahaa,
\q1 Iyana waxay xajiyeen markhaatifurkiisii iyo qaynuunkii uu iyaga siiyey.
\q1 
\v 8 Rabbiyow Ilaahayagiiyow, waad u jawaabtay,
\q1 Oo waxaad ahayd Ilaah iyaga cafiyey,
\q1 In kastoo aad falimahoodii ka aargoosatay.
\q1 
\v 9 Rabbiga Ilaaheenna ah sarraysiiya,
\q1 Oo isaga ku caabuda buurtiisa quduuska ah,
\q1 Waayo, Rabbiga Ilaaheenna ahu waa quduus.
\c 100
\s2 Kanu waa sabuur mahadnaqid ah.
\q1 
\v 1 Inta dhulka deggan oo dhammay, Rabbiga farxad ugu qayliya.
\q1 
\v 2 Rabbiga farxad ugu adeega,
\q1 Oo hortiisa gabay la kaalaya.
\q1 
\v 3 Ogaada in Rabbigu Ilaah yahay,
\q1 Waxaa ina sameeyey isaga, oo waxaynu nahay kuwiisii,
\q1 Waxaynu nahay dadkiisii iyo idihii daaqsintiisa.
\q1 
\v 4 Irdihiisa mahadnaqid la gala,
\q1 Barxadihiisana ammaan.
\q1 Isaga u mahadnaqa, oo magiciisa ammaana.
\q1 
\v 5 Waayo, Rabbigu waa wanaagsan yahay, naxariistiisuna weligeed way sii waartaa,
\q1 Aaminnimadiisuna tan iyo ka ab ka ab.
\c 101
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Waxaan ka gabyi doonaa naxariis iyo garsoorid,
\q1 Rabbiyow, waxaan kuugu gabyi doonaa ammaan.
\q1 
\v 2 Oo waxaan u dhawrsan doonaa si qumman oo caqliya,
\q1 Bal goormaad ii iman doontaa?
\q1 Waxaan gurigayga ku dhex socon doonaa qalbi qumman.
\q1 
\v 3 Indhahayga hortooda wax xun ma dhigi doono,
\q1 Waan necbahay kuwa leexda shuqulkooda,
\q1 Oo innaba iguma dhegi doono.
\q1 
\v 4 Qalbi qalloocanu wuu iga fogaan doonaa,
\q1 Oo innaba wax shar ah ma aqoon doono.
\q1 
\v 5 Kii qarsoodi u xanta deriskiisa, kaas waan baabbi'in doonaa,
\q1 Kii isla madax weyn oo qalbigiisu kibirsan yahayna uma dulqaadan doono.
\q1 
\v 6 Indhahaygu waxay la jiri doonaan kuwa aamiinka ah oo dalka deggan, si ay iila joogaan aawadeed,
\q1 Kii si qumman u socda ayaa ii adeegi doona.
\q1 
\v 7 Kii khiyaano ka shaqeeyaase gurigayga ma joogi doono,
\q1 Kii been ku hadlaana hortayda kuma xoogaysan doono.
\q1 
\v 8 Subax ilaa ka subax ayaan wada baabbi'in doonaa kuwa sharka leh oo dalka deggan oo dhan,
\q1 Si aan magaalada Rabbiga uga baabbi'iyo kuwa xumaanta ka shaqeeya oo dhan.
\c 102
\s2 Kanu waa mid dhibaataysan baryootankiis markuu taag darnaado, oo uu Rabbiga u cawdo.
\q1 
\v 1 Rabbiyow, baryootankayga maqal,
\q1 Qayladayduna ha ku soo gaadho.
\q1 
\v 2 Wejigaaga ha iga qarin maalinta aan dhibaataysnahay,
\q1 Dhegta ii dhig,
\q1 Oo maalinta aan ku baryo, dhaqso iigu soo jawaab.
\q1 
\v 3 Waayo, maalmahaygu waxay u dhammaadaan sida qiiq oo kale,
\q1 Oo lafahayguna waxay u gubtaan sida qori ololaya oo kale.
\q1 
\v 4 Wadnahayga wax baa lagu dhuftay, sida caws oo kalena wuu engegay,
\q1 Waayo, waan iska illoobaa inaan kibistayda cuno.
\q1 
\v 5 Codkii taahiddayda daraaddiis
\q1 Ayaa lafahaygu jidhkayga ku dhegaan.
\q1 
\v 6 Anigu waxaan la mid ahay haad cantalyaa ah oo cidlada joogta,
\q1 Oo waxaan la mid noqday haad guumays ah oo lamadegaanka dhex joogta.
\q1 
\v 7 Waan soo jeedaa, oo waxaan noqday
\q1 Sidii shimbir yar oo keligeed guri dhaladiis saaran.
\q1 
\v 8 Maalinta oo dhan cadaawayaashaydu way i caayaan,
\q1 Oo kuwa ii cadhaysanuna magacaygay ku caytamaan.
\q1 
\v 9 Waayo, dambas baan u cunay sidii kibis oo kale,
\q1 Oo cabniinkaygiina waxaan ku darsaday ilmadaydii.
\q1 
\v 10 Sababtuna waa dhirifkaagii iyo cadhadaadii aawadood,
\q1 Waayo, kor baad ii qaadday, dabadeedna waad i xoortay.
\q1 
\v 11 Cimrigaygu waa sida hoos sii libdhaya,
\q1 Oo waxaan u engegay sida caws oo kale.
\q1 
\v 12 Laakiinse Rabbiyow, adigu weligaaba waad sii jiri doontaa,
\q1 Oo waa lagu sii xusuusan doonaa ka ab ka ab.
\q1 
\v 13 Waad sara joogsan doontaa, oo Siyoon baad u naxariisan doontaa,
\q1 Waayo, waa wakhtiga iyada loo jixinjixo, haah, oo wakhtigii la ballamay waa yimid.
\q1 
\v 14 Waayo, addoommadaadu waxay u bogaan dhagaxyadeeda,
\q1 Oo waxay u jixinjixaan ciiddeeda.
\q1 
\v 15 Haddaba quruumuhu waxay ka cabsan doonaan magaca Rabbiga,
\q1 Boqorrada dunida oo dhammuna ammaantaada,
\q1 
\v 16 Waayo, Rabbigu wuxuu dhisay Siyoon,
\q1 Oo wuxuu ka dhex muuqday ammaantiisii,
\q1 
\v 17 Wuxuu u fiirsaday kuwa dan daraysan tukashadoodii,
\q1 Oo baryadoodiina ma uu quudhsan.
\q1 
\v 18 Tan waxaa loo qori doonaa farcanka soo socda,
\q1 Oo dad la abuuri doono ayaa Rabbiga ammaani doona.
\q1 
\v 19 Waayo, isagu wuxuu wax ka soo fiiriyey meeshiisa sare oo quduuska ah,
\q1 Rabbigu dhulkuu ka soo eegay samada,
\q1 
\v 20 Inuu maqlo taaha maxbuuska,
\q1 Iyo inuu sii daayo kuwa dilka lagu xukumay,
\q1 
\v 21 Si dadku magaca Rabbiga uga sheego Siyoon dhexdeeda,
\q1 Ammaantiisana Yeruusaalem dhexdeeda,
\q1 
\v 22 Markii dadyowgu isu soo wada ururaan,
\q1 Iyo xataa boqortooyooyinkuba, inay Rabbiga u adeegaan aawadeed.
\q1 
\v 23 Isagu xooggayguu ku dhex dhimay jidka,
\q1 Oo cimrigaygiina wuu gaabiyey.
\q1 
\v 24 Anigu waxaan idhi, Ilaahayow, ha i sii qaadin cimrigayga oo badh ah,
\q1 Sannadahaagu waxay sii waaraan tan iyo ka ab ka ab.
\q1 
\v 25 Waa hore ayaad aasaaska dhulka dhigtay,
\q1 Samooyinkuna waa shuqulkii gacmahaaga.
\q1 
\v 26 Iyagu way baabbi'i doonaan, adiguse waad sii waari doontaa,
\q1 Haah, oo kulligood waxay u duugoobi doonaan sida dhar oo kale,
\q1 Oo waxaad iyaga u beddeli doontaa sida maro oo kale, wayna beddelmi doonaan,
\q1 
\v 27 Laakiinse adigu isku si uun baad tahay had iyo goorba,
\q1 Oo sannadahaaguna ma idlaan doonaan.
\q1 
\v 28 Carruurta addoommadaadu way sii jiri doonaan,
\q1 Oo farcankooduna hortaaday ku xoogaysan doonaan.
\c 103
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Naftaydoy, Rabbiga ammaan,
\q1 Oo inta igu jirta oo dhammay, ammaana magiciisa quduuska ah.
\q1 
\v 2 Naftaydoy, Rabbiga ammaan,
\q1 Oo ha illoobin wanaagga uu kuu sameeyo oo dhan.
\q1 
\v 3 Isagaa kaa cafiya dembiyadaada oo dhan,
\q1 Oo kaa bogsiiya cudurradaada oo dhan,
\q1 
\v 4 Oo naftaada ka badbaadiya halligaadda,
\q1 Oo raxmad iyo naxariis kugu barakeeya,
\q1 
\v 5 Oo kaa dhergiya waxyaalaha wanwanaagsan,
\q1 Si ay dhallinyaranimadaadu ugu cusboonaato sida gorgorka oo kale.
\q1 
\v 6 Rabbigu wuxuu falaa xaqnimo,
\q1 Gar buuna u gooyaa kuwa dulman oo dhan.
\q1 
\v 7 Isagu wuxuu Muuse garansiiyey jidadkiisii,
\q1 Reer binu Israa'iilna falimihiisii.
\q1 
\v 8 Rabbigu waa raxmad badan yahay, waana nimco miidhan,
\q1 Cadho wuu u gaabiyaa, waana naxariis badan yahay.
\q1 
\v 9 Isagu had iyo goor wax canaanan maayo,
\q1 Oo sii cadhaysnaan maayo ilaa weligiis.
\q1 
\v 10 Isagu inoolama uu macaamiloon sidii dembiyadeennu ahaayeen,
\q1 Oo inooguma uu abaalmarin sidii xumaatooyinkeennu ahaayeen.
\q1 
\v 11 Waayo, sida samadu dhulka uga sarrayso,
\q1 Sidaas oo kalaa naxariistiisu ugu weyn tahay kuwa isaga ka cabsada.
\q1 
\v 12 Sida barigu uga fog yahay galbeedka,
\q1 Sidaas oo kaluu xadgudubkeennii inooga fogeeyey.
\q1 
\v 13 Sida aabbe carruurtiisa ugu naxo oo kale
\q1 Ayaa Rabbigu ugu naxaa kuwa isaga ka cabsada.
\q1 
\v 14 Waayo, abuuristeennuu og yahay,
\q1 Oo wuu xusuusan yahay inaan innagu ciid nahay.
\q1 
\v 15 Laakiinse dadka cimrigiisu waa sida doog oo kale,
\q1 Sida ubaxa berrinka ayuu u barwaaqoobaa.
\q1 
\v 16 Waayo, dabayl baa dul marta, wuuna baabba'aa,
\q1 Oo meeshiisiina mar dambe ma aqoon doonto.
\q1 
\v 17 Laakiinse Rabbigu wuxuu u naxariistaa kuwa isaga ka cabsada weligiis iyo weligiisba,
\q1 Oo xaqnimadiisuna waxay la jirtaa carruurta carruurteeda,
\q1 
\v 18 Kuwaas oo ah kuwa axdigiisa xajiya
\q1 Iyo kuwa amarradiisa xusuusta oo wada yeela.
\q1 
\v 19 Rabbigu carshigiisii wuxuu ka dhistay samooyinka,
\q1 Oo boqortooyadiisuna wax walbay u talisaa.
\q1 
\v 20 Malaa'igihiisa xoogga badan oo eraygiisa oofiya
\q1 Oo codka hadalkiisa maqlow,
\q1 Rabbiga ammaana.
\q1 
\v 21 Rabbiga ammaana, ciidammadiisa oo dhammow,
\q1 Idinkoo ah midiidinyadiisa wuxuu doonayo sameeyow,
\q1 
\v 22 Shuqulladiisa oo dhammow, Rabbiga ku ammaana
\q1 Meel kasta oo dowladnimadiisa ahba,
\q1 Naftaydoy, Rabbiga ammaan.
\b
\c 104
\q1 
\v 1 Naftaydoy, Rabbiga ammaan.
\q1 Rabbiyow Ilaahayow, aad baad u weyn tahay,
\q1 Oo waxaad huwan tahay murwad iyo haybad.
\q1 
\v 2 Waxaad sida maro u huwataa nuur,
\q1 Oo samooyinkana waxaad u kala bixisaa sida daah oo kale.
\q1 
\v 3 Waxa qolkaaga saqafka u hayana waxaad dhigtaa biyaha dhexdooda,
\q1 Daruurahana waxaad ka dhigataa gaadhifaras,
\q1 Oo waxaad ku kor socotaa dabaysha baalasheeda,
\q1 
\v 4 Waxaad dabaysha ka dhigataa wargeeyayaashaada,
\q1 Oo waxaad midiidinyadaada ka dhigataa dab ololaya,
\q1 
\v 5 Adigaa dhigay aasaaska dhulka,
\q1 Si aanu weligiis u dhaqdhaqaaqin.
\q1 
\v 6 Waxaad ku dabooshay mool sidii dhar oo kale,
\q1 Biyihiina waxay joogsadeen buuraha korkooda.
\q1 
\v 7 Canaantaadii ayay ku carareen,
\q1 Oo codkii onkodkaaga ayay haddiiba ka baxsadeen,
\q1 
\v 8 Waxay kor u fuuleen buuraha, oo waxay hoos ugu dhaadheceen dooxooyinka,
\q1 Ilaa meeshii aad u samaysay.
\q1 
\v 9 Waxaad iyaga u dhigtay xudduud aanay soo dhaafin,
\q1 Si aanay mar kale u noqon oo aanay dhulka u daboolin.
\q1 
\v 10 Isagu dooxooyinka wuxuu ku soo daayaa ilo,
\q1 Iyana waxay durduraan buuraha dhexdooda,
\q1 
\v 11 Waxay waraabiyaan xayawaanka duurka jooga oo dhan,
\q1 Oo dameerdibadeedyaduna way harraad beelaan.
\q1 
\v 12 Haadda samadu iyagay ag degganaadaan,
\q1 Oo waxay ka dhex gabyaan laamaha.
\q1 
\v 13 Buuraha wuxuu ka waraabiyaa qolalkiisa,
\q1 Dhulkuna wuxuu ka dheregsan yahay midhihii shuqulladaada.
\q1 
\v 14 Isagu wuxuu ka dhigaa in dooggu xoolaha u soo baxo,
\q1 Oo geedaha yaryarna wuxuu u soo bixiyey in dadku ku isticmaalo,
\q1 Inuu dhulka cunto ka soo bixiyo,
\q1 
\v 15 Iyo khamri ka farxiya dadka qalbigiisa,
\q1 Iyo saliid uu wejiga ku dhaashado,
\q1 Iyo kibis qalbiga dadka xoogaysa.
\q1 
\v 16 Rabbiga dhirtiisu waa dheregsan tahay,
\q1 Kuwaas oo ah geedaha kedar la yidhaahdo oo Lubnaan oo uu isagu beeray,
\q1 
\v 17 Kuwaas oo ah meesha shimbirruhu buulkooda ay ka samaystaan,
\q1 Xuurtuna gurigeeda waxay ka kor dhisataa geedaha waaweyn.
\q1 
\v 18 Buuraha dhaadheer waxaa leh riyaha dibadda,
\q1 Dhagaxyada waaweynuna waxay gabbaad u yihiin walooyinka.
\q1 
\v 19 Isagu dayaxa wuxuu u sameeyey xilliyo,
\q1 Oo qorraxduna dhicitinkeeda way taqaan.
\q1 
\v 20 Waxaad samaysaa gudcur, oo habeen baa yimaada,
\q1 Markaasay xayawaanka duurku soo wada baxaan.
\q1 
\v 21 Libaaxyada aaranka ahu waxay u ciyaan ugaadhsigooda,
\q1 Cuntadoodana waxay ka sugaan xagga Ilaah.
\q1 
\v 22 Oo kolkii qorraxdu soo baxdana way noqdaan,
\q1 Oo waxay iska seexdaan godadkooda.
\q1 
\v 23 Dadku waa u soo baxaa shuqulkiisa
\q1 Iyo hawshiisa ilaa tan iyo fiidka.
\q1 
\v 24 Rabbiyow, shuqulladaadu tiro badanaa!
\q1 Kulligoodna xigmad baad ku samaysay,
\q1 Dhulka waxaa ka buuxa hodantinimadaada.
\q1 
\v 25 Halkoo waxaa ku taal bad weyn oo ballaadhan,
\q1 Gudaheedana waxaa ku jira waxyaalo gurguurta oo aan la tirin karin,
\q1 Iyo xayawaan waaweyn iyo kuwo yaryarba.
\q1 
\v 26 Halkaas waxaa ku socda doonniyo,
\q1 Oo waxaa halkaas yaal bahal badeed oo Lewiiyaataan la odhan jiray oo aad u abuurtay inuu ku dhex cayaaro.
\q1 
\v 27 Kuwaas oo dhammu adigay kaa sugaan,
\q1 Inaad cuntadooda siiso wakhti ku habboon.
\q1 
\v 28 Oo waxaad iyaga siiso ayay isu soo urursadaan,
\q1 Gacantaadaad furtaa oo waxay ka dhergaan waxyaalo wanaagsan.
\q1 
\v 29 Wejigaagaad qarisaa, oo way dhibtoodaan,
\q1 Naftoodaad ka qaaddaa oo way dhintaan,
\q1 Oo waxay ku noqdaan ciiddoodii.
\q1 
\v 30 Waxaad soo dirtaa ruuxaaga, kolkaasay iyagu abuurmaan,
\q1 Dhulkana waad cusboonaysiisaa.
\q1 
\v 31 Rabbiga ammaantiisu ha sii raagto weligeedba,
\q1 Oo Rabbigu ha ku reyreeyo shuqulladiisa.
\q1 
\v 32 Isagu dhulkuu eegaa, oo wuu gariiraa,
\q1 Wuxuu taabtaa buuraha, oo way qiiqaan.
\q1 
\v 33 Intaan noolahay oo dhan ayaan Rabbiga u gabyi doonaa,
\q1 Oo Ilaahay ayaan ammaan ugu gabyi doonaa intaan jiro oo dhan.
\q1 
\v 34 Fikirkaygu isaga ha u macaanaado,
\q1 Rabbigaan ku rayrayn doonaa.
\q1 
\v 35 Dembilayaashu dhulka ha ka baabbe'een,
\q1 Oo kuwa sharka lahuna yaanay mar dambe sii jirin.
\q1 Naftaydoy, Rabbiga ammaan.
\q1 Rabbiga ammaana.
\b
\c 105
\q1 
\v 1 Rabbiga ku mahadnaqa, oo magiciisa ku barya,
\q1 Falimihiisana dadyowga ka dhex sheega.
\q1 
\v 2 Isaga u gabya, oo ammaan ugu gabya,
\q1 Shuqulladiisa yaabka badan oo dhanna ka hadla.
\q1 
\v 3 Ku faana magiciisa quduuska ah,
\q1 Kuwa Rabbiga doondoona qalbigoodu ha reyreeyo.
\q1 
\v 4 Rabbiga iyo xooggiisa doondoona,
\q1 Oo weligiinba wejigiisa doondoona.
\q1 
\v 5 Xusuusta shuqulladiisii yaabka badnaa oo uu sameeyey,
\q1 Iyo cajaa'ibyadiisii iyo xukummadii afkiisa,
\q1 
\v 6 Kuwiinna farcankii addoonkiisii Ibraahim ahow,
\q1 Kuwiisa uu doortay oo reer Yacquub ahow.
\q1 
\v 7 Isagu waa Rabbiga Ilaaheenna ah,
\q1 Xukummadiisuna waxay ku jiraan dhulka oo dhan.
\q1 
\v 8 Axdigiisuu soo xusuustay weligiisba,
\q1 Kaasoo ah hadalkiisii uu kun farcan ku amray,
\q1 
\v 9 Kaasu waa axdigii uu Ibraahim la dhigtay,
\q1 Oo uu Isxaaq ugu dhaartay,
\q1 
\v 10 Oo isla kaas wuxuu u adkeeyey oo qaynuun uga dhigay Yacquub,
\q1 Oo Israa'iilna wuxuu uga dhigay axdi weligiis jiraya,
\q1 
\v 11 Oo wuxuu ku yidhi, Dalka Kancaan waxaan kuu siinayaa
\q1 Inuu ahaado qaybtii dhaxalkiinna,
\q1 
\v 12 Markay dad tiro yar ahaayeen,
\q1 Oo ay aad u yaraayeen, qariibna dalka ku ahaayeen,
\q1 
\v 13 Oo iyagu quruunba quruun bay uga bexeen,
\q1 Oo intay boqortooyo ka tageen ayay dad kale u gudbeen.
\q1 
\v 14 Isagu ninna uma oggolaanin inuu wax yeelo,
\q1 Haah, oo daraaddood ayuu boqorro u canaantay,
\q1 
\v 15 Oo wuxuu ku yidhi, Ha taabanina kuwayga subkan,
\q1 Oo nebiyadaydana waxba ha yeelina.
\q1 
\v 16 Dhulkiina abaar buu ugu yeedhay inay ku dhacdo,
\q1 Ushii cuntada oo ay ku tiirsanaayeen oo dhanna wuu wada jebiyey.
\q1 
\v 17 Oo nin buu iyaga ka sii hor diray,
\q1 Kaas oo ahaa Yuusuf oo loo iibiyey addoon ahaan.
\q1 
\v 18 Cagihiisii waxay ku xanuujiyeen bircago,
\q1 Oo naftiisii waxay gashay silsilado bir ah,
\q1 
\v 19 Ilaa wakhtigii eraygiisu noqday
\q1 Eraygii Rabbiga ayaa isaga tijaabiyey.
\q1 
\v 20 Markaasaa boqorkii u cid diray oo furay,
\q1 Kaas oo ahaa taliyihii dadyowga, wuuna sii daayay.
\q1 
\v 21 Oo wuxuu isagii ka dhigay sayidkii reerkiisa,
\q1 Iyo taliyihii maalkiisa oo dhan,
\q1 
\v 22 Inuu amiirradiisa xidho markuu doonayoba,
\q1 Oo uu odayaashiisana xigmad baro.
\q1 
\v 23 Israa'iilna wuxuu yimid dalkii Masar,
\q1 Yacquubna wuxuu qariib ahaan u joogay dalkii Xaam.
\q1 
\v 24 Oo isagu dadkiisii aad buu u badiyey,
\q1 Oo wuxuu ka dhigay inay ka xoog bataan cadaawayaashoodii.
\q1 
\v 25 Qalbigoodii wuxuu u beddelay si ay dadkiisa u nebcaadaan,
\q1 Iyo si ay addoommadiisa u khiyaaneeyaan.
\q1 
\v 26 Wuxuu u soo diray addoonkiisii Muuse,
\q1 Iyo Haaruun oo uu doortay.
\q1 
\v 27 Oo waxay dhexdooda ku sameeyeen calaamooyinkiisii,
\q1 Oo dalkii Xaamna waxay ku sameeyeen yaabab.
\q1 
\v 28 Wuxuu u soo diray gudcur, dalkiina gudcur buu ka dhigay,
\q1 Oo iyana hadalkiisii kuma ay caasiyoobin.
\q1 
\v 29 Biyahoodii wuxuu u beddelay dhiig,
\q1 Oo kalluunkoodiina wuu wada laayay.
\q1 
\v 30 Rahyo waa ku bateen dhulkoodii
\q1 Iyo qolalka boqorkoodiiba.
\q1 
\v 31 Isagu waa hadlay, markaasaa waddankoodii oo dhan
\q1 Waxaa yimid duqsi faro badan iyo injir.
\q1 
\v 32 Oo roob ahaan wuxuu u siiyey roob dhagaxyaale,
\q1 Dalkoodiina wuxuu ku soo daayay dab ololaya.
\q1 
\v 33 Wuxuu wax ku dhuftay geedahoodii canabka ahaa iyo geedahoodii berdaha ahaaba,
\q1 Oo dhirtii waddankooda ku tiilna wuu jejebiyey.
\q1 
\v 34 Wuu hadlay, markaasaa waxaa yimid ayax,
\q1 Iyo diir aan la tirin karin,
\q1 
\v 35 Oo waxay wada cuneen geedo yaryar oo kasta oo dalkooda ku yiil,
\q1 Wayna dhammaysteen midhihii dhulkooda.
\q1 
\v 36 Oo weliba wuxuu wada laayay curadyadii dalkooda oo dhan,
\q1 Kuwaas oo ahaa bilowgii xooggooda.
\q1 
\v 37 Oo wuxuu dibadda u bixiyey reer binu Israa'iil iyagoo wata lacag iyo dahab,
\q1 Oo qabiilooyinkiisiina mid taagdarani kuma uu jirin.
\q1 
\v 38 Reer Masarna way ku farxeen kolkay ambabbexeen,
\q1 Waayo, cabsidoodii baa ku dhacday.
\q1 
\v 39 Wuxuu korkooda ku kala bixiyey daruur inay qariso,
\q1 Iyo dab habeenkii iftiin u noqda.
\q1 
\v 40 Wax bay weyddiisteen, markaasuu u keenay digaag duur,
\q1 Oo wuxuu ka dhergiyey kibistii samada.
\q1 
\v 41 Dhagaxii ayuu dillaaciyey, markaasay biyo ka soo buqdeen,
\q1 Oo meelihii engegnaa ayay ku durdureen sidii webi oo kale.
\q1 
\v 42 Waayo, wuxuu soo xusuustay eraygiisii quduuska ahaa,
\q1 Oo uu kula hadlay addoonkiisii Ibraahim.
\q1 
\v 43 Dadkiisiina wuxuu soo bixiyey iyagoo faraxsan,
\q1 Kuwii uu doortayna iyagoo gabyaya.
\q1 
\v 44 Oo wuxuu iyagii siiyey dalalkii quruumaha,
\q1 Oo iyana waxay hanti ahaan u qaadeen waxay dadyowgu ku hawshoodeen,
\q1 
\v 45 Inay amarradiisa dhawraan,
\q1 Oo ay qaynuunnadiisa xajiyaan.
\q1 Rabbiga ammaana.
\b
\c 106
\q1 
\v 1 Rabbiga ammaana.
\q1 Rabbiga ku mahadnaqa, waayo, isagu waa wanaagsan yahay,
\q1 Oo naxariistiisuna weligeedba way waartaa.
\q1 
\v 2 Yaa sheegi kara Rabbiga falimihiisa waaweyn?
\q1 Amase yaa muujin kara ammaantiisa oo dhan?
\q1 
\v 3 Waxaa barakaysan kuwa xukunka dhawra,
\q1 Oo xaqnimada ka shaqeeya wakhti kastaba.
\q1 
\v 4 Rabbiyow, igu soo xusuuso naxariista aad dadkaaga u qabto,
\q1 Oo igu soo booqo badbaadintaada,
\q1 
\v 5 Inaan arko kuwaaga aad dooratay barwaaqadooda,
\q1 Oo aan ku reyreeyo farxadda quruuntaada,
\q1 Iyo inaan la faano dadka dhaxalkaaga ah.
\q1 
\v 6 Waxaannu la dembaabnay awowayaashayo,
\q1 Xumaanna waannu samaynay, oo si shar ah ayaannu wax u samaynay.
\q1 
\v 7 Awowayaashayo ma ay garan yaababkii aad dalka Masar ku samaysay.
\q1 Oo ma ay xusuusan badnaantii naxariistaada,
\q1 Laakiinse way ku ag caasiyoobeen badda, taas oo ah Badda Cas.
\q1 
\v 8 Habase yeeshee wuxuu iyagii u badbaadiyey magiciisa daraaddiis,
\q1 Inuu xooggiisa weyn ka dhigo mid la yaqaan.
\q1 
\v 9 Oo weliba Badda Cas ayuu canaantay, kolkaasay engegtay,
\q1 Sidaas daraaddeed wuxuu iyagii ku hor kacay moolka dhexdiisii sidii iyagoo maraya cidlada dhexdeeda.
\q1 
\v 10 Oo wuxuu iyagii ka badbaadiyey kii iyaga necbaa gacantiisii,
\q1 Oo wuxuu ka furtay gacantii cadowga.
\q1 
\v 11 Biyihiina waxay qariyeen cadaawayaashoodii.
\q1 Xataa mid qudhahu kama hadhin.
\q1 
\v 12 Markaasay rumaysteen erayadiisii,
\q1 Oo ammaantiisay ku gabyeen.
\q1 
\v 13 Haddiiba way illoobeen shuqulladiisii,
\q1 Oo taladiisiina ma ay sugin,
\q1 
\v 14 Laakiinse aad bay wax u damacsanaayeen intay cidladii dhex joogeen,
\q1 Oo Ilaahna way ku jirrabeen lamadegaanka dhexdiisa.
\q1 
\v 15 Oo isna wuxuu siiyey wixii ay weyddiisteen,
\q1 Laakiinse wuxuu naftoodii u soo diray caatow.
\q1 
\v 16 Oo weliba waxay xerada dhexdeedii kaga hinaaseen Muuse
\q1 Iyo Haaruun oo ahaa Rabbiga kiisii quduuska ahaa.
\q1 
\v 17 Oo dhulkiina waa kala furmay oo wuxuu liqay Daataan,
\q1 Oo weliba wuxuu qariyey Abiiraam guutadiisii.
\q1 
\v 18 Oo guutadoodiina dab baa ka dhex shidmay,
\q1 Ololkiina wuxuu wada gubay kuwii shar lahaa.
\q1 
\v 19 Waxay samaysteen weyl markii ay Xoreeb joogeen,
\q1 Oo waxay caabudeen sanam la shubay.
\q1 
\v 20 Oo sidaasay ammaantoodii ugu beddeleen
\q1 Dibi caws daaqa ekaantiis.
\q1 
\v 21 Waxay illoobeen Ilaahii Badbaadiyahooda ahaa,
\q1 Oo waxyaalo waaweyn ku sameeyey dalkii Masar,
\q1 
\v 22 Shuqullo yaab badanna ku sameeyey dalkii Xaam,
\q1 Waxyaalo cabsi badanna ku sameeyey Badda Cas agteeda.
\q1 
\v 23 Sidaas daraaddeed isagu wuxuu yidhi, Waan baabbi'inayaa.
\q1 Laakiinse Muuse oo ahaa kii uu doortay ayaa hortiisa u istaagay xidhiidhla'aantii u dhexaysay,
\q1 Inuu Ilaah cadhadiisa ka leexiyo aawadeed si aanu iyaga u baabbi'in.
\q1 
\v 24 Waxay quudhsadeen dalkii wacnaa,
\q1 Mana ay rumaysan eraygiisii,
\q1 
\v 25 Laakiinse teendhooyinkooday ku dhex gunuunaceen,
\q1 Mana ay dhegaysan codkii Rabbiga.
\q1 
\v 26 Sidaas daraaddeed gacantiisuu kor ugu taagay iyaga,
\q1 Oo wuxuu ku dhaartay inuu iyaga cidladii ku afgembiyo,
\q1 
\v 27 Iyo inuu farcankooda ku afgembiyo quruumaha dhexdooda,
\q1 Oo uu iyaga ku kala firdhiyo dalalka.
\q1 
\v 28 Oo weliba waxay isku dareen Bacal Fecoor,
\q1 Oo waxay cuneen allabarigii kuwii dhintay.
\q1 
\v 29 Sidaasay isaga shuqulladoodii ugaga xanaajiyeen,
\q1 Markaasay belaayadu ka dhex dillacday.
\q1 
\v 30 Markaasaa waxaa istaagay Fiinexaas, oo wuxuu ku soo dejiyey xukun,
\q1 Oo sidaasaa belaayada lagu joojiyey.
\q1 
\v 31 Oo taas waxaa isagii loogu tiriyey xaqnimo
\q1 U sii waaraysa qarni kasta iyo weligeedba.
\q1 
\v 32 Oo weliba waxay isagii kaga cadhaysiiyeen biyihii Meriibaah agtooda,
\q1 Sidaas daraaddeed dhib baa ku dhacday Muuse iyaga aawadood,
\q1 
\v 33 Maxaa yeelay, iyagu waxay ku caasiyoobeen ruuxiisii,
\q1 Kolkaasuu fiirola'aan u hadlay.
\q1 
\v 34 Dadyowgiina uma ay baabbi'in,
\q1 Sidii Rabbigu ugu amray iyaga,
\q1 
\v 35 Laakiinse iyagu waxay ku dhex qasmeen quruumihii,
\q1 Shuqulladoodiina way barteen,
\q1 
\v 36 Oo waxay u adeegeen sanamyadoodii,
\q1 Kuwaasoo iyaga dabin u noqday,
\q1 
\v 37 Haah, oo waxay wiilashoodii iyo gabdhahoodii allabari ahaan ugu qaleen jinniyo,
\q1 
\v 38 Oo waxay daadiyeen dhiig aan eed lahayn, kaasoo ah dhiiggii wiilashooda iyo kii gabdhahooda
\q1 Oo ay allabari ahaan ugu qaleen sanamyadii reer Kancaan,
\q1 Oo dalkiina wuxuu ku nijaasoobay dhiig.
\q1 
\v 39 Haddaba sidaasay shuqulladoodii ugu nijaasoobeen,
\q1 Oo falimahoodii ayay ku caasiyoobeen sidii dhillo oo kale.
\q1 
\v 40 Sidaas daraaddeed ayaa Rabbigu dadkiisii aad ugu cadhooday,
\q1 Oo isna wuxuu karhay dadkii dhaxalkiisii ahaa.
\q1 
\v 41 Oo wuxuu iyagii u gacangeliyey quruumaha,
\q1 Oo kuwii iyaga necbaa ayaa u taliyey.
\q1 
\v 42 Oo weliba cadaawayaashoodii ayaa dulmay,
\q1 Oo iyagoo gacantooda ka hooseeya ayay addoonsadeen.
\q1 
\v 43 Marar badan ayuu samatabbixiyey,
\q1 Laakiinse waxay ku caasiyoobeen taladoodii,
\q1 Oo waxaa lagu hoosaysiiyey dembigoodii.
\q1 
\v 44 Habase yeeshee isagu waa ka fiirsaday cidhiidhigoodii,
\q1 Markuu qayladoodii maqlay,
\q1 
\v 45 Oo wuxuu iyagii u soo xusuustay axdigiisii,
\q1 Kolkaasuu naxariistiisa badan aawadeed u qoomamooday.
\q1 
\v 46 Oo weliba wuxuu ka dhigay inay
\q1 Kuwii iyaga maxaabiis ahaanta u kaxaystay oo dhammu u naxaan.
\q1 
\v 47 Rabbiyow Ilaahayagow, na badbaadi,
\q1 Oo quruumaha naga soo dhex ururi,
\q1 Si aannu magacaaga quduuska ah ugu mahadnaqno,
\q1 Oo aannu ammaantaada ugu guulaysanno.
\q1 
\v 48 Waxaa mahad leh Rabbiga ah Ilaaha reer binu Israa'iil
\q1 Tan iyo weligiis iyo weligiisba.
\q1 Oo dadka oo dhammu ha yidhaahdo, Aamiin.
\q1 Rabbiga ammaana.
\c 107
\ms1 Kitaabka Shanaad
\mr Sabuurrada 107-150
\q1 
\v 1 Rabbiga ku mahadnaqa, waayo, isagu waa wanaagsan yahay,
\q1 Oo naxariistiisuna weligeedba way sii waartaa.
\q1 
\v 2 Kuwa Rabbigu soo furtay sidaas ha yidhaahdeen,
\q1 Waana kuwa uu isagu ka soo furtay gacantii cadowga,
\q1 
\v 3 Oo uu ka soo ururiyey dalalka,
\q1 Xagga bari, iyo xagga galbeed,
\q1 Xagga woqooyi, iyo xagga koonfureedba.
\q1 
\v 4 Waxay dhex wareegi jireen cidlada iyo jid lamadegaan ah,
\q1 Mana ay helin magaalo ay degaan.
\q1 
\v 5 Way gaajoodeen, wayna harraadeen,
\q1 Oo naftoodiina way ku dhex taag darnaatay.
\q1 
\v 6 Markaasay Rabbiga u qayshadeen iyagoo dhibban,
\q1 Oo isna wuu ka samatabbixiyey dhibaatooyinkoodii.
\q1 
\v 7 Oo weliba wuxuu iyagii ku hoggaamiyey jid toosan,
\q1 Si ay u tagaan magaalo ay degaan.
\q1 
\v 8 Dadku muu Rabbiga ku ammaano wanaaggiisa,
\q1 Iyo shuqulladiisa yaabka badan oo uu binu-aadmiga u sameeyo!
\q1 
\v 9 Waayo, isagu wuxuu dhergiyaa nafta aad wax u doonaysa,
\q1 Oo nafta gaajaysanna wuxuu ka dhergiyaa wanaagga.
\q1 
\v 10 Kuwii dhex fadhiyey gudcurkii iyo hooskii dhimashada,
\q1 Oo ku xidhnaa dhibaatada iyo birta,
\q1 
\v 11 Waxay ku caasiyoobeen erayadii Ilaah,
\q1 Oo waxay fududaysteen taladii Ilaaha ugu sarreeya,
\q1 
\v 12 Sidaas daraaddeed ayuu qalbigoodii daal ku soo dejiyey,
\q1 Wayna dheceen, mid iyaga caawiyaana ma jirin.
\q1 
\v 13 Markaasay Rabbiga u qayshadeen iyagoo dhibban,
\q1 Oo isna wuu ka badbaadiyey dhibaatooyinkoodii.
\q1 
\v 14 Wuxuu ka soo dhex bixiyey gudcurkii iyo hooskii dhimashada,
\q1 Silsiladihii ku xidhnaana wuu kala jejebiyey.
\q1 
\v 15 Dadku muu Rabbiga ku ammaano wanaaggiisa,
\q1 Iyo shuqulladiisa yaabka badan oo uu binu-aadmiga u sameeyo!
\q1 
\v 16 Waayo, irdihii naxaasta ahaa wuu kala jejebiyey,
\q1 Qataarradii birta ahaana wuu burburiyey.
\q1 
\v 17 Nacasyadu waxay u dhibban yihiin xadgudubkooda aawadiis,
\q1 Iyo xumaatooyinkooda aawadood.
\q1 
\v 18 Naftoodu waxay nacdaa cunto kasta,
\q1 Oo waxay ku soo dhowaadaan irdaha dhimashada.
\q1 
\v 19 Markaasay Rabbiga u qayshadaan iyagoo dhibban,
\q1 Oo isna wuxuu ka soo badbaadiyaa dhibaatooyinkooda.
\q1 
\v 20 Wuxuu soo diraa eraygiisa, wuuna bogsiiyaa iyaga,
\q1 Oo wuxuu ka samatabbixiyaa halligaaddooda.
\q1 
\v 21 Dadku muu Rabbiga ku ammaano wanaaggiisa,
\q1 Iyo shuqulladiisa yaabka badan oo uu binu-aadmiga u sameeyo!
\q1 
\v 22 Iyagu allabariga mahadnaqidda ha bixiyeen,
\q1 Oo shuqulladiisa gabay ha ku sheegeen.
\q1 
\v 23 Kuwa badda doonniyaha ku mara,
\q1 Oo shuqulkooda ku sameeya biyaha badan,
\q1 
\v 24 Kuwaasu waxay arkaan Rabbiga shuqulladiisa,
\q1 Iyo yaababkiisa moolka ku jira.
\q1 
\v 25 Waayo, wuxuu amraa oo kiciyaa dabaysha duufaanka,
\q1 Taas oo kor u qaadda hirarka badda.
\q1 
\v 26 Waxay u kacaan xagga samada, oo haddana waxay hoos ugu soo dhacaan moolalka,
\q1 Naftoodiina waxay ku dhalaashay dhibaato daraaddeed.
\q1 
\v 27 Hore iyo dib bay isaga daba noqdaan, oo sida nin sakhraan ah bay dhacdhacaan,
\q1 Oo waxay sameeyaan ayay garan waayaan.
\q1 
\v 28 Markaasay Rabbiga u qayshadaan iyagoo dhibban,
\q1 Oo isna wuxuu ka soo bixiyaa dhibaatooyinkooda.
\q1 
\v 29 Wuxuu dejiyaa duufaanka,
\q1 Si ay hirarkiisu u xasillaan.
\q1 
\v 30 Way farxaan, maxaa yeelay, way xasilloon yihiin,
\q1 Oo sidaasuu iyaga ku keenaa marsada ay doonayaan.
\q1 
\v 31 Dadku muu Rabbiga ku ammaano wanaaggiisa,
\q1 Iyo shuqulladiisa yaabka badan oo uu binu-aadmiga u sameeyo!
\q1 
\v 32 Iyagu ha ku sarraysiiyeen shirka dadka dhexdiisa,
\q1 Oo ha ku ammaaneen fadhiga odayaasha.
\q1 
\v 33 Isagu webiyo wuxuu u beddelaa cidlo,
\q1 Oo ilo biyo ahna wuxuu u beddelaa dhul oommane ah,
\q1 
\v 34 Oo dhul barwaaqaysanna wuxuu u beddelaa lamadegaan cusbo leh,
\q1 Oo waana kuwa halkaas deggan xumaantooda aawadeed.
\q1 
\v 35 Cidlada wuxuu u beddelaa balli biyo ah,
\q1 Oo dhul engeganna wuxuu u beddelaa ilo biyo ah.
\q1 
\v 36 Oo halkaasuu kuwa gaajaysan dejiyaa,
\q1 Si ay u samaystaan magaalo ay degaan,
\q1 
\v 37 Oo ay beeraha u abuurtaan, oo ay beero canab ah u beertaan,
\q1 Oo ay u helaan midho tiro badan.
\q1 
\v 38 Oo weliba iyaga wuu barakeeyaa, sidaas daraaddeed aad bay u tarmaan,
\q1 Oo weliba uma uu oggolaado in xoolahoodu yaraadaan.
\q1 
\v 39 Oo haddana way sii dhinmaan, oo waxay la foororsadaan
\q1 Dulmi iyo dhib iyo murug.
\q1 
\v 40 Amiirro wuxuu ku soo daayaa quudhsasho,
\q1 Oo wuxuu ka dhigaa inay ku wareegaan cidlada aan jid lahayn.
\q1 
\v 41 Oo weliba kan baahanna dhibaatada ayuu ka sara mariyaa,
\q1 Oo wuxuu u yeelaa qolooyin ah sidii adhi oo kale.
\q1 
\v 42 Kuwa qummanuna way arki doonaan, wayna ku farxi doonaan,
\q1 Oo kolkaas xumaanta oo dhammu afkeeday xidhi doontaa.
\q1 
\v 43 Ku alla kii caqli lahu wuu dhawri doonaa waxyaalahan,
\q1 Oo iyana way ka fiirsan doonaan Rabbiga naxariistiisa.
\c 108
\s2 Kanu waa sabuur gabay ah oo Daa'uud tiriyey.
\q1 
\v 1 Ilaahow, qalbigaa ii fadhiya,
\q1 Waan gabyi doonaa, haah, waxaan kuugu gabyi doonaa ammaantayda.
\q1 
\v 2 Shareerad iyo kataaradow, toosa,
\q1 Aroorta hore waan toosi doonaa.
\q1 
\v 3 Rabbiyow, mahad baan kuugu naqi doonaa dadyowga dhexdooda,
\q1 Oo waxaan ammaan kuugu gabyi doonaa quruumaha dhexdooda.
\q1 
\v 4 Waayo, naxariistaadu way ku weyn tahay samooyinka korkooda,
\q1 Oo runtaaduna waxay gaadhaa ilaa daruuraha.
\q1 
\v 5 Ilaahow, samooyinka ka sarree,
\q1 Oo ammaantaaduna dhulka oo dhan ha ka sarrayso,
\q1 
\v 6 Si ay kuwaad jeceshahay u samatabbaxaan aawadeed,
\q1 Gacantaada midig ku badbaadi, oo ii jawaab.
\q1 
\v 7 Ilaah wuxuu ku hadlay quduusnimadiisa oo yidhi, Anigu waan farxi doonaa,
\q1 Shekem waan kala qaybin doonaa, oo waxaan qiyaasi doonaa dooxada Sukod,
\q1 
\v 8 Gilecaad anigaa iska leh, Manasehna anigaa iska leh,
\q1 Oo weliba Efrayimna waa daafacaaddii madaxayga,
\q1 Yahuudahna waa ushaydii boqornimo.
\q1 
\v 9 Moo'aab waa weelkaygii aan ku maydhan jiray,
\q1 Edomna kabahaygaan ku dul tuuri doonaa,
\q1 Oo Falastiinna waan ku qaylin doonaa.
\q1 
\v 10 Bal yaa i geeyn doona magaalada deyrka leh?
\q1 Yaase xagga Edom ii kaxayn doona?
\q1 
\v 11 Ilaahow, sow nama aadan xoorin?
\q1 Ilaahow, lama soo baxdid ciidammadayada.
\q1 
\v 12 Cadowga naga caawi,
\q1 Waayo, binu-aadmiga caawimaaddiisu waxtar ma leh.
\q1 
\v 13 Ilaah caawimaaddiisa ayaannu wax xoog leh ku samayn doonnaa,
\q1 Waayo, isagaa ah kan cadaawayaashayada ku tuman doona.
\c 109
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Ilaaha ammaantaydow, ha iska aamusin,
\q1 
\v 2 Waayo, waxay igu kala qaadeen afka kan sharka leh iyo kan khiyaanada lehba,
\q1 Oo waxay igula hadleen carrab been sheega.
\q1 
\v 3 Oo weliba waxay igu hareereeyeen erayo nacayb badan,
\q1 Oo sababla'aan bay igula dirireen.
\q1 
\v 4 Anigoo jecel bay cadow ii yihiin,
\q1 Laakiinse anigu Ilaah baan baryaa.
\q1 
\v 5 Wanaag waxay iigaga abaalgudeen xumaan,
\q1 Jacaylna nacayb.
\q1 
\v 6 Nin shar leh ka sarraysii isaga,
\q1 Oo Shayddaan ha istaago midigtiisa.
\q1 
\v 7 Markii la xukumo, ha soo baxo isagoo dembi lagu helay,
\q1 Oo tukashadiisiina dembi ha noqoto.
\q1 
\v 8 Cimrigiisu ha yaraado,
\q1 Jagadiisana mid kale ha qaato.
\q1 
\v 9 Carruurtiisu ha agoontoobeen,
\q1 Naagtiisuna carmal ha noqoto.
\q1 
\v 10 Carruurtiisu kuwa warwareega ha noqdeen oo ha dawarsadeen,
\q1 Cuntadoodana ha ka doondooneen meelahooda cidlada ah.
\q1 
\v 11 Midka korsaarta qaataa ha qabsado wuxuu haysto oo dhan,
\q1 Oo shisheeyayaalna ha ka dheceen wixii uu ku hawshooday.
\q1 
\v 12 Yaanu jirin mid isaga u sii naxariistaa,
\q1 Oo yaanu jirin mid u naxa carruurtiisa agoonta ah.
\q1 
\v 13 Farcankiisu ha baabba'o,
\q1 Oo qarniga soo socda magacooda ha la tirtiro.
\q1 
\v 14 Xumaantii awowayaashiis Rabbigu ha soo xusuusto,
\q1 Oo dembigii hooyadiisna yaan la tirtirin.
\q1 
\v 15 Rabbiga ha hor joogeen had iyo goorba,
\q1 Si uu xusuustooda uga gooyo dhulka.
\q1 
\v 16 Maxaa yeelay, isagu wuu xusuusan waayay inuu u naxariisto
\q1 Miskiinka, iyo kan baahan, iyo kan qalbiga ka murugaysan,
\q1 Laakiinse wuxuu u silciyey inuu iyaga laayo aawadeed.
\q1 
\v 17 Wuxuu jeclaaday habaaridda, markaasaa habaar ku soo degay,
\q1 Ducaynta kuma farxin, ducona way ka sii fogaatay isaga.
\q1 
\v 18 Oo weliba isagu wuxuu sidii dharkiisii u huwaday habaaridda,
\q1 Oo iyana waxay gashay uurkiisa hoose sidii biyo oo kale,
\q1 Oo lafihiisana waxay u gashay sidii saliid.
\q1 
\v 19 Isaga ha u ahaato sida marada uu huwado,
\q1 Iyo sida dhex-xidhka uu ku xidho had iyo goorba,
\q1 
\v 20 Tanu waa abaalmarinta cadaawayaashaydu ay xagga Rabbiga ka helaan,
\q1 Iyo kuwa naftayda xumaan ka sheegaba.
\q1 
\v 21 Laakiinse Ilaahow, Sayidow, magacaaga daraaddiis wax iigu yeel,
\q1 Naxariistaadu waa wanaagsan tahay, ee sidaas daraaddeed ii samatabbixi,
\q1 
\v 22 Waayo, anigu waxaan ahay miskiin iyo mid baahan,
\q1 Oo qalbigayguna wuu igu dhex dhaawacmay.
\q1 
\v 23 Waxaan u dhammaaday sida hoos sii libdhaya,
\q1 Waxaan u gilgilmaa sida ayax oo kale.
\q1 
\v 24 Jilbahaygu soon bay la taag darnaadaan,
\q1 Oo jidhkayguna baruurla'aanteed wuu la caatoobaa.
\q1 
\v 25 Oo weliba waxaan iyaga u noqday cay,
\q1 Oo kolkay i arkaan ayay madaxa ruxruxaan.
\q1 
\v 26 Rabbiyow, Ilaahayow, i caawi,
\q1 Oo igu badbaadi si naxariistaada waafaqsan,
\q1 
\v 27 Si ay u ogaadaan in tanu tahay shaqadii gacaantaada,
\q1 Iyo inaad taas samaysay, Rabbiyow.
\q1 
\v 28 Iyagu ha habaartameen, adiguse i barakee,
\q1 Kolkay kacaan, way ceeboobi doonaan, laakiinse anigoo addoonkaaga ah waan rayrayn doonaa.
\q1 
\v 29 Cadaawayaashaydu sharafdarro ha xidheen,
\q1 Oo ceebtooda ha u huwadeen sida go' oo kale.
\q1 
\v 30 Afkaygaan aad ugaga mahadnaqi doonaa Rabbiga,
\q1 Haah, oo waxaan isaga ku ammaani doonaa dadka badan dhexdiisa.
\q1 
\v 31 Waayo, isagu wuxuu isa soo taagi doonaa miskiinka midigtiisa,
\q1 Si uu uga badbaadiyo kuwa naftiisa xukuma.
\c 110
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Rabbigu wuxuu Sayidkayga ku yidhi, Midigtayda fadhiiso,
\q1 Ilaa aan cadaawayaashaada ka dhigo meeshaad cagahaaga saaratid.
\q1 
\v 2 Rabbigu wuxuu Siyoon ka soo diri doonaa ushii xooggaaga,
\q1 Cadaawayaashaada dhexdooda ka tali.
\q1 
\v 3 Dadkaagu iyagoo raalli ah bay isbixiyaan maalintii xooggaaga,
\q1 Iyagoo leh quruxda quduusnimada, ee ka timaada uurka waaberiga,
\q1 Adigaa leh sayaxa dhallinyaranimadaada.
\q1 
\v 4 Rabbigu wuu dhaartay, kana soo noqon maayo, oo wuxuu yidhi,
\q1 Adigu weligaaba wadaad baad tahay,
\q1 Sidii derejadii Malkisadaq.
\q1 
\v 5 Sayidka midigtaada joogaa
\q1 Wuxuu maalinta cadhadiisa dooxi doonaa boqorro.
\q1 
\v 6 Isagu quruumaha dhexdooda ayuu wax ku xukumi doonaa,
\q1 Oo meel walba wuxuu ka buuxin doonaa meydad,
\q1 Oo waddammo badan ayuu madaxda ka dili doonaa.
\q1 
\v 7 Intuu jidka socdo ayuu durdurka ka cabbi doonaa,
\q1 Oo sidaas daraaddeed ayuu madaxa kor u qaadi doonaa.
\b
\c 111
\q1 
\v 1 Rabbiga ammaana.
\q1 Qalbigayga oo dhan ayaan Rabbiga ugaga mahadnaqi doonaa
\q1 Guddiga kuwa qumman dhexdiisa iyo ururka dhexdiisaba.
\q1 
\v 2 Shuqullada Rabbigu way waaweyn yihiin,
\q1 Oo waxaa doondoona kuwa ku faraxsan oo dhan.
\q1 
\v 3 Shuqulkiisu waa sharaf iyo haybad,
\q1 Oo xaqnimadiisuna weligeedba way waartaa.
\q1 
\v 4 Wuxuu ka dhigay in la sii xusuusto shuqulladiisa yaabka badan,
\q1 Rabbigu waa nimco miidhan, oo waxaa ka buuxda raxmad.
\q1 
\v 5 Wuxuu cunto siiyey kuwa isaga ka cabsada,
\q1 Oo weligiisna wuxuu xusuusnaan doonaa axdigiisii.
\q1 
\v 6 Wuxuu dadkiisii tusay xooggii shuqulladiisa,
\q1 Markii uu iyaga siiyey quruumaha dhaxalkoodii.
\q1 
\v 7 Shuqullada gacmihiisu waa run iyo garsoorid,
\q1 Oo amarradiisa oo dhammuna waa hubaal.
\q1 
\v 8 Way sii adag yihiin weligood iyo weligoodba,
\q1 Oo waxaa lagu sameeyey run iyo qummanaan.
\q1 
\v 9 Wuxuu dadkiisa u soo diray furasho,
\q1 Oo wuxuu amray in axdigiisu ahaado mid weligiisba waara,
\q1 Magiciisu waa quduus, waana mid laga cabsado.
\q1 
\v 10 Rabbiga ka cabsashadiisu waa bilowga xigmadda,
\q1 Kuwa sidaas yeela oo dhammu waxay leeyihiin waxgarasho wanaagsan,
\q1 Ammaantiisu way waartaa weligeedba.
\b
\c 112
\q1 
\v 1 Rabbiga ammaana.
\q1 Waxaa barakaysan ninkii Rabbiga ka cabsada,
\q1 Oo aad ugu farxa amarradiisa.
\q1 
\v 2 Farcankiisu wuxuu ku xoog badnaan doonaa dhulka,
\q1 Kuwa qumman farcankooduna wuu barakoobi doonaa.
\q1 
\v 3 Gurigiisa waxaa ku jira maal iyo taajirnimo,
\q1 Xaqnimadiisuna weligeedba way sii waartaa.
\q1 
\v 4 Kuwa qumman iftiin baa gudcurka uga soo baxa,
\q1 Isagu waa nimco miidhan, oo waxaa ka buuxda raxmad, waana xaq.
\q1 
\v 5 Waxaa nimcaysan ninkii naxariis leh oo dadka wax amaahiya,
\q1 Kaasu danihiisuu ku wadi doonaa caddaalad.
\q1 
\v 6 Waayo, isaga weligiis lama dhaqaajin doono,
\q1 Oo kii xaq ah weligiisba waa la xusuusan doonaa.
\q1 
\v 7 Isagu innaba kama cabsan doono war xun,
\q1 Qalbigaa u fadhiya, oo wuxuu isku halleeyaa Rabbiga.
\q1 
\v 8 Qalbigaa u fadhiya, oo ma uu cabsan doono,
\q1 Ilaa uu wuxuu doonayay ku arko cadaawayaashiisa.
\q1 
\v 9 Wax buu kala qaybshay, oo wuxuu wax siiyey kuwii baahnaa,
\q1 Xaqnimadiisuna way sii waartaa weligeedba,
\q1 Geeskiisana waxaa lagu sarraysiin doonaa sharaf.
\q1 
\v 10 Kii shar lahu wuu arki doonaa, wuuna cadhoon doonaa,
\q1 Wuu ilko jirriqsan doonaa, oo wuu dhalaali doonaa,
\q1 Kuwa sharka leh doonistoodu way baabbi'i doontaa.
\b
\c 113
\q1 
\v 1 Rabbiga ammaana.
\q1 Rabbiga addoommadiisow, ammaana.
\q1 Rabbiga magiciisa ammaana.
\q1 
\v 2 Hadda intii ka bilaabata iyo tan iyo weligeedba
\q1 Rabbiga magiciisu mahad ha lahaado.
\q1 
\v 3 Qorraxdu markay soo baxdo iyo markay dhacdo inta ka dhex leh
\q1 Magaca Rabbiga waa in la ammaano.
\q1 
\v 4 Rabbigu quruumaha oo dhan wuu ka wada sarreeyaa,
\q1 Ammaantiisuna samooyinka way ka sii sarraysaa.
\q1 
\v 5 Bal yaa la mid ah Rabbiga Ilaaheenna ah,
\q1 Oo kursigiisa ku leh xagga sare,
\q1 
\v 6 Oo hoos u eega
\q1 Waxyaalaha samada ku jira iyo waxyaalaha dhulka yaalba?
\q1 
\v 7 Wuxuu miskiinka kor uga qaadaa ciidda,
\q1 Oo kan baahanna wuxuu sara uga qaadaa meesha digada,
\q1 
\v 8 Inuu isaga la fadhiisiyo amiirro,
\q1 Kuwaas oo ah amiirrada dadkiisa.
\q1 
\v 9 Oo naagtii madhalays ahna wuxuu ka dhigaa inay reer hayso,
\q1 Iyo inay ahaato hooyo faraxsan oo carruur leh.
\q1 Rabbiga ammaana.
\b
\c 114
\q1 
\v 1 Markay reer binu Israa'iil Masar ka soo bexeen,
\q1 Oo ay reerkii Yacquub dad af qalaad ka soo bexeen,
\q1 
\v 2 Ayaa Yahuudah noqday meeshiisa quduuska ah,
\q1 Israa'iilna noqday meeshuu u talinayay.
\q1 
\v 3 Baddii way aragtay, wayna carartay,
\q1 Webi Urdunna dib baa loo celiyey.
\q1 
\v 4 Buurihii waxay u boodboodeen sidii wanan,
\q1 Kurihiina sidii baraar.
\q1 
\v 5 Baddoy, bal maxaa kugu dhacay oo aad u cararaysaa?
\q1 Webi Urdunow, maxaad dib ugu noqonaysaa?
\q1 
\v 6 Buurahow, bal maxaad ugu boodboodaysaan sida wanan?
\q1 Kuraha yaryarow, bal maxaad ugu boodboodaysaan sida baraar?
\q1 
\v 7 Dhulkow, ku gariir Sayidka hortiisa,
\q1 Ilaaha reer Yacquub hortiisa ku gariir,
\q1 
\v 8 Kaas oo dhagaxii u beddelay balli biyo ah,
\q1 Oo dhagaxmadowgiina u beddelay il biyo ah.
\b
\c 115
\q1 
\v 1 Rabbiyow, yaanay noo ahaan, yaanay noo ahaan,
\q1 Laakiinse magacaaga ammaani ha u ahaato,
\q1 Naxariistaada iyo runtaada daraaddood.
\q1 
\v 2 Bal maxay quruumuhu u odhanayaan,
\q1 Haddaba Ilaahoodu meeh?
\q1 
\v 3 Laakiinse Ilaahayagu samooyinkuu ku jiraa,
\q1 Oo wax alla wixii uu doonayayna wuu sameeyey.
\q1 
\v 4 Sanamyadoodu waa lacag iyo dahab,
\q1 Oo waa wax dad gacmaha ku sameeyey.
\q1 
\v 5 Waxay leeyihiin af, laakiinse ma hadlaan,
\q1 Indhona way leeyihiin, laakiinse waxba ma arkaan,
\q1 
\v 6 Dhegona way leeyihiin, laakiinse waxba ma maqlaan,
\q1 Sanna way leeyihiin, laakiinse waxba ma urshaan,
\q1 
\v 7 Gacmo way leeyihiin, laakiinse waxba ma qabtaan,
\q1 Cagona way leeyihiin, laakiinse ma socdaan,
\q1 Oo hungurigoodana hadal kama soo saaraan.
\q1 
\v 8 Kuwa iyaga sameeyaana sidooda oo kale ayay noqon doonaan,
\q1 Iyo xataa mid kasta oo iyaga isku halleeyaba.
\q1 
\v 9 Reer binu Israa'iilow, Rabbiga isku halleeya,
\q1 Isagu waa caawimaaddooda iyo gaashaankooda.
\q1 
\v 10 Reer Haaruunow, Rabbiga isku halleeya,
\q1 Isagu waa caawimaaddooda iyo gaashaankooda.
\q1 
\v 11 Kuwiinna Rabbiga ka cabsadow, Rabbiga isku halleeya,
\q1 Isagu waa caawimaaddooda iyo gaashaankooda.
\q1 
\v 12 Rabbigu aad buu inoo xusuusnaa, wuu ina barakayn doonaa,
\q1 Reerka Israa'iilna wuu barakayn doonaa,
\q1 Reerka Haaruunna wuu barakayn doonaa.
\q1 
\v 13 Wuxuuna barakayn doonaa kuwa Rabbiga ka cabsada,
\q1 Yar iyo weynba.
\q1 
\v 14 Rabbigu aad iyo aad ha idiin kordhiyo,
\q1 Idinka iyo carruurtiinnaba.
\q1 
\v 15 Rabbiga sameeyey samada iyo dhulka
\q1 Ayaa idin barakeeyey.
\q1 
\v 16 Samooyinku waa samooyinkii Rabbiga,
\q1 Laakiinse dhulka wuxuu siiyey binu-aadmiga.
\q1 
\v 17 Kuwii dhintay Rabbiga ma ay ammaanaan,
\q1 Kuwa hoos ugu dhaadhaca meesha aamusnaantana ma ay ammaanaan isaga,
\q1 
\v 18 Laakiinse annagu Rabbiga waannu ammaani doonnaa
\q1 Haatan intii ka bilaabata iyo tan iyo weligeedba.
\q1 Rabbiga ammaana.
\b
\c 116
\q1 
\v 1 Rabbiga waan jeclahay, maxaa yeelay, wuxuu maqlay
\q1 Codkaygii iyo baryootankaygii.
\q1 
\v 2 Dhegtuu ii dhigay,
\q1 Sidaas daraaddeed isagaan baryi doonaa intaan noolahay oo dhan.
\q1 
\v 3 Xadhkihii dhimashada ayaa i hareereeyey,
\q1 Xanuunkii She'oolna waa i qabsaday.
\q1 Oo waxaan la kulmay dhib iyo murug.
\q1 
\v 4 Markaasaan ku baryootamay magaca Rabbiga,
\q1 Anigoo leh, Rabbiyow, naftayda samatabbixi.
\q1 
\v 5 Rabbigu waa nimco miidhan, waana xaq,
\q1 Haah, oo Ilaaheennu waa naxariis badan yahay.
\q1 
\v 6 Rabbigu kuwa garaadka daran wuu dhawraa,
\q1 Hoos baa la ii soo dejiyey, kolkaasuu i badbaadshay.
\q1 
\v 7 Naftaydoy, nasashadaadii ku noqo,
\q1 Waayo, Rabbigu wax badan oo wanaagsan buu kuu sameeyey.
\q1 
\v 8 Waayo, naftayda waxaad ka samatabbixisay dhimasho,
\q1 Indhahaygana ilmo,
\q1 Cagahaygana kufid.
\q1 
\v 9 Waxaan ku socon doonaa Rabbiga hortiisa
\q1 Anigoo dhex jooga dalka kuwa nool.
\q1 
\v 10 Waan rumaysnaa, oo markaan hadlay
\q1 Aad baa la ii dhibay,
\q1 
\v 11 Anigoo degdegsan baan waxaan idhi,
\q1 Dadka oo dhammu waa beenaalayaal.
\q1 
\v 12 Bal maxaan Rabbiga uga celiyaa
\q1 Waxyaalihii uu ii taray oo dhan?
\q1 
\v 13 Waxaan qaadan doonaa koobka badbaadada,
\q1 Oo magaca Rabbiga ayaan ku baryootami doonaa.
\q1 
\v 14 Rabbiga ayaan u oofin doonaa nidarradaydii,
\q1 Oo weliba waxaan ku bixin doonaa dadkiisa oo dhan hortooda.
\q1 
\v 15 Rabbiga hortiisa dhimashada quduusiintiisa
\q1 Ayaa qiimo weyn ku leh.
\q1 
\v 16 Rabbiyow, sida runta ah waxaan ahay addoonkaaga,
\q1 Waxaan ahay addoonkaaga, oo ah wiilka addoontaada,
\q1 Silsiladahaygii waad iga furtay.
\q1 
\v 17 Waxaan kuu soo bixin doonaa allabarigii mahadnaqidda,
\q1 Oo magaca Rabbiga ayaan ku baryootami doonaa.
\q1 
\v 18 Rabbiga ayaan u oofin doonaa nidarradaydii,
\q1 Oo weliba waxaan ku bixin doonaa dadkiisa oo dhan hortooda,
\q1 
\v 19 Iyo guriga Rabbiga barxadihiisa,
\q1 Iyo dhexdaada, Yeruusaalemay.
\q1 Rabbiga ammaana.
\b
\c 117
\q1 
\v 1 Quruumaha oo dhammow, Rabbiga ammaana,
\q1 Dadyowga oo dhammow, ammaana isaga.
\q1 
\v 2 Waayo, naxariistiisu xaggeenna waa ku weyn tahay,
\q1 Rabbiga runtiisuna weligeedba way waartaa.
\q1 Rabbiga ammaana.
\b
\c 118
\q1 
\v 1 Rabbiga ku mahadnaqa, maxaa yeelay, isagu waa wanaagsan yahay,
\q1 Waayo, naxariistiisu weligeedba way waartaa.
\q1 
\v 2 Haddaba reer binu Israa'iil ha yidhaahdeen,
\q1 Naxariistiisu weligeedba way waartaa.
\q1 
\v 3 Oo reerka Haaruun hadda ha yidhaahdeen,
\q1 Naxariistiisu weligeedba way waartaa.
\q1 
\v 4 Oo kuwa Rabbiga ka cabsadaa hadda ha yidhaahdeen,
\q1 Naxariistiisu weligeedba way waartaa.
\q1 
\v 5 Anigoo cidhiidhi ku jira ayaan Rabbiga u qayshaday,
\q1 Markaasaa Rabbigu ii jawaabay, oo wuxuu i taagay meel ballaadhan.
\q1 
\v 6 Rabbigu waa ila jiraa, oo anigu ma cabsan doono,
\q1 Bal maxaa dad igu samayn karaa?
\q1 
\v 7 Rabbigu waa ila jiraa, oo wuxuu ku dhex jiraa kuwa i caawinaya,
\q1 Haddaba waxaan kuwa i neceb ku arki doonaa waxaan doonayo.
\q1 
\v 8 Intii dad lagu kalsoonaan lahaa
\q1 Waxaa ka wanaagsan in Rabbiga laysku halleeyo.
\q1 
\v 9 Intii amiirro lagu kalsoonaan lahaa
\q1 Waxaa ka wanaagsan in Rabbiga laysku halleeyo.
\q1 
\v 10 Quruumihii oo dhammu way i wada hareereeyeen,
\q1 Oo anna magaca Rabbiga ayaan ku baabbi'in doonaa.
\q1 
\v 11 Way i hareereeyeen, haah, oo way i hareereeyeen,
\q1 Oo anna magaca Rabbiga ayaan ku baabbi'in doonaa.
\q1 
\v 12 Waxay ii hareereeyeen sida shinni oo kale, oo iyaga waxaa loo demiyey sida dabka qodxanta oo kale,
\q1 Oo anna magaca Rabbiga ayaan ku baabbi'in doonaa.
\q1 
\v 13 Adigu aad baad igu mudday si aan u dhaco aawadeed,
\q1 Laakiinse Rabbigaa i caawiyey.
\q1 
\v 14 Rabbigu waa xooggayga iyo gabaygayga,
\q1 Oo wuxuu ii noqday badbaadadayda.
\q1 
\v 15 Kuwa xaq ah teendhooyinkooda waxaa ku jira codkii rayraynta iyo badbaadada,
\q1 Gacanta midig oo Rabbiguna wax xoog leh bay samaysaa.
\q1 
\v 16 Gacanta midig oo Rabbiga waa la sarraysiiyey,
\q1 Gacanta midig oo Rabbiguna wax xoog leh bay samaysaa.
\q1 
\v 17 Anigu ma dhiman doono, laakiinse waan noolaan doonaa,
\q1 Oo waxaan sheegi doonaa shuqullada Rabbiga.
\q1 
\v 18 Rabbigu aad buu ii edbiyey,
\q1 Laakiinse dhimasho iima uu dhiibin.
\q1 
\v 19 Irdaha xaqnimada iga fura,
\q1 Oo anna waan geli doonaa, oo Rabbigaan ku mahadnaqi doonaa.
\q1 
\v 20 Tanu waa iriddii Rabbiga,
\q1 Oo waxaa geli doona kuwa xaqa ah.
\q1 
\v 21 Waan kugu mahadnaqi doonaa, waayo, waad ii jawaabtay,
\q1 Oo waxaad ii noqotay badbaadadayda.
\q1 
\v 22 Dhagaxii kuwa wax dhisaa ay diideen,
\q1 Kaasu wuxuu noqday madaxa rukunka.
\q1 
\v 23 Tanu xagga Rabbiga bay ka timid,
\q1 Oo waa ku yaab indhahayaga.
\q1 
\v 24 Tanu waa maalinta Rabbigu sameeyey,
\q1 Waannu rayrayn doonnaa oo waannu farxi doonnaa.
\q1 
\v 25 Rabbiyow, waan ku baryaynaaye, haatan na badbaadi,
\q1 Oo waan ku baryaynaaye, Rabbiyow, haatan barwaaqo noo soo dir.
\q1 
\v 26 Waxaa barakaysan kan Rabbiga magiciisa ku imanaya,
\q1 Waxaannu idinka ammaannay guriga Rabbiga.
\q1 
\v 27 Rabbigu waa Ilaah, oo wuxuu na siiyey iftiin,
\q1 Allabariga xadhko ku xidha tan iyo meesha allabariga geeseheeda.
\q1 
\v 28 Waxaad tahay Ilaahay, oo anna waan kugu mahadnaqi doonaa,
\q1 Waxaad tahay Ilaahay, oo waan ku sarraysiin doonaa.
\q1 
\v 29 Rabbiga ku mahadnaqa, waayo, isagu waa wanaagsan yahay,
\q1 Oo naxariistiisuna weligeedba way waartaa.
\b
\c 119
\s1 ALEF
\q1 
\v 1 Waxaa barakaysan kuwa jidka ku qumman,
\q1 Oo sharciga Rabbiga ku socda.
\q1 
\v 2 Waxaa barakaysan kuwa dhawra markhaatifurkiisa,
\q1 Oo Rabbiga ku doondoona qalbiga oo dhan.
\q1 
\v 3 Haah, oo xaqdarro ma sameeyaan,
\q1 Jidadkiisase way ku socdaan.
\q1 
\v 4 Waxaad nagu amartay amarradaada,
\q1 Inaan aad u dhawrno.
\q1 
\v 5 Aad baan u jeclaan lahaa in jidadkayga la hagaajiyo
\q1 Inaan qaynuunnada dhawro!
\q1 
\v 6 Markaas anigu ceeboobi maayo,
\q1 Markaan dhawro amarradaada oo dhan.
\q1 
\v 7 Markaan barto xukummadaada xaqa ah
\q1 Ayaan qummanaanta qalbiga kuugu mahadnaqi doonaa.
\q1 
\v 8 Waxaan dhawri doonaa qaynuunnadaada,
\q1 Rabbow, ha i dayrin weligay.
\s1 BED
\q1 
\v 9 Bal nin dhallinyaro ahu muxuu jidkiisa ku nadiifiyaa?
\q1 Waa inuu aad ugu fiirsado si eraygaaga waafaqsan.
\q1 
\v 10 Waxaan kugu doondoonay qalbigayga oo dhan,
\q1 Yaanan amarradaada ka leexan.
\q1 
\v 11 Waxaan eraygaagii qalbigayga ugu kaydsaday
\q1 Si aanan kuugu dembaabin.
\q1 
\v 12 Rabbiyow, adigaa mahad leh,
\q1 Haddaba qaynuunnadaada i bar.
\q1 
\v 13 Waxaan bushimahayga ku sheegay
\q1 Xukummadii afkaaga oo dhan.
\q1 
\v 14 Waxaan ku reyreeyey jidka markhaatifurkaaga,
\q1 Sidaan ugu rayrayn lahaa taajirnimada oo dhan.
\q1 
\v 15 Waxaan aad ugu fiirsan doonaa amarradaada,
\q1 Oo jidadkaagaan dhawri doonaa.
\q1 
\v 16 Qaynuunnadaada waan ku farxi doonaa,
\q1 Eraygaagana ma illoobi doono.
\s1 GIMEL.
\q1 
\v 17 Anoo addoonkaaga ah wax badan oo wanaagsan ii samee, si aan u noolaado,
\q1 Oo sidaasaan eraygaaga u dhawri doonaa.
\q1 
\v 18 Indhahayga fur
\q1 Si aan waxyaalo yaab badan sharcigaaga uga arko.
\q1 
\v 19 Socotaan dhulka ku ahay,
\q1 Haddaba amarradaada ha iga qarin.
\q1 
\v 20 Naftaydu waxay u xiisootay
\q1 Jacaylkay had iyo goorba u qabto xukummadaada.
\q1 
\v 21 Waxaad canaanatay kuwa kibirsan oo inkaaran,
\q1 Oo amarrada ka leexda.
\q1 
\v 22 Cay iyo ceeb iga fogee,
\q1 Waayo, markhaatifurkaaga waan xajiyey,
\q1 
\v 23 Oo weliba amiirraa fadhiistay oo wax iga gees ah ka wada hadlay,
\q1 Laakiinse anoo addoonkaaga ah aad baan uga fiirsaday qaynuunnadaada.
\q1 
\v 24 Markhaatifurkaagu waa waxa iga farxiya,
\q1 Waana lataliyayaashayda.
\s1 DALED.
\q1 
\v 25 Naftaydu waxay ku dhegtaa ciidda,
\q1 Haddaba ii noolee si eraygaaga waafaqsan.
\q1 
\v 26 Waxaan kuu sheegay jidadkaygii, oo adna waad ii jawaabtay,
\q1 Bal qaynuunnadaada i bar.
\q1 
\v 27 Jidka amarradaada i garansii,
\q1 Oo sidaasaan aad ugu fiirsan doonaa shuqulladaada yaabka badan.
\q1 
\v 28 Naftaydu waxay la dhacdaa murug,
\q1 Haddaba ii xoogee si eraygaaga waafaqsan.
\q1 
\v 29 Jidka beenta iga fogee,
\q1 Oo si raxmad leh sharcigaaga ii sii.
\q1 
\v 30 Waxaan doortay jidka aaminnimadaada,
\q1 Oo waxaan hortayda dhigay xukummadaadii.
\q1 
\v 31 Markhaatifurkaaga waan xajiyaa,
\q1 Rabbiyow, ha i ceebayn.
\q1 
\v 32 Waxaan ku ordi doonaa jidka amarradaada
\q1 Markii aad qalbigayga ballaadhisid.
\s1 HE.
\q1 
\v 33 Rabbiyow, jidka qaynuunnadaada i bar,
\q1 Waanan xajin doonaa tan iyo ugu dambaysta.
\q1 
\v 34 Waxgarasho i sii, oo anna sharcigaaga waan xajin doonaa,
\q1 Haah, oo waxaan ku dhawri doonaa qalbigayga oo dhan.
\q1 
\v 35 Igu kexee waddada amarradaada,
\q1 Waayo, kaasaan ku farxaa.
\q1 
\v 36 Qalbigayga u soo jeedi xagga markhaatifurkaaga,
\q1 Oo ha u leexin xagga faa'iidada xaqdarrada ah.
\q1 
\v 37 Indhahayga inay fiiriyaan wax aan micne lahayn ka sii jeedi,
\q1 Oo jidadkaaga igu noolee.
\q1 
\v 38 Eraygaaga ii xaqiiji anoo addoonkaaga ah
\q1 Oo doonaya inaan kaa cabsado.
\q1 
\v 39 Caydayda aan ka cabsanayo iga leexi,
\q1 Waayo, xukummadaadu waa wanaagsan yihiin.
\q1 
\v 40 Bal eeg, waxaan u xiisooday amarradaada,
\q1 Haddaba xaqnimadaada igu soo noolee.
\s1 WAW.
\q1 
\v 41 Rabbiyow, naxariistaada iyo weliba badbaadintaadu
\q1 Ha iigu yimaadeen si eraygaaga waafaqsan.
\q1 
\v 42 Markaasaan jawaab u heli doonaa kan i caaya,
\q1 Waayo, waxaan isku halleeyaa eraygaaga.
\q1 
\v 43 Oo erayga runta ahna dhammaantiis afkayga ha ka gooyn,
\q1 Waayo, waxaan rajo ku qabay xukummadaada.
\q1 
\v 44 Markaasaan had iyo goorba dhawri doonaa sharcigaaga
\q1 Weligay iyo weligayba.
\q1 
\v 45 Oo waxaan ku socon doonaa xorriyad,
\q1 Waayo, waxaan doondoonay amarradaada.
\q1 
\v 46 Oo weliba waxaan markhaatifurkaaga ka sheegi doonaa boqorro hortooda,
\q1 Mana ceeboobi doono.
\q1 
\v 47 Oo waxaan ku farxi doonaa amarradaada
\q1 Aan jeclaaday.
\q1 
\v 48 Oo weliba waxaan gacmaha u hoorsan doonaa amarradaada aan jeclaaday,
\q1 Oo aad baan ugu fiirsan doonaa qaynuunnadaada.
\s1 SAYN.
\q1 
\v 49 Xusuuso eraygii aad anoo addoonkaaga ah igula hadashay,
\q1 Oo aad igu rajo gelisay.
\q1 
\v 50 Oo taasu waa i qalbi qaboojisaa markii aan dhibaataysnahay,
\q1 Waayo, eraygaagaa i soo nooleeyey.
\q1 
\v 51 Kuwa kibirsan aad bay iigu qosleen,
\q1 Laakiinse sharcigaaga kama aan leexan.
\q1 
\v 52 Rabbiyow, tan iyo mar hore waxaan soo xusuusnaa xukummadaada,
\q1 Waanan isqalbi qaboojiyey.
\q1 
\v 53 Aad baan u xanaaqay,
\q1 Waana kuwa sharka leh oo sharcigaaga ka tegey aawadood.
\q1 
\v 54 Qaynuunnadaadu waxay ii ahaayeen heeso
\q1 Markaan ku jiray gurigii aan socotada ku ahaa.
\q1 
\v 55 Rabbiyow, habeenkaan magacaaga soo xusuustay,
\q1 Oo sharcigaagaan dhawray.
\q1 
\v 56 Taasu waa ii ahaatay,
\q1 Maxaa yeelay, amarradaadii baan xajiyey.
\s1 KHED.
\q1 
\v 57 Rabbigu waa qaybtayda,
\q1 Oo anigu waxaan idhi, Waxaan dhawrayaa erayadaada.
\q1 
\v 58 Qalbigayga oo dhan ayaan kugu baryay inaad raalli iga ahaato,
\q1 Si eraygaaga waafaqsan iigu naxariiso.
\q1 
\v 59 Waxaan ka fikiray jidadkayga,
\q1 Kolkaasaan cagahayga u soo duway xagga markhaatifurkaaga.
\q1 
\v 60 Waan u degdegay, oo kama aan raagin
\q1 Inaan amarradaada dhawro.
\q1 
\v 61 Waxaa isku kay duudduubay xadhkihii kuwa sharka leh,
\q1 Laakiinse sharcigaaga ma aan illoobin.
\q1 
\v 62 Waxaan kici doonaa habeenbadhka inaan kugu mahadnaqo,
\q1 Waana xukummadaada caddaaladda ah daraaddood.
\q1 
\v 63 Anigu waxaan wehel la ahay kuwa kaa cabsada oo dhan,
\q1 Iyo kuwa amarradaada dhawraba.
\q1 
\v 64 Rabbiyow, dhulka waxaa ka buuxda naxariistaada,
\q1 Haddaba qaynuunnadaada i bar.
\s1 TET.
\q1 
\v 65 Rabbiyow, anoo addoonkaaga ah waxaad iila macaamilootay
\q1 Si wanaagsan oo eraygaaga waafaqsan.
\q1 
\v 66 Haddaba i bar kaladoorasho wanaagsan iyo aqoon,
\q1 Waayo, waxaan rumaystay amarradaada.
\q1 
\v 67 Intaan lay dhibin ka hor ayaan ambaday,
\q1 Laakiinse haatan eraygaaga waan dhawraa.
\q1 
\v 68 Waad wanaagsan tahay, oo wanaag baad samaysaa,
\q1 Haddaba qaynuunnadaada i bar.
\q1 
\v 69 Kuwa kibirka lahu been bay iga sheegeen,
\q1 Aniguse amarradaada ayaan ku xajin doonaa qalbigayga oo dhan.
\q1 
\v 70 Qalbigoodu wuu qallafsanaaday,
\q1 Aniguse waxaan ku farxaa sharcigaaga.
\q1 
\v 71 Waa ii wanaagsanayd in lay dhibo,
\q1 Si aan qaynuunnadaada u barto.
\q1 
\v 72 Sharciga afkaagu waa iiga sii fiican yahay
\q1 Kumanyaal dahab iyo lacag ah.
\s1 YOD.
\q1 
\v 73 Waxaa i sameeyey oo i qabanqaabiyey gacmahaaga,
\q1 Haddaba i sii waxgarasho aan amarradaada ku barto.
\q1 
\v 74 Kuwa kaa cabsadaa way i arki doonaan, wayna farxi doonaan,
\q1 Maxaa yeelay, waxaan rajo ku qabay eraygaaga.
\q1 
\v 75 Rabbiyow, waan ogahay in xukummadaadu ay xaq yihiin,
\q1 Iyo inaad aaminnimo igu dhibtay.
\q1 
\v 76 Waan ku baryayaaye raxmaddaadu ha ii noqoto qalbiqaboojin
\q1 Si waafaqsan eraygii aad anoo addoonkaaga ah igula hadashay.
\q1 
\v 77 Naxariistaadu ha ii timaado si aan u noolaado,
\q1 Waayo, waxaa iga farxiya sharcigaaga.
\q1 
\v 78 Kuwa kibirka lahu ha ceeboobeen, waayo, si gardarro ah ayay igu afgembiyeen,
\q1 Aniguse waxaan aad uga fiirsan doonaa amarradaada.
\q1 
\v 79 Kuwa kaa cabsadaa ha ii soo noqdeen,
\q1 Oo waxay ogaan doonaan markhaatifurkaaga.
\q1 
\v 80 Qalbigaygu qaynuunnadaada ha ku qummanaado,
\q1 Si aanan u ceeboobin.
\s1 KAF.
\q1 
\v 81 Naftaydu waa u taag darnaataa badbaadintaada aan u xiisoodo aawadeed,
\q1 Laakiinse eraygaagaan rajo ku qabaa.
\q1 
\v 82 Sidii aan u lahaa, Goormaad i qalbi qaboojinaysaa?
\q1 Ayaa indhahaygu u gudheen eraygaaga aawadiis.
\q1 
\v 83 Waayo, waxaan noqday sidii sibraar qiiq ku dhex jiro,
\q1 Laakiinse innaba qaynuunnadaada ma aan illoobo.
\q1 
\v 84 Anoo addoonkaaga ah cimrigaygu waa intee?
\q1 Oo goormaad xukun ku soo dejinaysaa kuwa i silciya?
\q1 
\v 85 Kuwa kibirka leh oo aan sharcigaaga waafaqsanayn
\q1 Ayaa ii qoday godad.
\q1 
\v 86 Amarradaada oo dhammu waa wada daacad,
\q1 Si gardarro ah ayay ii silciyaan, haddaba i caawi,
\q1 
\v 87 Dhulka ayay iga baabbi'in gaadheen,
\q1 Aniguse kama aan tegin amarradaadii.
\q1 
\v 88 Raxmaddaada igu soo noolee,
\q1 Oo anna waxaan dhawri doonaa markhaatifurka afkaaga.
\s1 LAMED.
\q1 
\v 89 Rabbiyow, eraygaagu weligiisba
\q1 Wuxuu taagan yahay samada.
\q1 
\v 90 Aaminnimadaaduna waxay gaadhaa tan iyo ka ab ka ab;
\q1 Dhulkaad dhistay, wuuna sii jirayaa.
\q1 
\v 91 Maantadan waxay u joogaan si qaynuunnadaada waafaqsan,
\q1 Waayo, wax waluba waa addoommadaada.
\q1 
\v 92 Haddaanu sharcigaagu iga farxin,
\q1 Waxaan kol hore ku halligmi lahaa dhibaatadii i haysatay.
\q1 
\v 93 Weligay amarradaada ma aan illoobi doono,
\q1 Waayo, iyagaad igu soo noolaysay.
\q1 
\v 94 Anigu waxaan ahay kaaga, haddaba i badbaadi,
\q1 Waayo, waxaan doondoonay amarradaada.
\q1 
\v 95 Kuwa sharka lahu way ii sugeen inay i baabbi'iyaan,
\q1 Aniguse waxaan ka fiirsan doonaa markhaatifurkaaga.
\q1 
\v 96 Waxaan arkay in wax kasta oo kaamil ah ay dhammaad leeyihiin,
\q1 Amarkaaguse aad buu u ballaadhan yahay.
\s1 MEM.
\q1 
\v 97 Aad baan sharcigaaga u jeclahay!
\q1 Maalinta oo dhan isagaan u fiirsadaa.
\q1 
\v 98 Amarradaadu waxay iga dhigaan ku ka sii caqli badan cadaawayaashayda.
\q1 Waayo, weligayba way ila jiraan.
\q1 
\v 99 Waan ka sii waxgarasho badnahay macallimiintayda oo dhan,
\q1 Waayo, waxaan u fiirsadaa markhaatifurkaaga.
\q1 
\v 100 Waan ka sii waxgarasho badnahay odayaasha,
\q1 Waayo, waxaan xajiyey amarradaada.
\q1 
\v 101 Cagahayga waan ka joojiyey jid kasta oo shar leh,
\q1 Si aan eraygaaga u dhawro.
\q1 
\v 102 Xukummadaada gees ugama aan leexan,
\q1 Waayo, wax baad i bartay.
\q1 
\v 103 Erayadaadu dhanxanaggayga u macaan badanaa!
\q1 Afkayga malab way uga sii macaan badan yihiin!
\q1 
\v 104 Amarradaada ayaan waxgarasho ku helaa,
\q1 Oo sidaas daraaddeed ayaan jid kasta oo been ah u necbahay.
\s1 NUN.
\q1 
\v 105 Eraygaagu wuxuu cagahayga u yahay laambad,
\q1 Waddooyinkaygana iftiin.
\q1 
\v 106 Waxaan ku dhaartay oo aan weliba xaqiijiyey
\q1 Inaan dhawrayo xukummadaada xaqa ah.
\q1 
\v 107 Aad iyo aad baan u dhibaataysnahay,
\q1 Haddaba Rabbiyow, igu soo noolee si eraygaaga waafaqsan.
\q1 
\v 108 Rabbiyow, waan ku baryayaaye, aqbal qurbaannada ikhtiyaarka ah oo afkayga,
\q1 Xukummadaadana i bar.
\q1 
\v 109 Naftaydu had iyo goorba waxay ku jirtaa khatar,
\q1 Habase yeeshee sharcigaaga ma illoobo.
\q1 
\v 110 Kuwa sharka lahu waxay ii dhigeen dabin,
\q1 Laakiinse amarradaada kama aan amban.
\q1 
\v 111 Markhaatifurkaaga waxaan u qaatay sida dhaxal weligiis waaraya,
\q1 Waayo, kaasu waxa weeye waxa qalbigaygu ku reyreeya.
\q1 
\v 112 Qalbigayga waxaan u jeediyey inaan qaynuunnadaada oofiyo,
\q1 Tan iyo weligay iyo ilaa ugu dambaysta.
\s1 SAMEKH.
\q1 
\v 113 Waan necbahay kuwa labada qalbi leh,
\q1 Laakiinse sharcigaaga waan jeclahay.
\q1 
\v 114 Waxaad tahay gabbaadkayga iyo gaashaankayga,
\q1 Oo waxaan rajo ku qabaa eraygaaga.
\q1 
\v 115 Kuwiinna xumaanta falow, iga taga,
\q1 Si aan amarrada Ilaahayga u xajiyo.
\q1 
\v 116 Rabbiyow, ii tiiri si eraygaaga waafaqsan si aan u noolaado,
\q1 Oo yaanan rajadayda ku ceeboobin.
\q1 
\v 117 Kor ii hay, oo waan badbaadi doonaa,
\q1 Oo had iyo goorba waxaan u fiirsan doonaa qaynuunnadaada.
\q1 
\v 118 Kuwa qaynuunnadaada ka habaabay oo dhan waad fudaydsatay,
\q1 Waayo, khiyaanadoodu waa wax been ah.
\q1 
\v 119 Kuwa sharka leh oo dhulka oo dhan waxaad u fogaysaa sida wasakh oo kale,
\q1 Oo sidaas daraaddeed baan markhaatifurkaaga u jeclahay.
\q1 
\v 120 Jidhkaygu wuxuu la gariiraa cabsidaada,
\q1 Oo waxaan ka baqaa xukummadaada.
\s1 CAYN.
\q1 
\v 121 Waxaan sameeyey xukun iyo caddaalad,
\q1 Haddaba ha iiga tegin kuwa i dulma.
\q1 
\v 122 Anoo addoonkaaga ah wanaag daraaddiis ii dammiino,
\q1 Oo kuwa kibirsanu yaanay i dulmin.
\q1 
\v 123 Indhahaygii waxay u gudheen jacaylkay badbaadintaada u qabaan,
\q1 Iyo eraygaaga xaqa ah daraaddiis.
\q1 
\v 124 Anoo addoonkaaga ah iila macaamilow si naxariistaada waafaqsan,
\q1 Oo qaynuunnadaada i bar.
\q1 
\v 125 Waxaan ahay addoonkaaga, haddaba waxgarasho i sii,
\q1 Si aan markhaatifurkaaga u ogaado.
\q1 
\v 126 Waa wakhtiga aad shaqayn lahayd, Rabbiyow,
\q1 Waayo, sharcigaaga way buriyeen.
\q1 
\v 127 Haddaba amarradaada waan ka sii jeclahay
\q1 Dahab, haah, xataa dahab saafi ah.
\q1 
\v 128 Sidaas daraaddeed amarradaada oo dhammu waxay ila yihiin wax hagaagsan,
\q1 Oo waan necbahay jid kasta oo been ah.
\s1 FE.
\q1 
\v 129 Markhaatifurkaagu waa yaab badan yahay,
\q1 Oo sidaas daraaddeed ayay naftaydu u xajisaa.
\q1 
\v 130 Erayadaada furniinkoodu wax buu iftiimiyaa,
\q1 Oo wuxuu waxgarasho siiyaa kuwa garaadka daran.
\q1 
\v 131 Afka aad baan u kala qaaday, oo waan harraaday,
\q1 Waayo, waxaan u xiisooday amarradaada.
\q1 
\v 132 Ii soo jeeso, oo ii naxariiso,
\q1 Sidaad kuwa magacaaga jecel u samaysid.
\q1 
\v 133 Tallaabooyinkayga ku toosi eraygaaga,
\q1 Oo dembina yaanu ii talin.
\q1 
\v 134 Dadka dulmigiisa iga bixi,
\q1 Oo anna waxaan dhawri doonaa amarradaada.
\q1 
\v 135 Anoo addoonkaaga ah wejigaaga iigu iftiimi,
\q1 Oo qaynuunnadaada i bar.
\q1 
\v 136 Indhahayga waxaa ka shubma durdurro biyo ah,
\q1 Maxaa yeelay, sharcigaaga lama dhawrin.
\s1 SADE.
\q1 
\v 137 Rabbiyow, xaq baad tahay,
\q1 Oo xukummadaaduna waa qumman yihiin.
\q1 
\v 138 Markhaatifurkaaga waxaad ku amartay xaqnimo
\q1 Iyo daacadnimo oo dhan.
\q1 
\v 139 Waxaa i baabba'shay qiirada aan kuu qabo,
\q1 Maxaa yeelay, cadaawayaashaydu waxay illoobeen erayadaada.
\q1 
\v 140 Eraygaagu aad buu u daahirsan yahay,
\q1 Sidaas daraaddeed anoo addoonkaaga ah waan jeclahay.
\q1 
\v 141 Anigu waan yarahay, oo waa lay quudhsadaa,
\q1 Laakiinse amarradaada ma illoobo.
\q1 
\v 142 Xaqnimadaadu waa xaqnimo weligeed sii waaraysa,
\q1 Oo sharcigaaguna waa run.
\q1 
\v 143 Dhib iyo cidhiidhi baa i qabsaday.
\q1 Laakiinse amarradaadu waa waxa iga farxiya.
\q1 
\v 144 Markhaatifurkaagu weligiisba waa xaq,
\q1 Haddaba waxgarasho i sii, oo anna waan sii noolaan doonaa.
\s1 QOF.
\q1 
\v 145 Waxaan ku qayshaday qalbigayga oo dhan, haddaba Rabbiyow, ii jawaab,
\q1 Oo anna waxaan xajin doonaa qaynuunnadaada.
\q1 
\v 146 Waan kuu qayshaday ee i badbaadi,
\q1 Oo markhaatifurkaaga waan dhawri doonaa.
\q1 
\v 147 Waan ka soo hor maray waaga berigiisii, oo waan qayliyey,
\q1 Oo waxaan rajo ku qabay erayadaada.
\q1 
\v 148 Indhahaygu way ka hor mareen wakhtiga la soo jeedo oo habeennimo,
\q1 Si aan eraygaaga uga fikiro.
\q1 
\v 149 Codkayga u maqal si raxmaddaada waafaqsan,
\q1 Rabbiyow, igu soo noolee si xukummadaada waafaqsan.
\q1 
\v 150 Kuwii xumaatada raaci jiray way soo dhowaanayaan,
\q1 Iyagu sharcigaaga way ka fog yihiin.
\q1 
\v 151 Rabbiyow, adigu waad dhow dahay,
\q1 Oo amarradaada oo dhammuna waa wada run.
\q1 
\v 152 Waxaan markhaatifurkaaga waa hore ka iqiin
\q1 Inaad u aasaastay si ay weligood u sii waaraan.
\s1 RESH.
\q1 
\v 153 Dhibaatadayda ka fiirso oo i samatabbixi,
\q1 Waayo, anigu sharcigaaga ma illoobo.
\q1 
\v 154 Dacwadayda ii muddac, oo i soo furo,
\q1 Igu soo noolee si eraygaaga waafaqsan.
\q1 
\v 155 Kuwa sharka leh badbaadadu waa ka fog tahay,
\q1 Waayo, qaynuunnadaada ma ay doondoonaan.
\q1 
\v 156 Rabbiyow, naxariistaadu waa badan tahay,
\q1 Igu soo noolee si xukummadaada waafaqsan.
\q1 
\v 157 Kuwa i silciya iyo cadaawayaashayduba way badan yihiin,
\q1 Laakiinse anigu kama aan leexan markhaatifurkaaga.
\q1 
\v 158 Waxaan arkay khaa'innada, kolkaasaan murugooday,
\q1 Maxaa yeelay, iyagu eraygaaga ma ay dhawraan.
\q1 
\v 159 Bal ka fiirso sida aan amarradaada u jeclahay,
\q1 Rabbiyow, igu soo noolee si raxmaddaada waafaqsan.
\q1 
\v 160 Eraygaaga dhammaantiisu waa run,
\q1 Mid kasta oo xukummadaada xaqa ah ka mid ahu wuu sii waaraa weligiisba.
\s1 SHIN.
\q1 
\v 161 Amiirraa sababla'aan ii silciyey,
\q1 Laakiinse qalbigaygu wuxuu ka baqaa erayadaada.
\q1 
\v 162 Waxaan eraygaaga ugu reyreeyaa
\q1 Sidii mid booli badan helay.
\q1 
\v 163 Beenta waan necbahay oo waan karahsaday,
\q1 Laakiinse sharcigaaga waan jeclahay.
\q1 
\v 164 Maalintiiba toddoba jeer baan ku ammaanaa,
\q1 Waana xukummadaada xaqa ah daraaddood.
\q1 
\v 165 Kuwa sharcigaaga jecelu waxay haystaan nabad weyn,
\q1 Oo wax iyaga turuntureeyaa ma jiraan.
\q1 
\v 166 Rabbiyow, badbaadintaada waan u xiisooday,
\q1 Oo amarradaadiina waan oofiyey.
\q1 
\v 167 Naftaydu waxay dhawrtay markhaatifurkaaga,
\q1 Oo anna aad iyo aad baan u jeclahay.
\q1 
\v 168 Waxaan dhawray amarradaada iyo markhaatifurkaaga,
\q1 Waayo, jidadkayga oo dhammu hortaaday wada yaalliin.
\s1 TAW.
\q1 
\v 169 Rabbiyow, qayladaydu ha ku soo dhowaato hortaada,
\q1 Oo waxgarasho ii sii si eraygaaga waafaqsan.
\q1 
\v 170 Baryootankaygu hortaada ha yimaado,
\q1 Oo ii samatabbixi si eraygaaga waafaqsan.
\q1 
\v 171 Bushimahaygu ammaan ha ku hadleen,
\q1 Waayo, waxaad i bartaa qaynuunnadaada.
\q1 
\v 172 Carrabkaygu ha ku gabyo eraygaaga,
\q1 Waayo, amarradaada oo dhammu waa wada xaqnimo.
\q1 
\v 173 Gacantaadu diyaar ha u ahaato inay i caawiso,
\q1 Waayo, amarradaadaan doortay.
\q1 
\v 174 Rabbiyow, badbaadintaada, waan u xiisooday,
\q1 Oo sharcigaaguna waa waxa iga farxiya.
\q1 
\v 175 Naftaydu ha iska noolaato, wayna ku ammaani doontaa,
\q1 Oo xukummadaaduna ha i caawiyaan.
\q1 
\v 176 Waxaan u hallaabay sidii lax luntay, haddaba anigoo addoonkaaga ah i doondoon,
\q1 Waayo, amarradaada ma aan illoobo.
\c 120
\s2 Gabayga meelokoridda.
\q1 
\v 1 Anigoo cidhiidhi ku jira ayaan Rabbiga u qayshaday,
\q1 Oo isna wuu ii jawaabay.
\q1 
\v 2 Rabbiyow, naftayda ka samatabbixi bushimo been sheega,
\q1 Iyo carrab khiyaano badan.
\q1 
\v 3 Carrabka khiyaanada badanow, bal maxaa lagu siin doonaa?
\q1 Oo maxaa kaloo laguu samayn doonaa?
\q1 
\v 4 Adoo ah sida ku xoog badan oo fallaadhihiisa afaysan,
\q1 Kuwaas oo wata dhuxulo geed rotem la yidhaahdo.
\q1 
\v 5 Anaa hoogay, waayo, Mesheg baan qariib ku noqday,
\q1 Oo waxaan dhex degay teendhooyinkii Qedaar!
\q1 
\v 6 Naftaydu waxay wakhti dheer la degganayd
\q1 Mid nabadda neceb.
\q1 
\v 7 Waxaan ahay mid nabad jecel,
\q1 Laakiinse kolkii aan hadlo, iyagu waa kuwa dagaal jecel.
\c 121
\s2 Gabayga meelokoridda.
\q1 
\v 1 Buurahaan indhahayga ku taagi doonaa,
\q1 Caawimaaddaydu xaggee bay ka iman doontaa?
\q1 
\v 2 Caawimaaddaydu waxay ka timaadaa
\q1 Rabbiga sameeyey samada iyo dhulka.
\q1 
\v 3 Isagu uma oggolaan doono in cagtaada la dhaqaajiyo,
\q1 Kan ku dhawraa ma gam'i doono.
\q1 
\v 4 Bal eeg, kan reer binu Israa'iil dhawraa
\q1 Ma gam'i doono, mana seexan doono.
\q1 
\v 5 Kan ku dhawraa waa Rabbiga,
\q1 Rabbigu waa hooskaaga midigtaada taagan.
\q1 
\v 6 Qorraxdu maalinta waxba kuma yeeli doonto.
\q1 Habeenkana dayaxu waxba kuma yeeli doono.
\q1 
\v 7 Rabbiga ayaa kaa dhawri doona shar kasta,
\q1 Isagu wuxuu dhawri doonaa naftaada.
\q1 
\v 8 Hadda intii ka bilaabata iyo tan iyo weligeedba
\q1 Rabbigu wuxuu dhawri doonaa bixiddaada iyo soo geliddaadaba.
\c 122
\s2 Gabayga meelokoridda oo Daa'uud tiriyey.
\q1 
\v 1 Waan farxay markay igu yidhaahdeen,
\q1 Ina keena, aan guriga Rabbiga tagnee.
\q1 
\v 2 Yeruusaalemay, cagahayagu
\q1 Waxay taagan yihiin irdahaaga gudahooda,
\q1 
\v 3 Yeruusaalem waxaa loo dhisay
\q1 Sida magaalo isku wada dheggan,
\q1 
\v 4 Halkaasay qabiilooyinka, oo ah qabiilooyinka Rabbigu kor ugu baxaan
\q1 Inay Israa'iil u marag furaan,
\q1 Iyo inay magaca Rabbiga ku mahadnaqaan.
\q1 
\v 5 Waayo, waxaa yaalla carshiyo garsoorid loo dhigay,
\q1 Waana carshiyadii reerka Daa'uud.
\q1 
\v 6 Yeruusaalem nabad ugu duceeya.
\q1 Kuwa ku jecelu way barwaaqoobi doonaan.
\q1 
\v 7 Nabadu ha ku jirto derbiyadaada gudahooda,
\q1 Barwaaqona ha ku jirto daarahaaga dhaadheer.
\q1 
\v 8 Walaalahay iyo rafiiqyadayda daraaddood
\q1 Ayaan hadda waxaan odhanayaa, Nabadu gudahaaga ha ku jirto.
\q1 
\v 9 Rabbiga Ilaahayaga gurigiisa daraaddiis
\q1 Ayaan wanaaggaaga u doondooni doonaa.
\c 123
\s2 Gabayga meelokoridda.
\q1 
\v 1 Kaaga samooyinka dhex fadhiyow,
\q1 Adigaan indhahayga kor kuugu taagaa.
\q1 
\v 2 Bal eeg, sida ay indhaha addoommadu u fiiriyaan gacanta sayidkooda,
\q1 Iyo sida ay gabadh indhaheedu u fiiriyaan gacanta sayidaddeeda
\q1 Ayay indhahayagu u fiiriyaan Rabbiga Ilaahayaga ah,
\q1 Ilaa uu noo naxariisto.
\q1 
\v 3 Rabbiyow, noo naxariiso, annaga noo naxariiso,
\q1 Waayo, waxaa aad nooga buuxda quudhsasho.
\q1 
\v 4 Naftayadii waxaa aad uga batay
\q1 Qosolka kuwa istareexsan
\q1 Iyo quudhsashadii kuwa kibirsan.
\c 124
\s2 Gabayga meelokoridda oo Daa'uud tiriyey.
\q1 
\v 1 Haddaan Rabbigu inala jirin
\q1 Hadda reer binu Israa'iil ha yidhaahdeen,
\q1 
\v 2 Haddaan Rabbigu inala jirin,
\q1 Markii dadku inagu kacay,
\q1 
\v 3 Kolkaasay innagoo noolnool ina wada liqliqi lahaayeen,
\q1 Markay aad inoogu cadhoodeen,
\q1 
\v 4 Kolkaasay biyuhu ina qarqin lahaayeen,
\q1 Durdurna nafteennuu dul mari lahaa,
\q1 
\v 5 Oo kolkaasay biyaha kibirsanu nafteenna dul mari lahaayeen.
\q1 
\v 6 Waxaa mahad leh Rabbiga
\q1 Aan inaga dhigin ugaadh ilkahoodu ay qabsadaan.
\q1 
\v 7 Nafteennu waxay u baxsatay sida shimbir uga baxsato dabinka shimbirrodabtaha,
\q1 Dabinkii wuu go'ay, innaguna waynu baxsannay.
\q1 
\v 8 Caawimaaddeennu waxay ku jirtaa magaca Rabbiga
\q1 Sameeyey samada iyo dhulkaba.
\c 125
\s2 Gabayga meelokoridda.
\q1 
\v 1 Kuwa Rabbiga isku halleeyaa
\q1 Waa sida Buur Siyoon oo aan la dhaqaajin karin, laakiinse weligeedba sii jirta.
\q1 
\v 2 Sida buuruhu Yeruusaalem ugu wareegsan yihiin
\q1 Ayuu Rabbigu dadkiisa ugu wareegsan yahay,
\q1 Hadda intii ka bilaabata iyo tan iyo weligeedba.
\q1 
\v 3 Waayo, usha xumaantu ku dhici mayso qaybta kuwa xaqa ah,
\q1 Si aan kuwa xaqa ahu gacmahooda xumaan ugu soo fidin.
\q1 
\v 4 Rabbiyow, kuwa wanaagsan wanaag u samee,
\q1 Iyo weliba kuwa qalbigoodu qumman yahay.
\q1 
\v 5 Laakiinse kuwa geesta ugu leexda jidadkooda qalloocan
\q1 Rabbigu wuxuu iyaga la kaxayn doonaa xumaanfalayaasha.
\q1 Reer binu Israa'iil korkooda nabadu ha ahaato.
\c 126
\s2 Gabayga meelokoridda.
\q1 
\v 1 Markii Rabbigu soo celiyey maxaabiistii Siyoon,
\q1 Waxaynu noqonnay sida kuwa riyooda.
\q1 
\v 2 Markaasaa afkeenna waxaa ka buuxsamay qosol,
\q1 Carrabkeennana gabay,
\q1 Kolkaasaa quruumaha waxaa laga dhex yidhi,
\q1 Rabbigu waxyaalo waaweyn ayuu iyaga u sameeyey.
\q1 
\v 3 Rabbigu wuxuu inoo sameeyey waxyaalo waaweyn,
\q1 Oo aynu ku faraxsan nahay.
\q1 
\v 4 Rabbiyow, maxaabiisnimada mar kale nooga soo celi
\q1 Sida durdurrada koonfureed.
\q1 
\v 5 Kuwa ilmada wax ku abuurtaa, farxad bay ku goosan doonaan.
\q1 
\v 6 Kii iska taga isagoo ooyaya oo abuurkiisa sita,
\q1 Wuxuu soo noqon doonaa isagoo faraxsan oo xidhmooyinkiisa sita.
\c 127
\s2 Gabayga meelokoridda oo Sulaymaan tiriyey.
\q1 
\v 1 Haddaan Rabbigu guriga dhisin,
\q1 Kuwa dhisaya, waxtarla'aan bay u hawshoodaan,
\q1 Haddaan Rabbigu magaalada dhawrin,
\q1 Waardiyuhu micnela'aan buu u soo jeedaa.
\q1 
\v 2 Faa'iido idiinma leh inaad aroor hore kacdaan oo aad goor dambe seexataan,
\q1 Oo aad kibista dhibka cuntaan,
\q1 Waayo, wuxuu kuwuu jecel yahay siiyaa hurdo.
\q1 
\v 3 Bal eeg, carruurtu waa dhaxal xagga Rabbiga laga helo.
\q1 Oo midhaha maxalku waa abaalgudkiisa.
\q1 
\v 4 Sida fallaadho ku jira nin xoog badan gacantiis,
\q1 Sidaasoo kale weeye carruurta dhallinyaranimadu.
\q1 
\v 5 Waxaa barakaysan ninkii gabooyihiisa ka buuxsada iyaga,
\q1 Iyagu ma ay ceeboobi doonaan
\q1 Markay cadaawayaashooda kula hadlaan xagga iridda.
\c 128
\s2 Gabayga meelokoridda.
\q1 
\v 1 Waxaa barakaysan mid kasta oo Rabbiga ka cabsada,
\q1 Oo jidadkiisa ku socda.
\q1 
\v 2 Waayo, waad cuni doontaa waxa gacmahaagu ku hawshoodeen,
\q1 Waadna farxi doontaa, oo waad barwaaqoobi doontaa.
\q1 
\v 3 Naagtaadu waxay gurigaaga ku dhex ahaan doontaa sida geed canab ah oo midho badan dhala.
\q1 Carruurtaaduna waxay noqon doonaan sida geedo saytuun ah oo miiskaaga ku wareegsan.
\q1 
\v 4 Bal eeg, sidaasuu u barakoobi doonaa
\q1 Ninka Rabbiga ka cabsadaa.
\q1 
\v 5 Rabbigu Siyoon buu kaa barakayn doonaa,
\q1 Oo cimrigaaga oo dhan waxaad arki doontaa wanaagga Yeruusaalem.
\q1 
\v 6 Haah, oo waxaad arki doontaa carruurtaada carruurtooda.
\q1 Reer binu Israa'iil korkooda nabadu ha ahaato.
\c 129
\s2 Gabayga meelokoridda.
\q1 
\v 1 Tan iyo yaraantaydii marar badan bay i dhibeen,
\q1 Reer binu Israa'iil hadda ha yidhaahdeen,
\q1 
\v 2 Tan iyo yaraantaydii marar badan bay i dhibeen,
\q1 Laakiinse igama ay adkaan.
\q1 
\v 3 Kuwa beerta jeexa ayaa dhabarkayga jeexay,
\q1 Oo jeexjeexoodiina way dheereeyeen.
\q1 
\v 4 Rabbigu waa xaq,
\q1 Oo isagu wuxuu kala gooyay xadhkihii kuwa sharka leh.
\q1 
\v 5 Inta Siyoon neceb oo dhammu,
\q1 Ha ceeboobeen oo dib ha u noqdeen.
\q1 
\v 6 Ha noqdeen sida cawska guryaha korkooda ka baxa
\q1 Oo engega intaanu korin,
\q1 
\v 7 Oo aan beergooyuhu gacantiisa ka buuxin,
\q1 Kan xidhmooyinka xidhaana aanu laabtiisa ka buuxin.
\q1 
\v 8 Oo kuwa ag maraana ma yidhaahdaan,
\q1 Barakadii Rabbigu korkiinna ha ahaato.
\q1 Waxaan idiinku ducaynaynaa magaca Rabbiga.
\c 130
\s2 Gabayga meelokoridda.
\q1 
\v 1 Rabbiyow, waxaan kaaga qayshaday moolalka.
\q1 
\v 2 Sayidow, codkayga maqal,
\q1 Oo dhegahaagu ha noqdeen kuwo u digtoon
\q1 Codka baryootankayga.
\q1 
\v 3 Rabbiyow, haddaad dembiyada u fiirsatid,
\q1 Bal yaa istaagi doona, Sayidow?
\q1 
\v 4 Laakiinse waxaa kula jirta dembidhaafid,
\q1 In adiga lagaa cabsado daraaddeed.
\q1 
\v 5 Waxaan sugaa Rabbiga,
\q1 Naftayduna way sugtaa, oo eraygiisa ayaan rajo ku qabaa.
\q1 
\v 6 Naftaydu waxay Sayidka u dhawrtaa
\q1 In ka sii badan sida waardiyuhu u dhawro waaga berigiisa,
\q1 Haah, in ka sii badan sida waardiyuhu u dhawro waaga berigiisa.
\q1 
\v 7 Reer binu Israa'iilow, Rabbiga rajo ku qaba,
\q1 Waayo, Rabbigu wuxuu leeyahay naxariis
\q1 Iyo weliba furasho aad iyo aad u badan.
\q1 
\v 8 Oo wuxuu reer binu Israa'iil ka soo furan doonaa
\q1 Dembiyadooda oo dhan.
\c 131
\s2 Gabayga meelokoridda oo Daa'uud tiriyey.
\q1 
\v 1 Rabbiyow, qalbigaygu kor isuma qaado, indhahayguna ma kibirsana,
\q1 Oo anna iskuma dhex tuuro axwaal waaweyn,
\q1 Ama waxyaalihii igu yaab badan.
\q1 
\v 2 Hubaal naftaydii waan dejiyey, oo waan xasilliyey,
\q1 Sida ilmo naas laga gudhiyey oo hooyadiis la jooga,
\q1 Naftaydu waxay iigu jirtaa sida ilmo naas laga gudhiyey.
\q1 
\v 3 Reer binu Israa'iilow, Rabbiga rajo ku qaba,
\q1 Haddeer intii laga bilaabo iyo tan iyo weligiinba.
\c 132
\s2 Gabayga meelokoridda.
\q1 
\v 1 Rabbiyow, bal xusuuso Daa'uud
\q1 Dhibaatooyinkiisii oo dhan,
\q1 
\v 2 Iyo siduu Rabbiga ugu dhaartay,
\q1 Oo nidar ugu galay Ilaaha Xoogga leh oo Yacquub, isagoo leh,
\q1 
\v 3 Hubaal anigu geli maayo teendhada gurigayga,
\q1 Sariirtaydana fuuli maayo,
\q1 
\v 4 Indhahayga seexasho isugu qaban maayo,
\q1 Il iyo baalna isu keeni maayo,
\q1 
\v 5 Ilaa aan meel u helo Rabbiga,
\q1 Oo aan taambuug u helo Kan Xoogga leh oo Yacquub.
\q1 
\v 6 Bal eeg, annagu waxaan ku maqalnay Efraataah,
\q1 Oo waxaan ka helnay berrinkii duurka.
\q1 
\v 7 Waxaan geli doonnaa taambuugyadiisa,
\q1 Oo waxaan ku sujuudi doonnaa meeshuu cagaha saarto.
\q1 
\v 8 Rabbiyow, sara joogso, oo meeshaada nasashada gal,
\q1 Adiga iyo sanduuqa xooggaaguba.
\q1 
\v 9 Wadaaddadaadu xaqnimo ha huwadeen,
\q1 Quduusiintaaduna farxad ha la qayliyeen.
\q1 
\v 10 Addoonkaagii Daa'uud daraaddiis
\q1 Ha sii jeedin kaaga subkan wejigiisa.
\q1 
\v 11 Rabbigu run buu Daa'uud ugu dhaartay,
\q1 Oo dhaartiisiina ka soo noqon maayo,
\q1 Midhaha jidhkaaga midkood ayaan carshigaaga ku fadhiisin doonaa.
\q1 
\v 12 Carruurtaadu hadday xajiyaan axdigayga
\q1 Iyo markhaatifurkayga aan iyaga bari doono,
\q1 De markaas carruurtooduna weligood bay ku fadhiisan doonaan carshigaaga.
\q1 
\v 13 Waayo, Rabbigu wuu doortay Siyoon,
\q1 Oo wuxuu u jeclaystay inuu rugtiisii ka dhigto.
\q1 
\v 14 Halkanu waa meeshaydii nasashada weligeedba,
\q1 Halkanaan degganaan doonaa, waayo, waan jeclaystay.
\q1 
\v 15 Waxaan iyada aad iyo aad ugu barakayn doonaa quud,
\q1 Oo masaakiinteeda waxaan ka dhergin doonaa cunto.
\q1 
\v 16 Wadaaddadeedana waxaan huwin doonaa badbaado,
\q1 Quduusiinteeduna aad bay ula qaylin doonaan farxad.
\q1 
\v 17 Halkaas waxaan ka dhigi doonaa in gees Daa'uud u soo baxo,
\q1 Waxaan laambad u diyaariyey kii aan subkaday.
\q1 
\v 18 Cadaawayaashiisa waxaan huwin doonaa ceeb,
\q1 Laakiinse taajkiisu madaxiisuu ku waari doonaa.
\c 133
\s2 Gabayga meelokoridda oo Daa'uud tiriyey.
\q1 
\v 1 Bal eeg, siday u wanaagsan tahay oo ay u wacan tahay
\q1 Inay walaalo wadajir ku degganaadaan!
\q1 
\v 2 Waa sida saliidda qaaliga ah ee madaxa,
\q1 Oo ku soo dareertay gadhka,
\q1 Kaasoo ahaa gadhkii Haaruun,
\q1 Oo waxay soo gaadhay daraftii dharkiisa,
\q1 
\v 3 Waana sida dharabka Buur Xermoon,
\q1 Oo ku soo dega buuraha Siyoon,
\q1 Waayo, Rabbigu wuxuu amray inay halkaas ku dhacdo barako,
\q1 Taasoo ah nolosha tan iyo weligeedba.
\c 134
\s2 Gabayga meelokoridda.
\q1 
\v 1 Bal eega, Rabbiga ammaana, Rabbiga addoommadiisa oo dhammow,
\q1 Kuwiinna goor habeennimo ah guriga Rabbiga dhex taaganow.
\q1 
\v 2 Gacmaha u taaga macbudka xaggiisa,
\q1 Oo Rabbiga ammaana.
\q1 
\v 3 Rabbigu Siyoon ha idinka soo barakeeyo,
\q1 Kaasoo ah kii sameeyey samada iyo dhulkaba.
\b
\c 135
\q1 
\v 1 Rabbiga ammaana.
\q1 Ammaana magaca Rabbiga,
\q1 Rabbiga addoommadiisow, isaga ammaana,
\q1 
\v 2 Kuwiinna guriga Rabbiga
\q1 Iyo barxadaha guriga Ilaaheenna dhex taaganow.
\q1 
\v 3 Rabbiga ammaana, waayo, Rabbigu waa wanaagsan yahay,
\q1 Magiciisa ammaan ugu gabya, waayo, wuu wacan yahay.
\q1 
\v 4 Waayo, Rabbigu reer Yacquub nafsaddiisuu u doortay,
\q1 Hantidiisa gaarka ah ayuu u doortay reer binu Israa'iil.
\q1 
\v 5 Waayo, waan ogahay in Rabbigu weyn yahay,
\q1 Iyo in Sayidkeennu ka wada sarreeyo ilaahyada oo dhan.
\q1 
\v 6 Rabbigu wax alla wixii uu jeclaystayba wuu ku sameeyey
\q1 Samada iyo dhulka, iyo badaha iyo moolalka oo dhan dhexdooda.
\q1 
\v 7 Isagaa ka dhiga in dhulka darafyadiisa uumi ka soo kaco,
\q1 Roobkana wuxuu u sameeyaa hillaac,
\q1 Oo dabayshana isagaa khasnadihiisa ka soo saara.
\q1 
\v 8 Isagaa laayay curadyadii Masar,
\q1 Kuwii dadka iyo kuwii duunyadaba.
\q1 
\v 9 Masaray, isagu wuxuu dhexdaada u soo diray calaamooyin iyo yaabab,
\q1 Oo wax buu ku soo kor daayay Fircoon iyo addoommadiisii oo dhanba.
\q1 
\v 10 Wuxuuna laayay quruumo badan,
\q1 Oo wuxuu dilay boqorro xoog badan, kuwaas oo ahaa
\q1 
\v 11 Siixon oo ahaa boqorkii reer Amor,
\q1 Iyo Coog oo ahaa boqorkii Baashaan,
\q1 Iyo boqortooyooyinkii reer Kancaan oo dhan,
\q1 
\v 12 Oo dalkoodiina dhaxal ahaan buu u bixiyey,
\q1 Oo wuxuu dhaxal u siiyey dadkiisa reer binu Israa'iil.
\q1 
\v 13 Rabbiyow, magacaagu weligiisba wuu waaraa,
\q1 Rabbiyow, xusuustaadu waxay gaadhaa qarni kasta.
\q1 
\v 14 Waayo, Rabbigu dadkiisuu u garsoori doonaa,
\q1 Oo addoommadiisana wuu u naxariisan doonaa.
\q1 
\v 15 Sanamyada quruumuhu waa lacag iyo dahab,
\q1 Oo waa wax ay dad gacmaha ku sameeyeen.
\q1 
\v 16 Afaf way leeyihiin, laakiinse ma hadlaan,
\q1 Indhona way leeyihiin, laakiinse waxba ma arkaan,
\q1 
\v 17 Dhegona way leeyihiin, laakiinse waxba ma maqlaan,
\q1 Oo afkoodana neefu kuma jirto.
\q1 
\v 18 Kuwa iyaga sameeyaana sidooda oo kale ayay noqon doonaan,
\q1 Iyo xataa mid kasta oo iyaga isku halleeyaaba.
\q1 
\v 19 Reer binu Israa'iilow, Rabbiga ammaana,
\q1 Reer Haaruunow, Rabbiga ammaana,
\q1 
\v 20 Reer Laawiyow, Rabbiga ammaana,
\q1 Kuwiinna Rabbiga ka cabsadow, Rabbiga ammaana.
\q1 
\v 21 Rabbiga Yeruusaalem deggan ha laga ammaano Siyoon.
\q1 Rabbiga ammaana.
\b
\c 136
\q1 
\v 1 Rabbiga ku mahadnaqa, waayo, isagu waa wanaagsan yahay,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 2 Ku mahadnaqa Ilaaha ilaahyada,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 3 Ku mahadnaqa Sayidka sayidyada,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 4 Kan keligiis sameeya yaabab waaweyn,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 5 Kan samada waxgarashada ku sameeyey,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 6 Kan dhulka biyaha korkooda ku goglay,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 7 Kan sameeyey iftiimmo waaweyn,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 8 Qorraxdu inay maalinta xukunto,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 9 Dayaxa iyo xiddiguhuna inay habeenka xukumaan,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 10 Kan Masar curadyadii ka laayay,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 11 Oo reer binu Israa'iilna ka soo dhex saaray,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 12 Kan kaga soo bixiyey gacan xoog badan iyo cudud fidsan,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 13 Kan Badda Cas kala qaybiyey,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 14 Oo reer binu Israa'iilna dhex marshay iyada,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 15 Laakiinse Fircoon iyo ciidankiisiiba wuu ku afgembiyey Badda Cas dhexdeeda,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 16 Kan dadkiisa cidlada dhex hoggaamiyey,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 17 Kan boqorro waaweyn wax ku dhuftay,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 18 Oo laayay boqorro caan ah,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 19 Kuwaas oo ahaa Siixon oo ahaa boqorkii reer Amor,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 20 Iyo Coog oo ahaa boqorkii Baashaan,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 21 Oo dalkoodiina u bixiyey dhaxal ahaan,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 22 Kaasoo ahaa dhaxalkii uu siiyey addoonkiisii Israa'iil,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 23 Kan ina soo xusuustay markaan gunta ahayn,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 24 Oo inaga soo samatabbixiyey cadaawayaasheennii,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 25 Kan cunto siiya wax kastoo jidh leh,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\q1 
\v 26 Ku mahadnaqa Ilaaha samada,
\q1 Waayo, naxariistiisu weligeedba way sii waartaa.
\b
\c 137
\q1 
\v 1 Waxaannu ag fadhiisannay webiyaashii Baabuloon,
\q1 Oo waannu ooynay markii aannu Siyoon soo xusuusannay.
\q1 
\v 2 Oo waxaannu kataaradahayagii sudhannay geedaha safsaafkaa.
\q1 
\v 3 Waayo, kuwii maxaabiis ahaanta noo watay ayaa halkaas gabayo nagu weyddiistay,
\q1 Oo kuwii na silciyey ayaa farxad na weyddiistay, oo waxay nagu yidhaahdeen,
\q1 Noogu gabya gabayadii Siyoon midkood.
\q1 
\v 4 Bal sidee baannu gabaygii Rabbiga ugu gabaynaa
\q1 Dal qalaad dhexdiis?
\q1 
\v 5 Yeruusaalemay, haddaan ku illoobo,
\q1 Gacantayda midig ha illowdo sancadeedii.
\q1 
\v 6 Carrabkayguna ha ku dhego dhanxanagga afkayga,
\q1 Haddaanan ku xusuusan,
\q1 Iyo haddaanan Yeruusaalem ka sii jeclaan
\q1 Farxaddayda ugu weyn.
\q1 
\v 7 Rabbiyow, soo xusuuso reer Edom,
\q1 Kuwaasoo maalintii Yeruusaalem yidhi,
\q1 Dumiya, dumiya, tan iyo aasaaskeeda.
\q1 
\v 8 Gabadha Baabuloonay, waa lagu baabbi'in doonaa,
\q1 Waxaa faraxsanaan doona kii kaa abaalmariya
\q1 Sidii aad nagu samaysay.
\q1 
\v 9 Waxaa faraxsanaan doona kii dhallaankaaga qabsada
\q1 Oo dhagaxa weyn ku dul tuura.
\c 138
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Qalbigayga oo dhan ayaan kugu mahadnaqi doonaa,
\q1 Oo ilaahyada hortooda ayaan ammaan kuugu gabyi doonaa,
\q1 
\v 2 Waxaan u soo tukan doonaa macbudkaaga quduuska ah xaggiisa,
\q1 Oo magacaagana waxaan ugu mahadnaqi doonaa raxmaddaada iyo runtaada aawadood,
\q1 Waayo, eraygaaga ayaad ka sii weynaysay magacaaga oo dhan.
\q1 
\v 3 Maalintii aan qayshaday waad ii jawaabtay,
\q1 Waanad igu kalsooni gelisay xooggii aad naftayda u yeeshay.
\q1 
\v 4 Rabbiyow, boqorrada dhulka jooga oo dhammu way kugu mahadnaqi doonaan,
\q1 Waayo, waxay maqlaan erayada afkaaga.
\q1 
\v 5 Haah, way ka gabyi doonaan jidadka Rabbiga,
\q1 Waayo, ammaanta Rabbigu waa weyn tahay.
\q1 
\v 6 Waayo, in kastoo Rabbigu sarreeyo, haddana wuu fiiriyaa kuwa hooseeya,
\q1 Laakiinse kan kibra meel fog buu ka yaqaan.
\q1 
\v 7 In kastoo aan ku dhex socdo dhibaato waad i soo noolayn doontaa,
\q1 Oo waxaad gacantaada ku soo fidin doontaa cadhada cadaawayaashayda,
\q1 Oo gacantaada midigna way i badbaadin doontaa.
\q1 
\v 8 Rabbigaa kaamil ka dhigi doona waxa igu saabsan,
\q1 Rabbiyow, naxariistaadu weligeedba way sii waartaa,
\q1 Ha ka tegin shuqulladii gacmahaaga.
\c 139
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Rabbiyow, waad i baadhay, oo waad i soo ogaatay.
\q1 
\v 2 Waad og tahay fadhiisashadayda iyo sara kiciddaydaba,
\q1 Oo fikirkaygana meel fog baad ka garataa.
\q1 
\v 3 Socodkayga iyo seexashadaydaba waad baadhaa,
\q1 Oo jidadkayga oo dhanna waad wada taqaan.
\q1 
\v 4 Waayo, Rabbiyow, eray aanad aqoonu carrabkayga kuma jiro,
\q1 Laakiinse adigu waad wada og tahay.
\q1 
\v 5 Adigu hor iyo dibba waad iga xidhay,
\q1 Oo gacantaadaad i saartay.
\q1 
\v 6 Aqoontaas oo kale aad iyo aad bay iigu yaab badan tahay,
\q1 Waa wax sare, oo anigu ma aan gaadhi karo.
\q1 
\v 7 Bal xaggee baan ruuxaaga ka tagaa?
\q1 Xaggee baanse wejigaaga uga cararaa?
\q1 
\v 8 Haddaan samada koro, halkaasaad joogtaa,
\q1 Haddaan sariirtayda She'ool dhex dhigtona, bal eeg, halkaasna waad joogtaa.
\q1 
\v 9 Haddaan qaato baalasha subaxda,
\q1 Iyo haddaan dego badda darafyadeeda ugu shisheeyaba,
\q1 
\v 10 Xataa halkaas gacantaada ayaa i hoggaamin doonta,
\q1 Oo midigtaada ayaa i soo qaban doonta.
\q1 
\v 11 Haddaan idhaahdo, Hubaal gudcurkaa i qarin doona,
\q1 Oo iftiinka igu wareegsanu habeennimuu noqon doonaa,
\q1 
\v 12 Xataa gudcurku igama kaa qariyo,
\q1 Laakiinse habeenku wuxuu u iftiimaa sida maalinta oo kale,
\q1 Gudcurka iyo iftiinku waa isugu kaa mid.
\q1 
\v 13 Waayo, kelyahayga adigaa sameeyey,
\q1 Oo adigaa igu daboolay maxalkii hooyaday.
\q1 
\v 14 Waan kugu mahadnaqi doonaa, waayo, waxaa la ii sameeyey si cabsi iyo yaab badan,
\q1 Shuqulladaadu waa yaab badan yihiin,
\q1 Oo naftayduna taas aad bay u taqaan.
\q1 
\v 15 Lafahaygu kaama qarsoonayn,
\q1 Markii laygu sameeyey qarsoodiga,
\q1 Oo farsamada yaabka leh laygu sameeyey dhulka meesha ugu hoosaysa.
\q1 
\v 16 Indhahaagu way i arkeen markaan uurjiifka ahaa,
\q1 Oo xubnahaygu kitaabkaagay ku wada qornaayeen,
\q1 Kuwaas oo maalin ka maalin la qabanqaabiyey
\q1 Intaan midkoodna jirin ka hor.
\q1 
\v 17 Ilaahow, fikirradaadu ila qiimo badanaa!
\q1 Oo tiro badanaa!
\q1 
\v 18 Haddaan tiriyo, way ka sii tiro badan yihiin ciidda,
\q1 Oo markaan tooso weli adigaan kula joogaa.
\q1 
\v 19 Ilaahow, hubaal waxaad layn doontaa kuwa sharka leh,
\q1 Haddaba iga taga, raggiinna dhiigyocabyada ahow.
\q1 
\v 20 Waayo, iyagu si xun ayay wax kaaga sheegaan,
\q1 Oo cadaawayaashaaduna micnela'aan bay magacaaga ku soo qaadqaadaan.
\q1 
\v 21 Rabbiyow, sow ma aan nebci kuwa ku neceb?
\q1 Oo sow kama aan murugaysni kuwa kugu kaca?
\q1 
\v 22 Nacayb dhan ayaan ku necbahay iyaga,
\q1 Oo waxaan iyaga u haystaa cadaawayaashayda.
\q1 
\v 23 Ilaahow, i baadh, oo qalbigayga garo,
\q1 I tijaabi, oo fikirradayda ogow,
\q1 
\v 24 Oo bal fiiri inuu jid xumaan ahu igu jiro iyo in kale,
\q1 Oo igu hoggaami jidka weligiis ah.
\c 140
\s2 Kanu waa sabuur Daa'uud u tiriyey madaxdii muusikaystayaasha.
\q1 
\v 1 Rabbiyow, ninka sharka leh iga samatabbixi,
\q1 Oo iga ilaali ninka dulmiga badan,
\q1 
\v 2 Kuwaasoo qalbigooda kaga fikira belaayooyin,
\q1 Had iyo goorna dagaal bay isu soo urursadaan.
\q1 
\v 3 Waxay carrabkoodii u afaysteen sidii abeeso oo kale,
\q1 Oo bushimahoodana waxaa ku hoos jirta waabaydii jilbiska. (Selaah)
\q1 
\v 4 Rabbiyow, gacmaha kuwa sharka leh iga dhawr,
\q1 Oo iga ilaali ninka dulmiga badan,
\q1 Kuwaasoo u qasdiyey inay tallaabooyinkayga dhinac u leexiyaan.
\q1 
\v 5 Kuwa kibirka badanu waxay ii qariyeen dabin iyo xadhko,
\q1 Oo jidka dhinaciisana waxay ii gogleen shabag, oo siriq bay ii qooleen. (Selaah)
\q1 
\v 6 Waxaan Rabbiga ku idhi, Waxaad tahay Ilaahayga,
\q1 Haddaba, Rabbiyow, bal dhegta u dhig codka baryootankayga.
\q1 
\v 7 Ilaahow Sayidow, xooggii badbaadadaydow,
\q1 Maalintii dagaalka madaxaygaad dabooshay.
\q1 
\v 8 Rabbiyow, kuwa sharka leh ha siin waxay doonayaan,
\q1 Oo horay ha u sii wadin xeeladdooda sharka ah, waaba intaasoo ay kor isu qaadaane. (Selaah)
\q1 
\v 9 Oo kuwa igu wareegsan madaxoodana
\q1 Belaayada bushimahooda ka soo baxaysa ha daboosho.
\q1 
\v 10 Dhuxulo ololaya ha ku soo dul daateen,
\q1 Oo iyaga ha lagu dhex tuuro dabka,
\q1 Iyo godad aad u dhaadheer, si aanay mar dambe u soo sara kicin.
\q1 
\v 11 Ninka sharka ku hadlaa yaanu dhulka ku sii waarin,
\q1 Sharku wuxuu u ugaadhsan doonaa ninka dulmiga badan inuu afgembiyo aawadeed.
\q1 
\v 12 Waan ogahay in Rabbigu kuwa dhibban dacwadooda u gar qaadi doono,
\q1 Oo uu kuwa baahanna xaqooda siin doono.
\q1 
\v 13 Hubaal kuwa xaqa ahu waxay ku mahadnaqi doonaan magacaaga,
\q1 Oo kuwa qummanuna waxay joogi doonaan hortaada.
\c 141
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Rabbiyow, adigaan kuu qayshaday, haddaba ii soo dhaqso,
\q1 Oo markaan kuu qayshado, codkayga dhegta u dhig.
\q1 
\v 2 Baryootankaygu ha noqdo sida foox hortaada la dhigay,
\q1 Oo gacma-koruqaadiddayduna ha noqoto sida allabariga fiidnimo.
\q1 
\v 3 Rabbiyow, afkayga waardiye hor jooji,
\q1 Oo albaabka bushimahaygana dhawr.
\q1 
\v 4 Qalbigayga ha u duwin wax shar ah,
\q1 Yaanu falimo xumaan ah la gelin
\q1 Dadka xumaanta ka shaqeeya,
\q1 Oo yaanan wax ka cunin waxyaalahooda macaan.
\q1 
\v 5 Kan xaqa ahu ha i dilo, raxmad bay ii ahaan doontaa,
\q1 Oo ha i canaanto, waxay ii noqon doontaa sida saliid madaxa lagu shubto,
\q1 Madaxayguna yaanu diidin,
\q1 Waayo, xataa intay sharkooda ku sii jiraan ayaan tukashadayda ka geesta ah sii wadaa.
\q1 
\v 6 Xaakinnadoodii waxaa lagu tuuray dhagaxa dhinacyadiisa,
\q1 Oo iyagu waxay maqli doonaan erayadayda, waayo, way macaan yihiin.
\q1 
\v 7 Sida markii beerta la qodo oo dhulka la jeexo
\q1 Ayaa lafahayagii ugu firidhsan yihiin She'ool afkiisa.
\q1 
\v 8 Waayo, Ilaahow Sayidow, indhahaygu xaggaagay ku soo jeedaan,
\q1 Oo adigaan isku kaa halleeyaa, haddaba naftayda ha dayrin.
\q1 
\v 9 Iga dhawr dabinka ay ii dhigeen,
\q1 Iyo siriqda ay xumaanfalayaashu qooleen.
\q1 
\v 10 Kuwa sharka lahu ha ku dhex dheceen shabagyadooda
\q1 Markaan anigu ka baxsado.
\c 142
\s2 Kanu waa baryootan Maskiil ah ee Daa'uud tiriyey markuu godkii ku jiray.
\q1 
\v 1 Anigu codkaygaan Rabbiga ugu qayshadaa,
\q1 Oo codkaygaan Rabbiga ku baryaa.
\q1 
\v 2 Oo hortiisaan ku cawdaa,
\q1 Oo dhibaatadaydana hortiisaan ku muujiyaa.
\q1 
\v 3 Markii naftaydu gudahayga ku itaal darnaatay, waddadayda waad tiqiin,
\q1 Jidka aan ku socdona dabin bay iigu qariyeen.
\q1 
\v 4 Bal fiiri xaggayga midig, oo bal arag,
\q1 Waayo, nin i yaqaan ma jiro,
\q1 Meel aan magangalo ayaan waayay, ninna naftayda dan kama leh.
\q1 
\v 5 Rabbiyow, adigaan kuu qayshaday,
\q1 Oo waxaan idhi, Waxaad tahay magangalkayga,
\q1 Iyo qaybta aan dalka kuwa nool ku leeyahay.
\q1 
\v 6 Qayladayda dhegayso, waayo, aad baa hoos laygu dejiyey,
\q1 Kuwa i silciya iga samatabbixi, waayo, iyagu way iga xoog badan yihiin.
\q1 
\v 7 Naftayda xabsiga ka soo bixi, si aan magacaaga ugu mahadnaqo,
\q1 Kuwa xaqa ah ayaa igu hareeraysnaan doona,
\q1 Waayo, wax badan oo wanaagsan baad ii samayn doontaa.
\c 143
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Rabbiyow, tukashadayda maqal, oo baryootankayga dhegta u dhig,
\q1 Oo daacadnimadaada iyo xaqnimadaada iigu jawaab.
\q1 
\v 2 Anoo addoonkaaga ah xukun ha i gelin,
\q1 Waayo, inta nool oo dhan ma jiro nin hortaada lagu caddayn doonaa inuu xaq yahay.
\q1 
\v 3 Waayo, cadowgaa naftayda silciyey,
\q1 Noloshaydiina dhulkuu ku tuuray,
\q1 Oo wuxuu iga dhigay inaan meelo gudcur ah dego, sidii kuwii waagii hore dhintay.
\q1 
\v 4 Sidaas daraaddeed ayaa ruuxaygu iigu dhex itaal darnaadaa,
\q1 Qalbigayguna gudahayguu ku cidloobay.
\q1 
\v 5 Waxaan soo xusuustaa wakhtigii hore,
\q1 Falimahaaga oo dhanna waan ka fikiraa,
\q1 Oo waxaan fiiro u yeeshaa shuqulkii gacmahaaga.
\q1 
\v 6 Gacmahaygaan kuu hoorsadaa,
\q1 Oo naftaydu adigay kuu harraaddaa sida dhul oommane ah. (Selaah)
\q1 
\v 7 Rabbiyow, dhaqso iigu soo jawaab, waayo, naftaydu way itaal darnaataa.
\q1 Wejigaaga ha iga qarin,
\q1 Waaba intaasoo aan noqdaa sida kuwa godka ku dhaca oo kale.
\q1 
\v 8 Aroorta naxariistaada i maqashii,
\q1 Waayo, adigaan isku kaa halleeyaa,
\q1 I garansii sidii aan u socon lahaa,
\q1 Waayo, naftaydaan kor kuugu qaadaa.
\q1 
\v 9 Rabbiyow, cadaawayaashayda iga samatabbixi,
\q1 Waayo, adaan kugu soo cararaa inaad i qariso.
\q1 
\v 10 I bar si aan doonistaada u sameeyo, waayo, waxaad tahay Ilaahayga,
\q1 Ruuxaaga wanaagsanu ha igu dhex hoggaamiyo dalka qummanaanta.
\q1 
\v 11 Rabbiyow, ii soo noolee magacaaga daraaddiis,
\q1 Oo xaqnimadaada naftayda kaga soo bixi dhibaato.
\q1 
\v 12 Oo raxmaddaada cadaawayaashayda ku wada tirtir,
\q1 Kuwa naftayda dhiba oo dhanna baabbi'i,
\q1 Waayo, waxaan ahay addoonkaaga.
\c 144
\s2 Kanu waa sabuur Daa'uud tiriyey.
\q1 
\v 1 Mahad waxaa leh Rabbiga dhagaxayga weyn ah,
\q1 Oo gacmahayga dagaalka bara,
\q1 Farahaygana dirirta bara,
\q1 
\v 2 Kaasoo ah raxmaddayda, iyo qalcaddayda,
\q1 Munaaraddayda, iyo samatabbixiyahayga,
\q1 Iyo gaashaankayga, iyo kan aan isku halleeyo,
\q1 Oo dadkayga ka yeela kuwo iga hooseeya.
\q1 
\v 3 Rabbiyow, waa maxay dadku oo aad u xusuusataa isaga?
\q1 Ama wiilka aadanaha oo aad ka fikirtaa isaga?
\q1 
\v 4 Dadku waa sida wax aan waxtar lahayn,
\q1 Oo cimrigiisuna waa sida hooska libdha.
\q1 
\v 5 Rabbiyow, samooyinkaaga foorori, oo soo dhaadhac,
\q1 Buuraha taabo, oo iyana way qiiqi doonaan.
\q1 
\v 6 Hillaac soo tuur, oo iyaga kala firdhi,
\q1 Fallaadhahaaga soo gan, oo iyaga jebi.
\q1 
\v 7 Gacantaada kor ka soo fidi,
\q1 Oo i badbaadi, oo iga samatabbixi biyaha badan,
\q1 Iyo gacanta shisheeyayaasha,
\q1 
\v 8 Kuwaasoo afkoodu wax bilaash ah ku hadlo,
\q1 Gacantooda midigna tahay midig beeneed.
\q1 
\v 9 Ilaahow, gabay cusub ayaan kuugu gabyi doonaa,
\q1 Oo waxaan ammaan kuugu gabyi doonaa shareerad toban xadhig leh.
\q1 
\v 10 Waa isaga kan boqorrada badbaadiyaa,
\q1 Oo addoonkiisa Daa'uud ka badbaadiya seefta sharka leh.
\q1 
\v 11 I badbaadi, oo iga samatabbixi gacanta shisheeyayaasha,
\q1 Kuwaasoo afkoodu wax bilaash ah ku hadlo,
\q1 Gacantooda midigna tahay midig beeneed.
\q1 
\v 12 Markii wiilashayadu ay noqdaan sidii geedo yaraantoodii ku koray,
\q1 Oo gabdhahayaguna ay noqdaan sidii dhagaxyada rukunka oo loo qoray qaabkii guriga boqorka,
\q1 
\v 13 Markii maqsinnadayadu ay buuxsamaan iyagoo na siinaya alaab cayn kasta ah,
\q1 Idahayaguna ay noo dhalaan kumanyaal iyo kumaankun oo berrimmada noo jooga,
\q1 
\v 14 Markii dibidayadu ay aad u xoogaystaan,
\q1 Markaan la arag weerarid iyo qaxid,
\q1 Oo aan cabasho jirin jidadkayaga dhexdooda,
\q1 
\v 15 Waxaa faraxsan dadkii xaalkoodu sidaas yahay,
\q1 Haah, oo waxaa faraxsan dadkii Rabbigu Ilaahooda yahay.
\c 145
\s2 Kanu waa sabuur ammaan ah oo Daa'uud tiriyey.
\q1 
\v 1 Ilaahayow, Boqorow, anigu waan ku sarraysiin doonaa,
\q1 Oo magacaagana waan ammaani doonaa weligay iyo weligayba.
\q1 
\v 2 Maalin kasta mahad baan kuu naqi doonaa,
\q1 Oo magacaagana waan ammaani doonaa weligay iyo weligayba.
\q1 
\v 3 Rabbigu waa weyn yahay, oo waa in aad loo ammaano,
\q1 Weynaantiisuna waa mid aan la baadhi karin.
\q1 
\v 4 Farcanba farcan ayuu shuqulladaada u ammaani doonaa,
\q1 Oo waxay ka warrami doonaan falimahaaga waaweyn.
\q1 
\v 5 Anigu waxaan ka fikiri doonaa haybadda ammaanta leh oo sharaftaada,
\q1 Iyo shuqulladaada yaabka badan.
\q1 
\v 6 Dadku waxay ka hadli doonaan xooggii falimahaaga cabsida badan,
\q1 Oo anna waxaan sheegi doonaa weynaantaada.
\q1 
\v 7 Waxay ku hadli doonaan wanaaggaaga badan xusuustiisa,
\q1 Xaqnimadaadana way ka gabyi doonaan.
\q1 
\v 8 Rabbigu waa nimco miidhan, oo waxaa ka buuxda raxmad,
\q1 Cadhona wuu u gaabiyaa, wuuna naxariis badan yahay.
\q1 
\v 9 Rabbigu wax kasta wuu u roon yahay,
\q1 Naxariistiisuna waxay ka sarraysaa shuqulladiisa oo dhan.
\q1 
\v 10 Rabbiyow, shuqulladaada oo dhammu way kugu mahadnaqi doonaan,
\q1 Oo quduusiintaaduna way ku ammaani doonaan.
\q1 
\v 11 Waxay ka hadli doonaan sharafta boqortooyadaada,
\q1 Oo waxay ka sheekaysan doonaan xooggaaga,
\q1 
\v 12 Si ay binu-aadmiga u ogeysiiyaan Ilaah falimihiisa waaweyn,
\q1 Iyo ammaanta haybadda boqortooyadiisa.
\q1 
\v 13 Boqortooyadaadu waa boqortooyo daa'imis ah,
\q1 Oo dawladnimadaaduna way sii waartaa tan iyo ab ka ab.
\q1 
\v 14 Rabbigu wuu tiiriyaa kuwa kufa oo dhan,
\q1 Oo wuxuu toosiyaa kuwa gota oo dhan.
\q1 
\v 15 Wax kasta indhahoodu adigay wax kaa sugayaan,
\q1 Oo quudkoodana waad siisa xilligiisa.
\q1 
\v 16 Gacantaadaad furtaa,
\q1 Oo waxaad dherjisaa wax kasta oo nool.
\q1 
\v 17 Rabbigu jidadkiisa oo dhan wuu ku qumman yahay,
\q1 Oo shuqulladiisa oo dhanna wuu ku nimco badan yahay.
\q1 
\v 18 Rabbigu waa u dhow yahay inta isaga barida oo dhan,
\q1 Kuwaas oo ah inta runta ku barida oo dhan.
\q1 
\v 19 Kuwa isaga ka cabsada waxay doonayaanba wuu siin doonaa,
\q1 Oo weliba qayladoodana wuu maqli doonaa, wuuna badbaadin doonaa iyaga.
\q1 
\v 20 Rabbigu inta isaga jecel oo dhan wuu ilaaliyaa,
\q1 Laakiinse kuwa sharka leh oo dhan wuu wada baabbi'in doonaa.
\q1 
\v 21 Afkaygu wuxuu ku hadli doonaa ammaanta Rabbiga,
\q1 Oo inta jidh leh oo dhammuna magiciisa quduuska ah ha ammaaneen weligood iyo weligoodba.
\b
\c 146
\q1 
\v 1 Rabbiga ammaana.
\q1 Naftaydoy, Rabbiga ammaan.
\q1 
\v 2 Intaan noolahay oo dhan Rabbiga waan ammaani doonaa,
\q1 Oo ammaan baan Ilaahay ugu gabyi doonaa intaan jiro oo dhan.
\q1 
\v 3 Ha isku hallaynina amiirrada
\q1 Iyo binu-aadmiga aan waxba caawimi karin.
\q1 
\v 4 Naftiisu way ka baxdaa, oo wuxuu ku noqdaa dhulkiisii.
\q1 Oo isla maalintaas ayaa fikirradiisu baabba'aan.
\q1 
\v 5 Waxaa faraxsan ninkii ay caawimaaddiisu tahay Ilaaha reer Yacquub,
\q1 Oo rajadiisuna ay ku xidhan tahay Rabbiga Ilaahiisa ah,
\q1 
\v 6 Oo sameeyey cirka iyo dhulka,
\q1 Iyo badda iyo waxyaalaha ku jira oo dhan,
\q1 Oo runtana dhawra weligiisba,
\q1 
\v 7 Oo kuwa la dulmay u garsoora,
\q1 Oo kuwa gaajaysanna quud siiya.
\q1 Rabbigu maxaabiistuu furaa.
\q1 
\v 8 Rabbigu indhahuu u bixiyaa indhoolayaasha,
\q1 Oo kuwa gotana Rabbigaa toosiya,
\q1 Oo kuwa xaqa ahna Rabbigu waa jecel yahay.
\q1 
\v 9 Rabbigu waa ilaaliyaa kuwa qariibka ah,
\q1 Oo isagaa taageera agoonta iyo carmallada,
\q1 Laakiinse jidka kuwa sharka leh wuu qalloociyaa.
\q1 
\v 10 Rabbigu xukun buu haysan doonaa weligiis,
\q1 Siyoonay, Ilaahaagaa boqor ah tan iyo ab ka ab.
\q1 Rabbiga ammaana.
\b
\c 147
\q1 
\v 1 Rabbiga ammaana.
\q1 Waayo, way wanaagsan tahay in Ilaaheenna ammaan loogu gabyo,
\q1 Waayo, taasu way wacan tahay, oo ammaantuna way habboon tahay.
\q1 
\v 2 Rabbigu Yeruusaalem buu dhisaa,
\q1 Oo wuxuu isu soo wada ururiyaa kuwa la naco oo reer binu Israa'iil ah.
\q1 
\v 3 Isagaa bogsiiya kuwa qalbi jabay,
\q1 Oo nabrahoodana wuu duubaa.
\q1 
\v 4 Wuxuu sheegaa xiddigaha tiradooda,
\q1 Oo kulligoodna magacyo buu u bixiyaa.
\q1 
\v 5 Sayidkeennu waa weyn yahay, wuuna xoog badan yahay,
\q1 Waxgarashadiisuna waa mid aan la koobi karayn.
\q1 
\v 6 Rabbigu wuu tiiriyaa kuwa camalka qabow,
\q1 Oo kuwa sharka lehna dhulkuu ku soo tuuraa.
\q1 
\v 7 Rabbiga mahadnaqid ugu gabya,
\q1 Oo kataaradda ammaan ugu gabya Ilaaheenna,
\q1 
\v 8 Kaasoo samada daruuro ku qariya,
\q1 Oo dhulka roob u diyaarsha,
\q1 Buurahana doog ka soo bixiya.
\q1 
\v 9 Wuxuu quud siiyaa xayawaanka,
\q1 Iyo tukayaasha yaryar markay qayliyaanba.
\q1 
\v 10 Isagu kuma farxo xoogga faraska,
\q1 Oo kuma reyreeyo lugaha dadka.
\q1 
\v 11 Rabbigu wuxuu ku reyreeyaa kuwa isaga ka cabsada,
\q1 Iyo kuwa naxariistiisa rajada ka qaba.
\q1 
\v 12 Yeruusaalemay, Rabbiga ammaan,
\q1 Siyoonay, Ilaahaaga ammaan.
\q1 
\v 13 Waayo, wuxuu xoogeeyey qataarrada irdahaaga,
\q1 Carruurtaadana wuu kugu dhex barakeeyey.
\q1 
\v 14 Soohdimahaaga nabad buu ka dhigaa,
\q1 Oo wuxuu kaa dhergiyaa sarreenka ugu wanaagsan.
\q1 
\v 15 Amarkiisa wuxuu u soo diraa dhulka,
\q1 Eraygiisuna aad buu u dheereeyaa.
\q1 
\v 16 Baraf cad wuxuu u soo daadshaa sida dhogor oo kale,
\q1 Sayax barafoobayna wuxuu u kala firdhiyaa sida dambas oo kale.
\q1 
\v 17 Barafkiisa wuxuu u soo ridaa sida jajab oo kale,
\q1 Bal yaa qabowgiisa hor istaagi kara?
\q1 
\v 18 Wuxuu soo diraa eraygiisa, oo wuu dhalaaliyaa iyaga,
\q1 Dabayshiisana wuxuu ka dhigaa inay dhacdo, biyuhuna way qulqulaan.
\q1 
\v 19 Eraygiisa wuxuu tusaa reer Yacquub,
\q1 Qaynuunnadiisa iyo xukummadiisana reer binu Israa'iil.
\q1 
\v 20 Quruunna sidaas oo kale uma uu samayn.
\q1 Xukummadiisiina ma ay garanaynin,
\q1 Rabbiga ammaana.
\b
\c 148
\q1 
\v 1 Rabbiga ammaana.
\q1 Rabbiga samooyinka ka ammaana,
\q1 Meelaha sarsarena ka ammaana.
\q1 
\v 2 Malaa'igihiisa oo dhammow, ammaana isaga,
\q1 Ciidankiisa oo dhammow, ammaana isaga.
\q1 
\v 3 Qorraxda iyo dayaxow, ammaana isaga,
\q1 Xiddigaha iftiinka oo dhammow, ammaana isaga.
\q1 
\v 4 Ammaana isaga, samooyinka samooyinkow,
\q1 Iyo biyaha samooyinka ka sarreeyow.
\q1 
\v 5 Iyagu magaca Rabbiga ha ammaaneen,
\q1 Waayo, isagu wuu amray, oo iyana way abuurmeen.
\q1 
\v 6 Oo weliba isagaa adkeeyey iyaga weligood iyo weligoodba,
\q1 Oo wuxuu sameeyey xad aan la gudbi doonayn.
\q1 
\v 7 Rabbiga dhulka ka ammaana,
\q1 Masbadeedyo iyo moolal oo dhammow,
\q1 
\v 8 Dab iyo roobdhagaxyaale, baraf cad iyo ceeryaamow,
\q1 Iyo dabayl duufaan ah oo eraygiisa oofiyow,
\q1 
\v 9 Buuro iyo kuro oo dhammow,
\q1 Dhir midho badan iyo dhir kedar la yidhaahdo oo dhammow,
\q1 
\v 10 Dugaag iyo xoolo oo dhammow,
\q1 Waxa gurguurta iyo haadda duusha oo dhammow,
\q1 
\v 11 Boqorrada dhulka iyo dadyowga oo dhammow,
\q1 Amiirrada iyo xaakinnada dhulka oo dhammow,
\q1 
\v 12 Barbaar iyo hablow,
\q1 Odayaal iyo carruuray,
\q1 
\v 13 Ha ammaaneen magaca Rabbiga,
\q1 Waayo, magiciisa oo keliya ayaa la sarraysiiyaa,
\q1 Ammaantiisu dhulka iyo cirkaba way ka korraysaa.
\q1 
\v 14 Isagu wuxuu sare u qaaday geeskii dadkiisa,
\q1 Iyo ammaantii quduusiintiisa oo dhan,
\q1 Waana reer binu Israa'iil oo ah dad isaga u dhow.
\q1 Rabbiga ammaana.
\b
\c 149
\q1 
\v 1 Rabbiga ammaana.
\q1 Rabbiga gabay cusub ugu gabya,
\q1 Oo ammaantiisana shirka quduusiinta kaga dhex gabya.
\q1 
\v 2 Reer binu Israa'iil kii iyaga uumay ha ku reyreeyeen,
\q1 Oo reer Siyoonna boqorkooda ha ku farxeen.
\q1 
\v 3 Magiciisa cayaarta ha ku ammaaneen,
\q1 Oo ammaan ha ugu gabyeen iyagoo sita daf iyo kataarad.
\q1 
\v 4 Waayo, Rabbigu wuxuu ku farxaa dadkiisa,
\q1 Wuxuu kuwa camalka qabowna ku qurxin doonaa badbaado.
\q1 
\v 5 Quduusiintu ammaan ha ku reyreeyeen,
\q1 Oo farxad ha ku gabyeen iyagoo sariirahooda jiifa.
\q1 
\v 6 Ammaanta sare oo Ilaah afkooda ha ku jirto,
\q1 Seef laba af lahuna gacantooda ha ku jirto,
\q1 
\v 7 Si ay quruumaha uga aargutaan,
\q1 Oo ay dadyowgana u ciqaabaan,
\q1 
\v 8 Si ay boqorradooda silsilado ugu soo xidhaan,
\q1 Oo ay raggooda gobta ahna jeebbooyin bir ah ugu soo xidhaan,
\q1 
\v 9 Si ay iyaga ugu soo dejiyaan xukunka qoran,
\q1 Quduusiintiisa oo dhammuna waxay leeyihiin sharaftan.
\q1 Rabbiga ammaana.
\b
\c 150
\q1 
\v 1 Rabbiga ammaana.
\q1 Ilaah ku dhex ammaana meeshiisa quduuska ah,
\q1 Ku dhex ammaana samada xooggiisa.
\q1 
\v 2 Falimihiisa waaweyn aawadood u ammaana,
\q1 U ammaana si waafaqsan weynaantiisa sare.
\q1 
\v 3 Dhawaaqa buunka ku ammaana,
\q1 Oo shareerad iyo kataarad ku ammaana.
\q1 
\v 4 Ku ammaana daf iyo cayaar,
\q1 Oo ku ammaana alaab xadhko leh oo muusiko ah iyo biibiile.
\q1 
\v 5 Suxuunta laysku garaaco oo codka dheer ku ammaana,
\q1 Ku ammaana suxuunta sanqadha dheer.
\q1 
\v 6 Wax kasta oo neef lahuba Rabbiga ha ammaaneen.
\q1 Rabbiga ammaana.
