\id PRO – ESR Marek Olah Unicode
\h Prislovja
\toc1 O Prislovja
\toc2 Prislovja
\toc3 Pri
\mt1 O Prislovja
\mt2 O Goďaver lava
\c 1
\s1 Pre soste hin o goďaver lava
\q1 
\v 1 O goďaver lava le Šalamunoskre, le Davidoskre čhaskre, le Izraeloskre kraľiskre.
\q1 
\v 2 Kala prislovja tuke pomožinena
\q1 te prindžarel o goďaveripen,
\q1 bararena tut avri,
\q1 dena tuke te achaľol o goďaver lava;
\q1 
\v 3 sikavena tut sar te dživel andre bari goďi,
\q1 te kerel, so hin lačho, čačipnaskro the spravno;
\q1 
\v 4 le manušes, saves nane goďi, dena goďi
\q1 a le terne manušes dena o prindžaripen the o achaľuvipen.
\q1 
\v 5 O goďaver manuš len mi šunel a mi barvaľol andro prindžaripen,
\q1 a oda, ko hino avrisikado, mi prilel e lačhi rada,
\q1 
\v 6 hoj te achaľol o goďaver lava the o podobenstva,
\q1 o lava le goďavere manušengre the lengro garuďipen.
\q1 
\v 7 O prindžaripen chudel la sveta daraha anglo RAJ;
\q1 ča o diline dikhen tele o goďaveripen the o sikaviben.
\s1 De pozoris pro nalačhe manuša
\q1 
\v 8 Čhavo miro, šun, so tuke phenel tiro dad
\q1 a ma omuk oda, so tut sikavel tiri daj,
\q1 
\v 9 bo oda hin sar o šukar vencos pre tiro šero
\q1 a sar o lancocis pre tiri meň.
\b
\q1 
\v 10 Čhavo miro, te tut o binošna manuša cirdena te kerel o nalačho, phen lenge na.
\q1 
\v 11 Te phenena: „Av amenca, arakhaha varekas a murdaraha les!
\q1 Av chučaha pre varekaste, ko amen ňič na kerďa!
\q1 
\v 12 Av, zachas leskro dživipen sar o Šeol\f + \fr 1,12 \ft Oda hin o than, kaj hine o mule.\f*
\q1 a chas les calones sar oles, ko džal tele andre chev.
\q1 
\v 13 Laha peske savoro barvaľipen
\q1 a pherdžaraha le čorde vecenca amare khera.
\q1 
\v 14 Av amenca andre partija
\q1 a rozďelinaha pes savoreha.“
\q1 
\v 15 Čhavo miro, ma dža kajse dženenca,
\q1 a ma thov tiro pindro pre lengre droma.
\q1 
\v 16 Se lengre pindre denašen te kerel o nalačho
\q1 a siďaren te čhorel avri o rat.
\q1 
\v 17 Te o čiriklo dikhel,
\q1 sar nacirdes e sita,
\q1 na chudela pes,
\q1 
\v 18 ale on nacirden e sita prekal peste
\q1 a keren e pasca, andre savi korkore merena.
\q1 
\v 19 Kada pes ačhel savorenge,
\q1 savenge džal pal o nalačho ziskos:
\q1 o nalačho ziskos lenge lel o dživipen.
\s1 O goďaveripen vakerel
\q1 
\v 20 O goďaveripen vičinel avri pro uľici,
\q1 zorales vakerel pro pľaci.
\q1 
\v 21 Zoraha vičinel paš o brani le foroskre,
\q1 vakerel všadzik, kaj hine zgele but manuša:
\q1 
\v 22 Tumen diline, dži kana kamena o nagoďaveripen?
\q1 Tumen, so asan, dži kana kamen te asal?
\q1 Dži kana o diline na kamena o prindžaripen?
\q1 
\v 23 Prilen mandar, sar tumenge dovakerav!
\q1 A me tumenge anava avri oda, so man hin andro jilo,\f + \fr 1,23 \ft E hebrejiko čhib: Me pre tumende čhivava avri mire duchos.\f*
\q1 a dava tumenge te prindžarel mire lava.
\q1 
\v 24 Ale vašoda, hoj tumen na kamenas te šunel, sar me vičinavas,
\q1 a ňiko na ačhelas olestar, hoj me nacirdavas miro vast,
\q1 
\v 25 vašoda, hoj dikhenas tele miri rada,
\q1 a na priiľan mandar o lava, sar tumenge dovakeravas,
\q1 
\v 26 asava tumendar, sar pre tumende avela o pharipen
\q1 a sar pre tumende demela e pohroma;
\q1 
\v 27 sar pre tumende avela o pharipen sar e burka
\q1 a e bari pohroma pre tumende demela sar e zoraľi balvaj,
\q1 sar tumenge ela phares a cerpinena,
\q1 
\v 28 akor pre mande vičinena, ale me man na dava anglal,
\q1 igen man rodena, ale na arakhena man,
\q1 
\v 29 vašoda, bo našťi avri ačhenas o prindžaripen,
\q1 a na sas tumen e sveto dar anglo Raj,
\q1 
\v 30 miri rada dikhenas tele
\q1 a visarenas tumen mange le dumeha,
\q1 sar tumenge dovakeravas.
\q1 
\v 31 Akana chana o ovocje olestar, sar dživenas,
\q1 a čaľona le nalačhipnastar, so kerenas.
\q1 
\v 32 O nagoďaver merena, bo odgele le goďaveripnastar,
\q1 a o diline ena zňičimen, bo lenge sas mištes avke te dživel.
\q1 
\v 33 Ale oda, ko man šunel, pes na mušinel te daral,
\q1 dživela andro smirom a na darala pes le nalačhipnastar.
\c 2
\s1 So anel o goďaveripen
\q1 
\v 1 Čhavo miro, te prileha mire lava,
\q1 a doľikeraha, so tuke prikazinav,
\q1 
\v 2 te šuneha oda, so hin goďaver,
\q1 a kameha oleske te achaľol,
\q1 
\v 3 te tuke mangeha o goďaveripen
\q1 a te zorales vičineha, hoj te achaľos,
\q1 
\v 4 te oda rodeha avke sar o rup
\q1 a kameha oda te arakhel avke sar o garudo barvaľipen,
\q1 
\v 5 akor achaľoha, so hin e sveto dar le RAJESTAR,
\q1 a arakheha o prindžaripen pal o Del.
\q1 
\v 6 Bo o RAJ del e goďi
\q1 a andral leskro muj avel o goďaveripen the o prindžaripen.
\q1 
\v 7 Ov pomožinel olenge, ko hine čačipnaskre,
\q1 a chraňinel olen, ko dživen žužes;
\q1 
\v 8 ov stražinel olen, ko pes ľikeren mištes ke aver džene,
\q1 a dodikhel pre ola, ko leske hine verna.
\b
\q1 
\v 9 Akor achaľoha, so hin lačho, čačipnaskro
\q1 a spravno; džaneha, sar kampel te dživel,
\q1 
\v 10 bo o goďaveripen tuke džala andro jilo
\q1 a o prindžaripen tuke anela o radišagos pre duša.
\q1 
\v 11 O spravno gondoľišagos pre tu dela pozoris
\q1 a o achaľuvipen tut stražinela;
\q1 
\v 12 ochraňinela tut, hoj te na džas pro nalačhe droma
\q1 a hoj te na pačas le manušenge, save vakeren o previsarde lava;
\q1 
\v 13 olenge, ko omukle o rovna droma
\q1 a gele pro bange droma andro kaľipen.
\q1 
\v 14 On radisaľon, sar keren o nalačhipen
\q1 a thoven o baripen andro previsarde veci.
\q1 
\v 15 Kale manušengre droma hine bange
\q1 a lengre chodňiki hine nalačhe.
\s1 Ma dža pro drom la lubňakro
\q1 
\v 16 O goďaveripen tut zachraňinela la lubňatar;
\q1 la avra džuvľatar, savi pes tuke guľarel le lavenca,
\q1 
\v 17 savi omukľa le romes, saves peske iľa, sar sas terňi,
\q1 a bisterďa pre zmluva, so kerďa anglo Del.
\q1 
\v 18 O drom andre lakro kher ľidžal andro meriben,
\q1 bo džal tele andro than le mulengro.
\q1 
\v 19 Ňiko olendar, ko džal ke late, na avel pale,
\q1 a šoha pes na visarel pale pro drom le dživipnaskro.
\b
\q1 
\v 20 Vašoda phir pal o drom le lačhe manušengro
\q1 the pal o chodňikos le spravodľive manušengro.
\q1 
\v 21 Bo o pačivale bešena andre phuv
\q1 a o žuže anglo Del ačhena andre,
\q1 
\v 22 ale o bijedevleskre ena avričhide
\q1 a o napačivale ena avricirdle le koreňenca.
\c 3
\s1 O goďaveripen anel o požehnaňje
\q1 
\v 1 Čhavo miro, ma bister pre oda, so tut sikaďom,
\q1 a ľiker andro jilo mire prikazi.
\q1 
\v 2 Miro sikaviben tuke dothovela o berša ko dživipen
\q1 a anela tuke o smirom.
\q1 
\v 3 O verno kamiben the e vernosť tut te na omukel;
\q1 phand tuke len pašal e meň,
\q1 a pisin tuke len andre tiro jilo,
\q1 
\v 4 kaleha tut ela e pačiv the baro nav
\q1 anglo Del the anglo manuša.
\q1 
\v 5 Pača cale jileha le RAJESKE
\q1 a ma muk tut pre tiri goďi.
\q1 
\v 6 Pridžan tut ke leste pre savore tire droma
\q1 a ov tuke rovňinela avri o chodňiki.
\q1 
\v 7 Ma av goďaver andre tire jakha,
\q1 ale šun le RAJES a visar tut het le nalačhestar.
\q1 
\v 8 Te ada kereha, sasťola tiro ťelos
\q1 a tire kokala zoraľona.
\q1 
\v 9 De pačiv le RAJES andral tiro barvaľipen
\q1 the andral o ešebno ovocje savore uľipnastar.
\q1 
\v 10 Te kada kereha, ela tut pherdo zrnos andre tire stodoli
\q1 a tire sudi prečuľana la neva moľaha.
\q1 
\v 11 Čhavo miro, ma odvisar tut le RAJESKRE dovakeribnastar
\q1 a ma choľisaľuv, sar tuke priphenel.
\q1 
\v 12 Bo o RAJ dovakerel oleske, kas kamel,
\q1 avke sar o dad le čhaske, saves rado dikhel.
\q1 
\v 13 Bachtalo hin o manuš, savo arakhľa o goďaveripen,
\q1 o murš, savo dochudňa o achaľuvipen.
\q1 
\v 14 Oda mol buter sar o rup
\q1 a dela tut oda, so hin feder sar o somnakaj.
\q1 
\v 15 Te el goďaver hin vzacneder sar o diamanti;
\q1 ňič, so kames, nane ajso sar o goďaveripen.
\q1 
\v 16 O goďaveripen ľikerel andre jekh vast o baro dživipen
\q1 a andre dujto o barvaľipen the e slava;
\q1 
\v 17 leskre droma tut dena o šukar dživipen
\q1 a leskre chodňiki tuke anena o smirom.
\q1 
\v 18 O goďaveripen hin o stromos le dživipnaskro olenge,
\q1 ko pes lestar chuden,
\q1 a požehňimen hine, save pes lestar ľikeren.
\q1 
\v 19 Le goďaveripnaha o RAJ zathoďa la phuvakre zakladi
\q1 a o ňebos ačhaďa la goďaha.
\q1 
\v 20 Peskra goďaha diňa,
\q1 hoj o bare paňa te demen avri andral e phuv
\q1 a andral o chmari te perel o brišind.
\q1 
\v 21 Čhavo miro, ľiker tut le goďaveripnastar the le achaľuvipnastar;
\q1 šoha lenge ma domuk, te džan tutar het:
\q1 
\v 22 Dena tut o dživipen
\q1 a anena tuke e pačiv anglo manuša,
\q1 
\v 23 avke phireha andro smirom
\q1 a o pindro tuke na poddžala.
\q1 
\v 24 Rači, sar džaha te sovel, na daraha tut
\q1 a soveha tuke andro smirom.
\q1 
\v 25 Na mušines te daral, hoj pes jekhvareste vareso ačhela,
\q1 abo te daral le burkendar, so aven pro bijedevleskre.
\q1 
\v 26 Bo o RAJ ačhela pal tiri sera
\q1 a na mukela tiro pindro te uštarel andre pasca.
\s1 O kamiben ko aver manuša
\q1 
\v 27 Te tut hin pre oda,
\q1 pomožin le manušenge, save peske oda zaslužinen.
\q1 
\v 28 Ma phen tire susedaske:
\q1 „Dža, av pale tajsa a dava tut,“
\q1 te oda hin paš tu.
\q1 
\v 29 Ma gondoľin, sar te dukhavel varekas,
\q1 ko dživel pašes paš tu a pačal tuke.
\q1 
\v 30 Ma vaker pre ňikaste ča avke,
\q1 te tut na kerďa ňič nalačho.
\q1 
\v 31 Ma zavidzin le manušeske, savo pes marel,
\q1 a ma ker avke sar ov,
\q1 
\v 32 bo o RAJ kajse manušen našťi avri ačhel,
\q1 ale hino prijaťeľis le čačipnaskre manušenca.
\q1 
\v 33 O prekošiben le RAJESKRO hin pro kher le bijedevleskro,
\q1 ale o kher le čačipnaskro ela požehňimen.
\q1 
\v 34 O RAJ asal avri olen, save asan,
\q1 no le pokornen del peskri milosť.
\q1 
\v 35 O goďaver manuša chudena e pačiv,
\q1 ale o diline peske lena e ladž.
\c 4
\s1 Le dadeskro dovakeriben
\q1 
\v 1 Čhave mire, šunen le dadeskro sikaviben;
\q1 te dena pozoris, achaľuvena, so hin goďaver.
\q1 
\v 2 Oda, so tumen me sikavav, hin lačho,
\q1 vašoda ma omuken oda.
\q1 
\v 3 The me somas cikno čhavoro le dadeskro,
\q1 ča jekhoro mira dakro,
\q1 
\v 4 miro dad man sikavelas a phenďa:
\q1 „Ľiker mire lava andro jilo,
\q1 doľiker mire prikazi a dživeha.
\q1 
\v 5 Dochude o goďaveripen the o achaľuvipen!
\q1 Ma bister pre mire lava a ma visar tut olestar, so vakerav.
\q1 
\v 6 Ma muk o goďaveripen a chraňinela tut,
\q1 kam les a stražinela tut.
\q1 
\v 7 Ešebno goďaveripen, so šaj keres, hin kada:
\q1 Dochude o goďaveripen
\q1 a cin tuke o achaľuvipen vaš savoro, so tut hin.
\q1 
\v 8 Kam o goďaveripen a kerela tutar baro,
\q1 obchude les a dela tut pačiv.
\q1 
\v 9 Thovela tuke pro šero o šukar vencos
\q1 a dela tut e vzacno koruna.“
\b
\q1 
\v 10 Šun man, čhavo miro,
\q1 prile mire lava
\q1 a dživeha but berš.
\q1 
\v 11 Me tuke sikaďom o goďaveripnaskro drom
\q1 a ľigenďom tut le čačipnaskre chodňikenca.
\q1 
\v 12 Sar phireha, na zaačhavela tut ňič;
\q1 te denašeha, na poddžala tuke o pindro.
\q1 
\v 13 Chude tut zorales mire sikavibnastar, ma domuk les te džal het,
\q1 stražin tuke les, bo hino tiro dživipen.
\q1 
\v 14 Ma dža pro chodňikos le bijedevleskre manušengro
\q1 a ma phir pal o drom le nalačhe manušengro.
\q1 
\v 15 Obdža oda drom a ma phir odarik,
\q1 visar tut a dža avre dromeha.
\q1 
\v 16 Bo on na džana te sovel, te na kerena o nalačhipen,
\q1 našťi zasovena, medik varekaske na podthovena o pindre.
\q1 
\v 17 O bijedevleskeriben hin lenge sar o maro
\q1 a o mariben sar e mol.
\b
\q1 
\v 18 O chodňikos le čačipnaskerengro hino sar o tosaraskro kham,
\q1 so švicinel zoraleder the zoraleder medik nane o džives.
\q1 
\v 19 O chodňikos le bijedevleskerengro hin sar baro kaľipen,
\q1 a vašoda na džanen, pre soste šaj peren.
\b
\q1 
\v 20 Čhavo miro, de pozoris pre mire lava
\q1 a šun mištes, so tuke vakerav!
\q1 
\v 21 Ľiker tuke len anglo jakha
\q1 a garuv len andro jilo.
\q1 
\v 22 Kala lava hine o dživipen olenge, ko len arakhen,
\q1 a hine pro sasťipen cale lengre ťeloske.
\q1 
\v 23 Nekbuter savorestar tuke chraňin tiro jilo,
\q1 bo lestar avel o dživipen.
\q1 
\v 24 Le avri o klamišagos andral tiro muj
\q1 a de tutar het o vušta, so na vakeren o čačipen.
\q1 
\v 25 Tire jakha mi dikhen anglal peste
\q1 a te na dikhen avrether pre sera.
\q1 
\v 26 Rovňin avri o chodňikos tire pindrenge
\q1 a savore tire droma ena zorale.
\q1 
\v 27 Ma dža pre čači aňi pre baľogňi sera
\q1 a ma uštar tire pindreha andro nalačhipen.
\c 5
\s1 Ma dža pal aver džuvľi
\q1 
\v 1 Čhavo miro, šun mištes miro goďaveripen
\q1 a visar tiro kan paš mire lava, hoj te achaľos.
\q1 
\v 2 Avke tut džaneha mištes te ľikerel
\q1 a le lavenca sikaveha, hoj tut hin o prindžaripen.
\q1 
\v 3 Pal o vušta la avra džuvľake čuľal o medos
\q1 a lakri čhib hiňi hladko sar olejos,
\q1 
\v 4 ale pro koňec hiňi kirko sar e palina
\q1 a ostro sar e šabľa, so čhinel pal soduj seri.
\q1 
\v 5 Lakre pindre ľidžan andro meriben
\q1 a lakre kroki tele andro Šeol.
\q1 
\v 6 Oj na ačhel pro drom, so ľidžal ko dživipen,
\q1 ale phirel banges a aňi olestar na džanel.
\q1 
\v 7 Vašoda akana, čhave mire, šunen man
\q1 a ma visaren tumen het olestar, so tumenge phenav.
\q1 
\v 8 Ačh dur kajsa džuvľatar
\q1 a ma dža aňi paš o vudar lakre khereskro!
\q1 
\v 9 Bo te oda kereha, našaveha tiri pačiv paš aver džene
\q1 a o bijileskro manuš tuke lela o dživipen;
\q1 
\v 10 aver džene lena tiro barvaľipen
\q1 a oda, pre soste tu kerehas, ela aver dženeskro.
\q1 
\v 11 Paš o meriben jojčineha dukhatar,
\q1 sar tuke o nasvaľiben chala calo ťelos.
\q1 
\v 12 Paľis pheneha: „Sar na kamavas, hoj mange te dovakeren!
\q1 Na davas mange ňikastar te phenel!
\q1 
\v 13 Soske na kamavas te šunel mire učiťeľen?
\q1 Soske na šunavas olen, ko man kamenas te sikavel?
\q1 
\v 14 Akana som jekhvareste calkom zňičimen
\q1 a teledikhlo maškar amare manuša.“
\s1 Te kamel peskra romňa
\q1 
\v 15 Pi o paňi andral tiri chaňig,
\q1 o paňi, so avel andral tiri chaňigori!
\q1 
\v 16 Kames, hoj pes tire prameňa te rozčhiven avri pro uľici?
\q1 Soske te rozdes tiro kamiben avre džuvľenge andro foros?
\q1 
\v 17 Tiro kamiben hino ča prekal tiri romňi;
\q1 ma de les avra džuvľake!
\q1 
\v 18 Av požehňimen tire prameňistar
\q1 a radisaľuv tira romňatar, savaha sal terňipnastar!
\q1 
\v 19 Oj hiňi šukar a lačhi sar e terňi srnka!
\q1 Lakre koľina tuke mi anen furt o radišagos;
\q1 domuk lakre kamibnaske, hoj tut te zalel.
\q1 
\v 20 Čhavo miro, soske te des tiro kamiben avra džuvľake?
\q1 Soske te obchudes avra džeňa?
\q1 
\v 21 Se o RAJ dikhel pre dojekh tiro drom
\q1 a džanel savore tire krokendar.
\q1 
\v 22 Le bijedevleskres dochudena leskre nalačhipena;
\q1 ela phandlo andro puta peskre binengre.
\q1 
\v 23 Kajso manuš merela, bo na phenďa „Na“ peskre žadoscenge
\q1 a ela našado vaš peskro baro diliňipen, so kerďa.
\c 6
\s1 Ma zaručin tut
\q1 
\v 1 Čhavo miro, te tut zaručinďal vaš tiro susedas
\q1 a phandľal tut andre zmluva vaš aver manuš;
\q1 
\v 2 te tut zachudňal andre oda, so vakerehas le mujeha,
\q1 a zakerďal tut andro lava, so phenďal;
\q1 
\v 3 ta ker kada, čhavo miro, hoj tut te zachraňines,
\q1 bo dochudňal tut tel e zor avre dženeske:
\q1 Dža a igen tut leske mang, hoj tuha te zrušinel e zmluva;
\q1 
\v 4 ma de te sovel tire jakhenge
\q1 a ma dža te pašľol, medik leha na vakereha!
\q1 
\v 5 Le tut avri olestar, sar e srnka denašel le poľovňikoske,
\q1 sar o čiriklo ľecinel andral o vasta oleske, ko les chudel.
\s1 Pal o leňivo manuš
\q1 
\v 6 Tu, so sal leňivo, dža ko mravci,
\q1 dikh o dromora le mravcengre a sikľuv!
\q1 
\v 7 Kajte len nane vodcas abo veľiťeľis,
\q1 a ňiko pre lende na ačhel pre buči,
\q1 
\v 8 ňilaje peske skiden o chaben,
\q1 a sar hin e žatva, sthoven peske o maro.
\b
\q1 
\v 9 Leňivcona, dži kana kames te pašľol?
\q1 Kana ušťeha andral o soviben?
\q1 
\v 10 Te tuke phenes: „Mek sikra mange sovav, mek sikra mange pašľuvav,
\q1 sikra mange prethovav o vasta a odpočovinav mange,“
\q1 
\v 11 akor jekhvareste pre tu avela o čoripen sar o zbujňikos
\q1 the e bokh sar o vizbrojimen murš.
\s1 Pal o bijedevleskro manuš
\q1 
\v 12 O bijedevleskro the nalačho manuš hin oda,
\q1 ko furt vakerel o klamišagos,
\q1 
\v 13 džmurkinel la jakhaha,
\q1 le pindreha del te džanel
\q1 a sikavel le angušteha;
\q1 
\v 14 andre peskro previsardo jilo furt gondoľinel, sar te kerel o nalačhipen
\q1 a všadzik rozľidžal o vesekedišagi.
\q1 
\v 15 Vašoda pre leste avela jekhvareste o baro nasvaľiben,
\q1 ela zňičimen a ňič leske na pomožinela.
\s1 Oda, so džungľol le RAJESKE
\q1 
\v 16 Šov veci o RAJ našťi avri ačhel,
\q1 efta veci leske džungľol:
\q1 
\v 17 O barikane jakha;
\q1 e falošno čhib;
\q1 o vasta, so čhoren avri o ňevinno rat;
\q1 
\v 18 o jilo, so gondoľinel avri o nalačhipen;
\q1 o pindre, so igen siďaren te kerel o nalačho;
\q1 
\v 19 o falošno švedkos, savo vakerel o klamišagos,
\q1 the oda manuš, savo rozľidžal o vesekedišagi maškar o phrala.
\s1 Ma ker o lubipen
\q1 
\v 20 Čhavo miro, doľiker o prikazaňja tire dadeskre
\q1 a ma omuk tira dakro sikaviben!
\q1 
\v 21 Priphand tuke len pre tiro jilo pro furt
\q1 a zaker tuke len pašal tiri meň!
\q1 
\v 22 Sar džaha, ľidžana tut;
\q1 sar zasoveha, stražinena tut;
\q1 sar ušťeha andral o soviben, sikavena tut.
\q1 
\v 23 Kala prikazaňja hine sar e lampa, o sikaviben sar o švetlos,
\q1 o dovakeribena la kazňakre hine o drom le dživipnaskro,
\q1 
\v 24 so tut chraňinena la nalačha džuvľatar
\q1 the le gule lavendar avre muršeskra romňatar.
\b
\q1 
\v 25 Ma cirde tut pal lakro šukariben andre tiro jilo
\q1 a ma de tut lakre jakhenge te sphandel andre.
\b
\q1 
\v 26 O murš šaj peske cinel la lubňa vaš jekh maro,
\q1 ale avre dženeskri romňi leske kamel te lel o vzacno dživipen.
\q1 
\v 27 Šaj ľidžal o murš andre peskri žeba o jagale angara avke,
\q1 hoj peske te na labarel o gada?
\q1 
\v 28 Abo šaj phirel o manuš pal o jagale angara avke,
\q1 hoj peske te na labarel o pindre?
\q1 
\v 29 Avke ela oleha, ko džal te pašľol avra dženeskra romňaha,
\q1 sako, ko pes latar chudela, na ela bi o trestos.
\b
\q1 
\v 30 O manuša na dikhen tele le živaňis,
\q1 te peske čorel o chaben, sar hino bokhalo;
\q1 
\v 31 ale te les paš oda chuden, mušinel oda te visarel pale eftavar,
\q1 kajte les oda moľahas savoro barvaľipen, so les hin andro kher.
\q1 
\v 32 Ale oda, ko kerel o lubipen avra džuvľaha, našaďa e goďi;
\q1 ko ada kerel, zňičinela pes korkores.
\q1 
\v 33 Ajso dženo ela mardo a teledikhlo
\q1 a e ladž ačhela pre leste furt.
\b
\q1 
\v 34 Sar o rom žjarlinel pre džuvľi, igen choľisaľol
\q1 a na sajinela ole muršes, sar leske džala te del pale.
\q1 
\v 35 Ov na priačhela pre ňisave love;
\q1 na dela pes te prepočinel aňi but lovenca.
\c 7
\q1 
\v 1 Čhavo miro, ľiker tut mire lavendar
\q1 a mire prikazaňja doľiker!
\q1 
\v 2 Šun mire prikazi a dživeha.
\q1 Chraňin tuke miro sikaviben sar tiri jakh!
\q1 
\v 3 Phand len tuke pro angušta;
\q1 pisin len pre tabla tire jileskri!
\q1 
\v 4 Phen la goďake: „Tu sal miri pheň,“
\q1 a le achaľuvipnaske: „Tu sal miri famelija.“
\q1 
\v 5 Ochraňinena tut la avra džuvľatar,
\q1 lakre gule lavendar.
\s1 E nalačhi džuvľi
\q1 
\v 6 Jekhvar dikhavas andral miro kher
\q1 a prekal e oblaka dikhľom
\q1 
\v 7 terne nagoďaver muršen
\q1 a sas maškar lende jekh ajso,
\q1 savo našaďa e goďi.
\q1 
\v 8 Ov peske džalas la uľicaha dži pro agor,
\q1 phirelas le dromeha pašal lakro kher
\q1 
\v 9 rači, sar o kham zadžalas,
\q1 sar imar avelas e kaľi rat.
\b
\q1 
\v 10 Jekhvareste angle leste avľa odi džuvľi
\q1 le budžande gondoľišagoha,
\q1 urďi andro lubikane gada.
\q1 
\v 11 Kerelas vika a sas bi e ladž,
\q1 šoha na ačhelas but khere.
\q1 
\v 12 Jekhvar sas pre uľica a jekhvar maškar o foros,
\q1 pre dojekh rohos užarelas pre varekaste.
\q1 
\v 13 Obchudňa le terne muršes, čumidľa les
\q1 a bi e ladž leske phenďa:
\q1 
\v 14 „Adadžives doľikerďom mire lava, so diňom,
\q1 a mek mange ačhiľa mas pal e smiromoskri obeta.
\q1 
\v 15 Vašoda avľom avri, hoj tut te arakhav;
\q1 igen rodavas a arakhľom tut.
\q1 
\v 16 Učharďom miro hadžos le lepedenca,
\q1 le šukar pochtanenca andral o Egipt.
\q1 
\v 17 Kerďom, hoj miro hadžos te voňinel pal e mirha,
\q1 pal o aloe the pal e škorica.
\q1 
\v 18 Av, mačaras pes le kamibnaha dži tosara,
\q1 uživinas peske o kamiben.
\q1 
\v 19 Miro rom nane khere,
\q1 geľa pro baro drom.
\q1 
\v 20 Iľa peha but love
\q1 a na avela khere, medik na ela o čhonoro calo.“
\b
\q1 
\v 21 Pricirdňa les peskre vakeribnaha,
\q1 zachudňa les peskre gule lavenca.
\q1 
\v 22 Jekhvareste džalas pal late sar o bikos, saves džan te murdarel;
\q1 sar o jeleňis, so pes chudel andre pasca,
\q1 
\v 23 saveske o šipos predžal prekal o per;
\q1 sar o čiriklo, so ľecinel andre sita
\q1 a na džanel, hoj leske džal pal o dživipen.
\q1 
\v 24 Čhavo miro, akana man šun
\q1 a de pozoris pro lava mire mujeskre:
\q1 
\v 25 Tiro jilo te na džal pre lakre droma,
\q1 ma phir pal lakre chodňiki.
\q1 
\v 26 Angle late sas but murša dukhade pro meriben;
\q1 murdarde sas ajci džene, hoj pes aňi na del te zgenel.
\q1 
\v 27 Lakro kher ľidžal andro than le mulengro;
\q1 ko džala andre, merela.
\c 8
\s1 O goďaveripen vičinel
\q1 
\v 1 Či o goďaveripen na vičinel?
\q1 Či na del o achaľuvipen te šunel peskro hangos?
\q1 
\v 2 Ačhel upre pro nekučeder thana,
\q1 ode, kaj pes o droma prephanden,
\q1 
\v 3 the ode, khatar pes avel andro foros,
\q1 paš o brani zorales vičinel:
\q1 
\v 4 „Pre tumende vičinav, manušale!
\q1 Savore manušale pro svetos, šunen miro hangos!
\q1 
\v 5 Tumen, ko san bi e goďi, sikľon te achaľol!
\q1 Tumen, ko san diline, sikľon te rozprindžarel!
\q1 
\v 6 Šunen man, bo vakerav, so igen kampel;
\q1 phundravav mire vušta a phenav, so hin spravno.
\q1 
\v 7 Me furt vakerav o čačipen,
\q1 bo džungľol mange te vakerel o nalačhipen.
\q1 
\v 8 Savore mire lava hine čačipnaskre,
\q1 nane previsarde aňi banďarde.
\q1 
\v 9 O goďaver manuš achaľol savore mire lava
\q1 a oleske, kas hin o prindžaripen, hine čače.
\q1 
\v 10 Te prilel miro dovakeriben hin feder sar te prilel o rup
\q1 a te achaľol hin buter sar o žužo somnakaj.
\q1 
\v 11 Bo o goďaveripen mol buter sar o šperki,
\q1 ňič, so kames, nane ajso sar ov.
\s1 O goďaveripen vakerel pal peste
\q1 
\v 12 Me, o goďaveripen, bešav jekhetane la sasťa goďaha,
\q1 hin man o achaľuvipen a džanav te rozprindžarel.
\q1 
\v 13 Te vareko daral le Devlestar, našťi avri ačhel o nalačho.
\q1 Me, o goďaveripen, našťi avri ačhav o baripen, aňi te pes vareko ľidžal upre,
\q1 aňi o nalačhipen, aňi o vušta, so klaminen.
\q1 
\v 14 Me dav e rada the e lačhi goďi,
\q1 me som o achaľuvipen a mande hin e zor.
\q1 
\v 15 Me pomožinav le kraľenge te kraľinel
\q1 a le vodcenge te kerel o lačhe zakoni.
\q1 
\v 16 Mira pomocaha vladňinen o vladara,
\q1 o bare raja the savore čačipnaskre sudci.
\q1 
\v 17 Me kamav olen, ko man kamen,
\q1 a ola, ko man čačes roden, man arakhen.
\q1 
\v 18 Paš ma arakhena o barvaľipen the e pačiv,
\q1 o barvaľipen, so ačhel, the o spravodľišagos.
\q1 
\v 19 Oda, so tut me dava, mol buter sar o žužo somnakaj
\q1 a hin feder sar o nekžužeder rup.
\q1 
\v 20 Me phirav pal o čačipnaskre droma,
\q1 pal o spravodľiva chodňiki,
\q1 
\v 21 hoj te dav o barvaľipen olen, ko man kamen,
\q1 a te pherdžarav lengre pokladňici.
\s1 Khatar avel o goďaveripen
\q1 
\v 22 O RAJ man stvorinďa anglal savoreste,
\q1 anglal savore peskre buča, imar čirla angloda.
\q1 
\v 23 Somas stvorimen ešebnovarestar,
\q1 pro agor savoreske, sar mek na sas e phuv kerďi.
\q1 
\v 24 Uľiľom sigeder, sar sas kerde o oceani,
\q1 sar mek o prameňa na prečhorďonas le paňeha.
\q1 
\v 25 Mek angloda, sar sas rozthode o verchi,
\q1 sigeder, sar sas o brehi, me uľiľom.
\q1 
\v 26 Somas imar akor, sar mek na sas stvorimen e phuv, aňi lakre maľi,
\q1 aňi o ešebno prachos la phuvakro.
\q1 
\v 27 Me somas ode, sar thovelas o ňebi pre peskro than,
\q1 sar merinelas avri e hraňica maškar o moros the o ňebos,
\q1 
\v 28 sar rozthovelas o chmari pro ňebos,
\q1 sar phundraďa o prameňa, hoj te pherdžaren o bare paňa.
\q1 
\v 29 Me somas the ode, sar kerďa o hraňici le moroske,
\q1 hoj te na prečhorďon o paňa dureder, sar lenge prikazinďa,
\q1 a the ode, kaj merinelas o zakladi la phuvakre.
\q1 
\v 30 Ačhavas paš leste sar o majstros la bučakro.
\q1 Džives so džives leske keravas o radišagos
\q1 a paš leste radisaľuvavas furt.
\q1 
\v 31 Sas mange igen pre dzeka leskro svetos
\q1 a radisaľuvavas le manušendar.
\s1 Bachtalo, ko arakhel o goďaveripen
\q1 
\v 32 Avke akana, čhavale, šunen man!
\q1 Bachtale hine ola, ko phiren pal mire droma.
\q1 
\v 33 Šunen mištes, so tumen sikavav, a aven goďaver!
\q1 Ma odčhiven tumendar miro sikaviben!
\q1 
\v 34 Bachtalo manuš, ko man šunel,
\q1 oda, ko hino paš miro vudar sako džives
\q1 a užarel pre ma paš mire brani.
\q1 
\v 35 Bo ko man arakhel, arakhel o dživipen
\q1 a ela le RAJESKE pre dzeka.
\q1 
\v 36 No ko man na arakhel, dukhavel korkoro pes
\q1 a savore, save man našťi avri ačhen, kamen o meriben.“
\c 9
\s1 O goďaveripen vičinel pre hoscina
\q1 
\v 1 O goďaveripen peske ačhaďa kher
\q1 a kerďa andre efta slupi.
\q1 
\v 2 Murdarďa le dobitkos, mišinďa e mol,
\q1 pripravinďa o chaben pro skamind
\q1 
\v 3 a bičhaďa avri peskre služken,
\q1 hoj te vičinen pal o nekučeder than le foroskro:
\q1 
\v 4 „Kas nane o prindžaripen, mi avel kade!“
\q1 Olenge, ko hine bi e goďi, phenel:
\q1 
\v 5 „Aven, chan mire chabenestar
\q1 a pijen la moľatar, so mišinďom.
\q1 
\v 6 Omuken o nagoďaveripen a dživena,
\q1 phiren pal o drom, so tumen dela goďi.“
\b
\q1 
\v 7 Te sikaveha oles, ko peske kerel pheras savorestar, chudeha lestar ladž.
\q1 Te dovakereha le nalačhe manušeske, dukhavela tut.
\q1 
\v 8 Te pokarhineha oles, ko peske na del te phenel, našťi tut avri ačhela,
\q1 ale te pokarhineha le goďaverones, kamela tut.
\q1 
\v 9 De goďi le goďaverones a ela meksa goďavereder,
\q1 sikav le čačipnaskres a džanela buter.
\b
\q1 
\v 10 O goďaveripen chudel la sveta daraha anglo RAJ,
\q1 a te prindžareha le Svetes, akor achaľoha.
\q1 
\v 11 Me, o goďaveripen, tuke dava te dživel buter dživesa
\q1 a dothovava tuke o berša pro dživipen.
\q1 
\v 12 Te aveha goďaver, ela oda pre tiro lačho,
\q1 ale te asaha olestar, tu korkoro cerpineha.
\s1 The o diliňipen vičinel pre hoscina
\q1 
\v 13 O diliňipen hin sar e džuvľi, savi kerel vika,
\q1 ňikastar pes na kerel a na ladžal.
\q1 
\v 14 Bešel peske paš o vudar paš peskro kher,
\q1 pro nekučeder than andro foros,
\q1 
\v 15 a vičinel le muršen, save odarik predžan;
\q1 save džan rovnones pal peskre droma:
\q1 
\v 16 „Ko na achaľol, mi avel kade!“
\q1 A olenge, ko hine bi e goďi, phenel:
\q1 
\v 17 „O čordo paňi hino gulo
\q1 a o chaben, so chas počoral, hino igen lačho.“
\q1 
\v 18 Ale on na džanen, hoj ola, ko džan ke late, meren
\q1 a hoj lakre hosci imar hine dži tele andro than le mulengro.
\c 10
\s1 Le Šalamunoskre privakeribena
\p 
\v 1 Kala hine le Šalamunoskre privakeribena:
\q1 O goďaver čhavo anel le dadeske radišagos,
\q1 ale o nagoďaver čhavo kerel pharipen la dake.
\b
\q1 
\v 2 O barvaľipen, so dochudes nalačhipnaha, tuke na ela pre chasna,
\q1 no o spravodľišagos tut lel avri andral o meriben.
\b
\q1 
\v 3 O RAJ na mukela le čačipnaskres te bokhaľol,
\q1 ale le nalačhenge na domukela te chudel oda, so kamen.
\q1 
\v 4 Te aveha leňivo, aveha čoro,
\q1 no te kereha e buči mištes, barvaľoha.
\q1 
\v 5 Ko skidel o uľipen ňilaje, hino goďaver čhavo,
\q1 ale o čhavo, savo prekal e žatva sovel, hino pre ladž.
\q1 
\v 6 Pro čačipnaskro manuš bešela baro požehnaňje,
\q1 ale o mariben hin garudo pal o lava le nalačhe manušengre.
\q1 
\v 7 O lačhe manuša ena leperde pro požehnaňje,
\q1 ale o nav le bijedevleskro kirňola.
\q1 
\v 8 O goďaver prilel le jileha o prikazi,
\q1 no ko vakerel o diliňipen, zňičinela pes korkores.
\q1 
\v 9 O pačivalo manuš phirel bi e dar,
\q1 ale pre oda, ko phirel napačivalones, pes avela avri.
\q1 
\v 10 Ko džmurkinel la jakhaha, anel avreske dukh,
\q1 a ko vakerel o diliňipen, ela zňičimen.
\q1 
\v 11 O vušta le čačipnaskre manušeskre hine o prameňis le dživipnaskro,
\q1 ale o vušta le bijedevleskre manušengre garuven o nalačhipen.
\q1 
\v 12 Te pes našťi avri ačhas, ena o vesekedišagi,
\q1 no o kamiben učharel andre savore nalačhipena.
\q1 
\v 13 Andral o vušta olenge, ko achaľon, avel o goďaveripen,
\q1 ale ola, ko na achaľon, ena marde la pacaha.
\q1 
\v 14 Ola, ko hine goďaver, skiden upre o prindžaripen,
\q1 no o vakeriben le dilineskro anel pharipen.
\q1 
\v 15 O barvaľipen chraňinel le barvalen sar o muri le foros,
\q1 ale le čoren zňičinela o čoripen.
\q1 
\v 16 O počiňiben le čačipnaskro hin o dživipen,
\q1 no o binos ľidžal ča ko buter bini.
\q1 
\v 17 O dživipen ela oles, ko prilel o dovakeriben,
\q1 ale ko na prilel o dovakeriben, našavel o drom ko dživipen.
\q1 
\v 18 Oda, ko garuvel andre, hoj varekas našťi avri ačhel, hino klamaris.
\q1 Ko vakerel o pľetki, hino dilino.
\q1 
\v 19 Ko vakerel but, šaj phenel vareso nalačho,
\q1 ale ko zľikerel peskre vušta, hino goďaver.
\q1 
\v 20 Oda, so vakerel o čačipnaskro, hin sar o žužo rup,
\q1 no oda, so gondoľinen o bijedevleskre, na mol ňič.
\q1 
\v 21 O čačipnaskre vušta čaľaren but manušen,
\q1 ale o diline meren, bo na achaľon.
\q1 
\v 22 O požehnaňje le RAJESKRO barvaľarel
\q1 a na anel ňisavo pharipen.
\q1 
\v 23 Le dilineske hin pre dzeka te kerel o nalačhipen,
\q1 ale o goďaver arakhel o radišagos andro goďaveripen.
\q1 
\v 24 O čačipnaskre chudena, so peske mangen,
\q1 no le binošnenge pes ačhela oda, sostar pes nekbuter daran.
\q1 
\v 25 Sar avela e bari balvaj, o binošno na obačhela,
\q1 ale o čačipnaskro ačhela furt zorales.
\q1 
\v 26 Sar hin o šut le dandenge a o thuv le jakhenge,
\q1 avke hin o leňivo olenge, ko les den te kerel buči.
\q1 
\v 27 E sveto dar anglo RAJ tut dela buter te dživel,
\q1 ale o berša le bijedevleskre manušengre ena charneder.
\q1 
\v 28 E naďej le spravodľivengri anel o radišagos,
\q1 no o užaripen le nalačhengro našľola.
\q1 
\v 29 O drom le RAJESKRO hin o hrados prekal o žužo manuš,
\q1 ale zňičinela olen, ko keren o nalačhipen.
\q1 
\v 30 O čačipnaskro pes šoha na čhalavela,
\q1 no o bijedevleskre na ačhena andre phuv.
\q1 
\v 31 Andral o čačipnaskro muj avel o goďaveripen,
\q1 ale e previsarďi čhib ela čhimen avri.
\q1 
\v 32 O čačipnaskre vušta džanen te vakerel šukar lava,
\q1 ale o bijedevleskre vušta vakeren ča oda, so hin previsardo.
\c 11
\q1 
\v 1 Le RAJESKE džungľol oda, ko važinel falošňe,
\q1 ale o vahi, so važinen mištes, leske hin pre dzeka.
\q1 
\v 2 Sar avel o baripen, avel the e ladž,
\q1 no goďaver hin oda, ko hino pokorno.
\q1 
\v 3 Le lačhen ľidžal o pačivaľiben,
\q1 ale o napačivale ena zňičimen peskre klamišagoha.
\q1 
\v 4 O barvaľipen tut na zachraňinela andre oda džives, sar avela le RAJESKRI choľi,
\q1 no o spravodľišagos tut lela avri andral o meriben.
\q1 
\v 5 O čačipnaskro dživipen rovňinel avri o drom le lačhe manušeske,
\q1 ale o bijedevleskre manuša perena vaš peskro nalačho dživipen.
\q1 
\v 6 O spravodľišagos zachraňinel le pačivalen,
\q1 ale le napačivalen zachudel e pasca lengre nalačhe žadoscengri.
\q1 
\v 7 Sar merel o nalačho, merel leha the leskri naďej
\q1 a oda, pre soste užarel, ela pre ňisoste.
\q1 
\v 8 O čačipnaskro hino avriilo andral o pharipen,
\q1 ale o nalačho manuš zalela leskro than.
\q1 
\v 9 O bijedevleskro šaj zňičinel avres peskre lavenca,
\q1 ale o čačipnaskre ena zachraňimen peskre achaľuvipnaha.
\q1 
\v 10 Sar hin bach le čačipnaskren, o foros radisaľol,
\q1 a sar merel o nalačho manuš, radišagostar khelel.
\q1 
\v 11 Sar o čačipnaskre žehňinen le foroske, o foros barol,
\q1 ale o vakeriben le nalačhengro o foros musarel.
\q1 
\v 12 O nagoďaver le vakeribnaha tele dikhel avren,
\q1 ale o goďaver manuš hino čhit.
\q1 
\v 13 Ko vakerel o pľetki, phenel avri o garuďipen,
\q1 ale kaske pes del te pačal, ľikerel oda andre peste.
\q1 
\v 14 O narodos perela, te les na ela, ko te ľidžal:
\q1 Leskri zachrana hin andro but lačhe vodci.
\q1 
\v 15 Ko pes zaručinel vaš o cudzo dženo, igen cerpinela.
\q1 Ko pes na zaručinel vaš aver, hino chraňimen.
\q1 
\v 16 La džuvľa, so hiňi lačhejileskri, den o manuša pačiv,
\q1 ale o maribnaskre dochuden ča o barvaľipen.
\q1 
\v 17 Te o manuš hino lačhejileskro, kerel mištes korkoro peske,
\q1 ale te o manuš hino bijileskro, dukhavel pes korkores.
\q1 
\v 18 O bijedevleskro chudela o klamišagoskro počiňiben,
\q1 ale oda, ko kerel čačipnaha, chudela o čačikano počiňiben.
\q1 
\v 19 O spravodľišagos čačes ľidžal andro dživipen,
\q1 ale ko kamel te kerel o nalačhipen, merela.
\q1 
\v 20 O RAJ našťi avri ačhel olen, kaskre jile hine previsarde,
\q1 ale pre dzeka leske hine ola, ko furt keren oda, so hin lačho.
\q1 
\v 21 Oda hin čačes avke, hoj o RAJ marela le nalačhe manušen,
\q1 ale o čhave le spravodľive manušengre ena zachraňimen.
\q1 
\v 22 Sar e somnakuňi angrusi le baleske andro nakh
\q1 avke hin o šukariben la džuvľake, sava nane ňisavi pačiv.
\q1 
\v 23 Oda, so kamen o čačipnaskre, hin pro lačho,
\q1 ale te o nalačhe dochuden, so kamen, sako hino choľamen.
\q1 
\v 24 Varesave manuša den peskre love jilestar a mek len hin buter,
\q1 ale varesave manuša izdran pal o love a hine mek čoreder.
\q1 
\v 25 O ščiro manuš barvaľola;
\q1 a ko del paňi avres, the les dena te pijel.
\q1 
\v 26 O manuša prekošen oles, ko na kamel te bikenel e pšeňica, medik na bikenela vzacneder,
\q1 ale o manuša ašaren oles, ko e pšeňica bikenel.
\q1 
\v 27 E pačiv dena oles, ko čačes rodel o lačho,
\q1 ale o nalačhipen avela pre oda, ko les rodel.
\q1 
\v 28 Ko pes mukel pre peskro barvaľipen, perela,
\q1 no o čačipnaskre barona sar o zelena prajti.
\q1 
\v 29 Ko anel o trapišagos andre peskri famelija, na chudela o ďeďictvos
\q1 a o dilino služinela le goďavedereske.
\q1 
\v 30 O čačipnaskro chala pal o stromos le dživipnaskro
\q1 a o goďaver murš zachraňinela o dživipena.
\q1 
\v 31 Te imar o čačipnaskro chudela o počiňiben kade pre phuv,
\q1 keci buter o bijedevleskro the o binošno!
\c 12
\q1 
\v 1 Oda, ko rado prilel o dovakeriben, kamel o prindžaripen,
\q1 a ko našťi avri ačhel o privakeriben, hino dilino.
\q1 
\v 2 O lačho manuš hino le RAJESKE pre dzeka,
\q1 ale odsudzinela oles, ko gondoľinel pro nalačho.
\q1 
\v 3 O nalačhipen na dela le manušeske te obačhel,
\q1 no o koreňis le lačhe manušengro pes na čhalavela.
\q1 
\v 4 E lačhi romňi hiňi sar e koruna pro šero le romeske,
\q1 ale odi, savi leske kerel ladž, hiňi sar o hňisos andre leskre kokala.
\q1 
\v 5 O lačhe gondoľinen, sar te kerel oda, so hin lačho,
\q1 no o nalačhe ča roden, sar varekaha te thovel avri.
\q1 
\v 6 O lava le nalačhe manušengre hine sar e pasca, so užarel te murdarel,
\q1 ale o lava le lačhengre zachraňinen.
\q1 
\v 7 O nalačhe peren a imar našľon,
\q1 no e famelija le lačhe muršeskri ačhela furt.
\q1 
\v 8 Ašaren le manušes, te les hin goďi,
\q1 ale dikhen tele oles, kas hin previsardo jilo.
\q1 
\v 9 Feder hin oda, ko nane baro manuš a hin les sluhas,
\q1 sar oda, ko pes ľidžal upre a nane les so te chal.
\q1 
\v 10 O lačho pes starinel pal peskro dobitkos,
\q1 ale o nalačho hino ke lende bijileskro.
\q1 
\v 11 Ko kerel pre peskri maľa, čaľola le marestar,
\q1 no oda, ko del peskro časos pre chocsoste, hino bi e goďi.
\q1 
\v 12 O nalačho manuš igen džal pal oda, so hin le nalačhen,
\q1 ale o koreňis le lačhengro anel uľipen.
\q1 
\v 13 O nalačho manuš pes chudela andre pasca le nalačhe lavenca, so vakerel,
\q1 no o lačho pes lela avri andral o pharipen.
\q1 
\v 14 O goďaver lava anen but lačhipen oleske, ko len vakerel,
\q1 a e phari buči leske anel o počiňiben.
\q1 
\v 15 Le dilineske pes dičhol leskro drom lačho,
\q1 ale o goďaver šunel e rada.
\q1 
\v 16 O dilino sikavel peskri choľi takoj,
\q1 no o goďaver peske na kerel ňič, sar leske dophenen.
\q1 
\v 17 O lačho švedkos vakerel o čačipen,
\q1 ale o falošno phenel o klamišagos.
\q1 
\v 18 Oda, ko vakerel bi e goďi, sar te džubinďahas la šabľaha,
\q1 no o goďaver sasťarel peskra čhibaha.
\q1 
\v 19 O čačipen ľikerela pro furt,
\q1 ale o klamišagos ča pro sikra.
\q1 
\v 20 Olen, ko gondoľinen te kerel o nalačho, hin o klamišagos andro jilo,
\q1 no olen, ko anen o smirom, hin o radišagos.
\q1 
\v 21 Le lačheske pes na ačhela ňič nalačho,
\q1 ale le nalačhes ela furt pharipen.
\q1 
\v 22 O vušta, so klaminen, džungľon le RAJESKE,
\q1 no pre dzeka leske hin ola, ko doľikeren o lav.
\q1 
\v 23 O goďaver na vakerel sig, so džanel,
\q1 ale o jilo le dilineskro čhivkerel avri o diliňipen.
\q1 
\v 24 Olendar, ko keren lačhi buči, ačhen vodci,
\q1 no olendar, ko hine leňiva, ačhen otroka.
\q1 
\v 25 O starišagos andro jilo ispidel le manušes tele,
\q1 ale o šukar lav les hazdel upre.
\q1 
\v 26 O spravodľivo manuš anela peskre prijaťeľis pro lačho drom,
\q1 no o bijedevleskro pes pre peskro drom našavel.
\q1 
\v 27 O leňivo peske na tavela aňi o mas le džvirostar, so chudňa,
\q1 ale oda, ko kerel mištes buči, dochudela o baro barvaľipen.
\q1 
\v 28 O čačipnaskro drom ľidžal andro dživipen;
\q1 pre oda chodňikos nane o meriben.
\c 13
\q1 
\v 1 O goďaver čhavo šunel, sar les o dad bararel avri,
\q1 ale oda, ko peske kerel pheras savorestar, na prilel o dovakeriben.
\q1 
\v 2 O lačho manuš chala o ovocje peskre lačhe lavengro,
\q1 no olenge, ko kamen te thovel avri, džal ča pal o mariben.
\q1 
\v 3 Oda, ko peske del pozoris pre čhib, chraňinel peske o dživipen,
\q1 ale oda, ko sig vakerel, zňičinela pes korkores.
\q1 
\v 4 O leňivo manuš peske žadinel a nane les ňič,
\q1 no oles, ko kerel mištes buči, ela savoro, so kamel.
\q1 
\v 5 O lačho manuš našťi avri ačhel o falošna lava,
\q1 ale o nalačho kerel oda, so hin džungalo a bi e ladž.
\q1 
\v 6 O spravodľišagos chraňinel oles, ko dživel čačipnaha,
\q1 no o nalačhipen zňičinela le binošnes.
\q1 
\v 7 Vareko pestar kerel barvalo a nane les ňič;
\q1 aver dženo pestar kerel čoro, ale hin les pherdo barvaľipen.
\q1 
\v 8 O barvalo peske šaj počinel, hoj les te na murdaren,
\q1 no o čoro pes na mušinel oleha te trapinel.
\q1 
\v 9 O čačipnaskro hino sar o švetlos, so švicinel zorales,
\q1 ale o nalačho hino sar e lampa, so murdaľol andre.
\q1 
\v 10 O baripen anel ča o mariben,
\q1 no ola, ko peske den te phenel, hine goďaver.
\q1 
\v 11 O barvaľipen skidlo napačivalones cikňola,
\q1 ale oleske, ko peske skidel po sikra, barola.
\q1 
\v 12 Te pes na ačhel oda, pre soste pes o manuš zmukel, leskro jilo nasvaľol,
\q1 ale te chudel, so igen mangelas, hin leske oda sar o stromos le dživipnaskro.
\q1 
\v 13 Ko na prilel e lačhi rada, zňičinela pes korkores,
\q1 ale oleske, ko ľikerel o prikazaňje, ela počimen.
\q1 
\v 14 O sikaviben le goďavereskro hin o prameňis le dživipnaskro,
\q1 lela tut avri andral o meribnaskre pasci.
\q1 
\v 15 O lačho rozsudkos hin pre dzeka le manušenge,
\q1 ale o drom le napačivalengro ľidžal andro meriben.
\q1 
\v 16 Dojekh goďaver manuš gondoľinel, medik vareso kerel,
\q1 no o dilino rozľidžal o diliňipen.
\q1 
\v 17 O nalačho poslos kerel pharipen,
\q1 ale o pačivalo anel o smirom.
\q1 
\v 18 Oda, ko na prilel o sikaviben, ela čoro the andre ladž,
\q1 no oda, ko prilel o dovakeriben, chudela e pačiv.
\q1 
\v 19 Sar šukares hin, te chudes oda, so tuke andro jilo manges.
\q1 O diline pes na kamen te visarel le nalačhipnastar.
\q1 
\v 20 Ko phirel le goďaverenca, ela goďaver,
\q1 no ko pes ľikerel le dilinenca, namištes doperela.
\q1 
\v 21 Le binošnen hin e bibach všadzik, kaj džan,
\q1 ale o lačhe ena počimen le lačhe vecenca.
\q1 
\v 22 O lačho manuš zamukela o ďeďictvos peskre vnučatenge,
\q1 no o barvaľipen le binošneskro chudela o čačipnaskro manuš.
\q1 
\v 23 Pherdo uľipen šaj barol pre maľa le čore manušeske,
\q1 ale o načačipnaskre oda savoro lena.
\q1 
\v 24 Ko na potrestinel peskre čhavores, narado les dikhel,
\q1 no oda, ko les kamel, bararel les avri, medik hino cikno.
\q1 
\v 25 Le čačipnaskres hin but chaben, hoj te čaľol,
\q1 ale o nalačho hino furt bokhalo.
\c 14
\q1 
\v 1 E goďaver džuvľi budinel peskro kher,
\q1 ale e diliňi les korkori čhivel tele peskre vastenca.
\q1 
\v 2 Kas hin e sveto dar anglo RAJ, dživel pačivalones,
\q1 no kas hin previsarde droma, dikhel les tele.
\q1 
\v 3 O vakeriben le dilineskro hin e paca pre leskro dumo,
\q1 ale o goďaver hino chraňimen peskre lavenca.
\q1 
\v 4 Te nane le manušes voli, nane ňič andro žľabi,
\q1 ale le voloskri zor leske anel but uľipen.
\q1 
\v 5 O pačivalo švedkos na klaminel,
\q1 no o falošno rozľidžal o klamišagos.
\q1 
\v 6 Ko asal le goďaveripnastar, šoha les na arakhela,
\q1 ale oda, ko hino goďaver, lokes sikľol.
\q1 
\v 7 Dža het le diline muršestar,
\q1 bo nane les so tut te sikavel.
\q1 
\v 8 O goďaver manuš džanel, so te kerel a so na,
\q1 ale o dilino peha thovel avri, bo peske ča gondoľinel, hoj džanel.
\q1 
\v 9 O diline peske asan, sar keren o binos,
\q1 ale le Devleske hin pre dzeka ola, ko keren, so hin čačo.
\q1 
\v 10 Sako džanel, so les hin andro jilo, či o pharipen vaj o radišagos;
\q1 a ňiko aver na džanel, sar pes šunel.
\q1 
\v 11 O kher le nalačhengro ela zňičimen,
\q1 ale o stanos le lačhengro, kvitňisaľola.
\q1 
\v 12 Varesavo drom pes dičhol le manušeske lačho,
\q1 no pro koňec ľidžal andro meriben.
\q1 
\v 13 Varekana o asaben garuvel e dukh,
\q1 ale sar o radišagos preačhel, ačhel o pharipen.
\q1 
\v 14 O nalačho manuš chala oda nalačho, so kerel,
\q1 ale oda, ko kerel o lačho, čaľola buter.
\q1 
\v 15 O nagoďaver pačal savoreske,
\q1 ale o goďaver peske rozgondoľinel peskre kroki.
\q1 
\v 16 O goďaver pes daral a džal het le nalačhipnastar,
\q1 ale o dilino olestar na ačhel a sig kerel o veci.
\q1 
\v 17 Ko sig choľisaľol, kerel diline veci,
\q1 a o manuša našťi avri ačhena le vibitones.
\q1 
\v 18 Le nagoďaverenge ačhela o diliňipen,
\q1 ale o goďaver ena koruňimen le prindžaripnaha.
\q1 
\v 19 O nalačhe manuša banďona tele anglo lačhe
\q1 a o bijedevleskre banďona anglo brani le čačipnaskerengre.
\q1 
\v 20 Ňiko na kamel le čore manušes, aňi leskre susedi,
\q1 ale le barvales hin pherdo prijaťeľa.
\q1 
\v 21 Binos hin te dikhel tele le čores,
\q1 no požehňimen hin oda, ko le čoreske presikavel o lačhipen.
\q1 
\v 22 Či na bludzinen ola, ko gondoľinen te kerel o nalačho?
\q1 Ale ola, ko kamen te kerel o lačho, arakhena o jileskeriben the o pačivaľiben.
\q1 
\v 23 Dojekha phara bučatar tut ela chasna,
\q1 ale te ča vakeres a ňič na keres, ačheha čoro.
\q1 
\v 24 E koruna le goďaverengri hin lengro barvaľipen,
\q1 ale le dilinen hin pro šero diliňipen.
\q1 
\v 25 Oda švedkos, savo vakerel o čačipen, zachraňinel o dživipena,
\q1 ale oda, ko klaminel, thovel avri le manušenca.
\q1 
\v 26 Kas hin e sveto dar anglo RAJ, oles hin e zoraľi istota,
\q1 the leskre čhave hine tel e ochrana.
\q1 
\v 27 E sveto dar anglo RAJ hin o prameňis le dživipnaskro,
\q1 le manušes lel avri andral o pasci le meribnaskre.
\q1 
\v 28 Le kraľiskri slava hin andro but nipi,
\q1 ale bijal lende nane ňič.
\q1 
\v 29 O manuš, savo na choľisaľol sig, hino igen goďaver,
\q1 no oda, ko sig choľisaľol, sikavel peskro diliňipen.
\q1 
\v 30 O smirom andro jilo hin sasťipen prekal o ťelos,
\q1 ale e žjarlivosť hin sar o hňisos andro kokala.
\q1 
\v 31 Ko namištes kerel le čore manušeha, tele dikhel le Devles, savo les kerďa,
\q1 ale oda, ko le čoreske presikavel o lačhipen, del pačiv le Devles.
\q1 
\v 32 O nalačhe manuša zňičinen pes korkoren ole nalačhe vecenca, so keren,
\q1 ale le lačhe manušen chraňinen o pačivaľiben the o čačipen.
\q1 
\v 33 Andro jilo le goďavereske bešel o goďaveripen,
\q1 ale o diline manuša na džanen ňič pal o goďaveripen.
\q1 
\v 34 O spravodľišagos hazdel upre o narodos,
\q1 ale o binos hin pre ladž le narodenge.
\q1 
\v 35 Le kraľiske hino pre dzeka o goďaver sluhas,
\q1 ale pre oda sluhas, savo kerel ladž, ela choľamen.
\c 15
\q1 
\v 1 O šukar lav odvisarel e choľi,
\q1 ale o zoralo lav anel bareder choľi.
\q1 
\v 2 O vakeriben le goďaverengro pricirdel le manušen te šunel o prindžaripen,
\q1 ale le dilinengre vuštendar demel avri o diliňipen.
\q1 
\v 3 O jakha le RAJESKRE hine všadzik,
\q1 dikhen pro nalačhe the pro lačhe manuša.
\q1 
\v 4 O šukar vakeriben hin sar o stromos le dživipnaskro,
\q1 ale e previsarďi čhib dukhavel pro duchos.
\q1 
\v 5 O dilino na prilel le dadeskro sikaviben,
\q1 ale ko prilel o dovakeriben, kerel mištes.
\q1 
\v 6 Andro kher le spravodľive manušeskro hin pherdo barvaľipen,
\q1 no o love le nalačheske anen o pharipen.
\q1 
\v 7 O vušta le goďaverengre rozľidžan o prindžaripen,
\q1 ale andro jile le dilinengre nane avke.
\q1 
\v 8 Le RAJESKE džungľon o obeti le nalačhe manušendar,
\q1 ale pre dzeka leske hin e modľitba le čače manušengri.
\q1 
\v 9 Le RAJESKE džungľol o drom le nalačhe manušeskro,
\q1 no kamel oles, ko kerel oda, so hin spravno.
\q1 
\v 10 Oda, ko omukel o čačo drom, ela zorales mardo,
\q1 a ko na kamel te prilel o dovakeriben, merela.
\q1 
\v 11 O RAJ dikhel andro than le mulengro\f + \fr 15,11 \ft E hebrejiko čhib: Šeol\f* the le meribnaskro\f + \fr 15,11 \ft E hebrejiko čhib: Abaddon\f*,
\q1 a keci buter andro jilo le manušengro?
\q1 
\v 12 Oleske, ko peske kerel pheras savorestar, džungľol o dovakeriben,
\q1 aňi na džala pal o goďaver te phučel.
\q1 
\v 13 O radišagos andro jilo rozšvicinel o muj,
\q1 ale o smutňišagos anel e dukh pro duchos.
\q1 
\v 14 O jilo le goďavereskro rodel avri o prindžaripen,
\q1 no o vušta le dilinengre pes čaľaren le diliňipnaha.
\q1 
\v 15 Le smutne manušes hin andro dživipen furt pharipen,
\q1 ale olen, saven hin o radišagos andro jilo, hin furt lačhe dživesa.
\q1 
\v 16 Feder te sal čoreder a hin tut e sveto dar anglo RAJ,
\q1 sar te el tut but barvaľipen a leha o pharipen.
\q1 
\v 17 Feder hin o zeleňinakro chaben andro kamiben,
\q1 sar o nekfeder mas ode, kaj nane kamiben.
\q1 
\v 18 Oda, ko sig choľisaľol, anel o vesekedišagi,
\q1 no oda, ko na choľisaľol sig, anel o smirom.
\q1 
\v 19 Te sal leňivo, ela tuke phares všadzik,
\q1 ale te sal pačivalo, na ela tut ňisavo pharipen.
\q1 
\v 20 O goďaver čhavo anel o radišagos le dadeske,
\q1 no o nagoďaver čhavo tele dikhel peskra da.
\q1 
\v 21 Le nagoďaveres hin radišagos andro diliňipen,
\q1 ale o goďaver phirel rovne dromeha.
\q1 
\v 22 Bijal e lačhi rada nane pre ňisoste o plani,
\q1 no avena avri akor, sar hin but radci.
\q1 
\v 23 Le manušes hin radišagos, sar odphenel le lačhe laveha;
\q1 savo šukar hin o lav phendo ipen akor, sar kampel!
\q1 
\v 24 O goďaver manuša phiren pal o drom, so len ľidžal upre andro dživipen
\q1 a obdžan o drom, so džal tele andro meriben.
\q1 
\v 25 O RAJ čhivela tele o khera le barikanengre,
\q1 ale e phuv le vdovengro chraňinela.
\q1 
\v 26 Le RAJESKE džungľol o nalačho gondoľišagos,
\q1 no pre dzeka leske hin o lačhe lava.
\q1 
\v 27 Ko izdral pal o napačivale love, kerel peskra famelijake pharipen,
\q1 ale ko na kamel o prepočiňiben, dživela.
\q1 
\v 28 O jilo le čačipnaskereskro gondoľinel, so te phenel,
\q1 no andral o vušta le nalačhe manušengre demel avri o nalačhipen.
\q1 
\v 29 O RAJ hino dur le nalačhendar a na šunel len,
\q1 ale o mangipen le lačhengro šunel avri.
\q1 
\v 30 Te le manušen hin o asaben pro muj, keren avrenge o radišagos
\q1 a o lačho hiros tut dela sasťipen andro kokala.
\q1 
\v 31 Te prithoveha tiro kan paš o dovakeriben le dživipnaskro,
\q1 bešeha maškar o goďaver.
\q1 
\v 32 Te na priles o sikaviben, tele dikhes pes korkores,
\q1 no te šunes o dovakeriben, aveha goďavereder.
\q1 
\v 33 E sveto dar le RAJESKRI tut bararel avri andro goďaveripen,
\q1 te aveha pokorno, o manuša tut dena pačiv.
\c 16
\q1 
\v 1 O manuš peske andro jilo plaňinel, so kerela,
\q1 ale o Del phenela, so pes ačhela.
\q1 
\v 2 O manuš šaj peske gondoľinel, hoj savoro, so kerel, hin pro lačho,
\q1 no o RAJ džanel, soske o manuš kerel oda, so kerel.
\q1 
\v 3 Muk tut pro RAJ savoreha, so keres,
\q1 a avela tuke savoro avri.
\q1 
\v 4 Le RAJES hin planos savoreha, so kerel,
\q1 a kerďa the le bijedevleskres pre oda džives, sar ela potrestimen.
\q1 
\v 5 Le RAJESKE džungľol sako, ko hino barikano andro jilo;
\q1 šaj tuke aves isto, hoj ela mardo.
\q1 
\v 6 O kamiben the e vernosť odmukel o binos;
\q1 te amen hin e sveto dar anglo RAJ, džaha het le nalačhipnastar.
\q1 
\v 7 Te le RAJESKE hin pre dzeka le manušeskro dživipen,
\q1 kerela, hoj leskre ňeprijaťeľa leha te aven andro smirom.
\q1 
\v 8 Feder hin, te tut hin sikra, so tuke zarodňal pačivalones,
\q1 sar but, so dochudňal napačivalones.
\q1 
\v 9 O manuš peske andro jilo gondoľinel avri o drom,
\q1 ale o Del ľidžal leskre kroki.
\q1 
\v 10 Te o Del ľidžal le kraľis andro lava,
\q1 akor leskre vušta vakerena o čačipen pro sudos.
\q1 
\v 11 O RAJ kamel o pačivale vahi the o mieri,
\q1 hoj pes savoro te bikenavkerel čačipnaha.
\q1 
\v 12 Le kraľenge džungľol o binošna skutki,
\q1 bo le čačipnaha o tronos zoraľol.
\q1 
\v 13 Le kraľen hin radišagos le čačipnaskre vuštendar
\q1 a kamen olen, save vakeren o čačipen.
\q1 
\v 14 Te o kraľis choľisaľol, šaj del varekas te murdarel,
\q1 vašoda les o goďaver keren tele.
\q1 
\v 15 Te le kraľiske o muj asal, anel oda dživipen,
\q1 a leskro lačhipen hin sar o brišind jarone.
\q1 
\v 16 Te dochudel o goďaveripen hin feder sar o žužo somnakaj
\q1 a te skidel o achaľuvipen hin buter sar o rup.
\q1 
\v 17 O drom le lačhe manušengro obdžal o nalačhipen,
\q1 a chraňinel peske o dživipen oda, ko del pozoris, kaj džal.
\q1 
\v 18 O baripen ľidžal andre pohroma
\q1 a o barikano gondoľišagos kerela, hoj pereha tele.
\q1 
\v 19 Feder hin te el pokorno a te avel le čorenca,
\q1 sar peske te rozďelinel le barikanenca oda, so ande andral o mariben.
\q1 
\v 20 Te ľikereha andro jilo oda, so sikľiľal, arakheha o lačhipen,
\q1 a te tut zmukeha pro RAJ, aveha bachtalo.
\q1 
\v 21 Oles, ko achaľol, vičinena goďaver murš,
\q1 a ko vakerel šukares, šaj prevakerel avren pro lačho.
\q1 
\v 22 Le goďaverenge hin o goďaveripen o prameňis le dživipnaskro,
\q1 ale le dilinenge hin o diliňipen sar o trestos.
\q1 
\v 23 Ola, ko hine goďaver, gondoľinen mištes, medik vareso phenen,
\q1 vašoda šaj prevakeren avren pro lačho.
\q1 
\v 24 O šukar lava hine sar o medos,
\q1 sar o guľipen tira dušake the o sasťipen tire kokalenge.
\q1 
\v 25 Varesavo drom pes dičhol le manušeske lačho,
\q1 ale pro koňec ľidžal andro meriben.
\q1 
\v 26 E bokh le manušes ispidel andre buči,
\q1 a leskre bokhale vušta les cirden te kerel.
\q1 
\v 27 O nalačho manuš rodel, sar te dukhavel avres;
\q1 leskre lava labaren sar jag.
\q1 
\v 28 O previsardo manuš kerel upre pro vesekedišagos
\q1 a o pľetkaris rozďelinel le lačhe prijaťeľen.
\q1 
\v 29 O maribnaskro manuš scirdel peskre prijaťeľis
\q1 a ľidžal les le nalačhe dromeha.
\q1 
\v 30 Ko džmurkinel la jakhaha, gondoľinel pro nalačho,
\q1 a ko del znameňje le vuštenca, kamel te kerel o nalačhipen.
\q1 
\v 31 O šiva bala hin e šukar koruna,
\q1 dochudel pes la čačipnaskre dživipnaha.
\q1 
\v 32 Feder hin te avel poloko andre choľi, sar te el hrďinas,
\q1 feder hin oda, ko pes zľikerel, sar oda, ko domarel o foros.
\q1 
\v 33 O manuša roden prekal o losos so te kerel,
\q1 ale o RAJ phenel, so pes ačhela.
\c 17
\q1 
\v 1 Te chal sikra šuko maro andro smirom hin feder,
\q1 sar te el andro kher pre bari oslava, kaj pes vesekedinel.
\q1 
\v 2 O goďaver sluhas vladňinela upral le rajeskro čhavo, savo kerel ladž,
\q1 a leskre phralenca chudela o kotor le ďeďictvostar.
\q1 
\v 3 O somnakaj the o rup pes prežužarel andre jag
\q1 a o jilo le manušeskro hino preskušimen le RAJESTAR.
\q1 
\v 4 O nalačho manuš šunel oles, ko vakerel o nalačho,
\q1 a o klamaris šunel oles, ko vakerel o klamišagos.
\q1 
\v 5 Oda, ko asal le čorestar, tele dikhel le Devles, savo les kerďa;
\q1 oda, ko radisaľol avrengre pharipnastar, ela mardo.
\q1 
\v 6 O phure manuša thoven baripen andre le čhavengre čhave,
\q1 a o čhave thoven baripen andre peskre dada.
\q1 
\v 7 Le dilineske na pasinel te vakerel rajikanes,
\q1 avke sar le vladcaske na pasinel te klaminel.
\q1 
\v 8 O prepočiňiben dičhol oleske, ko les del, sar vareso, so prianel e bach;
\q1 gondoľinel peske, hoj sa leske všadzik avela avri.
\q1 
\v 9 Ko odmukel o nalačhipen, rodel o kamiben,
\q1 ale oda, ko oda furt leperel, musarel o prijaťeľstvo.
\q1 
\v 10 Le goďavereske anel buter chasna jekh dovakeriben,
\q1 sar le dilineske šel rani la pacaha.
\q1 
\v 11 O nalačho manuš rodel ča e vzbura,
\q1 vašoda pes pre leste bičhavela o meribnaskro poslos.
\q1 
\v 12 Feder hin te arakhel pes la medveďicaha, savatar ile le ciknoren,
\q1 sar le dilineha akor, sar kerel o diliňipen.
\q1 
\v 13 O nalačhipen na džala avri andral o kher oleske,
\q1 ko vaš o lačho visarel pale o nalačho.
\q1 
\v 14 Sar chudel o vesekedišagos, sar te pes mukľahas avri o paňi andral e hradza,
\q1 vašoda preačh, medik na demel zorales avri.
\q1 
\v 15 Kala duj veci džungľon le RAJESKE:
\q1 Te premukel le vinnovates abo te odsudzinel le čačipnaskres.
\q1 
\v 16 Pre soste hin o love andro vasta le dilineske?
\q1 Cinela peske goďi? Se oleske na achaľol!
\q1 
\v 17 O prijaťeľis presikavel o kamiben andro dojekh časos
\q1 a tiro phral tuke pomožinel andro pharipen.
\q1 
\v 18 Oda, ko našaďa e goďi, podel peskro vast
\q1 a zaručinel pes vaš avreske.
\q1 
\v 19 Oda, ko pes rado vesekedinel, rado kerel o binos,
\q1 a ko pes furt ašarel\f + \fr 17,19 \ft E hebrejiko čhib: ko ačhavel e bari brana\f*, rodel e zahuba.
\q1 
\v 20 Oles, kas hin previsardo jilo, na ela bach,
\q1 a kas hin e falošno čhib, doperela andre bibach.
\q1 
\v 21 Ko anďa pro svetos le nagoďaveres, rovela
\q1 a o dad le dilineskro na radisaľola.
\q1 
\v 22 O radišagos andro jilo tut sasťarel,
\q1 ale o strapimen duchos šučarel o kokala.
\q1 
\v 23 O nalačho manuš lel počoral o prepočiňiben,
\q1 a vašoda pes na rozhodňinel čačipnaha pro sudos.
\q1 
\v 24 O goďaver peske kidel avri te kerel oda, so hin goďaver,
\q1 ale o dilino furt gondoľinel pro všelijaka veci a na džanel, so kamel te kerel.
\q1 
\v 25 O nagoďaver čhavo anel peskre dadeske e dukh,
\q1 a peskra dake e žaľa.
\q1 
\v 26 Nane mištes te del te počinel pokuta oles, ko ňič na kerďa,
\q1 aňi te marel le lačhe manušes vaš o čačipen.
\q1 
\v 27 Oda, ko hino goďaver, na vakerel but
\q1 a oda, ko peske na domukel e choľi, hin o goďaver manuš.
\q1 
\v 28 Sar o dilino hino čhit, the ov dičhol sar goďaver,
\q1 a sar na vakerel, dičhol pes, hoj achaľol.
\c 18
\q1 
\v 1 Kaske džal ča pal peskre veci, pes odďelinel avrendar
\q1 a na ačhel ňisava lačha radatar.
\q1 
\v 2 Le dilineske na džal pal oda, či achaľol vaj na;
\q1 ča kamel te phenel peskro.
\q1 
\v 3 O binos the e ladž aven jekhetane,
\q1 te našaveha e pačiv, aveha teledikhlo.
\q1 
\v 4 O goďaver lav hin sar o moros, andre savo našťi te dodžal dži tele,
\q1 del dživipen sar o paňi, so čuľal avri andral o prameňis.
\q1 
\v 5 Nane mištes te chudel paš o vinnovato
\q1 a le čačipnaskres pro sudos te odčhivel.
\q1 
\v 6 O lava le dilineskre les dochuden furt andro vesekedišagi,
\q1 mangel peske te chudel mariben.
\q1 
\v 7 Oda, so o dilino vakerel, les zňičinel;
\q1 leskre lava les zachuden andre pasca.
\q1 
\v 8 O lava le pľetkariskre hine gulore
\q1 a džan dži tele andre džombra.
\q1 
\v 9 O leňivo andre buči
\q1 hino phral oleske, so savoro musarel.
\q1 
\v 10 Le RAJESKRO nav hin e zoraľi veža;
\q1 o čačipnaskro andre denašel a hino garudo.
\q1 
\v 11 O barvaľipen hin le barvaleske sar o ohradzimen foros;
\q1 hin andre leskri goďi sar o učo muros.
\q1 
\v 12 Angloda, sar o manuš perel, hin o baripen andro jilo;
\q1 e pokora hin anglal e slava.
\q1 
\v 13 Te odphenel varekaske, medik les na šunďal avri,
\q1 hin diliňipen a pre ladž.
\q1 
\v 14 O manušeskro duchos šaj zľidžal peskro nasvaľiben,
\q1 ale ko birinela te zľidžal le dukhade duchos?
\q1 
\v 15 O goďaver jilo dochudela o prindžaripen
\q1 a o goďaver kan les rodel.
\q1 
\v 16 Te aneha daros le bare manušeske,
\q1 otkerela tuke o drom ke leste.
\q1 
\v 17 Dičhol pes, hoj hin čačipen oles, ko vakerel pro sudos ešebno,
\q1 medik lestar na phučel oka dujto manuš, ko pre leste vakerel.
\q1 
\v 18 O losos zaačhavel e vika
\q1 a maškar o zorale manuša anel o smirom.
\q1 
\v 19 Te dochudel pes paš o dukhado phral hin phareder, sar te dodžal andro ohradzimen foros;
\q1 o vesekedišagi hine maškar o phrala sar o zakerde brani pro hrados.
\q1 
\v 20 O manuš čaľola le lavendar, so vakerel,
\q1 a kidela upre o uľipen olestar, so avel avri andral leskre vušta.
\q1 
\v 21 E čhib šaj murdarel abo del o dživipen,
\q1 a ola, ko la kamen, chana lakro ovocje.
\q1 
\v 22 Ko arakhľa lačha romňa, arakhľa o lačhipen,
\q1 bo hino le RAJESKE pre dzeka.
\q1 
\v 23 O čoro vakerel pokorne mangipnaha,
\q1 ale o barvalo odphenel zorales.
\q1 
\v 24 Vareko pestar ča kerel, hoj hino amaro prijaťeľis\f + \fr 18,24 \ft Abo: Varesave prijaťeľa hine jekh avreske pro nalačho.\f*,
\q1 ale varesavo prijaťeľis hino pašeder sar amaro phral.
\c 19
\q1 
\v 1 Feder hin o čoro manuš, savo hino pačivalo,
\q1 sar o dilino, savo klaminel.
\q1 
\v 2 Nane mištes, te kames te kerel o lačho, ale nane tut o prindžaripen;
\q1 ko siďarel, našavel o drom.
\q1 
\v 3 Varesavo manuš pes korkoro zňičinel peskre nagoďaver skutkenca,
\q1 ale paľis del e vina le RAJESKE.
\q1 
\v 4 Le barvalen hin but prijaťeľa,
\q1 ale le čores omukel leskro prijaťeľis.
\q1 
\v 5 Le falošne švedkos o mariben na obdžala
\q1 a oda, ko rozľidžal o klamišagos, na denašela.
\q1 
\v 6 But džene pes guľaren le rajikane manušeske
\q1 a sako hino prijaťeľis oleha, ko hino ščiro.
\q1 
\v 7 Le čores našťi avri ačhen savore leskre phrala
\q1 a the leskre prijaťeľa les obdžan!
\q1 A sar lenca kamel te vakerel, on na kamen.
\q1 
\v 8 Ko dochudel o prindžaripen, rado pes dikhel;
\q1 sa avela avri mištes oleske, ko kerel goďaha.
\q1 
\v 9 Le falošne švedkos o mariben na obdžala
\q1 a oda, ko vakerel o klamišagos, ela zňičimen.
\q1 
\v 10 Le dilineske na pasinel te dživel andro baro barvaľipen,
\q1 a meksa goreder hin, te o otrokos ľidžal le rajen.
\q1 
\v 11 E goďi del le manušes o zľikeriben andre choľi;
\q1 te tuke na keres ňič olestar, sar tuke dophenen, hin oda pre tiri pačiv.
\q1 
\v 12 E choľi le kraľiskri hin sar e vika le terne ľevoskri,
\q1 ale leskro lačhipen hin sar e rosa pre čar.
\q1 
\v 13 O nagoďaver čhavo anel o pharipen le dadeske.
\q1 E romňi, savi furt dudrinel, hiňi sar o paňi, so na preačhel te kvapkinel.
\q1 
\v 14 O kher the o barvaľipen amen hin amare dadendar,
\q1 ale e goďaver romňi hin le RAJESTAR.
\q1 
\v 15 O leňivišagos ľidžal andro zoralo soviben;
\q1 o leňivo manuš ela bokhalo.
\q1 
\v 16 Ko doľikerel le Devleskre prikazaňja, doľikerel peske o dživipen;
\q1 ko na ačhel leskre dromendar, merela.
\q1 
\v 17 Ko pomožinel le čoreske, del kečeň le RAJES
\q1 a ov leske počinela pale vaš o lačhipen, so kerďa.
\q1 
\v 18 Barar avri tire čhas, medik pes del,
\q1 te oda na keres, zňičines les\f + \fr 19,18 \ft Abo: Ale na avke, hoj les te murdares!\f*.
\q1 
\v 19 Ko hino furt choľamen, zaslužinel peske vaš oda te počinel,
\q1 te leske pomožineha jekhvar, mušineha oda te kerel pale a pale.
\q1 
\v 20 Šun e rada a prile, sar tut sikaven,
\q1 a pro koňec ačheha goďaver.
\q1 
\v 21 But veci plaňinel o manuš andro jilo,
\q1 ale e voľa le RAJESKRI pes ačhela.
\q1 
\v 22 Le manušestar pes užarel, hoj ela pačivalo,
\q1 vašoda feder hino o čoro sar o klamaris.
\q1 
\v 23 E sveto dar anglo RAJ ľidžal andro dživipen,
\q1 kas oda hin, sovela peske andro smirom a o nalačhipen pre leste na avela.
\q1 
\v 24 O leňivo manuš thovel o vast andro čaro,
\q1 ale paš o muj imar na dohazdel.
\q1 
\v 25 Te mareha oles, ko asal savorestar, so hin lačho,
\q1 ta o nagoďaver sikľola goďi;
\q1 pokarhin le goďaveres a dochudela o prindžaripen.
\q1 
\v 26 Oda čhavo, savo trapinel le dades a tradel avri peskra da,
\q1 hino džungalo a pre ladž.
\q1 
\v 27 Čhavo miro, te preačheha te prilel o dovakeriben,
\q1 pobistereha oda, so imar džanes.
\q1 
\v 28 O klamišagoskro švedkos asal avri o sudos,
\q1 a o previsarde rado koštoľinen o nalačhipen.
\q1 
\v 29 Pre ola, ko peske keren pheras savorestar,
\q1 hin imar pripravimen o tresti,
\q1 a pre savore diline o rani pal o dumo.
\c 20
\q1 
\v 1 Te pijes but mol the aver pijiben, ačhes sprosto a kames tut te marel.
\q1 Oda, ko mačol, nane goďaver.
\q1 
\v 2 E dar le choľamen kraľistar hin sar e dar le zurive ľevostar,
\q1 oda, ko les choľarela, šaj našavel peskro dživipen.
\q1 
\v 3 Hin pre pačiv le manušeske, te pes zľikerel le vesekedišagendar,
\q1 ale o dilino sig demel avri choľaha.
\q1 
\v 4 Le leňive manušeske pes na kamel te orinel jesone,
\q1 ale sar hin e žatva, rodel a nane les ňič.
\q1 
\v 5 Le manušeskre plani hin sar o paňi andre bari chaňig,
\q1 no o goďaver manuš džanel oda te lel avri.
\q1 
\v 6 But manuša pes ašaren peskre pačivaľibnaha,
\q1 ale ko arakhela muršes, saveske pes del te pačal?
\q1 
\v 7 O čačipnaskro ľidžal o žužo dživipen;
\q1 bachtale hine o čhave, save pal leste ačhena.
\q1 
\v 8 O kraľis, savo bešel pro sudno stolkos,
\q1 sprindžarel peskre jakhenca savoro, so hin nalačho.
\q1 
\v 9 Ko šaj phenel: „Me mange obžužarďom miro jilo;
\q1 nane man ňisavo binos“?
\q1 
\v 10 Kala duj veci džungľon le RAJESKE:
\q1 e falošno vaha the e falošno mira.
\q1 
\v 11 Imar o čhavoro peskre skutkenca sikavel,
\q1 či oda, so kerel, hin lačho the čačo.
\q1 
\v 12 O RAJ amenge kerďa jakha, hoj te dikhas,
\q1 the o kana, hoj te šunas.
\q1 
\v 13 Ma kam o soviben, hoj te na ačhes čoro!
\q1 Ušťi, ker buči a čaľoha le marestar!
\q1 
\v 14 „Nane lačho, nane lačho!“ phenel oda, ko cinel,
\q1 no sar džal het, imar pes oleha ašarel.
\q1 
\v 15 O somnakaj the o vzacna bara hine vzacna,
\q1 ale o goďaver lava hine vzacneder.
\q1 
\v 16 Le o gada olestar, ko pes zaručinel vaš o cudzincos,
\q1 a le e zaloha olestar, ko pes zaručinďa vaš e cudzinka.
\q1 
\v 17 O maro dochudlo le klamišagoha hin igen lačho,
\q1 ale pro koňec pes tuke visarela pre poši andro muj.
\q1 
\v 18 Ker tire plani pal e porada;
\q1 so buter akor, te džas andro mariben.
\q1 
\v 19 Oda, ko phirel a kerel pľetki, phenel avri o garude veci,
\q1 vašoda tut ma ľiker oleha, ko but vakerel.
\q1 
\v 20 Ko prekošel le dades abo la da,
\q1 oda doperela avke sar e momeľi, so rači murďalol andre.
\q1 
\v 21 O barvaľipen, so dochudes igen sig,
\q1 tuke pro koňec na anela o požehnaňje.
\q1 
\v 22 Ma phen: „Dava pale vaš o nalačhipen!“
\q1 Muk tut pro RAJ a rušela vaš tu.
\q1 
\v 23 Le RAJESKE džungľol oda, ko važinel dvojitones;
\q1 e falošno vaha nane lačhi.
\q1 
\v 24 Le manušeskre kroki ľidžal o RAJ,
\q1 akor, sar šaj o manuš achaľol peskre dromeske?
\q1 
\v 25 Gondoľin mištes, medik phenes le Devleske, hoj les vareso deha,
\q1 hoj paľis te na bajines, so phenďal.
\q1 
\v 26 O goďaver kraľis avel pre oda, ko hin nalačhe,
\q1 a marel len igen zorales.
\q1 
\v 27 O svedomje le manušeskro hin sar e momeľi, so diňa o RAJ,
\q1 hoj amenge te švicinel pre savoreste, so gondoľinas andro jilo.
\q1 
\v 28 O verno kamiben the o čačipen chraňinen le kraľis;
\q1 le lačhipnaha zoraľarel peskro tronos.
\q1 
\v 29 O šukariben le ternengro hin lengri zor;
\q1 no o šiva bala šukaľaren le phuren.
\q1 
\v 30 O mariben the o modrini traden avri o nalačhipen
\q1 a o rani žužaren le manušes andral.
\c 21
\q1 
\v 1 Le kraľiskro jilo andro vast le RAJESKE hin sar o prudos le paňeskro,
\q1 visarel les, kaj ča kamel.
\q1 
\v 2 O manuš peske gondoľinel, hoj savore leskre droma hine čače,
\q1 ale o RAJ dikhel andro jilo, soske oda kerel.
\q1 
\v 3 Te kerel o čačipen the o pravos
\q1 hin le RAJESKE buter pre dzeka sar e obeta.
\q1 
\v 4 O barikane jakha the o jilo, so pes upre hazdel,
\q1 hin le nalačhenge sar lampa, so len ľidžal andro binos.
\q1 
\v 5 Oles, ko hino bučakro, ela savoro pherdo,
\q1 ale ko sig kamel te barvaľol, ačhela čoro.
\q1 
\v 6 O barvaľipen dochudlo klamišagoha
\q1 našľola sig sar o thuv andre balvaj a hino e meribnaskri pasca.
\q1 
\v 7 Le bijedevleskren zňičinena lengre maribnaskre skutki,
\q1 bo na kamen te kerel o čačipen.
\q1 
\v 8 O drom oleskro, ko kerel o nalačhipen, hino bango,
\q1 ale o čačipnaskre keren o lačho.
\q1 
\v 9 Feder hin te bešel pro pados andro kutos
\q1 sar andre jekh kher la čhibaľa romňaha.
\q1 
\v 10 E duša le bijedevleskri igen džal pal o nalačho,
\q1 leskro prijaťeľis lestar na chudela ňisavo jileskeriben.
\q1 
\v 11 Te maren oles, ko asal savorestar, so hin lačho,
\q1 ta o nagoďaver sikľola;
\q1 te sikaven le goďaverones, dochudel o prindžaripen.
\q1 
\v 12 O Del, o Čačipnaskro, dikhel, so pes kerel andro kher le nalačheskro
\q1 a čhivel le bijedevleskren andro meriben.
\q1 
\v 13 Ko phandel o kan andre, hoj te na šunel le čores te vičinel,
\q1 na ela avrišundo, sar ov vičinela.
\q1 
\v 14 O daros dino počoral thovel tele e choľi
\q1 a o prepočiňiben andre žeba la ačhavel.
\q1 
\v 15 Le lačhe manušes hin radišagos, sar dikhel, hoj pes sudzinel čačipnaha,
\q1 ale le nalačhe manušenge anel e dar.
\q1 
\v 16 O manuš, savo odgeľa la sasťa goďatar,
\q1 dochudela pes maškar o mule manuša.
\q1 
\v 17 Ko peske kamel te uživinel, ačhela čoro;
\q1 ko rado pijel e mol a chal o bare chabena, na ela šoha barvalo.
\q1 
\v 18 O nalačhe manuša anen pre peste oda pharipen,
\q1 so kamle te kerel le lačhe manušenge\f + \fr 21,18 \ft Abo: O nalačho manuš cerpinela vaš o lačho a o napačivalo vaš o pačivalo. \f*.
\q1 
\v 19 Feder hin te bešel pre pušťa
\q1 sar la čhibaľa romňaha, savi furt dudrinel.
\q1 
\v 20 Andro kher ko goďaver hin but barvale veci,
\q1 ale o dilino rozkerel savoro.
\q1 
\v 21 Ko igen džal pal o lačhipen, pačivaľiben the kamiben,
\q1 arakhel o dživipen, o spravodľišagos the e slava.
\q1 
\v 22 O goďaver džala andro foros le zorale muršengro
\q1 a čhivela tele o muri, pre save pes zmukenas.
\q1 
\v 23 Ko peske stražinel o vušta the e čhib,
\q1 chraňinel pes korkores le pharipnastar.
\q1 
\v 24 Oda manuš, ko peske kerel pheras savore lačhipnastar, hino barikano a ľidžal pes upre,
\q1 andre peskro baripen ňikastar na ačhel.
\q1 
\v 25 O leňivo merela, bo ča žadinel
\q1 a leskre vasta na kamen te kerel buči;
\q1 
\v 26 calo džives žadinel buter a buter,
\q1 ale o čačipnaskro rozdel ščirones a na sajinel.
\q1 
\v 27 Le RAJESKE džungľol e obeta le nalačhendar,
\q1 a meksa buter, sar pes obetinel le nalačhe gondoľišagoha.
\q1 
\v 28 O falošno švedkos ela zaačhado te vakerel pro sudos,
\q1 ale o pačivalo švedkos vakerela dureder.
\q1 
\v 29 O nalačho pes kerel, hoj na daral,
\q1 ale o čačipnaskro gondoľinel pal peskro drom.
\q1 
\v 30 Ňisavo goďaveripen aňi achaľuvipen
\q1 aňi rada tuke na pomožinela, te o RAJ pre tu džala.
\q1 
\v 31 O graj hino pripravimen pro džives le maribnaskro,
\q1 ale o viťazstvo del o RAJ.
\c 22
\q1 
\v 1 O lačho nav hin buter sar o baro barvaľipen,
\q1 e pačiv hin feder sar o rup the o somnakaj.
\q1 
\v 2 O barvalo the o čoro hine jekh andre kada:
\q1 Sodujdžene hine stvorimen le RAJESTAR.
\q1 
\v 3 O goďaver manuš dikhel o nalačhipen a garuvel pes,
\q1 o nagoďaver džal dureder a doperela pre oda.
\q1 
\v 4 O počiňiben vaš e pokora the vaš e sveto dar anglo RAJ
\q1 hin o barvaľipen, e slava the o dživipen.
\q1 
\v 5 O koľaka the o pasci hine pro drom le previsarde manušeskro,
\q1 ale ko chraňinel peskro dživipen, dural len obdžala.
\q1 
\v 6 Sikav le čhas, sar mek hino ciknoro,
\q1 a na oddžala olestar aňi akor, sar phurola.
\q1 
\v 7 O barvalo hino raj upral o čore;
\q1 te varekaske kames love, sal leskro otrokos.
\q1 
\v 8 Ko sadzinel o načačipen, skidela upre e bibach,
\q1 a imar na dukhavela avren.
\q1 
\v 9 Ko hino ščiro, ela požehňimen,
\q1 bo del le čores peskre marestar.
\q1 
\v 10 Trade avri oles, ko tele dikhel o čačipen, a našľola o vesekedišagos
\q1 a preačhela o reptišagos the e ladž.
\q1 
\v 11 Ko kamel o žužipen andro jilo the o šukar vakeriben,
\q1 ela prijaťeľis le kraľiskro.
\q1 
\v 12 O RAJ chraňinel oles, ko prindžarel o čačipen\f + \fr 22,12 \ft Abo: Le RAJESKRE jakha chraňinen o prindžaripen.\f*,
\q1 ale o lava le napačivaleskre visarela avri.
\q1 
\v 13 O leňivo phenel: „Avri hino o ľevos!
\q1 Murdarela man pro pľacos!“
\q1 
\v 14 O vušta la lubňakre hine sar e bari jama,
\q1 a oda, pre kaste o RAJ hino choľamen, perela andre.
\q1 
\v 15 Le čhavores hin andro jilo te kerel o diliňipen,
\q1 ale e paca le dadeskri lestar oda tradela avri.
\q1 
\v 16 Te trapines le čoren, hoj lendar te barvaľos
\q1 abo te des o dari le barvalen, ačheha čoro.
\s1 O tranda goďaver privakeribena
\q1 
\v 17 Prithov tiro kan a šun o lava le goďaverengre;
\q1 visar tiro jilo pre mire sikavibena.
\q1 
\v 18 Ena tuke pro radišagos, te tuke len ľikereha andro jilo,
\q1 a sar tuke kampela, džaneha len te phenel.
\q1 
\v 19 Adadžives tut sikavav, he, tut,
\q1 hoj tut te mukes pro RAJ.
\q1 
\v 20 Pisinďom tuke tranda (30) privakeribena,
\q1 andre save hin pherdo goďaveripena the radi.
\q1 
\v 21 Lendar sikľoha, so hin lačho the čačo,
\q1 hoj mištes te odphenes olenge, ko tut bičhaven te rodel o čačipen.
\b
\q1 
\v 22 Ma občorar le čores, bo les nane ňič,
\q1 a ma trapin les pro sudos.
\q1 
\v 23 Bo o RAJ vaš leste zaačhela
\q1 a lela o dživipen oleske, ko les občorarďa.
\b
\q1 
\v 24 Ma av prijaťeľis le rušle muršeha,
\q1 aňi ma ľiker tut le choľamen muršeha,
\q1 
\v 25 hoj te na phires pal leskro chodňikos
\q1 a te na peres andre pasca.
\b
\q1 
\v 26 Ma av jekh olendar, ko podel peskro vast
\q1 a zaručinel pes vaš avreskre dluhi.
\q1 
\v 27 Te tut na ela sostar te počinel,
\q1 avena a lena tutar mek the o hadžos.
\b
\q1 
\v 28 Ma čhalav e čirlatuňi hraňica,
\q1 so zathode tire phure dada.
\b
\q1 
\v 29 Dikhes varekas, ko džanel mištes te kerel buči?
\q1 Ajso dženo služinela le kraľenge
\q1 a na kerela chocsave manušenge.
\c 23
\q1 
\v 1 Te bešeha jekhetane varesave rajeha pašal o skamind te chal,
\q1 ma pobister, ko hin anglal tute;
\q1 
\v 2 zľiker tut\f + \fr 23,2 \ft E hebrejiko čhib: thov tuke e čhuri pro kirlo \f*, te rado but chas.
\q1 
\v 3 Ma mang tuke te chal but leskre lačhe chabenestar,
\q1 bo šaj tut oleha chudel avri.
\b
\q1 
\v 4 Ma cirde tut igen pal o barvaľipen,
\q1 av goďaver a preačh oleha.
\q1 
\v 5 Bo soča tut le jakhenca zadikheha, imar na ela;
\q1 se jekhvareste leske barola kridli a ľecinela het sar orlos.
\b
\q1 
\v 6 Oleha, ko hino skupo, ma cha
\q1 a ma dža pal leskro lačho chaben!
\q1 
\v 7 Bo ov peske sa andre goďi zrachinela a phenela tuke:
\q1 „Cha, pi, keci kames,“ ale andro jilo tuke na žičinel.
\q1 
\v 8 Oda, so chaľal, čhandeha avri
\q1 a tire šukar lava, so phenďal, ela pre ňisoste.
\b
\q1 
\v 9 Le dilineha ma vaker,
\q1 bo dikhela tele tire goďaver lava.
\b
\q1 
\v 10 Ma čhalav e čirlatuňi hraňica
\q1 a ma le tuke e phuv le širotengri,
\q1 
\v 11 bo o RAJ hino lengro zoralo ochrancas,
\q1 ov vaš lenge rušela a ačhela vaš lenge pro sudos.
\b
\q1 
\v 12 Visar tiro jilo pro dovakeriben
\q1 a tire kana pro prindžaripen.
\b
\q1 
\v 13 Ma dara tut te bararel avri le čhavores,
\q1 te les demeha la pacaha, na merela.
\q1 
\v 14 Te les demeha la pacaha,
\q1 zachraňineha leskro dživipen andral o peklos.
\b
\q1 
\v 15 Čhavo miro, te ela tiro jilo goďaver,
\q1 the miro jilo radisaľola;
\q1 
\v 16 andre ma ela o radišagos,
\q1 sar tire vušta vakerena, so hin čačo.
\b
\q1 
\v 17 Te na zavidzinel tiro jilo le binošnenge,
\q1 ale feder kereha, te phireha andre sveto dar anglo RAJ sako džives,
\q1 
\v 18 bo užarel tut bachtalo dživipen,
\q1 a oda, pre soste tut zmukes, na ela zbitočno.
\b
\q1 
\v 19 Šun, čhavo miro, av goďaver
\q1 a tiro jilo mi džal rovne dromeha:
\q1 
\v 20 Ma ľiker tut le pijakenca, so pijen but mol,
\q1 aňi olenca, so našťi dočaľon pro mas,
\q1 
\v 21 bo o pijakos the oda, ko but chal, ačhena čore;
\q1 te ča soves the chas, ela tut ča čhingerde gada.
\b
\q1 
\v 22 Šun tire dades, bo ov tut diňa dživipen,
\q1 a ma dikh tele tira da, sar phurola.
\q1 
\v 23 Cin tuke o čačipen a ma biken les,
\q1 cin the o goďaveripen, o dovakeriben the o achaľuvipen.
\q1 
\v 24 Baro radišagos hin le dades le čačipnaskre čhastar,
\q1 a oda, ko anďa pro svetos le goďaveres, radisaľol lestar.
\q1 
\v 25 Mi radisaľol tiro dad the tiri daj,
\q1 a mi thovel baripen odi, so tut anďa pro svetos.
\b
\q1 
\v 26 De mange, čhavo miro, tiro jilo
\q1 a tire jakha mištes mi dikhen pre mire droma,
\q1 
\v 27 bo e lubňi hiňi sar e bari chev,
\q1 a e cudzo džuvľi hiňi sar e saňi chaňig:
\q1 
\v 28 Oj pre tu užarel sar o zbujňikos
\q1 a but muršendar kerel napačivalen.
\b
\q1 
\v 29 Kaske vigos a ko furt cerpinel?
\q1 Ko pes vesekedinel? Ko furt dudrinel?
\q1 Kas hin o zbitočna modrini?
\q1 Kaske ľoľon o jakha?
\q1 
\v 30 Olenge, ko pijen but mol,
\q1 olenge, ko džan te koštoľinel e mišimen mol.
\q1 
\v 31 Ma dikh pre mol, hoj ľoľol,
\q1 bľišťisaľol andro poharis a šukares džal tele le kirleha!
\q1 
\v 32 Bo pro koňec tut danderela sar o sap
\q1 a šťipinela sar e zmija.
\q1 
\v 33 Tire jakha dikhena čudna veci,
\q1 našťi gondoľineha mištes a na vakereha žužes
\q1 
\v 34 a aveha sar oda, ko peske pašľol pre loďa maškar o moros,
\q1 sar oda, ko sovel upre pro stožjaris.
\q1 
\v 35 Pheneha tuke: „Demade man, ale na džanavas olestar;
\q1 marde man, ale ňič na šunďom.
\q1 Kana uščava, hoj te pijav pale?“
\c 24
\q1 
\v 1 Ma zavidzin le nalačhe manušenge
\q1 a ma kam lenca te avel,
\q1 
\v 2 bo le jileha gondoľinen pro mariben
\q1 a le vuštenca vakeren, sar te dukhavel avren.
\b
\q1 
\v 3 La goďaha pes ačhavel o kher
\q1 a le achaľuvipnaha pes zoraľarel
\q1 
\v 4 a le prindžaripnaha pherďon o komori
\q1 savore vzacne the šukar barvaľipnaha.
\b
\q1 
\v 5 Feder hin te el goďaver, sar te el zoralo,
\q1 o avrisikado manuš hino bareder sar o zoralo murš,
\q1 
\v 6 bo le goďaver radenca ľidžaha o mariben
\q1 a e zachrana hiňi andro but radci.
\b
\q1 
\v 7 O goďaveripen hin igen učo le dilineske;
\q1 sar pes zdžan o manuša, nane les ňič lačho te phenel.
\b
\q1 
\v 8 Oles, ko gondoľinel, sar te kerel o nalačhipen,
\q1 vičinena bitangos;
\q1 
\v 9 o gondoľišagos le nagoďavereskro hin binos;
\q1 le manušenge džungľol oda, ko asal savore lačhipnastar.
\b
\q1 
\v 10 Te slabisaľos andre oda džives, sar pre tu avel o pharipen,
\q1 akor sal čačes igen slabo!
\q1 
\v 11 Zachraňin olen, kas načačipnaha ľidžan pro meriben,
\q1 a the olen, kas cirden te murdarel.
\q1 
\v 12 Te pheneha: „Amen olestar na džanahas,“
\q1 či oda, ko prindžarel o jile, oleske na achaľol?
\q1 A či oda, ko stražinel tiro dživipen, olestar na džanel?
\q1 Ov počinela le manušeske pal oda, sar kerelas.
\b
\q1 
\v 13 Cha, čhavo miro, o medos, bo hino lačho:
\q1 Ajso gulo sar o medos andre tiro muj
\q1 
\v 14 avke hin the o goďaveripen tira dušake.
\q1 Te les arakhľal, aveha bachtalo andro dživipen, so tut užarel,
\q1 a oda, pre soste tut zmukes, na ela hijaba.
\b
\q1 
\v 15 Ma av sar o nalačho manuš, ko kamel te rozmarel le čačipnaskereske o kher;
\q1 ma musar oda than, kaj bešel.
\q1 
\v 16 Se kajte o čačipnaskro eftavar perela, the avke pale ušťela,
\q1 ale sar avel o nalačhipen pro bijedevleskre, hine zňičimen.
\b
\q1 
\v 17 Ma radisaľuv, te tiro ňeprijaťeľis perela;
\q1 te leske poddžala o pindro, ma thov baripen andro jilo,
\q1 
\v 18 bo te oda o RAJ dikhela,
\q1 na ela leske pre dzeka
\q1 a visarela lestar peskri choľi.
\b
\q1 
\v 19 Le nalačhe manušenca tut ma trapin,
\q1 aňi lenge ma zavidzin.
\q1 
\v 20 Se le nalačhe manušes na užarel ňič lačho,
\q1 a e lampa olengri, ko dživen bi o Del, murdaľola andre.
\b
\q1 
\v 21 Čhavo miro, dara tut le Devlestar the le kraľistar,
\q1 a ma ľiker tut olenca, ko pre lende džan,
\q1 
\v 22 bo jekhvareste šaj ena zňičimen.
\q1 Ko džanel, savi pohroma pre lende o Del vaj o kraľis šaj mukel?
\s1 Aver goďaver lava
\q1 
\v 23 The kala lava phende o goďaver manuša:
\q1 Nane mištes te chudel paš varekaste, sar sudzines:
\q1 
\v 24 O manuša košena ajses, ko phenela le nalačhe manušeske: „Na kerďal ňič nalačho,“
\q1 a o narodi les odsudzinena,
\q1 
\v 25 ale olenge, ko les pokarhinena, džala mištes
\q1 a bešela pre lende o baro požehnaňje.
\q1 
\v 26 Te odphenes čačipnaha,
\q1 oda hin avke, sar te pes čumidlehas o prijaťeľa.
\b
\q1 
\v 27 Ker tuke ešeb tiri buči avral,
\q1 pripravin tuke tire maľi
\q1 a paľis tuke ačhaveha o kher.
\b
\q1 
\v 28 Ma svedčin pre aver dženo, te tut nane soske,
\q1 a ma klamin tire vuštenca.
\q1 
\v 29 Ma phen: „Avke sar kerďa ov mange, kerava the me leske!
\q1 Sakoneske dava pale oda nalačho, so mange kerďa!“
\b
\q1 
\v 30 Predžavas pašal e maľa le leňive muršeskri
\q1 the pašal e viňica oleskri, ko nane goďaver.
\q1 
\v 31 A dikh, savoro sas zabarardo le koľakenca,
\q1 e phuv sas učharďi andre la pokrivaha
\q1 a o baruno muros, so džalas pašal, sas telečhido.
\q1 
\v 32 A me sar pre oda dikhavas, iľom mange oda andro jilo
\q1 a sikľiľom olestar kada:
\q1 
\v 33 Te tuke phenes: „Mek sikra mange sovav, mek sikra mange pašľuvav,
\q1 sikra mange prethovav o vasta a odpočovinav mange,“
\q1 
\v 34 akor jekhvareste pre tu avela o čoripen sar o zbujňikos
\q1 the e bokh sar o vizbrojimen murš.
\c 25
\s1 Buter le Šalamunoskre privakeribena
\p 
\v 1 The kala hine le Šalamunoskre privakeribena, save pisinde andre o murša le Chizkijoskre le judske kraľiskre.
\q1 
\v 2 Le Devleskri slava hin o veci te garuvel
\q1 a le kraľengri slava hin oda te arakhel avri.
\q1 
\v 3 Avke sar našťi te merinel o ňebos upre aňi e phuv tele,
\q1 avke pes na del te avel pre oda, so hin le kraľen andro jile.
\b
\q1 
\v 4 Le avri e mel andral o rup
\q1 a o kovačis šaj kerel šukar nadoba;
\q1 
\v 5 trade het le nalačhe manušes pašal o kraľis
\q1 a leskro tronos ačhela zorales pro čačipen.
\b
\q1 
\v 6 Ma ašar tut anglo kraľis
\q1 a ma ačh pro than le anglune muršengro,
\q1 
\v 7 bo hin feder, te tuke phenena: „Av kade upre!“
\q1 sar oda, hoj tuke te keren ladž anglo bare manuša.
\b
\q1 Oda, so dikhľal pre tire jakha,
\q1 
\v 8 ma siďar te del andre pro sudos.
\q1 So paľis kereha, te tut aver dženo anela andre ladž?
\b
\q1 
\v 9 Te tut hin vareso avreha, keren oda ča maškar tumende
\q1 a ma phen avri oda, so tuke phenďa,
\q1 
\v 10 bo sar pes pal oda aver džene došunena
\q1 džala pal tu o nalačho hiros a ela tuke ladž.
\b
\q1 
\v 11 Avke sar o somnakune phaba pre rupuňi tacka
\q1 hin o lav phendo andro lačho časos.
\q1 
\v 12 Oleske, ko šunel, hin o dovakeriben le goďavereskro
\q1 sar e somnakuňi čeň the o somnakuno lancocis.
\q1 
\v 13 Sar o šilalo paňi, so tut den te pijel andre žatva
\q1 avke hin o pačivalo poslos olenge, ko les bičhaven,
\q1 bo občerstvinel e duša peskre rajenge.
\q1 
\v 14 Sar o chmari abo e balvaj bi o brišind
\q1 ajso hin o manuš, savo tuke phenel, hoj tut dela daros, ale na del.
\q1 
\v 15 E trpezľivosť šaj prevakerel le kraľis
\q1 a o kovlo vakeriben šaj prephagel o kokalos.
\q1 
\v 16 Te arakhľal medos, cha a čaľuv,
\q1 ale ma precha tut, bo čhandeha les avri.
\q1 
\v 17 Ma phir igen furt ko susedas,
\q1 bo leske džungľoha a našťi tut avri ačhela.
\q1 
\v 18 O manuš, savo falošňe svedčinel pre aver dženo,
\q1 hino sar o kijakos, e šabľa the o ostro šipos.
\q1 
\v 19 Te zmukel pes andro pharipen pro napačivalo manuš
\q1 hin sar te chal le phage dandeha a te phirel phage pindreha.
\q1 
\v 20 Sar te tuke ilehas o plašťos andro šilalo džives
\q1 abo čhidehas o šut andre dukhaďi rana,
\q1 avke hin, te tuke giľaven o giľa, sar tut hin pharipen andro jilo.
\q1 
\v 21 Te hino tiro ňeprijaťeľis bokhalo, de les te chal,
\q1 a te hino smedno, de les te pijel,
\q1 
\v 22 bo te kada kereha, čhiveha leske pro šero o jagale angara,
\q1 a o RAJ tuke vaš oda počinela.
\q1 
\v 23 E balvaj pal o severos anel o brišind,
\q1 avke the e pľetkošno čhib anel e choľi.
\q1 
\v 24 Feder hin te bešel pro pados andro kutos
\q1 sar andre jekh kher la čhibaľa romňaha.
\q1 
\v 25 Sar hin o šilalo paňi le avrišuke kirleske,
\q1 avke hin the o lačho hiros, so avel dural.
\q1 
\v 26 Sar o prameňis vaj e chaňig, so hine meľarde andre,
\q1 avke hin o čačipnaskro, savo pomukel le nalačhe manušeske.
\q1 
\v 27 Nane mištes te chal igen but medos
\q1 aňi te džal pal o lašariben le manušendar.
\q1 
\v 28 Sar o rozburimen foros bi o muri
\q1 hin oda murš, ko na zľikerel peskri choľi.
\c 26
\q1 
\v 1 Sar o jiv ňilaje abo o brišind andre žatva,
\q1 avke na pasinel te del pačiv le dilines.
\q1 
\v 2 Sar o vrabcos vaj e lastovička ľecinen a na bešen peske tele,
\q1 avke pre tu na avela o košiben phendo vaš ňisoske.
\q1 
\v 3 Pro graj o bičos, pro somaris e uzda,
\q1 a pro dumo le dilineske e paca.
\q1 
\v 4 Ma odphen le dilineske pre leskro diliňipen,
\q1 hoj te na aves ajso sar ov.
\q1 
\v 5 Odphen le dilineske pre leskro diliňipen,
\q1 hoj pes te na šunel goďaver angle peskre jakha.
\q1 
\v 6 Te bičhavel o lava le dilineha hin avke,
\q1 sar te odčhinďalas tuke o pindre, abo te piľalas o jedos.
\q1 
\v 7 Avke sar hin pre ňisoste o pindre le kaľikoske,
\q1 avke hin the o podobenstvo andro muj le dilineske.
\q1 
\v 8 Sar o bar zaphandlo andre pariďa
\q1 avke hin te presikavel e pačiv le dilineske.
\q1 
\v 9 Sar e šťamba andro vast le mate manušeske
\q1 avke dičhol o goďaver lav andro muj le dilinenge.
\q1 
\v 10 Sar o strelcos, savo savoren pašal peste ľivinel,
\q1 ajso hin oda, ko lel andre buči le dilines vaj oles, ko odarik ča predžal.
\q1 
\v 11 Sar o rikono džal pale paš oda, so čandľa avri,
\q1 avke o dilino kerel pale peskro diliňipen.
\q1 
\v 12 Le dilines hin feder naďej,
\q1 sar le muršes, savo pes šunel igen goďaver, ale nane.
\b
\q1 
\v 13 O leňivo phenel: „O ľevos hino avri pro drom –
\q1 o ľevos maškar o foros!“
\q1 
\v 14 Sar pes o vudar visarel pre peskre čopi,
\q1 avke the o leňivo pre peskro hadžos.
\q1 
\v 15 O leňivo manuš thovel o vast andro čaro,
\q1 ale imar phares leske hin te hazdel les upre paš o muj.
\q1 
\v 16 O leňivo pes šunel goďavereder angle peskre jakha
\q1 sar o efta džene, so odphenen goďaha.
\b
\q1 
\v 17 Sar oda, ko le rikones chudel kanendar,
\q1 hin oda, ko pes thovel andro vesekedišagos, andre savo les nane ňič.
\q1 
\v 18 Sar o dilino, so ľivinel
\q1 o jagale meribnaskre šipi,
\q1 
\v 19 hin oda, ko thovel varekaha avri
\q1 a phenel: „Me ča pheras keravas.“
\b
\q1 
\v 20 Sar nane kašta, murdaľol andre e jag,
\q1 a kaj nane o pľetkaris, preačhel o vesekedišagi.
\q1 
\v 21 Sar o kašta, so čhives andro jagale angara,
\q1 avke o čhibakro manuš rozlabarel o dokeriben.
\q1 
\v 22 O lava le pľetkariskre hine gulore;
\q1 džan dži tele andre džombra.
\b
\q1 
\v 23 Sar e piri čikatar obthoďi le rupoha,
\q1 ajse hine o gule vušta le nalačhe jileha.
\q1 
\v 24 O manuš le vuštenca garuvel, hoj tut našťi avri ačhel,
\q1 ale andro jilo tuha kamel te thovel avri.
\q1 
\v 25 Te vakerďahas igen šukares, ma pača leske,
\q1 bo efta džungipena hin les andro jilo;
\q1 
\v 26 šaj garuvel, hoj tut našťi avri ačhel, le klamišagoha,
\q1 ale leskro nalačhipen avela avri anglo manuša, sar ena zgele.
\q1 
\v 27 Te kopaľineha e chev avreske, tu korkoro andre pereha;
\q1 te ispideha o baro bar pre avreste, oda bar visaľola pre tu.
\q1 
\v 28 E klamišagoskri čhib dukhavel oles, kas našťi avri ačhel;
\q1 o gule vušta zňičinen avren.
\c 27
\q1 
\v 1 Ma lašar tut tajsaskre dživeseha,
\q1 bo na džanes, so oda džives anela.
\q1 
\v 2 Mi lašarel tut aver dženo, a na tiro muj –
\q1 cudzo manuš, a na tire vušta!
\q1 
\v 3 O bar hino pharo the e poši but važinel,
\q1 ale o pharipen, so kerel o dilino, hino phareder sar kala soduj.
\q1 
\v 4 Te choľisaľol hin igen namištes a e choľi hin sar e potopa,
\q1 ale ko obačhela angle žjarlivosť?
\q1 
\v 5 Feder hin o phundrado dovakeriben
\q1 sar o garudo kamiben.
\q1 
\v 6 O dovakeribena tire prijaťelistar, savo tut kamel,
\q1 hine feder sar o but čumibena olestar, ko tut našťi avri ačhel.
\q1 
\v 7 O čalo na kamel te chal aňi o medos,
\q1 ale le bokhaleske hin gulo the o kirko chaben.
\q1 
\v 8 Sar o čiriklo, so odľecinel dur peskre hňizdostar,
\q1 hin oda, ko odgeľa dur peskre kherestar.
\q1 
\v 9 O parfumos the o kaďidlos anen radišagos andro jilo,
\q1 ale o prijaťeľis, savo tut del e lačhi rada, anel meksa buter.
\q1 
\v 10 Ma omuk tire prijaťeľis, aňi le prijaťeľis tire dadeskres.
\q1 Sar pes tuke ačhel vareso nalačho, ma dža ke tiro phral,
\q1 bo feder hin o susedas, savo hino pašes, sar o phral, savo hino dur.
\q1 
\v 11 Av goďaver, čhavo miro, a ker mange o radišagos andro jilo,
\q1 hoj te šaj odphenav oleske, ko pre mande namištes vakerel.
\q1 
\v 12 O goďaver manuš dikhel, sar avel o nalačhipen a garuvel pes,
\q1 ale o nagoďaver džan dureder a doperena pre oda.
\q1 
\v 13 Le o gada olestar, ko pes zaručinel vaš o cudzincos;
\q1 le e zaloha olestar, ko pes zaručinďa vaš e cudzinka.
\q1 
\v 14 Te vareko peskre prijaťeľiske pozdravinel sig tosara zorale hangoha,
\q1 ov peske šaj lel oda sar košiben.
\b
\q1 
\v 15 E čhibaľi džuvľi hiňi sar o paňi,
\q1 so na preačhel te kvapkinel andro brišindalo džives;
\q1 
\v 16 te zaačhavel la, hin sar te zaačhavel e balvaj,
\q1 abo te chudel o olejos andro vast.
\b
\q1 
\v 17 O trast pes brušinel le trasteha
\q1 a jekh manuš brušinel avres.
\q1 
\v 18 Oda, ko pes starinel pal o figovňikos, chala leskro ovocje;
\q1 ko stražinel peskre rajes, chudela e pačiv.
\q1 
\v 19 Sar andro paňi dičhol o muj,
\q1 avke pal o jilo dičhol, savo hin o manuš.
\q1 
\v 20 Avke sar o peklos the o meriben šoha na čaľona,
\q1 avke na čaľona aňi o jakha le manušeskre.
\q1 
\v 21 Sar pes o rup prelabarel andre tači nadoba a o somnakaj andro bov,
\q1 avke o manuš hino skušimen, te les lašaren.
\q1 
\v 22 Kajte le dilines rozmarďalas le tlučkoha, saveha pes rozmarel o zrnos,
\q1 the avke lestar na mareha avri o diliňipen.
\b
\q1 
\v 23 Kampel tuke te džanel, sar dživel tiro stados,
\q1 a starin tut mištes pal o bakrore,
\q1 
\v 24 bo o barvaľipen na ela pro furt –
\q1 se aňi e kraľiko koruna na mušinel te predžal pre aver pokoleňje.
\q1 
\v 25 Sar pes košinel e čar a chudel te barol e nevi,
\q1 a pal o verchi pes skiden upre o phusa,
\q1 
\v 26 akor tut ela le bakrorendar o uraviben,
\q1 vaš o capi tuke cineha e maľa
\q1 
\v 27 a le kozendar tut ela dos thud,
\q1 pro dživipen tuke, tira famelijake the tire služkenge.
\c 28
\q1 
\v 1 O nalačho manuš denašel, kajte ňiko pre leste na džal,
\q1 ale o čačipnaskro hino šmelo sar o terno ľevos.
\q1 
\v 2 Te hin e vzbura andre varesavi phuv, čerinen pes furt o vodci,
\q1 ale ča o goďaver murš, ko achaľol, šaj doľikerel o poradkos.
\q1 
\v 3 O čoro murš, savo trapinel avre čore manušen,
\q1 hino sar o zoralo brišind, so musarel o uľipen.
\q1 
\v 4 Ola, ko omuken o zakonos, vakeren mištes pal o nalačhe,
\q1 no ola, ko o zakonos doľikeren, pes lenge ačhaven.
\q1 
\v 5 O nalačhe manuša na achaľon, so hin te kerel o čačipen,
\q1 ale ola, ko roden le RAJES, oleske mištes achaľon.
\q1 
\v 6 Feder hin o čoro, savo phirel žuže dromeha,
\q1 sar o barvalo, saveskre droma hine previsarde.
\q1 
\v 7 Te doľikeres o zakonos, sal goďaver čhavo,
\q1 no keres ladž le dadeske, te tut ľikeres le bitangenca.
\q1 
\v 8 Ko barvaľol pro bare interesa,
\q1 skidel oda oleske, kaske hin pharo vaš o čore.
\q1 
\v 9 Te peske vareko phandel andre o kana, hoj te na šunel o zakonos,
\q1 leskri modľitba le RAJESKE džungľol.
\q1 
\v 10 Ko cirdel le čačipnaskren pro nalačho drom, korkoro perela andre chev,
\q1 ale o žuže dochudena lačho ďeďictvos.
\q1 
\v 11 O barvalo peske pal peste gondoľinel, hoj hino goďaver,
\q1 ale o čoro, saves hin goďi, dikhel andre leste.
\q1 
\v 12 Te pes o lačhe manuša dochuden paš e zor, sako radisaľol,
\q1 no te o nalačhe manuša chuden te kraľinel, o manuša pes garuven.
\q1 
\v 13 Ko garuvel peskro binos, na džala anglal,
\q1 ale ko viznavinel peskro binos a omukel les,
\q1 chudela le Devleskro jileskeriben.
\q1 
\v 14 Bachtalo oda manuš, savo peske furt ľikerel e sveto dar anglo RAJ,
\q1 no ko peske phandel o jilo andre, dochudela pes andro pharipen.
\q1 
\v 15 Sar o choľamen ľevos the o bokhalo medvedzis
\q1 hin o nalačho kraľis, savo trapinel le čore manušen, save pes našťi braňinen.
\q1 
\v 16 O nagoďaver vodcas ela bijileskro pro manuša,
\q1 ale oda, ko našťi avri ačhel o napačivalo barvaľipen, kraľinela but.
\q1 
\v 17 Oda, ko cerpinel vaš oda, hoj murdarďa varekas, denašela dži o meriben.
\q1 Ňiko leske te na pomožinel!
\q1 
\v 18 Ko phirel žuže dromeha, ela zachraňimen,
\q1 no oda, ko phirel pal o previsarde droma, jekhvareste perela.
\q1 
\v 19 Ko kerel pre peskri maľa, čaľola le marestar,
\q1 ale oda, ko del peskro časos pre ňisoste, čaľola le čoripnastar.
\q1 
\v 20 O pačivalo manuš ela igen požehňimen,
\q1 no o trestos na obdžala oles, ko kamel sig te barvaľol.
\q1 
\v 21 Nane mištes te chudel paš varekaste pro sudos,
\q1 no the avke pes vareko vaš jekh kotor maro del te prepočinel.
\q1 
\v 22 O hamišno manuš denašel pal o barvaľipen,
\q1 aňi na džanel, hoj pre leste avela o čoripen.
\q1 
\v 23 Oles, ko dovakerel le manušeske, pro koňec ela buter pačiv
\q1 sar oles, ko vakerel o gule lava.
\q1 
\v 24 Ko občorel peskre dades abo da a phenel:
\q1 „Oda nane binos,“ hino sar o živaňis.
\q1 
\v 25 Oda, ko dikhel ča pre peste, anel ča o vesekedišagi,
\q1 ale oles, ko pes zmukel pro RAJ, ela savoro pherdo.
\q1 
\v 26 Ko pes zmukel pre peskri goďi, hino dilino,
\q1 no oda, ko prilel o goďaveripen, ela zachraňimen.
\q1 
\v 27 Te des le čoren, na chibaľinela tuke ňič,
\q1 ale te phandes o jakha anglo čore, but manuša tut košena.
\q1 
\v 28 Sar o nalačhe chuden te vladňinel, o manuša pes garuven,
\q1 no sar on peren tele, akor ušťen upre o čačipnaskre.
\c 29
\q1 
\v 1 Oda, kaske sas buterval dovakerdo a ačhiľa zacato andro jilo,
\q1 ela jekhvareste zňičimen a ňič les na sasťarela.
\q1 
\v 2 Sar o lačhe manuša ľidžan, o nipi radisaľon,
\q1 ale te o nalačho vladňinel, o manuša jojčinen.
\q1 
\v 3 Ko kamel o goďaveripen, kerel peskre dadeske radišagos,
\q1 no oda, ko phirel pal o lubňa, rozkerel o barvaľipen.
\q1 
\v 4 Te o kraľis ľidžal čačipnaha, o narodos ela zoralo,
\q1 ale zňičinela les oda, ko pal leste cirdel tele e cipa le daňenca.
\q1 
\v 5 O manuš, savo pes guľarel ke avreste,
\q1 nacirdel e sita tel o pindre.
\q1 
\v 6 O nalačho manuš hino zachudlo andre pasca peskre binoskri,
\q1 ale o čačipnaskro giľavel a radisaľol.
\q1 
\v 7 O lačho džal pal o čačipen le čore manušeskro,
\q1 ale o nalačho manuš olestar na ačhel, bo oleske na achaľol.
\q1 
\v 8 Ola, ko asan savore lačhipnastar, keren o nasmirom andro foros,
\q1 ale o goďaver anen pale o smirom.
\q1 
\v 9 Sar pes o goďaver sudzinel le dilineha,
\q1 ča viskinel vaj asal a furt nane smirom.
\q1 
\v 10 O vrahi našťi avri ačhen le pačivales,
\q1 no o lačhe manuša les kamen te zachraňinel.
\q1 
\v 11 O dilino dela pestar avri savori choľi,
\q1 ale o goďaver ľikerela peskro jilo andro smirom.
\q1 
\v 12 Te o vladcas šunel o klamišagi,
\q1 savore leskre sluhi ačhena nalačhe.
\q1 
\v 13 Le žobrakos the ole manušes, ko les trapinel, hin kada jekh:
\q1 O RAJ del o dživipen sodujen.
\q1 
\v 14 Te o kraľis sudzinel le čoren čačipnaha,
\q1 leskro tronos ačhela pro furt.
\q1 
\v 15 E paca the o dovakeriben del goďi le čhas,
\q1 ale o rozmuklo čhavoro peskra dake kerel ladž.
\q1 
\v 16 Sar vladňinen o nalačhe manuša, o nalačhipen barol,
\q1 ale o čačipnaskre len dikhena te perel tele.
\q1 
\v 17 Mištes barar avri tire čhas, bo ela tut smirom
\q1 a kerela tuke baro radišagos.
\q1 
\v 18 Ode, kaj nane le Devleskro veďeňje, o manuša ačhena rozmukle.
\q1 Bachtale hine ola, ko doľikeren le Devleskro zakonos.
\q1 
\v 19 Na del pes te dovakerel le otrokoske ča le laveha;
\q1 ov achaľol, so phenes, ale na ačhel olestar.
\q1 
\v 20 Dikhľal le muršes, savo sig vakerel a na gondoľinel?
\q1 Le dilines hin feder naďej sar les.
\q1 
\v 21 Te des tire sluhas ciknovarestar sa, so kamel,
\q1 pro koňec tuke lela savoro, so tut hin.
\q1 
\v 22 O rušlo manuš kerel o vesekedišagi;
\q1 oda, ko sig choľisaľol, perel andro but bini.
\q1 
\v 23 O baripen le manušes thovela tele,
\q1 ale oda, ko hino pokorno andro duchos, chudela e pačiv.
\q1 
\v 24 Ko pomožinel le živaňiske te čorel, dukhavel pes korkores,
\q1 bo pro sudos lel pre peste vera, ale daral te phenel o čačipen.
\q1 
\v 25 Te tut daraha le manušendar, hoj so peske gonďolinena, zachudeha tut andre pasca,
\q1 ale te tut zmukeha pro RAJ, aveha chraňimen.
\q1 
\v 26 But džene kamen te dochudel le kraľis pre peskri sera,
\q1 ale ča o RAJ del čačipen le manušes.
\q1 
\v 27 Le lačhe manušenge džungľol o nalačho manuš
\q1 a le nalačhe manušeske džungľol oda, ko dživel čačipnaha.
\c 30
\s1 O lava le Aguroskre
\p 
\v 1 Kala lava hine dine le Devlestar le Aguroske, le Jakehoskre čhaske.
\p Oda murš phenďa:
\b
\q1 „Strapimen som, Devla, strapimen\f + \fr 30,1 \ft Abo: le Itieloske, le Itieloske the le Uchaloske \f*.
\q1 
\v 2 Jaj, som sar džviros, na gondoľinav sar manuš;
\q1 nane man le manušengri goďi.
\q1 
\v 3 Na sikľiľom o goďaveripen
\q1 a nane man aňi o prindžaripen pal o Neksveteder.
\q1 
\v 4 Ko geľa upre andro ňebos? Ko odarik avľa tele?
\q1 Ko skidňa andre peskri burňik e balvaj?
\q1 Ko pačarďa o paňi andro plašťos?
\q1 Ko merinďa avri savore agora la phuvakre?
\b
\q1 
\v 5 Dojekh lav le Devleskro hino čačo,
\q1 hino šťitos savorenge, ko ke leste denašen.
\q1 
\v 6 Ma dothov ňič ke leskre lava,
\q1 hoj tuke te na dovakerel a te na sikavel pre tu, hoj sal klamaris.
\b
\q1 
\v 7 Duj veci tutar mangav, RAJEJA,
\q1 de mange len sigeder, sar merava:
\q1 
\v 8 Le mandar o klamišagos the o načačipen!
\q1 Ma de man o čoripen aňi o barvaľipen!
\q1 De man ajci maro, keci mange kampel,
\q1 
\v 9 hoj man te na prechav, te na zaprinav tut a te na phenav:
\q1 ‚Ko hin o RAJ?‘
\q1 Abo te na ačhav čoro, hoj te na čorav
\q1 a te na kerav ladž le Devleskre naveske.
\b
\q1 
\v 10 Ma vaker namištes pro sluhas angle leskro raj,
\q1 hoj tut o sluhas te na prekošel a te na počines vaš oda.
\q1 
\v 11 Varesave manuša košen peskre dades
\q1 a peskra dake na žehňinen;
\q1 
\v 12 varesave peske gondoľinen, hoj hine lačhe,
\q1 ale nane obžužarde la meľatar;
\q1 
\v 13 varesave barikanes dikhen le jakhenca
\q1 a hazden upre o bervi!
\q1 
\v 14 Varesaven hin o danda sar o šabľi
\q1 a andro muj len hin sar te pherdo čhura,
\q1 hoj te chan le slaben pre phuv
\q1 the le čoren le manušendar.
\b
\q1 
\v 15 La pijavica hin duj čhaja a viskinen: ‚De man, de man!‘
\q1 Hin trin veci, so našťi dočaľon,
\q1 štar, so na phenena ‚Dos!‘:
\q1 
\v 16 O peklos, e džuvľi, savi našťi ačhel khabňi,
\q1 e šuki phuv, savake furt kampel o paňi,
\q1 the e jag šoha ňikda na phenena: ‚Dos!‘
\b
\q1 
\v 17 E jakh, so asal le dadestar
\q1 a dikhel tele peskra phura da,
\q1 džubinena avri o havrani andral e dolina
\q1 a chana les o supi.
\b
\q1 
\v 18 Hin trin veci, so mange hine čudna,
\q1 štar, savenge na achaľuvav:
\q1 
\v 19 o drom le orloskro, so ľecinel pro ňebos,
\q1 o drom le sapeskro pal e skala,
\q1 o drom la loďakro maškar o moros
\q1 a o drom le muršeskro paš e terňi džuvľi.
\b
\q1 
\v 20 Kavke kerel e lubňi:
\q1 Chal, khosel o vušta
\q1 a phenel: ‚Na kerďom ňič nalačho.‘
\q1 
\v 21 Hin trin veci, savendar e phuv izdral,
\q1 štar, savendar na birinel:
\q1 
\v 22 Le sluhastar, savo kraľinel,
\q1 le dilinestar, savo pes prechal le mareha,
\q1 
\v 23 la nalačha džuvľatar, sar džal romeste,
\q1 the la služkatar, savi zalel o than peskra raňake.
\b
\q1 
\v 24 Kala štar džviri pre phuv hine cikne,
\q1 ale igen goďaver:
\q1 
\v 25 O mravci – nane zorale,
\q1 ale ňilaje peske pripravinen o chaben;
\q1 
\v 26 o damana – nane igen zorale,
\q1 ale bešen maškar o skali;
\q1 
\v 27 o maľakre grajora – nane len vodcas,
\q1 ale savore ľecinen jekhetane andre čata sar slugaďa;
\q1 
\v 28 o jašťerički – šaj len te chudel andro vast,
\q1 ale the avke bešen andro kraľengre palaca.
\b
\q1 
\v 29 Hin trin, so peske rajikanes phiren,
\q1 štar, so barikanes pochodinen:
\q1 
\v 30 O ľevos – nekzoraleder maškar o džviri,
\q1 so na daral ňikastar;
\q1 
\v 31 o barikano kohutos, o capos
\q1 the o kraľis, sar džal angle peskre manuša.
\b
\q1 
\v 32 Te kerďal o diliňipen oleha, hoj tut ašarehas,
\q1 a te gondoľinehas pro nalačho, dander tuke andre čhib!
\q1 
\v 33 Te mišines e šmetanka, avel upre o čhil;
\q1 te demes varekas andro nakh, avel avri o rat;
\q1 a te choľares avres, ela o vesekedišagos.“
\c 31
\s1 O lava le Lemueloskre
\p 
\v 1 O goďaver lava le kraľiskre Lemueloskre – o lava dine le Devlestar, savenca les e daj bararelas avri.
\b
\q1 
\v 2 Ó, čhavo miro! Čhavo miro, saves anďom pro svetos!
\q1 Šun, čhavo miro, saves mangavas le Devlestar!
\q1 
\v 3 Ma de avri tiri zor pre oda, hoj pašľoha le džuvľenca,
\q1 bo oda zňičinďa but kraľen.
\q1 
\v 4 Nane oda šukares, Lemuelina,
\q1 na pasinel le kraľenge te pijel e mol,
\q1 aňi le vladarenge o aver pijiben,
\q1 
\v 5 bo sar pijen, bisteren pro zakoni
\q1 a previsaren o pravos savore čore manušengro.
\q1 
\v 6 Den te pijel oles, ko imar merel,
\q1 a e mol olen, ko hine andro pharipen.
\q1 
\v 7 Mi pijel, hoj te bisterel pre peskro čoripen,
\q1 a te na leperel peske pro pharipen.
\q1 
\v 8 Phundrav tiro muj vaš oda, ko hino ňemo,
\q1 the vaš o čačipen savore slabengro.
\q1 
\v 9 Phundrav tiro muj, sudzin čačipnaha
\q1 a ruš vaš o čore the vaš ola, so len ňič nane!
\s1 Pal e lačhi romňi
\q1 
\v 10 Ko šaj arakhel lačha romňa?
\q1 Odi romňi mol buter sar o perli!
\q1 
\v 11 O rom lake pačal andre savoreste,
\q1 angle late les hin sa, so leske kampel.
\q1 
\v 12 Kerel leske o lačhipen, a na o nalačhipen,
\q1 calo lakro dživipen.
\q1 
\v 13 Starinel pes, hoj te avel furt dos vlna the ľanos,
\q1 a radišagoha kerel buči peskre vastenca.
\q1 
\v 14 Hiňi sar e loďa olengri, ko cinen the bikenen,
\q1 so dural anel o maro.
\q1 
\v 15 Ušťel sigeder, sar vidňisaľol,
\q1 hoj te del te chal peskra famelija
\q1 a te rozďelinel e buči peskre služkenge\f + \fr 31,15 \ft Abo: te del len peskro kotor le chabenestar\f*.
\q1 
\v 16 Rodel peske e maľa a cinel la;
\q1 olestar, so peskre vastenca zarodňa, sadzinel e viňica.
\q1 
\v 17 Kerel igen phares
\q1 a hin la zorale vasta pre buči.
\q1 
\v 18 Džanel, hoj oda, so kerel, anel e chasna;
\q1 e lampa lake na murdaľol andre dži rači.
\q1 
\v 19 Peskre vastenca chudel e pacica te kerel o thav
\q1 a korkori peske kerel o pochtana.
\q1 
\v 20 Le čoreske otkerel peskri burňik
\q1 a peskre vasta nacirdel ke oda, kas nane.
\q1 
\v 21 Jevende andro šil pes na daral pal peskri famelija,
\q1 bo savoren andre lakro kher hin te urel o tate veci.
\q1 
\v 22 Sivel peske o uraviben pro hadžos,
\q1 a lakre gada hin le šukar fijalove ľanostar.
\q1 
\v 23 Lakre romes mištes džanen paš e foroskri brana,
\q1 kaj zabešel la phuvakre vodcenca.
\q1 
\v 24 Sivel o pochtana a bikenel len;
\q1 le kupcenge bikenel o sirimi.
\q1 
\v 25 Hiňi urďi andre zor the andre pačiv
\q1 a na daral pes avre dživesestar.
\q1 
\v 26 O muj phundravel goďaha
\q1 a pre čhib la hin o kamibnaskro sikaviben.
\q1 
\v 27 Dodikhel mištes pre savoreste andro kher
\q1 a šoha nane leňivo.
\q1 
\v 28 Sar ušťen lakre čhave, žehňinen lake,
\q1 the lakro rom la ašarel.
\q1 
\v 29 Phenel lake: „But džuvľa hine lačhe romňija,
\q1 ale tu sal savorendar nekfeder!“
\q1 
\v 30 Ma de tuha te thovel avri oleha, hoj e džuvľi hiňi tuke pre dzeka,
\q1 bo o šukariben našľola,
\q1 ale kampel te ašarel ola džuvľa, savi pes daral le RAJESTAR.
\q1 
\v 31 Den kajsa džuvľa pačiv vaš lakri buči
\q1 a ašaren la anglal savorende vaš oda, so kerďa!
