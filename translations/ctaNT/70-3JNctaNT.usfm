\id 3JN  
\h 3 JUAN 
\toc1 Quityi sube nu nguscua San Juan nu nchca tyuna 
\toc2 3 JUAN 
\toc3 3 Jn. 
\mt1 Quityi sube nu nguscua San Juan nu nchca tyuna 
\c 1  
\s1 Tsoꞌo tsa nchcuiꞌ Juan jiꞌi̱ Gayo 
\p  
\v 1 La cuiꞌ nu cusuꞌ Juan laca naꞌ. Nscua naꞌ quityi re chaꞌ ca̱a̱ ca slo nuꞌu̱, Gayo; jlya tiꞌ nuꞌu̱ lcaa chaꞌ nu laca jiꞌi̱ Jesucristo, biꞌ chaꞌ tsoꞌo tsa ntsuꞌu tyiquee naꞌ chaꞌ chcuiꞌ naꞌ loꞌo nuꞌu̱. 
\p  
\v 2 Tsoꞌo tsa ñati̱ laca nuꞌu̱, cusuꞌ. Nchcuiꞌ naꞌ loꞌo ycuiꞌ Ndyosi cuentya jinuꞌu̱ chaꞌ tsoꞌo ti taca tyiꞌi̱ tyiquee nuꞌu̱, chaꞌ taca ca lye tiꞌ nuꞌu̱. Cua jlo tiꞌ naꞌ chaꞌ tsoꞌo tsa ngusñi nuꞌu̱ chaꞌ jiꞌi̱ ycuiꞌ Ndyosi.  
\v 3 Loꞌo juani tsoꞌo tsa ntsuꞌu tyiquee naꞌ chaꞌ cua ndyalaa xi nguꞌ tyaꞌa ntsuꞌu chaꞌ jiꞌna loꞌo Cristo nu ngutuꞌu ca su ndiꞌi̱ ma̱ ya̱a̱ nguꞌ ca nde. Nacui̱ nguꞌ chaꞌ ñaꞌa̱ ti ndaquiyaꞌ tsoꞌo ma̱ jiꞌi̱ chaꞌ liñi nu cua nda Jesús loꞌo na, chaꞌ juaꞌa̱ nduꞌni ma̱ lcaa tsa̱.  
\v 4 Sca ti chaꞌ nclyacua tiꞌ naꞌ cuentya jiꞌi̱ cuꞌma̱, si chañi chaꞌ ndaquiyaꞌ ma̱ jiꞌi̱ chaꞌ liñi nu cua nda Jesús loꞌo na, chaꞌ cuañiꞌ la cuꞌma̱ cuentya jnaꞌ; tsoꞌo tsa ntsuꞌu tyiquee naꞌ loꞌo ndyuna naꞌ chaꞌ juaꞌa̱ nduꞌni ma̱. 
\p  
\v 5 Cusuꞌ, ndube tsa tiꞌ naꞌ chaꞌ lcaa tyempo tsoꞌo tsa nxtyucua nuꞌu̱ jiꞌi̱ nguꞌ tyaꞌa na, masi ná nslo nuꞌu̱ jiꞌi̱ nguꞌ, chaꞌ nguꞌ xaꞌ quichi̱ laca nguꞌ ntsuꞌu quiyaꞌ.  
\v 6 Cua nchcuiꞌ nguꞌ biꞌ loꞌo lcaa nguꞌ tyaꞌa ntsuꞌu chaꞌ jiꞌna loꞌo Jesús nde quichi̱ re, ndachaꞌ nguꞌ jiꞌi̱ ya ñiꞌya̱ nu tsoꞌo ntsuꞌu tyiquee ma̱ ñaꞌa̱ ma̱ jiꞌi̱ ycuiꞌ ca nguꞌ. Loꞌo juaꞌa̱ cuaꞌni ma̱ chaꞌ tsoꞌo tya xtyucua la ma̱ jiꞌi̱ nguꞌ biꞌ tyucui̱i̱ su tsaa nguꞌ, cuaꞌni ma̱ ñiꞌya̱ laca si na nxtyucua ma̱ jiꞌi̱ ycuiꞌ Ndyosi laca;  
\v 7 cña jiꞌi̱ Cristo ndyaꞌa̱ nguꞌ, biꞌ chaꞌ ngutuꞌu nguꞌ biꞌ ndyaa nguꞌ tyijyuꞌ. Ná ntajaꞌa̱ nguꞌ xñi nguꞌ ni sca centavo jiꞌi̱ xaꞌ ñati̱ nu ná ndaquiyaꞌ jiꞌi̱ Cristo tsiyaꞌ ti, chaꞌ xtyucua jiꞌi̱ nguꞌ tyucui̱i̱;  
\v 8 biꞌ chaꞌ nu na ni, tyaꞌa ngusñi na chaꞌ jiꞌi̱ Cristo, ngaꞌa̱ chaꞌ xtyucua na jiꞌi̱ nguꞌ biꞌ. Loꞌo juaꞌa̱ taca ca stuꞌba chaꞌ jiꞌna loꞌo nguꞌ biꞌ loꞌo sañi na chaꞌ liñi nu cua nda Cristo loꞌo na ca tyijyuꞌ la. 
\s1 Cuxi tsa cña nu ndyuꞌni Diótrefes 
\p  
\v 9 Cua nscua naꞌ sca quityi tya tsubiꞌ la nu ndyaa ca su ndiꞌi̱ ñaꞌa̱ taju ti ma̱ ñati̱ jiꞌi̱ Jesucristo, cuꞌma̱ nu ndyuꞌu tiꞌi̱ ma̱ tsa tlyu ti ca biꞌ; pana ná ntajaꞌa̱ Diótrefes taquiyaꞌ jiꞌi̱ chaꞌ nu nacui̱ naꞌ jiꞌi̱ ma̱, chaꞌ ntiꞌ yu biꞌ chaꞌ xuꞌna ma̱ laca yu.  
\v 10 Nu loꞌo tyalaa naꞌ ca slo ma̱, liꞌ chcuiꞌ naꞌ loꞌo ma̱ cuentya jiꞌi̱ lcaa cña nu ndyuꞌni yu biꞌ, chaꞌ chiyaꞌa̱ tsa nchcuiꞌ yu jiꞌi̱ cuare; nchcuiꞌ yu biꞌ cua ñaꞌa̱ ca lo chaꞌ cuiñi loꞌo ñati̱. Masi ndyuꞌni yu juaꞌa̱, ná cuayáꞌ jiꞌi̱ yu ntiꞌ yu, chaꞌ juani ná ntajaꞌa̱ yu ta yu su tyiꞌi̱ nguꞌ tyaꞌa ndyaꞌa̱ ya cña loꞌo ndyaa nguꞌ quichi̱ tyi ma̱; ñaꞌa̱ cuayáꞌ ndacaꞌa yu chacuayáꞌ jiꞌi̱ tyaꞌa ma̱ chaꞌ loꞌo cuꞌma̱ ná ta ma̱ su tyiꞌi̱ nguꞌ, masi ngua tiꞌ ma̱ ta ma̱ su tyiꞌi̱ nguꞌ nquichaꞌ. Loꞌo juaꞌa̱ ngua tiꞌ yu culoꞌo yu jiꞌi̱ tyaꞌa ndyaꞌa̱ ya cña biꞌ, chaꞌ ná tyuꞌu tiꞌi̱ nguꞌ loꞌo ma̱. 
\p  
\v 11 Cusuꞌ, ná tyatí̱ yuꞌu ma̱ loꞌo chaꞌ cuxi nu ntsuꞌu chalyuu, tsoꞌo la si tyiꞌu tiꞌ ma̱ jiꞌi̱ lcaa chaꞌ nu tsoꞌo ti. Lcaa ñati̱ nu xcuiꞌ clyana chaꞌ tsoꞌo nu cuaꞌni nguꞌ chaꞌ xtyucua nguꞌ jiꞌi̱ xaꞌ la tyaꞌa ñati̱ nguꞌ, cua ntsuꞌu chaꞌ jiꞌi̱ nguꞌ biꞌ loꞌo ycuiꞌ Ndyosi; lcaa ñati̱ nu xcuiꞌ clyana chaꞌ cuxi chaꞌ cuaꞌni nguꞌ, bilya tyuꞌu chaꞌ jiꞌi̱ nguꞌ biꞌ tsiyaꞌ ti loꞌo ycuiꞌ Ndyosi. 
\s1 Tsoꞌo la ndyuꞌni Demetrio 
\p  
\v 12 Tsoꞌo tsa nchcuiꞌ lcaa ñati̱ jiꞌi̱ Demetrio; masi ycuiꞌ ca na, loꞌo ñaꞌa̱ na jiꞌi̱ yu nchca cuayáꞌ tiꞌ na chaꞌ tsoꞌo tsa ndyuꞌni yu loꞌo lcaa ñati̱. Juaꞌa̱ cuare, nchcuiꞌ ya loꞌo ma̱ juani chaꞌ chañi tsa chaꞌ nu nchcuiꞌ nguꞌ jiꞌi̱ yu chaꞌ tsoꞌo tsa tyiquee yu. Cua jlo tsoꞌo tiꞌ ma̱ chaꞌ nchcuiꞌ ya chaꞌ liñi loꞌo ma̱. 
\s1 Chaꞌ nu nguscua Juan loꞌo cua tye ti quityi 
\p  
\v 13 Tya ntsuꞌu tsa chaꞌ nu ntiꞌ naꞌ chcui̱ꞌ loꞌo nuꞌu̱, pana tsoꞌo la masi ná scua naꞌ chaꞌ biꞌ lo quityi re juani;  
\v 14 tsoꞌo la yala ti ca̱a̱ naꞌ ca su ndiꞌi̱ nuꞌu̱ chaꞌ ycuiꞌ ca naꞌ ta naꞌ xi chaꞌ loꞌo nuꞌu̱. 
\p  
\v 15 Ti̱ ti tyiꞌi̱ tyiquee ma̱ lacua, chaꞌ ycuiꞌ Ndyosi xtyucua jiꞌi̱ ma̱. Lcaa nguꞌ tyaꞌa tsoꞌo ma̱ nu ndiꞌi̱ ca su ndiꞌi̱ cuare, cua ntiꞌ nguꞌ chcuichaꞌ nguꞌ jiꞌi̱ ma̱, xquiꞌya chaꞌ nu scua naꞌ lo quityi re; juaꞌa̱ cuꞌma̱, chcuichaꞌ ma̱ jiꞌi̱ lcaa nguꞌ tyaꞌa tsoꞌo ya nu ndiꞌi̱ ca ndacua.