\p 
\v 17 \w No|strong="H3808"\w* habrá prostitutas sagradas \w ni|strong="H3808"\w* prostitutos sagrados \w entre|strong="H7130"\w* \w los|strong="H3427"\w* hijos \w de|strong="H5973"\w* Israel.
\v 18 \w No|strong="H3808"\w* llevarás \w como|strong="H1961"\w* voto \w el|strong="H1121"\w* salario \w de|strong="H1121"\w* una prostituta \w ni|strong="H3808"\w* \w de|strong="H1121"\w* un prostituto \w a|strong="H3068"\w* la Casa \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, \w porque|strong="H3808"\w* ambos \w son|strong="H1961"\w* repugnancia \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*.
\p 
\v 19 \w No|strong="H3808"\w* cobrarás interés \w a|strong="H3068"\w* tu hermano \w por|strong="H3588"\w* dinero, \w por|strong="H3588"\w* comida, \w ni|strong="H3808"\w* \w por|strong="H3588"\w* \w cualquier|strong="H3605"\w* \w cosa|strong="H3605"\w* \w por|strong="H3588"\w* \w la|strong="H1571"\w* \w cual|strong="H3588"\w* \w se|strong="H3808"\w* pueda cobrar interés.
\v 20 Al extranjero \w podrás|strong="H3808"\w* cobrar interés, pero \w a|strong="H3068"\w* tu hermano \w no|strong="H3808"\w* le cobrarás, para \w que|strong="H3808"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* te bendiga en \w toda|strong="H3605"\w* obra \w de|strong="H1697"\w* tus manos en \w la|strong="H3605"\w* tierra donde vas para tomar posesión \w de|strong="H1697"\w* \w ella|strong="H3605"\w*.
\p 
\v 21 Cuando hagas algún voto \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, \w no|strong="H3808"\w* tardes \w en|strong="H5921"\w* cumplirlo, \w porque|strong="H5921"\w* ciertamente \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H5921"\w* \w lo|strong="H3808"\w* demandará \w y|strong="H5921"\w* \w será|strong="H3808"\w* pecado \w para|strong="H4616"\w* \w ti|strong="H5921"\w*.
\v 22 \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* \w te|strong="H3588"\w* abstienes \w de|strong="H3588"\w* hacer un \w voto|strong="H5087"\w*, esto \w no|strong="H3808"\w* \w será|strong="H1961"\w* \w pecado|strong="H2399"\w* \w en|strong="H5973"\w* \w ti|strong="H5973"\w*.
\v 23 \w Sin|strong="H3808"\w* embargo \w lo|strong="H3808"\w* \w que|strong="H3588"\w* salga \w de|strong="H3588"\w* tus labios, \w lo|strong="H3808"\w* guardarás \w y|strong="H3588"\w* \w lo|strong="H3808"\w* cumplirás. Conforme prometiste \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, pagarás \w la|strong="H3588"\w* ofrenda voluntaria \w que|strong="H3588"\w* prometiste \w con|strong="H3588"\w* tu boca.
\p 
\v 24 Cuando entres en \w la|strong="H8104"\w* viña de \w tu|strong="H6213"\w* prójimo, podrás comer las uvas \w que|strong="H5071"\w* desees hasta saciarte, pero \w no|strong="H6213"\w* las pondrás en \w tu|strong="H6213"\w* cesta.
\v 25 \w Cuando|strong="H3588"\w* entres \w en|strong="H3588"\w* \w el|strong="H3588"\w* trigal \w de|strong="H3588"\w* tu \w prójimo|strong="H7453"\w*, \w podrás|strong="H3808"\w* arrancar espigas \w con|strong="H3588"\w* \w la|strong="H3588"\w* mano, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* meterás \w la|strong="H3588"\w* hoz \w en|strong="H3588"\w* \w el|strong="H3588"\w* trigal \w de|strong="H3588"\w* tu \w prójimo|strong="H7453"\w*.
\c 24
\p 
\v 1 \w Cuando|strong="H3588"\w* alguno \w tome|strong="H3947"\w* \w una|strong="H4672"\w* mujer, \w y|strong="H3588"\w* \w se|strong="H1961"\w* case \w con|strong="H3588"\w* ella, \w y|strong="H3588"\w* suceda \w que|strong="H3588"\w* ella \w no|strong="H3808"\w* \w le|strong="H5869"\w* agrada \w porque|strong="H3588"\w* \w halló|strong="H4672"\w* \w en|strong="H3588"\w* ella alguna \w cosa|strong="H1697"\w* reprochable, \w y|strong="H3588"\w* \w él|strong="H3588"\w* \w le|strong="H5869"\w* \w escribe|strong="H3789"\w* un certificado \w de|strong="H3588"\w* divorcio, \w se|strong="H1961"\w* \w lo|strong="H1697"\w* \w entrega|strong="H5414"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w echa|strong="H7971"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w*;
\v 2 \w cuando|strong="H1961"\w* ella \w salga|strong="H3318"\w* de la \w casa|strong="H1004"\w* de él, \w va|strong="H3068"\w* y \w se|strong="H1961"\w* \w casa|strong="H1004"\w* con otro hombre;
\v 3 \w si|strong="H3588"\w* \w el|strong="H3588"\w* segundo esposo \w la|strong="H3588"\w* \w aborrece|strong="H8130"\w*, le \w escribe|strong="H3789"\w* certificado \w de|strong="H3588"\w* divorcio, \w lo|strong="H5612"\w* coloca \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* despide \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w*, \w o|strong="H3068"\w* \w si|strong="H3588"\w* muere este último esposo \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w tomó|strong="H3947"\w* \w como|strong="H3588"\w* esposa,
\v 4 al \w primer|strong="H7223"\w* esposo \w que|strong="H3588"\w* \w la|strong="H1931"\w* \w despidió|strong="H7971"\w* \w no|strong="H3808"\w* \w le|strong="H1931"\w* \w será|strong="H1961"\w* permitido \w tomarla|strong="H3947"\w* \w de|strong="H3588"\w* nuevo \w como|strong="H3588"\w* esposa, \w después|strong="H1961"\w* \w que|strong="H3588"\w* \w fue|strong="H1961"\w* envilecida, \w pues|strong="H3588"\w* \w esto|strong="H1931"\w* \w es|strong="H1931"\w* repugnancia \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p \w No|strong="H3808"\w* corromperás \w la|strong="H1931"\w* tierra \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H3588"\w* \w da|strong="H5414"\w* \w como|strong="H3588"\w* \w heredad|strong="H5159"\w*.
\p 
\v 5 \w Cuando|strong="H3588"\w* \w alguno|strong="H3605"\w* \w esté|strong="H1961"\w* recién casado, \w no|strong="H3808"\w* entrará \w al|strong="H5921"\w* \w ejército|strong="H6635"\w* \w ni|strong="H3808"\w* \w se|strong="H1961"\w* \w le|strong="H5921"\w* impondrá \w alguna|strong="H3605"\w* obligación. \w Estará|strong="H1961"\w* \w libre|strong="H5355"\w* \w en|strong="H5921"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w* durante un \w año|strong="H8141"\w* \w para|strong="H5921"\w* alegrar \w a|strong="H3068"\w* \w la|strong="H5921"\w* esposa \w que|strong="H3588"\w* \w tomó|strong="H3947"\w*.
\p 
\v 6 \w Ninguna|strong="H3808"\w* \w de|strong="H3588"\w* las dos piedras del molino tomarás \w como|strong="H3588"\w* prenda, \w ni|strong="H3808"\w* \w la|strong="H1931"\w* \w de|strong="H3588"\w* abajo \w ni|strong="H3808"\w* \w la|strong="H1931"\w* \w de|strong="H3588"\w* arriba, \w pues|strong="H3588"\w* sería igual \w a|strong="H3068"\w* tomar \w la|strong="H1931"\w* \w vida|strong="H5315"\w* \w como|strong="H3588"\w* prenda.
\p 
\v 7 \w Si|strong="H3588"\w* \w se|strong="H1931"\w* descubre \w a|strong="H3068"\w* \w alguno|strong="H5315"\w* \w que|strong="H3588"\w* secuestró \w a|strong="H3068"\w* uno \w de|strong="H3588"\w* \w sus|strong="H1931"\w* hermanos \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w y|strong="H3588"\w* \w lo|strong="H1931"\w* esclavizó \w o|strong="H3068"\w* \w lo|strong="H1931"\w* \w vendió|strong="H4376"\w*, tal secuestrador \w morirá|strong="H4191"\w*. \w Así|strong="H3588"\w* \w quitarás|strong="H1197"\w* \w el|strong="H1931"\w* \w mal|strong="H7451"\w* \w de|strong="H3588"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* ti.
\p 
\v 8 En cuanto \w a|strong="H3068"\w* \w la|strong="H8104"\w* \w plaga|strong="H5061"\w* de \w la|strong="H8104"\w* \w lepra|strong="H6883"\w*, ten cuidado de observar con diligencia \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* \w les|strong="H6680"\w* enseñen \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w levitas|strong="H3881"\w*, y en obrar conforme \w a|strong="H3068"\w* ello. Como \w les|strong="H6680"\w* \w mandé|strong="H6680"\w* \w a|strong="H3068"\w* \w ellos|strong="H3605"\w*, así \w harás|strong="H6213"\w* con cuidado.
\v 9 Recuerda \w lo|strong="H6213"\w* que \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd* \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* Miriam \w en|strong="H3318"\w* \w el|strong="H6213"\w* \w camino|strong="H1870"\w*, cuando \w salieron|strong="H3318"\w* de \w Egipto|strong="H4714"\w*.
\p 
\v 10 \w Cuando|strong="H3588"\w* prestes \w algo|strong="H3972"\w* \w a|strong="H3068"\w* tu \w prójimo|strong="H7453"\w*, \w no|strong="H3808"\w* entres \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w* \w para|strong="H3588"\w* tomar tu \w prenda|strong="H5667"\w*.
\v 11 Te quedarás \w afuera|strong="H2351"\w* y el hombre \w a|strong="H3068"\w* quien \w prestaste|strong="H5383"\w* te \w sacará|strong="H3318"\w* la \w prenda|strong="H5667"\w*.
\v 12 \w Si|strong="H3808"\w* \w el|strong="H1931"\w* hombre \w es|strong="H1931"\w* \w pobre|strong="H6041"\w*, \w no|strong="H3808"\w* duermas con \w su|strong="H1931"\w* \w prenda|strong="H5667"\w*.
\v 13 Sin falta le regresarás la \w prenda|strong="H5667"\w* \w cuando|strong="H1961"\w* el \w sol|strong="H8121"\w* \w se|strong="H1961"\w* oculte \w para|strong="H1961"\w* \w que|strong="H1961"\w* duerma con su ropa y te \w bendiga|strong="H1288"\w*, y te \w será|strong="H1961"\w* \w justicia|strong="H6666"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*.
\p 
\v 14 \w No|strong="H3808"\w* \w oprimirás|strong="H6231"\w* al jornalero \w pobre|strong="H6041"\w* y necesitado de tus hermanos \w o|strong="H3068"\w* de los \w extranjeros|strong="H1616"\w* \w que|strong="H3808"\w* están en tu tierra, dentro de tus \w puertas|strong="H8179"\w*.
\v 15 \w En|strong="H5921"\w* \w su|strong="H1931"\w* \w día|strong="H3117"\w* \w le|strong="H1931"\w* \w pagarás|strong="H5375"\w* \w su|strong="H1931"\w* \w jornal|strong="H7939"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H1961"\w* ocultará \w el|strong="H1931"\w* \w sol|strong="H8121"\w* \w sin|strong="H3808"\w* pagárselo, \w pues|strong="H3588"\w* \w él|strong="H1931"\w* \w es|strong="H1931"\w* \w pobre|strong="H6041"\w* \w y|strong="H3588"\w* \w tiene|strong="H1961"\w* fijado \w su|strong="H1931"\w* \w corazón|strong="H5315"\w* \w en|strong="H5921"\w* \w ello|strong="H1931"\w*, \w no|strong="H3808"\w* \w sea|strong="H1961"\w* \w que|strong="H3588"\w* \w él|strong="H1931"\w* \w clame|strong="H7121"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w y|strong="H3588"\w* \w sea|strong="H1961"\w* \w pecado|strong="H2399"\w* \w para|strong="H5921"\w* \w ti|strong="H5921"\w*.
\p 
\v 16 \w Los|strong="H1121"\w* padres \w no|strong="H3808"\w* \w morirán|strong="H4191"\w* \w por|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w*, \w ni|strong="H3808"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w por|strong="H5921"\w* \w los|strong="H1121"\w* padres. Cada uno \w morirá|strong="H4191"\w* \w por|strong="H5921"\w* su \w pecado|strong="H2399"\w*.
\p 
\v 17 \w No|strong="H3808"\w* \w torcerás|strong="H5186"\w* el \w derecho|strong="H4941"\w* del \w extranjero|strong="H1616"\w* \w o|strong="H3068"\w* del \w huérfano|strong="H3490"\w*, \w ni|strong="H3808"\w* tomarás en prenda la ropa de la viuda.
\v 18 \w Acuérdate|strong="H2142"\w* \w que|strong="H3588"\w* \w tú|strong="H6213"\w* \w fuiste|strong="H1961"\w* esclavo \w en|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w de|strong="H5921"\w* \w allí|strong="H8033"\w* \w te|strong="H5921"\w* rescató \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd*. \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w yo|strong="H3588"\w* \w te|strong="H5921"\w* \w ordeno|strong="H6680"\w* \w que|strong="H3588"\w* \w hagas|strong="H6213"\w* \w esto|strong="H2088"\w*.
\p 
\v 19 \w Cuando|strong="H3588"\w* recojas tu cosecha \w en|strong="H3588"\w* tu \w campo|strong="H7704"\w* \w y|strong="H3588"\w* \w olvides|strong="H7911"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w campo|strong="H7704"\w* un manojo, \w no|strong="H3808"\w* regresarás \w a|strong="H3068"\w* recogerlo. \w Será|strong="H1961"\w* \w para|strong="H4616"\w* \w el|strong="H3588"\w* \w extranjero|strong="H1616"\w*, \w el|strong="H3588"\w* \w huérfano|strong="H3490"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* viuda, \w a|strong="H3068"\w* fin \w de|strong="H3588"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H3588"\w* \w bendiga|strong="H1288"\w* \w en|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w obra|strong="H4639"\w* \w de|strong="H3588"\w* tus \w manos|strong="H3027"\w*.
\v 20 \w Cuando|strong="H3588"\w* sacudas tu olivo \w con|strong="H3588"\w* vara, \w no|strong="H3808"\w* volverás \w a|strong="H3068"\w* \w su|strong="H3588"\w* rama. \w Será|strong="H1961"\w* \w para|strong="H3588"\w* \w el|strong="H3588"\w* \w extranjero|strong="H1616"\w*, \w el|strong="H3588"\w* \w huérfano|strong="H3490"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* viuda.
\v 21 \w Cuando|strong="H3588"\w* coseches tu \w viña|strong="H3754"\w* \w no|strong="H3808"\w* \w rebuscarás|strong="H5953"\w* detrás \w de|strong="H3588"\w* ti. \w Será|strong="H1961"\w* \w para|strong="H3588"\w* \w el|strong="H3588"\w* \w extranjero|strong="H1616"\w*, \w el|strong="H3588"\w* \w huérfano|strong="H3490"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* viuda.
\p 
\v 22 Recuerda \w que|strong="H3588"\w* \w fuiste|strong="H1961"\w* esclavo \w en|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*. \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w yo|strong="H3588"\w* \w te|strong="H5921"\w* \w ordeno|strong="H6680"\w* \w que|strong="H3588"\w* \w hagas|strong="H6213"\w* \w esto|strong="H2088"\w*.
\c 25
\p 
\v 1 \w Cuando|strong="H3588"\w* \w se|strong="H1961"\w* presente un \w pleito|strong="H7379"\w* \w entre|strong="H3588"\w* algunos, \w y|strong="H3588"\w* acudan al tribunal \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w los|strong="H1961"\w* \w jueces|strong="H8199"\w* \w los|strong="H1961"\w* juzguen, éstos absolverán al \w justo|strong="H6662"\w* \w y|strong="H3588"\w* condenarán al culpable.
\v 2 \w Si|strong="H6440"\w* \w el|strong="H5307"\w* perverso merece ser azotado, entonces \w el|strong="H5307"\w* \w juez|strong="H8199"\w* ordenará \w que|strong="H1121"\w* \w se|strong="H1961"\w* acueste \w en|strong="H5221"\w* tierra y \w sea|strong="H1961"\w* azotado \w en|strong="H5221"\w* su \w presencia|strong="H6440"\w*, \w según|strong="H1767"\w* \w el|strong="H5307"\w* \w número|strong="H4557"\w* \w de|strong="H6440"\w* \w azotes|strong="H5221"\w* \w que|strong="H1121"\w* merezca su culpa.
\v 3 \w Podrá|strong="H3808"\w* darle 40 \w azotes|strong="H5221"\w*. \w No|strong="H3808"\w* \w más|strong="H3254"\w*, \w no|strong="H3808"\w* \w sea|strong="H6435"\w* \w que|strong="H3808"\w* \w si|strong="H3808"\w* aumentan \w mucho|strong="H7227"\w* \w los|strong="H5921"\w* \w azotes|strong="H5221"\w* \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* éstos, tu hermano \w se|strong="H5921"\w* sienta degradado \w delante|strong="H5869"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*.
\p 
\v 4 \w No|strong="H3808"\w* pondrás bozal al \w buey|strong="H7794"\w* cuando trilla.
\p 
\v 5 \w Cuando|strong="H3588"\w* \w unos|strong="H1992"\w* hermanos vivan \w juntos|strong="H3162"\w*, \w y|strong="H3588"\w* uno \w de|strong="H5921"\w* \w ellos|strong="H1992"\w* \w muera|strong="H4191"\w* \w sin|strong="H3808"\w* \w tener|strong="H1961"\w* \w hijos|strong="H1121"\w*, \w la|strong="H5921"\w* esposa \w del|strong="H5921"\w* difunto \w no|strong="H3808"\w* \w se|strong="H1961"\w* casará \w afuera|strong="H2351"\w* \w con|strong="H5921"\w* \w un|strong="H3162"\w* \w hombre|strong="H1121"\w* \w extraño|strong="H1121"\w*. \w Su|strong="H1992"\w* cuñado \w se|strong="H1961"\w* unirá \w a|strong="H3068"\w* \w ella|strong="H5921"\w* \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w tomará|strong="H3947"\w* \w como|strong="H3588"\w* esposa \w y|strong="H3588"\w* cumplirá \w con|strong="H5921"\w* \w ella|strong="H5921"\w* \w el|strong="H5921"\w* deber \w de|strong="H5921"\w* hermano \w de|strong="H5921"\w* \w su|strong="H1992"\w* esposo.
\v 6 \w Al|strong="H5921"\w* \w primogénito|strong="H1060"\w* \w que|strong="H3808"\w* \w ella|strong="H5921"\w* \w dé|strong="H5921"\w* \w a|strong="H3068"\w* luz \w se|strong="H1961"\w* \w le|strong="H5921"\w* \w dará|strong="H3205"\w* \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* su hermano difunto \w para|strong="H5921"\w* \w que|strong="H3808"\w* su \w nombre|strong="H8034"\w* \w no|strong="H3808"\w* \w sea|strong="H1961"\w* borrado \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
\p 
\v 7 Pero \w si|strong="H3808"\w* el hombre \w no|strong="H3808"\w* \w quiere|strong="H2654"\w* \w tomar|strong="H3947"\w* \w a|strong="H3068"\w* su cuñada, entonces \w ésta|strong="H6965"\w* \w irá|strong="H5927"\w* \w a|strong="H3068"\w* los \w ancianos|strong="H2205"\w* en la \w puerta|strong="H8179"\w* de la ciudad y dirá: Mi cuñado \w se|strong="H3808"\w* niega \w a|strong="H3068"\w* perpetuar el \w nombre|strong="H8034"\w* de su hermano en \w Israel|strong="H3478"\w*. \w No|strong="H3808"\w* \w quiere|strong="H2654"\w* cumplir conmigo el deber de levirato.
\v 8 Entonces los \w ancianos|strong="H2205"\w* de aquella \w ciudad|strong="H5892"\w* \w lo|strong="H3808"\w* \w llamarán|strong="H7121"\w* y \w hablarán|strong="H1696"\w* con él. \w Si|strong="H3808"\w* él \w se|strong="H3808"\w* levanta y \w dice|strong="H1696"\w*: \w No|strong="H3808"\w* \w deseo|strong="H2654"\w* \w tomarla|strong="H3947"\w*,
\v 9 entonces su cuñada \w se|strong="H5921"\w* acercará \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w en|strong="H5921"\w* \w presencia|strong="H6440"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w ancianos|strong="H2205"\w*, \w le|strong="H5921"\w* quitará \w la|strong="H5921"\w* sandalia \w del|strong="H5921"\w* \w pie|strong="H7272"\w*, \w lo|strong="H3808"\w* escupirá \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w rostro|strong="H6440"\w* \w y|strong="H5921"\w* dirá: ¡\w Así|strong="H3602"\w* \w se|strong="H5921"\w* \w hace|strong="H6213"\w* \w al|strong="H5921"\w* hombre \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w edifica|strong="H1129"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* su hermano!
\v 10 Se le dará este \w nombre|strong="H8034"\w* en \w Israel|strong="H3478"\w*: \w Casa|strong="H1004"\w* del Descalzado.
\p 
\v 11 \w Si|strong="H3588"\w* dos \w varones|strong="H3588"\w* luchan \w el|strong="H3588"\w* uno contra \w el|strong="H3588"\w* otro, \w y|strong="H3588"\w* \w la|strong="H3588"\w* esposa del uno se acerca \w para|strong="H3588"\w* \w librar|strong="H5337"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* esposo del \w que|strong="H3588"\w* lo ataca, \w y|strong="H3588"\w* al meter ella \w su|strong="H3588"\w* \w mano|strong="H3027"\w* le agarra sus genitales,
\v 12 entonces \w le|strong="H5869"\w* cortarás su \w mano|strong="H3709"\w*. \w No|strong="H3808"\w* \w le|strong="H5869"\w* tendrás compasión.
\p 
\v 13 \w No|strong="H3808"\w* \w tendrás|strong="H1961"\w* en tu \w bolsa|strong="H3599"\w* pesa \w grande|strong="H1419"\w* y pesa \w pequeña|strong="H6996"\w*.
\v 14 \w No|strong="H3808"\w* \w tendrás|strong="H1961"\w* en tu \w casa|strong="H1004"\w* medida \w grande|strong="H1419"\w* y medida \w pequeña|strong="H6996"\w*.
\v 15 \w Tendrás|strong="H1961"\w* pesa \w y|strong="H5921"\w* medida exactas \w y|strong="H5921"\w* \w justas|strong="H6664"\w*, \w para|strong="H4616"\w* \w que|strong="H5921"\w* tus \w días|strong="H3117"\w* \w se|strong="H1961"\w* prolonguen \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w que|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H5921"\w* \w da|strong="H5414"\w*.
\v 16 \w Porque|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w hace|strong="H6213"\w* \w estas|strong="H6213"\w* cosas, \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* comete injusticia, \w es|strong="H3588"\w* repugnancia ante \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd*.
\p 
\v 17 Recuerda \w lo|strong="H6213"\w* que \w Amalec|strong="H6002"\w* te \w hizo|strong="H6213"\w* \w en|strong="H3318"\w* \w el|strong="H6213"\w* \w camino|strong="H1870"\w* cuando \w salieron|strong="H3318"\w* de \w Egipto|strong="H4714"\w*,
\v 18 cómo te salió al \w camino|strong="H1870"\w* y atacó \w a|strong="H3068"\w* \w los|strong="H3605"\w* rezagados \w entre|strong="H3808"\w* \w los|strong="H3605"\w* tuyos, \w que|strong="H3808"\w* iban en tu retaguardia \w fatigados|strong="H5889"\w* y \w cansados|strong="H5889"\w*, y \w no|strong="H3808"\w* tuvo temor \w a|strong="H3068"\w* \nd ʼElohim\nd*.
\p 
\v 19 \w Por|strong="H8478"\w* tanto, \w cuando|strong="H1961"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* te \w dé|strong="H8478"\w* descanso \w de|strong="H8478"\w* \w todos|strong="H3605"\w* tus enemigos \w de|strong="H8478"\w* \w alrededor|strong="H5439"\w*, \w en|strong="H8478"\w* \w la|strong="H3605"\w* tierra \w que|strong="H3808"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* te \w da|strong="H5414"\w* \w como|strong="H1961"\w* \w heredad|strong="H5159"\w* \w para|strong="H5414"\w* \w que|strong="H3808"\w* \w la|strong="H3605"\w* poseas, borrarás \w la|strong="H3605"\w* \w memoria|strong="H2143"\w* \w de|strong="H8478"\w* \w Amalec|strong="H6002"\w* \w de|strong="H8478"\w* \w debajo|strong="H8478"\w* del \w cielo|strong="H8064"\w*. \w No|strong="H3808"\w* \w lo|strong="H3808"\w* \w olvides|strong="H7911"\w*.
\c 26
\s1 Primicias y diezmos
\p 
\v 1 \w Cuando|strong="H3588"\w* entres \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H3588"\w* \w da|strong="H5414"\w* \w como|strong="H3588"\w* \w heredad|strong="H5159"\w*, \w la|strong="H3588"\w* tomes \w en|strong="H3588"\w* \w posesión|strong="H5159"\w* \w y|strong="H3588"\w* vivas \w en|strong="H3588"\w* ella,
\v 2 \w tomarás|strong="H3947"\w* las \w primicias|strong="H7225"\w* \w de|strong="H5414"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w frutos|strong="H6529"\w* \w que|strong="H3605"\w* coseches en \w la|strong="H3605"\w* tierra \w que|strong="H3605"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* te \w da|strong="H5414"\w*, las \w pondrás|strong="H5414"\w* en una cesta, \w e|strong="H3068"\w* irás al \w lugar|strong="H4725"\w* \w que|strong="H3605"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* escoja \w para|strong="H5414"\w* \w que|strong="H3605"\w* more \w allí|strong="H8033"\w* su \w Nombre|strong="H8034"\w*.
\v 3 \w Te|strong="H3588"\w* presentarás al \w sacerdote|strong="H3548"\w* \w que|strong="H3588"\w* ministre \w en|strong="H3588"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w*, \w y|strong="H3588"\w* le dirás: \w Hoy|strong="H3117"\w* \w reconozco|strong="H5046"\w* ante \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, \w que|strong="H3588"\w* \w entré|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w juró|strong="H7650"\w* \w a|strong="H3068"\w* nuestros antepasados \w que|strong="H3588"\w* nos \w daría|strong="H5414"\w*.
\p 
\v 4 El \w sacerdote|strong="H3548"\w* \w tomará|strong="H3947"\w* la cesta \w de|strong="H6440"\w* tu \w mano|strong="H3027"\w* y la mecerá \w delante|strong="H6440"\w* \w del|strong="H4196"\w* \w altar|strong="H4196"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*.
\p 
\v 5 Entonces \w hablarás|strong="H6030"\w* en \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*: Un arameo errante \w fue|strong="H1961"\w* \w mi|strong="H1961"\w* antepasado, el cual con muy \w pocos|strong="H4592"\w* \w hombres|strong="H4962"\w* bajó \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* \w para|strong="H1961"\w* vivir \w allí|strong="H8033"\w* temporalmente, y \w allí|strong="H8033"\w* llegó \w a|strong="H3068"\w* ser un \w pueblo|strong="H7227"\w* \w grande|strong="H1419"\w*, \w fuerte|strong="H6099"\w* y \w numeroso|strong="H7227"\w*.
\v 6 Pero \w los|strong="H5921"\w* \w egipcios|strong="H4713"\w* \w nos|strong="H5921"\w* maltrataron, \w afligieron|strong="H6031"\w* \w e|strong="H3068"\w* impusieron \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w* una \w dura|strong="H7186"\w* esclavitud.
\v 7 Entonces clamamos \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* de nuestros antepasados, y \nd \w Yavé|strong="H3068"\w*\nd* \w oyó|strong="H8085"\w* nuestra \w voz|strong="H6963"\w* y \w vio|strong="H7200"\w* nuestra \w aflicción|strong="H6040"\w*, nuestro \w trabajo|strong="H5999"\w* forzado y la \w opresión|strong="H3906"\w* \w a|strong="H3068"\w* la cual estábamos sometidos.
\v 8 \nd \w Yavé|strong="H3068"\w*\nd* nos \w sacó|strong="H3318"\w* de \w Egipto|strong="H4714"\w* con \w mano|strong="H3027"\w* \w fuerte|strong="H2389"\w* y \w brazo|strong="H2220"\w* \w extendido|strong="H5186"\w*, con \w gran|strong="H1419"\w* terror, señales y milagros,
\v 9 y nos trajo \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* y nos \w dio|strong="H5414"\w* \w esta|strong="H2063"\w* tierra \w que|strong="H2088"\w* \w fluye|strong="H2100"\w* \w leche|strong="H2461"\w* y \w miel|strong="H1706"\w*.
\p 
\v 10 \w Ahora|strong="H6258"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*, \w aquí|strong="H2009"\w* traigo las \w primicias|strong="H7225"\w* del \w fruto|strong="H6529"\w* \w de|strong="H6440"\w* la tierra \w que|strong="H6258"\w* me \w diste|strong="H5414"\w*. Las \w pondrás|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, y te postrarás \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*.
\v 11 Te regocijarás con \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w bien|strong="H2896"\w* \w que|strong="H1616"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* te \w dio|strong="H5414"\w*, \w a|strong="H3068"\w* ti y \w a|strong="H3068"\w* tu \w familia|strong="H1004"\w*, así como \w al|strong="H7130"\w* \w levita|strong="H3881"\w*, y \w al|strong="H7130"\w* \w extranjero|strong="H1616"\w* \w que|strong="H1616"\w* está en \w medio|strong="H7130"\w* \w de|strong="H5414"\w* ti.
\p 
\v 12 \w En|strong="H3588"\w* \w el|strong="H3588"\w* tercer \w año|strong="H8141"\w*, \w el|strong="H3588"\w* \w año|strong="H8141"\w* del diezmo, \w cuando|strong="H3588"\w* acabes \w de|strong="H3588"\w* diezmar \w el|strong="H3588"\w* total \w de|strong="H3588"\w* tu cosecha, \w lo|strong="H3605"\w* \w darás|strong="H5414"\w* al \w levita|strong="H3881"\w*, al \w extranjero|strong="H1616"\w*, al \w huérfano|strong="H3490"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* viuda \w para|strong="H3588"\w* \w que|strong="H3588"\w* coman \w en|strong="H3588"\w* las \w puertas|strong="H8179"\w* \w de|strong="H3588"\w* tus \w ciudades|strong="H8179"\w* \w y|strong="H3588"\w* se sacien.
\p 
\v 13 \w Y|strong="H3068"\w* dirás \w en|strong="H4480"\w* \w presencia|strong="H6440"\w* \w de|strong="H4480"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*: Aparté \w de|strong="H4480"\w* mi \w casa|strong="H1004"\w* \w lo|strong="H3808"\w* \w consagrado|strong="H6944"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w lo|strong="H3808"\w* \w dí|strong="H5414"\w* \w al|strong="H4480"\w* \w levita|strong="H3881"\w*, \w al|strong="H4480"\w* \w extranjero|strong="H1616"\w*, \w al|strong="H4480"\w* \w huérfano|strong="H3490"\w* \w y|strong="H1571"\w* \w a|strong="H3068"\w* \w la|strong="H1571"\w* viuda, según \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w Mandamientos|strong="H4687"\w* \w que|strong="H4480"\w* \w me|strong="H4480"\w* \w ordenaste|strong="H6680"\w*. \w No|strong="H3808"\w* transgredí \w ni|strong="H3808"\w* olvidé tus \w Mandamientos|strong="H4687"\w*.
\v 14 \w No|strong="H3808"\w* comí \w de|strong="H4480"\w* ello cuando estuve \w de|strong="H4480"\w* luto, \w ni|strong="H3808"\w* \w lo|strong="H3808"\w* tomé cuando estaba impuro, \w ni|strong="H3808"\w* \w de|strong="H4480"\w* ello ofrecí \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w muertos|strong="H4191"\w*. Obedecí \w la|strong="H1197"\w* \w voz|strong="H6963"\w* \w de|strong="H4480"\w* \nd \w Yavé|strong="H3068"\w*\nd* mi \nd ʼElohim\nd*. \w Hice|strong="H6213"\w* según \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H4480"\w* \w me|strong="H4480"\w* \w mandaste|strong="H6680"\w*.
\v 15 Contempla \w desde|strong="H4480"\w* tu \w santa|strong="H6944"\w* \w morada|strong="H4583"\w*, \w desde|strong="H4480"\w* los \w cielos|strong="H8064"\w*, y \w bendice|strong="H1288"\w* \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w* y la tierra \w que|strong="H4480"\w* \w nos|strong="H4480"\w* \w diste|strong="H5414"\w*, como \w juraste|strong="H7650"\w* \w a|strong="H3068"\w* nuestros antepasados, tierra \w que|strong="H4480"\w* \w fluye|strong="H2100"\w* \w leche|strong="H2461"\w* y \w miel|strong="H1706"\w*.
\p 
\v 16 \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd* \w te|strong="H5315"\w* \w manda|strong="H6680"\w* \w hoy|strong="H3117"\w* \w que|strong="H3117"\w* \w cumplas|strong="H6213"\w* \w estos|strong="H2088"\w* \w Estatutos|strong="H2706"\w* y \w Ordenanzas|strong="H2706"\w*. \w Por|strong="H2088"\w* tanto, tendrás \w el|strong="H3605"\w* cuidado de practicarlos con \w todo|strong="H3605"\w* \w tu|strong="H6213"\w* \w corazón|strong="H3824"\w* y \w toda|strong="H3605"\w* \w tu|strong="H6213"\w* \w alma|strong="H5315"\w*.
\p 
\v 17 \w Hoy|strong="H3117"\w* declaraste solemnemente \w que|strong="H3117"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w es|strong="H1961"\w* tu \nd ʼElohim\nd*, \w que|strong="H3117"\w* \w andarás|strong="H3212"\w* \w en|strong="H3212"\w* sus \w caminos|strong="H1870"\w*, \w guardarás|strong="H8104"\w* sus \w Estatutos|strong="H2706"\w*, \w Mandamientos|strong="H4687"\w* y \w Ordenanzas|strong="H2706"\w*, y escucharás su \w voz|strong="H6963"\w*.
\p 
\v 18 \w Hoy|strong="H3117"\w* \nd \w Yavé|strong="H3068"\w*\nd* declaró \w que|strong="H5971"\w* \w eres|strong="H1961"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* su exclusiva posesión, \w como|strong="H1961"\w* te prometió, \w para|strong="H1961"\w* \w que|strong="H5971"\w* \w guardes|strong="H8104"\w* \w todos|strong="H3605"\w* sus \w Mandamientos|strong="H4687"\w*,
\v 19 \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* \w que|strong="H5921"\w* \w Él|strong="H5921"\w* \w te|strong="H5921"\w* eleve \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w que|strong="H5921"\w* \w hizo|strong="H6213"\w*, \w para|strong="H5921"\w* \w alabanza|strong="H8416"\w*, \w fama|strong="H8034"\w* \w y|strong="H5921"\w* \w gloria|strong="H8597"\w*, \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* propósito \w de|strong="H5921"\w* \w que|strong="H5921"\w* \w seas|strong="H1961"\w* un \w pueblo|strong="H5971"\w* \w santo|strong="H6918"\w* \w para|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd*, \w como|strong="H1961"\w* \w Él|strong="H5921"\w* \w habló|strong="H1696"\w*.
\c 27
\s1 Ratificación del Pacto
\p 
\v 1 \w Moisés|strong="H4872"\w*, con \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*, \w mandó|strong="H6680"\w* al \w pueblo|strong="H5971"\w*: \w Guarden|strong="H8104"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w Mandamientos|strong="H4687"\w* \w que|strong="H5971"\w* \w les|strong="H6680"\w* \w ordeno|strong="H6680"\w* \w hoy|strong="H3117"\w*.
\v 2 \w El|strong="H5674"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w pases|strong="H5674"\w* \w el|strong="H5674"\w* \w Jordán|strong="H3383"\w* hacia la tierra \w que|strong="H3117"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* te \w da|strong="H5414"\w*, te erigirás unas piedras \w grandes|strong="H1419"\w* y las enlucirás con cal.
\v 3 Escribirás \w sobre|strong="H5921"\w* \w ellas|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w Palabras|strong="H1697"\w* \w de|strong="H5921"\w* \w esta|strong="H2063"\w* \w Ley|strong="H8451"\w*, tan pronto \w como|strong="H5921"\w* \w pases|strong="H5674"\w* \w para|strong="H4616"\w* entrar \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w que|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H5921"\w* \w da|strong="H5414"\w*, tierra \w que|strong="H5921"\w* \w fluye|strong="H2100"\w* \w leche|strong="H2461"\w* \w y|strong="H5921"\w* \w miel|strong="H1706"\w*, \w como|strong="H5921"\w* \w te|strong="H5921"\w* \w dijo|strong="H1696"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w el|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* tus antepasados.
\p 
\v 4 Así \w que|strong="H3117"\w* \w cuando|strong="H3117"\w* cruces \w el|strong="H5674"\w* \w Jordán|strong="H3383"\w*, erigirás en la montaña \w Ebal|strong="H5858"\w* estas piedras \w que|strong="H3117"\w* \w yo|strong="H6680"\w* \w les|strong="H6680"\w* \w mando|strong="H6680"\w* \w hoy|strong="H3117"\w*, y las enlucirás con cal.
