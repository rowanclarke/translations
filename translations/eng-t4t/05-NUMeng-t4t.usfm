\m 
\v 16 \w Those|strong="H1121"\w* \w are|strong="H1121"\w* \w the|strong="H7121"\w* \w names|strong="H8034"\w* \w of|strong="H1121"\w* \w the|strong="H7121"\w* \w men|strong="H1121"\w* \w whom|strong="H7121"\w* \w Moses|strong="H4872"\w*/\w I|strong="H1121"\w* \w sent|strong="H7971"\w* \w out|strong="H7971"\w* \w to|strong="H7971"\w* \w explore|strong="H8446"\w* Canaan. \add Before they left\add*, \w Moses|strong="H4872"\w*/\w I|strong="H1121"\w* \w gave|strong="H7121"\w* \w Hoshea|strong="H1954"\w* \w a|strong="H3068"\w* new \w name|strong="H8034"\w*, \w Joshua|strong="H3091"\w*, \add which means ‘Yahweh is the one who saves\add*.’
