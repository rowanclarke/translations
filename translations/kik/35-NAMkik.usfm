\id NAM - Biblica® Open Kikuyu Holy Word of God 
\h Nahumu 
\toc1 Nahumu 
\toc2 Nahumu 
\toc3 Nahu 
\mt1 NAHUMU 
\c 1  
\p  
\v 1 Ĩno nĩyo ndũmĩrĩri nditũ ĩkoniĩ Nineve. Rĩĩrĩ nĩrĩo ibuku rĩa kĩoneki kĩa Nahumu, ũrĩa Mũelikoshi. 
\s1 Jehova Kũrakarĩra Nineve 
\q1  
\v 2 Jehova nĩ Mũrungu ũrĩ ũiru na mwĩrĩhĩria; 
\q2 Jehova nĩerĩhagĩria na akaiyũrwo nĩ mangʼũrĩ. 
\q1 Jehova nĩerĩhagĩria harĩ thũ ciake, 
\q2 na agatũũria mangʼũrĩ make harĩ amuku ake. 
\q1  
\v 3 Jehova ndahiũhaga kũrakara na nĩarĩ hinya mũnene; 
\q2 Jehova ndakaaga kũherithia mũndũ mwaganu. 
\q1 Njĩra yake ĩrĩ thĩinĩ wa rũhuho rũnene na thĩinĩ wa kĩhuhũkanio,\f + \fr 1:3 \ft Ihuhũkanio na huho nene Kĩrĩkanĩro-inĩ cionanagia hinya na riiri wa Jehova.\f* 
\q2 matu namo nĩ rũkũngũ rwa makinya make. 
\q1  
\v 4 Akũũmaga iria, agatũma rĩhũe; 
\q2 ahũithagia njũũĩ ciothe. 
\q1 Bashani na Karimeli nĩkũhoohete, 
\q2 na kĩro kĩa Lebanoni gĩkaragatha.\f + \fr 1:4 \ft Bashani, na Karimeli, na Lebanoni kuoĩkaine nĩ ũndũ wa ũnoru na ũruru wakuo.\f* 
\q1  
\v 5 Irĩma ithingithaga mbere yake, 
\q2 natuo tũrĩma tũgatweka. 
\q1 Thĩ ĩinainaga ĩrĩ mbere yake, 
\q2 o na mabũrũri mothe makainaina, 
\q2 na arĩa othe matũũraga kuo. 
\q1  
\v 6 Nũũ ũngĩĩtiiria mathirĩ make? 
\q2 Nũũ ũngĩkĩũmĩrĩria marakara make mahiũ? 
\q1 Mangʼũrĩ make-rĩ, maitĩkaga ta mwaki; 
\q2 ndwaro cia mahiga igathethereka mbere yake. 
\b  
\q1  
\v 7 Jehova nĩ mwega, 
\q2 nĩ kĩĩhitho hĩndĩ ya thĩĩna. 
\q1 Arĩa mamwĩhokete-rĩ, nĩamamenyagĩrĩra, 
\q2  
\v 8 no rĩrĩ, nĩakaniina Nineve 
\q1 na kĩguũ kĩnene kĩa maaĩ; 
\q2 nĩakaingata thũ ciake nginya nduma-inĩ. 
\b  
\q1  
\v 9 Ũrĩa wothe magaaciirĩra gwĩka Jehova-rĩ, 
\q2 we nĩakaũniina; 
\q2 o na thĩĩna ndũgooka hĩndĩ ya keerĩ. 
\q2  
\v 10 Makaarigiicwo mĩigua-inĩ 
\q1 na marĩĩo nĩ ndibei yao; 
\q2 nao magaacinwo ta maragara momũ. 
\q1  
\v 11 Nĩ harĩ ũmwe wĩyumĩrĩtie thĩinĩ waku wee Nineve, 
\q2 ũrĩa ũthugundaga ũũru wa gũũkĩrĩra Jehova, 
\q2 na akaheanaga irĩra cia waganu. 
\p  
\v 12 Jehova ekuuga atĩrĩ: 
\q1 “O na aakorwo marĩ na arata, na nĩ aingĩ mũno-rĩ, 
\q2 nĩmakaniinwo, meherio. 
\q1 O na aakorwo nĩngũnyariirĩte, wee Juda-rĩ, 
\q2 ndigacooka gũkũnyariira rĩngĩ. 
\q1  
\v 13 Na rĩrĩ, nĩnguunanga icooki rĩao riume ngingo-inĩ yaku, 
\q2 na nduange mĩnyororo ĩrĩa woheetwo nayo.” 
\b  
\q1  
\v 14 Jehova nĩarutĩte watho ũgũkoniĩ, 
\q2 wee Nineve, akoiga atĩrĩ, 
\q2 “Ndũkagĩa na njiaro cia gũtũũria rĩĩtwa rĩaku. 
\q1 Nĩngananga mĩhianano ĩyo mĩicũhie o na ĩyo ya gũtwekio 
\q2 ĩrĩa ĩrĩ kũu hekarũ ya ngai ciaku. 
\q1 Nĩngũhaarĩria mbĩrĩra yaku, 
\q2 nĩgũkorwo ũrĩ kĩndũ kĩũru biũ.” 
\b  
\q1  
\v 15 Ta cũthĩrĩriai kũũrĩa irĩma-igũrũ, 
\q2 muone magũrũ ma mũndũ ũrĩa ũrarehe ũhoro mwega, 
\q2 ũrĩa wanagĩrĩra thayũ! 
\q1 Wee Juda-rĩ, kũngũĩra ciathĩ ciaku, 
\q2 na ũhingie mĩĩhĩtwa yaku. 
\q1 Andũ aaganu matigagũtharĩkĩra rĩngĩ, 
\q2 nĩgũkorwo nĩmakaniinwo biũ. 
\c 2  
\s1 Kũgũa kwa Nineve 
\q1  
\v 1 Atĩrĩrĩ, wee Nineve, mũgũtharĩkĩri nĩokĩte gũgũtharĩkĩra. 
\q2 Rangĩra kĩĩgitĩro kĩa hinya, 
\q2 na ũgitĩre njĩra; 
\q2 wĩhotore, 
\q2 na wĩĩkĩre hinya mũno! 
\p  
\v 2 Jehova nĩagacookeria Jakubu riiri wake, 
\q2 ũhaane ta riiri wa Isiraeli, 
\q1 o na aakorwo aanangi nĩmamonũhĩte, 
\q2 na makaananga mĩthabibũ yao. 
\b  
\q1  
\v 3 Ngo cia thigari ciake nĩ cia rangi mũtune, 
\q2 njamba cia ita ciĩhumbĩte nguo ndune ta gakarakũ. 
\q1 Igera cia ngaari cia ita irahenia 
\q2 mũthenya ũrĩa ciahaarĩrio; 
\q1 matimũ mahangĩrĩtwo mĩtĩ ya mĩkarakaba 
\q2 namo makahenũka maahiũrio. 
\q1  
\v 4 Ngaari cia ita iraguthũka ituĩkanĩirie njĩra cia itũũra, 
\q2 irahanyũka na mbere, ningĩ na thuutha, 
\q2 ituĩkanĩirie ihaaro-inĩ cia itũũra. 
\q1 Ihaana ta imũrĩ irakana; 
\q2 irahiũka ta rũheni. 
\q1  
\v 5 Acookanĩrĩirie mbũtũ cia thigari iria njamba, 
\q2 no ciũkaga ikĩhĩngagwo. 
\q1 Iguthũkaga nginya rũthingo-inĩ rwa itũũra inene; 
\q2 ituĩkaga ta ngo ya kũrĩgitĩra. 
\q1  
\v 6 Hingĩrĩrio cia rũũĩ nĩ hingũre,\f + \fr 2:6 \ft Hingĩrĩrio cia njũũĩ nĩ kuuga kũrĩa Rũũĩ rwa Koseri rwahingĩrĩirio, naguo mũiyũro ũcio wahingũrĩrwo ũkĩgũithia thingo.\f* 
\q2 naguo mũciĩ wa ũthamaki ũkamomoka. 
\q1  
\v 7 Nĩ gwathanĩtwo itũũra rĩu inene 
\q2 rĩtahwo na rĩthaamio. 
\q1 Ngombo ciarĩo cia airĩtu iragirĩka na mĩgambo ta ya ndutura, 
\q2 na ikehũũra ithũri. 
\q1  
\v 8 Nineve kũhaana ta ndia, 
\q2 na maaĩ makuo nĩkũhwa marahwa. 
\q1 Kũraanĩrĩrwo, gũkeerwo atĩrĩ, “Ta rũgamai! Ta rũgamai!” 
\q2 No gũtirĩ mũndũ ũngĩĩhũgũra. 
\q1  
\v 9 Tahai betha! 
\q2 Tahai thahabu! 
\q2 Ũtonga ũrĩa ũrĩ igĩĩna-inĩ ciao ciothe ndũngĩthira! 
\q1  
\v 10 Nineve nĩgũtahe, na indo igatunyanwo gũgatigwo ũtheri! 
\q2 Ngoro nĩikuĩte, na maru makaregera, 
\q2 na mĩĩrĩ ĩkainaina, o na andũ othe magathita ithiithi. 
\b  
\q1  
\v 11 Atĩrĩrĩ, imamo cia mĩrũũthi irĩ ha, 
\q2 kũndũ kũrĩa yarereire ciana ciayo, 
\q1 kũrĩa mĩrũũthi ya njamba na ya nga yathiiaga 
\q2 na ciana ciayo ĩtegwĩtigĩra? 
\q1  
\v 12 Mũrũũthi wa njamba nĩwatambuurĩire ciana ciaguo nyama cia gũciigana, 
\q2 na ũgĩitĩra mũgoma waguo gĩa kũrĩa, 
\q1 ũkĩiyũria imamo ciaguo na kĩrĩa woragĩte, 
\q2 na ũkĩiyũria ngurunga ciaguo na kĩrĩa waguĩmĩte. 
\b  
\q1  
\v 13 Jehova Mwene-Hinya-Wothe ekuuga atĩrĩ, 
\q2 “Niĩ nĩngũũkĩrĩire. 
\q1 Nĩngacina ngaari ciaku cia ita na mwaki, 
\q2 naruo rũhiũ rwa njora nĩrũkaniina mĩrũũthi yaku ĩrĩa mĩĩthĩ. 
\q2 Ndigagũtigĩria kĩndũ gĩa kũguĩma gũkũ thĩ. 
\q1 Nayo mĩgambo ya andũ arĩa ũtũmaga 
\q2 ndĩgaacooka kũiguuo rĩngĩ.” 
\c 3  
\s1 Mwanangĩko Ũtangĩgirĩrĩka Nineve 
\q1  
\v 1 Kaĩ itũũra inene rĩa Nineve rĩrĩa rĩitaga thakame rĩrĩ na haaro-ĩ! 
\q2 Itũũra rĩu rĩiyũrĩtwo nĩ maheeni 
\q1 na indo cia ũtunyani, 
\q2 na rĩtiagaga andũ moragĩtwo. 
\q1  
\v 2 Rĩ na mwanũko wa mĩcaarica, 
\q2 na mũrurumo wa magũrũ ma ngaari, 
\q1 na mbarathi itengʼerete, 
\q2 na ngaari cia ita ikũrũgarũga! 
\q1  
\v 3 Thigari cia mbarathi irahithũka, 
\q2 ikahenũkia hiũ cia njora 
\q2 na matimũ marahenia! 
\q1 Andũ aingĩ nĩmooragĩtwo, 
\q2 gũkagĩa na hĩba cia arĩa makuĩte, 
\q1 na ciimba itangĩtarĩka, 
\q2 nao andũ makahĩngwo nĩ ciimba icio: 
\q1  
\v 4 maũndũ maya mothe marekĩka nĩ ũndũ wa ũingĩ wa merirĩria ma mũmaraya, 
\q2 ũrĩa ũguucĩrĩirie mũndũ-wa-nja ũcio mũrogi, 
\q1 ũrĩa watuire ndũrĩrĩ ngombo na ũmaraya wake, 
\q2 na agĩtua kĩrĩndĩ ngombo na ũragũri wake. 
\b  
\q1  
\v 5 Jehova Mwene-Hinya-Wothe ekuuga atĩrĩ, 
\q2 “Niĩ nĩngũgũũkĩrĩra. 
\q1 Ngũkũheta nguo ikũhumbĩre ũthiũ. 
\q2 Nguonia ndũrĩrĩ njaga yaku, 
\q2 na ngũconorithie mbere ya mothamaki. 
\q1  
\v 6 Ngũgũikĩria gĩko kĩrĩ magigi, 
\q2 ngũnyarare ũtuĩke kĩndũ gĩa kũmakania gĩkĩonwo nĩ andũ. 
\q1  
\v 7 Arĩa othe magaakuona nĩmakoora makiugaga atĩrĩ, 
\q2 ‘Hĩ, Nineve nĩrĩanange, nũũ ũkaarĩcakaĩra?’ 
\q2 Mũndũ wa gũkũhooreria-rĩ, ingĩmũruta kũ?” 
\b  
\q1  
\v 8 Wee-rĩ, ũkĩrĩ mwega gũkĩra Thebesi,\f + \fr 3:8 \ft Thebesi rĩarĩ itũũra inene rĩa mwena wa rũgongo wa Rũũĩ rwa Nili. No rĩo rĩetagwo No kana No-Amoni.\f* 
\q2 itũũra rĩrĩa rĩakĩtwo Rũũĩ-inĩ rwa Nili, 
\q2 o rĩo rĩrigiicĩirio nĩ maaĩ? 
\q1 Rũũĩ rũu nĩruo rũrĩgitagĩra, 
\q2 naruo rũthingo rwarĩo nĩ maaĩ macio. 
\q1  
\v 9 Kushi na Misiri nĩcio ciarĩ hinya warĩo ũtangĩathirire; 
\q2 Putu na Lubimu maarĩ amwe a thiritũ narĩo. 
\q1  
\v 10 No rĩrĩ, nĩrĩatahirwo, 
\q2 na andũ aarĩo magĩthaamio. 
\q1 Tũkenge twarĩo twatungumanirio, 
\q2 tũgĩtuĩka icunjĩ magomano-inĩ mothe ma njĩra. 
\q1 Mĩtĩ nĩyacuukĩirwo andũ aarĩo arĩa maarĩ igweta, 
\q2 anene othe aarĩo makĩohwo na mĩnyororo. 
\q1  
\v 11 Wee nawe nĩũkarĩĩo, 
\q2 na nĩũkoora, wĩhithe, 
\q2 wethe kĩĩhitho ũũrĩre thũ ciaku. 
\b  
\q1  
\v 12 Ciĩhitho ciaku nũmu ciothe ihaana ta mĩtĩ ya mĩkũyũ, 
\q2 ĩrĩ na ngũyũ iria ciambĩte kwĩrua, 
\q1 yainainio-rĩ, 
\q2 ngũyũ ikagũa kanua-inĩ ka mũrĩi. 
\q1  
\v 13 Tarora, mbũtũ ciaku cia ita, 
\q2 hĩ, ciothe ihaana ta andũ-a-nja! 
\q1 Ihingo cia bũrũri waku 
\q2 nĩ hingũrĩre thũ ciaku biũ, 
\q2 mĩgĩĩko yacio ĩgacinwo na mwaki. 
\b  
\q1  
\v 14 Taha maaĩ ũige, ũgaakorwo namo hĩndĩ ya kũrigiicĩrio, 
\q2 ciĩgitĩro ciaku cia hinya ũcirũmie wega! 
\q1 Haarĩria rĩũmba, 
\q2 kia ndoro, 
\q2 ũthondeke maturubarĩ. 
\q1  
\v 15 Kũu nĩkuo mwaki ũgaakũniinĩra, 
\q2 na rũhiũ rwa njora rũgũtemenge ũthire biũ, 
\q2 rũkũrĩe o ta ũrĩa ũngĩrĩĩo nĩ itono. 
\q1 Ciaranai ta itono, 
\q2 mũciarane, mũingĩhe ta ngigĩ! 
\q1  
\v 16 Onjoria aku ũmaingĩhĩtie, 
\q2 makaingĩha gũkĩra njata cia igũrũ, 
\q1 no mahaana ta ngigĩ iria cianangaga bũrũri, 
\q2 igacooka ikeyũmbũkĩra. 
\q1  
\v 17 Arangĩri aku matariĩ ta ngigĩ, 
\q2 anene aku nao nĩ ta mĩrumbĩ ya ngigĩ, 
\q2 ĩrĩa yũmbaga thingo-inĩ ciaku mũthenya wa heho, 
\q1 no riũa rĩara, ĩkombũka ĩgathiĩ, 
\q2 na gũtirĩ mũndũ ũngĩmenya kũrĩa yathiĩ. 
\b  
\q1  
\v 18 Atĩrĩrĩ, wee mũthamaki wa Ashuri, arĩithi aku nĩmakomete; 
\q2 andũ aku arĩa marĩ igweta nĩmahuurũkĩte. 
\q1 Andũ aku othe mahurunjũkĩire irĩma-inĩ, 
\q2 na gũtirĩ wa kũmacookanĩrĩria. 
\q1  
\v 19 Kĩronda gĩaku gĩtingĩhona; 
\q2 nguraro yaku nĩ ya gũkũũraga. 
\q1 Mũndũ o wothe ũiguĩte ũhoro waku 
\q2 arahũũra hĩ tondũ nĩũgwĩte, 
\q1 nũũ ũtarĩ wahutio 
\q2 nĩ kĩnyariirano gĩaku gĩtarĩ mũthia?