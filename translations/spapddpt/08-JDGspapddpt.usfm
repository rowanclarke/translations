\v 19 \w Gedeón|strong="H1439"\w* y los 100 hombres \w que|strong="H3027"\w* \w estaban|strong="H7218"\w* con \w él|strong="H4264"\w* llegaron \w a|strong="H3068"\w* las afueras del \w campamento|strong="H4264"\w* al principio de \w la|strong="H8104"\w* vigilia intermedia, cuando \w acababan|strong="H6965"\w* de relevar \w a|strong="H3068"\w* los \w centinelas|strong="H8104"\w*. \w Y|strong="H3068"\w* al hacer resonar cornetas, quebraron los \w cántaros|strong="H3537"\w* \w que|strong="H3027"\w* llevaban en sus \w manos|strong="H3027"\w*.
\v 20 Entonces, las \w tres|strong="H7969"\w* \w compañías|strong="H7218"\w* hicieron resonar las cornetas y \w quebraron|strong="H7665"\w* los \w cántaros|strong="H3537"\w*. \w Tomaron|strong="H2388"\w* con su \w mano|strong="H3027"\w* \w izquierda|strong="H8040"\w* las antorchas y con su \w derecha|strong="H3225"\w* las cornetas para hacerlas resonar, y clamaron: ¡\w Por|strong="H3027"\w* \nd \w Yavé|strong="H3068"\w*\nd* y \w por|strong="H3027"\w* \w Gedeón|strong="H1439"\w*!
\v 21 \w Cada|strong="H3605"\w* hombre se mantuvo firme \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w alrededor|strong="H5439"\w* del \w campamento|strong="H4264"\w*, y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w ejército|strong="H4264"\w* echó \w a|strong="H3068"\w* correr, gritaba y huía.
\p 
\v 22 Pues \w cuando|strong="H5704"\w* \w hicieron|strong="H7760"\w* resonar \w las|strong="H5921"\w* 300 cornetas, \nd \w Yavé|strong="H3068"\w*\nd* levantó \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w de|strong="H5921"\w* \w cada|strong="H3605"\w* uno \w contra|strong="H5921"\w* su \w compañero|strong="H7453"\w* \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w campamento|strong="H4264"\w*. \w El|strong="H5921"\w* \w ejército|strong="H4264"\w* \w huyó|strong="H5127"\w* \w hasta|strong="H5704"\w* Bet-sita, \w en|strong="H5921"\w* dirección \w de|strong="H5921"\w* Zerera, \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* límite \w de|strong="H5921"\w* Abel-mehola, \w cerca|strong="H5921"\w* \w de|strong="H5921"\w* Tabat.
\p 
\v 23 \w Fueron|strong="H7291"\w* convocados \w los|strong="H3605"\w* israelitas \w de|strong="H4480"\w* Neftalí, \w de|strong="H4480"\w* Aser y \w de|strong="H4480"\w* \w todo|strong="H3605"\w* \w Manasés|strong="H4519"\w*, y \w persiguieron|strong="H7291"\w* \w a|strong="H3068"\w* \w Madián|strong="H4080"\w*.
\v 24 \w Luego|strong="H5704"\w* \w Gedeón|strong="H1439"\w* \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w por|strong="H5704"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* región montañosa \w de|strong="H5704"\w* Efraín \w y|strong="H5704"\w* dijo: ¡Bajen \w a|strong="H3068"\w* encontrar \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w madianitas|strong="H4080"\w* \w y|strong="H5704"\w* tomen \w los|strong="H3605"\w* vados \w de|strong="H5704"\w* Bet-bara \w y|strong="H5704"\w* del \w Jordán|strong="H3383"\w* \w antes|strong="H5704"\w* \w que|strong="H5704"\w* \w ellos|strong="H3605"\w*! \w Y|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w de|strong="H5704"\w* Efraín se reunieron \w y|strong="H5704"\w* \w tomaron|strong="H3920"\w* \w los|strong="H3605"\w* vados \w de|strong="H5704"\w* Bet-bara \w y|strong="H5704"\w* del \w Jordán|strong="H3383"\w*.
\p 
\v 25 Capturaron \w a|strong="H3068"\w* \w los|strong="H7291"\w* \w dos|strong="H8147"\w* \w jefes|strong="H8269"\w* \w madianitas|strong="H4080"\w*: \w Oreb|strong="H6159"\w* y Zeeb, y \w mataron|strong="H2026"\w* \w a|strong="H3068"\w* \w Oreb|strong="H6159"\w* en Tsur-oreb, y \w a|strong="H3068"\w* Zeeb en Jequeb-zeeb. \w Y|strong="H3068"\w* \w persiguieron|strong="H7291"\w* \w a|strong="H3068"\w* \w los|strong="H7291"\w* \w madianitas|strong="H4080"\w*, pero las \w cabezas|strong="H7218"\w* \w de|strong="H8269"\w* \w Oreb|strong="H6159"\w* y \w de|strong="H8269"\w* Zeeb las llevaron \w a|strong="H3068"\w* \w Gedeón|strong="H1439"\w*, al otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*.
\c 8
\s1 Gobierno y muerte de Gedeón
\p 
\v 1 \w Entonces|strong="H3588"\w* \w los|strong="H3588"\w* hombres \w de|strong="H3588"\w* Efraín le \w dijeron|strong="H1697"\w*: ¿\w Qué|strong="H3588"\w* \w es|strong="H2088"\w* \w esto|strong="H2088"\w* \w que|strong="H3588"\w* \w hiciste|strong="H6213"\w* \w con|strong="H3588"\w* nosotros, \w de|strong="H3588"\w* \w no|strong="H6213"\w* llamarnos \w cuando|strong="H3588"\w* \w fuiste|strong="H1980"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w guerra|strong="H3898"\w* contra \w Madián|strong="H4080"\w*? \w Y|strong="H3068"\w* discutieron enérgicamente \w con|strong="H3588"\w* \w él|strong="H3588"\w*.
\p 
\v 2 Pero \w él|strong="H6213"\w* les dijo: ¿\w Qué|strong="H4100"\w* \w hice|strong="H6213"\w* \w yo|strong="H6213"\w* en comparación con ustedes? ¿\w No|strong="H3808"\w* \w son|strong="H3808"\w* \w mejores|strong="H2896"\w* los rebuscos de Efraín \w que|strong="H4100"\w* la cosecha de Abiezer?
\v 3 \nd ʼElohim\nd* \w entregó|strong="H5414"\w* \w en|strong="H5921"\w* sus \w manos|strong="H3027"\w* \w a|strong="H3068"\w* \w Oreb|strong="H6159"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* Zeeb, \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w Madián|strong="H4080"\w*. ¿\w Qué|strong="H4100"\w* \w podía|strong="H3201"\w* \w hacer|strong="H6213"\w* \w yo|strong="H6213"\w* \w en|strong="H5921"\w* comparación \w con|strong="H5921"\w* ustedes? \w Cuando|strong="H4100"\w* \w dijo|strong="H1696"\w* \w esto|strong="H2088"\w*, \w se|strong="H5921"\w* aplacó su enojo \w hacia|strong="H6213"\w* \w él|strong="H5921"\w*.
\p 
\v 4 Cuando \w Gedeón|strong="H1439"\w* y \w los|strong="H7291"\w* 300 hombres \w que|strong="H1931"\w* \w tenía|strong="H1931"\w* consigo llegaron al \w Jordán|strong="H3383"\w* y \w lo|strong="H1931"\w* cruzaron, estaban \w cansados|strong="H5889"\w*, pero continuaron \w la|strong="H1931"\w* persecución.
\v 5 \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* \w los|strong="H1992"\w* hombres \w de|strong="H3588"\w* Sucot: \w Les|strong="H1992"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* den algunos \w bocados|strong="H3603"\w* \w de|strong="H3588"\w* \w pan|strong="H3899"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w gente|strong="H5971"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* sigue, \w porque|strong="H3588"\w* están \w cansados|strong="H5889"\w*, \w y|strong="H3588"\w* \w persigo|strong="H7291"\w* \w a|strong="H3068"\w* \w Zeba|strong="H2078"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* Zalmuna, \w reyes|strong="H4428"\w* \w de|strong="H3588"\w* \w Madián|strong="H4080"\w*.
\p 
\v 6 \w Pero|strong="H3588"\w* \w los|strong="H3588"\w* \w jefes|strong="H8269"\w* \w de|strong="H3588"\w* Sucot le respondieron: ¿Están \w ya|strong="H6258"\w* \w en|strong="H3588"\w* tu \w mano|strong="H3027"\w* \w Zeba|strong="H2078"\w* \w y|strong="H3588"\w* Zalmuna, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w demos|strong="H5414"\w* \w pan|strong="H3899"\w* \w a|strong="H3068"\w* tu tropa?
\p 
\v 7 \w Y|strong="H3068"\w* \w Gedeón|strong="H1439"\w* les contestó: \w Por|strong="H3027"\w* \w esto|strong="H3651"\w*, cuando \nd \w Yavé|strong="H3068"\w*\nd* \w entregue|strong="H5414"\w* en mi \w mano|strong="H3027"\w* \w a|strong="H3068"\w* \w Zeba|strong="H2078"\w* y \w a|strong="H3068"\w* Zalmuna, trillaré la \w carne|strong="H1320"\w* \w de|strong="H5414"\w* ustedes con \w espinos|strong="H6975"\w* y abrojos del \w desierto|strong="H4057"\w*.
\p 
\v 8 \w Subió|strong="H5927"\w* de \w allí|strong="H8033"\w* \w a|strong="H3068"\w* \w Peniel|strong="H6439"\w* y les \w dijo|strong="H1696"\w* las mismas \w palabras|strong="H1696"\w*. \w Y|strong="H3068"\w* los hombres de \w Peniel|strong="H6439"\w* le \w respondieron|strong="H6030"\w* de \w la|strong="H2063"\w* misma manera que los hombres de Sucot.
\v 9 \w Entonces|strong="H1571"\w* \w él|strong="H1571"\w* dijo \w también|strong="H1571"\w* \w a|strong="H3068"\w* los hombres de \w Peniel|strong="H6439"\w*: \w Cuando|strong="H1571"\w* yo regrese en \w paz|strong="H7965"\w*, \w derribaré|strong="H5422"\w* \w esta|strong="H2088"\w* \w torre|strong="H4026"\w*.
\v 10 \w Zeba|strong="H2078"\w* y Zalmuna estaban \w en|strong="H5973"\w* Carcor \w con|strong="H5973"\w* su \w ejército|strong="H4264"\w* \w de|strong="H5973"\w* \w como|strong="H5973"\w* 15.000 \w hombres|strong="H1121"\w*, \w los|strong="H1121"\w* \w que|strong="H1121"\w* \w quedaron|strong="H3498"\w* \w de|strong="H5973"\w* \w todo|strong="H3605"\w* \w el|strong="H5973"\w* \w campamento|strong="H4264"\w* \w de|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H5973"\w* \w oriente|strong="H6924"\w*, pues \w cayeron|strong="H5307"\w* 120.000 \w hombres|strong="H1121"\w* \w que|strong="H1121"\w* \w sacaban|strong="H8025"\w* \w espada|strong="H2719"\w*.
\v 11 Entonces \w Gedeón|strong="H1439"\w* \w subió|strong="H5927"\w* \w por|strong="H1870"\w* \w el|strong="H4264"\w* \w camino|strong="H1870"\w* de \w los|strong="H1961"\w* \w que|strong="H1961"\w* \w habitan|strong="H7931"\w* \w en|strong="H5221"\w* tiendas al \w oriente|strong="H6924"\w* de \w Noba|strong="H5025"\w* y de Jogbeá, y atacó al \w ejército|strong="H4264"\w* \w cuando|strong="H1961"\w* \w no|strong="H1961"\w* \w estaba|strong="H1961"\w* \w en|strong="H5221"\w* guardia.
\v 12 \w Zeba|strong="H2078"\w* y Zalmuna \w huyeron|strong="H5127"\w*, pero \w él|strong="H3605"\w* \w los|strong="H3605"\w* \w persiguió|strong="H7291"\w* y capturó \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w dos|strong="H8147"\w* \w reyes|strong="H4428"\w* de \w Madián|strong="H4080"\w*, \w a|strong="H3068"\w* \w Zeba|strong="H2078"\w* y \w a|strong="H3068"\w* Zalmuna. Llenó de terror \w a|strong="H3068"\w* \w todo|strong="H3605"\w* su \w ejército|strong="H4264"\w*.
\p 
\v 13 \w Luego|strong="H7725"\w* \w Gedeón|strong="H1439"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Joas|strong="H3101"\w*, regresó \w de|strong="H4480"\w* la \w batalla|strong="H4421"\w* \w por|strong="H4480"\w* la cuesta \w de|strong="H4480"\w* Heres,
\v 14 y detuvo \w a|strong="H3068"\w* un joven \w de|strong="H8269"\w* los hombres \w de|strong="H8269"\w* Sucot y lo interrogó. Éste le dio \w por|strong="H3789"\w* \w escrito|strong="H3789"\w* los nombres \w de|strong="H8269"\w* los \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* Sucot y \w de|strong="H8269"\w* sus \w ancianos|strong="H2205"\w*: 76 varones.
\v 15 \w Cuando|strong="H3588"\w* llegó ante \w los|strong="H3588"\w* hombres \w de|strong="H3588"\w* Sucot, les dijo: Miren \w a|strong="H3068"\w* \w Zeba|strong="H2078"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* Zalmuna, quienes se burlaron \w de|strong="H3588"\w* \w mí|strong="H2009"\w* \w y|strong="H3588"\w* dijeron: ¿\w Están|strong="H2009"\w* \w ya|strong="H6258"\w* \w en|strong="H3588"\w* tu \w mano|strong="H3027"\w* \w Zeba|strong="H2078"\w* \w y|strong="H3588"\w* Zalmuna, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w demos|strong="H5414"\w* \w pan|strong="H3899"\w* \w a|strong="H3068"\w* tus hombres cansados?
\v 16 \w Tomó|strong="H3947"\w* \w a|strong="H3068"\w* los \w ancianos|strong="H2205"\w* de la \w ciudad|strong="H5892"\w*, y azotó \w a|strong="H3068"\w* los varones de Sucot con \w espinos|strong="H6975"\w* y abrojos del \w desierto|strong="H4057"\w*.
\v 17 También \w derribó|strong="H5422"\w* la \w torre|strong="H4026"\w* de \w Peniel|strong="H6439"\w* y \w mató|strong="H2026"\w* \w a|strong="H3068"\w* los varones de la \w ciudad|strong="H5892"\w*.
\p 
\v 18 Luego preguntó \w a|strong="H3068"\w* \w Zeba|strong="H2078"\w* y \w a|strong="H3068"\w* Zalmuna: ¿\w Qué|strong="H1121"\w* aspecto tenían \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w que|strong="H1121"\w* ustedes \w mataron|strong="H2026"\w* en \w Tabor|strong="H8396"\w*?
\p \w Y|strong="H3068"\w* ellos respondieron: \w Como|strong="H3644"\w* tú, así eran ellos. Cada uno parecía \w el|strong="H1121"\w* \w hijo|strong="H1121"\w* del \w rey|strong="H4428"\w*.
\p 
\v 19 \w Y|strong="H3068"\w* \w él|strong="H1121"\w* dijo: ¡\w Eran|strong="H3808"\w* mis hermanos! ¡\w Los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* mi madre! \w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w que|strong="H3808"\w* \w si|strong="H3863"\w* \w los|strong="H1992"\w* hubieron dejado \w vivos|strong="H2416"\w*, yo \w no|strong="H3808"\w* \w los|strong="H1992"\w* mataría \w a|strong="H3068"\w* ustedes.
\v 20 \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* \w Jéter|strong="H3500"\w*, \w su|strong="H3588"\w* \w primogénito|strong="H1060"\w*: ¡\w Levántate|strong="H6965"\w*, mátalos! \w Pero|strong="H3588"\w* \w el|strong="H3588"\w* joven \w no|strong="H3808"\w* \w desenvainó|strong="H8025"\w* \w su|strong="H3588"\w* \w espada|strong="H2719"\w*, \w pues|strong="H3588"\w* \w tuvo|strong="H3372"\w* \w temor|strong="H3372"\w*, \w porque|strong="H3588"\w* \w aún|strong="H5750"\w* era un \w muchacho|strong="H5288"\w*.
\p 
\v 21 \w Entonces|strong="H3588"\w* \w Zeba|strong="H2078"\w* \w y|strong="H3588"\w* Zalmuna dijeron: ¡\w Levántate|strong="H6965"\w* tú \w y|strong="H3588"\w* mátanos, \w pues|strong="H3588"\w* \w como|strong="H3588"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* varón, \w así|strong="H3588"\w* \w es|strong="H3588"\w* \w su|strong="H3588"\w* valentía! \w Y|strong="H3068"\w* \w Gedeón|strong="H1439"\w* se \w levantó|strong="H6965"\w* \w y|strong="H3588"\w* \w mató|strong="H2026"\w* \w a|strong="H3068"\w* \w Zeba|strong="H2078"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* Zalmuna, \w y|strong="H3588"\w* \w tomó|strong="H3947"\w* las lunetas \w que|strong="H3588"\w* sus \w camellos|strong="H1581"\w* llevaban \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w cuello|strong="H6677"\w*.
\p 
\v 22 \w Los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* dijeron \w a|strong="H3068"\w* \w Gedeón|strong="H1439"\w*: Gobiérnanos tú, tu \w hijo|strong="H1121"\w* \w y|strong="H1571"\w* tu \w nieto|strong="H1121"\w*, \w pues|strong="H3588"\w* nos libraste \w de|strong="H3588"\w* \w la|strong="H1571"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w Madián|strong="H4080"\w*.
\p 
\v 23 Pero \w Gedeón|strong="H1439"\w* respondió: Yo \w no|strong="H3808"\w* \w los|strong="H1121"\w* gobernaré, \w ni|strong="H3808"\w* mi \w hijo|strong="H1121"\w*. \nd \w Yavé|strong="H3068"\w*\nd* \w los|strong="H1121"\w* gobernará.
\v 24 Sin embargo, \w Gedeón|strong="H1439"\w* \w les|strong="H1992"\w* dijo: \w Les|strong="H1992"\w* \w hago|strong="H7592"\w* una \w petición|strong="H7596"\w*: \w que|strong="H3588"\w* cada uno \w me|strong="H4480"\w* \w dé|strong="H4480"\w* \w los|strong="H1992"\w* zarcillos \w de|strong="H4480"\w* \w su|strong="H1992"\w* botín, \w pues|strong="H3588"\w* \add los madianitas\add* tenían zarcillos \w de|strong="H4480"\w* \w oro|strong="H2091"\w*, \w porque|strong="H3588"\w* eran ismaelitas.
\p 
\v 25 Ellos dijeron: Con mucho gusto te los \w daremos|strong="H5414"\w*. \w Y|strong="H3068"\w* tendieron el manto y \w allí|strong="H8033"\w* \w echó|strong="H7993"\w* \w cada|strong="H8033"\w* uno los zarcillos \w de|strong="H5414"\w* su botín.
\v 26 \w El|strong="H5921"\w* \w peso|strong="H4948"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* zarcillos \w de|strong="H4480"\w* \w oro|strong="H2091"\w* \w que|strong="H4480"\w* \w él|strong="H5921"\w* \w pidió|strong="H7592"\w* \w fue|strong="H1961"\w* 18,7 kilogramos \w de|strong="H4480"\w* \w oro|strong="H2091"\w*, aparte \w de|strong="H4480"\w* \w las|strong="H5921"\w* lunetas, \w los|strong="H5921"\w* pendientes \w y|strong="H5921"\w* \w las|strong="H5921"\w* ropas \w de|strong="H4480"\w* púrpura \w que|strong="H4480"\w* \w llevaban|strong="H1961"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H4480"\w* \w Madián|strong="H4080"\w*, \w y|strong="H5921"\w* aparte \w de|strong="H4480"\w* \w los|strong="H5921"\w* collares \w que|strong="H4480"\w* \w llevaban|strong="H1961"\w* sus \w camellos|strong="H1581"\w*.
\v 27 \w Gedeón|strong="H1439"\w* \w hizo|strong="H6213"\w* con \w ellos|strong="H3605"\w* un \tl efod\tl* y \w lo|strong="H6213"\w* puso en Ofra, su \w ciudad|strong="H5892"\w*. \w Todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w se|strong="H1961"\w* prostituyó \w allí|strong="H8033"\w* con aquello, y \w se|strong="H1961"\w* convirtió en una trampa \w para|strong="H1961"\w* \w Gedeón|strong="H1439"\w* y su \w familia|strong="H1004"\w*.
\p 
\v 28 Así \w Madián|strong="H4080"\w* \w fue|strong="H3808"\w* sometido \w ante|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* y \w no|strong="H3808"\w* volvieron \w a|strong="H3068"\w* levantar sus \w cabezas|strong="H7218"\w*. \w Y|strong="H3068"\w* la tierra \w tuvo|strong="H5375"\w* 40 \w años|strong="H8141"\w* \w de|strong="H6440"\w* descanso en \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H6440"\w* \w Gedeón|strong="H1439"\w*.
\p 
\v 29 \w Jerobaal|strong="H3378"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joás|strong="H3101"\w*, \w fue|strong="H3212"\w* y vivió \w en|strong="H3212"\w* su \w casa|strong="H1004"\w*.
\v 30 \w Gedeón|strong="H1439"\w* \w tuvo|strong="H1961"\w* 70 \w hijos|strong="H1121"\w* \w que|strong="H3588"\w* \w fueron|strong="H1961"\w* sus descendientes \w porque|strong="H3588"\w* \w tenía|strong="H1961"\w* \w muchas|strong="H7227"\w* mujeres.
\v 31 \w Su|strong="H1931"\w* \w concubina|strong="H6370"\w*, \w que|strong="H1931"\w* vivía en Siquem, \w también|strong="H1571"\w* \w le|strong="H1931"\w* \w dio|strong="H7760"\w* un \w hijo|strong="H1121"\w*, \w y|strong="H1571"\w* \w lo|strong="H1931"\w* \w llamó|strong="H8034"\w* Abimelec.
\v 32 \w Gedeón|strong="H1439"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joás|strong="H3101"\w*, \w murió|strong="H4191"\w* \w en|strong="H6912"\w* \w buena|strong="H2896"\w* \w vejez|strong="H7872"\w*. Fue \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* \w el|strong="H1121"\w* \w sepulcro|strong="H6913"\w* \w de|strong="H1121"\w* \w Joás|strong="H3101"\w*, su padre, \w en|strong="H6912"\w* Ofra \w de|strong="H1121"\w* \w los|strong="H1121"\w* abiezeritas.
\p 
\v 33 Pero \w aconteció|strong="H1961"\w* \w que|strong="H1121"\w* \w cuando|strong="H1961"\w* \w Gedeón|strong="H1439"\w* \w murió|strong="H4191"\w*, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w volvieron|strong="H7725"\w* \w a|strong="H3068"\w* prostituirse al seguir \w a|strong="H3068"\w* \w los|strong="H1121"\w* baales y escogieron \w a|strong="H3068"\w* Baal-berit \w como|strong="H1961"\w* su \tl ʼelohim\tl*.
\v 34 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* acordaron \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*, \w Quien|strong="H3605"\w* \w los|strong="H1121"\w* \w libró|strong="H5337"\w* \w de|strong="H1121"\w* \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w todos|strong="H3605"\w* sus enemigos \w de|strong="H1121"\w* \w alrededor|strong="H5439"\w*.
\v 35 \w Tampoco|strong="H3808"\w* \w se|strong="H3808"\w* mostraron agradecidos \w con|strong="H5973"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* \w Jerobaal|strong="H3378"\w*, \w quien|strong="H3605"\w* es \w Gedeón|strong="H1439"\w*, por \w todo|strong="H3605"\w* \w el|strong="H5973"\w* \w bien|strong="H2896"\w* \w que|strong="H3808"\w* \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*.
\c 9
\s1 El juez Abimelec
\p 
\v 1 Abimelec, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jerobaal|strong="H3378"\w*, \w fue|strong="H3212"\w* \w a|strong="H3068"\w* Siquem, \w a|strong="H3068"\w* \w los|strong="H1121"\w* parientes \w de|strong="H1121"\w* su madre, y \w habló|strong="H1696"\w* con \w ellos|strong="H3605"\w* y con \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w familia|strong="H1004"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* su abuelo materno:
\v 2 Les \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* digan \w a|strong="H3068"\w* oídos \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H3588"\w* Siquem: ¿\w Es|strong="H3588"\w* \w mejor|strong="H2896"\w* \w para|strong="H3588"\w* ustedes \w que|strong="H3588"\w* \w los|strong="H1121"\w* gobiernen 70 \w hombres|strong="H1121"\w*, \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Jerobaal|strong="H3378"\w*, \w o|strong="H3068"\w* \w que|strong="H3588"\w* \w los|strong="H1121"\w* gobierne un solo varón? Recuerden también \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy \w hueso|strong="H6106"\w* \w y|strong="H3588"\w* \w carne|strong="H1320"\w* \w de|strong="H3588"\w* ustedes.
\p 
\v 3 \w Los|strong="H5921"\w* hermanos \w de|strong="H5921"\w* \w su|strong="H1931"\w* madre \w dijeron|strong="H1697"\w* \w todas|strong="H3605"\w* estas \w palabras|strong="H1697"\w* \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w él|strong="H1931"\w* \w a|strong="H3068"\w* oídos \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* hombres \w de|strong="H5921"\w* Siquem. \w El|strong="H1931"\w* \w corazón|strong="H3820"\w* \w de|strong="H5921"\w* \w ellos|strong="H1931"\w* \w se|strong="H1931"\w* inclinó \w hacia|strong="H5921"\w* Abimelec, \w pues|strong="H3588"\w* decían: \w Es|strong="H1931"\w* nuestro hermano.
\v 4 Le \w dieron|strong="H5414"\w* 770 gramos \w de|strong="H5414"\w* \w plata|strong="H3701"\w* del \w templo|strong="H1004"\w* \w de|strong="H5414"\w* Baal-berit, con los cuales Abimelec contrató hombres \w ociosos|strong="H7386"\w* y vagabundos que lo siguieron.
\v 5 Luego fue \w a|strong="H3068"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* padre \w en|strong="H5921"\w* Ofra, \w y|strong="H3588"\w* \w sobre|strong="H5921"\w* una misma piedra \w mató|strong="H2026"\w* \w a|strong="H3068"\w* sus hermanos, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Jerobaal|strong="H3378"\w*, \w que|strong="H3588"\w* eran 70 \w varones|strong="H3588"\w*, salvo Jotam, \w el|strong="H5921"\w* \w hijo|strong="H1121"\w* \w menor|strong="H6996"\w* \w de|strong="H5921"\w* \w Jerobaal|strong="H3378"\w*, \w porque|strong="H3588"\w* \w se|strong="H5921"\w* escondió.
\v 6 Entonces \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w de|strong="H5973"\w* Siquem y \w los|strong="H3605"\w* \w de|strong="H5973"\w* Bet-milo, se reunieron y proclamaron \w a|strong="H3068"\w* Abimelec \w como|strong="H5973"\w* \w rey|strong="H4428"\w* \w en|strong="H5973"\w* \w el|strong="H5973"\w* roble \w de|strong="H5973"\w* \w la|strong="H3605"\w* piedra ritual \w que|strong="H7927"\w* \w estaba|strong="H5324"\w* \w en|strong="H5973"\w* Siquem.
\p 
\v 7 Cuando se lo dijeron \w a|strong="H3068"\w* Jotam, \w fue|strong="H3212"\w* y se colocó \w en|strong="H5975"\w* la \w cumbre|strong="H7218"\w* de la montaña \w Gerizim|strong="H1630"\w*, \w alzó|strong="H5375"\w* su \w voz|strong="H6963"\w* y \w clamó|strong="H7121"\w*:
\q1 Escúchenme, \w varones|strong="H1167"\w* de Siquem,
\q1 \w Y|strong="H3068"\w* \w que|strong="H7927"\w* \w escuche|strong="H8085"\w* \nd ʼElohim\nd*:
\q1 
\v 8 \w Fueron|strong="H1980"\w* una vez \w los|strong="H5921"\w* \w árboles|strong="H6086"\w*
\q1 \w A|strong="H3068"\w* ungir \w a|strong="H3068"\w* uno \w como|strong="H5921"\w* su \w rey|strong="H4428"\w*,
\q1 \w Y|strong="H3068"\w* dijeron \w al|strong="H5921"\w* olivo:
\q1 \w Sé|strong="H5921"\w* tú nuestro \w rey|strong="H4428"\w*.
\q1 
\v 9 Pero \w el|strong="H5921"\w* olivo \w les|strong="H5921"\w* dijo:
\q1 ¿Dejaré \w mi|strong="H5921"\w* aceite
\q1 \w Con|strong="H5921"\w* \w el|strong="H5921"\w* cual \nd ʼElohim\nd* \w y|strong="H5921"\w* \w los|strong="H5921"\w* hombres son honrados,
\q1 \w Para|strong="H5921"\w* mecerme \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w árboles|strong="H6086"\w*?
\q1 
\v 10 Entonces \w los|strong="H5921"\w* \w árboles|strong="H6086"\w* dijeron \w a|strong="H3068"\w* \w la|strong="H5921"\w* higuera:
\q1 ¡\w Ven|strong="H3212"\w* tú, \w sé|strong="H5921"\w* nuestra \w reina|strong="H4427"\w*!
\q1 
\v 11 Pero \w la|strong="H5921"\w* higuera \w les|strong="H5921"\w* dijo:
\q1 ¿Dejaré \w mi|strong="H5921"\w* dulzura \w y|strong="H5921"\w* \w mi|strong="H5921"\w* \w buen|strong="H2896"\w* \w fruto|strong="H8570"\w*,
\q1 \w Para|strong="H5921"\w* mecerme \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w árboles|strong="H6086"\w*?
\q1 
\v 12 Dijeron luego \w los|strong="H5921"\w* \w árboles|strong="H6086"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w vid|strong="H1612"\w*:
\q1 ¡\w Ven|strong="H3212"\w* tú, \w sé|strong="H5921"\w* nuestra \w reina|strong="H4427"\w*!
\q1 
\v 13 \w Y|strong="H3068"\w* \w la|strong="H5921"\w* \w vid|strong="H1612"\w* \w les|strong="H5921"\w* respondió:
\q1 ¿Dejaré \w mi|strong="H5921"\w* \w mosto|strong="H8492"\w*
\q1 \w Que|strong="H5921"\w* \w alegra|strong="H8055"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* hombres,
\q1 \w Para|strong="H5921"\w* mecerme \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w árboles|strong="H6086"\w*?
\q1 
\v 14 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w árboles|strong="H6086"\w* dijeron \w a|strong="H3068"\w* \w la|strong="H5921"\w* zarza:
\q1 ¡\w Ven|strong="H3212"\w* tú, \w sé|strong="H5921"\w* nuestra \w reina|strong="H4427"\w*!
\q1 
\v 15 \w Y|strong="H3068"\w* \w la|strong="H5921"\w* zarza dijo \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w árboles|strong="H6086"\w*:
\q1 ¡\w Si|strong="H5921"\w* \w en|strong="H5921"\w* verdad quieren ungirme
\q1 \w Como|strong="H5921"\w* \w reina|strong="H4428"\w* \w de|strong="H4480"\w* ustedes,
\q1 Vengan \w a|strong="H3068"\w* refugiarse bajo \w mi|strong="H5921"\w* \w sombra|strong="H6738"\w*!
\q1 \w De|strong="H4480"\w* \w lo|strong="H5921"\w* contrario, \w salga|strong="H3318"\w* fuego \w de|strong="H4480"\w* \w la|strong="H5921"\w* zarza
\q1 \w Y|strong="H3068"\w* devore \w los|strong="H5921"\w* cedros \w del|strong="H4480"\w* \w Líbano|strong="H3844"\w*.
\p 
\v 16 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, si procedieron \w a|strong="H3068"\w* ungir \w a|strong="H3068"\w* Abimelec \w como|strong="H5973"\w* su \w rey|strong="H4427"\w* \w de|strong="H5973"\w* buena fe \w e|strong="H3068"\w* integridad, si obraron \w bien|strong="H2895"\w* \w con|strong="H5973"\w* \w Jerobaal|strong="H3378"\w* y \w con|strong="H5973"\w* su \w casa|strong="H1004"\w* y si \w lo|strong="H6213"\w* \w trataron|strong="H6213"\w* según la \w obra|strong="H6213"\w* \w de|strong="H5973"\w* sus \w manos|strong="H3027"\w*,
\v 17 (pues \w mi|strong="H5921"\w* padre combatió \w por|strong="H5921"\w* ustedes \w al|strong="H5921"\w* exponer su \w vida|strong="H5315"\w* \w para|strong="H5921"\w* librarlos \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w Madián|strong="H4080"\w*,
\v 18 \w pero|strong="H3588"\w* \w hoy|strong="H3117"\w* ustedes \w se|strong="H1931"\w* \w levantaron|strong="H6965"\w* \w contra|strong="H5921"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* padre \w y|strong="H3588"\w* \w mataron|strong="H2026"\w* \w a|strong="H3068"\w* \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w*, \w a|strong="H3068"\w* 70 \w varones|strong="H3588"\w* \w sobre|strong="H5921"\w* una \w misma|strong="H1931"\w* piedra, \w y|strong="H3588"\w* proclamaron \w como|strong="H3588"\w* \w rey|strong="H4427"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w varones|strong="H3588"\w* \w de|strong="H5921"\w* Siquem \w a|strong="H3068"\w* Abimelec, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* esclava, \w por|strong="H5921"\w* \w cuanto|strong="H3588"\w* \w es|strong="H1931"\w* \w su|strong="H1931"\w* hermano),
\v 19 \w si|strong="H1571"\w* procedieron \w con|strong="H5973"\w* verdad \w y|strong="H1571"\w* rectitud \w hoy|strong="H3117"\w* \w con|strong="H5973"\w* \w Jerobaal|strong="H3378"\w* \w y|strong="H1571"\w* \w con|strong="H5973"\w* \w su|strong="H1931"\w* \w familia|strong="H1004"\w*, \w entonces|strong="H3117"\w* regocíjense \w con|strong="H5973"\w* Abimelec \w y|strong="H1571"\w* \w él|strong="H1931"\w* \w con|strong="H5973"\w* ustedes.
\p 
\v 20 Pero si no, entonces \w que|strong="H7927"\w* \w salga|strong="H3318"\w* fuego de Abimelec y consuma \w a|strong="H3068"\w* \w los|strong="H1167"\w* hombres de Siquem y de Bet-milo, y \w que|strong="H7927"\w* de \w los|strong="H1167"\w* hombres de Siquem y de Bet-milo \w salga|strong="H3318"\w* fuego \w que|strong="H7927"\w* consuma \w a|strong="H3068"\w* Abimelec.
\p 
\v 21 Luego Jotam escapó, \w huyó|strong="H1272"\w* y se \w fue|strong="H3212"\w* \w a|strong="H3068"\w* Beer. \w Allí|strong="H8033"\w* permaneció \w por|strong="H6440"\w* temor \w a|strong="H3068"\w* su hermano Abimelec.
\p 
\v 22 Abimelec gobernó \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w tres|strong="H7969"\w* \w años|strong="H8141"\w*.
\v 23 Luego \nd ʼElohim\nd* suscitó un \w espíritu|strong="H7307"\w* maligno entre Abimelec y \w los|strong="H1167"\w* \w varones|strong="H1167"\w* \w de|strong="H7451"\w* Siquem, \w de|strong="H7451"\w* modo \w que|strong="H7927"\w* \w los|strong="H1167"\w* \w varones|strong="H1167"\w* \w de|strong="H7451"\w* Siquem traicionaron \w a|strong="H3068"\w* Abimelec.
\v 24 \w Así|strong="H2555"\w* devolvieron \w la|strong="H5921"\w* \w violencia|strong="H2555"\w* hecha \w a|strong="H3068"\w* \w los|strong="H1121"\w* 70 \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Jerobaal|strong="H3378"\w* \w e|strong="H3068"\w* \w hicieron|strong="H7760"\w* recaer su \w sangre|strong="H1818"\w* \w sobre|strong="H5921"\w* su hermano Abimelec, quien \w los|strong="H1121"\w* asesinó, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w los|strong="H1121"\w* \w varones|strong="H1167"\w* \w de|strong="H5921"\w* Siquem, quienes fortalecieron \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* aquél \w para|strong="H5921"\w* \w que|strong="H5921"\w* asesinara \w a|strong="H3068"\w* sus hermanos.
\p 
\v 25 \w Los|strong="H5921"\w* \w varones|strong="H1167"\w* \w de|strong="H5921"\w* Siquem \w pusieron|strong="H7760"\w* emboscadas \w contra|strong="H5921"\w* \add Abimelec\add* \w en|strong="H5921"\w* \w las|strong="H5921"\w* cumbres \w de|strong="H5921"\w* \w las|strong="H5921"\w* montañas, quienes robaban \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w pasaban|strong="H5674"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ellos|strong="H5921"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w*. \w De|strong="H5921"\w* esto \w se|strong="H5921"\w* informó \w a|strong="H3068"\w* Abimelec.
\p 
\v 26 Entonces \w Gaal|strong="H1603"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Ebed|strong="H5651"\w*, y sus hermanos llegaron y se \w pasaron|strong="H5674"\w* \w a|strong="H3068"\w* Siquem. \w Los|strong="H1121"\w* \w varones|strong="H1167"\w* \w de|strong="H1121"\w* Siquem pusieron su confianza en \w él|strong="H1121"\w*.
\v 27 \w Luego|strong="H3318"\w* \w salieron|strong="H3318"\w* al \w campo|strong="H7704"\w* y cosecharon sus \w viñas|strong="H3754"\w*, \w pisaron|strong="H1869"\w* la uva \w e|strong="H3068"\w* \w hicieron|strong="H6213"\w* fiesta. Entraron \w en|strong="H3318"\w* \w el|strong="H6213"\w* \w templo|strong="H1004"\w* de sus \tl ʼelohim\tl*, comieron y \w bebieron|strong="H8354"\w*, y maldijeron \w a|strong="H3068"\w* Abimelec.
\p 
\v 28 \w Entonces|strong="H3588"\w* \w Gaal|strong="H1603"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Ebed|strong="H5651"\w*, dijo: ¿\w Quién|strong="H4310"\w* \w es|strong="H3588"\w* Abimelec \w y|strong="H3588"\w* \w quiénes|strong="H4310"\w* \w son|strong="H3588"\w* \w los|strong="H1121"\w* siquemitas \w para|strong="H3588"\w* \w que|strong="H3588"\w* les \w sirvamos|strong="H5647"\w*? ¿\w No|strong="H3808"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Jerobaal|strong="H3378"\w*, \w y|strong="H3588"\w* \w Zebul|strong="H2083"\w*, \w su|strong="H3588"\w* ayudante? ¡Sirvan \w a|strong="H3068"\w* \w los|strong="H1121"\w* descendientes \w de|strong="H3588"\w* \w Hamor|strong="H2544"\w*, padre \w de|strong="H3588"\w* Siquem! ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* tenemos \w que|strong="H3588"\w* servirle \w a|strong="H3068"\w* \w él|strong="H3588"\w*?
\v 29 ¡\w Quién|strong="H4310"\w* colocara \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* bajo mi \w mano|strong="H3027"\w*! ¡Yo arruinaría \w a|strong="H3068"\w* Abimelec! Diría \w a|strong="H3068"\w* Abimelec: ¡Refuerza tu \w ejército|strong="H6635"\w* y \w sal|strong="H3318"\w*!
\p 
\v 30 Cuando \w Zebul|strong="H2083"\w*, \w gobernador|strong="H8269"\w* \w de|strong="H1121"\w* la \w ciudad|strong="H5892"\w*, \w oyó|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1121"\w* \w Gaal|strong="H1603"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Ebed|strong="H5651"\w*, se encendió su ira
\v 31 \w y|strong="H5921"\w* \w envió|strong="H7971"\w* secretamente emisarios \w a|strong="H3068"\w* Abimelec \w para|strong="H5921"\w* decirle: \w Mira|strong="H2009"\w*, \w Gaal|strong="H1603"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Ebed|strong="H5651"\w*, \w y|strong="H5921"\w* sus hermanos vinieron \w a|strong="H3068"\w* Siquem \w y|strong="H5921"\w* sublevan \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*.
\v 32 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, ven \w de|strong="H5971"\w* \w noche|strong="H3915"\w* con la \w gente|strong="H5971"\w* \w que|strong="H6258"\w* \w está|strong="H6965"\w* \w contigo|strong="H5971"\w* y tiende una emboscada en el \w campo|strong="H7704"\w*.
\v 33 \w Por|strong="H5921"\w* \w la|strong="H1931"\w* \w mañana|strong="H1242"\w*, \w al|strong="H5921"\w* \w salir|strong="H3318"\w* \w el|strong="H1931"\w* \w sol|strong="H8121"\w*, \w levántate|strong="H7925"\w* \w y|strong="H5921"\w* ataca \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w*. \w Cuando|strong="H1961"\w* \w él|strong="H1931"\w* \w y|strong="H5921"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w que|strong="H1931"\w* \w lo|strong="H1931"\w* acompaña \w salgan|strong="H3318"\w* \w hacia|strong="H6213"\w* \w ti|strong="H5921"\w*, \w les|strong="H5921"\w* \w harás|strong="H6213"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* puedas.
\p 
\v 34 Entonces Abimelec, \w con|strong="H5973"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w gente|strong="H5971"\w* \w que|strong="H5921"\w* estaba \w con|strong="H5973"\w* \w él|strong="H5921"\w*, \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w de|strong="H5921"\w* \w noche|strong="H3915"\w* \w y|strong="H5921"\w* tendió una emboscada \w contra|strong="H5921"\w* Siquem, \w con|strong="H5973"\w* cuatro \w compañías|strong="H7218"\w*.
\v 35 Entonces \w Gaal|strong="H1603"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Ebed|strong="H5651"\w*, \w salió|strong="H3318"\w* y \w se|strong="H4480"\w* \w puso|strong="H5975"\w* \w en|strong="H4480"\w* la \w puerta|strong="H6607"\w* \w de|strong="H4480"\w* la \w ciudad|strong="H5892"\w*, mientras \w que|strong="H4480"\w* Abimelec y toda la \w gente|strong="H5971"\w* \w que|strong="H4480"\w* \w estaba|strong="H5975"\w* \w con|strong="H4480"\w* \w él|strong="H1121"\w*, \w salían|strong="H3318"\w* \w de|strong="H4480"\w* la emboscada.
\p 
\v 36 \w Y|strong="H3068"\w* al \w ver|strong="H7200"\w* \w Gaal|strong="H1603"\w* al \w pueblo|strong="H5971"\w*, dijo \w a|strong="H3068"\w* \w Zebul|strong="H2083"\w*: ¡\w Mira|strong="H7200"\w* la \w gente|strong="H5971"\w* \w que|strong="H5971"\w* \w baja|strong="H3381"\w* \w de|strong="H5971"\w* las cumbres \w de|strong="H5971"\w* las montañas!
\p \w Zebul|strong="H2083"\w* le respondió: ¡Tú \w ves|strong="H7200"\w* la \w sombra|strong="H6738"\w* \w de|strong="H5971"\w* las montañas como \w si|strong="H2009"\w* fueran hombres!
