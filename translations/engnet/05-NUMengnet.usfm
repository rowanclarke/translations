\c 34  
\p
\v 1  \w Then|strong="H1696"\w* \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w spoke|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*:  
