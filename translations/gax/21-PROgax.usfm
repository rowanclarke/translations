\q2 jiruu ifii eegata; 
\q2 ka ifi eegataa hin dubbanne ammoo hin bada. 
\q1  
\v 4 Nami boosenni hin halcha malee 
\q2 womaa hin dhaggatu; 
\q2 nami jabaatee huju ammoo waan halche hin dhaggata. 
\q1  
\v 5 Nami balchaan dhara jibba; 
\q2 nami hamaan ammoo qaani'ii fi salphinna fida. 
\q1  
\v 6 Balchummaan nama yakkaa hin qanne eeddi; 
\q2 hammeenni ammoo cubbaalessa balleessa. 
\q1  
\v 7 Nami womaa adoo hin qabaatin 
\q2 dureessa ifi fakkeessu tokko jira; 
\q2 ka dhibiin ammoo qabeenna guddaa adoo qabuu 
\q2 hiyyeessa ifi fakkeessu tokko jirra. 
\q1  
\v 8 Nami dureessi karra ifiitiin 
\q2 jiruu ifii wodatiisa dande'a fa'a te'a; 
\q2 nami hiyyeessi ammoo 
\q2 karra waan hin qanneef, 
\q2 jiruu ifii wodatiisaaf itti hin rakkatu. 
\q1  
\v 9 Ifi worra balcha'aa yennaa mara ifa; 
\q2 issaan nama hama'aa ammoo hin dhaama. 
\q1  
\v 10 Ifi jajiis lola qofa kaasa; 
\q2 qarummaan ammoo worra gorsa fudhatu bira jirti. 
\q1  
\v 11 Karri ariiti'iin dhaggatane ariifattee baddi; 
\q2 ka diqqeessee diqqeessee 
\q2 kuufate ammoo itti ede'ata. 
\q1  
\v 12 Addiin yennaa turte gadhaa nama gaddisiitti; 
\q2 halchaan muummotte ammoo 
\q2 midhaan muka jiru'uu ti. 
\q1  
\v 13 Nami gorsa tuffatu badii ifi irratti fida; 
\q2 nami ajaja ulfeessu 
\q2 ammoo gatii irraa dhaggata. 
\q1  
\v 14 Barsiisi nama qaro'oo madda jiru'uu ti; 
\q2 tiyyoo du'aa irraa nama deebisa. 
\q1  
\v 15 Qalbeeffati dansaan ulfinna namaaf kenniti; 
\q2 karaan worra hin addatannee ammoo bu'aa-bayi'i. 
\q1  
\v 16 Nami qalbeeffataan beekkumsaan hujata; 
\q2 gowwaan ammoo gowwummaa ifii 
\q2 badhinnatti mudhisa. 
\q1  
\v 17 Ergamaan hamaan rakkoo keessa gala; 
\q2 ergamaan addatamaan ammoo nageya buusa. 
\p  
\v 18 Nama qajeelfama tuffatu 
\q2 hiyyumma'aa fi salphinnatti itti dhufa; 
\q2 nami xixicha dhage'ee deebi'uu ammoo hin ulfaata. 
\q1  
\v 19 Halchaan muummottu namatti mi'ootti; 
\q2 gowwooleen ammoo 
\q2 waan hantuu irraa deebi'iisa jibban. 
\q1  
\v 20 Nami qaroo woliin ideemu qaroo hin te'a; 
\q2 waa'elli gowwa'aa ammoo hin farra. 
\q1  
\v 21 Wonni hantuun cubbaaleyyii ariiti; 
\q2 qananummaan ammoo gatii balcha'aa ti. 
\p  
\v 22 Nami dansaan ijoollee ijoollee ifiitiif 
\q2 dhaala lakkisee dabara; 
\q2 qabeenni cubbaalessaa ammoo 
\q2 balcha'aaf kuufama. 
\q1  
\v 23 Fichaan nama hiyyeessaa 
\q2 midhaan bacaa kennuu dande'a; 
\q2 haqa dhabiisi ammoo haxowee duraa balleessa. 
\q1  
\v 24 Nami ilma ifii adabiisa mararfatu ilma ifii jibba; 
\q2 ka jaalatu ammoo malaan adabee isa guddisa. 
\q1  
\v 25 Nami balchaan haga quufutti nyaata; 
\q2 nami hamaan yennaa mara beelota. 
\c 14  
\q1  
\v 1 Dubartiin qaroon mana ifii ijaarratti; 
\q2 dubartiin gowwaan ammoo 
\q2 harkuma ifiitiin mana ifii diiddi. 
\q1  
\v 2 Nami karaa qajeelaa ideemu 
\q2 Mootii Waan Maraa sodaata; 
\q2 ka karaan isaa micciirama'aa ammoo isa tuffata. 
