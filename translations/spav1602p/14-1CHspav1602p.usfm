\c 12
\m
\v 1 \w ÉSTOS|strong="H1992"\w* son \w los|strong="H1992"\w* \w que|strong="H1121"\w* vinieron \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w a|strong="H3068"\w* \w Siclag|strong="H6860"\w*, estando \w él|strong="H1121"\w* \w aún|strong="H5750"\w* \w encerrado|strong="H6113"\w* \w por|strong="H6440"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* \w Saúl|strong="H7586"\w* \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Cis|strong="H7027"\w*, y eran \w de|strong="H6440"\w* \w los|strong="H1992"\w* \w valientes|strong="H1368"\w* ayudadores \w de|strong="H6440"\w* la \w guerra|strong="H4421"\w*.   
\m
\v 2 Estaban \w armados|strong="H5401"\w* de \w arcos|strong="H7198"\w*, y usaban de ambas \w manos|strong="H8041"\w* en tirar piedras con honda, y \w saetas|strong="H2671"\w* con \w arco|strong="H7198"\w*. De los hermanos de \w Saúl|strong="H7586"\w* de \w Benjamín|strong="H1144"\w*:   
\m
\v 3 \w El|strong="H1121"\w* \w principal|strong="H7218"\w* Ahiezer, después \w Joas|strong="H3101"\w*, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Semaa gabaatita; y Jeziel, y \w Pelet|strong="H6404"\w*, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Azmavet, y Beracah, y \w Jehú|strong="H3058"\w* anatotita;   
\m
\v 4 \w E|strong="H3068"\w* \w Ismaías|strong="H3460"\w* \w gabaonita|strong="H1393"\w*, \w valiente|strong="H1368"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* \w treinta|strong="H7970"\w*, \w y|strong="H5921"\w* \w más|strong="H5921"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* \w treinta|strong="H7970"\w*; \w y|strong="H5921"\w* Jeremías, Jahaziel, Joanán, Jozabad gederatita,   
\m
\v 5 Eluzai, y Jeremot, Bealías, Semarías, y Sefatías el harufita;   
\m
\v 6 Elcana, \w e|strong="H3068"\w* Isías, y Azareel, y Joezer, y Jasobam, de Coré;   
\m
\v 7 \w Y|strong="H3068"\w* Joela, y Zebadías, hijos de Jeroham de Gedor.   
\m
\v 8 También \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w de|strong="H4480"\w* Gad \w se|strong="H4480"\w* huyeron \w a|strong="H3068"\w* David, \add estando\add* \w en|strong="H4480"\w* la fortaleza \w en|strong="H4480"\w* \w el|strong="H1121"\w* desierto, muy \w valientes|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H4480"\w* guerra \w para|strong="H4480"\w* pelear, dispuestos \add a hacerlo\add* \w con|strong="H4480"\w* escudo y pavés: sus rostros como rostros \w de|strong="H4480"\w* leones, y ligeros como las cabras monteses.   
\m
\v 9 Eser \w el|strong="H5921"\w* primero, Obadías \w el|strong="H5921"\w* segundo, Eliab \w el|strong="H5921"\w* tercero,   
\m
\v 10 Mismana el cuarto, Jeremías el quinto,   
\m
\v 11 Atai el sexto, Eliel el sépti­mo,   
\m
\v 12 Johanán el octavo, Elzabad el noveno,   
\m
\v 13 Jeremías el décimo, Macbani el undécimo.   
\m
\v 14 Éstos \add fueron\add* capitanes del ejército de los hijos de Gad. El menor tenía cargo de cien hom­bres, y el mayor de mil.   
\m
\v 15 Éstos pasaron \w el|strong="H1121"\w* Jordán en \w el|strong="H1121"\w* mes primero, cuando había sali­do sobre todas sus riberas; \w e|strong="H3068"\w* hicieron huir \w a|strong="H3068"\w* todos \w los|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* valles al oriente y al poniente.   
\m
\v 16 Asimismo algunos \w de|strong="H5921"\w* \w los|strong="H1992"\w* hijos \w de|strong="H5921"\w* Benjamín \w y|strong="H5921"\w* \w de|strong="H5921"\w* Judá vinieron \w a|strong="H3068"\w* David \w a|strong="H3068"\w* \w la|strong="H1931"\w* fortaleza.   
\m
\v 17 \w Y|strong="H3068"\w* \w David|strong="H1732"\w* salió \w a|strong="H3068"\w* \w ellos|strong="H4480"\w*, \w y|strong="H5704"\w* les habló­ diciendo: Si habéis venido \w a|strong="H3068"\w* mí \w para|strong="H5704"\w* paz \w y|strong="H5704"\w* \w para|strong="H5704"\w* ayudarme, mi corazón será unido \w con|strong="H4480"\w* vosotros; \w mas|strong="H4480"\w* si \w para|strong="H5704"\w* entregarme \w a|strong="H3068"\w* mis enemigos, siendo mis manos sin iniquidad, véalo \w el|strong="H1121"\w* Dios \w de|strong="H4480"\w* nuestros padres, \w y|strong="H5704"\w* \w lo|strong="H5704"\w* reprenda.   
\m
\v 18 Entonces \w se|strong="H1961"\w* envistió \w el|strong="H5921"\w* espíritu \w en|strong="H5921"\w* Amasai, príncipe \w de|strong="H5921"\w* treinta, \add y dijo:\add* \w Por|strong="H5921"\w* \w ti|strong="H5921"\w*, oh \w David|strong="H1732"\w*, \w y|strong="H5921"\w* conti­go, oh hijo \w de|strong="H5921"\w* Isaí. \w Paz|strong="H7965"\w*, \w paz|strong="H7965"\w* \w con|strong="H5921"\w*­tigo, \w y|strong="H5921"\w* \w paz|strong="H7965"\w* \w con|strong="H5921"\w* tus ayudadores; \w pues|strong="H7200"\w* \w que|strong="H3808"\w* \w también|strong="H3162"\w* tu Dios \w te|strong="H5921"\w* \w ayuda|strong="H5826"\w*. \w Y|strong="H3068"\w* \w David|strong="H1732"\w* \w los|strong="H5921"\w* recibió, \w y|strong="H5921"\w* púsolos \w entre|strong="H5921"\w* \w los|strong="H5921"\w* capitanes \w de|strong="H5921"\w* \w la|strong="H5921"\w* cuadrilla.   
\m
\v 19 También se pasaron \w a|strong="H3068"\w* \w David|strong="H1732"\w* algunos \w de|strong="H3588"\w* Manasés, \w cuando|strong="H3588"\w* vino \w con|strong="H5973"\w* \w los|strong="H1121"\w* filisteos \w a|strong="H3068"\w* \w la|strong="H3588"\w* batalla \w contra|strong="H5973"\w* Saúl, \w aunque|strong="H3588"\w* \w no|strong="H3588"\w* \w les|strong="H5973"\w* \w ayudaron|strong="H5826"\w*; \w porque|strong="H3588"\w* \w los|strong="H1121"\w* sátrapas \w de|strong="H3588"\w* \w los|strong="H1121"\w* filisteos, habido consejo, lo \w des|strong="H5414"\w*­pidieron, diciendo: \w Con|strong="H5973"\w* nuestras \w cabezas|strong="H7218"\w* se pasará \w a|strong="H3068"\w* \w su|strong="H3588"\w* señor Saúl.   
\m
\v 20 \w Así|strong="H3588"\w* \w que|strong="H3588"\w* viniendo \w él|strong="H5921"\w* \w a|strong="H3068"\w* Siclag, \w se|strong="H5921"\w* pasaron \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w de|strong="H4480"\w* \w Manasés|strong="H4519"\w*, Adnas, \w y|strong="H3588"\w* Jozabad, \w y|strong="H3588"\w* Jediaiel \w y|strong="H3588"\w* Micael, \w y|strong="H3588"\w* Jozabad, \w y|strong="H3588"\w* Eliú, \w y|strong="H3588"\w* Ziletai, \w príncipes|strong="H7218"\w* \w de|strong="H4480"\w* millares \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w de|strong="H4480"\w* \w Manasés|strong="H4519"\w*.   
\m
\v 21 Éstos ayudaron \w a|strong="H3068"\w* David \w con|strong="H5921"\w*­tra \w aquella|strong="H5921"\w* compañía; \w porque|strong="H5921"\w* todos \w ellos|strong="H5921"\w* eran hombres valien­tes, \w y|strong="H5921"\w* \w fueron|strong="H3212"\w* \w capitanes|strong="H7218"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* ejér­cito.   
\m
\v 22 \w Porque|strong="H3588"\w* \w entonces|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H1992"\w* días venía \w ayuda|strong="H5826"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w hasta|strong="H5921"\w* hacerse un grande \w ejército|strong="H2428"\w*, \w como|strong="H3588"\w* \w ejército|strong="H2428"\w* \w de|strong="H5921"\w* Dios.   
\m
\v 23 \w Y|strong="H3068"\w* éste \add es\add* \w el|strong="H5921"\w* número \w de|strong="H5921"\w* \w los|strong="H5921"\w* principales \w que|strong="H3588"\w* estaban \w a|strong="H3068"\w* punto \w de|strong="H5921"\w* guerra, \w y|strong="H3588"\w* vinieron \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w en|strong="H5921"\w* Hebrón, \w para|strong="H5704"\w* traspasarle \w el|strong="H5921"\w* reino \w de|strong="H5921"\w* Saúl, \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* palabra \w del|strong="H5921"\w* SEÑOR:   
\m
