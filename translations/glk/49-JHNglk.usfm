\id JHN  
\h یوحنا 
\toc1 انجیله یوحنا 
\toc2 یوحنا 
\mt1 انجیله یوحنا  
\imt1 پیشگفتار  
\ip کلمه‌یه «انجیل» یعنی «خبره خوش» و اَ خبره خوش کی خدا پیغامه، عیسی مسیح اونه همه‌یه مردمه دنیا‌ره بأورده. و بعداً عیسی شاگردأن و پیروأن از اونه زندگی و تعلیماتی کی بدَه کیتابأنی بینیویشتیدی. اَ کیتابأن اناجیل خوأنده به، چونکی هو خبره خوشَ اعلام کونه.  
\ip یوحنا یهودی و ایتأ از همراهأنه عیسی مسیح بو. اونه پئره نام زِبِدی و اونه برأره نام یعقوب بو. یوحنا پیش از اونکی جزوِ همراهأنه عیسی ببه، ماهیگیر و پِطرُسِ اَمره دوست و همکار بو. یوحنا خو انجیله میأن از خودش نامی نبره بلکی خوره «شاگردی کی عیسی اونه دوست دأشتی» یا «شاگرده دیگر» معرفی کونه.  
\ip نسخه‌یه اصلی‌یه اَ کیتاب به زبان یونانی بینیویشته بوبوسته و تا ایمروز انجیله یوحنا، به بیشتر از ۱۵۰۰ زبانه جورواجور ترجمه بوبوسته. تا تمامه مردمه دنیا بتأنید اَ کیتابه به خوشأنه زبان بخوأنید و بفهمید. مدارک و اسناده تاریخی نیشأن دهه کی انجیله یوحنا پیش از قرنه چهارمه میلادی به زبانه فارسی ترجمه بوبوسته کی متأسفانه ایمروزه به او نیویشته دس رسی نأریمی ولی دوباره هو انجیل به زبانه فارسی ترجمه بوبوسته. و ایمروز اَمأن اَ افتخاره دأریمی کی هو انجیله به گیلکی، در دس رسِ شومأن قرار بدیم.  
\ip یوحنا خو هدفه از نیویشتنه اَ انجیل در بابه ۲۰ آیه ۳۱ بیان بوکوده. اون گه: «ولی اَنقدر بینیویشته بوبوسته تا ایمأن بأورید کی عیسی هو مسیح، و خدا پسره، و به توسطه اَ ایمأن صاحبه زندگی‌یه اَبدی بیبید.»  
\ip انجیله یوحنا دورون، عیسی مسیح به عنوانه کلمه الهی و اَبدی کی دنیا به توسطه اون ساخته بوبوسته معرفی بوبو. و دینیمی کی در سرتاسره دورانی کی عیسی مسیح اَ دنیایه خاکی دورون ایسه بو بر علیه اَ باور مخالفت و تضاد نَهه بو. و اَ تضاد و مخالفت باعثه کوشته بوستن مسیح صلیبه رو بوبوسته. پس با اونه مرگ و قیام بو کی خو مأموریته به انجام و کمال برسأنه. و با انجامه اَ مأموریت خودشه و خدایه بشنأسأنه. اَ انجیله دورون زندگی‌یه عیسی، مسیحه موعود، به صورته ایتأ مجموعه از نیشأنه‌یأن و معجزاته کی اتفاق دکفته و به صورته سمبلیک به تصویر بکشه بوبوسته. چیزی کی قابله توجه‌یه و انجیله یوحنایه مشخصه کونه به کار بردنه سمبلیک از اشیا و اسامی در زندگی‌یه روزمره‌یه. از اَ طریق به حقیقت و واقعیتأنه روحانی اشاره به. نیشأنه‌یأنی مثله: آب، نان، نور، چوپان و برّه، تاک و اونه میوه.  
\iot تقسیمبندی‌یه کلی  
\io1 ۱- الوهیت و شخصیته عیسی مسیح.\ior ۱:‏۱-‏۱۸ \ior*\f * \fr 1.0 \ft خوأننده‌یه عزیز، وختی شومأن شماره‌یأن به اَ شکل دینیدی (۱:‏۱-‏۱۸) به معنی‌یه انجیله یوحنا بابه ۱، از آیه‌یه ۱ تا آیه‌یه ۱۸ خوأنده به.\f*  
\io1 ۲- یحیی تمید‌دهنده و اوّلین شاگردأنه عیسی مسیح. \ior ۱:‏۱۹-‏۵۱\ior*  
\io1 ۳- معجزات و تعلیماته عیسی مسیح.\ior بابه ۲-‏۱۲\ior*  
\io1 ۴- عیسی مسیح خو شاگردأنه اَمره خداحافظی کونه و اوشأنه تشویق کونه و اوشأنه‌ره دعا کونه.\ior بابه ۱۳-‏۱۷\ior*  
\io1 ۵- دستگیری‌یه عیسی مسیح، محاکمه، مصلوب و مَردن و دفن بوستن.\ior بابه ۱۸ و ۱۹\ior*  
\io1 ۶- زنده بوستن و قیامه عیسی مسیح.\ior بابه ۲۰\ior*  
\io1 ۷- ایبار دیگر عیسی مسیح خوره خودشه به خو شاگردأن ظاهره کونه.\ior بابه ۲۱\ior*  
\ib  
\is1 نکاتی درباره‌یه اَمی روش برای نیویشتن به گیلکی  
\ip گیلکی میأن صدایأن تفاوته بیشتری نسبت به زبانه فارسی دأره. و اَ موضوع باعثه مشکل در نیویشتن به گیلکی به. اَمی هدف و مقصود برای نیویشتن اَنه‌ کی به شکلی بینیویشته ببه کی اونه خوأندن آسان و روان ببه. روشی کی اَ کیتابه میأن به کار ببرده بوبوسته، مثله نیویشتن به زبان فارسی‌یه ولی تلفظه مناسب کلمه‌یه به عهده شومأن خوأننده‌یأن عزیز نیهیمی. دوتأ تغیره اساسی اَ کیتابه میأن وجود دأره کی اوشأنه به اَ خاطر کی شمره در موقعه خوأندن کمک کونه به عرضه شومأن رسأنیمی.  
\ip اوّل، الف (ا) صداداره بلند در کلماته زبانه فارسی به گیلکی به صورته الف (ا) صداداره کوتاه تلفظ به. اَمأن اَ صداره از نیشأنه‌یه الف و همزه (أ) استفاده بوکودیمی. مثله: «میان» در فارسی‌یه به گیلکی به صورته: «میأن» بینیویشتیمی.  
\ip دوّم، کلماتی کی در آخره اون پسوند اضافه دأره، اَمأن اَ پسونده در گیلکی با (ه) و یا (یه) بینیویشتیمی. مثله: «آب روان» در زبانه فارسی‌یه در گیلکی به صورته: «آبه روان» بینیویشتیمی و «صدای بلند» در زبانه فارسی‌یه در گیلکی به صورته «صدایه بلند» بینیویشتیمی.  
\ip اَمی آرزو اَنه کی خوأندنه اَ کیتاب شمره باعثه برکت ببه. آمین.  
\c 1  
\s1 کلمه انسان بوبوسته  
\p
\v 1 از اوّل کلمه بو و کلمه خدا اَمره بو و کلمه، خدا بو.  
\v 2 اون از اوّل خدا اَمره بو.  
\v 3 همه چی توسطه اون به وجود بَمو، و از هر اونچی کی به وجود بَمو، هیچ چی بدونه اون به وجود نَمو.   
\p
\v 4 در اون حیات بو و او حیات، نوره آدمیأن بو.  
\v 5 اَ نور در تاریکی تأبه و تاریکی نتأنه اونه از بین ببره.   
\p
\v 6 مردی بَمو کی خدا اونه اوسه کوده بو. اونه نام یحیی بو.  
\v 7 اون شهادت دَئنه‌ره بَمو بو، شهادته بر او نور، تا همه توسطه اون ایمأن بأورید.  
\v 8 یحیی خودش او نور نوبو، بلکی بَمو بو تا بر او نور شهادت بده.  
\v 9 اون نوره حقیقی کی هر آدمی‌یه منوّره کونه، حقیقتاً به جهان اَمون دوبو.   
\p
\v 10 اون دنیا میأن ایسه بو و دنیا به واسطه‌یه اون به وجود بَمو، امّا دنیا اونه نشنأخته.  
\v 11 به خو مِلکِ سر بَمو، ولی اونه قوم، اونه قبول نوکودیدی.  
\v 12 امّا به تمامه کسأنی کی اونه قبول بوکودیدی، اَ حقَ فده کی خدا زأکأن بیبید، یعنی هر کسی کی به اونه نام ایمأن بأوره.  
\v 13 نه کسأنی کی از انسان به دنیا بَموییدی و نه از نفسه خوأهشیدی و نه از ایتأ مردِ خوأسته به دنیا بَموییدی، بلکی تولدی از خدایه.   
\p
\v 14 و کلمه، انسانه خاکی بوبوسته و اَمی میأن ساکن بوبوسته و اَمأن اونه جلاله بیده‌ییم، \f * \fr 1.14 \ft به معنی: با دقّت نیگاه کودن \f* جلالی کی شایسته‌یه او یگانه پسری ایسه کی از طرفه پئر بَمو، پُر از فیض و راستی.  
\v 15 یحیی بر اون شهادت دَیی و با صدایه بلند گفتی کی: «اَن او کسی ایسه کی درباره‌یه اون بوگفتم: ‹اون کی بعد از من اَیه بر من برتری پیدا بوکوده، چونکی قبل از من وجود دأشتی›.»  
\v 16 از اونه پُری اَمأن همه بهره‌مند بوبوستیم، فیض، فیضه سر.  
\v 17 چونکی شریعت توسطه موسی بَمو، امّا فیض و راستی به واسطه‌یه عیسی مسیح بَمو.  
\v 18 هیچکی هرگز خدایه نیده. امّا او یگانه، کی پئره ورجه ایسه و در خودشه ذاتم خدایه، اون، اونه بشنأسأنه.   
\s1 یحیی شهادت  
\p
\v 19 اَنه یحیی شهادت او وختی کی یهودیأن، کاهنأن و لاویأنه از اورشلیم اونه پهلو اوسه کودیدی تا از اون وَورسید کی: «تو کی ایسی؟»  
\v 20 یحیی اعتراف بوکوده، انکار نوکوده، بلکی اصرار دأشتی کی: «من مسیح نی‌یم.»   
\p
\v 21 وَورسه‌ییدی: «پس چی؟ تو الیاسی؟»  
\p جواب بده: «نی‌یم.» وَورسه‌ییدی:  
\p «تو او پیامبری؟»  
\p جواب بده: «نه!»   
\p
\v 22 او وخت اونه بوگفتیدی: «پس کی ایسی؟ بوگو چی جوابی او کسأنی‌ره کی اَمَره اوسه کودیدی، ببریم؟ درباره‌یه خودت چی گی؟»   
\p
\v 23 یحیی طبقِ اونچی کی اِشَعْیایه نبی بیان بوکوده بو، بوگفته  
\q1 «من او صدایه نداکوننده در بیابانم کی گه:  
\q2 ‹خداونده رایه همواره کونید!›» \x * \xo 1.23 \xt تورات، کیتابه اِشَعْیا، بابه ۴۰، آیه ۳. \x*   
\p
\v 24 تعدادی از اوشأنی کی روانه بوسته بید و از فَریسیأن بید،  
\v 25 اونه وَورسه‌ییدی: «اگر تو نه مسیحی، نه الیاسی و نه او پیامبر، پس چره تعمید دیهی؟»  
\v 26 یحیی در جواب بوگفته: «من آبه اَمره تعمید دهم، امّا شیمی میأن کسی ایسه کی شومأن اونه نشنأسیدی.  
\v 27 اونی کی بعد از من اَیه، من لایقه وأکودن اونه کفشه بندم نی‌یم.»   
\p
\v 28 اَشأن همه در بیت‌عَنْیا واقع در او طرفه اُردنِ رودخانه رخ بده، جایی کی یحیی تعمید دَیی.   
\s1 خدا برّه  
\p
\v 29 فردایه او روز، یحیی چون عیسایه بیده کی اونه طرف اَمون دره، بوگفته: «اَنه برّه‌یه خدا کی گناهه از دنیا اوسَنه!  
\v 30 اَن، اونی ایسه کی من درباره‌یه اون بوگفتم؛ ‹بعد از من مردی اَیه کی بر من برتری دأشتی، چونکی قبل از من وجود دأشتی.›  
\v 31 من خودمم اونه نشنأختیم، امّا هَنه وستی بَموم کی آبه اَمره تعمید بدَم تا اون، اسرائیله‌ره ظاهره به.»  
\v 32 پس یحیی شهادت بده و بوگفته: «روحه بیدم کی کبوتره مأنستن از آسمان فرود بَمو و بر اون قرار بیگیفته.  
\v 33 من خودمم اونه نشنأختیم، امّا اونی کی مره اوسه کوده تا آبه اَمره تعمید بدَم، مره بوگفته کی: ‹هر وخت بیده‌یی کی روح بر کسی فرود بَمو و بر اون قرار بیگیفته، بدأن اون، اونی ایسه کی روح‌القدسه اَمره تعمید دهه.›  
\v 34 و من بیدم و شهادت دهم کی اَن خدا پسره!»   
\s1 عیسی اوّلین شاگردأن  
\p
\v 35 فردایه او روز، ایبارِ دیگر یحیی خو دوتأ شاگردأنه اَمره ایسه بو.  
\v 36 اون عیسایه کی راه شوئون دوبو، نیگاه بوکوده و بوگفته: «اَنه، خدا برّه!»  
\v 37 وختی اونه دوتأ شاگرد، اَنه حرفه بیشنَوستیدی، از عیسی دونبالسر راه دکفتیدی.  
\v 38 عیسی خو رویه وأگردأنه و بیده کی از اونه دونبالسر اَمون دریدی. اوشأنه بوگفته: «چی خوأییدی؟»  
\p بوگفتیدی: «ای اوستاد، تی خانه کویه ایسه؟»   
\p
\v 39 جواب بده: «بأیید و بیدینید!» پس بوشوییدی و بیده‌ییدی کی کویه خانه دأره و او روز اونه اَمره سر بوکودید. او لحظه ساعته چهاره بعد از ظهر بو.   
\p
\v 40 ایتأ از او دو نفر کی یحیی حرفأنه بیشنَوسته بو و عیسی دونبالسر بوشو، آندریاس، شَمعونِ پِطرُسِ برأر بو.  
\v 41 اون اوّل خو برأر شَمعونَ پیدا بوکوده و اونه بوگفته: «اَمأن مسیحه (کی اونه معنی ‹مسح بوبوسته‌یه›) پیدا بوکودیم.»  
\v 42 و اونه عیسی ورجه ببرده. عیسی اونه نیگاه بوکوده و بوگفته: «تو شَمعونِ پِطرُس، یوحنا پسری. امّا ‹کیفا› دوخوأده بی» (کی اونه معنی صخره‌یه).   
\s1 عیسی فیلیپُس و نَتَنائیلَ به خو شاگردی دعوت کونه  
\p
\v 43 روزِ بعد عیسی خوأستی کی به ولایته جلیل بشه. فیلیپُسه پیدا بوکوده و اونه بوگفته: «می دونبال بیأ!»  
\v 44 فیلیپُس اهله بیت‌صِیْدا بو، آندریاس و پِطرُسِ همشهری.  
\v 45 اون نَتَنائیلَ پیدا بوکوده و بوگفته: «اون کسی کی موسی در تورات درباره‌یه اون بوگفته و پیامبرأنم بینیویشتیدی، پیدا بوکودیم! اون عیسی، یوسفه پسر از شهر ناصره‌یه!»   
\p
\v 46 نَتَنائیل اونه بوگفته: «مگر به، کی از ناصره چیزه خوبی بیرون بأیه؟»  
\p فیلیپُس جواب بده: «بیأ و بیدین.»   
\p
\v 47 وختی عیسی بیده کی نَتَنائیل اونه طرف اَمون دره، درباره‌یه اون بوگفته: «حقیقتاً کی اَنه او مردِ اسرائیلی کی در اون هیچ مکر و حیله‌یی پیدا نیبه!»   
\p
\v 48 نَتَنائیل اونه بوگفته: «مره از کویه شنأسی؟»  
\p عیسی جواب بده: «قبل از اونکی فیلیپُس تره دوخوأنه، وختی کی درخته انجیره زیر ایسه بی، تره بیدم.»   
\p
\v 49 نَتَنائیل جواب بده: «اوستاد تو خدا پسری! تو اسرائیله پادشاهی!»   
\p
\v 50 عیسی در جواب بوگفته: «آیا بخاطره اَنکی بوگفتم تره درخته انجیره زیر بیدم، ایمأن بأوردی؟ از اَن به بعد چیزأنه بزرگتری دینی.»  
\v 51 بعداً بوگفته: «آمین، آمین \f * \fr 1.51 \ft اصطلاحه آمینِ، یهودیأن وختی کی کلامی‌یه ایشنَوستیدی به زبان اَوردیدی و اونه معنی اَنه کی «هَطو ببه» یا به «حقیقت هَطو ایسه.» بعداً مسیحیأن آمینَ در آخره دعا یا بعد از ایشنَوسته کلامه خدا به کار بردیدی ولی عیسی با به کار بردنه اون در اوّله بعضی از خو گفته‌یأن به درستی و صحته خو کلام تأکید کودی.\f* شمره گم کی آسمان بازه به و خدا فرشته‌یأنه در حالی کی بر انسانه پسر بیزیر اَییدی و به آسمان شیدی، دینیدی.»   
\c 2  
\s1 معجزه‌یی عروسی میأن  
\p
\v 1 سوّمین روز قانایه جلیلِ میأن عروسی بو و عیسی مارم اویه ایسه بو.  
\v 2 عیسی و اونه شاگردأنم به عروسی دعوت بوبوسته بید.  
\v 3 وختی کی شراب تمامه بوسته، عیسی مار، عیسایه بوگفته: «اَشأن دِ شراب نأریدی.»   
\p
\v 4 عیسی اونه بوگفته: «بانو، مره چی به اَ کارأن؟ می وخت هنوز فَنرسه.»   
\p
\v 5 اونه مار پیشخدمتأنه بوگفته: «هر چی شمره گه، بوکونید.»   
\p
\v 6 اویه شیش‌تأ خمره‌یه سنگی نَهه بو کی برای رسمه تطهیره یهودیأن \f * \fr 2.6 \ft یهود مذهبه میأن، یهودیأن از اَ آب بدن و وسایله پاکه وستی استفاده کودیدی. \f* به کار اَمویی و هر کدام ظرفیته دو یا سه‌تأ پیمانه‌یه \f * \fr 2.6 \ft هر پیمانه ۷۵-‏۱۱۵ لیتر جا دأشتی. \f* دأشتی.  
\v 7 عیسی خدمتکارأنه بوگفته: «اَ خمره‌یأنه از آب پُره کونید.» پس اوشأنه لبالب پُره کودیدی.  
\v 8 بعداً اوشأنه بوگفته: «الأن ایپچه از اون اوسَنید و صاحبه مجلسه‌ره ببرید.» اوشأنم هوطو بوکودیدی.   
\p
\v 9 صاحبه مجلس نأنستی کی اونه از کویه بأوردیدی، ولی خدمتکارأنی کی اونه اوسَده بید، دأنستیدی. اون وخت آبی کی شراب بوبوسته بو بیچیشته، داماده دوخوأده  
\v 10 و اونه بوگفته: «همه اوّل شرابه نابه اَوریدی و پذیرایی کونیدی و وختی مهمانأن مسته بیدی، بعداً شرابه ارزانتره اَوریدی؛ امّا تو شرابه نابه تا اَ لحظه بدأشتی!»   
\p
\v 11 اَطویی عیسی خو اوّلین معجزه‌یه قانایه جلیلِ میأن انجام بده و خو جلاله نیشأن بده و اونه شاگردأن به اون ایمأن بأوردیدی.   
\p
\v 12 بعد از اون، خو مار و خو برأرأن و شاگردأنه اَمره به کَفَرناحوم بوشو و چند روزی‌یه در اویه بِیسه‌ییدی.   
\s1 عیسی معبده میأن  
\p
\v 13 چونکی یهودیأنه عیده پِسَخ نزدیک بو، عیسی به اورشلیم بوشو.  
\v 14 معبده صحنِ میأنی بیده کی تعدادی به فروختنه گاو و گوسفند و کبوتر مشغولیدی و صرافأنم به کاسبی نیشته بید.  
\v 15 پس، از طناب شلاق چأکوده اوشأنه با همه‌یه گاوأن و گوسفندأن از معبد بیرونه کوده و صرافأنه سکه‌یأنه، زمینه رو فوکوده و اوشأنه میزأنه وأگردأنه  
\v 16 و کبوتر فروشأنه بوگفته: «اَشأنه از اَیه بیرون ببرید و می پئره خانه‌یه به محلِ کاسبی تبدیل نوکونید!»  
\v 17 اون وخت اونه شاگردأن به یاد بأوردیدی کی بینیویشته بوبوسته بو: «غیرتی کی تی خانه وستی دأرم، مره سوزنه.» \x * \xo 2.17 \xt تورات، کیتابه مزمور، بابه ۶۹، آیه ۹. \x*   
\p
\v 18 پس یهودیأن بخاطره اَ کارأن اونه بوگفتیدی: «چی معجزه‌یی اَمَره نیشأن دیهی کی بدأنیم تو اجازه‌یه اَ کارأنه دأری؟»   
\p
\v 19 عیسی در جوابه اوشأن بوگفته: «شومأن اَ معبده خرابه کونید من سه روزِ اونه دوباره چأکونم.»   
\p
\v 20 یهودیأن اونه بوگفتیدی: «اَ معبده ساختن چهل و شیش سال طول بکشه، و الأن تو خوأیی سه روزِ اونه چأکونی؟»  
\v 21 ولی معبدی کی عیسی از اون حرف زه‌یی، خودشه بدن بو.  
\v 22 پس وختی کی از مُرده‌یأن ویریشته، اونه شاگردأن اَ گفته‌یه به یاد بأوردیدی و به کیتابه مقدّس و اونه حرفأن ایمأن بأوردیدی.   
\p
\v 23 وختی کی عیسی عیده پِسَخِ‌ره اورشلیمه میأن ایسه بو، خیلی‌یأن بخاطره معجزاتی کی انجام بده بو، به اونه نام ایمأن بأوردیدی.  
\v 24 امّا عیسی به اوشأنه ایمأن اعتماد نأشتی، چونکی همه‌یه شنأختی  
\v 25 و لازم نوبو کسی درباره‌یه انسان چیزی اونه بگه، چونکی خودش دأنستی کی انسانه دورونی چی نَهه!   
\c 3  
\s1 عیسی نیقودیموسِ اَمره ملاقات بوکوده  
\p
\v 1 مردی بو از فرقه‌یه فَریسی، نیقودیموس نام، از حاکمأنه یهود.  
\v 2 اون ایتأ شب عیسی ورجه بَمو و اونه بوگفته: «اوستاد! دأنیمی کی تو معلمی ایسی کی از خدا طرف بَمویی، چونکی هیچکی نتأنه معجزاتی‌یه کی تو انجام دیهی، انجام بده، بجز اونکی خدا اونه اَمره ببه.»   
\p
\v 3 عیسی در جواب بوگفته: «آمین، آمین، تره گم تا کسی از نو به دنیا نأیه، نتأنه خدا پادشاهی‌یه بیدینه.»   
\p
\v 4 نیقودیموس اونه بوگفته: «کسی کی پیره، چوطو تأنه دوباره به دنیا بأیه؟ آیا تأنه به خو ماره شکم وأگرده و دوباره به دنیا بأیه؟»   
\p
\v 5 عیسی جواب بده: «آمین، آمین تره گم تا کسی از آب و روح به دنیا نأیه، نتأنه وارده خدا پادشاهی ببه.  
\v 6 اونچی کی از انسان به دنیا بأیه، جسمأنی‌یه و اونچی کی از روح به دنیا بأیه، روحانی‌یه.  
\v 7 تعجب نوکون کی بوگفتم بأید از نو به دنیا بأیید!  
\v 8 باد هر جایی کی بخوأیه، حرکت کونه و اونه صدایه ایشنَوی، امّا نأنی کی از کویه اَیه و به کویه شه. هوطویه هر کسی کی از روح به دنیا بأیه.»   
\p
\v 9 نیقودیموس از اون وَورسه: «اَ چیز چوطو ممکنه؟»   
\p
\v 10 عیسی جواب بده: «تو اسرائیله معلمی و اَ چیزأنه متوجه نیبی؟  
\v 11 آمین، آمین، تره گم اَمأن از اونچی کی دأنیم، حرف زنیم و اونچی کی بیده‌ییم، شهادت دیهیم، امّا شومأن اَمی شهادته قبول نوکونیدی.  
\v 12 وختی شیمی اَمره درباره‌یه اموره زمینی حرف بزم، باور نوکودیدی، چوطو باور کونیدی اگر شیمی اَمره از اموره آسمانی بگم؟  
\v 13 هیچکس به آسمان بوجور نوشو، مگر اونی کی از آسمان بیزیر بَمو، یعنی انسانه پسر.  
\v 14 هوطویی کی موسی بیابانه میأن ماره مجسمه‌یه بلنده کوده تا مردم بیدینید و از مرگ نجات پیدا بوکونید، هوطویی هم انسانه پسر بأید بلنده کوده ببه تا مردم بیدینید و نجات پیدا بوکونید.  
\v 15 تا هر کسی کی به اون ایمأن بأوره، زندگی‌یه اَبدی بدأره.   
\p
\v 16 «چونکی خدا دنیایه اونقدر محبت بوکوده کی خو یگانه پسره فده، تا هرکی به اون ایمأن بأوره هلاکه نبه، بلکی زندگی‌یه اَبدی بدأره.  
\v 17 چونکی خدا خو پسره اوسه نوکوده تا مردمه دنیایه محکوم بوکونه، بلکی اوسه کوده تا توسطه اون نجات پیدا بوکونید.   
\p
\v 18 «هرکی به اون ایمأن دأره، محکوم نیبه، امّا هرکی به اون ایمأن نأره، از هَه الأنم محکوم بوبوسته، چونکی به خدا یگانه پسره نام ایمأن نأورده.  
\v 19 و محکومیت در اَنه کی نور به جهان بَمو، امّا مردم تاریکی‌یه بیشتر از نور دوست دأشتیدی، چونکی اَشأنه کارأن بد ایسه.  
\v 20 چونکی هر کسی بدی کونه، از نور نفرت دأره و نوره طرف نأیه، مبادا اونه کارأن آشکاره به و رسوا ببه.  
\v 21 امّا اونی کی در راستی زندگی کونه، نوره طرف اَیه تا آشکاره به، کی خو کارأنه به یاری‌یه خدا انجام بده.»   
\s1 یحیی خو آخرین شهادته درباره‌یه عیسی دهه  
\p
\v 22 بعد از اون، عیسی خو شاگردأنه اَمره به دهاته اطرافه یهودیه بوشو، اون چند روزی اویه بِیسه و مردمه تعمید بده.  
\v 23 یحیایم عِیْنونِ میأن، نزدیکه سالیم، تعمید دَیی، چونکی در اویه آب زیاد بو و مردم اَموییدی و تعمید گیفتیدی.  
\v 24 اون وختی بو کی یحیی هنوز به زندان دنکفته بو.  
\v 25 ایدفعه بین یحیی شاگردأن و ایتأ یهودی، رسمه تطهیره وستی بحثی به وجود بَمو.  
\v 26 پس یحیی ورجه بَموییدی و اونه بوگفتیدی: «اوستاد، اونی کی تی اَمره او طرفه رودِ اُردن ایسه بو و تو درباره‌یه اون شهادت دَیی، الأن خودش تعمید دهه و همه اونه ورجه شیدی.»   
\p
\v 27 یحیی در جواب بوگفته: «هیچکی نتأنه چیزی به دست بأوره مگر اونکی از آسمان به اون عطا ببه.  
\v 28 شومأن خودتأن شاهدید کی من بوگفتم کی من مسیح نی‌یم، بلکی پیشاپیشه اون روانه بوبوستم.  
\v 29 عروس داماده‌شینه، امّا داماده رفق کی کنار ایسَه به اون گوش کونه، و از ایشنَوستنه داماده صدا، شادی‌یه زیادی کونه. می شادی‌یم اَطویی تکمیله بوسته.  
\v 30 اون بأید جلال پیدا بوکونه و من بأید کوچیکه بم.   
\p
\v 31 «اون کی از آسمان اَیه، از همه بالاتره، امّا اونی کی از زمین ایسه، زمینی‌یه و از چیزأنه زمینی حرف زنه. اونی کی از آسمان اَیه، از همه بالاتره.  
\v 32 اون از اونچی کی بیده و بیشنَوسته شهادت دهه، امّا هیچکی اونه شهادته قبول نوکونه.  
\v 33 کسی کی اونه شهادته قبول بوکونه، بر راستی‌یه خدا مُهرِ تأیید بزه.  
\v 34 چون اونی‌یه کی خدا اوسه کوده، خدا کلامه بیان کونه، چون خدا خو روحه به یک میزان عطا نوکونه.  
\v 35 پئر پسره محبت کونه و همه چیزه به اون بیسپرده.  
\v 36 اونی کی به پسر ایمأن دأره زندگی‌یه اَبدی دأره، امّا اونی کی از پسر اطاعت نوکونه، زندگی‌یه اَبدی‌یه نیدینه، بلکی زیرِ غضبه خدا مأنه.»   
\c 4  
\s1 عیسی و زنه سامری  
\p
\v 1 وختی عیسی بفهمسته کی فَریسیأن بیشنَوستیدی کی اون بیشتر از یحیی شاگردأن بساخته و اوشأنه تعمید دهه،  
\v 2 گر چی عیسی شاگردأن تعمید دَییدی، نه خودش،  
\v 3 یهودیه‌یه ترکه کوده و ایبارِ دیگر به طرفه جلیل بوشو.  
\v 4 و بأیستی از سامره ردّه بوسته بی.  
\v 5 پس به ایتأ شهر از سامره کی اونه نام سوخار بو، فَرسه؛ نزدیکه او تیکه زمینی کی یعقوب خو پسر یوسفه فده بو.  
\v 6 یعقوبه چاه اویه نَهه بو و عیسی کی از سفر خسته بوسته بو، چایه کنار بینیشته. حدوداً ساعت دوازده ظهر بو.   
\p
\v 7 در اَ وخت زنی از مردمأنه سامره آب فکشنه وستی بَمو. عیسی اونه بوگفته: «ایپچه آب مره فدن.»  
\v 8 او وخت اونه شاگردأن بوشو بید شهر، غذا تهیه بوکونید.   
\p
\v 9 زن اونه بوگفته: «چوطو تو کی یهودی ایسی، از من کی ایتأ زنه سامری‌یم، آب خوأیی؟» چونکی یهودیأن سامریأنه اَمره هیچ معاشرتی نأشتیدی.   
\p
\v 10 عیسی در جواب بوگفته: «اگر بخششه خدایه بدأنستی بی و دأنستی کی چه کسی از تو آب خوأیه، تو خودت از اون خوأستی تره آبه روانی کی حیات بخشه، عطا بوکونه.»   
\p
\v 11 زن اونه بوگفته: «ای سرور، سطل نأری و چایم خیلی گوده، پس آبه روانَ از کویه اَوری؟  
\v 12 آیا تو از اَمی پئر یعقوبم پیله‌تری کی اَ چایه اَمَره فده و خودش و اونه پسرأن و اونه گاو و گوسفندأن از او چاه آب خوردیدی؟»   
\p
\v 13 عیسی بوگفته: «هر کسی از اَ آب بوخوره، بازم تشنه به.  
\v 14 امّا هر کی از او آبی کی من اونه فدم بوخوره، هرگز تشنه نیبه. چونکی آبی کی من اونه فدم، در اون چشمه‌یه آبی به، کی تا زندگی‌یه اَبدی جوشأنه!»   
\p
\v 15 زن بوگفته: «ای سرور، از اَ آب مره فدن تا دِ تشنه نبم و آب فکشنه‌ره اَیه نأیم.»   
\p
\v 16 عیسی بوگفته: «بوشو تی مردَ دوخوأن و وأگرد.»   
\p
\v 17 زن جواب بده: «مرد نأرم.»  
\p عیسی بوگفته: «راست گی کی مرد نأری.  
\v 18 چونکی پنج‌تأ مرد دأشتی و اونم کی الأن دأری تی مرد نی‌یه. اونچی کی بوگفتی درسته!»   
\p
\v 19 زن بوگفته: «ای سرور، دینم کی تو ایتأ نبی ایسی!  
\v 20 اَمی پئرأن اَ کوه رو عبادت کودیدی، امّا شومأن یهودیأن، گیدی جایی کی بأید در اویه عبادت بوکونید، اورشلیمه.»   
\p
\v 21 عیسی بوگفته: «ای زن، باور بوکون زمانی فَرسه کی پئره نه اَ کوه رو عبادت کونیدی، نه اورشلیمه میأن.  
\v 22 شومأن اونچی‌یه کی نشنأسیدی عبادت کونیدی، امّا اَمأن اونچی‌یه کی شنأسیم عبادت کونیم، چونکی نجات به وسیله‌یه قومه یهود فراهم به.  
\v 23 امّا زمانی اَیه و الأنم او زمان فَرسه کی عبادت‌کوننده‌یأنه حقیقی، پئره در روح و راستی عبادت کونیدی، چونکی پئر به دونباله اَجور عبادت‌کوننده‌یأن ایسه.  
\v 24 خدا روحه و اونه عبادت‌کوننده‌یأن بأید اونه در روح و راستی عبادت بوکونید.»   
\p
\v 25 زن بوگفته: «دأنم کی مسیح (یعنی ‹مسح بوبوسته›) اَیه. وختی اون بأیه، همه چیزه اَمَره خبر دهه.»   
\p
\v 26 عیسی اونه بوگفته: «من کی تی اَمره حرف زِئن درم، هونم.»   
\p
\v 27 او لحظه عیسی شاگردأن از راه فَرسه‌ییدی و از اَنکی اون ایتأ زنه اَمره حرف زِئن دوبو، تعجب بوکودیدی. امّا هیچکی وَنَورسه کی: «چی خوأیی؟» یا «چره او زنه اَمره حرف زنی؟»  
\v 28 اون وخت زن خو کوزه‌یه جا بنَه و به شهر بوشو و مردمه بوگفته:  
\v 29 «بأیید مردی‌یه بیدینید کی هر چی کی تا الأن بوکوده بوم، مره بوگفته. آیا امکان نأره کی اون مسیح ببه؟»  
\v 30 پس اوشأن از شهر بیرون بَموییدی و عیسی ورجه بوشوییدی.   
\p
\v 31 اَ میأن، شاگردأن از اون خوأهش بوکودیدی و بوگفتیدی: «اوستاد چیزی بوخور!»   
\p
\v 32 امّا عیسی اوشأنه بوگفته: «من خوراکی، خوردنه‌ره دأرم کی شومأن از اون چیزی نأنیدی.»   
\p
\v 33 شاگردأن همدیگره بوگفتیدی: «مگر کسی اونه‌ره خوراکی بأورده؟»   
\p
\v 34 عیسی اوشأنه بوگفته: «می خوراک اَنه کی اراده‌یه او کسی‌یه کی مره اوسه کوده بجا بأورم و اونه کاره به کمال برسأنم.  
\v 35 آیا اَ حرفه نیشنَوستیدی کی: ‹چهار ماه بیشتر به وخته درو نمأنسته›؟ امّا من شمره گم، شیمی چشمأنه وأکونید و بیدینید کی الأن مزرعه‌یأن آماده‌یه درویه.  
\v 36 الأن دروگر خو مزده فیگیره و حاصلی برای زندگی‌یه اَبدی به دست اَوره، تا اونی کی بکاشته و اونی کی درو بوکوده، با هم شاد بیبید.  
\v 37 در اَیه اَ گفته درسته کی: ‹اینفر کأره، و اینفر دیگر درو کونه›.  
\v 38 من شمره اوسه کودم تا محصولی‌یه درو بوکونید کی شیمی دسترنج نی‌یه. دیگرأن سخت کار بوکودیدی و شومأن اوشأنه دسترنجه بردأشت کونیدی.»   
\p
\v 39 پس به دونباله شهادته او زنی کی بوگفته بو: «هرچی کی تا الأن بوکوده بوم، مره بوگفته،» خیلی از سامریأنه ساکنه او شهر به عیسی ایمأن بأوردیدی.  
\v 40 وختی کی او سامریأن عیسی ورجه بَموییدی، از عیسی بخوأستیدی کی اوشأنه ورجه بِیسه. پس دو روز اویه بِیسه.  
\v 41 و خیلی‌یأنم بخاطره ایشنَوستنه اونه حرفأن ایمأن بأوردیدی.  
\v 42 اوشأن او زنه بوگفتیدی: «تنها دِ بخاطره تی حرفأن ایمأن نأوریم، چونکی اَمأن خودمأن اونه حرفأنه بیشنَوستیم و دأنیم کی حقیقتاً اَ مرد نجات‌دهنده‌یه دنیایه.»   
\s1 عیسی جلیلِ میأن  
\p
\v 43 بعد از دو روز، عیسی از اویه به جلیل بوشو.  
\v 44 (قبلاً خودش بوگفته بو کی: «نبی در خودشه محل احترام نأره.»)  
\v 45 وختی به جلیل فَرسه، جلیلیأن اونه به گرمی قبول بوکودیدی، چونکی اوشأن بخاطره عید به اورشلیم بوشو بید و اونچی‌یه کی عیسی اویه انجام بده بو، بیده بید.   
\s1 شفایه ایتأ درباری پسر  
\p
\v 46 بعد از اون، عیسی دوباره به قانایه جلیل بوشو، اویه کی آبه تبدیل به شراب بوکوده بو. در اویه ایتأ از افسرأن ایسه بو کی پسری مریض کَفَرناحومِ میأن دأشتی.  
\v 47 وختی بیشنَوسته کی عیسی از یهودیه به جلیل بَمو، به اونه دِئن بوشو و منّت بوکوده کی بأیه اونه پسره کی در حال مرگ بو، شفا بده.   
\p
\v 48 عیسی اونه بوگفته: «تا معجزات و چیزأنه عجیب نیدینید، ایمأن نأوریدی!»   
\p
\v 49 او مرد بوگفته: «ای سرور قبل از اونکی می زأی بیمیره، بیأ.»   
\p
\v 50 عیسی اونه بوگفته: «بوشو، تی پسر زنده مأنه.» او مرد عیسی کلامه قبول بوکوده و به راه دکفته.   
\p
\v 51 هنوز راه میأن ایسه بو کی اونه خدمتکارأن بَموییدی و بوگفتیدی: «تی پسر زنده و سالمه.»  
\v 52 از اوشأن وَورسه: «چی ساعتی اون شفا پیدا بوکوده؟» بوگفتیدی: «دیروز ساعت یکِ بعد از ظهر تب، اونه وله کوده.»  
\v 53 او وخت پئر بفهمسته کی اَن هو ساعتی بو کی عیسی اونه بوگفته بو: «تی پسر زنده مأنه.» پس خودش و اونه تمامه خانواده ایمأن بأوردیدی.  
\v 54 اَن دوّمین معجزه‌یی بو کی عیسی وختی کی از یهودیه به جلیل بَمو بو، انجام بده.   
\c 5  
\s1 شفایه مردِ علیل  
\p
\v 1 بعد از مدتی عیسی بخاطره ایتأ از یهودیأنه عید به اورشلیم بوشو.  
\v 2 اورشلیمه میأن، «دروازه‌یه گوسفنده» کنار حوضی نَهه کی به زبانه عبرانیأن \f * \fr 5.2 \ft یعنی: زبانه یهودی \f* «بیت‌حِسْدا» گیدی و پنج‌تأ اِیوانه سربسته دأره.  
\v 3 در اویه خیلی از علیلأن، مثله کورأن، شلأن و افلیجأن خوفتیدی، [و منتظره حرکت آب بیدی.  
\v 4 چونکی هرچند وخت ایبار ایتأ فرشته‌یه خداوند اَمویی کی آبه حوضه به حرکت بأوره. اوّلین نفری کی بعد از به حرکت اَمونه آب وارده اون بوستی، از هر مرضی کی دأشتی، شفا پیدا کودی.]   
\p
\v 5 اَ میأنی مردی ایسه بو کی سی و هشت سال زمینگیر بو.  
\v 6 وختی عیسی بیده اون اویه خوفته، بفهمسته کی خیلی وخته به اَ حال دوچاره. از اون وَورسه: «آیا خوأیی کی تی سلامتی‌یه به دست بأوری؟»   
\p
\v 7 مردِ علیل بوگفته: «ای سرور، کسی‌یه نأرم کی وختی آب به حرکت اَیه، مره حوضه میأن تَوَدَه. تا اَیم خودمه به اویه فَرسأنم، کسه دیگری پیشتر از من آبه میأن دکفه.»   
\p
\v 8 عیسی اونه بوگفته: «ویریز، تی جایه جمعَ کون و راه بوشو.»   
\p
\v 9 او مرد در هو لحظه خو سلامتی‌یه به دست بأورده و خو جایه جمعَ کوده و شروع بوکوده به راه شوئون.  
\p او روز، شَبّات \f * \fr 5.9 \ft شَبّات، روزِ هفتمه هفته‌یه کی او روزِ میأن یهودیأن کار نوکونیدی و تمامه روزَ عبادت و استراحت کونیدی. \f* بو.  
\v 10 پس حاکمأنه یهود او مردی‌یه کی شفا پیدا بوکوده بو، بوگفتیدی: «امروز روزِ شَبّاته و تو اجازه نأری کی تی جایه جمعَ کونی!»   
\p
\v 11 اون جواب بده: «اونی کی مره شفا بده مره بوگفته، ‹تی جایه جمعَ کون و راه بوشو.›»   
\p
\v 12 از اون وَورسه‌ییدی: «اونی کی تره بوگفته تی جایه جمعَ کون و راه بوشو، کی بو؟»   
\p
\v 13 امّا او مردی کی شفا پیدا بوکوده بو، نأنستی کی اون کی ایسه. چونکی عیسی جمعیته میأن ناپدیده بوسته بو.   
\p
\v 14 مدتی بعد، عیسی او مردَ معبده میأن پیدا بوکوده و اونه بوگفته: «الأن کی تی سلامتی‌یه پیدا بوکودی، دِ گناه نوکون تا از اونی کی بی بدتره نیبی.»  
\v 15 او مرد بوشو و یهودیأنه بوگفته: «اونی کی مره شفا بده، عیسایه!»   
\s1 قدرت و اقتداره خدا پسر  
\p
\v 16 به اَ دلیل بو کی حاکمأنه یهود عیسایه آزار دَییدی، چونکی در روزِ شَبّات دست به اَجور کارأن زه‌یی.  
\v 17 عیسی جواب بده: «می پئر هنوز کار کونه، منم کار کونم.»  
\v 18 به اَ خاطر یهودیأن بیشتر از قبل خوأستیدی کی اونه بوکوشید، چونکی نه تنها روزِ شَبّاته ایشکنه‌یی، بلکی خدایه خو پئر دوخوأدی و خودشه خدا اَمره برابر دأنستی.   
\p
\v 19 عیسی جواب بده: «آمین، آمین، شمره گم کی پسر از خودش هیچ کاری نتأنه انجام بده مگر او کارأیی کی پئر انجام دهه، پسر بیدینه. چونکی هرچی کی پئر کونه، پسرم کونه.  
\v 20 پئر پسره دوست دأره و هر کاری کی کونه، اونه نیشأن دهه و کارأیی از اَن بزرگترم در آینده نیشأن دهه تا شومأن از تعجب مات بمأنید.  
\v 21 هوطو کی پئر مُرده‌یأنه ویریزأنه و اوشأنه زندَه کونه، پسر هم هر کسی‌یه کی بخوأیه، زندَه کونه.  
\v 22 پئر کسی‌یه داوری نوکونه، بلکی تمامه کاره داوری‌یه به پسر بیسپرده.  
\v 23 تا همه پسره احترام بوکونید، هوطو کی پئره احترام نهیدی. کسی کی پسره احترام نوکونه، به پئری کی اونه اوسه کوده، احترام ننَه.  
\v 24 آمین، آمین، شمره گم هر کی می کلامه گوش بده و به کسی کی مره اوسه کوده ایمأن بأوره، زندگی‌یه اَبدی دأره و محکومه نیبه، بلکی از مرگ به زندگی‌یه اَبدی انتقال پیدا کونه.  
\v 25 آمین، آمین، شمره گم، زمانی فَرسه، بلکی الأنه کی مُرده‌یأن، خدا پسره صدایه ایشنَویدی و هر کی گوش بده، زندَه به.  
\v 26 چونکی هوطو کی پئر در خودش حیات دأره، خو پسرم عطا بوکوده کی در خودش حیات بدأره.  
\v 27 و اونه اَ قدرته ببخشه کی داوری بوکونه، چونکی انسانه پسره.  
\v 28 از اَ حرفأن تعجب نوکونید، چونکی زمانی فَرسه کی همه‌یه اوشأنی کی در قبریدی، اونه صدایه ایشنَویدی و بیرون اَییدی.  
\v 29 اوشأنی کی خوبی بوکوده بید، برای قیامتی کی خو دونبال زندگی اَبدی‌یه دأره. اوشأنی کی بدی بوکوده بید، برای قیامتی کی خو دونبال مکافاتَه دأره.  
\v 30 من از خودم هیچ کاری نتأنم بوکونم، بلکی از اونچی کی ایشنَوم، داوری کونم و می داوری‌یم عادلأنه‌یه، چونکی به دونبال انجامه می خوأسته‌یأن نی‌یم، بلکی خوأیم خوأسته‌یه اونی‌یه کی مره اوسه کوده انجام بدَم.   
\s1 عیسی شاهدأن  
\p
\v 31 «اگر خودم مره شهادت بدَم، می شهادت اعتبار نأره.  
\v 32 امّا کسی دیگری ایسه کی مره شهادت دهه و دأنم کی اونه شهادت در مورده من معتبره.  
\v 33 البته شومأن کسأنی‌یه یحیی ورجه اوسه کودیدی و اون بر حقیقت شهادت بده.  
\v 34 نه بخاطره اَنکی من انسانه شهادته قبول بوکونم، بلکی اَ حرفأنه زنم تا نجات پیدا بوکونید.  
\v 35 یحیی چراغی بو روشن و نورانی و شومأن خوأستیدی کی زمانی اونه نوره میأن خوش بیبید.  
\v 36 امّا من شهادتی محکمتر از یحیی شهادت دأرم، چونکی پئر کارأنی مره بیسپرده تا به کمال برسأنم، یعنی اَ کارأنی کی کونم، مره شهادت دهه کی مره پئر اوسه کوده.  
\v 37 هو پئری کی مره اوسه کوده، خودش مره شهادت دهه. شومأن هرگز اونه صدایه نیشنَوستیدی و اونه رویه نیده‌ییدی.  
\v 38 اونه کلامه شیمی دیله میأن نأریدی. چونکی به اونی کی اونه اوسه کوده ایمأن نأریدی.  
\v 39 هَه کیتابه مقدّسه به دقّت خوأنیدی، چونکی فکر کونیدی توسطه اون زندگی‌یه اَبدی دأریدی، در حالی کی هَه کیتابأنه کی مره شهادت دهه.  
\v 40 امّا نخوأییدی می ورجه بأیید تا زندگی‌یه اَبدی پیدا بوکونید.   
\p
\v 41 «جلاله از آدمیأن قبول نوکونم.  
\v 42 امّا شمره شنأسم کی خدا محبته شیمی دیله دورون نأریدی.  
\v 43 من به نامِ می پئر بَموم، امّا شومأن مره قبول نوکونیدی. امّا اگر کسی دیگری به نامِ خودش بأیه، شومأن اونه قبول کونیدی.  
\v 44 چوطو تأنیدی ایمأن بأورید، در حالی کی همدیگره جلال دیهیدی. امّا به دونباله جلالی کی از خدایه یکتا ایسه، نی‌ییدی؟  
\v 45 فکر نوکونید اون منم کی پئره ورجه شمره متهم کونم. شیمی متهم‌کوننده موسایه، هونی کی شومأن به اون امید دَوَستیدی.  
\v 46 اگر موسایه قبول دأشتیدی، مرم قبول کودیدی، چونکی اون درباره‌یه من بینیویشته بو.  
\v 47 امّا اگر اونه نیویشته‌یأنه باور نأریدی، چوطو می حرفأنه قبول کونیدی؟»   
\c 6  
\s1 زیاده بوستنه پنج‌تأ نان و دوتأ ماهی  
\p
\v 1 مدتی بعد، عیسی به او طرفه دریاچه جلیل کی هو دریاچه تیبِریه بو، بوشو.  
\v 2 گرویه زیادی اونه دونبالسر بوشوییدی چونکی معجزاتی کی با شفایه مریضأن انجام بده بو، بیده بید.  
\v 3 پس عیسی تپه جور بوشو و خو شاگردأنه اَمره اویه بینیشته.  
\v 4 (یهودیأنه عیده پِسَخ نزدیک بو.)  
\v 5 وختی عیسی نیگاه بوکوده، بیده کی گرویه زیادی اونه طرف اَمون دریدی، فیلیپُسه بوگفته: «از کویه نان بیهینیم تا اَشأن بوخورید؟»  
\v 6 عیسی اَ حرفه بوگفته چون خوأستی اونه امتحان بوکونه و خودش بهتر دأنستی کی چی بوکونه.   
\p
\v 7 فیلیپُس جواب بده: «دیویست دینار نانم اوشأنه سئره نوکونه، حتی اگر هر کدامه اوشأن ایپچه نان بوخورید.» (دیویست دینار، او موقع حدوده هشت ماهه کارگره مزد بو.)   
\p
\v 8 ایتأ دیگر از شاگردأن به نامِ آندریاس کی شَمعونِ پِطرُسِ برأر بو، بوگفته:  
\v 9 «ایتأ پسر بچه ایسَه کی پنج‌تأ نانه جو و دوتأ ماهی دأره، امّا اَن، چوطو اَ گرویه سئره کونه؟»   
\p
\v 10 عیسی بوگفته: «مردمه بینیشأنید.» اویه سبزه‌زار زیاد بو. او جمعیت میأن پنج هزار نفر فقط مرد بید.  
\v 11 اون وخت عیسی نانه فیگیفته و شکرگزاری بوکوده و اونه شاگردأن، بین اوشأنی کی نیشته بید، تقسیم بوکودیدی، و ماهی‌یأنه اَمره‌یم هو کاره بوکوده، به اندازه‌یی کی خوأستیدی اوشأنه فده.  
\v 12 وختی سئره بوستیدی، خو شاگردأنه بوگفته: «هر چی زیاد بَمو خورده‌نانأنه جمعَ کونید تا چیزی از بین نشه.»  
\v 13 پس اوشأنه جمعَ کودیدی و از باقی‌مانده‌یه او پنج‌تأ نانه جو کی جماعت بوخورده بید، دوازده‌تأ زنبیل پُره بوسته!   
\p
\v 14 مردم با دِئنه اَ معجزه کی از عیسی ظاهره بوسته، بوگفتیدی: «راستی، راستی کی اون هو پیامبری ایسه کی بأیستی به جهان بَمو بی.»  
\v 15 عیسی وختی بفهمسته کی اوشأن تصمیم دأریدی اونه به زور پادشاه بوکونید، او جایه ترکه کوده و تنهایی به کوه بوشو.   
\s1 عیسی آبه رو راه شه  
\p
\v 16 غروب دم، اونه شاگردأن به سمته دریاچه بیزیر بَموییدی.  
\v 17 هوا تاریک بو و عیسی هنوز اوشأنه اَمره نِیسه بو، اوشأن سوارِ قایق بوبوستیدی و به او طرفه دریاچه، به طرفه کَفَرناحوم بوشوییدی.  
\v 18 امّا در اَ موقع، دریاچه بخاطره وزشه باده سختی کی اَمویی به تلاطم دکفته.  
\v 19 وختی به اندازه پنج یا شیش کیلومتر پارو بزه بید، عیسایه بیده‌ییدی کی آبه رو راه شوئون دره و قایقه نزدیکه بوستن دره. پس هراسأنه بوستیدی.  
\v 20 امّا عیسی اوشأنه بوگفته: «منم، نترسید!»  
\v 21 اون وخت خوأستیدی اونه سوارِ قایق بوکونید، کی قایق هو لحظه به مقصد فَرسه.   
\s1 عیسی، نانه حیاته  
\p
\v 22 روزِ بعد، جماعتی کی او طرفه دریاچه ایسه بید، بفهمستیدی کی بجز ایتأ قایق، قایقه دیگری اویه ننَه بو و دأنستیدی کی عیسی خو شاگردأنه اَمره اونه سوارَ نوبوسته بو، بلکی شاگردأن تنهایی بوشو بید.  
\v 23 اون وخت قایقأنه دیگری از تیبِریه بَموییدی و نزدیکه جایی فَرسه‌ییدی کی اوشأن بعد از شکرگزاریه عیسی، نان بوخورده بید.  
\v 24 وختی مردم بفهمستیدی کی نه عیسی اویه ایسه و نه اونه شاگردأن، او قایقأنه سوارَ بوستیدی و به دونباله عیسی به کَفَرناحوم بوشوییدی.   
\p
\v 25 وختی اونه او طرفه دریاچه پیدا بوکودید، اونه وَورسه‌ییدی: «ای اوستاد، کِـی اَیه بَمویی؟»   
\p
\v 26 عیسی جواب بده: «آمین، آمین، شمره گم، می دونبال گردیدی نه به دلیله معجزاتی کی بیده‌ییدی، بلکی بخاطره او نانی کی بوخوردیدی و سئره بوستیدی.  
\v 27 کار بوکونید امّا نه خوراکه فانی‌ره، برای خوراکی کی تا زندگی‌یه اَبدی باقی‌یه، خوراکی کی انسانه پسر شمره فده. چونکی بر پسره کی خدایه پئر، مُهرِ تأیید بزه.»   
\p
\v 28 اون وخت از اون وَورسه‌ییدی: «چی بوکونیم تا کارأیی کی خدا خوأیه انجام بدیم؟»   
\p
\v 29 عیسی در جواب بوگفته: «کاری کی خدا خوأسته‌یه اَنه کی به او کسی کی اون اوسه کوده ایمأن بأورید.»   
\p
\v 30 بوگفتیدی: «چی معجزه‌یی اَمَره نیشأن دیهی تا با اونه دِئن، تره ایمأن بأوریم؟ چی کونی؟  
\v 31 اَمی پئرأن بیابانه میأنی مَنّایه \f * \fr 6.31 \ft نان کی خدا برای قومه اسرائیل بیابانه میأن فده. تورات، کیتابه خروج، بابه ۱۶، آیه ۴. \f* کی خوراکه آسمانی بو، بوخوردیدی هوطو کی بینیویشته نَهه: ‹اون از آسمان اوشأنه نان فده تا بوخورید.›»   
\p
\v 32 عیسی جواب بده: «آمین، آمین، شمره گم، موسی نبو کی از آسمان او نانه شمره فده، بلکی می پئر بو کی نانه حقیقی‌یه از آسمان شمره فده.  
\v 33 چونکی خدا نان، کسی‌یه کی از آسمان نازله به و به دنیا حیات بخشه.»   
\p
\v 34 پس بوگفتیدی: «اَ نانه برای همیشه اَمَره فدن.»  
\v 35 عیسی اوشأنه بوگفته: «من نانه حیات ایسم، هر کی می ورجه بأیه، هرگز گرسنه نیبه و هر کی مره ایمأن بأوره، هرگز تشنه نیبه.  
\v 36 ولی هوطو کی شمره بوگفتم، هرچند کی مره بیده‌ییدی، امّا ایمأن نأوریدی.  
\v 37 هر کسی کی پئر، مره ببخشه، می ورجه اَیه و هر کی می ورجه بأیه، هیچ وخت اونه از خودم دوره نوکونم.  
\v 38 چونکی از آسمان بیزیر نَموم کی می خوأسته‌یه عمل بوکونم، بلکی بَموم تا خوأسته‌یه کسی‌یه کی مره اوسه کوده انجام بدَم.  
\v 39 و خوأسته‌یه کسی کی مره اوسه کوده اَنه کی کسأنی‌یه کی اون مره ببخشه، هیچ‌کدامه از دست ندم، بلکی اوشأنه در روزِ آخر ویریزأنم.  
\v 40 و می پئره خوأسته اَنه کی هر کسی کی پسره بیدینه به اون ایمأن بأوره، از زندگی‌یه اَبدی برخوردأره به، و من اونه در روزِ آخر ویریزأنم.»   
\p
\v 41 اون وخت یهودیأن درباره‌یه اون شروع به همهمه بوکودیدی، چونکی بوگفته بو: «من او نان ایسم کی، از آسمان نازله بوسته.»  
\v 42 اوشأن گفتیدی: «مگر اَ مرد، عیسی، یوسفه پسر نی‌یه کی اونه پئر و ماره اَمأن شنأسیم؟ پس چوطو گه کی ‹از آسمان نازله بوستم›؟»   
\p
\v 43 عیسی در جواب بوگفته: «همدیگره اَمره همهمه نوکونید!  
\v 44 هیچکس نتأنه می ورجه بأیه مگر، پئری کی مره اوسه کوده اونه جذب بوکونه. من اونه در روزِ آخر ویریزأنم.  
\v 45 در کیتابه انبیا بَمو کی: ‹همه از خدا تعلیم گیریدی.› \x * \xo 6.45 \xt تورات، کیتابه اِشَعْیا، بابه ۵۴، آیه ۱۳. \x* پس هر کی از خدا بیشنَوه و از اون تعلیم بیگیره، می ورجه اَیه.  
\v 46 هیچ کس پئره نیده، مگر اون کسی کی از طرفه خدا بَمو؛ اون، پئره بیده.  
\v 47 آمین، آمین، شمره گم، هر کی ایمأن بأوره، از زندگی‌یه اَبدی برخوردأره.  
\v 48 من نانه زندگی ایسم.  
\v 49 شیمی پئرأن بیابانه میأن مَنّایه بوخوردیدی، ولی به هر حال بمَردیدی.  
\v 50 امّا نانی کی از آسمان نازله به، هر کی از اون بوخوره، نیمیره.  
\v 51 اون نانه زنده من ایسم کی از آسمان نازله بوسته. هر کی اَ نانه بوخوره، تا اَبد زنده مأنه. نانی کی من برای حیاته دنیا بخشم، می بدنه.»   
\p
\v 52 پس بحثه تندی حاکمأنه یهوده میأن به وجود بَمو کی: «اَ مرد چوطو تأنه خو بدنه اَمَره فده تا بوخوریم؟»   
\p
\v 53 عیسی اوشأنه بوگفته: «آمین، آمین، شمره گم کی تا انسانه پسره بدنه نوخورید و اونه خونه ننوشید، در خودتأن زندگی اَبدی نأریدی.  
\v 54 هر کی می بدنه بوخوره و می خونه بنوشه، زندگی‌یه اَبدی دأره و من در روزِ آخر اونه ویریزأنم.  
\v 55 چونکی می بدن خوراکه حقیقی و می خون نوشیدنی‌یه حقیقی‌یه.  
\v 56 کسی کی می بدنه خوره و می خونه نوشه در من ساکنه به و منم در اون ساکنه بم.  
\v 57 هوطو کی پئره زنده مره اوسه کوده منم به می پئر زنده‌یم، اونی کی مره خوره، توسطه من زنده مأنه.  
\v 58 اَن، نانی‌یه کی از آسمان نازله بوسته، نه مثله اونچی کی شیمی پئرأن بوخوردیدی و به هر حال بمَردیدی؛ بلکی هر کی از اَ نان بوخوره، تا اَبد زنده مأنه.»  
\v 59 عیسی اَ حرفأنه زمانی بوگفته کی کَفَرناحومه کنیسه میأن تعلیم دَیی.   
\s1 عیسی شاگردأن عیسایه ترکه کودید  
\p
\v 60 خیلی از اونه شاگردأن با ایشنَوستنه اَ حرفأن بوگفتیدی: «اَ تعلیم خیلی سخته، کی تأنه اونه قبول بوکونه؟»   
\p
\v 61 عیسی دأنستی کی اونه شاگردأن درباره‌یه اونه حرفأن همهمه کودن دریدی. اوشأنه بوگفته: «آیا اَن باعثه شیمی انحراف به؟  
\v 62 پس اگر انسانه پسره بیدینید کی به خو جایه اوّل صعود بوکونه، چی کونیدی؟  
\v 63 روحه کی زندَه کونه، جسم فایده‌یی نأره. حرفأنی کی من شمره بوگفتم، روح و زندگی‌یه.  
\v 64 امّا بعضی از شومأن ایسه‌ییدی کی ایمأن نأوریدی.» عیسی از اوّل دأنستی کی چی کسأنی ایمأن نأوریدی و کی‌یه کی اونه به دشمن تسلیم کونه.  
\v 65 بعد از اون، بوگفته: «هَنه وستی شمره بوگفتم کی هیچکس نتأنه می ورجه بأیه، مگر اَنکی از پئره طرف به اون عطا بوبوسته بی.»   
\p
\v 66 در اَ زمان خیلی از اونه شاگردأن وأگردستیدی و دِ اونه همرأهی نوکودیدی.  
\v 67 پس عیسی او دوازده شاگرده کی قبلاً انتخاب بوکوده بو بوگفته: «آیا شومأنم خوأییدی بیشید؟»   
\p
\v 68 شَمعونِ پِطرُس جواب بده: «ای سرور، کی ورجه بیشیم؟ کلماته زندگی‌یه اَبدی تی ورجه نَهه.  
\v 69 و اَمأن ایمأن بأوردیم و دأنیم کی تویی او قدّوس از پیشه خدا.»   
\p
\v 70 عیسی اوشأنه جواب بده: «مگر شومأن دوازده نفره من انتخاب نوکودم؟ با اَ حال ایتأ از شومأن از ابلیسه.»  
\v 71 اون به یهودا، شَمعونِ اِسْخَریوطی پسر، اشاره کودی، چونکی ایتأ از او دوازده نفر بو کی بعد از مدتی عیسایه به دشمن تسلیم کودی.   
\c 7  
\s1 عیسی عیده خیمه‌یأن شوئون دره  
\p
\v 1 از اون به بعد عیسی جلیلِ میأن گردستی، نخوأستی یهودیه میأن بِیسه، چونکی حاکمأنه یهود خوأستیدی اونه بوکوشید.  
\v 2 وختی عیده خیمه‌یأن کی ایتأ از یهودیأنه عید بو، نزدیکه بوسته،  
\v 3 عیسی برأرأن اونه بوگفتیدی: «اَیه ترکه کون و به یهودیه بوشو، تا تی هوادارأن کارأیی کی کونی، بیدینید.  
\v 4 چونکی هر کی خوأیه شنأخته ببه، خلوتی کار نوکونه. تو کی اَ کارأنه کونی، دنیایه نیشأن بدَن.»  
\v 5 چونکی حتی اونه برأرأنم اونه ایمأن نأورده بید.   
\p
\v 6 پس عیسی اوشأنه بوگفته: «می وخت هنوز فَنرسه، امّا شیمی‌ره هر وختی مناسبه.  
\v 7 دنیا نتأنه از شومأن متنفر ببه، امّا از من نفرت دأره، چونکی من شهادت دهم کی اونه کارأن، بده.  
\v 8 شومأن خودتأن به عید بیشید. من الأن نأیم، چونکی می وخت هنوز فَنرسه.»  
\v 9 اَنه بوگفته و جلیلِ میأن بِیسه.   
\p
\v 10 امّا بعد از اونکی اونه برأرأن به عید بوشوییدی، خودشم بوشو، امّا نه آشکارا بلکی خلوتی.  
\v 11 پس حاکمأنه یهود، عیده موقع اونه دونبال بیدی و وَورسه‌ییدی: «او مرد کویه ایسه؟»  
\v 12 درباره‌یه اون مردمه میأن همهمه زیاد بو. تعدادی گفتیدی: «مردِ خوبی ایسه» و تعداده دیگرم گفتیدی: «نه، بلکی مردمه گمراهه کونه.»  
\v 13 چون از حاکمأنه یهود ترس دأشتیدی، هیچکس درباره‌یه اون آشکارا حرف نزه‌یی.   
\s1 عیسی خانه‌یه خدا میأن تعلیم دهه  
\p
\v 14 چون نیمی از عید بوگذشته بو، عیسی به صحنِ معبد بَمو و شروع به تعلیم بوکوده.  
\v 15 یهودیأن تعجب بوکودیدی و وَورسه‌ییدی: «اَ مرد کی درسه الهی نخوأنده، چوطو تأنه اَنقدر معلومات بدأره؟»   
\p
\v 16 عیسی در اوشأنه جواب بوگفته: «می تعالیم از من نی‌یه، بلکی از کسی ایسه کی مره اوسه کوده.  
\v 17 اگر کسی براستی بخوأیه کی اونه اراده‌یه انجام بده، فهمه کی اَ تعالیم از خدایه، یا اَن کی من از خودم گم.  
\v 18 اونی کی از خودش گه، به دونبال اَنه کی خودشه جلال بده، امّا اونی کی خوأیه کسی‌یه کی اونه اوسه کوده جلال بده، راستگه و در اون هیچ ناراستی‌یی ننَه.  
\v 19 آیا موسی شریعته شمره فنده؟ امّا هیچ‌کدام از شومأن به اون عمل نوکونیدی. پس چره خوأییدی مره بوکوشید؟»   
\p
\v 20 مردم جواب بدَییدی: «تره دیوبزه، کی‌یه کی تی کوشتنه دونبال ببه؟»   
\p
\v 21 عیسی در جوابه اوشأن بوگفته: «من ایتأ معجزه بوکودم و شومأن همه‌تأ از اون ماته بوستیدی.  
\v 22 موسی حکمه ختنه‌یه شمره فده - البته اَن نه از طرفه موسی بو، بلکی از طرفه پئرأنه قوم بو - و طبقِ اَ حکم، شومأن شیمی پسرأنه در روزِ شَبّات ختنه کونیدی.  
\v 23 پس اگر انسان در روزِ شَبّات ختنه به تا موسی شریعت نشکفه، چره عصبانی بیدی از اَنکی تمامه بدنه انسانی‌یه در روزِ شَبّات سلامتی ببخشم؟  
\v 24 سرسری داوری نوکونید، بلکی به حق داوری بوکونید.»   
\s1 مردمه واکنش نسبت به عیسی حرفأن  
\p
\v 25 پس بعضی از اهالی‌یه اورشلیم بوگفتیدی: «آیا اَن هونی نی‌یه کی قصد دأریدی اونه بوکوشید؟  
\v 26 بیدینید چوطو آشکارا حرف زنه و اونه هیچی نیگیدی! آیا امکان دأره کی حاکمأنه قوم اَ حقیقته بفهمستیدی کی اون هو مسیحه؟  
\v 27 اَمأن دأنیم کی اَ مرد از کویه بَمو، وختی کی مسیح ظهور بوکونه، کسی نأنه کی از کویه اَیه.»   
\p
\v 28 اون وخت عیسی موقعه تعلیم معبده میأنی، با صدایه بلند بوگفته: «مره شنأسیدی و دأنیدی کی کویه‌شینم، امّا من از طرفه خودم نَموم؛ اونی کی مره اوسه کوده، حقِ و شومأن اونه نشنأسیدی.  
\v 29 امّا من اونه شنأسم، چونکی من از اونم و اون مره اوسه کوده.»  
\v 30 پس خوأستیدی کی اونه گرفتاره کونید، امّا هیچکی اونه دست درازه نوکوده، چونکی اونه وخت فَنرسه بو.  
\v 31 به هر حال خیلی از مردم اونه ایمأن بأوردیدی. اوشأن گفتیدی کی: «آیا وختی مسیح بأیه، از اَ مرد بیشتر معجزه کونه؟»   
\p
\v 32 امّا فَریسیأنه گوش فَرسه کی مردم درباره‌یه عیسی اَجور همهمه کونیدی. پس سرأنه کاهنأن و فَریسیأن، قراولأنه معبده اوسه کودیدی تا اونه گرفتاره کونید.  
\v 33 اون وخت عیسی بوگفته: «زمانه کمی شیمی اَمره ایسَم، از اَن به بعد او کسی ورجه شم کی مره اوسه کوده.  
\v 34 می دونبال گردیدی، امّا پیدا نوکونیدی، و جایی کی من شم، شومأن نتأنیدی بأیید.»   
\p
\v 35 پس یهودیأن همدیگره گفتیدی کی: «اَ مرد کویه شه کی اَمأن نتأنیم اونه پیدا بوکونیم؟ نوکونه خوأیه بشه یهودیأنی ورجه کی بین یونانیأن پراکنده‌ییدی و یونانیأنه تعلیم بده.  
\v 36 اونه منظور چی بو کی بوگفته ‹می دونبال گردیدی، امّا نتأنیدی پیدا بوکونید و جایی کی من ایسم، شومأن نتأنیدی بأیید؟›»   
\s1 عیسی حرفأن در آخرین روزِ عید  
\p
\v 37 روزِ آخر کی روزِ بزرگه عید بو، عیسی بِیسه و با صدایه بلند بوگفته: «هر کی تشنه‌یه، می ورجه بأیه و آب بوخوره.  
\v 38 هر کی به من ایمأن بأوره، هوطو کی کیتابه مقدّس گه، از اونه وجود چشمه‌یأنه آبه زنده جاری به.»  
\v 39 اَ حرفه درباره‌یه روح بوگفته کی کسأنی کی به اون ایمأن بأورید، او روحه پیدا کونیدی. چونکی روح هنوز عطا نوبوسته بو، و عیسی هنوز جلال پیدا نوکوده بو.   
\s1 مردمه اختلاف در مورده عیسی  
\p
\v 40 بعضی از مردم با ایشنَوستنه اَ حرفأن گفتیدی کی: «راستی، راستی کی اَ مرد هو پیامبره موعوده.»  
\v 41 دیگرأن گفتیدی کی: «اون مسیحه!» امّا گروهی دیگر وَورسه‌ییدی: «مگر مسیح از جلیل ظهور کونه؟  
\v 42 مگر کیتابه مقدّس نوگفته کی مسیح از نسله داووده و از بیت‌لِحِم، دِهی کی داوود در اون زندگی کودی، ظهور کونه؟»  
\v 43 پس بخاطره عیسی مردمه میأنی اختلاف دکفته.  
\v 44 تعدادی خوأستیدی کی اونه گرفتاره کونید، امّا هیچکی اونه دست درازه نوکوده.   
\s1 بی‌ایمأنی رهبرأنه دین  
\p
\v 45 پس قراولأنه معبد وأگردستیدی سرأنه کاهنأن و فَریسیأنه ورجه. فَریسیأن و سرأنه کاهنأن از اوشأن وَورسه‌ییدی: «چره اونه نأوردیدی؟»   
\p
\v 46 قراولأن جواب بدَییدی: «تا الأن مثله اَ مرد کسی حرف نزه.»   
\p
\v 47 پس فَریسیأن بوگفتیدی: «مگر شومأنم فریب بوخوردیدی؟  
\v 48 آیا از حاکمأن یا فَریسیأن کسی ایسه کی اونه ایمأن بأورده بی؟  
\v 49 البته کی نه! امّا اَ مردمه نادان کی از شریعت چیزی نأنیدی، ملعونیدی.»   
\p
\v 50 نیقودیموس کی پیشتر عیسی ورجه بوشو بو و ایتأ از فَریسیأن بو، بوگفته:  
\v 51 «آیا اَمی شریعت کسی‌یه محکوم کونه، بدونه اَنکی اوّل اونه حرفه بیشنَوه و بدأنه کی چی بوکوده؟»   
\p
\v 52 در جواب بوگفتیدی: «مگر تونم جلیلی‌یی؟ تحقیق بوکون و بیدین کی هیچ پیامبری از جلیل وینیریزه!»  
\v 53 بعد از اون، هر کی خودشه خانه بوشو.   
\c 8  
\m
\v 1 امّا عیسی بوشو به کوهه زیتون.   
\s1 بخششه زنه زناکار  
\p
\v 2 وخته سحر عیسی بازم به صحنِ معبد بَمو. در اویه مردم همه اونه دور جمعَ بوستیدی عیسی بینیشته و اوشأنه تعلیم بده.  
\v 3 در اَ وخت علمایه دین و فَریسیأن، زنی‌یه کی در حینه زنا بیگیفته بید، بأوردیدی و اونه مردمه میأن بدأشتیدی.   
\p
\v 4 عیسایه بوگفتیدی: «اوستاد، اَ زنه در حینه زنا بیگیفتیدی.  
\v 5 موسی در شریعت، اَمَره حکم بوکوده کی اَجور زنأکأن سنگسار بیبید. امّا تو چی گی؟»   
\p
\v 6 اَنه بوگفتیدی تا اونه امتحان بوکونید تا ایتأ بهانه‌یی بدأرید و اونه محکوم بوکونید. امّا عیسی خو سره بیزیر تَوَدَه و خو انگوشته اَمره زمینه رو نیویشتی.  
\v 7 امّا چونکی اوشأن بازم از اون سؤال کودیدی، عیسی خو سره بلنده کوده و اوشأنه بوگفته: «از شیمی میأنی هر کسی کی گناهی نأره، اوّلین سنگه اونه بزنه.»  
\v 8 بازم خو سره بیزیر تَوَدَه و زمینه رو نیویشتی.   
\p
\v 9 با ایشنَوستن اَ حرف اوشأن، ایتأ ایتأ از بزرگترأن شروع بوکودیدی و از اویه بوشوییدی و عیسی اویه او زنه اَمره تنها بِیسه.  
\v 10 اون وخت عیسی خو سره بلنده کوده و اونه بوگفته: «ای زن، اوشأن کویه ایسه‌ییدی؟ هیچکس تره محکوم نوکوده؟»   
\p
\v 11 جواب بده: «هیچکس، ای سرور.»  
\p عیسی اونه بوگفته: «منم تره محکوم نوکونم. بوشو، و دِ گناه نوکون.»   
\s1 عیسی نوره دنیایه  
\p
\v 12 پس عیسی ایبارِ دیگر مردمه اَمره حرف بزه و بفرمأسته: «من نوره دنیا ایسم، هر کی از من پیروی بوکونه، هرگز در تاریکی راه نیشه، بلکی از نوره زندگی برخوردأره به.»   
\p
\v 13 پس فَریسیأن اونه بوگفتیدی: «تو خودت، خودته‌ره شهادت دیهی، پس تی شهادت معتبر نی‌یه.»   
\p
\v 14 عیسی در جوابه اوشأن بوگفته: «هرچند کی من خودم، خودمه‌ره شهادت دهم، ولی می شهادت معتبره، چونکی دأنم از کویه بَموم و به کویه شم، امّا شومأن نأنیدی کی من از کویه بَموم و به کویه شم.  
\v 15 شومأن فکره انسانی اَمره داوری کونیدی، امّا من کسی‌ره داوری نوکونم.  
\v 16 ولی اگر داوری‌یم بوکونم، می داوری درسته، چونکی تنها نی‌یم، بلکی پئری کی مره اوسه کوده، می اَمره‌یه.  
\v 17 شیمی شریعته دورون بینیویشته بو کی شهادته دوتأ شاهد معتبره.  
\v 18 من خودم مره شهادت دهم و می پئرم کی مره اوسه کوده، مره شهادت دهه.»   
\p
\v 19 اون وخت از عیسی وَورسه‌ییدی: «تی پئر کویه ایسه؟»  
\p عیسی جواب بده: «نه مره شنأسیدی نه می پئره. اگر مره شنأختیدی می پئرم شنأختیدی.»  
\v 20 عیسی اَ حرفأنه زمانی کی در بیت‌الماله معبد تعلیم دَیی، بیان بوکوده، امّا هیچکس اونه دستگیر نوکوده چونکی اونه وخت هنوز فَنرسه بو.   
\s1 عیسی حرفأن درباره‌یه خودشه مرگ  
\p
\v 21 عیسی ایدفعه دیگر اوشأنه بوگفته: «من شم و شومأن می دونبال گردیدی و شیمی گناهأنه میأن میریدی. او جایی کی من شم، شومأن نتأنید بأیید.»   
\p
\v 22 پس یهودیأن بوگفتیدی: «آیا تصمیم دأره کی خوره بوکوشه کی اَطو گه: ‹او جایی کی من شم، شومأن نتأنید بأیید›؟»   
\p
\v 23 عیسی اَشأنه بوگفته: «شومأن از بیزیریدی و من از بوجور. شومأن از اَ دنیایید ولی من از اَ دنیا نی‌یم.  
\v 24 شمره بوگفتم کی شیمی گناهأنه میأن میریدی. چون اگر ایمأن نأورید کی من ایسم کی ایسم، \f * \fr 8.24 \ft عبارت «من ایسم کی ایسم» خدا نامِ‌ره در تورات، کیتابه خروج، بابه ۳، آیه ۱۴ بینیویشته بوبوسته: «خدا موسی‌یه بوگفته: ‹ایسم اونی کی ایسم› و بوگفته بنی اسرائیله اَطو بوگو: ‹ایسم مره شیمی ورجه اوسه کوده›». و تورات، کیتابه اِشَعْیا، بابه ۴۳، آیه ۱۰ بینیویشته بوبوسته: «خداوند گه: ‹شومأن می شاهدأن ایسیدی و می بنده کی اونه انتخاب بوکودم تا بدأنید، به من ایمأن بأورید و بفهمید کی من اون ایسم و پیش از من خدایی وجود نأشتی و بعد از منم خدایی وجود نأره.›» هَطو در بابه ۸ آیاته ۲۸ و ۵۸ و بابه ۱۳ آیه ۱۹.\f* در شیمی گناهأن میریدی.»   
\p
\v 25 از اون وَورسه‌ییدی: «تو کی ایسی؟»  
\p عیسی جواب بده: «هونی کی از اوّل شمره بوگفتم.  
\v 26 خیلی چیزأن درباره‌یه شومأن دأرم کی شمره بگم و شمره محکومه کونم، امّا اونی کی مره اوسه کوده، حقِ و من اونچی‌یه کی از اون بیشنَوستم، به دنیا بازم گم.»  
\v 27 اوشأن نفهمستیدی کی از پئر اوشأنه‌ره گفتن دره.   
\p
\v 28 پس عیسی اوشأنه بوگفته: «اون وختی کی انسانه پسره بلنده کودیدی، فهمیدی کی من ایسم \f * \fr 8.28 \ft به آیه ۲۴ نیگاه بوکونید. \f* و از خودم کاری نوکونم، بلکی فقط اونچی‌یه گم کی می پئر مره یاد بدَه.  
\v 29 اون کی مره اوسه کوده، می اَمره‌یه. اون مره تنها ننَه، چونکی من همیشه اون چیزی‌یه کی اونه خوشحاله کونه، انجام دهم.»  
\v 30 اَ حرفأنه اَمره خیلی‌یأن اونه ایمأن بأوردیدی.   
\s1 آزادی حقیقی  
\p
\v 31 پس عیسی به یهودیأنی کی اونه ایمأن بأورده بید، بوگفته: «اگر می کلامه میأن بِیسید، حقیقتاً می شاگرد بیدی.  
\v 32 و حقیقته شنأسیدی و حقیقت شمره آزاده کونه.»   
\p
\v 33 اونه جواب بدَییدی: «اَمأن ابراهیمه زأکأنیم و هیچ وخت غلامه کسی نوبوستیم. پس چوطویی گی، کی آزاده بیمی؟»   
\p
\v 34 عیسی جواب بده: «آمین، آمین، شمره گم، هر کسی کی گناه کونه، غلامه گناهه!  
\v 35 غلام هیچ وخت اهله خانه میأن جایه همیشگی نأره، امّا پسره همیشه جا نَهه.  
\v 36 پس اگر پسر شمره آزاده کونه، حقیقتاً آزاده بیدی!   
\s1 ابراهیمِ اصلی زأکأن  
\p
\v 37 «دأنم کی ابراهیمه زأکأنیدی. امّا به دونباله اَنیدی کی مره بوکوشید، چونکی می کلام شیمی میأنی جایی نأره.  
\v 38 من از اونچی کی می پئره ورجه بیدم، حرف زنم و شومأنم اونچی‌یه کی از شیمی پئر بیشنَوستیدی، انجام دیهیدی.»   
\p
\v 39 بوگفتیدی: «اَمی پئر، ابراهیمه.»  
\p عیسی بوگفته: «اگر ابراهیمه زأکأن بید، ابراهیمه مأنستن رفتار کودیدی.  
\v 40 امّا به دونباله اَنید کی مره بوکوشید و من اونی ایسم کی حقیقتی‌یه کی از خدا بیشنَوستم، شمره باز بوگفتم! ابراهیم اَطو رفتار نوکوده.  
\v 41 ولی شومأن شیمی پئره کارأنه انجام دیهیدی.»  
\s1 خدا زأکأن و شیطانه زأکأن  
\p بوگفتیدی: «اَمأن حرامزاده نی‌ییم! ایتأ پئر دأریم کی هو خدایه.»   
\p
\v 42 عیسی اَشأنه بوگفته: «اگر خدا شیمی پئر بو، مره دوست دأشتیدی، چونکی من از طرفه خدا بَموم و الأن اَیه ایسم. من از طرفه خودم نَموم، بلکی اون مره اوسه کوده.  
\v 43 بخاطره چی می حرفأنه نفهمیدی؟ بخاطره اَنکی نتأنیدی می کلامه قبول بوکونید.  
\v 44 شومأن از شیمی پئر شیطانیدی و به دونباله انجامه اونه خوأسته‌یأنیدی. اون از اوّل قاتل بو و حقیقته اَمره نسبتی نأشتی، چونکی هیچ حقیقتی در اون ننَه. هر وخت دروغ گه، از ذاته خودش گه. چونکی دروغگویه و دروغگویأنه پئره.  
\v 45 امّا از اویه کی من حقیقته شمره گم، می حرفأنه باور نوکونیدی.  
\v 46 کی شیمی میأن تأنه مره به گناه محکوم بوکونه؟ پس اگر حقیقته شمره گم، چره می حرفأنه باور نوکونیدی؟  
\v 47 کسی کی از خدایه، خدا کلامه قبول کونه، امّا شومأن کی قبول نوکونیدی، بخاطره اَنه کی از خدا نی‌ییدی.»   
\s1 برتری‌یه عیسی بر ابراهیم و پیامبرأن  
\p
\v 48 یهودیأن در جوابه اون بوگفتیدی: «آیا اَمأن درست نوگفتیم کی تو سامری‌یه بیگانه و دیوبزه‌یی؟»   
\p
\v 49 عیسی جواب بده: «من دیوبزه نی‌یم، بلکی می پئره احترامه دأرم. امّا شومأن مره بی‌احترامی کونیدی.  
\v 50 من به دونباله می جلال نی‌یم. ولی کسی ایسه کی به دونباله جلال دَئنه منه و داوری‌یم با اونه.  
\v 51 آمین، آمین، شمره گم، اگر کسی می کلامه بدأره، مرگه تا اَبد نیدینه!»   
\p
\v 52 یهودیأن اونه بوگفتیدی: «الأن دِ یقین پیدا بوکودیم کی تو دیوبزه‌یی! ابراهیم و پیامبرأن بمَردید، الأن تو گی کی: ‹اگر کسی می کلامه بدأره، هرگز نیمیره!›  
\v 53 آیا تو از اَمی پئر ابراهیمم بزرگتری؟ اون بمَرده، پیامبرأنم بمَردیدی، خودته کی دأنی؟»   
\p
\v 54 عیسی بوگفته: «اگر من خودمه جلال بدَم، می جلال ارزش نأره. اونی کی مره جلال دهه، می پئره، هونی کی شومأن گیدی اَمی خدایه.  
\v 55 هرچند کی شومأن اونه نشنأسیدی، امّا من اونه شنأسم. اگر بگم کی اونه نشنأسم، شیمی مأنستن دروغگو بم. امّا من اونه شنأسم و اونه کلامه دأشتن درم.  
\v 56 شیمی پئر، ابراهیم، شادی کودی تا می روزَ بیدینه. و او روزَ بیده و شاده بوسته.»   
\p
\v 57 یهودیأن اونه بوگفتیدی: «هنوز پنجاه سالم نأری، ابراهیمه بیده‌یی؟»   
\p
\v 58 عیسی اوشأنه بوگفته: «آمین، آمین، شمره گم، قبل از اونکی ابراهیم ببه، من ایسم!» \f * \fr 8.58 \ft به آیه ۲۴ نیگاه بوکونید. \f*  
\v 59 پس سنگه اوسَدیدی تا اونه سنگساره کونید. امّا عیسی خوره قأیمه کوده و از صحنِ معبد بیرون بوشو.   
\c 9  
\s1 شفایه کوره مادرزاد  
\p
\v 1 عیسی شوئون دوبو کی ایتأ کوره مادرزاده بیده.  
\v 2 اونه شاگردأن از اون وَورسه‌ییدی: «اوستاد، گناهه کی بوکوده، کی اَ مرد کور به دنیا بَمو؟ از خودشه یا از اونه پئر و مار؟»   
\p
\v 3 عیسی جواب بده: «نه از خودشه و نه از اونه پئر و مار، بلکی اَطو بوبوسته تا اَنکی قدرته خدا در اون آشکاره به.  
\v 4 تا روزِ، بأیستی اونی‌یه کی مره اوسه کوده اونه کارأنه انجام بدیم. شب نزدیکه بوستن دره کی در اون کسی نتأنه کاری بوکونه.  
\v 5 تا زمانی کی دنیا میأن ایسم، نوره دنیا ایسَم.»   
\p
\v 6 اَنه بوگفته خو آبه دهأنَ زمینه رو تَوَدَه، و گیل چأکوده، و اونه او مردِ چشمأنه رو بمألسته.  
\v 7 و اونه بوگفته: «بوشو در حوضه سْیلوحا (کی به زبانه عبری ‹فرستاده› معنی دهه) تی چشمأنه بوشور.» پس بوشو و بوشوسته و از اویه با چشمأنه باز وأگردسته.   
\p
\v 8 همسأیأن و کسأنی کی قبلاً اونه در حاله گدایی بیده بید، از همدیگر وَورسه‌ییدی: «مگر اَن، اونی نی‌یه کی نیشتی و گدایی کودی؟»  
\v 9 بعضی گفتیدی: «هونه.» دیگرأن گفتیدی: «شبیه اونه.»  
\p امّا اون خودش اصرار بوکوده و بوگفته: «من هونم.»   
\p
\v 10 پس از اون وَورسه‌ییدی: «چوطو تی چشمأن بازه بوسته؟»   
\p
\v 11 جواب بده: «مردی عیسی نام، گیل چأکوده و می چشمأنه رو بمألسته و بوگفته ‹بوشو به حوضه سْیلوحا و تی چشمأنه بوشور.› پس بوشوم و بوشوستم و می چشمأن بازه بوسته.»   
\p
\v 12 از اون وَورسه‌ییدی: «اون کویه ایسه؟»  
\p جواب بده: «نأنم.»   
\p
\v 13 پس او مردی‌یه کی قبلاً کور بو، فَریسیأنه ورجه بأوردیدی.  
\v 14 او روز کی عیسی گیل چأکوده بو و اونه چشمأنه وأکوده، روزِ شَبّات بو.  
\v 15 اون وخت فَریسیأنم اونه پرس و جو بوکودیدی کی چوطو تی چشمأن بازه بوسته. جواب بده: «می چشمأنه گیل بمألسته و من بوشوستم، الأن می چشمأن تأنه بیدینه.»   
\p
\v 16 پس بعضی از فَریسیأن بوگفتیدی کی: «او مرد از خدا نی‌یه. چونکی احترامه روزِ شَبّات ندأشته.» امّا دیگرأن بوگفتیدی: «چوطو شخصی کی گناهکاره، تأنه اَجور معجزات بوکونه؟» و اوشأنه میأن اختلاف دکفته.   
\p
\v 17 پس ایدفعه دیگر از اون وَورسه‌ییدی: «تو خودت درباره‌یه اون چی گی؟ چونکی تی چشمأنه، اون بازه کوده.»  
\p جواب بده: «اون نبی‌یه.»   
\p
\v 18 امّا حاکمأنه یهود هنوز باور نأشتیدی کی اون کور بو و اونه چشمأن بازه بوسته، تا اَنکی اونه پئر و ماره دوخوأدیدی.  
\v 19 و از اوشأن وَورسه‌ییدی: «آیا اَن شیمی پسره، هونی کی گیدی کور به دنیا بَمو؟ پس چوطو الأن تأنه بیدینه؟»   
\p
\v 20 جواب بدَییدی: «دأنیم کی اَمی پسره و دأنیم کی کور به دنیا بَمو.  
\v 21 امّا از اَنکی چوطو اَنه چشمأن بازه بوسته و یا کی اونه چشمأنه وأکوده، اَمأن نأنیم. از خودش وَورسید. اون خودش بالغه و خودش درباره‌یه خودش تأنه گب بزنه.»  
\v 22 اَشأن بخاطره اَن اَطو گفتیدی، چونکی از حاکمأنه یهود ترسه‌ییدی. چونکی حاکمأنه یهود همدست بوبوسته بید هر کسی کی اعتراف بوکونه عیسی هو مسیحه، اونه از کنیسه بیرونه کونید.  
\v 23 بخاطره اَن بو کی اونه پئر و مار بوگفتیدی، «خودش بالغه و از خودش وَورسید.»   
\p
\v 24 پس ایبارِ دیگر او مردی کی قبلاً کور بو، دوخوأدیدی و اونه بوگفتیدی: «در حضوره خدا بوگو کی حقیقته گی. اَمأن دأنیم کی اون مردی گناهکاره!»   
\p
\v 25 جواب بده: «اون گناهکار ایسه یا نی‌یه نأنم. ایچی‌یه دأنم کی کور بوم ولی الأن دینم!»   
\p
\v 26 وَورسه‌ییدی: «تی اَمره چی بوکوده؟ چوطو تی چشمأنه بازه کوده؟»   
\p
\v 27 جواب بده: «من کی شمره بوگفتم، ولی شومأن گوش ندَییدی، چره خوأییدی دوباره بیشنَوید؟ مگر شومأنم خوأییدی اونه شاگرد بیبید؟»   
\p
\v 28 اوشأن اونه فحش بدَییدی و بوگفتیدی: «تو خودت اونه شاگردی! اَمأن موسی شاگردیم!  
\v 29 اَمأن دأنیم کی خدا موسی اَمره حرف بزه. امّا نأنیم اَ شخص کویه‌شینه.»   
\p
\v 30 او مرد در جوابه اوشأن بوگفته: «جایه تعجبه در حالی کی می چشمأنه بازه کوده، نأنیدی از کویه بَمو!  
\v 31 ولی اَمأن دأنیم کی خدا گناهکارأنه دعایه نیشنَوه، امّا اگر کسی خداترس ببه و اونه خوأسته‌یه انجام بده، خدا اونه دعایه ایشنَوه.  
\v 32 از بنیاده عالم تا الأن کسی نیشنَوسته اینفر کوره مادرزاده چشمأنه بازه کوده بی.  
\v 33 اگر اَ مرد از طرفه خدا نوبو، از اون کاری برنَمویی.»   
\p
\v 34 اَشأن در جوابه اون بوگفتیدی: «تو سر تا پا در گناه به دنیا بَمویی! الأن اَمَره درس دَئن دری؟» پس اونه بیرونه کودیدی.   
\p
\v 35 وختی عیسی بیشنَوسته کی او مردَ بیرونه کودیدی، اونه پیدا بوکوده و از اون وَورسه: «آیا به انسانه پسر ایمأن دأری؟»   
\p
\v 36 جواب بده: «ای سرور، بوگو کی ایسه تا اونه ایمأن بأورم.»   
\p
\v 37 عیسی اونه بوگفته: «تو اونه بیده‌یی! اون هونی ایسه کی الأن تی اَمره حرف زِئن دره.»   
\p
\v 38 بوگفته: «ای سرور، ایمأن دأرم!» و عیسی جلو زانو بزه.   
\p
\v 39 عیسی بوگفته: «من داوری‌ره به اَ دنیا بَموم تا کورأن بینا، و بینایأن کوره بید.»   
\p
\v 40 بعضی از فَریسیأن کی اونه اَمره بید وختی اَنه بیشنَوستیدی، وَورسه‌ییدی: «آیا اَمأنم کوریم؟»   
\p
\v 41 عیسی اوشأنه بوگفته: «اگر کور بید، گناهی نأشتیدی. ولی الأن کی ادعا کونیدی دینیدی، گناهکار باقی مأنیدی.   
\c 10  
\s1 چوپانه خوب  
\p
\v 1 «آمین، آمین، شمره گم، کسی کی از در، وارده طویله‌یه گوسفندأن نبه، بلکی از رایه دیگر وارد ببه، دوزد و راهزنه.  
\v 2 امّا اونی کی از در وارده به، چوپانه گوسفندأنه.  
\v 3 دربان، درَ اونه‌ره بازه کونه و گوسفندأن اونه آوازه ایشنَویدی. اون خو گوسفندأنه به نام دوخوأنه و اوشأنه بیرون بره.  
\v 4 وختی تمامه خو گوسفندأنه بیرون بره، جلوتر از اوشأن قدم اوسَنه و گوسفندأن اونه دونبالسر شیدی، چونکی اونه صدایه شنأسیدی.  
\v 5 امّا هرگز بیگانه دونبالسر نیشیدی، بلکی از اون فرار کونیدی، چونکی اونه صدایه نشنأسیدی.»   
\p
\v 6 عیسی اَ مَثَله اوشأنه‌ره بوگفته، امّا نفهمستیدی کی اوشأنه چی گفتن دره.   
\p
\v 7 پس ایدفعه دیگر اوشأنه بوگفته: «آمین، آمین، شمره گم، من گوسفندأنه‌ره ‹در› ایسم!  
\v 8 اوشأنی کی از من پیشتر بَموییدی همگی دوزد و راهزنید، امّا گوسفندأن اوشأنه حرفه گوش نوکودیدی.  
\v 9 من ‹در› ایسم! هر کی از می راه وارد ببه، نجات پیدا کونه و آزادأنه بودورون اَیه و بیرون شه و چراگاه پیدا کونه.  
\v 10 دوزد نأیه، مگر اَنکی دوزدی بوکونه و بوکوشه و نابود بوکونه. من بَموم تا اَشأن زندگی‌یه اَبدی پیدا بوکونید و از او زندگی‌یه اَبدی به فراوانی بهره ببرید!   
\p
\v 11 «چوپانه خوب من ایسم! چوپانه خوب خو جانه گوسفندأنه‌ره نِهه.  
\v 12 کارگر چوپانه مأنستن نی‌یه و گوسفندأن اونه‌شین نی‌ییدی. هر وخت بیدینه گرگ اَمون دره، گوسفندأنه وله کونه و فرار کونه و گرگ گوسفندأنه حمله کونه و اوشأنه پراکنده کونه.  
\v 13 کارگر فرار کونه، چره کی کارگره و به فکر گوسفندأن نی‌یه.  
\v 14 چوپانه خوب من ایسم! من می گوسفندأنه شنأسم و می گوسفندأن مره شنأسیدی.  
\v 15 هوطو کی پئر مره شنأسه، منم پئره شنأسم. من می جانه گوسفندأنه‌ره نَهم.  
\v 16 گوسفندأنه دیگری‌یم دأرم کی از اَ طویله نی‌ییدی. اوشأنه بأید بأورم و اوشأن می صدایه گوش کونیدی. اون وخت ایتأ گله بیدی با ایتأ چوپان.  
\v 17 پئر، هَنه وستی مره دوست دأره کی من می جانه نَهم تا اونه پس فیگیرم.  
\v 18 هیچکس اونه از من فینگیره، بلکی من به میلِ خودم اونه فدم. اختیارشه دأرم کی فدم و اختیارشه دأرم کی اونه پس فیگیرم. اَ حکمه از می پئره فیگیفتم.»   
\p
\v 19 به دلیله اَ حرفأن ایدفعه دیگر یهودیأنه میأن اختلاف دکفته.  
\v 20 خیلی‌یأن از اوشأن بوگفتیدی: «اون دیوبزه و دیوأنه‌یه. چره اونه حرفأنه گوش کونیدی؟»  
\v 21 امّا دیگرأن بوگفتیدی: «اَشأن ایتأ دیوبزه حرفأن نی‌یه. آیا دیو تأنه کورأنه چشمأنه بازه کونه؟»   
\s1 یهودیأن عیسایه به عنوانه مسیح قبول نوکونیدی  
\p
\v 22 زمان برگزاری عیده وقف اورشلیمه میأن فَرسه بو. زمستان بو  
\v 23 و عیسی معبده میأن، اِیوانه سلیمانه میأن راه شویی.  
\v 24 یهودیأن اونه دور جمعَ بوستیدی و بوگفتیدی: «تا کی خوأیی اَمَره شکّه میأن بدأری؟ اگر مسیح ایسی، اَمَره آشکارا بوگو.»   
\p
\v 25 عیسی جواب بده: «شمره بوگفتم، امّا باور نوکونیدی. کارأیی کی من به نامِ می پئر کونم، مره شهادت دیهیدی.  
\v 26 امّا شومأن ایمأن نأوریدی، چونکی از می گوسفندأن نی‌ییدی.  
\v 27 می گوسفندأن، می صدایه گوش کونیدی. من اوشأنه شنأسم و اوشأن می دونبال اَییدی.  
\v 28 من اوشأنه زندگی‌یه اَبدی بخشم و یقیناً هرگز هلاکه نیبیدی و کسی اوشأنه از می دست نتأنه بدوزده.  
\v 29 می پئر کی اوشأنه مره ببخشه، از همه پیله‌تره و هیچکس نتأنه اوشأنه از می پئره دست بدوزأنه.  
\v 30 من و پئر ایتأییم.»   
\p
\v 31 اون وخت ایدفعه دیگر یهودیأن سنگ اوسَدیدی تا اونه سنگساره کونید.  
\v 32 عیسی اوشأنه بوگفته: «کارأیه خوبه زیادی از می پئر شمره نیشأن بدَم، بخاطره کویتأ خوأییدی مره سنگساره کونید؟»   
\p
\v 33 جواب بدَییدی: «بخاطره کاره خوب نی‌یه کی تره سنگسار کونیم، بلکی بخاطره اَنکی کفر گی. چونکی انسانی و خودته خدا خوأنی!»   
\p
\v 34 عیسی اوشأنه بوگفته: «مگر در شیمی تورات نَمو کی خدا بوگفته، شومأن خدایأنید؟ \x * \xo 10.34 \xt تورات، کیتابه مزمور، بابه ۸۲، آیه ۶. \x*  
\v 35 هیچ قسمتی از کیتابه مقدّس از اعتبار ساقطه نیبه. اگر اوشأنی کی کلامه خدا اوشأنه فَرسه، خدایأن خوأنده بیبید،  
\v 36 چوطو تأنیدی کسی‌یه کی پئر اونه وقف بوکوده و به دنیا اوسه کوده، بیگید کی: ‹کفر گه،› تنها به اَ خاطر کی بوگفتم خدا پسرم؟  
\v 37 اگر می پئره کارأنه بجا نأورم، می کلامه باور نوکونید.  
\v 38 امّا اگر بجا اَورم، حتی اگر می کلامه باور نأریدی، دسته کم به اونه کارأن ایمأن بأورید تا بدأنید و باور بدأرید کی پئر در منه و من در پئر.»  
\v 39 اون وخت ایدفعه دیگر خوأستیدی کی اونه گرفتاره کونید، ولی از اوشأنه دست در بوشو.   
\p
\v 40 بعد از اون، عیسی به او طرفه رودِ اُردن، اویه کی یحیی قبلاً تعمید دَیی، بوشو و اویه بِیسه.  
\v 41 خیلی‌یأن عیسی ورجه بَموییدی. اوشأن گفتیدی: «هرچند کی یحیی هیچ معجزه‌یی نوکوده، ولی هر اونچی کی درباره‌یه اَ شخص بوگفته، حقیقت دأشتی.»  
\v 42 پس خیلی‌یأن اویه به عیسی ایمأن بأوردیدی.   
\c 11  
\s1 ایلعازَرِ مَردن  
\p
\v 1 مردی ایلعازَر نام مریض بو. اون از مردمأنه بیت‌عَنْیا بو، دِهی کی مریم و اونه خواخور مارتا اویه‌شین بید.  
\v 2 مریم او زنی بو کی عیسی پایأنه معطر بوکوده و خو گیسه اَمره اونه خوشکه کوده. اونه برأر ایلعازَر مریضه بوسته بو.  
\v 3 پس ایلعازَرِ خواخورأن، عیسی‌ره پیغام بدَییدی و بوگفتیدی: «ای سرور، تی دوستِ عزیز مریضه.»   
\p
\v 4 عیسی وختی اَ خبره بیشنَوسته بوگفته: «اَ مریضی مرگه اَمره به آخر نرسه، بلکی خدا جلاله وستی‌یه، تا خدا پسر، توسطه اونه مریضی جلال پیدا بوکونه.»  
\v 5 عیسی مارتا و اونه خواخور و ایلعازَرَ دوست دأشتی.  
\v 6 پس وختی بیشنَوسته کی ایلعازَر مریضه، دو روز دیگرم در جایی کی ایسه بو، بِیسه.   
\p
\v 7 بعد از اون، خو شاگردأنه بوگفته: «بأیید بازم به یهودیه بیشیم.»   
\p
\v 8 اونه شاگردأن بوگفتیدی: «اوستاد، چند روزِ پیش بو کی یهودیأن خوأستیدی تره سنگساره کونید، تو بازم خوأیی اویه بیشی؟»   
\p
\v 9 عیسی جواب بده: «مگر هر روز دوازده ساعت نی‌یه؟ اونی کی در روز راه شه لغزش نوخوره، چونکی نوره اَ دنیایه دینه.  
\v 10 امّا اونی کی در شب راه شه لغزش خوره، چونکی نوری نأره.»  
\v 11 بعد از اَ حرفأن، اوشأنه بوگفته: «اَمی رفق ایلعازَر خوفته، امّا شوئون درم تا اونه بیداره کونم.»   
\p
\v 12 پس شاگردأن اونه بوگفتیدی: «ای سرور، اگر خوفته، خوره خوره خوب به.»  
\v 13 امّا عیسی از اونه مرگ حرف زه‌یی، در حالی کی اونه شاگردأن فکر کودیدی کی گه اون خوفته.   
\p
\v 14 اون وخت عیسی آشکارا اوشأنه بوگفته: «ایلعازَر بمَرده.  
\v 15 شیمی وستی خوشحالم کی اویه نِیسه بوم، تا ایمأن بأورید. امّا الأن اونه ورجه بیشیم.»   
\p
\v 16 پس توما کی به دوقولو معروف بو، شاگردأنه بوگفته: «بأیید اَمأنم بیشیم و اونه اَمره بیمیریم.»   
\s1 عیسی، قیامت و حیاته  
\p
\v 17 وختی عیسی اویه فَرسه، بفهمسته کی چهار روزِ ایلعازَرَ قبره میأن بنَه‌ییدی.  
\v 18 بیت‌عَنْیا حدوداً سه کیلومتر اورشلیمه اَمره فاصله دأشتی.  
\v 19 یهودیأنه زیادی مریم و مارتا ورجه بَمو بید تا اوشأنه بخاطره مرگه ایلعازَر تسلی بدید.  
\v 20 پس وختی مارتا بیشنَوسته کی عیسی اویه اَمون دره، اونه استقبال بوشو. امّا مریم خانه میأن بِیسه.  
\v 21 مارتا عیسایه بوگفته: «ای سرور، اگر اَیه بِیسه بی، می برأر نَمردی.  
\v 22 امّا دأنم کی الأن اگر هر چی از خدا بخوأیی، تره فده.»   
\p
\v 23 عیسی اونه بوگفته: «تی برأر زندَه به.»   
\p
\v 24 مارتا اونه بوگفته: «دأنم کی در روزِ قیامت زندَه به.»   
\p
\v 25 عیسی بوگفته: «قیامت و حیات من ایسم. اونی کی مره ایمأن بأوره، حتی اگر بیمیره بازم زندَه به.  
\v 26 و هر کی زنده‌یه و مره ایمأن دأره، یقیناً تا اَبد نیمیره. آیا اَنه باور کونی؟»   
\p
\v 27 مارتا بوگفته: «بله، ای سرور، من ایمأن دأرم کی تو ایسی مسیح، خدا پسر، اونی کی بأید به جهان بَمو بی.»   
\p
\v 28 اَنه بوگفته و بوشو خو خواخور مریمه دوخوأده و خلوتی اونه بوگفته: «اوستاد اَیه ایسه و تره دوخوأنه.»  
\v 29 مریم وختی اَنه بیشنَوسته، بدونه معطلی ویریشته و اونه ورجه بوشو.  
\v 30 عیسی هنوز وارده دهکده نوبوسته بو، بلکی جایی ایسه بو کی مارتا اونه ملاقات بوکوده بو.  
\v 31 یهودیأنی کی مریمه اَمره خانه میأن ایسه بید و اونه تسلی دَییدی، وختی بیده‌ییدی کی مریم عجله اَمره ویریشته و بیرون بوشو، اونه دونبالسر بوشوییدی، فکر کودیدی کی قبره سر شوئون دره تا اویه گریه و زاری بوکونه.  
\v 32 وختی مریم اویه فَرسه کی عیسی ایسه بو، اونه بیده و اونه پا زیر بکفته و بوگفته: «ای سرور، اگر اَیه بِیسه بی، می برأر نَمردی!»  
\v 33 وختی عیسی، گریه و زاریه مریم و یهودیأنی کی اونه اَمره همرأه بید، بیده، اونه روح آشفته و سخت منقلبه بوسته.  
\v 34 وَورسه: «اونه کویه بنَه‌ییدی؟»  
\p بوگفتید: «ای سرور، بیأ و بیدین.»  
\v 35 عیسی گریه بوکوده.  
\v 36 پس یهودیأن بوگفتیدی: «بیدینید چقدر اونه دوست دأشتی.»  
\v 37 امّا بعضی‌یأن بوگفتیدی: «آیا کسی کی او مردِ کوره چشمأنه بینا بوکوده، نتأنستی ایلعازَرَ مرگه جلویه بیگیره؟»   
\s1 ایلعازَرِ زندَه بوستن  
\p
\v 38 بعد از اون، عیسی، در حالی کی باز آشفته بو، قبره سر بَمو. قبر، غاری بو کی اونه دهأنه رو سنگی بنَه بید.  
\v 39 بفرمأسته: «سنگه اوسَنید.»  
\p مارتا میّتِ خواخور بوگفته: «ای سرور، الأن دِ بویه بد دهه، چونکی چهار روز بوگذشته.»   
\p
\v 40 عیسی اونه بوگفته: «مگر تره نوگفتم کی اگر ایمأن بأوری، خدا جلاله دینی؟»  
\v 41 پس سنگه اوسَدیدی. اون وخت عیسی آسمانه نیگاه بوکوده و بوگفته: «پئر تره شکر کونم کی مره بیشنَوستی.  
\v 42 من دأنستیم کی همیشه مره ایشنَوی. امّا اَنه کسأنی وستی بوگفتم کی در اَیه ایسه‌ییدی، تا ایمأن بأورید کی تو مره اوسه کودی.»  
\v 43 اَنه بوگفته و بعد از اَن، صدایه بلنده اَمره دوخوأده: «ایلعازَر، بیرون بیأ!»  
\v 44 پس او میّت کی اونه دست و پایه کفنه اَمره دَوَسته بید و اونه صورته ایتأ دستماله اَمره بپوشأنه بید، بیرون بَمو. عیسی اوشأنه بوگفته: «اونه بازه کونید و وئلید بشه.»   
\s1 عیسی قتله توطئه  
\p
\v 45 پس خیلی از یهودیأنی کی به دِئنه مریم بَمو بید و عیسی کاره بیده بید، اونه ایمأن بأوردیدی.  
\v 46 امّا بعضی‌یأن بوشوییدی فَریسیأنه ورجه و اوشأنه از اونچی کی عیسی بوکوده بو، خبر بدَییدی.  
\v 47 پس سرأنه کاهنأن و فَریسیأن بینیشتیدی و مشورت بوکودیدی. بوگفتیدی: «چی بوکونیم؟ اَ مرد معجزاته زیادی ظاهره کونه.  
\v 48 اگر وئلیم اون، هوطو پیش بشه، همه به اون ایمأن اَوریدی و رومیأن اَییدی و اَ مکانه و اَ قومه از اَمی دست بیرون اَوریدی.»   
\p
\v 49 امّا ایتأ از اوشأن کی اونه نام قیافا و در او سال کاهنِ اعظم بو، دیگرأنه بوگفته: «شومأن هیچی نأنیدی.  
\v 50 فکر نوکونید صلاح اَنه کی اینفر قومه وستی بیمیره، تا اَنکی تمامه مردم نابوده بید.»  
\v 51 امّا اَ حرف از خودش نوبو، بلکی چون در او سال اون کاهنِ اعظم بو اَطو نبوّت بوکوده کی عیسی قومه وستی میره،  
\v 52 نه تنها قومه وستی، بلکی برای جمعَ کودن و ایتأ بوستنه خدا زأکأن کی پراکنده‌ییدی.  
\v 53 بعد از او روز، اونه قتله توطئه‌یه دیچه‌ییدی.   
\p
\v 54 از اون به بعد، عیسی آشکارا دِ یهودیأنه میأن رفت و آمد نوکودی، بلکی به شهری کی اونه نام اِفْرایم بو در ناحیه‌یی نزدیکه بیابان بوشو و خو شاگردأنه اَمره اویه بِیسه.   
\p
\v 55 وختی یهودیأنه عیده پِسَخ نزدیکه بوسته، عده زیادی از جاهایه مختلف به اورشلیم بوشوییدی تا رسمه تطهیر کودنه قبل از پِسَخَ بجا بأورید.  
\v 56 اوشأن به دونبال عیسی بید، وختی معبده صحنِ میأن ایسه بید، همدیگره گفتیدی: «چی فکر کونیدی؟ آیا اصلاً عیده‌ره نأیه؟»  
\v 57 امّا سرأنه کاهنأن و فَریسیأن دستور بده بید کی هر وخت کسی بدأنه عیسی کویه ایسه، خبر بده تا اونه دستگیر بوکونید.   
\c 12  
\s1 عیسی تدهین  
\p
\v 1 شیش روز قبل از عیده پِسَخ، عیسی به بیت‌عَنْیا، جایی کی ایلعازَر زندگی کودی، بَمو؛ هونی کی عیسی اونه از مُرده‌یأنه میأن زندَه کوده بو.  
\v 2 در اویه به افتخاره عیسی شام بدَییدی. مارتا پذیرایی کودی و ایلعازَر از جمله کسأنی بو کی اونه اَمره سفره سر نیشته بو.  
\v 3 اون وخت، مریم عطره گران قیمتی‌یه کی از سنبله خالص و حدوداً نیم لیتر بو، بیگیفته و عیسی پایأنه معطره کوده و خو گیسأنه اَمره اونه پایه خوشکه کوده، تا جایی کی خانه پُر از عطر بوبوسته بو.  
\v 4 امّا یهودایه اِسْخَریوطی، ایتأ از عیسی شاگردأن کی بعداً اونه به دشمن تسلیمه کوده، بوگفته:  
\v 5 «چره اَ عطره سیصد دینار نوفروختیدی تا اونه پوله فقیرأنه فدید؟»  
\v 6 اون اَنه، فقیرأنه وستی نوگفتی، بلکی به اَ خاطر گفتی کی خودش دوزد بو. اون مسئوله دخل و خرج بو، و از پولی کی اونه ورجه بنَه بید، دوزدی کودی.   
\p
\v 7 پس عیسی بوگفته: «اونه به حاله خودش بنید، چونکی اَ عطره می روزِ دفن کودنه‌ره بدأشته بو.  
\v 8 فقیرأنه همیشه شیمی اَمره دأریدی، امّا مره همیشه نأریدی.»   
\p
\v 9 عده زیادی از یهودیأن چون بیشنَوستیدی عیسی اویه ایسه، بَموییدی تا نه فقط عیسایه بلکی ایلعازَرم کی زندَه بوکوده بو، بیدینید.  
\v 10 پس سرأنه کاهنأن تصمیم بیگیفتیدی تا ایلعازَرم بوکوشید،  
\v 11 چونکی باعث بوبوسته بو کی خیلی از یهودیأن از اوشأن دوره بید و به عیسی ایمأن بأورید.   
\s1 عیسی پادشاه مأنستن وارده اورشلیم به  
\p
\v 12 صبحه دم جمعیته زیادی کی عیده‌ره بَمو بید، وختی بیشنَوستیدی عیسی به اورشلیم اَمون دره،  
\v 13 نخله درخته شاخه‌یأنه به دست بیگیفتیدی و اونه پیشواز بوشوییدی. اوشأن فریادزنأن گفتیدی:  
\q1 «هوشیعانا! \f * \fr 12.13 \ft کلمه‌یه «هوشیعانا» در زبانه عبری «نجات بده» معنی دهه. از اَ کلمه موقعه حمد و ستایش استفاده کودیدی. تورات، کیتابه مزمور، بابه ۱۱۸، آیاته ۲۵ و ۲۶.\f*  
\q2 مبارکه، اونی کی به نامِ خداوند اَیه!  
\q1 مبارکه، اسرائیله پادشاه!»   
\m
\v 14 اون وخت عیسی کرّه الاغی‌یه پیدا بوکوده و اونه سوارَ بوسته؛ هوطو کی بینیویشته بوبوسته بو:   
\q1
\v 15 «نَواترسن! ای صهیونِ دختر،  
\q2 بیدین، تی پادشاه  
\q1 کرّه الاغه سر سواره اَمون دره!» \x * \xo 12.15 \xt تورات، کیتابه زکریا، بابه ۹، آیه ۹. \x*   
\p
\v 16 اونه شاگردأن اوّل اَ چیزأنه نفهمستیدی، امّا وختی عیسی جلال پیدا بوکوده، به یاد بأوردیدی کی اَ چیزأن همه درباره‌یه اون بینیویشته بوبوسته بو، هوطویی کی مردم اونه اَمره بوکوده بید.   
\p
\v 17 وختی عیسی ایلعازَرَ دوخوأده و زندَه کوده و از قبر بیرون بأورده، جماعته زیادی اویه ایسه بید. اوشأن او چیزی کی بیده بید شهادت دَییدی.  
\v 18 خیلی از مردم به هَه دلیل اونه پیشواز بوشوییدی، چونکی بیشنَوسته بید، چه معجزه‌یی از اون ظاهره بوسته بو.  
\v 19 پس فَریسیأن همدیگره بوگفتیدی: «بیدینید کی شومأن راه به جایی نبریدی. نیگاه بوکونید تمامه دنیا اونه دونبال بوشوییدی!»   
\s1 یونانیأن به دونباله عیسی ملاقاتیدی  
\p
\v 20 از کسأنی کی عبادته‌ره، به عید بَمو بید، تعدادی یونانی بید.  
\v 21 اوشأن فیلیپُسه ورجه بَموییدی کی اهله بیت‌صِیْدایه جلیل بو. اونه بوگفتیدی: «ای سرور، خوأییم عیسایه بیدینیم.»  
\v 22 فیلیپُس بَمو و آندریاسَ بوگفته و اوشأن هر دوتأ بوشوییدی عیسایه بوگفتیدی.   
\p
\v 23 عیسی اوشأنه بوگفته: «وخته جلال پیدا کودنه انسانه پسر فَرسه.  
\v 24 آمین، آمین، شمره گم، اگر دانه گندم خاکه میأن نکفه و نیمیره، تنها مأنه، امّا اگر بیمیره، بارِ زیاد اَوره.  
\v 25 کسی کی خو جانه دوست بدأره، اونه از دست دهه، امّا کسی کی در اَ دنیا از خودشه جان نفرت بدأره، اونه تا زندگی‌یه اَبدی حفظ کونه.  
\v 26 اونی کی بخوأیه مره خدمت بوکونه، بأیستی از من پیروی بوکونه، و جایی کی من ایسم، می خادمم اویه ایسه. کسی کی مره خدمت بوکونه، می پئر هم اونه سربلنده کونه.   
\s1 عیسی از خودشه مَردن حرف زنه  
\p
\v 27 «الأن می جان در اضطرابه، چی بگم؟ آیا بگم، ‹پئر! مره از اَ ساعت آزاده کون›؟ امّا به هَه دلیل من به اَ وخت فَرسم.  
\v 28 پئر تی نامِ جلال بدَن!»  
\p اون وخت ندایی از آسمان فَرسه کی: «جلال بدَم و بازم دهم!»  
\v 29 پس مردمی کی اویه ایسه بید، اَنه بیشنَوستیدی و بوگفتیدی: «رعد بو!» دیگرأن بوگفتیدی: «ایتأ فرشته اونه اَمره حرف بزه.»   
\p
\v 30 عیسی بوگفته: «اَ ندا شیمی وستی بو، نه می وستی.  
\v 31 الأن زمانه داوری‌یه اَ دنیایه؛ الأن رئیسه اَ دنیا بیرون تَوَدَه به.  
\v 32 و من، وختی کی از زمین بلنده بم همه‌یه به طرفه خودم اَورم.»  
\v 33 اون اَ حرفأنه اَمره، اشاره به مرگی بوکوده کی اونه انتظاره دأشتی.   
\p
\v 34 مردم بوگفتیدی: «طبقِ اونچی کی از تورات بیشنَوستیم، مسیح تا اَبد باقی مأنه، پس چوطویه کی گه انسانه پسر بأید بلنده به؟ اَ انسانه پسر کی‌یه؟»   
\p
\v 35 عیسی اَشأنه بوگفته: «تا مدته کمی نور شیمی اَمره ایسه! پس تا مدتی کی هنوز نوره دأریدی، راه بیشید، مبادا کی تاریکی شمره بیگیره. اونی کی تاریکی میأن راه شه، نأنه کویه شوئون دره!  
\v 36 تا زمانی کی نوره دأریدی، به نور ایمأن بأورید، تا نوره زأکأن بیبید.»  
\p وختی اَ حرفأنه بزه، از اویه بوشو و خودشه از اوشأن پنهانه کوده.   
\s1 مردمه بی‌ایمأنی  
\p
\v 37 با اونکی عیسی معجزاته زیادی اوشأنه چشمأنه جلو انجام بده بو، به اون ایمأن نأوردیدی.  
\v 38 هَنه وستی اِشَعْیایه نبی پیشگویی، ثابته به کی بوگفته بو:  
\q1 «کی‌یه، ای خداوند کی اَمی پیغامه باور بوکونه،  
\q2 و کی‌یه کی قدرته خداوند \f * \fr 12.38 \ft در یونانی: ‹خداونده بازو.› یعنی قدرتی کی نجات بخشه \f* اونه‌ره آشکاره بوسته؟» \x * \xo 12.38 \xt تورات، کیتابه اِشَعْیا، بابه ۵۳، آیه ۱. \x*   
\m
\v 39 هوطو کی اِشَعْیایه نبی خودش در جایه دیگر بوگفته، اوشأن نتأنستیدی ایمأن بأورید چونکی:   
\q1
\v 40 «اون، اوشأنه چشمأنه کور،  
\q2 و اوشأنه دیلأنه سخته کوده،  
\q1 تا خوشأنه چشمأنه اَمره نیدینید،  
\q2 و خوشأنه دیلأنه اَمره نفهمید،  
\q1 و وأنَگردید تا اوشأنه شفا بدَم.» \x * \xo 12.40 \xt تورات، کیتابه اِشَعْیا، بابه ۶، آیه ۱۰. \x*   
\m
\v 41 اِشَعْیا به اَ خاطر اَنه بوگفته چونکی اونه جلاله بیده و درباره‌یه اون حرف بزه.   
\p
\v 42 با اَنکی حتی خیلی از حاکمأنه قوم عیسایه ایمأن بأوردیدی، امّا از ترسه فَریسیأن، خوشأنه ایمأنه اقرار نوکودید، نوکونه کی اوشأنه از کنیسه بیرونه کونید.  
\v 43 چونکی تعریفه مردمه بیشتر از تعریفه خدا دوست دأشتیدی.   
\p
\v 44 اون وخت عیسی با صدایه بلند بوگفته: «هر کی به من ایمأن بأوره، نه به من بلکی به او کسی کی مره اوسه کوده ایمأن بأورده.  
\v 45 هر کی مره دینه، اونی‌یه دینه کی مره اوسه کوده.  
\v 46 من ایتأ نوره مأنستن به جهان بَموم تا هر کی به من ایمأن بأوره، تاریکی میأن نِیسه.  
\v 47 اگر کسی می حرفأنه بیشنَوه ولی از اون اطاعت نوکونه، من اونه داوری نوکونم، چونکی نَموم تا مردمه دنیایه داوری بوکونم، بلکی بَموم تا اوشأنه نجات ببخشم.  
\v 48 کسی کی مره ردّه کونه و می حرفأنه قبول نوکونه، ایتأ داوره دیگر ایسه؛ هو حرفأنی‌یه کی بوگفتم، در روزِ آخر اونه محکومه کونه.  
\v 49 چونکی من از طرفه خودم حرف نزنم، بلکی پئری کی مره اوسه کوده، مره دستور بده کی چی بگم و از چی حرف بزنم.  
\v 50 و من دأنم کی اونه دستور زندگی‌یه اَبدی‌یه. پس اونچی‌یه کی من گم هو چیزی ایسه کی پئر بوگفته کی من بگم.»   
\c 13  
\s1 شاگردأنه پایه شوستن  
\p
\v 1 ایروز قبل از عیده پِسَخ، عیسی دأنستی اونه وأگردستنه موقع از اَ دنیا به پئره ورجه فَرسه، خو کسأنه کی اَ دنیا میأن دوست دأشتی، تا حده کمال محبت بوکوده.   
\p
\v 2 وخته شام بو، ابلیس قبلاً یهودایه اِسْخَریوطی، شَمعونِ پسره دیله میأن بنَه بو کی عیسایه تسلیمه دشمن بوکونه.  
\v 3 عیسی کی دأنستی پئر همه چیزه اونه دست بیسپرده و از اونه ورجه بَمو، و اونه ورجه شوئون دره،  
\v 4 از شامِ سر ویریشته و خو ردایه از تن بیرون بأورده و ایتأ حوله اوسَده و به خو کمر دَوَسته.  
\v 5 بعد ایتأ لگنه میأن آب دوکوده و شروع بوکوده خو شاگردأنه پایه شوستن و اوشأنه پایه او حوله اَمره کی خو کمره دور، دَوَسته بو خوشکه کوده.  
\v 6 وختی به شَمعونِ پِطرُس فَرسه، اون عیسایه بوگفته: «ای سرور، تو خوأیی می پایه بوشوری؟»   
\p
\v 7 عیسی جواب بده: «الأن از درکِ اونچی کی کودن درم، ناتوانی، امّا بعداً فهمی.»   
\p
\v 8 پِطرُس اونه بوگفته: «هرگز! تو هرگز می پایأنه نوشوری!»  
\p عیسی جواب بده: «تا تره نوشورم، از من سهمی نَبری.»   
\p
\v 9 پس شَمعونِ پِطرُس بوگفته: «ای سرور، نه فقط می پایأنه، بلکی می دستأن و می سره هم بوشور!»   
\p
\v 10 عیسی جواب بده: «اونی کی حمام بوکوده، سر تا پا تمیزه، دِ شوستن احتیاج نأره، بجز اونه پایأن. بله، شومأن پاکیدی، امّا نه همه.»  
\v 11 چونکی دأنستی چه کسی اونه تسلیمه دشمن کونه و بخاطره اَن بوگفته: «شومأن همه پاک نی‌ییدی.»   
\p
\v 12 بعد از اَنکی عیسی اوشأنه پایأنه بوشوسته، خو ردایه دوکوده و بازم شامِ سفره سر بینیشته. اون وخت از اوشأن وَورسه: «آیا بفهمستیدی کی شمره چه کاری انجام بدَم؟  
\v 13 شومأن مره اوستاد و سرور دوخوأنیدی، و درستم گیدی، چونکی هَطو ایسم.  
\v 14 پس اگر من کی شیمی اوستاد و سرورم، شیمی پایأنه بوشوستم، شومأن هم بأید همدیگره پایأنه بوشورید.  
\v 15 من اَ کاره اَمره شمره سرمشق بنَم تا شومأنم هَطو رفتار بوکونید کی من شیمی اَمره بوکودم.  
\v 16 آمین، آمین، شمره گم، نه غلام از خو ارباب بزرگتره، نه فرستاده، از خودشه فرستنده!  
\v 17 الأن اَشأنه دأنیدی، خوش بحاله شومأن کی اگر اَشأنه انجام بدید.   
\s1 پیشگویی یهودا خیانت  
\p
\v 18 «اونچی کی گفتن درم درباره‌یه همه‌یه شومأن نی‌یه. من اوشأنی کی انتخاب بوکودم، شنأسم. امّا اَ گفته‌یه کیتابه مقدّس بأید ثابت ببه کی: ‹می همسفره می اَمره به دشمنی ویریزه.›  
\v 19 پس الأن قبل از اَنکی اتفاق دکفه، شمره گم تا زمانی کی اتفاق دکفه، ایمأن بأورید کی من ایسم. \x * \xo 13.19 \xt به بابه ۸ آیه ۲۴ نیگاه بوکونید. \x*  
\v 20 آمین، آمین، شمره گم، هر کی، کسی‌یه کی من اوسه کونم قبول بوکونه، مره قبول بوکوده، و هر کی مره قبول بوکونه، اونه کی مره اوسه کوده، قبول بوکوده.»   
\p
\v 21 عیسی بعد از اَنکی اَنه بوگفته، در روح منقلبه بوسته و آشکارا بوگفته: «آمین، آمین، شمره گم، ایتأ از شومأن مره به دشمن تسلیم کونه.»   
\p
\v 22 شاگردأن همدیگره نیگاه بوکودیدی و در تعجب بید کی اَ حرفأنه درباره‌یه کی گفتن دره.  
\v 23 ایتأ از شاگردأن کی عیسی اونه دوست دأشتی، اونه سینه ورجه تکیه بده بو.  
\v 24 شَمعونِ پِطرُس اشاره اَمره از اون بخوأسته تا از عیسی وَورسه اونه منظور کی‌یه.  
\v 25 پس اون کمی عقب بوشو و به عیسی سینه تکیه بده و بوگفته: «ای سرور، اون کی‌یه؟»   
\p
\v 26 عیسی جواب بده: «اونی‌یه کی اَ لقمه نانه بعد از اَنکی کاسه میأن زنم و اونه فدم.» و اون وخت، لقمه‌یه کاسه میأن بزه و اونه به یهودا، شَمعونِ اِسْخَریوطی پسر فده.  
\v 27 یهودا وختی لقمه‌یه فیگیفته، او لحظه شیطان وارده اون بوبوسته. اون وخت عیسی اونه بوگفته: «اونچی کی خوأیی انجام بدی، زودتر انجام بدَن.»  
\v 28 امّا هیچکس از کسأنی کی سفره سر نیشته بید، عیسی منظوره نفهمستیدی.  
\v 29 بعضی‌یأن فکر کودیدی چونکی یهودا مسئوله دخل و خرجه، عیسی اونه گه کی اونچی کی عیده‌ره لازمه بیهینه، یا اَنکی فقیرأنه چیزی فده.  
\v 30 بعد از فیگیفتنه لقمه، یهودا بدونه معطلی بیرون بوشو و شب بو.   
\s1 پیشگویی‌یه پِطرُسِ انکار  
\p
\v 31 بعد از اَنکی یهودا بیرون بوشو، عیسی بوگفته: «الأن انسانه پسر جلال پیدا بوکوده، و خدا هم در اون جلال پیدا بوکوده.  
\v 32 اگر خدا در اون جلال پیدا کوده، پس خدایم اونه در خودش جلال دهه و اونه بدونه معطلی جلال دهه.  
\v 33 عزیزأن، مدته کمی شیمی اَمره ایسم. می دونبال گردیدی، هوطو کی یهودیأنه بوگفتم، الأنم شمره گم کی او جایی کی من شوئون درم، شومأن نتأنیدی بأیید.  
\v 34 شمره ایتأ حکمه جدید فدم، و اون اَنه کی همدیگره دوست بدأرید؛ هوطویی کی من شمره دوست دأشتیم، شومأنم بأید همدیگره دوست بدأرید.  
\v 35 از هَه محبتی کی شومأن همدیگره کونیدی، همه فهمیدی کی شومأن می شاگردیدی.»   
\p
\v 36 شَمعونِ پِطرُس بوگفته: «ای سرور، کویه شوئون دری؟»  
\p عیسی جواب بده: «تو الأن جایی کی من شوئون درم نتأنی می دونبال بأیی، امّا بعداً می دونبال اَیی.»   
\p
\v 37 پِطرُس بوگفته: «ای سرور، چره الأن نتأنم تی دونبال بأیم؟ من می جانه تی رایه وستی نَهم.»   
\p
\v 38 عیسی بوگفته: «آیا در رایه من تی جانه نهی؟ آمین، آمین، تره گم، قبل از اَنکی خروس بخوأنه، تو مره سه بار انکار کونی.»   
\c 14  
\s1 عیسی، تنها رایی ایسه به سمت پئر  
\p
\v 1 «شیمی دیل نیگران نبه! به خدا ایمأن بدأرید، به منم ایمأن بدأرید.  
\v 2 می پئره خانه میأن منزل زیاده، وگر نه شمره گفتیم. شوئون درم تا جایی شمره حاضره کونم.  
\v 3 اون وخت کی بوشوم و جایی شمره حاضره کودم، بعداً اَیم و شمره می ورجه برم، تا جایی کی من ایسم شومأنم بِیسید.  
\v 4 جایی کی من شوئون درم، او رایه دأنیدی.»   
\p
\v 5 توما اونه بوگفته: «اَمأن حتی نأنیمی کویه شوئون دری، پس چوطو تأنیم رایه بدأنیم؟»   
\p
\v 6 عیسی اونه بوگفته: «راه و راستی و حیات من ایسم، هیچکس می پئره ورجه نأیه مگر به واسطه‌یه من.  
\v 7 اگر مره شنأختیدی، می پئرم شنأختیدی. امّا بعد از اَن، اونه شنأسیدی و اونه بیده‌ییدی.»   
\p
\v 8 فیلیپُس اونه بوگفته: «ای سرور، پئره اَمَره نیشأن بدَن، هَن اَمَره کافی‌یه.»   
\p
\v 9 عیسی اونه بوگفته: «فیلیپُس، خیلی وخته کی شیمی اَمره ایسم، هنوز مره نشنأختی؟ کسی کی مره بیده، پئره بیده. پس چوطو ایسه کی گی ‹پئره اَمَره نیشأن بدَن›؟  
\v 10 آیا باور نأری کی من در پئرم و پئرم در من؟ حرفأنی کی من شمره گم از خودم نی‌یه، بلکی از پئری‌یه کی در من ساکنه، اونه کی خو کارأنه به انجام رسأنه.  
\v 11 اَ حرفه کی من گم باور بوکونید کی من در پئرم و پئرم در من؛ وگر نه اونه کارأنه وستی باور بوکونید کی من در پئرم و پئرم در من.   
\p
\v 12 «آمین، آمین، شمره گم، اونی کی به من ایمأن بدأره، اونم کارأنی کی من کونم انجام دهه، و حتی کارأنه بزرگتر از اونم انجام دهه، چونکی من پئره ورجه شوئون درم.  
\v 13 و به نامِ من هر چیزی کی بخوأیید، من اونه انجام دهم، تا پئر در پسر جلال پیدا بوکونه.  
\v 14 اگر چیزی به نامِ من بخوأیید من اونه انجام دهم.   
\s1 روح‌القدسه وعده  
\p
\v 15 «اگر مره دوست بدأرید، می احکامه دأریدی.  
\v 16 و من از پئر خوأیم و اون، پشتیبانه \f * \fr 14.16 \ft پشتیبان کی هو روحه راستی در بابه ۱۵ آیه ۲۶ و بابه ۱۶ آیه ۱۳ کی روح‌القدس ایسه. \f* دیگری شمره فده کی همیشه شیمی اَمره بِیسه،  
\v 17 یعنی روحه راستی کی دنیا نتأنه اونه قبول بوکونه، چونکی نه اونه دینه و نه اونه شنأسه، امّا شومأن اونه شنأسیدی، چره کی شیمی ورجه ساکنه به و در آینده شیمی میأن ایسه.   
\p
\v 18 «شمره بی‌کس نَنم، شیمی ورجه اَیم.  
\v 19 بعد از مدتی دنیا مره نیدینه، امّا شومأن مره دینیدی. چونکی من زنده‌یم، شومأنم زندگی کونیدی.  
\v 20 در او روز فهمیدی کی من در پئر ایسم و شومأن در من و منم در شومأن.  
\v 21 اونی کی می احکامه بدأره و از اوشأن پیروی بوکونه، اون مره دوست دأره؛ و اونی کی مره دوست دأره، می پئرم اونه دوست دأره و منم اونه دوست دأرم و خودمه اونه‌ره آشکاره کونم.»   
\p
\v 22 یهودا (نه اون یهودایه اِسْخَریوطی) از اون وَورسه: «ای سرور، چوطویه کی خوأیی خودته اَمَره آشکاره کونی، امّا نه اَ دنیاره؟»   
\p
\v 23 عیسی جواب بده: «اگر کسی مره دوست بدأره، می کلامه دأره، و می پئرم اونه دوست دأره و اَمأن اونه ورجه اَییم و اونه اَمره زندگی کونیم.  
\v 24 اونی کی مره دوست نأره، می کلامم اطاعت نوکونه، و اَ کلامه کی ایشنَویدی از من نی‌یه، بلکی از پئری‌یه کی مره اوسه کوده.   
\p
\v 25 «اَ چیزأنه تا الأن کی شیمی اَمره ایسم، شمره بوگفتم.  
\v 26 امّا او پشتیبان، یعنی روح‌القدس، کی پئر اونه به نامِ من اوسه کونه، اون همه چیزه شمره یاد دهه و هر اونچی کی من شمره بوگفتم، شمره به یاد اَوره.  
\v 27 شمره آرامش بجا نَهم، می آرامشه شمره فدم. اونچی کی من شمره فدم اونی نی‌یه کی دنیا شمره فده. شیمی دیل نیگران و هراسان نبه.  
\v 28 بیشنَوستیدی کی شمره بوگفتم ‹من شوئون درم. امّا بازم شیمی ورجه اَیم.› اگر مره دوست بدأشته بید، خوشحاله بوستیدی کی می پئره ورجه شوئون درم، چونکی پئر از من بزرگتره.  
\v 29 الأن اَنه قبل از اَنکی چیزی پیش بأیه شمره بوگفتم، تا وختی کی اتفاق دکفه، ایمأن بأورید.  
\v 30 وخته زیادی نمأنسته کی شیمی اَمره حرف بزنم، چونکی رئیسه اَ دنیا اَمون دره، اون هیچ قدرتی بر من نأره.  
\v 31 امّا من کاری‌یه کونم کی پئر مره دستور بده، تا دنیا بدأنه کی پئره دوست دأرم. \f * \fr 14.31 \ft یا: تا دنیا بدأنه کی پئره دوست دأرم و من کاری کونم کی پئر مره دستور بدَه. \f* ویریزید، بیشیم.   
\c 15  
\s1 انگور درخته واقعی  
\p
\v 1 «انگور درخته حقیقی من ایسم و می پئر باغبأنه.  
\v 2 هر شاخه‌یی کی از منه و میوه نأوره، می پئر اونه وَوینه، و هر شاخه‌یی کی میوه اَوره، اونه هَرَس کونه، تا زیادتر میوه بأوره.  
\v 3 شومأن الأن بخاطره کلامی کی شمره بوگفتم، پاکیدی.  
\v 4 در من بمأنید، و منم در شومأن مأنم. چونکی شاخه نتأنه از خودش میوه بأوره مگر اینکه در درخت بمأنه، شومأنم نتأنید میوه بأورید اگر در من نمأنید.   
\p
\v 5 «من درخته انگور ایسم و شومأن اونه شاخه‌یأنیدی. کسی کی در من بمأنه و منم در اون، میوه‌یه زیادی اَوره. چونکی بدونه من هیچی نتأنیدی بوکونید.  
\v 6 اگر کسی در من نمأنه، مثله شاخه‌یی ایسه کی اونه دور تَوَدیدی و خوشکه به. خوشکه بوسته شاخه‌یأنه جمعَ کونیدی و آتشه میأن تَوَدیدی و سوزانیدی.  
\v 7 اگر در من بمأنید و می کلام در شومأن بمأنه، هر چیزی کی بخوأیید و درخوأست بوکونید براَورده به.  
\v 8 می پئره جلال در اَنه کی شومأن میوه‌یه زیادی بأورید و اَطویی می شاگرد بیدی.   
\p
\v 9 «هوطو کی می پئر مره دوست دأشتی، منم شمره دوست دأشتیم. در می محبت بمأنید.  
\v 10 اگر می احکامه بدأرید، در می محبت مأنیدی، هَطو کی من می پئره احکامه بدأشتم و در اونه محبت مأنم.  
\v 11 اَ حرفأنه شمره بوگفتم تا می شادی در شومأن بأیه و شیمی شادی کامل ببه.   
\p
\v 12 «می حکم اَنه کی همدیگره محبت بوکونید، هوطو کی من شمره محبت بوکودم.  
\v 13 بیشتر از اَن محبتی وجود نأره کی کسی خو جانه فدایه خو دوستأن بوکونه.  
\v 14 می دوستأن شومأنیدی، اگر اونچی کی شمره حکم بوکودم انجام بدید!  
\v 15 دِ شمره غلام دونوخوأنم، چونکی غلام از خو اربابه کارأن خبر نأره، بلکی شمره می دوست دأنم، چونکی هر چی کی از می پئر بیشنَوستم، شمره از اون باخبر بوکودم.  
\v 16 شومأن نیبید کی مره انتخاب بوکودیدی، بلکی من شمره انتخاب بوکودم و قرار بنَم کی بیشید و میوه بأورید و شیمی میوه بمأنه، تا هر چی از می پئر به نامِ من بخوأیید، شمره فده.  
\v 17 می حکم به شومأن اَنه کی همدیگره محبت بوکونید!   
\s1 دنیا نفرت از عیسی مسیح شاگردأن  
\p
\v 18 «اگر دنیا از شومأن نفرت بدأره، به یاد بأورید کی قبل از شومأن، از من نفرت دأشتی.  
\v 19 اگر متعلق به دنیا بید، دنیا شمره مثله خو کسأن دوست دأشتی. امّا به دنیا تعلّق نأریدی، من شمره از دنیا انتخاب بوکودم، بخاطره اَنه کی دنیا از شومأن نفرت دأره.  
\v 20 کلامی‌یه کی شمره بوگفتم به یاد بأورید: ‹غلام از خو ارباب بزرگتر نی‌یه.› اگر مره آزار بدَییدی، شیمی اَمره‌یم هَطو کونیدی و اگر می کلامه بدأشتیدی، شیمی کلامه هم دأریدی.  
\v 21 امّا همه‌یه اَ کارأنه می نامِ وستی شیمی اَمره کونیدی چونکی اونی کی مره اوسه کوده اونه نشنأسیدی.  
\v 22 اگر نَمو بیم و اَشأنه اَ حرفأن نزه بیم، گناهی نأشتیدی، امّا الأن هیچ بهانه‌یی برای خوشأنه گناهأن نأریدی.  
\v 23 کسی کی از من نفرت بدأره، از می پئرم نفرت دأره.  
\v 24 اگر اوشأنه‌ره کاری نوکوده بیم کی بجز من کسی نوکوده، گناهی نأشتیدی، امّا الأن با اَنکی او کارأنه بیده‌ییدی، هم از من، هم از می پئر نفرت دأریدی.  
\v 25 اَطویی‌یه کی، کلامی کی در خوشأنه تورات بَمو، ثابت ببه کی: ‹از من بی‌دلیل نفرت دأریدی.› \x * \xo 15.25 \xt تورات، کیتابه مزمور، بابه ۳۵، آیه ۱۹ و بابه ۶۹، آیه ۴. \x*   
\p
\v 26 «امّا چون او پشتیبان کی از طرفه پئر روانه به، بأیه، یعنی روحه راستی \f * \fr 15.26 \ft روجوع ببه به یوحنا، بابه ۱۴ آیه ۱۶ \f* کی از پئره ورجه اَیه، اون خودش می وستی شهادت دهه.  
\v 27 و شومأنم بأید شهادت بدید چونکی از اوّل می اَمره بید.   
\c 16  
\p
\v 1 «اَ چیزأنه شمره بوگفتم تا از راه بدره نیبید!  
\v 2 شمره از کنیسه‌یأن بیرونه کونیدی. حتی زمانی فَرسه کی هر کی شمره بوکوشه، فکر کونه کی خدایه خدمت بوکوده.  
\v 3 اَ کارأنه کونیدی، چونکی نه پئره شنأسیدی نه مره!  
\v 4 اَ حرفأنه شمره بوگفتم تا وخته اونه انجام فَرسه، به یاد بأورید کی شمره آگاه بوکوده بوم. اوشأنه از اوّل شمره نوگفتم، چونکی خودم شیمی اَمره بوم.   
\s1 تعلیم درباره‌یه روحه خدا  
\p
\v 5 «الأن کسی کی مره اوسه کوده اونه ورجه شوئون درم و هیچ‌کدام ونَورسیدی ‹کویه شوئون دری؟›  
\v 6 امّا می حرفأنه وستی شیمی دیل پُر از غم بوبوسته.  
\v 7 با اَ حال من شمره حقیقته گم کی می شوئون به نفعِ شومأنه، چونکی اگر نشم، او پشتیبان شیمی ورجه نأیه، امّا اگر بشم، اونه شیمی ورجه اوسه کونم.  
\v 8 و وختی اَیه، جهانه از اونه گناه، و از عدالته خداوند، و از روزِ داوری آگاه کونه.  
\v 9 گناهه جهان، بی‌ایمانی به منه.  
\v 10 عدالت فراهمه، چونکی من پئره ورجه شوئون درم و دِ مره نیدینیدی.  
\v 11 داوری اَیه چونکی رئیسه اَ جهان داوری بوبوسته.   
\p
\v 12 «خیلی چیزأنه دیگر دأرم کی شمره بگم، امّا الأن طاقتِ اونه ایشنَوستنه نأریدی.  
\v 13 امّا وختی روحه راستی \f * \fr 16.13 \ft روجوع ببه به بابه ۱۴، آیه ۱۶ \f* بأیه، شمره به طرفه حقیقت هدایت کونه. چونکی اون از طرفه خودش حرفی نزنه، بلکی اونچی‌یه کی ایشنَوه، گه، و اونچی‌یه کی پیش اَیه، شمره خبر دهه.  
\v 14 اون مره جلال دهه، چونکی اونچی‌یه کی از من فیگیره، شمره خبر دهه.  
\v 15 هر چیزی کی پئره‌شینه، می‌شینم ایسه. هَنه وستی بوگفتم کی اونچی‌یه کی از من فیگیره، شمره خبر دهه.   
\s1 عیسی خو شاگردأنه تسلی دهه  
\p
\v 16 «پس از مدته کمی، دِ مره نیدینیدی، بعد از مدته کمه دیگری بازم مره دینیدی.»   
\p
\v 17 اون وخت بعضی از اونه شاگردأن همدیگره بوگفتیدی: «اونه منظور از اَ حرفأن چی‌یه کی: ‹پس از مدته کمی، دِ مره نیدینیدی و پس از مدته کمه دیگری بازم مره دینیدی›؟ یا اَنکی گه ‹چونکی پئره ورجه شوئون درم›؟»  
\v 18 پس همدیگره گفتیدی: «اَ ‹مدته کمی› کی گه، چی‌یه؟ اونه منظوره نفهمیم؟»   
\p
\v 19 امّا عیسی قبلاً دأنستی کی خوأییدی از اون سؤال بوکونید؛ پس اوشأنه بوگفته: «آیا اَنه وستی همدیگره اَمره بحث کونیدی کی بوگفتم ‹پس از مدته کمی، دِ مره نیدینیدی، و پس از مدته کمه دیگری بازم مره دینیدی؟›  
\v 20 آمین، آمین، شمره گم، شومأن گریه و زاری کونیدی امّا دنیا خوشحاله به. شومأن غمگینه بیدی، امّا شیمی غم به شادی تبدیله به.  
\v 21 زن تا وخته زأیمأن درد کشه، چونکی اونه وخت فَرسه. امّا وختی کی اونه زأی به دنیا بَمو، دِ خو درده به یاد نأوره، چونکی خوشحاله از اَنکی انسانی به دنیا بَمو.  
\v 22 هَطو کی شومأنم الأن غمگینیدی، امّا بازم شمره دینم کی شیمی دیل شاده به و هیچکس او شادی‌یه از شومأن فینگیره.  
\v 23 او روز دِ چیزی از من نخوأییدی. آمین، آمین، شمره گم، هر چی از پئر به نامِ من بخوأیید، اونه شمره فده.  
\v 24 تا الأن به نامِ من چیزی نخوأستیدی. بخوأیید تا پیدا بوکونید و شیمی شادی کامله به.   
\p
\v 25 «اَ چیزأنه مَثَله اَمره شمره بوگفتم، امّا زمانی فَرسه کی، دِ شیمی اَمره اَجور حرف نزنم، بلکی آشکارا در مورده پئر شمره گم.  
\v 26 او روز به نامِ من تقاضا کونیدی و شمره نگم کی من از طرفه شومأن از پئر تقاضا کونم.  
\v 27 چره کی پئر خودش شمره دوست دأره، چونکی شومأن مره دوست دأشتیدی و ایمأن بأوردیدی کی از خدا ورجه بَموم.  
\v 28 من از پئره ورجه بَموم و به اَ دنیا وارده بوستم، و الأن اَ دنیایه ترکه کونم و پئره ورجه شم.»   
\p
\v 29 اون وخت اونه شاگردأن بوگفتیدی: «الأن آشکارا حرف زنی، نه مَثَله اَمره.  
\v 30 الأن دِ دأنیم کی از همه چیز آگاهی و حتی احتیاج نأری کسی خو سؤاله تی اَمره در میأن بنَه. هَنه وستی ایمأن دأریم کی از خدا ورجه بَمویی.»   
\p
\v 31 عیسی اوشأنه بوگفته: «آیا الأن واقعاً ایمأن دأریدی؟  
\v 32 ولی زمانی فَرسه کی، و حقیقتاً الأن فَرسه کی پخشه بیدی و هر کی خو خانه و زندگی سر شه و مره تنها نَهه. ولی من تنها نی‌یم، چونکی پئر می اَمره‌یه.  
\v 33 اَ چیزأنه شمره بوگفتم تا در من آرامش بدأرید، دنیا میأن شومأن به زحمت دکفیدی؛ ولی شیمی دیل قوی ببه، چونکی من بر دنیا غلبه بوکودم.»   
\c 17  
\s1 عیسی دعا خودشه‌ره  
\p
\v 1 بعد از اَ حرفأن عیسی آسمانه نیگاه بوکوده و بوگفته: «پئر! وختش فَرسه. تی پسره جلال بدَن تا تی پسرم تره جلال بده.  
\v 2 چونکی تو اونه قدرت فدَیی بر تمامی‌یه بشر تا همه‌یه کسأنی‌یه کی تو به اون عطا بوکودی، زندگی‌یه اَبدی ببخشه.  
\v 3 و اَنه زندگی‌یه اَبدی، کی تره، تنها خدایه حقیقی و عیسی مسیحه کی اوسه کودی، بشنأسید.  
\v 4 من او کاری‌یه کی مره بیسپرده بی، به کمال فَرسأنم، و اَجور تره زمینه رو جلال بدَم.  
\v 5 پس الأن ای پئر، تونم مره در حضور خودت جلال بدَن، همان جلالی کی قبل از دنیا، تی ورجه دأشتیم.   
\s1 عیسی دعا شاگردأنه‌ره  
\p
\v 6 «من تی نامِ به اوشأنی کی از دنیا مره ببخشه‌یی، آشکاره کودم. تی‌شین بید و تو اوشأنه مره ببخشه‌یی و تی کلامه بدأشتیدی.  
\v 7 الأن بفهمستیدی کی هر چی کی مره ببخشه‌یی حقیقتاً از طرفه تویه.  
\v 8 چونکی او کلامی‌یه کی مره بیسپردی، اوشأنه بیسپردم و اوشأن اونه قبول بوکودیدی و یقین بدأنستیدی کی از طرفه تو بَمو و ایمأن بأوردیدی کی تو مره اوسه کودی.  
\v 9 می درخوأست اوشأنه وستی‌یه؛ من نه دنیا وستی، بلکی اوشأنی وستی تقاضا کونم کی تو مره ببخشه‌یی. چونکی تی‌شینیدی.  
\v 10 هر اونچی کی به من تعلّق دأره، تی‌شینه و هر اونچی کی به تو تعلّق دأره، می‌شینه و در اوشأن جلال پیدا بوکودم.  
\v 11 بیشتر از اَن، دنیا میأن نِیسم، امّا اوشأن هنوز در دنیا ایسیدی. من تی ورجه اَیم. ای پئره قدّوس، تی نامِ مره ببخشه‌یی، اوشأنه به قدرته تی نام حفظ بوکون، تا ایتأ بیبید، هَطو کی اَمأن ایسیم.  
\v 12 من اوشأنه تا زمانی کی می اَمره ایسه بید، حفظ بوکودم، و از اوشأن به قدرته تی نام کی مره ببخشه‌یی، محافظت بوکودم. هیچ‌کدام از اوشأن هلاکه نوبوستیدی، جز اونی کی بأید به هلاکت برسه، تا پیشگویی‌یه کیتابه مقدّس ثابت ببه.  
\v 13 امّا الأن تی ورجه اَیم و اَ حرفأنه زمانی گم کی دنیا میأن ایسم تا می شادی‌یه خوشأنه میأن به کمال برسأنید.  
\v 14 من تی کلامه اوشأنه فدم، امّا دنیا از اوشأن نفرت دأشتی، چونکی متعلق به دنیا نی‌ییدی. هَطو کی من تعلّق نأرم.  
\v 15 می درخوأست اَن نی‌یه کی اوشأنه از اَ دنیا ببری، بلکی خوأیم از شَرور محافظت بوکونی.  
\v 16 اوشأن به اَ دنیا تعلّق نأریدی هَطو کی من تعلّق نأرم.  
\v 17 اوشأنه به وسیله‌یه تی حقیقت تقدیس بوکون؛ تی کلام، حقیقته!  
\v 18 هَطو کی تو مره به اَ دنیا اوسه کودی، منم اوشأنه اَ دنیا میأن اوسه کودم.  
\v 19 من خودمه اوشأنه وستی تقدیس کونم، تا اوشأنم حقیقته اَمره تقدیس بیبید.   
\s1 عیسی دعا خو همه‌تأ پیروأنه‌ره  
\p
\v 20 «می درخوأست فقط اوشأنه‌ره نی‌یه، بلکی برای کسأنی‌یه کی توسطه اوشأنه پیغام به من ایمأن اَوریدی.  
\v 21 تا همه ایتأ بیبید، هَطو کی تو ای پئر در منی و من در تو، طوری بوکون کی اوشأنم در اَمأن بیبید، تا دنیا ایمأن بأوره کی تو مره اوسه کودی.  
\v 22 و من جلالی‌یه کی مره ببخشه‌یی، اوشأنه ببخشم، تا ایتأ بیبید، هَطویی کی اَمأن ایتأییم.  
\v 23 من در اوشأن و تو در من، طوری بوکون کی اوشأنم کاملاً ایتأ بیبید، تا دنیا بدأنه کی تو مره اوسه کودی و اوشأنه هوطویی دوست دأشتی کی مره دوست دأشتی.  
\v 24 ای پئر خوأیم اوشأنی کی مره ببخشه‌یی، می اَمره بیبید، هو جایی کی من ایسم، تا می جلاله بیدینید، جلالی کی تو مره ببخشه‌یی؛ چون قبل از اَنکی دنیا به وجود بأیه، مره دوست دأشتی.   
\p
\v 25 «ای پئره عادل، دنیا تره نشنأسه، امّا من تره شنأسم، و اوشأن دأنیدی کی تو مره اوسه کودی.  
\v 26 من تی نامِ به اوشأن بشنأسأنم و بازم شنأسأنم، تا او محبتی کی تو مره دأشتی، در اوشأنم بمأنه و منم در اوشأن بمأنم.»   
\c 18  
\s1 عیسی گرفتاره بوستن  
\p
\v 1 عیسی پس از گفتنه اَ حرفأن خو شاگردأنه اَمره به او طرفه دره‌یه قِدْرون بوشو. در اویه باغی نَهه بو و عیسی خو شاگردأنه اَمره اویه بوشو.  
\v 2 امّا یهودا، اونه تسلیم‌کوننده، او محله شنأختی، چونکی عیسی و اونه شاگردأن همیشه در او محل جمعَ بوستیدی.  
\v 3 پس یهودا گروهی از سربازأن و مأمورأنه سرأنه کاهنأن و فَریسیأنه اوسَده و به اویه بَمو، اوشأن چراغ و مشعل و اسلحه اَمره اویه فَرسه‌ییدی.   
\p
\v 4 عیسی با اونکی دأنستی چی رخ دهه، جلو بوشو و اوشأنه بوگفته: «کی دونبال گردیدی؟»   
\p
\v 5 جواب بدَییدی: «عیسایه ناصری دونبال.»  
\p بوگفته: «منم!» یهودایه خائنم اوشأنه اَمره بو.  
\v 6 وختی عیسی بوگفته، «منم» اوشأن عقب عقب بوشوییدی و زمینه رو بکفتیدی.  
\v 7 عیسی ایبارِ دیگرم از اوشأن وَورسه: «کی دونبال گردیدی؟»  
\p بوگفتیدی: «عیسایه ناصری دونبال.»   
\p
\v 8 جواب بده: «شمره بوگفتم کی من خودمم. پس اگر مره خوأییدی، وئلید اَشأن بیشید.»  
\v 9 اَنه بوگفته تا اونچی کی قبلاً بوگفته بو، ثابت ببه کی: «هیچ‌کدام از اوشأنی کی مره ببخشه‌یی، از دست ندم.» \x * \xo 18.9 \xt تورات، کیتابه یوحنا، بابه ۶، آیه ۳۹. \x*   
\p
\v 10 اون وخت شَمعونِ پِطرُس شمشیری‌یه کی دأشتی، بیرون بأورده و ضربه‌یی به خادمه کاهنِ اعظم بزه و اونه گوشِ راسته وَوِه. اونه خادمه نام مالخوس بو.  
\v 11 عیسی پِطرُسَ بوگفته: «تی شمشیره غلاف بوکون. آیا نبأید او جامِ کی پئر مره فده، بنوشم؟»   
\s1 بازجویی حَنّا از عیسی  
\p
\v 12 اون وخت سربازأن، خوشأنه فرمانده و مأمورأنه یهودی اَمره، عیسایه دستگیر بوکودیدی و اونه دستأنه دَوَستیدی.  
\v 13 اوّل اونه حَنّا ورجه ببردید. حَنّا، قیافا زن پئر بو و او زمان کاهنِ اعظم بو.  
\v 14 قیافا اونی بو کی یهودیأنه توصیه کودی کی بهتره اینفر بخاطره قوم بیمیره.   
\s1 انکارِ پِطرُس  
\p
\v 15 شَمعونِ پِطرُس و ایتأ شاگرده دیگر عیسی دونبالسر بوشوییدی. او شاگرد از آشنایأنه کاهنِ اعظم بو. پس عیسی اَمره وارده حیاطه خانه‌یه کاهنِ اعظم بوبوسته.  
\v 16 امّا پِطرُس درِ پشت بِیسه. او شاگردی کی از آشنایأنه کاهنِ اعظم بو، بیرون بوشو و کنیزه اَمره کی دربان بو، حرف بزه و پِطرُسَ به خانه دورون ببرده.  
\v 17 اون وخت او کنیز پِطرُسَ بوگفته: «مگر تو از شاگردأنه او مرد نی‌یی؟»  
\p پِطرُس جواب بده: «نی‌یم.»   
\p
\v 18 هوا سرد بو. خادمأن و مأمورأن زغاله اَمره آتشی چأکوده بید و اونه دور جمعَ بوسته بید و خوشأنه گرمه کودیدی. پِطرُسم اوشأنه اَمره ایسه بو و خودشه گرمه کودی.   
\s1 بازجویی‌یه کاهنِ اعظم از عیسی  
\p
\v 19 پس کاهنِ اعظم از عیسی درباره‌یه اونه شاگردأن و اونه تعالیم وَورسه.  
\v 20 عیسی جواب بده: «من به دنیا آشکارا حرف بزم و همیشه کنیسه و معبده میأن کی یهودیأن اویه جمعَ بیدی، تعلیم بدَم و چیزی‌یه مخفیأنه نوگفتم.  
\v 21 چره از من وَورسی؟ از اوشأنی وَورس کی می حرفأنه بیشنَوستیدی؛ اوشأن بهتر دأنیدی کی من اوشأنه چی بوگفتم.»   
\p
\v 22 وختی اَنه بوگفته، ایتأ از قراولأن کی اویه ایسه بو، ایتأ سیلی اونه صورته بزه و بوگفته: «اَطو کاهنِ اعظمِ جواب دیهی؟»   
\p
\v 23 عیسی جواب بده: «اگر خطا بوگفتم، بر می خطا شهادت بدَن، امّا اگر راست بوگفتم، چره مره زنی؟»   
\p
\v 24 اون وخت حَنّا اونه با دسته دَوَسته اوسه کوده قیافا کاهنِ اعظمِ ورجه.   
\s1 پِطرُس عیسایه بازم انکار کونه  
\p
\v 25 موقعی کی شَمعونِ پِطرُس ایسه بو و خودشه گرمه کودن دوبو، بعضی‌یأن اونه بوگفتیدی: «مگر تو از اونه شاگردأن نی‌یی؟»  
\p اون انکار بوکوده و بوگفته: «نه! نی‌یم.»   
\p
\v 26 ایتأ از خادمأنه کاهنِ اعظم اویه ایسه بو. اون از بستگأنه کسی بو کی پِطرُس اونه گوشِ وَوِه بو، بوگفته: «مگر من خودم تره اونه اَمره او باغه میأن نیدم؟»  
\v 27 پِطرُس بازم انکار بوکوده. هو لحظه ایتأ خروس بخوأنده.   
\s1 عیسی محاکمه در حضوره پیلاتُس  
\p
\v 28 یهودیأن عیسایه از قیافا ورجه به کاخِ فرمانداره رومی ببردیدی. وخته سحر بو. اوشأن خودشأن وارده کاخ نوبوستیدی تا نجسته نیبید و بتأنید پِسَخَ بوخورید.  
\v 29 پس پیلاتُس اوشأنه ورجه بَمو و وَورسه: «اَ مردَ به چی جُرمی متهم کونیدی؟»   
\p
\v 30 جواب بدَییدی و بوگفتیدی: «اگر جُرمی نأشتی، اونه به تو تسلیمه نوکودیم.»   
\p
\v 31 پیلاتُس اوشأنه بوگفته: «شومأن خودتأن اونه ببرید و طبقِ شیمی شریعت اونه محاکمه بوکونید.»  
\p یهودیأن بوگفتیدی: «اَمأن اجازه نأریم کسی‌یه اعدام بوکونیم.»  
\v 32 به اَ طریق عیسی حرفأن در مورده اَنکی چی جور مرگی در انتظاره اونه، ثابته به.   
\p
\v 33 پس پیلاتُس به کاخ وأگردسته و عیسایه دوخوأده و اونه بوگفته: «آیا تو پادشایه یهودی؟»   
\p
\v 34 عیسی جواب بده: «آیا اَنه تو خودت گی، یا دیگرأن درباره‌یه من تره بوگفتیدی؟»   
\p
\v 35 پیلاتُس جواب بده: «مگر من یهودی‌یم؟ تی قوم و سرأنه کاهنأن تره به من تسلیم بوکودیدی. مگر چی بوکودی؟»   
\p
\v 36 عیسی جواب بده: «می پادشاهی از اَ دنیا نی‌یه. اگر می پادشاهی از اَ دنیا بو، می خادمأن جنگستیدی تا من به دسته یهودیأن دستگیره نبم. امّا می پادشاهی از اَ دنیا نی‌یه.»   
\p
\v 37 پیلاتُس اونه بوگفته: «پس تو پادشاهی؟»  
\p عیسی جواب بده: «تو خودت گی کی من پادشاهم. من هَنه وستی به دنیا بَموم تا حقیقته شهادت بدَم. پس هر کسی کی به حقیقت تعلّق دأره، می صدایه گوش کونه.»   
\p
\v 38 پیلاتُس بوگفته: «حقیقت چیسه؟»  
\s1 حکمه مصلوب بوستنه عیسی  
\p وختی پیلاتُس اَنه بوگفته، بازم بوشو بیرون یهودیأنه ورجه و اوشأنه بوگفته: «من هیچ دلیلی اونه محکوم کودنه‌ره نیدینم.  
\v 39 امّا شومأن ایتأ رسم دأریدی کی در روزِ پِسَخ ایتأ زندانی‌یه شمره آزاده کونم. آیا خوأییدی کی پادشاه یهوده آزاده کونم؟»   
\p
\v 40 اوشأن در جواب، داد بزه‌ییدی: «اونه نه! بلکی بارْاَبّایه آزاده کون!» (بارْاَبّا راهزن بو.)   
\c 19  
\p
\v 1 اون وخت پیلاتُس دستور بده عیسایه شلاق بزنید.  
\v 2 و سربازأن، تاجی از خار ببافتیدی و اونه سر بنَه‌ییدی و لیباسی ارغوانی رنگ اونه دوکودیدی.  
\v 3 و اونه ورجه اَموییدی و گفتیدی: «سلام بر تو، ای پادشایه یهود.» و اونه سیلی زه‌ییدی.   
\p
\v 4 بعد از اون، پیلاتُس ایبارِ دیگر بیرون بَمو و یهودیأنه بوگفته: «من اونه شیمی ورجه بیرون اَورم تا بدأنید کی هیچ دلیلی اونه محکوم کودنه‌ره پیدا نوکودم.»  
\v 5 پس عیسی، تاجه خار و لیباسه ارغوانی اَمره، بیرون بَمو. پیلاتُس اوشأنه بوگفته: «اَنه، او شخص!»   
\p
\v 6 وختی سرأنه کاهنأن و قراولأنه معبد اونه بیده‌ییدی فریاد بزه‌ییدی و بوگفتیدی: «مصلوبه کون! مصلوبه کون!»  
\p پیلاتُس اوشأنه بوگفته: «شومأن خودتأن اونه ببرید و مصلوبه کونید، چون من هیچ دلیلی اونه محکوم کودنه‌ره پیدا نوکودم.»   
\p
\v 7 یهودیأن در جوابه اون بوگفتیدی: «اَمأن شریعتی دأریم کی طبقِ اون، اَ شخص بأید بیمیره، چونکی ادعا کونه خدا پسره!»   
\p
\v 8 وختی پیلاتُس اَنه بیشنَوسته، بیشتر بترسه.  
\v 9 بازم به کاخ وأگردسته و از عیسی وَورسه: «تو از کویه بَمویی؟» امّا عیسی اونه جوابی نده.  
\v 10 پس پیلاتُس اونه بوگفته: «مره هیچی نیگی؟ آیا نأنی کی قدرت دأرم تره آزاده کونم و قدرت دأرم کی تره مصلوبه کونم؟»   
\p
\v 11 عیسی بوگفته: «هیچ قدرتی بر من نأشتی، مگر اینکه از بوجور، فیگیفته بی ولی گناهه اونی کی مره به تو تسلیم بوکوده از تو بیشتره.»   
\p
\v 12 بعد از اون، پیلاتُس سعی بوکوده کی اونه آزاده کونه، امّا یهودیأن فریاد زه‌ییدی و گفتیدی: «اگر اَ مردَ آزاده کونی، قیصرِ دوست نی‌یی! هر کی ادعایه پادشاهی کونه، به ضده قیصر حرف زنه.»   
\p
\v 13 وختی پیلاتُس اَ حرفأنه بیشنَوسته، عیسایه بیرون بأورده و خودش بر مسنده داوری بینیشته، در محلی کی به «سنگه فرش» معروف بو و به زبانه عبرانیأن «جَبّاتا» گفتیدی.  
\v 14 او روز، روزِ «تهیه» عیده پِسَخ بو و ظهر نزدیک بو. پیلاتُس یهودیأنه بوگفته: «اَنه شیمی پادشاه!»   
\p
\v 15 اوشأن فریاد بزه‌ییدی: «اونه از میأن اوسَن! اونه از میأن اوسَن. اونه مصلوبه کون!»  
\p پیلاتُس بوگفته: «آیا شیمی پادشایه مصلوبه کونم؟»  
\p سرأنه کاهنأن جواب بدَییدی: «اَمأن پادشاهی جز قیصر نأریم.»   
\p
\v 16 سر آخر پیلاتُس عیسایه به اوشأن بیسپرده تا اونه مصلوبه کونید.  
\s1 عیسی به صلیب کشن  
\p اون وخت عیسایه بیگیفتیدی و ببردیدی.  
\v 17 عیسی صلیب به دوش بیرون بوشو، به سمته محلی به نامِ جمجمه کی به زبانه عبرانیأن جُلجُتا خوأنده به.  
\v 18 اویه اونه به صلیب بکشه‌ییدی. اونه اَمره دو نفر دیگرم، اونه دو طرف مصلوبه کودیدی و عیسی اوشأنه میأن قرار دأشتی.  
\v 19 به دستوره پیلاتُس ایتأ نیویشته اونه صلیبه جور نصب بوکودیدی، کی اونه رو بینیویشته بوبوسته بو: «عیسایه ناصری، پادشایه یهود.»  
\v 20 خیلی از یهودیأن او نیویشته‌یه بخوأندیدی، چون جایی کی عیسایه به صلیب بکشه‌ییدی، نزدیک به شهر بو و او نیویشته به زبانه عبرانیأن و لاتینی و یونانی بو.   
\p
\v 21 پس سرأنه کاهنأنه یهود پیلاتُسَ بوگفتیدی: «نینیویس، ‹پادشاه یهود›، بلکی بینیویس اَ مرد بوگفته کی من پادشاه یهودم.»   
\p
\v 22 پیلاتُس جواب بده: «اونچی بینیویشتم، بینیویشتم.»   
\p
\v 23 وختی سربازأن عیسایه به صلیب بکشه‌ییدی، اونه لیباسأنه اوسَدیدی و به چهارتأ قسمت تقسیم بوکودیدی. هر کدام ایتأ تیکه اوسَدیدی. اونه لیباسه زیرَ هم فیگیفتید. امّا او لیباس درز نأشتی، بلکی یکسره از بوجور به بیزیر ببافته بوبوسته بو.  
\v 24 پس همدیگره بوگفتیدی: «اَنه تیکه تیکه نوکونیم، بلکی قرعه تَوَدیم و بیدینیم کی‌شین به.» اَطویی پیشگویی‌یه کیتابه مقدّس ثابته به کی:  
\q1 «می لیباسأنه خوشأنه میأن تقسیم کونیدی  
\q2 و می لیباسأنه‌ره قرعه تَوَدیدی.» \x * \xo 19.24 \xt تورات، کیتابه مزمور، بابه ۲۲ آیه ۱۸. \x*  
\m پس سربازأن هوطو بوکودیدی.   
\p
\v 25 عیسی صلیبه نزدیکی اونه مار و اونه خألأ و مریم کْلوپاسِ زن و مریمِ مَجْدَلیّه ایسه بید.  
\v 26 وختی عیسی خو مار و او شاگردی‌یه کی دوست دأشتی و اونه کنار ایسه بو، بیده، خو ماره بوگفته: «بانو، اَنه، تی پسر!»  
\v 27 بعد از اَن او شاگرده بوگفته: «اَنه، تی مار!» از او ساعت، او شاگرد، عیسی ماره خودشه خانه ببرده.   
\s1 عیسی مَردن  
\p
\v 28 اون وخت عیسی دأنستی کی همه چیز به انجام برسه؛ بوگفته: «تشنه‌یم!» به اَ خاطر بوگفته تا پیشگویی‌یه کیتابه مقدّس ثابت ببه.  
\v 29 در اویه ظرفی نَهه بو پُر از شرابه ترشیده. پس اسفنجی‌یه به او شراب بزه‌ییدی و بنَه‌ییدی ایتأ شاخه سر و اونه دهأنِ ورجه ببردیدی.  
\v 30 وختی عیسی شرابه بیچیشته، بوگفته: «به انجام برسه.» بعد از اون، خو سره خمه کوده و خو روحه تسلیم بوکوده.   
\p
\v 31 او روز، روزِ «تهیه» بو، و روزِ بعد، شَبّاتِ بزرگ. از اویه کی حاکمأنه یهود نخوأستیدی کی جسدأن، تا روزِ بعد صلیبه رو بمأنه، از پیلاتُس بخوأستیدی کی او سه نفره ساقِ پایه بشکنید و اوشأنه جسدأنه از صلیب بیزیر بأورید.  
\v 32 پس سربازأن بَموییدی و اوّلین نفره ساقِ پا و اویتأ ساقِ پایه کی عیسی اَمره به صلیب بکشه بید، بشکنه‌ییدی.  
\v 33 امّا وختی به عیسی فَرسه‌ییدی، بیده‌ییدی کی بمَرده، اونه ساقأنه نشکنه‌ییدی.  
\v 34 امّا ایتأ از سربازأن نیزه‌یه اونه پهلویه بزه و هو لحظه از اونه بدن خون و آب جاری بوبوسته.  
\v 35 اونی کی اَنه بیده شهادت دهه، تا شومأنم ایمأن بأورید. اونه شهادت راسته و اون دأنه کی حقیقته گفتن دره.  
\v 36 اَشأن رخ بده تا پیشگویی‌یه کیتابه مقدّس ثابت ببه کی: «هیچ‌کدام از اونه استخوأنأن نشکفه.» \x * \xo 19.36 \xt تورات، کیتابه خروج، بابه ۱۲، آیه ۴۶؛ کیتابه اعداد، بابه ۹، آیه ۱۲؛ کیتابه مزمور، بابه ۳۴، آیه ۲۰. \x*  
\v 37 و قسمتی دیگرم از کیتابه مقدّس کی گه: «اونی‌یه کی به اون نیزه بزه‌ییدی، تماشا کونیدی.» \x * \xo 19.37 \xt تورات، کیتابه زکریا، بابه ۱۲، آیه ۱۰. \x*   
\s1 عیسی دفنه کودن  
\p
\v 38 اون وخت یوسف، اهله رامه، از پیلاتُس اجازه بخوأسته کی عیسی جسده فیگیره. یوسف از پیروأن عیسی بو، امّا مخفیأنه. چونکی از حاکمأنه یهود ترسه‌یی. پیلاتُس اونه اجازه بده. پس بَمو و عیسی جسده فیگیفته.  
\v 39 نیقودیموسم کی قبلاً شبأنه عیسی ورجه بوشو بو، بَمو و خو اَمره عطری از مُر و عود کی حدوده سی و پنج کیلو بو، بأورده.  
\v 40 پس اوشأن عیسی جسده فیگیفتیدی و اونه به رسمه دفنه یهودیأن عطریاته اَمره کفنه میأن بپیچَنیدی.  
\v 41 نزدیکه او جایی کی عیسی مصلوبه بوسته، باغی بو کی او باغه میأن مقبره‌یی تازه وجود دأشتی کی هنوز مُرده‌یی در اون ننَه بید.  
\v 42 پس چونکی روزِ «تهیه» یهودیأن بو و او مقبره‌یم نزدیک بو، عیسی جسده در اویه بنَه‌ییدی.   
\c 20  
\s1 قبره خالی  
\p
\v 1 در اوّلین روزِ هفته، وخته سحر، زمانی کی هوا هنوز تاریک بو، مریم مَجْدَلیّه مقبره ورجه بوشو و بیده کی اونه سنگ اوسَده بوبوسته.  
\v 2 پس بدو بدو بوشو شَمعونِ پِطرُسِ ورجه و او شاگرده دیگری کی عیسی، اونه دوست دأشتی. مریم اوشأنه بوگفته: «اَمی سروره از قبر ببردیدی و نأنیم کویه بنَه‌ییدی.»  
\v 3 پس پِطرُس اویتأ شاگرده اَمره بیرون بَمو و بوشوییدی به سمته مقبره.  
\v 4 هر دوتأ دووَستیدی، امّا اویتأ شاگرد تندتر بوشو، از پِطرُس پیش دکفته و اوّل اون به مقبره فَرسه.  
\v 5 پس خمه بوسته و بیده کی پارچه‌یه کفن اویه نَهه. امّا مقبره دورون نوشو.  
\v 6 پس شَمعونِ پِطرُسم، اونه دونبالسر بَمو و مقبره دورون بوشو و بیده کی پارچه کفنی اویه نَهه،  
\v 7 امّا او دستمالی کی عیسی سر دَوَسته بید، پارچه‌یه کفنی کنار ننَه بو، بلکی جدا و تا بوبوسته جایی دیگر نَهه بو.  
\v 8 پس او شاگرده دیگرم کی اوّل به مقبره فَرسه بو، بوشو بودورون، بیده و ایمأن بأورده.  
\v 9 چونکی هنوز کیتابه مقدّسه درک نوکوده بید کی اون بأید از مُرده‌یأنه میأن ویریزه.  
\v 10 اون وخت او دوتأ شاگرد خوشأنه خانه وأگردستیدی.   
\s1 ظاهر بوستنه عیسی به مریمه مَجْدَلیّه  
\p
\v 11 ولی مریم بیرونه مقبره ایسه بو و گریه کودی. اون گریه اَمره خمه بوسته تا مقبره دورونه نیگاه بوکونه.  
\v 12 نیگاه بوکوده و دوتأ فرشته‌یه بیده کی لیباسه سفید، دوکوده بید، او جایی کی عیسی جسده بنَه بید، ایتأ سره ورجه و اویتأ پا ورجه نیشته بید.  
\v 13 اوشأن اونه بوگفتیدی: «ای زن، چره گریه کونی؟»  
\p جواب بده: «می سروره ببردیدی و نأنم کویه بنَه‌ییدی.»   
\p
\v 14 وختی اَنه بوگفته وأگردسته و عیسایه اویه سرپا بیده، ولی نشنأخته.  
\v 15 عیسی اونه بوگفته: «ای زن، چره گریه کونی؟ کی دونبال گردی؟»  
\p مریم به خیال اَنکی باغبأنه، بوگفته: «ای سرور، اگر تو اونه اوسَدی مره بوگو کویه بنَه‌یی تا بشم و اونه اوسَنم.»   
\p
\v 16 عیسی دوخوأده: «مریم!»  
\p مریم خو رویه اونه طرف وأگردأنه و به زبانه عبرانیأن بوگفته: «رَبّونی!» (یعنی اوستاد).   
\p
\v 17 عیسی اونه بوگفته: «مره وله کون، چونکی هنوز می پئره ورجه بوجور نوشوم. بلکی می برأرأنه ورجه بوشو و اوشأنه بوگو، می پئر و شیمی پئره ورجه و می خدا و شیمی خدا ورجه بوجور شوئون درم.»   
\p
\v 18 مریم مَجْدَلیّه بوشو و شاگردأنه خبر بده کی: «خداونده بیدم!» و اونچی کی بوگفته بو، اوشأنه بوگفته.   
\s1 ظاهر بوستنه عیسی به شاگردأن  
\p
\v 19 هو روز غروب کی یکشمبه بو، وختی کی شاگردأن جمعَ بوسته بید و درأن از ترسه حاکمأنه یهود قفل بو، عیسی بَمو و اوشأنه میأن بِیسه و بوگفته: «سلام بر شومأن!»  
\v 20 وختی اَنه بوگفته، خو دستأنه و خو پهلویه اوشأنه نیشأن بده. شاگردأن با خداونده دِئن شاده بوستیدی.  
\v 21 عیسی بازم اوشأنه بوگفته: «سلام بر شومأن! هوطو کی پئر مره اوسه کوده، منم شمره اوسه کونم.»  
\v 22 وختی اَ حرفه بوگفته، شاگردأنه رو فوت بوکوده و بفرمأسته: «روح‌القدسه فیگیرید.  
\v 23 اگر کسی گناهأنه ببخشید، اونه‌ره بخشیده به، و اگر کسی گناهأنه نبخشید اونه‌ره، بخشیده نیبه.»   
\s1 عیسی و توما  
\p
\v 24 وختی کی عیسی بَمو، توما، ایتأ از اون دوازده نفر کی دوقولویم اونه دوخوأدیدی، اوشأنه اَمره نوبو.  
\v 25 پس شاگردأنه دیگر اونه بوگفتیدی: «خداونده بیده‌ییم!» امّا اون اوشأنه بوگفته: «تا خودم جایه میخه اونه دستأنه میأن نیدینم و می انگوشته اونه جایه میخ نَنم و می دسته اونه پهلو سوراخه میأن نَنم، ایمأن نأورم.»  
\v 26 بعد از یک هفته، عیسی شاگردأن، بازم خانه میأن ایسه بید و تومایم اوشأنه اَمره بو. در حالی کی درأن قفل بید عیسی بَمو و اوشأنه میأن بِیسه و بوگفته: «سلام بر شومأن!»  
\v 27 اون وخت تومایه بوگفته: «تی انگوشته اَیه بنَه و می دستأنه بیدین. تی دسته جلو بأور و می پهلو سوراخه میأن بنَه. بی‌ایمأن نوبو، بلکی ایمأن بدأر.»   
\p
\v 28 توما اونه بوگفته: «می خداوند! می خدا!»   
\p
\v 29 عیسی بوگفته: «آیا چونکی مره بیده‌یی، ایمأن بأوردی؟ خوش بحال اوشأنی کی نیده‌ییدی، ایمأن بأوردیدی.»   
\s1 اَ کیتابه هدف  
\p
\v 30 عیسی معجزاته زیاده دیگری در حضور خو شاگردأن انجام بده کی اَ کیتابه میأن بینیویشته نوبوسته.  
\v 31 ولی اَنقدر بینیویشته بوبوسته تا ایمأن بأورید کی عیسی هو مسیح، و خدا پسره، و به توسطه اَ ایمأن صاحبه زندگی‌یه اَبدی بیبید.   
\c 21  
\s1 ظاهر بوستنه عیسی به هفتأ از شاگردأن  
\p
\v 1 بعد از اَ اتفاقأن، عیسی بارِ دیگر خودشه در کنار دریاچه تیبِریه، به خو شاگردأن آشکاره کوده. اون اَطو ظاهره بوسته:  
\v 2 ایتأ روز، شَمعونِ پِطرُس، تومایه معروف به دوقولو، نَتَنائیل از مردمأنه قانایه جلیل، زِبِدی پسرأن، و دوتأ از شاگردأنه دیگرم با هم بید.   
\p
\v 3 شَمعونِ پِطرُس اوشأنه بوگفته: «من شوئون درم ماهی صید بوکونم.»  
\p اوشأن بوگفتیدی: «اَمأنم تی اَمره اَییم.» پس بیرون بوشوییدی و قایقه سوارَ بوستیدی. امّا او شب هر چقدر تور تَوَدیدی، چیزی صید نوکودیدی.   
\p
\v 4 وخته سحر، عیسی ساحله کنار بِیسه، امّا شاگردأن نفهمستیدی کی عیسایه.  
\v 5 اون اوشأنه بوگفته: «ای زأکأن، چیزی خوردنه‌ره نأریدی؟»  
\p جواب بدَییدی: «نه!»   
\p
\v 6 بوگفته: «توره به طرفه راسته قایق تَوَدید، تأنیدی بیگیرید.» اوشأن اَ کاره بوکودیدی و از زیادی ماهی نتأنستیدی توره قایقه دورون فکشید.   
\p
\v 7 شاگردی کی عیسی اونه دوست دأشتی، پِطرُسَ بوگفته: «اون خداونده!» وختی شَمعونِ پِطرُس بیشنَوسته اون خداونده، خو لیباسه خو دور دَوَسته - چونکی اونه از خو تن بیرون بأورده بو و خودشه دریا میأن تَوَدَه.  
\v 8 امّا شاگردأنه دیگر قایقه اَمره بَموییدی، در حالی کی تور پُر از ماهی‌یه، خوشأنه اَمره فکشن دیبید. چونکی اوشأنه فاصله ساحله اَمره حدوده صد متر بو.   
\p
\v 9 وختی به ساحل فَرسه‌ییدی، آتشی‌یه بیده‌ییدی کی زغاله اَمره چأکوده بوسته بو و ماهی‌یم اونه رو و نانم اویه نَهه بو.   
\p
\v 10 عیسی اَشأنه بوگفته: «از او ماهی‌یأنی کی الأن بیگیفتیدی، بأورید.»  
\v 11 شَمعونِ پِطرُس وارده قایق بوبوسته و توره به طرفه ساحل فکشه. تور پُر از پیله ماهی بو، به تعداده صد و پنجاه و سه‌تأ ماهی. با اَنکی تعداده ماهی بیش از حد بو، تور پاره نوبوسته.   
\p
\v 12 عیسی اَشأنه بوگفته: «بأیید ناشتأیی بوخورید.» هیچ‌کدام از شاگردأن جرأت نوکودیدی از اون وَورسید «تو کی ایسی؟» چونکی دأنستیدی کی اون خداونده.  
\v 13 عیسی جلو بَمو و نانه اوسَده و اوشأنه فده و ماهی‌یم هَطو.  
\v 14 اَن سوّمین بار بو کی عیسی بعد از ویریشتن از مُرده‌یأنه میأن، به خو شاگردأن ظاهره بوسته.   
\s1 عیسی گفتگو پِطرُسِ اَمره  
\p
\v 15 بعد از ناشتأیی، عیسی از شَمعونِ پِطرُس وَورسه: «ای شَمعون، یوحنا پسر، آیا مره بیشتر از اَشأن دوست دأری؟»  
\p اون جواب بده: «بله ای خداوند! تو دأنی کی تره دوست دأرم!»  
\p عیسی اونه بوگفته: «از می گوسفندأن مراقبت بوکون.»   
\p
\v 16 دوّمین بار عیسی از اون وَورسه: «ای شَمعون، یوحنا پسر، آیا مره دوست دأری؟»  
\p اون جواب بده: «بله ای خداوند! دأنی کی تره دوست دأرم!»  
\p عیسی بوگفته: «از می گوسفندأن مراقبت بوکون.»   
\p
\v 17 سوّمین بار اونه بوگفته: «ای شَمعون، یوحنا پسر، آیا مره دوست دأری؟»  
\p پِطرُس از اَنکی عیسی سه بار از اون وَورسه کی «آیا مره دوست دأری؟» ناراحته بوسته و جواب بده: «ای خداوند! تو از همه چیز باخبری. تو دأنی کی تره دوست دأرم.»  
\p عیسی بوگفته: «از می گوسفندأن مراقبت بوکون.  
\v 18 آمین، آمین، تره گم، زمانی کی جوانتر بی، تی کمره دَوَستی و هر جا کی خوأستی شویی؛ امّا وختی کی پیره بی، تی دستأنه درازه کونی و کسی دیگر تی کمره دَوَده و به جایی کی نخوأیی بیشی، تره بره.»  
\v 19 عیسی اَ حرفأنه اَمره اشاره به چوطو مَردنه پِطرُس کودی کی اونه اَمره خدایه جلال دهه. بعد از اون، عیسی اونه بوگفته: «می دونبالسر بیأ!»   
\p
\v 20 اون وخت پِطرُس وأگردسته و بیده کی او شاگردی کی عیسی اونه دوست دأشتی، اونه دونبالسر اَمون دره. اون هونی بو کی شامِ موقع عیسی سینه سر تکیه بده بو و وَورسه بو کی: «سرورم، کی‌یه کی تره تسلیم کونه؟»  
\v 21 وختی پِطرُس اونه بیده، از عیسی وَورسه: «پس اون چی به؟»   
\p
\v 22 عیسی اونه بوگفته: «اگر بخوأیم اون تا می وأگردستن، زنده بمأنه، به تو چی؟ تو می دونبال بیأ!»  
\v 23 پس اَ فکر، برأرأنه میأن شایع بوبوسته کی او شاگرد نیمیره، در حالی کی عیسی پِطرُسَ نوگفته کی اون نیمیره، بلکی بوگفته: «اگر بخوأیم اون تا می وأگردستن، زنده بمأنه، به تو چی؟»   
\p
\v 24 هو شاگرده کی بر اَ چیزأن شهادت دهه، و اَشأنه بینیویشته و اَمأن دأنیم کی اونه شهادت راسته.   
\s1 در آخر  
\p
\v 25 عیسی کارأیه زیاد دیگری‌یم بوکوده، کی اگر دانه دانه بینیویشته بوبوسته بید، گومان نوکونم حتی تمام دنیایم گنجایشه اونه نیویشته‌یأنه بدأشته بی.   