\v 17 \w Pero|strong="G1161"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w* estuvo presente \w y|strong="G2532"\w* \w me|strong="G1473"\w* fortaleció \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w yo|strong="G1473"\w* cumpliera \w la|strong="G3588"\w* \w predicación|strong="G2782"\w*, \w y|strong="G2532"\w* \w que|strong="G3588"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* gentiles oyeran. Fui librado \w de|strong="G1537"\w* \add la\add* \w boca|strong="G4750"\w* \w del|strong="G3588"\w* \w león|strong="G3023"\w*.  
\v 18 \w El|strong="G3588"\w* \w Señor|strong="G2962"\w* \w me|strong="G1473"\w* \w librará|strong="G4506"\w* \w de|strong="G1519"\w* \w toda|strong="G3956"\w* \w obra|strong="G2041"\w* \w mala|strong="G4190"\w* \w y|strong="G2532"\w* \w me|strong="G1473"\w* \w preservará|strong="G4982"\w* \w para|strong="G1519"\w* \w su|strong="G3588"\w* reino \w celestial|strong="G2032"\w*. \w A|strong="G1519"\w* \w Él|strong="G3588"\w* \w sea|strong="G3588"\w* \w la|strong="G3588"\w* \w gloria|strong="G1391"\w* \w por|strong="G1519"\w* \w los|strong="G3588"\w* siglos \w de|strong="G1519"\w* \w los|strong="G3588"\w* siglos. Amén.   
\s1 Despedida  
