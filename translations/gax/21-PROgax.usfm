\q2 nama ifi gad qabee 
\q2 hojjataa te'ee le'u woyya. 
\q1  
\v 10 Nami balchaan horii ifiitiif hin marara; 
\q2 nami hamaan 
\q2 ammoo yennaa mara gadhaa jabaata. 
\q1  
\v 11 Nami jabaatee lafa qotu sagalee bacaa hin qabaata; 
\q2 ka waan bu'aa hin qanne ari'u ammoo gowwa'a. 
\q1  
\v 12 Nami hamaan waan worri hamaan saame kajeela; 
\q2 nami balchaan ammoo horee bacata. 
\q1  
\v 13 Nami hamaan jechuma hamaa ifiitiin qabama; 
\q2 nami balchaan ammoo rakkinna jalaa hin baya. 
\q1  
\v 14 Nami waan afaan isaa keessaa bayuun 
\q2 waan dansaa quufa; 
\q2 akkuma hujii harka ifiititti gatii isaaf malte fudhata. 
\q1  
\v 15 Nama gowwaa karaan isaa qajeelaa itti fakkaata; 
\q2 nami qaroon ammoo gorsa caqasa. 
\q1  
\v 16 Aariin nama gowwa'aa yoosuma beekkanti; 
\q2 nami qalbeeffataan ammoo 
