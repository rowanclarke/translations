\v 28 \w Te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* \w perdones|strong="H5375"\w* \w la|strong="H3588"\w* transgresión \w de|strong="H3588"\w* \w tu|strong="H6213"\w* esclava, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w ciertamente|strong="H3588"\w* dará \w una|strong="H4672"\w* \w casa|strong="H1004"\w* segura \w a|strong="H3068"\w* \w mi|strong="H5375"\w* \tl ʼadón\tl*. \w Porque|strong="H3588"\w* \w mi|strong="H5375"\w* \tl ʼadón\tl* \w pelea|strong="H3898"\w* las \w batallas|strong="H4421"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* iniquidad \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w hallará|strong="H4672"\w* \w en|strong="H3588"\w* ti \w en|strong="H3588"\w* todos tus \w días|strong="H3117"\w*.
\v 29 Aunque un hombre \w se|strong="H1961"\w* \w levantó|strong="H6965"\w* \w para|strong="H1961"\w* perseguirte y buscar tu \w vida|strong="H5315"\w*, la \w vida|strong="H5315"\w* de \w mi|strong="H1961"\w* \tl ʼadón\tl* \w está|strong="H1961"\w* bien \w atada|strong="H6887"\w* \w en|strong="H8432"\w* el manojo de la \w vida|strong="H5315"\w* junto \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, mientras Él quita la \w vida|strong="H5315"\w* \w a|strong="H3068"\w* tus enemigos \w como|strong="H1961"\w* por \w medio|strong="H8432"\w* de una honda.
\v 30 \w Acontecerá|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w haga|strong="H6213"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \tl ʼadón\tl* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w bien|strong="H2896"\w* \w que|strong="H3588"\w* \w te|strong="H5921"\w* \w dijo|strong="H1696"\w* \w y|strong="H3588"\w* \w te|strong="H5921"\w* constituya \w como|strong="H3588"\w* soberano \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*,
\v 31 \w esto|strong="H2063"\w* \w no|strong="H3808"\w* causará pesar \w ni|strong="H3808"\w* remordimiento \w a|strong="H3068"\w* \w mi|strong="H1961"\w* \tl ʼadón\tl* por \w haber|strong="H1961"\w* \w derramado|strong="H8210"\w* \w sangre|strong="H1818"\w* \w sin|strong="H3808"\w* causa, \w o|strong="H3068"\w* \w que|strong="H3808"\w* \w mi|strong="H1961"\w* \tl ʼadón\tl* \w se|strong="H1961"\w* vengó por él mismo. \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* \nd \w Yavé|strong="H3068"\w*\nd* favorezca \w a|strong="H3068"\w* \w mi|strong="H1961"\w* \tl ʼadón\tl*, \w acuérdate|strong="H2142"\w* \w de|strong="H1818"\w* tu esclava.
\p 
\v 32 \w Entonces|strong="H3117"\w* \w David|strong="H1732"\w* dijo \w a|strong="H3068"\w* Abigail: ¡\w Bendito|strong="H1288"\w* sea \nd \w Yavé|strong="H3068"\w* ʼElohim\nd* de \w Israel|strong="H3478"\w*, \w que|strong="H3117"\w* te \w envió|strong="H7971"\w* \w hoy|strong="H3117"\w* \w a|strong="H3068"\w* encontrarme!
