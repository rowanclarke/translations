\id SNG
\h GABAYGII SULAYMAAN
\mt1 GABAYGII
\mt1 SULAYMAAN
\c 1
\q1 
\v 1 Kanu waa gabaygii gabayada ee Sulaymaan.
\sp Gacalisada Hadlaysaa
\q1 
\v 2 Isagu ha igu dhunkado dhunkashooyinka afkiisa;
\q1 Waayo, jacaylkaagu xataa khamri wuu ka sii macaan yahay.
\q1 
\v 3 Saliiddaadu caraf wanaagsan bay leedahay,
\q1 Oo magacaaguna waa sida saliidcadar la shubay,
\q1 Oo sidaas daraaddeed baa habluhu kuu jecel yihiin.
\q1 
\v 4 I soo jiido, waannu kaa daba ordaynaaye.
\q1 Boqorkii wuxuu i soo geliyey qolladihiisii.
\sp Saaxiibadaha Hadlayaa
\q1 Annagu waannu kugu farxi doonnaa, oo waannu kugu rayrayn doonnaa,
\q1 Oo jacaylkaagana waxaannu u sii xusuusan doonnaa in khamri ka sii badan.
\sp Gacalisada Hadlaysaa
\q1 Si qumman ayay kuu jecel yihiin.
\q1 
\v 5 Gabdhaha reer Yeruusaalemow,
\q1 Anigu waan madoobahay, laakiinse waan u qurxoonahay
\q1 Sida teendhooyinkii reer Qedaar
\q1 Iyo sida daahyadii Sulaymaan.
\q1 
\v 6 Ha ii soo dhuganina madowgayga qorraxdu i gubtay aawadiis.
\q1 Wiilashii hooyaday ayaa ii cadhooday,
\q1 Oo waxay iga dhigeen ilaaliyihii beeraha canabka ah,
\q1 Laakiinse beertayda canabka ah ma aan dhawrayn.
\q1 
\v 7 Kan naftaydu jeceshahayow, ii sheeg
\q1 Meesha aad adhigaaga daajisid, iyo meesha aad hadhkii hadhisid;
\q1 Waayo, bal maxaan u ahaanayaa
\q1 Sida mid ag wareegta adhyaha saaxiibbadaa?
\sp Saxiibadaha Hadlayaa
\q1 
\v 8 Taada naagaha ugu qurux badanay, haddaadan aqoon,
\q1 Waxaad daba gashaa adhiga raadkiisa,
\q1 Oo waxaad waxarahaaga ag daajisaa teendhooyinka adhijirrada.
\sp Gacaliyaha Hadlayaa
\q1 
\v 9 Taan jeclahayay, waxaan kugu masaalay
\q1 Faras ka mid ah fardihii gaadhifardoodyadii Fircoon.
\q1 
\v 10 Dhabannadaadu waxay la qurxoon yihiin timo tidcan,
\q1 Oo qoortaaduna laasimmo jowharad ah.
\q1 
\v 11 Waxaannu kuu samaynaynaa silsilado dahab ah
\q1 Oo lacag laga taagay.
\sp Gacalisada Hadlaysaa
\q1 
\v 12 Inta boqorku miiskiisii fadhiyey,
\q1 Ayaa cadarkaygii naaradiinka ahaa caraftiisu soo baxday.
\q1 
\v 13 Gacaliyahaygu wuxuu ii yahay sida guntin malmal ah
\q1 Oo habeenkii oo dhan naasahayga ku dhex jirta.
\q1 
\v 14 Gacaliyahaygu wuxuu ii yahay sida xidhmo ubax xinne ah
\q1 Oo beeraha canabka ah ee Ceyn Gedii ku yaal.
\sp Gacaliyaha Hadlayaa
\q1 
\v 15 Taan jeclahayay, bal eeg, adigu waad qurxoon tahay, bal eeg, waad qurxoon tahay,
\q1 Oo waxaad leedahay indhaha qoolleyda oo kale.
\sp Gacalisada Hadlaysaa
\q1 
\v 16 Gacaliyahaygow, bal eeg, adba waad qurxoon tahay, waanad wacan tahay,
\q1 Oo weliba sariirteennuna waa cagaar.
\sp Gacaliyaha Hadlayaa
\q1 
\v 17 Alwaaxda gurigeennu waa qoryo kedar ah,
\q1 Oo saqafkeennuna waa qoryo beroosh ah.
\c 2
\sp Gacalisada Hadlaysaa
\p 
\v 1 Anigu waxaan ahay ubaxnarjiska Shaaroon,
\q1 Iyo ubaxshooshanka dooxooyinka.
\sp Gacaliyaha Hadlayaa
\q1 
\v 2 Sida ubaxshooshanku qodxanta ku dhex yahay,
\q1 Ayay taan jeclahayna gabdhaha ku dhex tahay.
\sp Gacalisada Hadlaysaa
\q1 
\v 3 Sida geedka tufaaxa ahu uu dhirta duurka ku dhex yahay,
\q1 Ayuu gacaliyahayguna wiilasha ku dhex yahay.
\q1 Hooskiisaan fadhiistay anigoo aad u faraxsan,
\q1 Oo midhihiisuna way ila dhadhan macaanaayeen.
\q1 
\v 4 Wuxuu i keenay guriga diyaafadda,
\q1 Oo calankiisii i kor sudhnaana wuxuu ahaa jacayl.
\q1 
\v 5 Sabiib igu quudi, oo tufaax igu noolee,
\q1 Waayo, anigu caashaq baan la bukaa.
\q1 
\v 6 Gacantiisa bidix madaxaygay ka hoosaysaa,
\q1 Oo gacantiisa midigna way igu duuban tahay.
\q1 
\v 7 Gabdhaha reer Yeruusaalemow, waxaan idinku dhaarinayaa
\q1 Cawsha iyo deerada duurka
\q1 Inaydaan jacayl kicin, ama aydaan toosin
\q1 Ilaa uu doono.
\q1 
\v 8 Waa kaa codkii gacaliyahaygu!
\q1 Bal eega, wuu soo socdaa,
\q1 Isagoo buuraha korkooda ku soo boodboodaya, oo kuraha dushooda ku faclaynaya.
\q1 
\v 9 Gacaliyahaygu waa sida cawl ama deer qayrab ah oo kale.
\q1 Bal eega, wuxuu taagan yahay derbigayaga gadaashiisa,
\q1 Oo daaqadahuu ka soo eegayaa, oo shabagguu ka soo dayayaa.
\q1 
\v 10 Markaasaa gacaliyahaygii ila hadlay oo wuxuu igu yidhi,
\q1 Taan jeclahayay, soo kac, taydan qurxoonay i soo raac.
\q1 
\v 11 Waayo, qabowgii wuu na dhaafay,
\q1 Oo roobkiina wuu dhammaaday, wuuna qaaday,
\q1 
\v 12 Ubaxii dhulkuu ka muuqanayaa,
\q1 Oo wakhtigii shimbirruhu gabyi jireenna waa la gaadhay,
\q1 Oo codkii qoolleydana dalkayagaa laga maqlayaa.
\q1 
\v 13 Berduhu midhihiisuu soo bixinayaa,
\q1 Oo geedaha canabkuna way ubxinayaan,
\q1 Wayna soo carfayaan.
\q1 Taan jeclahayay, soo kac, taydan qurxoonay i soo raac.
\sp Gacaliyaha Hadlayaa
\q1 
\v 14 Qoolleydayda qararka dillaacyadooda iyo meelahooda qarsoon ee dalcad ah ku jirta,
\q1 Bal jaahaaga i tus, oo codkaaga i maqashii,
\q1 Waayo, codkaagu wuu macaan yahay, oo jaahaaguna wuu surad wacan yahay.
\q1 
\v 15 Dawacooyinka noo qabta, kuwaasoo ah dawacooyinka yaryar ee beerahayaga canabka ah bi'iya,
\q1 Waayo, beerahayaga canabka ahu haatan way ubxinayaan.
\sp Gacalisada Hadlaysaa
\q1 
\v 16 Gacaliyahaygu waa kaygii oo anna tiisii baan ahay.
\q1 Wuxuu adhigiisa daajinayaa ubaxyada dhexdooda.
\q1 
\v 17 Ilaa waagu baryo, oo hoosku baabba'o,
\q1 Gacaliyahaygiiyow, soo noqo, oo ahow sida cawl oo kale, amase sida deer qayrab ah
\q1 Oo buuraha Beter kor jooga.
\b
\c 3
\q1 
\v 1 Goor habeennimo ah ayaan sariirtayda ka doondoonay kan naftaydu jeceshahay.
\q1 Waan doondoonay, laakiinse ma aanan helin.
\q1 
\v 2 Haddaba waan kacayaa, oo magaaladaan dhex wareegayaa,
\q1 Oo dariiqyada iyo jidadka waaweyn
\q1 Ayaan ka dhex goobayaa kan naftaydu jeceshahay.
\q1 Waan doondoonay laakiinse ma aanan helin.
\q1 
\v 3 Waxaa i helay waardiyayaashii magaalada dhex warwareegayay,
\q1 Oo anna waxaan ku idhi, Kan naftaydu jeceshahay ma aragteen?
\q1 
\v 4 Oo kolkaan iyagii in yar sii dhaafay
\q1 Ayaan helay kii naftaydu jeceshahay.
\q1 Waan qabtay, mana sii dayn,
\q1 Ilaa aan isaga gurigii hooyaday keenay,
\q1 Oo aan qolladdii tii i uuraysatay geliyey.
\q1 
\v 5 Gabdhaha reer Yeruusaalemow, waxaan idinku dhaarinayaa
\q1 Cawsha iyo deerada duurka
\q1 Inaydaan jacayl kicin ama aydaan toosin
\q1 Ilaa uu doono.
\q1 
\v 6 Waa kuma kan cidlada uga soo baxaya sida tiirar qiiq ah?
\q1 Oo ay malmalka, iyo fooxa,
\q1 Iyo dhirta udgoon ee baayacmushtariga oo dhammu ka carfayaan?
\q1 
\v 7 Bal eeg, waa sariirta Sulaymaan lagu qaadee.
\q1 Lixdan nin oo xoog badan oo ka mid ah kuwa xoogga badan ee reer binu Israa'iil
\q1 Ayaa hareereheeda ku wareegsan.
\q1 
\v 8 Kulligood seefta aad bay u yaqaaniin, waana wada dagaalyahan.
\q1 Ninkood kastaba seeftiisii dhexday ugu xidhan tahay,
\q1 Cabsida habeenka aawadeed.
\q1 
\v 9 Boqor Sulaymaan wuxuu kursi la qaado
\q1 Ka samaystay qoryihii Lubnaan.
\q1 
\v 10 Tiirarkiisii lacag buu ka dhigay,
\q1 Hoostiisiina dahab buu ka dhigay, oo meeshuu fadhiistayna guduud buu ka dhigay,
\q1 Oo dhexdiisiina gabdhaha reer Yeruusaalem ayaa jacayl ku sharraxay.
\q1 
\v 11 Gabdhaha reer Siyoonow, bal baxa, oo Boqor Sulaymaan eega,
\q1 Isagoo qaba taajkii hooyadiis madaxa u saartay maalintii arooskiisa,
\q1 Iyo maalintii qalbigiisu faraxsanaa.
\c 4
\sp Gacaliyaha Hadlayaa
\q1 
\v 1 Taan jeclahayay, bal eeg, adigu waad qurxoon tahay, bal eeg, waad qurxoon tahay,
\q1 Oo waxaad leedahay indhaha qoolleyda oo kale oo indhashareertaada ku qarsoon.
\q1 Timahaaguna waa sida riyo
\q1 Buur Gilecaad ka muuqda.
\q1 
\v 2 Ilkahaaguna waa sida laxo loo xiiray,
\q1 Oo ka soo baxay meeshii lagu soo maydhay,
\q1 Oo middood kastaaba mataano dhashay,
\q1 Oo aan dhexdooda lagu arag mid dhicisay.
\q1 
\v 3 Bushimahaagu waa sida dun guduudan,
\q1 Oo afkaaguna waa qurxoon yahay,
\q1 Oo dhafoorradaada indhashareertaada ku qarsoonuna waa sida xabbad rummaan ah jeexeed.
\q1 
\v 4 Qoortaaduna waa sida munaaraddii Daa'uud oo loo dhisay inay ahaato meel hubka dagaalka la dhigto,
\q1 Oo ay sudhan yihiin kun gaashaan,
\q1 Oo ah gaashaammadii ragga xoogga badan oo dhan.
\q1 
\v 5 Oo labadaada naasna waa sida laba gibin oo mataano ah oo cawl dhashay.
\q1 Oo ubaxshooshannada dhexdooda daaqaya.
\q1 
\v 6 Ilaa waagu baryo, oo hoosku baabbo'o,
\q1 Waxaan u kici doonaa buurta malmalka,
\q1 Iyo kurta fooxa.
\q1 
\v 7 Taan jeclahayay, adigu waad qurxoon tahay,
\q1 Oo innaba iin ma lihid.
\q1 
\v 8 Aroosaddaydiiyey, Buur Lubnaan iga soo raac,
\q1 Oo kaalay, Buur Lubnaan iga soo raac.
\q1 Buur Amaanaah dhaladeeda wax ka fiiri,
\q1 Oo Buur Seniir iyo Buur Xermoon dhaladooda wax ka fiiri,
\q1 Oo wax ka soo fiiri boholaha libaaxyada,
\q1 Iyo buuraha shabeelladaba.
\q1 
\v 9 Walaashayay, aroosaddaydiiyey, qalbigaygii waad la tagtay,
\q1 Oo waxaad qalbigayga kula tagtay daymooyinka indhahaaga middood
\q1 Iyo laasimmada qoortaada midkood.
\q1 
\v 10 Walaashayay, aroosaddaydiiyey, jacaylkaagu qurux badanaa!
\q1 Oo jacaylkaagu intee buu khamri ka sii fiican yahay!
\q1 Oo saliiddaada carafteeduna way ka fiican tahay dhirta udgoon oo dhan.
\q1 
\v 11 Aroosaddaydiiyey, bushimahaaga malab baa ka soo tiftifqaya,
\q1 Oo carrabkaaga hoostiisana malab iyo caanaa ku jira.
\q1 Oo dharkaaga caraftiisuna waa sida carafta Buur Lubnaan.
\q1 
\v 12 Walaashayay, aroosaddaydiiyey, waxaad tahay sida beer la xidhay,
\q1 Iyo ilbiyood la awday, iyo durdur la xidhay.
\q1 
\v 13 Dhirtaadu waa beer ay ku dhex yaalliin rummaan, iyo dhir kale oo midho aad u wanaagsan,
\q1 Iyo xinne iyo naaradiin,
\q1 
\v 14 Naaradiin iyo huruud,
\q1 Iyo kalamus iyo qorfe, iyo dhir kasta oo foox dhasha,
\q1 Iyo malmal iyo cuud iyo dhir udgoon oo fiican oo dhan.
\q1 
\v 15 Waxaad tahay ilbiyood beero waraabisa,
\q1 Iyo ceel biyo nool leh,
\q1 Iyo durdurro Buur Lubnaan ka soo qulqulaya.
\sp Gacalisada Hadlaysaa
\q1 
\v 16 Dabaysha woqooyay, soo kac, oo tan koonfureeday, kaalay,
\q1 Oo beertayda necaw ku afuufa si ay dhirteeda udgoonu uga soo carfaan,
\q1 Gacaliyahaygu beertiisa ha soo galo oo midhaheeda wacan ha cuno.
\c 5
\sp Gacaliyaha Hadlayaa
\q1 
\v 1 Walaashayay, aroosaddaydiiyey, beertaydii waan soo dhex galay.
\q1 Malmalkaygiina dhirtaydii udgoonayd baan la gurtay,
\q1 Oo awlalladaydii shinniyeed iyo malabkaygiina waan cunay,
\q1 Khamrigaygii iyo caanahaygiina waan cabbay,
\sp Saaxiibadaha Hadlayaa
\q1 Saaxiibbadayow, wax cuna,
\q1 Wax cabba, gacaliyayaalow, aad u cabba.
\sp Gacalisada Hadlaysaa
\q1 
\v 2 Anigu waan hurday, laakiinse qalbigaygu waa soo jeeday.
\q1 Waxaan maqlay codkii gacaliyahayga oo albaabka garaacaya, isagoo leh,
\q1 Walaashayay, taan jeclahayay, qoolleydaydiiyey, tayda sanay, iridda iga fur,
\q1 Waayo, madaxayga waxaa ka buuxa dharab,
\q1 Oo timahaygana waxaa qoyay dhibicyihii habeennimada.
\q1 
\v 3 Dharkaygii waan iska bixiyey, bal sidee baan u xidhaa?
\q1 Oo cagahaygiina waan maydhay, bal sidee baan u wasakheeyaa?
\q1 
\v 4 Gacaliyahaygii wuxuu gacantiisii ka soo dusiyey daloolkii albaabka,
\q1 Oo qalbigaygu isaguu u dhaqaaqay.
\q1 
\v 5 Waxaan u sara joogsaday inaan gacaliyahayga iridda ka furo,
\q1 Oo gacmahaygana waxaa ka daadanayay malmal,
\q1 Farahaygana malmalku
\q1 Wuxuu kaga tiftifqay qataarkii albaabka.
\q1 
\v 6 Gacaliyahaygii waan ka furay,
\q1 Laakiinse gacaliyahaygii wuu iska noqday, wuuna tegey.
\q1 Naftaydii markuu hadlay way naxday.
\q1 Isagaan doondoonay, laakiinse waan heli kari waayay.
\q1 Waan u dhawaaqay, laakiinse innaba iima uu jawaabin.
\q1 
\v 7 Oo waardiyayaashii magaalada dhex warwareegayay ayaa i helay
\q1 Wayna i garaaceen oo i dhaawaceen.
\q1 Oo kuwii derbiyada dhawrayay ayaa garbasaartaydii iga qaaday.
\q1 
\v 8 Gabdhaha reer Yeruusaalemow, Waxaan idinku dhaarinayaa, haddaad gacaliyahaygii aragtaan,
\q1 U sheega inaan caashaq la buko.
\sp Saaxiibadaha Hadlayaa
\q1 
\v 9 Gacaliyahaagu muxuu gacaliye kale dheer yahay,
\q1 Taada naagaha ugu qurxoonay?
\q1 Bal gacaliyahaagu muxuu gacaliye kale dheer yahay,
\q1 Waadigaa sidan noo dhaarinayee?
\sp Gacalisada Hadlaysaa
\q1 
\v 10 Gacaliyahaygu waa cad yahay oo waa casaan.
\q1 Waana kan toban kun ugu wanaagsan.
\q1 
\v 11 Madaxiisu waa sida dahab saafi ah,
\q1 Oo timihiisuna waa sida cawbaar, oo waxay u madow yihiin sida tuke oo kale.
\q1 
\v 12 Indhihiisu waa sida indho qoolley oo durdur biya ah ag joogta,
\q1 Oo caano lagu maydhay oo si qumman loo dhigay.
\q1 
\v 13 Dhabannadiisu waa sida beer dhir udgoon ah iyo sida ubaxyo carfa.
\q1 Oo bushimihiisuna waa sida ubaxshooshanno uu malmal ka tiftifqayo.
\q1 
\v 14 Gacmihiisu waa sida kaatummo dahab ah oo berullos lagu dhejiyey,
\q1 Oo jidhkiisuna waa sida foolmaroodi oo dhalaalaya oo safayr lagu sharraxay.
\q1 
\v 15 Lugihiisu waa sida tiirar marmar ah, oo lagu qotomiyey saldhigyo dahab saafiya ah,
\q1 Oo muuqashadiisuna waa sida Buur Lubnaan oo kale, oo wuxuu u qurxoon yahay sida geedaha kedarka oo kale.
\q1 
\v 16 Afkiisu aad iyo aad buu u macaan yahay, oo isaga dhammaantiis waa mid aad loo jecel yahay.
\q1 Gabdhaha reer Yeruusaalemow,
\q1 Kaasu waa gacaliyahayga, waana saaxiibkayga.
\c 6
\sp Saaxiibadaha Hadlayaa
\q1 
\v 1 Taada naagaha u qurxoonay,
\q1 Xaggee gacaliyahaagii tegey?
\q1 Aannu kula goobnee,
\q1 Xaggee buu gacaliyahaagii u leexday?
\sp Gacalisada Hadlaysaa
\q1 
\v 2 Gacaliyahaygii wuxuu u dhaadhacay beertiisa, iyo beer qaybaheed oo dhir udgoon ah
\q1 Inuu adhigiisa soo daajiyo beeraha dhexdooda, oo uu soo urursado ubaxshooshanno.
\q1 
\v 3 Anigu waxaan ahay tii gacaliyahayga, oo gacaliyahayguna waa kaygii,
\q1 Oo wuxuu adhigiisa daajiyaa ubaxshooshannada dhexdooda.
\sp Gacaliyaha Hadlayaa
\q1 
\v 4 Taan jeclahayay, waxaad u qurux badan tahay sida Tirsaah oo kale,
\q1 Oo waxaad u suurad wacan tahay sida Yeruusaalem oo kale,
\q1 Waxaana lagaaga cabsadaa sida ciidan calammo sita oo kale.
\q1 
\v 5 Indhahaaga iga sii jeedi,
\q1 Waayo, way iga adkaadeen.
\q1 Timahaagu waa sida riyo
\q1 Buur Gilecaad ka muuqda.
\q1 
\v 6 Ilkahaaguna waa sida laxo
\q1 Ka soo baxay meeshii lagu soo maydhay,
\q1 Oo middood kastaaba mataano dhashay,
\q1 Oo aan dhexdooda lagu arag mid dhicisay.
\q1 
\v 7 Oo dhafoorradaada indhashareertaada ku qarsoonuna waa sida xabbad rummaan ah jeexeed.
\q1 
\v 8 Waxaa jira lixdan boqoradood, iyo siddeetan naagood oo addoommo ah,
\q1 Iyo gabdho aan tiro lahayn.
\q1 
\v 9 Laakiinse qoolleydayda, iyo tayda sanu waa mid qudha.
\q1 Iyadu waa tan keliya ee hooyadeed,
\q1 Oo waa tan daahirsan ee tii iyada dhashay.
\q1 Gabdhuhu iyaday arkeen oo waxay ku sheegeen mid barakaysan,
\q1 Oo xataa boqoradihii iyo naagihii addoommaha ahaaba way ammaaneen.
\sp Saaxiibadaha Hadlayaa
\q1 
\v 10 Waa tuma tan u soo muuqata sida kaaha waaberiga,
\q1 Oo sida dayaxa u qurxoon,
\q1 Ee sida qorraxda u daahirsan,
\q1 Oo haddana looga cabsado sida ciidan calammo sita oo kale?
\sp Gacaliyaha Hadlayaa
\q1 
\v 11 Waxaan ku dhaadhacay beertii yicibta
\q1 Inaan soo arko geedaha cagaarka ah ee dooxada,
\q1 Iyo inaan soo arko bal in canabkii magoolay,
\q1 Oo uu rummaankii ubxiyey iyo in kale.
\q1 
\v 12 Anigoo aan garanayn ayaa nafsaddaydu iga dhigtay sida gaadhifardoodkii Cammiinaadiib oo kale.
\sp Saaxiibadaha Hadlayaa
\q1 
\v 13 Tan reer Shuuleemay, soo noqo, soo noqo,
\q1 Aan ku daawannee soo noqo, soo noqo.
\sp Gacaliyaha Hadlayaa
\q1 Bal maxaad u daawanaysaan tan reer Shuuleem
\q1 Sida cayaarta Maxanayim?
\b
\c 7
\q1 
\v 1 Gabadha amiirku dhalayay, cagahaagu qurux badanaa markay kabo illan yihiin,
\q1 Bowdooyinkaagu waa sida dahab
\q1 Nin saanac ahu gacantiisa ku sameeyey.
\q1 
\v 2 Xudduntaadu waa sida fijaan goobaaban
\q1 Oo aan innaba khamri ka dhinnanayn,
\q1 Oo xaluskaaguna waa sida sarreen meel tuunsan
\q1 Oo ubaxshooshanno lagu wareejiyey.
\q1 
\v 3 Labadaada naasna waa sida laba gibin
\q1 Oo mataano ah oo cawl dhashay.
\q1 
\v 4 Qoortaaduna waa sida munaarad foolmaroodi ah,
\q1 Oo indhahaaguna waa sida ballidii Xeshboon oo ku ag yaal iridda Batrabbiim.
\q1 Oo sankaaguna waa sida munaaradda Lubnaan
\q1 Oo xagga Dimishaq u jeeda.
\q1 
\v 5 Madaxaagu sida Buur Karmel oo kale wuu dheer yahay,
\q1 Oo timaha madaxaaguna waa sida guduud oo kale,
\q1 Oo boqorkuna wuu ku xidhan yahay.
\q1 
\v 6 Taan jeclahayay, qurux badnidaa!
\q1 Fiicnaan badnidaa! Aad baad iiga farxisaa!
\q1 
\v 7 Sarajooggaagu waa sida geed baar ah,
\q1 Oo naasahaaguna waa sida rucubyo canab ah.
\q1 
\v 8 Waxaan is-idhi, Geedka baarka waan fuuli doonaa,
\q1 Oo waxaan qabsan doonaa laamihiisa.
\q1 Naasahaagu ha ahaadeen sida rucubyo canab ah,
\q1 Oo sankaaga neeftiisuna ha u carafto sida midho tufaax ah.
\q1 
\v 9 Oo afkaaguna ha ahaado sida khamri wanaagsan.
\sp Gacalisada Hadlaysaa
\q1 Si qumman oo macaan ha ugu socda gacaliyahayga,
\q1 Oo kuwa hurda bushimahooda ka hadliya.
\q1 
\v 10 Anigu waxaan ahay tii gacaliyahayga,
\q1 Oo damaciisuna xaggayguu soo jiraa.
\q1 
\v 11 Gacaliyahaygow, kaalay, aynu duurka isla tagnee,
\q1 Oo aynu tuulooyinka ku soo dhaxnee.
\q1 
\v 12 Aynu aroor hore beercanabyada tagnee,
\q1 Oo aynu soo aragno bal in canabkii magoolay, oo ay ubixiisii soo muuqdeen,
\q1 Oo uu rummaankii ubxiyey iyo in kale;
\q1 Oo halkaasaan jacaylkayga kugu siin doonaa.
\q1 
\v 13 Ubixii duudaygu way soo carfayaan,
\q1 Oo albaabbadayada agtooda waxaa yaal midho cayn kasta ah oo cusayb iyo duugba leh,
\q1 Oo adigaan kuu kaydiyey, gacaliyahaygiiyow.
\b
\c 8
\q1 
\v 1 Haddaad ahaan lahayd walaalkay
\q1 Oo naasihii hooyaday nuugay,
\q1 Markaan dibadda kaa helaba waan ku dhunkan lahaa.
\q1 Oo innaba layma quudhsadeen.
\q1 
\v 2 Waan ku soo kaxayn lahaa oo waxaan ku gelin lahaa guriga hooyaday,
\q1 Wax baadna i bari lahayd.
\q1 Oo waxaan ku cabsiin lahaa khamriga xawaashka leh
\q1 Ee biyaha rummaankayga laga sameeyey.
\q1 
\v 3 Gacantiisa bidix madaxaygay ka hoosayn lahayd,
\q1 Oo gacantiisa midigna way isku kay duubi lahayd.
\q1 
\v 4 Gabdhaha reer Yeruusaalemow, waxaan idinku dhaarinayaa
\q1 Inaydaan jacayl kicin, ama aydaan toosin,
\q1 Ilaa uu doono.
\sp Saaxiibadaha Hadlayaa
\q1 
\v 5 Waa tuma tan cidlada ka soo baxaysa,
\q1 Ee gacaliyeheeda ku tiirsanu?
\sp Gacalisada Hadlaysaa
\q1 Waxaan kaa soo kiciyey geed tufaax ah hoostiis.
\q1 Halkaasaa hooyadaa kugu foolatay,
\q1 Oo halkaasay tii ku dhashay kugu foolatay.
\q1 
\v 6 Qalbigaaga korkiisa ii dhig sida shaabad oo kale, oo gacantaada korkeeda ii dhig sida shaabad oo kale,
\q1 Waayo, jacaylku wuxuu u xoog badan yahay sida geeri oo kale,
\q1 Oo masayrkuna wuxuu u nac weyn yahay sidii She'ool oo kale.
\q1 Belbelkiisu waa sida belbel dab ah,
\q1 Oo waa ololka ugu wada kulul ee Rabbiga.
\q1 
\v 7 Biyo badanu jacayl ma demin karaan,
\q1 Oo daadadkuna innaba ma qarqin karaan.
\q1 Haddii nin damco inuu jacayl soo siisto maalka gurigiisa oo dhan,
\q1 Haddana dhammaan waa la quudhsan lahaa.
\sp Saaxiibadaha Hadlayaa
\q1 
\v 8 Annagu waxaannu leennahay walaal yar,
\q1 Oo aan innaba naaso lahayn.
\q1 Haddaba bal maxaannu walaashayo u samayn doonnaa
\q1 Maalintii iyada guur loo soo doonto?
\q1 
\v 9 Hadday derbi tahay waxaannu korkeeda ka dhisi doonnaa munaarad lacag ah,
\q1 Oo hadday albaab tahayna waxaannu iyada ku hareerayn doonnaa alwaaxyo kedar ah.
\sp Gacalisada Hadlaysaa
\q1 
\v 10 Anigu waxaan ahay derbi, oo naasahayguna waa sida munaaradaha oo kale.
\q1 Oo markaas waxaan hortiisa ku ahaa sidii mid nabad heshay.
\q1 
\v 11 Sulaymaan beercanab buu Bacal Hamoon ku lahaa;
\q1 Oo beercanabkii wuxuu ka kireeyey kuwa dhawra,
\q1 Oo midkood kastaaba wuxuu midhaheeda uga keeni jiray kun xabbadood oo lacag ah.
\q1 
\v 12 Beercanabkayga ah kan aan iska leeyahay, hortayduu ku yaal,
\q1 Haddaba Sulaymaanow, adigu waxaad heli doontaa kun,
\q1 Kuwa midhihiisa dhawraana laba boqol.
\sp Gacaliyaha Hadlayaa
\q1 
\v 13 Taada beeraha dhexdooda degganay,
\q1 Rafiiqyadaadu waxay dhegaystaan codkaaga,
\q1 Haddaba, bal i maqashii.
\sp Gacalisada Hadlaysaa
\q1 
\v 14 Gacaliyahaygow, dhaqso,
\q1 Oo waxaad ahaataa sida cawl ama deer qayrab ah
\q1 Oo buuraha dhirta udgoon kor jooga.
