\q1 tlen eliyaya icone Isaí, 
\q1 tlen eliyaya icone Obed, 
\q1 tlen eliyaya icone Booz, 
\q1 tlen eliyaya icone Salmón, 
\q1 tlen eliyaya icone Naasón, 
\q1  
