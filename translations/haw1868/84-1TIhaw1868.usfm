\id 1TI
\h Timoteo I.
\toc1 Timoteo I.
\toc2 Timoteo I.
\toc3 Timoteo I.
\mt1 Timoteo I.
\c 1
\s1 O KA EPISETOLE
\q1 
\v 1 NA Paulo ka lunaolelo a Iesu Kristo, ma ke kauoha ana mai o ke Akua, ko kakou Ola, a o ka Haku o Iesu Kristo, ko kakou mauaolana;
\q1 
\v 2 Ia Timoteo i ko keiki ponoi ma ka manaoio; ke aloha, ke ahonui, a me ka maluhia, mai ke Akua mai o ko kakou Makua, a me Iesu Kristo ko kakou Haku.
\b
\q1 
\v 3 Me a'u i nonoi aku ai ia oe e noho oe ma Epeso, i kuu hele ana ku i Makedonia, i kauoha oe i kekahi poe, i ao ole aku lakou i ka olelo e,
\q1 
\v 4 Aole hoi e malama i na olelo hakuwaleia, a me na kuauhau hope ole, ona mea i hoomahuahua'e i ka hoopaapaa ana, aole i ka pono o ke Akua, ma ka manao oiaio.
\q1 
\v 5 O ka hope o ke kauoha, o ke aloha ia, mai loko mai o ka naau maemae, a me ka manao maikai, a me ka paulele oiaio.
\q1 
\v 6 Aka, na kapae kekahi poe mai ia mea aku, a ua huli ae hoi ma ka hoopaapaa lapuwale;
\q1 
\v 7 E makemake ana e lilo i mau kumu ao kanawai; aole hoi i ike pono i ka lakou mea i olelo ai, aole noi i ka lakou mea i hooiaio ai.
\q1 
\v 8 Aka, ua ike kakou i ke kanawai, he mea maikai ia, ke malama pono ia oia e ke kanaka;
\q1 
\v 9 Me ka ike hoi, aole i kauia ke kanawai no ke kanaka hoopono, aka, no ka poe pono ole, ka poe hoolohe ole, ka poe aia, ka poe hewa, ka poe haihaia, ka poe hoino, ka poe pepehi makuakane, ka poe pepehi makuwahine, ka poe pepehi kanaka,
\q1 
\v 10 Ka poe hookamakama, ka poe moe aikane, ka poe aihue kanaka, ka poe hoopunipuni, ka poe hoohiki wahahee, a me na mea e ae i ku e mai i ka pono oiaio,
\q1 
\v 11 Mamuli o ka euanelio nani, a ke Akua pomaikai, i kauohaia mai ai ia'u.
\b
\q1 
\v 12 He aloha ko'u ia Kristo Iesu i ko kakou Haku i ka mea i hooikaika mai ia'u, no ka mea, ua manao mai oia e ku paa ana au, a ua hoolilo mai ia'u no keia oihana;
\q1 
\v 13 I ka mea hoino wale mamua, me ka hoomaau, a me ka hooluhi hewa aku; aka, ua alohaia mai la au, no ka mea, ua hana au ia mea me ka naaupo, a me ka manaoio ole.
\q1 
\v 14 A ua mahuahua nui mai la ke aloha wale mai o ko kakou Haku me ka manaoio, a me ke aloha aku iloko o Kristo Iesu.
\q1 
\v 15 Eia hoi ka olelo oiaio, e pono e malama nui ia mai, ua hele mai o Kristo Iesu i ke ao nei, e hoola i ka poe hewa; owau no ko lakou mea oi.
\q1 
\v 16 A ua alohaia mai hoi au, i hoike mai ai o Iesu Kristo ma o'u nei la mua, i ke ahonui a pau, i kumu no ka poe e paulele ana ia ia ma ia hope aku, i ola mau loa ai.
\q1 
\v 17 I ke Alii mua loa, make ole, ike maka ole ia, ke Akua akamai hookahi wale no, ka mahalo, a me ka hoonaniia, a mau loa aku. Amene.
\b
\q1 
\v 18 O keia kauoha ka'u e kauoha aku nei ia oe, e ke keiki Timoteo, e like me na wanana i hai mua ia mai nou, e kaua aku oe no ia mau mea, i ke kaua maikai;
\q1 
\v 19 E hoomau ana i ka paulele a me ka manao maikai, i ka mea a kekahi poe i haalele ai, a ili iho la nabaha ka manaoio;
\q1 
\v 20 O Humenaio, a me Alekanedero, kekahi o ua poe la; o laua ka'u i haawi aku ai ia Satana, i aoia'i laua e hoino hou ole aku.
\c 2
\b
\q1 
\v 1 KE kauleo mua aku nei au i nui ka pule ana, a me ka hoomana ana, a me ka nonoi ana, a me ka hoomaikai ana, no na kanaka a pau loa;
\q1 
\v 2 No na'lii hoi, a me na luna a pau; i malu ko kakou ola ana me ka noho malie, a me ka manao nui i ke Akua, a ma ka pono no hoi.
\q1 
\v 3 O ka maikai no ia me ka pono imua i ke alo o ke Akua o ko kakou Ola;
\q1 
\v 4 Nona ka makemake e ola na kanaka a pau, a e hooiaio hoi i ka olelo oiaio.
\q1 
\v 5 No ka mea, hookahi no Akua, hookahi no mea uwao, iwaena o ke Akua, a me kanaka, o ke kanaka Kristo Iesu;
\q1 
\v 6 Ka mea i haawi ia ia iho i kalahala no na mea a pau, e hoikeia hoi i ka manawa pono.
\q1 
\v 7 Nona wau i hookaawaleia'e i kahuna hai, i lunaolelo hoi, a (he oiaio ka'ue olelo aku nei iloko o Kristo, aole o'u wahahee,) i kumu ao hoi i ko na aina e, ma ka manaoio a me ka olelo oiaio.
\b
\q1 
\v 8 O ko'u manao hoi ia, e pule na kanaka ma kela wahi keia wahi, e hapai ana i na lima hala ole, me ka huhu ole a me ka hoopaapaa ole.
\q1 
\v 9 Pela hoi e kahiko na wahine ia lakou iho i ka aahu kohu pono, me ka maka hilahila a me ka noho malie; aole me ka lauoho hoonionio, a me ke gula, a me na momi, a me na kapa komo he nui ke kumukuai;
\q1 
\v 10 Aka, me na hana maikai, he mea kohu ia i na wahine i hooiaio i ko lakou manao i ke Akua.
\q1 
\v 11 E aoia'ku hoi ka wahine me ka noho malie a me ka hoolohe wale mai.
\q1 
\v 12 Aole au e ae aku i ka wahine e ao aku a e hooalii aku maluna o ke kane, aka, e noho malie ia.
\q1 
\v 13 No ka mea, ua hana mua ia o Adamu, alaila hoi o Eva.
\q1 
\v 14 Aole hoi o Adamu i puni, aka, ua puni ka wahine, a lilo i ka hewa.
\q1 
\v 15 Aka hoi, e hoolaia no ia ma ka hanau keiki ana, ke noho paa lakou ma ka manaoio, a me ke aloha, a me ka hemolele a me ka manao malu.
\c 3
\b
\q1 
\v 1 HE olelo oiaio keia, ina make make kekahi i ka oihana kahunapule, he hana maikai kana i makemake ai.
\q1 
\v 2 Eia ka pono no ke kahunapule, he hala ole, he kane na ka wahine hookahi, he kiai ia ia iho, he kuoo, he akahai, he hookipa, he akamai hoi i ke ao aku;
\q1 
\v 3 Aole e lilo i ka waina, aole e kipikipi, aole hoi alunu wale; aka, e ahonui, a e hakaka ole, aole hoi makee waiwai;
\q1 
\v 4 E hoomalu maikai ana i kona hale iho me ka hoolohe pono ia mai e kana mau keiki me ka hanohano.
\q1 
\v 5 No ka mea, ina i ike ole ke kanaka i ka hoomalu ana i kona hale iho, pehea la e hiki ai ia ia ke malama i ka ekalesia o ke Akua?
\q1 
\v 6 Aole ka mea akahiakahi, o hookiekie ae oia a haule iloko o ka hoohewaia ana o ka diabolo.
\q1 
\v 7 E pono hoi e hoaponoia mai ia e ka poe mawaho; o lilo i ka hoahewaia, a hei aku la i ke pahele a ka diabolo.
\q1 
\v 8 Pela hoi na puuku ekalesia, e pono e noho kuoo, aole alelo lua, aole lilo i ka waina nui, aole hoi alunu wale;
\q1 
\v 9 E hoopaa ana i ka mea pohihihi o ka manaoio me ka manao maemae.
\q1 
\v 10 E hooiaio mua ia hoi lakou nei a ikea ka hala ole; alaila e lawe lakou i ka oihana puuku ekalesia.
\q1 
\v 11 Pela hoi ka lakou mau wahine, e pono e noho kuoo, me ke aki ole, me ka noho malie, e hoopono ana ma na mea a pau.
\q1 
\v 12 E pono hoi e lawe pakahi na puuku ekalesia i ka wahine, e hoomalu pono ana hoi i ka lakou mau keiki a me ko lakou mau hale iho.
\q1 
\v 13 No ka mea, o ka poe i lawelawe pono i ka oihana puuku, ua loaa ia lakou kekahi pono nui, a me ka wiwo ole ma ka manaoio iloko o Kristo Iesu.
\b
\q1 
\v 14 O keia mau mea ka'u e palapala aku nei ia oe, me ka manao e hele koke aku iou la;
\q1 
\v 15 A i hakalia au, i ike oe i kou pono e hana ai maloko o ka hale o ke Akua, oia ka ekalesia o ke Akua ola, o ke kia a me ke kahua o ka olelo oiaio.
\q1 
\v 16 Ua akaka no he mea nui ka mea pohihihi o ka manao i ke Akua: ua hoikeia mai ke Akua ma ke kino, ua hoaponoia mai e ka Uhane, ua ikea mai e na anela, ua haiia ku i ko na aina e, ua manaoio ia ma ke ao nei, a ua hookipaia'ku iluna i ka nani.
\c 4
\b
\q1 
\v 1 KE olelo paka mai nei ka Uhane, a i ka manawa mahope, e haalele kekahi poe i ka manaoio, e malama ana i na uhane hoopunipuni, a me ke ao ana a na daimonio;
\q1 
\v 2 E wahahee ana me ka hookamani; a e hoaaia ko lakou naau me ka hao wela;
\q1 
\v 3 E papa ana i ka mare, a me kekahi mau mea ai, a ke Akua i hana'i e aiia'i me ke aloha, e ka poe manaoio me ka ike i ka olelo oiaio.
\q1 
\v 4 He maikai na mea a pau i hanaia e ke Akua, aole e paleia'ku ke laweia mai ia me ka hoomaikai aku:
\q1 
\v 5 No ka mea, ua hooponoia mai ia e ka olelo a ke Akua a me ka pule.
\b
\q1 
\v 6 Ina, e paipai oe i neia mau mea i na hoahanau, e lilo no oe i kahunapule maikai no Iesu Kristo, e hanaiia me ka huaolelo o ka manaoio, a me ke ao maikai ana i loaa pono ia oe.
\q1 
\v 7 Aka, e pale aku i na kaao lapuwale a na luwahine, e hooikaika oe ma ka manao i ke Akua.
\q1 
\v 8 No ka mea, o ka hooikaika ana o ke kino, he uuku ka waiwai; aka, o ka manao i ke Akua he mea ia e pono ai i na mea a pau, ua olelo mua ia mai no hoi, nona keia ola ana e noho nei, a me kela ola ana.
\q1 
\v 9 He olelo oiaio keia e pono e malama nui ia mai.
\q1 
\v 10 No ka mea, nolaila kakou e hooikaika nei me ka hoino wale ia mai no ko kakou hilinai ana i ke Akua ola, oia ke ola no na kanaka a pau, e ola io ai ka poe manaoio.
\q1 
\v 11 E kauoha aku oe me ke ao io aku ia mau mea.
\q1 
\v 12 Mai hoowahawaha kekahi i kou opiopio ana; aka, e lilo oe i kumu hoohalike no ka poe paulele, ma ka olelo ana, a ma ke kamailio ana, a ma ke aloha, a ma ka manao, a ma ka paulele, a ma ka maemae.
\q1 
\v 13 Eia kau e hana'i a hiki wale aku au, o ka heluhelu palapala, o ka hooikaika aku, a me ke ao aku.
\q1 
\v 14 Mai waiho aku i kou haawina iloko ou, i haawiia mai nou, maka wanana, a me ke kau ana iho o na lima o ka poe lunakahiko.
\q1 
\v 15 E manao oe i ua mau mea la; a e hoolilo loa malaila; i ikea kou pono ana e na mea a pau.
\q1 
\v 16 E malama oe ia oe iho, a me ke ao ana'ku. E noho mau ma ia mau mea; no ka mea, ma kau hana ana ia, e hoola oe ia oe iho, a me ka poe a pau e hoolohe mai ana ia oe.
\c 5
\b
\q1 
\v 1 MAI papa ikaika i ke kanaka kahiko, aka, e ao pono aku ia ia, me he makuakane la; a i ka poe ui hoi me he mau hoahanau la;
\q1 
\v 2 A i na wahine kahiko, me he mau makuwahine la; a i na kaikamahine hoi me he mau kaikuwahine la, me ka maemae loa.
\q1 
\v 3 E hoomaikai aku i na wahinekanemake, i ka poe wahinekanemake oiaio.
\q1 
\v 4 Aka, ina he mau keiki ka kekahi wahinekanemake, a he mau moopuna paha, e ao lakou e hoike mua i ke aloha ma ko lakou hale iho, a e uku aku i ko lakou mau makua; no ka mea, oia ka maikai, a me ka pono imua o ke alo o ke Akua.
\q1 
\v 5 O ka wahinekanemake oiaio, a mehameha hoi, ua hilinai no ia i ke Akua, a ua noho mau no ia me ka pule ana a me ka hoomana ana i ka po a me ke ao.
\q1 
\v 6 Aka, o ka wahine e noho ana ma ka lealea, ua make no ia i kona wa e ola ana.
\q1 
\v 7 Oia mau mea kau e kauoha aku ai i hala ole lakou.
\q1 
\v 8 A i hoolako ole kekahi i kona a me ko ka hale ponoi ona iho no hoi, ua hoole ia i ka manaoio, a ua oi aku kona hewa i ko ka mea manaoio ole.
\q1 
\v 9 Aole e pono, e kakauia ma ka palapala, ka wahinekanemake i kanaono ole na makahiki, a ua wahine na ke kanaka hookahi,
\q1 
\v 10 A i mahaloia no kana hana maikai ana; ina i hanai ia i na keiki i hookipa hoi i na malihini, a i holoi hoi i na wawae o ka poe hoano, a i kokua hoi i ka poe poino, a ina i hahai mau ia i na hana maikai a pau.
\q1 
\v 11 Aka, e hoole aku i na wahine kane make opiopio, no ka mea, i ka wa e lilo ai lakou i ka lealea e ku e ia Kristo, e ma re no lakou;
\q1 
\v 12 A e hoohewaia, no ko lakou haalele ana i ko lakou manaoio mamua.
\q1 
\v 13 A ua lilo hoi lakou ma ka palaualelo, e lalau ana ma ia hale aku a ia hale aku; aole hoi o ka palaualelo wale no, o ka holoholo olelo kekahi, mo he poe hana lapuwale la, e olelo ana i na mea aole e pono ke olelo.
\q1 
\v 14 O ko'u manao no ia no ua wahine opiopio, e mare lakou, a e hanau keiki, a e hooponopono i ka hale, i loaa ole ka hala e hoino mai ai ka enemi.
\q1 
\v 15 No ka mea, ua huli e ae nei kekahi poe mamuli o Satana.
\q1 
\v 16 A o ke kanaka, a o ka wahine paha i manaoio, he mau wahinekanemake kona, e malama no ia ia lakou i kaumaha ole ai ka ekalesia; a e pono ai hoi ia ia ke malama i ka poe wahinekanemake oiaio.
\b
\q1 
\v 17 E malama nui ia'ku na lunakahiko e hoomalu pono ana, he oiaio hoi, o ua poe la i hooikaika ma ka olelo a me ke ao aku;
\q1 
\v 18 No ka mea, ua olelo mai ka palapala hemolele, Mai hoopaa oe i ka waha o ka bipi kauo e hahi ana i ka palaoa. E pono ka paahana e ukuia mai.
\q1 
\v 19 Aole oe e hoolohe i ka hoohewa ana i ka luna kahiko, ke ole ia ma na mea hoike, elua, ekolu paha.
\q1 
\v 20 O ka poe hana hewa o kau ia e papa aku imua o ke alo o na mea a pau, i makau mai ai hoi o hai.
\q1 
\v 21 Ke kauoha aku nei au imua O ke alo o ke Akua a me ka Haku o Iesu Kristo, a me na anela punahele, e malama oe ia mau mea me ka hookela ole i kekahi mamua o kekahi, a me ka hana ewaewa ole.
\q1 
\v 22 Mai kau alulu i na lima maluna iho o kekahi, aole hoi e komo pu oe i ko hai hala. E malama ia oe iho me ka maemae.
\q1 
\v 23 Mai inu hou i ka wai maoli, he wahi waina uuku hoi kau e lawe ai i pono ai kou opu, a no kou nawaliwali pinepine ana.
\q1 
\v 24 O na hewa o kekahi poe kanaka, ua akaka e no ia e hele mua ana i ka hoohewaia mai; a e hahai ana no hoi na hewa mamuli o kekahi poe.
\q1 
\v 25 Pela no hoi na hana maikai, ua akaka e no kekahi; a o na mea i ole pela, aole nae e hiki ke hunaia.
\c 6
\b
\q1 
\v 1 E PONO i na kauwa a pau malalo iho o ka auamo, ke manao i ko lakou mau haku, he pono ke hoomaikai nui ia'ku, i ole ai e hoino wale ia ka inoa o ke Akua a me kana olelo.
\q1 
\v 2 A o ka poe nona na haku manaoio, mai hoowahawaha aku lakou no ko lakou hoahanau ana; aka, e lawelawe aku no lakou, no ka mea, he poe paulele lakou a he poe alohaia e lawe pu ana i ka pono. Ma ia mau mea e ao aku ai oe me ka hooikaika aku.
\b
\q1 
\v 3 A ina he okoa ka kekahi ao ana aku, me ka ae ole mai i na huaolelo pono, i na olelo a ko kakou Haku a Iesn Kristo, a me ke ao ana aku mamuli o ka manao maikai i ke Akua;
\q1 
\v 4 He hookano ia, he naaupo loa, a e kuko wale ana i na ninau a me na huaolelo hooakamai, kahi e ulu ai ka huwa, ka paio, ka nuku, ka hoohuoi ino,
\q1 
\v 5 A me ka hoopaapaa huhu ana a na kanaka naau ino, me ka lako ole i ka olelo oiaio, e manao ana hoi, o ka waiwai ka manao i ke Akua; e hoookoa oe ia oe iho ia lakou.
\q1 
\v 6 Aka, o ka manao i ke Akua, me ka oluolu io, oia ka waiwai nui.
\q1 
\v 7 No ka mea, aohe a kakou mea i lawe mai ai iloko o keia ao, he oiaio hoi aohe a kakou mea e hiki ke lawe pu aku iwaho.
\q1 
\v 8 A ina, ia kakou ka ai a me ke kapa, malaila kakou e oluolu ai.
\q1 
\v 9 Aka, o ka poe e makemake ana i ka waiwai nui, ua haule lakou iloko o ka hoowalewaleia a me ka pahele, a iloko o kela kuko lapuwale keia kuko lapuwale e pono ole ai, na mea e paholo ai na kanaka i ka poino, a me ka make.
\q1 
\v 10 No ka mea, o ka puni kala o ka mole no ia o ka hewa a pau; ua kuko nui ia ia e kekahi poe, a ua haalele lakou i ka manaoio, a ua houhou lakou ia lakou iho i na ehaeha he nui.
\b
\q1 
\v 11 Aka, o oe, e ke kanaka o ke Akua, e haalele ia mau mea; a e hahai mamuli o ka pono, o ka manao i ke Akua, o ka manaoio, o ke aloha, o ke ahonui, a me ke akahai.
\q1 
\v 12 E paio aku i ka paio maikai o ka manaoio, e hoopaa aku i ke ola mau loa, i kou mea i kohoia mai ai, a e hooia aku ai i ka hooiaio maikai imua o ke alo o na hoike he lehulehu.
\q1 
\v 13 Ke kauoha aku nei au ia oe imua i ke alo o ke Akua, ka mea i hoola i na mea a pau, a o Kristo Iesu hoi, ka mea i hoike imua o Ponetio Pilato i ka hooiaio maikai;
\q1 
\v 14 E malama oe i keia kauoha i kina ole, me ka hala ole, a hiki wale aku i ka ikea ana mai o ko kakou Haku o Iesu Kristo;
\q1 
\v 15 I ka mea i na manawa ona iho, o hoike mai ai oia, o ka Moi pomaikai hookahi, o ke Alii o na alii, o ka Haku o na haku;
\q1 
\v 16 Nona wale no ka make ole, e noho mau ana iloko o ka malamalama kahi e hiki ole aku ai ke kanaka; aole ikeia e ke kanaka, aole hoi e hiki ia ia ke nana aku; ia ia mau loa hoi ka mahalo a me ka mana. Amene.
\b
\q1 
\v 17 E kauoha aku oe i ka poe waiwai i keia ao, mai hookiekie ko lakou naau, mai hilinai i ka waiwai oiaio ole, aka, i ke Akua ola, nana na mea a pau i haawi lokomaikai mai ia kakou e oluolu ai.
\q1 
\v 18 E hana maikai hoi lakou, i lako hoi lakou i na hana maikai, i makaukau hoi i ka haawi wale aku me ka lokomaikai;
\q1 
\v 19 E hoahu ana i kumu maikai na lakou iho, no ka manawa e hiki mai ana, i paa aku ai lakou i ke ola mau loa.
\b
\q1 
\v 20 E Timoteo, e malama oe i ka mea i kauohaia'ku ia oe, e pale ana i ka wawa lapuwale, a me ke ku ee ana o ka mea i kapa hewa ia he naauao:
\q1 
\v 21 O ka mea a kekahi poe i hooia ai, ua haalele hoi i ka manaoio. Ia oe ke alohaia mai. Amene. 
