\p
\v 12 \w En|strong="G1722"\w* \w ningún|strong="G3762"\w* \w otro|strong="G2087"\w* \w hay|strong="G3588"\w* \w salvación|strong="G4991"\w*, \w porque|strong="G1063"\w* \w no|strong="G3756"\w* \w hay|strong="G3588"\w* \w otro|strong="G2087"\w* \w nombre|strong="G3686"\w* \w bajo|strong="G5259"\w* \w el|strong="G3588"\w* \w cielo|strong="G3772"\w* \w dado|strong="G1325"\w* \w a|strong="G1722"\w* \add los\add* hombres, \w en|strong="G1722"\w* \w Quien|strong="G3739"\w* tenemos \w que|strong="G3588"\w* ser \w salvos|strong="G4982"\w*.   
