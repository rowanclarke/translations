\p
\v 12 “\w When|strong="H3588"\w* \w you|strong="H3588"\w* \w saw|strong="H7200"\w* \w that|strong="H3588"\w* \w King|strong="H4428"\w* \w Nahash|strong="H5176"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* \w Ammonites|strong="H1121"\w* \w was|strong="H3068"\w* advancing \w against|strong="H5921"\w* \w you|strong="H3588"\w*, \w you|strong="H3588"\w* said \w to|strong="H3068"\w* \w me|strong="H7200"\w*, ‘\w No|strong="H3808"\w*! \w A|strong="H3068"\w* \w king|strong="H4428"\w* \w will|strong="H3068"\w* \w rule|strong="H4428"\w* \w over|strong="H5921"\w* \w us|strong="H5921"\w*’ – \w even|strong="H3588"\w* \w though|strong="H3588"\w* \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w your|strong="H3068"\w* \w God|strong="H3068"\w* \w is|strong="H3068"\w* \w your|strong="H3068"\w* \w king|strong="H4428"\w*!  
