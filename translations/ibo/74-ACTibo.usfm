\id ACT - Biblica® Open Igbo Contemporary Bible 2020
\h Ọrụ Ndị Ozi
\toc1 Ọrụ Ndị Ozi
\toc2 Ọrụ Ndị Ozi
\toc3 Ọrụ
\mt1 Ọrụ Ndị Ozi
\c 1
\s1 Jisọs alaa nʼeluigwe
\p 
\v 1 Ezigbo enyi m Tiofilọs, nʼakwụkwọ m nke mbụ m dere gị banyere ihe niile Jisọs malitere ime nakwa ikuzi,
\v 2 ruo nʼụbọchị e mere ka ọ laghachi nʼeluigwe mgbe o sitere nʼike Mmụọ nsọ nyesịa ndị na-eso ụzọ ya iwu, bụ ndị ọ họpụtara.
\v 3 Mgbe ọ hụsịrị ahụhụ nke ọnwụ, o gosiri ha onwe ya nʼụzọ dị iche iche nʼebe o doro anya na ya dị ndụ. O mere ka ha hụ ya anya nʼime iri ụbọchị anọ, na-akụziri ha banyere alaeze Chineke.
\v 4 Nʼotu oge, ọ nọnyeere ha na nri, o nyere ha iwu a, \wj “Unu esila na Jerusalem pụọ, kama cherenụ nkwa nke Nna m, nke unu nụrụ site nʼọnụ m.\wj*
\v 5 \wj Nʼihi na Jọn jiri mmiri mee unu baptizim, ma nʼoge na-adịghị anya, a ga-eji Mmụọ Nsọ mee unu baptizim.”\wj*
\p 
\v 6 Mgbe ha gbakọrọ, ha jụrụ ya, “Onyenwe anyị, ọ bụ ugbu a ka i ga-enyeghachi Izrel alaeze ahụ?”
\p 
\v 7 Ma ọ sịrị ha, \wj “Ọ bụghị ọrụ unu ịmata oge na mgbe Nna m na-akwado ihe o zubere ime nʼikike nke onwe ya.\wj*
\v 8 \wj Ma mgbe Mmụọ Nsọ bịakwasịrị unu, unu ga-anata ike. Mgbe ahụ, unu ga-agbara m ama na Jerusalem, na Judịa niile ya na Sameria ruokwa ebe niile ụwa sọtụrụ.”\wj*
\p 
\v 9 Mgbe o kwusiri nke a, e weliri ya elu mgbe ha na-ele anya, igwe ojii kpuchikwara ya, zopu ya nʼanya ha.
\p 
\v 10 Mgbe ha na-elegidesi anya ike nʼeluigwe dịka ọ na-ala, na mberede, ụmụ nwoke abụọ yi uwe ọcha guzooro ha nso.
\v 11 Ha sịrị, “Ndị ikom Galili, gịnị mere unu jiri guzoro ebe a na-ele anya nʼeluigwe? Jisọs a onye e sitere nʼetiti unu kpọrọ laa nʼeluigwe ga-alọghachikwa otu ahụ unu si hụ ya o siri laa nʼeluigwe.”
\s1 Mataias, onye nọchiri anya Judas
\p 
\v 12 Ha sitere nʼUgwu a na-akpọ Oliv nke dị Jerusalem nso, njem nke otu ụbọchị izuike, laghachi na Jerusalem.
\v 13 Mgbe ha batara nʼobodo, ha rigoro nʼime ụlọ ahụ dị nʼụlọ elu, ebe ha na-anọ. Ndị a bụ ndị nọ nʼụlọ ahụ:
\b
\li1 Pita, Jọn, Jemis na Andru,
\li1 Filip na Tọmọs,
\li1 Batalomi na Matiu,
\li1 Jemis nwa Alfiọs, Saimọn onye a na-akpọ Zilọt na Judas nwa Jemis.
\b
\p 
\v 14 Ndị a niile ji otu obi nọgidesie ike nʼekpere. Ndị sonyere ha bụ ụfọdụ ndị inyom na Meri nne Jisọs, na ụmụnna ya.
\p 
\v 15 Nʼoge ahụ, Pita bilitere nʼetiti ndị kwere ekwe ọnụọgụgụ ha dị ihe dị ka narị na iri abụọ, sị,
\v 16 “Ụmụnna m, ọ dị mkpa ka ihe e dere nʼakwụkwọ nsọ mezuo banyere Judas onye duuru ndị jidere Jisọs bịa. Mmụọ Nsọ kwuru na nke a ga-eme mgbe o sitere nʼọnụ Devid kwuo okwu nʼoge gara aga.
\v 17 Ọ bụ otu nʼime anyị. O nwere oke nʼime ọrụ a.”
\p 
\v 18 Ego ọ natara nʼihi ọrụ ọjọọ ya ka o jiri zụọ ala. Nʼala ahụ ka ọ dara sụọ isi nʼala, afọ ya etipuo, eriri afọ ya awụsịakwa.
\v 19 Ndị niile bi na Jerusalem nụrụ akụkọ banyere ya. Nʼihi ya, ha kpọrọ ala ahụ nʼasụsụ ha Akeldama, nke pụtara Ala Ọbara.
\p 
\v 20 Pita sịrị, “Nʼihi na e dere ya nʼakwụkwọ Abụ Ọma:
\q1 “ ‘Ka ebe obibi ya tọgbọrọ nʼefu,
\q2 ka mmadụ ọbụla gharakwa ibi nʼime ya,’\f + \fr 1:20 \ft \xt Abụ 69:25\xt*\f*
\m na,
\q1 “ ‘Ka onye ọzọ nọchiekwa ọnọdụ ya ka onyeisi.’\f + \fr 1:20 \ft \xt Abụ 109:8\xt*\f*
\m 
\v 21 Ya mere, otu onye nʼime ndị anyị na ha nọ nʼoge niile Onyenwe anyị Jisọs nọ nʼetiti anyị,
\v 22 bido nʼoge Jọn na-eme baptizim ruo nʼụbọchị Jisọs si nʼetiti anyị rigoro nʼeluigwe. Otu onye nʼime ndị a ga-eso anyị bụrụ onye akaebe nke mbilite nʼọnwụ ya.”
\p 
\v 23 Ya mere, ha họpụtara mmadụ abụọ, Josef onye a na-akpọ Basabas (aha ya ọzọ bụkwa Jọstus) na Mataias.\f + \fr 1:23 \ft Mataias bụ onye ahọpụtara ka ọ nọchie anya Judas Iskarịọt nʼije ozi. Ọrụ ndị ozi bụ ịgba ama na ikwupụta mbilite nʼọnwụ Jisọs dịka Kraịst ahụ.\f*
\v 24 Ha kpere ekpere sị, “Onyenwe anyị, ị maara obi mmadụ niile. Gosi anyị onye ị họpụtara nʼime mmadụ abụọ ndị a.
\v 25 Ka ọ bụrụ onyeozi na onyendu nke ga-anọchi anya Judas onye nke hapụrụ ma gawa ebe o kwesiri ka ọ gaa.”
\v 26 Ha fere ha nza. Nza ahụ makwara Mataias, ha gụnyere ya dị ka otu nʼime ndị ozi iri na otu ahụ.
\c 2
\s1 Ọbịbịa nke Mmụọ Nsọ
\p 
\v 1 Mgbe ụbọchị Pentikọọsụ ruru, ha niile zukọtara nʼotu ebe.
\v 2 Na mberede, ụzụ yiri nke oke ifufe dị ike sitere nʼeluigwe bịa jupụta nʼụlọ ahụ ha nọ.
\v 3 Ha hụrụ ihe dịka ire ọkụ ka o kewara nọkwasị nʼisi ha nʼotu nʼotu.
\v 4 Ha niile jupụtara na Mmụọ Nsọ, malite ịsụ asụsụ dị iche iche dịka Mmụọ Nsọ nyere ha ike.
\p 
\v 5 Nʼoge ahụ, ọtụtụ ndị Juu ji obi ọcha na-efe Chineke nọ na Jerusalem. Ndị si na mba dị iche iche nʼokpuru eluigwe.
\v 6 Igwe mmadụ gbakọtara nʼọnọdụ mgbagwoju anya mgbe ha nụrụ ụzụ ahụ, nʼihi na ha nụrụ ka ha na-asụ asụsụ nke onye ọbụla nʼime ha na-aghọta, nʼasụsụ obodo ha dị iche iche.
\v 7 Nʼoke iju anya, ha kwurịtara nʼonwe ha, “Ndị a niile na-ekwu okwu ha abụghị ndị Galili?
\v 8 Gịnị mere onye ọbụla nʼime anyị ji na-anụ okwu ha na-ekwu nʼasụsụ ala anyị dị iche iche?
\v 9 Ndị Patia, na ndị Midia, na ndị Elam, ndị bikwa nʼime Mesopotamịa, ndị Judịa, na ndị Kapadosia, ndị Pọntọs, na ndị Eshịa,
\v 10 ndị Frigia, na ndị Pamfilia, na ndị Ijipt, na ndị akụkụ Libiya nke dị Sirini nso, na ndị ọbịa si na Rom bịa
\v 11 (ndị Juu na ndị kwere nʼokpukpe ndị Juu). Ndị Kriit na ndị Arab; anyị na-anụ okwu ha na-ekwu nʼasụsụ anyị dị iche iche banyere ọrụ ebube Chineke.”
\v 12 O juru ha anya, gbaakwa ha gharịị. Ha sịrịtara onwe ha, “Gịnị ka nke a bụ?”
\p 
\v 13 Ma ụfọdụ ndị ọzọ na-akwa ha emo na-asị, “Ndị a bụ ndị mmanya na-egbu.”
\s1 Okwu Pita banyere Kraịst
\p 
\v 14 Pita guzoro, ya na ndị ozi iri na otu ahụ welie olu gwa ọgbakọ ahụ okwu, “Ndị Juu na unu ndị bi na Jerusalem, matanụ nke a, geekwanụ ntị na ihe m na-ekwu.
\v 15 Ọ bụghị mmanya na-egbu ndị a dị ka unu chere. Lee, ọ bụ naanị elekere itoolu nke ụtụtụ na-akụ.
\v 16 Mba, nke a bụ mmezu ihe Juel onye amụma kwuru,
\q1 
\v 17 “ ‘Chineke sịrị, nʼoge ikpeazụ,
\q2 aga m awụkwasị mmadụ niile Mmụọ m.
\q1 Ụmụ unu ndị ikom na ụmụ unu ndị inyom ga-ebu amụma,
\q2 ụmụ okorobịa unu ga-ahụkwa ọhụ,
\q2 ndị okenye nwoke unu ga-arọ nrọ.
\q1 
\v 18 Ọ bụladị ndị ohu m, nwoke ha na nwanyị nʼime ha,
\q2 ka m ga-awụkwasị Mmụọ m.
\q2 Ha ga-ebukwa amụma.
\q1 
\v 19 Aga m egosi ihe ịtụnanya na mbara eluigwe,
\q2 gosikwa ihe ịrịbama nʼụwa na nʼokpuru ụwa,
\q2 ọbara na ọkụ na alulu anwụrụ ọkụ.
\q1 
\v 20 Anyanwụ ga-agbanwe ghọọ ọchịchịrị,
\q2 ọnwa ga-aghọkwa ọbara,
\q2 tupu ụbọchị Onyenwe anyị abịa, bụ ụbọchị ahụ dị ukwu dịkwa ebube.
\q1 
\v 21 Ọ ga-erukwa, na onye ọbụla nke na-akpọku
\q2 aha Onyenwe anyị, ka a ga-azọpụta.’\f + \fr 2:21 \ft \xt Jul 2:28-32\xt*\f*
\p 
\v 22 “Ndị Izrel, geenụ ntị nʼokwu a, Jisọs onye Nazaret bụ nwoke Chineke gosiri unu, site nʼọrụ dị ike, nʼọrụ ebube nakwa ihe ịrịbama niile nke Chineke rụrụ nʼetiti unu site nʼaka ya, dịka unu ji anya unu hụ.
\v 23 Onye a ka e weere nyefee unu nʼaka site na nzube nke Chineke buru ụzọ tụọ atụmatụ ya, na dịka o siri mara na mbụ, ọ bụ ya ka unu gburu ma kpọgidekwa nʼobe site nʼaka ndị na-amaghị iwu.
\v 24 Ma Chineke emela ka o site nʼọnwụ bilie mgbe ọ tọpụchara ihe mgbu nke ọnwụ, nʼihi na ọnwụ enweghị ike ijide ya.
\v 25 Devid kwuru banyere ya,
\q1 “ ‘Ana m ahụ Onyenwe anyị ka ọ na-anọgide nʼihu m mgbe niile.
\q2 Nʼihi na ọ nọ nʼaka nri m.
\q2 Agaghị m ama jijiji.
\q1 
\v 26 Ya mere, ọṅụ jupụtara m obi, ire m na-aṅụrịkwa ọṅụ;
\q2 anụ ahụ m ga-ezukwa ike nʼolileanya,
\q1 
\v 27 nʼihi na ị gaghị ahapụ mkpụrụobi m nʼala mmụọ,
\q2 ị gakwaghị ahapụ anụ ahụ nke Onye gị dị nsọ ka ọ hụ ire ure.
\q1 
\v 28 I mere ka m mara ụzọ nke ndụ;
\q2 ị ga-emekwa ka m jupụta nʼọṅụ nʼihu gị.’\f + \fr 2:28 \ft \xt Abụ 16:8-11\xt*\f*
\p 
\v 29 “Ụmụnna m, eji m nkwuwa okwu na-agwa unu banyere nna nna anyị Devid, bụ onye nwụrụ anwụ e lie ya. Ili ya dịkwa nʼetiti anyị taa.
\v 30 Ma ọ bụ onye amụma marakwa na Chineke jiri ịṅụ iyi kwee ya nkwa na otu nʼime ụmụ ya ga-anọkwasị nʼocheeze ya.
\v 31 Ebe o buuru ụzọ hụ ihe ga-eme nʼoge dị nʼihu, o kwuru banyere mbilite nʼọnwụ nke Kraịst, mgbe ọ sịrị, a hapụghị ya nʼala mmụọ; anụ ahụ ya ahụghịkwa ire ure.
\v 32 Ọ bụ Jisọs a ka Chineke mere ka ọ dị ndụ ọzọ. Anyị niile bụkwa ndị akaebe banyere ya.
\v 33 Ebe ọ bụ na e buliela ya elu nʼaka nri Chineke. Ọ natala Mmụọ Nsọ dịka Nna ya kwere na nkwa. Ihe a unu na-ahụ na nke unu na-anụ bụ onyinye ya ọ wụkwasịrị anyị.
\v 34 Ọ dịghị oge Devid jiri rigoro nʼeluigwe, ma ya onwe ya sịrị,
\q1 “ ‘Onyenwe anyị gwara Onyenwe m sị,
\q2 “Nọdụ ala nʼaka nri m,
\q1 
\v 35 ruo mgbe m ga-eme ndị iro gị
\q2 ihe mgbakwasị ụkwụ nye ụkwụ gị.” ’\f + \fr 2:35 \ft \xt Abụ 110:1\xt*\f*
\p 
\v 36 “Ya mere, ana m eme ka ezinaụlọ Izrel niile mara nke ọma, na Chineke emeela Jisọs a onye unu kpọgidere nʼobe ka ọ bụrụ Onyenwe anyị na Kraịst.”
\p 
\v 37 Mgbe ha nụrụ ihe ndị a, akọnuche ha mara ha ikpe. Ha sịrị Pita na ndị ozi ndị ọzọ, “Ụmụnna, gịnị ka anyị ga-eme?”
\p 
\v 38 Ma Pita sịrị ha, “Chegharịanụ unu niile. Ka e mekwa unu baptizim nʼaha Jisọs Kraịst, maka mgbaghara mmehie unu. Unu ga-anatakwa onyinye nke Mmụọ Nsọ.
\v 39 Nkwa a dịrị unu na ụmụ ụmụ unu na mmadụ niile nọ nʼebe dị anya, dịkwara ndị niile Onyenwe anyị Chineke ga-akpọ ka ha bịakwute ya.”
\p 
\v 40 O jiri ọtụtụ okwu ndị ọzọ gbaa ama, ma dụọkwa ha ọdụ sị, “Sitenụ nʼetiti ọgbọ a jọrọ njọ zọpụta onwe unu.”
\v 41 E mere ndị nabatara okwu ya baptizim, ha dị ihe ruru puku mmadụ atọ, a gụnyere nʼọnụọgụgụ ha.
\s1 Nnọkọ nke ndị kwere ekwe
\p 
\v 42 Ha nyefere onwe ha nʼozizi nke ndị ozi, ya na ife ofufe na ịnyawa achịcha nakwa ikpe ekpere.
\v 43 Onye ọbụla nʼime ha jupụtara na egwu, nʼihi na ndị ozi na-arụ ọtụtụ ọrụ ebube, na ihe ịrịbama dị iche iche.
\v 44 Ndị niile kwere ekwe nọkọtara ọnụ, nwekọkwaa ihe niile ọnụ.
\v 45 Ha rere ihe ha nwere na nke ha kpatara, kenye onye ọbụla dịka mkpa ya siri dị.
\v 46 Ha gara nʼihu na-ezukọta nʼụlọnsọ ukwu ikpe ekpere kwa ụbọchị. Ha na-erikọkwa nri nʼụlọ ha, nʼobi ọṅụ na ekele.
\v 47 Dịka ha gara nʼihu na-eto Chineke, ha nwetara ihuọma nʼaka ndị mmadụ. Onyenwe anyị na-atụkwasịkwara ha ndị a na-azọpụta kwa ụbọchị.
\c 3
\s1 Ọgwụgwọ onye ngwụrọ
\p 
\v 1 Otu ụbọchị Pita na Jọn na-aga nʼụlọnsọ ukwu ikpe ekpere nʼoge ekpere nʼelekere atọ nke ehihie.
\v 2 Ma otu nwoke dara ngwụrọ site nʼafọ nne ya ka a na-ebute nʼọnụ ụzọ ama nke ụlọnsọ ukwu ahụ ụbọchị niile ka ọ na-arịọ ndị na-aba nʼime ụlọnsọ ukwu ahụ arịrịọ. Aha ọnụ ụzọ ama ahụ bụ ọnụ ụzọ ama ọma.
\v 3 Mgbe ọ hụrụ Pita na Jọn ka ha na-achọ ịba nʼụlọnsọ ukwu ahụ, o bidoro ịrịọ ha arịrịọ.
\v 4 Ma Pita na Jọn legidere ya anya, Pita sịrị, “Lee anyị anya.”
\v 5 O legidere ha anya chee na ha ga-enye ya onyinye.
\p 
\v 6 Ma Pita sịrị, “Enweghị m ọlaọcha maọbụ ọlaedo ma ihe m nwere ka m na-enye gị. Nʼaha Jisọs Kraịst onye Nazaret bilie ọtọ gawa ije.”
\v 7 O jidere ya aka nʼaka nri ya, nyere ya aka selite ya elu, ngwangwa, ụkwụ ya na nkwonkwo nke akwara ụkwụ ya nwetara ike.
\v 8 Ọ wụliri elu nʼụkwụ ya, bido ịga ije. O soro ha baa nʼụlọnsọ ukwu ahụ, ya na-aga, ya ana-awụlị elu, na-etokwa Chineke.
\v 9 Mmadụ niile hụrụ ya ka ọ na-agagharị na-eto Chineke,
\v 10 ha ghọtara na ọ bụ ya bụ onye ahụ na-anọ nʼọnụ ụzọ ama ụlọnsọ ukwu ahụ, nke a na-akpọ ọnụ ụzọ ama ọma na-arịọ arịrịọ. Ọ gbagwojuru ha anya nke ukwuu, gbakwa ha gharịị ihe mere ya.
\s1 Okwu Pita nʼụlọnsọ ukwu
\p 
\v 11 Ma dị ka o jidere Pita na Jọn aka, ndị mmadụ niile jiri mgbagwoju anya gbara ọsọ bịakwute ha nʼakụkụ ụlọnsọ ahụ ebe a na-akpọ mgbe ụlọ Solomọn.
\v 12 Mgbe Pita hụrụ nke a, ọ gwara igwe mmadụ ahụ, “Ndị Izrel, gịnị mere ihe a ji eju unu anya? Gịnị mere unu ji ele anyị anya dịka a ga-asị na ọ bụ site nʼike nke anyị maọbụ nʼịdị nsọ anyị ka anyị jiri mee ka nwoke a gawa ije?
\v 13 Chineke nke Ebraham, nke Aịzik na nke Jekọb, Chineke nke nna anyị ha, ebuliela onye na-ejere ya ozi, bụ Jisọs elu, onye unu nyefere ka e gbuo, ma gọnarịkwa ya nʼihu Pailet, nʼagbanyeghị na o kpebiri ịhapụ ya ka ọ laa.
\v 14 Unu gọnarịrị onye ahụ dị nsọ bụrụkwa onye ezi omume, ma rịọ ka a hapụrụ unu ogbu mmadụ.
\v 15 Unu gburu onye ahụ na-enye ndụ, ma Chineke akpọlitela ya site nʼọnwụ. Anyị bụ ndị akaebe ihe ndị a.
\v 16 Ọ bụ site nʼokwukwe nʼaha ya, ọ bụ aha ya naanị mere nwoke a ka ọ dị ike onye nke unu na-ahụ ma marakwa. Okwukwe nʼime Jisọs mere ka ahụ ya zuo oke nʼihu unu niile.
\p 
\v 17 “Ugbu a ụmụnna m, amaara m na unu kpara agwa na-amaghị ama, dịka ndị ndu unu sikwara kpaa.
\v 18 Ma Chineke siri otu a mezuo ihe o kwuru site nʼọnụ ndị amụma niile na Kraịst ya aghaghị ịhụ ahụhụ.
\v 19 Ya mere, chegharịanụ ugbu a ma lọghachikwutekwanụ Chineke, ka e nwee ike ihichapụ mmehie unu,
\v 20 ka enyekwa unu ntute nke ime mmụọ nke sitere nʼihu Onyenwe anyị, ma zitekwara unu Kraịst ahụ, bụ onye ahọpụtara nye unu, nke bụ Jisọs.
\v 21 Onye eluigwe na-aghaghị ịnabata tutu ruo oge ahụ Chineke ga-eweghachi ihe niile nʼọnọdụ ha, dịka o kwere na nkwa nʼogologo oge gara aga site nʼọnụ ndị amụma ya dị nsọ.
\v 22 Mosis sịrị, ‘Onyenwe anyị bụ Chineke ga-eme ka onye amụma ga-adị ka m biliere unu site nʼetiti ụmụ nne unu, unu aghaghị ige ntị nʼihe niile ọ ga-agwa unu.
\v 23 Onye ọbụla jụrụ ige onye amụma ahụ ntị, ka a ga-ekewapụ kpamkpam site nʼetiti ndị ya ma bibiekwa ya.’\f + \fr 3:23 \ft \xt Dit 18:15,18,19\xt*\f*
\p 
\v 24 “Nʼezie ndị amụma niile site na Samuel na ndị ọzọ so ya nʼazụ, bukwara amụma banyere ụbọchị ndị a.
\v 25 Ma unu bụ ndị nketa nke ndị amụma, nakwa nke ọgbụgba ndụ ahụ Chineke na nna nna unu gbara, mgbe ọ gwara Ebraham, ‘Site na mkpụrụ gị ka a ga-agọzi mba niile nke ụwa.’\f + \fr 3:25 \ft \xt Jen 22:18; 26:4\xt*\f*
\v 26 Mgbe Chineke kpọlitere onyeozi ya, o buuru ụzọ zitere unu ya, ka ọ gọzie unu site nʼime ka onye ọbụla nʼime unu chegharịa site nʼụzọ ọjọọ ya.”
\c 4
\s1 Pita na Jọn nʼụlọikpe
\p 
\v 1 Mgbe ha nọ na-agwa ndị mmadụ ahụ okwu, ndị nchụaja na onyeisi ndị agha na-eche ụlọnsọ ukwu ahụ na ndị Sadusii bịakwutere ha.
\v 2 Ha were oke iwe nʼihi na ha na-ezi ndị mmadụ ihe, na-ekwusakwa na nʼime Jisọs ka mbilite nʼọnwụ nke ndị nwụrụ anwụ dị.
\v 3 Ha jidere ha tinye ha nʼụlọ mkpọrọ, ruo nʼechi ya. Nʼihi na oge e jidere ha bụ nʼoge uhuruchi.
\v 4 Ma ọtụtụ ndị nụrụ okwu ahụ kwenyere. Ọnụọgụgụ ha ruru ihe dị ka puku mmadụ ise.
\p 
\v 5 Nʼechi ya, ndị na-achị achị, na ndị okenye na ndị ozizi iwu zukọrọ na Jerusalem.
\v 6 Onyeisi nchụaja bụ Anas nọ nʼebe ahụ, na Kaịfas na Jọn na Alegzanda, na ndị ọzọ bụ ndị ikwu onyeisi nchụaja.
\v 7 Mgbe ha kpọpụtara ha nʼetiti ha, ha jụrụ ha, “Ọ bụ site nʼike onye, na site nʼaha onye, ka unu ji mee ihe a?”
\p 
\v 8 Nʼoge ahụ, Pita jupụtara na Mmụọ Nsọ. Ọ gwara ha, “Unu ndị na-achị ala anyị, na ndị okenye.
\v 9 Ọ bụrụ na unu kpọpụtara anyị ịchọpụta otu nwoke ngwụrọ a si bụrụ onye ahụ dị mma maọbụ otu e si gwọọ ya,
\v 10 ya mere maranụ nke a, unu na ndị Izrel niile, a gwọrọ nwoke a guzo nʼetiti unu site nʼaha Jisọs Kraịst onye Nazaret, onye unu kpọgidere nʼobe, ma Chineke kpọlitere ya site nʼọnwụ.
\v 11 Jisọs a bụ
\q1 “ ‘nkume ahụ unu ndị na-ewu ụlọ jụrụ,
\q2 nke ghọrọ nkume isi ntọala ụlọ.’\f + \fr 4:11 \ft \xt Abụ 118:22\xt*\f*
\m 
\v 12 Nzọpụta adịghị nʼime onye ọbụla ọzọ, nʼihi na o nweghị aha ọzọ e nyere nʼetiti mmadụ nʼokpuru eluigwe nke e nwere ike isite na ya zọpụta anyị.”
\p 
\v 13 Mgbe ha hụrụ nkwuwa okwu Pita na Jọn, na-atụghị ụjọ, ma chọpụtakwa na ha bụ ndị mmadụ nkịtị, na ndị a na-azụghị nʼụlọ akwụkwọ, o juru ha anya. Ma ha ghọtara na ha bụ ndị ha na Jisọs nọkọrọ.
\v 14 Ma mgbe ha hụrụ nwoke ahụ a gwọrọ, ka o guzo nʼakụkụ ha, ha enweghị okwu ọbụla ha nwere ikwu megide nke a.
\v 15 Ha nyere iwu ka ha si nʼụlọikpe ahụ pụọ, ma bido ịgba izu nʼetiti onwe ha banyere nke a.
\v 16 Ha na-asị, “Gịnị ka anyị ga-eme ndị a? Anyị apụghị ịgọ agọ na ha rụrụ ọrụ ịrịbama pụrụ iche. Ndị niile bi na Jerusalem maara ihe banyere nke a.
\v 17 Ma iji mee ka akụkọ ọrụ ebube a hapụ ịgbasa ruo ọtụtụ mmadụ ntị, ka anyị dọọ ha aka na ntị ka ha ghara ịgwa onye ọbụla okwu banyere aha nwoke a.”
\p 
\v 18 Ha kpọrọ ha nye ha iwu ka ha kwụsị ikwu okwu maọbụ izi ihe nʼaha Jisọs.
\v 19 Ma Pita na Jọn zara sị ha, “Kpeenụ ikpe a nʼonwe unu, maọbụ ihe ziri ezi nʼanya Chineke ige unu ntị karịa ige Chineke ntị?
\v 20 Nʼihi na ọ bụ ihe rara ahụ na anyị ga-akwụsị ikwu okwu banyere ihe ahụ anyị hụrụ na nke anyị nụrụ.”
\p 
\v 21 Mgbe ha batụchara ha mba, ha hapụrụ ha ka ha laa. O nweghị ụzọ ọbụla ha ga-esi taa ha ahụhụ nʼihi na mmadụ niile nọ na-eto Chineke nʼihi ihe a mere.
\v 22 Nʼihi na nwoke a gwọrọ nʼụzọ dị ebube agafeela iri afọ anọ.
\s1 Ekpere ndị kwere ekwe
\p 
\v 23 Mgbe ha hapụrụ ha, ha lara kọọrọ ndị ibe ha ihe ndịisi nchụaja na ndị okenye gwara ha.
\v 24 Mgbe ha nụrụ nke a, ha niile ji otu obi welie olu ha kpọkuo Chineke, sị, “Gị, Onye kachasị ihe niile elu, bụ Onyenwe anyị, gị onwe gị kere eluigwe na ụwa, na oke osimiri, na ihe niile dị nʼime ha.
\v 25 Ọ bụ gị sitere nʼaka Mmụọ Nsọ site nʼọnụ nna anyị Devid, onye na-ejere gị ozi, sị:
\q1 “ ‘Gịnị mere mba niile ji eme oke mkpọtụ?
\q2 Gịnị mere ndị mmadụ ji na-apịa ọpịpịa nke na-abaghị uru?
\q1 
\v 26 Ndị eze nke ụwa na-eguzokwa onwe ha,
\q2 ndị na-achị achị na-agbakọtakwa,
\q1 imegide Onyenwe anyị
\q2 na imegide Onye ya e tere mmanụ.’\f + \fr 4:26 \ft \xt Abụ 2:1,2\xt*\f*
\m 
\v 27 Nʼezie nʼobodo a, Herọd na Pọntiọs Pailet, na ndị mba ọzọ, nakwa ndị Izrel ezukọtala imegide onye nsọ ahụ na-ejere gị ozi, bụ Jisọs, onye i tere mmanụ,
\v 28 ha mere ihe i jiri ike gị na uche gị kwuo na ha aghaghị imezu.
\v 29 Ugbu a, Onyenwe anyị, lee ịba mba ha ma nye ndị ohu gị ike iji gbasaa ozi gị na-atụghị egwu ọbụla.
\v 30 Setịpụ aka gị gwọọ ndị ọrịa ma rụọ ọtụtụ ọrụ ebube na ọrụ ịrịbama site nʼaha onye nsọ ahụ na-ejere gị ozi bụ Jisọs.”
\p 
\v 31 Mgbe ha kpesịrị ekpere, ụlọ ahụ ha zukọrọ nʼime ya mara jijiji. Ha jupụtara na Mmụọ Nsọ, ma jiri nkwuwa okwu kwusaakwa okwu Chineke.
\s1 Ndị kwere ekwe na-ekekọrịta ihe
\p 
\v 32 Ndị niile kwere ekwe nwere otu obi nʼotu mkpụrụobi. O nweghị onye ọbụla gụrụ ihe ọbụla o nwere dịka nke aka ya, kama ha mere ka onye ọbụla nʼime ha keta oke nʼihe ibe ya nwere.
\v 33 Ndị ozi sitere nʼike gaa nʼihu na-agba ama banyere mbilite nʼọnwụ Onyenwe anyị Jisọs, oke amara bakwaara ha niile ụba.
\v 34 O nweghị onye mkpa kpara nʼime ha, nʼihi na site nʼoge ruo nʼoge, ndị nwere ala maọbụ ụlọ na-ere ha, ma wetakwa ego ha retara na ha,
\v 35 nye ndị ozi, a na-ekekwa ya nye onye ọbụla dị ka mkpa ya si dị.
\p 
\v 36 Josef onye ikwu Livayị, onye sitere na Saiprọs, onye ndị ozi na-akpọ Banabas (nke pụtara “nwa nke nkasiobi”).
\v 37 O rere ala o nwere, weta ego ya, ma tọgbọ ya nʼụkwụ ndị ozi.
\c 5
\s1 Ananayas na Safaịra
\p 
\v 1 Ma otu nwoke a na-akpọ Ananayas na nwunye ya bụ Safaịra rekwara ala nke ha.
\v 2 Na nkwekọrịta ya na nwunye ya, o zoro ụfọdụ ego site nʼego ha retara nʼala ha ahụ, weta nke fọdụrụ bịa tọgbọ nʼụkwụ ndị ozi.
\p 
\v 3 Pita sịrị, “Ananayas, gịnị mere ekwensu jiri jupụta obi gị mee ka ị ghaara mmụọ nsọ ụgha mgbe i zopuuru onwe gị ego site nʼime ego i retara nʼala gị?
\v 4 Ọ bụghị gị nwe ala ahụ tupu e ree ya? Mgbe e rechara ya, ego e retara ya ọ bụghị nke gị, iji mee ka ị chọrọ? Gịnị mere i ji chee echiche ime ihe dị otu a? Ọ bụghị mmadụ ka ị ghaara ụgha kama ọ bụ Chineke.”
\p 
\v 5 Mgbe Ananayas nụrụ okwu ndị a, ọ dara nʼala nwụọ, egwu jidekwara ndị niile nụrụ ihe mere.
\v 6 Ụmụ okorobịa ndị nọ ebe ahụ batara jiri akwa kee ozu ya bupụ ya ga lie.
\p 
\v 7 Mgbe ihe dịka awa atọ gasịrị, nwunye ya batakwara, ma ọ matabeghị ihe mere di ya.
\v 8 Pita jụrụ ya, gwa m, “ọ bụ ego ole a ka gị na di gị retara ala ahụ?”
\p Ọ sịrị, “E, ọ bụ ego ole ahụ ka anyị retara ya.”
\p 
\v 9 Pita sịrị ya, “Gịnị mere unu jiri kpebie ịnwa Mmụọ nke Onyenwe anyị ọnwụnwa? Gee ntị, nzọ ụkwụ ndị buuru di gị gaa lie nọ nʼọnụ ụzọ. Ha ga-ebupụkwa gị.”
\p 
\v 10 Nʼotu oge ahụ ọ dara nʼala nʼụkwụ ya, nwụọ, ụmụ okorobịa ahụ liri di ya batakwara chọpụta na ọ nwụọla, buru ya pụọ gaa lie ya nʼakụkụ di ya.
\v 11 Oke egwu tụrụ nzukọ ahụ niile, tụọkwa ndị niile nụrụ akụkọ banyere ihe ndị a.
\s1 Ọrụ ebube na ọrụ ịtụnanya
\p 
\v 12 Ndị ozi ahụ rụkwara ọrụ ebube na ọrụ ịrịbama dị ukwuu nʼetiti ndị mmadụ. Ha niile na-ezukọ na mgbe ụlọ Solomọn.
\v 13 O nweghị onye ọbụla kwere iso ha ọzọ, nʼagbanyeghị na ọtụtụ mmadụ na-asọpụrụ ha.
\v 14 Ma otu ọ dị, ọtụtụ ndị nwoke na ndị nwanyị kwere nʼOnyenwe anyị sonyere ha.
\v 15 Nʼihi nke a, ndị mmadụ bupụtara ndị ọrịa nʼokporoụzọ nibe ha nʼute na ihe ndina, ka ọ ga-abụ mgbe Pita na-agafe onyinyo ya ga-adakwasị ụfọdụ nʼime ha.
\v 16 Igwe mmadụ zukọtara site nʼobodo ndị dị Jerusalem gburugburu. Ha butekwara ndị nrịa nrịa, na ndị mmụọ na-adịghị ọcha na-enye nsogbu, a gwọkwara ha niile.
\s1 Mkpagbu nke ndị ozi
\p 
\v 17 Mgbe ahụ onyeisi nchụaja na ndị otu ya so nʼotu ndị Sadusii ka ekworo jupụtara obi.
\v 18 Ha jidere ndị ozi a tụba ha nʼụlọ mkpọrọ nke ọha mmadụ.
\v 19 Ma nʼoge abalị mmụọ ozi Onyenwe anyị meghere ọnụ ụzọ ụlọ mkpọrọ ahụ kpọpụta ha sị,
\v 20 “Gaanụ, guzoronụ nʼụlọnsọ ukwu ahụ gwa ndị mmadụ ozi niile nke ndụ ọhụrụ a.”
\p 
\v 21 Mgbe ha nụrụ nke a, nʼisi ụtụtụ, ha banyere nʼụlọnsọ ukwu malite izi ihe.
\p Ma mgbe onyeisi nchụaja na ndị soo ya bịarutere, ha kpọrọ nzukọ ndị Sanhedrin nke bụ ọgbakọ jikọtara ndị okenye Izrel niile. Ha zipụrụ ozi ka e site nʼụlọ mkpọrọ kpụta ha.
\v 22 Ma mgbe ndị ahụ ha zipụrụ ruru nʼụlọ mkpọrọ, ha ahụghị ndị ozi ahụ. Ha lọghachiri azụ kọọrọ ndị ọgbakọ ahụ ihe ha hụrụ,
\v 23 “Anyị hụrụ ka a kpọchiziri ụlọ mkpọrọ ahụ nke ọma, ndị nche guzokwa nʼọnụ ụzọ ya. Ma mgbe anyị meghere ụlọ mkpọrọ ahụ, anyị ahụghị onye ọbụla nʼime ya.”
\v 24 Mgbe onyeisi ndị agha na-eche ụlọnsọ ukwu na ndịisi nchụaja nụrụ okwu ndị a, ọ gbara ha gharịị, ha na-eche ihe nke a ga-apụta.
\p 
\v 25 Nʼotu oge ahụ, otu onye gbabatara gwa ha, “Leenụ! Ndị ahụ unu tụbara nʼụlọ mkpọrọ guzo ugbu a nʼime ụlọnsọ ukwu na-ezi ndị mmadụ ihe.”
\v 26 Ngwangwa, onyeisi agha na ndị agha ya gara nʼụlọnsọ ahụ jide ndị ozi ahụ ma kpụta ha, ma ha ejighị ike mee nke a nʼihi na ha tụrụ egwu na ndị mmadụ ga-atụ ha nkume.
\p 
\v 27 Mgbe a kpụtara ha, e mere ka ha guzoro nʼihu ọgbakọ ndị Sanhedrin, onyeisi nchụaja jụrụ ha ajụjụ,
\v 28 sị, “Ọ bụ anyị adọghị unu aka na ntị ka unu kwụsị ikuzi ihe nʼaha a; ma unu emeela ka ozizi unu jupụta Jerusalem niile kpebiekwa ime ka ọbara nwoke a dịrị anyị nʼisi.”
\p 
\v 29 Pita na ndị ozi ndị ọzọ zara sị, “Anyị ga-erubere Chineke isi ọ bụghị mmadụ.
\v 30 Chineke nna nna anyị a kpọlitela Jisọs site nʼọnwụ bụ onye ahụ unu gburu site nʼịkpọgide ya nʼelu osisi.
\v 31 Chineke ebuliela ya elu nʼaka nri nke ya onwe ya dị ka Ọkpara eze na Onye nzọpụta, ka o nwee ike inye ndị Izrel niile nchegharị na mgbaghara mmehie.
\v 32 Anyị bụ ndị ama nke ihe ndị a, Mmụọ Nsọ onye Chineke nyere ndị na-erubere ya isi bụkwa onyeama.”
\p 
\v 33 Mgbe ha nụrụ nke a, ọ gbawara ha obi, ha chọọ igbu ha.
\v 34 Ma otu onye nʼime ha bụ onye Farisii, bụrụkwa onye ozizi iwu a na-asọpụrụ, aha ya bụ Gamaliel, biliri ọtọ nʼetiti ọgbakọ ahụ, nye iwu ka a kpọpụ ndị ozi ahụ nʼezi nwa oge nta.
\v 35 Ọ sịrị ha, “Ndị Izrel, leziekwanụ anya nke ọma ihe unu na-achọ ime ndị a.
\v 36 Nʼoge gara aga Teodas pụtara na-egosi na ya bụ onye pụrụ iche, ihe dịka narị mmadụ anọ sokwara ya, mgbe e gburu ya, ndị niile sooro ya gbasasịrị ihe niile a kwụsịkwa.
\v 37 Mgbe nke ya gasịrị, Judas onye Galili pụtakwara gosi onwe ya nʼoge a na-agụ ọnụọgụgụ mmadụ, o nwetakwara ndị sooro ya. Mgbe e gbukwara ya, ndị niile na-eso ya gbasasịrị.
\v 38 Ya mere, agwa m unu, hapụnụ ndị a ka ha laara onwe ha. Nʼihi na ọ bụrụ na ọrụ ha bụ ọrụ mmadụ, ọ ga-akwụsị mgbe na-adịghị anya.
\v 39 Ma ọ bụrụ na o sitere nʼaka Chineke, unu agaghị enwe ike ịkwụsị ndị ikom ndị a, unu ga-achọpụta naanị na unu na-alụso Chineke ọgụ.”
\p 
\v 40 Ọgbakọ ahụ nabatara ndụmọdụ ya. Ha kpọrọ ndị ozi ahụ pịa ha ihe, nyekwa ha iwu ka ha kwụsị ikwu okwu nʼaha Jisọs, hapụkwa ha ka ha laa.
\p 
\v 41 Mgbe ha hapụrụ ọgbakọ ahụ, ha na-aṅụrị ọṅụ nʼihi na-agụnyere ha na ndị kwesiri ịnara mkparị nʼihi aha ya.
\v 42 Ụbọchị niile, nʼime ụlọnsọ ukwu ma nʼụlọ ndị mmadụ ha na-akụzi ma na-ekwusa oziọma na Jisọs bụ Kraịst ahụ.
\c 6
\s1 Nhọpụta nke ndị inyeaka asaa
\p 
\v 1 Nʼoge ahụ mgbe ọnụọgụgụ ndị na-eso ụzọ ya bidoro ịmụba, ndị Juu na-asụ asụsụ Griik mere mkpesa megide ndị Juu na-asụ asụsụ Hibru nʼihi na a na-elefuru ndị inyom ha, ndị di ha nwụrụ anwụ anya na nri a na-eke kwa ụbọchị.
\v 2 Nʼihi nke a, ndị ozi iri na abụọ ahụ kpọrọ ọgbakọ ndị niile na-eso ụzọ ya sị, “O zighị ezi na anyị ga-ahapụ ikwusa oziọma Chineke bido na-eke nri.
\v 3 Ụmụnna anyị, sitenụ nʼetiti unu họpụta ndị ikom asaa ndị a na-agbara ezi ama na ha jupụtara na Mmụọ Nsọ na amamihe. Anyị ga-enyefe ha ọrụ a nʼaka.
\v 4 Ebe anyị onwe anyị, ga-enyefe onwe anyị nʼọrụ ikpe ekpere, na ọrụ niile metụtara izisa oziọma.”
\p 
\v 5 Mmadụ niile nabatara atụmatụ a nke ọma. Ha họpụtara Stivin, nwoke jupụtara nʼokwukwe na Mmụọ Nsọ. Ha họpụtakwara Filip, Prokorọs, Nikanọ, Timọn, Pamenas na Nikolas, onye Antiọk na-eso ụzọ ofufe ndị Juu.
\v 6 Ha chere mmadụ ndị a nʼihu ndị ozi, ndị kpeere ha ekpere, bikwasịkwa ha aka nʼisi.
\p 
\v 7 Okwu Chineke gbasara nnọọ. Ọnụọgụgụ ndị na-eso ụzọ ya na Jerusalem bakwara ụba. Nʼoge a, ọtụtụ ndị nchụaja nabatara na-erubekwa isi nʼokwukwe.
\s1 Njide e jidere Stivin
\p 
\v 8 Ugbu a, Stivin, nwoke jupụtara nʼamara na nʼike Chineke rụrụ ọtụtụ ọrụ ebube na ọrụ ịrịbama dị ukwuu nʼetiti ndị mmadụ.
\v 9 Mgbe ahụ ụfọdụ ndị Juu si nʼụlọ nzukọ nke ndị nweere onwe ha (dị ka e si akpọ ya), na nke ndị Sirini na Alegzandria nakwa ndị ọzọ sitere na mpaghara Silisia na Eshịa. Ha na Stivin malitere ịrụgharị ụka.
\v 10 Ma ha enweghị ike iguzogide amamihe na ike nke Mmụọ Nsọ nke o ji ekwu okwu.
\p 
\v 11 Mgbe ahụ, ha ji ụzọ nzuzo kpalie ụfọdụ ndị ikom ka ha sị, “Anyị nụrụ ka ọ na-ekwujọ Mosis na Chineke.”
\p 
\v 12 Ha kpasuru ndị mmadụ, ma ndị okenye ma ndị ozizi iwu. Ha bịakwutere ya jide ya, kpụrụ ya gaa na nnọkọ ụlọ ikpe.
\v 13 Ha kpọtakwara ndị bịara gbaa ama ụgha megide ya sị, “Oge niile ka nwoke a na-ekwu okwu ọjọọ banyere ebe a dị nsọ na iwu anyị.
\v 14 Anyị nụrụ ka o kwuru, na Jisọs onye Nazaret a ga-akwatu ụlọ a, gbanwekwa omenaala Mosis nyere anyị.”
\p 
\v 15 Ndị niile nọ nʼụlọikpe ahụ legidere ya anya. Ha hụrụ ihu ya ka ọ na-enwu dị ka ihu mmụọ ozi.
\c 7
\s1 Stivin agọrọ onwe ya
\p 
\v 1 Onyeisi nchụaja sịrị ya, “Ị nụrụ ihe ndị a, ọ bụ eziokwu?”
\p 
\v 2 Ọ sịrị, “Ụmụnna m na ndị nna, geenụ m ntị. Chineke onye dị ebube gosiri nna nna anyị Ebraham onwe ya mgbe ọ nọ na Mesopotamịa, tupu ọ gaa biri na Haran.
\v 3 Ọ gwara ya, ‘Site nʼobodo gị na nʼetiti ndị ikwu gị pụọ, gaa nʼala m ga-egosi gị.’\f + \fr 7:3 \ft \xt Jen 12:1\xt*\f*
\p 
\v 4 “Ya mere, o sitere nʼobodo ndị Kaldịa pụọ, gaa biri na Haran. Mgbe nna ya nwụrụ, Chineke zitere ya nʼala a ebe unu bi ugbu a.
\v 5 O nyeghị ya ihe nketa nʼebe a, ọ bụladị ihe ruru otu nzọ ụkwụ. Ma o kwere ya nkwa na ọ ga-enye ya na ụmụ ụmụ ya ala ahụ ka ọ bụrụ nke ha, nʼagbanyeghị na ọ mụtaghị nwa.
\v 6 Ma Chineke gwara ya otu a, na, ‘Ụmụ ụmụ ya ga-ebi dịka ndị ọbịa nʼala na-abụghị nke ha, ndị ga-eji ha mere ohu, ma mejọọkwa ha narị afọ anọ.
\v 7 Mana aga m ata mba ahụ ha na-efe dịka ohu ahụhụ.’\f + \fr 7:7 \ft Ya bụ, kpee ha ikpe\f* Chineke kwukwara sị, ‘Mgbe nke a gasịrị, ha ga-esi na mba ahụ pụta, bịa fee m ofufe nʼebe a.’\f + \fr 7:7 \ft \xt Jen 15:13,14\xt*\f*
\v 8 O nyere ya ọgbụgba ndụ nke obibi ugwu. Ebraham mụrụ Aịzik bie ya ugwu nʼụbọchị nke asatọ. Aịzik amụta Jekọb, Jekọb amụta ndịisi ebo iri na abụọ nke Izrel.
\p 
\v 9 “Nʼihi na ndị nna ochie ahụ nwere ekworo nʼebe Josef nọ. Ha resi ya ndị Ijipt dịka ohu. Ma Chineke nọnyeere ya,
\v 10 zọpụta ya na mkpagbu ya niile, mee ka o nwee ihuọma na amamihe nʼihu Fero eze Ijipt. Onye mere ya onye ọchịchị nʼala Ijipt na onye nlekọta nke ezinaụlọ ya niile.
\p 
\v 11 “Nʼoge ahụ, ụnwụ dara nʼala Ijipt na nʼala Kenan. Ụnwụ a wetara ahụhụ dị ukwuu. Nna nna anyị ha enwekwaghị ike ịchọta nri.
\v 12 Ma mgbe Jekọb nụrụ na nri ọka dị nʼala Ijipt, o zipụrụ nna nna anyị ha ka ha gaa njem mbụ ha nʼIjipt. Nke a bụ oge nke mbụ ha na-aga Ijipt.
\v 13 Mgbe ha gara Ijipt nke ugboro abụọ, Josef mere ka ụmụnne ya mata ya, Fero matakwara ụmụnne Josef.
\v 14 Mgbe ahụ, Josef ziri ozi ka a kpọta nna ya bụ Jekọb na ndị ikwu ya, ndị dị iri mmadụ asaa na ise ka ha bịakwute ya.
\v 15 Jekọb gara Ijipt. Ebe ahụ ka ya na nna nna anyị ha nọkwa nwụọ.
\v 16 E budatara ozu ha na Shekem, ebe e liri ha nʼili nke Ebraham jiri ego ọlaọcha zụta nʼaka ụmụ Hamọ nʼala Shekem.
\p 
\v 17 “Ma mgbe oge ahụ Chineke kwere Ebraham na nkwa na-abịaru nso, ndị Izrel nọ nʼIjipt mụbara nke ukwuu,
\v 18 ruo mgbe eze ọzọ nke na-amaghị Josef, bidoro ịchị ọchịchị nʼala Ijipt.\f + \fr 7:18 \ft \xt Ọpụ 1:8\xt*\f*
\v 19 O megburu ndị agbụrụ anyị, kpagbukwaa ha. Manye ndị nna nna anyị ha ka ha tufuo ụmụ ọhụrụ ha, ka ha ghara ịdị ndụ.
\p 
\v 20 “Ọ bụ nʼoge a ka a mụrụ Mosis, ọ mara mma nke ukwuu nʼanya Chineke. A zụrụ ya naanị ọnwa atọ nʼụlọ nna ya.
\v 21 Mgbe e tufuru ya, ada Fero kpọọrọ ya, zụọ ya dị ka nwa nwoke nke aka ya.
\v 22 A zụrụ Mosis nʼamamihe niile nke ndị Ijipt, ọ bụrụ dike nʼokwu na nʼọrụ ịtụnanya.
\p 
\v 23 “Mgbe ọ gbara iri afọ anọ, ọ batara ya nʼuche ịga ileta ụmụnna ya ndị Izrel.
\v 24 Mgbe ọ hụrụ otu onye nʼime ha nke onye Ijipt na-emegide ya, ọ lụtara ya ọgụ, bọtakwara ya ọbọ site nʼigbu onye Ijipt ahụ.
\v 25 Mosis chere na ụmụnna ya ga-aghọta na Chineke akpọlitela ya isite nʼaka ya napụta ha. Ma ha aghọtaghị.
\v 26 Nʼụbọchị ọzọ sonụ, Mosis hụrụ ụmụnna ya ndị Izrel abụọ ka ha na-alụ ọgụ. Ọ gbalịrị ime ka udo dịrị nʼetiti ha, sị, ‘Unu bụ ụmụnna, gịnị mere unu ji emejọrịta onwe unu?’
\p 
\v 27 “Ma nwoke ahụ nke na-emegbu nwanna ya nupuru ya sị, ‘Onye mere gị onyeisi na onye ikpe nʼetiti anyị?
\v 28 Ị na-achọ igbu m dị ka i si gbuo onye Ijipt ụnyaahụ?’\f + \fr 7:28 \ft \xt Ọpụ 2:14\xt*\f*
\v 29 Mgbe ọ nụrụ nke a, Mosis gbara ọsọ, gaa biri dị ka ọbịa nʼala Midia. Nʼebe ahụ ka ọ nọ mụta ụmụ nwoke abụọ.
\p 
\v 30 “Mgbe iri afọ anọ gafere, e mere ka Mosis hụ mmụọ ozi nʼọkụ na-ere ọhịa dị nʼọzara, nʼakụkụ Ugwu Saịnaị.
\v 31 Ma mgbe ọ hụrụ nke a, o juru ya anya. Dị ka ọ na-agaru nso ka o leruo ya anya, ọ nụrụ olu Onyenwe anyị ka ọ dara, sị,
\v 32 ‘Abụ m Chineke nna nna gị ha. Chineke nke Ebraham, nke Aịzik na nke Jekọb.’\f + \fr 7:32 \ft \xt Ọpụ 3:6\xt*\f* Ụjọ mere ka Mosis maa jijiji, na o nweghị ike ilegide ya anya.
\p 
\v 33 “Ma Onyenwe anyị gwara ya, ‘Yipụ akpụkpọụkwụ gị. Nʼihi na ebe ahụ i guzo bụ ala dị nsọ.
\v 34 Ahụla m otu e si akpagbu ndị m nọ nʼala Ijipt. Anụla m ịsụ ude ha bịakwa ịzọpụta ha. Ugbu a bịa, aga m ezighachi gị nʼIjipt.’\f + \fr 7:34 \ft \xt Ọpụ 3:5,7,8,10\xt*\f*
\p 
\v 35 “Ọ bụ otu Mosis ahụ ha jụrụ ajụ, mgbe ha sịrị, ‘Onye mere gị onyeisi na onye ikpe?’ Ọ bụkwa ya ka Chineke zigara ị bụ onyeisi na onye nnapụta ha, site nʼinyeaka mmụọ ozi ahụ mere ka ọ hụ ya nʼọhịa ahụ.
\v 36 O duuru ha pụta mgbe ọ rụsịrị ọrụ ebube na ihe ịrịbama dị iche iche nʼala Ijipt, na nʼOsimiri Uhie na nʼọzara iri afọ anọ.
\p 
\v 37 “Onye a bụ Mosis ahụ gwara ụmụ Izrel, sị, ‘Chineke ga-eme ka onye amụma nke dị ka m, biliere unu site nʼetiti ụmụnne unu.’\f + \fr 7:37 \ft \xt Dit 18:15\xt*\f*
\v 38 Ya onwe ya nọ nʼọgbakọ nʼọzara, ya na mmụọ ozi ahụ gwara ya okwu nʼUgwu Saịnaị, na nna nna anyị ha; ebe ọ natakwara okwu dị ndụ\f + \fr 7:38 \ft Okwu si nʼọnụ Chineke pụta\f* inye anyị.
\p 
\v 39 “Ma nna nna anyị ha jụrụ irubere ya isi. Kama ha nupuru ya nʼakụkụ, ma tụgharịa laghachi azụ nʼIjipt nʼobi ha,
\v 40 na-asị Erọn, ‘Meere anyị chi, ndị nke ga-edu anyị, nʼihi na anyị amaghị ihe mere nwoke a bụ Mosis, onye sitere nʼala Ijipt dupụta anyị.’\f + \fr 7:40 \ft \xt Ọpụ 32:1\xt*\f*
\v 41 Ha kpụụrụ onwe ha arụsị nke oyiyi nwa ehi, ha butere ihe ịchụ aja nye ya. Ha ṅụrịrị ọṅụ nʼọrụ nke aka ha.
\v 42 Ma Chineke chepuru ihu ya site nʼebe ha nọ. Ọ rara ha nye ikpere usuu ihe dị nʼeluigwe.\f + \fr 7:42 \ft Anyanwụ, ọnwa na kpakpando dị iche iche\f* Nke a dabara nʼihe e dere nʼakwụkwọ ndị amụma,
\q1 “ ‘Unu ụlọ Izrel, unu o wetara m onyinye anụ e gburu egbu ka ọ dị aja\f + \fr 7:42 \ft Ọ bụ aja unu chụrụ m\f* unu chụụrụ m
\q2 iri afọ anọ unu nọrọ nʼọzara?
\q1 
\v 43 Unu buliri ụlọ ikwu nke Mọlọk
\q2 na kpakpando nke chi unu bụ Refan,
\q2 bụ arụsị ndị ahụ unu mere ịkpọ isiala nye ha.
\q1 Ya mere, aga m ewezuga unu, burukwa unu gaa nʼofe obodo Babilọn.’\f + \fr 7:43 \ft \xt Ems 5:25-27\xt*\f*
\p 
\v 44 “Ndị nna nna anyị ha nwere ụlọ ikwu nke iwu ọgbụgba ndụ nʼọzara. E mere ya site na ntụziaka na usoro ihe atụ Chineke gosiri Mosis.
\v 45 Mgbe Joshua duuru nna nna anyị ha nweta ala ndị mba ọzọ ndị Chineke chụpụrụ. E butekwara igbe ọgbụgba ndụ a nʼala ahụ. Ọ nọgidekwara nʼala ahụ tutu ruo nʼoge Devid.
\v 46 Onye chọtara ihuọma nʼebe Chineke nọ, ma rịọ ka o wuore Chineke nke Jekọb ebe obibi.
\v 47 Ma ọ bụ Solomọn wuru ya ụlọ ahụ.
\p 
\v 48 “Otu ọ dị, Onye kachasị ihe niile elu adịghị ebi nʼụlọ e ji aka wuo, dịka onye amụma kwuru,
\q1 
\v 49 “ ‘Eluigwe bụ ocheeze m.
\q2 Ụwa bụkwa ebe mgbakwasị ụkwụ m.
\q1 Ụdị ụlọ dị aṅaa ka unu ga-ewuru m?
\q2 Maọbụ ebee ka ebe izuike m ga-adị?
\q2 Ka Onyenwe anyị kwuru.
\q1 
\v 50 Ọ bụghị aka m mere ihe ndị a niile?’\f + \fr 7:50 \ft \xt Aịz 66:1,2\xt*\f*
\p 
\v 51 “Unu ndị isiike! Ndị obi ha, na ntị ha kpọchiri akpọchi ịnụ ihe. Ndị na-ajụ ịnabata Mmụọ Nsọ dịka nna nna unu ha mere.
\v 52 Ọ dị onye amụma ndị nna unu ha na-akpọgbughị? Ha gburu ọ bụladị ndị buru amụma banyere ọbịbịa nke onye ezi omume ahụ, ma ugbu a unu bụ ndị raara ya nye ma gbukwaa ya.
\v 53 Unu bụ ndị natara iwu Chineke dịka e nyere ya site nʼaka ndị mmụọ ozi, ma unu edebeghị ya.”
\s1 Ọnwụ Stivin
\p 
\v 54 Mgbe ha nụrụ ihe ndị a, iwe were ha nke ukwu. Ha tara ikikere eze nʼiwe na nʼọnụma nʼebe ọ nọ.
\v 55 Ma ebe o jupụtara na Mmụọ Nsọ, o lere anya nʼeluigwe hụ ebube Chineke. Ọ hụkwara Jisọs ka o guzoro nʼaka nri Chineke.
\v 56 Ọ sịrị, “Lee, ana m ahụ ka eluigwe meghere, hụkwa Nwa nke Mmadụ ka ọ na-eguzo nʼaka nri Chineke.”
\p 
\v 57 Ha mere ụzụ dị ukwuu, were mkpịsịaka ha rụchie ntị ha. Ha niile gbara ọsọ gaa nụkwasị ya,
\v 58 dọkpụrụ ya pụọ nʼazụ obodo malite ịtụ ya nkume. Nʼoge a, ndị akaebe wụsara uwe ha nʼụkwụ otu nwokorobịa a na-akpọ Sọl.
\p 
\v 59 Mgbe ha na-atụ Stivin nkume ahụ, o kpere ekpere, “Onyenwe anyị Jisọs, nara mmụọ m.”
\v 60 O gburu ikpere nʼala werekwa oke olu tie mkpu, “Onyenwe anyị, biko agụnyekwarala ha mmehie nke a!” Mgbe o kwusiri nke a, ọ dara nʼala nwụọ.
\c 8
\p 
\v 1 Sọl kwenyere ka e gbuo ya.
\s1 Mkpagbu nke nzukọ Kraịst
\p Nʼụbọchị ahụ, oke mkpagbu bidoro megide nzukọ dị na Jerusalem. Ndị niile kwere ekwe, ma ewezuga ndị ozi nʼonwe ha gbasasịrị nʼala Judịa na Sameria.
\v 2 Ndị ikom, ndị na-atụ egwu Chineke, bịara buru ozu Stivin gaa lie ya. Ha ruru ụjụ nke ukwuu nʼihi ya.
\v 3 Ma Sọl bidoro ịla nzukọ nʼiyi. Ọ na-abanye site nʼụlọ ga nʼụlọ ndị kwere ekwe na-adọpụta ha, nwoke na nwanyị, tinye ha nʼụlọ mkpọrọ.
\s1 Filip nʼobodo Sameria
\p 
\v 4 Ndị ahụ a chụsasịrị zisara oziọma nʼebe niile ha gbagara.
\v 5 Filip gara nʼotu obodo dị na Sameria kwusaara ndị nọ nʼebe ahụ ihe banyere Kraịst.
\v 6 Igwe mmadụ gere ntị nʼihe Filip na-ekwu nʼihi na ha hụrụ ọrụ ịrịbama ọ rụrụ.
\v 7 Mmụọ ndị ahụ na-adịghị ọcha ji iti mkpu site nʼime ọtụtụ mmadụ pụta. Ọ gwọkwara ọtụtụ ndị ahụ ha kpọnwụrụ akpọnwụ na ndị ngwụrọ.
\v 8 Nʼihi ya, ọṅụ dị ukwuu jupụtara nʼobodo ahụ.
\s1 Saimọn onye mgbaasị
\p 
\v 9 Ugbu a, kemgbe ọtụtụ oge gara aga, otu nwoke aha ya bụ Saimọn bụ onye mgbaasị. O jirila mgbaasị ya mee ọtụtụ ihe tụrụ ndị niile bi nʼobodo Sameria nʼanya. Ọ na-anyakwa isi na ya bụ onye dị ukwu.
\v 10 Onye ọbụla, ma onye ukwu ma onye nta, na-ege ya ntị na-asịkwa “Nwoke a bụ ike Chineke ahụ a na-akpọ Ike dị ukwuu.”
\v 11 Ha na-ege ya ntị oge niile nʼihi na ọ na-eji ike mgbaasị ya na-eme ihe juru ha anya.
\v 12 Ma mgbe ha kwenyere nʼoziọma Filip dịka ọ na-ekwusa ihe banyere oziọma alaeze Chineke na aha Jisọs Kraịst, e mere ha baptizim, ma nwoke ma nwanyị ha.
\v 13 Saimọn kwerekwara otu aka ahụ. Mgbe e mechara ya baptizim, o bidoro iso Filip na-agagharị nʼihi ihe ịrịbama na ọrụ ebube niile Filip rụrụ, tụrụ ya nʼanya nke ukwuu.
\p 
\v 14 Mgbe ndị ozi nọ na Jerusalem nụrụ na ndị Sameria anabatala okwu nke Chineke, ha zigaara ha Pita na Jọn.
\v 15 Mgbe ha bịaruru, ha kpere ekpere ka ha nata Mmụọ Nsọ.
\v 16 Nʼihi na Mmụọ Nsọ abịakwasịbeghị onye ọbụla nʼime ha, kama ihe e mere ha bụ baptizim nʼaha Onyenwe anyị Jisọs.
\v 17 Mgbe Pita na Jọn bikwasịrị ha aka nʼisi, ha natara Mmụọ Nsọ.
\p 
\v 18 Mgbe Saimọn hụrụ na a na-enye Mmụọ Nsọ naanị site nʼaka ndị ozi bikwasịrị ha nʼisi, o chere ha ego nʼihu,
\v 19 sị, “nyekwanụ m ike a. Ka onye ọbụla m bikwasịrị aka nʼisi nata Mmụọ Nsọ.”
\p 
\v 20 Ma Pita sịrị, “Gị na ego gị laakwa nʼiyi. Nʼihi na i chere na ị ga-eji ego zụta onyinye Chineke.
\v 21 I nweghị oke maọbụ ihe nketa nʼọrụ a, nʼihi na obi gị ezighị ezi nʼihu Chineke.
\v 22 Si nʼajọ omume gị chegharịa, rịọ Onyenwe anyị arịrịọ ma eleghị anya ọ ga-agbaghara gị echiche ọjọọ niile nke obi gị.
\v 23 Nʼihi na ahụrụ m na ị jupụtara nʼobi ilu na ị nọkwa nʼagbụ nke ajọ omume.”
\p 
\v 24 Saimọn zara Pita sị, “Biko, kpee ekpere rịọrọ m Chineke, ka ihe ndị a niile i kwuru, hapụ ịbịakwasị m.”
\p 
\v 25 Mgbe ha gbachara akaebe, ma kwusaakwa okwu nke Onyenwe anyị, ha lọghachiri Jerusalem. Ma mgbe ha na-ala ha zisara oziọma nʼọtụtụ obodo ndị Sameria.
\s1 Filip na onye onozi Itiopia
\p 
\v 26 Mgbe ahụ mmụọ ozi Onyenwe anyị gwara Filip sị, “Gaa na ndịda, nʼụzọ ọzara nke siri Jerusalem gawa Gaza, ụzọ ahụ bụ ụzọ ọzara.”
\v 27 O biliri gawa. Mgbe ahụ, otu onye Itiopia bụ onye onozi, bụrụkwa onyeisi ozi dị mkpa, onye na-eche akụ nke Kandis, eze nwanyị ndị Itiopia, gara Jerusalem ife Chineke.
\v 28 Mgbe ọ na-ala, ọ nọdụrụ ala nʼụgbọala ya, nke ịnyịnya na-adọkpụgharị, na-agụ akwụkwọ Aịzaya onye amụma.
\v 29 Mmụọ Nsọ gwara Filip, “Gaa ụgbọ ahụ nso, sonyekwara ya.”
\p 
\v 30 Filip gara nso, nụkwa ka ọ na-agụ akwụkwọ Aịzaya onye amụma. Ọ sịrị, “Ị na-aghọta ihe ị na-agụ?”
\p 
\v 31 Ọ sịrị, “M ga-esi aṅaa ghọta, ma mmadụ ezighị m?” Ọ rịọrọ Filip ka ọ rigota nʼụgbọala ahụ, soro ya nọdụ nʼime ya.
\p 
\v 32 Mpaghara akwụkwọ nsọ ọ na-agụ bụ nke a,
\q1 “E duuru ya dị ka atụrụ gaa nʼebe a ga-egbu ya.
\q2 Dịka nwa atụrụ na-anọ nwayọọ nʼihu onye na-akpacha ya ajị,
\q2 otu a ka ọ na-emegheghị ọnụ ya.
\q1 
\v 33 Nʼọnọdụ ịdị ala ya, e meghị ka ikpe ziri ezi ruo ya aka.
\q2 Onye ga-akọ akụkọ banyere agbụrụ ya?
\q2 Nʼihi na e sitere nʼụwa wepụ ndụ ya.”\f + \fr 8:33 \ft \xt Aịz 53:7,8\xt*\f*
\p 
\v 34 Onozi ahụ jụrụ Filip, “Biko, gwa m, onye ka onye amụma a na-ekwu okwu ya? Ọ bụ ihe banyere onwe ya ka ọ na-ekwu, ka ọ bụ banyere onye ọzọ?”
\v 35 Mgbe ahụ, Filip malitere ikwu okwu, site nʼakụkọ akwụkwọ nsọ ọ na-agụ kọọrọ ya akụkọ oziọma banyere Jisọs.
\p 
\v 36 Mgbe ha na-aga nʼụzọ, ha bịaruru ebe ọdọ mmiri nta dị. Onozi ahụ sịrị, “Lee, nke a bụ mmiri. Ọ dị ihe ga-egbochi ime m baptizim?”
\p 
\v 37 Filip sịrị, “Ọ bụrụ na i ji obi gị niile kwere, e nwere ike ime gị baptizim.”
\p Onozi ahụ sịrị, “Ekwere m na Jisọs Kraịst bụ Ọkpara Chineke.”\f + \fr 8:37 \ft Ụfọdụ akwụkwọ adịghị edebanye amaokwu a na-ekwu banyere ihe Filip kwuru na ihe onozi zara ya.\f*
\v 38 O kwuru ka a kwụsị ụgbọala ahụ. Mgbe ahụ, onozi ahụ na Filip wụdatara banye nʼime mmiri ebe Filip nọ mee ya baptizim.
\v 39 Mgbe ha sitere nʼime mmiri ahụ pụta, ngwangwa Mmụọ Onyenwe anyị sitere nʼebe ahụ wepụ Filip, onye onozi ahụ ahụkwaghị ya anya ọzọ; kama ọ gara nʼihu nʼije ya na-aṅụrịkwa ọṅụ.
\v 40 Ebe ọzọ a hụrụ Filip bụ nʼAzọtus. O jegharịkwara nʼobodo niile dị nʼala ahụ, na-ekwusa oziọma ruo mgbe ọ bịaruru Sizaria.
\c 9
\s1 Nchegharị Sọl
\p 
\v 1 Ma ugbu a, Sọl, onye ume niile ọ na-ekupụta bụ naanị ịba mba na igbu ndị na-eso ụzọ Onyenwe anyị, gakwuuru onyeisi nchụaja,
\v 2 rịọ ya ka o nye ya akwụkwọ ozi nke ọ ga-eji jekwuru ndị ụlọ nzukọ ndị Juu dị na Damaskọs, nke ọ ga-abụ ọ hụ onye ọbụla na-eso Ụzọ ahụ ma ha bụ nwoke ma ha bụ nwanyị, ka ọdọkpụrụ ha nʼagbụ, kpụgaa Jerusalem.
\v 3 Mgbe ọ na-aga nʼụzọ, ọ bịaruru ebe dị Damaskọs nso. Na mberede, ihe ìhè nke sitere nʼeluigwe chara ya gburugburu.
\v 4 Ọ dara nʼala, nụ olu na-akpọ ya oku, \wj “Sọl, Sọl, gịnị mere i ji na-akpagbu m?”\wj*
\p 
\v 5 Ọ sịrị, “Ị bụ onye, Onyenwe anyị?”
\p Olu ahụ zaghachiri, \wj “Abụ m Jisọs onye ị na-akpagbu.\wj*
\v 6 \wj Ugbu a, bilie, baa nʼime obodo, a ga-agwa gị ihe ị na-aghaghị imezu.”\wj*
\p 
\v 7 Ndị ikom ha na ya so aga guzoro nʼebe ahụ, ma ha enweghị ike ikwu okwu. Ha nụrụ olu ahụ, ma ha ahụghị onye ọbụla.
\v 8 Sọl si nʼala bilie, ma nʼagbanyeghị nʼanya ya meghere emeghe, ọ dịghị ihe o nwere ike ịhụ. Nke a mere na ha sekpụrụ ya nʼaka dubata ya na Damaskọs.
\v 9 Ọ hụghị ụzọ ụbọchị atọ, o nweghị ike iri nri maọbụ ṅụọ ihe ọṅụṅụ.
\p 
\v 10 Otu onye nke na-eso ụzọ ya nọ na Damaskọs, a na-akpọ Ananayas. Onyenwe anyị gwara ya nʼọhụ, \wj “Ananayas!”\wj*
\p Ọ sịrị, “Lee m, Onyenwe anyị.”
\p 
\v 11 Onyenwe anyị gwara ya, \wj “Gaa nʼụlọ Judas nke dị nʼokporoụzọ Guzoziri Eguzo, jụọ ajụjụ banyere onye a na-akpọ Sọl, onye si Tasọs, ọ nọ ugbu a na-ekpe ekpere.\wj*
\v 12 \wj Ọ hụla ọhụ na otu nwoke a na-akpọ Ananayas na-abịakwute ya, ibikwasị ya aka nʼisi ka ọ hụ ụzọ.”\wj*
\p 
\v 13 Ma Ananayas zara, “Onyenwe anyị, anụla m akụkọ ihe ọjọọ niile nwoke a mere ndị nsọ gị bi na Jerusalem.
\v 14 Ugbu a, ọ natara ikike nʼaka ndịisi nchụaja bịa nʼebe a ka o jide ndị niile na-akpọku aha gị.”
\p 
\v 15 Ma Onyenwe anyị gwara ya, \wj “Gaa, nʼihi na ahọpụtala m nwoke a ka ọ bụrụ ngwa ọrụ m, onye ga-ewegara mba ndị ọzọ, ndị eze na ụmụ Izrel aha m.\wj*
\v 16 \wj Mụ onwe m ga-egosi ya ụdị ahụhụ ọ na-aghaghị ịta nʼihi aha m.”\wj*
\p 
\v 17 Ya mere, Ananayas garuru nʼụlọ ahụ, banyekwa nʼime ya. Ọ bikwasịrị aka ya nʼisi Sọl, sị, “Nwanna Sọl, Onyenwe anyị Jisọs, onye gosiri gị onwe ya nʼụzọ, zitere m ka ị hụkwa ụzọ ọzọ, ka ị jupụtakwa na Mmụọ Nsọ.”
\v 18 Otu mgbe ahụ, ihe dịka akpịrịkpa sitere nʼanya ya dapụta, o bidokwara ịhụ ụzọ ọzọ. O biliri ọtọ, e mee ya baptizim.
\v 19 Mgbe o richara nri, ọ nwetakwara ike ya.
\s1 Oziọma Sọl na Damaskọs
\p Ya na ndị na-eso ụzọ Jisọs nọrọ na Damaskọs ọtụtụ ụbọchị.
\v 20 Ngwangwa, o bidoro ikwusa Jisọs nʼụlọ nzukọ na-asị, Ọ bụ Ọkpara Chineke.
\v 21 O juru ndị niile nụrụ ya anya, ha na asị, “Ọ bụghị nwoke a bụ onye ahụ na-emekpa ndị niile na-akpọku aha ahụ na Jerusalem? Ọ bụ na ọ bụghị maka nke a ka o ji bịa ebe a ịkpụrụkwa ha kpụgara ndịisi nchụaja?”
\v 22 Ma Sọl gara nʼihu baa ụba nʼike karịa na ikwu okwu nke gbara ndị Juu bi nʼobodo Damaskọs gharịị site nʼụzọ o siri gosi na Jisọs bụ Kraịst ahụ.
\p 
\v 23 Mgbe ọtụtụ ụbọchị gasịrị ndị Juu gbara izu igbu ya.
\v 24 Ma Sọl chọpụtara ihe ha zubere ime. Ehihie na abalị, ndị a nọ na-eche ụzọ niile e si apụ nʼobodo ahụ nche, ka ha nwe ike gbuo ya.
\v 25 Ma ụmụazụ ya kunyere ya na nkata amanyere ụdọ bufee ya nʼofe mgbidi nke obodo.
\s1 Mbata Sọl na Jerusalem
\p 
\v 26 Mgbe o rutere Jerusalem, ọ gbalịrị ịdịnyere ndị na-eso ụzọ Jisọs nọ nʼebe ahụ, ma ha tụrụ egwu. Ha ekwenyeghị na ọ ghọọla ezi onye na-eso ụzọ Jisọs dịka ha.
\v 27 Ma Banabas duuru ya gaa nʼebe ndị ozi nọ. Ọ kọọrọ ha akụkọ otu o siri hụ Onyenwe anyị na otu o siri gwakwa ya okwu. Na otu o siri kwusaa oziọma nʼaha Jisọs na Damaskọs na-atụghị egwu.
\v 28 O soro ha na-agagharị na Jerusalem. Ọ na-ekwusakwa okwu nʼaha Onyenwe anyị na-atụghị egwu.
\v 29 Ya na ndị Juu na-asụ asụsụ Griik rụrịtakwara ụka. Nʼihi ya ndị a gbara izu igbu ya.
\v 30 Mgbe ndị kwere ekwe nụrụ banyere nzube ha, ha duuru ya gaa Sizaria site nʼebe ahụ zipụ ya ka ọ laa obodo Tasọs.
\p 
\v 31 Mgbe ahụ, nzukọ niile ndị nọ na Judịa, Galili na Sameria, nọọrọ nʼudo, guzosiekwa ike. Ha na-amụba nʼọnụọgụgụ site nʼịtụ egwu nke Onyenwe anyị na ịgbaume nke Mmụọ Nsọ.
\s1 Ọgwụgwọ Ainias na Dọkas
\p 
\v 32 Pita na-ejegharị nʼetiti ndị kwere ekwe, ọ gakwara leta ndị nsọ nọ nʼobodo Lida.
\v 33 Nʼebe ahụ, ọ hụrụ otu nwoke aha ya bụ Ainias. Nwoke a anọọla nʼute ọrịa afọ asatọ. Ọ bụ onye ahụ ya kpọnwụrụ akpọnwụ.
\v 34 Pita sịrị ya, “Ainias, Jisọs Kraịst agwọọla gị. Bilie mezie ute gị.” Ngwangwa, Ainias biliri ọtọ.
\v 35 Ndị niile bi na Lida na Sharọn hụrụ ya. Nʼihi ya, ha nabatara Onyenwe anyị.
\p 
\v 36 Nʼobodo Jopa, e nwere otu onye nwanyị na-eso ụzọ ya, nke aha ya bụ Tabita nke pụtakwara Dọkas na asụsụ Griik. O jupụtara nʼọrụ ọma, na ọrụ obi ebere nʼebe ụmụ ogbenye nọ.
\v 37 Nʼoge a, ọ rịara ọrịa, nwụọ. Mgbe ha sachara ya ahụ, ha nibere ya nʼotu ime ụlọ dị nʼụlọ elu.
\v 38 Jopa dịkwa nso na Lida. Mgbe ndị na-eso ụzọ ya nụrụ na Pita nọ nʼebe ahụ, ha ziri ụmụ nwoke abụọ ozi ka a rịọọ ya, sị, “Biko, ahapụla ịbịakwute anyị ngwangwa.”
\p 
\v 39 Pita biliri soro ha gawa, mgbe o ruru, ha duuru ya gbago nʼụlọ elu nʼime ụlọ ahụ. Ụmụ nwanyị niile di ha nwụrụ anwụ nọ nʼebe ahụ na-ebe akwa, na-egosi uwe Dọkas dụụrụ ha mgbe ọ dị ndụ.
\p 
\v 40 Pita chụpụrụ ha niile nʼezi, gbuo ikpere nʼala, kpee ekpere. Ọ tụgharịrị chee ozu ahụ ihu sị, “Tabita, bilie.” O meghere anya ya, ma mgbe ọ hụrụ Pita, o biliri, nọdụ ala.
\v 41 O nyeere ya aka ka ọ kwụrụ ọtọ. Ọ kpọrọ ndị nsọ niile nọ nʼebe ahụ, ha na ụmụ nwanyị ahụ di ha nwụrụ gosi ha na ọ dị ndụ.
\v 42 A nụrụ akụkọ ihe a mere nʼebe niile na Jopa, nke mere ka ọtụtụ kwere nʼOnyenwe anyị.
\v 43 Ọ nọgidere na Jopa ọtụtụ ụbọchị. Ọ nọdụrụ nʼụlọ Saimọn, onye ọrụ ya bụ idozi akpụkpọ anụ.
\c 10
\s1 Kọnelịọs ezie Pita ozi
\p 
\v 1 Nʼoge ahụ, o nwere otu nwoke bi na Sizaria, aha ya bụ Kọnelịọs. O bụ ọchịagha na-elekọta narị ndị agha si na mpaghara Itali.
\v 2 Nwoke a na ezinaụlọ ya bụ ndị na-asọpụrụ ma na-atụkwa egwu Chineke. Ọ na-enyere ndị ogbenye aka na-ekpekwara Chineke mgbe niile.
\v 3 Otu ụbọchị, nʼihe dịka elekere atọ nke ehihie, ọ hụrụ ọhụ ebe otu mmụọ ozi nke Chineke bịakwutere ya sị ya, “Kọnelịọs!”
\p 
\v 4 Kọnelịọs lekwasịrị ya anya nʼegwu jụọ ya sị, “Onyenwe m, ọ bụ gịnị?”
\p Ọ sịrị ya, “Ekpere gị na onyinye gị nye ndị ogbenye e rutela dịka ihe ncheta nʼihu Chineke.
\v 5 Ugbu a, zie ndị ikom ka ha gaa nʼobodo Jopa kpọta otu onye aha ya bụ Saimọn, onye a na-akpọkwa Pita.
\v 6 Ọ bụ ọbịa nʼụlọ otu nwoke a na-akpọ Saimọn, onye na-edozi akpụkpọ anụ. Onye ụlọ ya dị nʼakụkụ osimiri.”
\p 
\v 7 Mgbe mmụọ ozi ahụ gwara ya okwu pụrụ, ọ kpọrọ ndị ohu ya abụọ na otu nʼime ndị agha na-eche ya nche nke na-atụkwa egwu Chineke.
\v 8 Mgbe ọ kọchara ha ihe niile, o zigara ha Jopa.
\s1 Ọhụ Pita hụrụ
\p 
\v 9 Nʼechi ya, mgbe ha nọ nso nʼebe ahụ, nʼihe dịka elekere iri na abụọ nke ehihie, Pita rigooro nʼelu ụlọ ahụ ikpe ekpere.
\v 10 Agụụ bidoro ịgụ ya, ọ chọọ ihe ọ ga-eri. Ma mgbe a na-akwado nri, ọ hụrụ ọhụ.
\v 11 Ọ hụrụ ka eluigwe meghere, hụkwa ihe dịka akwa ọcha dị obosara nke e sitere nʼakụkụ anọ ya na-ewedata nʼala.
\v 12 Ihe dị nʼime ya: bụ ụmụ anụmanụ dị iche iche, ndị nwere ụkwụ anọ, ma anụ ndị na-akpụ akpụ nʼala na ụmụ nnụnụ nke igwe.
\v 13 Mgbe ahụ, ọ nụrụ olu na-asị, \wj “Pita bilie, gbuo ma riekwa.”\wj*
\p 
\v 14 Ma Pita sịrị, “Mba, Onyenwe m. Ọ dịbeghị mgbe m riri ihe ọbụla rụrụ arụ maọbụ nke na-adịghị ọcha.”
\p 
\v 15 Olu ahụ gwara ya nke ugboro abụọ, \wj “Akpọla ihe ọbụla ihe rụrụ arụ bụ nke Chineke mere ka ọ dị ọcha.”\wj*
\p 
\v 16 Ihe a mere ugboro atọ, ngwangwa, e weghachikwara ya nʼeluigwe.
\p 
\v 17 Mgbe Pita nọ na-atule ihe ọhụ ahụ pụtara bụ nke gbakwara ya gharịị, lee, ndị ikom ahụ Kọnelịọs zipụrụ abịarutela kwụsị nʼọnụ ụzọ, na-ajụ ebe ụlọ Saimọn dị.
\v 18 Ha kpọrọ oku ịjụ ma Saimọn onye a na-akpọ Pita ọ nọ nʼụlọ ahụ.
\p 
\v 19 Ka Pita nọrịị na-atụgharị uche nʼihe ọhụ ahụ pụtara, Mmụọ Nsọ gwara ya, “Lee, mmadụ atọ guzo nʼọnụ ụzọ ugbu a. Ha chọkwara ịhụ gị.
\v 20 Bilie, rịda jekwuru ha ngwangwa, enwela obi abụọ ị soro ha gawa, nʼihi na ọ bụ m zitere ha.”
\p 
\v 21 Pita jekwuru ndị ikom ahụ, sị, “Ọ bụ m bụ onye unu na-achọ, gịnị ka unu na-achọrọ m?”
\p 
\v 22 Ha sịrị, “Ọ bụ Kọnelịọs onyeisi agha na-elekọta narị ndị agha zitere anyị. Ọ bụ onye ezi omume nke na-atụ egwu Chineke, bụrụkwa onye ndị Juu niile na-asọpụrụ. Mmụọ ozi dị nsọ gwara ya ka ọ kpọta gị nʼụlọ ya, ịnụ ihe i nwere ikwu.”
\v 23 Ya mere, ọ kpọbatara ha nʼụlọ dịka ndị ọbịa.
\s1 Pita agaa nʼụlọ Kọnelịọs
\p Echi ya, o biliri soro ha gawa, ụfọdụ ndị kwere ekwe na Jopa sokwara ya gaa.
\v 24 Nʼụbọchị na-esota ya, ha bịaruru Sizaria. Kọnelịọs nọrịị na-eche ha, ya na ndị ezinaụlọ ya, na ndị ikwu na ibe ya, na ndị enyi ya ọ kpọrọ.
\v 25 Mgbe Pita batara, Kọnelịọs zutere ya, daa nʼala nʼụkwụ ya, kpọọrọ ya isi nʼala.
\v 26 Ma Pita selitara ya elu sị, “Bilie ọtọ, mụ onwe m bụkwa mmadụ.”
\p 
\v 27 Mgbe ha na-ekwurịta okwu, ọ banyere nʼime ụlọ ma hụ igwe mmadụ ka ha zukọtara.
\v 28 Ọ sịrị ha, “Unu maara nke ọma na ọ bụ ihe megidere iwu na onye Juu na onye mba ọzọ ga-enwe mmekọrịta maọbụ gaa leta onye mba ọzọ. Ma Chineke ezila m na m ekwesighị ịkpọ mmadụ ọbụla onye rụrụ arụ maọbụ onye na-adịghị ọcha.
\v 29 Nʼihi nke a, ọ bụ ya mere m jiri bịa mgbe akpọrọ m na-ajụghị ajụjụ. Ma ka m jụọ ugbu a ihe mere unu ji kpọọ m?”
\p 
\v 30 Kọnelịọs sịrị, “Nʼụbọchị anọ gara aga, mgbe m nọ na-ekpe ekpere nʼoge ehihie nʼụlọ m, nʼihe dịka elekere atọ, na mberede, ahụrụ m nwoke yi uwe na-enwu ọcha ka o guzoro nʼihu m.
\v 31 Ọ sịrị, Kọnelịọs, ‘Chineke anụla ekpere gị ma chetakwa onyinye ị na-enye ndị ogbenye.
\v 32 Ziga nʼobodo Jopa nʼụlọ otu nwoke a na-akpọ Saimọn, onye na-edozi akpụkpọ anụ. O bi nʼakụkụ osimiri.’ Nʼebe ahụ ha ga-ahụkwa otu onye ọbịa aha ya bụ Saimọn a na-akpọ Pita.
\v 33 Ọ bụ nʼihi nke a ka m ji mee ngwangwa zie ka a kpọọ gị. Ọ dị mma na ị bịara. Ugbu a, anyị niile ezukọtala nʼebe a nʼihu Chineke ịnụrụ ihe niile Onyenwe anyị chọrọ ka ị gwa anyị.”
\s1 Okwu Pita kwuru
\p 
\v 34 Mgbe ahụ Pita meghere ọnụ ya sị, “Ugbu a, aghọtala m nʼezie na Chineke abụghị onye na-ele mmadụ anya nʼihu.
\v 35 Kama nʼime mba ọbụla, onye ọbụla na-atụ egwu ya na onye na-arụ ọrụ ezi omume ka ọ na-anabata.
\v 36 Unu maara ihe banyere oziọma ahụ o zigaara ndị Izrel niile, nke na-akọ akụkọ oziọma nke udo site na Jisọs Kraịst onye bụ Onyenwe anyị nʼihe niile.
\v 37 Okwu ahụ gbasara nʼala Judịa niile, malite na Galili mgbe Jọn kwusachara baptizim nke ya.
\v 38 Otu Chineke si were Mmụọ Nsọ na ike wụkwasị Jisọs onye Nazaret dịka mmanụ, na otu o si jegharịa na-eme mma na-agwọkwa ndị niile ekwensu na-emekpa ahụ, nʼihi na Chineke nọnyeere ya.
\p 
\v 39 “Anyị bụ ndị akaebe ihe niile o mere nʼala ndị Juu na nʼime Jerusalem. Ha gburu ya site nʼịkpọgide ya nʼelu obe.
\v 40 Ma Chineke mere ka o si nʼọnwụ bilite mgbe ụbọchị atọ gasịrị. E mekwara ka ndị mmadụ hụ ya anya.
\v 41 Ọ bụghị mmadụ niile kama ọ bụ naanị anyị ndị Chineke họpụtara, dịka ndị akaebe, ndị soro ya rie ma ṅụọkwa mgbe o si nʼọnwụ bilie.
\v 42 O nyere anyị iwu ka anyị gaa zisaa oziọma nʼebe niile, ịkọwa na ọ bụ ya ka Chineke họpụtara ịbụ onye ikpe nke ndị dị ndụ na ndị nwụrụ anwụ.
\v 43 Ndị amụma niile gbara ama ihe banyere ya na onye ọbụla nke kweere na ya ga-enweta mgbaghara mmehie site nʼaha ya.”
\s1 Ndị mba ọzọ anata Mmụọ Nsọ
\p 
\v 44 Mgbe Pita nọ na-ekwu okwu, Mmụọ Nsọ bịakwasịrị ndị niile nụrụ okwu a.
\v 45 Nke a juru ndị e biri ugwu nʼetiti ndị kwere ekwe soro Pita bịa anya otu e siri mee ka ndị mba ọzọ nata onyinye Mmụọ Nsọ ahụ.
\v 46 Nʼihi na ha nụrụ ka ha na-ekwu okwu nʼasụsụ dị iche iche na-etokwa Chineke.
\p Mgbe ahụ Pita jụrụ,
\v 47 “Ọ dị onye pụrụ igbochi anyị ime ndị a baptizim. Ndị natara Mmụọ Nsọ dị ka anyị onwe anyị?”
\v 48 Nʼihi nke a, o nyere iwu ka e mee ha baptizim nʼaha Jisọs Kraịst. Ha rịọrọ ya ka ọ nọnyere ha ụbọchị ole na ole.
\c 11
\s1 Pita akọwaa ọrụ ya nʼihu ndị okenye
\p 
\v 1 Ndị ozi na ụmụnna ndị bi na Judịa niile nụrụ na ndị mba ọzọ anabatala okwu Chineke.
\v 2 Mgbe Pita ruru Jerusalem, ndị kwere ekwe e biri ugwu tara ya ụta,
\v 3 na-asị, “Gịnị mere ị ji gakwuru ndị a na-ebighị ugwu soro ha rie ihe?”
\p 
\v 4 Pita kọwaara ha ihe niile mere na otu o si mee, na-asị.
\v 5 “Otu ụbọchị, mgbe m nọ nʼobodo Jopa, ahụrụ m ọhụ nʼoge m na-ekpe ekpere. Nʼime ọhụ a, ahụrụ m ihe yiri akwa ọcha dị obosara nke e sitere nʼakụkụ anọ ya na-ewedata site nʼeluigwe. E budatara ya nʼihu m.
\v 6 Nʼime ya, ahụrụ m anụmanụ ndị nwere ụkwụ anọ, na anụ ọhịa, na anụ ndị na-akpụ akpụ nʼala na ụmụ nnụnụ nke eluigwe.
\v 7 Mgbe ahụ, anụrụ m olu gwara m sị, \wj ‘Pita, bilie, gbuo ma riekwa.’\wj*
\p 
\v 8 “Ma asịrị m, ‘Mba, Onyenwe m, ọ dịbeghị mgbe ihe na-adịghị ọcha maọbụ ihe rụrụ arụ bara m nʼọnụ.’
\p 
\v 9 “Olu ahụ siri nʼeluigwe zaghachi nke ugboro abụọ, \wj ‘Akpọla ihe ọbụla ihe rụrụ arụ bụ nke Chineke mere ka ọ dị ọcha.’\wj*
\v 10 Nke a mere ugboro atọ, ma emesịa dọlie ha niile laa nʼeluigwe.
\p 
\v 11 “Nʼotu oge ahụ, ndị ikom atọ ndị e zipụrụ site Sizaria ịkpọ m bịarutere kwụsị nʼọnụ ụzọ nʼụlọ ebe m nọ.
\v 12 Mmụọ Nsọ gwara m ka m ghara inwe obi abụọ isoro ha na-akpaghị oke ọbụla. Mmadụ isii ndị a nʼetiti ụmụnna anyị sokwa m, bịarute nʼụlọ nwoke ahụ.
\v 13 Ọ gwara anyị otu o si hụ mmụọ ozi nʼụlọ ya, onye sịrị, ‘Ziga ndị ozi jee Jopa ka ha kpọta Saimọn onye a na-akpọ Pita.
\v 14 Ọ ga-ewetara gị ozi nke a ga-esite na ya zọpụta gị nʼezinaụlọ gị niile.’
\p 
\v 15 “Mgbe m ka kpụ okwu ahụ nʼọnụ, Mmụọ Nsọ bịakwasịrị ha dịka o siri bịakwasị anyị na mbụ.
\v 16 Mgbe ahụ, echetara m okwu ahụ Onyenwe anyị kwuru sị, \wj ‘Jọn ji mmiri mee unu baptizim, ma a ga-eji Mmụọ Nsọ mee unu baptizim.’\wj*
\v 17 Ya mere, ọ bụrụ na Chineke nyere ha otu onyinye ahụ o nyere anyị mgbe anyị kweere nʼOnyenwe anyị Jisọs Kraịst, onye ka m bụ iguzogide Chineke?”
\p 
\v 18 Mgbe ha nụrụ nke a, ha agaghị nʼihu nʼịrụ ụka kama ha toro Chineke, na-asị, “Nʼezie, Chineke enyela ohere ka ọ bụladị ndị mba ọzọ chegharịa baa na ndụ.”
\s1 Ụlọ nzukọ dị na Antiọk
\p 
\v 19 Ugbu a, ndị ahụ niile gbasasịrị nʼihi mkpagbu ahụ bidoro mgbe a tụgburu Stivin na nkume, jeruru akụkụ Fonisia na Saiprọs na Antiọk na-ekwusa oziọma ahụ naanị nʼetiti ndị Juu.
\v 20 Ma otu ọ dị, ụfọdụ nʼime ndị ikom ndị ahụ sitere nʼakụkụ Saiprọs na Sirini gara Antiọk, malite ikwusara ndị Griik oziọma banyere Onyenwe anyị Jisọs.
\v 21 Onyenwe anyị gọziri mgbalị ha niile. Nʼihi na ọtụtụ mmadụ chegharịrị kwere nʼOnyenwe anyị.
\p 
\v 22 Mgbe nzukọ dị na Jerusalem nụrụ ihe ndị a, ha zipụrụ Banabas ka ọ gaa Antiọk.
\v 23 Mgbe o rutere, hụ ihe amara Chineke rụrụ nʼetiti ha. Ọ ṅụrịrị ọṅụ, mgbakwaa ha niile ume, gwa ha ka ha were obi ha niile nọgide nʼime Onyenwe anyị.
\v 24 Ọ bụ ezigbo mmadụ, onye jupụtara na Mmụọ Nsọ na okwukwe. O nwekwara okwukwe dị ebube, nʼihi ya ọtụtụ mmadụ chegharịkwara bịakwute Onyenwe anyị.
\p 
\v 25 Emesịa, ọ gara Antiọk obodo Tasọs ịchọ Sọl.
\v 26 Mgbe ọ chọpụtara ya, o duuru ya bịa nʼAntiọk. Ihe ha ka otu afọ, ka ha na-ezukọ nʼụlọ chọọchị na-akụziri ọtụtụ igwe mmadụ ihe. Ọ bụ nʼime Antiọk ka e buru ụzọ kpọọ ndị na-eso ụzọ ya ndị Kraịst.
\p 
\v 27 Nʼoge ahụ, ndị amụma sitere na Jerusalem bịaruru Antiọk.
\v 28 Otu onye nʼime ha a na-akpọ Agabọs biliri ọtọ buo amụma site nʼike Mmụọ Nsọ banyere oke ụnwụ ga-abịakwasị ụwa niile. Amụma a mezukwara nʼoge Klọdiọs na-achị.
\v 29 Ndị na-eso ụzọ ya kwekọrịtara ịtụkọta na iziga onyinye dị iche iche nye ndị kwere ekwe nọ na Judịa. Onye ọbụla nyekwara ihe dịka o nwere ike.
\v 30 Ha mere nke a, ha zigara ndị okenye ihe ha tụkọtara, site nʼaka Banabas na Sọl.
\c 12
\s1 Mkpagbu site nʼaka Herọd
\p 
\v 1 Nʼoge ahụ, eze Herọd jidere ụfọdụ ndị so na chọọchị buru nʼobi ịkpagbu ha.
\v 2 O jiri mma agha gbuo Jemis nwanne Jọn.
\v 3 Mgbe ọ chọpụtara na omume ya tọrọ ndị Juu ụtọ, ọ gara nʼihu jidekwa Pita. Nke a mere nʼoge mmemme Achịcha Ekoghị eko.
\v 4 Mgbe o jidere ya, o tinyere ya nʼụlọ mkpọrọ ebe o mere ka ndị agha chee ya nche, ndị agha anọ nʼotu oge, ndị agha anọ ọzọ nʼoge nke ọzọ. Ebumnobi ya bụ ịkpọpụta ya nʼihu ọha mmadụ kpee ya ikpe mgbe Mmemme Ngabiga gasịrị.
\p 
\v 5 Mgbe e debere Pita nʼụlọ mkpọrọ, nzukọ esepụghị aka nʼikpe ekpere nʼihi ya nye Chineke.
\s1 Mmụọ ozi agbapụta Pita
\p 
\v 6 Ma nʼabalị na-esota ụbọchị ahụ Herọd ga-akpụpụta ya, Pita nọ nʼụra nʼetiti ndị agha abụọ, e jiri eriri igwe kee ya nʼụkwụ nʼaka, ma ndị nche ọzọ nọkwa nʼọnụ ụzọ na-eche ya nche.
\v 7 Na mberede mmụọ ozi Onyenwe anyị bịara guzoro nʼebe ahụ, ìhè nwukwara nʼime ụlọ mkpọrọ ahụ. Ọ kutụrụ Pita aka nʼakụkụ sị, “Ngwangwa, bilie ọtọ!” Eriri igwe ahụ dapụrụ nʼaka ya.
\p 
\v 8 Mmụọ ozi ahụ sịrị ya, “Yiri uwe gị na akpụkpọụkwụ gị.” O mere otu ahụ, Mmụọ ozi ahụ gwakwara ya, “Yirikwa akwa mgbokwasị gị soro m.”
\v 9 Pita sooro ya nʼazụ, o chere na ọ na-ahụ ọhụ, ma ọ mataghị na ihe mmụọ ozi ahụ na-eme bụ ezie.
\v 10 Ha gafere ndị nche nke mbụ na nke abụọ rute nʼọnụ ụzọ e si abanye nʼime obodo, nke bụ ọnụ ụzọ igwe. Ọnụ ụzọ igwe ahụ meghekwara nʼonwe ya, ha esite na ya gafee. Mgbe ha gara ije ruo ebe tere anya nʼama nke ọzọ, ngwangwa mmụọ ozi ahụ hapụrụ ya.
\p 
\v 11 Mgbe ahụ kwa ka Pita ghọtara ihe niile mere. O kwuru, “Ugbu a, amatala m nʼezie, na Onyenwe anyị ezitela mmụọ ozi ya, ka ọ bịa zọpụta m site nʼaka eze Herọd na ihe niile ndị Juu na-atụ anya ya. Ugbu a ọ napụtakwala m site nʼọchịchọ ọjọọ niile nke ndị Juu.”
\p 
\v 12 Mgbe ọ ghọtara ihe merenụ, ọ gawara nʼụlọ Meri nne Jọn onye a na-akpọkwa Mak, ebe ọtụtụ mmadụ zukọtararị na-ekpe ekpere.
\v 13 Mgbe ọ kụrụ aka nʼọnụ ụzọ ama, otu odibo nwanyị aha ya bụ Roda bịara ka o zaa ya.
\v 14 Mgbe ọ nụrụ olu Pita, ọṅụ juru ya obi nke mere na ọ gbaara ọsọ laghachi azụ nʼemegheghị ụzọ. Ọ gara tisaa, “Ọ bụ Pita nọ nʼọnụ ụzọ!”
\p 
\v 15 Ha sịrị ya na ọ na-ekwu okwu dịka onye uche ya na-ezughị oke. Mgbe ọ nọgidesịrị ike na-ekwu otu ihe ahụ, ha sịrị, “Ọ ghaghị ị bụ mmụọ ozi ya.”
\p 
\v 16 Ma Pita nọgidere na-akụ aka nʼụzọ. Mgbe ha meghere ụzọ hụ ya, ọ gbagwojuru ha anya.
\v 17 O feere ha aka ka ha mechie ọnụ. Ọ kọọrọ ha otu Onyenwe anyị si dupụta ya site nʼụlọ mkpọrọ. Ọ gwara ha, “Meenụ ka Jemis na ụmụnna anyị niile mata ihe ndị a.” Ọ pụrụ gawa ebe ọzọ.
\p 
\v 18 Nʼisi ụtụtụ echi ya, oke ọgbaaghara dị nʼetiti ndị agha, ebe ha na-eche ihe mere Pita.
\v 19 Mgbe Herọd chọgharịchara ya ma ọ chọtaghị ya, ọ jụrụ ndị nche ahụ ajụjụ dị iche iche. Nʼikpeazụ ọ nyere iwu ka e gbuo ha.
\s1 Ọnwụ Herọd
\p Emesịa ọ hapụrụ Judịa gaa Sizaria nọdụ nʼebe ahụ.
\v 20 Nʼoge ahụ Herọd na-eweso ndị Taịa na Saịdọn iwe, ha zipụrụ ndị ozi ha izute ya. Ha buru ụzọ mee ka ha na Blastọs bụrụ enyi, onye eze tụkwasịrị obi nke na-elekọtakwa ime ụlọ ndina eze anya. Ha rịọrọ ya ka udo dịrị, nʼihi na a na-esi nʼobodo eze na-enwetara ha ihe oriri.
\p 
\v 21 Nʼụbọchị nzukọ ahụ, Herọd gbokwasịrị uwe ndị eze ya nọkwasị nʼocheeze ya. O weere oke olu dị iche gwa nzukọ ahụ niile okwu.
\v 22 Igwe mmadụ ahụ nọ na-eti mkpu, “Nke a abụghị olu mmadụ, ọ bụ olu chi!”
\v 23 Nʼotu oge ahụ, mmụọ ozi Onyenwe anyị tiri ya ihe otiti dị egwu nʼihi na o nyeghị Chineke otuto ma otu. Ikpuru ripịara ya ahụ, nke mere ka ọ nwụọ.
\p 
\v 24 Ma okwu Chineke gara nʼihu na-aba ụba na-agbasakwa.
\s1 Nzipụ Sọl na Banabas
\p 
\v 25 Mgbe ha rụchara ọrụ ha, Banabas na Sọl si Jerusalem lọghachi. Ha kpọọrọ Jọn onye a na-akpọkwa Mak nʼije ha.
\c 13
\nb 
\v 1 Ndị amụma na ndị nkuzi ụfọdụ nọkwa na nzukọ dị nʼAntiọk. Ụfọdụ nʼime ha bụ Banabas na Simiọn onye a na-akpọ nwoke ojii, na Lusiọs onye Sirini, na Manaen (onye azụlitekọrọ ya na eze Herọd), na Sọl.
\v 2 Mgbe ha nọ na-efe Onyenwe anyị ofufe na-ebukwa ọnụ, Mmụọ Nsọ sịrị, “Kewapụtaranụ m Banabas na Sọl, nʼihi ọrụ ahụ nke m kpọrọ ha.”
\v 3 Ya mere, mgbe ha busiri ọnụ kpekwa ekpere, ha bikwasịrị ha aka nʼisi zipụ ha.
\s1 Obodo Saiprọs
\p 
\v 4 Ebe Mmụọ Nsọ zipụrụ ha, ha gbadara Selusia, sitekwa ebe ahụ gbadaa Saiprọs.
\v 5 Mgbe ha bịaruru Salamis, ha banyere nʼụlọ nzukọ ndị Juu kwusaa okwu Chineke. Jọn sokwa ha dịka onye na-ejere ha ozi.
\p 
\v 6 Mgbe ha gazuchara obodo niile ndị ahụ mmiri gbara gburugburu ruo Pafọs, ha zutere otu onye mgbaasị, onye Juu bụ onye amụma ụgha a na-akpọ Ba-Jisọs.
\v 7 Ya na otu onye ọchịchị obodo, aha ya bụ Sajiọs Pọlọs nọ. Ọ bụ nwoke nwere ọgụgụisi nʼebe ọ dị ukwuu, ọ kpọrọ Banabas na Sọl ka ha gwa ya okwu nke Chineke.
\v 8 Ma onye mgbaasị ahụ, onye aha ya bụkwa Elimas (nʼihi nke a bụ aha ya ma asụgharịa ya) malitere igbochi ha site nʼimegharị onyeisi ahụ anya ka ọ ghara ịnabata okwukwe ahụ.
\v 9 Ma Sọl, onye aha ya bụkwa Pọl, onye jupụtara na Mmụọ Nsọ, legidere ya anya
\v 10 sị, “Gị nwa ekwensu, jupụtara nʼaghụghọ na nʼihe ọjọọ dị iche iche. Gị onye iro nke ezi omume niile. Ọ bụ na i gaghị akwụsị imerụ ụzọ niile ziri ezi nke Onyenwe anyị?
\v 11 Nʼihi ya lee, iwe nke Onyenwe anyị ga-adakwasị gị. Ị ga-ekpụ ìsì nwa oge, ị gaghị enwe ike hụ ìhè nke anyanwụ.”
\p Nʼotu oge ahụ, ọ hụkwaghị ụzọ ọzọ. Ọ malitere na-ebigharị aka, na-achọkwa onye ga na-edugharị ya.
\v 12 Mgbe onyeisi ahụ hụrụ ihe mere, o kweere, nʼihi na o juru ya anya bụ ozizi nke okwu Onyenwe anyị.
\s1 Pọl nʼobodo Antiọk nke Pisidia
\p 
\v 13 Pọl na ndị otu ya ji ụgbọ mmiri site na Pafọs garuo Pega nke dị nʼala Pamfilia. Nʼebe a ka Jọn hapụrụ ha laghachi Jerusalem.
\v 14 Site na Pega ha gara ruo Antiọk obodo nke dị na Pisidia. Nʼụbọchị izuike, ha banyere nʼụlọ nzukọ ndị Juu nọdụ ala.
\v 15 Mgbe a gụpụtasịrị site nʼakwụkwọ iwu na nke ndị amụma, ndịisi ụlọ ekpere ahụ zigara ya ozi, sị, “Ụmụnna anyị, ọ bụrụ na unu nwere okwu ịgbaume nye anyị, biko kwuonụ ya.”
\p 
\v 16 Pọl guzoro ọtọ nʼetiti ha feere ha aka ya, sị, “Unu ndị Izrel na unu ụmụnna m ndị mba ọzọ na-atụ egwu Chineke. Geenụ m ntị.
\v 17 Chineke nke Izrel họpụtara nna nna anyị ha mee ha mba dị ukwu nʼoge ha nọ nʼobodo Ijipt. O ji ike aka ya dupụta ha site nʼala ahụ.
\v 18 Ọ nagidere ha iri afọ anọ nʼime ọzara.
\v 19 O bibiri mba asaa dị ukwuu nʼime ala Kenan nʼihi ha, nyekwa ndị ya obodo a ka ọ bụrụ nke ha.
\v 20 Nke a bụ ihe dị ka narị afọ anọ na iri afọ ise.
\p “Mgbe nke a gasịrị, o nyere ha ndị ikpe dị iche iche ruo oge Samuel onye amụma.
\v 21 Mgbe ahụ ha rịọrọ ka enye ha eze, Chineke nyekwara ha Sọl, nwa Kish, onye si nʼagbụrụ Benjamin pụta, onye chịrị iri afọ anọ.
\v 22 Mgbe o wepụsịrị ya, o mere Devid ka ọ bụrụ eze ha. Ọ gbara ama banyere ya sị, ‘Achọtala m Devid nwa Jesi, nwoke nke dị ka ọchịchọ obi m nke si dị. Ọ bụkwa onye ga-eme ihe niile m chọrọ ka o mee.’
\p 
\v 23 “Jisọs onye si nʼezinaụlọ Devid pụta ka Chineke wetaara Izrel Onye nzọpụta ahụ bụ Jisọs, dịka o kwere nkwa izite.
\v 24 Ma tupu ọbịbịa ya, Jọn ekwusala nye ndị Izrel banyere baptizim nke nchegharị.
\v 25 Nʼoge Jọn na-arụsị ọrụ ya, ọ na-asị, ‘Onye ka unu chere na m bụ? Abụkwaghị m onye ahụ. Mba! Abụghị m ya. Ma otu onye ahụ na-abịa nʼazụ m, onye m na-erughị ịtọpụ eriri akpụkpọụkwụ ya.’
\p 
\v 26 “Ya mere, ụmụnna m, ndị si nʼagbụrụ Ebraham na ndị niile na-atụ egwu Chineke, ozi nke nzọpụta a dịrị anyị niile.
\v 27 Ndị bi na Jerusalem na ndị na-achị ha amataghị ya, nke ha ji aghọta okwu ndị amụma nke a na-agụpụtara ha kwa izu, bụ nʼụbọchị izuike. Ma ha mere ka okwu ahụ mezuo, mgbe ha mara ya ikpe ọnwụ.
\v 28 Ọ bụ ezie na ha achọtaghị ihe kwesiri ọnwụ nʼaka ya. Ma ha rịọrọ Pailet ka o nye ike ka e gbuo ya.
\v 29 Mgbe ha mezuru ihe niile e dere banyere ya, ha budatara ya site nʼelu obe, lie ya.
\v 30 Ma Chineke mere ka o si nʼọnwụ bilie.
\v 31 Ndị niile soro ya jegharịa site na Galili ruo Jerusalem hụkwara ya anya ọtụtụ ụbọchị. Ndị a bụkwa ndị na-agba ama nʼihu ndị mmadụ banyere ya.
\p 
\v 32 “Anyị na-ezikwa unu oziọma a, nke nkwa ahụ Chineke kwere ndị nna nna anyị ha.
\v 33 O mezuola ha nye anyị bụ ụmụ ha, site na-ime ka Jisọs site nʼọnwụ bilie, dịka e dere ya nʼakwụkwọ Abụ ọma,
\q1 “ ‘Ị bụ ọkpara m,
\q2 taa abụrụla m nna gị.’\f + \fr 13:33 \ft \xt Abụ 2:7\xt*\f*
\m 
\v 34 Ma banyere ime ka o site nʼọnwụ bilie, ka ọ ghara ịlaghachi nʼire ure ọzọ. Nke a bụ ihe o kwuru,
\q1 “ ‘Aga m emezuru gị nkwa nsọ ahụ niile m kwere Devid.’\f + \fr 13:34 \ft \xt Aịz 55:3\xt*\f*
\m 
\v 35 E dekwara ya nʼebe ọzọ nʼabụ ọma,
\q1 “ ‘Ị gakwaghị ahapụ anụ ahụ nke Onye gị dị nsọ ka ọ hụ ire ure.’\f + \fr 13:35 \ft \xt Abụ 16:10\xt*\f*
\p 
\v 36 “Mgbe Devid rụzuru ọrụ Chineke chọrọ ka ọ rụọ nʼọgbọ ha, ọ nwụrụ, e likọọ ya na ndị nna nna ya ha o rekwara ure.
\v 37 Ma onye ahụ Chineke mere ka o site nʼọnwụ bilite erekwaghị ure.
\p 
\v 38 “Ya mere, ụmụnna m, achọrọ m ka o doo unu anya na mgbaghara mmehie dịkwa nʼime nwoke a, bụ Jisọs, anyị na-ekwusa nye unu.
\v 39 A na-esite na ya gụọ onye ọbụla kwere nʼonye ezi omume ọ bụladị site nʼihe ndị ahụ niile nke iwu Mosis na-apụghị ịgụ unu dị ka ndị ezi omume.
\v 40 Lezienụ anya ka ihe niile ndị amụma kwuru ghara ịdakwasị unu.
\q1 
\v 41 “ ‘Lee, unu ndị na-akwa emo,
\q2 nọrọnụ na mgbagwoju anya ma lakwanụ nʼiyi.
\q1 Nʼihi na agaje m ime otu ihe nʼụbọchị unu
\q2 nke unu na-agaghị ekwe na o mere,
\q2 ọ bụladị na mmadụ kọrọ unu maka ya.’\f + \fr 13:41 \ft \xt Hab 1:5\xt*\f*”
\p 
\v 42 Mgbe Pọl na Banabas na-apụ, ndị mmadụ rịọrọ ha ka ha bịakwa nʼizu ụka ọzọ gwa ha okwu gbasara ihe ndị a.
\v 43 Mgbe a gbasara nzukọ ahụ, ọtụtụ ndị Juu na ndị mba ọzọ na-atụ egwu Chineke sooro Pọl na Banabas, ndị gwara ha okwu, rịọsiekwa ha ike ka ha nọgide nʼamara Chineke.
\p 
\v 44 Nʼụbọchị izuike ọzọ ahụ, ọtụtụ ndị bi nʼobodo ahụ pụtara ịnụrụ okwu Onyenwe anyị.
\v 45 Mgbe ndị Juu hụrụ igwe mmadụ ndị a, obi ha jupụtara nʼekworo, ha bidokwara ikwu okwu ọjọọ megide okwu niile Pọl na-ekwu.
\p 
\v 46 Ma Pọl na Banabas kwuru okwu na-asọghị anya sị, “Ọ dị mkpa na anyị buuru ụzọ gwa unu okwu nke Chineke, ma ebe ọ bụ na unu jụrụ ịnabata ya, na-echekwa na unu ekwesighị inweta ndụ ebighị ebi, lee, anyị ga-agakwuru ndị mba ọzọ.
\v 47 Nʼihi na nke a bụ ihe Onyenwe anyị nyere anyị nʼiwu,
\q1 “ ‘Emeela m ka unu bụrụ ìhè nye ndị mba ọzọ,
\q2 ka ị nwee ike weruo nzọpụta nʼebe niile ụwa sọtụrụ.’\f + \fr 13:47 \ft \xt Aịz 49:6\xt*\f*”
\p 
\v 48 Mgbe ndị mba ọzọ nụrụ ihe ndị a, obi tọrọ ha ụtọ, ha sọpụkwara okwu nke Onyenwe anyị. Ya mere ndị niile a họpụtara inweta ndụ ebighị ebi bụ ndị kwenyerenụ.
\p 
\v 49 Ya mere okwu Onyenwe anyị gbasara ruo ebe niile nʼobodo ahụ.
\v 50 Mgbe ahụ, ndị Juu kpaliri obi ọtụtụ ụmụ nwanyị na-atụ egwu Chineke ndị ọnọdụ ha dị elu, na ndị ikom ndị nke ndu obodo ahụ. Ha kpasuru mkpagbu megide Pọl na Banabas si otu a, chụpụ ha site nʼobodo ahụ.
\v 51 Ha tichapụrụ aja dị nʼụkwụ ha ka ọ bụrụ ihe ịdọ aka na ntị mmegide ha. Ha hapụrụ obodo ahụ gaa Aikoniọm.
\v 52 Ma ndị na-eso ụzọ ya jupụtakwara nʼọṅụ na nʼike nke Mmụọ Nsọ.
\c 14
\s1 Pọl nʼobodo Aikoniọm
\p 
\v 1 Nʼobodo Aikoniọm, Pọl na Banabas banyekwara nʼụlọ nzukọ ndị Juu, kwuo okwu nʼụzọ pụrụ iche nke mere nʼọtụtụ mmadụ, ndị Juu na ndị mba ọzọ kwenyekwara.
\v 2 Ndị Juu, ndị na-anabataghị okwu ahụ, kpaliri ndị mba ọzọ mee ka mkpụrụobi ha jọọ njọ megide ụmụnna.
\v 3 Otu ọ dị, ha nọgidere nʼebe ahụ ogologo oge, na-ekwusakwa okwu nke Onyenwe anyị na-atụghị egwu ọbụla. Onye nke gosikwara na ọ bụ okwu amara ya ka ha na-ekwu site nʼinye ha ike ịrụ ọrụ ịrịbama na ọrụ ebube dị iche iche.
\v 4 Ma ndị obodo ahụ kewara abụọ, ụfọdụ nʼime ha dịnyere ndị Juu. Ụfọdụ dịnyekwara ndị ozi.
\v 5 Mgbe ndị mba ọzọ, na ndị Juu, ha na ndị ndu ha, gbara izu ime ha ihe ihere, tụọkwa ha nkume.
\v 6 Ndị ozi ahụ matara nzube ha site nʼebe ahụ gbapụ ọsọ gbaruo nʼakụkụ Laikonia, gbaba nʼime obodo Listra na Debi na obodo nta ndị ọzọ ndị dị nʼakụkụ ebe ahụ.
\v 7 Nʼebe ahụ, ha gara nʼihu na-ekwusakwa oziọma ahụ.
\s1 Nʼime obodo Listra na Debi
\p 
\v 8 Nʼobodo Listra, o nwere otu nwoke dara ngwụrọ site nʼoge a mụrụ ya. Nwoke a ejibeghị ụkwụ ya abụọ gaa ije mgbe ọbụla.
\v 9 O gere ntị mgbe Pọl na-ekwu okwu. Onye legidere ya anya hụ na ọ nwere okwukwe nke a ga-eji mee ka a gwọọ ya,
\v 10 were oke olu sị, “Guzoro nʼụkwụ gị abụọ.” Nwoke ahụ wuliri elu malite ịga ije.
\p 
\v 11 Mgbe igwe mmadụ ahụ hụrụ ihe Pọl mere, ha tiri mkpu nʼasụsụ Laikonia sị, “Ndị a bụ chi bịakwutere anyị nʼụdịdị mmadụ.”
\v 12 Banabas ka ha kpọrọ Zeus ma kpọkwa Pọl Hamis nʼihi na ọ bụ ya bụ onye ọka okwu.\f + \fr 14:12 \ft Ndị a bụ aha chi ndị obodo a. Aha ha ọzọ bụ Jupita na Mekuri.\f*
\v 13 Onye nchụaja Zeus, nke ụlọ arụsị ya dị nso nʼihu obodo, kpụtara oke ehi wetakwa okoko osisi dị iche iche. Ya na igwe mmadụ ahụ chọrọ ịchụ aja nye ha nʼọnụ ụzọ ama ha.
\p 
\v 14 Mgbe ndị ozi ahụ, Banabas na Pọl nụrụ ihe ndị a, ha dọwara uwe ha, gbara ọsọ jekwuru igwe mmadụ ahụ na-eti mkpu,
\v 15 na-asị, “Ndị ikom, gịnị ka unu na-achọ ime? Lee, anyị bụkwa mmadụ dị ka unu. Ọ bụ oziọma ka anyị wetaara unu. Anyị chọrọ ka unu site nʼịsọpụrụ ihe ndị a na-abaghị uru, bịakwute Chineke dị ndụ. Onye kere eluigwe na ụwa, na oke osimiri na ihe niile dị nʼime ha.
\v 16 Nʼoge gara aga, ọ hapụrụ mba niile ka ha na-eme ihe masịrị ha.
\v 17 Nʼagbanyeghị nke a ọ hapụghị ị debere onwe ya ihe ndị ga-agbara ya akaebe, site nʼọrụ ọma ya niile. Dị ka inye unu mmiri ozuzo site nʼeluigwe, na mkpụrụ nke ala nʼoge ha. Ọ na-enyekwa unu nri na-emekwa ka obi na-atọ unu ụtọ.”
\v 18 Nʼagbanyeghị okwu ndị a, ọ rara ha ahụ igbochi igwe mmadụ ahụ ịchụrụ ha aja.
\p 
\v 19 Ma ndị Juu sitere nʼAntiọk na Aikoniọm bịara kpalie obi igwe mmadụ ahụ. Nʼihi ya, ha tụrụ Pọl nkume, dọkpụrụ ya pụọ nʼobodo, chee na ọ nwụọla.
\v 20 Ma mgbe ndị na-eso ụzọ bịara gbaa ya gburugburu, o bilitere, laghachikwa nʼime obodo ahụ. Ma nʼechi ya, ya na Banabas sooro gaa Debi.
\s1 Pọl na Banabas alaghachi Antiọk nke Siria
\p 
\v 21 Ha zisasịrị oziọma nʼime obodo ahụ, nke mere ka ọtụtụ mmadụ bụrụ ndị na-eso ụzọ ya. Ha lọghachiri nʼobodo Listra site ya gaa Aikoniọm na Antiọk.
\v 22 Nʼebe ahụ ha gbara ndị na-eso ụzọ ume kasịekwa ha obi sị ha jidesie okwukwe ahụ ike. Ha sịrị, “Anyị ga-agabiga ọtụtụ mkpagbu dị iche iche tupu anyị abaa nʼalaeze Chineke.”
\v 23 Mgbe ha họpụtachara ndị okenye nʼime nzukọ niile. Ha sitere nʼobubu ọnụ na ekpere tinye ha nʼaka Onyenwe anyị, bụ onye ha kwenyere na ya.
\v 24 Ha sitere nʼakụkụ Pisidia garuo Pamfilia.
\v 25 Mgbe ha zisachara oziọma nʼobodo Pega, ha gbadara gaa Atalia.
\p 
\v 26 Site nʼebe ahụ, ha sooro ụgbọ mmiri jeruo Antiọk bụ ebe a nọ nyefee ha nʼamara Chineke nʼihi ọrụ ndị a ha rụzuru.
\v 27 Mgbe ha bịaruru, ha kpọkọtara nzukọ kọwara ha ihe niile Chineke sitere nʼaka ha mee, na otu o siri meghe ọnụ ụzọ nke okwukwe nye ndị mba ọzọ.
\v 28 Ha na ndị na-eso ụzọ nọgidere nʼebe ahụ ruo oge dị anya.
\c 15
\s1 Nzukọ dị mkpa na Jerusalem
\p 
\v 1 Ụfọdụ ndị ikom sitere Judịa bịa malitere izi ụmụnna ozi, “Ọ bụrụ na e bighị unu ugwu dịka Mosis nyere nʼiwu, a pụghị ịzọpụta unu.”
\v 2 Ha na Pọl na Banabas rụrịtara ụka nke ukwuu. Nʼihi nke a, ha kpebiri ka Pọl na Banabas, na ụfọdụ ndịisi ndị ọzọ soro gaa Jerusalem hụ ndị ozi na ndị okenye nke nzukọ maka okwu a.
\v 3 Nzukọ ahụ zipụrụ ha nʼụzọ ha, mgbe ha sitere Fonisia na Sameria na-agafe, ha kọrọ otu ndị mba ọzọ siri chegharịa. Nke a wetara ndị niile kwere ekwe oke ọṅụ dị ukwuu.
\v 4 Mgbe ha bịaruru Jerusalem, nzukọ, ndị ozi na ndị okenye nabatara ha, ha kọkwara ha ihe niile Chineke sitere nʼaka ha mee.
\p 
\v 5 Ma ụfọdụ ndị kwere ekwe si nʼotu ndị Farisii biliri na-ekwu sị, “Na ọ dị mkpa ka e bie ha ugwu ma gwakwa ha ka ha dobe iwu Mosis.”
\p 
\v 6 Mgbe ahụ, ndị ozi na ndị okenye zukọtara itule okwu a.
\v 7 Mgbe ha nọ tulegide okwu ahụ ruo oge dị anya, Pita guzoro ọtọ sị ha, “Ụmụnna m, unu niile maara na site na mbụ Chineke họpụtara m site nʼetiti unu, ka m zisaa oziọma ahụ nye ndị mba ọzọ ka ha nụrụ, ma kwerekwa.
\v 8 Chineke a, onye maara obi mmadụ niile gbaara ha akaebe site nʼinye ha onyinye Mmụọ Nsọ dịka anyị si nata ya na mbụ.
\v 9 O gosighị na o nwere ihe dị iche nʼetiti anyị na ha. Nʼihi na o mere ka obi ha dị ọcha site nʼokwukwe.
\v 10 Ugbu a, gịnị mere unu ji anwa Chineke ọnwụnwa site na-itinye nʼolu ndị na-eso ụzọ ya ibu arọ nke anyị maọbụ nna nna anyị ha na-enweghị ike ịdọkpụ?
\v 11 Mba, anyị kwenyere na ọ bụ site nʼamara nke Onyenwe anyị Jisọs ka a ga-eji zọpụta anyị, dịka a ga-esi zọpụtakwa ha.”
\p 
\v 12 Mmadụ niile nọdụrụ nwayọọ, ha bidoro ige ntị nʼakụkọ Banabas na Pọl na-akọrọ ha banyere ihe ịrịbama niile na ọrụ ebube niile Chineke jiri ha rụọ nʼetiti ndị mba ọzọ.
\v 13 Mgbe ha kwusiri okwu ndị a, Jemis sịrị, “Ụmụnna m geenụ ntị.
\v 14 Saimọn akọọlara anyị otu Chineke si buru ụzọ lekọta ndị mba ọzọ site na isite nʼetiti ha họpụtara onwe ya ndị ga-ekwere na aha ya.
\v 15 Nke a na okwu ndị amụma dakọtara, dịka e dere ya,
\q1 
\v 16 “ ‘Mgbe nke a gasịrị, aga m alọghachi,
\q2 aga m ewughachikwa ụlọ ikwu Devid nke dara ada.
\q1 Ebe ya niile dakpọsịrị adakpọsị ka m ga-ewugharịkwa,
\q2 aga m emekwa ka ọ guzozie,
\q1 
\v 17 ka ndị fọdụrụ nʼetiti mmadụ nwe ike chọọ Onyenwe anyị,
\q2 ọ bụladị ndị mba ọzọ niile ndị a kpọkwasịrị aha m,
\q1 ka Onyenwe anyị kwuru, onye na-emekwa ihe ndị a.’\f + \fr 15:17 \ft \xt Ems 9:11,12\xt*\f*
\q2 
\v 18 Nke a amaara site na mgbe ochie.
\p 
\v 19 “Nʼihi nke a, mkpebi ikpe m bụ nke a, ka anyị ghara isogbu ndị mba ọzọ lọghachikwutere Chineke,
\v 20 kama o kwesiri ka anyị degara ha akwụkwọ gwa ha sị ha hapụ iri nri ọbụla e ji chụọrọ arụsị aja. Ka ha wezugakwa onwe ha site na mmehie ịkwa iko, ya na iri anụ a nyagburu anyagbu, maọbụ ọbara.
\v 21 Site na mbụ, Mosis nwere ndị na-ekwusa iwu nʼobodo niile. A na-agụkwa ya nʼụlọ nzukọ nʼụbọchị izuike niile.”
\s1 Akwụkwọ e degaara ndị mba ọzọ
\p 
\v 22 Mgbe ahụ, ndị ozi na ndị okenye, ha na nzukọ niile, kpebiri ka a họpụta ndị ikom a ga-eziga Antiọk ha na Pọl na Banabas. Ha họpụtara Judas onye a na-akpọkwa Basabas, na Saịlas, ndị ndu so nʼetiti ụmụnna.
\v 23 Ha nyekwara ha nʼakwụkwọ ozi dị otu a,
\pmo Akwụkwọ a sitere nʼaka ndị ozi, na ndị okenye ndị bụ ụmụnna unu.
\pmo A na-edetara ya unu ndị sitere na mba ọzọ kwere bụ ndị nọ nʼAntiọk, Siria na Silisia.
\pmo Ekele.
\pm 
\v 24 E mere ka anyị mata na ụfọdụ ndị otu anyị ebuterela unu nsogbu na ọgbaaghara, mee ka obi lọọ unu mmiri, na-emebi mkpụrụobi unu. Ma nʼezie, ha anataghị ike nʼaka anyị ime nke a.
\v 25 Nʼihi nke a, anyị zukọrọ, sitekwa nʼotu obi kpebie ịhọpụta ụfọdụ ndị ikom na izitere unu ha, ha na ndị anyị hụrụ nʼanya, bụ Pọl na Banabas,
\v 26 ndị ikom werela ndụ ha tụnye nʼaha Onyenwe anyị Jisọs Kraịst.
\v 27 Ya mere, anyị na-ezite Judas na Saịlas ndị ga-akọwara unu nʼihu nʼihu, ihe anyị dere nʼakwụkwọ a.
\v 28 Nʼihi na ọ bụ ihe ziri ezi nʼanya Mmụọ Nsọ na nʼanya anyị kwa, na o kwesighị ka anyị bokwasị unu ibu arọ karịa ihe ndị a dị mkpa.
\v 29 Ma o kwesiri ka unu hapụ iri ihe ọbụla e jiri chụọ aja nye arụsị, ya na iri anụ ọbụla a nyagburu anyagbu, maọbụ ọbara. Kewapụkwanụ onwe unu site nʼịkwa iko. Ọ bụrụ na unu eme ihe ndị a, unu mere nke ọma.
\pmc Nọọnụ nke ọma.
\p 
\v 30 Ya mere, e zipụrụ ha, ha jeruokwa Antiọk. Mgbe ha kpọkọrọ nzukọ ahụ, ha nyere ha akwụkwọ ozi ahụ.
\v 31 Mgbe ndị otu ọgbakọ ahụ gụsịrị ya, ha ṅụrịrị ọṅụ nke ukwuu nʼihi agbamume ha natara.
\v 32 Judas na Saịlas, ndị ha onwe ha bụ ndị amụma, kwuru ọtụtụ okwu, iji gbaa ha ume na ime ka okwukwe ndị kwere ekwe guzosie ike.
\v 33 Mgbe ha nọnyesịrị ha nwa oge nta, ndị kwere ekwe ji ngọzị nke udo zilaga ha ka ha laghachikwuru ndị zitere ha.
\v 34 Ma ọ masịrị Saịlas ịnọtukwu nʼebe ahụ.\f + \fr 15:34 \ft Ụfọdụ akwụkwọ adịghị edebanye ihe banyere Saịlas nʼamaokwu a.\f*
\v 35 Pọl na Banabas nọgidere nʼAntiọk, ebe ha na ndị ọzọ kuziri ihe ma kwusakwa okwu Onyenwe anyị.
\s1 Nkewa nke dị nʼetiti Pọl na Banabas
\p 
\v 36 Mgbe ụbọchị ole na ole gasịrị, Pọl gwara Banabas, “Ka anyị gaghachi nʼobodo niile anyị kwusara okwu Onyenwe anyị nʼotu nʼotu, mata ka ndị kwere ekwe si agbalị nʼebe ahụ.”
\v 37 Banabas chọrọ ka ha na Jọn onye a na-akpọ Mak soro gaa.
\v 38 Ma Pọl echeghị na o ziri ezi iduru ya nʼihi na ọ hapụrụ ha na Pamfilia. O sokwaghị ha jezuo ozi ha.
\v 39 Ịrụ ụka dapụtara nʼetiti ha siri ike nke mere na ha kewara. Banabas kpọrọ Jọn Mak banye nʼụgbọ gawa Saiprọs.
\v 40 Ma Pọl họọrọ Saịlas, kpọrọ ya gawa njem, mgbe ụmụnna kpesịrị ha ekpere raara ha nye nʼamara Onyenwe anyị.
\v 41 O jegharịrị nʼime obodo Siria na Silisia na-agba nzukọ nọ nʼebe ahụ ume.
\c 16
\s1 Timoti esonyere Pọl na Saịlas
\p 
\v 1 Pọl bịaruru Debi na Listra, ebe otu onye na-eso ụzọ Jisọs a na-akpọ Timoti bi. Nne ya bụ onye Juu bụrụkwa onye kwere ekwe, ma nna ya bụ onye Griik.
\v 2 Ụmụnna ndị bi na Listra na Aikoniọm gbara ezi ama banyere ya.
\v 3 Pọl chọrọ ka Timoti soro ya nʼije ya. Ma nʼihi ndị Juu bi nʼakụkụ ebe ahụ, o biri ya ugwu nʼihi na mmadụ niile maara na nna ya bụ onye Griik.
\v 4 Dịka ha na-eme njem site nʼobodo ruo nʼobodo, ha na-akọwara ha ihe banyere mkpebi ndị ozi na ndị okenye kpebiri na Jerusalem ka ha nwe ike idebe ha.
\v 5 Ihe ndị a niile mere ka nzukọ sie ike nʼokwukwe ma baakwa ụba nʼọnụọgụgụ kwa ụbọchị.
\s1 Pọl ahụ ọhụ banyere nwoke Masidonia
\p 
\v 6 Ha gara mpaghara Frigia na Galeshịa. Ma Mmụọ Nsọ ekweghị ka ha kwusaa oziọma nʼakụkụ Eshịa nʼoge ahụ.
\v 7 Mgbe ha ruru nʼakụkụ obodo Misia, ha chere ihu ịbanye nʼakụkụ obodo Bitinia. Ma Mmụọ Nsọ nke Jisọs akwagideghị ka ha gaa.
\v 8 Ka ha si nʼakụkụ Misia gafee, ha batara Troas.
\v 9 Nʼabalị ahụ, Pọl hụrụ ọhụ ebe ọ hụrụ otu nwoke onye Masidonia ka o guzo na-arịọ ya sị, “Bịa na Masidonia nyere anyị aka.”
\v 10 Mgbe ọ hụchara nke a, anyị jikeere ngwangwa ịga Masidonia ebe anyị mara na Chineke akpọọla anyị ịgbasara ha oziọma.
\s1 Lidia aghọọ onye kwere ekwe
\p 
\v 11 Anyị banyere ụgbọ mmiri na Troas sị ya gafee Samotres. Nʼechi ya, anyị bịaruru Niapolis.
\v 12 Site nʼebe ahụ anyị jeruru Filipai nke bụ isi obodo dị nʼakụkụ mpaghara Masidonia bụrụkwa otu akụkụ nʼebe ndị Rom na-achị. Anyị nọdụrụ nʼime obodo a ọtụtụ ụbọchị.
\p 
\v 13 Nʼụbọchị izuike, anyị sitere nʼobodo ahụ gaa nʼakụkụ osimiri ebe anyị chọpụtara na ụlọ ekpere dị. Nʼebe a ka anyị nọ gwa ụmụ nwanyị ndị gbakọrọnụ okwu.
\v 14 Aha otu nʼime ndị inyom nụrụ okwu anyị bụ Lidia, onye obodo Tiatira, onye na-azụ ahịa akwa e sijiri odo odo. Ọ bụkwa nwanyị na-asọpụrụ Chineke. Onyenwe anyị meghere obi ya, ige ntị nʼihe Pọl na-ekwu.
\v 15 Ka e mesịrị ya na ezinaụlọ ya baptizim, ọ rịọrọ anyị na-asị, “Ọ bụrụ nʼezie na unu gụrụ m dịka onye kwesiri ntụkwasị obi nye Onyenwe anyị, batanụ nʼụlọ m nọrọ.” Mgbe ọ kwagidesịrị anyị ike, anyị sooro ya.
\s1 Pọl na Saịlas nʼụlọ mkpọrọ
\p 
\v 16 Otu ụbọchị, mgbe anyị na-aga nʼụlọ ekpere, anyị zutere otu nwaagbọghọ bụ ohu, onye nwere mmụọ ịgba afa. Ọ na-ewetara ndị nwe ya ezigbo ego site nʼịgba afa.
\v 17 Ma o sogidere anyị na Pọl ebe ọbụla anyị na-aga, na-eti mkpu na-asị, “Ndị a bụ ndị ohu Chineke Onye kachasị ihe niile elu. Ha bịara ikwupụtara unu ihe banyere ụzọ nzọpụta.”
\v 18 O mere nke a ọtụtụ ụbọchị. Ma site nʼoke iwe, Pọl baara mmụọ ọjọọ ahụ bi nʼime ya mba sị, “Eji m aha Jisọs Kraịst na-enye gị iwu sị gị site nʼime ya pụta!” Otu mgbe ahụ o siri nʼime ya pụta.
\p 
\v 19 Mgbe ndị nwe ya hụrụ nʼolileanya ha iji inweta ego akwụsịla, ha jidere Pọl na Saịlas dọkpụrụ ha jekwuru ndịisi obodo nʼọma ahịa.
\v 20 Mgbe ha dutara ha nʼihu ndị na-ekpe ikpe ha sịrị, “Ndị ikom a bụ ndị Juu ma ha etinyela ọgbaaghara nʼobodo anyị,
\v 21 site nʼikuzi omenaala megidere iwu anyị, nke anyị bụ ndị Rom na-enweghị ike ịnabata maọbụ mee.”
\p 
\v 22 Igwe mmadụ sonyere imegide ha. Ndị ikpe nyere iwu ka a dọwaa uwe,\f + \fr 16:22 \ft Ya bụ gbaa ha ọtọ\f* pịakwa ha ihe.
\v 23 Mgbe ha pịachara ha ihe nke ọma, a tụnyere ha nʼime ụlọ mkpọrọ, nyekwa onye nche iwu ka o chee ha nke ọma.
\v 24 Nʼihi nke a, o tinyere ha nʼime ime ụlọ mkpọrọ, ebe o jiri ọtọsị kegide ha nʼụkwụ.
\p 
\v 25 Nʼetiti abalị, mgbe Pọl na Saịlas na-ekpe ekpere na-abụkwa abụ ito Chineke, ndị niile nọ nʼụlọ mkpọrọ ahụ na-ege ha ntị.
\v 26 Na mberede, oke ala ọma jijiji bidoro, nke mere ka ntọala ụlọ mkpọrọ ahụ maa jijiji. Ngwangwa, ọnụ ụzọ ya niile meghere, ụdọ igwe niile e jiri kee ndị mkpọrọ tọpụkwara.
\v 27 Mgbe onyeisi nche ụlọ mkpọrọ tetara nʼụra ma hụ na ọnụ ụzọ niile ghere oghe. Nʼihi ya, o chere na ndị mkpọrọ niile agbapụla. Ya mere, ọ mịpụtara mma agha ya chọọ igbu onwe ya.
\v 28 Ma Pọl tiri mkpu nʼoke olu, sị, “Emerula onwe gị ahụ. Anyị niile nọ nʼebe a!”
\p 
\v 29 Onyeisi nche ahụ kpọrọ ka eweta ọkụ, ọ gbabara nʼime, daa nʼụkwụ Pọl na Saịlas na-ama jijiji.
\v 30 Ọ kpọpụtara ha nʼezi sị, “Ndị nwe m, gịnị ka m ga-eme ka a zọpụta m?”
\p 
\v 31 Ha sịrị, “Kwere nʼOnyenwe anyị Jisọs, a ga-azọpụta gị na ezinaụlọ gị niile.”
\v 32 Mgbe ahụ, ha gwara ya na ndị niile nọ nʼezinaụlọ ya okwu nke Onyenwe anyị.
\v 33 Nʼotu elekere ahụ, nʼabalị ahụ, ọ sachara ọnya ha. Nʼatụfughị oge, ha mere ya na ezinaụlọ ya baptizim.
\v 34 Ọ kpọbatara ha nʼụlọ ya, nye ha ihe oriri. Ya onwe ya na ezinaụlọ ya ṅụrịrị ọṅụ nʼihi na o kwerela na Chineke.
\p 
\v 35 Nʼechi ya, ndị ikpe ahụ zitere ndị uweojii sị, “Hapụnụ ụmụ nwoke ahụ ka ha laa.”
\v 36 Onyeisi ụlọ mkpọrọ ahụ gwara Pọl, sị, “na ndị ikpe zitere ozi sị ha laa. Ugbu a pụtanụ. Unu laanụ nʼudo.”
\p 
\v 37 Ma Pọl sịrị ha, “Ha tiri anyị ihe nʼihu mmadụ niile na-ebughị ụzọ kpee anyị ikpe. Emesịa ha tinyere anyị nʼụlọ mkpọrọ. Anyị bụ diala nʼobodo Rom! Olee otu ha ga-esi zipụ anyị na nzuzo. O kwesiri ka ha bịa nʼonwe ha kpọpụta anyị.”
\p 
\v 38 Ndị uweojii ahụ gara gwa ndị ikpe ahụ ihe ha kwuru. Mgbe ha nụrụ na ha bụ diala na Rom, ha tụrụ egwu nke ukwuu.
\v 39 Ha bịakwutere ha rịọsie ha arịrịọ ike. Ha kpọpụtakwara ha, rịọ ha ka ha hapụ obodo ahụ.
\v 40 Mgbe ha sitere nʼụlọ mkpọrọ pụta, ha gara nʼụlọ Lidia. Nʼebe ahụ ka ha zutere ụmụnna, gwa ha okwu mgbamume, emesịa ha si nʼobodo ahụ pụọ.
\c 17
\s1 Pọl nʼobodo Tesalonaịka
\p 
\v 1 Mgbe ha gafechara obodo Amfipolis na Apolonia, ha bịaruru obodo Tesalonaịka, ebe ụlọ nzukọ ndị Juu dị.
\v 2 Pọl bakwuuru ha, dịka ọ na-eme oge niile. Ọ nọnyere ha izu ụka atọ, ya na ha na-atụgharị uche nʼAkwụkwọ Nsọ,
\v 3 na-akọwara ha na-edokwa ha anya na ọ dị mkpa na Kraịst ga-ahụ ahụhụ, ma sitekwa nʼọnwụ bilie. Ọ sịrị, “Jisọs a, nke m na-ekwusara unu bụ Kraịst ahụ.”
\v 4 Ụfọdụ nʼime ndị Juu ahụ ka e mere ka ha kwere ma sonyere Pọl na Saịlas, otu aka ahụ, igwe mmadụ ndị na-atụ egwu Chineke nʼetiti ndị Griik na ụmụ nwanyị ụfọdụ a maara aha ha.
\p 
\v 5 Ma ndị Juu jupụtara nʼekworo, nʼihi ya, ha kpaliri obi ụfọdụ mmadụ efu nʼetiti ha nʼọma ahịa. Ndị a malitekwara ọgbaaghara nʼụzọ dị iche nʼime obodo. Ha tikasịrị ụlọ Jesin, nʼihi na ha chọrọ ịdọpụta ha nyefee ha nʼaka ọha mmadụ.
\v 6 Ma mgbe ha na-achọtaghị ha nʼebe ahụ, ha dọpụtara Jesin na ụmụnna anyị ụfọdụ, duru ha jekwuru ndị ikpe nke obodo ahụ, na-eti mkpu, “Ndị a kpuru ụwa ihu nʼala abịala inye obodo ukwu anyị nsogbu.
\v 7 Ma Jesin nabatara ha nʼụlọ ya. Ha na-emebi iwu Siza nʼihi na ha na-asịkwa na ọ dị eze ọzọ dị nke a na-akpọ Jisọs.”
\v 8 Okwu dị otu a wetara obi ịlọ mmiri nʼetiti ndị ikpe na mmadụ niile.
\v 9 Ha hapụrụ Jesin na ndị ọzọ, naanị mgbe ndị akaebe bịara kwụọ ụgwọ e jiri gbapụta ha.
\s1 Pọl nʼobodo Beria
\p 
\v 10 Ma nʼabalị ahụ, ndị kwere ekwe mere ngwangwa zipụ Pọl na Saịlas ka ha gaa obodo Beria. Ma mgbe ha ruru nʼebe ahụ, ha banyere nʼụlọ nzukọ ndị Juu.
\v 11 Ma ndị bi na Beria jiri obi ghere oghe nabata okwu a karịa ndị bi na Tesalonaịka. Nʼihi na ha ji ịnụ ọkụ nʼobi nara okwu ahụ, na-enyocha Akwụkwọ Nsọ kwa ụbọchị, ka ha mara ma ihe ha na-ekwu ọ bụ eziokwu. Ha mere nke a ụbọchị niile.
\v 12 Ọtụtụ nʼime ha kweere, ụfọdụ ụmụ nwanyị na ụmụ nwoke ndị Griik a maara aha ha chegharịkwara.
\p 
\v 13 Ma mgbe ndị Juu bi na Tesalonaịka nụrụ na Pọl na-ekwusa oziọma Chineke na obodo Beria, ụfọdụ ha gara nʼebe ahụ na-akpali igwe ndị mmadụ nʼihi iwebata ọgbaaghara.
\v 14 Ndị kwere ekwe mere ngwangwa zipụ Pọl ka ọ gaa nʼakụkụ oke osimiri dị nʼebe ahụ. Ma ha hapụrụ Saịlas na Timoti ka ha na ha nọdụ.
\v 15 Ma ndị dupuru Pọl sooro ya ruo obodo Atens. Ha lawara, hapụrụ Saịlas na Timoti ozi ka ha bịakwute ya na-atụfughị oge.
\s1 Pọl nʼobodo Atens
\p 
\v 16 Mgbe Pọl nọ na-echere ha nʼAtens, o wutere mmụọ ya nke ukwuu nʼihi arụsị niile ọ hụrụ, nke jupụtara nʼobodo ahụ.
\v 17 Nʼihi nke a, ya na ndị Juu na ndị na-atụ egwu Chineke, na-anọgide nʼụlọ nzukọ na-arụrịta ụka. Kwa ụbọchị, ọ na-apụkwa nʼọma ahịa na-agwa ndị niile o zutere okwu.
\v 18 Ya na ụfọdụ ndị Epikuri\f + \fr 17:18 \ft Otu ndị kwenyere na ndụ bụ maka naanị oriri na ọṅụṅụ.\f* na ndị Stoịk\f + \fr 17:18 \ft Otu ndị na-ekwenyeghị na ndụ bụ naanị oriri na ọṅụṅụ.\f* bụ ndị ọkachamara na-arụrịta ụka. Ndị ụfọdụ na-asị, “gịnị ka onye ekwurekwu a ga-ekwu?” Ndị ọzọ sịrị, “ọ dịka onye na-ekwusa ụmụ mmụọ\f + \fr 17:18 \ft Ha chere na ọ bụ chi nke ndị ala ọzọ, ha amaghị na ọ bụ Chi onye kere ihe niile ka ọ na-ekwu banyere ya.\f* ndị ala ọzọ.” Ha kwuru nke a nʼihi na ọ na-ekwusa oziọma banyere Jisọs na mbilite nʼọnwụ ya.
\v 19 Ha kpọbatara ya nʼebe ha zukọrọ, ebe a na-akpọ Areopagọs,\f + \fr 17:19 \ft Maọbụ, \fqa Ugwu Maas\f* ebe ha nọ sị ya, “Anyị enwere ike ịmata ihe banyere ozizi ọhụrụ gị a?
\v 20 Ị na-ekwu ihe ndị na-agbagwoju anyị anya. Anyị chọrọ ịmata ihe ndị a nke ọma.”
\v 21 (Ndị Atens niile na ndị ala ọzọ bi nʼobodo ahụ, enweghị ohere ime ihe ọbụla, ọ gwụchaala ọrụ ikwu na ịnụ banyere ihe dị ọhụrụ.)
\p 
\v 22 Mgbe ahụ Pọl guzoro na nzukọ Areopagọs sị, “Unu ndị Atens, ahụla m na ọ na-anụ unu ọkụ nʼobi ịsọpụrụ mmụọ nke unu na-efe ofufe.
\v 23 Nʼihi na mgbe m na-ejegharị nʼobodo unu, ahụrụ m ụlọ chi dị iche iche, ahụrụ m otu ebe ịchụ aja nke e dekwasịrị nʼelu ya:
\pc Ihe e nyere chi nke amaghị ama.
\m Ya mere, ihe ahụ unu na-efe ofufe nʼamaghị ama nke a ka m na-ekwusara unu.
\p 
\v 24 “Chineke onye kere ụwa na ihe niile dị nʼime ya. Ebe ọ bụ onye nwe eluigwe na ụwa, ọ dịghị ebikwa nʼụlọnsọ e jiri aka wuo.
\v 25 Otu aka ahụ, ọ dịghị anara ije ozi site nʼaka mmadụ, dịka a ga-asị na o nwere ihe kọrọ ya. Ya onwe ya na-enye ndụ na ume na ihe niile. Ọ na-egbokwa mkpa niile.
\v 26 O sitere nʼaka otu onye, bụ mmadụ mbụ ahụ, kee agbụrụ niile nke mmadụ nʼotu nʼotu, ka ha biri nʼelu ụwa dum. O jiri aka ya kewachaa oge ọgbọ ọbụla ga-anọ na oke niile nke ebe obibi ha.
\v 27 Ma nzube ya banyere ihe niile bụ ka onye ọbụla chọsie Chineke ike. Eleghị anya, mmadụ nwere ike lezie ụzọ ya anya, si otu a chọta ya. Ọ nọkwaghị mmadụ ọbụla nʼebe dị anya.
\v 28 ‘Nʼihi nʼime ya ka anyị na-ebi, anyị na-ejegharịkwa nʼime ya na-adịkwa ndụ.’ Dịka ụfọdụ nʼime unu ndị ode abụ na-ekwu sị, ‘Anyị onwe anyị bụ ụmụ ya.’
\p 
\v 29 “Ebe anyị bụ ndị Chineke mụrụ, o kwesighị ka anyị na-eche na ihe akpọrọ Chineke yiri ọlaọcha maọbụ ọlaedo, maọbụ nkume, ihe apịrị apị site na ǹka na ihe dị nʼobi mmadụ.
\v 30 Ma Chineke lefuru enweghị nghọta nke mmadụ anya banyere ihe ndị a niile nʼoge gara aga. Ma ugbu a, ọ chọrọ ka mmadụ niile chegharịa.
\v 31 Nʼihi na o debela otu ụbọchị mgbe ọ ga-ekpe ụwa niile ikpe nʼụzọ ezi omume, site nʼaka otu nwoke ọ họpụtara. O mekwara ka nke a guzosie ike, mgbe o mere ka onye ahụ sị nʼọnwụ bilie.”
\p 
\v 32 Mgbe ha nụrụ ihe banyere mbilite nʼọnwụ nke ndị nwụrụ anwụ, ha chịrị ya ọchị. Ma ụfọdụ nʼime ha sịrị, “Nʼoge ọzọ anyị ga-achọ ịnụ okwu ndị a.”
\v 33 Nʼoge a, Pọl hapụrụ ha.
\v 34 Mmadụ ole na ole sooro ya, bụrụkwa ndị kwere ekwe. Otu onye nʼime ha bụ Dionisiọs onye Areopagọs. Onye ọzọ bụ nwanyị a na-akpọ Damaris na ndị ọzọkwa.
\c 18
\s1 Pọl nʼobodo Kọrint
\p 
\v 1 Ka nke a mechara, Pọl hapụrụ Atens gaa Kọrint.
\v 2 Nʼebe ahụ o zutere otu onye Juu a mụrụ nʼobodo Pọntọs, onye a na-akpọ Akwila. Ya na nwunye ya Prisila sitere Itali Klọdiọs nyere iwu ka a chụpụ ndị Juu site nʼobodo Rom. Pọl gara hụ ha,
\v 3 nʼihi na ha na-arụ otu ọrụ, o binyere ha, sokwara ha rụkọọ ọrụ nʼihi na ha bụ ndị na-akpa akwa e ji ama ụlọ ikwu.
\v 4 Ụbọchị izuike niile, ọ na-arụ ụka nʼụlọ nzukọ ha na-agbalị ime ka ndị Juu na ndị Griik kwere.
\p 
\v 5 Mgbe Saịlas na Timoti sitere na Masidonia bịa, Pọl tinyere oge ya niile ikwusa okwu na ịkọwara ndị Juu na Jisọs bụ Kraịst ahụ.
\v 6 Mgbe ọbụla ha megidere ya ma kparịa ya, ọ na-efecha uwe ya, sị ha, “Ọbara unu dị unu nʼisi, aka m dị ọcha. Malite ugbu a, aga m agakwuru ndị mba ọzọ.”
\p 
\v 7 O siri nʼebe ahụ pụọ, gaa nʼụlọ otu nwoke a na-akpọ Taịtọs Jọstus, onye na-asọpụrụ na-efekwa Chineke ofufe. Ụlọ ya dị nso nʼụlọ nzukọ ndị Juu.
\v 8 Krispọs onyeisi nʼụlọ nzukọ ahụ na ezinaụlọ ya niile kweere nʼOnyenwe anyị. Ọtụtụ ndị ọzọ bi na Kọrint nụrụ okwu ahụ, kwere, e mee ha baptizim.
\p 
\v 9 Onyenwe anyị gwara Pọl nʼọhụ nʼotu abalị sị, \wj “Atụla egwu, kwusie okwu ike, emechikwala ọnụ gị.\wj*
\v 10 \wj Nʼihi na anọnyeere m gị. Ọ dịkwaghị onye ọbụla pụrụ imerụ gị ahụ. Enwekwara m ọtụtụ mmadụ nʼime obodo a.”\wj*
\v 11 Ọ nọgidere ebe ahụ otu afọ na ọkara. Ọ na-ezikwa ndị mmadụ okwu Chineke.
\p 
\v 12 Mgbe Galio malitere ịchị achị nʼobodo Akaịa, ndị Juu bidoro omume ọjọọ megide Pọl. Nʼikpeazụ, ha dupụtara ya, gaa nʼụlọikpe.
\v 13 Ha sịrị, “Nwoke a na-amanye ndị mmadụ ka ha na-ekpere Chineke nʼụzọ megidere iwu.”
\p 
\v 14 Ma mgbe Pọl chọrọ ikwu okwu, Galio sịrị ndị Juu ahụ, “Agaara m enwe ndidi gee unu ntị ma ọ bụrụ na okwu a gbasara mmejọ mmadụ mejọrọ ibe ya, maọbụ arụ mmadụ mere megide obodo.
\v 15 Ma ebe unu na-ekwu ihe banyere okwu na aha dị iche iche nakwa iwu unu, gaanụ dozie ya nʼonwe unu. Agaghị m abụ onye ikpe okwu ihe ndị dị otu a.”
\v 16 O sitere nʼime ụlọ ikpe ya chụpụ ha.
\v 17 Ha jidere Sostenis, onye bụ onyeisi ụlọ nzukọ ahụ tie ya ihe nke ukwuu nʼọnụ ụzọ ụlọ ikpe ahụ. Ma Galio emeghị dịka ọ maara ihe na-eme nʼebe ahụ.
\s1 Prisila, Akwila na Apọlọs
\p 
\v 18 Mgbe ọ nọsịrị nʼebe ahụ ọtụtụ ụbọchị, Pọl sịrị ndị kwere ekwe nọ nʼebe ahụ ka ha nọdụnụ nke ọma, ma si nʼebe ahụ banye nʼụgbọ mmiri ruo Siria. Prisila na Akwila sokwaara ya gaa. Nʼobodo a na-akpọ Senkria, ọ kpụchara agịrị isi ya, nʼihi nkwa o kwere.
\v 19 Mgbe ha rutere Efesọs, ọ hapụrụ ha nʼebe ahụ, ma o bu ụzọ banye nʼụlọ nzukọ ebe ya na ndị Juu nwere mkparịta ụka.
\v 20 Ma mgbe ha rịọrọ ya ka ọ nọnyetụkwuoro ha ogologo oge, ọ kweghị.
\v 21 Mgbe ọ na-ahapụ, ọ sịrị ha, “Ọ bụrụ na Chineke kwe, aga m alọghachikwute unu ọzọ.” Emesịa ọ banyere nʼụgbọ hapụ Efesọs.
\v 22 Mgbe ọ kwụsịrị na Sizaria, ọ gara leta chọọchị dị nʼebe ahụ kelee ha. Emesịa, ọ gara nʼihu ruo Antiọk.
\p 
\v 23 Mgbe ọ nọsịrị nwa oge nta nʼebe ahụ, ọ sitere nʼebe ahụ pụọ jegharịa nʼakụkụ obodo Galeshịa na Frigia na-agba ndị na-eso ụzọ ahụ ume.
\s1 Ọbịbịa Apọlọs nʼobodo Efesọs na Kọrint
\p 
\v 24 Ma otu nwoke onye Juu, aha ya bụ Apọlọs, onye Alegzandria bịara na Efesọs. Ọ bụ onye ọka okwu, bụrụkwa onye maara ihe edere nʼAkwụkwọ Nsọ nke ọma.
\v 25 Nwoke a natara ozizi banyere ụzọ Onyenwe anyị. O sitekwara nʼịnụ ọkụ nke obi kuzie nnọọ ihe ziri ezi banyere Jisọs. Ma ihe ọ maara bụ naanị ihe gbasara baptizim Jọn mere.
\v 26 Ma ọ nọgidesịrị ike na-ekwuwa okwu nʼụlọ nzukọ. Mgbe Prisila na Akwila nụrụ okwu ya, ha jekwuru ya, duru ya gaa nʼụlọ, were nwayọọ kọwaara ya ihe niile banyere ụzọ Chineke.
\p 
\v 27 Mgbe o zubere ịga obodo Akaịa, ndị ụmụnna gbara ya ume. Ha degaara ndị na-eso ụzọ Onyenwe anyị nọ nʼebe ahụ akwụkwọ ka ha nabata ya. Mgbe ọ bịaruru, Onyenwe anyị sitere nʼaka ya mee ka amara ya baa ụba nʼebe ndị kwere ekwe nọ.
\v 28 Nʼihi na nʼihu ndị mmadụ niile, o guzoro kwuo okwu megide ozizi ọjọọ na ịrụ ụka niile nke ndị Juu. O gosiri ha site nʼakwụkwọ nsọ na Jisọs bụ Kraịst ahụ.
\c 19
\s1 Pọl nʼobodo Efesọs
\p 
\v 1 Mgbe Apọlọs nọ na Kọrint, Pọl sitere ụzọ nke nʼime elu ala bịarute Efesọs. Nʼebe ahụ, ọ hụrụ ụfọdụ ndị na-eso ụzọ ahụ,
\v 2 sị ha, “Unu natakwara Mmụọ Nsọ mgbe unu kweere?”
\p Ha sịrị ya, “Mba, anyị anụbeghị na ọ nwere ihe dịka Mmụọ Nsọ.”
\p 
\v 3 Ya mere, ọ sịrị, “Gịnị ka unu kwenyere nʼime ya mgbe e mere unu baptizim?”
\p Ha sịrị, “Baptizim nke Jọn.”
\p 
\v 4 Mgbe ahụ, Pọl sịrị, “Baptizim Jọn bụ nke gbasara nchegharị site na mmehie, na-agwa ndị mmadụ ka ha kwere nʼonye ahụ na-eso ya na-abịa, nke bụ, ikwere nʼime Jisọs.”
\v 5 Mgbe ha nụrụ nke a, e mere ha baptizim nʼaha Onyenwe anyị Jisọs.
\v 6 Mgbe Pọl bikwasịrị ha aka ya abụọ nʼisi, ha natara Mmụọ Nsọ. Ha kwukwara okwu nʼasụsụ dị iche iche, bukwaa amụma.
\v 7 Ha niile ruru ndị ikom iri na abụọ.
\p 
\v 8 Ọ banyere nʼụlọ nzukọ ahụ ma were nkwuwa okwu, na ịrụ ụka nʼebe o doro anya gwasie ha okwu ike banyere alaeze Chineke. Ọ bụ ọnwa atọ ka o were ya ime nke a.
\v 9 Ma ụfọdụ nʼime ha mechiri obi ha; ha juru ikwenye, kama ha kwuru okwu ọjọọ megide Ụzọ ahụ nʼihu ọgbakọ ahụ niile. Ya mere, o sitere nʼebe ha nọ pụọ, kpọrọkwa ndị na-eso ụzọ ahụ, ha na-akparịta ụka kwa ụbọchị nʼụlọ ọgbakọ\f + \fr 19:9 \ft Nke a bụ ebe a na-anọ na-akụziri ọha mmadụ ihe.\f* Tiranọs.
\v 10 Ihe ndị a gakwara nʼihu afọ abụọ. Ndị niile bi na Eshịa nụkwara oziọma Onyenwe anyị. Ọtụtụ nʼime ha bụ ndị Juu, ma ndị ọzọ bụ ndị Griik.
\s1 Ụmụ Skiva
\p 
\v 11 Chineke sitere nʼaka Pọl rụọ ọtụtụ ọrụ ebube pụrụ iche.
\v 12 Nke bụ na-ewere ụfọdụ nʼime akịsị maọbụ ịchafọ na akwa mgbochi nke metụrụ ya nʼahụ na-atụkwasị nʼahụ ndị ọrịa, ahụ a dịkwa ha ike. E sitekwara na ya chụpụ mmụọ ọjọọ.
\p 
\v 13 Ụfọdụ ndị Juu dịkwa ndị na-ejegharị nʼobodo dị iche iche na-achụpụ mmụọ ọjọọ nʼime mmadụ. Ha chọkwara ime nke a nʼaha Onyenwe anyị Jisọs na-asị, “E ji m aha Jisọs, onye Pọl na-ekwusa na-enye unu iwu ka unu site nʼime ya pụta.”
\v 14 Ndị na-eme ihe dị otu a bụ ụmụ asaa nke Skiva, onyeisi nchụaja, bụ onye Juu.
\v 15 Mmụọ ọjọọ ahụ zara ha sị, “Amaara m onye Jisọs bụ, amakwaara m onye Pọl bụ, ma unu onwe unu, unu bụ ndị ole?”
\v 16 Nwoke ahụ mmụọ ọjọọ na-achị makwasịrị ha, tie ha ihe nke ukwuu, mee ka ha gbaa ọsọ. Ha gbara ọtọ gbapụ nʼụlọ ahụ. Ha merụkwara ahụ.
\p 
\v 17 Akụkọ banyere ihe ndị a jezuru obodo Efesọs niile. Mgbe ahụ, ndị Juu na ndị Griik ụfọdụ nụkwara ihe ndị a. Oke egwu jidekwara ha. Nʼihi nke a, e mekwara ka aha Onyenwe anyị Jisọs daa ụda nʼebe niile.
\v 18 Ọtụtụ ndị kwenyerenụ bịara na-ekwupụta omume ọjọọ ha niile, nʼihu mmadụ niile.
\v 19 Ọtụtụ nʼime ndị na-agwọ ọgwụ mgbaasị bupụtara akwụkwọ niile ha ji na-eme mgbaasị, kpọọ ha ọkụ nʼihu mmadụ niile. Akwụkwọ niile a kpọrọ ọkụ nʼụbọchị ahụ ga-eru ego ruru puku ọlaọcha iri ise.
\v 20 Ya mere, okwu Onyenwe anyị toro, na-agbasa nʼike nʼike na-adịkwa ire.
\p 
\v 21 Mgbe ihe ndị a gasịrị, Pọl kpebiri nʼime mmụọ ya na ya ga-eje ruo Masidonia na Akaịa tupu ọ bịaruo Jerusalem. O sịkwara “na ya aghaghị ijeru Rom nʼọgwụgwụ ije ya niile.”
\v 22 O zipụrụ ndị na-enyere ya aka, bụ Timoti na Erastọs ka ha buru ụzọ jeruo Masidonia. Ma ya onwe ya nọgidere nʼime Eshịa nwa oge.
\s1 Ọgbaaghara nʼobodo Efesọs
\p 
\v 23 Ma ọ bụ nʼoge a ka oke nsogbu malitere megide Ụzọ ahụ.
\v 24 Otu onye ụzụ na-agbaze ọlaọcha, aha ya bụ Dimitriọs, onye ji ọlaọcha na-akpụ ụlọ arụsị ala ahụ a na-akpọ Atemis. Ọ na-ewetara ya na ndị ụzụ ibe ya ego nʼebe o hiri nne.
\v 25 Nwoke a kpọkọtara ndị ọrụ ya niile, na ndị ya na ha na-arụkọ otu ọrụ, sị, “Ndị ibe m, unu ma na ọ bụ site nʼọrụ nke a ka anyị si enweta akụnụba anyị.
\v 26 Unu niile ahụla ma nụkwa, otu nwoke a na-akpọ Pọl si rafuo ọtụtụ ndị mmadụ site nʼime ka ha kwenye na chi\f + \fr 19:26 \ft Ya bụ, chi nke mmadụ hiwere\f* ọbụla e ji aka mee abụghị chi. Ọ bụkwaghị naanị nʼEfesọs kama ọ fọdụrụ ihe nta ka ọ bụrụ nʼEshịa niile.
\v 27 Ọ bụkwaghị naanị na ihe ize ndụ dị banyere ọrụ aka anyị nke a ga elelị kama tinyere nke a, ụlọ nke oke chi nwanyị bụ Atemis agaghị enwekwa nsọpụrụ. Ya bụ, chi nwanyị nʼonwe ya bụ onye a na-efe nʼobodo Eshịa niile nakwa nʼelu ụwa niile ka a ga-anapụ nkwanye ugwu dịrị ya dịka chi.”
\p 
\v 28 Ma mgbe ha nụrụ ihe ndị a, ha were oke iwe tie mkpu na-asị, “Atemis ndị Efesọs dị ukwuu!”
\v 29 Ọgbaaghara ahụ gbasara, zuo obodo ahụ niile. Ha banyere nʼebe a na-eme ihe ileleanya, kpọpụta Gaiọs na Arịstakọs ndị Masidonia, bụ ndị ha na Pọl na-arụkọ ọrụ.
\v 30 Pọl chọrọ ịbakwuru igwe mmadụ ahụ, ma ndị na-eso ụzọ ahụ ekweghị ya.
\v 31 Otu aka ahụ kwa, ụfọdụ ndị enyi ya nʼetiti ndị na-achị Eshịa zigakwaara ya ozi na-arịọ ya ka ọ hapụ ịbanye nʼebe ahụ a na-eme ihe ileleanya.
\p 
\v 32 Ugbu a, nzukọ ahụ na-agba aghara, ụfọdụ mmadụ na-eti mkpu otu ihe, ndị ọzọ na-eti ihe ọzọ. Nʼezie, ọtụtụ nʼime ha amatakwaghị ihe ha jiri nọdụ nʼebe ahụ.
\v 33 Ụfọdụ ndị Juu nʼime ọgbakọ ahụ nupuru Alegzanda, sepụta ya, mee ka o buru ụzọ. Alegzanda feere ha aka ka ha dere duu mgbe ọ chọrọ ịgọrọ onwe ya nʼihu ọha mmadụ ahụ.
\v 34 Ma nʼotu ntabi anya ahụ, mgbe ha matara na ọ bụ onye Juu, ha bidoro iti mkpu ihe dịka ogologo awa abụọ na-asị, “Atemis ndị Efesọs dị ukwuu!”
\p 
\v 35 Nʼikpeazụ, ode akwụkwọ nke obodo ahụ kwụsịrị igwe mmadụ ahụ ime ụzụ. O kwuru, “Ndị ikom Efesọs, o nwere onye na-amaghị na obodo Efesọs bụ obodo na-echekwa ụlọ ofufe Atemis, na oyiyi ya nke si nʼeluigwe daa?
\v 36 Ebe ihe ndị a adịghị na ngọpụ, ọ dị mkpa ka unu nọdụ nwayọọ, ghara imebi ihe ọbụla nʼecheghị echiche.
\v 37 Lee ugbu a, ndị a unu kpọtara nʼebe a abụghị ndị ohi, ndị na-ezuru ihe nʼogige chi anyị, maọbụ na-ekwutọ eze nwanyị arụsị anyị.
\v 38 Ọ bụrụ na Dimitriọs na ndị ọkpụ ụzụ ibe ya nwere ihe ọbụla megide ha, ha gaa nʼụlọikpe. Ndị na-ekpe ikpe ga-eleba okwu ha anya. Kama ha mee ya nʼusoro iwu kwadoro.
\v 39 Ma ọ bụrụ na o nwere ihe ọzọ dị iche unu chọrọ ka e mee, a ga-edozi ya na nzukọ nke ndị obodo na-eme nʼụzọ ziri ezi.
\v 40 Nʼihi na egwu dị, na-eleghị anya a ga-eji ihe nke mere taa boo anyị ebubo na anyị na-ebute ọgbaaghara. Anyị enweghị ọsịsa ziri ezi banyere ọgbaaghara nke a.”
\v 41 Mgbe o kwuchara nke a, ọ gbasara ha.
\c 20
\s1 Pọl agaa obodo Masidonia na Griis
\p 
\v 1 Mgbe ọgbaaghara ndị a kwụsịrị, Pọl kpọkwara ndị na-eso ụzọ ahụ, gbaa ha ume, gwa ha ka ha nọdụ nke ọma, ọ pụrụ gawa Masidonia.
\v 2 Mgbe ọ gagharịchara nʼakụkụ ala ahụ niile, werekwa okwu nkasiobi gbaa ndị ụmụnna ume, ọ bịaruru ala Griis.
\v 3 Ọ nọrọ ọnwa atọ nʼebe ahụ. Mgbe ọ chọpụtara na ndị Juu agbaala ajọ izu megide ya dịka ọ na-ejikere iso ụgbọ mmiri gaa Siria, o kpebiri ka ya si ụzọ Masidonia laghachi.
\v 4 Sopata onye Boria bụ ọkpara Pirọs, na Arịstakọs, na Sekundus ndị si na Tesalonaịka, na Gaiọs onye Debi na Timoti, na Taịkikọs na Trofimọs, ndị Eshịa sokwa ya na-aga ije a.
\v 5 Ndị a bu ụzọ gawa, na-eche anyị na Troas.
\v 6 Mgbe Mmemme Ngabiga ahụ gwụsịrị, anyị banyere ụgbọ mmiri rute Filipai bịakwute ha na Troas nʼụbọchị nke ise. Anyị nọrọ nʼebe ahụ ụbọchị asaa.
\s1 Mkpọlite Yutikọs site nʼọnwụ nʼobodo Troas
\p 
\v 7 Nʼụbọchị mbụ nʼizu ụka, mgbe anyị zukọrọ ịnyawa achịcha, Pọl gwara ha okwu, ebe ọ na-akwado ịla ma chi bọọ, o kwugidere okwu ruo nʼetiti abalị.
\v 8 Ọtụtụ oriọna dịkwa nʼime ọnụụlọ ahụ dị nʼụlọ elu ebe anyị zukọrọ.
\v 9 Otu nwokorobịa a na-akpọ Yutikọs nọdụrụ ala nʼoghereikuku, ọ bụ onye oke ụra bidoro ịtụ dịka Pọl na-ekwu okwu ruo oge dị anya. Mgbe ọ dara nʼoke ụra a, o sitere na nʼụlọ elu nke atọ dapụ, daa nʼala. Mgbe e buliri ya, ọ bụ onye nwụrụ anwụ.
\v 10 Pọl rituru nʼala selite ya elu jikụọ ya. Ọ sịrị ndị gbakọrọ nʼebe ahụ sị, “Ka obi hapụ ịlọ unu mmiri ọ dị ndụ.”
\v 11 Ọ laghachikwara nʼụlọ elu ahụ, mgbe ọ nyawachara achịcha ma riekwa, o kwugidere okwu tutu chi abọọ, ọ hapụrụ ha bilie ije ya.
\v 12 Ha kulitere nwokorobịa ahụ na ndụ nke mere ka ọṅụ jupụta ha nʼobi. Ọ gbakwara ha ume nke ukwuu.
\s1 Ekele ikpeazụ nke Pọl nye ndị okenye Efesọs
\p 
\v 13 Anyị onwe anyị gara nʼihu banye nʼụgbọ mmiri chee ihu ịga Asọs. Ebe anyị zubere iburu Pọl nʼụgbọ anyị. O soghị anyị nʼihi na o zubere iji ụkwụ ruo ebe ahụ.
\v 14 Mgbe o zutere anyị nʼAsọs, anyị buru ya nʼụgbọ gaa Mitilen.
\v 15 Nʼụbọchị nke ọzọ ya, anyị rutere Kiọs, nʼụbọchị nke so ya, anyị gafere rute Samọs. Ma mgbe otu ụbọchị ọzọ gasịrị, anyị rutere Melitọs.
\v 16 Nʼoge a, Pọl kpebiri na ọ gaghị akwụsị nʼEfesọs ka ọ ghara itufu oge nʼEshịa, nʼihi na ọ na-eme ngwangwa irute Jerusalem nʼụbọchị mmemme Pentikọọsụ, ma ọ bụrụ ihe ọ pụrụ ime.
\p 
\v 17 Site na Melitọs, ọ zipụrụ ozi ka a kpọọrọ ya ndị okenye chọọchị nke Efesọs ka ha bịa zute ya.
\v 18 Oge ha bịakwutere ya, ọ gwara ha, “Unu maara nke ọma otu m si nọ nʼetiti unu mgbe niile mụ na unu nọrọ, site nʼụbọchị mbụ ụkwụ m zọkwasịrị nʼala Eshịa tutu ruo ugbu a.
\v 19 Arụrụ m ọrụ Onyenwe anyị site nʼobi umeala na anya mmiri nʼetiti ntaramahụhụ dị ukwuu, site nʼizu ọjọọ ndị Juu gbara maka m.
\v 20 Unu hụrụ na m ahapụghị ime ka unu mara ihe ọbụla ga-abara unu uru, mgbe ọbụla m na-akụziri unu ihe nʼụlọ maọbụ nʼihu ọha.
\v 21 E kwusaala m nye ma ndị Juu ma ndị Griik okwu nchegharị nʼebe Chineke nọ, na okwukwe nʼebe Onyenwe anyị Jisọs nọ.
\p 
\v 22 “Ma otu ọ dị, ana m aga Jerusalem dịka iwu Mmụọ Nsọ nyere m si dị, ma amaghị m ihe ọnọdụ m ga-abụ nʼebe ahụ.
\v 23 Karịakwa na Mmụọ Nsọ na-agbara m ama nʼebe ọbụla na mkpọrọ na ntaramahụhụ na-eche m nʼebe ahụ.
\v 24 Ma akpọghị m ndụ m ihe ọbụla. Karịa naanị ka m gbazuo ọsọ m ma jezuokwa ozi ahụ m natara nʼaka Onyenwe anyị Jisọs, nke bụ ịkọwa banyere oziọma nke amara Chineke.
\p 
\v 25 “Ma ugbu a, amaara m na o nweghị onye ọbụla nʼime unu, bụ ndị m jegharịrị nʼetiti ha na-ezisara ihe banyere alaeze a ga-ahụ m anya ọzọ.
\v 26 Ya mere, ana m agwasị unu ike, taa, na abụ m onye aka ya dị ọcha nʼebe ọbara onye ọbụla nʼime unu dị.
\v 27 Nʼihi na-esepụghị m aka ikwupụta nzọpụta Chineke nye unu.
\v 28 Ma ugbu a, kpacharanụ anya! Leziekwanụ onwe unu na igwe atụrụ nke Mmụọ Nsọ mere unu ndị nlekọta anya ya. Ka unu bụrụ ndị ọzụzụ atụrụ nke chọọchị Chineke, bụ nke o ji ọbara ya zụtara onwe ya.
\v 29 Nʼihi na amaara m na mgbe m lachara, agụ jọgburu onwe ya ga-abata nʼetiti unu nke na-agaghị emere igwe atụrụ ebere.
\v 30 Ụfọdụ nʼime unu ga-ebili tụgharịa eziokwu ahụ ịhụ ka ha si otu a dọrọ ụfọdụ ndị na-eso ụzọ ahụ nye onwe ha.
\v 31 Ya mere, na-echenụ nche! Chetakwanụ na nʼime afọ atọ m nọrọ nʼetiti unu, ehihie na abalị, eji m ịkwa akwa na anya mmiri na-adụ unu ọdụ.
\p 
\v 32 “Ugbu a ana m etife unu nʼaka Chineke na nlekọta ya. Ana m etifekwa unu nʼaka okwu amara ya nke pụrụ ịgba okwukwe unu ume na inyekwa unu akụnụba ọ kwadobeere ndị ahụ e doro nsọ.
\v 33 Ọ dịghị mgbe ọbụla agụụ ịdọtara onwe m ọlaọcha maọbụ ọlaedo maọbụ uwe nke onye ọbụla ji gụọ m.
\v 34 Ọ bakwaghị uru ịgwa unu na ọ bụ aka m rụpụtara ọrụ gbooro m mkpa niile, na nke gbokwara mkpa ndị ahụ mụ na ha so.
\v 35 Nʼihe niile, abụkwa m ihe ilere anya nye unu banyere inyere ndị ogbenye aka, site nʼịrụ ọrụ nʼụzọ dị otu a, na-echetara m okwu nke Onyenwe anyị Jisọs kwuru sị, \wj ‘Ngọzị karịrị dị nʼinye enye karịa ịnara anara.’ ”\wj*
\p 
\v 36 Mgbe o kwusiri okwu ndị a, o soro ha niile gbuo ikpere nʼala kpekwa ekpere.
\v 37 Ha bere akwa nke ukwuu, makụọ Pọl, sutukwa ya ọnụ.
\v 38 O wutere ha karịa na o kwuru na ha agaghị ahụ ya anya ọzọ. Emesịa, ha duru ya ruo ebe ọ banyere ụgbọ mmiri.
\c 21
\s1 Pọl agaa Jerusalem
\p 
\v 1 Mgbe anyị hapụsịrị ha, anyị nyapụrụ ụgbọ anyị bịaruo Kos. Nʼechi ya, anyị rutere Rods. Anyị sitere nʼebe ahụ jeruo Patara.
\v 2 Mgbe anyị hụrụ ụgbọ mmiri na-aga Fonisia, anyị banyere nʼime ya kwọpụ.
\v 3 Mgbe anyị kwọruru ụgbọ anyị ebe anyị nwere ike ịhụ Saiprọs, anyị siri nʼaka ekpe ya gafee, ruo Siria. Anyị rutere nʼọnụ mmiri Taịa, ebe ụgbọ mmiri ga-akwapụ ibu dị nʼime ya.
\v 4 Mgbe anyị chọtara ndị na-eso ụzọ ahụ, anyị nọnyere ha abalị asaa. Ha gwara Pọl site nʼike nke Mmụọ Nsọ, ka ọ ghara ịga Jerusalem.
\v 5 Mgbe anyị nọzuru ụbọchị anyị, anyị hapụrụ ha, bilie ije. Ha na nwunye ha na ụmụ ha so dupu ruo mgbe anyị si nʼobodo ahụ pụọ. Anyị na ha gburu ikpere nʼala nʼọnụ mmiri kpee ekpere.
\v 6 Mgbe ahụ, anyị kelere onwe anyị ekele ikpeazụ. Emesịa, anyị banyere nʼime ụgbọ, ma ha laghachiri azụ nʼụlọ ha.
\p 
\v 7 Mgbe anyị hapụrụ Taịa, anyị kwụsịrị na Tolomas. Nʼebe a anyị kelekwara ndị kwere ekwe nọ nʼime obodo a, nọnyere ha naanị otu ụbọchị.
\v 8 Nʼụbọchị nke ọzọ ya, anyị gara nʼihu nʼije anyị rute Sizaria. Nʼebe ahụ, anyị nọnyeere otu nwanna anyị a na-akpọ Filip onye na-agbasa oziọma. Ọ bụ otu nʼime mmadụ asaa ahụ.
\v 9 O nwere ụmụ agbọghọ anọ ndị na-alụbeghị di. Ha nwekwara onyinye ibu amụma.
\p 
\v 10 Mgbe anyị nọrọ ọtụtụ ụbọchị nʼebe ahụ, ka otu onye amụma a na-akpọ Agabọs, si Judịa bata.
\v 11 Ọ bịakwutere anyị, chilite belịt Pọl na-eke nʼukwu, kee onwe ya nʼụkwụ na aka sị, “Dịka Mmụọ Nsọ kwuru, ‘otu a ka ndị ndu ndị Juu ga-eke onye nwe ihe a agbụ na Jerusalem. Ha ga-ararakwa ya nye nʼaka ndị mba ọzọ.’ ”
\p 
\v 12 Mgbe anyị nụrụ nke a, anyị na ndị niile nọ nʼebe ahụ rịọrọ Pọl ka ọ ghara ịga Jerusalem.
\v 13 Ma Pọl zaghachiri, “Gịnị ka unu na-eme, ọ bụ akwa ka unu na-ebe, na-eme ka obi gbawaa m? Nʼihi na ọ bụghị naanị na m dị njikere ka e kee m agbụ, kama ejikekwara m iwere ndụ m nye na Jerusalem nʼihi aha Onyenwe anyị Jisọs.”
\v 14 Ebe ọ na-ekweghị ege anyị ntị, anyị kwụsịrị ma sị, “Ka e mee uche Onyenwe anyị.”
\p 
\v 15 Mgbe ụbọchị ndị a gasịrị, anyị jikere bilie ịga Jerusalem.
\v 16 Ụfọdụ ndị na-eso ụzọ ahụ ndị nọ na Sizaria, duuru anyị gaa, ha kpọruru anyị nʼụlọ Mnasin, onye Saiprọs ebe anyị ga-anọ dịka ọbịa, onye sitere na mbụ bụrụ onye na-eso ụzọ ahụ.
\s1 Pọl erute Jerusalem
\p 
\v 17 Mgbe anyị rutere Jerusalem, ndị ụmụnna jiri obi ụtọ nabata anyị.
\v 18 Nʼụbọchị nke so ya, anyị na Pọl gara ileta Jemis, ndị okenye niile nọkwa nʼebe ahụ.
\v 19 Mgbe o kelechara ha, ọ kọọrọ ha nʼotu nʼotu, ihe niile Chineke rụrụ nʼetiti ndị mba ọzọ site nʼije ozi ya.
\p 
\v 20 Mgbe ha nụchara nke a, ha nyere Chineke otuto. Emesịa, ha sịrị Pọl, “Leenụ nwanna, otu ọtụtụ puku ndị Juu si bụrụ ndị kwere ekwe, ha niile ka ihe banyere iwu a na-anụ ọkụ nʼobi.
\v 21 A kọọrọla ha ihe banyere gị, na ị na-ezi ndị Juu bi nʼetiti ndị mba ọzọ ka ha hapụ ịgbasokwa iwu Mosis, na ka ha kwụsịkwa ibi ụmụ ha ugwu maọbụ bie ndụ nʼusoro omenaala anyị.
\v 22 Gịnị ka anyị ga-eme ugbu a? O doro anya na ha ga-amata na ị bịara nʼebe a.
\v 23 Ya bụ, jisie ike mee ihe anyị ga-agwa gị ugbu a. Anyị nwere mmadụ anọ nʼebe a, ndị nọ na nkwa ha kwere Chineke.
\v 24 Soro ha mee omenaala ahụ nke ndị nọ na nkwa ji edo onwe ha ọcha. Kwụọrọ ha ụgwọ maka ịkpụcha isi ha. I mee otu a, mmadụ niile ga-amata na eziokwu adịghị nʼihe ndị a niile e kwuru maka gị, kama na gị onwe gị na-agazi ma na-edebekwa iwu.
\v 25 Ma nʼebe ndị mba ọzọ kwere ekwe nọ, anyị edegarala ha akwụkwọ gwa ha kwụsị iri ihe ọbụla a chụrụ nʼaja nye arụsị, na iri ọbara, maọbụ anụ a nyagburu anyagbu, ya na ịkwa iko.”
\p 
\v 26 Pọl kpọọrọ ndị ikom anọ ndị ahụ tinyere onwe ya, nʼụbọchị so ya mee ka ya na ha dị ọcha. Mgbe ahụ, ọ banyere nʼụlọnsọ ukwu ahụ, maka ikwupụta ụbọchị ole mmemme ịdị ọcha ahụ ga-anọ tupu e mechaa ya, nakwa mgbe ịchụ aja nʼihi ha nʼotu nʼotu ga-abụ.
\s1 Njide e jidere Pọl
\p 
\v 27 Ma mgbe ọ fọdụrụ nwa oge nta ka ụbọchị asaa ahụ gwụchaa, ụfọdụ ndị Juu si Eshịa bịa hụrụ ya nʼụlọnsọ ukwu ahụ. Ha tikuru igwe mmadụ ma kpaliekwa ha. Ha jidere ya,
\v 28 na-eti mkpu, “Ndị ikom Izrel, nyerenụ anyị aka! Onye a bụ nwoke ahụ na-ejegharị nʼebe niile na-ezi ozizi megidere ndị nke anyị, iwu anyị nakwa ebe a. Ma nke kachasị nke, ọ merụọkwala ụlọnsọ a site nʼịkpọbata ndị Griik nʼime ya.”
\v 29 (Nʼihi na ha ebula ụzọ hụ ya na Trofimọs onye Efesọs nʼime obodo, ha chere na Pọl kpọbatara ya nʼụlọnsọ ukwu ahụ.)
\p 
\v 30 Ọgbaaghara jupụtara nʼobodo ahụ niile. Ndị mmadụ gbakọtara dọkpụpụta Pọl site nʼụlọnsọ ukwu ahụ. Nʼotu mgbe ahụ, e mechiri ọnụ ụzọ niile.
\v 31 Mgbe ha na-achọ igbu ya, ozi ruru ọchịagha ntị na Jerusalem niile nọ nʼọgbaaghara.
\v 32 Otu mgbe ahụ o duuru ụfọdụ ndịisi agha ya na ndị agha ya mee ngwangwa bịaruo nʼebe ha nọ. Mgbe ha hụrụ ndị agha ka ha na-abịa, ha kwụsịrị iti Pọl ihe.
\p 
\v 33 Ọchịagha ahụ bịara jide ya, nye iwu ka e were ụdọ igwe abụọ kee ya agbụ, ọ jụkwara onye ọ bụ na ihe o mere.
\v 34 Ụfọdụ nʼime igwe mmadụ ahụ na-eti mkpu na-ekwu otu ihe, ebe ụfọdụ na-eti na-ekwu ihe ọzọ. Mgbe ọ na-apụghị ịchọpụta ihe bụ isi mkpọtụ na ọgbaaghara ahụ, o nyere iwu ka e duru ya gaa nʼogige ndị agha.
\v 35 Mgbe o rutere na mgbagolite ọnụ ụzọ ụlọ ahụ, ndị agha bulitere ya elu nʼihi ọgbaaghara igwe ndị mmadụ dị ukwuu.
\v 36 Igwe mmadụ ahụ so ha nọ na-eti mkpu, “Wepụnụ ya! Wepụnụ ya!”
\s1 Pọl agọrọ onwe ya
\p 
\v 37 Mgbe ha chọrọ iduba Pọl nʼime ogige ahụ, ọ sịrị ọchịagha ahụ, “Ị ga-ekwe ka m gwa gị okwu?”
\p Ọ sịrị, “I maara asụ asụsụ ndị Griik?
\v 38 Ọ pụtara na ị bụghị onye Ijipt ahụ malitere ọgbaaghara ma duuru puku ndị ogbu mmadụ anọ gbalaa nʼọzara?”
\p 
\v 39 Pọl sịrị, “Abụ m onye Juu si Tasọs, obodo dị na Silisia, nwa afọ oke obodo amara aha ya. Biko, kwee ka m gwa ndị mmadụ okwu.”
\p 
\v 40 Mgbe o nyere ya ikike, Pọl guzooro nʼihe nrigo nke ọnụ ụzọ ahụ fee aka ya ime ka ha nọọ duu. Mgbe ha nọdụrụ nwayọọ, ọ gwara ha okwu nʼasụsụ Hibru\f + \fr 21:40 \ft Maọbụ, \fqa Aramaik\f* sị,
\c 22
\nb 
\v 1 “Ụmụnna m na ndị nna anyị, geenụ m ntị mgbe m na-agọrọ onwe m nʼihu unu.”
\p 
\v 2 Mgbe ha nụrụ na ọ na-agwa ha okwu nʼasụsụ Hibru, ha deere duu karịa.
\p Mgbe ọ sịrị,
\v 3 “Abụ m onye Juu. Amụrụ m na Tasọs nʼime Silisia. Azụrụ m na obodo a nʼụkwụ Gamaliel onye nkuzi m. Anatara m ọzụzụ dị ike na ịsọpụrụ iwu nke nna nna anyị ha ejikwa m ịnụ ọkụ nʼobi na-efe Chineke dịka unu niile si eme taa.
\v 4 Akpagburu m ndị niile na-eso ụzọ ọhụrụ a, na-etinye ha nʼaka ọnwụ. Ejidere m ndị ikom na ndị inyom ha tụbakwa ha nʼụlọ mkpọrọ.
\v 5 Ma dịka onyeisi nchụaja na nzukọ ndị okenye niile pụrụ ịgbara m akaebe. Anatakwara m nʼaka ha akwụkwọ ozi e deere ụmụnna anyị nọ na Damaskọs. Agara m ebe ahụ ịkpụta ha nʼagbụ bịa Jerusalem maka ịta ha ahụhụ.
\s1 Akụkọ nchegharị Pọl
\p 
\v 6 “Nʼetiti ehihie, mgbe m na-aga nʼụzọ, nʼebe dị Damaskọs nso, oke ìhè nke si nʼeluigwe, chara gburugburu m.
\v 7 Adara m nʼala ma nụkwa olu gwara m okwu sị m, \wj ‘Sọl, Sọl, gịnị mere i ji na-akpagbu m?’\wj*
\p 
\v 8 “ ‘Onye ka ị bụ Onyenwe m?’ Ka m jụrụ.
\p “Ọ sịrị m, \wj ‘Abụ m Jisọs onye Nazaret onye ị na-akpagbu.’\wj*
\v 9 Ndị mụ na ha so hụkwara ìhè ahụ, ma ha anụghị olu onye ahụ na-agwa m okwu.
\p 
\v 10 “Asịrị m, ‘Gịnị ka m ga-eme Onyenwe anyị?’
\p “Onyenwe anyị sịrị m, \wj ‘Bilie banye Damaskọs; nʼebe ahụ a ga-agwa gị ihe niile a kwadobere na ị ga-eme.’\wj*
\v 11 Nʼihi na-enweghị m ike ịhụ ụzọ nʼihi ebube ìhè ahụ chachiri m anya. Ya mere ndị mụ na ha so sekpụụrụ m nʼaka bata na Damaskọs.
\p 
\v 12 “Nʼebe ahụ ka Ananayas bi, bụ onye anyị pụrụ ịgụ nʼonye ezi omume nʼihi idebe iwu. O nwekwara ọgbụgba ama dị mma site nʼọnụ ndị Juu bi nʼebe ahụ.
\v 13 Ọ bịakwutere m, guzoro nʼakụkụ m sị, ‘Nwanna anyị Sọl, ka emee ka ị hụ ụzọ!’ Otu mgbe ahụ, e nwetara m ike ịhụ ụzọ, m hụkwara ya.
\p 
\v 14 “Mgbe ahụ, ọ sịrị, ‘Chineke nke nna nna anyị ha ahọpụtala gị ịmara uche ya na ịhụ Onye Ezi Omume ahụ na ịnụta okwu site nʼọnụ ya.
\v 15 Ị ga-abụ onyeama ya nye ndị niile banyere ihe ị hụrụ na ihe ị nụrụ.
\v 16 Ma ugbu a, gịnị ka ị na-eche? Bilie ọtọ, ka e mee gị baptizim, ka a sachakwa gị site na mmehie, na-akpọkukwa aha ya.’
\s1 Pọl onyeozi nye ndị mba ọzọ
\p 
\v 17 “Mgbe m lọghachikwara na Jerusalem, nọrọ na-ekpe ekpere nʼụlọnsọ ukwu ahụ, ahụrụ m ọhụ,
\v 18 ebe ọ na-agwa m, \wj ‘Mee ngwa! Hapụ Jerusalem, nʼihi na ndị bi nʼala a agaghị anara ọgbụgba ama gị banyere m.’\wj*
\p 
\v 19 “Ma asịrị m, ‘Onyenwe anyị, ndị a maara nke ọma na m na-aga nʼụlọ nzukọ nʼotu nʼotu, na-atụba ndị kwere na gị nʼụlọ mkpọrọ, na-etikwa ha ihe.
\v 20 Nʼoge a na-awụfu ọbara onyeama gị bụ Stivin, eguzo m nso na-akwado nʼihe emere dị mma, ma na-elekọtakwa uwe ndị ahụ tụgburu ya anya.’
\p 
\v 21 “Mgbe ahụ, ọ sịrị m, \wj ‘Gawa; nʼihi na aga m ezipu gị ebe dị anya ijekwuru ndị mba ọzọ.’\wj* ”
\s1 Pọl onye Rom
\p 
\v 22 Ha ṅara ya ntị ruo ugbu a. Mgbe ahụ, ha niile tiri mkpu nʼotu olu sị, “Wepụnụ onye dị otu a nʼụwa! O kwesighị ka onye dị otu a dịrị ndụ!”
\p 
\v 23 Ha tiri mkpu na-atụli uwe mgbokwasị ha elu, na-achilikwa aja nʼala na-efesasị ya ebe niile,
\v 24 ọchịagha ahụ nyere iwu ka a kpụgaa ya nʼogige ndị agha, pịa ya ụtarị, ka eziokwu pụta ya nʼọnụ. Ọ chọrọ ịmata ihe mere ha ji eti mkpu otu a megide ya.
\v 25 Ma mgbe ha chịịrị ụdọ akpụkpọ kechaa ya, Pọl sịrị onye agha guzo ya nso, “Ọ bụ ihe ziri ezi nʼiwu na unu ga-eti nwa afọ Rom ihe, onye na-enweghị ikpe a mara ya?”
\p 
\v 26 Mgbe onye agha a nụrụ okwu a, o jekwuuru ọchịagha ahụ sị, “Gịnị ka ị na-aga ime? Nwoke a bụkwa onye Rom.”
\p 
\v 27 Ọchịagha ahụ bịakwutere sị ya, “Gwa m, ị bụ onye Rom?”
\p Ọ sịrị, “E.”
\p 
\v 28 Ọchịagha ahụ zara, “ma o furu m ego dị ukwuu iji bụrụ onye Rom.”
\p Ma Pọl sịrị, “Amụrụ m dịka nwa afọ ala a.”
\p 
\v 29 Ndị ahụ chọrọ ịgba ya ajụjụ ọnụ mere ngwangwa wezuga onwe ha. Egwu tụkwara ọchịagha nʼonwe ya mgbe ọ matara na ọ bụ nwa afọ Rom, nʼihi na o keela ya rịị agbụ na mbụ.
\s1 Pọl nʼihu ndị ikpe
\p 
\v 30 Nʼechi ya, ebe ọ chọrọ ịmata ihe bụ isi okwu na ihe mere ndị Juu ji ebo ya ebubo, o nyere iwu ka ndịisi nchụaja na ndị ụlọ ikpe ha zukọọ. Mgbe ahụ, o dupụtara Pọl, mee ka o guzo nʼihu ha.
\c 23
\s1 Pọl nʼihu nzukọ ndị Juu
\p 
\v 1 Mgbe Pọl legidere ndị nzukọ a anya, ọ sịrị, “Ụmụnna m, mụ onwe m ejirila ezi akọnuche bie ndụ m niile nʼihu Chineke ruokwa ụbọchị taa.”
\v 2 Nke a mere, Ananayas onyeisi nchụaja nyere iwu ka ndị nọ ya nso tie ya aka nʼọnụ.
\v 3 Ma Pọl, sịrị ya, “Otu a ka Chineke ga-esi tie gị, gị mgbidi e tere nzu. Ụdị onye ikpe dị aṅaa ka ị bụ i ji na-emebi iwu nʼonwe gị site nʼinye iwu ka e si otu a tie m ihe?”
\p 
\v 4 Ndị guzo ya nso sịrị, “Ị na-ekwutọ onyeisi nchụaja Chineke?”
\p 
\v 5 Ma Pọl sịrị, “Aghọtaghị m, ụmụnna m na ọ bụ onyeisi nchụaja. Nʼihi na akwụkwọ nsọ kwuru sị, ‘Ekwula okwu ọjọọ ọbụla megide onye na-achị ndị nke gị.’\f + \fr 23:5 \ft \xt Ọpụ 22:28\xt*\f*”
\p 
\v 6 Mgbe Pọl chọpụtara na otu ụzọ nʼime nzukọ ahụ bụ ndị otu Sadusii, ebe ndị ọzọ bụkwa ndị Farisii, o tiri mkpu nʼime nnọkọ ahụ sị, “Ụmụnna m, abụ m onye Farisii na nwa ndị Farisii. A na-ekpe m ikpe taa nʼihi olileanya m nwere na mbilite nʼọnwụ nke ndị nwụrụ anwụ.”
\v 7 Mgbe o kwusiri nke a esemokwu dapụtara nʼetiti ndị Farisii na ndị Sadusii. Ọgbakọ ahụ kewara.
\v 8 Nʼihi na ndị Sadusii na-asị na mbilite nʼọnwụ maọbụ mmụọ ozi maọbụ mmụọ ọbụla adịghị. Ma ndị Farisii kweere nʼihe ndị a niile.
\p 
\v 9 Mkpọtụ malitere na-ada ike ike. Ụfọdụ ndị ozizi iwu so nʼotu ndị Farisii biliri ọtọ malite ịrụ ụka nʼoke olu sị, “Anyị ahụghị ihe ọjọọ nʼebe nwoke a nọ, ma gịnịkwa ma ọ bụrụ na ọ bụ mmụọ, maọbụ mmụọ ozi gwara ya okwu?”
\v 10 Esemokwu a bịara karịa, nke mere na onyeisi ọchịagha tụrụ egwu na ha ga-adọkasị Pọl. Ọ gwara ndị agha ya ka ha banye were ike kpọpụta ya, ziga ya nʼogige ndị agha.
\p 
\v 11 Nʼabalị ya, Onyenwe anyị bịakwutere ya sị, \wj “Nwee obi ike, dịka i si gbaa ama banyere m na Jerusalem, ị ghaghị ịgbakwara m ama na Rom.”\wj*
\s1 Izuzu igbu Pọl
\p 
\v 12 Nʼụtụtụ echi ya ụfọdụ ndị Juu zukọtara gbaa izu, ṅụọkwa iyi na ha agaghị eri nri maọbụ ṅụọ ihe ọbụla tutu ruo mgbe ha gburu Pọl.
\v 13 Ndị zukọtara gbaa izu ọjọọ a karịrị iri mmadụ anọ.
\v 14 Ha jekwuuru ndịisi nchụaja ha na ndị okenye, sị ha, “Anyị kwekọtara ịhapụ iri maọbụ ịṅụ ihe ọbụla tutu ruo mgbe anyị gburu Pọl.
\v 15 Ugbu a, unu na nzukọ zienụ onyeisi ọchịagha ka ọ kpọpụtara unu ya. Meenụ ka unu na-achọ ịjụpụtasị eziokwu nʼọnụ ya nakwa itule ikpe ya nke ọma. Anyị dị njikere igbu ya nʼụzọ tupu ọ bịaruo unu nso.”
\p 
\v 16 Ma nwa nwanne nwanyị Pọl nụrụ maka izuzu ọjọọ a. Ọ banyere nʼogige ndị agha kọọrọ Pọl.
\p 
\v 17 Pọl kpọrọ otu nʼime ndịisi agha ahụ gwa ya, “Biko kpọrọ nwokorobịa a gaa nʼebe ọchịagha nọ, o nwere okwu dị mkpa ọ chọrọ ịgwa ya.”
\v 18 Ọ kpọọrọ ya jekwuru onyeisi agha, sị.
\p “Pọl, onye mkpọrọ, kpọrọ m rịọ m ka m kpọtara gị nwokorobịa a nʼihi na o nwere ihe ọ chọrọ ịgwa gị.”
\p 
\v 19 Onyeisi agha ahụ duuru ya nʼaka ya gaa nʼakụkụ ọzọ jụọ ya, “Gịnị bụ ihe ị chọrọ ịkọrọ m?”
\p 
\v 20 Ọ sịrị, “Ndị Juu ụfọdụ ekwekọrịtala ịrịọ gị ka ị kpọpụta Pọl echi na nzukọ ụlọ ikpe. Ha ga-eme dịka ha nwere ihe dị mkpa ha chọrọ ịjụta ya.
\v 21 Ma aṅala ha ntị. Nʼihi na ihe karịrị iri mmadụ anọ na-ezo onwe ha na-eche inwude ya. Ndị a gbara ndụ na ha agaghị eri maọbụ ṅụọ ihe ọbụla tutu ruo mgbe ha gburu ya. Ha adịla njikere, ihe a na-eche bụ mkpebi gị nye arịrịọ ha.”
\p 
\v 22 Ọchịagha ahụ zilagara nwokorobịa ahụ site nʼinye ya iwu, “Emekwala ka onye ọbụla mata na ị bịara gwa m ihe dị otu a.”
\s1 Pọl agaa Sizaria
\p 
\v 23 Mgbe e mesịrị, ọ kpọrọ mmadụ abụọ nʼime ndịisi agha nye ha iwu sị, “Gaanụ jikere narị ndị agha abụọ, na iri mmadụ asaa ndị na-agba ịnyịnya, tinyere narị ndị ikom abụọ ndị na-ama ùbe, ndị ga-aga Sizaria nʼelekere itoolu nke abalị a.
\v 24 Nyekwa Pọl ịnyịnya nke ọ ga-agba, ka e nwee ike duru ya gakwuru Feliks bụ gọvanọ nʼudo.”
\p 
\v 25 O dere akwụkwọ nʼolu dị otu a:
\pmo 
\v 26 Klọdiọs Lisias,
\pmo Na-edegara Feliks onye nsọpụrụ na-adịrị, onye na-achị akụkụ a.
\pmo Ana m ekele gị.
\pm 
\v 27 Ndị Juu jidere nwoke a chọọ igbu ya, ma mgbe m nụrụ na ọ bụ onye Rom, mụ na ndị agha m bịara napụta ya nʼaka ha.
\v 28 Achọrọ m ịmata ihe mere ha ji ebo ya ebubo, nʼihi ya eduuru m ya gaa nʼọgbakọ ndị okenye ha.
\v 29 Ma achọpụtara m na ọ bụ ihe banyere iwu ha. Nʼeziokwu, o nweghị ihe ọbụla kwesiri iji tụọ ya mkpọrọ maọbụ ọnwụ nʼime ebubo ahụ.
\v 30 Mgbe a gwara m banyere izuzu a na-agba megide nwoke a, ezitere m gị ya nʼegbughị oge. Enyekwara m ndị niile na-ebo ya ebubo iwu, ka ha bịa nʼihu gị kpee ọnụ ha.
\p 
\v 31 Ya mere, nʼabalị ahụ, ndị agha dubatara Pọl na Antipatris dịka e nyere ha nʼiwu.
\v 32 Nʼechi ya, ha hapụrụ ya na ndị na-agba nʼelu ịnyịnya ka ha duru ya gawa, ebe ha laghachiri nʼogige ndị agha.
\v 33 Mgbe ha bịarutere Sizaria, ha nyere onyeisi obodo ahụ akwụkwọ ozi, ma kpọnyekwa ya Pọl.
\v 34 Gọvanọ ahụ gụrụ akwụkwọ ozi ahụ, jụọ ya akụkụ ala o si pụta. Mgbe ọ matara na ọ bụ onye Silisia,
\v 35 ọ sịrị ya, “Aga m enye okwu gị ezigbo ohere mgbe ndị na-ebo gị ebubo bịara.” O nyekwara iwu ka e debe ya nʼobi Herọd nʼaka ndị nche.
\c 24
\s1 Ebubo ndị Juu boro Pọl nʼihu Feliks
\p 
\v 1 Mgbe ụbọchị ise gasịrị, onyeisi nchụaja bụ Ananayas na ụfọdụ ndị okenye ndị Juu na lọya ha aha ya bụ Tatulọs bịara. Ha dum pụtara ịgbagide Pọl ama nʼihu onye na-achị obodo.
\v 2 Mgbe a kpọbatara ya, Tatulọs pụtara guzo boo ya ebubo sị, “Onye a na-asọpụrụ ka ị bụ. Nʼihi gị, mmadụ niile enwela udo ogologo mgbe. Ịdị nkọ nke uche gị emeela ka mgbanwe dị nʼobodo a.
\v 3 Anyị ji ekele nke jupụtara nʼọṅụ na-anabata ihe ndị a nke ọma, nʼebe niile na nʼụzọ niile, gị Feliks, onye a na-asọpụrụ.
\v 4 Achọghị m itufu oge gị. Ana m arịọ ka i were ndidi na obiọma nụrụ nkenke okwu anyị ji bịa.
\p 
\v 5 “Anyị chọpụtara na nwoke a bụ onye na-akpalikarị ọgbaaghara, onye ọrụ ya bụ ịkwagide ndị Juu nọ nʼebe niile nʼụwa a ka ha nupu isi. Ọ bụkwa onyeisi nke ajọ otu ahụ a na-akpọ Otu ndị Nazaret.
\v 6 Ọ chọkwara imerụ ụlọnsọ anyị, ya mere anyị ji jide ya. Ma anyị chọrọ ikpe ya ikpe dịka omenaala anyị siri dị,
\v 7 ọchịagha Lisias, bịara jiri ike napụ ya nʼaka anyị.\f + \fr 24:7 \ft Ụfọdụ akwụkwọ edebanyeghị amaokwu nke asaa na ụfọdụ okwu dị nʼamaokwu nke asatọ, ebe sịrị na o nyere iwu ka ndị na-ebo ya ebubo pụta nʼihu nʼihu.\f*
\v 8 Ọ bụrụ na inyochaa ya, ị ga-enwe ike ịghọta ihe niile banyere ebubo anyị na-ebo ya.”
\p 
\v 9 Ndị Juu kwadokwara okwu ya, na ihe niile e boro ya, bụ ihe mere eme.
\p 
\v 10 Mgbe gọvanọ feere ya aka ka o kwuo okwu, Pọl zara, “amaara m na ị bụ onye ọkaikpe nke mba a ogologo mgbe. Nke a na-enye m obi ụtọ ịgọpụ onwe m nʼihu gị.
\v 11 Ị pụrụ ịchọpụta na o rubeghị ụbọchị iri na abụọ kemgbe m rigooro nʼụlọnsọ ukwu na Jerusalem ife ofufe.
\v 12 Ha ahụghị m ka mụ na onye ọbụla na-arụrịta ụka nʼụlọnsọ, maọbụ na o nwere ebe m kpatara ọgbaaghara nʼime ụlọ nzukọ, maọbụ ebe ọbụla nʼime obodo.
\v 13 Ha enwekwaghị ihe ọbụla ha ga-eji kwagide ama ha na-agba megide m.
\v 14 Agaghị m agọ agọ nʼihu gị na m na-ekpere Chineke nke nna anyị ha, dịka onye na-eso Ụzọ ahụ ha na-akpọ otu. Ekwenyere m ihe niile dịka usoro nke iwu si dị, na nke e dere nʼakwụkwọ ndị amụma.
\v 15 Ma enwere m olileanya nʼebe Chineke nọ dịka ha onwe ha nwekwara, na mbilite nʼọnwụ nke ndị ezi omume na nke ndị ajọ omume ga-adị.
\v 16 Nʼihi nke a, a na m agbalị inwe akọnuche dị ọcha nʼihu Chineke na nʼihu mmadụ niile.
\p 
\v 17 “Ugbu a, mgbe ọtụtụ afọ gasịrị, abịara m Jerusalem iwetara ndị nke m onyinye, nakwa ịchụrụ Chineke aja.
\v 18 Emezuola m omenaala ịdị ọcha mgbe ha hụrụ m nʼụlọnsọ ukwu ahụ mgbe m na-eme nke a. Ọ dịkwaghị igwe mmadụ so m maọbụ na m sonyere ọgbaaghara ọbụla.
\v 19 Ma enwere ụfọdụ ndị Juu si Eshịa bịa, bụ ndị kwesiri ịnọ nʼebe a ma ọ bụrụ na ha nwere ihe ọbụla megide m.
\v 20 Maọbụ ndị nke nọ nʼebe a ugbu a, ka ha kwuo ajọ omume ọbụla ha hụrụ nʼime m mgbe m guzoro nʼihu ndị nzukọ ndị okenye.
\v 21 Karịa na m kwuru naanị otu ihe mgbe m guzoro nʼihu ha tie mkpu, ‘A na-ekpe m ikpe taa nʼihi okwukwe m na mbilite nʼọnwụ nke ndị nwụrụ anwụ.’ ”
\p 
\v 22 Mgbe ahụ, Feliks onye maara ihe banyere Ụzọ ahụ nke ọma yigharịrị ikpe a. Ọ gwara ha, “Aga m eleba anya nʼikpe gị a, mgbe Lisias onyeisi agha bịara.”
\v 23 O nyere ọchịagha ahụ iwu ka e debe ya nʼokpuru nlekọta ha. Ma ka ha nye ya ohere inwere onwe ya ime ụfọdụ ihe, ka ha kwekwa ka ndị enyi ya bịa nyere ya aka gboo mkpa ya.
\s1 Pọl nʼihu Feliks na nwunye ya
\p 
\v 24 Mgbe ụbọchị ole na ole gasịrị, Feliks na nwunye ya Drusila, bụ onye Juu bịara, ọ kpọrọ Pọl ka ọ gwa ha okwu banyere inwe okwukwe nʼime Jisọs Kraịst.
\v 25 Ma mgbe ọ gara nʼihu na-ekwu ihe banyere ezi omume na mkpa ọ dị mmadụ ijide onwe ya aka, ya na ihe banyere ụbọchị ikpe nke na-abịa nʼoge ikpeazụ, egwu jidere Feliks. Ọ sịrị, “I nwere ike ịpụ ugbu a. Aga m akpọkwa gị nʼoge ọzọ mgbe m nwetara ohere.”
\v 26 Ọ na-atụkwa anya na Pọl ga-enye ya ego. Ya mere o jiri na-eziga ka a na-akpọ ya site nʼoge ruo nʼoge ka ya na ya na-akparịta ụka.
\p 
\v 27 Mgbe afọ abụọ gasịrị, onye a na-akpọ Pọshiọs Festọs nọchiri anya Feliks. Ma ebe ọ chọrọ inweta ihuọma nʼaka ndị Juu, Feliks hapụrụ Pọl nʼụlọ mkpọrọ.
\c 25
\s1 Pọl nʼihu Festọs
\p 
\v 1 Mgbe ụbọchị atọ gasịrị site nʼoge Festọs bịara na mpaghara ọchịchị ya, o sitere Sizaria garuo Jerusalem.
\v 2 Nʼebe ahụ ka ndịisi nchụaja na ndịisi ndị Juu kọwara ya ihe banyere Pọl.
\v 3 Ha rịọkwara ya nʼamara ọ ga-emere ha bụ ime ka Pọl bịa na Jerusalem. Nʼihi na ha agbaala izu igbu ya nʼụzọ.
\v 4 Ma Festọs zara, “Pọl nọ dịka onye mkpọrọ na Sizaria. Ebe ahụ ka mụ onwe m ga-alaghachi na mgbe na-adịghị anya.
\v 5 Ya mere, ka ndịisi unu ji ikike soro m gaa, boo nwoke ahụ ebubo ma ọ bụrụ na o nwere ihe ọjọọ o mere.”
\p 
\v 6 Ọ nọnyeere ha ihe dịka ụbọchị asatọ maọbụ ụbọchị iri, tupu ọ laghachi na Sizaria. Nʼụbọchị so ya, ọ nọdụrụ nʼoche ikpe, nye ikike ka a kpọpụta Pọl.
\v 7 Mgbe ọ bịaruru, ndị Juu sitere Jerusalem bịa gbara ya gburugburu na-ekwu ọtụtụ ihe megide ya nke ha na-enweghị ike ịkọwa.
\p 
\v 8 Ma Pọl gọọrọ onwe ya, na-asị, “Ọ dịghị ihe ọjọọ ọbụla m mere megide iwu ndị Juu maọbụ ụlọnsọ, maọbụ Siza.”
\p 
\v 9 Ma ebe Festọs na-achọ inwe ihuọma nʼebe ndị Juu nọ, ọ sịrị Pọl, “Ị chọrọ ịga Jerusalem ka m kpee gị ikpe nʼebe ahụ?”
\s1 Pọl eburu ikpe gaa nʼihu Siza
\p 
\v 10 Ma Pọl sịrị, “Eguzo m nʼụlọikpe Siza nʼonwe ya, ebe e kwesiri ka a nọdụ kpee m ikpe. Ọ dịghị ihe ọjọọ ọbụla m mere ndị Juu, dịka ị maara nke ọma.
\v 11 Ọ bụrụ na ọ dị ihe m mere kwesiri ọnwụ, anaghị m arịọ ka m gbanarị ọnwụ. Ma ọ bụrụ na ọ dịghị eziokwu dị nʼebubo ndị Juu a na-ebo m, mmadụ ọbụla agaghị e were m nyefee nʼaka ha. Ya mere, ọ bụ Siza ka m na-akpọku.”
\p 
\v 12 Ya mere, mgbe Festọs na ndị na-adụ ya ọdụ gbara izu, ọ zara, “Ị kpọkuola Siza, ọ bụkwa Siza ka ị ga-agakwuru.”
\s1 Festọs na eze Agripa e nwee nzukọ
\p 
\v 13 Mgbe ụbọchị ole na ole gasịrị, eze Agripa na Benaisi bịara Sizaria ịnabata Festọs.
\v 14 Mgbe ha nọrọ ọtụtụ ụbọchị nʼebe ahụ, Festọs kọwara eze a ọnọdụ Pọl sị, “Ọ dị nwoke Feliks hapụrụ nʼụlọ mkpọrọ nʼebe a.
\v 15 Mgbe m gara Jerusalem, ndịisi nchụaja na ndị okenye ndị Juu gwara m banyere ya. Ha rịọkwara ka m maa ya ikpe.
\p 
\v 16 “Ma emere m ka ha ghọta na o megidere iwu ndị Rom ịrara mmadụ ọbụla nye tupu ekpee ya ikpe nyekwa ya ohere ịgọrọ onwe ya nʼihu ndị na-ebo ya ebubo.
\v 17 Nʼihi nke a, mgbe ha bịara nʼebe a, atụfughị m oge ọbụla, kama nʼụbọchị nke ọzọ ya, anọdụrụ m nʼoche ikpe, nye ikike ka a kpọbata nwoke ahụ.
\v 18 Mgbe ndị na-ebo ya ebubo biliri, ọ dịghị otu nʼime ụrụ ala ndị m chere ha ga-akpọ aha nke ha gụpụtara na o mere.
\v 19 Okwu ha niile bụ ịrụ ụka banyere okpukpe ha, na banyere otu onye ọzọ a na-akpọ Jisọs onye nwụrụ, onye Pọl na-ekwusịkwa ike na ọ dị ndụ.
\v 20 Ọ rara m ahụ imedo okwu dị otu a. Nʼihi ya, a jụrụ m ya ma ọ ga-amasị ya ị ga nʼụlọikpe dị na Jerusalem ka ọ nọrọ nʼebe ahụ gọrọ onwe ya.
\v 21 Ma Pọl rịọrọ ka e debe ya nʼụlọ mkpọrọ ruo mgbe Siza nʼonwe ya ga-ekpebi ikpe ya. Ya mere, ezighachiri m ya nʼụlọ mkpọrọ tutu ruo mgbe m jikeere izigara ya Siza.”
\p 
\v 22 Agripa gwara Festọs, “Achọrọ m ịnụ okwu site nʼọnụ nwoke a nʼonwe ya.”
\p Ọ sịrị, “Ị ga-anụ ya echi.”
\s1 Pọl nʼihu Agripa
\p 
\v 23 Ya mere, nʼechi ya, Agripa na Benaisi rutere nʼụlọ ọha na-anọ anụ ikpe nʼoke nganga. Ọtụtụ ndịisi agha na ndị a maara aha ha nʼobodo a sooro ha. Festọs nyere iwu ka a kpọbata Pọl.
\v 24 Festọs sịrị, “Eze Agripa na ndị niile soro anyị nọrọ nʼebe a, unu ahụla nwoke a onye ọha ndị Juu niile, ma ndị nọ nʼebe a ma ndị nọ na Jerusalem, wetara ikpe ya nʼaka m na-eti mkpu na o kwesighị ịdị ndụ ọzọ.
\v 25 Ma achọpụtaghị m ihe ọjọọ o mere nke kwesiri ka ọ nwụọ. Ma ebe ọ rịọrọ ka Siza lenye ikpe ya anya, ekpebiri m iziga ya.
\v 26 Ma enweghị m ihe ọbụla doro anya m ga-edegara Siza banyere ya. Ya mere m jiri kpọpụta ya nʼihu unu niile, ma karịsịa nʼihu gị onwe gị eze Agripa, ka ọ ga-abụ anyị tulesịa ihe banyere ya, ka m nwee ihe m ga-ede.
\v 27 Nʼihi na ọ bụ ihe na-ezighị ezi na m ga-ezipụ onye mkpọrọ na-egosighị nʼebubo e boro ya.”
\c 26
\s1 Pọl agọrọ onwe ya nʼihu Agripa
\p 
\v 1 Agripa gwara Pọl, “Ị nwere ike i kwuru ọnụ gị.”
\p Mgbe ahụ, Pọl gbasara aka ya abụọ bido ikwu okwu ịgọrọ onwe ya,
\v 2 “Ana m agụ onwe m dịka onye nwere ihuọma, eze Agripa, inwe ohere ọma dị otu a, ịzara ọnụ m nʼihu gị nʼihe niile metụtara ebubo ndị Juu na-ebo m.
\v 3 Nke ka nke, amatara m na omenaala ndị Juu na ịrụ ụka metụtara iwu ha doro gị anya. Biko ana m arịọ gị ka i jiri ndidi gee m ntị.
\p 
\v 4 “Ndị Juu niile maara ibi ndụ m site na nwata m. Ha makwa site na mbụ, otu m si bie ndụ m niile nʼobodo nke m, nakwa nʼime Jerusalem.
\v 5 Ha matara kemgbe ogologo oge, ha ga-agbakwa ama, ma ọ bụrụ na ha chọrọ ikwu eziokwu, na site na mbụ e biri m ndụ dịka otu onye so nʼime otu ahụ nke iwu ya dị ike karịchasịa nʼime okpukpe ndị Juu, nke bụ otu ndị Farisii.
\v 6 Ma ugbu a, a na-ekpe m ikpe nʼihi na enwere m olileanya na nkwa ahụ Chineke kwere nna nna anyị ochie ha.
\v 7 Nkwa nke ebo iri na abụọ niile na-ele anya ịnata mgbe ha na-efe ofufe ehihie na abalị. Eze Agripa, ọ bụ nʼihi olileanya a, gị onye a na-asọpụrụ, ka ndị Juu ji na-ebo m ebubo.
\v 8 Gịnị mere unu jiri na-eche na ọ rara Chineke ahụ ime ka ndị nwụrụ anwụ site nʼọnwụ bilie?
\p 
\v 9 “Na mbụ, anara m eche na apụrụ m imeso aha Jisọs onye Nazaret mmeso ọjọọ niile.
\v 10 Otu a ka m mere na Jerusalem. Ọ bụghị naanị na m natara ikike nʼaka ndịisi nchụaja jiri ya kpọchie ọtụtụ ndị nsọ nʼụlọ mkpọrọ, ewelikwara m aka elu nʼoge a na-ama ha ikpe ọnwụ.
\v 11 Ọtụtụ mgbe ka m hụrụ na a tara ha ahụhụ nʼụlọ nzukọ niile. Agbalịrị m ịkwagide ha ka ha kwuo arụ ma kwutọkwa okwukwe ha. Nʼihi na iwe m dị ọkụ megide ha, esogburu m ha nʼobodo dị iche iche nke na-abụghị obodo ndị Juu.
\s1 Pọl ekwuo maka nchegharị ya
\p 
\v 12 “Nʼihi nke a, a gara m Damaskọs site nʼikike na nkwenye nke ndịisi nchụaja. Anatakwara m ike nʼaka ndịisi nchụaja.
\v 13 Nʼoge ehihie, eze Agripa, mgbe mụ na ndị otu m na-aga nʼụzọ, gị onye a na-asọpụrụ, ka m hụrụ ìhè nke na-acha karịa anyanwụ ka o si nʼeluigwe chaa m na ndị mụ na ha so gburugburu.
\v 14 Anyị niile dara nʼala. Ma anụrụ m olu gwara m okwu nʼasụsụ Hibru, \wj ‘Sọl! Sọl! Gịnị mere i ji na-akpagbu m? Ị na-emerụ onwe gị ahụ site nʼịkpọ ụkwụ na ndụdụ e ji achị ehi.’\wj*
\p 
\v 15 “Asịrị m, ‘Ị bụ onye, Onyenwe anyị?’
\p “Onyenwe anyị kwuru, \wj ‘Abụ m Jisọs onye ị na-akpagbu.\wj*
\v 16 \wj Ugbu a, bilie, kwụrụ ọtọ! Nʼihi na-emere m ka ị hụ m anya, ka m họpụta gị ka ị bụrụ onyeozi m na onye akaebe m. Ị ga-emekwa ka ụwa niile mara ihe banyere nzute a i zutere m taa, na ọtụtụ mgbe ọzọ m ga-ezute gị.\wj*
\v 17 \wj Aga m azọpụta gị site nʼaka ndị nke gị na sitekwa nʼaka ndị mba ọzọ, ndị m na-eziga gị ka i jekwuru.\wj*
\v 18 \wj Imeghe anya ha mee ka ha si nʼọchịchịrị lọghachi banye nʼìhè, sikwa nʼike nke ekwensu lọghachikwute Chineke. Ka ha site nʼokwukwe ha nwere nʼebe m nọ nata mgbaghara mmehie ha, ketakwa oke ahụ dị ngọzị nʼetiti ndị e doro nsọ.’\wj*
\p 
\v 19 “Ya mere, eze Agripa, enupughị m isi nʼọhụ nke eluigwe ahụ.
\v 20 Ebidoro m izisa oziọma a na Damaskọs. Emekwara m otu a na Jerusalem na nʼime Judịa niile na nʼetiti ndị mba ọzọ. Ana m ekwusa mkpa ọ dị ka mmadụ niile nwee nchegharị lọghachikwute Chineke. Ka ha gosikwa nchegharị ha site nʼezi ọrụ nke ha na-arụ.
\v 21 Ọ bụ nʼihi nke a ka ndị Juu jiri nwụchie m nʼụlọnsọ ukwu ahụ ma chọsiekwa ụzọ ike ịnapụ m ndụ m.
\v 22 Ma Chineke chebere m mee ka m bụrụ onye dị ndụ taa, ịkọrọ mmadụ niile akụkọ a, ndị ukwu na ndị nta. Ihe m na-ekwu bụkwa ihe ndị amụma na Mosis kwuru na ọ ga-emezu,
\v 23 na Kraịst ahụ ga-ahụ ahụhụ, bụrụkwa onye mbụ ga-esi nʼọnwụ bilie, iwetara ndị Juu na ndị mba ọzọ ìhè.”
\p 
\v 24 Mgbe ọ na-agọpụ onwe ya, Festọs tiri mkpu, “Pọl, ị bụ onye isi mebiri! Oke mmụta gị emebiela gị isi.”
\p 
\v 25 Ma Pọl sịrị, “Isi emebighị m, ezigbo nna anyị Festọs. Ihe m na-ekwu nʼanya udo bụ naanị eziokwu.
\v 26 Eze nʼonwe ya makwaara ihe ndị a niile, nʼihi ya ejighị m egwu ọbụla agwa ya okwu a. Ekwenyere m na ọ dịghị ihe ọbụla nʼime ihe ndị a merenụ nke ezonarịrị ya, nʼihi na o nweghị nke mere na nzuzo.
\v 27 Gị eze Agripa, i kwenyeghị na ndị amụma? Amaara m na i kweere.”
\p 
\v 28 Mgbe ahụ Agripa sịrị, “Pọl, ị na-achọ nʼime ntakịrị oge a ịkwagide m ka m bụrụ onye kwere na Kraịst?”
\p 
\v 29 Ma Pọl sịrị, “Ọ gaara atọ m ụtọ ma ọ bụrụ na Chineke ga-ekwe, mee ka gị na ndị niile nọ nʼebe a bụrụ ihe mụ onwe m bụ nʼime Kraịst ma ewezuga agbụ ndị a.”
\p 
\v 30 Mgbe ahụ eze biliri ọtọ, ya na Festọs na Benaisi nwunye ya na ndị ọzọ niile ya na ha nọ nʼoche.
\v 31 Mgbe ha na-apụ, ha kwurịtara nʼonwe ha, “Nwoke a emeghị ihe ọbụla kwesiri ọnwụ maọbụ ịga mkpọrọ.”
\p 
\v 32 Agripa gwara Festọs, “A gaara a hapụ nwoke a ma ọ bụrụ na o nyefeghị Siza ikpe ya.”
\c 27
\s1 Pọl agaa Rom
\p 
\v 1 Mgbe e kpebiri na anyị ga-eso ụgbọ mmiri gaa Itali, e nyefere Pọl na ndị mkpọrọ ọzọ nʼaka onyeisi na-elekọta ndị mkpọrọ aha ya bụ Juliọs. Ọ bụ ọchịagha nke igwe ndị agha Ọgọstọs.
\v 2 Anyị banyere nʼụgbọ sitere Adramitiọm nke na-ejikere ịga nʼọnụ mmiri nke dị nʼakụkụ obodo Eshịa. Anyị nupuru nʼoke osimiri, Arịstakọs, onye Masidonia sitere na Tesalonaịka sokwa anyị nʼije a.
\p 
\v 3 Nʼechi ya, anyị rutere Saịdọn. Juliọs nwere obiọma nʼebe Pọl nọ. Ọ hapụkwara ya ka o jegharịara onwe ya izute ndị enyi ya. Ndị a lekwara anyị ọbịa nke ọma.
\v 4 Nʼịgakwa nʼihu na mmiri ahụ, anyị zutere ifufe mmiri nke mere na anyị gara nʼazụ ala Saiprọs.
\v 5 Anyị gafere ọnụ mmiri obodo Silisia na Pamfilia. Anyị bịaruru Mira nʼime obodo Lisia.
\v 6 Nʼebe ahụ ka onye ọchịagha hụrụ ụgbọ onye Alegzandria nke na-aga Itali. O mere ka anyị banye nʼime ya.
\v 7 Ụgbọ anyị ji, gara nwayọọ ọtụtụ ụbọchị na o siiri anyị ike irute Snidos. Ebe ọ bụ nʼoke ifufe ekweghị ka anyị gaa nʼihu, anyị enwekwaghị ike ịga nʼụzọ anyị, kama anyị si nʼazụ Kriit na ncherita ihu Salmone gafee.
\v 8 Anyị jikwa nwayọọ na-agba nʼakụkụ ọnụ mmiri ahụ tutu ruo mgbe anyị sitere nʼoke nsogbu rute ebe a na-akpọ ọnụ mmiri ọma, nke dị nso nʼobodo Lasia.
\p 
\v 9 Anyị tufuru oge nʼebe ahụ. Ije ụgbọ mmiri abụrụkwala nke jupụtakwara nʼihe ize ndụ ugbu a, nʼihi na mmemme Obubu ọnụ nke ndị Juu agafeela. Nʼihi nke a, Pọl dụrụ mmadụ niile ọdụ,
\v 10 na-asị, “Ndị nwe m, a na m ahụta na njem a ga-abụ nke ihe egwu nke ga-eweta oke ịla nʼiyi. Ọ bụghị naanị nke ụgbọ mmiri na ibu o bu, ma metụtakwa ndụ anyị.”
\v 11 Ma ọchịagha ahụ kwenyere nʼihe onyeisi ụgbọ na onye nwe ụgbọ kwuru karịa nke Pọl kwuru.
\v 12 Ma ebe ọnụ mmiri a abụghị ebe dị mma ịnọ nʼoge oyi, ndị ka nʼọnụọgụgụ họọrọ ka ụgbọ ahụ gaa nʼihu, nʼolileanya na a ga-eru Fonikisi ebe ha ga-anọdụ nʼoge oyi. Nke a bụ ọnụ mmiri dị na Kriit, nke chere ihu nʼọwụwa anyanwụ nʼakụkụ ugwu na akụkụ ndịda.
\s1 Oke ifufe nʼosimiri
\p 
\v 13 Mgbe ikuku dị nwayọọ bidoro ifegharị site na ndịda, ha chere na nke a bụ ohere dịrị ha. Nʼihi ya, ha kwọpụrụ ụgbọ nyara ya na-aga nso nso ọnụ mmiri Kriit.
\v 14 Ma mgbe na-adịghị anya, oke ifufe dị egwu nke si nʼagbata ugwu na ọwụwa anyanwụ kuru site nʼagwa etiti ahụ rịdata.
\v 15 Ndị na-anya ụgbọ ahụ gbalịsịrị ike na mbụ ichigharị ihu ụgbọ ahụ ka ọ gaa nʼọnụ mmiri, ma ọ pụghị ime. Anyị hapụrụ ya ka o soro ikuku.
\v 16 Nʼikpeazụ, anyị kwọọrọ ụgbọ anyị gaa nʼazụ agwa etiti nta a na-akpọ Klọda. Nʼebe ahụ anyị jisiri ike kekwasị ụgbọ nta nke ụgbọ mmiri anyị na-adọkpụ nʼazụ nʼelu ụgbọ mmiri ahụ.
\v 17 Emesịa, anyị jiri ụdọ kee ụgbọ mmiri ahụ ime ka o sie ike karịa. Ndị na-anya ụgbọ ahụ tụrụ egwu na ikuku ga-eburu ụgbọ anyị gaa nʼọnụ mmiri na-achị ọkụ nke dị na Satis. Ha wedatara akwa e kobere nʼelu, nke na-enyere ikuku aka ibu ụgbọ mmiri. Emesịa, ha sooro ikuku mmiri ahụ na-aga.
\v 18 Mgbe chi bọrọ, dịka osimiri ahụ na-etonye etonye, ndị na-eso ụgbọ bidoro ịtụbasị ngwongwo ndị dị nʼụgbọ ahụ nʼime osimiri.
\v 19 Nʼụbọchị nke atọ ha tụbakwara ngwongwo e ji edozi ụgbọ mmiri na ọtụtụ ihe ọbụla nke aka ha ghọtara nʼime osimiri.
\v 20 Mgbe ọtụtụ ụbọchị gara ma ọ dịghị anyanwụ maọbụ kpakpando wapụtaranụ, ma oke ifufe ọjọọ ahụ gara nʼihu na-amagharị, nʼikpeazụ olileanya anyị na a ga-azọpụta anyị gwụsịrị.
\p 
\v 21 Nʼoge a niile, o nweghị onye ọbụla nri ọbụla bara ọnụ. Ma nʼikpeazụ. Pọl kwụụrụ ọtọ nʼetiti ha sị, “Ndị ikom ibe m, ọ bụrụ na unu gere ntị nʼokwu m na mbụ, anyị agaraghị ahapụ Kriit. Anyị gara agbanarị mbibi na ịla nʼiyi nke a.
\v 22 Ma otu ọ dị, ana m arịọ unu, nweenụ obi ike! Nʼihi na o nweghị onye ọbụla nʼime unu a ga-atụfu ndụ ya. Ọ bụ ezie na ụgbọ a ga-emikpu.
\v 23 Nʼihi na nʼabalị gara aga, mmụọ ozi Chineke Onyenwe m, na onye m na-efekwa bịakwutere m,
\v 24 ọ sịrị, ‘Atụla egwu Pọl, nʼihi na ị ghaghị iguzo nʼihu Siza. Nke ọzọkwa, Chineke emeela amara nye gị ndụ ndị a niile gị na ha so nʼụgbọ eme njem.’
\v 25 Ya mere, ndị ikom nweenụ obi ike! Nʼihi na enwere m ntụkwasị obi na Chineke ga-eme dị ka o siri gwa m.
\v 26 Ma otu ọ dị, a ga-eburu ụgbọ mmiri anyị buba ya nʼotu agwa etiti.”
\s1 Ụgbọ imikpu
\p 
\v 27 Ihe dịka nʼetiti abalị nʼụbọchị nke iri na anọ ebili mmiri a, mgbe anyị na-erugharị nʼosimiri a na-akpọ Adratik, ndị na-anya ụgbọ chere na ala dị nso.
\v 28 Ha tụnyere ụdọ e kenyere igwe nʼọnụ ya nʼime osimiri chọpụta na omimi osimiri ahụ dị narị nzọ ụkwụ na iri abụọ nʼebe ahụ ha nọ. Ha gakwara nʼihu tụọkwa ụdọ ahụ ọzọ chọpụta na omimi osimiri ahụ dị iri nzọ ụkwụ itoolu.
\v 29 Ma egwu juru ha obi nʼihi na ha amaghị ma ha ga-ezute nkume nʼakụkụ ọnụ mmiri ahụ. Ha tụpụtara arịlịka anọ e ji ejide ụgbọ site nʼazụ ụgbọ ahụ ma na-arịọ chi ha maka chi ọbụbọ.
\v 30 Mgbe ndị na-eso ụgbọ ahụ kpebiri ịhapụ ya. Ha wedatara ụgbọ epeepe e dobere maka ihe mberede, mee dịka ha na-aga itinye arịlịka nʼọnụ ụgbọ mmiri ahụ.
\v 31 Ma Pọl gwara ndị agha na ọchịagha ha okwu, “Ọ bụrụ na ndị a anọgideghị nʼime ụgbọ a, agaghị azọpụta unu.”
\v 32 Nʼihi nke a, ndị agha ahụ gbubiri ụdọ e jiri kee ụgbọ epeepe ahụ hapụ ụgbọ epeepe ahụ ka ọ daba nʼime osimiri.
\p 
\v 33 Mgbe chi bidoro ịbọ, Pọl rịọrọ mmadụ niile ka ha rie nri, na-asị, “Taa mere ya ụbọchị iri na anọ unu nọ na nche, nọgidekwa nʼibu ọnụ, nʼerighị ihe ọbụla.
\v 34 Nʼihi ọdịmma nke ndụ unu, ana m arịọ unu ka unu rie ihe. Nʼihi na o nweghị onye ọbụla nʼime unu otu agịrị isi ya ga-ala nʼiyi.”
\v 35 Mgbe o kwuchara nke a, o weere achịcha nye Chineke ekele nʼihu ha niile, nyawaa ya, malitekwa iri ya.
\v 36 Otu mgbe ahụ, obi ụtọ batara mmadụ niile nʼobi, ha bidokwara iri nri.
\v 37 Anyị niile nọ nʼụgbọ ahụ dị narị mmadụ abụọ na iri asaa na isii.
\v 38 Mgbe anyị richara nri, ha buuru akpa ọka niile dị nʼụgbọ ahụ tụba ha nʼime osimiri ime ka ụgbọ ahụ gbaa mfe.
\s1 Omimi nke ụgbọ mmiri ahụ
\p 
\v 39 Mgbe chi bọrọ, ha enwekwaghị ike ịghọta akụkụ mmiri nke ha nọ nʼime ya. Ma ha hụrụ obosara ala nta nke nwere ọnụ mmiri. Ha gbara izu ịchọpụta ma ọ ga-ekwe mee ka ụgbọ mmiri ahụ site nʼebe ahụ gafee.
\v 40 Ha chabisiri arịlịka niile ji ụgbọ ahụ, hapụ ha nʼime osimiri. Otu aka ahụkwa, ha tọpụrụ ụdọ ji ụmara e ji anyagharị ụgbọ. Mgbe ahụ, ha weliri akwa ifufe nke ọnụ ụgbọ nye ifufe, mekwa ka ụgbọ mmiri chee ihu nʼelu ala.
\v 41 Ma ụgbọ mmiri ahụ gara maa isi na mkpumkpu aja mmiri, mikpuo nʼaja. Ọnụ ụgbọ ahụ mikpuru nke ukwuu mee ka isi ụgbọ ahụ laa elu, nke a nyere ebili mmiri a ohere iji ike tiwasịa azụ ụgbọ ahụ.
\p 
\v 42 Ndị agha zubere igbu ndị mkpọrọ niile, ka onye ọbụla ghara igwuru mmiri site ya gbafuo.\f + \fr 27:42 \ft Ọ bụrụ na ndị mkpọrọ a gbafuo, a na-egbu ndị agha niile ọ bụ ọrụ ha iledo ha.\f*
\v 43 Ma onye ọchịagha ahụ na-ezube ịzọpụta ndụ Pọl, nʼihi ya, o gbochiri ha nʼizuzu ha. Mgbe ahụ o nyere iwu ka ndị niile maara igwu mmiri buru ụzọ si nʼụgbọ ahụ wụba nʼime mmiri, gwuru mmiri gaa nʼelu ala.
\v 44 Ma ndị fọdụrụ ga-eru nʼelu ala site nʼịghọnye aka na obodobo osisi maọbụ nʼihe ndị ọzọ dị iche iche si nʼahụ ụgbọ ahụ dapụta. Nʼụzọ dị otu ka mmadụ niile ji bụrụ ndị rutere nʼelu ala nʼudo.
\c 28
\s1 Ọnụ mmiri obodo Malta
\p 
\v 1 Mgbe a pụtara nʼọnụ mmiri ahụ nʼudo, anyị chọpụtara na aha agwa etiti ahụ bụ Malta.
\v 2 Ndị obodo ahụ gosiri anyị obiọma nʼụzọ pụrụ iche. Ha kwanyere anyị ọkụ ma nabatakwa anyị nʼihi na mmiri nọ na-ezo, oyi na-atụkwa.
\v 3 Nʼoge Pọl na-achịkọta nkụ itinye nʼọkụ a, otu agwọ ajụala sitere nʼime nkụ na-enwu ọkụ mapụta nʼihi okpomọkụ tụhịkọ onwe ya nʼaka ya.
\v 4 Mgbe ndị obodo ahụ hụrụ agwọ ahụ ka ọ tụhịkọtara onwe ya nʼaka ya, ha gwarịtara onwe ha, “nʼezie a, nwoke a bụ ogbu mmadụ, a naghị eji ọkụ enyo ya. Ọ bụ ezie na azọpụtara ya site oke mmiri, ma ikpe ziri ezi ekweghị ka ọ dị ndụ.”
\v 5 Ma Pọl fepụrụ agwọ ahụ nʼaka ya, mee ka ọ daba nʼọkụ, ọ dịghịkwa ihe mere ya.
\v 6 Ha na-ele anya ma aka ya ọ ga-aza, maọbụ na ọ ga-ada nwụọ. Ma mgbe ha chegidere hụ na o nweghị ihe mere ya, ha gbanwere obi ha bido na-ekwu, na ọ bụ chi.
\p 
\v 7 Na nso ọnụ mmiri a ebe anyị kwụsịrị, otu ubi dị ya. Ọ bụ ubi Pobilios otu nwoke onyeisi na-achị agwa etiti ahụ. Ọ nabatara anyị nke ọma, lee anyị ọbịa ụbọchị atọ.
\v 8 Nʼoge ahụ, nna Pobilios nwere ahụ ọkụ na afọ ọsịsa, Pọl banyere nʼime obodo gaa leta ya, kpeere ya ekpere, bikwasịkwa ya aka. Ahụ dịkwara ya mma.
\v 9 Mgbe nke a mechara, ndị niile nwere nrịa nrịa nʼagwa etiti ahụ bịakwara, a gwọkwara ha.
\v 10 Ha wetaara anyị ọtụtụ ihe onyinye. Mgbe oge ịnyapụ ụgbọ anyị ruru, ha nyere anyị ọtụtụ ihe dị anyị mkpa nke pụrụ idu anyị nʼije ahụ.
\s1 Pọl erute Rom
\p 
\v 11 Anyị nọrọ ihe dịka ọnwa atọ nʼoge oyi, nʼagwa etiti ahụ tutu anyị anyalie ụgbọ. Ọ bụ ụgbọ ndị Alegzandria nke bu ihe a tụrụ atụ a na-akpọ ejima, bụ chi Kastọ na Polụkus.
\v 12 Anyị bịaruru obodo Sirakọs ebe anyị nọrọ ụbọchị atọ.
\v 13 Site nʼebe ahụ, anyị gara gburugburu tutu rute Rejiọm. Mgbe otu ụbọchị gafere, ikuku bidoro ife site na ndịda. Nʼụbọchị nke abụọ ya, anyị rutere Pọteọlị.
\v 14 Nʼebe a anyị chọpụtara ndị kwere ekwe ndị rịọrọ ka anyị nọnyere ha ụbọchị asaa. Site nʼebe a, anyị rutere Rom.
\v 15 Mgbe ụmụnna anyị nọ nʼebe ahụ nụrụ na anyị na-abịa. Ha pụtara zute anyị nʼụzọ Apiọs na nʼụlọ ndị Ije atọ. Mgbe Pọl hụrụ ha, o kelere Chineke ma bụrụ onye a gbara ume.
\v 16 Mgbe anyị bịaruru Rom, e nyere Pọl ohere ibiri onwe ya dịka o si chọọ nʼebe masịrị ya. Ma otu onye agha na-eche ya nche.
\s1 Pọl abata Rom
\p 
\v 17 Mgbe ụbọchị atọ gasịrị, ọ kpọrọ ndịisi ndị Juu. Mgbe ha zukọrọ, ọ gwara ha, “Ụmụnna m, ọ dịghị ihe ọjọọ ọbụla m mere megide ndị nke anyị, maọbụ megide omenaala nna nna anyị ha, ha jidere m na Jerusalem were m nyefee m nʼaka ndị Rom.
\v 18 Ndị ọchịchị Rom lenyere anya nʼikpe m chọọ ịhapụ m ka m laa nʼihi na ha achọtaghị ihe kwesiri ịma m ikpe ọnwụ dịka ndị anyị chọrọ.
\v 19 Ma mgbe ndị Juu jụrụ, ahụrụ m na ọ dị mkpa ibutere Siza ikpe m. Ma o nweghị ihe ọjọọ m bu nʼuche megide ndị obodo m.
\v 20 Nʼihi nke a, ka m jiri rịọọ ka mụ na unu hụ ma kwurịtakwa okwu. Ọ bụ nʼihi olileanya nke Izrel ka e ji kee m nʼagbụ igwe a.”
\p 
\v 21 Ha sịrị, “Anyị anataghị akwụkwọ ozi ọbụla site na Judịa banyere gị. Ọ dịghịkwa ụmụnna anyị ọbụla nke si ebe ahụ bịa nke kọrọ maọbụ kwuo okwu ọjọọ ọbụla banyere gị.
\v 22 Otu ọ dị, anyị ga-achọ ịnụta ihe i chere, nʼihi na anyị maara na a na-ekwujọ otu a nʼebe niile.”
\p 
\v 23 Ha yiri agba mgbe ha na ya ga-ezukọta nʼụbọchị ọzọ. Ọtụtụ mmadụ karịrị bịara nʼụlọ ebe ọ na-anọ. Ọ gbara ama banyere alaeze Chineke site nʼakwụkwọ iwu Mosis na nke ndị amụma, ọ gbalịrị ime ka ha kwenye nʼihe banyere Jisọs. O bidoro izi ha ihe site nʼụtụtụ ruo anyasị.
\v 24 Ụfọdụ ka e mere ka ha kweere, ma ụfọdụ mechiri ntị ha na obi ha.
\v 25 Ha nwe nghọtahie nʼetiti onwe ha ma malite ịla mgbe Pọl kwusiri okwu nke ikpeazụ a, “Mmụọ Nsọ Chineke kwuru eziokwu mgbe o sitere nʼọnụ Aịzaya onye amụma kwuo okwu nye nna nna anyị ha,
\q1 
\v 26 “ ‘Jekwuru ndị a gwa ha okwu,
\q1 “Unu ga na-anụ, nụkwa, ma unu agaghị aghọta ihe ọbụla,
\q2 unu ga na-ele anya, hụkwa, ma unu agaghị ahụ ihe ọbụla.”
\q1 
\v 27 Nʼihi na obi ndị a amaala abụba, dịkwa arọ;
\q2 ha adịghị ejikwa ntị ha anụ ihe,
\q2 ha mechikwara anya ha ka ha ghara ịhụ ụzọ.
\q1 Ma ọ bụghị otu a, ha nwere ike iji anya ha hụ ụzọ,
\q2 jirikwa ntị ha nụ ihe
\q2 sitekwa nʼobi ha nwe nghọta
\q1 ma chigharịa bịakwute m, ka m gwọọ ha.’\f + \fr 28:27 \ft \xt Aịz 6:9,10\xt*\f*
\p 
\v 28 “Ya mere, a chọrọ m ka unu ghọta na nzọpụta a nke si nʼaka Chineke bịa, dịkwa nye ndị mba ọzọ, ha ga-egekwa ntị.”
\v 29 Mgbe o kwusiri nke a, ndị Juu ahụ lara na-arụrịta ụka nke ukwu nʼetiti onwe ha.\f + \fr 28:29 \ft Akwụkwọ ụfọdụ na-edebanye amaokwu a ma ụfọdụ adịghị eme nke a.\f*
\p 
\v 30 O biri obi nke onwe ya afọ abụọ nʼụlọ ọ na-akwụ ụgwọ ya. Ọ na-anabatakwa ndị niile bịara ileta ya,
\v 31 o ji mkwuwa okwu na-ekwusa ihe banyere alaeze Chineke na-akụzikwa ihe banyere Onyenwe anyị Jisọs Kraịst. Ọ dịkwaghị onye ọbụla gbalịrị igbochi ya.
