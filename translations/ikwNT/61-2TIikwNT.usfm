\id 2TI - Ikwerre 
\h 2 Timoti 
\toc1 Ọkwukwo izi ke Ẹbo Pọlu gbaznennu Timoti 
\toc2 2 Timoti 
\toc3 2 Tim 
\mt2 Ọkwukwo izi 
\mt2 ke Ẹbo 
\mt2 Pọlu gbaznennu 
\mt1 Timoti 
\imt1 Nhne gbasịri ọkwukwo izi ka 
\im Nụ \bk Ọkwukwo izi ke Ẹbo ka ke Pọlu gbaznennu Timoti\bk*, bụ ke ọ gbarụ lele ọkwukwo izi nda naagbanụ nnwọ ọ whnụrnu n'anya (1:2,3), Pọlu pioru ma Timoti bụru nye ọgwnu ọma ke Karaịsi, o nwe ndidi nga ọ naata awhnụwhnu lele nye Karaịsi (2:1,3). Pọlu gbadiyarụ nne Timoti nụ nne nne a, ele nwernu ọkwnata mkpọma nụ Karaịsi. Pọlu karụ Timoti chenwanya nụ ya Pọlu tụkwasiri a aka a lawụru nụ risi, ke neegesi nụ Enine Chiokike noodu a nụ ẹrnu a. 
\ip Agwna ele kweru nụ Nyenwe aị dnabnarnụ nụ mbịta nye irno, kọvu Pọlu dọru Timoti aka nụ nsnị ọ gbanahọru kpakara ọrnurna ke nooduwhu rụmu ikoro (2:20-26; 3:1-9). Ọ kanụ Timoti ọ zịri kwem neezni izi ọma, ọ bụ n'ezi nụ agịda ele badnụ jéekweru (4:2). 
\ip Pọlu magwụ nụ ige matị ọ jọonwu ẹnwu kwnornu ọkwnata ovu a, kọvu o nwernu ọgwo ẹrnu (4:6-8). Ọ bụru nụ a sno Karaịsi nwụ ẹnwu, a joosno a zịri bụdnu, ọ bụru nụ a nwe ndidi, a joosno a chị lele eze (2:11,12a). 
\iot Nhne zị n'ọkwukwo ka 
\io1 Obekwu ikwu nụ okpukpe o kpenu Timoti \ior (1:1,2) \ior* 
\io1 Iwhnerne Nyenwe aị tụ́ko ị \ior (1:3-18)\ior* 
\io1 Bụru nye ọgwnu ọma Karaịsi \ior (2:1-26) \ior* 
\io1 Kpa ele badnụ joowu bụdnu be n'ige ipne-aznụ \ior (3:1-9) \ior* 
\io1 Bụru nye be kwesiri ọkwnata mkpọma \ior (3:10---4:8) \ior* 
\io1 Ezni ke aka Pọlu nụ obekwu ikwu ipne-aznụ \ior (4:9-22) \ior* 
\c 1  
\p  
\v 1 Mawa, Pọlu, nye izi Karaịsi Jizọsi hite n'echiche Chiokike, o ziyaru m me zni ele badnụ gbasịri mkwna bụdnu ke zị nụ Karaịsi Jizọsi. 
\p  
\v 2 M naagbaznenu Timoti nnwọ m me whnụrnu n'anya ọkwukwo. 
\p Oru, obirizi nụ udno ke hi n'aka Chiokike Nda aị nụ Nyenwe aị nụ Jizọsi Karaịsi dazịnu ị. 
\s1 Iwhnerne Nyenwe aị tụ́ko ị 
\p  
\v 3 M nọotunu Chiokike mmamma, nye me neekpenu hite n'ovu zị snam lele kpa ele nda m kpennu a, neekpe okpukpe iwhnehnie nụ abalị, neechenwanya ị n'okpukpe m.  
\v 4 Me chenwanya anya-mini ẹkwna ị, ọ nọogwnu m ọ whnụ ị anya ma ovu sọ m n'ọnu.  
\v 5 M neechenwanya ọkwnata ovu ị n'ezi, ke beru ọsno zịri nụ rime nne nne i, Lọisi, nụ nne i Unisi, m kweru m nụ ọ zị masị kpam nụ rime i.  
\v 6 Kam kpayarụ, gwakne bẹkwnu ke nkesi Chiokike, ke o nyernu ị nga me tụkwasiri ị aka m nụ risi.  
\v 7 Kwnornu nụ Chiokike nyége aị enine ke ogwnu, kọvu enine ke iknernema nụ ọwhnun'anya nụ anya udno. 
\p  
\v 8 Bikno, iwhnerne ọkpo okwo nhne gbasịri Nyenwe aị tụ́ko ị, mọbu iwhnerne me nye ikelu a. Kọvu snornu m ta awhnụwhnu n'izi ọma hite n'iknernema Chiokike nyernu i.  
\v 9 Chiokike znọhiaru aị, sukwu aị ma a wuru bụdnu zị nsọ. Ka bụ́o hite nụ nhne ọbula ke a mernu, kọvu ọ bụ mmụma a hite n'oru a. Ka bụ oru ke o nyernu aị nụ Karaịsi Jizọsi sụ ọwa panịzoru.  
\v 10 Kịtna, o mernu ka whụya iwhne nga Nye Ọznohia aị Karaịsi Jizọsi whụyaru iwhne, nye megburu ẹnwu gweyanụ aị bụdnu ke kwó okwo, ke noonwu n'iwhne ke izi ọma.  
\v 11 Me jiri bụru nye nọokpo okwo izi ọma ka, nụ nye izi nụ nye zni nhne.  
\v 12 Kam kpayarụ, me naata awhnụwhnu nụ rime ikelu. Kọvu iwhnerne zá nọotu m, kwnornu nụ m magwụ m nye me kweru nụ ya, m magwụ m masị nụ o nwernu rikne ọ bịta nhne me yisiri a n'aka\f + \fr 1:12 \fq nhne me yisiri a n'aka \ft mọbu \fq nhne Chiokike yisiri n'aka m \f* dụ ọbochi wam. 
\p  
\v 13 Hite n'ọkwnata ovu nụ ọwhnun'anya Karaịsi Jizọsi, bịta kpakara nhne ị nụrnu n'ọnu m, ma be bụru nhne atụ ke iznizni zị snam.  
\v 14 Enine Nsọ yinu i aka bịta nhne ọma wam be yisiri ị n'aka. 
\p  
\v 15 Ị magwụ nụ kpakara ele zị nụ Esia ghasarụ m, ma Figelusi nụ Hamogenisi. 
\p  
\v 16 Nyenwe aị dọnu ezi-nụ-ọro Onesiforosi obirizi kwnornu nụ o mesiri m ovu rikne, ijigba be tụru m zá nọotu a iwhnerne.  
\v 17 Nga ọ zị nụ Rom, o piosiri m rikne tem o piohịa m.  
\v 18 Nyenwe aị dọnu a obirizi n'ọbochi ikpe. Ị magwụ nkarị nkarị kpa o yinu m aka n'apna zị ọdo n'ọdo n'Efesọsi. 
\c 2  
\s1 Nye ọgwnu ọma ke Jizọsi 
\p  
\v 1 Timoti nnwọ m, gbasị rikne n'oru ke Karaịsi Jizọsi.  
\v 2 Kpakara nhne ị nụrnu me kwuru nụ ruwhnu agịda ele akebne, zni ele kwesiri be kwnata be ovu, ele jeenwe rikne zni masị ele berere.  
\v 3 Nwe ọkasi ovu n'awhnụwhnu lele nye ọgwnu ọma ke Karaịsi Jizọsi.  
\v 4 Ọ zá nye ọbula ke bụ nye ọgwnu ke neeme nhne nye bụ́o nye ọgwnu neeme, ma o mee nhne jọosno nye risi a ovu n'ọnu.  
\v 5 Kpam masị, ọ zá nye naagba ẹso ke jeenwe rikne kpuru okpu mmeri ọ bụru nụ ọ gbáge ẹso lele kpa iwu ẹso kwuru.  
\v 6 Nye ẹrnu ẹkwnu ke nọornu ẹrnu nkarị kwesiri o beru ọso ri mkpụru mbọm ke hi n'ẹkwnu a whụya.  
\v 7 Tule nhne me nookwu, Nyenwe aị jeenye i ọghohia nụ kpakara nhne. 
\p  
\v 8 Chenwanya nụ ka bụ izi ọma m, Jizọsi Karaịsi nye hiri n'avnụrnu Devidi, hiri n'ẹnwu lizọ.  
\v 9 Kwnornu nụ izi ọma ka, m naata awhnụwhnu dụ kpa be tụru m ijigba lele nye noolulu iwu, kọvu be tụ́ge ikwu-ọnu Chiokike ijigba.  
\v 10 Ka bụ nhne mernu me neenwe nkasi ovu kwnornu ele wam Chiokike họhiaru, ma be nwehịa ọznohia ke zị nụ Jizọsi Karaịsi nụ igwugwu kwó okwo. 
\p  
\v 11 Ka bụ ikwu-ọnu ke kwesiri ọkwnata ovu, 
\q1 Ọ bụru nụ a snornu a nwụ, 
\q2 a joosno a zịri bụdnu. 
\q1  
\v 12 Ọ bụru nụ a nwe ndidi, 
\q2 a joosno a chị lele eze. 
\q1 Ọ bụru nụ a gọnahoru a, 
\q2 ọ jọogonahoru aị. 
\q1  
\v 13 Ọ bụru nụ a nwée ọkwnata ovu, 
\q2 o jeekwesi kọriri ọkwnata ovu, 
\q1 kwnornu nụ ọ jọ́ogonahoru ẹhni a. 
\s1 Nye ẹrnu ke Chiokike  //  naakweru 
\p  
\v 14 Chenwanyanụ be kpakara nhne ka. Dọ be aka nụ nsnị nụ ruwhnu Chiokike gbasịri ọdogbuta n'ikwu-ọnu, ọ zá mbnarna ọbula zị a, o noolulu ele noobno nsnị.  
\v 15 Gbalị gweru ẹhni i gesi nụ ruwhnu Chiokike lele nye ẹrnu Chiokike nakweru, nye iwhnerne zá nọotu, nye nwernu rikne zni ikwu-ọnu ke ezi ọka nkarị.  
\v 16 Zeru ọka iwhnirniwhno nụ ọka etekne, kwnornu nụ ele nookwu a neegweme ẹhni be hne Chiokike zị.  
\v 17 Iznizni be naagbasa lele bẹkwnu ọkochi, \f + \fr 2:17 \ft mọbu \fq lele mbam mbam \f* ke Haịmenousi nụ Filetusi zị n'esilawụru ele neezni a.  
\v 18 Ka bụ ele kpawhuru n'ezi ọka. Be nookwu nụ olizọ n'ẹnwu ele nwụrnu ọnwu whelem, be naakwnadna ọkwnata ovu agwna ele badnụ.  
\v 19 Kpa ọ zị, ntụ-ẹli Chiokike gwuzo kwem, ke nwernu akara ka, “Chiokike magwụ ele ke a,” nụ “Nye ọbula ke noosukwu rẹwhna Nyenwe aị, hi nụ nhne ọjo whụya.” 
\p  
\v 20 N'ọro hna okpotokpo, ọ bụ́o agbụgba wiri golu nụ agbụgba wiri siliva bụ nhne zị a kpọi, kọvu okiko isisi nụ rịzna, agwna be ji nọornu ẹrnu zị mkpa, agwna be ji nọornu ẹrnu zị́la okne mkpa.  
\v 21 Kọvu ọ bụru nụ badnụ ọbula snụsnama ẹhni a nkarị, be jeeji a nọornu ẹrnu zị mkpa, ke zị nsọ, be jiknernu a, Nyenwe a jeeji nọornu ẹrnu ọma ọbula.  
\v 22 Gbanahọru kpakara nhne ọjo ke nọogwnu ele ikoro. Gbasnornu ome mma, nụ ọkwnata ovu, nụ ọwhnun'anya nụ udno, jị nụ kpakara ele neekpenu Nyenwe aị nụ mkpọma zị rịchna.  
\v 23 I kwú ọka ọbula ke iwhnirniwhno nụ agịrigo nwée risi, kwnornu nụ be noovuya okno ọka.  
\v 24 Nye izi Nyenwe aị jọ́oburu nye nookno ọka, tnụnuma, ọ jọoburiri nye neegesi nye ọbula ovu ọma, nye nwernu rikne zni nhne, nye nwernu ndidi.  
\v 25 O jeegweru wọhnernerne neezni ele neemegidne a nhne, neele anya nụ Chiokike jeeme be tụhnasna, o dubna be n'ezi ọka,  
\v 26 ma be mahịa nhne, gbanahọru mbịta Ekwensu sninu be, kpa o gidnernu be ma be mee nhne o pioru be mee. 
\c 3  
\s1 Ọbochi ipne-aznụ 
\p  
\v 1 Kọvu hnata ka ama, ige tụ ogwnu k'agịda vawa n'ọbochi ipne-aznụ.  
\v 2 Ele badnụ jọoburu ele whnụrnu ẹhni be n'anya, ele whnụrnu ịwai n'anya, ele oknomokno, ele nganga, ele noolulu ele badnụ, ele zá noobnonu ele mụrnu be nsnị, ele nwée ovu ọtu mmamma, ele zá nsọ,  
\v 3 ele nwée ọwhnun'anya, ele zá naagbarụnu ele badnụ nhne be mernu be, ele nookwulu, ele nwée rikne jikwaru ẹhni be, ele nụ lele anọhia, ele nhne bụru ọma zá naamasị,  
\v 4 ele neere ele badnụ, ele risi rikne, ele nọowhu nụ nganga, ele whnụrnu nhne sọ n'ọnu n'anya karụ ọ whnụ Chiokike n'anya,  
\v 5 ele nwernu ọdi ogwnu Chiokike kọvu be gọnahoru rikne a. Jị nụ be nwékọ nhne ọbula. 
\p  
\v 6 Be bụ ele ji aghịgho nooduwhu ezi-nụ-ọro, duwhu ele rinya nwée rikne, ele rinya mmehie noovughari lele ele nwọrnu manya nụ ẹgwnurnu nhne ọjo.  
\v 7 Ele rinya nụ kpa zị nọomu nhne, kọvu be nwée rikne mụhia ezi ọka.  
\v 8 Lele kpa Janisi nụ Jambirisi gwuzogidnernu Mozizi, ele ka neemegidne ezi ọka, ele mkpọma be nwụrnu ọnwu, ele ọkwnata ovu be bụ nhne etekne.  
\v 9 Kọvu be jéenwe rikne zne nụ ruwhnu, lele kpa iwhnirniwhno ele wam whụyaru iwhne, ọ bụ masị kpa iwhnirniwhno ele ka jọowhuya iwhne. 
\s1 Pọlu znirni Timoti  //  ezi ipne-aznụ 
\p  
\v 10 Kịtna, Timoti, ị magwụ kpakara nhne me znirni nụ kpa me wuru bụdnu m. Ị magwụ nhne me neeme nụ nhne me kweru nụ ya, nkasi ovu m, nụ ọwhnun'anya m, nụ ndidi,  
\v 11 nụ kpa me nagidnernu ọkpagbu, nụ awhnụwhnu. Ị magwụ kpakara nhne me whnụrnu n'Antịoku, nụ Aịkoniom, nụ Lisitira, kpa me nagidnernu ọkpagbu. Kọvu Nyenwe aị dọhiaru m nụ rime kpakara be.  
\v 12 Me kanụ ị ezi ọka, nye ọbula ke joowu bụdnu ke nọotu ogwnu Chiokike nụ rime Karaịsi Jizọsi jaata awhnụwhnu.  
\v 13 Kọvu ele ọjo nụ ele ka nụ be bụ nhne be bụ́la, jaazị nọojokari bụjo, nooduwhu ele badnụ, be nooduwhu masị be.  
\v 14 Kọvu dazịgidne nụ nhne me znirni ị nụ nhne i kweru, hne ị magwụ nye ị mụhiaru nhne n'aka a.  
\v 15 Hite n'ige ị bụ nnwọ matị, ị magwụ nhne ọkwukwo nsọ kwuru, ke nwernu rikne mee i ị bụru nye nwernu akọniche. Ka joodubna i n'ọznohia hite n'ọkwnata ovu ke zị nụ Karaịsi Jizọsi.  
\v 16 Kpakara nhne be gbarụ n'ọkwukwo nsọ hi n'echiche Chiokike whụya, be bụru ọma n'ogweru zni nhne, bigbọ, dọ aka nụ nsnị nụ ọznuznu ke ome mma,  
\v 17 ma badnụ ke Chiokike bụru nye zuru ozu, nye be jiknernu nọornu kpakara ẹrnu ọma. 
\c 4  
\p  
\v 1 M gwuzo m nụ ruwhnu Chiokike nụ Karaịsi Jizọsi nye jeekpe ele zị bụdnu nụ ele nwụrnu ọnwu ikpe nga ọ jaava lele eze, neenye i iwu ka.  
\v 2 Kpọ okwo izi ọma, zịri gnarnagnarna n'ige kwesiri nụ ige kwésige, bna mbna, bigbọ, kwnalizọ mkpọma, gweru agịda ndidi nụ anya dụru ẹli neezni nhne.  
\v 3 Kwnornu nụ ige jaava nga ele badnụ jéekweru iznizni bụru ọma. Tnụnuma, be jaachịkota ele neezni nhne, ele jeezni be nhne ke nsnị nọoko be ẹko noopio.  
\v 4 Be jéekwe o bno nsnị n'ezi ọka, kọvu snornu ọtnutnu ruwhere.  
\v 5 Kọvu bụru nye anya dụru ẹli ige ọbula, naagidne awhnụwhnu, rnụ ẹrnu nye nọokpo okwo izi ọma, rnụ kpakara ẹrnu ke kwesiri nye izi Chiokike. 
\p  
\v 6 Kịtna, ige be jọowusi bụdnu m lele arịohna manya dụlam, ige me jọonwu ẹnwu valẹm.  
\v 7 M lụkwolem ọgwnu ọma wam, m gbazulem ẹso wam, m bịtala m ọkwnata ovu wam.  
\v 8 Kịtna, Nyenwe aị bịtannu m okpu-eze ke ome mma, ke nye ikpe ziri ezi jeenye m n'ọbochi wam, o jéenye me nụ nsnụnu m, kọvu o jeenye kpakara ele noopio ọ whnụ a anya nga ọ jọowhuya iwhne. 
\s1 Iznuznu Pọlu nụ Timoti 
\p  
\v 9 Me wara wara va.  
\v 10 Demasị whnụrnu nhne ọwa n'anya, ọ ghasa m zne Tẹsalonika. Kirẹskensi znernu Galasia, Taịtosi zne Dalimatia.  
\v 11 Me nụ Lukwu kpọi zị. Nga ị jaava kwuru Makị va, kwnornu nụ o jeenyinu m aka n'ẹrnu me nọornu.  
\v 12 M ziznernu m Taịkikosi Efesọsi.  
\v 13 Nga ị jaava chịyanu m iwo me chịsaru n'ọro Kapọsi nụ Torasi, nụ ọkwukwo, ke kakwo mkpa ọkwukwo. 
\p  
\v 14 Alẹkizanda nye ẹrnu rugwe mernu m nhne ọjo k'agịda. Nyenwe aị jọokwu a ọgwo ẹrnu a.  
\v 15 Anya dụ ẹli hne ọ zị, kwnornu nụ ọ bụ nye neemegidne izi aị. 
\p  
\v 16 Nga me gwuzo n'ikpe n'ọziri nọogoru ọnu m, ọ zá nye ọbula ke sno m, kpakara ele badnụ gbanahọru m. Chiokike bikno, gwnụ́ko nhne ka megidne be.  
\v 17 Kọvu Nyenwe aị dagwụnu m, nyee masị m rikne, me jiri kpọ okwo izi ọma nụ nsnị kpakara ele bụ́o ele Ju. Be dọhiaru m n'ọnu odum.  
\v 18 Nyenwe aị jọodohia m nụ kpakara nhne ọjo, duru m n'udno bna n'ọchichi ẹli-eze oligwe. Ya nwe igwugwu ọkwnukokwnu. Amịm. 
\s1 Obekwu ipne-aznụ ke Pọlu 
\p  
\v 19 Bekwu Prisila nụ Akwịla nụ ezi-nụ-ọro Onesiforosi.  
\v 20 Erasịtosi dazịri nụ Kọrinti, Tirofimọsi naarịa ẹhni igbugbu, m ghasa a nụ Miletọsi.  
\v 21 Gbalị va sụ okirika dụ. Ebulusi neebekwu i, ma Pudesi, Laịnosi, nụ Kalaudịa nụ kpakara rụmu nda. 
\p  
\v 22 Nyenwe aị dazịnu ị. Oru Chiokike dazịnu anụ.