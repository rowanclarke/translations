\id HAB - Biblica® Open Ndebele Contemporary Bible 
\h UHabhakhukhi 
\toc1 UHabhakhukhi 
\toc2 UHabhakhukhi 
\toc3 Hab 
\mt1 UHabhakhukhi 
\c 1  
\p  
\v 1 Isiphrofethi esemukelwa nguHabhakhukhi umphrofethi. 
\b  
\s1 Insolo KaHabhakhukhi 
\q1  
\v 2 Koze kube nini, awu \nd Thixo\nd*, ngicela usizo, 
\q2 kodwa ungalaleli na? 
\q1 Loba ngimemezela kuwe ngisithi, “Udlakela!” 
\q2 kodwa ungangihlengi na? 
\q1  
\v 3 Kungani ungitshengisa okungasimfanelo na? 
\q2 Kungani ubekezelela okungalunganga na? 
\q1 Ukuchitheka lodlakela kuphambi kwami; kulokulwa, 
\q2 lengxabano yandile. 
\q1  
\v 4 Ngakho umthetho usuthundubezekile, 
\q2 lokulunga akusabi khona. 
\q1 Ababi baminyezela abalungileyo 
\q2 ukuze ukulunga konakaliswe. 
\s1 Impendulo \nd KaThixo\nd* 
\q1  
\v 5 “Khangelani ezizweni libone 
\q2 njalo limangale kakhulu. 
\q1 Ngoba ensukwini zenu 
\q2 ngizakwenza into elingasoze liyikholwe, 
\q2 lanxa lingabe litsheliwe. 
\q1  
\v 6 Sengivusa amaKhaladiya, 
\q2 lesiya isizwe esilesihluku lamawala, 
\q1 esitshaya sibhuqe umhlaba wonke, 
\q2 sithumba izindawo zokuhlala ezingasizo zaso. 
\q1  
\v 7 Bayisizwe esesabekayo lesitshayisa uvalo; 
\q2 bangumthetho bona ngokwabo 
\q2 njalo baziphakamisa udumo lwabo. 
\q1  
\v 8 Amabhiza abo alesiqubu esedlula esamahlosi, 
\q2 ayesabeka kulezimpisi kusihlwa. 
\q1 Amabhiza abo empi amatha ephulukundlela, 
\q2 abagadi bawo amabhiza bavela khatshana. 
\q1 Bandiza njengamanqe ehwitha ukudla, 
\q2  
\v 9 bonke beza belande udlakela. 
\q1 Amaxuku abo aqhubekela phambili njengomoya wasenkangala 
\q2 abuthe abathunjiweyo njengenhlabathi. 
\q1  
\v 10 Baklolodela amakhosi, 
\q2 bahleke ababusi usulu. 
\q1 Wonke amadolobho avikelweyo bayawahleka; 
\q2 bakha amadundulu ngenhlabathi bawathumbe lawo madolobho. 
\q1  
\v 11 Emva kwalokho badlula ngesiqubu njengomoya baqhubeke, 
\q2 abantu abalecala abamandla abo angunkulunkulu wabo.” 
\s1 Insolo Yesibili KaHabhakhukhi 
\q1  
\v 12 Awu \nd Thixo\nd*, kawuveli phakade na? 
\q2 Nkulunkulu wami, Ngcwele wami, kasiyikufa. 
\q1 Awu \nd Thixo\nd*, ubabekile ukuba bahlulele. 
\q2 Awu Dwala, ubamisile ukuba bajezise. 
\q1  
\v 13 Amehlo akho ahlanzeke kakhulu ukuba akhangele okubi; 
\q2 awungeke ubekezelele okungalunganga. 
\q1 Pho kungani ubekezelela abachithayo na? 
\q2 Uthulelani lapho ababi 
\q2 beqeda labo abalunge kakhulu kulabo na? 
\q1  
\v 14 Wenze abantu bafana lenhlanzi olwandle, 
\q2 njengezidalwa zasolwandle ezingelambusi. 
\q1  
\v 15 Isitha esibi siyazikhupha zonke ngewuka, 
\q2 siyazibamba ngembule laso, 
\q1 sizibuthele embuleni laso elidonswayo; 
\q2 ngalokho siyajabula sithokoze. 
\q1  
\v 16 Ngakho-ke senzela imbule laso umhlatshelo, 
\q2 sitshisele imbule laso elidonswayo 
\q1 impepha ngoba ngenxa yembule laso 
\q2 sithe pekle phakathi kwenotho, 
\q2 sizitika ngokudla okumnandi. 
\q1  
\v 17 Kuzamele siqhubeke sithulula umambule waso, 
\q2 sitshabalalisa izizwe kungekho sihawu na? 
\b  
\c 2  
\q1  
\v 1 Ngizakuma esilindweni sami 
\q2 ngime phezu komthangala; 
\q1 ngizakhangela ukuba ngibone ukuthi uzakuthini kimi, 
\q2 lokuthi yimpendulo bani engizayitsho ngale insolo. 
\s1 Impendulo \nd KaThixo\nd* 
\p  
\v 2 \nd UThixo\nd* waphendula wathi: 
\q1 “Loba phansi isibonakaliso 
\q2 usenze sicace ezicecedwini 
\q2 ukuze isithunywa sigijime laso. 
\q1  
\v 3 Ngoba isibonakaliso silindela isikhathi esimisiweyo; 
\q2 sikhuluma ngesiphetho 
\q2 njalo kasiyikuba ngamanga. 
\q1 Lanxa siphuza, silindele; 
\q2 sizafika impela 
\q2 njalo kasiyikuphuza. 
\b  
\b  
\q1  
\v 4 Khangela, uyazigqaja; 
\q2 izifiso zakhe kazilunganga, 
\q2 kodwa olungileyo uzaphila ngokholo lwakhe. 
\q1  
\v 5 Impela iwayini liyamkhohlisa; 
\q2 uyazikhukhumeza njalo kalakho ukuphumula. 
\q1 Ngoba uyisihwaba njengengcwaba, 
\q2 njalo kasuthi njengokufa, 
\q1 ubuthelela izizwe zonke kuye 
\q2 athumbe labantu bonke. 
\p  
\v 6 Bonke kabayikumchothoza na bamhleke besithi, 
\q1 ‘Maye kulowo obuthelela impahla zokwebiwa 
\q2 azinothise ngobugebenga! 
\q2 Koze kube nini lokhu kusenzakala na?’ 
\q1  
\v 7 Labo olezikwelede kubo kabayikukujuma na? 
\q2 Kabayikuvuka bakuthuthumelise na? 
\q2 Lapho-ke uzakuba yinto yabo yokuhlutshwa. 
\q1  
\v 8 Ngoba sewaphanga izizwe ezinengi, 
\q2 abantu abaseleyo bazakuphanga 
\q1 ngoba wachitha igazi labantu; 
\q2 watshabalalisa amazwe lamadolobho labo bonke abakuwo. 
\b  
\q1  
\v 9 Maye kulowo obumba umbuso ngenzuzo embi 
\q2 ukuba akhele isidleke sakhe phezulu 
\q2 ukuba abalekele ukuwelwa yingozi! 
\q1  
\v 10 Ucebe ukubhujiswa kwabantu abanengi, 
\q2 wayangisa indlu yakho, walahlekelwa yikuphila kwakho. 
\q1  
\v 11 Amatshe omduli azakhala 
\q2 imijabo yamapulanka izasabela. 
\b  
\q1  
\v 12 Maye kulowo owakha idolobho ngokuchitha igazi 
\q2 akhe umuzi ngobudlwangudlwangu. 
\q1  
\v 13 \nd UThixo\nd* uSomandla kakumisanga na 
\q2 ukuthi umsebenzi uzinkuni zomlilo nje kuphela, 
\q2 lokuthi izizwe ziqeda amandla azo ngeze? 
\q1  
\v 14 Ngoba umhlaba uzagcwala ngolwazi lodumo \nd lukaThixo\nd*, 
\q2 njengamanzi egcwalisa ulwandle. 
\b  
\q1  
\v 15 Maye kulowo onika omakhelwane bakhe 
\q2 okunathwayo ekuthulula 
\q2 esigujini sewayini badakwe, 
\q2 ukuze akhangele imizimba yabo enqunu. 
\q1  
\v 16 Uzakuba lehlazo elikhulu endaweni yodumo. 
\q2 Khathesi sekulithuba lakho! Natha uchayeke. 
\q1 Inkezo yesandla sokunene \nd kaThixo\nd* iyeza kuwe, 
\q2 ihlazo lizamboza udumo lwakho. 
\q1  
\v 17 Udlakela olwenze eLebhanoni luzakuqeda amandla, 
\q2 lokubulala kwakho izinyamazana kuzakuthuthumelisa. 
\q1 Ngoba uchithe igazi labantu; 
\q2 uchithe amazwe lamadolobho labo bonke abakuwo. 
\b  
\q1  
\v 18 Silosizo bani isithombe njengoba sibazwe ngumuntu? 
\q2 Kumbe isifanekiso esifundisa amanga? 
\q1 Ngoba lowo osenzayo uthemba isidalwa sakhe; 
\q2 wenza izithombe ezingeke zikhulume. 
\q1  
\v 19 Maye kulowo othi esigodweni, ‘Vuka uphile!’ 
\q2 loba athi elitsheni elingaphiliyo, ‘Phaphama!’ 
\q1 Linganika iseluleko na? 
\q2 Lembeswe ngegolide langesiliva, 
\q2 akulamphefumulo phakathi kwalo.” 
\b  
\q1  
\v 20 Kodwa \nd uThixo\nd* usethempelini lakhe elingcwele; 
\q2 umhlaba wonke kawuthule phambi kwakhe. 
\c 3  
\s1 Umkhuleko KaHabhakhukhi 
\p  
\v 1 Umkhuleko kaHabhakhukhi umphrofethi. \tl NgeShigiyonothi\tl*. 
\q1  
\v 2 \nd Thixo\nd*, ngizwile ngodumo lwakho; 
\q2 ngiyazesaba izenzo zakho, awu \nd Thixo\nd*. 
\q1 Zivuselele ensukwini zethu, 
\q2 yenza zazakale esikhathini sethu; 
\q2 ekuthukutheleni khumbula isihawu. 
\b  
\q1  
\v 3 UNkulunkulu wavela eThemani, 
\q2 oNgcwele wavela eNtabeni iPharani. 
\q1 Inkazimulo yakhe yasibekela amazulu 
\q2 lokudunyiswa kwakhe kwagcwala umhlaba wonke. 
\q1  
\v 4 Ubucwazicwazi bakhe babunjengokuphuma kwelanga; 
\q2 imisebe yaphazima esandleni sakhe 
\q2 lapho amandla akhe ayefihlwe khona. 
\q1  
\v 5 Isifo sahamba phambi kwakhe, 
\q2 umkhuhlane walandela amanyathelo akhe. 
\q1  
\v 6 Wasukuma, wanyikinya umhlaba; 
\q2 wakhangela, waqhaqhazelisa izizwe. 
\q1 Izintaba zasendulo zabhidlika 
\q2 lamaqaqa akudala adilika. 
\q2 Izindlela zakhe ngezanini lanini. 
\q1  
\v 7 Ngabona amathente aseKhushani ephakathi kosizi, 
\q2 lezindawo zokuhlala zaseMidiyani zisebuhlungwini. 
\b  
\q1  
\v 8 Awu \nd Thixo\nd*, imifula wawuyithukuthelele na? 
\q2 Ulaka lwakho lwavuthela izifula na? 
\q1 Ulwandle wawuluthukuthelele na 
\q2 lapho ugade amabhiza akho 
\q2 lezinqola zakho zempi ezinqobayo? 
\q1  
\v 9 Idandili lakho ulembule, 
\q2 ufune imitshoko eminengi. 
\q1 Uqhekeze umhlaba ngemifula; 
\q2  
\v 10 izintaba zakubona zajanqula, 
\q1 izikhukhula zamanzi zedlula, 
\q2 ulwandle lwahlokoma, 
\q2 lwaphakamisela amagagasi alo phezulu. 
\b  
\q1  
\v 11 Ilanga lenyanga kwema mpo emazulwini 
\q2 ekubenyezeleni kwemitshoko yakho entwezayo, 
\q2 ekuphazimeni kwemitshoko yakho ecazimulayo. 
\q1  
\v 12 Wanyathela umhlaba ngolaka, 
\q2 wabhula izizwe ngentukuthelo. 
\q1  
\v 13 Waphuma ukuba ukhulule abantu bakho, 
\q2 ukuba usindise ogcotshiweyo wakho. 
\q1 Umkhokheli welizwe lobubi umchobozile, 
\q2 wamebula kusukela ekhanda kusiya enyaweni. 
\q1  
\v 14 Umhlabe ikhanda ngomkhonto wakhe 
\q2 lapho amabutho akhe ephume ngesiqubu ukuba asihlakaze, 
\q1 ethokoza kungani asezakudla 
\q2 abahluphekayo abebecatshile. 
\q1  
\v 15 Wanyathela ulwandle ngamabhiza akho, 
\q2 uqubula amanzi amanengi. 
\b  
\q1  
\v 16 Ngezwa, inhliziyo yami yatshaya, 
\q2 izindebe zami zabikizeliswa ngumsindo; 
\q1 amathambo ami angenwa yikubola, 
\q2 imilenze yami yaqhaqhazela. 
\q1 Kodwa ngizalindela ngesineke usuku lomonakalo 
\q2 ukuba lufike esizweni esihlasela esethu. 
\q1  
\v 17 Lanxa isihlahla somkhiwa singanunkuli 
\q2 lamavini engekho emivinini; 
\q1 lanxa ama-oliva engathelanga, 
\q2 lamasimu engabanga lokudla, 
\q1 lanxa kungelazimvu esibayeni 
\q2 lenkomo zingekho ezibayeni, 
\q1  
\v 18 kodwa ngizathokoza \nd kuThixo\nd*, 
\q2 ngizajabula kuNkulunkulu uMsindisi wami. 
\b  
\q1  
\v 19 \nd UThixo\nd* Wobukhosi ungamandla ami; 
\q2 wenza inyawo zami zibe njengezempala, 
\q2 ungenza ngihambe ezindaweni eziphakemeyo. 
\d Ngeyomqondisi womculo. Ezigincini zami.