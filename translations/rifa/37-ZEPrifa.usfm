\id ZEP
\h صَافَانْيَا
\toc1 صَافَانْيَا
\toc2 صَافَانْيَا
\toc3 صَاف.
\mt1 صَافَانْيَا
\c 1
\s1 أَسّْ أَمقّْرَانْ ن سِيذِي
\m 
\v 1 أَوَاڒْ نْ سِيذِي إِ د-يُوسِينْ إِ صَافَانْيَا، مِّيسْ ن كُوشِي، مِّيسْ ن جَاذَالْيَا، مِّيسْ ن أَمَارْيَا، مِّيسْ ن حِيزْقِييَا، ذڭْ وُوسَّانْ ن يُوشِييَا، مِّيسْ ن أَمُونْ، أَجدْجِيذْ ن يَاهُوذَا. \f ◼ \fr 1:‏1 \ft \bd ’صَافَانْيَا‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي ث إِسّْنُوفَّارنْ سِيذِي‘.\f*
\b
\m 
\v 2 نشّْ أَذْ كّْسغْ قَاعْ مَارَّا \add مِينْ إِدْجَانْ\add*
\m زڭْ وُوذمْ ن ثمُّورْثْ،
\m \add أَمُّو إِ\add* إِقَّارْ سِيذِي.
\m 
\v 3 أَذْ كّْسغْ بْنَاذمْ ذ ڒْمَاڒْ،
\m أَذْ كّْسغْ إِجْضَاضْ ن ؤُجنَّا
\m ذ إِسڒْمَانْ ن ڒبْحَارْ
\m ذ ثْعنْكْرِيفِينْ أَكْ-ذ إِعفَّاننْ،
\m \add وَاهْ\add* نشّْ أَذْ قْضِيغْ بْنَاذمْ
\m خْ وُوذمْ ن ثمُّورْثْ،
\m \add أَمُّو\add* إِ إِقَّارْ سِيذِي. \x ◘ \xo 1:‏3 \xt أَمز. 6‏:‏7\x*
\m 
\v 4 نشّْ أَذْ سّْوِيژّْضغْ س ؤُفُوسْ إِنُو
\m ضِيدّْ إِ يَاهُوذَا
\m ؤُ ضِيدّْ إِ مَارَّا إِمزْذَاغْ ن ؤُرْشَالِيمْ.
\m نشّْ أَذْ ثحِّيغْ مِينْ إِقِّيمنْ زِي بَاعْلْ
\m زڭْ ومْشَانْ-أَ
\m أَكْ-ذ يِيسمْ ن إِكهَّاننْ ن لْ-أَصْنَامْ، \f ◼ \fr 1:‏4 \ft \bd ’أَذْ ثحِّيغْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَذْ قضْعغْ‘.\f*
\m 
\v 5 ذ يِينِّي إِسجْذنْ خْ ثْزغْوِينْ
\m زَّاثْ إِ ڒْعسْكَارْ ن إِجنْوَانْ،
\m ؤُ إِنِّي، أَمْ بنْذْقنْ، جُّودْجنْ غَارْ سِيذِي،
\m ؤُ \add أَقَا\add* جُّودْجنْ إِ مَالْكَامْ،
\m 
\v 6 ؤُڒَا ذ يِينِّي د-إِتّْعَاقَّابنْ
\m زِي ضفَّارْ ن سِيذِي،
\m ؤُ يِينِّي وَارْ أَرزُّونْ خْ سِيذِي
\m ؤُ وَارْ خَاسْ تّْسّقْسِينْ. \x ◘ \xo 1:‏6 \xt إِشا. 1‏:‏4؛ 59‏:‏13؛ إِرْم. 15‏:‏6\x*
\b
\m 
\v 7 سغْذْ زَّاثْ إِ وُوذمْ ن سِيذِي إِنُو، سِيذِي،
\m مَاغَارْ أَسّْ ن سِيذِي يُوذسْ.
\m سِيذِي أَقَا إِسّوْجذْ إِشْثْ ن ثْغَارْصْثْ،
\m نتَّا إِسّْقدّسْ إِمعْرَاضنْ نّسْ.
\m 
\v 8 أَذْ إِمْسَارْ ذڭْ وَاسّْ ن ثْغَارْصْثْ ن سِيذِي،
\m أَقَا نشّْ أَذْ عَاقْبغْ ڒْحُوكَّامْ
\m ذ إِحنْجِيرنْ ن ؤُجدْجِيذْ
\m ذ مَارَّا إِنِّي يَارّْضنْ أَرُّوضْ أَغْرِيبْ.
\m 
\v 9 \bdit ذڭْ وَاسّْ نِّي\bdit* أَذْ عَاقْبغْ
\m مَارَّا إِنِّي إِنڭّْزنْ ثَانبْذَاثْ،
\m إِنِّي إِتّْعمَّارنْ ثَادَّارْثْ ن سِيذِيثْسنْ
\m س لْعُونْفْ ذ ڒْغشّْ.
\b
\m 
\v 10 ذڭْ وَاسّْ نِّي، إِقَّارْ سِيذِي،
\m أَذْ \add ذِينْ\add* يِيڒِي إِجّْ ن ڒْحسّْ ن إِغُويَّانْ
\m زِي ثوَّارْثْ ن إِسڒْمَانْ،
\m ؤُڒَا ذ \add ڒْحسّْ ن\add* يِينِّي إِتّْرُونْ
\m زِي ثنْذِينْثْ ن جْذِيذْ
\m ذ إِشْثْ ن ثَارژِّيثْ ثمْغَارْ زِي ثوْرِيرِينْ.
\m 
\v 11 رُومْ، إِمزْذَاغْ \add ن جِّيهثْ\add* ن ؤُمهْرَازْ،
\m مِينْزِي مَارَّا إِسبَّابّنْ تّْوَاسغْضنْ،
\m مَارَّا إِنِّي إِوزّْننْ ثْمنْيَاثْ تّْوَاقضْعنْ.
\m 
\v 12 ذِي ڒْوقْثْ نِّي أَذْ بقّْشغْ
\m ذِي ؤُرْشَالِيمْ س ڒقْنَاذڒْ،
\m ؤُ نشّْ أَذْ عَاقْبغْ إِرْيَازنْ
\m إِنِّي إِتّْوَاڭْذَارنْ زِي ڒَاثَارْ
\m نِّي إِقِّيمنْ ن بِينُو،
\m إِنِّي إِقَّارنْ ذڭْ وُوڒْ نْسنْ:
\m ’سِيذِي وَارْ إِتّڭّْ ڒْخَارْ
\m ؤُ وَارْ إِتّڭّْ ڒْغَارْ!‘
\m 
\v 13 أَڭْڒَا نْسنْ أَذْ يِيڒِي إِ ثْكشَّاضْثْ
\m ذ ثُوذْرِينْ نْسنْ أَذْ ذوْڒنْثْ ذ ڒْخَارْبثْ.
\m نِيثْنِي أَذْ بْنَانْ ثُوذْرِينْ إِ يِيخفْ نْسنْ،
\m \add مَاشَا\add* وَارْ ذَايْسنْثْ زدّْغنْ شَا،
\m نِيثْنِي أَذْ ژُّونْ ثِيزَايَارِينْ،
\m \add مَاشَا\add* وَارْ سسّنْ زِي بِينُو نّسْ.
\b
\m 
\v 14 أَسّْ أَمقّْرَانْ ن سِيذِي يُوذسْ،
\m أَقَا-ث يُوذسْ، ذغْيَا يُوسَا-د.
\m ڒْْحسّْ ن وَاسّْ ن سِيذِي!
\m أَذْ إِسْغُويْ بُو-ثغْرُوضْثْ ذِينْ
\m س يِيشْثْ ن ثْغُويِّيثْ ثَارْزڭْ. \x ◘ \xo 1:‏14 \xt يُووِ. 2‏:‏10، 31؛ 3‏:‏15؛ إِشا. 13‏:‏6‏-‏13؛ 24‏:‏23؛ Am. 8‏:‏9؛ مت. 24‏:‏29؛ ڒخ. 2‏:‏20؛ أَسَا. 6‏:‏12‏-‏13\x*
\m 
\v 15 أَسّْ نِّي \add أَذْ يِيڒِي\add*
\m ذ أَسّْ ن ؤُذُوقّزْ \add ن ؤُفُوڭمْ\add*،
\m ذ أَسّْ ن ڒحْصَارثْ ذ ضِّيقَا،
\m ذ أَسّْ ن ؤُخَارّبْ ذ وَاردّدْجْ،
\m ذ أَسّْ ن طّْڒَامْ ذ ثَادْجسْثْ،
\m ذ أَسّْ ن إِسيْنُوثنْ ذ ؤُسيْنُو إِبُّومْبسْ،
\m 
\v 16 إِجّْ ن وَاسّْ ن ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي
\m ؤُ ن إِغُويَّانْ \add ن ؤُمنْغِي\add*
\m ضِيدّْ إِ ثْندَّامْ إِفَارْينْ
\m ؤُ ضِيدّْ إِ صُّومْعَاثْ نِّي \add إِدْجَانْ\add*
\m غَارْ ثْغمُّورَا.
\b
\m 
\v 17 نشّْ أَذْ حْصَارغْ إِوْذَانْ
\m ؤُ نِيثْنِي أَذْ ؤُيُورنْ أَمْ يِيذَارْغَاڒنْ،
\m مِينْزِي نِيثْنِي ڭِّينْ دّنْبْ خْ سِيذِي.
\m إِذَامّنْ نْسنْ أَذْ تّْوَازدْجْعنْ
\m أَمشْنَاوْ ثْعجَّاجْثْ،
\m ذ ويْسُومْ نْسنْ أَمشْنَاوْ إِخَّانْ.
\m 
\v 18 ؤُڒَا ذ نُّوقَارْثْ نْسنْ ذ وُورغْ نْسنْ
\m وَارْ زمَّارنْ أَذْ ثنْ سّْنجْمنْ
\m ذڭْ وَاسّْ ن ؤُذُوقّزْ \add ن ؤُفُوڭمْ\add* ن سِيذِي.
\m ثِيمسِّي ن ثُوسْمِي نّسْ \add إِقدّْسنْ\add*
\m أَذْ ثشّْ مَارَّا ثَامُّورْثْ،
\m مَاغَارْ ذغْيَا نتَّا أَذْ إِقْضَا
\m مَارَّا إِمزْذَاغْ ن ثمُّورْثْ. \x ◘ \xo 1:‏18 \xt أَوڒن. 11‏:‏4؛ حِز. 7‏:‏19؛ صَاف.1‏:‏14‏-‏16\x*
\b
\b
\c 2
\s1 ڒْحُوكْمْ خْ ڒْعذْيَانْ ن يَاهُوذَا
\m 
\v 1 سْذوْڒمْ-د إِخفْ نْومْ غَارْ ڒعْقڒْ،
\m ذوْڒمْ-د غَارْ ڒعْقڒْ،
\m \add أَ\add* ڒْڭنْسْ بْڒَا أَسضْحِي،
\m 
\v 2 قْبڒْ إِ غَا إِفّغْ ڒْحُوكْمْ
\m - أَسّْ أَمْ ؤُڒُومْ إِعدُّو -
\m قْبڒْ إِ خَاومْ د غَا يَاسْ
\m ڒْحَاذُوقْ ن وغْضَابْ ن سِيذِي،
\m قْبڒْ إِ خَاومْ د غَا يَاسْ
\m وَاسّْ ن وغْضَابْ ن سِيذِي.
\m 
\v 3 أَرْزُومْ خْ سِيذِي،
\m مَارَّا إِمْوَاضْعنْ ن ثمُّورْثْ،
\m إِنِّي إِتّڭّنْ ڒْحقّْ نّسْ!
\m أَرْزُومْ ثَاسڭْذَا، أَرْزُومْ أَوَاضعْ،
\m أَذْ ثَاغْ أَذْ ثنُّوفَّارمْ كنِّيوْ
\m ذڭْ وَاسّْ ن وغْضَابْ ن سِيذِي. \x ◘ \xo 2:‏3 \xt إِزهد. 27‏:‏5؛ 32‏:‏6، 7\x*
\b
\m 
\v 4 مَاغَارْ غَازَّا أَذْ ثتّْوَاجّْ،
\m أَشْقَالُونْ \add أَذْ ثذْوڒْ\add*
\m ذ إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ،
\m أَشْذُوذْ أَذْ خَاسْ أَزّْڒنْ
\m غَارْ وزْينْ ن وَاسّْ،
\m ؤُشَا عَاقْرُونْ أَذْ ثتّْوَاقْڒعْ.
\m 
\v 5 ؤُشْثْ خْ إِمزْذَاغْ ن ثْمَا ن ڒبْحَارْ،
\m ڒْْڭنْسْ ن إِكَارِيثِييّنْ.
\m أَوَاڒْ ن سِيذِي أَذْ خَاومْ يِيڒِي،
\m \add أَ\add* كنْعَانْ، ثَامُّورْثْ ن إِفِيلِيسْطِينِييّنْ!
\m نشّْ أَذْ كنِّيوْ هلّْكغْ،
\m وَارْ إِتِّيڒِي ؤُمزْذُوغْ عَاذْ.
\m 
\v 6 \add ثَامُّورْثْ نِّي خْ\add* ثْمَا ن ڒبْحَارْ
\m أَذْ ثِيڒِي ذ دّْمَانِي ن ثَاروْسَا،
\m ؤُڒَا ذ وَانُوثنْ إِ إِمكْسَاونْ
\m ذ ڒْكُورِيثْ \add إِ وُودْجِي\add*.
\m 
\v 7 أَذْ ثِيڒِي ثمُّورْثْ إِ مِينْ إِقِّيمنْ
\m ن ثَادَّارْثْ ن يَاهُوذَا،
\m حِيمَا أَذْ ذَايسْ أَروْسنْ \add ثِيحِيمْرِيوِينْ نْسنْ\add*.
\m ذِي ثُوذْرِينْ ن أَشْقَالُونْ
\m أَذْ ذِينْ أَرْسنْ غَارْ ثْمذِّيثْ،
\m مَاغَارْ سِيذِي، أَربِّي نْسنْ،
\m أَذْ غَارْسنْ يَارْزفْ،
\m ؤُ نتَّا إِسّْنقْڒبْ ثَامحْبَاسْثْ نْسنْ.
\b
\m 
\v 8 نشّْ سْڒِيغْ إِ ؤُسحْقَارْ ن مُوآبَ
\m ذ ؤُشقّفْ ن أَيْثْ ن عَامُّونْ،
\m إِ زِي سّْحقَارنْ نِيثْنِي ڒْڭنْسْ إِنُو،
\m ؤُ سّْڭعّْذنْ إِخفْ نْسنْ أَطَّاسْ
\m ضِيدّْ إِ ثمُّورْثْ نْسنْ.
\m 
\v 9 س ؤُيَا، س ثِيذتّْ أَمْ دَّارغْ نشّْ،
\m إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ،
\m أَربِّي ن إِسْرَائِيل:
\m مُوآبَ أَذْ ثذْوڒْ أَمْ سَاذُومْ،
\m ؤُ أَيْثْ ن مُوآبَ أَمْ عَامُورَّا،
\m زِي سِّيبّثْ ن ؤُغمُّويْ ن ثْزڭّْوَارْثْ
\m ؤُ زِي سِّيبّثْ ن وَانُو\add ثنْ\add* ن ثْمدْجَاحْثْ،
\m إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ إِ ڒبْذَا.
\m مِينْ إِقِّيمنْ ن ڒْڭنْسْ إِنُو
\m أَذْ ثنْ إِكشّضْ
\m ؤُ إِنِّي إِقِّيمنْ ن ڒْڭنْسْ إِنُو
\m أَذْ طّْفنْ ثَاسْغَارْثْ نْسنْ ذ ڒْوَارْثْ.
\m 
\v 10 أَيَا \add أَذْ\add* ثنْ \add إِڒْقفْ\add*
\m زِي سِّيبّثْ ن نّْفَاخثْ نْسنْ،
\m مَاغَارْ نِيثْنِي ثُوغَا سّحْقَارنْ
\m ؤُ أَرْزْمنْ أَقمُّومْ نْسنْ
\m خْ ڒْڭنْسْ ن سِيذِي ن ڒْعسْكَارَاثْ.
\b
\m 
\v 11 إِسَّاڭّْوَاذْ أَذْ غَارْسنْ إِفّغْ سِيذِي،
\m مَاغَارْ نتَّا أَذْ إِقْضَا
\m خْ مَارَّا إِربِّيثنْ زِي ثمُّورْثْ،
\m ؤُ نِيثْنِي أَذْ أَسْ بنْذْقنْ،
\m كُوڒْ إِجّْ زڭْ ومْشَانْ نّسْ،
\m مَارَّا ثِيڭْزِيرِينْ ن ڒڭْنُوسْ.
\b
\m 
\v 12 كنِّيوْ عَاوذْ، \add أَ\add* أَيْثْ ن كُوشْ،
\m تّْوَاسّْنُوقّْبنْ نِيثْنِي زِي سِّيفْ إِنُو.
\m 
\v 13 نتَّا أَذْ إِسّْوِيژّضْ
\m س ؤُفُوسْ نّسْ غَارْ شَّامَالْ،
\m نتَّا أَذْ يَاردّدْجْ أَشُّورْ،
\m ؤُ أَذْ يَارّْ نِينْوَا
\m ذ إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ،
\m ثُوژغْ أَمْ ڒخْڒَا.
\m 
\v 14 ذِي ڒْوسْطْ نّسْ أَذْ ڭيّْرنْثْ ثْحِيمْرِيوِينْ،
\m مَارَّا ڒْمَاڒْ نّسْ، أَقَا تّڭّنْ
\m أَمْ يِيجّْ \add ؤُبَارُّو ن\add* ن ڒْڭنْسْ.
\m ؤُڒَا ذ بُو-إِعُوقَّانْ،
\m \add وَاهْ\add* ؤُڒَا ذ ثْوُوشْثْ ن دْجِيڒثْ
\m أَذْ سّنْسنْ خْ إِزدْجِيفنْ ن إِپِيلَارنْ نّسْ.
\m ثْمِيجَّا \add نْسنْ\add* أَذْ ثْغنّجْ زِي ڒْكَازِي،
\m أَردّدْجْ أَذْ يِيڒِي خْ ثْنبْذَاثْ نّسْ،
\m مَاغَارْ ثَافْروْثْ ن ثنْڭلْثْ ثتّْوَاعَارَّا.
\m 
\v 15 ذ ثَا ذ ثَانْذِينْثْ إِسْڒِيوْڒِيونْ،
\m ثنِّي إِقِّيمنْ ذِي ڒَامَانْ،
\m ثنِّي إِنَّانْ ذڭْ وُوڒْ نّسْ:
\m ’نشّْ \add ذ ثنِّي\add*، وَارْ ثدْجِي ذ ثنّغْنِي!‘
\m مَامّشْ ثذْوڒْ
\m ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ،
\m إِشْثْ ن ومْشَانْ ن أَرَّاحثْ إِ ڒْمَاڒْ ن ڒخْڒَا!
\m مَارَّا إِنِّي خَاسْ غَا إِكّنْ،
\m أَذْ \add خَاسنْ\add* إِصفَّارْ \add ؤُ\add* س ؤُسحْقَارْ
\m أَذْ إِسّنْهزّْ أَفُوسْ نّسْ.
\b
\b
\c 3
\s1 ڒْحُوكْمْ خْ ؤُرْشَالِيمْ ذ ڒڭْنُوسْ
\m 
\v 1 ؤُشْثْ خَامْ، ثنِّي إِغوّْغنْ
\m ذ يَارْصُوضنْ،
\m ثَانْذِينْثْ ن دّدْجْ!
\m 
\v 2 نتَّاثْ وَارْ ثتّسْڒِي
\m غَارْ \add ؤُڒَا ذ إِشْثْ ن\add* ثْمِيجَّا،
\m وَارْ ثْقبّڒْ أَودّبْ،
\m نتَّاثْ وَارْ ثتّْشِيڒْ خْ سِيذِي،
\m نتَّاثْ وَارْ ثتّْقَارَّابْ شَا
\m غَارْ أَربِّي نّسْ.
\b
\m 
\v 3 ڒْحُوكَّامْ نّسْ ذِي ڒْوسْطْ نّسْ
\m ذ أَيْرَاذنْ إِتَّارُّوجْذُوذنْ،
\m ڒْقُوضَاثْ نّسْ ذ ؤُشَّاننْ ن دْجِيڒثْ،
\m إِنِّي وَارْ إِتّجِّينْ وَالُو أَڒْ ثُوفُّوثْ. \x ◘ \xo 3:‏3 \xt أَوڒن. 28‏:‏15؛ حِز. 22‏:‏27\x*
\m 
\v 4 إِنَابِييّنْ نّسْ ذَايْسنْ ڒفْشُوشْ،
\m نِيثْنِي ذ إِرْيَازنْ إِخدَّاعنْ!
\m إِكهَّاننْ نّسْ سّْفسْذنْ
\m زَّاوشْثْ إِقدّْسنْ،
\m نِيثْنِي خَالْفنْ شَّارِيعَا. \x ◘ \xo 3:‏4 \xt إِرْم. 23‏:‏11، 32؛ حُوش. 9‏:‏7\x*
\b
\m 
\v 5 سِيذِي أَمْسڭّذْ \add أَقَا-ث\add* ذِي ڒْوسْثْ نّسْ.
\m نتَّا وَارْ إِتّڭّْ شَا مِينْ وَارْ إِسڭّْذنْ.
\m كُوڒْ ثُوفُّوثْ إِتَّارَّا ڒْحقّْ نّسْ غَارْ ثْفَاوْثْ،
\m عمَّارْصْ وَارْ ثْنقّصْ!
\m \add مَاشَا\add* ونِّي إِتّڭّنْ مِينْ وَارْ إِسڭّْذنْ،
\m وَارْ إِسِّينْ شَا أَسضْحِي. \x ◘ \xo 3:‏5 \xt أَعَوذ. 32‏:‏4\x*
\b
\m 
\v 6 نشّْ قْضِيغْ ڒڭْنُوسْ،
\m أَردّْدْجغْ صُّومْعَاثْ نْسنْ ن ثْغمُّورَا.
\m نشّْ خْڒِيغْ إِ ثْبْرِيذِينْ نّسْ،
\m أَڒَامِي ؤُڒَا ذ إِجّنْ وَارْ إِقِّيمْ عَاذْ
\m إِتّْسَارَا ذِينِّي.
\m ثِيندَّامْ نْسنْ تّْوَاردّْدْجنْثْ،
\m وَارْ إِقِّيمْ حذْ،
\m ؤُڒَا ذ إِجّْ ن ؤُمزْذُوغْ.
\m 
\v 7 نشّْ نِّيغْ: إِتّْخصَّا شمْ
\m أَذْ أَيِي ثڭّْوذذْ،
\m أَذْ ثكْسِيذْ أَودّبْ!،
\m حِيمَا وَارْ ثتّْوَاكّسْ ثْزذِّيغْثْ نّسْ،
\m \add س\add* مَارَّا مِينْ ذ أَسْ غَا ڭّغْ.
\m س ثِيذتّْ، نِيثْنِيغوّْغنْ زِيشْ،
\m مَاحنْذْ أَذْ سّْفضْحنْ
\m ثِيمڭَّا نْسنْ أَڒْ طَّارْفْ.
\b
\m 
\v 8 س ؤُيَا رَاجَامْ أَيِي، إِقَّارْ سِيذِي،
\m أَسّْ إِ ذِي د غَا كَّارغْ إِ ثْكشَّاضْثْ.
\m مِينْزِي أَيَا ذ ڒْحُوكْمْ إِنُو \add إِسڭّْذنْ\add*
\m أَقَا أَذْ جَارْوغْ ڒڭْنُوسْ،
\m أَذْ سّْمُونغْ ثِيڭلْذِينْ،
\m حِيمَا أَذْ خَاسنْ سّْفسْيغْ أَسْخضْ إِنُو،
\m مَارَّا ڒْحَاذُوقْ ن وغْضَابْ إِنُو،
\m مَاغَارْ س ثْمسِّي ن ثُوسْمِي إِنُو \add إِقدّْسنْ\add*
\m أَذْ ثتّْوَاشّْ مَارَّا ثَامُّورْثْ.
\b
\s1 تُّوبثْ ن ڒڭْنُوسْ
\m 
\v 9 مِينْزِي خنِّي نشّْ أَذْ بدّْڒغْ
\m \add ڒْْحَارْذْ\add* ن ڒڭْنُوسْ
\m إِينْشِيشنْ إِمزْذَاڭنْ \add أَذْ ثنْ وْشغْ\add*،
\m أَڒَامِي إِ غَا ڒَاغَانْ خْ يِيسمْ ن سِيذِي،
\m حِيمَا أَذْ ثعبّْذنْ \add أَمْ س\add* يِيشْثْ ن ثغْرُوضْثْ.
\m 
\v 10 زڭْ ؤُجمَّاضْ ن إِغزْرَانْ ن كُوشْ،
\m إِنِّي خَافِي إِتّْژَادْجَانْ،
\m يدْجِيسْ ن إِمّْطَارّْشنْ إِنُو،
\m أَذْ \add ت\add* أَوْينْ نِيثْنِي \add أَمشْنَاوْ\add* ثوْهِيبْثْ إِنُو. \x ◘ \xo 3:‏10 \xt إِشا. 66‏:‏20\x*
\m 
\v 11 \bdit ذڭْ وَاسّْ نِّي\bdit* وَارْ ثْسضْحِيذْ شَا \add عَاذْ\add*،
\m خْ مَارَّا ثِيمڭَّا إِ زِي خَافِي ثْغوّْغذْ،
\m مِينْزِي أَذْ كّْسغْ زِي ڒْوسْطْ نّمْ
\m إِنِّي إِتّْفيّْشنْ ذِي نّْفَاخثْ،
\m ؤُ كنِّيوْ وَارْ ثسّْڭعَّاذمْ عَاذْ إِخفْ نْومْ
\m خْ وذْرَارْ إِنُو إِقدّْسنْ.
\m 
\v 12 نشّْ أَذْ جّغْ ذِي ڒْوسْطْ نّمْ
\m إِجّْ ن ڒْڭنْسْ إِتّْوَاحْصَارْ، إِژڒْضْ.
\m نِيثْنِي أَذْ أَروْڒنْ غَارْ يِيسمْ ن سِيذِي.
\m 
\v 13 مِينْ إِقِّيمنْ ن إِسْرَائِيل
\m وَارْ إِتّڭّْ مِينْ وَارْ إِسڭّْذنْ،
\m نِيثْنِي وَارْ سّْخَارِّيقنْ شَا،
\m ؤُ ذڭْ ؤُقمُّومْ نْسنْ
\m وَارْ إِتّتّْوِيفِي يِيڒسْ إِسّْخَارِّيقنْ،
\m مَاشَا نِيثْنِي أَذْ هدَّانْ أَذْ زّْڒنْ،
\m ؤُ ؤُڒَا ذ إِجّنْ أَذْ ثنْ إِسّْنخْڒِيعْ.
\b
\s1 ڒفْرَاحثْ ن إِسْرَائِيل ذ وعْذَاڒْ نّسْ
\m 
\v 14 غنّجْ، \add أَ\add* يدْجِيسْ ن صِيهْيُونْ،
\m سْڒِيوْڒوْ، \add أَ\add* إِسْرَائِيل.
\m فَارْحْ ؤُ ثْفَادْجِيذْ س مَارَّا ؤُڒْ نّمْ،
\m \add أَ،\add* يدْجِيسْ ن ؤُرْشَالِيمْ! \x ◘ \xo 3:‏14 \xt زَاك. 9‏:‏9\x*
\m 
\v 15 سِيذِي إِكّسْ ڒحْكَامَاثْ نّمْ،
\m نتَّا أَقَا إِمْحَا ڒعْذُو نّمْ.
\m أَجدْجِيذْ ن إِسْرَائِيل،
\m سِيذِي، أَقَا-ث ذِي ڒْوسْطْ نّمْ!
\m وَارْ ثْژَارّذْ عَاذْ ڒْغَارْ.
\m 
\v 16 \bdit ذڭْ وَاسّْ نِّي\bdit* أَذْ إِنِينْ إِ ؤُرْشَالِيمْ:
\m وَارْ تّڭّْوذْ شَا، صِيهْيُونْ!
\m وَارْ تّجِّي إِفَاسّنْ نّمْ
\m أَذْ أَرْخُونْعمَّارْصْ \add عَاذْ\add*!
\m 
\v 17 سِيذِي، أَربِّي نّمْ، أَقَا-ث ذِي ڒْوسْثْ نّمْ،
\m بُو-ثغْرُوضْثْ نِّي إِ د غَا يَاوْينْ أَسنْجمْ
\m نتَّا أَذْ زَّايمْ إِفَارْحْ س وَاطَّاسْ،
\m نتَّا أَذْ إِسغْضْ ذِي ثَايْرِي نّسْ،
\m نتَّا أَذْ خَامْ إِسْڒِيوْڒوْ س ؤُغنّجْ.‘
\b
\m 
\v 18 نشّْ أَذْ سّْمُونغْ إِنِّي إِشطّْننْ
\m \add ؤُمِي وَارْ زمَّارنْ أَذْ شَارْشنْ\add*
\m \add ذِي\add* ثْمسْمُونْثْ إِتّْوَاڭّنْ \add إِ ڒْعِيذْ\add*.
\m أَقَا نِيثْنِي زَّايمْ!
\m دّْقڒْ ن ڒْحڭْرَا أَقَا-ث خَاسْ.
\m 
\v 19 خْزَارْ، نشّْ أَذْ شغْڒغْ إِخفْ إِنُو
\m أَكْ-ذ يِينِّي شمْ إِحْصَارنْ.
\m نشّْ أَذْ سّْنجْمغْ إِقجْذَاحنْ
\m ؤُ يِينِّي إِتّْوَاسُّوفّْغنْ أَذْ ثنْ سّْمُونغْ.
\m نشّْ أَذْ أَسنْ وْشغْ ڒْعزّْ
\m ذ يِيجّْ ن إِسمْ إِشنّْعنْ،
\m ذِي مَارَّا دُّونشْثْ
\m نِّي ثنْ ثُوغَا إِسّْفطّْحنْ.
\m 
\v 20 ذِي ڒْوقْثْ نِّي أَذْ كنِّيوْ د-أَرّغْ،
\m ؤُ ذِي ڒْوقْثْ نِّي أَذْ كنِّيوْ سّْمُونغْ،
\m نشّْ أَذْ أَومْ وْشغْ
\m إِجّْ ن يِيسمْ \add إِشنّْعنْ\add* ذ ڒْعزّْ
\m جَارْ مَارَّا ڒڭْنُوسْ ن دُّونشْثْ،
\m خْمِي إِ زَّايْومْ غَا سّنْقڒْبغْ
\m ثَامحْبَاسْثْ نْومْ
\m زَّاثْ إِ ثِيطَّاوِينْ نْومْ،
\m إِنَّا سِيذِي. 
