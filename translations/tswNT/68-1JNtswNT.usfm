\id 1JN NT0023 Tsishingini (tsw) (Salka Kambari) KLP Feb. 2011
\h 1 Yahaya
\toc1 Mepepelime mo Ufaru ma Yahaya
\toc2 1 Yahaya
\toc3 1 Yah.
\mt2 Mepepelime mo Ufaru ma
\mt1 Yahaya
\is1 Ucuɗuwu wa aatagada a nda
\ip Yahaya ɗana ta̱ mpepelime n wawaꞌa aza a taꞌatsu a̱ tyo ama kokoꞌo. E mepepelime mo ufaru ma nda, u ɗe ta̱ a̱za̱ e ɗesununa̱ va̱ yi muwun ma̱ yi. Ana wo oꞌwoi Yahaya aajiya a ɗa waru zagbain va̱ a̱za̱ e Itoni a ɗa a mantsaꞌa, u ta dansa mepepelime ma nda za va̱ a̱za̱ e Itoni a ɗa suru.
\ip A̱tsuma̱ a aatagada a nda, Yahaya yuwan ta̱ adanshi cine vuma a̱a̱ da̱na̱ zuzu na̱ A̱sula̱ a yuwusaan yi a̱ga̱nda̱. U yuwan ta̱ adanshi cine a̱a̱ da̱na̱ zuzu na̱ A̱sula̱ e re re. Ure wu ufaru a̱yi ɗa vuma isawan a̱tsuma̱ e ekan a̱ A̱sula̱. Ure we ire a̱yi ɗa vuma isawan a̱tsuma̱ e icigi ya̱ A̱sula̱.
\ip Aatagada a nda a damma tsu ta̱ a na tsi isawan a̱tsuma̱ e ekan a̱yi ɗa tsu yuwan wuma cine A̱sula̱ a cigai, ne ɗa ili i ro ya̱a̱ da̱na̱ lo usokowu e ekere a ama ko uba̱ta̱ wa̱ A̱sula̱ shi. Aatagadaꞌa fo u damma ta̱ a na vuma isawan a̱tsuma̱ e icigi ya̱ A̱sula̱ a̱yi ɗa a cigalai pa a̱tsuma̱ o uvaɗi. O ukosu, u cuwaan tsu ta̱ na tsu ri na̱ a̱ba̱jini o ulyuwu wa aci na̱ tsu ri uɓolu na̱ Zamawawa.
\is1 Ili i na i ri pe a̱tsuma̱ a aatagada a nda
\io1 1. Adanshi a na a tsu ca Wuma (1:1-4)
\io1 2. A̱sula̱ ekan a ɗa waru Zamawawa ɗa iroci i tsu (1:5–2:6)
\io1 3. Wila̱ u Saꞌavu (2:7-17)
\io1 4. Nꞌyuwatan mu Zamawawa na̱ Muwun ma̱ A̱sula̱ (2:18–3:10)
\io1 5. Icigi ya̱ A̱sula̱ ni icigi i tsu (3:11–4:21)
\io1 6. Ulyuwu wa aci wu uvaɗi (5:1-21)
\c 1
\s1 Adanshi a wuma
\p 
\v 1 Za na da̱na̱i wuma diga a mantsa mo ufaru, a̱yi ɗa tsu uwwai adama a̱ yi, waru tse ene yi ta̱ ne esu a̱ tsu, reve tsu ka̱lyuwa̱ yi ulobonu, waru tsu juꞌwa̱n yi ta̱ ne ekere a̱ tsu. A̱yi ɗa Yesu Kristi Zamawawa, Adanshi a wuma.
\v 2 Za na a casu wuma ta̱wa̱ ta̱ uba̱ta̱ u tsu! Tse ene yi ta̱, waru a̱tsu esu e ili i na tse enei ɗa. Gogo tsu ta dansaa ɗu adama a wuma a babu ukotu za na da̱na̱i na̱ Dada reve u ta̱wa̱ uba̱ta̱ u tsu.
\v 3 Ili i na tse enei waru tsu uwwai i ɗa tsaa dansaa ɗu, tsa̱ra̱ a̱ɗu fo i yuwan nden m muwwulai oɓolo na̱ a̱tsu. Waru nden n tsu oɓolo na̱ Dada na̱ Mawun ma̱ yi Yesu Zamawawa ɗa.
\v 4 Tsu ɗanaa ɗu ta̱ ili i nda tsa̱ra̱ i da̱na̱ tapu na̱ ma̱za̱nga̱ oɓolo na̱ a̱tsu.
\s1 A̱sula̱ ekan a ɗa
\p 
\v 5 Apa a nda ikaka i na tsu uwwai uba̱ta̱ wa̱ Yesu Zamawawa a̱yi ɗa gba tsaa dansaa ɗu gogo: A̱sula̱ ekan a ɗa, waru u ri ni irumbu shi, ko keꞌen.
\v 6 Na̱ tsu damma tsu ta̱ a̱ nden oɓolo na̱ A̱sula̱, agba a̱tsuma̱ e irumbu i ɗa tsu ri nden, epen a ɗa tsaa yuwusan, tsoo tono amayun shi.
\v 7 Amma na̱ tsu ri nden a̱tsuma̱ e ekan, ununa A̱sula̱ a̱ ri a̱tsuma̱ e ekan, tsu ta̱ a̱ nden m muwwulai. Waru mpasa m Mawun ma̱ yi Yesu n ta̱ za̱za̱ꞌusa̱ nusu tsu.
\p 
\v 8 Na̱ tsu damma koto tsu yuwan unusu shi, aciya̱tsu a ɗa tsa̱a̱ lumusa̱, waru amayun a̱ ri pe a̱tsuma̱ a̱ tsu shi.
\v 9 Amma na̱ tsu damma nusu tsu, u ta yuwaan tsu gafura vu nusu tsu adama a na a̱yi za na tsu shiton nzuwulai n ɗa, waru a̱yi za na tsu yuwan ili na̱ a̱ɓula̱ a ɗa. A̱yi waru u ta̱ za̱ꞌwa̱ tsu diga a̱ nusu na tsu yuwain.
\v 10 Na̱ tsu damma koto tsu yuwan unusu shi, tsu ta̱ ka̱mbuwusa̱ A̱sula̱ za ve epen, waru tsu to rocosu ikaka ya̱ yi i ri nu uba̱ta̱ wu nden o okolo a̱ tsu shi.
\c 2
\s1 Yesu ɗa za vi ikambi i tsu
\p 
\v 1 Ncigata m muwun n va̱, n ta ɗanasaa ɗu ili i nda adama i yuwan unusu wan.
\p Agba na̱ tsu yuwan unusu, Yesu Zamawawa za na ri za va̱ a̱ɓula̱, u ta pati Dada o una̱ u tsu.
\p Agba ni i yuwan unusu, Yesu Zamawawa tsu yuwan ta̱ ili i na yi ntsayi kuci, u ta pati Dada o una̱ u tsu.
\v 2 A̱yi ɗa kucci adama a̱ nusu tsu. Nusu tsu ɗa u tarai goon shi, amma hali na̱ nusu va ama a̱tsuma̱ o uvaɗi suru.
\p 
\v 3 Tsu te reve na amayun tsu reve ta̱ A̱sula̱ na̱ tsu toni ikaka i na u dammai suru.
\v 4 Za na suru dammai, “N reve ta̱ A̱sula̱,” agba u yuwan tsutoni ni ili i na u dammai shi, vuma ndolo za ve epen ɗa, waru amayun a̱ ri pe a̱tsuma̱ a̱ yi shi.
\v 5 Amma na̱ tsu yuwan tsutoni ni ili i na A̱sula̱ a dammai, tsundolo tsa ɗa icigi ya̱ A̱sula̱ yaa lamba ili i ro a̱tsuma̱ a̱ tsu shi, ne ɗa waru tsee reve tsu ta̱ pe a̱tsuma̱ a̱ yi.
\v 6 Na̱ tsu damma a̱tsu ama a̱ yi a ɗa, tsu yuwain cine Yesu yuwain.
\s1 A̱sula̱ a damma tsu cigai ama
\p 
\v 7 Ncigata n va̱, maa ɗanasaa ɗu tsa̱ra̱ n ca ɗu wila̱ u saꞌavu shi. Za na a fara ca nɗu ɗaɗa, waru ikaka i na yu uwwai ɗe ɗa.
\v 8 Amma hali n gogo u tu usaꞌavu. Zamawawa roco ta̱ wila̱ u nda amayun a ɗa, a̱ɗu waru i roco ta̱ ne. Ye ene ta̱ irumbu i ta̱ ma̱ka̱ra̱, waru ekan a amayun a̱ te ikanasa ulobonu.
\p 
\v 9 Vuma na dammai suru, “N ta̱ a̱ nden a̱tsuma̱ e ekan,” a̱vu u ꞌyuwan za va̱ yi, cuꞌun vuma ndolo hali n gogo u ta̱ pe nden a̱tsuma̱ e irumbu.
\v 10 Za na cigai a̱za̱ a̱ yi suru u ta a mmalu a̱tsuma̱ e ekan, waru wa̱a̱ ta̱wa̱a̱ nu uta̱ɗa̱tsa̱sa̱ shi.
\v 11 Na̱ tsu ꞌyuwan ozo o ro, tsu ta̱ nden a̱tsuma̱ e irumbu, waru tsu ta̱ a mmalu a̱tsuma̱ e irumbu. Tsu reve uba̱ta̱ u na tsa̱a̱ tyo shi, adama a na tsaa gura ene ili a̱tsuma̱ e irumbu shi.
\q1 
\v 12 N ta ɗanasaa ɗu muwun n va̱,
\q1 adama a na A̱sula̱ a yuwaan ɗu ta̱ gafura vu nusu ɗu a̱tsuma̱ a ala e Yesu Zamawawa.
\q1 
\v 13 N ta ɗanasaa ɗu nan dada,
\q1 adama a na i reve yi ta̱, vuma na shi diga o ufaru.
\q1 N ta ɗanasaa ɗu olobo ne esheli,
\q1 adama a na i lyuwa ta̱ aci a za vi iwuya.
\q1 N ta ɗanasaa ɗu muwun,
\q1 adama a na i reve ta̱ Dadaꞌa.
\q1 
\v 14 N ta ɗanasaa ɗu nan dada,
\q1 adama a na i reve yi ta̱, vuma na shi diga o ufaru.
\q1 N ta ɗanasaa ɗu olobo ne esheli,
\q1 adama a na i ta̱ nu ucira.
\q1 Adanshi a̱ A̱sula̱ a̱ ta̱ pe a̱tsuma̱ a̱ ɗu,
\q1 waru i lyuwa ta̱ aci a za vi iwuya.
\p 
\v 15 She i ciga uvaɗi ko ili yu uvaɗi wan. Ni i ciga uvaɗi, icigi ya Dada yi pe a̱tsuma̱ a̱ ɗu shi.
\v 16 Apa re vu uvaɗi: tsu ciga ta̱ tsu uwwaa aciya̱tsu uyoꞌo wu unusu, icigi yi iwuya i na tse eneshe, waru a̱ ꞌya̱sa̱sa̱n avangaci adama e ili i na tsu ri na̱ a̱yi. A̱tsuma̱ e le babu ili i na yu uta̱i ya Dada, amma suru nle o uvaɗi u ɗa o uta̱i.
\v 17 Uvaɗi ni ili i na i ri pe suru a na ama a cigai suru o to koto, amma vuma na o tonishi ili i na A̱sula̱ a cigai u ta̱ tsura̱ wuma u babu ukotu.
\s1 Maꞌyuwatan ma̱ Yesu
\p 
\v 18 Ncigata m muwun n va̱, rana vu ukosu ɗa ndaꞌa. Yu uwwa ta̱ ɗe a na maꞌyuwatan ma Zamawawa ma̱ ri lo a̱ ta̱wa̱, gogo gba nꞌyuwatan ma̱ a̱bunda̱ mu Zamawawa n ta̱ pa. Ne ɗa tsu revei a na rana vu ukosu ɗa.
\v 19 Ama a nda a lyawa ta̱ a̱ꞌisa̱ a̱ a̱za̱ e Itoni a̱ tsu, adama a na ko ɗe e pe a̱tsuma̱ a̱ tsu na amayun shi. Na̱ a̱ shi pe a̱tsuma̱ a̱ tsu na amayun, a̱ shi te isawan oɓolo na̱ a̱tsu. Uka̱ru u le u roco ta̱ a̱ pe a̱tsuma̱ a̱ tsu shi.
\p 
\v 20 I ta̱ nu uneꞌe u na Za va Akiza ca nɗu, adama o ndolo suru nɗu i reve ta̱ amayun.
\v 21 She na̱ n ɗanaa ɗu adama a amayuꞌun shi, adama a na i reve yi ta̱ ɗe. I reve ta̱ a na ama e epen e pe a̱tsuma̱ a amayun shi.
\v 22 Zane ɗa za ve epeꞌen? Vuma na wasain Yesu a̱yi ɗaɗa Zamawawaꞌa, a̱yi ɗa za ve epen. Vuma na dammai ne suru, a̱yi maꞌyuwatan ma Zamawawa ma ɗa, waru u ꞌyuwan ta̱ Dadaꞌa na̱ Mawuꞌun.
\v 23 Vuma na wasain Mawuꞌun, vuma ndolo fo u wasan ta̱ Dada. Amma na̱ tsu damma tsu usu ta̱ Mawuꞌun, tsu usu ta̱ Dada fo.
\p 
\v 24 I lyuwa elime ni itoni yu uritosu u na i tsura̱i nu ufaru. Ni i lyuwa elime ni itoni yi ili i na i tsura̱i nu ufaru, i ta̱ da̱na̱ oɓolo na̱ Mawuꞌun waru oɓolo na̱ Dadaꞌa.
\v 25 Apa ili i na Zamawawa yuwaan tsu nzuwulai n na waa ca tsu: u ta ca tsu wuma u babu ukotu.
\p 
\v 26 N ta ɗanasaa ɗu tsa̱ra̱ n rono ɗu atsuvu adama ama a na a cigai a̱ luluma̱ ɗu.
\v 27 Amma a̱ɗu, Zamawawa tsuwa̱n ɗu ta̱ Ruhu va̱ yi. Na̱ Ruhu va̱ yi ri oɓolo na̱ a̱ɗu, yaa ciga nanza roco ɗu shi. Adama a na Ruhu va̱ yi tsu rito ɗu ta̱ ili suru, waru ili i na woo ritosu amayun a ɗa, epen a ɗa shi. I toni uritosu u Ruhu, waru i lyuwa elime na̱ moɓolo na̱ Zamawawa.
\p 
\v 28 Amayun, ncigata m muwun n va̱, i lyuwa elime oɓolo na̱ Zamawawa, adama nu u ka̱mba̱, tsu to oꞌwo babu wovon waru tsu uwwai wono a̱ ma̱ka̱ka̱n ma̱ yi wan.
\v 29 I reve ta̱ Zamawawa ta̱ na̱ a̱ɓula̱. I reve waru vuma na a yuwusan ili ya̱ a̱ɓula̱ suru wo oꞌwo ta̱ mawun ma̱ A̱sula̱.
\c 3
\s1 A̱tsu muwun ma̱ A̱sula̱ n ɗa
\p 
\v 1 Dada ciga tsu ta̱ a̱bunda̱ lon, adama o ndolo a ɗa e ɗe ntsu muwun ma̱ A̱sula̱. Amayun a̱tsu muwun ma̱ yi n ɗa. Adama a na ama o uvaɗi e revei Dadaꞌa shi, a̱yi ɗa i zuwai e reve ntsu shi.
\v 2 Nꞌutsa̱ n na n cigai, gogo a̱tsu muwun ma̱ A̱sula̱ n ɗa, agba koto u roco tsu ili i na tsoo oꞌwo shi, na̱ Yesu Zamawawa ka̱mba̱. Agba tsu reve ta̱ nu u ta̱wisa̱, tsu to oꞌwo cine u ri, adama a na tsu te ene yi cine u ri na amayun.
\v 3 Aza a na a̱ usuyi adanshi a nda a̱ guza̱sa̱ aciyele cece cine Zamawawa ri cece.
\p 
\v 4 Vuma na yuwain unusu suru u kuɗa ta̱ wila̱ wa̱ A̱sula̱, adama a na unusu una̱ta̱ u ɗa u ri na̱ nla̱ngi na̱ A̱sula̱ oɓolo na̱ wila̱ wa̱ yi.
\v 5 I reve ta̱ Yesu Zamawawa ta̱wa̱ ta̱ tsa̱ra̱ u tawa unusu, waru a̱yi u ri nu unusu shi.
\v 6 Adama o ndolo vuma na a̱a̱ da̱nu oɓolo na̱ a̱yi waa lyuwa elime na̱ mayan mo unusu shi. Vuma na gba lyuwai elime na̱ mayan mo unusu koto we ene yi shi waru koto u reve yi shi.
\p 
\v 7 Muwun n va̱ she i lyawa nanza luluma̱ ɗu adama e ili i nda wan: na ama a yuwusan nden n saꞌani, a ta yuwusan ne adama a na a̱za̱ a̱ a̱ɓula̱ a ɗa, cine Yesu Zamawawa ri na̱ a̱ɓula̱.
\v 8 Vuma na lyuwai elime na̱ mayan mo unusu wo oꞌwo ta̱ vuma Mekerenkesu.† Mekerenkesu ma ta yuwusan unusu diga o ufaru. Agba Mawun ma̱ A̱sula̱ ma̱ ta̱wa̱ ta̱ tsa̱ra̱ u lungusa̱ linga va̱ yi.
\v 9 Aza a na a̱ ri muwun ma̱ A̱sula̱ a tsu lyuwa elime na̱ mayan mo unusu shi, adama a na u ca nle wuma u saꞌavu. Waru adama a na A̱sula̱ a ɗa Dada le, aa gura lyuwa elime na̱ mayan mo unusu shi.
\v 10 Tsu ta gura reve ko zane ɗa mawun ma̱ A̱sula̱, waru ko zane ɗa mawun me Mekerenkesu. Vuma na a yuwusan ili i saꞌani shi suru, mawun ma̱ A̱sula̱ ma ɗa shi. Vuma na gba cigai za va̱ yi shi, mawun ma̱ A̱sula̱ ma ɗa shi.
\s1 I cigalai
\p 
\v 11 Cuꞌun vi ikaka i nda a̱yi ɗa yu uwwai diga o ufaru: tsu cigalai.
\v 12 She yoo oꞌwo ana Ka̱yinu† wan, za na oꞌwoi za vu za vi iwuya reve wu una zawaꞌa va̱ yi. Nye i zuwai wu una niyi? Adama e ili i na Ka̱yinu yuwain iwuya i ɗa, agba ili i na zawaꞌa va̱ yi yuwain isaꞌani i ɗa.
\v 13 Nꞌutsa̱ n va̱, she i yuwan asalama wan na ama o uvaɗi a nda a ꞌyuwan nɗu.
\v 14 Icigi i na tsu cigalai u roco ta̱ tsu pasa ta̱ ukwa̱ a̱ tyo wuma. Vuma na ri ni icigi cuꞌun nda shi, u buwa ta̱ ukwa̱.
\v 15 Vuma na ꞌyuwain za va̱ yi za mona ɗa, waru i reve ta̱ a̱za̱ a̱ mona a̱ ri na̱ wuma u babu ukotu a̱tsuma̱ e le shi.
\p 
\v 16 Apa cine tsu revei ili i na a̱ tsu ɗe icigi: Yesu ca ta̱ wuma wa̱ yi adama a̱ tsu. Adama o ndolo a̱tsu fo u lobono ta̱ tsu cayi wuma u tsu adama a ama o ro!
\v 17 A damma za ro ta̱ nu utsuru a̱vu we ene vali ko ka nu ulambu, reve u ꞌyuwan a kamba yi. Icigi ya̱ A̱sula̱ i ri a̱tsuma̱ a̱ cuꞌun vuma ndolo shi.
\v 18 Muwun, tsu roco ta̱ icigi a̱ tyo uba̱ta̱ wa ama, na̱ tsu kamba le na amayun, amma tsu yuwusain adanshi a aci a̱ yi goon wan.
\v 19 Na̱ tsu ciga ama, tsu reve ta̱ na tsu ri pe a̱tsuma̱ a amayun, waru tsu ta̱ na asuvu nden a̱ ma̱ka̱ka̱n ma̱ A̱sula̱.
\v 20 Amma na̱ tsu ri na asuvu nden a̱tsuma̱ a̱ tsu shi adama o wono, to, A̱sula̱ a laꞌa ta̱ okolo a̱ tsu, waru u reve ta̱ ili suru.
\p 
\v 21 Nꞌutsa̱ n va̱, na̱ tsu ri na asuvu nden a̱tsuma̱ a̱ tsu, tsu ta̱ da̱na̱ a̱ ma̱ka̱ka̱n ma̱ A̱sula̱ babu wovon.
\v 22 U ta ca tsu ili i na tsu patiyi suru, adama a na tsu to tono yi waru tsu ta yuwusan ili i na yoo yoꞌonotosu yi okolo.
\v 23 Apa ili i na A̱sula̱ a dammai: tsu usuyi Mawun ma̱ yi, Yesu Zamawawa, a̱vu waru tsu cigalai. A̱yi ɗa waru ili i na Yesu roco ntsu tsu yuwan.
\v 24 Aza a na aa yuwusan tsutoni na̱ wila̱ wa̱ A̱sula̱, a̱ ta̱ pe nden a̱tsuma̱ a̱ A̱sula̱, waru fo u ta̱ pe a̱tsuma̱ e le. Tsu reve ta̱ A̱sula̱ a̱ ta̱ pe nden a̱tsuma̱ a̱ tsu adama a̱ Ruhu na A̱sula̱ a ca ntsu.
\c 4
\s1 Munlu me epen
\p 
\v 1 Ncigata n va̱, she i usu vuma na ta̱wa̱i suru a dansa u ta̱ na̱ Ruhu va̱ A̱sula̱ wan. I lyungwa̱ le neꞌen suru, tsa̱ra̱ i reve ko amayun a ɗa o uta̱ ta̱ uba̱ta̱ wa̱ A̱sula̱. Ama a̱ A̱sula̱ e epen a̱ a̱bunda̱ a̱ ka̱ra̱ ta̱ ɗe a uwa a̱tsuma̱ o uvaɗi.
\v 2 Apa cine yee reve Ruhu va̱ A̱sula̱: Vuma uta̱ ta̱ uba̱ta̱ wa̱ A̱sula̱ nu u damma Yesu Zamawawa ta̱wa̱ ta̱ o uvaɗi tsu vaɗilima̱.
\v 3 Amma vuma na wasain adanshi a nda a adama e Yesu u ri na̱ Ruhu va̱ A̱sula̱ shi. Cuꞌun ruhu vuma ndolo wu uta̱ ta̱ uba̱ta̱ u maꞌyuwatan ma̱ Zamawawa. I reve ta̱ ɗe a na maꞌyuwatan mo ndolo ma̱ ta̱ ta̱wa̱ a̱tsuma̱ o uvaɗi, waru u ta̱wa̱ ta̱ ɗe.
\p 
\v 4 Muwun n va̱, a̱ɗu a̱za̱ a̱ A̱sula̱ a ɗa, waru i lyuwa ta̱ aci a nꞌyuwatan n ndolo. Ruhu va̱ A̱sula̱ ta̱ pe a̱tsuma̱ a̱ ɗu, waru u laꞌa ta̱ za na ri pa o uvaɗi ucira lon.
\v 5 Nꞌyuwatan n ndolo a ta yuwusan adanshi e ili yu uvaɗi adama a na ele fo a̱za̱ o uvaɗi a ɗa, waru ama o uvaɗi a tsu zuwaa le ta̱ atsuvu.
\v 6 A̱tsu gba ama a̱ A̱sula̱ a ɗa, a̱yi ɗa i zuwai aza a na e revei A̱sula̱ aa zuwusaa tsu atsuvu. Na ama a̱ A̱sula̱ a ɗa shi, aa zuwaa tsu atsuvu shi. Ne ɗa tsee reve ko vuma ta̱ na̱ Ruhu va amayun ko ruhu ve epen.
\s1 Uba̱ta̱ wa̱ A̱sula̱ u ɗa icigi i tsu uta̱
\p 
\v 7 Nꞌutsa̱ n va̱, tsu cigalai, adama a na icigi e ekere a̱ A̱sula̱ a ɗa wu uta̱i. Za na rocoi icigi suru mawun ma̱ A̱sula̱ ma ɗa, waru u reve ta̱ A̱sula̱.
\v 8 Vuma na ri ni icigi shi, u reve A̱sula̱ shi, adama a na A̱sula̱ icigi i ɗa.
\v 9 A̱sula̱ o roco tsu ta̱ icigi ya̱ yi ana u lyunguyi Mawun ma̱ ta̱ ma̱ yi a̱tsuma̱ o uvaɗi tsa̱ra̱ u ca tsu wuma.
\v 10 Apa icigi ya amayun: A̱tsu ɗa tsu cigai A̱sula̱ shi, amma a̱yi ɗa u ciga ntsu ɗaɗa u lyunguyi Mawun ma̱ yi wo oꞌwo kucci vi ili i na yaa tawa nusu tsu.
\v 11 Nꞌutsa̱ n va̱, adama a na A̱sula̱ a ciga ntsu tsunda, a̱tsu fo tsu cigalai.
\v 12 Babu vuma na enei ɗe A̱sula̱, amma na̱ tsu cigalai, A̱sula̱ a̱ to oɓolo na̱ a̱tsu, waru icigi ya̱ yi i ta̱ tapu a̱tsuma̱ a̱ tsu.
\p 
\v 13 A̱sula̱ a ca tsu ta̱ Ruhu va̱ yi. Ne ɗa tsu revei a na tsu ri oɓolo na̱ a̱yi cine u ri oɓolo na̱ a̱tsu.
\v 14 A̱sula̱ a̱ lyungu ta̱ Mawun ma̱ yi wo oꞌwo Za vi Iwawi yu uvaɗi. Tse ene yi ta̱, ɗaɗa i zuwai tsaa dansaa ama o ro adama a̱ yi.
\v 15 Za na tarai Yesu Mawun ma̱ A̱sula̱ ma ɗa, u to oɓolo na̱ A̱sula̱, A̱sula̱ fo u to oɓolo na̱ a̱yi.
\v 16 A̱tsu aciya̱tsu tsu reve ta̱ cine A̱sula̱ a ciga ntsu lon, waru tsu ca ta̱ okolo a̱ tsu e ekere a̱ yi suru suru.
\p A̱sula̱ icigi i ɗa. Na̱ tsu lyuwa elime na̱ ncigalai, tsu to oɓolo na̱ A̱sula̱, waru u to oɓolo na̱ a̱tsu.
\v 17 Na̱ tsu ciga a̱za̱ a̱ tsu ni icigi ya amayun, a̱vu tsu da̱nu cine Zamawawa yuwain a̱tsuma̱ o uvaɗi u nda, tsaa uwwa wovon o urana wu ugeꞌetosu shi.
\v 18 Babu wovon a̱tsuma̱ e icigi, icigi ya amayun i tsu lo ta̱ wovon. Na̱ vuma ri a uwwusa wovon u ta majiyan gashi a ta ca yi oforo. Na̱ vuma ri a uwwusa wovon, icigi ya̱ A̱sula̱ koto i ri ugbamu a̱tsuma̱ a̱ yi shi.
\p 
\v 19 Tsu te icigi adama a na A̱sula̱ a ɗa a fara neꞌen ciga ntsu.
\v 20 Na̱ vuma damma, “N ciga ta̱ A̱sula̱,” a̱vu u ꞌyuwan za va̱ yi, za ve epen a ɗa. Aza a na a cigai a̱za̱ e le a na e eneshe kuci shi, aa ciga A̱sula̱ a na koto e enei shi.
\v 21 Apa wila̱ u na A̱sula̱ a ca ntsu: aza a na a cigai A̱sula̱ a ciga a ꞌyuwan a ciga a̱za̱ e le.
\c 5
\s1 Ulyuwu wa aci wu uvaɗi
\p 
\v 1 Vuma na usuyi suru a na Yesu Zamawawa ɗa, mawun ma̱ A̱sula̱ ma ɗa. Vuma na cigai dada u ciga ta̱ mawun ma̱ yi fo.
\v 2 Apa cine tsu revei tsu ciga ta̱ muwun ma̱ A̱sula̱: na̱ tsu ciga A̱sula̱ a̱vu tsu yuwan ntoniloi ni ili i na u dammai.
\v 3 Tsu roco ta̱ tsu ciga ta̱ A̱sula̱ na̱ tsu yuwan ntoniloi na̱ wila̱ wa̱ yi, waru a̱ ri usa̱n u na tsa̱a̱ kuru shi.
\v 4 Vuma na ri mawun ma̱ A̱sula̱ suru, u ta lyuwa aci o uvaɗi, waru ucawu wo okolo a̱ tsu a̱yi ɗa ili i na i tsu ca tsu malyuwa ma aciꞌi.
\v 5 Zane ɗa aa gura lyuwa aci o uvaɗi? She vuma na usuyi Yesu ɗa Mawun ma̱ A̱sula̱.
\s1 Adanshi a saꞌani adama e Yesu
\p 
\v 6 Yesu Zamawawa ɗa ta̱wa̱i ya̱ꞌa̱ tsu o ure u na a̱ rumbu niyi na̱ mini na̱ mpasa mo ukwa̱ ma̱ yi. O ure u mini ma ɗa u ta̱wa̱i goon shi, amma oɓolo na̱ mpasa na̱ mini. Waru Ruhu na aciya̱yi u damma ta̱ adanshiꞌi amayun a ɗa, adama a na Ruhuꞌu a amayun a ɗa.
\v 7 Ili i taꞌatsu i ta̱ lo i na i yuwain adanshi adama e Yesu:
\v 8 Ele ɗa Ruhu, na̱ mini, oɓolo na̱ mpasa, suru nle adanshi a amayun a̱ ta̱ a ɗa aa yuwusan.
\v 9 Tsu usu ta̱ ama na a damma ili i ro amayun a ɗa. Amma ili i na A̱sula̱ a dammai u laꞌa ta̱ ucira, waru ili ya amayun a na u damma ntsu a̱yi ɗa adama a Mawun ma̱ yi.
\v 10 Za na usuyi Mawun ma̱ A̱sula̱ suru u reve ta̱ ili i na A̱sula̱ a dammai a aci a̱ yi amayun a ɗa. Amma za na usuyi ili i na A̱sula̱ a dammai amayun a ɗa shi, nu u yuwan tsundolo u ɗe ta̱ A̱sula̱ za ve epen.
\v 11 Apa ili i na A̱sula̱ a damma ntsu: A̱sula̱ a ca tsu ta̱ wuma u babu ukotu, waru Mawun ma̱ yi, a̱yi ɗa u zuwai wuma u ndolo wo oꞌwo ne.
\v 12 Vuma na ri na̱ Mawuꞌun u ta̱ na̱ wuma u nda, za na waru ri na̱ Mawun ma̱ A̱sula̱ shi u ri na̱ wumaꞌa shi.
\s1 Wuma u babu ukotu
\p 
\v 13 N ta ɗanasaa ɗu aza a na a̱ usuyi Mawun ma̱ A̱sula̱, tsa̱ra̱ i reve i ta̱ na̱ wuma u babu ukotu.
\v 14 Tsunda tsu ta gura ꞌya̱wa̱ uba̱ta̱ wa̱ A̱sula̱ babu wovon, waru tsu reve ta̱ u ta uwwa tsu na̱ tsu pati yi ili i na u cigaa ntsu.
\v 15 U tsu uwwa tsu ta̱ mantsa ma na tsu pati niyi. Adama a na tsu reve ta̱ a na amayun a ɗa, tsu reve ta̱ waru u tsu ca tsu ta̱ ili i na tsu pati niyi suru.
\p 
\v 16 Na̱ ve ene za vi Itoni a yuwusan unusu u na u rawai ukwa̱ shi, i pati A̱sula̱, u ta ca vuma ndolo wuma. N ta yuwusan adanshi adama a ama a na a yuwain unusu u na u rawai ukwa̱ shi. Agba unusu u na u tsu ta̱wa̱a̱ nu ukwa̱ u ta̱ lo,\f + \fr 5:16 \ft Unusu u na u tsu ta̱wa̱a̱ nu ukwa̱ a̱yi ɗa vuma ꞌyuwan a̱ usu Yesu Zamawawa, waru vuma ꞌyuwan a ciga a̱za̱ a̱ yi. She na̱ a̱yi za vu unusu u vadala ɗa goon wa̱a̱ tsura̱ gafura.\f* n zuwa ɗu i yuwan avasa uba̱ta̱ wa̱ A̱sula̱ adama a̱ cuꞌun ndolo shi.
\v 17 Mantsa ma na i yuwain iwuya suru, unusu u ɗa, agba cuꞌun vu unusu suru ɗa tsu ta̱wa̱a̱ nu ukwa̱ shi.
\p 
\v 18 Tsu reve ta̱ aza a na a̱ ri muwun ma̱ A̱sula̱ a tsu lyuwa elime na̱ mayan mo unusu shi. Yesu Zamawawa Mawun ma̱ A̱sula̱ ma̱ tsu ka̱lyuwusa̱ le ta̱, waru za vi iwuya aa gura juꞌwa̱n le shi.
\p 
\v 19 Tsu reve ta̱ e ekere a̱ A̱sula̱ ɗa tsu ri, agba a̱yi za vi iwuya ta yuwusan tsugono tsu uvaɗi suru.
\p 
\v 20 Tsu reve ta̱ a na Yesu Zamawawa Mawun ma̱ A̱sula̱ ma̱ ta̱wa̱ ta̱ a̱vu u roco tsu A̱sula̱ a amayun. Tso oꞌwo ta̱ oɓolo na̱ A̱sula̱ a amayun, adama a na tsu ri a muwwulai na̱ Mawun ma̱ yi Yesu Zamawawa. A̱yi ɗa A̱sula̱ a amayun za na tsu ca wuma u babu ukotu.
\p 
\v 21 Muwun n va̱, i ciga i ꞌyuwan i suma itoni ya̱ a̱ma̱li.
