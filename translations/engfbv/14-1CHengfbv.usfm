\v 48 \w Maacah|strong="H4601"\w*, \w Caleb|strong="H3612"\w*'s \w concubine|strong="H6370"\w*, \w was|strong="H3205"\w* \w the|strong="H3205"\w* mother \w of|strong="H3205"\w* \w Sheber|strong="H7669"\w* \w and|strong="H6370"\w* \w Tirhanah|strong="H8647"\w*.
\v 49 She \w was|strong="H3205"\w* \w also|strong="H3205"\w* \w the|strong="H3205"\w* mother \w of|strong="H1323"\w* \w Shaaph|strong="H8174"\w*, \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H1323"\w* \w Madmannah|strong="H4089"\w*, \w and|strong="H1323"\w* \w of|strong="H1323"\w* \w Sheva|strong="H7724"\w*, \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H1323"\w* Macbenah \w and|strong="H1323"\w* \w Gibea|strong="H1388"\w*. \w Caleb|strong="H3612"\w*'s \w daughter|strong="H1323"\w* \w was|strong="H3205"\w* \w Acsah|strong="H5915"\w*.
\v 50 These \w are|strong="H1121"\w* all \w the|strong="H1961"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Caleb|strong="H3612"\w*.
