\mt2 This book is the account of Jeremiah foretelling about God punishing the Israeli people because they rejected him and would not repent. We call this book  
\mt1 Jeremiah  
\c 1  
\s1 Introduction  
\p
\v 1  \add I\add*, \w Jeremiah|strong="H3414"\w*, \w the|strong="H4480"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Hilkiah|strong="H2518"\w*, \add am writing\add* these \w messages|strong="H1697"\w*. \add I am\add* \w a|strong="H3068"\w* \w priest|strong="H3548"\w*, \w from|strong="H4480"\w* \w Anathoth|strong="H6068"\w* \add town\add* \w in|strong="H1121"\w* \w the|strong="H4480"\w* area \w where|strong="H4480"\w* \w the|strong="H4480"\w* tribe \w of|strong="H1121"\w* \w Benjamin|strong="H1144"\w* \add lives\add*.  
\v 2 \w Yahweh|strong="H3068"\w* \w started|strong="H1961"\w* \w to|strong="H3068"\w* \w give|strong="H1961"\w* \w me|strong="H1697"\w* \w these|strong="H3117"\w* \w messages|strong="H1697"\w* \w when|strong="H1961"\w* \w Josiah|strong="H2977"\w* \w had|strong="H3068"\w* \w been|strong="H1961"\w* ruling \w Judah|strong="H3063"\w* \w for|strong="H3068"\w* \w almost|strong="H3117"\w* 13 \w years|strong="H8141"\w*.  
\v 3 \w Yahweh|strong="H3068"\w* \w continued|strong="H1961"\w* \w to|strong="H5704"\w* \w give|strong="H1961"\w* \w me|strong="H1961"\w* \w more|strong="H5704"\w* messages \w when|strong="H1961"\w* \w Josiah|strong="H2977"\w*’s \w son|strong="H1121"\w* \w Jehoiakim|strong="H3079"\w* \w was|strong="H1961"\w* \w the|strong="H3117"\w* \w king|strong="H4428"\w*, \w and|strong="H1121"\w* \w he|strong="H3117"\w* \w continued|strong="H1961"\w* \w to|strong="H5704"\w* \w do|strong="H3063"\w* \w that|strong="H3117"\w* \w until|strong="H5704"\w* \w Zedekiah|strong="H6667"\w* \w had|strong="H1961"\w* \w been|strong="H1961"\w* \w the|strong="H3117"\w* \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w* \w for|strong="H5704"\w* \w almost|strong="H3117"\w* \w eleven|strong="H6249"\w* \w years|strong="H8141"\w*. \w It|strong="H1961"\w* \w was|strong="H1961"\w* \w in|strong="H8141"\w* August \w of|strong="H1121"\w* \w that|strong="H3117"\w* \w year|strong="H8141"\w* \w that|strong="H3117"\w* \w the|strong="H3117"\w* \w people|strong="H1121"\w* \w of|strong="H1121"\w* \w Jerusalem|strong="H3389"\w* \w were|strong="H1961"\w* ◄\w exiled|strong="H1540"\w*/\w taken|strong="H1540"\w* \w as|strong="H5704"\w* prisoners► \add to Babylonia\add*.   
\s1 Yahweh chose Jeremiah to be his prophet  
\p
\v 4  \add One day\add* \w Yahweh|strong="H3068"\w* \w gave|strong="H1961"\w* \w me|strong="H1697"\w* \w this|strong="H1697"\w* \w message|strong="H1697"\w*:   
\q1
\v 5 “\w I|strong="H5414"\w* \w knew|strong="H3045"\w* \w you|strong="H5414"\w* \w before|strong="H2962"\w* \w I|strong="H5414"\w* \add finished\add* \w forming|strong="H3335"\w* \w you|strong="H5414"\w* \w in|strong="H5414"\w* \w your|strong="H5414"\w* \w mother|strong="H7358"\w*’s \w womb|strong="H7358"\w*.  
\q2 \w Before|strong="H2962"\w* \w you|strong="H5414"\w* \w were|strong="H1471"\w* \w born|strong="H3318"\w*, \w I|strong="H5414"\w* ◄\w set|strong="H5414"\w* \w you|strong="H5414"\w* \w apart|strong="H6942"\w*/chose \w you|strong="H5414"\w*►  
\q2 \w and|strong="H1471"\w* \w I|strong="H5414"\w* \w appointed|strong="H5414"\w* \w you|strong="H5414"\w* \w to|strong="H3318"\w* \w be|strong="H1471"\w* \add my\add* \w prophet|strong="H5030"\w*  
\q2 \add whose messages would be\add* \w for|strong="H3045"\w* \add all\add* \w nations|strong="H1471"\w*.”   
\p
\v 6 \w I|strong="H3588"\w* \w replied|strong="H1696"\w*, “\w O|strong="H3068"\w*, \w Yahweh|strong="H3068"\w* \w my|strong="H3045"\w* \w God|strong="H3069"\w*, \w I|strong="H3588"\w* am \add not qualified to\add* \w speak|strong="H1696"\w* \add for you\add*, \w because|strong="H3588"\w* \w I|strong="H3588"\w* am \w very|strong="H3045"\w* \w young|strong="H5288"\w*!”   
\p
\v 7 \w Yahweh|strong="H3068"\w* \w replied|strong="H1696"\w*, “\w Do|strong="H3068"\w* \w not|strong="H3588"\w* \w say|strong="H1696"\w* \w that|strong="H3588"\w*, \w because|strong="H3588"\w* \w you|strong="H3588"\w* must \w go|strong="H3212"\w* \w to|strong="H1696"\w* \w everyone|strong="H3605"\w* \w to|strong="H1696"\w* \w whom|strong="H3588"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w send|strong="H7971"\w* \w you|strong="H3588"\w*, \w and|strong="H3068"\w* \w you|strong="H3588"\w* must \w tell|strong="H1696"\w* \w them|strong="H5921"\w* \w everything|strong="H3605"\w* \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w tell|strong="H1696"\w* \w you|strong="H3588"\w* \w to|strong="H1696"\w* \w say|strong="H1696"\w*.  
\v 8 \w And|strong="H3068"\w* \w you|strong="H3588"\w* must \w not|strong="H3588"\w* \w be|strong="H3068"\w* \w afraid|strong="H3372"\w* \w of|strong="H3068"\w* \w the|strong="H6440"\w* people \add to whom you will speak\add*, \w because|strong="H3588"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* protect \w you|strong="H3588"\w* \add from being harmed by them\add*. \add This will surely happen because I\add*, \w Yahweh|strong="H3068"\w*, \w have|strong="H3068"\w* \w said|strong="H5002"\w* \w it|strong="H3588"\w*!”   
\p
\v 9 \w Then|strong="H2009"\w* \add it was as though\add* \w Yahweh|strong="H3068"\w* \w touched|strong="H5060"\w* \w my|strong="H5414"\w* \w mouth|strong="H6310"\w* \w and|strong="H3068"\w* \w said|strong="H1697"\w*, “\w Listen|strong="H2009"\w* \w to|strong="H3068"\w* \w me|strong="H5414"\w*! \w I|strong="H5414"\w* \w am|strong="H3068"\w* ◄\w putting|strong="H5414"\w* \w my|strong="H5414"\w* \w message|strong="H1697"\w* \w into|strong="H5921"\w* \w your|strong="H3068"\w* \w mouth|strong="H6310"\w*/telling \w you|strong="H5414"\w* \w what|strong="H1697"\w* \w you|strong="H5414"\w* must \w speak|strong="H1697"\w*►.  
\v 10 \w Today|strong="H3117"\w* \w I|strong="H3117"\w* \w am|strong="H6485"\w* appointing \w you|strong="H5921"\w* \w to|strong="H5921"\w* warn \w nations|strong="H1471"\w* \w and|strong="H3117"\w* \w kingdoms|strong="H4467"\w*. \w You|strong="H5921"\w* \w will|strong="H1471"\w* \w tell|strong="H7200"\w* \w them|strong="H5921"\w* \w that|strong="H7200"\w* \w I|strong="H3117"\w* \w will|strong="H1471"\w* completely \w destroy|strong="H5422"\w* \w and|strong="H3117"\w* get rid \w of|strong="H3117"\w* [DOU] \w some|strong="H3117"\w* \w of|strong="H3117"\w* \w them|strong="H5921"\w* \w and|strong="H3117"\w* \w that|strong="H7200"\w* \w I|strong="H3117"\w* \w will|strong="H1471"\w* \w establish|strong="H5193"\w* [MET] others \w and|strong="H3117"\w* cause \w them|strong="H5921"\w* \w to|strong="H5921"\w* \w be|strong="H3117"\w* strong.”   
\p
\v 11 \w Then|strong="H1961"\w* \w Yahweh|strong="H3068"\w* \w said|strong="H1697"\w* \w to|strong="H3068"\w* \w me|strong="H7200"\w*, “\w Jeremiah|strong="H3414"\w*, \w what|strong="H4100"\w* \w do|strong="H3068"\w* \w you|strong="H7200"\w* \w see|strong="H7200"\w*?”  
\p \w I|strong="H1697"\w* replied, “\w I|strong="H1697"\w* \w see|strong="H7200"\w* \w a|strong="H3068"\w* branch \w from|strong="H3068"\w* \w an|strong="H1961"\w* \w almond|strong="H8247"\w* \w tree|strong="H8247"\w*.”   
\p
\v 12 \w Yahweh|strong="H3068"\w* \w said|strong="H1697"\w*, “\w That|strong="H3588"\w* \w is|strong="H3068"\w* \w correct|strong="H3190"\w*. \w And|strong="H3068"\w* \add because the word for ‘almond’ resembles the word for ‘watching’\add*, \w it|strong="H5921"\w* means \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w am|strong="H3068"\w* \w watching|strong="H8245"\w* \add what will happen\add*, \w and|strong="H3068"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w make|strong="H6213"\w* certain \w that|strong="H3588"\w* \w what|strong="H1697"\w* \w I|strong="H3588"\w* \w have|strong="H3068"\w* \w said|strong="H1697"\w* \w to|strong="H3068"\w* \w you|strong="H3588"\w* \add about destroying nations\add* \w will|strong="H3068"\w* \w happen|strong="H1697"\w*.”   
\p
\v 13  \add Then\add* \w Yahweh|strong="H3068"\w* \w spoke|strong="H1697"\w* \w to|strong="H3068"\w* \w me|strong="H6440"\w* \w again|strong="H8145"\w* \w and|strong="H3068"\w* \w said|strong="H1697"\w*, “\w What|strong="H4100"\w* \w do|strong="H3068"\w* \w you|strong="H6440"\w* \w see|strong="H7200"\w* \add now\add*?”  
\p \w I|strong="H1697"\w* replied, “\w I|strong="H1697"\w* \w see|strong="H7200"\w* \w a|strong="H3068"\w* \w pot|strong="H5518"\w* full \w of|strong="H3068"\w* \w boiling|strong="H5301"\w* \add water\add* [MTY]. \w It|strong="H7200"\w* \w is|strong="H3068"\w* tipping \add toward me\add* \w from|strong="H6440"\w* \w the|strong="H6440"\w* \w north|strong="H6828"\w*.”   
\p
\v 14 \w Yahweh|strong="H3068"\w* replied, “\add Yes! It means that\add* \w from|strong="H5921"\w* \w the|strong="H3605"\w* \w north|strong="H6828"\w* \w great|strong="H7451"\w* \w trouble|strong="H7451"\w*/\w destruction|strong="H7451"\w* \w will|strong="H3068"\w* \add spread\add* [MET] \w over|strong="H5921"\w* \w this|strong="H3068"\w* land, \add like boiling water\add* [MET] pouring \add from a pot\add*.   
\q1
\v 15 \w Listen|strong="H2005"\w* \w to|strong="H3068"\w* \w what|strong="H3588"\w* \w I|strong="H3588"\w* say:  
\q2 \w I|strong="H3588"\w* \w am|strong="H3068"\w* \w summoning|strong="H7121"\w* \add the armies of\add* \w kingdoms|strong="H4467"\w* \w that|strong="H3588"\w* \w will|strong="H3068"\w* \w come|strong="H3063"\w* \w from|strong="H5921"\w* \w the|strong="H3605"\w* \w north|strong="H6828"\w* \add of Judah\add* \w to|strong="H3068"\w* \w Jerusalem|strong="H3389"\w*.  
\q1 \w Their|strong="H3605"\w* kings \w will|strong="H3068"\w* \w set|strong="H5414"\w* \w up|strong="H5414"\w* \w their|strong="H3605"\w* \w thrones|strong="H3678"\w* \w at|strong="H5921"\w* \w the|strong="H3605"\w* \w gates|strong="H8179"\w* \w of|strong="H3068"\w* \w this|strong="H5414"\w* \w city|strong="H5892"\w* \add to indicate that they are now the kings of Judah\add*.  
\q2 \add Their armies\add* \w will|strong="H3068"\w* attack \add and break down\add* \w the|strong="H3605"\w* \w walls|strong="H2346"\w* \w of|strong="H3068"\w* \w this|strong="H5414"\w* \w city|strong="H5892"\w*, \w and|strong="H3063"\w* \add they will do the same thing to\add* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \add other\add* \w towns|strong="H5892"\w* \w in|strong="H5921"\w* \w Judah|strong="H3063"\w*.   
\q1
\v 16 \w I|strong="H5921"\w* \w will|strong="H3027"\w* punish [MTY] \w my|strong="H3605"\w* \w people|strong="H1696"\w* \w because|strong="H5921"\w* \w of|strong="H3027"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w evil|strong="H7451"\w* \w things|strong="H3605"\w* \w that|strong="H3605"\w* \w they|strong="H5921"\w* \w have|strong="H3027"\w* \w done|strong="H4639"\w*;  
\q1 \w they|strong="H5921"\w* \w have|strong="H3027"\w* \w abandoned|strong="H5800"\w* \w me|strong="H5921"\w* \w and|strong="H3027"\w* \w they|strong="H5921"\w* \w worship|strong="H7812"\w* gods/idols.  
\q2 \w They|strong="H5921"\w* \w worship|strong="H7812"\w* idols \w that|strong="H3605"\w* \w they|strong="H5921"\w* \w have|strong="H3027"\w* \w made|strong="H4639"\w* \w with|strong="H1696"\w* \w their|strong="H3605"\w* \w own|strong="H3027"\w* \w hands|strong="H3027"\w*!   
\p
\v 17 \w So|strong="H6435"\w*, \w get|strong="H6965"\w* \w up|strong="H6965"\w* \w and|strong="H6965"\w* \w put|strong="H6680"\w* \w on|strong="H1696"\w* \w your|strong="H3605"\w* clothes \add to get ready for action\add*! \w Then|strong="H6965"\w* \w go|strong="H6965"\w* \w to|strong="H1696"\w* \w the|strong="H3605"\w* \w people|strong="H1696"\w* \w of|strong="H6440"\w* Judah \w and|strong="H6965"\w* \w tell|strong="H1696"\w* \w them|strong="H6440"\w* \w everything|strong="H3605"\w* \w that|strong="H3605"\w* \w I|strong="H6680"\w* \w tell|strong="H1696"\w* \w you|strong="H6440"\w* \w to|strong="H1696"\w* \w say|strong="H1696"\w*. \w Do|strong="H6680"\w* \w not|strong="H6435"\w* \w be|strong="H6440"\w* \w afraid|strong="H2865"\w* \w of|strong="H6440"\w* \w them|strong="H6440"\w*, \w because|strong="H6440"\w* \add if you are afraid of them\add*, \w I|strong="H6680"\w* \w will|strong="H2865"\w* cause \w you|strong="H6440"\w* \w to|strong="H1696"\w* \w be|strong="H6440"\w* truly \w terrified|strong="H2865"\w* \w in|strong="H1696"\w* \w front|strong="H6440"\w* \w of|strong="H6440"\w* \w them|strong="H6440"\w*!  
\v 18 \w But|strong="H2009"\w* \w listen|strong="H2009"\w*! \w I|strong="H3117"\w* \w will|strong="H4428"\w* \w cause|strong="H5414"\w* \w you|strong="H5414"\w* \w to|strong="H5921"\w* \w be|strong="H3117"\w* \add strong, like\add* [MET] \w a|strong="H3068"\w* \w city|strong="H5892"\w* \w that|strong="H5971"\w* \w has|strong="H4428"\w* \w strong|strong="H4013"\w* \w walls|strong="H2346"\w* \w around|strong="H5921"\w* \w it|strong="H5414"\w*. \w You|strong="H5414"\w* \w will|strong="H4428"\w* \w be|strong="H3117"\w* \add as strong as\add* [MET] \w an|strong="H5414"\w* \w iron|strong="H1270"\w* \w pillar|strong="H5982"\w* \w or|strong="H3117"\w* \w a|strong="H3068"\w* \w bronze|strong="H5178"\w* \w wall|strong="H2346"\w*. \w None|strong="H3605"\w* \w of|strong="H4428"\w* \w the|strong="H3605"\w* \w kings|strong="H4428"\w* \w or|strong="H3117"\w* \w officials|strong="H8269"\w* \w or|strong="H3117"\w* \w priests|strong="H3548"\w* \w will|strong="H4428"\w* \w be|strong="H3117"\w* able \w to|strong="H5921"\w* \w defeat|strong="H5414"\w* \w you|strong="H5414"\w*.  
\v 19 \w They|strong="H3588"\w* \w will|strong="H3068"\w* oppose \w you|strong="H3588"\w*, \w but|strong="H3588"\w* \w they|strong="H3588"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w be|strong="H3808"\w* \w able|strong="H3201"\w* \w to|strong="H3201"\w* defeat \w you|strong="H3588"\w*, \w because|strong="H3588"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w be|strong="H3808"\w* \w with|strong="H3068"\w* \w you|strong="H3588"\w* \w and|strong="H3068"\w* \w will|strong="H3068"\w* protect \w you|strong="H3588"\w*. \add That will surely happen because I\add*, \w Yahweh|strong="H3068"\w*, \w have|strong="H3068"\w* \w said|strong="H5002"\w* \w it|strong="H3588"\w*!”   
\c 2  
\s1 The Israelis sinned in spite of God’s care for them  
\p
\v 1 \w Yahweh|strong="H3068"\w* \w gave|strong="H1961"\w* \w me|strong="H1697"\w* another \w message|strong="H1697"\w*   
\q1
\v 2  \add to proclaim to everyone in Jerusalem. He said that I should tell them this\add* [MET]:  
\q1 “\w I|strong="H3541"\w*, \w Yahweh|strong="H3068"\w*, \w remember|strong="H2142"\w* \w that|strong="H3068"\w* \w you|strong="H3808"\w* \w very|strong="H1980"\w* much wanted \w to|strong="H1980"\w* please \w me|strong="H7121"\w* \add long ago\add*.  
\q2 \add You tried to please me like\add* \w a|strong="H3068"\w* bride \add tries to please her husband\add*;  
\q1 \w You|strong="H3808"\w* loved \w me|strong="H7121"\w*,  
\q2 \w and|strong="H1980"\w* \w you|strong="H3808"\w* \w followed|strong="H1980"\w* \w me|strong="H7121"\w* \w through|strong="H1980"\w* \w the|strong="H3541"\w* \w desert|strong="H4057"\w* [DOU].   
\q1
\v 3  \add At that time you\add* Israelis ◄\w were|strong="H3478"\w* \w set|strong="H3478"\w* \w apart|strong="H6944"\w*/belonged \w only|strong="H3605"\w*► \w to|strong="H3478"\w* \w me|strong="H3605"\w*;  
\q2 \add you belonged to me like\add* \w the|strong="H3605"\w* \w first|strong="H7225"\w* \w part|strong="H7225"\w* \w of|strong="H3068"\w* \w the|strong="H3605"\w* \w harvests|strong="H8393"\w* belong \w to|strong="H3478"\w* \w me|strong="H3605"\w* [MET].  
\q1 \w I|strong="H3478"\w* \w promised|strong="H3068"\w* \w to|strong="H3478"\w* punish \w all|strong="H3605"\w* \w those|strong="H3605"\w* \w who|strong="H3605"\w* harmed \w you|strong="H3605"\w*, \w my|strong="H3605"\w* people,  
\q2 \w and|strong="H3478"\w* truly \w I|strong="H3478"\w* \w did|strong="H3478"\w* send \w disasters|strong="H7451"\w* \w on|strong="H3068"\w* \w them|strong="H3478"\w*.  
\q2 \add That happened because I\add*, \w Yahweh|strong="H3068"\w*, \w said|strong="H5002"\w* \add that it would happen\add*.”   
\b  
\q1
\v 4 \w So|strong="H1697"\w*, \w you|strong="H3605"\w* \add descendants of\add* [MTY] \w Jacob|strong="H3290"\w*, \w all|strong="H3605"\w* \w you|strong="H3605"\w* \w people|strong="H8085"\w* \w of|strong="H1004"\w* [MTY] \w Israel|strong="H3478"\w*,   
\q1
\v 5 listen \w to|strong="H3068"\w* \w what|strong="H4100"\w* \w Yahweh|strong="H3068"\w* \w says|strong="H3541"\w*:  
\q2 “◄\w What|strong="H4100"\w* \w sin|strong="H5766"\w* \w did|strong="H4100"\w* \w I|strong="H3588"\w* commit [RHQ] \w that|strong="H3588"\w* caused \w your|strong="H3068"\w* ancestors \w to|strong="H3068"\w* turn \w far|strong="H7368"\w* \w away|strong="H3212"\w* \w from|strong="H5921"\w* \w me|strong="H5921"\w*?/\w Though|strong="H3588"\w* \w your|strong="H3068"\w* ancestors \w found|strong="H4672"\w* \w no|strong="H4672"\w* \w fault|strong="H4672"\w* \w in|strong="H5921"\w* \w me|strong="H5921"\w*, \w they|strong="H3588"\w* \w turned|strong="H3068"\w* \w far|strong="H7368"\w* \w away|strong="H3212"\w* \w from|strong="H5921"\w* \w me|strong="H5921"\w*.►  
\q1 \w They|strong="H3588"\w* worshiped \w worthless|strong="H1892"\w* \w idols|strong="H1892"\w*,  
\q2 \w and|strong="H3068"\w* \w they|strong="H3588"\w* \w themselves|strong="H5921"\w* \w became|strong="H1891"\w* \w worthless|strong="H1892"\w*.   
\q1
