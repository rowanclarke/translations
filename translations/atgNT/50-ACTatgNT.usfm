\id ACT - Okphela 
\h Ikanya 
\toc1 Ikanya 
\toc2 Ikanya 
\toc3 Ika 
\mt1 Ikanya 
\mt2 Eyi Ighiusomhi eyi iKirisiti 
\c 1  
\s1 A rue IJesu nga idane 
\p  
\v 1 Elemhi ebe oni ododẹ ni mhi kpẹ kẹkẹ ghi yẹyẹ iTiofilọsi,\f + \fr 1:1 \ft Li zẹ \fq iLuk 1.1-4\f* mhi kẹkẹ ikanya ni IJesu ọọ gbe ali emini ọ sẹsẹ rọte igbaekẹle,  
\v 2 ya ramhi ogbẹlẹ ni a rọ rue ọli nga idane. Neni a rue ọli nga idane, ọ rọte Ayẹmhẹ-nọ-pfuasẹ ri omhẹsẹ na ighiusomhi na kẹẹ ni ọ zẹ.  
\v 3 Abi ọ rọ ghu-a se, ogbẹlẹ egbhuẹva ọ la elemhi agbọ ọ ri egbọli kia khasẹ ighiusomhi eyọli, ni o rọkhasẹ gboo khi akhọkhọmhẹ ọa la ọ khi ọ la agbọ. E mẹ ọli, ọọ gue ungmemhi oyi Eghiele oyi Ẹshinẹgba yẹ wẹ.  
\v 4 Ẹlẹghuo khi e legba asheghuo, khi ọ nu wẹ ẹ le eminale, ọ ri omhẹsẹ ona na wẹ, ọọ wẹ, “A khi rọte iJerusalẹmu vu, a migha khẹ isomhopfa ni mhi gueyẹ ẹ, ikhi isomhopfa ni itamhẹ ọ shobọ.\f + \fr 1:4 \ft Li zẹ \fq iLuk 24.49\f* 
\v 5 Amẹ iJọni ọ rọ ọ batazi ẹgbọ, ama ọa ke ya tẹsẹ neni a ri Ayẹmhẹ-nọ-pfuasẹ ya batazi ẹ.”\f + \fr 1:5 \ft Li zẹ \fq iMat 3.11; iMak 1.8; iLuk 3.16; iJọn 1.33\f* 
\s1 A rue iJesu nga iloghie 
\r (iMak 16.19-20; iLuk 24.50-53) 
\p  
\v 6 Abi ighiusomhi e rọ nu iJesu legba kugbe, e mhila li, ẹẹ ọli, “Ọnọmhuẹ, u ya la ẹghẹghẹ ona rue eghiele oyi ẹgbọ iZirẹni nyenẹ gbo na wẹ?” 
\p  
\v 7 Ọọ wẹ: “Aa khi eni ẹ lẹsẹ oni ẹghẹghẹ ali oni ogbẹlẹ ni Ita ọ ri afu eyọli mhẹsẹ.  
\v 8 Ama ini Ayẹmhẹ-nọ-pfuasẹ ọ bhale ẹ idiegbe, a ya mhọli ekpabọ, a ya ke pfi ọtsẹlẹ na mhẹ elemhi ekẹ iJerusalẹmu, ali ekẹ iJudia, ali iSameria ali elemhi ekẹ agbọ ona nya.”\f + \fr 1:8 \ft Li zẹ \fq iMat 28.19; iMak 16.15; iLuk 24.47-48\f* 
\p  
\v 9 Abi ọ rọ ngme eni ingmemhi enana se, a rue ọli nga idane abi e kie li ghọ fẹli ọli. Otughunu o khukhu ọli-a, o rue ọli odalo oyẹwẹ le.\f + \fr 1:9 \ft Li zẹ \fq iMak 16.19; iLuk 24.50-51\f* 
\p  
\v 10 E bino idane chii abi ọ li vu, utoghuokpe emọse aava ni e sọ ide epfopfo e migha wẹ iteva.  
\v 11 Ẹẹ wẹ, “Ẹgbọ iGalili, elọ o zẹ ni a rọ migha a fẹli idane chii? Ọni iJesu ọna ni a rue odalo oyẹẹ vu nga idane, abi a li rue ọli vu, ighọ ọ li ya gbo nyenẹ egbe bhale.” 
\s1 A zẹ iMatayasi to ẹloli iJudasi 
\r (iMat 27.3-10) 
\p  
\v 12 Ighọ, eni ighiusomhi na kẹẹ e rọte oni ukhomhi Ute Ẹẹra Olivu ni e migha vu je iJerusalẹmu, aghọ ọa lolo nuẹ shi iJerusalẹmu, okiali imali oghuo lọ, ni Ishi eyi iMosisi o lama shi ọgbọ ke kia ogbẹlẹ iyẹmhẹa.  
\v 13 Abi e rọ ramhi iJerusalẹmu, e nga ukhomhi atọnga, e lo elemhi owa ni ee legba. Eni e la akaghọ khi iPita, iJọni, iJemhisi ali Aduru, iFilipu ali iTọmọsi, iBatolomiu ali iMatiu, iJemhisi ọlese ni ọ khi omi Afeusi, iSamioni ni ọ la otu iZilọti ali iJudasi omi iJemhisi.\f + \fr 1:13 \ft Li zẹ \fq iMat 10.2-4; iMak 3.16-19; iLuk 6.14-16\f* 
\v 14 Wẹwẹ nya e lona a kugbe ẹghẹghẹ kpa a sọ iromhi. Ghe eni ikpotso ali, iMeli inyọ iJesu, ali inyọghuo iJesu. 
\p  
\v 15 Ogbẹlẹ ni a ngme ena, iPita ọ vule migha iteva oyi igbaa oyi eni e mie iJesu iKirisiti suọ. Ẹgbọ egbhuẹsesa e la aghọ (120)  
\v 16 Ighọ ọọ, “Inyọghuo, a mema ya ri emini ebe-no-pfuasẹ o ngme tsẹ, ni Ayẹmhẹ-nọ-pfuasẹ ọ rọte unu oyi iDefidi ngme shi ekẹ shi iJudasi egbe, lọli ọni iJudasi ni ọ ri odẹ khasẹ ẹgbọ ni e mu iJesu.  
\v 17 Ọtuọghuo elemhi awa ọ khi ni ọ nu awa gbe akanya abi aghiusomhi.” 
\p  
\v 18 IJudasi ọ wolọ ikpaghọ ni ọ mie shi ikanya ọkhọlọ ni ọ gbe ya dẹ ekẹ. Aghọ ọ de tu ukhomhi ekẹ ku itọ-a shi.  
\v 19 Ọgbọkpa ni ọ la iJerusalẹmu ọ suọ ona, e ri irarighọ ri unu ẹoli oyẹwẹ lu akaghọ Akẹdama, ni o migha shi Ekẹ Ọlia. \f + \fr 1:19 \ft Li zẹ \fq iMat 27.3-8\f* 
\p  
\v 20 IPita ọọ, “Irari khi, a kẹkẹ ọli shi ebe Iwolo khi, 
\q1 “ ‘A tsua owa oyọli pfia. 
\q1 A khi mẹ ọgbọkhọghuo 
\q2 ni ọ gbo la oni owa,’ 
\p “A gbo li kẹkẹ ọli: 
\q1 “ ‘Ọgbọẹse ọ rue asha omhẹsẹ oyọli.’\f + \fr 1:20 \ft Li zẹ \fq Iwolo 69.25; 109.8\f* 
\p  
\v 21 “Itobọ onana, o ti ni awa zẹ ọgbọ ọghuo ni ọ to ẹlolo iJudasi, ọni ọgbọ ọ mema ya khi ọgbọ ni ọ nu awa la ọ rọte ẹghẹghẹ ni iJesu ọ rọ la iteva oyi awa,  
\v 22 rọte ẹghẹghẹ ni iJọni ọ rọ batazi ẹgbọ ya ramhi ogbẹlẹ ni Ẹshinẹgba ọ rọ rue iJesu lasele elemhi iteva oyi awa nga idane. Ọgbọ ni awa ya zẹ ọ mema ya nu awa gbe akanya aguele irọte eghuli guale oyi iJesu.” 
\p  
\v 23 Ighọ e khọkhọ emọse aava. Ọmọse ọghuo ni a lu iJosẹfu ni a lu iBasabasi, ni a gbolo ẹ lu iJọsitọsi, ali ọmọse ọlese ni a lu iMatayasi.  
\v 24 Ighọ e lema, ẹ li, “Ọnọmhuẹ, u lẹsẹ udu oyi ọgbọkpa, kpẹkpẹ rọte elemhi ẹgbọ etuava ena zẹ  
\v 25 ọni ọ ya rue ikanya aghiusomhi na kẹẹ ni iJudasi ọ zẹ obọ je obini o khili oyọli.”  
\v 26 Ighọ e bọ shi ọ, obọ o mu iMatayasi, Ighọ e li ya rue ọli ma ighiusomhi na kẹẹ ogbaghuo ni iJesu ọ zẹ. 
\c 2  
\s1 Ayẹmhẹ-nọ-pfuasẹ ọ bhale ogbẹlẹ iPẹtikọsiti 
\p  
\v 1 Abi ogbẹlẹ ukpe iPẹtikọsiti o rọ ramhi, igbaa oyi eni e mie iJesu iKirisiti suọ nya e lona kugbe asheghuo.\f + \fr 2:1 \ft Li zẹ \fq iLẹv 23.15-21; iDẹut 16.9-11\f* 
\v 2 Utoghuo-kpe, okeke o rọte idane tiemhile abi akpekpeli ni o toto, oni okeke o vọ elemhi oni owa ni e shitọ.  
\v 3 Ighọ e mẹ emini e li abi ẹlẹmhi erali khi e rọte ashakhasha a tiemhile shi wẹ ọ.  
\v 4 Ighọ Ayẹmhẹ-nọ-pfuasẹ ọ vọ wẹwẹ nya egbe, ee ngme ẹmuẹ oyi ẹoli ọdọda abi ọni Ayẹmhẹ ọ li khueghie wẹ unu-a.\fig Ayẹmhẹ no pfuasẹ o tiemhile ogbẹlẹ iPẹtikọsiti |src="CN01890B.TIF" size="col" loc="ACT 2.4" copy="Cook" ref="2.4" \fig* 
\p  
\v 5 Ẹgbọ iJu ni ẹ na ulishi Ẹshinẹgba ni e rọte ushishi ọdọda na ekẹ agbọ jele, e la elemhi iJerusalẹmu.  
\v 6 Abi e rọ suọ oni okeke ona, ebubu ẹgbọ e kpeli bhale. O nya wẹ alo-a abi e rọ suọ khi eni ẹgbọ ni e miesuọ khi ẹ ngme ẹmuẹ ọdọda eyi wẹwẹ.  
\v 7 Ighọ abọ e sha wẹ egbegbọ, e liẹ egbe. “Eni ẹgbọ ena, ni ẹẹ ngme ẹmuẹ eyawa ena, ọa khi ẹgbọ iGalili e she khi?  
\v 8 Sẹ awa ke liẹ suọ wẹ khi ẹẹ ngme ẹmuẹ ọdọda eyawa?  
\v 9 Ẹoli ọdọda awa te lasele, eghuo e rọte iPatia bhale, eghuo ọ, iMedisi ali Elamu, eghuo ọ, iMẹsopotemia, eghuo, ekẹ iJudia ali iKapadosha, eghuo, iPọtusi ali Esha,  
\v 10 eghuo, iFirigia ali iPafilia, eghuo, iJipiti ali ukiẹkiẹ ekẹ iLibiya ni o ti mama ekẹ iSairin, eghuo e rọte iRomu bhale,  
\v 11 li shi ẹgbọ iJu ali ẹgbọ iJẹta ni e mu pfi bhale irudunga oyi ẹgbọ iJu. Eghuo elemhi awa e rọte iKirẹti ali Arebia bhale. Abi o riẹ khi ighọ, awa kie ga suọ khi ẹ ngme ẹmuẹ eyawa, ẹẹ guele ikanya eniẹmhi ni Ẹshinẹgba o gbe.”  
\v 12 Eni ingme ni a mẹ e sha ọgbọkpa abọ, ẹa lẹsẹ udi wẹ, e mhila egbe wẹ. “Sẹẹ onana o ngme?” 
\p  
\v 13 Ẹgbọ eghuo e rẹwẹ ẹ li egia, ẹ liẹ, “Onyọ ọọ gbe wẹ.” 
\s1 IPita ọ nu eni ebubu ẹgbọ ngme 
\p  
\v 14 Ighọ iPita ọ vule migha, lọli ali ogbaghuo ni e kpọle, ọ khueghie unu-a leghe, ọ nu eni ebubu ẹgbọ ngme, ọọ, “Apfẹmhẹ iJu, ali ẹẹ ẹgbọ nya ni a la elemhi iJerusalẹmu, a rọ esọ shi mhẹ ekẹ ni mhi gue ingme ni a mẹ ena yẹ ẹ.  
\v 15 Ọa khi onyọ ọọ gbe eni ẹgbọ ena abi a dabi. Irari khi ogbe ọa dala ne, agogo itili ẹlẹ uzogbe awa la!  
\v 16 Iiye! Emini a mẹ ena o khi emini ọmekẹguele iJoẹl ọ guele ẹghẹghẹ ni o dọsẹ ni ọ rẹ: 
\q1  
\v 17 “ ‘Ẹshinẹgba ọọ, 
\q1 Ogbẹlẹ ni e kpukhokho, 
\q2 mhi ya ri Ayẹmhẹ oyẹmhẹ 
\q2 na ẹgbọkpa. 
\q1 Imi ẹ eni emọse ali eni ikpotso 
\q2 e ya ke gue usomhi ni mhi ghie wẹ le. 
\q2 Izẹo eyẹ ẹ, e ya ke mekẹguele, 
\q1 egbhali eyẹ ẹ, e ya ke la ẹlena. 
\q1  
\v 18 Shi eni ẹ ga ọgbọ 
\q2 eni emọse ali eni ikpotso eyẹmhẹ, 
\q1 Mhi ya ri Ayẹmhẹ oyẹmhẹ 
\q2 na wẹ ogbẹlẹ ni a ngme ena, 
\q1 e ya gue emini mhi rọkhasẹ wẹ le. 
\q1  
\v 19 Mhi ya rọ ọnyaloa khasẹ, 
\q2 obini irarogbe, 
\q1 ali khi mhi ya gbo ri 
\q2 irọkhasẹ khasẹ ekẹ agbọ. 
\q1 Mhi ya pfi okhọli shi elemhi agbọ, 
\q2 ni ẹgbọ e mẹ ọlia 
\q2 ali erali ali ewọli 
\q1  
\v 20 Ovọ o ya bi obili a, 
\q2 mhi ya ri uki yilẹ-a rarara abi ọlia, 
\q1 neni ogbẹlẹ ni o funẹ 
\q2 oyi Ọnọmhuẹ o ya bhale 
\q2 ni ọ rọ ya gue ọgbọkpa ẹzọ. 
\q1  
\v 21 Ọgbọkpa ni ọ da pfie lu 
\q1 eva oyi Ọnọmhuẹ ne, a ya tsumhi ọli.’\f + \fr 2:21 \ft Li zẹ \fq iJọẹ 2.28-32\f* 
\p  
\v 22 “Ẹẹ ẹgbọ ni a la ekẹ iZirẹni, a rọ esọ shi ungmemhi onana. Ẹẹ a lẹsẹ khi iJesu ọngi iNazarẹti, ọ khi ọgbọ ni Ẹshinẹgba ọ ri egbe khasẹ, ọ gbo ghie ọli, itobọ khi Ẹshinẹgba ọ ri ekpabọ na li ọ ke gbe ikanya ọnyaloa elemhi iteva o yẹ ẹ.  
\v 23 Abi o rọ tseku khia khi a lẹsẹ ona, a kie zẹ ni ẹgbọ ebe e mu ọli ghi ẹ ni a gbe ọli-a. Ama Ẹshinẹgba ọ she kpẹ gba onana ọ lẹsẹ ọli.\f + \fr 2:23 \ft Li zẹ \fq iMat 27.35; iMak 15.24; iLuk 23.33; iJọn 19.18\f* 
\v 24 Ama Ẹshinẹgba ọ rọte eghuli guise ọli le. Eghuli ọa dobẹ ri ekpabọ oyọli mu ọli mama, abi ọkpotso ni oku ọọ to ọa li dobẹ a mu ọmọ ọ khi lasele.\f + \fr 2:24 \ft Li zẹ \fq iMat 28.5-6; iMak 16.6; iLuk 24.5\f* 
\v 25 Itobọ khi oghie iDefidi ọọ ngme ingme oyi iKirisiti ni ọ rẹẹ, 
\q1 “ ‘Mhi mẹ khi Ọnọmhuẹ 
\q2 ọ migha kpẹsẹ mhẹ ẹghẹghẹ kpa, 
\q1 ọ la ukiẹkiẹ obita oyẹmhẹ, 
\q2 udu ọa ya nighise mhẹ. 
\q1  
\v 26 Itobọ ona udu oyẹmhẹ o rọ ọ ghẹlẹ, 
\q2 mhi ri uruli oyẹmhẹ ẹ kuẹghiẹ-ẹ, 
\q2 mhi ri egbe dẹẹ. 
\q1  
\v 27 Itobọ khi waa ya 
\q1 zẹ mhẹ obọ shi elemhi uji, 
\q2 wẹkhi eri u ya zẹ ni 
\q2 Ọni ọ pfuasẹ ọyẹ ọ kẹ-a. 
\q1  
\v 28 U she kpẹ gueyẹ mhẹ 
\q2 khi mhi ya la agbọ ini 
\q2 u guise mhẹ te eghuli le.\f + \fr 2:28 \ft Li zẹ \fq Iwolo 16.8-11\f* 
\q1 U ya ri oghẹlẹ oniẹmhi na mhẹ odalo oyẹ.’ 
\p  
\v 29 “Inyọghuo, mhi mema ya ri igbedu gueyẹ ẹ khi oghie iDefidi ni ọ khi itita awa, ọ she kpẹ ghu-a ni ẹgbọ e rọ tọ, oni uji ni a rọ ọli tọ o kie la akaghọ ramhi ogbe na amo.  
\v 30 Awa lẹsẹ khi iDefidi ọ ngme aguele-shi-ekẹ shi iKirisiti egbe, irari khi ọ lẹsẹ khi Ẹshinẹgba ọ she kpẹ shobọ na luẹ ni ọ mema rọ ya tsẹ, khi lọli ya ri ọgbọ ọghuo unuẹkpẹ oyẹluẹ shitọ ukpẹkhomhi oghie oyẹluẹ.\f + \fr 2:30 \ft Li zẹ \fq Iwolo 132.11; 2 iSam 7.12-13\f* 
\v 31 Eri Ẹshinẹgba ọ rọli khasẹ iDefidi emini a ya mẹ ogbenakọ, lọli ọ rọ ngme ọli khi Ẹshinẹgba ọ ya rọte eghuli guise iKirisiti le. Ọọ khi Ẹshinẹgba ọa ya zẹ ọli ghua ni idiegbe oyọli o kẹa shi elemhi uji.  
\v 32 Ẹshinẹgba guise iJesu le bhale agbọ. Awa nya awa ri ukpẹloe oyawa pfi ọtsẹlẹ shi ọ khi iJesu ọ she guale.  
\v 33 Ẹshinẹgba ọ she ri ekpẹ oniẹmhi na iJesu, ọ shitọ ukiẹkiẹ obita oyi Ẹshinẹgba. IJesu ọ she rọte obọ oyi ita mie Ayẹmhẹ-nọ-pfuasẹ, abi Ẹshinẹgba o kie kpẹ li shobọ na li. Ọni iJesu ọ she rue oni Ayẹmhẹ-nọ-pfuasẹ tutu vọ anye egbe, lọli o khi emini a mẹ, ni a gbolo a suọ memena.  
\v 34 Ama lẹsẹ khi iDefidi ọa nga iloghie. Itobọ ighọ, áà khi ingme egbọli iDefidi ọọ ngme abi ọ rọ liẹ, 
\q1 “ ‘Ọnọmhuẹ ọ gueyẹ Ọnọmhuẹ ọyẹmhẹ: 
\q2 Shitọ ukiẹkiẹ obita oyẹmhẹ, 
\q1  
\v 35 ramhi ni mhi rọ ya ri ebe ẹ 
\q2 mele akphawẹ-nga oyẹ-a’\f + \fr 2:35 \ft Li zẹ \fq Iwolo 110.1\f* 
\p  
\v 36 “Itobọ ona, mhia nono ni ẹẹ ẹgbọ iZirẹni nya a lolo lẹsẹ onana khi, Ẹshinẹgba ọ zẹ ọni iJesu ọnana ni a gbe-a shi apfida ọ khi Ọnọmhuẹ ali iKirisiti.” 
\p  
\v 37 Abi eni ẹgbọ e rọ suọ eni ingmemhi ena se, oo nasẹ wẹ udu. Ighọ ẹ li mhila iPita ali ighiusomhi na kẹẹ eni e kpọle, ẹẹ wẹ, “Inyọghuo, Sẹẹ anye li ya kia ni Ẹshinẹgba ọ rọ ọ gbe olamhẹ kua na anye?” 
\p  
\v 38 IPita ọọ, “Ẹẹ nya a mupfi ni anye ri eva oyi iJesu iKirisiti batazi ẹ, isheghọ ni Ẹshinẹgba ọ gbe olamhẹ kua na ẹ, itobọ khi eni e mie iJesu suọ a ke khi, ni a mie isomhopfa Ayẹmhẹ-nọ-pfuasẹ.  
\v 39 Emini Ẹshinẹgba ọ shobọ ena, oyẹ ẹ lọ ali oyi imi ẹ, ali oyi ọgbọkpa ni Ẹshinẹgba ọ ya zẹ obiobini e la.” 
\p  
\v 40 IPita ọ ngme ingmemhi ni e bu, ọ tse agua yẹ wẹ, ọọ wẹ, “A na pfue anasẹmhẹ ni ẹgbọ ikpamhika ena e ya mẹ.”  
\v 41 Ighọ a li batazi eni e mie oni ungmemhi suọ. Ẹgbọ agbẹlẹ esẹ e khi ni e kuma igbaa oyi eni e mie iJesu iKirisiti suọ ọ ẹlẹghọ. 
\s1 Ilakugbe oyi ighiusomhi eyi iKirisiti 
\p  
\v 42 Eni ẹgbọ e ri emini ighiusomhi na kẹẹ e sẹsẹ wẹ gbe akanya, e ga kugbe, e le eminale kugbe (e le eminale no pfuasẹ kugbe), e sọ iromhi kugbe.  
\v 43 Ọgbọkpa ọ́ mu ekpẹ ni o funẹ ẹ na Ẹshinẹgba irari ọlẹlẹ ọnyaloa ali ọshabọ ebubu ni eni ighiusomhi na kẹẹ e gbe.  
\v 44 Eni e mie iJesu suọ nya e kudugbe, e kemhi emini e mhọli nya na egbe.\f + \fr 2:44 \ft Li zẹ \fq Ika 4.32-35\f* 
\v 45 Eni e mhọli ekẹ e ri ekẹ eyẹwẹ dẹ, elese eni e mhọli itsua, e rẹ wẹ dẹ, e wolọ ikpaghọ kugbe kemhi ni eni ẹa mhọli.  
\v 46 Ogbẹlẹ kpa e rọ ọ legba elemhi apfẹ ni i la Owa Oyi Ẹshinẹgba. E ri oghẹlẹ ali udu ni o pfuasẹ nu egbe la apfẹ egbe e le eminale. E le eminale no pfuasẹ.  
\v 47 Ee kuẹghiẹ Ẹshinẹgba, ighọ ẹgbọ e li somhi elemhi wẹ. Ogbẹlẹ kpa Ẹshinẹgba ọ rọ ri ẹgbọ ni a mie e pfuese ma wẹ ọ. 
\c 3  
\s1 A ri ọchẹghẹlẹ-awẹ-a ni ọọ lema ze 
\p  
\v 1 Ogbẹlẹghuo khi iPita ali iJọni ee je Owa Oyi Ẹshinẹgba ẹghẹghẹ agogo esẹ ọguota ni a la sọ iromhi.  
\v 2 A tsua ọmọse ni ọ rọte abi a te bia li guọghọ-a bhale ya shi odẹ unuẹkpẹ ni a lu Isomhotse oyi Owa Oyi Ẹshinẹgba. Akaghọ a tsua li bhale ya shitọ ni ọ te mẹ asha mhila ẹgbọ ni ẹ lo oni Owa Oyi Ẹshinẹgba le ikpaghọ.  
\v 3 Abi ọ rọ mẹ iPita ali iJọni khi e lo oni Owa Oyi Ẹshinẹgba, ọ mhila wẹ ikpaghọ.  
\v 4 Ighọ iPita ọ bino ọli alo tatata, ighọ li khi iJọni. IPita ọọ li, “Bino anye!”  
\v 5 Ighọ ọ li bino wẹ, ọ ri udu sa khi lọli ya mẹ wẹ emhi obọ mie. 
\p  
\v 6 Ama iPita ọọ li, “Mhi aa mhuẹ ukpaghọ ya nẹ, ama mhi ri emini mhi mhọli nẹ. Irari eva oyi iJesu iKirisiti ọnge iNazarẹti, vule ni u ke kia!”  
\v 7 Ighọ iPita ọ mu ọli obọ-ita vule. Udemhija, awẹ ali ili awẹ eyọli e na ya to.  
\v 8 Ighọ ọ ti vule migha, ọọ kia gasẹ. Ọ nu wẹ lo elemhi oni Owa Oyi Ẹshinẹgba, ọ kia, ọ jino, ọ kuẹghiẹ Ẹshinẹgba.  
\v 9 Abi ẹgbọ ni e la akaghọ nya e rọ mẹ ọli khi ọ kia gasẹ, khi ọ kuẹghiẹ Ẹshinẹgba,  
\v 10 e lẹsẹ ọni ọ khi, khi lọli ọ́ kpẹ ẹ shitọ odẹ unuẹkpẹ ni a lu Isomhotse e lema, oni ingme o sha ọgbọkpa abọ, ẹa lẹsẹ abi ọ li kia. 
\s1 IPita ọ nu eni e migha a fẹ ngme 
\p  
\v 11 Abi ọni ọmọse ọ li mu iPita ali iJọni mhuẹ eghọ, ọshabọ o sha eni ebubu ẹgbọ, e kpikpi fiẹ deba wẹ ya lo arakpha ni a lu Arakpha oyi iSolomoni ni o la oni Owa Oyi Ẹshinẹgba.  
\v 12 Abi iPita ọ rọ mẹ abi eni ẹgbọ ee li, ọọ wẹ. “Ẹẹ ẹgbọ iZirẹni, elọ o zẹ ni onana o rọ lighọ ri abọ sha ẹ ni a rọ lina a bino anye abinẹ khi ekpabọ ali ipfuasẹ eyi anye, anye rọ rọli ze?  
\v 13 Ẹshinẹgba ọyi Aburaamu, ali Aziki ali iGiekọpu, ni ọ khi Ẹshinẹgba oyi itita awa, ọ she ri ufumhi oyọli na iJesu, Ọni ọọ ga li. Ama eri a rue ọli na ena omhẹsẹ, a kie ọli odalo oyi iPaleti abi ọ tseku mhọli ọli shi udu khi lọli ya rue ọli obọ-a.\f + \fr 3:13 \ft Li zẹ \fq Okiali 3.15\f* 
\v 14 A kie iJesu ọni ọ pfuasẹ ali ọni ọ guẹ ẹ ngeli, a ri ochoghọ liẹ iPaleti ọ rue ọgbọ ni ọ gbe ugbeli abọ-a na ẹ.\f + \fr 3:14 \ft Li zẹ \fq iMat 27.15-23; iMak 15.6-14; iLuk 23.13-23; iJọn 19.12-15\f* 
\v 15 Ama a gbe ọgbọ ni ọ ri ọgbọ a je agbọ-a. Ama Ẹshinẹgba ọ gbo guise ọli le abi ọ rọ ghua. Anye aava anye mẹ ọli abi ọ rọ guale, anye rọ pfi ọtsẹlẹ shi ọ.  
\v 16 Itobọ ekpabọ ni e la eva oyi iJesu anye rọ dobẹ ri ọmọse ọna ni a lẹsẹ ni a fẹli ena ze, oni irudunga oyi ọni ọmọse lọli o zẹ khi ọ ga ze pfo nya ni a ga mẹ memena. 
\p  
\v 17 “Inyọghuo-mhẹ, mhi lẹsẹ khi emini ẹẹ ali eni e ralo na ẹ a riẹlẹ iJesu, khi elemhi umhalẹsẹ a te riẹlẹ wẹ.  
\v 18 Ina Ẹshinẹgba ọ li ri ungmemhi oyọli ya tsẹ, oni ọ rọte ekẹ rọte unu oyi emekẹguele ngme khi iKirisiti ọ ya mẹ osoli.  
\v 19 A zọnọ khasẹ Ẹshinẹgba khi a pfidọ, ni a mu pfi deba Ẹshinẹgba, ni ọ shishi olamhẹ eyẹ ẹ a, Ini a lighọ, ẹghẹghẹ iyẹmhẹa o ya rọte obọ oyi Ọnọmhuẹ bhale deba ẹ.  
\v 20 Ini ọọ ghie ọni ọ shobọ bhale agbọ ghi awa kpa, ikhi iJesu, ọni Ọmiepfuese.  
\v 21 IJesu ọ mema ya kie la obini iloghie ramhi ẹghẹghẹ ni Ẹshinẹgba ọ rọ ya mu emhikpa pfi gbo mele enegbọ-a, abi Ẹshinẹgba ọ li rọte unu oyi emekẹguele eni e pfuasẹ eyọli shobọ na awa ẹghẹghẹ ni o dọsẹ.  
\v 22 IMosisi ọ ngme ọli, ọọ, ‘Ọnọmhuẹ Ẹshinẹgba ọyẹẹ ọ ya rọte iteva oyẹẹ mu Ọmekẹguele nabi mhẹmhẹ vule na ẹ. A ya mema ri esọ shi ingmemhi ni ọ ya gueyẹ ẹ.\f + \fr 3:22 \ft Li zẹ \fq iDẹut 18.15,18\f* 
\v 23 Ọni ọa da ri esọ shi ọli ọ, Ẹshinẹgba ọ ya khi ọli ẹgbọ eyọli ku-a.’\f + \fr 3:23 \ft Li zẹ \fq iDẹut 18.19\f* 
\p  
\v 24 “Egbegbọ lọ khi emekẹguele nya rọte iSamuẹ ya je odalo, e kpẹ ngme emini a ya mẹ ẹghẹghẹ oyawa shi ekẹ.  
\v 25 Emini eni emekẹguele enana e ngme, ẹẹ o gọ lu, a li mhọli okemhi shi ishobọ ni Ẹshinẹgba ọ shi na itita ẹ, ni ọ la liẹ Aburaamu, ‘Mhi ya rọte obọ oyi imimi ẹ khi vọsẹ na ẹgbọ na agbọ nya.’\f + \fr 3:25 \ft Li zẹ \fq Igbae 22.18\f* 
\v 26 Abi Ẹshinẹgba ọ rọ mu Ọni ọọ ga oyọli vule, Ọ te ododẹ ghie ọli ghi ẹ ni ọ khi vọsẹ na ẹ abi ọ rọ mu ẹ nyenẹ lase ingmobe eyẹ ẹ le.” 
\c 4  
\s1 IPita ali iJọni e migha odalo oyi Enighie shi ẹzọ 
\p  
\v 1 Abi iPita ali iJọni e kie nu eni ẹgbọ ọ ngme, eni ẹẹ khekhẹ oni Owa Oyi Ẹshinẹgba ali ẹgbọ iSadusisi eghuo e bhale deba iPita ali iJọni.  
\v 2 Elemhi e bi wẹ itobọ khi eni ighiusomhi na kẹẹ eyi iJesu ee sẹsẹ eni ẹgbọ khi iJesu ọ rọte eghuli guale. Eri onana guele khi ẹgbọ eni e ghu-a khi e gbo ya rọte eva oyi iJesu guale.  
\v 3 Ighọ eni ẹgbọ e li mu iPita ali iJọni, irari obili o she bi ẹlẹghọ, e mu wẹ shi owa ighumha ramhi ogbeakọlọ.  
\v 4 Ama ebubu ẹgbọ ni e suọ ingme ni iPita ọ ngme e mie iJesu suọ. Emọse ni e ke miesuọ e ya khi ẹgbọ agbẹlẹ ishe. 
\p  
\v 5 Ogbeakọlọ, eni ẹẹ mhẹsẹ eyi iJu ali eni egbhali ali esẹsẹ Ishi eyi iMosisi eyi ẹgbọ iJu e legba iJerusalẹmu.  
\v 6 E ya mẹ Ọga ọyi ekpodalo ugamhi ni a lu Anasi ali iKefasi, ali iJọni ali Alẹzada ali ena ọmhuẹ-apfẹ oyi Ọga ọyi eni ẹẹ ralo ugamhi.  
\v 7 Ighọ e mu iPita ali iJọni bhale iteva oyẹwẹ migha. E mhila wẹ, “Ekpabọ nabisẹ ali eva oyọghuo a rọ gbe akanya ona?” 
\p  
\v 8 Ighọ iPita ni Ayẹmhẹ-nọ-pfuasẹ o vọ egbe ọ wẹ: “Ẹẹ enighie eyi ẹgbọ ali egbhali,  
\v 9 A mhila anye amo akanya onete ni a gbe na ọni ọ guọghọ-a ọna, ali abi a li rọ ọli toto.  
\v 10 Emhi oghuo o la ọ ni anye ya gueyẹ ẹ ali ẹgbọ iZirẹni nya. Itobọ eva oyi iJesu iKirisiti ọnge iNazarẹti, ọmọse ona ọ rọ migha iteva oyẹẹ ni ọ rọ toto ngmala ena. Lọli ọ khi ọni iJesu ni a ta ma apfida, ni Ẹshinẹgba ọ rọte eghuli guise le.  
\v 11 IJesu khi ọgbọ ni Ebe-no-pfuasẹ o ngme ni ọọ,\f + \fr 4:11 \ft Li zẹ \fq Iwolo 118.22\f* 
\q1 “ ‘Ẹchẹ ni itsọna e kie pfia, 
\q2 o tigbe mele oni ẹchẹli ẹbẹ 
\q2 ni o mu ẹloe nẹ nya-a.’ 
\m  
\v 12 Imiepfuese ọa la obọ oyi ọgbọlese, irari khi eva olese ọa la ni Ẹshinẹgba ọ rọ na ọgbọkhọghuo elemhi agbọ onana ni awa ya te mhọli imiepfuese.” 
\p  
\v 13 Abi eni ẹẹ mhẹsẹ na ẹgbọ iJu e rọ mẹ igbedu ni iPita ali iJọni e mhọli, ni e rọ ya lẹsẹ khi ẹgbọ tsẹ ni ẹa ye owa ebe e khi, abọ e sha wẹ, e mẹ-wẹ-mẹ khi e kpẹ nu iJesu u kia.  
\v 14 Ama, abi e rọ mẹ ọmọse ni a rọ ze khi ọ nu wẹ migha aghọ, ẹa ke mhuẹ abi e ya ngme.  
\v 15 E gueyẹ wẹ e vu wẹwẹ iteva lase ne, ighọ e li nu egbewẹ ye ochi.  
\v 16 Ẹẹ, “Sẹ awa ya li eni emọse ena?” Ẹgbọkpa ni e la iJerusalẹmu e she lẹsẹ ikanya ọnyaloa ni e gbe, ọa zẹ awa ya tia.  
\v 17 Ini ingme ona o khi gbekẹ-a, awa mema tse agua yẹ wẹ e khi gbo gbudu ri eva oyi iJesu nu ọgbọkhọghuo ngme. 
\p  
\v 18 Ighọ e lu iPita ali iJọni nyenẹ egbe bhale elemhi oni owa ugamhi, e gueyẹ wẹ e khi mẹ emini o rẹ wẹ gbo gbudu ri eva oyi iJesu nu ọgbọkhọghuo ngme wẹkhi irọli sẹsẹ.  
\v 19 Ama iPita ali iJọni ẹẹ wẹ, “Ẹẹ a sọ ọ ghue, ini o ya ti Ẹshinẹgba ẹloe, ini ẹẹ o fẹ ti ni anye suọ esọ na, ocho ni anye kha rọ suọ esọ na Ẹshinẹgba.  
\v 20 Irari khi aa tigbe ya mẹ khi anye ẹa ya gueyẹ ẹgbọ emini anye mẹ ni anye suọ.”  
\v 21 Abi e rọ nyamhise wẹ alo se, e zẹwẹ obọ vu. E mẹ khi ẹa zẹ wẹ ya nasẹ itobọ khi ẹgbọ ni e la aghọ nya ee kuẹghiẹ Ẹshinẹgba shi itobọ ọmọse ni ọa kpẹ dobẹ ẹ kia ni e rọ ze.  
\v 22 Irari khi ọni ọmọse ni a ri akanya ọnyaloa rọ ze ọ dọsẹ ikpe egbhuẹva. 
\s1 Olema ni igbaa eni e mie iKirisiti suọ e lema shi igbedu 
\p  
\v 23 Abi a rọ rue iPita ali iJọni abọ-a, e lẹ deba apfẹwẹ. E gueyẹ wẹ abi ighie eyi ekpodalo-ugamhi ali egbhali e ngme ẹwẹ.  
\v 24 Abi e rọ suọ ona, e ku unu a nyogho lema Ẹshinẹgba, ẹẹ, “Ọnọmhuẹ, yẹyẹ u ma ekẹ ali ukhuli ali okẹ oniẹmhi ali emini e la elemhi wẹ nya.\f + \fr 4:24 \ft Li zẹ \fq Okiali 20.11; iNee 9.6; Iwolo 146.6\f* 
\v 25 Yẹyẹ u ri Ayẹmhẹ-nọ-pfuasẹ rọte unu oyi oghie iDefidi ita anye ni ọ khi ọni ọọ ga oyẹ liẹ, 
\q1 “ ‘Elọ o zẹ ni ishishi ẹgbọ 
\q2 e rọ ọ nyaghu 
\q1 ni ẹgbọ e rọ ọ dọmhi mhẹ shi afuẹ? 
\q1  
\v 26 Ni ighie ni e la agbọ 
\q2 e rọ mu egbe shi okhọli, 
\q1 ẹgbọ eni ẹẹ mhẹsẹ e tigbili 
\q2 ni e rọ mu okhọli vule 
\q1 shi Ẹshinẹgba Ọnọmhuẹ ọ, 
\q2 ali iKirisiti ni ọ she zẹ.’\f + \fr 4:26 \ft Li zẹ \fq Iwolo 2.1-2\f* 
\m  
\v 27 Esheshi ghọ Erọdu ali iPọtiusi iPaleti e ya nu ẹgbọ iJẹta ali ẹgbọ iZirẹni lona kugbe elemhi oni ẹoli ona. E gba kugbe, e gbe iJesu ọni ọọ ga ọyẹ-a, ọni u zẹ.\f + \fr 4:27 \ft Li zẹ \fq iMat 27.1-2; iMak 15.1; iLuk 23.1,7-11; iJọn 18.28-29\f* 
\v 28 E riẹlẹ emini u ri ekpabọ ali ọghuẹmhẹ oyẹ gba shi ekẹ khi a ya mẹ.  
\v 29 Ama memena, Ọnọmhuẹ, bino abi e liẹ dọmhi, ni u ri ekpabọ na anye eni ẹẹ ga eyẹ, ni anye gbe udu ke ngme ungmemhi oyẹ.  
\v 30 Nise obọ-a ri ẹgbọ ke ze, u gbolo ẹ gbe ọlẹlẹ ọnyaloa ali ọshabọ rọte eva oyi iJesu Ọni ọọ ga ni ọ pfuasẹ oyẹ.” 
\p  
\v 31 Abi e rọ lema se, elemhi owa ni e la oo jighise, Ayẹmhẹ-nọ-pfuasẹ o tiemhie shi wẹ ọ, ọ ri igbedu na wẹ ẹ ngme ungmemhi oyi Ẹshinẹgba. 
\s1 Igbaa oyi eni e mie iJesu iKirisiti suọ ee kemhi itsua na egbe 
\p  
\v 32 Igbaa oyi eni e mie iJesu iKirisiti suọ e mhọli udu ali usamhi oghuo. Ọngẹwẹ ọa ke liẹ khi eri lọli mhọli emhikhọghuo ọtsobọ oyẹluẹ, ama eri e ku emhikpa gbe ke mhọli.\f + \fr 4:32 \ft Li zẹ \fq Ika 2.44-45\f* 
\v 33 Eni ighiusomhi na kẹẹ e ri ekpabọ ọ pfi ọtsẹlẹ je odalo shi ungmemhi irọte-eghuli guale oyi iJesu Ọnọmhuẹ. Ẹgbọ nya e mu ekpẹ ẹ na wẹ.  
\v 34-35 Aa mẹ ọngẹwẹ ni emhikhọghuo o to. Irari khi ẹghẹghẹ kpa, eni e mhọli ekẹ ali apfẹ e rọ rẹwẹ ẹ dẹ, e rue eni ikpaghọ ni e rẹ wẹ dẹ bhale ufuẹgẹ oyi ighiusomhi na kẹẹ. E kemhi wẹ na ọgbọgbọ abi o li to ọli. 
\p  
\v 36 Ighọ iJosẹfu ni ọ khi unuẹkpẹ oyi iLiva, ni a bia shi ekẹ iSapurọsi. IBanabasi, eni ighiusomhi na kẹẹ ee lu ọli. Emini a ri eva ona ngme khi Ọrudushi-ẹgbọ ọ.  
\v 37 IBanabasi ọ ri ekẹ ni ọ mhọli dẹ, ọ rue eni ikpaghọ ni ọ rọli dẹ bhale ya shi ufuẹgẹ oyi ighiusomhi na kẹẹ. 
\c 5  
\s1 Ananayasi ali iSafira 
\p  
\v 1 Ọmọse ọghuo ọ la ọ ni a lu Ananayasi ali ughuẹ ọli iSafira, e ku abọ gbe ri ekẹ oyẹwẹ dẹ.  
\v 2 Ọ te eni ikpaghọ ni ọ ri oni ekẹ dẹ rue sheli na egbọli, ughuẹ ọ lama shi ọli ọ. Ọ tsua ikhukhui eni ikpaghọ ghi ighiusomhi na kẹẹ. 
\p  
\v 3 Ighọ iPita ọọ, “Ananayasi, elọ o zẹ ni u rọ zẹ ni ọkphaghiẹ ọ lo ẹ udu, ni u rọ lo ẹgbhọli khasẹ Ayẹmhẹ-nọ-pfuasẹ, ni u rọ rọte eni ikpaghọ ni u ri oni ekẹ dẹ rue shi na egbe ẹ?  
\v 4 Ọ́á khi oyẹ oni ekẹ o khi neni u rọli dẹ? Abi u rọ rọli dẹ se, eni ikpaghọ ẹa kie khili eyẹ? Elọ o rẹẹ sa usamhi onana? Ọa khi ọgbọ u lo ẹgbhọli khasẹ ama Ẹshinẹgba!” 
\p  
\v 5 Abi Ananayasi ọ rọ suọ ungmemhi ona se, ọ de ekẹ, ọ ghua. Ulishi oniẹmhi o ku rughu ẹgbọ kpa ni e suọ emini a mẹ.  
\v 6 Ighọ izẹo e rọte iteva oyẹwẹ fiẹ lasele ya ri ide khuli olimhi oyọli, e tsua li fiẹ je olase ya rọ tọ. 
\p  
\v 7 Iwakati esẹ e lẹsẹ na dọsẹ te, ughuẹ ọli ọ lole, ọa lẹsẹ emini a mẹ.  
\v 8 IPita ọ mhila li, ọọ, “Gueyẹ mhẹ ghue, ingme ni yẹyẹ ali Ananayasi ọdọẹ a ri oni ekẹ dẹ na?” 
\p Ọọ li, “Ii.” “Ighọ anye ri oni ekẹ dẹ.” 
\p  
\v 9 IPita ọọ, “Sẹ ẹẹ ava-ava a li yemhẹ shi oghuo ni a mhẹsẹ Ayẹmhẹ-nọ-pfuasẹ bino? Emọse ni e tsua ọdọẹ ya tọ lẹna e la odẹ kia bhale. Wẹwẹ e gbo li tsuẹ ya tọ!” 
\p  
\v 10 Utoghuokpe ọ de ekẹ, ọ ghua. Eni emọse e bhale, e ya ẹ khi ọ she ghua, ighọ e tsua li ya tọ mama ọdọli.  
\v 11 Ulishi oniẹmhi o mu igbaa oyi eni e mie iJesu iKirisiti suọ nya ni e suọ emini a mẹ. 
\s1 Eni Ighiusomhi na kẹ e ri eni ee ghua ebubu ze 
\p  
\v 12 Eni ighiusomhi na kẹẹ e gbe ebubu ọlẹlẹ ọnyaloa ali ọshabọ ọdọda iteva oyi eni ẹgbọ. Igbaa oyi eni e mie iJesu iKirisiti suọ e lona Arakpha oyi iSolomoni na elemhi Owa Oyi Ẹshinẹgba elemhi ikudugbe.  
\v 13 Ọgbọkhọghuo ọa gbudu kugbe wẹ ọ aboriẹkhia khi ẹgbọ nya e ri ekpẹ na wẹ.  
\v 14 Abi o riẹ khi ighọ, eri ebubu emọse ali ikpotso elese e mie Ọnọmhuẹ suọ, a ku wẹ ma igbaa oyi eni e mie iJesu iKirisiti suọ.  
\v 15 Irari ikanya ọnyaloa ni ighiusomhi na kẹẹ e gbe, ẹgbọ e tsua ẹgbọ ni ẹa ze bhale odẹ ifu apfẹ rẹwẹ yẹshi ukpho ali iya, ini akphakpha oyi iPita oo nga wẹ egbe ini ọọ dọsẹ.  
\v 16 Olele ẹgbọ e rọte ẹoli ni e la gasẹ iJerusalẹmu bhale. E tsua ẹgbọ ni ẹa ze ali eni e mhọli ayẹmhẹ ọkphaghiẹ bhale, ighọ a ri wẹwẹ nya ze. 
\s1 A mu okhọli vule shi Ighiusomhi na kẹ ọ 
\p  
\v 17 Ọga ọyi ekpodalo ugamhi ali apfọli ni e ga rọ la otu oghuo ni a lu otu iSadusisi, e kpe ofuma a deba ighiusomhi na kẹẹ.  
\v 18 E muno eni ighiusomhi na kẹẹ ku lo owa ighumha.  
\v 19 Ama ẹliyọsẹ, agẹni ọ khueghie odẹ oyi oni owa ighumha-a na wẹ, ọ rue wẹ ya lase.  
\v 20 Ọọ wẹ, “A ke vu, a je elemhi ogba na Owa Oyi Ẹshinẹgba ya migha ni a gueyẹ ẹgbọ usomhi onete oyi agbọ onogbọ ona.” 
\p  
\v 21 Abi ogbe o rọ gbe-a, eni ighiusomhi na kẹẹ e dọsẹ lo Owa oyi Ẹshinẹgba, ee sẹsẹ. Abi Ọga ọyi ekpodalo ugamhi ali apfọli ni e rọ ga la otu oghuo e rọ bhale, e lu ilegba oyi eni egbhali eyi ẹgbọ iZirẹni (ni a lu iSaẹdiri), ighọ e lu eni e ri ẹloe ẹ khu owa ighumha e ka wolọ eni ighiusomhi na kẹẹ igha ghi ẹwẹ.  
\v 22 Ama abi e rọ ramhi aghọ, e bhale ya ẹ khi eni ighiusomhi na kẹẹ ẹa la oni owa ighumha, ighọ e nyenẹ egbe je ya gueyẹ eni e ghie wẹ.  
\v 23 Ẹ li, “Anye bhale ya ẹ khi a sọ okpẹ owa ighumha gba-i! Khi ekhekhẹ e migha unu odẹ. Ama abi anye rọ khueghie eni odẹ-a lo elemhi aghọ, anye ẹa mẹ ọgbọkhọghuo elemhi aghọ.”  
\v 24 Abi e rọ suọ ona, abọ e sha oghie ọyi eni ẹ khẹ ekhẹ Owa Oyi Ẹshinẹgba, ali ighie eyi ekpodalo-ugamhi, itobọ khi ẹa dobẹ lẹsẹ udi emini a mẹ ena idiegbe oyi ighiusomhi na kẹẹ. Oni ingme ọa zẹ wẹ sa. 
\p  
\v 25 Ighọ ọmọse ọghuo ọ bhale wẹ iteva, ọọ wẹ, “A bino! Ẹgbọ ni a mu shi owa ighumha e la Owa Oyi Ẹshinẹgba a sẹsẹ ẹgbọ!”  
\v 26 Ighọ eni ẹ khẹ ekhẹ e vu ya mu eni ighiusomhi na kẹẹ. Ẹa ri itoto riẹlẹ ọli itobọ khi ulishi eni ẹgbọ o mu wẹ ini ẹ ya tono wẹ echẹ. 
\p  
\v 27 E muno eni ighiusomhi na kẹẹ bhale ya migha agbala, ọni oghie ọyi ekpodalo-ugamhi eyi Ẹshinẹgba ọ mhila wẹ ogbọ.  
\v 28 “Anye tse agua gueyẹ ẹ aa khi ke ri eva ona sẹsẹ ẹgbọ. Ama a kiele ẹ sẹsẹ ẹgbọ, osẹsẹ oyẹẹ o gbhiaku ekẹ iJerusalẹmu nya. A yẹsẹ ni ẹgbọ e ya ke dabi khi anye gbe iJesu-a!”\f + \fr 5:28 \ft Li zẹ \fq iMat 27.25\f* 
\p  
\v 29 IPita ali ighiusomhi na kẹẹ eni e kpọle ẹ wẹ, “Anye mema ya ri oyi Ẹshinẹgba gbe dọsẹ oyi ẹgbọ.”  
\v 30 Ẹshinẹgba ọyi itawa ọ rọte eghuli guise iJesu le, ọni a soli-a shi ọọra gbe-a.  
\v 31 Ẹshinẹgba ọ she yasẹ ọli nga obita ni o pfuasẹ oyọli abi Omi Oghie ali Ọmiepfuese, ni ọọ ri ẹghẹghẹ na iZirẹni gbo mhọli imupfi ali igbekua shi olamhẹ.  
\v 32 Anye khi ọtsẹlẹ shi eni ingme ena nya, ighọ li khi Ayẹmhẹ-nọ-pfuasẹ, ni ọ khi isomhopfa ni Ẹshinẹgba ọ rọna eni e suọ esọ na li.  
\v 33 Abi e rọ suọ ona, e pfaa, e nono abi e li ya gbolo wẹ-a.  
\v 34 Ama iGamaliẹ ni ọ khi otu iFarisi ni ọọ sẹsẹ Ishi eyi iMosisi, ni ọ khi ọni ẹgbọ e ri ekpẹ ẹ na, ọ vule migha elemhi oni igbaa oyi eni egbhali, ọ a wolọ wẹ fiẹ ne ukuku ẹghẹghẹ.  
\v 35 Ighọ ọọ wẹ, “Ẹẹ emọse iZirẹni a kuegbe-a sa emini a nono khi a ya riẹlẹ eni emọse ena.  
\v 36 Ẹghẹghẹ ni o dọsẹ, ọmọse ọghuo ni a lu iTeudasi ọ lasele, ọọ lu egbọli emhi, ẹgbọ egbhuẹshe asha ene e kpikpi deba li. Abi a rọ gbe ọli-a, ẹgbọ eyọli e gbhiaku-a, oni okiali oyọli o mele afuẹ-a.  
\v 37 IJudasi ọngi iGalili ọ gbo lasele ẹghẹghẹ ni a rọ leli ẹgbọ, lọli ali ẹgbọ eyọli e pfi onyaghu. Abi a rọ gbe ọli a ẹgbọ eyọli e gbhiaku-a.  
\v 38 Irarighọ, mhi ye ẹ ude shi idiegbe oyi ẹgbọ ena, a zẹ wẹ obọ! Zẹ wẹ obọ ni e vu! Ini emini e rọ bhale khi obọ oyi ọgbọ o te bhale, e ya de.  
\v 39 Ama ini o khi obọ oyi Ẹshinẹgba o te bhale, aa ya tigbe dobẹ mu wẹ gba, ama khi Ẹshinẹgba a nu ẹ khọli.” 
\p  
\v 40 Oni ungmemhi ni ọ ngme o lo wẹ udu. E lu eni ighiusomhi na kẹẹ lasele, e gbe wẹ itali, e gueyẹ wẹ e khi ke ngme ingme oyi iJesu, e zẹ wẹ obọ vu.  
\v 41 Eni ighiusomhi na kẹẹ e rọte aghọ vu, ee ghẹlẹ khi wẹwẹ e li tẹ ọ na ri omama a mu shi eva oyi iJesu.  
\v 42 Ẹa tigbe yẹmhẹ-a, ogbẹlẹ kpa e rọ ọ sẹsẹ, ni e gbo rọ ọ tse abọ usomhi onete khi iJesu ọ khi Ọmiepfuese, elemhi ọgba na Owa oyi Ẹshinẹgba ali rọte owa ya je owa. 
\c 6  
\s1 Emọse oshilua ni a zẹ 
\p  
\v 1 Ẹghẹghẹ ni a ngme ena khi igbaa oyi eni e mie iJesu iKirisiti suọ khi ee ke bu shi ọ, ẹgbọ iJu eni ee ngme ẹlẹmhi iGiriki elemhi wẹ, ee wọlọ khi ẹgbọ iJu eni ẹẹ ngme ẹlẹmhi Iburu, e ri ukpẹloe ẹ gbe esamhi-olimhi eyi wẹwẹ ini ẹẹ kemhi eminale ogbẹlẹ kpa.  
\v 2 Ighọ ighiusomhi ogbava e luno igbaa oyi eni e mie iJesu iKirisiti suọ nya kugbe, ẹẹ wẹ, “Ọa ti ni anye pfi akanya itsabọ ungmemhi oyi Ẹshinẹgba shi ekẹ, ni anye sọ alo ghue eminale ikemhi.  
\v 3 A zẹ emọse oshilua elemhi iteva oyẹ ẹ, ni a lẹsẹ khi e mhọli Ayẹmhẹ-nọ-pfuasẹ ali ilẹsingme. Ni awa ri akanya irẹloe-khu ingme eminale ali itsua ikemhi na wẹ.  
\v 4 Isheghọ, ni anye mẹ asha ri ẹloe shi iromhi isọsọ ali itsabọ usomhi onete.” 
\p  
\v 5 Oni akhọkhọmhẹ ona o ga ghọle ẹgbọ kpa ni e le gba. E zẹ iSitivini ni ọ mhọli irudunga ali Ayẹmhẹ-nọ-pfuasẹ, ali iFilipu, ali iPirokorusi, ali iNikanọ, ali iTimọni, ali iPamẹnasi, ali iNikolasi ni ọ khi ọngi Atiọki ni a mu pfi je irudunga oyi ẹgbọ iJu.  
\v 6 E ri ẹgbọ ena khasẹ eni ighiusomhi na kẹẹ, eni ighiusomhi na kẹẹ e ri abọ nga wẹ ukhomhi lema na. 
\p  
\v 7 Ighọ ungmemhi oyi Ẹshinẹgba oo gẹ shi ọ. Igbaa oyi eni e mie iJesu iKirisiti suọ e bu shi ọ elemhi iJerusalẹmu. Ebubu ekpodalo-ugamhi eyi Ẹshinẹgba e lama shi oni irudunga. 
\s1 A mu iSitivini 
\p  
\v 8 ISitivini, ọmọse ni Ẹshinẹgba ọ khivọsẹ na, ọ mhọli ekpabọ oyi Ẹshinẹgba rọ gbe ikanya ọnyaloa ali ọshabọ iteva oyi ẹgbọ.  
\v 9 Ama ẹgbọ eghuo ni e khi igbhogbho na owa ugamhi oyi eni e kpẹ khi ighumha, e nu iSitivini i khakọ. IJu eni ẹgbọ ena e khi ni e rọte ekẹ iSairini, ali Alẹzadira bhale ali eni e rọte ekẹ iSilisha ali Esha bhale, ni e ke ngeli iJerusalẹmu.  
\v 10 Ama ẹa dobẹ nu ilẹsingme ali Ayẹmhẹ ni ọ rọ ọ ngme khẹ abọ. 
\p  
\v 11 Ighọ e bẹna tanọ shi ẹgbọ eghuo elemhi, e liẹ, “Anye suọ abi iSitivini ọ rọ pfi unu-a deba iMosisi ali Ẹshinẹgba.” 
\p  
\v 12 Ighọ e ngmiasẹ eni ẹgbọ ali eni egbhali ali eni ẹ sẹsẹ Ishi eyi iMosisi. E mu iSitivini bhale ilegba oyi eni ẹẹ mhẹsẹ ali esọ-ẹzọ eyi ẹgbọ iJu ni a lu iSaẹdiri.  
\v 13 E wolọ ẹgbọ lasele ni e pfi ọtsẹlẹ ẹgbhọli khi, “Ọmọse ọna ọa tigbe yẹmhẹ-a ingme-ingmemhi ipfiunu-a ni ọ ngme ẹ deba Owa Oyi Ẹshinẹgba no pfuasẹ ali ushi.  
\v 14 Irari khi anye suọ khi ọọ li khi iJesu ọnge iNazarẹti ọna, ọ ya guọghọ Owa oyi Ẹshinẹgba oyi ẹgbọ iJu-a, ọ ya gbo mu ighuighuẹ ni iMosisi ọ rọ shi ekẹ na anye pfi.” 
\p  
\v 15 Ẹgbọ ni e la oni ilegba nya ee bino iSitivini, e mẹ khi alo eyọli e gẹ nyanyanya abi alo eyi agẹni. 
\c 7  
\s1 Ungmemhi ni iSitivini ọ ngme 
\p  
\v 1 Ighọ Ọga ọyi ekpodalo ugamhi ọ mhila li, ọọ li, “Igẹsikia ingme ni a gue shi ẹ egbe ena e khi?” 
\p  
\v 2 ISitivini ọọ li, “Inyọghuo ali ita ni e le gba, a ri esọ shi mhẹ ekẹ! Ẹshinẹgba ni ọ mhọli ufumhi, ọ ri egbe khasẹ ita awa Aburaamu abi ọ rọ kie la ekẹ iMẹsopotemia, neni ọ tigbe je ẹoli Arani ya la.  
\v 3 Ẹshinẹgba ọọ li, ‘Lase ekẹ ali iteva oyi ẹgbọ eyẹ le, ke je ekẹ ni mhi ya rọkhasẹ ẹ.’\f + \fr 7:3 \ft Li zẹ \fq Igbae 12.1\f* 
\p  
\v 4 “Ighọ ọ rọte oni ekẹ iKadia vu ya la ẹoli Arani. Abi itali ọ rọ ghu-a se, Ẹshinẹgba ọ ghie ọli je ekẹ ni a ngeli ogbe namo.\f + \fr 7:4 \ft Li zẹ \fq Igbae 11.31; 12.4\f* 
\v 5 Ọa ri ugu okhọghuo akana na li, wẹkhi ukuku ekẹ okhọghuo ọ khi na li. Ama khi Ẹshinẹgba ọ she kpẹ shobọ na li khi lọli ali imimi ọli, e ya le ugu oni ekẹ, abi o rọ tseku khia khi ẹghẹghẹ aghọ Aburaamu ọa bia ọmọ ọkhọghuo ne.\f + \fr 7:5 \ft Li zẹ \fq Igbae 12.7; 13.15; 15.18; 17.8\f* 
\v 6 Ina Ẹshinẹgba ọ li nu ọli ngme. ‘Imimiẹ e ya khi epfẹse shi ekẹ ni ọa khi oyẹwẹ, e ya khi ighumha, a nasẹ wẹ elemhi ikpe egbhuẹshe asha ene.  
\v 7 Ẹshinẹgba ọọ, ama mhi ya nasẹ ushishi ni e ya muno wẹ ighumha. Ini mhi nasẹ wẹ na wẹ se, e ya rọte ushishi oghọ lasele bhale ekẹ ona ya ngeli, e gbo la akana a ga mhẹ.’\f + \fr 7:7 \ft Li zẹ \fq Igbae 15.13; Okiali 3.12\f*\f + \fr 7:7 \ft Li zẹ \fq Igbae 15.13-14\f* 
\v 8 Ighọ Ẹshinẹgba ọ nu Aburaamu shobọ ishẹlẹ-a ni o ya khi irọkhasẹ khi ọgbọ ọ mhuẹ obọ shi oni ishobọ. Ighọ Aburaamu ọ bia Aziki, ọ shẹlẹ ọli-a abi ọ rọ gbe ogbẹlẹ elele. Ighọ Aziki ọ gbo li khi ita iGiekọpu, iGiekọpu ọ gbo li khi ita emọse ogbava ni e khi ititawa.\f + \fr 7:8 \ft Li zẹ \fq Igbae 17.10-14; 21.2-4; 25.26; 29.31--35.18\f* 
\p  
\v 9 “Itobọ khi eni imi iGiekọpu ee dọ iJosẹfu ọkọnyọ, e rọli dẹ abi oghumha ya je ekẹ iJipiti. Ama Ẹshinẹgba ọ nu ọli la.\f + \fr 7:9 \ft Li zẹ \fq Igbae 37.11,28; 39.2,21\f* 
\v 10 Ọ tsumhi ọli obọ ikphakphamhẹ nya. Ọ ri ilẹsingme na iJosẹfu, ọ gbo kpaghiẹ ọli obọ ni ingme oyọli o rọ ghọle iFero ni ọ khi oghie ọyi ekẹ iJipiti. Ighọ ọni oghie ọ rọli leghie ukhomhi iJipiti ali agbala oyọli nya.\f + \fr 7:10 \ft Li zẹ \fq Igbae 41.39-41\f* 
\p  
\v 11 “Ighọ okiamhi oniẹmhi o la ekẹ iJipiti ali iKena a pfi ni o pfi osoli oniẹmhi na ititawa ni ẹa ke rọ mẹ eminale e le.\f + \fr 7:11 \ft Li zẹ \fq Igbae 42.1-2\f* 
\v 12 Abi iGiekọpu ọ rọ suọ khi eminale e kpọku shi ekẹ iJipiti, ọ ghie imiọli ni e khi ititawa je oobọ ya bino ododẹ.  
\v 13 Utonuzeva ni e ke ye, ọni iJosẹfu ọ gueyẹ inyọghuo ọli ọni lọli khi, aghọ iFero ọ la lẹsẹ ẹgbọ eyi iJosẹfu.\f + \fr 7:13 \ft Li zẹ \fq Igbae 45.1,16\f* 
\v 14 Ighọ iJosẹfu ọ ghie ya rue itali iGiekọpu ali ẹgbọ eyọli nya ni e kugbe khi oshe ẹa la egbhuẹne.\f + \fr 7:14 \ft Li zẹ \fq Igbae 45.9-10,17-18; 46.27\f* 
\v 15 Ighọ iGiekọpu ọ je ekẹ iJipiti, ashini lọli ali ititawa e ghu-a shi.\f + \fr 7:15 \ft Li zẹ \fq Igbae 46.1-7; 49.33\f* 
\v 16 A tsua ilimhi eyẹwẹ nyenẹ egbe je iShẹkẹmu ya rọ tọ uji ni Aburaamu ọ ri ikpaghọ nu unuẹkpẹ oyi Amọni dẹ.\f + \fr 7:16 \ft Li zẹ \fq Igbae 23.3-16; 33.19; 50.7-13; iJosh 24.32\f* 
\p  
\v 17 “Abi oni ẹghẹghẹ o rọ ti ramhi ni Ẹshinẹgba ọ rọ ya ri ishobọ oyọli tsẹ na Aburaamu, ẹgbọ eyawa ni e la iJipiti e lolo bu shi ọ.  
\v 18 Ighọ oghie ọlese ni ọa lẹsẹ emhikhọghuo ingme oyi iJosẹfu ọ ke la ukpẹkhomhi shi ekẹ iJipiti.\f + \fr 7:18 \ft Li zẹ \fq Okiali 1.7-8\f* 
\v 19 Ọọ na ẹgbọ eyawa osoli obe, ọ jili ititawa, ọ ri itoto liẹ wẹ, e pfino imiwẹ kua ni eni eniyẹ e ba ghuloa.\f + \fr 7:19 \ft Li zẹ \fq Okiali 1.10-11,22\f* 
\p  
\v 20 “Oni ẹghẹghẹ a rọ bia iMosisi, ni ọa khi ọmọ na tsẹ. A la owa oyi itali kuẹlẹ ọli iki esẹ.\f + \fr 7:20 \ft Li zẹ \fq Okiali 2.2\f* 
\v 21 Abi ẹẹ ke rọ dobẹ rọli sheli, e rue ọli ya shi epfẹ okẹ. Omi iFero ni ọkpotso ọ mẹ ọli rue, ọ kuẹlẹ ọli abi omi ọli.\f + \fr 7:21 \ft Li zẹ \fq Okiali 2.3-10\f* 
\v 22 IMosisi ọ wẹna owẹna ali ilẹsingme oyi iJipiti, ekpabọ o la ẹmuẹ oyọli ali emini ọọ riẹlẹ. 
\p  
\v 23 “Abi iMosisi ọ rọ gbe ikpe egbhuẹva, ọ mhọli shi udu khi lọli lẹ ya bino ẹgbọ eyọli ni e khili ẹgbọ iZirẹni.  
\v 24 Ighọ ọ mẹ khi ọngi iJipiti ọọ nasẹ ọngi iZirẹni. Ighọ ọ li ye odọsẹ, ọ gbe ọngi iJipiti-a.  
\v 25 Eri iMosisi ọ dabi khi ẹgbọ eyẹluẹ e ya mẹ ọli mẹ khi eri Ẹshinẹgba ọ rẹ luẹ ẹ tsumhi ẹgbọ eyọli, ama ẹa lighọ mẹ ọli mẹ.  
\v 26 Ogbeakọlọ khi iMosisi ọ bhale ya ẹ khi ẹgbọ iZirẹni aava e nu egbewẹ ẹ khọli, ọọ nono ni lọli rẹwẹ riẹlẹ. Ọọ wẹ, ‘Elọ o zẹ ni ẹẹ ni a gbo li khi inyọghuo egbe a rọ nu egbe ẹ a khọli?’ 
\p  
\v 27 “Ama ọni ọa guẹli ni ọ la ọ ọ ghi iMosisi abọ pfia, ọọ li, ‘Ọghuo ọ rẹ khi ọni ọọ mhẹsẹ na anye ali ọni ọọ sọ ẹzọ na anye?  
\v 28 Eri u wa nono ni u li gbe mhẹ-a abi u li gbe ọngi iJipiti a oodẹ?’  
\v 29 Abi iMosisi ọ rọ suọ ona, ọ na pfia je ekẹ oyi iMidiani ya la abi ọpfẹse, ọ bia eniyẹ aava shi aghọ.\f + \fr 7:29 \ft Li zẹ \fq Okiali 18.3-4\f*\f + \fr 7:29 \ft Li zẹ \fq Okiali 2.11-15\f* 
\p  
\v 30 “Ikpe egbhuẹva e dọsẹ se, agẹni ọ ri egbe khasẹ iMosisi elemhi ẹlẹmhi erali ni oo to ukhomhi ebuli.  
\v 31 IMosisi ọ mẹ ọli, o sha li abọ. Ọọ lẹ ni ọ ya bino, uruli oyi Ọnọmhuẹ o lu ọli, ọọ li,  
\v 32 ‘Mhẹmhẹ mhi khi Ẹshinẹgba ọyi itita ẹ, Ẹshinẹgba ọyi Aburaamu ali ọyi Aziki, ali ọyi iGiekọpu.’ IMosisi ọọ guọ elemhi ulishi, ọa ke gbudu bino oobọ. 
\p  
\v 33 “Ọnọmhuẹ ọọ li, ‘Gueghie ekuẹ ni u sọ, ekẹ ni o pfuasẹ u migha.  
\v 34 Mhi she mẹ ajilimhẹ ni ẹgbọ eyẹmhẹ ni e la iJipiti ẹ mẹ memena. Mhi she suọ ekperumhẹ oyẹwẹ, mhi she bhale ya mie wẹ pfuese. Bhale memena khi mhi ya ghie ẹ nyenẹ egbe je ekẹ iJipiti.’\f + \fr 7:34 \ft Li zẹ \fq Okiali 3.1-10\f* 
\p  
\v 35 “Ọni iMosisi ọna ẹgbọ eyọli e ke ekpẹ kie, ni ẹẹ ọ li, ‘Ọghuo ọ rẹ khi ọni ọ mhẹsẹ ẹ na anye ali ọni ọọ sọ ẹzọ ọyi anye?’ Ẹshinẹgba lọlighuo ọ ri agẹni ni ọ ri egbe khasẹ ọli elemhi ẹlẹmhi erali ni e to ghie iMosisi ọ ka khi ọni ọọ mhẹsẹ ali ọmiepfuese ọyẹwẹ.\f + \fr 7:35 \ft Li zẹ \fq Okiali 2.14\f* 
\v 36 Lọli ọ rẹwẹ ya fiẹ lase ekẹ iJipiti, ọ la ekẹ iJipiti ali obini Okẹ Ifulọ ali udu oyẹmhi elemhi ikpe egbhuẹva gbe akanya ọnyaloa ali irọkhasẹ.\f + \fr 7:36 \ft Li zẹ \fq Okiali 7.5; 14.21; iNọba 14.33\f* 
\p  
\v 37 “IMosisi lọlighuo ọọ ẹgbọ iZirẹni, ‘Ẹshinẹgba ọ ya rọte elemhi ẹ ghie ọmekẹguele ọnabi mhẹmhẹ ghi ẹ.’\f + \fr 7:37 \ft Li zẹ \fq iDẹut 18.15,18\f* 
\v 38 Ọ la iteva ebubu ẹgbọ elemhi udu oyẹmhi, li shi agẹni ni ọ ke nu ọli ngme ukhomhi ute iSinai, li she ititawa, ọ mie ungmemhi ni o ri agbọ ọ na ọgbọ, ọ rue ọli na awa.\f + \fr 7:38 \ft Li zẹ \fq Okiali 19.1--20.17; iDẹut 5.1-33\f* 
\p  
\v 39 “Ama eni ititawa ẹa nono ni wẹwẹ e suọ esọ na li, eri e kie iMosisi, e ri udu oyẹwẹ nyenẹ egbe ukhokho je ekẹ iJipiti.  
\v 40 Ẹẹ Erọni, ‘Mama ikhumhi na anye ni e ya ri anye ke kia, irari khi anye ẹa lẹsẹ abi iMosisi ni ọ rue anye te iJipiti lasele ọ ke li kia.’\f + \fr 7:40 \ft Li zẹ \fq Okiali 32.1\f* 
\v 41 Oni ẹghẹghẹ eni ẹgbọ e rọ mama ikhumhi ni o li abi ozele ena, ee luasẹ ọli, e ghẹlẹ shi oni ikhumhi ni e ri abọ eyẹwẹ mama.\f + \fr 7:41 \ft Li zẹ \fq Okiali 32.2-6\f* 
\v 42 Ighọ Ẹshinẹgba ọ sọ ukhokho gbe wẹ, ọ zẹ ni e ga ovọ, ali uki, ali ikpẹtata abi a li kẹkẹ ọli shi ebe emekẹguele, ni ọọ: 
\q1 “ ‘Ẹẹ ẹgbọ iZirẹni, 
\q1 abi a rọ la udu oyẹmhi 
\q2 ikpe egbhuẹva a luasobo, 
\q2 mhẹmhẹ a ri iluasobo na? 
\q1  
\v 43 A yasẹ okula oyi 
\q1 ikhumhi iMolẹki 
\q1 ali ukpẹtata oyi iRefani, 
\q1 ni e khi ikhumhi ni 
\q1 a ri abọ mama ni a ga. 
\q1 Irarighọ, mhi ya ri ẹgbọ bhale 
\q2 ya mu ẹ okhọli vu, 
\q1 e tsua ẹ dọsẹ obini ekẹ iBabilọ.’\f + \fr 7:43 \ft Li zẹ \fq Emọ 5.25-27\f* 
\p  
\v 44 “Ititawa e mhọli igholo oyi ọtsẹlẹ obini elemhi udu oyẹmhi. Abi Ẹshinẹgba ọ li khọkhọ li ye iMosisi, ighọ ọ li riẹlẹ ọli.\f + \fr 7:44 \ft Li zẹ \fq Okiali 25.9,40\f* 
\v 45 Abi e rọ le oni igholo ugu se, iJoshua ọ tsua li ma egbe bhale ekẹ oyi ishishi ni Ẹshinẹgba ọ khu kua na wẹ. O nu wẹ la ramhi ẹghẹghẹ oyi iDefidi.\f + \fr 7:45 \ft Li zẹ \fq iJosh 3.14-17\f* 
\v 46 IDefidi ni Ẹshinẹgba ọ ri afu na ọ mhila li ini lọli tọ owa na Ẹshinẹgba ọyi iGiekọpu\f + \fr 7:46 \ft Li zẹ \fq 2 iSam 7.1-16; 1 Okhẹ 17.1-14\f* 
\v 47 Ama iSolomoni ọ tọ owa na Ẹshinẹgba.\f + \fr 7:47 \ft Li zẹ \fq 1 Ighie 6.1-38; 2 Okhẹ 3.1-17\f* 
\p  
\v 48 “Abibi o ririẹ li, a lẹsẹ khi Ẹshinẹgba nọ Yagha nẹ Nya ọa ya la owa ni ẹgbọ e ri abọ tọ. Lọli o zẹ khi Azaya ọmekẹguele ọ guele khi. 
\q1  
\v 49 “Ẹshinẹgba ọọ, ‘Iloghie o khi 
\q1 ukpẹkhomhi ni mhia shitọ. 
\q1 Ekẹ agbọ o khi 
\q1 akphawẹ-nga oyẹmhẹ. 
\q1 Owa nabisẹ ẹẹ ẹgbọ 
\q2 a ya tigbe tọ na mhẹ? 
\q1 Asha no ghuo o ya gua mhẹ la? 
\q2  
\v 50 Ọa khi mhẹmhẹ-ghuo 
\q1 mhi ma eni emhi ena nya?’\f + \fr 7:50 \ft Li zẹ \fq Aza 66.1-2\f* 
\p  
\v 51 “Ẹẹ ẹgbọ usuesọ-akhuẹ ni e zese udu oyẹwẹ-a khali igba zuse esọ. A li abi itita ẹ, ni e kie Ayẹmhẹ-nọ-pfuasẹ.\f + \fr 7:51 \ft Li zẹ \fq Aza 63.10\f* 
\v 52 A famhi mẹ ọmekẹguele ọkhọghuo ni itita ẹ ẹa mu okhọli vule shi ọ? Eri e gbo gbolo eghuo-a, ni e mẹ ekẹ guele khi, Ọni ọọ suọ esọ na Ẹshinẹgba ọ ya bhale. Memena ẹẹ a she rọ ọni iKirisiti ọna dẹ, a gbe ọli-a.  
\v 53 Ẹẹ ni a rọte obọ oyi agẹni ni Ẹshinẹgba ọ ghie mie ishi, ẹẹ áà kie gbo ri eni ishi gbe akanya.” 
\s1 A tono iSitivini echẹ 
\p  
\v 54 Abi eni igbaa eyi iSahẹdiri e rọ suọ ingmemhi ena, e pfaa na li ramhi ni e rọ gbe akọ akọ.  
\v 55 Ama iStivini ni ọ mhọli Ayẹmhẹ-nọ-pfuasẹ ọ yasẹ alo idane, ighọ ọ mẹ ugẹmhi oyi ufumhi oyi Ẹshinẹgba, ali iJesu khi ọ migha obita oyi Ẹshinẹgba.  
\v 56 Ighọ iSitivini ọọ, “Mhi mẹ khi iloghie o khueghie-a, mhi gbo mẹ iJesu ọni Omi Ọgbọ khi ọ migha obita oyi Ẹshinẹgba.” 
\p  
\v 57 Abi eni igbaa eyi eni iSahẹdiri e rọ suọ ona, e ri abọ khukhu esọ. Ẹ tsẹsẹ leghe, e vẹ rughu ọli.  
\v 58 E tialọ ọli fiẹ ifuapfẹ je ukhokho oni ẹoli, ee tono ọli echẹ. Eni ee tono ọli echẹ e gueghie itsua ni e sọ na ọmọse ọghuo ni a lu iSọlu mhuẹ.  
\v 59 Abi e rọ ọ tono iSitivini echẹ, ọ sọ iromhi, ọọ, “IJesu Ọnọmhuẹ, kpẹkpẹ kpe abọ mie ayẹmhẹ oyẹmhẹ.”  
\v 60 Ọ de wugha, ọ tsẹsẹ, ọọ li, “Ọnọmhuẹ, kpẹkpẹ khi ri olamhẹ ona mu ota sọ wẹ.” Abi ọ rọ ngme ona se, ọ ghua. 
\c 8  
\p  
\v 1-2 Ighọ iSọlu ọ migha wẹ ukhokho shi igbe-a oyi iSitivini. Abi iSitivini ọ rọ ghu-a se, ẹgbọ eghuo ni e mhọli ulishi oyi Ẹshinẹgba e ya rọli tọ. E viẹ eviẹ oyọli egbegbọ. 
\s1 Igbaa oyi eni e mie iJesu iKirisiti suọ e gbhiaku-a irari ajilimhẹ 
\p Ẹlẹghọ ukpokpomhi ajilimhẹ o lasele shi igbaa oyi eni e mie iJesu iKirisiti suọ ni e la ekẹ iJerusalẹmu ọ. Eni ighiusomhi na kẹẹ eghọ e miatsẹ ku ekẹ iJudia ali iSameria.  
\v 3 Ama iSọlu ọ rọshẹka a yese igbaa oyi eni e mie iJesu iKirisiti suọ-a. Ọ kia owa khi owa muno wẹ shi owa ighumha, ghe emọse, ghe ikpotso.\f + \fr 8:3 \ft Li zẹ \fq Ika 22.4-5; 26.9-11\f* 
\s1 Abi iFilipu ọ rọ la iSameria 
\p  
\v 4 Igbaa oyi eni e mie iJesu iKirisiti suọ eghọ ni e kia miatsẹ ku, e kia a gue ungmemhi oyi iJesu le asha ni e ramhi kpa.  
\v 5 IFilipu o je ekẹ iSameria. Ọ la oobọ ọ gueyẹ ẹgbọ khi iJesu ọ khi iKirisiti ni a shobọ.  
\v 6 Abi ebubu ẹgbọ e rọ mẹ ikanya ọshabọ ni iFilipu ọ gbe, e nyanya mie shi emini ọ ngme.  
\v 7 IFilipu ọ kha da lema na eni e mhọli ogbhọ ne, eni ẹgbọ e kpa oni ogbhọ pfia. Ebubu eni e guọghọ-a ali eni e ghua e toto nya.  
\v 8 Ukpokpomhi oghẹlẹ o la oni ẹoli oghọ. 
\s1 ISamọ ni ọọ li ọbo 
\p  
\v 9 Ọmọse ọghuo ọ laọ ni a lu iSamọ. Egbegbi ọbo ọ la iSameria ẹ li. Ọ kia ri ọbo ni ọ li tono obọ udu.  
\v 10 Ẹgbọ nya e ri ekpẹ ẹ na li. Ẹgbọ ọdọda ee liẹ li, “Ọmọse ọna Ẹshinẹgba ọ ri ekpabọ nali a gbe ikanya.” E lu ọli ekpabọ ni o fu.  
\v 11 Ingme ni ọ ngme kpa, e rọ ọ shi itobọ ọshabọ ni ọ ri ogbhọ oyọli i gbe ni o she tẹsẹ.  
\v 12 Ama iFilipu ọ gueyẹ wẹ ingme oyi Eghiele oyi Ẹshinẹgba ali iJesu iKirisiti, e mie shiọ. Ọ batazi wẹ, ghe ikpotso ghe emọse.  
\v 13 ISamọ ọ li miesuọ, iFilipu ọ li batazi ọli. Ọ deba iFilipu u kiakia irari ikanya ọnyaloa ali ọshabọ nefunẹ ni ọ mẹ khi iFilipu ọ gbe. 
\p  
\v 14 Abi ighiusomhi na kẹẹ ni e la iJerusalẹmu e rọ suọ khi ẹgbọ iSameria e mie ungmemhi oyi Ẹshinẹgba suọ, e ghie iPita ali iJọni ghi wẹ.  
\v 15 Abi iPita ali iJọni e rọ ramhi iSameria, e sọ iromhi na eni e miesuọ ni e la oobọ Ayẹmhẹ-nọ-pfuasẹ ọ tiemhile shi wẹ egbe.  
\v 16 Ayẹmhẹ-nọ-pfuasẹ ọa kie kpẹ tiemhile shi ọngẹ wẹ egbe ne, eri a kpẹ lẹsẹ ri eva oyi iJesu Ọnọmhuẹ batazi wẹ.  
\v 17 Abi iPita ali iJọni e rọ ri abọ nga wẹ ukhomhi, Ayẹmhẹ-nọ-pfuasẹ ọ tiemhile shi wẹ egbe. 
\p  
\v 18 Abi iSamọ ọ rọ mẹ khi ẹgbọ ni eni ighiusomhi na kẹẹ e ri abọ nga ukhomhi kpa khi e mie Ayẹmhẹ-nọ-pfuasẹ, ọ nise obọ-a ni lọli ri ikpaghọ na wẹ.  
\v 19 Ọọ wẹ. “A li ri oni itoto na mhẹ ni mhi ke ri Ayẹmhẹ-nọ-pfuasẹ na ogbọ ini mhi da ri obọ nga li ukhomhi ne.” 
\p  
\v 20 Ama iPita ọọ li, “Yẹyẹ ali ikpaghọ eyẹ a li opfu-a, itobọ khi u sa khi u ya dobẹ ri ikpaghọ dẹ isomhopfa oyi Ẹshinẹgba.  
\v 21 Itobọ khi u waa mhọli obọ shi akanya onana, irari khi udu oyẹ ọa pfuasẹ deba Ẹshinẹgba.  
\v 22 Irarighọ, mu udu pfi deba Ẹshinẹgba. U lema li ni ọ gbe olamhẹ kua nẹ, otsẹ ọ ya gbe isamhi ebe ni u mhọli shi udu kua nẹ.  
\v 23 Itobọ khi mhi she mẹ khi wa a kpe ofuma irari akanya ni anye a gbe ali khi olamhẹ o she dẹ ẹ ighumha.” 
\p  
\v 24 ISamọ ọọ wẹ. “A kpẹkpẹ a sọ iromhi na mhẹ ini emini a ngme ena e khi tsẹ shi mhẹ egbe ni mhi pfua.” 
\p  
\v 25 Abi iPita ali iJọni e rọ ngme ingmemhi eyi iJesu se, e mu egbe pfi je iJerusalẹmu, ee gue ungmemhi eyi iJesu kiakia elemhi ebubu inuẹkpẹ ni e la iSameria. 
\s1 IFilipu ọ gue ungmemhi oyi iJesu yẹ ọngi Ẹtiopia 
\p  
\v 26 Agẹni ọyi Ẹshinẹgba ọ gueyẹ iFilipu, ọọ li, “Ke tiemhi ukiẹkiẹ ọgobọ ini a sọ alo ghue obini ovọ o te ẹ lo eko je odẹ ọdagbe ifufu ni o rọte iJerusalẹmu je iGaza.”  
\v 27 Ighọ iFilipu ọ mu egbe ọọ lẹẹ. Abi ọ li lẹ eghọ, lọli ali ọmọse ọghuo ọngi Ẹtiopia ni ọ khi ọwali e ya lona. Ọmọse ọna ọkhẹmhuẹ ọ khi ni ọ ri ẹloe ẹ khu ẹpfue eyi iKadakhẹ ni ọ khi ọlele ọyi oni ekẹ. Ọ rọte iJerusalẹmu ni ọ je ya ga ugamhi i jele.  
\v 28 Abi ọ li i je apfẹ eghọ, ọ nga ọkọ ni ichi e rọ ọ na. Ọọ zẹ ebe ni Azaya ọmekẹguele ọ kẹkẹ.\fig Ọnge Ẹtiopia ni a wali-a ali iFilipu|src="lb00331c.tif" size="col" loc="ACT 8.28" copy="TIF" ref="8.28" \fig* 
\v 29 Ayẹmhẹ-nọ-pfuasẹ ọ gueyẹ iFilipu, ọọ li. “Je ọkọ oghọ ni u timama li migha.” 
\p  
\v 30 Abi iFilipu ọ rọ ramhi aghọ, ọ suọ khi ọni ọmọse ọọ zẹ ebe oyi Azaya ọmekẹguele. IFilipu ọ mhila ọni ọmọse. “Ebe ni u wa zẹ eghọ o fẹ lo ẹ esọ?” 
\p  
\v 31 Ọọ iFilipu, “Iiye oo. Ọa ya lighọ lo mhẹ esọ ini ọgbọ ọa li gueyẹ mhẹ abi o ngme.” Ọ iFilipu ọ nga oni ọkọ le ni ọ nu luẹ shitọ. 
\p  
\v 32 Ashini ọọ zẹ oni elemhi Ebe-no-pfuasẹ o khi, asha ni ọọ: 
\q1 “Eri a mu ọli abi omi osumha 
\q2 ni a ya fa uruli. 
\q1 Ẹzẹzẹ abi omi osumha 
\q2 ni a ya va kemhi, 
\q2 ni ọa khueghie unu-a. 
\q1  
\v 33 E ri omama mu ọli, 
\q2 e gbe ọli azẹba, 
\q2 e pfa ẹzọ mu ọli a gbe ọli-a. 
\q2 Ọghuo ọ ya mie shi ọ 
\q2 khi ọ ya dobẹ mhọli 
\q2 akhẹmhẹ-ukhokho, 
\q1 irari khi eri e mie ọli agbọ?”\f + \fr 8:33 \ft Li zẹ \fq Aza 53.7-8\f* 
\p  
\v 34 Ọni ọmọse ọwali ọ́ọ́ iFilipu, “Kpẹkpẹ gueyẹ mhẹ ọni ọmekẹguele ọnana ọọ ngme, ingme oyi egbọli ọọ ngme abi ingme oyi ọgbọẹse?”  
\v 35 IFilipu ọ gueyẹ ọli emini oni Ebe-no-pfuasẹ ni ọọ zẹ eghọ o ngme. Ọ gue ungmemhi oyi okhale oyi iJesu ye ọli. 
\p  
\v 36 Abi e kie li kia lẹẹ eghọ, e mẹ okẹ. Ọni ọmọse ọwali ọghọ ọọ li, “Bino, ghe okẹ ana, bie batazi mhẹ.”  
\v 37 IFilipu ọọ li, “Ini u mie iJesu suọ mhi ya batazi ẹ.” Ọni ọmọse ọọ li, “Mhi she miesuọ khi iJesu iKirisiti ọ khi Omi Ẹshinẹgba.”  
\v 38 Ighọ ọni ọmọse ọọ ọni ọ gua oni ọkọ oghọ ọ mu ọli migha. Lọli ali iFilipu e kia tiemhi oni okẹ, iFilipu ọ batazi ọli.  
\v 39 E lẹsẹ rọte oni okẹ nga egele le, Ayẹmhẹ-nọ-pfuasẹ ọ kele iFilipu-a je oboese. Ọni ọmọse ọa ke tigbe mẹ iFilipu, ama oghẹlẹ o la li elemhi i je apfẹ.  
\v 40 Ama iFilipu ọ mẹ egbọli ẹoli Azotusi. Ọ rọte oobọ ri oni ungmemhi i tse abọ kia kia ẹoli khi ẹoli ya ramhi ni ọ rọ ramhi ẹoli iSizeria. 
\c 9  
\s1 Imupfi oyi iSọlu 
\r (Ika 22.6-16; 26.12-18) 
\p  
\v 1 ISọlu ọ kiele tse ekha abi lọli li ya gbolo eni e mie iJesu suọ-a. Ọ lẹ deba Ọkpeda na ekpodalo-ugamhi eyi Ẹshinẹgba,  
\v 2 Ọ mhila li ọ ri ebe na luẹ ghi eni e la owa ugamhi na ekẹ iDamasikọsi. Ni lọli rọ mhọli afu dobẹ muno ikpotso ali emọse ni e mie iJesu suọ ighumha je obini iJerusalẹmu.  
\v 3 Abi iSọlu ọ li ri okiali ti i ramhi iDamasikọsi, utoghuokpe, ákpá o rọte idane mi nga li egbe nyagha.  
\v 4 Ọ de ta alo mu ekẹ. Ọ suọ khi ọgbọ ọ nu luẹ ngme, ọọ li, “ISọlu, iSọlu, elọ o zẹ ni u rọ mu okhọli vule ẹ shi mhẹ ọ?” 
\p  
\v 5 ISọlu ọ mhila li, ọọ, “Ọnọmhuẹ, ọghuo u khi?” Oni uruli ọli, “IJesu mhi khi, ni u mu okhọli vule shi ọ.”  
\v 6 “Memena, vule ni u lo elemhi ẹoli ona. U ya mẹ ọmọse ni ọ ya gueyẹ emini u mema ya riẹlẹ.” 
\p  
\v 7 Ẹgbọ ni e nu iSọlu kia e gbe ẹruẹ unu-a, e ga suọ oni ungmemhi, ama ẹa mẹ ọni ọọ ngme.  
\v 8 Ikpukhokho ọ, iSọlu ọ rọte ekẹ vule, abi ọ rọ khueghie alo-a ọa ke dobẹ ẹ mẹ ekẹ. Ẹgbọ ni e nu ọli kia e ke mu ọli obọ kia lo elemhi iDamasikọsi.  
\v 9 Ogbẹlẹ esẹ iSọlu ọ ga zalo shi aghọ. Ọa le eminale wẹkhi amẹ ọ da. 
\p  
\v 10 Ọmọse ọghuo ni ọ miesuọ ni a lu Ananayasi, ọ la elemhi iDamasikọsi. Ọ la imekẹ, ọ suọ khi Ọnọmhuẹ ọ lu luẹ, “Ananayasi!” 
\p Ọọ li, “Ee o.”  
\v 11 Ọnọmhuẹ ọọ li, “Ke je owa oyi iJudasi, ni o la odẹ ifuapfẹ ni a lu Isheshe, ni u ya mhila ogbọ oyi ọngi iTasọsi ni a lu iSọlu, ọ la aghọ ọ sọ iromhi.  
\v 12 Rọte ẹlena iSọlu o li kpẹ mẹ irọkhasẹ khi ọmọse ni a lu Ananayasi ọ ri obọ nga luẹ egbe sọ iromhi na, alo eyẹluẹ e khueghie-a.” 
\p  
\v 13 Ananayasi ọọ Ọnọmhuẹ, “Mhi she kpẹ suọ eko ebubu eyi ọmọse ọna abi ọ li ẹ nasẹ ẹgbọ ni e miesuọ, ọ la iJerusalẹmu gbolo eghuo-a.  
\v 14 Ighie eyi ekpodalo-ugamhi eyi Ẹshinẹgba e ri afu na li ọ ka muno ẹgbọ ni ẹẹ lu eva oyẹ.” 
\p  
\v 15 Ama Ọnọmhuẹ ọọ Ananayasi, “Ke lẹ, irari khi mhi she zẹ iSọlu ni ọ tsua ungmemhi oyẹmhẹ ghi ẹgbọ iJẹta ali ighie eyẹwẹ ali ẹgbọ iZirẹni nya.”  
\v 16 Mhi ya rọkhasẹ ọli khi ọ mema ya mẹ osoli shi ungmemhi oyẹmhẹ. 
\p  
\v 17 Abi Ananayasi ọ rọ mẹ oni owa, ọ dọsẹ lo ya ri obọ nga iSọlu egbe, ọọ li, “ISọlu inyọghuo-mhẹ, iJesu Ọnọmhuẹ ni ọ lonẹ odẹ abi u rọ ọ bhale oola, lọli ọọ mhi ka nono ẹ mẹ, ni u gbolo ke mẹ ekẹ ali ni Ayẹmhẹ-nọ-pfuasẹ ọ bhale egbe oyẹ.”  
\v 18 Utoghuokpe, emini e li abi ipfiapfia afẹlẹ o rọte ọli ikpamhi alo de pfia, ọ gbolo o mẹ ekẹ. Ọ vule migha, Ananayasi ọ batazi ọli.  
\v 19 Abi ọ rọ le eminale se, ọ tigbe mhọli ochi. 
\s1 ISọlu ọ ri igbedu u ngme ungmemhi oyi Ẹshinẹgba 
\p Ebubu ogbẹlẹ iSọlu ọ nu eni e miesuọ la elemhi iDamasikọsi.  
\v 20 Eloawẹ iSọlu ọ la elemhi owa ugamhi gueyẹ ẹgbọ khi iJesu Omi Ẹshinẹgba ọ khi.  
\v 21 Ẹgbọkpa ni e suọ ungmemhi oyi iSọlu ee mhila, “Ọa khi ọmọse ọnana ọọ nasẹ eni e miesuọ ni e la iJerusalẹmu? Ọa khi eri ọ bhale ya muno wẹ abi ighumha ghi ighie eyi ekpodalo-ugamhi?”  
\v 22 Ẹshinẹgba ọ ri ekpabọ na iSọlu ni ọ rọ ya ke gue oni ungmemhi le. Ama ẹgbọ iJu ni e la iDamasikọsi ẹa dobẹ mu iSọlu ekhakọ ọ le. O sha ẹgbọ iJu abọ abi e rọ mẹ ilẹsingme ni ọ rọ ọ guele khi iJesu ọ khi ọni iKirisiti ni a shobọ. 
\p  
\v 23 Ebubu ogbẹlẹ iSọlu ọ ga la iDamasikọsi. Ẹgbọ iJu e gba abi e li ya gbe ọli-a.  
\v 24 Ama iSọlu ọ suọ khi ẹgbọ ẹ gba abi e li ya gbeluẹ-a. Eri e shitọ unu odẹ unuẹkpẹ ni a te a lo oni ẹoli le ni e mẹ asha mu ọli.  
\v 25 Ama ẹgbọ ni e miesuọ e pfi uli rọte oni ugbe rọli shi ughughu bẹna ya tiemhi oni ugbe ẹliyọsẹ. \f + \fr 9:25 \ft Li zẹ \fq 2 iKọri 11.32-33\f* 
\p  
\v 26 Abi iSọlu ọ rọ ramhi iJerusalẹmu, ọọ dua ni lọli ya kuma ẹgbọ ni e miesuọ ọ, ama ulishi ọli o mu wẹ. E khọkhọ ini ọ she mie iJesu suọ.  
\v 27 Ama iBanabasi ọ rue ọli bhale deba eni ighiusomhi na kẹẹ. Ọ gueyẹ wẹ abi iSọlu ọ li mẹ Ọnọmhuẹ odẹ abi ọ rọ lẹ iDamasikọsi ali abi Ọnọmhuẹ ọ li nu ọli ngme. Ọ gbo gueyẹ wẹ abi ọ li la ekẹ iDamasikọsi ri eva oyi iJesu tse abọ ni ulishi ọa li mu ọli.  
\v 28 Ighọ ISọlu ọ nu wẹ la iJerusalẹmu kia kugbe. Ọ ri igbedu ri eva oyi Ọnọmhuẹ ẹ tse abọ gboo.  
\v 29 Ighọ ọ nu ẹgbọ iJu ni ẹẹ ngme ẹlẹmhi iGiriki i khakọ, ama ee dua ni wẹwẹ e gbe ọli-a.  
\v 30 Abi eni e miesuọ e rọ suọ ugbamhi ni eni ẹgbọ ẹẹ gba, e rue ọli je ekẹ iSizeria, e te aghọ rue ọli ya je iTasọsi. 
\p  
\v 31 Igbaa eyi eni e mie iJesu iKirisiti suọ ni e la ekẹ iJudia ali iGalili ali iSameria nya e mhọli opfọmhẹ, e toto-a, Ayẹmhẹ-nọ-pfuasẹ ọ ri udu shi wẹ ọ, ee bua shi ọ, ee ngeli angeli ni o pfuasẹ ri ekpẹ ẹ na Ẹshinẹgba. 
\s1 IPita ọ ri Eniasi ze 
\p  
\v 32 Abi iPita ọ li i kia oni ekẹ gasẹ, ọ kọ ya fẹli eni e miesuọ ni e la ẹoli iLida.  
\v 33 Ọ bhale ya ẹ ọmọse ni a lu Eniasi ni ọ guọghọ-a, o she gba ikpe elele abi ọ te yẹshi a ghua.  
\v 34 IPita ọọ, “Eniasi, iJesu iKirisiti ọ rẹ ze. Vule migha khili iya oyẹ ni u ke kia.” Utoghuo kpe Eniasi ọ vule migha, ọ toto.  
\v 35 Abi ẹgbọ ni e la ẹoli iLida ali iSharọ e rọ mẹ khi Eniasi ọ toto, e mu pfi deba Ọnọmhuẹ. 
\s1 IPita ọ guise iDọkasi le 
\p  
\v 36 Ọkpotso ọghuo ni ọ miesuọ ni a lu iTabita ọ la ẹoli iJopa, abi iTabita o ngme ẹmuẹ iGiriki khi “Ẹruẹ,” Ọ khi ọgbọ onete. Ọ gbolo mema ẹ kpaghiẹ eni ẹa mhuẹ obọ.  
\v 37 Ẹghẹghẹ ni a ngme ena, ọọ ghua, ighọ ọ ghua. Abi a rọ khuẹsẹ olimhi oyọli-a se, a rọli yẹshi elemhi owa atọnga.  
\v 38 Abi eni e miesuọ e rọ suọ khi iPita ọ la iLida, e ghie emọse aava ghi ọli, ẹ ọli, “Kpẹkpẹ bhale pia.” Irari khi ẹoli iLida ali ẹoli iJopa e ti mama egbe. 
\p  
\v 39 Ighọ iPita ọ deba wẹ. A ri ọli ya khasẹ asha ni a rọli yẹshi. Esamhi-olimhi e la aghọ ọ viẹ. E ri itsua ni iDọkasi ọ fia na wẹ khasẹ ọli abi ọ rọ la agbọ. 
\p  
\v 40 IPita ọ ẹgbọ ni e la aghọ nya e fiẹ je atukpapfẹ. Ọ de wugha sọ iromhi. Ọ sọ alo ghue ọni olimhi, ọọ li, “Tabita, guale!” Ọni olimhi ọ khueghie alo-a, abi ọ mẹ khi iPita ọ migha mama luẹ, ọ vule shitọ.  
\v 41 IPita ọ mu ọli obọ vule. Ọ luno eni e miesuọ ali eni esamhi-olimhi, ọ ri ọli khasẹ wẹ.  
\v 42 Iguisele oyi iDọkasi o gbekẹ-a shi ẹoli iJopa. Itobọ ighọ, ebubu ẹgbọ e mie iJesu suọ.  
\v 43 IPita ọ la iJopa ogbẹlẹ ni e bu. Ọ la owa oyi iSimọni ni ọ ri ekuẹ elamhakọ ọ gbe akanya. 
\c 10  
\s1 IKọnilusi ọ ghie ya lu iPita 
\p  
\v 1 Ọmọse ọghuo ọ la ẹoli iSizeria ni a lu iKọnilusi. Ọ khi ọga ọyi ekhọli-okhuẹ eyi Itili.  
\v 2 Lọli ali apfọli e khi ẹgbọ ni ẹ na ulishi Ẹshinẹgba. Ọ khi ọgbọ ni ọ pfo elemhi i somhi ẹgbọ ni ẹa mhuẹ opfa. Ọ gbo khi ọgbọ ni ọ sọ iromhi ẹghẹghẹ kpa.  
\v 3 Ẹlẹghuo elemhi agogo esẹ ẹlẹ ọguota, ọ mẹ imẹ-alo, ọ mẹ khi agẹni ọyi Ẹshinẹgba ọ bhale ọ lu ọli, “IKọnilusi!” 
\p  
\v 4 Ọ sọ alo ghue ọni agẹni, ulishi o mu ọli. Ọọ li, “Ọnọmhuẹ elọ o zẹ khi u bhale.” 
\p Ọni agẹni ọọ li, “Iromhi eyẹ ni u wa sọ ali isomhopfa ni u wa somhi e she bhale deba Ẹshinẹgba, Ọ she mu egbe ni ọ rọ ya yele ẹ le.  
\v 5 Memena nyanya ghie ẹgbọ je ẹoli iJopa ni e ya lu iSamọ ni a gbolo ẹ lu iPita, ni ọ bhale.  
\v 6 Ọ kushi ayi iSamọ ni ọ ri ekuẹ elamhi ẹ gbe akanya. Oni owa oyọli o la epfẹ okẹ.” 
\p  
\v 7 Abi ọni agẹni ọ rọ vu se, iKọnilusi ọ lu eni ẹ ga li etuava ali ọkhọli-okhuẹ ni ọ khi adogẹli ọyọli ni ọọ ga Ẹshinẹgba.  
\v 8 IKọnilusi ọ gueyẹ wẹ emini a mẹ nya. Ọ ghie wẹ je obini iJopa. 
\s1 Imẹ-alo ni iPita ọ mẹ 
\p  
\v 9 Ogbeakọlọ khi itsotso ọguota o mu ekẹ, khi e lẹsẹ ri okiali ramhi epfepfẹ iJopa, iPita ọ nga owa atọnga ya sọ iromhi.  
\v 10 Okiamhi oo gbe ọli. Ọọ nono emini ọ ya le. Abi a rọ ọ nye eminale ni ọ ya le, ọ mẹ imẹ-alo.  
\v 11 Ọ mẹ khi emini e li abi ode ni o zẹ igo ene o rọte idane e tiemhile.  
\v 12 Ighọ ọ mẹ khi iwali elamhakọ e laọ, ghe eni e zẹ awẹ ene ali eni ẹẹ tialọ idi ekẹ ali ipfeli.  
\v 13 Ighọ uruli o ngme, ọọ li, “Vule iPita, gbe ni u le.” 
\p  
\v 14 Ama iPita ọọ, “Iiye e, Ọnọmhuẹ! Mhia kpẹ tigbe le eminale ni ẹa pfuasẹ ni a ghuẹ ghue, a ti ẹ bia mhẹ.” 
\p  
\v 15 Oni uruli o gbo nu ọli ngme, ọọ li, “Emini Ẹshinẹgba ọ da rọ khi oni o pfuasẹ se, khi ke lu ọli emini ọa pfuasẹ.” 
\p  
\v 16 Itesẹ o lighọ mhẹsẹ abọ ri egbọli khasẹ neni a rue oni emhi nga idane. 
\p  
\v 17 Abi iPita ọ kie li i sa ingme imẹ-alo ni ọ mẹ, emọse ni iKọnilusi ọ ghie usomhi, e nono owa oyi iSamọ mẹ. E migha odalo odẹ unuẹkpẹ oyi oni apfẹ.  
\v 18 E lu mhila, “A mhọli ọpfẹse shi ana ni a lu iSamọ iPita?” 
\p  
\v 19 Abi iPita ọ kiele khọkhọ emini oni imẹ-alo ona o ngme, Ayẹmhẹ ọ rọ gueyẹ ọli, “Ri esọ kpẹ emọse aasẹ ẹẹ nono ẹ.  
\v 20 Nyanya mu egbe ni u deba wẹ vu, khi mhẹmhẹ mhi ghie wẹ.” 
\p  
\v 21 Ighọ iPita ọ tiemhi deba wẹ, ọọ wẹ, “Mhẹmhẹ a nono, elọ e rẹ ẹ bhale?” 
\p  
\v 22 Ẹẹ ọli, “Ọga ọyi ekhọli-okhuẹ ni a lu iKọnilusi ọ ghie anye ghi ẹ. Ọgbọ ọniẹmhi ni ẹgbọ iJu e mu ekpẹ a na ọ khi. Ọ gbo khi ọgbọ ni ọ pfuasẹ ni ọọ ga Ẹshinẹgba. Agẹni ọ gueyẹ oli ọ ghie ghi ẹ, u bhale owa oyọli, ni ọ suọ ingme ni u ya gueyẹ ọli.”  
\v 23 Ighọ iPita ọ lu eni emọse lo owa oyọli, e gbhẹ aghọ ni ogbe o gbe. 
\s1 IPita ọ la apfẹ oyi iKọnilusi 
\p Ogbeakọlọ, lọli ali eni e miesuọ eghuo e rọte iJopa deba wẹ vu.  
\v 24 Ogbeakọlọ, e lo elemhi ẹoli iSizeria le, ashini iKọnilusi ali apfọli ali egbegbi emọle ọli, e legba migha ẹ khẹ wẹ.  
\v 25 Abi iPita ọ rọ ramhi aghọ, iKọnilusi ọ lo ọ li odẹ, ọ wugha, ọ nyẹsẹ ukhomhi tsẹ ọli.  
\v 26 Ama iPita ọ mu ọli vule, ọọ li, “Vule khi ọgbọ ọnabi yẹyẹ mhi khi.” 
\p  
\v 27 IPita ọ nu ọli ngme, ọ lo owa, ọ bhale ya ẹ ẹgbọ ni e bu shi aghọ.  
\v 28 Ọọ wẹ, “Ẹẹ a she lẹsẹ khi eri Ishi eyi iMosisi ọọ ẹgbọ iJu e khi kugbe ẹgbọ iJẹta ọ, wẹkhi eri e kọ ya fẹli ọgbọ ni ọa khi iJu. Ama Ẹshinẹgba ọ rọli khasẹ mhẹ mhi khi leli ọgbọkhọghuo shi ọni ọa pfuasẹ ali ọni a ghuẹ.  
\v 29 Irarighọ, abi u rọ ghie lu mhẹ, mhia mhọli akhọkhọmhẹ shi ọ. Elọ u mema lu mhẹ shi?” 
\p  
\v 30 IKọnilusi ọọ li, “Amo o li ẹlẹ ene, ẹghẹghẹ agogo esẹ ọguota, mhi rọ la owa oyẹmhẹ ẹ sọ iromhi. Udemhija mhi mẹ khi ọmọse ọghuo ọ sọ itsua ni ẹẹ gẹ nyanyanya ọ migha mhẹ odalo.  
\v 31 Ọọ li, ‘IKọnilusi, Ẹshinẹgba ọ she suọ iromhi eyẹ, ọ she gbo mẹ ikanya isomhelemhi ni u gbe ẹ deba ẹgbọ eni ẹa mhuẹ.  
\v 32 Ghie ọgbọ ghi ọmọse ni a lu iSamọ iPita ni ọ la iJopa. Ọpfẹse ọ khi shi owa oyi iSamọ ni ọ ri ekuẹ ẹlamhi ẹ gbe akanya, ni ọ la epfẹ okẹ oku.’  
\v 33 Lọli mhi rọ ghie ọgbọ ghi ẹ pia. Oo guẹ ti, abi u bhale. Memena awa nya awa la odalo oyi Ẹshinẹgba ni anye suọ emini Ọnọmhuẹ o gueyẹ u gueyẹ anye.” 
\s1 Ungmemhi ni iPita ọ ngme 
\p  
\v 34 IPita ọọ, “Mhi she mẹ ọli mẹ khi igẹsikia o khi, khi Ẹshinẹgba ọa mhọli khi ọna ọ kpe ọli nẹ,\f + \fr 10:34 \ft Li zẹ \fq iDẹut 10.17\f* 
\v 35 ama ẹgbọ kpa ni e da a na ulishi oyi Ẹshinẹgba, ni e gbolo ẹ riẹlẹ emini o rọte odẹ, Ẹshinẹgba ọ kpe obọ ọọ mie.  
\v 36 Ẹẹ a lẹsẹ usomhi ni ọ ghie ghi ẹgbọ iZirẹni, ni o khi usomhi onete oyi opfọmhẹ ni o rọte obọ oyi iJesu iKirisiti ni ọ khi Ọnọmhuẹ ọyi agbọ kpa bhale.  
\v 37 Ẹẹ a lẹsẹ ingme ni a mẹ elemhi ekẹ iJudia nya, ni o rọte iGalili gbaekẹle, abi iJọni ọ́ rọ ọ tse abọ usomhi gueyẹ ẹgbọ, khi a mema batazi wẹ,  
\v 38 abi Ẹshinẹgba ọ li ri Ayẹmhẹ-nọ-pfuasẹ ali ekpabọ kpha iJesu ọnge iNazarẹti sọ, ali abi ọ li i kiakia ashakpa riẹlẹ onete, ni ọ mie ẹgbọ pfuese obọ oyi ekpabọ eyi ọkphaghiẹ, itobọ khi Ẹshinẹgba ọ́ nu ọli la. 
\p  
\v 39 “Anye ri ẹloe mẹ ikanya ni ọ gbe nya, elemhi ẹoli eyi ẹgbọ iJu ali iJerusalẹmu. Wẹwẹ e tali ma ọọra apfida gbe ọli-a.  
\v 40 Ama ẹlẹ nuzi-esẹ, Ẹshinẹgba ọ rọte eghuli guise ọli le ni a mẹ ọli.  
\v 41 Ọa khi ọgbọkpa ọ mẹ ọli, sẹẹ ni anye ni Ẹshinẹgba ọ she kpẹ zẹ, anye khi ọtsẹlẹ, anye ni anye nu ọli le eminale ni anye gbo nu ọli da abi ọ rọ rọte eghuli guale se.  
\v 42 Ọ mhẹsẹ na anye, anye kia ke gueyẹ ẹgbọkpa ali anye gbo ke pfi ọtsẹlẹ shi ọ khi lọli iJesu, Ẹshinẹgba ọ zẹ, lọli khi ọsọ-ẹzọ ọyi eni e laọ ali eni e ghu-a.  
\v 43 Emekẹguele nya e kpẹ ngme ungmemhi oyọli khi eni e da mie ọli suọ khi a ya gbe olamhẹ kua na wẹ, rọte ekpabọ ni o la eva oyọli.” 
\s1 Ẹgbọ iJẹta e mie ayẹmhẹ ni ọ pfuasẹ 
\p  
\v 44 Abi iPita ọ kie li i ngme, Ayẹmhẹ-nọ-pfuasẹ ọ tiemhile na ẹgbọ ni e suọ oni ungmemhi.  
\v 45 Abọ e sha eni e miesuọ ni e shẹlẹ-a, ni e rọte ẹoli iJopa kphase iPita bhale aghọ, khi Ẹshinẹgba ọ li ri Ayẹmhẹ-nọ-pfuasẹ na ẹgbọ iJẹta.  
\v 46 Irari khi e suọ khi e ngme ẹmuẹ ọdọda eyi Ayẹmhẹ nọ pfuasẹ, e kuẹghiẹ Ẹshinẹgba. 
\p Ighọ iPita ọ ri irarighọ liẹ,  
\v 47 “Ọgbọkhọghuo ọ dobẹ ya liẹ ọgbọ khi ri amẹ batazi ẹgbọ ena mena? E she li mie Ayẹmhẹ-nọ-pfuasẹ abi awa li mie ọli.”  
\v 48 Ighọ iPita ọọ a ka ri eva oyi iJesu iKirisiti batazi wẹ. Ighọ e gueyẹ ọli ọ nu wẹwẹ la aghọ ikukumi ogbẹlẹ. 
\c 11  
\s1 IPita ọ gueyẹ eni e miesuọ emini ọ riẹlẹ 
\p  
\v 1 Eni ighiusomhi na kẹẹ ali eni e miesuọ ni e la ekẹ iJudia nya e suọ khi ẹgbọ iJẹta e li mie ungmemhi oyi Ẹshinẹgba suọ.  
\v 2 Abi iPita ọ rọ nga obini iJerusalẹmu, eni e miesuọ ni e shẹlẹ-a, ee shi iPita unu.  
\v 3 Ẹẹ ọli, “Yẹyẹ u lo owa oyi ẹgbọ iJẹta ni ẹa shẹlẹ-a, u gbo la aghọ le eminale!” 
\p  
\v 4 Ighọ iPita ọ rọte ekẹ rọli lo wẹ esọ abi a ga li mẹ oni ingme nya. Ọọ wẹ,  
\v 5 “Ẹoli iJopa mhi la a sọ iromhi, ni ukuku olesẹ o rọ kia mhẹ alo-a, ni mhi rọ mẹ imẹ-alo, mhi mẹ khi emini o li abi ode ni o zẹ igo ene, o te idane tiemhile ashini mhi la.  
\v 6 Mhi bino elemhi ọli, mhi mẹ elamhakọ ni e zẹ awẹ-ene, ali elamhakọ ebuli, ali elamhakọ ni ẹ tialọ idi ekẹ, ipfeli na idane e li la elemhi ọli.  
\v 7 Ighọ mhi suọ khi uruli o nu mhẹ ngme, ọọ mhẹ, ‘Vule, iPita gbe elamhi ena, ni u le.’ 
\p  
\v 8 “Ama, mhiẹ ọli, ‘Iiye e, Ọnọmhuẹ! Mhi aa le eminale ni ẹa pfuasẹ ni a ghuẹ ghue abi a te bia mhẹ.’ 
\p  
\v 9 “Oni uruli o gbo nu mhẹ ngme, ọọ mhẹ, ‘Emini Ẹshinẹgba ọ she rọ pfuasẹ, khi ke rọli shi emhi ni ọa pfuasẹ.’  
\v 10 Itesẹ o li ighọ mhẹsẹ abọ ri egbọli khasẹ neni a rue oni ode nga idane. 
\p  
\v 11 “Aghọaghọ, eni emọse aasẹ ni e te iSizeria nono mhẹ bhale, e lo owa ni mhi la le.  
\v 12 Ayẹmhẹ ọ gueyẹ mhẹ mhi deba wẹ vu, mhia aa khẹ akọ. Ẹgbọ osasa ena e te ẹoli iJopa kphase mhẹ je ẹoli iSizeria ni anye rọ ga bhale owa oyi iKọnilusi.  
\v 13 Lọli ọ gueyẹ anye abi ọ li mẹ agẹni elemhi owa oyọli, ni ọ ọli, ‘Ghie ọgbọ je iJopa ya lu ọmọse ni a lu iSamọ ni a gbo lo a lu iPita.  
\v 14 Lọli ọ ya gueyẹ abi yẹyẹ ali apfẹ a li ya mhọli imiepfuese.’ 
\p  
\v 15 “Abi mhi li i ngme, Ayẹmhẹ-nọ-pfuasẹ ọ tiemhile shi wẹ ọ abi ọ li rọte igbaekẹle li tiemhile shi awa ọ.  
\v 16 Ighọ mhi yelele emini Ọnọmhuẹ ọ ngme ni ọọ, ‘Amẹ iJọni ọ rọ batazi ẹgbọ, ama Ayẹmhẹ-nọ-pfuasẹ a ke rọ ya batazi ẹ.’\f + \fr 11:16 \ft Li zẹ \fq Ika 1.5\f* 
\v 17 Abi o rọ khia khi Ẹshinẹgba ọ she ri isomhopfa enabi ọ rọ na awa abi awa rọ mie iJesu iKirisiti Ọnọmhuẹ suọ li na ẹgbọ ni ẹ a khi iJu. Ọghuo ọ khi mhẹmhẹ ni mhi ya nu Ẹshinẹgba khabọ?” 
\p  
\v 18 Abi e rọ suọ ona se, e yẹmhẹ awọlọ-a, ee kuẹghiẹ Ẹshinẹgba, ee liẹ, “Ẹshinẹgba ọ li zẹ ni ẹgbọ iJẹta e li mu pfi ni e li mhuẹ agbọ na agbọagbọ.” 
\s1 Igbaa oyi eni e mie iJesu iKirisiti suọ ni o la Atiọki 
\p  
\v 19 Eni e mie iJesu iKirisiti suọ e kia gbhiaku ekẹ iFonisha ali ekẹ iSapurọsi ali ẹoli Atiọki itobọ okhọli ni a mu vule shi wẹ ọ ẹghẹghẹ ni a rọ gbe iSitivini-a. E kia gue oni usomhi yẹ ẹgbọ iJu wẹwẹghuo tsẹ.\f + \fr 11:19 \ft Li zẹ \fq Ika 8.1-4\f* 
\v 20 Eghuo ọ e rọte ekẹ iSapurọsi ali ekẹ iSairini bhale, e vu je ẹoli Atiọki, e lili gue usomhi onete oyi Ọnọmhuẹ yẹ ẹgbọ iGiriki  
\v 21 Ekpabọ oyi Ọnọmhuẹ o nu wẹ la, Ebubu ẹgbọ e miesuọ, e mu udu pfi deba Ọnọmhuẹ. 
\p  
\v 22 Igbaa oyi eni e mie iJesu iKirisiti suọ ni e la iJerusalẹmu e suọ oni ingme, ighọ e ghie iBanabasi je ẹoli Atiọki.  
\v 23 Abi ọ rọ ramhi aghọ, ni ọ rọ mẹ abi Ẹshinẹgba ọ li somhi-elemhi eni ẹgbọ, egbe e mu ọli. Ọ ri udu shi wẹ ọ e ri udu oyẹwẹ nya na Ọnọmhuẹ.  
\v 24 IBanabasi ọ khi egbegbi ọgbọ ọnete ni ọ mhuẹ Ayẹmhẹ-nọ-pfuasẹ ali irudunga oniẹmhi. Ebubu ẹgbọ e ri itobọ emini ọ riẹlẹ mie Ọnọmhuẹ suọ. 
\p  
\v 25 Ighọ iBanabasi ọ je ẹoli iTasọsi ya nono iSọlu.  
\v 26 Abi ọ rọ mẹ ọli, ọ rue ọli je ẹoli Atiọki, e la aghọ ukpe oghuo, ee sẹsẹ ebubu ẹgbọ. Elemhi ẹoli Atiọki a la te ododẹ kpẹ lu eni e miesuọ, iKirisiti enikeke.\f + \fr 11:26 \ft Ẹgbọ eni ẹẹ ngeli a bi iJesu iKirisiti a lu iKiristiani.\f* 
\p  
\v 27 Oni ẹghẹghẹ, emekẹguele eghuo e rọte ẹoli iJerusalẹmu je Atiọki.  
\v 28 Ọghuo elemhi eni emekẹguele ni a lu Agabusi ọ vule, ọ guele abi Ayẹmhẹ ọ ghie ọli, khi úkhúmhi o ya pfi ushishi na ekẹ iRomu nya. (Ẹghẹghẹ ni iKiladiusi ọ rọ khi Oghie iRomu nya ona o rọ bhale ya tsẹ.)\f + \fr 11:28 \ft Li zẹ \fq Ika 21.10\f* 
\v 29 Eniyẹ odukhokho eyi iJesu ni e la Atiọki e gba ugbamhi, abi e li ya ri ikpaghiobọ ghie usomhi ghi eni e miesuọ ni e la ekẹ iJudia, abi ọgbọgbọ ọ mhuẹ ekpabọ ramhi.  
\v 30 Ighọ e zẹla ikpaghọ kugbe, e rẹwẹ ghie iBanabasi ali iSọlu usomhi ghi eni egbhali ni e la igbaa oyi eni e mie iJesu iKirisiti suọ na iJerusalẹmu. 
\c 12  
\s1 Imhẹsẹ-bino onofunẹ 
\p  
\v 1 Oni ẹghẹghẹ aghọ, oghie Erọdu ọ muno ẹgbọ eghuo ena igbaa oyi eni e mie iJesu iKirisiti suọ, ọọ nono ni lọli nasẹ wẹ shi afuẹ.  
\v 2 Ọ ri unu bhale a ri uwẹrẹ gbe iJemhisi ni ọ khi inyọghuo iJọni-a.  
\v 3 Abi ọ rọ mẹ khi o ti ẹgbọ iJu ẹloe, ọ gbo mu iPita shi owa. Oni ẹghẹghẹ e rọ li ukpe ibulẹdi ni aa ri ifuma ma nye.  
\v 4 Ọ mu ọli se, ọ rọli shi owa ighumha, ọ zẹ ekhọli-okhuẹ ikuwẹ asha ene ni e ọọghiẹ egbe, e ri ẹloe shi ọli egbe. Erọdu ọ mhọli ọli shi udu khi a kha da li oni ukpe se, lọli rue ọli lasele gboo, ni a gue ọli ẹzọ.\f + \fr 12:4 \ft Li zẹ \fq Okiali 12.1-27\f* 
\p  
\v 5 Ighọ a ri iPita shi owa ighumha, ama igbaa oyi eni e mie iJesu iKirisiti suọ e toto obọ ọ sọ iromhi lu Ẹshinẹgba na li. 
\p  
\v 6 Ẹliyọsẹ ni Erọdu ọ kha rọ rue iPita lasele ogbeakọlọ, iPita ọ lesẹ-a shi ifuabọ eyi iku ekhọli-okhuẹ aava, a ri iwẹghẹ eva gẹ ọli. Eni ẹ khẹ ekhẹ aava elese e la odẹ unuẹkpẹ oni owa ighumha ẹ khẹ ekhẹ.  
\v 7 Udemhija, agẹni ọyi Ọnọmhuẹ ọ lole, ighọ ákpá o la elemhi oni owa ighumha a gẹ. Ọni agẹni ọ pfi iPita emhi epfẹ, guise ọli le. Ọọ li, “Nyanya vule!” Utoghuokpe, iwẹghẹ ni a sọ li e ku ọli abọ kua. 
\p  
\v 8 Ighọ ọni agẹni ọọ li, “Ri ọgbẹnẹ oyẹ mu oku, ri ekuẹ sọ.” IPita ọ nyanya lighọ. Ọọ li, “Ri itsua eyẹ sọ, ke deba mhẹ.”  
\v 9 Ighọ IPita ọ deba li je olase oni owa ighumha, ama ọa lẹsẹ khi emini ọni agẹni ọ riẹlẹ khi egbegbi ingme lọ, ọ dabi khi ẹlena lọli ii la.  
\v 10 É dọsẹ eni ẹ khẹ ekhẹ eni ododẹ ali enuzava. E bhale odẹ unuẹkpẹ akhuli ni a rọte a lasele shi ifui apfẹ. Oni odẹ unuẹkpẹ akhuli lọlighuo o khueghie-a. E rọte ọ dọsẹ. Abi e rọ kia ifui apfẹ lẹ dẹnẹ, ọni agẹni ọ kele-a. 
\p  
\v 11 Ighọ ẹgbhali eyi iPita e na ya to. Ọọ, “Ena mhi lẹsẹ, ni ọa mhuẹ akhọkhọmhẹ khi Ọnọmhuẹ ọ ghie agẹni ọyọli, ọ ka pfa mhẹ shi ekẹ obọ oyi Erọdu ali emini ẹgbọ iJu ẹẹ sa khi mhi ya mẹ nya.” 
\p  
\v 12 Abi ẹgbhali eyọli e rọ na ya to se, ọ je owa oyi iMeli ni ọ khi inyọ iJọni ni a gbolo ẹ lu iMaki. Aghọ eni e miesuọ e legba la a sọ iromhi.  
\v 13 IPita ọ kpheli odẹ na olase. Ighọ ọmueshi ni ọọ ga ọgbọ ni a lu iRoda ọ bhale ya mie ọli unu.  
\v 14 Abi ọ rọ suọ uruli oyi iPita, oghẹlẹ o vọ ọli udu. Ọa je okpẹ odẹ-a ne, ọ nyanya nyenẹ egbe ukhokho ya tsẹsẹ gueyẹ wẹ, “IPita ọ she jele!” 
\p  
\v 15 Ẹẹ ọli, “Ujili ọọ kphẹ!” Ama ọ li khi egbegbi ingme lọli ẹ ngme. Ighọ ẹ ọli, “Ayẹmhẹ olimhi ọyọli lọ!” 
\p  
\v 16 Ama iPita ọ kiele kpheli obọ odẹ. Abi e ke rọ khueghie oni odẹ-a, e mẹ khi lọli lọ. Abọ e sha wẹ.  
\v 17 Ọ ri obọ gbe wẹ akhiakhia. Ọ tigbe gueyẹ wẹ abi Ọnọmhuẹ ọ li rue luẹ owa ighumha le. Ọọ wẹ, “A gueyẹ iJemhisi ali eni e miesuọ eni e kpọle.” Ighọ ọ vu je oboese. 
\p  
\v 18 Ogbeakọlọ, ozughu o lo iteva oyi eni ekhọli-okhuẹ le shi abi iPita ọ li kia.  
\v 19 Abi Erọdu ọ rọ ọ e lolo nono iPita kia gasẹ, ni ẹa rọ mẹ ọli. Ọ ri eni ẹẹ khẹ ekhẹ eghọ gue ẹzọ. Ọọ a gbolo wẹ-a. 
\s1 Eghuli oyi Erọdu 
\p Abi a rọ mẹ enana se, Erọdu ọ rọte ekẹ iJudia je iSizeria ya la ukuku ẹghẹghẹ. 
\p  
\v 20 Elemhi e lolo bi Erọdu deba ẹgbọ iTai ali iSidọni. Ighọ eni ẹgbọ e to ukhomhi ma, ee dua abi e li ya mẹ asha nu oni oghie shitọ ngme. Abi iBilasitọsi ni ọ khi adogẹli ọyi oghie ọ rọ lama shi wẹ ọ, e tigbe lama khi wẹwẹ e ya lema oghie ni wẹwẹ e rọ riẹlẹ. Itobọ khi ẹoli oyi ọni Erọdu eni ẹgbọ e rọte mẹ eminale ẹ dẹ. 
\p  
\v 21 Oni ogbẹlẹ o ramhi Erọdu ọ gbanọ itsua oghie eyọli, ọ shitọ ukpẹkhomhi oghie oyọli. Ọ nu eni ẹgbọ ọ ngme.  
\v 22 Eni ẹgbọ e ku unu-a nyoghoo, ẹ li, “Uruli oyi Ẹshinẹgba na, ọa ke khi oyi ọgbọ.”  
\v 23 Utoghuo kpe agẹni ọyi Ọnọmhuẹ ọ pfi Erọdu emhi, itobọ khi ọa ri ekpẹ na Ẹshinẹgba. Ekhọli e ri ọli le. Ọ ghu eghuli osoli. 
\p  
\v 24 Ungmemhi oyi Ẹshinẹgba o gbhiaku ashakpa, oo gẹ shọ.  
\v 25 IBanabasi ali iSọlu e rọte iJerusalẹmu, obini a ri ikpaghọ ghie wẹ usomhi je jele. Abi e rọ ọ jele, e rue iJọni ni a gbolo ẹ lu iMaki mhuẹ obọ. 
\c 13  
\s1 A zẹ iBanabasi ali iSọlu ghie usomhi 
\p  
\v 1 Emekẹguele ali eni ẹ sẹsẹ e la igbaa oyi eni e mie iJesu iKirisiti suọ ni ọ la Atiọki, ni e khi iBanabasi, ali iSamọ ni ọ khi ọgbọ ọbishi, ali iLushọsi ọngi iSairini, iMaini ọni a ga kuẹlẹ ọli ali oghie Erọdu, ali iSọlu.  
\v 2 Abi e li i kuẹghiẹ Ọnọmhuẹ ni e li i pfi azumhi, Ayẹmhẹ-nọ-pfuasẹ ọọ wẹ, “A zẹ iBanabasi ali iSọlu-ọ lase na mhẹ ni e ya gbe akanya ni mhi lu wẹ shi.”  
\v 3 E pfi azumhi, e ri abọ nga wẹ ukhomhi sọ iromhi na, e ghie wẹ vu.\fig Okiali onododẹ oyi iPọlu|src="ATG Paul1-BW.ai" size="span" loc="ACT 13.1--14.28" ref="13.1--14.28" \fig* 
\s1 Elemhi iSapurọsi 
\p  
\v 4 Ayẹmhẹ-nọ-pfuasẹ ọ ghie iBanabasi ali iSọlu je iSelusha aghọ e te lo ọkọ okẹ je ekẹ ni oku o khi shi na lu iSapurọsi.  
\v 5 Abi e rọ ramhi ẹoli iSalamisi, e la owa ugamhi oyi ẹgbọ iJu gue ungmemhi oyi Ẹshinẹgba le. IJọni ni a gbolo ẹ lu iMaki ọ la aghọ ri obọ da wẹ oni akanya. 
\p  
\v 6 E kia je ukiẹkiẹ iSapurọsi ni o kpọle nya, e bhale ẹoli iPafọsi. Aghọ e ya ẹ ọbo ni a lu iBajisọsi ọngi iJu ni ọọ li ẹboli, ni ọ khi ọmekẹguele ọyi ẹgbhọli.  
\v 7 Lọli ọ khi ọmọle ọni igọvunọ ni ọ la oni ekẹ, eva oyi ọni igọvunọ khi iSajọsi iPọlọsi ni ọ khi ọtsẹgbhẹ. Ọni igọvunọ ọ lu iBanabasi ali iSọlu itobọ khi ọ nono ni lọli suọ ungmemhi oyi Ẹshinẹgba.  
\v 8 Ama ọni iBajisọsi ni ọ liẹ Ẹlimasi ni ọọ li ọbo, ọ tsua ozughu lo aghọ le ini ọni igọvunọ ọ khi mẹ asha miesuọ.  
\v 9 Ighọ iSọlu ni a liẹ lu iPọlu, ni Ayẹmhẹ-nọ-pfuasẹ ọ vọ egbe, ọ fẹli ọni ọbo chii.  
\v 10 Ọọ li, “Yẹyẹ omi ọkphaghiẹ! Yẹyẹ ọbe eminete ni u wa li ikẹnẹguẹ. Ẹlẹ u ya rọte imu-ungmemhi oyi Ẹshinẹgba pfi ukhomhi kpọkẹ lasele?  
\v 11 Memena Ẹshinẹgba ọ ya nise obọ oyọli ti ẹ, u ya zẹ alo, waa kẹ gbo dobẹ ya mẹ ugẹmhi oyi ovọ ukuku ẹghẹghẹ ne.” 
\p Aghọaghọ, Ẹlimasi ọ mẹ khi alo eyẹluẹ e bi obili-a, Ọọ bibi, ọọ nono ọni ọ ya mu ọli obọ ke kia.  
\v 12 Abi ọni igọvunọ ọ rọ mẹ ingme ni a mẹ, ọ miesuọ, irari khi osẹsẹ ingme ọyi Ọnọmhuẹ o ri abọ sha li. 
\s1 Atiọki ni o la elemhi iPisidia 
\p  
\v 13 IPọlu ali apfọli e rọte iPafọsi lo ọkọ okẹ da okẹ oniẹmhi je iPẹriga, ni o khi ẹoli ni o la iPafilia. Ana iJọni ni a gbolo ẹ lu iMaki ọ pfi wẹ shi nyenẹ egbe je iJerusalẹmu.  
\v 14 E rọte iPẹriga je ẹoli Atiọki ni o la ekẹ iPisidia. Ogbẹlẹ iyẹmhẹa oyi iJu, e lo owa ugamhi ya shitọ.  
\v 15 Abi e rọ rọte ebe ishi oyi iMosisi ali ebe eyi emekẹguele zẹ se, eni ẹẹ mhẹsẹ shi oni owa ugamhi e ghie usomhi ya gueyẹ iPọlu ali iBanabasi, ẹẹ wẹ, “Inyọghuo anye, ini a mhọli ungmemhi ni a mẹ ya guele ni o ya ri udu shi ẹgbọ ọ, a ke ngme.”  
\v 16 IPọlu ọ vule migha ọ ri obọ nu wẹ ngme. Ọọ, “Ẹẹ ẹgbọ iZirẹni ali ẹẹ iJẹta ni a ga Ẹshinẹgba a ri esọ shi mhẹ ekẹ!  
\v 17 Ẹshinẹgba ọyi ẹgbọ iZirẹni ọ zẹ eni e bia awa, lọli ọ rẹwẹ khi ẹgbọ eniẹmhi, oni ẹghẹghẹ e khi epfẹse shi ekẹ iJipiti. Ẹshinẹgba ọ ri ekpabọ eyọli wolọ wẹ ekẹ iJipiti lasele.\f + \fr 13:17 \ft Li zẹ \fq Okiali 1.7; 12.51\f* 
\v 18 Elemhi ikpe egbhuẹva ọ ri abọ mu udu na ẹ elemhi ọdagbe ifufu.\f + \fr 13:18 \ft Li zẹ \fq iNọba 14.34; iDẹut 1.31\f* 
\v 19 Ẹdẹli ishilua ọ pfusea ekẹ iKena. Ọ ri ekẹ oyẹwẹ na ẹgbọ eyọli le ugu.\f + \fr 13:19 \ft Li zẹ \fq iDẹut 7.1; iJosh 14.1\f* 
\v 20 Elemhi ikpe egbhuẹ-uye ali eva ali ikpe igbe (450) a mẹ ingme enana.\f + \fr 13:20 \ft Li zẹ \fq iDẹut 7.1; iJosh 14.1\f* 
\p “Abi a rọ mẹ ena se, ọ ri esọ-ẹzọ na wẹ ni ee mhẹsẹ, ya ramhi ẹghẹghẹ oyi iSamuẹni ọmekẹguele.  
\v 21 Ighọ eni ẹgbọ e mhila Ẹshinẹgba ọ ri oghie na wẹwẹ, Ẹshinẹgba ọ rue iSọlu omi iKishi ọyi unuẹkpẹ oyi iBẹjami na wẹ. Lọli ọ khi oghie ọyẹwẹ elemhi ikpe egbhuẹva.\f + \fr 13:21 \ft Li zẹ \fq 1 iSam 8.5; 10.21\f* 
\v 22 Abi Ẹshinẹgba ọ rọ rue iSọlu oghie le, ọ ri iDefidi le oghie na wẹ. Ingme ni Ẹshinẹgba ọ ngme shi iDefidi egbe na, ‘Mhi she mẹ khi iDefidi omi iJese ọ khi ọmọse ọnabi udu oyẹmhẹ ọọ nono, ọ ya riẹlẹ ọghuẹmhẹ oyẹmhẹ nya.’\f + \fr 13:22 \ft Li zẹ \fq 1 iSam 13.14; 16.12; Iwolo 89.20\f* 
\p  
\v 23 “Rọte unuẹkpẹ oyi ọni iDefidi, iJesu ni ọ khi Ọmiepfuese ọyi ẹgbọ iZirẹni ọ te bhale, abi Ẹshinẹgba ọ li rọli shobọ.  
\v 24 Neni iJesu ọ bhale, iJọni ọ she kpẹ gueyẹ ẹgbọ iZirẹni e ti olamhẹ le, e mupfi deba Ẹshinẹgba, ẹghẹghẹ aghọ ni a batazi wẹ.\f + \fr 13:24 \ft Li zẹ \fq iMak 1.4; iLuk 3.3\f* 
\v 25 Abi iJọni ọ rọ gbe akanya se, ọ mhila eni ẹgbọ, ọọ, ‘Ọghuo a khọkhọ mhẹ shi? Mhi aa khi ọni a migha a khẹ. Ọni ọ ya bhale ini mhi gbe akanya oyẹmhẹ se, mhi aa fu tẹ ni mhia taghiẹ uli ekuẹ ni ọ sọ-a.’\f + \fr 13:25 \ft Li zẹ \fq iMat 3.11; iMak 1.7; iLuk 3.16; iJọn 1.20,27\f* 
\p  
\v 26 “Inyọghuo-mhẹ imi Aburaamu, ali ẹẹ iJẹta ni a na ulishi Ẹshinẹgba ni a la akana, oni ungmemhi imiepfuese ona, oyawa lọ!  
\v 27 Ẹgbọ ni e la iJerusalẹmu ali eni ẹẹ mhẹsẹ na wẹ, ẹa lẹsẹ iJesu shi Ọmiepfuese. Ama igbe-a ni e gbe iJesu-a, o ri emini emekẹguele ee ngme, ni ee zẹ khasẹ wẹ ẹlẹ iyẹmhẹa kpa bhale ya tsẹ.  
\v 28 Abi o tseku khia khi ẹa mẹ ẹzọ gue shi ọli egbe, ẹẹ li ipaleti ọ zẹ ni a gbe ọli-a.\f + \fr 13:28 \ft Li zẹ \fq iMat 27.22-23; iMak 15.13-14; iLuk 23.21-23; iJọn 19.15\f* 
\v 29 Abi e rọ riẹlẹ emini Ebe-no-pfuasẹ o ngme shi ọli egbe se, e rue ọli apfida tiemhile, e rọli tọ uji.\f + \fr 13:29 \ft Li zẹ \fq iMat 27.57-61; iMak 15.42-47; iLuk 23.50-56; iJọn 19.38-42\f* 
\v 30 Ama Ẹshinẹgba ọ rọte eghuli guise ọli le.  
\v 31 Ogbẹlẹ ebubu ọ ri egbọli khasẹ ẹgbọ eni e nu ọli rọte iGalili je iJerusalẹmu. Wẹwẹ e ke pfi ọtsẹlẹ shi ingme oyọli khasẹ ẹgbọ eyawa.\f + \fr 13:31 \ft Li zẹ \fq Ika 1.3\f* 
\p  
\v 32 “Eri anye bhale akana ni anye ya ri oni usomhi onete na ẹ, ikhi ishobọ ni Ẹshinẹgba ọ shi na eni e bia awa.  
\v 33 Ọ she ri oni ishobọ ona tsẹ na awa imi wẹ, abi ọ li guise iJesu le. Abi a li kẹkẹ ọli shi ebe Iwolo ni uzeva, khi, 
\q1 “ ‘Omimhẹ u khi, ogbe namo, 
\q2 mhẹmhẹ mhi khi Itẹ.’ 
\m  
\v 34 Abi Ẹshinẹgba ọ rọte eghuli guise ọli le, ni ọa zẹ ọli ghu kẹ-a, o mu ma ungmemhi oyọli ni ọ la liẹ,\f + \fr 13:34 \ft Li zẹ \fq Aza 55.3\f* 
\q1 “ ‘Mhi ya ri ikhivọsẹ no pfuasẹ, 
\q2 ni a ri egbe ẹ nga egbegbọ 
\q2 ni mhi shobọ na iDefidi nẹ.’ 
\m  
\v 35 Ighọ ọ kie gbo li ngme ọli shi ashese.\f + \fr 13:35 \ft Li zẹ \fq Iwolo 16.10\f* 
\q1 “ ‘Waa ya zẹ ni 
\q1 ọni ọ pfuasẹ ọyẹ 
\q2 ọ ghu kẹ-a.’ 
\p  
\v 36 “Irari khi eri iDefidi ọ ga Ẹshinẹgba abi ọ rọ la agbọ, ighọ ọ ghu-a, a ri ọli tọ mama eni e bia li. Ọ kẹ-a shi elemhi uji.  
\v 37 Ama idiegbe oyi iJesu ni Ẹshinẹgba ọ rọte eghuli guise le, ọa kẹ-a. 
\p  
\v 38 “Irarighọ, inyọghuo, anye tse abọ yẹ ẹ khi obọ oyi iJesu a te ya mhọli igbe olamhẹ kua.  
\v 39 Ọnini ọ da mie ọli suọ ne, a she pfa na li, ọa ke lue shi emini Ushi oyi iMosisi ọa dobẹ pfa na wẹ shi.  
\v 40 A mhuẹ ẹgbhẹ, ini emini emekẹguele e ngme o khi ya tsẹ shi ẹ egbe, ni ẹẹ, 
\q1  
\v 41 “ ‘A ghe i, ẹẹ ni 
\q1 a ri Ẹshinẹgba a li egia 
\q1 Ọshabọ ọ sha ẹ, a pfua. 
\q1 Irari khi mhi ya riẹlẹ 
\q1 emhi ẹghẹghẹ oyẹ ẹ 
\q2 ni aa ya mie shi ghue, 
\q2 ini ọgbọ ọ tseku gue ọli yẹ ẹ.’ ”\f + \fr 13:41 \ft Li zẹ \fq Abak 1.5\f* 
\p  
\v 42 Abi iPọlu ali iBanabasi e rọ rọte oni owa ugamhi vu, eni ẹgbọ e gbo lu wẹ e nyenẹ egbe bhale ogbẹlẹ ugamhi olese ya nu wẹwẹ ngme oni ungmemhi.  
\v 43 Abi oni ilegba o rọ gbhia khuse, ẹgbọ iJu ali ẹgbọ iJẹta eni e she mu pfi bhale ugamhi oyi ẹgbọ iJu, e kpikpi i deba iPọlu ali iBanabasi. IPọlu ali iBanabasi e ye wẹ ude, e kie ke deba okhale ni ẹa fu tẹ ni Ẹshinẹgba ọ riẹlẹ na wẹ. 
\p  
\v 44 Ẹlẹ iyẹmhẹa ni o deba li, ẹgbọ ni e la oni ẹoli nya e legba ni e ri esọ shi ungmemhi oyi Ẹshinẹgba.  
\v 45 Abi ẹgbọ iJu e rọ mẹ oni ilegba, ee kpe ofuma, ee kholo ingmemhi zu iPọlu unu, e tsue ọli. 
\p  
\v 46 Ama iPọlu ali iBanabasi e ngme ungmemhi igbedu, ẹ li, “Ẹẹ a khi eni anye kha mema kpẹ gue ungmemhi oyi Ẹshinẹgba yẹ neni o ramhi ẹgbọẹse egbe. Ama abi a ke rọ kie oni ungmemhi ni aa rọ sa khi o ti ni a mhọli agbọ na agbọagbọ eghọ, mena, anye ya zẹ ẹ obọ, anye deba ẹgbọ iJẹta.  
\v 47 Irari khi ona khi omhẹsẹ ni Ọnọmhuẹ o mhẹsẹ na anye, ni ọ rẹẹ,\f + \fr 13:47 \ft Li zẹ \fq Aza 42.6; 49.6\f* 
\q1 “ ‘Mhi she rẹ ẹ khi 
\q1 ákpá na ẹgbọ iJẹta, 
\q2 ni agbọ nya e mhuẹ imiepfuese.’ ” 
\p  
\v 48 Abi ẹgbọ iJẹta e rọ suọ ona, ee ghẹlẹ, ee kuẹghiẹ Ẹshinẹgba shi oni ungmemhi, ẹgbọ eni a she zẹ shi agbọ na agbọagbọ, e mie iJesu suọ. 
\p  
\v 49 Oni ungmemhi oyi Ọnọmhuẹ o gbhiaku asha kpa oni ekẹ.  
\v 50 Ama ẹgbọ iJu e tanọ shi ikpotso ni ẹẹ na ulishi Ẹshinẹgba ni a mu ekpẹ a na ali ekhẹmhuẹ eyi oni ẹoli. E sẹsẹ ẹgbọ ni e mu okhọli oniẹmhi vule shi iPọlu ali iBanabasi ọ, e khu wẹ fiẹ lase oni ẹoli.  
\v 51 Ama eni eniyẹ odukhokho eyi iJesu e kpishi itutu awẹ shi ekẹ, ni e pfi ọtsẹlẹ mu eni ẹgbọ. E rọte aghọ dọsẹ je ẹoli iKoniọmu.\f + \fr 13:51 \ft Li zẹ \fq iMat 10.14; iMak 6.11; iLuk 9.5; 10.11\f* 
\v 52 Oghẹlẹ ali Ayẹmhẹ-nọ-pfuasẹ ọ lo eni e miesuọ eghọ egbe. 
\c 14  
\s1 Emini a mẹ iKoniọmu 
\p  
\v 1 IPọlu ali iBanabasi e lo owa ugamhi oyi ẹgbọ iJu obini iKoniọmu, abi e kie kpẹ ẹ li. E lolo guẹ ẹ ngme ungmemhi ni o lo ẹgbọ esọ, ni o ri ebubu ẹgbọ iJu ali iJẹta miesuọ.  
\v 2 Ama ẹgbọ iJu ni ẹa lama miesuọ, e tanọ ẹgbọ iJẹta abọ ni elemhi o yese wẹ-a deba eni e miesuọ.  
\v 3 Ighọ iPọlu ali iBanabasi e kushi aghọ tẹsẹ, e ri igbedu u ngme ungmemhi oyi Ọnọmhuẹ ni ọ pfi ọtsẹlẹ shi ungmemhi okhale oyọli, rọte ekpabọ ni ọ rọ na wẹ ẹ gbe akanya ọnyaloa ali ọshabọ.  
\v 4 Okemhi o lo oni ẹdẹli le, ẹgbọ eghuo e kugbe ẹgbọ iJu ọ, eghuo ọ e la ukhokho oyi ighiusomhi na kẹẹ.  
\v 5 Ighọ ẹgbọ iJẹta eghuo ali ẹgbọ iJu ali enighie eyẹwẹ, e gba abi e li ya gbe wẹ ali abi e li ya tono wẹ echẹ.  
\v 6 Abi eni ighiusomhi e rọ suọ ona, e na je ẹoli iLisitira ali iDẹbi ni o la ekẹ iLikaonia ali ẹoli elese ni e mama wẹ.  
\v 7 Aghọ e la a gue usomhi onete le. 
\s1 Elemhi iLisitira ali iDẹbi 
\p  
\v 8 Ọmọse ọghuo ọni a bia ọkhomhi ni ọa kia ghue abi a te bia li, ọ li la oni iLisitira.  
\v 9 Ọ shitọ aghọ ri esọ shi ungmemhi ni iPọlu ọọ ngme. IPọlu ọ mẹ khi ọ mhọli irudunga ni o dobẹ ya rọ li ze, iPọlu ọ bino ọli chii.  
\v 10 Ọ tsẹsẹ leghe, ọọ, “Vule migha!” Ọni ọmọse ọ ti vule, ọọ kia gasẹ. 
\p  
\v 11 Abi eni ẹgbọ e rọ mẹ akanya ni iPọlu ọ gbe, e ngme ẹlẹmhi iLikaonia, ee tsẹsẹ, ee liẹ, “Ilitsa e mele ẹgbọ-a bhale iteva oyawa o!”  
\v 12 Eva ni e lu iBanabasi khi iZeusi,\f + \fr 14:12 \fk iZeusi: \ft IZeusi o khi ọga iyẹmhẹ ni ẹgbọ iGiriki e ga. Isheghuo a lu ọli iJupita. Olitsa ọlese ni a lu Amẹsi ẹẹ khi ọ khi aghiusomhi ọyọli\f* itobọ khi iPọlu khi ọni ọ mema e ngme, e lu ọli Amẹsi.\f + \fr 14:12 \fk Amẹsi: \ft Amẹsi o khi eva oyi olitsa ni ẹgbọ iGiriki e ga. Eri ẹgbọ iGiriki ena e liẹ khi aghiusomhi oyi iyẹmhẹ elese\f* 
\v 13 Ọni ọọ luasẹ oni olitsa iZeusi, ni okula oyọli o la ukhokho apfẹ oni ẹoli, ọ muno ena enokpo ali idodo je oni odẹ unuẹkpẹ oyi oni ẹoli, itobọ khi lọli ali eni ẹgbọ ee nono ni wẹwẹ ya luasẹ iBanabasi ali iPọlu abi ilitsa. 
\p  
\v 14 Abi iBanabasi ali iPọlu e rọ suọ emini eni ẹgbọ e mu egbe khi e ya riẹlẹ, e nyanọ itsua shi egbewẹ uruli, e nanọ lo eni ẹgbọ ifuabọ. Ee tsẹsẹ liẹ,  
\v 15 “Elọ e zẹ khi a li na?” Ẹgbọ enabi ẹẹ anye khi! Ungmemhi usomhi onete anye rọ tse abọ khasẹ ẹ, ni a rọte ugamhi afuẹ mu pfi deba Ẹshinẹgba ni ọ laọ, ni ọ ma ekẹ ali ukhuli ali okẹ oniẹmhi ali emini e la elemhi wẹ nya.\f + \fr 14:15 \ft Li zẹ \fq Okiali 20.11; Iwolo 146.6\f* 
\v 16 Ẹghẹghẹ ni o dọsẹ, Ẹshinẹgba ọ zẹ ni ushishi ọgbọgbọ ọ ngeli abi o ghọle ọli.  
\v 17 Ama ọ kie rọte akanya onete oyọli ri ọlẹlẹ khasẹ khi lọli laọ, lọli ọ rọte idane e ruẹsẹ amẹ shi emhi ẹkọmhi shi ẹghẹghẹ, lọli ọ ri eminale na ẹ ẹ le, ọ ri oghẹlẹ ẹ shi ẹ udu.  
\v 18 Abi iPọlu ali iBanabasi e riẹ lina nu wẹ ngme ingmemhi ena, ẹa kie dobẹ mu wẹ gba e khi luasẹ ẹwẹ abi ilitsa. 
\p  
\v 19 Ẹgbọ iJu eghuo e rọte Atiọki ali iKoniọmu bhale, e ri eta-ọlẹlẹmhunu ti eni ẹgbọ mama egbe, e tono iPọlu echẹ, e tialọ ọli ekẹ fiẹ je ukhokho oni ẹoli, e dabi khi ọ she ghua.  
\v 20 Ama abi eni e miesuọ e rọ le gasẹ ọli, ọ vule, ọ nyenẹ egbe je ifuapfẹ ni a la tono ọli echẹ. Ogbeakọlọ, lọli ali iBanabasi e je ẹoli iDẹbi. 
\p  
\v 21 IPọlu ali iBanabasi e gue usomhi onete le elemhi iDẹbi, ebubu ẹgbọ e miesuọ. Ighọ e nyenẹ egbe je iLisitira ali iKoniọmu ali Atiọki ni o la iPisidia,  
\v 22 e ri udu shi eni e miesuọ ọ e ri igẹsikia migha shi oni irudunga. Ẹẹ wẹ, “Neni awa lo Eghiele oyi Ẹshinẹgba, awa ya mẹ anasẹmhẹ.”  
\v 23 Elemhi igbaa nya eyi eni e mie iJesu iKirisiti suọ ọdọda, ee zẹ egbhali shi, ee pfi azumhi sọ iromhi na wẹ rẹwẹ nga Ọnọmhuẹ ni e regbenga obọ.  
\v 24 Abi e rọ kia gasẹ ekẹ iPisidia se, e je ekẹ iPafilia.  
\v 25 Abi e rọ la ẹoli iPẹga gue usomhi onete le se, e te aghọ je ẹoli Atalia. 
\p  
\v 26 Aghọ e te lo ọkọ-okẹ oniẹmhi nyenẹ egbe jele obini Atiọki; Ashini eni e miesuọ e ke la sọ iromhi na wẹ rẹ wẹ nga okhale oyi Ẹshinẹgba obọ shi akanya ni e ye ya gbe se.  
\v 27 Abi e rọ jele Atiọki, e lu eni e miesuọ tigbili, e gueyẹ wẹ ikanya ni Ẹshinẹgba ọ rẹ wẹ gbe ali abi ọ li khueghie odẹ-a na ẹgbọ iJẹta ni e miesuọ.  
\v 28 E nu eni e miesuọ la akaghọ tẹsẹ. 
\c 15  
\s1 Ilegba ni a mhọli shi iJerusalẹmu 
\p  
\v 1 Ẹgbọ eghuo e rọte ekẹ iJudia bhale Atiọki, ee sẹsẹ eni e miesuọ khi, Ini aa li shẹlẹ wẹ-a abi Ushi oyi iMosisi o ngme ẹa ya khi eni a miepfuese.\f + \fr 15:1 \ft Li zẹ \fq iLẹv 12.3\f* 
\v 2 Onana o pfi ingme ni o zẹ khi iPọlu ali iBanabasi e nu eni ẹgbọ ni e rọte iJudia bhale e khakọ. Irarighọ, a zẹ iPọlu ali iBanabasi ali eni e miesuọ elese e nga iJerusalẹmu ya mẹ ighiusomhi na kẹẹ ali eni egbhali shi oni ingme. 
\p  
\v 3 Ighọ e ghie wẹ e ke lẹ, abi e li rọte ekẹ iFonisha ali iSameria dọsẹ ẹ lẹ, ee gueyẹ ẹgbọ abi ẹgbọ iJẹta e li mu pfi deba Ẹshinẹgba. Onana o pfi oghẹlẹ oniẹmhi na eni e miesuọ.  
\v 4 Abi e rọ ramhi iJerusalẹmu, eni e miesuọ ali eni egbhali ali ighiusomhi na kẹẹ, e mu wẹ epfẹse. Eni a ghie usomhi e gueyẹ wẹ ikanya ọdọda ni Ẹshinẹgba ọ rọte obọ oyẹwẹ gbe.  
\v 5 Ama eni e miesuọ eghuo ni e la otu iFarisi e vule, ẹẹ li, “Ẹgbọ iJẹta e mema shẹlẹ-a. A gueyẹ wẹ e ri Ushi oyi iMosisi ke gbe akanya.” 
\p  
\v 6 Ighiusomhi na kẹ ali eni egbhali e ye ochi shi oni ingme ona.  
\v 7 Abi e rọ khakọ shi ọ tẹsẹ se, iPita ọ vule, ọọ wẹ, “Inyọghuo, a lẹsẹ khi ẹghẹghẹ ni o dọsẹ, Ẹshinẹgba ọ rọte iteva oyẹ ẹ zẹ mhẹ mhi ka gue oni usomhi onete yẹ ẹgbọ iJẹta ni e mẹ asha suọ, ni e miesuọ.\f + \fr 15:7 \ft Li zẹ \fq Ika 10.1-43\f* 
\v 8 Ẹshinẹgba ni ọ lẹsẹ isamhi ni e la ọgbọkpa udu, ọ ri Ayẹmhẹ-nọ-pfuasẹ na ẹgbọ iJẹta, rọ rọli khasẹ khi lọli li mie wẹ, ẹzẹzẹ abi ọ li li mie awa.\f + \fr 15:8 \ft Li zẹ \fq Ika 2.4; 10.44\f* 
\v 9 Ọa ri ikhiọda shi iteva oyawa ali wẹwẹ, irari khi ọ khuẹsẹ udu oyẹwẹ-a pfuasẹ itobọ khi e imiesuọ.  
\v 10 Memena, elọ o zẹ khi a nono ni a mhẹsẹ Ẹshinẹgba bino, ni a rọ ọ sheli iJẹta ni e miesuọ itsua ni awa ali eni e bia awa ẹa dobẹ tsua?  
\v 11 Iiye e! Awa lama shi ọ khi okhale oyi iJesu iKirisiti Ọnọmhuẹ o mie awa pfuese, ighọ li khi wẹwẹ.” 
\p  
\v 12 Oni igbaa e tsaghiẹ-a tsukẹ, abi e rọ suọ ọlẹlẹ eyi ọnyaloa ali ọshabọ nya ni Ẹshinẹgba ọ rọte obọ oyi iPọlu ali iBanabasi gbe iteva oyi ẹgbọ iJẹta.  
\v 13 Abi e rọ ngme se, iJemhisi ọọ, “Inyọghuo, a ri esọ shi mhẹ ekẹ!  
\v 14 ISamọ iPita ọ lẹsẹ guele abi Ẹshinẹgba ọ li mhọli ọmuegbe shi ingme oyi ẹgbọ iJẹta, ni ọ rọte elemhi wẹ sanọ ẹgbọ, rọ mele ẹgbọ eyọli-a.  
\v 15 Onana o ri emini emekẹguele e kẹkẹ shi Ebe-no-pfuasẹ bhale ya tsẹ, ni ọọ, 
\q1  
\v 16 “ ‘Ini a mẹ enana se, 
\q1 mhi ya nyenẹ egbe bhale, 
\q2 mhi rue eghiele oyi iDefidi 
\q2 gbo nyenẹ egbe bhale, 
\q1 mhi riẹlẹ ikpukpu-igbe 
\q1 ni e de kua oyọli ma, 
\q2 mhi gbo zese ọli-a. 
\q1  
\v 17 Isheghọ ẹgbọ ni e kpọle nya 
\q2 e nyenẹ egbe bhale deba Ọnọmhuẹ, 
\q2 ẹgbọ iJẹta nya ni mhi lu, 
\q2 e bhale ya khi eyẹmhẹ, 
\q1 Ọnọmhuẹ ọ ngme ghọ, 
\q1 ni ọ riẹlẹ emhi ena.’ 
\q1  
\v 18 Lọli ọ she kpẹ zẹ 
\q2 ni a lẹsẹ ona shi ekẹ agbọagbọ.\f + \fr 15:18 \ft Li zẹ \fq Emọ 9.11-12\f* 
\p  
\v 19 “Abi mhi sọ ọ shi khi, awa khi pfi ẹgbọ iJẹta ni e nyenẹ egbe bhale deba Ẹshinẹgba lo ọmunu.  
\v 20 Awa ri ochoghọ kẹkẹ ebe ya gueyẹ wẹ, e khi ke le eminale ni a rọ luasẹ ikhumhi. Awa gbo gueyẹ wẹ e khi ke ku itsẹbọ, e khi ke le ẹlamhi ni aa fa uruli, e khi ke da ọlia.\f + \fr 15:20 \ft Li zẹ \fq Okiali 34.15-17; iLẹv 17.10-16; 18.6-23\f* 
\v 21 Irari khi o she tẹsẹ ni a te la owa ugamhi ẹ zẹ ebe Ushi oyi iMosisi ẹlẹ Iyẹmhẹa kpa, a ri ingme oyọli ẹ tse abọ ifui ẹoli kpa.” 
\p  
\v 22 Ighọ ighiusomhi na kẹẹ ali eni egbhali ali eni e miesuọ nya e te eni ẹgbọ zẹ emọse aava ni a mu ekpẹ ẹ na ma iPọlu ali iBanabasi egbe, je Atiọki. IJudasi iBasabasi ali iSalasi e zẹ.  
\v 23 Ebe ni e kẹkẹ rọ ghie wẹ usomhi na: 
\p Anye ighiusomhi na kẹẹ ali eni egbhali ni anye khi inyọghuo ẹ, anye tsẹ ẹẹ Inyọghuo anye ni a khi ẹgbọ iJẹta ni a la Atiọki ali iSiria ali iSilisha. 
\p  
\v 24 Anye suọ khi ẹgbọ eghuo e rọte anye iteva vu ni o khia khi ọa khi anye ghie wẹ, ni e bhale ya nu ẹ ngme ingmemhi ni oo yese ẹ elemhi-a ali ni oo nasẹ ẹ udu.  
\v 25 Irarighọ, anye rọ kugbe ghie emọse eghuo ghi ẹ, e deba iBanabasi ali iPọlu emọle anye bhale.  
\v 26 Emọse ena e she ri agbọ oyẹwẹ shi okhẹna itobọ eva oyi iJesu iKirisiti Ọnọmhuẹ.  
\v 27 Irarighọ, anye rọ ghie iJudasi ali iSalasi ni e ri unu gue emini anye kẹkẹ shi ebe yẹ ẹ.  
\v 28 O ti Ayẹmhẹ-nọ-pfuasẹ ali anye ẹloe, ini anye khi ri itsua elese nasẹ ẹ tsua dọsẹ ishi enana.  
\v 29 A ti egbe eminale ni a rọ luasẹ ikhumhi le, a khi ke da ọlia, a khi le ẹlamhi ni aa fa uruli. A khi ku itsẹbọ. O ma a ti ẹ egbe ini a lase emhi enana le. 
\p Ẹshinẹgba ọ nu ẹ la. 
\p  
\v 30 Eni emọse ni a ghie usomhi e vu ya tiemhi Atiọki. E ti eni e miesuọ nya gbili, e ri oni ebe na wẹ.  
\v 31 Abi eni ẹgbọ e rọ zẹ oni ebe se, oghẹlẹ o vọ wẹ elemhi itobọ khi usomhi onete ni o ri udu ẹ shi ọgbọ ọ o tsua.  
\v 32 IJudasi ali iSalasi ni e khi emekẹguele e nu wẹ ngme ebubu ingmemhi ri udu shi wẹ ọ, e zese wẹ-a.  
\v 33 E nu wẹ la aghọ ukuku ẹghẹghẹ, eni e miesuọ e tsẹ wẹ okhila. Wẹwẹ ni a ghie usomhi e nyenẹ egbe je iJerusalẹmu deba eni e ghie wẹ.  
\v 34 [Ama iSalasi ọ lama nu wẹ la aghọ.]  
\v 35 IPọlu ali iBanabasi e la Atiọki, wẹwẹ ali ẹgbọ elese e la aghọ ọ sẹsẹ, ee tse abọ ungmemhi oyi Ọnọmhuẹ. 
\s1 IPọlu ali iBanabasi e vasẹ egbe-a 
\p  
\v 36 Abi ebubu ogbẹlẹ e rọ dọsẹ, iPọlu ọ gueyẹ iBanabasi, ọọ li, “Awa nyenẹ egbe je ẹoli ni awa te dọsẹ ni awa ya bino ẹgbọ ni awa gue ungmemhi oyi Ọnọmhuẹ yẹ, ni awa mẹ abi e ke laọ shi.”  
\v 37 O ghọle iBanabasi ni e tsua iJọni ni a gbolo ẹ lu iMaki ma egbe vu.  
\v 38 Ama ọa ghọle iPọlu ni e tsua li. Itobọ khi ọni iJọni ni a gbolo ẹ lu iMaki ọa nu wẹ gbe ikanya ramhi ukpẹsẹ ni ọ rọ tsua wẹ kua ekẹ iPafilia vu, ọ sọ ukhokho gbe wẹ.\f + \fr 15:38 \ft Li zẹ \fq Ika 13.13\f* 
\v 39 IPọlu ali iBanabasi e mhọli ekhakọ ni o toto shi ingme ona, e kemhi egbe. IBanabasi ọ rue iJọni iMaki ma egbe, e lo ọkọ-okẹ oniẹmhi da je iSapurọsi.  
\v 40 Ama iPọlu ọ pfi obọ rue iSalasi, e vu abi eni e miesuọ e rọ sọ iromhi na wẹ, rẹ wẹ nga okhale irẹloe-khu oyi Ọnọmhuẹ se.  
\v 41 E kia rọte ekẹ iSiria ali iSilisha, e ri udu u shi igbaa nya eyi eni e mie iKirisiti suọ ọ.\fig Okiali onuzi-eva oyi iPọlu |src="ATG Paul2-BW.ai" size="span" loc="ACT 15.36--18.22" ref="15.36--18.22" \fig* 
\c 16  
\s1 ITimoti ọ deba iPọlu ali iSalasi 
\p  
\v 1 IPọlu ọ bhale ẹoli iDẹbi ali iLisitira, ashini ọmọ odukhokho ni a lu iTimoti ọ la. Inyọli ni ọ li miesuọ ọ khi ọngi iJu, ama itali ọ khi ọngi iGiriki.  
\v 2 Igbaa oyi eni e mie iJesu iKirisiti suọ ni e la iLisitira ali iKoniọmu nya e ngme onete oyi iTimoti.  
\v 3 IPọlu ọọ nono ni lọli ri iTimoti ma egbe vu, ighọ ọ shẹlẹ ọli-a. Itobọ khi ẹgbọ iJu ni e la oobọ e ga lẹsẹ khi ita iTimoti khi ọngi iGiriki lọ.  
\v 4 Abi e li kia ẹoli i gasẹ, e sẹsẹ eni e miesuọ ilamashi ni ighiusomhi na kẹẹ ali eni egbhali ni e la iJerusalẹmu e kẹkẹ shi ebe na wẹ, e gueyẹ wẹ, e rẹwẹ gbe akanya.  
\v 5 Ighọ igbaa nya eyi eni e mie iKirisiti suọ, e fu u shi irudunga, ee bua shi ọ ẹlẹkpa. 
\s1 IMekẹ ni iPọlu ọ mẹ obini iTiroasi 
\p  
\v 6 IPọlu ali eni e ga kia, e rọte ekẹ iFirigia ali iGalesha, itobọ khi Ayẹmhẹ-nọ-pfuasẹ ọa zẹ wẹ gue usomhi onete le ekẹ Esha.  
\v 7 Abi e rọ ramhi ekẹ iMisia, ee nono ni wẹwẹ e lo elemhi ekẹ iBitinia, ama Ayẹmhẹ oyi iJesu ọa zẹ wẹ lo.  
\v 8 Ighọ e rọte ekẹ iMisia dọsẹ je iTiroasi.  
\v 9 Ẹliyọsẹ ẹlẹghọ iPọlu ọ mẹ imẹ-alo, ọ mẹ khi ọngi iMasidonia ọ migha a lema, “Bhale iMasidonia ni u ya kpaghiẹ anye obọ!”  
\v 10 Abi iPọlu ọ rọ mẹ oni imekẹ se, anye mu egbe e lẹ iMasidonia, itobọ khi anye lẹsẹ khi Ẹshinẹgba ọ she lu anye, anye je aghọ ya gue usomhi onete le. 
\s1 ILidia ọ mu pfi 
\p  
\v 11 Anye rọte iTiroasi lo ọkọ-okẹ oniẹmhi da okẹ oniẹmhi je iSamotirasi, ogbeakọlọ, anye te aghọ je iNiapolisi. 
\p  
\v 12 Aghọ anye te je ifuapfẹ oyi iFilipi ni o khi ẹoli ni o mu ẹloe shi ekẹ iMasidonia ni ebubu ẹgbọ iRomu e ngeli. Anye ga la aghọ ebubu ogbẹlẹ. 
\p  
\v 13 Ogbẹlẹ iyẹmhẹa oyi ẹgbọ iJu, anye te oni ẹoli vu je oni okẹ, ashini anye khọkhọ khi ẹgbọ iJu ee lona shi iromhi isọsọ. Anye shitọ nu ikpotso ni e legba aghọ ngme.  
\v 14 Ọkpotso ọghuo elemhi wẹ ni ọ ri esọ shi ekẹ khi iLidia ọngi iTiatira, ọni ọ ri ide eyilẹ ẹ dẹ. Ọ khi ọkpotso ni ọọ na ulishi Ẹshinẹgba. Abi iPọlu ọ li i ngme, Ẹshinẹgba ọ khueghie ọli udu-a shi oni ungmemhi.  
\v 15 Abi a rọ batazi ọli ali apfọli se, ọ lu anye je owa oyọli, ọọ anye, “A kha lẹsẹ khi egbegbi ọni ọ miesuọ mhi khi, a bhale ya ku shi na mhẹ.” Ọ ti anye shi ọ ramhi ni anye rọ lama shi ọli ọ. 
\s1 A mu iPọlu ali iSalasi shi igha 
\p  
\v 16 Ẹlẹghuo abi anye li i je ashini anye la a sọ iromhi, ọmueshi oghumha ọghuo ni ọ mhọli ayẹmhẹ obe ni ọ rọ ọ mekẹ guele emini a ya mẹ, ọ ya to anye ukhomhi. Eri ọ ri oni ekpabọ imẹguele ona a gbe ikpaghọ na eni e mhọli ọli.  
\v 17 Ọọ deba iPọlu ali anye, ọọ tsẹsẹ, ọọ liẹ, “Eni ẹ ga Ẹshinẹgba ni ọ funẹ eni ẹgbọ ena e khi! Eri ẹ tse abọ guele abi a li ya mhọli imiepfuese!”  
\v 18 Ina ọ li i riẹlẹ ọli ogbẹlẹ kpa ya ramhi ni oni ingme o rọ ri elemhi i bi iPọlu, ighọ iPọlu ọ nyenẹ egbe gueyẹ oni ayẹmhẹ, ọọ li, “Mhi ri eva oyi iJesu mhẹsẹ nẹ, fiẹ ọli idiegbe ya lase!” Aghọaghọ oni ayẹmhẹ o fiẹ ọli idiegbe ya lase.  
\v 19 Abi eni e mhọli ọli e rọ mẹ khi ẹa ke mẹ ikpaghọ afa ni e kpẹ te ẹ ọli obọ ọ mẹ, e mu iPọlu ali iSalasi tialọ ghi enighie obini agbala oyẹwẹ.  
\v 20 E wolọ wẹ bhale odalo oyi esọ-ẹzọ, ẹẹ wẹ, “Emọse ena, ẹgbọ iJu e khi ni e pfi ozughu ẹ shi awa ifuapfẹ.  
\v 21 E kia a sẹsẹ ẹgbọ imu ni e khi ọda shi eyi awa. Awa ni awa khi iRomu, awa aa ya dobẹ ri osẹsẹ oyẹwẹ gbe akanya.”  
\v 22 Eni ebubu ẹgbọ e kuma wẹ ọ gue ẹzọ shi iPọlu ali iSalasi egbe. Ighọ eni esọ-ẹzọ e gueyẹ wẹ e banọ wẹ a, e gbe wẹ itali.  
\v 23 Abi e rọ gbe wẹ egbegbọ se, e tigbe pfi wẹ lo owa ighumha. E gueyẹ ọni ọọ khẹ-ekhẹ ọ pfi okpẹ ashini ọ rẹwẹ shi egbegbọ.  
\v 24 Abi a rọ ri oni omhẹsẹ na li se, ọ mu wẹ kulo owa aza elemhi oni owa ighumha, ọ sọ wẹ awẹ igha.  
\v 25 Abi itsotso ogbiẹ o rọ mu ekẹ, iPọlu ali iSalasi ee sọ iromhi, ee to uwolo kuẹghiẹ Ẹshinẹgba. Ighumha eni e kpọle e ri esọ shi wẹ ekẹ.  
\v 26 Udemhija, ekẹ o ri itoto nighise. Oni owa ighumha o rọte ekẹ jighise egbegbọ. Eloawẹ eloawẹ, odẹ nya ni e lo oni owa le e khueghie-a. Iwẹghẹ ni e rọ gẹ eni ighumha nya e ku wẹ awẹ-a.  
\v 27 Abi ọni ọọ khẹ ekhẹ aghọ ọ rọ mẹ khi odẹ ni e la oni owa ighumha nya khi e khueghie-a, ọ dabi khi ighumha ni e la aghọ nya e she pfue. Ighọ ọ ji itakobi emhi lasele ni luẹ rọ gbe egbeluẹ-a.  
\v 28 Ama iPọlu ọ tsẹsẹ leghe, ọọ li, “Khi gbe egbe ẹ-a! Anye nya anye la ana.” 
\p  
\v 29 Ọni ọọ khẹ ekhẹ ọghọ ọ lu ọgbọ ọ nyanya rue ugbili bhale. Ọ ri ulishi-ulishi na buẹ buẹ, ọ de ya wugha odalo oyi iPọlu ali iSalasi.  
\v 30 Ighọ ọ rue wẹ lasele, ọ mhila wẹ, “Elọ mhi ya li ni mhi rọ ya mhọli imiepfuese?” 
\p  
\v 31 Ẹẹ ọli, “Yẹyẹ ali apfẹ nya a mie iJesu Ọnọmhuẹ suọ khi a ya mhọli imiepfuese.”  
\v 32 Ighọ e gue ungmemhi oyi Ọnọmhuẹ ye ọli ali apfẹ ọli.  
\v 33 Ighọ ọni ọmọse ọ wolọ wẹ, ọ dua wẹ utse ni a kuali wẹ. IPọlu ali iSalasi e rue ọli ali apfọli ya batazi na aghọaghọ.  
\v 34 Ighọ ọ rue iPọlu ali iSalasi nga owa oyọli ya ri eminale na le. Oghẹlẹ o vọ ọli ali apfọli nya udu irari khi e she mie Ẹshinẹgba suọ. 
\p  
\v 35 Ẹlẹ uzogbe ogbeakọlọ, eni esọ-ẹzọ e ri unu na ipolisi e ka gueyẹ ọni ọọ khẹ-ekhẹ ọghọ, “Zobẹ emọse eghọ obọ ni e vu.”  
\v 36 Ighọ ọni ọọ khẹ ekhẹ ọghọ ọọ iPọlu, “Esọ-ẹzọ e she ri unu bhale a wolọ ẹ abọ-a ni a ke vu. Opfọmhẹ o ka nu ẹ kia.”  
\v 37 Ama iPọlu ọọ li, “Anye a li ingme okhọghuo ni a rọ mu anye gbe itali ukpẹloe oyi ẹgbọ nya, aboriẹkhia khi ẹgbọ iRomu anye khi! Ama e mu anye kulo owa ighumha. Memena, ẹẹ nono ni wẹwẹ e bẹna rue anye abọ-a, ọa ya tsẹ e! Eni esọ-ẹzọ wẹwẹ-ghuo e bhale ya wolọ anye lasele.” 
\p  
\v 38 Eni ipolisi e lẹ ya gueyẹ eni enighie abi e ngme. Abi e rọ suọ khi ẹgbọ iRomu iPọlu ali iSalasi e khi, ulishi o mu wẹ.  
\v 39 Ighọ e vu ya kuegbe-a lema wẹ, e wolọ wẹ owa ighumha le, e lema wẹ e kpẹkpẹ e lase ẹwẹ ifuapfẹ le.  
\v 40 Ighọ iPọlu ali iSalasi e lase oni owa ighumha le, e ya je apfẹ oyi iLidia. E bhale ya ẹ eni e miesuọ aghọ. E ri udu shi wẹ ọ, e rọte aghọ vu. 
\c 17  
\s1 Obini iTẹsalonika 
\p  
\v 1 IPọlu ali iSalasi e rọte Afipolisi ali Apolonia dọsẹ e bhale iTẹsalonika ashini owa ugamhi oyi ẹgbọ iJu o la. 
\p  
\v 2 IPọlu ọ dọsẹ je owa ugamhi abi ọ kie kpẹ ẹ li. Ẹfo uka esẹ ọ la aghọ nu wẹ rọte Ebe-no-pfuasẹ ku ochi.  
\v 3 Ọ rọte Ebe-no-pfuasẹ rọli khasẹ gboo, khi ọni Ọmiepfuese, ọ mema ya mẹ osoli, ọ rọte eghuli guale. IPọlu ọ gueyẹ wẹ, “IJesu ni mhi rọ ọ tse abọ yẹ ẹ ọ khi ọni Ọmiepfuese ni Ẹshinẹgba ọ shobọ khi lọli ya rọ bhale.”  
\v 4 Ẹgbọ iJu eghuo e mie shi emini iPọlu ali iSalasi e ngme, e ku ma wẹ ọ ọ ga Ẹshinẹgba. Ighọ li khi ẹgbọ iGiriki eni ẹ na ulishi Ẹshinẹgba ali ebubu ikpotso ni e fialo-a e li miesuọ.  
\v 5 Ama ẹgbọ iJu ee kpe ofuma, e kia ya luno ẹgbọ usuesọ-akhuẹ tigbili shi okhọli. E pfi ozughu shi oni ẹdẹli nya. E tsua okhọli lo owa oyi ọmọse ni a lu iJasi ya nono iPọlu ali iSalasi ni wẹwẹ e muno wẹ lasele na eni ẹgbọ.  
\v 6 Ama abi ẹa rọ mẹ wẹ, e tialọ iJasi ali eni e miesuọ elese ghọ je odalo oyi enighie eyi oni ẹoli, e tsẹsẹ leghe, e liẹ, “Emọse ena e she pfi ozughu shi asha kpa! Memena e gbo bhale ifuapfẹ eyi awa,  
\v 7 IJasi ọ mie wẹ shi owa oyọli. Ẹ da ishi eyi iSiza, ẹẹ khi oghie ọlese ọ laọ ni a lu iJesu.”  
\v 8 Abi e rọ suọ eni ingmemhi ena, elemhi e te ododẹ yese eni ebubu ẹgbọ ali enighie eyi oni ẹoli-a.  
\v 9 E ri iJasi ali eni a ga muno wẹ eghọ zẹ oko, neni a tigbe zẹwẹ vu. 
\s1 Elemhi iBẹrea 
\p  
\v 10 Obili o lẹsẹ bi ẹlẹghọ, eni e miesuọ e ghie iPọlu ali iSalasi je iBẹrea. Abi e rọ ramhi aghọ, e je owa ugamhi oyi ẹgbọ iJu.  
\v 11 Ẹgbọ ni e la aghọ e mhọli udu ni o khueghie-a dọsẹ eni e la iTẹsalonika. E ri esọ shi oni usomhi onete egbegbọ. Ogbẹlẹ kpa e rọ wẹna Ebe-no-pfuasẹ ni e mẹ ini emini iPọlu ọ gueyẹ wẹ ini igẹsikia lọ.  
\v 12 Ẹgbọ iJu ebubu e miesuọ, ikpotso iGiriki ni e fia alo-a, ali emọse iGiriki e li miesuọ. 
\p  
\v 13 Ama abi ẹgbọ iJu ni e la iTẹsalonika e rọ suọ khi iPọlu ọ la iBẹrea a tse abọ ungmemhi oyi Ẹshinẹgba, e bhale aghọ ya ngmiasẹ ẹgbọ e ka pfi ozughu.  
\v 14 Eloawẹ eloawẹ, eni e miesuọ ẹẹ iPọlu vu ke je egele okẹ oniẹmhi, ama iSalasi ali iTimoti e kie la iBẹrea.  
\v 15 Eni emọse ni e kphase iPọlu, e rọ li bhale Atẹni, e gbo nyenẹ egbe je iBẹrea. IPọlu ọ ghie wẹ ghi iSalasi ali iTimoti e kẹlẹ bhale ya ẹ luẹ shi aghọ. 
\s1 Abi iPọlu ọ rọ la obini Atẹni 
\p  
\v 16 Abi iPọlu ọ li migha Atẹni i khẹ iSalasi ali iTimoti, ọ mẹ ilitsa ọdọda ni e la oni ekẹ, o nighise ọli ayẹmhẹ.  
\v 17 Ighọ ọ nu ẹgbọ iJu ali ẹgbọ iJẹta ni ẹẹ na ulishi Ẹshinẹgba ku ochi elemhi owa ugamhi. Ighọ ọ li gbo nu ẹgbọ kpa ni e rọte olele e dọsẹ ẹ ngme ogbẹlẹ kpa.  
\v 18 Ẹgbọ eghuo ni ẹ sẹsẹ, ni e khi Ẹpikuria ali iSitoiki e nu ọli i khẹ akọ.\f + \fr 17:18 \ft Ẹgbọ Ẹpikuria ali iSitoiki ena, e deba osẹsẹ ni ẹa te odẹ, eyi ọ ni a lu Ẹpikurọsi ali iZẹno. Eri Ẹpikurọsi ọọ sẹsẹ ẹgbọ e zobẹ ni oghẹlẹ o khi emini e na khu agbọ oyẹwẹ, a na ke na emini e ya pfi osoli ali ulishi na wẹ. Ẹgbọ iSitoiki e deba osẹsẹ ni ẹa te odẹ eyi iZẹno, ni ọọ ọgbọkpa ọ ke li agbọ oyọli abi usamhi oyọli o lama na li shi. Ọgbọ khi zobẹ ni usamhi agbọ aruele okekhi oyi osoli, ni o nasẹ ọli.\f* Abi iPọlu ọ rọ ngme ungmemhi oyi iJesu ali irọte eghuli guale, eghuo ọ e liẹ, “Elọ ọyẹghẹ ọna ọ mẹ ẹ ngme?” Eghuo ẹẹ li, “Abi khi eri ọọ liẹ awa ke ga ilitsa eyi ẹoli oboese?”  
\v 19 Ighọ e rue iPọlu bhale owa ni a lu Aropagọsi. (Owa ona eguebe ni e la ẹoli Atẹni ẹẹ legba.) “Anye ẹ nono ni u gueyẹ anye abi osẹsẹ onogbọ ona o ngme.  
\v 20 Ingmemhi ni u wa ngme, enegbọ e khi shi anye esọ, gueyẹ anye abi e ngme.”  
\v 21 Irari khi ẹgbọ Atẹni nya, ali epfẹse ni e la ọ, e ma pfuse ẹghẹghẹ-a ke ngme ingmemhi ali ke ri esọ shi owẹna ali ilẹsẹ enegbọ ni e shẹ lasele ẹ gbigbi ekẹ.  
\v 22 IPọlu ọ vule migha wẹ iteva ọ wẹ, “Emọse Atẹni, mhi mẹ ẹ mẹ khi ẹgbọ ni e mhuẹ ulishi oyi Ẹshinẹgba a khi.  
\v 23 Irari khi abi mhi rọọ kia ifuapfẹ eyẹ ẹ gasẹ mhi bino ikhumhi ebubu ni aa ga. Mhi mẹ okula oghuo ni a kẹkẹ emhi shi, ni ọọ, ‘Oyi olitsa ni aa lẹsẹ.’ Emini a ga ni ẹẹ khi aa lẹsẹ, mhi ya gue ingme oyọli yẹ ẹ ena. 
\p  
\v 24 “Ẹshinẹgba ni ọ ma agbọ ali emhikpa ni e la elemhi wẹ, lọli ọ khi Ọnọmhuẹ ọyi ekẹ ali ukhuli ni ọa ya la Owa ugamhi ni ẹgbọ e ri abọ tọ.  
\v 25 Wẹkhi eri ọ nono emhikhọghuo ali ikpaghiobọ oyi ẹgbọ. Itobọ khi lọli ọ ri agbọ ali ayẹmhẹ ali emhikpa na ẹgbọ nya.\f + \fr 17:25 \ft Li zẹ \fq 1 Ighie 8.27; Aza 42.5; Ika 7.48\f* 
\v 26 Ọgbọ ọghuo ọ te ma ẹgbọ ọdọda na ushishi ni e la agbọ nya, Lọlighuo ọ ri ẹghẹghẹ shi ekẹ na ushishi ni e rọ ya la agbọ ali khi ọ shi ughuli oyi ọgbọgbọ nali.  
\v 27 Lọli ọ lighọ riẹlẹ ona ini ẹgbọ e rọshẹka ke nono ọli, ini e mẹ asha ramhi ọli egbe. Ama Ẹshinẹgba ọa nuata shi ọngẹ-awa ọ.  
\v 28 ‘Lọli ọ ri ekpabọ na awa la agbọ ni awa rọ́ ọ kia, ni awa rọ khi ọni awa khi,’ ali khi, ‘imi ọli awa khi,’ abi ekẹkebe eyẹ ẹ eghuo e li ngme ọli. 
\p  
\v 29 “Irarighọ, aborọkhia khi imi Ẹshinẹgba awa khi, awa khi ke rọli khọkhọ isheli ni ẹgbọ e ri ẹnẹli ri igolu ali ẹlomho ali echẹ ma.  
\v 30 Ẹghẹghẹ ni o dọsẹ, eri Ẹshinẹgba ọ mu alo kua shi umhalẹsẹ oyi ẹgbọ. Memena ọ she ri omhẹsẹ ni ọgbọkpa ni ọ la ashakpa ọ mu nyenẹ.  
\v 31 Irari khi ọ she shi ogbẹlẹ shi ekẹ ni ọ rọ ya ri ọmọse ọghuo gue agbọ kpa ẹzọ. Ẹshinẹgba ọ she rọkhasẹ agbọ khi igẹsikia onana o khi ni ọ rọ rọte eghuli guise ọni ọmọse ọna lẹ.” 
\p  
\v 32 Abi e rọ suọ khi iPọlu ọ ngme ramhi irọte eghuli guale, e ri ọli i li egia, ama elese ẹẹ ọli, “Anye a nono ni anye gbo suọ ungmemhi ona ẹlẹlese.”  
\v 33 Ighọ iPọlu ọ rọte ọni ilegba vu.  
\v 34 Emọse eghuo e deba li, e mie ọli suọ. IDionisusi ni ọ khi ọghuo oni igbaa Aropagọsi ọ li deba li. Ighọ li khi ọkpotso ọghuo ni a lu iDamarisi ali ẹgbọ eghuo elese e li laọ. 
\c 18  
\s1 Abi iPọlu ọ rọ la iKọriti 
\p  
\v 1 Abi a rọ mẹ eni ingme ena se, iPọlu ọ rọte ẹoli Atẹni vu je ẹoli iKọriti.  
\v 2 Aghọ ọ bhale ya ẹ ọngi iJu ọghuo ni a lu Akuila ni a bia shi ekẹ iPọtusi. Ọni lọli ali ughuẹ ọli ni a lu iPisila e lẹsẹ rọte ekẹ Itili bhale, irari khi oghie iRomu nya ni a lu iKiladiusi ọ shi ushi na ẹgbọ iJu nya ni e la ẹoli iRomu nya e lase ẹoli iRomu lẹ. IPọlu ọ lẹ ya bino wẹ,  
\v 3 irari khi akanya ọni ọ ri ide ẹ ghi okholo ọọ gbe, ọ nu Akuila ali iPisilia a gbe oni akanya ni ee gbe. Ọ nu wẹ la aghọ. 
\p  
\v 4 Ogbẹlẹ Iyẹmhẹa oyi ẹgbọ iJu kpa ọ rọ je owa ugamhi oyi ẹgbọ iJu ya nu wẹ ku ochi ini ọ dobẹ ri oni ungmemhi lo ẹgbọ iJu ali ẹgbọ iGiriki esọ.  
\v 5 Abi iSalasi ali iTimoti e rọ rọte ekẹ iMasidonia bhale, iPọlu ọ ri ẹghẹghẹ ni ọ mhọli nya gue oni ungmemhi yẹ ẹgbọ iJu, khi iJesu ọ khi Ọmiepfuese ni Ẹshinẹgba ọ shobọ khi ọ ya bhale.  
\v 6 Abi eni ẹgbọ iJu e rọ nu ọli khẹ akọ ni e rọ zẹ ẹmuẹ ebe na li, ọa lama shi wẹ ọ, ọ kpe abọ shi wẹ ọ, Ọọ, “Mhi kpe abọ shi ẹ ọ. Ini a pfua, ẹẹ a ya mu ota sọ. Ọa khi mhẹmhẹ a ya mu ota sọ shi ọlia eyẹẹ. Rọte memena vu, mhia je ekẹ oyi ẹgbọ iJẹta.”  
\v 7 Ọ pfi wẹ shi aghọ vu, ọ je owa oyi ọgbọ iJẹta ni a lu iTatọsi iJọsitọsi ni ọọ ga Ẹshinẹgba, ni owa oyọli o la mama owa ugamhi oyi ẹgbọ iJu.  
\v 8 IKirisipusi ni ọ khi ọga shi oni owa ugamhi ali apfọli e mie Ọnọmhuẹ suọ; ebubu ẹgbọ ni e la iKọriti ni e suọ oni usomhi e miesuọ, a batazi wẹ. 
\p  
\v 9 Ẹliyọsẹ ẹlẹghuo, iPọlu ọ mẹ imẹ-alo ni Ọnọmhuẹ ọ la nu ọli ngme, ọọ li, “Ulishi o khi mu ẹ, ama kie ke gue ungmemhi le, khi tsaghiẹ-a.  
\v 10 Irari khi mhi nu ẹ la. Ọgbọ ọa la ọ ni ọ ya kuali ẹ utse. Irari khi mhi mhọli ebubu ẹgbọ shi ẹoli ona ni e khi ẹgbọ eyẹmhẹ.”  
\v 11 Ighọ iPọlu ọ la iKọriti ukpe oghuo ali ukhukhui, ọọ sẹsẹ eni ẹgbọ ungmemhi oyi Ẹshinẹgba. 
\p  
\v 12 Abi iGalilio ọ rọ khi igọvunọ ni iRomu e zẹ shi obini ekẹ Akhaya, ẹgbọ iJu eghuo e kugbe mu okhọli vule shi iPọlu ọ, e mu ọli je ikọtu.  
\v 13 Ẹẹ li, “Eri ọmọse ọna ọọ sẹsẹ ẹgbọ odẹ ẹgbhọli ni a te ẹ ga Ẹshinẹgba abi ushi oyi awa ọa ngme.” 
\p  
\v 14 Abi iPọlu ọ li i nono ni lọli ngme, ighọ iGalilio ọ nu ẹgbọ iJu ngme, ọọ, “Ini ẹzọ ni a lu ena o khia khi oyi umhaguẹli lọ okekhi oyi ingmobe okhọghuo lọ, mhi kha kuegbe-a ri esọ shi ẹ ẹẹ ẹgbọ iJu ọ.  
\v 15 Ama abi o rọ khi ungmemhi ekhakọ ni o la ingmemhi ali eva ali ushi oyẹẹ eghọ, ẹẹ-ghuo a ya sọ oni ingme, mhi aa ya sọ ọ.”  
\v 16 Ọọ a khu wẹ ikọtu ya fiẹ.  
\v 17 E gamhi iSositẹnisi ni ọ khi ọga shi owa ugamhi mu. E la odalo oni ikọtu gbe ọli. Ama iGalilio ọa fẹ pfi esọ shi wẹ ọ. 
\p  
\v 18 IPọlu ọ nu eni e miesuọ la iKọriti ogbẹlẹ ni e bu, ighọ ọ li tsẹ wẹ okhila, lọli ali iPisilia ali Akuila e lo ọkọ-okẹ oniẹmhi da okẹ oniẹmhi je iSiria. Neni iPọlu ọ rọte iKẹnkhiria da okẹ oniẹmhi, ọ yamhi itsu ukhomhi-a itobọ irọnga ni ọ rọ nga.\f + \fr 18:18 \ft Li zẹ \fq iNọba 6.18\f* 
\v 19 E ramhi Efesọsi, ashini iPọlu ọ pfi iPisilia ali Akuila shi. Ọ je owa ugamhi ni ọ nu ẹgbọ iJu ku ochi.  
\v 20 Eni ẹgbọ ẹ ọ nu wẹwẹ la aghọ tẹsẹ, ama ọa lama.  
\v 21 Ochoghọ, ọ gueyẹ wẹ abi ọ rọ ọ vu, ọọ, “Ini o da khi ọghuẹmhẹ ọyi Ẹshinẹgba, mhi ya nyenẹ egbe bhale deba ẹ.” Ighọ ọ rọte Efesọsi lo ọkọ-okẹ oniẹmhi vu da okẹ oniẹmhi.  
\v 22 Abi ọ rọ ramhi iSizeria, ọ te aghọ je iJerusalẹmu ya tsẹ eni e miesuọ, ọ ke te aghọ je ẹoli Atiọki. 
\p  
\v 23 Abi ọ rọ la aghọ ukuku ẹghẹghẹ, ọ te aghọ vu, ọ rọte ekẹ iGalesha ali iFirigia ya ri udu shi eni e miesuọ ọ.\fig Okiali onuzi-esẹ oyi iPọlu |src="ATG Paul3-BW.ai" size="span" loc="ACT 18.23--21.17" ref="18.23--21.17" \fig* 
\s1 Abi Apolosi ọ rọ la Efesọsi ali iKọriti 
\p  
\v 24 Oni ẹghẹghẹ, ọmọse ọnge iJu ni a lu Apolosi ni a bia shi Alẹzadira ni ọ khi ọni ọ mema guẹ ebe, o gbo lolo lẹsẹ ebe nọ pfuasẹ, ọ bhale Efesọsi.  
\v 25 Ọ khi ọgbọ ni a rọte ekẹ sẹsẹ odẹ oyi Ọnọmhuẹ. Ọ mhọli ọmuegbe ni o fu ni ọ rọ sẹsẹ ingme oyi iJesu. Emini ọọ sẹsẹ o rọte odẹ igẹsikia. Ama osẹsẹ oyi iJọni Ọni ọọ batazi ẹgbọ ọ lẹsẹ guẹ.  
\v 26 Ighọ ọ li la owa ugamhi oyi ẹgbọ iJu ri igbedu u ngme. Abi iPisila ali Akuila e rọ suọ ẹmuẹ ni o la li unu, e rue ọli ma egbe je apfẹ, e kuegbe-a sẹsẹ ọli odẹ oyi Ẹshinẹgba shi ọ egbegbọ.  
\v 27 Apolosi ọ rọli shi udu khi lọli ya je Akhaya, eni e miesuọ ni e la Efesọsi e kpaghiẹ ọli obọ, e kẹkẹ ebe ghi eni e miesuọ ni e la Akhaya. E gueyẹ wẹ e kpe abọ mie ọli. Abi ọ rọ ramhi akaghọ, ọ khi ikpaghiobọ oniẹmhi na eni e rọte okhale oyi Ẹshinẹgba miesuọ.  
\v 28 Irari khi ọ nu ẹgbọ iJu khẹ akọ egbegbọ, ọ rọ mu wẹ ọ le. Ọ rọte Ebe-no-pfuasẹ rọkhasẹ wẹ khi iJesu ọ khi Ọmiepfuese ni a shobọ. 
\c 19  
\s1 Abi iPọlu ọ rọ la Efesọsi 
\p  
\v 1 Abi Apolosi ọ li la elemhi iKọriti, iPọlu ọ rọte elemhi oni ekẹ kia rọte ugbogbode ni o khi ute ute e dọsẹ, ọ bhale Efesọsi. Aghọ ọ bhale ya ẹ eni e miesuọ eghuo,  
\v 2 ọ mhila wẹ, ọọ wẹ, “Abi a rọ miesuọ, a li mie Ayẹmhẹ-nọ-pfuasẹ?” 
\p Ẹẹ ọli, “Anye a fẹ suọ khi a mẹ emini a lu Ayẹmhẹ-nọ-pfuasẹ ghue.”  
\v 3 IPọlu ọọ wẹ, “Ibatizi onabi onoghuo a kpẹ mie?” 
\p Ẹẹ ọli, “Ibatizi oyi iJọni.”  
\v 4 IPọlu ọọ wẹ, “Ibatizi oyi iJọni, ibatizi ona imupfi lọ. Ama ọni iJọni ọ gueyẹ ẹgbọ iZirẹni e mie ọni ọ ya bhale ikpukhokho oyẹluẹ suọ, ikhi iJesu.”\f + \fr 19:4 \ft Li zẹ \fq iMat 3.11; iMak 1.4,7-8; iLuk 3.4,16; iJọn 1.26-27\f* 
\v 5 Abi e rọ suọ ona se, a ri eva oyi iJesu Ọnọmhuẹ batazi wẹ.  
\v 6 IPọlu ọ ri abọ nga wẹ ukhomhi, Ayẹmhẹ-nọ-pfuasẹ ọ tiemhile shi wẹ ọ, ee ngme ẹmuẹ onogbọ. E gbolo o ngme ungmemhi ni Ẹshinẹgba ọ rọ shi wẹ unu.  
\v 7 Wẹwẹ nya e khi emọse ogbava. 
\p  
\v 8 IPọlu ọ lo elemhi owa ugamhi, ọ la aghọ iki esẹ, ọ ri igbedu nu eni ẹgbọ ngme. Ọ nu wẹ ku ochi, ọọ sẹsẹ wẹ ni e mie shi ingme Eghiele oyi Ẹshinẹgba.  
\v 9 Ama eghuo ọ e khi isuesọ-akhuẹ ni ẹa lama miesuọ. E la ukpẹloe oni igbaa ngme ingmemhi ebe deba oni odẹ. Ighọ iPọlu ọ pfi wẹ shi aghọ vu, ọ rue eni e deba li je owa oyi iTiranọsi. Ọ la aghọ nu wẹ ẹ ku ochi ingme iloghie ogbẹlẹ kpa.  
\v 10 Ikpe eva ọ la aghọ sẹsẹ wẹ, ghe ẹgbọ iJu ali ẹgbọ iGiriki ni e la ekẹ Esha, e suọ ungmemhi oyi Ọnọmhuẹ. 
\s1 Imi iSikiva 
\p  
\v 11 Ẹshinẹgba ọ te obọ oyi iPọlu u gbe ikanya ọshabọ ọdọda.  
\v 12 O ya ramhi khi ibẹde ali ọgbẹnẹ ni a rọte iPọlu egbe wolọ, e ri ẹgbọ ni ẹa ze e toto, ali e khu ẹgbọ ayẹmhẹ ọkphaghiẹ idiegbe ya lase. 
\p  
\v 13 Ẹgbọ iJu eghuo ni ee kia ukhomhi ẹoli gasẹ ri imajiki i khu ayẹmhẹ obe kua, e li nono ni e ri eva oyi iJesu Ọnọmhuẹ riẹlẹ abi imajiki khu ayẹmhẹ obe. E liẹ, “Anye ri eva oyi iJesu ni iPọlu ọ rọ tse abọ mhẹsẹ nẹ, fiẹ lase!”  
\v 14 Imi ọga ọyi ekpodalo ugamhi ọnge iJu ọghuo ni a lu iSikiva etuoshilua, ee li ona.  
\v 15 Ighọ, oni ayẹmhẹ obe, ọọ wẹ, “Mhi lẹsẹ iJesu, mhi lẹsẹ iPọlu, eghuo a khi?”  
\v 16 Ọni ọmọse ni ọ mhọli oni ayẹmhẹ obe ọghọ, ọ kpha rughu wẹ, ọ gbe wẹ kuali utse. E ri irumheba na kua. 
\p  
\v 17 Abi ẹgbọ iJu ali iJẹta ni e la ekẹ Efesọsi e rọ suọ emini a mẹ, ulishi oo mu wẹ. E ri ékpẹ́ na eva oyi iJesu Ọnọmhuẹ.  
\v 18 Igbaa oyi eni e mie iJesu iKirisiti suọ e fiẹ lasele gboo, e zọnọ olamhẹ eyẹwẹ le nya.  
\v 19 Ebubu wẹ ni e kpẹ ẹ li ẹboli, e wolọ ebe ni e rọ ọ li ẹboli nya lasele tosẹ-a. Abi a rọ ta ingmẹ ni a rọ dẹ eni ebe ni e tosẹ-a, e ya khi ẹkpa udududu.  
\v 20 Ighọ ungmemhi oyi Ọnọmhuẹ oo gẹ shi ọ tsẹ, oo toto-a. 
\p  
\v 21 Abi a rọ mẹ ingme ena se, iPọlu ọ sa ọ khi lọli ya rọte ekẹ iMasidonia ali Akhaya dọsẹ je iJerusalẹmu. Ọọ eni ẹgbọ, “Mhi kha ramhi aghọ se, mhi ya rọte oobọ je ẹoli iRomu.”  
\v 22 Ighọ ọ ghie iTimoti ali Erasitọsi ni e nu ọli a gbe akanya je iMasidonia. Lọli ọ la ekẹ Esha ukuku ẹghẹghẹ. 
\s1 Onyaghu ni a mẹ Efesọsi 
\p  
\v 23 Oni ẹghẹghẹ, ukpokpomhi onyaghu o ya de shi ẹoli Efesọsi irari osẹsẹ ni iPọlu ọọ sẹsẹ.  
\v 24 Ọmọse ọghuo ọ la ọ, ni a lu iDẹmẹtiriusi ni ọọ lumhi igolu rọ riẹlẹ irọkhọkhọ okula oyi olitsa Atẹmisi. Ọ tsua oki oniẹmhi ghi eni e gbe oni akanya.  
\v 25 Ighọ ọni ọmọse ọ luno wẹwẹ nya kugbe, ọọ wẹ, “A lẹsẹ khi egbegbi eleli awa rọte oni oki ona mẹ.  
\v 26 Mena a she mẹ, a gbolo suọ ikanya ni iPọlu ọọ gbe. Lọli ọọ gueyẹ ẹgbọ khi ilitsa ni a ri abọ mama khi afuẹ e khi. Ebubu ẹgbọ ni e la ẹoli Efesọsi ali ekẹ Esha nya e she mie ọli suọ.  
\v 27 Oki oyawa o she la okhẹna ni o rọ ọ le eva obe. Ali khi ekpẹ oniẹmhi ni a rọ na olitsa Atẹmisi ali okula oyọli o ya mele afuẹ-a. Olitsa ona ẹgbọ ni e la ekẹ Esha ali agbọ nya ẹẹ ga.” 
\p  
\v 28 Abi eni ẹgbọ e rọ suọ ona, elemhi ee bi wẹ. E ri ofu tsẹsẹ ẹ gasẹ ekẹ gbii, ee liẹ, “Olitsa ọnọfunẹ, Atẹmisi o khi ni anye ẹgbọ Efesọsi anye ẹẹ ga.”  
\v 29 Oni okeke o gbhiaku oni ẹoli. Eni ẹgbọ e mu iGayusi ali Arisitakusi ni e khi engi iMasidonia ni e nu iPọlu kia a gasẹ. E rue wẹ bhale olele.  
\v 30 IPọlu ọọ nono ni lọli je odalo oyi oni igbaa, ama eni e miesuọ ẹa zẹ ọli obọ.  
\v 31 Ekhẹmhuẹ eghuo ni ẹẹ mhẹsẹ shi oni ekẹ ni e khi emọle iPọlu e li ghie usomhi ya lema li ọ khi bie je elemhi olele ya ri egbọli khasẹ.  
\v 32 Oni ẹghẹghẹ, okeke oniẹmhi o de elemhi oni igba. Eghuo e kha ngme ẹ je ola, elese e ngme ẹ je oobọ. Ẹgbọ eghuo ni e la aghọ ẹa lẹsẹ emini o pfi oni ozughu.  
\v 33 Eni ẹẹ ralo na ẹgbọ iJu eghuo e tanọ Alẹzada abọ je odalo ọ ka ngme na ẹwẹ. E gueyẹ ọli emini ọ ya ngme. Ighọ ọni Alẹzada ọ ri abọ gbe wẹ akhiakhia. Ọ guele emini a mẹ.  
\v 34 Ama abi eni ebubu ẹgbọ e rọ lẹsẹ khi ọngi iJu ọ khi, e ri uruli oghuo tsẹsẹ gbii, elemhi iwakati eva, ee liẹ, “Olitsa onofunẹ Atẹmisi o khi ni anye ẹgbọ Efesọsi ẹẹ ga.”  
\v 35 Ikpukhokho ọ, ọkẹkẹ-ebe ọyẹwẹ ọ fiẹ lasele, ọ ri abọ gbe wẹ akhiakhia. Ọọ wẹ, “Inyọghuo-mhẹ ẹgbọ Efesọsi, ọgbọkpa ọ lẹsẹ khi awa khi eni ẹ khekhẹ okula Atẹmasi, ali ẹchẹli oyọli ni o rọte idane de tiemhile?  
\v 36 Aa mẹ ọgbọkhọghuo ni ọ dobẹ ya tia onana. Itobọ ighọ a diẹ oili lalọ ni udu oyẹẹ o pfọmhẹ. A khi ri inyanya-dọsẹ riẹlẹ emhikhọghuo.  
\v 37 Eri a muno emọse ena bhale abi o riẹ khia khi ẹa rọte oni owa ugamhi do ughiatọ, wẹkhi eri e zẹ ẹmuẹbe na olitsa ni awa a ga.  
\v 38 Ini iDẹmẹtiriusi ali apfọli e mhuẹ ọgbọkhọghuo ni ọ li wẹ ingme, a lẹsẹ khi awa mhọli ikọtu ali esọ-ẹzọ, ọ ka lu eni ẹgbọ ẹzọ.  
\v 39 Ama ini a mẹ emhese ni a nono ni a rọ lasele, a zẹ ni a la igba ni a la gue ẹzọ sọ ọ.  
\v 40 Irari khi ini a bino emini a mẹ amo, awa la okhẹna ipfa ẹzọ mu khi awa, awa pfi ozughu. Awa aa ya mẹ ẹzọ gue pfa egbe awa shi ekẹ, irari khi awa aa mhọli emini o pfi oni ozughu onana.”  
\v 41 Abi ọ rọ ngme se, ọọ oni igba o vẹ-a. 
\c 20  
\s1 IPọlu ọ rọte ekẹ iMasidonia ali Akhaya dọsẹ 
\p  
\v 1 Abi oni okeke o rọ pfọmhẹ, iPọlu ọ ghie ya lu eni e miesuọ. Ọ ye wẹ ude se, ọ tsẹ wẹ okhila. Ọ je ekẹ iMasidonia.  
\v 2 Ọ rọte oni ekẹ dọsẹ. Ọ kia ri ingmemhi ni e bu ri udu shi eni e miesuọ ni e la oni ekẹ ọ. Ikpukhokho, ọ ramhi ekẹ iGirisi.  
\v 3 Ọ la aghọ iki esẹ. Irari khi ẹgbọ iJu è gba ugbamhi obe khẹ ọli, abi ọ li nono ni lọli lo ọkọ-okẹ oniẹmhi je iSiria, ọ ri ochoghọ mu egbe pfi rọte odẹ iMasidonia vu.  
\v 4 ISopata omi iParọsi ọngi iBẹrea ọ deba li, li shi Aristakusi ali iSẹkudọsi ni e khi engi iTẹsalonika, ghe iGayusi ali iTimoti engi iDẹbi, gbo li shi iTakikọsi ali iTirofimọsi ni e khi engi ekẹ Esha.  
\v 5 Etuava ni a ngme kpukhokho enana, e je odalo ya migha khẹ anye obini ẹoli iTiroasi.  
\v 6 Anye rọte iFilipi kia ukhomhi okẹ oniẹmhi ogbẹlẹ ishe, abi a rọ li ukpe ibulẹdi ni aa ri ifuma shi nye se. Anye bhale ya ẹ eni e migha ẹ khẹ anye ẹoli iTiroasi, anye la aghọ ogbẹlẹ ishilua. 
\s1 IPọlu ọ rọte eghuli guise Iyutikọsi le 
\p  
\v 7 Ogbẹlẹ nododẹ elemhi ẹfo uka, anye bhale kugbe ni anye ya le eminale ni o pfuasẹ. IPọlu ọ nu eni ẹgbọ ngme tẹsẹ irari khi ọ ya vu ogbeakọlọ. Ọ ngme ya ramhi itsotso ogbiẹ.  
\v 8 A ri igbili ni e bu ru shi elemhi owa ukhomhi atọnga ni anye legba.  
\v 9 Ọzẹo ọghuo ni a lu Iyutikọsi ọ shitọ okele ni o la oni atọnga. Ukpokpomhi olesẹ o dọ li rue abi iPọlu ọ rọ ngme e tẹsẹ dọsẹ. Abi iPọlu ọ kie li i ngme, oni olese o lo ọli egbe ramhi ni ọ rọ rọte ukhomhi atọnga nuzi-esẹ de ya tiemhi ekẹ. Abi ẹ rọ mu ọli vule, ọ she ghua.  
\v 10 Ama iPọlu ọ tiemhi ekẹ, ọ mu ọli ko elemhi, ọ to ọli etuli, ọọ, “A li tsukẹ, ayẹmhẹ oyọli ọ kie laọ.”  
\v 11 Ighọ, ọ nyenẹ egbe nga atọnga, e le eminale ni o pfuasẹ. Ọ nu wẹ ngme ramhi ni ovọ o rọ ngale. IPọlu ọ vu.  
\v 12 Eni ẹgbọ e rue ọni ọzẹo je apfẹ, ọa mhọli ikuatse okhọghuo. Onana o ri udu pfọmhẹ wẹ egbegbọ. 
\s1 IPọlu ọ tsẹ eni egbhali Ẹfisha okhila 
\p  
\v 13 Anye lo ọkọ-okẹ oniẹmhi je odalo ya migha khẹ iPọlu Asọsi, asha ni iPọlu ọ te ya deba anye lo ọkọ-okẹ oniẹmhi. Lọli ọ mhẹsẹ ona itobọ khi awẹ ọ rọ ya bhale.  
\v 14 Abi ọ rọ bhale ya ẹ anye shi Asọsi, anye ga lo ọkọ okẹ oniẹmhi oghuo je iMitileni.  
\v 15 Ogbeakọlọ, anye lo ọkọ okẹ oniẹmhi te aghọ ya je iKhiosi, ogbẹlẹ ni o de bali, anye rọte aghọ da je iSamosi, ogbeakọlọ anye ramhi iMilẹtusi.  
\v 16 IPọlu ọa nono ni lọli migha ẹoli Efesọsi itobọ ini lọli khi pfuse ẹghẹghẹ a shi ekẹ Esha, irari khi inyanya ọ la ini lọli kẹlẹ ramhi iJerusalẹmu shi ogbẹlẹ iPẹtikọsiti. 
\p  
\v 17 Ẹoli iMilẹtusi iPọlu ọ te ghie usomhi ghi egbhali ni e la igba oyi ẹgbọ eni e miesuọ ni e la ẹoli Efesọsi e bhale ya ẹ luẹ.  
\v 18 Abi e rọ ramhi aghọ, ọọ wẹ, “A lẹsẹ abi mhi li nu ẹ ngeli abi mhi rọ la iteva oyẹẹ, rọ tẹ ogbẹlẹ onododẹ ni mhi te lo ekẹ Esha le.  
\v 19 Rọte iregbemhẹ-tiemhile ali amẹ eviẹ mhi rọ gbe ikanya eyẹmhẹ abi ọni ọọ ga ọyi Ọnọmhuẹ, ẹghẹghẹ ni o rọ ze mu mhẹ ni ẹgbọ iJu e rọ gba khẹ mhẹ.  
\v 20 Ẹa lẹsẹ khi mhi aa ri emhikhọghuo ni o ya kpaghiẹ ẹ obọ sheli ẹ abi mhi rọ ọ tse abọ ali ni mhi rọ ọ sẹsẹ ẹ elemhi igbaa ali ifuapfẹ.  
\v 21 Mhi she kpẹ gueyẹ ẹgbọ iJu ali ẹgbọ iJẹta khi e mema a te olamhẹ eyẹwẹ mu pfi deba Ẹshinẹgba ni e mie iJesu Ọnọmhuẹ ọyawa suọ. 
\p  
\v 22 “Memena, ni mhi rọ suọ esọ na Ayẹmhẹ-nọ-pfuasẹ, mhia lẹ iJerusalẹmu, ni o khia khi mhi aa lẹsẹ emini mhi ya mẹ oobọ.  
\v 23 Mhi lẹsẹ khi asha kpa ni mhi je, Ayẹmhẹ-nọ-pfuasẹ ọ she kpẹ gueyẹ mhẹ khi owa ighumha ali anasẹmhẹ e migha a khẹ mhẹ.  
\v 24 Ama eri mhi leli agbọ oyẹmhẹ shi afuẹ, ini mhi lẹsẹ mẹ asha gbe akanya ni iJesu Ọnọmhuẹ ọ mhẹsẹ na mhẹ pfo. Ikhi itsabọ usomhi onete isomhelemhi oyi Ẹshinẹgba.\f + \fr 20:24 \ft Li zẹ \fq 2 iTimo 4.7\f* 
\p  
\v 25 “Mhi she kia rọte asha je asha tse abọ ungmemhi Eghiele oyi Ẹshinẹgba yẹ ẹ. Memena mhi lẹsẹ khi ọngẹẹ, ọa kẹ tigbe ya mẹ mhẹ ghue.  
\v 26 Irarighọ, mhi gueyẹ ẹ amo khi ini ọngẹẹ ọ pfua, ọa ke la obọ oyẹmhẹ.  
\v 27 Irari khi ulishi ọgbọkhọghuo ọa mu mhẹ ni mhi rọ gue ungmemhi oyi Ẹshinẹgba yẹ ẹ.  
\v 28 Ighọ, a ri ẹloe khu egbe ẹ, ali ọgbọkpa ni Ayẹmhẹ-nọ-pfuasẹ ọ rọ nga ẹ obọ. Khi ọrisumha-kia ọyi igbaa oyi eni e mie iJesu iKirisiti suọ oyi Ẹshinẹgba ni ọ ri ọlia eyọli dẹ.  
\v 29 Mhi lẹsẹ khi ini mhi da vu se, ẹgbọ ni e khọlọ abi ekpẹ ali idumhi e ya lo ẹ iteva le, ẹa ya zẹ eni isumha obọ khi ẹa kuali wẹ utse.  
\v 30 Ẹghẹghẹ o ya ramhi ni ẹgbọ eghuo elemhi ẹ e rọ ya ri ingmemhi ẹgbhuẹ di eni e miesuọ, e rue iteva oyẹẹ lasele.  
\v 31 Irarighọ, a ri ẹloe shi ọ, a gbo sato khi elemhi ikpe esẹ mhi aa tigbe yẹmhẹ-a itse agua ye ẹ, shi ẹlẹ ọguota ghe ẹliyọsẹ, elemhi eviẹ. 
\p  
\v 32 “Memena, mhi rẹ ẹ nga Ẹshinẹgba obọ, ali ungmemhi isomhelemhi oyọli, ni o ya rẹ ẹ fu shi irudunga, ni o ya rẹ ẹ mhọli ugu ni eni Ẹshinẹgba ọ she khuẹsẹ pfuasẹ e ya mhọli.  
\v 33 Mhi aa dọ ọgbọkhọghuo ọkọnyọ ẹlomho ali igolu wẹkhi ode oyọli.  
\v 34 Ẹẹ a lẹsẹ khi abọ eyẹmhẹ ena mhi rọ gbe akanya rọ dẹ emini mhẹmhẹ ali eni e nu mhẹ kia ẹẹ nono kpa.  
\v 35 Elemhi emini mhi riẹlẹ kpa, mhi rọkhasẹ ẹ khi awa mema ya ri akanya igbegbe onana kpaghiẹ eni ẹa mhọli obọ. A sato ungmemhi oyi iJesu Ọnọmhuẹ, ni ọọ, ‘Ikhivọsẹ o la irọna dọsẹ imiemie.’ ” 
\p  
\v 36 Abi iPọlu ọ rọ ngme se, lọli ali ẹwẹ e wugha, ọ sọ iromhi.  
\v 37 Ee viẹ abi e li i tsẹ ọli okhila, e mu ọli, ni e pfipfi ọli egbe.  
\v 38 Oni o lolo ri egbe pfọ wẹ-a khi oni ọ gueyẹ wẹ khi ẹa kẹ tigbe ya mẹ luẹ ghue. Ighọ e kphase ọli ya lo ọkọ-okẹ oniẹmhi. 
\c 21  
\s1 IPọlu ọ vu iJerusalẹmu 
\p  
\v 1 Anye tsẹ wẹ okhila se, anye kia okẹ oniẹmhi talala a je ẹoli iKọsi. Ogbeakọlọ anye je ekẹ iRodisi, anye rọte aghọ je ẹoli iPatara.  
\v 2 Anye lo ọkọ-okẹ oniẹmhi ni oo je ekẹ iFonisha, ighọ anye lo ọ vu.  
\v 3 Anye nise alo mẹ iSapurọsi, anye rọte ukiẹkiẹ ọgobọ ini a sọ alo ghue obini ovọ o te ẹ lo eko. Anye je ekẹ iSiria. Anye migha ẹoli iTai, aghọ ọkọ oyi anye o la tiese itsua shi ekẹ. 
\p  
\v 4 Anye mẹ ẹgbọ eni e miesuọ eghuo, anye nu wẹ la aghọ ogbẹlẹ ishilua. Ayẹmhẹ-nọ-pfuasẹ ọ gueyẹ wẹ iPọlu ọ khi je ekẹ iJerusalẹmu.  
\v 5 Anye nu wẹ la aghọ ramhi ẹghẹghẹ ni anye nu wẹ ya la akaghọ ramhi se, anye rue okiali ekẹ. Igbaa oyi eni e mie iJesu iKirisiti suọ nya ali ighuẹwẹ ali imiwẹ e kphase anye fiẹ lasele oni ẹoli, anye ramhi esesọ okẹ oniẹmhi, anye wugha sọ iromhi.  
\v 6 Anye tsẹ egbe okhila se, anye ya lo ọkọ-okẹ, wẹwẹ e nyenẹ egbe ukhokho, e je apfẹ. 
\p  
\v 7 Anye rọte iTai vu, anye bhale iTolẹmasi. Anye la aghọ tsẹ eni e miesuọ, anye nu wẹ la aghọ ogbẹlẹghuo.  
\v 8 Anye vu ogbeakọlọ, anye ramhi iSizeria. Anye kushi owa oyi iFilipu ọni ọ kia gue ungmemhi oyi Ẹshinẹgba le, ni ọ khi ọghuo ẹgbọ oshilua ni a la iJerusalẹmu zẹ.\f + \fr 21:8 \ft Li zẹ \fq Ika 6.5; 8.5\f* 
\v 9 Ọ mhọli eniyẹ imueshi aane ni ẹa ye ughuẹ ne, ni e mẹ ekẹ ẹ guele. 
\p  
\v 10 Abi anye rọ la aghọ ogbẹlẹ ni e bu, ọmekẹguele ni a lu Agabusi ọ rọte ekẹ iJudia bhale.\f + \fr 21:10 \ft Li zẹ \fq Ika 11.28\f* 
\v 11 Ighọ ọ rue ugbhogbho ni a rọ ọ mu oku oyi iPọlu. Ọ rọli gẹnọ egbọli abọ ali awẹ. Ọọ, “Ayẹmhẹ-nọ-pfuasẹ ọọ khi, ‘Ina ẹgbọ iJu ni e la iJerusalẹmu e li ya gẹ ọni ọ mhọli ugbhogbho ona, e mu ọli na ẹgbọ iJẹta.’ ” 
\p  
\v 12 Abi anye rọ suọ ona, anye ali ẹgbọ elese ni e la aghọ, anye lema iPọlu ọ khi je iJerusalẹmu.  
\v 13 Ama iPọlu ọọ, “Elọ o zẹ ni a rọ ọ viẹ, ni a rọ ọ yese mhẹ udu-a. Aa khi eri mhi lẹsẹ mu egbe ni a rọ ya gẹ mhẹ tsẹ, ama mhi ga mu egbe ni mhi rọ ya ghu-a shi iJerusalẹmu, irari eva oyi iJesu Ọnọmhuẹ.”  
\v 14 Abi anye aa rọ dobẹ zu ọli odẹ, anye yẹmhẹ-a, anye ẹ ọli, “O ka tsẹ abi o ghọle Ọnọmhuẹ.” 
\p  
\v 15 Onana o dọsẹ se, anye mu egbe, anye nga iJerusalẹmu.  
\v 16 Eniyẹ odukhokho eghuo ni e la iSizeria, e kphase anye, e ri anye bhale owa oyi iMinasọ, ni ọ khi ọngi iSapurọsi ni ọ khi ọghuo eni e kpẹ tododẹ miesuọ. 
\s1 Abi iPọlu ọ rọ ramhi iJerusalẹmu 
\p  
\v 17 Abi anye rọ ramhi iJerusalẹmu, eni e miesuọ e kpe abọ mie anye egbegbọ.  
\v 18 Ogbeakọlọ iPọlu ali anye enekpọle anye ya mẹ iJemhisi, eni egbhali eni e miesuọ nya e li la aghọ.  
\v 19 IPọlu ọ tsẹ wẹ, ọ kuegbe-a gueyẹ wẹ ikanya ni Ẹshinẹgba ọ gbe shi iteva oyi ẹgbọ iJẹta rọte akanya oyi Ẹshinẹgba ni ọọ gbe. 
\p  
\v 20 Abi e rọ suọ ingmemhi ni iPọlu ọ ngme se, e kuẹghiẹ Ẹshinẹgba. Ighọ ẹ iPọlu, “Inyọghuo, wa a mẹ ẹgbọ agbẹlẹ-agbẹlẹ eyi iJu ni e mie iJesu suọ, wẹwẹ nya e mhọli ọmuegbe shi iri ushi gbe akanya.  
\v 21 E she kpẹ suọ khi eri u wa sẹsẹ ẹgbọ iJu nya e tsua Ishi eyi iMosisi kua, khi u wẹ e khi shẹlẹ imi wẹ-a ali e khi ke deba ighuighuẹ eyi ẹgbọ iJu.  
\v 22 Sẹ awa ya li, irari khi e mema ya suọ khi u she bhale.  
\v 23 Ina anye nono u li, emọse aane e nu anye la ana ni e she rọ nga.  
\v 24 Rue emọse ena, ni a ga ya riẹlẹ ikhuẹ-pfuasẹ. U gbo fali ota na wẹ ni a rọ ya ta wẹ itsu-a. Isheghọ, ọgbọkpa ọ ya lẹsẹ khi ẹgbhọli a kie mẹ, khi u ri Ishi eyi iMosisi ẹ gbe akanya.\f + \fr 21:24 \ft Li zẹ \fq iNọba 6.13-21\f* 
\v 25 Ama anye she ri ebe ghi ẹgbọ iJẹta eni e miesuọ rọ gueyẹ wẹ abi anye ngme, khi e ti egbe eminale ni a rọ luasẹ obo le, ali e khi ke da ọlia ali e khi le ẹlamhi ni aa fa uruli, ali e lase itsẹbọ ikuku le.”\f + \fr 21:25 \ft Li zẹ \fq Ika 15.29\f* 
\p  
\v 26 Ogbeakọlọ, iPọlu ọ rue eni emọse, e ga ya riẹlẹ ikhuẹ-pfuasẹ. Ighọ ọ je Owa Oyi Ẹshinẹgba ya gueyẹ wẹ ogbẹlẹ ni oni ikhuẹ-pfuasẹ o ya pfo ali emini a rọ ya riẹlẹ iluasobo na ọgbọgbọ. 
\s1 A mu iPọlu 
\p  
\v 27 Abi eni ogbẹlẹ ishilua e rọ ya gba, ẹgbọ iJu eghuo ni e rọte ekẹ Esha bhale e mẹ iPọlu elemhi Owa Oyi Ẹshinẹgba. E tanọ shi eni ebubu ẹgbọ elemhi, e mu iPọlu.  
\v 28 E tsẹsẹ leghe, ẹẹ li, “Ẹgbọ iZirẹni, a kpaghiẹ anye obọ. Eri ọni ọmọse ọna ọ kia sẹsẹ ẹgbọ ashakpa, mu okhọli vule shi ẹgbọ eyawa ọ, ali ishi eyawa ali Owa Oyi Ẹshinẹgba onana. Ọa khi ena tsẹ, ọ she gbo rue ẹgbọ iGiriki lo Owa oyi Ẹshinẹgba oyawa ya ri ichimhi mu asha ni o pfuasẹ onana.” 
\p  
\v 29 (Eri e ngme ona itobọ khi e mẹ iTirofimọsi ọngi Efesọsi ali iPọlu ifuapfẹ, e dabi khi ọ she rọli lo Owa Oyi Ẹshinẹgba.)\f + \fr 21:29 \ft Li zẹ \fq Ika 20.4\f* 
\p  
\v 30 Onyaghu o lo oni ifuapfẹ nya le, eni ẹgbọ e rọte ashakhasha na a bhale. E mu iPọlu, e rọte oni Owa oyi Ẹshinẹgba ti ọli lasele, aghọaghọ, e sọ okpẹ odẹ nya.  
\v 31 Abi eni ẹgbọ e li nono ni wẹwẹ gbe ọli-a, oni ingme o ramhi esọ oyi ọni ọọ mhẹsẹ na ekhọli-okhuẹ eyi iRomu khi ẹdẹli iJerusalẹmu nya o la onyaghu oniẹmhi.  
\v 32 Eloawẹ eloawẹ, ọ wolọ ekhọli-okhuẹ ma egbe e na tiemhi deba eni ebubu ẹgbọ. Abi eni ẹ nyaghu eghọ e rọ mẹ ọli ali eni ekhọli-okhuẹ, e mu mhuẹ, ẹ a ke gbe iPọlu. 
\p  
\v 33 Ọni ọ mhẹsẹ na ekhọli-okhuẹ ọghọ ọ mu iPọlu, ọ e ri iwẹghẹ eva gẹ ọli. Ọ mhila eni ẹgbọ ọni ọ khi ali emini ọ li.  
\v 34 Ẹgbọ eghuo ni e la oni igba ee tsẹsẹ, ọgbọgbọ ọ ngme oyọli. Abi ọni ọga ọkhọli-okhuẹ ọghọ ọa rọ lẹsẹ emini ee ngme, ọọ a mu iPọlu ya shi apfẹ ekhọli-okhuẹ.  
\v 35 Abi e rọ ramhi unu owa, eni ekhọli-okhuẹ e mu iPọlu tsua irari khi eni ẹ dọmhi ọli e bu dọsẹ.  
\v 36 Ighọ e li kpikpi deba li, ee tsẹsẹ gbii, e liẹ, “A gbe ọli-a, a gbe ọli-a.” 
\s1 IPọlu ọ pfa egbọli shi ekẹ 
\p  
\v 37 Abi eni ekhọli-okhuẹ e li mu iPọlu lo apfẹ eyi ekhọli-okhuẹ, ọọ ọga ọyẹwẹ, “Mhia nono ni mhi nu ẹ ngme?” 
\p Ọni ọga ọọ li, “U guẹ ẹ ngme ẹlẹmhi iGiriki?”  
\v 38 “Ọa khi yẹyẹ u khi ọngi iJipiti ni ọ ke gba onyaghu ekẹ le? Ni u wolọ ẹgbọ agbẹlẹ ene ni ee gbolo ekhọli-okhuẹ eyi iRomu-a, ni u rue wẹ je ọdagbe ifufu ya mu wẹ egbe shi onyaghu?” 
\p  
\v 39 IPọlu ọ sọ li ọ, ọọ li, “Ọngi iJu ni a bia shi ẹoli iTasọsi ni o la ekẹ iSilisha mhi khi. Ọmọ ekẹ ẹoli ni o mu ẹloe. Kpẹkpẹ zẹ mhẹ nu eni ẹgbọ ena ngme.” 
\p  
\v 40 Abi ọga ọyi ekhọli-okhuẹ ọ rọ ri oni ẹghẹghẹ na li, iPọlu ọ migha atẹtẹ unu odẹ, ọ ri abọ nu wẹ ngme e tsaghiẹ-a. Abi e rọ tsaghiẹ-a, iPọlu ọ ri ẹlẹmhi Iburu nu wẹ ẹ ngme. 
\c 22  
\p  
\v 1 “Inyọghuo-mhẹ ali itamhẹ ni a mu ekpẹ ẹ na, a ri esọ shi ekẹ ni a suọ ẹzọ ni mhi ya gue pfa egbemhẹ shi ekẹ ena.”  
\v 2 Abi e suọ khi ọ nu wẹ ngme ẹlẹmhi Iburu, e ga lolo tsaghiẹ-a. 
\p Ighọ iPọlu ọọ,  
\v 3 “Ọngi iJu mhi khi, ni a bia shi ẹoli iTasọsi ni o la ekẹ iSilisha. Ẹoli iJerusalẹmu ona mhi la fu vule. Ayi iGamaliẹ a la sẹsẹ mhẹ egbegbọ abi a liẹ deba ishi eyi ititawa. Eri mhi mhọli ọmuegbe shi ingme oyi Ẹshinẹgba egbegbọ ẹzẹzẹ abi ẹẹ a ke li ogbe na amo.\f + \fr 22:3 \ft Li zẹ \fq Ika 5.34-39\f* 
\v 4 Eri mhi mu okhọli vule shi ẹgbọ ni e rọte Odẹ oyi Ọnọmhuẹ ọ, ramhi ni mhi rọ gbolo eghuo-a. Mhi mu emọse ali ikpotso kulo owa ighumha.  
\v 5 Ọkpeda na ekpodalo-ugamhi eyi Ẹshinẹgba ali enighie e ya pfi ọtsẹlẹ shi ọ khi igẹsikia mhia ngme. Mhi mie wẹ ebe ghi eni eralo na ẹgbọ iJu ni e la iDamasikọsi, ni mhi rọ ya ri iwẹghẹ shi eni e miesuọ ni e la oobọ abọ, ni mhi muno wẹ je iJerusalẹmu ya nasẹ.\f + \fr 22:5 \ft Li zẹ \fq Ika 8.3; 26.9-11\f* 
\s1 IPọlu ọ guele abi lọli li mupfi 
\r (Ika 9.1-19; 26.12-18) 
\p  
\v 6 “Ẹlẹghuo khi mhi i lẹ iDamasikọsi, itsotso ọguota khi mhi lẹsẹ ti ramhi oni ẹoli, ákpá ni o lolo gẹ nyanyanya o rọte irarogbe mi nga mhẹ egbe udemhija.  
\v 7 Ighọ mhi de ya gbe, mhi suọ khi uruli ọọ mhẹ, ‘ISọlu! ISọlu! Elọ e zẹ ni u rọ mu okhọli vule shi mhẹ ọ?’ 
\p  
\v 8 “Mhi mhila li, ‘Ọghuo u khi, Ọnọmhuẹ?’ 
\p “Ọọ mhẹ, ‘Mhẹmhẹ khi iJesu ọnge iNazarẹti ni u mu okhọli vule shi ọ.’  
\v 9 Emọse ni e nu mhẹ kia, e mẹ oni ákpá, ama ẹa suọ uruli ni o nu mhẹ ngme. 
\p  
\v 10 “Mhi mhila li, ‘Elọ mhi ya riẹlẹ, Ọnọmhuẹ?’ 
\p “Ọnọmhuẹ ọọ mhẹ, ‘Vule ni u lo elemhi ẹoli iDamasikọsi, a ya la aghọ gueyẹ emini a mhẹsẹ nẹ nya ni u ya riẹlẹ.’  
\v 11 Mhi zẹ alo itobọ ugẹmhi ákpá ni o mi nga mhẹ alo. Eni anye ga kia e ke mu mhẹ obọ lo elemhi ẹoli iDamasikọsi. 
\p  
\v 12 “Ọmọse ọghuo ọ la aghọ ni a lu Ananayasi. Ọni ọ ga ugamhi, ni ọ ri ushi ẹ gbe akanya ọ khi. Ẹgbọ iJu nya e mu ekpẹ a na li.  
\v 13 Lọli ọ bhale ya migha mama mhẹ, ni ọọ, ‘Inyọghuo-mhẹ iSọlu, alo eyẹ e khueghie-a,’ utoghuo kpe, alo eyẹmhẹ e khueghie-a, mhi mẹ ekẹ mẹ ọli. 
\p  
\v 14 “Ọọ mhẹ, ‘Ẹshinẹgba ọyi ititawa ọ she zẹ kẹẹ, ni u lẹsẹ ọghuẹmhẹ oyọli, ni u mẹ Ọni ọ suọ esọ na Ẹshinẹgba, ni ọ ri unu oyọli nu ẹ ngme.  
\v 15 Irari khi u ya khi ọtsẹlẹ ọyọli, ni u ke ngme emini u suọ ali ni u gbo ri alo mẹ, gueyẹ ẹgbọ nya.  
\v 16 Memena, elọ u ke migha khẹ? Vule ni mhi batazi ẹ, ni a gbe olamhẹ eyẹ kua nẹ, rọte eva oyi Ọnọmhuẹ.’ 
\p  
\v 17 “Aghọ mhi te mu egbe pfi je ẹoli iJerusalẹmu. Abi mhi rọ la Owa Oyi Ẹshinẹgba lema, mhi mẹ imẹ-alo,  
\v 18 ighọ mhi mẹ Ọnọmhuẹ, ọ gueyẹ mhẹ, ‘Nyanya rọte ẹoli iJerusalẹmu vu, itobọ khi eni ẹgbọ ena, ẹa ya mie shi ọtsẹlẹ oyẹ ni u ya pfi na mhẹ.’ 
\p  
\v 19 “Mhiẹ ọli, ‘Ọnọmhuẹ, eni ẹgbọ ena e ga lẹsẹ khi mhẹmhẹ mhi kia kia owa ugamhi muno ẹgbọ ni e mie ẹ suọ kulo owa ighumha, mhi gbe wẹ egbegbọ.  
\v 20 Ali, ẹlẹ ni e gbe iSitivini-a ni ọ li khi ọtsẹlẹ, mhẹmhẹ mhi la aghọ, mhii mie obọ shi oni eghuli, mhi ri ẹloe khu itsua na eni e tono ọli echẹ gbe-a.’\f + \fr 22:20 \ft Li zẹ \fq Ika 7.58\f* 
\p  
\v 21 “Ọni Ọnọmhuẹ ọọ mhẹ, ‘Ke lẹ, mhi ya ghie ẹ je odonuẹ ghi ẹgbọ iJẹta.’ ” 
\s1 IPọlu ọmọ-ekẹ iRomu 
\p  
\v 22 Eni ebubu ẹgbọ e ku esọ-a na iPọlu kie ramhi ana ni ọ rọ ngme na, ighọ e li tsẹsẹ leghe, ẹẹ li, “A mu ọli vu, A gbe ọli-a. Ọna ọa ke khi ọni ọ́ọ́ la agbọ!” 
\p  
\v 23 E tsẹsẹ, ee pfi ide idane wiliwili, e yalọ ifufu ku nga idane.  
\v 24 Ọni ọọ mhẹsẹ na ekhọli-okhuẹ, ọọ a rue iPọlu lo apfẹ oyi ekhọli-okhuẹ. Ọọ wẹ, e gbe ọli itẹ ni e mhila li ini e lẹsẹ emini o zẹ khi ẹgbọ iJu e lina a tsẹsẹ ku ọli.  
\v 25 Ama abi e rọ gẹ iPọlu, ni wẹwẹ e gbe ọli, iPọlu ọ mhila ọni ọga ọyi ọkhọli-okhuẹ ni ọ migha aghọ,\fig Oga eyi Ekhọli-okhuẹ oyi iRomu|src="hk00193c.tif" size="col" loc="ACT 22.25" copy="TIF" ref="22.25" \fig* “Ushi o lama a shi ọ u gbe ọmọ ekẹ iRomu itali ini aa mẹ umhaguẹli ọli obọ ne?”  
\v 26 Abi ọni ọga oyi ọkhọli-okhuẹ ọ rọ suọ ona, ọ lẹ ya gueyẹ ọni ọọ mhẹsẹ na wẹ ni ọ kpeda na li. Ọọ, “Guẹ kia e, sẹẹ u wa li ena? Ọmọse ọna ọmọ-ekẹ iRomu ọ khi e.”  
\v 27 Ighọ ọni ọọ mhẹsẹ na wẹ ọ lẹ deba iPọlu ọ mhila li, “Mhiẹ i, ọmọ-ekẹ iRomu u khi?” 
\p IPọlu ọọ, “Ii, ọmọ-ekẹ mhi khi.” 
\p  
\v 28 Ọni ọọ mhẹsẹ na ekhọli-okhuẹ ọọ, “Ọmọ-ekẹ ni mhẹmhẹ mhi khi, ikpokpomhi ikpaghọ mhi fali rọ mie ebe rọ khi ọmọ ekẹ.” 
\p IPọlu ọọ, “Ama mhẹmhẹ oyẹmhẹ, ọngi iRomu a bia mhẹ.” 
\p  
\v 29 Ẹloawẹ-ẹloawẹ, eni ekhọli-okhuẹ ni e nono ni wẹwẹ e mhila iPọlu ingme unu, e ti egbe je ukhokho, abi ọni ọọ mhẹsẹ na ekhọli-okhuẹ ọ rọ lẹsẹ khi ọngi iRomu iPọlu ọ khi, ulishi oo mu ọli, irari khi ọ she gueyẹ wẹ e ri iwẹghẹ shi ọli abọ, e gbe ọli. 
\s1 Abi a rọ rue iPọlu bhale odalo oyi iSaẹdiri 
\p  
\v 30 Ogbeakọlọ, ọni ọọ mhẹsẹ na ekhọli-okhuẹ ọọ nono ni lọli lẹsẹ emini ẹgbọ iJu e nu iPọlu ẹ gue, ọ taghiẹ iPọlu iwẹghẹ-a. Ọ gueyẹ ighie eyi ekpodalo-ugamhi ali iSaẹdiri e legba. Ọ rue iPọlu bhale ya migha odalo oyẹwẹ. 
\c 23  
\p  
\v 1 IPọlu ọ bino oni igbaa iSaẹdiri tatata, ọọ wẹ, “Inyọghuo-mhẹ, mhi she rọte udu onete oyẹmhẹ nya gbe akanya oyẹmhẹ pfo na Ẹshinẹgba ya ramhi amo.”  
\v 2 Abi ọ rọ ngme ona, Ọga ọyi ekpodalo ugamhi ni a lu Ananayasi ọọ eni e ti mama iPọlu e lase ọli unu.  
\v 3 IPọlu ọọ li, “Ẹshinẹgba ọ ya ri emhi liẹ, yẹyẹ ugbe ni a ri ẹtseli gboloa. Yẹyẹ u shitọ aghọ a gue mhẹ ẹzọ egbe-a, ama yẹyẹ ọyẹ u gbe ushi-a abi u li ri unu bhale a ri emhi li mhẹ.”\f + \fr 23:3 \ft Li zẹ \fq iMat 23.27-28\f* 
\p  
\v 4 Eni e ti mama iPọlu ẹ ọli, “Ú ga gbudu ri unu a ghi ọga ọyi ekpodalo ugamhi eyi Ẹshinẹgba?”  
\v 5 IPọlu ọọ wẹ, “Inyọghuo-mhẹ, mhi aa lẹsẹ khi lọli ọ khi ọga ọyi ekpodalo ugamhi eyi Ẹshinẹgba! A kẹkẹ ọli shi ebe-no-pfuasẹ, ‘Khi gbudu ngme onobe oyi ọni ọ mhẹsẹ na ẹgbọ eyẹ.’ ”\f + \fr 23:5 \ft Li zẹ \fq Okiali 22.28\f* 
\p  
\v 6 Abi iPọlu ọ rọ lẹsẹ khi eghuo eni ẹgbọ khi iSadusi e khi, eni e kpọle e khi iFarisi, ọ la oni igbaa ngme lasele leghe, ọọ, “Inyọghuo-mhẹ, otu iFarisi mhi la, mhi gbo khi omi iFarisi. Eri a la ana a gue mhẹ ẹzọ itobọ khi mhi mhọli irudushọ khi eni e ghu-a e ya gbo guale.”\f + \fr 23:6 \ft Li zẹ \fq Ika 26.5; iFili 3.5\f* 
\v 7 Abi ọ li ngme ona se, uwola o de ni otu iFarisi ali otu iSadusi, oni igbaa o kemhi.  
\v 8 (Irari khi otu iSadusi ẹa lama shi ọ khi ẹgbọ e ya rọte eghuli guale, ẹa gbo lama khi igẹni ali iyẹmhẹ e la ọ, ama otu iFarisi e lama shi enana nya.)\f + \fr 23:8 \ft Li zẹ \fq iMat 22.23; iMak 12.18; iLuk 20.27\f* 
\p  
\v 9 Ukpokpomhi okeke o de, esẹsẹ Ishi eyi iMosisi eghuo ni e khi otu iFarisi e vule e khẹ akọ ni o toto, ẹẹ li, “Anye aa mẹ emhikhọghuo obọ oyi ọmọse ọna,” e gbolo ẹ, “Ini o fẹ khi-a khi ayẹmhẹ, o ke khi agẹni ọ nu ọli ngme?”  
\v 10 Oni ekhakọ o pfuse toto-a shọ, ulishi o mu ọni ọga ọyi ekhọli-okhuẹ khi e tigbe khẹrẹ iPọlu-a. Ighọ ọ mhẹsẹ na eni ekhọli-okhuẹ e tiemhi ya ri itoto mie wẹ iPọlu obọ ni e rọli bhale apfẹ oyi eni ekhọli-okhuẹ. 
\p  
\v 11 Ẹlẹ iyọsẹ ni oo deba li, Ọnọmhuẹ ọ migha mama iPọlu, ọọ li, “Mhuẹ igbedu! Abi u li la iJerusalẹmu pfi ọtsẹlẹ na mhẹ, ighọ u li mema ya li pfi ọtsẹlẹ na mhẹ ẹoli iRomu.” 
\s1 Ugbamhi igbe-a ni a gba khẹ iPọlu 
\p  
\v 12 Ogbeakọlọ, ẹgbọ iJu eghuo e ya mhẹsẹ kugbe, e romhi isheli khi wẹwẹ ẹa ya le eminale wẹkhi eri wẹwẹ e ya da amẹ, ini ẹa li gbe iPọlu-a.  
\v 13 Ẹgbọ ni e gba ugbamhi onana, e dọsẹ ẹgbọ egbhuẹva.  
\v 14 E lẹ deba ọga ọyi ekpodalo ugamhi eyi Ẹshinẹgba ali eni egbhali, ẹ li, “Anye she romhi ukpokpomhi isheli khi anye aa ya le emhikhọghuo sẹ khi anye gbe iPọlu-a.  
\v 15 Memena, yẹyẹ ali igbaa iSaẹdiri a kẹkẹ ebe ghi ọga ọyi ekhọli-okhuẹ, a liẹ khi a nono ni a lolo suọ oni ingme bie. Anye mu egbe ni anye rọ ya gbe ọli-a neni a rọli ya ramhi ana.” 
\p  
\v 16 Ama abi ọmọ ọmọse ni ọ khi omi inyọghuo iPọlu ọni ọkpotso ọ rọ suọ oni ugbamhi, ọ je oni apfẹ ekhọli-okhuẹ ya gueyẹ iPọlu. 
\p  
\v 17 Ighọ iPọlu ọ lu ọga ọyi ekhọli-okhuẹ ọghuo, ọọ, “Rue ọzẹo ona ghi ọni ọọ mhẹsẹ na ẹ, ọ mhọli emini ọ ya gueyẹ ọli.”  
\v 18 Ighọ ọ rue ọli ghi ọni ọọ mhẹsẹ na wẹ. 
\p Ọ li, “IPọlu ni a mu shi igha ọọ mhi rue ọzẹo ọna ghi ẹ, itobọ khi ọ mhọli emini ọ ya gueyẹ.”  
\v 19 Ọni ọọ mhẹsẹ ọghọ, ọ mu ọni ọzẹo obọ, e ti je olase, ọ mhila li, “Elọ wa nono ni u gueyẹ mhẹ?” 
\p  
\v 20 Ọọ li, “Ẹgbọ iJu e she gba li khi wẹwẹ e ya ghie ghi ẹ akọ, ni u rue iPọlu bhale odalo oyi iSaẹdiri khi ẹẹ nono ni e te unu oyọli suọ oni ingme bie.  
\v 21 Khi lama shi wẹ ọ, itobọ khi e bu dọsẹ ẹgbọ egbhuẹva ni e kpe odẹ khẹ ọli. E she romhi ishe khi wẹwẹ ẹa ya le, wẹkhi eri wẹwẹ e ya da ini wẹwẹ ẹa li gbe iPọlu-a. E migha a khẹ ni e suọ emini u ya sọ shi emini e mhila ẹ ena.” 
\p  
\v 22 Ọni ọọ mhẹsẹ na eni ekhọli-okhuẹ ọ gueyẹ ọli, ọọ, “Khi gueyẹ ọgbọ ọkhọghuo khi u she gueyẹ mhẹ.” Ọọ li ọ ke lẹ. 
\s1 A rue iPọlu te aghọ je ẹoli iSizeria 
\p  
\v 23 Ighọ ọni ọ mhẹsẹ ọghọ ọ lu ega ekhọli-okhuẹ aava eyọli, ọ mhẹsẹ na wẹ, ọọ wẹ, “A wolọ ekhọli-okhuẹ egbhuẹgbe, ali eni ẹ nga ichi egbhuẹsẹ ali ogbe, ali epfi-ote egbhuẹgbe ni a ke lẹ iSizeria agogo itili amiọsẹ.  
\v 24 A ri achi na iPọlu nga ni a rọli je oobọ ini emhikhọghuo e khi li ọli, ni a rue ọli ghi iFẹlisi ni ọ khi igọvunọ.”  
\v 25 Ọ lina kẹkẹ ebe na wẹ. 
\p  
\v 26 Mhẹmhẹ iKiladiusi iLisiasi mhi kẹkẹ ebe onana ghiẹ: 
\p Yẹyẹ igọvunọ iFẹlisi ni a mu ekpẹ ẹ na, 
\p Mhia tsẹ. 
\p  
\v 27 Ẹgbọ iJu e mu ọmọse ọna, e nono ni wẹwẹ e gbe ọli-a. Ama eri mhi ri ekhọli-okhuẹ eyẹmhẹ bhale ya pfa li shi ekẹ irari khi mhi suọ khi ọmọ-ekẹ iRomu ọ khi.  
\v 28 Mhi i nono ni mhi lẹsẹ emini e zẹ ni e rọ gue ẹzọ ọ shi ọli egbe, mhi rue ọli je igbaa iSaẹdiri oyẹwẹ.  
\v 29 Mhi bhale ya ẹ khi ẹzọ ingme ishi eyẹwẹ e rọ nali i gue, ama ọa mhuẹ emini ọ li ni abi a gbe ọli-a shi, wẹkhi imuọli shi ọgba igha.  
\v 30 Abi a rọ gueyẹ mhẹ ugbamhi ni e gba khẹ ọni ọmọse, mhi rọ nyanya rue ọli ghi ẹ, mhi gbo gueyẹ eni e gue ẹzọ a shi ọli egbe e bhale deba ẹ ni e guele emini ọ li. 
\p  
\v 31 Oni ẹliyọsẹ ẹlẹghọ, eni ekhọli-okhuẹ e rue iPọlu mhọli obọ vu, abi a li mhẹsẹ ọli na wẹ, e ramhi Atipatirisi.  
\v 32 Ogbeakọlọ, eni ekhọli-okhuẹ e rọli na eni e nga ichi ni e rue ọli kie ke lẹ, wẹwẹ e nyenẹ egbe ukhokho je apfẹ ekhọli-okhuẹ oyẹwẹ.  
\v 33 Abi eni e nga ichi eghọ e rọ ramhi ẹoli iSizeria, e rue oni ebe na ọni igọvunọ iFẹlisi, e rue iPọlu na li.  
\v 34 Ọni igọvunọ ọ zẹ oni ebe, ọ mhila iPọlu ukiẹkiẹ obini ọ khi. Abi ọ rọ bhale ya lẹsẹ khi ekẹ iSilisha ọ te bhale,  
\v 35 ọọ, “Mhi ya suọ ẹzọ oyẹ ini eni e gue ẹzọ shi ẹ egbe e ramhi ana.” Ighọ ọ mhẹsẹ a ri iPọlu nga ekhe-khẹ obọ ni e la agbala oyi Erọdu. 
\c 24  
\s1 Ẹzọ ni iPọlu ọ gue odalo oyi iFẹlisi 
\p  
\v 1 Abi ogbẹlẹ ishe e rọ dọsẹ, Ọga ọyi ekpodalo ugamhi ni a lu Ananayasi ọ je iSizeria, lọli ali egbhali eghuo ali ilọya ni a lu iTatulọsi. E bhale odalo oyi igọvunọ ni a lu iFẹlisi ni e ya gue ẹzọ shi iPọlu egbe.  
\v 2 Abi a rọ lu iPọlu bhale, iTatulọsi ọ gue ẹzọ oyọli shi ekẹ khasẹ iFẹlisi: Ọọ, “Irẹloe-khu oyẹ o she ri anye mhọli opfọmhẹ ali emhi enegbọ ukhomhi ekẹ ona.  
\v 3 Ashakhasha ali odẹkhodẹ anye te ẹ kuẹghiẹ ẹ, anye ẹ nono ni anye kphẹmhi nẹ shi ona, yẹyẹ iFẹlisi oghie.  
\v 4 Ini anye khi pfuse ẹ ẹghẹghẹ-a, mhi lema ẹ u kpẹkpẹ u ku esọ-a shi anye ekẹ ukuku ẹghẹghẹ. 
\p  
\v 5 “Eri anye mẹ ọmọse ọna shi ọgbọ ingme, ni ọ tsua okhọli ẹ lasele ke tanọ ẹgbọ iJu ni e la ekẹ agbọ nya, e ke pfi onyaghu ali umha-suesọ. Lọli ọ ralo na ẹgbọ otu iNazarini  
\v 6 Ọ gbolo o nono ni lọli ri ichimhi mu Owa oyi Ẹshinẹgba, lọli anye rọ gba li mu. [Anye e nono ni anye gue ọli ẹzọ abi ushi oyanye o ngme.  
\v 7 Ama iLisiasi ọni ọ mhẹsẹ na ekhọli-okhuẹ, ọ bhale ya ri itoto ti anye luẹ abọ mie rue vu.  
\v 8 Ọọ eni e mẹ umha-guẹli oyi ọmọse ọna e bhale odalo oyẹ.] Ini u mhila ọmọse onana ogbọ u ya mẹ igẹsikia ni o la ẹzọ ni anye gue shi ọli egbe ena.” 
\p  
\v 9 Eni ẹgbọ iJu ni e la aghọ e kugbe lama shi ẹzọ ni a gue shi ekẹ, khi igẹsikia lọ. 
\p  
\v 10 Abi ọni igọvunọ ọ ri obọ nu iPọlu ngme ọ gue shi ọli ọ. 
\p IPọlu ọọ, “Mhi lẹsẹ khi ikpe ni e bu u te la ukhomhi ẹoli ona a sọ ẹzọ, itobọ ona egbe ẹ mu mhẹ ni mhi rọ migha odalo oyẹ ya gue ẹzọ pfa egbemhẹ shi ekẹ.  
\v 11 Abi u kie kpẹ lẹsẹ, amo o gbe ẹlẹ igbẹva ni mhi rọ je iJerusalẹmu ni mhi ya ga ugamhi.  
\v 12 Ẹgbọ iJu ni e gue ẹzọ shi mhẹ egbe ẹa bhale ya ẹ mhẹ shi elemhi Owa Oyi Ẹshinẹgba khi mhi nu ọgbọkhọghuo ẹ khẹ akọ, wẹkhi eri mhi la owa ugamhi, wẹkhi ifuapfẹ ashikhọghuo tanọ ebubu ẹgbọ abọ shi onyaghu.  
\v 13 Ẹa mhọli abi e li dobẹ rọ ya migha pfi ọtsẹlẹ shi ẹzọ ni e gue shi mhẹ egbe khi igẹsikia lọ.  
\v 14 Mhi lama shi ọ khi, eri mhia ga Ẹshinẹgba ọyi eni e bia awa, mhi khi ọni ọ rọte oni Odẹ ona, ni ẹẹ khi ẹgbhọli o khi. Ama mhi mie shi Ushi oyi iMosisi ali emini a kẹkẹ shi ebe eyi emekẹguele.  
\v 15 Mhi miesuọ abi ẹgbọ enana e li miesuọ, khi Ẹshinẹgba ọ ya rọte eghuli guise ọgbọ nya le, ghe eni e guẹ ngeli ghe ena ọkhọlọ.  
\v 16 Irarighọ mhi rọ rọshẹka, emini mhia riẹlẹ nya, ini udu ni ọọ gue ọgbọ ẹzọ oyẹmhẹ o pfuasẹ shi odalo oyi Ẹshinẹgba ali ọgbọ. 
\p  
\v 17 “O she gba ikpe eni e bu abi mhi te lase ẹoli iJerusalẹmu le. Eri mhi jele aghọ ni mhi ya rue ikpaghọ ghi ẹgbọ ni ẹa mhuẹ ali ni mhi ri isomhopfa ghi Ẹshinẹgba.  
\v 18 Emini mhii riẹlẹ na ni e rọ bhale ya ẹ mhẹ shi Owa oyi Ẹshinẹgba abi mhi la ipfuasẹ abi ushi o ngme. Ẹgbọ ekhọghuo ẹa le gasẹ mhẹ, wẹkhi eri a mẹ onyaghu.\f + \fr 24:18 \ft Li zẹ \fq Ika 21.17-28\f* 
\v 19 Ama ẹgbọ iJu eghuo ni ẹ rọte ekẹ Esha bhale e ga li la akaghọ. E kha bhale odalo oyẹ ẹ ya gue ẹzọ oyẹwẹ, ini e mhọli emini e ya gue shi mhẹ egbe.  
\v 20 Okekhi emọse ni e la akana ena, a mhila wẹ e guele umhaguẹli ni e gue shi mhẹ egbe abi a rọ rue mhẹ bhale odalo iSaẹdiri.  
\v 21 Ama emhi oghuo mhi la akpẹwẹ tsẹsẹ ngme khi, ‘Eri a gue mhẹ ẹzọ itobọ khi mhi mie shọ khi eni e ghu-a e ya gbo guale bhale agbọ.’ ”\f + \fr 24:21 \ft Li zẹ \fq Ika 23.6\f* 
\p  
\v 22 Ighọ iFẹlisi ni ọ ga lolo lẹsẹ emhi oni Odẹ ona, ọọ, a yẹmhẹ oni ẹzọ-a ne. Ọọ, “Ini iLisiasi ọni ọ mhẹsẹ na ekhọli-okhuẹ ọ da bhale mhi rọ ya sọ ẹ oni ingme.”  
\v 23 Ọ gueyẹ ọga ekhọli-okhuẹ ọghọ ọ lolo ri ẹloe shi iPọlu egbe, ama e zẹ ọli pfi ẹfo-a ukukuọ. E zẹ ni emọle ọli e ke bhale ya tsẹ ọli ali ni e ke ri emini ọ nono bhale ghi ọli. 
\s1 IPọlu ọ bhale odalo oyi iFẹlisi ali iDurusila 
\p  
\v 24 Abi ikuku ogbẹlẹ e rọ dọsẹ se, iFẹlisi ọ tsua ughuẹ ọli ni a lu iDurusila ni ọ khi ọngi iJu ma egbe bhale. Ọ ghie ya lu iPọlu, ọ ri esọ shi ekẹ suọ abi iPọlu ọ li ngme ungmemhi irudunga ni o la iJesu iKirisiti.  
\v 25 Ama abi iPọlu ọ li ngme ungmemhi iguẹ-ngeli, ali ikuegbe-a ali isọ-ẹzọ oyi Ẹshinẹgba ni ọ bhale, ulishi oo mu iFẹlisi, ọọ, “Osomhi ghọ ne! Ke vu. Mhi ya ghie lu ẹ ini mhi ke mẹ asha.”  
\v 26 Oni ẹghẹghẹ ọ dabi khi iPọlu ọ ya vi ufa na luẹ, itobọ ighọ ọ rọ kẹlẹ ẹ ghie lu ọli, ọ́ bhale ni wẹwẹ e ngme.  
\v 27 Abi ikpe eva e rọ dọsẹ, iPọshusi iFẹsitọsi ọ ke khi igọvunọ ni iFẹlisi ọ kpẹ khi. Ama itobọ khi iFẹlisi ọ nono ni lọli guẹ riẹlẹ ti ẹgbọ iJu ẹloe, ọ zẹ iPọlu obọ shi owa ighumha. 
\c 25  
\s1 IPọlu ọ bhale odalo oyi iFẹsitọsi 
\p  
\v 1 A liẹ amo o li ẹlẹ esẹ abi iFẹsitọsi ọ te khi igọvunọ, ọ rọte ẹoli iSizeria nga ẹoli iJerusalẹmu.  
\v 2 Oobọ ighie eyi ekpodalo-ugamhi ali enighie eyi ẹgbọ iJu e la gue ẹzọ shi iPọlu egbe.  
\v 3 E nyanya lema iFẹsitọsi ọ rue iPọlu je iJerusalẹmu ni ọ rọli kpaghiẹ ẹwẹ obọ. Irari khi e she gba khi ẹwẹ e ya kpẹ odẹ gbe iPọlu-a ini ẹẹ lẹ.  
\v 4 IFẹsitọsi ọọ wẹ, “A she ri iPọlu shi owa ighumha obini ẹoli iSizeria, mhẹmhẹ mhi ya nyenẹ egbe kẹlẹ je oobọ.  
\v 5 A zẹ ni eni ẹẹ ralo na ẹ e deba mhẹ je iSizeria ya gue ẹzọ shi ọni ọmọse egbe, ini o khia khi eri ọ lue.” 
\p  
\v 6 Ogbẹlẹ elele ya ramhi ogbẹlẹ igbe iFẹsitọsi ọ nu wẹ la aghọ, ni ọ rọ kia tiemhi ẹoli iSizeria. Ogbeakọlọ ọ khueghie ikọtu-a, ọọ a rue iPọlu bhale odalo oyẹluẹ.  
\v 7 Abi iPọlu ọ rọ bhale, ẹgbọ iJu ni e rọte iJerusalẹmu bhale e migha gasẹ ọli, e gue ẹzọ ni o toto shi ọli egbe, ama ẹa dobẹ to eni ẹzọ migha. 
\p  
\v 8 Ama iPọlu ọ gue ẹzọ pfa egbọli shi ekẹ, ọọ, “Mhi aa riẹlẹ emhikhọghuo ni o da ushi oyi ẹgbọ iJu, wẹkhi Owa Oyi Ẹshinẹgba, wẹkhi eri mhi lue na iSiza iRomu.” 
\p  
\v 9 Ama iFẹsitọsi ọ nono ni lọli riẹlẹ ọghuẹmhẹ oyi ẹgbọ iJu, ighọ ọ mhila iPọlu, “O ghọle ẹ ni a rue ẹ je iJerusalẹmu, ni a la aghọ gue ẹzọ oyẹ ukpẹloe mhẹ?” 
\p  
\v 10 IPọlu ọọ, “Iiye. Ikọtu oyi iSiza ni a kha mema la gue ẹzọ oyẹmhẹ mhi la ena. Mhi aa mhọli onobe ni mhi li ẹgbọ iJu ni yẹyẹ u lẹsẹ gboo.  
\v 11 Ini o khia khi mhi lue nabi a gbe ọgbọ-a shi, mhi mu egbe ni mhi rọ ya ghua. Ama o kha da khia khi ẹzọ ni ẹgbọ iJu ena e gue ẹ shi mhẹ egbe khi ẹgbhọli lọ, ọgbọkhọghuo ọa dobẹ ya rue mhẹ na wẹ. Irarighọ, mhi lema a zẹ ni iSiza luẹghuo ọ rẹmhẹ gue oni ẹzọ ona.” 
\p  
\v 12 IFẹsitọsi ọ ri eni e nu ọli ẹ sọ ẹzọ ye ochi se, ọọ iPọlu, “U she lema a rue ẹzọ ona je ayi iSiza ya gue, ayi iSiza u mema ya je.” 
\s1 IPọlu ọ migha odalo oyi Agiripa ali iBẹnisi 
\p  
\v 13 Ogbẹlẹ ingmẹ-na e dọsẹ, oghie Agiripa ali iBẹnisi e bhale ekẹ iSizeria ni e ya tsẹ iFẹsitọsi.  
\v 14 Aborọkhia khi e la akaghọ ogbẹlẹ ebubu, iFẹsitọsi ọ gue ingme oyi iPọlu yẹ oni oghie, ọọ, “Ọmọse ọghuo ọ la owa ighumha shi ana ni iFẹlisi ni ọ kpẹ khi igọvunọ ọ zẹ obọ shi aghọ.  
\v 15 Abi mhi rọ ye iJerusalẹmu, ighie eyi ekpodalo-ugamhi ali egbhali eyi ẹgbọ iJu e tsua ẹzọ bhale ya gue shi ọli egbe, ẹẹ mhi pfa ẹzọ igbe-a mu ọli. 
\p  
\v 16 “Ama mhi gueyẹ wẹ khi awa ẹgbọ iRomu awa aa ya pfa ẹzọ mu ọgbọ ni a gue ẹzọ shi egbe, ini ọgbọ a ri ẹghẹghẹ nali gue shi ẹzọ ni a gue shi ọli egbe ne.  
\v 17 Abi e rọ deba mhẹ bhale ana, mhi nyanya shi oni ẹzọ shi ogbeakọlọ, mhi shitọ elemhi ikọtu, mhiẹ a lu ọni ọmọse bhale.  
\v 18 Abi eni ẹẹ gue ẹzọ shi ọli egbe e rọ vule ngme, ẹa gue ẹzọ umhaguẹli ni mhi dabi khi e ya gue.  
\v 19 Ochoghọ ẹzọ ekhakọ tsẹ e lẹsẹ mẹ gue shi ọli egbe, ni o khi ingme oyi ugamhi oyẹwẹ, ali ekhakọ ni o khi ingme oyi ọmọse ni a lu iJesu, ni ọ ghua, ni iPọlu ọ khi ọ kie la agbọ.  
\v 20 Mhi aa lẹsẹ abi mhi li ya tọnọ udi oni ingme onana. Mhi ri irarighọ mhila li ini ọ nono ni a rue oli je iJerusalẹmu ya gue eni ẹzọ ni a gue ẹ shi ọli egbe enana, oobọ.  
\v 21 Ama iPọlu ọ lema a kie mu luẹ shi igha ne, ni a ri oni ingme ghi iSiza ni ọ sọ ọ. Irarighọ mhi rọ liẹ a rọ ọli shi owa ighumha ramhi ni mhi rọ ya rue ọli ghi iSiza.” 
\p  
\v 22 Ighọ Agiripa ọ gueyẹ iFẹsitọsi, ọọ li, “Mhi kha nono ni mhẹmhẹ-ghuo ni mhi li ri esọ suọ ungmemhi oyi ọni ọmọse.” IFẹsitọsi ọọ li, “U ya suọ ọli akọ.” 
\p  
\v 23 Ogbeakọlọ, a ri ebọla kphase Agiripa ali iBẹnisi lo elemhi ikọtu le. Ega ekhọli-okhuẹ ni e lolo fu, ali ẹgbọ eniẹmhi ni e la oni ẹoli e deba li lo. IFẹsitọsi ọ ghie ya rue iPọlu bhale.  
\v 24 IFẹsitọsi ọọ, “oghie Agiripa ali ẹgbọ ni e la ana nya, a bino ọmọse ọna. Ẹgbọ iJu ni e la ana ali iJerusalẹmu ali iSizeria e she bhale deba mhẹ, ẹẹ tsẹsẹ a khi ke zẹ ni ọ la agbọ.  
\v 25 Mhi mẹ khi ọa li emhikhọghuo onabi a ya gbe ọli-a shi, ama abi ọ rọ da lema a rue luẹ ghi Oghie iRomu nya eghọ, mhi ya rue ọli je iRomu.  
\v 26 Ama mhi aa mẹ ingme nabi mhi kha kẹkẹ shi ọli egbe ghi Oghie iRomu nya. Irarighọ, mhi rọ rue ọli bhale ghi ẹ ẹẹ nya, yẹyẹ oghie Agiripa kpaashi, ni a bhale ya ẹ khi ini a bino oni ingme se, otsẹ mhi ya mẹ emini mhi ya kẹkẹ shi ọli egbe.  
\v 27 Irari khi mhia sa khi o gbe akanya ni a rọ rue ọni a mu shi igha ke ghi Oghie iRomu nya, ini aa mẹ ushi okhọghuo kẹkẹ shi ọli egbe gboo.” 
\c 26  
\s1 IPọlu ọ pfa egbọli shi ekẹ odalo Agiripa 
\p  
\v 1 Ighọ Agiripa ọọ iPọlu, “A she lama nẹ u ngme na egbe ẹ.” Ighọ iPọlu ọ tsua obọ ekẹ, ọ bẹlẹ ẹ gue ẹzọ, ọọ,  
\v 2 “Agiripa ni oghie, mhi mẹ egbe mhẹ shi ọni ọ mẹ afa ni mhi rọ migha odalo oyẹ amo, ni mhi rọ ọ gue ẹzọ pfa egbe mhẹ shi ekẹ shi ingme nya ni ẹgbọ iJu e gue shi mhẹ egbe.  
\v 3 Oo guẹ ti gba irari khi u ga lẹsẹ imu eyi ẹgbọ iJu nya ali emini e mie shi. Irarighọ, mhi lolo lemẹ u mhọli irabọmudu na mhẹ ni mhi ngme. 
\p  
\v 4 “Ẹgbọ iJu nya e lẹsẹ abi mhi laọ shi abi mhi te khi ọmọ, rọte igbaekẹle agbọ oyẹmhẹ obini ushishi ẹgbọ iJu eyẹmhẹ ali ẹoli iJerusalẹmu.  
\v 5 Odẹ o she nuẹ ni e te lẹsẹ mhẹ, e ya dobẹ pfi ọtsẹlẹ shi ọ ini o ghọle wẹ, khi abi ugamhi oyawa o ngme khi eri mhi mhọli ọmuegbe egbegbọ shi ọ abi ọna otu iFarisi ni mhi khi.\f + \fr 26:5 \ft Li zẹ \fq Ika 23.6; iFili 3.5\f* 
\v 6 Ama mena, itobọ khi mhi mhọli iregbeda shi emini Ẹshinẹgba ọ shi na itita awa mhi rọ migha shi imufẹ amo.  
\v 7 Ona o khi ishobọ ni unuẹkpẹ igbẹva eyawa e migha a khẹ, abi e li rọshẹka a ga Ẹshinẹgba ghe ẹlẹọguota ali ẹlẹ iyọsẹ. Oghie, irari oni iregbeda onana ẹgbọ iJu e gue ẹzọ shi mhẹ egbe ẹ shi.  
\v 8 Elọ e zẹ ni a rọ lama shiọ khi Ẹshinẹgba ọ dobẹ ẹ guise ọni ọ ghu-a le? 
\p  
\v 9 “Mhẹmhẹ mhi kpẹ mhọli ọli shi udu khi eri o ye ni mhi mu okhọli vule shi oni eva oyi iJesu ọngi iNazarẹti ọ.  
\v 10 Ighọ mhi li i riẹlẹ ọli obini ẹoli iJerusalẹmu. Irari afu ni ọga ọyi ekpodalo ugamhi eyi Ẹshinẹgba ọ rọ na mhẹ, mhi muno ebubu eni e miesuọ shi owa ighumha, abi a rọ ọ gbolo wẹ-a, mhii mie obọ shi ọ.  
\v 11 Ebubu ẹghẹghẹ mhi te owa ugamhi je owa ugamhi ya nasẹ wẹ, mhi gbolo ri ajilimhẹ rẹwẹ ngme ungmemhi ipfiunu-a deba Ẹshinẹgba. Irari elemhi wẹ ni e bi mhẹ. Mhi gbolo je ẹoli oboese ya mu okhọli vule shi wẹ ọ.\f + \fr 26:11 \ft Li zẹ \fq Ika 8.3; 22.4-5\f* 
\s1 IPọlu ọ guele abi lọli li mupfi 
\r (Ika 9.1-19; 22.6-16) 
\p  
\v 12 “Ẹlẹghuo mhi i lẹ ẹoli iDamasikọsi, rọte afu ali omhẹsẹ ni ọga ọyi ekpodalo ugamhi eyi Ẹshinẹgba ọ rọ na mhẹ.  
\v 13 Itsotso ọguota o mu ekẹ, oghie, abi mhi la odẹ, mhi mẹ khi ákpá ni o gẹ dọsẹ ovọ o rọte idane mi gasẹ mhẹ ali eni anye ga kia.  
\v 14 Anye nya, anye de ekẹ, ighọ mhi suọ khi uruli o nu mhẹ ngme ẹlẹmhi Iburu, ọọ, ‘ISọlu, iSọlu, elọ o zẹ ni u rọ mu okhọli vule ẹ shi mhẹ ọ, ọọyẹghẹ wa li ini u nu mhẹ ẹ khọli.’ 
\p  
\v 15 “Ighọ mhi mhila, ‘Ọghuo u khi Ọnọmhuẹ?’ 
\p “Ọọ mhẹ, ‘Mhẹmhẹ iJesu lọ ni u mu okhọli vule shi ọ.’  
\v 16 ‘Memena, vule migha. Mhi she ri egbe mhẹ khasẹ irari khi mhi she zẹ shi ọni ọọ ga mhẹ ali ni u ke pfi ọtsẹlẹ ọyẹmhẹ shi emini u ri ukpẹloe oyẹ mhẹ, ali emini mhi ya rọkhasẹ okhẹse.  
\v 17 Mhi ya tsumhi ẹ obọ oyi ẹgbọ eyẹ ali obọ oyi ẹgbọ iJẹta. Mhi ghie ẹ ghi wẹ,  
\v 18 ni u khueghie wẹ alo-a, ni u mu wẹ pfi lase alo ebili le bhale ákpá, ali u rue wẹ ekpabọ eyi ọkphaghiẹ lasele bhale deba Ẹshinẹgba, ni a gbe olamhẹ kua na wẹ, ali ni e kugbe ẹgbọ eyi Ẹshinẹgba eni e pfuasẹ ọ, itobọ irudunga ni e mhọli na mhẹ.’ 
\p  
\v 19 “Irarighọ, oghie Agiripa, mhia rọ ri ukpẹloe gbe ekẹ ni mhi rọte iloghie mẹ.  
\v 20 Mhi kpẹ te ododẹ gue ọli yẹ ẹgbọ iDamasikọsi, mhi ke gbo gue ọli yẹ ẹgbọ iJerusalẹmu ali ẹgbọ ni e la ekẹ iJudia nya ali ẹgbọ iJẹta. Mhi rọli tse abọ, e lase olamhẹ le ni e mupfi deba Ẹshinẹgba, e rọkhasẹ khi wẹwẹ e she mu nyenẹ rọte ikanya ebe eyẹwẹ lasele.\f + \fr 26:20 \ft Li zẹ \fq Ika 9.20,28-29\f* 
\v 21 Ona o zẹ ni ẹgbọ iJu e rọ bamhẹ rue Owa Oyi Ẹshinẹgba ni e rọ rọshẹka ini wẹwẹ e gbe mhẹ-a.  
\v 22 Ama mhi she mhọli ikpaghiobọ oyi Ẹshinẹgba ramhi ogbe na amo, ali mena mhi migha akana a pfi ọtsẹlẹ ye ọgbọ ọnọfunẹ ali ọnikeke abeghuo. Mhi aa ngme dọsẹ emini emekẹguele ali iMosisi ẹ khi a ya mẹ,  
\v 23 khi ọni Ọmiepfuese ni a shobọ khi ọọ bhale ọ ya mẹ osue, ali khi lọli ni ọ kpẹ te ododẹ rọte eghuli guale khi ọ ya ri ákpá ru na ẹgbọ eyọli ali ẹgbọ iJẹta.”\f + \fr 26:23 \ft Li zẹ \fq Aza 42.6; 49.6; 1 iKọri 15.20\f* 
\v 24 Abi iPọlu ọ rọ ngme ramhi ana, iFẹsitọsi ọ mu ọli migha, ọọ li, “Eri waa ke lẹsẹ emini u wa li? Ebe ni u zẹ dọsẹ e she ri ujili ẹ kphẹ.” 
\p  
\v 25 IPọlu ọọ li, “Ujili ọa kpha mhẹ, iFẹsitọsi ọgbẹgbẹdu, emini mhia ngme egbegbingme lọ ni o tsua ẹgbhali.  
\v 26 Oghie Agiripa ọ ga lẹsẹ eni ingme enana nya, emhikhọghuo ena, ẹa lase ọli ẹgbhali-a irari khi aa riẹlẹ wẹ osheli. Ona o zẹ khi mhi ga dobẹ nu ọli a ngme oni ingme ona gboo.  
\v 27 Oghie Agiripa, u fẹ mieshi emini emekẹguele e ngme? Mhi lẹsẹ khi u mie shọ ọ.” 
\p  
\v 28 Ighọ Agiripa ọọ iPọlu, “Eri u dabi khi u dobẹ ya ri oni ukuku ẹghẹghẹ ona ti mhẹ ni u rẹmhẹ mele ọni ọ miesuọ-a?”  
\v 29 IPọlu ọọ li, “O kẹlẹ, o tẹsẹ oo, mhi lema Ẹshinẹgba o khi khi yẹyẹ-ghuo tsẹ, ama li shi ọgbọkpa ni ọ ri esọ shi mhẹ ekẹ ogbenamo, ni e li abi mhi li, ini a da ri obọ rue iwẹghẹ ni e lamhẹ abọ ena ọ le.” 
\p  
\v 30 Ighọ ọni oghie ọ vule, li shi ọni igọvunọ ali iBẹnisi ali eni e nu wẹ shitọ.  
\v 31 E rọte oni agbala vu, ee ngme, ẹẹ, “Ọmọse ona ọa li ingme ni a ya gbe ọli-a shi wẹkhi oni a rọ ọ mu ọli shi owa ighumha.” 
\p  
\v 32 Agiripa ọọ iFẹsitọsi, “Áá kha wolọ ọmọse ọna abọ-a ini ọa she lema a ri oni ingme je ayi iSiza lọ.” 
\c 27  
\s1 A rue iPọlu je iRomu 
\p  
\v 1 Abi e rọ lama shi ọ, anye lo ọkọ-okẹ oniẹmhi je Itili, e rue iPọlu ali ighumha ni e kpọle mhọli obọ oyi ọga ekhọli-okhuẹ ni a lu iJuliọsi, ni ọ khi ọghuo ọyi ekhọli-okhuẹ eyi Oghie iRomu nya, ni a zẹ ọda kẹ.  
\v 2 Anye lo ọkọ-okẹ oniẹmhi rọte Adiramitiọmu, ikhi ọkọ-okẹ ni o ya kia migha ikpe eghuo ni ọkọ-okẹ ẹẹ migha, ni e la epfepfẹ okẹ ni e la ekẹ Esha. Arisitakusi ni ọ khi ọngi iMasidonia ọ nu anye kia. 
\p  
\v 3 Ogbeakọlọ anye migha iSidọni. IJuliọsi ọ mhọli isomhelemhi na iPọlu, ọ zẹ ọli obọ ya mẹ emọle ọli, ni e ri emini ọọ nono na li.  
\v 4 Anye ke gbo rọte aghọ mu oni ọkọ nga, anye rọte odane ukiẹkiẹ ekẹ ni okẹ oniẹmhi o khi shi ni a lu iSapurọsi irari khi akpekpeli oo nasẹ anye.  
\v 5 Abi anye rọ gua ọkọ ọ da je ọdada iSilisha ali iPafilia, anye migha ẹoli iMara na ekẹ iLisia.  
\v 6 Aghọ ọni ọga ekhọli-okhuẹ ọ te mẹ ọkọ-okẹ oniẹmhi oyi ẹoli Alẹzadira ni oo je Itili, ọ ri anye lo ọ.  
\v 7 Anye e kia fiẹ, ogbẹlẹ ebubu, anye mhọli ọmunu neni anye ramhi iKinidusi. Abi akpekpeli ọa rọ zẹ anye rọte ashini anye kha rọte, anye gua ọkọ-okẹ je ukiẹkiẹ ekẹ ni okẹ oniẹmhi o khi shi iKirẹti ni o sọ alo ghue ẹoli iSalimọ.  
\v 8 Anye mhọli ọmunu rọte oni okẹ oniẹmhi. Ikpukhokho, anye bhale ashini ọkọ-okẹ ẹẹ migha ni a lui ọpfọmhẹgbe ni o ti mama ẹoli iLasia. 
\p  
\v 9 Ẹghẹghẹ o she pfu anye-a. Oni okiali o de shi ẹghẹghẹ ni a rọ lẹsẹ pfi azumhi se, ni o khi ẹghẹghẹ ni okhẹna o la la okiali na ukhomhi okẹ oniẹmhi. Ighọ iPọlu ọ tse agua ye wẹ, ọọ wẹ,  
\v 10 “Emọse, mhi she mẹ khi okiali oyawa o ya khi okhẹna ali khi o ya ri ukpokpomhi opfu ghi oni ọkọ ali itsua ni o tsua ali agbọ oyawa.”  
\v 11 Ama, ocho ni ọni ọga ekhọli-okhuẹ ọ kha rọ ri esọ shi emini iPọlu ọ ngme, ọ deba abi ọni ọ gua oni ọkọ ọ ngme ali emini ọni ọ mhọli oni ọkọ ọ ngme.  
\v 12 Aborọkhia khi ashini anye migha ọa ya ti egbe ẹghẹghẹ oruẹ; ebubu ẹgbọ e yemhẹ anye gua ke lẹ, e dabi khi anye ya ramhi ẹoli iFonisi, ni anye la aghọ ẹghẹghẹ oruẹ. Aghọ ọkọ okẹ eniẹmhi nya ẹẹ migha yẹmhẹ-a. Ekẹ ni okẹ oniẹmhi o khishi ni a lu iKirẹti ni ọ sọ alo ghue obini ovọ o te ẹ lo eko o khi.\fig Abi iPọlu ọ li ye iRomu|src="ATG Paul4-BW.ai" size="span" loc="ACT 27.1--28.14" ref="27.1--28.14" \fig* 
\s1 Akpekpeli oniẹmhi 
\p  
\v 13 Abi akpekpeli okẹ o rọ ri ọfiẹ rọte ukiẹkiẹ ọgobọ ọ pfiolo, eni emọse e dabi khi okiali o ya zẹ wẹ kia ke je odalo, ighọ e leli uli ali akhuli ni a rọ gba ọkọ ọọ zu. Ee kia esesọ oni okẹ oniẹmhi na iKirẹti.  
\v 14 Ama o li dẹnẹ, akpekpeli oniẹmhi, o li rọte ukiẹkiẹ obita ini a sọ alo ghue obini ovọ o te ẹ tiemhi eko pfiolo rọte oni ekẹ ni o la iteva okẹ oniẹmhi i dọsẹ.  
\v 15 Oni akpekpeli o tsua rughu ọkọ-okẹ oyanye, ọa dobẹ ke kia je obini akpekpeli o te pfiolo o bhale. O lọsẹ anye. Anye bie zẹ ọli obọ na akpekpeli lọlighuo oo tsua.  
\v 16 Anye kia rọte ukiẹkiẹ ukuku ekẹ ni o la iteva okẹ oniẹmhi ni a lu iKauda, ikhi ukiẹkiẹ obini oni akpekpeli ọa ri egbe ramhi. Irọshẹka anye rọ dobẹ tialọ ọkọ onikeke ni a rọ ọ tsumhi ẹgbọ lo elemhi oni ọkọ-okẹ oniẹmhi.  
\v 17 Abi eni emọse e rọ tialọ li lo se, e ri ili gẹ oni ọkọ-okẹ oniẹmhi gasẹ, ini eni ili e dobẹ mu ọli mhuẹ toto. Irari khi ee na ulishi ini oni ọkọ o ya gbe aye shi ugbe ekẹ, ni o la egele ekẹ iLibiya, ni o sọ alo ghue wẹ. Ighọ e gbaghiẹ ode na kpishi oyi oni ọkọ-a, irari khi ẹa bie ke mhuẹ abi e ya li ọ. Isheghọ ni oni akpekpeli o bie tsua wẹ ke le.  
\v 18 Oni akpekpeli o kie ri itoto tsua oni ọkọ-okẹ ramhi ogbeakọlọ, ramhi ni, eni emọse e rọ tino itsua ni e tsua shi oni ọkọ ọ pfino kulo oni okẹ.  
\v 19 Ogbeakọlọ e pfino ikhuli ni oni ọkọ o rọ ọ gbe akanya kulo oni okẹ.  
\v 20 Aborọkhia khi ogbẹlẹ ebubu ni e dọsẹ khi anye a ri ẹloe ti ovọ wẹkhi ukpẹtata, ni oni akpekpeli o kiele rọ ri itoto o pfiolo, anye a ke ri udu shi ọ khi anye mẹ odẹ ni anye te ya pfue ọ. 
\p  
\v 21 Abi eni emọse ẹa rọ le eminale ogbẹlẹ ebubu, iPọlu ọ vule, ọ wẹ, “Emọse a kha suọ ude ni mhi ye ẹ lọ, a kha migha iKirẹti, Ẹghẹghẹ aghọ, a kha tsumhi egbe ẹ oyese onana ali opfu.  
\v 22 Ama mena mhi gueyẹ ẹ a mhọli udu, itobọ khi ọngẹẹ ọkhọghuo ọa ya pfua sẹ ni oni ọkọ.  
\v 23 Ooyọsẹ agẹni ọyi Ẹshinẹgba ni ọ mhọli mhẹ ali ni mhi a ga ọ migha mama mhẹ,  
\v 24 ọọ mhẹ, ‘Khi zẹ ni ulishi o muẹ, iPọlu. U mema ya migha ẹzọ odalo oyi iSiza ali khi Ẹshinẹgba ọ she rọte ilẹlemhi ri agbọ oyi eni a ga kia mhọli ẹ obọ.’  
\v 25 Irarighọ, a mu igbedu oyẹ mhọli, emọse, irari khi mhi mhuẹ irudunga khi Ẹshinẹgba ọ ya riẹlẹ ọli abi ọ gueyẹ mhẹ.  
\v 26 Ama ọkọ oyawa o mema ya gbe aye shi ugbe ekẹ okhọghuo ni o la iteva okẹ oniẹmhi, o tigbe migha.” 
\s1 Oni ọkọ o de ya khẹrẹ-a 
\p  
\v 27 Ẹliyọsẹ ẹlẹnuzi-igbẹne, akpekpeli o kie tsua anye e kiakia okẹ oniẹmhi Adiriatiki. Itsotso ogbiẹ, o li eni ẹẹ gbe akanya oni ọkọ ẹloe abinẹ khi e she ti ẹ mama ekẹ.  
\v 28 E mhẹsẹ oni okẹ bino, e mẹ khi ilimhi oyọli o khi ẹtẹ-awẹ egbhuẹsesa. O gbo li dẹnẹ, e gbo mhẹsẹ ọli, o ke khi ẹtẹ-awẹ egbhuẹne ali igbe.  
\v 29 Ulishi o mu wẹ khi oni ọkọ o ya gbe aye shi echẹ, e rọte ukhokho pfi ikhuli ene ni a rọ a mu ọkọ ọ gbashi lo oni okẹ oniẹmhi, ee sọ iromhi ogbe o gbe a. 
\p  
\v 30 Eni e la oni ọkọ ọ gbe akanya e dua abi e li mẹ asha a na kua. Ee tiese ukuku ọkọ ni e tialọ lole eghọ nga okẹ oniẹmhi, abinẹ khi eri e nono ni e rọte odalo ya pfi ikhuli lo okẹ oniẹmhi.  
\v 31 Ama iPọlu ọọ ọni ọga ekhọli-okhuẹ ali eni ekhọli-okhuẹ, “Ini emọse enana ẹa li la elemhi oni ọkọ, ọngẹẹ, ọa ya pfue ọ.”  
\v 32 Ighọ eni ekhọli-okhuẹ e pfa uli ni o mu oni ọkọ onikeke mhuẹ-a. E zẹ ọli de tiemhi elemhi okẹ. 
\p  
\v 33 Neni ogbe o maghiẹ-a, iPọlu ọ lema wẹ nya e le eminale. Ọọ wẹ, “O she ramhi ogbẹlẹ igbẹne ni udu ọa ke te sheshe ẹ, ni a le eminale kpẹ.  
\v 34 Mena mhia lema ẹ, a le eminale. A lemhi ini a nono ni a kie dobẹ la agbọ, A lemhi khi emhikhọghuo ọa ya li ọngẹẹ.”  
\v 35 Abi ọ rọ ngme na se, ọ rue ibulẹdi lasele, o kphẹmhi na Ẹshinẹgba ukpẹloe wẹ nya, ọ khi ọli-a, ọọ le.  
\v 36 Wẹwẹ nya e mhọli udu, e le eminale.  
\v 37 Anye nya ni anye la oni ọkọ, ẹgbọ egbhuẹgbẹsẹ ali ogbasasa 276 anye khi.  
\v 38 Abi e rọ ga le eminale se abi e nono, e tino ikpulu ikpamhi emhi ni e tsua kulo okẹ oniẹmhi, ini oni ọkọ o kpẹ li fuẹ. 
\s1 Oni ọkọ okẹ oniẹmhi ọ kuluẹ 
\p  
\v 39 Abi ogbe o rọ gbe-a se, eni ẹẹ gua oni ọkọ ẹa ke lẹsẹ egele okẹ oniẹmhi bie, ama e mẹ ashini ekhashẹ e kpi gbili shi. Aghọ e ke bie rọli shi udu khi wẹwẹ e ya gua oni ọkọ ya migha ini o zẹ wẹ ẹ riẹlẹ.  
\v 40 Ighọ e pfanọ eni ili ni e mu ukpokpomhi akhuli ni o mu ọkọ-okẹ oniẹmhi ẹ gbashi kulo udi okẹ oniẹmhi. Ẹghẹghẹ aghọ e taghiẹ uli ni a rọ mu emini a rọ mu oni ọkọ ukhomhi ẹ nyenẹ-a. E taghiẹ ugbakpi oyi oni ọkọ-a nga idane, ni e dobẹ ramhi ashini e nono.  
\v 41 Ama oni ọkọ-okẹ o ya tọ aye sọ ugbe ekẹ ni o la elemhi okẹ oniẹmhi, o migha, akpekpeli o kie ri itoto o li, o tsẹkẹ udi oni ọkọ-a. 
\p  
\v 42 Eni ekhọli-okhuẹ ee gba abi e li ya gbolo eni ighumha nya a, ini e ya gua okẹ ramhi egele ni e na vu.  
\v 43 Ama ọni ọga ekhọli-okhuẹ, ọọ nono abi lọli li ya tsumhi iPọlu, ọa zẹ wẹ riẹlẹ emini e gba. Ochoghọ ọ gueyẹ eni e guẹ ẹ gua okẹ e kpẹ danọ kulo okẹ ni e ramhi egele.  
\v 44 Eni e kpọle nya e mu ikiẹkiẹ ẹẹra mhuẹ okekhi izaga oyi oni ọkọ-okẹ. Ighọ wẹwẹ nya e ramhi ekẹkhẹ emhikhọghuo ọa li wẹ. 
\c 28  
\s1 Ekẹ ni a lui iMọta 
\p  
\v 1 Abi anye rọ ri ẹpfua-ẹpfua ramhi egele se, anye bhale ya ẹ khi iMọta a lu oni ekẹ ni o la iteva okẹ oniẹmhi.  
\v 2 Ẹgbọ ni e ngeli oni ekẹ e somhelemhi anye odẹ ni anye aa sa shi. E pfi avuerẹ rọ mu anye epfẹse irari khi eri amẹ oo ruẹ, ogbe o pfọ.  
\v 3 IPọlu ọ ya nu iguagha ẹẹra, ọ rẹwẹ kpẹ eni erali, ighọ ẹnyẹ afue ọ te eni iguagha lasele ya tsakọ shi iPọlu obọ, itobọ khi erali e she basẹ ọli.  
\v 4 Abi ẹgbọ ni e la oni ekẹ ee mẹ khi ọni ẹnyẹ ọ ngomhi iPọlu obọ, e gueyẹ egbe, ẹẹ, “Ọmọse ọna, ọgbọ ugbeli ni ọ gbolo ẹgbọ-a ọ fẹ khi memena. Aa mẹ khi abi ọ ririẹ na pfue eghuli okẹ oniẹmhi, odeba oyi iguẹzọ ọa kie zẹ ọli obọ ni ọ la agbọ.”  
\v 5 Ama iPọlu ọ kpishi ọni ẹnyẹ pfilo elemhi erali. Ingomhi ni ọni ẹnyẹ ọ ngomhi ọli, ọa li ọli abikhọghuo.  
\v 6 E migha ri ẹloe shi ekẹ ẹ khẹ abi ọ li ya fumhi, okekhi abi ọ li ya fiagbe ekẹ ghua. Ama abi e rọ khẹ ọli ramhi ni ẹa rọ mẹ khi emhikhọghuo e li ọli, e mu udu pfi, ẹẹ khi olitsa ọ khi. 
\p  
\v 7 Epfẹ-aghọ iPọbiliọsi ni ọ khi ọgbọ igọmẹti oyi oni ekẹ ni okẹ oniẹmhi o khi shi, ọ mhọli apfẹ shi. Ọ rue anye je apfẹ oyọli, ọ fẹli anye epfẹse egbegbọ ogbẹlẹ esẹ.  
\v 8 Ita iPọbiliọsi ọ yẹshi i ghua, iba ali ukpokpomhi elemhi ofu e to ọli. IPọlu ọ lo elemhi owa ya sọ iromhi na li, ọ ri abọ nga li egbe, ọ rọli zẹ.  
\v 9 Abi a rọ mẹ ghọ se, ẹgbọ elese ni e ghua ni e la oni ekẹ ni okẹ oniẹmhi o khishi e bhale, a rẹwẹ zẹ.  
\v 10 Eni ẹgbọ e lolo mu ekpẹ na anye, e somhi anye opfa. Abi anye rọ ya lo ọkọ-okẹ oniẹmhi ke vu, e wọlọ itsua ọdọda ni e to anye na anye. 
\s1 Rọte ẹoli iMọta je iRomu 
\p  
\v 11 Abi o rọ gbe iki esẹ dọsẹ, anye lo ọkọ-okẹ oniẹmhi ni o migha aghọ khẹ ni oruẹ o dọsẹ. Ẹoli Alẹzadira oni ọkọ o te e bhale, isheli itsema iKasito ali iPolukisi a lu oni ọkọ.  
\v 12 Anye ramhi ẹoli iSirakusi, anye la aghọ ẹlẹ esẹ.  
\v 13 Anye rọte aghọ kia okẹ-oniẹmhi ramhi ẹoli iRẹgiumu. Ogbeakọlọ, akpekpeli o rọte ukiẹkiẹ ọgobọ ini a sọ alo ghue obini ovọ o te ẹ lo eko e pfiolo. Ogbẹlẹ onuzi-eva, anye lo ẹoli iPuteoli.  
\v 14 Anye ya ẹ eni e miesuọ ni ẹẹ anye nu wẹwẹ la aghọ elemhi ẹfo uka oghuo. Anye rọte aghọ vu, anye ramhi iRomu. 
\p  
\v 15 Igbaa oyi eni e mie iJesu iKirisiti suọ ni e la iRomu e she suọ khi anye ẹ bhale. Ighọ eni e miesuọ eghuo e bhale ya lu anye odẹ, e kia ramhi Oki Apiọsi ali Owa Esẹ ni a ku ẹ shi. Abi iPọlu ọ rọ mẹ wẹ, ọ tsẹ Ẹshinẹgba uwegbe, o ri udu shi ọli ọ. 
\s1 IPọlu ọ la elemhi iRomu tse abọ 
\p  
\v 16 Abi anye rọ ramhi iRomu, a zẹ ni iPọlu lọlighuo ọ la owa ni o ghọle ọ, a zẹ ọkhọli-okhuẹ ọghuo ọ ri ukpẹloe ke khu ọli. 
\p  
\v 17 Abi o rọ gba ẹlẹ esẹ dọsẹ, iPọlu ọ lu eni e ralo na ẹgbọ iJu shi ilona. Abi e rọ bhale shi oni ilona, ọọ wẹ, “Inyọghuo-mhẹ, mhi aa li ẹgbọ eyawa emhikhọghuo wẹkhi eri mhi gbe ushi ni eni e bia awa, e rọ nga awa obọ-a, ni e rọ la iJerusalẹmu mu mhẹ, rue mhẹ na igọmẹti iRomu.  
\v 18 Abi e rọ gue mhẹ ẹzọ egbe-a se, e nono abi wẹwẹ e liẹ rue mhẹ obọ-a, itobọ khi mhia lue, ni a ya gbe mhẹ-a shi.  
\v 19 Ama abi ẹgbọ iJu ẹa rọ lama shi ọ, lọli mhi rọ lema a tsua oni ẹzọ bhale odalo oyi iSiza. Ọa khi eri mhi mhuẹ emini mhi bhale ya gue shi ẹgbọ eyẹmhẹ egbe.\f + \fr 28:19 \ft Li zẹ \fq Ika 25.11\f* 
\v 20 Onana o zẹ khi mhiẹ a bhale ni awa ngme. Itobọ irudushi ni ẹgbọ iZirẹni e mhọli a rọ ri iwẹghẹ shi mhẹ awẹ ena.” 
\p  
\v 21 Ẹ ọli, “Anye a mẹ ebe okhọghuo ni a kẹkẹ ingme oyẹ shi, rọte ekẹ iJudia bhale, ghi anye, wẹkhi inyọghuo awa ni e rọte oobọ bhale e gue ingme oyẹ okhọghuo ni ọa ti ye anye.  
\v 22 Ama anye ẹ nono ni anye suọ unu oyẹ, itobọ khi ashakpa ẹgbọ e la ngme onobe shi oni otu onogbọ ona.” 
\p  
\v 23 Ighọ e shi ogbẹlẹ na iPọlu. Ebubu ẹgbọ e bhale asha ni iPọlu ọ la oni ogbẹlẹ. Rọte ẹlẹ uzogbe ya ramhi ẹliyọsẹ iPọlu ọ te gue ungmemhi oyi Eghiele oyi Ẹshinẹgba yẹ wẹ. Ọ rọte ebe Ushi oyi iMosisi ali eyi Emekẹguele rọli lo wẹ esọ ini e lama mie iJesu suọ.  
\v 24 Ingmemhi ni ọ ngme e lo ẹgbọ eghuo esọ, ama ẹgbọ eghuo ẹa mie shi ọli ọ.  
\v 25 Ighọ e li nu egbe e khakọ, e vu, abi iPọlu ọ rọ ngme ungmemhi ona ni o kpọli ukhokho unu se ni ọọ, “Ayẹmhẹ-nọ-pfuasẹ ọ she kpẹ rọte unu oyi Azaya ọmekẹguele gueyẹ eni e bia awa: 
\q1  
\v 26 “ ‘Lẹ deba ẹgbọ ena 
\q2 ni u gueyẹ wẹ, 
\q1 “A ya ri esọ shi ekẹ khue, 
\q2 ama ọa ya tigbe lo ẹ esọ, 
\q1 a fẹli ofẹli khue, 
\q2 ama aa mẹ emhikhọghuo.” 
\q1  
\v 27 Udu oyẹwẹ o bi obili-a, 
\q2 esọ eyẹwẹ e zuse, 
\q2 e gbo guese alo. 
\q1 Ini ọa khi ighọ lọ, 
\q2 e kha ri alo eyẹwẹ ke mẹ ekẹ, 
\q1 e ri esọ eyẹwẹ ẹ suọ, 
\q2 udu oyẹwẹ o kha mhọli ilẹsingme, 
\q1 e kha mu pfi bhale deba mhẹ, 
\q2 mhi rẹwẹ ze.’\f + \fr 28:27 \ft Li zẹ \fq Aza 6.9-10\f* 
\p  
\v 28 “Irarighọ, mhia nono ni a lẹsẹ khi imiepfuese oyi Ẹshinẹgba khi a she rọli ghi ẹgbọ iJẹta. E ya ri esọ shi ọ!”  
\v 29 [Abi ọ rọ ngme oni ungmemhi ona se, eni ẹgbọ iJu e vu, e nu egbewẹ khakọ ni o toto.] 
\p  
\v 30 Ikpe eva gbada iPọlu ọ la owa ni lọlighuo ọ ngmomhi shi. Aghọ ọ la a mu ẹgbọ ni e bhale ya fẹli ọli epfẹse.  
\v 31 Igbe-udu ni ọ mhuẹ ya, ọ rọ ọ gue ungmemhi Eghiele oyi Ẹshinẹgba le, ọ gbolo sẹsẹ ẹgbọ ingme eyi iJesu iKirisiti Ọnọmhuẹ, emhikhọghuo ọa zu ọli odẹ.