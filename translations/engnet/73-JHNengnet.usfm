\s1 A Final Note  
\p
\v 24  \w This|strong="G3778"\w* \w is|strong="G1510"\w* \w the|strong="G2532"\w* \w disciple|strong="G3101"\w* \w who|strong="G3588"\w* \w testifies|strong="G3140"\w* \w about|strong="G4012"\w* \w these|strong="G3778"\w* \w things|strong="G3778"\w* \w and|strong="G2532"\w* \w has|strong="G3778"\w* \w written|strong="G1125"\w* \w these|strong="G3778"\w* \w things|strong="G3778"\w*, \w and|strong="G2532"\w* \w we|strong="G3754"\w* \w know|strong="G1492"\w* \w that|strong="G3754"\w* \w his|strong="G4012"\w* \w testimony|strong="G3141"\w* \w is|strong="G1510"\w* \w true|strong="G3588"\w*.  
\v 25  \w There|strong="G2532"\w* \w are|strong="G1510"\w* \w many|strong="G4183"\w* \w other|strong="G1161"\w* \w things|strong="G4183"\w* \w that|strong="G2532"\w* \w Jesus|strong="G2424"\w* \w did|strong="G4160"\w*. \w If|strong="G1437"\w* \w every|strong="G2596"\w* \w one|strong="G1520"\w* \w of|strong="G2532"\w* \w them|strong="G4160"\w* \w were|strong="G1510"\w* \w written|strong="G1125"\w* \w down|strong="G2596"\w*, \w I|strong="G2532"\w* \w suppose|strong="G3633"\w* \w the|strong="G2532"\w* whole \w world|strong="G2889"\w* \w would|strong="G2532"\w* \w not|strong="G3761"\w* \w have|strong="G2532"\w* \w room|strong="G5562"\w* \w for|strong="G1161"\w* \w the|strong="G2532"\w* books \w that|strong="G2532"\w* \w would|strong="G2532"\w* \w be|strong="G1510"\w* \w written|strong="G1125"\w*.   