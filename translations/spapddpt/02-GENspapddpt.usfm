\v 8 Pero \w él|strong="H3605"\w* rehusó y respondió \w a|strong="H3068"\w* \w la|strong="H3605"\w* esposa \w de|strong="H5414"\w* su \tl ʼadón\tl*: \w Ciertamente|strong="H2005"\w* mi \tl ʼadón\tl* \w no|strong="H3808"\w* \w se|strong="H3045"\w* preocupa \w de|strong="H5414"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* \w hay|strong="H3426"\w* en \w la|strong="H3605"\w* \w casa|strong="H1004"\w*, y \w puso|strong="H5414"\w* en mi \w mano|strong="H3027"\w* \w todo|strong="H3605"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* \w tiene|strong="H3426"\w*.  
\v 9 \w No|strong="H3808"\w* \w me|strong="H4480"\w* priva \w de|strong="H4480"\w* \w alguna|strong="H3972"\w* \w cosa|strong="H3972"\w*, \w sino|strong="H3588"\w* solo \w de|strong="H4480"\w* \w ti|strong="H4480"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w tú|strong="H6213"\w* eres \w su|strong="H3588"\w* esposa. ¿\w Cómo|strong="H3588"\w*, \w pues|strong="H3588"\w*, \w haría|strong="H6213"\w* \w este|strong="H2088"\w* \w mal|strong="H7451"\w* tan \w grande|strong="H1419"\w* \w y|strong="H3588"\w* pecaría \w contra|strong="H4480"\w* \nd ʼElohim\nd*?  
\v 10 \w Sucedió|strong="H1961"\w* \w que|strong="H3808"\w*, \w aunque|strong="H3808"\w* ella instaba \w a|strong="H3068"\w* \w José|strong="H3130"\w* \w cada|strong="H3117"\w* \w día|strong="H3117"\w*, \w él|strong="H5973"\w* \w no|strong="H3808"\w* la \w escuchaba|strong="H8085"\w* \w para|strong="H1961"\w* acostarse \w a|strong="H3068"\w* su lado y unirse \w a|strong="H3068"\w* ella.   
\p
\v 11 Pero \w aconteció|strong="H1961"\w* cierto \w día|strong="H3117"\w* \w que|strong="H3117"\w*, \w cuando|strong="H3117"\w* \w él|strong="H6213"\w* entró en la \w casa|strong="H1004"\w* \w para|strong="H1961"\w* \w hacer|strong="H6213"\w* su \w oficio|strong="H4399"\w*, y nadie de \w los|strong="H1961"\w* de la \w casa|strong="H1004"\w* \w estaba|strong="H1961"\w* \w allí|strong="H8033"\w*,  
\v 12 ella lo agarró \w de|strong="H5973"\w* su manto y \w le|strong="H5973"\w* dijo: ¡Únete \w a|strong="H3068"\w* mí! Pero \w él|strong="H5973"\w* \w dejó|strong="H5800"\w* su manto \w en|strong="H5973"\w* \w mano|strong="H3027"\w* \w de|strong="H5973"\w* ella, \w huyó|strong="H5127"\w* y \w salió|strong="H3318"\w* \w afuera|strong="H2351"\w*.   
\p
\v 13 \w Cuando|strong="H3588"\w* ella \w miró|strong="H7200"\w* \w que|strong="H3588"\w* \w él|strong="H3588"\w* abandonó \w su|strong="H3588"\w* manto \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* ella \w y|strong="H3588"\w* \w huyó|strong="H5127"\w* hacia \w afuera|strong="H2351"\w*,  
\v 14 \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w los|strong="H5973"\w* varones \w de|strong="H5973"\w* su \w casa|strong="H1004"\w* y \w les|strong="H5973"\w* habló: Miren, nos trajo \w a|strong="H3068"\w* un esclavo \w hebreo|strong="H5680"\w* \w para|strong="H5973"\w* que se burlara \w de|strong="H5973"\w* \w nosotros|strong="H5973"\w*. Vino \w para|strong="H5973"\w* unirse \w a|strong="H3068"\w* mí, pero grité \w a|strong="H3068"\w* \w gran|strong="H1419"\w* \w voz|strong="H6963"\w*.  
\v 15 \w Sucedió|strong="H1961"\w* \w que|strong="H3588"\w*, \w cuando|strong="H3588"\w* \w él|strong="H3588"\w* \w oyó|strong="H8085"\w* \w que|strong="H3588"\w* alzaba \w mi|strong="H1961"\w* \w voz|strong="H6963"\w* \w y|strong="H3588"\w* gritaba, al huir \w dejó|strong="H5800"\w* \w su|strong="H3588"\w* manto junto \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w y|strong="H3588"\w* \w salió|strong="H3318"\w* \w afuera|strong="H2351"\w*.   
\p
\v 16 Entonces ella retuvo el manto \w de|strong="H5704"\w* él \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* su \tl ʼadón\tl* \w llegó|strong="H5704"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w*,  
\v 17 y ella le \w habló|strong="H1696"\w* las mismas \w palabras|strong="H1697"\w*: El esclavo \w hebreo|strong="H5680"\w* \w que|strong="H1697"\w* nos trajiste vino \w a|strong="H3068"\w* mí para divertirse conmigo.  
\v 18 \w Sucedió|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* alcé \w mi|strong="H1961"\w* \w voz|strong="H6963"\w* y grité, él \w dejó|strong="H5800"\w* su manto junto \w a|strong="H3068"\w* \w mí|strong="H1961"\w* y \w huyó|strong="H5127"\w* \w afuera|strong="H2351"\w*.  
\v 19 Entonces ocurrió \w que|strong="H1697"\w* al \w oír|strong="H8085"\w* su \tl ʼadón\tl* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* su esposa le \w habló|strong="H1696"\w*: \w Así|strong="H1696"\w* me \w trató|strong="H1696"\w* \w tu|strong="H6213"\w* esclavo, \w se|strong="H1961"\w* encendió su furor.   
\p
\v 20 Su amo \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w* y lo echó en la cárcel \w donde|strong="H8033"\w* \w estaban|strong="H1961"\w* encerrados \w los|strong="H1961"\w* presos del \w rey|strong="H4428"\w*.  
\p \w Allí|strong="H8033"\w* \w estaba|strong="H1961"\w* en la cárcel.  
\v 21 Pero \nd \+w Yavé|strong="H3068"\+w*\nd* \w estaba|strong="H1961"\w* con \w José|strong="H3130"\w*, \w le|strong="H5869"\w* \w extendió|strong="H5186"\w* su \w misericordia|strong="H2617"\w* y \w le|strong="H5869"\w* concedió \w gracia|strong="H2580"\w* ante el \w jefe|strong="H8269"\w* \w de|strong="H8269"\w* la cárcel.   
\p
\v 22 \w El|strong="H1931"\w* \w jefe|strong="H8269"\w* \w de|strong="H8269"\w* \w la|strong="H1931"\w* cárcel \w entregó|strong="H5414"\w* en \w mano|strong="H3027"\w* \w de|strong="H8269"\w* \w José|strong="H3130"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* presos \w que|strong="H1931"\w* \w estaban|strong="H1961"\w* en \w la|strong="H1931"\w* cárcel. \w Todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w hacían|strong="H6213"\w* \w allí|strong="H8033"\w*, \w él|strong="H1931"\w* \w era|strong="H1961"\w* \w el|strong="H1931"\w* responsable.  
\v 23 \w El|strong="H1931"\w* \w jefe|strong="H8269"\w* \w de|strong="H8269"\w* \w la|strong="H1931"\w* cárcel \w no|strong="H6213"\w* supervisaba \w algo|strong="H3972"\w* \w que|strong="H1931"\w* estuviera en \w mano|strong="H3027"\w* \w de|strong="H8269"\w* José, porque \nd \+w Yavé|strong="H3068"\+w*\nd* \w estaba|strong="H1004"\w* con \w él|strong="H1931"\w*. \w Lo|strong="H1931"\w* \w que|strong="H1931"\w* \w él|strong="H1931"\w* emprendía, \nd \+w Yavé|strong="H3068"\+w*\nd* \w lo|strong="H1931"\w* prosperaba.   
\c 40  
\s1 En la cárcel  
\p
\v 1 \w Después|strong="H1961"\w* \w de|strong="H1697"\w* estas \w cosas|strong="H1697"\w*, \w sucedió|strong="H1961"\w* \w que|strong="H1697"\w* el copero y el panadero del \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Egipto|strong="H4714"\w* ofendieron \w a|strong="H3068"\w* su \tl ʼadón,\tl* el \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Egipto|strong="H4714"\w*.  
\v 2 \w Faraón|strong="H6547"\w* \w se|strong="H5921"\w* enfureció \w contra|strong="H5921"\w* sus \w dos|strong="H8147"\w* funcionarios: \w el|strong="H5921"\w* \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* coperos \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* panaderos.  
\v 3 Los \w puso|strong="H5414"\w* bajo custodia en la \w casa|strong="H1004"\w* del \w capitán|strong="H8269"\w* \w de|strong="H8269"\w* la guardia, en la \w cárcel|strong="H4929"\w* \w donde|strong="H8033"\w* \w estaba|strong="H1004"\w* preso \w José|strong="H3130"\w*.  
\v 4 El \w capitán|strong="H8269"\w* \w de|strong="H8269"\w* la guardia \w se|strong="H1961"\w* \w los|strong="H1961"\w* encargó \w a|strong="H3068"\w* \w José|strong="H3130"\w*, y \w éste|strong="H1961"\w* les \w servía|strong="H8334"\w*. \w Estuvieron|strong="H1961"\w* bajo custodia durante algún \w tiempo|strong="H3117"\w*.   
\s1 Sueños del copero y del panadero de Faraón  
\p
\v 5 El copero y el panadero del \w rey|strong="H4428"\w* de \w Egipto|strong="H4714"\w*, cuando estaban presos en la cárcel, \w ambos|strong="H8147"\w* tuvieron un \w sueño|strong="H2472"\w* en una misma \w noche|strong="H3915"\w*, cada uno su \w sueño|strong="H2472"\w* con su peculiar sentido.   
\p
\v 6 \w José|strong="H3130"\w* fue \w a|strong="H3068"\w* ellos por la \w mañana|strong="H1242"\w* y observó que estaban perturbados.  
\v 7 \w Preguntó|strong="H7592"\w* \w a|strong="H3068"\w* los funcionarios \w de|strong="H6440"\w* \w Faraón|strong="H6547"\w* \w que|strong="H3117"\w* estaban con él en la prisión \w de|strong="H6440"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* su \tl ʼadón\tl*: ¿\w Por|strong="H4069"\w* \w qué|strong="H3117"\w* sus \w rostros|strong="H6440"\w* parecen tristes \w hoy|strong="H3117"\w*?   
\p
\v 8 Le respondieron: Nos vino un \w sueño|strong="H2472"\w* y \w no|strong="H3808"\w* hay quien \w lo|strong="H3808"\w* interprete. Entonces \w José|strong="H3130"\w* les dijo: ¿\w No|strong="H3808"\w* corresponden las interpretaciones \w a|strong="H3068"\w* \nd ʼElohim\nd*? Les \w ruego|strong="H4994"\w* \w que|strong="H3808"\w* me los narren.   
\p
\v 9 Entonces el \w jefe|strong="H8269"\w* \w de|strong="H6440"\w* los coperos \w contó|strong="H5608"\w* su \w sueño|strong="H2472"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w*: En \w mi|strong="H2009"\w* \w sueño|strong="H2472"\w* apareció \w ante|strong="H6440"\w* \w mí|strong="H2009"\w* una \w vid|strong="H1612"\w*,  
\v 10 y en \w la|strong="H1931"\w* \w vid|strong="H1612"\w* estaban \w tres|strong="H7969"\w* ramas. Parecía \w que|strong="H1931"\w* les salían brotes, florecían, y \w sus|strong="H1931"\w* racimos de \w uvas|strong="H6025"\w* maduraban.  
\v 11 \w La|strong="H5921"\w* copa \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w* estaba \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*. \w Tomé|strong="H3947"\w* \w las|strong="H5921"\w* \w uvas|strong="H6025"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* exprimí \w en|strong="H5921"\w* \w la|strong="H5921"\w* copa \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w*, \w y|strong="H5921"\w* \w entregué|strong="H5414"\w* \w la|strong="H5921"\w* copa \w en|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w*.   
\p
\v 12 \w José|strong="H3130"\w* le dijo: \w Esta|strong="H2088"\w* \w es|strong="H2088"\w* \w su|strong="H1992"\w* interpretación: \w Las|strong="H1992"\w* \w tres|strong="H7969"\w* ramas son \w tres|strong="H7969"\w* \w días|strong="H3117"\w*.  
\v 13 \w Dentro|strong="H5750"\w* \w de|strong="H5921"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* \w Faraón|strong="H6547"\w* \w alzará|strong="H5375"\w* tu \w cabeza|strong="H7218"\w* \w y|strong="H5921"\w* \w te|strong="H5921"\w* devolverá \w a|strong="H3068"\w* tu \w puesto|strong="H5414"\w*. \w Pondrás|strong="H5414"\w* \w la|strong="H5921"\w* copa \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w* \w en|strong="H5921"\w* su \w mano|strong="H3027"\w*, \w como|strong="H1961"\w* \w de|strong="H5921"\w* \w costumbre|strong="H4941"\w* \w cuando|strong="H3117"\w* \w eras|strong="H1961"\w* su copero.  
\v 14 \w Pero|strong="H3588"\w* \w cuando|strong="H3588"\w* \w te|strong="H4480"\w* vaya \w bien|strong="H3190"\w*, \w acuérdate|strong="H2142"\w* \w de|strong="H4480"\w* \w mí|strong="H4994"\w*. \w Te|strong="H4480"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* tengas \w misericordia|strong="H2617"\w* \w de|strong="H4480"\w* \w mí|strong="H4994"\w*, \w me|strong="H4480"\w* menciones \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* \w y|strong="H3588"\w* \w me|strong="H4480"\w* saques \w de|strong="H4480"\w* \w esta|strong="H2088"\w* \w casa|strong="H1004"\w*,  
\v 15 \w porque|strong="H3588"\w* \w ciertamente|strong="H3588"\w* \w fui|strong="H3808"\w* secuestrado \w de|strong="H3588"\w* \w la|strong="H1571"\w* tierra \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w hebreos|strong="H5680"\w*. \w Nada|strong="H3808"\w* \w hice|strong="H6213"\w* \w aquí|strong="H6311"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* confinaran \w en|strong="H3588"\w* \w la|strong="H1571"\w* cárcel.   
\p
\v 16 \w Entonces|strong="H3588"\w*, \w al|strong="H5921"\w* \w ver|strong="H7200"\w* \w el|strong="H5921"\w* \w jefe|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* panaderos \w que|strong="H3588"\w* interpretó favorablemente, dijo \w a|strong="H3068"\w* \w José|strong="H3130"\w*: También \w yo|strong="H3588"\w* soñé \w que|strong="H3588"\w* \w veía|strong="H7200"\w* \w tres|strong="H7969"\w* cestas \w de|strong="H5921"\w* pan \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w cabeza|strong="H7218"\w*.  
\v 17 \w En|strong="H5921"\w* \w la|strong="H5921"\w* cesta \w más|strong="H4480"\w* alta había \w de|strong="H4480"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* manjares \w de|strong="H4480"\w* \w Faraón|strong="H6547"\w*, \w obra|strong="H4639"\w* \w de|strong="H4480"\w* panadero, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w aves|strong="H5775"\w* \w se|strong="H5921"\w* \w los|strong="H5921"\w* comían \w de|strong="H4480"\w* \w la|strong="H5921"\w* cesta \w que|strong="H4480"\w* estaba \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w cabeza|strong="H7218"\w*.   
\p
\v 18 \w José|strong="H3130"\w* \w respondió|strong="H6030"\w*: \w Esta|strong="H2088"\w* \w es|strong="H2088"\w* \w su|strong="H1992"\w* interpretación: \w Las|strong="H1992"\w* \w tres|strong="H7969"\w* cestas son \w tres|strong="H7969"\w* \w días|strong="H3117"\w*.  
\v 19 \w Dentro|strong="H5750"\w* \w de|strong="H5921"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* \w Faraón|strong="H6547"\w* \w alzará|strong="H5375"\w* tu \w cabeza|strong="H7218"\w* \w y|strong="H5921"\w* \w te|strong="H5921"\w* hará colgar \w de|strong="H5921"\w* un \w árbol|strong="H6086"\w*, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w aves|strong="H5775"\w* comerán tu \w carne|strong="H1320"\w*.   
\p
\v 20 \w Sucedió|strong="H1961"\w*, \w pues|strong="H1961"\w*, al tercer \w día|strong="H3117"\w*, \w el|strong="H3605"\w* \w día|strong="H3117"\w* del cumpleaños \w de|strong="H8269"\w* \w Faraón|strong="H6547"\w*, \w que|strong="H3117"\w* \w él|strong="H3605"\w* \w hizo|strong="H6213"\w* un \w banquete|strong="H4960"\w* \w para|strong="H1961"\w* \w todos|strong="H3605"\w* sus esclavos. \w En|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H8269"\w* sus esclavos \w levantó|strong="H5375"\w* \w la|strong="H3605"\w* \w cabeza|strong="H7218"\w* del \w jefe|strong="H7218"\w* \w de|strong="H8269"\w* \w los|strong="H3605"\w* coperos y \w la|strong="H3605"\w* \w cabeza|strong="H7218"\w* del \w jefe|strong="H7218"\w* \w de|strong="H8269"\w* \w los|strong="H3605"\w* panaderos.  
\v 21 Restableció \w en|strong="H5921"\w* su oficio \w al|strong="H5921"\w* \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* coperos, \w y|strong="H5921"\w* éste colocó \w la|strong="H5921"\w* copa \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3709"\w* \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w*,  
\v 22 pero \w colgó|strong="H8518"\w* al \w jefe|strong="H8269"\w* \w de|strong="H8269"\w* los panaderos, como \w José|strong="H3130"\w* les interpretó.   
\p
\v 23 \w Sin|strong="H3808"\w* embargo, el \w jefe|strong="H8269"\w* \w de|strong="H8269"\w* los coperos \w no|strong="H3808"\w* \w se|strong="H3808"\w* acordó \w de|strong="H8269"\w* \w José|strong="H3130"\w*, \w sino|strong="H3808"\w* \w lo|strong="H3808"\w* \w olvidó|strong="H7911"\w*.   
\c 41  
\s1 Los sueños de Faraón  
\p
\v 1 \w Aconteció|strong="H1961"\w* \w que|strong="H5921"\w* \w después|strong="H1961"\w* \w de|strong="H5921"\w* \w dos|strong="H8141"\w* \w años|strong="H8141"\w* completos \w Faraón|strong="H6547"\w* \w tuvo|strong="H1961"\w* un sueño. \w Ciertamente|strong="H2009"\w* \w él|strong="H5921"\w* \w estaba|strong="H1961"\w* \w en|strong="H5921"\w* \w pie|strong="H5975"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* Nilo,  
\v 2 y \w del|strong="H4480"\w* Nilo \w subían|strong="H5927"\w* \w siete|strong="H7651"\w* \w vacas|strong="H6510"\w* \w hermosas|strong="H3303"\w* y gordas \w que|strong="H4480"\w* apacentaban \w en|strong="H4480"\w* \w el|strong="H2975"\w* juncal.  
\v 3 Inmediatamente \w después|strong="H5921"\w* \w de|strong="H4480"\w* \w ellas|strong="H2009"\w* \w subían|strong="H5927"\w* \w del|strong="H4480"\w* Nilo otras \w siete|strong="H7651"\w* \w vacas|strong="H6510"\w* feas \w y|strong="H5921"\w* flacas, \w y|strong="H5921"\w* \w se|strong="H5921"\w* colocaron \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* otras \w vacas|strong="H6510"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* orilla \w del|strong="H4480"\w* Nilo.  
\v 4 Las \w vacas|strong="H6510"\w* feas y flacas devoraron \w a|strong="H3068"\w* las \w siete|strong="H7651"\w* \w vacas|strong="H6510"\w* \w hermosas|strong="H3303"\w* y gordas. \w Y|strong="H3068"\w* \w Faraón|strong="H6547"\w* \w despertó|strong="H3364"\w*.   
\p
\v 5 Se volvió \w a|strong="H3068"\w* dormir y \w soñó|strong="H2492"\w* la \w segunda|strong="H8145"\w* vez. Ahí estaban \w siete|strong="H7651"\w* \w espigas|strong="H7641"\w* \w gruesas|strong="H1277"\w* y \w hermosas|strong="H2896"\w* \w que|strong="H7651"\w* crecían de un mismo tallo.  
