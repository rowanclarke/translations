\id 2JN - Kekchi Bible -Guatemala 2012 (DBL -2013) 
\h 2 JUAN 
\toc1 Li Xcab Hu li Quixtz'i̱ba li San Juan 
\toc2 2 Juan 
\toc3 2 Jn 
\mt1 Li Xcab Hu li Quixtz'i̱ba li San Juan 
\c 1  
\s1 Laj Juan natz'i̱bac riq'uin jun li ixk aj pa̱banel 
\p  
\v 1 La̱in aj c'amol be cha̱cuu sa' la̱ pa̱ba̱l. At hermana, nintz'i̱bac a̱cuiq'uin la̱at li sic'bil a̱cuu xban li Dios. Ut nintz'i̱bac ajcui' riq'uineb la̱ cualal a̱c'ajol. Ya̱l nak la̱in nequexinra. Moco ca'aj ta cui' la̱in ninrahoc e̱re. Nequexrahe' aj ban cui' xbaneb chixjunileb li neque'xnau li xya̱lal.  
\v 2 Nequexkara xban nak junaj li nakapa̱b ut lix ya̱lal a'an ta̱cua̱nk kiq'uin chi junelic.  
\v 3 A' taxak li rusilal, li ruxta̱n ut li tuktu̱quilal li naxq'ue li Dios Acuabej ut li Jesucristo li Alalbej chicua̱nk e̱riq'uin sa' xya̱lal ut riq'uin rahoc.  
\v 4 C'ajo' nak nasaho' sa' inch'o̱l chirilbaleb la̱ cualal a̱c'ajol nak cuanqueb sa' xya̱lal. Jo'ca'in li kataklanquil xban li Dios Acuabej.  
\v 5 Ut anakcuan nintz'a̱ma cha̱cuu nak chikarahak taxak kib chi kibil kib. Li chak'rab a'in moco ac' ta. Abanan q'uebil chak ke chalen chak sa' xticlajic li kapa̱ba̱l.  
\v 6 Cui nakara kib chi kibil kib, nakapa̱b li kachak'rabinquil xban li Dios. Chalen chak sa' xticlajic, li Dios quixye ke nak tento takara kib chi kibil kib. 
\s1 Eb laj tzolonel aj balak' 
\p  
\v 7 Ninnumsi cui'chic sa' e̱xic li na'leb a'in xban nak nabaleb laj tzolonel aj balak' cuanqueb sa' ruchich'och'. Eb li cui̱nk a'in inc'a' neque'xch'olob li xya̱lal nak li Jesucristo quitz'ejcualo' ut tz'akal cui̱nk nak quic'ulun sa' ruchich'och'. Eb li cui̱nk a'in aj balak'eb ut xic' neque'ril li Jesucristo.  
\v 8 Cheq'uehak retal che̱ribil e̱rib re nak inc'a' ta̱cana̱k chi ma̱c'a' rajbal le̱ c'anjel chiru li Dios. Tz'akalak ban re ru xk'ajca̱munquil le̱ c'anjel te̱c'ul riq'uin li Dios.  
\v 9 Cui ani junak naxq'ue xtz'akob li quix-ch'olob li Jesucristo, li jun a'an ma̱c'a' li Dios riq'uin. Abanan cui nakapa̱b li c'a'ru quixch'olob li Jesucristo, li Dios Acuabej cua̱nk kiq'uin ut cua̱nk ajcui' kiq'uin li Jesucristo li C'ajolbej.  
\v 10 Cui nacuulac junak e̱riq'uin ut nequenau nak jalan li yo̱ chixch'olobanquil che̱ru chiru li quixch'olob li Jesucristo, me̱c'ul sa' le̱ rochoch chi moco te̱ye re nak li Dios chi-osobtesi̱nk re.  
\v 11 Xban nak li ani naxtz'a̱ma chiru li Dios nak ta̱rosobtesiheb laj balak', a'an ta̱tz'ako̱nk riq'uin lix yibal ru lix c'anjeleb. 
\s1 Xchak'rabinquileb 
\p  
\v 12 Cuan raj chic nabal tinye e̱re, abanan inc'a' nacuaj xtz'i̱banquil sa' li hu a'in. La̱in nacuaj xic e̱riq'uin re nak toa̱tinak ut takil xsahil kach'o̱l chi kibil kib.  
\v 13 Neque'xtakla xsahil a̱ch'o̱l eb li ralal xc'ajol la̱ chak'na', li sic'bil ru xban li Dios. Jo'can taxak. \fig Xiuxiu xculbal eb aj tzolonel aj balak.|src="cn02065B.tif" size="col" copy="©1978 David C. Cook Publishing Co." ref="2 Juan 1.13" \fig*