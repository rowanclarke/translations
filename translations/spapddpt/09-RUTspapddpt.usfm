\v 10 \w Y|strong="H3068"\w* él dijo: ¡\w Bendita|strong="H1288"\w* seas \w por|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w hija|strong="H1323"\w* mía! Hiciste mejor tu última bondad \w que|strong="H4480"\w* la \w primera|strong="H7223"\w*, \w al|strong="H4480"\w* \w no|strong="H1115"\w* \w ir|strong="H3212"\w* \w en|strong="H4480"\w* busca \w de|strong="H4480"\w* los jóvenes, sean \w pobres|strong="H1800"\w* \w o|strong="H3068"\w* ricos.  
\v 11 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, \w hija|strong="H1323"\w* mía, \w no|strong="H6213"\w* \w temas|strong="H3372"\w*. \w Yo|strong="H3588"\w* \w haré|strong="H6213"\w* \w por|strong="H3588"\w* ti \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* dices, \w pues|strong="H3588"\w* \w todo|strong="H3605"\w* mi \w pueblo|strong="H5971"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* ciudad \w sabe|strong="H3045"\w* \w que|strong="H3588"\w* eres una mujer excelente.  
\v 12 \w Ahora|strong="H6258"\w*, \w aunque|strong="H3588"\w* \w es|strong="H3588"\w* \w cierto|strong="H3588"\w* \w que|strong="H3588"\w* soy un \w pariente|strong="H1350"\w* \w cercano|strong="H7138"\w*, sin embargo, \w hay|strong="H3426"\w* un \w pariente|strong="H1350"\w* \w más|strong="H3588"\w* \w cercano|strong="H7138"\w* \w que|strong="H3588"\w* \w yo|strong="H4480"\w*.  
\v 13 Permanece aquí \w esta|strong="H1961"\w* \w noche|strong="H3915"\w*, \w y|strong="H5704"\w* \w cuando|strong="H5704"\w* llegue \w el|strong="H3885"\w* día, \w si|strong="H3808"\w* \w él|strong="H3885"\w* \w quiere|strong="H2654"\w* redimirte, \w bien|strong="H2896"\w*, \w que|strong="H3808"\w* te redima. Pero \w si|strong="H3808"\w* \w él|strong="H3885"\w* \w no|strong="H3808"\w* \w quiere|strong="H2654"\w* redimirte, ¡\w vive|strong="H2416"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, yo te \w redimiré|strong="H1350"\w*! \w Acuéstate|strong="H7901"\w* \w hasta|strong="H5704"\w* la \w mañana|strong="H1242"\w*.   
\p
\v 14 \w Así|strong="H3588"\w* \w que|strong="H3588"\w* ella \w se|strong="H3045"\w* acostó \w a|strong="H3068"\w* sus \w pies|strong="H4772"\w* \w hasta|strong="H5704"\w* \w la|strong="H3588"\w* \w mañana|strong="H1242"\w*. \w Luego|strong="H5704"\w* \w se|strong="H3045"\w* \w levantó|strong="H6965"\w* \w antes|strong="H3588"\w* \w que|strong="H3588"\w* uno pudiera reconocer \w a|strong="H3068"\w* \w otro|strong="H7453"\w*, \w porque|strong="H3588"\w* \w él|strong="H3588"\w* dijo: \w No|strong="H3588"\w* \w se|strong="H3045"\w* \w sepa|strong="H3045"\w* \w que|strong="H3588"\w* vino mujer \w a|strong="H3068"\w* \w la|strong="H3588"\w* era.   
\p
\v 15 \w Después|strong="H5921"\w* \w le|strong="H5921"\w* dijo: \w Dame|strong="H3051"\w* \w el|strong="H5921"\w* manto \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w y|strong="H5921"\w* sostenlo. \w Ella|strong="H5921"\w* \w lo|strong="H5921"\w* sostuvo. \w Y|strong="H3068"\w* \w él|strong="H5921"\w* tomó \w seis|strong="H8337"\w* medidas \w de|strong="H5921"\w* \w cebada|strong="H8184"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w las|strong="H5921"\w* colocó \w encima|strong="H5921"\w*. Entonces \w ella|strong="H5921"\w* fue \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*.   
\p
\v 16 Cuando volvió \w a|strong="H3068"\w* su \w suegra|strong="H2545"\w*, ésta preguntó: ¿\w Qué|strong="H4310"\w* sucedió, \w hija|strong="H1323"\w* mía?  
\p \w Y|strong="H3068"\w* \w ella|strong="H3605"\w* \w le|strong="H4310"\w* \w contó|strong="H5046"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H4310"\w* \w aquel|strong="H3605"\w* varón \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* por \w ella|strong="H3605"\w*.  
\v 17 \w Y|strong="H3068"\w* añadió: \w Me|strong="H3588"\w* \w dio|strong="H5414"\w* estas \w seis|strong="H8337"\w* medidas \w de|strong="H3588"\w* 22 litros \w de|strong="H3588"\w* \w cebada|strong="H8184"\w*, \w pues|strong="H3588"\w* dijo: \w No|strong="H3588"\w* regreses \w a|strong="H3068"\w* tu \w suegra|strong="H2545"\w* \w con|strong="H3588"\w* las manos \w vacías|strong="H7387"\w*.   
\p
\v 18 \w Y|strong="H3068"\w* \w ésta|strong="H3427"\w* dijo: Descansa, \w hija|strong="H1323"\w* mía, \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* \w sepas|strong="H3045"\w* \w cómo|strong="H3588"\w* termina este \w asunto|strong="H1697"\w*, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* hombre \w no|strong="H3808"\w* descansará \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* \w concluya|strong="H3615"\w* \w hoy|strong="H3117"\w* mismo \w el|strong="H3588"\w* \w asunto|strong="H1697"\w*.   
\c 4  
\s1 Redención de Rut y Noemí  
\p
\v 1 \w Booz|strong="H1162"\w* \w subió|strong="H5927"\w* \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w* y se sentó \w allí|strong="H8033"\w*. \w Y|strong="H3068"\w* \w ciertamente|strong="H2009"\w* \w ahí|strong="H8033"\w* \w pasaba|strong="H5674"\w* aquel \w pariente|strong="H1350"\w* más cercano, del cual \w Booz|strong="H1162"\w* \w habló|strong="H1696"\w*, y le \w dijo|strong="H1696"\w*: ¡Hola, \w fulano|strong="H6423"\w*, \w ven|strong="H5493"\w* \w acá|strong="H5927"\w* y \w siéntate|strong="H3427"\w*! \w Y|strong="H3068"\w* \w él|strong="H5674"\w* se desvió y se sentó.   
\p
\v 2 Entonces Booz \w tomó|strong="H3947"\w* \w diez|strong="H6235"\w* varones de \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w* de la \w ciudad|strong="H5892"\w* y dijo: Siéntense \w aquí|strong="H6311"\w*.  
\p \w Y|strong="H3068"\w* se \w sentaron|strong="H3427"\w*.  
\v 3 \w Luego|strong="H7725"\w* dijo al \w pariente|strong="H1350"\w* más cercano: \w Noemí|strong="H5281"\w*, quien regresó de la \w tierra|strong="H2513"\w* de \w Moab|strong="H4124"\w*, \w vende|strong="H4376"\w* la parcela de \w tierra|strong="H2513"\w* que perteneció \w a|strong="H3068"\w* nuestro hermano Elimelec.   
\p
\v 4 Decidí hacértelo \w saber|strong="H5046"\w* \w y|strong="H3588"\w* decirte \w frente|strong="H5048"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w están|strong="H3427"\w* \w sentados|strong="H3427"\w* aquí \w y|strong="H3588"\w* \w frente|strong="H5048"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w* \w de|strong="H3588"\w* mi \w pueblo|strong="H5971"\w*, \w que|strong="H3588"\w* \w la|strong="H3588"\w* compres. \w Si|strong="H3588"\w* quieres \w redimirla|strong="H1350"\w*, \w redímela|strong="H1350"\w*. \w Si|strong="H3588"\w* \w no|strong="H3808"\w* quieres \w redimirla|strong="H1350"\w*, \w decláramelo|strong="H5046"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w lo|strong="H3808"\w* \w sepa|strong="H3045"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* hay \w nadie|strong="H3808"\w* \w para|strong="H3588"\w* \w redimirla|strong="H1350"\w* \w fuera|strong="H2108"\w* \w de|strong="H3588"\w* ti, \w y|strong="H3588"\w* \w después|strong="H3427"\w* \w de|strong="H3588"\w* ti, \w yo|strong="H3588"\w*. \w Y|strong="H3068"\w* \w él|strong="H3588"\w* contestó: \w Yo|strong="H3588"\w* \w la|strong="H3588"\w* \w redimiré|strong="H1350"\w*.   
\p
\v 5 Pero \w Booz|strong="H1162"\w* añadió: \w El|strong="H5921"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* adquieras \w el|strong="H5921"\w* \w campo|strong="H7704"\w* \w de|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w Noemí|strong="H5281"\w*, deberás tomar también \w a|strong="H3068"\w* Rut \w la|strong="H5921"\w* \w moabita|strong="H4125"\w*, esposa \w del|strong="H5921"\w* difunto, \w para|strong="H5921"\w* perpetuar \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w del|strong="H5921"\w* \w muerto|strong="H4191"\w* \w sobre|strong="H5921"\w* su \w herencia|strong="H5159"\w*.   
\p
\v 6 \w El|strong="H3588"\w* \w pariente|strong="H1350"\w* \w más|strong="H3588"\w* cercano respondió: \w Entonces|strong="H3588"\w* \w no|strong="H3808"\w* \w podré|strong="H3201"\w* \w redimirla|strong="H1350"\w* \w para|strong="H3588"\w* mí, \w pues|strong="H3588"\w* destruiría mi \w herencia|strong="H5159"\w*. \w Redime|strong="H1350"\w* tú. Usa mi oportunidad, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w no|strong="H3808"\w* \w podré|strong="H3201"\w* \w redimir|strong="H1350"\w*.   
\p
\v 7 \w Desde|strong="H6440"\w* antaño había una tradición \w en|strong="H5921"\w* \w Israel|strong="H3478"\w* \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w redención|strong="H1353"\w* \w y|strong="H5921"\w* \w al|strong="H5921"\w* contrato \w para|strong="H5921"\w* confirmar \w cualquier|strong="H3605"\w* \w asunto|strong="H1697"\w*. Uno \w se|strong="H5921"\w* quitaba su sandalia \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w daba|strong="H5414"\w* \w al|strong="H5921"\w* \w otro|strong="H7453"\w*, \w y|strong="H5921"\w* \w esto|strong="H2063"\w* servía \w de|strong="H5921"\w* testimonio \w en|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\p
\v 8 Entonces el \w pariente|strong="H1350"\w* más cercano dijo \w a|strong="H3068"\w* \w Booz|strong="H1162"\w*: Adquiérela para ti. \w Y|strong="H3068"\w* se quitó la sandalia.   
\p
\v 9 \w Entonces|strong="H3117"\w* \w Booz|strong="H1162"\w* anunció \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w*: Ustedes \w son|strong="H3588"\w* \w testigos|strong="H5707"\w* \w hoy|strong="H3117"\w* \w de|strong="H3588"\w* \w que|strong="H3588"\w* adquirí \w de|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w Noemí|strong="H5281"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3588"\w* fue \w de|strong="H3588"\w* Elimelec, \w de|strong="H3588"\w* Quelión \w y|strong="H3588"\w* \w de|strong="H3588"\w* Mahlón.  
\v 10 \w Además|strong="H5921"\w* adquiero \w a|strong="H3068"\w* Rut \w la|strong="H5921"\w* \w moabita|strong="H4125"\w*, esposa \w de|strong="H5921"\w* Mahlón, \w para|strong="H5921"\w* \w que|strong="H3808"\w* sea \w mi|strong="H5921"\w* esposa \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* perpetuar \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w del|strong="H5921"\w* difunto \w sobre|strong="H5921"\w* su \w heredad|strong="H5159"\w*, \w y|strong="H1571"\w* \w que|strong="H3808"\w* \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w del|strong="H5921"\w* difunto \w no|strong="H3808"\w* \w se|strong="H5921"\w* borre \w de|strong="H5921"\w* \w entre|strong="H5921"\w* sus hermanos \w ni|strong="H3808"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w de|strong="H5921"\w* su \w lugar|strong="H4725"\w*. Ustedes \w son|strong="H3808"\w* \w testigos|strong="H5707"\w* \w hoy|strong="H3117"\w*.   
\p
\v 11 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* del \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w estaban|strong="H5971"\w* en \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* con \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w*, dijeron: ¡Somos \w testigos|strong="H5707"\w*! ¡\nd \+w Yavé|strong="H3068"\+w*\nd* \w haga|strong="H6213"\w* \w que|strong="H5971"\w* \w la|strong="H3605"\w* esposa \w que|strong="H5971"\w* entra en \w tu|strong="H6213"\w* \w casa|strong="H1004"\w* sea como Raquel y como \w Lea|strong="H3812"\w*, quienes \w edificaron|strong="H1129"\w* \w la|strong="H3605"\w* \w familia|strong="H1004"\w* \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*, \w que|strong="H5971"\w* \w tú|strong="H6213"\w* logres riqueza en Efrata y seas famoso en Belén,  
\v 12 y tu \w casa|strong="H1004"\w* \w sea|strong="H1961"\w* \w como|strong="H1961"\w* \w la|strong="H2063"\w* \w casa|strong="H1004"\w* \w de|strong="H4480"\w* Fares, \w a|strong="H3068"\w* quien Tamar \w dio|strong="H5414"\w* \w a|strong="H3068"\w* luz \w para|strong="H4480"\w* \w Judá|strong="H3063"\w*, \w por|strong="H4480"\w* \w la|strong="H2063"\w* \w descendencia|strong="H2233"\w* \w que|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w te|strong="H4480"\w* \w dé|strong="H4480"\w* \w por|strong="H4480"\w* medio \w de|strong="H4480"\w* \w esta|strong="H2063"\w* joven!   
\p
\v 13 \w Booz|strong="H1162"\w* \w tomó|strong="H3947"\w*, \w pues|strong="H1961"\w*, \w a|strong="H3068"\w* Rut, y ella \w fue|strong="H1961"\w* su esposa. \w Se|strong="H1961"\w* unió con ella, y \nd \+w Yavé|strong="H3068"\+w*\nd* \w permitió|strong="H5414"\w* \w que|strong="H1121"\w* concibiera y \w dio|strong="H5414"\w* \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*.  
\v 14 \w Y|strong="H3068"\w* las mujeres decían \w a|strong="H3068"\w* \w Noemí|strong="H5281"\w*: ¡\w Bendito|strong="H1288"\w* sea \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H3808"\w* \w no|strong="H3808"\w* permitió \w que|strong="H3808"\w* te falte \w pariente|strong="H1350"\w* \w hoy|strong="H3117"\w*! ¡Sea su \w nombre|strong="H8034"\w* famoso en \w Israel|strong="H3478"\w*!  
\v 15 ¡\w Que|strong="H3588"\w* también \w él|strong="H1931"\w* \w sea|strong="H1961"\w* \w para|strong="H3588"\w* ti \w restaurador|strong="H7725"\w* \w de|strong="H3588"\w* \w vida|strong="H5315"\w* \w y|strong="H3588"\w* sustentador \w de|strong="H3588"\w* tu \w vejez|strong="H7872"\w*! \w Porque|strong="H3588"\w* tu \w nuera|strong="H3618"\w*, \w quien|strong="H1931"\w* \w te|strong="H3588"\w* ama, \w te|strong="H3588"\w* \w dio|strong="H7725"\w* \w a|strong="H3068"\w* luz, \w y|strong="H3588"\w* \w ella|strong="H1931"\w* \w es|strong="H1931"\w* \w mejor|strong="H2896"\w* \w para|strong="H3588"\w* ti \w que|strong="H3588"\w* \w siete|strong="H7651"\w* \w hijos|strong="H1121"\w*.   
\p
\v 16 \w Noemí|strong="H5281"\w* \w tomó|strong="H3947"\w* al niño, lo \w puso|strong="H7896"\w* en su pecho y \w fue|strong="H1961"\w* su madre de crianza.  
\v 17 Las vecinas \w le|strong="H1931"\w* dieron un \w nombre|strong="H8034"\w* y dijeron: \w A|strong="H3068"\w* \w Noemí|strong="H5281"\w* \w le|strong="H1931"\w* \w nació|strong="H3205"\w* un \w hijo|strong="H1121"\w*. \w Y|strong="H3068"\w* \w lo|strong="H1931"\w* \w llamaron|strong="H7121"\w* \w Obed|strong="H5744"\w*. \w Éste|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* padre \w de|strong="H1121"\w* \w Isaí|strong="H3448"\w*, padre \w de|strong="H1121"\w* \w David|strong="H1732"\w*.   
\p
