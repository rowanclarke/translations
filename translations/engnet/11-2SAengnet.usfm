\v 8  \w The|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w has|strong="H3068"\w* punished \w you|strong="H5414"\w* \w for|strong="H3588"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* spilled \w blood|strong="H1818"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* \w house|strong="H1004"\w* \w of|strong="H1121"\w* \w Saul|strong="H7586"\w*, \w in|strong="H5921"\w* \w whose|strong="H1121"\w* \w place|strong="H8478"\w* \w you|strong="H5414"\w* \w rule|strong="H3027"\w*. \w Now|strong="H3588"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w has|strong="H3068"\w* \w given|strong="H5414"\w* \w the|strong="H3605"\w* \w kingdom|strong="H4410"\w* \w into|strong="H7725"\w* \w the|strong="H3605"\w* \w hand|strong="H3027"\w* \w of|strong="H1121"\w* \w your|strong="H3068"\w* \w son|strong="H1121"\w* Absalom. \w Disaster|strong="H7451"\w* \w has|strong="H3068"\w* overtaken \w you|strong="H5414"\w*, \w for|strong="H3588"\w* \w you|strong="H5414"\w* \w are|strong="H1121"\w* \w a|strong="H3068"\w* \w man|strong="H1121"\w* \w of|strong="H1121"\w* \w bloodshed|strong="H1818"\w*!”   
\p
\v 9  \w Then|strong="H2088"\w* Abishai \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Zeruiah|strong="H6870"\w* said \w to|strong="H4191"\w* \w the|strong="H5674"\w* \w king|strong="H4428"\w*, “\w Why|strong="H4100"\w* \w should|strong="H4100"\w* \w this|strong="H2088"\w* \w dead|strong="H4191"\w* \w dog|strong="H3611"\w* \w curse|strong="H7043"\w* \w my|strong="H5493"\w* lord \w the|strong="H5674"\w* \w king|strong="H4428"\w*? \w Let|strong="H4994"\w* \w me|strong="H4994"\w* \w go|strong="H5674"\w* \w over|strong="H5674"\w* \w and|strong="H1121"\w* \w cut|strong="H5493"\w* \w off|strong="H5493"\w* \w his|strong="H5493"\w* \w head|strong="H7218"\w*!”  
