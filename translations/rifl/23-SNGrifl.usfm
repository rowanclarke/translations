\id SNG
\h Izři x izřan 
\toc1 Izři x izřan 
\toc2 Izři x izřan 
\toc3 Izři 
\mt1 Izři x izřan  
\c 1
\s1 Mmeẓri n tesřit i yesři  
\m
\v 1 Izři x izřan nni \add iǧan\add* n Suliman.   
\b  
\m
\v 2 “Ejj i-t ad ayi issudem  
\m s isudimen n uqemmum nnes,  
\m minzi usḥinneb nnec ḥsen zi binu.   
\m
\v 3 Řefwaḥet n zzect nnec tecna,  
\m isem nnec am zzect izeǧɛen,  
\m x uya ttexsent cek teɛzariyyin.   
\m
\v 4 Jbed ayi awarni ac,  
\m neccin ad nazzeř awarni ac!  
\m Ajeǧid indeh ayi deg ixammen nnes.  
\m Ejj aneɣ ad narceq u ad zzayek nfarḥ,  
\m ad neɛqeř x usḥinneb nnec  
\m ktar x min ɣa neɛqeř x binu.  
\m Nican ttexsent cek.”   
\b  
\m
\v 5 “D tabarcant necc, u ṣebḥeɣ,  
\m \add a\add* yessis n Urcalim,  
\m am tqiḍunin n Qidar,  
\m am řizarat n Suliman.   
\m
\v 6 War d ayi xezzarent \add ammu\add*,  
\m minzi necc bbarcneɣ,  
\m minzi tessecmeḍ ayi tfuct,  
\m iḥenjiren n yemma tuɣa xeyyqen xafi,  
\m ggin ayi ad ḥḍiɣ imarjaɛen n uḍiř.  
\m Amarjeɛ n yixef inu war t ḥḍiɣ ca.”   
\b  
\m
\v 7 “Cek, wenni ittexs buḥbeř inu,  
\m ini ayi, mani tarekkwesed,  
\m mani tessareyyaḥed \add taḥimart\add*  
\m ɣar ṭḥa n uziř,  
\m minzi i umi ɣa iřiɣ am tenni iḥejben  
\m ɣar tḥimriwin n imɛacaren nnec?”   
\b  
\m
\v 8 “Mařa cem war t tessined,  
\m \add cem\add* tenni icnan qaɛ jar temɣarin,  
\m xenni ffeɣ, ḍfar řatar n wuǧi,  
\m arwes tiɣaḍtin nnem  
\m mani zeddɣen imeksawen.” \f ◼ \fr 1:8 \ft \+fk imeksawen\ft  - niɣ ‘iničan’.\f*   
\b  
\m  
\s1 Řeɣnuj n yesři d tesřit s nnubtat  
\m
\v 9 “Ssemquddiɣ cem ak-d řɛewda inu  
\m zzat ikarruten n firɛun,  
\m \add a\add* tameddukkeč inu.   
\m
\v 10 Mecḥař ṣebḥen imeggizen nnem  
\m jar tseddyin,  
\m iri nnem jar ifiřan s tyaqutin.   
\m
\v 11 Ad am negg tiseddyin n wureɣ,  
\m ak-d tneqqiḍin n nnuqart.”   
\b  
\m
\v 12 “Min ɣa yekk ujeǧid  
\m \add iqqim\add* ɣar ṭṭabřa nnes taqurarit,  
\m itticc ṣṣenbel inu řefwaḥet nnes.   
\m
\v 13 Llif inu ittegg ayi  
\m am tecyart n mirru,  
\m tenni issensen jar idmaren inu.   
\m
\v 14 Llif inu i necc  
\m am tqebbiḍt n newwac n řḥenni,  
\m deg imarjaɛen n uḍiř n Ɛayn-Jadi.”   
\b  
\m
\v 15 “Xzar, tecnid cem,  
\m tameddukkeč inu!  
\m Xzar, cem tecnid,  
\m tiṭṭawin nnem d idbiren.”   
\b  
\m
\v 16 “Xzar, cek tecnid, \add a\add* llif inu,  
\m wah, tḍarfed,  
\m tuzzizewt d tassut nneɣ,   
\m
\v 17 Tiḥenya n tudrin nneɣ d tineglin,  
\m tiḥenya n tzeqqa  
\m aqa atent d ticejjura n umerzi.”   
\b  
\b  
\m  
\c 2
\s1 Arcam n tesřit  
\m
\v 1 “Necc d tanewwact n Carun  
\m war zzayes wḍant tifray ɛemmarṣ,  
\m d talillect n teysarin.” \f ◼ \fr 2:1 \ft \+fk talillect\ft  - ijj n marka n nnuwarat daysen aẓri aṭṭas.\f*   
\b  
\m
\v 2 “Am tlillect jar tzeggʷart,  
\m ammu i teǧa tameddukkeč inu  
\m jar tyeǧitin.”   
\b  
\m  
\s1 Arcam n yesři  
\m
\v 3 “Am tcejjart n tteffaḥt  
\m jar tcejjura n wezɣar,  
\m ammu i yeǧa llif inu jar warrawen.  
\m Necc aqa ayi mmeẓreɣ  
\m ad qqimeɣ di tiři nnes.  
\m řɣiǧet nnes d miẓid i waneɣ inu. \f ◼ \fr 2:3 \ft \+fk azɣar\ft  - niɣ ‘řɣabet’ niɣ ‘tazgant’.\f*   
\m
\v 4 Netta indeh ayi di taddart n binu,  
\m u \bd tayri\bd* d taɛeǧant nnes xafi.   
\b  
\m
\v 5 Sjehdem ayi s tɣaryiṭatin n zzbib,  
\m sbarrdem ayi s tteffaḥin,  
\m maɣar necc heřceɣ s \bd tayri\bd*.   
\b  
\m
\v 6 Azeřmaḍ nnes sadu uzeǧif inu,  
\m afusi nnes idarreɛ ayi-dd.   
\b  
\m
\v 7 Necc ad kennint ssjaǧaɣ,  
\m \add a\add* yessis n Urcalim,  
\m ɣar tɣayḍin n wezɣar  
\m u ɣar tudadin deg iyyar\add en\add*,  
\m aqa kennint war hekkwřent \bd tayri\bd*,  
\m war tt-i-dd-ssekkarant  
\m ař tᵉttexs simant nnes.”   
\b  
\m  
\s1 Tawasit n yesři  
\m
\v 8 “Tmijja n llif inu!  
\m Aqa da, ittas-dd,  
\m ineṭṭu x idurar,  
\m ineggez x tewririn!   
\b  
\m
\v 9 Llif inu \add yarwes\add* deg iɣayḍ n wezɣar,  
\m niɣ deg ijj n umeẓyan n wudaden.  
\m Aqa-t da, ibedd awarni i řḥiḍ nneɣ,  
\m ixezzar zi řekwazi,  
\m ittceyyeɛ zi ccebbac.”   
\b  
\m  
\s1 Řeɛruḍ n yesři  
\m
\v 10 “Llif inu ittarra-dd, inna ayi:  
\m ‘Kkar, bedd, \add a\add* tameddukkeč inu, aẓri inu,  
\m as-dd!   
\m
\v 11 Maɣar aqa da, tagerst teɛdu,  
\m iksi wenẓar, aqa iruḥ.   
\m
\v 12 Banen-dd inuwwaren di temmurt,  
\m řḥař n wenziz aqa-t da,  
\m u tmijja n tjlilleḥt nesřa i-tt \add ɛawed\add*  
\m di temmurt nneɣ.   
\m
\v 13 Artu n tazart ittxemmař řbacur nnes,  
\m tizayarin ittnewwaren arxun i řefwaḥ.  
\m Kkar, bedd, tameddukkeč inu,  
\m aẓri inu,  
\m as-dd!’”   
\b  
\m  
\s1 Isři yarenni di řeɛruḍ  
\m
\v 14 “Tadbirt inu  
\m deg imucan n udurri di řejruf,  
\m tnuffar di tsawent \add n wedrar\add*.  
\m Ejj ayi ad ẓareɣ aɣembub nnem,  
\m ad sřeɣ i tmijja nnem,  
\m maɣar d tmiẓidt \add i teǧa\add* tmijja nnem,  
\m iṣbeḥ uɣembub nnem.”   
\b  
\m  
\s1 Tasřit texs ad tiři i yesři waha  
\m
\v 15 “Ṭṭfem aneɣ-dd iceɛbawen,  
\m iceɛbawen imeẓyanen,  
\m inni ittarytaren \add aneɣ\add* imarjaɛen n uḍiř,  
\m maɣar tizayarin deg imarjaɛen nneɣ  
\m ttnewwarent \add ɛad\add*.   
\b  
\m
\v 16 Llif inu aqa-t inu u necc nnes,  
\m necc n wenni yarekkwsen jar tlillicin   
\m
\v 17 ař i ɣa ismeḍ wass  
\m u ad arewřent tiřiwin.  
\b  
\m Nneḍ-dd, \add a\add* llif inu,  
\m iři am yijj n iɣayḍ n wezɣar  
\m niɣ am yijj n umeẓyan n wudaden  
\m x idurar \add i ittwaqeḍɛen\add* s teysarin.”   
\b  
\b  
\m  
\c 3
\s1 Mmeẓři n tesřit i yesři  
\m
\v 1 “Arzuɣ xas di ǧyaři  
\m \add am ǧiɣ\add* x tassut inu,  
\m \add arzuɣ x\add* wenni ittexs řeɛmar inu.  
\m Necc arzuɣ xas,  
\m \add maca necc\add* war t ufiɣ.   
\m
\v 2 \add Necc nniɣ\add*: ‘Ad kkareɣ,  
\m ad suḥeɣ di tendint,  
\m deg ibriden u x wazzayen.  
\m Necc ad xas arzuɣ, \add ad arzuɣ\add*  
\m \add x\add* wenni ittexs řeɛmar inu.’  
\m Necc arzuɣ xas, \add maca\add* war t ufiɣ.   
\m
\v 3 Ufin ayi iɛessasen  
\m am ttennḍen di tendint.  
\m Necc nniɣ: ‘Ma teẓrim kenniw  
\m wenni ittexsen řeɛmar inu?’   
\m
\v 4 Řami tuɣa ɛad war xasen ɛduɣ, ufiɣ t,  
\m wenni ittexsen řeɛmar inu.  
\m Necc ṭṭfeɣ t, war zzayes arexxuɣ  
\m ařami t-i-dd-iwyeɣ  
\m ɣar taddart n yemma,  
\m deg wexxam n daxeř  
\m n tenni i dd ayi yurwen.   
\b  
\m
\v 5 Necc ad kennint ssjaǧaɣ,  
\m \add a\add* yessis n Urcalim,  
\m ɣar tɣayḍin n wezɣar  
\m u ɣar tudadin deg iyyar\add en\add*,  
\m aqa kennint war hekkwřent \bd tayri\bd*,  
\m war tt-i-dd-ssekkarant  
\m ař tᵉttexs simant nnes.”   
\b  
\m  
\s1 Tawasit n kula ak-d yesři i řemřac  
\m
\v 6 “Min teɛna tenni i dd-igeɛɛden zi řexřa,  
\m am iqellijen n ddexxan,  
\m deg ijj n useynu n mirru d jjawi,  
\m n marra řebzar ittfuḥen n usebbab? \x ◘ \xo 3:6 \xt Izři 3:6\x*   
\m
\v 7 Xzar, řectu \add n trebbut\add* n Suliman,  
\m ttennḍen as-dd settin n ayt n bu-teɣruḍt,  
\m zeg ayt n bu-teɣruḍt n Israil,   
\m
\v 8 marra inni itteṭṭfen ssif,  
\m inni iřemmden amenɣi,  
\m kuř ijj s ssif nnes ɣar tmeṣṣaḍt nnes  
\m zi ssibbet n min issaggʷaden di ǧiřet.   
\m
\v 9 Ajeǧid Suliman igga i yixef nnes  
\m ijj n řectu i trebbut s ukeccuḍ n Lubnan.   
\m
\v 10 Iɛumad \add ɣar teɣmart\add*  
\m igga i-ten s nnuqart,  
\m aɛemmed n weɛrur n wureɣ  
\m uca aɣimi nnes n arjuwani.  
\m Daxeř nnes yarḍen t  
\m s \bd tayri\bd* n yessis n Urcalim.”   
\b  
\m
\v 11 “Ffɣent u xzarent,  
\m \add kennint\add* yessis n Ṣihyun,  
\m \add aqa da\add* ajeǧid Suliman  
\m ak-d ttaj i zi t tgelled yemmas  
\m deg wass n wurar nnes,  
\m deg wass n řefraḥet \add yuẓɣen\add*  
\m deg wuř nnes.”   
\b  
\b  
\m  
\c 4
\s1 Izři n yesři x tesřit  
\m
\v 1 “Xzar, tecnid cem,  
\m tameddukkeč inu,  
\m cem tecnid.  
\m Awarni lltam nnem  
\m tiṭṭawin nnem d tidbirin.  
\m Acuwwaf nnem  
\m am tḥimart n iɣayḍen  
\m i dd-ihekkwan zeg idurar n Jilɛad.   
\m
\v 2 Tiɣmas nnem ggint  
\m am tḥimart n wuǧi řsin tent,  
\m inni dd-ittgeɛɛaden  
\m zeg wemcan n uṣebben,  
\m marra \add tixeswin\add* urwent tacniwin,  
\m war teqqim ict nbřa iḥenjiren.   
\m
\v 3 Iyencicen nnem  
\m am ufiřu azeggʷaɣ iḥedqen,  
\m iṣbeḥ uqemmum nnem.  
\m Lḥenkat nnem am tremmant ibḍan  
\m sadu lltam nnem.   
\m
\v 4 Iri nnem am ṣṣumɛet n Dawud,  
\m bnan tt am tesfifin \add n tseddyin\add*.  
\m Ařef n tseddariyin \add n uɛeskari\add* uyřent ɣares,  
\m marra am tseddariyin \add iqesḥen iquraren\add*  
\m n ayt n bu-teɣruḍt.   
\m
\v 5 Idmaren nnem ggin  
\m am tnayen n iɣayḍen imeẓyanen,  
\m am wacniwen n tɣayḍet n wezɣar,  
\m ttheddan di tlillicin.\f ◼ \fr 4:5 \ft \+fk tilillicin\ft  - ijj n marka n inuwwaren daysen aẓri aṭṭas.\f*   
\b  
\m
\v 6 Ař i ɣa ismeḍ wass  
\m u ad arewřent tiřiwin,  
\m ad uyureɣ ɣar wedrar n umirru,  
\m ɣar tewrirt n jjawi.   
\m
\v 7 Cem marra d aẓri, tameddukkeč inu,  
\m war dayem uřa d ijj n řɛib.   
\b  
\m
\v 8 \add As-dd\add* akidi zeg \add idurar n\add* Lubnan,  
\m \add a\add* tasřit inu,  
\m as-dd akidi zeg \add idurar n\add* Lubnan,  
\m ṣwed-dd zi tqiccet n Amana,  
\m zi tqiccet n Canir d Hirmun,  
\m zi ɣar řmarageḥ n wayraden,  
\m zeg idurar n iɣiřasen.   
\m
\v 9 Tucared ayi uř, \add a\add* učma, \add a\add* tasřit \add inu\add*,  
\m \add wah\add* tucared ayi uř,  
\m s ict n \add řxezrat n\add* tiṭṭawin nnem,  
\m s ict n tseddect n yiri nnem.   
\m
\v 10 Mammec tecna usḥinneb nnem,  
\m \add a\add* učma, \add a\add* tasřit \add inu\add*,  
\m mecḥař teṣbeḥ usḥinneb nnem x binu,  
\m řefwaḥet n zzect nnem x marra řeɛṭur.   
\m
\v 11 Zeg iyencicen nnem, \add a\add* tasřit \add inu\add*,  
\m tᵉttudum tamment n teɣraṣt,  
\m tamment d uɣi sadu iřes nnem,  
\m u řefwaḥet n warruḍ nnem  
\m am řefwaḥet \add n idurar n\add* Lubnan.   
\b  
\m
\v 12 \add A\add* učma, \add a\add* tasřit \add inu\add*,  
\m cem d taḥwict ibellɛen,  
\m d tařa iqqnen, d řɛunṣar icemmɛen.   
\m
\v 13 Řefruɛ i zzayem issneṭṭiyen  
\m d jennet n tremmanin,  
\m s řɣiǧet iṣebḥen aṭṭas,  
\m nnewwac n řḥenni d ṣṣenbel,   
\m
\v 14 ṣṣenbel d zzɛefran,  
\m s uɣanim uḥemmum ittfuḥen  
\m ak-d řqarfa,  
\m ɛřam kuř ticejjura n jjawi,  
\m mirru d wecfiř,  
\m ak-d marra řeɛṭur iṣebḥen qaɛ.   
\m
\v 15 \add A\add* tařa n iḥwicen,  
\m anu n waman iddaren,  
\m inni dd-ittazzřen zeg \add idurar n\add* Lubnan.”   
\b  
\m  
\s1 Tasřit tessiweř, isři yarra-dd  
\m
\v 16 “Kkar, \add a\add* asemmiḍ n nnej,  
\m as-dd, \add a\add* asemmiḍ n swadday,  
\m suḍ x weḥwic inu,  
\m ejj \add řefwaḥet n\add* řeɛṭur nnes ad tuyur.  
\m Ejj llif inu ad dd-yas ɣar weḥwic nnes,  
\m ad icc zi řɣiǧet nnes iṣebḥen!”   
\b  
\b  
\m  
\c 5
\m
\v 1 “Necc usiɣ-dd ɣar weḥwic inu,  
\m \add a\add* učma, \add a\add* tasřit inu,  
\m řeqḍeɣ mirru inu ak-d balsam. inu,  
\m cciɣ aɣrum n tzizwa ak-d tamment inu,  
\m swiɣ binu inu d uɣi inu.  
\m Imeddukkař, eccem, swem,  
\m scarem, \add a\add* imɛizzen!” \f ◼ \fr 5:1 \ft \+fk azɣar\ft  - niɣ ‘řɣabet’ niɣ ‘tazgant’.\f*   
\b  
\m  
\s1 Tasřit tzehza ad tarzem i yesři  
\m
\v 2 “Necc ṭṭseɣ, maca uř inu ifaq.  
\m \add Aqa da\add* tmijja n llif inu,  
\m wenni issqarqben:  
\m ‘Arzem ayi, \add a\add* učma, tameddukkeč inu,  
\m tadbirt inu, \add a\add* kuřci inu,  
\m maɣar azeǧif inu iccur s nnda,  
\m imuzaren inu \add ccuren\add* s tuddimin n ǧiřet!’   
\b  
\m
\v 3 Aqa kkseɣ arruḍ inu,  
\m mammec i t ɣa yarḍeɣ ɛawed?  
\m Iḍaren ssirdeɣ ten,  
\m ma ad ten ssxemjeɣ ɛawed?   
\b  
\m
\v 4 Llif inu issekk-dd afus nnes  
\m zeg unuqqib n tewwart,  
\m uca inhezz wuř inu zzayes.   
\b  
\m
\v 5 Necc beddeɣ ḥima ad arzmeɣ i llif inu,  
\m ifassen inu udumen s mirru,  
\m \add zeg\add* iḍewḍan inu issizzeř mirru  
\m x ifassen n zzekrun.   
\m
\v 6 Necc arzmeɣ i llif inu,  
\m \add maca\add* llif inu tuɣa yuyur, iɛdu.  
\m Iffeɣ řeɛmar inu umi tuɣa issawař!  
\m Necc arzuɣ xas, \add maca\add* war t ufiɣ.  
\m Necc řaɣiɣ as, netta war xafi dd-yarri.   
\b  
\m
\v 7 Ufin ayi iɛessasen  
\m ɣar wenneḍ nsen di tendint,  
\m nitni wtin ayi, yezmen ayi,  
\m aqendur inu kksen ayi t iɛessasen n řeḥyuḍ.”   
\b  
\m  
\s1 Izři n tesřit ak-d yessis n Urcalim  
\m
\v 8 “Necc ad kennint ssjaǧaɣ,  
\m \add a\add* yessis n Urcalim,  
\m mařa kennint tufint llif inu,  
\m min d as ɣa tinint?  
\m Aqa tesseḥřec ayi \bd tayri\bd*.”   
\b  
\m
\v 9 “Min ɣares ɣar llif nnem  
\m ktar x llif \add nneɣni\add*,  
\m \add a\add* cem i di iǧa waẓri qaɛ zi temɣarin?  
\m Min ɣares ɣar llif nnem ktar x inneɣni,  
\m aqa cem ammu i d aneɣ tᵉssjaǧad?”   
\b  
\m
\v 10 “Llif inu d acemřař \add ittissiqen\add*  
\m d azeggʷaɣ \add am idammen\add*,  
\m \add ittban\add* am ubandu sennej x ɛecra n řuřuf.   
\m
\v 11 Azeǧif nnes d ureɣ iqqur iṣfan,  
\m imuzaren n ucuwwaf nnes d tiwririn  
\m itteggen am řemwaj,  
\m d ibarcanen am yibaɣřiwen.   
\m
\v 12 Tiṭṭawin nnes ggint am tedbirin  
\m ɣar tseǧyawin n waman,  
\m ɛumment deg uɣi,  
\m qqiment di tcuyar nsen  
\m \add am iẓra iɣřan\add*.   
\m
\v 13 Imeggizen nnes ggin  
\m am yiḥwicen n řeɛṭur,  
\m \add ccuren s\add* řeɛcub ittfuḥen,  
\m iyencicen nnes am tlillicin,  
\m ttudumen s mirru ifesyen. \f ◼ \fr 5:13 \ft \+fk tilillicin\ft  - ijj n marka n nnuwarat daysen aẓri aṭṭas.\f*   
\m
\v 14 Iɣaǧen nnes am yiqeḍban n wureɣ,  
\m ɛemmarent s \add iẓra n\add* texrisulit,  
\m aɛeddis nnes igga am řɛaj ittissiqen,  
\m řeḥḥfen t s tyaqutin n ṣaffir. \f ◼ \fr 5:14 \ft \+fk řɛaj\ft  - ixs ad yini ‘accawen n lfil’.\f*   
\m
\v 15 Imesḍan nnes d ipilaren n řmarmur,  
\m x dsusa n wureɣ ittwaṣeffan.  
\m Iban-dd netta am Lubnan,  
\m ittwafarz am \add tcejjart n\add* tengelt.   
\m
\v 16 Aneɣ nnes iccur s taẓyudi,  
\m marra i ɣares icuwwar.  
\m Wa d llif inu,  
\m wa d ameddukkeř inu,  
\m \add a kennint\add* yessis n Urcalim!”   
\b  
\b  
\m  
\c 6
\s1 Taneggarut n izři n tesřit  
\m
\v 1 “Mani yuyur llif nnem,  
\m \add a\add* cem icnan qaɛ x temɣarin?  
\m Mani yarra s uzeǧif llif nnem?  
\m Neccin nexs ad xas narzu akidem!”   
\b  
\m
\v 2 “Llif inu ihwa ɣar uḥwic nnes,  
\m ɣar tbuda s řeɛṭur,  
\m ḥima ad yarwes deg iḥwicen,  
\m ḥima ad issmun tilillicin. \f ◼ \fr 6:2 \ft \+fk tilillicin\ft  - ijj n marka n nnuwarat daysen aẓri aṭṭas.\f*   
\m
\v 3 Necc zeg llif inu,  
\m u llif inu aqa-t inu,  
\m netta d wenni yarekkwsen jar tlillicin.”   
\b  
\m  
\s1 Asři iɣennej x weẓri n tesřit  
\m
\v 4 “Cem tṣebḥed, \add a\add* tameddukkeč inu,  
\m amecnaw Tirṣa,  
\m tecnid am Urcalim,  
\m tessaggʷaded am yiseddiyyen n řɛeskar  
\m s ibanduten \add nsen\add*.   
\m
\v 5 Kkes tiṭṭawin zzayi,  
\m maɣar nitenti ɣeḍřent ayi ifadden aṭṭas.  
\m Acuwwaf nnem am tḥimart n iɣayḍen  
\m i dd-ihekkʷan zeg \add idurar n\add* Jilɛad.   
\m
\v 6 Tiɣmas nnem ggint am tḥimart n wuǧi,  
\m i dd-ittgeɛɛaden zeg wemcan n uṣebben.  
\m Marra \add tixeswin\add* urwent tacniwt,  
\m war teqqim ict nbřa iḥenjiren.   
\m
\v 7 Lḥenkat nnem am tremmant ibḍan  
\m awarni i lltam nnem.   
\m
\v 8 Aqa din settin n tjeǧidin  
\m d tmenyin n tiyya,  
\m uřa d tiɛzariyyin břa řeḥsab.   
\m
\v 9 Weḥḥdes nettat, tadbirt inu,  
\m tenni ikemmřen inu,  
\m ayenni n yessis n yemmas,  
\m nettat d tenni ifarzen  
\m ɣar tenni i d as dd-yurwen.  
\m Mařa zřint tt tyessit, ad tt ssɛuǧant,  
\m tijeǧidin d tiyya ad tt ssemɣarent.”   
\b  
\m
\v 10 “Min teɛna tenni dd-issijjen  
\m am tfawt n řefjar,  
\m tecna am tziri iqefřen,  
\m teṣfa am tfuct yareqqen,  
\m tessaggʷad am yiseddiyyen n řɛeskar  
\m s ibanduten?”   
\b  
\m  
\s1 Tseḍḥi tesřit  
\m
\v 11 “Necc ḥwiɣ ɣar teḥwict  
\m n tcejjura n teɣyact  
\m ḥima ad ẓareɣ  
\m aɣemmuy ibedden di teɣzurt,  
\m ḥima ad ẓareɣ ma tazayart tessuffeɣ-dd,  
\m ma ticejjura n aremman ttnewwarent.   
\m
\v 12 Tuɣa war dd-arriɣ taynit  
\m aqa ggiɣ ixef inu  
\m deg ikarruten n řgens inu igellden.”   
\b  
\b  
\m  
\c 7
\s1 Aẓri n tesřit ɣar ccdiḥ  
\m
\v 1 “Ɛqeb-dd, ɛqeb-dd, \add a\add* Culamit!  
\m Ɛqeb-dd, ɛqeb-dd,  
\m maḥend ad dayem nexzar.”  
\b  
\m “Min texsem ad tẓarem di Culamit?”  
\b  
\m “\add Nettat\add* am ccḍiḥ s nnubtat  
\m n tnayen n řɛeskarat.”   
\b  
\m
\v 2 “Mecḥař cnan iṣuraf nnem  
\m di ṣandaliyyat \add nnem\add*,  
\m \add a, cem\add* yessis n ijj n umcenneɛ!  
\m Aḥnunni n tmeṣṣaḍt nnem  
\m am tseddyin iɣřan  
\m \add ttraḥent ttasent-dd\add*,  
\m ṣṣenɛet n ifassen n ufennan.   
\m
\v 3 Taɛebbuḍt nnem  
\m am tsarijt teḥnunni,  
\m mani war ittxeṣṣi binu ixeǧḍen.  
\m Aɛeddis nnem d akemmic n irden,  
\m nnḍent as-dd tlillicin. \f ◼ \fr 7:3 \ft \+fk tilillicin\ft  - ijj n marka n nnuwarat daysen aẓri aṭṭas.\f*   
\m
\v 4 Idmaren nnem \add ggin\add*  
\m am tnayen n iɣayḍen imeẓyanen,  
\m am wacniwen n tɣayḍet n wezɣar.   
\m
\v 5 Iri nnem igga am ṣṣumɛet n řɛaj,  
\m tiṭṭawin nnem  
\m am yiyeřmamen n Ḥacbun,  
\m ɣar tewwart n Bat-Rabbim,  
\m tinzart nnem am ṣṣumɛet n Lubnan  
\m i issajjan ɣar Dimacq.   
\m
\v 6 Tiwa nnem \add igga\add* azeǧif nnem  
\m am Karmil,  
\m acuwwaf n uzeǧif nnem d arjuwani,  
\m ajeǧid ittwaḥbes deg imuzaren nnem.”   
\b  
\m
\v 7 “Mecḥař tecnid cem,  
\m u mecḥař tṣebḥed, \add a\add* \bd tayri\bd*,  
\m di \add kuřci\add* min izemmar bnadem  
\m ad yarr meẓri!”   
\b  
\m  
\s1 Awař n yesři uca tasřit tarni dayes  
\m
\v 8 “Tiddi nnem tarwes di tcejjart n tini,  
\m idmaren nnem deg izekkunen n uḍiř.   
\m
\v 9 Necc nniɣ: ‘Ad nyeɣ x tcejjart n tini,  
\m ad ṭṭfeɣ di řefruɛ nnes.’  
\m Idmaren nnem \add ad iřin\add*  
\m am izenkak n uḍiř ɣar tzayart,  
\m řefwaḥet n wenzaren nnem  
\m am tteffaḥin,   
\m
\v 10 aneɣ nnem am binu iṣebḥen aṭṭas ...”,  
\b  
\m “... wenni ittraḥen nican ɣar llif inu,  
\m wenni ittarran iyencicen  
\m n yinni iṭṭṣen ad nhezzen.”   
\b  
\m
\v 11 “Necc n llif inu,  
\m ɣari dd-ittas meẓri nnes.   
\m
\v 12 As-dd, llif inu,  
\m ejj aneɣ ad nuyur ɣar yeyyar,  
\m ad nessens di ředcur.   
\m
\v 13 Ejj aneɣ ad nekkar zic  
\m ḥima ad nuyur ɣar imarjaɛen n uḍiř,  
\m ejj aneɣ ad nẓar,  
\m ma tazayart \add aqa\add* tessuffuɣ,  
\m ma nnuwwar nnes nnurzmen,  
\m ma ticejjura n aremman newwarent.  
\m Dinni i d ac ɣa wceɣ asḥinneb inu.   
\m
\v 14 Ttiffaḥin n tayri arxunt i řefwaḥ  
\m u tiwa n tewwura nneɣ  
\m aqa din frutat icewwaren,  
\m tinni n ṭṭri d tinni ittwaxemmřen.  
\m \add A\add* llif inu, xemmřeɣ tent i cek!”   
\b  
\b  
\m  
\c 8
\s1 Tasřit tkemmeř awař nnes  
\m
\v 1 “Ax, meɛlik qaɛ cek d uma,  
\m tᵉṭṭeḍed di tbibbicin n yemma.  
\m Mařa ufiɣ cek di barra, ad cek ssudmeɣ,  
\m břa ma d ayi sseḥqaran.   
\m
\v 2 Iři ad cek nedheɣ, ad cek awyeɣ  
\m ɣar taddart n yemma,  
\m cek ad ayi tessřemded \add din\add*.  
\m Ad ac wceɣ binu ittfuḥen  
\m s řeɛṭur ad teswed,  
\m aẓemmi n \add tcejjart\add* inu \add n\add* waremman.   
\b  
\m
\v 3 Azeřmaḍ nnes sadu uzeǧif inu,  
\m afusi nnes idarreɛ ayi-dd.   
\b  
\m
\v 4 Necc ad kennint ssjaǧaɣ,  
\m \add a\add* yessis n Urcalim:  
\m Mayemmi ɣa thewřent \bd tayri\bd*  
\m niɣ ad tt-i-dd-tessekkarent,  
\m qbeř ma tᵉttexs nettat?”   
\b  
\m  
\s1 Tasřit teffeɣ-dd zi řexřa ak-d yesři nnes  
\m
\v 5 “Min teɛna nni \add din\add* ittgeɛɛaden zi řexřa,  
\m tᵉttɛemmed x llif nnes?”  
\b  
\m “Sadu \add tcejjart\add* n tteffaḥt  
\m arreɣ meẓri nnem,  
\m mani cem dd-tejja yemmam  
\m s řeḥriq n tarwa,  
\m mani cem dd-tejja  
\m tenni cem dd-yurwen.” \x ◘ \xo 8:5 \xt Izři 8:5\x*   
\b  
\m
\v 6 “Sars ayi am ṭṭabeɛ x wuř nnec,  
\m am ṭṭabeɛ x uɣiř nnec,  
\m maɣar \bd tayri\bd* tejhed am řmewt,  
\m tusmi teqseḥ am řaxart,  
\m tifeṭṭutin nnes d tifeṭṭutin n tmessi,  
\m \add aqa atent\add* am uceɛɛař n SIDi.   
\m
\v 7 Aṭṭas n waman  
\m war zemmaren ad ssxesyen \bd tayri\bd*,  
\m uřa d iɣezran war tt ttiwyen.  
\m Waxxa iwca ijjen i \bd tayri\bd*  
\m marra agřa n taddart nnes,  
\m ad t sseḥqaren d aseḥqar.”   
\b  
\m  
\s1 Tasřit d aytmas  
\m
\v 8 “Neccin ɣarneɣ  
\m ict n učmatneɣ tameẓyant,  
\m ɛad war d as dd-ffiɣen idmaren.  
\m Min ɣa negg i učmatneɣ  
\m deg wass i di xas i ɣa ssiwřen?”   
\b  
\m
\v 9 “Mařa nettat d řḥiḍ,  
\m ad xas nessbedd acbar  
\m \add am ijj n ttaj\add* n nnuqart.  
\m Mařa nettat d tawwart,  
\m ad tt neqqen s tfeřwin n ukeccuḍ n tengelt.”   
\b  
\m
\v 10 “Necc d řḥiḍ u idmaren inu am lburjat.  
\m Xenni dewřeɣ necc di tiṭṭawin nnes  
\m am tenni yufin řeḥna.”   
\b  
\m  
\s1 Aḥwic n tzayart n Suliman d weḥwic n tzayart n tesřit  
\m
\v 11 “Suliman tuɣa ɣares  
\m ijj n umarjeɛ n uḍiř di Baɛl-Hamun.  
\m Iwca amarjeɛ nni i iɛessasen.  
\m I řɣiǧet nnes qaɛ ijj yiwi-dd  
\m ařef n řewzen n nnuqart.” \x ◘ \xo 8:11 \xt Ica. 7:23\x*   
\b  
\m
\v 12 “Aḥwic n uḍiř inu,  
\m aqa-t zzat i tiṭṭawin inu.  
\m Ařef n řewzen n nnuqart  
\m aqa aten i cek, \add a\add* Suliman,  
\m u ařfayen i iɛessasen n řɣiǧet zzayes.”   
\b  
\m  
\s1 Ařaɣi n yesři d tesřit  
\m
\v 13 “\add A cem\add* tenni izeddɣen deg iḥwicen,  
\m iɛciren \add nnem\add* ttesřan \add s imezzuɣen nsen\add*  
\m i tmijja nnem,  
\m \add qqaren:\add* ‘Ejj ayi ad tt sřeɣ!”   
\b  
\m
\v 14 “Deɣya, \add a\add* llif inu,  
\m egg am yiɣayḍ n wezɣar  
\m niɣ am umeẓyan n udaden,  
\m x idurar \add iccuren\add* s řeɛcub ittfuḥen.”   