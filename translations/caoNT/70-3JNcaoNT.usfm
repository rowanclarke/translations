\id 3JN - Chácobo NT -Bolivia 2010 (DBL -2013)
\h 3 San Juan
\toc1 Tercera Carta Del Apostol San Juan
\toc2 3 Juan
\toc3 3 Jn
\mt2 Tercera Carta Del Apostol
\mt1 San Juan
\c 1
\p 
\v 1 Juan yosi tsi xo naa chani quënëti ibo. Mia joihuaquia, noho rabëti Gayó. Mia noiquia Jesucristo tahëxo na.
\v 2 ¿Jënima ni mia? Mi bax bëhoxquia, jia tsi mi bësono, mi jënimariano, naa jënima mi shina nori ca jascaria.
\v 3 Mia ë nicahitaquë, toá ca xatë bo huësti huësti cabo cahëquë no. Cahëxo tsi quiha mi Ibo qui chitimiriahaina, jabija ca quinia ó tsi mi bësohaina, tihi cabo yoati ëa ja yoacahitaquë. Nicahax ë rani-ranihitaquë.
\v 4 Jabija ca quinia ó tsi noho xocobo bësono tsi rani-raniquia nicahax na. Yama tsi xo toa ëa ranihuahai ca oquë cato iquia.
\p 
\v 5 Jia tsi xo toa nobë xatë bo, naa mi bëroma ca xatë bo mi mëbihaina iquia, ëbë xatë́.
\v 6 Mi mëbihai ca iqui tsi noqui, naa nëá ca iglesia qui bëroria tsi xo toa mi noihaina. Jasca, Dios qui jia ca quiniá tsi jia tsi toa xatë bo jari mi mëbino, ja narisyamacano ja bocaquë no.
\v 7 Bohocani quiha Cristo bax yonocohi na. Yonocohax tsi Dios cahëyamacanaibá jato mëbihai ca ó pasoyamacani quiha.
\v 8 Ja tsi xo toa toca cabo no mëbixëti xo jia tsi Dios Chani ja yoacano iquish na. Tocapihi tsi jato yonoco xatënaqui noa jato bëta.
\s1 Diótrefes jabi yoi cato
\p 
\v 9 Toá ca iglesiá ca chahahuacanaibo qui carta ë raaniquë jato yobaxëna. Jama, ë yoahai ca chahahuayamahi quiha toá ca Diótrefes rë, naa toá ca xatë bo yonacatsai cato.
\v 10 Anoma quiha. Joquí tsi noqui ja ocahuahaina, ja quiahaina, tihi cabo nicamaxëquia pë. Jasca, raniyamaquí tsi no raani ca xatë bo joihuayamahi quiha pë. Jasca, iglesiá cabo quëtiahi quiha rë, jato chani ja nicayamacano iquish na. Jatsi jato chani nicacascanaibo raahi quiha pë iglesia quima.
\p 
\v 11 Jisa, ëbë xatë́. Anoma tsi xo toa joní acaina iquia. Mi tocayamano ra. Oquë tsi xo toa quinia jia ca mi banahuahaina. Jia ca acai ca tsi xo toa Dios baquë yoi. Jama, yoi ca pi aquí tsi Dios cahëyamaqui toa iquia.
\s1 Demetrio jabi jia cato
\p 
\v 12 Demetrio yoati tsi nohiria bo chanino tsi jia tsi xo toa ja yoacanaina. Jabija tsi xo toa jia ca ja acaina iquia. Shinajiaxëni ca joni tsi xo naa ra. Jabija ca ë yoahai ca nori ca cahëqui mia tia.
\s1 Jaroha ca yoba
\p 
\v 13 Jari tobi huëstima ca ë yoacatsaina rë. Jaboqui papí tsi quënënoma xo.
\v 14 Mi qui shishoti ó pasoquia. Toatiyá tsi jia tsi chaninabëquixëqui noa.
\p 
\v 15 Mi rani-ranino. Mia joihuahi quiha nëá ca rabëti bo. Jasca, toá ca noba rabëti bo tëquë ë bax mi joihuano. Iquë. Amén.
