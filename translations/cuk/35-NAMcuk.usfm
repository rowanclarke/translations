\id NAM - Kuna, San Blas - Bible -Panama 2014 (DBL -2014) 
\h Nahúm 
\toc1 Nahúm-Garda 
\toc2 Nahúm 
\toc3 Na 
\mt1 NAHÚM-GARDA 
\mt2 NAHÚM 
\imt2 GEBE-SOGLENAID 
\imt1 Garda-nug 
\ip \it Nahúm-Garda.\it* Nahúm, Elcos-neggweburginedid. \it Jehová gwage-armaksaye,\it* Nahúm-nug obarileged. 
\is1 Nahúm-Gardagi weyob sunmaklenaid 
\ip Nahúm, negburgan daksad. Nahúm Judá-yalagi Bab-igargi sunmakdii gusad. Nínive-neggwebur-odurdaklegoedgi bur sunmakdii gusad. We-neggwebur bela-bela gangued-nika-siidbali, dulemar-baigan wioali gusad. Nínive-neggwebur sabsur-ibitosgua, bela dulemar-yar-baid-baidginmalad egi wergunai gusmalad. 
\ip We-gardagine, weyob ilemakar sunmaklenaid: 
\io1 1. Bab-Jehová e-urwedgi bugedmai imaked (1:1-14). 
\io1 2. Nínive-neggwebur berguoed (1:15–2:12). 
\io1 3. Nínive-neggweburginmalad wiledar-itomaloed (2:13–3:19). 
\ip Be itogua. 
\c 1  
\ms1 1. BAB-JEHOVÁ E-URWEDGI BUGEDMAI IMAKED 
\mr (1:1-14) 
\p  
\v 1 Nahúm-negburgan-daksad-e-garda. Nahúmʼde Elcos-neggweburgined. We-gardagi Bab-Jehová Nínive-neggweburgi neg-guoed sogsad. 
\s1 Bab-Jehová-magarosad 
\q1  
\v 2 Bab-Jehová, unnila dule-ebarbi-nanabi abeged, 
\q2 buged-mai dule-imakedbalid. 
\q1 Bab-Jehová dule-buged-mai-imakedid, 
\q2 e-isdarmaladse urwedid. 
\q1 Bab-Jehová, dule-egi-yoledimalad buged-mai imaked, 
\q2 e-isdarmalad ese sabsur-odurdakleged. 
\q1  
\v 3 Bab-Jehová wissur gwae-gwae urwed. 
\q2 Bab-Jehová bela-bela gangued nikad. 
\q2 Bab-Jehová dule-ibmar-oakalosad sabsur-odurdakedsegad. 
\q1 Bab-Jehová burwa-oored-abargi, burwa-dummad-abargi gudidaed, 
\q2 mogir Bab-Jehová-e-nanaedba ukub-ainakweyobi gued. 
\q1  
\v 4 Bab-Jehová demarga ibmar binnasur sogdele, demar dinnaa naddaed. 
\q2 Bela diwarmar dinnaa guega imakbalid. 
\q1 Basán-yar, degi, Carmelo-yar bela dinguded, 
\q2 Líbano-yar-dutumar bela dingudbalid. 
\q1  
\v 5 Bab-Jehová-asabin yarmar giglimakdedaed, 
\q2 yar-mullugan babatiddaed. 
\q1 Bab-Jehová-asabin napneg giglimakdedaed, 
\q2 Bab-Jehová-asabin napneg-dirbir-naid, 
\q2 degi, bela egi bukmalad wawanmakdedaed. 
\q1  
\v 6 Bab-Jehová-e-urwed-abin, ¿doa gwisguoe? 
\q2 Bab-Jehová-e-sae-itoged-abin, ¿doa gannarbaa gwisguoe? 
\q1 Bab-Jehová-e-urwedi, soo-gwabunye-gwichidyobi gued, 
\q2 e-asabin akwasailagan bela ese ubigwar gued. 
\s1 Nínive-neggwebur berguoed 
\q1  
\v 7 Bab-Jehová, duledar-nuedid, 
\q2 suli-suli-itogedgine, anmar-odukuedid. 
\q2 Dule-egi-bensurmalad-bendakedid. 
\q1  
\v 8 Bab-Jehová Nínive-neggwebur diwar-dummad-noedbali obelogoed. 
\q2 Bab-Jehová amba negsichidgine e-isdarmalad-baleginnoed. 
\q1  
\v 9 Bab-Jehováʼgi-gwisguega, ¿ibiga bemar igar-isgana aminanai? 
\q2 Bab-Jehová bela bemar-giir imakoed, 
\q2 bemar-wiledakega bar iba-baid nasikosulid. 
\q1  
\v 10 Bemar gagan-dinnagwadyobi bergumaloed, ikomar-dinnagwadyobi bergumaloed, 
\q2 Dule vino-doggus-gobsadba bar-itodisurdaedyobi bemar guoed. 
\q1  
\v 11 Be, Nínive-neggwebur, begi dule-binsaed-uked-isgana gwalulesad. 
\q2 A-dule, Bab-Jehováʼgi igar-isgana amied. 
\s1 Mesagwar-dule-imakdiidgi ollorgued 
\p  
\v 12 Bab-Jehová weyob soged: 
\q1 “Asiria-dulemar nollosurgumala-inigwele, bergumaloed. 
\q2 Asiria-dulemar dula-bukidar-inigwele, burgwemaloed. 
\q1 Bedi, Judá-dulemar, an sabsuli-be-wiosmala-inigwele, 
\q2 bar deyobi, an be-wiogosurmalad. 
\q1  
\v 13 Dulemar-sabsur-be-imakdimaladgi an be-ollor-imakoed, 
\q2 bar be maiga-gudii guosurmalad.” 
\b  
\q1  
\v 14 Bemardi, Nínive-dorgan, Bab-Jehová bemarga igar-mesisad: 
\q2 “Mimmigan bar be nikuosurmarye, 
\q2 adi, be-nug mer bar degisadegu obarledii guegarye. 
\q1 Be-bab-dummadse-goled-neggi ibmar-wagar-sobarmar-bukwad, 
\q2 esgoro-gordikidgi ibmar-bab-dummadyob-sobar-bukwad, an obelogoed. 
\q1 Ar be dule-isganasoggu, 
\q2 an bega neg-uan guagwar sioed.” 
\ms1 2. NÍNIVE-NEGGWEBUR BERGUOED 
\mr (1:15–2:12) 
\s1 Nínive-dorgan-galakuoed-igar 
\q1  
\v 15 ¡Be dakmala! Dule-gayaburba-nuegan-berbegedi, 
\q2 dule neg-bogidik-naguoedgi-sunmakedi, bato yalaganba danikid. 
\q1 Judá-dulemar, be-iba-onomaladgi, be wergumala, 
\q2 Bab-Jehováʼga be ibmar-ukoye-sogsad be uke. 
\q1 Ar dule-isganamar bar be-yarse ubogosurmalad, 
\q2 ar bela Bab-Jehováʼse giir gusmalad. 
\c 2  
\s1 Nínive-neggwebur berguoed 
\q1  
\v 1 Nínive-dorgan, bemargi dule-ibmar-obeloged gwichigudanikid, 
\q2 be-neggandikidgi, be nakulegwichi imake. 
\q1 Be-igarmarba be nakulemala, es-suid be guagwar gamala, 
\q2 bela bemar na niga ogannomala. 
\q1 Danale be ambikumala, 
\q2 adi, na be gargangued nikumalagar. 
\q1  
\v 2 Ar Bab-Jehová Jacob-dulemar-e-yeerdakleged gannar obinoged. 
\q2 Israel-dulemar-e-yeerdakleged gannar obinoged. 
\q1 Ar dule-atursamalad e-ibe ibmar susmalanad, 
\q2 bela e-ibe uva-dub obelosmalanad. 
\b  
\q1  
\v 3 E-sorda-bila-onomalad-bulegan-e-sigu-abgamalad, ginnitibi magaled, 
\q2 sordamar-bila-onomalad mor-ginnigan yoimalad. 
\q1 E-ur-napaginmalad guagwar bila-onogega-nanaidi, soo-gaeyobi dakarmaknanaid. 
\q2 Sorda-bila-onomalad e-eswarmar-gani-gani, sakwa bipinmakdanimalad. 
\q1  
\v 4 E-ur-napaginmalad neg-imbaba gwae-gwae oabarmakdemalad, 
\q2 binnasuli dulemar-danar-bukumaladgi iirmakdidimalad. 
\q1 Acha-gwallu-gaeyobi urmar daklenanaed, 
\q2 mar-gaeyobi dakar-dakar gamalad. 
\s1 Nínive-neggwebur-bergusad, degi, e-ibe ibmar-sulesad 
\q1  
\v 5 Nínive-e-rey e-sordagan-bila-onomalad-buleganse goled, 
\q2 we-sordagan duurmakdegua, na muchub-muchub yolenanai gusad. 
\q1 Egi-ubodanimalad-abin-bukuega, galu-matusulidsik abarmakdemalad, 
\q2  
\v 6 degi-inigwele, yawagak-dummagan-diwar-abgamaid argaded, reyneg aimukuded. 
\q1  
\v 7 Rey-ome gales selemaid, 
\q2 omegan-ega-arbamaladi nuu-akiginmaiyobi selemamaid, 
\q2 nue-nunmak-itogedbali bonadapmalad. 
\b  
\q1  
\v 8 Nínive-neggwebur dii-sied-mamarisadyob gued, e-diimar ariomaid. 
\q2 Ese gornanaid: “¡Mer be abarmakmala! ¡Be gannar dagmala!” 
\q2 Ar dule-wargwensaar gwen gannar aibirsulid. 
\q1  
\v 9 ¡Mani be sumala! 
\q2 ¡Or be atursamala! 
\q1 Nínive-neggwebur e-ibmar-nuegan yaisulid, 
\q2 manimar bukidar nikad, ibmar-yeerdaklemalad bukidar nikbalid. 
\q1  
\v 10 Nínive-neggwebur bergus siid, 
\q2 dule-sate siid, napabi-nai nagusad. 
\q1 Dobedbali dulemar nig-argwatemalad, 
\q2 e-yokormar nollomakded. 
\q1 Bela e-abagan wawanmakded, 
\q2 e-wagarmar bela sibudiki daklenaded. 
\s1 Achumigur-nono-wawaad-obelolegoed 
\q1  
\v 11 Achumigur-nono-wawaad-e-neg, ¿bia nade? 
\q2 Achumigur-e-mimmigan-e-neg, ¿bia nade? 
\q1 A-neggine, achumigur-machered, e-ome, degi, e-mimmigan, dule-e-ogwayed-sate, dobsuli mamaidaenad. 
\q2  
\v 12 Achumigur-machered na e-mimmiganga san-goa-goa-imakdidaedi, ¿bia nade? 
\q1 Na e-omeganga ibdurgan-oburgwedaedi, ¿bia nade? 
\q2 Na e-megedgi ibdurgan-oburgwisad-urbedidaedi, ¿bia nade? 
\q2 Na e-neggi san-sabodidaedi, ¿bia nade? 
\ms1 3. NÍNIVE-NEGGWEBURGINMALAD WILEDAR-ITOMALOED 
\mr (2:13–3:19) 
\p  
\v 13 Bab-Jehová Bela-Gangued-Nikad weyob soged: 
\q1 “Emigindi, an bemargi gwisguega danikid. 
\q2 Be-urmar-napagined-bila-onomalad burubi-sii an imakoed, 
\q2 be-achumigur-burwigana an es-suidgi oburgoed. 
\q1 Ibmar-atursamaladi be-yargi an osulogoed, 
\q2 be-dule-gayaburba-barsogmalad bar bipisaale itolegosulid.” 
\c 3  
\s1 Nínive-neggwebur-berguoedgi sunmaklenaid 
\q1  
\v 1 Neggwebur-dulemar-ablis-eogedbi-siid, be ¡duledar-wiles! 
\q2 Bela begi neg-gakansalegedbi naid, 
\q1 begi bela-bela ibmar-atursalegedbi naid, 
\q2 ibmar-atursaedi gwen be indaksulid. 
\q2 Be deyob gusiidi, be ¡duledar-wiles! 
\q1  
\v 2 Molidub-suid-goledi bato itoleged. 
\q2 Ur-napaginmalad-e-nagmar-bipirmaknaid-goled bato itoleged. 
\q1 Moli-nag-goledi bato itoleged, 
\q2 bila-onomalad-ur-napaginmalad e-gollomakedi bato itoleged. 
\q1  
\v 3 Sorda-moli-birgi-sii-bila-onomalad-danimalad itoleged. 
\q2 Es-suid-e-dakarmaked mag dakleged, 
\q1 eswar-dakar-dakar-gaed mag dakleged. 
\q2 Dulemar-burgwarmaladi yaisulid. 
\q1 Muimar odunnumakded, 
\q2 muimar baid-baidsik omileded, 
\q2 dulemar a-muimargi yolenanaid. 
\q1  
\v 4 Ar ome-gambasaed macherganga yamo-yamo-gudidaed-ular, deyobi neg-gunonikid. 
\q2 We-omede, dule-binsaed-gaed-buledid. 
\q1 E-gambanuchu-saedgi dulemar-yardaksad, 
\q2 e-inamar-isgana-imakedgi dulemar-yardaksabalid. 
\p  
\v 5 Bab-Jehová-Bela-Gangued-Nikad weyob soged: 
\q1 “¡An bemargi gwisguega danikid! 
\q2 Be-sabure wagarse an be-ibe onakoed, 
\q1 adi, dulemar-yar-baid-baidgi-bukmalad uka-swiri be-dakmalaga, 
\q2 dule-yar-dummaganginmalad be-binge-itoged dakmalagar. 
\q1  
\v 6 Begine an ibmar-isgana mioed, 
\q2 an be-nug oichogoed, 
\q2 dulemar-abargi-oyolegega an be-imakoed. 
\q1  
\v 7 Bela dule-be-dakmaloedi begi bangudoed. 
\q2 Sogdemaloed: ‘Nínive-neggwebur bergusye. 
\q1 ¿Doa eba wile itogoe? 
\q2 ¿Bia dule-wile-e-daked an ega amioe?’ ” 
\s1 Nínive-neggwebur-bela-obelolesad 
\q1  
\v 8 ¿Ar bede Tebas-neggweburba bur-nuedsi? 
\q2 Ar Tebas-neggweburde diimar-abargi siinad, 
\q2 Nilo-diwar-sukamakmaid-walik siinad, 
\q1 Demar e-napa-odinnogaledyob guenad, 
\q2 diimar e-galu-matusulidyob guenad. 
\q1  
\v 9 Etiopía-yar, Egipto-yar, Tebas-neggwebur-bendaksimalanad, 
\q1 bela-bela gangued nikamalanad. 
\q2 Fut-yar, Libia-yar, Tebasʼba naimalanad. 
\q1  
\v 10 Degi-inigwele, Tebas-dulemar yar-baidse ononnolesmalad, 
\q2 yar-baidse gales-selesmalad. 
\q1 E-mimmigan igar-abingunanaidgi 
\q2 sabsur-omukulenai gusmalad. 
\q1 E-dule-nuga-nikamalad ibmarba-wilubdakar mimilesgusmalad, 
\q2 e-dule-dummagan-negsediid esgoro-dubgi edilles gusmalad. 
\b  
\q1  
\v 11 Be, Nínive-neggwebur, be-omumsamarmogoed, 
\q2 neg-itosuli be gudii guoed. 
\q1 Be-isdarmalad-ulale, 
\q2 neg-dukued amidii be gumogoed. 
\q1  
\v 12 Bela be-neg-gandikmaladi 
\q2 higuera-sapi-san-gordik-siiyobi gued, 
\q1 ar dule osiamakele, 
\q2 dule-gunnega-gwichid-e-gaya-yaba argwaned. 
\q1  
\v 13 Be dake, be-isdarmaladbo be bila-ononaidgi, 
\q2 be-sorda-bila-onomalad omeganyobi damalad. 
\q1 Be-neggwebur-e-yawagakmar argasii guoed, 
\q2 ar be-yawagakgi-suar-biir-biir-megmalad soose gummakoed. 
\s1 Binsa neg-bendaked amimaloed 
\q1  
\v 14 Nínive-neggwebur, be-isdarmalad be-neggwebur-ebiris-ambikunonimaloed-iduar, dii be enomar, 
\q2 be-neg-gandikmalad be ogannomala. 
\q1 Napa-olli-ollid-birgi be gwisgue, napsa-ginnid-birgi be annae, 
\q2 akwa-napsa-ginnidgi-sobaled be sobe. 
\q1  
\v 15 Degi-inigwele, soogi be burgwemaloed, 
\q2 es-suidgi be girgumaloed, 
\q2 be-isdarmalad sesmaryobi giir be-imakmaloed. 
\q1 Ses-burwiganayobi be mergumai gumala, 
\q2 sesmaryobi be gwalulemai gumala. 
\q1  
\v 16 Be-dula ibmar-ukedgi-arbamaladi, 
\q2 bur bule nibneggi-niisgwamar-nanaidba merguded. 
\q1  
\v 17 Be-dummagan seseyobi gumalad, 
\q2 be-sordamar-e-dummagan ibmar-gukumalad-gar-satedyobi gumalad. 
\q2 We-ibmarmar neg-dambegwadgine galu-matusurmaladgi achaa nagudamalad. 
\q1 Ar dad-nakwialirdi gukuddamalad, bar daklegosulid, 
\q2 dule wissulid bia naddamala. 
\b  
\q1  
\v 18 Asiria-e-Rey, 
\q2 dule-bega-negdakmamaid bela-bela gabmamaid, 
\q2 be-sordamar-ise-welegar-imaklesmalad gabidmalad. 
\q1 Be-dulamar yala-imbaganba aisakis gudidiid, 
\q2 amar-onmakega dule sated. 
\q1  
\v 19 Be-nailikgusadi gege nudakleged, 
\q2 be-yaa-siid-nudakega ina sated. 
\b  
\q1 Dulemar deyob-be-gusadi be-wisgumaloedi, 
\q2 bega yeer-itomaloed. 
\q1 Ar ade, dulemar-yar-baid-baidgi-bukmalad-bukidara 
\q2 be sabsur-imaksa gusad.