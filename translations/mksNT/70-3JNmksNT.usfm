\id 3JN
\h 3 Juan
\toc1 Carta chí u̱ni̱ na̱ca̱hyí Juan nu̱ú na̱ cúú cuéntá Jesús
\toc2 3 Juan
\toc3 3 Jn.
\mt1 Carta chí u̱ni̱ na̱ca̱hyí Juan nu̱ú na̱ cúú cuéntá Jesús
\c 1
\s1 Cáha̱n Ndióxi̱ Juan xi̱hín in da̱ naní Gayo
\p 
\v 1 Ye̱he̱ cúú u̱ in da̱ sa̱cua̱ha̱ ta cáhyí i̱ carta yóho nu̱ mún ñani máni̱, da̱ naní Gayo. Ta mé a̱ nda̱a̱ quíhvi̱ ndusa ini i̱ yo̱hó.
\p 
\v 2 Cande̱hé, ñani máni̱, da̱ cúú cuéntá Jesús. Xíca̱ ta̱hví i̱ nu̱ Ndióxi̱ ña̱ ná quia̱hva mé á tá nu̱ú ña̱ va̱ha nu̱u̱n. Ta ná caja mé á ña̱ ná a̱ quíhvu̱n ta já coo va̱ha inún tá quia̱hva íin va̱ha inún xi̱hi̱n Ndióxi̱.
\v 3 A̱ ju̱ú quia̱hva ná caji̱i̱ íní i̱ tá na̱quixi java na̱ cúú cuéntá Jesús yóho ta na̱ndicani na nu̱ú i̱ ña̱ co̱ cáxoún nu̱ú ña̱ nda̱a̱ jáchi̱ cája tá cájún ña̱.
\v 4 A̱ ju̱ú quia̱hva cáji̱i̱ íní i̱ tá ñéhé e̱ tu̱hun ña̱ xíca ndó íchi̱ cuéntá ña̱ nda̱a̱ jáchi̱ mé ndó cúú ndó tátu̱hun ja̱hyi i̱.
\p 
\v 5 Cande̱hé, ñani máni̱. Va̱ha ndiva̱ha cájún jáchi̱ xi̱hín ndinuhu inún chíndeún na̱ cúú cuéntá Jesús tá sa̱a̱ na̱ ja̱n va̱tí cúú ná na̱ quíxi ñuu tóho̱.
\v 6 Ta nu̱ tócó ndihi na̱ tácá veñu̱hu yóho ndícani mé na̱ tóho̱ ndá quia̱hva quíhvi̱ ndiva̱ha inún na̱. Ña̱ cán quéa̱ xíca̱ i̱ ña̱ma̱ni̱ nu̱ yóhó, Gayo ña̱ ná chindeún na̱ tá ná sa̱a̱ tucu na cán ta ná quia̱hvún ña̱ ndíma̱ní nu̱ ná cañehe na íchi̱ cu̱hu̱n na̱ jáchi̱ ña̱ yóho cúú á ña̱ cáji̱i̱ ini Ndióxi̱ xi̱hi̱n.
\v 7 Ndítahan chindeún na̱ jáchi̱ na̱queta na xíca nuu na cája na chuun cuéntá Jesucristo ta co̱ cúni̱ na̱ ca̱ca̱ na̱ ña̱ha catacu na nu̱ú na̱ co̱ cúú cuéntá Jesús.
\v 8 Sa̱há ña̱ cán quéa̱ ndítahan nu̱ mí, na̱ cúú cuéntá Jesús chindeé yó na̱ cán xi̱hín ña̱ ndíma̱ní nu̱ ná. Ta xi̱hín ña̱ yóho in nduu yó xi̱hi̱n ná tá cáha̱n na̱ ña̱ nda̱a̱ xi̱hín ña̱yivi.
\s1 Cua̱chi cája in da̱ naní Diótrefes
\p 
\v 9 Sa̱ na̱chindahá i̱ in carta nu̱ tócó ndihi na̱ cúú cuéntá Jesús ndúu ja̱n joo Diótrefes co̱ó na̱xeen da cándúsa da ña̱ cáchí nde̱. Jáchi̱ cája cáhnu da mé dá ta cúni̱ da̱ cacuu da ji̱ni̱ nu̱ tócó ndihi na̱ cúú cuéntá Jesús ndúu ja̱n.
\v 10 Sa̱há ña̱ cán quéa̱ tá ná sa̱a̱ i̱ ja̱n ca̱xi tu̱hun i̱ nu̱u̱n sa̱há ña̱ cája da jáchi̱ xíca nuu da cáha̱n ndiva̱ha da ña̱ tu̱hún sa̱há nde̱. Ta a̱ ju̱ú ña̱ yóho cuití cája da, va̱ha jáchi̱ ni co̱ cúni̱ da̱ ndiquehe da na̱ cúú cuéntá Jesús xínu̱ co̱o ja̱n. Ta sájí nuu da nu̱ú na̱ cúni̱ ndiquehe va̱ha ñahá ta ja̱nda̱ táxí da̱ na̱ veñu̱hu.
\p 
\v 11 Cande̱hé, ñani máni̱. A̱ cájún ña̱ núu tá quia̱hva cája Diótrefes ja̱n. Xíní ñúhú cajún ndinuhu ña̱ va̱ha jáchi̱ da̱ cája ña̱ va̱ha cúú dá cuéntá Ndióxi̱ joo da̱ cája quini co̱ xíni̱ da̱ Ndióxi̱.
\s1 Ña̱ va̱ha cája Demetrio
\p 
\v 12 Joo tócó ndihi na̱ cúú cuéntá Jesús cáha̱n va̱ha na sa̱há da̱ naní Demetrio jáchi̱ ña̱ nda̱a̱ cuití va cája da. Ta quia̱hva já cáha̱n va̱ha ri nde̱he̱ va sa̱ha̱ dá ta cánda̱a̱ inún ña̱ cáha̱n nde̱ ña̱ nda̱a̱.
\s1 Ndínda̱yí Juan Gayo
\p 
\v 13 Mé a̱ nda̱a̱ íin cua̱há ndiva̱ha ña̱ha cúni̱ ca̱ha̱n i̱ xu̱hu̱n joo co̱ cúni̱ ca̱hyí i̱ ña̱ nu̱ú tutu yóho
\v 14 jáchi̱ cúni̱ cuni ya̱chi̱ i̱ yo̱hó já ná nditúhún yúhu̱ mí i̱ xu̱hu̱n.
\p 
\v 15 Ña̱ xíca̱ i̱ nu̱ Ndióxi̱ quéa̱ ná caja mé á ña̱ ná coo va̱ha inún. Na̱ cúú cuéntá Jesús ndúu yóho chíndahá na̱ Ndióxi̱ coún. Ta cajún ña̱ma̱ni̱ ca̱ha̱n Ndióxi̱ lohún xi̱hín in in na̱ cúú cuéntá Jesús ndúu ja̱n.
