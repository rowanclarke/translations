\id SNG - Baibal Kathoung New Testament
\h SOLOMON LA
\toc1 SOLOMON LA
\toc2 Solomon La
\toc3 Sol
\mt1 SOLOMON LA
\c 1
\s1 Sulam tami
\p 
\v 1 Solomon ni a thut e lanaw thung dawk e la lah ao.
\q1 
\v 2 Pahni hoi paconae hoi kai hah na paco haw.
\q2 Bangkongtetpawiteh, nange lungpatawnae teh
\q2 misurtui hlak ahawihnawn.
\q1 
\v 3 Na kâhluk e hmuitui ni na kaying toe.
\q2 Nange na min teh awi e hmuitui lah ao.
\q2 Hatdawkvah tanglakacuemnaw ni nang teh na lungpataw awh.
\q1 
\v 4 Kai hah na hrawi nateh, karanglah yawng lei sei.
\q2 Nang siangpahrang ni kai teh amae inae khan thung na kaw toe.
\q2 Nang dawk ka lunghawi vaiteh ka konawm han.
\q2 Na lungpatawnae hah misurtui hlak ka pouk han.
\q2 Nang teh na lungpataw katang awh.
\q1 
\v 5 Oe Jerusalem canu, kai teh Kedar rim patetlah ka tamang eiteh,
\q2 Solomon siangpahrang e im dawk
\q2 yap e hni patetlah a mei kahawi.
\q1 
\v 6 Ka tamang poung e kaie ka takthai kecu dawk,
\q2 kahawi hoeh lah na hmawt awh han.
\q2 Ka manu e capanaw ni kai koe a lungkhuek awh teh,
\q2 misur takhanaw hah, ka ring hanelah ka rakueng awh toe.
\q2 Kaie misur takha teh ka ring hoeh.
\s1 A pahren e napui koe
\q1 
\v 7 Kaie ka lungthin thung dawk
\q2 Ka pahren e tami,
\q1 na tuhu hah nâ e hmuen koe vaimoe,
\q2 a khoum awh vaiyoe,
\q2 kanîthun vah na e hmuen koe vaimoe a kâhat sak vaiyoe.
\q2 Kai hah na dei pouh haw.
\q2 Kai teh bangkongmaw na hui tuhu naw rahak vah
\q2 hro e patetlah khuet ka o han va.
\s1 A pahren e
\q1 
\v 8 Napuinaw thung dawk
\q2 a mei kahawipoung e lah na
\q1 Oe na ka panuek hoehpawiteh,
\q2 tunaw e hnukkâbang haw.
\q2 Tukhoumnaw e rim teng vah,
\q2 nange hmaeca hah rawca poe haw.
\q1 
\v 9 Ka pahren e tawncanu,
\q2 nang teh Faro siangpahrang e
\q2 ranglengnaw thung dawk e
\q2 marang hoi na bangnue.
\q1 
\v 10 Nange na tamboungnaw teh
\q2 talung phu kaawm poung e lah ao teh,
\q2 na lahuen teh suidingyin hoi na meihawi poung.
\s1 Jerusalem canunaw
\q1 
\v 11 Nang hanelah ngun hoi sak e
\q2 suihnapacap hai kaimouh ni na sak pouh han.
\s1 Sulam tami
\q1 
\v 12 Nang siangpahrang teh ahnie caboi dawk
\q2 na tahung nah kai koehoi,
\q2 ka tho e hmuitui hmui ni kaying e lah ao.
\q1 
\v 13 Kai ni ka pahren e nang e,
\q2 murah hmuitui tabu ca teh,
\q2 kaie lungtabue dawkvah rum touh thung ao.
\q1 
\v 14 Kai ni ka pahren e nang teh,
\q2 kai hanelah Engedi misur takha dawk e
\q2 Henna pei patetlah ao.
\q1 
\v 15 Ka pahren e ka tawncanu,
\q2 nang teh na mei ahawipoung.
\q2 Na hawi poung.
\q2 Nange na mit teh bakhu mit na tawn.
\q1 
\v 16 Kai ni ka pahren e nang teh
\q2 na mei ahawipoung.
\q2 Ngai a tho poung.
\q2 Ka lung a nawm sak.
\q2 Maimae ikhun teh hringsuepcalah ao.
\q1 
\v 17 Maimae im khomnaw teh,
\q2 Sidar thing, a lemphu teh hmaicathing e doeh.
\c 2
\q1 
\v 1 Kai teh Sharon e rosi pei hoi kâvan teh
\q2 ayawn dawk e lili pei lah ka o.
\q1 
\v 2 Ka pahren e nang teh, ka lungpataw e tangla,
\q2 pâkhingum e, lili pei patetlah na o.
\q1 
\v 3 Kahrawngum ka paw e
\q2 Epal thingkung patetlah ka pahren nang teh,
\q2 thoundounnaw e rahak na o.
\q2 Kai teh ahnie tâhlip dawk kanawmca lah ka o teh,
\q2 a paw teh kai hanelah a radip poung oe.
\q1 
\v 4 Ahni ni kai teh buvennae im koe na hrawi teh,
\q2 kaie lathueng a yap e hni teh
\q2 a lungpatawnae doeh.
\q1 
\v 5 Kai teh ngaipatawnae hoi ka o dawkvah
\q2 misur hoi Epal paw hoi
\q2 lung bout na pahawi haw.
\q1 
\v 6 Ahnie avoilae a kut ka lû rahim a ta teh,
\q2 aranglae kut hoi na takawi na seh.
\q1 
\v 7 Oe Jerusalem canu ka pahren e teh,
\q2 a mahmawk a kâhlaw hoeh roukrak
\q2 na pâhlaw awh hoeh nahanelah,
\q2 kahrawng e sayuk sakhinaw thoebo laihoi
\q2 nangmouh teh lawk na thui awh.
\q1 
\v 8 Khenhaw! ka pahren e lawk doeh.
\q2 Montang monruinaw yawngtapue laihoi a tho.
\q1 
\v 9 Ka pahren e teh, sayuk sakhi ca patetlah ao.
\q2 Rapan lawilah a kangdue.
\q2 Hlalangaw koe a khet teh,
\q2 hlalangaw koe a kâpâtue.
\q1 
\v 10 Ka pahren ni na kaw teh,
\q2 a dei e lawk teh, ka pahren poung e tangla,
\q2 a meikahawi e, thaw nateh tho haw.
\q1 
\v 11 Khenhaw! kasik hai aloum teh
\q2 cotui hai abaw toe.
\q1 
\v 12 Talai van vah, a peinaw a kamhlawng toe.
\q2 Tavanaw hai a cainae tue a pha toe.
\q2 Maimae ram vah, bakhu lawk hai thai toe.
\q1 
\v 13 Thaibunglung kung a pawnaw hai a hmin toe.
\q2 Misurkung hai a pei teh, a hmuitui toe.
\q2 Ka pahren e ka imlawinu, a meikahawi poung e,
\q2 thaw nateh tho leih.
\q1 
\v 14 Lungsong rahak e bakhu,
\q2 na mei heh na hmawt sak haw.
\q2 Na lawk hai na thaisak haw.
\q2 Na lawk a rading teh na mei teh ngai ao poung.
\q1 
\v 15 Maimae misurnaw teh
\q2 a pei lahun toung dawkvah,
\q2 misurkungnaw ka raphoe hane
\q2 Asuinaw hoi Asuicanaw hah man awh.
\q1 
\v 16 Kaie ka pahren e teh kai hanelah ao e patetlah
\q2 kai hai ahni hanelah ka o.
\q2 Ahni teh tucahunaw hah
\q2 kahrawngum a khoum teh a kawkhik.
\q1 
\v 17 Khohmo a kahma teh,
\q2 khodai totouh ka pahren teh
\q2 Bether mon dawk e
\q2 sayuk sakhi patetlah doeh ao.
\c 3
\q1 
\v 1 Ka lungthung hoi ka pahren e hateh,
\q2 karum vah ka inae koehoi ka tawng.
\q2 Hateiteh ka hmawt hoeh.
\q1 
\v 2 Atu ka thaw teh khothung ka lawngven teh
\q2 lam tangkuem hoi tami a kamkhuengnae
\q2 hmuennaw koe ka lungthinthung hoi
\q2 ka pahren nang teh na tawng.
\q2 Hateiteh na hmawt hoeh.
\q1 
\v 3 Khoipui ka ring e ramvengnaw ni hai
\q2 na hmu awh.
\q2 Ahnimouh koe ka pahren hah
\q2 na hmu awh maw telah ka pacei.
\q1 
\v 4 Ahnimouh koung tapoung hoi a ro hoehnahlan,
\q2 ka pahren e teh ka hmu.
\q2 Ahni hah ka kuet teh, ka khenae,
\q2 anu imthungkhu totouh ka hrawi.
\q1 
\v 5 Oe Jerusalem canunaw ka pahren teh
\q2 amahmawk a kâhlaw hoeh roukrak
\q2 na pâhlaw awh hoeh nahanelah,
\q2 kahrawng e sayuk sakhinaw thoebo laihoi,
\q2 nangmouh teh lawk na thui awh.
\q1 
\v 6 Murah hoi frankinsen koehoi
\q2 hno kayawtnaw ni
\q2 a yo e hmuituinaw pueng hah,
\q2 hmaisawi toteh ka khu e hmaikhukhom patetlah
\q2 kahrawngum hoi ka tâcawt e teh api nama.
\q1 
\v 7 Khenhaw! Solomon kâkayawtnae doeh.
\q2 Isarel athakaawme taminaw,
\q2 athakaawme 60 touh hoi a tho.
\q1 
\v 8 Hotnaw abuemlah teh tarantuk hanelah
\q2 tahloi ka patuem e tarankahawinaw doeh.
\q2 Karum lae atueng nah
\q2 puen hanelah ao dawkvah,
\q2 tami pueng ni tahloi coungkacoelah a neng awh.
\q1 
\v 9 Solomon siangpahrang ni
\q2 Lebanon thing hoi ama hanelah,
\q2 kâkayawtnae hah a sak.
\q1 
\v 10 Alungui e khomnaw hah, ngun hoi,
\q2 a rahim e naw hah sui hoi,
\q2 tahung nahane carawng hah
\q2 Opaou e hni hoi a sak.
\q2 Athung lae naw teh,
\q2 Jerusalem canunaw ni lungpatawnae hoi
\q2 a pathoup awh.
\q1 
\v 11 Zion canunaw kâpaluen e hnin hoi,
\q2 lungthin a nawmnae hnin nah,
\q2 a manu ni oupnae bawilakhung hah
\q2 kâmuk sak e Solomon siangpahrang hah
\q2 cet nateh khen awh.
\c 4
\s1 Thoundoun
\q1 
\v 1 Ka pahren e, nang teh na meihawipoung.
\q2 Na meihawi tangngak na mit teh
\q2 minhmai ramuk thung kaawm e
\q2 Bakhu e mit hoi a kâvan.
\q2 Nange na sam teh, Gilead mon hoi
\q2 ka kum e hmaehu patetlah ao.
\q1 
\v 2 Nange na hânaw teh a muen ngaw teh
\q2 thoung sak hnukkhu,
\q2 ka takhang e tuhu patetlah ao.
\q2 Buet touh hai kahmat hoeh.
\q2 Suetalah a kamphek awh.
\q1 
\v 3 Nange na pahni teh langsanrui hoi a kâvan.
\q2 Nange na lawk teh a pâdingsue.
\q2 Nange na minhmai ramuk thung kaawm e,
\q2 nange na hnâlakheng teh
\q2 tale paw tangawntangai hoi a kâvan.
\q1 
\v 4 Na lahuen hai Devit ni a sak e imrasang hoi a kâvan.
\q2 Athakaawme taminaw e bahlingnaw pueng,
\q2 hawvah bahling 1,000 touh a bang awh.
\q1 
\v 5 Na sanu roi teh ayawn dawk
\q2 ka pouh e sayuk sakhi samphei hoi a kâvan.
\q1 
\v 6 Kanî a khup hoi kanîka suirasai totouh,
\q2 Murah mon hoi frankinsen mon
\q2 totouh ka cei han.
\q1 
\v 7 Ka pahren e nang dawk toun hane
\q2 banghai awmhoeh.
\q2 Na meihawi toungloung.
\q1 
\v 8 Ka imlawinu, kai hoi lebanon mon hoi tho haw.
\q2 Kai hoi Lebanon mon hoi kum haw.
\q2 Amana monsom, Senir mon hoi,
\q2 Hermon monsom, sendek e kâkhu,
\q2 takainaw a onae mon dawkvah khenhaw!
\q1 
\v 9 Kaie ka tangla, ka tawncanu,
\q2 nang ni ka lungmuenti sak toe.
\q2 Na mit hoi vai touh na khet e hoi
\q2 lahuen vai touh na pahei e ni,
\q2 kaie ka lungthin teh muen na ti sak toe.
\q1 
\v 10 Kaie ka tangla, ka tawncanu,
\q2 nange lungpatawnae teh a radip poung.
\q2 Nange lung na patawnae teh
\q2 misurtui hlak hoe ahawi.
\q2 Hmuituinaw hlak hai na tui.
\q1 
\v 11 Kaie tangla, nange na pahni teh
\q2 khoipha patetlah a lawi.
\q2 Na lai rahim sanutui hoi khoitui ao.
\q1 
\v 12 Kaie tangla, ka tawncanu,
\q2 ka khan e takha ka tungdum e tuiim,
\q2 tacikkin e tuiphuek lah ao.
\q1 
\v 13 Nange thingthainaw teh,
\q2 ka radip e a paw hoi talepawnaw onae takha,
\q2 hennakung hoi a hmuituinaw,
\q1 
\v 14 Hmuitui, spiknard hoi saffron, kalamus,
\q2 nakzik thing hoi, frankinsen, murah,
\q2 aloe hmuitui, phunkuep ao.
\q1 
\v 15 Takha thung e naw, tui bu nahanelah tuiim,
\q2 tuiphueknaw, lebanon mon hoi
\q2 ka lawng e tuinaw hai ao.
\q1 
\v 16 Tung lae kahlî thaw haw, akalae kahlî tho haw.
\q2 Kaie takha dawkvah tho awh haw.
\q2 A hmuituinae naw teh kâkahei naseh.
\q2 Ka pahren e ni takha thung kâen vaiteh
\q2 ka radip e paw hah cat naseh.
\c 5
\q1 
\v 1 Kaie ka tangla ka tawncanu,
\q2 ka takha thung kai ka tho toe.
\q2 Kai ni Murah hoi a hmuitui e phun hah
\q2 ka pâkhueng toe.
\q2 Khoitui hoi khoiphanaw hah ka ca toe.
\q2 Ka huinaw cat awh, net awh,
\q2 Oe ka pahren, ka boum lah cat net.
\q1 
\v 2 Kai teh ka i lahun nahai ka lungthin teh
\q2 a kâhlaw doeh.
\q2 Ka pahren e lawk teh ka thai doeh.
\q2 Kaie bakhu, ka pahren e, ka tawncanu,
\q2 tamikalan, kai hane na paawng pouh haw.
\q2 Ka lû teh tadamtui hoi, ka samnaw hai
\q2 karum kabawt e tadamtui hoi
\q2 a duk toe telah ati teh tho a takhawng.
\q1 
\v 3 Kaie ka khohna e teh ka rading toe.
\q2 Bangtelamaw bout ka kho han.
\q2 Ka khoknaw hai ka pâsu toe.
\q2 Bangkong bout kakhin sak han.
\q1 
\v 4 Ka pahren ni kut hoi takhang hah
\q2 ka tanawt teh a paawng torei teh,
\q2 kaie ka lungthin teh ahni dawk noenae ao toe.
\q1 
\v 5 Ka pahren hanelah takhang
\q2 paawng pouh hane ka thaw navah,
\q2 kaie ka kut dawk hoi Murah satui dek a ca.
\q2 Murah satui teh kaie kutcarei rahak hoi
\q2 tho khannae dawk hoi a lawng.
\q1 
\v 6 Ka pahren hanelah tho ka paawng pouh navah,
\q2 Hatei ka pahren teh yo la a tâco toe.
\q2 Ahnie lawk thai han ka ngai dawk ahni teh
\q2 ka tawng ei, ka hmawt hoeh, ka kaw ei voi hoeh.
\q1 
\v 7 Khopui ka ring e ramvengnaw ni na hmu navah
\q2 puenghoi na hem awh.
\q2 Khorapan karingkungnaw ni
\q2 ka minhmai ramuk na lawp awh.
\q1 
\v 8 Oe Jerusalem canunaw ka pahren hah,
\q2 na kâhmo pawiteh, kai ni ka pahren lawi,
\q2 ngaipataw e lah ka o e hah,
\q2 ahni koe dei pouh loe telah
\q2 nangmanaw lawk na thui awh.
\q1 
\v 9 Napuinaw thung dawk a meikahawi poung e,
\q2 nang ni na pahren e teh,
\q2 alouknaw e phrennae hoi bangtelamaw kâvanhoehnae .
\q2 Kaimanaw hah hottelah lawk na thui nahanelah,
\q2 na pahren e teh alouknaw e pahrennae hoi
\q2 bangtelamaw a kâvanhoehnae,
\q1 
\v 10 Ka pahren teh, a pangaw palingnae hoi
\q2 a kawi e teh tami thong hra touh thung dawk
\q2 ka talue poung lah ao.
\q1 
\v 11 Ahnie a lû dawkvah, sui patetlah
\q2 suituici patetlah ao.
\q2 Ahnie sam teh atha teh,
\q2 vonga patetlah a tamang.
\q1 
\v 12 Ahnie mit teh palang teng vah
\q2 sanutui hoi pâsu e bakhunaw hoi a kâvan.
\q1 
\v 13 Ahnie tamboung teh hmuitui e a pei hmui,
\q2 hmuitui ungnae kahrawngum patetlah ao.
\q2 Ahnie pahni teh, murah tui kalawng e
\q2 lili pei patetlah ao.
\q1 
\v 14 Ahnie kutnaw teh talung hoi pathoup e
\q2 suikuthrawt patetlah
\q2 ahnie tak teh Sapphire lung hoi pathoup e
\q2 loukloukkaang e kasaino patetlah ao.
\q1 
\v 15 Ahnie khok teh, suikhom dawk sak e
\q2 talung phukaawm e khom hoi a kâvan.
\q2 Ahnie a meilam teh,
\q2 Lebanon mon patetlah ao teh,
\q2 Sidar thing patetlah a talue poung.
\q1 
\v 16 A hni e pahni teh a radip poung teh,
\q2 a takthai abuemlah ngai a tho poung
\q2 Jerusalem canu ahni teh ka pahren e ka hui lah ao.
\c 6
\q1 
\v 1 Napuinaw thung dawk a mei kahawipoung e
\q2 ka tawncanu, nange na pahren e teh
\q2 nâ e hmuen koe maw a cei vai.
\q2 Kaimouh ni nang hoi reirei tawng hanelah,
\q2 nange pahren e teh,
\q2 namaw na kâceihlinghlang roi tie hah dei haw.
\q1 
\v 2 Ka pahren teh, a pawnaw cat vaiteh,
\q2 lili peinaw ka la han a titeh,
\q2 takha thung hmuitui onae koe lah a cei toe.
\q1 
\v 3 Ka pahren hanelah kai teh ka o.
\q2 Ka pahren hai kai hanelah ao.
\q2 Ayawn dawk ka pouh e lah ao.
\q1 
\v 4 Ka pahren e ka tawncanu,
\q2 nang teh Tirzah kho patetlah na mei ahawi.
\q2 Jerusalem kho patetlah ngai ao.
\q2 Taran kâtuknae koe e patetlah
\q2 taki kawi lah na o.
\q1 
\v 5 Nange na mit teh,
\q2 kai koehoi alouklah kangvawi leih.
\q2 Ahnimouh ni kai teh na tâ toe.
\q2 Nange na san teh,
\q2 Gilead mon hoi ka kum e hmaehu patetlah ao.
\q1 
\v 6 Nange na hânaw teh tui pâhluknae koehoi
\q2 ka luen e tuhu patetlah ao.
\q2 Buet touh hai kahmat hoeh.
\q2 Kamphei e dueng doeh a khe awh.
\q1 
\v 7 Na minhmai ramuknae thung kaawm e
\q2 na tangboungnaw teh
\q2 talepaw tangawntangai hoi a kâvan.
\q1 
\v 8 Siangpahrang napui 60,
\q2 a yu ado lah 80,
\q2 touklek thai hoeh e tanglakacuemnaw ao.
\q1 
\v 9 Kaie bakhu, kaie ka kuep e,
\q2 buet touh dueng doeh kaawm.
\q2 Ahni ka khe e manu ni a pahren poung e lah ao.
\q2 Tanglanaw ni ahni hah a hmu teh,
\q2 yawhawi a poe awh.
\q2 Siangpahrangnu hoi a yudonaw ni hai
\q2 ahni teh a pholen awh.
\q1 
\v 10 Thapa patetlah ahawi teh,
\q2 kanî patetlah a sei teh,
\q2 tarankâtuknae koe e patetlah
\q2 taki hanlah na o.
\q2 Amom patetlah ngaihawi laihoi
\q2 ka khen e teh apimaw .
\q1 
\v 11 Kai teh misurkung roung hai a roung hoeh hai,
\q2 Tale a pei hoi a pei hoeh e hai panue hanelah,
\q2 ka khetyawt hanelah takha koe ka cei.
\q1 
\v 12 Kai ka panue hoehnahlan vah,
\q2 ka muitha teh,
\q2 Aminadab leng dawk kâcuie patetlah ao.
\q1 
\v 13 Oe Sulammit, bout tho haw.
\q2 Kaimouh ni nang teh na hmu thai nahanelah
\q2 bout tho haw. Bout tho haw.
\q2 Sulammit dawk bang hno maw
\q2 a hmu awh han vai.
\q2 Ransahu bokhni touh e patetlah a hmu awh han.
\c 7
\q1 
\v 1 Oe bawi canu, khokkhawm na khawm laihoi
\q2 na khoknaw teh a kamcu poung.
\q2 Na phainaw teh kathoumnaw ni a sak e
\q2 aphu kaawm e talung patetlah ao awh.
\q1 
\v 2 Nange na keng teh tui hoi ka kawi e
\q2 manang lah ao.
\q2 Na vonpui hai, lili pei hoi ka kawi e
\q2 cakang pung e lah ao.
\q1 
\v 3 Sanu roi teh
\q2 sayukca kamphei e hoi a kâvan.
\q1 
\v 4 Nange na lahuen teh,
\q2 kasaino imrasang patetlah na mit teh,
\q2 Heshbon kho, Bethrabbim
\q2 longkha teng kaawm e, tuiim patetlah
\q2 na hnawng teh Damaskas kho koe ka kangvawi e,
\q2 lebanon im hoi a kâvan.
\q1 
\v 5 Nange na lû dawk kaawm e bawilakhung teh,
\q2 Karmel mon hoi a kâvan.
\q2 Nange na lû dawk kaawm e na sam hai,
\q2 opaou e hni hoi a kâvan.
\q2 Siangpahrang ni sam a vei e hoi a kâvan.
\q1 
\v 6 Ka pahren e ka tawncanu, nang teh,
\q2 kai ka nawm nahanelah ahawi poung.
\q2 Ngai kaawm poung e nuen hoi na kawi.
\q1 
\v 7 Nange na rasangravuinae teh,
\q2 samtuekung patetlah na o teh
\q2 nange sanunaw hai samtuepaw hoi a kâvan.
\q1 
\v 8 Samtuekung dawk ka luen vaiteh,
\q2 a kangnaw hah ka tek han ka ti navah
\q2 nange sanunaw teh misurbom patetlah thoseh,
\q2 na kâha hmui teh, Epal hmui patetlah thoseh,
\q1 
\v 9 Nange na pahni hai katuipounge
\q2 misurtui patetlah thoseh ao.
\q2 Hote misurtui teh ka pahren hanelah
\q2 kalancalah a lawng.
\q2 Kaipnaw e pahni dawk pouk laipalah a lawng.
\q1 
\v 10 Kaie ka pahren e tami teh,
\q2 kaie lah ao patetlah ahnie a ngainae teh
\q2 kaie lah ao.
\q1 
\v 11 Tho leih, ka pahren e,
\q2 kahrawng e hmuen koe cei vaiteh,
\q2 khonaw dawk tangmin lae atueng
\q2 loum sak awh sei.
\q1 
\v 12 Amom lah misur takha koe cet awh sei.
\q2 Misurkung a hring, hring hoeh maw,
\q2 a paw rano moi rano hoeh maw,
\q2 khenhaw! sei.
\q2 Hote hmuen dawk ka lungpataw e
\q2 nang hah na poe han.
\q1 
\v 13 Hloisikungnaw ni hmuitui e
\q2 kaimae longkha teng radip e a paw katha hoi,
\q2 karuem e abuemlah ka pahren nang hanelah
\q2 ka pâtung toe.
\c 8
\q1 
\v 1 Nang koe kaie manu e sanutui karadip e,
\q2 ka net e, ka thangroi patetlah o sak han ka ngai.
\q2 Kai ni nang teh, alawilah kâhmo vaiteh,
\q2 na paco nakunghai ayânaw ni kai teh
\q2 na pathoe mahoeh.
\q1 
\v 2 Anu e irakhan na kut dawk hoi
\q2 na hrawi vaiteh na ceikhai han.
\q2 Ahni ni hai kai hai na cangkhai han.
\q2 Kai ni tâsi hoi kalawt e misurtui hoi
\q2 taletui hah na nei sak han.
\q1 
\v 3 Ahnie avoilah,
\q2 e kut kaie ka lû rahim a hruek vaiteh,
\q2 aranglae kut hoi na takawi seh.
\q1 
\v 4 Oe Jerusalem canunaw, ka pahren e teh
\q2 amahmawk a kâhlaw hoehroukrak
\q2 na pâhlaw awh hoeh nahanelah,
\q2 kahrawng e sayuk sakhinaw noe lahoi
\q2 lawk na thui awh.
\q1 
\v 5 A pahren dawk kamngawi laihoi
\q2 kahrawngum hoi ka tho e hateh
\q2 api han namaw.
\q2 Epal thingkung rahim nang teh na pâhlaw toe.
\q2 Hote hmuen koe nange na manu ni
\q2 nang teh na hâ toe.
\q2 Hote hmuen koe nang na khe teh,
\q2 hâ e lah na hruek toe.
\q1 
\v 6 Kai teh nange na lung dawkvah
\q2 tacik na kin leih lah.
\q2 Na kut dawk hai tacik na kin leih.
\q2 Bangkongtetpawiteh, lungpatawnae teh,
\q2 due e patetlah a thao.
\q2 Dipmanae lungthin teh phuen kho patetlah a ru.
\q2 Ahnie a hue teh, hmaisaan hoi
\q2 hmaito patetlah ao.
\q1 
\v 7 Hatnavah, tuinaw ni
\q2 lungpatawnae roum sak thai hoeh.
\q2 Tuikalen ni hai pâyawt thai hoeh.
\q2 Tami ni ama im kaawm hnopai pueng
\q2 lungpatawnae lahoi poe han a ngai nakunghai
\q2 puenghoi dudamnae doeh kâhmo ti.
\q1 
\v 8 Kaimouh koevah kanaw rae ka tawncanu
\q2 buet touh ao rah.
\q2 Ahni teh sanu co hoeh rah.
\q2 Hote ka tawncanu a pacei awh navah,
\q2 ahni hanelah bangtelamaw ka ti awh han.
\q1 
\v 9 Ahni teh rapan lah awm pawiteh,
\q2 ahni van ngunrapan ka sak han.
\q2 Takhang lah awm pawiteh
\q2 Sidar thing hoi ka kalup han.
\q1 
\v 10 Kai teh kho rapan lah ka o.
\q2 Kaie sanu hai imrasang patetlah o.
\q2 Hatdawkvah, kai teh
\q2 nang na hmalah hawinae ka sak.
\q1 
\v 11 Baalhamon ram dawk takha buet touh ao.
\q2 Hote misur takha teh,
\q2 karingkungnaw koe ka hlai sak teh
\q2 a paw a ca phu lah
\q2 shekel thawng touh rip a sin awh.
\q1 
\v 12 Ka tawn e misur takha teh kahma lah ao.
\q2 Oe Solomon, ngun shekel thong touh
\q2 nama hanelah ao teh,
\q2 karingkungnaw ni cumhni touh rip a la awh.
\q1 
\v 13 Takha thung kaawm e,
\q2 nange tami na huikonaw ni nange
\q2 na lawk teh a ngai awh.
\q2 Kai hai na thaisak van awh haw.
\q1 
\v 14 Ka pahren nang kai koe karanglah tho leih.
\q2 Hmuitui monnaw dawk kaawm e
\q2 sayuk sakhicanaw patetlah na awm sak haw. 
