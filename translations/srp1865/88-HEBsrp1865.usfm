\id HEB
\h Jevrejima poslanica svetog apostola Pavla
\toc1 Jevrejima poslanica svetog apostola Pavla
\toc2 Jevrejima
\toc3 Jev
\mt1 Jevrejima poslanica
\mt2 svetog apostola Pavla
\c 1
\s1 Hristos je Božiji Sin i viši od anđela.
\p 
\v 1 Bog koji je nekada mnogo puta i različitim načinom govorio očevima preko proroka, govori i nama u posledak dana ovih preko sina,
\v 2 kog postavi naslednika svemu, kroz kog i svet stvori.
\v 3 Koji budući sjajnost slave i obličje bića Njegovog, i noseći sve u reči sile svoje, učinivši sobom očišćenje greha naših, sede s desne strane prestola veličine na visini,
\v 4 i toliko bolji posta od anđela koliko preslavnije ime od njihova dobi.
\p 
\v 5 Jer kome od anđela reče kad:
\b
\q1 Sin moj ti si,
\q2 ja te danas rodih?
\b
\p I opet:
\b
\q1 Ja ću Mu biti Otac,
\q2 i On će mi biti Sin.
\b
\p 
\v 6 I opet uvodeći Prvorodnoga u svet govori:
\b
\q1 i da Mu se poklone svi anđeli Božiji.
\b
\p 
\v 7 Tako i anđelima govori:
\b
\q1 Koji čini anđele svoje duhove,
\q2 i sluge svoje plamen ognjeni.
\b
\p 
\v 8 A sinu:
\b
\q1 Presto je Tvoj, Bože, va vek veka;
\q2 palica je pravde palica carstva Tvog.
\q1 
\v 9 Omilela Ti je pravda,
\q2 i omrzao si na bezakonje:
\q1 toga radi pomaza Te, Bože, Bog Tvoj uljem radosti
\q2 većma od drugova Tvojih.
\b
\p 
\v 10 I opet:
\b
\q1 Ti si, Gospode, u početku osnovao zemlju,
\q2 i nebesa su dela ruku Tvojih:
\q1 
\v 11 Ona će proći, a Ti ostaješ:
\q2 i sva će ostareti kao haljina,
\q1 
\v 12 I savićeš ih kao haljinu,
\q2 i izmeniće se:
\q1 a Ti si Onaj isti,
\q2 i Tvojih godina neće nestati.
\b
\p 
\v 13 A kome od anđela reče kad:
\b
\q1 Sedi meni s desne strane
\q2 dok položim neprijatelje Tvoje podnožje nogama Tvojim?
\b
\p 
\v 14 Nisu li svi službeni duhovi koji su poslani na službu onima koji će naslediti spasenje?
\c 2
\s1 Dužni smo da Hristovu reč slušamo. Hristov put vodi slavi kroz stradanje.
\p 
\v 1 Toga radi valja nam većma paziti na reči koje slušamo, da kako ne otpadnemo.
\v 2 Jer ako je ono što je govoreno preko anđela utvrđeno, i svaki prestupak i oglušak pravednu platu primio:
\v 3 Kako ćemo pobeći na marivši za toliko spasenje? Koje poče Gospod propovedati, i oni koji su čuli potvrdiše među nama,
\v 4 kad i Bog posvedoči i znacima i čudesima i različitim silama, i Duha Svetog razdeljivanjem po svojoj volji.
\b
\p 
\v 5 Jer Bog ne pokori anđelima vasioni svet, koji ide i o kome govorimo.
\v 6 Ali neko posvedoči negde govoreći:
\b
\q1 Šta je čovek da ga se opomeneš,
\q2 ili sin čovečiji da ga obiđeš?
\q1 
\v 7 Umalio si ga malim nečim od anđela,
\q2 slavom i časti venčao si ga,
\q1 i postavio si ga nad delima ruku svojih:
\q2 
\v 8 Sve si pokorio pod noge Njegove.
\b
\p A kad Mu pokori sve, ništa ne ostavi Njemu nepokoreno; ali sad još ne vidimo da Mu je sve pokoreno.
\v 9 A umanjenog malim čim od anđela vidimo Isusa, koji je za smrt što podnese venčan slavom i časti, da bi po blagodati Božijoj za sve okusio smrt.
\p 
\v 10 Jer prilikovaše Njemu za kog je sve i kroz kog je sve, koji dovede mnoge sinove u slavu, da dovrši Poglavara spasenja njihovog stradanjem.
\v 11 Jer i Onaj koji osvećuje, i oni koji se osvećuju, svi su od Jednog; zaradi tog uzroka ne stidi se nazvati ih braćom
\v 12 govoreći:
\b
\q1 Objaviću ime Tvoje braći svojoj,
\q2 i posred crkve zapevaću Te.
\b
\p 
\v 13 I opet:
\b
\q1 Ja ću se u Njega uzdati.
\b
\p I opet:
\b
\q1 Evo ja i deca moja koju mi je dao Bog.
\b
\p 
\v 14 Budući, pak, da deca imaju telo i krv, tako i On uze deo u tome, da smrću satre onog koji ima državu smrti, to jest đavola;
\v 15 i da izbavi one koji god od straha smrti u svemu životu biše robovi.
\v 16 Jer se zaista ne primaju anđeli, nego se prima seme Avraamovo.
\v 17 Zato beše dužan u svemu da bude kao braća, da bude milostiv i veran poglavar sveštenički pred Bogom, da očisti grehe narodne.
\v 18 Jer u čemu postrada i iskušan bi u onome može pomoći i onima koji se iskušavaju.
\c 3
\s1 Hristos je viši od Mojsija, zato otpadništvo od Njega zaslužuje veću kaznu.
\p 
\v 1 Zato, braćo sveta, zajedničari zvanja nebeskog, poznajte poslanika i vladiku, kog mi priznajemo, Isusa Hrista,
\v 2 koji je veran Onome koji ga stvori, kao i Mojsije u svemu domu njegovom.
\v 3 Jer Ovaj posta toliko dostojan veće časti od Mojsija, koliko veću od doma čast ima onaj koji ga je načinio.
\v 4 Jer svaki dom treba neko da načini; a ko je sve stvorio ono je Bog.
\v 5 I Mojsije dakle beše veran u svemu domu njegovom, kao sluga, za svedočanstvo onog što je trebalo da se govori.
\v 6 Ali je Hristos kao sin u domu svom: kog smo dom mi, ako slobodu i slavu nade do kraja tvrdo održimo.
\b
\p 
\v 7 Zato, kao što govori Duh Sveti:
\b
\q1 Danas ako glas Njegov čujete,
\q1 
\v 8 Ne budite drvenastih srca,
\q2 kao kad se progneviste u dane napasti u pustinji,
\q1 
\v 9 Gde me iskušaše očevi vaši,
\q2 iskušaše me, i gledaše dela moja četrdeset godina.
\q1 
\v 10 Toga radi rasrdih se na taj rod,
\q2 i rekoh:
\q1 Jednako se metu u srcima,
\q2 ali oni ne poznaše puteve moje;
\q1 
\v 11 Zato se zakleh u gnevu svom
\q2 da neće ući u pokoj moj.
\b
\p 
\v 12 Gledajte, braćo, da ne bude kad u kome od vas zlo srce neverstva da odstupi od Boga Živoga;
\v 13 nego se utešavajte svaki dan, dokle se danas govori, da koji od vas ne odrveni od prevare grehovne;
\v 14 jer postadosmo zajedničari Hristu, samo ako kako smo počeli u Njemu biti do kraja tvrdo održimo;
\v 15 dokle se govori:
\b
\q1 Danas, ako glas Njegov čujete,
\q2 ne budite drvenastih srca,
\q2 kao kad se progneviste.
\b
\p 
\v 16 Jer neki čuvši progneviše se, ali ne svi koji iziđoše iz Misira s Mojsijem.
\v 17 A na koje mrzi četrdeset godina? Nije li na one koji sagrešiše, koji ostaviše kosti u pustinji?
\v 18 A kojima se zakle da neće ući u pokoj Njegov, nego onima koji ne hteše da veruju?
\v 19 I vidimo da ne mogoše ući za neverstvo.
\c 4
\s1 Ostavljeno je još počivanje narodu Božijem uz pomoć Hristovu.
\p 
\v 1 Da se bojimo, dakle, da kako dok je još ostavljeno obećanje da se ulazi u pokoj Njegov, ne zakasni koji od vas.
\v 2 Jer je nama objavljeno kao i onima; ali onima ne pomaže čuvena reč, jer ne verovaše oni koji čuše.
\v 3 Jer mi koji verovasmo ulazimo u pokoj, kao što reče:
\b
\q1 Zato se zakleh u gnevu svom
\q2 da neće ući u pokoj moj,
\b
\p ako su dela i bila gotova od postanja sveta.
\v 4 Jer negde reče za sedmi dan ovako: i počinu Bog u dan sedmi od svih dela svojih.
\v 5 I na ovom mestu opet:
\b
\q1 Neće ući u pokoj moj.
\b
\p 
\v 6 Budući, pak, da neki imaju da uđu u njega, i oni kojima je najpre javljeno ne uđoše za neposlušanje;
\v 7 opet odredi jedan dan, danas, govoreći u Davidu po tolikom vremenu, kao što se pre kaza:
\b
\q1 Danas ako glas Njegov čujete,
\q2 ne budite drvenastih srca.
\b
\p 
\v 8 Jer da je Isus one doveo u pokoj, ne bi za drugi dan govorio potom.
\v 9 Dakle je ostavljeno još počivanje narodu Božijem.
\v 10 Jer koji uđe u pokoj Njegov, i on počiva od dela svojih, kao i Bog od svojih.
\p 
\v 11 Da se postaramo, dakle, ući u taj pokoj, da ne upadne ko u onu istu gatku neverstva.
\v 12 Jer je živa reč Božija, i jaka, i oštrija od svakog mača oštrog s obe strane, i prolazi tja do rastavljanja i duše i duha, i zglavaka i mozga, i sudi mislima i pomislima srca.
\v 13 I nema tvari nepoznate pred Njime, nego je sve golo i otkriveno pred očima Onog kome govorimo.
\b
\p 
\v 14 Imajući, dakle, velikog Poglavara svešteničkog, koji je prošao nebesa, Isusa sina Božijeg, da se držimo priznanja.
\v 15 Jer nemamo Poglavara svešteničkog koji ne može postradati s našim slabostima, nego koji je u svačemu iskušan kao i mi, osim greha.
\v 16 Da pristupimo, dakle, slobodno k prestolu blagodati, da primimo milost i nađemo blagodat za vreme kad nam zatreba pomoć.
\c 5
\s1 Hristos je pravi Poglavar sveštenički, viši od Arona.
\p 
\v 1 Jer svaki poglavar sveštenički koji se iz ljudi uzima, za ljude se postavlja na službu k Bogu, da prinosi dare i žrtve za grehe,
\v 2 koji može postradati s onima koji ne znaju i zalaze; jer je i on pod slabošću.
\v 3 I zato je dužan kako za narodne tako i za svoje grehe prinositi.
\v 4 I niko sam sebi ne daje časti, nego koji je pozvan od Boga, kao i Aron.
\p 
\v 5 Tako i Hristos ne proslavi sam sebe da bude poglavar sveštenički, nego Onaj koji Mu reče:
\b
\q1 Ti si moj sin,
\q2 ja Te danas rodih.
\b
\p 
\v 6 Kao što i na drugom mestu govori:
\b
\q1 Ti si sveštenik vavek
\q2 po redu Melhisedekovom.
\b
\p 
\v 7 On u dane tela svog moljenja i molitve k Onome koji Ga može izbaviti od smrti s vikom velikom i sa suzama prinošaše, i bi utešen po svojoj pobožnosti.
\v 8 Iako i beše Sin Božji, ali od onog što postrada nauči se poslušanju.
\v 9 I svršivši sve, postade svima koji Ga poslušaše uzrok spasenja večnog.
\v 10 I bi narečen od Boga poglavar sveštenički po redu Melhisedekovom.
\b
\p 
\v 11 Za kog bismo vam imali mnogo govoriti što je teško iskazati; jer ste postali slabi na slušanju.
\v 12 Jer vi koji bi valjalo da ste učitelji po godinama, opet potrebujete da učite koje su prva slova reči Božije; i postadoste da trebate mleka, a ne jake hrane.
\v 13 Jer koji se god hrani mlekom, ne razume reči pravde, jer je dete.
\v 14 A savršenih je tvrda hrana, koji imaju osećanja dugim učenjem obučena za razlikovanje i dobra i zla.
\c 6
\s1 Treba se čuvati otpadništva od vere i biti postojan i uzdati se u obricanje.
\p 
\v 1 Zato da ostavimo početak Hristove nauke i da se damo na savršenstvo: da ne postavljamo opet temelja pokajanja od mrtvih dela, i vere u Boga,
\v 2 nauke krštenja, i stavljanja ruku, i vaskrsenja mrtvih, i suda večnog.
\v 3 I ovo ćemo učiniti ako Bog dopusti.
\v 4 Jer nije moguće one koji su jednom prosvetljeni, okusili dar nebeski, postali zajedničari Duha Svetog,
\v 5 i okusili dobru reč Božju, i silu onog sveta, i otpali,
\v 6 opet obnoviti na pokajanje, jer sami sebi nanovo raspinju i ruže sina Božijeg.
\v 7 Jer zemlja koja pije dažd što često na nju pada, i koja rađa povrće dobro onima koji je rade, prima blagoslov od Boga;
\v 8 a koja iznosi trnje i čičak, nepotrebna je i kletve blizu, koja se najposle sažeže.
\p 
\v 9 Ali od vas, ljubazni, nadamo se boljem i šta se drži spasenja, ako i govorimo tako.
\v 10 Jer Bog nije nepravedan da zaboravi delo vaše i trud ljubavi koju pokazaste u ime Njegovo, posluživši svetima i služeći.
\v 11 Ali želimo da svaki od vas pokaže to isto staranje da se nada održi tvrdo do samog kraja;
\v 12 da ne budete lenivi, nego da se ugledate na one koji verom i trpljenjem dobijaju obećanja.
\b
\p 
\v 13 Jer kad Bog Avramu obeća, ne imajući ničim većim da se zakune, zakle se sobom,
\v 14 govoreći: Zaista blagosiljajući blagosloviću te, i umnožavajući umnožiću te.
\v 15 I tako trpeći dugo, dobi obećanje.
\v 16 Jer se ljudi većim kunu, i svakoj njihovoj svađi svršetak je zakletva za potvrđenje.
\v 17 Zato i Bog kad htede naslednicima obećanja obilnije da pokaže tvrđu zaveta svog, učini posrednika kletvu:
\v 18 Da bi u dvema nepokolebljivim stvarima, u kojima Bogu nije moguće slagati, imali jaku utehu mi koji smo pribegli da se uhvatimo za nadu koja nam je dana,
\v 19 koji imamo kao tvrd i pouzdan lenger duše, koji ulazi i za najdalje zavese,
\v 20 gde Isus uđe napred za nas, postavši poglavar sveštenički doveka po redu Melhisedekovom.
\c 7
\s1 Hristos sveštenik kao Melhisedek, veći od sveštenika sinova Levijevih.
\p 
\v 1 Jer ovaj Melhisedek beše car salimski, sveštenik Boga Najvišeg, koji srete Avraama kad se vraćaše s boja careva, i blagoslovi ga;
\v 2 kome i Avraam dade desetak od svega. Prvo dakle znači car pravde, potom i car salimski, to jest car mira:
\v 3 Bez oca, bez matere, bez roda, ne imajući ni početka danima, ni svršetka životu, a ispoređen sa sinom Božijim, i ostaje sveštenik doveka.
\p 
\v 4 Ali pogledajte koliki je ovaj kome je i Avraam patrijarh dao desetak od plena.
\v 5 Istina, i oni od sinova Levijevih koji primiše sveštenstvo, imaju zapovest da uzimaju po zakonu desetak od naroda, to jest od braće svoje, ako su i izišli iz bedara Avramovih.
\v 6 Ali onaj koji se ne broji od njihovog roda, uze desetak od Avraama, i blagoslovi onog koji ima obećanje.
\v 7 Ali bez svakog izgovora manje blagoslovi veće.
\v 8 I tako ovde uzimaju desetak ljudi koji umiru, a onamo Onaj za kog se posvedoči da živi.
\v 9 I, da ovako kažem, Levije koji uze desetak, dao je desetak kroz Avraama:
\v 10 Jer beše još u bedrima očevim kad ga srete Melhisedek.
\b
\p 
\v 11 Ako je, dakle, savršenstvo postalo kroz levitsko sveštenstvo (jer je narod pod njim zakon primio), kakva je još potreba bila govoriti da će drugi sveštenik postati po redu Melhisedekovom, a ne po redu Aronovom?
\v 12 Jer, kad se promeni sveštenstvo, mora se i zakon promeniti.
\v 13 Jer za koga se ovo govori On je od drugog kolena, od kog niko ne pristupi k oltaru.
\v 14 Jer je poznato da Gospod naš od kolena Judina izađe, za koje koleno Mojsije ne govori ništa o sveštenstvu.
\p 
\v 15 I još je više poznato da će po redu Melhisedekovom drugi sveštenik postati,
\v 16 koji nije postao po zakonu telesne zapovesti nego po sili života večnog.
\v 17 Jer svedoči:
\b
\q1 Ti si sveštenik vavek
\q2 po redu Melhisedekovom.
\b
\p 
\v 18 Tako se ukida pređašnja zapovest, što bi slaba i zaludna.
\v 19 Jer zakon nije ništa savršio; a postavi bolju nadu, kroz koju se približujemo k Bogu.
\p 
\v 20 I još ne bez zakletve:
\v 21 Jer oni bez zakletve postaše sveštenici; a Ovaj sa zakletvom kroz Onog koji Mu govori:
\b
\q1 Zakle se Gospod i neće se raskajati:
\q2 Ti si sveštenik vavek
\q2 po redu Melhisedekovom.
\b
\p 
\v 22 Toliko boljeg zaveta posta Isus jamac.
\p 
\v 23 I oni mnogi biše sveštenici, jer im smrt ne dade da ostanu.
\v 24 A Ovaj, budući da ostaje vavek, ima večno sveštenstvo.
\v 25 Zato i može vavek spasti one koji kroza Nj dolaze k Bogu, kad svagda živi da se može moliti za njih.
\p 
\v 26 Jer takav nama trebaše poglavar sveštenički: svet, bezazlen, čist, odvojen od grešnika, i koji je bio više nebesa;
\v 27 kome nije potrebno svaki dan, kao sveštenicima, najpre za svoje grehe žrtve prinositi, a potom za narodne, jer On ovo učini jednom, kad sebe prinese.
\v 28 Jer zakon postavlja ljude za sveštenike koji imaju slabost; a reč zakletve koje je rečena po zakonu, postavi sina vavek savršena.
\c 8
\s1 Svetost i služba novozavetnog Poglavara viša je nego starozavetnog.
\p 
\v 1 A ovo je glava od toga što govorimo: imamo takvog Poglavara svešteničkog koji sedi s desne strane prestola Veličine na nebesima;
\v 2 koji je sluga svetinjama i istinitoj skiniji, koju načini Gospod, a ne čovek.
\v 3 Jer se svaki poglavar sveštenički postavlja da prinosi dare i žrtve; zato valja da i Ovaj šta ima što će prineti.
\v 4 Jer da je na zemlji, ne bi bio sveštenik, kad imaju sveštenici koji prinose dare po zakonu,
\v 5 koji služe obličju i senu nebeskih stvari, kao što bi rečeno Mojsiju kad htede skiniju da načini: Gledaj, reče, da načiniš sve po prilici koja ti je pokazana na gori.
\v 6 A sad dobi bolju službu, kao što je i posrednik boljeg zaveta, koji se na boljim obećanjima utvrdi.
\v 7 Jer da je onaj prvi bez mane bio, ne bi se drugom tražilo mesta.
\p 
\v 8 Jer kudeći ih govori:
\b
\q1 Evo dani idu, govori Gospod,
\q2 i načiniću s domom Izrailjevim i s domom Judinim nov zavet;
\q1 
\v 9 Ne po zavetu koji načinih s očevima njihovim
\q2 u onaj dan kad ih uzeh za ruku da ih izvedem iz zemlje misirske;
\q1 jer oni ne ostaše u zavetu mom,
\q2 i ja ne marih za njih,
\q2 govori Gospod.
\q1 
\v 10 Jer je ovo zavet koji ću načiniti s domom Izrailjevim posle onih dana,
\q2 govori Gospod:
\q1 daću zakone svoje u misli njihove,
\q2 i na srcima njihovim napisaću ih,
\q1 i biću im Bog,
\q2 i oni će biti meni narod.
\q1 
\v 11 I nijedan neće učiti svog bližnjeg,
\q2 i nijedan brata svog,
\q1 govoreći: Poznaj Gospoda;
\q2 jer će me svi poznati
\q2 od malog do velikog među njima.
\q1 
\v 12 Jer ću biti milostiv nepravdama njihovim,
\q2 i grehe njihove i bezakonja njihova neću više spominjati.
\b
\p 
\v 13 A kad veli: nov zavet, prvi načini vethim; a šta je vetho i ostarelo, blizu je kraja.
\c 9
\s1 Skinija i žrtva Starog zaveta nesavršena je; Hristova žrtva je potpuno dovoljna za pomirenje.
\p 
\v 1 Tako i prvi zavet imaše pravdu bogomoljstva i svetinju zemaljsku.
\v 2 Jer skinija beše načinjena prva, u kojoj beše svećnjak i trpeza i postavljeni hlebovi, što se zove svetinja.
\v 3 A za drugim zavesom beše skinija, koja se zove svetinja nad svetinjama,
\v 4 koja imaše zlatnu kadionicu, i kovčeg zaveta okovan svuda zlatom, u kome beše zlatan sud s manom, i palica Aronova, koja se beše omladila, i ploče zaveta.
\v 5 A više njega behu heruvimi slave, koji osenjavahu oltar; o čemu se ne može sad govoriti redom.
\p 
\v 6 A kad ovo beše tako uređeno, ulažahu sveštenici svagda u prvu skiniju i savršivahu službu Božiju.
\v 7 A u drugu ulažaše jednom u godini sam poglavar sveštenički, ne bez krvi, koju prinosi za sebe i za narodna neznanja.
\v 8 Ovim pokazivaše Duh Sveti da se još nije otvorio put svetih, dokle prva skinija stoji;
\v 9 koja ostade prilika za sadašnje vreme, u koje se prinose dari i žrtve, i ne mogu da se svrše po savesti onog koji služi.
\v 10 Osim u jelima i pićima, i različnom umivanju i pravdanju tela, koje je postavljeno do vremena popravljenja.
\b
\p 
\v 11 Ali došavši Hristos, poglavar sveštenički dobara koja će doći, kroz bolju i savršeniju skiniju, koja nije rukom građena, to jest, nije ovog stvorenja,
\v 12 ni s krvlju jarčijom, niti telećom, nego kroz svoju krv uđe jednom u svetinju, i nađe večni otkup.
\v 13 Jer ako krv junčija i jarčija, i pepeo juničin, pokropivši njom opoganjene, osvećuje na telesnu čistotu;
\v 14 a kamoli neće krv Hrista, koji Duhom Svetim sebe prinese bez krivice Bogu, očistiti savest našu od mrtvih dela, da služimo Bogu Živom i Istinitom?
\p 
\v 15 I zato je novom zavetu posrednik, da kroz smrt, koja bi za otkup od prestupaka u prvom zavetu, obećanje večnog nasledstva prime zvani.
\v 16 Jer gde je zavet valja da bude i smrt onog koji čini zavet.
\v 17 Jer je zavet po smrti potvrđen: budući da nema nikakve sile dok je živ onaj koji ga je načinio.
\v 18 Jer ni prvi nije utvrđen bez krvi.
\v 19 Jer kad Mojsije izgovori sve zapovesti po zakonu svom narodu, onda uze krvi jarčije i teleće, s vodom i vunom crvenom i isopom, te pokropi i knjigu i sav narod.
\v 20 Govoreći: Ovo je krv zaveta koji Bog načini s vama.
\v 21 A tako i skiniju i sve sudove službene pokropi krvlju.
\v 22 I gotovo sve se krvlju čisti po zakonu, i bez prolivanja krvi ne biva oproštenje.
\p 
\v 23 Tako je trebalo da se obličja nebeskih ovima čiste, a sama nebeska boljim žrtvama od ovih.
\v 24 Jer Hristos ne uđe u rukotvorenu svetinju, koja je prilika prave, nego u samo nebo, da se pokaže sad pred licem Božijim za nas;
\v 25 niti da mnogo puta prinosi sebe, kao što poglavar sveštenički ulazi u svetinju svake godine s krvlju tuđom:
\v 26 Inače bi On morao mnogo puta stradati od postanja sveta; a sad jednom na svršetku veka javi se da svojom žrtvom satre greh.
\v 27 I kao što je ljudima određeno jednom umreti, a potom sud:
\v 28 Tako se i Hristos jednom prinese, da uzme mnogih grehe; a drugom će se javiti bez greha na spasenje onima koji Ga čekaju.
\c 10
\s1 Sila Hristove žrtve. Slava Novog zaveta opominje da ostanemo u veri i priznanju.
\p 
\v 1 Jer zakon imajući sen dobara koja će doći, a ne samo obličje stvari, ne može nikada savršiti one koji pristupaju svake godine i prinose one iste žrtve.
\v 2 Inače bi se prestale prinositi se, kad oni koji služe ne bi više imali nikakve savesti za grehe, kad se jednom očiste;
\v 3 nego se njima svake godine čini spomen za grehe.
\v 4 Jer krv junčija i jarčija ne može uzeti grehe.
\p 
\v 5 Zato, ulazeći u svet govori:
\b
\q1 Žrtava i darova nisi hteo,
\q2 ali si mi telo pripravio.
\q1 
\v 6 Žrtve i prilozi za greh
\q2 nisu Ti bili ugodni.
\q1 
\v 7 Tada rekoh: Evo dođoh,
\q2 u početku knjige pisano je za mene,
\q2 da učinim volju Tvoju, Bože.
\b
\p 
\v 8 I više kazavši: Priloga i prinosa i žrtava, i žrtava za grehe nisi hteo, niti su Ti bili ugodni, što se po zakonu prinose;
\v 9 tada reče: Evo dođoh da učinim volju Tvoju, Bože. Ukida prvo da postavi drugo.
\v 10 Po kojoj smo volji mi osvećeni prinosom tela Isusa Hrista jednom.
\p 
\v 11 I svaki sveštenik stoji svaki dan služeći i jedne žrtve mnogo puta prinoseći koje nikad ne mogu uzeti grehe.
\v 12 A On prinesavši jedinu žrtvu za grehe sedi svagda s desne strane Bogu.
\v 13 Čekajući dalje dok se polože neprijatelji Njegovi podnožje nogama Njegovim.
\v 14 Jer jednim prinosom savršio je vavek one koji bivaju osvećeni.
\p 
\v 15 A svedoči nam i Duh Sveti; jer kao što je napred kazano:
\b
\q1 
\v 16 Ovo je zavet koji ću načiniti s njima posle onih dana,
\q2 govori Gospod:
\q1 Daću zakone svoje u srca njihova,
\q2 i u mislima njihovim napisaću ih;
\b
\p 
\v 17 I
\b
\q1 grehe njihove i bezakonja njihova neću više spominjati.
\b
\p 
\v 18 A gde je oproštenje ovih onde više nema priloga za grehe.
\b
\p 
\v 19 Imajući, dakle, slobodu, braćo, ulaziti u svetinju krvlju Isusa Hrista, putem novim i živim.
\v 20 Koji nam je obnovio zavetom, to jest telom svojim,
\v 21 i sveštenika velikog nad domom Božijim:
\v 22 Da pristupamo s istinim srcem u punoj veri, očišćeni u srcima od zle savesti, i umiveni po telu vodom čistom;
\v 23 da se držimo tvrdo priznanja nade: jer je veran onaj koji je obećao;
\v 24 i da razumevamo jedan drugog u podbunjivanju k ljubavi i dobrim delima,
\v 25 ne ostavljajući skupštinu svoju, kao što neki imaju običaj, nego jedan drugog savetujući, toliko većma koliko vidite da se približuje dan sudni.
\p 
\v 26 Jer kad mi grešimo namerno, pošto smo primili poznanje istine, nema više žrtve za grehe;
\v 27 nego strašno čekanje suda, i revnost ognja koji će da pojede one koji se suprote.
\v 28 Ko prestupi zakon Mojsijev, bez milosti umire kod dva ili tri svedoka.
\v 29 Koliko mislite da će gore muke zaslužiti onaj koji sina Božijeg pogazi, i krv zaveta kojom se osveti za poganu uzdrži, i Duha blagodati naruži?
\v 30 Jer znamo Onog koji reče: Moja je osveta, ja ću vratiti, govori Gospod; i opet: Gospod će suditi narodu svom.
\v 31 Strašno je upasti u ruke Boga Živoga.
\p 
\v 32 Opominjite se, pak, prvih dana svojih, u koje se prosvetliste i mnogu borbu stradanja podnesoste,
\v 33 koje postavši gledanje sa sramota i nevolja, a koje postavši drugovi onima koji žive tako.
\v 34 Jer se na okove moje sažaliste, i dadoste s radošću da se razgrabi vaše imanje, znajući da imate sebi imanje bolje i nepropadljivo na nebesima.
\v 35 Ne odbacujte, dakle, slobodu svoju, koja ima veliku platu.
\v 36 Jer vam je trpljenje od potrebe da volju Božiju savršivši primite obećanje.
\b
\q1 
\v 37 Jer još malo, vrlo malo,
\q2 pa će doći Onaj koji treba da dođe
\q2 i neće odocniti.
\q1 
\v 38 A pravednik živeće od vere;
\q2 ako li odstupi
\q2 neće biti po volji moje duše.
\b
\p 
\v 39 A mi, braćo, nismo od onih koji odstupaju na pogibao, nego od onih koji veruju da spasu duše.
\c 11
\s1 Vera i njena sila. Primeri verskih junaka iz Starog zaveta.
\p 
\v 1 Vera je, pak, tvrdo čekanje onog čemu se nadamo, i dokazivanje onog što ne vidimo.
\v 2 Jer u njoj stari dobiše svedočanstvo.
\v 3 Verom poznajemo da je svet rečju Božjom svršen, da je sve što vidimo iz ništa postalo.
\p 
\v 4 Verom prinese Avelj Bogu veću žrtvu nego Kain, kroz koju dobi svedočanstvo da je pravednik, kad Bog posvedoči za dare njegove; i kroz nju on mrtav još govori.
\v 5 Verom bi Enoh prenesen da ne vidi smrt; i ne nađe se, jer ga Bog premesti, jer pre nego ga premesti, dobi svedočanstvo da ugodi Bogu.
\v 6 A bez vere nije moguće ugoditi Bogu; jer onaj koji hoće da dođe k Bogu, valja da veruje da ima Bog i da plaća onima koji Ga traže.
\v 7 Verom Noje primivši zapovest i pobojavši se onog što još ne vide, načini kovčeg za spasenje doma svog, kojim osudi sav svet, i posta naslednik pravde po veri.
\p 
\v 8 Verom posluša Avraam kad bi pozvan da iziđe u zemlju koju htede da primi u nasledstvo, i iziđe ne znajući kuda ide.
\v 9 Verom dođe Avraam u zemlju obećanu, kao u tuđu, i u kolibama življaše s Isakom i s Jakovom, sunaslednicima obećanja tog.
\v 10 Jer čekaše grad koji ima temelje, kome je zidar i Tvorac Bog.
\v 11 Verom i sama Sara nerotkinja primi silu da zatrudni i rodi preko vremena starosti; jer držaše za vernog Onog koji obeća.
\v 12 Zato se i rodiše od jednog, još gotovo mrtvog, kao zvezde nebeske mnoštvom, i kao nebrojeni pesak pokraj mora.
\p 
\v 13 U veri pomreše svi ovi ne primivši obećanja, nego ga videvši izdaleka, i poklonivši mu se, i priznavši da su gosti i došljaci na zemlji.
\v 14 Jer koji tako govore pokazuju da traže otačanstvo.
\v 15 I da bi se oni opomenuli onog iz kog iziđoše, imali bi vreme da se vrate.
\v 16 Ali sad bolje žele, to jest nebesko. Zato se Bog ne stidi njih nazvati se Bog njihov; jer im pripravi grad.
\p 
\v 17 Verom privede Avraam Isaka kad bi kušan, i jedinorodnoga prinošaše, pošto beše primio obećanje,
\v 18 u kome beše kazano: U Isaku nazvaće ti se seme;
\v 19 pomislivši da je Bog kadar i iz mrtvih vaskrsnuti; zato ga i uze za priliku.
\v 20 Verom blagoslovi Isak Jakova i Isava u stvarima koje će doći.
\v 21 Verom blagoslovi Jakov umirući svakog sina Josifovog, i pokloni se vrhu palice njegove.
\v 22 Verom se opominja Josif umirući izlaska sinova Izrailjevih, i zapoveda za kosti svoje.
\p 
\v 23 Verom Mojsija, pošto se rodi, kriše tri meseca roditelji njegovi, jer videše krasno dete, i pobojaše se zapovesti careve.
\v 24 Verom Mojsije, kad bi veliki, ne htede da se naziva sin kćeri Faraonove;
\v 25 i volje stradati s narodom Božijim, negoli imati zemaljsku sladost greha:
\v 26 Državši sramotu Hristovu za veće bogatstvo od svega blaga misirskog; jer gledaše na platu.
\v 27 Verom ostavi Misir, ne pobojavši se ljutine careve; jer se držaše Onog koji se ne vidi, kao da Ga viđaše.
\v 28 Verom učini pashu i proliv krvi, da se onaj koji gubljaše prvorođene ne dotakne do njih.
\p 
\v 29 Verom pređoše Crveno More kao po suvoj zemlji; koje i Misirci okušavši potopiše se.
\v 30 Verom padoše zidovi jerihonski, kad se obilazi oko njih sedam dana.
\v 31 Verom Raav kurva ne pogibe s nevernicima, primivši uhode s mirom, i izvedavši ih drugim putem.
\p 
\v 32 I šta ću još da kažem? Jer mi ne bi dostalo vremena kad bih stao pripovedati o Gedeonu, i o Varaku i Samsonu i Jeftaju, o Davidu i Samuilu, i o drugim prorocima,
\v 33 koji verom pobediše carstva, učiniše pravdu, dobiše obećanja, zatvoriše usta lavovima,
\v 34 ugasiše silu ognjenu, pobegoše od oštrica mača, ojačaše od nemoći, postaše jaki u bitkama, rasteraše vojske tuđe;
\v 35 žene primiše svoje mrtve iz vaskrsenja; a drugi biše pobijeni, ne primivši izbavljenje, da dobiju bolje vaskrsenje;
\v 36 a drugi ruganje i boj podnesoše, pa još i okove i tamnice;
\v 37 kamenjem pobijeni biše, pretrveni biše, iskušani biše, od mača pomreše; idoše u kožusima i u kozjim kožama, u sirotinji, u nevolji, u sramoti;
\v 38 kojih ne beše dostojan svet, po pustinjama potucaše se, i po gorama i po pećinama i po rupama zemaljskim.
\p 
\v 39 I ovi svi dobivši svedočanstvo verom ne primiše obećanja;
\v 40 jer Bog nešto bolje za nas odredi, da ne prime bez nas savršenstva.
\c 12
\s1 Trpeti gledajući u Isusa. Biti blažen u Gospodu gledajući na nebeski Jerusalim.
\p 
\v 1 Zato, dakle, i mi imajući oko sebe toliku gomilu svedoka, da odbacimo svako breme i greh koji je za nas prionuo, i s trpljenjem da trčimo u bitku koja nam je određena,
\v 2 gledajući na Načelnika vere i Svršitelja Isusa, koji mesto određene sebi radosti pretrpe krst, ne mareći za sramotu, i sede s desne strane prestola Božijeg.
\b
\p 
\v 3 Pomislite, dakle, na Onog koji je takvo protivljenje protiv sebe od grešnika podneo, da ne oslabe duše vaše i da vam ne dotuži.
\v 4 Jer još do krvi ne dođoste boreći se protiv greha,
\v 5 i zaboraviste utehu koju vam govori, kao sinovima:
\b
\q1 Sine moj! Ne puštaj u nemar karanja Gospodnja,
\q2 niti gubi volje kad te On pokara;
\q1 
\v 6 Jer koga ljubi Gospod onog i kara;
\q2 a bije svakog sina kog prima.
\b
\p 
\v 7 Ako trpite karanje, kao sinovima pokazuje vam se Bog: jer koji je sin kog otac ne kara?
\v 8 Ako li ste bez karanja, u kome svi deo dobiše, dakle ste kopilad, a ne sinovi.
\v 9 Ako su nam dakle telesni očevi naši karači, i bojimo ih se, kako da ne slušamo Oca duhova, da živimo?
\v 10 Jer oni za malo dana, kako im ugodno beše, karahu nas; a Ovaj na korist, da dobijemo deo od Njegove svetinje.
\v 11 Jer svako karanje kad biva ne čini se da je radost, nego žalost; ali posle daće miran rod pravde onima koji su naučeni njime.
\p 
\v 12 Zato oslabljene ruke i oslabljena kolena ispravite,
\v 13 i staze poravnite nogama svojim, da ne svrne šta je hromo, nego još da se isceli.
\v 14 Mir imajte i svetinju sa svima; bez ovog niko neće videti Gospoda.
\v 15 Gledajte da ko ne ostane bez blagodati Božije: da ne uzraste kakav koren gorčine, i ne učini pakost, i tim da se mnogi ne opogane.
\v 16 Da ne bude ko kurvar ili opoganjen, kao Isav, koji je za jedno jelo dao prvorodstvo svoje.
\v 17 Jer znate da je i potom, kad htede da primi blagoslov, odbačen; jer pokajanje ne nađe mesta, ako ga i sa suzama tražaše.
\b
\p 
\v 18 Jer ne pristupiste ka gori koja se može opipati, i ognju razgorelom, oblaku, i pomrčini i oluji,
\v 19 i trubnom glasu, i glasu reči, kog se odrekoše oni koji čuše, da ne čuju više reči;
\v 20 jer ne mogahu da podnesu ono što se zapovedaše: Ako se i zver dotakne do gore, biće kamenjem ubijena.
\v 21 I tako strašno beše ono što se vide da Mojsije reče: Uplašio sam se i drhćem.
\v 22 Nego, pristupiste k sionskoj gori, i ka gradu Boga Živoga, Jerusalimu nebeskom, i mnogim hiljadama anđela,
\v 23 k saboru i crkvi prvorodnih koji su napisani na nebesima, i Bogu, sudiji svih, i duhovima savršenih pravednika,
\v 24 i k Isusu, Posredniku zaveta novog, i krvi kropljenja, koja bolje govori negoli Aveljeva.
\p 
\v 25 Ali gledajte da se ne odreknete Onog koji govori; jer kad oni ne utekoše koji se odrekoše onog koji prorokovaše na zemlji, a kamoli mi koji se odričemo nebeskog,
\v 26 kog glas potrese onda zemlju, a sad obeća govoreći; još jednom ja ću potresti ne samo zemlju nego i nebo.
\v 27 A što veli: još jednom, pokazuje da će se ukinuti ono što se pomiče, kao stvoreno, da ostane ono što se ne pomiče.
\v 28 Zato, primajući carstvo nepokolebano, da imamo blagodat kojom služimo za ugodnost Bogu, s poštovanjem i sa strahom.
\v 29 Jer je Bog naš oganj koji spaljuje.
\c 13
\s1 O ljubavi. Treba se čuvati razvrata i srebroljublja i opominjati se dobrih učitelja i ugledati se na njih. Završne opomene i pozdravi.
\p 
\v 1 Ljubav bratinska da ostane među vama.
\v 2 Gostoljubivosti ne zaboravljajte; jer neki ne znajući iz gostoljubivosti primiše anđele na konak.
\v 3 Opominjite se sužnja kao da ste s njima svezani, onih kojima se nepravda čini kao da ste i sami u telu.
\v 4 Ženidbu da drže svi u časti, i postelja ženidbena da bude čista; a kurvarima i preljubočincima sudiće Bog.
\v 5 Ne budite srebroljupci; budite zadovoljni onim što imate. Jer On reče: Neću te ostaviti, niti ću od tebe odstupiti;
\v 6 tako da smemo govoriti:
\b
\q1 Gospod je moj pomoćnik,
\q2 i neću se bojati;
\q2 šta će mi učiniti čovek?
\b
\p 
\v 7 Opominjite se svojih učitelja koji vam kazivaše reč Božiju; gledajte na svršetak njihovog življenja, i ugledajte se na veru njihovu.
\v 8 Isus Hristos juče je i danas onaj isti i vavek.
\v 9 U nauke tuđe i različne ne pristajte; jer je dobro blagodaću utvrđivati srca, a ne jelima, od kojih ne imaše koristi oni koji življaše u njima.
\v 10 Imamo, pak, oltar od kog oni ne smeju jesti koji služe skiniji.
\v 11 Jer kojih životinja krv unosi poglavar sveštenički u svetinju za grehe, onih se telesa spaljuju izvan logora.
\v 12 Zato Isus, da osveti narod krvlju svojom, izvan grada postrada.
\v 13 Zato dakle da izlazimo k Njemu izvan logora, noseći Njegovu sramotu.
\v 14 Jer ovde nemamo grada koji će ostati, nego tražimo onaj koji će doći.
\v 15 Kroz Njega, dakle, da svagda prinosimo Bogu žrtvu hvale, to jest plod usana koje priznaju ime Njegovo.
\v 16 A dobro činiti i davati milostinju ne zaboravljajte; jer se takvim žrtvama ugađa Bogu.
\p 
\v 17 Slušajte učitelje svoje i pokoravajte im se, jer se oni staraju za duše vaše, kao koji će dati odgovor, da to s radošću čine, a ne uzdišući; jer vam ovo ne pomaže.
\p 
\v 18 Molite se Bogu za nas. Jer se nadamo da imamo dobru savest, starajući se u svemu dobro da živimo.
\v 19 A odviše molim činite ovo, da bih se pre vratio k vama.
\b
\p 
\v 20 A Bog mira, koji izvede iz mrtvih velikog Pastira ovcama, krvlju zaveta večnog, Gospoda našeg Isusa Hrista,
\v 21 da vas savrši u svakom delu dobrom, da učinite volju Njegovu, čineći u vama šta je ugodno pred Njime, kroz Isusa Hrista, kome slava va vek veka. Amin.
\b
\p 
\v 22 Molim vas pak, braćo, primite reč poučenja; jer ukratko napisah i poslah vam.
\v 23 Znajte da je otišao naš brat Timotije, s kojim, ako skoro dođe, videću vas.
\v 24 Pozdravite sve učitelje svoje i sve svete. Pozdravljaju vas braća koja su iz Talijanske.
\v 25 Blagodat sa svima vama. Amin. 
