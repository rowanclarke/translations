\p
\v 1 \w Judas|strong="G2455"\w*, \w un|strong="G3588"\w* esclavo \w de|strong="G1722"\w* \w Jesucristo|strong="G2424"\w*, \w y|strong="G2532"\w* hermano \w de|strong="G1722"\w* \w Jacobo|strong="G2385"\w*, \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w llamados|strong="G2822"\w*, amados \w por|strong="G1722"\w* \w Dios|strong="G2316"\w* \w Padre|strong="G3962"\w* \w y|strong="G2532"\w* \w guardados|strong="G5083"\w* \w por|strong="G1722"\w* \w Jesucristo|strong="G2424"\w*.   
