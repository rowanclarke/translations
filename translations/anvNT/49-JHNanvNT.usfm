\id JHN 44JHNDENU.SFM Denya New Testament June 2009
\h Jɔn
\toc2 Jɔn
\toc3 Jɔn
\toc1 Abya melɔ́mélɔ́ Jisɔs Kras ndɛre JƆN ásamé
\mt2 Abya melɔ́mélɔ́ Jisɔs Kras ndɛre
\mt1 JƆN
\mt3 ásamé
\c 1
\s1 Mekomejɔɔ́ ayi achwɔɔ́ ne geŋwá
\p 
\v 1 Gemɛgé nnó mme yina alɔ, mekomejɔɔ́ abɔ alú mɛ. Mekomejɔɔ́ yimbɔ abɔ alu ne Ɛsɔwɔ ne mekomejɔɔ́ yimbɔ abɔ alu Ɛsɔwɔ.
\v 2 Abɔ́ alú mɛ́ ne Ɛsɔwɔ tɛ́ ula ulɔɔ́.
\p 
\v 3 Unó uko ɛbi Ɛsɔwɔ akwyɛɛ́ ukɛ́ ne ji. Ji ábɛ́ dampɔ, mmbɔ yɛ́ geno gema gepɔ.
\v 4 Mekomejɔɔ́ yimbɔ ne awyaa geŋwá. Ne geŋwá ɛyigémbɔ gelú lé geŋgbɔ mbaá akwaá.
\v 5 Geŋgbɔ ɛyigémbɔ gegɛnégé né mmu gemmua, yɛ́mbɔ gemua gékágé kweré gejí.
\p 
\v 6 Ɛsɔwɔ abɔ́ atɔ mende fɔ ayi ákuú ji nnó Jɔn,
\v 7 Jɔn achwɔ́ ndɛre ntɛsɛ, mangaré akwaá genó ɛyigé geŋgbɔ ɛyigémbɔ gelú, nnó ɛbwɔ́ awú áfyɛɛ́ metɔɔ́ ne gejí.
\v 8 Jimbɔɔ́ apɔ́fɔ́ geŋgbɔ́ ɛyigémbɔ, achwɔ́ lé nkane ntɛsɛ mampyɛ akwaá ákaá geŋgbɔ́ ɛyigémbɔ.
\v 9 Geŋgbɔ ɛyigé wáwálé, ɛyi gegɛnégé mbaá yɛ́ndémuú, gebɔ gechwɔɔ́ fa né mme.
\p 
\v 10 Ji abɔ́ alú fa mme, ne yɛ́ ɛlé mme ayi Ɛsɔwɔ akwyɛ akɛné ne jí, bɔɔ́ mme akaá fɔ́ ji wɔ́.
\v 11 Ji achwɔ́ né melɔ wuú, bɔɔ́ melɔ wuú ásɛ́ fɔ́ jí wɔ.
\v 12 Yɛ́mbɔ bɔɔ́ ako abi ásɛ́lé ji, áfyɛɛ́ matɔɔ́ ne ji, áchyɛɛ́ ɛbwɔ́ ɛbwɔnyɛ mambɛ baá Ɛsɔwɔ.
\v 13 Gefɔɔ́ ɛyigé ábyɛ́né ɛbwɔ́, gepɔ́fɔ́ ndɛre akwaá ábyɛne baá. Ne ɛpɔ́fɔ́ ntó ndɛre akwaá ákɛlegé, ɛpɔ́fɔ́ ntó ndɛre ntɛ akɛlege. Nebyɛne bwɔ́ netane mbaá Ɛsɔwɔ.
\p 
\v 14 Mekomejɔɔ́ yimbɔ, abwɔlé mekwaá, ajwɔle fa mme ne ɛse, alɛre galɔ́gálɔ́ ayi apwɔ amu ne ajɔ́gé depɔ ɛtire delú wáwálé. Degɛ́ ɛnoge ɛwé ji awyaá, ɛwé ji asɛ́le mbaá Ntɛ wuú ndɛre danchi Maá.
\p 
\v 15 Jɔn agarege bɔɔ́ geno ɛyigé ji agɛne getóme ne Jisɔs, ajɔ́gé keŋke aké, “Gɛgé muú ayi njɔɔ́gé nya nnó, ‘Ji ayi achwɔɔ́ mbɔ me meso apwɔ́ me, néndé gemɛgé nnó ábyɛ́ me, ji abɔ alu mɛ́.’”
\p 
\v 16 Ne gétúgé galɔ́gálɔ́ wuú apyɛ ɛse ako debɔ́ nebɔ matimati.
\v 17 Mabɛ́ Ɛsɔwɔ akɛ́ ne Mosis yɛ́mbɔ galɔ́gálɔ́ ne wáwálé ákɛ ne Jisɔs Kras.
\v 18 Yɛ́ muú ama ayi agɛne mɛ Ɛsɔwɔ apɔ́ ɛkose danchi maá wuú. Ji alu ntó ɛke Ɛsɔwɔ. Ji ayi alu fií ne ntɛ wuú ne apyɛ bɔɔ́ akaá gefɔɔ́ ɛyigé ntɛ alu.
\s1 Mekomejɔɔ́ ayi Jɔn menwyaá bɔɔ́ manaá Ɛsɔwɔ ágarége
\r (Mat 3:1-12; Luk 3:1-18)
\p 
\v 19 Ákpakpa bɔɔ́ Jus né Jɛrosalɛ átɔ ámpyɛɛ́ upɛ Ɛsɔwɔ ne ámpoó ámpyɛɛ́ upɛ Ɛsɔwɔ nnó áchwɔ́ ágií Jɔn nnó ji alú waá? Agigé mbɔ,
\p 
\v 20 Jɔn ashya fɔ́ mangaré ɛbwɔ́ wáwálé wɔ́. Gɛ na ne ji agare, aké “Me mpɔ́fɔ́ Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa.”
\p 
\v 21 Ágí ji áké, “Ne wɔ ɔlu waá? Nnó wɔ ɔlu ɛlé Ɛlija.” Ne Jɔn ashuú ɛbwɔ́ meko aké, “Ngba me mpɔ́.” Áma ágií ji áké, “Nnó wɔ ɔlu muú ɛkpávé Ɛsɔwɔ?” Ama ashuú ɛbwɔ́ meko aké, “Ngba.”
\p 
\v 22 Áké, “Wɔ ɔlu waá yɛɛ́, shuú ɛsé meko ayi dejyɛ garé bɔɔ́ abi atɔmé ɛsé. Wɔ mbɔɔ́ ɔké ɔlu waá?”
\p 
\v 23 Ne Jɔn ashuú ɛbwɔ́ meko aké, “Me nlu meko muú fɔ́ ayi ábɛ́ne né mashwɔne nnó, nyage meti Ata ɛbɛ cho; mbɔ ne Asaya muú ɛkpávé Ɛsɔwɔ abɔ ajɔɔ́.”
\p 
\v 24 Bɔɔ́ dentɔɔ́ bina álu ntó ɛkwɔ bɔɔ́ Farasi,
\v 25 Ne ágií Jɔn áké, “Ulannó wɔ ɔwyagé bɔɔ́ manaá Ɛsɔwɔ mbɔgé ɔpɔ́fɔ́ Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa, yɛ́ ɛlé Ɛlija yɛ́ ɛbɛ́ ɛlé muú ɛkpávé Ɛsɔwɔ ayi abɔ agare nnó achwɔɔ́?”
\p 
\v 26 Jɔn ashuú ɛbwɔ́ meko aké, “Me, nwyage ɛnyú ne manaá Ɛsɔwɔ mamímamí, yɛ́mbɔ muú fɔ alú fa metɔɔ́ metɔɔ́ ɛnyú ayi délá kágé ji.
\v 27 Achwɔɔ́ mbɔ me meso, me nkwané yɛ́ muú ayi akágé manyií unó uka ɛbií wɔ́.”
\p 
\v 28 Unó bi na uko upyɛ né melɔ Bɛtani né ɛgbɛ́ ɛbɛɛ́ Jodan mbaá Jɔn awyagé bɔɔ́ manaá Ɛsɔwɔ.
\s1 Jisɔs alu maá ɛgɔŋme Ɛsɔwɔ
\p 
\v 29 Bií ujyagé Jɔn agɛ́ ndɛre Jisɔs achwɔ́ɔ ɛta wuú, aké, “Gɛgé maá ɛgɔŋme Ɛsɔwɔ ayi akpáné gabo akwaá fa mme.
\v 30 Ji ne me mbɔ njɔɔ́ge ntome ne ji nnó, ‘Muú fɔ achwɔ́ɔ mbɔ me meso ayi apwɔɔ́ me néndé gemɛ́ge nnó ábyɛ́ me ji abɔ́ alu mɛ́.’
\v 31 Me mbɔɔ́, mbɔ nkaá fɔ́ ji wɔ́. Yɛ́mbɔ ula bi me nwyagé bɔɔ́ manaá Ɛsɔwɔ úlú ɛlé mampyɛ bɔɔ́ Isrɛli akaá ji.”
\p 
\v 32 Ne Jɔn agaré bɔɔ́ geno ɛyigé ji agɛne, aké, “Ngɛ́ Mendoó Ukpea ndɛre ɛtané mfaánebuú ɛké gepwine ɛchwɔ́ tɛ́ne ji mmyɛ.
\v 33 Me mbɔɔ́, nkaá fɔ ji wɔ́, yɛ́mbɔ muú ayi atɔmé me nnó nwyaá bɔɔ́ manaá agaré me aké, ‘Muú ayi ɔgɛné Mendoó Ukpea ɛ́shúlege ɛtɛné ji mmyɛ, ji yi mbɔ ne alú muú ayi awyagé bɔɔ́ ne Mendoó Ukpea.’
\v 34 Me ngɛ́ ndɛre ɛpyɛmbɔ ne Jisɔs, ne ngarege ɛnyú nnó ji alú Maá Ɛsɔwɔ.”
\s1 Baá utɔɔ́ abi Jisɔs abɔɔ́ mbɛ akuú
\p 
\v 35 Bií ɛbifɔ́ ujyágé, Jɔn ama atɛné ɛfɛɛ́ ne baá utɔɔ́ bií apea.
\v 36 Ndɛre agɛ́ne Jisɔs akɛne ajyɛ, ajɔɔ́ ne baá utɔɔ́ bií aké, “Gɛ́gé maá ɛgɔŋme gepɛgé Ɛsɔwɔ mbɔ.”
\p 
\v 37 Ne baá utɔɔ́ bií bimbɔ apeá áwúgé ndɛre Jɔn ajɔɔ́ mbɔ, ákwɔlé Jisɔs.
\v 38 Jisɔs ábwɔ́légé ushu meso agɛ́ ɛbwɔ́ ndɛre akwɔlégé ji, ágií ɛbwɔ́ aké, “Ɛnyú dekɛlégé ndé?” Ɛbwɔ́ aké ne ji “Rabi wɔ ɔjwɔlege ɛfɔ́” (Ula Rabi utɛne nnó menlɛré).
\p 
\v 39 Aké ne ɛbwɔ́, “Chwɔ́ge dégɛ́ mbaá ayi me njwɔlege.” Ɛbwɔ́ ákwɔlé yɛ́ ji ájyɛ gɛ́ mbaá awu, álá ɛwú ábɛlé ne ji bií bimbɔ. Gébé ɛyigémbɔ gébɔ́ gélú káláŋká ɛni né nkwale.
\p 
\v 40 Ne baá utɔɔ́ bina apeá abi áwuú ndɛre Jɔn ajɔɔ́ ákwɔlé Jisɔs, ama ɛle Andru meŋmo Simun Pita.
\v 41 Andru abɔ́ mbɛ akɛlé meŋmo wuú Simun. Agɛ́gé ji, agaré ji aké, “Ɛsé degɛ́ Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa.” Mabɔ ami na, malu wyɛ mabɔ mami mamaá ne Kras.
\v 42 Asɛ́ yɛ́ Simun afɛ́ mbaá Jisɔs ne Jisɔs apɛ́ ji domeé, aké, “Wɔ ɔkamege Simun maá Jɔn, akuú nyɛ ntó wɔ nnó Sɛfas.” Sɛfas alu wyɛ mabɔ mami mamaá ne Pita. (Ula Pita utɛne nnó ɛtárávɛ́.)
\s1 Jisɔs akú Filip ne Nataniɛl
\p 
\v 43 Bií ɛbifɔ ujyagé, Jisɔs akpome mmyɛ manjyɛ Galilií, ndɛre ajyɛɛ́ agɛ́ Filip, ajɔɔ́ ne ji aké, “Kwɔlé me.”
\p 
\v 44 Filip ntó atané Bɛtsada maá melɔ ayi Andru ɛbwɔ́ ne Pita atane wyɛ.
\v 45 Filip akɛle Nataniɛl. Agɛ́gé ji, agaré ji aké, “Ɛsé dégɛ́ muú ayi Mosis asamé né mabɛ́ atome ne ji ne bɔɔ́ ɛkpávé Ɛsɔwɔ ntó ásá ato ne ji. Alu Jisɔs muú Nasarɛt maá Josɛf.”
\p 
\v 46 Nataniɛl akale aké, “Ɛ ɛ́! Genó gelɔ́gélɔ́ ntó gétánege né Nasarɛt.”
\p Filip aké, “Chwɔ́ kpa amɛ jyɛ ɔgɛ́.”
\p 
\v 47 Jisɔs agɛ́gé ndɛre Nataniɛl achwɔɔ́ ɛta wuú, aké, “Gɛ́ maá Isrɛli ayi wáwálé na. abwɔlége fɔ dembwɔle.”
\p 
\v 48 Nataniɛl agií ji aké, “Ɔpyɛ nnó ne ɔkaá me?” Jisɔs ashuú ji meko aké, “Gemɛgé nnó Filip akú wɔ, me ngɛ́ mɛ wɔ né ulaá genɔɔ́ ɛyigé ákuú nnó fig.”
\p 
\v 49 Nataniɛl awúgé mbɔ, aké, “Ménlɛré wɔ ɔlu Maá Ɛsɔwɔ, ɔlu nto mfwa bɔɔ́ Isrɛli.”
\p 
\v 50 Jisɔs aké ne ji, gétúgé ngaré wɔ nnó ngɛ́ wɔ né ulaá genɔɔ́ ɛyigémbɔ, “Ne ɔfyɛɛ́ metɔɔ́ ne me? Ɔgɛ́ne nyɛ ukpɛ́kpɛ́ unó bi upwɔɔ́ ɛbi.”
\v 51 Ama ajɔɔ́ aké, “Ngarége ɛnyu wáwálé nnó, dégɛ́ne nyɛ nkane mfaánebuú anenege ne makiɛ́nné Ɛsɔwɔ akwɔme áshulege ne mfaa Maá Ntɛ Mekwaá.”
\c 2
\s1 Neba né melɔ Kana
\p 
\v 1 Bií ɛbifɔ́ ujyagé, né ndɔ ɛyi ɛgbeé ɛlɛɛ́, neba nefɔ́ nebɔ́ nélú né melɔ Kana né gebagé mewaá Galilií, mma Jisɔs abɔ́ alú wyɛ.
\v 2 Álɔ ntó Jisɔs ne baá utɔɔ́ bií né neba ɛníné mbɔ.
\v 3 Ne mmɔɔ́ ɛpaá ɛwémbɔ mabyɛgé mma Jisɔs ajɔɔ́ ne ji aké, “Mmɔɔ́ bwɔ́ mabyɛ.”
\p 
\v 4 Ne Jisɔs ajɔɔ́ ne ji aké, “Mma ɔgarégé fɔ́ me genó ɛyigé mbɔɔ́ mampyɛ, gébé ya gélú gakwáne.”
\p 
\v 5 Yɛ́mbɔ mma Jisɔs ajɔɔ́ ne baá defwɛ abi ánɛne aŋkɛɛ́ aké, “Pyɛgé yɛ́ndégenó ɛyigé ji agarege ɛnyú nnó dépyɛ.”
\p 
\v 6 Ɛké ɛpyɛɛ́mbɔ, bɔ nkwɔ́ manaá fɔ akené álú ɛfɛɛ́ kwɔ́kwɔ́lé abi bɔɔ́ Jus áchwɛle manaá wyɛ ne áshwɔ́nege byɔ bwɔ́ manɛmmyɛ mbaá Ɛsɔwɔ ndɛre gepɔgé bwɔ́ gélú. Nkwɔ́ ama akpɛne baá bɔ nda manaá ɛsaá yɛ́ ɛsaá meso ɛfya.
\p 
\v 7 Jisɔs ajɔɔ́ ne baá defwɛ abi ánɛ́ne aŋkɛɛ́ aké, “Fyɛgé manaá magbeé né bɔ ŋkwɔ́ bimbɔ.” Áfyɛgé manaá magbégé lábé lábé,
\v 8 aké ne ɛbwɔ́, “Chwɛgé amifɔ déchyɛ memgbare ɛpaá.” Ne ápyɛ wyɛ ndɛre ji ájɔɔ́.
\v 9 Ne memgbare ɛpaá afwɔ́régé manaá amimbɔ, ami mabwɔlé mmɔɔ́, akaá fɔ́ mbaá ayi mami matané wɔ́. Yɛ́mbɔ bɔɔ́ abi áchwɛlé manaá amimbɔ ákaá. Ne megbare ɛpaá akuú menɔ neba atɛné baba,
\v 10 ajɔɔ́ ne ji aké, “Yɛ́ndémuú anɛgé ɛpaá, abɔɔ́ kpɛ mbɛ achwɔ́ ne mmɔɔ́ malɔ́málɔ́. Bɔɔ́ ányúgé mɛ kpaá ápwagé ne achwɔ́ ne ami mabomabo. Ne wɔ ɔbelé mmɔɔ́ ami malɔ́málɔ́ mala kpaá tɛ́ nana”?
\p 
\v 11 Gɛ gepɔge ufélekpa mbɛ ɛyigé Jisɔs apyɛɛ na. Ápyɛ geji né Kana né gebagé mewaá Galilií. Apyɛ mbɔ manlɛre gepɔgé uto bií. Ne baá utɔɔ́ bií ágɛ́gé mbɔ áfyɛɛ́ matɔɔ́ ne ji.
\p 
\v 12 Ɛpaá ɛwémbɔ ɛbyɛ́gé, Jisɔs ashulé afɛ́ né Kapanɔm ne mma wuú, aŋmo bií ne baá utɔɔ́ bií, ɛfɛɛ́ ne ɛbwɔ́ ábɛlé mboó ndɔ.
\s1 Jisɔs abú bɔɔ́ bi ákpoó unó né mmu ɛcha upɛ Ɛsɔwɔ
\r (Mat 21:12-13; Luk 19:45-48; Jɔn 2:13-22)
\p 
\v 13 Ɛpaá koó upú bɔɔ́ Jus ɛlágé kwɔ́kwɔ́lé Jisɔs akwɔ́ afɛ́ né Jɛrosalɛ.
\v 14 Akwɔ́négé, akpɛ né mmu dachi ɛcha upɛ Ɛsɔwɔ. Agɛ́ ndɛre bɔɔ́ abi ákpóo mpɔ, magɔŋme, upwene mampyɛ upɛ mbaa Ɛsɔwɔ, ne abi ájwɔlé ákwɔ́rege maŋka.
\v 15 Agɛ́gé mbɔ, abɔ́ manyií akwyɛ getó, abú bɔɔ́ bimbɔ ako átané wyɛ chónchó ne magɔŋme, ne mpɔ. Atyá maŋka ayi bɔɔ́ abi ákɛne gesegé maŋka mankwɔré, amu makpókpógélé bwɔ́ agbɛ́.
\v 16 Ne anyá bɔɔ́ abi akpoó upwene aké, “Kpagé ubi détáné fa, débɔ́fɔ́ mambwɔlé gepúgé Ntɛ wa gélá ntoné gese wɔ́.”
\p 
\v 17 Jisɔs apyɛgé mbɔ, baá utɔɔ́ bií áte meko mejɔɔ́ ayi asamé né mmu ŋwɛ Ɛsɔwɔ nnó, “Géchyɛɛ́ ɛyigé me nwyaá né gepú jyɛ gesɔɔ́ me mmu ɛké mewɛ.”
\p 
\v 18 Ákpákpá bɔɔ́ Jus áchwɔ́ɔ jɔɔ́ ne Jisɔs áké, “Ndé gefɔgé gepɔ ɛyigé wɔ ɔkagé lɛré mampyɛ ɛsé dékaá nnó ɛlé Ɛsɔwɔ ne achyɛ wɔ ɛshyɛ mampyɛ depɔ ɛti.”
\p 
\v 19 Jisɔs ashuú ɛbwɔ́ meko aké, “Muúgé ɛcha upɛ ɛwéna, nsɛlé ndɔ ɛlɛɛ́ mpyɛ ɛwú ɛkere meso ndɛre ɛbɔ ɛlu”.
\p 
\v 20 Bɔɔ́ bimbɔ áké, “Ɔké ndeé? Ɛcha upɛ ɛwé, ɛsɛlé ɛsé usaá ŋmɛ upeá meso ɛkené mantɛné, ne wɔ ɔké ɔsɛlé ndɔ ɛlɛɛ́ mantɛné ɛwú?”
\v 21 Yɛ́mbɔ ɛcha upɛ ɛwé Jisɔs ajɔɔ́ mbɔ, ató ɛlé ne menyammyɛ wuú jimbɔɔ́.
\v 22 Jisɔs akwilégé né negbo, baá utɔɔ́ bií áte nnó ji abɔ́ ajɔɔ́ mɛ́ mechɔ́ ɛwé. Ákamé ne genó ɛyigé ŋwɛ Ɛsɔwɔ ajɔɔ́ ne ɛyigé Jisɔs ajɔɔ́.
\s1 Jisɔs akaá genó ɛyi gélú né metɔɔ́ akwaá
\p 
\v 23 Ne gébégé Jisɔs alú né Jɛrosalɛ anyɛɛ́ ɛpaá koó upú, apyɛ gejamégé bɔɔ́ áfyɛɛ́ matɔɔ́ ne ji gétúgé ufɔɔ́ unó ne ufélekpa ɛbi ji apyɛɛ́.
\v 24 Yɛ́mbɔ Jisɔs afyɛɛ́ fɔ́ matɔɔ́ ne ɛbwɔ́ wɔ́, néndé akaá ndɛre mekwaá alú.
\v 25 Ɛpɔ́sé ɛwé muú agarégé ji néndé jimbɔɔ́ akaá mɛ́ genó ɛyi gélú mekwaá metɔɔ́.
\c 3
\s1 Jisɔs ne Nikodɛmus
\p 
\v 1 Muú kpaá bɔɔ́ Jus fɔ abɔ́ alú, ayi ákuú ji Nikodɛmus. Alú muú ɛkwɔ́ bɔɔ́ Farasi.
\v 2 Mende yimbɔ achwɔ́ bané Jisɔs ne utuú, ajɔɔ́ ne ji aké, “Ménlɛré ɛsé dékaá nnó Ɛsɔwɔ ne atɔmé wɔ, néndé muú fɔ akágé pyɛ unó bi wɔ ɔpyɛ́ɛ, mbɔgé Ɛsɔwɔ álá pɔ́ ne ji.”
\p 
\v 3 Ne Jisɔs ashuú ji meko aké, “Ngarégé wɔ wáwálé nnó, mbɔgé álá ábyɛ́ muú mambyɛ ayi mekɛ wɔ́, agɛne fɔ́ gefwa ɛyigé Ɛsɔwɔ ágbárege.”
\p 
\v 4 Ajɔɔ́gé mbɔ, Nikodɛmus agií ji aké, “Muú akwɔ́gé mbɔ mɛ́ ukoó, ápyɛɛ́ mbɔ nnó ne ámá ábyɛ́ ji?” nno amage kpɛ né mmu unɛ mma wuú ábyɛ́ ji?
\p 
\v 5 Jisɔs ashuú ji meko aké, “Ngarégé wɔ wáwálé nnó mbɔgé álá ábyɛɛ́ muú nebyɛɛ́ né manaá ne Mendoó wɔ́, anyɛɛ́ fɔ́ gefwage Ɛsɔwɔ.
\v 6 Mekwaá abyɛne ɛle ntɛ mekwaá, Mendoó ntó ɛbyɛne ɛlé Mendoó.
\v 7 Ɛ́kágé ɔlá meno mekpo fuú, ɛlé njɔɔ́ ne wɔ nnó, abɔ́ mambyɛ́ muú mambyɛ́ ayi mekɛ.
\v 8 Mbyo amyɛ yɛ́ndé mbaá ayi akɛlégé, muú awuú gewya jií, yɛ́mbɔ ákágé fɔ mbaá ayi atané ne mbaá ayi ajyɛ. Wyɛmbɔ ntó ne ɛlu ne muú ayi ábyɛ́ne ji né Mendoó. Muu ákaáge gare fɔ́ ndɛre Mendoó ɛbyɛne Mendoó.”
\p 
\v 9 Nikodɛmus awúgé mbɔ, agií Jisɔs aké, “Ɛwéna ɛbɛɛ mbɔ nnó?”
\v 10 Jisɔs ashuú ji meko aké, “Wɔ ɔlú gekpɛ́kpɛ́gé menlɛré bɔɔ́ Isrɛli nnó ɔkágé unó bi?”
\v 11 Ngaregé wɔ wáwálé nnó, ɛsé dejɔɔ́ge depɔ ɛtiré dékágé, ne dégarege unó bi ɛsé dégɛ́ne, yɛ́mbɔ ɛnyú dékɛlege fɔ manwú.
\v 12 Ngarege ɛnyú unó bi upyɛ fa mme ɛnyú dékámégé, nnó ngare ɛnyú ɛbi upyɛ́ɛ né mfaánebuú ne dékámegé?
\v 13 Yɛ́ muú ayi akwɔmé mɛ́ ájyɛɛ́ né mfaánebuú apɔ́, ɛkosé wyɛ Maá Ntɛ Mekwaá ne atané mfaánebuú achwɔ́ɔ fa mme.
\v 14 Ndɛre Mosis abwɛɛ́ nyá mmyɔ né mashwɔne wyɛmbɔ ntó ne abɔɔ́ mambwɛ Maá Ntɛ Mekwaá né mfaá
\v 15 Ne yɛ́ndémuú ayi áfyɛɛ́ metɔɔ́ ne ji, abɔ́ geŋwá ɛyi gélágé byɛ́.
\p 
\v 16 Ɛsɔwɔ abɔ́ gejeé ne bɔɔ́ mme, nkáwú ne atɔmé danchi maá wuú nnó yɛ́ndémuú ayi áfyɛɛ́ metɔɔ́ ne ji, anomé fɔ́ mme detu, abɔ́ geŋwá ɛyi gélágé byɛ́.
\v 17 Ɛsɔwɔ átɔɔ́ fɔ́ Maá wuú fa mme nnó áchwɔ́ ágare nnó bɔɔ́ mme ákwe mpa wɔ́. Atɔ́ lé ji nnó áchwɔ́ áfere ɛbwɔ́ né ɛfwyale gabo.
\v 18 Yɛ́ndémuú ayi áfyɛɛ́ metɔɔ́ ne ji akwene fɔ́ mpa, yɛ́mbɔ muú ayi álá áfyɛɛ́ metɔɔ́ ne ji wɔ́ akwe mɛ́ mpa néndé áfyɛɛ́ fɔ́ metɔɔ́ ne danchi Maá Ɛsɔwɔ wɔ́.
\v 19 Gɛ́ na ne mpa ayi mbɔ abɛɛ́ nyɛ. Geŋgbɔ́ gechwɔ́ fa mme, yɛ́mbɔ bɔɔ́ ágbóo ne gemua ápwɔ geŋgbɔ́ néndé unó bi ɛbwɔ́ abɔ ápyɛ ulɔmé fɔ.
\v 20 Ne yɛ́ndémuú ayi apyɛ́ɛ gabo akií fɔ geŋgbɔ́, ne akɛ́légé fɔ́ manchwɔ́ né geŋgbɔ́ nnó ɛkágé gabo wuú agɛ́né.
\v 21 Yɛ́mbɔ muú ayi apyɛ́ɛ galɔ́gálɔ́, achwɔɔ́ né geŋgbɔ́, nnó galɔ́gálɔ́ wuú agɛ́né ágɛ́ nnó ji apyɛ́ɛ ndɛre Ɛsɔwɔ akɛ́lege.
\s1 Jɔn menwyaá bɔɔ́ manaá Ɛsɔwɔ agaré ndɛre Jisɔs alu
\p 
\v 22 Ɛwyágé Jisɔs ne baá utɔɔ́ bií alyaá Jɛrosalɛ, áfɛ́ né gebagé mewaá Judiya ábɛlé ɛwú mboó ndɔ awyagé bɔɔ́ manaá Ɛsɔwɔ.
\v 23 Né gébé ɛyigémbɔ, Jɔn menwyaá bɔɔ́ manaá Ɛsɔwɔ abɔ́ awyagé ntó bɔɔ́ manaá Ɛsɔwɔ né melɔ Ɛnɔn ɛwé ɛlú kwɔ́kwɔ́lé ne melɔ Salim, ɛlé manaá malú ɛwú dɔɔ́. Bɔɔ́ ájyɛ ɛta wuú awyagé ɛbwɔ́ manaá Ɛsɔwɔ.
\v 24 (Né gébé ɛyigémbɔ, ábɔ́ álú danfyɛ Jɔn né denɔ.)
\v 25 Ɛwyágé muú Jus fɔ alɔ́ manyɛ mbeé ne baá utɔɔ́ Jɔn, gétúgé gefɔɔ́ ɛyigé muú abɔɔ́ manshwɔné mmyɛ ne ábɛ́ pópó né mbɛ ushu Ɛsɔwɔ.
\v 26 Ne baá utɔɔ́ Jɔn achwɔ́ ɛta wuú agaré ji aké, “Ménlɛré, mende ayi nyá ɔbɔ́ ɔlu ne ji né ɛgbɛ́ ɛbɛɛ́ Jodan ɛwé né, ayi ɔbɔ ɔgarege bɔɔ́ gétú jií, alú mbɔ fa ne bɔɔ́ ako ájyɛɛ́ ɛta wuú awyagé ɛbwɔ́ manaá Ɛsɔwɔ.”
\p 
\v 27 Ájɔɔ́gé mbɔ, Jɔn ashuú ɛbwɔ́ meko aké, “Muú fɔ akágé bɔ́ genó ɛkose nno Ɛsɔwɔ achyɛge ji geji.
\v 28 Ɛnyú ambɔɔ́ délú bɔ ntɛ́sɛ́ ba gébégé ngaré nnó, ‘Me mpɔ́ fɔ́ Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa. Ɛsɔwɔ atɔ me nnó mbɔ́ mbɛ ne ji.’
\v 29 Menɔ neba ne awyaá mendée neba, yɛ́mbɔ mejeé menɔ neba, muú ajwɔlege awuú meko menɔ neba, abɛɛ́ ne nechɔ́chɔ́ gétúgé meko menɔ neba ayi ji awuú. Nechɔ́nchɔ́ ɛnina nelú ɛna, ne nana metɔɔ́ ɛgɔɔ́ me gétúgé mende yina.
\v 30 Ji abɔ́ mankwɔ́ ŋgɔ́, me mbɔ́ magbó gelú.”
\p 
\v 31 “Muú yi atané mfaánebuú aŋea gemɛ apwɔ bɔɔ́ ako. Muú mme, abyɛ wyɛ muú mme ne ajɔɔ́gé lé depɔ ndɛre bɔɔ́ mme ájɔɔ́ge. Ji ayi atané mfaánbeuú apwɔ bɔɔ́ ako.
\v 32 Ji agarege unó bi ji awuú ne ɛbi agɛ́ne, yɛ́mbɔ yɛ́ muú yi akamege meko wuú apɔ́.
\v 33 Yɛ́ndémuú ayi akámege meko mejɔɔ́ wuú alɛrege nnó genó ɛyigé Ɛsɔwɔ ajɔɔ́ gelú wáwálé.
\v 34 Ne muú yi Ɛsɔwɔ atɔmé, ajɔɔ́gé ɛlé depɔré Ɛsɔwɔ néndé Ɛsɔwɔ achyɛge ji uto Mendoó wuú byágébyágé.
\v 35 Ntɛ agboó ne Maá, ne afyɛ ji unó uko né amu.
\v 36 Ne yɛ́ndémuú ayi áfyɛɛ́ metɔɔ́ ne Maá yimbɔ, awyaá geŋwá ɛyi gélágé byɛ́. Yɛ́mbɔ, yɛ́ndémuú ayi atoó mekpo mamfyɛ metɔɔ́ ne ji agɛ́né fɔ́ geŋwá ɛyigémbɔ, metɔɔ́ usɔɔ́ Ɛsɔwɔ ɛlu ne muú yimbɔ tɛ kwyákwyá.”
\c 4
\p 
\v 1 Ɛkwɔ́ bɔɔ́ Farasi áwú nnó bɔɔ́ abi ajyɛɛ mbaa Jisɔs, ji awyage ɛbwɔ́ manaá Ɛsɔwɔ aja apwɔ abi ajyɛɛ mbaá Jɔn.
\v 2 Yembɔ wáwálé alú nnó Jisɔs jimbɔ awyáge fɔ́ bɔɔ́ manaá Ɛsɔwɔ, ɛlé baá utɔɔ́ bií ne áwyáge.
\v 3 Ne Jisɔs awúgé nnó bɔɔ́ Farasi áwu nnó bɔɔ́ abi áchwɔɔ́ ɛta wuú aja apwɔ abi Jɔn, alyaá Judiya akeré meso né Galilií,
\v 4 abɔ́ mankoó wyɛ né gebage mewaá Samariya ne afɛ́ né gebagé mewaá Galilií.
\p 
\v 5 Ákwɔ́négé né gebagé mewaá Samariya akwɔné melɔ ɛwé ákuú nnó Sikar. Sikar alú kwɔ́kwɔ́lé ne melú mme ɛwé Jakɔb abɔ́ achyɛ́ɛ maá wuú Josɛf.
\v 6 Ɛmbu manaá ɛwé Jakɔb abɔ́ áchomé ɛlú ntó ɛfɛɛ́. Jisɔs ákɛgé ápwagé, ajyɛ jwɔ́lé wyɛ. Gébé gélú kalaŋká ɛfyánéɛpeá ne ŋwɔmese ɛyigé Jisɔs akwɔné né mbaá yimbɔ.
\p 
\v 7 Ɛké ɛwyáge, mendée Samariya fɔ achwɔ́ ɛfɛɛ́ manchwɛ́ manaá. Jisɔs ajɔɔ́ ne ji aké, “Chyɛɛ́ me manaá nyú.”
\v 8 Gébé ɛyigémbɔ, baá utɔɔ́ bií áfɛ́ né melɔ manjyɛ na menyɛɛ́.
\p 
\v 9 Mendée Samariya yimbɔ aké, ne ji “Wɔ ɔlú muú Jus, me nlú muú Samariya, ɛpyɛɛ́mbɔ nnó ne ɔgií me manaá manyú?” Ajɔɔ́ mbɔ néndé bɔɔ́ Jus ne bɔɔ́ Samariya átuúgé fɔ. \f + \fr 4:9 \ft Ɛlú wáwálé nnó: Bɔɔ́ Jus átugé fɔ́ ne bɔɔ́ Samariya nendé gébé ɛyigé bɔɔ́ Asariya amyɛɛ́ be ápwɔɔ́ bɔɔ́ Isrɛli, ákpa ɛbwɔ́ áfɛ ndɛre afwɛ. Ne abi álá né gebagé mewaá Samariya ába bɔɔ́ abi álá pɔ́ fɔ́ bɔɔ́ Jus. Ndɛre ɛlúmbɔ, bɔ Jus bifɔ abi ála né gebagé mewaá Judiya, ásɛ nnó ɛbwɔ́ ápɔ pópó né mbɛ ushu Ɛsɔwɔ.\f*
\p 
\v 10 Jisɔs ashuú ji meko aké, “Wɔ ɔbɔ́ ɔkaá mbɔ ɛchyɛ ɛwé Ɛsɔwɔ achyɛgé ne gefɔgé muú ayi agií mbɔ wɔ manaá, mbɔ ɔgií ji, ne ji abɔ́ achyɛgé wɔ manaá ami machyɛge geŋwá.”
\p 
\v 11 Mendée yimbɔ ajɔɔ́ ne ji aké, “Ata ɔpɔ́ ne genó manchwɛ́ manaá, ne ɛmbu manaá ɛwéna ɛgomé. Ɔpyɛ́ɛ mbɔ nnó ne ɔgɛ́ manaá ami machyɛgé geŋwá?
\v 12 Nnó wɔ ɔŋeá gemɛ ɔpwɔ gekwenege ntɛ sé Jakɔb muú áchomé ɛsé ɛmbu manaá ɛwéna? Ɛwé jimbɔ, baá bií ne utú bií anyuú manaá wyɛ.”
\p 
\v 13 Jisɔs aké ne ji, “Yɛ́ndémuú ayi anyú manaá amina, mmwɔ́lé manaá ɛmágé pyɛ ji,
\v 14 yɛ́mbɔ, yɛ́ndémuú ayi anyúu manaá ami me nchyɛge nyɛ, mmwɔ́lé manaá ɛmágé pyɛ sé ji tɛ kwyakwya. Ne manaá ami me nchyɛge ji, mabwɔlége nyɛ mala ɛta wuú ɛké ɛmbu nnyi ɛwé ɛtanege manaá ami machyɛ́ge geŋwá ɛyi gélágé byɛ́.”
\p 
\v 15 Mendée yimbɔ aké, “Ata chyɛɛ́ me manaá amimbɔ nnó mmwɔ́lé manaá ɛpyɛgé sé me, ne nnó nchwɔ́ge sé fa manchwɛ́ manaá.”
\p 
\v 16 Jisɔs ajɔɔ́ ne ji, aké, “Chó kuú menɔ wyɛ ɛnyú déchwɔ́.”
\p 
\v 17 Ne mendée yimbɔ ashuú ji meko aké, “Me mmpɔ ne menɔ”,
\p Jisɔs aké, “Wɔ ɔlú cho ndɛre ɔké ɔpɔ́ ne menɔ,
\v 18 néndé ɔbɔ́ ɔbá mɛ́ anɔ ata, ne ayi ɔlú mbɔ ne ji nana, apɔ́ fɔ́ menɔ wyɛ. Genó ɛyigé wɔ ɔjɔɔ́ mbɔ gélú wáwálé.”
\p 
\v 19 Mendée yimbɔ ajɔɔ́ ne ji aké, “Ata ɛlúmbɔ ɛké wɔ ɔlú muú ɛkpávé Ɛsɔwɔ.
\v 20 Ukwene antɛ sé ábɔ́ ánógé Ɛsɔwɔ né mekwɛ ɛwéna, yɛ́mbɔ ɛnyú bɔɔ́ Jus deké ánógé ɛlé Ɛsɔwɔ né melɔ Jɛrosalɛ.”
\p 
\v 21 Jisɔs ajɔɔ́ ne ji aké, “Kámé genó ɛyigé me njɔɔ́gé, gébé gechwɔ́ nyɛ ɛyigé ɛnyú délá nógé sé Ɛsɔwɔ fa né mekwɛ ɛwéna, yɛɛ́ ɛbɛ́lé né Jɛrosalɛ.
\v 22 Ɛnyú bɔɔ́ Samariya dénógé genó ɛyigé délá kaágé, ɛsé bɔɔ́ Jus dénógé genó ɛyigé dékaágé néndé muú ayi áférege akwaá né ɛfwyale gabo atanege nyɛ ɛlé né mbaá bɔɔ́ Jus.
\v 23 Yɛ́mbɔ gébé gechwɔ́ɔ, ne géchwɔ́ mɛ́, ɛyige bɔɔ́ abi anógé Ntɛ sɛ wáwálé anoge nyɛ ji né gefɔɔ́ ɛyi gelu wáwálé ndɛre Mendoó Ɛsɔwɔ ɛlɛrege. Gɛ́ ufɔɔ́ bɔɔ́ abi Ɛsɔwɔ akɛ́lege nnó ánoógé ji mbɔ.
\v 24 Ɛsɔwɔ alú Mendoó ne bɔɔ́ abi anógé ji abɔ́ manógé ji né gefɔɔ́ ɛyi gelu wáwálé ndɛre Mendoó Ɛsɔwɔ ɛlɛrege.”
\p 
\v 25 Ne mendée yimbɔ aké, “Nkaá nnó Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa, ayi akuú ji Kras achwɔ́ɔ, gébégé achwɔ́gé agarege nyɛ ɛsé yɛ́ndégenó cháŋéné.”
\p 
\v 26 Jisɔs agaré yɛ́ ji aké, “Me yi njɔ́ge mbɔ nlu ji awu.”
\p 
\v 27 Ɛké ɛwyágé baá utɔɔ́ Jisɔs áchwɔ́; ne álá meno mekpo fuú nkane ágɛ́né ji ajɔɔ́ge mejɔɔ́ ne mendée yɛ́mbɔ yɛ́ muú ayi agií ji nnó ɔkɛlege ndé, yɛ́ ɛbɛ́ ɛlé nnó ulannó ɔjɔɔ́ge mejɔɔ́ ne mendée yina apɔ́.
\p 
\v 28 Mendée yimbɔ alyaá yɛ́ ŋkwɔ́ manaá wuú ɛfɛɛ́ afɛ́ né melɔ ajyɛ gáré bɔɔ́ aké,
\v 29 “Chwɔ́ge dégɛ́ mende ayi agaré me yɛ́ndégenó ɛyige me mbɔ mpyɛ́ɛ. Nnó ji ne alu Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa?”
\v 30 Ne bɔɔ́ átané né melɔ ájyɛ́ɛ gɛ́ Jisɔs.
\p 
\v 31 Né gébé ɛyigé mendée yimbɔ ajyɛɛ né melɔ, baá utɔɔ́ Jisɔs ákpeáge ji áké, “Ménlɛré nyɛ́ menyɛɛ́.”
\p 
\v 32 Yɛ́mbɔ Jisɔs ajɔɔ́ ne ɛbwɔ́ aké, “Me nwya menyɛɛ́ manyɛ́ ayi ɛnyú délá kaá wɔ́.”
\p 
\v 33 Ajɔɔ́gé mbɔ, baá utɔɔ́ bií ájɔɔ́ ne atɛ aké, “Nnó muú fɔ achwɔ́ ji ne menyɛɛ́?”
\p 
\v 34 Ndɛre ájɔɔ́gé mbɔ, Jisɔs aké, “Menyɛɛ́ wa alú ɛlé mampyɛ genó ɛyigé muú ayi atɔmé me akɛ́lege ne mampyɛ utɔɔ́ bií nnéré chánchá.
\v 35 Pɔ́ ɛnyú déjɔɔ́ge na nnó, ‘Ɛla amfaá ani ne mbwɛ́ ákwɔ́né mamferé?’ Yɛ́mbɔ me ngarege ɛnyú nnó bwɛge amɛ dépɛ makɔɔ́, mbwɛ akwɔné mɛ́ mamferé.
\v 36 Yɛ nana muú ayi aférégé mbwɛ́ abɔɔ́ nsa wuú ne anywerege mbwɛ́ yimbɔ́ ne mbwɛ́ yimbɔ ɛle geŋwá ɛyi gélágé byɛ́. Ɛ́bɛgé mbɔ, mempɛné ne memferé ábɛɛ́ ne nechɔ́chɔ́ chónchó.
\v 37 Ɛ́pyɛgémbɔ, nekanemejɔɔ́ ɛniné ajɔɔ́ nnó, ‘Mempɛné apɛgé, memferé aféré’ nelú wáwálé.
\v 38 Me ntɔ́ ɛnyú nnó déjyɛɛ́ déféré mbwɛ́ né mekɔɔ́ ɛwé ɛnyú déla dépɛ́ɛ mbwɛ́ wyɛ wɔ́. Bɔɔ́ abi chá ápyɛ utɔɔ́, ɛnyú débɔ́ nsá né utɔɔ́ bwɔ́.”
\s1 Gejamégé bɔɔ́ Samariya áfyɛ́ metɔɔ́ ne Jisɔs
\p 
\v 39 Né gébé ɛyigémbɔ gejamégé bɔɔ́ Samariya, áfyɛ́ metɔɔ́ ne Jisɔs gétúgé genó ɛyigé mendée yimbɔ agaré ɛbwɔ́ nnó, “Ágaré me yɛ́ndégenó ɛyigé mbɔ́ mpyɛ́ɛ.”
\v 40 Bɔɔ́ Samariya bimbɔ, ágɛ́gé Jisɔs, ánɛ́ ji mmyɛ nnó ajwɔ́lé ne ɛbwɔ́, ne Jisɔs abɛlé ne ɛbwɔ́ ndɔ ɛpeá.
\p 
\v 41 Né mboó ndɔ ɛyimbɔ, gejamégé bɔɔ́ ama áfyɛ́ metɔɔ́ ne Jisɔs gétúgé mekomejɔɔ́ ayi ji ágaré.
\v 42 Ne ájɔɔ́ ne mendée yimbɔ aké, “Ɛsé défyɛɛ́ metɔɔ́ ne Jisɔs nana ɛpɔ́sé gétúgé mekomejɔɔ́ ayi ɔgaré ɛsé néndé ɛsé ambɔɔ́ déwú ne dékaá nnó ji alu Mempoó bɔɔ́ mme wáwálé.”
\s1 Jisɔs apyɛ́ɛ maá muú kpaá gɔ́mena atoó
\p 
\v 43 Ndɔ yimbɔ ɛpea ɛkógé, Jisɔs alyaá melɔ Samariya afɛ́ né Galilií.
\v 44 Jisɔs jimbɔɔ́ abɔ́ ajɔɔ́ mɛ́ aké, “Muú ɛkpávé Ɛsɔwɔ apɔ́ ne ɛ́nógé né melɔ wuú.”
\v 45 Ákwɔ́négé né Galilií bɔɔ́ melɔ Galilií ásɛ́ ji amu apeá néndé ɛbwɔ́ ágɛ́ yɛ́ndégenó ɛyigé Ji apyɛɛ́ né Jɛrosalɛ gébégé ɛpaá koó upú. Ɛlé ɛbwɔ́ ntó ábɔ́ álú wyɛ.
\p 
\v 46 Ne Jisɔs ama ajyɛ́ɛ né melɔ Kana ɛwé ji abɔ́ apyɛɛ́ manaá mábwɔ́lé mmɔɔ́ né gebagé mewaá Galilií. Ne muú kpaá gɔ́mena fɔ abɔ́ alú né melɔ Kapanɔm ayi maá wuú abɔ amée.
\v 47 Mende yimbɔ awúgé nnó Jisɔs atané melɔ Judiya achwɔ́ né Galilií, ajyɛ́ nɛ ji mmyɛ nnó áchwɔ́ ápyɛɛ́ maá wuú ayi amée álá magbómagbó átoó.
\p 
\v 48 Ne Jisɔs ajɔɔ́ yɛ́ ne ji aké, “Me nlá mpyɛ́ gepɔgé ufélékpá ɛbi ulɛ́rege utó Ɛsɔwɔ wɔ́, ɛnyú défyɛɛ́ fɔ́ matɔɔ́ ne me.”
\p 
\v 49 Ajɔɔ́gé mbɔ, muú kpaá yimbɔ aké, “Ata chwɔ́ déjyɛ́ ɛkágé maá wa agbó.”
\p 
\v 50 Ne Jisɔs ajɔɔ́ ne ji aké, “Chó maá wyɛ́ atoge nyɛ.”
\p Ne mende yimbɔ akamé ne mekomejɔɔ́ ayi Jisɔs ajɔɔ́ mbɔ, afɛ́.
\v 51 Ndɛre mende yimbɔ ajyɛ́ɛ, baá défwɛ bií átuú ne ji né meti, ágaré ji áké, “Maá wyɛ alu mebɛ.”
\v 52 Ne mende yimbɔ agií ɛbwɔ́ gébé ɛyigé maá yimbɔ atoó. Áké, “Gefwene yimbɔ gébyɛ́ ji mmyɛ njuna né kalaŋká ama.”
\p 
\v 53 Ágárégé ji mbɔ, ate nnó ɛlé wyɛ né gébé ɛyigémbɔ ne Jisɔs abɔ́ ajɔɔ́ ne ji nnó, “Maá wyɛ atógé nyɛ.” Ndɛre ɛpyɛɛ́mbɔ mende yimbɔ ne ula gepú bií uko áfyɛ́ metɔɔ́ ne Jisɔs.
\p 
\v 54 Gɛ́ ndɔ ayi agbeé maŋáne apea ayi Jisɔs alɛré gepɔgé ufélékpá né Galilií gébégé atané né Judiya.
\c 5
\s1 Jisɔs apyɛ mbwére atoó
\p 
\v 1 Ndɔfɔ́ ɛkógé, Jisɔs alyaá Galilií akwɔ́ afɛ́ né Jɛrosalɛ manjyɛ nyɛ́ ɛpaá bɔɔ́ Jus fɔ́.
\v 2 Né melɔ Jɛrosalɛ, géntoógé manaá fɔ́ gélú wyɛ́ ɛyigé anɔ geji nebɔ agbá ata, Kwɔ́kwɔ́lé ne menombi ɛwé magɔ́ŋme ákóge wyɛ. Ákuú geji né mejɔɔ́ Hibru nnó Bɛtsata.
\v 3 Gejamégé bɔɔ́ abi amée, ájwɔlége wyɛ. Abi amɛ nónómé, ubwéré, ne abi amée unchanchi. Ágile nnó Nnyi nebulé.
\v 4 Ɛkiɛ́nné Ɛsɔwɔ fɔ́ ɛchwɔ́ɔ, gébégébé ɛbúlege géntoógé manaá ɛyimbɔ. Ne muú ayi ábɔɔ́ mbɛ ashúlége né mmu manaá mimbɔ, yɛ́ndé nemée ɛniné ji amée nebyɛɛ́. \f + \fr 5:4 \ft Ɛlú wáwálé nnó: Malɔ ani yina, apɔ́ né ukwéne bɔ ŋwɛ.\f*
\v 5 Mende fɔ ntó ayi abɔ́ amée né aŋmɛ ɛsaá meso nekuúnelɛɛ́ abɔ alu ɛfɛɛ́.
\v 6 Jisɔs agɛ́gé ji ndɛre álú ɛ́fɛɛ́ bɛ́lé, akaá nnó amée mɛ́ né gejamégé aŋmɛ. Agií ji aké, “Ɔkɛlege nemée nyɛ́ɛ nebyɛ?”
\p 
\v 7 Mende yimbɔ ashuú ji meko aké, “Ata, mpɔ́ ne muú ayi akpané me afyɛɛ́ né mmu gentoó ɛyigémbɔ gébégé nnyi nébulégé. Yɛ́ndégébé nkulégé manjyɛ, muú yicha abɔ́ mbɛ.”
\p 
\v 8 Ajɔɔ́gé mbɔ, Jisɔs aké ne ji, “Kwilé ka, pwi gebɔ jyɛ́, ɔjyɛ mmu.”
\v 9 Ne tɛ́nétɛ́né ayi Jisɔs ajɔɔ́ mbɔ mende yimbɔ atoó, akwilé ka, apwi gébɔ jií akɛne.
\p Mechɔ́ ɛwéna ɛpyɛ́ né bií uwyaá bɔɔ́ Jus.
\v 10 Ɛpyɛ́gémbɔ, ákpakpa bɔɔ́ Jus ájɔɔ́ ne mende yi atoó mbɔ áké, “Fina ɛlé bií uwyaá, ne ɛbɛ́ sé ɛkamé fɔ́ nnó muú akpá gébɔ né bií uwyaá wɔ́.”
\p 
\v 11 Ne mende yimbɔ ashuú ɛbwɔ́ meko aké, “Muú ayi apyɛ me ntoó ne agaré me nnó nkpá gébɔ ya nkɛ njyɛ.”
\p 
\v 12 Ákpakpa bimbɔ, ágií ji áké, “Ndé muú awú agaré wɔ nnó ɔkpá gébɔ jyɛ ɔkɛné”?
\p 
\v 13 Mende yimbɔ akagé sé muú ayi apyɛ ji atoó, néndé gejamégé bɔɔ́ abɔ́ alú ɛfɛɛ́, ne Jisɔs akpɛ né mpú bwɔ́.
\p 
\v 14 Ɛwyagé Jisɔs ama agɛ́ ji né mmu ɛcha upɛ Ɛsɔwɔ, ajɔɔ́ ne ji aké, “Gɛ́, nana ɔtoó, ɔpyɛgé sé gabo, ɛ́kágé mechɔ́ kpáa ɛshúlí wɔ mmyɛ.”
\v 15 Ne mende yimbɔ ajyɛ garé yɛ́ ákpakpa bɔɔ́ Jus bimbɔ nnó ɛlé Jisɔs ne abɔ́ apyɛɛ́ ji atoó.
\p 
\v 16 Ɛfɛɛ́ mbɔ ne ákpakpa bɔɔ́ Jus álɔɔ́ manchyɛgé Jisɔs ɛfwyale gétúgé ji apyɛɛ́ muú atoó né bií uwyaá.
\v 17 Jisɔs ajɔɔ́ ne ɛbwɔ́ aké, “Ntɛ wa apyɛ utɔɔ́ yɛ́ndégébé, mentó mbɔ mampyɛge utɔɔ́.”
\p 
\v 18 Ajɔɔ́gé mbɔ, matɔɔ́ ásɔ́ ákpakpa bɔɔ́ Jus kpaá, ányɛ́meno nnó ábɔ́ manwá ji. Néndé ji akwé fɔ́ ɛbɛ́ bií uwyaá ɛwú ɛwú wɔ́, amɛɛ́ ntó mmyɛ ne Ɛsɔwɔ gétúgé ajɔɔ́ nnó Ɛsɔwɔ alú ntɛ wuú.
\s1 Jisɔs awya utó manchyɛɛ́ geŋwá ne mansɔ́ mpa
\p 
\v 19 Jisɔs ajɔɔ́ ne ɛbwɔ́ aké, “Me ngaré ɛnyú wáwálé nnó me Maá ntɛ́négé fɔ́ ushu ushu ba mampyɛ genó, ɛkosé unó bi me ngɛ́ne Ntɛ wa apyɛ́ɛ ne me ntó mpyɛ néndé yɛ́ndégenó ɛyigé Ntɛ apyɛ, geji ntó ne Maá apyɛɛ́.
\v 20 Ɛlé Ntɛ agboó ne me Maá alɛ́rege me unó uko ɛbi jimbɔɔ́ apyɛɛ́. Ne amágé lɛ́re nyɛ me ukpɛ́kpɛ́ unó bi upwɔɔ́ bina. Ne ɛnyú délaá nyɛ mano mekpo fuú.
\v 21 Ne wyɛ ndɛre Ntɛ apyɛ bɔɔ́ abi ágboó ákwilege ne negbo, achyɛ ɛbwɔ́ geŋwá, mbɔntó ne Maá achyɛgé geŋwá mbaá yɛ́ndémuú ayi ji Ntɛ akɛ́lege.
\v 22 Ne yɛ́ muú ayi Ntɛ wa asɔ́ɔ mpa wuú apɔ́. Yɛ́mbɔ achyɛ me Maá wuú utó nnó nsɔ́gé mpa bɔɔ́ akó.
\v 23 Nnó bɔɔ́ ako ánógé Maá wyɛ ndɛre ánógé Ntɛ. Muú ayi álá anógé Maá wɔ́, ɛbyɛnnó ánógé fɔ́ ntó Ntɛ muú atɔmé ji.
\p 
\v 24 “Ne me ngarége ɛnyú wáwálé nnó yɛ́ndémuú yi awuú mekomejɔɔ́ wa ayina, ne áfyɛɛ́ metɔɔ́ ne muú ayi atɔmé me, awya geŋwá ɛyi gélágé byɛ́. Muú yimbɔ ntó akpɛ́né fɔ́ unɔɔ́ mpa, atané mɛ né meti negbo akpɛ né meti geŋwá.
\v 25 Ngarége ɛnyú wáwálé nnó gébé géchwɔɔ́, ne géchwɔ́ mɛ́ ɛyigé bɔɔ́ abi álú ne meti negboó awuú nyɛ meko Maá Ɛsɔwɔ. Ne bɔɔ́ abi awuú ne áfyɛɛ́ metɔɔ́ ne ji, ákerege nyɛ́ né meti geŋwá.
\v 26 Ndɛre Ntɛ wa jimbɔ alú menchyɛɛ́ geŋwá mbɔntó ne ji apyɛ me Maá wuú nnó mbɛ́ menchyɛɛ́ geŋwá.
\v 27 Ne achyɛɛ́ mɛ Maá wuú uto mansɔ́ mpa akwaá, néndé melú Maá Ntɛ Mekwaá.
\p 
\v 28 “Ɛ́kágé délá mano mekpo fuú gétúgé mechɔ́ ɛwé. Gébé géchwɔ́ɔ ɛyigé áwuú bɔɔ́ abi álú né mmu manome áwúu nyɛ mekomejɔɔ́ Maá Ntɛ Mekwaá
\v 29 Áwúgé átánege nyɛ mmu manome. Abi ápyɛɛ́ unó bi Ɛsɔwɔ ákɛ́lege, ákwilége nyɛ ákpɛ né geŋwá ɛyi gélágé byɛɛ́. Ne abi ápyɛɛ́ gabo ákwilége nyɛ ákpɛ né unɔɔ́ mpa.
\v 30 Nkágé tɛ́ne fɔ́ ushu ushu ba mpyɛ genó. Nkane Ntɛ wa agárege me mbɔntó ne nsɔ́ɔ mpa. Ne gefɔɔ́ ɛyigé me nsɔ́ɔ mpa gelú cho, néndé nkɛlege lé mampyɛ genó ɛyigé muú ayi atɔmé me akɛ́lege nnó mpyɛ, ɛpɔ́fɔ́ ndɛre me nkɛ́lege mampyɛ.
\s1 Bɔ ntɛse Jisɔs
\p 
\v 31 “Mbɔgé me mbɔɔ́ nke ngarege bɔɔ́ depɔ ɛtiré détome ne uto ba ɛbyɛ́nnó unó bi me ngarege mbɔ úlú detú.
\v 32 Muú fɔ ntó alú ayi alú ntɛ́sɛ́ wa, ne nkaá nnó unó bi ji agarege átóme ne me, úlú wáwálé.
\v 33 Ɛnyú detɔ́ nyá bɔɔ́ dentɔɔ́ mbaá Jɔn menwyaá bɔɔ́ manaá Ɛsɔwɔ, ne ji agaré ɛnyú wáwálé gefɔgé muú ayi me nlú.
\v 34 Me nkɛlege fɔ́ nnó bɔɔ́ ákaá gefɔgé muú ayi me nlu. Me njɔ́gé mbɔ ntome ne Jɔn, nkɛlege ɛlé nnó ɛnyú dewu nnó ɛ́kágé dekwe mpa Ɛsɔwɔ.
\v 35 Ji Jɔn abɔ́ alú ɛké ɛtulekaŋ ɛwé ɛ́lúlí ɛ́gɛ́nege. Ne mboó gébé fɔ́ ɛnyú debɔ désɛ́ geŋgbɔ́ jií ne nechɔ́chɔ́.
\v 36 Me nwya unó bi úlɛ́rege gefɔgé muú ayi me nlú, ɛbi uŋea upwɔ ɛbi Jɔn ágaré. Ɛlé wyɛ utɔɔ́ ubi, ɛbi Ntɛ wa afyɛɛ́ me né amu nnó nnéré, ubi ne mpyɛ́ɛ. Ne ubi ne úlɛ́rege nnó Ntɛ wa ne atɔmé me.
\v 37 Ne Ntɛ wa muú atɔmé me, agaré ntó gefɔgé muú ayi me nlú. Ɛnyú délú danwú meko wuú, ne yɛ gefɔgé muú ayi ji alú délú daŋgɛ́.
\v 38 Ne ɛnyú debelé fɔ́ mekomejɔɔ́ wuú né matɔɔ́ nyú wɔ́, néndé genó ɛyi gelɛrege mbɔ ɛlé metɔɔ́ ɛwé ɛnyú dela défyɛɛ́ fɔ ne muú ayi ji atɔmé wɔ́.
\v 39 Ɛnyú dechɛrege uno ɛbi ásame né muu ŋwɛ Ɛsɔwɔ ayi défɛré nnó ji ne apyɛ́ɛ ɛnyú débɔ́ geŋwá ɛyi gélágé byɛ́ ne mekomejɔɔ́ yimbɔ ajɔɔ́gé atome ɛlé ne me.
\v 40 Yɛ́mbɔ ɛnyú dékɛ́légé fɔ́ manchwɔ́ ɛta wa nnó débɔ́ geŋwá ɛyi gélágé byɛ́.
\p 
\v 41 “Me nkɛ́légé fɔ́ nnó ákwaá áfɛɛ́ me.
\v 42 Yɛ́mbɔ ndɛre me nkaá ɛnyú, ɛnyú débɔɔ́ fɔ́ gejeé ne Ɛsɔwɔ wɔ́.
\v 43 Me nchwɔ́ né mabɔ Ntɛ wa, ɛnyú déshya mansɛ me. Yɛ́mbɔ muú yi chá achwɔ́ge né mabɔ amií jimbɔɔ́, ɛnyú désɛlé nyɛ ji.
\v 44 Ɛnyú dékɛ́lege nnó atɛ bɔɔ́ ne áfɛge ɛnyú dékɛ́lege fɔ́ nnó muú yi ji mbií ne alú Ɛsɔwɔ, afɛɛ́ ɛnyú. Ɛpyɛmbɔ nnó ne ɛnyú défyɛɛ́ matɔɔ́ ne me.
\p 
\v 45 “Yɛ́mbɔ défɛrégé fɔ́ nnó me ne nkúu nyɛ ɛnyú mpa né mbɛ ushu Ntɛ wa, ɛlé Mosis ayi ɛnyú dénɛré matɔɔ́ ne ji ne akuú nyɛ ɛnyú mpa.
\v 46 Mbɔgé ɛnyú débɔ́ défyɛɛ́ matɔɔ́ ne Mosis wáwálé, mbɔ́ défyɛɛ́ ntó matɔɔ́ ne me, néndé unó bi ji asamé, útoó ne me.
\v 47 Tɛɛ́ ndɛre ɛnyú délá kamé nnó unó bi Mosis asamé úlú wáwálé wɔ́, ɛpyɛmbɔ nnó ne dekame nnó ɛbi me njɔ́gé úlú wáwálé?”
\c 6
\s1 Jisɔs achyɛɛ́ dɛlé bɔɔ́ áta menyɛɛ́
\r (Mat 14:13-21; Mak 6:30-44; Luk 9:10-17)
\p 
\v 1 Ɛ́bɛ́légé, Jisɔs achyaá géntoógé mewaá Galilií ɛyigé ákuú ntó nnó géntoógé Tibɛras.
\v 2 Ne gejamégé bɔɔ́ ákwɔ́lege ji gétúgé ágɛné gepɔgé ufélekpá ɛbi ji apyɛɛ́ bɔɔ́ mameé átoó.
\v 3 Jisɔs ne baá utɔɔ́ bií ákwɔ́ ájyɛ jwɔ́le né mfaá mekwɛ.
\v 4 Gébé ɛyigémbɔ, ɛpaá bɔɔ́ Jus ɛwé ákuú nnó ɛpaá koó upú, ɛ́la kwɔ́kwɔ́lé.
\p 
\v 5 Ne Jisɔs ábwɛ́gé amɛ agɛ́ ndɛre gejamégé bɔɔ́ áchwɔɔ́ ɛta wuú, ajɔɔ́ ne Filip aké, “Déname mbɔ brɛd ɛfɔ́ ayi akwánege bɔɔ́ bina manyɛ́?”
\v 6 Agií mbɔ manwú meko yi Filip ashúge nyɛ, néndé jimbɔɔ́ akaá mɛ́ genó ɛyigé ji abɔɔ́ mampyɛ.
\p 
\v 7 Filip ashuú ji meko aké, “Yɛ́ dékpá ɛlé ŋká ɛyi muú utɔɔ́ anyɛɛ́ né ámfaá aneé ne déna brɛd dékáré ukɛ́kɛ́ ukɛ́kɛ́ mbaá bɔɔ́ bina, akwánégé fɔ́ ɛbwɔ́ ako.”
\p 
\v 8 Ne maá utɔɔ́ Jisɔs ayifɔ ayi akúu ji nnó Andru meŋmo Simun Pita, aké,
\v 9 “Njyɛ gesa fɔ, alú fana ayi awyaá ntó brɛd ɛta ɛyi ápyɛ ne bɛle ne meshuú ɛpea, yɛ́mbɔ ɛkwánege mbɔ bɔɔ́ bina nnó?”
\p 
\v 10 Ajɔɔ́gé mbɔ, Jisɔs aké, “Gáré yɛ́ndémuú ájwɔ́lé ka.” Melú ɛwémbɔ ɛjá dambyanja dɔɔ́, bɔɔ́ abi ájwɔlé wyɛ ande ɛbwɔ́ ɛbwɔ́ álú genógé dɛlé bɔɔ́ átáa.
\v 11 Ne Jisɔs asɛ́ ntóo brɛd ɛyímbɔ, achyɛ́ matamé mbaá Ɛsɔwɔ, akaré mbaá bɔɔ́ abi ajwɔlé ɛfɛɛ́. Wyɛmbɔ ntó ne apyɛ ne meshuú ɛyimbɔ ɛ́peá ne yɛ́ndémuú asɛ ndɛre ji akɛlege.
\v 12 Ányɛ́gé agbégé, Jisɔs agaré baá utɔɔ́ bií aké, “Nywerege ayi álaá ɛkágé délyaá yɛɛ́ genógefɔ́”
\v 13 Ne ányweré ayi álaá ágbeé usá úfyáneupeá yɛ́ ɛlé ntó brɛd ɛbɔ ɛlú ɛlé ɛta.
\p 
\v 14 Ne bɔɔ́ bina ágɛ́gé gepɔge ufélekpá bina, ɛbí Jisɔs apyɛ́mbɔ, áké, “Gɛ́ muú ɛkpávé Ɛsɔwɔ wáwálé na, ayi alú manchwɔ́ fa mme.”
\v 15 Jisɔs ákágé nnó bɔɔ́ bimbɔ ákɛ́lege mangbaré ji ne utó ápyɛ ji ábɛ́ mfwa, alyaá ɛbwɔ́ ama akwɔ́ afɛ́ tɛ mfaá mekwɛ jimbií.
\s1 Jisɔs akɛ mfaá mekɔ manaá
\r (Mat 14:22-23; Mak 6:45-52)
\p 
\v 16 Nkwalé akwɔ́négé baá utɔɔ́ Jisɔs áshulé áfɛ́ né mbale géntoógé mewaá ɛyigémbɔ,
\v 17 ákpɛ ɛ́kpe manchyaá ájyɛ́ né melɔ Kapanɔm. Gébé ɛyigémbɔ utuú ugi, ne Jisɔs abɔ́ alú danchwɔ́ báne ɛbwɔ́.
\v 18 Ndɛre ajyɛ́ɛ mbyo metometo ammyɛ apyɛ mgbannyi akwɔme.
\v 19 Ɛbwɔ́ ájyɛ́gé genógé ŋkpa nekɛ ɛni, áké ágɛ́ne nkane Jisɔs akɛ́ne mfaá mekɔ manaá achwɔ́ɔ kwɔ́kwɔ́lé ne ɛkpée, ábɔ́ ɛfɔ.
\v 20 Ne Jisɔs ajɔɔ́ ne ɛbwɔ́ aké, “Défɔgé, ɛlé me.”
\v 21 Ajɔ́ɔgé mbɔ matɔɔ́ ágɔ ɛbwɔ́ mansɛ ji akpɛ né mmu ɛkpée, áké ápɛ́le ɛ́kpe ɛtaré mɛ́ mbale mewaá né mbaá ayi ɛbwɔ́ ájyɛ́ɛ.
\s1 Jisɔs alú ɛké brɛd ayi achyɛge geŋwá
\p 
\v 22 Bií ujyage, gejamégé bɔɔ́ abɔ alu né ɛgbɛ́ géntoógé mewaá ɛwefɔ, ágɛ́ nnó ɛlé ɛ́kpe ɛma ne ɛbɔ́ ɛlú né mbale nnyi. Ápɛ ágɛ sé Jisɔs wɔ́, ne ate nnó ji abɔ́ akpɛɛ́ fɔ́ ɛ́kpe ɛwémbɔ ne baá utɔɔ́ bií wɔ́, baá utɔɔ́ bií ábɔ́ áfɛ́ ɛbwɔ́ ambií.
\v 23 Wyɛ né bií bimbɔ, makpe fɔ́ átané né melɔ Tibɛras achwɔ́ táré né mapea gentoge mewaa kwɔ́kwɔ́lé ne mbaá ayi Ata Jisɔs abɔ́ ajelé brɛd bɔɔ́ anyɛ́ɛ.
\v 24 Ápɛ́ Jisɔs ne baá utɔɔ́ bií né makpe yimbɔ ágɛ́ wɔ́. Akpɛ makpe yimbɔ áchyaá géntoógé mewaá ɛyigémbɔ áfɛ́ né melɔ Kapanɔm ákɛ́lege Jisɔs.
\p 
\v 25 Agɛ́gé ji, ágií ji aké, “Ménlɛré ndé gébé wɔ ɔchyaá géntoógé mewaá ɔchwɔɔ́ wé?”
\p 
\v 26 Jisɔs ashuú ɛbwɔ́ meko aké, “Me ngarégé ɛnyú wáwálé nnó dékɛ́légé fɔ́ me gétúge gepɔge ufélekpá ɛbi ɛnyú dégɛné. Dékɛ́lege ɛlé me gétúgé dényɛɛ́ brɛd dégbeé.
\v 27 Détulégé fɔ́ mmyɛ dékɛ́légé menyɛɛ́ ayi áchɔ́ge, mmyɛ́ge mmyɛ dékɛ́légé ɛlé menyɛɛ́ ayi achyɛgé geŋwá ɛyi gélágé byɛ́. Ji yimbɔ ne me Maá Ntɛ Mekwaá nchyɛgé nyɛ ɛnyú. Ntɛ wa Ɛsɔwɔ apyɛ ukpɛkpɛ uno fɔ ne alɛ́rege nnó ji achyɛɛ́ me utó bií, nnó nchyɛge bɔɔ́ geŋwá ɛyigembɔ.”
\p 
\v 28 Ne bɔɔ́ bimbɔ ágií ji áké, “Ɛsé dépyɛɛ́mbɔ nnó ne dépyɛ́ɛ utɔɔ́ Ɛsɔwɔ?”
\p 
\v 29 Jisɔs ashuú ɛbwɔ́ meko aké, “Utɔɔ Ɛsɔwɔ bimbɔ úlú nnó ɛnyú défyɛɛ́ metɔɔ́ ne muú ayi ji atɔmé.”
\v 30 Bɔɔ́ bimbɔ ama agií ji áké, “Ndé ufélekpá ɛbi wɔ ɔmáge pyɛ nnó ɛsé dégɛ́ ne dékámé ne genó ɛyigé wɔ ɔjɔɔ́ge?
\v 31 Ukwéne antɛ sé anyɛ́ nyá mana né mashwɔ́ne, wyɛ ndɛre asamé né mmu bɔ ŋwɛ Ɛsɔwɔ nnó, ‘Achyɛɛ́ ɛbwɔ́ brɛd ayi atané né mfaánebuú ányɛ́’.”
\p 
\v 32 Ne Jisɔs aké ne ɛbwɔ́, “Me ngarége ɛnyú wáwálé nnó ɛpɔ́fɔ́ Mosis ne achyɛɛ́ ɛnyú brɛd ayi átané mfaánebuú, ɛlé Ntɛ wa ne achyɛ́ge ushuú brɛd ayi mbɔɔ́ ayi atané né mfaánebuú.
\v 33 Brɛd ayi Ɛsɔwɔ achyɛge ɛlé muú ayi atané mfaánebuú ne achyɛgé bɔɔ́ geŋwá ɛyi gélá gébyɛɛ́.”
\p 
\v 34 Jisɔs ajɔɔ́ge mbɔ, bɔɔ́ bimbɔ áké, “Ata chyɛ́gé ɛsé brɛd yimbɔ yɛ́ndégébé.”
\p 
\v 35 Ne Jisɔs agaré yɛ́ ɛbwɔ́ aké, “Me ne nlú brɛd ayi achyɛ́ge geŋwá. Yɛ́ndémuú ayi achwɔ́ɔ ɛta wa mesa ammyɛ sé ji, ne muu ayi áfyɛɛ́ metɔɔ́ ne me mmwɔ́lé manaá nto ɛpyɛ sé ji.
\v 36 Ne ngare mɛ́ ɛnyú nnó ɛnyú dégɛ́ me yɛ́mbɔ défyɛɛ́ matɔɔ́ ne me wɔ́.
\v 37 Yɛ́ndémuú ayi Ntɛ wa achyɛ́ge me, achwɔ́ɔ nyɛ ɛta wa, ne yɛ́ndémuú ayi achwɔ́ɔ ɛta wa, me mbuú fɔ́ ji.
\v 38 Néndé me ntané fɔ́ mfaánebuú manchwɔ́ pyɛ ndɛre nkɛ́lege wɔ́, nchwɔ́lé mampyɛ ndɛre muú ayi atɔmé me akɛ́lege.
\v 39 Ne genó ɛyigé muú ayi atɔmé me akɛ́lege nnó, mpyɛ gélú nnó ɛkágé mpyɛ yɛɛ́ muú ama anó né geluágé bɔɔ́ ako abi ji achyɛɛ́ me. Mpyɛ ɛlé ɛbwɔ́ akwilé né negbo né bií bi kwyakwya.
\v 40 Néndé genó ɛyigé Ntɛ wa akɛ́lege gélú nnó, yɛ́ndémuú ayi agɛ́né me Maá wuú ne áfyɛɛ́ metɔɔ́ ne me, abɔ́ geŋwá ɛyi gélágé byɛ́. Ne me mpyɛ nyɛ ji akwilé né negbo né bií ɛbi kwyakwya.”
\p 
\v 41 Jisɔs ajɔɔ́gé mbɔ, bɔɔ́ bimbɔ álɔ maŋménégé gétúgé ji ajɔɔ́ aké, ‘Me nlú brɛd ayi atané mfaánebuú ashulé mme’.
\v 42 Áké pɔ́ nnó Jisɔs maá Josɛf na? Ɛsé dékage mma wuú ne ntɛ wuú. Ɛpyɛmbɔ nnó ne ji aké atané mfaánebuú ashulé mme?
\p 
\v 43 Ne Jisɔs ashuú yɛ́ ɛbwɔ́ meko aké, “Gɔ́gé maŋménégé ne atɛ,
\v 44 yɛɛ́ muú ayi ákágé chwɔ́ ɛta wa ayi ntɛ wa muú atɔmé me álá aja ji áchwɔ wɔ́ apɔ́. Ne ayi achwɔ́ɔ ɛta wa, mpyɛ nyɛ ji akwilé né negbo né bií bi kwyakwya.
\v 45 Muú ɛkpávé Ɛsɔwɔ fɔ abɔ́ asá nnó, ‘Ɛsɔwɔ alɛ́rege nyɛ bɔɔ́ ako meti.’ Ɛwena ɛtɛne nno yɛ́ndémuú ayi awuú ne agií genó ɛyigé Ntɛ wa akɛ́lege, achwɔ́ɔ ɛta wa.
\v 46 Menjɔɔ́ mbɔ, ɛpɔ́fɔ́ nnó muú fɔ agɛ́ mɛ́ Ntɛ wa wɔ́, ɛkosé me muú ntané ɛta wuú ne ngɛ́ne ji.
\v 47 Ngaré ɛnyú wáwálé nnó yɛ́ndémuú ayi áfyɛɛ́ metɔɔ́ ne me abɔɔ́ geŋwá ɛyi gélá gébyɛɛ́.
\v 48 Me nlú brɛd ayi achyɛge geŋwá.
\v 49 Ukwéne antɛ nyú anyɛ́ nya mana né mashwɔ́ne, yɛ́mbɔ ágbó.
\v 50 Ne gɛ́ brɛd ayi atané mfaánebuú ashulé mme, ji ne alu gefɔɔ́ ɛyigé yɛ́ndémuú ayi anyɛ́ ji agboó fɔ́.
\v 51 Me nlú brɛd ayi achyɛgé geŋwá, ayi atané mfaánebuú ashulé mme. Yɛ́ndémuú ayi ányɛɛ́ brɛd yina abɛɛ́ ne geŋwá ɛyi gélágé byɛ́. Ne brɛd yina ɛlé menyammyɛ wa ayi nchyɛ́ge nyɛ mbaá bɔɔ́ mme mekó manwene geŋwáge bwɔ́.”
\p 
\v 52 Jisɔs ajɔɔ́gé mbɔ, bɔɔ́ Jus álɔ́ manyɛ́ mbeé metometo ne atɛ áké, “Mende yina achyɛge mbɔ ɛsé menyammyɛ wuú nnó dényɛ nnó?”
\p 
\v 53 Jisɔs ajɔɔ́ yɛ́ ne ɛbwɔ́ aké, “Ngarége ɛnyú wáwálé nnó, mbɔgé ɛnyú délá dényɛɛ́ menyammyɛ Maá Ntɛ Mekwaá ne dényúu manoó mií wɔ́, débɔ́ fɔ́ geŋwá.
\v 54 Ne yɛ́ndémuú ayi anyɛ́ɛ menyammyɛ wa ne anyúu manoó ma, abɔɔ́ geŋwá ɛyi gélágé byɛ́, ne mpyɛ nyɛ ji akwilé né negbo né bií bi kwyakwya.
\v 55 Néndé menyammyɛ wa alú menyɛɛ́ wáwálé ne manoó ma ntó málú genó ɛyigé ányú wáwálé.
\v 56 Yɛ́ndémuú ayi anyɛ́ɛ menyammyɛ wa ne anyú manoó ma, abɛɛ́ muú ama ne me, ne me ntó mbɛɛ muu ama ne ji.
\v 57 Ntɛ wa menchyɛ geŋwá atɔ́ me, Me ntó nwyaá geŋwá gétú jií. Mbɔntó ne yɛ́ndémuú ayi anyɛ́ɛ menyammyɛ wa abɔɔ́ geŋwá gétú ya.
\v 58 Gɛ́ brɛd ayi atané mfaánebuú ashulé mme na. Apɔ́fɔ́ ɛké mana ayi ukwéne antɛ nyú ányɛ́ nyá ne ábɛlégé ágboó. Yɛ́ndémuú ayi ányɛ́ɛ brɛd yina abɛɛ́ mebɛ tɛ kwyakwya.”
\v 59 Jisɔs ajɔɔ́ depɔ ɛtiré na né Kapanɔm, gébégé alɛ́rege bɔɔ́ unó né mmu ɛcha mmyɛmenɛne.
\s1 Gejamégé aŋkwɔlé Jisɔs ályaá jií
\p 
\v 60 Gejamégé aŋkwɔlé Jisɔs áwúgé genó ɛyigé ji alɛ́régé áké, “Genó ɛyigé mende yi alɛ́rege getoó. Yɛɛ́ muú ayi akámege gefɔgé genó ɛyigé na apɔ́.”
\p 
\v 61 Yɛ́mbɔ Jisɔs akágé né mmu metɔɔ́ wuú nnó aŋkwɔle bií áŋmɛ́nége gétúgé mechɔ́ ɛwé ji ajɔɔ́. Aké, ne bwɔ, “nnó mechɔ ɛwéna ɛpyɛ nnó ɛnyú deja mmyɛ meso?
\v 62 Ɛ́bɛgé mbɔ, ɛnyú defɛrege nyɛ nnó mbɔgé dégɛ́gé Me Maá Ntɛ Mekwaá ndɛre nkérége meso mbaá ayi ntané yɛ́?
\p 
\v 63 Ɛ́lé Mendoó ne ɛ́chyɛ́ge geŋwá. Menyammyɛ mekwaá apyɛ yɛ genó cháchá! Unó bi Me njɔɔ́ mbɔ ne ɛnyú, utané mbaá Mendoó ne ubi ne uchyɛge geŋwá ɛyi gélágé byɛ́.
\v 64 Yɛ́mbɔ, ɛnyú abifɔ défyɛɛ́ matɔɔ́ ne me wɔ́.” (Jisɔs akaá mɛ́ tɛ ula ulɔ́ bɔɔ́ abi álá fyɛ matɔɔ́ ne ji wɔ́, ne muú ayi achyɛge nyɛ ji maŋkwaá)
\v 65 Ne ajɔɔ́ ne ɛbwɔ́ aké, “Gɛ́ ula bí ngaré ɛnyú nnó, muú akágé chwɔ́ fɔ ɛta wa, mbɔgé Ntɛ wa álá lɛré ji meti wɔ́.”
\p 
\v 66 Ɛlɔ né gébé ɛyigé na, gejamégé aŋkwɔlé bií ája mmyɛ meso, ámágé kwɔ́le sé ji.
\p 
\v 67 Ne ɛpyɛ́gémbɔ, Jisɔs aké ne áŋbá bií áfyáneapeá, “Nnó ɛnyú ntó dékɛ́légé manlyaá me?”
\p 
\v 68 Simun Pita ashuú ji meko aké, “Ata, ɛsé demágé lya wɔ défɛ́ ɛfɔ? ɛle wɔ ne uwyaá mekomejɔɔ́ ayi achyɛ́ge geŋwá ɛyi gélágé byɛɛ́.
\v 69 Ɛsé défyɛɛ́ matɔɔ́ ne wɔ ne dékaá nnó wɔ ne ɔlu Muú Ukpea ayi Ɛsɔwɔ átɔmé.”
\p 
\v 70 Jisɔs ashuú ɛbwɔ́ meko aké, “Me ne njyá ɛnyú áfyáneapeá, yɛ́mbɔ muú nyú ama alú danchɔmeló.”
\v 71 Jisɔs ajɔɔ́ mbɔ ato lé ne Judas maá Simun Iscarot, yɛ́lé alú né geluágé abi áfyáneapeá, ji ne achyɛge nyɛ Jisɔs maŋkwaá.
\c 7
\s1 Jisɔs ne aŋmo bií
\p 
\v 1 Jisɔs ánérégé manlɛ́ré unó bi, alɔ́ mankɛ́né né gebagé mewaá Galilií, ákɛ́légé fɔ́ manjyɛ né gebagé mewaá Judiya gétúgé ákpakpa bɔɔ́ Jus ákɛ́lege manwá ji.
\v 2 Gébé ɛyigémbɔ ɛpaá bɔɔ́ Jus ɛwé ákuú nnó ɛpaá baá otó ɛlá kwɔ́kwɔ́lé. \f + \fr 7:2 \ft Ɛlú wáwálé nnó: Ɛpaá baá otó ɛlé ɛpaá ɛwé bɔɔ́ Jus atɛ́nege baá otó né mbaá ayi alú bɔmbɔ, manjwɔlé wyɛ átámége Ɛsɔwɔ né galɔ́gálɔ́ ayi álɛ́re ɛbwɔ́ né mashwɔne.\f*
\v 3 Ne aŋmo Jisɔs abi ande áké, “Lyaá fa ɔjyɛ né gebagé mewaá Judiya ɔpyɛ ufélekpá aŋkwɔlé byɛ ágɛ́.
\v 4 Néndé muú aké akɛ́lege nnó bɔɔ́ ákaá gefɔgé muú ayi ji alú, apyɛɛ́ fɔ́ utɔɔ́ bií bíbí. Tɛ́ ndɛre ɔkágé pyɛ ufélekpá ɛbi, ɛ́lɔme nnó ɔpyɛ ubi mbaá ayi bɔɔ́ ako ágɛ́ne.”
\v 5 Aŋmo bií ájɔɔ́ge mbɔ yɛ ɛbwɔ́ ntó áfyɛɛ́ fɔ́ matɔɔ́ ne Jisɔs wɔ́.
\p 
\v 6 Jisɔs ashuú ɛbwɔ́ meko aké, “Ɛya gébé gélu daŋkwɔ́ne, né ɛgbɛ́ ɛwé nyú dékágé jyɛ yɛ́ndégébé.
\v 7 Bɔɔ́ mme akage paá fɔ́ ɛnyú, ápaá ɛlé me, néndé me ngarege gabo ayi ɛbwɔ́ ápyɛ́ɛ gbɔ́gɔ́nɔ́.
\v 8 Ɛnyú chóge ɛpaá ɛwéná me njyɛɛ́ fɔ́ nana néndé gébé ya gélú daŋkwɔ́ne.”
\v 9 Ajɔɔ́gé mbɔ ama abɛ́le mboó ndɔ né Galilií.
\s1 Jisɔs afɛ́ ɛpaá baá otó
\p 
\v 10 Aŋmo Jisɔs ájyɛ́gé ji alá meso akwɔlé ɛbwɔ́ afɛ́ bíbí, ɛpɔ́fɔ́ gbɔ́gɔ́nɔ́.
\v 11 Ndɛre bɔɔ́ ányɛ́ɛ ɛpaá ɛwémbɔ, ákpakpa bɔɔ́ Jus álɔ mankɛlé Jisɔs, ágigé atɛ bɔɔ́ áké, “Mende yimbɔ alɛ́?”
\p 
\v 12 Bɔɔ́ abi áchwɔɔ́ ɛpaá ɛwémbɔ, áŋménege ákuú Jisɔs meno. Abifɔ áké, “Alú muú melɔ́mélɔ́,” abifɔ ntó áké, “Ŋgba” “achɔɔ́ bɔɔ́ makpo.”
\v 13 Yɛ́mbɔ yɛɛ́ muú ayi akuú Jisɔs meno gbɔ́gɔ́nɔ́ apɔ́ néndé áfɔ́ɔ ákpakpa bɔɔ́ Jus.
\p 
\v 14 Ányɛ́gé ɛpaá ɛkárégé mmyɛ, Jisɔs afɛ́ né mmu ɛcha upɛ Ɛsɔwɔ alɛ́rege meko mejɔɔ́ Ɛsɔwɔ.
\v 15 Ne ákpakpa bɔɔ́ Jus áwúgé ndɛre Jisɔs alɛ́rege, mano álá ɛbwɔ́ mekpo fuú ágígé atɛ áké, “Déŋgá ɛtire na détané mende yina ɛfɔ́, ayi yɛɛ́ ŋwɛ ji alá agi dɔɔ wɔ́?”
\p 
\v 16 Ájɔɔ́gé mbɔ, Jisɔs ashuú ɛbwɔ́ meko aké, “Unó bi me nlɛ́rege mbɔ utáné fɔ́ me né metɔɔ́ wɔ́ utané lé mbaá muú ayi atɔmé me.
\v 17 Muú ayi awyaá metɔɔ́ mampyɛ genó ɛyigé Ɛsɔwɔ akɛ́lege, ji ne akágé nyɛ mbaá yi unó bi me nlɛ́rege mbɔ utánege. Yɛɛ́ utanége lé mbaá Ɛsɔwɔ yɛɛ́ lé né metɔɔ́ wa, akáge nyɛ.
\v 18 Muú ayi ajɔɔ́ge unó bi utánege ji né metɔɔ́, akɛ́lege lé nnó ŋgɔ́ wuú akwɔ́. Yɛ́mbɔ muú ayi akɛ́lege nnó muú ayi atɔme ji akwɔ́ ŋgɔ́, ajɔge genó ɛyi gelu wáwálé, ábyɔ́gé fɔ́ gebyɔ́ cháchá.
\v 19 Mosis abɔ́ achyɛ́ ɛnyú mabɛ́, wá mbɔ fɔ́ wɔ́? Yɛ́mbɔ, yɛɛ́ muú nyú ama ayi abelé aji apɔ́. Ulannó ɛnyú demuame manwá me?”
\p 
\v 20 Jisɔs ajɔɔ́gé mbɔ, bɔɔ́ bimbɔ áshuú ji meko áké, “Melo nchyɛ achyɛgé wɔ ɛfwyale, ndé bɔɔ́ amuame manwá wɔ?”
\p 
\v 21 Ji ntó ashuú ɛbwɔ́ meko aké, “Me mpyɛ muú atoó bií uwyaá, ɛnyú délá mano mekpo fuú.
\v 22 Ɛle Mosis ne achyɛɛ́ ɛnyú ɛbɛ́ nnó desɔ́gé nsɔ́. Yɛ lé ɛla ɛlɔ fɔ́ ne ji wɔ́, ɛlɔ ne ukwéne antɛ nyu, ɛnyu desɔɔ baá nyu nsɔ né bií uwyaá.
\v 23 Ne mbɔgé bií ɛbi asɔ́ɔ maá nsɔ́ ukwegé bií uwyaá, ɛnyú desɔ́ɔ ji nsɔ́ nnó ɛkágé dékwé ɛbɛ́ Mosis, ulánnó ɛnyú désɔ́ɔ matɔɔ́ ne me gétúgé me mpyɛ menyammyɛ muú meko atoó né bií uwyaá?
\v 24 Muú apyɛgé genó ɛ́kágé débɔ́ mbɛ déjɔɔ́ nnó ji apyɛ gabo ndɛre bɔɔ́ ako ágɛne, ayi délá débɔ́ɔ mbɛ dékaá ulá wɔ́. Chɛrége dékaá né meti ɛwé ɛlú cho ne desɔ mpa wuu.”
\s1 Nde mmú alú Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa
\p 
\v 25 Ndɛre Jisɔs alɛ́rege bɔɔ́ Jɛrosalɛ, abifɔ álɔ mangigé atɛ áké, “Pɔ́ mende yi ákɛ́lege na ji manwá na?
\v 26 Pɛ ndɛre ji ajɔɔ́gé mejɔɔ́ né mbɛ ushu bɔɔ́ ako ne yɛɛ́ muú ayi apɛ́gé meko apɔ́, nnó ákpakpa sé ágɛ́ nnó ji ne alú Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa waá?
\v 27 Ndɔfɔ ji fɔ́ wɔ́ néndé Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa aké achwɔ́ɔ muú akágé fɔ mbaá ayi ji atánégé yɛ́mbɔ ɛsé dékaá mbaá yi mende yina atané.”
\p 
\v 28 Ndɛre Jisɔs alú lɛ́rege né mmu ɛcha upɛ Ɛsɔwɔ, abwɛɛ́ meko mfaá aké “Ɛlú wáwálé nnó ɛnyú dékaá me ne dékaá ntó mbaá yi me ntané yɛ́mbɔ me nchwɔ́ fɔ́ fa né utó ba wɔ́, nchwɔ́lé gétúgé muú ayi atɔmé me. Ɛlu wawale nno ji ne atɔmé me ne ɛnyú dékágé fɔ́ ji.
\v 29 Me nkágé ji néndé me ntané lé ɛta wuú. Ji ne atɔmé me nnó nchwɔ́.”
\p 
\v 30 Ajɔɔ́gé mbɔ, bɔɔ́ bimbɔ ákwilé nnó ápyɛ́ ji yɛ́mbɔ yɛɛ́ muú ayi ataá ji ɛbwɔ mmyɛ apɔ́, ɛlé gébé ɛjií gélá gelú daŋkwɔ́ne.
\v 31 Yɛ́mbɔ né geluáge bɔɔ́ bimbɔ gejame abi áfyɛɛ́ metɔɔ́ ne ji ájɔɔ́gé áké, “Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa achwɔ́gé nnó amáge pyɛ gepɔge ufelekpa upwɔɔ́ ɛbi mende yina apyɛ́ɛ?”
\p 
\v 32 Bɔɔ́ ɛkwɔ́ Farasi abi alú ɛfɛɛ́ áwúgé ndɛre bɔɔ́ aŋménege gétúgé Jisɔs, ácho ula ne anɔɔ́ baá ampyɛɛ́ upɛ Ɛsɔwɔ, átɔ́ ámbamé ɛcha upɛ Ɛsɔwɔ nnó ajyɛ apyɛ́ Jisɔs.
\v 33 Ne Jisɔs ajɔɔ aké, “Me mbɛlege sé ne ɛnyú dɔɔ́, ɛla gachyɛɛ́ me nkerege meso mbaá muú ayi atɔmé me.
\v 34 Ɛnyú dékɛ́lege nyɛ me, yɛ́mbɔ degɛ́ne fɔ́ me. Mbaá ayi me mbɛ́ɛ ɛnyú dékágé chwɔ́ fɔ́ wyɛ.”
\p 
\v 35 Ajɔɔ́gé mbɔ, ákpakpa bɔɔ́ Jus álɔ mangígé atɛ áké, “Ndé mbaá yi mende yina afɛré nnó ji ajyɛ, ayi yɛɛ́ dékɛ́lé ji délá dégɛ́né? Nnó ajyɛ jwɔ́le nyɛ ɛlé né gebagé mewaá Greek ne malɔ ayi bɔɔ́ sé ájwɔ́lege, alɛrege bɔɔ́ Grek mekomejɔɔ́ Ɛsɔwɔ?”
\v 36 Ajɔɔ́ mbɔ, aké, “Ɛnyú dékɛ́lege nyɛ me dégɛ́né, ne mbaá yi me mbɛ́ɛ, ɛnyú dékágé chwɔ́ fɔ́ wyɛ. Ula utɛne mbɔ nnó?”
\s1 Manaá ami machyɛge geŋwá
\p 
\v 37 Kwyakwya bií bi ányɛɛ́ ɛpaá ɛwémbɔ, úlú gekpɛkpɛge bií. Né bií bimbɔ Jisɔs akwilé ka ajɔɔ́ keŋke aké, “Yɛ́ndémuú ayi mmwɔ́lé manaá ɛpyɛɛ́ ji achwɔ́ anyú ɛta wa. \f + \fr 7:37 \ft Ɛlú wáwálé nnó: Gébégé ɛpaá ɛwéna ampyɛɛ́ upɛ Ɛsɔwɔ ájyɛɛ́ yɛ́ndé bií átuú manaá áchwɔɔ́ ne mami né ɛcha upɛ. Ndɛre ápyɛɛ́ mbɔ áteé nkane Ɛsɔwɔ áchyɛ́ nya bɔɔ́ bií manaá gébégé ɛbwɔ́ ákɛne né mashwɔne. Jisɔs ájɔgé nnó ji alu ɛké manaá mimbɔ mbaá bɔɔ́.\f*
\v 38 Muú afyɛgé metɔɔ́ ne me, genó ɛyi gepyɛ ne ji gebɛɛ́ wyɛ ndɛre ásamé né mmu ŋwɛ Ɛsɔwɔ nnó, ‘Genó ɛyi gétánege ji tɛ metɔɔ́ gebɛ́ɛ ɛké nnyi ɛniné néwya manaá ami machyɛgé geŋwá.’”
\v 39 Manaá ami machyɛgé geŋwá ami Jisɔs ajɔɔ́ mbɔ matɛné mbaá Mendoó Ukpea ɛwé bɔɔ́ abi áfyɛɛ́ matɔɔ́ ne Jisɔs ábɔɔ́ nyɛ. Né gébé ɛyigémbɔ, Ɛsɔwɔ abɔ́ alú danchyɛɛ́ ɛbwɔ́ Mendoó Ukpea, néndé Jisɔs abɔ́ alú dangbó akéré meso mfaánebuú mbaá ayi Ɛsɔwɔ achyɛgé ji ɛnógé.
\s1 Bɔɔ́ ájɔɔ́gé unó ucháuchá gétúgé Jisɔs
\p 
\v 40 Bɔɔ́ bimbɔ áwuúgé genó ɛyigé Jisɔs ajɔɔ́, abifɔ áké, “Ɛlú wáwálé nnó mende yina alú muú ɛkpavé Ɛsɔwɔ ayi débɔ́ dégilé.”
\p 
\v 41 Abifɔ áké, “Alú Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa.” Yɛ́mbɔ abifɔ aké, “Ɛpyɛmbɔ nnó ne Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa átanégé né Galilií.
\v 42 Pɔ́ ŋwɛ Ɛsɔwɔ aké na, Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa abɛɛ́ mpyáne mfwa Dɛvid ne ábyɛ́ne ji né Bɛtɛlɛhɛm, melɔ ɛwé mfwa Dɛvid atané wyɛ?”
\v 43 Ndɛre ɛlúmbɔ, bɔɔ́ abifɔ ájɔɔ́gé ágáme Jisɔs, abifɔ ágáme fɔ́.
\v 44 Bɔɔ́ abifɔ ábɔ́ álú mampyɛ́ ji, yɛ́mbɔ yɛ́ muú ayi ataá ji ɛbwɔ mmyɛ apɔ́.
\s1 Ákpakpa bɔɔ́ Jus áshya mamfyɛ́ metɔɔ́ ne Jisɔs
\p 
\v 45 Ambamé ɛcha upɛ Ɛsɔwɔ abi ábɔ́ átɔmé ɛbwɔ́ nnó ájyɛ apyɛ́ Jisɔs, ákeré meso amuamu mbaá anɔɔ́ baá ampyɛ upɛ Ɛsɔwɔ ne ɛkwɔ́ bɔɔ́ Farasi. Áchwɔ́gé ákpakpa bimbɔ ágií ɛbwɔ́ áké, “Ulannó ɛnyú délá chwɔ́ ne ji wɔ́?”
\p 
\v 46 Ambamé bimbɔ áshuú ɛbwɔ́ meko áké, “Ɛsé délú danwú muú fɔ ajɔɔ́ gefɔgé depɔ ɛtiré mende yimbɔ ajɔɔ́gé.”
\v 47 Ɛkwɔ́ bɔɔ́ Farasi áshuú ɛbwɔ́ meko áké, “Nnó abwɔlé ɛnyú ntó?”
\v 48 Ɛbwɔ́ ama gíi áké, “Nnó ɛnyú dékaá yɛɛ́ muú sé ama né geluágé ákpakpa, yɛ́ ɛbɛ́lé muú ɛkwɔ́ Farasi ayi áfyɛɛ́ metɔɔ́ ne ji?
\v 49 Ngba! Ɛkosé bɔɔ́ abi álá kaágé mabɛ sé ne áfyɛɛ́ metɔɔ́ ne ji. Ne ɛbwɔ bimbɔ alu bɔɔ́ abo né mbɛ ushu Ɛsɔwɔ.”
\p 
\v 50 Muú Farasi fɔ ayi ɛbwɔ́ ákuú ji Nikodɛmus muú yi abɔ́ ájyɛ mbaá Jisɔs, abɔɔ́ alu ntó né geluage bwɔ́. Agií ɛbwɔ́ aké,
\v 51 “Nnó ɛbɛ́ sé ɛgbarege muú nnó alú gyɛɛ́ ayi bɔɔ́ álá lu danwú mpa wuú akaá mechɔ ɛwe ji apyɛ?”
\p 
\v 52 Ákpakpa bimbɔ áshuú ji meko áké, “Ɛlú ɛké wɔ ntó ɔlu muú Galilií. Chó gií né mmu ŋwɛ Ɛsɔwɔ ne ɔkaá nnó muú ɛkpavé Ɛsɔwɔ atanégé fɔ né Galilií.” \f + \fr 7:52 \ft Ɛlú wáwálé nnó: Ukwene bɔ ŋwɛ abi mbɛmbɛ ápɔ́ ne malɔ́ ŋwɛ yina. Ɔlɔ né 7:53 ɔkwɔ́né né 8:11.\f*
\v 53 Ájɔɔ́gé mbɔ, yɛ́ndémuú atyaá akeré meso né gepú jií.
\c 8
\s1 Ápyɛ mendée ayi akwené ulɔ
\p 
\v 1 Jisɔs akwɔ́ afɛ ji né Mekwɛ Olif.
\v 2 Ne bií ujyágé ji ama kéré meso né dachi ɛcha upɛ Ɛsɔwɔ. Gejamégé bɔɔ́ áchwɔ́ anɔ ji mme ne ajwɔlé ka alɔ́ manlɛ́régé ɛbwɔ́.
\v 3 Ndɛre ji ajɔɔ́gé, anlɛ́ré mabɛ́ Ɛsɔwɔ ne ɛkwɔ́ bɔɔ́ Farasi áchwɔ́ ne mendée ayi akwené ulɔ. Áchoó ji né mbɛ ushuú bɔɔ́ ako abi álú ɛfɛɛ́.
\v 4 Áké ne Jisɔs, “Ménlɛré, ɛsé dépyɛ mendée yina nkane akwéne ulɔ.
\v 5 Ásá né mmu ŋwɛ mabɛ́ Mosis nnó ábɔ́ manwá gefɔgé mendée yina ne mataá. Ne wɔ ɔjɔɔ́ nnó?”
\v 6 Nkwɛ́ yi ɛbwɔ́ agií mbɔ ɛlé metaá né ɛbwɔ́ ápɛné nnó Jisɔs akwegé, ɛbwɔ́ ágɛ́ meti manjɔɔ́ nnó apyɛ gyɛɛ́.
\p Yɛ́mbɔ Jisɔs abyɛlé mme asamé genó gefɔ́ ne ɛnɔɔ́ ɛbwɔ wuú.
\v 7 Ndɛre ɛbwɔ́ álú ágigé wyɛ ji gigé, Jisɔs anyaá mmyɛ mfaá aké ne ɛbwɔ́, “Mbɔgé muú nyú fɔ alú dampyɛ gabo, abɔ́ mbɛ abɔ́ ntaá ató ji.”
\v 8 Ajɔɔ́gé mbɔ, ama byɛ́le mme asamé genó ne ɛnɔɔ́ ɛbwɔ wuú.
\p 
\v 9 Bɔɔ́ abi achwɔɔ́ ne mendée yimbɔ, áwuúgé nkane Jisɔs ajɔɔ́, alɔ manjyɛ ama ama. Bɔɔ́ kpakpa ne ábɔɔ́ mbɛ alɔɔ́ manjyɛ. Afɛ́ kpá ályá mendée yimbɔ tɛ́né né mbɛ ushuú Jisɔs.
\v 10 Jisɔs anyaá mmyɛ mfaá aké ne mendée yimbɔ, “Bɔɔ́ bimbɔ alɛ́? Nnó yɛɛ́ muú fɔ ajɔɔ́ nnó wɔ nkwe mpa wɔ́?”
\p 
\v 11 Mendée yimbɔ ashuú ji meko aké, “Ata yɛɛ́ muú ajɔɔ́ wɔ́.” Ajɔɔ́gé mbɔ, Jisɔs ajɔɔ́ yɛ́ aké, “Yɛ́ me ntó mpyɛɛ́ wɔ genó, chó, ɔpyɛgé sé gabo.”
\s1 Jisɔs alú geŋgbɔ́ mbaá bɔɔ́ mme
\p 
\v 12 Ɛwyágé Jisɔs ama jɔɔ́ ne ɛkwɔ bɔɔ bimbɔ aké, “Me nlú geŋbɔ́ mbaá bɔɔ́ mme, muú yi akwɔ́lege me, akɛ́né fɔ́ né gemua, agɛ́ne nyɛ lé geŋgbɔ́ ɛyi gechyɛge geŋwá.” \f + \fr 8:12 \ft Ɛlú wáwálé nnó: Jisɔs abɛɛ́ ne áŋkwɔle bií yɛ́ndégébé wyɛ nkane gekwage mewɛ gebɔ gelú ne bɔɔ́ Isrɛli gébégé átané né Ijipt. (Gɛ Ɛsɔ. 13:21)\f*
\p 
\v 13 Ne ɛkwɔ́ bɔɔ́ Farasi áké ne ji, “Gɛ́ yɛ́ nkane ɔtɛné ntɛ́sɛ́ né gemɛ jyɛ, ɛbyɛnnó depɔ ɛtiré wɔ ɔgárege mbɔ delu detu.”
\p 
\v 14 Jisɔs ashuú ɛbwɔ́ meko aké, “Yɛ́ me ntɛ́né lé ntɛ́sé né gemɛ ya, depɔ ɛtiré me ngarege mbɔ dépɔ́ fɔ́ detu, néndé me nkaáge mbaá ayi ntané ne mbaá ayi njyɛ́ɛ. Yɛ́mbɔ ɛnyú dékaágé fɔ mbaá ayi ntané, yɛ́ mbaá ayi njyɛɛ́ dékaágé.
\v 15 Ɛnyú dechɛrege depɔ ndɛre akwaá áchɛ́rege, me nchɛ́régé yɛɛ́ mechɔ́ muú fɔ.
\v 16 Ne yɛɛ́ ɛbɛ́lé nnó nchɛrégé, uchɛ́chɛ́re ba úlú cho néndé nchɛ́régé fɔ́ me mbií, Ntɛ wa muú atɔmé me alú ne me.
\v 17 Ásá né mmu mabɛ́ nyú nnó bɔ ntɛ́sé apeá ájɔɔ́gé genó gema, ɛbyɛ́nnó mechɔ́ ɛwémbɔ ɛpɔ fɔ detú.
\v 18 Me ntɛné ntɛ́sé né gemɛ ya, ne Ntɛ wa muú atɔmé me alú ntó ntɛ́sé wa.”
\p 
\v 19 Ajɔɔ́gé mbɔ, ɛbwɔ́ ágií yɛ́ ji aké, “Ntɛ wyɛ alú ɛfɔ́?” Jisɔs ashuú ɛbwɔ́ meko aké, “Ɛsé ne ntɛ wa yɛɛ́ muú ayi ɛnyú dékágé ápɔ́. Mbɔgé ɛnyú debɔ dékaá me, mbɔ dékaá ntó Ntɛ wa.”
\p 
\v 20 Jisɔs abɔ́ ajɔɔ́gé depɔ ɛtiré na gébégé ji álɛ́rege bɔɔ́ né dachi ɛcha upɛ Ɛsɔwɔ kwɔ́kwɔ́lé ne mbaá ayi ábélege makwa ayi áfyɛ́ɛ ŋka Ɛsɔwɔ wyɛ. Yɛ́mbɔ yɛɛ́ muú ayi apyɛné ji apɔ́ néndé gébé jií gélú dankwɔ́né.
\s1 Jisɔs akwelé mbeé mbaá bɔɔ́ abi álá kame fɔ́ nnó ji alu muú ayi Ɛsɔwɔ atɔme ji wɔ́
\p 
\v 21 Ɛwyágé Jisɔs ama jɔɔ́ ne ɛkwɔ́ bɔɔ́ bimbɔ aké, “Me njyɛ nyɛ mbaá fɔ, ɛnyú dékɛlégé nyɛ me dégɛ́né, ne dégbóo nyɛ né mmu gabo ɛnyú. Ne mbaá ayi me njyɛ́ɛ ɛnyú dékaágé chwɔ́ fɔ́ wyɛ.”
\p 
\v 22 Ákpakpa bɔɔ́ Jus áwuúgé mbɔ ágií atɛ áké, “Nnó ájyɛ wá nyɛ gemɛ jií waá? Mbɔgé mbɔ fɔ́ wɔ́, ula bi ji ajɔɔ́gé nnó ‘mbaá ayi ji ajyɛ nyɛ ɛsé dékaágé jyɛ́ɛ wyɛ utɛné nnó?’”
\p 
\v 23 Jisɔs ashuú ɛbwɔ́ meko aké, “Ɛnyú détané fa mme yina, me ntané mfaánebuú, ɛnyú délú bɔɔ́ mme, me mpɔ́ fɔ́ muú mme.
\v 24 Gɛ́ ula bi mbɔ́ njɔɔ́ ne ɛnyú nnó, dégbóo nyɛ né mmu gabo nyú. Ne mbɔgé ɛnyú délá kamé nnó, ‘Me Nlú Muu ayi Me Nké Nlú wɔ́, dégbóo nyɛ né mmu gabo nyú wáwálé.’”
\p 
\v 25 Ɛbwɔ́ ágií yɛɛ́ ji áké, “Wɔ ɔlú waá?” Jisɔs ashuú ɛbwɔ́ meko aké, “Me nlú muú yi mbɔ́ ngárege mɛ́ ɛnyú tɛ gachií nnó nlú.
\v 26 Nwya gejamégé unó bi njɔɔ́gé ulɛ́rege nnó ɛnyú dékwé mpa. Yɛ́mbɔ muú ayi atɔmé me ajɔɔ́gé wáwálé ne genó ɛyigé nwúgé ɛta wuú géji ne ngárege bɔɔ́ mme.”
\p 
\v 27 Ndɛre Jisɔs abɔ ajɔge mbɔ ɛbwɔ́ ábɔ́ akaá fɔ́ nnó ajɔɔ́gé mbɔ atome lé ne Ntɛ wuú wɔ́.
\v 28 Ne Jisɔs ajɔɔ́ yɛ́ ne ɛbwɔ́ aké, “Gébégé abwɛge nyɛ me Maá Ntɛ Mekwaá né mfaa, gébé ɛyigémbɔ ne dékáage nyɛ nnó, ‘Me Nlú Muú ayi Me Nké Nlú’ ne dékaáge nyɛ ntó nnó me njɔge fɔ́ genó gefɔ́ né ushu ushu ba, mpyɛ lé ɛyigé Ntɛ wa alɛré me nnó mpyɛ. \f + \fr 8:28 \ft Ɛlú wáwálé nnó: Jisɔs ajɔgembɔ, átome mbɔ ɛle ne gebe ɛyige áwɔme nyɛ ji né gekwa.\f*
\v 29 Ne ji muú atɔmé me alú ne me, alyaá fɔ́ me mbií wɔ́ néndé mpyɛ unó bi ujigé ji metɔɔ́.”
\p 
\v 30 Ne gejámé bɔɔ́ abi áwuú ndɛre Jisɔs ajɔɔ́gé unó bina ákamé nnó úlú wáwálé.
\s1 Bɔɔ́ abi álu baá Abraham wáwálé
\p 
\v 31 Jisɔs ajɔɔ́ ne bɔɔ́ Jus abi ákamé ne ji aké, “Dégbarégé amu né unó bi nlɛrege ɛnyú, débɛ aŋkwɔlé ba wáwálé.
\v 32 Ne dékáage nyɛ wáwálé ne wáwálé, yimbɔ apyɛ nyɛ ɛnyú dela mmyɛmmyɛ nyu.”
\p 
\v 33 Ɛbwɔ́ ashuú ji meko áké, “Ɛsé délú upyáne Abraham ne délú dambɛ́ afwɛ́ ɛta muú fɔ, ulannó wɔ ɔké ɛsé détanege nyɛ né ɛfwyale.”
\p 
\v 34 Jisɔs ashuú ɛbwɔ́ meko aké, “Me ngarege ɛnyú wáwálé nnó, yɛ́ndémuú ayi apyɛ́ɛ gabo, abwɔlé mefwɛ́ gabo.
\v 35 Ne mefwɛ́ alaá fɔ́ né ula gepú ɛyigé ji akpane défwɛ́ wyɛ tɛ kwyakwya ɛlé maá mbɔɔ́ gepú ne ala.
\v 36 Nkane ɛlúmbɔ, mbɔgé Maá apyɛge wɔ ɔlage mmyɛmmyɛ jyɛɛ, ɛbyɛ́nnó ɔla mmyɛmmyɛ jyɛ wawale.
\v 37 Me nkaá nnó ɛnyú délú upyáne Abraham. Yɛ́mbɔ dékɛlégé manwá me néndé ɛnyú debɔɔ́ fɔ gébé ne mekomejɔɔ́ wa chacha wɔ́.
\v 38 Me ngarege ɛnyú genó ɛyigé me ngɛné mbaá Ntɛ wa, ɛnyú dépyɛ́ɛ lé genó ɛyigé ntɛ nyú agaré ɛnyú.”
\p 
\v 39 Bɔɔ́ Jus bimbɔ ashuú ji meko áké, “Abraham alú gekwéne ntɛ sé.” Ájɔɔ́gé mbɔ Jisɔs aké ne ɛbwɔ́, “Mbɔgé ɛnyú débɔ́ débɛ́ upyáne Abraham wáwálé, mbɔ́ dépyɛ́ɛ unó bi ji abɔ́ apyɛɛ́.
\v 40 Yɛ́mbɔ ɛnyú dékɛlege manwá me ayi ngárege ɛnyú mekomejɔɔ́ ayi wáwálé, ayi nwuú ne Ɛsɔwɔ. Abraham abɔ́ apyɛɛ́ fɔ́ mbɔ wɔ́.
\v 41 Ɛnyú depyɛ́ɛ genó ɛyigé ntɛ nyú apyɛ́ɛ.”
\p Ɛbwɔ́ áké ne ji, “Ɛsé depɔ́ fɔ́ baá ulɔ, Ɛsɔwɔ ne alú Ntɛ sé wáwálé.”
\p 
\v 42 Ájɔɔ́gé mbɔ, Jisɔs aké ne ɛbwɔ́, “Mbɔgé Ɛsɔwɔ abɔ́ ábɛ́ Ntɛ nyú wáwálé, mbɔ́ dégbóo ne me néndé ntané ɛta wuú ne nchwɔ́ fa. Nchwɔɔ́ fɔ́ fa né ushu ushu ba wɔ́, ji ne atɔmé me.
\v 43 Ɛpyɛnnó ne ɛnyú delá kaágé genó ɛyigé me njɔɔ́gé? Ndɔfɔ ɛlé délá kɛ́légé manwú genó ɛyigé me njɔɔ́ge.
\v 44 Ntɛ nyú ɛlé danchomeló, ɛnyú dékɛlege lé mampyɛ́gé unó bi ujigé ji metɔɔ́. Tɛ ula ulɔɔ́ geŋwá jií, ji alú lé muú ayi awáne bɔɔ́, ne akií fɔ genó ɛyi gélú wáwálé, néndé jimbɔɔ́ ajɔɔ́gé fɔ́ wáwálé. Áke abyɔge gebyɔ akwɔlege lé gepɔ jií, néndé gebyɔ geko gelɔ ne ji.
\v 45 Ɛlé me ngarege genó ɛyi gélú wáwálé, ɛnyú dekámégé fɔ́ ne genó ɛyigé me njɔɔ́gé.
\v 46 Nnó muu nyu fɔ akage gare yɛ gabo ayi me mpyɛɛ? Ne mbɔgé me ngarege ɛnyú genó ɛyi gélu wáwálé, ulannó ɛnyu déla dékámégé ne me?
\v 47 Yɛ́ndémuú ayi alu muu Ɛsɔwɔ, awúu genó ɛyigé Ɛsɔwɔ ajɔɔ́gé. Ɛlú wáwálé nnó ɛnyú depɔ́ fɔ́ baá Ɛsɔwɔ, gɛ́ ula bi ɛnyú délá wuú fɔ́ me mbɔ.”
\s1 Jisɔs agarege gefɔgé muú ayi ji alú
\p 
\v 48 Ajɔɔ́gé mbɔ, ákpakpa bɔɔ́ Jus áshuú ji meko áké, “Ɛsé depɔ́ fɔ́ gyɛ manjɔɔ́ nnó wɔ ɔlu muú Samariya ne melo nchyɛ achyɛge wɔ ɛfwyale.”
\p 
\v 49 Ne Jisɔs ashuú ɛbwɔ́ meko aké, “Meló nchyɛ achyɛge fɔ́ me ɛfwyale. Me nnogé Ntɛ wa yɛ́mbɔ ɛnyú dénógé fɔ́ me.
\v 50 Me mpyɛɛ́ fɔ́ unó nnó bɔɔ́ áfɛɛ́gé me, yɛ́mbɔ muú alú wyɛ ayi afɛ́ge me. Ji ne alú muú ayi asɔ́ɔ mpa bɔɔ́.
\v 51 Ne me ngarege ɛnyú wáwálé nnó muú ayi ábélege mekomejɔɔ́ ayi me nlɛrege agboó fɔ́ chacha.”
\p 
\v 52 Ajɔɔ́gé mbɔ bɔɔ́ Jus áké, “Nana ɛsé dékaá nnó ɔmée gebwɔ́ wáwálé. Abraham agbó wyɛ ndɛre bɔɔ́ ɛkpávé Ɛsɔwɔ abifɔ agbóo, wɔ ɔké mbɔgé muú abelégé unó bi wɔ ɔlɛ́rege agboó fɔɔ́?
\v 53 Nnó wɔ ɔŋeá gemɛ ɔpwɔ ntɛsé Abraham ayi agbóo wa nnó? Bɔɔ́ ɛkpávé Ɛsɔwɔ ntó agbóo, wɔ ɔfɛré nnó ɔlú waá?”
\p 
\v 54 Ne Jisɔs ashuú ntó ɛbwɔ́ meko aké, “Mbɔgé me nfɛ́ɛgé gemɛ ɛyá, ufɛfɛ́ɛ ɛbimbɔ unó mme detú. Muú ayi afɛ́ɛge me ɛlé Ntɛ wa muú ɛnyú désɛlé nnó alú Ɛsɔwɔ nyú.
\v 55 Yɛ́ ɛlé ɛnyú délá dékaá yɛɛ́ ji kaŋka wɔ́. Me nkáge ji. Mbɔgé me njɔ́gé nnó nkaágé fɔ́ ji, ɛbyɛnnó me nlú muú gebyɔ nkane ɛnyú. Me nkaá ji wáwálé, ne nwúu ne ji.
\v 56 Ntɛ nyú Abraham abɔɔ́ mɛ́ mbɛ akaá nnó, me nchwɔ́ɔ nyɛ ne metɔɔ ɛgɔ ji. Agɛge mbɔ metɔɔ́ ɛgɔ ji dɔɔ́.”
\p 
\v 57 Ne bɔɔ́ Jus áshuú meko áké, “Ɔlú dankwɔ́ne yɛ́ usaá aŋmɛ upeá meso ɛfya, ɔpyɛmbɔ nnó ne ɔkaá Abraham.”
\v 58 Ne Jisɔs aké, “Me ngarege ɛnyú wáwálé nnó, gemɛ́gé nnó ábyɛ́ Abraham, me nlú.”
\p 
\v 59 Ajɔɔ́gé mbɔ, ɛbwɔ́ abɔ́ mataá nnó ató ji, yɛ́mbɔ Jisɔs abií atané né mmu ɛcha upɛ Ɛsɔwɔ.
\c 9
\s1 Jisɔs apyɛ muú ayi ábyɛné ji amɛ nónómé agɛ́ne
\p 
\v 1 Ndɛre Jisɔs akɛ́ne ajyɛɛ́, agɛ́ mende fɔ ayi ábyɛné ji amɛ nónómé.
\v 2 Ne baá utɔɔ́ bií agií ji aké, “Ménlɛré, gabo ayi ndé muú apyɛɛ́ ábyɛné mende yina amɛ nónómé? Awuú jimbɔɔ́? Waá ayi mma wuú ne ntɛ wuú.”
\p 
\v 3 Jisɔs ashuú ɛbwɔ́ meko aké, “Amɛ anómé fɔ́ mende yina gétúgé gabo ayi ji apyɛɛ́ wɔ́. Ne ɛ́pɔ́fɔ́ ntó gétúgé gabo ayi mma wuú ne ntɛ wuú ápyɛɛ́. Ábyɛ́ mende yina amɛ nónómé nnó Ɛsɔwɔ alɛ́ré ndɛre utó bi upyɛ́ɛ utɔɔ́ né menyammyɛ wuú.
\v 4 Debɔ mampyɛ utɔɔ́ Átá muú atɔmé me ndɛre bií úlú gbɔɔ́, néndé utuú ugigé yɛ muu akage pyɛ se ubi.
\v 5 Tɛ ndɛre me nlú fa mme yina, me nlú geŋgbɔ́ mbaá bɔɔ́ mme.”
\p 
\v 6 Ajɔɔ́gé mbɔ akpó matyɛ mme, apyɛ gentwɔtwɔ awaá mende yimbɔ né amɛ
\v 7 ajɔɔ́ ne ji aké, “Chó shwɔ́né ushu byɛ né gentoógé manaá ɛyigé ákuú nnó Silɔm” (Ula Silɔm utɛné nnó átɔ). Ne mende yimbɔ afɛ́, ashwɔné ushu bií, aké achwɔɔ́, alɔ́ mangɛ́né mbaá.
\p 
\v 8 Ɛpyɛ́gémbɔ, bɔɔ́ abi ájwɔ́lege dachi ama ne ji, ne abi abɔ́ ágɛ́ne mɛ́ ji ndɛre akɔɔ́ dekɔ, ágɛ́gé ji, áké, “Pɔ́ mende ayi ajwɔ́lege na akɔɔ́ dekɔ yɛ́ndégébé na?”
\v 9 Abifɔ áké, “Ɛlé ji,” abifɔ ntó áké, “Ŋgba muú yimbɔ afú ɛlé fulé.”
\p Ne mende yimbɔ ajɔɔ́gé wyɛ aké, “Ɛlé me mbɔɔ́.”
\p 
\v 10 Ajɔɔ́gé mbɔ, bɔɔ́ bimbɔ agií ji áké, “Ɛkɛ nnó ne wɔ ɔlɔ́ɔ mangɛ́?”
\p 
\v 11 Ashuú ɛbwɔ́ meko aké, “Mende fɔ ayi akámege Jisɔs, ne apyɛ gentwɔtwɔ awaá me né amɛ, ajɔɔ́ ne me aké, chó shwɔ́né ushu byɛ né géntoógé manaá ɛyigé ákuú nnó Silɔm. Njyɛ́gé, nshwɔné ne nlɔɔ́ mbaá maŋgɛ́né.”
\p 
\v 12 Ne bɔɔ́ bimbɔ agií ji aké, “Mende awú alú fɔ́? Aké ne ɛbwɔ́ me nkaá wɔ́”.
\s1 Ɛkwɔ́ bɔɔ́ Farasi áchɛré mankaá ndɛre ɛpyɛ́ɛ ne mende yimbɔ alɔɔ́ mbaá mangɛ́né
\p 
\v 13 Mende yimbɔ ajɔɔ́gé mbɔ, ákpá ji áfɛ́ mbaá ɛkwɔ bɔɔ́ Farasi.
\v 14 Bií bi Jisɔs apyɛ getwɔtwɔ mende yimbɔ alɔɔ́ mbaá mangɛ́né, ɛlé bií uwyaá.
\v 15 Ne ɛkwɔ bɔɔ́ Farasi ntó ama ágií mende yimbɔ ndɛre ɛpyɛ́gé ne ji alɔɔ́ mbaá mangɛ́né. Ne mende yimbɔ agaré ɛbwɔ́ aké, “Awaá me gentwɔtwɔ né amɛ, nshwɔné ushu ba ne nana ngɛ́ne mbaá”.
\p 
\v 16 Ajɔɔ́gé mbɔ, ɛkwɔ bɔɔ́ Farasi abifɔ áké, “Mende yina ayi ákuú ji Jisɔs atané fɔ́ mbaá Ɛsɔwɔ wɔ́, néndé ábélégé fɔ́ ɛbɛ́ ɛwé aké muú apyɛ́gé fɔ utɔɔ́ bií uwyaá”.
\p Yɛ́mbɔ abifɔ aké, “Ɛpyɛmbɔ nnó ne muú ayi apyɛɛ́ gabo, apyɛɛ́ ufɔɔ́ ufélekpá bina?” Ɛwéna ɛpyɛ ɛbwɔ́ ábɔ́ ufɛ́ré ucháchá.
\p 
\v 17 Ne áma ágií mende yimbɔ áké, “Ne wɔ mbɔɔ́ ɔjɔɔ́ nnó, gétúgé mende yina ayi apyɛ amɛ jyɛ ánené?”
\p Ashuú meko aké, “Ji alu muú ɛkpávé Ɛsɔwɔ.”
\p 
\v 18 Yɛ́mbɔ ákpakpa bɔɔ́ Jus ákɛ́légé fɔ́ mankamé nnó ábɔ́ ábyɛ́ mende yina amɛ nónómé ne alɔɔ́ mbaá mangɛ́né. Ákuú mma wuú ne ntɛ wuú.
\v 19 Áchwɔ́gé ágií ɛbwɔ́ áké, “Maá nyú na? Ɛnyú déké débyɛ́ ji amɛ nónómé? Ɛpyɛ́gé nnó ne ji agɛ́ne nana?”
\p 
\v 20 Mma wuú ne ntɛ wuú ágaré ɛbwɔ́ áké, “Ɛsé dékaá nnó gɛ́ maá sé na, débɔ́ débyɛ́ ji amɛ nónómé.
\v 21 Ne genó ɛyi gépyɛ́gé ne ji alɔɔ́ mangɛ́né mbaá, ɛsé dékaá wɔ́. Yɛɛ́ muú ayi anené ji amɛ, ɛsé dékaágé fɔ́. Gígé jimbɔɔ́ agáré ɛnyú, apɔ́ sé mamane kɔ.”
\v 22 Ɛbwɔ́ ájɔɔ́ mbɔ gétúgé áfɔɔ́ ákpakpa bɔɔ́ Jus, abi ábɔ́ ajɔɔ́ mɛ́ nnó muú ayi ajɔge nnó Jisɔs alu Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa, áfyɛ́ɛ ji ɛbɛ́ nnó akpɛgé sé né mmu ɛcha mmyɛmenɛne.
\v 23 Gɛ́ genó ɛyi gepyɛɛ́ mma wuú ne ntɛ wuú ajɔɔ́ áké, “Ji apɔ́ sé mamáné kɔ, gíge jimbɔɔ́ agáré ɛnyú.”
\p 
\v 24 Ne ákpakpa bɔɔ́ Jus áma kuú mende yi amɛ́ abɔ́ ánómé ji, ájɔɔ́ ne ji áké, “Gáré wáwálé wyɛ né mbɛ ushu Ɛsɔwɔ, néndé ɛsé dékaá nnó mende yina alú muú ayi apyɛɛ́ gabo.”
\p 
\v 25 Ne mende yimbɔ ashuú ɛbwɔ́ meko aké, “Waá ji alú muú ayi apyɛɛ́ gabo ah, waá apɔɔ́ ah, genó gema ɛyigé me nkaá gélú nnó me mbɔ nlú amɛ nónómé ne nana ngɛ́ne mbaá.”
\p 
\v 26 Ne ágií ji áké, “Apyɛ́ nnó, ne wɔ? Apyɛ nno ne wɔ ɔlɔɔ́ mangɛ́né mbaá?”
\p 
\v 27 Ashuú ɛbwɔ́ meko aké, “Pɔ́ me mbɔ́ ngáré mɛ́ ɛnyú? Yɛ́mbɔ dékɛ́légé fɔ́ manwú, ulannó ɛnyú dékɛ́légé mámanwú? Ndɔfɔ ɛnyú ntó dékɛ́légé mambɛ́ aŋkwɔlé bií?”
\p 
\v 28 Ajɔɔ́gé mbɔ, bɔɔ́ bimbɔ álɔ manju ji mashyɛ mmyɛ, áké, “Wɔ ne ɔlú menkwɔlé wuú. Ɛsé délú aŋkwɔlé Mosis.
\v 29 Ɛsé dékaá nnó Ɛsɔwɔ ajɔɔ́ nyá mejɔɔ́ ne Mosis, ne ushuú mbaá menya muú yina atané ɛsé dekaá wɔ́.”
\p 
\v 30 Mende yimbɔ aké, “Mechɔ́ ɛwé ɛgboó me mmyɛ. Ɛnyú déké dékaá fɔ́ mbaá ayi ji atané wɔ́ yɛ́mbɔ apyɛ me ngɛ́né mbaá.
\v 31 Dékaá nnó Ɛsɔwɔ awuú fɔ́ mmyɛmenɛné bɔɔ́ abi ápyɛɛ́ gabo, yɛ́mbɔ yɛ́ndémuú ayi ánogé Ɛsɔwɔ ne ápyɛ́ɛ unó bi Ɛsɔwɔ ákɛ́lege, Ɛsɔwɔ awuú mmyɛmenɛne jií.
\v 32 Tɛ mme álɔɔ́ délú danwú nnó muú fɔ ánené ámɛ́ muú ayi ábyɛné ji amɛ́ nónómé.
\v 33 Mende yina ábɛ́ dantáne mbaá Ɛsɔwɔ mbɔ yɛ genó ji apyɛɛ́ wɔ́.”
\p 
\v 34 Ajɔɔ́gé mbɔ, áshuú ji meko áké, “Ábyɛ́ wɔ ɔwɛ́ né mmu gabo. Ndé genó wɔ ɔ́kɛ́lege manlɛré ɛsé?” Ájɔɔ́gé mbɔ, áfyɛ́ ji ɛbɛ́ nnó ákpɛ́gé sé mmu ɛcha mmyɛmenɛne.
\s1 Bɔɔ́ abi ágɛ́ne ne abi álá ágɛ́né
\p 
\v 35 Ne Jisɔs awuúgé nnó afyɛ́ mende yimbɔ ɛbɛ́, akɛlé ji agɛ́, agií ji aké, “Nnó wɔ ɔfyɛ metɔɔ́ ne Maá Ntɛ Mekwaá?”
\p 
\v 36 Ne mende yimbɔ ashuú ji meko aké, “Ata, Maá Ntɛ Mekwaá ɛlé waá? Garé me mmfyɛ́ metɔɔ́ ne ji.”
\p 
\v 37 Jisɔs ajɔɔ́ ne ji aké, “Wɔ ɔgɛ́ mɛ́ ji nana. Ji ne ajɔɔ́gé mbɔ mejɔɔ́ ne wɔ.”
\p 
\v 38 Mende yimbɔ ajɔɔ́ yɛ́ ne Jisɔs aké, “Ata me mmfyɛ́ metɔɔ́ ne wɔ”, ne anógé ji.
\p 
\v 39 Ne Jisɔs ajɔɔ́ ne ji aké, “Me nchwɔ́ fa mme mampyɛ gabo bɔɔ agɛne gbɔgɔnɔ, nnó bɔɔ́, abi álú amɛ nónómé ágɛ́né mbaá ne nnó abi afɛré nnó ɛbwɔ́ ágɛ́ne, abɛ amɛ nónómé.”
\p 
\v 40 Ajɔɔ́gé mbɔ, bɔɔ́ ɛkwɔ Farasi abi álú ɛfɛɛ́, áwuú, ágií ji áké, “Ɛsé défɛré nnó wɔ ɔjɔɔ́gé fɔ́ lé ne ɛsé nnó délú ntó amɛ́ nónómé?”
\p 
\v 41 Ne Jisɔs ashuú ɛbwɔ́ meko aké, “Ɛnyú débɔ́ dékámé nnó délú amɛ nónómé mbɔ abɔ ajɔɔ fɔ nno ɛnyu depyɛ gabo wɔ́. Tɛ mbaá ɛnyú déké dégɛ́ne, gabo nyú alá ɛnyú mmyɛ.”
\c 10
\s1 Mebame magɔŋme melɔ́mélɔ́ ne magɔŋme jií
\p 
\v 1 Ngarege ɛnyú wáwálé nnó, “Muú ayi akwɔme mfaá gebame akpɛne né mmu gebamege magɔŋme, álá koge né meno gebame alú menjo. Ɛlá pɔ́ mbɔ fɔ́ wɔ́, alú muú yi afɔgé unó bɔɔ́.
\v 2 Ne muú yi akogé né meno gebame akpɛ né mmu gebamege magɔŋme alú mbɔɔ́ magɔŋme yimbɔ.
\v 3 Mebame meno gebame ánénégé ji meno gebame, ji akpɛ né mmu, ne magɔŋme awuú meko wuú. Ne ji akuú magɔŋme jií né mabɔ ne asɛ áji afɛ́ dafyɛ.
\v 4 Ne asɛ́gé magɔŋme jií ako atanege dafyɛ, ji ajyɛ mbɛ aji akwɔlege ji meso, néndé ákáge meko wuú.
\v 5 Yɛ́mbɔ áji akwɔlege fɔ meŋkɛɛ́, áboó lé ji boó nénde ákáge fɔ meko wuú.”
\p 
\v 6 Jisɔs ató ɛbwɔ́ nekané mejɔɔ́ ɛníné na, yɛ́mbɔ, ɛbwɔ́ ákáge fɔ geno ɛyige ji agarege ɛbwɔ.
\p 
\v 7 Ne Jisɔs ama ajɔɔ́ aké, “Me ngarege ɛnyú wáwálé nnó me ne nlú meno gebamege magɔŋme.
\v 8 Ne bɔɔ́ ako abi abɔɔ́ mbɛ achwɔɔ́ ne me, álú lé anjo, ne bɔɔ́ abi afɔgé unó bɔɔ́ fɔge, magɔŋme awuú fɔ ɛbwɔ́.
\v 9 Me ne nlú meno gebame, yɛ́ndémuú ayi akoógé ɛta wa ne akpɛ né mmu, Ɛsɔwɔ aferege nyɛ ji né ɛfwyale gabo. Ne akpɛne nyɛ mmu atanege dafyɛ agɛne yɛ́ndégenó ɛyi gelií ji.
\v 10 Menjo achwɔɔ́ lé nnó ajo unó, awá bɔɔ́ ne áchɔ unó, yɛ́mbɔ me nchwɔ lé nnó mmpyɛ bɔɔ́ abɔ geŋwá abɛ gbɛne né mati mako.
\p 
\v 11 “Me nlú membame magɔŋme melɔ́mélɔ́. Membame magɔŋme melɔ́mélɔ́ achyɛge gemɛ jií gétúgé magɔŋme jií.
\v 12 Muú usege apɔ́ fɔ́ membamé magɔŋme, muú áwyaá magɔŋme, ndɛre ɛlúmbɔ, gébégé agɛge mekwala aké achwɔɔ́, aboó alyaá magɔŋme, mekwala afwené áji álá tyátyá.
\v 13 Muú yimbɔ, aboó alyaá magɔŋme yimbɔ néndé ji alú lé muú usege, abɔɔ́ fɔ́ gébé ne áji wɔ́.
\v 14 Me nlú membame magɔŋme melɔ́mélɔ́, me nkágé magɔŋme ya ne magɔŋme ya ntó ákáge me.
\v 15 Wyɛ ndɛre Ntɛ wa akaa me, me ntó nkaa ji. Me nchyɛge gemɛ ya gétúgé magɔŋme ya.
\v 16 Ne nwya magɔŋme ayifɔ, ayi álá pɔ́ né geluage ayina, mbɔ́ mansɛ áji ncho ne ayina. Áji ntó áwuú nyɛ meko wa, ne mpyɛ nyɛ áji ábɛ ɛkwɔ magɔŋme ɛma ne ábɛɛ́ nyɛ ne membame ama.
\p 
\v 17 “Ula bi ntɛ wa agboó ne me úlú nnó nchyɛge gemɛ ya nnó áwá gétúgé bɔɔ́ ba ne nnó kwyakwya me mma mbɔ́ geji.
\v 18 Yɛ́ muú ayi akágé wa me apɔ́, yɛ́mbɔ me mbɔɔ́ ne nchyɛge gemɛ ya nnó awá. Ne me nwyaá uto manchyɛ gemɛ ya nnó áwá ne nwya ntó uto mamma mbɔ geŋwá ya. Gɛ geno ɛyige Ntɛ wa agare me mbɔ”
\p 
\v 19 Jisɔs ajɔ́gé mbɔ, bɔɔ́ Jus ábɔ́ ufɛre ucháucha.
\v 20 Abifɔ ájɔ́gé áké, “Melo nchyɛ achyɛge Jisɔs ɛfwyale ne ameé gebwɔɔ́, déwúgé ji.”
\p 
\v 21 Ne abifɔ ntó ájɔ́gé áké, “Muú ayi melo nchyɛ achyɛgé ji ɛfwyale ajɔ́gé fɔ ufɔɔ́ unó bina. Nnó muú ayi meló nchyɛ achyɛgé ji ɛfwyale, akaáge apyɛɛ́ ntó muú amɛ nónómé agɛne mbaá?”
\s1 Bɔɔ́ Jus áshyá Jisɔs
\p 
\v 22 Ne gébégé bɔɔ́ Jus ányɛɛ́ ɛpaá ɛwe ɛbwɔ́ áteé ndɛre áfyɛɛ ɛcha upɛ né amu Ɛsɔwɔ, Jisɔs abɔ alu né Jɛrosalɛ. Gébé ɛyigémbɔ nebá nelu.
\v 23 Ndɛre Ji alú né dachi ɛcha upɛ Ɛsɔwɔ, akɛne né agbá ayi akuú nnó agba Solomun.
\v 24 Bɔɔ́ Jus áchwɔ́ nɔ ji né mme, ágií ji áké, “Wɔ ɔlyagé mbɔ ɛsé né mmu dembyɔ nnó? Mbɔgé wɔ ɔlú Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa gare ɛse gbɔŋɔnɔ.”
\p 
\v 25 Ne Jisɔs ashuú ɛbwɔ́ meko aké, “Me mbɔ ngare mɛ ɛnyú, yɛ́mbɔ ɛnyú dékame ne me wɔ. Utɔɔ́ ɛbi mempyɛɛ́ né mabɔ Ntɛ wa, ubi ne ulɛrege gefɔge muú ayi me nlú.
\v 26 Yɛ́mbɔ ɛnyú dékamege néndé depɔ fɔ́ né geluage magɔŋme ya.
\v 27 Magɔŋme ya, ákágé meko wa. Me nkágé áji ne áji ntó ákwɔlege me.
\v 28 Me nchyɛge áji geŋwá ɛyi gélágé byɛɛ́. Áji ánome fɔ́ mme detu ne yɛ́ muú ayi ákágé fɔɔ́ áji né amu ya ápɔ́.
\v 29 Néndé Ntɛ wa muú áfyɛɛ́ me áji né amu, aŋea gemɛ apwɔ bɔɔ́ ako, ne yɛ́ muú ayi ákágé fɔɔ́ aji né amu Ntɛ wa apɔ́.
\v 30 Me ne ntɛ wa Ɛsɔwɔ delu muú ama.”
\p 
\v 31 Jisɔs ajɔ́gé mbɔ, bɔɔ́ Jus ama ábɔ́ mataá nnó áto ji áwá.
\v 32 Ne Jisɔs ajɔɔ́ ne ɛbwɔ́ aké, “Me mpyɛ gejamégé utɔɔ́ ulɔ́úlɔ́ ɛbi Ntɛ wa achyɛɛ́ me utó nnó mpyɛ, ɛnyú degɛ. Né ɛbi ndé ne ɛnyú dékɛlege manto me ne mataá?”
\p 
\v 33 Bɔɔ́ Jus bimbɔ áshuú ji meko aké, “Ɛpɔfɔ gétúgé utɔɔ́ ulɔ́úlɔ́ ɛbi wɔ ɔpyɛɛ́ ne ɛse detome wɔ ne mataá. Ɛlé gétúgé wɔ ɔbyaá Ɛsɔwɔ. wɔ ɔlú lé mekwaá, yɛ́mbɔ ɔsɛ gemɛ jyɛɛ́ nnó wɔ ɔlú Ɛsɔwɔ.”
\p 
\v 34 Ne Jisɔs ajɔɔ́ ne ɛbwɔ́ aké, “Pɔ nnó asa né mmu ŋwɛ Ɛsɔwɔ nnó, ‘Me nke ɛnyú delu bɔ ɛsɔwɔ?’
\v 35 Ɛse dékaá nnó mekomejɔɔ́ Ɛsɔwɔ akwɔrégé fɔ́. Ne mbɔgé Ɛsɔwɔ akú bɔɔ́ abi ji achyɛɛ́ ɛbwɔ́ mekomejɔɔ́ nnó álú bɔ ɛsɔwɔ.
\v 36 Ɛpyɛmbɔ nnó ne me muú Ɛsɔwɔ ajyaá atɔme fa mme, njɔ́gé nnó nlú Maá Ɛsɔwɔ, ɛnyú déké me mbyaá Ɛsɔwɔ?
\v 37 Mbɔgé me mpyɛɛ́ fɔ́ utɔɔ́ ɛbi Ntɛ wa achyɛɛ́ me nnó mpyɛge, dékamegé fɔ́ ne me.
\v 38 Ne mbɔgé me mpyɛ lé ubi, yɛ́ lé ɛnyú déla dékame nnó genó ɛyigé me njɔ́gé gelú wáwálé wɔ́, kamegé ne utɔɔ́ ɛbi me mpyɛɛ́. Dépyɛge mbɔ, dégɛne nyɛ nnó me nlu muú ama ne Ntɛ wa, ne Ntɛ alu muú ama ne me.”
\p 
\v 39 Ajɔ́gé mbɔ, bɔɔ́ Jus bimbɔ ama amua mampyɛ ji, yɛ́mbɔ aloó ɛbwɔ́ né amu.
\p 
\v 40 Achyaá afɛ né ɛgbɛ ɛbɛɛ́ Jodan ɛwefɔ mbaá ayi Jɔn abɔ awyage nya bɔɔ́ manaá Ɛsɔwɔ, ajwɔlege ɛwú.
\v 41 Ne gejamégé bɔɔ́ ákwɔle ji, ájɔ́gé ne atɛ áké, “Jɔn apyɛ yɛ́ ufélekpa fɔ́ wɔ́, yɛ́mbɔ yɛ́ndégenó ɛyigé ji ajɔɔ́ atome ne mende yina gelú wáwálé.”
\v 42 Ɛfɛɛ́ ne gejamégé bɔɔ́ áfyɛɛ́ metɔɔ́ ne Jisɔs.
\c 11
\s1 Negboné Lasarɔs
\p 
\v 1 Gébégé fɔ, mende fɔ abɔ ameé, akuú ji nnó Lasarɔs. Ji alu muú Bɛtani. Bɛtani ɛle melɔ Mɛri ɛbwɔ ne meŋmo wuú Mata.
\v 2 Ɛlé Mɛri yina ne abɔ ágbɛlé nya lamɛnda né uka Ata, atile ne mejwɛ wuú. Ji ne meŋmo wuú Lasarɔs abɔ́ ameé.
\v 3 Gétúgé Lasarɔs ameé, aŋmɛ bií átɔ́ meko mbaá Jisɔs aké, “Ata mejeé wyɛɛ́ ayi ɔgboó ne ji dɔɔ́ ameé.”
\p 
\v 4 Jisɔs awúgé meko ayi alɔɔ́ ji, aké, “Nemeé ɛniné Lasarɔs ameé mbɔ, nepɔ́ fɔ́ ɛni netene ji aló nelú ɛle nnó, bɔɔ́ áfɛge Maá Ɛsɔwɔ nnó ŋgɔ Ɛsɔwɔ akwɔ. Getu ɛyigembɔ bɔɔ́ áfɛge nyɛ Maá Ɛsɔwɔ.”
\p 
\v 5 Jisɔs agboó ne Mata, ne meŋmo wuu Mɛri ne Lasarɔs.
\v 6 awuge nnó Lasarɔs ameé ama bɛle né melɔ ɛwé ji abɔ alú wyɛɛ́ ndɔ ɛpea.
\v 7 Ne ndɔ yimbɔ ɛpea ɛkógé, ajɔɔ́ ne baá utɔɔ́ bií aké, “Déma déjyɛ né gebage mewaá Judiya.”
\p 
\v 8 Baá utɔɔ́ bií ájɔɔ́ ne ji áké, “Ménlɛré ɛlú dambɛle ayi bɔɔ́ bimbɔ áké áto wɔ ne mataá áwá, ne wɔ ɔkɛlege nnó déma dékeré ɛwú?”
\p 
\v 9 Ájɔ́gé mbɔ, Jisɔs ashuú ɛbwɔ́ meko né nekanémejɔɔ́ aké. “Yɛ́ndé bií uwyaá nchwanekɛ ɛfyánéɛpeá ne utuú ugi, wa mbɔ fɔ́ wɔ́? Bɔɔ́ áké ákɛne ne bií gbɔɔ́, ákparege fɔ́ nekwe néndé ágɛne mbaá.
\v 10 Yɛ́mbɔ bɔɔ́ abi akɛne ne utuú ákpárege nekwe néndé geŋgbɔ gepɔ́.”
\v 11 Ajɔ́gé mbɔ, aké ne ɛbwɔ́, “Meŋmɛ se Lasarɔs akwe gejya, yɛ́mbɔ me njyɛ ɛwú nnó pyɛ ji apeé gejya.”
\p 
\v 12 Ajɔ́gé mbɔ, baá utɔɔ́ bií áké ne ji, “Ata mbɔgé abɛlé gejya ɛbyɛnnó alé atoó.”
\p 
\v 13 Jisɔs abɔ agarege mbɔ lé ɛbwɔ́ negbone Lasarɔs, yɛ́mbɔ ɛbwɔ́ áfɛre nnó ajɔ́gé mbɔ lé mechɔ gejya ɛyigémbɔ.
\p 
\v 14 Jisɔs agare yɛ́ ɛbwɔ́ gbɔgɔnɔ aké, “Lasarɔs agbo.
\v 15 Ne metɔɔ́ ɛgɔɔ́ me gétúgé nyú nnó me mbɔ́ mpɔ́ fɔ́ ɛwú ne ji. Genó ɛyigé mempyɛ nyɛ, gepyɛ nyɛ ɛnyú défyɛɛ́ metɔɔ́ ne me cháŋéné. Kwilege mme déjyɛ dégɛ ji.”
\p 
\v 16 Ajɔ́gé mbɔ, Tɔmasi maá gefa, ajɔɔ́ ne atɛ baá utɔɔ́ aké, “Kwilege déjyɛ, yɛ́ ɛbɛ lé negbo, degbo ne ji”.
\s1 Jisɔs afyɛɛ́ aŋmɛ Lasarɔs metɔɔ́
\p 
\v 17 Jisɔs akwɔnege né melɔ Bɛtani, agɛ nnó anií Lasarɔs né mmu ɛba ntaá alɛ mɛ ndɔ ɛni.
\v 18 Nekɛne Bɛtani ne Jɛrosalɛ nelú genóge ŋkpa nekɛ ɛpea.
\v 19 Ne gejamégé bɔɔ́ Jus áfɛ́ manjwyɛ Mata ɛbwɔ́ ne Mɛri mmyɛ gétúgé negbone meŋmo bwɔ́.
\p 
\v 20 Mata awúgé nnó Jisɔs achwɔɔ́, atane ajyɛ bane ji, Mɛri álá ji né mmu gepú.
\v 21 Mata ábánégé Jisɔs ajɔɔ́ ne Ji aké, “Ata mbɔgé wɔ ɔbɔ́ ɔbɛ fa, mbɔ meŋmó wa agboó wɔ́.”
\v 22 Yɛ́mbɔ, yɛ́ ɛbɛ ɛlé nana, nkaá nnó, yɛ́ndégenó ɛyigé wɔ ɔgigé Ɛsɔwɔ, achyɛge wɔ geji.
\p 
\v 23 Ne Jisɔs ajɔɔ́ ne ji aké, “Meŋmó wyɛ akwilege nyɛ né negbo.”
\p 
\v 24 Ne Mata aké, “Nkaá nnó akerege nyɛ meso né geŋwá gébégé bɔɔ́ áké ákwilege nyɛ né negbo né bií bi kwyakwya.”
\p 
\v 25 Ajɔ́gé mbɔ, Jisɔs aké, “Me ne mbwyɛge bɔɔ́ ákwilege né negbo, ne me ne nchyɛge bɔɔ́ geŋwá. Yɛ́ndémuú ayi áfyɛɛ́ metɔɔ́ ne me, yɛ́ agbo akerege né geŋwá.
\v 26 Ne yɛ́ndémuú ayi alú mebɛ, áfyɛɛ́ metɔɔ́ ne me ágboó fɔ́, Mata ɔkamé nnó ɛlé wáwálé?”
\p 
\v 27 Mata aké, “Ɛh Ata nkamé, nnó wɔ ne ɔlú Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa, Maá Ɛsɔwɔ ayi ábɔɔ́ manchwɔ fa mme.”
\s1 Jisɔs asɔ manse
\p 
\v 28 Mata ajɔ́gé mbɔ, ajyɛ kú meŋmo wuú Mɛri ajɔɔ́ ne ji bibi aké, “Ménlɛré achwɔ, akɛlege mangɛ wɔ.”
\v 29 Mɛri awúgé mbɔ, akwilé mme wáwá, ajyɛ bane Jisɔs.
\v 30 Jisɔs abɔ alú dankwɔne yɛ́ né melɔ, alú wyɛ né mbaá ayi Mata abané ji.
\v 31 Ne bɔɔ́ Jus abi alú né mmu gepúge negbo áfyɛɛ́ Mɛri metɔɔ́ né negbone meŋmo wuú, ágɛge ndɛre Mɛri akwilé ka wáwá átane dafyɛ, ɛbwɔ́ ntó ákwilé ákwɔle ji, néndé áfɛre nnó ji ajyɛɛ́ mbɔ lé né menome meŋmo wuú Lasarɔs manli negbo.
\p 
\v 32 Mɛri akwɔnege, agɛ Jisɔs, akwe ji né uka aké, “Ata wɔ ɔbɔ ɔbɛ fa, mbɔ meŋmo wa abɔ́ agboó wɔ́.”
\p 
\v 33 Jisɔs ágɛ́gé ndɛre Mɛri álíli chonchó ne bɔɔ́ Jus abi ákwɔlege ji, ɛta ji mmu ne meshwɛ akwɔ ji metɔɔ́.
\p 
\v 34 Agií ɛbwɔ́ aké, “Ɛnyú dénií ji ɛfɔ́?”
\p Áshuú ji meko aké, “Ata, chwɔ gɛ mbaá wuú.”
\p 
\v 35 Jisɔs asɔ manse.
\v 36 Bɔɔ́ Jus bimbɔ, ágɛgé mbɔ, áké, “Ɛ́ ɛ́, gɛge ndɛre ji abɔɔ́ gejeé ne Lasarɔs.”
\p 
\v 37 Yɛ́mbɔ abifɔ ájɔ́gé áké, “Nnó ji muú apyɛɛ́ muú amɛ nónómé agɛne, abɔ́ akágé pyɛ fɔ́ nnó Lasarɔs agboge?”
\s1 Jisɔs ape Lasarɔs né negbo
\p 
\v 38 Ne nchyɛ ama anywɔne Jisɔs né mmu, afɛ́ né menome. Menome ɛwémbɔ, ɛlú lé ɛmbu ɛbá ntaá, agbɛ ɛwú ne ntaá.
\v 39 Jisɔs aké, “Ferege ntaá ɛniné mbɔ né meno menome.”
\p Mata meŋmɛ Lasarɔs ashuú ji meko aké, “Ata, agbo mbɔ alɛ fina ndɔ ɛni, gébé ɛyi, gebɛ gebogebo geja gepwɔ amu.”
\p 
\v 40 Ne Jisɔs ajɔɔ́ ne ji aké, “Mata, pɔ́ me ngaré na wɔ nnó ɔfyɛge metɔɔ́ ne Ɛsɔwɔ, ɔgɛne nyɛ genó ɛyigé utó ba upyɛɛ́?”
\v 41 Áférégé ntaá ɛniné mbɔ, Jisɔs abwɛɛ́ amɛ apɛ mfaá anɛmmyɛ aké, “Ntɛ wa, ntame wɔ néndé ɔwú mmyɛmenɛne ya.
\v 42 Nkaá nnó wɔ ɔwuú mmyɛmenɛne ya yɛ́ndégébé. Yɛ́mbɔ, njɔɔ́ mbɔ gétúgé bɔɔ́ abi álú fa, nnó ɛbwɔ́ ákamé nnó wɔ ne ɔtɔme me.”
\v 43 Anerege manjɔɔ́ mbɔ, anyá ne meko metometo aké, “Lasarɔs táné chwɔ fa.”
\v 44 Tɛnétɛné yimbɔ, Lasarɔs atane dafyɛ, uka bií ne amu, úlú wyɛ wɛ́wɛ́ né mmu uba mandée ɛbií áni ji né mmyɛ chonchó ne ushu. Ne Jisɔs aké, “Kaáge ji ajyɛ.”
\s1 Ájɔɔ́ geju manwá Jisɔs
\r (Mat 26:1-5; Mak 14:1, 2; Luk 22:1, 2)
\p 
\v 45 Ne gejamégé bɔɔ́ Jus abi ábɔ́ álú ɛfɛɛ́ áchwɔɔ́ áchwɛɛ́ Mɛri mmyɛ́, ágɛge ndɛre Jisɔs apyɛɛ́ Lasarɔs apeé né negbo, áfyɛɛ́ matɔɔ́ ne Jisɔs.
\v 46 Yɛ́mbɔ, abifɔ ájyɛ gare bɔɔ́ Farasi fɔ genó ɛyigé Jisɔs apyɛɛ́.
\v 47 Ne anɔ ba ampyɛɛ́ upɛ Ɛsɔwɔ ne ɛkwɔ bɔɔ́ Farasi fɔ, ákú ujwɔlé, áchomé né ɛso ájɔɔ́ aké, “Nana ɛsé dépyɛmbɔ nnó? Mende yina apyɛɛ́ mbɔ ufélekpa ufɔɔ́ ufɔɔ́ ajyɛɛ́.
\v 48 Mbɔgé délyage ji nnó ajyɛɛ́ mbɛ mampyɛ ubi, melɔ meko ɛfyɛɛ́ nyɛ metɔɔ́ ne ji, ne bɔɔ́ Rom áchwɔ chɔ nyɛ ɛcha upɛ se chonchó ne melɔ.” \f + \fr 11:48 \ft Ɛlú wáwálé nnó: Mbɔgé nnó bɔɔ́ Jus áfyɛgé metɔɔ́ ne Jisɔs, Ji ámmyɛ nyɛ apwɔ bɔɔ́ Rom nnó bɔɔ́ Jus álaá mmyɛmmyɛ bwɔ́.\f*
\p 
\v 49 Ne muú bwɔ́ ama, ayi akamege Kaifas, ji ne alú ɛtukpe ampyɛ upɛ Ɛsɔwɔ né ŋmɛ ɛniné mbɔ. Ajɔɔ́ aké, “Ɛnyú dékage yɛ́ genó kaŋka,
\v 50 dekaá fɔ́ nnó ɛlú galɔ́gálɔ́ ɛta nyú nnó muú ama agbo gétúgé bɔɔ́ ako ɛpwɔ nnó melɔ meko ɛ́nómé wɔ́?”
\v 51 Mejɔɔ́ ɛwé Kaifas ajɔɔ́ mbɔ, ɛtane fɔ́ jimbɔɔ́ né metɔɔ́ wɔ́. Ndɛre ji alú ɛtukpe ampyɛɛ́ upɛ Ɛsɔwɔ né ŋmɛ ɛniné mbɔ, Ɛsɔwɔ apyɛ nnó ji agare nnó Jisɔs abɔ magbo gétúgé melɔ meko.
\v 52 Ne ɛpɔ́fɔ́ gétúgé melɔ ɛwú ɛwú wɔ́, agbo ntó nnó apyɛ bɔɔ́ Ɛsɔwɔ abi álaá tyátyá né mme meko anywɛre akwe muú ama.
\v 53 Ɛlɔ né gébé ɛyigémbɔ, ákpakpa bɔɔ́ Jus asɔ mala ndɛre ápyɛɛ́ ne áwa Jisɔs.
\v 54 Né getú ɛyigémbɔ, Jisɔs amáge kɛ sé gbɔŋɔnɔ né géluage bɔɔ́ Jus. Alyaá Jɛrosalɛ afɛ́ né maá melɔ fɔ́ ayi akuú nnó Ɛfrɛm kwɔ́kwɔ́lé ne mashwɔne. Ɛwúmbɔ ne ji ne baá utɔɔ́ bií ájwɔlége.
\p 
\v 55 Ne gébégé ɛpaá bɔɔ́ Jus ɛwé ákuú nnó ɛpaá koó upú ɛlá kwɔ́kwɔ́lé, gejamégé bɔɔ́ áfɛ́ né Jɛrosalɛ nnó akpome mmyɛ ndɛre ɛbwɔ́ apyɛ mɛ gemɛge nnó ɛpaá ɛwémbɔ ɛkwɔne.
\v 56 Ne ndɛre ɛbwɔ anywere né mmu ɛcha upɛ Ɛsɔwɔ, ápɛle mbɔgé agɛne nyɛ Jisɔs. Ájɔ́ge ne atɛ áké, “Ɛnyú défɛre mbɔ nnó? Nnó ji achwɔɔ́ nyɛ né ɛpaá ɛwéna waá achwɔɔ́?”
\v 57 Gemɛge nnó ɛpyɛmbɔ ɛtukpe ampyɛ upɛ Ɛsɔwɔ ne ɛkwɔ bɔɔ́ Farasi fɔ, ábɔ́ áchyɛɛ́ mɛ meko nnó muú ayi akaáge mbaá ayi Jisɔs alú ágare, ájyɛ apyɛ ji.
\c 12
\s1 Áwaá Jisɔs maweé né melɔ́ Bɛ́táni
\r (Mat 26:6-13; Mak 14:3-9)
\p 
\v 1 Ɛpaá koó upú ɛlágé ndɔ ɛkene, Jisɔs afɛ né melɔ Bɛtani melɔ ɛwé Lasarɔs muú Jisɔs apyɛ ji apeé né negbo ajwɔlége.
\v 2 Ɛfɛɛ́ ne anɛne Jisɔs ne menyɛɛ́. Mata ne afaá menyɛɛ́ yimbɔ ne Lasarɔs alú muú ama né geluage bɔɔ́ abi ájwɔle agií mmyɛ né ɛkpókpógélé ne Jisɔs.
\v 3 Ndɛre ájwɔle mbɔ, Mɛri akpa ɛkpómé maweé Lamɛnda ami majame ŋka dɔɔ́, amo Jisɔs né uka. Gepú geko geka ne gebɛge lamɛnda, ne asɛ mejwɛ wuú ati uka Jisɔs. Maweé amina malu mmyɛ po. Ákwyɛɛ́ mami ne genó ɛyigé akuú nnó, “Nard.”
\v 4 Ne Judas Iscarot, maá utɔɔ́ Jisɔs ama ayi abɔɔ́ manchyɛɛ́ Jisɔs maŋkwaá, agɛge geno ɛyi meri apyɛmbɔ, aké,
\v 5 “Mbɔ ákpoó maweé lamɛnda amina, ásɛ gejamégé ŋka, ɛyi ɛpwɔɔ́ ŋka ɛyi muu akage pyɛ né ŋmɛ áchyɛɛ́ mbaá ubyá bɔɔ́.”
\v 6 Mejɔɔ́ ɛwé Judas ajɔɔ́ mbɔ na, ɛpɔ́fɔ́ nnó ji agboó ne ubya bɔ, ɛlé gétúgé ji alú menjo ne ajɔɔ́ mbɔ. Ji ne ábélege mekwa ŋka baá utɔɔ́ Jisɔs. Ne gébé ɛyigé fɔ, ajoó ŋka wyɛ.
\p 
\v 7 Judas ajɔ́gé mbɔ, Jisɔs aké, “Gɔgé ji abɛ nyame, ji apyɛ́mbɔ nnó me ngboge ánií me niíge.
\v 8 Ubyá bɔɔ́ úlú fa ne ɛnyú yɛ́ndégébé, yɛ́mbɔ me mbɛɛ́ nyɛ fɔ́ ne ɛnyú gébé geko.”
\p 
\v 9 Ne gejamégé bɔɔ́ Jus áwúgé nnó Jisɔs alú ɛfɛɛ́ né melɔ Bɛtani, ákwɔle áfɛ ɛwú. Ájyɛ nya fɔ mangɛ lé Jisɔs jimbií wɔ́, áfɛ ntó nnó ágɛ Lasarɔs muú Jisɔs apyɛ ji apeé né negbo.
\v 10 Ndɛre ɛlúmbɔ, anɔɔ́ baá ampyɛɛ́ upɛ Ɛsɔwɔ asɔ mala nnó áwa Lasarɔs.
\v 11 néndé ɛlé getú jií ne gejame bɔɔ́ Jus ályaá ɛbwɔ́ áfyɛɛ́ metɔɔ́ ne Jisɔs.
\s1 Jisɔs akpɛ né Jɛrosalɛ nkane mfwa
\r (Mat 21:1-9; Mak 11:1-11; Luk 19:28-40)
\p 
\v 12 Bií ujyage, gejamégé bɔɔ́ abi áchwɔɔ́ manyɛ́ ɛpaá koó upú, áwú nnó Jisɔs achwɔɔ́ né Jɛrosalɛ.
\v 13 Ásɔ mammɛ́ɛ, átane ájyɛ bane ji meti. Áwyále áké, “Matame mábɛ́ ne Ɛsɔwɔ. Mejé ɛbɛ́ ne muú ayi achwɔɔ́ né mabɔ Ata. Ɛfwɔ́ ɛbɛ ne Mfwa bɔɔ́ Isrɛli!”
\p 
\v 14 Jisɔs agɛ́ge maá géjuŋá, akwɔ ajwɔle né mfaá. Ne genó ɛyigé ábɔ́ ásamé né mmu ŋwɛ Ɛsɔwɔ getane wáwálé nnó,
\v 15 “Ɛnyú bɔɔ́ Sayɔn défɔge, gɛ́ge mfwa nyú achwɔɔ́, ajwɔlé mbɔ né mfaá maá géjuŋá” \f + \fr 12:15 \ft Ɛlú wáwálé nnó: Ɔpɛge né Mat. 21:5 né nteé gebagé ŋwɛ ɔgɛné ula Sayɔn.\f*
\p 
\v 16 Ndɛre Jisɔs akpɛne né Jɛrosalɛ, baá utɔɔ́ bií ákaá fɔ́ nnó uno bi ábɔ ásame mɛ né mmu ŋwɛ Ɛsɔwɔ úlú wawale wɔ́. Yɛ́mbɔ gébégé Jisɔs akwɔme ajyɛɛ́ né mfaánebuú, ne ɛbwɔ́ ateé nnó abɔ asa né mmu ŋwɛ Ɛsɔwɔ nnó unó bina upyɛɛ́ nyɛ ne ji. Ne ápyɛ ntó ubi ne ji.
\p 
\v 17 Ne bɔɔ́ abi abɔ alú ne Jisɔs gébégé ji apyɛ Lasarɔs apeé né negbo, akpa gegare ɛyigémbɔ, ájyɛɛ́ ne geji.
\v 18 Genó ɛyigé na ne gepyɛ gejamégé bɔɔ́ ájyɛɛ́ bane Jisɔs né meti gétúgé áwuú gepɔge ufélekpa ɛbi ji apyɛɛ́.
\v 19 Ne ɛkwɔ bɔɔ́ Farasi, ájɔ́gé ne atɛ aké, “Yɛ mekpo ne ula ɛsé dégɛne fɔ né mechɔ ɛwe desɔɔ mbɔ mala manwa Jisɔs. Gɛgé, gemɛge melɔ geko gela kwɔle ɛlé ji.”
\s1 Jisɔs abɔ́ mbɛ agare negbo nií
\p 
\v 20 Né geluage bɔɔ́ abi ájyɛ né Jɛrosalɛ manogé Ɛsɔwɔ gébégé ɛpaá koó upú, ne abi ákú ɛbwɔ́ nnó bɔɔ́ Grek álú wyɛ.
\v 21 Bɔɔ́ Grek bina áchwɔ mbaá Filip muú melɔ Bɛtsada né gebage mewaá Galilií, ájɔɔ́ ne ji áké, “Ata ɛsé dékɛlege mangɛ Jisɔs.”
\p 
\v 22 Filip awúgé mbɔ, ajyɛ gare Andru, ne ɛbwɔ́ ne Andru ájyɛ gare Jisɔs.
\v 23 Ne Jisɔs ashuú ɛbwɔ́ meko aké, “Gébé gekwane ɛyigé bɔɔ ágɛne nyɛ nnó Maá Ntɛ Mekwaá apwɔ amu.
\v 24 Me ngarege ɛnyú wáwálé nnó nyine nchi nelaá wyɛ nyine nchi nemaá, mbɔgé muú álá apɛɛ́ néní né mme degbo wɔ́. Negboge ne nechií nefyɛ gejame amɛ nchi.
\v 25 Muú ayi asɛle geŋwá jií nnó geŋeá gemɛ dɔɔ́, geŋwá jii genóme nyɛ mme detu. Ne muú ayi asɛle nnó geŋwá jií geŋeá fɔ gemɛ né mme yina wɔ́, abɛɛ́ nyɛ ne geŋwá ɛyi gélágé byɛ́.
\v 26 Mbɔgé muú akɛlege mampyɛge utɔɔ́ ba, abɔ́ mankwɔle me. Ne yɛ́ndé mbaá ayi me mbɛɛ, muú utɔɔ́ wa ntó abɛɛ́ wyɛɛ́ ne me. Ne yɛ́ndémuú ayi apógé me mampyɛ utɔɔ́ ba, Ntɛ wa anoge nyɛ ji.
\p 
\v 27 “Nana ufɛre ba úlú uyaá uyaá. Ɛwena njɔge mbɔ nnó? Nnɛne mbɔ ɛlé mmyɛ nnó, ‘Ntɛ wa aféré me né ɛfwyale ɛwé ɛchwɔɔ́ mbɔ me né mbɛ waá?’ Ngba, nnɛne fɔ́ mbɔ, néndé ula bi me nchwɔɔ́ fa mme úlú nnó ngɛ ɛfwyale ɛwéna.
\v 28 Ntɛ wa, pyɛ bɔɔ́ ákaá nnó wɔ ɔpwɔ amu.”
\p Ajɔ́gé mbɔ, meko fɔ atane né mfaánebuú aké, “Me mpyɛ mɛ́ bɔɔ́ akaá nnó me mpwɔ amu, ne mmage pyɛ wyɛmbɔ.”
\p 
\v 29 Ne gejamégé bɔɔ́ abi átɛne ɛfɛɛ́, áwúgé meko yimbɔ, abifɔ aké, ɛlé nemfe, abifɔ aké, ɛlé ɛkiɛ́nné Ɛsɔwɔ ne ɛjɔɔ́ mejɔɔ́ ne Jisɔs.
\p 
\v 30 Ne Jisɔs ajɔɔ́ ne ɛbwɔ́ aké, “Meko ayi déwuú mbɔ́ alú lé né galɔ́gálɔ́ nyú, ɛpɔ́fɔ́ awa.
\v 31 Nana, gébé ɛyigé Ɛsɔwɔ apyɛɛ́ bɔɔ́ mme ákpɛ né unɔɔ́ mpa gekwɔne, gébé gekwɔne ɛyigé ábuú danchɔmeló mfwa bɔɔ́ mme,
\v 32 né geluɔge gefwa jií. Ne abwɛge me né mbaá gekwa, njame nyɛ bɔɔ́ ako achwɔ́ ɛta wa.”
\v 33 Jisɔs ajɔɔ́ mbɔ, manlɛre gefɔge negbo ɛniné ji agboó nyɛ.
\p 
\v 34 Ne bɔɔ́ bimbɔ, ájɔɔ́ áké, “ŋwɛ mabɛ ɛsɔwɔ agare ɛse nnó Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa, abɛ mebɛ tɛ kwyakwyaá, ɛpyɛɛ́mbɔ nnó ne wɔ ɔke ábɔ́ mambwyɛ Maá Ntɛ Mekwaá né mfaá gekwa, waá álú Maá Ntɛ Mekwaá yimbɔ?”
\p 
\v 35 Jisɔs ashuú ɛbwɔ́ meko aké, “Geŋgbɔ gelú gegɛnege ɛta nyú né mboó gébé, kɛ́ge nana ndɛre geŋgbɔ gelú gegɛnege nnó ɛ́kágé gemua gewere ɛnyú. Muú ayi akɛne né gemua ákágé fɔ́ mbaá ayi ji ajyɛɛ́.
\v 36 Fyɛ́ge metɔɔ́ ne muú ayi achyɛgé geŋgbɔ nana ayi ji alú ne ɛnyú, nnó debɛ bɔɔ́ abi achyɛge geŋgbɔ. Jisɔs ajɔ́gé mbɔ, alyaá ɛbwɔ́ ajyɛ bií.”
\s1 Bɔɔ́ Jus áshyá wyɛ shyá mamfyɛ matɔɔ́ ne Jisɔs
\p 
\v 37 Ne yɛ́ lé Jisɔs apyɛ gejamégé ufɔɔ́ ufélekpa ɛbwɔ́ ágɛné, áfyɛɛ́ fɔ́ matɔɔ́ ne ji wɔ́.
\v 38 Ɛpyɛmbɔ nnó genó ɛyigé Asaya muú ɛkpave Ɛsɔwɔ abɔ ajɔɔ́ getane wáwálé. Asaya abɔ ajɔɔ́ nya aké, “Ata, ndé muú ákamé ne mekomejɔɔ́ ayi ɛsé dégare. Ne ndé muú ayi Ata alɛre ji gefɔge utó bi ji awyaá?”
\p 
\v 39 Ula bi ɛbwɔ́ álá ákame nya ne mekomejɔɔ́ yimbɔ wɔ́, úlú wyɛ ndɛre, Asaya muú ɛkpave Ɛsɔwɔ abɔ ajɔɔ́ nya nnó Ɛsɔwɔ aké,
\v 40 “Ngilége ɛbwɔ́ amɛ nnó ɛ́kágé ágɛne unó ne amɛ, ne mpyɛ bwɔ́ áŋea matɔɔ́ nnó ɛ́kágé ɛbwɔ́ ákaá genó ɛyigé mekomejɔɔ́ yimbɔ ágaré. Ɛsɔwɔ aké, ‘Me mpyɛ mbɔ nnó ɛ́kágé ɛbwɔ́ áti meso ne gabo bwɔ́, áchwɔ́ ɛta wá nnó me mfɛre ɛbwɔ́ né ɛfwyale’.”
\p 
\v 41 Asaya ajɔɔ́ mejɔɔ́ ɛwéna ato ne Jisɔs, néndé ji abɔ agɛ mɛ nnó Jisɔs abɛɛ́ nyɛ muú ayi apwɔɔ́ amu.
\p 
\v 42 Ne yɛ́ ɛlé gejamégé bɔɔ́ álú abi ála áfyɛɛ́ fɔ matɔɔ ne Jisɔs wɔ, abifɔ áfyɛ, yɛ́ ákpakpa bɔɔ́ Jus abifɔ áfyɛ́ ntó metɔɔ́ ne Jisɔs, yɛ́mbɔ álɛrege fɔ́ gbɔgɔnɔ nnó áfyɛɛ́ metɔɔ́ ne ji gétúgé áfɔɔ́ nnó álɛrege, bɔɔ́ Farasi ábuú nyɛ ɛbwɔ́ né ɛcha mmyɛmenɛne.
\v 43 Néndé ɛbwɔ́ ágbóo lé nnó akwaá áfɛge ɛbwɔ́ ápwɔ nnó Ɛsɔwɔ ne afɛge ɛbwɔ́.
\s1 Mekomejɔɔ́ ayi Jisɔs agare ne asɔɔ́ nyɛ mpa bɔɔ́
\p 
\v 44 Ne Jisɔs ajɔɔ́ keŋke, aké, “Yɛ́ndémuú ayi áfyɛɛ́ metɔɔ́ ne me, áfyɛ́ fɔ́ metɔɔ́ ne me mbií wɔ́, afyɛ́ ntó ne muú yi atɔme me.
\v 45 Muú agɛgé me, ɛbyɛnnó agɛ ntó muú ayi atɔme me.
\v 46 Me nchwɔ ndɛre muú yi alɛrege geŋgbɔ mbaá bɔɔ́ mme, nnó ɛ́kágé bɔɔ́ abi áfyɛɛ́ metɔɔ́ ne me álá kenékéné ɛké muú ayi alú mmu gemua.
\v 47 Mbɔgé muú awúgé mekomejɔɔ́ ayi me ngare ne álá apyɛɛ́ fɔ́ genó ɛyigé me nké ji apyɛ wɔ́, me njɔ́gé fɔ́ nnó ji akwe mpa, néndé me nchwɔɔ́ fɔ́ fa mensɔ mpá bɔɔ́ mme wɔ́ nchwɔ́ lé mamfere ɛbwɔ́ né ɛfwyale gabo.
\v 48 Muú yi ashyaá nnó ji ákágé me, ne álá apyɛ genó ɛyigé me njɔɔ́, genó ɛyi gesɔ mpa wuú gelú wyɛɛ́. Ne genó ɛyi gesɔɔ́ mpá wuú né bií bi kwyakwya, ɛlé mekomejɔɔ́ wa ayi ngare.
\v 49 Nende Me njɔ́gé fɔ́ né uto ba. Ntɛ wa muú atɔme me agare me genó ɛyi me njɔ́gé ne ndɛre me mbɔɔ́ manjɔɔ́.
\v 50 Ne nkaá nnó genó ɛyigé ji aké me ngare gechwɔɔ́ ne geŋwá ɛyi gélágé byɛ́. Né getú ɛyigémbɔ, me njɔ́gé lé genó ɛyigé Ntɛ wa agare me nnó njɔɔ́.”
\c 13
\s1 Jisɔs ashwɔne uka baá utɔɔ́ bií
\p 
\v 1 Wyɛ ndɛre ɛpaá koó upú ɛlaá kwɔ́kwɔ́lé Jisɔs akaá nnó gébé ɛyigé ji alyagé mme yina nnó akere meso mbaá Ntɛ wuú gekwɔne. Ne ɛlé ji abɔɔ́ gejeé ne bɔɔ́ bií abi alú fa mme, alɛre ɛbwɔ́ gefɔɔ́ ɛyigé ji abɔɔ́ gejeé ne ɛbwɔ́.
\p 
\v 2 Ne ndɛre Jisɔs ajwɔle anyɛɛ́ menyɛɛ́ ne baá utɔɔ́ bií ne nkwale, danchomeló anyú mɛ metɔɔ́ maá utɔɔ́ Jisɔs ayi ama nnó achyɛɛ́ Jisɔs maŋkwaá. Ákuú maá utɔɔ́ yimbɔ nnó Judas Iscarot, maá Simun.
\v 3 Jisɔs akaá nnó Ntɛ wuú Ɛsɔwɔ afyɛ ji yɛ́ndégenó né amu. Akaá ntó nnó ji abɔ atane mbaá Ɛsɔwɔ ne ji akerege meso mbaá Ɛsɔwɔ.
\v 4 Ndɛre álú ányɛ́ menyɛ́, Jisɔs akwile tɛ́né, afeé nku yi mfaa abelé. Ani agbogbo né gebwɛ.
\v 5 Afane manaá né mmu geku, alɔ manshwɔne uka baá utɔɔ́ bií, ne atile ubi ne agbogbo ayi ji anií né gebwɛ.
\v 6 Akwɔnégé mbaá Simun Pita, Simun agií ji aké, “Ata ɔkɛlege manshwɔne me uka?”
\p 
\v 7 Ne Jisɔs ashuú ji meko aké, “Genó ɛyigé me mpyɛ mbɔ, ɛnyú dékáge fɔ́ ula nana, meso gébé dékage nyɛ.”
\p 
\v 8 Ajɔ́gémbɔ, Pita aké, “Ngba, wɔ ɔbɔ fɔ́ manshwɔne uka ɛba wɔ́.”
\p Ne Jisɔs aké ne Pita, “Mbɔgé me nlá nshwɔne wɔ wɔ́, ɔchome fɔ́ mbwa ne me.”
\p 
\v 9 Ajɔ́gé mbɔ Simun Pita aké, “Ata ɔshwɔnege fɔ́ lé uka ba ubiubi, shwɔne ntó amu ya chonchó ne mekpo wa.”
\p 
\v 10 Jisɔs aké, “Muú yi awɔɔ́ mɛ manaá ábɔ́ mashwɔne lé uka bií ubiubi néndé menyammyɛ wuú alu mɛ pópó. Ne ɛnyú délu mɛ pópó, yɛ́mbɔ ɛnyú ako fɔ́ wɔ́.”
\v 11 Jisɔs ajɔɔ́ mbɔ, ji akaá mɛ muú ayi achyɛgé nyɛ ji maŋkwaá, ŋkaawu ne ji aké, “Ɛnyú ako depɔ fɔ́ pópó.”
\p 
\v 12 Ne ji anerege manshwɔne uka baá utɔɔ́ bií, abɔ nku wuú afyɛ, akere ajwɔle ká. Agií ɛbwɔ́ aké, “Ɛnyú dékaá ulaá genó ɛyigé mempyɛ mbɔ né ɛnyú?”
\v 13 “Ɛnyú dékuú me menlɛre ne Ata. Ɛnyú délu cho mankú me mbɔ, néndé gɛ muú ayi me nlú mbɔ.
\v 14 Ne mbɔgé me, Ata ne menlɛre ɛnyú, nshwɔne ɛnyú uka, ɛnyú ntó debɔ manshwɔnege uka atɛ.
\v 15 Me nlɛre ɛnyú genó ɛyigé debɔɔ́ mampyɛge nnó dépyɛge geji ne atɛ ndɛre me mpyɛɛ́ ne ɛnyú.
\v 16 Me ngaregé ɛnyú wáwálé nnó, maá utɔɔ́ aŋeáge fɔ́ gemɛ apwɔ ntɛ wuú. Yɛ́ maá déntɔɔ́ ntó aŋeáge fɔ́ gemɛ apwɔ muú ayi atɔme ji.
\v 17 Nana ayi ɛnyú dékaá unó bina, déké dépyɛɛ́ ubi, débɛɛ́ ne metɔɔ́ megɔmegɔ.
\v 18 Me njɔ́gé mbɔ, ntome fɔ́ ne ɛnyú ako. Me nkaá ufɔɔ́ bɔɔ́ abi me njyaá. Yɛ́mbɔ mpyɛ mbɔ nnó genó ɛyigé ásame né mmu ŋwɛ Ɛsɔwɔ gétáné wawale. Ása wyɛ nno, ‘Muu yi ɛsé ne ji déchome ɛbwɔ menyɛɛ́, abwɔlé atɛne ummyɛ ne me’
\v 19 Me ngarege ɛnyú genó ɛyigé na nana gemɛge nnó gepyɛ. Ne gébégé gepyɛge, ɛnyú dekamege nyɛ nnó, ‘Me Nlú gefɔge Muú ayi Me Nké Me Nlú.’
\v 20 Me ngarege ɛnyú wáwálé nnó yɛ́ndémuú ayi asɛle muú dentɔɔ́ wa ne metɔɔ́ megɔ́mégɔ́, ɛbyɛnnó asɛ mbɔ lé me mbɔɔ́. Ne muú ayi asɛle me, asɛ mbɔ lé Ɛsɔwɔ muú átɔme me.”
\s1 Jisɔs abɔ mbɛ agare nnó áchyɛge nyɛ ji maŋkwaá
\r (Mat 26:20-25; Mak 14:17-21; Luk 22:21-23)
\p 
\v 21 Jisɔs ajɔ́gé unó bina, metɔɔ́ ɛsɔ ji, agare gbɔgɔnɔ aké, “Me ngarege ɛnyú wáwálé, muú nyú ama achyɛge nyɛ me maŋkwaá.”
\p 
\v 22 Ajɔ́gé mbɔ baá utɔɔ́ bií álá meno mekpo fuú ápɛ atɛ ne amɛ ne amɛ. Ákágé yɛ́ muú ayi ji ajɔɔ́ atome ne ji.
\v 23 Ne maá utɔɔ́ ama, ayi Jisɔs agboó ne ji, agií mmyɛ né ɛkpokpogele kwɔ́kwɔ́lé ne uwyaá Jisɔs.
\v 24 Ne Simun Pita anyú meno aké, ne ji “Gií Jisɔs muú ayi ji ajɔɔ́ mbɔ atome ne ji.”
\p 
\v 25 Ndɛre maá utɔɔ́ yimbɔ, ajwɔle agií kwɔ́kwɔ́lé ne uwyaá Jisɔs, akɔ gemɛ agií Jisɔs aké, “Ata waá achyɛge nyɛ wɔ maŋkwaá?”
\p 
\v 26 Jisɔs ashuú ji meko aké, “ɛle muú ayi me nyuale brɛd yina né mmu akpáŋkpa nchyɛge ji. Jisɔs ajɔge mbɔ abɔ gekpɔge brɛd, anyuá né mmu akpáŋkpa achyɛ Judas Iscarot, maá Simun.”
\v 27 Tɛnétɛné ayi Judas asɛle gekpɔge brɛd ɛyigémbɔ, danchɔmeló anyú ji metɔɔ́. Ne Jisɔs ajɔɔ́ ne Judas aké, “Genó ɛyigé wɔ ɔkɛlege mampyɛ, pyɛ geji wáwá.”
\v 28 Né geluage bɔɔ́ abi ajwɔle agií né ɛkpokpogele, yɛ muú ama ayi akaá ulaá mejɔɔ́ ɛwé Jisɔs ajɔɔ́ mbɔ ne Judas apɔ.
\v 29 Ne ɛlé Judas ne ábélege mekwa ŋka bwɔ́. Baá utɔɔ́ abifɔ áfere nnó Jisɔs ajɔɔ́ mbɔ lé nnó Judas ajyɛ ána unó ɛbifɔ ɛbi ɛbwɔ́ ákɛlege. Ɛla ɛpɔ mbɔ wɔ́, ndɔfɔ Jisɔs ajɔɔ́ mbɔ lé nnó Judas ajyɛ achyɛ genó gefɔ mbaá ubya bɔɔ́.
\p 
\v 30 Ne Judas asɛge gekpɔge brɛd ɛyigé Jisɔs achyɛ ji, atane afɛ́. Gébé ɛyigémbɔ utuú ugi mɛ.
\s1 Ɛbɛ mekɛ
\p 
\v 31 Judas atanege ajyɛge, Jisɔs aké, “Nana bɔɔ́ agɛne nyɛ ndɛre Maá Ntɛ Mekwaá apwɔɔ́ amu. Ne ji apyɛ nyɛ bɔɔ́ agɛ ndɛre Ɛsɔwɔ apwɔɔ́ amu.
\v 32 Ne mbɔgé Maá Ntɛ Mekwaá apyɛɛ́ bɔɔ́ agɛ ndɛre Ɛsɔwɔ apwɔ amu, Ɛsɔwɔ ntó apyɛɛ́ nyɛ bɔɔ́ ágɛ́ ndɛre Maá Ntɛ Mekwaá apwɔɔ́ amu, ne achɔɔ́ sé gébé.
\v 33 Baá ba, me mbɛlege sé ne ɛnyú dɔɔ́, ɛnyú dékɛlege nyɛ me, ne wyɛ ndɛre me mbɔ ngare ákpakpa bɔɔ́ Jus, mbɔntó ne ngarege ɛnyú nana nnó, ‘Mbaá ayi me njyɛ ɛnyú dékage chwɔ́ fɔ́ wyɛɛ́.’
\v 34 Ajɔ́gé mbɔ, aké, nana nchyɛge ɛnyú ɛbɛ ɛwé mekɛ́, “Bɔɔ́gé gejeé ne atɛ. Ndɛre me ngboó ne ɛnyú mbɔntó ne ɛnyú debɔɔ́ mangboge ne atɛ.
\v 35 Ne mbɔgé deké débɔɔ́ gejeé ne atɛ, yɛ́ndémuú ákáge nyɛ nnó ɛnyú délú baá utɔɔ́ ba.”
\s1 Jisɔs agaré ndɛre Pita áshyáa nyɛ ji
\r (Mat 26:31-35; Mak 14:27-31; Luk 22:31-34)
\p 
\v 36 Ne Simun Pita agií ji aké, “Ata, wɔ ɔjyɛ ɛfɔ?”
\p Jisɔs aké, “Mbaá ayi me njyɛ ɔkágé kwɔle me nana, yɛ́mbɔ ɔkwɔlege nyɛ me meso gébé.”
\p 
\v 37 Pita agií ji aké, “Ata ulannó ne me nla nkágé kwɔle fɔ́ wɔ nana? Me nkpome mmyɛ mangbó gétú jyɛɛ́.”
\p 
\v 38 Ne Jisɔs ashuú Pita meko aké, “Pita nnó ɔkpome mmyɛ magbo gétú ya? Gɔ me ngare wɔ wáwálé nnó gemɛ nnó menɔ mekwɔ akú, wɔ ɔshyaá nyɛ máŋáne alɛɛ́ nnó wɔ ɔ́kágé me.”
\c 14
\s1 Jisɔs ne alɛrege meti ɛwé ɛjyɛɛ́ mbaá ntɛ wuú
\p 
\v 1 “Dekamege fɔ́ mesome ɛbɛ ɛnyú né metɔɔ́. Fyɛgé metɔɔ́ ne Ɛsɔwɔ, fyɛgé ntó metɔɔ́ ne me.
\v 2 Baá upú alú gejame né gepúge Ntɛ wa; mbɔgé abɛ dampɔ mbɔ, mbɔ me ngare fɔ́ ɛnyú mbɔ wɔ́. Me njyɛ kwyɛɛ́ melú mbele ɛnyú.
\v 3 Nnerege mankwyɛɛ́ melú ɛwémbɔ, nkerege, nchwɔ́ nsɛ ɛnyú nnó mbaá ayi me mbɛɛ́ ɛnyú ntó débɛ wyɛɛ́.
\v 4 Ɛnyú dékaá meti ɛwé ɛjyɛɛ́ né mbaá yi me njyɛɛ́.”
\p 
\v 5 Ne Tɔmasi ajɔɔ́ ne Jisɔs aké, “Ata ɛse dékaá yɛ́ mbaá yi wɔ ɔjyɛɛ́ wɔ́, ɛpyɛmbɔ nnó ne dékaá meti ɛwé ɛjyɛ wyɛɛ́?”
\p 
\v 6 Jisɔs ashuú ji meko aké, “Me ne nlú meti ɛwú. Me ne ngarege bɔɔ́ wáwálé. Ne me ne nchyɛgé geŋwá. Yɛ́ muú fɔ ákágé chwɔ́ fɔ mbaá Ntɛ wa mbɔgé álá akoó ɛta wa wɔ.
\v 7 Mbɔgé ɛnyú débɔ dékaá me cháŋéné, mbɔ debɔ dékaá ntó ntɛ wa. Manlɔ́ nana déjyɛgé mbɛ, dékaá mɛ ji ne degɛ mɛ ji.”
\p 
\v 8 Ne Filip aké, “Ata lɛre ɛsé Ntɛ wyɛ awu, nnó matɔɔ́ akwene ɛse mmu.”
\p 
\v 9 Jisɔs ashuú ji meko aké, “Mbɔ tɛ me nlú mbɔ fana ne ɛnyú, delú daŋkaá me Filip? Yɛ́ndémuú yi agɛne me, ɛbyɛnnó agɛ ntó Ntɛ wa. Waá ulannó wɔ ɔké me nlɛre ɛnyú Ntɛ wa?
\v 10 Ɛnyú dékame fɔ́ nnó me ncho mmyɛ ne Ntɛ, ne Ntɛ wa ntó acho mmyɛ ne me wɔ? Depɔ ɛtire me njɔ́gé mbɔ, detanege fɔ́ me mbɔɔ́ né metɔɔ́, ɛlé Ntɛ wa mmu áchomé mmyɛ ne me ne apyɛɛ́ utɔɔ́ bií.
\v 11 Kamege ne me nnó genó ɛyigé me ngarege ɛnyú gelú wáwálé nnó me ncho mmyɛ ne Ntɛ wa ne Ntɛ wa ntó acho mmyɛ ne me. Ne mbɔgé ɛwéna ɛla ɛkwane ɛnyú metɔɔ́ wɔ, kamege nnó ɛlú wáwálé gétúgé ufélekpa ɛbi me mpyɛɛ́.
\v 12 Me ngarege ɛnyú wáwálé nnó, yɛ́ndémuú ayi áfyɛɛ́ metɔɔ́ ne me, apyɛɛ́ ntó unó bi me mpyɛɛ́ mbɔ. Yɛ́ ɛbɛ lé ɛbi uŋea upwɔ ɛbi, apyɛ nyɛ néndé me njyɛ́ mbaá Ntɛ wa.
\v 13 Ne yɛ́ndégenó ɛyigé ɛnyú dégigé né mabɔ ma, mpyɛ geji nnó metɔɔ́ ɛgɔ Ntɛ wa gétú ya.
\v 14 Ndɛre ɛlúmbɔ, mbɔgé dégige yɛ́ndégenó né mabɔ ma, mpyɛɛ́ geji.
\s1 Jisɔs anyɛ́meno mantɔ Mendoó Ukpea
\p 
\v 15 “Mbɔgé ɛnyú dégbóo ne me, belege mabɛ ya.
\v 16 Dépyɛge mbɔ, me nnɛne nyɛ mmyɛ mbaá Ntɛ wa, ne ji atɔme nyɛ ɛnyú muú majyɛɛ́ ayifɔ, ayi abɛ nyɛ ne ɛnyú tɛ kwyakwya.
\v 17 Muú majyɛ yimbɔ ɛlé Mendoó Ukpea muú alɛrege ɛnyú wáwálé ayi Ɛsɔwɔ. Bɔɔ́ mme akamege fɔ ne ji néndé agɛne fɔ́ ji ne akage ji. Yɛ́mbɔ ɛnyú dékage ji, néndé ji ajwɔlege ne ɛnyú ne alú ɛnyú né mmyɛ.
\v 18 Njyɛge, nlyage fɔ ɛnyú gelame, nmáge kere nchwɔ ɛta nyú.
\v 19 Ɛla gachyɛɛ́ bɔɔ́ mme amage gɛ sé me. Ɛnyú ne dégɛne nyɛ me. Ne tɛ ndɛre me nwyaá geŋwá, ɛnyú ntó debɛɛ́ nyɛ ne geŋwá.
\v 20 Bií bimbɔ ukwɔnege, ɛnyú dékage nyɛ nnó mencho mmyɛ ne Ntɛ, Ntɛ wa acho mmyɛ ne me, ne me ntó ncho mmyɛ ne ɛnyú.
\v 21 Yɛ́ndémuú ayi awúgé mabɛ ya abelégé áji, ji yimbɔ ne abɔɔ́ gejeé ne me, Ntɛ wa ntó abɔɔ́ gejeé ne ji. Me ntó mbɔɔ́ nyɛ gejeé ne ji, ne me mbɔɔ́ nlɛrege nyɛ gemɛ ya ɛtaá wuú.”
\p 
\v 22 Ne Judas (ayi álá pɔ́ fɔ́ Judas Iscarot) ajɔɔ́ ne Jisɔs aké, “Ata nde gepyɛɛ wɔ ɔlɛrege gemɛ jyɛ lé ɛta sé, ayi ɔla ɔlɛrege fɔ́ ntó mbaá bɔɔ́ mme meko?”
\p 
\v 23 Jisɔs ashuú ji meko aké, “Muú ayi abɔɔ́ gejeé ne me, apyɛ geno ɛyigé me ngarege, Ntɛ wa gboó nyɛ ne ji. Ne ɛsé ne Ntɛ wa déchwɔ bane nyɛ ji déjwɔlé ne ji mbaá ama.
\v 24 Muú yi álá agboó ne me, apyɛ fɔ geno ɛyigé me ngarege. Ne unó bi ɛnyú déwuú mbɔ utane fɔ membɔɔ́ né metɔɔ́ wɔ, utane lé mbaá ntɛ wa muú atɔme me.
\p 
\v 25 “Me ngare mbɔ ɛnyú unó bina nana yi me nlú ne ɛnyú.
\v 26 Yɛ́mbɔ Ntɛ wa atɔme nyɛ Menchyɛɛ́ majyɛɛ́ né mabɔ ma. Menchyɛɛ́ majyɛɛ́ yimbɔ ɛlé Mendoó Ukpea achwɔgé alɛrege nyɛ ɛnyú unó uko ne ateé nyɛ ɛnyú yɛ́ndégenó ɛyigé me ngare ɛnyú.
\p 
\v 27 “Ndɛre me njyɛ nchyɛge ɛnyú nesɔ, ne nesɔ na ne me nchyɛge ɛnyú. Me nchyɛge fɔ́ ɛnyú nesɔ na nkane bɔɔ́ mme achyɛge genó. Dekamégé fɔ matɔɔ achyɛge ɛnyú ɛfwyale, ne debɛge fɔ́ ntó ne ɛfɔ.
\v 28 Ɛnyú dewú nkane me nké, ‘Me nlyage ɛnyú. Yɛ́mbɔ nmage kere nyɛ nchwɔ ɛta nyú.’ Ɛbɛge nnó ɛnyú débɔɔ́ gejeé ne me, mbɔ́ débɛɛ́ ne metɔɔ́ megɔ́mégɔ́ ɛlé me njyɛɛ́ mbaá Ntɛ wa muú aŋea gemɛ apwɔɔ́ me.
\v 29 Me mbɔ́ mɛ mbɛ ngare ɛnyú unó bina gemɛge nnó ubi upyɛge, nnó meso gébé, upyɛge ɛnyú dekame nnó unó bi me njɔɔ́ úlú wáwálé.
\v 30 Me mpɔ sé ne gejamégé gébé manjɔɔ́ mejɔɔ́ ne ɛnyú néndé mfwa bɔɔ́ mme alé chwɔ. Ji apɔ́ fɔ́ ne ɛshyɛ apwɔ me.
\v 31 Yɛ́mbɔ me mpyɛɛ́ lé genó ɛyigé Ntɛ wa agare me nnó mpyɛ, nnó bɔɔ́ mme akaá nnó me mbɔɔ́ gejeé ne Ntɛ wa.
\p “Kwilege mme déjyɛgé.”
\c 15
\s1 Genɔge umpome ne mata jií
\p 
\v 1 “Me ne nlú genɔge vin geji ambɔɔ́, ne Ntɛ wa ne alú muú ayi áchɛ́rege geji. \f + \fr 15:1 \ft Ɛlú wáwálé nnó: Né ukwene ŋwɛ menomenyɛɛ́, Ɛsɔwɔ abɔ́ amɛge bɔɔ́ Isrɛli nkane mekɔɔ́ vin ɛwé ji áchɛ́rege. Jisɔs jimbɔɔ́ ntó ájɔɔ́ nnó ji ne alu genɔɔ́ge vin yimbɔ nana.\f*
\v 2 Yɛ́ndé ɛta ɛwé ɛtome ne me, mbɔgé ɛlá ɛwɔme fɔ́ umpome, ji asɔɔ́ ɛwuú afɔme mme, ne yɛ́ndé ɛta ɛwé ɛwɔme umpome, ji akwyɛge ɛwú nnó ɛwɔme gejamégé umpome.
\v 3 Mekomejɔɔ́ ayi me ngare ɛnyú apyɛ ɛnyú dela mɛ pópó ɛké ɛta genɔɔ́ ɛyigé akwyɛɛ́.
\v 4 Chogé wyɛ mmyɛ ne me, me nchome mmyɛ ne ɛnyú. Ɛta genɔɔ́ ɛ́kágé wɔ fɔ́ umpome mbɔgé ɛlá cho mmyɛ ne mbyɔ genɔɔ́ geji mbɔɔ́ wɔ́. Wyɛmbɔ ntó ne ɛnyú déla dekágé pyɛ genó gefɔ mbɔgé dela decho mmyɛ ne me wɔ́.
\p 
\v 5 “Me ne nlú genɔɔ́ ɛyigémbɔ, ɛnyú ntó ne delú mata jií. Muú achogé mmyɛ ne me, ne me ntó nchoge mmyɛ ne ji, ji ne apyɛ nyɛ gejamégé unó néndé me nla mpɔ ɛnyú dékage pyɛ fɔ yɛ́ genó.
\v 6 Ne muú álá cho mmyɛ ne me wɔ, alú ɛké ɛta genɔɔ́ ɛwé ásɔgé afomege ɛ́wáŋese ɛgbo. Ufɔɔ́ mata unɔɔ́ yina anywerege áji áfyɛ né mewɛ, ásɔ.
\v 7 Mbɔgé ɛnyú déchogé wyɛ mmyɛ ne me, ne deké débelege mekomejɔɔ́ wa né matɔɔ́ nyú, yɛ́ndégenó ɛyi ɛnyú degige nno Ntɛ wa apyɛ, geji ne ji apyɛ́ ɛta nyu.
\v 8 Ɛnyú deké dépyɛ gejamégé unó ulɔúlɔ́ Ntɛ wa abɛɛ́ ne ŋgɔ. Ne ɛwéna ɛlɛrege nnó ɛnyú delu baá utɔɔ́ ba.
\v 9 Ndɛre Ntɛ wa abɔɔ́ gejeé ne me, mbɔntó ne me mbɔɔ́ gejeé ne ɛnyú. Bɔgé wyɛ gejeé ne atɛ wyɛ ndɛre me mbɔɔ́ ne ɛnyú.
\v 10 Mbɔgé ɛnyú deké depyɛ genó ɛyige me njɔɔ́, me mbɔɔ́ nyɛ gejeé ne ɛnyú wyɛ ndɛre Ntɛ wa abɔɔ́ gejeé ne me gétúgé mpyɛɛ́ genó ɛyigé ji akɛlege.
\v 11 Me ngaré ɛnyú unó bina nnó ɛnyú débɛ ne metɔɔ́ megɔmegɔ wyɛ ndɛre me nwyaá. Ne nnó metɔɔ́ megɔmegɔ nyú ɛja ɛpwɔ amu.
\v 12 Gɛgé genó ɛyigé me nkɛlege nnó ɛnyú dépyɛge na: Bɔgé gejeé ne atɛ wyɛ ndɛre me mbɔɔ́ ne ɛnyú.
\v 13 Gejeé ɛyigé cha gepɔ, ɛyigé muú alɛrege, ɛyi gepwɔɔ́ gejeé ɛyigé muú ágbóo gétúgé ajeé bií.
\v 14 Ɛnyú débɛɛ́ ajeé ba mbɔgé dépyɛ unó bi me ngaré ɛnyú.
\v 15 Me mmagé kú se ɛnyú nnó baá défwɛ néndé maá défwɛ ákágé fɔ́ genó ɛyigé ntɛ wuú apyɛɛ́. Me nkuú ɛnyú ajeé ba néndé yɛ́ndégenó ɛyigé Ntɛ wa agare me, geji ne me nto ngare ɛnyú.
\v 16 Ɛnyú fɔ́ wɔ déjyaá me wɔ, ɛlé me ne njyaá ɛnyú ne ntɔme ɛnyú nnó dépyɛgé unó ulɔ́úlɔ́ ne nnó unó bimbɔ ubɛɛ́ tɛ kwyakwya. Ne yɛ́ndégenó ɛyi ɛnyú dégige Ntɛ wa né mabɔ ma achyɛge ɛnyú geji.
\v 17 Gɛge yɛ mma ngare ɛnyú nnó bɔge gejeé ne atɛ.
\s1 Bɔɔ́ mme ápaá baá utɔɔ́ Jisɔs
\p 
\v 18 “Mbɔgé bɔɔ́ mme apaá ɛnyú, kaáge nnó abɔ mɛ mbɛ apa mɛ me ne alé pa ɛnyú.
\v 19 Ɛnyú debɔ débɛ́ bɔɔ́ mme, mbɔ bɔɔ́ mme agboó ne ɛnyú ɛké atɛ bɔɔ́ mme. Ne ɛnyú depɔ néndé me njya ɛnyú né geluage bɔɔ́ mme, getu ɛyigémbɔ ne bɔɔ́ mme apaá ɛnyú.
\v 20 Tege genó ɛyigé me ngare ɛnyú nnó, ‘Maá défwɛ aŋeage fɔ́ gemɛ apwɔ ntɛ wuú.’ Tɛ ndɛre ɛbwɔ́ achyɛ me ɛfwyale, áchyɛge nyɛ ntó ɛnyú ɛfwyale. Ne ɛbwɔ́ abɔ awú mekomejɔɔ́ wa mbɔ áwuú ntó awe nyú.
\v 21 Ɛbwɔ́ apyɛ nyɛ unó bina uko ɛta nyú gétúgé ɛnyú délu bɔɔ́ ba. Néndé ɛbwɔ́ ákágé fɔ́ muú yi atɔme me.
\v 22 Me mbɛ danchwɔ́ gare ɛbwɔ́ mekomejɔɔ́, mbɔ akwe fɔ mpa wɔ́, yɛ́mbɔ nana yi ngare ɛbwɔ mekomejɔɔ Ɛsɔwɔ, yɛ meti ɛwe áboó gabo bwɔ́ ɛpɔ́sé
\v 23 Ne yɛ́ndémuú yi apaá me, ɛbyɛnnó apaá ntó Ntɛ wa.
\v 24 Me mbɛ dampyɛ ukpɛkpɛ unó né metɔɔ́ metɔɔ́ bwɔ́, ɛbwɔ́ agɛ wɔ́, ɛbi yɛ́ muú fɔ́ álá alú dampyɛ, mbɔ Ɛsɔwɔ agarege nyɛ fɔ́ ɛbwɔ́ nnó ápyɛ gabo ákwe mpa. Yɛ́ ndɛre ɛbwɔ́ ágɛne unó bi me mpyɛ, ápaá me chonchó ne Ntɛ wa.
\v 25 Unó bina ubɔ mampyɛ nnó, genó ɛyigé asame né mmu ŋwɛ Ɛsɔwɔ gebɛ wáwálé. Ása wyɛ nnó, ‘Ɛbwɔ́ ápaá me ula pɔ́.’
\p 
\v 26 “Menchyɛɛ́ majyɛɛ́ achwɔɔ́, ji alú Mendoó Ukpea muú alɛrege wáwálé yi Ɛsɔwɔ. Me ntɔme nyɛ ji atane mbaá Ntɛ wa, achwɔgé agarege nyɛ ɛnyú muú yi me nlú.
\v 27 Ɛnyú ntó dégarege nyɛ bɔɔ́ muú yi me nlú néndé delu ne me tɛ ula ulɔɔ́.
\c 16
\p 
\v 1 “Me ngare mɛ ɛnyú unó bina nnó ɛ́kágé deja mmyɛ meso.
\v 2 Ábuú nyɛ ɛnyú né macha mmyɛmenɛne. Ne gébé gechwɔɔ́ ɛyigé yɛ́ndémuú yi awáne ɛnyú afɛrege nnó ji apyɛmbɔ ɛlé utɔɔ́ Ɛsɔwɔ.
\v 3 Ápyɛ nyɛ unó bina ne ɛnyú néndé ákágé Ntɛ wa, yɛ́ me ntó ákágé.
\v 4 Me mbɔ mbɛ ngare ɛnyú nnó gébé ɛyigémbɔ gekwɔnége ɛnyú détege nnó me mbɔ ngare mɛ ɛnyú nnó unó bina upyɛɛ́ nyɛ.
\s1 Utɔɔ́ bi Mendoó Ukpea ɛpyɛɛ́
\p “Me mbɔ́ ngare ɛnyú unó bina mbɛmbɛ wɔ́, néndé me mbɔ nlú ne ɛnyú.
\v 5 Ne nana me nkerege meso mbaá muú yi atɔme me, yɛ́mbɔ yɛ́ muú nyú yi agige mme nnó, “Ɔjyɛ ɛfɔ́?” Apɔ.
\v 6 Ne gétúgé me ngare ɛnyú unó bina, matɔɔ́ nyú álá meshwɛmeshwɛ.
\v 7 Yɛ́mbɔ ngarege ɛnyú wáwálé. Ɛlú ɛlé né galɔ́gálɔ́ awe nyú nnó me njyɛ, néndé me nla njyɛ wɔ́ menchyɛɛ́ majyɛɛ́ achwɔɔ́ fɔ́ ɛta nyú. Yɛ́mbɔ me njyɛge ntɔme nyɛ ji achwɔ ɛta nyú.
\v 8 Achwɔgé apyɛɛ́ nyɛ bɔɔ́ mme akaá nnó ufɛre bwɔ́ né gabo ayi ɛbwɔ́ apyɛɛ́ úlú gyɛ. Apyɛ nyɛ ɛbwɔ́ akaá nnó ufɛre bwɔ́ né ndɛre muú abɛɛ́ cho né mbɛ ushu Ɛsɔwɔ úlú gyɛɛ́, ne apyɛ nyɛ ntó ɛbwɔ́ akaá nnó ufɛ́ré bwɔ́ né ndɛre Ɛsɔwɔ ásɔɔ́ nyɛ mpa úlú gyɛɛ́.
\v 9 Né ɛgbɛ ɛwé gabo, ɛbwɔ́ alú gyɛɛ́ néndé áfyɛɛ́ fɔ́ metɔɔ́ ne me wɔ́.
\v 10 Né ɛgbɛ ɛwé mambɛ cho né mbɛ ushu Ɛsɔwɔ, apyɛ nyɛ ɛbwɔ́ akaá nnó me nlú cho néndé me nkerege meso mbaá Ntɛ wa ne ɛnyú demage gɛ nyɛ se me.
\v 11 Né ɛgbɛ ɛwé mpa ayi Ɛsɔwɔ ásɔɔ́, apyɛ nyɛ bɔɔ́ mme akaá nnó alu gyɛɛ́ né gefɔɔ́ ɛyigé ásɔɔ́ mpa wa, néndé danchɔmeló mfwa bɔɔ́ mme akwe mɛ mpa.
\p 
\v 12 “Me nlú wyaá gejamégé unó mangare ɛnyú, yɛ́mbɔ ɛnyú dékage gbare nyɛ fɔ matɔɔ́ gétúgé ubi.
\v 13 Yɛ́mbɔ gébégé Mendoó Ukpea muú alɛrege wáwálé achwɔge, apyɛ nyɛ ɛnyú dékaá wáwálé meko. Agarege nyɛ fɔ́ unó bi utanege ji metɔɔ́, genó ɛyigé ji awúgé geji ne ji ágarege. Ne apyɛɛ́ nyɛ ɛnyú dékaá unó bi upyɛɛ́ nyɛ meso gébé.
\v 14 Ji apyɛ́ nyɛ me mbɔ ŋgɔ néndé genó ɛyi getanege me metɔɔ́ geji ne ji asɛle agarege ɛnyú.
\v 15 Yɛ́ndé genó ɛyigé Ntɛ wa awyaá ɛlé ɛya, getú ɛyigémbɔ ne me nké genó ɛyi gelú me metɔɔ́ geji ne ji agarege nyɛ ɛnyú.
\s1 Mesome nyu ɛla nyɛ lé nechɔ́chɔ́
\p 
\v 16 “Ɛlá gachyɛɛ́ ɛnyú demage gɛ sé me, ne ɛmage wyaá sé ntó ndɔɔ́ ɛnyú degɛne nyɛ me.”
\p 
\v 17 Ajɔ́gé mbɔ, baá utɔɔ́ bií abifɔ alɔ mangigé atɛ aké, “Ajɔɔ́ aké, ‘Ɛla gachyɛ ɛnyú degɛne sé me,’ ne ama aké, ‘Ɛmage wyaá se ntó dɔɔ́ ɛnyú dégɛne nyɛ me’, ula utɛne mbɔ nno? ne ulaa me njyɛ mbaá ntɛ wa.
\v 18 Ulaá ɛla gachyɛɛ́ utɛne mbɔ nnó? Ɛsé dekágé fɔ́ genó ɛyigé ji ajɔ́gé mbɔ.”
\p 
\v 19 Ndɛre ɛbwɔ́ áferege mbɔ, Jisɔs akaá mɛ nnó ɛbwɔ́ akɛlege mangií ji ulaá mejɔɔ́ ɛwé ji ajɔɔ́ mbɔ. Ajɔɔ́ ne ɛbwɔ́ aké, “Ɛnyú degige mbɔ ɛlé atɛ ulaá mejɔɔ́ ɛwé me njɔɔ́ nnó, ‘ɛla gachyɛɛ́ ɛnyú demage gɛ sé me ne nnó ɛmage wyaá sé ntó dɔɔ́ ɛnyú dégɛne nyɛ me?’
\v 20 Me ngarege ɛnyú wáwálé nnó ɛnyú delilí nyɛ desɔɔ́ manse gétúgé unó bi upyɛ nyɛ. Ne bɔɔ́ mme ábɛɛ́ ne nechɔ́chɔ́, Ɛnyú debɛɛ́ ne masome né matɔɔ́, yɛ́mbɔ masome nyú abwɔlege nyɛ nechɔ́chɔ́.
\v 21 Nebyɛɛ́ neke nemmyɛ mendée, unɛ ugyalege ji néndé gébé ɛyigé ji awuú ubale gekwɔne. Ne abyɛgé mɛ maá, amage te se ubale, abɛɛ́ ɛlé ne nechɔ́chɔ́ nnó ji agbɛɛ́ muú ama fa mme.
\v 22 Wyɛmbɔ ntó ne ɛlú ne ɛnyú. Nana ɛnyú delú ne masome né matɔɔ́, yɛ́mbɔ me mmage gɛ nyɛ ɛnyú, ne ɛnyú debɛɛ́ nyɛ ne nechɔ́chɔ́ né matɔɔ́. Ne yɛ́ muú ayi akágé fere gefɔ nechɔ́chɔ́ ɛniné na né matɔɔ́ nyú ápɔ́.
\v 23 Bií bi mbɔ ukwɔnege, demage gii se me yɛ mechɔ fɔ́. Me ngarege ɛnyú wáwálé nnó, yɛ́ndégenó ɛyi degige ntɛ wa né mabɔ ma, achyɛge ɛnyú geji.
\v 24 Kpaá tɛ gébé ɛyigé na, ɛnyú delu dangií yɛ́ genó gefɔ́ né mabɔ ma. Gige achyɛge nyɛ ɛnyú, ne nechɔ́chɔ́ nyú nejame nyɛ kpaá nepwɔ́.
\p 
\v 25 “Me ngare ɛnyú unó bina né makamejɔɔ́, yɛ́mbɔ gébé gechwɔɔ́ nyɛ ɛyigé me nla ngarege sé ɛnyú depɔ né makamejɔɔ́. Me ngarege nyɛ ɛnyú uno bi utome ne Ntɛ wa gbɔgɔnɔ.
\v 26 Gébé ɛyigémbɔ gekwɔnege ɛnyú degige nyɛ Ntɛ wa unó né mabɔ ma. Me njɔɔ́ mbɔ fɔ́ nnó ngige nyɛ Ntɛ wa genó gefɔ gétúgé nyú wɔ́.
\v 27 Néndé Ntɛ wa jimbɔɔ́ abɔ gejeé ne ɛnyú gétúgé ɛnyú debɔɔ́ gejeé ne me, ne dékame nnó me ntane mbaá Ɛsɔwɔ.
\v 28 Wáwálé me ntane mbaá Ntɛ wa nchwɔɔ́ fa mme. Nana me lé nlyaá mme nkerege meso mbaá Ntɛ wa.”
\p 
\v 29 Ajɔ́gé mbɔ, baá utɔɔ́ bií aké, “Nana wɔ ɔlé jɔɔ́ yɛ́ mejɔɔ́ gbɔgɔnɔ, ɔjɔ́gé sé né makamejɔɔ́.
\v 30 Ɛsé dékaá nana nnó wɔ ɔkaá unó uko, wɔ ɔkage yɛ ɛbɛ lé unó bi bɔɔ́ awyaa né metɔɔ mangií wɔ. Ɛwéna ɛpyɛ ɛsé dékamé nnó wɔ ɔtane mbaá Ɛsɔwɔ.”
\p 
\v 31 Ne Jisɔs ashuú ɛbwɔ́ meko aké, “Pɔ́ ɛnyú dékamé ne me, naná?
\v 32 Gébé gechwɔɔ́ nyɛ, ne géfií mɛ ɛyigé ɛnyú ako délaá nyɛ tyátyá, yɛ́ndémuú nyú abɔɔ́ nyɛ meti gepú jií, délyaá membií. Yɛ́mbɔ me mpɔ fɔ́ me mbií, Ntɛ wa alú ne me.
\v 33 Me ngare ɛnyú unó bina nnó ɛnyu delií mmyɛ ne me debɛ ne nesɔ. Bɔɔ́ mme apyɛ nyɛ ɛnyú degɛ ɛfwyale yɛ́mbɔ gbarege matɔɔ́ nyú néndé mmyɛ mɛ mpwɔ bɔɔ́ mme.”
\c 17
\s1 Jisɔs anɛmmyɛ mbaá Ntɛ wuú nno apyɛ ji abɔ ŋgɔ
\p 
\v 1 Jisɔs anerege manjɔɔ́ unó bina, abwɛɛ́ amɛ apɛ né mfaánebuú, anɛmmyɛ aké, “Ntɛ wa gébé gekwɔne pyɛ me maá wyɛɛ́ mbɔ ŋgɔ nnó me ntó mpyɛ wɔ ɔbɛ ne ɛnoge.
\v 2 Wɔ ɔchyɛɛ́ me uto bi upwɔ bɔɔ́ ako nnó me nchyɛɛ́ geŋwá ɛyi gélágé byɛ́ mbaá bɔɔ́ ako abi wɔ ɔchyɛɛ́ me.
\v 3 Geŋwá ɛyi gélágé byɛ́ gelu nnó ɛbwɔ́ akaá ɛlé wɔ mbií muú ɔlu Ɛsɔwɔ ayi wáwálé, ne me Jisɔs Kras muú wɔ ɔtɔme fa mme.
\v 4 Mpyɛ wɔ ɔbɔ ɛnógé fa né mme, gétúge me nɛre mampyɛ utɔɔ́ bi wɔ ɔchyɛɛ́ me nnó mpyɛ.
\v 5 Ntɛ wa, pyɛ me mbɛ ne ɛnóge né mbɛ ushu wyɛ nana, gefɔ́gé ɛnógé ɛwé me mbɔ nwya nya gébégé nlú ne wɔ, gemɛge nnó mme álɔ.
\s1 Jisɔs anɛmmyɛ mbaá ntɛ wuú gétúgé baá utɔɔ́ bií
\p 
\v 6 “Me mpyɛ bɔɔ́ abi wɔɔ jyaá fa mme ɔchyɛɛ́ me akaá wɔ. Ábɔ́ álú bɔɔ́ byɛɛ́, wɔ ɔchyɛɛ́ me ɛbwɔ́ ne ɛbwɔ ábele mekomejɔɔ́ wyɛɛ́.
\v 7 Ne nana ɛbwɔ ákaá nnó ufɔɔ́ unó uko bi wɔ ɔchyɛɛ́ me utane ɛta wyɛ.
\v 8 Ngare ɛbwɔ́ mekomejɔɔ́ ayi wɔ ɔchyɛɛ́ me, ásɛ ji amu apea ne ákaá wáwálé nnó me ntane ɛta wyɛɛ́ ne ákame nnó wɔ ne ɔtɔme me.
\p 
\v 9 “Nnɛnemmyɛ gétúgé ɛbwɔ́. Nnɛne fɔ́ mmyɛ gétúgé bɔɔ́ mme, nnɛne lé gétúgé bɔɔ́ abi wɔ ɔchyɛɛ́ me, néndé álú bɔɔ́ byɛɛ́.
\v 10 Yɛ́ndé genó ɛyi nwyaá ɛlé ɛjyɛɛ́ ne yɛ́ndégenó ɛyi wɔ ɔwyaá, ɛle ɛya. Ne ɛle bɔɔ́ bina ne apyɛɛ́ me mbɔɔ́ ɛnógé.
\v 11 Mbɛɛ́ sé fa mme, yɛ́mbɔ ɛbwɔ́ alú fa mme. Nchwɔɔ́ ɛta wyɛɛ́ Ntɛ wa, Muú Ukpea, nnɛnemmyɛ nnó wɔ ɔbame ɛbwɔ́ né uto mabɔ mmyɛɛ́, ami wɔ ɔchyɛɛ́ me, nnó ɔpyɛ ɛbwɔ́ ábɛ́ muú ama ndɛre ɛsé ne wɔ delu muú ama.
\v 12 Gébégé nlú ne ɛbwɔ́, mbáme ɛbwɔ́ né utó mabɔ ami wɔ ɔchyɛɛ́ me. Mbá ɛbwɔ́ cháŋéné, ne yɛ́ muú bwɔ́ ama anó mme detu wɔ́ ɛkose muú ayi abɔ alú mɛ nnó anome mme detu nnó genó ɛyigé ásame né mekomejɔɔ́ wyɛɛ́ gebɛ wáwálé.
\p 
\v 13 “Ne nana me nlé chwɔɔ́ ɛta wyɛɛ́. Ne njɔ́gé unó bina ndɛre me nlú fa mme, nnó mpyɛ ɛbwɔ́ abɛ ne nechɔ́chɔ́ gbɛne wyɛ ndɛre me nwyaá nechɔ́chɔ́ gbɛne.
\v 14 Me ngare ɛbwɔ́ mekomejɔɔ́ wyɛɛ́ ne bɔɔ́ mme apaá ɛbwɔ́ néndé ɛbwɔ́ ápɔ́fɔ́ mbwa ama ne bɔɔ́ mme wyɛ ndɛre me nlá pɔ́ fɔ́ mbwa ama ne bɔɔ́ mme.
\v 15 Me nnɛne fɔ́ mmyɛ nnó wɔ ɔfere ɛbwɔ́ fa mme. Nnɛne lé nnó wɔ ɔbame ɛbwɔ́ ɛ́kágé ɛbwɔ́ akpɛ né amu muú nchyɛ.
\v 16 Ɛbwɔ́ apɔ́ fɔ́ mbwa ama ne bɔɔ́ mme wyɛ ndɛre me nlá pɔ́ fɔ́ mbwa ama ne bɔɔ́ mme.
\v 17 Pyɛ ɛbwɔ́ áchyɛɛ́ gemɛ́ge bwɔ́ wáwálé ɛta wyɛ. Ne wáwálé yimbɔ ɛlé mekomejɔɔ́ wyɛɛ́.
\v 18 Ndɛre wɔ ɔtɔme me fa né mme, mbɔntó ne me ntɔme ɛbwɔ́.
\v 19 Me nchyɛ gemɛ ya mampyɛ utɔɔ́ byɛɛ́. Me mpyɛ mbɔ gétúgé bwɔ́, nnó ɛbwɔ́ ntó áchyɛɛ́ gemɛ́ge bwɔ́ wáwálé mampyɛ utɔɔ́ byɛɛ́.
\s1 Jisɔs anɛmmyɛ mbaá Ntɛ wuú gétúgé bɔɔ́ abi ámáge fyɛ nyɛ metɔɔ́ ne ji
\p 
\v 20 “Me nnɛne fɔ́ mmyɛ gétúgé baá utɔɔ́ baá bina ɛbwɔ́ bwɔ́, nnɛne ntó gétúgé bɔɔ́ abi áfyɛ nyɛ metɔɔ́ ne me ɛlé áwuú mekomejɔɔ́ wyɛ ayi baá utɔɔ́ ba ágarege nyɛ.
\v 21 Me nnɛnemmyɛ nnó wɔ ɔpyɛ́ ɛbwɔ́ ako abɛ muú ama, wyɛ ndɛre wɔ Ntɛ wa ɔlu muú ama ne me, me ntó nlu muú ama ne wɔ. Pyɛ ɛbwɔ́ abɛ muú ama ne ɛsé nnó, bɔɔ́ mme ákamé nnó wɔ ne ɔtɔme me.
\v 22 Ɛnógé ɛwé wɔ ɔchyɛɛ́ me, ɛwú ntó ne me nchyɛɛ́ ɛbwɔ́. Mpyɛ mbɔ nnó ɛbwɔ́ abɛ muú ama wyɛ ndɛre ɛsé ne wɔ delú muú ama.
\v 23 Me nlu muú ama ne ɛbwɔ́, wɔ ntó ɔlu muú ama ne me. Dépyɛ mbɔ nnó ɛbwɔ́ ntó abɛ muú ama cháŋéné. Ndɛre ɛlúmbɔ bɔɔ́ mme ákágé nyɛ nnó wɔ ne ɔtɔme me, ne ákágé nyɛ ntó nnó wɔ ɔbɔɔ́ gejeé ne ɛbwɔ́ wyɛ ndɛre wɔ ɔbɔɔ́ gejeé ne me.
\p 
\v 24 “Ntɛ wa, nkɛlege ntó nnó bɔɔ́ abi wɔ ɔchyɛɛ́ me, ábɛ ne me né mbaá yi me mbɛɛ́ nyɛ, nnó ágɛ́ ntó ɛnógé wa. Wɔ ɔchyɛɛ́ me ɛnógé ɛwéna gétúgé gejeé ɛyigé wɔ ɔbɔɔ́ ne me gemɛge nnó mme alɔ.
\p 
\v 25 “Ɛh, Ntɛ wa muú ɔlú cho, wáwálé, bɔɔ́ mme ákágé fɔ́ wɔ, yɛ́mbɔ me nkágé wɔ. Ne bɔɔ́ bina, abi wɔ ɔchyɛɛ́ me ákaá ntó nnó wɔ ne ɔtɔme me.
\v 26 Me mpyɛ ɛbwɔ́ ákaá wɔ, ne mpyɛ nyɛ wyɛ ɛbwɔ́ ákágé wɔ yɛ́ndégébé nnó gejeé ɛyigé wɔ ɔbɔɔ́ ne me ɔbɔ ntó ne ɛbwɔ́ ne nnó me mbɛ muú ama ne ɛbwɔ́.”
\c 18
\s1 Ápyɛ Jisɔs
\r (Mat 26:47-56; Mak 14:43-50; Luk 22:47-53)
\p 
\v 1 Jisɔs anerege mmyɛmenɛne, ji ne baá utɔɔ́ bií ályaá melu ɛwémbɔ, achyaá geŋkɔ ɛyigé akuú nnó Kidrɔn ajyɛ kpɛ mmu maá mekɔɔ́ fɔ.
\v 2 Ne Judas muú achyɛge nyɛ Jisɔs maŋkwaá abɔ akaá ntó melu ɛwémbɔ néndé ɛbwɔ́ abɔ áchómege mɛ wyɛ.
\v 3 Ndɛre ɛlúmbɔ, ji asɛ ɛkwɔ bɔɔ́ bee ne ambame ɛcha upɛ Ɛsɔwɔ abi anɔɔ́ baá ámpyɛɛ́ upɛ Ɛsɔwɔ ne Farasi átɔme áchwɔ́ né maá mekɔɔ́ yimbɔ. Gébégé ájyɛɛ́ ákpomé mmyɛ ne unó ummyɛ, alwɛɛ́ desá ne bɔ akpɔgéfo.
\v 4 Ne ɛlé Jisɔs akaá mɛ yɛ́ndégenó ɛyigé ápyɛ nyɛ ne ji, ake mmyɛ afií ɛbwɔ́, agií ɛbwɔ́ aké, “Ɛnyú dékɛlege ndé muú?”
\p 
\v 5 Ashuú ji meko aké, “Dékɛlege Jisɔs muú Nasarɛt.”
\p Ji aké, “Me ne nlu ji.” Judas muú achyɛɛ́ Jisɔs maŋkwaá alú ntó ɛfɛɛ́ tɛné ne ɛbwɔ́.
\v 6 Jisɔs ajɔ́gé ne ɛbwɔ́ nnó, “Me ne nlu ji,” ája mmyɛ meso ákwe mme gbaram.
\v 7 Ne ama agií ɛbwɔ́ aké, “Ɛnyú déke dékɛlege wa?” Áké, “Dékɛlege Jisɔs muú Nasarɛt.”
\p 
\v 8 Aké, “Pɔ́ me ngare ɛnyú nnó me ne nlu ji? Ne mbɔgé nnó ɛlé me ne ɛnyú dékɛlege, lyage bɔɔ́ bina ájyɛ.
\v 9 Ajɔɔ́ mbɔ nnó meko ayi ji abɔ ajɔɔ ábɛ́ wáwálé. Ji abɔ ajɔɔ́ aké, Ntɛ yɛ́ muú ama ayi anome mme detú né geluage bɔɔ́ abi ɔchyɛɛ́ me ápɔ́.”
\p 
\v 10 Ne Simun Pita ajú yɛ́ aparanja ayi ji awyaá, asɔ́ ɛtu ɛwé ɛgbɛ́ ɛbwɔnyɛ ɛwé memfwɛ́ ɛtukpɛ ámpyɛɛ́ upɛ Ɛsɔwɔ. Mabɔ memfwɛ́ yimbɔ makamege Malkɔs.
\v 11 Pita apyɛgé mbɔ, Jisɔs ajɔɔ́ ne ji aké, “Shwɔ́ré aparanja wyɛ yimbɔ né mmu mekɔ́, wɔ ɔkɛlege fɔ́ nnó me ngɛ ɛfwyale ndɛre ntɛ wa ake ngɛ?”
\s1 Áfɛ́ ne Jisɔs mbaá Anas
\p 
\v 12 Ndɛre ɛlúmbɔ, muú kpaá bɔɔ́ bee ne bɔɔ́ bee bií chonchó ne ambame ɛcha upɛ Ɛsɔwɔ apyɛ Jisɔs awɛ ji amu.
\v 13 Asɛ ji ábɔ́ mbɛ afɛ né mbaá Anas ntɛ Mendée Kaifas. Kaifas yina ne alú ɛtúkpɛ ampyɛ upɛ Ɛsɔwɔ né ŋmɛ ɛniné mbɔ.
\v 14 Ɛlé Kaifas yina ntó ne abɔ achyɛɛ́ nya bɔɔ́ Jus majyɛɛ́ nnó, “Ɛlú galɔ́gálɔ́ nnó muú ama agbo gétúgé bɔɔ́ ako.”
\s1 Pita ashya nnó akaágé fɔ Jisɔs
\r (Mat 26:69-70; Mak 14:66-68; Luk 22:55-57)
\p 
\v 15 Simun Pita ɛbwɔ́ ne maá utɔɔ́ Jisɔs yifɔ ama akwɔle Jisɔs meso. Ɛtukpe ampyɛ upɛ Ɛsɔwɔ akaá maá utɔɔ́ yimbɔ cháŋéné, getu ɛyigémbɔ ályaá maá utɔɔ́ yimbɔ akpɛ ne Jisɔs né mmu dachi ɛtukpe ampyɛɛ́ upɛɛ́ Ɛsɔwɔ,
\v 16 Pita álá né dafyɛ. Ndɛre Pita atɛne né dafyɛ, maá utɔɔ́ ayi ɛtukpe ampyɛ upɛ Ɛsɔwɔ akaá ji, ajyɛ bane mesɔ mendée ayi alú menombi gébame, ajɔɔ́ mejɔɔ́ ne ji ne mesɔ mendée yimbɔ alyaá Pita akpɛ muu.
\v 17 Mesɔ mendée yimbɔ né meno gebame agií Pita aké, “Nnó wɔ ɔpɔ́fɔ́ maá utɔɔ́ ama né geluage baá utɔɔ́ Jisɔs?”
\p Pita ashuú ji meko aké, “Ɛɛh, me mpɔ́.”
\p 
\v 18 Gébé ɛyigémbɔ ntó gefwene gemmyɛɛ́, baá défwɛ ne ambame dachi ɛtukpe ásené mewɛ né dafyɛ átɛne áwyaá. Pita ntó abɔ alú ne ɛbwɔ́ áwyaá mewɛ.
\s1 Jisɔs akpɛ unɔɔ́ mpa
\r (Mat 26:57-66; Mak 14:53-65; Luk 22:54, 55, 63-71)
\p 
\v 19 Ɛtukpɛ ɛgií Jisɔs depɔ ɛtiré détóme ne baá utɔɔ́ bií ne unó bi ji álɛ́rege.
\v 20 Jisɔs ashuú ji meko aké, “Me njɔ́gé mɛ mejɔɔ́ gbɔgɔnɔ mbaá bɔɔ́ ako. Me nlɛrege unó yɛ́ndégébé né mmu macha mmyɛmenɛne ne ɛcha upɛ Ɛsɔwɔ mbaá ayi bɔɔ́ Jus ako áchómege. Yɛ́ genó gefɔ ɛyigé me njɔɔ́ bibí gepɔ́.
\v 21 Ulannó wɔ ɔgigé me bɔ ŋkwɛ bina? Gií ɛlé bɔɔ́ abi awuú genó ɛyigé me ngare ɛbwɔ́, neńdé ákaá uno bi me njɔɔ́.”
\p 
\v 22 Jisɔs ajɔ́gé mbɔ, membame dachi ɛtukpe ayi alu fií ado ji né ushu. Agií ji aké, “Mbɔ ne wɔ ɔbɔɔ́ manshuú ɛtukpe meko?”
\p 
\v 23 Jisɔs ashuú ji meko aké, “Mbɔgé mechɔ ɛwé me njɔɔ́ ɛlú gyɛɛ́, gare gabo ayi me njɔɔ́. Ne mbɔgé ɛlú cho, ulannó wɔ ɔdoó me.”
\v 24 Ɛfɛɛ́ ne Anas atɔme yɛ́ Jisɔs wyɛ amuú wɛwɛ mbaá Kaifas ɛtukpe ampyɛ upɛ Ɛsɔwɔ.
\s1 Pita ama ashya Jisɔs maŋáne ɛpea ne ɛlɛɛ́
\p 
\v 25 Ndɛre ɛpyɛmbɔ, Pita abɔ alú né dafyɛ tɛné awyaá mewɛ. Ágií ji aké, “Nnó wɔ ntó ɔpɔ́ fɔ́ maá utɔɔ́ ama né geluage baá utɔɔ́ Jisɔs?” Pita ashya aké, “Ɛɛh me mpɔ́”.
\p 
\v 26 Maá defwɛ ɛtukpe ampyɛ upɛɛ́ Ɛsɔwɔ ama ayi alú meŋmɛ muú ayi Pita asɔɔ́ ji ɛtu, agií Pita aké, “Nnó me ngɛ fɔ́ wɔ né mmu maá mekɔɔ́ ne mende yimbɔ wɔ́?”
\v 27 Pita ama ashya wyɛ shyá. Wyɛ né gébé ɛyigémbɔ menɔ mekwɔ akú kɔkɔgɔlɔ́kɔɔ́.
\s1 Áfɛ́ ne Jisɔs mbaá Palɛt
\r (Mat 27:1, 2, 11-14; Mak 15:1; Luk 23:1, 2)
\p 
\v 28 Bií ujyagé ne dondo gemua mme ákpakpa bɔɔ́ Jus asɛ yɛ́ Jisɔs né gepúge Kaifas afɛ́ ne ji né ɛcha gɔmena bɔɔ́ Rom. Ɛbwɔ́ ambɔɔ́ akpɛ wyɛ wɔ́. Apyɛ mbɔ nnó ɛ́kágé ɛbwɔ́ ábɛ́ ne deba né mbɛ ushu Ɛsɔwɔ néndé akɛlege manyɛ́ ɛpaá koó upú.
\v 29 Ndɛre ɛlúmbɔ Palɛt muú alú ngɔmena atané, aké ne ɛbwɔ́, “ɛnyú deké mende yina apyɛ nnó?”
\p 
\v 30 Ɛbwɔ́ ashuú ji meko aké, “Mbɔgé mende yina apɔ́ muú mebo fɔ́ wɔ́, mbɔ ɛsé defyɛ fɔ ji né amu jyɛ wɔ.”
\p 
\v 31 Palɛt aké ne ɛbwɔ́, “Sɛge ji ɛnyú ambɔɔ́ depa mpa wuú ndɛre ɛbɛ nyú ɛjɔɔ́.” Ákpakpa bɔɔ́ Jus ashuú ji meko aké, “Ɛbɛ́ nyu bɔɔ́ Rom ɛkamege fɔ nnó ɛsé desɔ́ mpa nnó áwá muú.”
\v 32 Genó ɛyigé ɛbwɔ́ ajɔɔ́ gepyɛ nnó genó ɛyigé Jisɔs abɔ ajɔɔ atome ne gefɔgé negbo ɛniné ji agboó nyɛ getane wáwálé.
\p 
\v 33 Ne Palɛt akere meso né mmu ɛcha, mfwa akú Jisɔs agií ji aké, “Wɔ ne ɔlú mfwa bɔɔ́ Jus?”
\p 
\v 34 Jisɔs aké, “Wɔ mbɔɔ́ ne ɔfere mbɔ, waá nnó bɔɔ́ fɔ ne agare wɔ mmu ayi me nlú?”
\p 
\v 35 Palɛt ashuú ji meko aké, “Me, ɔfɛre nnó me nlú muú Jus? Ɛlé bɔɔ́ byɛ ne anɔɔ́ baá ampyɛ upɛ Ɛsɔwɔ ne afyɛ wɔ́ ne amu ya. Ndé mechɔ wɔ ɔpyɛɛ́?”
\p 
\v 36 Ne Jisɔs ashuú ji meko aké, “Gefwa ya gepɔ fɔ́ ɛyigé bɔɔ́ mme. Mbɔge gebɔ́ gebɛ ɛyigé bɔɔ́ mme, mbɔ baá defwɛ ba ammyɛ nnó ɛ́kágé me nkpɛ né ámu bɔɔ́ Jus, yɛ́mbɔ gefwa ya getane mbaá yicha.”
\p 
\v 37 Ndɛre ji ajɔɔ́ mbɔ Palɛt aké ne ji, “Mmyɛké wɔ ɔlú mfwa?” Ne Jisɔs ashuú ji meko aké, “Wɔ ɔlú cho manjɔɔ́ nnó menlú mfwa. Gɛ ula bi ábyɛné me mbɔ, ne getu ɛyigémbɔ ne nchwɔ́ fa mme nno ngáre bɔɔ wáwálé. Ne yɛ́ndémuú ayi agboó ne wáwálé, awuú mekomejɔɔ́ wa.”
\p 
\v 38 Ne Palɛt agií ji aké, “Wáwálé ɛlé ndé?” Agige mbɔ ama akere meso né dafyɛ, mbaá bɔɔ́ Jus aké, “Me ngɛ fɔ́ gabo ayi mende yina apyɛɛ́ wɔ́.
\v 39 Yɛ́mbɔ gepɔge nyú gelú nno, yɛ́ndé ŋmɛ gébégé ɛpaá koó upu me mbɔ mamferé muú denɔ ama ndɛre ɛnyú dékɛlege. Ndɛre ɛlúmbɔ nnó ɛnyú dékɛlege nnó mferé Mfwa bɔɔ́ Jus?”
\v 40 Palɛt ajɔ́gé mbɔ, ɛbwɔ́ ákalé ne meko metometo, áké, “Ɔferege fɔ́ mende yina fere ɛlé Barabas.” Barabas abɔ alú mmu ayi achyɛge ɛfwyale né melɔ.
\c 19
\s1 Bɔɔ́ bee ájwyagé Jisɔs
\r (Mat 27:27-31; Mak 15:16-20)
\p 
\v 1 Palɛt achyɛɛ Jisɔs nnó, átule ji ne getó.
\v 2 Ne bɔɔ́ bee átɔ ɛla ɛwé ɛlú meshií áfaá Jisɔs né mekpo, áfyɛ ji nkúu megɛ́lé né mmyɛ ɛke mfwa.
\v 3 Ájwyage ji aké, “Geŋwá gétyɛɛ́ getyɛɛ́ gebɛ ne wɔ Mfwa bɔɔ́ Jus” ne ádo ji ukpɛ kpɛ né ushu.
\p 
\v 4 Palɛt ama akere achwɔ́ ajɔɔ́ ne bɔɔ́ bimbɔ aké, “Nana me nchwɔ ne ji né mbɛ ushu nyu yɛ́mbɔ kaáge nnó me ngɛ fɔ́ gabo ayi ji apyɛɛ́ wɔ́.”
\v 5 Jisɔs atane né dafyɛ ne ɛla ɛwé ɛlú meshií meshií né mekpo ne nkúu megɛ́lé né mmyɛ. Ne Palɛt ajɔɔ́ ne bɔɔ́ bimbɔ aké, “Gɛgé mende yimbɔ na.”
\p 
\v 6 Anɔɔ́ baá ampyɛ upɛ Ɛsɔwɔ ne ambame ɛcha upɛ agɛge Jisɔs, alɔ makale ne meko metometo aké, “Áwɔ ji né gekwa, áwɔ ji né gekwa.” Ajɔ́gé mbɔ,
\p Palɛt ajɔɔ́ ne ɛbwɔ́ aké, “Ɛnyú ambɔɔ́ sɛge ji dewɔ né gekwa, néndé me ngɛ fɔ́ gabo ayi ji apyɛɛ́ wɔ́.”
\p 
\v 7 Yɛ́mbɔ bɔɔ́ Jus atome wyɛ ɛshyɛ ajɔ́gé aké, “Ɛsé déwya ɛbɛ ɛwé ɛjɔɔ́ nnó ji abɔ magbo. Néndé ji aké alú Maá Ɛsɔwɔ.”
\p 
\v 8 Palɛt awúgé mechɔ ɛwéna, ɛfɔ ɛkwɔ ji metɔɔ́ dɔɔ́.
\v 9 Akere meso né mmu ɛcha wuú, ama agií Jisɔs aké, “Wɔ ɔtane ɛfɔ?”
\p Yɛ́mbɔ Jisɔs ashuú ji meko wɔ́.
\v 10 Ne Palɛt ajɔɔ́ ne Jisɔs aké, “Wɔ ukɛlege fɔ́ manjɔɔ́ mejɔɔ́ ne me? Wɔ ɔkaá fɔ́ nnó me nwyaá utó manlyaá wɔ ɔjyɛ ne nwyaá uto manwɔ wɔ né gekwa wɔ́?”
\p 
\v 11 Jisɔs ashuú ji meko aké, “Wɔ ɔ́pɔ́fɔ́ ne utó mampyɛ me genó mbɔgé uto bimbɔ ulá utane fɔ́ né mfaánebuú wɔ́. Ne getu ɛyigémbɔ muú ayi afyɛɛ́ me né amu nyú, gabo awuú aŋea apwɔɔ́.”
\v 12 Palɛt awúgé mbɔ, abɔ akɛle meti nnó ályaá Jisɔs ajyɛɛ́ yɛ́mbɔ bɔɔ́ Jus akalege aké, “Mbɔgé wɔ ɔlyage mende yina, ɛbyɛnnó wɔ ɔ́pɔ́ fɔ́ mejeé Sɛsa. Yɛ́ndémuú ayi asɛle gemɛ jií nnó alú mfwa ɛbyɛnnó akɛlege mankare gefwa ne mfwa Sɛsa mfwa Rom.”
\v 13 Ne Palɛt awúgé mejɔɔ́ ɛwéna, asɛ Jisɔs afɛ ne ji né dafyɛ. Jimbɔɔ́ ajwɔlé né geluɔge mpa né mbaá ayi ákuú nnó, “Melu Mataá.” (Né Hibru ákuú mbaá yimbɔ nnó “Gabata”.)
\v 14 Bií bimbɔ úlú ɛlé bií bi bɔɔ́ Jus akpomege mmyɛ manyɛ́ ɛpaá koó upu. Ne metɔɔ́ ŋwɔmese, Palɛt ajɔɔ́ ne ɛbwɔ́ aké, “Gɛ́ge Mfwa nyú na.”
\v 15 Yɛ́mbɔ ɛbwɔ́ ákálé aké cho ne ji ɛwú, cho ne ji ɛwú, awɔ ji né gekwa. Ne Palɛt ama gií ɛbwɔ́ aké, “Dékɛlege me nwɔ́ mfwa nyú né gekwa?” Anɔɔ́ baá ampyɛ upɛ Ɛsɔwɔ, aké, “Ɛsé depɔ sé ne mfwa yicha ɛkosé Sɛsa wɔ́”.
\v 16 Ne kwyakwyaá, Palɛt achyɛɛ yɛ́ Jisɔs né amu bwɔ́ nnó áwɔ́ ji né gekwa. Bɔɔ bee ásɛ́ Jisɔs áfɛ́ ne ji.
\s1 Áwɔ Jisɔs né gekwa
\r (Mat 27:32-44; Mak 15:21-32; Luk 23:26-43)
\p 
\v 17 Jisɔs jimbɔɔ́ ne akpane gekwa jií afɛ́ né melú ɛwé ákuú nnó, “Melú Uŋkɔ́kɔ́ makpo.” (Bɔɔ́ Hibru akuú ntó melu ɛwémbɔ nnó “Golgota.”)
\v 18 Ɛlé né melu ɛwéna ne awɔme Jisɔs né gekwa. Áwɔ ntó anjo makpo apea né ɛbi bwɔ́ ukwa. Áwɔ ama né ɛgbɛ́ ɛbwɔɛbɛ, ama ɛgbɛ́ ɛbwɔnyɛ ne Jisɔs né metɔɔ́ metɔɔ́.
\v 19 Palɛt asá ntó genó gefɔ́ aba né mekpo gekwa ɛyigé áwɔmé Jisɔs. Ásá wyɛɛ́ nnó, “Jisɔs muú Nasarɛt Mfwa bɔɔ́ Jus.”
\v 20 Ne gejamégé bɔɔ́ Jus ájɔ́gé genó ɛyigé ásamé ábalé né mfaá mekpo gekwa néndé mbaá ayi awɔme Jisɔs né gekwa alú kwɔ́kwɔ́lé ne Jɛrosalɛ. Ása mansa ŋwɛ amimbɔ né mekómejɔɔ́ Hibru, Latin ne Grek.
\v 21 Anɔɔ́ bá ampyɛɛ́ upɛ Ɛsɔwɔ, ájɔɔ́ ne Palɛt aké, “Ɔsage fɔ́ nnó Jisɔs alú mfwa bɔɔ́ Jus, sa ɛlé nnó ji ajɔɔ́ aké, ‘Me nlu mfwa bɔɔ́ Jus’.”
\p 
\v 22 Ne Palɛt aké ne ɛbwɔ́, “Genó ɛyigé me nsame, nsa mɛ.”
\p 
\v 23 Bɔɔ́ bee ánerege manwɔ Jisɔs né gekwa abɔ mandée jií akare malu ani yɛ́ndémuú bee asɛ melu ɛma. Ásɛ nto nku wuú ayi ji áfyɛɛ́ ne áfyɛɛ́ ɛwule. Nku yimbɔ apɔ ne nkwɔmé.
\v 24 Bɔɔ́ bee bimbɔ ajɔɔ́ ne atɛ aké, “Dekarege fɔ́ nku yina, déŋmeé lé megyaá wyɛɛ́ mankaá muú ayi asɛlé ji.” Ápyɛ́ mbɔ nnó genó ɛyigé ásame né mekomejɔɔ́ Ɛsɔwɔ gebɛ wáwálé. Ása wyɛ áké, “Ákare mandeé ya áfyɛ atɛ amu, ásɛ nku wa áŋme megyaá wyɛɛ́.” Gɛ́ genó ɛyigé bɔɔ́ bee ápyɛmbɔ.
\p 
\v 25 Ne bɔɔ́ fɔ abi atɛne kwɔ́kwɔ́lé ne gekwa ɛyi awɔme Jisɔs wyɛ, ɛlé mma Jisɔs, meŋmɛ mma Jisɔs ayi mendée, Mɛri mendée Klopas, ne Mɛri Magdala.
\v 26 Jisɔs ágɛgé ndɛre mma wuú átɛne ɛfɛɛ́ kwɔ́kwɔ́lé ne maá utɔɔ́ ayi jimbɔɔ́ Jisɔs agboó ne ji dɔɔ́, ajɔɔ́ ne mma wuú aké, “Mma, gɛ maá wyɛ na.”
\p 
\v 27 Ne ajɔɔ́ ntó ne maá utɔɔ́ yimbɔ aké, “Gɛ mma wyɛ na.” Ɛlɔ né gébé ɛyigémbɔ maá utɔɔ́ yimbɔ asɛ mma Jisɔs afɛ ne ji né gepú jií, nnó ajwɔlege ne ji.
\s1 Negboné Jisɔs
\r (Mat 27:45-56; Mak 15:33-41; Luk 23:44-49)
\p 
\v 28 Ɛwyagé, Jisɔs akaá nnó ji anere mɛ yɛ́ndégenó ɛyigé ji abɔɔ́ mampyɛ, ne nnó genó ɛyigé mekomejɔɔ́ Ɛsɔwɔ ajɔɔ́ gebɛ wáwále, ajɔɔ́ aké, “Mmwɔ́lé manaá ɛpyɛɛ́ me.”
\p 
\v 29 Ɛké ɛpyɛɛ́mbɔ, nkwɔ fɔ́ alú ɛfɛɛ́, ayi áfyɛ mmɔɔ́ amí mamyáme magbeé wyɛɛ. Ásɛ ɛkochá, ányua né mmu mmɔɔ́ amibɔ, áfaá né ɛta maá genɔɔ́ ɛyigé akuú hisɔp, ábwɛɛ́ até Jisɔs né ubɔɔ́ meno. \f + \fr 19:29 \ft Ɛlú wáwálé nnó: Jɔn afyɛ́ genɔ́ge hisɔp né ŋwɛ wuú gétúgé genó ɛyigé apyɛɛ́ ne ji gébégé ɛpaá koo upú.\f*
\v 30 Ne gébégé Jisɔs anyú mmɔɔ́ amimbɔ aké, “Nnere utɔɔ́ ba.” Ajɔ́gé mbɔ, amo mekpo mme, afyɛ gemɛ jií né amu Ntɛ wuú Ɛsɔwɔ.
\p 
\v 31 Bií bimbɔ, ɛle bií ɛbi bɔɔ́ Jus ákpomege mmyɛ manyɛ́ uwyaá bwɔ́. \f + \fr 19:31 \ft Ɛlú wáwálé nnó: Uwyaá bina, úlú lé uwyaá kpaá nénde ukwe gébégé ɛpaá koo upu.\f* Ɛbwɔ́ akɛlege fɔ́ nnó bií bimbɔ ubane uŋkwɔ bɔɔ́ abi awɔme né ukwa. Ajyɛ jɔɔ́ ne Palɛt nnó achyɛɛ́ ɛbwɔ́ uto ájyɛ ákɔre uka bɔɔ́ bimbɔ né mfaá ukwa, áfere uŋkwɔ ɛbwɔ́.
\v 32 Ne bɔɔ́ bee achwɔ́ akɔre uka bɔɔ́ apea abi awɔme ɛbwɔ́ ne Jisɔs.
\v 33 Áchwɔgé mbaá Jisɔs, ákɔre sé uka bií wɔ néndé agɛ nnó ji agbo mɛ.
\v 34 Yɛ́mbɔ muú bee ama ajo ɛgbɛ amba wuú ne nekɔ. Tɛnétɛné yimbɔ manoó ne manaá matanege.
\v 35 Muú yi agɛne unó bina ne agaré. Ne unó bi ji agare úlú wáwálé. Ne jimbɔɔ́ akaá nnó ji agarege wáwálé nnó apyɛ ɛnyú ntó défyɛ metɔɔ́ ne Jisɔs.
\v 36 Unó bina upyɛ nnó genó ɛyigé ásame né mmu ŋwɛ Ɛsɔwɔ ubɛ wáwálé. Ása wyɛ aké, “Yɛ́ gegoó jií gemma akɔɔ́ fɔ́.”
\v 37 Ne ama ása ntó né melu ŋwɛ Ɛsɔwɔ ɛwé fɔ́ aké, “Ápɛle nyɛ muú ayi ɛbwɔ́ ájomé.”
\s1 Anií Jisɔs
\r (Mat 27:57-61; Mak 15:42-47; Luk 23:50-56)
\p 
\v 38 Unó bina upyɛge, Josɛf muú melɔ Arimatya ajyɛ gií ne Palɛt nnó agɔ ji afere geŋkwɔ́gé Jisɔs né gekwa. Josɛf abɔ alú maá utɔɔ́ Jisɔs ama, yɛ́mbɔ akwɔlege ji bibií néndé afɔɔ́ ákpakpa bɔɔ́ Jus. Palɛt akamege, Josɛf ajyɛ fere geŋkwɔ́gé Jisɔs né gekwa afɛ́ ne geji.
\v 39 Josɛf afɛ́ ɛbwɔ́ ne Nikodɛmus muú abɔ́ achwɔ́ gɛ́ Jisɔs ne utuú. Nekodɛmus achwɔ́ ntó ne gejamégé maka gebɛ. Akwyɛɛ́ mami ne unó bi akuú nnó merrh ne alose. Manɔɔ́ genógé bɔ kilo usaá upea meso ɛfya.
\v 40 Ɛbwɔ́ ákpa geŋkwɔ́gé Jisɔs, afyɛge ji unó ɛbimbɔ ne mmyɛ aní ne ɛ́shyɛ́ ndeé. Gɛ́ mbɔ ne bɔɔ́ Jus ákwyɛge geŋkwɔ́gé muú ne anií.
\v 41 Né mbaá yi awɔme Jisɔs né gekwa, maá mekɔɔ́ alú wyɛ. Né mmu maá mekɔɔ́ yimbɔ ntó, menome mekɛ ɛwé álá alú danií muú fɔ ɛbɔ ɛlú wyɛ.
\v 42 Ánií Jisɔs né mmu menome ɛwémbɔ néndé mbaá yimbɔ, alu kwɔ́kwɔ́lé. Ne bií bimbɔ ntó bɔɔ́ Jus ákpomege mmyɛ nnó bií ujyage ɛbwɔ́ ányɛ́ uwyaá bwɔ́.
\c 20
\s1 Menome ɛla mewa
\r (Mat 28:1-10; Mak 16:1-10; Luk 24:1-12)
\p 
\v 1 Bií mbɛ né uwyaá, ne dondo gemua mme Mɛri muú melɔ Magdala afɛ́ né menome ɛwé abɔ́ anií Jisɔs. Ajyɛge, agɛ nnó áferé ntaá ɛniné ábɔ́ ákweré ɛmbú menome.
\v 2 Ndɛre ágɛne mbɔ Meri muú melɔ Magdala abó gatɛlé akere ajyɛ garé Simun Pita ɛbwɔ́ ne maá utɔɔ́ ayifɔ ayi Jisɔs ágboó ne ji dɔɔ́ aké, “Áfere Ata né mmu menome, ne ɛsé dékaá fɔ́ mbaá ayi ájyɛ belé ji wɔ́.”
\p 
\v 3 Ajɔ́gé mbɔ, Pita ɛbwɔ́ ne maá utɔɔ́ yimbɔ átane áfɛ né menome.
\v 4 Ndɛre ájyɛ, álómege gatɛle. Yɛ́mbɔ maá utɔɔ́ yimbɔ alome apwɔ Pita, ne abɔ́ mbɛ akwɔne né menome.
\v 5 Akwɔnege wyɛ, asé mmyɛ mme apɛ né mmu menome, agɛ ubaá ɛ́shyɛ́ ndeé ɛbi ábɔ́ anií Jisɔs ne ubi yɛ́mbɔ, akpɛ fɔ́ né mmu menome wɔ́.
\v 6 Ne Simun Pita muú abɔ alú meso akwɔnege, akpɛ né mmu menome, agɛ ubaá ɛ́shyɛ́ ndeé ɛbimbɔ ɛfɛɛ́.
\v 7 Agɛ́ ntó gebagé ndeé ɛyigé abɔ anií Jisɔs né mekpo ndɛre gelú pwipwi né mbaá awuú cha. Ɛpɔ́fɔ́ mbaá ama ne uba ɛ́shyɛ́ ndeé ɛbimbɔ.
\v 8 Ne maá utɔɔ́ ayi abɔ abɔɔ́ mbɛ akwɔne né menome, akpɛ ntó né mmu menome Jisɔs, agɛ unó bi upyɛ, akame nnó ɛlú wawale.
\v 9 (Yɛ́ ɛlé ɛbwɔ́ ágɛne unó bina, álu wyɛ dankaá genó ɛyi mekomejɔɔ́ Ɛsɔwɔ abɔ ajɔɔ́ nnó Jisɔs abɔ mankwilé né negbo.)
\v 10 Ne baá utɔɔ bií agɛge mbɔ áma akere meso né upú bwɔ́.
\s1 Jisɔs alɛre mmyɛ mbaá Mɛri Magdala
\p 
\v 11 Yɛ́mbɔ Mɛri álá dafyɛ tɛ́né né alilé. Ndɛre alilé abyɛlé mmyɛ mme apɛ́ né mmu menome,
\v 12 agɛ makiɛ́nné Ɛsɔwɔ apea ne mandeé pópó mmyɛ, ájwɔle né mbaá yi abɔ ábelé geŋkwɔ́gé Jisɔs. Ɛma né mekpo, ɛma né uka.
\v 13 Makiɛ́nné yimbɔ, ágií Mɛri áké, “Mma wɔ ɔlilé ndé?”
\p Ashuú ɛbwɔ́ meko aké, “Ákpa Ata wa ne me nkaá fɔ́ mbaá yi ájyɛ bele ji wɔ!”
\v 14 Ajɔ́gé mbɔ, abwɔlé mmyɛ ake apɛle agɛ ndɛre Jisɔs atɛne, yɛ́mbɔ akaá fɔ nnó ɛlé Jisɔs ne atɛne mbɔ wɔ́.
\v 15 Jisɔs agií ji aké, “Mma wɔ ɔlilé ndé? Ndé muú wɔ ɔkɛlege?”
\p Mɛri afɛre nnó ɛlé mbɔɔ́ maá mekɔɔ́ yimbɔ ne ji agɛne mbɔ, ajɔɔ́ ne ji aké, “Ata mbɔgé wɔ ne ɔkpane geŋkwɔ jii lɛre me mbaá ayi wɔ ɔbele geji, me njyɛ mkpa.”
\p 
\v 16 Ajɔ́gé mbɔ, Jisɔs akú ji aké, “Mɛri” abwɔlé mmyɛ apɛ Jisɔs, ajɔɔ́ né mekómejɔɔ́ Hibru aké, “Rabɔni” (ula Rabɔni utɛné nnó “Ménlɛré.”)
\p 
\v 17 Jisɔs ajɔɔ́ ne ji aké, “Ɔtage me, néndé me nlú dankwɔ njyɛ mbaá Ntɛ wa. Cho gare ɛlé aŋmɛ́ ba nnó me nlé nkwɔ njyɛ́ mbaá Ntɛ wa muú alú Ntɛ nyú ntó. Ɛsɔwɔ wa ne Ɛsɔwɔ nyú ntó.”
\p 
\v 18 Mɛri muú melɔ Magdala ajyɛ gare baá utɔɔ́ Jisɔs aké, “Me ngɛ Ata.” Ne agare ntó ɛbwɔ́ unó bi ji ajɔɔ́ ne ji.
\s1 Jisɔs alɛre mmyɛ mbaá baá utɔɔ́ bií
\r (Mat 28:16-20; Mak 16:14-18; Luk 24:36-49; Aŋg 1:6-8)
\p 
\v 19 Né nkwalé bií mbɛ né uwyaá, baá utɔɔ́ Jisɔs ányweré mbaá ama, ágbɛ mano mbií néndé áfɔɔ́ bɔɔ́ Jus. Ne Jisɔs akpɛ atɛné né metɔɔ́ metɔɔ́ bwɔ́ aké, “Nesɔ nébɛ́ ne ɛnyú.”
\v 20 Ajɔ́gé mbɔ, alɛre ɛbwɔ́ mabɔme upa né amu jií ne ɛgbɛ mmyɛ wuú. Baá utɔɔ́ bií ágɛge ji mbɔ álu ne nechɔchɔ́ ndɛre ágɛné Atá.
\v 21 Jisɔs ama ajɔɔ́ ne ɛbwɔ́ aké, “Nesɔ nebɛ ne ɛnyú, ndɛre Ntɛ wa atɔme me, mbɔntó ne me ntɔme ɛnyú.”
\v 22 Ajɔ́gé mbɔ afɔ ɛbwɔ́ gejulé né mmyɛ aké “Sɛge Mendoó Ukpea.
\v 23 Yɛndemuu ayi ɛnyu dejigente gabo wuu, Ɛsɔwɔ ajigente gabo muu yimbɔ, ne yɛnde muu ayi ɛnyu dela dejinte gabo wuu wɔ, Ɛsɔwɔ nto ajige fɔ nte gabɔ wuu.”
\s1 Jisɔs alɛre mmyɛ mbaá Tɔmasi
\p 
\v 24 Gébégé Jisɔs achwɔ́ lɛre mmyɛ mbaá baá utɔɔ́ bií, ŋgba wuú ama né geluage abi áfyanéápeá ayi akuú ji nnó, Tɔmasi maá gefa abɔ apɔ́.
\v 25 Tɔmasi achwɔgé baá utɔɔ́ abifɔ ágare ji aké, “Ɛse degɛ Ata.”
\p Tɔmasi aké, “Me nla ngɛ́ fɔ mabɔme upaá mpi né maka amu jií me nta ɛnɔ ɛbwɔ wa wyɛ, mma nta nto ɛbwɔ wa né nebɔmé gepa ɛnií nélú ji nɛ́ ɛ́gbɛ́ amba wɔ me nkamege fɔ.”
\p 
\v 26 Ndɔ ɛneé ɛkógé, baá utɔɔ́ Jisɔs ama anywere, né mmu gepú. Ne Tɔmasi alu ne ɛbwɔ́. Ágbɛ́ manombi, ne aké apɛle Jisɔs achwɔ́ tɛne né metɔɔ́ metɔɔ́ bwɔ́ aké, “Nesɔ nebɛ ne ɛnyú.”
\v 27 Ajɔɔ́ ntó ne Tɔmasi aké, “Fyɛ ɛnɔbwɔ wyɛɛ́ fa. Pɛ amu ya. Nyaá ɛbwɔ wyɛɛ́ ɔta ɛgbɛ amba wá. Ɔbɛgé sé ne dembyɔ kamé wyɛ kamege ne me.”
\p 
\v 28 Ne Tɔmasi ashuú ji meko aké, “Ata wa ne Ɛsɔwɔ wa.”
\p 
\v 29 Jisɔs ajɔɔ́ ne ji aké, “Ɛlé wɔ ɔgɛne me, ne ɔkame nnó ɛlé me? Metɔɔ́ megɔmegɔ ɛbɛɛ́ ne bɔɔ́ abi álá agɛ me wɔ, yɛ́mbɔ áfyɛɛ́ matɔɔ́ bwɔ́ ne me!”
\s1 Ula bi asame ŋwɛ yina
\p 
\v 30 Ne Jisɔs apyɛ gejamégé upɔɔ́ ufélekpa né mbɛ ushu baá utɔɔ́ bií ɛbi álá ása fɔ́ ubi né mmu ŋwɛ yina wɔ́.
\v 31 Yɛ́mbɔ ása lé bina nnó upyɛ ɛnyú dékamé nnó Jisɔs ne alú Muú yi Ɛsɔwɔ akweré ji ɛlá gefwa, nnó ji alú Maá Ɛsɔwɔ. Ne nnó dekamege mbɔ debɔɔ́ geŋwá ɛyi gélágé byɛ́ gétúgé mabɔ mií.
\c 21
\s1 Jisɔs alɛre mmyɛ mbaá baá utɔɔ́ bií akeneama
\p 
\v 1 Mboó ndɔ fɔ́ ɛkoge, Jisɔs ama alɛre mmyɛ mbaá baá utɔɔ́ bií né ɛbɛɛ́ mega ɛwé ákuú nnó Tibɛras. Gɛ́ na ne Jisɔs alɛre mmyɛ mbaá baá utɔɔ́ bií.
\v 2 Simun Pita, Tɔmasi maá gefa, Nataniɛl muú melɔ Kana né gebage mewaá Galilií, baá Sɛbɛdee ne baá utɔɔ́ abifɔ makpo apea ábɔ́ álú mbaá ama.
\v 3 Ne Simun Pita ajɔɔ́ ne ɛbwɔ́ aké “Me nkɛlege manjyɛ ntofó.”
\p Ɛbwɔ́ ntó aké, “Ɛse ntó déjyɛ ne wɔ.” Ɛbwɔ́ ako ajyɛ kpɛ mmu ɛkpeé. Né utuú bimbɔ yɛ́ genó ɛbwɔ́ áwa wɔ́.
\v 4 Ndɛre bií ujyage, Jisɔs achwɔ atɛne né mapea ɛbɛɛ mega, baá utɔɔ́ bií agɛge ji akaá fɔ jí wɔ́
\v 5 Jisɔs akú ɛbwɔ́ aké, “Baá ba, déwaá meshuu fɔ wɔ?” Ɛbwɔ́ áshuú ji meko, “Déwa wɔ́.”
\p 
\v 6 Ajɔɔ́ ne ɛbwɔ́ aké, “Ŋmégé ntofo nyú né ɛgbɛ ɛbwɔnyɛ ɛ́kpe, déwane nyɛ meshuú.” Áŋmégé, meshuú ɛyi ɛsɛle, ɛpwɔ ɛbwɔ́ manja afyɛ mmu ɛ́kpe néndé ɛja dɔɔ́.
\p 
\v 7 Ɛpyɛge mbɔ, maá utɔɔ́ ayi Jisɔs abɔɔ́ gejeé ne ji dɔɔ́, ajɔɔ́ ne Pita aké, “Muú ayi ajɔ́gé mbɔ ne ɛsé ɛlé Ata.” Simun Pita awúge ndɛre maa utɔɔ yimbɔ ajɔɔ ake “Muú ayi ajɔɔ mbɔ mejɔɔ ne ɛse ɛle Ata” Akwyɛ afyɛ mandeé mmyɛ (néndé abɔ afere áji) Anyo achɔ né nnyi.
\v 8 Baá utɔɔ́ abifɔ álá né mmu ɛkpeé ajame dansa ne gejamégé meshuú ɛyi ɛlú wyɛ nnó achwɔ́ né mapea nnyi. Mantane né mapea nnyi ɔkwɔne mbaá ayi ɛbwɔ́ ajame dansa alú genógé matyɛɛ́ amu usaá upea meso ɛfya.
\v 9 Ájágé dansa yimbɔ akwɔnege né mapea nnyi, agɛ ujenjeé mewɛ ne brɛd wyɛ nɛre.
\v 10 Jisɔs ajɔɔ́ ne ɛbwɔ́ aké, “Chwɔge me ne meshuú fɔ́ ɛyi ɛnyú déwane mbɔ.”
\p 
\v 11 Simun Pita akwɔ akpɛ mmu ɛkpeé aja dansa yɛ́mbɔ achwɔ́ ne ji né mewaá. Dansa yimbɔ agbeé ne gejamégé meshuú kpakpa. Meshuú ɛlú usaá ukenéama meso ɛfyane ɛlɛɛ́ (153). Ne yɛ́ ɛlé meshuú ɛjame, dansa yimbɔ agyalé wɔ́.
\v 12 Ne Jisɔs ajɔɔ́ ne ɛbwɔ́ aké, “Chwɔge dégbáré unɛ dondo”. Ne yɛ́ maá utɔɔ́ ama ayi aŋea metɔɔ́ mangií ji nnó, “Ɔlu wa?” apɔ́; néndé ɛbwɔ́ ákaá nnó ɛlé Ata.
\v 13 Jisɔs ajyɛ bɔ brɛd yimbɔ ne meshuu ntó achyɛɛ́ ɛbwɔ́.
\p 
\v 14 Gɛ́ maŋáne alɛɛ́ na ayi Jisɔs alɛre mmyɛ mbaá baá utɔɔ bií gébégé ji akwilé né negbo.
\s1 Jisɔs ajɔɔ́ ne Pita nnó mbɔgé abɔ gejeé ne ji apyɛ utɔɔ́ bií
\p 
\v 15 Ɛbwɔ́ anerege mangbaré unɛ, Jisɔs agií Simun Pita aké, “Simun, maá Jɔn nnó wɔ ɔbɔ gejeé ne me dɔɔ́, ɔpwɔ abifɔ na?” Ne Pita ashuú Jisɔs meko aké, “Ɛh Ata, wɔ ɔkaá nnó me mbɔ gejeé ne wɔ.”
\p Jisɔs ajɔɔ́ ne ji aké, “Pɛle baá magɔŋme ya.”
\v 16 Jisɔs ama agií ji maŋáne apea aké, “Simun Pita maá Jɔn nnó ɔbɔɔ́ gejeé ne me?”
\p Pita akame aké, “Ɛh Ata wɔ mbɔ ɔkaá nnó mbɔɔ́ gejeé ne wɔ”. Jisɔs aké, “Pɛle magɔŋme ya”.
\v 17 Ama agií Pita ne maŋáne ayi ágbeé alɛɛ́ aké, “Simun maá Jɔn nnó wɔ ɔbɔ gejeé ne me.”
\p Agigé mbɔ, metɔɔ́ ɛsɔ Pita gétúgé agií ji tɛ́ maŋáne alɛɛ nnó, “Pita nnó wɔ ɔbɔ gejeé ne me?” Getu ɛyigémbɔ Pita ashuú ji meko aké, “Ata wɔ ɔkágé unó uko, ɔkaá cháŋéné nnó me mbɔ gejeé ne wɔ.” Jisɔs ajɔɔ́ ne ji aké, “Pɛle magɔŋme ya.”
\v 18 Ngarege wɔ wáwálé nnó, “Gébégé wɔ ɔlu gesage muú, wɔ mbɔɔ́ ɔfyɛ mandeé ɔjyɛɛ́ yɛ́nde mbaá ayi wɔ ɔkɛlege, yɛ́mbɔ gébégé ɔkwɔge ukoó, ula bwyɛ ɛlé amu mfaá ne ɛlé muu yicha ne afyɛɛ́ wɔ mandeé ágbárege wɔ ɛbwɔ aja wɔ meti ɔjyɛɛ mbaá ayi wɔ ɔlá ɔkɛlege fɔ manjyɛ.”
\v 19 Jisɔs ajɔɔ́ mejɔɔ́ ɛwéna ne Pita mampyɛ ji ákaá gefɔge negbo ɛniné Pita agboó nyɛ ne achyɛɛ́ Ɛsɔwɔ ŋgɔ. Jisɔs ajɔ́gé mbɔ aké ne Pita, “Kwɔle me.”
\p 
\v 20 Pita abwɔlége mmyɛ, agɛ ndɛre maá utɔɔ́ ayi Jisɔs abɔɔ́ gejeé ne ji dɔɔ́ akwɔlege ɛbwɔ́. Ɛlé maá utɔɔ́ yina ne abɔ ajwɔlé nya agií Jisɔs né ɛgbɛ mmyɛ, gébégé ɛbwɔ́ anyɛɛ́ menyɛɛ́, agií Jisɔs nnó, “Ata ndé muú wɔ ɔke achyɛge nyɛ wɔ maŋkwaá?”
\v 21 Pita agɛ́ge ji agií Jisɔs aké, “Ata ji ntó yɛ́?”
\p 
\v 22 Ne Jisɔs ashuú Pita meko aké, “Mbɔgé me nkɛlege nnó ji abɛ mebɛ kpaá tɛ me nchwɔɔ́, wɔ ɔbɔ ndé mechɔ wyɛɛ́? Wɔ kwɔle ɛlé me.”
\p 
\v 23 Ajɔ́gé mbɔ, mechɔ ɛwéna ɛkɛ ɛkwɔne mbaá baá utɔɔ́ abifɔ nnó Jisɔs aké maá utɔɔ́ yina agboó fɔ. Yɛ́mbɔ Jisɔs ajɔɔ́ fɔ́ nnó maá utɔɔ́ yimbɔ agboó fɔ́ wɔ́. Ajɔɔ́ ɛlé nnó, “Mbɔgé me nkɛlege nnó ji abɛ mebɛ kpaá tɛ me nchwɔɔ́, ɔbɔ ndé mechɔ wyɛɛ́?”
\p 
\v 24 Gɛ ɛlé maá utɔɔ́ awú ne agarege unó bina. Asá ubi né mme ne ɛsé dékaá nnó unó bi ji agarege úlú wáwálé.
\p 
\v 25 Gejamege unó ɛbifɔ úlú ntó ɛbi Jisɔs apyɛɛ́. Mbɔgé abɔ ása ubi uko né mme, mbɔ melú ɛbɛɛ́ fɔ́ fa mme ɛwé ábélege bɔ ŋwɛ abi ásame ubi.
