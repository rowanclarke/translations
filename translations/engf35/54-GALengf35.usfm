\v 21 \w Tell|strong="G3004"\w* \w me|strong="G1473"\w*, \w you|strong="G3004"\w* \w who|strong="G3588"\w* \w desire|strong="G2309"\w* \w to|strong="G3004"\w* \w be|strong="G1510"\w* \w under|strong="G5259"\w* \w law|strong="G3551"\w*, \w do|strong="G3004"\w* \w you|strong="G3004"\w* \w not|strong="G3756"\w* heed \w that|strong="G3588"\w* \w law|strong="G3551"\w*?
