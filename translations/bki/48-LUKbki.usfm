\v 29 Ere, naio be Yosua kenerinio
\mi1 Yosua, naio be Eliesa kenerinio
\mi1 Eliesa, naio be Jorim kenerinio
\mi1 Jorim, nao be M̃atat kenerinio
\mi1 M̃atat, naio be Livai kenerinio
\mi1 
\v 30 Livai, naio be Simion kenerinio
\mi1 Simion, naio be Yuta kenerinio
\mi1 Yuta, naio be Yoseve kenerinio
