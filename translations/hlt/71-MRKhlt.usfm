\v 20 \wj Tedae \+w lai|strong="G1093"\+w* \+w then|strong="G2570"\+w* \+w ah|strong="G1909"\+w* \+w tuh|strong="G4687"\+w* la aka \+w om|strong="G1526"\+w* \+w rhoek|strong="G1565"\+w* \+w tah|strong="G2532"\+w* \+w ol|strong="G3056"\+w* \+w te|strong="G3588"\+w* a \+w yaak|strong="G0191"\+w* uh \+w vaengah|strong="G2532"\+w* a \+w doe|strong="G3858"\+w* uh \+w tih|strong="G2532"\+w* a \+w ngen|strong="G1520"\+w* tah \+w thumkip|strong="G5144"\+w*, a \+w ngen|strong="G1520"\+w* tah \+w sawmrhuk|strong="G1835"\+w*, a \+w ngen|strong="G1520"\+w* tah \+w yakhat|strong="G1540"\+w* la \+w thaihtak|strong="G2592"\+w*,” \wj* a \w ti|strong="G3004"\w* nah.   
\s1 Hmaiim neh Hmaivang  
\p
\v 21 \x - \xo 4.21 \xt Mat 5. 15; Luk 11. 33.\x* Te \w phoeiah|strong="G2532"\w* \w amih|strong="G0846"\w* te, \wj “ \+w Hmaiim|strong="G3088"\+w* \+w te|strong="G3588"\+w* \+w voh|strong="G3426"\+w* \+w hmui|strong="G5259"\+w* \+w neh|strong="G2228"\+w* \+w thingkong|strong="G2825"\+w* \+w hmuiah|strong="G5259"\+w* \+w khueh|strong="G5087"\+w* ham a hang \+w khuen|strong="G2064"\+w*? \+w Hmaitung|strong="G3087"\+w* \+w soah|strong="G1909"\+w* a \+w khueh|strong="G5087"\+w* \+w ham|strong="G2443"\+w* \+w moenih|strong="G3756"\+w* a?\wj*  
\v 22 \x - \xo 4.22 \xt Mat 10. 26; Luk 12. 2.\x*\wj Te \+w dongah|strong="G1063"\+w* a \+w huephael|strong="G2927"\+w* \+w akhaw|strong="G1437"\+w* a \+w phoe|strong="G5319"\+w* \+w mueh|strong="G3361"\+w* \+w la|strong="G2443"\+w* a \+w om|strong="G2076"\+w* \+w moenih|strong="G3756"\+w*. A \+w huep|strong="G0614"\+w* te a \+w thoeng|strong="G1096"\+w* mueh \+w moenih|strong="G3761"\+w*. Te \+w van|strong="G0235"\+w* \+w daengah|strong="G2443"\+w* ni \+w mingpha|strong="G5318"\+w* \+w la|strong="G1519"\+w* a \+w om|strong="G2064"\+w* eh\wj*.  
\v 23 \wj \+w Yaak|strong="G0191"\+w* nah \+w hna|strong="G3775"\+w* aka \+w khueh|strong="G2192"\+w* long \+w te|strong="G5100"\+w* \+w tah|strong="G1487"\+w* \+w ya|strong="G0191"\+w* saeh,” \wj* a \w ti|strong="G3004"\w* nah.   
\p
\v 24 \x - \xo 4.24 \xt Mat 7. 2; Luk 6. 38.\x* Te \w phoeiah|strong="G2532"\w* \w amih|strong="G0846"\w* te, \wj “ Na \+w yaak|strong="G0191"\+w* uh \+w te|strong="G5101"\+w* \+w poek|strong="G0991"\+w* uh, na \+w nueh|strong="G3354"\+w* nah \+w cungnueh|strong="G3358"\+w* \+w nen|strong="G1722"\+w* \+w te|strong="G3739"\+w* \+w nangmih|strong="G5213"\+w* \+w n'nueh|strong="G3354"\+w* van \+w vetih|strong="G2532"\+w* \+w nangmih|strong="G5213"\+w* taengah han \+w thap|strong="G4369"\+w* ni\wj*.  
