\p
\v 24 Te \w lamkah|strong="G1564"\w* \w thoo|strong="G0450"\w* tih \w Tyre|strong="G5184"\w* \w vaang|strong="G3725"\w* \w la|strong="G1519"\w* \w cet|strong="G0565"\w*. Te \w vaengah|strong="G2532"\w* \w im|strong="G3614"\w* pakhat \w ah|strong="G1519"\w* a \w kun|strong="G1525"\w* te \w ming|strong="G1097"\w* sak ham \w ngaih|strong="G2309"\w* \w pawt|strong="G3762"\w* \w dae|strong="G2532"\w* \w phah|strong="G2990"\w* \w thai|strong="G1410"\w* \w pawh|strong="G3756"\w*.  
