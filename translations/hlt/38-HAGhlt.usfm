\c 2  
\s1 Thahphohnah Olkhueh  
\p
\v 1 \w Hla|strong="H2320"\w* \w rhih|strong="H7636"\w*, hnin \w kul|strong="H6242"\w* hnin \w khat|strong="H0259"\w* \w dongkah|strong="H9996"\w* \w BOEIPA|strong="H3068"\w* \w ol|strong="H1697"\w* he \w tonghma|strong="H5030"\w* \w Haggai|strong="H2292"\w* \w kut|strong="H3027"\w* \w lamloh|strong="H9996"\w* \w pai|strong="H1961"\w* tih,  
\v 2 \w Judah|strong="H3063"\w* \w rhalboei|strong="H6346"\w* \w Shealtiel|strong="H7597"\w* \w capa|strong="H1121"\w* \w Zerubbabel|strong="H2216"\w* \w taengah|strong="H0413"\w* \w khaw|strong="H9999"\w*, \w khosoih|strong="H3548"\w* \w puei|strong="H1419"\w* \w Jehozadak|strong="H3087"\w* \w capa|strong="H1121"\w* \w Joshua|strong="H3091"\w* \w taengah|strong="H0413"\w* khaw, \w pilnam|strong="H5971"\w* kah a \w meet|strong="H7611"\w* \w taengah|strong="H0413"\w* khaw \w thui|strong="H0559"\w* \w laeh|strong="H4994"\w*.  
\v 3 \x - \xo 2.3 \xt Ezr 3. 12.\x*“\w Hlamat|strong="H7223"\w* vaengkah \w a|strong="H9909"\w* \w thangpomnah|strong="H3519"\w* \w dongah|strong="H9996"\w* \w im|strong="H1003"\w* aka \w hmu|strong="H7200"\w* \w te|strong="H0834"\w* \w nangmih|strong="H9904"\w* \w khuiah|strong="H9996"\w* \w unim|strong="H4310"\w* aka \w sueng|strong="H7604"\w*? Aka \w hmu|strong="H7200"\w* rhoek \w nang|strong="H0859"\w* \w te|strong="H9909"\w* \w te|strong="H0853"\w* \w metlam|strong="H4100"\w* a om \w coeng|strong="H6258"\w*? \w Te|strong="H9909"\w* \w bang|strong="H3644"\w* te \w na|strong="H9904"\w* \w mik|strong="H5869"\w* \w dongkah|strong="H9996"\w* a \w hong|strong="H0369"\w* \w bangla|strong="H9995"\w* a om \w moenih|strong="H3808"\w* \w a|strong="H9994"\w*?  
\v 4 \w Tedae|strong="H9999"\w* \w Zerubbabel|strong="H2216"\w* aw, \w BOEIPA|strong="H3068"\w* kah \w olphong|strong="H5002"\w* bangla \w thaahuel|strong="H2388"\w* \w laeh|strong="H6258"\w*. \w Khosoih|strong="H3548"\w* \w puei|strong="H1419"\w* \w Jehozadak|strong="H3087"\w* \w capa|strong="H1121"\w* \w Joshua|strong="H3091"\w* \w thaahuel|strong="H2388"\w* laeh. \w Khohmuen|strong="H0776"\w* \w pilnam|strong="H5971"\w* \w boeih|strong="H3605"\w* loh \w thaahuel|strong="H2388"\w* laeh. He tah \w BOEIPA|strong="H3068"\w* kah \w olphong|strong="H5002"\w* coeng ni. \w Nangmih|strong="H9904"\w* \w taengah|strong="H0854"\w* \w ka|strong="H0589"\w* om coeng \w dongah|strong="H3588"\w* \w saii|strong="H6213"\w* uh laeh. He tah \w caempuei|strong="H6635"\w* \w BOEIPA|strong="H3068"\w* kah \w olphong|strong="H5002"\w* ni.  
\v 5 \x - \xo 2.5 \xt Sng 29. 45,46.\x*\w Ol|strong="H1697"\w* \w he|strong="H0853"\w* \w Egypt|strong="H4713"\w* \w lamloh|strong="H4480"\w* \w na|strong="H9904"\w* \w lo|strong="H3318"\w* \w vaengah|strong="H9996"\w* ni \w nangmih|strong="H9904"\w* \w taengah|strong="H0854"\w* kang \w khueh|strong="H3772"\w* coeng. \w Ka|strong="H9901"\w* \w mueihla|strong="H7307"\w* he \w na|strong="H9904"\w* \w khui|strong="H8432"\w* \w ah|strong="H9996"\w* a \w om|strong="H5975"\w* dongah \w rhih|strong="H3372"\w* \w boeh|strong="H0408"\w*.   
\p
\v 6 \x - \xo 2.6 \xt Heb 12. 26.\x*\w Caempuei|strong="H6635"\w* \w BOEIPA|strong="H3068"\w* loh \w he|strong="H3541"\w* ni a \w thui|strong="H0559"\w*. \w Vai|strong="H0259"\w* khaw \w bet|strong="H4592"\w* \w a|strong="H1931"\w* om \w bal|strong="H5750"\w* \w phoeiah|strong="H9999"\w* tah \w vaan|strong="H8064"\w* \w neh|strong="H9999"\w* \w diklai|strong="H0776"\w* \w khaw|strong="H9999"\w*, \w tuitunli|strong="H3220"\w* \w neh|strong="H9999"\w* \w lanhak|strong="H2724"\w* khaw \w ka|strong="H0589"\w* \w hinghuen|strong="H7493"\w* ni.  
\v 7 \w Namtom|strong="H1471"\w* \w boeih|strong="H3605"\w* \w te|strong="H0853"\w* ka \w hinghuen|strong="H7493"\w* \w vetih|strong="H9999"\w* \w namtom|strong="H1471"\w* \w boeih|strong="H3605"\w* te \w sahnaih|strong="H2532"\w* la ha \w pai|strong="H0935"\w* uh ni. Te \w vaengah|strong="H9999"\w* \w he|strong="H2088"\w* \w im|strong="H1003"\w* \w he|strong="H0853"\w* \w thangpomnah|strong="H3519"\w* ka \w bae|strong="H4390"\w* sak ni tila \w caempuei|strong="H6635"\w* \w BOEIPA|strong="H3068"\w* loh a \w thui|strong="H0559"\w*.  
\v 8 \w Cak|strong="H3701"\w* he \w kamah|strong="H9901"\w* \w kah|strong="H9997"\w* \w tih|strong="H9999"\w* \w sui|strong="H2091"\w* khaw \w kamah|strong="H9901"\w* \w kah|strong="H9997"\w* ni. He tah \w caempuei|strong="H6635"\w* \w BOEIPA|strong="H3068"\w* kah \w olphong|strong="H5002"\w* ni.  
\v 9 “\w He|strong="H2088"\w* \w im|strong="H1003"\w* \w thangpomnah|strong="H3519"\w* tah \w lamhma|strong="H7223"\w* \w lakah|strong="H4480"\w* khaw \w lamhnuk|strong="H0313"\w* ah a \w len|strong="H1419"\w* \w om|strong="H1961"\w* ni,” tila \w caempuei|strong="H6635"\w* \w BOEIPA|strong="H3068"\w* loh a \w thui|strong="H0559"\w*. Te \w dongah|strong="H9999"\w* \w he|strong="H2088"\w* \w hmuen|strong="H4725"\w* \w ah|strong="H9996"\w* \w ngaimongnah|strong="H7965"\w* ka \w paek|strong="H5414"\w* ni. He tah \w caempuei|strong="H6635"\w* \w BOEIPA|strong="H3068"\w* kah \w olphong|strong="H5002"\w* ni.   
\s1 Pocinah lamloh Yoethennah  
\p
\v 10 \w Darius|strong="H1867"\w* \w kah|strong="H9997"\w* a \w kum|strong="H8141"\w* \w bae|strong="H8147"\w*, hla \w ko|strong="H8671"\w*, hin \w kul|strong="H6242"\w* hnin \w li|strong="H0702"\w* \w vaengah|strong="H9996"\w* \w BOEIPA|strong="H3068"\w* \w ol|strong="H1697"\w* te \w tonghma|strong="H5030"\w* \w Haggai|strong="H2292"\w* \w taengla|strong="H0413"\w* \w pai|strong="H1961"\w* tih,  
\v 11 \w Caempuei|strong="H6635"\w* \w BOEIPA|strong="H3068"\w* loh \w he|strong="H3541"\w* ni a \w thui|strong="H0559"\w*. \w “Khosoih|strong="H3548"\w* \w te|strong="H0853"\w* \w olkhueng|strong="H8451"\w* \w dawt|strong="H7592"\w* \w laeh|strong="H4994"\w*,” a \w ti|strong="H0559"\w* nah.   
\p
\v 12 Te dongah, “\w Hlang|strong="H0376"\w* loh \w a|strong="H9909"\w* \w himbai|strong="H0899"\w* \w cun|strong="H3671"\w* \w khuiah|strong="H9996"\w* \w hmuencim|strong="H6944"\w* \w maeh|strong="H1320"\w* a \w phueih|strong="H5375"\w* \w tih|strong="H9999"\w* \w a|strong="H9909"\w* \w hmoi|strong="H3671"\w* \w neh|strong="H9996"\w* \w buh|strong="H3899"\w* \w khaw|strong="H9999"\w*, \w andam|strong="H5138"\w* \w khaw|strong="H9999"\w*, \w misurtui|strong="H3196"\w* \w khaw|strong="H9999"\w*, \w situi|strong="H8081"\w* \w khaw|strong="H9999"\w*, \w caak|strong="H3978"\w* te khat \w khat|strong="H3605"\w* khaw, a \w ben|strong="H5060"\w* \w te|strong="H2005"\w* a \w ciim|strong="H6942"\w* a?” a \w ti|strong="H0559"\w* nah.  
\p Te \w vaengah|strong="H9999"\w* \w khosoih|strong="H3548"\w* rhoek loh a \w doo|strong="H6030"\w* \w tih|strong="H9999"\w*, “Cim \w mahpawh|strong="H3808"\w*,” a \w ti|strong="H0559"\w* uh.   
\p
\v 13 \x - \xo 2.13 \xt Lmp 19. 11-22.\x*Te \w phoeiah|strong="H9999"\w* \w Haggai|strong="H2292"\w* loh, “\w Hinglu|strong="H5315"\w* \w rhalawt|strong="H2931"\w* loh \w he|strong="H0428"\w* \w he|strong="H9996"\w* \w boeih|strong="H3605"\w* a \w ben|strong="H5060"\w* \w atah|strong="H0518"\w*, a \w poeih|strong="H2930"\w* \w nama|strong="H9994"\w*?” a \w ti|strong="H0559"\w* nah.  
