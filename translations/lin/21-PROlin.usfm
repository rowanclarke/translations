\id PRO Biblica® Open Lingala Contemporary Bible 2020 
\h Masese 
\toc1 Masese 
\toc2 Masese 
\toc3 Mas 
\mt1 Masese 
\c 1  
\s1 Maloba ya ebandeli 
\p  
\v 1 Masese ya Salomo, mwana mobali ya Davidi, mokonzi ya Isalaele : 
\q1  
\v 2 mpo na koyeba bwanya, kozwa mateya 
\q2 mpe kososola maloba ya mayele ; 
\q1  
\v 3 mpo na kozwa mateya ya bwanya 
\q2 oyo epesaka bizaleli ya sembo, 
\q2 ya boyengebene mpe makambo ya alima ; 
\q1  
\v 4 mpo na kopesa mayele epai ya bazoba, 
\q2 mpe boyebi epai ya bilenge. 
\q1  
\v 5 Tika ete moto ya bwanya ayoka yango, 
\q2 mpe akobakisa bwanya na ye, 
\q1 bongo moto ya mayele akoyeba mayele 
\q2 ya kotambolisa bato ; 
\q1  
\v 6 mpo na kososola masese mpe sambole, 
\q2 maloba ya bwanya mpe kolimbola makambo. 
\s1 Fungola ya bwanya 
\q1  
\v 7 Kotosa Yawe ezali mosisa ya mayele ; 
\q2 bato oyo bazangi mayele batiolaka bwanya mpe toli. 
\q1  
\v 8 Mwana na ngai ya mobali, yoka toli ya tata na yo, 
\q2 mpe kobwaka te mateya ya mama na yo ; 
\q1  
\v 9 Pamba te ekozala lokola ekoti ya ngolu na moto na yo, 
\q2 mpe lokola mayaka ya kitoko na kingo na yo. 
\b  
\q1  
\v 10 Mwana na ngai ya mobali, 
\q2 soki bato ya masumu balingi kokweyisa yo, komitika te. 
\q1  
\v 11 Soki balobi na yo : « Yaka elongo na biso, 
\q2 tika ete tosala motambo mpo na koboma bato, 
\q1 tokosepela mpo na kokanga moto 
\q2 oyo ayebi likambo te ! 
\q1  
\v 12 Ndenge mokili ya bakufi esalaka, 
\q2 tokomela ye ya bomoi, tokomela ye mobimba 
\q2 lokola bato oyo bakitaka na libulu ya kufa ; 
\q1  
\v 13 tokozwa biloko ya talo ya ndenge na ndenge, 
\q2 mpe tokotondisa bandako na biso 
\q2 na bomengo ya bitumba ; 
\q1  
\v 14 okozwa ndambo na yo epai na biso, 
\q2 pamba te biso nyonso tokosangisa 
\q2 biloko na biso esika moko ; » 
\q1  
\v 15 mwana na ngai ya mobali, kokende elongo na bango te, 
\q2 longola makolo na yo na nzela na bango ; 
\q1  
\v 16 pamba te makolo na bango ekimaka mbangu 
\q2 mpo na kolanda mabe, 
\q2 mpe bapotaka mbangu mpo na kosopa makila. 
\q1  
\v 17 Solo, ezali pamba kotia monyama 
\q2 liboso ya miso ya bikelamu nyonso oyo ezali na mapapu. 
\q1  
\v 18 Kasi bango, batiaka mitambo 
\q2 mpo na kosopa makila na bango moko, 
\q2 bamilukelaka pasi na bomoi na bango. 
\q1  
\v 19 Moto oyo alukaka kozwa bomengo na nzela ya lokuta 
\q2 asukaka kaka bongo, 
\q2 mpe bomengo yango ebomaka kaka ye moko. 
\s1 Bwanya azali kobelela 
\q1  
\v 20 Bwanya azali koganga na libanda, 
\q2 atomboli mongongo na ye na bisika 
\q2 oyo bato ebele bakutanaka ; 
\q1  
\v 21 azali koganga na bisika ya loyenge 
\q2 mpe azali koloba liboso ya ekuke ya engumba : 
\b  
\q1  
\v 22 « Yo moto oyo ozangi mayele, 
\q2 kino tango nini okolinga bozoba na yo ? 
\q1 Kino tango nini batioli bakokoba kosepela kotiola ? 
\q2 Mpe bino bazoba, kino tango nini bokokoba 
\q2 koyina mayele ? 
\q1  
\v 23 Soki boyoki makebisi na Ngai, 
\q2 nakosopela bino Molimo na Ngai 
\q2 mpe nakososolisa bino maloba na Ngai. 
\q1  
\v 24 Kasi lokola bosundolaki Ngai tango nazalaki kobelela 
\q2 mpe moto moko te asalaki keba tango natandaki loboko, 
\q1  
\v 25 lokola bobwakaki toli na Ngai 
\q2 mpe boboyaki kondima pamela na Ngai, 
\q1  
\v 26 Ngai mpe nakoseka bino tango pasi ekoyela bino, 
\q2 nakotiola bino tango minyoko ekokomela bino, 
\q1  
\v 27 tango minyoko ekokomela bino na pwasa 
\q2 lokola mvula ya kake makasi, 
\q1 tango somo ekoyela bino lokola ekumbaki, 
\q2 tango mawa mpe somo ekokomela bino. 
\b  
\q1  
\v 28 Bakoganga epai na Ngai, kasi nakoyanola bango te ; 
\q2 bakoluka Ngai na ngonga ya malamu, 
\q2 kasi bakomona Ngai te. 
\q1  
\v 29 Lokola bayinaki boyebi 
\q2 mpe baponaki te nzela ya kotosa Yawe, 
\q1  
\v 30 lokola baboyaki kondima toli na Ngai 
\q2 mpe batiolaki pamela na Ngai, 
\q1  
\v 31 bakolia mbuma ya etamboli na bango 
\q2 mpe bakotonda na mabongisi ya mitema na bango moko. 
\q1  
\v 32 Pamba te kotomboka ya bato oyo bazangi mayele 
\q2 ekoboma bango, 
\q1 mpe bozangi bokebi ya bato oyo bazangi mayele 
\q2 ekoboma kaka bango moko ; 
\q1  
\v 33 kasi moto oyo ayokaka Ngai 
\q2 akovanda na kimia mpe akobanga mabe moko te. » 
\c 2  
\s1 Bwanya : bomengo oyo ebombama 
\q1  
\v 1 Mwana na ngai, soki ondimi maloba na ngai 
\q2 mpe obateli kati na motema na yo mibeko na ngai ; 
\q1  
\v 2 soki opesi litoyi na yo na maloba ya bwanya 
\q2 mpe okabi motema na yo na makambo ya mayele ; 
\q1  
\v 3 soki obeleli mayele 
\q2 mpe ogangi epai ya bososoli ; 
\q1  
\v 4 soki oluki yango penza ndenge balukaka palata 
\q2 to bomengo oyo ebombama, 
\q1  
\v 5 okososola solo soki kotosa Yawe elakisi nini 
\q2 mpe okozwa boyebi ya Nzambe. 
\q1  
\v 6 Pamba te Yawe nde apesaka bwanya, 
\q2 mpe maloba ya monoko na Ye epesaka 
\q2 mayele mpe bososoli. 
\q1  
\v 7 Abongiselaka bato ya sembo elonga 
\q2 mpe azali nguba ya bato oyo batambolaka na bosembo. 
\q1  
\v 8 Pamba te abatelaka bayengebene 
\q2 mpe nzela ya bato oyo batosaka Ye. 
\b  
\q1  
\v 9 Boye, okososola likambo nini 
\q2 ezali solo, alima, sembo : 
\q2 nzela nyonso oyo ememaka na bolamu. 
\q1  
\v 10 Pamba te bwanya ekokota kati na motema na yo 
\q2 mpe boyebi ekosepelisa molimo na yo. 
\q1  
\v 11 Bososoli ekobatela yo, 
\q2 mpe mayele ekobomba yo 
\q1  
\v 12 mpo na kobikisa yo na nzela mabe, 
\q2 na moto oyo alobaka makambo ezanga tina, 
\q1  
\v 13 na bato oyo batikaka nzela ya sembo 
\q2 mpo na kolanda nzela ya molili, 
\q1  
\v 14 na bato oyo basepelaka kosala mabe, 
\q2 na bato oyo bazalaka na esengo 
\q2 ya kokota na bozindo ya mabe, 
\q1  
\v 15 na bato oyo nzela na bango etengama-tengama 
\q2 mpe etamboli na bango etonda na mobulu. 
\b  
\q1  
\v 16 Bwanya ekobikisa yo lisusu liboso ya mwasi mopaya, 
\q2 liboso ya mwasi oyo atonda na maloba ya sukali, 
\q1  
\v 17 oyo akima mobali na ye ya bolenge 
\q2 mpe abosana boyokani oyo asalaki 
\q2 elongo na Nzambe na ye ; 
\q1  
\v 18 pamba te ndako na ye ememaka na kufa, 
\q2 mpe nzela na ye ememaka na mboka ya bakufi. 
\q1  
\v 19 Moto moko te oyo akotaka epai na ye azongaka 
\q2 mpe amonaka lisusu nzela ya bomoi. 
\b  
\q1  
\v 20 Boye, okotambola na nzela ya bato malamu 
\q2 mpe okolanda nzela ya bato ya sembo. 
\q1  
\v 21 Pamba te bato ya sembo bakovanda na mokili, 
\q2 mpe bato oyo bazangi pamela bakotikala kati na yango ; 
\q1  
\v 22 kasi bato mabe bakokufa na mokili 
\q2 mpe bakolongola bango kati na mokili 
\q2 ya bato ya songisongi. 
\c 3  
\s1 Elikya na Yawe 
\q1  
\v 1 Mwana na Ngai, kobosana mateya na ngai te, 
\q2 kasi batela mibeko na ngai kati na motema na yo ; 
\q1  
\v 2 pamba te ekoyeisa mikolo ya bomoi na yo milayi, 
\q2 ekobakisa mibu ebele na bomoi na yo 
\q2 mpe ekomemela yo kimia. 
\b  
\q1  
\v 3 Tika ete bolamu mpe bosolo ekabwana na yo te, 
\q2 linga yango zingazinga na kingo na yo, 
\q2 mpe koma yango na etando ya motema na yo ! 
\q1  
\v 4 Okozwa ngolu mpe kombo ya malamu 
\q2 na miso ya Nzambe mpe na miso ya bato. 
\b  
\q1  
\v 5 Ndimela Yawe na motema na yo mobimba, 
\q2 mpe kotia motema te na mayele na yo. 
\q1  
\v 6 Yebaka Ye na banzela na yo nyonso, 
\q2 mpe Ye akokomisa yango alima. 
\b  
\q1  
\v 7 Tika ete omimonaka te moto ya bwanya 
\q2 na miso na yo moko ; 
\q2 tosa Yawe mpe longwa na mabe. 
\q1  
\v 8 Ekozala kisi mpo na kokomisa nzoto na yo kolongono 
\q2 mpe kolendisa mikuwa na yo. 
\b  
\q1  
\v 9 Pesaka Yawe lokumu na nzela ya biloko na yo 
\q2 mpe ya bambuma ya liboso ya bozwi na yo nyonso. 
\q1  
\v 10 Bongo bibombelo na yo ekotonda na biloko, 
\q2 mpe bambeki na yo ekotonda na vino. 
\b  
\q1  
\v 11 Mwana na ngai, yamba toli ya Yawe, 
\q2 koboya te pamela na Ye ; 
\q1  
\v 12 pamba te Yawe apamelaka moto oyo Ye alingaka, 
\q2 ndenge kaka tata apamelaka mwana na ye, oyo alingaka. 
\s1 Bwanya : bomengo oyo ezanga talo 
\q1  
\v 13 Esengo na moto oyo amoni bwanya ! 
\q2 Esengo na moto oyo azwi mayele ! 
\q1  
\v 14 Pamba te kozala na yango eleki kozala 
\q2 na palata na motuya, 
\q1 mpe lifuti na yango eleki wolo 
\q2 oyo balekisi na moto na motuya. 
\q1  
\v 15 Ezali na motuya koleka babiju, 
\q2 mpe eloko moko te oyo moto akoki koluka 
\q2 ekokani na yango. 
\q1  
\v 16 Kati na loboko na Ye ya mobali, 
\q2 ezali na bomoi ya molayi ; 
\q1 mpe kati na loboko na Ye ya mwasi, 
\q2 ezali na lokumu mpe bomengo. 
\q1  
\v 17 Nzela na Ye ezali ya esengo, 
\q2 mpe banzela na Ye nyonso ya mike ezali ya kimia. 
\q1  
\v 18 Bwanya ezali nzete ya bomoi 
\q2 mpo na bato oyo basimbaka yango ; 
\q1 bato oyo bakokanga yango makasi 
\q2 bakozala na esengo. 
\b  
\q1  
\v 19 Na nzela ya bwanya, Yawe atiaki miboko ya mabele ; 
\q2 na nzela ya mayele, alendisaki likolo. 
\q1  
\v 20 Na nzela ya mayele na Ye, 
\q2 mozindo ya se ya mabele ebimisaki mayi 
\q2 mpe mapata enokisaki mvula. 
\s1 Yawe akozala elikya na yo 
\q1  
\v 21 Mwana na ngai, tika ete bwanya mpe bososoli ezala mosika ya miso na yo te ; 
\q2 batela yango malamu, 
\q1  
\v 22 pamba te ekozala bomoi mpo na yo 
\q2 mpe ngolu mpo na kingo na yo. 
\q1  
\v 23 Boye, okotambola na kimia na nzela na yo, 
\q2 mpe lokolo na yo ekobeta libaku te. 
\q1  
\v 24 Tango okolala, okobanga eloko moko te, 
\q2 pamba te pongi na yo ekozala ya kimia. 
\q1  
\v 25 Somo ya pwasa ekobangisa yo te, 
\q2 ezala tango bato mabe bakobimela yo na pwasa ; 
\q1  
\v 26 pamba te Yawe akozala elikya na yo 
\q2 mpe akobatela makolo na yo mpo ete ekangama te na motambo. 
\s1 Kolinga baninga 
\q1  
\v 27 Koboyaka te kosala bolamu epai ya moto 
\q2 oyo azali na bosenga, 
\q2 tango maboko na yo ezali na makoki ya kosala yango. 
\q1  
\v 28 Kolobaka na moninga na yo te : 
\q2 « Kende, bongo oya sima ; nakopesa yo yango lobi ; » 
\q2 soki ozali na makoki ya kosala likambo yango. 
\q1  
\v 29 Kosalaka moninga na yo mabe te 
\q2 soki azali kovanda na kimia epai na yo. 
\q1  
\v 30 Kolukelaka moto makambo te, oyo ezanga tina 
\q2 soki asali yo mabe te. 
\b  
\q1  
\v 31 Kolulaka te moto ya mobulu 
\q2 mpe koponaka ata nzela moko te, 
\q2 kati na banzela na ye. 
\b  
\q1  
\v 32 Pamba te Yawe ayinaka bato mabe, 
\q2 kasi ayebisaka basekele na Ye epai ya bato ya sembo. 
\q1  
\v 33 Yawe alakelaka mabe ndako ya moto mabe, 
\q2 kasi apambolaka ndako ya moto ya sembo ; 
\q1  
\v 34 asambwisaka batioli, 
\q2 kasi atalisaka ngolu na Ye 
\q2 epai ya bato oyo bamikitisaka. 
\q1  
\v 35 Bato ya bwanya bakozwa nkembo, 
\q2 kasi bazoba bakozala na soni. 
\c 4  
\s1 Batoli ya tata 
\q1  
\v 1 Bana na ngai, boyokaka mateya ya tata, 
\q2 bozalaka na bokebi mpo ete bozwa mayele. 
\q1  
\v 2 Pamba te nazali kopesa bino mateya ya malamu ; 
\q2 bobwaka mateya na ngai te. 
\q1  
\v 3 Ngai mpe nazalaki mwana malamu 
\q2 na miso ya tata na ngai, 
\q1 boye mama na ngai alingaki ngai makasi 
\q2 lokola mwana oyo abotama kaka ye moko. 
\q1  
\v 4 Tata na ngai azalaki koteya 
\q2 mpe koloba na ngai boye : 
\q1 « Tika ete motema na yo ebatela maloba na ngai, 
\q2 bomba mibeko na ngai mpe okozala na bomoi, 
\q1  
\v 5 zwa bwanya, zwa mayele, kobosana yango te, 
\q2 kopesa mokongo te na maloba ya monoko na ngai, 
\q1  
\v 6 kosundola bwanya te, mpe yango ekobatela yo, 
\q2 linga yango mpe ekobomba yo. 
\q1  
\v 7 Tala ebandeli ya bwanya : Zwa bwanya, 
\q2 pesa biloko nyonso oyo ozali na yango 
\q2 mpo ete ozwa mayele. 
\q1  
\v 8 Simba yango makasi, mpe ekotombola yo ; 
\q2 yamba yango, mpe ekopesa yo lokumu. 
\q1  
\v 9 Ekolatisa yo ekoti ya lokumu na moto, 
\q2 ekopesa yo motole ya nkembo. » 
\b  
\q1  
\v 10 Mwana na ngai, yoka mpe yamba maloba na ngai, 
\q2 mpe mibu ya bomoi na yo ekobakisama. 
\q1  
\v 11 Nazali kolakisa yo nzela ya bwanya, 
\q2 nazali kotambolisa yo na nzela ya alima. 
\q1  
\v 12 Mpo ete makolo na yo ezala na mikakatano te 
\q2 tango okotambola ; 
\q2 mpe soki okimi mbangu, okokweya te. 
\q1  
\v 13 Tingama makasi na mateya oyo bapesi yo, 
\q2 kobwaka yango te, batela yango malamu 
\q2 mpo ete ezali bomoi na yo. 
\q1  
\v 14 Kokotaka te na nzela ya bato ya mobulu 
\q2 mpe kotambolaka te na nzela ya bato mabe. 
\q1  
\v 15 Longwa kati na bango, kolekela wana te, 
\q2 kosala mpe maseki kuna te, 
\q2 kasi kende na yo na nzela mosusu. 
\q1  
\v 16 Pamba te balalaka pongi te 
\q2 soki basali nanu moto mabe te, 
\q1 mpe pongi ekimaka bango 
\q2 soki babomi moto te ; 
\q1  
\v 17 baliaka lipa na nzela ya mabe 
\q2 mpe bamelaka vino na nzela ya mobulu. 
\b  
\q1  
\v 18 Nzokande, nzela ya bato ya sembo ezali 
\q2 lokola pole ya tongo makasi, 
\q1 oyo kongenga na yango eyaka malembe-malembe 
\q2 kino tango moyi ekobima makasi. 
\q1  
\v 19 Nzela ya bato ya mobulu ezali lokola molili, 
\q2 bayebaka te eloko nini ekokweyisa bango. 
\b  
\q1  
\v 20 Mwana na ngai, zala na bokebi na maloba na ngai, 
\q2 pesa litoyi na yo na mateya na ngai. 
\q1  
\v 21 Tika ete ezala te mosika ya miso na yo ! 
\q2 Batela yango malamu kati na motema na yo, 
\q1  
\v 22 pamba te ezali bomoi mpo na bato oyo bazwaka yango, 
\q2 mpe epesaka nzoto kolongono. 
\q1  
\v 23 Batela malamu motema na yo koleka biloko nyonso, 
\q2 pamba te makambo nyonso oyo tosalaka, 
\q2 wana tozali na bomoi, ewutaka na motema. 
\q1  
\v 24 Longola lokuta na monoko na yo, 
\q2 mpe longola mabe na bibebu na yo. 
\q1  
\v 25 Tika ete miso na yo etalaka kaka liboso, 
\q2 mpe salaka makambo na bosembo mpe bosolo. 
\q1  
\v 26 Bongisa nzela oyo makolo na yo ekolekela, 
\q2 mpe tambola kaka na nzela oyo oyebi malamu. 
\q1  
\v 27 Kotengama te, 
\q2 ezala na ngambo ya loboko ya mobali to ya mwasi, 
\q2 longola makolo na yo na mabe. 
\c 5  
\s1 Sala keba na ekobo 
\q1  
\v 1 Mwana na ngai, zala na bokebi na bwanya na ngai, 
\q2 mpe pesa litoyi na yo na mayele na ngai, 
\q1  
\v 2 mpo ete ozala na bososoli, 
\q2 mpe bibebu na yo ebomba boyebi. 
\q1  
\v 3 Pamba te bibebu ya mwasi ya ndumba ebimisaka 
\q2 mafuta ya nzoyi, 
\q2 mpe lolemo na ye ezali elengi lokola mafuta ; 
\q1  
\v 4 kasi na suka na nyonso, 
\q2 azali bololo lokola masanga ya bololo, 
\q2 songe lokola mopanga ya minu mibale. 
\q1  
\v 5 Makolo na ye ekokita kino na kufa, 
\q2 ekokende kino na mokili ya bakufi. 
\q1  
\v 6 Amitungisaka te mpo na nzela ya bomoi, 
\q2 alandaka nzela oyo ayebi te esika nini ekosuka. 
\b  
\q1  
\v 7 Sik’oyo mwana na ngai, yoka ngai, 
\q2 kopesa maloba na ngai mokongo te ; 
\q1  
\v 8 longola nzela na yo pembeni na ye 
\q2 mpe kopusana te liboso ya ndako na ye, 
\q1  
\v 9 noki te akoya kokaba lokumu na yo 
\q2 epai ya bato mosusu, 
\q2 mpe mibu na yo epai ya moto mabe ; 
\q1  
\v 10 noki te bapaya bakotonda na biloko oyo yo omoneli pasi, 
\q2 mpe mbuma ya mosala na yo ekokende 
\q2 na ndako ya mopaya ; 
\q1  
\v 11 noki te okokoma kolelalela na suka 
\q2 tango nzoto na yo ekolemba mpe makasi na yo ekosila, 
\q1  
\v 12 mpe oloba : « Mpo na nini nayinaki mateya, 
\q2 mpe motema na ngai eboyaki koyoka toli ? 
\q1  
\v 13 Mpo na nini nayokaki te mongongo ya balakisi na ngai 
\q2 mpe napesaki litoyi te epai ya bato 
\q2 oyo bazalaki koteya ngai ? 
\q1  
\v 14 Etikalaki kaka moke ete nakweya na mabe ya mozindo, 
\q2 kati na Lingomba ya bato ya Nzambe. » 
\s1 Mwasi ya bolenge na yo 
\q1  
\v 15 Melaka mayi ya libulu na yo moko, 
\q2 oyo ezali kobima penza na libulu na yo. 
\q1  
\v 16 Boni, bitima na yo esopa penza mayi na libanda 
\q2 to miluka na yo esopa penza mayi na balabala ? 
\q1  
\v 17 Tika ete ezala kaka mpo na yo moko, 
\q2 kasi kokabola yango te na bapaya. 
\q1  
\v 18 Tika ete etima na yo epambolama, 
\q2 mpe sepela na mwasi ya bolenge na yo, 
\q1  
\v 19 oyo azali lokola mbuli kitoko ya mwasi, 
\q2 lokola mboloko ya mafuta. 
\q1 Tika ete tango nyonso, 
\q2 mabele na ye etondisaka yo na esengo, 
\q2 mpe bolingo na ye elangwisaka yo ! 
\q1  
\v 20 Mwana na ngai ya mobali, mpo na nini kokufela 
\q2 kolinga mwasi ya ndumba ? 
\q1 Mpo na nini kosepela kosakana 
\q2 na mabele ya mwasi mosusu ? 
\b  
\q1  
\v 21 Solo, nzela ya moto ezali liboso ya Yawe, 
\q2 mpe ayekolaka malamu makambo nyonso 
\q2 oyo moto asalaka. 
\q1  
\v 22 Moto mabe akokangama kaka 
\q2 na motambo ya mabe na ye moko 
\q2 mpe na singa ya lisumu na ye, 
\q1  
\v 23 akokufa likolo ya bozoba, 
\q2 mpe liboma na ye ekobungisa ye nzela. 
\c 6  
\s1 Bilaka ya somo 
\q1  
\v 1 Mwana na ngai, soki ondimi niongo ya moninga na yo, 
\q2 soki obeti tolo mpo na kondima niongo ya mopaya, 
\q1  
\v 2 omikangi nde singa na maloba na yo, 
\q2 omikangi nde na motambo ya maloba ya monoko na yo. 
\q1  
\v 3 Boye, mwana na ngai, sala makambo oyo 
\q2 mpo ete omikangola, 
\q1 pamba te omikabaki na maboko ya moninga na yo ; 
\q2 kende komikitisa liboso na ye mpe tingama na ye, 
\q1  
\v 4 kotika te ete miso na yo elala pongi to enimba ; 
\q1  
\v 5 mikangola na motambo lokola mboloko na maboko 
\q2 ya mobomi banyama ya zamba, 
\q2 mpe lokola ndeke na motambo ya mokangi bandeke. 
\s1 Moto ya goyigoyi 
\q1  
\v 6 Yo moto ya goyigoyi, kende epai ya furmi, 
\q2 tala malamu ezaleli na yango mpe okozwa bwanya ! 
\q1  
\v 7 Yango ezalaka na mokambi te, 
\q2 mokengeli te to mokonzi te ; 
\q1  
\v 8 ebongisaka bilei na yango na tango ya moyi makasi, 
\q2 ebombaka yango na tango ya kobuka mbuma. 
\b  
\q1  
\v 9 Yo moto ya goyigoyi, okolala pongi kino tango nini ? 
\q2 Kino tango nini okolamuka na pongi na yo ? 
\q1  
\v 10 Mwa pongi moke, mwa kopema moke, 
\q2 mwa kokanga maboko moke mpo na kolala 
\q1  
\v 11 mpe bobola ekoyela yo na pwasa lokola moleki nzela, 
\q2 mpe pasi ekoyela yo lokola moyibi. 
\s1 Bato ya lokuta 
\q1  
\v 12 Moto oyo atambolaka na lokuta na monoko 
\q2 azali moto ya Beliali\f + \fr 6.12 \ft Beliali ezali molimo mabe.\f*, moto mabe : 
\q1  
\v 13 Abetaka-betaka miso, 
\q2 apesaka bilembo na makolo na ye 
\q2 mpe alobaka na nzela ya bilembo ya misapi ; 
\q1  
\v 14 azalaka na makanisi mabe kati na motema na ye, 
\q2 asalaka tango nyonso mabongisi ya mabe 
\q2 mpe alukaka kaka tango nyonso makelele. 
\q1  
\v 15 Yango wana, pasi ekoyela ye na pwasa, 
\q2 akobukana mbala moko, 
\q2 mpe kisi ya kobikisa ye ekozala te. 
\s1 Makambo oyo Yawe ayinaka 
\li1  
\v 16 Yawe ayinaka makambo wana motoba ; 
\li2 mpe makambo oyo sambo ezali mabe penza na miso na Ye : 
\li3  
\v 17 Kodongola, 
\li3 lolemo ya lokuta, 
\li3 maboko oyo ebomaka moto oyo asali mabe te, 
\li3  
\v 18 motema oyo ekanisaka mabongisi ya mabe, 
\li3 makolo oyo epotaka mbangu na mabe, 
\li3  
\v 19 motatoli mabe oyo alobaka lokuta 
\li3 mpe moto oyo alukaka makelele kati na bandeko. 
\b  
\q1  
\v 20 Mwana na ngai, batela mibeko ya tata na yo 
\q2 mpe kosundola te mateya ya mama na yo. 
\q1  
\v 21 Kanga yango tango nyonso na motema na yo, 
\q2 lata yango na kingo na yo. 
\q1  
\v 22 Pamba te ekolakisa yo nzela tango okokende na mobembo, 
\q2 ekobatela yo tango okolala pongi 
\q2 mpe ekosolola na yo tango okolamuka. 
\q1  
\v 23 Mibeko ezali mwinda, mateya ezali pole, 
\q2 makebisi mpe pamela ezali nzela ya bomoi, 
\q1  
\v 24 mpo na kobatela yo mosika ya mwasi ya ndumba, 
\q2 mosika ya lokuta ya lolemo ya mwasi ya mopaya. 
\b  
\q1  
\v 25 Kotika te ete motema na yo elula kitoko na ye, 
\q2 mpe miso na ye ekweyisa yo. 
\b  
\q1  
\v 26 Pamba te likolo ya mwasi ya ndumba, 
\q2 okoki kobungisa ezala eteni na yo ya lipa, 
\q2 mpe mwasi ya libala akoki kobebisa bomoi ya motuya. 
\q1  
\v 27 Boni, moto akoki solo kozika moto, 
\q2 bongo bilamba na ye ezika te ? 
\q1  
\v 28 Moto akoki solo kotambola na likolo ya makala ya moto, 
\q2 bongo makolo na ye ezika te ? 
\q1  
\v 29 Boye, moto nyonso oyo akosangisa nzoto 
\q2 na mwasi ya ndeko na ye 
\q2 akozanga te kozwa etumbu. 
\b  
\q1  
\v 30 Kotiola moyibi te soki ayibi 
\q2 mpo ete azali na nzala mpe azangi eloko ya kolia. 
\q1  
\v 31 Kasi soki bakangi ye, akozongisa mbala sambo, 
\q2 akopesa biloko nyonso ya ndako na ye. 
\q1  
\v 32 Mobali oyo asalaka ekobo na mwasi ya moninga 
\q2 azali lokola moto oyo azangi mayele ; 
\q2 kosala ekobo ya boye ezali nde komiboma ; 
\q1  
\v 33 akobuka lokola mbuma : minyoko mpe kosambwa ; 
\q2 bongo soni na ye ekosila te. 
\b  
\q1  
\v 34 Pamba te zuwa epelisaka kanda makasi kati na mobali, 
\q2 mpe akozala na mawa te na mokolo 
\q2 oyo akozongisa mabe na mabe ; 
\q1  
\v 35 akotikala kondima ata lifuti moko te 
\q2 mpo ete akoka kolimbisa, 
\q2 mpe akoboya yango ata soki babakisi bakado. 
\c 7  
\s1 Makebisi mpo na mwasi ya ndumba 
\q1  
\v 1 Mwana na ngai, batela mibeko na ngai 
\q2 mpe bomba yango malamu kati na motema na yo. 
\q1  
\v 2 Batela mateya na ngai malamu, mpe okozala na bomoi ; 
\q2 batela mibeko na ngai lokola mbuma ya liso na yo. 
\q1  
\v 3 Lata yango na loboko na yo lokola lopete, 
\q2 koma yango na etando ya motema na yo. 
\q1  
\v 4 Loba na Bwanya : « Ozali ndeko na ngai ya mwasi, » 
\q2 mpe bengaka Mayele « Moninga na ngai ; » 
\q1  
\v 5 mpo ete ekoka kobatela yo liboso ya mwasi ya ndumba 
\q2 mpe ekoka kokebisa yo liboso ya mwasi 
\q2 oyo alobaka maloba ya elengi, nzokande ezali ya lokuta. 
\b  
\q1  
\v 6 Mokolo moko, nazalaki kotala wuta na madusu 
\q2 ya lininisa ya ndako na ngai, 
\q1  
\v 7 namonaki kati na molongo ya bato oyo bazangi mayele, 
\q2 kati na bilenge mibali, 
\q2 elenge mobali moko oyo azangi penza mayele. 
\q1  
\v 8 Azalaki koleka na balabala, 
\q2 pene ya esika oyo mwasi wana ya ndumba avandaka, 
\q1 mpe akotaki na nzela oyo ekenda 
\q2 kino na ndako ya mwasi ya ndumba. 
\q1  
\v 9 Ezalaki na pokwa, tango moyi elimwaki, 
\q2 mpe molili ya butu ekomaki koya. 
\b  
\q1  
\v 10 Mpe tala, mwasi yango ya ndumba ayaki 
\q2 kokutana na elenge mobali, 
\q1 alataki penza lokola mwasi ya ndumba, 
\q2 mpe motema na ye etonda na mayele mabe ; 
\q1  
\v 11 azalaki mwasi ya makelele makasi mpe ya mobulu, 
\q2 makolo na ye evandaka na ndako te, 
\q1  
\v 12 atalaka-talaka na bisika nyonso, 
\q2 tango mosusu na libanda, 
\q2 tango mosusu na bisika oyo bato ebele bakutanaka. 
\q1  
\v 13 Mwasi yango ya ndumba asimbaki elenge mobali, 
\q2 ayambaki ye, alaliselaki ye miso mpe alobaki na ye : 
\q1  
\v 14 « Nazalaki na niongo ya mbeka ya kozongisa 
\q2 matondi epai na Yawe ; 
\q2 mpe lelo, nasili kokokisa ndayi na ngai. 
\q1  
\v 15 Yango wana, nabimaki mpo na kokutana na yo ; 
\q2 nazalaki koluka yo, mpe, tala, namoni yo. 
\q1  
\v 16 Natandi mbeto na ngai na babulangeti 
\q2 ya langi ya ndenge na ndenge, basala na basinga ya lino 
\q2 oyo ewutaka na Ejipito. 
\q1  
\v 17 Na mbeto na ngai, nasopi malasi 
\q2 ya mire, ya aloe mpe ya sinamoni. 
\q1  
\v 18 Yaka tolangwa bolingo kino na tongo, 
\q2 tomipesa mobimba na elengi ya bolingo, 
\q1  
\v 19 pamba te mobali na ngai azali na ye na ndako te, 
\q2 akendeki mobembo na mokili ya mosika, 
\q1  
\v 20 akendeki na saki ya mbongo na maboko, 
\q2 akozonga na ndako te kino na tango 
\q2 oyo sanza engengaka. » 
\b  
\q1  
\v 21 Na nzela ya maloba na ye ya sukali, 
\q2 alongaki kokosa ye ; 
\q2 na nzela ya maloba na ye ya elengi, amemaki ye. 
\b  
\q1  
\v 22 Elenge mobali alandaki ye mbala moko, 
\q2 lokola ngombe oyo bazali komema 
\q1 na bisika oyo babomaka banyama, 
\q2 lokola moto ya liboma oyo bakangi mpo na kobeta ye 
\q1  
\v 23 kino tango likonga ekotobola ye motema, 
\q2 lokola ndeke oyo ekeyi mbangu na motambo 
\q2 na kozanga koyeba ete ekeyi kokufa. 
\b  
\q1  
\v 24 Sik’oyo, mwana na ngai ya mobali, yoka ngai, 
\q2 pesa ngai matoyi na yo mpo na koyoka 
\q2 maloba ya monoko na ngai ! 
\q1  
\v 25 Tika ete mwasi ya boye akumba te motema na yo ! 
\q2 Kopengwa te na banzela na ye, 
\q1  
\v 26 pamba te asili kokweyisa mpe kozokisa bato ebele, 
\q2 mpe asili kobomisa bingambe mibali. 
\q1  
\v 27 Ndako na ye ezali penza nzela ya mboka ya bakufi, 
\q2 oyo ememaka kino na bandako ya kufa. 
\c 8  
\s1 Maloba ya Bwanya 
\q1  
\v 1 Boni, Bwanya azali kobelela te ? 
\q2 Mayele azali koyokisa mongongo na ye te ? 
\q1  
\v 2 Atelemi na songe ya bangomba, na pembeni ya nzela, 
\q2 na bisika oyo banzela ekutana, 
\q1  
\v 3 azali koganga pene ya bikuke, 
\q2 na ekotelo ya engumba : 
\q1  
\v 4 « Bato, nazali koganga makasi epai na bino, 
\q2 nazali nde koloba na bino bato ! 
\q1  
\v 5 Bino bato oyo bozanga mayele, bokoma na bososoli ! 
\q2 Bino bazoba, bokoma mayele ! 
\q1  
\v 6 Boyoka, pamba te nazali na makambo ya motuya 
\q2 ya koyebisa bino, 
\q1 nafungoli monoko na ngai 
\q2 mpo na koloba makambo ya sembo. 
\q1  
\v 7 Pamba te monoko na ngai ebimisaka maloba ya solo, 
\q2 mpe bibebu na ngai eyinaka mabe. 
\q1  
\v 8 Maloba nyonso oyo ebimaka na monoko na ngai 
\q2 ezali sembo, 
\q2 ezalaka na likambo moko te ya lokuta to ya mabe ; 
\q1  
\v 9 nyonso ezali pole mpo na moto ya mayele, 
\q2 mpe sembo mpo na bato oyo bazali na bososoli. 
\q1  
\v 10 Boluka mateya na ngai kasi palata te, 
\q2 boyebi kasi wolo te oyo eleki peto, 
\q1  
\v 11 pamba te bwanya ezali na motuya 
\q2 koleka mayaka ya kitoko, 
\q2 bongo eloko moko te ya motuya ekokani na yango. 
\b  
\q1  
\v 12 Ngai, Bwanya, navandaka elongo na kokanisa, 
\q2 boye nayebi kokundola mayele mpe bososoli. 
\q1  
\v 13 Kotosa Yawe ezali koyina mabe. 
\q2 Nayinaka lolendo, lofundu, nzela ya masumu 
\q2 mpe monoko ya lokuta. 
\q1  
\v 14 Toli mpe bososoli ezali ya ngai, 
\q2 ngai nde mayele mpe makasi. 
\q1  
\v 15 Ezali na nzela na ngai nde bakonzi batambolisaka mokili, 
\q2 mpe bakambi basalaka mibeko ya sembo ; 
\q1  
\v 16 ezali na nzela na ngai nde bakambi, bankumu 
\q2 mpe basambisi nyonso ya mokili bayangelaka. 
\q1  
\v 17 Nalingaka bato oyo balingaka ngai, 
\q2 mpe bato oyo balukaka ngai bamonaka ngai. 
\q1  
\v 18 Bozwi mpe lokumu, 
\q2 bomengo oyo ewumelaka mpe bosembo 
\q2 etambolaka elongo na ngai. 
\q1  
\v 19 Mbuma na ngai ezali kitoko koleka wolo, 
\q2 ezala wolo ya peto, 
\q2 mpe mbuma oyo nabotaka eleki palata ya kitoko. 
\q1  
\v 20 Natambolaka na nzela ya bosembo, 
\q2 mpe nasalelaka banzela oyo ememaka na boyengebene, 
\q1  
\v 21 mpo na kopesa libula epai ya bato oyo balingaka ngai 
\q2 mpe mpo na kotondisa bibombelo na bango. 
\b  
\q1  
\v 22 Yawe asalaki ngai liboso ete asala nyonso, 
\q2 liboso ya misala na Ye nyonso ya kala ; 
\q1  
\v 23 aponaki ngai liboso ete mokili ezala, 
\q2 wuta na ebandeli penza, wuta na tango 
\q2 oyo biloko nyonso ya mokili ezalaki nanu te. 
\q1  
\v 24 Nabotamaki tango mayi ya bozindo ezalaki nanu te, 
\q2 tango miluka ebimisaki nanu mayi na yango te, 
\q1  
\v 25 liboso ete bangomba ya milayi mpe bangomba ya mikuse 
\q2 ezala na bisika na yango, 
\q1  
\v 26 tango amisalelaki nanu te, ezala mabele to bilanga 
\q2 to mpe putulu ya mokili. 
\q1  
\v 27 Nazalaki wana tango atandaki likolo na esika na yango, 
\q2 mpe tango akataki mondelo 
\q2 ya etando monene ya mayi ya bozindo, 
\q1  
\v 28 tango atiaki mapata na likolo 
\q2 mpe abimisaki mayi wuta na bitima, 
\q1  
\v 29 tango akatelaki ebale monene mondelo 
\q2 mpo ete mayi ezindisa mokili na Ye te, 
\q2 tango atiaki miboko ya mabele ; 
\q1  
\v 30 nazalaki pembeni na Ye lokola mosungi, 
\q2 nazalaki kosepelisa ye tango nyonso, 
\q2 mpe nazalaki tango nyonso na esengo liboso na Ye ; 
\q1  
\v 31 nazalaki kosepela kati na mokili na Ye 
\q2 mpe nazalaki na esengo kati na bato. 
\b  
\q1  
\v 32 Sik’oyo, mwana na ngai, yoka ngai : 
\q2 Esengo na bato oyo babatelaka banzela na ngai ! 
\q1  
\v 33 Boyoka mateya na ngai mpe bokokoma bato ya bwanya, 
\q2 bomeka kobwaka yango te ! 
\q1  
\v 34 Esengo na moto oyo ayokelaka ngai, 
\q2 oyo asenzelaka na ekuke na ngai mokolo na mokolo, 
\q2 mpe akengelaka na ekotelo na ngai ! 
\q1  
\v 35 Pamba te moto oyo amoni ngai amoni bomoi 
\q2 mpe azwi ngolu na miso ya Yawe. 
\q1  
\v 36 Kasi moto oyo atosaka ngai te 
\q2 amisalaka mabe ye moko : 
\q2 moto nyonso oyo ayinaka ngai alingaka kufa. » 
\c 9  
\s1 Feti ya Bwanya 
\q1  
\v 1 Bwanya atongi ndako na ye, 
\q2 atelemisi yango na makonzi sambo ; 
\q1  
\v 2 abomi banyama na ye, akamoli masanga na ye ya vino 
\q2 mpe, na sima, atandi mesa. 
\q1  
\v 3 Atindi basali na ye ya basi mpo ete babelela 
\q2 wuta na basonge ya bangomba ya engumba : 
\q1  
\v 4 « Tika ete moto nyonso oyo azangi mayele aya awa ! » 
\q2 Atindi maloba epai ya bato oyo bazangi bososoli : 
\q1  
\v 5 « Boya kolia bilei na ngai 
\q2 mpe komela vino oyo nakamoli, 
\q1  
\v 6 botika nzela na bino ya bozoba mpe bokozala na bomoi, 
\q2 botambola na nzela ya mayele. » 
\b  
\q1  
\v 7 Moto nyonso oyo apamelaka motioli 
\q2 amilukelaka kosambwa, 
\q1 moto nyonso oyo apamelaka moto mabe 
\q2 amilukelaka ngambo. 
\q1  
\v 8 Kopamela motioli te, noki te akoyina yo ; 
\q2 kasi pamela moto ya bwanya, mpe akolinga yo. 
\q1  
\v 9 Teya moto ya bwanya, mpe akokoma lisusu 
\q2 na bwanya koleka ; 
\q2 teya moto ya sembo, mpe akobakisa lisusu boyebi na ye. 
\b  
\q1  
\v 10 Kotosa Yawe ezali mosisa ya bwanya ; 
\q2 koyeba Mosantu, yango nde kozala mayele. 
\q1  
\v 11 Pamba te, na nzela na ngai, 
\q2 mikolo ya bomoi na yo ekokoma ebele, 
\q2 mpe mibu ya bomoi na yo ekobakisama. 
\q1  
\v 12 Soki ozali moto ya bwanya, bwanya na yo ezali 
\q2 mpo na litomba na yo moko ; 
\q2 kasi soki ozali motioli, yo moko kaka nde okomona pasi. 
\s1 Feti ya liboma 
\q1  
\v 13 Mwasi ya zoba azali mwasi ya makelele, 
\q2 ayokaka te mpe azanga mayele, 
\q1  
\v 14 avandaka na ekuke ya ndako na ye, 
\q2 atiaka kiti na ye na bisika ya likolo ya engumba, 
\q1  
\v 15 mpo na kobenga baleki nzela, 
\q2 bato oyo bazali kokende na nzela na bango. 
\q1  
\v 16 Tika ete moto oyo azangi mayele aya awa ! 
\q2 Atindi maloba epai ya bato oyo bazanga bososoli : 
\q1  
\v 17 « Mayi oyo bayibi ezalaka elengi, 
\q2 mpe lipa oyo baliaka na kobombama ezalaka kitoko. » 
\q1  
\v 18 Kasi bayebi te ete epai na ye nde bakufi basanganaka, 
\q2 mpe ete babengami na ye bazali kati na mokili ya bakufi. 
\c 10  
\s1 Masese ya Salomo 
\p  
\v 1 Masese ya Salomo : 
\q1 Mwana ya bwanya asepelisaka tata na ye, 
\q2 kasi mwana ya zoba ayokisaka 
\q2 mama na ye pasi na motema. 
\b  
\q1  
\v 2 Bomengo oyo ezwami na nzela ya mabe 
\q2 epesaka litomba te, 
\q2 kasi bosembo ekangolaka na kufa. 
\b  
\q1  
\v 3 Yawe atikaka te ete moto ya sembo akufa nzala, 
\q2 kasi apimelaka bato mabe biloko oyo bazali na yango posa. 
\b  
\q1  
\v 4 Maboko ya goyigoyi ekomisaka moto mobola, 
\q2 kasi maboko oyo esalaka ekomisaka moto mozwi. 
\b  
\q1  
\v 5 Moto oyo abombaka biloko na eleko ya mvula azali mwana mayele, 
\q2 kasi moto oyo alalaka pongi na eleko ya kobuka mbuma 
\q2 azali mwana ya soni. 
\b  
\q1  
\v 6 Mapamboli ezali na likolo 
\q2 ya moto ya moto ya sembo lokola motole, 
\q2 kasi monoko ya moto mabe ebombaka bitumba. 
\b  
\q1  
\v 7 Makanisi ya moto ya sembo ezali na lipamboli, 
\q2 kasi bakobosana kombo ya moto mabe. 
\b  
\q1  
\v 8 Motema ya bwanya endimaka mibeko, 
\q2 kasi moto oyo alobaka makambo ya bozoba 
\q2 amilukelaka libebi. 
\b  
\q1  
\v 9 Moto ya sembo atambolaka na kimia, 
\q2 kasi moto oyo atambolaka na banzela etengama-tengama 
\q2 akobima na pwasa. 
\b  
\q1  
\v 10 Moto oyo afinaka liso na mayele mabe alukaka mobulu, 
\q2 kasi moto oyo apamelaka na bosolo alukaka kimia. 
\b  
\q1  
\v 11 Monoko ya moto ya sembo ezali etima ya bomoi, 
\q2 kasi monoko ya moto mabe ebombaka makambo mabe. 
\b  
\q1  
\v 12 Koyina ebendaka koswana, 
\q2 kasi bolingo ezipaka mabe. 
\b  
\q1  
\v 13 Bibebu ya moto ya mayele ezalaka na bwanya, 
\q2 kasi fimbu ezali malamu 
\q2 mpo na mokongo ya moto oyo azangi mayele. 
\b  
\q1  
\v 14 Moto ya bwanya abombaka boyebi, 
\q2 kasi monoko ya zoba ebendaka pasi. 
\b  
\q1  
\v 15 Bomengo ya mozwi ezali engumba na ye, 
\q2 oyo batonga makasi, 
\q2 kasi bobola ya bato bakelela ezali libebi na bango. 
\b  
\q1  
\v 16 Lifuti ya moto ya sembo ememaka ye na bomoi, 
\q2 kasi lifuti ya moto mabe ememaka na lisumu. 
\b  
\q1  
\v 17 Moto oyo ayokaka pamela atambolaka na nzela ya bomoi, 
\q2 kasi moto oyo ayokaka pamela te 
\q2 apengwisaka bato mosusu. 
\b  
\q1  
\v 18 Moto oyo abombaka koyina kati na motema na ye 
\q2 azali na bibebu ya lokuta, 
\q2 mpe moto oyo atongaka bato azali zoba. 
\b  
\q1  
\v 19 Moto oyo alobaka maloba ebele 
\q2 azangaka te kosala masumu, 
\q1 kasi moto oyo abatelaka bibebu na ye 
\q2 azali moto ya bwanya. 
\b  
\q1  
\v 20 Lolemo ya moto ya sembo ezali lokola palata ya talo, 
\q2 kasi motema ya moto mabe ezali na tina te. 
\b  
\q1  
\v 21 Bibebu ya moto ya sembo ebikisaka bato ebele, 
\q2 kasi zoba akokufa na bozoba na ye. 
\b  
\q1  
\v 22 Lipamboli ya Yawe ekomisaka moto mozwi, 
\q2 mpe abakisaka pasi te na likolo na yango. 
\b  
\q1  
\v 23 Kosala mabe esepelisaka moto oyo azangi mayele, 
\q2 kasi bwanya esepelisaka moto ya mayele. 
\b  
\q1  
\v 24 Makambo oyo moto mabe abangaka, 
\q2 yango kaka nde ekomelaka ye, 
\q2 kasi baposa ya moto ya sembo ekokokisama. 
\b  
\q1  
\v 25 Ndenge mbonge elekaka, 
\q2 ndenge wana mpe moto mabe akozala lisusu te, 
\q1 kasi moto ya sembo akotikala 
\q2 lokola moboko mpo na libela. 
\b  
\q1  
\v 26 Ndenge masanga ya ngayi esalaka minu ngayi, 
\q2 mpe molinga esalaka miso pasi, 
\q1 ndenge wana mpe moto ya goyigoyi azalaka 
\q2 epai ya bato oyo batindaka ye pasi. 
\b  
\q1  
\v 27 Kotosa Yawe eyeisaka bomoi molayi, 
\q2 kasi bomoi ya bato mabe ekokoma mokuse. 
\b  
\q1  
\v 28 Elikya ya moto ya sembo ekosuka na esengo, 
\q2 kasi elikya ya moto mabe ekosuka na pamba. 
\b  
\q1  
\v 29 Nzela ya Yawe ezali ekimelo ya makasi 
\q2 mpo na bato oyo batambolaka na boyengebene, 
\q2 kasi ezali nde libebi mpo na bato oyo basalaka mabe. 
\b  
\q1  
\v 30 Moto ya sembo akotikala kokweya te, 
\q2 kasi bato mabe bakovanda na mokili te. 
\b  
\q1  
\v 31 Monoko ya moto ya sembo epesaka bwanya, 
\q2 kasi lolemo ya lokuta ekokatama. 
\b  
\q1  
\v 32 Bibebu ya moto ya sembo eyebaka makambo 
\q2 oyo ezali malamu, 
\q1 kasi monoko ya moto mabe ezalaka kaka 
\q2 na makambo mabe. 
\b  
\c 11  
\q1  
\v 1 Bimekelo kilo ya lokuta ezali lokola makambo ya nkele 
\q2 na miso ya Yawe, 
\q2 kasi kilo ya sembo ezali elengi na miso na Ye. 
\b  
\q1  
\v 2 Tango lolendo eyaka, soni mpe eyaka, 
\q2 kasi bwanya ezali elongo na bato oyo bamikitisaka. 
\q1  
\v 3 Boyengebene ya bato ya sembo etambolisaka bango, 
\q2 kasi mayele mabe ya bato oyo batambolaka 
\q2 na boyengebene te ebebisaka bango. 
\b  
\q1  
\v 4 Bomengo ekolongisa ata moke te 
\q2 na mokolo ya kanda ya Nzambe, 
\q2 kasi bosembo ekangolaka na kufa. 
\b  
\q1  
\v 5 Bosembo ya moto oyo atambolaka alima 
\q2 ekomisaka nzela na ye sembo, 
\q2 kasi moto mabe akokweya mpo na mabe na ye moko. 
\b  
\q1  
\v 6 Bosembo ya bato oyo batambolaka alima 
\q2 ekangolaka bango, 
\q1 kasi bato oyo batambolaka na boyengebene te 
\q2 bakweyaka na motambo ya baposa na bango. 
\b  
\q1  
\v 7 Soki moto mabe akufi, elikya na ye mpe ekufi ; 
\q2 boye, elikya nyonso oyo etiami na bomengo na ye 
\q2 mpe ekufi. 
\b  
\q1  
\v 8 Moto ya sembo akokangolama na pasi, 
\q2 mpe moto mabe akomona pasi 
\q2 na esika ya moto ya sembo. 
\b  
\q1  
\v 9 Moto ya mbindo abebisaka moninga na ye 
\q2 na maloba ya monoko na ye, 
\q2 kasi boyebi ekokangola bato ya sembo. 
\b  
\q1  
\v 10 Tango bato ya sembo bapambolamaka, 
\q2 engumba esepelaka ; 
\q1 mpe tango moto mabe akufaka, 
\q2 bato bagangaka na esengo. 
\b  
\q1  
\v 11 Engumba etongamaka na nzela ya mapamboli 
\q2 ya bato ya sembo, 
\q2 kasi ebebisamaka na nzela ya monoko ya bato mabe. 
\b  
\q1  
\v 12 Moto oyo atiolaka moninga na ye azangi mayele, 
\q2 kasi moto ya mayele avandaka kimia. 
\b  
\q1  
\v 13 Moto oyo aswanaka abimisaka basekele, 
\q2 kasi moto oyo azali na molimo ya sembo 
\q2 abombaka basekele. 
\b  
\q1  
\v 14 Mpo na kozanga koyeba kokamba, ekolo ekokweya ; 
\q2 kasi lobiko ezali kati na motango ebele ya bapesi toli. 
\b  
\q1  
\v 15 Moto oyo abetaka tolo mpo na kondima 
\q2 baniongo ya mopaya akomona solo pasi, 
\q2 kasi moto oyo aboyaka kozwa bikateli akozala na kimia. 
\b  
\q1  
\v 16 Mwasi ya malamu azwaka lokumu, 
\q2 mpe bato ya makasi bazwaka bomengo. 
\b  
\q1  
\v 17 Moto oyo asalelaka bato bolamu amisalelaka nde bolamu, 
\q2 kasi moto na kanza amimonisaka pasi. 
\b  
\q1  
\v 18 Moto mabe asalaka mosala na lokuta, 
\q2 kasi moto oyo alonaka na bosembo 
\q2 akozwa lifuti ya malonga. 
\b  
\q1  
\v 19 Lokola bosembo ememaka na bomoi, 
\q2 moto oyo alandaka nzela ya mabe 
\q2 alandaka nde nzela ya kufa. 
\b  
\q1  
\v 20 Bato ya kilikili bazalaka nkele na miso ya Yawe, 
\q2 kasi bato oyo bazangi pamela basepelisaka Ye. 
\b  
\q1  
\v 21 Moto mabe akosambisama solo, 
\q2 kasi bakitani ya bayengebene bakokangolama. 
\b  
\q1  
\v 22 Mwasi ya kitoko, kasi azangi mayele, 
\q2 azali lokola lopete ya wolo na zolo ya ngulu. 
\b  
\q1  
\v 23 Baposa ya moto ya sembo esukaka kaka malamu, 
\q2 nzokande elikya ya moto mabe ezelaka kaka 
\q2 kanda ya Nzambe. 
\b  
\q1  
\v 24 Moto oyo akabaka na motema malamu 
\q2 azwaka mingi koleka, 
\q2 mpe moto oyo abombaka kaka akomaka mobola. 
\b  
\q1  
\v 25 Moto oyo akabaka akokoma na bomengo ; 
\q2 mpe moto oyo apesaka bato mosusu mayi, 
\q2 ye mpe bakopesa ye mayi. 
\b  
\q1  
\v 26 Moto oyo abombaka ble, bato bakolakela ye mabe ; 
\q2 kasi lipamboli ezali epai na moto oyo akoteka yango. 
\b  
\q1  
\v 27 Moto oyo alukaka kosala bolamu akozwa ngolu, 
\q2 kasi pasi ekomelaka moto oyo alukaka kosala mabe. 
\b  
\q1  
\v 28 Moto oyo atiaka elikya na bomengo na ye akokweya, 
\q2 kasi bayengebene bakozala kitoko lokola makasa ya sika. 
\b  
\q1  
\v 29 Moto oyo akotisaka mobulu kati na ndako na ye 
\q2 akozwa mopepe lokola libula, 
\q1 mpe moto oyo azangi mayele 
\q2 akokoma mowumbu ya moto ya bwanya. 
\b  
\q1  
\v 30 Mbuma ya moto ya sembo ezali nzete ya bomoi, 
\q2 mpe moto ya bwanya abengaka bato pene na ye. 
\b  
\q1  
\v 31 Soki moto ya sembo azwaka litomba na ye awa na mokili, 
\q2 ekozala boni mpo na moto mabe mpe mosumuki ? 
\b  
\c 12  
\q1  
\v 1 Moto oyo alingaka koyekola alingaka boyebi, 
\q2 kasi moto oyo aboyaka pamela azali zoba. 
\b  
\q1  
\v 2 Moto ya malamu azwaka ngolu na miso ya Yawe, 
\q2 kasi Nzambe akatelaka moto ya mayele mabe etumbu. 
\b  
\q1  
\v 3 Motema mabe elendisaka moto te ; 
\q2 mosisa ya bato ya sembo ekatanaka te. 
\b  
\q1  
\v 4 Mwasi ya malamu azali motole ya mobali na ye, 
\q2 kasi mwasi oyo ayokisaka soni azali lokola bokono 
\q2 oyo ezali kolia mikuwa. 
\b  
\q1  
\v 5 Mabongisi ya bayengebene ezalaka ya sembo, 
\q2 kasi makanisi ya bato mabe ezalaka kaka lokuta. 
\b  
\q1  
\v 6 Maloba ya bato mabe ezali mitambo 
\q2 mpo na kosopa makila, 
\q2 kasi maloba ya bayengebene ebikisaka bango. 
\b  
\q1  
\v 7 Bato mabe bakokweyisama mpe bakozala lisusu te, 
\q2 kasi ndako ya bayengebene ekowumela seko. 
\b  
\q1  
\v 8 Bwanya epesaka moto lokumu, 
\q2 kasi motema mabe ememaka kotiolama. 
\b  
\q1  
\v 9 Eleki malamu kozala moto pamba mpe kozala na mosali, 
\q2 na esika ya komimona moto monene mpe kozanga bilei. 
\b  
\q1  
\v 10 Moto ya sembo ayebaka ata baposa ya bibwele na ye, 
\q2 kasi motema ya moto mabe eyokaka mawa te. 
\b  
\q1  
\v 11 Moto oyo asalaka bilanga atondaka na bilei, 
\q2 kasi moto oyo alandaka bagoyigoyi azangi mayele. 
\b  
\q1  
\v 12 Moto mabe alingaka misuni ya bato mabe, 
\q2 kasi mosisa ya bayengebene ebotaka mingi. 
\b  
\q1  
\v 13 Moto ya misala mabe akangamaka na motambo 
\q2 ya maloba na ye ya lokuta, 
\q2 kasi moyengebene akobika kati na pasi. 
\b  
\q1  
\v 14 Na nzela ya mbuma ya monoko na ye, 
\q2 moto akotondisama na bolamu ; 
\q2 mpe moto akozwa lifuti ya misala ya maboko na ye. 
\b  
\q1  
\v 15 Nzela ya moto oyo azangi mayele emonanaka alima 
\q2 na miso na ye, 
\q2 kasi moto oyo ayokaka toli azali moto ya bwanya. 
\b  
\q1  
\v 16 Kotomboka ya moto oyo azangi mayele eyebanaka 
\q2 kaka mokolo wana, 
\q2 kasi moto ya mayele abombaka soni na ye. 
\b  
\q1  
\v 17 Motatoli ya malamu apesaka matatoli ya solo, 
\q2 kasi motatoli ya mabe apesaka matatoli ya lokuta. 
\b  
\q1  
\v 18 Maloba ya bato oyo balobaka mingi ezokisaka 
\q2 lokola mopanga, 
\q1 kasi lolemo ya bato ya bwanya ezali 
\q2 lokola mafuta oyo ebikisaka. 
\b  
\q1  
\v 19 Moto oyo alobaka solo akowumela mpo na libela, 
\q2 kasi mokosi akowumela kaka mpo na tango moke. 
\b  
\q1  
\v 20 Lokuta ezalaka kati na mitema ya bato 
\q2 oyo basalaka mabongisi ya mabe, 
\q1 kasi esengo ezali mpo na bato 
\q2 oyo bakopesaka batoli ya kimia. 
\b  
\q1  
\v 21 Mabe moko te ekokomela bayengebene, 
\q2 kasi bato mabe bakotondisama na pasi. 
\b  
\q1  
\v 22 Bibebu oyo ekosaka ezali nkele na miso ya Yawe, 
\q2 kasi bibebu oyo ekokisaka bosembo 
\q2 ezalaka elengi na miso na Ye. 
\b  
\q1  
\v 23 Moto ya mayele abombaka boyebi, 
\q2 kasi motema ya zoba etatolaka makambo ya bozoba. 
\b  
\q1  
\v 24 Maboko oyo esalaka ezwaka bokonzi, 
\q2 kasi maboko ya goyigoyi ememaka na bowumbu. 
\b  
\q1  
\v 25 Motema oyo etondi na komitungisa ekobuka moto, 
\q2 kasi liloba ya esengo esepelisaka moto. 
\b  
\q1  
\v 26 Moyengebene alakisaka baninga na ye nzela, 
\q2 kasi nzela ya moto mabe ebungisaka ye moko moto mabe. 
\b  
\q1  
\v 27 Moto ya goyigoyi azangaka bilei, 
\q2 mpe moto ya nzunzu akomaka mozwi monene. 
\b  
\q1  
\v 28 Bomoi ezalaka kati na nzela ya bosembo, 
\q2 mpe kufa ezalaka te kati na nzela ya bosembo. 
\b  
\c 13  
\q1  
\v 1 Mwana mayele ayokaka mateya ya tata na ye, 
\q2 kasi mwana oyo atiolaka ayokaka pamela te. 
\b  
\q1  
\v 2 Mbuma ya monoko eleisaka moto bilei ya malamu, 
\q2 kasi molimo ya moto oyo atambolaka na bosembo te 
\q2 ememaka na mobulu. 
\b  
\q1  
\v 3 Moto oyo abatelaka monoko na ye 
\q2 abatelaka molimo na ye, 
\q1 kasi moto oyo afungolaka monoko na ye makasi 
\q2 akosuka na libebi. 
\b  
\q1  
\v 4 Moto ya goyigoyi ayokaka baposa, 
\q2 kasi akoki kokokisa yango te ; 
\q2 nzokande baposa ya moto ya nzunzu ekokisamaka. 
\b  
\q1  
\v 5 Moto ya sembo ayinaka maloba ya lokuta, 
\q2 kasi moto mabe amiyinisaka mpe apanzaka soni. 
\b  
\q1  
\v 6 Bosembo ebatelaka moto oyo atambolaka 
\q2 alima na nzela na ye, 
\q2 kasi mabe ebebisaka bongo ya moto ya masumu. 
\b  
\q1  
\v 7 Ezali na moto moko oyo asalaka makambo lokola mozwi, 
\q2 nzokande azali na ye ata na eloko moko te ; 
\q1 mpe ezali na moto mosusu oyo asalaka 
\q2 makambo lokola mobola, 
\q2 nzokande azali na bozwi mingi. 
\b  
\q1  
\v 8 Bomengo ya mozwi ebatelaka bomoi na ye, 
\q2 kasi bato mabe batungisaka mobola te. 
\b  
\q1  
\v 9 Pole ya bato ya sembo engengaka makasi, 
\q2 kasi mwinda ya bato mabe ekufaka. 
\b  
\q1  
\v 10 Lolendo ememaka kaka na koswana, 
\q2 kasi bato oyo bayokaka toli bazwaka bwanya. 
\b  
\q1  
\v 11 Bomengo oyo ezwami na lombangu 
\q2 mpe na nzela ya mabe esilaka noki, 
\q1 kasi bomengo oyo babakisaka na moke-moke 
\q2 ekomaka ebele. 
\b  
\q1  
\v 12 Elikya oyo ekokisami te epesaka bokono na motema, 
\q2 kasi posa oyo ekokisami ezali nzete ya bomoi. 
\b  
\q1  
\v 13 Moto oyo atiolaka liloba amiyokisaka pasi, 
\q2 kasi moto oyo atosaka malako akozwa lifuti. 
\b  
\q1  
\v 14 Mateya ya moto ya bwanya ezali etima ya bomoi, 
\q2 ekangolaka na mitambo ya kufa. 
\b  
\q1  
\v 15 Boyebi ememelaka bato ngolu, 
\q2 kasi nzela ya bato oyo babukaka mibeko ezalaka pasi. 
\b  
\q1  
\v 16 Moto ya mayele asalaka makambo kolanda boyebi, 
\q2 kasi zoba, atandaka bozoba na ye. 
\b  
\q1  
\v 17 Motindami ya mabe akweyaka kati na pasi, 
\q2 kasi motindami ya sembo amemaka lobiko. 
\b  
\q1  
\v 18 Bobola mpe soni ekomelaka bato oyo baboyaka koyekola, 
\q2 kasi moto oyo andimaka pamela akozwa lokumu. 
\b  
\q1  
\v 19 Posa oyo ekokisami esalaka esengo na motema, 
\q2 kasi kokabwana na mabe ezali likambo ya nkele 
\q2 na miso ya zoba. 
\b  
\q1  
\v 20 Moto oyo asanganaka na bato ya bwanya 
\q2 akomaka moto ya bwanya, 
\q1 kasi moto oyo atambolaka nzela moko na bazoba 
\q2 akomona pasi. 
\b  
\q1  
\v 21 Mabe elandaka bato ya masumu, 
\q2 kasi bolamu ezali lifuti ya bato ya sembo. 
\b  
\q1  
\v 22 Moto oyo asalaka bolamu atikelaka bakitani na ye libula, 
\q2 kasi bomengo ya moto ya masumu ebombamaka 
\q2 mpo na moyengebene. 
\b  
\q1  
\v 23 Bilanga ya mobola ekoki kobotela ye bilei ebele, 
\q2 kasi ezali na bato oyo bazali kobeba 
\q2 mpo na kozanga bosembo. 
\b  
\q1  
\v 24 Moto oyo aboyaka kobeta mwana na ye fimbu 
\q2 alingaka ye te, 
\q2 kasi moto oyo alingaka mwana na ye abetaka ye. 
\b  
\q1  
\v 25 Moyengebene aliaka mpe atondaka, 
\q2 kasi libumu ya moto mabe ezalaka na nzala. 
\b  
\c 14  
\q1  
\v 1 Mwasi ya bwanya atongaka ndako na ye, 
\q2 kasi mwasi oyo azangi mayele abukaka yango 
\q2 na maboko na ye moko. 
\b  
\q1  
\v 2 Moto oyo atambolaka alima atosaka Yawe, 
\q2 kasi moto oyo nzela na ye etengama-tengama atiolaka Ye. 
\b  
\q1  
\v 3 Kati na monoko ya moto oyo azangi mayele, 
\q2 ezalaka na nzete ya lolendo, 
\q2 kasi bibebu ya moto ya bwanya ebatelaka ye. 
\b  
\q1  
\v 4 Esika oyo ezalaka na ngombe te, 
\q2 elielo mpe ezalaka na eloko te, 
\q2 pamba te ezali makasi ya bangombe nde epesaka bomengo. 
\b  
\q1  
\v 5 Motatoli ya sembo akosaka te, 
\q2 kasi motatoli ya mabe alobaka lokuta. 
\b  
\q1  
\v 6 Motioli alukaka bwanya mpe azwaka yango te, 
\q2 kasi boyebi eyaka na pete epai na moto ya mayele. 
\b  
\q1  
\v 7 Zala mosika ya zoba, 
\q2 pamba te okotikala kozwa boyebi te na bibebu na ye. 
\b  
\q1  
\v 8 Bwanya ya moto ya mayele esosolisaka ye nzela na ye, 
\q2 kasi bozoba ya bato oyo bazangi mayele : lokuta. 
\b  
\q1  
\v 9 Bazoba balingaka te kosenga bolimbisi, 
\q2 kasi ngolu na Nzambe ezalaka kati na bato ya sembo. 
\b  
\q1  
\v 10 Motema eyebaka pasi na yango moko, 
\q2 moko te akoki kokabola na yango esengo. 
\b  
\q1  
\v 11 Ndako ya moto mabe ekobukana, 
\q2 kasi ndako ya kapo ya bayengebene ekofuluka. 
\b  
\q1  
\v 12 Nzela mosusu emonanaka sembo na miso ya bato, 
\q2 nzokande, na suka, ememaka na kufa. 
\b  
\q1  
\v 13 Ezala kati na koseka, motema ekoki kozala na mawa, 
\q2 mpe esengo ekoki kosuka na mawa. 
\b  
\q1  
\v 14 Bato oyo batambolaka na boyengebene te 
\q2 bakozwa lifuti kolanda misala na bango, 
\q1 kasi moto ya sembo mpe akozwa lifuti 
\q2 kolanda misala na ye. 
\b  
\q1  
\v 15 Moto oyo azangi mayele andimaka 
\q2 makambo nyonso oyo balobaka, 
\q2 kasi moto ya mayele atambolaka na bokebi. 
\b  
\q1  
\v 16 Moto ya bwanya abangaka mabe mpe akimaka yango, 
\q2 kasi zoba atombokaka, na elikya nyonso. 
\b  
\q1  
\v 17 Moto oyo asilikaka noki asalaka makambo ya bozoba, 
\q2 mpe bayinaka moto ya mayele mabe. 
\b  
\q1  
\v 18 Bato oyo bazangi mayele bazwaka bozoba lokola libula, 
\q2 kasi bato ya mayele bazwaka boyebi lokola motole. 
\b  
\q1  
\v 19 Bato mabe bakofukama liboso ya bato ya malamu, 
\q2 bato ya mitema mabe bakofukama 
\q2 na ekuke ya bato ya sembo. 
\b  
\q1  
\v 20 Mobola ayinamaka ata epai na moninga na ye moko, 
\q2 kasi mozwi azalaka na baninga ebele. 
\b  
\q1  
\v 21 Moto oyo atiolaka moninga na ye asalaka lisumu, 
\q2 kasi esengo na moto oyo asalaka bato bakelela bolamu. 
\b  
\q1  
\v 22 Boni, bato oyo babongisaka kosala mabe 
\q2 bazali na libunga te ? 
\q1 Kasi boboto mpe solo ezali epai ya bato 
\q2 oyo babongisaka kosala bolamu. 
\b  
\q1  
\v 23 Mosala nyonso epesaka litomba, 
\q2 kasi maloba ya pamba ememaka na bobola. 
\b  
\q1  
\v 24 Bozwi ya bato ya bwanya ezalaka 
\q2 lokola motole na bango, 
\q1 kasi bozoba ya bato oyo bazangi mayele ezalaka 
\q2 lokola liboma. 
\b  
\q1  
\v 25 Motatoli oyo alobaka solo abikisaka bato ebele, 
\q2 kasi motatoli ya mabe alobaka lokuta. 
\b  
\q1  
\v 26 Moto oyo atosaka Yawe akomaka na kondima makasi, 
\q2 mpe bana na ye bakozwa ekimelo. 
\b  
\q1  
\v 27 Kotosa Yawe ezali etima ya bomoi, 
\q2 ekangolaka na mitambo ya kufa. 
\b  
\q1  
\v 28 Kozala na bato ebele epesaka mokonzi lokumu, 
\q2 kasi mokonzi akweyaka soki azali na bato te. 
\b  
\q1  
\v 29 Moto oyo asilikaka noki te azalaka mayele, 
\q2 kasi moto oyo akangaka motema te abimisaka 
\q2 bozoba na ye. 
\b  
\q1  
\v 30 Motema oyo ezali na kimia epesaka bomoi na nzoto, 
\q2 kasi bilulela epolisaka mikuwa. 
\b  
\q1  
\v 31 Moto oyo anyokolaka mobola atiolaka 
\q2 Mokeli ya mobola yango, 
\q1 kasi moto oyo asalelaka moto akelela bolamu 
\q2 apesaka Ye lokumu. 
\b  
\q1  
\v 32 Babenganaka moto mabe mpo na mabe na ye, 
\q2 kasi moto ya sembo awumelaka na elikya kino ata na kufa. 
\b  
\q1  
\v 33 Bwanya ewumelaka kati na motema ya moto 
\q2 oyo azali na bososoli ; 
\q2 kasi boni, ekoyebana solo kati na bazoba ? 
\b  
\q1  
\v 34 Bosembo etombolaka ekolo, 
\q2 kasi lisumu ememelaka bato soni. 
\b  
\q1  
\v 35 Mokonzi asepelaka na mosali ya bwanya, 
\q2 kasi mosali oyo ayokisaka ye soni apelisaka kanda na ye. 
\b  
\c 15  
\q1  
\v 1 Eyano ya kimia ekimisaka kanda, 
\q2 kasi maloba oyo ezokisaka ebakisaka kanda. 
\b  
\q1  
\v 2 Lolemo ya moto ya bwanya ekomisaka boyebi elengi, 
\q2 kasi monoko ya bato oyo bazangi mayele 
\q2 ebimisaka bozoba. 
\b  
\q1  
\v 3 Miso na Yawe ezalaka bisika nyonso 
\q2 mpo na kotala bato mabe mpe bato ya malamu. 
\b  
\q1  
\v 4 Maloba ya kimia ezali lokola nzete ya bomoi, 
\q2 kasi maloba ya botomboki ezokisaka motema. 
\b  
\q1  
\v 5 Moto oyo azangi mayele atiolaka mateya ya tata na ye, 
\q2 kasi moto oyo andimaka pamela akokoma mayele. 
\b  
\q1  
\v 6 Ezalaka na bomengo ebele kati na ndako ya moyengebene, 
\q2 kasi lifuti ya moto mabe ememaka pasi. 
\b  
\q1  
\v 7 Bibebu ya moto ya bwanya esopaka boyebi, 
\q2 kasi ezali bongo te na motema ya zoba. 
\b  
\q1  
\v 8 Mbeka ya moto mabe ezalaka nkele na miso ya Yawe, 
\q2 kasi libondeli ya moto ya sembo esepelisaka Ye. 
\b  
\q1  
\v 9 Nzela ya moto mabe ezalaka nkele na miso ya Yawe, 
\q2 kasi alingaka moto oyo alandaka nzela ya sembo. 
\b  
\q1  
\v 10 Moto oyo abimaka libanda ya nzela ya sembo 
\q2 akozwa pamela ya makasi ; 
\q2 moto oyo aboyaka pamela akokufa. 
\b  
\q1  
\v 11 Ndenge mboka ya bakufi mpe mokili ya mozindo 
\q2 ezali penza polele liboso ya Yawe, 
\q1 ndenge wana mpe mitema ya bana ya bato 
\q2 ezali polele liboso na Ye. 
\b  
\q1  
\v 12 Moto ya moto makasi alingaka te moto oyo apamelaka ye, 
\q2 yango wana akendaka te epai ya bato ya bwanya. 
\b  
\q1  
\v 13 Motema ya esengo engengisaka elongi, 
\q2 kasi motema ya mawa elembisaka molimo. 
\b  
\q1  
\v 14 Motema ya moto ya mayele elukaka boyebi, 
\q2 kasi monoko ya zoba ebimisaka kaka bozoba. 
\b  
\q1  
\v 15 Mikolo nyonso ezalaka mabe 
\q2 mpo na moto oyo azali na pasi, 
\q1 kasi bomoi ya moto oyo azali na esengo ezalaka 
\q2 tango nyonso na feti. 
\b  
\q1  
\v 16 Kozala na eloko moko kati na kotosa Yawe ezali malamu 
\q2 koleka kozala na bomengo mingi kati na komitungisa. 
\b  
\q1  
\v 17 Kolia ndunda kati na bolingo ezali malamu 
\q2 koleka kolia ngombe ya mafuta kati na koyina. 
\b  
\q1  
\v 18 Moto oyo atombokaka noki ayeisaka koswana, 
\q2 kasi moto oyo akangaka motema akitisaka koswana. 
\b  
\q1  
\v 19 Nzela ya moto ya goyigoyi ezalaka 
\q2 lokola banzela mike ya banzube, 
\q2 kasi nzela ya bato ya sembo ezalaka ya kosembolama. 
\b  
\q1  
\v 20 Mwana ya bwanya asepelisaka tata na ye, 
\q2 kasi moto oyo azangi mayele atiolaka mama na ye. 
\b  
\q1  
\v 21 Bozoba esepelisaka moto oyo azangi mayele, 
\q2 kasi moto ya mayele atambolaka alima na nzela na ye. 
\b  
\q1  
\v 22 Mabongisi ekokisamaka te soki bato basangani te 
\q2 mpo na kopesa mayele, 
\q2 kasi ekokisamaka malamu soki bapesi toli bazali ebele. 
\b  
\q1  
\v 23 Kozongisa eyano ya malamu epesaka moto esengo, 
\q2 mpe liloba oyo elobami na tango oyo ekoki ezalaka kitoko. 
\b  
\q1  
\v 24 Nzela ya bomoi ememaka moto ya bwanya na likolo, 
\q2 mpo na kobatela ye ete akita na mboka ya bakufi te. 
\b  
\q1  
\v 25 Yawe abukaka ndako ya moto ya lolendo, 
\q2 kasi alendisaka libula ya mwasi oyo akufisa mobali. 
\b  
\q1  
\v 26 Makanisi ya moto mabe ezalaka nkele na miso ya Yawe, 
\q2 kasi maloba ya malamu ezalaka peto na miso na Ye. 
\b  
\q1  
\v 27 Moto oyo alukaka litomba na nzela ya sembo te 
\q2 amemaka mitungisi na libota na ye, 
\q2 kasi moto oyo aboyaka kanyaka akozala na bomoi. 
\b  
\q1  
\v 28 Motema ya moyengebene ekanisaka 
\q2 liboso ya kopesa eyano, 
\q2 kasi monoko ya moto mabe ebimisaka maloba ya mabe. 
\b  
\q1  
\v 29 Yawe azalaka mosika ya bato mabe, 
\q2 kasi ayokaka libondeli ya bayengebene. 
\b  
\q1  
\v 30 Eloko oyo esepelisaka miso esepelisaka mpe motema ; 
\q2 sango malamu elendisaka mikuwa. 
\b  
\q1  
\v 31 Moto oyo ayokaka pamela oyo epesaka bomoi 
\q2 avandaka kati na bato ya bwanya. 
\b  
\q1  
\v 32 Moto oyo asundolaka koyekola 
\q2 atiolaka nde bomoi na ye moko, 
\q2 kasi moto oyo andimaka pamela akomaka mayele. 
\b  
\q1  
\v 33 Kotosa Yawe ezali eteyelo ya bwanya ; 
\q2 komikitisa eyaka liboso ya nkembo. 
\b  
\c 16  
\q1  
\v 1 Motema ya moto esalaka mabongisi, 
\q2 kasi eyano ewutaka epai na Yawe. 
\b  
\q1  
\v 2 Nzela nyonso ya moto emonanaka peto na miso na ye, 
\q2 kasi Yawe nde amekaka mitema. 
\b  
\q1  
\v 3 Pesa misala na yo epai na Yawe, 
\q2 mpe mabongisi na yo ekokokisama. 
\b  
\q1  
\v 4 Yawe asalaka makambo nyonso na tina, 
\q2 ezala bato mabe, asala bango mpo na mokolo ya pasi. 
\b  
\q1  
\v 5 Moto nyonso ya lolendo azalaka nkele na miso ya Yawe ; 
\q2 solo, akozanga te kozwa etumbu. 
\b  
\q1  
\v 6 Bolingo mpe bosembo elongolaka mbeba ; 
\q2 kotosa Yawe etindaka moto kokima mabe. 
\b  
\q1  
\v 7 Soki Yawe asepeli na nzela ya moto, 
\q2 akoyokanisa ye na banguna na ye. 
\b  
\q1  
\v 8 Kozwa biloko moke kati na bosembo ezali malamu 
\q2 koleka kozwa bomengo ebele kati na nzela ya mabe. 
\b  
\q1  
\v 9 Motema ya moto esalaka mabongisi, 
\q2 kasi ezali Yawe nde asalaka ete ekokisama to te. 
\b  
\q1  
\v 10 Maloba ya mokonzi ezali lokola Liloba na Nzambe, 
\q2 ekweyaka te kati na kosambisama. 
\b  
\q1  
\v 11 Emekelo kilo ya sembo mpe basani oyo bamekelaka kilo 
\q2 ezali ya Yawe, 
\q2 mpe kilo nyonso ya saki ezali likambo na Ye. 
\b  
\q1  
\v 12 Ezali malamu te mpo na mokonzi kosala mabe, 
\q2 pamba te bokonzi elendisamaka nde na nzela ya bosembo. 
\b  
\q1  
\v 13 Bakonzi balingaka maloba ya solo, 
\q2 mpe bapesaka moto oyo alobaka na bosembo lokumu. 
\b  
\q1  
\v 14 Kanda ya mokonzi ememaka na kufa, 
\q2 kasi moto ya bwanya ayebaka kokitisa yango. 
\b  
\q1  
\v 15 Soki elongi ya mokonzi ezali kongenga, 
\q2 elingi koloba : bomoi. 
\q1 Bolamu na ye ezali lokola lipata ya mvula ya eleko ya suka. 
\b  
\q1  
\v 16 Bwanya ezali malamu koleka wolo, 
\q2 mpe kozwa mayele ezali na litomba koleka palata. 
\b  
\q1  
\v 17 Bato ya sembo batambolaka 
\q2 na nzela oyo epesaka mabe mokongo. 
\q1 Moto oyo abatelaka motema na ye 
\q2 abatelaka nde bomoi na ye. 
\b  
\q1  
\v 18 Lolendo eyaka liboso ya kobebisama, 
\q2 mpe komimatisa eyaka liboso ya kokweyisama. 
\b  
\q1  
\v 19 Kozala moto ya komikitisa mpe kozala elongo na bato bakelela 
\q2 ezali malamu koleka kokabola bomengo ya bitumba 
\q2 elongo na bato ya lolendo. 
\b  
\q1  
\v 20 Moto oyo akanisaka na tina na makambo 
\q2 amonaka bolamu. 
\q2 Esengo na moto oyo atiaka elikya na Yawe. 
\b  
\q1  
\v 21 Babengaka moto oyo azali na motema ya bwanya 
\q2 moto ya mayele, 
\q2 mpe bibebu ya kimia ebakisaka boyebi. 
\b  
\q1  
\v 22 Mayele ezali etima ya bomoi 
\q2 mpo na bato oyo bazali na yango, 
\q2 kasi bozoba ezali etumbu mpo na bazoba. 
\b  
\q1  
\v 23 Motema ya moto ya bwanya ekomisaka 
\q2 monoko na ye mayele, 
\q2 mpe bibebu na ye ebakisaka boyebi. 
\b  
\q1  
\v 24 Maloba ya elengi ezalaka lokola mafuta ya nzoyi, 
\q2 epesaka kimia na motema mpe lobiko na mikuwa. 
\b  
\q1  
\v 25 Nzela mosusu emonanaka sembo na miso ya bato, 
\q2 nzokande, na suka, ememaka na kufa. 
\b  
\q1  
\v 26 Nzala etindaka mosali ete asala mosala, 
\q2 monoko na ye etindikaka ye na mosala. 
\b  
\q1  
\v 27 Moto ya Beliali abongisaka kosala mabe, 
\q2 mpe maloba na ye ezali lokola moto oyo etumbaka. 
\b  
\q1  
\v 28 Moto mabe alonaka koswana, 
\q2 moto ya songisongi akabolaka baninga. 
\b  
\q1  
\v 29 Moto ya mobulu abendaka moninga na ye 
\q2 mpe atambolisaka ye na nzela ya mabe. 
\b  
\q1  
\v 30 Moto oyo akangi miso mpe bibebu na ye 
\q2 mpo na kosala mabongisi ya mabe 
\q2 asili kosala masumu. 
\b  
\q1  
\v 31 Suki ya pembe ezali motole ya nkembo ; 
\q2 bazwaka yango na nzela ya bosembo. 
\b  
\q1  
\v 32 Moto oyo akangaka motema azali makasi koleka elombe, 
\q2 mpe moto oyo ayebi komikanga azali makasi 
\q2 koleka moto oyo abotolaka bingumba. 
\b  
\q1  
\v 33 Bakobetaka zeke kati na elamba ya Nganga-Nzambe, 
\q2 kasi mikano nyonso ewutaka na Yawe. 
\b  
\c 17  
\q1  
\v 1 Kolia na kimia ndambo ya lipa ya kokawuka ezali malamu 
\q2 koleka kovanda na ndako etonda na misuni elongo na koswana. 
\b  
\q1  
\v 2 Mosali ya bwanya akozala na bokonzi 
\q2 likolo ya mwana mobali oyo asalaka soni, 
\q2 mpe akozwa libula elongo na bandeko. 
\b  
\q1  
\v 3 Bapetolaka palata na kikalungu, 
\q2 mpe bapetolaka wolo na fulu ya moto makasi, 
\q2 kasi ezali Yawe nde amekaka mitema. 
\b  
\q1  
\v 4 Moto oyo asalaka mabe ayokaka maloba ya bato mabe, 
\q2 mokosi apesaka litoyi na ye na maloba ya lokuta. 
\b  
\q1  
\v 5 Moto oyo anyokolaka mobola 
\q2 anyokolaka Mokeli ya mobola yango ; 
\q1 moto oyo asepelaka na pasi ya moninga 
\q2 akozanga te kozwa etumbu. 
\b  
\q1  
\v 6 Bakitani bazali motole ya bakoko, 
\q2 mpe baboti bazali lokumu ya bana. 
\b  
\q1  
\v 7 Ndenge maloba ya lokumu ebongi te mpo na moto mabe, 
\q2 ndenge mpe maloba ya lokuta ebongi te mpo na mokonzi. 
\b  
\q1  
\v 8 Kanyaka ezalaka lokola kisi na miso ya moto 
\q2 oyo azali na yango ; 
\q2 alongaka na esika nyonso oyo akendaka. 
\b  
\q1  
\v 9 Moto oyo abombaka mabe alukaka bolingo, 
\q2 kasi moto oyo azongelaka yango tango nyonso 
\q2 akabolaka bato oyo balingani. 
\b  
\q1  
\v 10 Pamela ezalaka na litomba mpo na moto ya mayele, 
\q2 kasi kobeta zoba bafimbu nkama moko ezalaka 
\q2 na litomba te. 
\b  
\q1  
\v 11 Moto mabe alukaka kaka kotomboka, 
\q2 kasi bakotindela ye ntoma ya motema mabe 
\q2 mpo na kotelemela ye. 
\b  
\q1  
\v 12 Kokutana na ngombolo oyo babotoli bana ezali malamu 
\q2 koleka kokutana na zoba oyo azali kati na bolema. 
\b  
\q1  
\v 13 Pasi etikaka ata moke te ndako ya moto 
\q2 oyo azongisaka mabe mpo na malamu. 
\b  
\q1  
\v 14 Kobanda koswana ezali lokola kofungola nzela ya mayi ; 
\q2 tika na yo liboso ete kobendana ekoma makasi. 
\b  
\q1  
\v 15 Moto oyo alongisaka bato mabe 
\q2 mpe moto oyo akweyisaka bato ya sembo 
\q2 bazali, bango mibale, nkele na miso ya Yawe. 
\b  
\q1  
\v 16 Mpo na nini mbongo ezala na maboko ya zoba ? 
\q2 Mpo ete asomba bwanya wana azali na posa na yango te ! 
\b  
\q1  
\v 17 Molingami alingaka tango nyonso, 
\q2 mpe akomaka ndeko na tango ya pasi. 
\b  
\q1  
\v 18 Moto oyo azangi mayele abetaka tolo 
\q2 mpo na kondima baniongo ya mopaya. 
\b  
\q1  
\v 19 Moto oyo alingaka koswana alingaka masumu ; 
\q2 moto oyo atongaka ekuke na ye na likolo 
\q2 amilukelaka kokweya. 
\b  
\q1  
\v 20 Moto ya motema mabe abongaka te, 
\q2 mpe moto ya lolemo ya lokuta akomona pasi. 
\b  
\q1  
\v 21 Kozala na mwana ya zoba esalaka pasi na motema, 
\q2 mpe tata ya moto ya liboma akotikala kozala na esengo te. 
\b  
\q1  
\v 22 Motema ya esengo ebikisaka nzoto, 
\q2 kasi motema oyo etutami ebukaka mikuwa. 
\b  
\q1  
\v 23 Moto mabe azwaka kanyaka na nkuku 
\q2 mpo na kobebisa nzela ya bosembo. 
\b  
\q1  
\v 24 Bwanya emonanaka na elongi ya moto ya mayele, 
\q2 kasi miso ya zoba ekendaka kino na suka ya mokili. 
\b  
\q1  
\v 25 Mwana oyo azangi mayele apesaka tata na ye mawa, 
\q2 mpe ayokisaka mama na ye pasi na motema. 
\b  
\q1  
\v 26 Ezali malamu te kopesa moto ya sembo etumbu, 
\q2 mpe ezali malamu te kobeta bato ya lokumu 
\q2 na miso ya bosembo. 
\b  
\q1  
\v 27 Moto oyo abatelaka monoko na ye azali na boyebi ; 
\q2 moto oyo alengaka-lengaka te azali mayele. 
\b  
\q1  
\v 28 Ezala moto ya liboma, soki avandi kimia, 
\q2 amonanaka lokola moto ya bwanya ; 
\q1 moto oyo akangaka monoko na ye 
\q2 amonanaka lokola moto ya mayele. 
\b  
\c 18  
\q1  
\v 1 Moyimi alukaka kaka kosepelisa baposa na ye, 
\q2 atelemelaka bososoli nyonso. 
\b  
\q1  
\v 2 Moto oyo azangi mayele asepelaka te kozwa 
\q2 tango ya kokanisa, 
\q2 kasi asepelaka kaka kotalisa makanisi ya motema na ye. 
\b  
\q1  
\v 3 Soki moto mabe ayei, kotiola mpe eyaka ; 
\q2 soki soni eyei, kofinga mpe eyaka. 
\b  
\q1  
\v 4 Maloba ya monoko ya moto ezalaka 
\q2 lokola mayi ya mozindo ; 
\q1 etima ya bwanya ezalaka lokola mayi ya ebale 
\q2 oyo etondi makasi. 
\b  
\q1  
\v 5 Ezali malamu te kolongisa moto mabe 
\q2 mpe kokweyisa moyengebene, kati na kosambisama. 
\b  
\q1  
\v 6 Bibebu ya moto oyo azangi mayele eyeisaka koswana, 
\q2 mpe monoko na ye eyeisaka fimbu. 
\b  
\q1  
\v 7 Monoko ya moto oyo azangi mayele ememelaka ye kufa, 
\q2 mpe bibebu na ye ezalaka motambo 
\q2 mpo na molimo na ye moko. 
\b  
\q1  
\v 8 Maloba ya moto ya songisongi ezalaka 
\q2 lokola bilei ya kitoko, 
\q2 ekitaka na esengo kino na libumu. 
\b  
\q1  
\v 9 Moto oyo azongaka sima na mosala na ye 
\q2 azali ndeko ya mobebisi. 
\b  
\q1  
\v 10 Kombo ya Yawe ezali 
\q2 lokola ndako molayi batonga makasi ; 
\q1 moyengebene akimelaka kuna 
\q2 mpe azwaka ebombamelo ya makasi. 
\b  
\q1  
\v 11 Bomengo ya mozwi ezali engumba na ye, 
\q2 oyo batonga makasi ; 
\q2 akanisaka ete ezali lokola mir ya molayi. 
\b  
\q1  
\v 12 Liboso ete moto akweya, 
\q2 motema na ye ekomaka na lolendo ; 
\q2 kasi komikitisa eyaka liboso ya nkembo. 
\b  
\q1  
\v 13 Kopesa eyano liboso ya koyoka 
\q2 ezali liboma mpe bozoba. 
\b  
\q1  
\v 14 Kimia kati na motema elendisaka moto 
\q2 na tango ya bokono, 
\q2 kasi nani akokoka kolendisa motema oyo etutami ? 
\b  
\q1  
\v 15 Motema ya moto ya mayele ezwaka mayele, 
\q2 mpe litoyi ya moto ya bwanya elukaka boyebi. 
\b  
\q1  
\v 16 Kado efungolelaka moto oyo apesi yango nzela 
\q2 mpe ekotisaka ye liboso ya bato minene. 
\b  
\q1  
\v 17 Moto ya liboso na kosamba amonanaka 
\q2 lokola nde alongi ; 
\q1 kasi soki moto oyo azali kosamba na ye ayei, 
\q2 akotelemela ye. 
\b  
\q1  
\v 18 Zeke esilisaka koswana 
\q2 mpe ekataka makambo kati na bato ya makasi. 
\b  
\q1  
\v 19 Kokota lisusu na motema ya ndeko oyo osali mabe 
\q2 ezalaka pasi koleka kokota na engumba batonga makasi ; 
\q1 mpe koswana na moto ezali lokola kokanga 
\q2 bikuke ya ndako batonga makasi na bibende ya minene. 
\b  
\q1  
\v 20 Moto atondisaka libumu na ye 
\q2 na nzela ya mbuma ya monoko na ye 
\q2 mpe akotonda na lifuti ya bibebu na ye. 
\b  
\q1  
\v 21 Kufa mpe bomoi ezali na se ya nguya ya lolemo ; 
\q2 moto oyo alingaka lolemo akolia mbuma na yango. 
\b  
\q1  
\v 22 Mobali oyo azwi mwasi ya malamu azwi bomengo, 
\q2 azwi ngolu kowuta epai na Yawe. 
\b  
\q1  
\v 23 Mobola alobaka na mongongo ya kobondela, 
\q2 kasi mozwi azongisaka eyano na lolendo. 
\b  
\q1  
\v 24 Moto oyo azalaka na balingami ebele amitiaka na pasi, 
\q2 kasi ezali na molingami moko ya motema, 
\q2 oyo aleki ata ndeko. 
\b  
\c 19  
\q1  
\v 1 Mobola oyo atambolaka na bosembo azali malamu 
\q2 koleka mokosi oyo azangi mayele. 
\b  
\q1  
\v 2 Ezali malamu te kobungisa mayele, 
\q2 kati na bolingo oyo eleka ndelo. 
\q1 Lokolo ya moto oyo atambolaka noki-noki 
\q2 ezangaka te kobeta libaku. 
\b  
\q1  
\v 3 Bozoba ya moto ebebisaka bomoi na ye ; 
\q2 mpe, na sima, akomaka kotombokela Yawe. 
\b  
\q1  
\v 4 Mozwi azalaka na baninga ebele, 
\q2 kasi mobola akabwanaka 
\q2 ata na molingami na ye ya motema. 
\b  
\q1  
\v 5 Motatoli ya lokuta akozwa etumbu ; 
\q2 moto oyo akosaka akozanga te kozwa etumbu. 
\b  
\q1  
\v 6 Bato mingi balukaka kosepelisa moto ya lokumu, 
\q2 mpe moto nyonso alukaka kozala molingami ya moto 
\q2 oyo asungaka bato. 
\b  
\q1  
\v 7 Soki bandeko nyonso ya mobola bayinaka ye, 
\q2 mpo na nini baninga na ye bakima ye te ? 
\q2 Ata tango azali nanu koloba, batikalaka lisusu wana te. 
\b  
\q1  
\v 8 Moto oyo alukaka kozwa bwanya alingaka bomoi na ye ; 
\q2 moto oyo alingaka mayele alongaka. 
\b  
\q1  
\v 9 Motatoli ya lokuta azwaka etumbu ; 
\q2 moto oyo akosaka akobebisama. 
\b  
\q1  
\v 10 Bomoi ya lokumu ebongi na zoba te ; 
\q2 ebongi mpe te na mowumbu kopesa mitindo na bakambi. 
\b  
\q1  
\v 11 Bwanya ya moto ekomisaka ye motema molayi ; 
\q2 mpe azwaka lokumu tango atalaka pamba 
\q2 mabe oyo basalaka ye. 
\b  
\q1  
\v 12 Kanda ya mokonzi ezali lokola koganga ya nkosi, 
\q2 kasi bolamu na ye ezali lokola mamwe. 
\b  
\q1  
\v 13 Mwana ya zoba azali pasi mpo na tata na ye ; 
\q2 koswana ya mwasi ezali lokola linzanza ya ndako, 
\q2 oyo etangisaka mayi tango nyonso. 
\b  
\q1  
\v 14 Moto akoki kozwa bandako mpe bomengo 
\q2 lokola libula kowuta epai ya batata, 
\q2 kasi mwasi ya bwanya azali likabo kowuta na Yawe. 
\b  
\q1  
\v 15 Bogoyigoyi ememaka moto na pongi makasi, 
\q2 mpe moto ya goyigoyi akufaka nzala. 
\b  
\q1  
\v 16 Moto oyo atosaka mibeko abatelaka molimo na ye ; 
\q2 moto oyo akebaka te na etamboli na ye akokufa. 
\b  
\q1  
\v 17 Moto oyo asalaka bolamu epai ya mobola 
\q2 adefisaka Yawe, 
\q2 bongo Yawe akozongisela ye bolamu. 
\b  
\q1  
\v 18 Pesaka mwana na yo etumbu wana elikya ezali nanu, 
\q2 kasi kotomboka na yo ekoma te kino 
\q2 na posa ya koboma ye. 
\b  
\q1  
\v 19 Tika ete moto oyo asilikaka makasi amema 
\q2 mokumba ya kanda na ye ; 
\q2 pamba te soki obikisi ye, okotinda ye ete azongela lisusu. 
\b  
\q1  
\v 20 Yoka toli mpe ndima mateya, 
\q2 mpo ete okoma moto ya bwanya. 
\b  
\q1  
\v 21 Motema ya moto ezalaka na makanisi ebele, 
\q2 kasi ezali mokano ya Yawe nde ekokisamaka. 
\b  
\q1  
\v 22 Eloko oyo moto alingaka epai ya moninga na ye moto 
\q2 ezali bolingo ya solo, 
\q2 mpe mobola azali malamu koleka mokosi. 
\b  
\q1  
\v 23 Kotosa Yawe ememaka na bomoi, 
\q2 esalaka ete moto azala na kimia ; 
\q2 boye ata mabe moko te ekokomela ye. 
\b  
\q1  
\v 24 Moto ya goyigoyi akotisaka loboko na ye kati na bilei, 
\q2 kasi akokaka te kozongisa yango na monoko na ye. 
\b  
\q1  
\v 25 Beta motioli fimbu, mpe zoba akozwa mayele ; 
\q2 sembola moto ya mayele, mpe akozwa boyebi. 
\b  
\q1  
\v 26 Mwana oyo abetaka tata na ye 
\q2 mpe abenganaka mama na ye 
\q2 ayeisaka soni mpe mawa. 
\b  
\q1  
\v 27 Mwana na ngai, soki otiki koyoka mateya, 
\q2 okobunga nzela ya maloba ya boyebi. 
\b  
\q1  
\v 28 Moto oyo atiolaka bosembo azali motatoli ya zoba ; 
\q2 mpe monoko ya bato mabe emelaka kaka mabe. 
\b  
\q1  
\v 29 Etumbu esalema mpo na batioli, 
\q2 mpe fimbu esalema mpo na bazoba. 
\b  
\c 20  
\q1  
\v 1 Vino elobisaka bato maloba ya soni, 
\q2 masanga ya makasi ememaka mobulu ; 
\q1 moto nyonso oyo amipesaka na yango akotikala te 
\q2 kokoma moto ya bwanya. 
\b  
\q1  
\v 2 Somo oyo mokonzi apesaka ezali 
\q2 lokola koganga ya nkosi ; 
\q2 moto oyo apesaka ye kanda amilukelaka ye moko pasi. 
\b  
\q1  
\v 3 Koboya koswana epesaka moto lokumu, 
\q2 kasi moto oyo azangi mayele amipesaka na yango. 
\b  
\q1  
\v 4 Moto ya goyigoyi asalaka bilanga te 
\q2 likolo ya kobanga malili ; 
\q1 boye na tango ya kobuka mbuma, 
\q2 alukaka mpe kobuka, kasi akozwa eloko te. 
\b  
\q1  
\v 5 Makanisi ya motema ya moto ezalaka 
\q2 lokola ebale ya mozindo, 
\q2 moto ya mayele alukaka kotoka kati na yango. 
\b  
\q1  
\v 6 Bato ebele batatolaka bolamu na bango, 
\q2 kasi nani akomona moto ya sembo ? 
\b  
\q1  
\v 7 Moyengebene atambolaka na bosembo na ye ; 
\q1 boye sima na ye, bana na ye bakozala bato ya esengo. 
\b  
\q1  
\v 8 Soki mokonzi avandi na kiti mpo na kosambisa, 
\q2 miso na ye ebenganaka mabe nyonso. 
\b  
\q1  
\v 9 Nani akoki koloba : « Nabatelaka motema na ngai peto, 
\q2 nazali peto, nazali na masumu te ? » 
\b  
\q1  
\v 10 Kilo mibale mpe bimekelo mibale, 
\q2 nyonso ezali nkele na miso ya Yawe. 
\b  
\q1  
\v 11 Bayebaka elenge mobali na nzela ya misala na ye, 
\q2 soki ezaleli na ye ezali peto mpe sembo. 
\b  
\q1  
\v 12 Ezala litoyi oyo eyokaka to liso oyo emonaka, 
\q2 ezali Yawe nde asalaki nyonso mibale. 
\b  
\q1  
\v 13 Kolingaka pongi te, noki te okokoma mobola ; 
\q1 sala ete miso na yo ezalaka ya kofungwama, 
\q2 mpe okozanga te bilei ya kobomba. 
\b  
\q1  
\v 14 Moto oyo asombaka biloko alobaka : 
\q2 « Biloko oyo ezali mabe ! Ezali malamu te ! » 
\q1 Kasi soki akei, atombolaka mapeka mpo na biloko oyo azwi. 
\b  
\q1  
\v 15 Wolo mpe babiju ezalaka na yango ebele, 
\q2 kasi bibebu oyo ebimisaka boyebi eleki na motuya. 
\b  
\q1  
\v 16 Kamata elamba ya moto oyo alapi ndayi 
\q2 mpo na niongo ya moto mosusu ; 
\q1 bomba yango lokola ndanga 
\q2 soki alapi ndayi mpo na mwasi mopaya. 
\b  
\q1  
\v 17 Bilei oyo ezwami na nzela ya lokuta 
\q2 ezalaka elengi na monoko ya moto, 
\q2 kasi, na sima, monoko na ye etondaka na zelo. 
\b  
\q1  
\v 18 Soki ozali kosala mabongisi, 
\q2 tunaka toli ; 
\q1 mpe soki olingi kobunda bitumba, 
\q2 zala na ekenge mpe na mayele. 
\b  
\q1  
\v 19 Moto ya bilobaloba abimisaka basekele ; 
\q1 yango wana kima bato oyo balobaka mingi. 
\b  
\q1  
\v 20 Moto oyo alakelaka tata to mama na ye mabe, 
\q2 mwinda na ye ekokufa kati na molili. 
\q1  
\v 21 Bomengo oyo moto azwi noki-noki na ebandeli 
\q2 ekopambolama te na suka. 
\b  
\q1  
\v 22 Kolobaka te : « Nakozongisa mabe 
\q2 na mabe oyo basali ngai ! » 
\q1 Kasi talela Yawe, mpe akobikisa yo. 
\b  
\q1  
\v 23 Kilo oyo ekesana na kilo mosusu ezalaka 
\q2 nkele na miso ya Yawe, 
\q2 mpe emekelo kilo ya lokuta ezalaka eloko ya malamu te. 
\b  
\q1  
\v 24 Ezali Yawe nde atambolisaka matambe ya moto ; 
\q2 bongo ndenge nini moto akoki kososola ye moko 
\q2 nzela na ye ? 
\b  
\q1  
\v 25 Ezali motambo mpo na moto koloba na lombangu : 
\q2 « Eloko oyo ebulisami mpo na Yawe, » 
\q2 mpe kokanisa sima na ye kolapa ndayi. 
\b  
\q1  
\v 26 Mokonzi ya bwanya abenganaka bato mabe 
\q2 mpe azangaka te kopesa bango etumbu. 
\b  
\q1  
\v 27 Molimo ya moto ezali mwinda oyo Yawe apesi ye ; 
\q1 esosolaka bozindo nyonso ya motema ya moto. 
\b  
\q1  
\v 28 Bolamu mpe solo ebatelaka mokonzi ; 
\q1 alendisaka bokonzi na ye na nzela ya bolamu. 
\b  
\q1  
\v 29 Makasi ezali biju ya bilenge, 
\q2 mpe suki ya pembe ezali lokumu ya mibange. 
\b  
\q1  
\v 30 Bapota elongolaka mabe, 
\q2 mpe bafimbu esukolaka bozindo ya molimo ya moto. 
\b  
\c 21  
\q1  
\v 1 Kati na loboko na Yawe, 
\q2 motema ya mokonzi ezalaka lokola moluka 
\q2 oyo atindaka esika nyonso oyo alingi. 
\b  
\q1  
\v 2 Nzela nyonso ya moto emonanaka alima na miso na ye, 
\q2 kasi ezali Yawe nde amekaka mitema. 
\b  
\q1  
\v 3 Na miso na Yawe, 
\q2 kosala makambo ya sembo mpe ya alima ezali motuya 
\q2 koleka bambeka ya kotumba. 
\b  
\q1  
\v 4 Miso ya lofundu, motema ya lolendo 
\q2 mpe kongenga ya bato mabe ezali masumu. 
\b  
\q1  
\v 5 Mabongisi ya moto oyo asalaka mosala 
\q2 ememaka ye na bomengo, 
\q2 kasi kozala motema moto-moto ememaka na kozanga. 
\b  
\q1  
\v 6 Kozwa bomengo na nzela ya lokuta ezali kaka molinga 
\q2 oyo epanzanaka mpe motambo oyo ememaka na kufa. 
\b  
\q1  
\v 7 Makambo ya bato mabe ebebisaka bango moko, 
\q2 pamba te baboyaka kosala makambo ya sembo. 
\b  
\q1  
\v 8 Nzela ya moto mabe ezalaka na mabaku, 
\q2 kasi mosala ya moto ya peto ezalaka sembo. 
\b  
\q1  
\v 9 Kovanda na songe ya ndako ezali malamu 
\q2 koleka kovanda elongo na mwasi oyo aswanaka-swanaka. 
\b  
\q1  
\v 10 Molimo ya moto mabe elingaka kaka makambo mabe ; 
\q2 ata moninga na ye penza azwaka ngolu te na miso na ye. 
\b  
\q1  
\v 11 Tango bapesaka motioli etumbu, 
\q2 zoba akomaka moto ya bwanya ; 
\q1 mpe tango bapesaka malako epai ya moto ya bwanya, 
\q2 azwaka solo boyebi. 
\b  
\q1  
\v 12 Nzambe ya sembo atalaka na bokebi makambo 
\q2 oyo esalemaka kati na bandako ya bato mabe, 
\q2 mpe akweyisaka bango kati na pasi. 
\b  
\q1  
\v 13 Soki moto akangi matoyi na ye 
\q2 mpo na koboya koyoka koganga ya mobola, 
\q2 ye mpe bakoyanola ye te tango akoganga. 
\b  
\q1  
\v 14 Likabo oyo bapesi na nkuku ekitisaka kanda, 
\q2 mpe kado oyo batie na tolo ekitisaka kanda makasi. 
\b  
\q1  
\v 15 Ezali esengo mpo na moyengebene kosambisa makambo na sembo, 
\q2 kasi yango ezali pasi makasi mpo na bato oyo basalaka mabe. 
\b  
\q1  
\v 16 Moto oyo abungi nzela ya bwanya 
\q2 akovanda kati na lisanga ya bakufi. 
\b  
\q1  
\v 17 Moto oyo alingaka biyenga akokoma mobola ; 
\q2 moto oyo alingaka masanga ya vino mpe mafuta 
\q2 akotikala kokoma mozwi te. 
\b  
\q1  
\v 18 Moto mabe azalaka lokola motuya oyo bafutaka 
\q2 mpo na kosikola moto ya sembo ; 
\q1 moto ya sembo te azalaka lokola motuya 
\q2 oyo bafutaka mpo na kosikola moto ya alima. 
\b  
\q1  
\v 19 Kovanda kati na esobe ezali malamu 
\q2 koleka kovanda esika moko na mwasi 
\q2 oyo aswanaka-swanaka mpe asilikaka-silikaka. 
\b  
\q1  
\v 20 Bilei ya kitoko mpe mafuta ezalaka 
\q2 kati na ndako ya moto ya bwanya, 
\q2 kasi moto oyo azangi mayele abebisaka yango. 
\b  
\q1  
\v 21 Moto oyo alukaka bosembo mpe bolingo 
\q2 akozwa bomoi, bomengo mpe lokumu. 
\b  
\q1  
\v 22 Moto ya bwanya abundisaka engumba ya bato ya makasi, 
\q2 mpe akweyisaka bandako ya makasi 
\q2 oyo bato batielaka mitema. 
\b  
\q1  
\v 23 Moto oyo abatelaka monoko mpe lolemo na ye 
\q2 abatelaka molimo na ye na pasi. 
\b  
\q1  
\v 24 Kombo ya moto ya lofundu mpe ya lolendo ezali : « Motioli. » 
\q2 Asalaka makambo na lolendo oyo eleka ndelo. 
\b  
\q1  
\v 25 Baposa ya moto ya goyigoyi ekoboma ye, 
\q2 pamba te maboko na ye eboyaka kosala. 
\q1  
\v 26 Mokolo mobimba, 
\q2 akufaka na ye kaka na baposa makasi ; 
\q2 kasi moto ya sembo apesaka na kobomba te. 
\b  
\q1  
\v 27 Mbeka ya moto mabe ezalaka nkele ; 
\q2 ezalaka nkele koleka soki amemi yango na makanisi mabe. 
\b  
\q1  
\v 28 Motatoli ya lokuta akokufa, 
\q2 kasi moto oyo ayokaka akoloba tango nyonso. 
\b  
\q1  
\v 29 Moto mabe akangaka elongi na ye, 
\q2 kasi moto ya sembo alendisaka nzela na ye. 
\b  
\q1  
\v 30 Liboso na Yawe, bwanya moko te, mayele moko te 
\q2 mpe toli moko te ekoki kolonga. 
\b  
\q1  
\v 31 Mpunda ebongisama mpo na mokolo ya bitumba, 
\q2 kasi elonga ewutaka na Yawe. 
\b  
\c 22  
\q1  
\v 1 Kokende sango ya malamu ezali malamu 
\q2 koleka kozala na bomengo mingi ; 
\q2 lokumu ezali malamu koleka palata mpe wolo. 
\b  
\q1  
\v 2 Mozwi mpe mobola bazali na likambo moko ya lisanga : 
\q2 ezali Yawe nde azali Mokeli na bango mibale. 
\b  
\q1  
\v 3 Moto ya mayele amonaka likama na mosika mpe amibombaka, 
\q2 kasi moto oyo azangi mayele akoleka wana mpe akokutana na pasi. 
\b  
\q1  
\v 4 Komikitisa mpe kotosa Yawe ememaka 
\q2 bozwi, lokumu mpe bomoi. 
\b  
\q1  
\v 5 Nzela ya bato mabe ezalaka na banzube mpe mitambo, 
\q2 kasi moto oyo abatelaka molimo na ye azalaka mosika na yango. 
\b  
\q1  
\v 6 Lakisa mwana nzela oyo asengeli kotambola wuta na bomwana na ye ; 
\q2 ezala tango akokoma mokolo, akobunga yango te. 
\b  
\q1  
\v 7 Mozwi azalaka mokonzi ya mobola, 
\q2 mpe modefi azalaka mowumbu ya modefisi. 
\b  
\q1  
\v 8 Moto oyo alonaka masumu abukaka pasi, 
\q2 mpe makasi ya kanda na ye nyonso ekosuka. 
\b  
\q1  
\v 9 Moto oyo akabaka na esengo akopambolama, 
\q2 pamba te akabolaka bilei na ye na mobola. 
\b  
\q1  
\v 10 Bengana motioli, 
\q2 bongo kowelana, koswana mpe kofingana ekosila. 
\b  
\q1  
\v 11 Moto oyo alingaka kozala peto na motema, 
\q2 oyo ngolu ezalaka na bibebu na ye, 
\q2 mokonzi azalaka molingami na ye. 
\b  
\q1  
\v 12 Miso na Yawe ebatelaka boyebi, 
\q2 kasi akweyisaka maloba ya moto oyo azangi mayele. 
\b  
\q1  
\v 13 Moto ya goyigoyi alobaka : « Nkosi ezali kuna na libanda, 
\q2 ekoboma ngai na kati-kati ya balabala. » 
\b  
\q1  
\v 14 Monoko ya mwasi ya ndumba ezalaka lokola libulu ya mozindo ; 
\q2 moto oyo Yawe asilikeli akweyaka kuna. 
\b  
\q1  
\v 15 Motema ya mwana moke ezalaka na bozoba, 
\q2 bongo fimbu ya pamela elongolaka yango kati na ye. 
\b  
\q1  
\v 16 Moto oyo anyokolaka mobola 
\q2 mpo ete akoma na bomengo mingi 
\q2 mpe oyo apesaka mozwi bakado bakokweya na bobola. 
\s1 Maloba ya bato ya bwanya 
\q1  
\v 17 Pesa matoyi mpe yoka toli ya bato ya bwanya, 
\q2 mpe tika ete motema na yo endima mateya na ngai. 
\q1  
\v 18 Pamba te ekozala esengo soki obombi yango na motema na yo, 
\q2 mpe soki yango nyonso ezali pene ya bibebu na yo. 
\q1  
\v 19 Nateyi yo yango lelo 
\q2 mpo ete elikya na yo ezala kati na Yawe. 
\q1  
\v 20 Boni, lobi eleki, nakomelaki yo te batoli koleka tuku misato, 
\q2 batoli ya bwanya mpe ya boyebi, 
\q1  
\v 21 batoli oyo epesaka mateya ya solo 
\q2 mpe maloba ya solo mpo ete okoka kozongisa biyano ya solo 
\q2 na moto oyo atindi yo ? 
\b  
\q1  
\v 22 Kobotola te na makasi biloko ya mobola, 
\q2 pamba te azali mobola, 
\q2 konyokola te moto ya pasi na esambiselo, 
\q1  
\v 23 pamba te Yawe akobundela bango 
\q2 mpe akobebisa bomoi ya bato 
\q2 oyo bakobebisa bomoi na bango. 
\b  
\q1  
\v 24 Kozala molingami te ya moto ya kanda, 
\q2 mpe kosangana te na moto ya motema moto-moto, 
\q1  
\v 25 noki te okoyekola nzela na ye 
\q2 mpe okokangama na motambo na ye. 
\b  
\q1  
\v 26 Kozala te na molongo ya bato oyo batombolaka maboko 
\q2 mpo na kondima kofuta baniongo ya bato mosusu, 
\q1  
\v 27 pamba te soki ozali na yo na makoki ya kofuta te, 
\q2 mpo na nini okolinga ete babotola ata mbeto na yo ya kolala ? 
\b  
\q1  
\v 28 Kozongisa na sima te mondelo ya kala 
\q2 oyo batata na yo bakataki. 
\b  
\q1  
\v 29 Osila komona moto oyo ayebi mosala na ye malamu ? 
\q2 Akosala kaka liboso ya bakonzi, 
\q2 akosala te liboso ya bato ya molili. 
\b  
\c 23  
\q1  
\v 1 Soki ovandi mpo na kolia mesa moko elongo na mokonzi, 
\q2 tala malamu moto oyo azali liboso na yo. 
\q1  
\v 2 Tia mbeli na mongongo na yo 
\q2 soki ozalaka lokoso. 
\q1  
\v 3 Kolula te bilei na ye ya kitoko, 
\q2 pamba te, tango mosusu, ezali na yango bololo. 
\b  
\q1  
\v 4 Koboma nzoto te mpo na koluka kozwa bomengo, 
\q2 kotia mayele na yo te kati na yango. 
\q1  
\v 5 Tango okobwaka miso na ngambo ya bomengo, ekobunga, 
\q2 pamba te ezalaka na mapapu 
\q2 mpe epumbwaka na likolo makasi lokola mpongo. 
\b  
\q1  
\v 6 Kolia te bilei ya moto oyo azali kotala yo na miso mabe 
\q2 mpe kolula te bilei na ye ya kitoko, 
\q1  
\v 7 pamba te azalaka ndenge makanisi ya motema na ye ezali. 
\q2 Alobaka : « Lia mpe mela, » 
\q2 kasi motema na ye ezali elongo na yo te. 
\q1  
\v 8 Okosanza eteni oyo oliaki, 
\q2 mpe maloba na yo ya kitoko ekokende pamba. 
\b  
\q1  
\v 9 Kolobaka na zoba te, 
\q2 pamba te akotiola bwanya ya maloba na yo. 
\b  
\q1  
\v 10 Kozongisa te na sima mondelo ya kala 
\q2 mpe kokota te na bilanga ya bana bitike, 
\q1  
\v 11 pamba te Molobeli na bango azalaka makasi, 
\q2 akozwa makambo na bango na maboko 
\q2 mpo na kotelemela yo. 
\b  
\q1  
\v 12 Tika ete motema na yo endimaka kotosa mibeko, 
\q2 mpe matoyi na yo eyokaka maloba ya boyebi ! 
\b  
\q1  
\v 13 Kozangisa te kopesa mwana etumbu ; 
\q2 soki obeti ye fimbu, akokufa te. 
\q1  
\v 14 Na kobeta ye fimbu, 
\q2 okokangola molimo na ye na lifelo. 
\q1  
\v 15 Mwana na ngai, soki motema na yo ezali na bwanya, 
\q2 motema na ngai ekozala na esengo. 
\q1  
\v 16 Solo, bomoto na ngai nyonso ekotonda na esengo, 
\q2 soki bibebu na yo elobi makambo ya sembo. 
\b  
\q1  
\v 17 Tika ete motema na yo elulaka te bato ya masumu, 
\q2 kasi zalaka tango nyonso na posa makasi ya kotosa Yawe ; 
\q1  
\v 18 pamba te suka na yo ekozala solo malamu 
\q2 mpe elikya na yo ekozala ya pamba te. 
\b  
\q1  
\v 19 Mwana na ngai, yoka mpe zala na bwanya, 
\q2 batela motema na yo kati na nzela ya sembo. 
\q1  
\v 20 Kozala esika moko te na balangwi masanga 
\q2 to na bato ya lokoso, 
\q1  
\v 21 pamba te balangwi masanga mpe bato na lokoso bakomaka babola, 
\q2 mpe bogoyigoyi ekolatisa bango bilamba epasuka. 
\b  
\q1  
\v 22 Yokela tata oyo aboti yo, 
\q2 mpe kotiola mama na yo te ata soki anuni. 
\q1  
\v 23 Luka bosolo, kasi koteka yango te ; 
\q2 sala se bongo na bwanya, na mateya mpe na mayele. 
\q1  
\v 24 Tata ya moto ya sembo akozala na esengo mingi, 
\q2 mpe moto oyo abota mwana ya bwanya akosepela kati na ye. 
\q1  
\v 25 Tika ete tata na yo mpe mama na yo basepela ! 
\q2 Tika ete mama oyo abota yo azala na esengo ! 
\b  
\q1  
\v 26 Mwana na ngai ya mobali, pesa ngai motema na yo, 
\q2 mpe tika ete miso na yo esepela na nzela na ngai ! 
\q1  
\v 27 Pamba te mwasi ya ndumba azali lokola libulu ya monene, 
\q2 mpe mwasi ya mopaya azali lokola libulu ya mozindo. 
\q1  
\v 28 Mwasi ya ndumba atelemaka na ekenge lokola moyibi 
\q2 mpe akomisaka mibali bazoba koleka. 
\b  
\q1  
\v 29 Mpo na nani : « Ah ngai, mawa ! » 
\q2 Mpo na nani : « Eh ! » 
\q1 Mpo na nani koswanaswana ? 
\q2 Mpo na nani kolelalela ? 
\q1 Mpo na nani kowelana ezanga tina ? 
\q2 Mpo na nani kotelisa miso ? 
\q1  
\v 30 Mpo na bato oyo bawumelaka liboso ya masanga ya vino, 
\q2 mpo na bato oyo bamelaka masanga ya makasi. 
\q1  
\v 31 Kotalaka te masanga ya vino tango ezali motane, 
\q2 tango ezali kongala kati na kopo mpe kokita na pete na mongongo. 
\q1  
\v 32 Na suka na yango, ekoswa yo lokola nyoka 
\q2 mpe ekotia yo minu lokola etupa. 
\q1  
\v 33 Miso na yo ekomona biloko na ndenge ya kokamwa, 
\q2 mpe motema na yo ekobimisa makambo ya bozoba. 
\q1  
\v 34 Boye, okokoma lokola moto oyo alali kati na ebale monene, 
\q2 mpe lokola moto oyo alali na songe ya nzete ya molayi. 
\q1  
\v 35 Okoloba : « Babeti ngai, kasi nazali koyoka pasi te ; 
\q2 babeti ngai fimbu, kasi nazali koyoka eloko te ! 
\q1 Tango nini nakolamuka ? 
\q2 Nakozongela lisusu komela vino. » 
\b  
\c 24  
\q1  
\v 1 Kolulaka te bato oyo basalaka mabe 
\q2 mpe kolukaka te kozala elongo na bango, 
\q1  
\v 2 pamba te mitema na bango ekanisaka kaka kosala mabe, 
\q2 mpe bibebu na bango eyeisaka kaka mobulu soki elobi. 
\b  
\q1  
\v 3 Ndako etongamaka na nzela ya bwanya, 
\q2 mpe elendisamaka na nzela ya mayele. 
\q1  
\v 4 Bashambre ekotondisama na biloko nyonso 
\q2 ya talo mpe ya kitoko na nzela ya boyebi. 
\b  
\q1  
\v 5 Moto ya bwanya atondi na nguya, 
\q2 moto oyo azalaka na boyebi alendisaka nguya na ye. 
\q1  
\v 6 Pamba te kolonga na etumba esengaka bwanya, 
\q2 mpe lobiko ezalaka kati na motango ebele ya bapesi toli. 
\b  
\q1  
\v 7 Bwanya ezalaka likolo mingi mpo na zoba, 
\q2 yango wana azalaka te na likambo ya koloba 
\q2 kati na mayangani oyo esalemaka pembeni ya ekuke. 
\q1  
\v 8 Moto oyo asalaka mabongisi ya kosala mabe 
\q2 akokende sango lokola moteki baninga. 
\q1  
\v 9 Mabongisi ya bozoba ezali masumu, 
\q2 mpe bato bayinaka motioli. 
\b  
\q1  
\v 10 Soki omilembisi na mokolo ya pasi, 
\q2 makasi na yo ekozala pamba. 
\q1  
\v 11 Kangola bato oyo bazali komema bango na kufa, 
\q2 mpe bikisa bato oyo bazali kokende na kufa 
\q2 lokola bato oyo balangwe masanga. 
\q1  
\v 12 Soki olobi : « Tala, toyebaki likambo moko te 
\q2 kati na makambo oyo nyonso ; » 
\q1 boni, Ye oyo amekaka mitema asosolaka yango te ? 
\q2 Ye oyo abatelaka molimo na yo ayebaka yango te ? 
\q2 Afutaka te moto na moto kolanda misala na ye ? 
\b  
\q1  
\v 13 Mwana na ngai, lia mafuta ya nzoyi, 
\q2 pamba te ezalaka kitoko ! 
\q1 Mwa ndambo ya mafuta ya nzoyi ekozala 
\q2 elengi na lolemo na yo. 
\b  
\q1  
\v 14 Yeba lisusu ete bwanya ezali elengi 
\q2 mpo na molimo na yo ; 
\q1 soki ozwi yango, yeba ete lobi na yo ekozala malamu, 
\q2 mpe elikya na yo ekozala ya pamba te. 
\q1  
\v 15 Yo moto mabe, komeka te kotia mitambo 
\q2 kati na ndako ya moto ya sembo, 
\q2 mpe komeka te kopanza yango, 
\q1  
\v 16 pamba te ata soki moto ya sembo akweyi mbala sambo, 
\q2 akotelema kaka ; 
\q2 nzokande pasi ekweyisaka moto mabe. 
\b  
\q1  
\v 17 Soki monguna na yo akweyi, kosepela te ; 
\q2 mpe soki apengwi, tika ete motema na yo esepela te ; 
\q1  
\v 18 noki te Yawe akomona, akosepela te 
\q2 mpe akokitisela yo kanda na Ye. 
\b  
\q1  
\v 19 Kosilika te likolo ya bato oyo basalaka mabe, 
\q2 kolula te bato mabe ; 
\q1  
\v 20 pamba te lobi ya malamu ekozala te 
\q2 mpo na moto oyo asalaka mabe, 
\q2 mpe mwinda ya bato mabe ekokufa. 
\b  
\q1  
\v 21 Mwana na ngai, tosaka Yawe mpe mokonzi, 
\q2 kosanganaka te na batomboki, 
\q1  
\v 22 pamba te bango mibale bakoki kotindela batomboki pasi na pwasa. 
\q2 Bongo, nani ayebi pasi oyo bakoki kotinda ? 
\s1 Maloba mosusu ya bato ya bwanya 
\q1  
\v 23 Makambo oyo mpe ezali toli ya bato ya bwanya : 
\q2 Kopona bilongi, kati na kosambisa, ezali malamu te. 
\q1  
\v 24 Moto oyo alobaka na moto mabe : « Ozali moto ya sembo, » 
\q2 bato bakolakela ye mabe, mpe bikolo ekotombokela ye. 
\q1  
\v 25 Kasi bato oyo bapamelaka moto mabe bakozala malamu 
\q2 mpe lipamboli ekozala likolo na bango. 
\b  
\q1  
\v 26 Eyano ya solo ezali lokola beze ya bibebu. 
\q1  
\v 27 Bongisa libanda ya mosala na yo, 
\q2 bongisa bilanga na yo, 
\q2 bongo na sima, tonga ndako na yo. 
\b  
\q1  
\v 28 Kotatola na pamba te mpo na kosala moninga na yo mabe ; 
\q2 mpo na nini olingi kosalela bibebu na yo na lokuta ? 
\q1  
\v 29 Kolobaka te : « Nakosala ye ndenge asali ngai, 
\q2 nakozongisela ye kolanda makambo oyo ye asali. » 
\b  
\q1  
\v 30 Nalekaki pembeni ya elanga ya moto ya goyigoyi, 
\q2 mpe pembeni ya elanga ya vino ya moto oyo azangi mayele ; 
\q1  
\v 31 bongo, tala ndenge etondi na banzube, 
\q2 tala ndenge matiti mabe ezipi yango, 
\q2 mpe mir na yango ya mabanga ebukani. 
\q1  
\v 32 Tango natiaki makanisi na ngai 
\q2 kati na makambo oyo namonaki, 
\q2 nazwaki mayele oyo : 
\q1  
\v 33 mwa pongi moke, mwa kopema moke, 
\q2 mwa kokanga maboko moke mpo na kolala, 
\q1  
\v 34 bobola ekoyela yo na pwasa lokola moleki nzela, 
\q2 mpe pasi ekoyela yo lokola moyibi. 
\c 25  
\s1 Masese mosusu ya Salomo 
\p  
\v 1 Tala masese mosusu ya Salomo oyo bato ya Ezekiasi, mokonzi ya Yuda, bakomaki. 
\q1  
\v 2 Nzambe azwaka nkembo 
\q2 mpo ete asalaka makambo oyo bato bayebaka te, 
\q1 mpe bakonzi bazwaka nkembo 
\q2 mpo ete balukaka kososola tina ya makambo. 
\q1  
\v 3 Ndenge bakokaka te komeka 
\q2 bosanda ya Lola to bozindo ya mabele, 
\q2 ndenge wana mpe bakoki te kososola mitema ya bakonzi. 
\b  
\q1  
\v 4 Soki olongoli mbindo na palata, 
\q2 ekobimisa mbeki mpo na monyangwisi bibende na moto. 
\q1  
\v 5 Soki olongoli moto mabe liboso ya mokonzi, 
\q2 kiti na ye ya bokonzi ekolendisama na bosembo. 
\b  
\q1  
\v 6 Komikumisaka te liboso ya mokonzi, 
\q2 mpe komivandisaka te na esika ya bato minene ; 
\q1  
\v 7 pamba te eleki malamu ete baloba na yo : « Yaka kovanda na esika oyo ya lokumu, » 
\q2 na esika ete bayokisa yo soni na miso ya mokonzi. 
\q1  
\v 8 Kowelaka te kokende kofunda epai ya basambisi 
\q2 makambo oyo osili komona na miso, 
\q1 pamba te okosala nini na suka 
\q2 soki moninga na yo asukisi yo ? 
\b  
\q1  
\v 9 Soki ozali kowelana na moninga na yo, 
\q2 kobimisa sekele ya moto mosusu te, 
\q1  
\v 10 noki te ayoka yango mpe ayokisa yo soni, 
\q2 boye okosambwa mpo na libela. 
\b  
\q1  
\v 11 Liloba oyo elobami na tango oyo ekoki 
\q2 ezali lokola wolo oyo basangisi na palata. 
\q1  
\v 12 Pamela ya moto ya bwanya epai ya moto oyo ayokaka 
\q2 ezali lokola wolo ya peto mpe sheneti ya wolo. 
\b  
\q1  
\v 13 Motindami ya sembo azalaka 
\q2 lokola mopepe ya malili ya mvula ya pembe 
\q1 na tango ya kobuka bambuma, 
\q2 asalaka esengo ya mokonzi na ye. 
\q1  
\v 14 Moto oyo amikumisaka ete akabaka, 
\q2 nzokande apesaka na ye eloko te, 
\q2 azali lokola mapata mpe mopepe oyo ezangi mvula. 
\b  
\q1  
\v 15 Moto oyo akangaka motema 
\q2 akoki kobongola makanisi ya mokonzi, 
\q2 mpe maloba ya malamu ebukaka mikuwa. 
\q1  
\v 16 Soki omoni mafuta ya nzoyi, lia oyo ekoki na yo, 
\q2 pamba te soki olie yango na lokoso, okosanza yango. 
\b  
\q1  
\v 17 Kokendaka pamba-pamba te na ndako ya moninga na yo, 
\q2 noki te akotonda yo mpe akolemba yo. 
\q1  
\v 18 Moto oyo apesaka matatoli ya lokuta 
\q2 mpo na kosala moninga na ye mabe 
\q2 azali lokola marto, mopanga mpe mbanzi ya songe. 
\q1  
\v 19 Kotia elikya na zoba na tango na pasi 
\q2 ezali lokola lino ebukani mpe lokolo elembi. 
\q1  
\v 20 Koyembela moto oyo azali na mawa banzembo ya esengo 
\q2 ezali lokola kolongola ye kazaka na tango ya malili 
\q2 to kotia masanga ya ngayi na pota. 
\b  
\q1  
\v 21 Soki monguna na yo azali na nzala, pesa ye bilei ; 
\q2 soki azali na posa ya mayi, pesa ye mayi ya komela. 
\q1  
\v 22 Pamba te, soki osali bongo, 
\q2 okotondisa makala ya moto na likolo ya moto na ye, 
\q2 mpe Yawe akofuta yo. 
\b  
\q1  
\v 23 Mopepe oyo ewutaka na ngambo ya nor, ebetisaka mvula, 
\q2 mpe lolemo oyo etongaka ekomisaka bilongi kanda-kanda. 
\b  
\q1  
\v 24 Kovanda na songe ya ndako ezali malamu 
\q2 koleka kovanda elongo na mwasi oyo aswanaka-swanaka. 
\b  
\q1  
\v 25 Basango ya malamu oyo ewuti na mokili ya mosika 
\q2 ezali lokola mayi ya pio kati na motema ya moto 
\q2 oyo azali na posa ya mayi. 
\q1  
\v 26 Moto ya sembo oyo asopanaka liboso ya moto mabe 
\q2 azali lokola liziba ya potopoto 
\q2 mpe etima oyo ebimisaka mayi ya mabe. 
\b  
\q1  
\v 27 Ezali malamu te kolia mafuta ya nzoyi ebele, 
\q2 mpe ezali malamu te koluka lokumu na yo moko. 
\b  
\q1  
\v 28 Moto oyo akokaka te kokonza molimo na ye 
\q2 azali lokola engumba oyo ebukana mpe ezanga bamir. 
\c 26  
\s1 Moto ya zoba 
\q1  
\v 1 Ndenge mvula ya pembe elimwaka na tango ya molunge, 
\q2 mpe mvula enokaka te na tango ya elanga, 
\q2 ndenge wana mpe lokumu oyo bapesi na zoba ekowumela na ye te. 
\b  
\q1  
\v 2 Ndenge ndeke ya moke oyo babengaka mwano 
\q2 ekendaka bipai na bipai 
\q1 to mbilambila\f + \fr 26.2 \ft Mbilambila ezali ndeke ya moke oyo babengaka, na lifalanse : hirondelle.\f* epumbwaka-pumbwaka, 
\q2 ndenge wana mpe elakeli mabe ezwaka te 
\q2 moto oyo asali na ye mabe te. 
\b  
\q1  
\v 3 Ndenge fimbu ezalaka malamu mpo na mpunda, 
\q2 mpe ekangiseli ezalaka malamu mpo na monoko ya ane, 
\q2 ndenge wana mpe fimbu ezalaka malamu mpo na mokongo ya zoba. 
\b  
\q1  
\v 4 Kozongisela zoba te kolanda bozoba na ye, 
\q2 noki te okokokana na ye. 
\b  
\q1  
\v 5 Zongisela zoba kolanda bozoba na ye, 
\q2 noki te akomimona moto ya bwanya na miso na ye moko. 
\b  
\q1  
\v 6 Moto oyo atindaka sango na nzela ya zoba 
\q2 azali lokola moto oyo amikati makolo 
\q2 mpe amilukeli makambo. 
\b  
\q1  
\v 7 Ndenge makolo ya ebosono ezalaka makasi te, 
\q2 ndenge wana mpe masese ezalaka na nguya te 
\q2 kati na monoko ya zoba. 
\b  
\q1  
\v 8 Kopesa zoba lokumu ezali 
\q2 lokola kotia libanga na ebambelo mabanga. 
\b  
\q1  
\v 9 Lisese kati na monoko ya zoba ezali lokola etape ya banzube 
\q2 kati na loboko ya moto oyo alangwe masanga. 
\b  
\q1  
\v 10 Moto oyo azwaka zoba to moleki nzela na mosala 
\q2 azali lokola soda oyo azokisaka moto nyonso na likonga. 
\b  
\q1  
\v 11 Ndenge kaka mbwa ezongelaka kolia biloko oyo yango moko esanzi, 
\q2 ndenge wana mpe zoba azongelaka bozoba na ye. 
\b  
\q1  
\v 12 Eleki malamu kotia elikya na zoba, 
\q2 na esika ete otia elikya na moto 
\q2 oyo amimonaka moto ya bwanya na miso na ye moko. 
\b  
\q1  
\v 13 Moto ya goyigoyi alobaka : « Nkosi ekangi nzela ! 
\q2 Nyama moko ya mabe ezali na kati-kati ya balabala ! » 
\b  
\q1  
\v 14 Moto ya goyigoyi abalukaka na mbeto na ye 
\q2 ndenge ekuke ebalukaka na biloko oyo efungolaka yango. 
\b  
\q1  
\v 15 Moto ya goyigoyi akotisaka loboko na ye kati na bilei, 
\q2 kasi akokaka te kozongisa yango na monoko. 
\b  
\q1  
\v 16 Moto ya goyigoyi amimonaka ete azali na bwanya 
\q2 koleka bato sambo ya mayele. 
\b  
\q1  
\v 17 Moto oyo akotaka makambo oyo etali ye te 
\q2 azali lokola moto oyo akangi mbwa na matoyi. 
\b  
\q1  
\v 18 Ndenge moto ya liboma abwakaka 
\q2 moto, makonga mpe kufa, 
\q1  
\v 19 ndenge wana mpe moto oyo akosi moninga na ye 
\q2 alobaka : « Ezalaki kaka mpo na kosala maseki ! » 
\b  
\q1  
\v 20 Soki bakoni ezali te, moto ekokufa ; 
\q2 soki bato ya songisongi bazali te, koswana ekokita. 
\b  
\q1  
\v 21 Ndenge makala engalaka na mbabola, 
\q2 mpe bakoni epelisaka moto, 
\q1 ndenge wana mpe moto oyo alinga koswana 
\q2 ayeisaka matata. 
\b  
\q1  
\v 22 Maloba ya moto ya songisongi ezalaka 
\q2 lokola bilei ya kitoko, 
\q2 ekitaka na esengo kino na libumu. 
\b  
\q1  
\v 23 Maloba ya sukali ya moto ya motema mabe 
\q2 ezalaka lokola palata ya mbindo oyo bapakoli 
\q2 na mbeki basala na mabele. 
\b  
\q1  
\v 24 Moto oyo ayinaka moninga na ye 
\q2 amibombaka na maloba na ye, 
\q2 kasi atondi na lokuta kati na motema na ye. 
\q1  
\v 25 Ata soki abimisi maloba ya esengo, kondimela ye te, 
\q2 pamba te makambo sambo ya mbindo ebombama 
\q2 kati na motema na ye. 
\q1  
\v 26 Akoki solo kobomba makanisi na ye ya mabe 
\q2 na maloba ya lokuta, 
\q1 kasi motema mabe na ye ekosuka se na koyebana 
\q2 na miso ya bato nyonso. 
\b  
\q1  
\v 27 Moto oyo atimolaka libulu 
\q2 akweyaka ye moko kati na yango ; 
\q1 mpe moto oyo atindikaka libanga, 
\q2 libanga yango ekozongela kaka ye moko. 
\b  
\q1  
\v 28 Lolemo ya lokuta eyinaka bato oyo ezokisi, 
\q2 mpe maloba ya sukali ememaka libebi. 
\b  
\c 27  
\q1  
\v 1 Komikumisa te mpo na mokolo ya lobi, 
\q2 pamba te oyebi te likambo nini mokolo ekoki kobota. 
\b  
\q1  
\v 2 Tika ete moto mosusu akumisa yo, 
\q2 kasi monoko na yo moko te ; 
\q1 tika ete mopaya akumisa yo, 
\q2 kasi bibebu na yo moko te. 
\b  
\q1  
\v 3 Libanga mpe zelo ezalaka kilo, 
\q2 kasi kanda ya zoba ezalaka kilo koleka nyonso mibale. 
\b  
\q1  
\v 4 Kotomboka ememaka makambo ya somo, 
\q2 mpe kanda ebebisaka ; 
\q2 kasi nani akoki kotelema liboso ya zuwa ? 
\b  
\q1  
\v 5 Pamela oyo epesami na polele ezali malamu 
\q2 koleka moto oyo aboyi kopamela mpo na bolingo. 
\b  
\q1  
\v 6 Bapota oyo molingami azokisi ezali malamu 
\q2 koleka babeze ebele ya monguna. 
\b  
\q1  
\v 7 Moto oyo atondi aboyaka ata mafuta ya nzoyi, 
\q2 kasi moto oyo azali na nzala 
\q2 ayokaka ata bilei ya bololo elengi. 
\b  
\q1  
\v 8 Moto oyo ayengaka-yengaka mosika ya mokili na ye 
\q2 azali lokola ndeke oyo ezali koyengayenga 
\q2 mosika ya zala na yango. 
\b  
\q1  
\v 9 Mafuta mpe malasi esepelisaka motema, 
\q2 mpe molingami malamu apesaka toli na motema ya esengo. 
\b  
\q1  
\v 10 Kosundola te molingami na yo to molingami ya tata na yo, 
\q2 mpe kokende te na ndako ya ndeko na yo tango ozali na pasi ; 
\q1 kozala na molingami ya pembeni ezali malamu 
\q2 koleka kozala na ndeko ya mosika. 
\b  
\q1  
\v 11 Mwana na ngai, zala moto ya bwanya 
\q2 mpe sepelisa motema na ngai, 
\q1 mpo ete nazala na eyano ya kopesa 
\q2 na moto oyo akoluka kotiola ngai. 
\b  
\q1  
\v 12 Moto ya mayele amonaka likama na mosika 
\q2 mpe amibombaka, 
\q1 kasi moto oyo azangi mayele alekaka kaka wana 
\q2 mpe akutanaka na pasi. 
\b  
\q1  
\v 13 Kamata elamba ya moto oyo alapi ndayi 
\q2 mpo na niongo ya moto mosusu ; 
\q1 bomba yango lokola ndanga 
\q2 soki alapi ndayi mpo na mwasi mopaya. 
\b  
\q1  
\v 14 Soki moto moko ayei kopambola molingami na ye, 
\q2 na mongongo makasi mpe na tongo-tongo, 
\q2 bakozwa yango lokola elakeli mabe. 
\b  
\q1  
\v 15 Mwasi oyo alinga koswana azali 
\q2 lokola ndako oyo etangaka na tango ya mvula. 
\q1  
\v 16 Kokanga ye ezali lokola 
\q2 koluka kokanga mopepe to mafuta na loboko. 
\b  
\q1  
\v 17 Ndenge kaka ebende epelisaka ebende mosusu, 
\q2 ndenge wana mpe moto abongaka 
\q2 soki akutani na moto mosusu. 
\b  
\q1  
\v 18 Moto oyo abongisaka nzete na ye ya figi 
\q2 aliaka mpe mbuma na yango, 
\q2 mpe moto oyo abatelaka mokonzi azwaka lokumu. 
\b  
\q1  
\v 19 Ndenge mayi ezalaka lokola kitalatala mpo na elongi, 
\q2 ndenge wana mpe motema ya moto elakisaka bomoto na ye moko. 
\b  
\q1  
\v 20 Ndenge lifelo mpe mboka ya bakufi etondaka te, 
\q2 ndenge wana mpe miso ya moto etondaka te. 
\b  
\q1  
\v 21 Bapetolaka palata na kikalungu, 
\q2 mpe bapetolaka wolo na fulu ya moto makasi, 
\q2 kasi bamekaka moto na nzela ya lokumu na ye. 
\b  
\q1  
\v 22 Ata soki otuti moto ya liboma na liboka elongo na mbuma, 
\q2 liboma na ye ekotikala te kolongwa kati na ye. 
\b  
\q1  
\v 23 Yeba malamu ndenge bibwele na yo ezali, 
\q2 mpe kengela yango malamu, 
\q1  
\v 24 pamba te bomengo ewumelaka seko na seko te, 
\q2 motole mpe ewumelaka te mpo na libela. 
\q1  
\v 25 Soki bakati matiti ya bibwele, 
\q2 matiti ya sika ekobota 
\q2 mpe bakolokota matiti ya bangomba ; 
\q1  
\v 26 bameme ekopesa yo bilamba, 
\q2 mpe bantaba ekosunga yo mpo na kosomba elanga. 
\q1  
\v 27 Okozala na miliki ebele ya bantaba 
\q2 mpo na koleisa ndako na yo mpe basali na yo ya basi. 
\b  
\c 28  
\q1  
\v 1 Moto mabe akimaka ata soki moto moko te abengani ye, 
\q2 kasi bato ya sembo bazalaka na mpiko lokola nkosi. 
\b  
\q1  
\v 2 Soki kotomboka ezali kati na mokili, 
\q2 bakonzi bakomaka ebele ; 
\q2 kasi moto ya mayele mpe ya bososoli ayeisaka kimia. 
\b  
\q1  
\v 3 Mokonzi oyo anyokolaka bato bakelela 
\q2 azali lokola mvula ya makasi oyo ebebisaka biloko 
\q2 mpe ememaka nzala. 
\b  
\q1  
\v 4 Bato oyo babukaka mibeko bakumisaka bato mabe, 
\q2 kasi bato oyo babatelaka mibeko batelemelaka bato mabe. 
\b  
\q1  
\v 5 Bato mabe basosolaka te makambo ya bosembo, 
\q2 kasi bato oyo balukaka Yawe basosolaka yango nyonso. 
\b  
\q1  
\v 6 Mobola oyo atambolaka na bosembo azali malamu 
\q2 koleka mozwi oyo nzela na ye ezali mabe. 
\b  
\q1  
\v 7 Moto oyo abatelaka mibeko azali mwana mayele, 
\q2 kasi moto oyo atambolaka na bato ya loyenge 
\q2 ayokisaka tata na ye soni. 
\b  
\q1  
\v 8 Moto oyo abakisaka bomengo na ye na nzela ya moyibi 
\q2 abombelaka yango moto oyo asalisaka babola. 
\b  
\q1  
\v 9 Moto oyo akangi matoyi na ye 
\q2 mpo na koboya koyoka mobeko, 
\q2 libondeli na ye ekomaka nkele na miso ya Nzambe. 
\b  
\q1  
\v 10 Moto oyo amemaka bato ya sembo na nzela ya mabe 
\q2 akokangama na motambo oyo asali ye moko, 
\q2 kasi bato oyo bazangi pamela bakozwa esengo lokola libula na bango. 
\b  
\q1  
\v 11 Mozwi amimonaka lokola moto ya bwanya, 
\q2 kasi mobola oyo azali mayele ayebaka ye malamu. 
\b  
\q1  
\v 12 Tango bato ya sembo balongaka, ezalaka esengo mingi ; 
\q2 kasi tango bato mabe bazwaka bokonzi, 
\q2 bato bamibombaka. 
\b  
\q1  
\v 13 Moto oyo abombaka masumu na ye abongaka te, 
\q2 kasi ye oyo atubelaka mpe atikaka yango azwaka ngolu. 
\b  
\q1  
\v 14 Esengo na moto oyo abangaka tango nyonso kosala mabe, 
\q2 kasi ye oyo ayeisaka motema na ye libanga akweyaka kati na pasi. 
\b  
\q1  
\v 15 Mokonzi mabe oyo azali kokamba bato bakelela 
\q2 azali lokola nkosi ya kanda 
\q2 to lokola ngombolo oyo ezali kolanda nyama ya kolia. 
\b  
\q1  
\v 16 Mokonzi oyo anyokolaka bato azangi mayele, 
\q2 kasi oyo aboyaka bomengo na nzela ya moyibi 
\q2 ayeisaka mikolo ya bomoi na ye ebele. 
\b  
\q1  
\v 17 Moto oyo amitungisaka mpo ete abomi moninga 
\q2 akimaka kino na libulu ya kufa ; 
\q2 tika ete moto moko te akanga ye nzela. 
\b  
\q1  
\v 18 Moto oyo atambolaka na bosembo akozwa lobiko, 
\q2 kasi moto ya mobulu oyo alandaka banzela mibale 
\q2 akokweya na moko. 
\b  
\q1  
\v 19 Moto oyo asalaka bilanga atondaka na bilei, 
\q2 kasi moto oyo alandaka bagoyigoyi 
\q2 akotonda na bobola. 
\b  
\q1  
\v 20 Moto ya sembo afulukaka na mapamboli, 
\q2 kasi moto oyo awelaka kokoma mozwi na lombangu 
\q2 akozanga te kozwa etumbu. 
\b  
\q1  
\v 21 Kopona bilongi ezalaka malamu te ; 
\q2 nzokande ata mpo na eteni ya lipa, moto akoki mpe kosala mabe. 
\b  
\q1  
\v 22 Moto ya bilulela azalaka motema moto-moto 
\q2 mpo na kozwa bomengo, 
\q2 mpe ayebaka te ete bobola ekokomela ye. 
\b  
\q1  
\v 23 Moto oyo apamelaka moninga na ye 
\q2 akozwa ngolu na suka 
\q2 koleka moto oyo alobaka maloba ya sukali. 
\b  
\q1  
\v 24 Moto oyo ayibaka tata mpe mama na ye, 
\q2 bongo alobaka : « Ezali na yango mabe te, » 
\q2 azali moninga ya mobomi. 
\b  
\q1  
\v 25 Moto ya lokoso ayeisaka koswana, 
\q2 kasi moto oyo atiaka elikya na Yawe 
\q2 akotonda na mafuta. 
\b  
\q1  
\v 26 Moto oyo atiaka elikya kati na ye moko kaka azali zoba, 
\q2 kasi moto oyo atambolaka na bwanya akokangolama. 
\b  
\q1  
\v 27 Moto oyo akabelaka babola akozanga eloko te, 
\q2 kasi moto oyo aboyaka kotala bango 
\q2 akotonda na bilakeli mabe. 
\b  
\q1  
\v 28 Tango bato mabe bazwaka bokonzi, bato bamibombaka ; 
\q2 kasi tango bakufaka, bato ya sembo bakomaka ebele. 
\b  
\c 29  
\q1  
\v 1 Moto oyo atiaka moto makasi soki bapameli ye, 
\q2 akokweyisama na pwasa mpe akobika te. 
\b  
\q1  
\v 2 Soki bato ya sembo bakomi ebele, bato basepelaka ; 
\q2 kasi soki bato mabe bakomi koyangela, bato balelaka. 
\b  
\q1  
\v 3 Moto oyo alingaka bwanya asalaka esengo ya tata na ye, 
\q2 kasi moto oyo alandaka basi ya ndumba 
\q2 akosilisa bomengo na ye nyonso. 
\b  
\q1  
\v 4 Mokonzi oyo akambaka na bosembo 
\q2 ayeisaka kimia na mokili na ye, 
\q1 kasi mokonzi oyo afutisaka mpako ebele 
\q2 abebisaka mokili yango. 
\b  
\q1  
\v 5 Moto oyo alobaka na moninga na ye maloba ya sukali 
\q2 atielaka ye motambo na se ya matambe. 
\b  
\q1  
\v 6 Lisumu ya moto mabe ezalaka na motambo, 
\q2 kasi moto ya sembo agangaka na esengo mpe asepelaka. 
\b  
\q1  
\v 7 Moto ya sembo ayebaka pasi ya babola, 
\q2 kasi moto mabe ayebaka na ye kutu yango te. 
\b  
\q1  
\v 8 Batioli batiaka mobulu kati na engumba, 
\q2 kasi bato ya bwanya basilisaka kanda. 
\b  
\q1  
\v 9 Soki moto ya bwanya akei kosamba elongo na moto ya liboma, 
\q2 ezala asiliki to aseki, akotikala kozala na kimia te. 
\b  
\q1  
\v 10 Bato oyo basopaka makila balingaka bato ya sembo te, 
\q2 kasi bato malamu balukaka bato ya sembo. 
\b  
\q1  
\v 11 Zoba alandaka baposa nyonso ya motema na ye, 
\q2 kasi moto ya bwanya akangaka yango mpe akitisaka yango. 
\b  
\q1  
\v 12 Soki mokonzi akomi koyoka makambo ya lokuta, 
\q2 basali na ye nyonso bakokoma bato mabe. 
\b  
\q1  
\v 13 Mobola mpe monyokoli bazali na likambo moko ya lisanga : 
\q2 Yawe angengisaka miso ya bango mibale. 
\b  
\q1  
\v 14 Mokonzi oyo asambisaka babola na bosembo, 
\q2 kiti na ye ya bokonzi ekolendisama tango nyonso. 
\b  
\q1  
\v 15 Fimbu mpe pamela epesaka bwanya, 
\q2 kasi mwana oyo basundola ayokisaka mama na ye soni. 
\b  
\q1  
\v 16 Soki bato mabe bakomi ebele, 
\q2 mabe mpe ekomaka ebele ; 
\q2 kasi bato ya sembo bakomona bango kokweya. 
\b  
\q1  
\v 17 Pesa mwana na yo etumbu, 
\q2 bongo okozala na kimia 
\q2 mpe akotondisa motema na yo na esengo. 
\b  
\q1  
\v 18 Soki emoniseli ezali te, 
\q2 bato bakotambola ngulungulu. 
\q2 Esengo na moto oyo atosaka Mobeko ! 
\b  
\q1  
\v 19 Bapamelaka mosali na maloba te ; 
\q2 pamba te akososola, kasi akoyoka te. 
\b  
\q1  
\v 20 Soki omoni moto kowela koloba liboso ete akanisa, 
\q2 malamu kotia elikya na zoba, kasi na ye te. 
\b  
\q1  
\v 21 Moto oyo alengelaka mosali na ye wuta bolenge 
\q2 akosuka na kokomisa ye moto makasi. 
\b  
\q1  
\v 22 Moto ya kanda amemaka koswana, 
\q2 mpe moto oyo atombokaka noki 
\q2 akomaka na mabe koleka. 
\b  
\q1  
\v 23 Lolendo ya moto ekitisaka ye, 
\q2 kasi moto ya komikitisa azwaka lokumu. 
\b  
\q1  
\v 24 Moto oyo akabolaka biloko elongo na moyibi amiyinaka ; 
\q2 ayokaka bilakeli mabe, kasi amekaka te kofunda ye. 
\b  
\q1  
\v 25 Kobanga bato ezalaka motambo na se ya matambe, 
\q2 kasi Yawe abatelaka moto oyo atiaka elikya na Ye. 
\b  
\q1  
\v 26 Bato ebele balukaka kokoma balingami ya mokonzi, 
\q2 nzokande ezali Yawe nde apesaka 
\q2 oyo ekoki na moto na moto. 
\b  
\q1  
\v 27 Bato ya sembo bayinaka moto ya masumu, 
\q2 mpe moto mabe ayinaka etamboli ya bato ya sembo. 
\c 30  
\s1 Maloba ya Aguri 
\p  
\v 1 Tala maloba ya Aguri, mwana mobali ya Yake. Ezali ye nde alobaki yango epai ya Itieli, epai ya Itieli mpe Ukali : 
\q1  
\v 2 Solo, nazali zoba koleka bato nyonso, 
\q2 nazali ata na mayele ya bomoto te ; 
\q1  
\v 3 nayekolaki bwanya te, 
\q2 mpe nazali na boyebi ya Mosantu te. 
\b  
\q1  
\v 4 Nani amata na Lola to mpe akita wuta kuna ? 
\q2 Nani asangisa mopepe kati na maboko na ye ? 
\q1 Nani akanga mayi na kazaka na ye ? 
\q2 Nani akata bandelo nyonso ya mabele ? 
\q1 Kombo na ye nani ? Mpe kombo ya mwana na ye ezali nani ? 
\q2 Yebisa ngai soki oyebi ! 
\b  
\b  
\q1  
\v 5 Liloba nyonso ya Nzambe ezalaka na libunga te, 
\q2 ezali nguba mpo na bato oyo bazwaka yango 
\q2 lokola ebombamelo na bango. 
\q1  
\v 6 Kobakisa eloko moko te na maloba na Ye, 
\q2 noki te apamela yo mpe abimisa yo mokosi. 
\b  
\q1  
\v 7 Oh Yawe, nasengi Yo biloko mibale, 
\q2 kopimela ngai yango te liboso ete nakufa : 
\q1  
\v 8 longola mosika na ngai makambo ya pamba mpe ya lokuta, 
\q2 kopesa ngai te bobola to bozwi, 
\q2 kasi pesa ngai kaka, mokolo na mokolo, lipa oyo ekoki na ngai, 
\q1  
\v 9 pamba te soki natondi makasi, 
\q2 nakoki kowangana Yo mpe koloba : 
\q2 « Yawe nde nani ? » 
\q1 To soki nazali na bobola, nakoki koyiba 
\q2 mpe koyokisa Kombo ya Nzambe na ngai soni. 
\b  
\q1  
\v 10 Kotonga mowumbu te liboso ya nkolo na ye, 
\q2 noki te alakela yo mabe, mpe omona pasi. 
\b  
\q1  
\v 11 Ezali na bato oyo balakelaka batata na bango mabe 
\q2 mpe bapambolaka te bamama na bango. 
\q1  
\v 12 Ezali na bato oyo bamimonaka peto na miso na bango moko, 
\q2 nzokande bamipetoli na mbindo na bango te. 
\q1  
\v 13 Ezali na bato oyo batonda na lolendo 
\q2 mpe bamonaka bato mosusu pamba. 
\q1  
\v 14 Ezali na bato oyo minu na bango ezali lokola mipanga, 
\q2 lokola mbeli mpo na koboma babola kati na mokili 
\q2 mpe bato bakelela kati na bato. 
\b  
\q1  
\v 15 Sonzo ezalaka na bana basi mibale, 
\q2 egangaka kaka : « Pesa ! Pesa ! » 
\b  
\li1 Ezali na biloko misato oyo etondaka te, 
\li2 minei oyo elobaka te : « Ekoki ! » 
\li3  
\v 16 Mboka ya bakufi, 
\li3 libumu ya mwasi oyo abotaka te, 
\li3 mabele oyo etondaka mayi te, 
\li3 mpe moto oyo elobaka te : « Ekoki ! » 
\b  
\q1  
\v 17 Liso oyo etiolaka tata mpe ezanga botosi epai ya mama, 
\q2 ekotobolama na bayanganga ya lubwaku, 
\q2 mpe bana ya mpongo ekolia yango. 
\b  
\li1  
\v 18 Ezali na biloko misato oyo nasosolaka te, 
\li2 ata kutu minei oyo nayebaka te : 
\li3  
\v 19 Nzela ya mpongo na likolo, 
\li3 nzela ya nyoka na likolo ya libanga, 
\li3 nzela ya masuwa kati na ebale, 
\li3 mpe nzela ya elenge mobali epai ya elenge mwasi. 
\b  
\q1  
\v 20 Tala ndenge mwasi ya ndumba asalaka : 
\q2 Soki alie, apangusaka monoko ; 
\q2 mpe na sima, akoloba : « Nasali na ngai mabe te ! » 
\b  
\li1  
\v 21 Ezali na makambo misato oyo eningisaka mokili, 
\li2 ata kutu minei oyo mokili ekokaka kondima te : 
\li3  
\v 22 Mowumbu oyo akomi mokonzi, 
\li3 zoba oyo atondi na bomengo, 
\li3  
\v 23 mwasi oyo balingaka te, kasi abali ; 
\li3 mpe mwasi mosali oyo azwi bomengo ya nkolo na ye ya mwasi. 
\b  
\li1  
\v 24 Ezali na banyama mike minei na mokili, oyo, nzokande, ezalaka na bwanya mingi : 
\li2  
\v 25 Bafurmi : ezali bikelamu oyo ezanga makasi, 
\li3 kasi ebongisaka bilei na yango na tango ya elanga ; 
\li2  
\v 26 bampanya ya zamba : ezali bikelamu oyo ezanga nguya, 
\li3 kasi etongaka bandako na yango kati na mabanga ; 
\li2  
\v 27 mabanki : ezalaka na mokonzi te, 
\li3 kasi nyonso etambolaka nzela moko na molongo ; 
\li2  
\v 28 moselekete : loboko ekoki kokanga yango, 
\li3 kasi ezalaka kati na bandako ya bakonzi. 
\b  
\li1  
\v 29 Ezali na banyama misato oyo etambolaka malamu, 
\li2 ata kutu minei oyo edendaka soki ezali kotambola : 
\li3  
\v 30 Nkosi : nyama ya makasi kati na banyama, ezongaka sima te ata liboso ya nani ; 
\li3  
\v 31 soso ya mobali, 
\li3 ntaba mobali, 
\li3 mpe mokonzi oyo azali kotambola liboso ya mampinga na ye. 
\b  
\q1  
\v 32 Soki osali bozoba mpo na komikumisa, 
\q2 mpe soki ozali na makanisi mabe, 
\q2 tia loboko na monoko na yo, 
\q1  
\v 33 pamba te kobeta-beta mabele ebimisaka manteka, 
\q2 kobeta zolo ebimisaka makila, 
\q2 mpe kotumbola kanda eyeisaka koswana. 
\c 31  
\s1 Maloba ya mokonzi Lemweli 
\p  
\v 1 Maloba ya mokonzi Lemweli, mateya oyo mama na ye ateyaki ye : 
\q1  
\v 2 Eh mwana na ngai ya mobali, 
\q2 mwana oyo abimi na libumu na ngai, 
\q2 mwana mobali oyo nalapelaka ndayi : 
\q1  
\v 3 Kosilisa makasi na yo na basi te, 
\q2 komitika te na basi oyo bapengwisaka bakonzi ! 
\b  
\q1  
\v 4 Eh Lemweli, ebongi te mpo na bakonzi ; 
\q2 te, ebongi te mpo na bato minene kotuna : 
\q2 « Wapi masanga ya makasi ? » 
\q1  
\v 5 Noki te soki bameli yango, bakobosana mibeko 
\q2 mpe bakokata na bosembo te makambo ya banyokolami. 
\b  
\q1  
\v 6 Pesa masanga ya makasi epai ya bato oyo balingi kokufa, 
\q2 mpe vino epai ya bato oyo bazali kotungisama na motema. 
\q1  
\v 7 Tika bango bamela mpo ete babosana pasi na bango 
\q2 mpe batika kokanisa lisusu minyoko na bango. 
\b  
\q1  
\v 8 Fungola monoko na yo 
\q2 mpo na kolobela bato oyo bazali na makoki ya koloba te, 
\q2 mpe mpo na kolongisa bato oyo bazanga basungi. 
\q1  
\v 9 Fungola monoko na yo mpe sambisa na bosembo, 
\q2 bundela babola mpe bato oyo bakelela. 
\s1 Masese mpo na mwasi ya lokumu 
\q1  
\v 10 Nani akoki komona mwasi ya lokumu ? 
\q2 Azali na motuya koleka babiju ya talo. 
\q1  
\v 11 Mobali na ye atielaka ye motema 
\q2 mpe azangaka te biloko ya motuya. 
\q1  
\v 12 Tango nyonso ya bomoi na ye, 
\q2 apesaka mobali na ye esengo, kasi mawa te ; 
\q1  
\v 13 alukaka bapwale ya meme mpe basinga ya lino, 
\q2 bongo maboko na ye etongaka yango na esengo. 
\q1  
\v 14 Azali lokola masuwa ya bato ya mombongo, 
\q2 akendaka koluka bilei na ye mosika ; 
\q1  
\v 15 alamukaka wana butu ezali nanu, 
\q2 abongisaka bilei mpo na ndako na ye 
\q2 mpe akabolelaka basali na ye ya basi misala. 
\q1  
\v 16 Soki asepeli na elanga, asombaka yango ; 
\q1 mpe na mbuma ya misala na ye, alonaka elanga ya vino. 
\q1  
\v 17 Akangaka loketo na ye makasi 
\q2 mpe akembisaka maboko na ye na mosala. 
\q1  
\v 18 Amonaka ete mombongo na ye etambolaka malamu ; 
\q2 mpe kino na butu, mwinda na ye ekokufa te. 
\q1  
\v 19 Maboko na ye esimbaka mitonga oyo batongelaka, 
\q2 mpe misapi na ye etongaka bilamba. 
\q1  
\v 20 Afungolaka loboko na ye mpo na kokabela babola, 
\q2 mpe asembolaka yango mpo na kosunga bato bakelela. 
\q1  
\v 21 Tango mvula ya pembe ekitaka, 
\q2 abangaka eloko moko te mpo na ndako na ye, 
\q2 pamba te bato nyonso kati na ndako na ye balataka bilamba ya malili. 
\q1  
\v 22 Asalaka babulangeti mpo na mbeto na ye 
\q2 mpe alataka bilamba na ye ya lino ya kitoko mpe ya motane. 
\q1  
\v 23 Bapesaka mobali na ye lokumu, na ekuke ya engumba, 
\q2 tango avandaka elongo na bakambi ya mokili. 
\q1  
\v 24 Asalaka bilamba ya lino mpe atekaka yango, 
\q2 asalaka mombongo ya mikaba. 
\q1  
\v 25 Alataka lokola elamba : molende na mosala mpe lokumu ; 
\q2 mikolo ya lobi ebangisaka ye te, asekaka nde yango. 
\q1  
\v 26 Alobaka na bwanya, 
\q2 mpe lolemo na ye epesaka malakisi na bolingo. 
\q1  
\v 27 Azalaka na bokebi na makambo nyonso oyo elekaka na ndako na ye, 
\q2 mpe aliaka lipa na bogoyigoyi te. 
\q1  
\v 28 Bana na ye bakotelema mpo na kokumisa ye, 
\q2 mpe tala ndenge mobali na ye mpe akumisaka ye : 
\q1  
\v 29 « Basi ebele basalaka makambo ya lokumu ; 
\q2 kasi yo, oleki bango nyonso ! » 
\q1  
\v 30 Bonzenga ya elongi ekosaka, 
\q2 mpe kitoko ya nzoto ezalaka pamba ; 
\q1 kasi mwasi oyo atosaka Yawe, 
\q2 ye nde abongi na lokumu. 
\q1  
\v 31 Bopesa ye bambuma ya misala na ye ! 
\q2 Tika ete bapesa ye lokumu, na bikuke ya engumba, 
\q2 mpo na misala nyonso oyo asalaka !