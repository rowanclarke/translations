\v 4 \w La|strong="H3605"\w* \w causa|strong="H1697"\w* \w por|strong="H1870"\w* \w la|strong="H3605"\w* cual \w Josué|strong="H3091"\w* \w los|strong="H3605"\w* circuncidó fue \w que|strong="H5971"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w salió|strong="H3318"\w* \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w*, \w los|strong="H3605"\w* \w varones|strong="H2145"\w*, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* guerreros, \w murieron|strong="H4191"\w* \w por|strong="H1870"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w* \w en|strong="H3318"\w* \w el|strong="H3605"\w* \w desierto|strong="H4057"\w* después \w que|strong="H5971"\w* \w salieron|strong="H3318"\w* \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w*.  
