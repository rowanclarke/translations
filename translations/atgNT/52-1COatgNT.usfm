\id 1CO - Okphela
\h 1 iKọritia
\toc1 1 iKọritia
\toc2 1 iKọritia
\toc3 1 iKọri
\mt2 Ebe onododẹ ni iPọlu ọ kẹkẹ ghi ẹgbọ
\mt1 IKọritia
\mt2 Eni e miesuọ
\c 1
\s1 Otsẹ oyi iPọlu
\p 
\v 1 Mhẹmhẹ iPọlu, aghiusomhi na kẹẹ ọyi iJesu iKirisiti ni Ẹshinẹgba ọ zẹ abi o ghọle ọli shi mhi khi, li shi inyọghuo awa iSositẹnisi.
\p 
\v 2 Mhẹmhẹ mhi kẹkẹ ebe ona a ghi igbaa oyi eni e mie iJesu iKirisiti suọ onayi Ẹshinẹgba ni e la iKọriti, ikhi eni Ẹshinẹgba ọ lu e khi ẹgbọ eyọli. Eri ọ rẹ ẹ khi ẹgbọ ni e pfuasẹ rọte obọ oyi iJesu iKirisiti, abi ọ li ẹgbọ ni e miesuọ ashakhasha.\f + \fr 1:2 \ft Li zẹ \fq Ika 18.1\f*
\p 
\v 3 Ẹshinẹgba ita awa ali iJesu iKirisiti Ọnọmhuẹ ọyawa e ka li okhale na ẹ, e ri opfọmhẹ na ẹ.
\s1 IPọlu ọ ri ikphẹmhi na Ẹshinẹgba
\p 
\v 4 Ẹghẹghẹ kpa mhi rọ kphẹmhi ẹ na Ẹshinẹgba ọyẹmhẹ irari okhale ni ọ riẹlẹ na ẹ rọte obọ oyi iJesu iKirisiti.
\v 5 Ọ she rẹ mhọli ẹpfue odẹkhodẹ elemhi iguẹngme ungmemhi ali ilẹsẹ nya.
\v 6 Oni usomhi oyi iKirisiti o she lo ẹ egbe shitọ egbegbọ.
\v 7 Irarighọ, isomhopfa ayẹmhẹ okhọghuo ọa ke to ẹ abi a li migha khẹ ibhale oyi iJesu iKirisiti Ọnọmhuẹ oyawa ni a la rọli ya khasẹ.
\v 8 Ọ ya mu ẹ mhuẹ gbaa ya ramhi ukpẹsẹ, ni a khi eni ẹa mhuẹ umhaguẹkia, a khi ogbẹlẹ ni iJesu iKirisiti Ọnọmhuẹ oyawa ọ ya bhale.
\v 9 Ẹshinẹgba ni ọ lu ẹ ni a nu omi ọli iJesu iKirisiti Ọnọmhuẹ ọyawa mhuẹ ugamhi kugbe, ọni a ri egbe ẹ nga ọ khi.
\s1 Okemhi ni o la eni e miesuọ iteva
\p 
\v 10 Inyọghuo-mhẹ mhi ri eva oyi iJesu iKirisiti Ọnọmhuẹ oyawa lema ẹ, ẹẹ nya a ke yemhẹ na egbe ini okemhi o khi lo ẹ le, ali ni a mhọli udu oghuo ali usamhi oghuo.
\v 11 Ẹgbọ eghuo na ọmhuẹ-apfẹ oyi iKiloe e gueyẹ mhẹ khi iwola e la ẹ iteva.
\v 12 Emini mhi ri onana ngme khi, ọgbọgbọ ọọ ngme unu ọdọda, ọghuo ọ khẹ, “IPọlu mhia deba,” ọlese ọọ, “Apolosi mhia deba,” ọlese ọọ, “IPita mhia deba,” ọlese ọọ, “IKirisiti mhia deba.”\f + \fr 1:12 \ft Li zẹ \fq Ika 18.24\f*
\v 13 Eri a kemhi iKirisiti? IPọlu a gbe-a shi ọọra apfida na ẹ? Abi khi eva oyi iPọlu a rọ batazi ẹ? Eniyẹ odukhokho eyi iPọlu a khi?
\v 14 Mhi kphẹmhi na Ẹshinẹgba khi mhi aa batazi ọngẹ ẹ, sẹ ni iKirisipusi ali iGayusi.\f + \fr 1:14 \ft Li zẹ \fq Ika 18.8; 19.29; iRom 16.23\f*
\v 15 Irarighọ, ọngẹ ẹ ọa ya liẹ khi mhi ri eva oyẹmhẹ batazi luẹ.
\v 16 Mhi lẹsẹ khi mhi batazi apfẹ iSitẹfanasi, mhi aa ke sato ini mhi li batazi ọgbọẹse.\f + \fr 1:16 \ft Li zẹ \fq 1 iKọri 16.15\f*
\v 17 Irari khi iKirisiti ọa ghie mhẹ mhi ke batazi ẹgbọ, ama mhi ke kia gue ungmemhi oyọli le ni ọa rọte ilẹsẹ oyi ọgbọ bhale. Ini eghuli ni iKirisiti ọ ghu shi apfida o khi mele afuẹ-a.
\s1 IKirisiti ni ọ khi ilẹsẹ ali ekpabọ
\p 
\v 18 Irari khi eri ungmemhi oyi apfida o khi afuẹ shi esọ oyi ẹgbọ ni ẹẹ pfua ọ, ama awa ni a mie ẹ pfuese, ekpabọ oyi Ẹshinẹgba o khi na awa.
\v 19 Irari khi Ebe-no-pfuasẹ ọọ li,
\q1 “Mhi ya pfuẹchẹ ẹgbhali
\q2 oyi eni e mhọli ẹgbhali-a,
\q1 mhi bi ilẹsingme oyi
\q2 eni ẹ riẹlẹ khi wẹwẹ e guẹ ebe ma.”\f + \fr 1:19 \ft Li zẹ \fq Aza 29.14\f*
\m 
\v 20 Mena, ashi ọna ilẹsingme ọ migha? Ashi ọguebe ọ la? Ashi eni e guẹ khakọ ena agbọ namo e migha? Ọa khi eri Ẹshinẹgba ọ ri ẹgbhali ni e la agbọ ona mele ọọyẹghẹ-a?\f + \fr 1:20 \ft Li zẹ \fq iJobu 12.17; Aza 19.12; 33.18; 44.25\f*
\v 21 Eri Ẹshinẹgba ọ ri ilẹsingme oyi lọlighuo zẹ khi ẹgbọ ẹa rọte ilẹsẹ oyẹwẹ lẹsẹ ọli. Ochoghọ, eri o ghọle Ẹshinẹgba ni ọ rọte itsabọ oyi usomhi ni ẹgbọ ẹẹ khi ọyẹghẹ lọ, tsumhi eni e mie oni usomhi suọ.
\v 22 Ẹgbọ iJu, irọkhasẹ eyi ọnyaloa e migha khẹ, ẹgbọ iGiriki ẹẹ nono ilẹsingme,
\v 23 ama eri anye ri iKirisiti ni a gbe-a tama apfida tse abọ usomhi ona, o ri elemhi a bi ẹgbọ iJu, o khi ọyẹghẹ shi esọ oyi ẹgbọ iJẹta,
\v 24 ama ẹgbọ ni Ẹshinẹgba ọ lu, ghe iJu ali iGiriki e mẹ oni usomhi oyi iKirisiti shi khi ekpabọ ali ilẹsẹ ọyi Ẹshinẹgba o khi.
\v 25 Irari khi emini o li abi umhalẹsẹ oyi Ẹshinẹgba, o mhuẹ ilẹsẹ dọsẹ ẹgbhali oyi ọgbọ, emini o li abi ọlọsẹmhẹ oyi Ẹshinẹgba o mhuẹ itoto dọsẹ ekpabọ oyi ọgbọ.
\p 
\v 26 Inyọghuo, a sato emini a kpe khi neni Ẹshinẹgba ọ lu ẹ. Ẹgbọ ena agbọ ona ẹa bino shi eni e mhọli ugbhẹ, ali khi ọa khi ebubu ẹ e fialo-a, ọa khi ebubu ẹ e khi ekhẹmhuẹ.
\v 27 Eri Ẹshinẹgba ọ zẹ emini ẹgbọ e bino shi emhi eyẹghẹ elemhi agbọ ona kẹ, ọ rẹwẹ ri omama mu elẹsingme. Ọ zẹ emini ẹẹ mhuẹ ochi elemhi agbọ ona rọ khi eni e mhuẹ ekpabọ unu-a.
\p 
\v 28 Ẹshinẹgba ọ zẹ emini ẹa mu ẹloe na agbọ ona ali emini ẹgbọ e ri ẹloe gbe, ni e rọ shi afuẹ. Ọ rẹwẹ ri emini ẹgbọ ẹa bino khi e mu ẹloe mele afuẹ-a,
\v 29 ini ọgbọkhọghuo ọ khi dobẹ la odalo oyi Ẹshinẹgba tono obọ udu.
\v 30 Irari khi lọli ọ ku awa ali iJesu iKirisiti gbe. IKirisiti ni ọ khi ilẹsẹ ni o rọte obọ oyi Ẹshinẹgba bhale. Emini a ri ona ngme khi, lọli ọ khi ipfuasẹ ali irọpfuasẹ ali ipfashekẹ ọyawa.
\v 31 Irari ona, Ebe-no-pfuasẹ o rọ liẹ, “Ọnini ọ da nono ni lọli tono obọ udu, ọ ke ri emini Ọnọmhuẹ ọ riẹlẹ tono obọ udu.”\f + \fr 1:31 \ft Li zẹ \fq iJere 9.24\f*
\c 2
\p 
\v 1 Inyọghuo, abi mhi rọ bhale olieyẹ ẹ ya tsabọ osheli igẹsikia ni o la ungmemhi oyi Ẹshinẹgba, mhi aa lii ngme ingmemhi ena ghọgighọgi, wẹkhi eri mhi rọkhasẹ khi mhii wẹna gba.
\v 2 Irari khi abi mhi rọ la iteva oyẹẹ, eri mhi rue udu emhikpa-a, mhi ri udu lẹsẹ shi ingme oyi iJesu iKirisiti ali eghuli ni ọ ghu shi apfida.
\v 3 Onana o zẹ khi abi mhi rọ te ekẹ bhale, eri mhi li abi ọni ọa mhuẹ ochi, ulishi o rẹmhẹ kpheli.\f + \fr 2:3 \ft Li zẹ \fq Ika 18.9\f*
\v 4 Abi mhi rọ sẹsẹ ẹ, ni mhi rọ tse abọ ungmemhi gueyẹ ẹ, mhi aa ri ilẹsẹdọsẹ ali eta-ọlẹlẹmhunu nu ẹ ngme. Ama eri mhi ri ekpabọ oyi Ayẹmhẹ oyi Ẹshinẹgba khasẹ.
\v 5 Ini irudunga ni a mhuẹ, o khi ya migha nga ẹgbhali oyi ọgbọ, ama ekpabọ oyi Ẹshinẹgba.
\s1 Ilẹsingme oyi Ẹshinẹgba
\p 
\v 6 Usomhi ni o khi oyi ilẹsingme anye gueyẹ ẹgbọ ni e womhẹ ẹloe shi emhi irudunga. Ama ọa khi ilẹsẹ oyi agbọ namo wẹkhi oyi eni ẹẹ mhẹsẹ shi agbọ namo, eni e ya mele afuẹ-a.
\v 7 Ingme osheli ilẹsingme oyi Ẹshinẹgba mhia ngme. Ilẹsingme ni ọ rọ sheli na ẹgbọ agbọagbọ ni ọ she kpẹ gba shi ekẹ khi awa ya mhọli okemhi shi ufumhi oyọli.
\v 8 Aa mẹ oghie ọkhọghuo ighie ena agbọ namo ni ọ lẹsẹ oni ilẹsingme ona. Ini o khia khi e lẹsẹ lọ, ẹa kha ta Ọnọmhuẹ ni ọ mhuẹ ufumhi ma afida gbe-a.
\v 9 Ama abi Ebe-no-pfuasẹ o ngme ni ọọ,
\q1 “Ukpẹloe okhọghuo ọa mẹ ne,
\q2 esọ okhọghuo ọa suọ ne,
\q1 wẹkhi eri ọgbọkhọghuo
\q1 ọ sa udu oyọli ramhi ọ ghue,
\q2 emini Ẹshinẹgba ọ riẹlẹ
\q1 shi ekẹ ẹ khẹ eni
\q2 e nono ingme oyọli.”\f + \fr 2:9 \ft Li zẹ \fq Aza 64.4\f*
\p 
\v 10 Ama Ẹshinẹgba ọ she rọli khasẹ awa rọte Ayẹmhẹ oyọli. Irari khi eri Ayẹmhẹ ọ́ọ́ guanọ emhikpa, ya ramhi osheli ni Ẹshinẹgba ọ gba.
\v 11 Itobọ khi Ayẹmhẹ ni o la ọgbọ egbe luẹghuo o lẹsẹ isamhi eyi ọni ọgbọ. Ighọ ọgbọkhọghuo ọa lẹsẹ isamhi eyi Ẹshinẹgba, sẹẹ ni Ayẹmhẹ oyi Ẹshinẹgba.
\v 12 Awa aa mie ayẹmhẹ oyi agbọ ona, ochoghọ ayẹmhẹ ni o rọte obọ Ẹshinẹgba bhale ni awa rọ lẹsẹ emhi nya ni Ẹshinẹgba ọ rọ na awa afuẹ-afuẹ, awa mie.
\p 
\v 13 Anye ẹa ya ngme ingmemhi ni a rọte ẹgbhali oyi ọgbọ sẹsẹ, ama ingmemhi Ayẹmhẹ oyi Ẹshinẹgba o sẹsẹ anye, anye liẹ sẹsẹ ẹgbọ ni e la elemhi ayẹmhẹ, emini e khi emhi ayẹmhẹ, ni e khi egbegbọ.
\v 14 Ọgbọ ni ọa da mhuẹ oni ayẹmhẹ ne, ọa ya lẹsẹ emini a ri emhi na Ayẹmhẹ oyi Ẹshinẹgba ngme. Ọgbọ ọghọghọ, afuẹ emhi ayẹmhẹ e khi shi ọli ẹloe, irari khi emini e khi odẹ ayẹmhẹ, ayẹmhẹ a te ẹ lẹsẹ wẹ.
\v 15 Ọgbọ ni ọ da mhuẹ oni ayẹmhẹ ne, ọ dobẹ ya lẹsẹ udi emhikpa, ama ẹgbọẹse ẹa dobẹ ya lẹsẹ abi ọni ọgbọ ọna ọ la ọ shi.
\v 16 Abi Ebe-no-pfuasẹ o ngme, ni ọọ,
\q1 “Ọghuo ọ lẹsẹ udu
\q1 oyi Ọnọmhuẹ?
\q2 Ni ọ dobẹ ya ye ọli ude?”
\m Ama khi, awa mhọli udu oyi iKirisiti.\f + \fr 2:16 \ft Li zẹ \fq Aza 40.13\f*
\c 3
\s1 Okemhi ni o la iteva igbaa oyi eni e mie iJesu iKirisiti suọ na iKọriti
\p 
\v 1 Inyọghuo, mhi aa nu ẹ ya ngme abi eni e mhuẹ Ayẹmhẹ oyi Ẹshinẹgba, ama abi ẹgbọ ni ẹ ngeli abi ẹgbọ na agbọ, ali emọfẹ elemhi irudunga oyi iKirisiti.
\v 2 Lọli mhi rọ ri amẹ inyeli na ẹ da ni ọa khi eminale ni e toto, irari khi aa mu egbe shi eminale ni e toto ne. Ramhi memena aa kie mu egbe ne.\f + \fr 3:2 \ft Li zẹ \fq Iburu 5.12-13\f*
\v 3 Ẹgbọ na agbọ a kie khi. Emini o da zẹ khi a kiele ẹ kpe ofuma deba egbe ali khi a nu egbe ẹ ẹ wola, oghọ o rọkhasẹ khi ẹgbọ agbọ a kie khi? Ọa khi eri a kiele ẹ ngeli abi ẹgbọ na agbọ?
\v 4 Ini ọtuọghuo elemhi ẹ ọọ li, “IPọlu mhia deba”, ni ọlese ọ rọ ọ li, Apolosi mhia deba, ọa khi eri a ngeli abi ẹgbọ na agbọ eghọ?\f + \fr 3:4 \ft Li zẹ \fq 1 iKọri 1.12\f*
\p 
\v 5 Ini ẹẹ a bino ọli bie, ọghuo Apolosi ọ fẹ khi? Ọghuo iPọlu ọ khi. Eni ẹẹ ga eyi Ẹshinẹgba anye ga khi ni ẹẹ a rọte obọ oyanye miesuọ. Eri ọgbọgbọ ọọ gbe akanya oyọli ni Ọnọmhuẹ ọ rọna li ọ gbe.
\v 6 Mhẹmhẹ mhi ri ukpamhi kọ, Apolosi ọ ku amẹ shi ọ, ama Ẹshinẹgba ọ zẹ ni oni ukpamhi o rọ fu.\f + \fr 3:6 \ft Li zẹ \fq Ika 18.4-11,24-28\f*
\v 7 Ọni ọ rọ kọ ali ọni o ku amẹ shi ọ, ẹa mu ẹloe. Sẹ khi Ẹshinẹgba ni ọ ri emhi ẹ fu.
\v 8 Ikhiọda ọa laọ na ọni ọ rọ kọ ali ọni ọ ku amẹ shi ọ, Ẹshinẹgba ọ ya ri elele na ọgbọgbọ abi ọ li gbe.
\v 9 Irari khi eri anye kugbe ẹ gbe ikanya na Ẹshinẹgba, ẹẹ a khi ishemhi oyọli.
\p Owa oyi Ẹshinẹgba a gbo khi.
\v 10 Rọte afu ni Ẹshinẹgba ọ rọ na mhẹ, mhi rọ ri irọgbekẹ gbe, abi ọga ọyi itsọna. Onana ẹgbọẹese ẹẹ ma a nga. Eri-tsẹ ọgbọgbọ ọ lẹsẹ abi ọ li ma a nga ọ.
\v 11 Irari khi ọgbọkhọghuo ọa ke gbo dobẹ ya ri irọgbekẹ olese gbe dọsẹ oni Ẹshinẹgba ọ she rọ gbe ni ọ khili iJesu iKirisiti.
\v 12 Ini ọgbọkhọghuo ọ tọ nga oni irọgbekẹ ona, ni ọ rọ ri igolu tọ nga ọ, okekhi ẹlomho, okekhi ẹchẹ ni ẹ ghalẹ, okekhi ẹẹra, okekhi efọlọ, okekhi ifulọ ọ rọ tọ nga ọ.
\v 13 A ya ri emini e la elemhi emini ọgbọgbọ ọ rọ tọ nga ọ khasẹ gboo, ogbẹlẹ iguẹzọ. Erali a rọ ya mhẹsẹ emini ọ rọ tọ nga bino ni a lẹsẹ emini e la elemhi wẹ.
\v 14 Ini emini ọ rọ tọ nga ọ, o pfue oni erali, a ya ri elele na li.
\v 15 Ini e toa, opfu o gbe ọli, ama a ya tsumhi ọli. Eri-tsẹ khi eri o ya li abi ọgbọ ni ọ na pfue ẹlẹmhi erali.
\v 16 Ẹẹ a lẹsẹ khi owa ugamhi oyi Ẹshinẹgba a khi, ali khi Ayẹmhẹ oyi Ẹshinẹgba o la ẹ egbe?\f + \fr 3:16 \ft Li zẹ \fq 1 iKọri 6.19; 2 iKọri 6.16\f*
\v 17 Ini ọgbọkhọghuo ọ yese Owa ugamhi Oniẹmhi oyi Ẹshinẹgba-a, Ẹshinẹgba ọ ya yese ọni ọgbọ-a. Irari khi eri Owa ugamhi oyi Ẹshinẹgba, o pfuasẹ, ali khi Owa Ugamhi oniẹmhi oyọli ẹẹ a khi.
\p 
\v 18 A khi ke di egbe ẹ. Ini ọngẹ ẹ ọ nono ni lọli khi ọni ọ mhọli ilẹsingme shi ẹghẹghẹ ni a la ena, ọ ka khi ọyẹghẹ ni ọ mẹ asha khi ọni ọ khi ọlẹsingme egbegbọ.
\v 19 Irari khi emini ẹgbọ na agbọ ẹẹ bino shi ilẹsingme, afuẹ Ẹshinẹgba ọ bino ọli shi. Abi ebe o ngme, ni ọọ, “Eri Ẹshinẹgba ọ ri ilẹsẹdọsẹ eyi eni ẹ liẹ khi wẹwẹ e lẹsingme riẹlẹ wẹ gbo mu.”\f + \fr 3:19 \ft Li zẹ \fq iJobu 5.13\f*
\v 20 Asha olese o gbo ngme ọli shi ebe khi, “Ẹshinẹgba ọ lẹsẹ khi isamhi ni ọni ọ liẹ khi lọli lẹsẹ dọsẹ ọọ sa khi ẹa mu amẹ.”\f + \fr 3:20 \ft Li zẹ \fq Iwolo 94.11\f*
\v 21 Itobọ ighọ, a khi ke ri ọgbọkhọghuo tono obọ udu, irari khi emhikpa, eyi ẹẹ lọ,
\v 22 o khi iPọlu o, okekhi Apolosi o, okekhi iSẹfasi ni a gbolo a lu iPita o, okekhi agbọ ali eghuli o, okekhi agbọ onana ali ogbenakọ o, ẹẹ a ga mhuẹ wẹ nya.
\v 23 Ẹẹ oyẹẹ eyi iKirisiti a khi, ọni iKirisiti ọ khi ọyi Ẹshinẹgba.
\c 4
\s1 Ighiusomhi na kẹ eyi iKirisiti
\p 
\v 1 A ke sato anye egbe abi eni ẹẹ gbe akanya na iKirisiti ni a ri osheli oyi Ẹshinẹgba nga obọ.
\v 2 A zẹ ni a bhale ya ẹ khi ọni a ri emhi nga obọ, ọ ri igẹsikia deba li.
\v 3 Ẹgboli oyẹmhẹ ọa laọ ini u gue mhẹ ẹzọ, o ke khi ikọtu na agbọ e gue mhẹ ẹzọ. Mhẹmhẹ mhi aa fẹ gue egbemhẹ ẹzọ.
\v 4 Emhikhọghuo ọa nasẹ mhẹ udu ni ọ gue mhẹ ẹzọ, ama oghọ ọa liẹ khi abọ eyẹmhẹ e ma pfuasẹ gba. Ọnọmhuẹ ọọ gue mhẹ ẹzọ.
\v 5 Irarighọ, a khi gue ọgbọkhọghuo ẹzọ ne neni ẹghẹghẹ iguẹzọ o ramhi. Migha ni Ọnọmhuẹ ọ bhale ne. Ọ ya rue emini a rọ sheli alo ebili lasele ali emini e la ọgbọgbọ udu, ẹghẹghẹ aghọ Ẹshinẹgba ọ ya kuẹghiẹ ọgbọgbọ abi o ti shi.
\p 
\v 6 Emọle, mhi she ri Apolosi ali egbemhẹ riẹlẹ irọkhọkhọ khasẹ ẹ ni a rọ lẹsẹ abi ungmemhi onana o ngme ni ọọ li, “A deba oni omhẹsẹ ni o gbe akanya.” Aa khi ke liẹ khi ọghuo e, ọ ti dọsẹ ọlese.
\v 7 Elọ o la e egbe ni o ghọ rẹ ẹ mu ẹloe? Elọ a mhọli ni ọa khi eri a rọli na ẹ? Ini o khia khi eri a rọli na ẹ, elọ o zẹ ni a rọ tono obọ udu?
\p 
\v 8 Ẹẹ a she ga mhuẹ emini a nono nya! Ẹẹ a she ga pfue se! Eri a ke a mhẹsẹ abi ighie, anye tsẹ anye ke khi eni ẹa mhuẹ! Áá kpa liẹ khi egbegbọ a khili ighie, isheghọ ni anye li nu ẹ ke mhẹsẹ!
\v 9 O li mhẹ ẹloe khi anye ighiusomhi na kẹẹ, Ẹshinẹgba ọ rọ shi asha ni o ga khọlọ nẹ nya. Eri anye li abi ighumha ni a rue ẹ je obini olele ni a te ya gbolo wẹ-a. Ni anye khi emhi ofẹli ni ẹgbọ na agbọ ẹẹ gia, ali ni igẹni ẹẹ gia.
\v 10 Irari oyi iKirisiti a rọ bino anye shi eyẹghẹ, ama ẹẹ a khi eni e lolo mhọli ilẹsingme elemhi iKirisiti. Anye aa mhọli ekpabọ, ama ẹẹ a mhọli ekpabọ, ali khi ẹgbọ ẹa mu ekpẹ ẹ na anye, a mu ekpẹ ẹ na ẹ.
\v 11 Ya ramhi amo, okiamhi ali okiamẹ o gbe anye ramhi, anye aa mhọli emini a sọ, sẹ ni ijẹjẹ ide. A ri ukpẹloe a gbe anye, anye aa mhọli ashini a la.
\v 12 Anye rọshẹka ri abọ eyi anye ẹ gbe ikanya. Ini ẹgbọ ẹ ku itsẹ ẹ na anye, anye ẹ ku isẹmhẹ na wẹ, ini a mu okhọli vule shi anye ọ, anye ri egbe mie.\f + \fr 4:12 \ft Li zẹ \fq Ika 18.3\f*
\v 13 Ini ọgbọ ọ yese anye eva-a, anye ri unu ni o pfọmhẹ sọli ọ. Ramhi memena, eri a bino anye shi ẹgbọ afuẹ ali iku ni e la agbọ.
\v 14 Aa khi eri mhi kẹkẹ ebe ona ghi ẹ ni mhi rọ ri omama mu ẹ. Eri mhia nono ni mhi kpaghiẹ ẹ obọ, abi eni e bia eniyẹ e liẹ nono ni wẹwẹ e kpaghiẹ imi wẹ obọ.
\v 15 U dobẹ ya mhọli ẹgbọ agbẹlẹ igbe (10,000) ọdọda ni ẹ sẹsẹ ẹ ungmemhi oyi ikirisiti, ama ita ọghuo u lẹsẹ mhọli. Mhẹmhẹ khi ita ẹ, ẹẹ a khi imimhẹ rọte usomhi onete oyi iJesu iKirisiti ni mhi sẹsẹ ẹ.
\v 16 Irarighọ mhia nono ni a ke khọnya mhẹ.\f + \fr 4:16 \ft Li zẹ \fq 1 iKọri 11.1; iFili 3.17\f*
\v 17 Ona o zẹ ni mhi rọ ghi iTimoti ghi ẹ. Eri mhi nono ingme oyọli abi ọmọ ni mhi bia, ali khi ọni ọọ ga ọyi Ẹshinẹgba ni ọ ri igẹsikia a gbe akanya na Ọnọmhuẹ ọ khi. ITimoti ọ ya gueyẹ ẹ angeli oyẹmhẹ abi mhi liẹ deba iKirisiti ali abi oni angeli oyẹmhẹ o li de shi osẹsẹ ni mhia sẹsẹ ingme oyi iKirisiti elemhi igbaa oyi eni e mie iJesu iKirisiti suọ kpa.
\p 
\v 18 Eghuo elemhi ẹ, e tsua ipfua ekẹ abinẹ khi mhi aa ke ẹ bhale ya fẹli ẹ.
\v 19 O kha ghọle Ọnọmhuẹ, mhi ya kẹlẹ bhale oobọ. Ẹghẹghẹ aghọ, mhẹmhẹghuo mhi ya mẹ abi eni ẹgbọ ni ẹ tsua ipfua ekẹ eghọ e liẹ ngme, ni mhi gbo mẹ ekpabọ nabi ẹ khi wẹwẹ e mhọli.
\v 20 Irari eghiele ni Ẹshinẹgba ọ le shi awa udu, ọa khi oyi ungmemhi unu tsẹ, ama oyi ekpabọ lọ.
\v 21 Elọ a nono ni mhi li ini mhi bhale? Mhi rue utali mhọli obọ bhale, abi mhi ri ayẹmhẹ inono ali o pfọmhẹ bhale?
\c 5
\s1 A khu inyọghuo na itsẹbọ iteva ya fiẹ
\p 
\v 1 Mhi suọ khi angeli itsẹbọ e la iteva oyẹ ẹ. Onabi aa ya mẹ iteva oyi eni ẹa miesuọ kpa, a ga mẹ iteva oyẹẹ. Ni o ramhi khi ọgbọ ọ nu inyọli ọnuzava a gbhẹ.\f + \fr 5:1 \ft Li zẹ \fq iDẹut 22.30\f*
\v 2 A gbo ti ipfuabọ a nga, ocho ni egbe e kha rọ pfọ ẹ-a, ramhi ni a rọ khu ọgbọ ọghọghọ iteva oyẹẹ lasele.
\v 3 Abi o rọ tseku khia khi mhi nuata shi ẹ egbe alo-gbugbugbu, ayẹmhẹ oyẹmhẹ o nu ẹ la. Mhi she pfa ẹzọ mu ọgbọ ni ọ riẹlẹ emhi onana, abinẹ khi mhi la aghọ.
\v 4 Irarighọ, ini a ri eva oyi Ọnọmhuẹ iJesu lona kugbe, ali ni ayẹmhẹ oyẹmhẹ o rọ nu ẹ la, ali ni ekpabọ eyi Ọnọmhuẹ ọ rọ la ẹ iteva,
\v 5 a rue ọgbọ ọghọghọ abọ-a na ọkphaghiẹ, ni ọ pfuẹchẹ idiegbe eyọli-a, ini a pfuese ayẹmhẹ oyọli ini iJesu Ọnọmhuẹ ọ bhale.
\p 
\v 6 O ma khọlọ gba khi a tsua ipfuabọ ekẹ. Ni a rọ ọ zẹ ni ẹgbọ enana e la iteva oyẹẹ. Aa lẹsẹ khi eri e li abi umiesobọ oghuo ni o ri oili gbolo enekpọle-a?\f + \fr 5:6 \ft Li zẹ \fq iGal 5.9\f*
\v 7 A rue ọgbọ ọkhọlọ onana iteva oyẹẹ lasele, ni a mẹ asha la ipfuasẹ. IKirisiti khi omi osumha ọyi iPasova ni a she rọ luasẹ obo na awa.\f + \fr 5:7 \ft Li zẹ \fq Okiali 12.5\f*
\v 8 A khi zẹ ni awa ke riẹlẹ imu elemhi ọkhọlọ ilili ni o li abinẹ khi a kemhi ibulẹdi ni a ri ifuma nye. Awa khi eni e pfuasẹ ali ena igẹsikia, ni awa ke ri ibulẹdi ni aa ri ifuma nye li imu.\f + \fr 5:8 \ft Li zẹ \fq Okiali 13.7; iDẹut 16.3\f*
\v 9 Abi mhi rọ kpẹ te ododẹ kẹkẹ ebe ghi ẹ, mhi gueyẹ ẹ a khi nu ọgbọ na itsẹbọ ke kia kugbe.
\v 10 Ama ọa khi ingme oyi ẹgbọ ena agbọ mhi ngme. Irari khi u mema ya lase elemhi agbọ le neni u wa kie ẹgbọ ni ẹ ku itsẹbọ, ali ena emhi itoegbe ali ighiatọ ali eni ẹẹ ga ikhumhi.
\v 11 Emini mhi ri onana ngme khi, a khi nu ọni ọ miesuọ ọlo-ẹgbhọli, ni ọọ ku itsẹbọ kia kugbe, ọkekhi ọgbọ emhi itoegbe o, ọkekhi ọni ọ ga ikhumhi, ọkekhi ọni ọ yese ọgbọ eva-a, ọkekhi ọdonyọ pfuẹchẹ egbe-a, ọkekhi ọni ọ riẹlẹ alile. Khi ga nu ẹgbọ eghọghọ le eminale kugbe.
\p 
\v 12 Ọa khi akanya oyawa ni awa ke gue ena odato ni ẹa miesuọ ẹzọ. Ena elemhi igbaa oyi eni e mie iJesu iKirisiti suọ tsẹ ni e lina ngeli awa kha lẹsẹ ke gue ẹzọ
\v 13 Ẹshinẹgba ọ ya gue eni ẹa miesuọ ẹzọ, ama abi Ebe-no-pfuasẹ o ngme ọli khi, “A khu ọgbọ ọkhọlọ ọghọghọ ẹ iteva le.”\f + \fr 5:13 \ft Li zẹ \fq iDẹut 13.5; 17.7\f*
\c 6
\s1 Eni e mie suọ e khi ke lu egbe ẹzọ ikọtu
\p 
\v 1 Ini abi a li ga miesuọ abi inyọghuo a mẹ ingme, elọ o zẹ khi a lu egbe ẹzọ shi ikọtu oyi esọ-ẹzọ ni ẹa miesuọ, ocho ni a kha rọ zẹ ni eni e miesuọ e sọ ẹẹ oni ingme?
\v 2 Aa lẹsẹ khi awa ni awa miesuọ, khi awa ya gue ẹgbọ na agbọ ẹzọ? Ẹẹ ni a khi eni e ya gue agbọ ẹzọ, aa dobẹ a sọ shi ukuku ingme ifuabọ eyẹẹ?
\v 3 Aa lẹsẹ khi awa ni awa miesuọ, khi awa ya gue igẹni ẹzọ? Sẹẹ awa aa li ke dobẹ ẹ sọ egbe awa ikuku ingme na agbọ ona.
\v 4 Elọ o zẹ ni a rọ ọ tsua ingme ni a mẹ ogbẹlẹ kpa ke ghi esọ-ẹzọ ni ẹa mhuẹ unu shi ingme igbaa oyi eni e mie iJesu iKirisiti suọ?
\v 5 Eri mhia ngme ona ni omama o mu ẹ. Eri aa mẹ ọngẹẹ ni ọ lẹsẹ ingme iteva oyẹẹ, ni ọ dobẹ ya ri inyọghuo aava ni e miesuọ riẹlẹ?
\v 6 Elọ o zẹ ni ọngẹẹ ọ rọ ọ rue inyọghuo ọli lẹ deba eni ẹa miesuọ ni e rọli gue ẹzọ?
\p 
\v 7 Emini o da zẹ khi a mẹ iluegbe-ẹzọ ikọtu iteva oyẹẹ ne, eri o rọkhasẹ khi eni e de a khi. Oni u kha rọ ri egbe mie ini a lue na ẹ, ni u kha rọ lama ni a li ẹ le,
\v 8 u ri ochoghọ vu ya lue na ẹgbọ, u li wẹ ẹ le, gbo li shi eni e miesuọ elese.
\p 
\v 9 A lẹsẹ gboo khi ọna ọkhọlọ ọa ya lo Eghiele oyi Ẹshinẹgba. Aa khi di egbe ẹ. Ẹgbọ ni ẹ ku itsẹbọ, okekhi eni ẹ ga ikhumhi, okekhi eni ẹ kia okia, okekhi emọse idegbe, ali emọse ni e nu emọse enabi wẹwẹ ẹ gbhẹ,
\v 10 li shi ighiatọ, okekhi ena emhi ituegbe, okekhi edonyọ yese egbe-a, okekhi eni ẹ yese ẹgbọ eva, wẹ khi eni e li ẹgbọ a le, e ya lo Eghiele oyi Ẹshinẹgba.
\v 11 Ẹghẹghẹ o la ọ ni ẹẹ a rọ kpẹ la agbọ oghọghọ, ama a she khuẹsẹ ẹ olamhẹ-a, a khuẹsẹ-a pfuasẹ, a pfa na ẹ, rọte eva oyi iJesu iKirisiti Ọnọmhuẹ ali Ayẹmhẹ ọyi Ẹshinẹgba ọyawa.
\s1 Khi ke gbe ikanya itsẹbọ
\p 
\v 12 Ọgbọ ọ dobẹ ya liẹ, “Emini o ghọle mhẹ mhi dobẹ ya riẹlẹ.” Ama mhiẹ ọli, “Aa khi emhikpa e ti ni u riẹlẹ.” Ali khi ini mhi tseku dobẹ ya riẹlẹ emhikpa, mhi aa gbudu mele oghumha ọyi emhikhọghuo-a.\f + \fr 6:12 \ft Li zẹ \fq 1 iKọri 10.23\f*
\v 13 Wa liẹ khi, “Eminale khi oyi akpidi lọ, ali khi akpidi o khi oyi eminale.” Igẹsikia onana o khi, ama ẹlẹghuo, Ẹshinẹgba ọ ya yese wẹ-a. Ama aa riẹlẹ idiegbe eyawa shi itsẹbọ ilili. Eri a riẹlẹ idiegbe, ni awa rẹwẹ ke ga Ọnọmhuẹ. Ali khi idiegbe oyawa oo mu Ọnọmhuẹ egbe gba.
\v 14 Ali khi Ẹshinẹgba ọ ya ri ekpabọ eyọli guise awa eghuli le, abi ọ guise Ọnọmhuẹ ọyawa eghuli le.
\v 15 Aa lẹsẹ khi idiegbe oyawa khi uguabọ idiegbe oyi iKirisiti lọ. Eri ọgbọ ọ ke ya rue uguobọ idiegbe oyi iKirisiti, ọ ke ku ọli gbe uguobọ oyi adegbe? Ọa zẹ ya li!
\v 16 Abi aa lẹsẹ khi ọgbọ ni ọ da lẹ deba adegbe ne, khi ọ she to egbọli ma ọni adegbe ọ? Idiegbe oghuo e ke khi, irari khi ebe ọọ li, “Wẹwẹ avavava, idiegbe oghuo e ke khi.”\f + \fr 6:16 \ft Li zẹ \fq Igbae 2.24\f*
\v 17 Ama ọgbọ ni ọ da to ma Ọnọmhuẹ ọ ne, ayẹmhẹ ọghuo e ke khi.
\p 
\v 18 Mẹ itsẹbọ ikuku na, olamhẹ okhọghuo ọa la ọ ni o ri ichimhi a mu ọgbọ abi olamhẹ itsẹbọ ikuku. Irari khi olamhẹ itsẹbọ ikuku oo rẹ ẹ lamhẹ shi idiegbe oyi yẹyẹ ghuo ọ.
\v 19 Aa lẹsẹ khi idiegbe oyẹ ẹ khi owa ugamhi oyi Ayẹmhẹ-nọ-pfuasẹ lọ, ni o la idiegbe oyẹ, ni Ẹshinẹgba ọ rọ na ẹ? Ọa ke khi yẹyẹ u mhọli egbe ẹ,\f + \fr 6:19 \ft Li zẹ \fq 1 iKọri 3.16; 2 iKọri 6.16\f*
\v 20 irari khi eri Ẹshinẹgba ọ dẹ ghalẹ. Irarighọ, u mema ya ri idiegbe eyẹ ri ufumhi na Ẹshinẹgba.
\c 7
\s1 Ingme ingeli oyi ọmọse ali ọkpotso
\p 
\v 1 Ni mhi rọ sọ shi ogbọ ni a kẹkẹ shi ebe ya mhila mhẹ.
\p O ti ini ọmọse ali ọkpotso ẹa ya lẹ deba egbe.
\v 2 Ama irari itsẹbọ, ọmọse ọgbọgbọ ali ughuẹ ọli e ke lẹ deba egbe, ọkpotso ali ọdọli e ke lẹ deba egbe.
\v 3 Ọmọse ọ khi ri okiamhi ughuẹ gbe ughuẹ ọli, ọkpotso ọ khi li ri okiamhi ughuẹ gbe ọdọ li.
\v 4 Ọkpotso lọlighuo ọa mhọli idiegbe oyọli, ama ọdọli ọ mhọli wẹ. Ighọ o li khi egbe oyi ọmọse, ọa khi ọmọse lọlighuo ọ mhọli idiegbe eyọli, ama ughuẹ ọli ọ li mhọli wẹ.
\v 5 A khi kie egbe, sẹẹ khi ọmọse ali ọkpotso e lama shi egbe ọ khi wẹwẹ e ya nuata shi ilẹdeba-egbe ne, ni e mẹ asha mhọli ukuku ẹghẹghẹ rọ sọ iromhi. Oni ẹghẹghẹ o kha dọsẹ se, e gbo bhale ya lona, ini ọkphaghiẹ ọ khi mẹ asha mu wẹ fẹ, irari khi egbe ẹa zẹ ẹ mu shi ingme ughuẹ.
\v 6 Eri mhi khọkhọ ona na ẹ, ọa khi ushi ni mhi shi ẹ shi ekẹ na ẹ.
\v 7 O ma kha ti gba ini ọgbọkpa ọ dobẹ ya la ọ ni ọa rue ọkpotso shi abi mhẹmhẹ lọ. Ama awa nya awa aa li abeghuo. Ẹshinẹgba ọ somhi ọgbọgbọ isomhopfa ọdọda. Ọna ọ kha mhọli ona, ọlese ọ mhọli oghọ.
\p 
\v 8 Ẹẹ ni aa la ughuẹ ghue ali esamhi-olimhi, o ti nẹ ini ẹa bie ye ughuẹ abi mhẹmhẹ.
\v 9 Ama ini ẹa dobẹ ya mu egbe wẹ, e ke lẹ ughuẹ. O tinẹ ni a ye ughuẹ dọsẹ ocho ni a rọ ya shitọ, egbe ẹẹ lala ẹ shi ingme ughuẹ.
\p 
\v 10 Ẹẹ ni a la ughuẹ, mhi mhẹsẹ ona na ẹ, ni ọa rọte obọ oyẹmhẹ bhale, ama obọ oyi Ọnọmhuẹ. Ọkpotso ọ khi rọte obọ oyi ọdọli vu.
\v 11 Ama ini ọ li ghọ, ọ khi gbo ye ughuẹ olese ghue, ochoghọ ọ ka nu ọdọli rọ riẹlẹ. Ọmọse ọ khi gbudu khu ughuẹ ọli. \f + \fr 7:11 \ft Li zẹ \fq iMat 5.32; 19.9; iMak 10.11-12; iLuk 16.18\f*
\p 
\v 12 Ẹẹ oyẹẹ enekpọle, mhi gue ona yẹ ẹ, mhẹmhẹ mhi ngme ona, ọa khi Ọnọmhuẹ. Ini ọmọse ni ọ miesuọ ọ rue ọkpotso ni ọa miesuọ ughuẹ, o kha ghọle ọni ọkpotso ni ọ rọ nu ọni ọmọse shitọ, ọni ọmọse ọ khi khu ọli.
\v 13 Ini ọkpotso ni ọ miesuọ ọ ngeli na ọmọse ni ọa miesuọ, ni ọni ọmọse ọ rọ mhọli ọghuẹmhẹ khi lọli ya kie ri ọni ọkpotso shi, ọni ọkpotso ọ khi pfa oni ughuẹ-a.
\v 14 Irari khi ọkpotso ni ọ miesuọ ọọ rue ipfuasẹ ẹ bhale ughuẹ oyọli, ali khi ọmọse ni ọ miesuọ ọ ri ipfuasẹ ẹ bhale ughuẹ oyọli. Ini ọa khi ighọ lọ, imi ẹ, eni ẹa pfuasẹ e kha khi, ama abi o ke li ena khi, a she khuẹsẹ wẹ-a pfuasẹ.
\p 
\v 15 Ama ini ọni ọa miesuọ elemhi wẹwẹ aava, ọọ nono ni lọli lase oni ughuẹ le, ọ ke vu. Emhikhọghuo ọa ke la akana ya mu ọmọse okekhi ọkpotso ni ọ miesuọ mhuẹ ini a mẹ na. Eri Ẹshinẹgba ọ lu awa ni awa rọ la agbọ opfọmhẹ.
\v 16 Yẹyẹ ọkpotso, u fẹ lẹsẹ ini itobọ oyẹ odẹ ọ kha rọ mhuẹ imiepfuese? Abi khi, yẹyẹ ọmọse u lẹsẹ ini itobọ oyẹ ughuẹ ọ kha rọ mhuẹ imiepfuese?
\p 
\v 17 Abibi o tseku li, ọgbọgbọ ọ migha ashini ọ la ni Ẹshinẹgba ọ rọ lu ọli, ali emini ọ lu ọli shi. Ona o khi omhẹsẹ ni mhi rọ na igbaa oyi eni e mie iJesu iKirisiti suọ nya.
\v 18 Ini ọmọse ọ she shẹlẹ-a neni Ẹshinẹgba ọ lu ọli, ọ khi mu ọli pfi riẹlẹ. Ini ọmọse ọa shẹlẹ-a ne neni a lu ọli, ọ khi ya shẹlẹ-a.
\v 19 Ọa mhuẹ abi o ngme, ini ọgbọ ọ shẹlẹ-a okekhia khi ọa shẹlẹ-a, emini o mema mu egbe khi, ni a rọ ri ishi eyi Ẹshinẹgba gbe akanya.
\v 20 Ọgbọgbọ ọ kie li abi ọ la ọ shi ni Ẹshinẹgba ọ rọ lu ọli.
\v 21 Oghumha u khi ni Ẹshinẹgba ọ rọ luẹ? Khi zẹ ni oghọ o nasẹ udu. Ama ini u mẹ asha ya pfa egbe ẹ ọ le, li ghọ.
\v 22 Irari khi ọni ọ khi oghumha ni Ọnọmhuẹ ọ rọ lu ọli, ọni a rue abọ-a ọ ke khi, ighọ li khi ọni a rue abọ-a ni Ọnọmhuẹ ọ rọ lu ọli, oghumha ọyi Ọnọmhuẹ ọ ke khi.
\v 23 Eri a dẹ ẹ ghalẹ, irarighọ a khi gbo khi oghumha oyi ọgbọẹse.
\v 24 Inyọghuo, ọgbọgbọ ọ nu Ẹshinẹgba la abi ọ li ni a rọ lu ẹ.
\p 
\v 25 Shi ingme oyi ozele ni ẹa mu ughuẹ ghue. Mhi aa rọte obọ oyi Ọnọmhuẹ mie ushi ni mhi ya shi na wẹ, ama mhi ri ushi oyẹmhẹ bhale abi ọni a ri itobọ ilẹlemhi khi ọni a ri egbe ẹ nga.
\v 26 Ini a bino ingme ni a mẹ agbọ memena, mhi sa khi o ti ini ọgbọ ọ bie shitọ abi ọ li.
\v 27 U kha la ughuẹ se, khi dua ni u pfa li-a. Ini waa la ughuẹ ne, khi dua abi u li ya lo ọ.
\v 28 Ama ini o khia khi u lo ughuẹ, waa pfidọ, ini o riẹ khia khi u waa mu ughuẹ ghue. Ama eni e rue ikpotso, e ya mhọli anasẹmhẹ elemhi agbọ ona, mhi aa nono ni a mẹ onana.
\p 
\v 29 Inyọghuo emini mhi ri ona ngme khi ẹghẹghẹ o ke shẹ. Rọ te memena vu, emọse ni e rue ikpotso, ughuẹ wẹ e khi mu wẹ egbe dọsẹ.
\v 30 Eni ẹ viẹ, e khi zẹ ni o lo wẹ egbe dọsẹ odẹ. Eni ẹ ghẹlẹ, e khi zẹ ni oghẹlẹ rue wẹ vu, eni ẹ dẹ emhi, e khi zẹ ni emini e dẹ e lo wẹ alo,
\v 31 eni e mhọli emini e ri emhi na agbọ ọ riẹlẹ, e khi zẹ ni e rue wẹ udu vu. Irari khi abi agbọ ona o laọ shi memena, o she ẹ dọsẹ.
\p 
\v 32 Mhia nono ni a rue udu ayele le. Ọmọse ni ọa rue ọkpotso, ikanya eyi Ọnọmhuẹ ẹa ku ọli ẹlẹ-a, irari khi eri ọ nono abi lọli liẹ riẹlẹ ọghuẹmhẹ oyi Ọnọmhuẹ.
\v 33 Ama ọmọse ni ọ rue ọkpotso shi, eri isamhi agbọ ẹẹ nasẹ ọli udu, irari khi eri ọ dua ni lọli ri egbe ke mu ughuẹ ọli.
\v 34 Irarighọ, eri isamhi eyọli ẹ kemhi eva. Eri ọmueshi ni ọa ye ughuẹ, okekhi, ọmueshi ni ọmọse ọa ta owẹ lase ghue, ingme eyi Ọnọmhuẹ ẹ mu ọli egbe. Eri ọ dua ni lọli ri idiegbe ali ayẹmhẹ oyọli na akanya oyi Ọnọmhuẹ pfo nya. Ama ọkpotso ni ọ ye ughuẹ, emhi agbọ ọ sa, irari khi eri ọọ dua abi lọli li ri egbe ẹ ke mu ọdọ.
\p 
\v 35 Eri mhi a ngme onana ni mhi kpaghiẹ ẹ obọ, ọa khi eri mhia nono ni mhi zu ẹ odẹ, ini a khi la ughuẹ. Ochoghọ eri mhia nono ni a ke riẹlẹ emini o tẹ odẹ, ini udu oyẹ o khi kemhi eva shi iregbena Ọnọmhuẹ pfo oyẹẹ.
\p 
\v 36 Ini ọmọse ọ mẹ khi egbe ẹa ke zẹ lọli ẹ mu deba ọmueshi ọyọli ni ọmọse ọa ta owẹ lase ghue, ni e ga lama na egbe khi wẹwẹ e ya ri egbe shi. Ni ọ rọ she tẹ ni ọ ye ughuẹ abi o ye ni o, ọ rue ọni ọmueshi ughuẹ abi o ghọle ọli shi. Ọa lamhẹ.
\v 37 Ama ọmọse ni ọ mẹ khi lọli mhọli udu no toto ni ọ dobẹ ya mu egbọli mhuẹ. Ini ọ lama shi udu oyọli khi lọli ẹa ya rue ọni ọmueshi ọyẹluẹ ne, ọni ọmọse ọna ọ guẹ kia.
\v 38 Ọgbọ ni ọ rue ọmueshi ọyọli ughuẹ ọ guẹ kia. Ọni ọa rue ọli, lọli ọ guẹ kia nẹ.
\p 
\v 39 Ọkpotso ni ọ la ughuẹ, ọa gbudu rọte obọ oyi ọdọli vu ini ọ da kie la agbọ. Ama ini ọdọli ọ ghua, ọ dobẹ ya ngeli na ọmọse ni ọ nono, ama ọmọse ọni ọ miesuọ ọ mema ya khi.
\v 40 Abi mhẹmhẹ sọ oni ingme shi khi, ọ ya mhọli oghẹlẹ nẹ ini ọ shitọ khi ọa bie ke ngeli. Mhi sa khi mhi mhọli Ayẹmhẹ ọyi Ẹshinẹgba ni mhi rọ ọ ngme ona.
\c 8
\s1 Eminale ni a rọ luasẹ ikhumhi
\p 
\v 1 Mena ni mhi rọ ngme nga ogbọ ni a mhila mhẹ ingme eminale ni a rọ luasẹ ikhumhi.
\p Awa lẹsẹ khi, “Awa nya awa ga mhọli ilẹsẹ,” ingme ona. Eri ilẹsẹ o ri ọgbọ a ti-ipfuabọ nga ke titi egbe, ama eri inono o ri awa a kpaghiẹ egbe obọ.
\v 2 Ọni ọ dabi khi lọli lẹsẹ gba, ọa kie lolo lẹsẹ abi ọ kha li lẹsẹ ne.
\v 3 Ama ọgbọ ni ọ nono ingme oyi Ẹshinẹgba, Ẹshinẹgba ọ lẹsẹ ọli.
\p 
\v 4 Ama memena, ingme oyi eminale ni a rọ luasẹ ikhumhi, awa lẹsẹ khi ikhumhi ọa khi emhikhọghuo elemhi agbọ, ali khi Ẹshinẹgba ọghuo ọ khi.
\v 5 Ini a tseku mẹ emini a lu ilitsa ali ekhẹmhuẹ, o khi eni e la idane o, okekhi ena ekẹkhẹ, ọngẹwẹ ọa khi Ẹshinẹgba wẹkhi Ọnọmhuẹ.
\v 6 Ama oyawa khi, Ẹshinẹgba ọghuo kpe awa mhọli, ikhi ita ni emhikpa e rọte obọ oyọli bhale, ali ọni awa la agbọ na, ali khi Ọnọmhuẹ ọghuo ọ la ọ, ni ọ khi iJesu iKirisiti ni emhikpa e rọte obọ oyọli bhale ali ni awa rọte obọ oyọli la agbọ.
\p 
\v 7 Ama ọa khi eni e miesuọ nya e lẹsẹ igẹsikia onana khi afuẹ ilitsa e khi. Ama ingme oyi eni ilitsa ena, o she lo ẹgbọ eghọghọ egbe ramhi khi ini e le eminale ni a rọ luasobo eghọghọ, eri ọ li wẹ egbe khi eni ilitsa e liẹ ga eghọ. Eri ona ọọ yese udu oyẹwẹ ni ọ gue wẹ ẹzọ ọ-a, irari khi ọa lolo toto imiesuọ ne.
\v 8 Ama eminale ẹa ti ọgbọ ọ mama Ẹshinẹgba. Ẹa ri awa ya khi eni ẹa ti ini awa aa le, wẹkhi eri e ke ri awa ya ti nẹ ini awa le.
\p 
\v 9 Ama a kuegbe-a ini afa ni awa mhuẹ rọ ọ riẹlẹ emini o ghọle awa o khi ya khi ọzuodẹ na ọgbọẹse ni ọa toto imiesuọ, ni o rọli ya de pfilo olamhẹ.
\v 10 Ini ọgbọ ni ọ mhuẹ udu ni ọa toto imiesuọ ne ọ fẹ mẹ khi yẹyẹ ni u mhọli ilẹsẹ, khi u la udi olitsa ẹ le eminale, u sa khi oghọ ọa ya ri udu nali rọ ke le eminale ni a rọ luasẹ olitsa?
\v 11 Ighọ ọni ọgbọ ni udu oyọli ọa toto eghọ ni ọ khi inyọghuẹ ni iKirisiti ọ ghu-a na ọ li ya opfu-a itobọ ilẹsẹ oyẹ.
\v 12 Ini a da mẹ na ne, iKirisiti u lue a na, ini u da lue na inyọghuẹ ni a ga miesuọ, eri u wa kuale udu oyẹwẹ ni ọ gue wẹ ẹzọ ni ọa toto eghọ utse.
\v 13 Irarighọ, ini o da khia khi eminale ni mhi le o ri inyọghuo-mhẹ ya de pfilo olamhẹ ne, mhi aa ke gbo tigbe ya le eminale, ini mhi khi ya zẹ ni inyọghuo-mhẹ ọ de pfilo olamhẹ.
\c 9
\s1 Afu ni aghiusomhi na kẹẹ ọ mhọli
\p 
\v 1 Elọ e kpọmhẹ ọ le? Mhi áá khi aghiusomhi na kẹẹ? Mhi áá she mẹ iJesu Ọnọmhuẹ ọyawa, mhi rẹ ẹ mie ọli suọ?
\v 2 Ini o tseku khia khi mhia khi aghiusomhi na kẹẹ shi ẹgbọẹse ọ, mhi aa li khi aghiusomhi na kẹẹ shi ẹ ọ? Akanya ni mhi gbe iteva oyẹẹ o rọkhasẹ khi aghiusomhi mhi khi shi ẹ ọ.
\p 
\v 3 Ina mhi li a sọ ẹgbọ ni e ri unu a yese afu ni mhi mhọli-a,
\v 4 eri mhi aa fu tẹ ọ ni a ri eminale ali onyọ a na shi akanya ni mhia gbe?
\v 5 Mhi aa li fu tẹ ọ ni mhi li ẹ rue ọkpotso ni ọ miesuọ shi, abi ighiusomhi na kẹẹ enekpọle, ali inyọghuo Ọnọmhuẹ ali iPita e li rọshi. Ẹghẹghẹ aghọ ni mhi li ke rue ọli mhuẹ obo ini mhia lẹ asha?
\v 6 Abi khi mhẹmhẹ ali iBanabasi tsẹ anye lẹsẹ khi eni e ri obọ oyẹwẹ ẹ gbe akanya ke ri eminale na egbe anye le?
\v 7 A mẹ ọkhọli-okhuẹ ni lọlighuo ọ fali egbọli ota? Ọghiale ọnọghuo ọa ya le emhi ẹkọmhi eyọli? Ọni ọ ri ena kia ọnọghuo ọa ya rọte ena eyọli da amẹ inyeli?
\p 
\v 8 Abi usamhi oyi ẹgbọ o li mhi liẹ ngme ọli, abi khi eri ushi ọa li mu ma ọ?
\v 9 Irari khi a kẹkẹ ọli shi ebe Ushi oyi iMosisi, “Khi mu ẹna ọnokpo unu zu ini u rọli ẹ mhẹli ikpamhi emhi.” Ingme oyi ẹna wẹẹ khi Ẹshinẹgba ọ li ghọ lẹsẹ sa?\f + \fr 9:9 \ft Li zẹ \fq iDẹut 25.4; 1 iTimo 5.18\f*
\v 10 Itobọ oyawa ọ rọ ngme onana? Ii, irari oyanye a rọ lighọ kẹkẹ ọli. Itobọ khi ọgbọ ni ọ gua ọ kha gua ni ọni ọ khiẹsẹ ọ rọ khiẹsẹ, eri e ga rọli shi udu khi wẹwẹ e ya mhuẹ okemhi shi eni emhi ẹkọmhi.
\v 11 Aborọkhia khi anye she ri emhi ayẹmhẹ kọ iteva oyẹ ẹ eghọ, anye khi eni e kha rọte obọ oyẹ ẹ li khiẹsẹ emhi ikpaghiobọ ni a mẹ ẹloe.\f + \fr 9:11 \ft Li zẹ \fq iRom 15.27\f*
\v 12 Ini o khia khi ẹgbọẹse e tẹ ni a ri ikpaghiobọ ẹ na, ọa khi anye kha ga mema tẹ ọ nẹ? Ama anye ẹa rue ẹtẹ-awẹ oni afu ona.
\p Ochoghọ, eri anye ri egbe mie emini anye mẹ kpa ini anye khi zu usomhi onete oyi iKirisiti odẹ.
\v 13 Aa lẹsẹ khi eni e la Owa Oyi Ẹshinẹgba a gbe akanya, khi oni owa e te ẹ le eminale, ali khi eni e la atẹtẹ ẹ ga, eri e rọte emini a rọ luasobo ẹ kemhi?
\v 14 Ighọ, Ọnọmhuẹ ọ li mhẹsẹ ọli eni e ri usomhi onete a tse abọ, e rọte ọ ke le emhi.\f + \fr 9:14 \ft Li zẹ \fq iMat 10.10; iLuk 10.7\f*
\p 
\v 15 Ama mhia kie ri eni afu ena gbe akanya deba ẹ, wẹkhi eri mhi kẹkẹ ebe ona ni a ba riẹlẹ emhi eghọghọ na mhẹ. O tinẹ ni mhi bie ghu-a ni ọgbọ ọ rọ liẹ mhi khi tono obọ udu.
\v 16 Mhia mhuẹ afu ni mhi rọ tono obọ udu shi usomhi onete ni mhi rọ tse abọ. Eri a mhẹsẹ ọli na mhẹ. O ma khọlọ mhẹ egbe ini mhia ri oni usomhi onete tse abọ!
\v 17 Ini o khia khi eri mhia tsabọ ungmemhi oyi Ẹshinẹgba itobọ khi o ghọle mẹ. A ya fali mhẹ ota. Ama ini o riẹ khia khi ọa ghọle mhẹ, emini Ẹshinẹgba ọ rọ nga mhẹ obọ lọ ni mhia riẹlẹ
\v 18 Ighe ifata ni mhi ke ya mie mena? Afa o khi na mhẹ ni mhi ke tsabọ oni usomhi onete, ni mhia khi oki shi ọ, ni mhia mie emini e khi eyẹmhẹ shi akanya oyi itsabọ usomhi onete.
\p 
\v 19 Mhẹmhẹ ghuo mhi mhẹsẹ ona na egbemhẹ, mhia khi oghumha ọyi ọgbọkhọghuo, ama mhi ri egbe mhẹ mele oghumha ọyi ọgbọkpa-a, ni mhi rọ lu ebubu ẹgbọ na iKirisiti abi mhi li dobẹ.
\v 20 Abi mhi rọ nu ẹgbọ iJu u gbe akanya, mhii ngeli abi ọngi iJu ni mhi rọ dobẹ lu wẹ. Abi o riẹ khia khi ushi iMosisi ọa mu mẹ, mhi kiele ẹ ngeli abi ọni ushi o mu ini mhi nu ẹgbọ ni e la oni ushi gbe akanya, ni mhi dobẹ lu wẹ.
\v 21 Ighọ o li khi, abi mhi rọ nu ẹgbọ iJẹta ẹ gbe akanya, mhi ngeli abi ọgbọ ni ọa khi iJu ni ushi iJu ọa mu ni mhi rọ dobẹ lu wẹ. Ona ọ liẹ khi mhi aa ke ri ushi oyi Ẹshinẹgba a gbe akanya, ama ushi oyi iKirisiti mhi rọ gbe akanya.
\v 22 Ini mhi la ifuabọ oyi eni irudunga oyẹwẹ ọa toto, irudunga oyẹmhẹ o li abi oyẹwẹ, ni mhi rọ dobẹ lu wẹ. Emhikpa mhia mela-a na ẹgbọ nya, ni mhi rọ tsumhi eghuo, odẹ ni mhi ya te dobẹ riẹlẹ ọli kpa.
\p 
\v 23 Enana nya, irari oyi usomhi onete mhi rọ lighọ ni mhi mhuẹ okemhi shi ikhivọsẹ eyọli.
\p 
\v 24 A lẹsẹ khi ebubu ẹgbọ e migha shi unamhi ni a na, ama ọghuo elemhi wẹ ọ kpẹ na a pfo, ni ọ mie eleli unamhi. Irarighọ, a na ode ni a te ya mie eleli oyi unamhi.
\v 25 Eri ọgbọkpa ni ọ la unamhi ya na ọ kpẹ ẹ wẹna ushi unamhi egbegbọ. Eri ẹẹ na ni e mie arula oghie ni ọọ kẹ-a. Ama arula ni o laọ agbọagbọ awa na unamhi ẹ shi.
\v 26 Onana o zẹ ni mhi rọ na unamhi oyẹmhẹ sheshe ya ramhi ukpẹsẹ. Lọli o zẹ ni mhia rọ li abi ọpfiekpa ni ọọ pfi ekpa kua irarogbe.
\v 27 Eri mhia nasẹ egbe eyẹmhẹ ni mhi dobẹ mhẹsẹ ke na wẹ. Mhi aa nono, ini mhi tsabọ oni usomhi onete ona se, ni mhi khi ọni a khu pfia.
\c 10
\s1 A rọte okhẹ oyi ẹgbọ iZirẹni tse agua ye ẹgbọ
\p 
\v 1 Inyọghuo, mhia nono ni a sato emini itita awa ni e deba iMosisi e mẹ. Oguese oyi otughunu o khukhu wẹ, wẹwẹ nya e gbo rọte okẹ ifulọ ya dọsẹ tselele.\f + \fr 10:1 \ft Li zẹ \fq Okiali 13.21-22; 14.22-29\f*
\v 2 Elemhi otughunu ali okẹ oniẹmhi e la batazi abi eni ẹ deba iMosisi.
\v 3 Wẹwẹ nya e le eminale ayẹmhẹ.\f + \fr 10:3 \ft Li zẹ \fq Okiali 16.35\f*
\v 4 E gbo da amẹ oyi ayẹmhẹ oghuo ni o rọte ẹchẹ ayẹmhẹ ni oo deba wẹ tu. Oni ẹchẹ khi iKirisiti.\f + \fr 10:4 \ft Li zẹ \fq Okiali 17.6; iNọba 20.11\f*
\v 5 Abi o tseku li ghọ, egbe ẹa mu Ẹshinẹgba deba ebubu wẹ, itobọ ighọ, eri a miatsẹ ilimhi eyẹwẹ ku ọdagbe ifufu.\f + \fr 10:5 \ft Li zẹ \fq iNọba 14.29-30\f*
\p 
\v 6 Mena, ena nya irọkhasẹ e khi na awa, ni o tse agua ye awa, awa khi mhuẹ ọghuẹmhẹ na emhi ebe abi wẹwẹ e li,\f + \fr 10:6 \ft Li zẹ \fq iNọba 11.4\f*
\v 7 wẹ khi ilitsa awa ya ga abi eghuo ọ e li. Ebe-no-pfuasẹ o ngme ọli khi, “Eni ẹgbọ e shitọ le, e da, e gbe ishimhi idobiẹ, e ku itsẹbọ.”\f + \fr 10:7 \ft Li zẹ \fq Okiali 32.6\f*
\v 8 Awa khi khili ena itsẹbọ abi eghuo ọ e li, ni o zẹ khi agbẹlẹ uye ali esẹ, 23,000, e ghuloa ogbẹlẹghuo.\f + \fr 10:8 \ft Li zẹ \fq iNọba 25.1-18\f*
\v 9 Awa khi mu Ọnọmhuẹ fẹ bino abi eghuo ọ e li, ni enyẹ e rọ gbolo wẹ-a.\f + \fr 10:9 \ft Li zẹ \fq iNọba 21.5-6\f*
\v 10 Awa khi wọlọ abi eghuo ọ e li ni Agẹni eghuli ọ rọ gbolo wẹ-a.\f + \fr 10:10 \ft Li zẹ \fq iNọba 16.41-49\f*
\p 
\v 11 Eri emhi ena nya e li wẹ, ni a rọ sẹsẹ awa ingme ẹlẹ-lese, a kẹkẹ wẹ shi ekẹ tse agua yẹ awa ni awa la ẹghẹghẹ ikpukhokho agbọ ona.
\p 
\v 12 Ini u dabi khi u migha, guẹ kia ini u khi de odẹ-a.
\v 13 Aa mẹ imufẹ okhọghuo ni a mẹ egbe, ni ọa khi onabi ẹgbọẹse ẹa mẹ ghue. Ama Ẹshinẹgba ọni a ri egbe ẹ nga lọ. Ọa ya zẹ ni a mu ẹ fẹ ni o fu dọsẹ ẹ, ni aa ya dobẹ ri egbe mie. Ama ini a mu ẹ fẹ, Ẹshinẹgba ọ ya ri odẹ ni a te ya pfue ọ bhale, ni a rọ dobẹ ya ri egbe mie.
\p 
\v 14 Irarighọ, inyọghuo, a nuata shi ikhumhi ọ.
\v 15 Eri mhi nu ẹ ngme abi ẹgbọ elẹsingme. Ẹẹ ghuo a sa emini mhi ngme.
\v 16 Ini awa rọte uko ni awa lema Ẹshinẹgba ọ khivọsẹ shi da, ọa khi ọlia eyi iKirisiti awa da? Ini awa le ibulẹdi ni awa kemhi, ọa khi idiegbe oyi iKirisiti ni awa le?\f + \fr 10:16 \ft Li zẹ \fq iMat 26.26-28; iMak 14.22-24; iLuk 22.19-20\f*
\v 17 Irari khi ibulẹdi oghuo o khi, awa nya ini awa tseku bu, idiegbe oghuo awa khi, irari khi eminale oghuo awa kemhi.
\p 
\v 18 A sa ingme oyi ẹgbọ iZirẹni ghue. Ọa khi eri wẹwẹ nya ni ẹ le eminale ukhomhi atẹtẹ ugamhi e ga mhọli obọ shi oni ugamhi oyi Ẹshinẹgba eghọ?\f + \fr 10:18 \ft Li zẹ \fq iLẹv 7.6\f*
\v 19 Eri mhi ri ona liẹ khi olitsa ali eminale ni a rọ luasẹ ọli khi egbegbi emhi e khi?
\v 20 Iiye o! Emini mhi a ngme khi, emini eni ẹ ga ikhumhi e rọ luasẹ obo atẹtẹ, ọkphaghiẹ e rẹwẹ ẹ luasẹ, ọa khi Ẹshinẹgba. Mhi aa nono ni a mhuẹ kugbe iyẹmhẹ ọkphaghiẹ ọ.\f + \fr 10:20 \ft Li zẹ \fq iDẹut 32.17\f*
\v 21 Wa ya rọte uko oyi Ọnọmhuẹ da, u gbo rọte uko oyi ọkphaghiẹ da. Wa ya rọte ukpẹko oyi Ọnọmhuẹ le, u gbo te ukpẹko oyi ọkphaghiẹ le.
\v 22 Abi khi eri awa nono ni Ọnọmhuẹ ọ ke kpe ofuma? Eri awa dabi khi awa toto dọsẹ ọli?\f + \fr 10:22 \ft Li zẹ \fq iDẹut 32.21\f*
\s1 Ẹpfua ni eni e miesuọ e mhọli
\p 
\v 23 “Emini o ghọle awa, awa dobẹ ya riẹlẹ.” Abi a li ngme ọli. Ama aa khi emhikpa o mhọli eleli. “Emini o ghọle awa awa dobẹ ya riẹlẹ.” Ama aa khi emhikpa o mhọli ikpaghiobọ.\f + \fr 10:23 \ft Li zẹ \fq 1 iKọri 6.12\f*
\v 24 Ọgbọkhọghuo ọ khi lẹsẹ ke na shi onote oyi egbọli tsẹ ama onete oyi ẹgbọẹse.
\p 
\v 25 Ẹlamhi kpa ni a rọ ọ dẹ oki, ke dẹ ọli le, khi ri irari udu oyẹ ni ọọ gue ẹ ẹzọ mhila ogbọ okhọghuo shi ọ.
\v 26 Irari khi Ebe-no-pfuasẹ o ngme ọli khi, “Ekẹ ali emini e la ọ nya, khi Ọnọmhuẹ o ga mhọli wẹ.”\f + \fr 10:26 \ft Li zẹ \fq Iwolo 24.1\f*
\p 
\v 27 Ini ọgbọ ni ọa miesuọ ọ luẹ ukue, ni u rọ sa li shi udu khi u ya ye, le emiemini ọ rọ shi ẹ ekẹ. Khi mhila ogbọ okhọghuo oyi udu ni ọọ gue ọgbọ ẹzọ.
\v 28 Ama ini ọgbọkhọghuo ọọ yẹ, “Eminale ona, ikhumhi a rọli luasẹ.” Khi le oni eminale oghọ, irari usamhi udu oyi ọni ọ gueyẹ ọghọ, ali irari udu oyẹ.
\v 29 Aa khi irari usamhi udu oyẹ, ama irari usamhi udu oyi ọni ọgbọ ọghọ. “Elọ o zẹ khi ọgbọẹse o ke ya khi ọzuodẹ shi ẹpfua oyẹmhẹ, irari udu oni ọ gue ọgbọ ẹzọ oyi ọli?
\v 30 Ini mhi kphẹmhi na Ẹshinẹgba shi eminale ni mhia le, elọ o zẹ khi ọgbọẹse ọ kẹ tsue mhẹ shi eminale ni mhi kphẹmhi shi?”
\p 
\v 31 Abi o laọ shi khi, emiemini u wa riẹlẹ kpa, ni u wa le, ni u wa da, riẹlẹ ọli shi ufumhi oyi Ẹshinẹgba.
\v 32 Khi ngeli angeli ni o ya ri ọgbọkhọghuo de, o khi ẹgbọ iJu okekhi ẹgbọ iJẹta okekhi igbaa oyi eni e mie iJesu iKirisiti suọ eyi Ẹshinẹgba.
\v 33 Eri mhi dua ni mhi riẹlẹ emini o ti ọgbọkpa ẹloe odẹkhodẹ. Irari khi mhia lẹsẹ na khu oyi mhẹmhẹ ghuo, ama oyi ọgbọkpa ini a mie wẹ pfuese.
\c 11
\p 
\v 1 A ke khọnya mhẹ abi mhi liẹ khọnya iKirisiti Ọnọmhuẹ.\f + \fr 11:1 \ft Li zẹ \fq 1 iKọri 4.16; iFili 3.17\f*
\s1 Ukhomhi iguese elemhi ugamhi
\p 
\v 2 Mhi kuẹghiẹ ẹ shi abi a liẹ sato mhẹ egbe ni a rọ a deba osẹsẹ ni mhi sẹsẹ ẹ.
\p 
\v 3 Ama mhi a nono ni a lẹsẹ khi iKirisiti ọ khi ukhomhi oyi ọmọse nya, ali khi ọmọse ọ khi ukhomhi oyi Ọkpotso. Ama Ẹshinẹgba ọ khi ukhomhi oyi iKirisiti.
\v 4 Irarighọ, ọmọse ni ọọ sọ iromhi okekhi eri ọ ngme ungmemhi imẹguele, ni ọ rọ da ri emhi guese ukhomhi ne, oyẹghẹ ọ rọ ghi iKirisiti ni ọ khi ukhomhi oyọli.
\v 5 Ighọ ọkpotso ọkhọghuo ni ọọ sọ iromhi okekhi eri ọ ngme ungmemhi imẹguele, ni ọa rọ da ri emhi khukhu ukhomhi ne, eri ọ yẹghẹ-a, eri ọ ri ọdọli ni ọ khi ukhomhi oyọli shẹ-a, eri o bie li abinẹ khi ọ kpogholo itsu ukhomhia.
\v 6 Ini ọkpotso ọa da khukhu ukhomhi ne, ọ ka ta itsu ukhomhi-a nyaa. Ini o da khia khi emhi omama ọọ khi ini ọkpotso ọ kpogholo itsu-a eghọ, ọ ke khukhu ukhomhi oyọli.
\v 7 Ọa ye ni ọmọse o khukhu ukhomhi oyọli, irari khi irọkhọkhọ ali ufumhi ọyi Ẹshinẹgba ọ khi. Ama ọkpotso ufumhi oyi ọmọse ọ khi.\f + \fr 11:7 \ft Li zẹ \fq Igbae 1.26-27\f*
\v 8 Irari khi aa rọte egbe oyi ọkpotso ma ọmọse, ama idiegbe oyi ọmọse a te ma ọkpotso.
\v 9 Aa ma ọmọse na ọkpotso, ama ọmọse a ma ọkpotso na.\f + \fr 11:9 \ft Li zẹ \fq Igbae 2.18-23\f*
\v 10 Itobọ onana, ali irari oyi igẹni, ọkpotso ọ ke khukhu ukhomhi oyọli ni ọ rọ rọkhasẹ khi ọ kie la omhẹsẹ oyi ọdọli.
\p 
\v 11 Elemhi Ọnọmhuẹ ni awa ga la, ọkpotso ọa khi ọ́ngéli, wẹ khi ọmọse ọ khi ọ́ngéli ni wẹwẹ aava ẹa mhuẹ abi e liẹ riẹlẹ ugamhi kugbe.
\v 12 Irari khi abi a rọte ọmọse ma ọkpotso, ighọ ọkpotso ọ li bia ọmọse. Ama emhikpa obọ oyi Ẹshinẹgba e te bhale.
\v 13 Ẹẹ ghuo a sọ ọ bino ini o ti ni ọkpotso o ke sọ iromhi lema Ẹshinẹgba ọa ri emhi khukhu ukhomhi elemhi owa ugamhi?
\v 14 Abi a ma emhi nya shi rọte ekẹ vu, ọa sẹsẹ ẹ khi, omama o khi ni ọmọse ọ rọ mhuẹ itsu ni e nuẹ dọlọ shi ukhomhi?
\v 15 Ama khi ini ọkpotso ọ mhuẹ itsu ni e nuẹ shi ukhomhi khi ufumhi ali isomhotse o khi na li? Eri a ri itsu ni e nuata na li ni ọ rọ khukhu ukhomhi.
\v 16 Ini ọgbọ ọ nono ni lọli khakọ shi ingme onana, emini mhi mhuẹ ya ngme khi, anye-a mhọli odẹ olese ni anye te ẹ riẹlẹ, ighọ li khi igbaa nya eyi eni e mie iJesu iKirisiti suọ eyi Ẹshinẹgba.
\s1 Ushi oyi Eminale no pfuasẹ oyi Ọnọmhuẹ
\r (iMat 26.26-29; iMak 14.22-25; iLuk 22.14-20)
\p 
\v 17 Rọte omhẹsẹ ni mhi rọ bhale, mhi aa kuẹghiẹ ẹ, irari khi ilona kugbe shi ugamhi oyẹ ẹ, ọọ li oyese dọsẹ onete.
\v 18 Irari onododẹ, a she gueyẹ mhẹ khi okemhi ọọ la iteva oyẹẹ ini a lona ilegba abi eni e mie iJesu iKirisiti suọ. Mhi mie shi ọ khi ighọ o khi.
\v 19 Aa mẹ emini o zẹ khi aa ya khakọ. Ama oni ekhakọ ona o ya ri eni Ẹshinẹgba ọ mie iteva oyi ẹ khasẹ.
\v 20 Ini a lona kugbe shi oghuo, ọa khi eminale oyi Ọnọmhuẹ o khi ni a le,
\v 21 Irari khi ini a le, aa ya migha khẹ egbe. Ọgbọgbọ ọ rue eminale oyọli ẹ le. Irarighọ, eri eghuo ẹ da pfuẹchẹ egbe-a, eghuo ẹa ga mẹ le kpa.
\v 22 Aa mhuẹ apfẹ oyẹ ẹ ni a la le ni a la da? Abi khi eri a ri ẹloe a gbe igbaa oyi eni e mie iJesu iKirisiti suọ oyi Ẹshinẹgba? Eri a nono ni a ri omama mu ẹgbọ ni ẹa mhuẹ emhikhọghuo? Sẹ a nono ni mhi ngme shi onana? Eri mhi ya kuẹghiẹ ẹ mena? Iiye o!
\p 
\v 23 Irari khi obọ oyi Ọnọmhuẹ mhi te mie osẹsẹ ni mhi sẹsẹ ẹ. Khi iJesu Ọnọmhuẹ, ẹliyọsẹ ni a rọli dẹ, ọ rue ibulẹdi,
\v 24 ọ kphẹmhi na Ẹshinẹgba ọ khi ọli-a, ọọ li, “Idiegbe oyẹmhẹ na ni a rọ na e, a ke li ona rọ sato mhẹ egbe.”
\v 25 Ighọ ọ gbo li, abi e rọ le se. Ọ rue uko onyọ, ọọ li, “Onana o khi uko oyi ilama kugbe onogbọ, ni a ri ọlia eyẹmhẹ riẹlẹ. Ini a da lina da ne, eri a da li rọ sato mhẹ egbe.”\f + \fr 11:25 \ft Li zẹ \fq Okiali 24.6-8; iJere 31.31-34\f*
\v 26 Irari khi ẹghẹghẹ kpa ni a rọ da le ibulẹdi onana ni a rọ da oni uko onana ne, eghuli oyi Ọnọmhuẹ u rọ tse abọ eghọ neni ọ ya bhale.
\p 
\v 27 Ọnini ọ da le ibulẹdi oyi Ọnọmhuẹ ni ọ gbo rọte uko oyọli da, odẹ ni ọa gbe akanya ne, ọ she luẹ, ọ lamhẹ shi idiegbe ali ọlia oyi Ọnọmhuẹ ọ.
\v 28 Irarighọ, ọgbọgbọ ọ bino egbọli bie ne neni ọ tigbe le, neni ọ rọte oni uko da.
\v 29 Ini u waa da lẹsẹ emini oni idiegbe oyi Ọnọmhuẹ ona o migha shi ne, ni u rọ da le oni ibulẹdi ni u rọ gbo te oni uko da, u she le u gbo da rọ ri iguẹzọ bhale ghi egbe ẹ.
\v 30 Ona o zẹ ni ebubu ẹ e rọ ọ ghua, eghuo ẹa mhuẹ ochi, ebubu e she ghulo-a.
\v 31 Ini awa kpẹ gue egbe awa ẹzọ awa aa ya de pfilo ẹzọ oyi Ẹshinẹgba.
\v 32 Ini Ọnọmhuẹ ọ gue awa ẹzọ, eri ọ sẹsẹ awa ingme ini awa khi nu agbọ pfua.
\p 
\v 33 Irarighọ, ẹẹ inyọghuo-mhẹ, ini awa lona ni awa rọ ya le eminale oyi Ọnọmhuẹ, awa ke migha khẹ egbe.
\v 34 Ini a mẹ ọni okiamhi ọọ gbe, ọ la apfẹ le emhi ini a khi lo ẹzọ oyi Ẹshinẹgba, ini a lona kugbe. Mhi ya pfuse ingme enekpọle ngme ini mhi bhale.
\c 12
\s1 Isomhopfa Ayẹmhẹ
\p 
\v 1 Mena ni mhi rọ sọ shi ogbọ ni a mhila mhẹ ingme isomhopfa Ayẹmhẹ-nọ-pfuasẹ.
\p Mhia nono ni a lẹsẹ egbegbingme ni o la ọ.
\v 2 A lẹsẹ khi ẹghẹghẹ ni a rọ khili eni ẹa miesuọ, a di ẹ lo ode ni a la luasẹ ilitsa ni ẹa mhuẹ ayẹmhẹ.
\v 3 Mhia nono ni mhi gueyẹ ẹ khi aa mẹ ọgbọ ni Ayẹmhẹ oyi Ẹshinẹgba o rọ gbe akanya ni ọ ya liẹ, “A pfi unu na iJesu!” Aa mẹ ọni ọ gbolo ya liẹ, “IJesu ọ khi Ọnọmhuẹ!” Ini ọa li khi Ayẹmhẹ-nọ-pfuasẹ ọ sẹsẹ ọli.
\p 
\v 4 Isomhopfa ọdọda e la ọ, ama Ayẹmhẹ ọghuo ọ kemhi wẹ.
\v 5 Odẹ ebubu e laọ ni a te ẹ ga Ọnọmhuẹ, ama Ọnọmhuẹ ọghuo awa ga.
\v 6 Odẹ ọdọda Ẹshinẹgba ọ te ẹ gbe ikanya elemhi agbọ eyi awa, ama ọni Ẹshinẹgba ọ lighọ gbe oni akanya ona rọte idiegbe oyi awa nya.
\v 7 Ọgbọgbọ a ri isomhopfa Ayẹmhẹ na, ni ọ rọ ke gbe akanya ni o kpaghiẹ ọgbọkpa obọ.
\v 8 Ọni Ayẹmhẹ lọli ọ ri isomhopfa oyi ungmemhi ẹgbhali na ọgbọ ọghuo. Ọni Ayẹmhẹ ọ kie gbolo ri isomhopfa ilẹsingme a na ọgbọẹse.
\v 9 Ọni Ayẹmhẹ ọ gbo ri irudunga oniẹmhi a na ọgbọ. Ọni Ayẹmhẹ ọghuo ọ kie gbo ri ekpabọ na ọgbọẹse ni ọ rọ ri ọgbọ toto.
\v 10 Ọni Ayẹmhẹ ọ ri ekpabọ na ọgbọ ni ọ rọ gbe ikanya ọnyaloa, ọ ri ekpabọ na ọgbọẹse ni ọ rọ mẹ ekẹ guele. Ọ gbo rọ-na ọgbọẹse ni ọ lẹsẹ ikhiọda ni o la iyẹmhẹ ọdọda ọ. Ọ rọ-na ọgbọ ni ọ rọ dobẹ ẹ ngme ẹmuẹ ọda, ọ rọ-na ọlese ni ọ dobẹ guele abi oni ẹmuẹ oghọ o ngme.
\v 11 Ama Ayẹmhẹ ọghuo ọ kie khi ni ọ ga gbe eni ikanya eghọ abi o ghọle ọli shi. Ọ ri isomhopfa ọdọda na ọgbọgbọ.\f + \fr 12:11 \ft Li zẹ \fq iRom 12.6-8\f*
\s1 Idiegbe oghuo ni o mhuẹ iguabọ ọdọda
\p 
\v 12 Eri iKirisiti ọ li abi idiegbe oghuo ni o mhuẹ iguabọ ọdọda, idiegbe oghuo o kie khi, ini o tseku mhọli iguabọ ebubu ọdọda.\f + \fr 12:12 \ft Li zẹ \fq iRom 12.4-5\f*
\v 13 Ighọ awa nya awa gbo li, o khi ọngi iJu u khi, okekhi ọnge iJẹta, o ke khi oghumha oo, o ke khi ọni ọọ khi oghumha, a she batazi awa shi idiegbe oghuo rọte ọni Ayẹmhẹ oghuo ọghọ, a kie gbo ri oni ayẹmhẹ oghuo ọghọ na awa.
\p 
\v 14 Irari khi idiegbe ọa khi uguobọ oghuo tsẹ lọli nya o khi, ama iguabọ ni e bu o mhọli.
\v 15 Ini owẹ o gueyẹ obọ, “Irari khi mhia da khi obọ, mhi aa ke kugbe idiegbe ọ,” Oni owẹ ọa kie khi oyi idiegbe?
\v 16 Ini esọ ọọ khi, “Irari khi mhi aa khili ẹloe, mhi aa ke khili oyi oni idiegbe.” Oghọ o ya liẹ khi ọa ke la oni idiegbe?
\v 17 Ini idiegbe nya o khili ẹloe lọ, sẹ o kha li ke suọ. Abi ini idiegbe nya o ke khili esọ lọ, sẹ o kha li ke suọ isue?
\v 18 Abi o li khi, eri Ẹshinẹgba ọ tono iguabọ egbe ọdọda ma shi idiegbe abi ọ li nono ọli shi.
\v 19 Idiegbe o ya gbapfo, ini o khia uguabọ oghuo tsẹ lọli nya o khi?
\v 20 Abi o li khi, iguabọ ọdọda e la o, ama idegbe oghuo kpe o khi.
\v 21 Irarighọ, ẹloe ọa ya liẹ obọ, “Mhi aa mhuẹ emini mhi rẹ ya li!” Wẹ khi ukhomhi o ya liẹ awẹ mhia mhuẹ emini mhi rẹ ya li.
\v 22 Ini awa te ukiẹkiẹ ọ obini ọ kpọle oyi ingme ona bino ọli, iguabọ oyi idiegbe ni ọa lolo toto, ọa zẹ idiegbe ya tsua pfia,
\v 23 ama idiegbe ni awa bino khi ẹa lolo mu ẹloe, wẹwẹ awa ga sọnọ itsua guese. Awa a kuegbea guese iguabọ idiegbe ni ọa ti ni a ke khueghie-a shi ekẹ ni áá mẹ ẹloe,
\v 24 Ama awa aa ya sọ itsua guese ikpe ni e zẹ rọ ọ shi ekẹ ni ẹgbọẹse e mẹ ẹloe. Eri Ẹshinẹgba ọ lighọ riẹlẹ idiegbe, ni awa mu ekpẹ na iguabọ ni e li abinẹ khi ẹa lolo mu ẹloe.
\v 25 Itobọ ighọ, okemhi ọa la idiegbe, eri ikpe ọdọda eghọ e ri ẹloe a khu egbe.
\v 26 Ini asha eghuo ọọ mẹ osoli, ikpe enekpọle nya e li nu ọli a mẹ oni osoli. Ini a ri ekpẹ na uguabọ idiegbe oghuo eri enekpọle nya ẹẹ ghẹlẹ.
\p 
\v 27 Ẹẹ nya idiegbe oyi iKirisiti a khi, ọgbọgbọ ọ khi uguobọ oyọli.
\v 28 Elemhi igbaa oyi eni e mie iJesu iKirisiti suọ, onododẹ, Ẹshinẹgba ọ zẹ ighiusomhi na kẹẹ, onuzi-eva ọ zẹ emekẹguele, onuzi-esẹ, esẹsẹ, ọ tigbe ri eni ẹ gbe ọnyaloa shi asha eghuo, gbo li shi eni mhọli isomhopfa ni a rọ ri ọgbọ ze. Ọ gbo zẹ eni e guẹ ẹ kpaghiẹ ẹgbọẹse obọ, elese ọ zẹwẹ eni e guẹ ri omhẹsẹ kia, ali eni ẹ ngme ẹmuẹ ọdọda.\f + \fr 12:28 \ft Li zẹ \fq Ẹfi 4.11\f*
\v 29 Wẹwẹ nya e khi ighiusomhi na kẹẹ? Wẹwẹ nya e khi emekẹguele? Wẹwẹ nya e khi esẹsẹ? Ọgbọkpa ọ dobẹ a gbe akanya ọnyaloa?
\v 30 Wẹwẹ nya e mhọli isomhopfa oyi iri-ọgbọ ze? Ẹgbọ nya e guẹ ngme ẹmuẹ ọdọda? Abi khi wẹwẹ nya e guẹ ẹ guele abi oni ẹmuẹ ọdọda o ngme?
\v 31 Irarighọ, awa ke nono isomhopfa ni o tinẹ nya.
\p Mhi ya ri odẹ ni o tinẹ nya khasẹ ẹ.
\c 13
\s1 Inono
\p 
\v 1 Ini mhi ga guẹ ẹ ngme ẹmuẹ oyi ẹgbọ ali oyi igẹni, ni mhi aa rọ mhuẹ inono, okeke ulo ali okeke ipẹpẹ itasa mhi khi.
\v 2 Ini mhi mhuẹ isomhopfa imekẹguele ali ni mhi rọ lẹsẹ udi osheli ali ilẹsẹ nya a guele. Mhi kha mhọli irudunga ni a rọ dobẹ ọọghiẹ ite, ni mhi aa rọ mhuẹ inono, afuẹ mhi khi.\f + \fr 13:2 \ft Li zẹ \fq iMat 17.20; 21.21; iMak 11.23\f*
\v 3 Mhi kha ga ri emini mhi mhuẹ nya somhopfa, ni mhi rọ ga ri egbe mhẹ bhale ni a tosẹ-a ni mhi ba tono obọ udu, ni mhi aa rọ mhuẹ inono, mhi aa mhuẹ elele okhọghuo ni mhi ya mẹ.
\p 
\v 4 Eri inono o mhọli irabọmudu, o mhọli isomhelemhi. Ọa ya kpe ofuma, ọa ya tono obọ udu, ọa ya vuse ike.
\v 5 Inono ọa ya ngeli angeli obe, ọa ya khu oyọli tsẹ, elemhi ẹa kẹlẹ bi inono, ọa ya kẹkẹ ingme ni a li ọli ya shi na ọgbọ.
\v 6 Ọa ya mẹ emhi obe ni ọọ ke ghẹlẹ shi ọ, ama emhi egbegbingme o ghẹlẹ ẹ shi.
\v 7 Ọa ya mhọli ukhimhi-elemhi. Irudunga ali irudushi, ali irabọmudu oyọli ọa ya ba li ku.
\p 
\v 8 Inono ọa mhuẹ ukpẹsẹ. Imekẹguele e la ọ, eri-tsẹ khi e ya dọsẹ, isomhopfa oyi ingme-ẹmuẹ ọdọda e la ọ, ama e ya dọsẹ, ilẹsingme e la ọ, ama e ya dọsẹ.
\v 9 Irarikhi isomhopfa ilẹsingme ali imekẹguele oyawa ẹa ya gba pfo.
\v 10 Ama ini oni o gba pfo o ramhi, oni ọa gba pfo o kele-a.
\v 11 Abi mhi rọ khi ọmọ, ẹmuẹ ali isamhi ali akhọkhọmhẹ eyẹmhẹ, e khi eyi ọmọ. Mena abi mhi rọ ke khi ọgbhali, mhi aa ke mhuẹ emini mhi ri angeli ọmọ a li.
\v 12 Emini awa mẹ memena, eri o li abi aroro ni awa rọte ughegbe ẹ mẹ lishi-lishi. Ẹghẹghẹ aghọ o kha ramhi, awa ya mẹ ọli ghemhẹ, ghe ẹ. Emini mhi lẹsẹ, ọa gba pfo, ama ẹghẹghẹ aghọ, o ya gbapfo, abi Ẹshinẹgba ọ li sẹsẹ mhẹ pfo.
\p 
\v 13 Ama eni emhi esẹ enana e kie migha: Irudunga, irudushi, ali inono. Oni o ga funẹ nya shi wẹ ọ khi inono.
\c 14
\s1 Isomhopfa imekẹguele ali ẹmuẹ
\p 
\v 1 Zobẹ ni inono o khi emini u na a khu.
\p Ke dua ni u mhọli isomhopfa eyi Ayẹmhẹ no pfuasẹ, tete isomhopfa imekẹguele.
\v 2 Ọgbọ ni ọọ ngme ẹmuẹ ni ọgbọ ọa lẹsẹ emini ọọ ngme, Ẹshinẹgba ọ nu ẹ ngme, irari ọgbọkhọghuo ọa ya lẹsẹ emini ọ ri eni ingmemhi ngme. Egbegbi ingme osheli ọ rọte Ayẹmhẹ no pfuasẹ ẹẹ ngme.
\v 3 Ama ọgbọkpa ni ọ mekẹ ngme guele, eri ọọ nu ẹgbọ ọ ngme, o kpaghiẹ wẹ obọ, ọ ri udu shi wẹ ọ, ọ ri udu pfọmhi wẹ.
\v 4 Ọgbọ ni ọọ ngme ẹmuẹ ọda ni ẹgbọ ẹa lẹsẹ emini o ngme, egbọli ọọ kpaghiẹ obọ, ama ọgbọ ni ọ mekẹguele, igbaa oyi eni e mie iJesu iKirisiti suọ nya ọọ kpaghiẹ obọ.
\v 5 O ga ghọle mhẹ ni ẹẹ nya a ke ngme ẹmuẹ ọdọda, ama oni o ghọle mhẹ nẹ khi ni a ga mhọli isomhopfa imekẹguele. Irari khi ọni ọ mekẹguele ọ mu ẹloe dọsẹ ọni ọ ngme ẹmuẹ ọda. Sẹẹ ni eri ọgbọ ọ la aghọ ni ọ guele abi ọ ngme ni ọgbọkpa ni ọ la igbaa oyi eni e mie iJesu iKirisiti suọ ọ mhuẹ ikpaghiobọ.
\p 
\v 6 Ighọ inyọghuo, ini mhi bhale deba ẹ ni mhi rọ ọ ngme ẹmuẹ ọda, onete onoghuo o ya riẹlẹ na ẹ? Ọa khi ini, mhi gue irọkhasẹ ni mhi rọte obo oyi Ẹshinẹgba mẹ ye ẹ, okekhi emini mhi lẹsẹ mhi gueyẹ ẹ, okekhi imẹguele mhi gueyẹ ẹ, ọkekhi ungmemhi osẹsẹ mhi rọ bhale ghi ẹ, o ya ri eleli na ẹ?
\v 7 Bino itsua ni ẹa mhuẹ ayẹmhẹ, ni ẹẹ ngme, enabi ofele ali ẹfa. Sẹẹ ọgbọkhọghuo ọ li ya lẹsẹ emini a kpheli, ini ọa suọ obini a mu abọ wẹ je?
\v 8 Ali ọni ọọ pfi akala, ini ọa li pfi ọli gboo ni o de uruli ni a suọ, ọghuo ọ ya mu egbe okhọli?
\v 9 Ighọ khi, ini u ri emuẹ ni ẹgbọ ẹa ya suọ ọ ngme ingmemhi ni e mhọli ilẹsingme, ọgbọkhọghuo ọa ya lẹsẹ emini wa ngme. Eri u lẹsẹ ke ngme kua idane!
\v 10 Ẹmuẹ ebubu e la agbọ ona, wẹwẹ nya e khi eni e ti shi eni ẹ ngme wẹ ọ.
\v 11 Ama ini mhi aa lẹsẹ ẹmuẹ ni a ngme, ọni ọ nu mhẹ ngme, ọpfẹse ọ khi shi mẹ ọ, mhẹmhẹ khi ọpfẹse shi ọli ọ.
\v 12 Aborọkhia khi isomhopfa eyi ayẹmhẹ e mema kiele ẹ ghọle ẹ eghọ, a ke nono isomhopfa eni e ya ri ikpaghiobọ ghi igbaa oyi eni e mie iJesu iKirisiti suọ.
\p 
\v 13 Itobọ ighọ, ọni ọọ ngme ẹmuẹ ọda ọ mema ya lema a ri ekpabọ ni ọ rọ ọ ke guele abi ọ ngme na li.
\v 14 Irari ini mhi ri ẹmuẹ ọda a sọ iromhi, ayẹmhẹ oyẹmhẹ ọọ sọ iromhi, ama udu oyẹmhẹ ọa ya mhẹ mhuẹ emini ọ mu ọ.
\v 15 Sẹ mhi ke ya li shọ? Mhi ga ya riẹlẹ wẹwẹ eve-eva ena. Eri mhi ya ri ayẹmhẹ oyẹmhẹ sọ iromhi, mhi gbo li ri udu oyẹmhẹ sọ. Mhi ya ri ayẹmhẹ oyẹmhẹ to uwolo, mhi gbo li ri udu oyẹmhẹ to.
\v 16 Ini u ri ikphẹmhi na Ẹshinẹgba elemhi ayẹmhẹ tsẹ, sẹ ẹgbọ enekpọle ni ẹa ya suọ ikphẹmhi ni u rọ na Ẹshinẹgba e liẹ suọ, ni e mie Atsẹ shi ẹ oni iromhi ali ikphẹmhi? Ẹa mhuẹ abi e li ya lẹsẹ emini u wa ngme.
\v 17 Ini o tseku khia khi iromhi ikphẹmhi eyẹ khi enete lọ, ẹa ga kpaghiẹ ẹgbọ enekpọle obọ.
\v 18 Mhi kphẹmhi na Ẹshinẹgba khi mhi ga ngme ẹmuẹ ọdọda dọsẹ ẹẹ nyaa.
\v 19 Ini a la ugamhi igbaa oyi eni e mie iJesu iKirisiti suọ, o ti mhẹ egbe ni mhi lẹsẹ ngme ikpamhi ingmemhi ishe tsẹ ni ẹgbọ ya suọ abi mhi rẹwẹ ngme, rọ sẹsẹ wẹ, ocho ni mhi rọ ri ẹmuẹ ọda ya ngme ingmemhi agbẹlẹ ni ọgbọkhọghuo ọa ya suọ abi mhi rẹwẹ ngme.
\p 
\v 20 Inyọghuo-mhẹ, a khi ke sa abi eniyẹ. A mhọli isamhi abi egbhali ama a li abi emọfẹ ni ẹa lẹsẹ emhikhọghuo obodẹ onobe iriẹlẹ.
\v 21 A kẹkẹ ọli shi Ebe-no-pfuasẹ khi,
\q1 “Ẹmuẹ ọda mhi rọ ya
\q2 nu ẹgbọ eyẹmhẹ ngme.
\q1 Mhi ya ri uruli epfẹse ngme,
\q2 ama ini o tseku khi ighọ,
\q1 ẹgbọ eyẹmhẹ ẹa ya
\q2 ri esọ shi mhẹ ekẹ,
\q2 ighọ Ọnọmhuẹ ọ ngme.”\f + \fr 14:21 \ft Li zẹ \fq Aza 28.11-12\f*
\m 
\v 22 Itobọ ighọ, ẹmuẹ ọda, ọa khi emhi ọnyaloa shi eni e miesuọ ọ sẹẹ ni eni ẹa miesuọ. Ama imekẹguele, eni miesuọ o mema gọ lu, ọa khi oyi eni ẹa miesuọ.
\v 23 Irarighọ, ini igbaa oyi eni e mie iJesu iKirisiti suọ kpa e legba ni ọgbọkpa ọ rọ ọ ngme ẹmuẹ ọdọda, eshẹbhẹ ali eni ẹa miesuọ, ẹa ya liẹ khi ujili ọọ kpha ẹ nya?
\v 24 Ama ini ọgbọkpa ọọ mekẹguele, ni ẹgbọ ni ẹa miesuọ okekhi ọgbọ ni ọa lẹsẹ emini a riẹlẹ ọ rọ lo le. Rọte ingmemhi ni ọọ suọ, ọ rọ ya lẹsẹ khi ọna olamhẹ lọli khi, ni ọ khi ọni ọ mu pfi.
\v 25 Osheli isamhi udu eyọli e ya khueghie-a gboo. Ọ de yẹshi, ọọ ga Ẹshinẹgba, ọọ liẹ, “Ẹshinẹgba ọ la ẹ iteva egbegbọ.”
\s1 Ugamhi ni ọa mhuẹ ozughu
\p 
\v 26 Inyọghuo, abi mhi ri ona ngme khi, ini a lona kugbe shi ugamhi, ni ọghuo ọ rọ mhọli uwolo, okekhia khi ọghuo ọ mhọli emini ọ sẹsẹ, okekhi irọkhasẹ ọlese ọ mhọli, okekhi ẹmuẹ ọda ọlese ọọ ngme, okekhi aguele emini a ri oni ẹmuẹ olese ngme mhọli. A riẹlẹ enana nya rọ kpaghiẹ igbaa oyi eni e mie iJesu iKirisiti suọ obo.
\v 27 Ini ọgbọ ọ ya ngme ẹmuẹ ọda, ẹgbọ aava tsẹ e lẹsẹ ngme, ini ẹ khi e bu dọsẹ, e khi aasẹ. Ama ọtuọghuo ọghuo ọ kpẹ ke ngme, ọgbọẹse ọọ guele abi ọọ ngme.
\v 28 Ini o khia khi ọgbọ ọa la oni igba oyi eni e miesuọ ni ọ ya ke mie ọli emini ọọ ngme guele, ọni ọọ ngme ungmemhi ẹmuẹ ọda ọghọ ọ khukhu unu, ọ lẹsẹ nu egbọli ali Ẹshinẹgba ke ngme.
\p 
\v 29 Emekẹguele aava okekhi aasẹ e dobẹ ya ke ngme, ẹgbọ enekpọle e ku esọ-a ni e lẹsẹ abi ẹẹ ngme.
\v 30 O kha ke khia khi a ri irọkhasẹ khasẹ ọgbọẹse ni ọ shitọ oni ilegba, ọni ọ kpẹ ngme eghọ, o mu migha.
\v 31 Ẹẹ nya a dobẹ ya mẹguele, ama o khi ọtuọghuo ọghuo, ni enekpọle e wẹna ali ni a ri udu shi wẹ ọ.
\v 32 Eni e mhuẹ ayẹmhẹ imẹguele e ke ri ẹghẹghẹ na egbe rọ ngme ini ayẹmhẹ imẹguele o la wẹ egbe ẹ gbe akanya.
\v 33 Irari khi Ẹshinẹgba ọa khi ọna ozughu, ama ọyi opfọmhẹ. Abi o li shi elemhi igba oyi eni miesuọ nya.
\p 
\v 34 Ikpotso e ke khukhu unu ini igbaa oyi eni e mie iJesu iKirisiti suọ e legba, abi o li shi igbaa oyi eni e mie iJesu iKirisiti suọ elese nya. A khi zẹ wẹ ngme, e ri ochoghọ ke deba omhẹsẹ, abi ushi o ngme.\f + \fr 14:34 \ft Li zẹ \fq Igbae 3.16\f*
\v 35 Ini ẹ nono ni wẹwẹ e lẹsẹ udi-ingme okhọghuo, e la apfẹ mhila edọwẹ. Emhi omama o khi ni ọkpotso ọ rọ la ilegba igbaa oyi eni e mie iJesu iKirisiti suọ ngme.
\p 
\v 36 Abi khi obọ oyẹ ẹ ungmemhi oyi Ẹshinẹgba o te gba ekẹle, abi khi ẹẹ ghuo o lẹsẹ ramhi egbe?
\v 37 Ini ọgbọkhọghuo o sa khi ọmekẹguele lọli khi, okekhia khi eri ọ liẹ khi lọli mhọli ayẹmhẹ ni ọ pfuasẹ, ọ mema ya lẹsẹ khi emini mhi kẹkẹ ẹ ghi ẹ ena khi ushi oyi Ọnọmhuẹ lọ.
\v 38 Ama ini ọgbọkhọghuo ọ ri ẹloe gbe ungmemhi ona, a li ri ẹloe gbe ọli.
\p 
\v 39 Irarighọ, inyọghuo-mhẹ, a ke nono ni a mẹguele, ama ẹmuẹ ọda ingmengme, o khi khi ighuighuẹ.
\v 40 A ke riẹlẹ emhikpa te ode ni ọa mhuẹ ozughu.
\c 15
\s1 Irọte eghuli guale oyi iKirisiti
\p 
\v 1 Mena mhia nono ni mhi yele ẹ le inyọghuo, ingme usomhi onete ni mhi rọ tse abọ yẹ ẹ ni a miesuọ, ni irudunga oyẹ ẹ o migha nga egbegbọ.
\v 2 Oni usomhi onete ona a rọ tsumhi ẹ, ini a da mu emini mhi rọ tse abọ yẹ ẹ mhuẹ toto. Ini ọa khi ighọ, eri a miesuọ shi afuẹ.
\p 
\v 3 Abi mhi li te ekẹ mie oni usomhi ni o lolo mu ẹloe, ighọ mhi li gue ọli ye ẹ. Usomhi khi,
\q1 iKirisiti ọ ghu-a
\q2 to olamhẹ eyawa
\q1 abi a li kẹkẹ ọli
\q2 shi Ebe-no-pfuasẹ.\f + \fr 15:3 \ft Li zẹ \fq Aza 53.5-12\f*
\v 4 Khi a rọli tọ,
\q1 a rọte eghuli guise ọli le
\q1 ẹlẹ nuzi-esẹ,
\q2 abi Ebe-no-pfuasẹ o ngme.\f + \fr 15:4 \ft Li zẹ \fq Iwolo 16.8-10; iMat 12.40; Ika 2.24-32\f*
\q1 
\v 5 Ọ ri egbọli khasẹ iPita,
\q2 ọ tigbe ri egbọli khasẹ eni ogbava.\f + \fr 15:5 \ft Li zẹ \fq iMat 28.16-17; iMak 16.14; iLuk 24.34,36; iJọn 20.19\f*
\q1 
\v 6 Ọ tigbe ri egbọli khasẹ,
\q2 ẹgbọ ni e miesuọ ni e bu dọsẹ
\q2 ẹgbọ egbhuẹ uye ali ishe (500),
\q1 ni e la asheghuo utoghuo,
\q1 ni o khia khi ebubu wẹ
\q2 e kie la agbọ,
\q2 eghuo ọ e she ghua.
\q1 
\v 7 Ọ tigbe ri egbọli khasẹ iJemhisi,
\q2 neni ọ tigbe gbo
\q2 ri egbọli khasẹ ighiusomhi na kẹẹ nya.
\p 
\v 8 Ikpukhokho ọ, ọ li ri egbọli khasẹ mhẹ abi ọmọ ni a bia shi ẹghẹghẹ ni aa kha bia li shi.\f + \fr 15:8 \ft Li zẹ \fq Ika 9.3-6\f*
\v 9 Irari khi mhẹmhẹ mhi ga kpọkẹ na ighiusomhi na kẹẹ enekpọle nya a. Mhi aa fẹ fu tẹ ni a lu aghiusomhi na kẹẹ, itobọ khi mhi mu okhọli vule shi igbaa oyi eni e mie iJesu iKirisiti suọ oyi Ẹshinẹgba ọ.\f + \fr 15:9 \ft Li zẹ \fq Ika 8.3\f*
\v 10 Ama okhale ni mhia futẹ ni Ẹshinẹgba ọ li na mhẹ o rẹmhẹ khi emini mhi khi. Ali khi okhale ni ọ li na mhẹ ọa li opfu-a. Ini a ke gbo riẹlẹ ọli bino, mhi she ga rọshẹka gbe akanya dọsẹ wẹ nya. Ama ọa khi mhẹmhẹ mhi dobẹ gbe ọli, ama okhale oyi Ẹshinẹgba ni o la mhẹ egbe a gbe akanya lọ.
\v 11 Itobọ ighọ, ini o khia khi wẹwẹ e tsabọ oni usomhi, okekhi obọ oyẹmhẹ o te bhale o, ungmemhi oghuo anye kie ga rọ ọ tse abọ, ni o khi emini a mie shi.
\s1 Irọte eghuli guale oyi eni eghua
\p 
\v 12 Usomhi oyanye na. A she rọte eghuli guise iKirisiti le. Elọ o ke zẹ khi eghuo ẹ e rọ liẹ khi iteghuli guale oyi eni e ghu-a ọa la ọ shọ?
\v 13 Ini irọte eghuli guise eni e ghu-a le ọa la ọ, oghọ khi aa guise iKirisiti le.
\v 14 Ini o khia khi aa rọte eghuli guise iKirisiti le lọ, itsabọ oyawa, afuẹ o kha khi, ighọ li khi irudunga oyawa.
\v 15 Ọa khi ighọ tsẹ, eni e pfi ọtsẹlẹ kie ẹgbhọli ma Ẹshinẹgba anye kha khi. Irari khi anye she kpẹ pfi ọtsẹlẹ guele na Ẹshinẹgba khi ọ rọte eghuli guise iKirisiti le. Ini o khia khi igẹsikia o kha khi lọ khi aa ya guise eni e ghu-a le lọ, eri o kha rọkhasẹ khi ọa guise iKirisiti le.
\v 16 Irari khi ini aa ya guise eni e ghu-a le, aa li guise iKirisiti le o li khi eghọ.
\v 17 Ini o khia khi aa guise iKirisiti le, irudunga oyẹẹ ọa kha mhuẹ emini o kha li na ẹ. Ẹẹ a kha kiẹ la okhẹna ipfẹzọmu shi olamhẹ eyẹẹ.
\v 18 Oghọ li khia khi, eni e ghuloa ni e mie iKirisiti suọ khi eri e li li opfu-a.
\v 19 Ini o khia khi agbọ ana tsẹ, irudushi ni awa mhuẹ na iKirisiti o pfo shi lọ, awa a opfu o kha bie gbẹ nẹ nya.
\p 
\v 20 Egbegbi ingme ni o la ọ khi, a she rọte eghuli guise iKirisiti le, ni o ri awa mie shi ọ khi a ya gbo guise eni e ghu-a le.
\v 21 Irari khi abi eghuli o rọte obọ oyi ọgbọ ọtuọghuo bhale ikhi Adamu, ighọ irọte eghuli guise le o li rọte obọ oyi ọgbọ ọtuọghuo bhale ikhi iKirisiti.
\v 22 Irari khi abi ẹgbọkpa e li rọte obọ oyi Adamu ghu-a, ighọ a li ya rọte eghuli guise ọgbọkpa le, rọte obọ oyi iKirisiti.
\v 23 Ama a ya guise ọgbọgbọ le abi o li tẹ ọli, iKirisiti ọ khi ọni ododẹ, ọ kha nyenẹ egbe bhale, a tigbe li guise eni e mie oli suọ le.
\v 24 Isheghọ ọzukhomhi agbọ o bhale, ini iKirisiti ọ mu ekpabọ ayẹmhẹ nya ọ le, ali eni e mhuẹ afu ali itoto nya, ọ tigbe rue oni omhẹsẹ nya na Ẹshinẹgba ita.
\v 25 Irari khi iKirisiti ọ ya ke mhẹsẹ ramhi ni Ẹshinẹgba ọ rọ ya ri ebe ọli nya kpọkẹ ẹkoawẹ eyọli.\f + \fr 15:25 \ft Li zẹ \fq Iwolo 110.1\f*
\v 26 Ọbe ni ọ ya kpukhokho mu ọ le khi, eghuli.
\v 27 Irari khi Ebe-no-pfuasẹ o ngme ọli khi “Ẹshinẹgba ọ ri emhikpa kpọkẹ ẹkoawẹ eyọli.” Onana o rọli khasẹ gbo khi aa li ri Ẹshinẹgba ma ọ rọ kpọkẹ na iKirisiti, ikhi lọli ni ọ ri emhikpa kpọkẹ ẹkoawẹ eyi iKirisiti.\f + \fr 15:27 \ft Li zẹ \fq Iwolo 8.6\f*
\v 28 Itobọ khi ini a da ri emhikpa shi omhẹsẹ oyi iKirisiti se, ẹghẹghẹ aghọ lọli ọyọli ni ọ khi omiọli, o ri egbọli kpọkẹ na Ẹshinẹgba, ọni ọ ri emhikpa kpọkẹ na li. Ẹshinẹgba ọ mhẹsẹ ẹ shi emhi nya.
\p 
\v 29 Elọ zẹ ni ẹgbọ e rọ ọ batazi na ẹgbọ ni e she ghu-a? Ini aa ya guise eni e ghua le, elọ o zẹ ni a rọọ batazi shi na wẹ?
\v 30 Elọ o zẹ ni anye rọ ri agbọ oyanye ẹ shi okhẹna ẹghẹghẹ kpa?
\v 31 Anye ẹ la okhẹna eghuli ogbẹlẹkpa! Ititiegbe ni mhi ri itobọ oyẹ ẹ titi, irari emini iJesu iKirisiti ọyawa ọ riẹlẹ na ẹ, o rẹmhẹ ngme ona.
\v 32 Elọ a dabi khi o khi eleli oyẹmhẹ ni mhi rọ nu inyagbemhi ebe, ikhi emọse eghọ na ẹoli Efesọsi khọli? Ini aa ya guise eni e ghua le bhale agbọ,
\q1 Awa bie ke le awa a da,
\q2 irari khi awa ya ghu-a akọ.\f + \fr 15:32 \ft Li zẹ \fq Aza 22.13\f*
\p 
\v 33 Khi zẹ ni a sẹsẹ wasẹ-a. “Ikugbe ẹgbọ ebe ọ, o ma yese egbegbi angeli-a.”
\v 34 Nyenẹ egbe bhale ẹgbhali eyẹ, a tiegbe olamhẹ le. Eghuo ẹ e la ọ ni ẹa lẹsẹ Ẹshinẹgba. Ni o ri omama mu ẹ, mhi rọ ngme ona.
\s1 Idiegbe ni a rọte eghuli guise le
\p 
\v 35 Ama ọgbọ ọ dobẹ ya mhila ogbọ, “Sẹẹ a liẹ guise eni e ghu-a le bhale agbọ? Idiegbe onabi onoghuo e ke ya mhọli?”
\v 36 Yẹyẹ ọyẹghẹ! Waa lẹsẹ khi emini a rọ kọ ọa ya zẹ ini ọa li kpẹ ghua?
\v 37 Ini a ri ukpamhi ọakpa kọ, ọa ke ẹ zẹ ukpamhi ngẹ, ama ughẹghẹ ọli o ke zẹ ngale.
\v 38 Ẹshinẹgba ọ ri idiegbe ẹ na ikpamhi abi o ghọle ọli shi, ikpamhi emhi nya e mhọli idiegbe oyẹwẹ.
\v 39 Idiegbe oyi emhi nya ẹa li abeghuo. Ẹgbọ e mhọli idiegbe oghuo, elamhakọ e mhọli idiegbe olese, ipfeli ali ifẹlẹ e mhọli idiegbe eyẹwẹ.
\v 40 Emhi ọdọda e la idane, emhi ọdọda e li la ekẹkhẹ. Otse oyi emhi na idane, o khi oghuo, otse ni o la emini e la ekẹkhẹ o khi ọda.
\v 41 Ovọ o mhọli otse oyọli ọda kẹ, uki o mhọli otse olese, ikpẹtata e mhọli otse olese ọda. Eni ikpẹtata e gbo somhọtse dọsẹ egbe.
\v 42 Ighọ o ya li ini a guise eni e ghu-a le. Idiegbe ni a rọ tọ, eni ẹ kẹa e khi ni a rọ tọ. Ama eri a guise ọli le ni ọa ke ya kẹa ghue.
\v 43 Ini a rọli tọ, o yemhi osue, ọa mhuẹ itoto, ama ini a guise ọli le o somhotse-a, o mhuẹ itoto.
\v 44 Ini a rọli tọ, o khi idiegbe ni a mẹ alo gbugbugbu. Ini a guise ọli le, o khi idiegbe ayẹmhẹ.
\p Ini idiegbe ni a mẹ alo gbugbugbu o la ọ, idiegbe elemhi ayẹmhẹ o li la ọ.
\v 45 Abi a li kẹkẹ ọli khi, “Ọmọse onododẹ Adamu, eri a ma li ọgbọ ni ọ mhọli ayẹmhẹ.” Ama khi Adamu ni o kpe ukhokho, ayẹmhẹ ni ọ ri agbọ a na ọgbọ ọ khi.\f + \fr 15:45 \ft Li zẹ \fq Igbae 2.7\f*
\v 46 Ọa khi idiegbe ayẹmhẹ o kpẹ bhale, ama oni a mẹ alo gbugbugbu, neni a mẹ oyi ayẹmhẹ.
\v 47 Adamu, ọmọse ọnododẹ, itutu ena ekẹ a rọ ma li, Adamu ọnuzava iloghie o te tiemhile.
\v 48 Eni e khi eyi ekẹ, eri e li abi eni a ri itutu eyi ekẹ ma, eni e khi eyi iloghie eri e li abi eni e rọte iloghie bhale.
\v 49 Ẹzẹzẹ abi awa li ri irọkhọkhọ oyi ọmọse ni a ri ekẹ ma sọ, ighọ awa gbo li ya ri irọkhọkhọ oyi ọmọse ni ọ rọte idane bhale sọ.
\p 
\v 50 Mhi gue ona yẹ ẹ inyọghuo khi, emhi idiegbe ali emhi ọlia ẹa ya lo Eghiele oyi Ẹshinẹgba. U kẹ-liẹ khi eri idiegbe ni ọọ kẹ-a, o ke ya mhọli okemhi shi oni iloghie ni ọa ya kẹa.
\v 51 A ri esọ shi egbegbingme osheli ona. Awa nya awa aa ya ghua, ama ini akala ni o kpukhokho o de, a ya mu awa mela-a, bia,
\v 52 elemhi ikoko alo khueghie-a, ini oni akala ni o kpukhokho o de. Irari khi akala o ya de, eni e ghu-a e ya ri idiegbe ni ọa ya kẹa guale, a ya mu wẹ mela-a.\f + \fr 15:52 \ft Li zẹ \fq 1 iTẹsa 4.15-17\f*
\v 53 Irari khi idiegbe ni ọọ kẹ-a o mema ya ri idiegbe ni ọa ya kẹ sọ, oni ọọ ghu o ri idiegbe ni ọa ya ghu sọ.
\v 54 Isheghọ, ini idiegbe ni ọọ kẹ-a o ri idiegbe ni ọa ya kẹ sọ se, ni idiegbe ni ọọ ghu o rọ ri idiegbe ni ọa ya ghu sọ se, ungmemhi ni ebe o ngme o bhale ya tsẹ ni ọ li khi,
\q1 “A she to eghuli luẹ
\q2 elemhi imuọle.”\f + \fr 15:54 \ft Li zẹ \fq Aza 25.8\f*
\q1 
\v 55 “Eghuli o, ighe imuọle
\q2 ni u ke dobẹ ya mu ọ le mena?
\q1 Eghuli o! Ighe ekpabọ eyẹ mena?”\f + \fr 15:55 \ft Li zẹ \fq Osia 13.14\f*
\m 
\v 56 Olamhẹ o ri ekpabọ na utamhi oyi eghuli ẹ ta, ni o rọ kuali utse, olamhẹ o rọte ushi mhọli ekpabọ.
\v 57 Ama awa kphẹmhi na Ẹshinẹgba ni ọ ri imuọle na awa rọte obọ oyi iJesu iKirisiti Ọnọmhuẹ ọyawa.
\p 
\v 58 Irarighọ, inyọghuo a migha gbaa. A gbe akanya oyi Ọnọmhuẹ oyi ẹ ke je odalo, abi a rọ lẹsẹ khi akanya ni u da gbe na Ọnọmhuẹ khi ọa khi afuẹ.
\c 16
\s1 Ukpaghọ ni a mie ghi igbaa oyi eni e mie iJesu iKirisiti suọ na iJerusalẹmu
\p 
\v 1 Ni mhi rọ ngme nga ingme ikpaghọ ni a mie ni a rọ ya kpaghiẹ igbaa nya eyi eni e mie iJesu iKirisiti suọ ni e la ekẹ iJudia obọ, ni a kẹkẹ shi ebe ghi mhẹ. A ke li abi mhi gueyẹ igbaa oyi eni e mie iJesu iKirisiti suọ ni e la ekẹ iGalesha e li ke riẹlẹ.\f + \fr 16:1 \ft Li zẹ \fq iRom 15.25-26\f*
\v 2 Uka khi uka kpa, a ke rọte ikpaghọ ni a gbe, rue shi asheghuo abi ọgbọgbọ ọ mhuẹ, ini a khi gbo ke zẹla ikpaghọ elese ini mhi bhale.
\v 3 Ini mhi bhale, mhi ya kẹkẹ ebe na ẹgbọ ni á zẹ, mhi kẹkẹ shi ọ khi wẹwẹ a ghie, e tsua isomhopfa eyẹẹ je iJerusalẹmu.
\v 4 Ini o ke khia khi o ti ni mhi li ye, anye ga kia.
\s1 Omhẹsẹ ni iPọlu ọ mhẹsẹ
\p 
\v 5 Mhi ya bhale ya mẹ ẹ ini mhi rọte iMasidonia dọsẹ se.\f + \fr 16:5 \ft Li zẹ \fq Ika 19.21\f*
\v 6 Mhi nu ẹ ya la dẹnẹ. Otsẹ, mhi ga la aghọ okasẹ nya. Ẹghẹghẹ aghọ a ke ri ukpaghọ kpaghiẹ mhẹ obọ je obiobini mhi ke ya je.
\v 7 Mhi aa nono ni mhi mẹ ẹ ẹloe memena, mhi aa nono ni mhi lẹsẹ te aghọ dọsẹ tsẹ. Mhia nono ni mhi nu ẹ shitọ tẹsẹ ukukuọ ini Ẹshinẹgba ọ lama.
\v 8 Mhi ya la Efesọsi ramhi ẹlẹ ukpe iPẹtikọsiti,\f + \fr 16:8 \ft Li zẹ \fq iLẹv 23.15-21; iDẹut 16.9-11\f*
\v 9 irari khi asha oniẹmhi o khueghie-a na mhẹ shi ana ni mhi rọ mẹ asha gbe akanya Ẹshinẹgba. Ama khi eni e mu okhuẹ vule shi mhẹ ọ e bu.\f + \fr 16:9 \ft Li zẹ \fq Ika 19.8-10\f*
\p 
\v 10 Ini iTimoti ọ bhale, a lolo mu ọli epfẹse, irari ọni ọ gbe akanya na Ẹshinẹgba nabi mhẹmhẹ ọ li khi.\f + \fr 16:10 \ft Li zẹ \fq 1 iKọri 4.17\f*
\v 11 Ọgbọkhọghuo ọ khi ri ẹloe gbe ọli, ama a kpaghiẹ ọli obo ni ọ rọ dobẹ ti okiali eyọli je odalo shi opfọmhẹ, ni ọ dobẹ bhale deba mhẹ. Mhia khẹ ọli, ali inyọghuo enekpọle.
\p 
\v 12 Ingme oyi Apolosi. Eri mhi ga lolo ye ọli ude ọ kọ ya fẹli ẹ, lọli ali inyọghuo enekpọle. Ama ọa ghọle ọli ni ọ rọ ye memena, ama ini ọ mhuẹ oni ẹghẹghẹ, ọ ya bhale.
\p 
\v 13 A ke tọ ẹloe ekẹ, a migha gbaa shi irudunga, a khi ẹgbọ ni e mhọli aye, a khi eni e toto.
\v 14 A ri inono ke gbe ikanya eyẹ nya.
\p 
\v 15 A lẹsẹ khi iSitẹfanasi ali ọmhuẹ-apfẹ oyọli nya, e kpe tododẹ khi eni e miesuọ shi obini ekẹ Akhaya. E she ri egbewẹ na ugamhi oyi ẹgbọ ni a pfa na. Mhi lema ẹ,\f + \fr 16:15 \ft Li zẹ \fq 1 iKọri 1.16\f*
\v 16 a ke nyẹsẹ ukhomhi na omhẹsẹ oyi ẹgbọ eghọghọ ali ọgbọẹse ni e nu wẹ ẹ gbe ikanya eghọghọ.
\p 
\v 17 Egbe e ma mu mhẹ shi ibhale oyi iSitẹfanasi ali iFọtunatusi ali Akhaikusi irari wẹwẹ e ke to-ẹoli ẹ abi aa rọ la akaghọ.
\v 18 Eri e ri egbe mu mhẹ e ti ayẹmhẹ oyẹmhẹ nga, abi e ri egbe mu ẹ. Ẹgbọ enana, e ti ni a tsẹ, e mu akanya.
\p 
\v 19 Igbaa nya eyi eni e mie iJesu iKirisiti suọ eni e la ekẹ Esha ẹẹ tsẹ ẹ. Akuila ali iPisilia ali igbaa oyi eni e mie iJesu iKirisiti suọ ni ẹ lona apfẹ oyẹwẹ, e li ẹ tsẹ ẹ otsẹ irudunga.\f + \fr 16:19 \ft Li zẹ \fq Ika 18.2\f*
\v 20 Inyọghuo nya ni e la ana ẹẹ tsẹ ẹ. A ke tsẹ egbe egbegbi otsẹ a ghẹlẹ mu egbe.
\v 21 Mhẹmhẹ iPọlu mhi ga ri obọ ma ebe ona.
\v 22 Ọni ọa da nono ingme oyi Ọnọmhuẹ ne, Ẹshinẹgba ọ ya pfa ẹzọ mu ọli. Mhi lema, Ọnọmhuẹ ọ kẹlẹ bhale.
\v 23 Okhale oyi iJesu Ọnọmhuẹ o ke deba ẹ.
\p 
\v 24 Inono oyẹmhẹ o ka nu ẹ la nya ni a khi eyi iJesu iKirisiti. Atsẹ.
