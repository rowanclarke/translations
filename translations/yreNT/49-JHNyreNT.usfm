\id JHN - Yaouré NT [yre] -Côte d'Ivoire 1999 (web version -2013 bd) 
\h Zan 
\toc1 Zozi Crizi -le 'wɩ 'nɔnnɔn nɛn Zan -a crɛn -tɛ 
\toc2 Zan 
\toc3 Zan 
\mt2 Zozi Crizi -le 'wɩ 'nɔnnɔn nɛn 
\mt1 Zan 
\mt2 -a crɛn -tɛ 
\c 1  
\s1 Wei nɛn e 'belidɩ -nɔan "min lɛ bɛ, Zozi Crizi nɛn 
\p  
\v 1 Fɛ pɛɛnɔn drɛdɩ pou sianan "bɛ, te min nɛn waa laabo wei bɛ e ya. Wei 'bɔ a Bali va, ɛn e ya Bali -a.  
\v 2 -A pou sianan "bɛ te e ya Bali va. 
\p  
\v 3 Bali ciɩla "va ɛn e fɛ pɛɛnɔn drɛ. Fɛ -tʋ 'ka 'e drɛdɩ, te -yɛɛ "cɛɛ drɛ dɩ.  
\v 4 -A va nɛn 'belidɩ 'si. 'Belidɩ zɩɛ, 'tɛ 'san nɛn e 'trɛdanɔn 'man dra 'wein bɛ -nyrɛn.  
\v 5 'Tɛ zɩɛ -a -san -sɛn klun va, ɛn klun 'ka -tɔlɛ -a 'lɛ dɩ. 
\p  
\v 6 Bali min -tʋ 'pa 'sia, -a 'tɔ nɛn Zan.  
\v 7 E -ta 'nan -e 'e 'tɛ 'san -le 'wɩ vɩ minnun lɛ, 'dʋ -e minnun 'o man, -e 'o yi -tɛra "da.  
\v 8 Zan 'bɔ "cɛɛ 'tɛ 'san zɩɛ -a -nɔan "dɩ, 'pian e -ta 'nan -e 'e 'tɛ 'san -le 'wɩ vɩ minnun lɛ. 
\p  
\v 9 Min nɛn waa laabo wei bɛ, -yɛɛ cɩ 'tɛ 'san tɩglɩ 'a, ɛn -yɛɛ 'ta 'trɛdanɔn pɛɛnɔn 'man drɛlɛ 'wein.  
\v 10 Bali ciɩla "va ɛn e fɛ pɛɛnɔn drɛ. 'Pian zɩ e -ta 'trɛda bɛ, minnun 'ka -a 'silɛa min -a dɩ.  
\v 11 E -ta 'yee 'trɛda, ɛn -yee minnun 'ka -a 'kunlɛ 'o 'pɛ "fli "a dɩ.  
\v 12 'Pian min -mienun -a 'kun 'o 'pɛ "fli "a, ɛn o yi -tɛra "da. Minnun zɩɛ yaa -si -nɔn -wlɛ -e 'o drɛ Bali -le 'nɛnnun -a.  
\v 13 Wa'a drɛlɛ Bali -le 'nɛnnun -a "le zɩ min 'nɛn -yaa 'e 'pɔn -ji bɛ -yee 'wɩ 'zʋ dɩ. Ɛn min "cɛɛ o drɛ Bali -le 'nɛnnun -a dɩ. 'Pian Bali 'bɔ 'bɛ o drɛ 'yee 'nɛnnun -a. 
\p  
\v 14 Wei zɩɛ, e drɛ blamin -a, ɛn e -ta -nyɛnlɛa 'kʋ 'va. Kʋ -yee -dan ci 'yɩ, -dan zɩɛ e ya -kaa "tɩ Bali -le 'nɛn 'tʋwli "le vɛ -a. E ya 'e fadɩ "yi "a, ɛn zɩ Bali cɩ bɛ, yaa kɔɔn 'kʋɛ 'e tɩglɩ da. 
\p  
\v 15 Yi -tʋ da nɛn Zan -yee 'wɩ vɩdɩ 'sia minnun lɛ. 'E wei wluan 'plɛblɛ, ɛn yaa 'vɩ 'nan: «Min nɛn an -yee 'wɩ 'vɩ 'e 'cɛn bɛ -nyrɛn "bɛ. Maan 'vɩ 'nan, e -fɔla "da 'an -sru e -taa. -A -dan "mlian 'an da, kɔɔ e ya 'li 'e 'cɛn.» 
\p  
\v 16 "Yi "nɛn -yrɔ "bɛ e -cee "nɔn. Yi -tʋdʋ pɛɛnɔn man te e "yi zɩɛ -a -sɛan "da -cɛɛ.  
\v 17 Bali ciɩla Moizi -va, ɛn e -pei -tɔ -cɛɛ. 'Pian Zozi 'bɛ 'ta Bali -le "yi "a, ɛn zɩ Bali cɩ bɛ -yɛɛ kɔɔn -cɛɛ 'e tɩglɩ da.  
\v 18 Min -tʋ 'ka tian Bali yɩlɛ dɩ. 'Pian Bali -le 'nɛn -tʋwli "nɛn e ya Bali -a, ɛn e ya 'e 'cɛn -kaa "tɩ Bali "srɔn "bɛ, zɩ Bali 'bɔ cɩ bɛ -yɛɛ kɔɔn -cɛɛ. 
\s1 Zan 'yee 'nyranman -ci 'vɩ minnun lɛ 
\r (Mt 3.1-12; Mk 1.1-8; Lk 3.1-18) 
\p  
\v 19 Yi -tʋ da, Zuif 'nɔn 'tanɔn nɛn Zeruzalɛm bɛ, o Bali -pannɔn 'lee Levi kludanɔn -mienun 'pa 'sia Zan -va. Levi kludanɔn 'bɔ bɛ, -wɛɛ nyranman "paa Bali -pan 'kuin. O o 'pa 'sia 'nan 'o laabʋ Zan -lɔ 'nan: «-Tɩ nɛn 'yia?» 'Wɩ nɛn Zan -a 'vɩ minnun zɩɛ -wlɛ "bɛ -nyrɛn 'gʋ.  
\v 20 Ya'a 'wɩ 'tʋ yɔɔlɛ o man dɩ, yaa 'vɩ -wlɛ -gbaa 'nan: «An 'ka Crizi nɛn Bali -a 'si "va -e 'e minnun 'si 'wɩ 'ji bɛ -a dɩ.» 
\p  
\v 21 Tɔɔn ɛn waa laabʋ -yrɔ 'nan: «'Lɔɔ -tɩ nɛn 'yia "mɛn, Bali 'lewei vɩzan -dan nɛn waa laabo Eli bɛ, -nyrɛn 'yia?» 
\p Ɛn Zan "e 'nan: «Eli "cɛɛ 'maan dɩ.» 
\p Ɛn waa laabʋ -yrɔ "nyian 'nan: «Bali 'lewei vɩzan nɛn o -yee 'wɩ 'vɩ bɛ, -nyrɛn 'yia?» 
\p Ɛn e 'nan: «-Cɛjɛ.» 
\p  
\v 22 Ɛn waa laabʋ -yrɔ 'nan: «'Lɔɔ, -tɩ nɛn 'yia -kpɔ? 'I vɩ 'kʋɛ, 'dʋ -e 'kʋ -kɔla 'kʋ 'wɩ 'tʋ yɩ, -e 'kʋ vɩ minnun nɛn o 'kʋ 'pa 'sia bɛ -wlɛ. -Mɛ "wɩ nɛn i -kɔlaman -e 'i vɩ 'i 'fli man?» 
\p  
\v 23 Tɔɔn ɛn Zan "e 'nan -wlɛ 'nan: «Mɛɛn cɩ min nɛn Bali 'lewei vɩzan Ezai -a 'vɩ 'li bɛ -a. Yaa 'vɩ 'nan: 
\q1 ‹Min -tʋ wei 'bɛ "we "bui "da, -a san -a ve 'nan: 
\q1 'Ka Minsan -le -si ta drɛ!› » 
\p  
\v 24 Minnun nɛn o o 'pa 'sia Zan -va bɛ Farizɛn 'nɔn a o va.  
\v 25 Ɛn waa laabʋ -yrɔ nan: «Crizi "cɛɛ 'yia dɩ, ɛn Eli "cɛɛ yia dɩ, ɛn Bali 'lewei vɩzan nɛn o -yee 'wɩ 'vɩ bɛ -njɛɛ 'yia dɩ. -Mɛ "le "wɛan nɛn i min -batize dra "mɛn?» 
\p  
\v 26 Zan "e 'nan -wlɛ 'nan: «'An 'bɔ, "an "min -batize dra 'yi 'a, 'pian 'ka yei "bɛ, min -tʋ a -nan, ka'a tɔa dɩ.  
\v 27 E -fɔla "da. An 'ka -yee -manwua "tun "da baa "fluzan -a dɩ.» 
\p  
\v 28 'Wɩ pɛɛnɔn zɩɛ e drɛ 'fla nɛn waa laabo Betani bɛ -a da. 'Fla zɩɛ e ya 'yi nɛn waa laabo Zudan bɛ -a -sru, fɛ zɩɛ -a -nan nɛn Zan minnun -batize drɛ. 
\p  
\v 29 -A ta tʋ cɛɛn, zɩ Zan -a 'yɩ 'nan Zozi a -tanan 'e 'va zia bɛ, ɛn e 'nan: «"Ka 'yiɔ, Bali -le 'bla 'a. -A 'bɔ nɛn Bali -a -nɔn 'nan -e 'e 'trɛdanɔn 'le 'wɩ 'wlidɩ pɛɛnɔn "nɛn wɩ yɩ, -e -wee 'wɩ 'wlidɩ 'e 'fui.  
\v 30 Min nɛn, an -yee 'wɩ 'vɩ 'e 'cɛn bɛ, -nyrɛn "bɛ. Maan 'vɩ 'nan e -fɔla "da e -taa, -a -dan "mlian 'an da, kɔɔ e ya -nan 'li 'e 'cɛn.  
\v 31 Tʋ nɛn an 'wɩ zɩɛ -a ve bɛ te ma'an min 'bɔ 'tɔa dɩ, 'pian an minnun -batize drɛdɩ 'sia 'nan -e Izraɛl 'nɔn 'o min zɩɛ -a -tɔ.» 
\p  
\v 32 'Wɩ nɛn Zan -a -nan 'yɩ, ɛn yaa 'vɩ minnun lɛ bɛ, -nyrɛn 'gʋ: «An Bali lei 'saun 'yɩ 'sinan laji, e sɔɔn "da "le -plablo -zʋ, ɛn e -fʋ "va.  
\v 33 Tʋ nɛn an 'wɩ zɩɛ -a ve bɛ te ma'an min 'bɔ 'tɔa dɩ, 'pian Bali nɛn e 'nan 'an 'ta min -batize drɛ 'yi 'a bɛ, -yɛɛ 'vɩ 'mɛn 'nan: ‹Min nɛn 'i Bali lei ye -e 'e -sɔɔn "da -e 'e 'fʋ "va "bɛ, -yɛɛ Bali lei 'saun -nɔan "min lɛ.›  
\v 34 Maan -nan 'yɩ, ɛn maan 'vɩ 'wein 'nan, min 'labɛ Bali -pɩ nɛn.» 
\s1 Zozi -srunɔn tɛdɛ 
\p  
\v 35 -A ta tʋ cɛɛn, te Zan 'lee 'e -srunɔn "fli 'bɛ cɩ fɛ zɩɛ -a -nan,  
\v 36 ɛn zɩ e Zozi 'yɩ te e ya ciɩnan bɛ, ɛn e 'nan: «"Ka 'yiɔ Bali -le 'bla bɛ, -nyrɛn "bɛ.» 
\p  
\v 37 -A -srunɔn "fli "bɛ, o 'wɩ zɩɛ -a 'man, tɔɔn ɛn o sɔɔnla Zozi -sru.  
\v 38 Zozi 'e 'man lila, zɩ yaa 'yɩ 'nan Zan -srunɔn bɛ o sɔɔnla 'e -sru "bɛ, ɛn yaa laabʋ -wlɔ 'nan: «-Mɛ "nɛn kaa -wɛɛman?» 
\p O 'nan -yrɛ 'nan: «Rabi, 'yie "kɔnnɛn "a nyin zia?» Rabi -ci nɛn 'nan Bali -le 'wɩ "paazan. 
\p  
\v 39 Ɛn Zozi "e -wlɛ 'nan: «'Ka 'ta -e 'ka -nan yɩ!» 
\p O sɔɔnla -a -sru, ɛn waa -nyrannan 'yɩ. Yi zɩɛ -a da bɛ, o -fʋ -a "srɔn. 'Wɩ pɛɛnɔn zɩɛ e drɛ te yidɛ "ta -pliman "tra. 
\p  
\v 40 Min "fli "nɛn o Zan wei 'man ɛn o sɔɔnla Zozi -sru "bɛ, Simɔn Piɛri "bʋɩ Andre nɛn -a -tʋ -a.  
\v 41 Andre zɩɛ, min tɛdɛ nɛn e -kʋ "va "bɛ, -a 'bɔ "bʋɩ Simɔn nɛn. Ɛn e -yrɛ 'nan: «Kʋ min nɛn e cɩ Crizi -a bɛ -a 'yɩ.» Crizi -ci nɛn 'nan min nɛn Bali -a 'si "va.  
\v 42 Ɛn e -kʋ Simɔn -a Zozi lɛ. 
\p Zozi -a -nanjɛɛn tɛin ɛn e 'nan -yrɛ 'nan: «Zan -pɩ Simɔn nɛn 'yia, o -taa 'i laabʋlɛ Keva.» Keva 'bɔ nɛn waa ve "nyian Piɛri. 
\s1 Zozi Filipʋ 'lee Natanaɛl laabʋ 'nan 'o -sɔɔnla 'e -sru 
\p  
\v 43 'Bɛ 'ta tʋ cɛɛn, ɛn Zozi a "vale 'e 'ko Galile 'lɛglɔn 'ji, -a -nan nɛn e 'bɔ Filipʋ man ɛn e 'nan -yrɛ 'nan: «'I -sɔɔnla 'an -sru.» 
\p  
\v 44 Filipʋ zɩɛ, Bɛzaida nɛn Andre 'lee Piɛri fla -a bɛ, -a -nan min nɛn.  
\v 45 Filipʋ 'bɔ min -tʋ nɛn waa laabo Natanaɛl bɛ -a man, ɛn e 'nan -yrɛ 'nan: «Min nɛn -yee 'wɩ cɩ 'e 'crɛn -tɛdɩ Moizi -le -pei 'fluba 'lee Bali 'lewei vɩnɔn 'le 'fluba 'ji bɛ, kʋa 'yɩ. Nazarɛtɩ min Zozi nɛn Zozɛfʋ -pɩ -a bɛ, -nyrɛn.» 
\p  
\v 46 Ɛn Natanaɛl -a laabʋ -yrɔ 'nan: «Fɛ 'kpa -kɔlaman -e 'e bɔla 'fla nɛn waa laabo Nazarɛtɩ bɛ -a da?» 
\p -A -nan nɛn Filipʋ "e -yrɛ 'nan: «'I 'ta -e 'i yɩ 'i 'bɔ 'a.» 
\p  
\v 47 Zɩ Zozi Natanaɛl 'yɩ 'tanan 'e 'va bɛ, ɛn yaa 'vɩ 'nan: «Cɛɛ Izraɛl min tɩglɩ nɛn 'e 'wɩ tɩglɩ ve bɛ, -nyrɛn "bɛ.» 
\p  
\v 48 Ɛn Natanaɛl -a laabʋ -yrɔ 'nan: «Nyin zia nɛn yian -tɔa?» 
\p Zozi "e -yrɛ 'nan: «Te i ya 'i -nyrandɩ Fijie yiba 'wlu -e Filipʋ 'e 'i laabʋ bɛ, te mɛin 'yɩ 'va.» 
\p  
\v 49 -A -nan nɛn Natanaɛl "e 'nan -yrɛ 'nan: «Bali -le 'wɩ "paazan, Bali -pɩ nɛn 'yia, yiɛ cɩ Izraɛl 'nɔn 'le mingɔnnɛn -a.» 
\p  
\v 50 Zozi -a laabʋ -yrɔ 'nan: «Maan 'vɩ 'yiɛ 'nan mɛin 'yɩ Fijie yiba 'wlu 'le "wɛan nɛn i yi -tɛra 'an da? I -taa 'wɩ -dandan -nan yɩlɛ e -ciala 'wɩ 'labɛ 'bɛ da.» 
\p  
\v 51 Ɛn Zozi -a 'vɩ "nyian 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, ka -taa labli yɩlɛ 'e 'lɛ 'sʋdɩ -e 'ka Bali -le 'pasianɔn yɩ, te o -ko laji, ɛn te o "sia laji -e 'o -sɔɔn 'an Blamin -pɩ da.» 
\c 2  
\s1 Zozi -yee 'plɛblɛ 'ci kɔɔn minnun lɛ 'e tɛdɛ 
\p  
\v 1 Yi yaaga "bɛ -sru, ɛn lɩ 'pa "fɛdi drɛdɩ 'bɔ 'fla nɛn waa laabo Kanan bɛ -a da, Galile 'lɛglɔn 'ji. Zozi "bʋ "a "fɛdi zɩɛ -a da,  
\v 2 ɛn o Zozi 'lee 'e -srunɔn laabʋ "nyian "fɛdi 'bɔ da. 
\p  
\v 3 Zɩ -wɛn -nyan bɛ, ɛn Zozi "bʋ "e 'nan Zozi lɛ 'nan: «-Wɛn -nyan -wlɔ.» 
\p  
\v 4 Zozi "e 'nan -yrɛ 'nan: «Manmi, -mɛ "le "wɛan nɛn i -tɔa 'wɩ zɩɛ 'bɛ 'ji, 'mɛn tʋ 'ka tian bɔlɛ dɩ.» 
\p  
\v 5 -A -nan nɛn Zozi "bʋ "e 'nan minnun nɛn o cɩ fɛnun -plinan bɛ -wlɛ 'nan: «'Wɩ pɛɛnɔn nɛn yaa 've 'cɛɛ bɛ, 'ka drɛla "da.» 
\p  
\v 6 'Yi 'tɔbɔ nɛn 'e drɛdɩ -kɔlɛ -a bɛ, -a 'shɛɛdʋ a fɛ 'bɔ zɩɛ -a -nan. 'Yi 'tɔbɔ zɩɛ -a -ji nɛn Zuif 'nɔn 'o 'cɛin 'lee 'o 'pɛ -man "foe yi "sia -e 'o 'fli drɛ 'saun Bali 'lɛ. -A -tʋ -kɔlaman e 'yi "siala "tugu -yaa tʋ. 
\p  
\v 7 Ɛn Zozi "e 'nan minnun nɛn o cɩ fɛnun -plinan bɛ -wlɛ 'nan: «'Ka 'pɔnun 'labɛ o fa 'yi 'a!» O -pɔnun zɩɛ -a 'fa, e -sran "man. 
\p  
\v 8 -A -nan nɛn Zozi "e 'nan -wlɛ 'nan: «'Ka 'yi 'gʋɛ -a 'kolu "tiɛnnɔn -e 'ka 'kʋ -a min nɛn 'e yiɛ -tɔa "fɛdi 'gʋɛ -a da bɛ -yrɛ!» 
\p Ɛn waa kolu o -kʋ -a -yrɛ.  
\v 9 Min nɛn 'e yiɛ -tɔa "fɛdi 'bɔ da bɛ, e 'yi zɩɛ -a -nanjɛɛn 'e 'le te e lila 'wɛn -a. Fɛnan nɛn -wɛn zɩɛ e 'si bɛ ya'a tɔa dɩ. 'Pian fɛ -plinɔn nɛn o 'yi 'bɔ 'tɔ bɛ, "o -tɔa. E lɩ 'pazan laabʋ ɛn e 'nan -yrɛ 'nan:  
\v 10 «Minnun pɛɛnɔn 'gʋɛ, -wɛn nɛn e cɩ 'kpa bɛ, -a 'bɔ nɛn waa -nɔan "min lɛ 'e 'flin. "Bɛ -sru te -wɛn ciɩ min yiɛ da bɛ, -e -wɛn nɛn e 'ka 'kpa dɩɛ, 'wɛɛ 'nɔn min lɛ. 'Yie vɛ bɛ, -wɛn nɛn e cɩ 'kpa bɛ, yia ta -tɔ -trilii tʋ 'gʋɛ -a.» 
\p  
\v 11 'Lɛbo "fɔ wɩ tɛdɛ nɛn Zozi -a drɛ bɛ, -nyrɛn zɩɛ. Yaa drɛ Kanan, Galile 'lɛglɔn 'ji. E 'yee -dan ci kɔɔn ɛn -a -srunɔn yi -tɛra Zozi 'bɔ da. 
\p  
\v 12 "Bɛ -sru, ɛn e sɔɔn "ji 'fla nɛn waa laabo Kapanamo bɛ -a da, 'o 'vale 'e "bʋ 'lee 'e "bʋɩnun 'lee 'e -srunɔn 'a. O -fʋ 'fla zɩɛ -a da tʋ "wɛnnɛn 'a. 
\s1 Zozi fɛnun -tannɔn 'pin Bali -pan 'kuin 
\r (Mt 21.12-13; Mk 11.15-17; Lk 19.45-46) 
\p  
\v 13 Zuif 'nɔn 'le 'si nɔanba -ji "fɛdi drɛdɩ 'bɔ 'kogo, ɛn Zozi 'kʋ Zeruzalɛm.  
\v 14 Zɩ e 'bɔla 'nan nun bɛ, ɛn e wla Bali -pan 'kuin. E minnun 'yɩ te o ya trinun 'lee 'blanun 'lee -plablonun -tannan. Ɛn e minnun 'yɩ "nyian te o ya "lala ta -fɔɔnan.  
\v 15 Zɩ e 'wɩ zɩɛ -a -nan 'yɩ bɛ, e baa drɛ sɔnba "a, ɛn e 'blanun 'lee trinun 'lee minnun pɛɛnɔn 'pin Bali -pan 'kuin. E "lala ta -fɔɔnɔn 'le "lala fuila "man e -wee 'tablonun -sran ji.  
\v 16 Ɛn e 'nan -plablo -tannɔn lɛ 'nan: «'Ka fɛnun 'gʋɛ -a bɔla fɛ 'gʋɛ -a -nan. Te 'ka 'an "tɩ "le 'kɔn drɛ 'flɛ 'tan 'kɔn 'a dɩ!» 
\p  
\v 17 Ɛn -a -cin -tɔra -a -srunɔn 'ji 'nan 'e ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan: 
\q1 «'Yie 'kɔn yɩdɩ "yi "a 'an 'ji -dan e -ciala "da.» 
\p  
\v 18 Zɩ Zozi 'wɩ zɩɛ -a drɛ bɛ, ɛn Zuif 'nɔn 'tanɔn -a laabʋ -yrɔ 'nan: «'Lɛbo "fɔ 'wɩ "kɔ "nɛn yia dra -e 'e -kɔɔn 'nan Bali 'bɛ 'si -nɔn 'yiɛ 'nan 'i 'wɩ zɩɛ -a drɛ?» 
\p  
\v 19 Ɛn Zozi -a -sru "fɔ -wlɛ 'nan: «Bali -pan 'kɔn 'gʋɛ, 'ka -wi! E ya yi yaaga -e 'an wluan lou 'e "pa 'ji.» 
\p  
\v 20 Ɛn o 'nan -yrɛ 'nan: «Bali -pan 'kɔn 'labɛ, lɛ -fuba sinjɛn 'wlɛ 'shɛɛdʋ wlu nɛn minnun -a -tɔ, ɛn yie 'nan, yi yaaga 'wlu -e 'i pee -tɔ?» 
\p  
\v 21 'Pian -te Zozi a 'wɩ zɩɛ -a vɩnan bɛ, -a 'bɔ po nɛn Bali -le 'kɔn 'a bɛ -nyrɛn yaa ve.  
\v 22 Zɩ 'e wluan -kanɔn 'va bɛ, -a -ci -tɔ -a -srunɔn 'ji 'nan e 'wɩ zɩɛ -a 'vɩ 'e 'cɛn. Ɛn o yi -tɛra Bali wei nɛn 'e 'crɛn -tɛdɩ bɛ -a da, 'lee 'wɩ nɛn Zozi -a 'vɩ -wlɛ "bɛ -a da. 
\p  
\v 23 Tʋ nɛn te Zozi a Zeruzalɛm Zuif 'nɔn 'le 'si nɔanba -ji "fɛdi da bɛ, zɩ minnun 'lɛbo "fɔ wɩnun nɛn yaa drɛ bɛ -a -nan 'yɩ -yrɔ "bɛ, ɛn min "kaga "yi -tɛra Zozi 'bɔ da.  
\v 24 'Pian Zozi 'ka yi -tɛlɛa o da dɩ, kɔɔ e o pɛɛnɔn -tɔa "fo.  
\v 25 Ɛn Zozi 'ka -a wɛɛman 'nan, min 'e min -tʋ man wɩ vɩ 'yrɛ dɩ. 'Wɩ nɛn min ji bɛ, Zozi -a -tɔa 'e 'bɔ 'a. 
\c 3  
\s1 Nikodɛm -kʋ 'wɩ laabʋlɛ Zozi 'lɔ 
\p  
\v 1 Zuif 'nɔn 'tazan -tʋ nɛn waa laabo Nikodɛm bɛ, e ya Farizɛn 'nɔn 'va.  
\v 2 E -ta Zozi 'va 'pei -man, ɛn e 'nan -yrɛ 'nan: «'An 'san, kʋa -tɔa 'nan i ya min nɛn Bali -a 'pa 'sia -e 'e 'wɩ "paa minnun ji bɛ -a. Kɔɔ 'lɛbo "fɔ wɩnun nɛn yia dra 'gʋɛ min nɛn Bali a 'e 'padɩ "va "bɛ, -a san 'bɛ -kɔlaman -a drɛdɩ -a.» 
\p  
\v 3 Ɛn Zozi "e 'nan -yrɛ 'nan: «Maan ve 'yiɛ 'wɩ tɩglɩ 'a 'nan, min 'ka 'kɔlaman -e 'e Bali -le mingɔnnɛn trɛ yɩ, te wa'a -yalɛ 'e 'trɛ dɩ.» 
\p  
\v 4 -A -nan nɛn yaa laabʋ Zozi 'lɔ 'nan: «Min nɛn e drɛ ceje 'gʋɛ, waa dra 'kɔ -e 'o -ya? E -wlaman "nyian 'e "bʋ 'pɔn -ji -e 'o -ya 'e 'pee?» 
\p  
\v 5 Ɛn Zozi "e -yrɛ 'nan: «Maan ve 'yiɛ "nyian 'wɩ tɩglɩ 'a 'nan, min 'ka 'kɔlaman -e 'e 'kʋ Bali -le mingɔnnɛn trɛ da, te wa'a -yalɛ 'yi 'lee Bali lei -a dɩ.  
\v 6 Fɛ nɛn min -a -ya bɛ, e ya min -a. 'Pian fɛ nɛn Bali lei -a -ya bɛ, e ya -yee vɛ -a.  
\v 7 -Te 'an 'bɔ maan 'vɩ 'yiɛ 'nan e ya "le 'wei 'ya "nyian 'e 'trɛ bɛ, te -a 'wɩ 'e 'i 'kan dɩ.  
\v 8 Waa -kɔɔnman fulɔ man. Fɛnan nɛn fulɔ cɩ "vale 'e 'ko bɛ, -a -nan nɛn e "fɛɛnman e -ko. Waa -cin maan, 'pian -a -nan nɛn e "sia bɛ wa'a tɔa dɩ, ɛn -a -nan nɛn e -ko bɛ wa'a tɔa dɩ. -A -tʋwli "nɛn "nyian min nɛn Bali lei -a -ya 'e 'trɛ bɛ -yee vɛ -a.» 
\p  
\v 9 Nikodɛm -a laabʋ -yrɔ 'nan: «'Wɩ zɩɛ e dra 'kɔ -e 'bɛ drɛ?» 
\p  
\v 10 Ɛn Zozi "e 'nan -yrɛ 'nan: «'I 'bɔ nɛn i 'wɩ "paaman Izraɛl 'nɔn 'ji bɛ, yi'a 'wɩnun zɩɛ -a tɔa dʋʋ?  
\v 11 Maan ve 'yiɛ 'wɩ tɩglɩ 'a 'nan, 'wɩ nɛn kʋa -tɔa "bɛ -nyrɛn kʋa ve, ɛn 'wɩ nɛn kʋa -nan 'yɩ bɛ, -nyrɛn kʋa ve, ɛn 'kʋe 'wɩ zɩɛ ya'a 'ko 'ka 'wulo -ji dɩ.  
\v 12 An 'trɛ 'gʋɛ -a da wɩ 'vɩ 'cɛɛ, ka'a yi -tɛlɛa 'bɛ da dɩ, 'lɔɔ -te an laji lou "wɩ 'vɩ 'cɛɛ bɛ, e dra 'kɔ -e 'ka yi -tɛra 'bɛ da?  
\v 13 Min -tʋ 'ka tian 'kʋlɛ laji dɩ, -te ya'a 'silɛa Blamin -pɩ nɛn e 'si laji bɛ -a dɩɛ.  
\v 14 "Le zɩ Moizi a "bui "da 'li ɛn e -bulalɛ drɛ -mlɛn -a ɛn yaa 'pa yiba "man ɛn yaa wluan lou "bɛ, -a -tʋwli "nɛn "nyian waan 'bɔ blamin -pɩ wuanla lou.  
\v 15 'Dʋ -e min nɛn e yi -tɛra Blamin -pɩ 'bɔ da bɛ, 'belidɩ nɛn ya'a 'nyaan dɩɛ 'e drɛ -a san -le vɛ -a. 
\p  
\v 16 -Yɛɛ cɩ 'nan Bali 'trɛdanɔn pɛɛnɔn 'yɩ "yi "bʋʋ "le "wɛan, 'e 'pɩ -tʋwli "nɔn -wee 'wɩ 'ji, 'nan -e min nɛn e yi -tɛra -a -pɩ zɩɛ -a da bɛ, -a san -nan 'e vɩlɛ 'e 'nyan dɩ, 'pian -e 'belidɩ nɛn ya'a 'nyaan dɩɛ, 'e drɛ -a san -le vɛ -a.  
\v 17 Bali 'ka 'e 'pɩ 'palɛ -sia 'trɛda 'nan -e 'e tin -tɛ min da dɩ, yaa 'pa 'sia 'nan -e 'e min 'si 'wɩ 'ji.  
\v 18 Min nɛn e yi -tɛala -a -pɩ zɩɛ -a da bɛ, wa'a -yee tin 'baa dɩ, 'pian min nɛn ya'a yi 'tɛala "da "dɩɛ -a san -le 'wɩ a 'e tin 'badɩ 'va, kɔɔ ya'a yi -tɛlɛa Bali -pɩ -tʋwli "da dɩ -le "wɛan.  
\v 19 'Wɩ nɛn -yee "wɛan, Bali 'trɛdanɔn 'le tin "baa bɛ, -nyrɛn 'gʋ, 'tɛ 'san -ta 'trɛda, ɛn minnun 'ka -a yɩlɛ "yi "dɩ, o klun 'yɩ "yi e mlin 'tɛ 'san da, o drɛnan wɩ a -wlidɩ "le "wɛan.  
\v 20 -Yɛɛ cɩ 'nan min nɛn e 'wɩ 'wlidɩ "dra bɛ, ya'a 'tɛ 'san ye "yi "dɩ. Ɛn -a san 'ka 'taa 'tɛ 'san da dɩ, "tɔgɔ -yee 'wɩ 'wlidɩ "ta 'e bɔla.  
\v 21 'Pian min nɛn e 'ta 'wʋla 'wɩ tɩglɩ da bɛ, e -taa 'tɛ 'san da, 'dʋ -e 'tɛ 'san 'e drɛ wɩ -ci -kɔɔn 'nan e 'ta 'wʋla Bali wei da.» 
\s1 Zan Zozi 'le 'wɩ 'vɩ 
\p  
\v 22 "Bɛ -sru ɛn Zozi 'lee 'e -srunɔn 'kʋ Zude 'lɛglɔn 'ji. O -fʋ fɛ zɩɛ -a -nan tʋ "wɛnnɛn 'a, ɛn e minnun -batize drɛdɩ 'sia.  
\v 23 Tʋ 'bɔ 'lein zɩɛ -a wlu bɛ, te Zan "e minnun -batize dra "nyian 'fla nɛn waa laabo Enɔn bɛ -a da, kɔɔ 'yi banun a -nan "kaga. 'Fla zɩɛ, e ya 'fla nɛn waa laabo Salim bɛ -a "srɔn. Minnun -ko -nan nun te Zan o -batize dra,  
\v 24 Tʋ zɩɛ -a man bɛ, te wa'a tian -a -fɔlɛ -pʋ 'kuin dɩ. 
\p  
\v 25 Yi -tʋ da, ɛn -sa -tʋ -fɔla Zan -srunɔn 'lee Zuif min -tʋ yei. -Sa zɩɛ e ya min drɛdɩ 'saun Bali 'lɛ da.  
\v 26 O -kʋ Zan -va, ɛn waa laabʋ -yrɔ 'nan: «Bali -le 'wɩ "paazan, min nɛn "nɛn ka cɩ 'ka 'vale -a Zudan 'yi -sru, te i -yee 'wɩ ve minnun lɛ bɛ, e ya minnun -batize drɛnan ɛn minnun pɛɛnɔn a -kʋnan "va 'zia.» 
\p  
\v 27 -A -nan Zan "e 'nan -wlɛ 'nan: «Min 'ka 'kɔlaman -e 'e fɛ -tʋ yɩ te Bali "cɛɛ -nɔn -yrɛ "dɩ.  
\v 28 Maan 'vɩ 'ka yiɛ man 'nan, min nɛn e min "sia 'wɩ 'ji bɛ, -a 'bɔ "cɛɛ 'maan dɩ, 'pian an ya min nɛn Bali -a -trɔa -a 'lɛ bɛ -a. 'Ka 'bɔ ka ya 'mɛn 'wɩ 'nan yɩnɔn 'a.  
\v 29 Lɩmɔn nɛn e -kɔnnɛn 'pa bɛ, e ya -tɩ -le vɛ -a? Min nɛn yaa 'pa bɛ, -yee vɛ nɛn. Lɩ 'pazan 'bɔ bee -le vɛ "cɛɛ dɩ, -a bee bɛ, "bɛ "ya wo min nɛn e -tɔa -a "srɔn, te -a "trɔɛn "a 'e 'tɔdɩ -a wei lɛ bɛ -a. Ɛn -a wei mandɩ -a ci "nranman. Zɩ 'an 'ci cɩ zɩɛ. 'Bɛ nɛn 'gʋɛ, 'an 'ci "nranman e -ciala "da "mɛn "fo.  
\v 30 E ya "le -a 'bɔ 'tɔ nɛn 'e drɛ -dan -e 'an 'tɔ "e "ta wʋ "tra. 
\p  
\v 31 Min nɛn e "sia laji lou "bɛ, e ya fɛ pɛɛnɔn da, 'pian min nɛn e 'si 'trɛda bɛ, e ya 'trɛda min -a, ɛn 'trɛda wɩ nɛn yaa ve. Min nɛn e "sia laji bɛ, e ya fɛ pɛɛnɔn da.  
\v 32 Ɛn 'wɩ nɛn yaa -nan 'yɩ, 'lee 'wɩ nɛn yaa 'man bɛ -nyrɛn yaa ve, 'pian min -tʋ 'ka yi -tɛlɛa 'wɩ zɩɛ -a da dɩ.  
\v 33 Min nɛn e yi -tɛra 'wɩ nɛn yaa 'vɩ bɛ -a da bɛ, te 'bɛ 'san "e 'nan 'wɩ 'kpa, Bali 'wɩ tɩglɩ ve.  
\v 34 -Yɛɛ cɩ 'nan min nɛn Bali -a 'pa 'sia bɛ, Bali 'bɔ wei nɛn yaa ve, kɔɔ Bali 'ka 'yee lei 'saun 'nɔndɩ "nɛn 'palɛa dɩ.  
\v 35 -Kaa "tɩ Bali 'e 'pɩ ye "yi, ɛn e fɛ pɛɛnɔn 'pɛba 'wʋ -yrɔ.  
\v 36 Min nɛn e yi -tɛra -a -pɩ zɩɛ -a da bɛ, 'belidɩ nɛn ya'a 'nyaan dɩɛ, e ya -a san -le vɛ -a. 'Pian min nɛn ya'a -pɩ 'silɛa min -a dɩɛ, -a san 'ka 'belidɩ ye dɩ, te 'bli a 'e 'fɔdɩ Bali -ji -a san man.» 
\c 4  
\s1 Zozi 'lee Samari lɩmɔn -tʋ 'o cin 'yɩ 
\p  
\v 1 Zozi -a -tɔ 'nan, Farizɛn 'nɔn -a 'man 'nan minnun nɛn 'e -sru te 'e o -batize dra bɛ, o ya "kaga, ɛn o "mlian Zan -srunɔn da.  
\v 2 Zozi 'bɔ "cɛɛ min -batize dra 'e 'bɔ 'a dɩ, 'pian -a -srunɔn nɛn.  
\v 3 Zɩ Zozi 'wɩ zɩɛ -a -kɔnnɛn 'yɩ bɛ, -a -nan nɛn e 'si Zude 'lɛglɔn 'ji, ɛn e Galile si 'sia.  
\v 4 -Si zɩɛ e -ciala Samari 'lɛglɔn 'ji. 
\p  
\v 5 Zozi 'bɔla Samari 'fla 'tʋ da. 'Fla zɩɛ waa laabo Sisha e ya fei nɛn Zago -a -nɔn 'li 'e 'pɩ Zozɛfʋ lɛ bɛ -a "srɔn.  
\v 6 Fɛ zɩɛ -a -nan nɛn Zago 'le 'yi -klu cɩ. Zɩ Zozi "koe "nyian 'ta wʋdɩ -a bɛ, ɛn e -nyran 'yi -klu zɩɛ -a "srɔn te yidɛ 'bɔ min -win -ji 'sɛzɛ. 
\p  
\v 7 -A -nan nɛn Samari lɩmɔn -tʋ -ta 'yi 'tɔlɛ, ɛn Zozi "e 'nan -yrɛ 'nan: «'I 'yi 'nɔn 'mɛn -e 'an mlin.»  
\v 8 Tʋ zɩɛ -a wlu, te -a -srunɔn 'kʋ -blɩfɛnun 'lɔlɛ 'fla. 
\p  
\v 9 Ɛn Samari lɩ zɩɛ e 'nan Zozi lɛ 'nan: «-Mɛ "le "wɛan nɛn 'i 'bɔ nɛn Zuif min -a bɛ, i 'yi laabo 'an 'lɔ -e 'i mlin, te Samari lɩ nɛn 'maan?» Zuif 'nɔn 'lee Samari 'nɔn bɛ te o yei 'ka -a ble "fo "dɩ. 
\p  
\v 10 Ɛn Zozi "e 'nan -yrɛ 'nan: «"Te fɛ nɛn Bali -a -nɔn minnun lɛ bɛ, 'nan yia -tɔa "bɛ, ɛn min nɛn yaa ve 'yiɛ 'nan 'i 'yi 'nɔn 'mɛn 'gʋɛ, yia -tɔa "bɛ, "te 'i 'bɔ 'bɛ 'yi laabʋ -yrɔ, -e 'i mlin, -e 'e 'yi nɛn e 'belidɩ -nɔan "min lɛ bɛ -a -nɔn 'yiɛ.» 
\p  
\v 11 Ɛn lɩ zɩɛ e 'nan Zozi lɛ 'nan: «Minsan, fɛ -tʋ 'ka 'i 'lɔ -e 'i 'yi 'tɔ 'a dɩ, ɛn -klu 'gʋɛ e ya 'e trʋdɩ. Nyin zia nɛn i 'yi nɛn e 'belidɩ -nɔan "bɛ, -a "sia?  
\v 12 'Kʋ tra Zago nɛn e 'yi -klu 'gʋɛ -a -nɔn 'kʋɛ bɛ, -a 'bɔ "e ci yi mlin 'o 'vale 'e 'pɩnun 'lee 'yee trinun -a. 'I -dan "mlian 'bɛ da?» 
\p  
\v 13 Ɛn Zozi "e -yrɛ 'nan: «Min nɛn e 'yi 'gʋɛ -a mlin bɛ, 'yi dra pee -a -tɛa.  
\v 14 'Pian min nɛn e 'yi nɛn maan -nɔan "bɛ -a mlin bɛ, 'yi dra pee 'ka "nyian 'li -a tɛa dɩ, ɛn 'yi nɛn maan -nɔan -yrɛ "bɛ, e dra "ji 'yi ku -a, ɛn e 'belidɩ nɛn ya'a 'nyaan dɩɛ -a -nɔan -yrɛ.» 
\p  
\v 15 -A -nan nɛn lɩ bɛ e 'nan Zozi lɛ 'nan: «Minsan, 'yi zɩɛ 'i "mɛn "nɔn -e 'yi dra pee 'e vɩlɛ 'yaan 'tɛ dɩ, -e 'an vɩnan 'an 'ta "nyian 'yi 'tɔ 'gʋ dɩ.» 
\p  
\v 16 Ɛn Zozi "e -yrɛ 'nan: «'I 'kʋ 'i -sran laabʋ -e 'ka 'ta -a.» 
\p  
\v 17 Lɩ zɩɛ e 'nan -yrɛ 'nan: «'An -sran "ka "dɩ.» 
\p Ɛn Zozi "e -yrɛ 'nan: «I 'wɩ tɩglɩ 'vɩ -a vɩdɩ -a 'nan, 'i -sran "ka "dɩ.  
\v 18 -Yɛɛ cɩ 'nan i -kɔnnɛn 'pa tian 'soolu, ɛn min nɛn i cɩ "wlu "bɛ, 'i -sran "cɛɛ dɩ, i 'wɩ tɩglɩ 'vɩ.» 
\p  
\v 19 Tɔɔn lɩ bɛ e 'nan Zozi lɛ 'nan: «Minsan, maan ye "le 'nan Bali 'lewei vɩzan nɛn 'yia.  
\v 20 'Kʋ tranun nɛn Samari 'nɔn 'a bɛ, pɔn 'gʋɛ -a da nɛn o Bali 'bɔ, ɛn 'ka Zuif 'nɔn "ka 'vɩ 'nan Zeruzalɛm nɛn 'o 'kʋ Bali 'bɔ -kpɔ.» 
\p  
\v 21 Ɛn Zozi "e 'nan -yrɛ 'nan: «'I "trɔɛn "tɔ 'an wei 'gʋɛ -yrɛ 'kpa. Tʋ -tʋ -taa "bɔlɛ bɛ, te ka'a Bali bɔa pɔn 'gʋɛ -a da dɩ, ɛn ka'a 'ko Bali bɔlɛ Zeruzalɛm dɩ.  
\v 22 'Ka Samari 'nɔn bɛ, ka Bali bɔa, 'pian ka'a Bali 'bɔ 'tɔa dɩ, 'kʋ Zuif 'nɔn bɛ, "kʋ Bali bɔa ɛn "kʋ Bali 'bɔ -tɔa. -Yɛɛ cɩ 'nan min nɛn e 'trɛdanɔn "sia 'wɩ 'ji bɛ, Zuif 'nɔn 'va nɛn e "sia.  
\v 23 'Pian tʋ -tʋ -taa "bɔlɛ bɛ, ɛn -a tʋ 'bɔ 'bɔ 'va. Tʋ zɩɛ -a man nɛn Bali bɔ 'nɔn tɩglɩ -kaa "tɩ Bali bɔa Bali lei 'saun 'le 'plɛblɛ 'a, ɛn waa bɔa 'e -si tɩglɩ da. Bali bɔ 'nɔn zɩɛ o va nɛn -kaa "tɩ Bali cɩ.  
\v 24 Bali a lei -a. -Yee "wɛan minnun nɛn waa bɔa "bɛ, 'o bɔ -yee lei 'saun 'le 'plɛblɛ 'a, ɛn 'o bɔ 'e -si tɩglɩ da.» 
\p  
\v 25 Ɛn lɩ zɩɛ e 'nan Zozi lɛ 'nan: «Maan -tɔa 'nan min nɛn e cɩ Crizi -a bɛ e -taa, -a 'bɔ nɛn Bali -a 'si "va. Tʋ nɛn e -ta bɛ, e 'wɩ pɛɛnɔn 'ci ve 'kʋɛ.» 
\p  
\v 26 Ɛn Zozi "e 'nan -yrɛ 'nan: «'An 'bɔ nɛn an 'wɩ tin "baa 'yiɛ 'gʋɛ, mɛɛn cɩ -a.» 
\p  
\v 27 E -fʋ 'wɩ zɩɛ -a vɩnan, nun tɔɔn ɛn -a -srunɔn 'bɔla. 'Wɩ o 'kan 'nan 'o 'vale lɩmɔn -a o ya 'wɩ tin 'banan. 'Pian o va min -tʋ 'ka -a laabʋlɛ -yrɔ 'nan, -mɛ "wɩ nɛn e cɩ -a laabʋnan lɩ 'labɛ -yrɔ "dɩ? Ɛn wa'a laabʋlɛ "nyian 'nan, -mɛ "wɩ nɛn e cɩ -a tin 'banan -yrɛ "dɩ? 
\p  
\v 28 -A -nan nɛn lɩ zɩɛ e 'yee 'yi 'tɔvɛ 'tʋɩ, ɛn e -kʋ 'fla -a vɩlɛ minnun lɛ 'nan:  
\v 29 «'Ka 'ta min -tʋ yɩ. Min zɩɛ yaan drɛ wɩ pɛɛnɔn 'vɩ 'mɛn. -Te Crizi nɛn -o?»  
\v 30 Ɛn minnun pɛɛnɔn 'si 'fla, o -ta fɛnan nɛn e cɩ bɛ -a -nan. 
\p  
\v 31 Tʋ zɩɛ -a wlu bɛ, te Zozi -srunɔn Zozi man dra -wluwlu 'nan 'e fɛ -blɩ. 
\p  
\v 32 'Pian Zozi "e 'nan -wlɛ 'nan: «-Blɩfɛ nɛn 'an 'le 'gʋɛ, ka'a tɔa dɩ.» 
\p  
\v 33 Ɛn Zozi -srunɔn -a laabʋ 'o cin lɔ 'nan: «Min -tʋ -ta -blɩfɛ -a -yrɛ "baalɛ?» 
\p  
\v 34 Zozi "e -wlɛ 'nan: «'Mɛn -blɩfɛ nɛn 'nan min nɛn yaan 'pa 'sia bɛ, 'an 'ci 'sɔ wɩnun drɛ, ɛn 'nyranman nɛn yaa -nɔn 'mɛn bɛ 'an 'pa.  
\v 35 'Ka bɔ, "ka 'vɩ 'nan, e -fʋ mlɛn sinjɛn 'vaa -e 'o 'saa 'tɛdɩ 'sia. 'Pian 'an 'bɔ, maan ve 'cɛɛ 'nan, 'ka 'wulo wluan lou 'saa tran 'tɛvɛ -a.  
\v 36 Min nɛn e cɩ 'saa 'tɛnan bɛ, -a san -kopa a 'va, ɛn fɛ 'wlɛ 'bɔ nɛn yaa -tɛ bɛ, yaa tre 'belidɩ nɛn ya'a 'nyaan dɩɛ -yee vɛ -a. E drɛ zɩɛ 'nan -e min nɛn e 'saa 'fɔ bɛ, 'lee min nɛn yaa -tɛ bɛ, o 'ci 'e "nran 'e cin va.  
\v 37 O -kɔnnɛn "tʋ -fɔa 'nan: ‹Min -tʋ 'bɛ fɛ 'wlɛ -fɔa 'trɛ 'ji -e min pee nɛn 'e -tɛ.› E ya 'wɩ 'kpa -a.  
\v 38 An 'bɔ, an 'ka 'pa 'sia 'nan, 'ka 'kʋ 'saa 'tɛ fei nɛn ka'a 'nyranman 'palɛ "da "dɩɛ -a da. Min peenun -a da nyranman 'pa 'va, ɛn cɛɛ "ta -a "nɛn "ble.» 
\p  
\v 39 'Wɩ nɛn lɩ zɩɛ yaa 'vɩ bɛ, -yee "wɛan Samari 'nɔn "kaga "yi -tɛra Zozi da. Kɔɔ yaa 'vɩ 'nan, Zozi 'e drɛ wɩ pɛɛnɔn 'vɩ 'yrɛ.  
\v 40 Zɩ Samari 'nɔn 'ta Zozi 'va bɛ, ɛn waa trʋ 'ba 'nan 'e 'fʋ 'o 'va. -A -nan nɛn Zozi yi 'fiili drɛ o va.  
\v 41 'Wɩ nɛn yaa ve bɛ, -yee "wɛan minnun nɛn o yi -tɛra "da "bɛ, o 'bɔ "nyian "kaga 'kpa. 
\p  
\v 42 Ɛn waa 'vɩ 'siɛn lɩ zɩɛ -yrɛ 'nan: «Wa'a vɩlɛ 'nan 'wɩ nɛn yia 'vɩ bɛ, -a 'saza 'le "wɛan nɛn kʋ yi -tɛra "da "dɩ. 'Pian 'wɩ nɛn kʋa 'man "da 'kʋ 'bɔ 'a bɛ, -yee "wɛan nɛn kʋ yi -tɛra "da, ɛn kʋa -tɔ "mɛn 'nan -yɛɛ cɩ 'trɛdanɔn pɛɛnɔn 'sizan 'wɩ 'ji -a.» 
\s1 Mingɔnnɛn wluzan -tʋ -le 'nɛn 'man "yaaman ɛn Zozi -a beli 
\p  
\v 43 Zɩ Zozi yi "fli drɛ o va bɛ, ɛn e Galile -si 'sia "nyian.  
\v 44 Te Zozi -a 'vɩ 'e 'bɔ 'a 'nan, wa'a Bali 'lewei vɩzan -tʋ siala -dan 'e 'bɔ fla dɩ.  
\v 45 'Pian zɩ e 'bɔla Galile bɛ, Galile 'nɔn -a 'sia 'kpa tɩglɩ. Kɔɔ 'wɩ nɛn yaa drɛ "fɛdi da Zeruzalɛm bɛ, waa -nan 'yɩ, o -kʋ -nan nun -le "wɛan. 
\p  
\v 46 E 'bɔla "nyian Kanan Galile 'lɛglɔn 'bɔ 'ji, 'fla nɛn e 'yi lila 'wɛn -a bɛ -a da. 
\p Tʋ zɩɛ -a man bɛ, mingɔnnɛn wluzan -tʋ nɛn e -nyɛanla Kapanamo bɛ, te -a -pɩ 'man "yaaman 'kpa tɩglɩ.  
\v 47 Mingɔnnɛn wluzan zɩɛ, yaa 'man 'nan Zozi 'si Zude, ɛn e 'bɔla Galile. -A -nan nɛn e -kʋ Zozi 'va, ɛn e toba -fɔ -yrɛ 'nan, 'e -sɔɔn "ji Kapanamo -e 'e 'yee 'nɛn nɛn -a man "yaaman -nan nun bɛ -a 'beli. 'Nɛn zɩɛ -a -kadɩ -fɔla tʋ. 
\p  
\v 48 Ɛn Zozi "e 'nan -yrɛ 'nan: «-Te ka'a tian 'lɛbo "fɔ wɩnun 'lee -cɛ -srɔn "wɩnun -nan yɩlɛ dɩɛ, ka'a yi 'tɛala 'wɩ da 'mlɔnmlɔn dɩ.» 
\p  
\v 49 Mingɔnnɛn wluzan "e -yrɛ 'nan: «Minsan, 'i yra 'si, 'i -ta -trɛlɛ 'vaa -e 'mɛn 'nɛn 'e yiɛ 'lɛ wʋ.» 
\p  
\v 50 Ɛn Zozi -a 'vɩ -yrɛ 'nan: «'I 'kʋ, 'i -pɩ "belia.» E yi -tɛra 'wɩ nɛn Zozi -a 'vɩ bɛ -a da ɛn e -kʋ. 
\p  
\v 51 "Yɛɛ -kɔn -kʋnan -sia bɛ, ɛn -a 'sunɔn 'ta -a 'lɛ, ɛn o -yrɛ 'nan: «-Cɛ 'si 'yie 'nɛn man.»  
\v 52 -A -nan nɛn yaa laabʋ -wlɔ 'nan: «Tʋ "cɛn "man nɛn -cɛ 'si "man?» Ɛn o -yrɛ 'nan: «'Sɩ te yidɛ 'sia 'mɔɛnnɛn man "tiɛnnɔn, tɔɔn ɛn -cɛ 'si "man.» 
\p  
\v 53 Ɛn -a -cin -tɔ mingɔnnɛn wluzan ji 'nan, tʋ 'lein zɩɛ -a wlu nɛn Zozi -a 'vɩ 'yrɛ 'nan: «'I 'pɩ "belia.» -A -nan nɛn -a 'bɔ 'lee 'yee "kɔnnɛn 'nɔn pɛɛnɔn yi -tɛra Zozi da. 
\p  
\v 54 Zɩ Zozi 'si Zude ɛn e -kʋ Galile bɛ, -a -nan nɛn e 'lɛbo "fɔ wɩ zɩɛ -a drɛ. -Yee 'lɛbo "fɔ wɩ "flizan nɛn yaa dra fɛ 'lein zɩɛ -a -nan. 
\c 5  
\s1 Zozi min -tʋ nɛn e -sran "tra "bɛ -a beli 
\p  
\v 1 "Bɛ -sru, Zuif 'nɔn 'le "fɛdi -tʋ drɛdɩ 'bɔ Zeruzalɛm, ɛn Zozi 'kʋ -nan nun.  
\v 2 Zeruzalɛm 'bɔ man -klɔn bɛ, -a -wlala "nan "tʋ a, waa laabo 'blanun -wlala "nan. -Wlala "nan zɩɛ -a "srɔn "bɛ, 'yi 'tʋ a -nan, waa laabo Ebre wei -ji «Betɛsda». -Duban 'soolu a 'e 'tɔdɩ 'yi zɩɛ -a "srɔn.  
\v 3 -Dubannun zɩɛ -a wlu bɛ, -cɛ -tɛnɔn "kaga yra 'o nyinnandɩ -nan. Yiɛ 'winɔn 'lee minnun nɛn o "tun "bo bɛ 'lee minnun nɛn 'o -srandɩ "tra "bɛ, o nɛn. [O ya -a man -pɛnnan 'nan 'yi 'e 'nyɔɔn "ji.  
\v 4 -Yɛɛ cɩ 'nan Bali -le 'pasianɔn nɛn laji bɛ, -a -tʋ -sɔɔn "man 'yi zɩɛ -a va, -e 'e nyɔɔn. Min nɛn e sɔɔn "va 'e tɛdɛ te Bali -le 'pasiazan "sia -a nyɔɔnnan bɛ, -te -a san -le -cɛ a 'kɔ oo, e "sia "man.] 
\p  
\v 5 Ɛn min -tʋ a fɛ 'bɔ zɩɛ -a -nan, -cɛ a "man. -A -cɛ zɩɛ -a -nan lɛ -fuba yaaga 'wlɛ 'sɔra nɛn 'gʋ.  
\v 6 Zɩ Zozi -a 'yɩ 'e nyinnandɩ bɛ, ɛn yaa -tɔ 'nan -cɛ nɛn "man "bɛ -a yi "fli 'bɔ, -a -nan nɛn yaa laabʋ -yrɔ 'nan: «I ya "vale -cɛ 'e 'si 'i man?» 
\p  
\v 7 Ɛn min zɩɛ e 'nan Zozi lɛ nan: «Minsan, "mɛɛn -mie "ka -e 'yaan 'fɔ 'yi 'va te 'yi nyɔɔn "ji "dɩ. Ɛn -te "mɛɛn vɩnan 'an -pli 'yi 'bɔ man bɛ, -e min -tʋ 'e 'fɔ "va 'an 'lɔ 'e 'flin.» 
\p  
\v 8 -A -nan nɛn Zozi -a 'vɩ -yrɛ 'nan: «'I 'wluan lou, 'i 'yie nyinnan "davɛ 'sia, 'i 'ta wʋ!»  
\v 9 'Nun tɔɔn -cɛ 'si min zɩɛ -a man, e 'yee nyinnan "davɛ 'sia, ɛn e 'ta wʋdɩ 'sia. 
\p Yi zɩɛ -a da bɛ, te Zuif 'nɔn 'le 'flinla "yi nɛn waa laabo Saba bɛ -nyrɛn.  
\v 10 Ɛn zɩ Zuif 'nɔn 'tanɔn -a 'yɩ bɛ, ɛn waa 'vɩ -yrɛ 'nan: «Cɛɛgʋ 'flinla "yi nɛn, -yee "wɛan -a -si 'ka 'e 'nɔndɩ 'yiɛ -e 'i 'kʋ 'yie nyinnan "davɛ -a dɩ.» 
\p  
\v 11 Ɛn e 'nan -wlɛ 'nan: «Min nɛn e -cɛ 'si 'an man bɛ, e 'nan 'mɛn 'nan: ‹'I 'yie nyinnan "davɛ 'sia, 'i 'ta wʋ.› » 
\p  
\v 12 Waa laabʋ -yrɔ 'nan: «Min "cɛn 'bɛ 'vɩ 'yiɛ 'nan 'i 'yie nyinnan "davɛ 'sia, 'i 'ta wʋ?» 
\p  
\v 13 'Pian min nɛn -cɛ 'si "man "bɛ, ya'a min zɩɛ -a tɔa dɩ. Kɔɔ Zozi 'si fɛ zɩɛ -a -nan min "kaga "le "wɛan. 
\p  
\v 14 "Bɛ -sru, Zozi min zɩɛ -a 'yɩ Bali -pan 'kuin, ɛn e 'nan -yrɛ 'nan: «'I "trɔɛn "tɔ 'wɩ 'gʋɛ -yrɛ 'kpa! -Cɛ 'si 'i man, te 'i 'wɩ 'wlidɩ "drɛ "nyian dɩ, "tɔgɔ 'wɩ nɛn e -ciala 'wɩ zɩɛ 'bɛ da bɛ, 'e bɔ 'i man.» 
\p  
\v 15 Min zɩɛ e -kʋ, ɛn yaa 'vɩ Zuif 'nɔn lɛ "mɛn 'nan Zozi 'bɛ -cɛ 'si 'e man.  
\v 16 -Yee "wɛan Zuif 'nɔn Zozi -wɛɛdɩ 'sia 'nan e 'wɩ zɩɛ -a drɛ 'flinla "yi da. 
\p  
\v 17 'Pian Zozi 'wɩ 'ci 'vɩ -wlɛ, yaa 'vɩ 'nan: «'An "tɩ 'nyranman "paa tian tʋ 'gʋɛ -a, -yee "wɛan 'an 'bɔ "nyian, "an "ya wo -a 'panan.» 
\p  
\v 18 'Wɩ zɩɛ -yee "wɛan Zuif 'nɔn a Zozi -wɛɛnan 'kpa tɩglɩ 'nan o -tɛa. Wa'a vɩlɛ 'nan e -wee 'flinla "yi 'srɔɛn srɛ -yee "wɛan dɩ, 'pian 'nan, e 'nan Bali 'bɛ cɩ 'e "tɩ "a, te 'e 'fli -kɔɔnnan Bali man. 
\s1 Zozi 'le 'plɛblɛ bɛ Bali 'bɔ 'bɛ -nɔn -yrɛ 
\p  
\v 19 Ɛn Zozi 'e 'fli -le 'wɩ 'vɩ -wlɛ 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, Bali -pɩ 'ka 'kɔlaman 'wɩ 'tʋ drɛdɩ -a 'e 'bɔ 'wulo -ji wɩ -a dɩ, 'pian 'wɩ nɛn yaa -nan 'yɩ 'e "tɩ 'lɔ bɛ -nyrɛn yaa dra. 'Wɩ pɛɛnɔn nɛn -a "tɩ -a dra bɛ, -nyrɛn -a -pɩ -a dra "nyian.  
\v 20 -Yɛɛ cɩ 'nan -kaa "tɩ Bali 'e 'pɩ ye "yi, ɛn 'wɩ pɛɛnɔn nɛn Bali -a dra bɛ, yaa -kɔɔnman 'e 'pɩ lɛ. 'Wɩnun nɛn e cɩ -dandan 'kpa e -ciala 'gʋ da bɛ, yaa -kɔɔnman -yrɛ, 'nan -e 'wɩ 'e 'ka 'kan 'le "wɛan.  
\v 21 Zɩ -kaa "tɩ Bali minnun wuanla -kanɔn 'va -e 'e 'belidɩ -nɔn -wlɛ "bɛ, -a -tʋwli "nɛn "nyian -a -pɩ -a dra -e min nɛn e 'sɔ "ji "bɛ 'e 'belidɩ -nɔn -a san lɛ.  
\v 22 Ɛn "nyian bɛ, -kaa "tɩ Bali "cɛɛ min -le 'wɩ tin 'baa dɩ, 'pian e 'wɩ tin 'badɩ pɛɛnɔn -pɛba 'wʋ 'e 'pɩ -lɔ.  
\v 23 Yaa drɛ zɩɛ 'nan -e minnun pɛɛnɔn 'o -pɩ 'tɔ bɔ "le zɩ o -a 'bɔ 'tɔ bɔa "bɛ -yee 'wɩ 'zʋ. Min nɛn ya'a -pɩ 'tɔ bɔlɛ dɩɛ, te -a "tɩ "nɛn yaa 'pa 'sia bɛ, ya'a 'tɔ bɔlɛ dɩ. 
\p  
\v 24 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, min nɛn yaan wei 'man "yi, ɛn e yi -tɛra Bali nɛn yaan 'pa 'sia bɛ -a da bɛ, 'belidɩ nɛn ya'a 'nyaan dɩɛ e ya -a san -le vɛ -a. -A san -le tin 'badɩ 'ka 'kɔan 'mlɔnmlɔn dɩ, 'pian e 'sʋ 'ka -lɔ ɛn e 'belidɩ 'yɩ.  
\v 25 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, tʋ -tʋ -taa "bɔlɛ, ɛn e 'bɔ 'va. Tʋ zɩɛ -a man nɛn minnun nɛn o cɩ minnun -kadɩ -a Bali 'lɛ bɛ, o Bali -pɩ wei maan. Ɛn minnun nɛn waa 'man "yi "bɛ o "belia.  
\v 26 -Yɛɛ cɩ 'nan zɩ 'plɛblɛ a -kaa "tɩ Bali 'lɔ -e 'e 'belidɩ -nɔn minnun lɛ bɛ, -a -tʋwli "nɛn yaa -nɔn 'e 'pɩ lɛ 'nan 'e 'belidɩ -nɔn minnun lɛ.  
\v 27 Ɛn yaa -si -nɔn -yrɛ 'nan 'e minnun -le 'wɩ tin 'ba, e ya blamin -pɩ -a -le "wɛan. 
\p  
\v 28 Te 'wɩ 'gʋɛ 'e 'ka 'kan dɩ, kɔɔ -a tʋ -a -tanan bɔdɩ -a. Tʋ zɩɛ -a man nɛn minnun nɛn o kaa o ya -yrɛ -ji bɛ, o Blamin -pɩ wei maan,  
\v 29 ɛn o bɔala 'yrɛ -ji. Minnun nɛn o 'wɩ "yi drɛ bɛ, o wuanla -e 'o 'belidɩ yɩ. Ɛn minnun nɛn o 'wɩ 'wlidɩ drɛ bɛ, o wuanla -e tin 'e 'tɛ o da. 
\p  
\v 30 Ma'an 'kɔlaman -e 'an 'wɩ 'tʋ drɛ 'an 'bɔ 'wulo -ji wɩ -a dɩ. 'Wɩ nɛn 'an "tɩ -a ve 'mɛn bɛ, -a da nɛn an min -le 'wɩ tin "baa. Kɔɔ an 'ka 'an 'bɔ 'ci 'sɔ wɩnun -wɛɛnan dɩ, 'pian Bali nɛn yaan 'pa 'sia bɛ, -a ci 'sɔ wɩnun -wɛɛnan nɛn an cɩ. 
\p  
\v 31 -Te 'an 'bɔ mɛɛn cɩ 'an 'bɔ 'fli -le 'wɩ 'nan yɩzan -a bɛ, min 'ka 'an wei siala 'wɩ 'kpa -a dɩ.  
\v 32 'Pian 'mɛn 'wɩ 'nan yɩzan a, ɛn maan -tɔa 'nan 'wɩ nɛn yaa ve 'an man bɛ 'wɩ 'kpa nɛn. 
\p  
\v 33 'Ka 'bɔ, 'ka minnun 'pa 'sia Zan -va, ɛn e 'wɩ tɩglɩ 'vɩ 'an man.  
\v 34 An 'bɔ 'le vɛ bɛ, ma'an wɛɛman 'nan min nɛn 'e drɛ 'mɛn 'wɩ 'nan yɩzan -a dɩ, 'pian 'an Zan -le 'wɩ ve cɛɛ 'nan -e 'ka yi -tɛra "da, -e Bali 'e 'ka 'si 'wɩ 'ji.  
\v 35 Zan a "le 'nan 'tɛ nɛn waa -fɔ "nɛn ɛn e blɩ bɛ -yee 'wɩ 'zʋ. Ka wɩɩ "man, ɛn 'ka 'ci nran -a -san man tʋ "wɛnnɛn 'a. 
\p  
\v 36 'Wɩ nɛn 'bɛ 'mɛn 'wɩ -kɔɔnman bɛ, 'bɛ -dan "mlian 'wɩ nɛn Zan -a 'vɩ 'an man bɛ -a da. 'Wɩnun nɛn 'an "tɩ -a -nɔn 'mɛn 'nan 'an drɛ bɛ, -a 'wɩnun 'bɔ nɛn maan dra 'gʋ. -Yɛɛ -kɔɔnman 'nan 'an "tɩ 'bɛ 'an 'pa 'sia.  
\v 37 'An "tɩ 'bɔ nɛn yaan 'pa 'sia bɛ, -yɛɛ 'an 'man wɩ 'vɩ 'e 'bɔ 'a. 'Pian ka'a tian 'li -a wei manlɛ 'mlɔnmlɔn dɩ, ɛn ka'a tian 'li -a yra yɩlɛ 'mlɔnmlɔn dɩ.  
\v 38 Ɛn -a wei -cin 'ka 'fɔla 'ka 'ji dɩ, kɔɔ ka'a yi 'tɛala -a -pɩ nɛn yaa 'pa 'sia bɛ -a da dɩ.  
\v 39 Kaa -tɔa 'nan Bali wei nɛn 'e 'crɛn -tɛdɩ bɛ, e 'belidɩ nɛn ya'a 'nyaan dɩɛ -a -nɔan "min lɛ, -yee "wɛan kaa ta ve tʋ pɛɛnɔn man. 'Fluba 'crɛnnun zɩɛ, -wɛɛ 'an 'man wɩ ve minnun lɛ.  
\v 40 'Pian ka 'ka "vale 'ka -taa 'an -sru, -e 'belidɩ 'kpa 'e drɛ 'cee vɛ -a dɩ. 
\p  
\v 41 An 'ka -a -wɛɛnan 'nan minnun 'waan 'tɔ bɔ dɩ,  
\v 42 'pian an 'ka -tɔa. Maan -tɔa 'nan Bali yɩdɩ "yi 'ka 'ka 'ji dɩ.  
\v 43 'An "tɩ 'bɛ 'an 'pa 'sia, ɛn ka 'ka "vale 'kaan "sia 'cee vɛ -a dɩ. -Te min pee -ta 'e 'bɔ 'tɔ da bɛ, cɛɛ "sia 'cee vɛ -a.  
\v 44 Kaa -wɛɛman 'nan 'ka bɔɛzan -tʋ 'e 'ka 'tɔ bɔ. Ka'a wɛɛman 'pian 'nan Bali -tʋwli "nɛn 'e 'ka 'tɔ bɔ dɩ. Ɛn -te ka ya zɩɛ 'wɩ 'kpa bɛ, e dra 'kɔ -e 'ka yi -tɛra 'an da? 
\p  
\v 45 Te 'ka 'ci "nrɔn 'nan 'an "tɩ 'va nun bɛ, 'an 'bɔ 'bɛ 'wɩ -tɔa 'ka man dɩ! Min nɛn e 'wɩ -tɔa 'ka man bɛ, Moizi nɛn 'ka 'ci "nrɔn man "da 'nan e -taa 'palɛ 'ka 'va bɛ -nyrɛn.  
\v 46 -Yɛɛ cɩ 'nan "te ka yi -tɛala Moizi da bɛ, "te ka yi -tɛala 'an da "nyian, kɔɔ 'mɛn 'wɩ nɛn Moizi -a crɛn -tɛ.  
\v 47 'Pian 'wɩ nɛn yaa crɛn -tɛ bɛ, ka'a yi 'tɛala "da "dɩ, e dra "mɛn 'kɔ 'lɔɔ -e 'ka yi -tɛra 'wɩ nɛn maan ve bɛ -a da?» 
\c 6  
\s1 Zozi 'blɩfɛ -nɔn min "kaga "lɛ 
\r (Mt 14.13-21; Mk 6.30-44; Lk 9.10-17) 
\p  
\v 1 "Bɛ -sru ɛn Zozi 'kʋ Galile 'yi nɛn waa laabo "nyian Tiberia 'yi bɛ -a -sru.  
\v 2 Min "kaga 'kʋla Zozi -sru, -yee 'lɛbo "fɔ wɩnun nɛn yaa drɛ -cɛ -tɛnɔn 'belidɩ -a ɛn waa -nan 'yɩ bɛ -yee "wɛan.  
\v 3 Zozi pɔn -tʋ tri 'o 'vale 'e -srunɔn 'a, ɛn o -nyran.  
\v 4 Te Zuif 'nɔn 'le 'si nɔanba -ji "fɛdi drɛdɩ 'bɔ 'kogo. 
\p  
\v 5 Zɩ Zozi 'e 'wulo wluan, ɛn e min "kaga 'yɩ -tanan 'o 'va zia bɛ, -a -nan nɛn yaa laabʋ Filipʋ -lɔ 'nan: «Nyin zia nɛn, -kaa -blɩfɛ "lɔa, -e -kaa -nɔn min "kaga 'labɛ -wlɛ?»  
\v 6 Zɩ kɔ Zozi 'e drɛ bɛ -a -cin a "ji, 'pian e 'tan Filipʋ man -a ci wɩ mandɩ -le "wɛan. 
\p  
\v 7 Ɛn Filipʋ "e -yrɛ 'nan: «-Te -kaa -blɩfɛ 'lɔ -kpi fuba sinjɛn bɛ, ya'a 'bɔa waa "fo "dɩ.» 
\p  
\v 8 Ɛn Zozi -sruzan 'pee nɛn, waa laabo Andre, Simɔn Piɛri "bʋɩ -a bɛ e 'nan:  
\v 9 «'Kpɔun 'soolu 'lee pɔ "fli "a 'nɛn 'klɔnmɔn -tʋ -lɔ 'gʋ, 'pian ya'a 'bɔa waa "fo "dɩ?» 
\p  
\v 10 Ɛn Zozi "e 'nan 'e -srunɔn lɛ 'nan: «'Ka min pɛɛnɔn -nyran "tra.» Waa 'vɩ -wlɛ, ɛn o -nyran lu da, kɔɔ -a -nan lu a fɛnyian -nyran "davɛ -a. Minnun zɩɛ, -klɔnmɔn a o va -kpi 'soolu. 
\p  
\v 11 Zozi 'kpɔun 'soolu zɩɛ -a 'si, e Bali muo "fɔ, ɛn yaa pli o man. E pɔ 'si ɛn yaa drɛ "nyian zɩ. Min -tʋ "e blɩ "le zɩ e cɩ "va "bɛ -yee 'wɩ 'zʋ. 
\p  
\v 12 Zɩ e o 'kan bɛ, ɛn Zozi "e 'nan 'e -srunɔn lɛ 'nan: «'Ka -nyranman "koola! Te 'ka 'blɩfɛ 'tʋɩ -e 'e srɛ dɩ.»  
\v 13 Ɛn -a -srunɔn -a koola. 'Kpɔun 'soolu bɛ e min "kaga zɩɛ o 'kan, ɛn -a -nyranman saannɛn -fuda "fli 'fa. 
\p  
\v 14 Zɩ minnun Zozi 'le 'lɛbo "fɔ wɩ -dan zɩɛ, -a -nan 'yɩ bɛ, ɛn o 'nan: «'Wɩ 'kpa! Min 'labɛ, e ya Bali 'lewei vɩzan nɛn o 'nan e -taa "bɛ -a.» 
\p  
\v 15 Zɩ Zozi -a -kɔnnɛn 'yɩ 'nan, o "ta -daa 'e 'kunlɛ -e 'wee 'tɔ 'wee mingɔnnɛn -a bɛ, ɛn e 'li 'e da "nyian pɔn da nun 'e 'saza. 
\s1 Zozi 'ta 'wʋ Galile 'yi yiɛ da 
\r (Mt 14.22-33; Mk 6.45-52) 
\p  
\v 16 Zɩ funninmlan 'pla bɛ, ɛn -a -srunɔn sɔɔn "ji 'yi man.  
\v 17 O -fɔ -klʋ -tʋ -ji, ɛn o -kʋdɩ 'sia 'fla nɛn waa laabo Kapanamo bɛ -a da. E ya 'yi 'bɔ -sru. Klun -trɔa, te Zozi 'ka tian bɔlɛ o man dɩ,  
\v 18 ɛn fulɔ 'plɛblɛ 'tʋ "fɛɛndɩ 'sia, te 'yi 'bɔ 'nyɔɔnman.  
\v 19 O -klʋ -fɔ o -sru 'bɔ 'kɔɔbli, waa drɛ kilo 'soolu te 'bɛ "cɛɛ dɩ kilo 'shɛɛdʋ. "Wɛɛ vɩnan 'o yiɛ -tɔa "bɛ, te o Zozi ye -tanan 'ta wʋdɩ -a 'yi yiɛ da, ɛn "klan -sɛn o ji.  
\v 20 'Pian Zozi "e 'nan -wlɛ 'nan: «'An 'bɔ nɛn. Te "klan 'e 'ka 'tɛ dɩ!» 
\p  
\v 21 -A -nan nɛn o ya "vale 'nan 'o Zozi -fɔa 'o 'va 'klʋ -ji. 'Nun tɔɔn ɛn o bɔla fɛnan nɛn o cɩ -kʋnan bɛ -a -nan. 
\s1 Zozi a -blɩfɛ nɛn e 'belidɩ -nɔan "min lɛ bɛ -a 
\p  
\v 22 Zɩ tʋ cɛɛn bɛ, minnun nɛn o -fʋ "yi -sru "bɛ, ɛn -a -cin -trɔa o ji 'nan -klʋ a 'sɩ 'tʋwli, ɛn Zozi 'ka 'fɔlɛ -ji dɩ. Waa -tɔa 'pian 'nan -a -srunɔn 'kʋ 'o 'saza.  
\v 23 Tɔɔn ɛn -klʋ -mienun 'si minnun -a Tiberia. O 'bɔla fɛnan nɛn Minsan Bali muo "fɔ 'vaa ɛn o fɛnun blɩ bɛ, -a -nan "srɔn.  
\v 24 Zɩ wa'a Zozi yɩlɛ dɩɛ, te wa'a "nyian -a -srunɔn 'ye dɩɛ, ɛn minnun pɛɛnɔn 'fɔ -klʋnun zɩɛ -a -ji, ɛn o -kʋ Zozi -wɛɛlɛ Kapanamo. 
\p  
\v 25 O 'bɔ Zozi man 'yi -sru "nun, ɛn waa laabʋ -yrɔ 'nan: «Bali -le 'wɩ "paazan, tʋ "cɛn "man nɛn i -ta 'gʋ?» 
\p  
\v 26 Ɛn Zozi "e 'nan -wlɛ 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, ka -blɩfɛ 'yɩ, kaa blɩ, ka 'kan, -yee "wɛan ka ya 'an -wɛɛnan. Ka 'ka 'an -wɛɛnan 'nan -cɛ -srɔn "wɩnun nɛn maan drɛ bɛ, kaa -ci 'man 'le "wɛan dɩ.  
\v 27 Te 'ka -wɛɛ 'nan -blɩfɛ nɛn e srɛman bɛ, -nyrɛn 'ka ye dɩ. 'Pian 'ka -wɛɛ 'nan -blɩfɛ nɛn e "mɔan ɛn e 'belidɩ -nɔan "min lɛ bɛ, -nyrɛn 'ka ye. 'An 'bɔ Blamin -pɩ 'bɛ -blɩfɛ zɩɛ -a -nɔan 'cɛɛ, kɔɔ 'an "tɩ Bali -a 'plɛblɛ 'nɔn 'mɛn.» 
\p  
\v 28 Ɛn waa laabʋ -yrɔ 'nan: «Kʋa dra 'kɔ, 'wɩnun nɛn e cɩ Bali ci 'sɔ 'a bɛ, -e 'kʋ -kɔla -a drɛdɩ -a?» 
\p  
\v 29 Ɛn Zozi -a 'vɩ -wlɛ 'nan: «'Wɩ -tʋwli "nɛn Bali cɩ "vale 'ka drɛ bɛ, -nyrɛn 'nan, 'ka yi -tɛra min nɛn Bali 'bɔ -a 'pa 'sia bɛ -a da.» 
\p  
\v 30 -A -nan nɛn waa laabʋ Zozi 'lɔ 'nan: «'Lɛbo "fɔ wɩ "kɔ "nɛn yia dra -e 'kʋ yi -tɛra 'i da? -Mɛ "wɩ nɛn i -taa -a drɛlɛ?  
\v 31 'Li te 'kʋ tranun a "bui "da bɛ, o fɛ -tʋ nɛn waa laabo manɛn bɛ, -a blɩ. E ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji nan: 
\q1 ‹E -blɩfɛ nɛn e 'si laji bɛ 
\q1 -a -nɔn -wlɛ.› » 
\p  
\v 32 Ɛn Zozi -a 'vɩ -wlɛ 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, Moizi "cɛɛ -blɩfɛ tɩglɩ 'si laji ɛn yaa -nɔn 'cɛɛ dɩ. 'Pian 'an "tɩ 'bɛ -blɩfɛ tɩglɩ 'si laji, ɛn yaa -nɔn 'cɛɛ.  
\v 33 -Yɛɛ cɩ 'nan fɛ nɛn Bali -a -nɔn -blɩfɛ -a bɛ, min nɛn e 'si laji te e 'belidɩ -nɔan 'trɛdanɔn lɛ bɛ -nyrɛn.» 
\p  
\v 34 Ɛn minnun -a 'vɩ -yrɛ 'nan: «Minsan, -blɩfɛ zɩɛ 'i -nɔn 'kʋɛ tʋ pɛɛnɔn man.» 
\p  
\v 35 Zozi "e 'nan "mɛn -wlɛ 'nan: «'An 'bɔ 'bɛ cɩ -blɩfɛ nɛn e 'belidɩ -nɔan "bɛ -a. Min nɛn e -ta 'an 'va bɛ, dra 'ka -a tɛa "nyian 'mlɔnmlɔn dɩ, ɛn min nɛn e yi -tɛra 'an da bɛ, 'yi dra 'ka "nyian -a tɛa 'mlɔnmlɔn dɩ.  
\v 36 Maan 'vɩ 'cɛɛ 'va, ɛn kaan 'yɩ 'ka 'bɔa, 'pian ka'a yi 'tɛala 'an da dɩ.  
\v 37 Minnun pɛɛnɔn nɛn 'an "tɩ "o -nɔn 'mɛn bɛ, o -taa 'an 'va, ɛn min "ɛ -ta 'an 'va bɛ, ma'an pian 'mlɔnmlɔn dɩ.  
\v 38 Kɔɔ ma'an 'silɛ laji 'nan -e 'an 'bɔ 'fli ci 'sɔ wɩnun drɛ dɩ, 'pian 'nan -e 'an min nɛn yaan 'pa 'sia bɛ -a ci 'sɔ wɩnun drɛ.  
\v 39 Min nɛn yaan 'pa 'sia bɛ, -a ci 'sɔ wɩnun nɛn 'nan: Minnun nɛn e o -nɔn 'mɛn bɛ, te 'an -tʋwli "cɛ 'san "va "dɩ, 'pian 'nan 'an o wluan -kanɔn 'va yi -fɔla "da "ji.  
\v 40 'An "tɩ 'ci 'sɔ wɩnun nɛn "nyian 'nan, minnun pɛɛnɔn nɛn waan 'yɩ -a -pɩ -a ɛn o yi -tɛra "da "bɛ, 'belidɩ nɛn ya'a 'nyaan dɩɛ e ya -wee vɛ -a. 'An 'bɔ 'bɛ o wuanla -kanɔn 'va yi -fɔla "da "ji.» 
\p  
\v 41 Zozi -a 'vɩ 'nan 'e ya -blɩfɛ nɛn e 'si laji, ɛn e 'belidɩ -nɔan "min lɛ bɛ -a, -yee "wɛan minnun wunwun "vɩdɩ 'sia 'o cin yei.  
\v 42 Waa ve 'nan: «Min 'labɛ, Zozɛfʋ -pɩ Zozi bɛ -nyrɛn. -Kaa "tɩ -tɔa, ɛn kaa "bʋ -tɔa. E drɛ "mɛn 'kɔ, ɛn yaa ve 'nan 'e 'si laji?» 
\p  
\v 43 Ɛn Zozi "e 'nan -wlɛ 'nan: «'Ka wunwun "vɩdɩ 'le 'tɔ.  
\v 44 Min -tʋ 'ka 'kɔlaman -e 'e 'ta 'an 'va, te 'an "tɩ "nɛn yaan 'pa 'sia bɛ -yɛɛ "cɛɛ 'taa 'mɛn dɩ. Ɛn -te e -ta bɛ, maan wuanla -kanɔn 'va yi -fɔla "da "ji.  
\v 45 E ya 'e 'crɛn -tɛdɩ Bali 'lewei vɩnɔn 'le 'fluba 'ji 'nan: 
\q1 ‹Bali 'bɛ 'wɩ "paaman min pɛɛnɔn 'ji.› 
\m Min nɛn e -kaa "tɩ Bali wei 'man, ɛn e wɩɩ -yee 'wɩ "paadɩ man bɛ, -a san 'bɛ -taa 'an 'va.  
\v 46 E 'ka 'nan min -tʋ -kaa "tɩ 'yɩ dɩ. An 'bɔ nɛn 'an 'si "va "nun bɛ, mɛɛn -kaa "tɩ Bali 'yɩ.  
\v 47 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan min nɛn e yi -tɛala 'an da bɛ, 'belidɩ nɛn ya'a 'nyaan dɩɛ, e ya -a san -le vɛ -a.  
\v 48 'An 'bɔ 'bɛ cɩ -blɩfɛ nɛn e 'belidɩ -nɔan "bɛ -a.  
\v 49 'Ka tranun fɛ -tʋ nɛn waa laabo Manɛn bɛ -a blɩ "bui "da, ɛn ya'a 'kadɩ si 'lɛ wʋlɛ -wlɔ "dɩ.  
\v 50 'Pian -blɩfɛ 'gʋɛ, 'bɛ 'si laji, min nɛn yaa blɩ bɛ, ya'a 'kaa "fo "dɩ.  
\v 51 'An 'bɔ 'bɛ cɩ -blɩfɛ nɛn e 'belidɩ -nɔan "bɛ -a. Min nɛn e -blɩfɛ zɩɛ -a blɩ bɛ, 'belidɩ nɛn ya'a 'nyaan dɩɛ e ya -a san -le vɛ -a. -Blɩfɛ 'bɔ nɛn an -taa -a -nɔnlɛ bɛ, 'an 'bɔ 'kɔlɛ nɛn. Maan -nɔan 'trɛdanɔn pɛɛnɔn 'beli vɛ -a.» 
\p  
\v 52 -A -nan nɛn Zuif 'nɔn 'sa -fɔdɩ 'sia 'o cin yei, te waa ve 'nan: «Yaa dra 'kɔ -e 'e 'kɔlɛ 'nɔn min lɛ -blɩfɛ -a?» 
\p  
\v 53 Ɛn Zozi -a 'vɩ -wlɛ 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, -te ka'an 'bɔ Blamin -pɩ 'kɔlɛ 'blɩlɛ dɩɛ, ɛn -te ka'an nyɛn mlinlɛ dɩɛ, te 'belidɩ 'ka 'ka 'lɔ dɩ.  
\v 54 Min nɛn yaan 'kɔlɛ 'ble, ɛn yaan nyɛn -mlian "bɛ, 'belidɩ nɛn ya'a 'nyaan dɩɛ, e ya -a san -le vɛ -a. Maan wuanla -kanɔn 'va yi -fɔla "da "ji.  
\v 55 -Yɛɛ cɩ 'nan 'an 'kɔlɛ bɛ, -blɩfɛ tɩglɩ nɛn, ɛn 'an nyɛn bɛ, mlin vɛ tɩglɩ nɛn.  
\v 56 Min nɛn yaan 'kɔlɛ 'ble ɛn yaan nyɛn -mlian "bɛ, te 'kʋ 'vale -a san -a kʋ drɛ min -tʋwli "a, kʋ'a 'sia 'e cin man dɩ.  
\v 57 -Kaa "tɩ "nɛn yaan 'pa 'sia bɛ 'belidɩ a -yrɔ, ɛn -yɛɛ 'belidɩ -nɔn 'mɛn, -a -tʋwli "nɛn "nyian min nɛn yaan 'kɔlɛ blɩ bɛ, an 'belidɩ -nɔan -a san lɛ.  
\v 58 'An 'kɔlɛ bɛ, -blɩfɛ tɩglɩ nɛn e 'si laji bɛ -nyrɛn. E 'ka "le 'nan fɛ nɛn 'ka tranun -a blɩ "bui "da bɛ -yee 'wɩ 'zʋ dɩ. Waa blɩ, ɛn ya'a 'kadɩ si 'lɛ wʋlɛ -wlɔ "dɩ. Min nɛn e -blɩfɛ 'gʋɛ -a blɩ bɛ, 'belidɩ nɛn ya'a 'nyaan dɩɛ e ya -a san -le vɛ -a.» 
\p  
\v 59 'Wɩ zɩɛ, -a 'bɔ nɛn Zozi -a 'vɩ te e ya 'wɩ "paanan minnun ji Zuif 'nɔn 'le cin yɩ 'kuin, 'fla nɛn waa laabo Kapanamo bɛ -a da.  
\v 60 Ɛn zɩ -a -srunɔn 'wɩnun zɩɛ -a 'man bɛ, -a -nan nɛn o va min "kaga "e 'nan: «'Wɩ nɛn yaa "paaman 'gʋɛ, e ya 'plɛblɛ, min -tʋ 'ka 'kɔlaman -e 'e "trɔɛn "tɔ -yrɛ "dɩ.» 
\p  
\v 61 Te Zozi -a -tɔ 'e 'fli -lɔ 'va 'nan 'wɩ zɩɛ e wunwun "vɩdɩ 'pla 'e -srunɔn 'nɛan. Ɛn yaa laabʋ -wlɔ 'nan: «'Wɩ nɛn maan 'vɩ 'gʋɛ e 'ka 'ci baa 'ji?  
\v 62 'Lɔɔ -te ka Blamin -pɩ 'yɩ te e "ta wuanla -e 'e 'kʋ fɛnan nɛn e cɩ 'e tɛdɛ bɛ -a -nan bɛ, e dra 'cɛɛ 'kɔ?  
\v 63 Bali lei 'saun 'bɛ 'belidɩ -nɔan "min lɛ. Min 'bɔ 'saza 'ka 'kɔlaman -e 'e 'belidɩ yɩ dɩ. Wei nɛn maan 'vɩ 'cɛɛ 'gʋɛ, min nɛn e yi -tɛra "da "bɛ, e Bali lei 'saun ye, ɛn e 'belidɩ ye.  
\v 64 'Pian min -mienun a 'ka yei te wa'a yi 'tɛala "da "dɩ.» 
\p -Te Zozi 'wɩ zɩɛ -a 'vɩ bɛ, -yɛɛ cɩ 'nan -a pou sianan "bɛ, te e minnun nɛn wa'a yi 'tɛala -a wei da dɩɛ o -tɔa, ɛn min nɛn e -taa -a -nɔnlɛ minnun lɛ bɛ yaa -tɔa.  
\v 65 Tɔɔn ɛn Zozi -a 'vɩ "nyian 'nan: «-Yee "wɛan nɛn maan 'vɩ 'cɛɛ 'nan min 'ka 'kɔlaman -e 'e 'ta 'an 'va te 'an "tɩ "cɛɛ -si -nɔn -yrɛ "dɩ.» 
\p  
\v 66 Tʋ zɩɛ -a man nɛn Zozi -srunɔn "kaga 'li 'o da, ɛn wa'a "nyian -sɔɔnlɛa -a -sru "dɩ. 
\p  
\v 67 Ɛn Zozi -a laabʋ min -fuda "fli "nɛn o -fʋ -a -sru "bɛ -wlɔ 'nan: «Kaa "nun, ka 'ka "vale "ka -koo "nyian dʋʋ?» 
\p  
\v 68 -A -nan nɛn Simɔn Piɛri -a 'vɩ -yrɛ 'nan: «Minsan, -tɩ -va nɛn kʋ lia 'kʋ da? 'I wei 'bɛ 'belidɩ nɛn ya'a 'nyaan dɩɛ -a -nɔan "min lɛ.  
\v 69 Kʋ yi -tɛra "da ɛn kʋa -tɔ 'nan yiɛ cɩ min nɛn Bali -a 'si "va "bɛ -a.» 
\p  
\v 70 Ɛn Zozi -a 'vɩ -wlɛ 'nan: «'An 'bɔ 'bɛ 'ka 'si "va -fuda "fli, 'pian 'ka 'va min -tʋ a Satan -le 'nɛn 'a!»  
\v 71 Min nɛn Zozi cɩ -yee 'wɩ vɩnan bɛ, Simɔn Karioti -pɩ Zudazi nɛn. -A -srunɔn 'fuda "fli 'bɔ 'va min -tʋ nɛn, -yɛɛ -taa Zozi 'bɔ 'nɔnlɛ minnun lɛ. 
\c 7  
\s1 Zozi "bʋɩnun 'ka yi 'tɛala Zozi da dɩ 
\p  
\v 1 "Bɛ -sru ɛn Zozi ciɩ Galile 'lɛglɔn 'ji. E 'ka "vale 'e 'ko Zude 'lɛglɔn 'ji dɩ, kɔɔ Zuif 'nɔn 'tanɔn a -a -wɛɛnan 'nan -e 'o -tɛ.  
\v 2 Zuif 'nɔn 'le "fɛdi nɛn waa -ble lo 'la -paannun wlu bɛ -a tʋ 'bɔ 'kogo.  
\v 3 Ɛn Zozi "bʋɩnun "e Zozi lɛ 'nan: «'I 'si 'gʋ! 'I 'kʋ Zude 'lɛglɔn 'ji -e 'i -srunɔn 'o 'lɛbo "fɔ wɩnun nɛn yia dra bɛ -a -nan yɩ.  
\v 4 Min nɛn yaa -wɛɛman 'nan min pɛɛnɔn 'o 'e 'tɔ bɛ, ya'a 'yɔɔman dɩ. 'Wɩnun nɛn yia dra 'gʋɛ, 'i drɛ -e min pɛɛnɔn 'o -nan yɩ.»  
\v 5 Zozi 'bɔ "bʋɩnun 'ka "nyian "o yi 'tɛala Zozi da dɩ. 
\p  
\v 6 Ɛn Zozi "e 'nan -wlɛ 'nan: «'Mɛn tʋ 'ka tian bɔlɛ dɩ. 'Pian tʋ pɛɛnɔn a "yi 'cee vɛ "le "a.  
\v 7 -A -ci "ka -e 'trɛdanɔn 'o 'nan "cee "man dɩ, 'pian o "naan "mɛɛn "man, kɔɔ maan -tɛala o yra 'nan o drɛ wɩ a -wlidɩ.  
\v 8 'Ka 'bɔ, 'ka 'kʋ "fɛdi da. Ma'an 'koo "fɛdi 'labɛ -a da dɩ, kɔɔ 'mɛn tʋ 'ka tian bɔlɛ dɩ.»  
\v 9 E 'wɩ zɩɛ -a 'vɩ -wlɛ, ɛn e -fʋ Galile. 
\s1 Zozi 'kʋ "fɛdi da Zeruzalɛm 
\p  
\v 10 Zɩ Zozi "bʋɩnun -kʋ "fɛdi 'bɔ da bɛ, ɛn Zozi 'bɔ 'kʋla o -sru "mɛn. 'Pian ya'a 'yee -kʋdɩ -ci -tɛlɛ dɩ.  
\v 11 Zuif 'nɔn 'tanɔn -a -wɛɛdɩ 'sia minnun nɛn o -kʋ "fɛdi zɩɛ -a da bɛ o yei, te waa laabo -wlɔ 'nan: «-Vɛ -mie 'gʋɛ e ya nyin zia?» 
\p  
\v 12 Minnun wunwun "vɩdɩ 'sia fɛ zɩɛ -a -nan "kaga. Min -mienun -a ve 'nan: «E ya min tɩglɩ 'a.» 
\p Te -a -mienun "o "ve 'nan: «-Cɛjɛ! Min nɛn e min see "paaman bɛ -nyrɛn.»  
\v 13 'Pian min -tʋ 'ka 'wɩ 'bɔ zɩɛ -a vɩlɛ wei 'plɛblɛ 'ji dɩ, kɔɔ "klan a o ji Zuif 'nɔn 'tanɔn 'le "wɛan. 
\p  
\v 14 Zɩ "fɛdi drɛdɩ 'bɔ 'e yei "bɛ, Zozi 'kʋ Bali -pan 'kuin, ɛn e 'wɩ "paadɩ 'sia minnun ji.  
\v 15 -Yee 'wɩ "paadɩ Zuif 'nɔn 'tanɔn 'bɔ 'kan te waa ve 'nan: «Min 'labɛ ya'a drɛlɛ min -tʋ -sruzan 'a dɩ, e drɛ 'kɔ ɛn e 'wɩ nɛn 'e 'crɛn -tɛdɩ bɛ -a -tɔa zɩɛ.» 
\p  
\v 16 Ɛn Zozi "e 'nan -wlɛ 'nan: «'Wɩ nɛn maan "paaman minnun ji 'gʋɛ, ya'a 'sia 'an 'bɔ 'va dɩ, 'pian e "sia Bali nɛn yaan 'pa 'sia bɛ -a va.  
\v 17 Min nɛn e ya "vale 'e Bali zɩɛ -a ci 'sɔ wɩnun dra bɛ, -yɛɛ 'mɛn 'wɩ "paadɩ 'gʋɛ -a -tɔa. -Te Bali va nɛn e "sia oo, ɛn te 'an 'bɔ 'va nɛn e "sia oo, -a san 'bɛ -tɔa.  
\v 18 Min nɛn 'e 'bɔ 'wulo -ji wɩ "paaman minnun ji bɛ, te e ya 'e 'bɔ 'fli 'tɔ -wɛɛnan. 'Pian min nɛn e ya "vale 'nan min nɛn yee 'pa 'sia bɛ minnun 'o bɔ bɛ, -a san zɩɛ min tɩglɩ nɛn, ya'a 'wɩ 've 'wlu 'a dɩɛ, -nyrɛn.  
\v 19 Moizi -pei -tɔ wɩnun paa 'ka 'ji, 'pian 'ka pɛɛnɔn ka'a 'ta wʋla "da "dɩ. Ɛn ka ya "vale 'kaan -tɛa "nyian, -mɛ "le "wɛan?» 
\p  
\v 20 Minnun "kaga "bɛ waa 'vɩ -yrɛ 'nan: «Fɛ -wlidɩ "tʋ a 'i -sru. -Tɩɛ cɩ -a -wɛɛnan 'nan 'yei -tɛa?» 
\p  
\v 21 Zozi "e 'nan -wlɛ 'nan: «An 'lɛbo "fɔ wɩ -tʋwli drɛ 'gʋɛ, -a 'wɩ 'nan 'ka pɛɛnɔn man.  
\v 22 Moizi -a 'vɩ 'cɛɛ 'nan, 'ka 'nɛn 'fɔ -klɔnmɔn -va 'e -ya yi 'sɔra da. Ɛn -te yi 'sɔrazan zɩɛ e -tria 'flinla "yi da bɛ, kaa dra -kpɔ. -Pɛ -tʋ da zia bɛ, Moizi "cɛɛ -pei -trɔa dɩ, 'pian -a tranun -a dra 'e 'cɛn.  
\v 23 'Flinla "yi da bɛ ka 'nɛn -fɔa "klɔnmɔn -va, -e 'ka vɩlɛ 'ka Moizi -le -pei 'srɔɛn srɛ dɩ -le "wɛan. -Te 'bɛ a zɩɛ, -mɛ "le "wɛan 'bli 'fɔ 'ka 'ji 'an man 'nan, "an "blamin -munmuan beli 'flinla "yi da?  
\v 24 Ka min -le 'wɩ ve "ta lou. 'Cɛɛ 'le 'tɔ, 'ka 'wɩ 'fa 'si 'vaa -e 'ka min -le 'wɩ 'cɛn!» 
\s1 Min nɛn Bali -a 'si "va "bɛ -nyrɛn Zozi 'a 
\p  
\v 25 -A -nan nɛn Zeruzalɛm 'nɔn -mienun "o 'nan: «"Ka 'yiɔ, min nɛn o cɩ -a -wɛɛnan 'nan 'o -tɛa "bɛ -nyrɛn 'gʋ.  
\v 26 Ɛn -yɛɛ 'wɩ tin "baa minnun yei te wa'a 'wɩ tʋ ve -yrɛ "bɛ dɩ. Maan ye "le -kaa 'tanɔn -a -tɔ 'nan -yɛɛ cɩ min nɛn Bali -a 'si "va "bɛ -a.  
\v 27 'Pian min 'labɛ -cɛɛ 'sinan -tɔa. Min nɛn Bali -a 'si "va "bɛ -te 'bɛ 'ta bɛ, min -tʋ 'ka 'bɛ 'sinan 'tɔa dɩ.» 
\p  
\v 28 Tʋ zɩɛ -a wlu bɛ, te Zozi a 'wɩ "paanan minnun ji Bali -pan 'kuin, ɛn yaa 'vɩ wei 'plɛblɛ 'ji 'nan: «Kaa "nrɔnman 'ka 'ji 'nan, kaan -tɔa, ɛn -a -nan nɛn an 'si bɛ kaa -tɔa. 'Pian ma'an 'talɛ 'an 'bɔ 'fli -ji dɩ. Min nɛn yaan 'pa 'sia bɛ e ya tɩglɩ, ɛn ka'a min zɩɛ -a tɔa dɩ.  
\v 29 'Mɛn vɛ bɛ "an -tɔa, kɔɔ -a va nɛn an 'si, ɛn -yɛɛ 'an 'pa 'sia.» 
\p  
\v 30 -A -nan nɛn Zeruzalɛm 'nɔn zɩɛ o ya "vale 'o Zozi "kuan. 'Pian min -tʋ 'ka -kɔlalɛ -a 'kundɩ -a dɩ, kɔɔ -yee tʋ 'ka tian bɔlɛ dɩ.  
\v 31 Min -mienun "o "yi -tɛra Zozi 'bɔ da. Minnun zɩɛ o ya "kaga ɛn "o laabʋ 'nan: «Min nɛn Bali -a 'si "va "bɛ, yi nɛn e -ta bɛ, e -cɛ -srɔn "wɩ "kaga "dra e "mlian min 'labɛ -a da?» 
\p  
\v 32 Wunwun "nɛn minnun cɩ -a vɩnan Zozi man bɛ, Farizɛn 'nɔn -a 'man. -A -nan nɛn 'o 'vale Bali -pannɔn 'tanɔn 'a o minnun 'pa 'sia 'nan 'o 'kun. 
\p  
\v 33 Ɛn Zozi "e 'nan -wlɛ 'nan: «An "flian tian 'ka yei tʋ "wɛnnɛn 'a, "bɛ -sru -e 'an li 'an da min nɛn yaan 'pa 'sia bɛ -a va.  
\v 34 Ka -taa 'an -wɛɛlɛ, 'pian ka'a 'kɔlaman 'an yɩdɩ -a dɩ. Ɛn fɛnan nɛn an -kɔan "bɛ, ka'a 'kɔlaman -e 'ka 'kʋ -nan dɩ.» 
\p  
\v 35 Ɛn Zuif 'nɔn 'tanɔn -a laabʋ 'o cin lɔ 'nan: «Nyin zia nɛn e -taa "kʋlɛ -e -kaa vɩlɛ -kaa yɩ dɩ? E -ko Zuif 'nɔn nɛn 'o fuiladɩ "man 'trɛda bɛ o va, -e 'e 'wɩ "paa minnun nɛn o 'ka Zuif 'nɔn 'a dɩɛ o ji?  
\v 36 'Wɩ nɛn yaa 'vɩ 'labɛ -a -ci nɛn 'nɔn? Kɔɔ yaa 'vɩ 'nan: ‹Ka -taa 'an -wɛɛlɛ, 'pian ka'a 'kɔlaman 'an yɩdɩ -a dɩ.› Ɛn: ‹Fɛnan nɛn an -kɔan "bɛ, ka'a 'kɔlaman -e 'ka 'kʋ -nan dɩ.› » 
\p  
\v 37 "Fɛdi yi -nyranman da nɛn, -yɛɛ cɩ yi -dan 'bɔ 'a. Yi zɩɛ -a da nɛn Zozi a minnun yei 'e 'tɔdɩ, ɛn yaa 'vɩ wei 'plɛblɛ 'ji 'nan: «Min nɛn 'yi dra -a -tɛa "bɛ, -a san 'e 'ta 'an 'va -e 'e 'yi 'mlin.  
\v 38 Min nɛn e yi -tɛra 'an da bɛ, -a san -kɔan "le 'yi ku nɛn e 'belidɩ -nɔan "min lɛ bɛ -yee 'wɩ 'zʋ. Zɩ e cɩ 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji zɩɛ.»  
\v 39 Lei 'saun nɛn minnun nɛn o yi -tɛra Zozi da o -taa -a yɩlɛ bɛ, -yee 'wɩ nɛn Zozi 'bɔ cɩ -a vɩnan. Tʋ zɩɛ -a man bɛ, te Bali lei 'saun 'ka tian 'talɛ dɩ, kɔɔ Zozi 'ka tian 'kʋlɛ 'e "tɩ "le mingɔnnɛn trɛ nɛn e "bia bɛ -a da dɩ. 
\p  
\v 40 Zɩ min "kaga 'wɩ zɩɛ -a 'man bɛ, ɛn o -mienun -a 'vɩ 'nan: «Min 'labɛ, 'wɩ 'kpa e ya Bali 'lewei vɩzan nɛn o 'nan e -taa "bɛ -a.» 
\p  
\v 41 Min plɔɛnnun "o 'vɩ 'nan: «Min 'labɛ, min nɛn Bali -a 'si "va "bɛ -nyrɛn.» Ɛn min peenun "o 'vɩ 'nan: «Min nɛn Bali -a 'si "va "bɛ ya'a 'kɔlaman -e 'e 'si Galile dɩ.  
\v 42 Kɔɔ e ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan, min nɛn Bali -a 'si "va "bɛ, e -kɔan David kluda min -a, ɛn e "sia Bɛtelɛm, David -ya trɛ -da.» 
\p  
\v 43 Zozi 'le "wɛan, -sa -fɔla minnun "kaga zɩɛ o yei.  
\v 44 Ɛn o va min -mienun a "vale 'o "kuan, 'pian min -tʋ 'ka -kɔlalɛ -a 'kundɩ -a dɩ. 
\s1 Zuif 'nɔn 'tanɔn 'ka yi -tɛlɛa Zozi da dɩ 
\p  
\v 45 -A -nan nɛn minnun nɛn Bali -pannɔn 'tanɔn 'lee Farizɛn 'nɔn o 'pa 'sia bɛ o 'li 'o da o 'va. Ɛn Bali -pannɔn 'tanɔn 'lee Farizɛn 'nɔn -a laabʋ -wlɔ 'nan: «-Mɛ "le "wɛan nɛn ka'a 'kunlɛ -e 'ka 'ta -a dɩ?» 
\p  
\v 46 Ɛn 'pa 'sianɔn "o -wlɛ 'nan: «'Wɩ nɛn yaa ve bɛ, min -tʋ 'ka tian 'li -a vɩlɛ 'mlɔnmlɔn dɩ.» 
\p  
\v 47 Ɛn Farizɛn 'nɔn "o 'nan: «'Ka 'bɔ "nyian, maan ye "le -yee 'wɩ 'ka 'sia 'nan.  
\v 48 -Kaa Farizɛn 'nɔn -ka'a tɔlɛ -a -sru "dɩ, ɛn -kaa tazan -tʋ 'ka 'tɔlɛ -a -sru "dɩ.  
\v 49 'Pian minnun nɛn wa'a Moizi -le -pei -tɔ wɩ tɔa dɩ, ɛn Bali wei a 'e 'pladɩ o man bɛ, o 'saza 'bɛ -tɔa -a -sru.» 
\p  
\v 50 Nikodɛm nɛn e -kʋ Zozi 'man yɩlɛ 'e tɛdɛ bɛ, e ya Farizɛn 'nɔn 'bɔ 'va. Ɛn yaa 'vɩ Farizɛn 'nɔn zɩɛ -wlɛ 'nan:  
\v 51 «-Cee -pei "e 'nan, -te wa'a tian min -le tin 'balɛ dɩɛ, wa'a 'wɩ 'tɔa -a san man dɩ. 'Pian -te min 'wɩ drɛ bɛ, waa wei maan 'vaa, ɛn o 'wɩ -tɔa "man.» 
\p  
\v 52 Ɛn Farizɛn 'nɔn -a laabʋ -yrɔ 'nan: «Galile min nɛn "nyian "yie "a? 'I -nanjɛn Bali -le 'fluba 'ji 'kpa tɩglɩ -e 'i -tɔ 'nan Bali 'lewei vɩzan 'ka 'li 'sia Galile dɩ.» 
\s1 -Kɔnnɛn -wɛɛzan 'tʋ -le 'wɩ 
\p  
\v 53 ["Bɛ -sru ɛn o pɛɛnɔn 'kʋ 'wee "kɔnnɛn. 
\c 8  
\p  
\v 1 -A -nan nɛn Zozi 'kʋ Olivie pɔn da.  
\v 2 -A ta tʋ cɛɛn, bodrun puunɔn ɛn Zozi 'li 'e da Bali -pan 'kuin. Tɔɔn min "kaga "kʋ "va. Zozi -nyran, ɛn e 'wɩ "paadɩ 'sia o ji.  
\v 3 -A -nan nɛn 'fluba 'ci vɩnɔn 'lee Farizɛn 'nɔn 'ta lɩmɔn -tʋ -a, ɛn waa -tɔ minnun yei. Lɩ zɩɛ o 'bɔ "man, te e ya nyinnan -kɔnnɛn -sru.  
\v 4 Ɛn o 'nan Zozi lɛ 'nan: «Bali -le 'wɩ "paazan, lɩ 'gʋɛ, kʋ 'bɔ "man te e ya nyinnan -kɔnnɛn -sru.  
\v 5 Moizi -a crɛn -tɛ -pei 'fluba 'ji 'nan lɩmɔn nɛn e 'wɩ zɩɛ -a drɛ bɛ, 'o -tɛ -kɔlɛ -a. Bii "nun "i 'vɩ 'nɔn?»  
\v 6 O 'wɩ zɩɛ -a laabʋ 'nan -e 'o wei 'kun, -e 'o -kɔla 'wɩ 'tɔdɩ -a "man. 
\p 'Pian Zozi 'kunnan, ɛn e fɛ -tʋ crɛn -tɛdɩ 'sia 'e 'pɛ 'wlɛ 'a 'trɛ da,  
\v 7 te Farizɛn 'nɔn 'lee 'fluba 'ci vɩnɔn 'wɩ laabo Zozi 'lɔ. O ya 'wɩ laabʋnan Zozi 'lɔ "bʋʋ "le "wɛan, 'e 'wulo wluan, ɛn e 'nan -wlɛ 'nan: «Min nɛn 'ka yei, te ya'a tian 'wɩ 'wlidɩ "drɛlɛ dɩɛ, -a san 'e -kɔlɛ tɛdɛ tuʋ -yrɛ.»  
\v 8 E 'kunnan "nyian 'e "pa 'ji, ɛn yaa crɛn -tɛdɩ 'sia "nyian 'trɛ da. 
\p  
\v 9 Zɩ Farizɛn 'nɔn 'lee 'fluba 'ci vɩnɔn 'bɔ 'wɩ zɩɛ -a 'man bɛ, ɛn o pɛɛnɔn 'kʋ -tʋdʋ. Min cejenun 'bɛ 'kʋdɩ 'sia 'e 'flin. 
\p -A -nan nɛn lɩ bɛ e -fʋ 'e 'tɔdɩ Zozi 'lɛ 'e -tʋwli minnun yei.  
\v 10 Zozi 'e 'wulo wluan, ɛn yaa laabʋ -yrɔ 'nan: «Minnun nɛn o 'wɩ 'tɔ 'i man bɛ, o ya nyin zia? Min -tʋ 'ka "nyian -nan -e 'e 'wɩ 'tɔ 'i man dʋʋ?» 
\p  
\v 11 Ɛn lɩ zɩɛ e 'nan Zozi lɛ 'nan: «'An 'san, min -tʋ 'ka "nyian -nan dɩ.» 
\p Zozi "e -yrɛ 'nan: «'An 'bɔ "nyian, ma'an 'wɩ tɔa 'i man dɩ. 'I 'kʋ! Te 'i 'wɩ 'wlidɩ "drɛ "nyian dɩ!»] 
\s1 Zozi 'bɛ cɩ 'tɛ 'san nɛn e 'trɛdanɔn man dra 'wein bɛ -a 
\p  
\v 12 Tʋ pee -a bɛ, ɛn Zozi 'wɩ tin 'badɩ 'sia "nyian minnun lɛ. Yaa 'vɩ -wlɛ 'nan: «'An 'bɔ 'bɛ cɩ 'tɛ 'san nɛn e 'trɛdanɔn 'man dra 'wein bɛ -a. Min nɛn e sɔɔnla 'an -sru "bɛ, te ya'a "nyian 'ta wo klun va dɩ, ɛn 'tɛ 'san nɛn e 'belidɩ -nɔan "min lɛ bɛ e ya -a san -le vɛ -a.» 
\p  
\v 13 Ɛn Farizɛn 'nɔn -a 'vɩ Zozi lɛ 'nan: «'Wɩ nɛn yia ve bɛ, e 'ka 'wɩ 'kpa 'a dɩ, kɔɔ yiɛ cɩ -a vɩnan 'i 'fli man.» 
\p  
\v 14 Zozi -a 'vɩ -wlɛ 'nan: «-Te 'an 'bɔ mɛɛn cɩ 'an 'bɔ 'fli -le 'wɩ vɩnan oo, 'wɩ nɛn maan ve 'gʋɛ, 'wɩ 'kpa nɛn. Kɔɔ fɛnan nɛn an 'si bɛ, maan -tɔa. Ɛn fɛnan nɛn an cɩ -kʋnan bɛ, maan -tɔa. 'Pian 'cee vɛ bɛ, fɛnan nɛn an "sia bɛ, ka'a -nan tɔa dɩ, ɛn fɛnan nɛn an cɩ -kʋnan bɛ, ka'a -nan tɔa dɩ.  
\v 15 "Ka "tin -tɛa "min da blamin -wulo -ji wɩ yra man. 'An 'bɔ 'le vɛ bɛ, ma'an tin tɛa min da dɩ.  
\v 16 'Pian -te an tin -tɛ min da bɛ, e ya 'e 'nɔan da. Kɔɔ an 'ka 'an -tʋwli "dɩ, 'kʋ 'vale 'an "tɩ "nɛn yaan 'pa 'sia bɛ -a kʋɛ cɩ.  
\v 17 E ya 'e 'crɛn -tɛdɩ 'cee -pei 'fluba 'ji 'nan: ‹-Te min "fli "wei a -tʋwli 'wɩ 'tʋ da bɛ, te 'wɩ zɩɛ e ya 'wɩ 'kpa -a.›  
\v 18 'An 'bɔ 'an 'fli -le 'wɩ ve, ɛn 'an "tɩ "nɛn yaan 'pa 'sia bɛ, e 'mɛn 'wɩ ve.» 
\p  
\v 19 Ɛn waa laabʋ -yrɔ 'nan: «'I "tɩ 'bɔ a nyin zia?» 
\p Zozi "e -wlɛ 'nan: «Ka'an tɔa dɩ, ɛn ka'an "tɩ tɔa dɩ. "Te kaan -tɔa "bɛ, "te kaan "tɩ -tɔa "nyian.» 
\p  
\v 20 Zozi a 'wɩ zɩɛ -a "paanan minnun ji, te e ya Bali -pan 'kuin, fɛnan nɛn minnun "lala -sɛan -gbogbo -ji Bali -le vɛ -a bɛ -a -nan. Ɛn min -tʋ 'ka -a 'kunlɛ dɩ, kɔɔ -yee tʋ 'ka tian bɔlɛ dɩ. 
\s1 Zozi 'e "tɩ "srɔn "kʋdɩ -nan wɩ 'vɩ 
\p  
\v 21 Zozi -a 'vɩ "nyian -wlɛ 'nan: «An "ta -ko. Ka -taa 'an -wɛɛlɛ, 'pian ka'an 'ye dɩ. Ɛn 'cee 'wɩ 'wlidɩ "fo 'ka 'lɔ -e 'ka 'ka. Fɛnan nɛn an "ta -ko 'gʋɛ, ka'a 'kɔlaman -e 'ka 'kʋ -nan dɩ.» 
\p  
\v 22 Ɛn Zuif 'nɔn 'tanɔn -a laabʋ 'o 'fli -lɔ 'nan: «E "ta -ko 'e 'fli -tɛlɛ -baalɛ, kɔɔ yaa 'vɩ 'nan, fɛnan nɛn 'e "ta -ko bɛ, -ka'a 'kɔlaman -e -kaa kʋ -nan dɩ.» 
\p  
\v 23 Ɛn e 'nan -wlɛ 'nan: «'Trɛ 'gʋɛ -a da 'nɔn nɛn "cee "a. "Ka 'si wo 'trɛda 'gʋ, 'pian "an 'si wo laji lou. Ma'an 'sia 'trɛda 'gʋ dɩ.  
\v 24 -Yee "wɛan maan 'vɩ 'cɛɛ 'nan, 'cee 'wɩ 'wlidɩ "fo 'ka 'lɔ -e 'ka 'ka. Kɔɔ min nɛn an cɩ -a bɛ, -te ka'a yi 'tɛala "da 'nan an ya min zɩɛ -a dɩɛ, 'cee 'wɩ 'wlidɩ "fo 'ka 'lɔ -e 'ka 'ka.» 
\p  
\v 25 Ɛn waa laabʋ Zozi 'lɔ 'nan: «-Tɩ nɛn 'yia?» 
\p Zozi -a 'vɩ -wlɛ 'nan: «Min nɛn an cɩ -a bɛ, maan ve 'cɛɛ, te maan ve.  
\v 26 'Wɩ "kaga "a -e 'an vɩ 'ka man -e tin 'e 'tɛ 'ka da. 'Pian 'wɩ nɛn maan 'man min nɛn yaan 'pa 'sia bɛ -a da bɛ, -nyrɛn maan ve 'trɛdanɔn lɛ. Min zɩɛ ya'a 'wɩ 've 'wlu 'a dɩ.» 
\p  
\v 27 Wa'a -ci manlɛ "le 'nan -a "tɩ "le 'wɩ nɛn e cɩ -a vɩnan dɩ.  
\v 28 Ɛn Zozi -a 'vɩ -wlɛ 'nan: «Tʋ nɛn ka Blamin -pɩ "paa yiba "man lou "bɛ, -a tʋ zɩɛ -a man nɛn kaa -tɔa 'nan min nɛn an cɩ -a bɛ -nyrɛn 'maan. Ɛn kaa -tɔa 'nan ma'an 'wɩ 'dra 'an 'bɔ 'fli -ji dɩ, 'pian 'wɩ nɛn maan 'man 'an "tɩ "da bɛ -nyrɛn maan ve.  
\v 29 Min nɛn yaan 'pa 'sia bɛ, 'kʋ 'vale -a kʋɛ cɩ. Ya'an 'tʋɩlɛ 'an -tʋwli "dɩ, kɔɔ -a ci 'sɔ wɩnun nɛn maan dra tʋ pɛɛnɔn man.»  
\v 30 Zɩ Zozi 'wɩnun zɩɛ -a 'vɩ bɛ, ɛn min "kaga yi -tɛra Zozi 'bɔ da. 
\s1 Min nɛn e 'wɩ 'wlidɩ "dra bɛ, te e ya 'wɩ 'wlidɩ "le nɔan -a 
\p  
\v 31 -A -nan nɛn Zuif 'nɔn nɛn o yi -tɛra Zozi 'bɔ da bɛ, Zozi -a 'vɩ -wlɛ 'nan: «-Te 'ka 'ta 'wʋla 'an wei da 'kpa bɛ, te ka ya 'an -srunɔn 'a.  
\v 32 Ka -taa 'wɩ tɩglɩ 'tɔlɛ, -e 'wɩ tɩglɩ 'e 'ka drɛ minnun nɛn o 'ka nɔan -a dɩɛ waa.» 
\p  
\v 33 Ɛn Zuif 'nɔn 'bɔ -a 'vɩ -yrɛ 'nan: «Kʋ ya Abraam kluda 'nɔn 'a, ɛn kʋ'a tian 'li drɛlɛ min -tʋ -le nɔan -a dɩ. -Mɛ "le "wɛan nɛn yia ve 'nan: ‹Kʋ dra minnun nɛn o 'ka nɔan -a dɩɛ waa?› » 
\p  
\v 34 Ɛn Zozi -a 'vɩ -wlɛ 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, min oo min nɛn e 'wɩ 'wlidɩ "dra bɛ, te e ya 'wɩ 'wlidɩ "le nɔan -a.  
\v 35 Nɔan 'ka 'fo "kɔnnɛn 'li 'trilii dɩ, 'pian 'nɛn nɛn e cɩ 'yee vɛ -nan bɛ, -yɛɛ fo "kɔnnɛn 'li 'trilii.  
\v 36 -Te 'an 'bɔ Bali -pɩ an 'ka 'si nɔanba -ji bɛ, ka'a 'kɔan "nyian fɛ -tʋ -lɔ nɔan -a dɩ. 
\p  
\v 37 Maan -tɔa 'nan ka ya Abraam kluda 'nɔn 'a, 'pian ka ya -a -wɛɛnan 'nan 'kaan -tɛa, kɔɔ ka 'ka "vale 'ka 'ta wʋla 'mɛn 'wɩ "paadɩ da dɩ.  
\v 38 'Wɩ nɛn maan -nan 'yɩ 'an "tɩ 'lɔ bɛ, -nyrɛn maan ve, ɛn 'cee vɛ bɛ, 'wɩ nɛn kaa 'man 'ka "tɩ "da bɛ, -nyrɛn kaa dra.» 
\p  
\v 39 Ɛn o 'nan Zozi lɛ 'nan: «Abraam 'bɛ cɩ 'kʋ "tɩ "a.» 
\p Ɛn Zozi "e 'nan -wlɛ 'nan: «"Te Abraam -le 'nɛnnun nɛn 'kaa bɛ, "te Abraam drɛ wɩ nɛn kaa dra.  
\v 40 'Wɩ tɩglɩ nɛn maan 'man Bali da bɛ, maan ve 'cɛɛ tʋ pɛɛnɔn man. 'Pian 'bɛ nɛn 'gʋɛ, ka ya -a -wɛɛnan 'nan 'kaan -tɛa. 'Wɩ zɩɛ Abraam 'ka 'bɛ drɛlɛ dɩ.  
\v 41 'Pian 'cee vɛ bɛ, 'ka "tɩ "drɛ wɩ nɛn kaa dra.» 
\p Ɛn o 'nan Zozi lɛ 'nan: «Bɔɛda nɛn "cɛɛ 'kʋa dɩ, Bali -tʋwli 'bɛ cɩ 'kʋ "tɩ "a.» 
\p  
\v 42 Ɛn Zozi "e 'nan -wlɛ 'nan: «"Te Bali 'bɛ cɩ 'ka "tɩ "a bɛ, "te kaan ye "yi. Kɔɔ Bali va nɛn an 'si, ɛn an -ta. Ma'an 'talɛ 'an 'bɔ 'fli -ji dɩ, 'pian -yɛɛ 'an 'pa 'sia.  
\v 43 Ka 'ka "vale 'ka "trɔɛn -tɔa 'an wei lɛ dɩ, -yee "wɛan nɛn ka'an wei -ci maan dɩ?  
\v 44 Satan nɛn e 'wɩ 'wlidɩ "paa min lɔ bɛ, -yɛɛ cɩ 'ka "tɩ "a, ɛn 'ka "tɩ 'ci 'sɔ wɩnun nɛn kaa dra. -A pou sianan 'li 'trilii -e 'e bɔ cɛɛgʋɛ, min -tɛzan nɛn. Ya'a 'ta wʋla 'wɩ tɩglɩ da 'mlɔnmlɔn dɩ, kɔɔ ya'a 'tɔa 'wɩ tɩglɩ -sru "dɩ. 'Wlu 'sɛndɩ -cin nɛn "ji, kɔɔ 'wluzan nɛn, ɛn -a va nɛn 'wlu wɩ pɛɛnɔn "sia.  
\v 45 'Mɛn vɛ bɛ, an 'wɩ tɩglɩ ve, -yee "wɛan ka'a yi 'tɛala 'an da dɩ.  
\v 46 Min -tʋ 'ka 'ka yei -e 'e -ci -kɔɔn 'nan an 'wɩ 'wlidɩ drɛ dɩ. Ɛn -te 'wɩ tɩglɩ nɛn maan ve bɛ, -mɛ "le "wɛan ka'a yi 'tɛala 'an da dɩ?  
\v 47 Min nɛn Bali cɩ -a "tɩ "a bɛ, 'wɩ nɛn Bali -a ve bɛ 'e "trɔɛn -tɔa -yrɛ. 'Pian 'cee vɛ bɛ, Bali "cɛɛ 'ka "tɩ "a dɩ -yee "wɛan ka'a "trɔɛn 'tɔa -a wei lɛ dɩ.» 
\s1 Zozi -dan "mlian Abraam da 
\p  
\v 48 Zuif 'nɔn 'tanɔn "e Zozi lɛ 'nan: «'Kʋe tin a 'nɔnnɔn -a vɩdɩ -a 'nan Samari min nɛn yia, ɛn -yʋ -wlidɩ "a 'i -sru.» 
\p  
\v 49 Zozi -a 'vɩ -wlɛ 'nan: «-Yʋ -wlidɩ 'ka 'an -sru "dɩ. 'An "tɩ "nɛn maan 'tɔ dra -dan, ɛn 'cee vɛ bɛ, "kaan 'tɔ srɛman.  
\v 50 'An 'bɔ an 'ka -a -wɛɛnan 'nan min 'e 'an 'tɔ drɛ -dan dɩ. 'Pian min -tʋ 'bɛ cɩ -a -wɛɛnan. Ɛn -a min zɩɛ, -yɛɛ 'cee tin "baa.  
\v 51 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan min nɛn e 'ta 'wʋla 'an wei da bɛ, -a san 'ka 'kaa 'mlɔnmlɔn dɩ.» 
\p  
\v 52 Ɛn Zuif 'nɔn -a 'vɩ -yrɛ 'nan: «Kʋa -tɔ "mɛn 'nan -yʋ -wlidɩ "a 'i -sru. Abraam -ka, ɛn Bali 'lewei vɩnɔn "o "ka 'wʋ "nyian. -E 'i vɩ 'nan: ‹Min nɛn e 'ta 'wʋla 'i wei da bɛ, -a san 'ka 'kaa 'mlɔnmlɔn dɩ.›  
\v 53 'Kʋ tra Abraam -ka, ɛn Bali 'lewei vɩnɔn "o "ka 'wʋ "nyian. 'I -dan "mlian Abraam da? 'I 'bɔ 'i 'fli "siala 'kɔ?» 
\p  
\v 54 Ɛn Zozi "e 'nan -wlɛ 'nan: «-Te 'an 'bɔ mɛɛn 'an 'fli 'tɔ dra -dan bɛ, 'mɛn 'tɔ -dan zɩɛ, e ya 'wɩ "tun "a. 'An "tɩ 'bɔ 'bɛ 'an 'tɔ dra -dan. 'Ka 'bɔ cɛɛ 'vɩ 'nan -yɛɛ cɩ 'cee Bali -a,  
\v 55 'pian ka'a tɔa dɩ. 'An 'bɔ 'bɛ -tɔa. -Te maan 'vɩ 'nan ma'an tɔa dɩɛ, te an drɛ 'wluzan 'a "le 'cee 'wɩ 'zʋ. 'Pian maan -tɔa, ɛn an 'ta 'wʋla -a wei da.  
\v 56 Tʋ nɛn an -taa "man 'trɛda bɛ, Bali -a 'vɩ 'ka tra Abraam lɛ. 'Wɩ zɩɛ e Abraam ci -ta "tra. Abraam -a -nan 'yɩ, ɛn yaa ci nran.» 
\p  
\v 57 Ɛn Zuif 'nɔn -a vɩ Zozi lɛ 'nan: «'I lɛ -fuba 'soolu 'ka 'bɔa dɩ -e 'i Abraam yɩ?» 
\p  
\v 58 Zozi -a 'vɩ -wlɛ 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, tʋ nɛn te wa'a tian Abraam -yalɛ dɩɛ, te an ya.»  
\v 59 'Wɩ zɩɛ -a da nɛn o -kɔlɛ siila 'nan -e 'o Zozi 'tɛ -a. 'Pian Zozi yɔɔ, ɛn e 'bɔla Bali -pan 'kuin. 
\c 9  
\s1 Zozi yiɛ 'wizan -tʋ beli 
\p  
\v 1 Zozi a ciɩnan ɛn e min -tʋ nɛn waa -ya 'e yiɛ 'a 'e 'widɩ bɛ -a 'yɩ.  
\v 2 Ɛn Zozi -srunɔn 'a laabʋ Zozi 'lɔ 'nan: «Bali -le 'wɩ "paazan, -mɛ "le "wɛan nɛn o min 'gʋɛ -a -ya 'e yiɛ 'a 'e 'widɩ? -A 'bɔ 'le 'wɩ 'wlidɩ "man nɛn, -baa -a "tɩ 'lee -a "bʋ "le 'wɩ 'wlidɩ "man nɛn?» 
\p  
\v 3 Ɛn Zozi "e -wlɛ 'nan: «Wa'a vɩlɛ 'nan -a 'bɔ 'le 'wɩ 'wlidɩ "man nɛn dɩ, ɛn -te 'bɛ "cɛɛ dɩ, -a "tɩ 'lee -a "bʋ "le 'wɩ 'wlidɩ "man nɛn -a yiɛ 'wi dɩ. 'Pian -a yiɛ 'wi 'nan -e minnun 'o 'wɩ -dan nɛn Bali "ta -daa -a drɛlɛ -yrɛ "bɛ -a -nan yɩ.  
\v 4 'Bɛ nɛn tʋ a tian 'e 'cɛndɩ 'gʋɛ, min nɛn yaan 'pa 'sia bɛ, -kaa -yee 'nyranman 'pa. -Pei -taa "tanlɛ, te min -tʋ 'ka 'kɔlaman -e 'e 'nyranman 'pa "nyian dɩ.  
\v 5 'Bɛ nɛn an ya tian 'trɛda 'gʋɛ, mɛɛn cɩ 'tɛ 'san nɛn e 'trɛdanɔn 'man dra 'wein bɛ -a.» 
\p  
\v 6 Zɩ Zozi cɛɛn 'wɩ zɩɛ -a vɩdɩ man bɛ, ɛn 'e 'le 'yi -sran "tra. E -feli drɛ 'e 'le 'yi 'bɔ 'a, yaa ciɩ yiɛ 'wizan zɩɛ -a yiɛ da,  
\v 7 Ɛn e 'nan -yrɛ 'nan: «'I 'kʋ 'i yra "foe 'yi nɛn waa laabo Siloe bɛ -a va.» Siloe -ci nɛn 'nan 'padɩ -sia. E -kʋ 'e yra foe, ɛn e 'li 'e da te e fɛnan ye 'wein. 
\p  
\v 8 Yiɛ 'wizan zɩɛ -a "srɔn 'nɔn 'lee minnun nɛn waa 'yɩ te e fɛ trʋ "baa bɛ, "o laabʋ 'nan: «Min nɛn "nɛn e -nyɛanla 'gʋ te e fɛ trʋ "baa bɛ, -njɛɛ bɛ dʋʋ?»  
\v 9 Min -mienun "o 'vɩ 'nan: «-A 'bɔ nɛn.» 
\p Min plɔɛnnun "o 'vɩ 'nan: «-A 'bɔ "cɛɛ dɩ, 'pian -a siazan "nɛn.» 
\p Ɛn -a 'bɔ "e 'nan: «'Wɩ 'kpa, 'e 'bɔ nɛn.» 
\p  
\v 10 -A -nan nɛn waa laabʋ -yrɔ 'nan: «E drɛ 'kɔ ɛn 'i yiɛ 'lɛ 'sʋ?» 
\p  
\v 11 Ɛn e 'nan -wlɛ 'nan: «Min nɛn waa laabo Zozi bɛ, e -feli drɛ, yaa ciɩ 'an yiɛ da, ɛn e 'mɛn 'nan 'an 'kʋ 'an yra "foe Siloe 'yi 'va. An -kʋ -nan nun, zɩ 'an yra foe bɛ, ɛn 'an yiɛ 'lɛ 'sʋ.» 
\p  
\v 12 Ɛn waa laabʋ -yrɔ 'nan: «Min 'bɔ -a nyin zia?» 
\p E 'nan -wlɛ 'nan: «Ma'an 'tɔa dɩ.» 
\s1 Farizɛn 'nɔn 'wɩ laabʋ min nɛn -a yiɛ 'lɛ 'sʋ bɛ -yrɔ 
\p  
\v 13 O -kʋ min nɛn -a yiɛ 'lɛ 'sʋ bɛ -a Farizɛn 'nɔn 'va.  
\v 14 'Flinla "yi da nɛn Zozi 'feli drɛ, ɛn e min zɩɛ -a yiɛ 'lɛ 'sʋ 'a.  
\v 15 Farizɛn 'nɔn "o laabʋ "nyian min bɛ -yrɔ 'nan: «E drɛ 'kɔ ɛn 'i yiɛ 'lɛ 'sʋ?» 
\p Ɛn e 'nan -wlɛ 'nan: «E -feli ciɩ 'an yiɛ da, 'an yra foe, ɛn an fɛnan 'yɩ.»  
\v 16 Zɩ e 'wɩ zɩɛ -a 'vɩ bɛ, ɛn Farizɛn 'nɔn -mienun "o 'nan: «Min nɛn e 'wɩ 'labɛ -a drɛ bɛ, ya'a 'sia Bali va dɩ, kɔɔ e 'flinla "yi 'srɔɛn srɛ.» 
\p Te min plɔɛnnun "o "ve 'nan: «'Wɩ 'wlidɩ "drɛzan 'ka 'kɔlaman -e 'e 'cɛ -srɔn "wɩ zɩɛ -a drɛ dɩ.» 
\p -A -nan nɛn o wei 'ka "nyian drɛlɛ -tʋwli "dɩ.  
\v 17 Waa laabʋ min nɛn -a yiɛ 'lɛ 'sʋ bɛ -yrɔ 'nan: «'I 'bɔ "i "ve min nɛn yei yiɛ 'lɛ 'sʋ bɛ -a man 'nɔn?» 
\p Ɛn e 'nan -wlɛ 'nan: «Bali 'lewei vɩnan nɛn.» 
\p  
\v 18 Zuif 'nɔn 'tanɔn 'ka yi -tɛlɛa "da 'nan min zɩɛ -a yiɛ a 'e 'widɩ 'e 'cɛn dɩ. Ɛn waa "tɩ 'lee -a "bʋ laabʋ.  
\v 19 Zɩ o -ta bɛ, ɛn waa laabʋ -wlɔ 'nan: «'Cee 'nɛn nɛn ka 'nan waa -ya 'e yiɛ 'a 'e 'widɩ bɛ -nyrɛn 'gʋ? E drɛ "mɛn 'kɔ, ɛn -a yiɛ 'lɛ 'sʋ 'siɛn?» 
\p  
\v 20 -A "tɩ 'lee -a "bʋ "o 'nan: «Kʋa -tɔa 'nan 'kʋe 'nɛn nɛn, ɛn kʋa -ya te -a yiɛ a 'e 'widɩ.  
\v 21 'Pian fɛ nɛn e drɛ 'lɔɔ ɛn -a yiɛ 'lɛ 'sʋ 'siɛn 'gʋɛ, kʋ'a tɔa dɩ. Ɛn min 'bɔ nɛn yaa yiɛ 'lɛ 'sʋ bɛ, kʋ'a 'bɛ 'tɔa "nyian dɩ. 'Ka 'wɩ laabʋ -a 'bɔ 'lɔ, e ya ceje -e 'e -ci vɩ 'e 'bɔ 'a.»  
\v 22 -A "tɩ 'lee -a "bʋ "klanman Zuif 'nɔn 'tanɔn 'lɔ -yee "wɛan o 'wɩ zɩɛ -a 'vɩ. Kɔɔ Zuif 'nɔn 'o 'ci 'pa 'nan, min oo min nɛn yaa 'vɩ 'nan, Zozi 'bɛ cɩ min 'sizan 'wɩ 'ji Crizi -a bɛ, 'o -pian 'wee cin yɩ 'kuin.  
\v 23 -Yee "wɛan -a "tɩ 'lee -a "bʋ -a 'vɩ 'nan: «E ya ceje 'ka 'wɩ laabʋ -a 'bɔ 'lɔ.» 
\p  
\v 24 -A -nan nɛn min nɛn -a yiɛ 'lɛ 'sʋ bɛ, Farizɛn 'nɔn -a 'pa "flizan laabʋ "nyian, ɛn o 'nan -yrɛ 'nan: «'I Bali 'tɔ drɛ -dan 'wɩ tɩglɩ vɩdɩ -a! Kʋa -tɔa 'nan min bɛ 'wɩ 'wlidɩ "drɛzan nɛn.» 
\p  
\v 25 Ɛn e 'nan -wlɛ 'nan: «-Te e ya 'wɩ 'wlidɩ "drɛzan -a bɛ, ma'an tɔa dɩ. Maan -tɔa 'pian 'nan, 'an yiɛ a "nɛn 'e 'widɩ ɛn 'bɛ nɛn 'gʋɛ, an fɛnan ye 'siɛn.» 
\p  
\v 26 Waa laabʋ -yrɔ "nyian 'nan: «-Mɛ "nɛn yaa drɛ 'yiɛ? Yaa drɛ 'kɔ ɛn yei yiɛ 'lɛ 'sʋ?» 
\p  
\v 27 Ɛn e 'nan -wlɛ 'nan: «Maan 'vɩ 'cɛɛ 'va ɛn ka'a "trɔɛn "tɔlɛ -yrɛ "dɩ. -Mɛ "le "wɛan ka ya "nyian -a mandɩ va? "Ka "ya wo "nyian "vale 'ka dra -a -srunɔn 'a?» 
\p  
\v 28 -A -nan nɛn waa "srɔndɩ 'sia, ɛn o 'nan -yrɛ 'nan: «'I 'bɔ 'bɛ cɩ -a -sruzan 'a, "kʋ "ya wo Moizi -srunɔn 'a.  
\v 29 Kʋa -tɔa 'nan Bali 'wɩ tin 'ba Moizi lɛ, 'pian min 'labɛ, kʋ'a 'bɛ 'sinan 'tɔa dɩ.» 
\p  
\v 30 Ɛn min nɛn -a yiɛ 'lɛ 'sʋ bɛ, yaa 'vɩ -wlɛ 'nan: «"Ka 'yiɔ 'wɩ 'a bɛ, fɛnan nɛn e 'si bɛ, ka'a tɔa dɩ, ɛn yaan yiɛ 'lɛ 'sʋ!  
\v 31 -Kaa -ci -tɔa 'nan Bali 'ka 'wɩ 'wlidɩ "drɛnɔn wei maan dɩ. 'Pian -te min Bali bɔa ɛn yaa ci 'sɔ wɩnun dra bɛ, min zɩɛ Bali -a wei maan.  
\v 32 Ɛn ka'a tian 'li -a manlɛ 'nan min nɛn waa -ya 'e yiɛ 'a 'e 'widɩ bɛ, min -tʋ -a yiɛ 'lɛ 'sʋ dɩ.  
\v 33 "Te min 'bɛ ya'a 'silɛ Bali va dɩɛ, "te ya'a -kɔlalɛ -a drɛdɩ -a dɩ.» 
\p  
\v 34 Ɛn waa 'vɩ -yrɛ 'nan: «'I 'bɔ nɛn wei 'ya 'wɩ 'wlidɩ va "fo "bɛ, yiɛ 'wɩ "paaman 'kʋ 'ji?» Ɛn waa -pin 'o yei. 
\s1 Minnun yiɛ a 'e 'widɩ Bali -le 'wɩ 'ji 
\p  
\v 35 Zɩ Zozi -a 'man 'nan waa -pin 'o yei "bɛ, e -kʋ "va ɛn yaa laabʋ -yrɔ 'nan: «I yi -tɛala Blamin -pɩ da?» 
\p  
\v 36 Ɛn e 'nan Zozi lɛ 'nan: «'An 'san, -tɩɛ cɩ "nyian 'bɛ 'a -e 'an yi -tɛra "da?» 
\p  
\v 37 Zozi "e -yrɛ 'nan: «Yia 'yɩ, 'an 'bɔ nɛn an 'wɩ tin "baa yiɛ 'gʋɛ, 'an 'bɔ nɛn.» 
\p  
\v 38 -A -nan nɛn e 'nan: «Minsan, 'an yi -tɛala 'i da.» Ɛn e blula "wlu. 
\p  
\v 39 -A -nan nɛn Zozi "e 'nan: «An -ta 'trɛ 'gʋɛ -a da 'nan -e 'an minnun 'cɛn 'e cin man. -Yɛɛ cɩ 'nan minnun nɛn wa'a fɛnan ye dɩɛ, o fɛnan ye, ɛn minnun nɛn 'o 'fli "siala fɛnan yɩnɔn 'a bɛ o yiɛ -wia.» 
\p  
\v 40 Farizɛn 'nɔn -mienun nɛn -a "srɔn "bɛ, zɩ o 'wɩ zɩɛ -a 'man bɛ, ɛn waa laabʋ -yrɔ 'nan: «Yie 'nan 'i ve 'nan, 'kʋ yiɛ a 'e 'widɩ?» 
\p  
\v 41 Zozi "e 'nan -wlɛ 'nan: «"Te 'ka 'kɔn yiɛ 'winɔn 'a bɛ, "te 'cee 'wɩ 'wlidɩ "ka "fo "dɩ. 'Pian 'bɛ nɛn 'gʋɛ, 'ka 'nan, 'ka fɛnan ye, te ka'a 'we 'mɛn 'wɩ "paadɩ man dɩ, -yee "wɛan 'cee 'wɩ 'wlidɩ "a tian.» 
\c 10  
\s1 Zozi a 'bla -sru "pinzan 'kpa -a 
\p  
\v 1 Zozi "e 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, min nɛn ya'a 'wlamlan 'bla 'klɔn -ji -klɔn 'bɔ -yrɛ "nɛn "dɩɛ, 'pian yaa -tria "fɛ pee -nan bɛ, min zɩɛ crinzan nɛn, ɛn 'bla 'tɛzan nɛn.  
\v 2 'Pian min nɛn e -wlamlan 'klɔn -yrɛ "nɛn "bɛ, -yɛɛ cɩ 'blanun 'bɔ -sru "pinzan -a.  
\v 3 Min nɛn 'e -nyrandɩ -klɔn 'bɔ -yrɛ "nɛn "bɛ, e -klɔn 'lɛ "so -yrɛ. Ɛn 'blanun nɛn o cɩ -yee vɛ -a bɛ, 'o "trɔɛn -tɔa -a wei lɛ, e o laabo 'o 'tɔ man -e 'e bɔla waa bei.  
\v 4 -Te e cɛɛn 'blanun nɛn o cɩ -yee vɛ -a bɛ o bɔladɩ man bɛ, -e 'e -trɔa o 'lɛ, te 'blanun -kʋla -a -sru, kɔɔ waa wei -tɔa.  
\v 5 Wa'a 'sɔɔnmlan min nɛn e cɩ -pɛn -a bɛ -a -sru 'mlɔnmlɔn dɩ. O flan "blia 'pian -yrɔ, kɔɔ minnun nɛn o cɩ -pɛn -a bɛ wa'a o wei tɔa dɩ.»  
\v 6 Zozi -kɔnnɛn zɩɛ -a -fɔ -wlɛ, 'pian 'wɩ 'bɔ nɛn yaa tin 'ba -wlɛ "bɛ, wa'a -ci manlɛ dɩ. 
\p  
\v 7 Ɛn Zozi -a -ci 'vɩ "nyian -wlɛ 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, 'blanun man -klɔn 'bɔ bɛ, mɛɛn cɩ -a -yrɛ -a.  
\v 8 Minnun pɛɛnɔn nɛn o -trɔa 'an 'lɛ 'e tɛdɛ bɛ, crinnɔn nɛn waa, ɛn 'bla 'tɛnɔn nɛn waa. 'Pian 'blanun 'ka 'o "trɔɛn "tɔlɛ o wei lɛ 'mlɔnmlɔn dɩ.  
\v 9 -Klɔn 'bɔ man -yrɛ bɛ, 'an bɔ nɛn. Min nɛn e ciɩla 'an 'va, ɛn e wla 'klɔn -ji bɛ, e "sia 'wɩ 'ji. E bɔala e "tun, ɛn e -wlamlan 'e "tun, -a -blɩfɛ a -e 'e -blɩ.  
\v 10 Crinzan bɛ, "e "ta wo crin wʋdɩ 'lee 'bla 'tɛdɩ 'lee fɛ srɛdɩ 'tɔ 'ji. 'Pian 'mɛn vɛ bɛ, "an "ta 'wʋ 'nan -e 'blanun 'o 'beli, -e -wee 'belidɩ 'e 'kɔn 'e 'lɛ sɔɔdɩ. 
\p  
\v 11 Mɛɛn cɩ 'bla -sru "pinzan 'kpa -a. 'Bla -sru "pinzan 'kpa bɛ, e "we "man -e 'e 'ka 'yee 'blanun -le "wɛan.  
\v 12 'Pian min nɛn 'bɛ 'nyranman "paa "lala -le "wɛan bɛ, te 'blanun 'bɔ 'ka -a san -le vɛ -a dɩɛ, -te e beli 'yɩ 'tanan bɛ, e "sia 'blanun -sru -e 'e flan 'bli. Beli 'bɔ o fuimlan "man -e 'e o "kuun.  
\v 13 Min nɛn 'bɛ 'nyranman "paa "lala -le "wɛan bɛ, 'bɛ flan "blia, kɔɔ 'blanun -tɛdɩ bɛ, -a 'wɩ 'ka 'naan "man "dɩ. 
\p  
\v 14 Mɛɛn cɩ 'bla -sru "pinzan 'kpa -a. An 'mɛn 'blanun -tɔa, ɛn waan -tɔa,  
\v 15 "le zɩ 'an "tɩ 'an -tɔa ɛn 'an "tɩ 'bɔ -tɔa "bɛ -yee 'wɩ 'zʋ. 'An 'man a 'e wʋʋdɩ -e 'an 'ka 'mɛn 'blanun -le "wɛan.  
\v 16 'Mɛn 'bla -mienun a te o 'ka tian -klɔn 'gʋɛ -a -ji dɩ. 'Blanun zɩɛ, an o -fɔa "ji, o -taa 'an wei manlɛ -e 'o drɛ 'blanun nɛn o -sru "pinzan a -tʋwli "bɛ waa. 
\p  
\v 17 'An "tɩ 'an ye "yi, kɔɔ 'an 'fli -nɔn 'nan -e 'an 'ka, -e 'an 'belidɩ yɩ "nyian.  
\v 18 Min -tʋ 'ka 'mɛn 'belidɩ sia 'an 'lɔ dɩ, 'pian 'an 'bɔ 'bɛ -nɔan 'an 'fli -a. 'Plɛblɛ a 'an 'lɔ -e 'an -nɔn, ɛn 'plɛblɛ a 'an 'lɔ -e 'an 'si "nyian 'e "pa 'ji. 'Wɩ nɛn 'an "tɩ "e 'mɛn 'nan 'an drɛ bɛ, -nyrɛn "bɛ.» 
\p  
\v 19 'Wɩ nɛn Zozi -a 'vɩ zɩɛ, -yee "wɛan Zuif 'nɔn cɛɛn "nyian 'e cin man.  
\v 20 Min "kaga "a o yei te "o "ve 'nan: «-Yʋ -wlidɩ "a -a -sru, ɛn klin "a -a -wulo -ji. Te 'ka "trɔɛn "tɔ -a wei lɛ.» 
\p  
\v 21 Min -mienun "o 'vɩ 'nan: «Ya'a 'wɩ 've "le min nɛn -yʋ -wlidɩ "a -a -sru "bɛ -yee 'wɩ 'zʋ dɩ. -Yʋ -wlidɩ 'ka 'kɔlaman -e 'e min nɛn -a yiɛ cɩ 'e 'widɩ bɛ -a yiɛ 'lɛ 'sʋ dɩ.» 
\s1 Zuif 'nɔn 'tanɔn 'ka 'wɩlɛ Zozi 'le 'wɩ "paadɩ man dɩ 
\p  
\v 22 Minnun a Bali -pan 'kɔn 'le "fɛdi drɛnan Zeruzalɛm. "Fɛdi zɩɛ, waa dra lɛ pɛɛnɔn man 'nan -e Bali -pan 'kɔn nɛn waa 'lɛ 'sʋ "nyian 'e 'pee bɛ, -a -cin 'e -trɔa o ji. Tʋ zɩɛ -a man bɛ te trun -taa.  
\v 23 Ɛn Zozi ciɩdɩ 'sia Bali -pan 'kɔn 'lɛ "nɛn, fɛnan nɛn waa 'tɔ 'pa Salomɔn man bɛ -a -nan.  
\v 24 Ɛn Zuif 'nɔn 'o cin 'yɩ "man, waa laabʋ -yrɔ 'nan: «Tʋ "cɛn "a nɛn, i 'wɩ 'ci "sia 'kʋɛ 'wein -e 'kʋ vɩnan 'kʋ 'ci -tɔɔ "nyian dɩ? -Te min 'sizan 'wɩ 'ji Crizi nɛn 'yia bɛ, 'i -ci 'si 'kʋɛ tɩglɩ.» 
\p  
\v 25 Zozi -a 'vɩ -wlɛ 'nan: «Maan 'vɩ 'cɛɛ 'va, ɛn ka'a yi 'tɛala 'an da dɩ. 'Wɩnun nɛn maan dra 'an "tɩ 'tɔ da 'gʋɛ, yaa -ci -kɔɔnman 'nan, min 'sizan 'wɩ 'ji nɛn 'maan.  
\v 26 'Pian ka'a yi 'tɛala 'an da dɩ, 'mɛn 'blanun "cɛɛ 'kaa dɩ -le "wɛan.  
\v 27 'Blanun nɛn 'o cɩ 'mɛn vɛ -a bɛ, 'waan wei maan, an 'o -tɔa, ɛn 'o 'ta wʋla 'an -sru.  
\v 28 'Belidɩ nɛn ya'a 'nyaan dɩɛ, maan -nɔan -wlɛ, wa'a 'li 'kaa 'mlɔnmlɔn dɩ. Ɛn min -tʋ 'ka 'kɔlaman -e 'e o 'si 'an 'lɔ dɩ.  
\v 29 'An "tɩ "nɛn e o -nɔn 'mɛn bɛ, -a 'plɛblɛ "mlian fɛ pɛɛnɔn da, ɛn min -tʋ 'ka 'kɔlaman -e 'e o 'si 'an "tɩ 'lɔ dɩ.  
\v 30 'An 'bɔ 'lee 'an "tɩ "bɛ, kʋ ya min -tʋwli "a.» 
\p  
\v 31 Tɔɔn ɛn Zuif 'nɔn -kɔlɛ koola 'nan -e 'o wɛɛn "nyian Zozi 'va.  
\v 32 Ɛn Zozi "e 'nan -wlɛ 'nan: «An 'wɩ -dandan drɛ 'ka yiɛ man "kaga 'an "tɩ "le 'plɛblɛ 'a. 'Wɩ 'bɔ "cɛn "le "wɛan nɛn ka "ta -kɔlɛ wɛɛnman 'an 'va?» 
\p  
\v 33 Ɛn Zuif 'nɔn -a 'vɩ -yrɛ 'nan: «Wa'a vɩlɛ 'nan 'wɩ 'tʋ nɛn yia drɛ "yi "bɛ, -a 'tɔ 'ji nɛn kʋ "ta -kɔlɛ wɛɛnman 'i 'va dɩ, 'pian 'nan i Bali srɔn "le "wɛan. 'I ya min -a ɛn 'i 'fli drɛ Bali -a, -yee "wɛan kʋ "ta -kɔlɛ wɛɛnman 'i 'va.» 
\p  
\v 34 Zozi "e 'nan -wlɛ 'nan: «E ya 'e 'crɛn -tɛdɩ 'cee -pei 'fluba 'ji 'nan: 
\q1 ‹Bali "e 'nan, 'ka ya balinun -a.› 
\m  
\v 35 Ɛn -kaa -tɔa 'nan 'wɩ nɛn Bali -le 'fluba 'ji bɛ, 'wɩ 'kpa 'nɛn. Minnun nɛn Bali 'wɩ tin "baa -wlɛ "bɛ, e o laabo balinun.  
\v 36 Ɛn 'an 'bɔ bɛ, Bali 'an 'si "va ɛn yaan 'pa 'sia 'trɛda. -Mɛ "le "wɛan nɛn -te maan 'vɩ 'nan Bali -pɩ nɛn 'maan bɛ, ɛn kaa ve 'nan an Bali srɔn?  
\v 37 -Te 'wɩ nɛn maan dra 'gʋɛ, 'an "tɩ "drɛ wɩ "cɛɛ dɩɛ, te 'ka yi -tɛra 'an da dɩ!  
\v 38 'Pian -te -a 'bɔ nɛn maan dra bɛ, 'ka yi -tɛra 'an da. -Te 'bɛ "cɛɛ dɩ, 'ka yi -tɛra 'wɩ 'bɔ nɛn maan dra bɛ -a da. 'Ka drɛ zɩɛ, -e 'ka -tɔ 'kpa tɩglɩ 'nan 'kʋ 'vale 'an "tɩ "a bɛ, kʋ ya min -tʋwli "a.» 
\p  
\v 39 'Wɩ zɩɛ -a da nɛn, o ya "nyian "va 'nan 'o "kuan, 'pian e 'sʋ -wlɔ. 
\p  
\v 40 Zozi 'kʋ "nyian Zudan 'yi -sru, fɛnan nɛn Zan minnun -batize drɛ 'e tɛdɛ bɛ -a -nan, ɛn e -fʋ -nan nun.  
\v 41 Min "kaga "kʋla Zozi -sru. Minnun zɩɛ waa 'vɩ 'nan: «Zan 'ka -cɛ -srɔn "wɩ -tʋ drɛlɛ dɩ, 'pian 'wɩ pɛɛnɔn nɛn yaa 'vɩ min 'gʋɛ -a man bɛ, e ya 'wɩ 'kpa -a.»  
\v 42 Minnun nɛn o -kʋ fɛ zɩɛ -a -nan bɛ, o "kaga "yi -tɛra Zozi da. 
\c 11  
\s1 Laza -kanan wɩ 
\p  
\v 1 Min -tʋ nɛn waa laabo Laza bɛ, -a man "yaaman. E -nyɛanla 'fla nɛn waa laabo Betani bɛ -a da. -A "blu Mari 'lee Mat "o "nyɛnwla "nyian 'fla 'bɔ zɩɛ -a da.  
\v 2 Mari zɩɛ, -yɛɛ "ta -daa -laziglɔ -sɛnlɛ Minsan cɛin -da, -e 'e man bʋʋ 'e 'wulo "jɛ "a. -A "bʋɩ Laza man 'bɛ "yaaman.  
\v 3 -A "blunun zɩɛ, o min 'pa 'sia 'nan 'e vɩ Zozi lɛ 'nan: «Minsan, 'i bee bɛ -a man "yaaman.» 
\p  
\v 4 Zɩ Zozi 'wɩ zɩɛ -a 'man bɛ, ɛn e 'nan: «Laza -le -cɛ 'labɛ, -a -tɛ vɛ "cɛɛ dɩ. 'Pian e -fɔ Laza man 'nan -e 'e Bali -le 'plɛblɛ 'ci -kɔɔn. Ɛn "nyian 'dʋ -e Bali -pɩ 'tɔ 'e drɛ -dan -cɛ 'bɔ 'le "wɛan.»  
\v 5 Mat 'lee Mari 'lee o "bʋɩ Laza 'bɔ bɛ, Zozi o ye "yi. 
\p  
\v 6 Zɩ yaa 'man 'nan Laza man "yaaman bɛ, ɛn e yi drɛ "nyian fɛnan nɛn e cɩ bɛ -a -nan 'fiili.  
\v 7 "Bɛ -sru, ɛn yaa 'vɩ "e -srunɔn lɛ 'nan: «-Kaa 'li -kaa da Zude.» 
\p  
\v 8 Ɛn -a -srunɔn -a laabʋ -yrɔ 'nan: «Bali -le 'wɩ "paazan, tʋ nɛn e "sia ciɩnan -kogo 'gʋɛ -a -ji "cɛɛ Zuif 'nɔn nɛn Zude bɛ, o ya -a -wɛɛnan 'nan 'wei -tɛa "kɔlɛ -a 'gʋ dʋʋ? Yie 'nan 'i 'ko -nan nun?» 
\p  
\v 9 Ɛn Zozi -a 'vɩ -wlɛ 'nan: «-Te tʋ cɛɛn bɛ, fɛnan a 'wein bodrun 'trilii -e funnin 'e 'pla. Min nɛn e 'ta wo te tʋ cɛɛn bɛ, -a srɔɛn 'ka 'wia dɩ, kɔɔ 'tɛ nɛn e "bia 'trɛda bɛ, -a -san man nɛn e 'ta wo.  
\v 10 'Pian min nɛn e 'ta wo klun va bɛ, -a srɔɛn -wia, kɔɔ 'tɛ 'ka -a 'lɛ dɩ.» 
\p  
\v 11 Zɩ e cɛɛn 'wɩ zɩɛ -a vɩdɩ man bɛ, ɛn e 'nan -wlɛ 'nan: «-Kaa bee Laza a yi -tɛnan, 'pian 'an 'ko -a fuʋlɛ.» 
\p  
\v 12 Ɛn -a -srunɔn -a 'vɩ -yrɛ 'nan -te e ya yi -tɛnan bɛ, -a fa dra "yi -e 'e 'beli.  
\v 13 Laza -kadɩ 'wɩ nɛn Zozi -a 'vɩ, 'pian e ya -a -srunɔn "le 'ji 'nan yi tɩglɩ 'bɛ 'fɔla Laza da. 
\p  
\v 14 Ɛn Zozi -a -ci 'vɩ -wlɛ "mɛn 'wein 'nan: «Laza -ka.  
\v 15 'Cee "wɛan, ɛn 'dʋ -e 'ka yi -tɛra 'an da bɛ -yee "wɛan, 'an 'ci "nranman. Kɔɔ an 'ka 'nan nun dɩ ɛn e drɛ. 'Pian -kaa kʋ "va "nun.» 
\p  
\v 16 'Wɩ zɩɛ -a da nɛn Toma nɛn waa laabo "nyian "flɛn bɛ, e 'nan Zozi -srunɔn -mienun lɛ 'nan: «-Kaa kʋla Zozi -sru -e -kaa ka 'e cin va waa.» 
\p  
\v 17 Zozi "ɛ bɔla 'nan nun bɛ, te o Laza 'wʋ -a -nan yi sinjɛn 'bɔ.  
\v 18 Betani 'lee Zeruzalɛm bɛ, o yei bɔa kilo "fli, -te 'bɛ "cɛɛ dɩ kilo yaaga.  
\v 19 -Yee "wɛan Zuif 'nɔn "kaga "ta -nyɛnlɛa Mat 'lee Mari "srɔn o "bʋɩ nɛn e -ka bɛ -a -cɛ -da.  
\v 20 Zɩ Mat -a 'man 'nan Zozi -a -tanan bɛ, ɛn e -kʋ -a 'silɛ -sia te Mari yra 'e -nyrandɩ "kɔnnɛn. 
\p  
\v 21 Mat -a 'vɩ Zozi lɛ 'nan: «'An 'san, "te 'i 'kɔn 'gʋɛ, "te 'an "bʋɩ 'ka 'kalɛ dɩ.  
\v 22 'Pian 'bɛ 'bɔ nɛn 'gʋɛ, an yi -tɛala "da 'nan 'wɩ pɛɛnɔn nɛn yia laabo Bali lɔ bɛ, yaa 'lɛ sɔɔman 'yiɛ.» 
\p  
\v 23 Ɛn Zozi "e 'nan -yrɛ 'nan: «I "bʋɩ bɛ, e wuanla -kanɔn 'va.» 
\p  
\v 24 Mat "e -yrɛ 'nan: «'Wɩ 'kpa nɛn, maan -tɔa 'nan tʋ -fɔla "da "ji bɛ, minnun nɛn o kaa bɛ, o wuanla -kanɔn 'va. 'An "bʋɩ wuanla -kanɔn 'va "nyian.» 
\p  
\v 25 Ɛn Zozi "e -yrɛ 'nan: «'An 'bɔ 'bɛ min wuanla -kanɔn 'va, ɛn mɛɛn 'belidɩ -nɔan "min lɛ. Min nɛn e yi -tɛala 'an da bɛ, -te e -ka oo, 'belidɩ a -yrɔ.  
\v 26 Min nɛn -a yiɛ a "man ɛn e yi -tɛra 'an da bɛ, -a san 'ka kaa 'li 'mlɔnmlɔn dɩ. 'I yi -tɛala 'wɩ zɩɛ -a da?» 
\p  
\v 27 Ɛn Mat "e 'nan Zozi lɛ 'nan: «'An 'san 'wɩ 'kpa nɛn. An yi -tɛala "da 'nan yiɛ cɩ min nɛn Bali -a 'si "va "bɛ -a. Bali -pɩ nɛn waa 'vɩ 'e 'cɛn 'nan e -taa 'trɛda bɛ -nyrɛn 'yia.» 
\p  
\v 28 Zɩ Mat 'wɩ zɩɛ -a 'vɩ bɛ, ɛn e 'li 'e da. E "blu Mari laabʋ, ɛn yaa 'vɩ -yrɛ 'o "fli yei 'nan: «'Kʋ 'san bɛ e -ta, e ya "vale yei 'man ye.»  
\v 29 Zɩ Mari 'wɩ zɩɛ -a man bɛ, e wluan "klɩ, ɛn e -kʋ fɛnan nɛn Zozi cɩ bɛ -a -nan.  
\v 30 Zozi 'ka tian bɔlɛa 'fla yei "dɩ, e ya tian fɛnan nɛn Mat -kʋ -a 'silɛ -sia 'o cin yɩ 'a bɛ -a -nan.  
\v 31 Zuif 'nɔn nɛn o -kʋ -nyɛnlɛa Mari "srɔn "bɛ, zɩ o Mari yɩ e wluan "klɩ e bɔla bɛ, ɛn o sɔɔnla -a -sru. Waa nrɔn 'o 'ji 'nan e "ta -ko -wuɔlɛ 'e "bʋɩ -yrɛ da. 
\p  
\v 32 Zɩ Mari 'bɔla fɛnan nɛn Zozi cɩ bɛ -a -nan, ɛn e Zozi 'bɔ yɩ bɛ, -a -nan nɛn e -tria "wlu ɛn e 'nan: «'An 'san, "te 'i 'kɔn 'gʋɛ, "te 'an "bʋɩ 'ka 'kalɛ dɩ.» 
\p  
\v 33 Zɩ Zozi Mari 'yɩ 'wuɔnan 'o 'vale Zuif 'nɔn nɛn o -tra -a -sru "bɛ waa bɛ, -a -wulo -man -ta, ɛn -a 'wɩ 'nan "man 'kpa tɩglɩ.  
\v 34 Yaa laabʋ 'nan: «Nyin zia nɛn kaa 'wʋ?» 
\p Ɛn o 'nan -yrɛ 'nan: «'I 'ta -e 'kʋ -kɔɔn 'yiɛ.» 
\p  
\v 35 Zozi 'wuɔ. 
\p  
\v 36 Zɩ Zuif 'nɔn -a -nan 'yɩ bɛ, ɛn o 'nan: «'Ka 'yiɔ, yaa ye "yi e -ciala "da.» 
\p  
\v 37 -A -nan nɛn Zuif 'nɔn 'bɔ 'va min -mienun "o 'vɩ 'nan: «E min nɛn -a yiɛ cɩ 'e 'widɩ bɛ -a 'lɛ 'sʋ, ɛn ya'a -kɔlalɛ -a drɛdɩ -a -e Laza 'e vɩlɛ 'e 'ka dɩ.» 
\p  
\v 38 Zozi 'wulo -man -ta, ɛn e -kʋ -yrɛ da. -Wee min -yrɛ bɛ, -kɔlɛ -dan tʋ nɛn -a ci a 'e bʋdɩ bɛ -nyrɛn, ɛn -kɔlɛ nɛn waa -tɔa "nɛn -a 'lɛ wʋvɛ -a.  
\v 39 Zozi "e 'nan: «-Kɔlɛ 'labɛ 'ka 'si "nɛn.» 
\p Ɛn Laza 'bɔ "blu Mat "e 'nan: «Minsan, -a -koei bɔa, kɔɔ waa 'wʋ -a -nan yi sinjɛn nɛn 'gʋ.» 
\p  
\v 40 Ɛn Zozi "e Mat lɛ 'nan: «Maan 'nan 'yiɛ 'nan -te i yi -tɛra 'an da bɛ, i Bali -le -dan ci ye.» 
\p  
\v 41 Tɔɔn ɛn o -kɔlɛ bɛ -a 'si -yrɛ "nɛn. Zozi 'e yra -tɔ lou ɛn e 'nan: «'An "tɩ, mɛin muo -fɔa 'nan yian wei 'man.  
\v 42 An 'bɔ 'le vɛ bɛ, maan -tɔa 'nan yian wei maan tʋ pɛɛnɔn man. 'Pian minnun nɛn 'an "srɔn 'gʋɛ, -wee "wɛan maan 'vɩ 'dʋ -e 'o -tɔ 'nan yiɛ 'an 'pa 'sia.» 
\p  
\v 43 Zɩ e 'wɩ zɩɛ -a 'vɩ bɛ, ɛn e paan wei 'plɛblɛ 'ji. E 'nan: «Laza, 'i bɔla!»  
\v 44 Ɛn min -kadɩ zɩɛ e 'bɔla te -a cɛin 'lee -a -pɛ a 'e -yrɩdɩ sɔ -a. -A yra a 'e -yrɩdɩ "nyian. 
\p Zozi "e 'nan -wlɛ -nan: «'Ka sɔnun "flu "man -e 'ka 'si "man!» 
\p  
\v 45 Zuif 'nɔn nɛn o -ta Mari "srɔn, ɛn o 'wɩ nɛn Zozi -a drɛ bɛ -a -nan 'yɩ bɛ, o "kaga "yi -tɛradɩ 'sia Zozi da.  
\v 46 'Pian o va min -mienun -kʋ Farizɛn 'nɔn 'va, ɛn 'wɩ nɛn Zozi -a drɛ bɛ, waa 'vɩ -wlɛ. 
\s1 Zuif 'nɔn 'tanɔn Zozi 'tɛdɩ 'wɩ 'pla "da 
\p  
\v 47 Bali -pannɔn 'tanɔn 'lee Farizɛn 'nɔn bɛ, o tin 'banɔn cin 'yɩ, ɛn waa laabʋ -wlɔ 'nan: «-Kaa dra kɔ? Min 'labɛ e ya -cɛ srɔn "wɩ "kaga "drɛnan.  
\v 48 -Te e -fʋ 'wɩ zɩɛ -a drɛnan 'nan -ka'a 'wɩ 'silɛ "da "man "dɩɛ, min "kaga "yi -tɛala "da -e Rɔm 'nɔn 'o -cee Bali -pan 'kɔn 'wi, -e 'o -cee 'lɛglɔn 'wi.» 
\p  
\v 49 O va min -tʋ nɛn waa laabo Kaifa bɛ, -yɛɛ cɩ 'lɛ 'bɔ zɩɛ -a -ji Bali -pannɔn 'tazan -a. Yaa 'vɩ -wlɛ 'nan: «'Wɩ 'tʋ a bɛ, ka'a tɔa dɩ.  
\v 50 'Ka "nrɔn 'ka 'ji 'nan, e ya 'cee 'wɩ "yi "a -e min -tʋwli 'e min pɛɛnɔn 'ji -ka wʋ, "tɔgɔ -cee 'lɛglɔn 'ji minnun pɛɛnɔn 'nan 'e 'nyan.» 
\p  
\v 51 'Wɩ nɛn Kaifa -a 'vɩ bɛ, ya'a 'silɛ -a 'bɔ 'le ci "nrɔndɩ va dɩ. 'Pian lɛ 'bɔ zɩɛ -a -ji bɛ Bali -pannɔn 'tazan nɛn, -yee "wɛan Bali ciɩla "va ɛn e 'wɩ zɩɛ -a 'vɩ 'nan, Zozi -taa "kalɛ Zuif 'nɔn 'lɛji.  
\v 52 Wa'a vɩlɛ 'nan e -kaa Zuif 'nɔn 'saza 'lɛji dɩ, 'pian Bali -le 'nɛnnun pɛɛnɔn nɛn 'o fuiladɩ "man 'trɛda bɛ, o 'lɛji nɛn e -kaa, -e 'o 'tɛ 'e cin da min 'pa 'tʋ -a. 
\p  
\v 53 Yi 'lein nɛn Kaifa 'wɩ zɩɛ -a 'vɩ "da "bɛ, -a nyan nɛn Zuif 'nɔn 'tɔ "da 'nan 'o Zozi 'tɛ.  
\v 54 -Yee "wɛan ya'a "nyian bɔlɛa 'ji Zude 'lɛglɔn 'ji dɩ. 'Pian e 'si Zude, ɛn e -kʋ 'trɛ 'tʋ da "bui "da zia 'fla nɛn waa laabo Efrai bɛ -a da. 'O 'vale 'e -srunɔn 'a o -fʋ 'fla zɩɛ -a da. 
\p  
\v 55 Zuif 'nɔn 'le 'si nɔanba -ji "fɛdi drɛdɩ 'bɔ 'kogo. Ɛn 'lɛglɔn pɛɛnɔn 'ji minnun bɛ, o "kaga "kʋ Zeruzalɛm. O -kʋ -nan nun te "fɛdi 'bɔ 'ka tian bɔlɛ dɩ, 'nan -e 'o 'fli drɛ 'saun Bali 'lɛ.  
\v 56 Ɛn o Zozi -wɛɛdɩ 'sia. Zɩ 'o cin 'yɩ Bali -pan 'kɔn 'lɛ "nɛn "bɛ, ɛn waa laabʋ 'o cin lɔ 'nan: «Zozi 'ka 'kɔlaman -e 'e 'ta "fɛdi 'gʋɛ -a da dɩ, "ka "nrɔnman 'ka 'ji 'kɔ?»  
\v 57 Fɛ -le "wɛan nɛn o 'wɩ zɩɛ -a 'vɩ bɛ, Bali -pannɔn 'tanɔn 'lee Farizɛn 'nɔn -a 'vɩ 'nan min nɛn e Zozi 'yɩ bɛ, -a san 'e srɔɛn wʋ "man 'wlɛ 'dʋ -e 'o 'kun. 
\c 12  
\s1 Lɩmɔn -tʋ -laziglɔ -sɛn Zozi 'cɛin -da 
\r (Mt 26.6-13; Mk 14.3-9) 
\p  
\v 1 E -fʋ yi 'shɛɛdʋ -e Zuif 'nɔn 'le 'si nɔanba -ji "fɛdi 'e bɔ, ɛn Zozi 'kʋ 'fla nɛn waa laabo Betani bɛ -a da. Laza nɛn e -ka ɛn yaa fuʋ bɛ -a fla nɛn.  
\v 2 Zɩ e 'bɔla Betani nun bɛ, o fɛnun tɔɛn ɛn waa -nɔn -yrɛ. Mat 'bɛ fɛ zɩɛ -a -pliman. Ɛn minnun nɛn o cɩ 'o -nyrandɩ Zozi "srɔn fɛnun -sru "bɛ, Laza a o va. 
\p  
\v 3 Tɔɔn Mari -laziglɔ -pɔn -tʋ 'si, yaa -sɛn Zozi 'cɛin -da, ɛn yaa man bʋʋ 'e 'wulo "jɛ "a. -A -koei 'kɔn 'bɔ 'ji 'si 'e pɛɛnɔn. -Laziglɔ zɩɛ waa drɛ fɛ -tʋ nɛn waa laabo Nard bɛ -a, e 'ka 'e baadɩ fɛ -tʋ -a dɩ, ɛn -a 'flɛ a. 
\p  
\v 4 O Zozi -sruzan 'tʋ laabo Zudazi Karioti, -yɛɛ "ta -daa Zozi 'nɔnlɛ minnun lɛ. Min zɩɛ e 'nan:  
\v 5 «-Mɛ "le "wɛan nɛn wa'a -laziglɔ 'labɛ -a -tanlɛ dɩ? -Kaa taan paan, -a "lala bɔa -kpi fuba 'shɛɛdʋ, -e -kaa -pli 'yalɛ -tɛnɔn man.»  
\v 6 'Yalɛ -tɛnɔn 'le 'wɩ "cɛɛ "naan "man -yee "wɛan e 'wɩ zɩɛ -a 'vɩ dɩ. 'Pian crinzan nɛn, ɛn -wee "lala nɛn yaa "paala bɛ, yaa "sia "va te yaa -ble. 
\p  
\v 7 Ɛn Zozi "e 'nan: «'Ka lɩ 'labɛ -a 'tʋɩ flɩɩ, yaan 'man drɛ yi nɛn waan wo bɛ -yee "wɛan.  
\v 8 Tʋ pɛɛnɔn 'a bɛ, te 'yalɛ -tɛnɔn a 'ka 'va. 'Pian 'mɛn vɛ bɛ, ma'an 'fo 'ka 'va tʋ pɛɛnɔn 'a dɩ.» 
\s1 Bali -pannɔn 'tanɔn -a 'pla "da 'nan 'o Laza -tɛ 
\p  
\v 9 Zuif 'nɔn "kaga -a 'man 'nan Zozi a Betani, ɛn o -kʋ -nan nun. Wa'a 'kʋlɛ Zozi yɩdɩ 'saza 'le "wɛan dɩ, 'pian o -kʋ 'nan -e 'o Laza nɛn e -ka ɛn yaa fuʋ bɛ -a yɩ.  
\v 10 -A -nan nɛn Bali -pannɔn 'tanɔn -a 'pla "da 'nan 'o Laza -tɛ.  
\v 11 Kɔɔ Laza -le "wɛan Zuif 'nɔn "kaga "a 'sinan o -sru, te o yi -tɛala Zozi da. 
\s1 Zozi 'bɔla Zeruzalɛm 
\r (Mt 21.1-11; Mk 11.1-11; Lk 19.28-40) 
\p  
\v 12 -A ta tʋ nɛn e cɛɛn bɛ, Zuif 'nɔn "kaga "nɛn o -kʋ Zeruzalɛm Zuif 'nɔn 'le 'si nɔanba -ji "fɛdi da bɛ, zɩ waa 'man 'nan Zozi -a -tanan Zeruzalɛm bɛ,  
\v 13 o lo 'lanun 'sia, ɛn o -kʋ Zozi 'silɛ -sia te o plaman. Waa ve 'nan: 
\q1 «-Fɛavɛa o! -Fɛavɛa o! 
\q1 Min nɛn e cɩ -tanan Minsan 'tɔ da bɛ, 
\q1 Bali -le -fɛa 'e 'kɔn -a san man. 
\q1 Izraɛl 'nɔn 'le mingɔnnɛn nɛn.» 
\p  
\v 14 Zozi -aflumun pla 'nɛn 'tʋ 'yɩ, ɛn e -nyran "da "le 'wɩ nɛn 'e 'crɛn -tɛdɩ 'e 'cɛn Bali -le 'fluba 'ji bɛ -yee 'wɩ 'zʋ. E ya 'e 'crɛn -tɛdɩ 'nan: 
\q1  
\v 15 «Zeruzalɛm minnun, 
\q1 te nyɛn 'e 'kɔn 'ka 'ji dɩ! 
\q1 "Ka 'yiɔ, 'cee mingɔnnɛn a -tanan 
\q1 'e -nyrandɩ -aflumun pla 'nɛn da.» 
\p  
\v 16 Tʋ zɩɛ -a wlu bɛ, Zozi -srunɔn 'ka 'wɩ nɛn e cɩ 'e 'lɛ sɔɔnan zɩɛ -a -ci manlɛ dɩ. 'Pian tʋ nɛn Zozi 'kʋ 'e "tɩ "le mingɔnnɛn trɛ nɛn e "bia bɛ -a da bɛ, -a -nan nɛn -a -cin -tɔ o ji 'nan 'wɩ nɛn e crɛn -tɛdɩ Zozi 'bɔ 'le 'wɩ 'a bɛ, -yɛɛ 'lɛ sɔɔ. 
\p  
\v 17 Tʋ nɛn te Laza -ka e ya -yrɛ -ji -e Zozi 'e fuʋ bɛ, minnun pɛɛnɔn nɛn waa -nan 'yɩ bɛ, o Zozi 'le 'wɩ 'vɩ.  
\v 18 Ɛn minnun "kaga "ta Zozi 'silɛ -sia 'lɛbo "fɔ wɩ nɛn yaa drɛ waa 'man bɛ -yee "wɛan.  
\v 19 -A -nan nɛn Farizɛn 'nɔn -a vɩdɩ 'sia 'o cin lɛ 'nan: «Kaa ye, ka'a 'kɔlaman fɛ -tʋ drɛdɩ -a "nyian dɩ. "Ka 'yiɔ, 'trɛda minnun pɛɛnɔn -sɛn -a -sru.» 
\s1 Minnun nɛn o 'ka Zuif 'nɔn 'a dɩɛ o -ta Zozi 'va 
\p  
\v 20 Minnun nɛn o -kʋ Bali bɔlɛ "fɛdi da Zeruzalɛm bɛ, minnun nɛn o 'ka Zuif 'nɔn 'a dɩɛ o -mie a o va.  
\v 21 O 'nɔn zɩɛ, o pli Filipʋ man. Filipʋ bɛ, Bɛzaida min nɛn Galile 'lɛglɔn 'ji. Ɛn o kɔala "man -a vɩdɩ -a 'nan: «'Kʋ 'san, kʋ ya "vale 'kʋ Zozi ye.»  
\v 22 Filipʋ -kʋ -a vɩlɛ Andre lɛ, ɛn Andre 'lee Filipʋ -kʋ -a vɩlɛ Zozi lɛ. 
\p  
\v 23 Ɛn Zozi -a 'vɩ -wlɛ 'nan: «Tʋ nɛn 'an 'bɔ Blamin -pɩ 'an -ko 'an "tɩ "le mingɔnnɛn trɛ nɛn e "bia bɛ -a da bɛ e 'bɔ.  
\v 24 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, -te wa'a 'saa 'wlɛ 'fɔlɛ 'trɛ 'ji -e 'e fʋlɩ "ji "dɩɛ, e -fo 'e -tʋwli, yaa 'bɔa "da "dɩ. 'Pian -te e fʋlɩ "ji "bɛ, -a -kɔn bɔa "da -e 'e 'sɛn "da "kaga.  
\v 25 Min nɛn -yee 'belidɩ wɩ cɩ "man "bʋʋ "bɛ, e -taa 'yee 'belidɩ 'bɔ srɛlɛ, 'pian min nɛn 'e 'pɛ 'si 'trɛda wɩnun -sru "bɛ, 'belidɩ nɛn ya'a 'nyaan dɩɛ e ya -a san -le vɛ -a.  
\v 26 -Te min a "va 'nan 'an drɛ 'e 'san -a bɛ, 'e -sɔɔnla 'an -sru. -Te e sɔɔnla 'an -sru "bɛ, fɛnan nɛn an cɩ bɛ, 'an 'suzan zɩɛ e -kɔan "nan "nyian. Min nɛn yaan "sua bɛ, 'an "tɩ -a 'tɔ dra -dan. 
\p  
\v 27 'Bɛ nɛn 'gʋɛ, 'an 'ci baa 'ji. -Mɛ "wɩ nɛn an -taa -a vɩlɛ 'an "tɩ "lɛ? Maan ve 'an "tɩ "lɛ 'nan, 'e yra yɩdɩ 'labɛ -a 'si 'an man -kɔɔbli. -Cɛjɛ, ma'an 'wɩ zɩɛ -a ve dɩ, kɔɔ -yee "wɛan nɛn an -ta 'trɛda.  
\v 28 Maan ve 'pian 'nan: ‹'An "tɩ, 'i drɛ -e minnun 'o -tɔ 'nan 'i 'tɔ a -dan.› » 
\p 'Nun tɔɔn, ɛn wei -tʋ wɩɩ laji. E 'nan: «Maan -ci kɔɔn 'nan 'an 'tɔ a -dan 'va, ɛn maan dra "nyian -dan.»  
\v 29 Min "kaga "nɛn fɛ zɩɛ -a -nan, ɛn o 'wɩ zɩɛ -a 'man bɛ, o 'nan: «Laa -paan 'bɛ klun.» Ɛn o -mienun "o 'vɩ 'nan: «Bali -le 'pasianɔn nɛn laji bɛ, -a -tʋ 'bɛ 'wɩ tin 'ba -yrɛ.» 
\p  
\v 30 Ɛn Zozi 'bɔ -a 'vɩ -wlɛ 'nan: «Wei nɛn e wɩɩ 'gʋɛ, 'mɛn "wɛan "cɛɛ e wɩɩ dɩ, 'pian 'ka lɛ nɛn e 'wɩ tin 'ba.  
\v 31 'Bɛ nɛn 'gʋɛ, 'trɛdanɔn 'le tin 'badɩ bɛ e 'bɔ. Satan nɛn e 'trɛ 'gʋɛ -a "paala bɛ -a -pin tʋ 'bɔ.  
\v 32 'Mɛn vɛ bɛ, tʋ nɛn minnun 'an "paa yiba "plan da -e 'an 'si 'trɛda bɛ, -te -a tʋ 'bɔ bɛ, maan dra -e min pɛɛnɔn 'o yi -tɛra 'an da.»  
\v 33 -Te Zozi 'wɩ zɩɛ -a 'vɩ bɛ, zɩ e -taa "kalɛ bɛ -a -nan wɩ nɛn yaa 'vɩ. 
\p  
\v 34 Ɛn minnun -a 'vɩ -yrɛ 'nan: «Kʋa 'man -pei 'fluba 'ji 'nan, min nɛn Bali -a 'si "va "bɛ, ya'a kaa 'li "fo "dɩ. -Mɛ "le "wɛan nɛn yia ve 'nan: ‹Yi nɛn o Blamin -pɩ "paa yiba "plan da? Blamin -pɩ zɩɛ -tɩ nɛn?› » 
\p  
\v 35 Ɛn Zozi "e -wlɛ 'nan: «'Tɛ 'san a tian 'ka 'va tʋ "wɛnnɛn 'a. 'Ka 'ta wʋ te -a 'san a tian 'ka 'va, "tɔgɔ klun 'e bɔ 'ka man kligli. Min nɛn e 'ta wo klun va bɛ, fɛnan nɛn e cɩ -kʋnan bɛ, ya'a tɔa dɩ.  
\v 36 'Ka yi -tɛra 'tɛ 'san da te e ya tian 'ka 'va, -e 'ka 'kɔn minnun nɛn o ya 'tɛ 'san da bɛ waa.» 
\p Zɩ Zozi 'wɩ zɩɛ -a 'vɩ bɛ, e 'si o "srɔn, ɛn e yɔɔ -wlɔ. 
\s1 Zuif 'nɔn 'ka yi -tɛlɛa Zozi da dɩ 
\p  
\v 37 Zozi 'lɛbo "fɔ wɩ "kaga drɛ Zuif 'nɔn yiɛ man, 'pian wa'a yi -tɛlɛa Zozi da dɩ.  
\v 38 E drɛ zɩɛ 'nan -e 'wɩ nɛn Bali 'lewei vɩzan Ezai -a 'vɩ bɛ 'e 'lɛ sɔɔ. Yaa 'vɩ 'nan: 
\q1 «Minsan, -tɩɛ yi -tɛra 'wɩnun nɛn kʋa 'vɩ bɛ -a da? 
\q1 Ɛn -tɩ lɛ nɛn Minsan 'yee -pɛ 'plɛ 'ci kɔɔn?» 
\m  
\v 39 'Wɩ nɛn -yee "wɛan wa'a 'kɔlaman -e 'o yi -tɛra 'wɩ da dɩɛ, Ezai -a 'vɩ "nyian. Yaa 'vɩ 'nan: 
\q1  
\v 40 «Bali o yiɛ 'wi, 
\q1 -e 'o vɩlɛ 'o fɛnan 'yɩ dɩ, 
\q1 ɛn e o -pɔan "da -tɔ 'plɛblɛ, 
\q1 -e 'o vɩlɛ 'o 'wɩ 'wɩ man dɩ. 
\q1 E drɛ zɩɛ 'nan 
\q1 "tɔgɔ 'o -sɔɔnla 'e -sru, 
\q1 -e 'e o 'si 'wɩ 'ji.» 
\m  
\v 41 Zozi 'le 'wɩ nɛn Ezai -a 'vɩ. E Zozi 'le -dan ci 'yɩ, -yee "wɛan e 'wɩ zɩɛ -a 'vɩ. 
\p  
\v 42 Zuif 'nɔn 'tanɔn 'bɔ bɛ, o "kaga "yi -tɛala Zozi da. 'Pian Farizɛn 'nɔn 'le "wɛan o 'ka "vale 'o ve 'wein dɩ, "tɔgɔ 'o o -pin cin yɩ 'kuin.  
\v 43 -Te minnun o 'tɔ "yi "ve bɛ, waa ye "yi e "mlian Bali -le o 'tɔ "yi "vɩdɩ da. 
\p  
\v 44 Zozi paan 'nan: «Min nɛn e yi -tɛala 'an da bɛ, 'an 'saza da "cɛɛ e yi -tɛala dɩ, 'pian e yi -tɛala "nyian min nɛn yaan 'pa 'sia bɛ -a da.  
\v 45 Min nɛn yaan 'yɩ bɛ, te e min nɛn yaan 'pa 'sia bɛ -a 'yɩ.  
\v 46 Mɛɛn cɩ 'tɛ 'san -a, an -ta 'trɛda 'nan -e min nɛn e yi -tɛra 'an da bɛ, -a san 'e vɩlɛ 'e 'fʋ klun va -trilii dɩ. 
\p  
\v 47 -Te min 'an wei 'man, ɛn -a san 'ka 'ta wʋlɛa "da "dɩɛ, mɛɛn "cɛɛ tin -tɛa -a san da dɩ. -Yɛɛ cɩ 'nan an -ta 'trɛda 'nan -e 'an 'trɛdanɔn 'si 'wɩ 'ji, ma'an 'talɛ 'nan -e 'an tin -tɛ 'trɛdanɔn da dɩ.  
\v 48 Min nɛn yaan tuʋ 'e 'pɛla koda, ɛn ya'a 'an wei 'silɛa 'wɩ 'a dɩɛ, -a san -le 'wɩ tin 'bazan a. 'An wei nɛn maan 'vɩ bɛ, -yɛɛ tin -tɛa -a san da yi -fɔla "da "ji.  
\v 49 'Wɩ nɛn maan ve bɛ, ya'a 'sia 'an 'bɔ 'va dɩ, 'pian 'an "tɩ "nɛn yaan 'pa 'sia bɛ, -yɛɛ 'wɩ nɛn kɔ 'an vɩ bɛ -a 'pa 'an 'le.  
\v 50 Ɛn maan -tɔa 'nan 'an "tɩ "le 'wɩ nɛn yaa 'vɩ bɛ, e 'belidɩ nɛn ya'a 'nyaan dɩɛ -a -nɔan "min lɛ. 'Wɩnun nɛn maan ve 'gʋɛ, zɩ 'an "tɩ -a 'vɩ 'mɛn bɛ -a da nɛn maan ve.» 
\c 13  
\s1 Zozi 'lee 'e -srunɔn fɛ -nyranman blɩ 'e cin va 
\p  
\v 1 E -fʋ yi -tʋ -e Zuif 'nɔn 'le 'si nɔanba -ji "fɛdi yi 'e bɔ. Zozi -a -tɔa 'nan 'yee tʋ 'bɔ -e 'e 'si 'trɛ 'gʋɛ -a da -e 'e 'kʋ 'e "tɩ "srɔn. Minnun nɛn o yi -tɛra Zozi da 'trɛda bɛ, e o 'yɩ "yi, e o 'yɩ "yi "trilii, ɛn yaa 'le 'sran. 
\p  
\v 2 Yi zɩɛ -a funninmlan nɛn Zozi 'lee 'e -srunɔn a fɛnun -blɩnan 'e cin va. Tʋ zɩɛ -a man bɛ, te Satan ci "nrɔndɩ 'pla Simɔn -pɩ Zudazi Karioti man. Yaa -cin -trɔa "ji 'nan 'e Zozi 'nɔn 'e 'nanmannɔn lɛ.  
\v 3 Zozi -a -tɔa 'nan 'e "sia Bali va ɛn 'e lia 'e da Bali va. Yaa -tɔa "nyian 'nan 'e "tɩ 'e 'tɔ fɛ pɛɛnɔn da.  
\v 4 E wluan fɛnun nɛn o cɩ -a -blɩnan bɛ -a -sru, e 'yee sɔ 'si 'e da, ɛn e sɔ -tʋ 'si yaa -trɔa 'e -tiɛn "da.  
\v 5 E 'yi 'sɛn 'kpɔngbo 'tʋ -ji, ɛn 'e -srunɔn 'cɛin -man "foedɩ 'sia, te yaa man bʋʋman sɔ nɛn -a -tiɛn "da bɛ -a. 
\p  
\v 6 Zɩ e 'bɔ Simɔn Piɛri da bɛ, ɛn 'bɛ laabʋ -yrɔ 'nan: «Minsan, yiɛ 'an 'cɛin -man "foeman?» 
\p  
\v 7 Ɛn Zozi -a 'vɩ -yrɛ 'nan: «'Wɩ nɛn an cɩ -a drɛnan 'gʋɛ yi'a -ci maan tʋ 'gʋɛ -a dɩ, 'pian yia -ci maan 'e 'fɔla "da.» 
\p  
\v 8 Ɛn Piɛri "e -yrɛ 'nan: «Maan 'we "man "dɩ, yi'a 'li 'an 'cɛin -man foeman "fo "dɩ.» 
\p Zozi "e -yrɛ 'nan: «-Te ma'an 'i 'cɛin -man "foelɛ dɩɛ, te i 'ka 'mɛn vɛ -a dɩ.» 
\p  
\v 9 -A -nan nɛn Simɔn Piɛri "e Zozi lɛ 'nan: «Te 'yian 'cɛin 'saza 'man "foe dɩ. Minsan, 'an 'pɛ 'lee 'an 'wulo nɛn 'gʋ, 'i o man "foe "nyian.» 
\p  
\v 10 Ɛn Zozi "e 'nan -yrɛ 'nan: «Min nɛn 'e sru 'va bɛ, -a 'kɔlɛ pɛɛnɔn da a 'saun. -A cɛin -man 'saza nɛn yaa "foeman. Ka ya 'saun, 'pian 'ka pɛɛnɔn "cɛɛ dɩ.»  
\v 11 Min nɛn e "ta -daa Zozi 'nɔnlɛ 'e 'nanmannɔn lɛ bɛ, Zozi -a -tɔa, -yee "wɛan yaa 'vɩ 'nan, o pɛɛnɔn 'ka 'saun dɩ. 
\p  
\v 12 Zɩ Zozi cɛɛn 'e -srunɔn 'cɛin -man "foedɩ man bɛ, ɛn e 'yee sɔ 'wʋ "nyian 'e da. E -nyran fɛnun -sru 'e "pa 'ji, ɛn yaa laabʋ -wlɔ 'nan: «'Wɩ nɛn maan drɛ 'cɛɛ 'gʋɛ, kaa -ci 'man?  
\v 13 Kaan laabo Bali -le 'wɩ "paazan, ɛn kaan laabo Minsan. Kaa ve 'e 'nɔan da, kɔɔ an ya -a.  
\v 14 'An 'bɔ 'bɛ cɩ Bali -le 'wɩ "paazan -a, ɛn mɛɛn cɩ Minsan -a, -yee "wɛan -te an 'ka 'cɛin -man foe bɛ, 'ka cin cɛin -man "foe "nyian.  
\v 15 'Wɩ -kɔɔn "man wɩ nɛn man drɛ 'cɛɛ, 'dʋ -e 'ka drɛ "le zɩ maan drɛ 'cɛɛ bɛ -yee 'wɩ 'zʋ.  
\v 16 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, min 'suzan -dan 'ka 'mlian 'e 'tazan da dɩ. Ɛn 'pasiazan -dan 'ka 'mlian min nɛn yaa 'pa 'sia bɛ -a da dɩ.  
\v 17 'Wɩnun zɩɛ kaa -tɔa 'siɛn. -Te ka 'ta 'wʋla "da "bɛ, Bali -le -fɛa a 'ka man. 
\p  
\v 18 'Ka pɛɛnɔn "cɛɛ maan ve dɩ. Minnun nɛn an o 'si "va "bɛ, an o -tɔa, 'pian 'wɩ nɛn 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji bɛ, e ya "le 'e 'lɛ sɔɔ. E ya 'e 'crɛn -tɛdɩ 'nan: 
\q1 ‹Min nɛn 'kʋ fɛ blɩ a 'e cin va bɛ, 
\q1 e drɛ 'an 'nanmanzan 'a.› 
\p  
\v 19 Maan ve 'cɛɛ 'vaa -e -a tʋ 'e bɔ. Tʋ nɛn 'wɩnun zɩɛ e dra "man "bɛ, -e min nɛn an cɩ -a bɛ 'ka -tɔ.  
\v 20 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, min nɛn maan 'pa 'sia bɛ, -te min nɛn yaa -pɛ 'kun bɛ, 'an 'bɔ nɛn -a san 'an 'pɛ 'kun. Ɛn min nɛn yaan 'pɛ 'kun bɛ, te min nɛn yaan 'pa 'sia bɛ, -a 'bɔ nɛn -a san -a -pɛ 'kun.» 
\s1 Zozi "e 'nan Zudazi "ta 'e -nɔan 'e 'nanmannɔn lɛ 
\r (Mt 26.20-25; Mk 14.17-21; Lk 22.21-23) 
\p  
\v 21 Zɩ Zozi 'wɩ zɩɛ -a 'vɩ bɛ, ɛn -a ci baa 'ji. -A -nan nɛn yaa 'vɩ -wlɛ 'wein 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, min -tʋ a 'ka yei, -yɛɛ 'an -nɔan 'an 'nanmannɔn lɛ.» 
\p  
\v 22 Ɛn Zozi -srunɔn 'o yiɛ 'tɔ 'o cin yra, kɔɔ min nɛn e cɩ -yee 'wɩ vɩnan bɛ, wa'a san tɔa dɩ.  
\v 23 Zozi -sruzan 'tʋ nɛn Zozi -a ye "yi 'kpa tɩglɩ bɛ, -yɛɛ cɩ 'e -nyrandɩ Zozi 'bɔ "srɔn "kogo.  
\v 24 Ɛn Simɔn Piɛri 'wɩ 'tʋ drɛ -yrɛ 'nan 'e laabʋ Zozi 'lɔ 'nan -tɩ nɛn Zozi 'bɔ -a ve. 
\p  
\v 25 Zozi -sruzan zɩɛ, e tɛɛn "ji Zozi kugu da, ɛn yaa laabʋ Zozi 'lɔ 'nan: «Minsan, -tɩ nɛn?» 
\p  
\v 26 Zozi "e -yrɛ 'nan: «Min nɛn an 'kpɔun ponɛn 'fɔdɩ -nɔn -yrɛ "bɛ, te -a san nɛn.» -A -nan nɛn Zozi 'kpɔun ponɛn 'si, yaa 'fɔ, ɛn yaa -nɔn Simɔn -pɩ Zudazi Karioti lɛ.  
\v 27 Zɩ Zudazi 'kpɔun ponɛn zɩɛ -a 'si bɛ, ɛn Satan -fɔ -a -sru. 
\p Zozi "e -yrɛ 'nan: «'Wɩ nɛn i "ta -a dra bɛ, 'i drɛ tada.»  
\v 28 Minnun nɛn o cɩ 'o -nyrandɩ waa fɛnun -sru "bɛ, o -tʋ 'ka 'wɩ nɛn Zozi 'wɩ zɩɛ -a 'vɩ "man "bɛ -a -ci manlɛ dɩ.  
\v 29 Zudazi "kuan 'wee "lala man, -yee "wɛan min -mienun -a nrɔn 'o 'ji 'nan, Zozi -a 'vɩ -yrɛ 'nan 'e 'kʋ fɛ nɛn e klɩ 'o man "fɛdi fɛ -a bɛ -a 'lɔ. -Te 'bɛ "cɛɛ dɩ 'nan 'e 'kʋ fɛ -tʋ -nɔn 'yalɛ -tɛnɔn lɛ.  
\v 30 Zudazi 'kpɔun ponɛn zɩɛ -a 'si, nun tɔɔn ɛn e 'bɔla bei "nyiandʋ klun va. 
\s1 Zozi 'wɩ 'nyranman paa 'e -srunɔn 'ji 
\p  
\v 31 Zɩ Zudazi bɔla bɛ, ɛn Zozi "e 'nan: «'Bɛ nɛn 'gʋɛ, Blamin -pɩ 'tɔ drɛ -dan "mɛn, ɛn minnun Bali -le -dan ci ye Blamin -pɩ -le "wɛan.  
\v 32 Ɛn -te minnun Bali -le -dan ci 'yɩ Blamin -pɩ -le "wɛan bɛ, -e Bali 'bɔ 'e 'pɩ 'tɔ drɛ -dan 'e 'bɔ 'a. -A -nan 'ka "nyian mɔan dɩ -e 'e 'wɩ zɩɛ -a drɛ. 
\p  
\v 33 'Mɛn 'nɛnnun, an ya tian ka yei tʋ "wɛnnɛn 'a, 'pian ka -taa 'an -wɛɛlɛ. 'Wɩ nɛn maan 'vɩ Zuif 'nɔn lɛ bɛ, an "cee "ve "nyian. Ka'a 'kɔlaman -e 'ka 'kʋ fɛnan nɛn an "ta -ko bɛ -a -nan dɩ. 
\p  
\v 34 An -pei -trɛ -tɔa 'cɛɛ, -nyrɛn 'nan 'ka cin yɩ "yi "le zɩ an 'ka 'yɩ "yi "bɛ -yee 'wɩ 'zʋ.  
\v 35 -Te 'ka cin ye "yi "bɛ, minnun pɛɛnɔn -taa -a -tɔlɛ 'nan ka ya 'an -srunɔn 'a.» 
\s1 Zozi -a 'vɩ Piɛri lɛ 'nan e "sia 'e -sru 
\r (Mt 26.31-35; Mk 14.27-31; Lk 22.31-34) 
\p  
\v 36 Simɔn Piɛri -a laabʋ Zozi 'lɔ 'nan: «Minsan, i "ta -ko nyin zia?» 
\p Ɛn Zozi "e -yrɛ 'nan: «Fɛnan nɛn an "ta -ko tʋ 'gʋɛ -a bɛ, yi'a 'kɔlaman -e 'i -tra 'an -sru "dɩ, 'pian "bɛ -sru, i -taa -sɔɔnlɛa 'an -sru.» 
\p  
\v 37 Ɛn Piɛri -a laabʋ -yrɔ "nyian 'nan: «Minsan, -mɛ "le "wɛan ma'an 'kɔlaman -e 'an 'kʋla 'i -sru tʋ 'gʋɛ -a dɩ? 'An 'man a 'e wʋʋdɩ -e 'an 'ka 'yie "wɛan.» 
\p  
\v 38 Ɛn Zozi "e 'nan Piɛri lɛ 'nan: «Yia ve 'nan, 'i 'man a 'e wʋʋdɩ -e 'i 'ka 'mɛn "wɛan? 'Pian 'an 'bɔ "an "ve 'yiɛ 'wɩ tɩglɩ 'a 'nan, yia ve 'e 'pa -a yaaga 'nan, yi'an 'tɔa dɩ, 'vaa -e mannɛn tɛdɛ 'e 'wɩ.» 
\c 14  
\s1 Zozi 'tʋwli 'bɛ cɩ Bali va -si -a 
\p  
\v 1 Zozi "e 'nan 'e -srunɔn lɛ 'nan: «Te 'ka 'ci 'e baa -ji 'mlɔnmlɔn dɩ! 'Ka yi -tɛra Bali da, ɛn 'ka yi -tɛra "nyian 'an da!  
\v 2 'An "tɩ "le "kɔnnɛn "bɛ, -nyrannan "kaga "a -nan. An "ta -ko 'ka -nyrannan "man drɛlɛ. "Te -nyrannan 'ka 'nan dɩɛ, "te ma'an vɩlɛ 'cɛɛ dɩ.  
\v 3 -Yee "wɛan -te an -kʋ ɛn an 'ka -nyrannan "man drɛ bɛ, an -taa 'ka 'silɛ -e -kaa kʋ -nan nun. -Kaa -nyrannan -kɔan 'e cin va.  
\v 4 Fɛ nɛn an "ta -ko -nan 'gʋɛ, -kaa -nan si -tɔa.» 
\p  
\v 5 Ɛn Toma "e -yrɛ 'nan: «Minsan, fɛ nɛn i "ta -ko -nan bɛ, kʋ'a -nan si tɔa dɩ. Kʋa dra 'kɔ -e 'kʋ -nan si -tɔ?» 
\p  
\v 6 Zozi "e -yrɛ 'nan: «Mɛɛn cɩ -si -a, ɛn mɛɛn cɩ 'wɩ tɩglɩ 'a, ɛn mɛɛn cɩ 'belidɩ -a. Min 'ka 'kɔlaman -e 'e 'kʋ 'an "tɩ 'va, te ya'a 'ciɩlɛa 'an 'va dɩ.  
\v 7 Min nɛn an cɩ -a bɛ kaa -tɔ, -yee "wɛan kaan "tɩ -tɔa. 'Bɛ nɛn 'gʋɛ kaan "tɩ 'yɩ, ɛn zɩ e cɩ bɛ, kaa -tɔdɩ 'sia.» 
\p  
\v 8 Ɛn Filipʋ "e 'si "va 'nan: «Minsan, 'i "tɩ 'bɔ bɛ, 'i -kɔɔn 'kʋɛ, te 'kʋ 'ci 'sɔ.» 
\p  
\v 9 Zozi "e -yrɛ 'nan: «Filipʋ, an 'mɔn 'ka yei "kaga, ɛn yia tian 'an 'tɔlɛ dʋʋ? Min nɛn yaan 'yɩ bɛ, te -a san 'an "tɩ 'yɩ. -Mɛ "le "wɛan yia ve 'nan 'an "tɩ -kɔɔn 'cɛɛ?  
\v 10 Yi'a yi 'tɛala "da 'nan 'kʋ 'vale 'an "tɩ "a kʋ ya min -tʋwli "a dʋʋ? 'Wɩnun nɛn maan ve 'cɛɛ 'gʋɛ, ya'a 'sia 'an 'bɔ 'va dɩ. 'An "tɩ 'bɔ nɛn kʋ ya -a min -tʋwli "bɛ, -yɛɛ -ciala 'an 'va -e 'e 'yee 'wɩnun 'lɛ sɔɔ.  
\v 11 'Ka yi -tɛra "da 'nan 'kʋ 'vale 'an "tɩ "a kʋ ya min -tʋwli "a. Ɛn -te ka'a yi 'tɛala 'an da 'an 'lewei 'le "wɛan dɩɛ, 'ka yi -tɛra 'an da, wɩnun nɛn maan dra bɛ -yee "wɛan.  
\v 12 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, min nɛn e yi -tɛra 'an da bɛ, 'wɩnun nɛn maan dra 'gʋɛ, -a san "e "dra "nyian. -A -san -taa 'wɩ -dandan drɛlɛ e "mlian 'mɛn vɛ da, kɔɔ an "ta -ko 'an "tɩ 'va.  
\v 13 'Wɩ pɛɛnɔn nɛn kaa laabo 'an "tɩ 'lɔ te ka ya 'mɛn vɛ -a bɛ, maan dra, 'dʋ -e 'an "tɩ 'tɔ 'e drɛ -dan 'mɛn "wɛan.  
\v 14 -Te ka 'wɩ 'tʋ laabʋ 'an 'lɔ te ka ya 'mɛn vɛ -a bɛ, maan dra.» 
\s1 Zozi "e 'nan 'e -taa Bali lei 'saun 'a 'yee minnun da 
\p  
\v 15 «-Te kaan ye "yi "bɛ, 'an wei da nɛn 'ka 'ta wʋla.  
\v 16 Tɔɔn 'an "tɩ trʋ "baa -e 'e 'ka 'pa "vazan 'pa 'sia 'cɛɛ, -yɛɛ fo 'ka 'va 'li 'trilii.  
\v 17 'Ka 'pa "vazan zɩɛ Bali lei nɛn 'e 'wɩ tɩglɩ -kɔɔnman min lɛ bɛ -nyrɛn. Minnun nɛn 'trɛda 'wɩnun 'gʋɛ -nyrɛn waa ye "yi "bɛ, ya'a 'kɔlaman -e 'e drɛ -wee vɛ -a dɩ, kɔɔ o yra 'ka "da 'zia dɩ, ɛn wa'a -tɔlɛ dɩ. 'Pian 'cee vɛ bɛ, "ka "tɔ, kɔɔ e ya 'ka 'va, ɛn 'ka -taa "drɛlɛ waa min -tʋwli "a.  
\v 18 Ma'an 'ka 'tʋe 'ka 'saza "le 'nɛn nɛn -a "tɩ 'lee -a "bʋ "ka 'e da bɛ -yee 'wɩ 'zʋ dɩ. An lia 'an da 'ka 'va.  
\v 19 E -fʋ tʋ "wɛnnɛn 'a, te 'trɛda minnun 'ka "nyian 'an 'ye dɩ. 'Pian 'cee vɛ bɛ, ka -taa -a yɩlɛ 'nan 'an yiɛ a "man "nyian 'e "pa 'ji. Ɛn "cee yiɛ 'fo "man "nyian.  
\v 20 Tʋ zɩɛ -a man nɛn kaa -tɔa 'nan 'an "tɩ 'bɔ bɛ, kʋ ya -a min -tʋwli. Ɛn 'ka 'bɔ 'lee 'an 'bɔ bɛ, -kaa ya min -tʋwli "a.  
\v 21 Min nɛn 'mɛn -pei -tɔ wɩnun -cin a "ji, te e 'ta 'wʋla "da "bɛ, -a san 'bɛ 'an ye "yi. Min nɛn yaan ye "yi "bɛ, 'an "tɩ -taa -a san yɩlɛ "yi, 'an 'bɔ an -taa -a san yɩlɛ "yi "nyian, ɛn 'an 'fli -kɔɔnman -yrɛ.» 
\p  
\v 22 Ɛn -a -sruzan 'tʋ nɛn "nyian waa laabo Zudazi, te Zudazi Karioti "cɛɛ 'bɛ 'a dɩɛ, 'bɛ laabʋ -yrɔ 'nan: «Minsan, -mɛ "le "wɛan 'i 'fli -kɔɔnman 'kʋɛ, ɛn yi'a 'i 'fli kɔɔnman 'trɛda minnun lɛ dɩ?» 
\p  
\v 23 Ɛn Zozi -a 'vɩ -yrɛ 'nan: «-Te min 'an ye "yi te e 'ta 'wʋla 'an wei da bɛ, -a -nan nɛn 'an "tɩ -taa -a san yɩlɛ "yi. Tɔɔn 'kʋ 'vale 'an "tɩ "a bɛ, kʋ -taa "talɛ -a san va -e 'kʋ -nyran "va.  
\v 24 'Pian min nɛn ya'an ye "yi "dɩɛ, ya'a 'ta wʋla 'an wei da dɩ. Wei nɛn ka cɩ -a mannan 'gʋɛ, ya'a 'sia 'an 'va dɩ, 'pian 'an "tɩ 'nɛn yaan 'pa 'sia bɛ -a va nɛn e "sia. 
\p  
\v 25 'Wɩnun 'gʋɛ maan tin "baa 'cɛɛ te an ya tian 'ka yei.  
\v 26 'An "tɩ -taa "talɛ 'ka 'pa "vazan 'a 'an 'lɛji, Bali lei 'saun nɛn. -Yɛɛ 'wɩ pɛɛnɔn nɛn maan 'vɩ bɛ -a -cin -tɔa 'ka 'ji, ɛn -yɛɛ -ci "sia 'cɛɛ. 
\p  
\v 27 'Ka 'fʋ -trɔɔ, 'mɛn -fʋdɩ -trɔɔ bɛ, maan -nɔn 'cɛɛ. Ma'an -fʋdɩ -trɔɔ ve 'ka 'man "le 'nan 'trɛda minnun -a ve 'ka man bɛ -yee 'wɩ 'zʋ dɩ. Te nyɛn 'e 'ka 'cɛn dɩ, ɛn te "klan 'e 'ka 'tɛ dɩ. 
\p  
\v 28 Maan 'vɩ 'cɛɛ 'nan, an "ta -ko -e 'an li 'an da "nyian 'ka 'va. "Te kaan ye "yi "bɛ, "te 'ka 'ci "nranman, kɔɔ an "ta -ko 'an "tɩ 'va, ɛn 'an "tɩ -dan "mlian 'an da.  
\v 29 'Wɩnun zɩɛ, maan 'vɩ 'cɛɛ 'vaa -e -a drɛ tʋ 'e bɔ. 'Dʋ -e "yɛɛ vɩnan 'e drɛ bɛ, -e 'ka yi -tɛra 'an da.  
\v 30 'Mɛn tʋ 'ka "nyian "kaga -e 'an 'wɩ tin 'ba 'cɛɛ dɩ, kɔɔ Satan nɛn e 'trɛ 'gʋɛ -a "paala bɛ, e ya -tanan. -Yee 'plɛblɛ 'ka 'an da dɩ,  
\v 31 'pian -e 'trɛda minnun 'o -tɔ 'nan, 'an "tɩ ye "yi "bɛ, 'wɩ nɛn yaa 'vɩ 'mɛn bɛ an 'ta 'wʋla "da. 
\p 'Ka 'wluan lou, -kaa kʋ!» 
\c 15  
\s1 Zozi -kɔnnɛn "tʋ -fɔ yiba 'lee 'e pɛ 'nɛnnun da 
\p  
\v 1 Yaa vɩdɩ 'sia -wlɛ 'nan: «Mɛɛn cɩ rɛzɛn yiba 'kpa -a, ɛn 'an "tɩ 'bɛ cɩ min nɛn e rɛzɛn 'bɔ 'ta bɛ -a.  
\v 2 'An pɛ 'nɛnnun nɛn wa'a 'baa dɩɛ, 'an "tɩ o "cɛan, ɛn 'an pɛ 'nɛnnun nɛn o baa "bɛ, 'an "tɩ "o man dra 'dʋ -e 'o ba 'kpa "kaga.  
\v 3 Cɛɛ cɩ 'an pɛ 'nɛnnun nɛn o -taa "balɛ "kaga "bɛ waa, kɔɔ 'wɩ nɛn maan paa 'ka 'ji 'gʋɛ, e 'ka drɛ 'saun 'va.  
\v 4 'Ka 'fʋ 'ka lɛadɩ 'an man te -kaa ya min -tʋwli "a. Yiba "pɛ 'ka 'kɔlaman -e 'e ba 'e 'saza, te e 'ka 'e lɛadɩ yiba 'bɔ man dɩ. -A -tʋwli "nɛn "nyian 'cee vɛ -a, -te ka'a 'fʋlɛ 'ka lɛadɩ 'an man dɩɛ, ka'a 'kɔlaman 'wɩ 'tʋ drɛdɩ -a dɩ. 
\p  
\v 5 Mɛɛn cɩ rɛzɛn yiba "a, ɛn cɛɛ cɩ 'an pɛ 'nɛnnun -a. Min nɛn e -fʋ 'e lɛadɩ 'an man bɛ, kʋ 'vale -a kʋ dra min -tʋwli "a. -A san -kɔan "le yiba "pɛ nɛn e baa "kaga "bɛ -yee 'wɩ 'zʋ. -Yɛɛ cɩ 'nan -te ma'an 'palɛ 'ka 'va dɩɛ, ka'a 'kɔlaman 'wɩ 'tʋ drɛdɩ -a dɩ.  
\v 6 Min nɛn ya'a -fʋlɛ 'e lɛadɩ 'an man dɩɛ, waa -tua bei. -A san a "le 'nan yiba "pɛ nɛn waa cɛɛn ɛn waa tuʋ bei "bɛ -yee 'wɩ 'zʋ. E -kaa, waa "siala -e 'o -fɔ 'tɛa.  
\v 7 -Te ka -fʋ 'ka lɛadɩ 'an man, ɛn 'an wei -cin -fɔla 'ka 'ji bɛ, fɛ oo fɛ nɛn ka cɩ "va "bɛ, 'ka laabʋ 'an "tɩ 'lɔ, yaa -nɔan 'cɛɛ.  
\v 8 -Te ka ya "le 'nan yiba "pɛ nɛn e baa "kaga "bɛ -yee 'wɩ 'zʋ bɛ, 'an "tɩ 'tɔ dra -dan. 'Wɩ zɩɛ -yɛɛ -kɔɔnman 'nan ka ya 'an -srunɔn 'a. 
\p  
\v 9 Zɩ 'an "tɩ 'an ye "yi "bɛ, -a da nɛn an 'ka ye "yi. 'Ka 'fʋ 'ka lɛadɩ 'an man -e 'an 'ka yɩ "yi.  
\v 10 -Te ka 'ta 'wʋla 'mɛn -pei -tɔ wɩnun da bɛ, an 'ka ye "yi. An 'bɔ "nyian, "an 'ta wʋla 'an "tɩ "le -pei -tɔ wɩnun da ɛn yaan 'yɩ "yi. 
\p  
\v 11 'Wɩnun zɩɛ maan 'vɩ 'cɛɛ 'nan -e ci "nrandɩ nɛn an 'lɔ 'gʋɛ -e 'kɔn "nyian "cee 'lɔ. -E 'cee vɛ 'e 'ciɩla "da "fo.  
\v 12 'Mɛn -pei -tɔ wɩ nɛn 'nan, 'ka cin yɩ "yi "le zɩ an 'ka ye "yi "bɛ -yee 'wɩ 'zʋ.  
\v 13 Yɩdɩ "yi "nɛn e "mlian yɩdɩ "yi pɛɛnɔn da bɛ, -nyrɛn 'nan min 'e 'wɩ "man -e 'e 'ka 'e beenun "pa 'ji.  
\v 14 -Te ka 'ta 'wʋla 'wɩ nɛn maan 'vɩ 'cɛɛ bɛ -a da bɛ, te ka ya 'an beenun -a.  
\v 15 Ma'an "nyian 'ka laabo 'an 'sunɔn dɩ, 'pian an 'ka laabo 'an beenun. Min 'suzan 'ka 'e 'tazan drɛ wɩ tɔa dɩ, 'pian 'wɩ pɛɛnɔn nɛn maan 'man 'an "tɩ "da bɛ, maan 'vɩ 'cɛɛ, -yee "wɛan an 'ka laabo 'an beenun.  
\v 16 'Ka 'bɔ "cɛɛ 'an 'si "va ɛn ka sɔɔnla 'an -sru "dɩ, 'pian mɛɛn 'ka 'si "va. An 'ka 'si "va 'nan -e 'ka 'nyranman 'pa, -e 'ka drɛ yiba "pɛ nɛn e baa "kaga "bɛ -a. 'Cee 'nyranman "nɛn 'ka 'fo 'e "tun "dɩ. -Te kaa drɛ zɩɛ, fɛ pɛɛnɔn nɛn kaa laabo 'an "tɩ 'lɔ te ka ya 'mɛn vɛ -a bɛ, yaa -nɔan 'cɛɛ.  
\v 17 'Wɩnun nɛn maan 'vɩ 'cɛɛ 'gʋɛ, 'ka 'ta wʋla "da 'dʋ -e 'ka cin yɩ "yi.» 
\s1 'Trɛda minnun "naan Zozi 'lee 'e -srunɔn man 
\p  
\v 18 «'Trɛdanɔn "naan 'ka man, 'pian 'ka -tɔ 'nan o 'nan 'an man 'ka 'lɔ 'e 'flin.  
\v 19 "Te ka ya "le 'trɛdanɔn 'zʋ bɛ, "te o 'ka ye "yi "le 'o 'va minnun zʋ. 'Pian an 'ka 'si o yei, ɛn ka 'ka "nyian 'trɛdavɛ -a dɩ, -yee "wɛan o "naan 'ka man.  
\v 20 'Wɩ nɛn maan 'vɩ 'cɛɛ bɛ, -a -cin 'e 'fɔla 'ka 'ji. Maan 'vɩ 'nan, min 'suzan -dan 'ka 'mlian 'e 'tazan da dɩ, -yee "wɛan -te minnun 'tɛ 'pa 'an da bɛ, 'ka -tɔ 'nan o 'tɛ "paa "nyian "cee "da. -Te minnun 'ta 'wʋla 'an wei da bɛ, 'ka -tɔ 'nan o 'ta wʋla "nyian "cee "wei da.  
\v 21 'Wɩnun pɛɛnɔn zɩɛ waa dra 'cɛɛ, ka ya 'mɛn vɛ -a -le "wɛan. Min nɛn yaan 'pa 'sia bɛ, wa'a tɔa dɩ, -yee "wɛan nɛn waa dra.  
\v 22 "Te ma'an 'talɛ -e 'an 'wɩ tin 'ba -wlɛ "dɩɛ, "te o 'ka 'wɩ 'wlidɩ "drɛnɔn 'a dɩ. 'Pian 'bɛ nɛn 'gʋɛ, -wee 'wɩ 'pa "davɛ pee "ka "dɩ.  
\v 23 Kɔɔ min nɛn e "naan 'an man bɛ, te -a san "nan "nyian 'an "tɩ "man.  
\v 24 'Wɩnun nɛn min -tʋ 'ka tian 'li -a drɛlɛ dɩɛ, "te ma'an drɛlɛ o yiɛ man dɩɛ, "te o 'ka 'wɩ 'wlidɩ "drɛnɔn 'a dɩ. 'Pian 'bɛ nɛn 'gʋɛ, waan drɛ wɩnun 'yɩ, te o "naan tian 'kʋ 'vale 'an "tɩ "a 'kʋ man.  
\v 25 'Wɩ zɩɛ e dra 'nan -e 'wɩ nɛn 'e 'crɛn -tɛdɩ -wee -pei 'fluba 'ji bɛ 'e 'lɛ sɔɔ. E ya 'e 'crɛn -tɛdɩ 'nan: 
\q1 ‹Minnun 'nan 'an man te -a -ci "ka "dɩ.› 
\p  
\v 26 Tʋ nɛn an -ko 'an "tɩ 'va bɛ, an 'ka 'pa "vazan "paa -sia. Bali lei nɛn, e "sia 'an "tɩ 'va, ɛn e 'wɩ tɩglɩ 'ci "sia min lɛ. -Te e -ta bɛ, -yɛɛ 'an 'nan wɩ ve.  
\v 27 'Ka 'bɔ "nyian, cɛɛ 'an 'nan wɩ ve minnun lɛ. Kɔɔ -e 'e 'sia 'mɛn 'nyranman pou sianan "trilii -e 'e bɔ cɛɛgʋ yi -a bɛ, ka -fʋ 'an "srɔn. 
\c 16  
\p  
\v 1 'Wɩnun 'gʋɛ maan 'vɩ cɛɛ 'nan -e "wɛɛ vɩnan 'o 'tɛ "paa 'ka da bɛ -e 'ka vɩlɛ 'ka 'si 'an -sru "dɩ.  
\v 2 Minnun -taa 'ka 'pinlɛ 'wee cin yɩ 'kɔnnun -ji. Ɛn tʋ -mie -taa "bɔlɛ bɛ, minnun 'ka -tɛɛman, te o 'ci "nrɔnman 'nan 'o ya Bali 'sunan.  
\v 3 'Wɩnun zɩɛ waa dra, kɔɔ wa'an "tɩ 'tɔa dɩ, ɛn wa'an 'tɔa dɩ. 
\p  
\v 4 'Wɩnun zɩɛ maan 'vɩ 'cɛɛ 'nan -te -a -tʋ 'bɔ bɛ, -e 'an wei -cin 'e 'trɔa 'ka 'ji. Ma'an vɩlɛ 'cɛɛ -a pou sianan "dɩ, kɔɔ te an ya 'ka yei.» 
\s1 Zozi "e 'nan Bali lei 'saun -taa 'wɩ tɩglɩ 'ci 'silɛ 
\p  
\v 5 «'Bɛ nɛn 'gʋɛ, an "ta lia 'an da min nɛn yaan 'pa 'sia bɛ -a va. 'Wɩ zɩɛ maan 'vɩ 'cɛɛ, ɛn min -tʋ 'ka yɩlɛ 'ka yei -e 'e laabʋ 'an 'lɔ 'nan nyin zia nɛn an "ta -ko dɩ.  
\v 6 'Pian zɩ an 'wɩ zɩɛ -a 'vɩ 'cɛɛ bɛ, ɛn 'ka 'ta drɛ 'trɔdrɔ.  
\v 7 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, e ya 'cee 'wɩ "yi "a -e 'an 'kʋ. Kɔɔ -te ma'an 'kʋlɛ dɩɛ, 'ka 'pa "vazan 'ka 'taa dɩ. 'Pian -te an -kʋ bɛ, maan "paa -sia 'cɛɛ. 
\p  
\v 8 -Te e -ta bɛ, 'wɩ nɛn e cɩ 'wɩ 'wlidɩ "a bɛ 'lee 'wɩ nɛn e cɩ 'wɩ tɩglɩ 'a bɛ 'lee Bali -le tin 'badɩ bɛ, -yɛɛ -ci -kɔɔnman 'trɛdanɔn lɛ.  
\v 9 -Wee 'wɩ 'wlidɩ "nɛn 'nan wa'a yi 'tɛala 'an da dɩ.  
\v 10 Bali -le 'wɩ tɩglɩ drɛdɩ nɛn 'nan an lia 'an da 'an "tɩ 'va, ɛn ka'a "nyian 'an 'ye dɩ.  
\v 11 Bali -le tin 'badɩ nɛn 'nan Satan nɛn e 'trɛ 'gʋɛ -a "paala bɛ tin -tɛ "da. 
\p  
\v 12 'Wɩ "kaga "a -e 'an vɩ 'cɛɛ, 'pian ka'a 'kɔlaman -e 'ka -ci man tʋ 'gʋɛ -a dɩ.  
\v 13 Bali lei nɛn e 'wɩ tɩglɩ 'ci "sia min lɛ bɛ, -te e -ta bɛ, -yɛɛ 'wɩ tɩglɩ pɛɛnɔn 'ci "sia 'cɛɛ. Ya'a 'wɩ 've 'e 'bɔ 'le 'plɛblɛ 'a dɩ, 'pian 'wɩ nɛn yaa man bɛ, -nyrɛn yaa ve minnun lɛ. 'Wɩ nɛn e -taa "drɛlɛ -kɔɔbli bɛ, -nyrɛn yaa -ci "sia minnun lɛ.  
\v 14 -Yɛɛ 'mɛn -dan ci -kɔɔnman minnun lɛ, kɔɔ 'wɩnun nɛn e -taa -a vɩlɛ 'cɛɛ bɛ, e "sia an 'va.  
\v 15 Fɛ pɛɛnɔn nɛn e cɩ 'an "tɩ 'lɔ bɛ, te e ya 'mɛn vɛ -a "nyian, -yee "wɛan maan 'vɩ 'nan, 'wɩnun nɛn yaa ve 'cɛɛ bɛ, e "sia 'an 'va.» 
\s1 Zozi "e 'nan ci "nrandɩ -taa 'e -srunɔn 'lɔ 
\p  
\v 16 Zozi -a 'vɩ "nyian 'nan: «Tʋ -fʋ "wɛnnɔn -e 'ka vɩlɛ 'kaan yɩ "nyian dɩ, ɛn tʋ "wɛnnɛn 'a "nyian -e 'kaan yɩ.» 
\p  
\v 17 Zɩ Zozi 'wɩ zɩɛ -a 'vɩ bɛ, ɛn -a -srunɔn -mienun 'wɩ vɩdɩ 'sia o cin yei. Waa 'vɩ 'nan: «'Wɩ nɛn yaa 'vɩ -cɛɛ 'gʋɛ, -a -ci nɛn 'nɔn? Yaa 'vɩ 'nan, tʋ -fʋ "wɛnnɔn -e 'ka vɩlɛ 'kaan yɩ "nyian dɩ, ɛn tʋ "wɛnnɛn 'a "nyian -e 'kaan yɩ. Ɛn yaa 'vɩ "nyian 'nan an "ta -ko 'an "tɩ "srɔn.  
\v 18 Tʋ "wɛnnɛn 'bɔ nɛn yaa ve 'gʋɛ -a -ci nɛn 'nɔn? 'Wɩ nɛn e cɩ "vale 'e ve bɛ, -ka'a -ci maan dɩ.» 
\p  
\v 19 Zozi -a -tɔ 'nan o ya "vale 'o 'wɩ zɩɛ -a -ci laabo 'e 'lɔ, ɛn e 'nan -wlɛ 'nan: «Maan 'vɩ 'cɛɛ 'nan tʋ -fʋ "wɛnnɔn, te ka'a "nyian 'an 'ye dɩ ɛn tʋ "wɛnnɛn 'a "nyian -e 'kaan yɩ. 'Wɩ zɩɛ -a da nɛn ka 'wɩ laabo 'ka cin lɔ 'gʋ?  
\v 20 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, ka -taa "wuɔlɛ 'kpa tɩglɩ, 'pian te 'trɛdanɔn "le 'ci "nranman. 'Ka 'ta dra -trɔdrɔ, 'pian 'cee ta drɛdɩ -trɔdrɔ zɩɛ e limlan "da ci "nrandɩ -a.  
\v 21 'Ka 'ci "nrɔn -pɔnzan da. -Te -yee 'nɛn 'ya tʋ 'bɔ bɛ, -a ta dra -trɔdrɔ, kɔɔ -yee yra yɩdɩ 'bɔ. 'Pian -te e 'nɛn 'bɔ 'ya bɛ, -e 'yee yra yɩdɩ -cin 'e 'san "ji. -A ci "nranman 'siɛn 'nan 'e min 'bɔla 'trɛda.  
\v 22 -A -tʋwli "nɛn "nyian 'cee vɛ -a. Tʋ 'gʋɛ -a bɛ 'ka 'ta a -trɔdrɔ, 'pian an 'ka yɩ pee wo -e 'ka 'ci 'e "nran. Ɛn min -tʋ 'ka 'kɔlaman -e 'e ci "nrandɩ zɩɛ -a 'si 'ka 'lɔ dɩ.  
\v 23 Tʋ zɩɛ -a man bɛ, ka'a "nyian 'wɩ 'tʋ laabo 'an 'lɔ dɩ. 
\p Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, fɛ nɛn kaa laabo 'an "tɩ 'lɔ te ka ya 'mɛn vɛ -a bɛ yaa -nɔan 'cɛɛ.  
\v 24 Ka'a tian fɛ -tʋ laabʋlɛ 'an "tɩ 'lɔ te ka ya 'mɛn vɛ -a dɩ. 'Ka laabʋ -yrɔ, yaa -nɔan 'cɛɛ -e 'cee ci "nrandɩ 'e 'ciɩla "da "fo.» 
\s1 Zozi "e 'nan 'e -srunɔn 'o -pɔan 'kun 
\p  
\v 25 «'Wɩnun zɩɛ, maan 'vɩ 'cɛɛ -kɔnnɛn "ji. Tʋ -tʋ -taa "bɔlɛ, te ma'an "nyian 'wɩ tin 'baa 'cɛɛ -kɔnnɛn "ji dɩ, 'pian 'an "tɩ "le 'wɩ tin "baa 'cɛɛ 'wein.  
\v 26 Tʋ zɩɛ -a man bɛ, 'ka fɛ laabʋ 'an "tɩ 'lɔ te ka ya 'mɛn vɛ -a. 'An 'bɔ "cɛɛ 'an "tɩ trʋ "baa -yee fɛ -nɔndɩ 'cɛɛ -a dɩ,  
\v 27 kɔɔ 'an "tɩ 'bɔ 'ka ye "yi, kaan 'yɩ "yi "le "wɛan. Kaan ye "yi, ɛn ka yi -tɛala "da 'nan an 'si Bali va, -yee "wɛan 'an "tɩ 'bɔ 'ka ye "yi.  
\v 28 An 'si 'an "tɩ 'va, ɛn an -ta 'trɛ 'gʋɛ -a da. 'Bɛ nɛn 'gʋɛ, an "ta "sia 'trɛda -e 'an li 'an da 'an "tɩ 'va.» 
\p  
\v 29 Ɛn -a -srunɔn "e 'nan -yrɛ 'nan: «I ya 'wɩ tin 'banan "mɛn 'e 'ci -a 'wein te e 'ka -kɔnnɛn "ji dɩ.  
\v 30 'Bɛ nɛn 'gʋɛ, kʋa -tɔ "mɛn 'nan i 'wɩ pɛɛnɔn -tɔa. 'Wɩ nɛn kʋ cɩ "vale 'kʋ laabo 'i 'lɔ bɛ yia -tɔa, te kʋ'a tian -a laabʋlɛ dɩ. -Yee "wɛan kʋ yi -tɛala 'i da 'nan i 'si Bali va.» 
\p  
\v 31 Ɛn Zozi "e 'nan -wlɛ 'nan: «Ka yi -tɛala 'an da, 'bɛ a zɩ.  
\v 32 'Pian maan ve 'cɛɛ 'nan, tʋ -tʋ -taa "bɔlɛ, 'ka pɛɛnɔn fuimlan "man -e min -tʋ 'e 'kʋ 'e 'lɛ zia. -A tʋ 'bɔ 'bɔ 'va. Tʋ zɩɛ -a man nɛn kaan "tʋe 'an -tʋwli. 'Pian an 'ka 'an -tʋwli "dɩ, kɔɔ 'an "tɩ -kɔan 'an "srɔn. 
\p  
\v 33 An -fɔ 'e 'flin an 'wɩnun pɛɛnɔn 'gʋɛ -a 'vɩ 'cɛɛ 'nan -e 'ka 'fʋ -trɔɔ, -e -kaa drɛ min -tʋwli "a -le "wɛan. Ka -taa 'ka yra yɩlɛ 'trɛda, 'pian 'ka -pɔan 'e 'sɔ, an 'trɛda 'plɛblɛ pɛɛnɔn klɩ.» 
\c 17  
\s1 Zozi Bali trʋ 'ba 'e -srunɔn lɛ 
\p  
\v 1 Zɩ Zozi cɛɛn 'wɩ zɩɛ -a vɩdɩ man bɛ, 'e yra -tɔ laji, ɛn e 'nan: 
\p «'An "tɩ, -a tʋ 'bɔ. 'An 'bɔ nɛn 'i 'pɩ -a bɛ, 'yian 'tɔ drɛ -dan, -e 'mɛin 'tɔ drɛ -dan "nyian.  
\v 2 I 'plɛblɛ 'nɔn 'mɛn, ɛn yian 'pla fɛ pɛɛnɔn 'ta lou, -yee "wɛan minnun nɛn i o -nɔn 'mɛn bɛ, an 'belidɩ nɛn ya'a 'nyaan dɩɛ -a -nɔan -wlɛ.  
\v 3 'Belidɩ nɛn ya'a 'nyaan dɩɛ, -nyrɛn 'nan, min 'e 'i 'tɔ, 'nan 'i 'bɔ 'tʋwli yiɛ cɩ Bali tɩglɩ 'a, ɛn 'an 'bɔ Zozi Crizi nɛn yian 'pa 'sia bɛ min 'e 'an 'tɔ.  
\v 4 Mɛin 'tɔ drɛ -dan 'trɛda, ɛn 'nyranman nɛn yia -nɔn 'mɛn 'nan 'an 'pa bɛ, maan 'lɛ sɔɔ.  
\v 5 'Bɛ nɛn 'gʋɛ, 'an "tɩ, 'yian drɛ -dan 'i "srɔn "nun. Zɩ an cɩ -dan 'i "srɔn "nun 'e 'cɛn, te 'trɛ "ka tian dɩɛ, 'yian drɛ -a 'e "pa 'ji. 
\p  
\v 6 Zɩ i cɩ bɛ, maan -ci 'si minnun nɛn i o 'si "va 'trɛdanɔn yei ɛn i o -nɔn 'mɛn bɛ -wlɛ. O ya 'yie vɛ -a, ɛn i o -nɔn 'mɛn. O 'ta 'wʋla 'i wei da,  
\v 7 ɛn waa -tɔ "mɛn 'nan, fɛ pɛɛnɔn nɛn yia -nɔn 'mɛn bɛ, e "sia 'i 'va 'kpagba.  
\v 8 -Yɛɛ cɩ 'nan weinun nɛn yia -nɔn 'mɛn bɛ, maan 'vɩ -wlɛ ɛn waa 'sia "da. Waa -tɔ 'nan 'wɩ tɩglɩ an 'si 'i 'va, ɛn o yi -tɛra "da 'nan yiɛ 'an 'pa 'sia. 
\p  
\v 9 -Wee "wɛan nɛn an cɩ 'i trʋ 'banan. An 'ka 'i trʋ 'banan 'trɛdanɔn pɛɛnɔn 'le "wɛan dɩ. 'Pian minnun nɛn i o -nɔn 'mɛn bɛ, -wee "wɛan nɛn an cɩ 'i trʋ 'banan, kɔɔ o ya 'yie vɛ -a.  
\v 10 Minnun pɛɛnɔn nɛn o cɩ 'mɛn vɛ -a bɛ, o ya 'yie vɛ -a. Ɛn minnun nɛn yie vɛ -a bɛ, o ya 'mɛn vɛ -a, -wee "wɛan nɛn 'an 'tɔ drɛ -dan.  
\v 11 An "ta "sia 'trɛda -e 'an 'lʋ 'i 'va nun te "o "ya wo 'trɛda 'gʋ. 'An "tɩ "nɛn e ya 'saun bɛ, 'i 'tɔ nɛn yia -nɔn 'mɛn bɛ -yee 'plɛblɛ 'a, 'i yiɛ 'tɔ o va, 'dʋ -e -kaa fʋ waa -tʋwli "le zɩ 'kʋ cɩ 'yia min -tʋwli "a bɛ -yee 'wɩ 'zʋ.  
\v 12 Tʋ nɛn te an ya o va 'trɛda bɛ, 'an yiɛ 'tɔ o va, 'i 'tɔ nɛn yia -nɔn 'mɛn bɛ, -yee 'plɛblɛ 'a. Min -tʋwli 'ka 'sanlɛ dɩ, -te yaa 'silɛa min -wlidɩ "a dɩɛ. -Yɛɛ 'san 'nan -e Bali wei nɛn 'e 'crɛn -tɛdɩ bɛ 'e 'lɛ sɔɔ. 
\p  
\v 13 'Bɛ nɛn 'gʋɛ an "ta "lo 'i 'va, ɛn 'wɩnun 'gʋɛ maan ve trɛda 'gʋ 'nan -e ci "nrandɩ nɛn 'an 'lɔ bɛ, 'e 'kɔn "nyian -wee 'lɔ 'e 'ciɩladɩ "da "fo.  
\v 14 'I wei bɛ, maan 'vɩ -wlɛ, -yee "wɛan 'trɛdanɔn 'nandɩ 'sia o man. O 'nandɩ 'sia o man 'nan o 'ka "nyian 'wee vɛ -a dɩ, "le zɩ an 'ka -wee vɛ -a dɩɛ -yee 'wɩ 'zʋ.  
\v 15 An 'ka 'i trʋ 'banan 'nan 'i o 'si 'trɛdanɔn yei "dɩ. An ya 'i trʋ 'banan 'pian 'nan, 'i yiɛ 'tɔ o va Satan nɛn e 'wɩ 'wlidɩ "paa 'nyranman -a bɛ -yee "wɛan.  
\v 16 O 'ka 'trɛdavɛ -a dɩ, "le zɩ an 'ka 'trɛdavɛ -a dɩɛ -yee 'wɩ 'zʋ.  
\v 17 'I 'wɩ tɩglɩ -kɔɔn -wlɛ -e 'o drɛ 'yie vɛ -a "fo. 'Wɩ tɩglɩ zɩɛ 'i wei nɛn.  
\v 18 Zɩ yian 'pa 'sia 'trɛda bɛ, -a -tʋwli "nɛn "nyian an o 'pa 'sia 'trɛda.  
\v 19 An 'fli -nɔan -e 'an 'ka -wee "wɛan, 'dʋ -e 'o drɛ 'yie vɛ -a "fo. 
\p  
\v 20 -Wee "wɛan nɛn an ya 'i trʋ 'banan, ɛn minnun nɛn o yi -tɛra 'an da o wei -le "wɛan bɛ, an ya 'i trʋ 'banan "nyian -wee 'wɩ man.  
\v 21 An ya 'i trʋ 'banan 'nan -e 'o drɛ min -tʋwli "a. 'An "tɩ, 'o 'kɔn 'o lɛadɩ 'kʋ man, "le zɩ 'kʋ 'vale 'yia, kʋ ya min -tʋwli "a bɛ -yee 'wɩ 'zʋ. 'O drɛ min -tʋwli "a -e 'trɛdanɔn 'o -tɔ 'nan yiɛ 'an 'pa 'sia.  
\v 22 An o drɛ -dan "le zɩ yian drɛ -dan bɛ -yee 'wɩ 'zʋ. An o drɛ -dan 'nan -e 'o drɛ min -tʋwli "a, "le zɩ kʋ cɩ 'yia min -tʋwli "a bɛ -yee 'wɩ 'zʋ.  
\v 23 Kʋ ya waa min -tʋwli "a, ɛn kʋ ya 'yia min -tʋwli "a 'nan -e 'o drɛ min -tʋwli "a 'kpa tɩglɩ. 'E drɛ zɩɛ -e 'trɛdanɔn 'o -tɔ 'nan, yiɛ 'an 'pa 'sia, ɛn i o ye "yi "le zɩ yian ye "yi "bɛ -yee 'wɩ 'zʋ. 
\p  
\v 24 'An "tɩ, minnun pɛɛnɔn nɛn i o -nɔn 'mɛn bɛ, an ya "va 'nan 'kʋ 'kɔn waa fɛnan nɛn an -kɔan "bɛ -a -nan. An ya "va 'nan 'o 'mɛn -dan ci yɩ. Yian drɛ -dan, kɔɔ yian 'yɩ "yi, te yi'a tian 'trɛ drɛlɛ dɩ.  
\v 25 'An "tɩ, i ya tɩglɩ. 'Trɛdanɔn 'ka 'i 'tɔa dɩ, 'pian 'an 'bɔ 'mɛin -tɔa. Ɛn 'an -srunɔn "o "tɔ "nyian 'nan yiɛ 'an 'pa 'sia.  
\v 26 Zɩ i cɩ bɛ, maan kɔɔn -wlɛ, ɛn maan -kɔɔnman tian -wlɛ, 'nan -e 'o cin yɩ "yi "le zɩ yian ye "yi "bɛ -yee 'wɩ 'zʋ, te kʋ ya waa min -tʋwli "a.» 
\c 18  
\s1 Zuif 'nɔn 'tanɔn Zozi 'kun 
\r (Mt 26.47-58; Mk 14.43-50, 53-54; Lk 22.47-54) 
\p  
\v 1 Zɩ Zozi cɛɛn Bali trʋ 'badɩ man bɛ, ɛn 'o 'vale 'e -srunɔn 'a, o -kʋ 'yi nɛn waa laabo Cedrɔn bɛ -a -sru. Fei -tʋ a fɛ zɩɛ -a -nan, -a da nɛn o -kʋ.  
\v 2 Zozi 'lee 'e -srunɔn 'o cin ye 'e 'cɛn fɛ zɩɛ -a -nan, -yee "wɛan Zudazi nɛn e "ta -daa Zozi 'nɔnlɛ 'e 'nanmannɔn lɛ bɛ, yaa -nan -tɔa. 
\p  
\v 3 'Sounja 'pa 'tʋ 'lee minnun nɛn Bali -pannɔn 'tanɔn 'lee Farizɛn 'nɔn o 'pa 'sia bɛ, Zudazi -trɔa o 'lɛ, ɛn e -kʋ waa fei zɩɛ -a da. "Wɛɛ vɩnan 'o 'kʋ bɛ, srɔannun a -wlɔ, -kannɛnnun a -wlɔ, ɛn -kuli -tan fɛnun a -wlɔ. 
\p Zɩ o 'bɔla bɛ,  
\v 4 ɛn Zozi 'kʋ o 'lɛ, te e 'wɩ nɛn e "ta -daa "bɔlɛ "man "bɛ -a -tɔa, ɛn yaa laabʋ -wlɔ 'nan: «-Tɩ nɛn -kaa -wɛɛman?» 
\p  
\v 5 O 'nan -yrɛ 'nan: «Nazarɛtɩ min Zozi nɛn kʋa -wɛɛman.» 
\p Ɛn Zozi "e -wlɛ 'nan: «'An 'bɔ nɛn 'gʋ.» 
\p Zudazi nɛn e Zozi 'bɔ 'nɔn 'e 'nanmannɔn lɛ bɛ e ya o yei.  
\v 6 Zɩ Zozi -a 'vɩ -wlɛ 'nan, 'e 'bɔ nɛn 'gʋɛ, o -kʋ 'o koda ɛn o tiila "tra. 
\p  
\v 7 -A -nan nɛn Zozi -a laabʋ "nyian -wlɔ 'nan: «-Tɩ nɛn kaa -wɛɛman?» 
\p Ɛn o -yrɛ 'nan: «Nazarɛtɩ min Zozi nɛn.» 
\p  
\v 8 Zozi "e 'nan -wlɛ 'nan: «Maan 'vɩ 'cɛɛ 'va 'nan 'an 'bɔ nɛn 'gʋ. -Yee "wɛan -te maan nɛn ka cɩ 'an -wɛɛnan bɛ, ka minnun 'gʋɛ o 'tʋɩ 'o 'kʋ.» 
\p  
\v 9 Zɩ 'wɩ nɛn Zozi -a 'vɩ 'e 'cɛn bɛ 'e 'lɛ sɔɔ zɩɛ. Yaa 'vɩ 'e 'cɛn 'nan: «Minnun nɛn i o -nɔn 'mɛn bɛ, o va min -tʋwli 'ka 'sanlɛ dɩ.» 
\p  
\v 10 -A -sruzan nɛn Simɔn Piɛri -a bɛ, sɛn a -yrɔ, yaa 'sʋ 'e 'kɔlɛ 'ji, ɛn e Bali -pannɔn 'tazan 'suzan 'tʋ -pɛ "yi "da "trɔɛn cɛɛn. Min zɩɛ waa laabo Maku. 
\p  
\v 11 Ɛn Zozi "e Piɛri lɛ 'nan: «'I 'yie sɛn wʋ 'e 'kɔlɛ 'ji! 'Kulenɛn nɛn yra yɩdɩ cɩ -ji 'gʋɛ, 'an "tɩ -a 'pla 'mɛn, ma'an ve "man "cɛjɛ dɩ.» 
\p  
\v 12 'Sounjanun 'lee 'o 'tazan 'lee minnun nɛn Zuif 'nɔn 'tanɔn o 'pa 'sia bɛ, o Zozi 'kun, waa yrɩ,  
\v 13 ɛn o -kʋ -a 'e tɛdɛ min -tʋ nɛn waa laabo Ane bɛ -a va. Waa nan "tɩ laabo Kaifa, -yɛɛ cɩ lɛ 'bɔ zɩɛ -a -ji Bali -pannɔn 'tazan -a.  
\v 14 Kaifa zɩɛ, -yɛɛ 'wɩ tin 'ba "nɛn Zuif 'nɔn 'tanɔn lɛ. Yaa 'vɩ -wlɛ 'nan, -a "yi mlin -e min -tʋwli 'e min pɛɛnɔn 'lɛji -ka wʋ. 
\s1 Piɛri yɔɔ "da 'nan 'e 'ka Zozi -sruzan 'a dɩ 
\r (Mt 26.69-70; Mk 14.66-68; Lk 22.55-57) 
\p  
\v 15 Simɔn Piɛri 'lee Zozi -sruzan 'tʋ, 'bɛ sɔɔnla Zozi 'bɔ -sru. Zozi -sruzan 'tʋ zɩɛ Bali -pannɔn 'tazan 'bɔ -a -tɔa. -Yee "wɛan -yɛɛ wlala 'o 'vale Zozi 'a Bali -pannɔn 'tazan 'bɔ 'le -klɔn -ji.  
\v 16 'Pian Piɛri "e -fʋʋ bei -klɔn -yrɛ "nɛn. -A -sruzan 'tʋ bɛ, e 'li 'e da, ɛn e 'wɩ tin 'ba lɩmɔn nɛn 'e yiɛ -tɔa -klɔn 'bɔ -yrɛ "nɛn "bɛ -yrɛ. 
\p Tɔɔn, ɛn e -si -nɔn Piɛri lɛ,  
\v 17 yaa laabʋ Piɛri -lɔ 'nan: «Bii 'gʋɛ, -a -sruzan 'tʋ nɛn "nyian "yie "a?» 
\p Ɛn Piɛri "e 'nan -yrɛ 'nan: «An 'ka -a -sruzan 'a dɩ.» 
\p  
\v 18 Bali -pannɔn 'tazan 'bɔ 'sunɔn 'lee 'sounjanun nɛn -nan bɛ, o 'tɛ 'fɔ "nɛn, ɛn waa si -fɔ trun -taa "le "wɛan. Piɛri -tɔ o va, ɛn e 'tɛ "klandɩ 'sia. 
\s1 Bali -pannɔn 'tazan Ane 'wɩ laabʋ Zozi 'lɔ 
\p  
\v 19 Bali -pannɔn 'tazan 'wɩ laabʋ Zozi 'lɔ. Yaa laabʋ -yrɔ -a -srunɔn da, ɛn yaa laabʋ -yee 'wɩ "paadɩ da. 
\p  
\v 20 Ɛn Zozi "e 'nan -yrɛ 'nan: «An 'wɩ tin 'ba min pɛɛnɔn yiɛ man, ɛn yi pɛɛnɔn man te an 'wɩ "paaman minnun ji Bali trʋ 'ba 'kɔnnun -ji 'lee Bali -pan 'kɔnnun nɛn Zuif 'nɔn o cin ye -ji bɛ -a -ji. Ma'an 'wɩ 'tʋ drɛlɛ 'e yɔɔdɩ dɩ.  
\v 21 -Mɛ "le "wɛan i 'wɩ laabo 'an 'lɔ 'wɩ zɩɛ -a da? Minnun nɛn waan wei 'man bɛ, 'wɩ nɛn maan tin 'ba -wlɛ "bɛ, waa -tɔa. O lɔ nɛn 'i laabʋ.» 
\p  
\v 22 Zɩ Zozi 'wɩ zɩɛ -a 'vɩ bɛ, ɛn Bali -pannɔn 'tazan 'suzan 'tʋ nɛn 'e 'tɔdɩ Zozi "srɔn "bɛ, e 'pa 'fɔ Zozi yra, ɛn e 'nan -yrɛ 'nan: «-Tɩɛ 'vɩ 'yiɛ 'nan 'i 'wɩ tin 'ba Bali -pannɔn 'tazan lɛ zɩɛ?» 
\p  
\v 23 Ɛn Zozi -a 'vɩ -yrɛ 'nan: «-Te maan 'vɩ 'wlidɩ "bɛ, 'wɩ nɛn maan 'vɩ "va "wlidɩ "bɛ, 'i vɩ 'mɛn. Ɛn -te ma'an 'wɩ 'wlidɩ "vɩlɛ dɩɛ, -mɛ "le "wɛan nɛn i fɛ 'lɛ wo 'an 'ji?» 
\p  
\v 24 Ane Zozi 'tʋɩ 'e -yrɩdɩ, ɛn yaa -nɔn 'nan 'o 'kʋ -a Kaifa lɛ. -Yɛɛ cɩ Bali -pannɔn 'tazan -a lɛ 'bɔ zɩɛ -a -ji. 
\s1 Piɛri yɔɔ "da "nyian 'nan ya'a Zozi 'tɔa dɩ 
\r (Mt 26.71-75; Mk 14.69-72; Lk 22.58-62) 
\p  
\v 25 Tʋ zɩɛ -a wlu bɛ, te Simɔn Piɛri a tian 'e 'tɔdɩ 'tɛ man 'tɛ "klannan. Ɛn waa laabʋ -yrɔ 'nan: «Bii 'gʋɛ, -a -sruzan 'tʋ nɛn "nyian "yie "a?» 
\p Simɔn yɔɔ "da, ɛn e 'nan: «An 'ka -a -sruzan 'a dɩ.» 
\p  
\v 26 Bali -pannɔn 'suzan 'tʋ a fɛ 'bɔ zɩɛ -a -nan. Min nɛn Piɛri -a "trɔɛn cɛɛn bɛ, -a drɩ nɛn, e 'nan Piɛri lɛ 'nan: «Mɛin 'yɩ 'ka 'vale Zozi 'a fei.»  
\v 27 Piɛri yɔɔ "da "nyian. 'Nun tɔɔn, ɛn mannɛn wɩɩ. 
\s1 O -kʋ Zozi 'a Rɔm min -kɔnmandan Pilati 'lɛ 
\r (Mt 27.1-2, 11-14; Mk 15.1-5; Lk 23.1-5) 
\p  
\v 28 Bodrun puunɔn nɛn Zuif 'nɔn 'tanɔn 'si Zozi 'a Kaifa -va, ɛn o -kʋ -a Rɔm min -kɔnmandan -le -klɔn -ji. Zuif 'nɔn 'ka "o -wla "wʋlɛ Rɔm min -kɔnmandan -le -klɔn -ji dɩ, "tɔgɔ 'o "tri "tɔ Bali 'lɛ, -e 'o vɩlɛ 'o -kɔla Zuif 'nɔn 'le 'si nɔanba -ji "fɛdi da fɛnun -blɩdɩ -a dɩ. 
\p  
\v 29 -Yee "wɛan -kɔnmandan Pilati 'bɔ 'bɛ 'bɔla ɛn e -kʋ o va. Yaa laabʋ -wlɔ 'nan: «-Mɛ "wɩ nɛn min 'labɛ yaa drɛ, ɛn ka 'wɩ -tɔa "man?» 
\p  
\v 30 Ɛn o 'nan Pilati lɛ 'nan: «"Te 'wɩ 'wlidɩ "drɛzan "cɛɛ dɩɛ, "te kʋa 'talɛ -a 'i 'va 'gʋ dɩ.» 
\p  
\v 31 Ɛn Pilati -a 'vɩ -wlɛ 'nan: «'Ka 'bɔ, 'ka 'kʋ -a -e 'ka -yee 'wɩ tin 'ba "le zɩ 'cee -pei -a 'vɩ bɛ -yee 'wɩ 'zʋ.» 
\p Ɛn Zuif 'nɔn "o 'nan -yrɛ 'nan: «Ka'a -si -nɔnlɛ 'kʋɛ 'nan 'kʋ min -tɛ dɩ.»  
\v 32 Zɩ 'wɩ nɛn Zozi -a 'vɩ 'e 'cɛn 'yee -kadɩ da bɛ 'e 'lɛ sɔɔ zɩɛ. 
\p  
\v 33 Tɔɔn ɛn Pilati 'li 'e da 'yee -klɔn -ji. E Zozi laabʋ, ɛn yaa laabʋ -yrɔ 'nan: «Zuif 'nɔn 'le mingɔnnɛn nɛn 'yia?» 
\p  
\v 34 Ɛn Zozi -a laabʋ -yrɔ 'nan: «'I 'bɔ, yiɛ 'wɩ zɩɛ -a 'vɩ 'i 'bɔ 'a, -baa minnun 'bɛ 'vɩ ɛn "i "man?» 
\p  
\v 35 Pilati "e -yrɛ 'nan: «Zuif min nɛn maan? 'I 'bɔ flanɔn 'lee Bali -pannɔn 'tanɔn 'bɛ 'i 'nɔn 'nan 'mɛin 'tɛ. -Mɛ "nɛn yia drɛ?» 
\p  
\v 36 Ɛn Zozi "e 'nan: «'Trɛda minnun "cɛɛ 'an 'tɔ mingɔnnɛn -a dɩ. "Te -wɛɛ 'an 'tɔ mingɔnnɛn -a bɛ, "te 'an 'sunɔn 'an 'ta kuli -tan, -e minnun 'o vɩlɛ 'waan 'nɔn Zuif 'nɔn 'tanɔn lɛ dɩ. 'Trɛ 'gʋɛ -a da minnun "cɛɛ 'an 'tɔ mingɔnnɛn -a dɩ.» 
\p  
\v 37 Ɛn Pilati -a 'vɩ -yrɛ 'nan: «Yioo, mingɔnnɛn nɛn 'yia?» 
\p Zozi "e 'nan: «-Inyan, -a 'bɔ nɛn i "sia -a vɩnan bɛ an ya -a. An -ta 'trɛda 'nan -e 'an 'wɩ tɩglɩ vɩ minnun lɛ. -Yee "wɛan waan 'ya, minnun pɛɛnɔn nɛn o 'wɩ tɩglɩ -tɔa "bɛ, 'o "trɔɛn -tɔa 'an wei lɛ.» 
\p  
\v 38 Pilati -a laabʋ -yrɔ 'nan: «-Mɛ "nɛn 'wɩ tɩglɩ 'a?» 
\p Zɩ Pilati 'wɩ zɩɛ -a laabʋ bɛ, e 'bɔla, ɛn e -kʋ "nyian Zuif 'nɔn 'va. Ɛn e 'nan -wlɛ 'nan: «Ma'an 'wɩ 'tʋ yɩlɛ min 'gʋɛ -a man, -e min 'e 'ka -a 'wɩ 'ji dɩ.  
\v 39 'Pian 'wɩ nɛn -cɛɛ dra 'e 'cɛn bɛ, 'bɛ cɩ 'nan -te Zuif 'nɔn 'le 'si nɔanba -ji "fɛdi 'bɔ bɛ, an "sia -pʋ 'kɔnzan 'tʋ man. -Yee "wɛan maan laabo 'ka 'lɔ 'nan, ka ya "va 'nan 'an 'si Zuif 'nɔn 'le mingɔnnɛn man?» 
\p  
\v 40 Tɔɔn, ɛn o pɛɛnɔn -paandɩ 'sia 'e cin va. Waa ve 'nan: «-Cɛjɛ oo! -Cɛjɛ oo! Te 'i 'si min 'labɛ 'bɛ man dɩ oo! Barabazi man nɛn 'i 'si o!» Barabazi 'bɔ zɩɛ, min nɛn e min -tɛ bɛ -nyrɛn. 
\c 19  
\p  
\v 1 Ɛn Pilati "e 'nan 'sounjanun lɛ 'nan 'o Zozi 'kun, -e 'o -sɔn -ngble -a.  
\v 2 'Sounjanun 'bɔ lei 'tan, ɛn waa 'wʋ -a -wulo -man "le -yee mingɔnnɛn kle 'zʋ. O mingɔnnɛn -tralɛ 'tɛndɛn 'tʋ 'si, ɛn waa 'wʋ "da.  
\v 3 O -pli "man -a "srɔn te waa ve -yrɛ 'nan: «Zuif 'nɔn 'le mingɔnnɛn, 'tɩɩ 'tɔ bo», -e 'o 'pa 'fɔ -a yra. 
\p  
\v 4 Pilati 'bɔla "nyian, ɛn e 'nan Zuif 'nɔn lɛ 'nan: «An "ta -a bɔala 'cɛɛ bei -e 'ka -tɔ 'nan ma'an 'wɩ 'tʋ yɩlɛ "man -e 'e 'ka -a 'wɩ 'ji dɩ.»  
\v 5 Ɛn Zozi 'bɔla te lei kle "a -a -wulo -man, ɛn mingɔnnɛn -tralɛ a "da. -A -nan nɛn, Pilati "e 'nan -wlɛ 'nan: «'Cee min bɛ, -nyrɛn "bɛ.» 
\p  
\v 6 Zɩ Bali -pannɔn 'tanɔn 'lee o 'sunɔn -a 'yɩ bɛ, ɛn o -paandɩ 'sia. Waa ve 'nan: «'I -pɛin yiba "plan da! 'I -pɛin yiba "plan da!» 
\p Ɛn Pilati "e -wlɛ 'nan: «'Ka 'si, -e 'ka -pɛin yiba "plan da 'ka 'bɔ 'a! Kɔɔ ma'an 'wɩ 'tʋ yɩlɛ "man -e 'e 'ka -a 'wɩ 'ji dɩ.» 
\p  
\v 7 Zuif 'nɔn "o 'nan -yrɛ 'nan: «'Kʋe -pei -tɔ 'wɩ 'tʋ a. 'Kʋe -pei -tɔ wɩ zɩɛ -a pɛ -ji nɛn waa -tɛa, kɔɔ e 'nan Bali -pɩ nɛn 'yaa.» 
\p  
\v 8 Zɩ Pilati 'wɩ zɩɛ -a 'man bɛ, ɛn -yee "klandɩ 'pa "da.  
\v 9 Pilati wla "nyian 'yee -klɔn -ji, ɛn yaa laabʋ Zozi 'lɔ 'nan: «I "sia nyin?» 'Pian Zozi 'ka 'wɩ 'tʋ 'silɛ "da "dɩ.  
\v 10 Ɛn Pilati "e -yrɛ "mɛn 'nan: «'An 'bɔ 'lɛ nɛn yi'a 'wɩ 'tʋ sia "da "dʋʋ? Yi'a tɔa 'nan -a -si a 'an 'lɔ -e 'an 'si 'i man dʋʋ, ɛn -te 'bɛ "cɛɛ dɩ -e 'mɛin -pɛin yiba "plan da dʋʋ?» 
\p  
\v 11 Zozi "e 'nan -yrɛ 'nan: «Yi'a 'kɔlaman fɛ -tʋ drɛdɩ -a 'mɛn, te Bali "cɛɛ -si -nɔn dɩ, -yee "wɛan min nɛn yaan 'nɔn 'yiɛ bɛ, -yee 'wɩ 'wlidɩ 'bɛ cɩ -dan.» 
\p  
\v 12 Zɩ Pilati 'wɩ zɩɛ -a 'man bɛ, ɛn yaa -wɛɛdɩ 'sia 'nan 'e "sia Zozi man. 'Pian te Zuif 'nɔn -paanman 'nan: «-Te i 'si "man "bɛ, te 'i 'ka Rɔm 'nɔn 'le mingɔnnɛn tazan Seza bee -a dɩ. Kɔɔ min nɛn e 'fli drɛ mingɔnnɛn -a bɛ, te -a pei a 'e 'padɩ "man.» 
\p  
\v 13 Zɩ Pilati 'wɩ zɩɛ 'bɛ 'man "nyian bɛ, ɛn e 'nan 'o Zozi bɔla bei. Tɔɔn ɛn Pilati 'bɔ -nyran 'yee tin 'ba pɛin -da. Fɛ zɩɛ -a -nan a 'e wluandɩ, waa drɛ -kɔlɛ -a "le lazo nɛn waa -fɔ. Waa laabo Ebre wei -ji «Gabata».  
\v 14 Te yidɛ 'bɔ min -win -ji 'sɛzɛ, ɛn Zuif 'nɔn a 'wee 'si nɔanba -ji "fɛdi man drɛnan. 
\p -A -nan nɛn Pilati "e 'nan Zuif 'nɔn 'tanɔn lɛ 'nan: «'Cee mingɔnnɛn 'bɔ nɛn bɛ.» 
\p  
\v 15 Ɛn o -paandɩ 'sia 'nan: «'O -tɛ, 'o -tɛ! 'I -pɛin yiba "plan da!» 
\p Ɛn Pilati -a laabʋ -wlɔ 'nan: «'An 'cee mingɔnnɛn -pɛin yiba "plan da?» 
\p Tɔɔn ɛn Bali -pannɔn 'tanɔn -a 'vɩ -yrɛ 'nan: «'Kʋe mingɔnnɛn a -tʋwli "cɛ, waa laabo mingɔnnɛn Seza.» 
\p  
\v 16 'Wɩ zɩɛ -a da nɛn Pilati 'e 'pɛ 'si Zozi da, ɛn yaa -pɛindɩ yiba "plan da -si -nɔn. 
\s1 Zozi -pɛinnan yiba "plan da 
\r (Mt 27.32-44; Mk 15.21-32; Lk 23.26-43) 
\p 'Sounjanun -kʋ Zozi 'a.  
\v 17 Zozi 'bɔ 'bɛ 'yee yiba "plan 'sia, ɛn o -kʋ -a fɛnan nɛn waa laabo min -wulo klo bɛ -a -nan. Waa ve Ebre wei -ji «Gɔlgota».  
\v 18 Fɛ zɩɛ -a -nan nɛn waa pɛin yiba "plan da. O min -tʋ pɛin yiba "plan da -a -pɛ "yi "da, ɛn o min -tʋ pɛin "nyian yiba "plan da -a -pɛ bʋ da. 
\p  
\v 19 Pilati "e 'nan 'o yiba 'fʋɩnɛn da 'crɛn -tɛ, -e 'o 'pa Zozi 'le yiba "plan ta lou. Waa 'crɛn -tɛ "da 'nan: 
\qc «Zuif 'nɔn 'le mingɔnnɛn, Nazarɛtɩ min Zozi.» 
\m  
\v 20 'Wɩ 'bɔ a 'e 'crɛn -tɛdɩ Ebre wei -ji, ɛn e ya 'e 'crɛn -tɛdɩ Latɛn wei -ji, ɛn e ya 'e 'crɛn -tɛdɩ "nyian Grɛk wei -ji. Zuif 'nɔn "kaga 'wɩ zɩɛ -a ta 'vɩ, kɔɔ fɛnan nɛn o Zozi pɛin yiba "plan da bɛ, e ya 'fla "srɔn "kogo.  
\v 21 Ɛn Bali -pannɔn 'tanɔn 'kʋ -a vɩlɛ Pilati lɛ 'nan: «Te 'e 'kɔn 'e 'crɛn -tɛdɩ Zuif 'nɔn 'le mingɔnnɛn dɩ! 'Pian 'i crɛn -tɛ 'nan, e 'nan 'e ya Zuif 'nɔn 'le mingɔnnɛn -a!» 
\p  
\v 22 Pilati -a 'vɩ -wlɛ 'nan: «'Wɩ nɛn maan crɛn -tɛ bɛ, ma'an "nyian -a limlan dɩ.» 
\p  
\v 23 Zɩ 'sounjanun cɛɛn Zozi -pɛindɩ man yiba "plan da bɛ, ɛn o sɔnun nɛn waa 'sʋ "da "bɛ, waa 'pla sinjɛn, ɛn waa 'sia 'tʋdʋ. -Yee sɔ -gblɔ -tʋ nɛn wɛɛ pee 'tʋwli "plɔun bɛ, wɛɛ 'si,  
\v 24 Ɛn waa 'vɩ 'o cin yei 'nan: «Te -kaa 'fʋɩ bʋʋ dɩ, 'pian -kaa 'lein 'wlɛ tuʋla, -e min nɛn e -tria "da "bɛ, 'o -nɔn -yrɛ.» 
\p Zɩ Bali wei nɛn 'e 'crɛn -tɛdɩ 'e 'cɛn bɛ e 'lɛ sɔɔ zɩɛ. E ya 'e 'crɛn -tɛdɩ 'nan: 
\q1 «O 'mɛn sɔ pli 'o cin yei, 
\q1 ɛn o 'mɛn sɔ -gblɔ 'si 
\q1 'lein 'wlɛ 'tuʋladɩ da.» 
\m 'Wɩ zɩɛ -a 'bɔ nɛn 'sounjanun -a drɛ. 
\p  
\v 25 Tʋ zɩɛ -a wlu bɛ, te yiba "plan nɛn o Zozi pɛin "da "bɛ, lɩmɔn sinjɛn a 'o 'tɔdɩ "wlu. Zozi 'bɔ "bʋ 'lee Zozi "bʋ "blu 'lee Klopa nan Mari 'lee Madala lɩ Mari.  
\v 26 Zɩ Zozi 'e "bʋ 'yɩ, te 'e -sruzan nɛn yaa ye "yi "bɛ -a ye 'e 'tɔdɩ 'e "bʋ "srɔn "bɛ, ɛn e 'nan 'e "bʋ "lɛ 'nan: «'I 'pɩ nɛn bɛ o.»  
\v 27 Ɛn Zozi -a 'vɩ 'e -sruzan zɩɛ -yrɛ 'nan: «'I "bʋ "nɛn bɛ o.» 'Wɩ nɛn Zozi -a 'vɩ bɛ, -a da nɛn -a -sruzan -a drɛ, 'e yiɛ 'tɔ -a "bʋ 'va. 
\s1 Zozi 'kanan 
\r (Mt 27.45-56; Mk 15.33-41; Lk 23.44-49) 
\p  
\v 28 Zozi -a -tɔ 'nan 'e 'wɩ pɛɛnɔn 'lɛ sɔɔ, ɛn e 'nan "mɛn 'nan: «'Yi dra 'an -tɛa.» Zɩ 'wɩ nɛn 'e 'crɛn -tɛdɩ bɛ 'e 'lɛ sɔɔ zɩɛ.  
\v 29 -Wɛn 'wlɛ nɛn e -fɔla -trilii bɛ, -a -pɔ -tʋ a 'sounjanun 'bɔ 'lɔ -wee mlinvɛ -a. Ɛn o sɔ -tʋ 'si, waa 'fɔ -wɛn zɩɛ -a, waa yrɩ -cɛan "nɛn, ɛn waa -tɔ -a 'lɛbo "nɛn.  
\v 30 Zɩ Zozi cɛɛn -a flɔndɩ man "ji "bɛ, ɛn e 'nan: «'Wɩ pɛɛnɔn 'e 'lɛ sɔɔ "mɛn.» -A -nan nɛn 'e 'wulo -fɔ 'e 'wlu, ɛn 'e yiɛ 'lɛ 'wʋ. 
\p  
\v 31 'Yaa yi da nɛn, ɛn Zuif 'nɔn 'tanɔn 'kʋ Pilati trʋ 'balɛ 'nan minnun nɛn o o -pɛin yiba "plan da bɛ, o o cɛin "yee -e 'o o 'si 'nan. Waa drɛ zɩɛ, kɔɔ -te tʋ cɛɛn bɛ, -wee 'flinla "yi nɛn, ɛn o 'ka "vale min -kadɩ 'e 'fʋ 'e 'padɩ yiba "plan da dɩ. 
\p  
\v 32 Pilati 'sounjanun 'pa 'sia 'nan 'o 'kʋ -a drɛ. Zɩ 'o 'bɔla 'nan nun bɛ, ɛn min "fli "nɛn o o pɛin Zozi "srɔn "bɛ, waa -tʋ cɛin "fli yee, ɛn waa -tʋ cɛin "fli yee.  
\v 33 O 'bɔ Zozi da, ɛn waa 'yɩ 'nan e ya 'e 'kadɩ -yee "wɛan wa'a cɛin "yeelɛ dɩ.  
\v 34 'Pian 'sounja min -tʋ Zozi 'fɔn 'e 'sɛan da 'yee -tin -a. 'Nun tɔɔn 'yi -sran, ɛn nyɛn -sran. 
\p  
\v 35 Min 'bɔ nɛn e 'wɩ 'gʋɛ -a -nan 'yɩ bɛ, -a san 'bɛ 'vɩ. Yaa 'vɩ 'nan -e 'ka 'bɔ "nyian 'ka yi -tɛra "da. 'Wɩ nɛn yaa 'vɩ 'gʋɛ, 'wɩ 'kpa nɛn, ɛn -a 'bɔ "e -tɔa 'nan e ya 'wɩ 'kpa -a. 
\p  
\v 36 'Wɩnun 'bɔ zɩɛ e drɛ 'nan -e Bali wei nɛn 'e 'crɛn -tɛdɩ bɛ 'e 'lɛ sɔɔ. E ya 'e 'crɛn -tɛdɩ 'nan: 
\q1 «-A 'wlɛ -tʋwli 'ka 'wia dɩ.» 
\m  
\v 37 Ɛn e ya "nyian 'e 'crɛn -tɛdɩ fɛ pee -nan 'nan: 
\q1 «Min nɛn waa 'fɔn bɛ, 
\q1 -a lɛ nɛn min pɛɛnɔn yiɛ 'e 'fʋ.» 
\s1 Zozi wʋnan 
\r (Mt 27.57-61; Mk 15.42-47; Lk 23.50-56) 
\p  
\v 38 Min -tʋ nɛn waa laabo Zozɛfʋ bɛ, e "sia Arimate, Zozi -sruzan nɛn. 'Pian 'e "klanman Zuif 'nɔn 'tanɔn 'lɔ 'le "wɛan, e ya -a -sru 'e yɔɔdɩ. Zozɛfʋ -si trʋ 'ba Pilati -lɔ 'nan 'e Zozi pa -nɔn 'yrɛ -e 'e wʋ. Pilati -a -si -nɔn -yrɛ, ɛn e -kʋ Zozi 'kadɩ 'bɔ 'silɛa.  
\v 39 Nikodɛm nɛn yi -tʋ da e -kʋ Zozi 'va -pei -man bɛ, "e "ta wʋ "nyian 'e 'lɔ le 'yile nɛn waa wo min pa man bɛ -a. 'Yile zɩɛ, e ya 'e baadɩ mire 'lee aloe -a, ɛn -a kilo a -fuba yaaga.  
\v 40 'O 'vale Zozɛfʋ -a, -wɛɛ Zozi pa yrɩ. O 'yile -sɛn sɔ ji ɛn waa drɛ 'a. Zɩ Zuif 'nɔn 'wee pa dra zɩɛ -e 'o wʋ. 
\p  
\v 41 Fɛnan 'bɔ nɛn o Zozi pɛin yiba "plan da bɛ, fei -tʋ a -a "srɔn. Fei zɩɛ -a da bɛ, min -yrɛ nɛn waa cɛɛn -kɔlɛ -ji bɛ -a -tʋ a -nan. -Yrɛ zɩɛ wa'a tian min wʋlɛ "ji "dɩ.  
\v 42 -A 'bɔ 'ji nɛn o Zozi 'wʋ. Zuif 'nɔn 'le 'flinla "yi a -tanan bɔdɩ -a, ɛn -yrɛ 'bɔ a "nyian -kogo -yee "wɛan -a ji nɛn o Zozi 'wʋ. 
\c 20  
\s1 Zozi wluan -kanɔn 'va 
\r (Mt 28.1-8; Mk 16.1-8; Lk 24.1-12) 
\p  
\v 1 'Mɔnnɛn yi da, bodrun puunɔn, te klunglun 'nɛn a tian, ɛn Madala lɩ Mari -kʋ Zozi -yrɛ da. -Kɔlɛ nɛn o -yrɛ 'bɔ 'lɛ 'wʋ 'a bɛ, yaa 'yɩ 'e 'sidɩ "nɛn.  
\v 2 Mari 'li 'e da flan -a, ɛn e -kʋ e 'bɔ Simɔn Piɛri 'lee Zozi -sruzan 'tʋ nɛn Zozi -a ye "yi "bɛ o man, ɛn e 'nan -wlɛ 'nan: «O Minsan pa 'si 'yrɛ -ji, ɛn fɛnan nɛn o kʋ -a bɛ kʋ'a tɔa dɩ.» 
\p  
\v 3 Piɛri 'lee Zozi -sruzan zɩɛ o 'bɔla ɛn o -kʋ -yrɛ da.  
\v 4 O "flinɔn 'ko flan -a, 'pian min -tʋ bɛ, e flan bli e mlin Simɔn Piɛri da. -Yɛɛ 'bɔla -yrɛ da 'e 'flin.  
\v 5 'Pian ya'a -wlalɛ -nan nun dɩ, e 'kunnan ɛn 'e yiɛ 'tɔ -yrɛ 'bɔ 'ji. Sɔnun nɛn waa 'pa Zozi man bɛ yaa 'yɩ.  
\v 6 Simɔn Piɛri 'bɔla -yee -sru, ɛn "bɛ wla 'wʋ 'yrɛ 'bɔ 'ji nun. E sɔnun nɛn waa 'pa Zozi man bɛ -a 'yɩ 'e -srandɩ.  
\v 7 Sɔ nɛn waa -tɔ Zozi 'wulo -man bɛ, yɛɛ 'yɩ 'e -srandɩ 'e 'to, te e ya 'e plindɩ.  
\v 8 Ɛn Zozi -sruzan nɛn e 'bɔla paan 'e tɛdɛ bɛ, "e wla 'wʋ "nyian -yrɛ 'bɔ 'ji nun. Zɩ yaa -nan 'yɩ bɛ, ɛn e yi -tɛra "da 'nan Zozi wluan -kanɔn 'va.  
\v 9 Tʋ zɩɛ -a wlu bɛ, te 'wɩ nɛn 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan: Zozi -kaa -e 'e 'wluan -kanɔn 'va bɛ, -a -srunɔn 'ka tian -a -ci manlɛ dɩ.  
\v 10 Zozi -srunɔn "fli "bɛ, o 'li 'o da 'wee vɛ -nan. 
\s1 Zozi 'e 'fli kɔɔn Madala lɩ Mari lɛ 
\r (Mt 28.9-10; Mk 16.9-11) 
\p  
\v 11 Ɛn Mari "e fʋʋ 'e 'tɔdɩ -yrɛ 'bɔ "srɔn, te e -wua. E ya -wuɔnan ɛn e 'kunnan 'e yiɛ 'tɔ -yrɛ -ji nun.  
\v 12 Ɛn e Bali -le 'pasianɔn nɛn laji bɛ o "fli 'yɩ 'o 'ta le sɔ 'fuvu 'a fɛnan nɛn o Zozi pa 'pla bɛ -a -nan. -A -tʋ a 'e -nyrandɩ -a -wulo -man zia, ɛn -a -tʋ a 'e -nyrandɩ -a cɛin -man zia. 
\p  
\v 13 Bali -le 'pasianɔn -a laabʋ lɩ zɩɛ -yrɔ 'nan: «-Mɛ "le "wɛan nɛn i ya -wuɔnan?» 
\p Ɛn lɩ bɛ e -wlɛ 'nan: «Minnun 'an 'san pa 'si 'yrɛ -ji, ɛn fɛnan nɛn waa 'pla bɛ ma'an tɔa dɩ, -yee "wɛan an ya -wuɔnan.» 
\p  
\v 14 E 'wɩ zɩɛ -a 'vɩ, "yɛɛ vɩnan 'e man lila, te e min -tʋ ye 'e 'tɔdɩ. Min zɩɛ Zozi nɛn, 'pian ya'a -tɔlɛ 'nan Zozi nɛn dɩ. 
\p  
\v 15 Ɛn Zozi 'bɔ -a laabʋ -yrɔ 'nan: «-Mɛ "le "wɛan nɛn i ya -wuɔnan? -Tɩ nɛn yia -wɛɛman?» 
\p Mari -a nrɔn 'e 'ji 'nan min nɛn e 'nyranman "paa fei 'bɔ da bɛ -nyrɛn. Ɛn e 'nan -yrɛ 'nan: «'An 'san, -te yiɛ 'si 'yrɛ -ji bɛ, fɛnan nɛn yia 'pla bɛ, 'i vɩ 'mɛn -e 'an 'kʋ -a 'sia.» 
\p  
\v 16 Ɛn Zozi -a laabʋ: «Mari!» 
\p Mari 'e man lila, ɛn yaa 'vɩ -yrɛ Ebre wei -ji 'nan: «Rabuni!» -A -ci nɛn 'nan Bali -le 'wɩ "paazan. 
\p  
\v 17 Zozi "e -yrɛ 'nan: «Te 'i klɛ 'an man dɩ! Ma'an tian 'kʋlɛ 'an "tɩ 'va dɩ. 'I 'kʋ -a vɩ 'an "bʋɩnun lɛ 'nan: ‹An "ta -ko 'an "tɩ 'va, e ya 'ka "tɩ "a. An "ta -ko 'mɛn Bali va, e ya 'cee Bali -a.› » 
\p  
\v 18 Ɛn Madala lɩ Mari -kʋ -a vɩlɛ Zozi -srunɔn lɛ. Yaa 'vɩ -wlɛ 'nan 'e Minsan 'yɩ, ɛn e 'wɩ nɛn Zozi -a 'vɩ -yrɛ "bɛ, -a tin 'ba -wlɛ. 
\s1 Zozi 'e 'fli kɔɔn 'e -srunɔn lɛ 
\r (Mt 28.16-20; Mk 16.14-18; Lk 24.36-49) 
\p  
\v 19 'Mɔnnɛn yi 'bɔ 'lein zɩɛ -a funninmlan, ɛn Zozi -srunɔn 'o cin 'yɩ 'kɔn 'tʋ -ji. 'Kɔn zɩɛ waa -fɔ -ji, o ya "klannan Zuif 'nɔn 'tanɔn 'lɔ 'le "wɛan. 'Nun tɔɔn, ɛn Zozi 'bɔla o va, e -tɔ o yei, ɛn e -wlɛ 'nan: «Bali 'e 'fʋdɩ -trɔɔ -nɔn 'cɛɛ!»  
\v 20 E 'wɩ zɩɛ -a 'vɩ, ɛn 'e -pɛlanun kɔɔn -wlɛ 'lee 'e 'sɛan da. Zɩ o Minsan 'yɩ bɛ, o 'ci nran. 
\p  
\v 21 Ɛn Zozi -a 'vɩ "nyian -wlɛ 'nan: «Bali 'e 'fʋdɩ -trɔɔ -nɔn 'cɛɛ! Zɩ 'an "tɩ 'an 'pa 'sia bɛ, -a da nɛn 'an 'bɔ "nyian "an 'ka "paa -sia.»  
\v 22 E cɛɛn 'wɩ zɩɛ -a vɩdɩ man, tɔɔn ɛn 'e 'le fulɔ fɛɛn o man, ɛn yaa 'vɩ -wlɛ 'nan: «Bali lei 'saun nɛn bɛ, e ya 'cee vɛ -a, 'ka 'si.  
\v 23 Minnun nɛn o 'wɩ 'wlidɩ drɛ, ɛn kaa 'vɩ 'nan -wee 'wɩ 'wlidɩ fui bɛ, te Bali -wee 'wɩ 'wlidɩ fui. Ɛn -te ka'a -wee 'wɩ 'wlidɩ "fuilɛ dɩɛ, Bali 'ka -wee 'wɩ 'wlidɩ 'fuiman dɩ.» 
\s1 Zozi 'e 'fli kɔɔn Toma lɛ 
\p  
\v 24 Tʋ zɩɛ -a wlu bɛ, -a -sruzan 'tʋ nɛn waa laabo Toma bɛ, te e 'ka 'nan dɩ. Waa laabo "nyian "flɛn.  
\v 25 Zɩ e -ta bɛ, ɛn Zozi -srunɔn -mienun -a 'vɩ -yrɛ 'nan: «Kʋ Minsan 'yɩ.» 
\p Ɛn e 'nan -wlɛ 'nan: «-Te ma'an tian -a -pɛ nɛn waa pɛin bɛ -a "pa 'ji yɩlɛ dɩɛ, ma'an yi 'tɛala "da 'mlɔnmlɔn dɩ. 'An 'pɛ 'wlɛ -tɔala -a "pa 'ji, ɛn 'an 'pɛ "paa -a 'sɛan 'ji 'vaa, ɛn an yi -tɛala 'wɩ nɛn kaa 'vɩ 'gʋɛ -a da.» 
\p  
\v 26 Yi 'sɔra "bɛ -sru, Zozi -srunɔn a 'o cin yɩdɩ "nyian 'kuin, te Toma a 'siɛn o va. 'Kɔn 'bɔ -kpɛinnun a 'e 'fɔdɩ -ji, 'nun tɔɔn ɛn Zozi bɔla o va, e -tɔ o yei ɛn e 'nan -wlɛ 'nan: «Bali 'e 'fʋdɩ -trɔɔ -nɔn 'cɛɛ.»  
\v 27 Ɛn Zozi -a 'vɩ Toma lɛ 'nan: «'An -pɛlanun nɛn 'gʋ, 'i -pli 'i -pɛ 'wlɛ 'a 'gʋ, ɛn 'i 'pɛ 'pa "nyian 'an 'sɛan 'ji. 'I yi -tɛra "da, te 'i 'ci -fɔɔ "nyian dɩ.» 
\p  
\v 28 Toma "e -yrɛ 'nan: «Yiɛ cɩ 'an 'san -a, ɛn yiɛ cɩ 'mɛn Bali -a.» 
\p  
\v 29 Ɛn Zozi -a 'vɩ -yrɛ "mɛn 'nan: «Yian 'yɩ, -yee "wɛan nɛn i yi -tɛra 'an da. Minnun nɛn o yi -tɛala 'an da te wa'a 'an yɩlɛ dɩɛ, Bali -le -fɛa a o man.» 
\s1 -Mɛ "le "wɛan nɛn o 'fluba 'gʋɛ -a crɛn -tɛ? 
\p  
\v 30 Zozi 'lɛbo "fɔ wɩ "kaga drɛ 'e -srunɔn yiɛ man, te 'bɛ 'ka 'e 'crɛn -tɛdɩ 'fluba 'gʋɛ -a -ji dɩ.  
\v 31 'Pian 'wɩnun nɛn 'gʋɛ, wɛɛ 'crɛn -tɛ 'nan -e 'ka yi -tɛra "da 'nan min nɛn Bali -a 'si "va, ɛn e ya Bali -pɩ -a bɛ Zozi nɛn. -Te ka yi -tɛra Zozi da bɛ, 'belidɩ nɛn ya'a 'nyaan dɩɛ, e dra 'cee vɛ -a. 
\c 21  
\s1 Zozi 'e 'fli kɔɔn 'e -srunɔn 'sɔravli "lɛ 
\p  
\v 1 "Bɛ -sru ɛn Zozi 'e 'fli kɔɔn 'e -srunɔn lɛ "nyian 'yi nɛn waa laabo Tiberia bɛ -a man. Zɩ 'e 'fli kɔɔn -wlɛ "bɛ, -a -nan wɩ nɛn 'gʋ.  
\v 2 Yi -tʋ da te -a -srunɔn a 'o cin yɩdɩ. Simɔn Piɛri, 'lee Toma nɛn waa laabo "nyian "flɛn bɛ, 'lee Natanaɛl nɛn 'e "sia 'fla nɛn waa laabo Kanan bɛ -a da Galile 'lɛglɔn 'ji bɛ, 'lee Zebede -pɩnun 'lee Zozi -srunɔn "fli "pee 'bɛ cɩ.  
\v 3 Ɛn Simɔn Piɛri -a 'vɩ -wlɛ 'nan: «An "ta -ko pɔ -tɛlɛ.» O 'nan -yrɛ 'nan: «'Kʋ 'bɔ "nyian, "kʋ -koo 'i -sru.» O -kʋ, ɛn o -fɔ -klʋ -ji. -Pei zɩɛ -a man bɛ, wa'a pɔ -tɛlɛ 'mlɔnmlɔn dɩ. 
\p  
\v 4 Tʋ "ɛ vɩnan 'e 'cɛn bodrun, te Zozi a 'e 'tɔdɩ 'yi 'plo da. 'Pian Zozi -srunɔn 'ka -a -tɔlɛ "le Zozi nɛn dɩ. 
\p  
\v 5 Ɛn Zozi -a laabʋ -wlɔ 'nan: «-Gobonun, ka pɔ "tiɛnnɛn 'yɩ?» 
\p O 'nan -yrɛ 'nan: «-Cɛjɛ, kʋ'a -vɛ -tɛlɛ dɩ.» 
\p  
\v 6 Ɛn Zozi "e 'nan -wlɛ 'nan: «'Ka 'cee "se 'wɛɛn -klʋ 'bɔ -pɛ "yi "da zia, pɔ -sɛan "ji.» Waa drɛla "da, ɛn pɔ "kaga "sɛn -wee "se "ji, -yee "wɛan wa'a -kɔlalɛ "nyian "se zɩɛ -a -klandɩ -a dɩ. 
\p  
\v 7 -A -nan nɛn Zozi -sruzan 'tʋ nɛn Zozi -a ye "yi "bɛ, e 'nan Piɛri lɛ 'nan: «Minsan nɛn!» Zɩ Simɔn Piɛri -a 'man 'nan Minsan nɛn bɛ, ɛn e 'yee sɔ nɛn yaa wo sɔ ta lou "bɛ -a 'sia, yaa 'wʋ 'e man, ɛn e -fɔ 'yi 'va 'nan -e 'e 'kʋ 'yi 'plo man. E sɔ zɩɛ -a 'sʋ 'e man 'nyranman 'padɩ -le "wɛan. 
\p  
\v 8 Zozi -srunɔn -mienun bɛ, "o "ta 'wʋla 'klʋ -ji, te o -taa "se "nɛn 'e fadɩ pɔ -a bɛ -a -klandɩ -a 'o -sru. Fɛnan nɛn o 'si bɛ, -a -nan bɔa -mɛnliɛ -fuba 'soolu.  
\v 9 Zɩ o sɔɔnla 'klʋ -ji bɛ, ɛn o 'tɛ 'yɩ 'e 'sɔndɩ, te pɔ a "da 'e 'padɩ, ɛn 'kpɔun a -a "srɔn. 
\p  
\v 10 Ɛn Zozi "e 'nan -wlɛ 'nan: «Pɔ nɛn kaa -tɛ bɛ, 'ka 'ta -a -mie -a.» 
\p  
\v 11 Simɔn Piɛri -fɔ -klʋ -ji, ɛn e "se "nɛn 'e fadɩ pɔ -dandan -a bɛ -a klan 'yi 'plo man. Pɔ a "se 'bɔ 'ji "kaga, -a -yaa tʋ -fuba 'soolu 'wlɛ yaaga bɔa, 'pian ya'a 'fʋɩ bʋlɛ dɩ. 
\p  
\v 12 Ɛn Zozi -a 'vɩ -wlɛ 'nan: «'Ka 'ta fɛnun -blɩ!» -A -srunɔn 'bɔ 'tʋ 'ka -kɔlalɛ -a laabʋdɩ -a -yrɔ 'nan -tɩ nɛn dɩ. Kɔɔ o pɛɛnɔn -a -tɔ 'nan Minsan 'bɔ nɛn.  
\v 13 Zozi pli o "srɔn, e 'kpɔun 'sia, yaa pli o man, ɛn e pɔ 'sia, yaa pli o man. 
\p  
\v 14 Zozi 'fli -kɔɔndɩ 'e -srunɔn lɛ te 'e wluan -kanɔn 'va bɛ, -a 'pa yaagazan nɛn zɩɛ. 
\s1 Zozi 'wɩ tin 'ba Piɛri lɛ 
\p  
\v 15 Zɩ o cɛɛn fɛnun -blɩdɩ man bɛ, ɛn Zozi -a laabʋ Simɔn Piɛri -lɔ 'nan: «Zan -pɩ Simɔn, yian ye "yi e "mlian 'i bɔɛnun 'gʋɛ -wee 'an yɩdɩ "yi "da?» 
\p Simɔn "e -yrɛ 'nan: «-Inyan, Minsan, yia -tɔa 'nan mɛin ye "yi.» 
\p Ɛn Zozi "e -yrɛ 'nan: «'I yiɛ 'tɔ 'mɛn 'bla 'nɛnnun va!» 
\p  
\v 16 Zozi -a 'pa "flizan laabʋ -yrɔ. E 'nan: «Zan -pɩ Simɔn, yian ye "yi?» 
\p Piɛri "e -yrɛ 'nan: «-Inyan, Minsan, yia -tɔa 'nan mɛin ye "yi.» 
\p Ɛn Zozi "e -yrɛ 'nan: «'I yiɛ 'tɔ 'mɛn 'blanun va!» 
\p  
\v 17 Zozi -a 'pa yaagazan laabʋ "nyian -yrɔ. E 'nan: «Zan -pɩ Simɔn, yian ye "yi?» 
\p Ɛn Piɛri ta drɛ 'trɔdrɔ, kɔɔ e 'wɩ -tʋwli laabʋ -yrɔ 'e cin -sru 'e 'pa -a yaaga. Ɛn Piɛri -a 'vɩ -yrɛ 'nan: «Minsan, i 'wɩ pɛɛnɔn tɔa. Yia -tɔa 'nan mɛin ye "yi.» 
\p Ɛn Zozi -a 'vɩ -yrɛ 'nan: «'I yiɛ 'tɔ 'mɛn 'blanun va!  
\v 18 Maan ve yiɛ 'wɩ tɩglɩ 'a 'nan: Tʋ nɛn te i ya "wɛnnɔn bɛ, yiɛ 'i -tiɛn -tɔa 'i 'bɔ 'a -e 'i 'kʋ fɛnan nɛn i cɩ "va "bɛ -a -nan. 'Pian tʋ nɛn i dra ceje bɛ, min pee 'bɛ 'i -yrɩman -e 'e 'kʋ 'yia fɛnan nɛn i 'ka "va "dɩɛ -a -nan.» 
\p  
\v 19 Zɩ Piɛri -taa "kalɛ -e 'e Bali 'tɔ drɛ -dan bɛ, -a da -kɔnnɛn "nɛn Zozi -a -fɔ. E cɛɛn 'wɩ zɩɛ -a vɩdɩ man, ɛn e 'nan Piɛri lɛ 'nan: «'I -sɔɔnla 'an -sru!» 
\p  
\v 20 Piɛri 'e 'man 'lila, ɛn 'e yiɛ 'tɔ 'o -sru, te e Zozi -sruzan nɛn Zozi -a ye "yi 'kpa bɛ -a ye. -A -sruzan zɩɛ, -yɛɛ tɛɛn yi -tʋ da Zozi 'pɛ -ji, te o ya fɛnun -blɩnan, ɛn yaa laabʋ -yrɔ 'nan: «Minsan, -tɩɛ "ta 'i -nɔan 'i 'nanmannɔn lɛ?»  
\v 21 Zɩ Piɛri -a 'yɩ bɛ, ɛn yaa laabʋ Zozi 'lɔ 'nan: «Minsan, min 'labɛ "nun, -mɛ "wɩ 'bɛ bɔa -yee "man?» 
\p  
\v 22 Ɛn Zozi -a 'vɩ -yrɛ 'nan: «-Te an ya "va 'nan 'e 'fʋ -trilii -e 'an 'tadɩ 'e bɔ bɛ, 'yie 'wɩ 'tʋ 'ka 'ji dɩ. 'I 'bɔ, 'i -sɔɔnla 'an -sru.» 
\p  
\v 23 "Wɩ zɩɛ e fuila "man "bʋɩnun yei 'nan Zozi -sruzan zɩɛ, ya'a 'li 'kaa 'mlɔnmlɔn dɩ. 'Pian Zozi 'ka -a vɩlɛ Piɛri lɛ 'nan ya'a 'kaa dɩ. Zozi "e 'vɩ 'nan: «-Te an ya "va 'nan 'e 'fʋ -nan -trilii -e 'an 'tadɩ 'e bɔ bɛ, 'yie 'wɩ 'tʋ 'ka 'ji dɩ.» 
\p  
\v 24 Zozi -sruzan zɩɛ, -yɛɛ cɩ 'wɩnun 'gʋɛ -a -nan yɩzan -a, ɛn -yɛɛ crɛn -tɛ. Kʋa -tɔa 'nan 'wɩnun nɛn yaa 'vɩ bɛ 'wɩ 'kpa nɛn. 
\p  
\v 25 Zozi 'wɩ "kaga "pee drɛ "nyian. -Te waa pɛɛnɔn 'crɛn -tɛ paan bɛ, 'an 'ci "nrɔnman 'nan -a 'flubanun 'bɔ 'ka 'sɔa 'trɛ 'gʋɛ -a da "fo "dɩ.