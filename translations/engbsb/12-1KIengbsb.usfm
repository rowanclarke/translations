\v 26 \w Then|strong="H1961"\w* \w the|strong="H5921"\w* \w woman|strong="H3205"\w* \w whose|strong="H1121"\w* \w son|strong="H1121"\w* \w was|strong="H1961"\w* \w alive|strong="H2416"\w* spoke \w to|strong="H4191"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* \w because|strong="H3588"\w* \w she|strong="H3588"\w* \w yearned|strong="H3648"\w* \w with|strong="H5921"\w* \w compassion|strong="H7356"\w* \w for|strong="H3588"\w* \w her|strong="H5414"\w* \w son|strong="H1121"\w*. “Please, \w my|strong="H5414"\w* lord,” \w she|strong="H3588"\w* said, “\w give|strong="H5414"\w* \w her|strong="H5414"\w* \w the|strong="H5921"\w* \w living|strong="H2416"\w* \w baby|strong="H1121"\w*. Do \w not|strong="H3808"\w* \w kill|strong="H4191"\w* \w him|strong="H5414"\w*!”  
\b  
\m \w But|strong="H3588"\w* \w the|strong="H5921"\w* \w other|strong="H3205"\w* \w woman|strong="H3205"\w* said, “\w He|strong="H3588"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w neither|strong="H3808"\w* \w mine|strong="H5414"\w* \w nor|strong="H3808"\w* \w yours|strong="H5414"\w*. \w Cut|strong="H1504"\w* \w him|strong="H5414"\w* \w in|strong="H5921"\w* \w two|strong="H3808"\w*!”   
\b  
\m
\v 27 \w Then|strong="H6030"\w* \w the|strong="H5414"\w* \w king|strong="H4428"\w* \w gave|strong="H5414"\w* \w his|strong="H5414"\w* ruling: “\w Give|strong="H5414"\w* \w the|strong="H5414"\w* \w living|strong="H2416"\w* baby \w to|strong="H4191"\w* \w the|strong="H5414"\w* first \w woman|strong="H3205"\w*. \w By|strong="H5414"\w* \w no|strong="H3808"\w* \w means|strong="H4191"\w* \w should|strong="H4428"\w* \w you|strong="H5414"\w* \w kill|strong="H4191"\w* \w him|strong="H5414"\w*; \w she|strong="H1931"\w* \w is|strong="H1931"\w* \w his|strong="H5414"\w* mother.”   
\b  
\m
\v 28 \w When|strong="H3588"\w* \w all|strong="H3605"\w* \w Israel|strong="H3478"\w* \w heard|strong="H8085"\w* \w of|strong="H4428"\w* \w the|strong="H3605"\w* \w judgment|strong="H4941"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w had|strong="H3478"\w* \w given|strong="H8085"\w*, \w they|strong="H3588"\w* \w stood|strong="H4428"\w* \w in|strong="H3478"\w* \w awe|strong="H3372"\w* \w of|strong="H4428"\w* \w him|strong="H6440"\w*, \w for|strong="H3588"\w* \w they|strong="H3588"\w* \w saw|strong="H7200"\w* \w that|strong="H3588"\w* \w the|strong="H3605"\w* \w wisdom|strong="H2451"\w* \w of|strong="H4428"\w* \w God|strong="H2451"\w* \w was|strong="H3478"\w* \w in|strong="H3478"\w* \w him|strong="H6440"\w* \w to|strong="H3478"\w* \w administer|strong="H6213"\w* \w justice|strong="H4941"\w*.   
\c 4  
\s1 Solomon’s Princes  
\m
\v 1 \w So|strong="H1961"\w* \w King|strong="H4428"\w* \w Solomon|strong="H8010"\w* \w ruled|strong="H4428"\w* \w over|strong="H5921"\w* \w Israel|strong="H3478"\w*,  
\v 2 \w and|strong="H1121"\w* these \w were|strong="H1121"\w* \w his|strong="H3548"\w* \w chief|strong="H8269"\w* \w officials|strong="H8269"\w*:  
\b  
\li1 Azariah son of Zadok was the priest;   
\b  
\li1
\v 3 Elihoreph and Ahijah, the sons of Shisha,\f + \fr 4:3 \ft Shisha is also called Seraiah, Sheva, and Shavsha; see 2 Samuel 8:17, 2 Samuel 20:25, and 1 Chronicles 18:16.\f* were secretaries;  
\b  
\li1 Jehoshaphat son of Ahilud was the recorder;   
\b  
\li1
\v 4 Benaiah son of Jehoiada was in charge of the army;  
\b  
\li1 Zadok and Abiathar were priests;   
\b  
\li1
\v 5 Azariah son of Nathan was in charge of the governors;  
\b  
\li1 Zabud son of Nathan was a priest and adviser to the king;   
\b  
\li1
\v 6 Ahishar was in charge of the palace;  
\b  
\li1 and Adoniram \f + \fr 4:6 \ft Adoniram is a variant of Adoram and Hadoram; see 2 Samuel 20:24 and 2 Chronicles 10:18.\f* son of Abda was in charge of the forced labor.   
\s1 Solomon’s Twelve Officers  
\b  
\m
\v 7 \w Solomon|strong="H8010"\w* \w had|strong="H1961"\w* \w twelve|strong="H8147"\w* governors \w over|strong="H5921"\w* \w all|strong="H3605"\w* \w Israel|strong="H3478"\w* \w to|strong="H3478"\w* \w provide|strong="H3557"\w* \w food|strong="H1004"\w* \w for|strong="H5921"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w and|strong="H3478"\w* \w his|strong="H3605"\w* \w household|strong="H1004"\w*. \w Each|strong="H3605"\w* \w one|strong="H3605"\w* \w would|strong="H3478"\w* arrange provisions \w for|strong="H5921"\w* \w one|strong="H3605"\w* \w month|strong="H2320"\w* \w of|strong="H4428"\w* \w the|strong="H3605"\w* \w year|strong="H8141"\w*,  
\v 8 \w and|strong="H2022"\w* these \w were|strong="H2022"\w* their \w names|strong="H8034"\w*:  
\b  
\li1 Ben-hur in the hill country of Ephraim;   
\b  
\li1
\v 9 Ben-deker in Makaz, in Shaalbim, in Beth-shemesh, and in Elon-beth-hanan;   
\b  
\li1
\v 10 Ben-hesed in Arubboth (Socoh and all the land of Hepher belonged to him);   
\b  
\li1
\v 11 Ben-abinadab in Naphath-dor \f + \fr 4:11 \ft Or in all the heights of Dor; Naphath-dor is a variant of Naphoth-dor; see Joshua 11:2.\f* (Taphath, a daughter of Solomon, was his wife);   
\b  
\li1
\v 12 Baana son of Ahilud in Taanach, in Megiddo, and in all of Beth-shean next to Zarethan below Jezreel, from Beth-shean to Abel-meholah and on past Jokmeam;   
\b  
\li1
\v 13 Ben-geber in Ramoth-gilead (the villages of Jair son of Manasseh in Gilead belonged to him, as well as the region of Argob in Bashan with its sixty great cities with walls and bronze bars);   
\b  
\li1
\v 14 Ahinadab son of Iddo in Mahanaim;   
\b  
\li1
\v 15 Ahimaaz in Naphtali (he had married Basemath, a daughter of Solomon);   
\b  
\li1
\v 16 Baana son of Hushai in Asher and in Aloth;   
\b  
\li1
\v 17 Jehoshaphat son of Paruah in Issachar;   
\b  
\li1
\v 18 Shimei son of Ela in Benjamin;   
\b  
\li1
\v 19 Geber son of Uri in the land of Gilead, including the territories of Sihon king of the Amorites and of Og king of Bashan.  
\b  
\m There \w was|strong="H4428"\w* \w also|strong="H4428"\w* \w one|strong="H1121"\w* governor \w in|strong="H4428"\w* \w the|strong="H1121"\w* land \w of|strong="H1121"\w* Judah.\f + \fr 4:19 \ft Some LXX manuscripts; Hebrew And he was the one governor in the land.\f*   
\s1 Solomon’s Prosperity  
\b  
\m
\v 20 \w The|strong="H5921"\w* people \w of|strong="H7230"\w* \w Judah|strong="H3063"\w* \w and|strong="H3063"\w* \w Israel|strong="H3478"\w* \w were|strong="H3478"\w* \w as|strong="H7230"\w* \w numerous|strong="H7227"\w* \w as|strong="H7230"\w* \w the|strong="H5921"\w* \w sand|strong="H2344"\w* \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w seashore|strong="H3220"\w*, \w and|strong="H3063"\w* \w they|strong="H5921"\w* \w were|strong="H3478"\w* eating \w and|strong="H3063"\w* \w drinking|strong="H8354"\w* \w and|strong="H3063"\w* \w rejoicing|strong="H8056"\w*.  
\v 21 And Solomon reigned over all the kingdoms from the Euphrates \f + \fr 4:21 \ft Hebrew the River; also in verse 24\f* to the land of the Philistines, as far as the border of Egypt. These kingdoms offered tribute and served Solomon all the days of his life.   
\b  
\m
\v 22 Solomon’s provisions for \w a|strong="H3068"\w* single day were thirty cors of fine flour,\f + \fr 4:22 \ft 30 cors is approximately 187 bushels or 6,600 liters (probably about 5.5 tons or 5 metric tons of flour).\f* sixty cors of meal,\f + \fr 4:22 \ft 60 cors is approximately 375 bushels or 13,200 liters (probably about 11 tons or 10 metric tons of meal).\f*  
\v 23 ten fat oxen, twenty range oxen, and \w a|strong="H3068"\w* hundred sheep, as well as deer, gazelles, roebucks, and fattened poultry.  
\v 24 For Solomon had dominion over everything west of the Euphrates \f + \fr 4:24 \ft Or beyond the River\f*—over all the kingdoms from Tiphsah to Gaza—and he had peace on all sides.  
\v 25 Throughout the days of Solomon, Judah and Israel dwelt securely from Dan to Beersheba, each man under his own vine and his own fig tree.   
\b  
\m
\v 26 Solomon had 4,000 \f + \fr 4:26 \ft Some LXX manuscripts (see also 2 Chronicles 9:25); Hebrew 40,000 \f* stalls for his chariot horses and 12,000 horses.\f + \fr 4:26 \ft Or horsemen or charioteers\f*  
\v 27 Each month the governors in turn provided food for King Solomon and all who came to his table. They saw to it that nothing was lacking.  
\v 28 Each one also brought to the required place their quotas of barley and straw for the chariot horses and other horses.   
\s1 Solomon’s Wisdom  
\b  
\m
\v 29 And God gave Solomon wisdom, exceedingly deep insight, and understanding beyond measure, like the sand on the seashore.  
\v 30 Solomon’s wisdom was greater than that of all the men of the East, greater than all the wisdom of Egypt.  
\v 31 He was wiser than all men—wiser than Ethan the Ezrahite, and wiser than Heman, Calcol, and Darda, the sons of Mahol. And his fame spread throughout the surrounding nations.   
\b  
\m
\v 32 Solomon composed three thousand proverbs, and his songs numbered \w a|strong="H3068"\w* thousand and five.  
\v 33 He spoke of trees, from the cedar in Lebanon to the hyssop growing in the wall, and he taught about animals, birds, reptiles, and fish.   
\b  
\m
\v 34 So men of all nations came to listen to Solomon’s wisdom, sent by all the kings of the earth, who had heard of his wisdom.   
\c 5  
\s1 Preparations for the Temple  
\r (2 Chronicles 2:1–10)  
\m
\v 1 \w Now|strong="H1961"\w* \w when|strong="H1961"\w* Hiram king \w of|strong="H3117"\w* Tyre heard \w that|strong="H3605"\w* \w Solomon|strong="H8010"\w* \w had|strong="H1961"\w* \w been|strong="H1961"\w* anointed king \w in|strong="H3117"\w* \w his|strong="H3605"\w* father’s \w place|strong="H1961"\w*, \w he|strong="H3117"\w* sent envoys \w to|strong="H5704"\w* \w Solomon|strong="H8010"\w*; \w for|strong="H5704"\w* Hiram \w had|strong="H1961"\w* \w always|strong="H3605"\w* \w been|strong="H1961"\w* \w a|strong="H3068"\w* friend \w of|strong="H3117"\w* \w David|strong="H3117"\w*.   
\b  
\m
\v 2 \w And|strong="H3117"\w* \w Solomon|strong="H8010"\w* relayed \w this|strong="H3117"\w* message \w to|strong="H1961"\w* Hiram:   
\b  
\pmo
\v 3 “As you \w are|strong="H1241"\w* well aware, due \w to|strong="H6242"\w* \w the|strong="H3967"\w* wars waged on all sides against my father David, \w he|strong="H1241"\w* could not build \w a|strong="H3068"\w* house \w for|strong="H1241"\w* \w the|strong="H3967"\w* Name \w of|strong="H6629"\w* \w the|strong="H3967"\w* \w LORD|strong="H3068"\w* his God until \w the|strong="H3967"\w* \w LORD|strong="H3068"\w* \w had|strong="H6629"\w* put his enemies under his feet.  
\v 4 \w But|strong="H3588"\w* \w now|strong="H1961"\w* \w the|strong="H3605"\w* \w LORD|strong="H3068"\w* \w my|strong="H3605"\w* God \w has|strong="H1961"\w* given \w me|strong="H1961"\w* \w rest|strong="H7965"\w* \w on|strong="H1961"\w* \w every|strong="H3605"\w* \w side|strong="H5676"\w*, \w and|strong="H4428"\w* \w there|strong="H1961"\w* \w is|strong="H1931"\w* \w no|strong="H3605"\w* adversary \w or|strong="H5704"\w* crisis.   
\b  
\pmo
\v 5 \w So|strong="H3427"\w* behold, \w I|strong="H3117"\w* plan \w to|strong="H5704"\w* build \w a|strong="H3068"\w* house \w for|strong="H5704"\w* \w the|strong="H3605"\w* Name \w of|strong="H3117"\w* \w the|strong="H3605"\w* \w LORD|strong="H3068"\w* \w my|strong="H3605"\w* God, according \w to|strong="H5704"\w* what \w the|strong="H3605"\w* \w LORD|strong="H3068"\w* said \w to|strong="H5704"\w* \w my|strong="H3605"\w* father \w David|strong="H3117"\w*: ‘\w I|strong="H3117"\w* \w will|strong="H3478"\w* put \w your|strong="H3605"\w* son \w on|strong="H3117"\w* \w your|strong="H3605"\w* throne \w in|strong="H3427"\w* \w your|strong="H3605"\w* \w place|strong="H8478"\w*, \w and|strong="H3063"\w* \w he|strong="H3117"\w* \w will|strong="H3478"\w* build \w the|strong="H3605"\w* house \w for|strong="H5704"\w* \w My|strong="H3605"\w* Name.’   
\b  
\pmo
\v 6 \w Now|strong="H1961"\w* \w therefore|strong="H1961"\w*, order \w that|strong="H8010"\w* cedars \w of|strong="H8147"\w* Lebanon \w be|strong="H1961"\w* cut down \w for|strong="H1961"\w* \w me|strong="H1961"\w*. \w My|strong="H1961"\w* servants \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w with|strong="H8147"\w* \w your|strong="H1961"\w* servants, \w and|strong="H5483"\w* \w I|strong="H8147"\w* \w will|strong="H1961"\w* pay \w your|strong="H1961"\w* servants whatever wages \w you|strong="H1961"\w* set, \w for|strong="H1961"\w* \w you|strong="H1961"\w* know \w that|strong="H8010"\w* \w there|strong="H1961"\w* \w are|strong="H5483"\w* none among \w us|strong="H1961"\w* \w as|strong="H1961"\w* skilled \w in|strong="H8010"\w* logging \w as|strong="H1961"\w* \w the|strong="H1961"\w* Sidonians.”   
\s1 Hiram’s Reply to Solomon  
\r (2 Chronicles 2:11–18)  
\b  
\m
\v 7 When Hiram received \w Solomon|strong="H8010"\w*’s \w message|strong="H1697"\w*, \w he|strong="H3605"\w* rejoiced \w greatly|strong="H4428"\w* \w and|strong="H4428"\w* \w said|strong="H1697"\w*, “Blessed \w be|strong="H3808"\w* \w the|strong="H3605"\w* \w LORD|strong="H3068"\w* \w this|strong="H1697"\w* \w day|strong="H2320"\w*! \w He|strong="H3605"\w* \w has|strong="H4428"\w* given David \w a|strong="H3068"\w* wise son \w over|strong="H4428"\w* \w this|strong="H1697"\w* great \w people|strong="H3808"\w*!”  
\v 8 \w Then|strong="H1961"\w* Hiram sent \w a|strong="H3068"\w* reply \w to|strong="H1961"\w* Solomon, saying:  
\b  
\pmo “\w I|strong="H8033"\w* \w have|strong="H1961"\w* \w received|strong="H1961"\w* \w your|strong="H1961"\w* message; \w I|strong="H8033"\w* \w will|strong="H1961"\w* do all \w you|strong="H4725"\w* desire regarding \w the|strong="H1961"\w* cedar \w and|strong="H4941"\w* cypress \f + \fr 5:8 \ft Or pine or juniper or fir; also in verse 10\f* timber.  
\v 9 \w My|strong="H5414"\w* servants \w will|strong="H3820"\w* haul \w the|strong="H5921"\w* logs \w from|strong="H5921"\w* Lebanon \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w Sea|strong="H3220"\w*,\f + \fr 5:9 \ft That is, the Mediterranean Sea, also called the Great Sea\f* \w and|strong="H2451"\w* \w I|strong="H5414"\w* \w will|strong="H3820"\w* float \w them|strong="H5414"\w* \w as|strong="H7235"\w* rafts \w by|strong="H5921"\w* \w sea|strong="H3220"\w* \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w place|strong="H5414"\w* \w you|strong="H5414"\w* specify. There \w I|strong="H5414"\w* \w will|strong="H3820"\w* separate \w the|strong="H5921"\w* logs, \w and|strong="H2451"\w* \w you|strong="H5414"\w* can \w take|strong="H5414"\w* \w them|strong="H5414"\w* \w away|strong="H5414"\w*. \w And|strong="H2451"\w* \w in|strong="H5921"\w* \w exchange|strong="H5414"\w*, \w you|strong="H5414"\w* can meet \w my|strong="H5414"\w* needs \w by|strong="H5921"\w* providing \w my|strong="H5414"\w* household \w with|strong="H5921"\w* food.”   
\b  
\m
\v 10 \w So|strong="H7235"\w* Hiram \w provided|strong="H7235"\w* \w Solomon|strong="H8010"\w* \w with|strong="H4714"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* cedar \w and|strong="H1121"\w* cypress timber \w he|strong="H3605"\w* wanted,  
\v 11 \w and|strong="H1121"\w* \w year|strong="H1121"\w* \w after|strong="H1961"\w* \w year|strong="H1121"\w* Solomon \w would|strong="H8034"\w* provide Hiram \w with|strong="H3605"\w* 20,000 cors \w of|strong="H1121"\w* wheat \f + \fr 5:11 \ft 20,000 cors is approximately 124,800 bushels or 4.4 million liters (probably about 3,800 tons or 3,400 metric tons of wheat).\f* \w as|strong="H1961"\w* food \w for|strong="H8034"\w* \w his|strong="H3605"\w* household, \w as|strong="H1961"\w* well \w as|strong="H1961"\w* 20,000 baths \w of|strong="H1121"\w* pure olive oil.\f + \fr 5:11 \ft LXX (see also 2 Chronicles 2:10); 20,000 baths is approximately 116,000 gallons or 440,000 liters of olive oil; Hebrew twenty cors of pure oil or twenty cors of pressed oil\f*   
\b  
\m
\v 12 \w And|strong="H2568"\w* \w the|strong="H1961"\w* \w LORD|strong="H3068"\w* \w gave|strong="H1696"\w* Solomon wisdom, \w as|strong="H1961"\w* \w He|strong="H2568"\w* \w had|strong="H1961"\w* \w promised|strong="H1696"\w* \w him|strong="H1961"\w*. \w There|strong="H1961"\w* \w was|strong="H1961"\w* peace between Hiram \w and|strong="H2568"\w* Solomon, \w and|strong="H2568"\w* \w the|strong="H1961"\w* two \w of|strong="H7892"\w* \w them|strong="H1961"\w* \w made|strong="H1696"\w* \w a|strong="H3068"\w* treaty.\f + \fr 5:12 \ft Forms of the Hebrew berit are translated in most passages as covenant.\f*   
\s1 Solomon’s Labor Force  
\b  
\m
\v 13 \w Then|strong="H1696"\w* \w King|strong="H5921"\w* Solomon conscripted \w a|strong="H3068"\w* labor force \w of|strong="H4480"\w* 30,000 men \w from|strong="H4480"\w* \w all|strong="H5704"\w* Israel.  
\v 14 \w He|strong="H3605"\w* sent \w them|strong="H8085"\w* \w to|strong="H8085"\w* Lebanon \w in|strong="H4428"\w* monthly shifts \w of|strong="H4428"\w* 10,000 \w men|strong="H5971"\w*, \w so|strong="H8085"\w* \w that|strong="H5971"\w* \w they|strong="H5971"\w* \w would|strong="H5971"\w* spend \w one|strong="H3605"\w* month \w in|strong="H4428"\w* Lebanon \w and|strong="H4428"\w* two months \w at|strong="H4428"\w* home. \w And|strong="H4428"\w* Adoniram \w was|strong="H4428"\w* \w in|strong="H4428"\w* charge \w of|strong="H4428"\w* \w the|strong="H3605"\w* forced labor.   
\b  
\m
\v 15 \w Solomon|strong="H8010"\w* \w had|strong="H1961"\w* 70,000 porters \w and|strong="H7971"\w* 80,000 stonecutters \w in|strong="H4428"\w* \w the|strong="H3605"\w* mountains,  
\v 16 not including \w his|strong="H7971"\w* 3,300 \f + \fr 5:16 \ft Hebrew; some LXX manuscripts 3,600; see 2 Chronicles 2:18.\f* foremen who supervised \w the|strong="H7971"\w* workers.   
\b  
\m
\v 17 \w And|strong="H3068"\w* \w the|strong="H6440"\w* \w king|strong="H6440"\w* commanded \w them|strong="H5414"\w* \w to|strong="H5704"\w* quarry \w large|strong="H1004"\w*, costly stones \w to|strong="H5704"\w* \w lay|strong="H5414"\w* \w the|strong="H6440"\w* foundation \w of|strong="H1004"\w* \w the|strong="H6440"\w* \w temple|strong="H1004"\w* \w with|strong="H1004"\w* dressed stones.  
\v 18 \w So|strong="H6258"\w* Solomon’s \w and|strong="H3068"\w* Hiram’s builders, along \w with|strong="H3068"\w* \w the|strong="H3068"\w* Gebalites, quarried \w the|strong="H3068"\w* stone \w and|strong="H3068"\w* prepared \w the|strong="H3068"\w* timber \w and|strong="H3068"\w* stone \w for|strong="H3068"\w* \w the|strong="H3068"\w* construction \w of|strong="H3068"\w* \w the|strong="H3068"\w* temple.   
\c 6  
\s1 Temple Construction Begins  
