\v 19 \sig \+w This|strong="G3588"\+w* \+w is|strong="G3588"\+w* \+w me|strong="G1473"\+w*, \+w Paul|strong="G3972"\+w*, \+w writing|strong="G1125"\+w* \+w this|strong="G3588"\+w* \+w with|strong="G2532"\+w* \+w my|strong="G1699"\+w* \+w own|strong="G1699"\+w* \+w hand|strong="G5495"\+w* \+w so|strong="G2443"\+w* \+w you|strong="G4771"\+w* \+w can|strong="G3004"\+w* \+w be|strong="G2532"\+w* sure \+w I|strong="G1473"\+w* \+w mean|strong="G3004"\+w* \+w it|strong="G2532"\+w*, \+w I|strong="G1473"\+w* \+w will|strong="G2532"\+w* pay \+w that|strong="G3754"\+w* money back \+w to|strong="G2443"\+w* \+w you|strong="G4771"\+w*.\sig* \w But|strong="G2532"\w* remember \w you|strong="G4771"\w* already got \w a|strong="G2532"\w* lot \w from|strong="G2532"\w* \w me|strong="G1473"\w*. \w I|strong="G1473"\w* \w told|strong="G3004"\w* \w you|strong="G4771"\w* \w about|strong="G3754"\w* \w Jesus|strong="G3004"\w*, \w and|strong="G2532"\w* \w he|strong="G2532"\w* \w gave|strong="G2532"\w* \w you|strong="G4771"\w* real life.   
\p
