\c 1
\s1 Recuento histórico
\p 
\v 1 Éstas son las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* \w Moisés|strong="H4872"\w* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* en \w el|strong="H3605"\w* \w desierto|strong="H4057"\w* al otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*, en \w el|strong="H3605"\w* Arabá frente \w a|strong="H3068"\w* Suf, entre \w Parán|strong="H6290"\w*, Tofel, \w Labán|strong="H3837"\w*, Hazerot y Di-zahab.
\v 2 Hay 11 \w jornadas|strong="H3117"\w* \w desde|strong="H5704"\w* \w Horeb|strong="H2722"\w* \w por|strong="H1870"\w* el \w camino|strong="H1870"\w* \w de|strong="H5704"\w* la montaña \w de|strong="H5704"\w* \w Seir|strong="H8165"\w* \w hasta|strong="H5704"\w* Cades Barnea.
\p 
\v 3 \w El|strong="H3605"\w* primero del \w mes|strong="H2320"\w* \w undécimo|strong="H6249"\w* del \w año|strong="H8141"\w* 40, \w sucedió|strong="H1961"\w* \w que|strong="H1121"\w* \w Moisés|strong="H4872"\w* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* le \w ordenó|strong="H6680"\w* \w acerca|strong="H1696"\w* \w de|strong="H1121"\w* \w ellos|strong="H3605"\w*,
\v 4 \w después|strong="H3427"\w* de derrotar \w a|strong="H3068"\w* \w Sehón|strong="H5511"\w*, \w rey|strong="H4428"\w* amorreo, que \w habitaba|strong="H3427"\w* \w en|strong="H5221"\w* \w Hesbón|strong="H2809"\w*, y de vencer \w en|strong="H5221"\w* Edrei \w a|strong="H3068"\w* \w Og|strong="H5747"\w*, \w rey|strong="H4428"\w* de \w Basán|strong="H1316"\w*, quien \w vivía|strong="H3427"\w* \w en|strong="H5221"\w* Astarot,
\v 5 al otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w* en \w la|strong="H2063"\w* tierra de \w Moab|strong="H4124"\w*.
\p \w Moisés|strong="H4872"\w* comenzó \w a|strong="H3068"\w* explicar \w esta|strong="H2063"\w* \w Ley|strong="H8451"\w*:
\v 6 \nd \w Yavé|strong="H3068"\w*\nd* nuestro \nd ʼElohim\nd* nos \w habló|strong="H1696"\w* en \w Horeb|strong="H2722"\w*: \wj Bastante tiempo permanecieron en \w esta|strong="H2088"\w* montaña. \wj*
\v 7 \wj Vuelvan \w y|strong="H5704"\w* vayan \w a|strong="H3068"\w* \w la|strong="H3605"\w* montaña del amorreo, \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* lugares circunvecinos \w en|strong="H5704"\w* \w el|strong="H3605"\w* Arabá, \w en|strong="H5704"\w* \w la|strong="H3605"\w* región montañosa, \w en|strong="H5704"\w* \w los|strong="H3605"\w* valles, \w en|strong="H5704"\w* \w el|strong="H3605"\w* Neguev, \w en|strong="H5704"\w* \w la|strong="H3605"\w* costa del \w mar|strong="H3220"\w*, \w a|strong="H3068"\w* \w la|strong="H3605"\w* tierra del \w cananeo|strong="H3669"\w*, \w al|strong="H5704"\w* \w Líbano|strong="H3844"\w* \w y|strong="H5704"\w* \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w gran|strong="H1419"\w* \w río|strong="H5104"\w* \w Éufrates|strong="H6578"\w*. \wj*
\v 8 \wj Miren que \w pongo|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ustedes la tierra que \nd \w Yavé|strong="H3068"\w*\nd* \w juró|strong="H7650"\w* \w a|strong="H3068"\w* sus antepasados, Abraham, \w Isaac|strong="H3327"\w* y \w Jacob|strong="H3290"\w*, que la \w daría|strong="H5414"\w* \w a|strong="H3068"\w* ellos y después \w de|strong="H6440"\w* ellos \w a|strong="H3068"\w* su \w descendencia|strong="H2233"\w*. Entren y tomen posesión \w de|strong="H6440"\w* la tierra. \wj*
\p 
\v 9 En \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* les hablé: Yo \w solo|strong="H1931"\w* \w no|strong="H3808"\w* \w puedo|strong="H3201"\w* llevarlos.
\v 10 \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd* los \w multiplicó|strong="H7235"\w* \w mucho|strong="H7235"\w*, y \w ciertamente|strong="H2009"\w* \w hoy|strong="H3117"\w* son como la \w multitud|strong="H7230"\w* de las \w estrellas|strong="H3556"\w* en el \w cielo|strong="H8064"\w*.
\v 11 \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* \w de|strong="H5921"\w* sus antepasados, \w los|strong="H5921"\w* aumente 1.000 \w veces|strong="H6471"\w* \w más|strong="H3254"\w* \w de|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* son \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w bendiga|strong="H1288"\w* tal \w como|strong="H5921"\w* \w les|strong="H5921"\w* \w habló|strong="H1696"\w*.
\v 12 Pero ¿cómo puedo yo solo soportar sus problemas, la \w carga|strong="H4853"\w* de ustedes y su contención?
\v 13 Denme de sus \w tribus|strong="H7626"\w* varones \w sabios|strong="H2450"\w*, \w entendidos|strong="H3045"\w* y expertos, \w a|strong="H3068"\w* quienes yo designe como sus \w jefes|strong="H7218"\w*.
\p 
\v 14 \w Y|strong="H3068"\w* me \w respondieron|strong="H6030"\w*: \w Bueno|strong="H2896"\w* \w es|strong="H1697"\w* \w hacer|strong="H6213"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* \w dijiste|strong="H1696"\w*.
\p 
\v 15 \w Tomé|strong="H3947"\w*, pues, \w los|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* sus \w tribus|strong="H7626"\w*, varones \w sabios|strong="H2450"\w* \w y|strong="H5921"\w* expertos, \w y|strong="H5921"\w* \w los|strong="H5921"\w* designé \w como|strong="H5921"\w* sus caudillos, \w como|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* miles, centenas, cincuentenas \w y|strong="H5921"\w* decenas, \w y|strong="H5921"\w* \w como|strong="H5921"\w* \w oficiales|strong="H7860"\w* \w de|strong="H5921"\w* sus \w tribus|strong="H7626"\w*.
\v 16 \w Entonces|strong="H6256"\w* \w mandé|strong="H6680"\w* \w a|strong="H3068"\w* \w sus|strong="H1931"\w* \w jueces|strong="H8199"\w*: \w Escuchen|strong="H8085"\w* \w a|strong="H3068"\w* \w sus|strong="H1931"\w* hermanos y juzguen \w justamente|strong="H6664"\w* entre un hombre y \w su|strong="H1931"\w* hermano, \w o|strong="H3068"\w* \w el|strong="H1931"\w* \w extranjero|strong="H1616"\w* \w que|strong="H1931"\w* \w está|strong="H1931"\w* con \w él|strong="H1931"\w*.
\v 17 \w No|strong="H3808"\w* hagan distinción \w de|strong="H4480"\w* personas \w en|strong="H4480"\w* \w el|strong="H1931"\w* \w juicio|strong="H4941"\w*. \w Escuchen|strong="H8085"\w* tanto \w al|strong="H4480"\w* \w pequeño|strong="H6996"\w* \w como|strong="H3588"\w* \w al|strong="H4480"\w* \w grande|strong="H1419"\w*. \w No|strong="H3808"\w* \w se|strong="H1931"\w* intimiden \w delante|strong="H6440"\w* \w de|strong="H4480"\w* \w ningún|strong="H3808"\w* hombre, \w porque|strong="H3588"\w* \w el|strong="H1931"\w* \w juicio|strong="H4941"\w* pertenece \w a|strong="H3068"\w* \nd ʼElohim\nd*. \w La|strong="H1931"\w* \w causa|strong="H1697"\w* \w que|strong="H3588"\w* les sea demasiado difícil \w la|strong="H1931"\w* traerán \w a|strong="H3068"\w* mí \w y|strong="H3588"\w* \w yo|strong="H4480"\w* \w la|strong="H1931"\w* \w oiré|strong="H8085"\w*.
\v 18 En \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w les|strong="H6680"\w* prescribí \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* debían \w hacer|strong="H6213"\w*.
\p 
\v 19 \w Así|strong="H1931"\w* \w que|strong="H1931"\w* salimos \w de|strong="H5704"\w* \w Horeb|strong="H2722"\w* \w y|strong="H5704"\w* recorrimos \w todo|strong="H3605"\w* \w aquel|strong="H1931"\w* vasto \w y|strong="H5704"\w* \w terrible|strong="H3372"\w* \w desierto|strong="H4057"\w* \w que|strong="H1931"\w* ustedes \w vieron|strong="H7200"\w* \w en|strong="H5704"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* \w hacia|strong="H1870"\w* \w la|strong="H1931"\w* región montañosa del amorreo, tal \w como|strong="H5704"\w* \nd \w Yavé|strong="H3068"\w*\nd* nuestro \nd ʼElohim\nd* nos \w ordenó|strong="H6680"\w*, \w y|strong="H5704"\w* llegamos \w a|strong="H3068"\w* Cades Barnea.
\v 20 Entonces les dije: Llegaron ustedes \w a|strong="H3068"\w* la región montañosa del amorreo, la cual \nd \w Yavé|strong="H3068"\w*\nd* nuestro \nd ʼElohim\nd* está \w a|strong="H3068"\w* punto \w de|strong="H5704"\w* darnos.
\v 21 Miren, \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd* colocó esta tierra \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ustedes. Suban y tomen posesión, tal como \nd \w Yavé|strong="H3068"\w*\nd* el \nd ʼElohim\nd* \w de|strong="H6440"\w* sus antepasados les \w habló|strong="H1696"\w*. \w No|strong="H6440"\w* \w teman|strong="H3372"\w* ni se acobarden.
\p 
\v 22 \w Todos|strong="H3605"\w* ustedes acudieron \w a|strong="H3068"\w* mí, y \w dijeron|strong="H1697"\w*: \w Enviemos|strong="H7971"\w* varones \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w nosotros|strong="H3605"\w* para \w que|strong="H1697"\w* exploren \w la|strong="H3605"\w* tierra, nos informen \w acerca|strong="H1697"\w* del \w camino|strong="H1870"\w* \w por|strong="H1870"\w* \w el|strong="H3605"\w* cual debemos \w subir|strong="H5927"\w*, y \w de|strong="H6440"\w* las \w ciudades|strong="H5892"\w* en las cuales entraremos.
\v 23 \w Me|strong="H4480"\w* \w pareció|strong="H5869"\w* acertado el \w consejo|strong="H1697"\w*, \w por|strong="H4480"\w* \w lo|strong="H1697"\w* cual \w tomé|strong="H3947"\w* 12 varones \w de|strong="H4480"\w* \w entre|strong="H4480"\w* ustedes, un varón \w por|strong="H4480"\w* \w cada|strong="H1697"\w* \w tribu|strong="H7626"\w*,
\v 24 quienes \w salieron|strong="H5927"\w*. \w Al|strong="H5704"\w* \w subir|strong="H5927"\w* \w a|strong="H3068"\w* la montaña llegaron \w hasta|strong="H5704"\w* el \w arroyo|strong="H5158"\w* \w de|strong="H5704"\w* Escol \w y|strong="H5704"\w* exploraron la tierra.
\v 25 \w Tomaron|strong="H3947"\w* \w fruto|strong="H6529"\w* \w de|strong="H1697"\w* la tierra en sus \w manos|strong="H3027"\w* y nos \w lo|strong="H1697"\w* \w llevaron|strong="H3947"\w*. Nos informaron y \w dijeron|strong="H1697"\w*: ¡La tierra \w que|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd* nuestro \nd ʼElohim\nd* nos \w da|strong="H5414"\w* \w es|strong="H3027"\w* \w buena|strong="H2896"\w*!
\p 
\v 26 Pero \w no|strong="H3808"\w* quisieron entrar, \w sino|strong="H3808"\w* \w se|strong="H3808"\w* rebelaron contra el \w mandamiento|strong="H6310"\w* de \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*.
\v 27 Murmuraron \w en|strong="H3318"\w* sus tiendas y dijeron: Porque nos aborrece \nd \w Yavé|strong="H3068"\w*\nd* nos \w sacó|strong="H3318"\w* \w de|strong="H5414"\w* la tierra \w de|strong="H5414"\w* \w Egipto|strong="H4714"\w* \w para|strong="H5414"\w* entregarnos \w en|strong="H3318"\w* \w mano|strong="H3027"\w* del amorreo \w para|strong="H5414"\w* destruirnos.
\v 28 ¿\w A|strong="H3068"\w* \w dónde|strong="H8033"\w* \w subiremos|strong="H5927"\w*? Nuestros hermanos desmayaron nuestro \w corazón|strong="H3824"\w* \w al|strong="H4480"\w* decir: Este \w pueblo|strong="H5971"\w* es \w más|strong="H4480"\w* \w grande|strong="H1419"\w* \w y|strong="H1571"\w* \w más|strong="H4480"\w* \w alto|strong="H7311"\w* \w que|strong="H4480"\w* nosotros. Las \w ciudades|strong="H5892"\w* son \w grandes|strong="H1419"\w* \w y|strong="H1571"\w* amuralladas hasta \w el|strong="H1121"\w* \w cielo|strong="H8064"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w vimos|strong="H7200"\w* \w allí|strong="H8033"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Anac.
\p 
\v 29 Entonces \w les|strong="H1992"\w* dije: \w No|strong="H3808"\w* tengan \w temor|strong="H3372"\w* ante \w ellos|strong="H1992"\w*,
\v 30 \w porque|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w su|strong="H1931"\w* \nd ʼElohim\nd* \w va|strong="H3068"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ustedes. \w Él|strong="H1931"\w* \w peleará|strong="H3898"\w* \w por|strong="H6440"\w* ustedes, \w así|strong="H1931"\w* \w como|strong="H1931"\w* \w lo|strong="H1931"\w* \w hizo|strong="H6213"\w* \w por|strong="H6440"\w* ustedes en \w Egipto|strong="H4714"\w* \w ante|strong="H6440"\w* \w sus|strong="H1931"\w* propios \w ojos|strong="H5869"\w*.
\v 31 \w También|strong="H2088"\w* \w en|strong="H5704"\w* \w el|strong="H3605"\w* \w desierto|strong="H4057"\w*, \w donde|strong="H4725"\w* \w vieron|strong="H7200"\w* \w cómo|strong="H5704"\w* \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd* \w los|strong="H1121"\w* \w llevó|strong="H5375"\w* \w como|strong="H5704"\w* un \w hombre|strong="H1121"\w* \w lleva|strong="H5375"\w* \w a|strong="H3068"\w* su propio \w hijo|strong="H1121"\w*, \w en|strong="H5704"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w* \w que|strong="H5704"\w* \w anduvieron|strong="H1980"\w* \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* llegaron \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*.
\p 
\v 32 Pero ni aun con \w esto|strong="H2088"\w* creyeron \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*,
\v 33 Quien \w iba|strong="H1980"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ustedes \w en|strong="H3212"\w* el \w camino|strong="H1870"\w* con fuego \w de|strong="H6440"\w* \w noche|strong="H3915"\w* y con \w nube|strong="H6051"\w* \w de|strong="H6440"\w* \w día|strong="H3119"\w* para buscarles \w lugar|strong="H4725"\w* \w donde|strong="H4725"\w* acampar y mostrarles el \w camino|strong="H1870"\w* \w por|strong="H1870"\w* \w donde|strong="H4725"\w* debían \w andar|strong="H1980"\w*.
\p 
\v 34 Entonces \nd \w Yavé|strong="H3068"\w*\nd* \w oyó|strong="H8085"\w* la \w voz|strong="H6963"\w* \w de|strong="H1697"\w* sus \w palabras|strong="H1697"\w*, se airó y \w juró|strong="H7650"\w*:
\v 35 \wj Ninguno \w de|strong="H5414"\w* los hombres \w de|strong="H5414"\w* \w esta|strong="H2088"\w* \w perversa|strong="H7451"\w* \w generación|strong="H1755"\w* \w verá|strong="H7200"\w* la \w buena|strong="H2896"\w* tierra \w de|strong="H5414"\w* la cual \w juré|strong="H7650"\w* \w a|strong="H3068"\w* sus antepasados \w que|strong="H2088"\w* se la \w daría|strong="H5414"\w*,\wj*
\v 36 \wj \w excepto|strong="H2108"\w* \w Caleb|strong="H3612"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jefone. \w Él|strong="H1931"\w* \w la|strong="H1931"\w* \w verá|strong="H7200"\w*. \w Daré|strong="H5414"\w* \w la|strong="H1931"\w* tierra \w que|strong="H1931"\w* \w pisó|strong="H1869"\w* \w a|strong="H3068"\w* \w él|strong="H1931"\w* y \w a|strong="H3068"\w* \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w*, \w porque|strong="H3282"\w* siguió con integridad \w a|strong="H3068"\w* \w Yavé|strong="H3068"\w*.\wj*
\p 
\v 37 \w También|strong="H1571"\w* por causa de ustedes \nd \w Yavé|strong="H3068"\w*\nd* \w se|strong="H3808"\w* airó contra mí \w y|strong="H1571"\w* me dijo: \wj \w Tampoco|strong="H1571"\w* tú entrarás \w allá|strong="H8033"\w*.\wj*
\v 38 \wj \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Nun|strong="H5126"\w*, \w quien|strong="H1931"\w* \w está|strong="H1931"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti \w para|strong="H3588"\w* servirte, \w él|strong="H1931"\w* entrará \w allá|strong="H8033"\w*. Anímalo, \w porque|strong="H3588"\w* \w él|strong="H1931"\w* hará \w que|strong="H3588"\w* \w Israel|strong="H3478"\w* \w la|strong="H1931"\w* herede.\wj*
\p 
\v 39 Además \w sus|strong="H1992"\w* pequeños, \w de|strong="H1121"\w* \w los|strong="H1992"\w* cuales ustedes dijeron \w que|strong="H3808"\w* serían una presa, y \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w* \w que|strong="H3808"\w* \w hoy|strong="H3117"\w* \w no|strong="H3808"\w* \w conocen|strong="H3045"\w* \w bien|strong="H2896"\w* \w ni|strong="H3808"\w* \w mal|strong="H7451"\w*, entrarán \w allá|strong="H8033"\w* \w porque|strong="H3808"\w* \w a|strong="H3068"\w* \w ellos|strong="H1992"\w* la \w daré|strong="H5414"\w*. \w Ellos|strong="H1992"\w* la tomarán en posesión.
\v 40 Pero ustedes, devuélvanse y vayan \w hacia|strong="H1870"\w* el \w desierto|strong="H4057"\w* \w por|strong="H1870"\w* el \w camino|strong="H1870"\w* del \w mar|strong="H3220"\w* Rojo.
\p 
\v 41 Entonces me \w respondieron|strong="H6030"\w*: \w Pecamos|strong="H2398"\w* contra \nd \w Yavé|strong="H3068"\w*\nd*. \w Nosotros|strong="H3605"\w* ciertamente \w subiremos|strong="H5927"\w* y \w pelearemos|strong="H3898"\w*, tal como \nd \w Yavé|strong="H3068"\w*\nd* nuestro \nd ʼElohim\nd* nos \w ordenó|strong="H6680"\w*. \w Y|strong="H3068"\w* \w cada|strong="H3605"\w* uno se ató sus \w armas|strong="H3627"\w* \w de|strong="H3898"\w* \w guerra|strong="H4421"\w* y se alistó para \w subir|strong="H5927"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* región montañosa.
\p 
\v 42 \w Pero|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H3588"\w* dijo: \wj Diles: \w No|strong="H3808"\w* suban \w ni|strong="H3808"\w* peleen, \w porque|strong="H3588"\w* \w Yo|strong="H3588"\w* \w no|strong="H3808"\w* estoy \w entre|strong="H7130"\w* ustedes. \w De|strong="H3588"\w* otra manera serán derrotados \w delante|strong="H6440"\w* \w de|strong="H3588"\w* sus enemigos.\wj*
\p 
